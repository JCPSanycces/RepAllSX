#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(30)(1..3) , VALEUR(10)
GACTION = "VALCPC"
PARAM(1) = ""
PARAM(2) = ""
PARAM(3) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"VALCPC2","VALCPC","VALCPC",4,"") From GTRAITE
End

######################################################################################
# Modifications :
#     SYMEU - 04/10/10 - EXI 66191 LOT 10 - V6.1 : stage non défini
#     MABOS - 14/02/13 - FQ 81085-US1330- Add legislation + generic rules
#     MABOS - 11/03/13 - FQ 87514-US1406- From GESHRSES, do not come back to the last selection box
#     MABOS - 22/04/13 - FQ 86015 - US 1531 - improvement traces in mass processing
#     MABOS - 08/08/13 - FQ 81085 - US1833 - manage mémo
######################################################################################

#########################################
## Traitement des actions : SAIVAR
## Saisie des valeurs par variables
#########################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub BOUTON_OK
 When "END"         : Gosub BOUTON_FIN
 When "SETBOUT"     : Gosub SETBOUT
 When "AVANT_BOUTON": Gosub AVANT_BOUTON : #MABOS-FQ81085-US1833 - manage mémo
 When "BOUTON"      : Gosub BOUTON
 # 60564
 When "EXEC"        : Unlock =SYMBOLE
 # MABOS-11/03/13-FQ 87514-US1406-From GESHRSES, do not come back to the last selection box
                      If GFONCTION <> "GESHRSES" Then SAI=1 : Endif
Endcase
Return

#######################################################
$OUVRE
Case GACTION
 When "VALCPC"  : Gosub OUVRECPC
Endcase
Return


$OUVRECPC
# MABON 23/12/10 - On ne peut pas valider n'importe quand
If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
# SEGAY 10/01/13 - 87157 - le Look ne renvoie pas l'enregistrement de la session
#Look [F:HRSES]SES0=PARAM(2)
Read [F:HRSES]SES0=PARAM(2)
If !fstat & datesyst<[F:HRSES]ENDDAT Then
  GMESSAGE=mess(193,10717,1) : # La session doit être terminée pour pouvoir valider compétences et habilitations
  GERR=1
  FIN=1
Endif
Gosub OUVRE From SUBINS
Gosub OUVRE From WPDEFTABLE
If clalev([F:CPE])=0    : Local File CPCEMP     [CPE]   : Endif
If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
If clalev([F:SRV])=0    : Local File SERVICE    [SRV]   : Endif
If clalev([F:PRF])=0    : Local File PROFIL     [PRF]   : Endif
If clalev([F:HRPOA])=0  : Local File POPULA     [HRPOA] : Endif
If clalev([F:CIC])=0    : Local File CSICPC     [CIC]   : Endif
If clalev([F:CPC])=0    : Local File COMPETENCE [CPC]   : Endif
If clalev([F:HRSCA])=0  : Local File SCALE      [HRSCA] : Endif
If clalev([F:ID2])=0    : Local File EMPLOID    [ID2]   : Endif
# MABOS-14/02/2013-FQ 81085-US1331- Add legislation + generic rules
If clalev([F:AGC])=0    : Local File AGRPCPY       [AGC]    : Endif
If clalev([F:AGF])=0    : Local File AGRPFCY       [AGF]    : Endif
If clalev([F:ACC])=0    : Local File ACCES         [ACC]    : Endif

Local Mask VALCPC2 [VC2]
Local Mask VALCPC [DIA]
Raz [M:DIA]
#MABOS-FQ81085-US1833 - manage mémo
If GFONCTION <> "GESHRSES" & GFONCTION <> "GESINS"
  Call INI_LEG From DIVPAYE
  Call LECMEMO("STD","[M:DIA]","vcp") From GMEMO
Endif
#If [M:DIA]LEG<>"" Then GCURLEG=[M:DIA]LEG :Endif
#end MABOS-FQ81085-US1833
Local Char  CRITERE1(250), CRITERE2(250), CRITERE3(250), ZONE (250), SYMBOLE(50)
Local Integer I, J, NBMAX, OKC, FLG
Return

#######################################################
$CONTROLE
Case GACTION
 When "VALCPC" : Gosub CONTCPC
Endcase
Return


$CONTCPC
If GSTATUT=GSTAOK Then
  #MABOS-FQ81085-US1833 - manage mémo
  Local Char WECR(50)
  WECR="VALCPC"
  Gosub CONTROLE_VAL
  If GERR = 1 : Return :Endif
  #end MABOS-FQ81085-US1833 - manage mémo
Endif

If GSTATUT<>GSTAOK
 FIN = 1
Else
 SYMBOLE = "VALCPC"+[M:DIA]STG
 Lock =SYMBOLE
 If fstat
   Call ECR_TRACE([M:DIA]STG-":"-mess(10,100,1),1) From GESECRAN
   FIN=1 : Return
 Endif
 TMP = 1
 TRA = 1
Endif

Return

#MABOS-FQ81085-US1833 - manage mémo
# called from clic on "OK"  or "MEMO"  in Box VALCPC
$CONTROLE_VAL
   If ([M:DIA]DATENDDEB<>[0/0/0] & [M:DIA]DATENDDEB>datesyst) | ([M:DIA]DATENDFIN<>[0/0/0] & [M:DIA]DATENDFIN>datesyst) Then
      GMESSAGE=mess(193,10717,1) : # La session doit être terminée pour pouvoir valider compétences et habilitations
      GMESSAGE+=chr$(13)+mess(298,10717,1) : # Vérifiez votre borne de dates
      GERR=1 : SAI=1 : Return
    Endif

    # MABOS-14/02/2013-FQ 81085-US1331- Add legislation + generic rules
    # - The user is not allowed to mix criteria with different legislations.
    Local Integer WOK
#    Local Char WECR(50)     : # MABOS-FQ81085-US1833 - manage mémo
    Local Char WLIBCOUR(50)
    Local Char WMESSAGE(250)
    Local Char WFIELD(30) (1..4)
    Local Char WLEG(GLONADI) (1..4)
      If dim ([M]LEG)>0  & [M]LEG ="" Then
        WOK=0
        Call GET_LEGSRV([M]SRV,WOK,WLEG(1),0)    From TOOLSHRLEG        :# Service
        Call GET_LEGPRF([M]PRF,WOK, WLEG(2), 0)  From TOOLSHRLEG        :# Profil
        Call GET_LEGPOP([M]POP,WOK, WLEG(3), 0)  From TOOLSHRLEG        :# Population
        Call GET_LEGSTG([M]STG,WOK, WLEG(4), 0)  From TOOLSHRLEG        :# Stage

#        WECR="VALCPC" / WECR="VALHAB"  : # MABOS-FQ81085-US1833 - manage mémo
        WFIELD(1)="SRV"
        WFIELD(2)="PRF"
        WFIELD(3)="POP"
        WFIELD(4)="STG"
        For I =1 To 4
           WFIELD(I)=func TOOLSHRLEG.LIB_FIELD(WECR,WFIELD(I))
        Next

        If  WOK Then

          # Population
          WLIBCOUR = WFIELD(1)
          WLEGCOUR = WLEG(1)
          #
          For I =2 To 4
            Call LEGOK(WLIBCOUR,WLEGCOUR,WFIELD(I),WLEG(I) , WOK,WMESSAGE,0) From TOOLSHRLEG
            If !WOK Then  Break :  Endif
          Next

          If !WOK
            GMESSAGE = WMESSAGE:  GERR=1 : SAI=1 : Return
          Endif
        Endif
      Endif
      #end MABOS-14/02/2013-FQ 81085-US1331- Add legislation + generic rules
Return


$SETBOUT
Case BOITE
 When "VALCPC2"  : Gosub SETBOUTCPC
Endcase
Return

#MABOS-FQ81085-US1833 - manage mémo
$AVANT_BOUTON
  Case BOITE
    When "VALCPC"
     Case BOUT
       When "M" : # Button "Mémo"
         Local Char WECR(50)
         [L]WECR="VALCPC"
         Gosub CONTROLE_VAL
     Endcase
  Endcase
Return
#end MABOS-FQ81085-US1833 - manage mémo

# FQ86194 - MABON 05/02/13 - Nouveaux boutons
#**
#* Boutons "Tout cocher" et "Tout décocher"
#*!
$BOUTON
  Case BOITE
    When "VALCPC2"
      Case BOUT
        When "C" : For I=0 To [M:VC2]NBRINS-1 : [M:VC2]FLGVAL(I)=2 : Next : Affzo [M:VC2]
        When "D" : For I=0 To [M:VC2]NBRINS-1 : [M:VC2]FLGVAL(I)=1 : Next : Affzo [M:VC2]
      Endcase
#    Affzo [M:VC2] : #MABOS-FQ91298-US1835-add on each previous line

    #81085
    When "VALCPC"
     Case BOUT
      When "R" :
      # Button "Rappel MEMO"
      Call AFF_MEMO2(1) From DIVPAYE :#MABOS-FQ81085-US1833 - manage mémo
     Endcase
    #
  Endcase
  #LIPET - X3-62878 - 2017-11-08 - START
  Affzo [M:VC2]
  #LIPET - X3-62878 - 2017-11-08 - END
Return
# Fin MABON

$SETBOUTCPC
#MABOS-14/02/2013-FQ 81085-US1331- Add legislation + generic rules
#-Ne marche pas bien car la zone courante n'est pas encore enregistrée dans les valeurs de FLGVAL
#enlevé car pas géré dans les autres traitements de masse
#If !find (2,[M:VC2]FLGVAL(0..[M:VC2]NBRINS))
# CHBOU=""
#Else
# CHBOU="O"
#Endif
Return

#######################################################
$DEBUT
Case BOITE
 When "VALCPC"
    [M:DIA]LEG=[M:DIA]LEG : # Pour ne pas passer dans SUBADI/INILEG
    # MABOS-14/02/2013-FQ 81085-US1331- Add legislation + generic rules
    # Ne pas réaffecter de valeur après retour de VALCPC2, conserver les derniers critères saisis
    # si STG remplit, ce n'est pas la première ouverture
    If [M:DIA]STG = ""
      If PARAM(1)<>"" Then [M:DIA]STG=PARAM(1) : Endif
      If PARAM(2)<>""
       [M:DIA]ALLSES=1
       [M:DIA]SES=PARAM(2)
       Call LECTURE("HRSES",PARAM(2),"") From CONTOBJ
       [M]DATDEB=[F:HRSES]STRDAT
       [M]DATFIN=[F:HRSES]ENDDAT
       # FQ86194 - MABON 04/02/13 - Si "Toutes sessions" est décochée, on ne doit pas pouvoir sélectionner les bornes de dates de fin
       Grizo [M:DIA]DATENDDEB,DATENDFIN
       # Fin MABON
      Endif
      If PARAM(3)<>"" Then
        [M:DIA]MATDEB=PARAM(3) : [M:DIA]MATFIN=PARAM(3)
      Endif
      #MABOS-FQ81085-US1833 - manage mémo
      #MABOS-14/02/2013-FQ 81085-US1331- Add legislation + generic rules
#      If dim([M:DIA]LEG) >0 :
#       If [M:DIA]LEG="" : [M:DIA]LEG    = GCURLEG : Endif
#       If [M:DIA]LEG="" :  Call AM_CPY([M:DIA]CPY) From DIVPAYE :    Endif
#       If [M:DIA]LEG="" Then [M:DIA]LEG=GLEGFIL : Endif
#       Call AM_LEG([M:DIA]LEG)
#       GCURLEG=[M:DIA]LEG
#      Endif
    Else
     # Come back on the screen after Trt
     If dim([M]LEG)> 0 : GCURLEG=[M]LEG :Endif:
    Endif
    #end-MABOS-14/02/13 -FQ 81085-US1331
    Call AFF_MEMO2(1) From DIVPAYE
    #end MABOS-FQ81085-US1833 - manage mémo
    # FQ72438 - MABON 22/03/11 - Recherche des absences du salarié pendant l'inscription
    If GFONCTION<>"GESINS" Then Grizo [M:DIA]FLGFRC : Endif
    Affzo [DIA]
    Setmok [DIA] With 0

 When "VALCPC2"
   Raz [VC2]
   [M:VC2]STAGE=[M:DIA]STG
   Gosub FILTRE
   Gosub CHARGE_INS
   Affzo[M:VC2]
   If ![M:VC2]NBRINS
    #Aucune compétence à attribuer
    Call ERREUR(mess(10,10720,1)) From GESECRAN : FIN=1
   Endif
Endcase
Return

#######################
$FILTRE
#MABOS-04/03/13
Local Char    LIS_CPY(GLONCPY)(0..100)
Local Integer I

CRITERE1="1=1" : CRITERE2="1=1"
If [M:DIA]ALLCPY<>2
#MABOS-04/03/13
#    CRITERE1 -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
    I=0 : Call CALC_GRPCPY([M:DIA]CPY, LIS_CPY, I) From TOOLSVAR
    If I>0 Then
      CRITERE1 -= "& find([F:FCY]LEGCPY,"
      For K=0 To I-1
        CRITERE1 += "'"+LIS_CPY(K)+"'"
        If K<I-1 Then CRITERE1 += "," : Endif
      Next
      CRITERE1 += ")>0"
    Endif
Endif
If [M:DIA]ALLFCY<>2
 CRITERE1 -= '& [F:HRCTR]ETRFCY = "'+[M:DIA]FCY+'"'
Endif
#MABOS-14/02/2013-FQ 81085-US1331- Add legislation + generic rules
If dim([M:DIA]LEG)>0 & [M:DIA]LEG<>"" : #LEG
  CRITERE1 -= '& [FCY]LEG = "'+[M:DIA]LEG+'"'
Endif
If [M:DIA]ALLSRV<>2  #service
 CRITERE1 -= '& [F:ID]SRV = "'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLPRF<>2  #profil
 CRITERE2 -= '& [F:ID]PRF = "'+[M:DIA]PRF+'"'
Endif
If [M:DIA]MATDEB<>""
 CRITERE2 -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>""
 CRITERE2 -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif

CRITERE3="[F:HRSES]STG='"+[M:DIA]STG+"'"
If [M:DIA]SES<>""
 CRITERE3-="& [F:HRSES]COD='"+[M:DIA]SES+"'"
Endif
#Date de début de session dans la borne saisie
If 1=2
If [M:DIA]DATDEB<>[0/0/0]
 CRITERE3-="& [F:HRSES]STRDAT>=["+ format$("D:"+GFMDAT,[M:DIA]DATDEB)+"]"
 CRITERE3-="& [F:HRSES]STRDAT<=["+ format$("D:"+GFMDAT,[M:DIA]DATFIN)+"]"
Endif
Endif
# FQ86194 - MABON 05/02/13 - On peut sélectionner une borne de dates de fin de session
If [M:DIA]DATENDDEB<>[0/0/0]
 CRITERE3-="& [F:HRSES]ENDDAT>=["+ format$(GFMD,[M:DIA]DATENDDEB)+"]"
Endif
If [M:DIA]DATENDFIN<>[0/0/0]
 CRITERE3-="& [F:HRSES]ENDDAT<=["+ format$(GFMD,[M:DIA]DATENDFIN)+"]"
Endif
# Fin MABON

If [M:DIA]POP<>""
# Link [ID] With [FCY]FCY0 = [F:ID]FCY, [POA]POA0 = [M:DIA]POP;[F:ID]REFNUM As [LNK]
#&   Where evalue(CRITERE1) & evalue(CRITERE2) & [F:POA]REFNUM<>""
#MABOS-14/02/13- index pop
# Link [HRCTR] With [ID]ID0=[F:HRCTR]REFNUM, [FCY]FCY0 = [F:HRCTR]ETRFCY, [HRPOA]POA0 = [M:DIA]POP;[F:ID]REFNUM As [LNK]
#&   Where evalue(CRITERE1) & evalue(CRITERE2) & [F:HRPOA]REFNUM<>""
    Link [HRCTR] With [ID]ID0=[F:HRCTR]REFNUM, [FCY]FCY0 = [F:HRCTR]ETRFCY,
&                     [HRPOA]POA0 ~= [M:DIA]POP;[F:ID]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&     As [LNK] Where evalue(CRITERE1) & evalue(CRITERE2) & [F:HRPOA]REFNUM<>""

Else
# Link [ID] With [FCY]FCY0 = [F:ID]FCY As [LNK] Where evalue(CRITERE1) & evalue(CRITERE2)
 Link [HRCTR] With [F:ID]ID0=[F:HRCTR]REFNUM, [FCY]FCY0 = [F:HRCTR]ETRFCY As [LNK] Where evalue(CRITERE1) & evalue(CRITERE2)
Endif

 Link [INS] With
&   [HRSES]SES0 = [F:INS]SES
&   As [LNK2]

Return

#######################
$CHARGE_INS
Local Integer I, J, NBMAX, OKC, FLG
I=1 : OKC=1 : FLG=0
NBMAX=min(dim([F:INS]CPCAFT), 10)
For [F:LNK]
 Call CONTROLE([F:ID]REFNUM,datesyst,"",[M:DIA]CRI,OKC,FLG) From DIVPAYE
 If OKC
  For [LNK2] Where evalue(CRITERE3) & [F:INS]REFNUM=[F:ID]REFNUM & [F:INS]UPDCPC<>2
   # FQ86194 - MABON 04/02/13 - Critères de sélection supplémentaires :
   #     - Les sessions à venir doivent être exclues
   #     - Seules les inscriptions avec des compétences doivent apparaître
   OKC=1
   If [F:HRSES]ENDDAT>datesyst Then OKC=0 : Endif
   If [F:INS]CPCAFT(0)="" Then OKC=0 : Endif
   # End MABON
   If OKC & !find([F:INS]SES+"~"+[F:INS]REFNUM, [M:VC2]KEYLIG) Then
     [M:VC2]SESSION(I-1)=[F:INS]SES
     [M:VC2]REFNUM(I-1)=[F:INS]REFNUM
     # FQ86194 - MABON 05/02/13 - Ajout date fin session
     [M:VC2]ENDDAT(I-1)=[F:HRSES]ENDDAT
     # Fin MABON
     [M:VC2]KEYLIG(I-1)=[F:INS]SES+"~"+[F:INS]REFNUM
     Call LECTURE("EML",[F:INS]REFNUM,"") From CONTOBJ
     [M:VC2]NAM(I-1)=[F:ID]NAM-[F:ID]SRN
     For J=1 To NBMAX
      ZONE="[M:VC2]CPCAFT"+num$(J)+"(I-1)"
      Assign ZONE With [F:INS]CPCAFT(J-1)
      ZONE="[M:VC2]LEVAFT"+num$(J)+"(I-1)"
      Assign ZONE With [F:INS]LEVAFT(J-1)
     Next J
     # FQ86190 - MABON 04/02/13 - On coche tout par défaut
#     If [F:INS]NBRDAY>0 & [F:INS]CPCAFT(0)<>"" :#Présent et au moins une compétence
#      [M:VC2]FLGVAL(I-1)=2
#     Else
#      [M:VC2]FLGVAL(I-1)=1
#     Endif
     [M:VC2]FLGVAL(I-1)=2
     # Fin MABON
     I+=1
   Endif
  Next
 Endif
Next
[M:VC2]NBRINS=I-1
If [M:VC2]NBRINS
 NOL=0 : Gosub CHARGE_CPC
Endif
Return

$CHARGE_CPC
Effzo [M:VC2]15
For I=0 To dim([F:INS]CPCAFT)-1
 If evalue("[M:VC2]CPCAFT"+num$(I+1)+"("+num$(NOL)+")")="" : Break : Endif
 [M:VC2]WCPCAFT(I)=evalue("[M:VC2]CPCAFT"+num$(I+1)+"("+num$(NOL)+")")
 [M:VC2]WLEVAFT(I)=evalue("[M:VC2]LEVAFT"+num$(I+1)+"("+num$(NOL)+")")
Next
[M:VC2]NBRCPC=I
Return

#######################################################
$BOUTON_OK
Case BOITE
 When "VALCPC2"

  If !GSERVEUR
   #Validation des compétences
   Call OUVRE_TRACE(mess(11,10720,1)) From LECFIC
  Endif
  Call ECR_TRACE(mess(11,10720,1),0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call LIB_CRIT("[M:DIA]","VALCPC")From DIVPAYE :#MABOS-22/04/13-FQ86015-US1531
  Call DEBTRANS From GLOCK
  Gosub TR1

  If !GSERVEUR
   Call FERME_TRACE From LECFIC
   # FQ86194 - MABON 07/02/13 - Lecture de la trace, sinon avec le retour en saisie, on ne la voit pas
   Call LEC_TRACE From LECFIC
  Endif

  FIN = 1
Endcase
Return

#######################################################
$BOUTON_FIN
#MABOS
Case BOITE
 When "VALCPC2"
    FIN = 1
    GOK=0
Endcase
# 60564
#Unlock =SYMBOLE
Return

#######################################################
$TR1
Trbegin [CPE],[INS],[CIC]
#Infos du stage en ligne
Call LECTURE("STG",[M:VC2]STAGE,"") From CONTOBJ
Gosub MAJ_ECP
If   GOK<0 : Goto ROLL_TR1
Elsif !GOK : Goto AB_TR1
Endif
Commit
Return

#######################################################
$AB_TR1
Rollback
GMESSAGE = mess (17,107,1) :#Rollback suite à une erreur dans la transaction
Return

#######################################################
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#######################################################
$MAJ_ECP
Local Integer FLGMOD
GOK=1
For I=0 To [M:VC2]NBRINS-1
 If [M:VC2]FLGVAL(I)=2
  #Infos de la session en ligne
  Call LECTURE("HRSES",[M:VC2]SESSION(I),"") From CONTOBJ
  #Infos de l'inscription en ligne + lock pour MAJ flg
  Readlock [F:INS]INS1=[M:VC2]SESSION(I);[M:VC2]REFNUM(I)
  If !fstat
   Gosub ADD_CPC
   If GOK
    [F:INS]UPDCPC=2
    Rewrite[F:INS]
    If fstat
     GOK = 0 : Call FSTA("INS") From GLOCK
    Endif
    #Attribution de nouvelles compétences effectuée
    Call ECR_TRACE(mess(12,10720,1),0) From GESECRAN
   Else
    #Attribution de nouvelles compétences impossible
    Call ECR_TRACE(mess(13,10720,1),1) From GESECRAN
   Endif
  Endif
 Endif
Next
Return

#######################################################
$ADD_CPC
Local Integer FROM_CSI, II, JJ
Local Char CODCSI(15)
Local Integer MAJ :#MABOS-04/03/13
Local Char WSHOAXX(50) : #MABOS-22/04/13-FQ86015-US1531

Call ECR_TRACE(space$(1),0) From GESECRAN
Read [F:ID2]ID0=[F:INS]REFNUM
Call ECR_TRACE([F:INS]REFNUM-[F:ID2]NAM-[F:ID2]SRN-num$([F:HRSES]ENDDAT)-":",0) From GESECRAN

# FQ72438 - MABON 22/03/11 - Recherche des absences du salarié pendant l'inscription
GOK=0
Filter [F:INA] Where STG=[F:INS]STG & SES=[F:INS]SES & REFNUM=[F:INS]REFNUM
If rowcount([F:INA])>0 Then : # Le collaborateur a été absent pendant la session, on ne peut donc pas valider ses habilitations
  If GFONCTION<>'GESINS' | [M:DIA]FLGFRC<>2 Then
    Filter [F:INA]
    Call ECR_TRACE(mess(232,10717,1), 0) From GESECRAN : # Le salarié a été absent : ses compétences ou habilitations ne peuvent être validées
    Return
  Endif
Endif
Filter [F:INA]
# Fin MABON

GOK=1
# On regarde si l'inscription est liée à une demande, elle-même liée à un parcours individualisé
FROM_CSI=1
If [M:DIA]MAJCSI=2 Then
  If [F:INS]DEM<>"" Then
    Read [F:DEM]DEM0=[F:INS]DEM
    If !fstat & [F:DEM]ORIDEM=2 Then
      FROM_CSI=2
      CODCSI=[F:DEM]CODCSI
    Endif
  Endif
Endif
#53516 : Remplacement de [F:STG]CPCAFT et [F:STG]LEVAFT par [F:INS]CPCAFT et [F:INS]LEVAFT
For J=0 To dim([F:INS]CPCAFT)-1
 [L]WSHOAXX="": #MABOS-22/04/13-FQ86015-US1531
 COPIER=0
 If [F:INS]CPCAFT(J)="" : Break : Endif
 Filter [CPE] Where REFNUM=[F:INS]REFNUM & CPC=[F:INS]CPCAFT(J)
 Read [CPE]CPE1 Last
 Filter [CPE]
 If !fstat
  COPIER = func SUBECP.COMPNIV([F:INS]CPCAFT(J),[F:CPE]LEVCPC,[F:INS]LEVAFT(J))
 Endif
 # 58873 Point d'entrée MAJCPC
 GPOINT = "VALCPC" : Gosub ENTREE From EXEFNC
 If fstat | COPIER=1    :#Si elle n'existe pas ou que le niveau est <
  #MABOS-04/03/13
  [L]MAJ=0
  If COPIER & [F:CPE]CPCDAT=[F:HRSES]ENDDAT Then
    [L]MAJ=1
  Endif
  Raz [F:CPE]
  [F:CPE]REFNUM = [F:INS]REFNUM
  [F:CPE]CPCDAT = [F:HRSES]ENDDAT
  [F:CPE]CPC    = [F:INS]CPCAFT(J)
  [F:CPE]LEVCPC = [F:INS]LEVAFT(J)
  [F:CPE]ORICPC = 2 : # Stage
  If [L]MAJ=1 Then
    If dim([F:CPE]UPDDAT)>0 : [F:CPE]UPDDAT = date$ : Endif
    If dim([F:CPE]UPDUSR)>0 : [F:CPE]UPDUSR = GUSER : Endif
    If dim([F:CPE]UPDTIM)>0 : [F:CPE]UPDTIM = time  : Endif
    Rewrite [CPE]
  Else
    If dim([F:CPE]CREDAT)>0 : [F:CPE]CREDAT = date$ : Endif
    If dim([F:CPE]CREUSR)>0 : [F:CPE]CREUSR = GUSER : Endif
    If dim([F:CPE]CRETIM)>0 : [F:CPE]CRETIM = time  : Endif
    Write [CPE]
  Endif
  If fstat
   GOK = 0 : Call FSTA("CPE") From GLOCK : Break
  Endif
  #Compétence attribuée :
  #MABOS-22/04/13-FQ86015-US1531
  [L]WSHOAXX=""
  If [F:INS]CPCAFT(J)<>""
    Call LECTURE("CPC",[F:INS]CPCAFT(J),"") From  CONTOBJ
    If !fstat
      Call LECTEXTRA([L]WSHOAXX,"COMPETENCE","DES",[F:CPC]COD,"") From ATEXTRA
    Endif
   Endif
    #end MABOS-22/04/13-FQ86015-US1531
    Call ECR_TRACE(mess(14,10720,1)-":"-[F:INS]CPCAFT(J)-":"-[L]WSHOAXX-"-"-[F:INS]LEVAFT(J),0) From GESECRAN
  Endif
 # On doit aussi mettre à jour les compétences du parcours
 If FROM_CSI=2 Then
   Filter [CIC] Where COD=CODCSI & CPC=[F:INS]CPCAFT(J)
   Read [CIC]CIC0 Last
   Filter [CIC]
   If !fstat Then
     COPIER = func SUBECP.COMPNIV([F:INS]CPCAFT(J),[F:CIC]LEVCPCEVA,[F:INS]LEVAFT(J))
   Endif
   If fstat | COPIER=1    : # Si la compétence n'existe pas dans le parcours ou que son niveau est <
    #MABOS-04/03/13
    [L]MAJ=0
    If COPIER & [F:CIC]CPCDAT=[F:HRSES]ENDDAT Then
      [L]MAJ=1
    Endif
    Raz [F:CIC]
    [F:CIC]COD       = CODCSI
    [F:CIC]CPCDAT    = [F:HRSES]ENDDAT
    [F:CIC]CPC       = [F:INS]CPCAFT(J)
    [F:CIC]ORICPC    = 2 : # Stage
    [F:CIC]LEVCPCEVA = [F:INS]LEVAFT(J)
    [F:CIC]LEVREFEVA = func SUBECP.CPC_LEVREF([F:CIC]CPC,[F:INS]LEVAFT(J))
    # Récupération Référence liée à la compétence

    #MABOS-22/04/13-FQ86015-US1531
#    Call LECTURE("CPC",[F:INS]CPCAFT(J),"") From CONTOBJ
   If [L]WSHOAXX = "" & [F:INS]CPCAFT(J)<>""
      Call LECTURE("CPC",[F:INS]CPCAFT(J),"") From  CONTOBJ
      If !fstat
        Call LECTEXTRA([L]WSHOAXX,"COMPETENCE","DES",[F:CPC]COD,"") From ATEXTRA
      Endif
   Endif
    #end MABOS-22/04/13-FQ86015-US1531
    If !fstat Then
      Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
      If !fstat Then
        II = find("",[F:HRSCA]LEV)
        JJ = find(min([F:HRSCA]LEVREF(0..II-2)),[F:HRSCA]LEVREF(0..II-2))
        If JJ Then
          [F:CIC]LEVCPC    = [F:HRSCA]LEV(JJ-1)
          [F:CIC]LEVREFVAL = func SUBECP.CPC_LEVREF([F:CPC]COD,[F:CIC]LEVCPC)
        Endif
      Endif
    Endif
    #MABOS-04/03/13
    If [L]MAJ=1 Then
      If dim([F:CIC]UPDDAT)>0 : [F:CIC]UPDDAT = date$ : Endif
      If dim([F:CIC]UPDUSR)>0 : [F:CIC]UPDUSR = GUSER : Endif
      If dim([F:CIC]UPDTIM)>0 : [F:CIC]UPDTIM = time  : Endif
      Rewrite [CIC]
    Else
      If dim([F:CIC]CREDAT)>0 : [F:CIC]CREDAT = date$ : Endif
      If dim([F:CIC]CREUSR)>0 : [F:CIC]CREUSR = GUSER : Endif
      If dim([F:CIC]CRETIM)>0 : [F:CIC]CRETIM = time  : Endif
      Write [CIC]
    Endif
    If fstat
     GOK = 0 : Call FSTA("CIC") From GLOCK : Break
    Endif
    # Compétence attribuée pour le parcours :
     #MABOS-22/04/13-FQ86015-US1531
    Call ECR_TRACE(mess(14,10720,1)-mess(198,10717,1)-CODCSI-":"-[F:INS]CPCAFT(J)-":"-[L]WSHOAXX-"-"-[F:INS]LEVAFT(J),0) From GESECRAN
   Endif
 Endif
Next
# fin 53516
Return

