######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : contrôle du stage
######################################################################################
Subprog C_STG(VALEUR)
Variable Char    VALEUR()
  Call CTL_STG_NON_DEF(VALEUR) From DIVFOR
  If mkstat Then End Endif
End

Subprog C_ALLSES(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo SES : Diszo SES
 # FQ86194 - MABON 04/02/13 - Si "Toutes sessions" est cochée, on peut sélectionner les bornes de dates de fin
 Effzo [M:DIA]DATDEB, DATFIN
 Actzo [M:DIA]DATENDDEB,DATENDFIN
 # Fin MABON
Else
 Actzo SES
 # FQ86194 - MABON 04/02/13 - Si "Toutes sessions" est décochée, on ne peut pas sélectionner les bornes de dates de fin
 Effzo [M:DIA]DATENDDEB,DATENDFIN : Diszo [M:DIA]DATENDDEB,DATENDFIN
 # Fin MABON
Endif
End

Subprog AS_SES(VALEUR)
Variable Char    VALEUR()
If [M]ALLSES = 2 : mkstat = 1 : End : Endif
End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE From DIVPAYE
If [M]ALLSES=2 : Diszo SES : Else : Actzo SES : Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran VALCPC2)
######################################################################################
$SETNOL
Local Integer NOL
NOL=nolign-1
Return

Subprog AS_NBRINS
Gosub SETNOL
If NOL>=0 & [M]NBRINS>0
 If NOL<=[M]NBRINS
  # FQ86194 - MABON 07/02/13 - La ligne sélectionnée est colorée
  Chgstl [M]NBRINS With ""
  Chgstl [M]SESSION(NOL)  With "SELLIG"
  Chgstl [M]ZSESSION(NOL) With "SELLIG"
  Chgstl [M]ENDDAT(NOL)   With "SELLIG"
  Chgstl [M]NAM(NOL)      With "SELLIG"
  Chgstl [M]REFNUM(NOL)   With "SELLIG"
  # Fin MABON
  Affzo [M]NBRINS(NOL)
  Gosub CHARGE_CPC
  Affzo 15
 Else
  Effzo 15
 Endif
Endif
End

Subprog AS_FLGVAL(VALEUR)
Variable Integer VALEUR
If [M:VC2]NBRCPC=0
 GMESSAGE=mess(10,10720,1) :#Aucune compétence à attribuer
 mkstat=1 : End
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran VALCPC) 16/03/2006 17:56:32 (DBA)
######################################################################################
Subprog AM_SES(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("HRSES",VALEUR,"") From CONTOBJ
 [M]DATDEB=[F:HRSES]STRDAT
 [M]DATFIN=[F:HRSES]ENDDAT
 Affzo [M]DATDEB, DATFIN
Endif
End

# FQ86194 - MABON 07/02/13 - Pour gérer retour après traitement, action AV
Subprog AV_ALLCPY(VALEUR)
Variable Integer VALEUR

If VALEUR=2 Then Grizo [M:DIA]CPY,ALLFCY : Endif
End

Subprog AV_ALLFCY(VALEUR)
Variable Integer VALEUR

If VALEUR=2 Then Grizo [M:DIA]FCY : Endif
End

Subprog AV_ALLSRV(VALEUR)
Variable Integer VALEUR

If VALEUR=2 Then Grizo [M:DIA]SRV : Endif
End

Subprog AV_ALLPRF(VALEUR)
Variable Integer VALEUR

If VALEUR=2 Then Grizo [M:DIA]PRF : Endif
End

Subprog AV_SES(VALEUR)
Variable Char    VALEUR()

If [M:DIA]ALLSES=2 Then
  Grizo [M:DIA]SES
  Actzo [M:DIA]DATENDDEB,DATENDFIN
Else
  Actzo [M:DIA]SES
  Grizo [M:DIA]DATENDDEB,DATENDFIN
Endif
End

Subprog AV_DATENDDEB(VALEUR)
Variable Date    VALEUR

If [M:DIA]ALLSES=2 Then
  Grizo [M:DIA]SES
  Actzo [M:DIA]DATENDDEB,DATENDFIN
Else
  Actzo [M:DIA]SES
  Grizo [M:DIA]DATENDDEB,DATENDFIN
Endif
End

Subprog AV_DATENDFIN(VALEUR)
Variable Date    VALEUR

If [M:DIA]ALLSES=2 Then
  Grizo [M:DIA]SES
  Actzo [M:DIA]DATENDDEB,DATENDFIN
Else
  Actzo [M:DIA]SES
  Grizo [M:DIA]DATENDDEB,DATENDFIN
Endif
End
# Fin MABON

# FQ86194 - MABON 07/02/13 - Réinit session et dates
Subprog AM_STG(VALEUR)
Variable Char    VALEUR()

  [M:DIA]ALLSES=2 : Raz [M:DIA]SES,ZSES,DATDEB,DATFIN
  Affzo [M:DIA]SES,ZSES,DATDEB,DATFIN
  Diszo [M:DIA]SES
  Actzo [M:DIA]DATENDDEB,DATENDFIN
End

# FQ86194 - MABON 07/02/13 - Contrôle date session
Subprog C_SES(VALEUR)
Variable Char    VALEUR()

  Read [F:HRSES]SES0=VALEUR
  If !fstat Then
    If [F:HRSES]ENDDAT>datesyst Then
      GMESSAGE=mess(193,10717,1) : # La session doit être terminée pour pouvoir valider compétences et habilitations
      mkstat=2
    Endif
    If [F:HRSES]STG<>[M:DIA]STG Then
      GMESSAGE=mess(30,10717,1)-[M:DIA]STG : # Cette session ne dépend pas du stage
      mkstat=2
    Endif
  Endif
End

Subprog AS_MATFIN(VALEUR)
Variable Char    VALEUR()

  Call INIT_ZONE(VALEUR, "MATDEB") From TOOLSVAR
End

#MABOS-14/02/2013-FQ 81085-US1331- Add legislation + generic rules
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local    Integer AUZCFY

  AUZCFY = func SUBHRSES.GET_AUZ(VALEUR, "", "VALCPC")
  If AUZCFY=1 Then
    mkstat=2
  Endif

  Read [F:AGF]AGF0=VALEUR
  If !fstat & [F:AGF]FLGCPY=1 Then : # Ce n'est pas un groupe de sociétés
    Filter [F:AGC] Where GRP=VALEUR
    If rowcount([F:AGC])=0 Then : # Groupe de sites
      GMESSAGE=VALEUR-mess(216,10717,1) : # est un groupe de sites
      mkstat=2
    Endif
    Filter [F:AGC]
  Endif

End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Local    Integer AUZCFY
  AUZCFY = func SUBHRSES.GET_AUZ("", VALEUR, "VALCPC")
  If AUZCFY=1 Then
    mkstat=2
  Endif
End

Subprog C_MATFIN(VALEUR)
Variable Char    VALEUR()
End

Subprog INIT_BYLEG(VALEUR)
Variable Char    VALEUR()
# call by DIVPAYE
# Raz all fields after Leg, if leg is modified
Raz [M]SRV,[M]PRF,[M]MATDEB,[M]MATFIN,[M]POP,[M]CRI, [M]STG
Raz [M]SES,[M]DATDEB,[M]DATFIN,[M]DATENDDEB, [M]DATENDFIN
Raz [M]ZSRV,[M]ZPRF, [M]ZPOP,[M]ZSTG,[M]ZSES
[M]ALLSRV=2
[M]ALLPRF=2
[M]ALLSES=2
[M]MAJCSI=2
[M]FLGFRC=1
If dim([M]LEG)>0
  Call AM_LEG(VALEUR)
Endif
Affzo [M]ALLSRV,SRV,ALLPRF,PRF,MATDEB,MATFIN,POP,CRI,STG,ALLSES,SES
Affzo [M]ZSRV,ZPRF,ZPOP,ZSTG,ZSES
Affzo [M]DATDEB, DATFIN, DATENDDEB, DATENDFIN
Affzo [M]MAJCSI,FLGFRC
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
    [M]ALLPRF=2
    Diszo [M]ALLPRF
Else
  Actzo [M]ALLPRF
Endif
End

