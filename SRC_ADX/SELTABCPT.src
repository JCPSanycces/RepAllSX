#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion objet ITM
################################################################################
# SELECTION SUR LES OBJETS EVENTUELLEMENT PARTAGES AVEC X3
################################################################################
# GLE 01/03/2007 FQ39752 : Ajout du contrôle sur l'objet ITM
################################################################################

$ACTION
Case ACTION
  When "SEL_TABLE"  : Gosub SEL_TABLE
  When "CHX_TABLE"  : Gosub CHX_TABLE
  When default
Endcase
Return

################################################################################
## Actions SELITM & SELBPR
################################################################################
$SEL_TABLE
CRITERE(1) = PARAM(1)
OPTIONS    = PARAM(2)
Case TABLE
  When "SELITM"    : OBJET = "ITM" : If GTABCPT <> "" & GCPT130=0 : Gosub SELTABCPT : Endif
  When "SELBPR"    : OBJET = "BPR" : If GTABCPT <> "" & GCPT130=0 : Gosub SELTABCPT : Endif
  When "SELADILEG" : Gosub SELADILEG
Endcase
Return

$CHX_TABLE
Case TABLE
 When "SELADILEG"  : Gosub CHXADILEG
Endcase
Return

$SELTABCPT
# On va lire l'objet dans X3 pour déterminer les tables à ouvrir (tables de l'environnement de l'objet avec 
# une expression de lien) pour que le link dans OUVRE_LISTE soit sur des tables de la même base
  Local File =GTABCPT+"AOBJTAB"   [AOT]
  For [AOT] Where ABREV=OBJET
    If [F:AOT]TABLIEN <> ""
      Local File =GTABCPT+[F:AOT]TABFIC
    Endif
  Next
Return

$SELADILEG
  If clalev([F:ADV])=0 : Local File ATABTAB [ADV] : Endif
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  If clalev([F:AXX])=0 : Local file ATEXTRA [AXX] : Endif

  Local Char NUMTAB(10), NOMLEG(10)
  If clalev([F:ADV])=0 : Local File ATABTAB [ADV] : Endif
  [L]NUMTAB = PARAM(1) : # table diverse
  [L]NOMLEG = PARAM(2)

  If [L]NUMTAB = "" : OK = 0 : Return : Endif

  Read [ADV]CODE = val([L]NUMTAB)
  If fstat
    OK = 0
  Else
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'NUMTAB = '+[L]NUMTAB,"&") From GOBJSUB

    If dim([F:ADV]FLGLEG) > -1 and [F:ADV]FLGLEG = 2
      If [L]NOMLEG = ""
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'LEG = ""',"&") From GOBJSUB
      Else
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'(LEG = "" | LEG = "'+[L]NOMLEG+'")',"&") From GOBJSUB
      Endif
    Endif

    Link [ADI] With 
&   [AXX]AXX0="ATABDIV";"LNGDES";GLANGUE;[F:ADI]NUMTAB;[F:ADI]CODE
&   As [LNK]

    Call  TRANSCOL("ADI",NBCOL,COL,TIT(1..dim(TIT)-1),FMTCOL) From OBJDIV
    # Ajout de ma colonne Legislation    
    If dim([F:ADV]FLGLEG) > -1 and [F:ADV]FLGLEG = 2
      NBCOL += 1 : COL(NBCOL) = "[F:ADI]LEG" : COLTYP(NBCOL) =  type([F:ADI]LEG) : TIT(NBCOL) = mess(238,133,1)
    Endif
    Default File [LNK]
    ORDRE = "[F:ADI]CODE"
  Endif
Return

$CHXADILEG
  Call LECTEXTRA(TIT,"ATABTAB","LNGDES",num$([L]NUMTAB),"") From ATEXTRA
Return

##################################################
Subprog CONTITM(AZC,FILTRE,OPTIONA)
Variable Char    AZC()
Value    Char    FILTRE
Value    Char    OPTIONA
  If AZC = "" : End : Endif

  If FILTRE = "" : FILTRE = "1=1" : Endif

  OBJET = "ITM"
  If GTABCPT <> "" & GCPT130=0 : Gosub SELTABCPT : Endif

  Local File =GTABCPT+"ITMMASTER" [ITM]

  Filter [ITM] Where evalue(FILTRE)

  Read [ITM]ITM0=AZC

  If fstat Then 
    mkstat = 2
    GERR = 1
    [V]GMESSAGE = mess(67,7772,1) : # "L'article n'existe pas ou n'est sélectionnable."
  Endif
End

