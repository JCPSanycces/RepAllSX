# Representation Class script: CCMECCSTA_RSTD, Version Status ...

$METHODS

  Case CURPTH
    When ""
      Case ACTION
        When "AQUERY_TRANS_AFTER" : Gosub FILL_DESCRIPTION
        When "AREAD_AFTER"        : Gosub FILL_DESCRIPTION
      Endcase
  Endcase

Return

# --------------------------------------------------
# FUNCTION NAME:        AQUERY_TRANS_AFTER,
# FUNCTION DESCRIPTION:
# FUNCTION TYPE:        Subroutine,
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
$FILL_DESCRIPTION

  Local File ATEXTRA [AXX]

  Read [AXX]AXX0="ECCSTA";"ECCDESAXX";this.ACTX.LAN;this.ECS.ITMREF;this.ECS.ECCVALMAJ

  If (fstat = 0)
    this.ECCDESC = [F:AXX]TEXTE
  Endif

  LogicClose File [AXX]

Return

$PROPERTIES
Case [L]CURPRO
Endcase
Return


