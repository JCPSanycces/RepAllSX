#<AdxTL>@(#)4.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour Liste de gauche objet APE + divers
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update object APE") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJAPE
End

#-------------------#
$MAJAPE

Local Integer I , K , VALMOD(20) , OUVADS , EXISTE

If DOSSIER<>GDOSX3
 For I=0 To dim(VALMOD)-1
  VALMOD(I) = 2
 Next I
Else
 VALMOD(0) = 2
 For I=1 To dim(VALMOD)-1
  VALMOD(I) = 1
 Next I
Endif

# Mise à jour de la table AENTREE

Local File =DOSSIER+".AENTREE" [APE]
If dim([F:APE]TYP)<=0 : Return : Endif

Call ECR_TRACE(mess(81,125,1)-"AENTREE:"-time$,0) From GESECRAN

Trbegin [APE]
 For [APE]
  If [F:APE]TYP=0
   [F:APE]TYP = 1
   Rewrite [APE]
  Endif
 Next APE
Commit

# Traitement SPV dans la table AENTREE

If clalev([F:ADS2])=0
 OUVADS = 1 : Local File ADOSSIER [ADS2]
Endif
Read [ADS2]DOSSIER = [L]DOSSIER

Local File =DOSSIER+".AOBJET" [AOB2]

Trbegin [APE]
 For [AOB2]
  EXISTE = 0
  Call EXISTE_ADX("",DOSSIER,"SPV"+[F:AOB2]ABREV,EXISTE) From ORDSYS
  If !EXISTE
   Call EXISTE_ADX("",[F:ADS2]DOSREF,"SPV"+[F:AOB2]ABREV,EXISTE) From ORDSYS
  Endif
  If EXISTE
   Read [APE]APE0="";[F:AOB2]ABREV;"SPV"+[F:AOB2]ABREV
   If fstat
    Raz [F:APE]
    [F:APE]TRTSPE = "SPV"+[F:AOB2]ABREV
    [F:APE]OBJ    = [F:AOB2]ABREV
    [F:APE]TYP    = 2 : # Objet
    [F:APE]MODULE = [F:AOB2]MODULE
    [F:APE]CODACT = [F:AOB2]CODACT
    If dim([F:APE]CREUSR)>0 : [F:APE]CREUSR = GUSER : Endif
    If dim([F:APE]CREDAT)>0 : [F:APE]CREDAT = date$ : Endif
    If dim([F:APE]CRETIM)>0 : [F:APE]CRETIM = time  : Endif
    Write [APE]
   Endif
  Endif
 Next AOB2
Commit

Close Local File [APE] , [AOB2]
If OUVADS : Close Local File [ADS2] : Endif

# Onglet Sélection

Call MAJ_SEL(DOSSIER,"APE") From PATCHAOB

# Validation de l'objet

Call VALID_TRT(DOSSIER,0,"","","","","","","","","APE","APE","","","","","","","","","","",VALMOD) From VALDICO
Call VALFEN(DOSSIER,"APE") From SUBAOB

Return

