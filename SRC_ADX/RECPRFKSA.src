Subprog AM_POT(VALEUR)
Variable Char    VALEUR()
Local    Integer I
Local Integer CRSFLG : CRSFLG = [M:DIA]CRSFLG
Local Integer FLGKEY : FLGKEY = [M:DIA]FLGKEY
If func AFNC.ACTIV("KZA")>0
  If clalev([F:POT])=0 : Local File POSTE  [POT] : Endif
  Call LECTURE("POT",VALEUR,"") From CONTOBJ
  #If [M:DIA]JOT="" Then Raz [M:DIA]NBRCPC Endif
  If [M:DIA]JOT="" Then
    Effzo [DIA]10  #SBA on raz le tableau
  Endif
  nolign = [M]NBRCPC
  For I=0 To dim([F:POT]CPC)-1
   If [F:POT]CPC(I)="" : Break : Endif
   ###################################################
   # JML 28/07/10 LOT P02
   #Infbox num$([M:DIA]CRSFLG)
   Call LECTURE("CPC",[F:POT]CPC(I),"") From CONTOBJ
   If !find([F:POT]CPC(I),[M:DIA]CPC(0..[M]NBRCPC-1))
& & ([F:CPC]CRSFLG=CRSFLG & [F:CPC]FLGKEY=FLGKEY)
    If nolign>=dim([M:DIA]CPC)
    Call ERREUR(mess(26, 100, 1)) From GESECRAN :#"Le nombre de notifications de relance dépasse la limite autorisée ($1$). Veuillez restreindre votre population"
        Break
    Endif
    [M:DIA]CPC(nolign)    = [F:POT]CPC(I)
    [M:DIA]LEV(nolign)    = [F:POT]NIV(I)
    [M:DIA]WEI(nolign)    = [F:POT]WEI(I)
    [M:DIA]OBGFLG(nolign) = [F:CPC]FLGKEY
    [M:DIA]CRS(nolign)    = [F:CPC]CRSFLG
    nolign +=1
   Endif
  Next
  [M:DIA]NBRCPC = nolign
  Affzo [DIA]10
Endif
End



Subprog AM_JOT(VALEUR)
Variable Char    VALEUR()
Local    Integer I
Local Integer CRSFLG : CRSFLG = [M:DIA]CRSFLG
Local Integer FLGKEY : FLGKEY = [M:DIA]FLGKEY
If func AFNC.ACTIV("KZA")>0
  If clalev([F:JOT])=0 : Local File JOSTE  [JOT] : Endif
  Call LECTURE("JOT",VALEUR,"") From CONTOBJ
  #If [M:DIA]JOT="" Then Raz [M:DIA]NBRCPC Endif
  If [M:DIA]POT="" Then
    Effzo [DIA]10  #SBA on raz le tableau
  Endif
  nolign = [M]NBRCPC
  For I=0 To dim([F:JOT]CPC)-1
   If [F:JOT]CPC(I)="" : Break : Endif
   ###################################################
   # JML 28/07/10 LOT P02
   Call LECTURE("CPC",[F:JOT]CPC(I),"") From CONTOBJ
   If !find([F:JOT]CPC(I),[M:DIA]CPC(0..[M]NBRCPC-1))
& & ([F:CPC]CRSFLG=CRSFLG & [F:CPC]FLGKEY=FLGKEY)
   ###################################################
    If nolign>=dim([M:DIA]CPC)
    Call ERREUR(mess(26, 100, 1)) From GESECRAN :#"Le nombre de notifications de relance dépasse la limite autorisée ($1$). Veuillez restreindre votre population"
        Break
    Endif
    [M:DIA]CPC(nolign)    = [F:POT]CPC(I)
    [M:DIA]LEV(nolign)    = [F:POT]NIV(I)
    [M:DIA]WEI(nolign)    = [F:POT]WEI(I)
    [M:DIA]OBGFLG(nolign) = [F:CPC]FLGKEY
    [M:DIA]CRS(nolign)    = [F:CPC]CRSFLG
    nolign +=1
   Endif
  Next
  [M:DIA]NBRCPC = nolign
  Affzo [DIA]10
Endif
End
