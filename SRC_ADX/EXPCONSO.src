#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
GERR = 0
Call TRAITE_CHAR(VALEUR,PARAM,"","EXPCONSO","EXPCONSO",3,"") From GTRAITE
End
# Issue X3-107197 - 2018-09-12 by CBO : PARAMETER AND ACTIVITY CODE
End

$ACTION
Case ACTION
 When "INIT_DIA" : Gosub INIT_DIA
 When "EXEC"     : Gosub EXEC
 When "CONTROLE" : Gosub CONTROLE
Endcase
Return

$INIT_DIA
Raz [M]
Local File BALCONSO [BLC]
Read [BLC]First
If fstat<=2
 [M]GROUPE = [F:BLC]GRUGPY
 [M]LEDTYP = [F:BLC]LEDTYP
Endif
Gosub INIT_WAY
Return

$INIT_WAY
Local Char FICHIER(GDIMFIC)
Call BUILDNAMEFIC([M]GROUPE,[M]LEDTYP,[M]TYPEXP,FICHIER)

[M]VOLFIL=[L]FICHIER
If [M]VOLFIL=""
 [M]TYPEXP=1
 Grizo [M]VOLFIL
Else
 [M]TYPEXP=2
 Actzo [M]VOLFIL
Endif

Affzo
Return

$CONTROLE
TRA = 0
TMP = 1
Return

$EXEC
# Variables et initialisation de Poste client
Local Char FICDON(GDIMFIC),URL(GDIMFIC)
Local Integer STAT

If [M]TYPEXP=1 : # Client
 Call SET_FICNAM([M]FICHIER,FICDON,URL) From ORDSYS
Else
 FICDON = [M]FICHIER
Endif

Call EXPORT(FICDON,[M]GROUPE,[M]LEDTYP,([M]ANA=2),([M]FLU=2))

If [M]TYPEXP=1
 Call COPCLI(FICDON,[M]FICHIER,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  Call ERREUR(mess(164,141,1)) From GESECRAN
  FIN=1 : Return
 Elsif STAT>1
  # Fichier inexistant
  Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  FIN=1 : Return
 Endif
Endif
Return

###############
##   Utils
###############

Subprog VERIFPERIM(GROUPE,OK)
Value Char    GROUPE
Variable Integer OK

Local File BALCONSO [BLC]
Filter [BLC] Where GRUGPY=GROUPE
Read [BLC]BLC0 First
If !fstat
 OK=1
 [M]LEDTYP = [F:BLC]LEDTYP
Else
 OK=0
 # Aucune conso à exporter pour ce périmètre
 GMESSAGE = mess(151,107,1)
 mkstat   = 2
Endif
Filter [BLC]
End

Subprog VERIFTYPREF(GROUPE,TYPREF,OK)
Value Char    GROUPE
Value Integer TYPREF
Variable Integer OK

Local File BALCONSO [BLC]
Filter [BLC] Where GRUGPY=GROUPE and LEDTYP=TYPREF
Read [BLC]BLC0 First
If !fstat
 OK=1
Else
 OK=0
 # Aucune conso à exporter pour ce périmètre et ce type de référentiel
 GMESSAGE = mess(153,107,1)
 mkstat   = 2
Endif
Filter [BLC]
End

Subprog BUILDNAMEFIC(GROUPE,TYPREF,TYPEXP,FIC)
Value Char    GROUPE
Value Integer TYPREF
Value Integer TYPEXP
Variable Char FIC()

Local Char TYP, NOMFIC
Local Char CHEMIN(GDIMFIC)
Local Char DAT
Local Integer OK

If clalev([BLC])=0 : Local File BALCONSO [BLC] : Endif
Filter [BLC] Where GRUGPY=GROUPE and LEDTYP=TYPREF
Read [BLC]BLC0 First
If !fstat
 DAT = num$(month([F:BLC]DATFIN))+num$(year([F:BLC]DATFIN))
Endif
Filter [BLC]
Case TYPREF
 When 1, 4 : TYP = "SOC"
 When 2, 5 : TYP = "ANA"
 When 3, 6 : TYP = "IAS"
Endcase

NOMFIC = GROUPE+TYP+DAT
If func AFNC.ACTIV("EREP1")   # Issue X3-107197
Call PARAMUTIL("EXPCSL",CHEMIN,"","") From SUBAUS
Endif   # Issue X3-107197
If CHEMIN<>""
 If right$(CHEMIN, len(CHEMIN))<>"/" : CHEMIN += "/" : Endif
 [L]FIC = CHEMIN+NOMFIC+".cso"
Else
 [L]FIC = "[TMP]/"+NOMFIC+".cso"
Endif
End

###############################################################################
##  Contrôle en saisie du paramètre EXPCSL
###############################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK
Local Char TMP(250)
Gosub ENUM_VOLFIL_TYPE From ASYRSTO
If func ASYRSTO.CTL_VOLFIL(2,VALEUR,TMP,E_TYPE_FOLDER,GMESSAGE)<>0
 OK = 0 : End
Endif
End

#########################################################################
## Export Sage Concept
#########################################################################
Subprog EXPORT(FICHIER,GROUPE,TYPREF,FLANA,FLFLUX)
Value Char    FICHIER
Value Char    GROUPE
Value Integer TYPREF
Value Integer FLANA
Value Integer FLFLUX

Local Char    ANA(250) , FLUX(250)
Local Char    AXE(GLONDIE) , SECTION(GLONCCE)
Local Integer LIGNE , IAXE

Local File BALCONSO [BLC]
Filter [BLC] Where LEDTYP=TYPREF & GRUGPY=GROUPE

adxirs = chr$(13)+chr$(10)
adxifs = "|"
adxium = GASCII
Openo FICHIER,0

LIGNE = 0
For [BLC]
 LIGNE += 1

# En-tête

 If LIGNE=1
  Wrseq "CATP";
  Wrseq "ACTUAL"+"_"+format$("YYYYMM",[F:BLC]DATFIN)+"_"+format$("YYYYMM",[F:BLC]DATFIN)
 Endif

# Lignes

 Gosub INFOS
 Wrseq "DONN";                                : # 3) Constante DONN
 Wrseq "";                                    : # 4) Rang (vide)
 Wrseq "";                                    : # 5) Catégorie (vide)
 Wrseq [F:BLC]ACCGRU;                         : # 6) Indicateur (compte)
 Wrseq FLUX;                                  : # 7) Flux (vide pour l'instant)
 If [F:BLC]CURTRS=""                          : # 8) Méthode d'évaluation
  Wrseq "CLOCAL";                             : #    En devise locale
  Wrseq [F:BLC]CURCNS;
 Else
  Wrseq "COTHER";                             : #    En devise de transaction
  Wrseq [F:BLC]CURTRS;                        : # 10) Devise
 Endif
 Wrseq [F:BLC]CPYGRU;                         : # 11) Entité d'origine
 Wrseq [F:BLC]BPRGRU;                         : # 12) Partenaire
 Wrseq "";                                    : # 13) Entité intra-groupe titre
 Wrseq "";                                    : # 14) Groupe (vide)
 Wrseq "";                                    : # 15) Nature d'écriture (vide)
 Wrseq "";                                    : # 16) Type d'écriture (vide)
 Wrseq -[F:BLC]SNSBLC*[F:BLC]BLC;             : # 17) Montant (<0 pour débiteur)
 Wrseq ANA;                                   : # 18) Analytique
 Wrseq "COMMON"                               : # 19) Norme
Next
Openo
End

$INFOS
FLUX = ""
ANA  = ""

# Flux : on prend le critère libre ?

If FLFLUX
 FLUX = [F:BLC]CRI
Endif

# Ana : On concatène les axes et les sections

If FLANA
 For IAXE=1 To 9
  Case IAXE
   When 1 : AXE = [F:BLC]DIE1 : SECTION = [F:BLC]CCE1
   When 2 : AXE = [F:BLC]DIE2 : SECTION = [F:BLC]CCE2
   When 3 : AXE = [F:BLC]DIE3 : SECTION = [F:BLC]CCE3
   When 4 : AXE = [F:BLC]DIE4 : SECTION = [F:BLC]CCE4
   When 5 : AXE = [F:BLC]DIE5 : SECTION = [F:BLC]CCE5
   When 6 : AXE = [F:BLC]DIE6 : SECTION = [F:BLC]CCE6
   When 7 : AXE = [F:BLC]DIE7 : SECTION = [F:BLC]CCE7
   When 8 : AXE = [F:BLC]DIE8 : SECTION = [F:BLC]CCE8
   When 9 : AXE = [F:BLC]DIE9 : SECTION = [F:BLC]CCE9
  Endcase
  If AXE<>"" & SECTION<>""
   If ANA<>"" : ANA += "_" : Endif
   ANA += AXE+"+"+SECTION
  Endif
 Next IAXE
Endif
Return

#############################################################################
## Ecran EXPCONSO
############################################################################

Subprog C_GROUPE(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Call VERIFPERIM(VALEUR,OK)
End

Subprog AM_GROUPE(VALEUR)
Variable Char    VALEUR()
[M]GROUPE=VALEUR
Gosub INIT_WAY
End

Subprog C_LEDTYP(VALEUR)
Variable Integer  VALEUR
Local Integer OK
Call VERIFTYPREF([M]GROUPE,VALEUR,OK)
End

Subprog AM_LEDTYP(VALEUR)
Variable Integer VALEUR
[M]LEDTYP=VALEUR
Gosub INIT_WAY
End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M:DIA]VOLFIL
 Grizo [M:DIA]VOLFIL
Else
 Call BUILDNAMEFIC([M]GROUPE,[M]LEDTYP,VALEUR,[M]VOLFIL)
 Actzo [M:DIA]VOLFIL
Endif
Affzo [M:DIA]VOLFIL
End

Subprog D_INI(VALEUR)
Variable Decimal VALEUR
If [M]VOLFIL=""
 [M]TYPEXP=1
 Grizo [M]VOLFIL
Else
 [M]TYPEXP=2
 Call BUILDNAMEFIC([M]GROUPE,[M]LEDTYP,VALEUR,[M]VOLFIL)
 Actzo [M]VOLFIL
Endif
End

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FICHIER,E_TYPE_FILEWRITE,GMESSAGE)
End

