#<AdxTL>@(#)6.0.0.0 $Revision$
###########################################################################################
# Classe Données SRETURN : Retour Client                                                  #
#   --> Appelle SRETURN_METHODS    : Sous-prog de gestion des méthodes   de la classe     #
#   --> Appelle SRETURN_PROPERTIES : Sous-prog de gestion des propriétés de la classe     #
###########################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINIT"           : Gosub INIT                     From SRETURN_METHODS
        When "AREAD_AFTER"     : Gosub AREAD_AFTER              From SRETURN_METHODS
      Endcase
    # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
    When "SRD"
      Case [L]AEVENT
        When "AREAD_BEFORE"    : Gosub AREAD_BEFORE_SRD         From SRETURN_METHODS
        When Default
      Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES

  Case CURPRO
    When "CPY"              :  Gosub CPY From SRETURN_PROPERTIES
    When Default
  Endcase

Return

