#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SITRAFIL 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone NUM
mkstat = 0
zoncou = "NUM"
indice = 0
IMPENT = [M]NUM
If varinit([M]NUM,indice)=0
 IMPENT = 1
Endif
[M]NUM = IMPENT

## Zone TRTERR
mkstat = 0
zoncou = "TRTERR"
indice = 0
IMPENT = [M]TRTERR
If varinit([M]TRTERR,indice)=0
 IMPENT = 1
Endif
[M]TRTERR = IMPENT

## Zone TRAFLG
mkstat = 0
zoncou = "TRAFLG"
indice = 0
IMPENT = [M]TRAFLG
If varinit([M]TRAFLG,indice)=0
 IMPENT = 1
Endif
[M]TRAFLG = IMPENT

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBCOD
mkstat = 0
zoncou = "NBCOD"
indice = 0
status = 1
zoncou = "NBCOD"
If varmode([M]NBCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBCOD" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBCOD
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBCOD = nolign
   status = 75
   Call SAI_NBCOD(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone AFFERR
mkstat = 0
zoncou = "AFFERR"
indice = 0
IMPENT = [M]AFFERR
WNUM = IMPENT
If varinit([M]AFFERR,indice)=0
 IMPENT = 1
Endif
If varmode([M]AFFERR,indice)=0
 [M]AFFERR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "AFFERR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]AFFERR(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_AFFERR(IMPENT) From SUBSITF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "AFFERR" : GZNUM = 22822 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]AFFERR = IMPENT

## Zone AFFDBL
mkstat = 0
zoncou = "AFFDBL"
indice = 0
IMPENT = [M]AFFDBL
WNUM = IMPENT
If varinit([M]AFFDBL,indice)=0
 IMPENT = 1
Endif
If varmode([M]AFFDBL,indice)=0
 [M]AFFDBL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "AFFDBL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]AFFDBL(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_AFFDBL(IMPENT) From SUBSITF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "AFFDBL" : GZNUM = 21146 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]AFFDBL = IMPENT

## Zone AFFMDF
mkstat = 0
zoncou = "AFFMDF"
indice = 0
IMPENT = [M]AFFMDF
WNUM = IMPENT
If varinit([M]AFFMDF,indice)=0
 IMPENT = 1
Endif
If varmode([M]AFFMDF,indice)=0
 [M]AFFMDF(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "AFFMDF" : Gosub ACTION From =IMPTRT
  IMPENT = [M]AFFMDF(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_AFFMDF(IMPENT) From SUBSITF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "AFFMDF" : GZNUM = 24150 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]AFFMDF = IMPENT

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone ACCENT
mkstat = 0
zoncou = "ACCENT"
indice = 0
IMPENT = [M]ACCENT
If varinit([M]ACCENT,indice)=0
 IMPENT = 2
Endif
[M]ACCENT = IMPENT

## Zone FMTCLE
mkstat = 0
zoncou = "FMTCLE"
indice = 0
IMPENT = [M]FMTCLE
WNUM = IMPENT
If varinit([M]FMTCLE,indice)=0
 IMPENT = 2
Endif
[M]FMTCLE = IMPENT

## Zone HAUT
mkstat = 0
zoncou = "HAUT"
indice = 0
If varinit([M]HAUT,indice)=0
 [M]HAUT = "30"
Endif

## Zone MODIF
mkstat = 0
zoncou = "MODIF"
indice = 0
IMPENT = [M]MODIF
If varinit([M]MODIF,indice)=0
 IMPENT = 2
Endif
[M]MODIF = IMPENT

## Zone SPC
mkstat = 0
zoncou = "SPC"
indice = 0
IMPENT = [M]SPC
WNUM = IMPENT
If varinit([M]SPC,indice)=0
 IMPENT = 2
Endif
[M]SPC = IMPENT

## Zone BAS
mkstat = 0
zoncou = "BAS"
indice = 0
If varinit([M]BAS,indice)=0
 [M]BAS = "29"
Endif

## Zone MAJ
mkstat = 0
zoncou = "MAJ"
indice = 0
IMPENT = [M]MAJ
WNUM = IMPENT
If varinit([M]MAJ,indice)=0
 IMPENT = 2
Endif
[M]MAJ = IMPENT

## Zone ERRONLY
mkstat = 0
zoncou = "ERRONLY"
indice = 0
IMPENT = [M]ERRONLY
If varinit([M]ERRONLY,indice)=0
 IMPENT = 1
Endif
[M]ERRONLY = IMPENT

## Zone AUZDBL
mkstat = 0
zoncou = "AUZDBL"
indice = 0
IMPENT = [M]AUZDBL
If varinit([M]AUZDBL,indice)=0
 IMPENT = 1
Endif
[M]AUZDBL = IMPENT

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBCOD(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBCOD
mkstat = 0
zoncou = "NBCOD"

## Zone CODE
mkstat = 0
zoncou = "CODE"
SAVACT = GACTION : GACTION = "STD"
Call AV_CODE([M]CODE(indice)) From SUBSITF
GACTION = SAVACT
If mkstat=1 : Raz [M]CODE(indice) : Endif
If !mkstat
 If varinit([M]CODE,indice)=0
  [M]CODE(indice) = [M]COD(nolign-1)-string$([M]COD2(nolign-1)<>"","; "+[M]COD2(nolign-1))
 Endif
Endif

## Zone X3CLE
mkstat = 0
zoncou = "X3CLE"
WCHAR = [M]X3CLE(indice)
SAVACT = GACTION : GACTION = "STD"
Call AV_X3CLE([M]X3CLE(indice)) From SUBSITF
GACTION = SAVACT
If mkstat=1 : Raz [M]X3CLE(indice) : Endif
If !mkstat
 If varmode([M]X3CLE,indice)=0
  SAVACT = GACTION : GACTION = "STD"
  Call AS_X3CLE([M]X3CLE(indice)) From SUBSITF
  GACTION = SAVACT
  If mkstat=1 : Raz [M]X3CLE(indice) : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "X3CLE" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_X3CLE([M]X3CLE(indice)) From SUBSITF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "X3CLE" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]X3CLE(indice) or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_X3CLE([M]X3CLE(indice)) From SUBSITF
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "X3CLE" : GZNUM = 0 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone ERR
mkstat = 0
zoncou = "ERR"
IMPENT = [M]ERR(indice)
If varinit([M]ERR,indice)=0
 IMPENT = 1
Endif
[M]ERR(indice) = IMPENT

## Zone DBL
mkstat = 0
zoncou = "DBL"
IMPENT = [M]DBL(indice)
If varinit([M]DBL,indice)=0
 IMPENT = 1
Endif
[M]DBL(indice) = IMPENT

## Zone MDF
mkstat = 0
zoncou = "MDF"
IMPENT = [M]MDF(indice)
If varinit([M]MDF,indice)=0
 IMPENT = 1
Endif
[M]MDF(indice) = IMPENT

## Zone NBCOD
mkstat = 0
zoncou = "NBCOD"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "SITRAFIL"
Return

