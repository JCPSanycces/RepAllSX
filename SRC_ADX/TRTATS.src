## Section automatically added (screen TRTATS) 08/11/2016 16:24:25 (JOJAC)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
#JOJAC - 2016-08-11 - X3PEOP-975 - START
If VALEUR<>""
  If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 GSOCIETE=[F:CPY]CPY
 #19/04/12 - DKA - Compare site legislation to see if legislation has changed
 TMPLEG = GCURLEG
 If dim([F:CPY]LEG)>0
   GCURLEG =[F:CPY]LEG
 Endif
Endif

Raz [M:DIA]MATDEB,MATFIN
Affzo [M:DIA]MATDEB,MATFIN

#JOJAC - 2016-08-11 - X3PEOP-975 - END
End


