[F:HRATS]FLGALCTOT=1    :#Chomage total
[F:HRATS]FLGALC14=1     :#Transaction en cours
[F:HRATS]FLGFNG1=1      :#FNGS perçue
[F:HRATS]FLGFNG2=1      :#FNGS à percevoir

#MIPEA - 2016-08-11 - X3PEOP-975 - START
#Recherche du dernier règlement datant de moins d'un mois...
Filter [F:HRSTL] Where REFNUM=[F:HRATS]REFNUM & CTRNUM=[F:HRATS]CTRNUM & PYRDAT>=[F:HRATS]XITDAT-30
Read [F:HRSTL]STL1 Last
Filter [F:HRSTL]
If !fstat
 [F:HRATS]NUMFRM=[F:STL]NUMFRM
 #Bordereau de règlement du solde de tout compte
 Call ECR_TRACE(mess(210,10703,1)-':'-[F:STL]NUMFRM,0) From GESECRAN
Else
 #Bordereau de règlement du solde de tout compte non trouvé
 Call ECR_TRACE(mess(210,10703,1)-mess(42,9003,1),1) From GESECRAN
Endif
