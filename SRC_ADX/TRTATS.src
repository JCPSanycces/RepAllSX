######################################################################################
Subprog AM_FLGAED(VALEUR)
Variable Integer VALEUR
If [L]VALEUR = 2
    Actzo [M]DNAYEA
    Actzo [M]N4DVER
    If [M]DNAYEA = ""
        [M]DNAYEA = func AFNC.PARAM("DNAYEA", "")
        Affzo [M]DNAYEA
    Endif
    If [M]N4DVER = ""
        [M]N4DVER = func AFNC.PARAM("N4DVER", "")
        Affzo [M]N4DVER
    Endif
Else
    Effzo [M]DNAYEA : Grizo [M]DNAYEA
    Effzo [M]N4DVER : Grizo [M]N4DVER
Endif
End

Subprog C_DNAYEA(VALEUR)
Variable Char    VALEUR()
#MIPEA - 2016-08-11 - X3PEOP-975 - START
