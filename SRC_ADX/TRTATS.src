$RECUP_INFOS
Raz [F:HRATS]
Gosub INFOS_EMP
Gosub INFOS_FCY
If [F:HRATS]FCYHRSWEK<>[F:HRATS]EMPHRSWEK & [F:HRATS]FCYHRSWEK<>0 & [F:HRATS]EMPHRSWEK<>0 & [F:HRCTR]TYPJOB=2
 [F:HRATS]GRDHRSWEK=2
Endif
Filter [F:HRATS2] Where FCYSGE=[F:HRATS]FCYSGE & REFNUM<>[F:HRATS]REFNUM & XITDAT<>[F:HRATS]XITDAT & CTRNUM<>[F:HRATS]CTRNUM
Read [F:HRATS2]ATS0 Last
Filter [F:HRATS2]
If !fstat
 [F:HRATS]NUMORD= [F:HRATS2]NUMORD+1
Else
 [F:HRATS]NUMORD=1
Endif
Gosub AFFECTE_DIVERS
GOK=1
GPOINT = "MAJATS" : Gosub ENTREE From EXEFNC
If GOK
 If FLAG=0
  If dim([F:HRATS]CREDAT)>0 : [F:HRATS]CREDAT = date$ : Endif
  If dim([F:HRATS]CREUSR)>0 : [F:HRATS]CREUSR = GUSER : Endif
  If dim([F:HRATS]CRETIM)>0 : [F:HRATS]CRETIM = time  : Endif
 Write [F:HRATS]
  If fstat<>0
   GOK = 0 : Call FSTA("HRATS") From GLOCK : Return
  Endif
 Else
  If dim([F:HRATS]UPDDAT)>0 : [F:HRATS]UPDDAT = date$ : Endif
  If dim([F:HRATS]UPDUSR)>0 : [F:HRATS]UPDUSR = GUSER : Endif
  If dim([F:HRATS]UPDTIM)>0 : [F:HRATS]UPDTIM = time  : Endif
  Rewrite [F:HRATS]
  If fstat<>0
   GOK = 0 : Call FSTA("HRATS") From GLOCK : Return
  Endif
 Endif

# Enchainement de l'extraction AED
    If [L]WFLGAED = 2
        [L]ENDDAT_AED = eomonth([F:HRATS]XITDAT)
        [L]STRDAT_AED = gdat$(1, month([L]ENDDAT_AED), year([L]ENDDAT_AED))
        #88314
#MIPEA - 2016-08-11 - X3PEOP-975 - START
        Call AED_SILENCIEUSE([L]WN4DVER, [L]WDNAYEA, [F:FCY]LEGCPY, "15", [L]STRDAT_AED, [L]ENDDAT_AED, 1,
&                            [F:HRATS]FCY, [L]WALLSRV, [L]WSRV, [L]WALLPRF, [L]WPRF, 1, [F:HRATS]REFNUM, [L]WPOP, 1,
&                            [F:HRATS]CTRNUM, "") From TRTDXTR
#MIPEA - 2016-08-11 - X3PEOP-975 - END
      #  Call AED_SILENCIEUSE([L]WN4DVER, [L]WDNAYEA, [F:FCY]LEGCPY, "15", [L]STRDAT_AED, [L]ENDDAT_AED, 1, [F:HRATS]FCY, 1, [F:HRATS]REFNUM, 1, [F:HRATS]CTRNUM, "")
#&                    From TRTDXTR
    Endif

Endif
Return

