#############################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
#MIPEA - 2016-09-29 - 114309 - X3PEOP-975 - START
If dim([M:DIA]LEG)>0 : GCURLEG=[M:DIA]LEG : Endif
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If GLEGFIL<>"" & GCURLEG="" : GCURLEG = GLEGFIL : Endif
#MIPEA - 2016-09-29 - 114309 - X3PEOP-975 - END
Return

#############################################
$EXEC
# ouverture de la trace et écriture de l'en-tête
#"Extraction Attestation Pôle emploi"
TIT=mess(128,10703,1)
Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

SYMBOLE = "HRATS"+num$(date$)
Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 GERR = 1 : SAI = 1
 Return
Endif

#JASMI - 2016-09-30 - Needs to be done on EXEC action - START
#For PARAM, GCURLEG is already knew because we are called from GESHRATS (where GCURLEG is defined).
#Rubrique du solde de tout compte
Call PARAM(GCURLEG,"SLDTTCPT",RUBSLDCPT)From ADOVAL
If RUBSLDCPT=""
 Call ECR_TRACE(mess(68,10703,1),0) From GESECRAN : # Paramètre "Solde de tout compte" non renseigné
 GOK=0
Endif
Call PARAM(GCURLEG,"SLDHRSDIF",RUBHRSDIF)From ADOVAL
Call PARAM(GCURLEG,"SLDDIFAMT",RUBAMTDIF)From ADOVAL
#MIPEA - 2016-08-11 - X3PEOP-975 - START
Call PARAM(GCURLEG,"MAIGARMUT",RUBMUTMAIN)From ADOVAL
Call PARAM(GCURLEG,"MAIGARPRV",RUBPRVMAIN)From ADOVAL
#end 98617_US2621
Call PARAM(GCURLEG,"NBSTAREA",RUBNBSTA)From ADOVAL : : #US3751 108474 Stagiaire
Call PARAM(GCURLEG,"GRATIFSTA",RUBBNSSTA)From ADOVAL : : #US3751 108474 Stagiaire
#MIPEA - 2016-08-11 - X3PEOP-975 - END
#JASMI - 2016-09-30 - Needs to be done on EXEC action - END

GPOINT = "ADDCRITSPE" : Gosub ENTREE From EXEFNC
If vireblc([L]CRITSPE,4)="" : [L]CRITSPE="1=1" : Endif
[L]CRITEMP=[L]CRITSPE

CRITEMP2="1=1"
CRITFCY="1=1"

If dim([M:DIA]ALLCPY)>0 & [M:DIA]ALLCPY<>2  #société
 CRITFCY -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If dim([M:DIA]ALLFCY)>0 &  [M:DIA]ALLFCY<>2  #site
 CRITFCY -= '& [F:FCY]FCY = "'+[M:DIA]FCY+'"'
Endif

If dim([M:DIA]MATDEB)>0
 If [M:DIA]MATDEB<>"" #borne début matricule
  CRITEMP -= '& REFNUM>="'+[M:DIA]MATDEB+'"'
 Endif
 If [M:DIA]MATFIN<>"" #borne fin du matricule
  CRITEMP -= '& REFNUM<="'+[M:DIA]MATFIN+'"'
 Endif
Endif
If dim([M:DIA]REFNUM)>0 & [M:DIA]REFNUM<>""
 CRITEMP -= '& REFNUM="'+[M:DIA]REFNUM+'"'
Endif

CRITEMP2 -= '& [F:HRCTR]XITDAT<>[00/00/00] & [F:HRCTR]XITFNL=2'

If dim([M:DIA]DATXITSTR)>0
 If [M:DIA]DATXITSTR<>[00/00/00]
  CRITEMP2 -= '& [F:HRCTR]XITDAT>=[M:DIA]DATXITSTR'
 Endif
 If [M:DIA]DATXITEND<>[00/00/00]
  CRITEMP2 -= '& [F:HRCTR]XITDAT<=[M:DIA]DATXITEND'
 Endif
Endif

#88314
CRITEMP3="1=1"
If dim([M:DIA]ALLSRV)>0 & [M:DIA]ALLSRV<>2
 CRITEMP3 -= '& [F:HRCTR]ETRSRV = "'+[M:DIA]SRV+'"'
Endif
If dim([M:DIA]ALLPRF)>0 & [M:DIA]ALLPRF<>2
 CRITEMP3 -= '& [F:HRCTR]PROPRF = "'+[M:DIA]PRF+'"'
Endif

If [M:DIA]POP<>""
 CRITEMP3 -= '& [F:HRPOA]REFNUM<>""'
#MIPEA - 2017-01-23- X3-12004- START
 Link [HRCTR] With
&     [FCY]FCY0 = [F:HRCTR]ETRFCY,
&     [ID]ID0   = [F:HRCTR]REFNUM,
&     [HRPOA]POA0 = [M:DIA]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&    As [LNK] Where [F:ID]FLGPAY=2 & [F:FCY]LEG=GCURLEG : #MIPEA - 2016-08-11 - X3PEOP-975
Else
 Link [HRCTR] With
&     [FCY]FCY0 = [F:HRCTR]ETRFCY,
&     [ID]ID0 = [F:HRCTR]REFNUM
&     As [LNK] Where [F:ID]FLGPAY=2 & [F:FCY]LEG=GCURLEG : #MIPEA - 2016-08-11 - X3PEOP-975
Endif
# Link [HRCTR] With
#&   [ID]ID0   = [F:HRCTR]REFNUM,
#&   [HRPOA]POA0 = [M:DIA]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
#&   As [LNK] Where [F:ID]FLGPAY=2 : #MIPEA - 2016-08-11 - X3PEOP-975
#Else
# Link [HRCTR] With
#&   [ID]ID0 = [F:HRCTR]REFNUM
#&   As [LNK] Where [F:ID]FLGPAY=2 : #MIPEA - 2016-08-11 - X3PEOP-975
#Endif
#MIPEA - 2017-01-23- X3-12004- END
#

# Enchainement de l'extraction AED
[L]WFLGAED = 1
If dim([M:DIA]FLGAED) > 0
    [L]WFLGAED = [M:DIA]FLGAED
    [L]WN4DVER = [M:DIA]N4DVER
    [L]WDNAYEA = [M:DIA]DNAYEA
#MIPEA - 2016-08-11 - X3PEOP-975 - START
    #88314
    [L]WALLSRV = [M:DIA]ALLSRV
    [L]WSRV    = [M:DIA]SRV
    [L]WALLPRF = [M:DIA]ALLPRF
    [L]WPRF    = [M:DIA]PRF
    [L]WPOP    = [M:DIA]POP
#MIPEA - 2016-08-11 - X3PEOP-975 - END
Endif

Call DEBTRANS From GLOCK

Gosub TR1
If GOK<>0
 If NBSAL=0
   Call ECR_TRACE(mess(2,10703,1),0) From GESECRAN : # Aucun matricule à traiter
 Else
  #Opération réalisée
  Call ECR_TRACE(mess(3,10705,1),0) From GESECRAN
 Endif
Else
 #Opération interrompue : Erreur lors de la transaction.
 Call ECR_TRACE(mess(4,10705,1),0) From GESECRAN
Endif
Unlock =SYMBOLE
Call FERME_TRACE From LECFIC
Return

#############################################
$TR1
NBSAL=0
GOK=1
Trbegin [HRATS]
Gosub RECUP_RUBRIQUE
For [FCY]FCY0 Where evalue(CRITFCY)
 #88314
 #For [HRCTR]CTR1 Where ETRFCY=[F:FCY]FCY & evalue(CRITEMP)& evalue(CRITEMP2)
 For [LNK] Where ETRFCY=[F:FCY]FCY & evalue(CRITEMP) & evalue(CRITEMP2) & evalue(CRITEMP3)
  Read [F:ID]ID0=[F:HRCTR]REFNUM
  If ! fstat
   OK = 1
   If [F:ID]CODACS<>"" & GUSRACS<>2
    Read[F:ACC]CODACC= GUSER;[F:ID]CODACS
    If fstat or [F:ACC]EXEC<>2
     OK = 0
    Endif
   Endif
  Else
   OK =0
  Endif
  If OK
   Readlock [HRATS]ATS0=[F:HRCTR]REFNUM;[F:HRCTR]XITDAT;[F:HRCTR]CTRNUM
   If fstat=0
    If [M:DIA]ENAFLG=2     #Oui: MAJ attestation existante
     FLAG=1
     Gosub RECUP_INFOS
    Endif
   Elsif fstat=5
    FLAG=0
    Gosub RECUP_INFOS
   Else
    #"Erreur de lecture sur le fichier :"
    Call ECR_TRACE(mess(4,10707,1)-"TASSEDIC",0) From GESECRAN
    GOK = 0 : Break 2
   Endif
  Endif
 Next
Next
Commit
#MIPEA - 2016-08-11 - X3PEOP-975 - START
# FQ90623 - 30/09/14 - Enchainement de l'extraction DSN Fin de contrat
If dim([M:DIA]FLGDSNC)>0 & [M:DIA]FLGDSNC = 2
  Call DSN_SILENCIEUSE([M:DIA]PHADSN, [M:DIA]VERDSN, "02", [M:DIA]DATXITSTR, [M:DIA]DATXITEND, [M:DIA]ALLCPY, [M:DIA]CPY,
&                      [M:DIA]ALLFCY, [M:DIA]FCY, [M:DIA]ALLSRV, [M:DIA]SRV, [M:DIA]ALLPRF, [M:DIA]PRF, 3, [M:DIA]MATDEB, [M:DIA]MATFIN,
&                      [M:DIA]POP, 2, "", 0, "", "", [M:DIA]ERASE, 2, 1, 2, 1,0,0) From TRTDSNTR :#105476 - US3540
Endif
#MIPEA - 2016-08-11 - X3PEOP-975 - END
Return

$RECUP_RUBRIQUE
NBRUBSAL=0
NBRUBHRT=0
NBRUBASS=0
NBRUBPRV=0
NBRUBCP=0
NBRUBALC=0
NBINDEM=0
NBM12SAL=0
NBM12HRT=0
NBM12ASS=0

Filter [F:RUB] Where LEG=GCURLEG

For [F:RUB]RUB0 Where ATTASS<>""
 #THRAM - 2018-02-01 - X3-73514 - START
 #Case [F:RUB]ATTASS
 Case mid$([F:RUB]ATTASS,3,len([F:RUB]ATTASS)-2)#THRAM - 2018-02-01 - X3-73514-  END
  When "SAL"   : NBRUBSAL+=1 : RUBSAL(NBRUBSAL)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPSAL(NBRUBSAL)=3 : Else : TYPSAL(NBRUBSAL)=1 : Endif
  When "HRT"   : NBRUBHRT+=1 : RUBHRT(NBRUBHRT)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPHRT(NBRUBHRT)=3 : Else : TYPHRT(NBRUBHRT)=1 : Endif
  When "ASS"   : NBRUBASS+=1 : RUBASS(NBRUBASS)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPASS(NBRUBASS)=3 : Else : TYPASS(NBRUBASS)=1 : Endif
  When "PRV"   : NBRUBPRV+=1 : RUBPRV(NBRUBPRV)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPPRV(NBRUBPRV)=3 : Else : TYPPRV(NBRUBPRV)=1 : Endif
  When "CP"    : NBRUBCP+=1 : RUBCP(NBRUBCP)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPCP(NBRUBCP)=3   : Else : TYPCP(NBRUBCP)=1 : Endif
  When Default : NBRUBALC+=1 : RUBALC(NBRUBALC)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPALC(NBRUBALC)=3 : Else : TYPALC(NBRUBALC)=1 : Endif
 Endcase
Next
For [F:RUB]RUB0 Where BNSALC<>""
 NBINDEM+=1 : INDEMN(NBINDEM)=[F:RUB]COD
Next
For [F:RUB]RUB0 Where ATTSAL<>""
 #THRAM - 2018-02-01 - X3-73514 - START
 #Case [F:RUB]ATTSAL
 Case mid$([F:RUB]ATTASS,3,len([F:RUB]ATTASS)-2) #THRAM - 2018-02-01 - X3-73514 - END
  When "SAL"   : NBM12SAL+=1 : M12SAL(NBM12SAL)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPM12SAL(NBM12SAL)=3 : Else : TYPM12SAL(NBM12SAL)=1 : Endif
  When "HRT"   : NBM12HRT+=1 : M12HRT(NBM12HRT)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPM12HRT(NBM12HRT)=3 : Else : TYPM12HRT(NBM12HRT)=1 : Endif
  When "ASS"   : NBM12ASS+=1 : M12ASS(NBM12ASS)=[F:RUB]COD
               If [F:RUB]TYPRUB=5 : TYPM12ASS(NBM12ASS)=3 : Else : TYPM12ASS(NBM12ASS)=1 : Endif
 Endcase
Next

Filter [F:RUB]

Return

