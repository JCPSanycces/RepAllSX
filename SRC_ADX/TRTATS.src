$INFOS_EMP
#Extraction des informations pour le départ du salarié :
Call ECR_TRACE(mess(129,10703,1)-[F:HRCTR]REFNUM,0) From GESECRAN
Gosub DEBPERIO
NBSAL=NBSAL+1
STATUT=1
[F:HRATS]REFNUM = [F:HRCTR]REFNUM
[F:HRATS]XITDAT = [F:HRCTR]XITDAT
[F:HRATS]STRDAT = DEBPERIO
[F:HRATS]ENDDAT = [F:HRCTR]XITDAT
[F:HRATS]CTRNUM = [F:HRCTR]CTRNUM
#MIPEA - 2016-08-11 - X3PEOP-975 - START
[L]PDATANCENT=val(func AFNC.PARAM("DATANCENT",[F:FCY]LEGCPY)) # test si parametre Priorité date ancienneté et date d'entrée société
If [L]PDATANCENT <> 1 # test si parametre Priorité date ancienneté et date d'entrée société
  If [F:HRCTR]DATANC<>[0/0/0]
   # Date d'ancienneté
   [F:HRATS]STRWRK = [F:HRCTR]DATANC
   # Date d'entrée dans la société
  Elsif [F:HRCTR]DATCPY<>[0/0/0]
   [F:HRATS]STRWRK = [F:HRCTR]DATCPY
  Endif
  If [F:HRATS]STRWRK > DEBPERIO3# Test Date effective
   [F:HRATS]STRWRK =  DEBPERIO3
