Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTATS","TRTATS",4,"ZZTRTATS") From GTRAITE
End

#############################################
$ACTION

#MIPEA - 2016-09-30 - X3PEOP-751 - START
##MIPEA - 2016-08-11 - X3PEOP-975 - START
##JASMI - 2016-09-29 - START
##If func AFNC.ACTIV("KGZA")
#If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
##JASMI - 2016-09-29 - END
##  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
##If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
##  If func DIVPAYE.EXISTE_KXX("TRTATSKSA") Then
#    Gosub ACTION From TRTATSKSA
#    Return
#  #Endif
#Endif
##MIPEA - 2016-08-11 - X3PEOP-975 - END
#Case ACTION
# When "INIT"         : Gosub OUVRE
# When "CONTROLE"     : Gosub CONTROLE
# #MIPEA - 2016-08-11 - X3PEOP-975 - START
# When "DEBUT"        : Gosub DEBUT
# #When "DEBUT"        : Affzo [M:DIA] : Setmok [DIA] With 0
# #MIPEA - 2016-08-11 - X3PEOP-975 - END
# When "EXEC"         : Gosub EXEC
# When "OK"           : FIN = 1 : GOK = 1
# When "END"          : FIN = 1
# When "SORTIE"       : Gosub SORTIE
#Endcase

  Case ACTION
  When "INIT"         : Gosub OUVRE
  When "CONTROLE"     : Gosub CONTROLE
  When "DEBUT"        : Gosub DEBUT
  When "OK"           : FIN = 1 : GOK = 1
  When "END"          : FIN = 1
  When "SORTIE"       : Gosub SORTIE
  Endcase

  If func AFNC.ACTIV("KGZA")
    Case ACTION
    When "INIT","DEBUT"
      Gosub ACTION From TRTATSKSA
    Endcase
  Endif

  If ACTION = "EXEC"
    If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
      Gosub ACTION From TRTATSKSA
    Else
      Gosub EXEC
    Endif
  Endif
#MIPEA - 2016-09-30 - X3PEOP-751 - END
Return

#############################################
$OUVRE
Local Mask TRTATS [DIA]
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","HRATS") From GMEMO
Gosub SUITE_OUV

#JASMI - 2017-01-10 - START
Call MANAGE_LOCALISATION("TRTATS") From DIVPAYE
#JASMI - 2017-01-10 - END

Return

$SUITE_OUV
Gosub OUVFIC
Gosub DECLARATION
#JASMI - 2016-09-30 - Needs to be done on EXEC action - START
