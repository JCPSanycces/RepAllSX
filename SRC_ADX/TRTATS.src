[F:HRATS]EMPCTR=[F:HRCTR]NATCON
[F:HRATS]EMPHRSWEK=[F:HRCTR]HRSWEK
If [F:HRCTR]RATMIDWRK>0
 [F:HRATS]EMPHRSYEA=val(func AFNC.PARAM("HOUMAXYEA",[F:HRCTR]ETRFCY))*([F:HRCTR]RATMIDWRK/100)
Else
 [F:HRATS]EMPHRSYEA=val(func AFNC.PARAM("HOUMAXYEA",[F:HRCTR]ETRFCY))
Endif
STATUT=[F:HRCTR]STAEMP

If [F:HRATS]LSTDAYWRK<>[0/0/0]
 LASTDAT=[F:HRATS]LSTDAYWRK
Else
 LASTDAT=[F:HRATS]XITDAT
 #Dernier jour travaillé non renseigné
 Call ECR_TRACE(mess(211,10703,1),-1) From GESECRAN
