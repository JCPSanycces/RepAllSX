#############################################
## Recherche de la date d'entrée du salarié qui correspond à son départ. En effet, il a pu être muté et donc la date de début de contrat
## ne correspond pas à sa date d'entrée
$DEBPERIO
DEBPERIO = [0/0/0]
Filter [F:HRCTR2] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT<[F:HRCTR]CTRDAT & XITFNL=2
Read [F:HRCTR2]CTR0 Last
Filter [F:HRCTR2]
If !fstat
 #33868
 Read [F:HRCTR2]CTR0 Next
 If !fstat
  DEBPERIO=[F:HRCTR2]CTRDAT
 #MIPEA - 2016-08-11 - X3PEOP-975 - START
 # Test Date effective
  DEBPERIO3=DEBPERIO
  If [F:HRCTR2]FLGRET=2
     DEBPERIO3=[F:HRCTR2]RETDATEFF
  Endif
 #MIPEA - 2016-08-11 - X3PEOP-975 - END
 Endif
Endif
If DEBPERIO=[0/0/0]
 Filter [F:HRCTR2] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM
 Read [F:HRCTR2]CTR0 First
 Filter [F:HRCTR2]
 If !fstat
  DEBPERIO=[F:HRCTR2]CTRDAT
#MIPEA - 2016-08-11 - X3PEOP-975 - START
# Test Date effective
  DEBPERIO3=DEBPERIO
  If [F:HRCTR2]FLGRET=2
     DEBPERIO3=[F:HRCTR2]RETDATEFF
  Endif
 Else
  DEBPERIO=[F:HRCTR]CTRDAT
  # Test Date effective
  DEBPERIO3=DEBPERIO
 Endif
Endif
# Test Date effective
If [F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<DEBPERIO3
   DEBPERIO3=[F:HRCTR]RETDATEFF
Endif
#MIPEA - 2016-08-11 - X3PEOP-975 - END
Return

#############################################
$RECUP_IRC
Local Char ORGDES(250)
Raz [L]VARRCO : Raz [L]VAGIRC
#MIPEA - 2016-09-30 - X3PEOP-751 - START
Local Integer ORGLINE
Local Integer COUNTER
If clalev([F:PCA])=0 : Local File CAISSE [PCA] : Endif
If !clalev([F:ADIZZ]) : Local File ATABDIV [ADIZZ]    : Endif

Filter [ADIZZ] Where [ADIZZ]NUMTAB = 10469 & [ADIZZ]LEG = GCURLEG

For [ADIZZ]
  [L]COUNTER+=1
    If [ADIZZ]CODE = [V]GINDARR
      [L]ORGLINE=[L]COUNTER-1 : Break
    Endif
Next
Call ORGANISME ([F:ID]REFNUM,[F:FCY]FCY,[F:HRCTR]CTRNUM,[L]VARRCO,[L]ORGLINE) From SUBORG
#Call ORGANISME ([F:ID]REFNUM,[F:FCY]FCY,[F:HRCTR]CTRNUM,[L]VARRCO,GINDARR-1) From SUBORG
#MIPEA - 2016-09-30 - X3PEOP-751 - END
#38867
#If [F:HRATS]STA="CAD"
If STATUT>1
#MIPEA - 2016-09-30 - X3PEOP-751 - START
Local Integer ORGLINE
Local Integer COUNTER
If clalev([F:PCA])=0 : Local File CAISSE [PCA] : Endif
If !clalev([F:ADIZZ]) : Local File ATABDIV [ADIZZ]    : Endif

Filter [ADIZZ] Where [ADIZZ]NUMTAB = 10469 & [ADIZZ]LEG = GCURLEG

For [ADIZZ]
  [L]COUNTER+=1
    If [ADIZZ]CODE = [V]GINDAGI
      [L]ORGLINE=[L]COUNTER-1 : Break
    Endif
Next
 Call ORGANISME ([F:ID]REFNUM,[F:FCY]FCY,[F:HRCTR]CTRNUM,[L]VAGIRC,[L]ORGLINE) From SUBORG
 #Call ORGANISME ([F:ID]REFNUM,[F:FCY]FCY,[F:HRCTR]CTRNUM,[L]VAGIRC,GINDAGI-1) From SUBORG
Endif
#MIPEA - 2016-09-30 - X3PEOP-751 - END
If VARRCO<>""
 Read [F:ORG]ORG0=GCURLEG;VARRCO
 If fstat=0
  Call LECTEXTRA(ORGDES,"ORGANISME","DES",GCURLEG,VARRCO) From ATEXTRA
#  [F:HRATS]CAIARC=[F:ORG]DES-[F:ORG]ADD(0)-[F:ORG]ADD(1)-[F:ORG]ADD(2)-[F:ORG]POS-[F:ORG]CTY
  [F:HRATS]CAIARC=ORGDES-[F:ORG]ADD(0)-[F:ORG]ADD(1)-[F:ORG]ADD(2)-[F:ORG]POS-[F:ORG]CTY
 Else
 #"Erreur de lecture sur le fichier :"
  Call ECR_TRACE(mess(4,10707,1)-"ORGANISME",0) From GESECRAN
  GOK = 0 : Return
 Endif
Endif
If VAGIRC<>""
 Read [F:ORG]ORG0=GCURLEG;VAGIRC
 If fstat=0
  Call LECTEXTRA(ORGDES,"ORGANISME","DES",GCURLEG,VAGIRC) From ATEXTRA
#  [F:HRATS]CAIAGI=[F:ORG]DES-[F:ORG]ADD(0)-[F:ORG]ADD(1)-[F:ORG]ADD(2)-[F:ORG]POS-[F:ORG]CTY
  [F:HRATS]CAIAGI=ORGDES-[F:ORG]ADD(0)-[F:ORG]ADD(1)-[F:ORG]ADD(2)-[F:ORG]POS-[F:ORG]CTY
 Else
  #"Erreur de lecture sur le fichier :"
  Call ECR_TRACE(mess(4,10707,1)-"ORGANISME",0) From GESECRAN
  GOK = 0 : Return
 Endif
Endif
Return

