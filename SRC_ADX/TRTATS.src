 [F:HRATS]GRDXIT="AUT"
 Call LECTEXTRA([F:HRATS]GRDXITSPE,"HRXITGRD","DESAXX",[F:HRCTR]XITGRD,GCURLEG) From ATEXTRA
Elsif !fstat
 [F:HRATS]GRDXIT=[F:HRCTR]XITGRD
Else
  GMESSAGE=mess(4,10707,1)-"HRXITGRD [HRXGD]"
Endif
[F:HRATS]DATNTF=[F:HRCTR]NTFDAT
[F:HRATS]LSTDAYWRK=[F:HRCTR]LSTDAY

If [F:HRCTR]FLGPRV=2      :#Préavis effectué & payé
 [F:HRATS]FLGPRV=2
 [F:HRATS]STRDATPRV1=[F:HRCTR]STRTIMNTC
 [F:HRATS]ENDDATPRV1=[F:HRCTR]ENDTIMNTC
 [F:HRATS]STRDATPRV2=[F:HRCTR]STRTIMNTC
 [F:HRATS]ENDDATPRV2=[F:HRCTR]ENDTIMNTC
Endif

If [F:HRCTR]FLGPRV2=2      :#Préavis non effectué & payé
 [F:HRATS]FLGPRVOFF=2
 [F:HRATS]STRDATPRV4=[F:HRCTR]STRNTC2
 [F:HRATS]ENDDATPRV4=[F:HRCTR]ENDNTC2
 [F:HRATS]STRDATPRV2=[F:HRCTR]STRNTC2
 [F:HRATS]ENDDATPRV2=[F:HRCTR]ENDNTC2
Endif

If [F:HRCTR]FLGPRV3=2      :#Préavis non effectué & non payé
 [F:HRATS]FLGPRVOFF=2
 [F:HRATS]STRDATPRV4=[F:HRCTR]STRNTC3
 [F:HRATS]ENDDATPRV4=[F:HRCTR]ENDNTC3
 [F:HRATS]STRDATPRV3=[F:HRCTR]STRNTC3
 [F:HRATS]ENDDATPRV3=[F:HRCTR]ENDNTC3
Endif

[F:HRATS]=[F:ID]
If [F:HRCTR]WRKCTY<>""
 [F:HRATS]LSTPLCWRK=[F:HRCTR]WRKCTY
 If [F:HRCTR]WRKCODPOS<>""
  [F:HRATS]DEPLSTPLC=num$(left$([F:HRCTR]WRKCODPOS,2))
 Endif
Else
 Read [BPA]BPA0=3;[F:FCY]FCY;[F:FCY]BPAADD
 If !fstat
  [F:HRATS]LSTPLCWRK=[F:BPA]CTY
  [F:HRATS]DEPLSTPLC=num$(left$([F:BPA]POSCOD,2))
 Endif
Endif

# FQ81085 - 23/04/13 - Les numéros de sécu arrivent du contrat, et plus du salarié
[F:HRATS]NUMSSC  = [F:HRCTR]NUMSSCCTR
[F:HRATS]NUMSSC2 = [F:HRCTR]NUMSSCCTR2

[F:HRATS]QLF=[F:HRCTR]QLF
[F:HRATS]CATQLF=[F:HRCTR]CATQLF
[F:HRATS]FLGLIKFAM=[F:HRCTR]LNK     :#flag
[F:HRATS]TYPLNK=[F:HRCTR]TYPLNK     :#libellé
