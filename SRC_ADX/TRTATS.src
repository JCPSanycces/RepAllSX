#MIPEA - 2016-08-11 - X3PEOP-975 - START
$RECUP_CONTRATS

#Loop delete sub-table TASSEDIC3
Delete [F:AT3] Where REFNUM=[F:HRATS]REFNUM & XITDAT=[F:HRATS]XITDAT & CTRNUM=[F:HRATS]CTRNUM
If fstat=1
 GOK =-1 : GLOCK = "$TASSEDIC3" : Return
Endif

Raz [L]TABSTRCTR, [L]TABENDCTR, [L]TABSTRMINCTR, [L]TABSTRMAXCTR, [L]ICTR, [L]ICTR2, K
Raz [L]TABSTRCTR2, [L]TABENDCTR2, [L]TABSTRMINCTR2, [L]TABSTRMAXCTR2
#First loop with test payslip break, save in first tabs TABSTRCTR,TABSTRMINCTR,TABENDCTR,TABSTRMAXCTR
#Tab save périods of contract with test of Payslip regroup
#Only contract with XITDAT <= [CTR]XITDAT if FLGRET=2 & RETDATEFF<=[F:HRCTR]XITDAT & XITDAT<>[0/0/0]
Filter [F:HRCTR2] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT>=DEBPERIO
& & ((FLGRET<>2 & CTRDAT<=[F:HRCTR]XITDAT) | (FLGRET=2 & RETDATEFF<=[F:HRCTR]XITDAT & XITDAT<>[0/0/0] & XITDAT<=[F:HRCTR]XITDAT) )
For [F:HRCTR2]CTR0
  If [L]ICTR>MAXICTR+1 : Break : Endif
  If [L]ICTR=0 | [F:HRCTR2]CTRDAT>[L]TABENDCTR([L]ICTR-1)
   #Initialisation boundaries : First loop or current contrat record already included
   [L]TABSTRCTR ([L]ICTR)=[F:HRCTR2]CTRDAT
   [L]TABENDCTR ([L]ICTR)=[F:HRCTR2]CTRDAT
   [L]TABSTRMINCTR([L]ICTR)=[F:HRCTR2]CTRDAT
   [L]TABSTRMAXCTR([L]ICTR)=[F:HRCTR2]XITDAT
   If [F:HRCTR2]FLGRET=2 & [F:HRCTR2]RETDATEFF < F:HRATSCTRDAT
     [L]TABSTRMINCTR([L]ICTR)=[F:HRCTR2]RETDATEFF
   Endif
   If [L]ICTR=0 & [F:HRCTR2]FLGCREBUL<>2
    #Search the real started contrat record (= checked with breakdown)
    Filter [F:HRCTRX] Where REFNUM=[F:HRCTR2]REFNUM & CTRNUM=[F:HRCTR2]CTRNUM & CTRDAT<[F:HRCTR2]CTRDAT & FLGCREBUL=2
    Read [F:HRCTRX]CTR0 Last
    Filter [F:HRCTRX]
    If !fstat
     [L]TABSTRCTR ([L]ICTR)=[F:HRCTRX]CTRDAT
     [L]TABSTRMINCTR([L]ICTR)=[F:HRCTRX]CTRDAT
     If [F:HRCTRX]FLGRET=2 & [F:HRCTRX]RETDATEFF < [F:HRCTRX]CTRDAT
       [L]TABSTRMINCTR([L]ICTR)=[F:HRCTRX]RETDATEFF
     Endif
    Endif
   Endif
   #Search the laster contrat record (= not checked with breakdown)
   If [F:HRCTR2]XITDAT<>[0/0/0] & [F:HRCTR2]XITDAT<[F:HRCTR]XITDAT
    For [F:HRCTRX]CTR0 Where REFNUM=[F:HRCTR2]REFNUM & CTRNUM=[F:HRCTR2]CTRNUM & CTRDAT>[F:HRCTR2]XITDAT
     If [F:HRCTRX]FLGCREBUL=2 : Break : Endif
     [L]TABENDCTR ([L]ICTR)=[F:HRCTRX]CTRDAT
     [L]TABSTRMAXCTR([L]ICTR)=[F:HRCTRX]XITDAT
    Next
   Endif
   [L]ICTR+=1
  Endif
Next
Filter [F:HRCTR2]
#Second loop for the regroup payslip break, save in second tabs TABSTRCTR2,TABSTRMINCTR2,TABENDCTR2,TABSTRMAXCTR2
If [L]ICTR>0
  For K=0 To [L]ICTR-1
    If K=0 | (K > 0 & [L]TABENDCTR ([L]K-1) < [L]TABSTRCTR ([L]K))
     [L]TABSTRCTR2 ([L]ICTR2)=[L]TABSTRCTR ([L]K)
     [L]TABSTRMINCTR2 ([L]ICTR2)=[L]TABSTRMINCTR ([L]K)
     [L]TABENDCTR2 ([L]ICTR2)=[L]TABENDCTR ([L]K)
     [L]TABSTRMAXCTR2 ([L]ICTR2)=[L]TABSTRMAXCTR ([L]K)
     [L]ICTR2+=1
    Endif
  Next
Endif
#Third loop for the retroactivity(Backpay)
#Tab save périods of contract with test of Payslip regroup and Backpay
#if the effectivive date < the XITDAT ok previous contract
#if the effectivive date < the CTRDAT ok previous contract
[L]ICTR=1
K=[L]ICTR2-1
While K>0
  If ([L]TABSTRMAXCTR2 ([L]K-1) > [L]TABSTRMINCTR2 ([L]K))
   If [L]TABSTRMINCTR2 ([L]K-1) >= [L]TABSTRMINCTR2 ([L]K)
      Dela K-1,1 [L]TABSTRCTR2,[L]TABSTRMINCTR2,[L]TABENDCTR2,[L]TABSTRMAXCTR2
      [L]ICTR-=1
   Else
      [L]TABSTRMAXCTR2 ([L]K-1) = [L]TABSTRMINCTR2 ([L]K)-1
   Endif
  Endif
  K-=1
  [L]ICTR+=1
Wend
#Loop write sub-table TASSEDIC3
If [L]ICTR>0
  For K=0 To [L]ICTR-1
   Raz [F:AT3]
   [F:AT3]REFNUM=[F:HRATS]REFNUM
   [F:AT3]CTRNUM=[F:HRATS]CTRNUM
   [F:AT3]XITDAT=[F:HRATS]XITDAT
   [F:AT3]NUMLIG=K+1
   [F:AT3]STRCTRDAT=[L]TABSTRCTR2 ([L]K)
   [F:AT3]STRDATPER=[L]TABSTRMINCTR2 ([L]K)
   Read [F:HRCTR2]CTR0=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[L]TABENDCTR2 ([L]K)
   If fstat= 0
      [F:AT3]ENDDATPER=[L]TABSTRMAXCTR2([L]K)
      [F:AT3]CTRDAT=[F:HRCTR2]CTRDAT
      [F:AT3]JOB=[F:HRCTR2]JOB
   Endif
   GOK=1
   GPOINT = "MAJAT3" : Gosub ENTREE From EXEFNC
   If GOK
    Write[F:AT3]
    If fstat<>0
     GOK = 0 : Call FSTA("AT3") From GLOCK : Break
    Endif
   Endif
  Next
Endif
Return
#MIPEA - 2016-08-11 - X3PEOP-975 - END

#New 10/05
#############################################
$RECUP_SALAIRES
Delete [F:HRAT2] Where REFNUM=[F:HRATS]REFNUM & XITDAT=[F:HRATS]XITDAT & CTRNUM=[F:HRATS]CTRNUM
If fstat=1
 GOK =-1 : GLOCK = "$TASSEDIC2" : Return
Endif
I=1
DEBPERIO2=DEBPERIO
#On exclut les payes extournée
# 57997 : Ajout critère '& FLGOUT<>2'
Filter [F:VEP] Where EMP=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & [F:VEP]STRDAT>=DEBPERIO & [F:VEP]ENDDAT<LASTDAT & RVS<>2 & FLGOUT<>2
& Order By Key CLE=PYRDAT Desc
For [F:VEP]CLE
 If I>12 : Break : Endif
 DEBPERIO2=[F:VEP]STRDAT
 Raz [F:HRAT2]
 [F:HRAT2]REFNUM=[F:HRATS]REFNUM
 [F:HRAT2]CTRNUM=[F:HRATS]CTRNUM
 [F:HRAT2]XITDAT=[F:HRATS]XITDAT
 [F:HRAT2]NUMLIG=I
 [F:HRAT2]STRDATPER=[F:VEP]STRDAT
 [F:HRAT2]ENDDATPER=[F:VEP]ENDDAT
 [F:HRAT2]PYRDAT=[F:VEP]PAYDAT
 For J=1 To NBM12SAL
  Read [F:HSP]HSP3 = [F:VEP]BUL;M12SAL(J);TYPM12SAL(J)
  If fstat=0
   [F:HRAT2]SALGRO+=[F:HSP]AMT
  Endif
  Read [F:HSP]HSP3 = [F:VEP]BUL;M12SAL(J);TYPM12SAL(J)+6
  If fstat=0
   [F:HRAT2]SALGRO+=[F:HSP]AMT
  Endif
 Next
 For J=1 To NBM12HRT
  Read [F:HSP]HSP3 = [F:VEP]BUL;M12HRT(J);TYPM12HRT(J)
  If fstat=0
   [F:HRAT2]NBRHRSWRK+=[F:HSP]AMT
  Endif
  Read [F:HSP]HSP3 = [F:VEP]BUL;M12HRT(J);TYPM12HRT(J)+6
  If fstat=0
   [F:HRAT2]NBRHRSWRK+=[F:HSP]AMT
  Endif
 Next
 For J=1 To NBM12ASS
  Read [F:HSP]HSP3 = [F:VEP]BUL;M12ASS(J);TYPM12ASS(J)
  If fstat=0
   [F:HRAT2]AMTASS+=[F:HSP]AMT
  Endif
  Read [F:HSP]HSP3 = [F:VEP]BUL;M12ASS(J);TYPM12ASS(J)+6
  If fstat=0
   [F:HRAT2]AMTASS+=[F:HSP]AMT
  Endif
 Next
 GOK=1
 GPOINT = "MAJAT2" : Gosub ENTREE From EXEFNC
 If GOK
  Write[F:HRAT2]
  If fstat<>0
   GOK = 0 : Call FSTA("HRAT2") From GLOCK : Break
  Endif
  I=I+1
 Endif
Next
Filter [F:VEP]
Return

#############################################
$RECUP_SOLDE_TOUT_COMPTE
PAYESLD=0
#MIPEA - 2016-08-11 - X3PEOP-975 - START
#91943 : Add  & CTRDAT=[F:HRCTR]CTRDAT
#90002 : Add  & RVSDAT=[0/0/0] & RVS<>2
For [F:VEP]VEP0 Where EMP=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT=[F:HRCTR]CTRDAT & [F:VEP]ENDDAT>=LASTDAT & RVSDAT=[0/0/0] & RVS<>2
&                    & FLGOUT<>2
#For [F:VEP]VEP0 Where EMP=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT=[F:HRCTR]CTRDAT & [F:VEP]ENDDAT>=LASTDAT & FLGOUT<>2
#MIPEA - 2016-08-11 - X3PEOP-975 - END
  Call PARAM([F:VEP]FCY,"TYPCP",VALPAR)From ADOVAL
  FLGCPA=val(VALPAR)
  If [F:HRATS]STRDATCLE=[0/0/0]
   [F:HRATS]STRDATCLE=[F:VEP]STRDAT
  Endif
  [F:HRATS]ENDDATCLE=[F:VEP]ENDDAT
  [F:HRATS]PYRDATCLE=[F:VEP]PAYDAT
  For J=1 To NBRUBSAL
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBSAL(J);TYPSAL(J)
   If fstat=0
    [F:HRATS]SALGROCLE+=[F:HSP]AMT
   Endif
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBSAL(J);TYPSAL(J)+6
   If fstat=0
    [F:HRATS]SALGROCLE+=[F:HSP]AMT
   Endif
  Next
  For J=1 To NBRUBHRT
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBHRT(J);TYPHRT(J)
   If fstat=0
    [F:HRATS]NBRHRSCLE+=[F:HSP]AMT
   Endif
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBHRT(J);TYPHRT(J)+6
   If fstat=0
    [F:HRATS]NBRHRSCLE+=[F:HSP]AMT
   Endif
  Next
  For J=1 To NBRUBASS
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBASS(J);TYPASS(J)
   If fstat=0
    [F:HRATS]AMTCLE+=[F:HSP]AMT
   Endif
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBASS(J);TYPASS(J)+6
   If fstat=0
    [F:HRATS]AMTCLE+=[F:HSP]AMT
   Endif
  Next
  For J=1 To NBRUBPRV
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBPRV(J);TYPPRV(J)
   If fstat=0
    [F:HRATS]ALCNTC+=[F:HSP]AMT
   Endif
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBPRV(J);TYPPRV(J)+6
   If fstat=0
    [F:HRATS]ALCNTC+=[F:HSP]AMT
   Endif
  Next
  For J=1 To NBRUBCP
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBCP(J);TYPCP(J)
   If fstat=0
    [F:HRATS]ALCLEA+=[F:HSP]AMT
    If FLGCPA=2
     [F:HRATS]NBRDAYLEA+=[F:HSP]BAS  :#Nb jours Congés
    Else
     #Gestion des cp en ouvrés, donc il faut convertir en ouvrables...
     [F:HRATS]NBRDAYLEA+=arr(([F:HSP]BAS*2.50)/2.08,0.5)
    Endif
   Endif
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBCP(J);TYPCP(J)+6
   If fstat=0
    [F:HRATS]ALCLEA+=[F:HSP]AMT
    If FLGCPA=2
     [F:HRATS]NBRDAYLEA+=[F:HSP]BAS  :#Nb jours Congés
    Else
     #Gestion des cp en ouvrés, donc il faut convertir en ouvrables...
     [F:HRATS]NBRDAYLEA+=arr(([F:HSP]BAS*2.50)/2.08,0.5)
    Endif
   Endif
  Next
  For J=1 To NBRUBALC
   Call LECTURE("RUB",RUBALC(J),GCURLEG) From CONTOBJ
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBALC(J);TYPALC(J)
   If fstat=0
    Gosub MAJ_SOMME
   Endif
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBALC(J);TYPALC(J)+6
   If fstat=0
    Gosub MAJ_SOMME
   Endif
  Next
  #Solde de tout compte (Etat)
  Read [F:HSP]HSP3 = [F:VEP]BUL;RUBSLDCPT;1
  If fstat=0
   [F:HRATS]AMTALLCLE = [F:HSP]AMT
   [F:HRATS]BUL       = [F:HSP]BUL
   PAYESLD=1
  Endif
  Read [F:HSP]HSP3 = [F:VEP]BUL;RUBSLDCPT;7
  If fstat=0
   [F:HRATS]AMTALLCLE=[F:HSP]AMT
   PAYESLD=1
  Endif
  If PAYESLD=1
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBHRSDIF;1
   If !fstat :   [F:HRATS]NBRDIF = arr([F:HSP]AMT,0.01) :  Endif
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBHRSDIF;7
   If !fstat :  [F:HRATS]NBRDIF =  arr([F:HSP]AMT,0.01) :  Endif
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBAMTDIF;1
   If !fstat :   [F:HRATS]AMTDIF =  arr([F:HSP]AMT,0.01) :  Endif
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBAMTDIF;7
   If !fstat :  [F:HRATS]AMTDIF =  arr([F:HSP]AMT,0.01) :  Endif
#MIPEA - 2016-08-11 - X3PEOP-975 - START
#On veut la période suivant la dernière sortie definitive
   #Si c'est la paye du solde de tout compte on sort, car les payes suivantes
   #correspondent donc à une période d'emploi postérieure (saisonnier...)

   #98617_US2621
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBMUTMAIN;1
   If !fstat & [F:HSP]AMT>0 : [F:HRATS]FLGPORMUT=2 :  Endif
   If [F:HRATS]FLGPORMUT<2
    Read [F:HSP]HSP3 = [F:VEP]BUL;RUBMUTMAIN;7
    If !fstat & [F:HSP]AMT>0 : [F:HRATS]FLGPORMUT=2 :  Endif
   Endif
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBPRVMAIN;1
   If !fstat & [F:HSP]AMT>0 : [F:HRATS]FLGPORPRV=2 :  Endif
   If [F:HRATS]FLGPORPRV<2
    Read [F:HSP]HSP3 = [F:VEP]BUL;RUBPRVMAIN;7
    If !fstat & [F:HSP]AMT>0 : [F:HRATS]FLGPORPRV=2 :  Endif
   Endif
   #end 98617_US2621

   #US3751 108474 Stagiaire
   If WISTRAINEE
     Read [F:HSP]HSP3 = [F:VEP]BUL;RUBNBSTA;1
     If !fstat :   [F:HRATS]NBRMON = arr([F:HSP]AMT,0.01) :  Endif
     Read [F:HSP]HSP3 = [F:VEP]BUL;RUBNBSTA;7
     If !fstat :  [F:HRATS]NBRMON =  arr([F:HSP]AMT,0.01) :  Endif
     Read [F:HSP]HSP3 = [F:VEP]BUL;RUBBNSSTA;1
     If !fstat :   [F:HRATS]BNSSTG = arr([F:HSP]AMT,0.01) :  Endif
     Read [F:HSP]HSP3 = [F:VEP]BUL;RUBBNSSTA;7
     If !fstat :  [F:HRATS]BNSSTG =  arr([F:HSP]AMT,0.01) :  Endif
   Endif
   #END US3751 108474 Stagiaire
#MIPEA - 2016-08-11 - X3PEOP-975 - END
   Break
 Endif
Next
Return

#############################################
$MAJ_SOMME
Case [F:RUB]ATTASS
 When "LEG" : [F:HRATS]AMTALC(2)+=[F:HSP]AMT  : [F:HRATS]AMTALC(0)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
 When "SPE" : [F:HRATS]AMTALC(3)+=[F:HSP]AMT  : [F:HRATS]AMTALC(0)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
 When "SUP" : [F:HRATS]AMTALC(4)+=[F:HSP]AMT  : [F:HRATS]AMTALC(0)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
 When "JOU" : [F:HRATS]AMTALC(5)+=[F:HSP]AMT  : [F:HRATS]AMTALC(0)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
 When "CDD" : [F:HRATS]AMTALC(6)+=[F:HSP]AMT  : [F:HRATS]AMTALC(0)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
 When "CLI" : [F:HRATS]AMTALC(7)+=[F:HSP]AMT  : [F:HRATS]AMTALC(0)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
 When "MIS" : [F:HRATS]AMTALC(8)+=[F:HSP]AMT  : [F:HRATS]AMTALC(0)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
 When "NAV" : [F:HRATS]AMTALC(9)+=[F:HSP]AMT  : [F:HRATS]AMTALC(0)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
 When "RET" : [F:HRATS]AMTALC(10)+=[F:HSP]AMT : [F:HRATS]AMTALC(0)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
 When "AUT" : [F:HRATS]AMTALC(11)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
 When "CON" : [F:HRATS]AMTALC(12)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
 When "TRA" : [F:HRATS]AMTALC(13)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
 When "CNE" : [F:HRATS]AMTALC(14)+=[F:HSP]AMT  : [F:HRATS]AMTALC(0)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
 When "SIN" : [F:HRATS]AMTALC(15)+=[F:HSP]AMT  : [F:HRATS]AMTALC(0)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
 When "SPF" : [F:HRATS]AMTALC(16)+=[F:HSP]AMT  : [F:HRATS]AMTALC(0)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
 When "APP" : [F:HRATS]AMTALC(17)+=[F:HSP]AMT  : [F:HRATS]AMTALC(0)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
 When "RCV" : [F:HRATS]AMTALC(18)+=[F:HSP]AMT  : [F:HRATS]AMTALC(0)+=[F:HSP]AMT : [F:HRATS]AMTALC(1)+=[F:HSP]AMT
Endcase
Return

#############################################
$RECUP_PRIMES_INDEMNITE
J=0
Filter [F:VEP] Where EMP=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & [F:VEP]STRDAT>=DEBPERIO2 & [F:VEP]ENDDAT<LASTDAT & RVS<>2 & FLGOUT<>2
& Order By Key CLE=PYRDAT Desc
 For [F:VEP]CLE
  If NBINDEM<1 : Break : Endif
  For I=1 To NBINDEM
#MIPEA - 2016-08-11 - X3PEOP-975 - START
   W_OK=0 : #110859
   If J>dim([F:HRATS]DESBNS)-1 : Break 2 : Endif
   Read [F:RUB]RUB0=GCURLEG;INDEMN(I)
   If fstat=0
    Read [F:HSP]HSP3 = [F:VEP]BUL;INDEMN(I);1
    If fstat=0
      Call LECTEXTRA([F:HRATS]DESBNS(J),"RUBRIQUE","DES",GCURLEG,[F:RUB]COD) From ATEXTRA
      [F:HRATS]STRDATBNS(J)=[F:VEP]STRDAT
      [F:HRATS]ENDDATBNS(J)=[F:VEP]ENDDAT
      [F:HRATS]DATBNS(J)=[F:VEP]PAYDAT
      [F:HRATS]AMTBNS(J)=[F:HSP]AMT
      W_OK=1 : ##110859
    Else
     W_OK=0 : ##110859
      #J=J+1
#MIPEA - 2016-08-11 - X3PEOP-975 - END
    Endif
    Read [F:HSP]HSP3 = [F:VEP]BUL;INDEMN(I);7
    If fstat=0
      [F:HRATS]AMTBNS(J)+=[F:HSP]AMT
    Endif
#MIPEA - 2016-08-11 - X3PEOP-975 - START
    If W_OK : J=J+1 : Endif : ##110859
#MIPEA - 2016-08-11 - X3PEOP-975 - END
   Else
    #"Erreur de lecture sur le fichier :"
    Call ECR_TRACE(mess(4,10707,1)-"RUBRIQUE",0) From GESECRAN
    GOK = 0 : Break 2
   Endif
  Next
Next
Filter [F:VEP]
Return

#############################################
$INFOS_FCY
[F:HRATS]FCY=[F:FCY]FCY
[F:HRATS]FCYNAF=[F:FCY]NAF
[F:HRATS]FCYCRN=[F:FCY]CRN

Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
GCURLEG=[F:CPY]LEG

#Recup organisme ASSEDIC
#MIPEA - 2016-08-11 - X3PEOP-975 - START
[F:HRATS]ORGASS=1    :# par défaut car ML
#MIPEA - 2016-08-11 - X3PEOP-975 - END
Raz [L]ORG
#MIPEA - 2016-09-30 - X3PEOP-751 - START
Local Integer ORGLINE
Local Integer COUNTER
If clalev([F:PCA])=0 : Local File CAISSE [PCA] : Endif
If !clalev([F:ADIZZ]) : Local File ATABDIV [ADIZZ]    : Endif

Filter [ADIZZ] Where [ADIZZ]NUMTAB = 10469 & [ADIZZ]LEG = GCURLEG

For [ADIZZ]
  [L]COUNTER+=1
    If [ADIZZ]CODE = [V]GINDASS
      [L]ORGLINE=[L]COUNTER-1 : Break
    Endif
Next
Call ORGANISME ([F:HRCTR]REFNUM,[F:FCY]FCY,[F:HRCTR]CTRNUM,[L]ORG,[L]ORGLINE) From SUBORG
#Call ORGANISME ([F:HRCTR]REFNUM,[F:FCY]FCY,[F:HRCTR]CTRNUM,[L]ORG,GINDASS-1) From SUBORG
#MIPEA - 2016-09-30 - X3PEOP-751 - END
If [L]ORG<>""
 Read[ORG]ORG0=GCURLEG;[L]ORG
 If !fstat
  [F:HRATS]ORGASS=[F:ORG]TYPASS
  Call ORGAFFIL ([L]ORG,[F:FCY]FCY,"","",VNUMAFF,VNUMCTR) From SUBORA
  [F:HRATS]NUMORGASS=VNUMAFF
 Endif
Endif
[F:HRATS]FCYHRSWEK=val(func AFNC.PARAM("HOUWEKLEG",[F:HRCTR]ETRFCY))
[F:HRATS]FCYHRSYEA=val(func AFNC.PARAM("HOUMAXYEA",[F:HRCTR]ETRFCY))
#Recherche du site siège social
If [F:FCY]BPASGE<>""
 [F:HRATS]FCYSGE=[F:FCY]FCY
Else
 For [F:FCY2] Where LEGCPY=[F:FCY]LEGCPY & [F:FCY2]FCY<>[F:FCY]FCY
  If [F:FCY2]BPASGE<>""
   [F:HRATS]FCYSGE=[F:FCY2]FCY
   Break
  Endif
 Next
 If [F:HRATS]FCYSGE=""
  #Site principal (siège) de l'entreprise inexistant
  Call ECR_TRACE(mess(25,122,1)-"FACILITY",0) From GESECRAN
  GOK = 0 : Return
 Endif
Endif


Read [BPA]BPA0=3;[F:FCY]FCY;[F:FCY]BPAADD
If fstat= 0
 [F:HRATS]FCYADD1=[F:BPA]BPAADDLIG(0)
 [F:HRATS]FCYADD2=[F:BPA]BPAADDLIG(1)
 [F:HRATS]FCYADD3=[F:BPA]BPAADDLIG(2)
 [F:HRATS]FCYPOSCOD=[F:BPA]POSCOD
 [F:HRATS]FCYCTY=[F:BPA]CTY
 [F:HRATS]FCYCRY=[F:BPA]CRY
 [F:HRATS]FCYTEL=[F:BPA]TEL
Else
 #"Erreur de lecture sur le fichier :"
 Call ECR_TRACE(mess(4,10707,1)-"BPADDRESS",0) From GESECRAN
 GOK = 0 : Return
Endif
Read [F:CPY]CPY0=[F:FCY]LEGCPY
If fstat=0
 [F:HRATS]CURCLE=[F:CPY]ACCCUR
 [F:HRATS]FCYSTALEG=[F:CPY]CPYLOG
Else
 #"Erreur de lecture sur le fichier :"
 Call ECR_TRACE(mess(4,10707,1)-"COMPANY",0) From GESECRAN
 GOK = 0 : Return
Endif
Read [F:CNT]CNT0=3;[F:FCY]FCY;[F:FCY]CNTNAM
If fstat=0
 Read [F:AIN]AIN0=[F:FCY]CNTNAM
 If fstat=0
  [F:HRATS]FCYRPB=[F:AIN]CNTLNA-[F:AIN]CNTFNA
  [F:HRATS]FCYRPBFNC=[F:CNT]CNTFNC
  [F:HRATS]FCYRPBTEL=[F:CNT]TEL
 Elsif fstat<>5
 #"Erreur de lecture sur le fichier :"
  Call ECR_TRACE(mess(4,10707,1)-"CONTACTCRM",0) From GESECRAN
  GOK = 0 : Return
 Endif
Elsif fstat <>5
 #"Erreur de lecture sur le fichier :"
 Call ECR_TRACE(mess(4,10707,1)-"CONTACT",0) From GESECRAN
 GOK = 0 : Return
Endif
[F:HRATS]RPBCTY=[F:HRATS]FCYCTY
[F:HRATS]RPBDAT=date$
Gosub EFFECTIF
Return

#Effectif au 31/12 écoulé
$EFFECTIF
Raz [F:HRATS]FCYNBRSAL
If dim([M:DIA]DATXITEND)>0
 If month([M:DIA]DATXITEND)=12
  DATREF=gdat$(31,12,year([M:DIA]DATXITEND))
 Else
  DATREF=gdat$(31,12,year([M:DIA]DATXITEND)-1)
 Endif
Elsif dim([M:DIA]XITDAT)>0
 If month([M:DIA]XITDAT)=12
  DATREF=gdat$(31,12,year([M:DIA]XITDAT))
 Else
  DATREF=gdat$(31,12,year([M:DIA]XITDAT)-1)
 Endif
Endif
Raz OLDMAT
For [F:ES]CTR0 Where ETRFCY=[F:FCY]FCY & CTRDAT<=DATREF & (XITDAT>=DATREF | XITDAT=[00/00/00])
 If OLDMAT<>[F:ES]REFNUM : # Cas du multi contrats sur le même site
  [F:HRATS]FCYNBRSAL +=1
  OLDMAT = [F:ES]REFNUM
 Endif
Next
Return

AB_TR1
Rollback
GMESSAGE = mess (17,107,1) :#Rollback suite à une erreur dans la transaction
Return

$SORTIE
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

