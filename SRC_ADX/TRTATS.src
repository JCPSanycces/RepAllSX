WISTRAINEE=func DIVPAYE.ISTRAINEE([F:HRCTR]NATCON)
If WISTRAINEE
   [F:HRATS]NBRPERSTG=[F:HRCTR]NBRPER
   [F:HRATS]PERSTG=[F:HRCTR]PERCON
Endif
