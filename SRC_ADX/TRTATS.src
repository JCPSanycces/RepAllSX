# FQ90623 - 30/09/14 - Enchainement de l'extraction DSN Fin de contrat
Subprog AM_FLGDSNC(VALEUR)
Variable Integer VALEUR

  If [L]VALEUR = 2
    Actzo [M]PHADSN
    Actzo [M]VERDSN
    Actzo [M]ERASE
  Else
    Effzo [M]PHADSN : Grizo [M]PHADSN
    Effzo [M]VERDSN : Grizo [M]VERDSN
    Effzo [M]ERASE  : Grizo [M]ERASE
  Endif
End

