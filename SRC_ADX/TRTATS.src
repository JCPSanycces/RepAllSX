If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Return

#--------------------------------------------------
# V01X07 - Enchainement extraction AED
#--------------------------------------------------
$DEBUT
#JASMI - 2017-01-10 - START
Call DISPLAY_HIDE From TRTATSLEG
#JASMI - 2017-01-10 - END

#88314
#If dim([M:DIA]FLGAED) > 0
#    [M:DIA]FLGAED = val(func AFNC.PARAM("ENCEXTDNA", ""))
#    Call AM_FLGAED([M:DIA]FLGAED) From TRTATS
#Endif
#MIPEA - 2016-08-11 - X3PEOP-975 - START
If dim([M:DIA]FLGAED) > 0
    [M:DIA]FLGAED = val(func AFNC.PARAM("ENCEXTDNA", ""))
    Call AM_FLGAED([M:DIA]FLGAED) From TRTATS
    # FQ90623 - 30/09/14 - Enchainement de l'extraction DSN Fin de contrat
    If dim([M:DIA]FLGDSNC)>0 Then
      Call AM_FLGDSNC([M:DIA]FLGDSNC) From TRTATS
    Endif
Endif
#MIPEA - 2016-08-11 - X3PEOP-975 - END
Affzo [M:DIA] : Setmok [DIA] With 0
Return

