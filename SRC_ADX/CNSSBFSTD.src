      #NBLIGA = func FIND_DATA(num$(NATFIS), "AML", 10452)

      If NATFIS="" Then NATFIS = "ZVIDE" : Endif
      #US3924 106549 Not needed anymore
      # FQ106549 - Le menu local 452 est devenu une fonction
      NBLIGA = func FIND_DATA(NATFIS, "HRFISCALNAT", 0)
      #ADNGO - 2017-07-03 - X3-29553 - END
      For [F:PLC]
        [M]AMTBUDREF(NBLIGA-1) += [F:PLC]CSTTOTIDV*[F:PLF]NBREMP
      Next
      # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants
      [M]NBRPAR(NBLIGA-1)    += [F:PLF]NBREMP
      # FQ75457 - MABON 26/08/11 - Ajout du nombre d'heures
      If clalev([F:STG])=0 : Local File STAGE [STG] : Endif
      Read [F:STG]STG0=[F:PLF]STG
      [M]NBRHR(NBLIGA-1)     += [F:STG]NBRHOUIPT*[F:PLF]NBREMP
#    Endif
  Endif
  If TYPAMT="READ" Then
    # FQ80895 - MABON 07/06/12 - On écarte les inscriptions refusées
#    For [F:INS]
    For [F:INS] Where STA<>3
    # Fin MABON
      Gosub CALC_AMT_FIS
    Next
  Endif
  If TYPAMT="REAI" Then
    Gosub CALC_AMT_FIS
  Endif
End
# Fin MABON

#**#####################################################################################
#* Récupération du libellé du code de la table diverse
#*!
Funprog FIND_DESAXX(LCOD, NUMADI)
Value Char    LCOD
Value Integer NUMADI
Local Char    DES_C

  If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
  Read [AXX]AXX0="ATABDIV";"LNGDES";GLANGUE;num$(NUMADI);LCOD
  If !fstat Then
    DES_C=[F:AXX]TEXTE
  Endif
End DES_C

#**
#* Sélection des années, sociétés ou sites dans une liste
#*!
$SEL_LISTE

  Case LISTE
    When "SELYEA"    : Gosub SELYEAPLF
    When "SELLEGPLF" : Gosub SELLEGPLF
    When "SELCPYPLF" : Gosub SELCPYPLF
    When "SELFCYPLF" : Gosub SELFCYPLF
    When "SELVERPLF" : Gosub SELVERPLF
  Endcase
Return

#**
#* Sélection d'une année
#*!
$SELYEAPLF
Local Char    CRITERE(255)
Local Char    TEX(80)(1..200), KEYTEX(80)(1..200)
# FQ71320 - MABON 01/04/11 - Type de la sélection
If PARAM(1)="B" Then
  Local Char TEXTE(80)(1..200,1..6)
Else
  Local Char TEXTE(80)(1..200,1..4)
Endif

  # SYMEU : ajout du flag Calcul pour ne prendre que ceux pris en compte dans le calcul
  # FQ71320 - MABON 01/04/11 - Selon le type de la sélection, on filtre sur les plans définitifs ou non
#  CRITERE = "FLGCLO=2 & CLCFLG=2"
  CRITERE = "CLCFLG=2"
  If PARAM(1)<>"B" Then
    CRITERE -= "& FLGCLO=2"
  Endif
  If GLEGFIL<>"" Then
    CRITERE -= "& (LEGPLF='"+GLEGFIL+"' | LEGPLF='')"
  Endif

  NBCOL = 3 : EXPSTART="YEAPLF>''" : START="YEAPLF"
  TIT(0) = mess(8,31,1)-mess(166,10717,1) : # Sélection Plans prévisionnels
  #ADNGO - 2017-07-03 - X3-29553 - START
  #TIT(1) = mess(2,47,1)                   : # Année
  TIT(1) = mess(2,10464,1)                : # Plan #US3924 106549
  #ADNGO - 2017-07-03 - X3-29553 - END
  # FQ81085 - MABON 24/05/12 - Adding LEG
  TIT(2) = mess(238,133,1)                : # Législation
  If PARAM(1)="B" Then
#    TIT(3) = mess(2,45,1)+"/"+mess(3,45,1): # Société/Site
#    TIT(4) = mess(5,144,1)                : # Version
    TIT(3) = mess(5,144,1)                : # Version
    TIT(4) = mess(2,45,1)+"/"+mess(3,45,1): # Société/Site
    TIT(5) = mess(2,617,1)                : # Définitif
  Else
    TIT(3) = mess(2,45,1)                 : # Société
    TIT(4) = mess(3,45,1)                 : # Site
  Endif
  # End MABON

  Filter [F:PLF] Where evalue(CRITERE)
  For [F:PLF]
    # FQ71306 - MABON 03/02/11 - Le tableau KEY ne peut pas contenir une clé combinée, sinon on n'est pas positionnée
    # sur la valeur en cours
    # FQ71320 - MABON 01/04/11 - Selon le type de la sélection, on affiche la version ou non
#    If [F:PLF]YEAPLF<>"" & !find([F:PLF]YEAPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF, KEYTEX) Then
    #ADNGO - 2017-07-03 - X3-29553 - START
    Read [BUR]BUR0(4)=[F:PLF]YEAPLF;[F:PLF]CPYPLF;[F:PLF]FCYPLF;[F:PLF]LEGPLF
    If fstat
      PLFSTRDAT=[F:PLF]STRDAT
      PLFENDDAT=[F:PLF]ENDDAT
    Else
      PLFSTRDAT=[F:BUR]STRDAT
      PLFENDDAT=[F:BUR]ENDDAT
    Endif
    #ADNGO - 2017-07-03 - X3-29553 - END
    #&   & ((PARAM(1)<>"B" & !find([F:PLF]YEAPLF+"~"+[F:PLF]LEGPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF, KEYTEX))
    #&     | (PARAM(1)="B" & !find([F:PLF]YEAPLF+"~"+[F:PLF]LEGPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF+"~"+[F:PLF]VERPLF+"~"+num$([F:PLF]FLGCLO), KEYTEX))) Then
    If [F:PLF]YEAPLF<>""
&   & ((PARAM(1)<>"B" & !find([F:PLF]YEAPLF+"~"+[F:PLF]LEGPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF+"~"+num$(PLFSTRDAT)+"~"+num$(PLFENDDAT), KEYTEX))
&     | (PARAM(1)="B" & !find([F:PLF]YEAPLF+"~"+[F:PLF]LEGPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF+"~"+num$(PLFSTRDAT)+"~"+num$(PLFENDDAT)+"~"+[F:PLF]VERPLF+"~"+num$([F:PLF]FLGCLO), KEYTEX))) Then
      ENR_OK = func SUBHRSES.GET_AUZ([F:PLF]CPYPLF, [F:PLF]FCYPLF, "CONSSBF")
      If ENR_OK=2 Then
        NBTEX += 1
#        TEX(NBTEX)     = [F:PLF]YEAPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF
        TEX(NBTEX)     = [F:PLF]YEAPLF
        # FQ81085 - MABON 24/05/12 - Adding LEG
        KEYTEX(NBTEX)  = [F:PLF]YEAPLF+"~"+[F:PLF]LEGPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF

        KEYTEX(NBTEX) += "~"+num$(PLFSTRDAT)+"~"+num$(PLFENDDAT)
        # End MABON
        # FQ71320 - MABON 01/04/11 - Selon le type de la sélection, on affiche la version ou non
        If PARAM(1)="B" Then
          KEYTEX(NBTEX) += "~"+[F:PLF]VERPLF+"~"+num$([F:PLF]FLGCLO)
        Endif
        TEXTE(NBTEX,1) = [F:PLF]YEAPLF
        TEXTE(NBTEX,2) = [F:PLF]LEGPLF
#        TEXTE(NBTEX,3) = [F:PLF]CPYPLF
#        If PARAM(1)="B" Then
#          TEXTE(NBTEX,3) -= "/"-[F:PLF]FCYPLF
#        Else
#          TEXTE(NBTEX,4) = [F:PLF]FCYPLF
#        Endif
#        If PARAM(1)="B" Then
#          TEXTE(NBTEX,4) = [F:PLF]VERPLF
#          TEXTE(NBTEX,5) = mess([F:PLF]FLGCLO,1,1)
#        Endif
        If PARAM(1)="B" Then
          TEXTE(NBTEX,3) = [F:PLF]VERPLF
          #TEXTE(NBTEX,4) = [F:PLF]CPYPLF-"/"-[F:PLF]FCYPLF
          TEXTE(NBTEX,4) = [F:PLF]CPYPLF-"-"-[F:PLF]FCYPLF
          TEXTE(NBTEX,5) = mess([F:PLF]FLGCLO,1,1)
        Else
          TEXTE(NBTEX,3) = [F:PLF]CPYPLF
          TEXTE(NBTEX,4) = [F:PLF]FCYPLF
        Endif
      Endif
    Endif
  Next
  Filter [F:PLF]
Return

#**
#* FQ85365 - MABON 20/11/12
#* Liste des législations sélectionnables, selon l'année du plan, et les droits utilisateur
#*!
$SELLEGPLF
Local Char    CRITERE(255)
Local Char    TEX(80)(1..200), TEXTE(80)(1..200,1..1)
Local Integer AUZCFY

  CRITERE = "YEAPLF='"+[M]YEAPLF+"' & CLCFLG=2"
  If GCHOIX="SBF" Then
    CRITERE -= "& FLGCLO=2"
  Endif
  If [M:SBF1]CPYPLF<>"" Then
    CRITERE -= "& CPYPLF='"+[M:SBF1]CPYPLF+"'"
  Endif
  If [M:SBF1]FCYPLF<>"" Then
    CRITERE -= "& FCYPLF='"+[M:SBF1]FCYPLF+"'"
  Endif

  NBCOL = 3 : EXPSTART="LEGPLF<>''" : START="LEGPLF"
  TIT(0) = mess(  8, 31,1)-mess(218,107,1)-mess(166,10717,1) : # Sélection Législation Plans prévisionnels
  TIT(1) = mess(218,107,1)                                   : # Législation
  Filter [F:PLF] Where evalue(CRITERE)
  For [F:PLF]
    If [F:PLF]LEGPLF<>"" & !find([F:PLF]LEGPLF, TEX) Then
      NBTEX += 1
      TEX(NBTEX)     = [F:PLF]LEGPLF
      TEXTE(NBTEX,1) = [F:PLF]LEGPLF
    Endif
  Next
  Filter [F:PLF]
Return

#**
#* Liste des sociétés sélectionnables, selon l'année du plan, et les droits utilisateur
#*!
$SELCPYPLF
Local Char    CRITERE(255)
Local Char    TEX(80)(1..200), TEXTE(80)(1..200,1..4), KEYTEX(80)(1..200)
Local Integer AUZCFY, AUZLEG

  # FQ83584 - MABON 17/07/12 - On ne sélectionne plus les groupes
#  If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
  # Fin MABON
  # SYMEU : ajout du flag Calcul pour ne prendre que ceux pris en compte dans le calcul
  # FQ83584 - MABON 17/07/12 - On ne veut les définitifs que si suivi budget formation
#  CRITERE = "YEAPLF='"+[M]YEAPLF+"' & FLGCLO=2 & CLCFLG=2"
  CRITERE = "YEAPLF='"+[M]YEAPLF+"' & CLCFLG=2 & LEGPLF='"+[M]LEGPLF+"'"
  If GCHOIX="SBF" Then
    CRITERE -= "& FLGCLO=2"
  Endif
  # Fin MABON

  NBCOL = 4 : EXPSTART="CPYPLF<>''" : START="CPYPLF"
  TIT(0) = mess(8,31,1)-mess(2,45,1)-mess(166,10717,1) : # Sélection Société Plans prévisionnels
  TIT(1) = mess(2,45,1)                                : # Société
  TIT(2) = mess(238,133,1)                             : # Législation
  TIT(3) = mess(38,100,1)                              : # Nom
  TIT(4) = mess(167,10717,1)                           : # Int court
#  TIT(4) = mess(204,10717,1)                              : # Groupe
  # FQ83584 - MABON 17/07/12 - On trie par société
#  Filter [F:PLF] Where evalue(CRITERE)
  Filter [F:PLF] Where evalue(CRITERE) Order By CPYPLF
  # Fin MABON
  For [F:PLF]
    If [F:PLF]CPYPLF<>"" & !find([F:PLF]CPYPLF, TEX) Then
      #ADNGO - 2017-11-06 - START
      Read [BUR]BUR0(4)=[F:PLF]YEAPLF;[F:PLF]CPYPLF;[F:PLF]FCYPLF;[F:PLF]LEGPLF
      If fstat
        PLFSTRDAT=[F:PLF]STRDAT
        PLFENDDAT=[F:PLF]ENDDAT
      Else
        PLFSTRDAT=[F:BUR]STRDAT
        PLFENDDAT=[F:BUR]ENDDAT
      Endif
      If [F:PLF]YEAPLF<>""
&   & ((PARAM(1)<>"B" & !find([F:PLF]YEAPLF+"~"+[F:PLF]LEGPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF+"~"+num$(PLFSTRDAT)+"~"+num$(PLFENDDAT), KEYTEX))
&     | (PARAM(1)="B" & !find([F:PLF]YEAPLF+"~"+[F:PLF]LEGPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF+"~"+num$(PLFSTRDAT)+"~"+num$(PLFENDDAT)+"~"+[F:PLF]VERPLF+"~"+num$([F:PLF]FLGCLO), KEYTEX))) Then
      #ADNGO - 2017-11-06 - END
      AUZCFY = func SUBHRSES.GET_AUZ([F:PLF]CPYPLF, "", "CONSSBF") : # Vérification des droits de l'utilisateur sur cette société
      AUZLEG = 2
      Read [F:CPY]CPY0=[F:PLF]CPYPLF
#      If GLEGFIL<>"" & !fstat & [F:CPY]LEG<>GLEGFIL Then AUZLEG=1 : Endif
#      If [M]LEGPLF<>"" & !fstat & [F:CPY]LEG<>[M]LEGPLF Then AUZLEG=1 : Endif
      If AUZCFY=2 & AUZLEG=2 Then
        NBTEX += 1
        #ADNGO - 2017-11-06 - START
        KEYTEX(NBTEX)  = [F:PLF]YEAPLF+"~"+[F:PLF]LEGPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF
        # FQ106549 - Ajout de la période
        KEYTEX(NBTEX) += "~"+num$(PLFSTRDAT)+"~"+num$(PLFENDDAT)
        # FQ71320 -  Selon le type de la sélection, on affiche la version ou non
        If PARAM(1)="B" Then
          KEYTEX(NBTEX) += "~"+[F:PLF]VERPLF+"~"+num$([F:PLF]FLGCLO)
        Endif
        #ADNGO - 2017-11-06 - END
        TEX(NBTEX)     = [F:PLF]CPYPLF
        TEXTE(NBTEX,1) = [F:PLF]CPYPLF
        TEXTE(NBTEX,2) = [F:CPY]LEG
        TEXTE(NBTEX,3) = [F:CPY]CPYNAM
        TEXTE(NBTEX,4) = [F:CPY]CPYSHO
#          TEXTE(NBTEX,4) = mess(1,1,1) : # Non

        # FQ83584 - MABON 17/07/12 - On ne sélectionne plus les groupes
#        Filter [F:AGC] Where CPY=[F:PLF]CPYPLF
#        For [F:AGC]
#          If [F:AGC]GRP<>[F:PLF]CPYPLF & !find([F:AGC]GRP, TEX) Then
#            NBTEX += 1
#            TEX(NBTEX)     = [F:AGC]GRP
#            TEXTE(NBTEX,1) = [F:AGC]GRP
#            Read [F:CPY]CPY0=[F:AGC]GRP
#            If !fstat Then
#              TEXTE(NBTEX,2) = [F:CPY]CPYNAM
#              TEXTE(NBTEX,3) = [F:CPY]CPYSHO
#              TEXTE(NBTEX,4) = mess(2,1,1) : # Oui
#            Endif
#          Endif
#        Next
#        Filter [F:AGC]
        # Fin MABON
      Endif
    Endif
   Endif
  Next
  Filter [F:PLF]
Return

#**
#* Liste des sites sélectionnables, selon l'année du plan, et les droits utilisateur
#*!
$SELFCYPLF
Local Char    CRITERE(255)
Local Char    TEX(80)(1..200), TEXTE(80)(1..200,1..6),KEYTEX(80)(1..200)
Local Integer AUZCFY, AUZLEG

  # SYMEU : ajout du flag Calcul pour ne prendre que ceux pris en compte dans le calcul
  # FQ83584 - MABON 17/07/12 - On ne veut les définitifs que si suivi budget formation
#  CRITERE = "YEAPLF='"+[M]YEAPLF+"' & FLGCLO=2 & CLCFLG=2"
  CRITERE = "YEAPLF='"+[M]YEAPLF+"' & CLCFLG=2 & LEGPLF='"+[M]LEGPLF+"'"
  If GCHOIX="SBF" Then
    CRITERE -= "& FLGCLO=2"
  Endif
  # Fin MABON

  NBCOL = 5 : EXPSTART="FCYPLF<>''" : START="FCYPLF"
  TIT(0) = mess(8,31,1)-mess(3,45,1)-mess(166,10717,1) : # Sélection Site Plans prévisionnels
  TIT(1) = mess(2,45,1)                                : # Société
  TIT(2) = mess(238,133,1)                             : # Législation
#  TIT(2) = mess(38,100,1)                              : # Nom
  TIT(3) = mess(3,45,1)                                : # Site
  TIT(4) = mess(38,100,1)                              : # Nom
  TIT(5) = mess(167,10717,1)                           : # Int court
  # FQ83584 - MABON 17/07/12 - On trie par site
#  Filter [F:PLF] Where evalue(CRITERE)
  Filter [F:PLF] Where evalue(CRITERE) Order By FCYPLF
  # Fin MABON
  For [F:PLF]
    If [F:PLF]FCYPLF<>"" & !find([F:PLF]FCYPLF, TEX) Then
      #ADNGO - 2017-11-06 - START
      Read [BUR]BUR0(4)=[F:PLF]YEAPLF;[F:PLF]CPYPLF;[F:PLF]FCYPLF;[F:PLF]LEGPLF
      If fstat
        PLFSTRDAT=[F:PLF]STRDAT
        PLFENDDAT=[F:PLF]ENDDAT
      Else
        PLFSTRDAT=[F:BUR]STRDAT
        PLFENDDAT=[F:BUR]ENDDAT
      Endif
      If [F:PLF]YEAPLF<>""
&   & ((PARAM(1)<>"B" & !find([F:PLF]YEAPLF+"~"+[F:PLF]LEGPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF+"~"+num$(PLFSTRDAT)+"~"+num$(PLFENDDAT), KEYTEX))
&     | (PARAM(1)="B" & !find([F:PLF]YEAPLF+"~"+[F:PLF]LEGPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF+"~"+num$(PLFSTRDAT)+"~"+num$(PLFENDDAT)+"~"+[F:PLF]VERPLF+"~"+num$([F:PLF]FLGCLO), KEYTEX))) Then
      #ADNGO - 2017-11-06 - END
      AUZCFY = func SUBHRSES.GET_AUZ("", [F:PLF]FCYPLF, "CONSSBF") : # Vérification des droits de l'utilisateur sur ce site
      AUZLEG = 2
      Read [F:FCY]FCY0=[F:PLF]FCYPLF
#      If GLEGFIL<>"" & !fstat & [F:FCY]LEG<>GLEGFIL Then AUZLEG=1 : Endif
#      If [M]LEGPLF<>"" & !fstat & [F:FCY]LEG<>[M]LEGPLF Then AUZLEG=1 : Endif
      If AUZCFY=2 & AUZLEG=2 Then
        NBTEX += 1
        #ADNGO - 2017-11-06 - START
        KEYTEX(NBTEX)  = [F:PLF]YEAPLF+"~"+[F:PLF]LEGPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF
        # FQ106549 - Ajout de la période
        KEYTEX(NBTEX) += "~"+num$(PLFSTRDAT)+"~"+num$(PLFENDDAT)
        # FQ71320 - Selon le type de la sélection, on affiche la version ou non
        If PARAM(1)="B" Then
          KEYTEX(NBTEX) += "~"+[F:PLF]VERPLF+"~"+num$([F:PLF]FLGCLO)
        Endif
        #ADNGO - 2017-11-06 - END
        TEX(NBTEX)     = [F:PLF]FCYPLF
        TEXTE(NBTEX,3) = [F:PLF]FCYPLF
        Read [F:CPY]CPY0=[F:FCY]LEGCPY
        If !fstat Then
          TEXTE(NBTEX,1) = [F:FCY]LEGCPY
#          TEXTE(NBTEX,2) = [F:CPY]CPYNAM
          TEXTE(NBTEX,2) = [F:CPY]LEG
        Endif
        TEXTE(NBTEX,4) = [F:FCY]FCYNAM
        TEXTE(NBTEX,5) = [F:FCY]FCYSHO
      Endif
    Endif
   Endif
  Next
  Filter [F:PLF]
Return

#**
#* FQ71320 - MABON 01/04/11
#* Liste des versions sélectionnables, selon l'année du plan, et les droits utilisateur
#*!
$SELVERPLF
Local Char    CRITERE(255)
Local Char    TEX(80)(1..200), TEXTE(80)(1..200,1..4), KEYTEX(80)(1..200)
Local Integer AUZCFY

  CRITERE = "YEAPLF='"+[M]YEAPLF+"' & CLCFLG=2 & LEGPLF='"+[M]LEGPLF+"'"
  If [M:SBF1]CPYPLF<>"" Then
    CRITERE -= "& CPYPLF='"+[M:SBF1]CPYPLF+"'"
  Endif
  If [M:SBF1]FCYPLF<>"" Then
    CRITERE -= "& FCYPLF='"+[M:SBF1]FCYPLF+"'"
  Endif

  NBCOL = 3 : EXPSTART="VERPLF<>''" : START="VERPLF"
  TIT(0) = mess(  8, 31,1)-mess(235,10717,1)-mess(166,10717,1) : # Sélection Version Plans prévisionnels
  TIT(1) = mess(235,10717,1)                                   : # Version
  TIT(2) = mess(2,617,1)                                       : # Définitif
  TIT(3) = mess(2,45,1)                                        : # Société
  TIT(4) = mess(3,45,1)                                        : # Site
  Filter [F:PLF] Where evalue(CRITERE)
  For [F:PLF]
###    If [F:PLF]VERPLF<>"" & !find([F:PLF]VERPLF, TEX) Then
##    If [F:PLF]VERPLF<>""
##&     & !find([F:PLF]YEAPLF+"~"+[F:PLF]LEGPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF+"~"+[F:PLF]VERPLF+"~"+num$([F:PLF]FLGCLO), KEYTEX) Then
##      NBTEX += 1
##      TEX(NBTEX)     = [F:PLF]VERPLF
##      KEYTEX(NBTEX)  = [F:PLF]YEAPLF+"~"+[F:PLF]LEGPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF+"~"+[F:PLF]VERPLF+"~"+num$([F:PLF]FLGCLO)
##      TEXTE(NBTEX,1) = [F:PLF]VERPLF
##      TEXTE(NBTEX,2) =  mess([F:PLF]FLGCLO,1,1)
##      TEXTE(NBTEX,3) = [F:PLF]CPYPLF
##      TEXTE(NBTEX,4) = [F:PLF]FCYPLF
##    Endif
    If [F:PLF]VERPLF<>"" & !find([F:PLF]VERPLF, TEX) Then
          Read [BUR]BUR0(4)=[F:PLF]YEAPLF;[F:PLF]CPYPLF;[F:PLF]FCYPLF;[F:PLF]LEGPLF
          If fstat
            PLFSTRDAT=[F:PLF]STRDAT
            PLFENDDAT=[F:PLF]ENDDAT
          Else
            PLFSTRDAT=[F:BUR]STRDAT
            PLFENDDAT=[F:BUR]ENDDAT
          Endif

          If [F:PLF]YEAPLF<>""
&   & ((PARAM(1)<>"B" & !find([F:PLF]YEAPLF+"~"+[F:PLF]LEGPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF+"~"+num$(PLFSTRDAT)+"~"+num$(PLFENDDAT), KEYTEX))
&     | (PARAM(1)="B" & !find([F:PLF]YEAPLF+"~"+[F:PLF]LEGPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF+"~"+num$(PLFSTRDAT)+"~"+num$(PLFENDDAT)+"~"+[F:PLF]VERPLF+"~"+num$([F:PLF]FLGCLO), KEYTEX))) Then
              NBTEX += 1
              KEYTEX(NBTEX)  = [F:PLF]YEAPLF+"~"+[F:PLF]LEGPLF+"~"+[F:PLF]CPYPLF+"~"+[F:PLF]FCYPLF
              # FQ106549- Ajout de la période
              KEYTEX(NBTEX) += "~"+num$(PLFSTRDAT)+"~"+num$(PLFENDDAT)
              # FQ71320 - Selon le type de la sélection, on affiche la version ou non
              If PARAM(1)="B" Then
                KEYTEX(NBTEX) += "~"+[F:PLF]VERPLF+"~"+num$([F:PLF]FLGCLO)
              Endif
              TEX(NBTEX)     = [F:PLF]VERPLF
              TEXTE(NBTEX,1) = [F:PLF]VERPLF
              TEXTE(NBTEX,2) =  mess([F:PLF]FLGCLO,1,1)
              TEXTE(NBTEX,3) = [F:PLF]CPYPLF
              TEXTE(NBTEX,4) = [F:PLF]FCYPLF
          Endif
        Endif
  Next
  Filter [F:PLF]

Return

#**
#* Fin d sélection d'une année
#*!
$FIN_LISTE

  Case GACTION
    When "SELYEA"    : Gosub FINYEA
    #ADNGO - 2017-07-03 - X3-29553 - START
#    When "SELCPYPLF" : Gosub FINCPYPLF
#    When "SELFCYPLF" : Gosub FINFCYPLF
#    When "SELVERPLF" : Gosub FINVERPLF
    When "SELCPYPLF" : Gosub FINYEA #US3924 106549
    When "SELFCYPLF" : Gosub FINYEA #US3924 106549
    When "SELVERPLF" : Gosub FINYEA #US3924 106549
    #ADNGO - 2017-07-03 - X3-29553 - END
  Endcase
Return

#**
#* Récupération des données société, site et version
#*!
$FINYEA
Local Char VALSEL(80)

  If dim(CHOIX)>0 & dim(KEYTEX)>0 Then : # FQ71306 - MABON 14/02/11 - La clé complète ne se trouve plus dans VALEUR
#    VALSEL=VALEUR
    VALSEL=KEYTEX(CHOIX)
    If instr(1,VALSEL,"~")>0 Then
      [M]SELFLG=2
      #ADNGO - 2017-07-03 - X3-29553 - START
      #US3924 106549 on ne change pas de valeur du champ donc on ne passera pas dans AM_
      Case GACTION
        When "SELYEA"    : If VALEUR = [M]YEAPLF : [M]SELFLG=1 : Endif
        When "SELCPYPLF" : If VALEUR = [M]CPYPLF : [M]SELFLG=1 : Endif
        When "SELFCYPLF" : If VALEUR = [M]FCYPLF : [M]SELFLG=1 : Endif
        When "SELVERPLF" : If VALEUR = [M]VERPLF : [M]SELFLG=1 : Endif
      Endcase
      #ADNGO - 2017-07-03 - X3-29553 - END
      [M]YEAPLF = mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)
      VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
      # FQ81085 - MABON 24/05/12 - New field LEG
      [M]LEGPLF = mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)
      VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
      # End MABON
      [M]CPYPLF = mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)
      VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
      # FQ71320 - MABON 01/04/11 - Selon le type de la sélection, on affiche la version ou non
#      [M]FCYPLF = VALSEL
      #ADNGO - 2017-07-03 - X3-29553 - START
      # FQ106549 - Ajout de la période
      [M]FCYPLF = mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)
      VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
#      If mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)<>"" Then
#        #Infbox num$(gdat$(val(mid$(VALSEL, 1, 2)),val(mid$(VALSEL, 4, 2)),val(mid$(VALSEL, 7, 4))))
#        [M]STRDAT = gdat$(val(mid$(VALSEL, 1, 2)),val(mid$(VALSEL, 4, 2)),val(mid$(VALSEL, 7, 4)))
#      Endif
#      VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
      If mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)<>"" Then
        [M]STRDAT = gdat$(val(mid$(VALSEL, 1, 2)),val(mid$(VALSEL, 4, 2)),val(mid$(VALSEL, 7, 4)))
      Endif
      VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
      #ADNGO - 2017-07-03 - X3-29553 - END
      If PARAM(1)="B" Then
        #ADNGO - 2017-07-03 - X3-29553 - START
        #[M]FCYPLF = mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)
        If mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)<>"" Then
          [M]ENDDAT = gdat$(val(mid$(VALSEL, 1, 2)),val(mid$(VALSEL, 4, 2)),val(mid$(VALSEL, 7, 4)))
        Endif
        #ADNGO - 2017-07-03 - X3-29553 - END
        VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
        [M]VERPLF = mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)
        VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
        [M]FLGCLO = val(VALSEL)
      Else
        #ADNGO - 2017-07-03 - X3-29553 - START
        #[M]FCYPLF = VALSEL
        [M]ENDDAT = gdat$(val(mid$(VALSEL, 1, 2)),val(mid$(VALSEL, 4, 2)),val(mid$(VALSEL, 7, 4)))
        #ADNGO - 2017-07-03 - X3-29553 - END
      Endif

      ##      [M]YEAPLF = mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)
##      VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
##      [M]CPYPLF = mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)
##      VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
##      # FQ106549 - Ajout de la période
##      [M]FCYPLF = mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)
##      VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
##      If mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)<>"" Then
##        [M]STRDAT = gdat$(val(mid$(VALSEL, 1, 2)),val(mid$(VALSEL, 4, 2)),val(mid$(VALSEL, 7, 4)))
##      Endif
##      VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
##      # FQ71320 - Selon le type de la sélection, on affiche la version ou non
##      If PARAM(1)="B" Then
##        If mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)<>"" Then
##          [M]ENDDAT = gdat$(val(mid$(VALSEL, 1, 2)),val(mid$(VALSEL, 4, 2)),val(mid$(VALSEL, 7, 4)))
##        Endif
##        VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
##        Infbox VALSEL
##        [M]VERPLF = mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)
##        Infbox [M]VERPLF
##        VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
##        [M]FLGCLO = val(VALSEL)
##      Else
##        [M]ENDDAT = gdat$(val(mid$(VALSEL, 1, 2)),val(mid$(VALSEL, 4, 2)),val(mid$(VALSEL, 7, 4)))
##      Endif
      #US3924 106549

      #ADNGO - 2017-07-03 - X3-29553 - START
      #VALEUR = [M]YEAPLF
      #US3924 106549
      Case GACTION
        When "SELYEA"    :  VALEUR = [M]YEAPLF
        When "SELCPYPLF" :  VALEUR = [M]CPYPLF
        When "SELFCYPLF" :  VALEUR = [M]FCYPLF
        When "SELVERPLF" :  VALEUR = [M]VERPLF
      Endcase
      #ADNGO - 2017-07-03 - X3-29553 - END
      # FQ81085 - MABON 24/05/12 - New field LEG
#      Affzo [M]LEGPLF, ZLEGPLF
      # End MABON

      If [M]CPYPLF<>"" Then
        [M]ALLCPY=1 : Actzo [M]CPYPLF
      Else
        [M]ALLCPY=2 : Grizo [M]CPYPLF
      Endif

      If [M]FCYPLF<>"" Then
        [M]ALLFCY=1 : Actzo [M]FCYPLF
      Else
        [M]ALLFCY=2 : Grizo [M]FCYPLF
      Endif
      #ADNGO - 2017-07-03 - X3-29553 - START
      # FQ106549 - Ajout de la période et des mois/année de réalisation
      Gosub AFF_REA
      #ADNGO - 2017-07-03 - X3-29553 - END
      # FQ71758 - MABON 28/02/11 - Si on est dans la fenêtre de critères
      If dim(GCRIT)>0 & GCRIT=2 Then
        #ADNGO - 2017-07-03 - X3-29553 - START
        #Affzo [M:CSBF]YEAPLF, LEGPLF, ZLEGPLF, CPYPLF, ZCPYPLF, FCYPLF, ZFCYPLF, ALLCPY, ALLFCY, VERPLF
        Affzo [M:CSBF]YEAPLF, LEGPLF, ZLEGPLF, CPYPLF, ZCPYPLF, FCYPLF, ZFCYPLF, ALLCPY, ALLFCY, VERPLF, STRDAT, ENDDAT
        #ADNGO - 2017-07-03 - X3-29553 - END
        If GCHOIX = "SBB" Then Affzo [M:CSBF]VERPLF : Endif
        If dim([M:CSBF]FLGCLO)>0 Then Affzo [M:CSBF]FLGCLO Endif
      Endif
      If (dim(GCRIT)>0 & GCRIT=1) | dim(GCRIT)<0 Then
        Affzo [M:SBF1]YEAPLF, LEGPLF, ZLEGPLF, CPYPLF, ZCPYPLF, FCYPLF, ZFCYPLF, ALLCPY, ALLFCY, VERPLF
        If GCHOIX = "SBB" Then Affzo [M:SBF1]VERPLF : Endif
        If dim([M:SBF1]FLGCLO)>0 Then Affzo [M:SBF1]FLGCLO Endif
      Endif
      # Fin MABON
    Endif
  Endif
Return
#ADNGO - 2017-07-03 - X3-29553 - START
$AFF_REA

  If [M]STRDAT<>[0/0/0] Then
    If dim([M]MONREA)>0 Then
      [M]MONREA=month([M]STRDAT)
      Affzo [M]MONREA
    Endif

    If dim([M]YEAREA)>0 Then
      If [M]ENDDAT<>[0/0/0] Then
        [M]YEAREA=num$(year([M]STRDAT))
        Affzo [M]YEAREA
      Endif
    Endif
  Endif
Return
#ADNGO - 2017-07-03 - X3-29553 - END
#**
#* Récupération de la législation
#*!
$FINCPYPLF

  If dim(CHOIX)>0 Then
    [M]LEGPLF=TEXTE(CHOIX,2)
    Affzo [M]LEGPLF
  Endif
Return

#**
#* Récupération de la législation
#*!
$FINFCYPLF

  If dim(CHOIX)>0 Then
    [M]LEGPLF=TEXTE(CHOIX,2)
    Affzo [M]LEGPLF
  Endif
Return

#**
#* Récupération des données société et site
#*!
$FINVERPLF
Local Char VALSEL(80)

##  If dim(CHOIX)>0 & dim(KEYTEX)>0 Then
##    VALSEL=KEYTEX(CHOIX)
##    If instr(1,VALSEL,"~")>0 Then
##      [M]SELFLG=2
##
##      VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
##      VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
##      [M]CPYPLF = mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)
##      VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
##      [M]FCYPLF = mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)
##      VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
##      [M]VERPLF = mid$(VALSEL, 1, instr(1,VALSEL,"~")-1)
##      VALSEL = mid$(VALSEL, instr(1,VALSEL,"~")+1, len(VALSEL))
##      [M]FLGCLO = val(VALSEL)
##
##      VALEUR = [M]VERPLF
##
##      If [M]CPYPLF<>"" Then
##        [M]ALLCPY=1 : Actzo [M]CPYPLF
##      Else
##        [M]ALLCPY=2 : Grizo [M]CPYPLF
##      Endif
##
##      If [M]FCYPLF<>"" Then
##        [M]ALLFCY=1 : Actzo [M]FCYPLF
##      Else
##        [M]ALLFCY=2 : Grizo [M]FCYPLF
##      Endif
##
##      If dim(GCRIT)>0 & GCRIT=2 Then
##        Affzo [M:CSBF]YEAPLF, LEGPLF, ZLEGPLF, CPYPLF, ZCPYPLF, FCYPLF, ZFCYPLF, ALLCPY, ALLFCY, VERPLF
##        If GCHOIX = "SBB" Then Affzo [M:CSBF]VERPLF : Endif
##        If dim([M:CSBF]FLGCLO)>0 Then Affzo [M:CSBF]FLGCLO Endif
##      Endif
##      If (dim(GCRIT)>0 & GCRIT=1) | dim(GCRIT)<0 Then
##        Affzo [M:SBF1]YEAPLF, LEGPLF, ZLEGPLF, CPYPLF, ZCPYPLF, FCYPLF, ZFCYPLF, ALLCPY, ALLFCY, VERPLF
##        If GCHOIX = "SBB" Then Affzo [M:SBF1]VERPLF : Endif
##        If dim([M:SBF1]FLGCLO)>0 Then Affzo [M:SBF1]FLGCLO Endif
##      Endif
##    Endif
##  Endif
Return

$APRES_CHOI

  Case REPONSE
    When GSTAEDI :
      Local Char VALBOUT(250) , PARBOUT(250)(1..20)
      Local Char    SAVACT(GLONACT)
      Local Integer FLGEXE
      PARBOUT(1) = "SUISBF"
      PARBOUT(2) = GFONCTION
      PARBOUT(3) = num$(0)
      FLGEXE = 1
      SAVACT = GACTION
      GACTION = "AIMP1"
      Call TRAITE_CHAR(VALBOUT,PARBOUT,"","AIMP1","AIMP1",4,"XYAIMP1") From GTRAITE
      GACTION = SAVACT
      REPONSE=0
  Endcase
Return

$DEB_CRIT
If dim(GCRIT)<0 Then Global Integer GCRIT : Endif

  GCRIT=2
Return

$FIN_CRIT
If dim(GCRIT)<0 Then Global Integer GCRIT : Endif

  GCRIT=1
  #ADNGO - 2017-07-03 - X3-29553 - START
  Gosub CALC_MONTHS
  #If [M:SBF1]MONREA=12 Then
  # FQ106549 - Le dernier mois de la période n'est plus forcément le mois de décembre
  If NUMMON>0 & NUMMON=NBMONTH Then
  #ADNGO - 2017-07-03 - X3-29553 - END
    # FQ75458 - MABON 30/08/11 - Affichage des participants ou non, uniquement sur mois de décembre
    If [M:CSBF]DSYPRT=1 Then
      Chgfmt [M:SBF3]NBRPAR     With '-N3Z:9.2'
      Chgfmt [M:SBF3]NBRPARREA  With '-N3Z:9.2'
      Chgfmt [M:SBF3]NBRDEV     With '-N3Z:13.2'
      Chgfmt [M:SBF3]NBRPRC     With '-N3Z:13.2'
    Else
      Chgfmt [M:SBF3]NBRPAR     With 'NP3Zz:9.2'
      Chgfmt [M:SBF3]NBRPARREA  With 'NP3Zz:9.2'
      Chgfmt [M:SBF3]NBRDEV     With 'NP3Zz-:13.2'
      Chgfmt [M:SBF3]NBRPRC     With 'NP3Zz-:13.2'
    Endif
    # FQ75458 - MABON 30/08/11 - Affichage des heures ou non, uniquement sur mois de décembre
    If [M:CSBF]DSYHOU=1 Then
      Chgfmt [M:SBF3]NBRHR      With '-N3Z:9.2'
      Chgfmt [M:SBF3]NBRHRREA   With '-N3Z:9.2'
      Chgfmt [M:SBF3]HRDEV      With '-N3Z:13.2'
      Chgfmt [M:SBF3]HRPRC      With '-N3Z:13.2'
    Else
      Chgfmt [M:SBF3]NBRHR      With 'NP3Zz:9.2'
      Chgfmt [M:SBF3]NBRHRREA   With 'NP3Zz:9.2'
      Chgfmt [M:SBF3]HRDEV      With 'NP3Zz-:13.2'
      Chgfmt [M:SBF3]HRPRC      With 'NP3Zz-:13.2'
    Endif
  Endif
Return

#**
#* Avant de changer de plan prévisionnel, on change le mois quand c'est possible
#*!
$AV_MAGNETO
#ADNGO - 2017-07-03 - X3-29553 - START
#Local Char    SAU_YEAPLF(4), SAU_LEGPLF(5), SAU_CPYPLF(GLONCPY), SAU_FCYPLF(GLONFCY), SAU_VERPLF(5)
Local Char    SAU_YEAPLF(GLONHRPLF), SAU_LEGPLF(5), SAU_CPYPLF(GLONCPY), SAU_FCYPLF(GLONFCY), SAU_VERPLF(5)
#ADNGO - 2017-07-03 - X3-29553 - END
#ADNGO - 2017-07-03 - X3-29553 - START
Local Date    SAU_STRDAT,SAU_ENDDAT :#US3924 106549
#ADNGO - 2017-07-03 - X3-29553 - END
  # SYMEU : ajout du flag Calcul pour ne prendre que ceux pris en compte dans le calcul
#  FILTRE = "FLGCLO=2 & CLCFLG=2"
  FILTRE = "CLCFLG=2"
  #ADNGO - 2017-07-03 - X3-29553 - START
#  If GCHOIX="SBB" & dim([M:SBF1]FLGCLO)>0 Then
##    If [M:SBF1]FLGCLO>0 Then
##      FILTRE -= "& FLGCLO="+num$([M:SBF1]FLGCLO)
##    Endif
#  Else
#    FILTRE -= "& FLGCLO=2"
#  Endif
  If GCHOIX<>"SBB" Then
   FILTRE -= "& FLGCLO=2"
  Endif
  #ADNGO - 2017-07-03 - X3-29553 - END
  Case REPONSE
    When GSTASUI : Gosub SUI_PLF  : # On demande le suivant
    When GSTALAS : Gosub LAS_PLF  : # On demande le dernier
    When GSTAPRE : Gosub PRE_PLF  : # On demande le précédent
    When GSTAFIR : Gosub FIR_PLF  : # On demande le premier
  Endcase
Return

#**
#* Recherche du suivant
#*!
$SUI_PLF
  #ADNGO - 2017-07-03 - X3-29553 - START
  Gosub CALC_MONTHS
  #If [M:SBF1]MONREA<12 Then
  If NUMMON<>NBMONTH Then
  #ADNGO - 2017-07-03 - X3-29553 - END
    # Tant qu'on n'est pas au moins de décembre, on reste dans le même plan prévisionnel, et on passe au mois suivant
    SAU_YEAPLF = [M:SBF1]YEAPLF
    SAU_LEGPLF = [M:SBF1]LEGPLF
    SAU_CPYPLF = [M:SBF1]CPYPLF
    SAU_FCYPLF = [M:SBF1]FCYPLF
    If GCHOIX="SBB" Then
      SAU_VERPLF = [M:SBF1]VERPLF
    Endif
    #ADNGO - 2017-07-03 - X3-29553 - START
    SAU_STRDAT = [M:SBF1]STRDAT :#US3924 106549
    SAU_ENDDAT = [M:SBF1]ENDDAT :#US3924 106549
    #ADNGO - 2017-07-03 - X3-29553 - END
    [M:SBF1]MONREA += 1
    #ADNGO - 2017-07-03 - X3-29553 - START
    If find([M:SBF1]MONREA,13,25)>0 Then [M:SBF1]YEAREA = num$(val([M:SBF1]YEAREA)+1) : Endif
    #ADNGO - 2017-07-03 - X3-29553 - END
    [M:SBF1]NUMLIG = 0
  Else
    # Si on est en décembre, on passe au plan prévisionnel suivant, pour le mois de janvier... s'il y en a 1
#    SAU_YEAPLF     = ""
#    [M:SBF1]MONREA = 1
#    [M:SBF1]NUMLIG = 99999999
    If clalev([F:PLF2])=0 : Local File PLNFORM [PLF2] : Endif
    Filter [F:PLF2] Where YEAPLF=[F:PLF]YEAPLF & LEGPLF=[F:PLF]LEGPLF & CPYPLF=[F:PLF]CPYPLF & FCYPLF=[F:PLF]FCYPLF & VERPLF=[F:PLF]VERPLF
    Read [F:PLF2] Last
    If !fstat Then
      Filter [F:PLF2]
      Read [F:PLF2] Next
      If fstat<>4 Then
        SAU_YEAPLF     = ""
        [M:SBF1]MONREA = 1
        [M:SBF1]NUMLIG = 99999999
      Else
#        SAU_YEAPLF = [M:SBF1]YEAPLF
#        SAU_LEGPLF = [M:SBF1]LEGPLF
#        SAU_CPYPLF = [M:SBF1]CPYPLF
#        SAU_FCYPLF = [M:SBF1]FCYPLF
#        If GCHOIX="SBB" Then
#          SAU_VERPLF = [M:SBF1]VERPLF
#        Endif
        [M:SBF1]MONREA = 12
        [M:SBF1]NUMLIG = 99999999
      Endif
    Endif
  Endif
Return

#**
#* Recherche du dernier
#*!
$LAS_PLF

  # On affiche le dernier plan prévisionnel, sur le mois de décembre
  [M:SBF1]MONREA = 12
  [M:SBF1]NUMLIG = 99999999
Return

#**
#* Recherche du précédent
#*!
$PRE_PLF
  #ADNGO - 2017-07-03 - X3-29553 - START
  Gosub CALC_MONTHS
  #If [M:SBF1]MONREA>1 Then
  If NUMMON>1 Then
  #ADNGO - 2017-07-03 - X3-29553 - END
    # Tant qu'on n'est pas au moins de janvier, on reste dans le même plan prévisionnel, et on passe au mois précédent
    SAU_YEAPLF = [M:SBF1]YEAPLF
    SAU_LEGPLF = [M:SBF1]LEGPLF
    SAU_CPYPLF = [M:SBF1]CPYPLF
    SAU_FCYPLF = [M:SBF1]FCYPLF
    If GCHOIX="SBB" Then
      SAU_VERPLF = [M:SBF1]VERPLF
    Endif
    #ADNGO - 2017-07-03 - X3-29553 - START
    SAU_STRDAT = [M:SBF1]STRDAT :#US3924 106549
    SAU_ENDDAT = [M:SBF1]ENDDAT :#US3924 106549
    #ADNGO - 2017-07-03 - X3-29553 - END
    [M:SBF1]MONREA -= 1
    [M:SBF1]NUMLIG = 99999999
  Else
    # Si on est en janvier, on passe au plan prévisionnel précédent, pour le mois de décembre... s'il y en a 1
#    SAU_YEAPLF     = ""
#    [M:SBF1]MONREA = 12
#    [M:SBF1]NUMLIG = 0
    If clalev([F:PLF2])=0 : Local File PLNFORM [PLF2] : Endif
    Filter [F:PLF2] Where YEAPLF=[F:PLF]YEAPLF & LEGPLF=[F:PLF]LEGPLF & CPYPLF=[F:PLF]CPYPLF & FCYPLF=[F:PLF]FCYPLF & VERPLF=[F:PLF]VERPLF
    Read [F:PLF2] First
    If !fstat Then
      Filter [F:PLF2]
      Read [F:PLF2] Prev
      If fstat<>4 Then
        SAU_YEAPLF     = ""
        [M:SBF1]MONREA = 12
        [M:SBF1]NUMLIG = 0
      Else
#        SAU_YEAPLF = [M:SBF1]YEAPLF
#        SAU_LEGPLF = [M:SBF1]LEGPLF
#        SAU_CPYPLF = [M:SBF1]CPYPLF
#        SAU_FCYPLF = [M:SBF1]FCYPLF
#        If GCHOIX="SBB" Then
#          SAU_VERPLF = [M:SBF1]VERPLF
#        Endif
        [M:SBF1]MONREA = 1
        [M:SBF1]NUMLIG = 0
      Endif
    Endif
  Endif
Return

#**
#* Recherche du premier
#*!
$FIR_PLF

  # On affiche le premier plan prévisionnel, sur le mois de janvier
  [M:SBF1]MONREA = 1
  [M:SBF1]NUMLIG = 0
Return

#**
#* Avant de changer de plan prévisionnel, on change le mois quand c'est possible
#* Donc, les autres données ne doivent pas bouger
#*!
$AP_MAGNETO

  # Si on doit juste bouger de mois, on repositionne les données Année, Société, Site et Version pour rester sur le
  # même plan prévisionnel
  If SAU_YEAPLF<>"" Then
    [M:SBF1]YEAPLF = SAU_YEAPLF
    [M:SBF1]LEGPLF = SAU_LEGPLF
    [M:SBF1]CPYPLF = SAU_CPYPLF
    [M:SBF1]FCYPLF = SAU_FCYPLF
    If GCHOIX="SBB" Then
      [M:SBF1]VERPLF = SAU_VERPLF
    Endif
    #ADNGO - 2017-07-03 - X3-29553 - START
    [M:SBF1]STRDAT = SAU_STRDAT :#US3924 106549
    [M:SBF1]ENDDAT = SAU_ENDDAT :#US3924 106549
    #ADNGO - 2017-07-03 - X3-29553 - END
  Endif
  If [M:SBF1]CPYPLF<>"" Then
    [M:SBF1]ALLCPY=1 : Actzo [M:SBF1]CPYPLF
  Else
    [M:SBF1]ALLCPY=2 : Grizo [M:SBF1]CPYPLF
  Endif

  If [M:SBF1]FCYPLF<>"" Then
    [M:SBF1]ALLFCY=1 : Actzo [M:SBF1]FCYPLF
  Else
    [M:SBF1]ALLFCY=2 : Grizo [M:SBF1]FCYPLF
  Endif
  #ADNGO - 2017-07-03 - X3-29553 - START
#  If GCHOIX="SBB" & dim([M:SBF1]FLGCLO)>0 & [F:PLF]FLGCLO>0 Then
#    [M:SBF1]FLGCLO=[F:PLF]FLGCLO
#  Endif
  # FQ106549 - Ajout de la période et des mois/année de réalisation
  If SAU_YEAPLF="" & [F:PLF]YEAPLF<>"" Then
    Read [BUR]BUR0(4)=[F:PLF]YEAPLF;[F:PLF]CPYPLF;[F:PLF]FCYPLF;[F:PLF]LEGPLF
    If fstat
      Read [PLF]PLF0(5)=[F:PLF]YEAPLF;[F:PLF]LEGPLF;[F:PLF]CPYPLF;[F:PLF]FCYPLF;[F:PLF]VERPLF :#US3924 106549
      If !fstat
        [M:SBF1]STRDAT=[F:PLF]STRDAT
        [M:SBF1]ENDDAT=[F:PLF]ENDDAT
      Endif
    Else
      [M:SBF1]STRDAT=[F:BUR]STRDAT
      [M:SBF1]ENDDAT=[F:BUR]ENDDAT
    Endif
    Gosub AFF_REA
   Endif
Return

#**
#* FQ71693 - MABON 28/02/11
#* Initialisation du libellé de la 1ère colonne
#*!
Subprog D_CRIDSY(VALEUR)
Variable Integer VALEUR

  GINTITCRI=mess(1,10475,1)
  Affzo [M:SBF2] : Affzo [M:SBF3]
End

#**
#* Calcul du libellé de la 1ère colonne
#*!
Subprog AM_CRIDSY(VALEUR)
Variable Integer VALEUR

  GINTITCRI=mess(VALEUR,10475,1)
  Affzo [M:SBF2] : Affzo [M:SBF3]
End

$EVAL_YEA_ERROR

  GMESSAGE=mess(83,123,1) : # Valeur incorrecte
  mkstat=2
Resume

#**
#* L'année saisie peut ne pas être l'année d'un plan définitif : si c'est le cas, faire confirmer la saisie
#*!
Subprog AM_YEAPLF(VALEUR)
Variable Char    VALEUR()
Local    Integer OK,ISNUM

  Onerrgo EVAL_YEA_ERROR
  If val(VALEUR)=0 Then
    GMESSAGE=mess(83,123,1) : # Valeur incorrecte
    mkstat=2 : End
  Endif
  Onerrgo

  # SYMEU : ajout du flag Calcul pour ne prendre que ceux pris en compte dans le calcul
  Filter [F:PLF] Where YEAPLF=VALEUR and FLGCLO=2 and CLCFLG=2
  If rowcount([F:PLF])=0 & GCHOIX="SBF" Then
    # FQ85365 US903 - MABON 06/11/12 - Si pas de plan définitif sur l'année, on ne laisse plus la possibilité de poursuivre, on bloque,
#    Call OUINON(mess(168,10717,1)-VALEUR+chr$(10)+mess(169,10717,1), OK) From GESECRAN : # Il n'y a pas de plan définitif pour l'année yyyy. Confirmez-vous ?
#    If OK=1 Then mkstat=2 Endif
    GMESSAGE=mess(168,10717,1)-VALEUR : # Il n'y a pas de plan définitif pour l'année yyyy.
    mkstat=2 : End
    # Fin MABON
  Endif

  # FQ71758 - MABON 03/03/11 - Réinit de la société/site
  If [M]CPYPLF<>"" | [M]FCYPLF<>"" Then
    If [M]CPYPLF<>"" Then
      Filter [F:PLF] Where YEAPLF=VALEUR and FLGCLO=2 and CLCFLG=2 & CPYPLF=[M]CPYPLF
    Endif
    If [M]FCYPLF<>"" Then
      Filter [F:PLF] Where YEAPLF=VALEUR and FLGCLO=2 and CLCFLG=2 & FCYPLF=[M]FCYPLF
    Endif
    If rowcount([F:PLF])=0 Then
      [M]SELFLG=1
    Endif
  Endif
  Filter [F:PLF]
  #ADNGO - 2017-07-03 - X3-29553 - START
  #US3924 106549
  Gosub VERIF_YEACPYFCY
  If ENR_OK<>2
    GMESSAGE=mess(168,10717,1) : # Il n'y a pas de plan définitif .#US3924 106549
    mkstat=2 : End
  Endif
  #END US3924 106549
  #ADNGO - 2017-07-03 - X3-29553 - END
  If [M]SELFLG=1 Then
    [M]ALLCPY=2 : [M]CPYPLF=""
    [M]ALLFCY=2 : [M]FCYPLF=""
    # FQ71758 - MABON 28/02/11 - Si on est dans la fenêtre de critères
    If dim(GCRIT)>0 & GCRIT=2 Then
      Affzo [M:CSBF]
    Endif
    If (dim(GCRIT)>0 & GCRIT=1) | dim(GCRIT)<0 Then
      Affzo [M:SBF1]
    Endif
  Endif
  [M]SELFLG=1
End

#ADNGO - 2017-07-03 - X3-29553 - START
#US3924 106549
$VERIF_YEACPYFCY
Local    Char CRITPLF(250)
Local    Integer ENR_OK
ENR_OK=2
If [M]SELFLG=1
   ENR_OK=0
   Case zoncou
    When "YEAPLF"    : CRITPLF="YEAPLF='"+VALEUR+"'"
    When "CPYPLF"    : CRITPLF="CPYPLF='"+VALEUR+"' & YEAPLF='"+[M]YEAPLF+"'"
    When "FCYPLF"    : CRITPLF="FCYPLF='"+VALEUR+"' & YEAPLF='"+[M]YEAPLF+"'"
    When "VERPLF"    : CRITPLF="VERPLF='"+VALEUR+"' & YEAPLF='"+[M]YEAPLF+"' & CPYPLF='"+[M]CPYPLF+"' & FCYPLF='"+[M]FCYPLF+"'"
   Endcase

   If GCHOIX="SBF"
     CRITPLF-=" & FLGCLO=2 & CLCFLG=2"
   Else
   Endif
   Filter [F:PLF] Where evalue(CRITPLF)
   Read [F:PLF]First
   If !fstat
      Case zoncou
        When "YEAPLF"    : ENR_OK = func SUBHRSES.GET_AUZ([F:PLF]CPYPLF, [F:PLF]FCYPLF, "CONSSBF")
        When "CPYPLF"    : ENR_OK = func SUBHRSES.GET_AUZ([F:PLF]CPYPLF, "", "CONSSBF")
        When "FCYPLF"    : ENR_OK = func SUBHRSES.GET_AUZ("", [F:PLF]FCYPLF, "CONSSBF")
        When "VERPLF"    : ENR_OK = 2
      Endcase
      If ENR_OK=2 Then
        Read [BUR]BUR0(4)=[F:PLF]YEAPLF;[F:PLF]CPYPLF;[F:PLF]FCYPLF;[F:PLF]LEGPLF
        If fstat
          [M]STRDAT=[F:PLF]STRDAT
          [M]ENDDAT=[F:PLF]ENDDAT
        Else
          [M]STRDAT=[F:BUR]STRDAT
          [M]ENDDAT=[F:BUR]ENDDAT
        Endif
        If GCHOIX<>"SBF"
          [M]VERPLF=[F:PLF]VERPLF
          [M]FLGCLO=[F:PLF]FLGCLO
        Endif
        [M]CPYPLF = [F:PLF]CPYPLF
        [M]FCYPLF = [F:PLF]FCYPLF
        [M]LEGPLF = [F:PLF]LEGPLF
      Endif
   Endif
   Filter [F:PLF]
   If ENR_OK<>2 : Return : Endif
   If [M]CPYPLF<>"" Then
      [M]ALLCPY=1 : Actzo [M]CPYPLF
   Else
      [M]ALLCPY=2 : Grizo [M]CPYPLF
   Endif

   If [M]FCYPLF<>"" Then
      [M]ALLFCY=1 : Actzo [M]FCYPLF
   Else
      [M]ALLFCY=2 : Grizo [M]FCYPLF
   Endif

   Gosub AFF_REA
Endif
Return
#ADNGO - 2017-07-03 - X3-29553 - END

#**
#* Si on décoche "Toutes sociétés", il faut dégriser la zone "Société"
#* Si on coche la case, il faut griser la zone
#*!
Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Local    Char    CRITERE(250)

  If VALEUR=2
    Effzo [M]CPYPLF,ZCPYPLF : Grizo [M]CPYPLF
    If GCHOIX="SBB" Then
      CRITERE = "YEAPLF='"+[M]YEAPLF+"' & CLCFLG=2 & CPYPLF='' & LEGPLF='"+[M]LEGPLF+"'"
      If [M]ALLFCY=1 Then
        CRITERE -= "& FCYPLF='"+[M]FCYPLF+"'"
      Endif
      Filter [F:PLF] Where evalue(CRITERE)
      If rowcount([F:PLF])>0 Then
        Read [F:PLF] First
        [M]FLGCLO=[F:PLF]FLGCLO
        Affzo [M]FLGCLO
      Endif
      Filter [F:PLF]
    Endif
  Else
    Actzo [M]CPYPLF
  Endif
End

#**
#* On ne peut sélectionner une société que si sur l'année du plan, on a au moins un plan sur une société
#*!
Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
Local    Char    LIS_CPY(GLONCPY)
Local    Integer I

  If [M]FCYPLF<>"" Then
    mkstat=2
  Else
    # SYMEU : ajout du flag Calcul pour ne prendre que ceux pris en compte dans le calcul
    # FQ83584 - MABON 17/07/12 - On ne veut les définitifs que si suivi budget formation
#    Filter [F:PLF] Where YEAPLF=[M]YEAPLF and CPYPLF<>"" and FLGCLO=2 and CLCFLG=2
    If GCHOIX="SBF" Then
      Filter [F:PLF] Where YEAPLF=[M]YEAPLF and CPYPLF<>"" and LEGPLF=[M]LEGPLF and FLGCLO=2 and CLCFLG=2
    Else
      Filter [F:PLF] Where YEAPLF=[M]YEAPLF and CPYPLF<>"" and LEGPLF=[M]LEGPLF and CLCFLG=2
    Endif
    # Fin MABON
    If rowcount([F:PLF])=0 Then mkstat=2 Endif
    Filter [F:PLF]
  Endif
End

#**
#*  "Société" est grisé quand "Toutes sociétés" est cochée (sert pour l'initialisation)
#*!
Subprog AV_CPYPLF(VALEUR)
Variable Char    VALEUR()

  If [M]ALLCPY=2 Then
    Grizo [M]CPYPLF
  Else
    Actzo [M]CPYPLF
  Endif
End

#**
#* Si "Toutes sociétés" est décoché, il faut obligatoirement saisir une société
#*!
Subprog C_CPYPLF(VALEUR)
Variable Char    VALEUR()
Local    Integer AUZCFY
Local    Char    CRITERE(250)

  If [M]ALLCPY=1 & VALEUR="" Then
    mkstat=2
  Endif
  AUZCFY = func SUBHRSES.GET_AUZ(VALEUR,"", "CONSSBF")
  If AUZCFY=1 Then
    mkstat=2
  Endif
  # FQ85365 US903 - MABON 06/11/12 - Contrôle que le couple année/société a bien un plan (définitif ou pas)
  If VALEUR<>"" Then
    Local Char CPYLEG(GLONCPY)
    CPYLEG=func TOOLSHRLEG.FGET_LEGCPY(VALEUR)
    If CPYLEG<>[M]LEGPLF Then
      GMESSAGE=mess(269,10717,1)-[M]LEGPLF : # La législation de la société doit être
      mkstat=2
    Else
      CRITERE = "YEAPLF='"+[M]YEAPLF+"' & CLCFLG=2 & CPYPLF='"+VALEUR+"' & LEGPLF='"+[M]LEGPLF+"'"
      If GCHOIX="SBF" Then
        CRITERE -= "& FLGCLO=2"
      Endif
      Filter [F:PLF] Where evalue(CRITERE)
      If rowcount([F:PLF])=0 Then
        If GCHOIX="SBF" Then
          GMESSAGE=mess(2,45,1)-VALEUR-":"-mess(168,10717,1)-num$([M]YEAPLF) : # Société xxx : Il n'y a pas de plan pour l'année yyyy
        Else
          GMESSAGE=mess(2,45,1)-VALEUR-":"-mess(293,10717,1)-num$([M]YEAPLF) : # Société xxx : Il n'y a pas de plan définitif pour l'année yyyy
        Endif
        mkstat=2
      Else
        If GCHOIX="SBB" Then
          Read [F:PLF] First
          [M]FLGCLO=[F:PLF]FLGCLO
          Affzo [M]FLGCLO
        Endif
      Endif
      Filter [F:PLF]
    Endif
  Endif
  # Fin MABON
End
#ADNGO - 2017-07-03 - X3-29553 - START
#US3924 106549
Subprog AM_CPYPLF(VALEUR)
Variable Char    VALEUR()
Local    Integer OK
  Gosub VERIF_YEACPYFCY
  If ENR_OK<>2
    GMESSAGE=mess(168,10717,1) : # Il n'y a pas de plan définitif
    mkstat=2 : End
  Endif
  If [M]SELFLG=1 Then
    # FQ71758 - Si on est dans la fenêtre de critères
    If dim(GCRIT)>0 & GCRIT=2 Then
      Affzo [M:CSBF]
    Endif
    If (dim(GCRIT)>0 & GCRIT=1) | dim(GCRIT)<0 Then
      Affzo [M:SBF1]
    Endif
  Endif
  [M]SELFLG=1
End
#ADNGO - 2017-07-03 - X3-29553 - END
#**
#* On ne peut sélectionner un site que si sur l'année du plan, on a au moins un plan sur un site
#*!
Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
Local    Char    LIS_FCY(5)(0..1)
Local    Integer I

  If [M]CPYPLF<>"" Then
    mkstat=2
  Else
    # SYMEU : ajout du flag Calcul pour ne prendre que ceux pris en compte dans le calcul
    # FQ83584 - MABON 17/07/12 - On ne veut les définitifs que si suivi budget formation
#    Filter [F:PLF] Where YEAPLF=[M]YEAPLF and FCYPLF<>"" and FLGCLO=2 and CLCFLG=2
    If GCHOIX="SBF" Then
      Filter [F:PLF] Where YEAPLF=[M]YEAPLF and FCYPLF<>"" and LEGPLF=[M]LEGPLF and FLGCLO=2 and CLCFLG=2
    Else
      Filter [F:PLF] Where YEAPLF=[M]YEAPLF and FCYPLF<>"" and LEGPLF=[M]LEGPLF and CLCFLG=2
    Endif
    # Fin MABON
    If rowcount([F:PLF])=0 Then mkstat=2 Endif
    Filter [F:PLF]
  Endif
End

#**
#* Si on décoche la case "Tous sites", il faut dégriser la zone "Site"
#* Si on coche la case, il faut griser la zone
#*!
Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Local    Char    CRITERE(250)

  If VALEUR=2
    Effzo [M]FCYPLF,ZFCYPLF : Grizo [M]FCYPLF
    If GCHOIX="SBB" Then
      CRITERE = "YEAPLF='"+[M]YEAPLF+"' & CLCFLG=2 & FCYPLF='' & LEGPLF='"+[M]LEGPLF+"'"
      If [M]ALLCPY=1 Then
        CRITERE -= "& CPYPLF='"+[M]CPYPLF+"'"
      Endif
      Filter [F:PLF] Where evalue(CRITERE)
      If rowcount([F:PLF])>0 Then
        Read [F:PLF] First
        [M]FLGCLO=[F:PLF]FLGCLO
        Affzo [M]FLGCLO
      Endif
      Filter [F:PLF]
    Endif
  Else
    Actzo [M]FCYPLF
  Endif
End

#**
#*  "Site" est grisé quand "Tous sites" est cochée (sert pour l'initialisation)
#*!
Subprog AV_FCYPLF(VALEUR)
Variable Char    VALEUR()

  If [M]ALLFCY=2 Then
    Grizo [M]FCYPLF
  Else
    Actzo [M]FCYPLF
  Endif
End

#**
#* Si "Tous sites" est décoché, il faut obligatoirement saisir un site
#*!
Subprog C_FCYPLF(VALEUR)
Variable Char    VALEUR()
Local    Integer AUZCFY

  If [M]ALLFCY=1 & VALEUR="" Then
    mkstat=2
  Endif
  AUZCFY = func SUBHRSES.GET_AUZ("", VALEUR, "CONSSBF")
  If AUZCFY=1 Then
    mkstat=2
  Endif
  # FQ85365 US903 - MABON 06/11/12 - Contrôle que le couple année/société a bien un plan (définitif ou pas)
  If VALEUR<>"" Then
    CRITERE = "YEAPLF='"+[M]YEAPLF+"' & CLCFLG=2 & FCYPLF='"+VALEUR+"' & LEGPLF='"+[M]LEGPLF+"'"
    If GCHOIX="SBF" Then
      CRITERE -= "& FLGCLO=2"
    Endif
    Filter [F:PLF] Where evalue(CRITERE)
    If rowcount([F:PLF])=0 Then
      If GCHOIX="SBF" Then
        GMESSAGE=mess(3,45,1)-VALEUR-":"-mess(168,10717,1)-num$([M]YEAPLF) : # Site xxx : Il n'y a pas de plan pour l'année yyyy
      Else
        GMESSAGE=mess(3,45,1)-VALEUR-":"-mess(293,10717,1)-num$([M]YEAPLF) : # Site xxx : Il n'y a pas de plan définitif pour l'année yyyy
      Endif
      mkstat=2
    Else
      If GCHOIX="SBB" Then
        Read [F:PLF] First
        [M]FLGCLO=[F:PLF]FLGCLO
        Affzo [M]FLGCLO
      Endif
    Endif
    Filter [F:PLF]
  Endif
  # Fin MABON
End
#ADNGO - 2017-07-03 - X3-29553 - START
