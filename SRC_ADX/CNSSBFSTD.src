# FQ106549 - La période peut commencer en cours d'année, donc il faut faire glisser les mois possibles
#ADNGO - 2017-07-03 - X3-29553 - START
Subprog AS_MONREA(VALEUR)
Variable Integer VALEUR
Local    Integer MONDEB, MONFIN, I

  If [M]STRDAT<>[0/0/0] Then MONDEB=month([M]STRDAT) : Endif
  If [M]ENDDAT<>[0/0/0] Then
    MONFIN=month([M]ENDDAT)
    If year([M]STRDAT)<year([M]ENDDAT) Then
      MONFIN+=(year([M]ENDDAT)-year([M]STRDAT))*12
    Endif
  Endif

  For I=1 To MONDEB-1
    GMENLOC(I)=1
  Next
  For I=MONDEB To MONFIN
    GMENLOC(I)=0
  Next
  For I=MONFIN+1 To len(mess(0,9001,1))
    GMENLOC(I)=1
  Next
End
#ADNGO - 2017-07-03 - X3-29553 - END
# FQ106549 - La période peut commencer en cours d'année, donc il faut faire glisser les mois possibles
#ADNGO - 2017-07-03 - X3-29553 - START
Subprog AM_MONREA(VALEUR)
Variable Integer VALEUR

  If VALEUR<=12 Then
    [M]YEAREA=num$(year([M]STRDAT))
  Else
    If VALEUR<>24 Then
      [M]YEAREA=num$(year([M]STRDAT)+(int(VALEUR/12)))
    Else
      [M]YEAREA=num$(year([M]STRDAT)+(int(VALEUR/12))-1)
    Endif
  Endif
  Affzo [M]YEAREA
End
#ADNGO - 2017-07-03 - X3-29553 - END
Subprog AS_CRIDSY(VALEUR)
Variable Integer VALEUR
  If [M]LEGPLF<>"FRA" Then
    GMENLOC(7)=1
  Else
    GMENLOC(7)=0
  Endif
End

#ADNGO - 2017-07-03 - X3-29553 - START
# Issue X3-11720 - 2017-01-27 by BRBAN : New filter for Department
Subprog CHARGE_AMT_SRV(AMK, TYPAMT)
Value Char    AMK, TYPAMT
Local Integer NBLIGA, I, IS2, IS3
Local Char    SRV(type([F:PLF]SRV)-10)

  Call CALC_INDICE(AMK, IS2, IS3)

  If TYPAMT="PREV" Then
      SRV = [F:PLF]SRV
      If SRV="" Then SRV = "ZVIDE" : Endif
      NBLIGA = func FIND_DATA(SRV, "SERVICE", 0)
      For [F:PLC]
        [M]AMTBUDREF(NBLIGA-1) += [F:PLC]CSTTOTIDV*[F:PLF]NBREMP
      Next
      # FQ75457 - Ajout du nombre de participants
     [M]NBRPAR(NBLIGA-1)    += [F:PLF]NBREMP
      # FQ75457 - Ajout du nombre d'heures
      If clalev([F:STG])=0 : Local File STAGE [STG] : Endif
      Read [F:STG]STG0=[F:PLF]STG
      [M]NBRHR(NBLIGA-1)     += [F:STG]NBRHOUIPT*[F:PLF]NBREMP
  Endif
  If TYPAMT="READ" Then
    # FQ80895 - On écarte les inscriptions refusées
    For [F:INS] Where STA<>3
      Gosub CALC_AMT_SRV
    Next
  Endif
  If TYPAMT="REAI" Then
    Gosub CALC_AMT_SRV
  Endif
End
#ADNGO - 2017-07-03 - X3-29553 - END

#ADNGO - 2017-07-03 - X3-29553 - START
$CALC_AMT_SRV
Local Integer NBLIGA
Local Char    SRV(type([F:HRCTR]ETRSRV)-10)

  Read [F:HRSES]SES0=[F:INS]SES
  Filter [F:HRCTR] Where [F:HRCTR]REFNUM=[F:INS]REFNUM & [F:HRCTR]CTRNUM=[F:INS]CTRNUM & ([F:HRCTR]CTRDAT>= [F:HRSES]STRDAT| [F:HRCTR]CTRDAT<= [F:HRSES]ENDDAT)
&    Order By CTRDAT Desc
  Read [HRCTR] First
  Filter [F:HRCTR]
 If !fstat
    SRV = [F:HRCTR]ETRSRV
    If SRV="" Then SRV = "ZVIDE" : Endif
    NBLIGA = func FIND_DATA(SRV, "SERVICE", 0)
    Filter [F:HRCOR] Where TYPCOU=3 & SES=[F:INS]SES & REFNUM=[F:INS]REFNUM
    For [F:HRCOR]
      [M]AMTREA(NBLIGA-1) += [F:HRCOR]CSTTOTIDV2
    Next
    Filter [F:HRCOR]
    [M]NBINS(NBLIGA-1)  += 1
    [M]NBRPARREA(NBLIGA-1) += 1
    If clalev([F:INJ2])=0 : Local File INSJOU [INJ2] : Endif
    For [F:INJ2] Where SES=[F:INS]SES & REFNUM=[F:INS]REFNUM
      [M]NBRHRREA(NBLIGA-1)  += [F:INJ2]NBRHOUREA+[F:INJ2]NBRHOUREA2
    Next
    Call CALC_AMT_FOR_AMK(AMK, [F:INS]SES, IS2, IS3)
  Endif
Return
#ADNGO - 2017-07-03 - X3-29553 - END

# Réinitialisation des données sur changement de leg
Subprog AM_LEGPLF(VALEUR)
Variable Char    VALEUR()

  #Raz [M:SBF1]VERPLF,CPYPLF,ZCPYPLF,FCYPLF,ZFCYPLF
  Raz CPYPLF,ZCPYPLF,FCYPLF,ZFCYPLF
  [M:SBF1]ALLCPY=2
  [M:SBF1]ALLFCY=2
  Affzo [M:SBF1]VERPLF,CPYPLF,ZCPYPLF,FCYPLF,ZFCYPLF,ALLCPY,ALLFCY
End


