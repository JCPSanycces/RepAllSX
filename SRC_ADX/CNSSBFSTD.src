#*!
$CALC_AMT_FIS
#ADNGO - 2017-07-03 - X3-29553 - START
#Local Integer NBLIGA, NATFIS
Local Integer NBLIGA
Local Char    NATFIS(type([F:INS]DESNATFIS)-10)         : #US3924 106549
