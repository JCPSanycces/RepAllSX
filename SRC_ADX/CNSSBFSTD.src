#**
#* On ne peut aller en tunnel sur le stage prévu que s'il est connu
#* On ne peut aller en tunnel sur la demande prévue que si elle est connue
#*!
Subprog IB_NBLIG

  GBOUT1=""
  If [M]STGPREV(nolign-1)<>"" Then
    GBOUT1 = mess(33,10717,1) : # Stage
  Endif
  GBOUT2=""
  If [M]DEMPREV(nolign-1)<>"" Then
    GBOUT2 = mess(13,10717,1) : # Demande
  Endif
End

#**
#* On ne peut aller en tunnel sur le stage réalisé que s'il est connu
#* On ne peut aller en tunnel sur la demande réalisée que si elle est connue
#* On ne peut aller en tunnel sur l'inscription que si la session et le matricule sont connus, et que l'inscription existe
#*!
Subprog IB_NBREA
Local Char CRITERE(255)

  GBOUT1=""
  If [M]STGREA(nolign-1)<>"" Then
    GBOUT1 = mess(33,10717,1) : # Stage
  Endif
  GBOUT2=""
  If [M]DEMREA(nolign-1)<>"" Then
    GBOUT2 = mess(13,10717,1) : # Demande
  Endif
  GBOUT3=""
  If [M]SES(nolign-1)<>"" & [M]EMPREA(nolign-1)<>"" Then
    CRITERE = "SES='"+[M]SES(nolign-1)+"' & REFNUM='"+[M]EMPREA(nolign-1)+"'"
    If [M:SBF2]DEMREA(nolign-1)<>"" Then
      CRITERE -= "& DEM='"+[M:SBF2]DEMREA(nolign-1)+"'"
    Endif
    Filter [F:INS] Where evalue(CRITERE)
    If rowcount([F:INS])>0 Then
      GBOUT3 = mess(71,10717,1) : # Inscription
    Endif
    Filter [F:INS]
  Endif
End

# FQ75923 - MABON 30/08/11 - On ne peut pas saisir une version inexistante
Subprog C_VERPLF(VALEUR)
Variable Char    VALEUR()

  CRITERE = "YEAPLF='"+[M]YEAPLF+"'"
#  If [M:SBF1]CPYPLF<>"" Then
#    CRITERE -= "& CPYPLF='"+[M:SBF1]CPYPLF+"'"
#  Endif
#  If [M:SBF1]FCYPLF<>"" Then
#    CRITERE -= "& FCYPLF='"+[M:SBF1]FCYPLF+"'"
#  Endif
  If [M]CPYPLF<>"" Then
    CRITERE -= "& CPYPLF='"+[M]CPYPLF+"'"
  Endif
  If [M]FCYPLF<>"" Then
    CRITERE -= "& FCYPLF='"+[M]FCYPLF+"'"
  Endif
  CRITERE -= "& VERPLF='"+VALEUR+"' & LEGPLF='"+[M]LEGPLF+"'"

  Filter [F:PLF] Where evalue(CRITERE)
  If rowcount([F:PLF])=0 Then
    mkstat=2
  Endif
  Filter [F:PLF]
End
#ADNGO - 2017-07-03 - X3-29553 - START
