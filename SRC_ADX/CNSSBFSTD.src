#<AdxTL>@(#)0.0.0.0 $Revision$ Inquiry SBF
# Gestion du masque CONSSBF1
# Suivi du budget de formation

$ACTION

  Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "FERME"      : Gosub FERME
    When "LECTURE"    : Gosub LECTURE
    When "SETBOUT"    : Gosub SETBOUT

    When "SEL_LISTE"  : Gosub SEL_LISTE
    When "FIN_LISTE"  : Gosub FIN_LISTE

    When "APRES_CHOI" : Gosub APRES_CHOI

    When "DEB_CRIT"   : Gosub DEB_CRIT
    When "FIN_CRIT"   : Gosub FIN_CRIT

    When "AV_MAGNETO" : Gosub AV_MAGNETO
    When "AP_MAGNETO" : Gosub AP_MAGNETO

    When Default
  Endcase
Return

#**
#* Ouverture des tables et déclaration des variables
#*!
$OUVRE

  If clalev([F:PLF])=0    : Local File PLNFORM  [PLF]   : Endif
  If clalev([F:PLC])=0    : Local File PLNCOUT  [PLC]   : Endif
  If clalev([F:DEM])=0    : Local File DEMANDE  [DEM]   : Endif
  If clalev([F:DML])=0    : Local File DEMLIG   [DML]   : Endif
  If clalev([F:INS])=0    : Local File INSCRIPT [INS]   : Endif
  If clalev([F:INJ])=0    : Local File INSJOU   [INJ]   : Endif
  If clalev([F:HRSES])=0  : Local File SESSIONS [HRSES] : Endif
  If clalev([F:HRCOR])=0  : Local File COUTREEL [HRCOR] : Endif
  If clalev([F:ID])=0     : Local File EMPLOID  [ID]    : Endif
  If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR] : Endif
  If clalev([F:ADI])=0    : Local File ATABDIV  [ADI]   : Endif
  If clalev([F:CPY])=0    : Local File COMPANY  [CPY]   : Endif
  If clalev([F:FCY])=0    : Local File FACILITY [FCY]   : Endif
  If clalev([F:AFP])=0    : Local File AFCTPRF  [AFP]   : Endif
  If clalev([F:FGR])=0    : Local File FACGROUP [FGR]   : Endif
  If clalev([F:AGC])=0    : Local File AGRPCPY  [AGC]   : Endif
  #ADNGO - 2017-07-03 - X3-29553 - START
  If clalev([F:BUR])=0 : Local File BUDREF   [BUR] : Endif : # FQ106549 - 20/10/15 - Pour récupération de la période
  If clalev([F:INJW])=0 : Local File INSJOU   [INJW] : Endif :#US4003 112241 filtre SOCSITE
  If clalev([F:STG])=0 : Local File STAGE    [STG] : Endif :#US4003 112693
  #ADNGO - 2017-07-03 - X3-29553 - END
  Global Char    GINTITCRI : GINTITCRI=mess(1,10475,1) : # Dispositif
  # FQ85380 - MABON 22/10/12 - Le nombre de lignes peut dépasser 200, donc on ne précise plus
#  Global Char    GTABSES2(GLONHRSES)(0..200), GTABSES3(GLONHRSES)(0..200)
  Global Char    GTABSES2(GLONHRSES)(0..), GTABSES3(GLONHRSES)(0..)
  # Fin MABON
  # FQ73931 - MABON 19/05/11 - Ligne en trop en bas d'écran
  Global Decimal GAMTFOR2, GAMTFOR3
  #ADNGO - 2017-07-03 - X3-29553 - START
  #112795
  Global Integer GINSTOTFOR3
  #ADNGO - 2017-07-03 - X3-29553 - END
  # FQ71320 - MABON 01/04/11 - Type de la consultation
  Global Char    GCHOIX : GCHOIX="SBF"
  #ADNGO - 2017-07-03 - X3-29553 - START
  # Issue X3-11279 - 2017-01-30 by BRBAN : Open SERVICE table for description
  If clalev([F:SRV])=0  : Local File SERVICE  [SRV] :Endif
  #ADNGO - 2017-07-03 - X3-29553 - END

  #ADNGO - 2017-07-03 - X3-29553 - START
  #US3924 106549 New parameter CTLBUR
  Local Char    CTLBUR(1)
  Call PARAM("","CTLBUR",CTLBUR) From ADOVAL
  #ADNGO - 2017-07-03 - X3-29553 - END
Return

#**
#* Suppression des variables
#*!
$FERME

  If dim(GINTITCRI)>0 Then Kill GINTITCRI Endif
  If dim(GTABSES2)>0  Then Kill GTABSES2  Endif
  If dim(GTABSES3)>0  Then Kill GTABSES3  Endif
  If dim(GDETSBF)>0   Then Kill GDETSBF   Endif
  # FQ71320 - MABON 01/04/11 - Type de la consultation
  If dim(GCHOIX)>0    Then Kill GCHOIX    Endif
  # FQ73931 - MABON 19/05/11 - Ligne en trop en bas d'écran
  If dim(GAMTFOR2)>0  Then Kill GAMTFOR2  Endif
  If dim(GAMTFOR3)>0  Then Kill GAMTFOR3  Endif
  #ADNGO - 2017-07-03 - X3-29553 - START
  # 112795
  If dim(GINSTOTFOR3)>0 Then Kill GINSTOTFOR3  Endif
  #ADNGO - 2017-07-03 - X3-29553 - END
Return
#ADNGO - 2017-07-03 - X3-29553 - START
# FQ106549 - Calcul de la période glissante
$CALC_MONTHS
Local Integer NBMONTH,NUMMON

  If [M:SBF1]STRDAT<>[0/0/0] Then
    # Nombre de mois total de la période du plan
    NBMONTH=month([M:SBF1]ENDDAT)-month([M:SBF1]STRDAT)+1+(12*(year([M:SBF1]ENDDAT)-year([M:SBF1]STRDAT)))
    # Nombre de mois entre le début de la période du plan, et le mois de réalisation
    NUMMON=[M:SBF1]MONREA-month([M:SBF1]STRDAT)+1
  Endif
Return
#ADNGO - 2017-07-03 - X3-29553 - END
#**
#* Lecture et calcul des enregistrements
#*!
$LECTURE
# FQ75963 - MABON 15/09/11 - Les nombres totaux d'inscrits peuvent être des fractions sur chaque ligne
#Local Integer NBLIG4, NBINSTOT2, NBINSTOT3
Local Integer NBLIG4
Local Decimal NBINSTOT2, NBINSTOT3
# Fin MABON
Local Char    SIGNE(10)
#ADNGO - 2017-07-03 - X3-29553 - START
Local Date    MONREL

  # FQ106549 - Calcul de la période glissante
  Gosub CALC_MONTHS
  #ADNGO - 2017-07-03 - X3-29553 - END
  If [M:SBF1]YEAPLF<>"" & [M]LEGPLF="" Then
    Infbox(mess(295,10717,1)) : # La législation doit être renseignée
    Return
  Endif

  If [M:SBF1]YEAPLF<>"" & [M]LEGPLF<>"" Then
    Local Char CRIERE(250)
    CRITERE="YEAPLF='"+[M:SBF1]YEAPLF+"' & LEGPLF='"+[M:SBF1]LEGPLF+"' & CLCFLG=2"
    If GCHOIX="SBB" & dim([M:SBF1]FLGCLO)>0 Then
      If [M:SBF1]FLGCLO>0 Then
        CRITERE -= "& FLGCLO="+num$([M:SBF1]FLGCLO)
      Endif
    Else
      CRITERE -= "& FLGCLO=2"
    Endif
    Filter [F:PLF] Where evalue(CRITERE)
    If rowcount([F:PLF])=0 Then
      If GCHOIX="SBF"
        Infbox(mess(168,10717,1)-num$([M]YEAPLF)) : # Il n'y a pas de plan définitif pour l'année yyyy
      Else
        Infbox(mess(293,10717,1)-num$([M]YEAPLF)) : # Il n'y a pas de plan pour l'année yyyy
      Endif
      Filter [F:PLF]
      Return
    Endif
    Filter [F:PLF]
  Endif

  # FQ75457 - MABON 30/08/11 - Affichage des participants et des heures, uniquement si :
  #     - mois de décembre
  #     - critère <> Type financement
  #ADNGO - 2017-07-03 - X3-29553 - START
  #If [M:SBF1]MONREA<>12 | [M:SBF1]CRIDSY=2 Then
  If NUMMON<>NBMONTH | [M:SBF1]CRIDSY=2 Then
  #ADNGO - 2017-07-03 - X3-29553 - END
    Chgfmt [M:SBF3]NBRPAR     With '-N3Z:9.2'
    Chgfmt [M:SBF3]NBRPARREA  With '-N3Z:9.2'
    Chgfmt [M:SBF3]NBRDEV     With '-N3Z:13.2'
    Chgfmt [M:SBF3]NBRPRC     With '-N3Z:13.2'
    Chgfmt [M:SBF3]NBRHR      With '-N3Z:9.2'
    Chgfmt [M:SBF3]NBRHRREA   With '-N3Z:9.2'
    Chgfmt [M:SBF3]HRDEV      With '-N3Z:13.2'
    Chgfmt [M:SBF3]HRPRC      With '-N3Z:13.2'
  Else
    # FQ75458 - MABON 30/08/11 - Affichage des participants ou non
    If [M:CSBF]DSYPRT<>1 Then
      Chgfmt [M:SBF3]NBRPAR     With 'NP3Zz:9.2'
      Chgfmt [M:SBF3]NBRPARREA  With 'NP3Zz:9.2'
      Chgfmt [M:SBF3]NBRDEV     With 'NP3Zz-:13.2'
      Chgfmt [M:SBF3]NBRPRC     With 'NP3Zz-:13.2'
    Endif
    # FQ75458 - MABON 30/08/11 - Affichage des heures ou non
    If [M:CSBF]DSYHOU<>1 Then
      Chgfmt [M:SBF3]NBRHR      With 'NP3Zz:9.2'
      Chgfmt [M:SBF3]NBRHRREA   With 'NP3Zz:9.2'
      Chgfmt [M:SBF3]HRDEV      With 'NP3Zz-:13.2'
      Chgfmt [M:SBF3]HRPRC      With 'NP3Zz-:13.2'
    Endif
  Endif

  # FQ73931 - MABON 19/05/11 - Ligne en trop en bas d'écran
  GAMTFOR2=0 : GAMTFOR3=0
  #ADNGO - 2017-07-03 - X3-29553 - START
  GINSTOTFOR3=0 # 112795
  #ADNGO - 2017-07-03 - X3-29553 - END
  Gosub CHARGE_PREV
  # FQ71320 - MABON 01/04/11 - On ne charge pas le réalisé dans le cas du suivi de la répartition des coûts
  If GCHOIX="SBF" Then
    Gosub CHARGE_REA
  Endif

  If [M:SBF1]YEAPLF<>"" Then
    # Calcul des écarts sur le mois en cours
    NBLIG4=1 : NBINSTOT2=0 : NBINSTOT3=0
    For I=0 To dim([M:SBF2]CRIDSYA)-1
      NBINSTOT2 += [M:SBF2]NBINS(I)
    Next
    For I=0 To dim([M:SBF3]CRIDSYA)-1
      NBINSTOT3 += [M:SBF3]NBINS(I)
    Next
    For I=0 To dim([M:SBF2]CRIDSYA)-1
      # On répartit les coûts formateurs sur les différentes lignes, au prorata du nombre d'inscriptions
      If [M:SBF2]NBINS(I)<>0 & NBINSTOT2>0 Then
        # FQ73931 - MABON 19/05/11 - Ligne en trop en bas d'écran
#        [M:SBF2]AMTREA(I) += arr([M:SBF2]AMTFOR*[M:SBF2]NBINS(I)/NBINSTOT2, 0.01)
#        [M:SBF2]AMTREA(I) += arr(GAMTFOR2*[M:SBF2]NBINS(I)/NBINSTOT2, 0.01)
#        [M:SBF2]AMTREA(NBLIG4-1) = [M:SBF2]AMTREA(I)+arr(GAMTFOR2*[M:SBF2]NBINS(I)/NBINSTOT2, 0.01)
         [M:SBF2]AMTREA(I) += arr(GAMTFOR2*[M:SBF2]NBINS(I)/NBINSTOT2, 0.01)
      Endif

#      If [M:SBF2]NUMCRID(I)<>"" & ([M:SBF2]AMTBUDREF(I)>0 | [M:SBF2]AMTREA(I)>0) Then
      If [M:SBF2]NUMCRID(I)<>"" & ([M:SBF2]AMTBUDREF(I)>0 | [M:SBF2]AMTREA(I)>0 | [M:SBF2]NBRPAR(I)>0 | [M:SBF2]NBRPARREA(I)>0) Then
#        [M:SBF2]AMTDEV(I) = [M:SBF2]AMTREA(I)-[M:SBF2]AMTBUDREF(I)
#        # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants
#        [M:SBF2]NBRDEV(I) = [M:SBF2]NBRPARREA(I)-[M:SBF2]NBRPAR(I)
#        # FQ75457 - MABON 26/08/11 - Ajout du nombre d'heures
#        [M:SBF2]HRDEV(I)  = [M:SBF2]NBRHRREA(I)-[M:SBF2]NBRHR(I)
#        If [M:SBF2]AMTBUDREF(I)>0 Then
#          # FQ72277 - MABON 11/03/11 - C'est finalement le réalisé en pourcentage qui est calculé
##          [M:SBF2]PRCDEV(I) = arr([M:SBF2]AMTDEV(I)*100/[M:SBF2]AMTBUDREF(I), 0.01)
#          [M:SBF2]PRCDEV(I) = arr([M:SBF2]AMTREA(I)*100/[M:SBF2]AMTBUDREF(I), 0.01)
#        Else
#          # FQ72277 - MABON 11/03/11 - Si le budget est nul, le réalisé en pourcentage l'est aussi
##          [M:SBF2]PRCDEV(I) = 100
#          [M:SBF2]PRCDEV(I) = 0
#        Endif
#        # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants
#        If [M:SBF2]NBRPAR(I)>0 Then
#          [M:SBF2]NBRPRC(I) = arr([M:SBF2]NBRPARREA(I)*100/[M:SBF2]NBRPAR(I), 0.01)
#        Else
#          [M:SBF2]NBRPRC(I) = 0
#        Endif
#        # Fin MABON
#        # FQ75457 - MABON 26/08/11 - Ajout du nombre d'heures
#        If [M:SBF2]NBRHR(I)>0 Then
#          [M:SBF2]HRPRC(I) = arr([M:SBF2]NBRHRREA(I)*100/[M:SBF2]NBRHR(I), 0.01)
#        Else
#          [M:SBF2]HRPRC(I) = 0
#        Endif
#        # Fin MABON
#        [M:SBF2]NODSP(I)=""
        #[M:SBF2]NUMCRID(NBLIG4-1) = [M:SBF2]NUMCRID(I)
        #[M:SBF2]CRIDSYA(NBLIG4-1) = [M:SBF2]CRIDSYA(I)
        #[M:SBF2]AMTDEV(NBLIG4-1)  = [M:SBF2]AMTREA(I)-[M:SBF2]AMTBUDREF(I)
        #[M:SBF2]NBRDEV(NBLIG4-1)  = [M:SBF2]NBRPARREA(I)-[M:SBF2]NBRPAR(I)
        #[M:SBF2]HRDEV(NBLIG4-1)   = [M:SBF2]NBRHRREA(I)-[M:SBF2]NBRHR(I)
        [M:SBF2]AMTDEV(I) = [M:SBF2]AMTREA(I)-[M:SBF2]AMTBUDREF(I)
        # FQ75457 - Ajout du nombre de participants
        [M:SBF2]NBRDEV(I) = [M:SBF2]NBRPARREA(I)-[M:SBF2]NBRPAR(I)
        # FQ75457 - Ajout du nombre d'heures
        [M:SBF2]HRDEV(I)  = [M:SBF2]NBRHRREA(I)-[M:SBF2]NBRHR(I)
        If [M:SBF2]AMTBUDREF(I)>0 Then
          #ADNGO - 2017-07-03 - X3-29553 - START
          #[M:SBF2]PRCDEV(NBLIG4-1) = arr([M:SBF2]AMTREA(I)*100/[M:SBF2]AMTBUDREF(I), 0.01)
          # FQ72277 - C'est finalement le réalisé en pourcentage qui est calculé
          [M:SBF2]PRCDEV(I) = arr([M:SBF2]AMTREA(I)*100/[M:SBF2]AMTBUDREF(I), 0.01)
          #ADNGO - 2017-07-03 - X3-29553 - END
        Else
          #ADNGO - 2017-07-03 - X3-29553 - START
          #[M:SBF2]PRCDEV(NBLIG4-1) = 0
          [M:SBF2]PRCDEV(I) = 0
          #ADNGO - 2017-07-03 - X3-29553 - END
        Endif
        #ADNGO - 2017-07-03 - X3-29553 - START
#        If [M:SBF2]NBRPAR(I)>0 Then
#          [M:SBF2]NBRPRC(NBLIG4-1) = arr([M:SBF2]NBRPARREA(I)*100/[M:SBF2]NBRPAR(I), 0.01)
#        Else
#          [M:SBF2]NBRPRC(NBLIG4-1) = 0
#        Endif

        # FQ75457 - Ajout du nombre de participants
        If [M:SBF2]NBRPAR(I)>0 Then
          [M:SBF2]NBRPRC(I) = arr([M:SBF2]NBRPARREA(I)*100/[M:SBF2]NBRPAR(I), 0.01)
        Else
          [M:SBF2]NBRPRC(I) = 0
        Endif
        #ADNGO - 2017-07-03 - X3-29553 - END
        #ADNGO - 2017-07-03 - X3-29553 - START
#        If [M:SBF2]NBRHR(I)>0 Then
#          [M:SBF2]HRPRC(NBLIG4-1) = arr([M:SBF2]NBRHRREA(I)*100/[M:SBF2]NBRHR(I), 0.01)
#        Else
#          [M:SBF2]HRPRC(NBLIG4-1) = 0
#        Endif

        # FQ75457 - Ajout du nombre d'heures
        If [M:SBF2]NBRHR(I)>0 Then
          [M:SBF2]HRPRC(I) = arr([M:SBF2]NBRHRREA(I)*100/[M:SBF2]NBRHR(I), 0.01)
        Else
          [M:SBF2]HRPRC(I) = 0
        Endif
        #ADNGO - 2017-07-03 - X3-29553 - END
        #ADNGO - 2017-07-03 - X3-29553 - START
        #[M:SBF2]NODSP(NBLIG4-1)=""
        [M:SBF2]NODSP(I)=""
        #ADNGO - 2017-07-03 - X3-29553 - END
        NBLIG4 += 1
#ADNGO - 2017-07-03 - X3-29553 - START
#      Else
#        Break
      Else
        Break
#ADNGO - 2017-07-03 - X3-29553 - END
      Endif
    Next
    # Ligne de total
    If NBLIG4>1 Then
      [M:SBF2]AMTDEV(NBLIG4-1)=0 : [M:SBF2]AMTBUDREF(NBLIG4-1)=0
      [M:SBF2]NBRPAR(NBLIG4-1)=0 : [M:SBF2]NBRPARREA(NBLIG4-1)=0 : [M:SBF2]NBRDEV(NBLIG4-1)=0
      [M:SBF2]NBRHR(NBLIG4-1)=0  : [M:SBF2]NBRHRREA(NBLIG4-1)=0  : [M:SBF2]HRDEV(NBLIG4-1)=0
      [M:SBF2]CRIDSYA(NBLIG4-1) = mess(151,115,1) : # Total
      For I=0 To NBLIG4-2
        [M:SBF2]AMTBUDREF(NBLIG4-1) += [M:SBF2]AMTBUDREF(I)
        [M:SBF2]AMTREA(NBLIG4-1)    += [M:SBF2]AMTREA(I)
        [M:SBF2]AMTDEV(NBLIG4-1)    += [M:SBF2]AMTDEV(I)
        # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants
        [M:SBF2]NBRPAR(NBLIG4-1)    += [M:SBF2]NBRPAR(I)
        [M:SBF2]NBRPARREA(NBLIG4-1) += [M:SBF2]NBRPARREA(I)
        [M:SBF2]NBRDEV(NBLIG4-1)    += [M:SBF2]NBRDEV(I)
        # FQ75457 - MABON 26/08/11 - Ajout du nombre d'heures
        [M:SBF2]NBRHR(NBLIG4-1)     += [M:SBF2]NBRHR(I)
        [M:SBF2]NBRHRREA(NBLIG4-1)  += [M:SBF2]NBRHRREA(I)
        [M:SBF2]HRDEV(NBLIG4-1)     += [M:SBF2]HRDEV(I)
      Next
      If [M:SBF2]AMTBUDREF(NBLIG4-1)>0 Then
        # FQ72277 - MABON 11/03/11 - C'est finalement le réalisé en pourcentage qui est calculé
#        [M:SBF2]PRCDEV(NBLIG4-1) = arr([M:SBF2]AMTDEV(NBLIG4-1)*100/[M:SBF2]AMTBUDREF(NBLIG4-1), 0.01)
        [M:SBF2]PRCDEV(NBLIG4-1) = arr([M:SBF2]AMTREA(NBLIG4-1)*100/[M:SBF2]AMTBUDREF(NBLIG4-1), 0.01)
      Else
        # FQ72277 - MABON 11/03/11 - Si le budget est nul, le réalisé en pourcentage l'est aussi
#        [M:SBF2]PRCDEV(NBLIG4-1) = 100
        [M:SBF2]PRCDEV(NBLIG4-1) = 0
      Endif
      # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants
      [M:SBF2]NBRPARREA(NBLIG4-1) = arr([M:SBF2]NBRPARREA(NBLIG4-1), 0.01)
      If [M:SBF2]NBRPAR(NBLIG4-1)>0 Then
        [M:SBF2]NBRPRC(NBLIG4-1) = arr([M:SBF2]NBRPARREA(NBLIG4-1)*100/[M:SBF2]NBRPAR(NBLIG4-1), 0.01)
      Else
        [M:SBF2]NBRPRC(NBLIG4-1) = 0
      Endif
      # Fin MABON
      # FQ75457 - MABON 26/08/11 - Ajout du nombre d'heures
      If [M:SBF2]NBRHR(NBLIG4-1)>0 Then
        [M:SBF2]HRPRC(NBLIG4-1) = arr([M:SBF2]NBRHRREA(NBLIG4-1)*100/[M:SBF2]NBRHR(NBLIG4-1), 0.01)
      Else
        [M:SBF2]HRPRC(NBLIG4-1) = 0
      Endif
      # Fin MABON
      [M:SBF2]NODSP(NBLIG4-1)="X"
      NBLIG4 += 1
    Endif
    [M:SBF2]NBAMT = NBLIG4-1
    If [M:SBF2]NBAMT>0 Then
      # FQ86506 - MABON 14/01/13 - Si type ADI, NUMCRID n'est pas numérique, mais alphanumérique
#      Sorta [M:SBF2]NBAMT-1 [M:SBF2]NBAMT Order By val([M:SBF2]NUMCRID(indice))
      Case [M:SBF1]CRIDSY
        When 3,4,7 #When 1,3,4,7 : #ADNGO - 2017-07-03 - X3-29553
          Sorta [M:SBF2]NBAMT-1 [M:SBF2]NBAMT Order By val([M:SBF2]NUMCRID(indice))
        When 1,2,5,6,16 #When 2,5,6 : # FQ121853 - Item 1 moved here ; Add item 16 : #ADNGO - 2017-07-03 - X3-29553
          Sorta [M:SBF2]NBAMT-1 [M:SBF2]NBAMT Order By [M:SBF2]NUMCRID(indice)
      Endcase
      # Fin MABON
    Endif

    # Calcul des écarts sur le cumul fin de mois
    NBLIG4=1
    For I=0 To dim([M:SBF3]CRIDSYA)-1
      # On répartit les coûts formateurs sur les différentes lignes, au prorata du nombre d'inscriptions
      #ADNGO - 2017-07-03 - X3-29553 - START
      #If [M:SBF3]NBINS(I)<>0 & NBINSTOT3>0 Then
      If [M:SBF3]NBINS(I)<>0 & GINSTOTFOR3>0 Then
      #ADNGO - 2017-07-03 - X3-29553 - END
        # FQ73931 - MABON 19/05/11 - Ligne en trop en bas d'écran
#        [M:SBF3]AMTREA(I) += arr([M:SBF3]AMTFOR*[M:SBF3]NBINS(I)/NBINSTOT3, 0.01)
#        [M:SBF3]AMTREA(I) += arr(GAMTFOR3*[M:SBF3]NBINS(I)/NBINSTOT3, 0.01)
        #ADNGO - 2017-07-03 - X3-29553 - START
        #[M:SBF3]AMTREA(NBLIG4-1) = [M:SBF3]AMTREA(I)+arr(GAMTFOR3*[M:SBF3]NBINS(I)/NBINSTOT3, 0.01)
        [M:SBF3]AMTREA(I) += arr(GAMTFOR3*[M:SBF3]NBINS(I)/GINSTOTFOR3, 0.01)
        #ADNGO - 2017-07-03 - X3-29553 - END
      Endif

#      If [M:SBF3]NUMCRID(I)<>"" & ([M:SBF3]AMTBUDREF(I)>0 | [M:SBF3]AMTREA(I)>0) Then
      #ADNGO - 2017-07-03 - X3-29553 - START
      #If [M:SBF3]NUMCRID(I)<>"" & ([M:SBF3]AMTBUDREF(I)>0 | [M:SBF3]AMTREA(NBLIG4-1)>0 | [M:SBF3]NBRPAR(I)>0 | [M:SBF3]NBRPARREA(I)>0) Then
      If [M:SBF3]NUMCRID(I)<>"" & ([M:SBF3]AMTBUDREF(I)>0 | [M:SBF3]AMTREA(I)>0 | [M:SBF3]NBRPAR(I)>0 | [M:SBF3]NBRPARREA(I)>0) Then
      #ADNGO - 2017-07-03 - X3-29553 - END
#        [M:SBF3]AMTDEV(I) = [M:SBF3]AMTREA(I)-[M:SBF3]AMTBUDREF(I)
#        # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants
#        [M:SBF3]NBRDEV(I) = [M:SBF3]NBRPARREA(I)-[M:SBF3]NBRPAR(I)
#        # FQ75457 - MABON 26/08/11 - Ajout du nombre d'heures
#        [M:SBF3]HRDEV(I)  = [M:SBF3]NBRHRREA(I)-[M:SBF3]NBRHR(I)
#        If [M:SBF3]AMTBUDREF(I)>0 Then
#          # FQ72277 - MABON 11/03/11 - C'est finalement le réalisé en pourcentage qui est calculé
##          [M:SBF3]PRCDEV(I) = arr([M:SBF3]AMTDEV(I)*100/[M:SBF3]AMTBUDREF(I), 0.01)
#           [M:SBF3]PRCDEV(I) = arr([M:SBF3]AMTREA(I)*100/[M:SBF3]AMTBUDREF(I), 0.01)
#        Else
#          # FQ72277 - MABON 11/03/11 - Si le budget est nul, le réalisé en pourcentage l'est aussi
##          [M:SBF3]PRCDEV(I) = 100
#          [M:SBF3]PRCDEV(I) = 0
#        Endif
#        # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants
#        If [M:SBF3]NBRPAR(I)>0 Then
#          [M:SBF3]NBRPRC(I) = arr([M:SBF3]NBRPARREA(I)*100/[M:SBF3]NBRPAR(I), 0.01)
#        Else
#          [M:SBF3]NBRPRC(I) = 0
#        Endif
#        # Fin MABON
#        # FQ75457 - MABON 26/08/11 - Ajout du nombre d'heures
#        If [M:SBF3]NBRHR(I)>0 Then
#          [M:SBF3]HRPRC(I) = arr([M:SBF3]NBRHRREA(I)*100/[M:SBF3]NBRHR(I), 0.01)
#        Else
#          [M:SBF3]HRPRC(I) = 0
#        Endif
#        # Fin MABON
#        [M:SBF3]NODSP(I)=""
#        [M:SBF3]NUMCRID(NBLIG4-1) = [M:SBF3]NUMCRID(I)
#        [M:SBF3]CRIDSYA(NBLIG4-1) = [M:SBF3]CRIDSYA(I)
#        [M:SBF3]AMTDEV(NBLIG4-1)  = [M:SBF3]AMTREA(I)-[M:SBF3]AMTBUDREF(I)
#        [M:SBF3]NBRDEV(NBLIG4-1)  = [M:SBF3]NBRPARREA(I)-[M:SBF3]NBRPAR(I)
#        [M:SBF3]HRDEV(NBLIG4-1)   = [M:SBF3]NBRHRREA(I)-[M:SBF3]NBRHR(I)

        [M:SBF3]AMTDEV(I) = [M:SBF3]AMTREA(I)-[M:SBF3]AMTBUDREF(I)
        # FQ75457 - Ajout du nombre de participants
        [M:SBF3]NBRDEV(I) = [M:SBF3]NBRPARREA(I)-[M:SBF3]NBRPAR(I)
        # FQ75457 - Ajout du nombre d'heures
        [M:SBF3]HRDEV(I)  = [M:SBF3]NBRHRREA(I)-[M:SBF3]NBRHR(I)
        If [M:SBF3]AMTBUDREF(I)>0 Then
           #ADNGO - 2017-07-03 - X3-29553 - START
           #[M:SBF3]PRCDEV(NBLIG4-1) = arr([M:SBF3]AMTREA(I)*100/[M:SBF3]AMTBUDREF(I), 0.01)
           [M:SBF3]PRCDEV(I) = arr([M:SBF3]AMTREA(I)*100/[M:SBF3]AMTBUDREF(I), 0.01)
           #ADNGO - 2017-07-03 - X3-29553 - END
        Else
          #ADNGO - 2017-07-03 - X3-29553 - START
          #[M:SBF3]PRCDEV(NBLIG4-1) = 0
          # FQ72277 - Si le budget est nul, le réalisé en pourcentage l'est aussi
          [M:SBF3]PRCDEV(I) = 0
          #ADNGO - 2017-07-03 - X3-29553 - END
        Endif
        If [M:SBF3]NBRPAR(I)>0 Then
          #ADNGO - 2017-07-03 - X3-29553 - START
          #[M:SBF3]NBRPRC(NBLIG4-1) = arr([M:SBF3]NBRPARREA(I)*100/[M:SBF3]NBRPAR(I), 0.01)
          [M:SBF3]NBRPRC(I) = arr([M:SBF3]NBRPARREA(I)*100/[M:SBF3]NBRPAR(I), 0.01)
          #ADNGO - 2017-07-03 - X3-29553 - END
        Else
          #ADNGO - 2017-07-03 - X3-29553 - START
          #[M:SBF3]NBRPRC(NBLIG4-1) = 0
          [M:SBF3]NBRPRC(I) = 0
          #ADNGO - 2017-07-03 - X3-29553 - END
        Endif
        If [M:SBF3]NBRHR(I)>0 Then
          #ADNGO - 2017-07-03 - X3-29553 - START
          #[M:SBF3]HRPRC(NBLIG4-1) = arr([M:SBF3]NBRHRREA(I)*100/[M:SBF3]NBRHR(I), 0.01)
          [M:SBF3]HRPRC(I) = arr([M:SBF3]NBRHRREA(I)*100/[M:SBF3]NBRHR(I), 0.01)
          #ADNGO - 2017-07-03 - X3-29553 - END
        Else
          #ADNGO - 2017-07-03 - X3-29553 - START
          #[M:SBF3]HRPRC(NBLIG4-1) = 0
          [M:SBF3]HRPRC(I) = 0
          #ADNGO - 2017-07-03 - X3-29553 - END
        Endif
        #ADNGO - 2017-07-03 - X3-29553 - START
        #[M:SBF3]NODSP(NBLIG4-1)=""
        [M:SBF3]NODSP(I)=""
        #ADNGO - 2017-07-03 - X3-29553 - END
        NBLIG4 += 1
#ADNGO - 2017-07-03 - X3-29553 - START
#      Else
#        Break
      Else
        Break
#ADNGO - 2017-07-03 - X3-29553 - END
      Endif
    Next
    # Ligne de total
    If NBLIG4>1 Then
      [M:SBF3]AMTDEV(NBLIG4-1)=0 : [M:SBF3]AMTBUDREF(NBLIG4-1)=0
      [M:SBF3]NBRPAR(NBLIG4-1)=0 : [M:SBF3]NBRPARREA(NBLIG4-1)=0 : [M:SBF3]NBRDEV(NBLIG4-1)=0
      [M:SBF3]NBRHR(NBLIG4-1)=0  : [M:SBF3]NBRHRREA(NBLIG4-1)=0  : [M:SBF3]HRDEV(NBLIG4-1)=0
      [M:SBF3]CRIDSYA(NBLIG4-1) = mess(151,115,1) : # Total
      For I=0 To NBLIG4-2
        [M:SBF3]AMTBUDREF(NBLIG4-1) += [M:SBF3]AMTBUDREF(I)
        [M:SBF3]AMTREA(NBLIG4-1)    += [M:SBF3]AMTREA(I)
        [M:SBF3]AMTDEV(NBLIG4-1)    += [M:SBF3]AMTDEV(I)
        # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants
        [M:SBF3]NBRPAR(NBLIG4-1)    += [M:SBF3]NBRPAR(I)
        [M:SBF3]NBRPARREA(NBLIG4-1) += [M:SBF3]NBRPARREA(I)
        [M:SBF3]NBRDEV(NBLIG4-1)    += [M:SBF3]NBRDEV(I)
        # FQ75457 - MABON 26/08/11 - Ajout du nombre d'heures
        [M:SBF3]NBRHR(NBLIG4-1)     += [M:SBF3]NBRHR(I)
        [M:SBF3]NBRHRREA(NBLIG4-1)  += [M:SBF3]NBRHRREA(I)
        [M:SBF3]HRDEV(NBLIG4-1)     += [M:SBF3]HRDEV(I)
      Next
      If [M:SBF3]AMTBUDREF(NBLIG4-1)>0 Then
        # FQ72277 - MABON 11/03/11 - C'est finalement le réalisé en pourcentage qui est calculé
#        [M:SBF3]PRCDEV(NBLIG4-1) = arr([M:SBF3]AMTDEV(NBLIG4-1)*100/[M:SBF3]AMTBUDREF(NBLIG4-1), 0.01)
        [M:SBF3]PRCDEV(NBLIG4-1) = arr([M:SBF3]AMTREA(NBLIG4-1)*100/[M:SBF3]AMTBUDREF(NBLIG4-1), 0.01)
      Else
        # FQ72277 - MABON 11/03/11 - Si le budget est nul, le réalisé en pourcentage l'est aussi
#        [M:SBF3]PRCDEV(NBLIG4-1) = 100
        [M:SBF3]PRCDEV(NBLIG4-1) = 0
      Endif
      # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants
      [M:SBF3]NBRPARREA(NBLIG4-1) = arr([M:SBF3]NBRPARREA(NBLIG4-1), 0.01)
      If [M:SBF3]NBRPAR(NBLIG4-1)>0 Then
        [M:SBF3]NBRPRC(NBLIG4-1) = arr([M:SBF3]NBRPARREA(NBLIG4-1)*100/[M:SBF3]NBRPAR(NBLIG4-1), 0.01)
      Else
        [M:SBF3]NBRPRC(NBLIG4-1) = 0
      Endif
      # Fin MABON
      # FQ75457 - MABON 26/08/11 - Ajout du nombre d'heures
      If [M:SBF3]NBRHR(NBLIG4-1)>0 Then
        [M:SBF3]HRPRC(NBLIG4-1) = arr([M:SBF3]NBRHRREA(NBLIG4-1)*100/[M:SBF3]NBRHR(NBLIG4-1), 0.01)
      Else
        [M:SBF3]HRPRC(NBLIG4-1) = 0
      Endif
      # Fin MABON
      [M:SBF3]NODSP(NBLIG4-1)="X"
      NBLIG4 += 1
    Endif
    [M:SBF3]NBAMT = NBLIG4-1
    If [M:SBF3]NBAMT>0 Then
      # FQ86506 - MABON 14/01/13 - Si type ADI, NUMCRID n'est pas numérique, mais alphanumérique
#      Sorta [M:SBF3]NBAMT-1 [M:SBF3]NBAMT Order By val([M:SBF3]NUMCRID(indice))
      Case [M:SBF1]CRIDSY
        When 3,4,7 #When 1,3,4,7 : #ADNGO - 2017-07-03 - X3-29553
          Sorta [M:SBF3]NBAMT-1 [M:SBF3]NBAMT Order By val([M:SBF3]NUMCRID(indice))
        When 1,2,5,6,16 #When 2,5,6 #FQ121853 - Item 1 moved here ; Add item 16 : #ADNGO - 2017-07-03 - X3-29553
          Sorta [M:SBF3]NBAMT-1 [M:SBF3]NBAMT Order By [M:SBF3]NUMCRID(indice)
      Endcase
      # Fin MABON
    Endif

    Affzo [M:SBF3]
  Endif
Return

$SETBOUT

  Chgstl [M:SBF2]NBAMT With ""
  Chgstl [M:SBF2]NBAMT([M:SBF2]NBAMT-1) With "PLGCUR"

  Chgstl [M:SBF3]NBAMT With ""
  Chgstl [M:SBF3]NBAMT([M:SBF3]NBAMT-1) With "PLGCUR"
Return

#**
#* Récupération des actions prévisionnelles
#*!
$CHARGE_PREV
Local Char    CRITERE(255), CRITDATMON(255), CRITDATPER(255)
Local Integer NBLIG2, NBLIG3, NBLIG4, I, AUZCFY
Local Date    DATDEM
Local Char    LIS_CPY(GLONCPY)(0..100)

  Raz [M:SBF2]: Raz [M:SBF3]
  If [M:SBF1]YEAPLF<>"" Then
    # SYMEU : ajout du flag Calcul pour ne prendre que ceux pris en compte dans le calcul
    # FQ74949 - MABON 01/04/11 - On filtre sur le critère Plan définitif si Répartition des coûts
    # Si Suivi budget, on force FLGCLO à 2
#    CRITERE="YEAPLF='"+[M:SBF1]YEAPLF+"' & FLGCLO=2 & CLCFLG=2"
    CRITERE="YEAPLF='"+[M:SBF1]YEAPLF+"' & CLCFLG=2 & LEGPLF='"+[M:SBF1]LEGPLF+"'"
    If GCHOIX="SBB" & dim([M:SBF1]FLGCLO)>0 Then
      CRITERE -= "& FLGCLO="+num$([M:SBF1]FLGCLO)
    Else
      CRITERE -= "& FLGCLO=2"
    Endif
    # Fin MABON
    If [M:SBF1]CPYPLF<>"" Then
      I=0 : Call CALC_GRPCPY([M:SBF1]CPYPLF, LIS_CPY, I) From TOOLSVAR
      If I>0 Then
        CRITERE -= "& find(CPYPLF,"
        For K=0 To I-1
          CRITERE += "'"+LIS_CPY(K)+"'"
          If K<I-1 Then CRITERE += "," : Endif
        Next
        CRITERE += ")>0"
      Endif
    Endif
    If [M:SBF1]FCYPLF<>"" Then
      CRITERE -= "& FCYPLF='"+[M:SBF1]FCYPLF+"'"
    Endif
    # FQ71320 - MABON 01/04/11 - On filtre aussi sur la version dans le cas de la répartition des coûts
    If GCHOIX="SBB" Then
      CRITERE -= "& VERPLF='"+[M:SBF1]VERPLF+"'"
    Endif
    #ADNGO - 2017-07-03 - X3-29553 - START
#    If [M:SBF1]MONREA<12 Then
##      CRITDATPER  = "[F:DEM]DATDEM<["+format$("D:"+GFMDAT4, "01/"+num$([M:SBF1]MONREA+1)+"/"+[M:SBF1]YEAPLF)+"]"
#      CRITDATPER  = "[F:DEM]DATDEM<["+format$("D:"+GFMDAT4, gdat$(1,[M:SBF1]MONREA+1,val([M:SBF1]YEAPLF)))+"]"
#    Else
##      CRITDATPER  = "[F:DEM]DATDEM<["+format$("D:"+GFMDAT4, "01/01/"+num$(val([M:SBF1]YEAPLF)+1))+"]"
#      CRITDATPER  = "[F:DEM]DATDEM<["+format$("D:"+GFMDAT4, gdat$(1,1,val([M:SBF1]YEAPLF)+1))+"]"
#    Endif
    # FQ106549 - La période peut faire plus de 12 mois
    # FQ103083 - Si paramètres régionaux avec des tirets en séparateurs de dates, le evalue sur ce critère plante avec GFMDAT4
    # FQ106549 - [M:SBF1]MONREA est relatif au ML 727 qui court sur 3 ans, donc peut contenir les valeurs 1 à 35
    If [M:SBF1]MONREA>12 Then
      MONREL=gdat$(1,[M:SBF1]MONREA-12, val([M:SBF1]YEAREA))
    Else
      MONREL=gdat$(1,[M:SBF1]MONREA, val([M:SBF1]YEAREA))
    Endif
    #ADNGO - 2017-07-03 - X3-29553 - END
    #ADNGO - 2017-07-03 - X3-29553 - START
##    CRITDATMON  = CRITDATPER-"& [F:DEM]DATDEM>=["+format$("D:"+GFMDAT4, "01/"+num$([M:SBF1]MONREA)+"/"+[M:SBF1]YEAPLF)+"]"
##    CRITDATPER -= "& [F:DEM]DATEND>=["+format$("D:"+GFMDAT4, "01/01/"+[M:SBF1]YEAPLF)+"]"
#    CRITDATMON  = CRITDATPER-"& [F:DEM]DATDEM>=["+format$("D:"+GFMDAT4, gdat$(1,[M:SBF1]MONREA,val([M:SBF1]YEAPLF)))+"]"
#    CRITDATPER -= "& [F:DEM]DATEND>=["+format$("D:"+GFMDAT4, gdat$(1,1,val([M:SBF1]YEAPLF)))+"]"
    CRITDATPER  = "[F:DEM]DATDEM<=eomonth(MONREL)"
    CRITDATMON  = CRITDATPER-"& [F:DEM]DATDEM>=MONREL"
    CRITDATPER -= "& [F:DEM]DATEND>=[M:SBF1]STRDAT"
    #ADNGO - 2017-07-03 - X3-29553 - END

    nolign=1
    Filter [F:PLF] Where evalue(CRITERE)
    NBLIG2 = 1 : NBLIG3 = 1
    For [F:PLF]
      AUZCFY = func SUBHRSES.GET_AUZ([F:PLF]CPY, [F:PLF]FCY, "CONSSBF")
      If AUZCFY=2 Then
#        ENROKMON=2 : ENROKPER=2
        DATDEM=[0/0/0]
        If [F:PLF]DEMNUM<>'' Then
          Call LECTURE("DEM", [F:PLF]DEMNUM, "") From CONTOBJ
          If [F:DEM]DATDEM<>[0/0/0] Then
#            If evalue(CRITDATMON)=0 Then  ENROKMON=1 : Endif
#            If evalue(CRITDATPER)=0 Then  ENROKPER=1 : Endif
            DATDEM = [F:DEM]DATDEM
          Endif
        Endif
        Call LECTURE("EML", [F:PLF]EMP, "") From CONTOBJ
        [M:SBF2]STGPREV(NBLIG2-1)    = [F:PLF]STG
        [M:SBF2]EMPPREV(NBLIG2-1)    = [F:PLF]EMP
        [M:SBF2]SRNPREV(NBLIG2-1)    = [F:ID]SRN
        [M:SBF2]CTRNUMPREV(NBLIG2-1) = [F:PLF]CTRNUM
        [M:SBF2]DEMPREV(NBLIG2-1)    = [F:PLF]DEMNUM
        [M:SBF2]DATPREV(NBLIG2-1)    = DATDEM
        NBLIG2 += 1
        Call CHARGE_AMT("SBF2", "PREV")

        [M:SBF3]STGPREV(NBLIG3-1)    = [F:PLF]STG
        [M:SBF3]EMPPREV(NBLIG3-1)    = [F:PLF]EMP
        [M:SBF3]SRNPREV(NBLIG3-1)    = [F:ID]SRN
        [M:SBF3]CTRNUMPREV(NBLIG3-1) = [F:PLF]CTRNUM
        [M:SBF3]DEMPREV(NBLIG3-1)    = [F:PLF]DEMNUM
        [M:SBF3]DATPREV(NBLIG3-1)    = DATDEM
        NBLIG3 += 1
        Call CHARGE_AMT("SBF3", "PREV")
      Endif
    Next
    Filter [F:PLF]
    [M:SBF2]NBLIG = NBLIG2-1 : [M:SBF3]NBLIG = NBLIG3-1

    nolign=1
#    While [M:SBF2]CRIDSYA(nolign-1)<>""
    #ADNGO - 2017-07-03 - X3-29553 - START
    #While [M:SBF2]AMTBUDREF(nolign-1)<>0 | [M:SBF2]AMTREA(nolign-1)<>0
    While [M:SBF2]AMTBUDREF(nolign-1)<>0 | [M:SBF2]AMTREA(nolign-1)<>0 | [M:SBF2]CRIDSYA(nolign-1)<>""
    #ADNGO - 2017-07-03 - X3-29553 - END
      nolign +=1
    Wend
    [M:SBF2]NBAMT = nolign-1
    # Les montants prévisionnels sont divisés par 12 sur l'onglet "Mois en cours"
    #ADNGO - 2017-07-03 - X3-29553 - START
#    For nolign=1 To [M:SBF2]NBAMT
#      [M:SBF2]AMTBUDREF(nolign-1) = arr([M:SBF2]AMTBUDREF(nolign-1)/12, 0.01)
#      # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants
#      [M:SBF2]NBRPAR(nolign-1)    = arr([M:SBF2]NBRPAR(nolign-1)/12, 0.01)
#      # FQ75457 - MABON 26/08/11 - Ajout du nombre d'heures
#      [M:SBF2]NBRHR(nolign-1)     = arr([M:SBF2]NBRHR(nolign-1)/12, 0.01)
#    Next

    If NBMONTH>0 Then
      For nolign=1 To [M:SBF2]NBAMT
        # FQ106549 - La période peut faire plus de 12 mois
        [M:SBF2]AMTBUDREF(nolign-1) = arr([M:SBF2]AMTBUDREF(nolign-1)/NBMONTH, 0.01)
        [M:SBF2]NBRPAR(nolign-1)    = arr([M:SBF2]NBRPAR(nolign-1)/NBMONTH, 0.01)
        [M:SBF2]NBRHR(nolign-1)     = arr([M:SBF2]NBRHR(nolign-1)/NBMONTH, 0.01)
      Next
    Endif
    #ADNGO - 2017-07-03 - X3-29553 - END
    nolign=1
#    While [M:SBF3]CRIDSYA(nolign-1)<>""
    #ADNGO - 2017-07-03 - X3-29553 - START
    #While [M:SBF3]AMTBUDREF(nolign-1)<>0 | [M:SBF3]AMTREA(nolign-1)<>0
    While [M:SBF3]AMTBUDREF(nolign-1)<>0 | [M:SBF3]AMTREA(nolign-1)<>0 | [M:SBF3]CRIDSYA(nolign-1)<>""
    #ADNGO - 2017-07-03 - X3-29553 - END
      nolign +=1
    Wend
    [M:SBF3]NBAMT = nolign-1
    # Les montants prévisionnels sont ramenés au nombre de mois de la période demandée sur l'onglet "Cumul fin mois"
    #ADNGO - 2017-07-03 - X3-29553 - START
#    For nolign=1 To [M:SBF3]NBAMT
#      [M:SBF3]AMTBUDREF(nolign-1) = arr([M:SBF3]AMTBUDREF(nolign-1)*[M:SBF1]MONREA/12, 0.01)
#      # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants
#      [M:SBF3]NBRPAR(nolign-1)    = arr([M:SBF3]NBRPAR(nolign-1)*[M:SBF1]MONREA/12, 0.01)
#      # FQ75457 - MABON 26/08/11 - Ajout du nombre d'heures
#      [M:SBF3]NBRHR(nolign-1)     = arr([M:SBF3]NBRHR(nolign-1)*[M:SBF1]MONREA/12, 0.01)
#    Next


    If NBMONTH>0 Then
      For nolign=1 To [M:SBF3]NBAMT
        ###############################################################################################
        # FQ106549 - La période peut faire plus de 12 mois
        [M:SBF3]AMTBUDREF(nolign-1) = arr([M:SBF3]AMTBUDREF(nolign-1)*NUMMON/NBMONTH, 0.01)
        [M:SBF3]NBRPAR(nolign-1)    = arr([M:SBF3]NBRPAR(nolign-1)*NUMMON/NBMONTH, 0.01)
        [M:SBF3]NBRHR(nolign-1)     = arr([M:SBF3]NBRHR(nolign-1)*NUMMON/NBMONTH, 0.01)
        ###############################################################################################
      Next
    Endif
    #ADNGO - 2017-07-03 - X3-29553 - END
  Endif
Return

#**
#* Récupération des actions réalisées sur le mois (M:SBF2) et la période en cours (M:SBF3)
#*!
$CHARGE_REA
Local Char    CRITDATPER(255), CRITDATMON(255), CRITCFY(255)
Local Integer NBLIG2, NBLIG3, AUZCFY, ENR_OK
Local Char    LIS_CPY(GLONCPY)(0..100)
Local Char    CPYLEG(GLONCPY)

  Raz GTABSES2 : Raz GTABSES3
  If [M:SBF1]YEAPLF<>"" Then
    # Recherche des demandes répondant aux critères de date
    Link [F:DML] With [F:DEM]DEM0=[F:DML]DEMNUM As [DM_] Where [F:DEM]FLGPLF=1
     #ADNGO - 2017-07-03 - X3-29553 - START
#    If [M:SBF1]MONREA<12 Then
##      CRITDATPER  = "[F:DEM]DATDEM<["+format$("D:"+GFMDAT4, "01/"+num$([M:SBF1]MONREA+1)+"/"+[M:SBF1]YEAPLF)+"]"
#      CRITDATPER  = "[F:DEM]DATDEM<["+format$("D:"+GFMDAT4, gdat$(1,[M:SBF1]MONREA+1,val([M:SBF1]YEAPLF)))+"]"
#    Else
##      CRITDATPER  = "[F:DEM]DATDEM<["+format$("D:"+GFMDAT4, "01/01/"+num$(val([M:SBF1]YEAPLF)+1))+"]"
#      CRITDATPER  = "[F:DEM]DATDEM<["+format$("D:"+GFMDAT4, gdat$(1,1,val([M:SBF1]YEAPLF)+1))+"]"
#    Endif

    If [M:SBF1]MONREA>12 Then
      MONREL=gdat$(1,[M:SBF1]MONREA-12, val([M:SBF1]YEAREA))
    Else
      MONREL=gdat$(1,[M:SBF1]MONREA, val([M:SBF1]YEAREA))
    Endif
    #ADNGO - 2017-07-03 - X3-29553 - END
#    CRITDATPER -= "& [F:DEM]DATDEM>=["+format$("D:"+GFMDAT4, "01/01/"+num$(val([M:SBF1]YEAPLF)))+"]"
#    CRITDATMON  = CRITDATPER - "& [F:DEM]DATDEM>=["+format$("D:"+GFMDAT4, "01/"+num$([M:SBF1]MONREA)+"/"+[M:SBF1]YEAPLF)+"]"
#    CRITDATPER -= "& ([F:DEM]DATEND>=["+format$("D:"+GFMDAT4, "01/01/"+[M:SBF1]YEAPLF)+"] | [F:DEM]DATEND=[0/0/0])"
#ADNGO - 2017-07-03 - X3-29553 - START
    #CRITDATPER -= "& [F:DEM]DATDEM>=["+format$("D:"+GFMDAT4, gdat$(1,1,val([M:SBF1]YEAPLF)))+"]"
    #CRITDATMON  = CRITDATPER - "& [F:DEM]DATDEM>=["+format$("D:"+GFMDAT4, gdat$(1,[M:SBF1]MONREA,val([M:SBF1]YEAPLF)))+"]"
    #CRITDATPER -= "& ([F:DEM]DATEND>=["+format$("D:"+GFMDAT4, gdat$(1,1,val([M:SBF1]YEAPLF)))+"] | [F:DEM]DATEND=[0/0/0])"
    CRITDATPER  = "[F:DEM]DATDEM<=eomonth(MONREL) & ([F:DEM]DATDEM>=[M:SBF1]STRDAT | [F:DEM]DATEND=[0/0/0])"
    CRITDATMON  = CRITDATPER-"& [F:DEM]DATDEM>=MONREL"
#ADNGO - 2017-07-03 - X3-29553 - END
    # FQ71708 - MABON 03/03/11 - On doit aussi tenir compte du site/société pour déterminer les lignes de demande
    # à prendre en compte
    CRITCFY="1=1"
    If [M:SBF1]CPYPLF<>"" Then
      I=0 : Call CALC_GRPCPY([M:SBF1]CPYPLF, LIS_CPY, I) From TOOLSVAR
      If I>0 Then
        CRITCFY -= "& find([F:DML]CPY,'',"
        For K=0 To I-1
          CRITCFY += "'"+LIS_CPY(K)+"'"
          If K<I-1 Then CRITCFY += "," : Endif
        Next
        CRITCFY += ")>0"
      Endif
    Endif
    If [M:SBF1]FCYPLF<>"" Then
      CRITCFY -= "& find([F:DML]FCY,'','"+[M:SBF1]FCYPLF+"')>0"
    Endif
    # Fin MABON
    #ADNGO - 2017-07-03 - X3-29553 - START
    Gosub CALC_CRITCFY : #US4003 112241 filtre SOCSITE
    Gosub LNK_CPY_FCY  : #US4003 112241 filtre SOCSITE
    #ADNGO - 2017-07-03 - X3-29553 - END
    NBLIG2=1 : NBLIG3=1
    # FQ72179 - MABON 11/03/11 - Si on prend les demandes selon ces critères, on risque de ne pas prendre des demandes
    # faites l'année précédente, alors que l'inscription a lieu sur l'année en cours
    # Donc, on ne fait plus en deux temps : demandes, puis inscriptions sans demande. On prend toutes les
    # inscriptions avec ou sans demande
#    Filter [F:DM_] Where evalue(CRITDATPER) & evalue(CRITCFY)
#    For [F:DM_]
#      If NBLIG2<=dim([M:SBF2]STGREA) & NBLIG3<=dim([M:SBF3]STGREA) Then
#        AUZCFY=2
#        If [F:DML]NBREMP=1 Then
#          AUZCFY = func SUBHRSES.GET_AUZ([F:DML]CPY, [F:DML]FCY, "CONSSBF")
#        Endif
#
#        If AUZCFY=2 Then
#          If evalue(CRITDATMON)>0 Then
#            [M:SBF2]STGREA(NBLIG2-1)    = [F:DEM]STG
#            [M:SBF2]EMPREA(NBLIG2-1)    = [F:DML]EMP
#            Call LECTURE("EML", [F:DML]EMP, "") From CONTOBJ
#            [M:SBF2]SRNREA(NBLIG2-1)    = [F:ID]SRN
#            [M:SBF2]CTRNUMREA(NBLIG2-1) = [F:DML]CTRNUM
#            [M:SBF2]SES(NBLIG2-1)       = [F:DEM]SES
#            [M:SBF2]DEMREA(NBLIG2-1)    = [F:DEM]DEMNUM
#            [M:SBF2]DATREA(NBLIG2-1)    = [F:DEM]DATDEM
#            [M:SBF2]KEYLIG(NBLIG2-1)    = [F:DEM]STG+"~"+[F:DEM]SES+"~"+[F:DML]EMP
#            NBLIG2 += 1
#
#            Call CHARGE_AMT("SBF2", "READ") : # Chargement des montants pour les demandes
#          Endif
#
#          [M:SBF3]STGREA(NBLIG3-1)    = [F:DEM]STG
#          [M:SBF3]EMPREA(NBLIG3-1)    = [F:DML]EMP
#          Call LECTURE("EML", [F:DML]EMP, "") From CONTOBJ
#          [M:SBF3]SRNREA(NBLIG3-1)    = [F:ID]SRN
#          [M:SBF3]CTRNUMREA(NBLIG3-1) = [F:DML]CTRNUM
#          [M:SBF3]DEMREA(NBLIG3-1)    = [F:DEM]DEMNUM
#          [M:SBF3]SES(NBLIG3-1)       = [F:DEM]SES
#          [M:SBF3]DATREA(NBLIG3-1)    = [F:DEM]DATDEM
#          [M:SBF3]KEYLIG(NBLIG3-1)    = [F:DEM]STG+"~"+[F:DEM]SES+"~"+[F:DML]EMP
#          NBLIG3 += 1
#
#          Call CHARGE_AMT("SBF3", "READ") : # Chargement des montants pour les demandes
#        Endif
#      Else
#        # Trop de lignes de demandes/ Toutes les demandes ne seront pas comptabilisées
#        Infbox mess(226,10717,1)+chr$(10)+mess(227,10717,1)
#        Break
#      Endif
#    Next

    If NBLIG2<=dim([M:SBF2]STGREA) & NBLIG3<=dim([M:SBF3]STGREA) Then
      # Recherche des inscriptions sans demandes, répondant aux critères de date
      # FQ72179 - MABON 11/03/11 - Si on prend les demandes selon ces critères, on risque de ne pas prendre des demandes
      # faites l'année précédente, alors que l'inscription a lieu sur l'année en cours
      # Donc, on ne fait plus en deux temps : demandes, puis inscriptions sans demande. On prend toutes les
      # inscriptions avec ou sans demande
#      Link [F:INJ] With [F:INS]INS0=[F:INJ]STG;[F:INJ]SES;[F:INJ]REFNUM As [IN_] Where [F:INS]DEM=""
      # FQ73296 - MABON 15/04/11 - La vérification du mois de réalisation doit se faire sur la date de fin
      # de session
#      Link [F:INJ] With [F:INS]INS0=[F:INJ]STG;[F:INJ]SES;[F:INJ]REFNUM As [IN_] Where [F:INS]SES<>""
      # FQ80895 - MABON 07/06/12 - On écarte les inscriptions refusées
#      Link [F:INJ] With [F:INS]INS0=[F:INJ]STG;[F:INJ]SES;[F:INJ]REFNUM, [F:HRSES]SES0=[F:INS]SES As [IN_]
#&                  Where [F:INS]SES<>""
      Link [F:INJ] With [F:INS]INS0=[F:INJ]STG;[F:INJ]SES;[F:INJ]REFNUM, [F:HRSES]SES0=[F:INS]SES As [IN_]
&                  Where [F:INS]SES<>"" & [F:INS]STA<>3
&                  Order By Key KEY1=[F:INJ]SES;[F:INJ]REFNUM;[F:INJ]DAT Desc:#US4003 112241 filtre SOCSITE : #ADNGO - 2017-07-03 - X3-29553
      # End MABON
#      If [M:SBF1]MONREA<12 Then
#        CRITDATPER  = "[F:INJ]DAT<["+format$("D:"+GFMDAT4, "01/"+num$([M:SBF1]MONREA+1)+"/"+[M:SBF1]YEAPLF)+"]"
#      Else
#        CRITDATPER  = "[F:INJ]DAT<["+format$("D:"+GFMDAT4, "01/01/"+num$(val([M:SBF1]YEAPLF)+1))+"]"
#      Endif
#      CRITDATPER -= "& [F:INJ]DAT>=["+format$("D:"+GFMDAT4, "01/01/"+[M:SBF1]YEAPLF)+"]"
#      CRITDATMON  = CRITDATPER - "& [F:INJ]DAT>=["+format$("D:"+GFMDAT4, "01/"+num$([M:SBF1]MONREA)+"/"+[M:SBF1]YEAPLF)+"]"
      #ADNGO - 2017-07-03 - X3-29553 - START
#      If [M:SBF1]MONREA<12 Then
##        CRITDATPER  = "[F:HRSES]ENDDAT<["+format$("D:"+GFMDAT4, "01/"+num$([M:SBF1]MONREA+1)+"/"+[M:SBF1]YEAPLF)+"]"
#        CRITDATPER  = "[F:HRSES]ENDDAT<["+format$("D:"+GFMDAT4, gdat$(1,[M:SBF1]MONREA+1,val([M:SBF1]YEAPLF)))+"]"
#      Else
##        CRITDATPER  = "[F:HRSES]ENDDAT<["+format$("D:"+GFMDAT4, "01/01/"+num$(val([M:SBF1]YEAPLF)+1))+"]"
#        CRITDATPER  = "[F:HRSES]ENDDAT<["+format$("D:"+GFMDAT4, gdat$(1,1,val([M:SBF1]YEAPLF)+1))+"]"
#      Endif

      If [M:SBF1]MONREA>12 Then
        MONREL=gdat$(1,[M:SBF1]MONREA-12, val([M:SBF1]YEAREA))
      Else
        MONREL=gdat$(1,[M:SBF1]MONREA, val([M:SBF1]YEAREA))
      Endif
      #ADNGO - 2017-07-03 - X3-29553 - END
#      CRITDATPER -= "& [F:HRSES]ENDDAT>=["+format$("D:"+GFMDAT4, "01/01/"+[M:SBF1]YEAPLF)+"]"
#      CRITDATMON  = CRITDATPER - "& [F:HRSES]ENDDAT>=["+format$("D:"+GFMDAT4, "01/"+num$([M:SBF1]MONREA)+"/"+[M:SBF1]YEAPLF)+"]"
      #ADNGO - 2017-07-03 - X3-29553 - START
#      CRITDATPER -= "& [F:HRSES]ENDDAT>=["+format$("D:"+GFMDAT4, gdat$(1,1,val([M:SBF1]YEAPLF)))+"]"
#      CRITDATMON  = CRITDATPER - "& [F:HRSES]ENDDAT>=["+format$("D:"+GFMDAT4, gdat$(1,[M:SBF1]MONREA,val([M:SBF1]YEAPLF)))+"]"

      If CTLBUR="1"
        CRITDATPER  = "[F:HRSES]STRDAT>=[M:SBF1]STRDAT & [F:HRSES]STRDAT<=eomonth(MONREL)"
        CRITDATMON  = CRITDATPER-"& [F:HRSES]STRDAT>=MONREL"
      Else
        CRITDATPER  = "[F:HRSES]ENDDAT<=eomonth(MONREL) & [F:HRSES]ENDDAT>=[M:SBF1]STRDAT"
        CRITDATMON  = CRITDATPER-"& [F:HRSES]ENDDAT>=MONREL"
      Endif
      #ADNGO - 2017-07-03 - X3-29553 - END
      # Fin MABON

#      Filter [F:IN_] Where evalue(CRITDATPER) Order By [F:INJ]DAT Desc
      Filter [F:IN_] Where evalue(CRITDATPER) #Order By [F:INS]SES;[F:INS]REFNUM;[F:INJ]DAT Desc
      #ADNGO - 2017-07-03 - X3-29553 - START
      #For [F:IN_]
      For [IN_]KEY1(2) #US4003 112241 filtre SOCSITE lecture sans les lignes jours d'inscription
      #ADNGO - 2017-07-03 - X3-29553 - END
        If NBLIG2<=dim([M:SBF2]STGREA) & NBLIG3<=dim([M:SBF3]STGREA) Then
#          Call LECTURE("CTR", [F:INS]CTRNUM, "") From CONTOBJ
          Filter [F:HRCTR] Where CTRNUM=[F:INS]CTRNUM & REFNUM=[F:INS]REFNUM & CTRDAT<=[F:HRSES]ENDDAT
          Read [F:HRCTR] Last
          If fstat Then Raz [F:HRCTR] : Endif
          Filter [F:HRCTR]
          Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
          AUZCFY = func SUBHRSES.GET_AUZ([F:FCY]LEGCPY, [F:HRCTR]ETRFCY, "CONSSBF")
          # FQ72911 - MABON 01/04/11 - Si l'inscription est rattachée à une demande, il faut que celle-ci ne soit
          # pas hors plan
          ENR_OK=2
          If [F:INS]DEM<>"" Then
            Call LECTURE("DEM", [F:INS]DEM, "") From CONTOBJ
            If [F:DEM]DEMNUM<>"" & [F:DEM]FLGPLF=2 Then
              ENR_OK=1
            Endif
          #ADNGO - 2017-07-03 - X3-29553 - START
          Elsif [F:INS]STG<>"" Then : #US4003 112693  il faut que le stage ne soit pas hors plan
            Call LECTURE("STG", [F:INS]STG, "") From CONTOBJ
            If [F:STG]COD<>"" & [F:STG]FLGPLF=2 Then
              ENR_OK=1
            Endif
          #ADNGO - 2017-07-03 - X3-29553 - END
          Endif
          #ADNGO - 2017-07-03 - X3-29553 - START
          If ENR_OK=2 : Gosub VERIF_CPY_FCY : Endif:#US4003 112241 filtre SOCSITE
          #ADNGO - 2017-07-03 - X3-29553 - END

          CPYLEG=func TOOLSHRLEG.GETLEGFCY([F:HRCTR]ETRFCY)
          If CPYLEG<>[M]LEGPLF Then
            ENR_OK=1
          Endif

          If AUZCFY=2 & ENR_OK=2 Then
          #ADNGO - 2017-07-03 - X3-29553 - START
          For [IN_]KEY1 :#US4003 112241 filtre SOCSITE lecture des lignes jours d'inscription
          #ADNGO - 2017-07-03 - X3-29553 - END
            If evalue(CRITDATMON)>0 and !find([F:INS]STG+"~"+[F:INS]SES+"~"+[F:INS]REFNUM, [M:SBF2]KEYLIG) Then
              [M:SBF2]STGREA(NBLIG2-1)    = [F:INS]STG
              [M:SBF2]EMPREA(NBLIG2-1)    = [F:INS]REFNUM
              Call LECTURE("EML", [F:INS]REFNUM, "") From CONTOBJ
              [M:SBF2]SRNREA(NBLIG2-1)    = [F:ID]SRN
              [M:SBF2]CTRNUMREA(NBLIG2-1) = [F:INS]CTRNUM
              [M:SBF2]DEMREA(NBLIG2-1)    = [F:INS]DEM
              [M:SBF2]SES(NBLIG2-1)       = [F:INS]SES
              [M:SBF2]DATREA(NBLIG2-1)    = [F:INJ]DAT
              [M:SBF2]KEYLIG(NBLIG2-1)    = [F:INS]STG+"~"+[F:INS]SES+"~"+[F:INS]REFNUM
              NBLIG2 += 1

              Call CHARGE_AMT("SBF2", "REAI") : # Chargement des montants pour les inscriptions
            Endif

            If !find([F:INS]STG+"~"+[F:INS]SES+"~"+[F:INS]REFNUM, [M:SBF3]KEYLIG) Then
              [M:SBF3]STGREA(NBLIG3-1)    = [F:INS]STG
              [M:SBF3]EMPREA(NBLIG3-1)    = [F:INS]REFNUM
              Call LECTURE("EML", [F:INS]REFNUM, "") From CONTOBJ
              [M:SBF3]SRNREA(NBLIG3-1)    = [F:ID]SRN
              [M:SBF3]CTRNUMREA(NBLIG3-1) = [F:INS]CTRNUM
              [M:SBF3]DEMREA(NBLIG3-1)    = [F:INS]DEM
              [M:SBF3]SES(NBLIG3-1)       = [F:INS]SES
              [M:SBF3]DATREA(NBLIG3-1)    = [F:INJ]DAT
              [M:SBF3]KEYLIG(NBLIG3-1)    = [F:INS]STG+"~"+[F:INS]SES+"~"+[F:INS]REFNUM
              NBLIG3 += 1

              Call CHARGE_AMT("SBF3", "REAI") : # Chargement des montants pour les inscriptions
            Endif
           #ADNGO - 2017-07-03 - X3-29553 - START
           Next #[F:IN_] US4003 112241 filtre SOCSITE lecture sans les lignes jours d'inscription
           #ADNGO - 2017-07-03 - X3-29553 - END
          Endif
        Else
          # Trop de lignes de demandes/ Toutes les demandes ne seront pas comptabilisées
          Infbox mess(226,10717,1)+chr$(10)+mess(227,10717,1)
          Break
        Endif
      Next
    Endif

    For nolign=1 To dim([M:SBF2]AMTREA)
      [M:SBF2]AMTREA(nolign-1) = arr([M:SBF2]AMTREA(nolign-1), 0.01)
    Next
    For nolign=1 To dim([M:SBF3]AMTREA)
      [M:SBF3]AMTREA(nolign-1) = arr([M:SBF3]AMTREA(nolign-1), 0.01)
    Next

    [M:SBF2]NBREA = NBLIG2-1 : [M:SBF3]NBREA = NBLIG3-1
  Endif
Return
#ADNGO - 2017-07-03 - X3-29553 - START
#US4003 112241 filtre SOCSITE
$CALC_CRITCFY
CRITCFY="1=1"
Raz LIS_CPY
If [M:SBF1]CPYPLF<>"" Then
  I=0 : Call CALC_GRPCPY([M:SBF1]CPYPLF, LIS_CPY, I) From TOOLSVAR
  If I>0 Then
    CRITCFY = "find([F:FCY]LEGCPY,'',"
    For K=0 To I-1
      CRITCFY += "'"+LIS_CPY(K)+"'"
      If K<I-1 Then CRITCFY += "," : Endif
    Next
    CRITCFY += ")>0"
  Endif
Endif
If [M:SBF1]FCYPLF<>"" Then
  CRITCFY -= "& find([LCTR]ETRFCY,'','"+[M:SBF1]FCYPLF+"')>0"
Endif
Return
#ADNGO - 2017-07-03 - X3-29553 - END

#ADNGO - 2017-07-03 - X3-29553 - START
#US4003 112241 filtre SOCSITE
$LNK_CPY_FCY
Link [HRCTR] With
&               [FCY]FCY0 = [F:HRCTR]ETRFCY,
&               [CPY]CPY0 = [F:FCY]LEGCPY
& As [LCTR]
Return
#ADNGO - 2017-07-03 - X3-29553 - END

#ADNGO - 2017-07-03 - X3-29553 - START
#US4003 112241 filtre SOCSITE
$VERIF_CPY_FCY
Local Date DATSTR, DATEND

  DATSTR=[F:HRSES]STRDAT : DATEND=[F:HRSES]ENDDAT
  # Calcul dates inscription
  Filter [F:INJW] Where STG=[F:INS]STG & SES=[F:INS]SES & REFNUM=[F:INS]REFNUM Order By DAT
  Read [F:INJW] First : DATSTR=[F:INJW]DAT
  Read [F:INJW] Last  : DATEND=[F:INJW]DAT
  Filter [F:INJW]

    # Recherche site du contrat

  ENR_OK=1
  Filter [LCTR] Where [F:HRCTR]REFNUM=[F:INS]REFNUM & [F:HRCTR]CTRNUM=[F:INS]CTRNUM & ([F:HRCTR]CTRDAT>=DATSTR | [F:HRCTR]CTRDAT<=DATEND)
&    Order By CTRDAT Desc

  If rowcount([LCTR])>0 Then
     Read [LCTR] First
     If !fstat
       # Recherche société du contrat
       Read [FCY]FCY0 = [F:LCTR]ETRFCY
       If !fstat & evalue(CRITCFY) Then
          AUZCFY = func SUBHRSES.GET_AUZ([F:FCY]LEGCPY, [F:LCTR]ETRFCY, "CONSSBF")
          ENR_OK=2
       Endif
     Endif
  Endif
  Filter [LCTR]
Return
#ADNGO - 2017-07-03 - X3-29553 - END

#**
#* Récupération des montants, dispatchés selon le critère d'affichage sélectionné
#*!
Subprog CHARGE_AMT(AMK, TYPAMT)
Value Char AMK, TYPAMT
Local Char CRITERE(255)

  If AMK="SBF2" Then Local Mask [M:SBF2] Endif
  If AMK="SBF3" Then Local Mask [M:SBF3] Endif
  Case TYPAMT
    When "PREV" :
#      CRITERE = "YEAPLF='"+[F:PLF]YEAPLF+"' & NUMLIG="+num$([F:PLF]NUMLIG)+" & VERPLF='"+[F:PLF]VERPLF+"' & CPYPLF='"+[F:PLF]CPYPLF
#&              +"' & FCYPLF='"+[F:PLF]FCYPLF+"'"
      CRITERE = "YEAPLF='"+[F:PLF]YEAPLF+"' & NUMLIG="+num$([F:PLF]NUMLIG)+" & VERPLF='"+[F:PLF]VERPLF+"'"
&              +" & LEGPLF='"+[F:PLF]LEGPLF+"'"
      If [F:PLF]CPYPLF<>"" Then CRITERE -= " & CPYPLF='"+[F:PLF]CPYPLF+"'" Endif
      If [F:PLF]FCYPLF<>"" Then CRITERE -= " & FCYPLF='"+[F:PLF]FCYPLF+"'" Endif
      Filter [F:PLC] Where evalue(CRITERE)
    When "READ" :
      Filter [F:INS] Where DEM=[F:DEM]DEMNUM & REFNUM=[F:DML]EMP Order By SES
  Endcase

  # FQ85365 US903 - MABON 29/10/12 - Ajout critère Nature fiscale
  Case [M:SBF1]CRIDSY
    When 1 : # Dispositif
      Call CHARGE_AMT_FRT(AMK, TYPAMT)
    When 2 : # Type de financement
      Call CHARGE_AMT_FIN(AMK, TYPAMT)
    When 3 : # Catégorie d'action
      Call CHARGE_AMT_ACN(AMK, TYPAMT)
    When 4 : # Sexe
      Call CHARGE_AMT_SEX(AMK, TYPAMT)
    When 5 : # Age
      Call CHARGE_AMT_AGE(AMK, TYPAMT)
    When 6 : # CSP
      Call CHARGE_AMT_CSP(AMK, TYPAMT)
    When 7 : # Nature fiscale
      Call CHARGE_AMT_FIS(AMK, TYPAMT)
    #ADNGO - 2017-07-03 - X3-29553 - START
    # Issue X3-11720 - 2017-01-27 by BRBAN
    When 8
        Call CHARGE_AMT_SRV(AMK, TYPAMT)
    #ADNGO - 2017-07-03 - X3-29553 - END
  Endcase

  Case TYPAMT
    When "PREV" :
      Filter [F:PLC]
    When "READ" :
      Filter [F:INS]
  Endcase
End

#**
#* Fonction de calcul du n° de ligne
#*
#* @param DATA    : donnée à retrouver dans le tableau
#* @param TYPDATA : type de donnée AML pour menu local, ou ADI pour table diverse
#* @param NODATA  : n° du menu local ou de la table diverse
#*!
Funprog FIND_DATA(DATA, TYPDATA, NODATA)
Value Char    DATA, TYPDATA
Value Integer NODATA
Local Integer NBLIGA

  NBLIGA=find(DATA, [M]NUMCRID)
  If NBLIGA=0 Then
    For I=0 To dim([M]CRIDSYA)-1
      If [M]NUMCRID(I)="" Then NBLIGA = I : Break : Endif
    Next
#ADNGO - 2017-07-03 - X3-29553 - START
#    If TYPDATA="AML" Then
#      [M]CRIDSYA(NBLIGA) = mess(val(DATA),NODATA,1)
#      If [M]CRIDSYA(NBLIGA)="" & NODATA=314 Then : # Menu local Sexe, où Non défini n'existe pas
#        [M]CRIDSYA(NBLIGA) = mess(205,10717,1) : # Non défini
#      Endif
#    Endif
#    If TYPDATA="ADI" Then
#      # FQ86506 - MABON 14/01/13 - Si type ADI, NUMCRID n'a pas la valeur Non défini dans ses valeurs
#      # On le définit donc à ZVIDE pour permettre le tri, mais on définit CRIDSYA pour l'homogénéité avec les autres critères d'affichage
#      If DATA<>"ZVIDE" Then
#        [M]CRIDSYA(NBLIGA) = func FIND_DESAXX(DATA, NODATA)
#      Else
#        [M]CRIDSYA(NBLIGA) = mess(205,10717,1) : # Non défini
#      Endif
#      # Fin MABON
#     Endif
    If TYPDATA<>"" Then
      Case TYPDATA
        When "AML" :
          [M]CRIDSYA(NBLIGA) = mess(val(DATA),NODATA,1)
          If [M]CRIDSYA(NBLIGA)="" & NODATA=314 Then : # Menu local Sexe, où Non défini n'existe pas
            [M]CRIDSYA(NBLIGA) = mess(205,10717,1) : # Non défini
          Endif
        When "ADI" :
          # FQ86506 - Si type ADI, NUMCRID n'a pas la valeur Non défini dans ses valeurs
          # On le définit donc à ZVIDE pour permettre le tri, mais on définit CRIDSYA pour l'homogénéité avec les autres critères d'affichage
          If DATA<>"ZVIDE" Then
            [M]CRIDSYA(NBLIGA) = func FIND_DESAXX(DATA, NODATA)
          Else
            [M]CRIDSYA(NBLIGA) = mess(205,10717,1) : # Non défini
          Endif
        # Issue X3-11720 - 2017-01-30 by BRBAN : Service table has the DES field in SERVICE table instead of ATEXTRA
        When "SERVICE"
          If DATA<>"ZVIDE" Then
            Read [F:SRV]SRV0=DATA
            If !fstat
              #ADNGO - 2017-11-29 - START
              If [F:SRV]LEG <> ""
              #[M]CRIDSYA(NBLIGA) = [F:SRV]DES
                Call LECTEXTRA([M]CRIDSYA(NBLIGA),TYPDATA,"DES",[F:SRV]LEG,DATA) From ATEXTRA
              Else
                 Call LECTEXTRA([M]CRIDSYA(NBLIGA),TYPDATA,"DES","",DATA) From ATEXTRA
              Endif
              #ADNGO - 2017-11-29 - END
            Else
              [M]CRIDSYA(NBLIGA) = mess(205,10717,1) : # Non défini
            Endif
          Else
            [M]CRIDSYA(NBLIGA) = mess(205,10717,1) : # Non défini
          Endif
        # -
        When Default :
          If DATA<>"ZVIDE" Then
            #Call LECTEXTRA([M]CRIDSYA(NBLIGA),TYPDATA,"DES",GDOSLEG(1),DATA) From ATEXTRA
            Call LECTEXTRA([M]CRIDSYA(NBLIGA),TYPDATA,"DES",GCURLEG,DATA) From ATEXTRA
          Else
            [M]CRIDSYA(NBLIGA) = mess(205,10717,1) : # Non défini
          Endif
      Endcase
    Endif
#ADNGO - 2017-07-03 - X3-29553 - END
    [M]NUMCRID(NBLIGA) = DATA
    NBLIGA += 1
  Endif
End NBLIGA

#**
#* Calcul des montants par dispositif pour une inscription
#*!
$CALC_AMT_FRT
#ADNGO - 2017-07-03 - X3-29553 - START
#Local Integer I, NBLIGA, TYPFRT, NBFRT, LIS_FRT(0..)
Local Integer I, NBLIGA, NBFRT
Local Char    LIS_FRT(type([F:HRCOR]DESTYPFRT2)-10)(0..)   : #US3924 106549
Local Char    TYPFRT(type([F:HRCOR]DESTYPFRT2)-10)         : #US3924 106549
#ADNGO - 2017-07-03 - X3-29553 - END
Local Decimal NBRHRREA

  Filter [F:HRCOR] Where TYPCOU=3 & SES=[F:INS]SES & REFNUM=[F:INS]REFNUM
  For [F:HRCOR]
    TYPFRT = [F:HRCOR]DESTYPFRT2
    #ADNGO - 2017-07-03 - X3-29553 - START
    #If TYPFRT=0 Then TYPFRT=9 Endif
    If TYPFRT="" Then TYPFRT="ZVIDE" Endif
    #ADNGO - 2017-07-03 - X3-29553 - END
    If !find(TYPFRT,LIS_FRT) Then LIS_FRT(NBFRT)=TYPFRT : NBFRT += 1 : Endif
    #ADNGO - 2017-07-03 - X3-29553 - START
    #NBLIGA = func FIND_DATA(num$(TYPFRT), "AML", 10455)
    NBLIGA = func FIND_DATA(TYPFRT, "HRSYSUSED", 0)
    #ADNGO - 2017-07-03 - X3-29553 - END
    [M]AMTREA(NBLIGA-1) += [F:HRCOR]CSTTOTIDV2
#    [M]NBINS(NBLIGA-1)  += 1
  Next
  Filter [F:HRCOR]
  # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants et d'heures
  If clalev([F:INJ2])=0 : Local File INSJOU [INJ2] : Endif
  For [F:INJ2] Where SES=[F:INS]SES & REFNUM=[F:INS]REFNUM
    NBRHRREA  += [F:INJ2]NBRHOUREA+[F:INJ2]NBRHOUREA2
  Next
  If NBFRT>0 Then
    For I=0 To dim([M]CRIDSYA)-1
      #ADNGO - 2017-07-03 - X3-29553 - START
      #If find(val([M]NUMCRID(I)), LIS_FRT)>0 Then
      #US3924 106549
      If find([M]NUMCRID(I), LIS_FRT)>0 Then
      #ADNGO - 2017-07-03 - X3-29553 - END
        [M]NBINS(I)     += 1/NBFRT
        [M]NBRPARREA(I) += 1/NBFRT
        [M]NBRHRREA(I)  += NBRHRREA/NBFRT
      Endif
      If [M]NUMCRID(I)="" Then Break : Endif
    Next
  Else
    For I=0 To dim([M]CRIDSYA)-1
      If [M]AMTBUDREF(I)<>0 Then NBFRT += 1: Endif
      If [M]NUMCRID(I)="" Then Break : Endif
    Next
    If NBFRT>0 Then
      For I=0 To dim([M]CRIDSYA)-1
        If [M]AMTBUDREF(I)<>0 Then
          [M]NBINS(I)     += 1/NBFRT
          [M]NBRPARREA(I) += 1/NBFRT
          [M]NBRHRREA(I)  += NBRHRREA/NBFRT
        Endif
        If [M]NUMCRID(I)="" Then Break : Endif
      Next
    Endif
  Endif
  # Fin MABON
  Call CALC_AMT_FOR_AMK(AMK, [F:INS]SES, IS2, IS3)
Return

Subprog CALC_AMT_FOR_AMK(AMK, SESSION, IS2, IS3)
Value    Char    AMK, SESSION
Variable Integer IS2, IS3

  If AMK="SBF2" & !find(SESSION,GTABSES2) Then
    GTABSES2(IS2)=[F:INS]SES : IS2 += 1
    # FQ73931 - MABON 19/05/11 - Ligne en trop en bas d'écran
#    Call CALC_AMT_FOR([F:INS]SES, [M]AMTFOR)
    Call CALC_AMT_FOR([F:INS]SES, GAMTFOR2)
  Endif
  If AMK="SBF3" & !find(SESSION,GTABSES3) Then
    GTABSES3(IS3)=[F:INS]SES : IS3 += 1
    # FQ73931 - MABON 19/05/11 - Ligne en trop en bas d'écran
#    Call CALC_AMT_FOR([F:INS]SES, [M]AMTFOR)
    Call CALC_AMT_FOR([F:INS]SES, GAMTFOR3)
    #ADNGO - 2017-07-03 - X3-29553 - START
    Call CALC_NBINS_FOR([F:INS]SES, GINSTOTFOR3)  #112795
    #ADNGO - 2017-07-03 - X3-29553 - END
  Endif
End

Funprog CALC_AMT_FOR(SESSION, MTTFOR)
Value    Char    SESSION
Variable Decimal MTTFOR

  # Calcul coûts formateurs
  Filter [F:HRCOR] Where TYPCOU=2 & SES=SESSION
  For [F:HRCOR]
    MTTFOR += [F:HRCOR]CSTTOTIDV2
  Next
  Filter [F:HRCOR]
End
#ADNGO - 2017-07-03 - X3-29553 - START
#112795
Funprog CALC_NBINS_FOR(SESSION, NBINSTOT)
Value    Char    SESSION
Variable Integer NBINSTOT

  If clalev([F:INS2])=0 : Local File INSCRIPT [INS2] : Endif

  # Calcul nombre d'inscrit

  Filter [F:INS2] Where SES=SESSION & STA<>3
  NBINSTOT+=rowcount([F:INS2])
  Filter [F:INS2]
End
#ADNGO - 2017-07-03 - X3-29553 - END
Subprog CALC_INDICE(AMK, IS2, IS3)
Value    Char AMK
Variable Integer IS2, IS3
Local    Integer I

  If AMK="SBF2" Then
    For I=0 To dim(GTABSES2)-1
      If GTABSES2(I)="" Then
        IS2=I : Break
      Endif
    Next
  Endif
  If AMK="SBF3" Then
    For I=0 To dim(GTABSES3)-1
      If GTABSES3(I)="" Then
        IS3=I : Break
      Endif
    Next
  Endif
End

#**
#* Récupération des montants par dispositif
#*!
Subprog CHARGE_AMT_FRT(AMK, TYPAMT)
Value Char    AMK, TYPAMT
#ADNGO - 2017-07-03 - X3-29553 - START
#Local Integer NBLIGA, TYPFRT, I, IS2, IS3, LIS_FRT(0..), NBFRT
Local Integer NBLIGA, I, IS2, IS3, NBFRT
Local Char    LIS_FRT(type([F:PLC]DESTYPFRT)-10)(0..)    : #US3924 106549
Local Char    TYPFRT(type([F:PLC]DESTYPFRT)-10)          : #US3924 106549
#ADNGO - 2017-07-03 - X3-29553 - END
Local Decimal NBRHR

  Call CALC_INDICE(AMK, IS2, IS3)

  If TYPAMT="PREV" Then
    NBFRT=0
    For [F:PLC]
      TYPFRT = [F:PLC]DESTYPFRT
      #ADNGO - 2017-07-03 - X3-29553 - START
      #If TYPFRT=0 Then TYPFRT=9 Endif
      #US3924 106549 Not needed anymore
      If TYPFRT="" Then TYPFRT = "ZVIDE" : Endif
      #ADNGO - 2017-07-03 - X3-29553 - END
      If !find(TYPFRT,LIS_FRT) Then LIS_FRT(NBFRT)=TYPFRT : NBFRT += 1 : Endif
      #ADNGO - 2017-07-03 - X3-29553 - START
      #NBLIGA = func FIND_DATA(num$(TYPFRT), "AML", 10455)
      # FQ106549 - Le menu local 455 est devenu une fonction
      NBLIGA = func FIND_DATA(TYPFRT, "HRSYSUSED", 0)
      #ADNGO - 2017-07-03 - X3-29553 - END
      [M]AMTBUDREF(NBLIGA-1) += [F:PLC]CSTTOTIDV*[F:PLF]NBREMP
    Next
    # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants et d'heures
    If clalev([F:STG])=0 : Local File STAGE [STG] : Endif
    Read [F:STG]STG0=[F:PLF]STG
    NBRHR = [F:STG]NBRHOUIPT*[F:PLF]NBREMP
    If NBFRT>0 Then
      For I=0 To dim([M]CRIDSYA)-1
        #ADNGO - 2017-07-03 - X3-29553 - START
        #If find(val([M]NUMCRID(I)), LIS_FRT)>0 Then
        #US3924 106549
        If find([M]NUMCRID(I), LIS_FRT)>0 Then
        #ADNGO - 2017-07-03 - X3-29553 - END
          [M]NBRPAR(I) += [F:PLF]NBREMP/NBFRT
          [M]NBRHR(I)  += NBRHR/NBFRT
        Endif
        If [M]NUMCRID(I)="" Then Break : Endif
      Next
    Endif
    # Fin MABON
  Endif
  If TYPAMT="READ" Then
    # FQ80895 - MABON 07/06/12 - On écarte les inscriptions refusées
#    For [F:INS]
    For [F:INS] Where STA<>3
    # Fin MABON
      Gosub CALC_AMT_FRT
    Next
  Endif
  If TYPAMT="REAI" Then
    Gosub CALC_AMT_FRT
  Endif
End

#**
#* Calcul des montants par type de financement pour une inscription
#*!
$CALC_AMT_FIN
Local Integer I, NBLIGA, NBFIN
#ADNGO - 2017-07-03 - X3-29553 - START
#Local Char    TYPFIN, LIS_FIN(20)(0..)
Local Char    TYPFIN(GLONADI), LIS_FIN(GLONADI)(0..) :#GLONADI US3924 106549
#ADNGO - 2017-07-03 - X3-29553 - END
Local Decimal NBRHRREA

  Filter [F:HRCOR] Where TYPCOU=3 & SES=[F:INS]SES & REFNUM=[F:INS]REFNUM
  For [F:HRCOR]
    TYPFIN = [F:HRCOR]TYPFIN2
    # FQ86506 - MABON 14/01/13 - Si type ADI, NUMCRID n'a pas la valeur Non défini dans ses valeurs
    # On le défini donc à ZVIDE pour permettre le tri
    If TYPFIN="" Then TYPFIN="ZVIDE" Endif
    If !find(TYPFIN,LIS_FIN) Then LIS_FIN(NBFIN)=TYPFIN : NBFIN += 1 : Endif
    NBLIGA = func FIND_DATA(TYPFIN, "ADI", 10462)
    [M]AMTREA(NBLIGA-1) += [F:HRCOR]CSTTOTIDV2
#    [M]NBINS(NBLIGA-1)  += 1
  Next
  Filter [F:HRCOR]
  # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants et d'heures
  If NBFIN>0 Then
    For I=0 To dim([M]CRIDSYA)-1
      If find([M]NUMCRID(I), LIS_FIN)>0 Then
        [M]NBINS(I) += 1/NBFIN
      Endif
      If [M]NUMCRID(I)="" Then Break : Endif
    Next
  Endif
  # Fin MABON
  Call CALC_AMT_FOR_AMK(AMK, [F:INS]SES, IS2, IS3)
Return

#**
#* Récupération des montants par type de financement
#*!
Subprog CHARGE_AMT_FIN(AMK, TYPAMT)
Value Char    AMK, TYPAMT
Local Integer NBLIGA, I, IS2, IS3
#ADNGO - 2017-07-03 - X3-29553 - START
#Local Char    TYPFIN
Local Char    TYPFIN(GLONADI)
#ADNGO - 2017-07-03 - X3-29553 - END
  Call CALC_INDICE(AMK, IS2, IS3)

  If TYPAMT="PREV" Then
    For [F:PLC]
      TYPFIN = [F:PLC]TYPFIN
      # FQ86506 - MABON 14/01/13 - Si type ADI, NUMCRID n'a pas la valeur Non défini dans ses valeurs
      # On le définit donc à ZVIDE pour permettre le tri
      If TYPFIN="" Then TYPFIN="ZVIDE" Endif
      NBLIGA = func FIND_DATA(TYPFIN, "ADI", 10462)
      [M]AMTBUDREF(NBLIGA-1) += [F:PLC]CSTTOTIDV*[F:PLF]NBREMP
    Next
  Endif
  If TYPAMT="READ" Then
    # FQ80895 - MABON 07/06/12 - On écarte les inscriptions refusées
#    For [F:INS]
    For [F:INS] Where STA<>3
    # Fin MABON
      Gosub CALC_AMT_FIN
    Next
  Endif
  If TYPAMT="REAI" Then
    Gosub CALC_AMT_FIN
  Endif
End

#**
#* Calcul des montants par catégorie d'action pour une inscription
#*!
$CALC_AMT_ACN
#ADNGO - 2017-07-03 - X3-29553 - START
#Local Integer NBLIGA, CATACN
Local Integer NBLIGA
Local Char    CATACN(type([F:INS]DESCATACN)-10)         : #US3924 106549
#ADNGO - 2017-07-03 - X3-29553 - END
  CATACN = [F:INS]DESCATACN
  #ADNGO - 2017-07-03 - X3-29553 - START
  #If CATACN=0 Then CATACN=4 Endif
  #NBLIGA = func FIND_DATA(num$(CATACN), "AML", 10453)

  #US3924 106549 Not needed anymore
  # FQ106549 - Le menu local 453 est devenu une fonction
  NBLIGA = func FIND_DATA(CATACN, "HRCATACTION", 0)
  #ADNGO - 2017-07-03 - X3-29553 - END
  Filter [F:HRCOR] Where TYPCOU=3 & SES=[F:INS]SES & REFNUM=[F:INS]REFNUM
  For [F:HRCOR]
    [M]AMTREA(NBLIGA-1) += [F:HRCOR]CSTTOTIDV2
  Next
  Filter [F:HRCOR]
  [M]NBINS(NBLIGA-1)  += 1
  # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants et d'heures
  [M]NBRPARREA(NBLIGA-1) += 1
  If clalev([F:INJ2])=0 : Local File INSJOU [INJ2] : Endif
  For [F:INJ2] Where SES=[F:INS]SES & REFNUM=[F:INS]REFNUM
    [M]NBRHRREA(NBLIGA-1)  += [F:INJ2]NBRHOUREA+[F:INJ2]NBRHOUREA2
  Next
  # Fin MABON
  Call CALC_AMT_FOR_AMK(AMK, [F:INS]SES, IS2, IS3)
Return

#**
#* Récupération des montants par catégorie d'action
#*!
Subprog CHARGE_AMT_ACN(AMK, TYPAMT)
Value Char    AMK, TYPAMT
#ADNGO - 2017-07-03 - X3-29553 - START
#Local Integer NBLIGA, CATACN, I, IS2, IS3
Local Integer NBLIGA, I, IS2, IS3
Local Char    CATACN(type([F:PLF]CATACN)-10)         : #US3924 106549
#ADNGO - 2017-07-03 - X3-29553 - END
  Call CALC_INDICE(AMK, IS2, IS3)

  If TYPAMT="PREV" Then
    # FQ71596 - MABON 15/02/11 - La catégorie d'action est maintenant présente dans le plan prévisionnel, donc plus
    # besoin d'aller la chercher dans la demande
#    If [F:PLF]DEMNUM<>"" Then
#      Call LECTURE("DEM", [F:PLF]DEMNUM, "") From CONTOBJ
#      CATACN = [F:DEM]DESCATACN
      CATACN = [F:PLF]CATACN
      #ADNGO - 2017-07-03 - X3-29553 - START
      #If CATACN=0 Then CATACN=4 Endif
      #NBLIGA = func FIND_DATA(num$(CATACN), "AML", 10453)

      #US3924 106549 Not needed anymore
      # FQ106549 - Le menu local 453 est devenu une fonction
      NBLIGA = func FIND_DATA(CATACN, "HRCATACTION", 0)
      #ADNGO - 2017-07-03 - X3-29553 - END
      For [F:PLC]
        [M]AMTBUDREF(NBLIGA-1) += [F:PLC]CSTTOTIDV*[F:PLF]NBREMP
      Next
      # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants
      [M]NBRPAR(NBLIGA-1)    += [F:PLF]NBREMP
      # FQ75457 - MABON 26/08/11 - Ajout du nombre d'heures
      If clalev([F:STG])=0 : Local File STAGE [STG] : Endif
      Read [F:STG]STG0=[F:PLF]STG
      [M]NBRHR(NBLIGA-1)     += [F:STG]NBRHOUIPT*[F:PLF]NBREMP
#    Endif
  Endif
  If TYPAMT="READ" Then
    # FQ80895 - MABON 07/06/12 - On écarte les inscriptions refusées
#    For [F:INS]
    For [F:INS] Where STA<>3
    # Fin MABON
      Gosub CALC_AMT_ACN
    Next
  Endif
  If TYPAMT="REAI" Then
    Gosub CALC_AMT_ACN
  Endif
End

#**
#* Calcul des montants par sexe pour une inscription
#*!
$CALC_AMT_SEX
Local Integer NBLIGA, SEXE

  Call LECTURE("EML", [F:INS]REFNUM, "") From CONTOBJ
  SEXE = [F:ID]SEX
  NBLIGA = func FIND_DATA(num$(SEXE), "AML", 10314)
  Filter [F:HRCOR] Where TYPCOU=3 & SES=[F:INS]SES & REFNUM=[F:INS]REFNUM
  For [F:HRCOR]
    [M]AMTREA(NBLIGA-1) += [F:HRCOR]CSTTOTIDV2
  Next
  Filter [F:HRCOR]
  [M]NBINS(NBLIGA-1)  += 1
  # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants et d'heures
  [M]NBRPARREA(NBLIGA-1) += 1
  If clalev([F:INJ2])=0 : Local File INSJOU [INJ2] : Endif
  For [F:INJ2] Where SES=[F:INS]SES & REFNUM=[F:INS]REFNUM
    [M]NBRHRREA(NBLIGA-1)  += [F:INJ2]NBRHOUREA+[F:INJ2]NBRHOUREA2
  Next
  # Fin MABON
  Call CALC_AMT_FOR_AMK(AMK, [F:INS]SES, IS2, IS3)
Return

#**
#* Récupération des montants par sexe
#*!
Subprog CHARGE_AMT_SEX(AMK, TYPAMT)
Value Char    AMK, TYPAMT
Local Integer NBLIGA, SEXE, I, IS2, IS3

  Call CALC_INDICE(AMK, IS2, IS3)

  If TYPAMT="PREV" Then
    SEXE = [F:PLF]SEX
    NBLIGA = func FIND_DATA(num$(SEXE), "AML", 10314)
    For [F:PLC]
      [M]AMTBUDREF(NBLIGA-1) += [F:PLC]CSTTOTIDV*[F:PLF]NBREMP
    Next
    # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants
    [M]NBRPAR(NBLIGA-1)    += [F:PLF]NBREMP
    # FQ75457 - MABON 26/08/11 - Ajout du nombre d'heures
    If clalev([F:STG])=0 : Local File STAGE [STG] : Endif
    Read [F:STG]STG0=[F:PLF]STG
    [M]NBRHR(NBLIGA-1)     += [F:STG]NBRHOUIPT*[F:PLF]NBREMP
  Endif
  If TYPAMT="READ" Then
    # FQ80895 - MABON 07/06/12 - On écarte les inscriptions refusées
#    For [F:INS]
    For [F:INS] Where STA<>3
    # Fin MABON
      Gosub CALC_AMT_SEX
    Next
  Endif
  If TYPAMT="REAI" Then
    Gosub CALC_AMT_SEX
  Endif
End

#**
#* Calcul des montants par âge pour une inscription
#*!
$CALC_AMT_AGE
Local Integer NBLIGA, AGEN
Local Date    DATBRN
#ADNGO - 2017-07-03 - X3-29553 - START
#Local Char    AGE
Local Char    AGE(GLONADI)
#ADNGO - 2017-07-03 - X3-29553 - END
  Call LECTURE("EML", [F:INS]REFNUM, "") From CONTOBJ
  DATBRN = [F:ID]DATBRN
  AGEN = year(date$)-year(DATBRN)
  Filter [F:ADI] Where NUMTAB=10454 Order By N1
  For [F:ADI]
    # FQ71671 - MABON 28/02/11 - Comparaison <= au lieu de < strict
    If AGEN<=[F:ADI]N1 Then AGE=[F:ADI]CODE : Break : Endif
  Next
  Filter [F:ADI]
  # FQ86506 - MABON 14/01/13 - Si type ADI, NUMCRID n'a pas la valeur Non défini dans ses valeurs
  # On le définit donc à ZVIDE pour permettre le tri
  If AGE="" Then AGE="ZVIDE" Endif
  NBLIGA = func FIND_DATA(AGE, "ADI", 10454)
  Filter [F:HRCOR] Where TYPCOU=3 & SES=[F:INS]SES & REFNUM=[F:INS]REFNUM
  For [F:HRCOR]
    [M]AMTREA(NBLIGA-1) += [F:HRCOR]CSTTOTIDV2
  Next
  Filter [F:HRCOR]
  [M]NBINS(NBLIGA-1)  += 1
  # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants et d'heures
  [M]NBRPARREA(NBLIGA-1) += 1
  If clalev([F:INJ2])=0 : Local File INSJOU [INJ2] : Endif
  For [F:INJ2] Where SES=[F:INS]SES & REFNUM=[F:INS]REFNUM
    [M]NBRHRREA(NBLIGA-1)  += [F:INJ2]NBRHOUREA+[F:INJ2]NBRHOUREA2
  Next
  # Fin MABON
  Call CALC_AMT_FOR_AMK(AMK, [F:INS]SES, IS2, IS3)
Return

#**
#* Récupération des montants par âge
#*!
Subprog CHARGE_AMT_AGE(AMK, TYPAMT)
Value Char    AMK, TYPAMT
Local Integer NBLIGA, I, IS2, IS3
#ADNGO - 2017-07-03 - X3-29553 - START
#Local Char    AGE
Local Char    AGE(GLONADI)
#ADNGO - 2017-07-03 - X3-29553 - END
  Call CALC_INDICE(AMK, IS2, IS3)

  If TYPAMT="PREV" Then
    AGE = [F:PLF]AGE
    # FQ86506 - MABON 14/01/13 - Si type ADI, NUMCRID n'a pas la valeur Non défini dans ses valeurs
    # On le définit donc à ZVIDE pour permettre le tri
    If AGE="" Then AGE="ZVIDE" Endif
    NBLIGA = func FIND_DATA(AGE, "ADI", 10454)
    For [F:PLC]
      [M]AMTBUDREF(NBLIGA-1) += [F:PLC]CSTTOTIDV*[F:PLF]NBREMP
    Next
    # FQ75457 - MABON 26/08/11 - Ajout du nombre de participants
    [M]NBRPAR(NBLIGA-1)    += [F:PLF]NBREMP
    # FQ75457 - MABON 26/08/11 - Ajout du nombre d'heures
    If clalev([F:STG])=0 : Local File STAGE [STG] : Endif
    Read [F:STG]STG0=[F:PLF]STG
    [M]NBRHR(NBLIGA-1)     += [F:STG]NBRHOUIPT*[F:PLF]NBREMP
  Endif
  If TYPAMT="READ" Then
    # FQ80895 - MABON 07/06/12 - On écarte les inscriptions refusées
#    For [F:INS]
    For [F:INS] Where STA<>3
    # Fin MABON
      Gosub CALC_AMT_AGE
    Next
  Endif
  If TYPAMT="REAI" Then
    Gosub CALC_AMT_AGE
  Endif
End

#**
