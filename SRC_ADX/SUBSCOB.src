#<AdxTL>@(#)8.0.0.0 $Revision$
#############################################################################
# SUBSCOB         Traitements PICKING    selon TRTACHPIC1/SUBPOHB/SUBPPI    #
# ------------------------------------------------------------------------- #
# Ce traitement sert à gérer                                                #
#               - le masque  écran "PPICSCO1 [PPI1]"                        #
# est utilisé par l'action SAIPECBS                                         #
#                                                                           #
#############################################################################
# POUR MEMO: Test ok sur la création de l'ordre de sous-traitance 13/02/2006
# RESTE A FAIRE: CONSOMMATION DES ENCOURS APRES GENERE_SCO et VALIDATION de l'écran
#############################################################################


$ACTION
#---------------------------------------#
# Action de saisie SAIPECBS (GTRAITE)   #
#---------------------------------------#
Case ACTION
 When "OUVRE"
  #--------------------------------------------------------------#
  # Avant la définition des boutons et l'ouverture de la fenêtre #
  #--------------------------------------------------------------#
  Case GACTION
   When "SAIPECBS"   : Gosub OUV_SAIPECBS
  Endcase
 When "TITRE"
  #-------------------------------------------#
  # Titre juste avant ouverture de la fenêtre #
  #-------------------------------------------#
  Case GACTION
   When "SAIPECBS"   : TIT=mess(42,195,1)
  Endcase
 When "DEBUT"
  #---------------------------------#
  # Après l'ouverture de la fenêtre #
  #---------------------------------#
  Case GACTION
   When "SAIPECBS"   : Gosub DEB_SAIPECBS
  Endcase
 When "OK"
  #--------------------------------#
  # Après l'exécution du bouton OK #
  #--------------------------------#
  Case GACTION
   When "SAIPECBS"   : Gosub OK_SAIPECBS
  Endcase
 When "ABA"
  #-------------------------------------#
  # Après l'exécution du bouton ABANDON #
  #-------------------------------------#
  Case GACTION
   When "SAIPECBS"   : Gosub ABA_SAIPECBS
  Endcase
 When "APRES_MODIF"
  #------------------------------------#
  # Après chaque modification de champ #
  #------------------------------------#
  Case GACTION
   When "SAIPECBS"   : REP="M"
  Endcase
 When "SETBOUT"
  #-------------------------------#
  # Grisage/dégrisage des boutons #
  #-------------------------------#
  Case GACTION
   When "SAIPECBS"   : Gosub SETB_SAIPECBS
  Endcase
 When "FINSAI"
  #------------------------------------------#
  # Avant de revenir à la fenêtre précédente #
  #------------------------------------------#
  Case GACTION
   When "SAIPECBS"   : Gosub FINSAI_SAIPECBS
  Endcase
 When "AB1_NBLIG"    : Gosub AB1_NBLIG : # Selon SUBPPI
 When "BB1_NBLIG"    : Gosub BB1_NBLIG : # Selon SUBPPI
Endcase
Return



#############################################################################
# PICKING : S/P de prise en compte des besoins d'article sous-traité        #
# ------------------------------------------------------------------------- #
#   WBPRNUM  : Numéro du fournisseur                                        #
#   WITMREF  : Référence de l'article                                       #
#   WBOMALT  : Alternative de sous-traitance                                #
#   WPOHFCY  : Site de commande                                             #
#   WPRHFCY  : Site de réception                                            #
#   WTRTPIC  : Code traitement  0 = Rien                                    #
#                               1 = Prise en compte des "EOS" et "SOF"      #
#                               2 = Prise en compte des "EOS" et "TWF"      #
#                                   dans le cas inter-sites                 #
#   WRETOUR  : Code retour = 0 Pas de besoin                                #
#   WRCPFCY  : Site de réception (Si la zone est renseignée alors les       #
#              besoins sont filtrés sur ce site)                            #
#   WSHIFCY  : Site d'expédition (Si la zone est renseignée alors les       #
#              besoins sont filtrés sur ce site)                            #
# ------------------------------------------------------------------------- #
# Appel de l'action SAIPECBS avec paramètres :                              #
#   PARAM(1) = WBPRNUM : Numéro du fournisseur                              #
#   PARAM(2) = WITMREF : Référence de l'article                             #
#   PARAM(3) = WPOHFCY : Site de commande                                   #
#   PARAM(4) = WPRHFCY : Site de réception                                  #
#   PARAM(5) = WTRTPIC : Code traitement (cf ci-dessus)                     #
#   PARAM(6) = WCODFNC : Code fonction ("SCO")                              #
#   PARAM(7) = WBOMALT : Alternative de sous-traitance   (entrée/sortie)    #
#   PARAM(8) = WSCONUM : Référence de l'ordre de sous-traitance (sortie)    #
#   PARAM(9) = WTOTQTY : Quantité                               (sortie)    #
#############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_SAIPECBS
Global Shortint GSCOTRACE
Local Char     WBPRNUM (GLONBPS) : WBPRNUM =PARAM(1)
Local Char     WITMREF (GLONITM) : WITMREF =PARAM(2)
Local Char     WPOHFCY (GLONFCY) : WPOHFCY =PARAM(3)
Local Char     WRCPFCY (GLONFCY) : WRCPFCY =PARAM(4)
Local Integer  WTRTPIC           : WTRTPIC =val(PARAM(5))
Local Char     WCODFNC(3)        : WCODFNC =PARAM(6)
Local Integer  WBOMALT           : WBOMALT =val(PARAM(7))
Local Char     ACHETEUR(GLONAUS) : ACHETEUR=""
#----- Variables locales -----#
Local Decimal  WRETQTY   ,WRETQTYSTU
Local Decimal  WPICQTYSTU,WPICQTYPUU
Local Decimal  WTOTQTYSTU,WTOTQTYPUU
Local Integer  WRETOUR
Local Date     WENDDAT
#Local Char     WRCPFCY(GLONFCY)
Local Char     WSHIFCY(GLONFCY)
Local Integer  WOK : WOK = 2
Local Char     CRITERES(250)
Local Integer  WLIGREF : WLIGREF=-1 : # ligne de reference tableau PPI1
Local Integer  WNBLIG  : WNBLIG =0  : # nb de besoins consommés

# Issue 79579 - 2012-01-27 by MUARN : PEC sur transacation
If [F:PTR]PICRETFLG = 1
  FIN = 1
  Return
Endif

#----- Si aucun besoin demandé, ne pas ouvrir fenêtre de picking -----#
If WTRTPIC=0 : WRETOUR=0 : FIN=1 : Return: Endif
Gosub DELETE_PWO

#----- Vérification existence des besoins dans le fichier encours -----#
Case WTRTPIC
  When 1 :               # encours SOF ou EOS
     CRITERES  ='( (WIPTYP=1  & WIPSTA=1) '
     CRITERES -='| (WIPTYP=13 & WIPSTA=3) )'
     CRITERES -=' & ITMREF=WITMREF '
  When 2 :               # encours TWF ou EOS (dans le cas inter-site)
     CRITERES  ='( (WIPTYP=12 & WIPSTA=1) '
     CRITERES -='| (WIPTYP=13 & WIPSTA=3) )'
     CRITERES -=' & ITMREF=WITMREF '
Endcase

# Issue 71069 - 2016-05-19 by MUARN : pjt
If [M:SCO1]PJT <> ""
  CRITERES -='& PJT=[M:SCO1]PJT'
Endif

# FQ 60123 GA 11/2009 filtrer les besoins sur le site de commande
If WRCPFCY=""  WRCPFCY=WPOHFCY Endif
#----- Filtre sur site de réception et site d'expédition -----#
If WRCPFCY<>""             CRITERES-='& STOFCY=WRCPFCY' : Endif
If WSHIFCY<>"" & WTRTPIC>6 CRITERES-='& (ORIFCY=WSHIFCY | WIPTYP<>7)' : Endif
#-----
WRETOUR = 0
Filter [ORD] Where evalue(CRITERES)
#GA Link [ORD] With [ITF] ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY As [ORF]
#GA For [ORF] Where evalue(CRITLNK)
For [ORD]
  If [F:ORD]RMNEXTQTY>0 & ([F:ORD]STRDAT<=WENDDAT | WENDDAT=[0/0/0])
    #----- Contrôle existence du site et appartenance à la même sté juridique -----#
    If [F:FCY]FCY<>[F:ORD]STOFCY
      Read [FCY] FCY0=[F:ORD]STOFCY : If fstat Raz [F:FCY] : Endif
    Endif
  # on a au moins une ligne à traiter ... Sortie Ok
    WRETOUR=1 : Break
  Endif
Next
Filter [ORD]
mkstat=1
If WRETOUR=0
  FIN=1
  # Issue 71069 - 2016-05-13 by MUARN : PJT si pas de besoin affichage message
  Call MESSAGE(mess(96,194,1)) From GESECRAN
  mkstat = 0
Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_SAIPECBS
#----- Ouverture fichier table des unités si nécessaire -----#
If clalev([F:TUN])=0 Local File TABUNIT [TUN] : Endif

#----- Lecture fournisseur si nécessaire -----#
Gosub READ_BPS From BPRLIB
If GOK<>1 : Return : Endif

#----- Lecture Article si nécessaire -----#
Gosub READ_ITM From ITMLIB
If GOK<>1 : Return : Endif

#----- Lecture Article/Site si nécessaire -----#
Local Char WFCY (GLONFCY) : WFCY = WPOHFCY
Gosub READ_ITF From ITMLIB
If GOK<>1 : Return : Endif

Raz [M:PPI1]
#----- Chargement des zones dans le masque -----#
If WENDDAT<>[0/0/0]
  [M:PPI1]WBORNE=WENDDAT
  [M:PPI1]MAXDAT=[M:PPI1]WBORNE
Endif
[M:PPI1]POHFCY = WPOHFCY    : # site de l'ordre de sous-traitance
[M:PPI1]BPSNUM = WBPRNUM
[M:PPI1]ITMREF = WITMREF
[M:PPI1]BOMALT = WBOMALT
[M:PPI1]ORDBUY = ACHETEUR
[M:PPI1]UOM    = [F:ITM]STU
[M:PPI1]PUU    = [F:ITM]PUU
[M:PPI1]STU    = [F:ITM]STU
[M:PPI1]TRTPIC = WTRTPIC
[M:PPI1]CHXDAT = 2
[M:PPI1]RCPFCY = WRCPFCY    : # site de réception
[M:PPI1]SHIFCY = WSHIFCY
[M:PPI1]WCODFNC= WCODFNC
# Issue 71069 - 2016-04-27 by MUARN : PJT
[M:PPI1]PJTDOC=[M:SCO1]PJT
#----- Affichage foreground -----#
Affzo [PPI1]
Return

#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_SAIPECBS
  If [M:PPI1]RETDAT = [0/0/0]
     GMESSAGE = mess(1,762,1) : # Saisie obligatoire (RETDAT)
     zonsui="[M:PPI1]RETDAT"
  ###GERR=1 : mkstat=1 : FIN=1 : Return
  Endif
  If [M:PPI1]TOTQTY=0  FIN=1 : Return : Endif
  If clalev([F:PWO])<>0
# ========== voir par la suite si on utilise ou non PWO ============
     Gosub GENERE_PWO
     If GOK=0 | mkstat Goto AB_PWO : Endif
  Endif
#
  Gosub CHARGE_SCO1
#
Return
#----- Abandon transaction en cas d'erreur d'écriture sur [F:PWO] ----#
$AB_PWO
If GOK=0  Call FSTA("PWO") From GLOCK : Endif
Rollback : mkstat=1
Call TEMPOFF From GESECRAN
FIN=1
Return

#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA_SAIPECBS
Gosub DEB_SAIPECBS
Raz REP
Return
#-------------------------------#
# Grisage/dégrisage des boutons #
#-------------------------------#
$SETB_SAIPECBS
If [M:PPI1]TOTQTY=0
  ETABOU(GVALI)=0 : # Désactivation OK
Else
  ETABOU(GVALI)=1 : # Activation OK
Endif
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_SAIPECBS
Return
$RETOUR_ITMREF
If WRETOUR=0 : GMESSAGE=WITMREF-mess(96,194,1)-"Code="-num$(WTRTPIC) : GERR=2 : Endif
mkstat=1
Return

#==================================================
# GENERE_PWO: lister dans PWO les encours consommés
#==================================================
$GENERE_PWO
#----- Exploitation du picking avec regroupement éventuel -----#
Call TEMPON ("O") From GESECRAN
Call DEBTRANS From GLOCK
Trbegin [PWO]
  WTOTQTYPUU=0
  WTOTQTYSTU=0 : # qté totale réajustée si pour certains besoins on a pris plus que RMNEXTQTY
  WRETQTYSTU=0 : # qté totale pickée
  For I=0 To [M:PPI1]NBLIG-1
    If [M:PPI1]PICQTY(I)>0 : Gosub WRITE_PWO : Endif
    If GOK=0 | mkstat : Break : Return : Endif
  Next I
Commit
Call TEMPOFF From GESECRAN
Return

#==================================================
# WRITE_PWO: lister dans PWO les encours consommés
#==================================================
$WRITE_PWO
     Raz [F:PWO]
     [F:PWO]PRONUM = adxuid(1)
     [F:PWO]CODFNC = WCODFNC
     [F:PWO]LINNUM = 1000           : # [M:SCO1]SCILIN
     [F:PWO]ITMREF = [M:PPI1]ITMREF
     [F:PWO]PUU    = [M:PPI1]PUU
     [F:PWO]STU    = [M:PPI1]STU
     [F:PWO]WIPTYP = [M:PPI1]WIPTYP(I)
     [F:PWO]WIPSTA = [M:PPI1]WIPSTA(I)
     [F:PWO]WIPNUM = [M:PPI1]WIPNUM(I)
     [F:PWO]PSDLIN = 0
    #----- Conversion qté prise en UA puis US -----#
     WRETQTY=min([M:PPI1]PICQTY(I),[M:PPI1]RMNEXTQTY(I))
     Call PCAL_QTY(WRETQTY,[M:PPI1]UOM,[F:PWO]QTYPUU,[F:PWO]PUU,
&                 [M:PPI1]ITMREF,[M:PPI1]BPSNUM,1,GBIDD2) From TRTACHQTE1
     Call PCAL_QTY(WRETQTY,[M:PPI1]UOM,[F:PWO]QTYSTU,[F:PWO]STU,
&                 [M:PPI1]ITMREF,[M:PPI1]BPSNUM,1,GBIDD2) From TRTACHQTE1
     If WRETQTY<>[M:PPI1]PICQTY(I)
        Call PCAL_QTY([M:PPI1]PICQTY(I),[M:PPI1]UOM,WPICQTYPUU,[F:PWO]PUU,
&                     [M:PPI1]ITMREF,[M:PPI1]BPSNUM,1,GBIDD2) From TRTACHQTE1
        Call PCAL_QTY([M:PPI1]PICQTY(I),[M:PPI1]UOM,WPICQTYSTU,[F:PWO]STU,
&                     [M:PPI1]ITMREF,[M:PPI1]BPSNUM,1,GBIDD2) From TRTACHQTE1
     Else
        WPICQTYPUU=[F:PWO]QTYPUU
        WPICQTYSTU=[F:PWO]QTYSTU
     Endif
     Write [PWO]
     If fstat : GOK=0 : Endif
     WTOTQTYPUU+=WPICQTYPUU
     WTOTQTYSTU+=WPICQTYSTU
     WRETQTYSTU+=[F:PWO]QTYSTU
    #----- Mise à jour date de réception -----#
     If [M:PPI1]RETDAT=[0/0/0]   # FQ 74639 GA 11/2011
        [M:PPI1]RETDAT=[M:PPI1]ENDDAT(I)
     Elsif [M:PPI1]RETDAT>[M:PPI1]ENDDAT(I) & [M:PPI1]ENDDAT(I)<>[0/0/0]
        [M:PPI1]RETDAT=[M:PPI1]ENDDAT(I)
     Endif
     If WLIGREF=-1 : WLIGREF=I : Endif
     WNBLIG+=1
Return

#==================================================
# DELETE_PWO: supprimer dans PWO les encours consommés
#==================================================
$DELETE_PWO
Call TEMPON ("O") From GESECRAN
Call DEBTRANS From GLOCK
Trbegin [PWO]
 Delete [PWO] Where PRONUM = adxuid(1) & CODFNC=WCODFNC
Commit
Call TEMPOFF From GESECRAN
Return

$CHARGE_SCO1

# Issue 86516 GA 12/2012
  PARAM(6) =num$([M:PPI1]BOMALT)    # Parametre en Entrée/Sortie, met à jour [M:SCO0]BOMALT
  #[M:SCO1]PRHFCY=[M:PPI1]RCPFCY : Affzo [M:SCO1]PRHFCY
  If [M:SCO0]BOMALT<>[M:PPI1]BOMALT
     [M:SCO0]BPRNUM=[M:PPI1]BPSNUM : Affzo [M:SCO0]BPRNUM # forcer l'affectation sinon la recherche des adresses est Ko
     Call AM_BOMALT([M:PPI1]BOMALT) From SUBSCO
     [M:SCO0]BOMALT=[M:PPI1]BOMALT : Affzo [M:SCO0]BOMALT
  Endif

# Issue 71069 - 2016-05-10 by MUARN : pjt
[M:SCO1]PJT=[M:PPI1]PJTDOC
Affzo [M:SCO1]PJT

  # Chargement de la qté dans [M:SCO1]
  # FQ 62179 GA 02/2010
  #Call AM_EXTQTY([M:PPI1]TOTQTY) From SUBSCO1
  Call PCAL_QTY([M:PPI1]TOTQTY,[M:PPI1]STU,WPICQTYPUU,[M:PPI1]PUU,
&               [M:PPI1]ITMREF,[M:PPI1]BPSNUM,1,GBIDD2) From TRTACHQTE1
  [M:SCO1]QTYPUU = WPICQTYPUU
  Call AM_QTYPUU(WPICQTYPUU) From SUBSCO1
  Affzo [M:SCO1]EXTQTY,QTYPUU

  # Issue X3-58607 - 2018-03-01 by MUARN : ne pas faire si la date besoin est dans le passé
  If [M:PPI1]RETDAT > [M:SCO1]RETDAT
    # FQ 77115 & FQ 74639 GA 11/2011 chargement de la date
    [M:SCO1]RETDAT = [M:PPI1]RETDAT
  Endif
  ###If [M:SCO1]LTI>0 & [M:SCO1]RETDAT<>[0/0/0] #  Calcul de la date : ORDDAT = RETDAT - LTI
  ###  Call CALC_DAT_FCY([M:SCO1]RETDAT,[M:SCO1]LTI,[M:SCO0]POHFCY,1,[M:SCO1]ORDDAT) From TRTACHDAT
  ###Endif
  # Issue X3-58607 - 2018-03-01 by MUARN : ne pas faire si la date besoin est dans le passé
  If [M:PPI1]RETDAT > [M:SCO3]OPEEND
    [M:SCO3]OPEEND = [M:PPI1]RETDAT
    Call AM_OPEEND([M:SCO3]OPEEND) From SUBSCO3
    [M:SCO1]ORDDAT = [M:SCO3]OPESTR
  Endif
  # End issue X3-58607
  Affzo [M:SCO1]RETDAT : Affzo [M:SCO1]ORDDAT
  Affzo [M:SCO3]OPEEND : Affzo [M:SCO3]OPESTR
Return

##########################################################################################


Subprog AM_MAXDAT(VALEUR)
#-------------------------------------------------------------#
# Après modif de la date borne : Raz et effacement des lignes #
#-------------------------------------------------------------#
Variable Date    VALEUR
Effzo [PPI1]10
Affzo [PPI1]TOTQTY
# Issue 79579 - 2012-01-26 by MUARN : ajout date fin
If VALEUR <> [0/0/0] : [M]MAXDATEND = eomonth(VALEUR) : Affzo [M]MAXDATEND : Endif
End

Subprog C_MAXDAT(VALEUR)
#-------------------------------------------#
# Dans le cas cdes ouvertes borne <= wborne #
#-------------------------------------------#
Variable Date    VALEUR
# Issue 79579 - 2012-01-27 by MUARN : ajout wborne non null
   If VALEUR>[M:PPI1]WBORNE & [M:PPI1]WBORNE <> [0/0/0]
      GMESSAGE=mess (97,194,1)-num$([M:PPI1]WBORNE) : mkstat=1
   Endif
End


Subprog AM_UOM(VALEUR)
#-------------------------------------------------------#
# Après modif de l'unité : Raz et effacement des lignes #
# et conversion quantité appel d'offre                  #
#-------------------------------------------------------#
Variable Char    VALEUR()
Effzo [PPI1]10
Affzo [PPI1]TOTQTY
End


Subprog AM_CHXDAT(VALEUR)
#-----------------------------------------------------------------------#
# Après modif du choix date de sélection : Raz et effacement des lignes #
#-----------------------------------------------------------------------#
Variable Integer VALEUR
Effzo [PPI1]10
Affzo [PPI1]TOTQTY
End


Subprog AS_NBLIG
#--------------------------------------------------------#
# Activation des boutons "Tri date-site" "Tri site-date" #
# et chargement des lignes si nécessaire                 #
#--------------------------------------------------------#
If [M:PPI1]NBLIG=0 Gosub CHARG_TABLEAU : Call IB_NBLIG : Endif
If [M:PPI1]TOTQTY=0
  Disable GSTAOK : GETABOU(GVALI)=0   : # Désactivation Ok
Else
  Enable  GSTAOK : GETABOU(GVALI)=1   : # Activation    Ok
Endif
If [M:PPI1]NBLIG=0 mkstat=1 : Endif
End

Subprog IB_NBLIG
#----------------------------#
# Initialisation des boutons #
#----------------------------#
Raz GBOUT1, GBOUT1, GBOUT3, GBOUT4, GBOUT5, GBOUT6
GBOUT2=mess(449,198,1) : # "Tri date début"
GBOUT3=mess(115,198,1) : # "Tri date fin"
GBOUT4=mess(116,198,1) : # "Tri par site"
If dim([M:PPI1]ENDDAT)<nolign End : Endif : # Maximum lignes atteint
If nolign = 0 End : Endif
End

$AB1_NBLIG
#-------------------------------------------------------#
# Avant exécution du bouton tunnel vers ???             #
#-------------------------------------------------------#
Return

$BB1_NBLIG
#-------------------------------------------------------#
# Après exécution du bouton tunnel vers ???             #
#-------------------------------------------------------#
Return

Subprog B2_NBLIG
#----------------------------#
# Tri par date début et site #
#----------------------------#
Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]STRDAT(indice),
&                                          [M:PPI1]STOFCY(indice),
&                                          [M:PPI1]VCRNUM(indice),
&                                          [M:PPI1]VCRLIN(indice)
Affzo [PPI1]10
End

Subprog B3_NBLIG
#--------------------------#
# Tri par date fin et site #
#--------------------------#
Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]ENDDAT(indice),
&                                          [M:PPI1]STOFCY(indice),
&                                          [M:PPI1]VCRNUM(indice),
&                                          [M:PPI1]VCRLIN(indice)
Affzo [PPI1]10
End

Subprog B4_NBLIG
#----------------------#
# Tri par site et date #
#----------------------#
Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]STOFCY(indice),
&                                          [M:PPI1]ENDDAT(indice),
&                                          [M:PPI1]VCRNUM(indice),
&                                          [M:PPI1]VCRLIN(indice)
Affzo [PPI1]10
End

Subprog APRES_NBLIG
#-----------------------------------------------------#
# Après ligne : Recalcul et affichage quantité totale #
#-----------------------------------------------------#
Affzo [PPI1]TOTQTY
End


Subprog IB_PICQTY
#----------------------------------------#
# Activation du bouton "Quantité totale" #
#----------------------------------------#
Raz GBOUT1, GBOUT1, GBOUT3, GBOUT4
If [M:PPI1]QTYFLG(nolign-1)=0  GBOUT1=mess(47,198,1) : Endif
End

Subprog B1_PICQTY(VALEUR)
#------------------------------------#
# Prise en compte totale de la ligne #
#------------------------------------#
Variable Decimal VALEUR
VALEUR=[M:PPI1]RMNEXTQTY(nolign-1) : mkstat=99
End

Subprog AV_PICQTY(VALEUR)
#-------------------------------------------------------#
# Avant zone quantité : Colorisation de la qté en rouge #
#    si elle fait partie de l'appel d'offre sélectionné #
#-------------------------------------------------------#
Variable Decimal VALEUR
If [M:PPI1]QTYFLG(nolign-1)=0
  pcolor=GCOUL(0) : # Noir
Else
  pcolor=GCOUL(1) : # Rouge  (3=Bleu)
Endif
End

Subprog AS_PICQTY(VALEUR)
#-----------------------------#
# Avant saisie de la quantité #
#-----------------------------#
Variable Decimal VALEUR
If [M:PPI1]QTYFLG(nolign-1)=1  mkstat=2 : Endif
# Issue 79579 - 2012-01-27 by MUARN : initialisation à la quantité besoin
If VALEUR = 0
  VALEUR = [M:PPI1]RMNEXTQTY(nolign-1)
  [M:PPI1]TOTQTY=sum([M:PPI1]PICQTY(0..[M:PPI1]NBLIG-1))
  Affzo [PPI1]TOTQTY,10
Endif
End

Subprog C_PICQTY(VALEUR)
#-------------------------#
# Contrôle quantité prise #
#-------------------------#
Variable Decimal VALEUR
#If VALEUR>[M:PPI1]RMNEXTQTY(nolign-1) mkstat=1 : Endif : # Contrôle supprimé !
# Issue 71069 - 2016-04-27 by MUARN : PJT
If [M:PPI1]PJTDOC<>[M:PPI1]WPJT(nolign-1) & [M:PPI1]TOTQTY>0 & VALEUR <> 0
  GMESSAGE=mess(1023,196,1) : mkstat=1
Endif
End

Subprog AM_PICQTY(VALEUR)
#--------------------------------------------#
# Après modif de la quantité prise en compte #
#--------------------------------------------#
Variable Decimal  VALEUR
If [M:PPI1]RCPFCY<>"" & [M:PPI1]STOFCY(nolign-1)<>[M:PPI1]RCPFCY & VALEUR<>0
  GERR=1 : GMESSAGE=mess(266,194,1) : mkstat=2 : End
Endif
[M:PPI1]PICQTY(nolign-1)=VALEUR
Raz GBIDI1
For I=0 To [M:PPI1]NBLIG-1
  If [M:PPI1]PICQTY(I)<>0
    WLIGREF = nolign-1      : # pour GENERE_SCO(TRTSCOPIC1)
    If [M:PPI1]STOFCY(I)=[M:PPI1]RCPFCY : GBIDI1=1 : Break : Endif
  Endif
Next I
If GBIDI1=0 Raz [M:PPI1]RCPFCY : Endif
If [M:PPI1]RCPFCY="" & VALEUR <> 0 : [M:PPI1]RCPFCY=[M:PPI1]STOFCY(nolign-1) : Endif
[M:PPI1]TOTQTY=sum([M:PPI1]PICQTY(0..[M:PPI1]NBLIG-1))

# Issue 71069 - 2016-04-27 by MUARN : PJT
If [M:PPI1]WPJT(nolign-1)<>""
  [M:PPI1]PJTDOC=[M:PPI1]WPJT(nolign-1)
  Affzo [PPI1]PJTDOC
Endif

Affzo [PPI1]TOTQTY
End


Subprog AM_BOMALT(VALEUR)
Variable Decimal VALEUR
Local    Date    WDAT
Local    Integer WBOMALT

WBOMALT = VALEUR
If [M:PPI1]ITMREF <> [F:BOH]ITMREF | WBOMALT <> [F:BOH]BOMALT | [F:BOH]BOMALTTYP <> 3
  Read [BOH]BOH0=[M:PPI1]ITMREF;WBOMALT;3
  If fstat : mkstat=1 : Endif
Endif
If [F:TBO]BOMALT<>WBOMALT  | [F:TBO]BOMALTTYP <> 3
  Read [TBO]TBO0=3;WBOMALT
  If fstat : mkstat=1 : Endif
Endif
# Issue 86439 GA 12/2012 l'alternative provoque changt site
If [F:TBO]FCY<>""
  [M:PPI1]RCPFCY=[F:TBO]FCY : Affzo [M:PPI1]RCPFCY
Endif
If [M:PPI1]RETDAT<> [0/0/0]
   WDAT = [M:PPI1]RETDAT
Else
   WDAT = date$
Endif
Call CONTSCONOM([M:PPI1]RCPFCY, WBOMALT, WDAT, 1) From SCOLIB

End

Subprog AS_BOMALT(VALEUR)
Variable Decimal VALEUR
Local    Integer WBOMALT
If [M:PPI1]ITMREF <> "" and VALEUR = 0
 # on cherche à proposer une alt de nomenc lorsque c'est possible
   Call FIND_BOMALT([M:PPI1]ITMREF,[M:PPI1]BPSNUM,WBOMALT) From SCOLIB
   VALEUR = WBOMALT
Endif
End

######################################################################################



$CHARG_TABLEAU
#-------------------------------#
# Chargement tableau des lignes #
#-------------------------------#
Call TEMPON("O") From GESECRAN : # Opération en cours ...
Local Date     BORNE
Local Char     CRITERES(250)
Local Char     CRITERES1(250) #issue 79579 fenetre criteres muarn 30/01/2012
Local Char     WBPRNUM(GLONBPS), WITMREF(GLONITM), WPOHFCY(GLONFCY)
Local Char     ABREV(4), XZSCRITERES(250), XZSCRITLNK(70), CRITSUP(240), CRITLNK2(240)
Local Char     CRITBETPOH(240), WNOMSITE(6)
Local Shortint I, SAVXZSI, TRAIT, TYPFILT
Local Decimal  RMNQTY
#-----
If !clalev([F:BPR2])  Local File BPARTNER  [BPR2] : Endif
#-----
WBPRNUM=[M:PPI1]BPSNUM
WITMREF=[M:PPI1]ITMREF
WPOHFCY=[M:PPI1]POHFCY
#----------------------------------------------------#
# Chargement tableau à partir du fichier des encours #
#----------------------------------------------------#
Case [M:PPI1]TRTPIC
  When 1 :               # encours SOF ou EOS
     CRITERES  ='( (WIPTYP=1  & WIPSTA=1) '
     CRITERES -='| (WIPTYP=13 & WIPSTA=3) )'
     CRITERES -=' & ITMREF=WITMREF '
  When 2 :               # encours TWF ou EOS (dans le cas inter-site)
     CRITERES  ='( (WIPTYP=12 & WIPSTA=1) '
     CRITERES -='| (WIPTYP=13 & WIPSTA=3) )'
     CRITERES -=' & ITMREF=WITMREF '
Endcase
#----- Filtre sur site de réception et site d'expédition -----#
If [M:PPI1]RCPFCY<>""          CRITERES-='& STOFCY=[M:PPI1]RCPFCY' : Endif
If [M:PPI1]SHIFCY<>"" & TRTPIC>6 CRITERES-='& (ORIFCY=[M:PPI1]SHIFCY | WIPTYP<>7)' : Endif
#----- Filtre sur date borne -----#
# Issue 79579 - 2012-01-26 by MUARN : ajout date fin
If [M:PPI1]MAXDAT <> [0/0/0]
  If [M:PPI1]CHXDAT=1
    CRITERES +=' & STRDAT>=[M:PPI1]MAXDAT'
  Else
    CRITERES +=' & ENDDAT>=[M:PPI1]MAXDAT'
  Endif
Endif
If [M:PPI1]MAXDATEND <> [0/0/0]
  If [M:PPI1]CHXDAT=1
    CRITERES +=' & STRDAT<=[M:PPI1]MAXDATEND'
  Else
    CRITERES +=' & ENDDAT<=[M:PPI1]MAXDATEND'
  Endif
Endif

# Issue 79579 - 2012-01-30 by MUARN : ajout fenêtre critères
CRITERES1  = "1=1"

# Issue 71069 - 2016-05-10 by MUARN : PJT
If [M:PPI1]PJTDOC <>""
  CRITERES1 += " & (PJT=[M:PPI1]PJTDOC)"
Else
  # affaire
  If [M:PPI1]PJTSTR <> ""
     CRITERES1 += " & PJT>=[M:PPI1]PJTSTR"             # borne début affaire
  Endif
  If [M:PPI1]PJTEND <> ""
     CRITERES1 += " & PJT<=[M:PPI1]PJTEND"             # borne fin   affaire
  Endif
Endif

# pièce
If [M:PPI1]VCRNUMSTR <> ""
   CRITERES1 += " & VCRNUM>=[M:PPI1]VCRNUMSTR"         # borne début pièce
Endif
If [M:PPI1] VCRNUMEND <> ""
   CRITERES1 += " & VCRNUM<=[M:PPI1]VCRNUMEND"         # borne fin   pièce
Endif
# Pièce origine
If [M:PPI1]VCRORISTR <> ""
   CRITERES1 +=" & VCRNUMORI>=[M:PPI1]VCRORISTR"       # borne début pièce origine
Endif
If [M:PPI1]VCRORIEND <>""
   CRITERES1 += " & VCRNUMORI <=[M:PPI1]VCRORIEND"     # borne fin pièce origine
Endif

I=0
# Issue 79579 - 2012-01-30 by MUARN : ajout fenetre criteres
Filter [ORD] Where evalue(CRITERES) & evalue(CRITERES1)
For [ORD]
  If [F:ORD]RMNEXTQTY>0
    #----- Contrôle existence du site et appartenance à la même sté juridique -----#
    If [F:FCY]FCY<>[F:ORD]STOFCY
      Read [FCY] FCY0=[F:ORD]STOFCY : If fstat Raz [F:FCY] : Endif
    Endif
    Gosub CHARG_LIG_ORD
  Endif
  If I>dim([M:PPI1]ENDDAT)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
Next
Filter [ORD]
$FIN_CHARG_TABLEAU
[M:PPI1]NBLIG=I
[M:PPI1]TOTQTY=sum([M:PPI1]PICQTY(0..[M:PPI1]NBLIG-1))

# Issue 79579 - 2013-06-07 by MUARN : tri tableau
If [M:PPI1]NBLIG <> 0
  Case [M:PPI1]SRTCOD
      When 1: Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]STOFCY(indice),[M:PPI1]STRDAT(indice),[M:PPI1]VCRNUM(indice)
      When 2: Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]ITMREF(indice),[M:PPI1]STRDAT(indice),[M:PPI1]VCRNUM(indice)
      When 3: Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]WIPTYPSTA(indice),[M:PPI1]STRDAT(indice),[M:PPI1]VCRNUM(indice)
      When 4: Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]VCRTYP(indice),[M:PPI1]STRDAT(indice),[M:PPI1]VCRNUM(indice)
      When 5: Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]STRDAT(indice),[M:PPI1]VCRNUM(indice)
      When 6: Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]REQDAT(indice),[M:PPI1]VCRNUM(indice)
      When 7: Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]BPRNUM(indice),[M:PPI1]VCRNUM(indice)
  Endcase
Endif

Affzo [PPI1]
Enable GSTAFIN : GETABOU(GABAN)=1 : # Activation Abandon
Call TEMPOFF From GESECRAN
Return


#----- Chargement ligne a partir du fichier des encours -----#
$CHARG_LIG_ORD
#GA Gosub POINT_ORDLEC From TRTACHMGT1 : # Appel point d'entrée ORDLEC
If clalev ([F:PWO])>0
  For [PWO] PWO0 Where PRONUM=adxuid(1)
&                    & CODFNC=[M:PPI1]WCODFNC
&                    & WIPTYP=[F:ORD]WIPTYP
&                    & WIPNUM=[F:ORD]WIPNUM
&                    & ITMREF=[F:ORD]ITMREF
    [F:ORD]RMNEXTQTY-=[F:PWO]QTYSTU
  Next
Endif
If [F:ITF]ITMREF<>[F:ORD]ITMREF | [F:ITF]STOFCY <> [F:ORD]STOFCY
  Read [ITF]ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY : If fstat Raz [F:ITF] : Endif
Endif
RMNQTY=[F:ORD]RMNEXTQTY
If RMNQTY<=0 Return : Endif
[M:PPI1]WIPTYP(I)   =[F:ORD]WIPTYP
[M:PPI1]WIPSTA(I)   =[F:ORD]WIPSTA
[M:PPI1]WIPNUM(I)   =[F:ORD]WIPNUM
[M:PPI1]STRDAT(I)   =[F:ORD]STRDAT
[M:PPI1]ENDDAT(I)   =[F:ORD]ENDDAT
[M:PPI1]STOFCY(I)   =[F:ORD]STOFCY
If [M:PPI1]WIPTYP=7
   [M:PPI1]ORIFCY(I) =[F:ORD]ORIFCY
Else
   [M:PPI1]ORIFCY(I) =""
Endif
[M:PPI1]BUY(I)      =[F:ITF]BUY
[M:PPI1]BPRNUM(I)   =[F:ORD]BPRNUM
[M:PPI1]WPJT(I)     =[F:ORD]PJT
If dim([M:PPI1]ORI)>0
  [M:PPI1]ORI(I)    =[F:ORD]ORI : # Origine du besoin
Endif
If ([F:ORD]WIPTYP=2 & [F:ORD]WIPSTA=2) | ([F:ORD]WIPTYP=4 & [F:ORD]WIPSTA=1)
  [M:PPI1]VCRNUM(I)=[F:ORD]VCRNUM
  [M:PPI1]VCRLIN(I)=[F:ORD]VCRLIN
Else
  Raz [M:PPI1]VCRNUM(I), [M:PPI1]VCRLIN(I)
Endif
#----- Indicateur inter-sociétés -----#
If [F:ORD]WIPTYP=2 & [F:ORD]BPRNUM<>""
  If [F:BPR2]BPRNUM<>[F:ORD]BPRNUM
    Read [BPR2] BPR0=[F:ORD]BPRNUM : If fstat  Raz [F:BPR2] : Endif
  Endif
  If [F:BPR2]FCY<>""
     [M:PPI1]WIPISO(I)=func TRTACHISO1.ISOFLG([F:BPR2]FCY,[F:ORD]STOFCY)
  Else
     [M:PPI1]WIPISO(I)=1
  Endif
Else
  [M:PPI1]WIPISO(I)=1
Endif
#-----
Call PCAL_QTY(RMNQTY,[F:ITM]STU,[M:PPI1]RMNEXTQTY(I),[M:PPI1]UOM,
&             [F:ITM]ITMREF,[F:BPS]BPSNUM,1,GBIDD1) From TRTACHQTE1
#-----
$FIN_CHARG_LIG
# Les encours SO* comportent le code client dans BPRNUM
# on ne peut pas vérifier les lignes cohérentes avec le fournisseur choisi
   # Issue 79579 - 2012-01-27 by MUARN : quantité prise à zéro par défaut et initialisation champs
   #[M:PPI1]PICQTY(I)=[M:PPI1]RMNEXTQTY(I)
   [M:PPI1]PICQTY(I)=0
   [M:PPI1]REQDAT(I)=[F:ORD]MRPDAT
   If [M:PPI1]REQDAT(I)=[0/0/0] : [M:PPI1]REQDAT(I) = [M:PPI1]ENDDAT(I) Endif
   [M:PPI1]WIPTYPSTA(I)  = mess([F:ORD]WIPTYP,341,1) + mess([F:ORD]WIPSTA,342,1)

  #-- Le site de réception est unique
   If [M:PPI1]RCPFCY=""
      [M:PPI1]RCPFCY=[M:PPI1]STOFCY(I)
   Elsif [M:PPI1]RCPFCY<>[M:PPI1]STOFCY(I)
     Raz [M:PPI1]PICQTY(I)
   Endif
# Libellé correspondant au type d'encours SOF, EOS, ...
[M:PPI1]WIPCOD(I)=mess([F:ORD]WIPTYP,341,1) + mess([F:ORD]WIPSTA,342,1)
#-----
I+=1
Return




######################################################################################
#-----------------------------------#
# Sélection d'une ligne de commande #
#-----------------------------------#
$PICKE_CDE
Local Integer WRETOUR

# cela ne devrait pas se produire ...
If [F:POQ]VCRTYPORI<>36 OK=0 : Return : Endif

# on est déjà sur cet ordre de sous-traitance => rien à faire ...
If [F:POQ]VCRNUMORI=[M:SCO0]SCONUM : Return : Endif

WNUM=[F:POQ]POHNUM : WPOQLNK=[F:POQ]POQLNK
Read [POQ] POQ3=WNUM;WPOQLNK  : If fstat Raz [F:POQ] : Endif
If WDEBPICK | [F:POH]POHNUM<>[F:POQ]POHNUM
  Read [POH] POH0=[F:POQ]POHNUM : If fstat Raz [F:POH] : Endif
Endif
If WDEBPICK | [F:ITM]ITMREF<>[F:POQ]ITMREF
  Read [ITM] ITM0=[F:POQ]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
If WDEBPICK | [F:ITP]ITMREF<>[F:POQ]ITMREF | [F:ITP]BPSNUM<>[F:POQ]BPSNUM
  Read [ITP] ITP0=[F:POQ]ITMREF;[F:POQ]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
If WDEBPICK | [F:ITF]ITMREF<>[F:POQ]ITMREF | [F:ITF]STOFCY<>[M:SCO0]POHFCY
  Read [ITF] ITF0=[F:POQ]ITMREF;[M:SCO0]POHFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
WDEBPICK=0
#-----
If [F:POH]POHNUM="" & [F:ITM]ITMREF=""
  Call RSTA("XPOQ",WNUM-WPOQLNK) From GLOCK
  OK=0 : Return
Endif
If !evalue(FILGAUSUP)  OK=0 : Return : Endif

Read [F:SCO]SCO0=[F:POQ]VCRNUMORI
If fstat : OK=0 : Return : Endif

# Chargement de l'ordre de sous-traitance
[M:SCO0] = [F:SCO]
Gosub LIENS From SUBSCOA

#PICFLG=1
Return

#-------------------------------------#
# Déselection d'une ligne de commande #
#-------------------------------------#
$DEPICK_CDE
Return

# Issue 79579 - 2012-01-26 by MUARN : ajout bouton tout inclure en PEC
Subprog INCLURE
#--------------------------------------------#
# Chargement des qtés prises par les besoins #
#--------------------------------------------#
Local Decimal WQTEUA
For I=0 To [M:PPI1]NBLIG-1
  If [M:PPI1]RMNEXTQTY(I) <>0
    # Issue 71069 - 2016-05-10 by MUARN : PJT
    If I=0 & [M:PPI1]TOTQTY=0
      [M:PPI1]PJTDOC=[M:PPI1]WPJT(I)
    Elsif [M:PPI1]PJTDOC<>[M:PPI1]WPJT(I)
      Goto NEXT_I
    Endif
    If [M:PPI1]RCPFCY<>"" & [M:PPI1]STOFCY(I)<>[M:PPI1]RCPFCY
      GERR=1 : GMESSAGE=mess(266,194,1) : mkstat=2 : End
    Else
      [M:PPI1]PICQTY(I)= [M:PPI1]RMNEXTQTY(I)
    Endif
  Endif
$NEXT_I # Issue 71069 - 2016-05-10 by MUARN : PJT
Next I
[M:PPI1]TOTQTY=sum([M:PPI1]PICQTY(0..[M:PPI1]NBLIG-1))
Affzo [PPI1]TOTQTY,10
Enable GSTAFIN
End

# Issue 79579 - 2012-01-26 by MUARN : ajout bouton tout exclure en PEC
Subprog EXCLURE
#------------------------------------#
# Raz de toutes les quantités prises #
#------------------------------------#
Raz [M:PPI1]TOTQTY, [M:PPI1]PICQTY
# Issue 71069 - 2016-05-10 by MUARN : PJT
If [M:SCO1]PJT = "" : Raz [M:PPI1]PJTDOC : Endif
Affzo [PPI1]TOTQTY, 10
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran PPICSCO1) 26/01/2012 15:30:00 (MUARN)
## Issue 79579 - 2012-01-26 by MUARN : ajout date fin
######################################################################################
Subprog C_MAXDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]MAXDAT : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

Subprog AM_MAXDATEND(VALEUR)
Variable Date    VALEUR
Effzo [PPI1]10 : Raz [M:PPI1]TOTQTY
End

Subprog AM_PJTSTR(VALEUR)
Variable Char    VALEUR()
If [M]PJTEND = ""     : [M]PJTEND = VALEUR : Affzo [M]PJTEND : Endif
If [M]PJTEND < VALEUR : [M]PJTEND = VALEUR : Affzo [M]PJTEND : Endif
End

Subprog AS_VCRNUMSTR(VALEUR)
Variable Char    VALEUR()
[M]ORDFILTER = "1=1"
If [M:PPI1]ITMREF <> "" : [M]ORDFILTER += "&ITMREF>=[M:PPI1]ITMREF" : Endif
If [M:PPI1]BPSNUM <> "" : [M]ORDFILTER += "&BPRNUM>=[M:PPI1]BPSNUM" : Endif
If [M]PJTSTR    <> "" : [M]ORDFILTER += "&PJT>=[M]PJTSTR"       : Endif
If [M]PJTEND    <> "" : [M]ORDFILTER += "&PJT<=[M]PJTEND"       : Endif
End

Subprog AM_VCRNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M]VCRNUMEND = ""     : [M]VCRNUMEND = VALEUR : Affzo [M]VCRNUMEND : Endif
If [M]VCRNUMEND < VALEUR : [M]VCRNUMEND = VALEUR : Affzo [M]VCRNUMEND : Endif
End

Subprog AS_VCRNUMEND(VALEUR)
Variable Char    VALEUR()
[M]ORDFILTER = "1=1"
If [M:PPI1]ITMREF <> "" : [M]ORDFILTER += "&ITMREF>=[M:PPI1]ITMREF" : Endif
If [M:PPI1]BPSNUM <> "" : [M]ORDFILTER += "&BPRNUM>=[M:PPI1]BPSNUM" : Endif
If [M]PJTSTR    <> "" : [M]ORDFILTER += "&PJT>=[M]PJTSTR"       : Endif
If [M]PJTEND    <> "" : [M]ORDFILTER += "&PJT<=[M]PJTEND"       : Endif
End

Subprog AS_VCRORISTR(VALEUR)
Variable Char    VALEUR()
[M]ORDFILTER = "1=1"
If [M:PPI1]ITMREF <> "" : [M]ORDFILTER += "&ITMREF>=[M:PPI1]ITMREF" : Endif
If [M]PJTSTR    <> "" : [M]ORDFILTER += "&PJT>=[M]PJTSTR"       : Endif
If [M]PJTEND    <> "" : [M]ORDFILTER += "&PJT<=[M]PJTEND"       : Endif
End

Subprog AM_VCRORISTR(VALEUR)
Variable Char    VALEUR()
If [M]VCRORIEND ="" : [M]VCRORIEND= VALEUR : Affzo [M]VCRORIEND : Endif
If [M]VCRORIEND< VALEUR : [M]VCRORIEND = VALEUR : Affzo [M]VCRORIEND : Endif
End

Subprog AS_VCRORIEND(VALEUR)
Variable Char    VALEUR()
[M]ORDFILTER = "1=1"
If [M:PPI1]ITMREF <> "" : [M]ORDFILTER += "&ITMREF>=[M:PPI1]ITMREF" : Endif
If [M]PJTSTR    <> "" : [M]ORDFILTER += "&PJT>=[M]PJTSTR"       : Endif
If [M]PJTEND    <> "" : [M]ORDFILTER += "&PJT<=[M]PJTEND"       : Endif
End

######################################################################################

# Issue 71069 - 2016-04-27 by MUARN : PJT
Subprog AS_PJTSTR(VALEUR)
Variable Char    VALEUR()
If [M:PPI1]PJTDOC<>""
  mkstat=2
Endif
End

Subprog AS_PJTEND(VALEUR)
Variable Char    VALEUR()
If [M:PPI1]PJTDOC<>""
  mkstat=2
Endif
End
# End issue 71069

