# Mask Management TCI1
######################################################################################
## Section automatically added (screen ZBAS1) 03/15/2013 20:22:41 (BESPR)
## Screen was changed to TCI1 on 3/21/13
## Section automatically added (screen TCI1) 03/21/2013 17:16:19 (BESPR)
######################################################################################
#    Process Name:    SUBTCI - Intercompany account mapping  SAM #87307
#
#    Authors:         BeSpr   Mar 15-21, 2013
#
#    Modifications:
#                     BeSpr   May 03-04, 2013   Added Control and BP fields
#                     BeSpr   Jun 12, 2013      Added Exceptional account checking
######################################################################################

$ACTION
Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "FERME"       : Gosub FERME
  When Default
Endcase
Return

$OUVRE

If clalev([F:CPY]) = 0  : Local File  COMPANY   [CPY]  : Endif
If clalev([F:GCM]) = 0  : Local File  GACM      [GCM]  : Endif
If clalev([F:LED]) = 0  : Local File  GLED      [LED]  : Endif
If clalev([F:COA]) = 0  : Local File  GCOA      [COA]  : Endif
If clalev([F:GAC]) = 0  : Local File  GACCOUNT  [GAC]  : Endif

Return

####################################################################################
$FERME

# Clear the filter on the table before exiting
Filter [GAC]

Return

####################################################################################
$SET_ACCOUNTS_SRC

If [M]COASRC<>[F:COA]COA
  Filter [GAC]
  Filter [GAC] Where [F:GAC]COA = [M]COASRC
Endif

Return

####################################################################################
$SET_ACCOUNTS_TGR

If [M]COATGR<>[F:COA]COA
  Filter [GAC]
  Filter [GAC] Where [F:GAC]COA = [M]COATGR
Endif

Return

####################################################################################
####################################################################################
# Control for Source company
Subprog C_CPYSRC(VALEUR)
Variable Char    VALEUR()
Local Char TMPCOA
Local Integer TMPLEDT

Call LECTURE("CPY",VALEUR,"") From CONTOBJ
If mkstat : End : Endif

If VALEUR<>[M]CPYSRC
  Call CTLLEDCOA(VALEUR,TMPCOA,TMPLEDT)
  If TMPCOA <> [M]COASRC
    # Clear the Source GL Accounts if the COA has changed
    Effzo [M] ACCSRCDEB, ACCSRCCDT, ACCDES1, ACCDES2, SACSRCDEB, SACSRCCDT, BPRTGR
  Endif
  [M]COASRC = TMPCOA
  [M]LEDTYPSRC = TMPLEDT
  Affzo [M]
Endif

End


Subprog AM_CPYSRC(VALEUR)
Variable Char    VALEUR()
Call RESET_ACC_COA([M]COASRC,"S")
End

####################################################################################
# Control for Target company
Subprog C_CPYTGR(VALEUR)
Variable Char    VALEUR()
Local Char TMPCOA
Local Integer TMPLEDT

If VALEUR=[M]CPYSRC
 # Duplicate message - Target cannot be the same as the Source
 GMESSAGE = mess(5,37,1) # or is the standard 'invalid' mess(83,123,1)
 mkstat = 2 : End
Endif

Call LECTURE("CPY",VALEUR,"") From CONTOBJ
If mkstat : End : Endif

If VALEUR<>[M]CPYTGR
  Call CTLLEDCOA(VALEUR,TMPCOA,TMPLEDT)
  If TMPCOA <> [M]COATGR
    # Clear the Target GL Accounts if the COA has changed
    Effzo ACCTGRDEB, ACCTGRCDT, ACCDES3, ACCDES4, SACTGRDEB, SACTGRCDT, BPRSRC
  Endif
  [M]COATGR = TMPCOA
  [M]LEDTYPTGR = TMPLEDT
  Affzo [M]
Endif

End


Subprog AM_CPYTGR(VALEUR)
Variable Char    VALEUR()
Call RESET_ACC_COA([M]COATGR,"T")
End

####################################################################################
# Get the Chart of accounts from the Accounting Core and Main general ledger type Ledger
Subprog CTLLEDCOA(VALEUR,TMPCOA,TMPLEDT)
Variable Char VALEUR()
Variable Char TMPCOA
Variable Integer TMPLEDT

If clalev([CPY]) = 0 : Local File COMPANY  [CPY] : Endif
If clalev([GCM]) = 0 : Local File GACM     [GCM] : Endif
If clalev([LED]) = 0 : Local File GLED     [LED] : Endif

Read [F:CPY]CPY0 = VALEUR
Read [F:GCM]GCM0 = [F:CPY]ACM
# Finding the COA based upon the main general ledger type and sending back that COA and ledger type
Read [LED]LED0 = [F:GCM]LED([F:GCM]GENLEDTYP-1)
If !fstat
  TMPCOA = [F:LED]COA
  TMPLEDT = [F:GCM]GENLEDTYP
Else
  mkstat = 2 : End
Endif

End

######################################################################################
# Need to read GAC for the correct COA and reset the COA in case it has changed
Subprog RESET_ACC_COA(TMPCOA,TMPTYP)
Variable Char   TMPCOA
Value Char      TMPTYP

If TMPTYP="S" : Gosub SET_ACCOUNTS_SRC  : Endif
If TMPTYP="T" : Gosub SET_ACCOUNTS_TGR  : Endif
Read [F:COA]COA0 = TMPCOA
Call LECTURE("COA",TMPCOA,"") From CONTOBJ

End

######################################################################################
## Collectives / Controls and BPRs
######################################################################################
Subprog AS_SACSRCDEB(VALEUR)
Variable Char    VALEUR()
Call RESET_ACC_COA([M]COASRC,"S")
End

Subprog C_SACSRCDEB(VALEUR)
Variable Char    VALEUR()
Call C_SAC(VALEUR, "ACCSRCDEB")
If !mkstat and VALEUR<>[M]SACSRCDEB
  Affzo [M]ACCSRCDEB
  Effzo [M]ACCDES1
Endif
End

Subprog AS_SACSRCCDT(VALEUR)
Variable Char    VALEUR()
Call RESET_ACC_COA([M]COASRC,"S")
End

Subprog C_SACSRCCDT(VALEUR)
Variable Char    VALEUR()
Call C_SAC(VALEUR, "ACCSRCCDT")
If !mkstat and VALEUR<>[M]SACSRCCDT
  Affzo [M]ACCSRCCDT
  Effzo [M]ACCDES2
Endif
End

Subprog AS_SACTGRDEB(VALEUR)
Variable Char    VALEUR()
Call RESET_ACC_COA([M]COATGR,"T")
End

Subprog C_SACTGRDEB(VALEUR)
Variable Char    VALEUR()
Call C_SAC(VALEUR, "ACCTGRDEB")
If !mkstat and VALEUR<>[M]SACTGRDEB
  Affzo [M]ACCTGRDEB
  Effzo [M]ACCDES3
Endif
End

Subprog AS_SACTGRCDT(VALEUR)
Variable Char    VALEUR()
Call RESET_ACC_COA([M]COATGR,"T")
End

Subprog C_SACTGRCDT(VALEUR)
Variable Char    VALEUR()
Call C_SAC(VALEUR, "ACCTGRCDT")
If !mkstat and VALEUR<>[M]SACTGRCDT
  Affzo [M]ACCTGRCDT
  Effzo [M]ACCDES4
Endif
End

Subprog C_SAC(VALEUR, ACCNAM)
Variable Char    VALEUR()
Value Char ACCNAM
If VALEUR<>""
  If [F:GAC]AUZBPR(5)<>2
    GMESSAGE = mess(51,102,1) : # Collective incorrect
    mkstat = 2 : End
  Else
    Assign "[M]"+ACCNAM With [F:GAC]ACC
  Endif
Endif
End

######################################################################################
## Source and Target Accounts
######################################################################################
# AV_ Before field, AS_ Before entry, AM_ After change, AP_ After field
# Needed separate description fields to control the clearing of them when needed
# The account fields GAC parameter is set to COA=[M]COASRC or [M]COATGR
# The account fields GAC option for General=Yes, Collective=Yes and Short code=Yes
Subprog AV_ACCSRCDEB(VALEUR)
Variable Char    VALEUR()
Call RESET_ACC_COA([M]COASRC,"S")
End

Subprog C_ACCSRCDEB(VALEUR)
Variable Char    VALEUR()
Call C_ACCSRC(VALEUR)
If mkstat : End : Endif
Effzo [M]ACCDES1
If !mkstat :  Read [GAC]GAC0 = [M]COASRC;VALEUR  : Endif
If !mkstat and !fstat and [F:GAC]SAC = 2
  [M]SACSRCDEB = [F:GAC]ACCSHO
Else
  [M]SACSRCDEB = ""
Endif
Affzo [M]SACSRCDEB
If !mkstat and [M]SACSRCDEB="" and [M]SACSRCCDT=""
  [M]BPRTGR=""
  Affzo [M]BPRTGR
Endif
End

Subprog AV_ACCSRCCDT(VALEUR)
Variable Char    VALEUR()
Call RESET_ACC_COA([M]COASRC,"S")
End

Subprog C_ACCSRCCDT(VALEUR)
Variable Char    VALEUR()
Call C_ACCSRC(VALEUR)
If mkstat : End : Endif
Effzo [M]ACCDES2
If !mkstat :  Read [GAC]GAC0 = [M]COASRC;VALEUR  : Endif
If !mkstat and !fstat and [F:GAC]SAC = 2
  [M]SACSRCCDT = [F:GAC]ACCSHO
Else
  [M]SACSRCCDT = ""
Endif
Affzo [M]SACSRCCDT
If !mkstat and [M]SACSRCDEB="" and [M]SACSRCCDT=""
  [M]BPRTGR=""
  Affzo [M]BPRTGR
Endif
End

Subprog C_ACCSRC(VALEUR)
Variable Char    VALEUR()
Call LECTURE("GAC",VALEUR,[M]COASRC) From CONTOBJ
Call VERSOC([F:GAC]FCY,[M]CPYSRC,"",VALEUR) From CFYSUB
If !mkstat  :  Gosub CHECK_EXCEPT  :  Endif
End

Subprog C_ACCTGR(VALEUR)
Variable Char    VALEUR()
Call LECTURE("GAC",VALEUR,[M]COATGR) From CONTOBJ
Call VERSOC([F:GAC]FCY,[M]CPYTGR,"",VALEUR) From CFYSUB
If !mkstat  :  Gosub CHECK_EXCEPT  :  Endif
End

Subprog AV_ACCTGRDEB(VALEUR)
Variable Char    VALEUR()
Call RESET_ACC_COA([M]COATGR,"T")
End

Subprog C_ACCTGRDEB(VALEUR)
Variable Char    VALEUR()
Call C_ACCTGR(VALEUR)
If mkstat : End : Endif
Effzo [M]ACCDES3
If !mkstat :  Read [GAC]GAC0 = [M]COATGR;VALEUR  : Endif
If !mkstat and !fstat and [F:GAC]SAC = 2
  [M]SACTGRDEB = [F:GAC]ACCSHO
Else
  [M]SACTGRDEB = ""
Endif
Affzo [M]SACTGRDEB
If !mkstat and [M]SACTGRDEB="" and [M]SACTGRCDT=""
  [M]BPRSRC=""
  Affzo [M]BPRSRC
Endif
End

Subprog AV_ACCTGRCDT(VALEUR)
Variable Char    VALEUR()
Call RESET_ACC_COA([M]COATGR,"T")
End

Subprog C_ACCTGRCDT(VALEUR)
Variable Char    VALEUR()
Call C_ACCTGR(VALEUR)
If mkstat : End : Endif
Effzo [M]ACCDES4
If !mkstat :  Read [GAC]GAC0 = [M]COATGR;VALEUR  : Endif
If !mkstat and !fstat and [F:GAC]SAC = 2
  [M]SACTGRCDT = [F:GAC]ACCSHO
Else
  [M]SACTGRCDT = ""
Endif
Affzo [M]SACTGRCDT
If !mkstat and [M]SACTGRDEB="" and [M]SACTGRCDT=""
  [M]BPRSRC=""
  Affzo [M]BPRSRC
Endif
End

######################################################################################
# If the account classification is type = Exceptional (TYP=2) then do not allow the account
# Per Christine 6/10/13
$CHECK_EXCEPT

If clalev([F:CLS])=0 : Local File GACCCLS  [CLS] : Endif

Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GAC]CLSCOD
If [F:CLS]TYP=2
  # The message is the standard one from subprog CONTACCT in program CPTCNT
  GMESSAGE = mess(57,106,1)-"("+mess([M]LEDTYPTGR,2644,1)+")"
  mkstat = 2
Endif

Return

######################################################################################
## BPRs
######################################################################################
# Allow entering a BP if any one of the controls was entered
# 5/31/13 Changing the standard way of checking Source control will now check Target BP per Christine
Subprog AS_BPRSRC(VALEUR)
Variable Char VALEUR()
If [M]SACTGRDEB = "" and [M]SACTGRCDT = ""
  mkstat = 1
Endif
End

# 5/31/13 Changing the standard way of checking Target control will now check Source BP per Christine
Subprog AS_BPRTGR(VALEUR)
Variable Char VALEUR()
If [M]SACSRCDEB = "" and [M]SACSRCCDT = ""
  mkstat = 1
Endif
End

######################################################################################
######################################################################################
