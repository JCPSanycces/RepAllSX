#<AdxTL>@(#)7.0.0.0 $Revision$
#<AdxTL>@(#)7.0.0.0 $Revision$
GBIDC3="" : GBIDC2=""
Raz GPILOBJ, GPILCOD
Call OBJET("AOW",GBIDC2,GBIDC3) From GOBJET
End

#----------------------------------------------------#
$COMPILE
Local Integer K , N , L , NBVAL

NOMTRTAOW = "WWI"+num$(adxuid(1))
TRTSRCAOW = filpath("TRT",NOMTRTAOW,"src",0)

Openo TRTSRCAOW , 0
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8

TITPRG = mess(52,141,1)-"("+NOMTRTAOW+")" : # Importation Sas

Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"-TITPRG

Wrseq "$IMPORT"
Wrseq "Local Integer  DEBUT,NUMFLD,NBL"
Wrseq "Local Char     VALIMP(250)(300), LIGNE(250)"
Wrseq "Local Blbfile  BLBIMP(GLONABB)"
Wrseq "Local Clbfile  CLBIMP(GLONACB)"
Wrseq "Local Char     IMPFIC(GLONABR)"
Wrseq "Local Integer  IMPFINS, RUPT, NBCRE, NBMOD, NBENR, NBERR"
Wrseq "Local Integer  SEPNUMS, DEBENR, WDEBENR"

If !GESSAS
 Gosub COMPILE_SAS
Else
 Gosub COMPILE_SAS2
Endif
Openo

Return

#----------------------------------------------------#
$COMPILE_SAS
Local Char SAS_LOT(100) , SAS_LIG(100)
SAS_LOT = "[V]GLOTAOW"
SAS_LIG = "GNUMAOW-1"
Wrseq "$IMPORT_SAS"
Wrseq
Wrseq "If !clalev([F:AOW]) : Local File AOBJEXTMP   [AOW] : Endif"
Wrseq "If !clalev([F:AOV]) : Local File AOBJEXTMPD  [AOV] : Endif"
Wrseq "If !clalev([F:AOY]) : Local File AOBJEXTMPC  [AOY] : Endif"
Wrseq "If !clalev([F:AOZ]) : Local File AOBJEXTMPB  [AOZ] : Endif"
Wrseq
Wrseq "# Lot : "+SAS_LOT
Wrseq "Local Decimal LIG(9)"
Wrseq "[L]LIG = "+SAS_LIG
Wrseq "DEBUT = 1"
Wrseq "Call DEBTRANS From GLOCK"
Wrseq "Seek First + DEBENR Using [IMP]"
Wrseq "Gosub TR_MAJSAS"
Wrseq "Return"
Wrseq ""
Wrseq "$TR_MAJSAS"
Wrseq "Trbegin [AOV],[AOW],[AOZ],[AOY]"
If [F:AOE]TYPFIL=6 : Wrseq " [L]AOWENR += 1 " : Endif
Wrseq " While 1=1"
Wrseq "  Call RD_SEQ(VALIMP,BLBIMP,CLBIMP,IMPFIC,SEPNUMS,IMPFINS,WDEBENR) From SUBIMPOBJ"
If [F:AOE]TYPFIL=6
 Wrseq "  If adxseek('IMP') >= FINENR  & adxseek('IMP') <> WDEBENR   : Break : Endif "
 Wrseq "  [L]NBL += 1"
 For K=0 To dim([M:IMP2]SEPREC)-1
  If [M:IMP2]SEPREC(K)<>"" | K=0
   Wrseq "  Gosub SAS"+num$(K+1)
  Endif
 Next K
 Wrseq "  If WDEBENR = FINENR : Break : Endif "
Else
 Wrseq "  If IMPFINS : Break : Endif"
 Wrseq "  Case SEPNUMS"
 For K=0 To dim([M:IMP2]SEPREC)-1
  If [M:IMP2]SEPREC(K)<>"" | K=0
   If K =0
    Wrseq "   When "+num$(K+1)
    Wrseq "    If DEBUT"
    Wrseq "     DEBUT = 0"
    Wrseq "    Else"
    Wrseq "     Break"
    Wrseq "    Endif"
    Wrseq "    [L]NBL += 1"
    Wrseq "    Gosub SAS"+num$(K+1)
    Wrseq "    [L]AOWENR += 1 "
   Else
    Wrseq "   When "+num$(K+1)
    Wrseq "    [L]NBL += 1"
    Wrseq "    Gosub SAS"+num$(K+1)
   Endif
  Endif
 Next K
 Wrseq "  Endcase"
Endif
Wrseq "  If GOK<1 : Break : Endif"
Wrseq " Wend"
Wrseq " If GOK<1 : Goto ROLL_MAJSAS : Endif"
Wrseq " Gosub CRE_AOW"
Wrseq " If GOK<1 : Goto ROLL_MAJSAS : Endif"
Wrseq "Commit"
# Lot/Création enregistrement
Wrseq 'Call MESSAGE(mess(23,107,1)-":"-'+SAS_LOT+'+","-mess(213,124,1)-":"-num$([L]AOWENR)) From GESECRAN'
Wrseq "Return"
Wrseq ""
Wrseq "$ROLL_MAJSAS"
Wrseq "Rollback"
Wrseq "IMPSTA = 9"
Wrseq "GOK = 1"
Wrseq "Return"
NBVAL = 0
For K=0 To dim([M:IMP2]SEPREC)-1
 If [F:AOE]TYPFIL<>6
  NBVAL = 0
 Endif
 If [M:IMP2]SEPREC(K)<>"" | K=0
  Gosub IMPORT
  If IMPSTA : Break : Endif
 Endif
Next K
If IMPSTA : Return : Endif
Gosub CRE_AOW
Gosub MAJ
Return

#----------------------------------------------------#
$COMPILE_SAS2
Local Char SAS_LOT(100) , SAS_LIG(100)
SAS_LOT = "[L]LOT"
SAS_LIG = "0"
Wrseq "$IMPORT_SAS"
Wrseq "Local Char     VALIMP2(250)(300)"
Wrseq
Wrseq
Wrseq "If !clalev([F:AOW]) : Local File AOBJEXTMP   [AOW] : Endif"
Wrseq "If !clalev([F:AOV]) : Local File AOBJEXTMPD  [AOV] : Endif"
Wrseq "If !clalev([F:AOY]) : Local File AOBJEXTMPC  [AOY] : Endif"
Wrseq "If !clalev([F:AOZ]) : Local File AOBJEXTMPB  [AOZ] : Endif"
Wrseq
Wrseq "# Lot : "+SAS_LOT
Wrseq "Local Decimal LIG(9)"
Wrseq "[L]LIG = "+SAS_LIG
Wrseq "DEBUT = 1"
Wrseq "Call DEBTRANS From GLOCK"
Wrseq "Gosub TR_MAJSAS"
Wrseq "Return"
Wrseq ""
Wrseq "$TR_MAJSAS"
Wrseq "Trbegin [AOV],[AOW],[AOZ],[AOY]"
Wrseq " While 1=1"
If [F:AOE]NBRFLG >0
 Filter [AOD] Where EXT = [M:AOW4]EXT & TYP = [F:AOE]FLGREC(0)
 Read [AOD]AOD0 Last
 Filter [AOD]
 Wrseq "  For I=0 to "+num$([F:AOD]NUMLIG-1)
Else
 Wrseq "  For I=0 to dim([L]VALIMP2)-1"
Endif
Wrseq "   VALIMP2(I) = VALIMP(I)"
Wrseq "  Next I"
Wrseq "  Call RD_SEQ(VALIMP,BLBIMP,CLBIMP,IMPFIC,SEPNUMS,IMPFINS,WDEBENR) From SUBIMPOBJ"
If [F:AOE]TYPFIL=6
 Wrseq "  If IMPFINS : Break : Endif"
 Wrseq "  EGAL = 1"
 If [F:AOE]NBRFLG >0
  Filter [AOD] Where EXT = [M:AOW4]EXT & TYP = [F:AOE]FLGREC(0)
  Read [AOD]AOD0 Last
  Filter [AOD]
  Wrseq "  For I=0 to "+num$([F:AOD]NUMLIG-1)
 Else
  Wrseq "  For I=0 to 300"
 Endif
 Wrseq "   EGAL *= ( VALIMP(I) = VALIMP2(I) )"
 Wrseq "   If !EGAL : break : Endif"
 Wrseq "  Next I"
 Wrseq "  If !EGAL : [L]AOWENR+=1 : Endif"
 Wrseq "  [L]NBL += 1"
 For K=0 To dim([M:IMP2]SEPREC)-1
  If [M:IMP2]SEPREC(K)<>"" | K=0
   Wrseq "  Gosub SAS"+num$(K+1)
  Endif
 Next K
Else
 Wrseq "  If IMPFINS : Break : Endif"
 Wrseq "  Case SEPNUMS"
 For K=0 To dim([M:IMP2]SEPREC)-1
  If [M:IMP2]SEPREC(K)<>"" | K=0
   If K =0
    Wrseq "   When "+num$(K+1)
    Wrseq "    [L]NBL += 1"
    Wrseq "    Gosub SAS"+num$(K+1)
    Wrseq "    [L]AOWENR += 1 "
   Else
    Wrseq "   When "+num$(K+1)
    Wrseq "    [L]NBL += 1"
    Wrseq "    Gosub SAS"+num$(K+1)
   Endif
  Endif
 Next K
 Wrseq "  Endcase"
Endif
Wrseq "  If GOK<1 : Break : Endif"
Wrseq " Wend"
Wrseq " If GOK<1 : Goto ROLL_MAJSAS : Endif"
Wrseq " Gosub CRE_AOW"
Wrseq " If GOK<1 : Goto ROLL_MAJSAS : Endif"
Wrseq "Commit"
# Lot/Création enregistrement
Wrseq 'Call MESSAGE(mess(23,107,1)-":"-'+SAS_LOT+'+","-mess(213,124,1)-":"-num$([L]AOWENR)) From GESECRAN'
Wrseq "Return"
Wrseq ""
Wrseq "$ROLL_MAJSAS"
Wrseq "Rollback"
Wrseq "GOK = 1"
Wrseq "Return"
NBVAL = 0
For K=0 To dim([M:IMP2]SEPREC)-1
 If [F:AOE]TYPFIL<>6
  NBVAL = 0
 Endif
 If [M:IMP2]SEPREC(K)<>"" | K=0
  Gosub IMPORT
  If IMPSTA : Break : Endif
 Endif
Next K
If IMPSTA : Return : Endif
Gosub CRE_AOW
Gosub MAJ
Return


#----------------------------------------------------#
$MAJ
Wrseq
Wrseq "$MAJ"
Wrseq "Write [AOV]"
Wrseq "If fstat : GOK = 0 : Endif"
Wrseq "Return"
Return

#----------------------------------------------------#
$CRE_AOW
Wrseq
Wrseq "$CRE_AOW"
Wrseq "Read [AOW]AOW0 = "+SAS_LOT
Wrseq "If !fstat"
Wrseq " [F:AOW]NBRLIG = [L]NBL"
Wrseq " If [L]FICCLI<>''"
Wrseq "  [F:AOW]FILEXT = [L]FICCLI"
Wrseq " Else"
Wrseq "  [F:AOW]FILEXT = [L]FICHIER"
Wrseq " Endif"
Wrseq " [F:AOW]UPDDAT = date$"
Wrseq " [F:AOW]UPDUSR = GUSER"
Wrseq " If dim([F:AOW]UPDTIM)>0 : [F:AOW]UPDTIM = time  : Endif"
Wrseq " Rewrite [AOW]"
Wrseq " If fstat"
Wrseq '  GOK = 0 : Call FSTA("AOW") From GLOCK : Return'
Wrseq " Endif"
Wrseq "Else"
Wrseq " [F:AOW]NUMLOT = "+SAS_LOT
Wrseq " [F:AOW]EXT    = [L]MODELE"
Wrseq " [F:AOW]NBRLIG = [L]NBL"
Wrseq " If [L]FICCLI<>''"
Wrseq "  [F:AOW]FILEXT = [L]FICCLI"
Wrseq " Else"
Wrseq "  [F:AOW]FILEXT = [L]FICHIER"
Wrseq " Endif"
Wrseq " [F:AOW]CREDAT = date$"
Wrseq " [F:AOW]CREUSR = GUSER"
Wrseq " If dim([F:AOW]CRETIM)>0 : [F:AOW]CRETIM = time  : Endif"
Wrseq " Raz [F:AOW]UPDDAT"
Wrseq " Raz [F:AOW]UPDUSR"
Wrseq " If dim([F:AOW]UPDTIM)>0 : Raz [F:AOW]UPDTIM : Endif"
Wrseq " Write [AOW]"
Wrseq " If fstat"
Wrseq '  GOK = 0 : Call FSTA("AOW") From GLOCK : Return'
Wrseq " Endif"
Wrseq "Endif"
Wrseq "Return"
Return

#----------------------------------------------------#
$IMPORT
Wrseq
Wrseq "$SAS"+num$(K+1)
Wrseq "Raz [AOV]"
L = find([M:IMP2]SEPREC(K),[F:AOE]FLGREC)
For N=0 To [M:AOE2]NBRLIG-1
 If [M:AOE2]SEL(N)<>3
  If [M:AOE2]TYP(N)=[M:IMP2]SEPREC(K) & [M:AOE2]FIL(N)<>""
  OK  = 1
  OK *= ([M:AOE2]FLD(N)<>"")
  OK *= (left$([M:AOE2]FLD(N),1)<>"'" ) : # & left$([M:AOE2]FLD(N),1)<>'"')
  OK *= (left$([M:AOE2]FLD(N),1)<>"=")
  OK *= ([M:AOE2]FLD(N)<>"#")
  If OK
   If [M:AOE2]FLD(N)<>""
    If NBVAL=0
     Wrseq "[L]NUMFLD= 1"
     Wrseq "[L]LIG += 1"
    Else
     Wrseq "[L]NUMFLD += 1"
    Endif
    Wrseq "[F:AOV]NUMLOT = "+SAS_LOT
    Wrseq "[F:AOV]NUMLIG = [L]LIG"
    Wrseq "[F:AOV]FLDNUM = [L]NUMFLD"
    Wrseq "[F:AOV]LEVCOD = '"+[M:IMP2]SEPREC(K)+"'"
    If [F:AOE]TYPFIL=6 :  Wrseq "[F:AOV]ENREG = [L]AOWENR" : Endif
    Wrseq "[F:AOV]LEV = "+num$([F:AOE]FLGLEV(L-1))
    Wrseq "[F:AOV]AOVFIL = '"+[M:AOE2]FIL(N)+"'"
    Wrseq "[F:AOV]AOVFLD = '"+[M:AOE2]FLD(N)+"'"
    If left$([M:AOE2]FLD(N),1)="*" | left$([M:AOE2]FLD(N),1)="/"
     TYPFMT = 1
    Elsif left$([M:AOE2]FLD(N),1)= '"'
     TYPFMT = 10
    Else
     Gosub DICO
     If IMPSTA : Break : Endif
    Endif
    Case TYPFMT
     When 5
      Wrseq "If instr(1,VALIMP("+num$(NBVAL)+"),'~')"
      Wrseq " [F:AOV]FLDVAL = Left$(VALIMP("+num$(NBVAL)+"),instr(1,VALIMP("+num$(NBVAL)+"),'~')-1)"
      Wrseq " [F:AOV]FLDVAL += '&~&'+right$(VALIMP("+num$(NBVAL)+"),instr(1,VALIMP("+num$(NBVAL)+"),'~')+1)"
      Wrseq "Else"
      Wrseq " [F:AOV]FLDVAL = ''"
      Wrseq "Endif"
      Wrseq "Gosub MAJ"
      Wrseq "If GOK<1 : Return : Endif"
     When 7
      Wrseq "[F:AOV]FLDVAL = VALIMP("+num$(NBVAL)+")"
      Wrseq "Gosub MAJ"
      Wrseq "If GOK<1 : Return : Endif"
      Wrseq "[F:AOZ]NUMLIG = [L]LIG"
      Wrseq "[F:AOZ]NUMLOT = "+SAS_LOT
      Wrseq "[F:AOZ]FLDBLB = [L]BLBIMP"
      Wrseq "Write [AOZ]"
      Wrseq "If fstat"
      Wrseq ' GOK = 0 : Call FSTA("AOZ") From GLOCK : Return'
      Wrseq "Endif"
     When 8
      Wrseq "[F:AOV]FLDVAL = VALIMP("+num$(NBVAL)+")"
      Wrseq "Gosub MAJ"
      Wrseq "If GOK<1 : Return : Endif"
      Wrseq "[F:AOY]NUMLIG = [L]LIG"
      Wrseq "[F:AOY]NUMLOT = "+SAS_LOT
      Wrseq "[F:AOY]FLDCLB = [L]CLBIMP"
      Wrseq "Write [AOY]"
      Wrseq "If fstat"
      Wrseq ' GOK = 0 : Call FSTA("AOY") From GLOCK : Return'
      Wrseq "Endif"
     When Default
      Wrseq "[F:AOV]FLDVAL = VALIMP("+num$(NBVAL)+")"
      Wrseq "Gosub MAJ"
      Wrseq "If GOK<1 : Return : Endif"
    Endcase
   Else
    Wrseq "[F:AOV]FLDVAL = ''"
    Wrseq "Gosub MAJ"
    Wrseq "If GOK<1 : Return : Endif"
   Endif
  Endif
  NBVAL += 1
 Endif
Endif
Next N
If IMPSTA : Return : Endif
Wrseq "Return"
Return

#----------------------------------------------------#
$DICO
J=instr(1,[M:AOE2]FLD(N),"(")
If J<>0
 NOMZONE = left$([M:AOE2]FLD(N),J-1)
 DIME = val(right$([M:AOE2]FLD(N),J+1))
Else
 NOMZONE = [M:AOE2]FLD(N)
 DIME = 0
Endif
Read [ATZ_]CODZONE = [M:AOE2]FIL(N); NOMZONE
If fstat
 If GTRACE<>""
  Call ECR_TRACE(mess(41,100,1)-NOMZONE,1) From GESECRAN
 Endif
 GBIDC3 = NOMZONE : IMPSTA = 9
Else
 Read [ATY_]CODTYP  = [F:ATZ_]CODTYP
 If fstat
  IMPSTA = 9 : GBIDC3 = NOMZONE
 Else
  Case [F:ATY_]TYPTYP
   When 1         : TYPFMT = 4 : NOLIB = [F:ATY_]NOLIB : If NOLIB=0 : NOLIB = [F:ATZ_]NOLIB : Endif
   When 2,3,4,5,6 : TYPFMT = 2 : # Numérique
   When 7         : TYPFMT = 1 : # Alpha
   When 8         : TYPFMT = 3 : # Date
   When 9         : TYPFMT = 7 : # Blob
   When 10        : TYPFMT = 8 : # Clob
  Endcase
  Case [F:ATY_]CODTYP
   When "ATX"                   : TYPFMT = 5
   When "AXX","AX1","AX2","AX3" : TYPFMT = 6
  Endcase
 Endif
Endif
Return
