#<AdxTL>@(#)0.0.0.0 $Revision$

$ACTION
Case ACTION
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH

 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0

 When "EXPORT"      : Gosub EXPORT
 When "EXP_ZONE"    : Gosub EXP_ZONE

Endcase
Return

######################################################################################
$INIT
Gosub OPEN_FIL
Gosub DECLARE
Local Mask =[V]GFONCTION [DIA]
[M:DIA]CPY = GDEFSOC

Return

$OPEN_FIL
If !clalev([F:LED])  : Local File GLED       [LED]  : Endif
If !clalev([F:BLP])  : Local File BALPRECSL  [BLP]  : Endif
If !clalev([F:BLP1]) : Local File BALPRECSL  [BLP1] : Endif
If !clalev([F:COA])  : Local File GCOA       [COA]  : Endif
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif
If !clalev([F:CLS])  : Local File GACCCLS    [CLS]  : Endif
If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev([F:PER])  : Local File PERIOD     [PER]  : Endif
# Export
If !clalev([F:AOE])  : Local File AOBJEXT    [AOE]  : Endif
If !clalev([F:AOD])  : Local File AOBJEXTD   [AOD]  : Endif
If !clalev([F:AOR])  : Local File AOBJEXTR   [AOR]  : Endif
If !clalev([F:ATB])  : Local File ATABLE     [ATB]  : Endif
If !clalev([M:AOE0]) : Local Mask AOE0       [AOE0] : Endif
If !clalev([M:AOE1]) : Local Mask AOE1       [AOE1] : Endif
If !clalev([M:AOE2]) : Local Mask AOE2       [AOE2] : Endif
If !clalev([M:EXP1]) : Local Mask EXPOBJ     [EXP1] : Endif
If !clalev([M:EXP2]) : Local Mask EXPOBJ2    [EXP2] : Endif
Return

$DECLARE
Local Decimal EXE                : # Fiscalyear number
Local Decimal PER                : # Period number
Local Date    PERSTRDAT          : # Period start date
Local Date    PERENDDAT          : # Period end date
Local Char    MODELE(GLONAOE)    : # Export template name
Local Char    PARAMETRE(9)       : # Pamrameter name CSLEXP or CSLEXPANA

Local Integer  SAVGPARTRABTC     : # To save GPARTRABTC parameter value

Local Integer MAXPER
MAXPER = func AFNC.ACTIV("PER")  : # Maximum number of periods
Local Char    LINE(80)           : # Trace line

Return
######################################################################################
$CONTROLE

If GOK<1 : FIN = 1 : Return : Endif

# To not display the log file "MASQUE_TRACE" managed by the supervisor in GTRAITE
If GSERVEUR=1 & dim(GPARTRABTC)>0
 SAVGPARTRABTC = GPARTRABTC
 GPARTRABTC = 1
Endif
TMP = 1
Return

######################################################################################
$EXEC
If GSERVEUR
 [M:DIA]TRCFLG = 2
 If dim(GPARTRABTC)>0
  GPARTRABTC = SAVGPARTRABTC
 Endif
Endif
If !GSERVEUR & [M:DIA]TRCFLG=2
 Call OUVRE_TRACE(mess(417,107,1)) From LECFIC
Endif
If [M:DIA]TRCFLG=2
 Call ECR_TRACE(string$(50,"="),0) From GESECRAN
 Call ECR_TRACE(mess(417,107,1),0) From GESECRAN
 Call ECR_TRACE(string$(50,"="),0) From GESECRAN
 Call ECR_TRACE(mess(14,103,1)-":",0) From GESECRAN
 Call ECR_TRACE(string$(30,"-"),0) From GESECRAN
 If ([M:DIA]ALLCPY=2)
  Call ECR_TRACE(mess(145,139,1)-":"-mess(2,1,1),0) From GESECRAN
 Else
  Call ECR_TRACE(mess(26,113,1)-":"-[M:DIA]CPY,0) From GESECRAN
 Endif
 Call ECR_TRACE(mess(166,105,1)-":"-mess([M:DIA]LEDTYP,2644,1),0) From GESECRAN
 Call ECR_TRACE(mess(14,119,1)-":"-format$(GFMDAT,[M:DIA]ENDDAT),0) From GESECRAN
 Call ECR_TRACE(mess(416,107,1)-":"-mess([M:DIA]SNSSLD,668,1),0) From GESECRAN
 Call ECR_TRACE(mess(143,107,1)-":"-mess([M:DIA]HBI,1,1),0) From GESECRAN
 Call ECR_TRACE(string$(50,"="),0) From GESECRAN
 Call ECR_TRACE(mess(106,107,1),0) From GESECRAN
 Call ECR_TRACE(string$(30,"-"),0) From GESECRAN
Endif

If ([M:DIA]ANAFLG=2)
 [L]PARAMETRE = "CSLEXPANA"
Else
 [L]PARAMETRE = "CSLEXP"
Endif

If [M:DIA]ALLCPY=2
 For [BLP1]BLP0(2) Where LEDTYP= [M:DIA]LEDTYP
  Read [CPY]CPY0 = [F:BLP1]CPY
  Gosub EXPORT_COMPANY
  If FIN : Break : Endif
 Next
Else
 Read [CPY]CPY0 = [M:DIA]CPY
 Gosub EXPORT_COMPANY
Endif

If !GSERVEUR & [M:DIA]TRCFLG=2
 Call FERME_TRACE From LECFIC
Endif
Return

################################################
$EXPORT_COMPANY
 If [M:DIA]TRCFLG=2 : Call ECR_TRACE(mess(2,116,1)-":"-[F:CPY]CPY-[F:CPY]CPYNAM,0) From GESECRAN : Endif

Call PARAML([F:CPY]CPY,PARAMETRE,MODELE) From ADOVAL
If ([L]MODELE = "") Then
 If [M:DIA]TRCFLG=2 : Call ECR_TRACE(func ASYRFNC.MES1(mess(414,107, 1), [L]PARAMETRE),1) From GESECRAN : Endif
Else
 Read [AOE]AOE0=MODELE
 If (fstat) Then
  If [M:DIA]TRCFLG=2 : Call ECR_TRACE(func ASYRFNC.MES1(mess(415,107, 1), [L]MODELE),1) From GESECRAN : Endif
 Else
  Call GETPERSOC([F:CPY]CPY,[M:DIA]LEDTYP,[M:DIA]ENDDAT,EXE,PER) From CPTSUB
  If EXE=0 or PER=0
   If [M:DIA]TRCFLG=2 : Call ECR_TRACE(mess(107,107,1),1) From GESECRAN : Endif
  Else
   Call DATPER([F:CPY]CPY,[M:DIA]LEDTYP,EXE,PER,PERSTRDAT,PERENDDAT) From CPTSUB
   # Hiden fiels for export management
   [M:DIA]PER       = PER
   [M:DIA]PERENDDAT = PERENDDAT

   # Export
   LINE = string$(50,"*")
   Raz [M:EXP2]NOMEXP
   Raz [M:EXP2]STAT
   [M:EXP2] = [M:DIA]
   If [M:EXP2]TYPEXP=2
    [M:EXP2]NOMEXP = [M:DIA]FILDIRLOC
    If right$([M:EXP2]NOMEXP, len([M:EXP2]NOMEXP))<>"/" : [M:EXP2]NOMEXP += "/" : Endif
   Endif
   [M:EXP2]NOMEXP += "BALPRECSL_" + [F:CPY]CPY + "_" + format$("DDMMYY",[M:DIA]ENDDAT) + "_"+format$("DDMMYY",date$)+"-"+format$("hhmm", date$)
   [M:EXP2]MODELE = [L]MODELE
   If [M:DIA]ANAFLG = 2
    Filter [BLP] Where LEDTYP=[M:DIA]LEDTYP and CPY=[F:CPY]CPY and FIY=EXE and IDTCCE <> 0
   Else
    Filter [BLP] Where LEDTYP=[M:DIA]LEDTYP and CPY=[F:CPY]CPY and FIY=EXE and IDTCCE = 0
   Endif
   If rowcount([BLP])=0
    If [M:DIA]TRCFLG=2 : Call ECR_TRACE("0"-mess(82,141,1), 0) From GESECRAN : Endif
   Else

    If [M:DIA]TRCFLG=2
     Call ECR_TRACE(LINE,0) From GESECRAN
     LINE =      left$( mess(59 ,116,1) + string$(10,' '), 10)+" "
     LINE +=     left$( mess(144,141,1) + string$(15,' '), 15)+" "
     LINE +=     left$( mess(18 ,  2,1) + string$(15,' '), 15)+" "
     LINE +=     left$( mess(18 ,173,1) + string$(30,' '), 30)+" "
     Call ECR_TRACE(LINE,0) From GESECRAN
     LINE = string$(50,"*")
     Call ECR_TRACE(LINE,0) From GESECRAN
     For [PER]PER0 Where CPY=[F:CPY]CPY & LEDTYP=[M:DIA]LEDTYP & FIYNUM=EXE and PERNUM > 0 and PERNUM <= PER
      LINE =  left$( num$([F:PER]PERNUM)             + string$(10,' '), 10) +" "
      LINE += left$( format$(GFMDAT,[F:PER]PERSTR)   + string$(15,' '), 15) +" "
      LINE += left$( format$(GFMDAT,[F:PER]PEREND)   + string$(15,' '), 15) +" "
      LINE += left$( mess([F:PER]PERSTA,214,1)       + string$(30,' '), 30) +" "
      Call ECR_TRACE(LINE,0) From GESECRAN
     Next
     LINE = string$(50,"*")
     Call ECR_TRACE(LINE,0) From GESECRAN
    Endif

    Call EXPORTSIL From GEXPOBJ
    If [M:EXP2]STAT=0 and !GSERVEUR
     If [M:DIA]TYPEXP=1
      If [M:DIA]TRCFLG=2 : Call ECR_TRACE(mess(178,115,1)-[M:EXP2]NOMEXP, 0) From GESECRAN : Endif
     Else
      If [M:DIA]TRCFLG=2 : Call ECR_TRACE("|"+mess(14,9003,1)-[M:EXP2]NOMEXP, 0) From GESECRAN : Endif
     Endif
    Endif
   Endif
   Filter [BLP]
  Endif
 Endif
Endif
Return


######################################################################################
$TERMINE
# Logfile
If !GSERVEUR & [M:DIA]TRCFLG=2
 TRA = 1
Else
 TRA = 0
Endif
Return

#############################################################################
## BATCH
#############################################################################
$OUVRE_BATCH
Gosub OPEN_FIL
Gosub DECLARE
Return

################################################
## Ecran EXPBAL
################################################

Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 Diszo [M:DIA]ALLCPY
 Actzo [M:DIA]CPY
 mkstat = 1 : End
Endif
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo [M:DIA]CPY
 Grizo [M:DIA]CPY
 [M:DIA]TYPEXP=2
 Affzo [M:DIA]TYPEXP
 Grizo [M:DIA]TYPEXP

 Gosub AFFECT_VOLFIL
 Actzo [M:DIA]VOLFIL
 Affzo [M:DIA]VOLFIL
Else
 Actzo [M:DIA]CPY
 Actzo [M:DIA]TYPEXP
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = GDEFSOC
Endif
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
If([M:DIA]ALLCPY<>2)
 Local Integer OPTION
 OPTION=11 : # Consolidated ledger
 Call LEDTYP_CHOICE([M]CPY,OPTION) From CPTDIV
Endif
End

Subprog AM_CPY(VALEUR)
Variable Char VALEUR

If([M:DIA]ALLCPY=2)
  Actzo [M:DIA]ANAFLG
Else
 Local Char     CODLED(GLONLED)
 Local Char     DEVLED(GLONCUR)
 Call LECLED(VALEUR,[M:DIA]LEDTYP,CODLED,DEVLED) From CPTDIV
 Call LEC_LED(CODLED) From CPTLEC
 If ([F:LED]ANA=2) Then
  If [F:LED]GEN <> 2
   [M:DIA]ANAFLG = 2
   Affzo [M:DIA]ANAFLG
   Grizo [M:DIA]ANAFLG
  Else
   Actzo [M:DIA]ANAFLG
  Endif
 Else
  Effzo [M:DIA]ANAFLG
  Grizo [M:DIA]ANAFLG
 Endif
Endif
End

Subprog AM_LEDTYP(VALEUR)
Variable Integer VALEUR

If([M:DIA]ALLCPY=2)
  Actzo [M:DIA]ANAFLG
Else
 Local Char     CODLED(GLONLED)
 Local Char     DEVLED(GLONCUR)
 Call LECLED([M:DIA]CPY,VALEUR,CODLED,DEVLED) From CPTDIV
 Call LEC_LED(CODLED) From CPTLEC
 If ([F:LED]ANA=2) Then
  If [F:LED]GEN <> 2
   [M:DIA]ANAFLG = 2
   Affzo [M:DIA]ANAFLG
   Grizo [M:DIA]ANAFLG
  Else
   Actzo [M:DIA]ANAFLG
  Endif
 Else
  Effzo [M:DIA]ANAFLG
  Grizo [M:DIA]ANAFLG
 Endif
Endif
End

Subprog AS_ANAFLG(VALEUR)
Variable Integer VALEUR

If([M:DIA]ALLCPY=2)
  Actzo [M:DIA]ANAFLG
Else
 Local Char     CODLED(GLONLED)
 Local Char     DEVLED(GLONCUR)
 Call LECLED([M:DIA]CPY,[M:DIA]LEDTYP,CODLED,DEVLED) From CPTDIV
 Call LEC_LED(CODLED) From CPTLEC
 If [F:LED]ANA=2
  If [F:LED]GEN <> 2
   VALEUR = 2
   Affzo [M:DIA]ANAFLG
   Grizo [M:DIA]ANAFLG
   mkstat=2
  Else
   Actzo [M:DIA]ANAFLG
  Endif
 Else
  Effzo [M:DIA]ANAFLG
  Grizo [M:DIA]ANAFLG
  mkstat=2
 Endif
Endif
End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : mkstat = 2 : End
Endif

If VALEUR<>2
 Effzo [M:DIA]VOLFIL
 Grizo [M:DIA]VOLFIL
Else
 Gosub AFFECT_VOLFIL
 Actzo [M:DIA]VOLFIL
Endif
Affzo [M:DIA]VOLFIL
End

$AFFECT_VOLFIL
If [M:DIA]VOLFIL = ""
 Local Char NOMFIC(GDIMFIC)
 NOMFIC = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFLD,"","CSLEXPDIR")
 If NOMFIC<>"" & left$(NOMFIC,1)="["
  [M:DIA]VOLFIL = NOMFIC
 Else
  [M:DIA]VOLFIL = "[TMP]"
 Endif
Endif
Return

###############################################################################
##  CSLEXPDIR parameter control
###############################################################################

#======================
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK
Local Char TMP(250)
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
If func ASYRSTO.CTL_VOLFIL(2,VALEUR,TMP,E_TYPE_FOLDER,GMESSAGE)<>0
 OK = 0 : End
Endif
End

#======================
Subprog D_INI(VALEUR)
Variable Decimal VALEUR
Raz [M]
[M:DIA]TYPEXP=2
If [M:DIA]VOLFIL="" & !GBATCH
 Gosub AFFECT_VOLFIL
Endif
Actzo [M]VOLFIL
End

#======================
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FILDIRLOC,E_TYPE_FOLDER,GMESSAGE)
End



###############################################################################
##  Fonctions pour champs du modèle d'export CSLEXP
###############################################################################

Funprog BLCCURLED(DATBAL)
Value Date DATBAL
Local Decimal SOLDE
Raz SOLDE
If ([M:DIA]SNSSLD = 1) Then
 # Débit - Crédit"
 SOLDE = sum([F:BLP]DEBLED(0..[M:DIA]PER))-sum([F:BLP]CDTLED(0..[M:DIA]PER))
Else
 SOLDE = sum([F:BLP]CDTLED(0..[M:DIA]PER))-sum([F:BLP]DEBLED(0..[M:DIA]PER))
Endif

End SOLDE


Funprog BLCCUR(DATBAL)
Value Date DATBAL
Local Decimal SOLDE
Raz SOLDE
If ([M:DIA]SNSSLD = 1) Then
 # Débit - Crédit"
 SOLDE = sum([F:BLP]DEB(0..[M:DIA]PER))-sum([F:BLP]CDT(0..[M:DIA]PER))
Else
 SOLDE = sum([F:BLP]CDT(0..[M:DIA]PER))-sum([F:BLP]DEB(0..[M:DIA]PER))
Endif

End SOLDE


$EXPORT
# if off balance sheet is NOT ticked : BALPRECSL lines refering to "off balance sheet account" are NOT exported
If [M:DIA]HBI<>2
 If [F:BLP]COA<>[F:COA]COA
  Read [COA]COA0 = [F:BLP]COA
 Endif
 If [F:BLP]COA<>[F:GAC]COA or [F:BLP]ACC<>[F:GAC]ACC
  Read [GAC]GAC0 = [F:BLP]COA;[F:BLP]ACC
 Endif
 If [F:COA]LEG<>[F:CLS]LEG or [F:GAC]CLSCOD<>[F:CLS]CLSCOD
  Read [CLS]CLS0 = [F:COA]LEG;[F:GAC]CLSCOD
 Endif
 If [F:CLS]TYP=2
  [L]OK=0
 Endif
Endif
Return

$EXP_ZONE
# The amounts beyond the period in which is located the keyed date are set to 0.
Case EXPZON

  When "[F:BLP]DEBLED(1)" : If [M:DIA]PER < 1 : [F:BLP]DEBLED(1) = 0 : Endif
  When "[F:BLP]CDTLED(1)" : If [M:DIA]PER < 1 : [F:BLP]CDTLED(1) = 0 : Endif
  When "[F:BLP]DEB(1)"    : If [M:DIA]PER < 1 : [F:BLP]DEB(1)    = 0 : Endif
  When "[F:BLP]CDT(1)"    : If [M:DIA]PER < 1 : [F:BLP]CDT(1)    = 0 : Endif

  When "[F:BLP]DEBLED(2)" : If [M:DIA]PER < 2 : [F:BLP]DEBLED(2) = 0 : Endif
  When "[F:BLP]CDTLED(2)" : If [M:DIA]PER < 2 : [F:BLP]CDTLED(2) = 0 : Endif
  When "[F:BLP]DEB(2)"    : If [M:DIA]PER < 2 : [F:BLP]DEB(2)    = 0 : Endif
  When "[F:BLP]CDT(2)"    : If [M:DIA]PER < 2 : [F:BLP]CDT(2)    = 0 : Endif

  When "[F:BLP]DEBLED(3)" : If [M:DIA]PER < 3 : [F:BLP]DEBLED(3) = 0 : Endif
  When "[F:BLP]CDTLED(3)" : If [M:DIA]PER < 3 : [F:BLP]CDTLED(3) = 0 : Endif
  When "[F:BLP]DEB(3)"    : If [M:DIA]PER < 3 : [F:BLP]DEB(3)    = 0 : Endif
  When "[F:BLP]CDT(3)"    : If [M:DIA]PER < 3 : [F:BLP]CDT(3)    = 0 : Endif

  When "[F:BLP]DEBLED(4)" : If [M:DIA]PER < 4 : [F:BLP]DEBLED(4) = 0 : Endif
  When "[F:BLP]CDTLED(4)" : If [M:DIA]PER < 4 : [F:BLP]CDTLED(4) = 0 : Endif
  When "[F:BLP]DEB(4)"    : If [M:DIA]PER < 4 : [F:BLP]DEB(4)    = 0 : Endif
  When "[F:BLP]CDT(4)"    : If [M:DIA]PER < 4 : [F:BLP]CDT(4)    = 0 : Endif

  When "[F:BLP]DEBLED(5)" : If [M:DIA]PER < 5 : [F:BLP]DEBLED(5) = 0 : Endif
  When "[F:BLP]CDTLED(5)" : If [M:DIA]PER < 5 : [F:BLP]CDTLED(5) = 0 : Endif
  When "[F:BLP]DEB(5)"    : If [M:DIA]PER < 5 : [F:BLP]DEB(5)    = 0 : Endif
  When "[F:BLP]CDT(5)"    : If [M:DIA]PER < 5 : [F:BLP]CDT(5)    = 0 : Endif

  When "[F:BLP]DEBLED(6)" : If [M:DIA]PER < 6 : [F:BLP]DEBLED(6) = 0 : Endif
  When "[F:BLP]CDTLED(6)" : If [M:DIA]PER < 6: [F:BLP]CDTLED(6) = 0 : Endif
  When "[F:BLP]DEB(6)"    : If [M:DIA]PER < 6: [F:BLP]DEB(6)    = 0 : Endif
  When "[F:BLP]CDT(6)"    : If [M:DIA]PER < 6: [F:BLP]CDT(6)    = 0 : Endif

  When "[F:BLP]DEBLED(7)" : If [M:DIA]PER < 7 : [F:BLP]DEBLED(7) = 0 : Endif
  When "[F:BLP]CDTLED(7)" : If [M:DIA]PER < 7 : [F:BLP]CDTLED(7) = 0 : Endif
  When "[F:BLP]DEB(7)"    : If [M:DIA]PER < 7 : [F:BLP]DEB(7)    = 0 : Endif
  When "[F:BLP]CDT(7)"    : If [M:DIA]PER < 7 : [F:BLP]CDT(7)    = 0 : Endif

  When "[F:BLP]DEBLED(8)" : If [M:DIA]PER < 8 : [F:BLP]DEBLED(8) = 0 : Endif
  When "[F:BLP]CDTLED(8)" : If [M:DIA]PER < 8 : [F:BLP]CDTLED(8) = 0 : Endif
  When "[F:BLP]DEB(8)"    : If [M:DIA]PER < 8 : [F:BLP]DEB(8)    = 0 : Endif
  When "[F:BLP]CDT(8)"    : If [M:DIA]PER < 8 : [F:BLP]CDT(8)    = 0 : Endif

  When "[F:BLP]DEBLED(9)" : If [M:DIA]PER < 9 : [F:BLP]DEBLED(9) = 0 : Endif
  When "[F:BLP]CDTLED(9)" : If [M:DIA]PER < 9 : [F:BLP]CDTLED(9) = 0 : Endif
  When "[F:BLP]DEB(9)"    : If [M:DIA]PER < 9 : [F:BLP]DEB(9)    = 0 : Endif
  When "[F:BLP]CDT(9)"    : If [M:DIA]PER < 9 : [F:BLP]CDT(9)    = 0 : Endif

  When "[F:BLP]DEBLED(10)" : If [M:DIA]PER < 10 : [F:BLP]DEBLED(10) = 0 : Endif
  When "[F:BLP]CDTLED(10)" : If [M:DIA]PER < 10 : [F:BLP]CDTLED(10) = 0 : Endif
  When "[F:BLP]DEB(10)"    : If [M:DIA]PER < 10 : [F:BLP]DEB(10)    = 0 : Endif
  When "[F:BLP]CDT(10)"    : If [M:DIA]PER < 10 : [F:BLP]CDT(10)    = 0 : Endif


  When "[F:BLP]DEBLED(11)" : If [M:DIA]PER < 11 : [F:BLP]DEBLED(11) = 0 : Endif
  When "[F:BLP]CDTLED(11)" : If [M:DIA]PER < 11 : [F:BLP]CDTLED(11) = 0 : Endif
  When "[F:BLP]DEB(11)"    : If [M:DIA]PER < 11 : [F:BLP]DEB(11)    = 0 : Endif
  When "[F:BLP]CDT(11)"    : If [M:DIA]PER < 11 : [F:BLP]CDT(11)    = 0 : Endif


  When "[F:BLP]DEBLED(12)" : If [M:DIA]PER < 12 : [F:BLP]DEBLED(12) = 0 : Endif
  When "[F:BLP]CDTLED(12)" : If [M:DIA]PER < 12 : [F:BLP]CDTLED(12) = 0 : Endif
  When "[F:BLP]DEB(12)"    : If [M:DIA]PER < 12 : [F:BLP]DEB(12)    = 0 : Endif
  When "[F:BLP]CDT(12)"    : If [M:DIA]PER < 12 : [F:BLP]CDT(12)    = 0 : Endif

  When "[F:BLP]DEBLED(13)" : If [M:DIA]PER < 13 : [F:BLP]DEBLED(13) = 0 : Endif
  When "[F:BLP]CDTLED(13)" : If [M:DIA]PER < 13 : [F:BLP]CDTLED(13) = 0 : Endif
  When "[F:BLP]DEB(13)"    : If [M:DIA]PER < 13 : [F:BLP]DEB(13)    = 0 : Endif
  When "[F:BLP]CDT(13)"    : If [M:DIA]PER < 13 : [F:BLP]CDT(13)    = 0 : Endif


  When "[F:BLP]DEBLED(14)" : If [M:DIA]PER < 14 : [F:BLP]DEBLED(14) = 0 : Endif
