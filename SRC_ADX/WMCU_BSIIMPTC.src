#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank import type codes
# Supervisor
## CRUD-CLASSE ## BSIIMPTC
# 2018-08-16 22:22:46 337


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(BSIIMPTC,ASTATUS)
Variable Instance BSIIMPTC Using C_BSIIMPTC
Variable Integer ASTATUS

If BSIIMPTC = null : End : Endif

Gosub _AVARIABLES From WMC00BSIIMPTC

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_BSIIMPTC

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(BSIIMPTC,ASTATUS)
Variable Instance BSIIMPTC Using C_BSIIMPTC
Variable Integer ASTATUS

If BSIIMPTC = null : End : Endif

Gosub AVARIABLES From WMC00BSIIMPTC
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
BSIIMPTC.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_BSIIMPTC
Else
 Gosub AUPDATE_BSIIMPTC
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = BSIIMPTC.freeSnapshot
BSIIMPTC.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet BSIIMPTC._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet BSIIMPTC._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet BSIIMPTC._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If BSIIMPTC.ASTALIN = [V]CST_ANEWDEL : Return : Endif
BSIIMPTC.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(BSIIMPTC.ASTALIN)<>""
 [L]A_ASTALIN = BSIIMPTC.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
For A_N2=1 To maxtab(BSIIMPTC.LINES) : # BSIITCD -- 2
 If BSIIMPTC.LINES(A_N2) <> null
& and BSIIMPTC.LINES(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If BSIIMPTC.LINES(A_N2).ASTALIN<>[V]CST_ANEW & BSIIMPTC.ASTALIN=[V]CST_ADEL
   BSIIMPTC.LINES(A_N2).ASTALIN = [V]CST_ADEL
  Endif
  If BSIIMPTC.LINES(A_N2).ASTALIN=[V]CST_ANEW & find(BSIIMPTC.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
   BSIIMPTC.LINES(A_N2).ASTALIN = [V]CST_ANEWDEL
  Endif
  If [V]CST_ASTALIN(BSIIMPTC.LINES(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = BSIIMPTC.LINES(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.LINES(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER
For A_N2=1 To maxtab(BSIIMPTC.LINES) : # BSIITCD -- 2
 If BSIIMPTC.LINES(A_N2) <> null
& and BSIIMPTC.LINES(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If [V]CST_ASTALIN(BSIIMPTC.LINES(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = BSIIMPTC.LINES(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.LINES(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

If [V]CST_ASTALIN(BSIIMPTC.ASTALIN)<>""
 [L]A_ASTALIN = BSIIMPTC.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_BSIIMPTC
Trbegin [F:BSITC]
 Gosub AUPDATE_BSIIMPTC
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_BSIIMPTC
[L]A_ASTALIN = BSIIMPTC.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00BSIIMPTC._MAJSQL_BSIIMPTC(BSIIMPTC))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

For [L]A_TYPMAJ=[V]CST_ADEL,[V]CST_AUPD,[V]CST_ANEW
 #-----------------------#
 For A_N2=1 To maxtab(BSIIMPTC.LINES)
  If BSIIMPTC.LINES(A_N2) <> null and
& (BSIIMPTC.LINES(A_N2).ASTALIN=[L]A_TYPMAJ or
& BSIIMPTC.LINES(A_N2).ASTALIN=[V]CST_ALL)
   If BSIIMPTC.LINES(A_N2).ASTALIN=[L]A_TYPMAJ
    If [V]CST_ASTALIN(BSIIMPTC.LINES(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = BSIIMPTC.LINES(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.LINES(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
    [L]ASTATUS = func WMC00BSIIMPTC._MAJSQL_BSIITCD(BSIIMPTC.LINES(A_N2))
    If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    If [V]CST_ASTALIN(BSIIMPTC.LINES(A_N2).ASTALIN)<>""
     [L]A_ASTALIN = BSIIMPTC.LINES(A_N2).ASTALIN
     [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.LINES(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
     If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
    Endif
   Endif
  Endif
  If [L]ASTATUS>=[V]CST_AERROR : Break 2 : Endif
 Next A_N2
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 #-----------------------#
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]A_ASTALIN = BSIIMPTC.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If BSIIMPTC.snapshotEnabled=1
 [L]A_RETIK = BSIIMPTC.revertUpdTick
Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(BSIIMPTC.LINES)
 If BSIIMPTC.LINES(A_N2) <> null
  If BSIIMPTC.LINES(A_N2).ASTALIN=[V]CST_ANEWDEL
   BSIIMPTC.LINES(A_N2).ASTALIN = [V]CST_ANEW
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2

[L]ASTATUS = max(fmet BSIIMPTC.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(BSIIMPTC.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 BSIIMPTC.ASTALIN = [V]CST_ALL
Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(BSIIMPTC.LINES)
 If BSIIMPTC.LINES(A_N2) <> null
  If BSIIMPTC.LINES(A_N2).ASTALIN=[V]CST_ADEL or BSIIMPTC.LINES(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance BSIIMPTC.LINES(A_N2)
   BSIIMPTC.LINES(A_N2) = null
  Elsif BSIIMPTC.LINES(A_N2).ASTALIN <> [V]CST_ALL
   BSIIMPTC.LINES(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Return



