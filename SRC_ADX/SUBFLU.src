#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion objet FLU
####################################################################################################
##                      GESTION DU PARAMETRAGE DES FLUX                                           ##
####################################################################################################
##  Source : SUBFLU                                                                               ##
##  Auteur : FGR                                                                                  ##
##  Création le : 24/06/2004                                                                      ##
##  Mod :  MDJ  le 05/11/2007 (FQ V5   ) : Aménagement pour la V5                                 ##
####################################################################################################
##  CBO 26/10/2017 X3-57692 : Error when delete
##  CBO 02/06/2017 X3-40074 : G_SUP must not be killed
##  MWA 03/02/2017 FQ121352 : Message inaproprié après suppression d'un flux
##  GLE 04/07/2013 FQ101153 : Ajout du champ LEG pour filtrage correct à l'installation
##  GLE 12/06/2013 FQ90410  : Le bouton "Supprimer" n'était jamais actif
##  MDJ 21/12/2011 FQ78383  : PB PARAMÉTRAGE FLUX AVEC MULTI PLANS DE COMPTES
##  GLE 10/12/2010 FQ69845  : Le contrôle sur le flux liasse est fait par rapport au code pays au lieu
##                           d'être fait par rapport à la législation.
####################################################################################################

Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("FLU",GBIDC1,GBIDC2) From GOBJET
End

################################################################################
$ACTION
  Case ACTION
    When "OUVRE"            : Gosub OUVRE
    When "RAZCRE"           : Gosub RAZCRE
    When "RAZDUP"           : Gosub RAZDUP
    When "LIENS"            : Gosub LIENS
    When "CREATION"         : Gosub CREATION
    When "MODIF"            : Gosub MODIF
    When "ANNULE"           : Gosub ANNULE
    When "VERIF_CRE"        : Gosub VERIF_CRE
    When "VERIF_MOD"        : Gosub VERIF_MOD
    When "VERF_ANU"         : Gosub VERF_ANU
    When "AV_VERF_ANU"      : Gosub AV_VERF_ANU
    When "APRES_CHOI"       : Gosub APRES_CHOI
    When "SETBOUT"          : Gosub SETBOUT
    When "SEL_LISTE"        : Gosub SEL_LISTE
    When "DEVERROU"         : Gosub DEVERROU  : # FQ121352
    When "FIN"              : Gosub FIN       : # FQ121352
    When Default
  Endcase
Return

################################################################################
#-------------------------------------------------------------------------------
$OUVRE
  If clalev([F:TCY])  = 0 : Local File TABCOUNTRY [TCY]  : Endif : # Pays
  If clalev([F:PFL])  = 0 : Local File PARFLUX    [PFL]  : Endif : # Paramétrage des flux (entête)
  If clalev([F:PF1])  = 0 : Local File PARFLUX    [PF1]  : Endif : # Paramétrage des flux (entête)
  If clalev([F:PFD])  = 0 : Local File PARFLUXDET [PFD]  : Endif : # Paramétrage des flux (détail)
  # FQ 30450
  If clalev([F:PFL2])  = 0 : Local File PARFLUX    [PFL2]  : Endif : # Paramétrage des flux (entête)
  If clalev([F:PFD2])  = 0 : Local File PARFLUXDET [PFD2]  : Endif : # Paramétrage des flux (détail)
  If clalev([F:FLU2])  = 0 : Local File FXDLIFL    [FLU2]  : Endif : # Suivi des flux
  # FQ101153
  If clalev([F:COA])  = 0 : Local File  GCOA       [COA]  : Endif : # Plans de comptes

  Global Integer G_SUPP : G_SUPP = 0 : # FQ121352
Return

#-------------------------------------------------------------------------------
$RAZCRE
Return

#-------------------------------------------------------------------------------
$RAZDUP
  If COUZON="POSTXS"
    Raz [M:FLU1]GAC
    [M:FLU1]NBGAC=0
    Affzo [M:FLU1]NBGAC
  Endif
Return

#-------------------------------------------------------------------------------
$LIENS
  nolign = 1
  For [PFD]PFD0 Where CODTXS=[M:FLU0]CODTXS and COA=[M:FLU0]COA and POSTXS=[M:FLU0]POSTXS
    [M:FLU1] = [F:PFD]
    nolign  += 1
    # ------------------------------
    # Suite de la boucle
  Next PFD0
  # ------------------------------
  [M:FLU1]NBGAC = nolign-1
  Call ACTION_BLOCK (ACB_AFFZO, "PARFLU1", "NBGAC") From GLOBIENS
  Call AP_CLATXS([M:FLU0]CLATXS)
Return

#-------------------------------------------------------------------------------
$CREATION
  For nolign = 1 To [M:FLU1]NBGAC
    [F:PFD] = [M:FLU1]
    [F:PFD] = [M:FLU0]
    Write [PFD]
    If fstat Then
      GOK = 0
      Call RSTA("PFD",CLECUR1-CLECUR2-num$(CLECUR2(1))) From GLOCK
      Break
    Endif
    # ------------------------------
    # Suite de la boucle
  Next nolign
Return

#-------------------------------------------------------------------------------
$MODIF
  Gosub ANNULE
  Gosub CREATION
Return

#-------------------------------------------------------------------------------
$ANNULE

#*Fq-78383  Delete [PFD] Where CODTXS=[M:FLU0]CODTXS and POSTXS=[M:FLU0]POSTXS
  Delete [PFD] Where CODTXS=[M:FLU0]CODTXS and COA=[M:FLU0]COA and POSTXS=[M:FLU0]POSTXS
  If fstat Then
    GOK = 0
    Call RSTA("PFD",CLECUR1-CLECUR2-num$(CLECUR2(1))) From GLOCK
    Return
  Endif
Return

#-------------------------------------------------------------------------------
$VERIF_CRE
Return

#-------------------------------------------------------------------------------
$VERIF_MOD
Return

#-------------------------------------------------------------------------------

$AV_VERF_ANU

Return

#-------------------------------------------------------------------------------
$VERF_ANU

REPONSE =  0


Trbegin [FLU2]

# Issue X3-57692 add COA in test
Delete [PFD2] Where [F:PFD2]CODTXS=[M:FLU0]CODTXS and COA=[M:FLU0]COA and [F:PFD2]POSTXS=num$([M:FLU0]POSTXS)

If fstat = 1  : # enreg locké
  GOK = -1
  GLOCK = "$PARFLUXDET" : Goto ROLL_ANN
Elsif fstat
  Goto AB_ANN
Endif

# Issue X3-57692 add COA in test
Delete [PFL2] Where [F:PFL2]CODTXS=[M:FLU0]CODTXS and COA=[M:FLU0]COA and [F:PFL2]POSTXS=num$([M:FLU0]POSTXS)

If fstat = 1  : # enreg locké
  GOK = -1
  GLOCK = "$PARFLUX" : Goto ROLL_ANN
Elsif fstat
  Goto AB_ANN
Endif

Commit

OK = 0 # pour ne pas passer dans la suppression standard (TB 06/10/00)

# FQ121352
G_SUPP = 1

Return


$ROLL_ANN

  Rollback
  Call ROLL From GLOCK
  If GROLL : Return
  Else
    Goto VERF_ANU
  Endif
Return

$AB_ANN

 Rollback
 OK = 0 # pour ne pas passer dans la suppression standard

 Return

# FQ121352
$DEVERROU
  If G_SUPP
    G_SUPP = 0
    SUIZON = "CODTXS"
  Endif
Return

# FQ121352
$FIN
# If dim(G_SUPP) >0 : Kill G_SUPP     : Endif # Issue X3-40074
Return

#- FQ 30450 ------------------------------------------------------------------------------
$APRES_CHOI

# Si on fait une demande de suppression et si le 1er poste est non renseigné --> rejet
If REPONSE = GSTAANU and [M:FLU1]GAC (0) = ""
      GERR     = 1
      GMESSAGE = mess(165,7770,1)
      REPONSE  = 0
      Return
Endif

# Si on fait une demande de création et si le 1er poste est non renseigné --> rejet
If (REPONSE = GSTACRE or REPONSE = GSTAENR) and [M:FLU1]GAC (0) = ""
      GERR     = 1
      GMESSAGE = mess(166,7770,1)
      REPONSE  = 0
      Return
Endif


# Si on fait une demande de suppression et si le poste a été utilisé par FXDLIFL --> rejet

If REPONSE = GSTAANU
    # Issue X3-57692 add COA in test and in GMESSAGE
    Filter [F:FLU2] Where [F:FLU2]CODTXS=[M:FLU0]CODTXS and COA=[M:FLU0]COA and [F:FLU2]TXSCAT=num$([M:FLU0]POSTXS)
    Read [F:FLU2] First
    Filter [F:FLU2]
    If fstat = 0
          GERR     = 1
          GMESSAGE = mess(167,7770,1) - [M:FLU0]CODTXS - mess(168,7770,1) - num$([M:FLU0]POSTXS) - '\' + mess(169,7770,1)
&       - '\' +   'CPY=' + [F:FLU2]CPY + ',' -
&                 'TYP=' + num$([F:FLU2]TYP) + ',' -
&                 'COA=' + [F:FLU2]COA + ',' -
&                 'TXSCAT=' + [F:FLU2]TXSCAT + ',' -
&                 'DPRPLN=' + num$([F:FLU2]DPRPLN) + ',' -
&                 'AASREF=' + [F:FLU2]AASREF + ',' -
&                 'FIYSTRDAT=' + format$("DD2",[F:FLU2]FIYSTRDAT) + ',' -
&                 'PERSTRDAT=' + format$("DD2",[F:FLU2]PERSTRDAT)
          REPONSE  = 0
          Return
    Endif
Endif

Return




#-------------------------------------------------------------------------------
$SETBOUT
# Désactivation de l'action   "Changement de clé"
#Call VIREBOUT(CHAINE,"H") From GOBJET
  # FQ90410 : si plus de 2 éléments de clé le Superviseur n'active pas le bouton Supprimer
  If (GREP = "")
    CHAINE += "A"
  Endif
Return

#-------------------------------------------------------------------------------
# Sélection sur liste d'un code flux
#
$SEL_LISTE

  If LISTE = "SELFLU"
    # Sélection liste sur les Flux
      If clalev([F:PFL])=0 : Local File PARFLUX [PFL] : Endif

      NBTEX = 0
      TIT = mess(145,7770,1)

      For [PFL]PFL0(1)
        NBTEX += 1
        TEX(NBTEX)   = [F:PFL]CODTXS
        TEXTE(NBTEX) = [F:PFL]CODTXS
      Next
  Endif
Return

################################################################################
# Ecran : PARFLU0
################################################################################
# FQ101153
Subprog AM_COA(VALEUR)
Variable Char    VALEUR()

  # Alimentation du champ LEG à partir de celui de la législation du modèle comptable
  Read [F:COA]COA0=VALEUR
  If fstat : Raz [F:COA] : Endif
  [M:FLU0]LEG = [F:COA]LEG
End

########################################
Subprog AM_CLATXS(VALEUR)
Variable Integer VALEUR

  # ---------------------------------------------------------------
  # Si la liste des comptes n'est pas vide, on ne peut pas passer à "En cours"
  #   si on n'y est pas déjà, ou quitter "En cours"
  # ---------------------------------------------------------------
  If [M:FLU1]NBGAC > 0 Then
    If [M:FLU0]CLATXS = GML_CFENCOUR and VALEUR <> GML_CFENCOUR Then
      GMESSAGE = mess(119,7770,1) : # Ce changement de classe de flux est interdit lorsque des comptes sont définis
      GERR     = 1
      mkstat   = 2
    Endif
    If [M:FLU0]CLATXS <> GML_CFENCOUR and VALEUR = GML_CFENCOUR Then
      GMESSAGE = mess(119,7770,1) : # Ce changement de classe de flux est interdit lorsque des comptes sont définis
      GERR     = 1
      mkstat   = 2
    Endif
  Endif
End

########################################
Subprog AP_CLATXS(VALEUR)
Variable Integer VALEUR

  # ---------------------------------------------------------------
  # Déterminer la nature de compte en fonction de la classe de taxe
  # Corporelle ou incorporelle    => Immo en service
  # En cours                      => Immo en cours
  #+V5 Autre                      => Immo financiere
  # ---------------------------------------------------------------
If VALEUR = GML_CFENCOUR Then
   [M:FLU0]GACACN = GVML_NIENCOU
Else
   If VALEUR = GML_CFFINANC
      [M:FLU0]GACACN = GVML_NIAUTRE
   Else
       [M:FLU0]GACACN = GVML_NIENSER
   Endif
Endif

End
################################################################################
# Ecran : PARFLU1
################################################################################
########################################
Subprog AM_GAC(VALEUR)
Variable Char    VALEUR()

Local Integer N_I

  # ---------------------------------------------------------------
  # Contrôler que le comptes n'existe pas déjà :
  #   1°) sur une autre ligne pour ce poste de liasse
  #   2°) sur une ligne d'un autre poste de liasse pour le même CODTXS
  # ---------------------------------------------------------------
  For N_I = 1 To [M:FLU1]NBGAC
    If N_I <> nolign Then
      If [M:FLU1]GAC(N_I-1) = VALEUR Then
        GMESSAGE = mess(117,7770,1)-num$(N_I) : # Ce compte est déjà défini à la ligne
        GERR     = 1
        mkstat   = 2
        Break
      Endif
    Endif
    # ------------------------------
    # Suite de la boucle
  Next N_I
  #
  If GERR <> 1 Then
    Filter [PFD] Where CODTXS=[M:FLU0]CODTXS and COA=[M:FLU0]COA and POSTXS<>[M:FLU0]POSTXS and GAC=VALEUR
    Read [PFD]PFD0 Last
    Filter [PFD]
    If fstat>2 Then
      # Tout va bien
    Else
      Read[PF1]PFL0=[F:PFD]CODTXS;[F:PFD]COA;[F:PFD]POSTXS
      GMESSAGE = mess(118,7770,1)-'"'+num$([F:PFD]POSTXS)-[F:PF1]DES+'"': # Ce compte est déjà utilisé sur le poste
      GERR     = 1
      mkstat   = 2
    Endif
  Endif
End

####################################################
# Controle d'existence d'un code flux
# Appellé pour le contrôle de la colonne Flux Liasse
# dans le paramétrage des contextes d'amortissement
#
# Paramètres : 1- zone courante (code flux)
#              2- societe (pour en déduire le pays)
#              3- plan comptable
####################################################
Subprog CONTFLU(AZC, SOCIETE, PLAN)
Variable Char       AZC()
Value    Char       SOCIETE()
Value    Integer    PLAN

  # il est autorisé de ne pas mettre de code flux, sauf pour le plan "Comptable" si le code pays
  # de la société est FR. Dans ce cas, on doit obligatoirement avoir "FR" comme code flux.

  If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif

  Read [CPY]CPY0 = SOCIETE

  #If [CPY]CRY = "FR" and PLAN = G301CPT : # FQ69845
  # La société est en France et on est sur le plan "Comptable" (menu local 301 numéro 1)
  If [F:CPY]LEG = "FRA" and PLAN = G301CPT
  # La société est en legislation Française et on est sur le plan "Comptable" (menu local 301 numéro 1)
  # Remarque : dans ce cas il n'y a pas de contrôle d'existence du flux "FR" dans la table PARFLUX
    If AZC <> "FR"
      GMESSAGE = mess(144,7770,1) # Code flux FR obligatoire
      GERR   = 1
      mkstat = 2
    Endif
  Else
    If AZC <> ""
      # Contrôle d'existence du flux dans la table PARFLUX
      If clalev([F:PFL])=0 : Local File PARFLUX [PFL] : Endif

      Look [PFL]PFL0(1) = AZC

      If [S]fstat = 5
        GMESSAGE = mess(143,7770,1)+" : "+AZC # Flux inexistant : <nom du flux>
        GERR   = 1
        mkstat = 2
      Endif
    Endif
  Endif
End


# Issue X3-57692 control before deleting an account
Subprog AS_NBGAC

  If [M:FLU1]GAC(nolign-1) <> ""

    # Issue X3-57692 add COA in test
    Filter [F:FLU2] Where CODTXS = [M:FLU0]CODTXS and TXSCAT = num$([M:FLU0]POSTXS) and
&                         COA = [M:FLU0]COA and GAC = [M:FLU1]GAC(nolign-1)

    Look [F:FLU2]FLU1 First
    Filter [F:FLU2]

    If fstat=0
       Disable 65 : # status Suppression ligne
    Else
       Enable 65
    Endif
  Endif

End


######################################################################################

