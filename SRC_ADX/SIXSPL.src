#<AdxTL>@(#)7.0.0.0 $Revision$
#########################################################################
#  SIXSPL pour traitements de bascule Integrale --> X3                  #
#########################################################################
# Subprog SI_SPL                                                        #
#     Appele dans le traitement general de bascule                      #
# Subprog SI_X3_TARART                                                  #
#     Recuperation des tarifs de l'article  dans PBAHT et PBATTC        #
#                                                                       #
# Subprog SI_X3_TARDEV                                                  #
#     Recuperation des tarifs en devises dans PDA                       #
#                                                                       #
# Subprog SI_X3_TARQTE                                                  #
#     Recuperation des tarifs quantitatifs dans QAFX QASX QARP QARX     #
#                                                                       #
# Subprog SI_X3_TARCPN ( a voir si possible uterieurement )             #
#     Recuperation des tarifs composants dans TCHT TCTTC                #
#                                                                       #
#########################################################################

#--- Execution directe de la migration tarifs --------------------------#

Global Integer GJL_SIXSPL : GJL_SIXSPL=1
#---
Gosub SI_CONTEXT From SIXFONCTION
#---
SI_SIMUL=2
If !clalev([F:SPX]) : Local File =SI_DOSSIER+".SIPARX3"    [SPX] : Endif

#--- Lecture enregistrement des parametres  
Read [SPX] First

Call EXEC From SIXSPL 

If dim(GJL_SIXSPL)>0 : Kill GJL_SIXSPL : Endif 
End

#########################################################################

Subprog EXEC

Global Integer GJL_PBAHT, GJL_PBATTC, GJL_PDA, GJL_QARP, GJL_QARX, GJL_QAFX, GJL_QASX

Local Char    MESSAGE (250)
Local Integer WOUV_TRACE, WOK
If GTRACE = ""
    Call OUVRE_TRACE(MESSAGE) From LECFIC
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

#--- Ouverture de toutes les tables pour SI_SPL
If !clalev([F:SPC])  : Local File =SI_DOSSIER+".SPRICCONF"  [SPC] : Endif
If !clalev([F:SPF])  : Local File =SI_DOSSIER+".SPRICFICH"  [SPF] : Endif
If !clalev([F:SPL])  : Local File =SI_DOSSIER+".SPRICLIST"  [SPL] : Endif
If !clalev([F:SWX])  : Local File =SI_DOSSIER+".SIWRKX3"    [SWX] : Endif

If !clalev([F:XART]) : Local File =SI_DOSSIER+".XIART"      [XART] : Endif  : # Integrale Articles
If !clalev([F:XTDV]) : Local File =SI_DOSSIER+".XITRFDVS"   [XTDV] : Endif  : # Integrale Tarif devise
If !clalev([F:XTQT]) : Local File =SI_DOSSIER+".XITRFART"   [XTQT] : Endif  : # Integrale Tarif quantitatif article
If !clalev([F:XTQ1]) : Local File =SI_DOSSIER+".XITRFART"   [XTQ1] : Endif  : # Integrale Tarif quantitatif article
                                                                              # ( pour test ruptures quantites ) 
If !clalev([F:XNMC]) : Local File =SI_DOSSIER+".XINMC"      [XNMC] : Endif  : # Integrale Nomenclatures

#--- Test de controle des données importantes de la migration
#    ( verification de valeurs du code activite SPL et de l'affectation du compteur tarif ) 
If [F:SPX]SPLACT<>2
   Call ECR_TRACE(SI_MES(200),1) From GESECRAN  : # La valeur du code activite SPL doit etre confirmee
   Goto FIN_SPL
Endif
If [F:SPX]SPLCPT<>2
   Call ECR_TRACE(SI_MES(201),1) From GESECRAN  : # L affectation du compteur tarif doit etre confirmee
   Goto FIN_SPL
Endif

#----- V6 : Test de contrôle de la structure tarif (code tarif = "") -----#
If !clalev([F:PRS])   Local File =SI_DOSSIER+".PRICSTRUCT" [PRS]  : Endif
Read [PRS] PRS0=1;""
If fstat
   Call ECR_TRACE(SI_MES(272),1) From GESECRAN  : # Structure tarifs clients inexistante ou erronée
   Goto FIN_SPL
Endif
#----- V6

#--- Test de presence des parametrages tarifs
Look [SPC]SPC0="PBAHT"   
If !fstat : GJL_PBAHT=1  : Endif 
Look [SPC]SPC0="PBATTC"   
If !fstat : GJL_PBATTC=1 : Endif 
Look [SPC]SPC0="PDA"   
If !fstat : GJL_PDA=1    : Endif 
Look [SPC]SPC0="QARP"   
If !fstat : GJL_QARP=1   : Endif 
Look [SPC]SPC0="QARX"   
If !fstat : GJL_QARX=1   : Endif 
Look [SPC]SPC0="QAFX"   
If !fstat : GJL_QAFX=1   : Endif 
Look [SPC]SPC0="QASX"   
If !fstat : GJL_QASX=1   : Endif 

#--- Alimentation du compteur fiche tarif
If !clalev ([F:TCA]) : Local File =SI_DOSSIER+".TABCOUAFF"  [TCA] : Endif
#----- V6
#Read [TCA]TCA0=5  
GSOCIETE=[F:SPX]CPY
Call LECTCA(5,WOK) From SUBTCA 
#----- V6
If fstat | !WOK
   Call ECR_TRACE(mess(64,199,1),1) From GESECRAN  : # Aucun compteur n'est affecté à ce document
   GOK=0
   Goto FIN_SPL    
Endif
GCODNUM = [F:TCA]CODNUM(8)

#--- Code activite (nombre de lignes dans une fiche tarif)
Global Integer VALSPL : VALSPL=func AFNC.ACTIV("SPL")
If    VALSPL>500 VALSPL -= 100     : # pour laisser des lignes dispo sur la fiche
Elsif VALSPL>50  VALSPL -= 10 
Endif

#--- Tarifs de base article
MESSAGE=SI_MES(44)+" :  "+mess(42,198,1)-"PBAHT & PBATTC"
Call ECR_TIME(MESSAGE) From DOSSUB
Call SI_X3_TARART

#--- Tarifs en devise
MESSAGE=SI_MES(45)+" :  "+mess(42,198,1)-"PDA" 
Call ECR_TIME(MESSAGE) From DOSSUB
Call SI_X3_TARDEV

#--- Tarifs quantitatifs
MESSAGE=SI_MES(46)+" :  "+mess(42,198,1)-"QAFX QASX QARP & QARX" 
Call ECR_TIME(MESSAGE) From DOSSUB
Call SI_X3_TARQTE

#--- Tarifs composants ( a voir si possible uterieurement )
#MESSAGE=SI_MES(47)+" :  "+mess(42,198,1)-"TCHT TCTTC" 
#Call ECR_TIME(MESSAGE) From DOSSUB
#Call SI_X3_TARCPN


$FIN_SPL
Onerrgo
If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

If dim(GJL_PBAHT)>0  : Kill GJL_PBAHT  : Endif
If dim(GJL_PBATTC)>0 : Kill GJL_PBATTC : Endif
If dim(GJL_PDA)>0    : Kill GJL_PDA    : Endif
If dim(GJL_QARP)>0   : Kill GJL_QARP   : Endif
If dim(GJL_QARX)>0   : Kill GJL_QARX   : Endif
If dim(GJL_QAFX)>0   : Kill GJL_QAFX   : Endif
If dim(GJL_QASX)>0   : Kill GJL_QASX   : Endif

End

#------------------------------------------------------------------------
$TRT_ERR
    Call ECR_TRACE(errp-"("-num$(errl)-") :"-errmes$(errn)-errm, 1) From GESECRAN
    Raz GOK
Resume

#########################################################################
#   Tarifs de base article  
#########################################################################
Subprog SI_X3_TARART

Gosub OUVRE_SXTA
Gosub EXE_SXTA
Gosub FIN_SXTA
End

#------------------------------------------------------------------------
$OUVRE_SXTA

Local Date    DATDEB, DATFIN 
Local Decimal PRIX
Local Integer ORDRE           : # pour ordre des fiches  1=HT1 / 2=HT2 / 3=TTC1 / 4=TTC2
Local Integer CRIFICHE        : # Critere rupture des fiches ( 1=Non defini / 2=Famille / 3=S/Famille )
Local Char    PLI             : # code tarif PBAHT ou PBATTC
Local Integer SWXLIN          : # compteur de ligne interne

Local Char    RUPTFICHE (50)  : # champ de rupture de fiche  
Local Integer SPFLINNBR       : # nbre enregistements mis sur la fiche
Local Char    MESSAGE   (250)

Local Integer NBSPF_PBAHT     : # compteur pour trace
Local Integer NBSPL_PBAHT     : # compteur pour trace
Local Integer NBSPF_PBATTC    : # compteur pour trace
Local Integer NBSPL_PBATTC    : # compteur pour trace

Return

#------------------------------------------------------------------------
$EXE_SXTA

Delete [SPF] Where PLI="PBAHT"   : Delete [SPL] Where PLI="PBAHT" 
Delete [SPF] Where PLI="PBATTC"  : Delete [SPL] Where PLI="PBATTC" 

Gosub DEL_SWX

#--- Si absence de tarifs PBAHT et PBATTC --> pas de migration tarifs articles
If !GJL_PBAHT & !GJL_PBATTC : Return : Endif

#--- Ecriture de la table de travail et tri

SI_TABLE="XIART" : SI_SUBPRG="SI_X3_TARART" : Gosub SI_CRITSUP From SIXFONCTION

# Traitement des articles de nature "Normal" et de nature produit "Composant", "Produit fini" et "Gamme"
# ou de nature "Frais", "Port" et "Service"
# ou les opérations
For [XART] Where (evalue(SI_CRITART) | (NATPDT= "MO" | NATPDT ="OP"))
&              & left$(CODART,2)<>"$$"
&              & evalue(SI_CRITERE)

  GOK=1
  Trbegin [SWX]

    If GJL_PBAHT
       If [F:XART]PRXVENHT1>0    : # ---- creation ligne SWX pour tarif HT 1
          Raz DATDEB, DATFIN, PRIX
          DATDEB=[F:XART]DEBTRF1
          If DATDEB=[0/0/0]
             If [F:XART]DEBTRF2>[0/0/0]  
                DATDEB=addmonth([F:XART]DEBTRF2,-12)
             Else 
#                DATDEB=addmonth(date$,-12) : # 46571
                 If [F:SPX]STRPER<>[0/0/0]
                     DATDEB=gdat$(1,1,year([F:SPX]STRPER))
                 Else
                     DATDEB=addmonth(date$,-12)
                 Endif
             Endif
          Endif
          If      [F:XART]DEBTRF2>DATDEB        : DATFIN=[F:XART]DEBTRF2-1
            Elsif [F:SPX]SPLFINHT1>DATDEB       : DATFIN=[F:SPX]SPLFINHT1
            Else  DATFIN=addmonth(DATDEB,12)-1
          Endif          
          PRIX=[F:XART]PRXVENHT1 : ORDRE=1 : CRIFICHE=[F:SPX]SPLCRIHT1 : PLI="PBAHT" 
          Gosub ECR_SWX_SXTA
       Endif

       If [F:XART]PRXVENHT2>0    : # ---- creation ligne SWX pour tarif HT 2
          Raz DATDEB, DATFIN, PRIX
          DATDEB=[F:XART]DEBTRF2
          If     [F:SPX]SPLFINHT2>DATDEB      : DATFIN=[F:SPX]SPLFINHT2
            Else DATFIN=addmonth(DATDEB,12)-1
          Endif          
          PRIX=[F:XART]PRXVENHT2 : ORDRE=2 : CRIFICHE=[F:SPX]SPLCRIHT2 : PLI="PBAHT" 
          Gosub ECR_SWX_SXTA
       Endif
    Endif

    If GJL_PBATTC
       If [F:XART]PRXVENTTC1>0   : # ---- creation ligne SWX pour tarif TTC 1
          Raz DATDEB, DATFIN, PRIX
          DATDEB=[F:XART]DEBTRF1
          If DATDEB=[0/0/0]
             If [F:XART]DEBTRF2>[0/0/0]  
                DATDEB=addmonth([F:XART]DEBTRF2,-12)
             Else 
#                DATDEB=addmonth(date$,-12) : # 46571
                 If [F:SPX]STRPER<>[0/0/0]
                     DATDEB=gdat$(1,1,year([F:SPX]STRPER))
                 Else
                     DATDEB=addmonth(date$,-12)
                 Endif
             Endif
          Endif
          If      [F:XART]DEBTRF2>DATDEB       : DATFIN=[F:XART]DEBTRF2-1
            Elsif [F:SPX]SPLFINTTC1>DATDEB     : DATFIN=[F:SPX]SPLFINTTC1
            Else  DATFIN=addmonth(DATDEB,12)-1
          Endif          
          PRIX=[F:XART]PRXVENTTC1 : ORDRE=3 : CRIFICHE=[F:SPX]SPLCRITTC1 : PLI="PBATTC" 
          Gosub ECR_SWX_SXTA
       Endif

       If [F:XART]PRXVENTTC2>0   : # ---- creation ligne SWX pour tarif TTC 2
          Raz DATDEB, DATFIN, PRIX
          DATDEB=[F:XART]DEBTRF2
          If    [F:SPX]SPLFINTTC2>DATDEB     : DATFIN=[F:SPX]SPLFINTTC2
            Else  DATFIN=addmonth(DATDEB,12)-1
          Endif          
          PRIX=[F:XART]PRXVENTTC2 : ORDRE=4 : CRIFICHE=[F:SPX]SPLCRITTC2 : PLI="PBATTC" 
          Gosub ECR_SWX_SXTA
       Endif
    Endif

  If GOK>0  Commit
    Else    Rollback
  Endif 

Next

#--- Ecriture des tarifs fiches + lignes

Raz RUPTFICHE, SPFLINNBR
Raz [F:SPF],[F:SPL] 

For [SWX] Where PRONUM=adxuid(1)
    Case val(mid$([F:SWX]SWXKEY,1,1)) 
      When 1,2      PLI="PBAHT"   
      When 3,4      PLI="PBATTC"   
      When Default  PLI=""   
    Endcase

    If SPFLINNBR>=VALSPL-10 : Raz RUPTFICHE : Endif
    If RUPTFICHE<>[F:SWX]SWXKEY
       Gosub ECR_SPF          : # ---- ecrire entete fiche ( lignes deja ecrites )
       RUPTFICHE=[F:SWX]SWXKEY

       GOK=1                  : # ---- debut nouvelle fiche
       Trbegin [SWX]
   
       Raz SPFLINNBR
       Raz [SPF]
       [F:SPF]PLI       = PLI  
       [F:SPF]PLISTRDAT = [F:SWX]SWXDAT(0)
       [F:SPF]PLIENDDAT = [F:SWX]SWXDAT(1)
       [F:SPF]CREUSR    = GUSER
       [F:SPF]CREDAT    = date$
       Gosub NO_FICHE                 : # recherche no de fiche ( avec compteur )  
    Endif

    Raz [F:SPL]
    SPFLINNBR += 1
    [F:SPL]PLI       = [F:SPF]PLI
    [F:SPL]PLICRD    = [F:SPF]PLICRD
    [F:SPL]PLILIN    = SPFLINNBR*1000
    [F:SPL]PLICRI    = [F:SWX]SWXCHR(4)+"~~~~~"
    [F:SPL]PLICRI1   = [F:SWX]SWXCHR(4)
    [F:SPL]PLISTRDAT = [F:SWX]SWXDAT(0)
    [F:SPL]PLIENDDAT = [F:SWX]SWXDAT(1)
    [F:SPL]UOM       = [F:SWX]SWXCHR(1)
    [F:SPL]CUR       = [F:SWX]SWXCHR(0)
    [F:SPL]PRI       = [F:SWX]SWXDCB(0)
    [F:SPL]CREUSR    = GUSER
    [F:SPL]CREDAT    = date$

    SI_TABLE="SPRICLIST" : Gosub SI_BEFWRI From SIXFONCTION : # ---- Appel point d entree
    Write [SPL] 
    If fstat 
       MESSAGE=mess(56,123,1)+" SPRICLIST"-[F:SPL]PLI-[F:SPL]PLICRI1+"  "+func SIXFONCTION.FSTATMSG(fstat)
       Call ECR_TRACE(MESSAGE,1) From GESECRAN
       GOK=0 
    Else
       If [F:SPL]PLI="PBAHT"  : NBSPL_PBAHT  += 1 : Endif
       If [F:SPL]PLI="PBATTC" : NBSPL_PBATTC += 1 : Endif
    Endif

Next

Gosub ECR_SPF                 : # ---- ecrire entete derniere fiche ( lignes deja ecrites )

Return

#------------------------------------------------------------------------
$ECR_SWX_SXTA
Raz [F:SWX]
SWXLIN +=1
[F:SWX]PRONUM = adxuid(1)
[F:SWX]LIN    = SWXLIN   

[F:SWX]SWXCHR(0) = [F:SPX]CUR                                                              : # Devise 
[F:SWX]SWXCHR(1) = func SIXFONCTION.SI_COR("XIUNIFAC",[F:XART]UNIFAC,"","")                : # Unite
[F:SWX]SWXCHR(2) = func SIXFONCTION.SI_COR("XIFAMART",[F:XART]CODFAM,"","")                : # Famille article
[F:SWX]SWXCHR(3) = func SIXFONCTION.SI_COR2("XISOUFMART",[F:XART]CODFAM,[F:XART]CODSOUFAM,"#","") : # S/famille article
[F:SWX]SWXCHR(4) = func SIXFONCTION.SI_COR("XIART",[F:XART]CODART,"","")                   : # Reference article

[F:SWX]SWXDAT (0) = DATDEB
[F:SWX]SWXDAT (1) = DATFIN

[F:SWX]SWXDCB (0) = PRIX

[F:SWX]SWXKEY = num$(ORDRE)
[F:SWX]SWXKEY += "~"+num$(val(DATDEB)) 
[F:SWX]SWXKEY += "~"+num$(val(DATFIN)) 

If CRIFICHE=2                                       : # Famille                                   
   [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(2)               
Endif
If CRIFICHE=3                                       : # Famille + S/famille 
   [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(2)
   [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(3)
Endif

[F:SWX]SWXKEY1 = [F:SWX]SWXCHR(2)+"~"+[F:SWX]SWXCHR(3)+"~"+[F:SWX]SWXCHR(4) 
#                Famille         +    S/famille       +    Articel  

Write [SWX]
If fstat 
   MESSAGE=mess(56,123,1)+" SIWRKX3"-[F:SWX]SWXKEY+"  "+func SIXFONCTION.FSTATMSG(fstat)
   Call ECR_TRACE(MESSAGE,1) From GESECRAN
   GOK=0 
Endif
Return

#------------------------------------------------------------------------
$FIN_SXTA
Gosub DEL_SWX

MESSAGE ="  "+mess(59,123,1)-"SPRICFICH / SPRICLIST"
Call ECR_TRACE(MESSAGE,0) From GESECRAN

If GJL_PBAHT
   MESSAGE ="  "+mess(390,197,1)-"PBAHT    "+mess(56,123,1)+":  SPF = "+num$(NBSPF_PBAHT)+"  SPL = "+num$(NBSPL_PBAHT) 
   Call ECR_TRACE(MESSAGE,0) From GESECRAN
Else
   MESSAGE ="  "+SI_MES(188)-"PBAHT : "+SI_MES(189) 
   Call ECR_TRACE(MESSAGE,1) From GESECRAN
Endif

If GJL_PBATTC
   MESSAGE ="  "+mess(390,197,1)-"PBATTC   "+mess(56,123,1)+":  SPF = "+num$(NBSPF_PBATTC)+"  SPL = "+num$(NBSPL_PBATTC) 
   Call ECR_TRACE(MESSAGE,0) From GESECRAN
Else
   MESSAGE ="  "+SI_MES(188)-"PBATTC : "+SI_MES(190) 
   Call ECR_TRACE(MESSAGE,1) From GESECRAN
Endif

Return


#########################################################################
#   Tarifs en devise  
#########################################################################
Subprog SI_X3_TARDEV

Gosub OUVRE_SXTD
Gosub EXE_SXTD
Gosub FIN_SXTD
End

#------------------------------------------------------------------------
$OUVRE_SXTD
Local Date    DATDEB, DATFIN 
Local Decimal PRIX
Local Integer CRIFICHE        : # Critere rupture des fiches ( 1=Non defini / 2=Famille / 3=S/Famille )
Local Char    PLI             : # code tarif PBAHT ou PBATTC
Local Integer SWXLIN          : # compteur de ligne interne

Local Char    RUPTFICHE (30)  : # champ de rupture de fiche  
Local Integer SPFLINNBR       : # nbre enregistements mis sur la fiche
Local Char    MESSAGE   (250)

Local Integer NBSPF_PDA       : # compteur pour trace
Local Integer NBSPL_PDA       : # compteur pour trace

Local Char    WCODDVS (2)
Local Char    WCODART (16)
Local Char    WMESSAGE(30)
Return

#------------------------------------------------------------------------
$EXE_SXTD

Delete [SPF] Where PLI="PDA"   : Delete [SPL] Where PLI="PDA" 

Gosub DEL_SWX

#--- Si absence de tarifs PDA --> pas de migration tarifs articles en devise
If !GJL_PDA & !GJL_PDA : Return : Endif

#--- Ecriture de la table de travail et tri

Raz DATDEB, DATFIN
If [F:SPX]SPLDEBDEV<>[0/0/0]    DATDEB=[F:SPX]SPLDEBDEV
#  Else                          DATDEB=date$ : # 46571
   Elsif [F:SPX]STRPER<>[0/0/0] DATDEB=gdat$(1,1,year([F:SPX]STRPER))
   Else                         DATDEB=date$
Endif

If [F:SPX]SPLFINDEV>DATDEB      DATFIN=[F:SPX]SPLFINDEV
  Else                          DATFIN=addmonth(DATDEB,12)-1
Endif

CRIFICHE=[F:SPX]SPLCRIDEV

PLI="PDA"

SI_TABLE="XITRFDVS" : SI_SUBPRG="SI_X3_TARDEV" : Gosub SI_CRITSUP From SIXFONCTION
For [XTDV] Where evalue(SI_CRITERE) & [F:XTDV]PRXVENDVS<>0
  If [F:XART]CODART<>[F:XTDV]CODART
     Read [XART]IND0=[F:XTDV]CODART
     If fstat 
        MESSAGE=mess(56,123,1)+" XIART"-[F:XTDV]CODART+"  "+func SIXFONCTION.FSTATMSG(fstat)
        Call ECR_TRACE(MESSAGE,1) From GESECRAN
        Goto NEXT_XTDV
     Endif
  Endif   

  GOK=1
  Trbegin [SWX]

    Raz [F:SWX]
    SWXLIN +=1

    [F:SWX]PRONUM = adxuid(1)
    [F:SWX]LIN    = SWXLIN   

    [F:SWX]SWXCHR(0) = func SIXFONCTION.SI_COR("XIDVS",[F:XTDV]CODDVS,"","")                   : # Devise 
    [F:SWX]SWXCHR(1) = func SIXFONCTION.SI_COR("XIUNIFAC",[F:XART]UNIFAC,"","")                : # Unite
    [F:SWX]SWXCHR(2) = func SIXFONCTION.SI_COR("XIFAMART",[F:XART]CODFAM,"","")                : # Famille article
    [F:SWX]SWXCHR(3) = func SIXFONCTION.SI_COR2("XISOUFMART",[F:XART]CODFAM,[F:XART]CODSOUFAM,"#","") : # S/famille article
    [F:SWX]SWXCHR(4) = func SIXFONCTION.SI_COR("XIART",[F:XART]CODART,"","")                   : # Reference article

    [F:SWX]SWXDAT (0) = DATDEB
    [F:SWX]SWXDAT (1) = DATFIN

    [F:SWX]SWXDCB (0) = [F:XTDV]PRXVENDVS

    [F:SWX]SWXKEY += "~"+num$(val(DATDEB)) 
    [F:SWX]SWXKEY += "~"+num$(val(DATFIN)) 

    If CRIFICHE=2                                       : # Famille                                   
       [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(2)               
    Endif
    If CRIFICHE=3                                       : # Famille + S/famille 
       [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(2)
       [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(3)
    Endif

    If CRIFICHE=4                                       : # Devise + Famille
       [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(0)
       [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(2)
    Endif
    If CRIFICHE=5                                       : # Devise + Famille + S/famille 
       [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(0)              
       [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(2)
       [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(3)
    Endif

    [F:SWX]SWXKEY1 = [F:SWX]SWXCHR(2)+"~"+[F:SWX]SWXCHR(3)+"~"+[F:SWX]SWXCHR(4)+"~"+[F:SWX]SWXCHR(0)  
    #                Famille         +    S/famille       +    Article         +    Devise

    Write [SWX]
    If fstat 
       MESSAGE=mess(56,123,1)+" SIWRKX3"-[F:SWX]SWXKEY+"  "+func SIXFONCTION.FSTATMSG(fstat)
       GOK=0 
    Endif

#   --- Mise à jour indicateur de reprise sur Tarif en devise "Intégrale" 
    WCODDVS=[F:XTDV]CODDVS
    WCODART=[F:XTDV]CODART
    If SI_SIMU<>2
       Update [XTDV] Where CODDVS   =WCODDVS
&                        & CODART   =WCODART
&                    With FLGREP=2
    Endif

  If GOK>0  Commit
    Else    Rollback
  Endif 

$NEXT_XTDV

# ---
If dim(GJL_SIXSPL)<1           : # si lance en direct pas de boite
  Call AFFBOITE(WCODDVS-WCODART) From SUBSIM
Endif
# ---


Next

#--- Ecriture des tarifs fiches + lignes

Raz RUPTFICHE, SPFLINNBR
Raz [F:SPF],[F:SPL] 

For [SWX] Where PRONUM=adxuid(1)

    If SPFLINNBR>=VALSPL-10 : Raz RUPTFICHE : Endif
    If RUPTFICHE<>[F:SWX]SWXKEY
       Gosub ECR_SPF          : # ---- ecrire entete fiche ( lignes deja ecrites )
       RUPTFICHE=[F:SWX]SWXKEY

       GOK=1                  : # ---- debut nouvelle fiche
       Trbegin [SWX]
   
       Raz SPFLINNBR
       Raz [SPF]
       [F:SPF]PLI       = PLI  
       [F:SPF]PLISTRDAT = [F:SWX]SWXDAT(0)
       [F:SPF]PLIENDDAT = [F:SWX]SWXDAT(1)
       [F:SPF]CREUSR    = GUSER
       [F:SPF]CREDAT    = date$
       Gosub NO_FICHE                 : # recherche no de fiche ( avec compteur )  
    Endif

    Raz [F:SPL]
    SPFLINNBR += 1
    [F:SPL]PLI       = [F:SPF]PLI
    [F:SPL]PLICRD    = [F:SPF]PLICRD
    [F:SPL]PLILIN    = SPFLINNBR*1000
    [F:SPL]PLICRI    = [F:SWX]SWXCHR(4)+"~~~~~"
    [F:SPL]PLICRI1   = [F:SWX]SWXCHR(4)
    [F:SPL]PLISTRDAT = [F:SWX]SWXDAT(0)
    [F:SPL]PLIENDDAT = [F:SWX]SWXDAT(1)
    [F:SPL]UOM       = [F:SWX]SWXCHR(1)
    [F:SPL]CUR       = [F:SWX]SWXCHR(0)
    [F:SPL]PRI       = [F:SWX]SWXDCB(0)
    [F:SPL]CREUSR    = GUSER
    [F:SPL]CREDAT    = date$

    SI_TABLE="SPRICLIST" : Gosub SI_BEFWRI From SIXFONCTION : # ---- Appel point d entree
    Write [SPL] 
    If fstat 
       MESSAGE=mess(56,123,1)+" SPRICLIST"-[F:SPL]PLI-[F:SPL]PLICRI1+"  "+func SIXFONCTION.FSTATMSG(fstat)
       Call ECR_TRACE(MESSAGE,1) From GESECRAN
       GOK=0 
    Else
       NBSPL_PDA  += 1 
    Endif

Next

Gosub ECR_SPF                 : # ---- ecrire entete derniere fiche ( lignes deja ecrites )

Return

#------------------------------------------------------------------------
$FIN_SXTD
Gosub DEL_SWX

MESSAGE ="  "+mess(59,123,1)-"SPRICFICH / SPRICLIST"
Call ECR_TRACE(MESSAGE,0) From GESECRAN

If GJL_PDA
   MESSAGE ="  "+mess(390,197,1)-"PDA      "+mess(56,123,1)+":  SPF = "+num$(NBSPF_PDA)+"  SPL = "+num$(NBSPL_PDA) 
   Call ECR_TRACE(MESSAGE,0) From GESECRAN
Else
   MESSAGE ="  "+SI_MES(188)-"PDA : "+SI_MES(191) 
   Call ECR_TRACE(MESSAGE,1) From GESECRAN
Endif

Return


#########################################################################
#   Tarifs quantitatifs   
#########################################################################
Subprog SI_X3_TARQTE

Gosub OUVRE_SXTQ
Gosub EXE_SXTQ
Gosub FIN_SXTQ

End

#------------------------------------------------------------------------
$OUVRE_SXTQ

If !clalev([F:TUN])  : Local File =SI_DOSSIER+".TABUNIT"    [TUN] : Endif
If !clalev([F:TCU])  : Local File =SI_DOSSIER+".TABCUR"     [TCU] : Endif
If !clalev([F:ATY])  : Local File =SI_DOSSIER+".ATYPE"      [ATY] : Endif
If !clalev([M:SPLW]) : Local Mask =SI_DOSSIER+".SPLW"       [SPLW] : Endif

Local Date    DATDEB, DATFIN 

Local Integer CRIFICHE        : # Critere rupture fiches ( 1=Non defini / 2=Fam / 3=S/Fam )
Local Char    PLI             : # code tarif QAFX QASX QARX ou QARP
Local Integer SWXLIN          : # compteur de ligne interne

Local Char    RUPTFICHE (30)  : # champ de rupture de fiche  
Local Integer SPFLINNBR       : # nbre enregistements mis sur la fiche
Local Char    MESSAGE   (250)
Local Integer ORDRE 

Local Integer NBDECRAT,NBDECPRX,NBDECMNT,NBDECQTY
Local Decimal ARRRAT,ARRPRX,ARRMNT,ARRQTY

Local Integer NBSPF_QAFX    : # compteur pour trace
Local Integer NBSPL_QAFX    : # compteur pour trace
Local Integer NBSPF_QASX    : # compteur pour trace
Local Integer NBSPL_QASX    : # compteur pour trace
Local Integer NBSPF_QARX    : # compteur pour trace
Local Integer NBSPL_QARX    : # compteur pour trace
Local Integer NBSPF_QARP    : # compteur pour trace
Local Integer NBSPL_QARP    : # compteur pour trace

Local Char    WCODART (16)
Local Char    WCODFAMART (2)
Local Char    WSOUFAMART (2)
Local Decimal WQTEMIN
Local Char    WMESSAGE (30)

#---- V6 : Lecture structure tarif pour récupérer le format de la remise en %
If !clalev([F:PRS])   Local File =SI_DOSSIER+".PRICSTRUCT" [PRS]  : Endif
Read [PRS] PRS0=1;""
#---- Récupération format 1ère colonne : 1ère remise
If fstat NBDECRAT=2 Else NBDECRAT=mod(val([F:PRS]FMTCOL(0)),1)*10 Endif
#Read [ATY]CODTYP="RAT"
#If fstat NBDECRAT=2 Else NBDECRAT=mod(val([F:ATY]FORTYP),1)*10 Endif
#---- V6
NBDECPRX=3  :         : # les prix sont avec 3 décimales ( nombre de décimales dans Intégrale )
ARRRAT=10^-NBDECRAT : ARRPRX=10^-NBDECPRX
Read [TCU]TCU0=[F:SPX]CUR
If fstat  ARRMNT=0.001  Else  ARRMNT=[F:TCU]CURRND  Endif

Return

#------------------------------------------------------------------------
$EXE_SXTQ

Delete [SPF] Where PLI="QAFX"  : Delete [SPL] Where PLI="QAFX" 
Delete [SPF] Where PLI="QASX"  : Delete [SPL] Where PLI="QASX" 
Delete [SPF] Where PLI="QARX"  : Delete [SPL] Where PLI="QARX" 
Delete [SPF] Where PLI="QARP"  : Delete [SPL] Where PLI="QARP" 

Gosub DEL_SWX

#--- Si absence de tarifs QARP QARX QAFX QASX --> pas de migration tarifs quantitatif
If !GJL_QARP & !GJL_QARX & !GJL_QAFX & !GJL_QASX : Return : Endif

#--- Ecriture de la table de travail et tri

SI_TABLE="XITRFART" : SI_SUBPRG="SI_X3_TARQTE" : Gosub SI_CRITSUP From SIXFONCTION
For [XTQT] Where evalue(SI_CRITERE) & instr(1,CODART,"*")=0
  GOK=1
  Trbegin [SWX]

    If [F:XTQT]CODART<>""     : # ---- creation ligne SWX pour tarif QARX ou QARP
       Raz DATDEB, DATFIN
       If [F:SPX]SPLDEBQAR<>[0/0/0]  DATDEB=[F:SPX]SPLDEBQAR
#         Else                        DATDEB=date$ : # 46571
         Elsif [F:SPX]STRPER<>[0/0/0] DATDEB=gdat$(1,1,year([F:SPX]STRPER))
         Else                         DATDEB=date$
       Endif
       If [F:SPX]SPLFINQAR>DATDEB    DATFIN=[F:SPX]SPLFINQAR
         Else                        DATFIN=addmonth(DATDEB,12)-1
       Endif
       
       If [F:XART]CODART<>[F:XTQT]CODART
          Read [XART]IND0=[F:XTQT]CODART
         If fstat=5 
            Goto NEXT_XTQT    : # concerne les articles generiques qui ne sont pas dans la base article  
         Elsif fstat 
            MESSAGE=mess(56,123,1)+" XIART"-[F:XTQT]CODART+"  "+func SIXFONCTION.FSTATMSG(fstat)
            Call ECR_TRACE(MESSAGE,1) From GESECRAN
            Goto NEXT_XTQT
          Endif
       Endif   
       If [F:XTQT]PRXVEN<>0
          ORDRE=1 : CRIFICHE=[F:SPX]SPLCRIQAR : PLI="QARP" 
       Else
          ORDRE=2 : CRIFICHE=[F:SPX]SPLCRIQAR : PLI="QARX" 
       Endif
       Gosub ECR_SWX_SXTQ
       Goto NEXT_XTQT
    Endif

    If [F:XTQT]SOUFAMART<>""  : # ---- creation ligne SWX pour tarif QASX
       If [F:XTQT]PRXVEN<>0 | sum([F:XTQT]REMVAL,[F:XTQT]TAUREM)=0 : Goto NEXT_XTQT : Endif
       Raz DATDEB, DATFIN
       If [F:SPX]SPLDEBQAS<>[0/0/0]  DATDEB=[F:SPX]SPLDEBQAS
#         Else                        DATDEB=date$ : # 46571
         Elsif [F:SPX]STRPER<>[0/0/0] DATDEB=gdat$(1,1,year([F:SPX]STRPER))
         Else                         DATDEB=date$
       Endif
       If [F:SPX]SPLFINQAS>DATDEB    DATFIN=[F:SPX]SPLFINQAS
         Else                        DATFIN=addmonth(DATDEB,12)-1
       Endif

       Raz [F:XART] 
       ORDRE=3 : CRIFICHE=[F:SPX]SPLCRIQAS : PLI="QASX" 
       Gosub ECR_SWX_SXTQ
       Goto NEXT_XTQT
    Endif

    If [F:XTQT]CODFAMART<>""  : # ---- creation ligne SWX pour tarif QAFX
       If [F:XTQT]PRXVEN<>0 | sum([F:XTQT]REMVAL,[F:XTQT]TAUREM)=0 : Goto NEXT_XTQT : Endif
       Raz DATDEB, DATFIN
       If [F:SPX]SPLDEBQAF<>[0/0/0]  DATDEB=[F:SPX]SPLDEBQAF
#         Else                        DATDEB=date$ : # 46571
         Elsif [F:SPX]STRPER<>[0/0/0] DATDEB=gdat$(1,1,year([F:SPX]STRPER))
         Else                         DATDEB=date$
       Endif
       If [F:SPX]SPLFINQAF>DATDEB    DATFIN=[F:SPX]SPLFINQAF
         Else                        DATFIN=addmonth(DATDEB,12)-1
       Endif

       Raz [F:XART] 
       ORDRE=4 : CRIFICHE=[F:SPX]SPLCRIQAF : PLI="QAFX" 
       Gosub ECR_SWX_SXTQ
       Goto NEXT_XTQT
    Endif

$NEXT_XTQT
#   --- Mise à jour indicateur de reprise sur Tarif en devise "Intégrale" 
    WCODART   =[F:XTQT]CODART
    WCODFAMART=[F:XTQT]CODFAMART
    WSOUFAMART=[F:XTQT]SOUFAMART
    WQTEMIN   =[F:XTQT]QTEMIN
    If SI_SIMU<>2
       Update [XTQT] Where CODART   =WCODART
&                        & CODFAMART=WCODFAMART
&                        & SOUFAMART=WSOUFAMART
&                        & QTEMIN   =WQTEMIN
&                    With FLGREP=2
    Endif

  If GOK>0  Commit
    Else    Rollback
  Endif 

# ---
  Raz WMESSAGE
  Case ORDRE
      When 1    WMESSAGE = "QARP : "+WCODART
      When 2    WMESSAGE = "QARX : "+WCODART
      When 3    WMESSAGE = "QASX : "+WCODFAMART+" "+WSOUFAMART
      When 4    WMESSAGE = "QAFX : "+WCODFAMART
  Endcase

If dim(GJL_SIXSPL)<1           : # si lance en direct pas de boite
  Call AFFBOITE(WMESSAGE) From SUBSIM
Endif
# ---

Next

#--- Ecriture des tarifs fiches + lignes

Raz RUPTFICHE, SPFLINNBR
Raz [F:SPF],[F:SPL] 

For [SWX] Where PRONUM=adxuid(1)
    Case val(mid$([F:SWX]SWXKEY,1,1)) 
      When 1        PLI="QARP"   
      When 2        PLI="QARX"   
      When 3        PLI="QASX"   
      When 4        PLI="QAFX" 
      When Default  PLI=""   
    Endcase

    If SPFLINNBR>=VALSPL-10 : Raz RUPTFICHE : Endif
    If RUPTFICHE<>[F:SWX]SWXKEY
       Gosub ECR_SPF_SXTQ          : # ---- ecrire entete fiche + lignes stockées dans [M:SPLW] 
       RUPTFICHE=[F:SWX]SWXKEY
       Raz SPFLINNBR
       Raz [SPF]
       [F:SPF]PLI       = PLI  
       [F:SPF]PLISTRDAT = [F:SWX]SWXDAT(0)
       [F:SPF]PLIENDDAT = [F:SWX]SWXDAT(1)
       [F:SPF]CREUSR    = GUSER
       [F:SPF]CREDAT    = date$
       Gosub NO_FICHE                 : # recherche no de fiche ( avec compteur )  
       Raz nolign : Raz [M:SPLW]
   Endif

   nolign +=1

   If PLI="QARP" : [M:SPLW]CRIT1(nolign-1)=[F:SWX]SWXCHR(4) : Endif
   If PLI="QARX" : [M:SPLW]CRIT1(nolign-1)=[F:SWX]SWXCHR(4) : Endif
   If PLI="QASX" : [M:SPLW]CRIT1(nolign-1)=[F:SWX]SWXCHR(2) 
                   [M:SPLW]CRIT2(nolign-1)=[F:SWX]SWXCHR(3) : Endif
   If PLI="QAFX" : [M:SPLW]CRIT1(nolign-1)=[F:SWX]SWXCHR(2) : Endif
   
   [M:SPLW]CUR(nolign-1)=[F:SWX]SWXCHR(0)
   [M:SPLW]UOM(nolign-1)=[F:SWX]SWXCHR(1)
   [M:SPLW]MINQTY(nolign-1)=[F:SWX]SWXDCB(0)
   [M:SPLW]MAXQTY(nolign-1)=[F:SWX]SWXDCB(1)

#   If [F:SWX]SWXDCB(2)>0 : [M:SPLW]XFRAREM1(nolign-1)=[F:SWX]SWXDCB(2)    : Endif  : # Taux remise +      
#   If [F:SWX]SWXDCB(2)<0 : [M:SPLW]XFRAREM4(nolign-1)=[F:SWX]SWXDCB(2)*-1 : Endif  : # Taux remise -      
#   If [F:SWX]SWXDCB(3)>0 : [M:SPLW]XFRAREM3(nolign-1)=[F:SWX]SWXDCB(3)    : Endif  : # Mont remise +      
#   If [F:SWX]SWXDCB(3)<0 : [M:SPLW]XFRAREM5(nolign-1)=[F:SWX]SWXDCB(3)*-1 : Endif  : # Mont remise -      
   #-- Taux remise article positif
   If [F:SWX]SWXDCB(2)>0   
      If evalue ("dim([M:SPLW]XFRAREM"+num$([F:SPX]DISCRGVEN(0))+")") >0
         Assign "[M:SPLW]XFRAREM"+num$([F:SPX]DISCRGVEN(0))+"(nolign-1)" With [F:SWX]SWXDCB(2)
      Endif
   Endif
   #-- Taux remise article negatif
   If [F:SWX]SWXDCB(2)<0   
      If evalue ("dim([M:SPLW]XFRAREM"+num$([F:SPX]DISCRGVEN(1))+")") >0
         Assign "[M:SPLW]XFRAREM"+num$([F:SPX]DISCRGVEN(1))+"(nolign-1)" With [F:SWX]SWXDCB(2)*-1
      Endif
   Endif
   #-- Mont remise article positif
   If [F:SWX]SWXDCB(3)>0   
      If evalue ("dim([M:SPLW]XFRAREM"+num$([F:SPX]DISCRGVEN(2))+")") >0
         Assign "[M:SPLW]XFRAREM"+num$([F:SPX]DISCRGVEN(2))+"(nolign-1)" With [F:SWX]SWXDCB(3)
      Endif
   Endif
   #-- Mont remise article negatif
   If [F:SWX]SWXDCB(3)<0   
      If evalue ("dim([M:SPLW]XFRAREM"+num$([F:SPX]DISCRGVEN(3))+")") >0
         Assign "[M:SPLW]XFRAREM"+num$([F:SPX]DISCRGVEN(3))+"(nolign-1)" With [F:SWX]SWXDCB(3)*-1
      Endif
   Endif

   If [F:SWX]SWXDCB(4)>0 : [M:SPLW]PRI(nolign-1)=[F:SWX]SWXDCB(4)         : Endif  : # Prix de vente      

   [M:SPLW]LTI(nolign-1)=[F:SWX]SWXINT(0)    : # utilisation de LTI pour stocker le nbre de decimales

Next

Gosub ECR_SPF_SXTQ          : # ---- ecrire entete fiche + lignes stockées dans [M:SPLW] (dernière fiche) 

Return

#------------------------------------------------------------------------
$ECR_SWX_SXTQ

If !GJL_QARP & ORDRE=1 : Return : Endif
If !GJL_QARX & ORDRE=2 : Return : Endif
If !GJL_QASX & ORDRE=3 : Return : Endif
If !GJL_QAFX & ORDRE=4 : Return : Endif

Raz [F:SWX]
SWXLIN +=1
[F:SWX]PRONUM = adxuid(1)
[F:SWX]LIN    = SWXLIN   

[F:SWX]SWXCHR(0) = [F:SPX]CUR                                                                 : # Devise 
If find(ORDRE,1,2)
   [F:SWX]SWXCHR(1) = func SIXFONCTION.SI_COR("XIUNIFAC",[F:XART]UNIFAC,"","")                : # Unite
   [F:SWX]SWXCHR(2) = func SIXFONCTION.SI_COR("XIFAMART",[F:XART]CODFAM,"","")                : # Famille article
   [F:SWX]SWXCHR(3) = func SIXFONCTION.SI_COR2("XISOUFMART",[F:XART]CODFAM,[F:XART]CODSOUFAM,"#","") : # S/famille article
   [F:SWX]SWXCHR(4) = func SIXFONCTION.SI_COR("XIART",[F:XTQT]CODART,"","")                   : # Reference article
Endif
If ORDRE=3
   [F:SWX]SWXCHR(1) = "*" 
   [F:SWX]SWXCHR(2) = func SIXFONCTION.SI_COR("XIFAMART",[F:XTQT]CODFAMART,"","")             : # Famille article
   [F:SWX]SWXCHR(3) = func SIXFONCTION.SI_COR2("XISOUFMART",[F:XTQT]CODFAMART,[F:XTQT]SOUFAMART,"#","") : # S/famille article
Endif
If ORDRE=4
   [F:SWX]SWXCHR(1) = "*"
   [F:SWX]SWXCHR(2) = func SIXFONCTION.SI_COR("XIFAMART",[F:XTQT]CODFAMART,"","")             : # Famille article
Endif

#--- recherche nbre de decimales pour les qtes 
Raz NBDECQTY,ARRQTY 

If [F:SWX]SWXCHR(1)<>"*"
   If [F:TUN]UOM<>[F:SWX]SWXCHR(1) 
      Read [TUN]TUN0=[F:SWX]SWXCHR(1)
      If !fstat NBDECQTY=[F:TUN]UOMDEC Endif
      ARRQTY=10^-NBDECQTY
   Endif
   [F:SWX]SWXINT(0)=[F:TUN]UOMDEC
Endif

[F:SWX]SWXDAT (0) = DATDEB
[F:SWX]SWXDAT (1) = DATFIN

[F:SWX]SWXDCB (0) = arr([F:XTQT]QTEMIN,ARRQTY)

Read [XTQ1]IND0=[F:XTQT]CODART;[F:XTQT]CODFAMART;[F:XTQT]SOUFAMART;[F:XTQT]QTEMIN
If !fstat
   Read [XTQ1]Next
   If !fstat
      If [F:XTQ1]CODART=[F:XTQT]CODART & [F:XTQ1]CODFAMART=[F:XTQT]CODFAMART & [F:XTQ1]SOUFAMART=[F:XTQT]SOUFAMART
         [F:SWX]SWXDCB(1)=arr([F:XTQ1]QTEMIN,ARRQTY)
      Endif
   Endif
Endif
If [F:SWX]SWXDCB(1)=0
   Case [F:SWX]SWXINT(0)
       When 0   [F:SWX]SWXDCB(1) = 99999999999
       When 1   [F:SWX]SWXDCB(1) = 9999999999.9
       When 2   [F:SWX]SWXDCB(1) = 999999999.99
       When 3   [F:SWX]SWXDCB(1) = 99999999.999
       When 4   [F:SWX]SWXDCB(1) = 9999999.9999
       When 5   [F:SWX]SWXDCB(1) = 999999.99999
       When 6   [F:SWX]SWXDCB(1) = 99999.999999
   Endcase       
Else
   Case [F:SWX]SWXINT(0)
       When 0   [F:SWX]SWXDCB(1) -= 1
       When 1   [F:SWX]SWXDCB(1) -= 0.1
       When 2   [F:SWX]SWXDCB(1) -= 0.01
       When 3   [F:SWX]SWXDCB(1) -= 0.001
       When 4   [F:SWX]SWXDCB(1) -= 0.0001
       When 5   [F:SWX]SWXDCB(1) -= 0.00001
       When 6   [F:SWX]SWXDCB(1) -= 0.000001
   Endcase       
Endif

# garnir borne maxi

[F:SWX]SWXDCB (2) = arr([F:XTQT]TAUREM,ARRRAT)
[F:SWX]SWXDCB (3) = arr([F:XTQT]REMVAL,ARRMNT)
If ORDRE=1
   [F:SWX]SWXDCB (4) = [F:XTQT]PRXVEN
Endif

[F:SWX]SWXKEY = num$(ORDRE)
[F:SWX]SWXKEY += "~"+num$(val(DATDEB)) 
[F:SWX]SWXKEY += "~"+num$(val(DATFIN)) 

If CRIFICHE=2                                       : # Famille                                   
   [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(2)               
Endif
If CRIFICHE=3                                       : # Famille + S/famille 
   [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(2)
   [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(3)
Endif

If find(PLI,"QARP","QARX")
   [F:SWX]SWXKEY1 = [F:SWX]SWXCHR(2)+"~"+[F:SWX]SWXCHR(3)+"~"+[F:SWX]SWXCHR(4) 
   #                Famille         +    S/famille       +    Article  
Endif
#If find(PLI,"QTAF","QTAS") 
If find(PLI,"QAFX","QASX") 
   [F:SWX]SWXKEY1 = [F:SWX]SWXCHR(2)+"~"+[F:SWX]SWXCHR(3) 
   #                Famille         +    S/famille    
Endif

Write [SWX]
If fstat 
   MESSAGE=mess(56,123,1)+" SIWRKX3"-[F:SWX]SWXKEY+"  "+func SIXFONCTION.FSTATMSG(fstat)
   Call ECR_TRACE(MESSAGE,1) From GESECRAN
   GOK=0 
Endif

Return

#------------------------------------------------------------------------
$ECR_SPF_SXTQ
Local Integer IJ0,IJFIN,IJMAX
If [F:SPF]PLI="" : Return : Endif

GOK=1
Trbegin [SPL]

For IJ0=0 To dim([M:SPLW]CRIT1)-1

    If [M:SPLW]CRIT1(IJ0)="" : Break : Endif

    Raz [F:SPL]
    SPFLINNBR += 1
    [F:SPL]PLI       = [F:SPF]PLI
    [F:SPL]PLICRD    = [F:SPF]PLICRD
    [F:SPL]PLILIN    = SPFLINNBR*1000
    [F:SPL]PLICRI    = [M:SPLW]CRIT1(IJ0)+"~"+[M:SPLW]CRIT2(IJ0)+"~~~~"
    [F:SPL]PLICRI1   = [M:SPLW]CRIT1(IJ0)
    [F:SPL]PLICRI2   = [M:SPLW]CRIT2(IJ0)
    [F:SPL]PLISTRDAT = [F:SPF]PLISTRDAT
    [F:SPL]PLIENDDAT = [F:SPF]PLIENDDAT
    [F:SPL]UOM       = [M:SPLW]UOM(IJ0)
    [F:SPL]CUR       = [M:SPLW]CUR(IJ0)
    [F:SPL]MINQTY    = [M:SPLW]MINQTY(IJ0)
    [F:SPL]MAXQTY    = [M:SPLW]MAXQTY(IJ0)
    [F:SPL]PRI       = [M:SPLW]PRI(IJ0)
    [F:SPL]DCGVAL(0) = [M:SPLW]XFRAREM1(IJ0)
    [F:SPL]DCGVAL(1) = [M:SPLW]XFRAREM2(IJ0)
    [F:SPL]DCGVAL(2) = [M:SPLW]XFRAREM3(IJ0)
    [F:SPL]DCGVAL(3) = [M:SPLW]XFRAREM4(IJ0)
    [F:SPL]DCGVAL(4) = [M:SPLW]XFRAREM5(IJ0)
    [F:SPL]DCGVAL(5) = [M:SPLW]XFRAREM6(IJ0)
    [F:SPL]DCGVAL(6) = [M:SPLW]XFRAREM7(IJ0)
    [F:SPL]DCGVAL(7) = [M:SPLW]XFRAREM8(IJ0)
    [F:SPL]DCGVAL(8) = [M:SPLW]XFRAREM9(IJ0)
    [F:SPL]CREUSR    = GUSER
    [F:SPL]CREDAT    = date$

    SI_TABLE="SPRICLIST" : Gosub SI_BEFWRI From SIXFONCTION : # ---- Appel point d entree
    Write [SPL] 
    If fstat 
       MESSAGE=mess(56,123,1)+" SPRICLIST"-[F:SPL]PLI-[F:SPL]PLICRI1+"  "+func SIXFONCTION.FSTATMSG(fstat)
       Call ECR_TRACE(MESSAGE,1) From GESECRAN
       GOK=0 
    Else
       If [F:SPL]PLI="QARP" : NBSPL_QARP += 1 : Endif
       If [F:SPL]PLI="QARX" : NBSPL_QARX += 1 : Endif
       If [F:SPL]PLI="QASX" : NBSPL_QASX += 1 : Endif
       If [F:SPL]PLI="QAFX" : NBSPL_QAFX += 1 : Endif
    Endif

Next IJ0

#--- Ecrire la fiche SPF 

Gosub ECR_SPF

Return


#------------------------------------------------------------------------
$FIN_SXTQ
Gosub DEL_SWX

MESSAGE ="  "+mess(59,123,1)-"SPRICFICH / SPRICLIST"
Call ECR_TRACE(MESSAGE,0) From GESECRAN

If GJL_QAFX
   MESSAGE ="  "+mess(390,197,1)-"QAFX     "+mess(56,123,1)+":  SPF = "+num$(NBSPF_QAFX)+"  SPL = "+num$(NBSPL_QAFX) 
   Call ECR_TRACE(MESSAGE,0) From GESECRAN
Else
   MESSAGE ="  "+SI_MES(188)-"QAFX : "+SI_MES(193) 
   Call ECR_TRACE(MESSAGE,1) From GESECRAN
Endif

If GJL_QASX
   MESSAGE ="  "+mess(390,197,1)-"QASX     "+mess(56,123,1)+":  SPF = "+num$(NBSPF_QASX)+"  SPL = "+num$(NBSPL_QASX) 
   Call ECR_TRACE(MESSAGE,0) From GESECRAN
Else
   MESSAGE ="  "+SI_MES(188)-"QASX : "+SI_MES(194) 
   Call ECR_TRACE(MESSAGE,1) From GESECRAN
Endif

If GJL_QARX
   MESSAGE ="  "+mess(390,197,1)-"QARX     "+mess(56,123,1)+":  SPF = "+num$(NBSPF_QARX)+"  SPL = "+num$(NBSPL_QARX) 
   Call ECR_TRACE(MESSAGE,0) From GESECRAN
Else
   MESSAGE ="  "+SI_MES(188)-"QARX : "+SI_MES(192) 
   Call ECR_TRACE(MESSAGE,1) From GESECRAN
Endif

If GJL_QARP
   MESSAGE ="  "+mess(390,197,1)-"QARP     "+mess(56,123,1)+":  SPF = "+num$(NBSPF_QARP)+"  SPL = "+num$(NBSPL_QARP) 
   Call ECR_TRACE(MESSAGE,0) From GESECRAN
Else
   MESSAGE ="  "+SI_MES(188)-"QARP : "+SI_MES(192) 
   Call ECR_TRACE(MESSAGE,1) From GESECRAN
Endif

Return


#########################################################################
#   Tarifs composant  
#------------------------------------------------------------------------
#   NE PAS SUPPRIMER : DEVELOPPEMENT ULTERIEUR SI INDISPENSABLE
#########################################################################
Subprog SI_X3_TARCPN
End

Gosub OUVRE_SXTC
Gosub EXE_SXTC
Gosub FIN_SXTC
End

#------------------------------------------------------------------------
$OUVRE_SXTC

Local Date    DATDEB, DATFIN 
Local Decimal PRIX
Local Integer ORDRE           : # pour ordre des fiches  1=HT / 2=TTC
Local Integer CRIFICHE        : # Critere rupture des fiches ( 1=Non defini / 2=Famille / 3=S/Famille )
Local Char    PLI             : # code tarif TCHT ou TCTTC
Local Integer SWXLIN          : # compteur de ligne interne

Local Char    RUPTFICHE (50)  : # champ de rupture de fiche  
Local Integer SPFLINNBR       : # nbre enregistements mis sur la fiche
Local Char    MESSAGE   (250)

Local Integer NBSPF_TCHT      : # compteur pour trace
Local Integer NBSPL_TCHT      : # compteur pour trace
Local Integer NBSPF_TCTTC     : # compteur pour trace
Local Integer NBSPL_TCTTC     : # compteur pour trace

Return

#------------------------------------------------------------------------
$EXE_SXTC

Delete [SPF] Where PLI="TCHT"   : Delete [SPL] Where PLI="TCHT" 
Delete [SPF] Where PLI="TCTTC"  : Delete [SPL] Where PLI="TCTTC" 

Gosub DEL_SWX

#--- Ecriture de la table de travail et tri

SI_TABLE="XINMC" : SI_SUBPRG="SI_X3_TARCPN" : Gosub SI_CRITSUP From SIXFONCTION

For [XNMC] Where evalue(SI_CRITERE) 
&              & left$(CODART,2)<>"$$"

  GOK=1
  Trbegin [SWX]
    If [F:XART]PRXVENHT1>0    : # ---- creation ligne SWX pour tarif HT 
       Raz DATDEB, DATFIN
       DATDEB=[F:XART]DEBTRF1
       If    [F:XART]DEBTRF2>DATDEB        : DATFIN=[F:XART]DEBTRF2-1
       Elsif [F:SPX]SPLFINHT1>DATDEB       : DATFIN=[F:SPX]SPLFINHT1
       Else  DATFIN=addmonth(DATDEB,12)-1
       Endif          
       PRIX=[F:XART]PRXVENHT1 : ORDRE=1 : CRIFICHE=[F:SPX]SPLCRIHT1 : PLI="PBAHT" 
       Gosub ECR_SWX_SXTA
    Endif

    If [F:XART]PRXVENHT2>0    : # ---- creation ligne SWX pour tarif HT 2
       Raz DATDEB, DATFIN
       DATDEB=[F:XART]DEBTRF2
       If    [F:SPX]SPLFINHT2>DATDEB      : DATFIN=[F:SPX]SPLFINHT2
       Else  DATFIN=addmonth(DATDEB,12)-1
       Endif          
       PRIX=[F:XART]PRXVENHT2 : ORDRE=2 : CRIFICHE=[F:SPX]SPLCRIHT2 : PLI="PBAHT" 
       Gosub ECR_SWX_SXTA
    Endif

    If [F:XART]PRXVENTTC1>0   : # ---- creation ligne SWX pour tarif TTC 1
       Raz DATDEB, DATFIN
       DATDEB=[F:XART]DEBTRF1
       If    [F:XART]DEBTRF2>DATDEB       : DATFIN=[F:XART]DEBTRF2-1
       Elsif [F:SPX]SPLFINTTC1>DATDEB     : DATFIN=[F:SPX]SPLFINTTC1
       Else  DATFIN=addmonth(DATDEB,12)-1
       Endif          
       PRIX=[F:XART]PRXVENTTC1 : ORDRE=3 : CRIFICHE=[F:SPX]SPLCRITTC1 : PLI="PBATTC" 
       Gosub ECR_SWX_SXTA
    Endif

    If [F:XART]PRXVENTTC2>0   : # ---- creation ligne SWX pour tarif TTC 1
       Raz DATDEB, DATFIN
       DATDEB=[F:XART]DEBTRF2
       If    [F:SPX]SPLFINTTC2>DATDEB     : DATFIN=[F:SPX]SPLFINTTC2
       Else  DATFIN=addmonth(DATDEB,12)-1
       Endif          
       PRIX=[F:XART]PRXVENTTC2 : ORDRE=4 : CRIFICHE=[F:SPX]SPLCRITTC2 : PLI="PBATTC" 
       Gosub ECR_SWX_SXTA
    Endif

  If GOK>0  Commit
    Else    Rollback
  Endif 

Next

#--- Ecriture des tarifs fiches + lignes

Raz RUPTFICHE, SPFLINNBR
Raz [F:SPF],[F:SPL] 

For [SWX] Where PRONUM=adxuid(1)
    Case val(mid$([F:SWX]SWXKEY,1,1)) 
      When 1,2      PLI="PBAHT"   
      When 3,4      PLI="PBATTC"   
      When Default  PLI=""   
    Endcase

    If SPFLINNBR>=VALSPL-10 : Raz RUPTFICHE : Endif
    If RUPTFICHE<>[F:SWX]SWXKEY
       Gosub ECR_SPF          : # ---- ecrire entete fiche ( lignes deja ecrites )
       RUPTFICHE=[F:SWX]SWXKEY

       GOK=1                  : # ---- debut nouvelle fiche
       Trbegin [SWX]
   
       Raz SPFLINNBR
       Raz [SPF]
       [F:SPF]PLI       = PLI  
       [F:SPF]PLISTRDAT = [F:SWX]SWXDAT(0)
       [F:SPF]PLIENDDAT = [F:SWX]SWXDAT(1)
       [F:SPF]CREUSR    = GUSER
       [F:SPF]CREDAT    = date$
       Gosub NO_FICHE                 : # recherche no de fiche ( avec compteur )  
    Endif

    Raz [F:SPL]
    SPFLINNBR += 1
    [F:SPL]PLI       = [F:SPF]PLI
    [F:SPL]PLICRD    = [F:SPF]PLICRD
    [F:SPL]PLILIN    = SPFLINNBR*1000
    [F:SPL]PLICRI    = [F:SWX]SWXCHR(4)+"~~~~~"
    [F:SPL]PLICRI1   = [F:SWX]SWXCHR(4)
    [F:SPL]PLISTRDAT = [F:SWX]SWXDAT(0)
    [F:SPL]PLIENDDAT = [F:SWX]SWXDAT(1)
    [F:SPL]UOM       = [F:SWX]SWXCHR(1)
    [F:SPL]CUR       = [F:SWX]SWXCHR(0)
    [F:SPL]PRI       = [F:SWX]SWXDCB(0)
    [F:SPL]CREUSR    = GUSER
    [F:SPL]CREDAT    = date$

    SI_TABLE="SPRICLIST" : Gosub SI_BEFWRI From SIXFONCTION : # ---- Appel point d entree
    Write [SPL] 
    If fstat 
       MESSAGE=mess(56,123,1)+" SPRICLIST"-[F:SPL]PLI-[F:SPL]PLICRI1+"  "+func SIXFONCTION.FSTATMSG(fstat)
       Call ECR_TRACE(MESSAGE,1) From GESECRAN
       GOK=0 
    Else
       If [F:SPL]PLI="PBAHT"  : NBSPL_PBAHT  += 1 : Endif
       If [F:SPL]PLI="PBATTC" : NBSPL_PBATTC += 1 : Endif
    Endif

Next

Gosub ECR_SPF                 : # ---- ecrire entete derniere fiche ( lignes deja ecrites )

Return

#------------------------------------------------------------------------
$ECR_SWX_SXTC
Raz [F:SWX]
SWXLIN +=1
[F:SWX]PRONUM = adxuid(1)
[F:SWX]LIN    = SWXLIN   

[F:SWX]SWXCHR(0) = [F:SPX]CUR                                                              : # Devise 
[F:SWX]SWXCHR(1) = func SIXFONCTION.SI_COR("XIUNIFAC",[F:XART]UNIFAC,"","")                : # Unite
[F:SWX]SWXCHR(2) = func SIXFONCTION.SI_COR("XIFAMART",[F:XART]CODFAM,"","")                : # Famille article
[F:SWX]SWXCHR(3) = func SIXFONCTION.SI_COR2("XISOUFMART",[F:XART]CODFAM,[F:XART]CODSOUFAM,"#","") : # S/famille article
[F:SWX]SWXCHR(4) = func SIXFONCTION.SI_COR("XIART",[F:XART]CODART,"","")                   : # Reference article

[F:SWX]SWXDAT (0) = DATDEB
[F:SWX]SWXDAT (1) = DATFIN

[F:SWX]SWXDCB (0) = PRIX

[F:SWX]SWXKEY = num$(ORDRE)
[F:SWX]SWXKEY += "~"+num$(val(DATDEB)) 
[F:SWX]SWXKEY += "~"+num$(val(DATFIN)) 

If CRIFICHE=2                                       : # Famille                                   
   [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(2)               
Endif
If CRIFICHE=3                                       : # Famille + S/famille 
   [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(2)
   [F:SWX]SWXKEY += "~"+[F:SWX]SWXCHR(3)
Endif

[F:SWX]SWXKEY1 = [F:SWX]SWXCHR(2)+"~"+[F:SWX]SWXCHR(3)+"~"+[F:SWX]SWXCHR(4) 
#                Famille         +    S/famille       +    Articel  

Write [SWX]
If fstat 
   MESSAGE=mess(56,123,1)+" SIWRKX3"-[F:SWX]SWXKEY+"  "+func SIXFONCTION.FSTATMSG(fstat) 
   Call ECR_TRACE(MESSAGE,1) From GESECRAN
   GOK=0 
Endif
Return

#------------------------------------------------------------------------
$FIN_SXTC
Gosub DEL_SWX

MESSAGE ="  "+mess(59,123,1)-"SPRICFICH / SPRICLIST"
Call ECR_TRACE(MESSAGE,0) From GESECRAN
MESSAGE ="  "+mess(390,197,1)-"TCHT    "+mess(56,123,1)+":  SPF = "+num$(NBSPF_TCHT)+"  SPL = "+num$(NBSPL_TCHT) 
Call ECR_TRACE(MESSAGE,0) From GESECRAN
MESSAGE ="  "+mess(390,197,1)-"TCTTC   "+mess(56,123,1)+":  SPF = "+num$(NBSPF_TCTTC)+"  SPL = "+num$(NBSPL_TCTTC) 
Call ECR_TRACE(MESSAGE,0) From GESECRAN

Return




#########################################################################
# Traitements communs à recuperation des tarifs ventes Integrale 
#########################################################################

#------------------------------------------------------------------------  
#     Effacement fichier de travail   
#------------------------------------------------------------------------  
$DEL_SWX  
Call DEBTRANS From GLOCK  
Trbegin [SWX]  
  Delete [SWX] Where PRONUM=adxuid(1)  
Commit  
Return  

#------------------------------------------------------------------------  
#     Affectation un no de fiche    
#------------------------------------------------------------------------  
$NO_FICHE  
Local Integer STAT
Local Char    SITE          : # permet egalement de retrouver la societe
Local Char    COMPLEMENT (15)
SITE =       GFCYDEF(5)     : # site de vente par defaut ?????
COMPLEMENT = PLI
Call NUMERO(GCODNUM,SITE,[F:SPF]PLISTRDAT,COMPLEMENT,[F:SPF]PLICRD,STAT) From SUBANM
If STAT<>0 
   Call ECR_TRACE (mess(60,199,1),1) From GESECRAN 
   GOK=0 
Endif
Return

#------------------------------------------------------------------------  
#     Ecriture de entete de fiche tarif     
#------------------------------------------------------------------------  
$ECR_SPF  
If [F:SPF]PLI<>""    : # ---- ecrire la fiche ( lignes deja ecrites )
   [F:SPF]LINNBR=SPFLINNBR
   SI_TABLE="SPRICFICH" : Gosub SI_BEFWRI From SIXFONCTION : # ---- Appel point d entree
   Write [SPF] 
   If fstat 
      MESSAGE=mess(56,123,1)+" SPRICFICH"-[F:SPF]PLI-[F:SPF]PLICRD+"  "+func SIXFONCTION.FSTATMSG(fstat)
      Call ECR_TRACE(MESSAGE,1) From GESECRAN
      GOK=0 
   Else
      If [F:SPF]PLI="PBAHT"  & dim(NBSPF_PBAHT)>0  : NBSPF_PBAHT  += 1 : Endif
      If [F:SPF]PLI="PBATTC" & dim(NBSPF_PBATTC)>0 : NBSPF_PBATTC += 1 : Endif
      If [F:SPF]PLI="PDA"    & dim(NBSPF_PDA)>0    : NBSPF_PDA    += 1 : Endif
      If [F:SPF]PLI="QAFX"   & dim(NBSPF_QAFX)>0   : NBSPF_QAFX   += 1 : Endif
      If [F:SPF]PLI="QASX"   & dim(NBSPF_QASX)>0   : NBSPF_QASX   += 1 : Endif
      If [F:SPF]PLI="QARX"   & dim(NBSPF_QARX)>0   : NBSPF_QARX   += 1 : Endif
      If [F:SPF]PLI="QARP"   & dim(NBSPF_QARP)>0   : NBSPF_QARP   += 1 : Endif
   Endif

   If GOK>0  Commit
     Else    Rollback
   Endif 
Endif
Return


#########################################################################
# CALNBENR : Compte le nombre d'enregistrement déjà traité              #
#            et le nombre d'enregistrement total à traiter              #
# --------------------------------------------------------------------- #
# Appelé depuis le traitement SUBSIM                                    #
# La clase [M:SIM2] doit être ouverte et chargée                        #
# WNOL est l'indice de la ligne en cours de traitement                  #
# --------------------------------------------------------------------- #
# En sortie :                                                           #
#    [M:SIM2]NB2TRT chargé avec nbre total à traiter                    #
#    LMES chargé avec "nbre traité / nbre total"                        #
# --------------------------------------------------------------------- #
# Nota                                                                  #
# Le compteur ne prend en compte que les enr. XITRFDVS et XITRFART et   #
# pas les enr. de XIART utilises pour les tarifs de base                #
#########################################################################
Funprog CALNBENR(WNOL)
Value Integer WNOL
#-----
Local Char    LMES(30)
Local Integer WNBTAR
#----- Nombre total d'enregistrements reste à traiter ------------------#
Local File XITRFDVS [XTDV] Where FLGREP<2
WNBTAR=rowcount([XTDV])
Close Local File [XTDV]
Local File XITRFART [XTQT] Where instr(1,CODART,"*")=0 & FLGREP<2
WNBTAR+=rowcount([XTQT])
Close Local File [XTQT]
#-----
LMES=num$(WNBTAR)-"/"
#----- Nombre total d'enregistrements à traiter ------------------------#
Local File XITRFDVS [XTDV] 
WNBTAR=rowcount([XTDV])
Close Local File [XTDV]
#-----
Local File XITRFART [XTQT] Where instr(1,CODART,"*")=0
WNBTAR+=rowcount([XTQT])
Close Local File [XTQT]
#-----
LMES-=num$(WNBTAR)
[M:SIM2]NB2TRT(WNOL)=WNBTAR
#-----
End LMES

#########################################################################






