#<AdxTL>@(#)6.0.0.0 $Revision$
Call EXPORTATION(GBIDC1) From GEXPOBJ
End

#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "OUVRE_BATCH" : Gosub OUVRE From GIMPOBJ
 When "OUVRE"
  Case BOITE
   When "DEXPOBJ1"  : Gosub OUVRE_TRT
  Endcase
 When "DEBUT"
  Case BOITE
   When "DEXPOBJ1"  : Gosub DEBUT_TRT
  Endcase
 When "SETBOUT"
  Case BOITE
   When "DEXPOBJ1"  : Gosub SETBOUT_TRT
  Endcase
 When "BOUTON"
  Case BOITE
   When "DEXPOBJ1"  : Gosub BOUTON_TRT
  Endcase
 When "END"
  Case BOITE
   When "DEXPOBJ1"  : Gosub END_TRT
  Endcase
Endcase
Return

#######################################################
$OUVRE_TRT
Local Char    FICSRC(GDIMFIC) , FICLCK(GDIMFIC)
Local Char    LIGNE(200), APPLI(GLONADS), TRAIT(GLONADC)
Local Char    OLDIFS(5) , OLDIRS(5)
Local Integer OLDIUM

TRAIT  = [M:EXP2]NOMTRT
OLDIFS = adxifs
OLDIRS = adxirs
OLDIUM = adxium
If clalev([M:TTT])=0 : Local Mask OBJTRT [TTT] : Endif
Return

#######################################################
$DEBUT_TRT
Gosub CHARGE_TRT From TRTTRT
Affzo [TTT]
Return

#######################################################
$SETBOUT_TRT
Return

#######################################################
$BOUTON_TRT
Case BOUT
 When "A"
  FICSRC = filpath("TRT",TRAIT,"src",nomap(0))
  Openo FICSRC,0 Using [TRT]
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I% "+[M:TTT]COMMENT Using [TRT]
  For I=0 To [M:TTT]NBLIG-1
   Wrseq vireblc(format$("KT:255X",[M:TTT]LIGNE(I)),1) Using [TRT]
  Next I
  Openo Using [TRT]
  FIN = 1
  Goto FIN_TRT
Endcase
Return

#######################################################
$END_TRT
[M:EXP2]NOMTRT = ""

$FIN_TRT
adxifs = OLDIFS
adxirs = OLDIRS
adxium = OLDIUM
Return

#######################################################
$INIT
Local Integer IMPSTA, FINCHRONO
Local Char    FICDON(GDIMFIC) , FICTMP(GDIMFIC) , FICDONCLI(GDIMFIC)
Local Char    CHAINE(250) , SUF(10)
Local Char    MESSAGE(250)
Local Integer ER , STA , I , J , K , L , M , N , DIME , NUMIMP , NBEXP
Local Integer DEBCHRONO , FINLIG
Local Char    FICSRC(GDIMFIC) , FICLCK(GDIMFIC), LIGNE(200), APPLI(10), TRAIT(GLONADC)
Local Char    TRTSRC(GDIMFIC)
Local Char    NOMTRT(GLONADC) , NOMVAR(250)
Local Char    NOMZONE(20), BID(250)
Local Char    EXPLIEN(80) , CRITLIEN(250) , CLE(10)(1..16) , ZONLIEN(30)
Local Char    EXPIND(80), ZONIND(80)
Local Integer NBCLE
Local Char    SEPCHP(4) , SEPENR(8) , SEPDEC(1)
Local Char    SEPREC(5)(dim([F:AOE]FLGREC))
Local Char    FIFO(GDIMFIC) , PRGBL(30)
Local Char    QUOTE(10)
Local Char    SAVIFS(10) , SAVIRS(10)
Local Integer SAVIUM
Local Char    ZONE1(20) , ZONE2(20)
Local Char    REPTMP(GDIMFIC) , FICBAS(GDIMFIC)
Local Char    CRITERE(255)(0..30)
Local Char    REPERT(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(10)
Local Integer TYPFMT , NOLIB , ICRIT
Local Char    DIF(20)
Local Char    FICCRE(GDIMFIC)
Local Integer FILT_DROIT
Local Char    SAVFONC(GLONAFC) , SAVABR(GLONAOB)

If clalev([M:EXP2])=0 : FIN = 1 : Return : Endif

Raz GIMP

Gosub OUVRE From GEXPOBJ

[M:EXP2]DEBUG = 1
If BCRIT="DEXPOBJ1"
 [M:EXP2]DEBUG = 2
 FINCHRONO = [C]EXPORT : # Pour débugger, on incrémente pas le compteur
Else
 FINCHRONO = [M:EXP2]FINCHRONO
Endif

If [M:EXP2]DEBUG=2
 Call OUVRE_TRACE(mess(93,141,1)) From LECFIC
Endif

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

Gosub INC_IMP
If IMPSTA=6 : Goto FIN_INIT : Endif

If [F:AOE]FLDLIM="'"
 QUOTE = '"'+"'"+'"'
Else
 QUOTE = "'"+[F:AOE]FLDLIM+"'"
Endif

SEPCHP = [F:AOE]SEPFLD
SEPENR = [F:AOE]SEPREC
SEPDEC = [F:AOE]SEPDEC : If SEPDEC="" : SEPDEC = "." : Endif

I = 1
$SEP1
I = instr(1,SEPCHP,"\")
If I
 SEPCHP = left$(SEPCHP,I-1)+chr$(val(mid$(SEPCHP,I+1,3)))+right$(SEPCHP,I+4)
 I += 1
 Goto SEP1
Endif

I = 1
$SEP2
I = instr(1,SEPENR,"\")
If I
 SEPENR = left$(SEPENR,I-1)+chr$(val(mid$(SEPENR,I+1,3)))+right$(SEPENR,I+4)
 I += 1
 Goto SEP2
Endif

$SEP3
For J=0 To dim([F:AOE]FLGREC)-1
 SEPREC(J) = [F:AOE]FLGREC(J)
Next J

Gosub COMPILE From SUBEXPOBJ
If IMPSTA
 Goto FIN_INIT
Else
 [M:EXP2]NOMTRT = NOMTRT
Endif
Return

############
$FIN_INIT
BCRIT = ""
Return

###############
$INC_IMP
Call DEBTRANS From GLOCK
IMPSTA = 0

###############
$BOUC_IMP
Lock NUMIMP
If fstat
 GLOCK = "%NUMIMP"
 Call ROLL From GLOCK
 If GROLL
  IMPSTA = 6 : Return
 Endif
 Goto BOUC_IMP
Endif
If !adxlog
 Trbegin [APX]
 Gosub MAJ_IMP
 If IMPSTA=6
  Rollback
 Else
  Commit
 Endif
Else
 Gosub MAJ_IMP
Endif
Unlock NUMIMP
Return

###############
$MAJ_IMP
NUMIMP = [C]NUMIMP
[C]NUMIMP += 1
If fstat : IMPSTA = 6 : Endif
Return

#######################################################
$CONTROLE
If IMPSTA
 Return
Endif
If [M:EXP2]NOMTRT<>""
 GMESSAGE = ""
 Call VALID("TRT",NOMTRT,nomap,OK) From VALMSKSUB
 If !OK : IMPSTA = 7 : Endif
Endif
Return

#######################################################
$EXEC
Local Integer EXIST
If IMPSTA | [M:EXP2]NOMTRT=""
 Return
Endif
FICDON = [M:EXP2]NOMEXP
Call SETNAM(FICDON,CHAINE,SUF) From GOBJTXT
If instr(1,CHAINE,"#")
 I = instr(1,FICDON,CHAINE+"."+SUF)
 I = instr(I,FICDON,"#")
 If FINCHRONO>99999
  FICDON = left$(FICDON,I-1)+format$("N0:"+num$(len(num$(func GEXPOBJ.MAXCPTEXP)))+"#",FINCHRONO)+right$(FICDON,I+1)
 Else
  FICDON = left$(FICDON,I-1)+format$("N0:5#",FINCHRONO)+right$(FICDON,I+1)
 Endif
Endif

# Issue X3-43015 - 2017-06-20 by CCC : Control if file already exists. By default, we don't overwrite a file
If [M:EXP2]TYPEXP=2
    Raz EXIST
    Call FINDFILES(FICDON,EXIST) From ASYRSTO
    If EXIST
        GBIDC3 = FICDON
        IMPSTA = 22
        Return
    Endif
Endif

If [M:EXP2]TYPEXP=1 : # Client
 FICDONCLI = FICDON
 Call SET_FICNAM(FICDONCLI,FICDON,CHAINE) From ORDSYS
Else
 FICDONCLI = ""
Endif
Call GETREP("REPEXPTMP",REPTMP) From SUBEXPOBJ
If REPTMP<>""
 Call MACHINE(FICDON,MACHINE,REPERT) From ORDSYS
 Call GET_OS(MACHINE,OS) From ORDSYS
 Call REPERT(FICDON,REPERT,FICBAS,OS) From SUBEXPOBJ
 Call MACHINE(REPTMP,MACHINE,REPERT) From ORDSYS
 Call SETFIC(REPTMP,FICBAS,MACHINE,FICTMP)
Else
 FICTMP = FICDON
Endif

If FICTMP="" :  Return : Endif

ER = 0
Onerrgo ERFIC
Openo FICTMP , 0 Using [AEXP]
Onerrgo
If ER
 IMPSTA = 5 : GBIDC3 = FICTMP : Return
Endif

Case [F:AOE]TYPFIL
 When 1         : adxirs = SEPCHP : adxifs = ""
 When 4         : adxirs = SEPENR : adxifs = ""
 When 2,3,5,6,7 : adxirs = SEPENR : adxifs = SEPCHP
Endcase

Case [F:AOE]CODDBA
 When 1 : adxium = GASCII
 When 2 : adxium = GUTF8
 When 3 : adxium = GUCS2
Endcase

SAVABR  = GABREV
SAVFONC = GFONCTION

# Autorisations utilisateurs
If [F:AOE]FONCTION<>""
 GFONCTION = [F:AOE]FONCTION
 Call AUTORIS From EXEFNC
 If GNBAUZ=0
  GBIDC3 = [F:AOE]FONCTION : IMPSTA = 15 : Return
 Else
  # Init des variables fonctions
  Read [AFC]CODINT = [F:AOE]FONCTION
  For I=0 To [F:AFC]NBVAR-1
   If [F:AFC]VALEUR(I)<>"#"
    Assign [F:AFC]VARIA(I) With evalue([F:AFC]VALEUR(I))
   Endif
  Next I
 Endif
Endif

ER = 0
NBEXP = 0

Call EXPORT(NBEXP,SEPREC,ER) From =NOMTRT
If ER : IMPSTA = 8 : Endif

Return

###########################################################
$TERMINE
Openo Using [AEXP]

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

If IMPSTA=0
 If FICDON<>FICTMP
  Call MOVE_EMPTY(FICTMP,FICDON,STA) From ORDSYS
  If STA | filinfo(FICDON,0)<0
   IMPSTA = 5 : GBIDC3 = FICDON
  Endif
 Elsif filinfo(FICDON,0)<=0
  FICDON = ""
  FICDONCLI = ""
 Endif
Endif

If FICDON<>""
 Call EVENEMENT(3,[M:EXP2]MODELE,FICDON,"") From ARCHIVE : # Archive
Endif

GPOINT = "DELFIC" : Gosub ENTREE From EXEFNC : # mb 7.7.9 demande 56385

If FICDON="" : FICDONCLI = "" : Endif

If IMPSTA=0 & FICDONCLI<>""
 Call COPCLI(FICDON,FICDONCLI,STA) From ORDSYS
 If STA=1
  IMPSTA = 19 : GBIDC3 = FICDONCLI
 Elsif STA<0 or STA>1
  IMPSTA = 5 : GBIDC3 = FICDONCLI-"("+num$(STA)+")"
 Endif
Endif

If FICDONCLI<>""
 If len(FICDONCLI)<80
  FICCRE = FICDONCLI
 Else
  Call SETNAM(FICDONCLI,FICCRE,CHAINE) From GOBJTXT
  FICCRE += "."+CHAINE
 Endif
Else
 If len(FICDON)<80
  FICCRE = FICDON
 Else
  Call SETNAM(FICDON,FICCRE,CHAINE) From GOBJTXT
  FICCRE += "."+CHAINE
 Endif
Endif

# Lignes exportées/Fichier
If IMPSTA=0 & [M:EXP2]NOMTRT<>""
 If FICCRE<>"" & GFUSION=0
  Call ECR_TRACE('|'+num$(NBEXP)-mess(82,141,1)-'('+mess(55,100,1)-FICCRE+')',0) From GESECRAN
 Else
  Call ECR_TRACE('|'+num$(NBEXP)-mess(82,141,1),0) From GESECRAN
 Endif
Endif

GABREV = SAVABR
GFONCTION  = SAVFONC
Call AUTORIS From EXEFNC

If GTEST=0 : # Pour garder une trace si trt généré plante
 Call EFFACE(TRTSRC,STA) From ORDSYS
 Call EFFACE_ADX("","",NOMTRT,STA) From ORDSYS
Endif

If [M:EXP2]DEBUG=2
 Call ERR_EXPORT(IMPSTA,MESSAGE) From GEXPOBJ
 If MESSAGE<>""
  Call ECR_TRACE(MESSAGE,1) From GESECRAN
 Endif
 Call FERME_TRACE From LECFIC
 TRA = 1
Endif

[M:EXP2]STAT      = IMPSTA
[M:EXP2]FICDON    = FICDON
[M:EXP2]FICTMP    = FICTMP
[M:EXP2]FICDONCLI = FICDONCLI

Return

###########################################################
Subprog ADDCRIT(CRITERE,SUBCRIT)
Variable Char CRITERE()
Value    Char SUBCRIT
If CRITERE=""
 CRITERE = SUBCRIT
Else
 CRITERE -= "&"-SUBCRIT
Endif
End

$ERFIC
ER = errn
Resume


Subprog SETFIC(REPERT,FICHIER,MACHINE,CHEMIN)
Value    Char REPERT
Value    Char FICHIER
Value    Char MACHINE
Variable Char CHEMIN
Local Integer I
Local Char    EXT(250)

Local Char PATH(250),MESSAGE(250)
Local Integer ASTATUS

PATH = REPERT + '/' + FICHIER
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
ASTATUS = func ASYRSTO.CTL_VOLFIL(2,PATH,CHEMIN,E_TYPE_FILEOVERWRITE,MESSAGE)


End

