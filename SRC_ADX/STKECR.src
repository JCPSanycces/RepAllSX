#<AdxTL>@(#)0.0.0.0 $Revision$ Composants écrans
########################################################################
# Traitement STKECR - Librairie de composants écrans stock        V140 #
########################################################################
# Sous-programmes
#-----------------------------------------------------------------------
# Flux d'entrée
#---------------
# RECSTO_F   : Recherche du contenu des zones stock d'une ligne document
#              dans le fichier STOJOU
# RECSTO_M   : Recherche du contenu des zones stock d'une ligne document
#              dans le masque STOENTW
# RECSTO_ENM : Recherche du contenu des zones stock d'une ligne document
#              dans le masque STOENM
# STKDISCOL  :
# STKGRICOL  : Grise les colonnes ne pouvant pas être modifiées
#              Appelé dans la gestion des avoirs pour les avoirs sans mvt de stock
#                     Dans LIENS pour grizer toutes les colonnes stock
# STKDISLIG  :
# STKACTLIG  :
# STKACTLIGM :
# INIZONENT  : Initialisation et grisage champs stock sur ligne document d'entrée
# LECFICENT  : Lecture des tables stock nécessaires à la ligne document d'entrée
# SAIZONENT  : Avant saisie de chaque champ stock de la ligne document d'entrée
# CTLSTOENT  :
#
# Flux de sortie
#----------------
# LECFICSOR  : Lecture des tables article & règle de gestion
# ETAZONSOR  : Diszo des champs stock des lignes d'un document
# GRIZONSOR  : Grizo des champs stock des lignes d'un document
# INIZONSOR  : Action appelé en AM-ITMREF et AVANT-NBLIG
#              Lecture des tables article & règle de gestion
#              Grisage ou non des champs stock de la ligne du document
#              selon caractéristiques de l'article
#            : Diszo des champs stock de la ligne de document
# RECSTOSOR  : Alimentation des zones stock d'une ligne document sortie
#              ou chgt d'emplacement à partir de STOJOU, STOALL ou STOSORW
# CTLSTOSOR  : Contrôle de cohérence entre les quantités des lignes document
#              et les quantités à sortir stockées dans STOSORW afin de
#              déterminer si l'on peut créer/enregistrer le document
# SAIZONSOR  : Avant saisie de chaque champ stock de la ligne document
#
# Divers
#--------
# STKWSTOSEQ : Calcule le nouveau numéro de séquence servant de lien
#              entre le document et le détail stock
# STKWLOCSEQ : Calcule le nouveau numéro de séquence servant de lien entre le
#              détail et les emplacements
# STKINISEC  : Initialisation des sections analytiques stock
# INIECCSTA  : Initialisation statut des versions : Saisissable ou pas ---> #Isuue 71276
########################################################################
# Actions fenêtre
#-----------------------------------------------------------------------
# DIVCHX1    : Choix stock en sortie
#
########################################################################

########################################################################
######################## - Flux d'entrée - #############################
########################################################################

########################################################################
# RECSTO_F
# Cherche pour une ligne de document donné si dans le détail de cette ligne:
#    - Le statut qualité est unique ou multiple
#    - Le lot fournisseur est unique ou multiple
#    - Le lot est unique ou multiple
#    - Les sous lots sont continus
#    - Le type d'emplacement est unique ou multiple
#    - L'emplacement est unique ou multiple
#    - Les numéros de séries sont continus ou discontinus
#    - Désignation du mouvement unique ou multiple
# Le nombre de sous lots est également renvoyé
# Cette fonction permet de faire apparaître un $ pour montrer la décomposition du champ
########################################################################
# Paramètres E : ABR  = Ecran "XYZ"
#              : FCY  = Site
#              : VCR  = Numéro document
#              : TYP  = Type de document
#              : NOL  = Indice de ligne dans le tableau du document (nolign-1)
#              : LSUP = Inutilisé (paramètre supplémentaire au cas où)
#
# Prérequis : Fichier STOJOU [STJ] ouvert
#             Fichier ITMMASTER [ITM] ouvert et positionné
#             Fichier ITMFACILIT [ITF] ouvert et positionné
########################################################################
Subprog RECSTO_F (ABR,FCY,TYP,VCR,LIN,NOL,LSUP)
Value Char    ABR
Value Char    FCY
Value Integer TYP
Value Char    VCR
Value Integer LIN
Value Integer NOL
Value Char    LSUP

Local Char    LMABR(10)
Local Char    LITM(GLONITM)
Local Char    PSTA(GLONSTA)
Local Char    PLOF(GLONLOT)
Local Char    PLOT(GLONLOT)
Local Integer PNBSLO
Local Char    PSLO(GLONSLO)
Local Char    PSLOF(GLONSLO)
Local Char    PLOCTYP(GLONTEM)
Local Char    PLOC(GLONEMP)
#Local Char    PWRH(GLONWRH)
Local Char    PSER(GLONSER)
Local Char    PSERF(GLONSER)

Local Char    PPAL(GLONPAL)          #hcb 27200
Local Char    PCTR(GLONCTR)          #hcb 27200
Local Char    PMAJ(GLONECS)
Local Char    PMIN(GLONECS)
#--- Issue X3-53322
Local Char    PLPN(GLONLPN)
Local Char    PTCTR(GLONTCTR)
#---
#--- 110327
Local Decimal PQTYSTU

Local Integer I
Local Integer LRET

Local Shortint CLOC    # 1=vérifie la décomposition en plusieurs emplacecments
#Local Shortint CWRH    # 1=vérifie la décomposition en plusieurs dépôt
Local Shortint CLOT    # 1=vérifie la décomposition en plusieurs lots
Local Shortint CSLO    # 1=vérifie la décomposition en plusieurs sous lots
Local Shortint CSER    # 1=vérifie la décomposition en numéros de série discontinus
Local Shortint CPAL    # 1=vérifie la décomposition en identifiant 1 discontinus #hcb 27200
Local Shortint CCTR    # 1=vérifie la décomposition en identifiant 2 discontinus #hcb 27200
Local Shortint CMAJ    # 1=vérifie la décomposition en version discontinus
Local Shortint CMIN    # 1=vérifie la décomposition en version discontinus
Local Shortint CLPN    : #--- Issue X3-53322

Local Char CAR(1) : CAR = "$"

############
# Init des variables locales
LMABR  = "[M:"+ABR+"]"
LITM   = evalue(LMABR+"ITMREF(NOL)")
Case ABR
 When "MTK3"    : LITM   = evalue(LMABR+"MATITMREF(NOL)")
 When Default   : LITM   = evalue(LMABR+"ITMREF(NOL)")
Endcase

Raz I
Raz PSTA
Raz PLOF
Raz PLOT
Raz PNBSLO
Raz PSLO
Raz PSLOF
Raz PLOC
Raz PLOCTYP
#Raz PWRH
Raz PSER
Raz PMAJ
Raz PMIN
Raz PSERF
Raz PPAL                    #hcb 27200
Raz PCTR                    #hcb 27200
#--- Issue X3-53322
Raz PLPN, PTCTR

If !clalev([F:STJ]) : Local File STOJOU     [STJ] : Endif
If !clalev([F:STC]) : Local File STOLOC     [STC] : Endif
If !clalev([F:ACV]) : Local File ACTIV      [ACV] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
#--- Issue X3-53322
If !clalev([F:LPN]) : Local File LPN        [LPN] : Endif

If [F:FCY]FCY<>FCY      Read [FCY]FCY0=FCY  Endif
If [F:ITM]ITMREF<>LITM  Read [ITM]ITM0=LITM Endif

If !clalev([ITF])
    Local File ITMFACILIT [ITF]
    Read [ITF]ITF0=LITM;FCY
Elsif [F:ITF]ITMREF<>LITM |  [F:ITF]STOFCY<>FCY
    Read [ITF]ITF0=LITM;FCY
Endif

CLOC = evalue("dim("+LMABR+"LOC)")>0 & [F:ITF]LOCMGTCOD = 2

#CWRH = evalue("dim("+LMABR+"WRH)")>0 & [F:FCY]WRHGES = 2

CLOT = evalue("dim("+LMABR+"LOT)")>0 & [F:ITM]LOTMGTCOD>1

CSER = evalue("dim("+LMABR+"SERNUM)")>0 & [F:ITM]SERMGTCOD>1
CMAJ = evalue("dim("+LMABR+"ECCVALMAJ)")>0 & [F:ITM]ECCSTO>1
CMIN = evalue("dim("+LMABR+"ECCVALMIN)")>0 & [F:ITM]ECCSTO>2

CPAL = evalue("dim("+LMABR+"PALNUM)")>0   #hcb 27200
CCTR = evalue("dim("+LMABR+"CTRNUM)")>0   #hcb 27200

#--- Issue X3-53322
CLPN  = evalue("dim("+LMABR+"LPNNUM)")>0  & [F:ITF]LPNMGTCOD=2

################################
# Recherche pour STA, LOF, LOT, LOC et SER (pas SLO)
If CSER=1
    #--- Issue 110327
    If [F:ITM]SERMGTCOD=4
      Filter [STJ] Where STOFCY=FCY & VCRTYP=TYP & VCRNUM=VCR & VCRLIN=LIN & ITMREF=LITM & REGFLG<>2
&                  Order By SERDEB
    Else
    #---
      Filter [STJ] Where STOFCY=FCY & VCRTYP=TYP & VCRNUM=VCR & VCRLIN=LIN & ITMREF=LITM & REGFLG<>2
&                  Order By SERNUM
    #--- Issue 110327
    Endif
    #--- Issue X3-53322 ajout LPNNUM
    Columns [STJ] (TRSTYP,QTYSTU,STA,BPSLOT,LOC,LOT,SERNUM,MVTDES,PALNUM,CTRNUM,ECCVALMAJ,ECCVALMIN,SERDEB,SERFIN,LPNNUM)
    #---
Else
    Filter [STJ] Where STOFCY=FCY & VCRTYP=TYP & VCRNUM=VCR & VCRLIN=LIN & ITMREF=LITM & REGFLG<>2
    #--- Issue X3-53322 ajout LPNNUM
    Columns [STJ] (TRSTYP,QTYSTU,STA,BPSLOT,LOC,LOT,MVTDES,PALNUM,CTRNUM,ECCVALMAJ,ECCVALMIN,LPNNUM)            # hcb 27200
Endif

For [STJ] #Hint Key STJ1
    # si retour de pret on ne selectionne que les entrées donc les valeurs positives
    If [F:STJ]TRSTYP = 18 & [F:STJ]QTYSTU < 0
       Goto NEXTSTJ
    Endif
    # si reception transfert inter sites on ne selectionne que les entrées donc les valeurs positives
    If [F:STJ]TRSTYP = 10 & [F:STJ]QTYSTU < 0
       Goto NEXTSTJ
    Endif
    #MAE, en retour de sous traitance, on ne sélectionne que les entrées donc les valeurs positives
    If [F:STJ]TRSTYP = 33 & [F:STJ]QTYSTU < 0
       Goto NEXTSTJ
    Endif
    #--- Issue 115206
    # si sortie ordre sous-traitance à partir d'une réception
    If [F:STJ]VCRTYP = 6 & [F:STJ]TRSTYP = 29
       Goto NEXTSTJ
    Endif
    #---
    I+=1
    # Au 1er tour on initialise les variables qui permettront les comparaisons
    # Et on vérifie que la recherche sur le lot, le sous lot et le numéro de série sont nécessaires
    If I=1
        PSTA = [F:STJ]STA
        PLOF = [F:STJ]BPSLOT
        If CPAL = 1
           PPAL = [F:STJ]PALNUM
        Endif
        If CCTR = 1
           PCTR = [F:STJ]CTRNUM
        Endif
        If CMAJ = 1
           PMAJ = [F:STJ]ECCVALMAJ
        Endif
        If CMIN = 1
           PMIN = [F:STJ]ECCVALMIN
        Endif
        If CLOC=1
            PLOC = [F:STJ]LOC
            Read [STC]STC0=FCY;PLOC
            If !fstat
                PLOCTYP = [F:STC]LOCTYP
            Endif
        Endif
#        If CWRH = 1
#           PWRH = [F:STJ]WRH
#        Endif
        If CLOT = 1
            PLOT = [F:STJ]LOT
        Endif
        If CSER  = 1
          #--- Issue 110327
          If [F:ITM]SERMGTCOD=4
            PSER    = [F:STJ]SERDEB
            PSERF   = [F:STJ]SERFIN
            PQTYSTU = [F:STJ]QTYSTU
          Else
          #---
            PSER  = [F:STJ]SERNUM
            PSERF = PSER
          #--- Issue 110327
          Endif
          #---
        Endif
        #--- Issue X3-53322
        If CLPN=1
          PLPN = [F:STJ]LPNNUM
          If PLPN<>""
            Read [LPN]LPN0=[F:STJ]LPNNUM
            If !fstat
              PTCTR = [F:LPN]TCTRNUM
            Endif
          Endif
        Endif
        #---
        If evalue("dim("+LMABR+"MVTDES)")>0
            Assign LMABR+"MVTDES(NOL)" With [F:STJ]MVTDES
        Endif
    ###########
    # Aux tours suivants on regarde les différences
    Else
        If [F:STJ]STA <> PSTA
            PSTA = CAR
        Endif
        If [F:STJ]BPSLOT <> PLOF
            PLOF = CAR
        Endif
        If CPAL
           If [F:STJ]PALNUM <> PPAL
              PPAL = CAR
           Endif
        Endif
        If CCTR
           If [F:STJ]CTRNUM <> PCTR
              PCTR = CAR
           Endif
        Endif
        If CMAJ
           If [F:STJ]ECCVALMAJ <> PMAJ
              PMAJ = CAR
           Endif
        Endif
        If CMIN
           If [F:STJ]ECCVALMIN <> PMIN
              PMIN= CAR
           Endif
        Endif

        If CLOC
            If [F:STJ]LOC <> PLOC
                PLOC = CAR
                Read [STC]STC0=FCY;[F:STJ]LOC
                If !fstat
                    If [F:STC]LOCTYP <> PLOCTYP
                        PLOCTYP = CAR
                    Endif
                Endif
            Endif
        Endif
 #       If CWRH
 #          If [F:STJ]WRH <> PWRH
 #             PWRH = CAR
 #          Endif
 #       Endif
        If CLOT
            If [F:STJ]LOT <> PLOT
                PLOT=CAR
            Endif
        Endif
        If CSER
          #--- Issue 110327
          If [F:ITM]SERMGTCOD=4
            PSERF    = [F:STJ]SERFIN
            PQTYSTU += [F:STJ]QTYSTU
          Else
          #---
            PSERF = [F:STJ]SERNUM
          #--- Issue 110327
          Endif
          #---
        Endif
        #--- Issue X3-53322
        If CLPN
          If [F:STJ]LPNNUM<>PLPN
            PLPN = CAR
            If [F:STJ]LPNNUM<>""
              Read [LPN]LPN0=[F:STJ]LPNNUM
              If !fstat
                If [F:LPN]TCTRNUM<>PTCTR
                  PTCTR = CAR
                Endif
              Endif
            Elsif PTCTR<>""
              PTCTR = CAR
            Endif
          Endif
        Endif
        #---
    Endif
$NEXTSTJ
Next
Columns [STJ] (SLO)

#--- Issue 93710
#If CSER
If CSER & I>1
#---
    Local Char LSERNUMF(GLONSER)
    #--- Issue 110327
    If [F:ITM]SERMGTCOD=4
      Call PLUS_NB(PSER, PQTYSTU, LSERNUMF, LRET) From STKLIB
    Else
    #---
      Call PLUS_NB(PSER, I, LSERNUMF, LRET) From STKLIB
    #--- Issue 110327
    Endif
    #---
    If LSERNUMF <> PSERF
        PSER  = CAR
        PSERF = CAR
    Endif
Endif

Assign LMABR+"STA(NOL)"         With PSTA

If evalue("dim("+LMABR+"BPSLOT)")>0
    Assign LMABR+"BPSLOT(NOL)"  With PLOF
Endif
If CLOT=1
    Assign LMABR+"LOT(NOL)"     With PLOT
Endif
If CLOC=1
    Assign LMABR+"LOCTYP(NOL)"  With PLOCTYP
    Assign LMABR+"LOC(NOL)"     With PLOC
Endif
#If CWRH=1
#    Assign LMABR+"WRH(NOL)"     With PWRH
#Endif
If CSER=1
    Assign LMABR+"SERNUM(NOL)"  With PSER
    Assign LMABR+"SERNUMF(NOL)" With PSERF
Endif
If CPAL=1
    Assign LMABR+"PALNUM(NOL)"  With PPAL
Endif
If CCTR=1
    Assign LMABR+"CTRNUM(NOL)"  With PCTR
Endif
If CMAJ=1
    Assign LMABR+"ECCVALMAJ(NOL)"  With PMAJ
Endif
If CMIN=1
    Assign LMABR+"ECCVALMIN(NOL)"  With PMIN
Endif
#--- Issue X3-53322
If CLPN=1
  Assign LMABR+"LPNNUM(NOL)"  With PLPN
  If evalue("dim("+LMABR+"TCTRNUM)")>0
    Assign LMABR+"TCTRNUM(NOL)" With PTCTR
  Endif
Endif
#---

################################
# Recherche pour SLO
If evalue("dim("+LMABR+"SLO)")>0
    If [F:ITM]LOTMGTCOD=4
        Local Char LSLOF(GLONSLO)
        If PLOT<>CAR
            PNBSLO = 0
            Filter [STJ] Where STOFCY = FCY &
&                              VCRTYP = TYP &
&                              VCRNUM = VCR &
&                              VCRLIN = LIN &
&                              ITMREF = LITM &
&                              REGFLG <> 2
&                        Order By SLO
            For [STJ] Hint Key STJ1
                If [F:STJ]SLO <> PSLOF
                    PNBSLO+=1
                Endif
                If PNBSLO=1
                    PSLO  = [F:STJ]SLO
                    PSLOF = [F:STJ]SLO
                Endif
                PSLOF = [F:STJ]SLO
            Next
            If CSER=1
                PNBSLO = 1
            Endif
            Call PLUS_NB([L]PSLO, PNBSLO, LSLOF, [L]LRET) From STKLIB
        Endif

        If PSLOF <> LSLOF | PLOT=CAR
            PSLO   = CAR
            PSLOF  = CAR
        Endif
        Assign LMABR+"NBSLO(NOL)" With PNBSLO
        Assign LMABR+"SLO(NOL)"   With PSLO
        Assign LMABR+"SLOF(NOL)"  With PSLOF
    Endif
Endif
Filter [STJ]
Columns [STJ]
End

########################################################################
# RECSTO_M
# Cherche pour une ligne de document donné si dans le détail de cette ligne:
#    - Le statut qualité est unique ou multiple
#    - Le lot fournisseur est unique ou multiple
#    - Le lot est unique ou multiple
#    - Les sous lots sont continus
#    - Le type d'emplacement est unique ou multiple
#    - L'emplacement est unique ou multiple
#    - Les numéros de séries sont continus ou discontinus
#    - Désignation du mouvement unique ou multiple
# Le nombre de sous lots est également renvoyé
# Cette fonction permet de faire apparaître un $ pour montrer la décomposition du champ
########################################################################
# Paramètres E : FCY  = Site
#              : LIN  = Numéro de ligne dans le document
#              : ITM  = Article
#              : LSUP = Inutilisé (paramètre supplémentaire au cas où)
#            S : PLOCSEQ= Numéro de séquence de la réservation de l'emplacement
#                          Ce n° n'est significatif que s'il n'y a qu'une seule ligne de détail
#              : PQTY   = Quantité totale du détail en unité de stock
#              : PSTA   = Résultat de la recherche sur le statut              :  =$ si multiple
#              : PLOF   = Résultat de la recherche sur le lot fournis         :  =$ si multiple
#              : PLOT   = Résultat de la recherche sur le lot                 :  =$ si multiple
#              : PGESLOT= Résultat de la recherche sur le champ GESLOT
#                         qui indique si le lot est blanc ou pas
#              : PNBSLO = Résultat de la recherche sur le sous lot            :  =-1 si discontinus
#              : PSLO   = Résultat de la recherche sur le sous lot            :  =$ si discontinus
#              : PSLOF  = Résultat de la recherche sur le sous lot            :  =$ si discontinus
#              : PLOCTYP= Résultat de la recherche sur le type d'emplacement  :  =$ si multiple
#              : PLOC   = Résultat de la recherche sur l'emplacement          :  =$ si multiple
#              : PSER   = Résultat de la recherche sur le n° de série         :  =$ si discontinus
#              : PSERF  = Résultat de la recherche sur le n° de série         :  =$ si discontinus
#              : PNBLIGENTW = Nombre de lignes dans STOENTW
#              : PMAJ   = Résultat de la recherche sur version majeure        :  =$ si multiple
#              : PMIN   = Résultat de la recherche sur version mineure        :  =$ si multiple
#              : PLPN   = Résultat de la recherche sur no contenant           :  =$ si multiple
#              : PTCTR  = Résultat de la recherche sur contenant              :  =$ si multiple
#
# Prérequis : Masque  STOENTW [ENTW] ouvert
#             Fichier ITMMASTER [ITM] ouvert et positionné
#             Fichier ITMFACILIT [ITF] ouvert et positionné
########################################################################
Subprog RECSTO_M (FCY,LIN,ITM,LSUP,PLOCSEQ,PQTY,PSTA,PLOF,PLOT,PGESLOT,PNBSLO,PSLO,PSLOF,PLOCTYP,PLOC,PSER,PSERF,PPCU,PNBLIGENTW,PPAL,PCTR,PMAJ,PMIN,PLPN,PTCTR)
Value Char    FCY
Value Integer LIN
Value Char    ITM
Value Char    LSUP
Variable Integer PLOCSEQ
Variable Decimal PQTY
Variable Char    PSTA
Variable Char    PLOF
Variable Char    PLOT
Variable Char    PGESLOT
Variable Integer PNBSLO
Variable Char    PSLO
Variable Char    PSLOF
Variable Char    PLOCTYP
Variable Char    PLOC
Variable Char    PSER
Variable Char    PSERF
Variable Char    PPCU
Variable Integer PNBLIGENTW
Variable Char    PPAL
Variable Char    PCTR
Variable Char    PMAJ
Variable Char    PMIN
Variable Char    PLPN    : #--- Issue X3-53322
Variable Char    PTCTR   : #--- Issue X3-53322

Local Integer I, J
Local Integer LNBL    # nombre de ligne dans STOENTW dont WSTOSEQ=LIN
Local Integer LRET

Local Char SLO(GLONSLO)     # 1er numéro de sous lot permettant de faire la comparaison
Local Char SLO_1(GLONSLO)   # Numéro de sous lot précédent de SLO
Local Shortint CLOC    # 1=vérifie la décomposition en plusieurs emplacements
#Local Shortint CWRH    # 1=vérifie la décomposition en plusieurs dépôts
Local Shortint CLOT    # 1=vérifie la décomposition en plusieurs lots
Local Shortint CSLO    # 1=vérifie la décomposition en plusieurs sous lots
Local Shortint CSER    # 1=vérifie la décomposition en numéros de série discontinus
Local Shortint CPAL    # 1=vérifie la décomposition en identifiant 1 discontinus
Local Shortint CCTR    # 1=vérifie la décomposition en identifiant 2 discontinus
Local Shortint CMAJ    # 1=vérifie la décomposition en version majeure
Local Shortint CMIN    # 1=vérifie la décomposition en version majeure
Local Shortint CLPN    : #--- Issue X3-53322
Local Shortint CTCTR   : #--- Issue X3-53322

Local Char CAR(1) : CAR = "$"

############
# Init des variables locales
I=0
J=0
PQTY   = 0
PSTA   = ""
PLOF   = ""
PLOT   = ""
PNBSLO = 0
PSLO   = ""
PSLOF  = ""
PLOC   = ""
#PWRH   = ""
PSER   = ""
PSERF  = ""
PPCU   = ""
PPAL   = ""             # hcb 27200
PCTR   = ""             # hcb 27200
PLPN   = ""           : #--- Issue X3-53322
PTCTR  = ""           : #--- Issue X3-53322
CLOC = 0
#CWRH = 0
CLOT = 0
CSLO = 0
CSER = 0
CPAL = 0                # hcb 27200
CCTR = 0                # hcb 27200
CMAJ = 0
CMIN = 0
CLPN = 0              : #--- Issue X3-53322
CTCTR= 0              : #--- Issue X3-53322

If clalev([F:ITM]) =0  Local File ITMMASTER [ITM]  Endif
If [F:ITM]ITMREF<>ITM  Read [ITM]ITM0=ITM Endif
If clalev([F:ITF]) =0  Local File ITMFACILIT [ITF] : Read [ITF]ITF0=ITM;FCY : Endif

I = find(LIN, [M:ENTW]WSTOSEQ)
I -= 1
If I<0 End Endif
LNBL=1
J=I+1
While [M:ENTW]WSTOSEQ(J) = LIN
    J +=1
    LNBL+=1
Wend
PNBLIGENTW = LNBL

################################
# Recherche pour STA, LOF, LOT, LOC et SER (pas SLO)
# Au 1er tour on initialise les variables qui permettront les comparaisons
# Et on vérifie que la recherche sur le lot, le sous lot et le numéro de série sont nécessaires
PQTY    = [M:ENTW]QTYSTU(I)
PSTA    = [M:ENTW]STA(I)
If [M:ENTW]NUMLIGLOT(I)>=0
    PLOF    = [M:ENTW]BPSLOT([M:ENTW]NUMLIGLOT(I))
Else
    Raz PLOF
Endif
PPCU    = [M:ENTW]PCU(I)

PLOCSEQ = [M:ENTW]WLOCSEQ(I)
If dim([M:ENTW]LOC)>0
    If [F:ITF]LOCMGTCOD>1
        CLOC = 1
        PLOCTYP = [M:ENTW]LOCTYP(I)
        PLOC = [M:ENTW]LOC(I)
    Endif
Endif
#If dim([M:ENTW]WRH)>0
#   CWRH = 1
#   PWRH = [M:ENTW]WRH(I)
#Endif
If dim([M:ENTW]PALNUM)>0
   CPAL = 1
   PPAL = [M:ENTW]PALNUM(I)
Endif
If dim([M:ENTW]CTRNUM)>0
   CCTR = 1
   PCTR = [M:ENTW]CTRNUM(I)
Endif

#--- Issue X3-53322
If dim([M:ENTW]LPNNUM)>0
    If [F:ITF]LPNMGTCOD=2
        CLPN  = 1
        CTCTR = 1
        PLPN  = [M:ENTW]LPNNUM(I)
        PTCTR = [M:ENTW]TCTRNUM(I)
    Else
        Raz PLPN, PTCTR
    Endif
Endif
#---

############
# Vérifie que la recherche de lots différents est utile

If dim([M:ENTW]ECCVALMAJ)>0
    If [F:ITM]ECCSTO>1
        CMAJ = 1
        If [M:ENTW]NUMLIGLOT(I)>=0
            PMAJ = [M:ENTW]ECCVALMAJ([M:ENTW]NUMLIGLOT(I))
        Else
            Raz PMAJ
        Endif
    Endif
Endif

If dim([M:ENTW]ECCVALMIN)>0
    If [F:ITM]ECCSTO>2
        CMIN = 1
        If [M:ENTW]NUMLIGLOT(I)>=0
            PMIN = [M:ENTW]ECCVALMIN([M:ENTW]NUMLIGLOT(I))
        Else
            Raz PMIN
        Endif
    Endif
Endif

If dim([M:ENTW]LOT)>0
    If [F:ITM]LOTMGTCOD>1
        CLOT = 1
        If [M:ENTW]NUMLIGLOT(I)>=0
            PLOT = [M:ENTW]LOT([M:ENTW]NUMLIGLOT(I))
            PGESLOT = [M:ENTW]GESLOT([M:ENTW]NUMLIGLOT(I))
        Else
            Raz PLOT
            Raz PMAJ
            Raz PMIN
        Endif
    Endif
Endif
############
# Vérifie que la recherche de n° de série discontinus est utile
If dim([M:ENTW]SERNUM)>0
    If [F:ITM]SERMGTCOD>1
        Local Char LTABSER(GLONSER)(LNBL)
        Local Char LTABSERF(GLONSER)(LNBL)
        LTABSER(0) = [M:ENTW]SERNUM(I)
        LTABSERF(0) = [M:ENTW]SERNUMF(I)
        CSER = 1
#        PSER = [M:ENTW]SERNUM(I)
#        PSERF = [M:ENTW]SERNUMF(I)
    Endif
Endif
############
# Vérifie que la recherche de n° de /s lots discontinus est utile
If dim([M:ENTW]SLO)>0
    If [ITM]LOTMGTCOD=4
        Local Char LTABSLO(GLONSLO)(LNBL)
        CSLO=1
        PNBSLO=1
        If [M:ENTW]NUMLIGLOT(I)>=0
            LTABSLO(0) = [M:ENTW]SLO([M:ENTW]NUMLIGLOT(I))
        Else
            Raz LTABSLO(0)
        Endif
    Endif #LOTMGTCOD=4
Endif #Code activité SLO actif

###########
# On cherche maintenant les différences
J=1
I=I+1
While J<LNBL

    PQTY += [M:ENTW]QTYSTU(I)

    If [M:ENTW]STA(I) <> PSTA
        PSTA = CAR
    Endif
    If ([M:ENTW]NUMLIGLOT(I)=-1 & PLOF<>"") | ([M:ENTW]NUMLIGLOT(I)>=0 & [M:ENTW]BPSLOT([M:ENTW]NUMLIGLOT(I)) <> PLOF)
        PLOF = CAR
    Endif
    If [M:ENTW]PCU(I)    <> PPCU
        PPCU = CAR
    Endif

    If [M:ENTW]LOCTYP(I) <> PLOCTYP
        PLOCTYP = CAR
    Endif
    If CLOC
        If [M:ENTW]LOC(I) <> PLOC
            PLOC = CAR
            CLOC = 0
        Endif
    Endif
#    If CWRH
#        If [M:ENTW]WRH(I) <> PWRH
#            PWRH = CAR
#            CWRH = 0
#        Endif
#    Endif
    If CPAL
        If [M:ENTW]PALNUM(I) <> PPAL
            PPAL = CAR
            CPAL = 0
        Endif
    Endif
    If CCTR
        If [M:ENTW]CTRNUM(I) <> PCTR
            PCTR = CAR
            CCTR = 0
        Endif
    Endif

    #--- Issue X3-53322
    If CLPN
        If [M:ENTW]LPNNUM(I) <> PLPN
            PLPN = CAR
            CLPN = 0
        Endif
    Endif
    If CTCTR
        If [M:ENTW]TCTRNUM(I) <> PTCTR
            PTCTR = CAR
            CTCTR = 0
        Endif
    Endif
    #---

    If CLOT
        If ([M:ENTW]NUMLIGLOT(I)=-1 & PLOT<>"")
&        | [M:ENTW]NUMLIGLOT(I)>=0
&        & ([M:ENTW]LOT([M:ENTW]NUMLIGLOT(I)) <> PLOT)
&        | ([M:ENTW]GESLOT([M:ENTW]NUMLIGLOT(I)) <> PGESLOT)
            PLOT = CAR
            PGESLOT = ""
            CLOT = 0
        Endif
    Endif
    If CMAJ
        If [M:ENTW]NUMLIGLOT(I)>=0 & [M:ENTW]ECCVALMAJ([M:ENTW]NUMLIGLOT(I)) <> PMAJ
            PMAJ = CAR
            CMAJ = 0
        Endif
    Endif
    If CMIN
        If [M:ENTW]NUMLIGLOT(I)>=0 & ([M:ENTW]ECCVALMIN([M:ENTW]NUMLIGLOT(I)) <> PMIN)
            PMIN = CAR
            CMIN = 0
        Endif
    Endif
    If CSER
        LTABSER(J) = [M:ENTW]SERNUM(I)
        LTABSERF(J) = [M:ENTW]SERNUMF(I)
    Endif
    If CSLO
        If [M:ENTW]NUMLIGLOT(I)>=0
            LTABSLO(J) = [M:ENTW]SLO([M:ENTW]NUMLIGLOT(I))
        Else
            Raz LTABSLO(J)
        Endif
        PNBSLO += 1
    Endif
    J += 1
    I += 1
Wend

If CSER
    Sorta LTABSER, LTABSERF
    PSER =LTABSER(0)
    PSERF=LTABSERF(0)
    For I=1 To LNBL-1
            Call PLUS_UN(LTABSERF(I-1),LTABSERF(I-1), LRET) From STKLIB
            If LTABSER(I) <> LTABSERF(I-1)
                PSER = CAR
                PSERF = CAR
                CSER = 0
                Break
            Else
                PSERF = LTABSERF(I)
            Endif
    Next I
    Kill LTABSER, LTABSERF
Endif
# Si gestion de sous lot, recherche de la continuité des sous lots
If CSLO
    If PLOT=CAR
        PSLO   = CAR
        PSLOF  = CAR
    Else
        I = 0
        # Pour vérifier la continuité des n° de /s lot, il faut d'abord trier les lignes
        # suivant le n° de /s lot
        Sorta LTABSLO

        # Init de PSLO
        # Quand on a une gestion de n° de série, il n'y a pas de sous lot fin
        # 1 seul sous lot peut être défini pour une plage de n° de série
        PSLO = LTABSLO(0)
        PSLOF = LTABSLO(0)
        [L]SLO_1 = LTABSLO(0)
        Call PLUS_UN(LTABSLO(0), [L]SLO, LRET) From STKLIB
        # On recherche dans les lignes suivantes la discontinuité
        For I=1 To LNBL-1
            # on vérifie que les n° de /s lot
            # se suivent ou qu'ils sont identiques
            If LTABSLO(I) <> [L]SLO_1
                #... on vérifie qu'ils se suivent
                If LTABSLO(I) = [L]SLO
                    PSLOF = [L]SLO
                    [L]SLO_1 = [L]SLO
                    Call PLUS_UN([L]SLO_1, [L]SLO, [L]LRET) From STKLIB
                Else
                    PSLO   = CAR
                    PSLOF  = CAR
                    CSLO   = 0
                Endif
            Else
                # s'ils sont identiques, on a compté un sous lot de trop auparavant
                PNBSLO -= 1
            Endif
            If CSLO=0
                Break
            Endif
        Next
    Endif
Endif

End


########################################################################
# RECSTO_ENM
# Cherche pour une ligne de document donné si dans le détail de cette ligne:
#    - Le statut qualité est unique ou multiple
#    - Le lot fournisseur est unique ou multiple
#    - Le lot est unique ou multiple
#    - Les sous lots sont continus
#    - Le type d'emplacement est unique ou multiple
#    - L'emplacement est unique ou multiple
#    - Les numéros de séries sont continus ou discontinus
#    - Désignation du mouvement unique ou multiple
# Le nombre de sous lots est également renvoyé
# Cette fonction permet de faire apparaître un $ pour montrer la décomposition du champ
########################################################################
# Paramètres E : FCY  = Site
#              : ITM  = Article
#              : LSUP = Inutilisé (paramètre supplémentaire au cas où)
#            S : PQTY   = Quantité totale du détail en unité de stock
#              : PSTA   = Résultat de la recherche sur le statut              :  =$ si multiple
#              : PLOF   = Résultat de la recherche sur le lot fournis         :  =$ si multiple
#              : PLOT   = Résultat de la recherche sur le lot                 :  =$ si multiple
#              : PGESLOT= Résultat de la recherche sur le champ GESLOT
#                         qui indique si le lot est blanc ou pas
#              : PNBSLO = Résultat de la recherche sur le sous lot            :  =-1 si discontinus
#              : PSLO   = Résultat de la recherche sur le sous lot            :  =$ si discontinus
#              : PSLOF  = Résultat de la recherche sur le sous lot            :  =$ si discontinus
#              : PLOCTYP= Résultat de la recherche sur le type d'emplacement  :  =$ si multiple
#              : PLOC   = Résultat de la recherche sur l'emplacement          :  =$ si multiple
#              : PSER   = Résultat de la recherche sur le n° de série         :  =$ si discontinus
#              : PSERF  = Résultat de la recherche sur le n° de série         :  =$ si discontinus
#              : PNBLIGENTW = Nombre de lignes dans STOENTW
#              : PMAJ   = Résultat de la recherche sur version majeure        :  =$ si discontinus
#              : PMIN   = Résultat de la recherche sur version mineure        :  =$ si discontinus
#              : PLPN   = Résultat de la recherche sur no contenant           :  =$ si multiple
#              : PTCTR  = Résultat de la recherche sur contenant              :  =$ si multiple

#
# Prérequis : Masque  STOENTM [ENM] ouvert
#             Fichier ITMMASTER [ITM] ouvert et positionné
#             Fichier ITMFACILIT [ITF] ouvert et positionné
########################################################################
Subprog RECSTO_ENM (FCY,ITM,LSUP,PQTY,PSTA,PLOF,PLOT,PGESLOT,PNBSLO,PSLO,PSLOF,PLOCTYP,PLOC,PSER,PSERF,PPCU,PNBLIGENTW,PPAL,PCTR,PMAJ,PMIN,PLPN,PTCTR)
Value Char       FCY
Value Char       ITM
Value Char       LSUP
Variable Decimal PQTY
Variable Char    PSTA
Variable Char    PLOF
Variable Char    PLOT
Variable Char    PGESLOT
Variable Integer PNBSLO
Variable Char    PSLO
Variable Char    PSLOF
Variable Char    PLOCTYP
Variable Char    PLOC
Variable Char    PSER
Variable Char    PSERF
Variable Char    PPCU
Variable Integer PNBLIGENTW
Variable Char    PPAL
Variable Char    PCTR
Variable Char    PMAJ
Variable Char    PMIN
Variable Char    PLPN    : #--- Issue X3-53322

Local Integer  I
Local Integer  LRET

Local Char     SLO(GLONSLO)     # 1er numéro de sous lot permettant de faire la comparaison
Local Char     SLO_1(GLONSLO)   # Numéro de sous lot précédent de SLO
Local Shortint CLOC             # 1=vérifie la décomposition en plusieurs emplacecments
#Local Shortint CWRH             # 1=vérifie la décomposition en plusieurs dépôts
Local Shortint CLOT             # 1=vérifie la décomposition en plusieurs lots
Local Shortint CSLO             # 1=vérifie la décomposition en plusieurs sous lots
Local Shortint CSER             # 1=vérifie la décomposition en numéros de série discontinus
Local Shortint CPAL             # 1=vérifie la décomposition en identifiant 1 discontinus
Local Shortint CCTR             # 1=vérifie la décomposition en identifiant 2 discontinus
Local Shortint CMAN             # 1=vérifie la décomposition version majeure
Local Shortint CMIN             # 1=vérifie la décomposition version mineure
Local Shortint CLPN           : #--- Issue X3-53322

Local Char CAR(1) : CAR = "$"

############
# Init des variables locales
I=0
J=0
PQTY   = 0
PSTA   = ""
PLOF   = ""
PLOT   = ""
PNBSLO = 0
PSLO   = ""
PSLOF  = ""
PLOC   = ""
#PWRH   = ""
PSER   = ""
PSERF  = ""
PPAL   = ""
PCTR   = ""
PMAJ   = ""
PMIN   = ""
PLPN   = ""           : #--- Issue X3-53322
CLOC = 0
#CWRH = 0
CLOT = 0
CSLO = 0
CSER = 0
CPAL = 0
CCTR = 0
CMAJ = 0
CMIN = 0
CLPN = 0              : #--- Issue X3-53322

If clalev([F:FCY]) =0  Local File FACILITY   [FCY]  Endif
If clalev([F:ITM]) =0  Local File ITMMASTER  [ITM]  Endif
If clalev([F:ITF]) =0  Local File ITMFACILIT [ITF]  Endif
If [F:FCY]FCY<>FCY     Read [FCY]FCY0=FCY  Endif
If [F:ITM]ITMREF<>ITM  Read [ITM]ITM0=ITM  Endif
If [F:ITF]ITMREF<>ITM | [F:ITF]STOFCY<>FCY Read [ITF]ITF0=ITM;FCY  Endif

PNBLIGENTW = [M:ENM]NBLIG

If PNBLIGENTW = 0
   End
Endif
################################
# Recherche pour STA, LOF, LOT, LOC et SER (pas SLO)
# Au 1er tour on initialise les variables qui permettront les comparaisons
# Et on vérifie que la recherche sur le lot, le sous lot et le numéro de série sont nécessaires
PQTY    = [M:ENM]QTYSTU(0)
PSTA    = [M:ENM]STA   (0)
If dim([M:ENM]BPSLOTAFF(0))>0
    PLOF    = [M:ENM]BPSLOTAFF(0)
Endif
PPCU    = [M:ENM]PCU(0)
If dim([M:ENM]PALNUM)>0
   CPAL = 1
   PPAL = [M:ENM]PALNUM(0)
Endif
If dim([M:ENM]CTRNUM)>0
   CCTR = 1
   PCTR = [M:ENM]CTRNUM(0)
Endif

#--- Issue X3-53322
If dim([M:ENM]LPNNUM)>0
    If [F:ITF]LPNMGTCOD=2
        CLPN  = 1
        PLPN  = [M:ENM]LPNNUM(0)
    Else
        Raz PLPN
    Endif
Endif
#---

If dim([M:ENM]LOC)>0
    If [F:ITF]LOCMGTCOD>1
        CLOC    = 1
        PLOCTYP = [M:ENM]LOCTYP(0)
        PLOC    = [M:ENM]LOC   (0)
    Endif
Endif
#                                             # hcb 71276 deb
If dim([M:ENM]ECCVALMAJ)>0
    If [F:ITM]ECCSTO > 1
        CMAJ    = 1
        PMAJ    = [M:ENM]ECCVALMAJAFF (0)
    Endif
Endif
If dim([M:ENM]ECCVALMIN)>0
    If [F:ITM]ECCSTO > 2
        CMIN    = 1
        PMIN    = [M:ENM]ECCVALMINAFF (0)
    Endif
Endif
#                                             # hcb 71276 fin

#If dim([M:ENM]WRH)>0
#    If [F:FCY]WRHGES=2
#        CWRH    = 1
#        PWRH    = [M:ENM]WRH(0)
#    Endif
#Endif
############
# Vérifie que la recherche de lots différents est utile
If dim([M:ENM]LOTAFF)>0
    If [F:ITM]LOTMGTCOD>1
        CLOT    = 1
        PLOT    = [M:ENM]LOTAFF   (0)
        PGESLOT = [M:ENM]GESLOTAFF(0)
    Endif
Endif
############
# Vérifie que la recherche de n° de série discontinus est utile
If dim([M:ENM]SERNUM)>0
    If [F:ITM]SERMGTCOD>1
        Local Char LTABSER(GLONSER) (PNBLIGENTW)
        Local Char LTABSERF(GLONSER)(PNBLIGENTW)
        LTABSER (0) = [M:ENM]SERNUM (0)
        LTABSERF(0) = [M:ENM]SERNUMF(0)
        CSER        = 1
        PSER        = [M:ENM]SERNUM (0)
        PSERF       = [M:ENM]SERNUMF(0)
    Endif
Endif
############
# Vérifie que la recherche de n° de /s lots discontinus est utile
If dim([M:ENM]SLOAFF)>0
    If [ITM]LOTMGTCOD=4
        Local Char LTABSLO(GLONSLO)(PNBLIGENTW)
        CSLO       =1
        PNBSLO     =1
        LTABSLO(0) = [M:ENM]SLOAFF(0)
    Endif
Endif

###########
# On cherche maintenant les différences
For I = 1 To [M:ENM]NBLIG-1

    PQTY += [M:ENM]QTYSTU(I)

    If [M:ENM]STA(I) <> PSTA
        PSTA = CAR
    Endif
    If dim([M:ENM]BPSLOTAFF)>0 & [M:ENM]BPSLOTAFF(I) <> PLOF
        PLOF = CAR
    Endif
    If [M:ENM]PCU(I) <> PPCU
        PPCU = CAR
    Endif

    If CPAL
        If [M:ENM]PALNUM(I) <> PPAL
            PPAL = CAR
            CPAL = 0
        Endif
    Endif
    If CCTR
        If [M:ENM]CTRNUM(I) <> PCTR
            PCTR = CAR
            CCTR = 0
        Endif
    Endif

    #--- Issue X3-53322
    If CLPN
        If [M:ENM]LPNNUM(I) <> PLPN
            PLPN = CAR
            CLPN = 0
        Endif
    Endif
    #---

    If CLOC
        If [M:ENM]LOCTYP(I) <> PLOCTYP
            PLOCTYP = CAR
        Endif
        If [M:ENM]LOC(I) <> PLOC
            PLOC = CAR
        Endif
    Endif
#    If CWRH
#        If [M:ENM]WRH(I) <> PWRH
#            PWRH = CAR
#        Endif
#    Endif
    If CLOT
        If ([M:ENM]LOTAFF(I) <> PLOT) | ([M:ENM]GESLOTAFF(I) <> PGESLOT)
            PLOT = CAR
            PGESLOT = ""
            CLOT = 0
        Endif
    Endif
    If CMAJ
        If ([M:ENM]ECCVALMAJAFF(I) <> PMAJ)
            PMAJ = CAR
            CMAJ = 0
        Endif
    Endif
    If CMIN
        If ([M:ENM]ECCVALMINAFF(I) <> PMIN)
            PMIN = CAR
            CMIN = 0
        Endif
    Endif
    If CSER
        LTABSER (I) = [M:ENM]SERNUM (I)
        LTABSERF(I) = [M:ENM]SERNUMF(I)
    Endif
    If CSLO
        LTABSLO (I) = [M:ENM]SLOAFF    (I)
        PNBSLO += 1
    Endif
Next

If CSER
    Sorta LTABSER, LTABSERF
    For I=1 To PNBLIGENTW-1
            Call PLUS_UN(LTABSERF(I-1),LTABSERF(I-1), LRET) From STKLIB
            If LTABSER(I) <> LTABSERF(I-1)
                PSER = CAR
                PSERF = CAR
                CSER = 0
            Else
                PSERF = LTABSERF(I)
            Endif
    Next I
    Kill LTABSER, LTABSERF
Endif
# Si gestion de sous lot, recherche de la continuité des sous lots
If CSLO
    If PLOT=CAR
        PSLO   = CAR
        PSLOF  = CAR
    Else
        I = 0
        # Pour vérifier la continuité des n° de /s lot, il faut d'abord trier les lignes
        # suivant le n° de /s lot
        Sorta LTABSLO

        # Init de PSLO
        # Quand on a une gestion de n° de série, il n'y a pas de sous lot fin
        # 1 seul sous lot peut être défini pour une plage de n° de série
        PSLO     = LTABSLO(0)
        PSLOF    = LTABSLO(0)
        [L]SLO_1 = LTABSLO(0)
        Call PLUS_UN(LTABSLO(0), [L]SLO, LRET) From STKLIB
        # On recherche dans les lignes suivantes la discontinuité
        For I=1 To PNBLIGENTW-1
            # on vérifie que les n° de /s lot
            # se suivent ou qu'ils sont identiques
            If LTABSLO(I) <> [L]SLO_1
                #... on vérifie qu'ils se suivent
                If LTABSLO(I) = [L]SLO
                   PSLOF      = [L]SLO
                   [L]SLO_1   = [L]SLO
                   Call PLUS_UN([L]SLO_1, [L]SLO, [L]LRET) From STKLIB
                Else
                    PSLO   = CAR
                    PSLOF  = CAR
                    CSLO   = 0
                Endif
            Else
                # s'ils sont identiques, on a compté un sous lot de trop auparavant
                PNBSLO -= 1
            Endif
            If CSLO=0
                Break
            Endif
        Next
    Endif
Endif

End


###############################################################################
# STKDISCOL : Grise les colonness ne pouvant plus être modifiées
#             dans le masque par defaut, mais laisse active la dernière ligne.
###############################################################################
#Les champs suivants sont grisés:
#    ITMREF
#    ITMDES1
#    PCU/UOM
#    PCUQTY/UOMQTY
#    STA
#    LOCTYP
#    LOC
#    WRH
#    BPSLOT
#    LOT
#    NBSLO
#    SLO
#    SERNUM
#    ...
# Attention: Dans l'action LIENS, un affzo doit être appelé avant afin que
#            les diszo soient pris en compte
###############################################################################
Subprog STKDISCOL(PABR, PNBLIG)
Value Char    PABR
Value Integer PNBLIG
Local Char LMSKCOU : LMSKCOU = func STKLIB.MSKDEF    #CCC: astuce donnée par MB

Default Mask "["+PABR+"]"
    If evalue("dim([M:"+PABR+"]STA)")>0
        Diszo [M]STA
        Actzo [M]STA(PNBLIG)
    Endif
    If evalue("dim([M:"+PABR+"]LOCTYP)")>0
        Diszo [M]LOCTYP
        Actzo [M]LOCTYP(PNBLIG)
    Endif
    If evalue("dim([M:"+PABR+"]LOC)")>0
        Diszo [M]LOC
        Actzo [M]LOC(PNBLIG)
    Endif
    If evalue("dim([M:"+PABR+"]WRH)")>0
        Diszo [M]WRH
        Actzo [M]WRH(PNBLIG)
    Endif
    If evalue("dim([M:"+PABR+"]BPSLOT)")>0
        Diszo [M]BPSLOT
        Actzo [M]BPSLOT(PNBLIG)
    Endif

    If evalue("dim([M:"+PABR+"]LOT)")>0
        Diszo [M]LOT
        Actzo [M]LOT(PNBLIG)
    Endif
    If evalue("dim([M:"+PABR+"]NBSLO)")>0
        Diszo [M]NBSLO
        Actzo [M]NBSLO(PNBLIG)
    Endif
    If evalue("dim([M:"+PABR+"]SLO)")>0
        Diszo [M]SLO
        Actzo [M]SLO(PNBLIG)
    Endif
    If evalue("dim([M:"+PABR+"]SERNUM)")>0
        Diszo [M]SERNUM
        Actzo [M]SERNUM(PNBLIG)
    Endif
    If evalue("dim([M:"+PABR+"]PALNUM)")>0
        Diszo [M]PALNUM
        Actzo [M]PALNUM(PNBLIG)
    Endif
    If evalue("dim([M:"+PABR+"]CTRNUM)")>0
        Diszo [M]CTRNUM
        Actzo [M]CTRNUM(PNBLIG)
    Endif
    # HCB 71276
    If evalue("dim([M:"+PABR+"]ECCVALMAJ)")>0
        Diszo [M]ECCVALMAJ
        Actzo [M]ECCVALMAJ(PNBLIG)
    Endif
    If evalue("dim([M:"+PABR+"]ECCVALMIN)")>0
        Diszo [M]ECCVALMIN
        Actzo [M]ECCVALMIN(PNBLIG)
    Endif
    #---
    #--- Issue X3-53322
    If evalue("dim([M:"+PABR+"]LPNNUM)")>0
        Diszo [M]LPNNUM
        Actzo [M]LPNNUM(PNBLIG)
    Endif
    If evalue("dim([M:"+PABR+"]TCTRNUM)")>0
        Diszo [M]TCTRNUM
        Actzo [M]TCTRNUM(PNBLIG)
    Endif
    #---

Default Mask LMSKCOU

End

###############################################################################
# STKGRICOL : Grise les colonnes ne pouvant plus être modifiées
#             Appelé dans la gestion des avoirs pour les avoirs sans mvt de stock
#                    Dans LIENS pour grizer toutes les colonnes stock
###############################################################################
#Les champs suivants sont grisés:
#    STA
#    LOCTYP
#    LOC
#    WRH
#    BPSLOT
#    LOT
#    NBSLO
#    SLO
#    SERNUM
#    ...
# Attention: Dans l'action LIENS, un affzo doit être appelé avant afin que
#            les grizo soient pris en compte
###############################################################################
Subprog STKGRICOL(PABR, PNBLIG)
Value Char    PABR
Value Integer PNBLIG
Local Char LMSKCOU : LMSKCOU = func STKLIB.MSKDEF    #CCC: astuce donnée par MB

Default Mask "["+PABR+"]"
    If evalue("dim([M:"+PABR+"]STA)")>0
        Grizo [M]STA
    Endif
    If evalue("dim([M:"+PABR+"]LOCTYP)")>0
        Grizo [M]LOCTYP
    Endif
    If evalue("dim([M:"+PABR+"]LOC)")>0
        Grizo [M]LOC
    Endif
    If evalue("dim([M:"+PABR+"]WRH)")>0
        Grizo [M]WRH
    Endif
    If evalue("dim([M:"+PABR+"]BPSLOT)")>0
        Grizo [M]BPSLOT
    Endif
    If evalue("dim([M:"+PABR+"]LOT)")>0
        Grizo [M]LOT
    Endif
    If evalue("dim([M:"+PABR+"]NBSLO)")>0
        Grizo [M]NBSLO
    Endif
    If evalue("dim([M:"+PABR+"]SLO)")>0
        Grizo [M]SLO
    Endif
    If evalue("dim([M:"+PABR+"]SERNUM)")>0
        Grizo [M]SERNUM
    Endif
    If evalue("dim([M:"+PABR+"]PRIORD)")>0
        Grizo [M]PRIORD
    Endif
    If evalue("dim([M:"+PABR+"]MVTDES)")>0
        Grizo [M]MVTDES
    Endif
    If evalue("dim([M:"+PABR+"]PALNUM)")>0
        Grizo [M]PALNUM
    Endif
    If evalue("dim([M:"+PABR+"]CTRNUM)")>0
        Grizo [M]CTRNUM
    Endif
    # HCB 71276
    If evalue("dim([M:"+PABR+"]ECCVALMAJ)")>0
        Grizo [M]ECCVALMAJ
    Endif
    If evalue("dim([M:"+PABR+"]ECCVALMIN)")>0
        Grizo [M]ECCVALMIN
    Endif
    #---
    #--- Issue X3-53322
    If evalue("dim([M:"+PABR+"]LPNNUM)")>0
        Grizo [M]LPNNUM
    Endif
    If evalue("dim([M:"+PABR+"]TCTRNUM)")>0
        Grizo [M]TCTRNUM
    Endif
    #---

Default Mask LMSKCOU

End

########################################
# Grise tous les champs stock
########################################
Subprog STKDISLIG(PLIG)
Value Integer PLIG
#--- Issue 122875 remplacement LMSKCOU(7) par LMSKCOU(10)
Local Char    LMSKCOU(10)    : LMSKCOU = func STKLIB.MSKDEF

#--- X3-35900
If LMSKCOU<>"[PTH1]"
#---
  If evalue("dim("+LMSKCOU+"STA)")>0
    Diszo [M]STA(PLIG)
  Endif
  If evalue("dim("+LMSKCOU+"LOC)")>0
    Diszo [M]LOCTYP(PLIG),LOC(PLIG)
  Endif
  If evalue("dim("+LMSKCOU+"WRH)")>0
    Diszo [M]WRH(PLIG)
  Endif
  #--- Issue X3-53322
  If evalue("dim("+LMSKCOU+"LPNNUM)")>0
     Diszo [M]LPNNUM(PLIG)
  Endif
  If evalue("dim("+LMSKCOU+"TCTRNUM)")>0
     Diszo [M]TCTRNUM(PLIG)
  Endif
  #---
#--- X3-35900
Endif
#---
If evalue("dim("+LMSKCOU+"BPSLOT)")>0
    Diszo [M]BPSLOT(PLIG)
Endif
If evalue("dim("+LMSKCOU+"LOT)")>0
    Diszo [M]LOT(PLIG)
Endif
If evalue("dim("+LMSKCOU+"SLO)")>0
    Diszo [M]NBSLO(PLIG),SLO(PLIG)
Endif
If evalue("dim("+LMSKCOU+"SERNUM)")>0
    Diszo [M]SERNUM(PLIG)
Endif
If evalue("dim("+LMSKCOU+"PALNUM)")>0
    Diszo [M]PALNUM(PLIG)
Endif
If evalue("dim("+LMSKCOU+"CTRNUM)")>0
    Diszo [M]CTRNUM(PLIG)
Endif
# HCB 71276
If evalue("dim("+LMSKCOU+"ECCVALMAJ)")>0
    Diszo [M]ECCVALMAJ(PLIG)
Endif
If evalue("dim("+LMSKCOU+"ECCVALMIN)")>0
    Diszo [M]ECCVALMIN(PLIG)
Endif
#---

If evalue("dim("+LMSKCOU+"WSTOSAI)")>0
  #--- X3-35900
  If LMSKCOU="[PTH1]"
    [M]WSTOSAI(PLIG) = left$([M]WSTOSAI(PLIG),6)+"22222"+mid$([M]WSTOSAI(PLIG),12,2)+"22"
  Else
  #---
    [M]WSTOSAI(PLIG) = left$([M]WSTOSAI(PLIG),3)+"22222222"+mid$([M]WSTOSAI(PLIG),12,2)+"22"  # hcb 27200
  #--- X3-35900
  Endif
  #---
Endif

End


########################################
# Active une ligne du tableau
########################################
Subprog STKACTLIG(PLIG)
Value Integer PLIG
#--- Issue 122875 remplacement LMSKCOU(7) par LMSKCOU(10)
Local Char    LMSKCOU(10)    : LMSKCOU = func STKLIB.MSKDEF

    If evalue("dim("+LMSKCOU+"STA)")>0
        Actzo [M]STA(PLIG)
    Endif
    If evalue("dim("+LMSKCOU+"LOCTYP)")>0
        Actzo [M]LOCTYP(PLIG)
    Endif
    If evalue("dim("+LMSKCOU+"LOC)")>0
        Actzo [M]LOC(PLIG)
    Endif
    If evalue("dim("+LMSKCOU+"WRH)")>0
        Actzo [M]WRH(PLIG)
    Endif
    If evalue("dim("+LMSKCOU+"BPSLOT)")>0
        Actzo [M]BPSLOT(PLIG)
    Endif
    If evalue("dim("+LMSKCOU+"LOT)")>0
        Actzo [M]LOT(PLIG)
    Endif
    If evalue("dim("+LMSKCOU+"NBSLO)")>0
        Actzo [M]NBSLO(PLIG)
    Endif
    If evalue("dim("+LMSKCOU+"SLO)")>0
        Actzo [M]SLO(PLIG)
    Endif
    If evalue("dim("+LMSKCOU+"SERNUM)")>0
        Actzo [M]SERNUM(PLIG)
    Endif
    If evalue("dim("+LMSKCOU+"PALNUM)")>0
        Actzo [M]PALNUM(PLIG)
    Endif
    If evalue("dim("+LMSKCOU+"CTRNUM)")>0
        Actzo [M]CTRNUM(PLIG)
    Endif
    # HCB 71276
    If evalue("dim("+LMSKCOU+"ECCVALMAJ)")>0
       Actzo [M]ECCVALMAJ(PLIG)
    Endif
    If evalue("dim("+LMSKCOU+"ECCVALMIN)")>0
       Actzo [M]ECCVALMIN(PLIG)
    Endif
    #---
    #--- Issue X3-53322
    If evalue("dim("+LMSKCOU+"LPNNUM)")>0
        Actzo [M]LPNNUM(PLIG)
    Endif
    If evalue("dim("+LMSKCOU+"TCTRNUM)")>0
        Actzo [M]TCTRNUM(PLIG)
    Endif
    #---
    If evalue("dim("+LMSKCOU+"WSTOSAI)")>0
        [M]WSTOSAI(PLIG) = "000000000000000"
    Endif
End

#########################################################
# Active une ligne du tableau avec le masque en parametre
#########################################################
Subprog STKACTLIGM(PLIG,LABR)
Value Integer PLIG
Value    Char LABR

Default Mask "["+LABR+"]"
If evalue("dim([M:"+LABR+"]STA)")>0
        Actzo [M]STA(PLIG)
Endif
If evalue("dim([M:"+LABR+"]LOCTYP)")>0
        Actzo [M]LOCTYP(PLIG)
Endif
If evalue("dim([M:"+LABR+"]LOC)")>0
        Actzo [M]LOC(PLIG)
Endif
If evalue("dim([M:"+LABR+"]WRH)")>0
        Actzo [M]WRH(PLIG)
Endif
If evalue("dim([M:"+LABR+"]BPSLOT)")>0
        Actzo [M]BPSLOT(PLIG)
Endif
If evalue("dim([M:"+LABR+"]LOT)")>0
        Actzo [M]LOT(PLIG)
Endif
If evalue("dim([M:"+LABR+"]NBSLO)")>0
        Actzo [M]NBSLO(PLIG)
Endif
If evalue("dim([M:"+LABR+"]SLO)")>0
        Actzo [M]SLO(PLIG)
Endif
If evalue("dim([M:"+LABR+"]SERNUM)")>0
        Actzo [M]SERNUM(PLIG)
Endif
If evalue("dim([M:"+LABR+"]PALNUM)")>0
        Actzo [M]PALNUM(PLIG)
Endif
If evalue("dim([M:"+LABR+"]CTRNUM)")>0
        Actzo [M]CTRNUM(PLIG)
Endif
# HCB 71276
If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>0
        Actzo [M]ECCVALMAJ(PLIG)
Endif
If evalue("dim([M:"+LABR+"]ECCVALMIN)")>0
       Actzo [M]ECCVALMIN(PLIG)
Endif
#---
#--- Issue X3-53322
If evalue("dim([M:"+LABR+"]LPNNUM)")>0
    Actzo [M]LPNNUM(PLIG)
Endif
If evalue("dim([M:"+LABR+"]TCTRNUM)")>0
    Actzo [M]TCTRNUM(PLIG)
Endif
#---
If evalue("dim([M:"+LABR+"]WSTOSAI)")>0
        [M]WSTOSAI(PLIG) = "000000000000000"
Endif
End


##################################################################################
# Action INIZONENT appelée en après modification du champ ITMREF                 #
#             Initialisation et grisage champs stock sur ligne document d'entrée #
##################################################################################
# Paramètres E : LABR    = Abréviation écran
#                LITM    = Article
#                LFCY    = Site
#                LBPR    = Tiers
#                LTYPBPR = Type de tiers (1=Fournisseur, 2=Client)
#                LSUP    = "U" : Ne pas initialiser les champs Unité C, Coef, et US
#                          "S" : Article géré en stock obligatoire
#                LLIN    = Indice de la ligne en cours de saisie (nolign-1)
#                LTRSTYP = Type mvt de stock (menu local 704)
#                LTRSCOD = Code mouvement  (table diverse 14)
#                LCUN    = Message d'avertissement
#                           Si appel dans une transaction, mettre 0
#                           Si allocation mettre 0 ou 2
#                           0=non
#                           1=oui si article bloqué pour inventaire
#                           2=oui si article inutilisable
#                           3=oui si article bloqué pour inventaire ou inutilisable
#                LAFF    = Affichage des champs stock (0=Non, 1=Oui)
#            S : mkstat (0=OK / 1=Erreur)
#
# Prérequis    : Ces tables doivent être ouvertes   ITMMASTER
#                                                   ITMCATEG
#                                                   ITMFACILIT
#                                                   ITMMVT
#                                                   TABSTORUL
#                La classe [M] par défaut est celle du tableau des lignes article
##################################################################################
Subprog INIZONENT(LITM,LABR,LFCY,LBPR,LTYPBPR,LSUP,LLIN,LTRSTYP,LTRSCOD,LVCRNUM,LCUN,LAFF)
Value    Char     LITM
Value    Char     LABR
Value    Char     LFCY
Value    Char     LBPR
Value    Integer  LTYPBPR
Value    Char     LSUP
Value    Integer  LLIN
Value    Integer  LTRSTYP
Value    Char     LTRSCOD
Value    Char     LVCRNUM
Value    Integer  LCUN
Value    Integer  LAFF

#----- Variables locales -----#
Local    Integer  WPTHQUAFLG
Local    Integer  WRET, WQUAFLG, WSAICOEF, WTYPUOM, I,LITP # hcb V6CQ
Local    Char     WUSCAV(2), WLBEFMT(GLONARP), WUOM(GLONUOM), WSAIFLG(15)
Local    Decimal  WCOEF
Local    Char     WMSKCOU : WMSKCOU=func STKLIB.MSKDEF
Local    Integer  WLIGLOT
Local    Shortint W_K

If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
If [F:FCY]FCY<>LFCY
   Read [FCY]FCY0=LFCY
   If fstat  Raz [F:FCY] : mkstat=1 : End : Endif
Endif

If GWRHACT=2
   If !clalev([M:ITW])  Local File ITMWRH    [ITW] Endif
Endif

#----- Lecture table article par sécurité (appels autres que sur AM_ITMREF)
If [F:ITM]ITMREF<>LITM
   Read [ITM]ITM0=LITM
   If fstat  Raz [F:ITM] : mkstat=1 : End : Endif
Endif

#----- Lecture ITMFACILIT  pour recuperer STOMGTCOD
If [F:ITM]STOMGTCOD > 1
   If [F:ITF]STOFCY <> LFCY | [F:ITF]ITMREF <> [F:ITM]ITMREF
      Read [ITF]ITF0 = [F:ITM]ITMREF;LFCY
      If fstat
         Raz [F:ITF]
         If fstat = 5
            GMESSAGE = mess(139,197,1)
            mkstat=1
            End
         Endif
      Endif
   Endif
Endif
#----- Article non géré en stock ------#
If [F:ITM]STOMGTCOD<2 | [F:ITF]STOMGTCOD<2
   If instr(1,LSUP,"S")
      GMESSAGE = mess(283,197,1)
      mkstat=1
      End
   Endif

  #----- Lecture article-fournisseur si nécessaire -----#
  Gosub LEC_TABSTO
  If !instr(1,LSUP,"U")
      #----- Initialisation unités et coefficient -----#
      Gosub INIT_UNITE_COEF From STKECR2 : If mkstat End : Endif
  Endif
  Default Mask "["+LABR+"]"   # hcb 70382  + rajout [M]

  #----- Effacement et grisage des champs stock -----#
  If evalue("dim([M:"+LABR+"]PALNUM)")>0    Raz [M]PALNUM(LLIN) : Grizo [M]PALNUM(LLIN) : Endif
  If evalue("dim([M:"+LABR+"]CTRNUM)")>0    Raz [M]CTRNUM(LLIN) : Grizo [M]CTRNUM(LLIN) : Endif
  If evalue("dim([M:"+LABR+"]MVTDES)")>0    Raz [M]MVTDES(LLIN) : Grizo [M]MVTDES(LLIN) : Endif
  If evalue("dim([M:"+LABR+"]STA)")>0       Raz [M]STA(LLIN)    : Grizo [M]STA(LLIN)    : Endif
  If evalue("dim([M:"+LABR+"]LOC)")>0       Raz [M]LOCTYP(LLIN) : Grizo [M]LOCTYP(LLIN)
                                            Raz [M]LOC(LLIN)    : Grizo [M]LOC(LLIN)    : Endif
  If evalue("dim([M:"+LABR+"]WRH)")>0       Raz [M]WRH(LLIN)    : Grizo [M]WRH(LLIN)    : Endif
  If evalue("dim([M:"+LABR+"]BPSLOT)")>0    Raz [M]BPSLOT(LLIN) : Grizo [M]BPSLOT(LLIN) : Endif
  If evalue("dim([M:"+LABR+"]LOT)")>0       Raz [M]LOT(LLIN)    : Grizo [M]LOT(LLIN)    : Endif
  If evalue("dim([M:"+LABR+"]SLO)")>0       Raz [M]NBSLO(LLIN)  : Grizo [M]NBSLO(LLIN)
                                            Raz [M]SLO(LLIN)    : Grizo [M]SLO(LLIN)
                                            Raz [M]SLOF(LLIN)                        : Endif
  #                                                                                       # hcb 71276 deb
  If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>0 Raz [M]ECCVALMAJ(LLIN) : Grizo [M]ECCVALMAJ(LLIN)
                                            Raz [M]ECCVALMIN(LLIN) : Grizo [M]ECCVALMIN(LLIN): Endif
  #                                                                                       # hcb 71276 fin
  #--- Issue X3-53322
  If evalue("dim([M:"+LABR+"]LPNNUM)")>0    Raz [M]LPNNUM(LLIN)  : Grizo [M]LPNNUM(LLIN)  : Endif
  If evalue("dim([M:"+LABR+"]TCTRNUM)")>0   Raz [M]TCTRNUM(LLIN) : Grizo [M]TCTRNUM(LLIN) : Endif
  #---
  If evalue("dim([M:"+LABR+"]SERNUM)")>0    Raz [M]SERNUM(LLIN) : Grizo [M]SERNUM(LLIN)
                                            Raz [M]SERNUMF(LLIN)                     : Endif
  If LABR <> "DBY1"                # hcb 28654
     If evalue("dim([M:"+LABR+"]PRIORD)")>0    Raz [M]PRIORD(LLIN) : Grizo [M]PRIORD(LLIN) : Endif
  Endif                            # hcb 28654
  If evalue("dim([M:"+LABR+"]CPR)")>0       Raz [M]CPR(LLIN)    : Grizo [M]CPR(LLIN)    : Endif
  #-----
  If evalue("dim([M:"+LABR+"]WSTOSAI)")>0   [M]WSTOSAI(LLIN)="000222222222222"       : Endif
  WQUAFLG    = [F:ITF]QUAFLG                            # hcb V6CQ
  If LBPR <> "" &  LTYPBPR = 1  & LBPR = [F:ITP]BPSNUM  # hcb V6CQ
     WQUAFLG = [F:ITP]QUAFLG                            # hcb V6CQ
  Endif                                                 # hcb V6CQ
  #If evalue("dim([M:"+LABR+"]QUAFLG)")>0 & dim(LQUA)>0  # hcb V6CQ + Bug 56754 MBT 24/07/09
  #   Assign "[M:"+LABR+"]QUAFLG(LLIN)" With LQUA        # hcb V6CQ
  #Endif                                                 # hcb V6CQ
  If evalue("dim([M:"+LABR+"]QUAFLG)")>0                 # hcb V6CQ + Bug 56998 TS 06/08/09
     Assign "[M:"+LABR+"]QUAFLG(LLIN)" With WQUAFLG      # hcb V6CQ
  Endif                                                  # hcb V6CQ

  End
Endif

If LABR = "BBY0"
   If [F:SRT]SRTTYP = 7 & [F:SRT]PNTMVTCOD = 1
      If !instr(1,LSUP,"U")
  #----- Initialisation unités et coefficient -----#
         Gosub INIT_UNITE_COEF From STKECR2 : If mkstat End : Endif
      Endif
      End
   Endif
Endif

#----- Articles gérés en stock, lecture des tables articles -----#
WSAIFLG="000000000000000"
Gosub LEC_TABSTO : If WRET<>0  mkstat=1 : End : Endif
If !instr(1,LSUP,"U")
  #----- Initialisation unités et coefficient -----#
  Gosub INIT_UNITE_COEF From STKECR2 : If mkstat End : Endif
Endif
#----- Initialisation statut par défaut -----#
Actzo STA(LLIN)

If LABR <> "SSL1"                                                    # hcb V6CQ freq deb
   WPTHQUAFLG = 0
   # Sauvegarde ctrl qualité saisi en réception (1 ou 3)
   If LABR = "PTH1" & dim([M]QUAFLG)>0
      WPTHQUAFLG = [M]QUAFLG(LLIN)
   Endif
   # Alimentation WQUAFLG avec contrôle article-site ou article fournisseur
   WQUAFLG    = [F:ITF]QUAFLG
   If LBPR <> "" &  LTYPBPR = 1  & LBPR = [F:ITP]BPSNUM
      If WQUAFLG <> 2
         WQUAFLG = [F:ITP]QUAFLG
      Endif
   Endif
   # Si WQUAFLG = pas de contrôle ou contrôle modifiable,
   # on prend la valeur de contrôle saisie en réception
   If (WQUAFLG=1 & WPTHQUAFLG=3) | (WQUAFLG=3 & WPTHQUAFLG=1)
      WQUAFLG = WPTHQUAFLG
   Endif
   # Calcul de la fréquence pour déterminer si contrôle nécessaire
   Call STKFREQCQ(LABR,LFCY,LLIN,LITM,LBPR,"S",WQUAFLG,LITP) From STKACT
   # Si le calcul de fréquence renvoie pas de contrôle, et que l'on a voulu
   # un contrôle au niveau de la réception, alors contrôle facultatif
   If WQUAFLG = 1 & WPTHQUAFLG = 3
      WQUAFLG = WPTHQUAFLG
   Endif
# Plan de rangement
Else
   WQUAFLG=[M]QUAFLG(LLIN)
Endif                                                                 # hcb V6CQ freq fin
#---

Call STKINISTA([M]STA(LLIN),LBPR,WQUAFLG) From STKACT
#----- Initialisation de l'emplacement -----#
If [F:ITF]LOCMGTCOD<2
  #----- Pas de gestion d'emplacement -----#
  If evalue("dim([M:"+LABR+"]LOC)")>0
    Raz [M]LOCTYP(LLIN) : Grizo LOCTYP(LLIN)
    Raz [M]LOC(LLIN)    : Grizo LOC(LLIN)
  Endif
  WSAIFLG=left$(WSAIFLG,4)+"22"+right$(WSAIFLG,7)
  If evalue("dim([M:"+LABR+"]WRH)")>0
    Raz [M]WRH(LLIN) : Grizo WRH(LLIN)
  Endif
Else
  #----- Gestion d'emplacement -----#
  If evalue("dim([M:"+LABR+"]WLOCSEQ)")>0
    Call STKWLOCSEQ(mid$(WMSKCOU,2,len(WMSKCOU)-2), LLIN, WRET) From STKECR
  Endif
  If evalue("dim([M:"+LABR+"]LOC)")>0
    Actzo LOCTYP(LLIN)
    Actzo LOC(LLIN)
    #--- Issue X3-88004
    #If dim([M]SRGLOCDEF) > 0 & [M]SRGLOCDEF <>""
    Local Char WABR(10)
    If LABR="PTH1"
      WABR="PTH0"
    Elsif LABR="SIH4"
      WABR="SIH1"
    Elsif LABR="SMR1"
      WABR="SMR0"
    Else
      WABR=LABR
    Endif
    If evalue("dim([M:"+WABR+"]SRGLOCDEF)")>0 & evalue("[M:"+WABR+"]SRGLOCDEF")<>""
    #---
        # L'emplacement quai est forcément bon (illimité, multi-article...)
        # le contrôle du site a été fait à la saisie

        #--- Issue X3-88004
        #Read [STC]STC0=LFCY;[M]SRGLOCDEF
        Read [STC]STC0=LFCY;evalue("[M:"+WABR+"]SRGLOCDEF")
        #---
        Call STKCTRSTA([M]STA(LLIN),[F:STC]AUZSST,0,1,0,W_K) From STKACT
        If W_K=0
           #--- Issue X3-88004
           #[M]LOC(LLIN)    = [M]SRGLOCDEF
           #[M]LOCTYP(LLIN) = [F:STC]LOCTYP
           Assign "[M:"+LABR+"]LOC(LLIN)"    With [F:STC]LOC
           Assign "[M:"+LABR+"]LOCTYP(LLIN)" With [F:STC]LOCTYP
           #---
        Endif

    Endif
  Endif
  #----- Alimentation dépôt détail
  If evalue("dim([M:"+LABR+"]WRH)")>0 & dim([M]WRHE)>0
    If [F:FCY]WRHGES=2
      # Dépôt entête obligatoire
      If GWRHOBY=2
        Assign "[M:"+LABR+"]WRH(LLIN)" With [M]WRHE
        Diszo WRH(LLIN)
      Else
        If evalue("[M:"+LABR+"]WRH(LLIN)")="" & [M]WRHE<>""
          Assign "[M:"+LABR+"]WRH(LLIN)" With [M]WRHE
        Endif
        Actzo WRH(LLIN)
      Endif
      #--- Contrôle existence article dépôt
      Read [ITW]ITW0=LITM;evalue("[M:"+LABR+"]WRH(LLIN)")
      If fstat
         #--- Bug 65478
         # Si mono-dépôt ou dépôt ligne non saisissable
         #If GWRHOBY=2 | evalue("varmode([M:"+LABR+"]WRH)")<>0
         # Si mono-dépôt
         If GWRHOBY=2
         #---
           mkstat=1
           GMESSAGE = mess(978,196,1)-evalue("[M:"+LABR+"]WRH(LLIN)")
           End
         Else
           Assign "[M:"+LABR+"]WRH(LLIN)" With ""
         Endif
      Endif
    Else
      Assign "[M:"+LABR+"]WRH(LLIN)" With "" : Grizo WRH(LLIN)
    Endif
  Endif
Endif
#----- Initialisation palnum ctrnum -----#
If evalue("dim([M:"+LABR+"]PALNUM)")>0  Raz [M]PALNUM(LLIN) : Endif   # hcb 27200
If evalue("dim([M:"+LABR+"]CTRNUM)")>0  Raz [M]CTRNUM(LLIN) : Endif   # hcb 27200

#----- Initialisation lot fournisseur, lot et sous-lot -----#
If evalue("dim([M:"+LABR+"]BPSLOT)")>0  Raz [M]BPSLOT(LLIN) : Endif
If evalue("dim([M:"+LABR+"]GESLOT)")>0  Raz [M]GESLOT(LLIN) : Endif
If evalue("dim([M:"+LABR+"]LOT)")>0     Raz [M]LOT(LLIN)    : Endif
If evalue("dim([M:"+LABR+"]SLO)")>0     Raz [M]NBSLO(LLIN)
                                        Raz [M]SLO(LLIN)
                                        Raz [M]SLOF(LLIN)   : Endif
  #                                                                                       # hcb 71276 deb
If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>0 Raz [M]ECCVALMAJ(LLIN)
                                          Raz [M]ECCVALMIN(LLIN) : Endif

If [F:ITM]ECCFLG < 2 | [F:ITM]ECCSTO < 2
   If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>0 Grizo  [M]ECCVALMAJ(LLIN)
                                             Grizo  [M]ECCVALMIN(LLIN) : Endif
Endif
If [F:ITM]ECCSTO<3
   If evalue("dim([M:"+LABR+"]ECCVALMIN)")>0 Grizo  [M]ECCVALMIN(LLIN) : Endif
Endif
  #                                                                                       # hcb 71276 fin
#--- Issue X3-53322
If evalue("dim([M:"+LABR+"]LPNNUM)")>0
   Raz [M]LPNNUM(LLIN)
   If [F:ITF]LPNMGTCOD=2
      Actzo [M]LPNNUM(LLIN)
   Else
      Grizo [M]LPNNUM(LLIN)
   Endif
Endif
If evalue("dim([M:"+LABR+"]TCTRNUM)")>0
   Raz [M]TCTRNUM(LLIN)
   If [F:ITF]LPNMGTCOD=2
      Actzo [M]TCTRNUM(LLIN)
      [M]TCTRNUM(LLIN) = [F:ITF]TCTRDEF
   Else
      Grizo [M]TCTRNUM(LLIN)
   Endif
Endif
#---

If [F:ITM]LOTMGTCOD<2
  If evalue("dim([M:"+LABR+"]BPSLOT)")>0 Grizo [M]BPSLOT(LLIN) : Endif
  If evalue("dim([M:"+LABR+"]LOT)")>0    Grizo [M]LOT(LLIN)    : Endif
  If evalue("dim([M:"+LABR+"]SLO)")>0    Grizo [M]NBSLO(LLIN)
                                         Grizo [M]SLO(LLIN)    : Endif
  WSAIFLG=left$(WSAIFLG,6)+"2222"+right$(WSAIFLG,11)
Else
  If evalue("dim([M:"+LABR+"]GESLOT)")>0
    If [F:SRU]LOTSUPINH=3
      [M]GESLOT(LLIN)="V"
      If evalue("dim([M:"+LABR+"]LOT)")>0 [M]LOT(LLIN)=LVCRNUM : Endif
    Elsif [F:ITM]LOTCOU<>""
      [M]GESLOT(LLIN)="C"    # Compteur article (nécessaire au cas où le lot n'est pas saisissable)
    Else
      Raz [M]GESLOT(LLIN)    # Pas de compteur lot dans l'article
    Endif
  Endif
  If evalue("dim([M:"+LABR+"]BPSLOT)")>0 Actzo [M]BPSLOT(LLIN) : Endif
  If [F:SRU]DACLOT<2
    If evalue("dim([M:"+LABR+"]LOT)")>0  Diszo LOT(LLIN)       : Endif
    WSAIFLG=left$(WSAIFLG,7)+"2"+right$(WSAIFLG,9)
    # Si pas de saisie du lot et reprise numéro de pièce et pas gestion de sous-lot
    # => initialisation du lot fournisseur
    If [F:ITM]LOTMGTCOD<>4 & [M]GESLOT(LLIN)="V"
      If evalue("dim([M:"+LABR+"]LOT)")>0 & evalue("dim([M:"+LABR+"]BPSLOT)")>0
        If [M]LOT(LLIN)<>""
            Read [STL]STL0(2)=LITM;[M]LOT(LLIN)
            [G:STL]currlen = 0
            If !fstat
                [M]BPSLOT(LLIN)=[STL]BPSLOT
            Else
                Gosub INIT_BPSLOT From STKECR2
            Endif
        Else
            Gosub INIT_BPSLOT From STKECR2
        Endif
      Endif
    Endif
  Else
    If evalue("dim([M:"+LABR+"]LOT)")>0 Actzo LOT(LLIN)    : Endif
  Endif
  If [F:ITM]LOTMGTCOD<>4
    If evalue("dim([M:"+LABR+"]SLO)")>0
      Grizo NBSLO(LLIN)
      Grizo SLO(LLIN)
    Endif
    WSAIFLG=left$(WSAIFLG,8)+"22"+right$(WSAIFLG,11)
  Else
    If evalue("dim([M:"+LABR+"]SLO)")>0
      [M]NBSLO(LLIN)=1
      Actzo NBSLO(LLIN)
      Actzo SLO(LLIN)
# CCC 09/07/04 : Pose problème quand on saisit ensuite un lot qui existe avec le sous-lot "00001"
# puisque la proposition du prochain sous-lot n'est pas faite
#      [M]SLO(LLIN)=format$("N0:"+num$(GLONSLO),1)
    Endif
  Endif
Endif
#----- Initialisation no de série -----#
If evalue("dim([M:"+LABR+"]SERNUM)")>0
  Raz [M]SERNUM(LLIN)
  Raz [M]SERNUMF(LLIN)
Endif
#--- Issue 110327
#If (func STKLIB.SENSTRS(LTRSTYP)=1) & [F:ITM]SERMGTCOD<>3 | [F:ITM]SERMGTCOD=1
If (func STKLIB.SENSTRS(LTRSTYP)=1) & [F:ITM]SERMGTCOD<3 | [F:ITM]SERMGTCOD=1
#---
  If evalue("dim([M:"+LABR+"]SERNUM)")>0  Grizo SERNUM(LLIN) : Endif
  WSAIFLG=left$(WSAIFLG,10)+"2"+right$(WSAIFLG,12)
Else
  If evalue("dim([M:"+LABR+"]SERNUM)")>0 Actzo SERNUM(LLIN) : Endif
  If evalue("dim([M:"+LABR+"]NBSLO)")>0  Diszo NBSLO(LLIN)  : Endif
  WSAIFLG=left$(WSAIFLG,8)+"2"+right$(WSAIFLG,10)
Endif
#-----
If evalue("dim([M:"+LABR+"]WSTOSAI)")>LLIN [M]WSTOSAI(LLIN)=WSAIFLG : Endif
#----- Affichage des champs stock -----#
If LAFF
  Affzo STA(LLIN)
  If evalue("dim([M:"+LABR+"]LOC)")>0       Affzo LOCTYP(LLIN)
                                            Affzo LOC(LLIN)     : Endif
  If evalue("dim([M:"+LABR+"]WRH)")>0       Affzo WRH(LLIN)     : Endif
  If evalue("dim([M:"+LABR+"]BPSLOT)")>0    Affzo BPSLOT(LLIN)  : Endif
  If evalue("dim([M:"+LABR+"]LOT)")>0       Affzo LOT(LLIN)     : Endif
  If evalue("dim([M:"+LABR+"]SLO)")>0       Affzo NBSLO(LLIN)
                                            Affzo SLO(LLIN)
                                            Affzo SLOF(LLIN)    : Endif
  If evalue("dim([M:"+LABR+"]SERNUM)")>0    Affzo SERNUM(LLIN)
                                            Affzo SERNUMF(LLIN) : Endif
  If evalue("dim([M:"+LABR+"]MVTDES)")>0    Affzo MVTDES(LLIN)  : Endif
  If evalue("dim([M:"+LABR+"]PALNUM)")>0    Affzo PALNUM(LLIN)  : Endif
  If evalue("dim([M:"+LABR+"]CTRNUM)")>0    Affzo CTRNUM(LLIN)  : Endif
  #                                                                                       # hcb 71276 deb
  If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>0 Affzo [M]ECCVALMAJ(LLIN)
                                            Affzo [M]ECCVALMIN(LLIN) : Endif
  #                                                                                       # hcb 71276 fin
  #--- Issue X3-53322
  If evalue("dim([M:"+LABR+"]LPNNUM)")>0    Affzo [M]LPNNUM(LLIN)    : Endif
  If evalue("dim([M:"+LABR+"]TCTRNUM)")>0   Affzo [M]TCTRNUM(LLIN)   : Endif
  #---
Endif

End

#-----------------------------#
# Lecture des tables articles #
#-----------------------------#
$LEC_TABSTO
#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> LFCY | [F:ITF]ITMREF <> LITM
   Read [ITF]ITF0 = LITM;LFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

If [F:ITM]STOMGTCOD<2 | [F:ITF]STOMGTCOD<2
  #----- Lecture article-fournisseur si nécessaire -----#
  If clalev([F:ITP]) & LBPR<>""
    If [F:ITP]ITMREF<>LITM | [F:ITP]BPSNUM<>LBPR
      Read [ITP] ITP0=LITM;LBPR : If fstat  Raz [F:ITP] : Endif
    Endif
  Endif
Else
  Call LECITM(LFCY,LITM,LBPR,LCUN,"",WRET) From STKLIB
  If WRET<>0 :  Return : Endif
  If dim([M]WSRUFLG)<1
    #----- Lecture de la règle de gestion -----#
    Call LECSRU(LFCY,[F:ITG]TCLCOD,LTRSTYP,LTRSCOD,LSUP,WRET) From STKLIB
    If WRET<>0  mkstat=1 : Return : Endif
  Elsif [M]WSRUFLG(LLIN)=0 | [M]ITMREF(LLIN)<>LITM
    #----- Lecture de la règle de gestion -----#
    Call LECSRU(LFCY,[F:ITG]TCLCOD,LTRSTYP,LTRSCOD,LSUP,WRET) From STKLIB
    If WRET<>0  mkstat=1 : Return : Endif
    If  [F:SRU]TRSCOD<>""   & [F:SRU]STOFCY<>""
      [M]WSRUFLG(LLIN)=1
    Elsif [F:SRU]TRSCOD<>""
      [M]WSRUFLG(LLIN)=2
    Elsif [F:SRU]TCLCOD<>"" & [F:SRU]STOFCY<>""
      [M]WSRUFLG(LLIN)=3
    Elsif [F:SRU]TCLCOD<>""
      [M]WSRUFLG(LLIN)=4
    Else
      [M]WSRUFLG(LLIN)=5
    Endif
  Else
    Case [M]WSRUFLG(LLIN)
      When 1
        If [F:SRU]TCLCOD<>[F:ITG]TCLCOD |
&          [F:SRU]STOFCY<>LFCY          |
&          [F:SRU]TRSTYP<>LTRSTYP       |
&          [F:SRU]TRSCOD<>LTRSCOD
          Read [SRU] SRU0=[F:ITG]TCLCOD;LFCY;LTRSTYP;LTRSCOD
          If fstat  Raz [F:SRU] : Endif
        Endif
      When 2
        If [F:SRU]TCLCOD<>[F:ITG]TCLCOD |
&          [F:SRU]STOFCY<>""            |
&          [F:SRU]TRSTYP<>LTRSTYP       |
&          [F:SRU]TRSCOD<>LTRSCOD
          Read [SRU] SRU0=[F:ITG]TCLCOD;"";LTRSTYP;LTRSCOD
          If fstat  Raz [F:SRU] : Endif
        Endif
      When 3 :
        If [F:SRU]TCLCOD<>[F:ITG]TCLCOD |
&          [F:SRU]STOFCY<>LFCY          |
&          [F:SRU]TRSTYP<>LTRSTYP       |
&          [F:SRU]TRSCOD<>""
          Read [SRU] SRU0=[F:ITG]TCLCOD;LFCY;LTRSTYP;""
          If fstat  Raz [F:SRU] : Endif
        Endif
      When 4 :
        If [F:SRU]TCLCOD<>[F:ITG]TCLCOD |
&          [F:SRU]STOFCY<>""            |
&          [F:SRU]TRSTYP<>LTRSTYP       |
&          [F:SRU]TRSCOD<>""
          Read [SRU] SRU0=[F:ITG]TCLCOD;"";LTRSTYP;""
          If fstat  Raz [F:SRU] : Endif
        Endif
      When 5 :
        If [F:SRU]TCLCOD<>""            |
&          [F:SRU]STOFCY<>""            |
&          [F:SRU]TRSTYP<>LTRSTYP       |
&          [F:SRU]TRSCOD<>""
          Read [SRU] SRU0="";"";LTRSTYP;""
          If fstat  Raz [F:SRU] : Endif
        Endif
    Endcase
  Endif
Endif
Return


##################################################################################
# Action LECFICENT appelée en avant ligne du champ NBLIG                         #
#            Lecture des tables stock nécessaire à la ligne du document d'entrée #
##################################################################################
# Paramètres E : LFCY = Site
#                LBPR = Tiers
#                LSUP = Inutilisé (paramètre supplémentaire au cas où)
#                LLIN = Indice de la ligne en cours de saisie (nolign-1)
#                LTRSTYP = Type mvt de stock (menu local 704)
#                LTRSCOD = Code mouvement  (table diverse 14)
#                LCUN    = Message d'avertissement
#                           Si appel dans une transaction, mettre 0
#                           Si allocation mettre 0 ou 2
#                           0=non
#                           1=oui si article bloqué pour inventaire
#                           2=oui si article inutilisable
#                           3=oui si article bloqué pour inventaire ou inutilisable
#
# Prérequis    : Ces tables doivent être ouvertes   ITMMASTER
#                                                   ITMCATEG
#                                                   ITMFACILIT
#                                                   ITMMVT
#                                                   TABSTORUL
#                La classe [M] par défaut est celle du tableau des lignes article
##################################################################################
Subprog LECFICENT(LFCY,LBPR,LSUP,LLIN,LTRSTYP,LTRSCOD,LCUN)
Value    Char     LFCY
Value    Char     LBPR
Value    Char     LSUP
Value    Integer  LLIN
Value    Integer  LTRSTYP
Value    Char     LTRSCOD
Value    Integer  LCUN
#----- Variables locales -----#
Local    Integer  WRET
Local    Char     LITM(GLONITM)

If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
If [F:FCY]FCY<>LFCY
   Read [FCY]FCY0=LFCY
   If fstat  Raz [F:FCY] : End : Endif
Endif

# Ce test était prévu dans le cadre de la modif de réintégration.
# Or celle-ci n'existe pas en 140 et en plus le test n'est pas bon car
# dim([M]MATITMREF) ne nous renseigne pas sur le fait qu'on est en entrée ou sortie
#If dim([M]MATITMREF)>0        # Spécif pour modif réintégration
#    #----- Lecture table article -----#
#    If [F:ITM]ITMREF<>[M]MATITMREF(LLIN)
#      Read [ITM]ITM0=[M]MATITMREF(LLIN)
#      If fstat  Raz [F:ITM] : End : Endif
#    Endif
#    #----- Lecture des autres tables -----#
#    LITM=[M]MATITMREF(LLIN)
#Else
If clalev([F:ITM]) =0  Local File ITMMASTER [ITM]  Endif
If [F:ITM]ITMREF<>[M]ITMREF(LLIN)
   Read [ITM]ITM0=[M]ITMREF(LLIN)
   If fstat  Raz [F:ITM] : End : Endif
Endif
#----- Lecture des autres tables -----#
LITM=[M]ITMREF(LLIN)
#Endif
If LSUP = "BBY0" | LSUP = "DBY0"
   If [F:SRT]SRTTYP = 7 & [F:SRT]PNTMVTCOD = 1
      End
   Endif
Endif

Gosub LEC_TABSTO
#-----
Raz GMESSAGE, mkstat
End


##################################################################################
# Action SAIZONENT appelée en avant saisie de chaque champ stock de la ligne     #
#         Permet d'interdire la saisie d'un champ si Diszo et Grizo non utilisés #
##################################################################################
# Paramètres E : LZON = Nom du champ
#                LLIN = Indice de la ligne en cours de saisie (nolign-1)
#                La classe [M] par défaut est celle du tableau des lignes article
##################################################################################
Subprog SAIZONENT(LZON,LLIN)
Value    Char     LZON
Value    Integer  LLIN
#-----
Local    Libelle  WPOS
#-----
If dim([M]WSTOSAI)>0
  Case LZON
    When "PCU",       "UOM"       : WPOS=1
    When "QTYPCU",    "QTYUOM"    : WPOS=2
    When "PCUSTUCOE", "UOMSTUCOE" : WPOS=3
    When "STA"                    : WPOS=4
    When "LOCTYP"                 : WPOS=5
    When "LOC"                    : WPOS=6
    When "BPSLOT"                 : WPOS=7
    When "LOT"                    : WPOS=8
    When "NBSLO"                  : WPOS=9
    When "SLO"                    : WPOS=10
    When "SERNUM"                 : WPOS=11
    When "PRIORD",    "CPR"       : WPOS=12
    When "MVTDES"                 : WPOS=13
    When "PALNUM"                 : WPOS=14                  # hcb 27200
    When "CTRNUM"                 : WPOS=15                  # hcb 27200
  Endcase
  If WPOS
    mkstat=val(mid$([M]WSTOSAI(LLIN),WPOS,1))
  Endif
Endif
End

################################################################################
# CTLSTOENT      Contrôle de cohérence entre les quantités de STOENTW et le document
#                et vérifie que les info lot sont validées
#
# Paramètres E : LABR = Abréviation écran
#                LZON = Nom zone quantité en US
#
# Paramètres S : LRET = Code retour (0=Erreur / 1=OK)
#
################################################################################
Subprog CTLSTOENT (LABR, LZON, LNBLIG, LRET)
Value    Char    LABR
Value    Char    LZON
Value    Integer LNBLIG
Variable Integer LRET

Local    Integer I, J, K, L
Local    Decimal WQTY
Local    Char    LWRNLOT(20)
#--- Issue X3-53322
Local    Integer IC

# Pour chaque nouvelle ligne du document, contrôle que la quantité US
# est bien égale à la somme des quantités à sortir des lignes de stock
If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif  # hcb 71366
#--- X3-53322
If !clalev([F:LPN]) : Local File LPN        [LPN] : Endif
If !clalev([F:STO]) : Local File STOCK      [STO] : Endif
#---
LRET = 1
If LNBLIG=0
    Call ERREUR(mess(17,106,1)) From GESECRAN
    LRET=0
    End
Endif
Raz LWRNLOT

For I=0 To LNBLIG-1
    # Dans WZONSTOUPD, se trouve le nom du champ (facultatif) qui indique la valeur complémentaire à prendre en compte
    # lors des tests sur CREFLG : test= (CREFLG=0 | ZONSTOUPD>0)
    If LABR="DBY1" & evalue("dim([M:"+LABR+"]STOMGTCOD)")>0 & evalue("[M:"+LABR+"]STOMGTCOD(I)")< 2
# cas du desasemblage il n y a rien à faire
    Elsif
&      (LABR <> "MTK2" & LABR <> "SSL1" & LABR <> "MBR" & (evalue("dim([M:"+LABR+"]CREFLG)")>0  & evalue("[M:"+LABR+"]CREFLG(I)")=0) )
&    | ([M:ENTW]WZONSTOUPD<>"" & evalue("[M:"+LABR+"]"+[M:ENTW]WZONSTOUPD+"(I)")>0)
&    | (LABR="SSL1" & evalue("dim([M:"+LABR+"]COCHAGE)")>0   & evalue("[M:"+LABR+"]COCHAGE(I)")=2)
&    | (LABR="MTK2" & evalue("[M:"+LABR+"]CPLQTY(I)")<> 0)
&    | (LABR="MBR"  & evalue("[M:"+LABR+"]"+LZON+"(I)")<> 0)

        If evalue("[M:"+LABR+"]WSTOFLG(I)")=1
            #------- Contrôle des compléments lots -------------#
            If evalue("sigma(J=0,[M:ENTW]NBLIG-1,([M:ENTW]WSTOSEQ(J)=[M:"+LABR+
&                     "]WSTOSEQ(I))*([M:ENTW]NUMLIGLOT(J)>0)*(2-[M:ENTW]VALIDE([M:ENTW]NUMLIGLOT(J)*([M:ENTW]NUMLIGLOT(J)>0))))")
&                <> 0
                If type(LWRNLOT)-10-len(LWRNLOT)-3>1+len(num$(I+1))
                    If LWRNLOT<>""
                        LWRNLOT+="-"
                    Endif
                    LWRNLOT+=num$(I+1)
                Else
                    LWRNLOT+="..."
                Endif
# hcb 71366 deb
                If [F:ITM]ITMREF<>evalue("[M:"+LABR+"]ITMREF(I)")
                   Read [ITM]ITM0=evalue("[M:"+LABR+"]ITMREF(I)")
                Endif
                If [F:ITM]EXYMGTCOD = 6
                   Call ERREUR(mess(61,100,1)-num$(I+1)-":"-mess(382,184,1)) From GESECRAN
                   Raz LRET
                   Break
                Endif
# hcb 71366 fin

            Endif
            #------- Contrôle de cohérence des quantité --------#
            #WQTY=sigma(J=0,[M:ENTW]NBLIG-1,[M:ENTW]QTYSTU(J)*([M:ENTW]WSTOSEQ(J)=evalue("[M:"+LABR+"]WSTOSEQ(I)")))
            WQTY=evalue("sigma(J=0,[M:ENTW]NBLIG-1,[M:ENTW]QTYSTU(J)*([M:ENTW]WSTOSEQ(J)=[M:"+LABR+"]WSTOSEQ(I)))")
            If WQTY<>evalue("[M:"+LABR+"]"+LZON+"(I)")
                Call ERREUR(mess(61,100,1)-num$(I+1)-":"-mess(20,184,1)) From GESECRAN
                Raz LRET
                Break
            Endif
        Elsif evalue("[M:"+LABR+"]WSTOFLG(I)")=0     # si =2 article non géré en stock
             Call ERREUR(evalue("[M:"+LABR+"]ITMREF(I)")-":"-mess(17,104,1)-num$(I+1)+chr$(13)+mess(7,111,1)) From GESECRAN

            Raz LRET
            Break
        Endif

        Call CTLVLTCOD(LABR, I, "ENT", LRET)
        If LRET = 0 : Break : Endif

   Endif
Next I

#--- Issue X3-53322
# Contrôle des no LPN saisis
If LRET

  # Une seule ligne dans STOENTW ou plusieurs mais une seule active (WSTOSEQ<>0)
  If [M:ENTW]NBLIG=1 | ([M:ENTW]NBLIG>1 & sigma(0,[M:ENTW]NBLIG-1,1*([M:ENTW]WSTOSEQ(indcum)<>0))=1)
    # Si une seule
    If [M:ENTW]NBLIG=1
      IC=0
    # Si plusieurs, récupération de l'indice de celle qui est active
    Else
      IC=sigma(0,[M:ENTW]NBLIG-1,indcum*([M:ENTW]WSTOSEQ(indcum)<>0))
    Endif
    If [M:ENTW]LPNNUM(IC)<>"" & [M:ENTW]WSTOSEQ(IC)<>0
      Read [ITM]ITM0=[M:ENTW]ITMREF(IC)
      Read [LPN]LPN0=[M:ENTW]LPNNUM(IC)
      #--- Contrôle du mono-lot pour le LPN concerné
      If [F:LPN]MONLOTFLG=2 & [F:ITM]LOTMGTCOD>1
        Filter [STO] Where LPNNUM=[M:ENTW]LPNNUM(IC) & (ITMREF<>[M:ENTW]ITMREF(IC) | LOT<>[M:ENTW]LOT([M:ENTW]NUMLIGLOT(IC)))
        Look [STO]STO3 First
        If !fstat : LRET=0 : Endif
        Filter [STO]
        If LRET=0
          Call ERREUR(func AFNC.MES2(mess(516,184,1),[M:ENTW]LPNNUM(IC),"")) From GESECRAN
        Endif
      #--- Contrôle du mono-article pour le LPN concerné
      Elsif [F:LPN]MONITMFLG=2
        Filter [STO] Where LPNNUM=[M:ENTW]LPNNUM(IC) & ITMREF<>[M:ENTW]ITMREF(IC)
        Look [STO]STO3 First
        If !fstat : LRET=0 : Endif
        Filter [STO]
        If LRET=0
          Call ERREUR(func AFNC.MES2(mess(517,184,1),[M:ENTW]LPNNUM(IC),"")) From GESECRAN
        Endif
      Endif
    Endif
  # Plusieurs lignes dans STOENTW
  Else
    For I=0 To [M:ENTW]NBLIG-2
      If [M:ENTW]LPNNUM(I)<>"" & [M:ENTW]WSTOSEQ(I)<>0
        If [F:ITM]ITMREF<>[M:ENTW]ITMREF(I)
          Read [ITM]ITM0=[M:ENTW]ITMREF(I)
        Endif
        If [F:LPN]LPNNUM<>[M:ENTW]LPNNUM(I)
          Read [LPN]LPN0=[M:ENTW]LPNNUM(I)
        Endif
        J=0
        #--- Contrôle du mono-lot pour le LPN concerné
        If [F:LPN]MONLOTFLG=2 & [F:ITM]LOTMGTCOD>1
          J=sigma(I+1,[M:ENTW]NBLIG-1,1*([M:ENTW]LPNNUM(indcum)=[M:ENTW]LPNNUM(I) & [M:ENTW]WSTOSEQ(indcum)<>0
&              & ([M:ENTW]ITMREF(indcum)<>[M:ENTW]ITMREF(I) | [M:ENTW]LOT([M:ENTW]NUMLIGLOT(indcum))<>[M:ENTW]LOT([M:ENTW]NUMLIGLOT(I)))))
          If J>=1
            LRET=0
          Else
            Filter [STO] Where LPNNUM=[M:ENTW]LPNNUM(I) & (ITMREF<>[M:ENTW]ITMREF(I) | LOT<>[M:ENTW]LOT([M:ENTW]NUMLIGLOT(I)))
            Look [STO]STO3 First
            If !fstat : LRET=0 : Endif
            Filter [STO]
          Endif
          If LRET=0
            Call ERREUR(func AFNC.MES2(mess(516,184,1),[M:ENTW]LPNNUM(I),"")) From GESECRAN
            Break
          Endif
        #--- Contrôle du mono-article pour le LPN concerné
        Elsif [F:LPN]MONITMFLG=2
          J=sigma(I+1,[M:ENTW]NBLIG-1,1*([M:ENTW]LPNNUM(indcum)=[M:ENTW]LPNNUM(I) & [M:ENTW]WSTOSEQ(indcum)<>0
&                 & [M:ENTW]ITMREF(indcum)<>[M:ENTW]ITMREF(I)))
          If J>=1
            LRET=0
          Else
            Filter [STO] Where LPNNUM=[M:ENTW]LPNNUM(I) & ITMREF<>[M:ENTW]ITMREF(I)
            Look [STO]STO3 First
            If !fstat : LRET=0 : Endif
            Filter [STO]
          Endif
          If LRET=0
            Call ERREUR(func AFNC.MES2(mess(517,184,1),[M:ENTW]LPNNUM(I),"")) From GESECRAN
            Break
          Endif
        Endif
        #--- Contrôle du mono-emplacement par LPN
        K=sigma(I+1,[M:ENTW]NBLIG-1,1*([M:ENTW]LPNNUM(indcum)=[M:ENTW]LPNNUM(I) & [M:ENTW]WSTOSEQ(indcum)<>0))
        L=sigma(I+1,[M:ENTW]NBLIG-1,1*([M:ENTW]LPNNUM(indcum)=[M:ENTW]LPNNUM(I) & [M:ENTW]WSTOSEQ(indcum)<>0
&               & [M:ENTW]LOC(indcum)=[M:ENTW]LOC(I)))
        If K<>L
          Call ERREUR(func AFNC.MES2(mess(521,184,1),[M:ENTW]LPNNUM(I),[M:ENTW]LOC(I))) From GESECRAN
          LRET=0 : Break
        Endif
      Endif
    Next I
  Endif
Endif
#---

If LRET & LWRNLOT<>""
    Call AVERTIR(mess(93,100,1)+LWRNLOT+chr$(13)+mess(101,184,1)+chr$(13)+mess(205,100,1),LRET) From GESECRAN
    LRET -= 1
Endif

GPOINT = "CTL_STOENT"
Gosub  ENTREE From EXEFNC

End


#########################################################################
######################## - Flux de sortie - #############################
#########################################################################

#########################################################################
# Action LECFICSOR (Traitement divers)                                  #
#        - Lecture des tables articles                                  #
#        - Lecture de la règle de gestion à appliquer                   #
#########################################################################
# Paramètres E : LITM    = Article
#                LFCY    = Site
#                LTRSTYP = Type mvt de stock (menu local 704)
#                LTRSCOD = Code mouvement    (table diverse 14)
#                LAFF    = Affichage msg si article en inventaire
#                         (0=non / 1=oui)
#            S : mkstat
#
# Prérequis    : Ces tables doivent être ouvertes   ITMMASTER
#                                                   ITMFACILIT
#                                                   TABSTORUL
#########################################################################
Subprog LECFICSOR(LITM,LFCY,LTRSTYP,LTRSCOD,LAFF)
Value    Char     LITM
Value    Char     LFCY
Value    Integer  LTRSTYP
Value    Char     LTRSCOD
Value    Integer  LAFF

Local    Integer  WRET
Local Char WMSKCOU(10)                                          # hcb 28649

If !clalev([F:FCY])  Local File FACILITY [FCY]  Endif
If [F:FCY]FCY<>LFCY
   Read [FCY]FCY0=LFCY
   If fstat
      Call RSTA("FCY",LFCY) From GLOCK
      mkstat=2 : End
   Endif
Endif
If LITM<>""
   # Lecture table article
   If !clalev([F:ITM])  Local File ITMMASTER [ITM]  Endif
   If [F:ITM]ITMREF<>LITM
      Read [ITM]ITM0=LITM
      If fstat
         Call RSTA("ITM",LITM) From GLOCK
         mkstat=2 : End
      Endif
   Endif
   # Si article géré en stock
   If [F:ITM]STOMGTCOD>1
      # Lecture article-site
      If [F:ITF]ITMREF<>LITM | [F:ITF]STOFCY<>LFCY
         Read [ITF]ITF0=LITM;LFCY
         If fstat
            #MAE, bg68180
            #Call RSTA("ITF",LITM-LFCY) From GLOCK
            Call MESSAGE(LITM+" "+mess(25,192,1)+" "+LFCY) From GESECRAN
            mkstat=2 : End
#         Elsif [F:ITF]CUNFLG=2 & LAFF=1                      # hcb 68693
#            Call MESSAGE(mess(185,199,1)) From GESECRAN      # hcb 68693
         Endif
      Endif
      If [F:ITF]CUNFLG=2 & LAFF=1                             # hcb 68693
         Call MESSAGE(mess(185,199,1)) From GESECRAN          # hcb 68693
      Endif                                                   # hcb 68693
      If [F:ITF]STOMGTCOD>1
         WMSKCOU=func STKLIB.MSKDEF
         If WMSKCOU = "[DBY0]"
            If [F:SRT]SRTTYP = 7 & [F:SRT]PNTMVTCOD = 1
               End
            Endif
         Endif
      # Lecture de la règle de gestion à utiliser
         Call LECSRU(LFCY,[F:ITM]TCLCOD,LTRSTYP,LTRSCOD,"",WRET) From STKLIB
         If WRET<>0
            mkstat=2 : End
         Endif
      Endif
   Endif
Endif

End

#########################################################################
# ETAZONSOR  Diszo des champs stock des lignes d'un document utilisant  #
#            le composant de saisie des sorties                         #
#########################################################################
# Paramètres E : LABR  = Abréviation écran origine
#
#########################################################################
Subprog ETAZONSOR(LABR)
Value Char LABR

Local Char WMSKCOU(10)

WMSKCOU=func STKLIB.MSKDEF

If WMSKCOU<>"["+LABR+"]"
   Default Mask "["+LABR+"]"
Endif

# Désactivation des colonnes stock du document
Diszo [M]STA
If evalue("dim([M:"+LABR+"]LOT)")>0    Diszo [M]LOT     Endif
If evalue("dim([M:"+LABR+"]SLO)")>0    Diszo [M]SLO     Endif
If evalue("dim([M:"+LABR+"]WRH)")>0    Diszo [M]WRH     Endif
If evalue("dim([M:"+LABR+"]LOC)")>0    Diszo [M]LOC     Endif
If evalue("dim([M:"+LABR+"]SERNUM)")>0 Diszo [M]SERNUM  Endif
If evalue("dim([M:"+LABR+"]PALNUM)")>0 Diszo [M]PALNUM  Endif
If evalue("dim([M:"+LABR+"]CTRNUM)")>0 Diszo [M]CTRNUM  Endif
#--- Issue X3-53322
If evalue("dim([M:"+LABR+"]LPNNUM)")>0 Diszo [M]LPNNUM  Endif
#---
Diszo [M]MVTDES

If WMSKCOU<>"["+LABR+"]"
   Default Mask WMSKCOU
Endif

End

#########################################################################
# GRIZONSOR  Grizo des champs stock (sortie) des lignes d'un document   #
#            sans gestion de stock                                      #
#            Ex : Facture proforma                                      #
#########################################################################
# Paramètres E : LABR  = Abréviation écran origine
#
#########################################################################
Subprog GRIZONSOR(LABR)
Value Char LABR

Local Char WMSKCOU(10)

WMSKCOU=func STKLIB.MSKDEF

If WMSKCOU<>"["+LABR+"]"
   Default Mask "["+LABR+"]"
Endif

# Effacement et grisage des colonnes stock du document
Grizo [M]STA
Grizo [M]MVTDES
If evalue("dim([M:"+LABR+"]WRH)")>0     Grizo [M]WRH     Endif
If evalue("dim([M:"+LABR+"]LOC)")>0     Grizo [M]LOC     Endif
If evalue("dim([M:"+LABR+"]LOT)")>0     Grizo [M]LOT     Endif
If evalue("dim([M:"+LABR+"]SLO)")>0     Grizo [M]SLO     Endif
If evalue("dim([M:"+LABR+"]SERNUM)")>0  Grizo [M]SERNUM  Endif
If evalue("dim([M:"+LABR+"]SERNUMF)")>0 Grizo [M]SERNUMF Endif
If evalue("dim([M:"+LABR+"]PALNUM)")>0  Grizo [M]PALNUM  Endif
If evalue("dim([M:"+LABR+"]CTRNUM)")>0  Grizo [M]CTRNUM  Endif
#--- Issue X3-53322
If evalue("dim([M:"+LABR+"]LPNNUM)")>0  Grizo [M]LPNNUM  Endif
#---
If WMSKCOU<>"["+LABR+"]"
   Default Mask WMSKCOU
Endif

End

#########################################################################
# Action INIZONSOR (Traitement divers)                                  #
#        Appelé en AM-ITMREF et AVANT-NBLIG                             #
#        - Lecture des tables articles                                  #
#        - Lecture de la règle de gestion à appliquer                   #
#        - Grisage des champs stock de la ligne de document selon les   #
#          caractéristiques de l'article                                #
#        - Diszo des champs stock de la ligne de document selon que le  #
#          détail stock est déjà déterminé ou non                       #
#########################################################################
# Paramètres E : LABR    = Abréviation écran origine
#                LITM    = Article
#                LFCY    = Site
#                LLIN    = Indice de la ligne en cours de saisie (nolign-1)
#                LTRSTYP = Type mvt de stock (menu local 704)
#                LTRSCOD = Code mouvement    (table diverse 14)
#                LSUP    = Inutilisé (paramètre supplémentaire au cas où)
#            S : mkstat
#
# Prérequis    : Ces tables doivent être ouvertes   ITMMASTER
#                                                   ITMFACILIT
#                                                   TABSTORUL
#########################################################################
Subprog INIZONSOR(LABR,LITM,LFCY,LLIN,LTRSTYP,LTRSCOD,LSUP)
Value    Char     LABR
Value    Char     LITM
Value    Char     LFCY
Value    Integer  LLIN
Value    Integer  LTRSTYP
Value    Char     LTRSCOD
Value    Char     LSUP
Local    Char     WSAIFLG(11) : WSAIFLG="00000000000"
Local    Integer  I, WSOW
Local    Integer  LAFF
Local    Integer  WRHGES       : # Gestion de dépôt sur le site

Local Char WMSKCOU(10)
If evalue("dim([M:"+LABR+"]WSTOSAI)")>0 & evalue("[M:"+LABR+"]WSTOSAI(LLIN)")<>""
  WSAIFLG=evalue("[M:"+LABR+"]WSTOSAI(LLIN)")
Endif

If find(LABR,"BBY1","MTK3")
   LAFF=0
Else
   LAFF=1
Endif

If [F:FCY]FCY<>LFCY
   Read [FCY]FCY0=LFCY
   If fstat Raz [F:FCY] Endif
Endif
WRHGES=[F:FCY]WRHGES

Call LECFICSOR(LITM,LFCY,LTRSTYP,LTRSCOD,LAFF) From STKECR
If mkstat End Endif
WMSKCOU=func STKLIB.MSKDEF
If WMSKCOU<>"["+LABR+"]"
   Default Mask "["+LABR+"]"
Endif

If LABR = "DBY0"
   If [F:SRT]SRTTYP = 7 & [F:SRT]PNTMVTCOD = 1
      End
   Endif
Endif
Actzo [M]STA(LLIN)
Actzo [M]MVTDES(LLIN)
If evalue("dim([M:"+LABR+"]WRH)")>0     Actzo [M]WRH(LLIN)     Endif
If evalue("dim([M:"+LABR+"]LOC)")>0     Actzo [M]LOC(LLIN)     Endif
If evalue("dim([M:"+LABR+"]LOT)")>0     Actzo [M]LOT(LLIN)     Endif
If evalue("dim([M:"+LABR+"]SLO)")>0     Actzo [M]SLO(LLIN)     Endif
If evalue("dim([M:"+LABR+"]SERNUM)")>0  Actzo [M]SERNUM(LLIN)  Endif
If evalue("dim([M:"+LABR+"]SERNUMF)")>0 Actzo [M]SERNUMF(LLIN) Endif
If evalue("dim([M:"+LABR+"]PALNUM)")>0  Actzo [M]PALNUM(LLIN)  Endif
If evalue("dim([M:"+LABR+"]CTRNUM)")>0  Actzo [M]CTRNUM(LLIN)  Endif
#--- Issue X3-53322
If evalue("dim([M:"+LABR+"]LPNNUM)")>0  Actzo [M]LPNNUM(LLIN)  Endif
#---
If LABR = "BBY1" & dim([M:BBY1]PRIORD) > 0         # hcb 28654
          Grizo [M:BBY1]PRIORD(LLIN)               # hcb 28654
Endif                                              # hcb 28654
#--- TS 106217
If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>0
  Actzo  [M]ECCVALMAJ(LLIN)
  Actzo  [M]ECCVALMIN(LLIN)
Endif
#---

# Article non géré en stock
If [F:ITM]STOMGTCOD<2 | [F:ITF]STOMGTCOD<2
   # Effacement et grisage des champs stock
   Raz [M]STA(LLIN)    : Grizo [M]STA(LLIN)
   Raz [M]MVTDES(LLIN) : Grizo [M]MVTDES(LLIN)
   If evalue("dim([M:"+LABR+"]WRH)")>0     Raz [M]WRH(LLIN)    : Grizo [M]WRH(LLIN)     Endif
   If evalue("dim([M:"+LABR+"]LOC)")>0     Raz [M]LOC(LLIN)    : Grizo [M]LOC(LLIN)     Endif
   If evalue("dim([M:"+LABR+"]LOT)")>0     Raz [M]LOT(LLIN)    : Grizo [M]LOT(LLIN)     Endif
   If evalue("dim([M:"+LABR+"]SLO)")>0     Raz [M]SLO(LLIN)    : Grizo [M]SLO(LLIN)     Endif
   If evalue("dim([M:"+LABR+"]SERNUM)")>0  Raz [M]SERNUM(LLIN) : Grizo [M]SERNUM(LLIN)  Endif
   If evalue("dim([M:"+LABR+"]SERNUMF)")>0 Raz [M]SERNUMF(LLIN): Grizo [M]SERNUMF(LLIN) Endif
   If evalue("dim([M:"+LABR+"]PALNUM)")>0  Raz [M]PALNUM(LLIN) : Grizo [M]PALNUM(LLIN)  Endif
   If evalue("dim([M:"+LABR+"]CTRNUM)")>0  Raz [M]CTRNUM(LLIN) : Grizo [M]CTRNUM(LLIN)  Endif
   #--- Issue X3-53322
   If evalue("dim([M:"+LABR+"]LPNNUM)")>0  Raz [M]LPNNUM(LLIN) : Grizo [M]LPNNUM(LLIN)  Endif
   #---
   If evalue("dim([M:"+LABR+"]WSTOSAI)")>0 [M]WSTOSAI(LLIN)="00022222222" : Endif
   If LABR = "BBY1" & dim([M:BBY1]PRIORD) > 0         # hcb 28654
             Actzo [M:BBY1]PRIORD(LLIN)               # hcb 28654
   Endif                                              # hcb 28654
   #--- TS 106217
   If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>0
     Actzo  [M]ECCVALMAJ(LLIN)
     Actzo  [M]ECCVALMIN(LLIN)
   Endif
   #---
   Goto INIZONSOR_SUI
Endif

Raz WSOW
If [M]WSTOSEQ(LLIN)<>0
   # Calcul du nb enreg SOW associé à la ligne de document
   WSOW=sigma(I=0,[M:SOW]NBLIG-1,1*([M:SOW]WSTOSEQ(I)=[M]WSTOSEQ(LLIN)))
Endif

#--- TS 106217
If [F:ITM]ECCFLG<2
  If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>0
    Grizo  [M]ECCVALMAJ(LLIN)
    Grizo  [M]ECCVALMIN(LLIN)
  Endif
Elsif [F:ITM]ECCSTO<3
  If evalue("dim([M:"+LABR+"]ECCVALMIN)")>0
    Grizo  [M]ECCVALMIN(LLIN)
  Endif
Endif
#---

If evalue("dim([M:"+LABR+"]LOT)")>0
   If [F:ITM]LOTMGTCOD<2
      Grizo [M]LOT(LLIN)
      WSAIFLG=left$(WSAIFLG,5)+"2"+right$(WSAIFLG,7)
   # S'il y a déjà des SOW ou si la ligne existe déjà, on diszo
   Elsif WSOW<>0 | [M]CREFLG(LLIN)<>0
      Diszo [M]LOT(LLIN)
      WSAIFLG=left$(WSAIFLG,5)+"2"+right$(WSAIFLG,7)
   Endif
   Affzo [M]LOT(LLIN)
Endif
If evalue("dim([M:"+LABR+"]SLO)")>0
   If [F:ITM]LOTMGTCOD<2 | [F:ITM]LOTMGTCOD<>4
      Grizo [M]SLO(LLIN)
      WSAIFLG=left$(WSAIFLG,6)+"2"+right$(WSAIFLG,8)
   Elsif WSOW<>0 | [M]CREFLG(LLIN)<>0
      Diszo [M]SLO(LLIN)
      WSAIFLG=left$(WSAIFLG,6)+"2"+right$(WSAIFLG,8)
   Endif
   Affzo [M]SLO(LLIN)
Endif

If evalue("dim([M:"+LABR+"]SERNUM)")>0
   If [F:ITM]SERMGTCOD<3
      Grizo [M]SERNUM(LLIN)
      WSAIFLG=left$(WSAIFLG,7)+"2"+right$(WSAIFLG,9)
   Elsif WSOW<>0 | [M]CREFLG(LLIN)<>0
      Diszo [M]SERNUM(LLIN)
      WSAIFLG=left$(WSAIFLG,7)+"2"+right$(WSAIFLG,9)
   Endif
   Affzo [M]SERNUM(LLIN)
Endif

If [F:ITM]SERMGTCOD<3 & evalue("dim([M:"+LABR+"]SERNUMF)")>0
   Grizo [M]SERNUMF(LLIN)
Endif
If evalue("dim([M:"+LABR+"]SERNUMF)")>0 Affzo [M]SERNUMF(LLIN) Endif

# Alimentation dépôt détail
If evalue("dim([M:"+LABR+"]WRH)")>0
  If WRHGES=2
    If dim([M]WRHE)>0
      # Si gestion d'emplacement
      If [F:ITF]LOCMGTCOD>=2
        Assign "[M:"+LABR+"]WRH(LLIN)" With [M]WRHE
        If GWRHOBY=2 | WSOW<>0 | [M]CREFLG(LLIN)<>0
          Diszo WRH(LLIN)
        Else
          Actzo WRH(LLIN)
        Endif
      Else
        Raz [M]WRH(LLIN) : Grizo WRH(LLIN)
      Endif
    Endif
  Else
    Raz [M]WRH(LLIN) : Grizo WRH(LLIN)
  Endif
  Affzo [M]WRH(LLIN)
Endif

#--- Issue X3-53322
If evalue("dim([M:"+LABR+"]LPNNUM)")>0
   If [F:ITF]LPNMGTCOD<2
      Grizo [M]LPNNUM(LLIN)
   Elsif WSOW<>0 | [M]CREFLG(LLIN)<>0
      Diszo [M]LPNNUM(LLIN)
   Endif
   Affzo [M]LPNNUM(LLIN)
Endif
#---

If evalue("dim([M:"+LABR+"]LOC)")>0
   If [F:ITF]LOCMGTCOD<2
      Grizo [M]LOC(LLIN)
      WSAIFLG=left$(WSAIFLG,4)+"2"+right$(WSAIFLG,6)
   Elsif WSOW<>0 | [M]CREFLG(LLIN)<>0
      Diszo [M]LOC(LLIN)
      WSAIFLG=left$(WSAIFLG,4)+"2"+right$(WSAIFLG,6)
   Endif
   Affzo [M]LOC(LLIN)
Endif

If WSOW<>0 | [M]CREFLG(LLIN)<>0
   Diszo [M]STA(LLIN)
   WSAIFLG=left$(WSAIFLG,3)+"2"+right$(WSAIFLG,5)
Endif
Affzo [M]STA(LLIN)

If WSOW<>0 | [M]CREFLG(LLIN)<>0
   Diszo [M]MVTDES(LLIN)
   WSAIFLG=left$(WSAIFLG,8)+"2"+right$(WSAIFLG,10)
Endif
Affzo [M]MVTDES(LLIN)

If evalue("dim([M:"+LABR+"]PALNUM)")>0
   If WSOW<>0 | [M]CREFLG(LLIN)<>0
      Diszo [M]PALNUM(LLIN)
      WSAIFLG=left$(WSAIFLG,9)+"2"+right$(WSAIFLG,11)
   Endif
   Affzo [M]PALNUM(LLIN)
Endif

If evalue("dim([M:"+LABR+"]CTRNUM)")>0
   If WSOW<>0 | [M]CREFLG(LLIN)<>0
      Diszo [M]CTRNUM(LLIN)
      WSAIFLG=left$(WSAIFLG,10)+"2"
   Endif
   Affzo [M]CTRNUM(LLIN)
Endif

If evalue("dim([M:"+LABR+"]WSTOSAI)")>LLIN  [M]WSTOSAI(LLIN)=WSAIFLG : Endif

$INIZONSOR_SUI
If WMSKCOU<>"["+LABR+"]"
   Default Mask WMSKCOU
Endif

End

#########################################################################
# Action INIZONADC (Traitement divers)                                  #
#        Appelé en AM-ITMREF en contexte ADC                            #
#        - Lecture des tables articles                                  #
#        - Lecture de la règle de gestion à appliquer                   #
#        - Grisage des champs stock de la ligne de document selon les   #
#          caractéristiques de l'article                                #
#########################################################################
# Paramètres E : LABR    = Abréviation écran origine
#                LITM    = Article
#                LFCY    = Site
#                LLIN    = Indice de la ligne en cours de saisie (nolign-1)
#                LTRSTYP = Type mvt de stock (menu local 704)
#                LTRSCOD = Code mouvement    (table diverse 14)
#                LSUP    = Inutilisé (paramètre supplémentaire au cas où)
#            S : mkstat
#
# Prérequis    : Ces tables doivent être ouvertes   ITMMASTER
#                                                   ITMFACILIT
#                                                   TABSTORUL
#########################################################################
Subprog INIZONADC(LABR,LITM,LFCY,LLIN,LTRSTYP,LTRSCOD,LSUP)
Value    Char     LABR
Value    Char     LITM
Value    Char     LFCY
Value    Integer  LLIN
Value    Integer  LTRSTYP
Value    Char     LTRSCOD
Value    Char     LSUP
Local    Integer  I
Local    Integer  LAFF

Local Char WMSKCOU(10)

LAFF=1
Call LECFICSOR(LITM,LFCY,LTRSTYP,LTRSCOD,LAFF) From STKECR
If mkstat End Endif

WMSKCOU=func STKLIB.MSKDEF
If WMSKCOU<>"["+LABR+"]"
   Default Mask "["+LABR+"]"
Endif

If evalue("dim([M:"+LABR+"]STA)")>0     Actzo [M]STA(LLIN)     Endif
If evalue("dim([M:"+LABR+"]MVTDES)")>0  Actzo [M]MVTDES(LLIN)  Endif
If evalue("dim([M:"+LABR+"]LOC)")>0     Actzo [M]LOC(LLIN)     Endif
If evalue("dim([M:"+LABR+"]LOT)")>0     Actzo [M]LOT(LLIN)     Endif
If evalue("dim([M:"+LABR+"]SLO)")>0     Actzo [M]SLO(LLIN)     Endif
If evalue("dim([M:"+LABR+"]SERNUM)")>0  Actzo [M]SERNUM(LLIN)  Endif
If evalue("dim([M:"+LABR+"]SERNUMF)")>0 Actzo [M]SERNUMF(LLIN) Endif

# Article non géré en stock
If [F:ITM]STOMGTCOD<2
   # Effacement et grisage des champs stock
   If evalue("dim([M:"+LABR+"]STA)")>0     Raz [M]STA(LLIN)    : Grizo [M]STA(LLIN)     Endif
   If evalue("dim([M:"+LABR+"]MVTDES)")>0  Raz [M]MVTDES(LLIN) : Grizo [M]MVTDES(LLIN)  Endif
   If evalue("dim([M:"+LABR+"]LOC)")>0     Raz [M]LOC(LLIN)    : Grizo [M]LOC(LLIN)     Endif
   If evalue("dim([M:"+LABR+"]LOT)")>0     Raz [M]LOT(LLIN)    : Grizo [M]LOT(LLIN)     Endif
   If evalue("dim([M:"+LABR+"]SLO)")>0     Raz [M]SLO(LLIN)    : Grizo [M]SLO(LLIN)     Endif
   If evalue("dim([M:"+LABR+"]SERNUM)")>0  Raz [M]SERNUM(LLIN) : Grizo [M]SERNUM(LLIN)  Endif
   If evalue("dim([M:"+LABR+"]SERNUMF)")>0 Raz [M]SERNUMF(LLIN): Grizo [M]SERNUMF(LLIN) Endif
   Goto INIZONADC_SUI
Endif

If evalue("dim([M:"+LABR+"]LOT)")>0
   If [F:ITM]LOTMGTCOD<2
      Grizo [M]LOT(LLIN)
   Endif
   Affzo [M]LOT(LLIN)
Endif
If evalue("dim([M:"+LABR+"]SLO)")>0
   If [F:ITM]LOTMGTCOD<2 | [F:ITM]LOTMGTCOD<>4
      Grizo [M]SLO(LLIN)
   Endif
   Affzo [M]SLO(LLIN)
Endif

If evalue("dim([M:"+LABR+"]SERNUM)")>0
   If [F:ITM]SERMGTCOD<3
      Grizo [M]SERNUM(LLIN)
   Endif
   Affzo [M]SERNUM(LLIN)
Endif

If [F:ITM]SERMGTCOD<3 & evalue("dim([M:"+LABR+"]SERNUMF)")>0
   Grizo [M]SERNUMF(LLIN)
Endif
If evalue("dim([M:"+LABR+"]SERNUMF)")>0 Affzo [M]SERNUMF(LLIN) Endif

If evalue("dim([M:"+LABR+"]LOC)")>0
   If [F:ITF]LOCMGTCOD<2
      Grizo [M]LOC(LLIN)
   Endif
   Affzo [M]LOC(LLIN)
Endif

If evalue("dim([M:"+LABR+"]STA)")>0
   Affzo [M]STA(LLIN)
Endif

If evalue("dim([M:"+LABR+"]MVTDES)")>0
   Affzo [M]MVTDES(LLIN)
Endif

$INIZONADC_SUI
If WMSKCOU<>"["+LABR+"]"
   Default Mask WMSKCOU
Endif

End


#########################################################################
# RECSTOSOR  Cherche pour une ligne de document (sortie)
#            si dans le détail de la ligne :
#            - Le statut qualité est unique ou multiple
#            - Le lot est unique ou multiple
#            - Le sous-lot est unique ou multiple
#            - le no contenant est unique ou multiple
#            - L'emplacement est unique ou multiple
#            - L'identifiant 1 est unique ou multiple (PALNUM)
#            - L'identifiant 2 est unique ou multiple (CTRNUM)
#            - Les numéros de séries sont continus ou discontinus
#            - Le lot fournisseur est unique ou multiple
#            Cette fonction fait apparaître un $ s'il y a décomposition
#            du champ
#########################################################################
# Paramètres E : LTRT  = Origine de la recherche :
#                        1 = STOJOU  document sans validation ou
#                                    document avec validation (validé)
#                        2 = STOALL  document avec validation (non validé)
#                        3 = STOSORW document en cours de saisie
#                LABR  = Abréviation du masque
#                LNOL  = No ligne écran (nolign-1)
#                LFCY  = Site
#                LITM  = Article
#                LTYP  = Type document (Menu local 701)
#                LNUM  = Numéro document
#                LLIN  = Numéro ligne
#                LSUP  = Inutilisé (paramètre supplémentaire au cas où)
#            S : LRET  = Code retour : 0=OK / 1=Erreur
#
#########################################################################
Subprog RECSTOSOR (LTRT, LABR, LNOL, LFCY, LITM, LTYP, LNUM, LLIN, LSUP, LRET)
Value    Integer  LTRT
Value    Char     LABR
Value    Integer  LNOL
Value    Char     LFCY
Value    Char     LITM
Value    Integer  LTYP
Value    Char     LNUM
Value    Integer  LLIN
Value    Char     LSUP
Variable Integer  LRET

Local Char     LSERNUMF(GLONSER)
Local Integer  I,J,K,L,OK
Local Char     CAR(1)            : CAR = "$"
Local Char     WLOT(GLONLOT)
Local Char     WSLO(GLONSLO)
Local Char     WWRH(GLONWRH)
Local Char     WLOC(GLONLOC)
Local Char     WTLO(GLONTLO)
Local Char     WSTA(GLONSTA)
Local Char     WSERNUM(GLONSER)
Local Char     WSERNUMF(GLONSER)
Local Char     WMVTDES(GLONDES)
Local Char     WPCU(GLONUOM)
Local Char     WPAL(GLONPAL)
Local Char     WCTR(GLONCTR)
Local Char     WBPSLOT(GLONLOT)
Local Char     WLPN(GLONLPN)     : #--- Issue X3-53322
Local Decimal  WCOE
Local Decimal  WQTYPCU

Local Shortint WABRLOT
Local Shortint WABRSLO
Local Shortint WABRTLO
Local Shortint WABRWRH
Local Shortint WABRLOC
Local Shortint WABRSTA
Local Shortint WABRSER
Local Shortint WABRPCU
Local Shortint WABRCOE
Local Shortint WABRQTYPCU
Local Shortint WABRPAL
Local Shortint WABRCTR
Local Shortint WABRBPSLOT
Local Shortint WABRLPN           : #--- Issue X3-53322

Local Shortint WSORSER
Local Shortint WRUP
Local Decimal  WQTY

Local Integer WRHGES             : # Gestion de dépôt sur le site

If !clalev([FCY])  Local File FACILITY   [FCY]  Endif
If !clalev([ITF])  Local File ITMFACILIT [ITF]  Endif
If !clalev([STC])  Local File STOLOC     [STC]  Endif

Raz LRET
Case LTRT
 When 1       : If !clalev([STJ])  Local File STOJOU  [STJ]  Endif
 When 2       : If !clalev([STA])  Local File STOALL  [STA]  Endif
                If !clalev([STO])  Local File STOCK   [STO]  Endif
 When 3       : If !clalev([STO])  Local File STOCK   [STO]  Endif
 When Default : LRET=1 :  End
Endcase

If [F:FCY]FCY<>LFCY
   Read [FCY]FCY0=LFCY
   If fstat Raz [F:FCY] Endif
Endif
WRHGES=[F:FCY]WRHGES

# Lecture article et article-site
If clalev([F:ITM]) =0  Local File ITMMASTER [ITM]  Endif
If [F:ITM]ITMREF<>LITM
   Read [ITM]ITM0=LITM
   If fstat
      Call RSTA("ITM",LITM) From GLOCK
      LRET=1 : End
   Endif
Endif

# Article non géré en stock
If [F:ITM]STOMGTCOD<=1 End Endif

Read [ITF]ITF0=[F:ITM]ITMREF;LFCY
If fstat
   Call RSTA("ITF",[F:ITM]ITMREF-LFCY) From GLOCK
   LRET=1 : End
Endif

# Article non géré en stock
If [F:ITF]STOMGTCOD<=1 End Endif

# Positionnement des flags présence zone dans l'écran
Raz WABRLOT, WABRSLO, WABRLOC, WABRTLO, WABRSTA, WABRSER, WABRWRH
Raz WABRPCU, WABRCOE, WABRQTYPCU, WABRBPSLOT, WABRLPN               : #--- Issue X3-53322 ajout WABRLPN

If LABR="SCS1" | LABR="QCR1" | LABR = "LPNA" | LABR = "LPNO"   # Issue 67963 - 2018-01-10 by MAE : ajout de LPNA et LPNO
   #If evalue("dim([M:"+LABR+"]WRHDES(LNOL))")>0
   #   WABRWRH=1
   #Endif
   If evalue("dim([M:"+LABR+"]LOCDES(LNOL))")>0
      WABRLOC=1
   Endif
   If evalue("dim([M:"+LABR+"]LOCTYPDES(LNOL))")>0
      WABRTLO=1
   Endif
   If evalue("dim([M:"+LABR+"]STADES(LNOL))")>0
      WABRSTA=1
   Endif
   If evalue("dim([M:"+LABR+"]SERNUM(LNOL))") >0 &
&     evalue("dim([M:"+LABR+"]SERNUMF(LNOL))")>0
      WABRSER=1
   Endif
   If evalue("dim([M:"+LABR+"]PCUDES(LNOL))")>0
      WABRPCU=1
   Endif
   If evalue("dim([M:"+LABR+"]COEDES(LNOL))")>0
      WABRCOE=1
   Endif
   If evalue("dim([M:"+LABR+"]QTYPCUDES(LNOL))")>0
      WABRQTYPCU=1
   Endif
   If evalue("dim([M:"+LABR+"]PALNUMDES(LNOL))")>0
      WABRPAL=1
   Endif
   If evalue("dim([M:"+LABR+"]CTRNUMDES(LNOL))")>0
      WABRCTR=1
   Endif
   #--- Issue X3-53322
   If evalue("dim([M:"+LABR+"]LPNNUMDES(LNOL))")>0
      WABRLPN=1
   Endif
   #---
Else
   If evalue("dim([M:"+LABR+"]LOT(LNOL))")>0
      WABRLOT=1
   Endif
   If evalue("dim([M:"+LABR+"]SLO(LNOL))")>0
      WABRSLO=1
   Endif
   #If evalue("dim([M:"+LABR+"]WRH(LNOL))")>0
   #   WABRWRH=1
   #Endif
   If evalue("dim([M:"+LABR+"]LOC(LNOL))")>0
      WABRLOC=1
   Endif
   If evalue("dim([M:"+LABR+"]STA(LNOL))")>0
      WABRSTA=1
   Endif
   If evalue("dim([M:"+LABR+"]SERNUM(LNOL))") >0 &
&     evalue("dim([M:"+LABR+"]SERNUMF(LNOL))")>0
      WABRSER=1
   Endif
   If evalue("dim([M:"+LABR+"]PALNUM(LNOL))")>0
      WABRPAL=1
   Endif
   If evalue("dim([M:"+LABR+"]CTRNUM(LNOL))")>0
      WABRCTR=1
   Endif
   If evalue("dim([M:"+LABR+"]BPSLOT(LNOL))")>0
      WABRBPSLOT=1
   Endif
   #--- Issue X3-53322
   If evalue("dim([M:"+LABR+"]LPNNUM(LNOL))")>0
      WABRLPN=1
   Endif
   #---
Endif

Raz WLOT, WSLO, WLOC, WTLO, WSTA, WSERNUM, WSERNUMF, WPAL, WCTR, WBPSLOT, WWRH, WLPN  : #--- Issue X3-53322 ajout WLPN
Raz WPCU, WCOE, WQTYPCU
Raz I, WQTY, WRUP
WSORSER=1

# Origine de la recherche = STOJOU
If LTRT=1
   # No séries en Sortie ou E/S et no série définis dans l'écran
   If [F:ITM]SERMGTCOD>=2 & WABRSER=1
      If LABR="SCS1" | LABR="QCR1" | LABR = "LPNA" | LABR = "LPNO"    # Issue 67963 - 2018-01-10 by MAE : ajout de LPNA et LPNO
         #--- Issue 110327
         If [F:ITM]SERMGTCOD=4
            Filter [STJ] Where STOFCY=LFCY & VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN
&                            & REGFLG<>2 & QTYSTU>0 Order By SERDEB
         Else
         #---
            Filter [STJ] Where STOFCY=LFCY & VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN
&                            & REGFLG<>2 & QTYSTU>0 Order By SERNUM
         #--- Issue 110327
         Endif
         #---
      Else
         #--- Issue 110327
         If [F:ITM]SERMGTCOD=4
            Filter [STJ] Where STOFCY=LFCY & VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN
&                            & REGFLG<>2 & QTYSTU<0 Order By SERDEB
         Else
         #---
            Filter [STJ] Where STOFCY=LFCY & VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN
&                            & REGFLG<>2 & QTYSTU<0 Order By SERNUM
         #--- Issue 110327
         Endif
         #---
      Endif
   Else
      If LABR="SCS1" | LABR="QCR1" | LABR = "LPNA" | LABR = "LPNO"    # Issue 67963 - 2018-01-10 by MAE : ajout de LPNA et LPNO
         Filter [STJ] Where STOFCY=LFCY & VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN
&                         & REGFLG<>2 & QTYSTU>0
      Else
         Filter [STJ] Where STOFCY=LFCY & VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN
&                         & REGFLG<>2 & QTYSTU<0
      Endif
   Endif

   For [STJ] Hint Key STJ1
      If LABR="SCS1" | LABR="QCR1" | LABR = "LPNA" | LABR = "LPNO"   # Issue 67963 - 2018-01-10 by MAE : ajout de LPNA et LPNO
        WQTYPCU+=[F:STJ]QTYPCU
      Endif
      If I=0
         If WABRLOT=1 WLOT = [F:STJ]LOT       Endif
         If WABRSLO=1 WSLO = [F:STJ]SLO       Endif
         #If WABRWRH=1 WWRH = [F:STJ]WRH       Endif
         If WABRLOC=1 WLOC = [F:STJ]LOC       Endif
         If WABRTLO=1 & WLOC<>""
            Read [STC]STC0=LFCY;WLOC
            If !fstat WTLO=[F:STC]LOCTYP Endif
         Endif
         If WABRSTA=1 WSTA = [F:STJ]STA       Endif
         If WABRPCU=1 WPCU = [F:STJ]PCU       Endif
         If WABRCOE=1 WCOE = [F:STJ]PCUSTUCOE Endif

         #--- Issue 110327
         #If WABRSER=1 & [F:STJ]SERNUM<>""
         If WABRSER=1
            If [F:ITM]SERMGTCOD=4
               WSERNUM  = [F:STJ]SERDEB
               WSERNUMF = [F:STJ]SERFIN
            Elsif [F:STJ]SERNUM<>""
         #---
               WSERNUM  = [F:STJ]SERNUM
               If abs([F:STJ]QTYSTU)=1
                  WSERNUMF = WSERNUM
               Else
                  Call PLUS_NB(WSERNUM,abs([F:STJ]QTYSTU),WSERNUMF,LRET) From STKLIB
               Endif
            #--- Issue 110327
            Endif
            #---
         Endif
         WMVTDES  = [F:STJ]MVTDES
         If WABRPAL=1 WPAL = [F:STJ]PALNUM     Endif
         If WABRCTR=1 WCTR = [F:STJ]CTRNUM     Endif
         If WABRLPN=1 WLPN = [F:STJ]LPNNUM     Endif              : #--- Issue X3-53322
         If WABRBPSLOT=1 WBPSLOT = [F:STJ]BPSLOT     Endif          # hcb 120580
      Else
         If WABRLOT=1 & WLOT<>CAR
            If WLOT<>[F:STJ]LOT WLOT=CAR Endif
         Endif
         If WABRSLO=1 & WSLO<>CAR
            If WSLO<>[F:STJ]SLO WSLO=CAR Endif
         Endif
         #If WABRWRH=1 & WWRH<>CAR
         #   If WWRH<>[F:STJ]WRH WWRH=CAR Endif
         #Endif
         If WABRLOC=1 & WLOC<>CAR
            If WLOC<>[F:STJ]LOC WLOC=CAR Endif
         Endif
         If WABRTLO=1 & WTLO<>CAR
            If WLOC=CAR WTLO=CAR Endif
         Endif
         If WABRSTA=1 & WSTA<>CAR
            If WSTA<>[F:STJ]STA WSTA=CAR Endif
         Endif
         If WABRPCU=1 & WPCU<>CAR
            If WPCU<>[F:STJ]PCU WPCU=CAR Endif
         Endif
         If WABRCOE=1 & WCOE<>0
            If WCOE<>[F:STJ]PCUSTUCOE WCOE=0 Endif
         Endif

         #--- Issue 110327
         #If WABRSER=1 & [F:STJ]SERNUM<>""
         If WABRSER=1
            If [F:ITM]SERMGTCOD=4
               WSERNUMF = [F:STJ]SERFIN
            Elsif [F:STJ]SERNUM<>""
         #---
               If abs([F:STJ]QTYSTU)=1
                  WSERNUMF=[F:STJ]SERNUM
               Else
                  Call PLUS_NB([F:STJ]SERNUM,abs([F:STJ]QTYSTU),WSERNUMF,LRET) From STKLIB
               Endif
            #--- Issue 110327
            Endif
            #---
         Endif
         If WABRPAL=1 & WPAL<>CAR
            If WPAL<>[F:STJ]PALNUM WPAL=CAR Endif
         Endif
         If WABRCTR=1 & WCTR<>CAR
            If WCTR<>[F:STJ]CTRNUM WCTR=CAR Endif
         Endif
         #--- Issue X3-53322
         If WABRLPN=1 & WLPN<>CAR
            If WLPN<>[F:STJ]LPNNUM WLPN=CAR Endif
         Endif
         #---
         If WABRBPSLOT=1 & WBPSLOT<>CAR
            If WBPSLOT<>[F:STJ]BPSLOT WBPSLOT=CAR Endif
         Endif

      Endif
      I    += 1
      WQTY += abs([F:STJ]QTYSTU)
      If [F:STJ]UPDCOD<>2 WRUP=1 Endif
   Next
   Filter [STJ]
# Origine de la recherche = STOALL
Elsif LTRT=2
   For [STA]STA1 Where VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN & find(ALLTYP,2,4)
      If [F:STA]ALLTYP=2
         Read [STO]STO0=[F:STA]STOFCY;[F:STA]STOCOU
         If !fstat
            If I=0
               If WABRLOT=1    WLOT    = [F:STO]LOT    Endif
               If WABRSLO=1    WSLO    = [F:STO]SLO    Endif
               #If WABRWRH=1    WWRH    = [F:STO]WRH    Endif
               If WABRLOC=1    WLOC    = [F:STO]LOC    Endif
               If WABRSTA=1    WSTA    = [F:STO]STA    Endif
               If WABRPAL=1    WPAL    = [F:STO]PALNUM Endif
               If WABRCTR=1    WCTR    = [F:STO]CTRNUM Endif
               If WABRLPN=1    WLPN    = [F:STO]LPNNUM Endif     : #--- Issue X3-53322
               If WABRBPSLOT=1 WBPSLOT = [F:STO]BPSLOT Endif
               WMVTDES = [F:STA]MVTDES
            Else
               If WABRLOT=1 & WLOT<>CAR
                  If WLOT<>[F:STO]LOT WLOT=CAR Endif
               Endif
               If WABRSLO=1 & WSLO<>CAR
                  If WSLO<>[F:STO]SLO WSLO=CAR Endif
               Endif
               #If WABRWRH=1 & WWRH<>CAR
               #   If WWRH<>[F:STO]LOC WWRH=CAR Endif
               #Endif
               If WABRLOC=1 & WLOC<>CAR
                  If WLOC<>[F:STO]LOC WLOC=CAR Endif
               Endif
               If WABRSTA=1 & WSTA<>CAR
                  If WSTA<>[F:STO]STA WSTA=CAR Endif
               Endif
               If WABRPAL=1 & WPAL<>CAR
                  If WPAL<>[F:STO]PALNUM WPAL=CAR Endif
               Endif
               If WABRCTR=1 & WCTR<>CAR
                  If WCTR<>[F:STO]CTRNUM WCTR=CAR Endif
               Endif
               #--- Issue X3-53322
               If WABRLPN=1 & WLPN<>CAR
                  If WLPN<>[F:STO]LPNNUM WLPN=CAR Endif
               Endif
               #---
               If WABRBPSLOT=1 & WBPSLOT<>CAR
                  If WBPSLOT<>[F:STO]BPSLOT WBPSLOT=CAR Endif
               Endif
            Endif
            If WABRSER=1
               If [F:ITM]SERMGTCOD=3
                  If WSERNUM=""
                     WSERNUM =[F:STO]SERNUM
                     WSERNUMF=[F:STO]SERNUM
                  Elsif [F:STO]SERNUM<WSERNUM
                     WSERNUM=[F:STO]SERNUM
                  Elsif [F:STO]SERNUM>WSERNUMF
                     WSERNUMF=[F:STO]SERNUM
                  Endif
               Elsif [F:ITM]SERMGTCOD=2 & WSORSER=1
                  If [F:STA]SERNUM=""
                     WSORSER =0
                     WSERNUM =""
                     WSERNUMF=""
                  Elsif WSERNUM=""
                     WSERNUM=[F:STA]SERNUM
                     If [F:STA]QTYSTU=1
                        WSERNUMF = WSERNUM
                     Else
                        Call PLUS_NB(WSERNUM,[F:STA]QTYSTU,LSERNUMF,LRET) From STKLIB
                        If LRET<>0
                           WSORSER =0
                           WSERNUM =""
                           WSERNUMF=""
                        Else
                           WSERNUMF=LSERNUMF
                        Endif
                     Endif
                  Elsif [F:STA]SERNUM<WSERNUM
                     WSERNUM=[F:STA]SERNUM
                  Elsif [F:STA]SERNUM>WSERNUM
                     Call PLUS_NB([F:STA]SERNUM,[F:STA]QTYSTU,LSERNUMF,LRET) From STKLIB
                     If LRET<>0
                        WSORSER =0
                        WSERNUM =""
                        WSERNUMF=""
                     Else
                        WSERNUMF=LSERNUMF
                     Endif
                  Endif
               #--- Issue 110327
               Elsif [F:ITM]SERMGTCOD=4 & [F:STA]SERNUM<>""
                  If WSERNUM=""
                     WSERNUM = [F:STA]SERNUM
                     If abs([F:STA]QTYSTU)=1
                        WSERNUMF = WSERNUM
                     Else
                        Call PLUS_NB(WSERNUM,abs([F:STA]QTYSTU),WSERNUMF,LRET) From STKLIB
                     Endif
                  Elsif [F:STA]SERNUM<WSERNUM
                     WSERNUM = [F:STA]SERNUM
                  Elsif [F:STA]SERNUM>WSERNUMF
                     Call PLUS_NB([F:STA]SERNUM,abs([F:STA]QTYSTU),WSERNUMF,LRET) From STKLIB
                  Endif
               #---
               Endif
            Endif
         Endif
         I    += 1
         WQTY += [F:STA]QTYSTU
      Else
         WRUP=1
      Endif
   Next
# Origine de la recherche STOSORW
Else
   Raz J, K, L, OK
   While OK<>1
      K=evalue("find([M:"+LABR+"]WSTOSEQ(LNOL),[M:SOW]WSTOSEQ(L..[M:SOW]NBLIG-1))")
      If K>0
         J=L+K-1
         L=J+1
         Read [STO]STO0=LFCY;[M:SOW]WSTOCOU(J)
         If !fstat
            If I=0
               If WABRLOT=1    WLOT    = [F:STO]LOT    Endif
               If WABRSLO=1    WSLO    = [F:STO]SLO    Endif
               #If WABRWRH=1    WWRH    = [F:STO]WRH    Endif
               If WABRLOC=1    WLOC    = [F:STO]LOC    Endif
               If WABRSTA=1    WSTA    = [F:STO]STA    Endif
               If WABRPAL=1    WPAL    = [F:STO]PALNUM Endif
               If WABRCTR=1    WCTR    = [F:STO]CTRNUM Endif
               If WABRLPN=1    WLPN    = [F:STO]LPNNUM Endif     : #--- Issue X3-53322
               If WABRBPSLOT=1 WBPSLOT = [F:STO]BPSLOT Endif
               WMVTDES = evalue("[M:"+LABR+"]MVTDES(LNOL)")
            Else
               If WABRLOT=1 & WLOT<>CAR
                  If WLOT<>[F:STO]LOT WLOT=CAR Endif
               Endif
               If WABRSLO=1 & WSLO<>CAR
                  If WSLO<>[F:STO]SLO WSLO=CAR Endif
               Endif
               #If WABRWRH=1 & WWRH<>CAR
               #   If WWRH<>[F:STO]LOC WWRH=CAR Endif
               #Endif
               If WABRLOC=1 & WLOC<>CAR
                  If WLOC<>[F:STO]LOC WLOC=CAR Endif
               Endif
               If WABRSTA=1 & WSTA<>CAR
                  If WSTA<>[F:STO]STA WSTA=CAR Endif
               Endif
               If WABRPAL=1 & WPAL<>CAR
                  If WPAL<>[F:STO]PALNUM WPAL=CAR Endif
               Endif
               If WABRCTR=1 & WCTR<>CAR
                  If WCTR<>[F:STO]CTRNUM WCTR=CAR Endif
               Endif
               #--- Issue X3-53322
               If WABRLPN=1 & WLPN<>CAR
                  If WLPN<>[F:STO]LPNNUM WLPN=CAR Endif
               Endif
               #---
               If WABRBPSLOT=1 & WBPSLOT<>CAR
                  If WBPSLOT<>[F:STO]BPSLOT WBPSLOT=CAR Endif
               Endif
            Endif
            If WABRSER=1
               If [F:ITM]SERMGTCOD=3
                  If WSERNUM=""
                     WSERNUM =[F:STO]SERNUM
                     WSERNUMF=[F:STO]SERNUM
                  Elsif [F:STO]SERNUM<WSERNUM
                     WSERNUM=[F:STO]SERNUM
                  Elsif [F:STO]SERNUM>WSERNUMF
                     WSERNUMF=[F:STO]SERNUM
                  Endif
               #--- Issue 110327
               #Elsif [F:ITM]SERMGTCOD=2 & WSORSER=1
               Elsif ([F:ITM]SERMGTCOD=2 & WSORSER=1) | [F:ITM]SERMGTCOD=4
               #---
                  If [M:SOW]WSERNUM(J)=""
                     WSORSER =0
                     WSERNUM =""
                     WSERNUMF=""
                  Elsif WSERNUM=""
                     WSERNUM=[M:SOW]WSERNUM(J)
                     If [M:SOW]WQTYSTU(J)=1
                        WSERNUMF = WSERNUM
                     Else
                        Call PLUS_NB(WSERNUM,[M:SOW]WQTYSTU(J),LSERNUMF,LRET) From STKLIB
                        If LRET<>0
                           WSORSER =0
                           WSERNUM =""
                           WSERNUMF=""
                        Else
                           WSERNUMF=LSERNUMF
                        Endif
                     Endif
                  Elsif [M:SOW]WSERNUM(J)<WSERNUM
                     WSERNUM=[M:SOW]WSERNUM(J)
                  Elsif [M:SOW]WSERNUM(J)>WSERNUM
                     Call PLUS_NB([M:SOW]WSERNUM(J),[M:SOW]WQTYSTU(J),LSERNUMF,LRET) From STKLIB
                     If LRET<>0
                        WSORSER =0
                        WSERNUM =""
                        WSERNUMF=""
                     Else
                        WSERNUMF=LSERNUMF
                     Endif
                  Endif
               Endif
            Endif
         Endif
         I    += 1
         WQTY += [M:SOW]WQTYSTU(J)
         If L>[M:SOW]NBLIG-1    OK=1   Endif
         If [M:SOW]WSTOCOU(J)=0 WRUP=1 Endif
      Else
         OK=1
      Endif
   Wend
Endif

If [F:ITM]LOTMGTCOD =1 Raz WLOT,WBPSLOT     Endif
If [F:ITM]LOTMGTCOD<>4 Raz WSLO             Endif
If [F:ITF]LPNMGTCOD<>2 Raz WLPN             Endif   : #--- Issue X3-53322
If [F:ITF]LOCMGTCOD<>2 Raz WLOC,WTLO        Endif
If [F:ITM]SERMGTCOD <2 Raz WSERNUM,WSERNUMF Endif
If WRHGES<>2           Raz WWRH             Endif

#--- 61877
#If WABRSER=1 & WSERNUM<>"" & WSERNUMF<>""
If WABRSER=1 & WSERNUM<>"" & WSERNUMF<>"" & WQTY>1
#---
   Call PLUS_NB(WSERNUM,WQTY,LSERNUMF,LRET) From STKLIB
#   If LRET<>0 End Endif                                # hcb 105866
   If LSERNUMF<>WSERNUMF
      WSERNUM = CAR
      WSERNUMF= CAR
   Endif
Endif

If LABR="SCS1" | LABR="QCR1" | LABR = "LPNA" | LABR = "LPNO"    # Issue 67963 - 2018-01-10 by MAE : ajout de LPNA et LPNO
   If WABRWRH=1 Assign "[M:"+LABR+"]WRHDES(LNOL)"    With WWRH Endif
   If WABRLOC=1 Assign "[M:"+LABR+"]LOCDES(LNOL)"    With WLOC Endif
   If WABRTLO=1 Assign "[M:"+LABR+"]LOCTYPDES(LNOL)" With WTLO Endif
   If WABRSTA=1 Assign "[M:"+LABR+"]STADES(LNOL)"    With WSTA Endif
   If WABRPCU=1 Assign "[M:"+LABR+"]PCUDES(LNOL)"    With WPCU Endif
   If WABRPAL=1 Assign "[M:"+LABR+"]PALNUMDES(LNOL)" With WPAL Endif
   If WABRCTR=1 Assign "[M:"+LABR+"]CTRNUMDES(LNOL)" With WCTR Endif
   If WABRLPN=1 Assign "[M:"+LABR+"]LPNNUMDES(LNOL)" With WLPN Endif   : #--- Issue X3-53322
   If WABRSER=1
      Assign "[M:"+LABR+"]SERNUM(LNOL)"  With WSERNUM
      Assign "[M:"+LABR+"]SERNUMF(LNOL)" With WSERNUMF
   Endif
   If WABRCOE=1
      If WPCU=CAR WCOE=0 Endif
      Assign "[M:"+LABR+"]COEDES(LNOL)" With WCOE
   Endif
   If WABRQTYPCU=1
      If WPCU=CAR WQTYPCU=0 Endif
      Assign "[M:"+LABR+"]QTYPCUDES(LNOL)" With WQTYPCU
   Endif
Else
   If WABRLOT=1 Assign "[M:"+LABR+"]LOT(LNOL)" With WLOT Endif
   If WABRSLO=1 Assign "[M:"+LABR+"]SLO(LNOL)" With WSLO Endif
   If WABRWRH=1 Assign "[M:"+LABR+"]WRH(LNOL)" With WWRH Endif
   If WABRLOC=1 Assign "[M:"+LABR+"]LOC(LNOL)" With WLOC Endif
   If WABRSTA=1 Assign "[M:"+LABR+"]STA(LNOL)" With WSTA Endif
   If WABRSER=1
      Assign "[M:"+LABR+"]SERNUM(LNOL)"  With WSERNUM
      Assign "[M:"+LABR+"]SERNUMF(LNOL)" With WSERNUMF
   Endif
   If WABRPAL=1 Assign "[M:"+LABR+"]PALNUM(LNOL)" With WPAL Endif
   If WABRCTR=1 Assign "[M:"+LABR+"]CTRNUM(LNOL)" With WCTR Endif
   If WABRLPN=1 Assign "[M:"+LABR+"]LPNNUM(LNOL)" With WLPN Endif             : #--- Issue X3-53322
   If WABRBPSLOT=1 Assign "[M:"+LABR+"]BPSLOT(LNOL)"    With WBPSLOT Endif      # hcb 84636
Endif

Assign "[M:"+LABR+"]MVTDES(LNOL)"  With WMVTDES

# Il y a des ruptures
If evalue("dim([M:"+LABR+"]FLGRUP(LNOL))")>0
   Assign "[M:"+LABR+"]FLGRUP(LNOL)"  With WRUP
Endif

# Si l'on a déterminé automatiquement le stock,
# affichage des zones de la ligne document
If LTRT=3
   Default Mask "["+LABR+"]"
   Call ETAZONSORL(LABR,LNOL) From STKECR2
Endif

End

#########################################################################
# CTLSTOSOR  Contrôle de cohérence entre les quantités des lignes doc   #
#            et les quantités à sortir stockées dans STOSORW afin de    #
#            déterminer si l'on peut créer/enregistrer le document      #
#########################################################################
# Paramètres E : LABR    = Abréviation écran
#                LZON    = Nom zone quantité en UA
#                LNBLIG  = Nb ligne écran origine
#
# Paramètres S : LRET = Code retour (0=OK / 1=Erreur)
#
#########################################################################
Subprog CTLSTOSOR (LABR, LZON, LNBLIG, LRET)
Value    Char    LABR
Value    Char    LZON
Value    Integer LNBLIG
Variable Integer LRET

Local    Integer I, J, K, L
Local    Decimal WQTS, WQTY
Local    Char    WITM(GLONITM)
Local    Integer WSERNUM

# Pour chaque ligne (nouvelle ou modifiée), contrôle que la quantité US
# est bien égale à la somme des quantités à sortir des lignes de stock
Raz LRET, GMESSAGE, L

#--- Issue 110327
#WSERNUM=2

If LNBLIG=0
    Call ERREUR(mess(17,106,1)) From GESECRAN
    LRET=1
    End
Endif

For I=0 To LNBLIG-1
   # Si cumul des matières en suivi de prod, pas de contrôle
   If LABR="MTK3" & evalue("[M:"+LABR+"]CUMMATSUI(I)")=1
      Goto CTLSTOSOR_SUI
   Endif
   If evalue("[M:"+LABR+"]STOMGTCOD(I)")>1 & evalue("[M:"+LABR+"]"+LZON+"(I)")<>0
      If evalue("[M:"+LABR+"]CREFLG(I)") =0 |
&       (evalue("[M:"+LABR+"]CREFLG(I)")<>0 & evalue("[M:"+LABR+"]WSTOSEQ(I)")<>0)
         WQTS=evalue("[M:"+LABR+"]"+LZON+"(I)")
         WQTY=evalue("sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*([M:SOW]WSTOSEQ(J)=[M:"+LABR+"]WSTOSEQ(I)))")

         If LABR="MTK3"
            WITM=evalue("[M:"+LABR+"]MATITMREF(I)")
         Else
            WITM=evalue("[M:"+LABR+"]ITMREF(I)")
         Endif

         If WQTY<>WQTS
            Call ERREUR(mess(61,100,1)-num$(I+1)-"\"-mess(80,197,1)-WITM-":"-mess(396,199,1)-"\"-
&                       mess(506,197,1)-num$(WQTS)-mess(507,197,1)-num$(WQTY)) From GESECRAN
            LRET=1 : Break
         Endif

         #--- Issue 110327
         WSERNUM = 1

         # Si no série en sortie sans compteur, contrôle qu'ils ont été saisis
         If WITM<>[F:ITM]ITMREF
            Read [ITM]ITM0=WITM
         Endif
         If [F:ITM]SERMGTCOD=2 & [F:ITM]SERCOU=""
            #--- Issue 110327
            WSERNUM=2
            #MAE, le 27/09/2010, bg 67175, si inter-site et intra-société, pas de n° série a saisir
            If LABR = "SDH1" & [M:SDH1]BETFCY=2 & [M:SDH1]BETCPY<>2
                    WSERNUM = 1
            Elsif LABR="SIH4" & [M:SIH1]BETFCY=2 & [M:SIH1]BETCPY<>2
                    WSERNUM = 1
            #--- Bug 70723
            # Si retour fournisseur ou bon préparation, pas de no série à saisir
            Elsif find(LABR,"PNH1","PRH1","PREP")
                    WSERNUM = 1
            #---
            Endif
         #--- Issue 110327
         Elsif [F:ITM]SERMGTCOD=4
            WSERNUM=2
            If LABR="PREP" : WSERNUM=1 : Endif
         Endif
         #---

         If WSERNUM=2
            For K=0 To [M:SOW]NBLIG-1
               If [M:SOW]WSTOSEQ(K)=evalue("[M:"+LABR+"]WSTOSEQ(I)") & [M:SOW]WSTOCOU(K)<>0 & [M:SOW]WSERNUM(K)=""
                  L+=1
                  Case L
                   When 1   : GMESSAGE =mess(431,199,1)-":"-[F:ITM]ITMREF
                   When 2,3 : GMESSAGE+=","-[F:ITM]ITMREF
                   When 4   : GMESSAGE+=", ..."
                  Endcase
                  Break
               Endif
            Next K
         Endif
         #--- Issue 110327
         #Endif
      Endif
   Endif

    Call CTLVLTCOD(LABR, I, "SOR", LRET)
    If LRET = 1 : Break : Endif

   $CTLSTOSOR_SUI
Next I

If LRET=1 End Endif
If GMESSAGE<>""
   GMESSAGE += "\"-mess(312,184,1)
   If find(LABR,"SDH1","SIH4","PREP")
      Call MESSAGE(GMESSAGE) From GESECRAN
   Else
      Call ERREUR(GMESSAGE) From GESECRAN
      LRET=1
   Endif
   Raz GMESSAGE
Endif

End


#########################################################################
# Action SAIZONSOR (Traitement divers)                                  #
#        Appelée en avant saisie de chaque champ stock de la ligne      #
#        Permet d'interdire la saisie d'un champ si Diszo et Grizo      #
#        non utilisés                                                   #
#########################################################################
# Paramètres E : LZON = Nom du champ
#                LLIN = Indice de la ligne en cours de saisie (nolign-1)
#
#                La classe [M] par défaut est celle du tableau des lignes
#                articles
#########################################################################
Subprog SAIZONSOR(LZON,LLIN)
Value    Char     LZON
Value    Integer  LLIN
#-----
Local    Libelle  WPOS
#-----
If dim([M]WSTOSAI)>0
  Case LZON
    When "PCU",       "UOM"       : WPOS=1
    When "QTYPCU",    "QTYUOM"    : WPOS=2
    When "PCUSTUCOE", "UOMSTUCOE" : WPOS=3
    When "STA"                    : WPOS=4
    When "LOC"                    : WPOS=5
    When "LOT"                    : WPOS=6
    When "SLO"                    : WPOS=7
    When "SERNUM"                 : WPOS=8
    When "MVTDES"                 : WPOS=9
    When "PALNUM"                 : WPOS=10
    When "CTRNUM"                 : WPOS=11
  Endcase
  If WPOS
    mkstat=val(mid$([M]WSTOSAI(LLIN),WPOS,1))
  Endif
Endif
End

########################################################################
######################## - Divers - ####################################
########################################################################

#########################################################################
# STKWSTOSEQ Calcule le nouveau numéro de séquence servant de lien      #
#            entre le document et le détail                             #
#########################################################################
# Paramètres E : LABR   = Ecran origine
#                         "PSCM"=conso des composants en réception sous-traitance
#                LNOL   = Indice de la ligne (nolign-1)
#                LNBLIG = Nb ligne écran origine
#                LTYP   = Type de mouvement (0=entrée, 1=sortie ,2=changement)
#                         Permet de déterminer le masque de travail concerné:
#                         STOENTW, STOSORW ou STOCHGW
#
# Paramètres S : LLIG   = Lien avec ligne document [M:XXX]WSTOSEQ(nolign-1)
#                LRET   = Ecran faisant une insertion de ligne (0=OK, 1=Erreur)
#
# Prérequis    : Si LTYP = 0 --> le masque STOENTW (ENTW) doit être ouvert
#              : Si LTYP = 1 --> le masque STOSORW (SOW) doit être ouvert
#              : Si LTYP = 2 --> le masque STOCHGW (SGW) doit être ouvert
#
#########################################################################
Subprog STKWSTOSEQ (LABR, LNOL, LNBLIG, LTYP, LLIG, LRET)
Value    Char    LABR
Value    Integer LNOL
Value    Integer LNBLIG
Value    Integer LTYP
Variable Integer LLIG
Variable Integer LRET

Local Integer LSEQ
Local Char    LABRW


Case LTYP
 When 0      : LABRW="ENTW"
 When 1      : LABRW="SOW"
 When 2      : LABRW="SGW"
 When Default: Call ERREUR ("STKWTOSEQ, LTYP="+num$(LTYP)+" : "+mess(6,199,1)) From GESECRAN
               LRET=1
               End
Endcase

Raz LRET

If LNOL < 0
    Call ERREUR(mess(46,105,1)-"STKWSTOSEQ") From GESECRAN
    LRET=1
    End
Endif

LSEQ=0
If LNBLIG > 0
   LSEQ = evalue ("max([M:"+LABR+"]WSTOSEQ(0..LNBLIG-1))")
Endif

#--- Bug 87188
If LABR="PSCM"

   # alimenter LSEQ par recherche du no séquence max dans la table ...
    Local Char REQ(250)
    REQ = "SELECT MAX(WSTOSEQ_0) FROM PWRKSTT WHERE PRONUM_0="+num$(adxuid(1))
    For (Integer SEQ) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
        LSEQ=max(LSEQ,[F:SQLX]SEQ)
    Next

Endif
#---

If evalue("[M:"+LABRW+"]NBLIG") > 0
   LSEQ = evalue ("max(LSEQ,[M:"+LABRW+"]WSTOSEQ(0..[M:"+LABRW+"]NBLIG-1))")
Endif

If evalue("[M:"+LABR+"]WSTOSEQ(LNOL)")=0
   Assign "[M:"+LABR+"]WSTOSEQ(LNOL)" With LSEQ+1
Endif
LLIG = evalue("[M:"+LABR+"]WSTOSEQ(LNOL)")

End

#########################################################################
# STKWLOCSEQ   Calcule le nouveau numéro de séquence servant de lien
#              entre le détail et les emplacements
#########################################################################
# Paramètres E : LABR   = Ecran origine
#                LNOL   = Indice de la ligne (nolign-1)
#
# Paramètres S : LRET   = (0=OK, 1=Erreur)
#
#########################################################################
Subprog STKWLOCSEQ (LABR, LNOL, LRET)
Value    Char     LABR
Value    Integer  LNOL
Variable Integer  LRET

Local Integer LSEQ, LSEQ2
Local Char    LABRW

Case LABR
    When "ENM"       : LABRW=""
    When "SCS1","SCD","SGW","STQ1","SQD" ,"SMP" , "SMP1","LPNA", "LPNO" : LABRW="SGW"                  # hcb 50343
    When "QCR1"                                         : LABRW="QCR1"                 # hcb V6CQ
    When Default     : LABRW="ENTW"
Endcase

Raz LRET
If LNOL < 0
    Call ERREUR(mess(46,105,1)-"STKWLOCSEQ") From GESECRAN
    LRET=1
    End
Endif

#--- En modif d'entrée on peut avoir des WLOCSEQ<0 (déréservation)
#--- il faut donc en tenir compte car elles peuvent être seules (si suppression d'une ligne par exemple)
LSEQ = evalue ("max([M:"+LABR+"]WLOCSEQ)")
LSEQ2= evalue ("min([M:"+LABR+"]WLOCSEQ)")
If LABRW<>"" & evalue("[M:"+LABRW+"]NBLIG") > 0 & LABR<>LABRW
   LSEQ = evalue ("max(LSEQ,[M:"+LABRW+"]WLOCSEQ(0..[M:"+LABRW+"]NBLIG-1))")
   LSEQ2= evalue ("min(LSEQ,[M:"+LABRW+"]WLOCSEQ(0..[M:"+LABRW+"]NBLIG-1))")
Endif

LSEQ = max(abs(LSEQ2),abs(LSEQ))

If evalue("[M:"+LABR+"]WLOCSEQ(LNOL)")=0
   Assign "[M:"+LABR+"]WLOCSEQ(LNOL)" With LSEQ+1
Endif

End

#########################################################################
# STKINISEC      Alimentation des sections analytiques stock            #
#########################################################################
# Paramètres E : LSTOSEQ = Lien entre ligne document et écran de stockage
#                LANA    = code section analytique stock
#                LABR    = Ecran destination des sections analytiques
#                          (stock : [ENTW],[SOW],...)
#
#########################################################################
Subprog STKINISEC (LSTOSEQ, LANA, LABR)
Value   Integer  LSTOSEQ
Value   Char     LANA
Value   Char     LABR

Local   Integer  LIND  : # indice du tableau des sections ana de LABR (nolign)
Local   Integer  I, LIND
Local   Char     SECTION

Raz LIND

# Pas de lien entre ligne document et écran stockage
If LSTOSEQ=0 End Endif
# Pas de code section
If LANA="" End Endif

# Existe-t-il des lignes de stock pour LSTOSEQ
For I=0 To evalue("[M:"+LABR+"]NBLIG-1")
  If evalue("[M:"+LABR+"]WSTOSEQ(I)")=LSTOSEQ
    LIND=I+1 : Break
  Endif
Next I
# Si non, pas d'alimentation
If LIND=0 End Endif

# Récupération indice tableau des sections analytiques
# de l'écran de stockage pour la ligne document
LIND=sigma(I=0,evalue("[M:"+LABR+"]NBLIG2-1"),(I+1)*(evalue("[M:"+LABR+"]WSTOSEQ2(I)")=LSTOSEQ))
# Les sections analytiques existent déjà
If LIND<>0 End Endif

LIND = evalue("[M:"+LABR+"]NBLIG2")
For I=1 To GNBDIE
   If evalue("[M:"+LABR+"]CCE"+num$(I)+"(LIND)")=""
      #--- Bug 68026
      #GAXE=I
      Call INISEC(SECTION,LANA,I) From TRTX3CPT
      Assign "[M:"+LABR+"]CCE"+num$(I)+"(LIND)" With SECTION
   Endif
Next I
Assign "[M:"+LABR+"]WSTOSEQ2(LIND)" With LSTOSEQ
Assign "[M:"+LABR+"]NBLIG2" With evalue("[M:"+LABR+"]NBLIG2")+1

End

# Issue 71276 - 2015-04-02 by SR : Versions
##################################################################################
# Action INIECCSTA appelée en après modification du champ ITMREF                 #
#             grisage champs versions sur ligne document                         #
##################################################################################
# Paramètres E : LABR    = Abréviation écran
#                LITM    = Article
#                LLIN    = Indice de la ligne en cours de saisie (nolign-1)
#
# Prérequis    : Ces tables doivent être ouvertes   ITMMASTER
#                La classe [M] par défaut est celle du tableau des lignes article
##################################################################################
Subprog INIECCSTA(LITM,LABR,LLIN)
Value    Char     LITM
Value    Char     LABR
Value    Integer  LLIN

#----- Lecture table article par sécurité (appels autres que sur AM_ITMREF)
If [F:ITM]ITMREF<>LITM
   Read [ITM]ITM0=LITM
   If fstat  Raz [F:ITM] : mkstat=1 : End : Endif
Endif
Default Mask "["+LABR+"]"
If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>0 Actzo  [M]ECCVALMAJ(LLIN)
                                          Actzo  [M]ECCVALMIN(LLIN)
Endif
If [F:ITM]ECCFLG < 2 | [F:ITM]ECCSTO < 2
   If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>0 Grizo  [M]ECCVALMAJ(LLIN)
                                             Grizo  [M]ECCVALMIN(LLIN)
   Endif

#Elsif [F:ITM]ECCFLG = 2 & [F:ITM]ECCSTO < 3
#  If evalue("dim([M:"+LABR+"]ECCVALMIN)")>0 Grizo  [M]ECCVALMIN(LLIN) : Endif
Elsif [F:ITM]ECCSTO = 2
   If evalue("dim([M:"+LABR+"]ECCVALMIN)")>0 Grizo  [M]ECCVALMIN(LLIN) : Endif
   #--- Si cde vente pas d'accés à la version si qté allouée détail
   If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>0
      If (LABR="SOH4" & [M:SOH4]DALLTYP(LLIN)=2 & [M:SOH4]ALLQTY>0)
&      | (LABR="SOQ1" & [M:SOQ1]ALLTYP(LLIN)=2  & [M:SOQ1]ALLQTY>0)
         Diszo [M]ECCVALMAJ(LLIN)
      Endif
   Endif
Else
   #--- Si cde vente pas d'accés à la version si qté allouée détail
   If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>0
      If (LABR="SOH4" & [M:SOH4]DALLTYP(LLIN)=2 & [M:SOH4]ALLQTY>0)
&      | (LABR="SOQ1" & [M:SOQ1]ALLTYP(LLIN)=2  & [M:SOQ1]ALLQTY>0)
         Diszo [M]ECCVALMAJ(LLIN)
         Diszo [M]ECCVALMIN(LLIN)
      Endif
   Endif

Endif
If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>0 Affzo [M]ECCVALMAJ(LLIN)
                                          Affzo [M]ECCVALMIN(LLIN)
Endif
End

# Issue number - 2018-05-22 by ERMIL : Control backdating of transactions
#####################################################################################
# CTLVLTCOD - if a product has changed valuation methods after having stock on hand #
#             do not allow a transaction to be backdated to prior to that change    #
#####################################################################################
# Parameters E : LABR    = Screen abbreviation
#                LIDX    = Index on transaction screen
#                LTYP    = Issue (SOR) or Receipt (ENT)
# Parameters S : LRET    = If receipt, (0=OK, 1=Error), if issue, (1=OK, 0=Error)
#
##################################################################################
Subprog CTLVLTCOD(LABR,LIDX,LTYP,LRET)
Value    Char    LABR
Value    Integer LIDX
Value    Char    LTYP
Variable Integer LRET

Local Char LITM(GLONITM), LFCY(GLONFCY)
Local Char LFLDTMP(30), LDATTMP(10)
Local Date LVLTCODDAT, LIPTDAT

  # For a put away plan, date cannot be changed.  Don't stop a put away if valuation changed
  If LABR = 'SSL1' : End : Endif

  # Get the field used to populate IPTDAT
  Case LABR
    When 'MBR'    : [L]LFLDTMP = "[M:MBR]IPTDAT(LIDX)"
    When 'DBY1'   : [L]LFLDTMP = "[M:DBY0]IPTDAT"
    When 'MTK2'   : [L]LFLDTMP = "[M:MTK0]MFGTRKDAT"
    When 'PTH1'   : [L]LFLDTMP = "[M:PTH0]RCPDAT"
    When 'SIH4'   : [L]LFLDTMP = "[M:SIH0]INVDAT"
    When 'SMR1'   : [L]LFLDTMP = "[M:SMR0]IPTDAT"
    When 'SRH1'   : [L]LFLDTMP = "[M:SRH0]ENTRTNDAT"
    When 'SRL1'   : [L]LFLDTMP = "[M:SRL0]RTNDAT"
    When 'SRS1'   : [L]LFLDTMP = "[M:SRS0]RTNDAT"
    When 'SSL1'   : [L]LFLDTMP = "[M:SSL1]IPTDAT(LIDX)"
    When 'MBM'    : [L]LFLDTMP = "[M:MBM]IPTDAT(LIDX)"
    When 'BBY1'   : [L]LFLDTMP = "[M:BBY0]IPTDAT"
    When 'ITN8'   : [L]LFLDTMP = "[M:ITN8]HDTDONDAT(LIDX)"
    When 'MTK3'   : [L]LFLDTMP = "[M:MTK0]MFGTRKDAT"
    When 'PNH1'   : [L]LFLDTMP = "[M:PNH1]RTNDAT"
    When 'SDH1'   : [L]LFLDTMP = "[M:SDH1]SHIDAT"
    When 'SIH4'   : [L]LFLDTMP = "[M:SIH0]INVDAT"
    When 'SMO1'   : [L]LFLDTMP = "[M:SMO0]IPTDAT"
    When 'SRE9'   : [L]LFLDTMP = "[M:SRE9]HDTDONDAT(LIDX)"
    When Default  : [L]LFLDTMP = "[M:"+LABR+"]IPTDAT"
  Endcase
  If [L]LFLDTMP<>"" and evalue("dim("+LFLDTMP+")")>0
    LIPTDAT = evalue(LFLDTMP)
  Else : End
  Endif

  # Get the field used to populate ITMREF
  Case LABR
    When 'ITN8'   : [L]LFLDTMP = "[M:ITN8]HDTITM(LIDX)"
    When 'MTK3'   : [L]LFLDTMP = "[M:MTK3]MATITMREF(LIDX)"
    When 'SRE9'   : [L]LFLDTMP = "[M:SRE9]HDTITM(LIDX)"
    When Default  : [L]LFLDTMP = "[M:"+LABR+"]ITMREF(LIDX)"
  Endcase
  If [L]LFLDTMP<>"" and evalue("dim("+LFLDTMP+")")>0
    LITM = evalue(LFLDTMP)
  Else : End
  Endif

  # Get the field used to populate STOFCY
  Case LABR
    When 'MBR'    : [L]LFLDTMP = "[M:MBR]FCY"
    When 'DBY1'   : [L]LFLDTMP = "[M:DBY0]STOFCY"
    When 'MTK2'   : [L]LFLDTMP = "[M:MTK0]MFGFCY"
    When 'PTH1'   : [L]LFLDTMP = "[M:PTH0]PRHFCY"
    When 'SIH4'   : [L]LFLDTMP = "[M:SIH0]SALFCY"
    When 'SMR1'   : [L]LFLDTMP = "[M:SMR0]STOFCY"
    When 'SRH1'   : [L]LFLDTMP = "[M:SRH0]STOFCY"
    When 'SRL1'   : [L]LFLDTMP = "[M:SRL0]STOFCY"
    When 'SRS1'   : [L]LFLDTMP = "[M:SRS0]STOFCY"
    When 'MBM'    : [L]LFLDTMP = "[M:MBM]FCY"
    When 'BBY1'   : [L]LFLDTMP = "[M:BBY0]STOFCY"
    When 'ITN8'   : [L]LFLDTMP = "[M:ITN8]HDTSTOFCY(LIDX)"
    When 'MTK3'   : [L]LFLDTMP = "[M:MTK0]MFGFCY"
    When 'PNH1'   : [L]LFLDTMP = "[M:PNH1]PNHFCY"
    When 'SDH1'   : [L]LFLDTMP = "[M:SDH0]STOFCY"
    When 'SIH4'   : [L]LFLDTMP = "[M:SIH0]SALFCY"
    When 'SMO1'   : [L]LFLDTMP = "[M:SMO0]STOFCY"
    When 'SRE9'   : [L]LFLDTMP = "[M:SRE9]HDTSTOFCY(LIDX)"
    When Default  : [L]LFLDTMP = "[M:"+LABR+"]STOFCY"
  Endcase
  If [L]LFLDTMP<>"" and evalue("dim("+LFLDTMP+")")>0
    LFCY = evalue(LFLDTMP)
  Else : End
  Endif

  # Read the correct record into ITMFACILIT
  If [F:ITF]ITMREF<>LITM or [F:ITF]STOFCY<>LFCY
    Read [F:ITF]ITF0=LITM;LFCY
  Endif

  # If the valuation method has ever changed, make sure that the transaction date is not before that change
  If [F:ITF]VLTCODHIS(0) <> ""
    # Get the date of the valuation method change (convert from DateTime to Date)
    [L]LDATTMP = num$([F:ITF]VLTCODDAT(0))
    LVLTCODDAT = gdat$(val(mid$(LDATTMP,9,2)),val(mid$(LDATTMP,6,2)),val(left$(LDATTMP,4)))

    If [L]LIPTDAT<>[0/0/0] and [L]LIPTDAT<[L]LVLTCODDAT
      Call ERREUR([F:ITF]ITMREF-":"-mess(17,104,1)-num$(LIDX+1)-chr$(10)+mess(551,184,1)) From GESECRAN
      # In CTLSTOENT - 0 is error, in CTLSTOSOR - 1 is error
      If LTYP="ENT" : LRET = 0 : Else : LRET = 1 : Endif
    Endif
  Endif

End

