#<AdxTL>@(#)0.0.0.0 $Revision$ Inquiry SML

$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "DEB_CRIT"   : Raz [M:CSML] : Transmask [M:SML1] To [M:CSML]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When Default
Endcase
Return

############################################################
$OUVRE
Raz GSOC_ACTIVE

  If !clalev([F:STJ]) : Local File STOJOU     [STJ] : Endif
  If !clalev([F:STJ2]): Local File STOJOU     [STJ2]: Endif
  If !clalev([F:SJV]) : Local File STOJOUVAL  [SJV] : Endif
  If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
  If !clalev([F:ITV]) : Local File ITMMVT     [ITV] : Endif
  If !clalev([F:STO]) : Local File STOCK      [STO] : Endif
  If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
  If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
  If !clalev([F:TCU]) : Local File TABCUR     [TCU] : Endif
  If !clalev([F:TFO]) : Local File TABFOR     [TFO] : Endif
  If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
  If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif
  If !clalev([F:SRU]) : Local File TABSTORUL  [SRU] : Endif
  If GMODU(2)=2 : # If module counts active
    If !clalev([F:GCM])    Local File GACM       [GCM] : Endif
  Endif

  # Loading global indexes, accounts and sections of society
  GFCY=GFCYDEF(7)
  Call GETCPY(GFCY,"",0,"") From TRTX3CPT
  [M:SML1]CUR=GLOCALDEV
  GORITITCOL=1

  Local Char    WFIL1(250),WFIL2(250), WFILS(250), WFILF(250), DATE_RANGE(250), INDEX_TEST(30)
  Local Integer BEFORE_INDEX, AFTER_INDEX
  Local Integer WSKIP, WLIG, WPAGE, WSTL
  Local Decimal PRE_STO, WWSTO(1..)
  Local Decimal PRE_AMT, WWAMT(1..)
  Local Integer I, J
  Local Integer WOK

  WFILS = "1=1"
  [M:SML1]SRTCOD = 7
  [M:SML1]MISFLG = 1

  NAVIG="CONSSML"
  SUITE  = 1
  RETOUR = 1

  #Set default rules for line color formating
  If [M:SML1]NBFOR=0
    [M:SML1]FORASY([M:SML1]NBFOR) = "[M:SML2]AFTSTO(nolign-1)<0"
    [M:SML1]CODSTL([M:SML1]NBFOR) = "BACKRED"
    [M:SML1]CODZON([M:SML1]NBFOR) = "AFTSTO"
    [M:SML1]NBFOR+=1
    [M:SML1]FORASY([M:SML1]NBFOR) = "[M:SML2]IPTDAT(nolign-1)<>[M:SML2]CREDAT(nolign-1)"
    [M:SML1]CODSTL([M:SML1]NBFOR) = "BACKORANGE"
    [M:SML1]CODZON([M:SML1]NBFOR) = "IPTDAT"
    [M:SML1]NBFOR+=1
    [M:SML1]FORASY([M:SML1]NBFOR) = "nolign<[M:SML2]NBLIG & [M:SML2]AFTPRI(nolign)<>0 & abs(1-[M:SML2]AFTPRI(nolign-1)/[M:SML2]AFTPRI(nolign))>0.1"
    [M:SML1]CODSTL([M:SML1]NBFOR) = "BACKYELLOW"
    [M:SML1]CODZON([M:SML1]NBFOR) = "AFTPRI"
    [M:SML1]NBFOR+=1
  Endif

  #This handles the formating of lines based on criteria above
  Call GENTRT(WOK)
  If WOK
    FIN=1
  Endif

Return

############################################################
#This handles the formating of lines based on the criteria screen
Subprog GENTRT(PRET)
Variable Integer PRET

  Local Integer I
  Local Char TRTGEN(20),FICTRT(250)
  Local Char SAV_IFS(10), SAV_IRS(10)

  TRTGEN="WCNSSMLSTD"
  FICTRT=filpath('TRT',TRTGEN,'src',nomap)

  SAV_IFS = adxifs # backup of separator system variables
  SAV_IRS = adxirs
  adxifs = ""
  adxirs = chr$(10)

  Openo FICTRT , 0
  Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision:   1.0  $"
  Wrseq
  Wrseq "Subprog AFFSTL(PSTL,PLIG)"
  Wrseq "Value Integer PSTL"
  Wrseq "Value Integer PLIG"
  Wrseq "Case PSTL"

  For I=0 To [M:SML1]NBFOR-1
  Wrseq "    When "+num$(I)+" :Chgstl [M:SML2]"+[M:SML1]CODZON(I)+"(PLIG) With ''  : Chgstl [M:SML2]"+[M:SML1]CODZON(I)+"(PLIG) With '"+[M:SML1]CODSTL(I)+"'"
  Next
  Wrseq "Endcase"
  Wrseq "End"

  adxifs = SAV_IFS
  adxirs = SAV_IRS
  Call VALID("TRT",TRTGEN,nomap,PRET) From VALMSKSUB
  If PRET = 0
      PRET=2
      Call ERREUR(mess(20,123,1)) From GESECRAN    #Process validation error
  Else
      Raz PRET
  Endif

End

############################################################
#Moves everything from criteria window to main window
$FIN_CRIT
  [M:SML1] = [M:CSML]
  Call GENTRT(GBIDI1) #sets the formating for the lines
Return

############################################################
$LECTURE

  If [M:SML1]ITMREF = ""
    NBLU = 0
    Return
  Endif

  # calculates records on a new search
  Gosub TRANSACTIONS

  SUITE  = 0
  RETOUR = 0
  [M:SML2]NBLIG=0
  Raz nolign

  #Handles paging requests
  Case CHGPAG
    When 1 : #Search
      WSKIP=0
      WPAGE=0
      Gosub ADDLIN
      NOL+=nolign
      WPAGE += 1
      RETOUR = 1
      If nolign < MAXLIG
        SUITE = 1
      Endif
    When 2 : #Next
      WSKIP = WPAGE * MAXLIG
      Gosub ADDLIN
      NOL+=nolign
      WPAGE += 1
      If nolign < MAXLIG
        SUITE = 1
      Endif
    When -1 : #Last
      WLIG=0
      WLIG = rowcount([STJ])
      If mod(WLIG,MAXLIG) = 0
        WPAGE = int(WLIG/MAXLIG)
      Else
        WPAGE = int(WLIG/MAXLIG)+1
      Endif
      WSKIP  = (WPAGE-1) * MAXLIG
      Gosub ADDLIN
      If WPAGE = 1
        RETOUR = 1
      Endif
      SUITE  = 1
      CHGPAG=2
      NOL=nolign-1
    When -2 : #Back
      WPAGE -= 1
      WSKIP  = (WPAGE-1) * MAXLIG
      Gosub ADDLIN
      NOL    = 0
      If WPAGE = 1
        RETOUR = 1
      Endif
  Endcase

  [M:SML2]NBLIG = max(0,min(nolign,MAXLIG))

  If CHGPAG=1
    Affzo [M:SML2]
  Endif

  # Highlighting styles
  WOK=1
  Chgstl [M:SML2] With ""

  Onerrgo ERR_FOR
  For nolign=1 To [M:SML2]NBLIG
    If [M:SML2]QTYPCU(nolign-1) < 0
      Chgstl [M:SML2]QTYPCU(nolign-1) With ''
      Chgstl [M:SML2]QTYPCU(nolign-1) With 'AWARNHIGH'
    Endif
    If [M:SML2]QTYSTU(nolign-1) < 0
      Chgstl [M:SML2]QTYSTU(nolign-1) With ''
      Chgstl [M:SML2]QTYSTU(nolign-1) With 'AWARNHIGH'
    Endif

    For WSTL=0 To [M:SML1]NBFOR-1
      If WOK
        If !sigma(0,WSTL-1,[M:SML1]CODZON(indcum)=[M:SML1]CODZON(WSTL)) & evalue([M:SML1]FORASY(WSTL))
          Call AFFSTL(WSTL,nolign-1) From WCNSSMLSTD
        Endif
      Else
        Break 2
      Endif
    Next
  Next
  Onerrgo

  Affzo [M:SML2]
Return

############################################################
$ERR_FOR
    Call ERREUR(errmes$(errn)+"\"+[M:SML1]FORASY(WSTL)) From GESECRAN
    WOK=0
Resume

############################################################
$ADDLIN

  #Garbage collection is not resetting the table properly, need to reload it manually
  If clalev([F:STJ]) : Close Local File [F:STJ] : Local File STOJOU [STJ] : Endif

  Onerrgo ERR_FORM
  Case [M:SML1]SRTCOD
    When 7 : # Allocation date (-)
      Filter [F:STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(DATE_RANGE)
&                    Order By IPTDAT Desc; CREMVTDAT Desc; CREMVTTIM Desc; MVTSEQ Asc; MVTIND Asc
    When 9 : # Allocation date (+)
      Filter [F:STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(DATE_RANGE)
&                    Order By IPTDAT Asc; CREMVTDAT Asc; CREMVTTIM Asc; MVTSEQ Desc; MVTIND Desc
    When 10 : # Date created (-)
      Filter [F:STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(DATE_RANGE)
&                    Order By CREDAT Desc; CRETIM Desc; IPTDAT Desc; MVTSEQ
    When 11 : # Date created (+)
      Filter [F:STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(DATE_RANGE)
&                    Order By CREDATTIM; IPTDAT; MVTSEQ Desc
    When Default :
      Filter [F:STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(DATE_RANGE)
&                    Order By IPTDAT Asc; CREMVTDAT Asc; CREMVTTIM Asc; MVTSEQ Desc; MVTIND Desc
  Endcase
  Onerrgo

  Raz WLIG
  For [F:STJ]
    If WLIG >= WSKIP
      If nolign < MAXLIG
        Gosub LOA_LIGNE
        NBLU    = 2
      Else
        Break
      Endif
    Endif
    WLIG += 1
  Next

Return

############################################################
#Finds the stock/cost before the period and gets the values for each transaction
#This is needed when reversing sort order
#$TRT_FILTER
$TRANSACTIONS

  #Garbage collection is not resetting the table properly, need to reload it manually
  If clalev([F:STJ2]) : Close Local File [F:STJ2] : Local File STOJOU [STJ2] : Endif
  Local Integer COUNTER

  If CHGPAG = 1 #Only recalc when doing a new search
    Raz [M:SML2]
    Gosub LOAD_FILTER

    #Set sort order
    If find([M:SML1]SRTCOD,7,9)
      Filter [F:STJ2] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & IPTDAT <= [M:SML1]ENDDAT
&                     Order By IPTDAT Asc; CREMVTDAT Asc; CREMVTTIM Asc; MVTSEQ Desc; MVTIND Desc
    Else
      Filter [F:STJ2] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & IPTDAT <= [M:SML1]ENDDAT
&                    Order By CREDATTIM; IPTDAT; MVTSEQ Desc
    Endif

    If fstat
      Call MESSAGE (mess(65,106,1)) From GESECRAN
      End
    Endif

    Columns [F:STJ2] (IPTDAT,ACTQTY, VARORD)

    PRE_STO = 0
    PRE_AMT = 0
    COUNTER = 0
    Raz WWSTO, WWAMT

    For [F:STJ2]
      If [F:STJ2]IPTDAT < [M:SML1]STRDAT #Value before period
        PRE_STO += [F:STJ2]ACTQTY
        PRE_AMT += [F:STJ2]VARORD
      Else #Values during period
        COUNTER+=1
        If COUNTER = 1
          WWSTO(COUNTER) = PRE_STO + [F:STJ2]ACTQTY
          WWAMT(COUNTER) = PRE_AMT + [F:STJ2]VARORD
        Else
          WWSTO(COUNTER) = WWSTO(COUNTER-1) + [F:STJ2]ACTQTY
          WWAMT(COUNTER) = WWAMT(COUNTER-1) + [F:STJ2]VARORD
        Endif
      Endif
    Next

    Filter [F:STJ2]
    Columns [F:STJ2]
  Endif

Return

############################################################
$ERR_FORM
  Call MESSAGE (mess(65,106,1)) From GESECRAN
  End
Resume

############################################################
$LOAD_FILTER
  Raz WFIL1

  If [M:SML1]SRTCOD = 0
    [M:SML1]SRTCOD = 7
  Endif

  WFIL1 = "[F]STOFCY=[M:SML1]FCY"
  If [M:SML1]UPDFLG <> 2
    WFIL1 += "&[F]UPDCOD=2"
  Else
    WFIL1 += "&[F]UPDCOD=1"
  Endif

  WFIL1 += "&[F]ITMREF=[M:SML1]ITMREF"

  WFIL1 += "&[F]LOT=[M:SML1]LOT"

  WFIL1 += "&[F]SLO=[M:SML1]SLO"

  WFIL2 = "[F]TRSTYP<>0"

  If [M:SML1]MISFLG <> 2
    WFIL2 += "&!find([F]TRSTYP,7,8,9,21,25)"
  Endif

  DATE_RANGE = "[F]IPTDAT >= [M:SML1]STRDAT & [F]IPTDAT <= [M:SML1]ENDDAT"

  # Filter formula
  WFILF = "1=1"
  If [M:SML1]SELFOR <> ""
    Read [TFO]TFO0=11;[M:SML1]SELFOR
    If fstat = 0
      WFILF = [F:TFO]FORFOR
    Endif
  Endif

Return

############################################################
$LOA_LIGNE

  Raz BEFORE_INDEX, AFTER_INDEX, INDEX_TEST

  nolign+=1
  [M:SML2] = [F:STJ]

  #Set index for either ascending or descending order
  If find([M:SML1]SRTCOD,9,11)
    BEFORE_INDEX = WLIG
    AFTER_INDEX  = WLIG+1
    INDEX_TEST   = "WLIG=0"
  Else
    BEFORE_INDEX = maxtab(WWSTO)-WLIG-1
    AFTER_INDEX  = maxtab(WWSTO)-WLIG
    INDEX_TEST   = "WLIG=maxtab(WWSTO)-1"
  Endif

  #Stock
  If evalue(INDEX_TEST)
    [M:SML2]BEFSTO(nolign-1) = PRE_STO
  Else
    [M:SML2]BEFSTO(nolign-1) = WWSTO(BEFORE_INDEX)
  Endif
  [M:SML2]AFTSTO(nolign-1)   = WWSTO(AFTER_INDEX)

  #Amount
  If evalue(INDEX_TEST)
    [M:SML2]BEFAMT(nolign-1) = PRE_AMT
  Else
    [M:SML2]BEFAMT(nolign-1) = WWAMT(BEFORE_INDEX)
  Endif
  [M:SML2]AFTAMT(nolign-1)   = WWAMT(AFTER_INDEX)

  #Average cost
  If [M:SML2]BEFSTO(nolign-1) <> 0
    [M:SML2]BEFPRI(nolign-1) = [M:SML2]BEFAMT(nolign-1)/[M:SML2]BEFSTO(nolign-1)
  Else
    [M:SML2]BEFPRI(nolign-1) = 0
  Endif

  If [M:SML2]AFTSTO(nolign-1) <> 0
    [M:SML2]AFTPRI(nolign-1) = [M:SML2]AFTAMT(nolign-1)/[M:SML2]AFTSTO(nolign-1)
  Else
    [M:SML2]AFTPRI(nolign-1) = 0
  Endif

Return

############################################################
Subprog INIT_PAR(PITM,PFCY)
Value Char PITM
Value Char PFCY

  Local Char LTCM
  Local Integer LRET

  Call GETTCM(PITM, PFCY, LTCM, LRET) From STKVAL
  If [F:TCM]PRIREGS=2
      [M:SML1]SRTCOD = 7
  Else
      [M:SML1]SRTCOD = 10
      [M:SML1]REGFLG = 2
  Endif
  Affzo [M:SML1]SRTCOD
End

############################################################
$SETBOUT
  If [M:SML1]ITMREF <> ""
   CHMEN += "12"
  Endif
Return

############################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
  If GCONSULT <> 0
    mkstat = 2
  Endif
End

######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  Call GETCPY(VALEUR,"",0,"") From TRTX3CPT
  [M:SML1]CUR=GLOCALDEV

  Call INIT_PAR([M:SML1]ITMREF,VALEUR)
End

############################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

  Call INIT_PAR(VALEUR,[M:SML1]FCY)

  Read [ITM]ITM0 = VALEUR
  If !fstat and [ITM]LOTMGTCOD = 4
    Actzo [M:SML1]SLO
  Else
    Effzo [M:SML1]SLO
    Grizo [M:SML1]SLO
  Endif
End

############################################################
Subprog AS_SRTCOD(VALEUR)
Variable Integer VALEUR
  GMENLOC(1) = 1
  GMENLOC(2) = 1
  GMENLOC(3) = 1
  GMENLOC(4) = 1
  GMENLOC(5) = 1
  GMENLOC(6) = 1
  GMENLOC(8) = 1
  GMENLOC(12) = 1
End

############################################################
Subprog AP_SRTCOD(VALEUR)
Variable Integer VALEUR
  Raz GMENLOC
End

######################################################################################
Subprog IB_NBLIG

  # Only OF receptions and entries could be regularized
  If !find([M:SML2]TRSTYP(nolign-1),3,5)
    Raz GBOUT2
  Endif
  If [M:SML2]NUMVCR(nolign-1)=""
    Raz GBOUT3
  Endif

  # No inventory / lot or traceability consultation if not specified
  If dim([M:SML2]LOT) > 0
    If [M:SML2]LOT(nolign-1)=""
      Raz GBOUT4
    Endif
  Endif

  If (dim([M:SML2]LOT) > 0 and [M:SML2]LOT(nolign-1)="") or [F:ITM]TRKCOD<=1 Then   # SYMEU 61044
    Raz GBOUT5
  Endif

  If !GACTDECCST | [M:SML1]REGFLG<>2
    Raz GBOUT6, GBOUT7
  Endif

  If !find([M:SML2]VCRTYP(nolign-1),2,4,5,6,8,9,10,12,13,14,15,17,18,19,20,26,28,29,31,32,33,36)
    Raz GBOUT8
  Else
    GBOUT8 = mess([M:SML2]VCRTYP(nolign-1),701,1)-"("+[M:SML2]VCRNUM(nolign-1)+")"
  Endif

  If !find([M:SML2]VCRTYPORI(nolign-1),2,4,5,6,8,9,10,12,13,14,15,17,18,19,20,26,28,29,31,32,33,36)
    Raz GBOUT9
  Else
    GBOUT9 = mess([M:SML2]VCRTYPORI(nolign-1),701,1)-"("+[M:SML2]VCRNUMORI(nolign-1)+")"
  Endif

  If [M:SML2]TRSTYP(nolign-1)=34 | [M:SML2]VCRTYP(nolign-1)=28
    Raz GBOUT8
    #if piece origin = change of stock, no tunnel because the change of stock is
    #related to a quality control is not visible by the object
    If [M:SML2]VCRTYPORI(nolign-1)=29
      Raz GBOUT9
    Endif
  Endif

End

######################################################################################
Subprog B6_NBLIG
  GBIDC1="SJVO"
  Gosub ACT_SAIDECPRI
End

Subprog B7_NBLIG
    GBIDC1="SJVV"
    Gosub ACT_SAIDECPRI
End

$ACT_SAIDECPRI
  If GACTDECCST
  Raz [F:SJV]
    Raz [F:STJ], [F:SJV]
    For [F:STJ] Where STOFCY=[M:SML1]FCY
&                   & UPDCOD=2
&                   & ITMREF=[M:SML1]ITMREF
&                   & IPTDAT=[M:SML2]IPTDAT(nolign-1)
&                   & MVTSEQ=[M:SML2]MVTSEQ(nolign-1)
&                   & MVTIND=[M:SML2]MVTIND(nolign-1)
      Break
    Next

    Read [SJV]SJV0=[M:SML1]FCY;2;[M:SML1]ITMREF;[M:SML2]IPTDAT(nolign-1);[M:SML2]MVTSEQ(nolign-1);[M:SML2]MVTIND(nolign-1)
    If fstat
        mkstat=2
    Endif
  Endif
Return

######################################################################################
Subprog B8_NBLIG
  Local Integer NOL : NOL = nolign-1
  Call LNK2VCR([M:SML2]VCRTYP(NOL),[M:SML2]VCRNUM(NOL))
End

######################################################################################
Subprog B9_NBLIG
  Local Integer NOL : NOL = nolign-1
  Call LNK2VCR([M:SML2]VCRTYPORI(NOL),[M:SML2]VCRNUMORI(NOL))
End

######################################################################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
  If VALEUR > [M]ENDDAT
    [M]ENDDAT = VALEUR
  Endif
End

######################################################################################
Subprog LNK2VCR(PTYP, PNUM)
Value Integer PTYP
Value Char    PNUM

  GCONSULT = 2
  Case PTYP
  When 2   # Sales order
      Call OBJET("SOH",PNUM,num$(PTYP)) From GOBJET
  When 4   # Delivery
      Call OBJET("SDH",PNUM,num$(PTYP)) From GOBJET
  When 5   # Sales invoice
      Call OBJET("SIH",PNUM,num$(PTYP)) From GOBJET
  When 6   # Receipt
      Call OBJET("PTH",PNUM,num$(PTYP)) From GOBJET
  When 8   # Return to supplier
      Call OBJET("PNH",PNUM,num$(PTYP)) From GOBJET
  When 9   # Inventory
      Gosub SET_NOL From STKINV
      GCONSULT = 2
      Call OBJET("SNL",PNUM,[M:SML2]VCRNUMORI(NOL)) From GOBJET
      GCONSULT = 0
  When 10  # Work order
      Call OBJET("MFG",PNUM,num$(PTYP)) From GOBJET
  When 12  # Production tracking
      Call OBJET("MTK",PNUM,num$(PTYP)) From GOBJET
  When 13  # Customer return
      Call OBJET("SRH",PNUM,num$(PTYP)) From GOBJET
  When 14  # Purchase order
      Call OBJET("POH",PNUM,num$(PTYP)) From GOBJET
  When 15  # Production declaration
      Call OBJET("MTK",PNUM,num$(PTYP)) From GOBJET
  When 17  # Supplier invoice
      Call OBJET("PIH",PNUM,num$(PTYP)) From GOBJET
  When 18  # Sales credit
      Call OBJET("SIH",PNUM,num$(PTYP)) From GOBJET
  When 19  # Miscellaneous receipt
      Call OBJET("SMR",PNUM,num$(PTYP)) From GOBJET
  When 20  # Miscellaneous issue
      Call OBJET("SMO",PNUM,num$(PTYP)) From GOBJET
  When 26  # Return to stock (not active)
      Call OBJET("SCS",PNUM,num$(PTYP)) From GOBJET
  When 28  # Quality control
      Call OBJET("STQ",PNUM,num$(PTYP)) From GOBJET
  When 29  # Stock change
      Call OBJET("SCS",PNUM,num$(PTYP)) From GOBJET
  When 31  # Assembly
      Call OBJET("BBY",PNUM,num$(PTYP)) From GOBJET
  When 32  # Disassembly
      Call OBJET("DBY",PNUM,num$(PTYP)) From GOBJET
  When 33  # Service request
      Call OBJET("SRE",PNUM,num$(PTYP)) From GOBJET
  When 35  # Lot modification
      #no tunnel on Lot modification because we do not know what object used
  When 36  # Subcontract order
      Call OBJET("SCO",PNUM,num$(PTYP)) From GOBJET
  Endcase
  GCONSULT = 0

End

