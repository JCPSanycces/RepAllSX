#<AdxTL>@(#)0.0.0.0 $Revision$
##JOJAC - 2016-06-02 - REQ114309 US215 - START
#---------------------------------------------
# SUBCTRKFR : Gestion CTR / Localisation KFR
#---------------------------------------------

Call OBJET("CTR", [V]GBIDC1, [V]GBIDC2) From GOBJET
End

$ACTION
Case [L]ACTION
    When "LIENS"
        Gosub LIENS From SUBCTRKFR
    When "CREATION"
        Gosub CREATION From SUBCTRKFR
    When "MODIF"
        Gosub MODIF From SUBCTRKFR
    When "ANNULE"
        Gosub ANNULE From SUBCTRKFR
#JOJAC - 2016-06-02 - REQ114309 US215 - START
    When "STYLE"
        Gosub STYLE From SUBCTRKFR
#JOJAC - 2016-06-02 - REQ114309 US215 - END
    When Default
Endcase
Return

$LIENS
#JOJAC - 2016-06-09 - REQ114309 US215 - START
If !func DIVPAYE.IS_KFR_LEG(GCURLEG) : Return : Endif
#JOJAC - 2016-06-09 - REQ114309 US215 - END
Gosub CHARGE_CTRFRA From SUBCTRKFR
If dim([M]FLGEXCPEN) > 0
    Gosub CHARGE_CPN From SUBCTRKFR
Endif
Return

# Chargement CTRFRA - zones ajoutées à CTR pour la localisation FRANCE (KFR)
$CHARGE_CTRFRA
Read [F:CTRFRA]CTRFRA0 = [M:CTR0]REFNUM ; [M:CTR0]CTRNUM ; [M:CTR0]CTRDAT
If fstat = 0
    # Affectation des masques
    For [L]MA = 0 To [L]NBMASK
        Gosub SETMASK From =[L]WINPROG
        [M] = [F:CTRFRA]
    Next
Endif
Return

$CREATION
#JOJAC - 2016-06-09 - REQ114309 US215 - START
If !func DIVPAYE.IS_KFR_LEG(GCURLEG) : Return : Endif
#JOJAC - 2016-06-09 - REQ114309 US215 - END
Gosub ECRIT_CTRFRA
If [V]GOK < 1 : Return : Endif
If dim([M:CTRB]NBRPEN) > 0
    Gosub MAJ_EMPLOCTRCPN From SUBCTRKFR
    If [V]GOK < 1 : Return : Endif
Endif

Gosub CREATE_INTERVIEW

Return

$CREATE_INTERVIEW
Gosub DECLARE_VAR_TYPEVA From GENINIEVA
W_TYPENT="EVAPRO"
Gosub CREATE_FROM_GESCTR From GENINIEVA

Return

$MODIF
#JOJAC - 2016-06-09 - REQ114309 US215 - START
If !func DIVPAYE.IS_KFR_LEG(GCURLEG) : Return : Endif
#JOJAC - 2016-06-09 - REQ114309 US215 - END
Readlock [F:CTRFRA]CTRFRA0 = [M:CTR0]REFNUM ; [M:CTR0]CTRNUM ; [M:CTR0]CTRDAT
If fstat = 1
    [V]GOK = -1 : [V]GLOCK = "$EMPLOCTRFRA" : Return
Elsif fstat <> 0
    # A voir si on plante ou si l'on passe en création ?
    Gosub ECRIT_CTRFRA
    If [V]GOK < 1 : Return : Endif
    # [V]GOK = 0
    # Call RSTA("CTRFRA", [M:CTR0]REFNUM-[M:CTR0]CTRNUM-[M:CTR0]CTRDAT) From GLOCK
    # Return
Else
    Gosub AFFECTE_CTRFRA
    Rewrite [F:CTRFRA]
    If fstat <> 0
        [V]GOK = 0
        Call FSTA("CTRFRA") From GLOCK
        Return
    Endif
Endif
If dim([M:CTRB]NBRPEN) > 0
    Gosub MAJ_EMPLOCTRCPN From SUBCTRKFR
    If [V]GOK < 1 : Return : Endif
Endif
Return

$ECRIT_CTRFRA
Raz [F:CTRFRA]
Gosub AFFECTE_CTRFRA From SUBCTRKFR
# Sécurité sur la clé
#JOJAC - 2016-06-02 - REQ114309 US2150 - START
#[F:CTRFRA]REFNUM = [F:CTR]REFNUM
#[F:CTRFRA]CTRNUM = [F:CTR]CTRNUM
#[F:CTRFRA]CTRDAT = [F:CTR]CTRDAT
[F:CTRFRA]REFNUM = [F:HRCTR]REFNUM
[F:CTRFRA]CTRNUM = [F:HRCTR]CTRNUM
[F:CTRFRA]CTRDAT = [F:HRCTR]CTRDAT
#JOJAC - 2016-06-02 - REQ114309 US2150 - END
Write [F:CTRFRA]
If fstat <> 0
    [V]GOK = 0
    Call FSTA("CTRFRA") From GLOCK
    Return
Endif
Return

$AFFECTE_CTRFRA
For [L]MA = 0 To [L]NBMASK
    Gosub SETMASK From =[L]WINPROG
    nolign = 1
    [F:CTRFRA] = [M]
Next [L]MA
Return

$ANNULE
If !func DIVPAYE.IS_KFR_LEG(GCURLEG) : Return : Endif
Delete [F:CTRFRA] Where [F:CTRFRA]REFNUM = [M:CTR0]REFNUM
&                & [F:CTRFRA]CTRNUM = [M:CTR0]CTRNUM
&                & [F:CTRFRA]CTRDAT = [M:CTR0]CTRDAT
If fstat <> 0 & fstat <> 4
    [V]GOK = 0
    Call FSTA("CTRFRA") From GLOCK
    Return
Endif
Gosub MAJ_EMPLOCTRCPN From SUBCTRKFR
If [V]GOK < 1 : Return : Endif
Return

#JOJAC - 2016-06-02 - REQ114309 US215 - START
$STYLE
#JASMI - START
#Call DISPLAY_HIDE() From SUBCTRLEG
#JASMI - END
Return
#JOJAC - 2016-06-02 - REQ114309 US215 - END
#----------------
# Chargement CPN
#----------------
$CHARGE_CPN
If dim([M:CTRB]NBRPEN) > 0

    Local Integer PEN_EXCLUS

    Effzo [M:CTRB] 10-90
    Actzo [M:CTRB]FLGEXCPEN

    nolign = 0

    If [M:CTRB]FLGEXCPEN = 2
        # Chargement des données au contrat si existante - load contract data if exist
        Filter [F:CPN] Where [F:CPN]REFNUM = [M:CTR0]REFNUM & [F:CPN]CTRNUM = [M:CTR0]CTRNUM
&            & [F:CPN]CTRDAT = [M:CTR0]CTRDAT
        For [F:CPN]CPN0
            If nolign >= dim([M:CTRB]PEN)
                # Tableau plein
                Call ERREUR(mess(26,100,1)) From GESECRAN
                Break
            Endif
            nolign += 1
            [M:CTRB] = [F:CPN]
        Next
        Filter [F:CPN]
        [M:CTRB]NBRPEN = nolign

        Actzo [M:CTRB] 10-15

    Else

        Grizo [M:CTRB] 15    : # Pas de saisie à droite
        Diszo [M:CTRB] 10    : # Mais promenade autorisée sur le tableau

        # Pas de données spécifique pour le contrat, on reprends celles du poste en affichage
        # No specific data for the contract, take the "POSTE" data in display mode only
        # Seuls les critères "actifs" en fonction des dates d'exposition sont affichés (analyse faite ainsi)

        If dim([M:CTR1]POT) > 0 & [M:CTR1]POT <> ""

            Raz nolign

            Filter [F:HRPEN] Where [F:HRPEN]COD = [M:CTR1]POT
            For [F:HRPEN]HRPEN0
                Raz [L]PEN_EXCLUS
                # Sont exclus les critères qui se terminent avant le début du contrat (ou avant la date d'effet)
                # ou qui commencent après la fin de contrat
                If [F:HRPEN]ENDDATPEN <> [0/0/0] & [F:HRPEN]ENDDATPEN < [M:CTR0]CTRDAT  & [M:CTR0]FLGRET<>2
                    [L]PEN_EXCLUS = 1
                Endif
                If [F:HRPEN]ENDDATPEN <> [0/0/0] & [F:HRPEN]ENDDATPEN < [M:CTR0]RETDATEFF  & [M:CTR0]FLGRET=2
                    [L]PEN_EXCLUS = 1
                Endif
                 If [M]XITDAT <> [0/0/0] & [F:HRPEN]STRDATPEN > [M]XITDAT
                    [L]PEN_EXCLUS = 1
                Endif
                If not([L]PEN_EXCLUS)
                    If nolign >= dim([M:CTRB]PEN)
                     # Tableau plein
                     Call ERREUR(mess(26,100,1)) From GESECRAN
                     Break
                    Endif
                    nolign += 1
                    [M:CTRB] = [F:HRPEN]
                Endif
            Next
            [M:CTRB]NBRPEN = nolign
            Filter [F:HRPEN]

            # Si le poste n'admet pas d'exception, on se permet de griser l'écran
            Read [F:POT]POT0 = [M:CTR1]POT
            If fstat = 0
                If [F:POT]FLGEXCPEN <> 2
                    Grizo [M:CTRB]FLGEXCPEN
                Else
                    Actzo [M:CTRB]FLGEXCPEN
                Endif
            Else
                Grizo [M:CTRB]FLGEXCPEN
            Endif
        Else
            Grizo [M:CTRB]    : # Pas de poste, pas de pénibilité
        Endif
    Endif

    Affzo [M:CTRB]

    Kill [L]PEN_EXCLUS
    If [M:CTRB]NBRPEN > 0
        nolign = 1
        Call AS_NBRPEN From SUBCTR
    Endif

Endif

Return

#--------------------------
# Ecriture des données CPN
#--------------------------
$MAJ_EMPLOCTRCPN
Delete [F:CPN] Where [F:CPN]REFNUM = [M:CTR0]REFNUM
&                & [F:CPN]CTRNUM = [M:CTR0]CTRNUM
&                & [F:CPN]CTRDAT = [M:CTR0]CTRDAT
If fstat <> 0 & fstat <> 4
    [V]GOK = 0
    Call FSTA("CPN") From GLOCK
    Return
Endif
If [M:CTRB]FLGEXCPEN = 2 & GREP <> "A"
    For nolign = 1 To [M:CTRB]NBRPEN
        Raz [F:CPN]
        [F:CPN] = [M:CTR0]
        [F:CPN] = [M:CTRB]
        Write [F:CPN]
        If fstat <> 0
            [V]GOK = 0
            Call FSTA("CPR") From GLOCK
            Break
        Endif
    Next
    If [V]GOK < 1 : Return : Endif
Endif
Return

$LOAD_PEN
Local Char ZONE_ORIGINE(50), ZONE_DESTINATION(50), PREFIXE(10)
Local Integer IZON

[L]PREFIXE = "[M:CTRB]"

Assign [L]PREFIXE + "WNOLPEN" With [L]NOL

For [L]IZON = 1 To evalue("clanbs(" + [L]PREFIXE + ", 1)")
    [L]ZONE_DESTINATION = evalue("clavar(" + [L]PREFIXE + ", [L]IZON)")
    If left$([L]ZONE_DESTINATION, 1) = "W"
        [L]ZONE_ORIGINE = [L]PREFIXE + right$([L]ZONE_DESTINATION, 2)
        [L]ZONE_ORIGINE += "([L]NOL)"
        [L]ZONE_DESTINATION = [L]PREFIXE + [L]ZONE_DESTINATION
        If evalue("dim(" + [L]ZONE_ORIGINE + ")") > 0
            Assign [L]ZONE_DESTINATION With evalue([L]ZONE_ORIGINE)
        Endif
    Endif
Next

Return

# ----------------------- GESTION DE L'ECRAN --------------------------

$SETNOL
Local Integer NOL
[L]NOL = nolign - 1
Return

########################################################
#Pénibilité 109374 US3811
Subprog GRISE_PEN (VALEUR)
Value Char VALEUR
Local Char ZONE(10) : ZONE = VALEUR
Gosub SET_ZONE From SUBCTR
If MA
  If [M]FLGEXCPEN = 2
      Actzo [M] 10 - 90
  Else
      Grizo [M] 10 - 90
  Endif
Endif
End


Subprog AS_FLGEXCPEN(VALEUR)
Variable Integer VALEUR
If [M:CTR1]POT <> ""
    Read [F:POT]POT0 = [M:CTR1]POT
    If fstat = 0
        If [F:POT]FLGEXCPEN <> 2
            mkstat = 2 : End
        Endif
    Endif
Else
    mkstat = 2 : End
Endif
End

Subprog AM_FLGEXCPEN(VALEUR)
Variable Integer VALEUR
If [L]VALEUR = 2
    Actzo [M:CTRB] 10 - 90
Else
    Grizo [M:CTRB] 10 - 90
Endif
End

Subprog AS_NBRPEN
Gosub SETNOL
If [L]NOL >= 0 & [M:CTRB]PEN([L]NOL) <> ""
    Gosub LOAD_PEN
    Affzo [M:CTRB] 15
Else
    Effzo [M:CTRB] 15
    [M:CTRB]WNOLPEN = [L]NOL
Endif
End

Subprog AM_PEN(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
# Affichage temps réel du volet de visualisation coté droit
[M:CTRB]WPEN = [L]VALEUR
Affzo [M:CTRB]WPEN
If dim([M:CTRB]ZWPEN)
    Affzo [M:CTRB]ZWPEN
Endif
[M:CTRB]PEN([L]NOL) = [L]VALEUR
If dim([M:CTRB]LIBPEN)
    Call AV_LIBPEN([M:CTRB]LIBPEN([L]NOL)) From SUBCTR
    Affzo [M:CTRB]LIBPEN([L]NOL)
Endif
End

Subprog D_STRDATPEN(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR=max([M:CTR0]CTRDAT, gdat$(01,01,year(date$))): Endif
End

Subprog AS_STRDATPEN(VALEUR)
Variable Date    VALEUR
If [L]VALEUR = [0/0/0]
    [L]VALEUR = [M:CTR0]CTRDAT
Endif
End

Subprog C_STRDATPEN(VALEUR)
Variable Date    VALEUR
If [M:CTR0]XITDAT<>[0/0/0] & VALEUR>[M:CTR0]XITDAT
 #Date incorrecte : date au delà de la période
 GMESSAGE=mess(20,199,1)
 mkstat=2 : End
Endif
Gosub SETNOL
Call CTRL_OVERLAP([M:CTRB]PEN([L]NOL), [L]NOL, [L]VALEUR, [L]VALEUR)
If mkstat=2 : End : Endif
End

Subprog AM_STRDATPEN(VALEUR)
Variable Date    VALEUR
# Affichage temps réel du volet de visualisation coté droit
[M:CTRB]WSTRDATPEN = [L]VALEUR
Affzo [M:CTRB]WSTRDATPEN
End

Subprog C_ENDDATPEN(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & (([M:CTR0]FLGRET<>2 & VALEUR<[M:CTR0]CTRDAT) | ([M:CTR0]FLGRET=2 & VALEUR<[M:CTR0]RETDATEFF))
 #Cette date doit être supérieure à la date du contrat
 GMESSAGE=mess(98,199,1)
 mkstat=2 : End
Endif
Gosub SETNOL
Call CTRL_OVERLAP([M:CTRB]PEN([L]NOL), [L]NOL, [M:CTRB]STRDATPEN([L]NOL), [L]VALEUR)
If mkstat=2 : End : Endif
End

Subprog AM_ENDDATPEN(VALEUR)
Variable Date    VALEUR
# Affichage temps réel du volet de visualisation coté droit
[M:CTRB]WENDDATPEN = [L]VALEUR
Affzo [M:CTRB]WENDDATPEN
End

Subprog AV_LIBPEN(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M:CTRB]PEN([L]NOL) <> ""
    [L]VALEUR = func AFNC.TEXTRA("ATABDIV","LNGDES","410",[M:CTRB]PEN([L]NOL))
Else
    [L]VALEUR = ""
Endif
End

Subprog AS_WPRVORG(VALEUR)
Variable Char    VALEUR()
If [M:CTRB]WPEN = "" : mkstat = 2 : End : Endif
End

Subprog AS_WPRVCOL(VALEUR)
Variable Char    VALEUR()
If [M:CTRB]WPEN = "" : mkstat = 2 : End : Endif
End

Subprog AS_WPRVIND(VALEUR)
Variable Char    VALEUR()
If [M:CTRB]WPEN = "" : mkstat = 2 : End : Endif
End

Subprog AS_WCOMMENT(VALEUR)
Variable Char    VALEUR()
If [M:CTRB]WPEN = "" : mkstat = 2 : End : Endif
End

Subprog AM_WPRVORG(VALEUR)
Variable Char    VALEUR()
[M:CTRB]PRVORG([M]WNOLPEN) = [L]VALEUR
End

Subprog AM_WPRVCOL(VALEUR)
Variable Char    VALEUR()
[M:CTRB]PRVCOL([M]WNOLPEN) = [L]VALEUR
End

Subprog AM_WPRVIND(VALEUR)
Variable Char    VALEUR()
[M:CTRB]PRVIND([M]WNOLPEN) = [L]VALEUR
End

Subprog AM_WCOMMENT(VALEUR)
Variable Char    VALEUR()
[M:CTRB]COMMENT([M]WNOLPEN) = [L]VALEUR
End

Subprog CTRL_OVERLAP(WPEN,WINDIC,WSTRDAT,WENDDAT)
Value Char WPEN
Value Integer WINDIC
Value Date WSTRDAT, WENDDAT
Local Integer WOK, I

WOK=0
For I=0 To [M]NBRPEN-1
  If I<>WINDIC & WPEN=[M]PEN(I)

   If WENDDAT= [0/0/0]
      If [M]ENDDATPEN(I)=[0/0/0]   : WOK=2 : Endif
      If [M]ENDDATPEN(I)>= WSTRDAT : WOK=2 : Endif

   Else
      If [M]ENDDATPEN(I)<>[0/0/0]
        If !([M]STRDATPEN(I)> WENDDAT | [M]ENDDATPEN(I)<WSTRDAT)
          WOK=2
        Endif
      Else
         If [M]STRDATPEN(I)<= WENDDAT
           WOK=2
         Endif
      Endif
   Endif

   If WOK =2
   #JOJAC - 2016-06-02 - REQ114309 US2150 - START
      #GMESSAGE = mess(50,709,1) -num$(I+1)-" & "-num$(WINDIC+1)
      GMESSAGE = mess(50,10709,1) -num$(I+1)-" & "-num$(WINDIC+1)
      #JOJAC - 2016-06-02 - REQ114309 US2150 - END
      # Chevauchement de période entre les lignes
      mkstat = 2 : Break
   Endif

  Endif
Next
End

Subprog AM_POT(VALEUR)
Value Char VALEUR()
#Si il y avait des facteurs de pénibilité définis comme exception au contrat on les laisse, sinon on affiche ceux du nouveau poste !
If dim([M:CTRB]FLGEXCPEN) > 0 & [M:CTRB]FLGEXCPEN<>2
 If VALEUR<>""
  [M]POT=VALEUR
  Gosub CHARGE_CPN
 Else
  Effzo [M:CTRB]
 Endif
Endif
End
#JOJAC - 2016-06-02 - REQ114309 US2150 - END

