#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UTIACH7        Utilitaire de resynchronisation            Module ACHAT #
#                des DL inter-site achats avec ventes                    #
# ---------------------------------------------------------------------- #
# ProblÃĻme Ã  rÃĐsoudre :                                                  #
#   S'assurer que les enregistrements PORDERQ et SORDERQ sont en phase   #
#     - [F:POQ]POHNUM    = [F:SOQ]POHNUM                                 #
#     - [F:POQ]POPLIN    = [F:SOQ]SOPLIN et [F:SOQ]POPLIN                #
#     - [F:POQ]POQSEQ    = [F:SOQ]SOQSEQ et [F:SOQ]POQSEQ                #
#     - [F:POQ]LINOCNNUM = [F:SOQ]SOHNUM                                 #
#     - [F:POQ]OCNLIN    = [F:SOQ]SOPLIN                                 #
#     - [F:POQ]OCNSEQ    = [F:SOQ]SOQSEQ                  MBT 18/04/2002 #
##########################################################################


Call MAJ_UTIACH7
End


Subprog MAJ_UTIACH7
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACH7") From SAIDOS

# cathy le 24 fÃĐvier 2003 : attention cette moulinette ne peut s'executer que sur le dossier lui meme
# les tables ORDS et AVALNUM ne sont pas ouvertes correctement : je bloque donc la saisie du dossier
# il faut forcement dossier = nomap
#If DOSSIER<>"" Call EXE_UTIACH7(DOSSIER) : Endif
If DOSSIER= nomap 
    Call EXE_UTIACH7(DOSSIER)
Else
    Infbox "only in the same folder" 
Endif
   
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End


#######################################################################
# Pour exÃĐcution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If [F:ADS]MODULE(5) <> 2 : End : Endif
Call EXEB_UTIACH7(APPLI)
End


########################################################################

Subprog EXE_UTIACH7(DOSSIER)
Value Char DOSSIER
#----- Variables locales -----#
Local Shortint I1, I2, I, J, K, JD, JF
Local Char     WMSG(100)
Local Integer  NBENR,         NBCOR
Local Char     WPOHNUM(GLONPOH), WSOHNUM(GLONSOH)
Local Integer  WPOPLIN,       WSOPLIN
Local Integer  WPOQSEQ(1000), WSOQSEQ(1000)
Local Decimal  WQTEPOQ(1000), WQTESOQ(1000)
Local Date     WDATPOQ(1000), WDATSOQ(1000)
Local Decimal  WCUMQTEPOQ,    WCUMQTESOQ
Local Decimal  WQTE 
Local Libelle  UPDFLG, SIMFLG
Local Integer  OK
#-----
Call OUINON("Simulation ?",OK) From GESECRAN
If OK=2 SIMFLG=1 Else Raz SIMFLG : Endif
#SIMFLG=1
#-----
Call TEMPON("O") From GESECRAN
WMSG="UTIACH7: Utilitaire de resynchronisation DL inter-site achats-ventes"
Call OUVRE_TRACE(WMSG) From LECFIC
Goto UTIACH07_01


Subprog EXEB_UTIACH7(DOSSIER)
Value Char DOSSIER
# depuis dosmaj -  moulinette
#----- Variables locales -----#
Local Shortint I1, I2, I, J, K, JD, JF
Local Char     WMSG(100)
Local Integer  NBENR,         NBCOR
Local Char     WPOHNUM(GLONPOH), WSOHNUM(GLONSOH)
Local Integer  WPOPLIN,       WSOPLIN
Local Integer  WPOQSEQ(1000), WSOQSEQ(1000)
Local Decimal  WQTEPOQ(1000), WQTESOQ(1000)
Local Date     WDATPOQ(1000), WDATSOQ(1000)
Local Decimal  WCUMQTEPOQ,    WCUMQTESOQ
Local Decimal  WQTE 
Local Libelle  UPDFLG, SIMFLG
Local Integer  OK
#-----
SIMFLG=1
WMSG="UTIACH7: Utilitaire de resynchronisation DL inter-site achats-ventes"
Call ECR_TRACE(WMSG,0) From GESECRAN
Goto UTIACH07_01

########################################################
$UTIACH07_01
WMSG="UTIACH7: DÃĐbut traitement du dossier "+DOSSIER
If SIMFLG=1  WMSG-="(**Simulation**)" : Endif
Call ECR_TRACE(WMSG,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:POH]) =0  Local File =DOSSIER+".PORDER"    [POH]  : Endif 
If clalev([F:POC]) =0  Local File =DOSSIER+".PORDERC"   [POC]  : Endif 
If clalev([F:POQ]) =0  Local File =DOSSIER+".PORDERQ"   [POQ]  : Endif 
If clalev([F:POQ2])=0  Local File =DOSSIER+".PORDERQ"   [POQ2] : Endif 
If clalev([F:SOH]) =0  Local File =DOSSIER+".SORDER"    [SOH]  : Endif 
If clalev([F:SOC]) =0  Local File =DOSSIER+".SORDERC"   [SOC]  : Endif 
If clalev([F:SOQ]) =0  Local File =DOSSIER+".SORDERQ"   [SOQ]  : Endif
If clalev([F:ORD]) =0  Local File =DOSSIER+".ORDERS"    [ORD]  : Endif
If clalev([F:TCA]) =0  Local File =DOSSIER+".TABCOUAFF" [TCA]  : Endif
If clalev([F:AVN]) =0  Local File =DOSSIER+".AVALNUM"   [AVN]  : Endif
If clalev([F:ANM]) =0  Local File =DOSSIER+".ACODNUM"   [ANM]  : Endif
If clalev([M:ORDK])=0  Local Mask =DOSSIER+".ORDK"      [ORDK] : Endif
#----- DÃĐbut du traitement -----#
$DEBUT_UTIACH7
Call DEBTRANS From GLOCK
#-----
For [POH] POH0 Where BETFCY=2 & POHTYP=2
  WPOHNUM=[F:POH]POHNUM
  Read [SOH] SOH0=[F:POH]OCNNUM
  If !fstat
    WSOHNUM=[F:SOH]SOHNUM
    For [POC] POC0 Where POHNUM=WPOHNUM
      WPOPLIN=[F:POC]POPLIN
      Read [SOC] SOC0=WSOHNUM;WPOPLIN
      If !fstat
        WSOPLIN=[F:SOC]SOPLIN
        Raz WPOQSEQ, WQTEPOQ, WCUMQTEPOQ, I1
        For [POQ] POQ0 Where POHNUM=WPOHNUM & POPLIN=WPOPLIN
          WPOQSEQ(I1) =[F:POQ]POQSEQ
          WDATPOQ(I1) =[F:POQ]DEMRCPDAT
          WQTEPOQ(I1)+=[F:POQ]QTYPUU
          WCUMQTEPOQ +=[F:POQ]QTYPUU
          I1+=1
          If I1>999
            WMSG=WPOHNUM-num$(WPOPLIN)-" Trop de lignes de DL achats !"
            Call ECR_TRACE(WMSG,1) From GESECRAN
            Break
          Endif
        Next
        Raz WSOQSEQ, WQTESOQ, WCUMQTESOQ, I2
        For [SOQ] SOQ0 Where SOHNUM=WSOHNUM & SOPLIN=WSOPLIN
          If [F:SOQ]QTY>=0
            WSOQSEQ(I2) =[F:SOQ]SOQSEQ
            WDATSOQ(I2) =[F:SOQ]DEMDLVDAT
            WQTESOQ(I2)+=[F:SOQ]QTY
            WCUMQTESOQ +=[F:SOQ]QTY
            I2+=1
            If I2>999
              WMSG=WSOHNUM-num$(WSOPLIN)-" Trop de lignes de DL ventes !"
              Call ECR_TRACE(WMSG,1) From GESECRAN
              Break
            Endif
          Else
            WCUMQTESOQ +=[F:SOQ]QTY
            WMSG =WSOHNUM-num$(WSOPLIN)-num$([F:SOQ]SOQSEQ)
            WMSG-="("+num$([F:SOQ]QTY)+") DL vente qtÃĐ nÃĐgative !"
            Call ECR_TRACE (WMSG,1) From GESECRAN
          Endif
        Next
        Gosub TRAIT_UTIACH7
      Else
        WMSG=WPOHNUM-num$(WPOPLIN)-WSOHNUM-num$(WPOPLIN)-"Ligne article vente non trouvÃĐ !"
        Call ECR_TRACE(WMSG,1) From GESECRAN
      Endif
    Next
  Else
    WMSG=WPOHNUM-[F:POH]OCNNUM-"Contrat vente non trouvÃĐ !"
    Call ECR_TRACE(WMSG,1) From GESECRAN
  Endif
Next
#----- Fin du traitement -----#
$FIN_UTIACH7
WMSG ="UTIACH7 : Nbre d'enregistrements traitÃĐs :"-num$(NBENR)
WMSG+=" dont corrigÃĐs :"-num$(NBCOR)
Call ECR_TRACE(WMSG,0) From GESECRAN
Close Local File [POH]
Close Local File [POC]
Close Local File [POQ]
Close Local File [POQ2]
Close Local File [SOH]
Close Local File [SOC]
Close Local File [SOQ]
Close Local File [ORD]
Close Local File [TCA]
Close Local File [AVN]
Close Local File [ANM]
Close Local Mask [ORDK]
End

#------------------------------------------#
# VÃĐrification et traitement des dÃĐsynchro #
#------------------------------------------#
$TRAIT_UTIACH7
NBENR+=max(I1,I2)
If WCUMQTEPOQ<>WCUMQTESOQ
  WMSG =WPOHNUM-num$(WPOPLIN)-WSOHNUM-num$(WSOPLIN)
  WMSG-="DiffÃĐrence sur qtÃĐs ("+num$(WCUMQTEPOQ)-num$(WCUMQTESOQ)+")"
  Call ECR_TRACE(WMSG,1) From GESECRAN
Endif
JF=-1
#----- Boucle sur les DL d'achats
For I=0 To I1-1
  J=JF+1 : JD=JF+1
  Raz WQTE
  #----- Boucle sur les DL de ventes
  While J<I2
    If WDATPOQ(I)>WDATSOQ(J)
      JF=J
      Gosub ORPHELIN_SOQ : # C'est du 0:1
      JD=JF+1 : J+=1
    Elsif WDATPOQ(I)=WDATSOQ(J) & WQTE<WQTEPOQ(I)
      WQTE+=WQTESOQ(J) : JF=J : J+=1
    Else
      J=I2
    Endif
  Wend
  #-----
  Read [POQ] POQ0=WPOHNUM;WPOPLIN;WPOQSEQ(I)
  If !fstat
    If JD=JF
      Gosub UNIQUE       : # C'est du 1:1
    Elsif JF>JD
      Gosub PLUSIEURS    : # C'est du 1:N
    Else
      Gosub ORPHELIN_POQ : # C'est du 1:0
    Endif
  Else
    WMSG=WPOHNUM-num$(WPOPLIN)-num$(WPOQSEQ(I))-"Erreur de lecture sur [POQ]"
    Call ECR_TRACE (WMSG,1) From GESECRAN
  Endif
  #-----
Next I
Return

#---------------------------------------------#
# Ã  une DL d'achat correspond une DL de vente #
#---------------------------------------------#
$UNIQUE
Raz UPDFLG
Read [SOQ] SOQ0=WSOHNUM;WSOPLIN;WSOQSEQ(JD)
If !fstat
  GBIDI1=WPOQSEQ(I)
  #----- Alignement no sÃĐquence DL d'achat sur no sÃĐquence DL de vente -----#
  If WPOQSEQ(I)<>WSOQSEQ(JD)
    If !find(WSOQSEQ(JD),WPOQSEQ(0..I1-1))
      [F:POQ]POQSEQ=WSOQSEQ(JD)
      [F:POQ]POQLNK=mid$("00000000",1,8-len(num$([F:POQ]POPLIN)))+num$([F:POQ]POPLIN)
&                  +mid$("00000000",1,8-len(num$([F:POQ]POQSEQ)))+num$([F:POQ]POQSEQ)
      [F:POQ]LINOCNNUM=WSOHNUM
      [F:POQ]OCNLIN   =WSOPLIN
      [F:POQ]OCNSEQ   =WSOQSEQ(JD)
      If !SIMFLG
        #----- Ecriture DL d'achat avec nouveau no de sÃĐquence -----#
        Trbegin [POQ]
        Write [POQ]
        If !fstat
          #----- Si DL non soldÃĐe et ferme, mÃ j no sÃĐquence de l'encours -----#
          If [F:POQ]LINSTA<>3 & [F:POQ]WIPSTA=1
            Update [ORD] Where WIPTYP=[F:POQ]WIPTYP
&                            & WIPNUM=[F:POQ]WIPNUM
&                            & ITMREF=[F:POQ]ITMREF With  VCRSEQ=[F:POQ]POQSEQ
          Endif
          If !fstat
            WPOQSEQ(I)=[F:POQ]POQSEQ
            GBIDI2=[F:POQ]POQSEQ
            #----- Suppression DL d'achat avec ancien no de sÃĐquence -----#
            Delete [POQ] Where POHNUM=WPOHNUM & POPLIN=WPOPLIN & POQSEQ=GBIDI1
            UPDFLG=2
            Commit
          Else
            WMSG=num$([F:POQ]WIPTYP)-[F:POQ]WIPNUM-[F:POQ]ITMREF-"Erreur d'Update sur [ORD]"
            Call ECR_TRACE (WMSG,1) From GESECRAN
            Rollback
          Endif
        Else
          WMSG=WPOHNUM-num$(WPOPLIN)-num$(WSOQSEQ(JD))-"Erreur d'ÃĐcriture sur [POQ]"
          Call ECR_TRACE (WMSG,1) From GESECRAN
          Rollback
        Endif
      Else
        WPOQSEQ(I)=WSOQSEQ(JD)
        UPDFLG=2
      Endif
    Endif
  Endif
  #----- MÃ j liens DL de vente sur DL d'achat si nÃĐcessaire -----#
  If [F:POQ]LINOCNNUM<>WSOHNUM  |
&    [F:POQ]OCNLIN<>WSOPLIN  |
&    [F:POQ]OCNSEQ<>WSOQSEQ(JD)
    If !SIMFLG
      Trbegin [POQ]
        Update [POQ] Where POHNUM=WPOHNUM & POPLIN=WPOPLIN & POQSEQ=WPOQSEQ(I)
&                    With LINOCNNUM=WSOHNUM, OCNLIN=WSOPLIN, OCNSEQ=WSOQSEQ(JD)
        If !fstat
          [F:POQ]LINOCNNUM=WSOHNUM
          [F:POQ]OCNLIN   =WSOPLIN
          [F:POQ]OCNSEQ   =WSOQSEQ(JD)
          UPDFLG=1
        Else
          WMSG=WPOHNUM-num$(WPOPLIN)-num$(WPOQSEQ(I))-"Erreur d'Update sur [POQ]"
          Call ECR_TRACE (WMSG,1) From GESECRAN
        Endif
      Commit
    Else
      UPDFLG=1
    Endif
  Endif
  #----- MÃ j liens DL de vente sur DL d'achat si nÃĐcessaire -----#
  If [F:SOQ]POHNUM<>WPOHNUM     |
&    [F:SOQ]POPLIN<>WPOPLIN     |
&    [F:SOQ]POQSEQ<>WPOQSEQ(I)
    If !SIMFLG
      Trbegin [SOQ]
        Update [SOQ] Where SOHNUM=WSOHNUM & SOPLIN=WSOPLIN & SOQSEQ=WSOQSEQ(JD)
&                    With POHNUM=WPOHNUM, POPLIN=WPOPLIN, POQSEQ=WPOQSEQ(I)
        If !fstat
          [F:SOQ]POHNUM=WPOHNUM
          [F:SOQ]POPLIN=WPOPLIN
          [F:SOQ]POQSEQ=WPOQSEQ(I)
          If UPDFLG=0  UPDFLG=1 : Endif
        Else
          WMSG=WSOHNUM-num$(WSOPLIN)-num$(WSOQSEQ(JD))-"Erreur d'Update sur [SOQ]"
          Call ECR_TRACE (WMSG,1) From GESECRAN
        Endif
      Commit
    Else
      If UPDFLG=0  UPDFLG=1 : Endif
    Endif
  Endif
  #-----
  If UPDFLG
    WMSG =WPOHNUM-num$(WPOPLIN)-num$(WPOQSEQ(I))
    If UPDFLG=2  WMSG-="("+num$(GBIDI1)+")" : Endif
    WMSG-=WSOHNUM-num$(WSOPLIN)-num$(WSOQSEQ(JD))-"(1:1) DL achat-vente resynchronisÃĐes !"
    If UPDFLG=2  WMSG-="*" : Endif
    Call ECR_TRACE(WMSG,0) From GESECRAN
    NBCOR+=1
  Endif
Else
  WMSG=WSOHNUM-num$(WSOPLIN)-num$(WSOQSEQ(JD))-"Erreur de lecture sur [SOQ]"
  Call ECR_TRACE (WMSG,1) From GESECRAN
Endif
Return

#---------------------------------------------------#
# Ã  une DL d'achat correspond plusieurs DL de vente #
#---------------------------------------------------#
$PLUSIEURS
If !SIMFLG
  Call DEBTRANS From GLOCK
  Trbegin [POQ], [SOQ]
    #----- Sauvegarde buffer et suppression DL d'achat Ã  ÃĐclater -----#
    [F:POQ2]=[F:POQ]
    Delete [POQ] Where POHNUM=WPOHNUM & POPLIN=WPOPLIN & POQSEQ=WPOQSEQ(I) 
    #----- Si DL non soldÃĐe et ferme, suppression de l'encours -----#
    If [F:POQ2]LINSTA<>3 & [F:POQ2]WIPSTA=1
      [M:ORDK]MAJCOD="A"
      [M:ORDK]WIPTYP=[F:POQ]WIPTYP
      [M:ORDK]WIPNUM=[F:POQ]WIPNUM
      [M:ORDK]ITMREF=[F:POQ]ITMREF
      Call WIP From TRTWIP
      If GOK<1
        WMSG=WPOHNUM-num$(WPOPLIN)-num$(WPOQSEQ(I))-"Erreur mÃ j encours [ORD]"
        Call ECR_TRACE (WMSG,1) From GESECRAN
        Rollback : Return
      Endif
    Endif
    WPOQSEQ(I)=0
    #-----
    For K=JD To JF
      Raz UPDFLG
      If WQTESOQ(K)>=0
        #-----
        Read [SOQ] SOQ0=WSOHNUM;WSOPLIN;WSOQSEQ(K)
        If !fstat
          #----- CrÃĐation de la DL d'achat correspondant Ã  la DL de vente -----#
          [F:POQ]=[F:POQ2]
          If !find(WSOQSEQ(K),WPOQSEQ(0..I1-1))
            [F:POQ]POQSEQ=WSOQSEQ(K)
            [F:POQ]POQLNK=mid$("00000000",1,8-len(num$([F:POQ]POPLIN)))+num$([F:POQ]POPLIN)
&                        +mid$("00000000",1,8-len(num$([F:POQ]POQSEQ)))+num$([F:POQ]POQSEQ)
            [F:POQ]LINOCNNUM=WSOHNUM
            [F:POQ]OCNLIN   =WSOPLIN
            [F:POQ]OCNSEQ   =WSOQSEQ(K)
          Elsif !find(WSOQSEQ(K)-1,WPOQSEQ(0..I1-1))
            [F:POQ]POQSEQ=WSOQSEQ(K)-1
            [F:POQ]POQLNK=mid$("00000000",1,8-len(num$([F:POQ]POPLIN)))+num$([F:POQ]POPLIN)
&                        +mid$("00000000",1,8-len(num$([F:POQ]POQSEQ)))+num$([F:POQ]POQSEQ)
            [F:POQ]LINOCNNUM=WSOHNUM
            [F:POQ]OCNLIN   =WSOPLIN
            [F:POQ]OCNSEQ   =WSOQSEQ(K)
          Else
            [F:POQ]POQSEQ=WSOQSEQ(K)+1
            [F:POQ]POQLNK=mid$("00000000",1,8-len(num$([F:POQ]POPLIN)))+num$([F:POQ]POPLIN)
&                        +mid$("00000000",1,8-len(num$([F:POQ]POQSEQ)))+num$([F:POQ]POQSEQ)
            [F:POQ]LINOCNNUM=WSOHNUM
            [F:POQ]OCNLIN   =WSOPLIN
            [F:POQ]OCNSEQ   =WSOQSEQ(K)
          Endif
          #----- MÃ j liens DL d'achat sur DL de vente -----#
          Update [SOQ] Where SOHNUM=WSOHNUM & SOPLIN=WSOPLIN & SOQSEQ=WSOQSEQ(K)
&                    With POHNUM=WPOHNUM, POPLIN=WPOPLIN, POQSEQ=[F:POQ]POQSEQ
          If !fstat
            [F:SOQ]POHNUM=WPOHNUM
            [F:SOQ]POPLIN=WPOPLIN
            [F:SOQ]POQSEQ=[F:POQ]POQSEQ
            UPDFLG=1
          Else
            WMSG=WSOHNUM-num$(WSOPLIN)-num$(WSOQSEQ(K))-"Erreur d'Update sur [SOQ]"
            Call ECR_TRACE (WMSG,1) From GESECRAN
            GOK=0 : Break
          Endif
          #----- Calcul qtÃĐs commandÃĐes ------#
          If [F:POQ]QTYPUU>=[F:SOQ]QTY & K<JF
            [F:POQ2]QTYPUU-=[F:SOQ]QTY : [F:POQ]QTYPUU=[F:SOQ]QTY
            [F:POQ2]QTYUOM-=[F:SOQ]QTY : [F:POQ]QTYUOM=[F:SOQ]QTY
          Else
            Raz [F:POQ2]QTYPUU, [F:POQ2]QTYUOM
          Endif
          Call PCAL_QTY([F:POQ]QTYPUU,[F:POQ]PUU,[F:POQ]QTYSTU,[F:POQ]STU,
&                       [F:POQ]ITMREF,[F:POQ]BPSNUM,1,GBIDD1) From TRTACHQTE1 
          #----- Calcul qtÃĐs besoins pris en compte -----#
          If [F:POQ]RETQTYPUU>=[F:POQ]QTYPUU
            [F:POQ2]RETQTYPUU-=[F:POQ]QTYPUU : [F:POQ]RETQTYPUU=[F:POQ]QTYPUU
            [F:POQ2]RETQTYSTU-=[F:POQ]QTYSTU : [F:POQ]RETQTYSTU=[F:POQ]QTYSTU
          Else
            Raz [F:POQ2]RETQTYPUU, [F:POQ2]RETQTYSTU
          Endif
          #----- Calcul qtÃĐs rÃĐceptionnÃĐes -----#
          If [F:POQ]RCPQTYPUU>=[F:POQ]QTYPUU
            [F:POQ2]RCPQTYPUU-=[F:POQ]QTYPUU : [F:POQ]RCPQTYPUU=[F:POQ]QTYPUU
            [F:POQ2]RCPQTYSTU-=[F:POQ]QTYSTU : [F:POQ]RCPQTYSTU=[F:POQ]QTYSTU
          Else
            Raz [F:POQ2]RCPQTYPUU, [F:POQ2]RCPQTYSTU
          Endif
          #----- MÃ j flag ligne soldÃĐe -----#
          If [F:POQ]QTYPUU<=[F:POQ]RCPQTYPUU
            [F:POQ]LINCLEFLG=2
          Endif
          #----- Si DL non soldÃĐe et ferme, rÃĐcup cpteur pour crÃĐation encours -----#
          Raz [F:POQ]WIPNUM
          If [F:POQ]LINSTA<>3 & [F:POQ]WIPSTA=1
            #----- Chargement et contrÃīle du compteur des encours -----#
            Call GETSOC([F:POQ]POHFCY) From DEVSUB
            Call LECTCA(7,OK) From SUBTCA
            If fstat | !OK
              WMSG="Encours"-mess(64,199,1)
              Call ECR_TRACE(WMSG,1) From GESECRAN
              GOK=0 : Break
            Endif
            GWIP=[F:TCA]CODNUM(8)
            #-----
            Call NUMERO(GWIP,[F:POQ]PRHFCY,date$,"",[F:POQ]WIPNUM,GBIDI1) From SUBANM
            If GOK<1 | GBIDI1<>0
              WMSG =WPOHNUM-num$(WPOPLIN)-num$([F:POQ]POQSEQ)
              WMSG-=GWIP-mess(60,199,1)
              Call ECR_TRACE (WMSG,1) From GESECRAN
              GOK=0 : Break
            Else
              #----- CrÃĐation de l'encours -----#
              [M:ORDK]MAJCOD   ="C"
              [M:ORDK]WIPTYP   =[F:POQ]WIPTYP
              [M:ORDK]WIPSTA   =[F:POQ]WIPSTA
              [M:ORDK]WIPNUM   =[F:POQ]WIPNUM
              [M:ORDK]ITMREF   =[F:POQ]ITMREF
              [M:ORDK]ORIFCY   =[F:POQ]POHFCY
              [M:ORDK]STOFCY   =[F:POQ]PRHFCY
              [M:ORDK]PJT      =""
              [M:ORDK]BPRNUM   =[F:POQ]BPSNUM
              [M:ORDK]STRDAT   =[F:POQ]DEMRCPDAT
              [M:ORDK]ENDDAT   =[F:POQ]DEMENDDAT
              [M:ORDK]VCRTYP   =14
              [M:ORDK]VCRNUM   =[F:POQ]POHNUM
              [M:ORDK]VCRLIN   =[F:POQ]POPLIN
              [M:ORDK]VCRSEQ   =[F:POQ]POQSEQ
              [M:ORDK]EXTQTY   =[F:POQ]QTYSTU
              [M:ORDK]CPLQTY   =0
              [M:ORDK]ALLQTY   =0
              [M:ORDK]SHTQTY   =0
              [M:ORDK]FMI      =1
              [M:ORDK]MRPMES   =1
              [M:ORDK]ORIFCY   =[F:SOQ]STOFCY
              [M:ORDK]VCRTYPORI=2
              [M:ORDK]VCRNUMORI=[F:POQ]SOHNUM
              [M:ORDK]VCRLINORI=[F:POQ]SOPLIN
              [M:ORDK]VCRSEQORI=[F:POQ]SOQSEQ
              [M:ORDK]BOMALT    =0
              [M:ORDK]ORI       =1
              [M:ORDK]ABBFIL    ="POC"
              Call WIP From TRTWIP
              If GOK<1
                WMSG=WPOHNUM-num$(WPOPLIN)-num$([F:POQ]POQSEQ)-"Erreur mÃ j encours [ORD]"
                Call ECR_TRACE (WMSG,1) From GESECRAN
                GOK=0
              Endif 
            Endif
          Endif
          #----- Ecriture de la DL d'achat -----#
          If GOK
            Write [POQ]
            If !fstat
              If K=JD  WPOQSEQ(I)=[F:POQ]POQSEQ : Endif
              UPDFLG=1            
            Else
              WMSG=WPOHNUM-num$(WPOPLIN)-num$([F:POQ]POQSEQ)-"Erreur d'ÃĐcriture sur [POQ]"
              Call ECR_TRACE (WMSG,1) From GESECRAN
              GOK=0 : Break
            Endif
          Else
            Break 
          Endif
        Else
          WMSG=WSOHNUM-num$(WSOPLIN)-num$(WSOQSEQ(K))-"Erreur de lecture sur [SOQ]"
          Call ECR_TRACE (WMSG,1) From GESECRAN
        Endif
      Else
        WMSG =WSOHNUM-num$(WSOPLIN)-num$(WSOQSEQ(K))
        WMSG-="("+num$(WQTESOQ(K))+") DL vente qtÃĐ nÃĐgative !"
        Call ECR_TRACE (WMSG,1) From GESECRAN
      Endif
      #-----
      If UPDFLG
        WMSG =WPOHNUM-num$(WPOPLIN)-num$([F:POQ]POQSEQ)
        WMSG-=WSOHNUM-num$(WSOPLIN)-num$(WSOQSEQ(K))-"(N:1) DL achat-vente resynchronisÃĐes !"
        Call ECR_TRACE(WMSG,0) From GESECRAN
        NBCOR+=1
      Endif
    Next K
  If GOK  Commit Else  Rollback : Endif
Else
  For K=JD To JF
    If WQTESOQ(K)>=0
      If !find(WSOQSEQ(K),WPOQSEQ(0..I1-1))
        [F:POQ]POQSEQ=WSOQSEQ(K)
      Elsif !find(WSOQSEQ(K)-1,WPOQSEQ(0..I1-1))
        [F:POQ]POQSEQ=WSOQSEQ(K)-1
      Else
        [F:POQ]POQSEQ=WSOQSEQ(K)+1
      Endif
      WMSG =WPOHNUM-num$(WPOPLIN)-num$([F:POQ]POQSEQ)
      WMSG-=WSOHNUM-num$(WSOPLIN)-num$(WSOQSEQ(K))-"(N:1) DL achat-vente resynchronisÃĐes !"
      Call ECR_TRACE(WMSG,0) From GESECRAN
      NBCOR+=1
    Else
      WMSG =WSOHNUM-num$(WSOPLIN)-num$(WSOQSEQ(K))
      WMSG-="("+num$(WQTESOQ(K))+") DL vente qtÃĐ nÃĐgative !"
      Call ECR_TRACE (WMSG,1) From GESECRAN
    Endif
  Next K
Endif
Return

#---------------------------------------------------#
# Ã  une DL d'achat ne correspond aucune DL de vente #
#---------------------------------------------------#
$ORPHELIN_POQ
WMSG=WPOHNUM-num$(WPOPLIN)-num$(WPOQSEQ(I))-WSOHNUM-num$(WSOPLIN)-"DL achat orpheline !"
Call ECR_TRACE(WMSG,1) From GESECRAN
Return

#---------------------------------------------------#
# Ã  une DL de vente ne correspond aucune DL d'achat #
#---------------------------------------------------#
$ORPHELIN_SOQ
WMSG=WPOHNUM-num$(WPOPLIN)-WSOHNUM-num$(WSOPLIN)-num$(WSOQSEQ(JD))-"DL vente orpheline !"
Call ECR_TRACE(WMSG,1) From GESECRAN
Return
