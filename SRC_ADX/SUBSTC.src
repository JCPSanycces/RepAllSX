######################################################################################
## Etiquette ajoutée par le superviseur (écran STC1) 15/11/2012 14:36:45 (SR)
######################################################################################
Subprog AM_UOM(VALEUR)
Variable Char    VALEUR()
Local Integer WLIMOK,I,NOL
NOL = nolign-1
Raz WLIMOK
If [M:STC1]DIRCLCMOD(NOL) <> 5 : End : Endif
If [M:STC1]WSTCSEQ(NOL) <> 0
    For I=0 To [M:STCW]NBLIG-1
      If [M:STCW]WSTCSEQ(I)=[M:STC1]WSTCSEQ(NOL)
        WLIMOK = 1
        Break
      Endif
    Next
Endif
If WLIMOK = 0 &  GREP = "M"
  Filter [STCB] Where [F:STCB]STCNUM=[M:STC1]STCNUM and [F:STCB]STCLIN=[M:STC1]STCLIN(NOL)
   Look [F:STCB]STCB0 First
   If !fstat : WLIMOK = 1 : Endif
   Filter [F:STCB]
Endif
If WLIMOK
   Call MESSAGE(mess(606,199,1)) From GESECRAN # Vérifiez les barèmes
Endif
[M:STC1]WLIMOK(NOL) = WLIMOK
End


