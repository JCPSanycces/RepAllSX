#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion objet STC
########################################################################
# SUBSTC : Gestion des structures de coût             MUARN 07/05/2013 #
# Issue 70985 - 2012-02-15 by MUARN : Landed cost                      #
########################################################################

$ACTION
Case ACTION
  When "DEFLIG"        : Gosub DEFLIG
  When "VALLIG"        : Gosub VALLIG
  When "OUVRE"         : Gosub OUVRE
  When "FILTRE"        : Gosub FILTRE
  When "VERIF_CRE"     : Gosub VERIF
  When "RAZCRE"        : Gosub RAZCRE
  When "RAZDUP"        : Gosub RAZDUP
  When "INICRE"        : Gosub INICRE
  When "CREATION"      : Gosub CREATION
  When "APRES_CRE"     : Gosub RELIT
  #When "APRES_MOD"     : Gosub RELIT
  When "ABANDON"       : Raz [M:STCW]
  When "LIENS"         : Gosub LIENS
  When "VERIF_MOD"     : Gosub VERIF
  When "MODIF"         : Gosub MODIF
  When "APRES_MOD"     : Gosub APRES_MOD
  When "ANNULE"        : Gosub ANNULE
  When "DEFLIG"        : Gosub DEFLIG
  When "INICRE_LIG"    : Gosub INILIG
  When "INIMOD_LIG"    : Gosub INILIG
  #When "APRES_MODIF"   : Gosub GRISE
  When "CHANGE"        : Call CHANGE_AXX ("COSTSTCL",[L]SUPP(0),[L]OCODE,[L]SUPP(0),[L]NCODE) From TRTX3TEX
  When "FIN"           : If clalev([M:STCW])<>0 Raz [M:STCW] Endif
 When Default
Endcase
Return


#########################################################################
$OUVRE
Local Integer SAVSTCLIN
Local Char LSTCNUM

If !clalev([F:TCA])    Local File TABCOUAFF   [TCA]  : Endif
If !clalev([F:FCS])    Local File FRECST      [FCS]  : Endif
If !clalev([F:STCL])   Local File COSTSTCL    [STCL]  : Endif
Gosub DECLARE From TABLEAUX

# Issue 95741 - 2014-01-10 by MUARN : dossier mono-leg
GFCYDEF(0)=GFCYDEF(6)
GFCY      =GFCYDEF(6)
#----- Chargement des globales référentiels, comptes et sections de la société -----#
Call GETCPY(GFCY,"",0,"") From TRTX3CPT

#----- Compteur des structure de couts -----#
Call LECTCA(9,OK) From SUBTCA
If fstat | !OK
  GMESSAGE=mess(58,105,1)-mess(9,14,1)-mess(250,199,1) : Return
Endif
GMANCOU=[F:TCA]MANCOU(5) : GCODNUM=[F:TCA]CODNUM(5)
If clalev([M:STCW])=0
   Local Mask STC2W   [STCW]
Endif

Return
#########################################################################
$RAZCRE
[M:STC1]ENAFLG=2
Affzo [M:STC1]ENAFLG
Return
#########################################################################
$RAZDUP
#Sauvegarde du stcnum avant duplication
LSTCNUM = [M:STC1]STCNUM
[M:STC1]WSTCNUM=[M:STC1]STCNUM

Return
#########################################################################
$INICRE
Local Integer STAT
If GMANCOU<>2 | (GMANCOU=2 & vireblc([M:STC1]STCNUM,2)="")
  Call NUMERO(GCODNUM,GFCY,date$,"",[M:STC1]STCNUM,STAT) From SUBANM
  If GOK<0
    Return
  Elsif GOK<1 | STAT<>0
    Local Char MESSA(80)
    GMESSAGE=mess(60,199,1)-"("+GCODNUM+") : "
    Gosub MESSAGE From SUBANM
    GMESSAGE-=MESSA : GOK=0 : GERR=1
    Return
  Endif
  [F:STCH]STCNUM=[M:STC1]STCNUM
Endif

Return
#########################################################################
$DEFLIG
#--- Définition du fichier des lignes
# Critère de lecture             (CRIT)
# Nom et abréviation du fichier  (FICLIG,ABLIG)
# Zone numéro de ligne           (ZONLIG)
Default Mask [STC1]
Default File [STCL]
CRIT = 'STCNUM="'+[M:STC1]STCNUM+'"'
FICLIG = "COSTSTCL" : ABLIG  = "STCL"
ZONLIG = "STCLIN"
Return
#########################################################################
$LIENS
[M:STC1]WSTCNUM = [M:STC1]STCNUM
Gosub LIENS From TABLEAUX
For I=0 To [M:STC1]NBLIG-1
  [M:STC1]WSTCSEQ(I) = I
  Gosub GRISE
Next
Return
#########################################################################
######################################################################
$CREATION
Gosub CREATION From TABLEAUX
If GOK < 1 Return Endif
#--- maj de la table des libéllés traduisibles
Call MAJTEXTRA([M:STC1]STCDESAXX,"COSTSTCH","STCDESAXX",[M:STC1]STCNUM,"") From ATEXTRA
Return

######################################################################
$MODIF
Gosub MODIF From TABLEAUX
If GOK < 1 Return Endif
#--- maj de la table des libéllés traduisibles
Call MAJTEXTRA([M:STC1]STCDESAXX,"COSTSTCH","STCDESAXX",[M:STC1]STCNUM,"") From ATEXTRA
Return

######################################################################
$FILTRE
Default File [STCH]
Return
######################################################################
$ANNULE
Gosub ANNULE From TABLEAUX
If GOK < 1 Return Endif
#--- maj de la table des libéllés traduisibles
Delete [AXX] Where CODFIC="COSTSTCH" & IDENT1=[F:STCH]STCNUM
Return

######################################################################
$APRES_MOD

Local Integer LRET
Call CONTROL_CSTSTC([M:STC1]STCNUM,"STC",LRET) From STCCTL

#Gosub LIENS From TABLEAUX
Gosub RELIT
Return

######################################################################
$RELIT
Gosub LIENS
Raz [M:STCW]
Return

######################################################################
$INILIG
#Alimentation structure
[F:STCL]STCNUM = [F:STCH]STCNUM

Return
#########################################################################
Subprog DELSTCB(LNOL)
Value Integer LNOL  #numéro de ligne dans le document

Filter [STCB] Where [F:STCB]STCNUM = [M:STC1]STCNUM and [F:STCB]STCLIN = LNOL
  For [STCB]
    Readlock [STCB] Curr
    # Suppression des lignes de barêmes
    Delete [STCB]
    If fstat GOK=0 : Call FSTA("STCB") From GLOCK : Break : Endif
  Next
Filter [STCB]
End
#########################################################################
Subprog DUPSTCB(LSTCNUM,LNOL)
Value Char LSTCNUM
Value Integer LNOL  #numéro de ligne dans le document


Filter [STCB] Where [F:STCB]STCNUM = LSTCNUM and [F:STCB]STCLIN = LNOL
  For [STCB]
    [F:STCB]STCNUM = [M:STC1]STCNUM
    Write [STCB]
    If fstat
       GOK = 0 : Call FSTA("STCB") From GLOCK
    Endif
  Next
Filter [STCB]
End

#########################################################################
Subprog ADDSTCB(LNOL,TRTLIG,NOL)
Value Integer LNOL  #numéro de la ligne dans le document
Value Char TRTLIG   #type d'action
Value Integer NOL   #numéro de ligne dans le tableau (nolign)

Local Integer I
Local Integer SAVSTCLIN
SAVSTCLIN = 0
If dim([M:STCW]NBLIG)>0
  #Enregistrement de l'écran de travail
  If [M:STCW]NBLIG>0
    For I=0 To [M:STCW]NBLIG-1
         # nouvelle ligne : init du numéro de ligne sur les enr liés
         If TRTLIG ="C" & [M:STCW]WSTCSEQ(I)=[M:STC1]WSTCSEQ(NOL) :  [M:STCW]WSTCLIN(I)=LNOL : Endif
         If [M:STCW]WSTCLIN(I)<>0 & [M:STCW]WSTCLIM(I) <> 0
            #suppression de toutes les lignes de baréme correspondant à la ligne de charge
            If [M:STC1]STCLIN(NOL)=[M:STCW]WSTCLIN(I) & SAVSTCLIN <> [M:STCW]WSTCLIN(I)
              Call DELSTCB([M:STCW]WSTCLIN(I))
            Endif
            SAVSTCLIN = [M:STCW]WSTCLIN(I)
            #enregistrement de toutes les lignes de bareme correspondant à la ligne de charge
            If [M:STC1]WSTCSEQ(NOL)=[M:STCW]WSTCSEQ(I) & [M:STC1]WSTCSEQ(NOL)<>0
              [F:STCB]STCNUM = [M:STC1]STCNUM
              [F:STCB]STCLIN = [M:STCW]WSTCLIN(I)
              [F:STCB]STCLIM = [M:STCW]WSTCLIM(I)
              [F:STCB]MINLIM = [M:STCW]WMINLIM(I)
              [F:STCB]MAXLIM = [M:STCW]WMAXLIM(I)
              [F:STCB]UNTPRI = [M:STCW]WUNTPRI(I)

              Write [STCB]
              If fstat
                GOK = 0 : Call FSTA("STCB") From GLOCK
              Endif
            Endif
         Endif
  Next
 Endif
Endif

End
#########################################################################
$VALLIG
#----------------------------------------------------------------#
# En création     : TRTLIG = "C" et SIGN = +1 (après le write)   #
# En modification : TRTLIG = "M" et SIGN = -1 (avant le rewrite) #
#                                   SIGN = +1 (après le rewrite) #
# En annulation   : TRTLIG = "A" et SIGN = -1 (avant le delete)  #
#----------------------------------------------------------------#

Local Integer NOL
NOL  = nolign-1

If GOK < 1 : Return : Endif
Local Integer WRETOUR
Local Char WNUMTEX (12)

If TRTLIG = "A"
    Call DELSTCB([F:STCL]STCLIN)
   #-----
Else If TRTLIG = "C"
    If GREP="C" | ((GREP="D"|GREP="M") &[M:STCW]NBLIG>0)
      Call ADDSTCB([M:STC1]STCLIN(NOL),TRTLIG,NOL)
    Else If GREP="D" & [M:STCW]NBLIG=0  :Call DUPSTCB(LSTCNUM,[M:STC1]STCLIN(NOL)) :Endif
    Endif
Else If TRTLIG = "M" & SIGN = +1
  Call ADDSTCB([M:STC1]STCLIN(NOL),TRTLIG,NOL)
Endif
Endif
Endif
Return
######################################################################
$GRISE

Case [M:STC1]DIRCLCMOD(I)
  When 1    #prix net
    Actzo [M:STC1]PRINETPRC(I)
    Grizo [M:STC1]UNTPRI(I)
    Grizo [M:STC1]CUR(I)
    Grizo [M:STC1]QTY(I)
    Grizo [M:STC1]BAS(I)
    Grizo [M:STC1]UOM(I)
    Grizo [M:STC1]WEIPRC(I)
    Grizo [M:STC1]LIM(I)
    [M:STC1]LIM(I) = "191"
    Grizo [M:STC1]FORFCS(I)
  When 2    #forfait
    Grizo [M:STC1]PRINETPRC(I)
    Actzo [M:STC1]UNTPRI(I)
    Actzo [M:STC1]CUR(I)
    Grizo [M:STC1]QTY(I)
    Grizo [M:STC1]BAS(I)
    Grizo [M:STC1]UOM(I)
    Grizo [M:STC1]WEIPRC(I)
    Grizo [M:STC1]LIM(I)
    [M:STC1]LIM(I) = "191"
    Grizo [M:STC1]FORFCS(I)
  When 3    #montant unitaire
    Grizo [M:STC1]PRINETPRC(I)
    Actzo [M:STC1]UNTPRI(I)
    Actzo [M:STC1]CUR(I)
    Diszo [M:STC1]QTY(I)
    Actzo [M:STC1]BAS(I)
    Actzo [M:STC1]UOM(I)
    Grizo [M:STC1]WEIPRC(I)
    Grizo [M:STC1]LIM(I)
    [M:STC1]LIM(I) = "191"
    Grizo [M:STC1]FORFCS(I)
  When 4    #Montant par tranche
    Grizo [M:STC1]PRINETPRC(I)
    Actzo [M:STC1]UNTPRI(I)
    Actzo [M:STC1]CUR(I)
    Actzo [M:STC1]QTY(I)
    Actzo [M:STC1]BAS(I)
    Actzo [M:STC1]UOM(I)
    Grizo [M:STC1]WEIPRC(I)
    Grizo [M:STC1]LIM(I)
    [M:STC1]LIM(I) = "191"
    Grizo [M:STC1]FORFCS(I)
  When 5    #Montant par barême
    Grizo [M:STC1]PRINETPRC(I)
    Grizo [M:STC1]UNTPRI(I)
    Actzo [M:STC1]CUR(I)
    Grizo [M:STC1]QTY(I)
    Actzo [M:STC1]BAS(I)
    Actzo [M:STC1]UOM(I)
    Grizo [M:STC1]WEIPRC(I)
    Actzo [M:STC1]LIM(I)
    [M:STC1]LIM(I) = "81"
    Grizo [M:STC1]FORFCS(I)
  When 6    #Montant pondéré
    Grizo [M:STC1]PRINETPRC(I)
    Actzo [M:STC1]UNTPRI(I)
    Actzo [M:STC1]CUR(I)
    Grizo [M:STC1]QTY(I)
    Actzo [M:STC1]BAS(I)
    Actzo [M:STC1]UOM(I)
    Actzo [M:STC1]WEIPRC(I)
    Grizo [M:STC1]LIM(I)
    [M:STC1]LIM(I) = "191"
    Grizo [M:STC1]FORFCS(I)
  When 7    #Formule
    Grizo [M:STC1]PRINETPRC(I)
    Grizo [M:STC1]UNTPRI(I)
    Grizo [M:STC1]CUR(I)
    Grizo [M:STC1]QTY(I)
    Grizo [M:STC1]BAS(I)
    Grizo [M:STC1]UOM(I)
    Grizo [M:STC1]WEIPRC(I)
    Grizo [M:STC1]LIM(I)
    [M:STC1]LIM(I) = "191"
    Actzo [M:STC1]FORFCS(I)
  When Default
Endcase
Affzo [M:STC1]LIM(I)
Return

######################################################################
$EFFACE
Case [M:STC1]DIRCLCMOD(nolign-1)
  When 1    #prix net
    Raz [M:STC1]UNTPRI(nolign-1),[M:STC1]CUR(nolign-1),[M:STC1]QTY(nolign-1),[M:STC1]BAS(nolign-1)
    Raz [M:STC1]UOM(nolign-1),[M:STC1]WEIPRC(nolign-1),[M:STC1]LIM(nolign-1),[M:STC1]FORFCS(nolign-1)
  When 2    #forfait
    Raz [M:STC1]PRINETPRC(nolign-1),[M:STC1]QTY(nolign-1),[M:STC1]BAS(nolign-1),[M:STC1]UOM(nolign-1)
    Raz [M:STC1]WEIPRC(nolign-1),[M:STC1]LIM(nolign-1),[M:STC1]FORFCS(nolign-1)
  When 3    #montant unitaire
    Raz [M:STC1]PRINETPRC(nolign-1),[M:STC1]BAS(nolign-1)
    Raz [M:STC1]WEIPRC(nolign-1),[M:STC1]LIM(nolign-1),[M:STC1]FORFCS(nolign-1)
  When 4    #Montant par tranche
    Raz [M:STC1]PRINETPRC(nolign-1),[M:STC1]WEIPRC(nolign-1),[M:STC1]LIM(nolign-1),[M:STC1]FORFCS(nolign-1)
  When 5    #Montant par barême
    Raz [M:STC1]PRINETPRC(nolign-1),[M:STC1]UNTPRI(nolign-1),[M:STC1]QTY(nolign-1),[M:STC1]WEIPRC(nolign-1)
    Raz [M:STC1]FORFCS(nolign-1)
  When 6    #Montant pondéré
    Raz [M:STC1]PRINETPRC(nolign-1),[M:STC1]LIM(nolign-1),[M:STC1]FORFCS(nolign-1)
  When 7    #Formule
    Raz[M:STC1]PRINETPRC(nolign-1),[M:STC1]UNTPRI(nolign-1),[M:STC1]CUR(nolign-1),[M:STC1]QTY(nolign-1)
    Raz[M:STC1]BAS(nolign-1),[M:STC1]UOM(nolign-1),[M:STC1]WEIPRC(nolign-1),[M:STC1]LIM(nolign-1)
  When Default
Endcase

Return
######################################################################
$VERIF
If [M:STC1]NBLIG=0
  GMESSAGE = mess(101,102,1) : # Il faut au moins une ligne
  mkstat =1
Else
  I = find(1,[M:STC1]WLIMOK(0..[M:STC1]NBLIG-1))
  If I
    GMESSAGE = mess(605,199,1) - num$(I) # Barèmes non valides ligne :
    mkstat = 1
  Endif
Endif
Return

