## Etiquette ajoutée par le superviseur (écran STC1) 06/12/2012 11:09:58 (MAE)
######################################################################################
Subprog AM_BAS(VALEUR)
Variable Integer VALEUR

If !clalev([F:TUN])    Local File TABUNIT   [TUN]  : Endif
If (VALEUR = 2 or VALEUR =3) and [M:STC1]UOM(nolign-1) <> ""
  Read [TUN]TUN0=[M:STC1]UOM(nolign-1)
  If VALEUR = 2 and [F:TUN]UOMTYP <> 3
    Call MESSAGE(mess(471,199,1)) From GESECRAN # Pas une unité de poids
  Else If VALEUR = 3 and [F:TUN]UOMTYP <> 4
    Call MESSAGE(mess(471,199,1)) From GESECRAN # Pas une unité de poids
  Endif
Endif
Endif

End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran STC1) 06/12/2012 11:47:31 (MAE)
######################################################################################
Subprog C_UOM(VALEUR)
Variable Char    VALEUR()
If !clalev([F:TUN])    Local File TABUNIT   [TUN]  : Endif
Read [TUN]TUN0=VALEUR
If [M:STC1]BAS(nolign-1) = 2  #unité de volume
  If [F:TUN]UOMTYP <> 3
    Call MESSAGE(mess(471,199,1)) From GESECRAN # Pas une unité de poids
    mkstat = 2
  Endif
 Else If [M:STC1]BAS(nolign-1) = 3  #unité de poids
  If [F:TUN]UOMTYP <> 4
      Call MESSAGE(mess(471,199,1)) From GESECRAN # Pas une unité de volume
      mkstat = 2
  Endif
 Endif
Endif
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran STC1) 21.03.2013 14:48:30 (SR)
######################################################################################
Subprog C_ENAFLG(VALEUR)
Variable Integer VALEUR
# Si on tente de rendre inactive une charge
If VALEUR = 1 & [M:STC1]ENAFLG = 2
  Filter [F:ITG] Where STCNUM = [M:STC1]STCNUM
  Read [F:ITG]ITG0 First
  If !fstat
      #Structure de coût exploitée par catégorie article nnn : Modification impossible
      GMESSAGE=func AFNC.MES3(mess(614,199,1),mess(615,199,1),mess(3,2749,1),[F:ITG]STOFCY+"/"+[F:ITG]TCLCOD)
      mkstat = 1
      End
  Endif
  Filter [F:ITG]
  Filter [F:ITM] Where STCNUM = [M:STC1]STCNUM
  Read [F:ITM]ITM0 First
  If !fstat
      # Struture de coût exploité par  article xxxx : Modification impossible.
      GMESSAGE=func AFNC.MES3(mess(614,199,1),mess(615,199,1),mess(14,195,1),[F:ITM]ITMREF)
      mkstat = 1
      End
  Endif
  Filter [F:ITM]
  Filter [F:ITP] Where STCNUM = [M:STC1]STCNUM
  Read [F:ITP]ITP0 First
  If !fstat
      # Struture de coût exploitée par article-Fournisseur xxxx/xxxx : Modification impossible.
      GMESSAGE=func AFNC.MES3(mess(614,199,1),mess(615,199,1),mess(23,198,1),[F:ITP]ITMREF+"/"+[F:ITP]BPSNUM)
      mkstat = 1
      End
  Endif
  Filter [F:ITP]
Endif
End


