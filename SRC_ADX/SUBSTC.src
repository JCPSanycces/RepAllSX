######################################################################################
Subprog AS_STCNUM(VALEUR)
Variable Char    VALEUR()
If (GREP = "C" | GREP = "D") & GMANCOU <> 2 : mkstat = 2 : Endif
End

######################################################################################
# Interdire la modification d'un code charge
Subprog AS_FCSCOD(VALEUR)
Variable Char    VALEUR()
If  VALEUR <> "" &  GREP<> "C" : mkstat = 2 : End : Endif
End

# Issue 94299 - 2013-11-15 by SR : contrôle d'unicité
######################################################################################
Subprog C_FCSCOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:STC1]FCSCOD(0..[M:STC1]NBLIG-1)) From OBJDIV
If mkstat : End : Endif
End

######################################################################################
Subprog AM_FCSCOD(VALEUR)
Variable Char    VALEUR()
Local Integer I
[M:STC1]FCSNAT(nolign-1)=[F:FCS]FCSNAT
[M:STC1]DIRCLCMOD(nolign-1)=[F:FCS]DIRCLCMOD
[M:STC1]STKVLT(nolign-1)=[F:FCS]STKVLT
[M:STC1]HGHBKT(nolign-1)=[F:FCS]HGHBKT
[M:STC1]LIMTYP(nolign-1)=[F:FCS]LIMTYP
[M:STC1]DOCCHGTYP(nolign-1)=[F:FCS]DOCCHGTYP
[M:STC1]CHGTYP(nolign-1)=[F:FCS]CHGTYP
If [F:FCS]DIRCLCMOD = 3
    [M:STC1]QTY(nolign-1) = 1
Elsif [F:FCS]DIRCLCMOD = 5
    #[M:STC1]LIM(nolign-1) = 2
Endif
#Si montant pondéré, la quantité est à 1 et le champ est grisé
If [F:FCS]DIRCLCMOD=6
  [M:STC1]QTY(nolign-1) = 1
  Grizo[M:STC1]QTY(nolign-1)
Else
  Affzo [M:STC1]QTY(nolign-1)
Endif
Affzo [M:STC1]FCSNAT(nolign-1)
Affzo [M:STC1]DIRCLCMOD(nolign-1)
Affzo [M:STC1]STKVLT(nolign-1)
#Affzo [M:STC1]QTY(nolign-1)
Affzo [M:STC1]LIM(nolign-1)
Affzo [M:STC1]LIMTYP(nolign-1)
Affzo [M:STC1]DOCCHGTYP(nolign-1)
Affzo [M:STC1]CHGTYP(nolign-1)
Affzo [M:STC1]HGHBKT(nolign-1)
I = nolign-1
Gosub GRISE
End


