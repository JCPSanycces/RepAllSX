##########################################################################################################
#-------------------------------------#
# Hard copy des écrans de paramétrage #
#-------------------------------------#
$COP_ECRAN
Local Char WINT(20)(2) 
Local Char WTIT(100)
Local Char WMSK(GLONAMK)(8)
Local Char WABR(GLONABR)(2)

  #-----
  Call TEXTFIC("CRMTRS", "CTRNUM", 2, WINT(0)) From OBJDIV
  Call TEXTFIC("CRMTRS", "ACSCOD", 2, WINT(1)) From OBJDIV
  WTIT = WINT(0)+" : "+[M:CBA0]CTRNUM-[M:CBA0]DESAXX-WINT(1)+" : "+[M:CBA0]ACSCOD
  WMSK(0) = "CBA7"
  WMSK(1) = "CBA1"
  WMSK(2) = "CBA8"
  WMSK(3) = "CBA2"
  WMSK(4) = "CBA3"
  WMSK(5) = "CBA4"
  WMSK(6) = "CBA9"
  WMSK(7) = "CBA6"
  Call PRTSCR(WMSK, WABR, WTIT, 0, 0) From ATRTX3
  OK = 0 : # Pour ne pas imprimer tout de suite !
Return

##########################################################################################################
# Pour exécution de la validation des transactions en gestion de patch #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

Local Integer TYP

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  If [F:ADS]MODULE(12) <> 2 Then
    End
  Endif
  TYP = 1
  Gosub GENPATCH From FUNCRMTRS
End

##########################################################################################################
# Pour éxécution de la validation des transactions en gestion de dossier #
#                par l'utilitaire de revalidation DOSWWW                 #
#                à partir du dictionnaire des types de transaction (ATN) #
##########################################################################
Subprog GENDOS(APPLI)
Value Char    APPLI

Local Integer TYP

  TYP = 1
  Gosub GENDOS From FUNCRMTRS
End

##########################################################################################################
# Pour exécution de la copie en masse depuis le menu : #
# Utilitaires - Dictionnaire - Copie transactions      #
########################################################
$TRTCOP
Local Integer MODULE
Local Integer TYP
Local Char CODTAB(GLONTRS)

  MODULE = 13
  TYP = 1
  CODTAB = TABLE
  #-----
  Gosub OUVRE_COPTRS From SELTRS
  Gosub EXEC_COPTRS From SELTRS
  Gosub FERME_COPTRS From SELTRS
Return
