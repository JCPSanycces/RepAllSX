##########################################################################################################
Subprog B3_OPPFIEPOS(VALEUR)
Variable Decimal VALEUR

Local Integer ILIGNESAVE
Local Integer ILIGNE
Local Integer INUMERO
Local Integer IBCONTINUE

  ILIGNESAVE = nolign
  ILIGNE = nolign-1
  IBCONTINUE = 1
  ILIGNE = ILIGNE + 1
  INUMERO = VALEUR + 1
  While IBCONTINUE = 1
    If ILIGNE > dim([M:CBA4]OPPFIEPOS) Then
      IBCONTINUE = 0
