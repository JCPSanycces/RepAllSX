#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion objet CBA
##########################################################################################################
# SUBCBA : Transactions de saisie plan de travail action co       CRM janvier 2007
#---------------------------------------------------------------------#
# Tables mises à jour : [F:CTR]CRMTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                       [F:AWB]AWINBRO  Table des browsers            #
#                       [F:AWT]AWINBOUT Table des boutons             #
#                                                                     #
# Génération de 1 écran de saisie à partir des écrans de base         #
# CRMAGD0                                                             #
# CRMAGD1                                                             #
# CRMAGD2                                                             #
# CRMAGD3                                                             #
# CRMAGD4                                                             #
# CRMAGD6                                                             #
# CRMAGD7                                                             #
# CRMAGD8                                                             #
#                                                                     #
# Nom des écrans générés : WLxyyyz                                    #
#                            x = 1 pour agenda action co              #
#                            x = 2 pour demandes                      #
#                            x = 3 pour interventions                 #
#                            x = 4 pour plan de travail               #
#                            x = 5 pour agenda support                #
#                                                                     #
#                          yyy = nom de la transaction (CTRNUM)       #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                0, 1, 2, 3, 4 (menu local 3050)      #
#######################################################################
Call OBJET("CBA",GBIDC1,GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "FILTRE"      : Gosub FILTRE
    When "EFFMASK"     : [M:CBA0]CTRTYP = 1
    When "SETBOUT"     : Gosub SETBOUT
    When "EXEBOUT"     : Gosub EXEBOUT
    When "LIENS"       : Gosub LIENS
    When "RAZCRE"      : Gosub RAZCRE
    When "APRES_MODIF" : Gosub APRES_MODIF
    When "INICRE"      : Gosub INICRE
    When "CREATION"    : Gosub CREATION
    When "APRES_CRE"   : Gosub APRES_CRE
    When "INIMOD"      : Gosub INIMOD
    When "MODIF"       : Gosub MODIF
    When "APRES_MOD"   : Gosub APRES_MOD
    When "ANNULE"      : Gosub ANNULE
    When "AV_IMPRIME"  : Gosub COP_ECRAN
    When "FERME"       : Gosub FERME
    When Default
  Endcase
Return

##########################################################################################################
#-------------------------------------#
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
Local Char APPLI
Local Integer IINIMODTRS   # FGR 29/01/2010 : X3SUIVI62022

  APPLI = nomap
Return

##########################################################################################################
$FERME
Return

##########################################################################################################
#-------------------------------------------------------#
# Ne traiter que les transactions de type agenda action commercial#
#-------------------------------------------------------#
$FILTRE
  FILTSUP = "[F:CTR]CTRTYP=1"
Return

##########################################################################################################
#----------------------------------------------#
# Désactivation bouton "Validation" et "Copie" #
#----------------------------------------------#
$SETBOUT  
  If GREP <> "" or !CLECUR Then
    Call VIREBOUT(CHAINE, "12") From GOBJET
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT  
  Case REP  
    When "1"
      Call DEBTRANS From GLOCK
      Trbegin ADOVAL  
      Gosub TRT_ECRAN
      If GOK < 1 Then
        Rollback
      Else
        Commit
      Endif
    When Default  
  Endcase  
Return  

##########################################################################################################
#------------------------------------------------------------#
# Après lecture de chaque enregistrement chargement de NBAXE #
#------------------------------------------------------------#
$LIENS
  Gosub LOADDATA From SUBCBAB
Return

##########################################################################################################
#---------------------------------------#
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
  [M:CBA0]CTRTYP = 1
  [M:CBA0]ENAFLG = 2
  Gosub ONGLETS_INIT From SUBCBAB
  Gosub COLFIX_INIT From SUBCBAB
  Gosub CHAMPS_INIT From SUBCBAB
  Gosub VALINITIAL_INIT From SUBCBAB
  Gosub PE_CRMTRS From SUBCRMTRS
  Gosub REORGANISE From SUBCBAB
  Gosub AFF_FENETRE From SUBCBAB
Return

##########################################################################################################
#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
  Case COUZON
    When Default
      Gosub PE_CRMTRS From SUBCRMTRS
  Endcase
Return

##########################################################################################################
#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
  Raz [F:CTV]
  Gosub CHARGE_ATEXTRA
  Gosub ONGLETS_ENREG From SUBCBAB
  Gosub COLFIX_ENREG From SUBCBAB
  Gosub CHAMPS_ENREG From SUBCBAB
  Gosub VALINITIAL_ENREG From SUBCBAB
  Gosub PE_CRMTRS From SUBCRMTRS
Return

##########################################################################################################
$CREATION
  [F:CTV] = [F:CTR]
  [F:CTV] = [M:CBA4]
  Gosub PE_CRMTRS From SUBCRMTRS
  Write [CTV]
  If fstat <> 0 Then
    GOK = 0  # FGR 28/01/2010 : X3SUIVI62022
    GERR = 2
    #Erreur lors de l'écriture de la table des valeurs de transaction de saisie +" (CRMTRSVAL)".
    GMESSAGE = mess(521,177,1) - "(CRMTRSVAL)"
    Return
  Endif
  Gosub TRT_ECRAN
Return

##########################################################################################################
$APRES_CRE
  Gosub REORGANISE From SUBCBAB
  Gosub AFF_FENETRE From SUBCBAB
Return

##########################################################################################################
#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
$INIMOD
  Gosub CHARGE_ATEXTRA
  IINIMODTRS = 0  # FGR 28/01/2010 : X3SUIVI62022
  Read [CTV]CTV0=[F:CTR]CTRTYP;[F:CTR]CTRNUM
  If fstat <> 0 Then
    # FGR 28/01/2010 : X3SUIVI62022 (début)
    IINIMODTRS = 1
    #GOK = 0  # FGR 28/01/2010 : X3SUIVI62022
    #GERR = 2
    #Erreur lors de la lecture de la table des valeurs de transaction de saisie +" (CRMTRSVAL)".
    #GMESSAGE = mess(521,177,1) - "(CRMTRSVAL)"
    #Return
    # FGR 28/01/2010 : X3SUIVI62022 (fin)
  Endif
  Gosub ONGLETS_ENREG From SUBCBAB
  Gosub COLFIX_ENREG From SUBCBAB
  Gosub CHAMPS_ENREG From SUBCBAB
  Gosub VALINITIAL_ENREG From SUBCBAB
  Gosub PE_CRMTRS From SUBCRMTRS
Return

##########################################################################################################
$MODIF
  [F:CTV] = [F:CTR]
  [F:CTV] = [M:CBA7]
  Gosub PE_CRMTRS From SUBCRMTRS
  If IINIMODTRS = 0 Then
    Rewrite [CTV]
  Else
    Write [CTV]
  Endif
  If fstat <> 0 Then
    GOK = 0  # FGR 28/01/2010 : X3SUIVI62022
    GERR = 2
    #Erreur lors de l'écriture de la table des valeurs de transaction de saisie + " (CRMTRSVAL)".
    GMESSAGE = mess(521,177,1) - "(CRMTRSVAL)"
    Return
  Endif
  Gosub TRT_ECRAN
Return

##########################################################################################################
$APRES_MOD
  Gosub REORGANISE From SUBCBAB
  Gosub AFF_FENETRE From SUBCBAB
Return

##########################################################################################################
$ANNULE
  Delete [AXX] Where CODFIC = "CRMTRS" and IDENT1 = num$([F:CTR]CTRTYP) and IDENT2 = [F:CTR]CTRNUM
  Gosub TRT_ECRAN
  Delete [CTV] Where [F:CTV]CTRTYP=[F:CTR]CTRTYP and [F:CTV]CTRNUM=[F:CTR]CTRNUM
  If fstat <> 0 Then
    GOK = 0  # FGR 28/01/2010 : X3SUIVI62022
    GERR = 2
    #Erreur lors de la suppression dans la  table des valeurs de transaction de saisie.+" (CRMTRSVAL)"
    GMESSAGE = mess(523,177,1) - "(CRMTRSVAL)"
    Return
  Endif
Return

##########################################################################################################
#----------------------------------------#
# Création ou modif de texte traductible #
#----------------------------------------#
$CHARGE_ATEXTRA 
  Call MAJTEXTRA([M:CBA0]DESAXX, "CRMTRS", "DESAXX", num$([M:CBA0]CTRTYP), [M:CBA0]CTRNUM) From ATEXTRA
  [F:CTR]CTRDES = GLANGUE + "~" + [M:CBA0]DESAXX
  [F:CTR]CTRTYPCAR = num$([F:CTR]CTRTYP)
Return

##########################################################################################################
#------------------------------------------------#
# Génération ou suppression de l'écran de saisie #
#------------------------------------------------#
$TRT_ECRAN
  Gosub INIT_VARIABLES From CRMTRSUTI
  #---------------- Noms fenêtres et traitement -----------------#
Local Char WINREF(GLONFEN) : WINREF="OCRA"
Local Char NOMWIN(GLONFEN) : NOMWIN="WOCRA" + [M:CBA0]CTRNUM
Local Char NOMTRT(GLONADC) : NOMTRT="WGOCRA" + [M:CBA0]CTRNUM
  #------------------------- Entete --------------------------#
  MFROM = "CRMAGD0"
  MTO = "WL" + num$([M:CBA0]CTRTYP) + [M:CBA0]CTRNUM + "0"
  Gosub GERE_MSK_CRM From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #------------------------- agenda  --------------------------#
  MFROM = "CRMAGD1"
  MTO = "WL" + num$([M:CBA0]CTRTYP) + [M:CBA0]CTRNUM + "1"
  Gosub GERE_MSK_CRM From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #----------------------- Rendez-vous ------------------------#
  MFROM = "CRMAGD7"
  MTO = "WL" + num$([M:CBA0]CTRTYP) + [M:CBA0]CTRNUM + "7"
  Gosub GERE_MSK_CRM From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #-------------------------- Appels --------------------------#
  MFROM = "CRMAGD2"
  MTO = "WL" + num$([M:CBA0]CTRTYP) + [M:CBA0]CTRNUM + "2"
  Gosub GERE_MSK_CRM From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #-------------------------- Tâches ---------------------------#
  MFROM = "CRMAGD3"
  MTO = "WL" + num$([M:CBA0]CTRTYP) + [M:CBA0]CTRNUM + "3"
  Gosub GERE_MSK_CRM From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #------------------------- Affaires --------------------------#
  MFROM = "CRMAGD4"
  MTO = "WL" + num$([M:CBA0]CTRTYP) + [M:CBA0]CTRNUM + "4"
  Gosub GERE_MSK_CRM From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #-------------------- Campagne marketing ---------------------#
  MFROM = "CRMAGD8"
  MTO = "WL" + num$([M:CBA0]CTRTYP) + [M:CBA0]CTRNUM + "8"
  Gosub GERE_MSK_CRM From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #----------------------- Informations ------------------------#
  MFROM = "CRMAGD6"
  MTO = "WL" + num$([M:CBA0]CTRTYP) + [M:CBA0]CTRNUM + "6"
  Gosub GERE_MSK_CRM From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  If ACTION = "ANNULE" Then
    Gosub TRT_SUP_FEN
  Else 
    Gosub TRT_GEN_FEN
  Endif
Return

##########################################################################################################
#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
  Call DELWIN(NOMWIN, APPLI) From MSKDIV
Return

##########################################################################################################
#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
  If clalev([F:AOB])=0 Local File =APPLI+".AOBJET"   [AOB] : Endif : # Si appel par FUNCRMTRS
  If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW"  [AWI] : Endif : # Si appel par FUNCRMTRS
  If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR"  [AWP] : Endif : # Si appel par FUNCRMTRS
  If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par FUNCRMTRS
  If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par FUNCRMTRS
  If clalev([F:AMZ])=0 Local File =APPLI+".AMSKZON"  [AMZ] : Endif : # Si appel par FUNCRMTRS
  #----- Suppression fenêtre si transaction non active -----#
  If [M:CBA0]ENAFLG = 1 Then
    Gosub TRT_SUP_FEN
    Return
  Endif
  #----- Génération fenêtre si transaction active -----#
  Delete [AWI] Where WIN=NOMWIN
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$AWINDOW" - NOMWIN
    Return
  Elsif fstat Then
    GOK = 0
    Call RSTA ("AWI", NOMWIN) From GLOCK
    Return
  Endif
  Delete [AWP] Where WIN=NOMWIN
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$AWINPAR" - NOMWIN
    Return
  Elsif fstat Then
    GOK = 0
    Call RSTA ("AWP", NOMWIN) From GLOCK
    Return
  Endif
  Delete [AWB] Where WIN=NOMWIN
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$AWINBRO" - NOMWIN
    Return
  Elsif fstat Then
    GOK = 0
    Call RSTA ("AWB", NOMWIN) From GLOCK
    Return
  Endif
  Delete [AWT] Where WIN=NOMWIN
  If fstat=1 Then
    GOK = -1
    GLOCK = "$AWINBOUT" - NOMWIN
    Return
  Elsif fstat Then
    GOK = 0
    Call RSTA ("AWT", NOMWIN) From GLOCK
    Return
  Endif
  Read [AWI]AWI0=WINREF
  If fstat <> 0 Then
    GOK = 0
    Return
  Endif
  #---------------------------------------------------------
  #Entête
  WNOMMSK = "WL" + num$([M:CBA0]CTRTYP) + [M:CBA0]CTRNUM + "0"
  [F:AWI]WIN = NOMWIN
  [F:AWI]MSKENT = WNOMMSK
  #---------------------------------------------------------
  #Agenda
  WMSKREF = "CRMAGD1" 
  WNOMMSK = "WL" + num$([M:CBA0]CTRTYP) + [M:CBA0]CTRNUM + "1"
  I = find(WMSKREF, [F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 0
  Endif
  Gosub ONGLETVISIBLE_CRM From CRMTRSUTI
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #---------------------------------------------------------
  #Rendez-vous
  WMSKREF = "CRMAGD7"
  WNOMMSK = "WL" + num$([M:CBA0]CTRTYP) + [M:CBA0]CTRNUM + "7"
  I = find(WMSKREF, [F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 1
  Endif
  Gosub ONGLETVISIBLE_CRM From CRMTRSUTI
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #---------------------------------------------------------
  #Appels
  WMSKREF = "CRMAGD2" 
  WNOMMSK = "WL" + num$([M:CBA0]CTRTYP) + [M:CBA0]CTRNUM + "2"
  I = find(WMSKREF, [F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 2
  Endif
  Gosub ONGLETVISIBLE_CRM From CRMTRSUTI
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #---------------------------------------------------------
  #Tâches
  WMSKREF = "CRMAGD3" 
  WNOMMSK = "WL" + num$([M:CBA0]CTRTYP) + [M:CBA0]CTRNUM + "3"
  I = find(WMSKREF, [F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 2
  Endif
  Gosub ONGLETVISIBLE_CRM From CRMTRSUTI
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #---------------------------------------------------------
  #Affaires
  WMSKREF = "CRMAGD4"
  WNOMMSK = "WL" + num$([M:CBA0]CTRTYP) + [M:CBA0]CTRNUM + "4"
  I = find(WMSKREF, [F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 2
  Endif
  Gosub ONGLETVISIBLE_CRM From CRMTRSUTI
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #---------------------------------------------------------
  #Campagnes marketing
  WMSKREF = "CRMAGD8"
  WNOMMSK = "WL" + num$([M:CBA0]CTRTYP) + [M:CBA0]CTRNUM + "8"
  I = find(WMSKREF, [F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 2
  Endif
  Gosub ONGLETVISIBLE_CRM From CRMTRSUTI
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #---------------------------------------------------------
  #Informations
  WMSKREF = "CRMAGD6"
  WNOMMSK = "WL" + num$([M:CBA0]CTRTYP) + [M:CBA0]CTRNUM + "6"
  I = find(WMSKREF, [F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 2
  Endif
  Gosub ONGLETVISIBLE_CRM From CRMTRSUTI
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #---------------------------------------------------------
  [F:AWI]ENAFLG = 2
  [F:AWI]ACS = [M:CBA0]ACSCOD
  If dim([F:AWI]LIBEL) > 0 Then
    [F:AWI]LIBEL = ""
  Endif
  [F:AWI]TRN = ""
  [F:AWI]WINTYP = 1
  [F:AWI]OBJ = ""
  Write [AWI]
  If fstat Then
    GOK = 0
    Call FSTA("AWI") From GLOCK
    Return
  Endif
  For [AWP] AWP0 Where WIN=WINREF
    [F:AWP]WIN = NOMWIN
    Write [AWP]
    If fstat Then
      GOK = 0
      Call FSTA("AWP") From GLOCK
      Break
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
  For [AWB] AWB0 Where WIN=WINREF
    [F:AWB]WIN = NOMWIN
    Write [AWB]
    If fstat Then
      GOK = 0
      Call FSTA("AWB") From GLOCK
      Break
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
  For [AWT]AWT0 Where WIN = WINREF
    [F:AWT]WIN = NOMWIN
    Write [AWT]
    If fstat Then
      GOK = 0
      Call FSTA("AWT") From GLOCK
      Break
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
  Call VALID(NOMWIN, APPLI, 1, OK) From VALWIN
  If !OK Then
    GOK = 0
  Endif
Return

##########################################################################################################
Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()

  #-----------------------#
  # Avant saisie document #
  #-----------------------#
  [M:CBA0]CTRTYP = 1
End

##########################################################################################################
Subprog AM_ONGLETACT(VALEUR)
Variable Char    VALEUR()

Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Char SZLIBELLE (50)

  If VALEUR <> "" Then
    Call GETLIB_ONGLET("FCRMAGD", VALEUR, SZLIBELLE, SZMESSAGE, IBRETOUR) From CRMTRSUTI
    If IBRETOUR = 0 Then
      SZLIBELLE = ""
      mkstat = 2
      GMESSAGE = SZMESSAGE
    Endif
  Else
    SZLIBELLE = ""
  Endif
  [M:CBA7]LIBONGLET = SZLIBELLE
  Affzo [M:CBA7]LIBONGLET
End

##########################################################################################################
Subprog B3_AGDFIEPOS(VALEUR)
Variable Decimal VALEUR

Local Integer ILIGNESAVE
Local Integer ILIGNE
Local Integer INUMERO
Local Integer IBCONTINUE

  ILIGNESAVE = nolign
  ILIGNE = nolign-1
  IBCONTINUE = 1
  ILIGNE = ILIGNE + 1
  INUMERO = VALEUR + 1
  While IBCONTINUE = 1
    If ILIGNE > dim([M:CBA1]AGDFIEPOS) Then
      IBCONTINUE = 0
      Break
    Endif
    If [M:CBA1]AGDFIECOD(ILIGNE) = "" Then
      IBCONTINUE = 0
      Break
    Endif        
    [M:CBA1]AGDFIEPOS(ILIGNE) = INUMERO
    Affzo [M:CBA1]AGDFIEPOS(ILIGNE)
    ILIGNE += 1
    INUMERO += 1
  Wend
  nolign = ILIGNESAVE
End

##########################################################################################################
