    Endif
    If [M:CBA4]OPPFIECOD(ILIGNE) = "" Then
      IBCONTINUE = 0
      Break
    Endif        
    [M:CBA4]OPPFIEPOS(ILIGNE) = INUMERO
    Affzo [M:CBA4]OPPFIEPOS(ILIGNE)
    ILIGNE += 1
    INUMERO += 1
  Wend
  nolign = ILIGNESAVE
End

##########################################################################################################
Subprog B3_INFFIEPOS(VALEUR)
Variable Decimal VALEUR

Local Integer ILIGNESAVE
Local Integer ILIGNE
Local Integer INUMERO
Local Integer IBCONTINUE

  ILIGNESAVE = nolign
  ILIGNE = nolign-1
  IBCONTINUE = 1
  ILIGNE = ILIGNE + 1
  INUMERO = VALEUR + 1
  While IBCONTINUE = 1
    If ILIGNE > dim([M:CBA6]INFFIEPOS) Then
      IBCONTINUE = 0
      Break
    Endif
    If [M:CBA6]INFFIECOD(ILIGNE) = "" Then
      IBCONTINUE = 0
      Break
    Endif        
    [M:CBA6]INFFIEPOS(ILIGNE) = INUMERO
    Affzo [M:CBA6]INFFIEPOS(ILIGNE)
    ILIGNE += 1
    INUMERO += 1
  Wend
  nolign = ILIGNESAVE
End

