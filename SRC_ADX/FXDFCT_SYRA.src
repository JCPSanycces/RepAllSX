###############################################################################
Subprog GET_NEW_REFERENCE(PABREV, PNUMAFF, PINDEX, PCPY, PFCY, PDATE, RNUMERO, STAT)
# Numérote les objets métiers
# PABREV  : Abréviation (standard) de la table ppale de l'objet métier
# PNUMAFF : indice du compteur de l'objet dans l'affectation des compteurs
# PINDEX  : Rang de l'index à utiliser pour contrôler l'absence du numéro attribué
# PCPY    : Société
# PFCY    : Site de référence pour le compteur
# PDATE   : Date de référence pour le compteur
#
# Rend :
# RNUMERO : Numéro
# STAT    : Statut (0 : OK, >0 : KO)
# ------------------------------------------------------------------------------
Value    Char    PABREV
Value    Integer PNUMAFF
Value    Integer PINDEX
Value    Char    PCPY
Value    Char    PFCY
Value    Date    PDATE
Variable Char    RNUMERO
Variable Integer STAT

  Local Integer L_NBESSAI
  Local Char    L_COMPTEUR(5)
#  Local Char    MESSA

  Local File ATABLE       [ATB]  : # Table des tables
  Local File TABCOUAFF    [TCA]  : # Table des affectations de compteurs

  STAT = 0
  # Recherche de la table correspondant à l'abréviation
  Read [ATB]ABRFIC = PABREV
  If fstat : Raz [F:ATB] : Endif

  Local Integer L_MODULE   :   L_MODULE  = [F:ATB]MODULE
  Local Integer B_TCAFND

  # Gosub FAS_LECTCA
  Local Char L_LEG(GLONADI)
  B_TCAFND = 0
  If ( PCPY <> "" ) Then
    # look for the counter for the given company
    Read [TCA]TCA0=L_MODULE;"";PCPY
    If (!fstat) Then
      B_TCAFND = 1
    Else
      # look for the legislation of the given company in GLECSOC
      L_LEG =  fmet GACTX.ACACHE.ACPY.AGETVALCHAR(PCPY,"LEG")
      If ( L_LEG <> "" ) Then
        # look for the counter for the legislation of the given company
        Read [TCA]TCA0=L_MODULE;L_LEG;""
        If (!fstat) Then
          B_TCAFND = 1
        Else
          # if still not found, look for the counter of the whole module
          Read [TCA]TCA0=L_MODULE;"";""
          If (!fstat) Then
            B_TCAFND = 1
          Endif
        Endif
      Else
        # if still not found, look for the counter of the whole module
        Read [TCA]TCA0=L_MODULE;"";""
        If (!fstat) Then
          B_TCAFND = 1
        Endif
      Endif
    Endif
  Endif

  If (!B_TCAFND) Then : Raz [F:TCA] : Endif

  L_COMPTEUR = [F:TCA]CODNUM(PNUMAFF)
  If L_COMPTEUR = "" Then
    L_COMPTEUR   = PABREV                     : # Par défaut on prend l'abréviation de la table comme compteur
  Endif

  Local Integer RET
  Local Char ERRMSG(140)

$ININUM
  # Appel du compteur de numérotation
  #Call NUMERO(L_COMPTEUR, PFCY, PDATE, "", RNUMERO, STAT) From SUBANM
  [L]RET = func ANM_TOOL.NUMERO(GACTX, L_COMPTEUR, PFCY, PDATE, "", RNUMERO, [L]ERRMSG)

  # Entry point
  #GPOINT = "NUMEROFAS" : Gosub ENTREE From EXEFNC

  If [L]RET = [V]CST_AERROR
    # Erreur dans la numérotation automatique (COMPTEUR) : xxxxx
#    [L]ASTATUS = fmet this.ASETERROR("",  mess(22, 7770, 1) - "(" + L_COMPTEUR + ") :" - [L]ERRMSG, [V]CST_AERROR)
    STAT = 1
    End
  Endif

  # Contrôle existence du numéro rendu
  Assign "[G:"+PABREV+"]currind" With PINDEX
  Assign "[G:"+PABREV+"]currlen" With 1
  Default File "["+PABREV+"]"
  Look [F] = RNUMERO
  If !fstat : # Ca existe déjà, on prend le suivant..
    L_NBESSAI += 1
    If L_NBESSAI > 100 : # On va quand même pas boucler éternellement
      # Erreur dans la numérotation automatique (COMPTEUR) : Séquence de numérotation déjà utilisée
#      GMESSAGE  = mess(22, 7770, 1) - "(" + L_COMPTEUR + ") :" - mess(135,7770,1)
#      [L]ASTATUS = fmet this.ASETERROR("", mess(22, 7770, 1) -"(" + L_COMPTEUR + ") :" - [L]ERRMSG, [V]CST_AERROR)
      STAT = 99
      End
    Endif
    Goto ININUM
  Endif

End

#**
#* Get the first top level error's message from POBJ class error stack
#*
#* @param  POBJ
#* @return RETMSG message
#*!
Funprog GET_MAXMSG(POBJ)
Variable Instance POBJ Using OBJECT
Local Char RETMSG(250)

  Local Integer LIN, MAXERR

  [L]MAXERR = 0
  RETMSG = AVOID.ACHAR
  For [L]LIN = 1 To maxtab(POBJ.AERROR)
    If (POBJ.AERROR([L]LIN) <> null and POBJ.AERROR([L]LIN).DEL <> [V]CST_AYES)
      If POBJ.AERROR([L]LIN).STA > [L]MAXERR
        # Get the first error level message
        [L]MAXERR = POBJ.AERROR([L]LIN).STA
        If POBJ.AERROR([L]LIN).PRO = AVOID.ACHAR
          RETMSG = POBJ.AERROR([L]LIN).MES
        Else
          RETMSG = POBJ.AERROR([L]LIN).PRO - POBJ.AERROR([L]LIN).MES
        Endif
      Endif
    Endif
  Next

End RETMSG

#**
#* Copy all the messages from an instance to a second one
#*
#* @param POBJ1 from instance
#* @param POBJ2 to instance
#* @return [V]CST_ATRUE
#*!
Funprog COPY_MSG(POBJ1, POBJ2)
Variable Instance POBJ1 Using OBJECT
Variable Instance POBJ2 Using OBJECT

Local Integer LIN, STACK_ERROR

  For [L]LIN= 1 To maxtab(POBJ1.AERROR)
    If POBJ1.AERROR([L]LIN) <> null and POBJ1.AERROR([L]LIN).DEL <> [V]CST_AYES
      [L]STACK_ERROR = fmet POBJ2.ASETERROR(POBJ1.AERROR([L]LIN).PRO, POBJ1.AERROR([L]LIN).MES, POBJ1.AERROR([L]LIN).STA)
    Endif
  Next

End [V]CST_ATRUE

#**
#* Get the classic code trace belong the stak error status
#*
#* @param  PSTA Stack error status
#* @return RET  Classic level code
#*!
Funprog GET_CLASSICERRLEVEL(PSTA)
Value Integer PSTA

  Local Integer RET

  # ----------------------------------------------------
  #   Stack error status | Trace status
  # ----------------------------------------------------
  #   CST_ASUCCESS       |  0  (info)
  #   CST_AINFO          |  0  (info)
  #   CST_AWARNING       | -1  (warning)
  #   CST_AERROR         |  1  (error)
  #   CST_AFATAL         |  1  (error)
  # ----------------------------------------------------
  Case PSTA
    When [V]CST_AINFO:
      RET = 0
    When [V]CST_ASUCCESS:
      RET = 0
    When [V]CST_AWARNING:
      RET = -1
    When [V]CST_AERROR:
      RET = 1
    When [V]CST_AFATAL:
      RET = 1
    When Default:
      RET = 0
  Endcase

End RET

#**
#* Write error stack of an object into Classic log
#*
#* @param POBJ   : object instance
#* @param PLEVEL : (deprecated)
#*!
Subprog WRITE_ERROR_STACK_CLASSIC(POBJ, PLEVEL)
Value Instance POBJ  Using OBJECT
Value Integer  PLEVEL

  Local Integer N_I
  Local Char PRO(250)

  For [L]N_I = 1 To maxtab(POBJ.AERROR)
    If POBJ.AERROR(N_I) <> null
      PRO = POBJ.AERROR([L]N_I).PRO
      If PRO <> AVOID.ACHAR
        PRO += " : "
      Endif
      Call ECR_TRACE("-> " - PRO - POBJ.AERROR([L]N_I).MES -
&                    "(" + num$(POBJ.AERROR([L]N_I).NUM) + "/" + num$(POBJ.AERROR([L]N_I).STA) + ")",
&                    func FXDFCT_SYRA.GET_CLASSICERRLEVEL(POBJ.AERROR([L]N_I).STA)) From GESECRAN
    Endif
  Next N_I
End

#**
#* Write error stack of an object into Syracuse ALOG
#*
#* @param POBJ   : object instance
#* @param PALOG  : log class instance
#* @param PLEVEL : (deprecated)
#*!
Subprog WRITE_ERROR_STACK(POBJ, PALOG, PLEVEL)
Value Instance POBJ  Using OBJECT
Value Instance PALOG Using OBJECT
Value Integer  PLEVEL

  Local Integer N_I
  Local Char PRO(250)

  For [L]N_I = 1 To maxtab(POBJ.AERROR)
    If POBJ.AERROR(N_I) <> null
      PRO = POBJ.AERROR([L]N_I).PRO
      If PRO <> AVOID.ACHAR
        PRO += " : "
      Endif
      Local Integer RET
      RET = fmet PALOG.APUTLINE("-> " - PRO - POBJ.AERROR([L]N_I).MES -
&                    "(" + num$(POBJ.AERROR([L]N_I).NUM) + "/" + num$(POBJ.AERROR([L]N_I).STA) + ")",
&                    POBJ.AERROR([L]N_I).STA)
    Endif
  Next N_I
End

#**
#* Check message
#* Check if it's the wanted message and (optional) if it's the good level
#*
#* @param POBJ         instance to verify object
#* @param PNUM_MES     number of message to found
#* @param PCHAP_MES    chapter of message to found
#* @param PLEVEL_MES   message's level (AOK, AINFOS...   -1 if we don't want to compare the level)
#*!
Subprog CHECK_MSG(POBJ, PNUM_MES, PCHAP_MES, PLEVEL_MES)
Variable Instance POBJ Using OBJECT
Value Integer PNUM_MES, PCHAP_MES, PLEVEL_MES

  Local Char WMSG(250)
  Local Integer WLEVEL

  Call CHECK_MSG_DETAIL(POBJ, PNUM_MES, PCHAP_MES, PLEVEL_MES, WMSG, WLEVEL)

End

#**
#* Check message (with return infos)
#* Check if it's the wanted message and (optional) if it's the good level
#*
#* @param POBJ         instance to verify object
#* @param PNUM_MES     number of message to found
#* @param PCHAP_MES    chapter of message to found
#* @param PLEVEL_MES   message's level (AOK, AINFOS...   -1 if we don't want to compare the level
#* @param RMESSAGE     text message found
#* @param RLEVEL       level message found
#*!
Subprog CHECK_MSG_DETAIL(POBJ, PNUM_MES, PCHAP_MES, PLEVEL_MES, RMESSAGE, RLEVEL)
Variable Instance POBJ Using OBJECT
Value Integer PNUM_MES, PCHAP_MES, PLEVEL_MES
Variable Char RMESSAGE()
Variable Integer RLEVEL

  Local Integer LIN, BMSG_OK
  Local Char WMSG_TO_CMP(250)

  RMESSAGE = AVOID.ACHAR
  RLEVEL = -1
  [L]BMSG_OK = [V]CST_AFALSE

  [L]WMSG_TO_CMP = mess(PNUM_MES, PCHAP_MES, 1)

  For [L]LIN = 1 To maxtab(POBJ.AERROR)
    If (POBJ.AERROR([L]LIN) <> null and POBJ.AERROR([L]LIN).DEL <> [V]CST_AYES)

      # Message found
      If [L]WMSG_TO_CMP = POBJ.AERROR([L]LIN).MES
        [L]BMSG_OK = [V]CST_ATRUE
        RMESSAGE = POBJ.AERROR([L]LIN).MES
      Endif

      # Get the max level message
      If POBJ.AERROR([L]LIN).STA > RLEVEL
        RLEVEL = POBJ.AERROR([L]LIN).STA
        RMESSAGE = POBJ.AERROR([L]LIN).MES
      Endif
    Endif
  Next

  If [L]BMSG_OK = [V]CST_ATRUE
    # Also to compare with max level (if asked)
    If PLEVEL_MES > [V]CST_AOK
      # It's not the asked level :
      If PLEVEL_MES <> RLEVEL
        [L]BMSG_OK = [V]CST_AFALSE
      Endif
    Endif
  Endif

  Call CHECK_EQUAL([L]BMSG_OK, [V]CST_ATRUE) From AXUNIT
  If [L]BMSG_OK <> [V]CST_ATRUE
    Call LOG_LINE("Wanted message =" - [L]WMSG_TO_CMP)
    Call LOG_LINE("Red message    ="   - RMESSAGE)
  Endif

End


#**
#* Give the name of the callback traitment : (dynamic)
#*!
Funprog CALLBACK_TRT_NAME

Local Integer I

#  GTRT_CALLBACK = adxpno(0)  # current traitment
  GTRT_CALLBACK = adxpno(1)   # n-1 traitment
  I = instr(1, GTRT_CALLBACK, "/")
  If I = 0
    End [V]CST_AFALSE
  Endif

  GTRT_CALLBACK = right$(GTRT_CALLBACK, I + 1)
  I = instr(1, GTRT_CALLBACK, "$")
  If I
    GTRT_CALLBACK = left$(GTRT_CALLBACK, I - 1)
  Endif

End [V]CST_ATRUE

#**
#* General function for check, write log , write dump and del the stack of errors
#*
#* @param POBJECT
#* @param PRET        return value to compare
#* @param PWANTED     wanted walue
#* @param PDELERROR   del the stack of erros
#* @param PTXT        text to write
#*!

Subprog LOG_ACTION_CTL(POBJECT, PRET, PWANTED, PDELERROR, PTXT)
Variable Instance POBJECT Using OBJECT
Value Integer PRET, PWANTED, PDELERROR
Value Char PTXT()

Local Integer OK
If dim(G_NUM_TESTCASE) < 0
  Global Integer G_NUM_TESTCASE
Endif

  Call CHECK_EQUAL(PRET, PWANTED) From AXUNIT
  If PRET <> PWANTED or G_LOG_TITLE
    If G_NUM_TESTCASE
      Call LOG_LINE(num$(G_NUM_TESTCASE) + "." + PTXT)
    Else
      Call LOG_LINE(PTXT)
    Endif
  Endif

  If PRET <> PWANTED
    Call DUMP_ERROR_LOG(POBJECT)
  Endif

  If PDELERROR
    [L]OK = fmet POBJECT.ADELETEERROR([V]CST_ALLERRORS)
  Endif
End

Subprog LOG_LINE(LOG_MSG)
Value Char LOG_MSG
  If func WRITE_LOG_LINE = [V]CST_ATRUE
    Call LOG_LINE(LOG_MSG) From AXUNIT
  Endif
End

Funprog WRITE_LOG_LINE
Local Integer B_LOG_LINE
  #[L]B_LOG_LINE = [V]CST_AFALSE
  [L]B_LOG_LINE = [V]CST_ATRUE
End B_LOG_LINE


Subprog DUMP_ERROR_LOG(POBJECT)
Variable Instance POBJECT Using OBJECT

Local Integer NI, ASTATUS

  # --------------------------------------------------------------
  # [V]CST_C_NAME_CLASS_CONTEXT contains C_WMACONTEXT
  # if constant value is changed, Newinstance statement must be modified.
  Local Instance CTX Using =[V]CST_C_NAME_CLASS_CONTEXT
  CTX = NewInstance C_WMACONTEXT AllocGroup null

  ASTATUS = fmet POBJECT._AERROR(CTX, [V]CST_ANO)
  # --------------------------------------------------------------
  Call LOG_LINE(string$(40, "*") + num$(maxtab(CTX.AERROR))- "MESSAGE(S) IN ERROR LOGFILE")
  For [L]NI = 1 To maxtab(CTX.AERROR)
    If CTX.AERROR(NI) <> null
      Call LOG_LINE("-> Err.(" + num$([L]NI) + ") " +
&                      num$(CTX.AERROR([L]NI).PRO) -
&                      num$(CTX.AERROR([L]NI).NUM) -
&                      num$(CTX.AERROR([L]NI).STA) -
&                      num$(CTX.AERROR([L]NI).MES)  )
    Endif
  Next NI
  # --------------------------------------------------------------
  Call LOG_LINE(string$(40, "*") + "END ERROR LOGS")

  FreeGroup CTX
End


Subprog WRITE_ERROR_LOG(POBJECT)
Variable Instance POBJECT Using OBJECT

  Local Integer NI, ASTATUS
  Local Char PRO(250)

  # --------------------------------------------------------------
  # [V]CST_C_NAME_CLASS_CONTEXT contains C_WMACONTEXT
  # if constant value is changed, Newinstance statement must be modified.
  Local Instance CTX Using = [V]CST_C_NAME_CLASS_CONTEXT
  CTX = NewInstance C_WMACONTEXT AllocGroup null

  ASTATUS = fmet POBJECT._AERROR(CTX, [V]CST_ANO)

  For [L]NI = 1 To maxtab(CTX.AERROR)
    If CTX.AERROR(NI) <> null
      PRO = CTX.AERROR([L]NI).PRO
      If PRO <> AVOID.ACHAR
        PRO += " : "
      Endif
      Call LOG_LINE("-> " + PRO + CTX.AERROR([L]NI).MES - "(" + num$(CTX.AERROR([L]NI).NUM) + "/" + num$(CTX.AERROR([L]NI).STA) + ")")
    Endif
  Next NI

  FreeGroup CTX
End

Subprog CTRL_FIELD(RRET, PREF, PNAME, PWANTEDVAL, PREADVAL)
Variable Integer RRET
Value Char PREF(), PNAME(), PWANTEDVAL(), PREADVAL()

  If PWANTEDVAL <> PREADVAL
    Call LOG_LINE(PREF - ":" - PNAME - "Wanted =" - PWANTEDVAL - "<> Read =" - PREADVAL) From FXDFCT_SYRA
    RRET = [V]CST_AERROR
  Endif

End

