#********************************************************************
# Method ADELETE_BEFORE
#********************************************************************
#
#********************************************************************
$ADELETE_BEFORE
  Local Integer WOK
  WOK = fmet this.MET_DEL_JSON()
  ASTATUS = WOK
Return

#********************************************************************
# Method MET_GET_STO_PROPERTIES
#********************************************************************
#
#********************************************************************
$MET_GET_STO_PROPERTIES
  #empty the Storage tab
  Call DELETELINES(this, "ESTU") From EDILIBA

  Local Integer WOK, I, J

  #step 1 : get keys from linked setup
  Local Char WEDIFLOKEY(26)          #20+1+5
  Local Char WEDIPTCKEY(20)          #20
  Local Char WEDIMSGKEY_TAB(100)(1..)    #x+x 20+1+5
  Local Char WEDISEQFILKEY_TAB(100)(1..) #x+x+x
  Local Char WREPCOD_TAB(20)(1..)        #20
  Local Char WERR(250)
  Local Integer WFILTYP(1..)  ## 112148

  J = 1
  WOK = [V]CST_AERROR

  WEDIFLOKEY = this.FLOCOD+"~"+this.FLOREL
  WEDIPTCKEY = this.PTCCOD
  For I = 1 To maxtab(this.ESTF)
    If this.ESTF(I) <> null and this.ESTF(I).ASTALIN <> [V]CST_ADEL and this.ESTF(I).ASTALIN <> [V]CST_ANEWDEL
#      If this.ESTF(I).MSGTYP = 1 and this.ESTF(I).MSGFOR = 1 #Query and #Sequential ## 112148
      If this.ESTF(I).MSGTYP = 1 ## 112148
        WEDIMSGKEY_TAB(J)    = this.ESTF(I).MSGCOD+"~"+this.ESTF(I).MSGREL
        WEDISEQFILKEY_TAB(J) = this.ESTF(I).MSGCOD+"~"+this.ESTF(I).MSGREL+"~"+this.ESTF(I).MSGFILNOR
        WREPCOD_TAB(J)       = this.ESTF(I).REPCOD
        WFILTYP(J)           = this.ESTF(I).MSGFOR      ## 112148
        J=J+1
        WOK = [V]CST_AOK
#        WERR = "Flow is valid"-":"-num$(J)-"line(s) found"
      Endif
    Endif
  Next I

  If WOK <> [V]CST_AOK
    #error if no line is found
    WOK = fmet this.MET_LOG_INSERT_EVENT(datetime$, 1, [V]CST_AERROR, 25, this.FLOCOD+"~"+this.FLOREL)
    this.STA = 3 #transfert error
    ARET_VALUE = [V]CST_AWARNING
    Return
  Endif

  #step 2 : create the storage space tab
  Local Char WTABCOD(20)(1..)
  Local Char WTABDES(100)(1..)
  Local Char WTABCLA(20)(1..)
  Local Char WTABKEY(50)(1..)

  J = 1
  WTABCOD(J) = "EDIFLO"   : WTABCLA(J) = "EDIFLO"  : WTABKEY(J) = WEDIFLOKEY : WTABDES(J) = mess(3,7959,1)-"/"-mess(27,2006,1)   : J=J+1 #"Setup / Flow"
  WTABCOD(J) = "EDIPTC"   : WTABCLA(J) = "EDIPTC"  : WTABKEY(J) = WEDIPTCKEY : WTABDES(J) = mess(3,7959,1)-"/"-mess(113,2006,1) : J=J+1 #"Setup / Protocol"
  For I = 1 To maxtab(WEDIMSGKEY_TAB)
    WTABCOD(J) = "EDIMSG"+num$(I)    : WTABCLA(J) = "EDIMSG"      : WTABKEY(J) = WEDIMSGKEY_TAB(I)    : WTABDES(J) = mess(3,7959,1)-"/"-mess(115,2006,1)+"("+num$(I)+")"  : J=J+1 #"Setup / Message
# Mapping
    If WFILTYP(I)=1 ## 112148
      WTABCOD(J) = "EDISEQFIL"+num$(I) : WTABCLA(J) = "EDISEQFIL"   : WTABKEY(J) = WEDISEQFILKEY_TAB(I) : WTABDES(J) = mess(3,7959,1)-"/"-mess(114,2006,1)+"("+num$(I)+")"  : J=J+1 #"Setup / Sequential
    Else
      WTABCOD(J) = "EDIXMLFIL"+num$(I) : WTABCLA(J) = "EDIXMLFIL"   : WTABKEY(J) = WEDISEQFILKEY_TAB(I) : WTABDES(J) = mess(3,7959,1)-"/"-mess(178,2006,1)+"("+num$(I)+")"  : J=J+1 #"Setup / XML file
    Endif    ## 112148
# file
    WTABCOD(J) = "REPCOD"+num$(I)    : WTABCLA(J) = WREPCOD_TAB(I)       :
    If this.CATACT = 1 #issue
      WTABKEY(J) = this.KEYDOC
    Else
      WTABKEY(J) = ""
    Endif
    WTABDES(J) = mess(3,7959,1)-"/"-mess(23,140,1)+"("+num$(I)+")" : J=J+1 #"Setup / Representation
  Next
  WTABCOD(J) = "CRUDFILE"+num$(1)  : WTABCLA(J) = ""  : WTABKEY(J) = this.KEYDOC : WTABDES(J) = mess(5,7959,1)-"/"-"CRUD"   : J=J+1 # #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat

  #step 3 : set storage space tab with values
  Local Integer WPOS
  For J = 1 To maxtab(WTABCOD)
    WPOS = fmet this.ADDLINE("ESTU", [V]CST_ALASTPOS)
    this.ESTU(WPOS).CODE     = WTABCOD(J)
    this.ESTU(WPOS).DOCDES   = WTABDES(J)
    this.ESTU(WPOS).DOCUUID  = toUuid(func SET_UUID(WTABCOD(J), WTABKEY(J))) #NullUuid # toUuid("00000000-0000-0000-0000-000000000000") #test
    this.ESTU(WPOS).DOCCLASS = WTABCLA(J)
    this.ESTU(WPOS).DOCKEY   = WTABKEY(J)
  Next
  ARET_VALUE = [V]CST_AOK
Return

#********************************************************************
# Method MET_GET_FLO_PROPERTIES
#********************************************************************
#
#********************************************************************
$MET_GET_FLO_PROPERTIES
  this.CATCOD = fmet this.ACTX.ACACHE.EFL.AGETVALCHAR(this.FLOCOD,this.FLOREL,"CATCOD")
  this.CATACT = fmet this.ACTX.ACACHE.EFL.AGETVALNUM(this.FLOCOD,this.FLOREL,"CATACT")
  this.PARCOD = fmet this.ACTX.ACACHE.EFL.AGETVALCHAR(this.FLOCOD,this.FLOREL,"PARCOD")
  this.PTCCOD = fmet this.ACTX.ACACHE.EFL.AGETVALCHAR(this.FLOCOD,this.FLOREL,"PTCCOD")

  Local Integer WPOS

  Call DELETELINES(this, "ESTF") From EDILIBA

  Local File EDIFLOD [EFLD]
  Filter [EFLD] Where FLOCOD = this.FLOCOD and FLOREL = this.FLOREL
  For [EFLD]
    WPOS = fmet this.ADDLINE("ESTF", [V]CST_ALASTPOS)
    this.ESTF(WPOS).MSGCOD    = [EFLD]MSGCOD
    this.ESTF(WPOS).MSGREL    = [EFLD]MSGREL
    this.ESTF(WPOS).MSGDIR    = [EFLD]MSGDIR
    this.ESTF(WPOS).MSGTYP    = [EFLD]MSGTYP
    this.ESTF(WPOS).MSGFOR    = [EFLD]MSGFOR
    this.ESTF(WPOS).MSGFILNOR = [EFLD]MSGFILNOR
    this.ESTF(WPOS).PTCCOD    = [EFLD]PTCCOD
    this.ESTF(WPOS).REPCOD    = fmet this.ACTX.ACACHE.EMS.AGETVALCHAR([EFLD]MSGCOD,[EFLD]MSGREL,"REPCOD") #[EFLD]REPCOD
  Next
  Filter [EFLD]
  LogicClose File [EFLD]
  ARET_VALUE = [V]CST_AOK
Return

#********************************************************************
# Method MET_RAZ_DATA
#********************************************************************
#
#********************************************************************
$MET_RAZ_DATA
  this.CATCOD = ""
  this.PARCOD = ""
  this.PTCCOD = ""
  this.CATACT = 1
  Call DELETELINES(this, "ESTF") From EDILIBA
  Call DELETELINES(this, "ESTU") From EDILIBA
  ARET_VALUE = [V]CST_AOK
Return



#********************************************************************
# Method MET_LOG_INSERT_EVENT
#********************************************************************
# @param WTIMESTAMP
# @param WFLOSTP    M2014 1:Etape1/2:Etape2/3:Etape3/4:Etape4...
# @param WSEV
# @param WMSGNUM
# @param WINFO
#********************************************************************
$MET_LOG_INSERT_EVENT
  Local Integer WOK
  WOK = [V]CST_AOK

  Local Integer WPOS
  WPOS = fmet this.ADDLINE("ESTE", [V]CST_ALASTPOS)
  this.ESTE(WPOS).TIMESTAMP = datetime$
  this.ESTE(WPOS).FLOSTP    = WFLOSTP
  Case WSEV
    When [V]CST_AINFO    : this.ESTE(WPOS).SEV       = 1
    When [V]CST_AWARNING : this.ESTE(WPOS).SEV       = 2
    When [V]CST_AERROR   : this.ESTE(WPOS).SEV       = 3
    When Default : this.ESTE(WPOS).SEV       = 1
  Endcase
  this.ESTE(WPOS).MSGNUM    = WMSGNUM

  If WSEV = [V]CST_AERROR
    this.ESTE(WPOS).ERRSTA    = [V]CST_AYES
  Else
    this.ESTE(WPOS).ERRSTA    = [V]CST_ANO
  Endif

  this.ESTE(WPOS).INFO      = WINFO
#  this.ESTE(WPOS).ERR       = "" #to delete ??

  WOK = fmet this.AUPDATE()

  ARET_VALUE = WOK
Return



#********************************************************************
# Method MET_INSTANCIATE_REP
#********************************************************************
#@param WREPCOD_NUM
#@param WINFO
#@param WINFO1
#@param WDUPLICATEFLG
#@param WTESTFLG
#@param WSEPDEC #114721
#@param WEDISTRISS
#
#*!
$MET_INSTANCIATE_REP
  # step 1 : Instantiate the document representation using the flow information (message mapping parameters
  # and transcoding functions and operations)
  Local Integer I, K, WI
  Local Integer WOK : WOK = [V]CST_AERROR

  Local Char WREPCOD_TAB(20)(1..)
#  Local Integer WREPCOD_INDEX_TAB(1..)
  Local Char WREP(22)
  Local Char WETAG(50)       # etags of entity to store
  Local Char WMSG(250)      #returned
  Local Clbfile WJSON_UUID   #returned
  Local Clbfile WJSON_CLB(0) # JSON of entity return by storage
  Local Char WERR(250)
  K = 1
  # Get an array of REPCOD depending of number of message mappings

  For I = 1 To maxtab(this.ESTU)
    If this.ESTU(I).CODE = "REPCOD"+num$(WREPCOD_NUM)
      WREPCOD_TAB(K)       = "R_"+this.ESTU(I).DOCCLASS
      # step 1 : Instantiate the document representation
      Local Instance WMYREP Using =WREPCOD_TAB(K)
      WMYREP = NewInstance With =WREPCOD_TAB(K)

#      WOK = fmet WMYREP.AREAD(this.ESTU(I).DOCKEY) #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
      #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
      Local Char WCATTRGTAB(30)  : WCATTRGTAB   = ""
      Local Char WKEY(100)       : WKEY         = ""
      WCATTRGTAB  = func EDIISSSTD.SEARCH_ECA_FLD(this.CATCOD,this.PARCOD,"CATTRGTAB")
      WKEY        = func EDIISSSTD.SEARCH_ECA_FLD(this.CATCOD,this.PARCOD,"DESCRIPT")
      Local Char    WTAB_KEY_FLD(30)(1..) : Call PARSE_KEY_FLD(WKEY, WTAB_KEY_FLD) From EDIISSSTD
      Local Char    WTAB_KEY_VAL(30)(1..) : Call PARSE_KEY_VAL(this.ESTU(I).DOCKEY, WTAB_KEY_VAL) From EDIISSSTD
      Local Integer WTAB_KEY_TYPE(1..)
      Local Char    WSTR_KEY(250) : WSTR_KEY = ""
      If clalev ([F:ATZ]) = 0 : Local File ATABZON [ATZ] : Endif
      If clalev ([F:ATY]) = 0 : Local File ATYPE [ATY] : Endif
      For WI = 1 To maxtab(WTAB_KEY_FLD)
        #check zone
        Read [ATZ]CODZONE = WEDISTRISS.CATTRGTAB;WTAB_KEY_FLD(WI)
        If !fstat
          #get type
          Read [ATY]CODTYP = [F:ATZ]CODTYP
          If !fstat
            WTAB_KEY_TYPE(WI) = [F:ATY]TYPTYP
          Endif
        Endif
        If WI > 1 : WSTR_KEY += ',' : Endif
        Case WTAB_KEY_TYPE(WI)
          When 1,2,3,4,5,6 #1 - MENU Local #2 - ENTIER COURT #3 - ENTIER LONG #4 - DÉCIMAL #5 - FLOTTANT #6 - Double
            WSTR_KEY += WTAB_KEY_VAL(WI)
          When 7 #7 - ALPHANUMÉRIQUE
            WSTR_KEY  +=  "'"+WTAB_KEY_VAL(WI)+"'"
          When Default #8 - Date #9 - BLOB #10 - CLOB #11 - UUID #12 - Datetime A REVOIR...
            WSTR_KEY  +=  "'"+WTAB_KEY_VAL(WI)+"'"
        Endcase
      Next
      LogicClose File [F:ATZ]
      LogicClose File [F:ATY]

      WOK = evalue("fmet WMYREP.AREAD("+WSTR_KEY+")")
      If WOK = [V]CST_AOK
# issue 114721 Decimal separator in generated file
      # WOK = fmet WMYREP.MET_AFTER_LOAD_REPRESENTATION(this.CATACT, this.CATCOD, this.PARCOD, WDUPLICATEFLG, WTESTFLG, WERR)
       WOK = fmet WMYREP.MET_AFTER_LOAD_REPRESENTATION(this.CATACT, this.CATCOD, this.PARCOD, WDUPLICATEFLG, WTESTFLG, WSEPDEC, WERR)
 #/ 114721
        If WOK <> [V]CST_AOK
          WINFO1 = "Error loading representation"
          #WERR <>"" "Not authorized function" 110811 US9
          If WERR<>"": WINFO1=WERR: Endif #110811 US9
          WOK = [V]CST_AERROR
        Else
          # step 2 : Call a Supervisor method to serialize the instance of representation
          WJSON_CLB = ""
#          WOK = func ASYREIP.EXPORT_DATA_DETAIL(WMYREP, [V]CST_ANO, WJSON_CLB, WMSG)
          WOK = func ASYREIP.EXPORT_DATA_DETAIL_FULL(WMYREP, [V]CST_ANO, [V]CST_ATRUE, WJSON_CLB, WMSG) #X3-74605 JUCON (14/06/2018)
          If WOK = [V]CST_AOK and maxtab(WJSON_CLB) > 0

            WOK = func ASYREIP.MDB_CREATE_EDI_ENTITY(WJSON_CLB, this.ESTU(I).DOCKEY,"jsoncache",WETAG,WJSON_UUID,WMSG)
            If WOK = [V]CST_AOK and WJSON_UUID <> "" #Issue 111819 - 2015-10-20
              this.ESTU(I).DOCUUID = toUuid(WJSON_UUID)
              WJSON_CLB = ""
              WINFO = WREPCOD_TAB(K)
              WINFO1 = WJSON_UUID
              WOK = [V]CST_AOK
            Else
            #supprimer si elle existe deja
              WOK = func ASYREIP.MDB_DELETE_EDI_ENTITY_ID(this.ESTU(I).DOCKEY,"jsoncache",WMSG)
              If WOK = [V]CST_AOK
                WOK = func ASYREIP.MDB_CREATE_EDI_ENTITY(WJSON_CLB, this.ESTU(I).DOCKEY,"jsoncache",WETAG,WJSON_UUID,WMSG)
                If WOK = [V]CST_AOK and WJSON_UUID <> "" #Issue 111819 - 2015-10-20
                  #tester WOK, WMSG, WJSON_UUID
                  this.ESTU(I).DOCUUID = toUuid(WJSON_UUID)
                  WJSON_CLB = ""
                  WINFO  = WREPCOD_TAB(K)
                  WINFO1 = WJSON_UUID
                  WOK = [V]CST_AOK
                Else
                  WINFO  = WREPCOD_TAB(K)
                  #"No instance generated"
                  WINFO1 = mess(22,2007,1)-"("+WMSG+")"
                  WOK = [V]CST_AERROR
                Endif
              Else
                WINFO  = WREPCOD_TAB(K)
                #"No instance generated"
                WINFO1 = mess(22,2007,1)-"("+WMSG+")"
                WOK = [V]CST_AERROR
              Endif
            Endif
          Else
            #ERROR
            WINFO  = WREPCOD_TAB(K)
            #"No instance exported"
            WINFO1 = mess(21,2007,1)-WMSG
            WOK = [V]CST_AERROR
          Endif
          WREP = ""
          Break
        Endif
      Else
        WINFO  = WREPCOD_TAB(K)
        #"Instance not loaded"
        WINFO1 = mess(23,2007,1)
        #"Not authorized function" 110811 US9
        If WMYREP.AERROR.MES <> ""
          WINFO1= WMYREP.AERROR.MES
        Endif
        WOK = [V]CST_AERROR
      Endif

      FreeGroup WMYREP : WMYREP = null
      K = K + 1
      Break
    Endif
  Next I
  ARET_VALUE = WOK
Return

#********************************************************************
# Method MET_INS_GET_VALUE
#********************************************************************
# @param WPROPERTY
# @param WVALUE RETURNED
# @return WOK
#********************************************************************
$MET_INS_GET_VALUE
  # step 1 : Instantiate the document representation using the flow information (message mapping parameters
  # and transcoding functions and operations)
  Local Integer I, K
  Local Integer WOK : WOK = [V]CST_AERROR

  Local Char WREPCOD_TAB(20)(1..)

  K = 1
  # Get an array of REPCOD depending of number of message mappings
  For I = 1 To maxtab(this.ESTU)   #in V1, only 1 line !
    If left$(this.ESTU(I).CODE, 6) = "REPCOD"
      WREPCOD_TAB(K)       = "R_"+this.ESTU(I).DOCCLASS
      # step 1 : Instantiate the document representation
      Local Instance WMYREP Using =WREPCOD_TAB(K)
      WMYREP = NewInstance With =WREPCOD_TAB(K)
      WOK = fmet WMYREP.AREAD(this.ESTU(I).DOCKEY)
      If WOK = [V]CST_AOK
        #get value
        WVALUE = num$(evalue("WMYREP."+WPROPERTY))
      Else
        #"No instance saved"
        WINFO = mess(117,2006,1)
        WOK = [V]CST_AERROR
      Endif
      FreeGroup WMYREP : WMYREP = null
      K = K + 1
      Break
    Endif
  Next I
  ARET_VALUE = WOK
Return



#********************************************************************
# Method MET_COPY_SAS
#********************************************************************
# WNEWKEYDOC is inline
#********************************************************************
$MET_COPY_SAS
  Local Integer WOK : WOK = [V]CST_ATRUE
  Local Char WNUMBATCH(20)
  Local Char WKEYDOC(20)

  WNUMBATCH = this.NUMBATCH
  WKEYDOC   = this.KEYDOC

  If WOK = [V]CST_ATRUE
    Local File EDISTO [EST]
    Read [EST]EST0 = WNUMBATCH; WKEYDOC
    If !fstat
      Local File EDISTO [EST1]
      Trbegin [EST1]
      [F:EST1]       = [F:EST]
      [F:EST1]KEYDOC = WNEWKEYDOC
      Write
      If !fstat
        Commit
        WOK = [V]CST_ATRUE
      Else
        Rollback
        WOK = [V]CST_AFALSE
      Endif
      LogicClose File [EST1]
    Else
    #error
    Endif
    LogicClose File [EST]
  Endif


  If WOK = [V]CST_ATRUE
    Local File EDISTOC [ESTC]
    Filter [ESTC] Where NUMBATCH = WNUMBATCH and KEYDOC = WKEYDOC
    For [ESTC]
      Local File EDISTOC [ESTC1]
      Trbegin [ESTC1]
      [F:ESTC1]       = [F:ESTC]
      [F:ESTC1]KEYDOC = WNEWKEYDOC
      Write
      If !fstat
        Commit
        WOK = [V]CST_ATRUE
      Else
        Rollback
        WOK = [V]CST_AFALSE
      Endif
      LogicClose File [ESTC1]
    Next
    LogicClose File [ESTC]
  Endif

    Local File EDISTOE [ESTE]
    Filter [ESTE] Where NUMBATCH = WNUMBATCH and KEYDOC = WKEYDOC
    For [ESTE]
      Local File EDISTOE [ESTE1]
      Trbegin [ESTE1]
      [F:ESTE1]       = [F:ESTE]

      [F:ESTE1]KEYDOC = WNEWKEYDOC
      Write
      If !fstat
        Commit
        WOK = [V]CST_ATRUE
      Else
        Rollback
        WOK = [V]CST_AFALSE
      Endif
      LogicClose File [ESTE1]
    Next
    LogicClose File [ESTE]

    Local File EDISTOF [ESTF]
    Filter [ESTF] Where NUMBATCH = WNUMBATCH and KEYDOC = WKEYDOC
    For [ESTF]
      Local File EDISTOF [ESTF1]
      Trbegin [ESTF1]
      [F:ESTF1]       = [F:ESTF]
      [F:ESTF1]KEYDOC = WNEWKEYDOC
      Write
      If !fstat
        Commit
        WOK = [V]CST_ATRUE
      Else
        Rollback
        WOK = [V]CST_AFALSE
      Endif
      LogicClose File [ESTF1]
    Next
    LogicClose File [ESTF]

    Local File EDISTOJ [ESTJ]
    Filter [ESTJ] Where NUMBATCH = WNUMBATCH and KEYDOC = WKEYDOC
    For [ESTJ]
      Local File EDISTOJ [ESTJ1]
      Trbegin [ESTJ1]
      [F:ESTJ1]       = [F:ESTJ]
      [F:ESTJ1]KEYDOC = WNEWKEYDOC
      Write
      If !fstat
        Commit
        WOK = [V]CST_ATRUE
      Else
        Rollback
        WOK = [V]CST_AFALSE
      Endif
      LogicClose File [ESTJ1]
    Next
    LogicClose File [ESTJ]


    Local File EDISTOU [ESTU]
    Filter [ESTU] Where NUMBATCH = WNUMBATCH and KEYDOC = WKEYDOC
    For [ESTU]
      Local File EDISTOU [ESTU1]
      Trbegin [ESTU1]
      [F:ESTU1]       = [F:ESTU]
      [F:ESTU1]KEYDOC = WNEWKEYDOC
      Write
      If !fstat
        Commit
        WOK = [V]CST_ATRUE
      Else
        Rollback
        WOK = [V]CST_AFALSE
      Endif
      LogicClose File [ESTU1]
    Next
    LogicClose File [ESTU]

Return

#********************************************************************
# Method MET_DEL_JSON
#********************************************************************
#*
#
#*
#********************************************************************
#* @param WERR
#* @return WOK
#*!
$MET_DEL_JSON
  Local Integer WOK    : WOK = [V]CST_AOK
  Local Integer I
  Local Integer WNBERR : WNBERR = 0
  Local Char WMSG(250) : WMSG = ""
  Local Char WERR(250) : WERR = ""

  For I = 1 To maxtab(this.ESTU)
    If this.ESTU(I).DOCUUID <> NullUuid() and (left$(this.ESTU(I).CODE, 6) = "REPCOD" or left$(this.ESTU(I).CODE, 6) = "INSFIL")
      WOK = func ASYREIP.MDB_DELETE_EDI_ENTITY_UUID(num$(this.ESTU(I).DOCUUID),WMSG)
      If WOK = [V]CST_AOK
        #"Deleting entity in cache : Successful"
        WERR = mess(58,2007,1)-":"-mess(7,2007,1)-num$(this.ESTU(I).DOCUUID)
        ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AINFO)
        this.ESTU(I).DOCUUID = NullUuid()
      Else
        #"Deleting entity in cache : failed"
        WNBERR = WNBERR + 1
        WERR = mess(58,2007,1)-":"-mess(9,2007,1)-"("+WMSG+")"
        ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AWARNING)
      Endif
    Endif
  Next I

  If WNBERR > 0
    WOK = [V]CST_AERROR
  Else
    WOK = [V]CST_AINFO
  Endif

  ARET_VALUE = WOK
Return


#********************************************************************
# Funprog SAS_INSERT_ERROR_JS
#********************************************************************
#*
#*
#*
#********************************************************************
#@param WNUMBATCH
#@param WKEYDOC
#@param WFLOCOD
#@param WMESSAGE
#@param WSTACK
#@param WSEVERITY
#@param WINS_UUID
#@param WMYLOG
#@return WOK
#*!
Funprog SAS_INSERT_ERROR_JS(WNUMBATCH, WKEYDOC, WMESSAGE, WSTACK, WSEVERITY, WINS_UUID, WMYLOG)
Value Char WNUMBATCH
Value Char WKEYDOC
Value Char WMESSAGE
Value Clbfile WSTACK
Value Char WSEVERITY
Value Char WINS_UUID
Variable Instance WMYLOG Using C_ALOG

  Local Integer WSORT, WNUMLIN
  Local Integer WLOG
  Local Integer WOK    : WOK = [V]CST_AOK
  Local Integer WFOUND : WFOUND = [V]CST_AFALSE

  Local File EDISTOJ [ESTJ]
  Filter [ESTJ] Where [ESTJ]NUMBATCH = WNUMBATCH and [ESTJ]KEYDOC = WKEYDOC Order By Key ESTJ0 Desc
  For [ESTJ]
    WFOUND = [V]CST_ATRUE
    #le 1e à l'envers est lu
    WSORT   = [ESTJ]SORT + 10
    WNUMLIN = [ESTJ]NUMLIN + 10
    Break
  Next
  If WFOUND = [V]CST_AFALSE
    WSORT   = 10
    WNUMLIN = 10
  Endif
  Filter [ESTJ]
  LogicClose File [ESTJ]


  Local File EDISTOJ [ESTJ]
  Trbegin [ESTJ]
  [ESTJ]NUMBATCH  = WNUMBATCH
  [ESTJ]KEYDOC    = WKEYDOC
  [ESTJ]NUMLIN    = WNUMLIN
  [ESTJ]SORT      = WSORT
  [ESTJ]TIMESTAMP = datetime$
  [ESTJ]MESSAGE   = WMESSAGE
  [ESTJ]SEVERITY  = WSEVERITY
  [ESTJ]INSUUID   = toUuid(WINS_UUID)
  Write [ESTJ]
  If !fstat
    Commit

    Local File EDISTOC [ESTC]
    Trbegin [ESTJ]
    [ESTC]NUMBATCH   = [ESTJ]NUMBATCH
    [ESTC]KEYDOC     = [ESTJ]KEYDOC
    [ESTC]NUMLIN     = [ESTJ]NUMLIN
    [ESTC]STACKTRACE = WSTACK
    Write [ESTC]
    If !fstat
      Commit
      WOK = [V]CST_AOK
    Else
      #error to log in trace file only
      #"Creation of a log line : failed"
      WLOG = fmet WMYLOG.APUTLINE(mess(54,2007,1)-":"-mess(9,2007,1), [V]CST_AERROR)
      Rollback
      WOK = [V]CST_AERROR
    Endif

    LogicClose File [ESTC]
#    WOK = [V]CST_AOK
  Else
    #error to log in trace file only
    #"Creation of a log line : failed"
    WLOG = fmet WMYLOG.APUTLINE(mess(54,2007,1)-":"-mess(9,2007,1), [V]CST_AERROR)
    Rollback
    WOK = [V]CST_AERROR
  Endif

  LogicClose File [ESTJ]
End WOK



Funprog SAS_UPDATE_STA(WNUMBATCH, WKEYDOC, WSTA)
Value Char WNUMBATCH #20
Value Char WKEYDOC   #60
Value Integer WSTA

  Local Integer WOK

  #testing parameters
  If WNUMBATCH = "" or WKEYDOC = ""
    WOK = [V]CST_AERROR
  Else
    Local File EDISTO [EST]
    Read [EST]EST0 = WNUMBATCH; WKEYDOC
    If !fstat
      Trbegin [EST]
      [EST]STA = WSTA
      Rewrite
      If !fstat
        Commit
        WOK = [V]CST_AOK
      Else
        Rollback
        WOK = [V]CST_AERROR
      Endif
    Else
      WOK = [V]CST_AERROR
    Endif
  Endif
End WOK


#********************************************************************
# Funprog GET_UUID
#********************************************************************
#*
#*
#*
#********************************************************************
#@param WCODE
#@param WDOCKEY
#@param WEDISTO
#@return WDOCUUID
#*!
Funprog GET_UUID(WCODE, WEDISTO)
Value Char WCODE
Variable Instance WEDISTO Using C_EDISTO

  Local Char WDOCUUID(36) : WDOCUUID = ""
  Local Integer WOK : WOK = [V]CST_AERROR
  If WCODE <> ""
    For I = 1 To maxtab(WEDISTO.ESTU)
      If WEDISTO.ESTU(I).CODE = WCODE
        WDOCUUID = num$(WEDISTO.ESTU(I).DOCUUID)
        WOK = [V]CST_AOK
        Break
      Endif
    Next
  Endif
End WDOCUUID


#********************************************************************
# Funprog SET_UUID
#********************************************************************
#*
#*
#*
#********************************************************************
#@param WCODE
#@param WDOCKEY
#@return WDOCUUID
#*!
Funprog SET_UUID(WCODE, WDOCKEY)
Value Char WCODE
Value Char WDOCKEY

  Local Char WTAB_INDEX_KEYS(20)(1..)
  Local Char WDOCUUID(36) : WDOCUUID = num$(NullUuid())

  If WCODE <> "" and WDOCKEY <> ""
    Local Integer WOK
    WOK = func GET_INDEX(WCODE, WDOCKEY, WTAB_INDEX_KEYS)
    If WOK = [V]CST_AOK
      Case WCODE
        When "EDIFLO"     : WDOCUUID = func GET_FLO_CACHEUUID(WTAB_INDEX_KEYS)
        When "EDIPTC"     : WDOCUUID = func GET_PTC_CACHEUUID(WTAB_INDEX_KEYS)
        When "EDIMSG1"    : WDOCUUID = func GET_MSG_CACHEUUID(WTAB_INDEX_KEYS)
        When "EDISEQFIL1" : WDOCUUID = func GET_SEQ_CACHEUUID(WTAB_INDEX_KEYS)
        When "EDIXMLFIL1" : WDOCUUID = func GET_XML_CACHEUUID(WTAB_INDEX_KEYS)
        When Default      : WDOCUUID = num$(NullUuid())
      Endcase
    Endif
  Endif
End WDOCUUID


#********************************************************************
# Funprog GET_DOCKEY
#********************************************************************
#*
#*
#*
#********************************************************************
#@param WCODE
#@param WDOCKEY
#@param WEDISTO
#@return WDOCKEY
#*!
Funprog GET_DOCKEY(WCODE, WEDISTO)
Value Char WCODE
Variable Instance WEDISTO Using C_EDISTO

  Local Char WDOCKEY(50) : WDOCKEY = ""
  Local Integer WOK : WOK = [V]CST_AERROR
  If WCODE <> ""
    For I = 1 To maxtab(WEDISTO.ESTU)
      If WEDISTO.ESTU(I).CODE = WCODE
        WDOCKEY = num$(WEDISTO.ESTU(I).DOCKEY)
        WOK = [V]CST_AOK
        Break
      Endif
    Next
  Endif
End WDOCKEY


#********************************************************************
# Funprog SET_DOCKEY
#********************************************************************
#*
#*
#*
#********************************************************************
#@param WNUMBATCH
#@param WDOCID
#@param WCODE
#@param WDOCKEY
#@return WOK
#*!
Funprog SET_DOCKEY(WNUMBATCH, WDOCID, WCODE, WDOCKEY)
Value Char WNUMBATCH #20
Value Char WDOCID
Value Char WCODE
Value Char WDOCKEY

  Local Integer WOK : WOK = [V]CST_AOK
  Local Integer I
  Local Integer WFOUND : WFOUND = [V]CST_AFALSE

  #testing parameters
  If WNUMBATCH = "" or WDOCID = ""
    WOK = [V]CST_AERROR
  Else
    ##### New SAS
    Local Instance WMYEDISTO Using C_EDISTO
    WMYEDISTO = NewInstance C_EDISTO AllocGroup null
    WOK = fmet WMYEDISTO.AREAD(WNUMBATCH,WDOCID)
    If WOK = [V]CST_AOK
      WFOUND = [V]CST_AFALSE
      For I = 1 To maxtab(WMYEDISTO.ESTU)
        If WMYEDISTO.ESTU(I).CODE  = WCODE
          WMYEDISTO.ESTU(I).DOCKEY = WDOCKEY
          WFOUND = [V]CST_ATRUE
          Break
        Endif
      Next
      If WFOUND = [V]CST_AFALSE
        #on doit le créer
        If left$(WCODE, 7) = "PHYFILE"
          WPOS = fmet WMYEDISTO.ADDLINE("ESTU", [V]CST_ALASTPOS)
          WMYEDISTO.ESTU(WPOS).CODE     = WCODE
          WMYEDISTO.ESTU(WPOS).DOCDES   = mess(5,7959,1)-"/"-mess(116,2006,1) #"Data / Physical file"
          WMYEDISTO.ESTU(WPOS).DOCUUID  = NullUuid
          WMYEDISTO.ESTU(WPOS).DOCCLASS = ""
          WMYEDISTO.ESTU(WPOS).DOCKEY   = WDOCKEY
        Endif
      Endif
      WOK = fmet WMYEDISTO.AUPDATE()
    Else
      #AREAD in error
    Endif
    FreeGroup WMYEDISTO : WMYEDISTO = null
  Endif
End WOK


#********************************************************************
# Funprog GET_DOCCLASS
#********************************************************************
#*
#*
#*
#********************************************************************
#@param WCODE
#@param WDOCKEY
#@param WEDISTO
#@return WDOCKEY
#*!
Funprog GET_DOCCLASS(WCODE, WEDISTO)
Value Char WCODE
Variable Instance WEDISTO Using C_EDISTO

  Local Char WDOCCLASS(50) : WDOCCLASS = ""
  Local Integer WOK : WOK = [V]CST_AERROR
  If WCODE <> ""
    For I = 1 To maxtab(WEDISTO.ESTU)
      If WEDISTO.ESTU(I).CODE = WCODE
        WDOCCLASS = num$(WEDISTO.ESTU(I).DOCCLASS)
        WOK = [V]CST_AOK
        Break
      Endif
    Next
  Endif
End WDOCCLASS



#********************************************************************
# Funprog GET_INDEX
#********************************************************************
#*
#*
#*
#********************************************************************
#@param WCODE
#@param WDOCKEY
#@param WTAB_INDEX_KEYS
#@return WOK
#*!
Funprog GET_INDEX(WCODE, WDOCKEY, WTAB_INDEX_KEYS)
Value Char WCODE
Value Char WDOCKEY
Variable Char WTAB_INDEX_KEYS()(1..)

  Local Integer WPOS, I, K, WOK
  WOK = [V]CST_AERROR

  If WCODE <> "" and WDOCKEY <> ""
    #split key
    K = 1
    For I = 1 To len(WDOCKEY)
#      WPOS = instr(I, WDOCKEY, "~") #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
      WPOS = instr(I, WDOCKEY, "!") #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
      If WPOS = 0 : WPOS = instr(I, WDOCKEY, "~") : Endif  #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
      If WPOS > 0
        WTAB_INDEX_KEYS(K) = left$(WDOCKEY, WPOS-1)
        K = K + 1
        WDOCKEY = right$(WDOCKEY, WPOS+1)
      Endif
    Next
    If WPOS <= 0
      WTAB_INDEX_KEYS(K) = WDOCKEY
    Endif
    WOK = [V]CST_AOK
  Endif

End WOK

#********************************************************************
# Funprog GET_PTC_CACHEUUID
#********************************************************************
#*
#*
#*
#********************************************************************
#@param WTAB_INDEX_KEYS
#@return WCACHEUUID
#*!
Funprog GET_PTC_CACHEUUID(WTAB_INDEX_KEYS)
Value Char WTAB_INDEX_KEYS()(1..)

  Local Char WCACHEUUID(36)

  Local File EDIPTC [EPT]
  Read [F:EPT]EPT0 = WTAB_INDEX_KEYS(1)
  If !fstat
    WCACHEUUID = num$([EPT]CACHEUUID)
  Else
    WCACHEUUID = ""
  Endif
  LogicClose File [EPT]
End WCACHEUUID

