#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Data Class EDISTO                                                           #
# Manages data class EDISTO                                                   #
# Author : RBA                                                                #
###############################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ADELETE_BEFORE"         : Gosub ADELETE_BEFORE
      Endcase
    When "ESTF"
      Case [L]AEVENT
        When "ADDLINE_AFTER"          : Gosub ESTF_ADDLINE_AFTER
      Endcase
    When "ESTU"
      Case [L]AEVENT
        When "ADDLINE_AFTER"          : Gosub ESTU_ADDLINE_AFTER
      Endcase
    When "ESTE"
      Case [L]AEVENT
        When "ADDLINE_AFTER"          : Gosub ESTE_ADDLINE_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_GET_STO_PROPERTIES" : Gosub MET_GET_STO_PROPERTIES
    When "MET_GET_FLO_PROPERTIES" : Gosub MET_GET_FLO_PROPERTIES
    When "MET_RAZ_DATA"           : Gosub MET_RAZ_DATA
    When "MET_LOG_INSERT_EVENT"   : Gosub MET_LOG_INSERT_EVENT
    When "MET_INSTANCIATE_REP"    : Gosub MET_INSTANCIATE_REP
    When "MET_INS_GET_VALUE"      : Gosub MET_INS_GET_VALUE
    When "MET_COPY_SAS"           : Gosub MET_COPY_SAS
    When "MET_DEL_JSON"           : Gosub MET_DEL_JSON
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "FLOCOD"
      Case [L]ARULE
        When 'PROPAGATE'    : Gosub FLOCOD_PROPAGATE
      Endcase
    When "FLOREL"
      Case [L]ARULE
        When 'PROPAGATE'    : Gosub FLOREL_PROPAGATE
      Endcase
    When "STA"
      Case [L]ARULE
        When 'INIT'         : Gosub STA_INIT
        When 'PROPAGATE'    : Gosub STA_PROPAGATE
      Endcase
    When "ESTU.DOCKEY"
      Case [L]ARULE
        When "PROPAGATE"    : Gosub ESTU_DOCKEY_PROPAGATE
      Endcase
  Endcase
Return

####################################################################

$FLOCOD_PROPAGATE
  Gosub FLOCOD_AND_FLOREL_PROPAGATE
Return

####################################################################

$FLOREL_PROPAGATE
  Gosub FLOCOD_AND_FLOREL_PROPAGATE
Return

$FLOCOD_AND_FLOREL_PROPAGATE
  Local Integer WOK
#  Local Char WERR(100)

  If this.FLOCOD <> "" and this.FLOREL <> ""
    #tester que le flux est valide et actif
    Local File EDIFLO [EFL]
    #"Flow control"
    Read [EFL]EFL0=this.FLOCOD;this.FLOREL
    If !fstat
      If [EFL]VALID = [V]CST_AYES and [EFL]FLGACT = [V]CST_AYES
      WOK = fmet this.MET_GET_FLO_PROPERTIES()
      WOK = fmet this.MET_GET_STO_PROPERTIES()
      WOK = fmet this.MET_LOG_INSERT_EVENT(datetime$, 1, [V]CST_AINFO, 22, this.FLOCOD+"~"+this.FLOREL)
      Gosub MSGCOD_AND_MSGREL_PROPAGATE
      Else
        WOK = fmet this.MET_RAZ_DATA()
        WOK = fmet this.MET_LOG_INSERT_EVENT(datetime$, 1, [V]CST_AWARNING, 22, this.FLOCOD+"~"+this.FLOREL)
        this.STA = 3 #transfert error
      Endif
    Else
      WOK = fmet this.MET_RAZ_DATA()
      WOK = fmet this.MET_LOG_INSERT_EVENT(datetime$, 1, [V]CST_AERROR, 22, this.FLOCOD+"~"+this.FLOREL)
      this.STA = 3 #transfert error
    Endif
    LogicClose File [EFL]
  Elsif this.FLOCOD = "" or this.FLOREL = ""
    WOK = fmet this.MET_RAZ_DATA()
    this.STA = 1 #pending
  Endif
Return


$MSGCOD_AND_MSGREL_PROPAGATE
  Local Integer WOK
#  Local Char WERR(100)

  If this.FLOCOD <> "" and this.FLOREL <> ""
    #tester que le flux est valide et actif
    Local File EDIFLOD [EFLD] #in V1, only one line sequential with Query : WNBMSG = 1 max
#    Filter [EFLD] Where [EFLD]FLOCOD = this.FLOCOD and [EFLD]FLOREL = this.FLOREL and [EFLD]MSGTYP = 1 and [EFLD]MSGFOR = 1 #Query and #Sequential  # SAM 110699
    Filter [EFLD] Where [EFLD]FLOCOD = this.FLOCOD and [EFLD]FLOREL = this.FLOREL and [EFLD]MSGTYP = 1      # SAM 110699
    For [EFLD] #in V1, only one line sequential with Query : NB MSG = 1 max
      #get UUID of each setup needed (context)
      Local File EDIMSG [EMS]
      #"Message mapping control"
      Read [EMS]EMS0  = [EFLD]MSGCOD; [EFLD]MSGREL
      If !fstat
        If [EMS]VALID = [V]CST_AYES
          WOK = fmet this.MET_LOG_INSERT_EVENT(datetime$, 2, [V]CST_AINFO, 23, [EFLD]MSGCOD+"~"+[EFLD]MSGREL)
          this.STA = 1 #pending
          #CACHEUUID
        Else
          WOK = fmet this.MET_LOG_INSERT_EVENT(datetime$, 2, [V]CST_AWARNING, 23, [EFLD]MSGCOD+"~"+[EFLD]MSGREL)
          this.STA = 3 #transfert error
        Endif
      Else
        WOK = fmet this.MET_LOG_INSERT_EVENT(datetime$, 2, [V]CST_AERROR, 23, [EFLD]MSGCOD+"~"+[EFLD]MSGREL)
        this.STA = 3 #transfert error
      Endif
      LogicClose File [EMS]

      If [EFLD]MSGFOR = 1# SAM 110699
        Local File EDISEQFIL [ESF]
        #"Sequential file control"
#       WERR = mess(32,2007,1)
        Read [ESF]ESF0  = [EFLD]MSGCOD; [EFLD]MSGREL; [EFLD]MSGFILNOR
        If !fstat
          If [ESF]VALID = [V]CST_AYES
            WOK = fmet this.MET_LOG_INSERT_EVENT(datetime$, 3, [V]CST_AINFO, 24, [EFLD]MSGCOD+"~"+[EFLD]MSGREL+"~"+[EFLD]MSGFILNOR)
            this.STA = 1 #pending
            #CACHEUUID
          Else
            WOK = fmet this.MET_LOG_INSERT_EVENT(datetime$, 3, [V]CST_AINFO, 24, [EFLD]MSGCOD+"~"+[EFLD]MSGREL+"~"+[EFLD]MSGFILNOR)
            this.STA = 3 #transfert error
          Endif
        Else
          WOK = fmet this.MET_LOG_INSERT_EVENT(datetime$, 3, [V]CST_AINFO, 24, [EFLD]MSGCOD+"~"+[EFLD]MSGREL+"~"+[EFLD]MSGFILNOR)
          this.STA = 3 #transfert error
        Endif
        LogicClose File [ESF]
      Else    # Init SAM 110699
        Local File EDIXMLFIL [EXF]
        #"XML file control"
        Read [EXF]EXF0  = [EFLD]MSGCOD; [EFLD]MSGREL; [EFLD]MSGFILNOR
        If !fstat
          If [EXF]VALID = [V]CST_AYES
            WOK = fmet this.MET_LOG_INSERT_EVENT(datetime$, 3, [V]CST_AINFO, 24, [EFLD]MSGCOD+"~"+[EFLD]MSGREL+"~"+[EFLD]MSGFILNOR)
            this.STA = 1 #pending
            #CACHEUUID
          Else
            WOK = fmet this.MET_LOG_INSERT_EVENT(datetime$, 3, [V]CST_AINFO, 24, [EFLD]MSGCOD+"~"+[EFLD]MSGREL+"~"+[EFLD]MSGFILNOR)
            this.STA = 3 #transfert error
          Endif
        Else
          WOK = fmet this.MET_LOG_INSERT_EVENT(datetime$, 3, [V]CST_AINFO, 24, [EFLD]MSGCOD+"~"+[EFLD]MSGREL+"~"+[EFLD]MSGFILNOR)
          this.STA = 3 #transfert error
        Endif
        LogicClose File [EXF]
      Endif # End SAM 110699

    Next
    Filter [EFLD]
    LogicClose File [EFLD]
  Endif
Return

####################################################################

$STA_INIT
  this.STA = 1
Return

$STA_PROPAGATE
Return

#####################################################################

$ESTU_DOCKEY_PROPAGATE
  Local Char WDOCUUID(36)
  WDOCUUID = func SET_UUID(this.CODE, this.DOCKEY)
  If WDOCUUID <> ""
    this.DOCUUID = toUuid(WDOCUUID)
  Else
    this.DOCUUID = NullUuid()
  Endif
Return


#********************************************************************
# Method ESTF_ADDLINE_AFTER
#********************************************************************
# ESTF lines indexes managment
#********************************************************************
$ESTF_ADDLINE_AFTER
  #Add an new ligne number
  this.NUMLIN = 1 + max(this.APARENT.ESTF(1..maxtab(this.APARENT.ESTF)).NUMLIN)

  #Manage the SORT property
  Local Integer I, BEF_LINE, AFT_LINE #positions in collection (they have a 0 value here)
  #Where are the previous and next lines ?
  For I = 1 To maxtab(this.APARENT.ESTF)
    If this.APARENT.ESTF(I) <> null
      If this.APARENT.ESTF(I).AORDER = this.AORDER - 1
        BEF_LINE = I
      Elsif this.APARENT.ESTF(I).AORDER = this.AORDER + 1
        AFT_LINE = I
      Endif
    Endif
  Next I

  Local Integer BEF_LINE_SORT, AFT_LINE_SORT, OFFSET_LINE #positions in the sort order
  Local Integer MY_STEP #Step in the sort order between two records
  MY_STEP = 100
  #If the new line is inserted in the middle of the array, not in 1st position
  If AFT_LINE <> 0
    #Assign the SORT property
    AFT_LINE_SORT = this.APARENT.ESTF(AFT_LINE).SORT
    #Test if a next line exists
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.ESTF(BEF_LINE).SORT : Endif
    #If there is enough space then we insert using a dichotomy method
    If BEF_LINE_SORT <= AFT_LINE_SORT - 2
      #Assign the SORT property
      this.SORT = int((BEF_LINE_SORT + AFT_LINE_SORT)/2)
    Else
      #if there is not enough space, we reassign the SORT property of all lines from the new inserted line
      For I=1 To maxtab(this.APARENT.ESTF)
        If this.APARENT.ESTF(I) <> null
          OFFSET_LINE = this.APARENT.ESTF(I).AORDER - this.AORDER
#          If this.APARENT.ESTF(I).AORDER >= this.AORDER
          If OFFSET_LINE >= 0
            #Assign the SORT property
            this.APARENT.ESTF(I).SORT = BEF_LINE_SORT + MY_STEP + (OFFSET_LINE * MY_STEP)
          Endif
        Endif
      Next I
    Endif
  #If the new inserted line is at the 1st position in the array
  Else #If AFT_LINE = 0
    AFT_LINE_SORT = 0
    #Test if a next line exists
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.ESTF(BEF_LINE).SORT : Endif
    #Assign the SORT property
    this.SORT = BEF_LINE_SORT + MY_STEP
  Endif
Return

