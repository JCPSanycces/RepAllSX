#<AdxTL>@(#)2.0.0.0 $Revision$
########################################################################
# Traitement STKWRH - Librairie des composants de gestion de dépôts    #
########################################################################

#########################################################################
# Actions de type 'sélection table'
#------------------------------------------------------------------------
# WRHSEL   : Sélection dépôts d'un site
#########################################################################

#########################################################################
# Actions de type 'hors modèle'
#------------------------------------------------------------------------
# WRHINIT  : Initialisation du dépôt par défaut d'un document (objet)
# WRHINIT2 : Initialisation du dépôt par défaut (non objet)
# WRHCTL   : Contrôle dépôt par rapport au site
#########################################################################

#########################################################################
# Sous-Programmes (Subprog)
#------------------------------------------------------------------------
# WRHAUTO  : Recherche du dépôt par défaut d'un article-site
# GENITW   : Création automatique des articles-dépôts
# DELITW   : Suppression des articles-dépôts
#########################################################################

$ACTION
Case ACTION
  When "SEL_TABLE"      : Gosub SEL_TABLE
Endcase
Return

#########################################################################
$SEL_TABLE
Case TABLE
  When "WRHSEL"         : Gosub WRHSEL
Endcase
Return

#########################################################################
# WRHSEL      Section Dépôt
#########################################################################
$WRHSEL

Local Char    LFCY(GLONFCY)
LFCY = PARAM(1)

If clalev([F:WRH])=0 : Local File WAREHOUSE   [WRH] : Endif

TIT(0) = mess(336,184,1)

NBCOL  = 0
If LFCY=""
   NBCOL += 1 : COL(NBCOL) = "STOFCY"
   Call TEXTFIC("WAREHOUSE",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "WRH"
Call TEXTFIC("WAREHOUSE",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "WRHNAM"
Call TEXTFIC("WAREHOUSE",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "WRHSHO"
Call TEXTFIC("WAREHOUSE",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV

ORDRE   = "STOFCY;WRH"
If LFCY<>""
   CRITERE = "[F:WRH]STOFCY=LFCY"
Else
   CRITERE = ""
Endif
START   = "WRH"
SIZLIG  = 100
SIZCOL  = 200
Default File [WRH]
Return



########################################################################
# WRHINIT     Alimentation du dépôt par défaut d'un document
#             - à appeler en init du dépôt entête document 
########################################################################
# Sorties  LWRH : Dépôt par défaut
# Entrée   LFCY : Site stockage
#          LTYP : Type de flux
#                 - Entrée 1 = Réception
#                          2 = Entrée OF  
#                          3 = Réintégration de stock
#                          4 = Retour livraison
#                              --> Retour client, Avoir client
#                          5 = Mvt entrée interne  
#                              --> Entrée diverse, Assemblage
#                                  Chgt stock
#                 - Sortie 6 = Expédition
#                              --> Livraison, Facture, Retour fournisseur  
#                          7 = Expédition pour sous-traitance 
#                              --> Livraison, Plan réapprovisionnement
#                          8 = Conso matière
#                              --> Sortie OF
#                          9 = Conso matière pour sous-traitance
#                              --> Sortie OF, Sortie ordre sous-traitance  
#                         10 = Mvt sortie interne
#                              --> Sortie diverse, Désassemblage
#                                  Chgt stock, Demande service, Plan réappro 
#
########################################################################
Subprog WRHINIT(LWRH,LFCY,LTYP)
Variable Char    LWRH
Value    Char    LFCY
Value    Integer LTYP

Raz LWRH
If GWRHACT<>2 End Endif

# Pas d'initialisation du dépôt entête si document existant 
If !find(GREP,"C","D") End Endif

Gosub TRT_WRHINIT

End

########################################################################
# WRHINIT2   Alimentation du dépôt par défaut d'un document
#             - à appeler en init du dépôt entête document 
########################################################################
# Mêmes paramètres que WRHINIT
########################################################################
Subprog WRHINIT2(LWRH,LFCY,LTYP)
Variable Char    LWRH
Value    Char    LFCY
Value    Integer LTYP

Raz LWRH
If GWRHACT<>2 End Endif

Gosub TRT_WRHINIT

End

########################################################################
$TRT_WRHINIT 

If !clalev([F:FCY])  Local File FACILITY  [FCY]  Endif
If !clalev([F:WRH])  Local File WAREHOUSE [WRH]  Endif

If [F:FCY]FCY<>LFCY
   Read [FCY]FCY0=LFCY
   If fstat Raz [F:FCY] Endif
Endif
# Pas de gestion de dépôt sur le site
If [F:FCY]WRHGES<>2 End Endif

#--- Bug 65601
If GIMPORT End Endif
#---

# Alimentation du dépôt de l'utilisateur
LWRH = GUSRWRH
If LWRH<>""
   # Contrôle de cohérence du dépôt par rapport au site
   Read [WRH]WRH0=LWRH
   If fstat | [F:WRH]STOFCY<>LFCY
      Raz LWRH
   Endif  
Endif
 
If LWRH=""
   # Alimentation du dépôt du site
   Case LTYP
    When  1 : LWRH = [F:FCY]RCPWRH
    When  2 : LWRH = [F:FCY]MFPWRH
    When  3 : LWRH = [F:FCY]MFRWRH
    When  4 : LWRH = [F:FCY]RTNWRH
    When  5 : LWRH = [F:FCY]TRAWRH
    When  6 : LWRH = [F:FCY]SHIWRH
    When  7 : LWRH = [F:FCY]SCOWRH
    When  8 : LWRH = [F:FCY]MFGWRH
    When  9 : LWRH = [F:FCY]SCCWRH
    When 10 : LWRH = [F:FCY]TRFWRH
    When Default
   Endcase
Endif
Return

########################################################################
# WRHCTL      Contrôle du dépôt saisi par rapport au site
#             Action WRHCTL présente dans types de données WRH & DEP 
########################################################################
Subprog WRHCTL(AZC,FCY,OBL)
Variable Char    AZC()
Value    Char    FCY
Value    Integer OBL

# Dépôt obligatoire (transaction)
If OBL=2 & AZC=""
   GMESSAGE = mess(340,184,1)
   mkstat = 2 : End
Endif

AZC=vireblc(toupper(AZC),4)

# Si pas de site renseigné ou dépôt avec joker, pas de contrôle
If FCY="" | AZC="" | AZC<>ctrans(AZC,"*!?#","") End Endif

If !clalev([F:WRH])  Local File WAREHOUSE [WRH]  Endif

If AZC<>[F:WRH]WRH
   Read [WRH]WRH0=AZC
   If fstat 
      GMESSAGE = mess(344,184,1)
      mkstat = 2 : End
   Endif
Endif
If [F:WRH]STOFCY<>FCY
   GMESSAGE = mess(338,184,1)-FCY
   mkstat = 2 : End
Endif  

End

########################################################################
# WRHAUTO     Recherche du dépôt par défaut d'un article-site
########################################################################
# Entrée   LFCY : Site stockage
#          LITM : Article
#          LVCR : Type de document    (menu local 701)
#          LSST : Sous-traitance (0=non 1=oui)
# Sorties  LWRH : Dépôt
########################################################################
Subprog WRHAUTO(LFCY,LITM,LVCR,LSST,LWRH)
Value    Char    LFCY
Value    Char    LITM
Value    Integer LVCR
Value    Integer LSST
Variable Char    LWRH

Raz LWRH

If !clalev([F:FCY])  Local File FACILITY   [FCY]  Endif
If !clalev([F:ITF])  Local File ITMFACILIT [ITF]  Endif

If [F:FCY]FCY<>LFCY
   Read [FCY]FCY0=LFCY
   If fstat | [F:FCY]WRHGES<>2 End Endif
Endif

If [F:ITF]STOFCY<>LFCY & [F:ITF]ITMREF<>LITM
   Read [ITF]ITF0=LITM;LFCY
   If fstat End Endif
Endif

# Récupération du dépôt
Case LVCR
 When 2              : # Commande
                       LWRH = [F:ITF]ORDWRH
 When 3,4            : # Préparation/Livraison sous-traitance
                       If LSST=1
                          LWRH = [F:ITF]SCOWRH
                       # Préparation, Livraison
                       Else  
                          LWRH = [F:ITF]SHIWRH
                       Endif
 When 5,8            : # Facture, Retour fou
                       LWRH = [F:ITF]SHIWRH
 When 6              : # Réception (conso matières sous-traitance)
                       LWRH = [F:ITF]SCCWRH   
 When 10             : # OF (opération de sous-traitance)
                       If LSST=1
                          LWRH = [F:ITF]SCCWRH
                       # OF (interne)
                       Else 
                          LWRH = [F:ITF]MATWRH
                       Endif
 When 12             : # Suivi matière (opération de sous-traitance)
                       If LSST=1
                          LWRH = [F:ITF]SCCWRH
                       # Suivi matière (interne)
                       Else 
                          LWRH = [F:ITF]MFGWRH
                      Endif
 When 20,29,31,32,33 : # Sortie diverse, Changement de stock,
                       # Assemblage, Désassemblage, Demande de service
                       LWRH = [F:ITF]TRFWRH
 When 34             : # Réappro zones de consommation
                       If LSST=1
                          LWRH = [F:ITF]SCOWRH
                       Else
                          LWRH = [F:ITF]TRFWRH
                       Endif
 When 36             : # Ordre sous-traitance
                       LWRH = [F:ITF]SCCWRH
 When Default
Endcase

End

########################################################################
# GENITW      Création des articles-dépôts
#             - suite à création d'un dépôt
#             - suite à création d'un article-site 
########################################################################
# Entrée   LORI : Origine (1=création dépôt, 2=création article-site)
#          LFCY : Site stockage
#          LPAR : Dépôt si LORI=1 ou Article si LORI=2 
########################################################################
Subprog GENITW(LORI,LFCY,LPAR)
Value    Integer LORI
Value    Char    LFCY
Value    Char    LPAR

If !clalev([F:FCY])  Local File FACILITY   [FCY]  Endif
If !clalev([F:ITW])  Local File ITMWRH     [ITW]  Endif

Read [FCY]FCY0=LFCY
If fstat | [F:FCY]WRHGES<>2 End Endif

# Création d'un dépôt
If LORI=1
   If !clalev([F:ITF])  Local File ITMFACILIT [ITF]  Endif
   # Création des articles-dépôt pour le site du dépôt  
   For [ITF]ITF1 Where STOFCY=LFCY & STOMGTCOD>1 & LOCMGTCOD=2
      Raz [F:ITW]
      [F:ITW]ITMREF    = [F:ITF]ITMREF
      [F:ITW]STOFCY    = LFCY
      [F:ITW]WRH       = LPAR
      [F:ITW]CUNWRHFLG = 1
      [F:ITW]LOCDEFFLG = 1
      [F:ITW]CREUSR    = GUSER
      [F:ITW]CREDAT    = date$
      GPOINT = "BEFWRIITW"         # hcb 82248
      Gosub ENTREE From EXEFNC 
      Write [ITW]
   Next
# Création d'un article-site
Elsif LORI=2 
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH]  Endif
   # Création des articles-dépôt pour les dépôts du site   
   For [WRH]WRH1 Where STOFCY=LFCY
      Raz [F:ITW]
      [F:ITW]ITMREF    = LPAR
      [F:ITW]STOFCY    = LFCY
      [F:ITW]WRH       = [F:WRH]WRH
      [F:ITW]CUNWRHFLG = 1
      [F:ITW]LOCDEFFLG = 1
      [F:ITW]CREUSR    = GUSER
      [F:ITW]CREDAT    = date$
      GPOINT = "BEFWRIITW"        # hcb 82248  
      Gosub ENTREE From EXEFNC 
      Write [ITW]
   Next
Endif

End

########################################################################
# DELITW      Suppression des articles-dépôts
#             - suite à suppression d'un dépôt
#             - suite à suppression d'un article-site 
########################################################################
# Entrée   LORI : Origine (1=suppression dépôt, 2=suppression article-site)
#          LFCY : Site stockage
#          LPAR : Dépôt si LORI=1 ou Article si LORI=2 
########################################################################
Subprog DELITW(LORI,LFCY,LPAR)
Value    Integer LORI
Value    Char    LFCY
Value    Char    LPAR

If !clalev([F:FCY])  Local File FACILITY   [FCY]  Endif
If !clalev([F:ITW])  Local File ITMWRH     [ITW]  Endif

Read [FCY]FCY0=LFCY
If fstat | [F:FCY]WRHGES<>2 End Endif

# Suppression d'un dépôt
If LORI=1
   If !clalev([F:ITF])  Local File ITMFACILIT [ITF]  Endif
   # Suppression des articles-dépôt pour le site du dépôt  
    Delete [ITW] Where [F:ITW]WRH = LPAR & [F:ITW]STOFCY = LFCY
       If fstat = 1
          Call RSTA("ITW",CLE_TO_DEL) From GLOCK 
          GOK = -1
       Endif
# Suppression d'un article-site
Elsif LORI=2 
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH]  Endif
   # Suppression des articles-dépôt pour les articles site   
    Delete [ITW] Where [F:ITW]ITMREF = LPAR & [F:ITW]STOFCY = LFCY
       If fstat = 1
          Call RSTA("ITW",CLE_TO_DEL) From GLOCK 
          GOK = -1
       Endif
Endif

End

