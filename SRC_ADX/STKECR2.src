########################################################################
# Traitement STKECR2 - Librairie de composants ĂŠcrans stock       V140 #
########################################################################
# Sous-programmes
#-----------------------------------------------------------------------
# STKAUZSST  : DĂŠtermine les sous-statuts autorisĂŠs pour les mouvements
#              de rĂŠapprovisionnement des zones de consommation
# ETAZONSORL : Diszo des champs stock d'une ligne d'un document
########################################################################

#########################################################################
# STKAUZSST    DĂŠtermination des sous-statuts autorisĂŠs pour les mouvements
#              de rĂŠapprovisionnement des zones de consommation
#########################################################################
# ParamĂ¨tres E : LAUZ1  = Sous-statuts autorisĂŠs par la rĂ¨gle de gestion
#                LAUZ2  = Sous-statuts autorisĂŠs par l'emplacement
#
# ParamĂ¨tres S : LAUZ3  = Sous-statuts autorisĂŠs
#
#########################################################################
Subprog STKAUZSST (LAUZ1, LAUZ2, LAUZ3)
Value    Char  LAUZ1
Value    Char  LAUZ2
Variable Char  LAUZ3

Local  Char    WWSTA(30)
Local  Char    WSTA1(3)(10), WSTA2(3)(10)
Local  Integer I,J,K

# DĂŠpack des s-statuts autorisĂŠs dans WSTA1(I) et WSTA2(J)
WWSTA=LAUZ1
K=instr(K,WWSTA,",")
While K<>0
   WSTA1(I)=left$ (WWSTA,K-1)
   WWSTA   =right$(WWSTA,K+1)
   K=instr(K,WWSTA,",")
   I+=1
Wend
WSTA1(I)=WWSTA

WWSTA=LAUZ2
K=instr(K,WWSTA,",")
While K<>0
   WSTA2(J)=left$ (WWSTA,K-1)
   WWSTA   =right$(WWSTA,K+1)
   K=instr(K,WWSTA,",")
   J+=1
Wend
WSTA2(J)=WWSTA

# Si "A" non autorisĂŠ par rĂ¨gle de gestion,
# suppression des s-statuts "A" autorisĂŠs par emplacement
If sigma(K=0,I,left$(WSTA1(K),1)="A")=0
   For K=0 To J
      If left$(WSTA2(K),1)="A" Raz WSTA2(K) Endif
   Next K
Endif
# Si "Q" non autorisĂŠ par rĂ¨gle de gestion,
# suppression des s-statuts "Q" autorisĂŠs par emplacement
If sigma(K=0,I,left$(WSTA1(K),1)="Q")=0
   For K=0 To J
      If left$(WSTA2(K),1)="Q" Raz WSTA2(K) Endif
   Next K
Endif
# Si "R" non autorisĂŠ par rĂ¨gle de gestion,
# suppression des s-statuts "R" autorisĂŠs par emplacement
If sigma(K=0,I,left$(WSTA1(K),1)="R")=0
   For K=0 To J
      If left$(WSTA2(K),1)="R" Raz WSTA2(K) Endif
   Next K
Endif

Raz LAUZ3
For K=0 To J
   If WSTA2(K)<>""
      If LAUZ3<>"" LAUZ3 += "," Endif
      LAUZ3 += WSTA2(K)
   Endif
Next K

End

#--- Essai de rĂŠĂŠcriture de STKAUZSST ---#
Subprog STKAUZSST2 (LAUZ1, LAUZ2, LAUZ3)
Value    Char  LAUZ1
Value    Char  LAUZ2
Variable Char  LAUZ3

Local  Char    WWSTA(30)
Local  Char    WSTA(3)(10)
Local  Char    WA1(3)(10), WA2(3)(10)
Local  Char    WQ1(3)(10), WQ2(3)(10)
Local  Char    WR1(3)(10), WR2(3)(10)
Local  Integer A1,Q1,R1,A2,Q2,R2
Local  Integer I,J,K

# DĂŠpack des s-statuts autorisĂŠs dans WA1(A) et WSTA2(J)
WWSTA=LAUZ1
K=instr(K,WWSTA,",")
While K<>0
   Case left$(left$(WWSTA,K-1),1)
    When "A" : WA1(A1)=left$(WWSTA,K-1)
               A1+=1
    When "Q" : WQ1(Q1)=left$(WWSTA,K-1)
               Q1+=1
    When "R" : WR1(R1)=left$(WWSTA,K-1)
               R1+=1
   Endcase
   WWSTA=right$(WWSTA,K+1)
   K=instr(K,WWSTA,",")
Wend
Case left$(WWSTA,1)
 When "A" : WA1(A1)=WWSTA
 When "Q" : WQ1(Q1)=WWSTA
 When "R" : WR1(R1)=WWSTA
Endcase

WWSTA=LAUZ2
K=instr(K,WWSTA,",")
While K<>0
   Case left$(left$(WWSTA,K-1),1)
    When "A" : WA2(A2)=left$(WWSTA,K-1)
               A2+=1
    When "Q" : WQ2(Q2)=left$(WWSTA,K-1)
               Q2+=1
    When "R" : WR2(R2)=left$(WWSTA,K-1)
               R2+=1
   Endcase
   WWSTA   =right$(WWSTA,K+1)
   K=instr(K,WWSTA,",")
Wend
Case left$(WWSTA,1)
 When "A" : WA2(A2)=WWSTA
 When "Q" : WQ2(Q2)=WWSTA
 When "R" : WR2(R2)=WWSTA
Endcase

End

#########################################################################
# ETAZONSORL Diszo des champs stock d'une ligne d'un document utilisant #
#            le composant de saisie des sorties                         #
#########################################################################
# ParamĂ¨tres E : LABR  = AbrĂŠviation ĂŠcran origine
#                LNOL  = Indice de la ligne (nolign-1)
#
#########################################################################
Subprog ETAZONSORL(LABR,LNOL)
Value Char    LABR
Value Integer LNOL

Local Integer I, WSOW
Local Char    WMSKCOU(10)

#--- Bug 80673
If dim(GCREPARBOU)>0 & GCREPARBOU=1 End Endif

WMSKCOU=func STKLIB.MSKDEF
If WMSKCOU<>"["+LABR+"]"
   Default Mask "["+LABR+"]"
Endif

Local Char    WSAIFLG(11) : WSAIFLG="00000000000"
If evalue("dim([M:"+LABR+"]WSTOSAI)")>LNOL & [M]WSTOSAI(LNOL)<>""
   WSAIFLG=[M]WSTOSAI(LNOL)
Endif

Raz WSOW
If [M]WSTOSEQ(LNOL)<>0
   # Calcul du nb enreg SOW associĂŠ Ă  la ligne de document
   WSOW=sigma(I=0,[M:SOW]NBLIG-1,1*([M:SOW]WSTOSEQ(I)=[M]WSTOSEQ(LNOL)))
Endif

# DĂŠsactivation des colonnes du document
# Si la zone n'est pas en Grizo
If varmode([M]STA,LNOL)<>1
   Actzo [M]STA(LNOL)
   WSAIFLG=left$(WSAIFLG,3)+"0"+right$(WSAIFLG,5)
   # Si la zone est saisissable,
   # mais il y a dĂŠjĂ  des SOW ou la ligne existe dĂŠjĂ , on la diszo
   If varmode([M]STA,LNOL)=0 & (WSOW<>0 | [M]CREFLG(LNOL)<>0)
      Diszo [M]STA(LNOL)
      WSAIFLG=left$(WSAIFLG,3)+"2"+right$(WSAIFLG,5)
   Endif
Endif
If evalue("dim([M:"+LABR+"]LOT)")>0
   If varmode([M]LOT,LNOL)<>1
      Actzo [M]LOT(LNOL)
      WSAIFLG=left$(WSAIFLG,5)+"0"+right$(WSAIFLG,7)
      If varmode([M]LOT,LNOL)=0 & (WSOW<>0 | [M]CREFLG(LNOL)<>0)
         Diszo [M]LOT(LNOL)
         WSAIFLG=left$(WSAIFLG,5)+"2"+right$(WSAIFLG,7)
      Endif
   Endif
Endif
If evalue("dim([M:"+LABR+"]SLO)")>0
   If varmode([M]SLO,LNOL)<>1
      Actzo [M]SLO(LNOL)
      #WSAIFLG=left$(WSAIFLG,6)+"0"+right$(WSAIFLG,8)
      If varmode([M]SLO,LNOL)=0 & (WSOW<>0 | [M]CREFLG(LNOL)<>0)
         Diszo [M]SLO(LNOL)
         WSAIFLG=left$(WSAIFLG,6)+"2"+right$(WSAIFLG,8)
      Endif
   Endif
Endif
If evalue("dim([M:"+LABR+"]WRH)")>0
   If varmode([M]WRH,LNOL)<>1
      # DĂŠpĂ´t obligatoire en entĂŞte
      If GWRHOBY=2
         Diszo [M]WRH(LNOL)
      Else
         Actzo [M]WRH(LNOL)
      Endif
      If varmode([M]WRH,LNOL)=0 & (WSOW<>0 | [M]CREFLG(LNOL)<>0)
         Diszo [M]WRH(LNOL)
      Endif
   Endif
Endif
#--- Issue X3-53322
If evalue("dim([M:"+LABR+"]LPNNUM)")>0
   If varmode([M]LPNNUM,LNOL)<>1
      Actzo [M]LPNNUM(LNOL)
      If varmode([M]LPNNUM,LNOL)=0 & (WSOW<>0 | [M]CREFLG(LNOL)<>0)
         Diszo [M]LPNNUM(LNOL)
      Endif
   Endif
Endif
#---
If evalue("dim([M:"+LABR+"]LOC)")>0
   If varmode([M]LOC,LNOL)<>1
      Actzo [M]LOC(LNOL)
      WSAIFLG=left$(WSAIFLG,4)+"0"+right$(WSAIFLG,6)
      If varmode([M]LOC,LNOL)=0 & (WSOW<>0 | [M]CREFLG(LNOL)<>0)
         Diszo [M]LOC(LNOL)
         WSAIFLG=left$(WSAIFLG,4)+"2"+right$(WSAIFLG,6)
      Endif
   Endif
Endif
If evalue("dim([M:"+LABR+"]SERNUM)")>0
   If varmode([M]SERNUM,LNOL)<>1
      Actzo [M]SERNUM(LNOL)
      WSAIFLG=left$(WSAIFLG,7)+"0"+right$(WSAIFLG,9)
      If varmode([M]SERNUM,LNOL)=0 & (WSOW<>0 | [M]CREFLG(LNOL)<>0)
         Diszo [M]SERNUM(LNOL)
         WSAIFLG=left$(WSAIFLG,7)+"2"+right$(WSAIFLG,9)
      Endif
   Endif
Endif
If varmode([M]MVTDES,LNOL)<>1
   Actzo [M]MVTDES(LNOL)
   WSAIFLG=left$(WSAIFLG,8)+"0"+right$(WSAIFLG,10)
   If varmode([M]MVTDES,LNOL)=0 & (WSOW<>0 | [M]CREFLG(LNOL)<>0)
      Diszo [M]MVTDES(LNOL)
      WSAIFLG=left$(WSAIFLG,8)+"2"+right$(WSAIFLG,10)
   Endif
Endif
If evalue("dim([M:"+LABR+"]PALNUM)")>0
   If varmode([M]PALNUM,LNOL)<>1
      Actzo [M]PALNUM(LNOL)
      WSAIFLG=left$(WSAIFLG,9)+"0"+right$(WSAIFLG,11)
      If varmode([M]PALNUM,LNOL)=0 & (WSOW<>0 | [M]CREFLG(LNOL)<>0)
         Diszo [M]PALNUM(LNOL)
         WSAIFLG=left$(WSAIFLG,9)+"2"+right$(WSAIFLG,11)
      Endif
   Endif
Endif
If evalue("dim([M:"+LABR+"]CTRNUM)")>0
   If varmode([M]CTRNUM,LNOL)<>1
      Actzo [M]CTRNUM(LNOL)
      WSAIFLG=left$(WSAIFLG,10)+"0"
      If varmode([M]CTRNUM,LNOL)=0 & (WSOW<>0 | [M]CREFLG(LNOL)<>0)
         Diszo [M]CTRNUM(LNOL)
         WSAIFLG=left$(WSAIFLG,10)+"2"
      Endif
   Endif
Endif

If evalue("dim([M:"+LABR+"]WSTOSAI)")>LNOL  [M]WSTOSAI(LNOL)=WSAIFLG : Endif

# TS le 26.10.05
# TS le 04.06.07 - en attente du Affzo ligne (pb temps de rĂŠponse)
# TS le 15.10.09 - pas de Affzo ligne --> rĂŠactivation de l'affichage
#--- Bug 81627   - dĂŠsactivation affichage (pb temps de rĂŠponse)
#Affzo [M]1-99

If WMSKCOU<>"["+LABR+"]"
   Default Mask WMSKCOU
Endif

End

#----------------------------------------------------------#
# Initialisation des unitĂŠs UC, US et du coefficient UC-US #
#----------------------------------------------------------#
$INIT_UNITE_COEF
If evalue("dim([M:"+LABR+"]STU)")>1
    [M]STU(LLIN)=[F:ITM]STU
Elsif evalue("dim([M:"+LABR+"]STU)")=1
    [M]STU=[F:ITM]STU
Endif
If clalev([F:ITP]) & LBPR<>"" & LTYPBPR=1
  If [F:ITP]ITMREF=LITM & [F:ITP]BPSNUM=LBPR
    WUOM=[F:ITP]PUU : WTYPUOM=1
  Else
    WUOM=[F:ITM]PUU : WTYPUOM=1
  Endif
Elsif clalev([F:ITU]) & LBPR<>"" & LTYPBPR=2
  If [F:ITU]ITMREF=LITM & [F:ITU]BPCNUM=LBPR
    WUOM=[F:ITU]SAU : WTYPUOM=2
  Else
    WUOM=[F:ITM]SAU : WTYPUOM=2
  Endif
Else
  WUOM=[F:ITM]STU : WTYPUOM=3
Endif
Call CTLUOM(LITM,WTYPUOM,LBPR,WUOM,WCOEF,WUSCAV,WLBEFMT,WSAICOEF) From STKACT
If mkstat  Return : Endif
If evalue("dim([M:"+LABR+"]PCU)")>0  [M]PCU(LLIN)=WUOM  : Endif
If evalue("dim([M:"+LABR+"]UOM)")>0  [M]UOM(LLIN)=WUOM  : Endif
If evalue("dim([M:"+LABR+"]SAU)")>0  [M]SAU(LLIN)=WUOM  : Endif

If evalue("dim([M:"+LABR+"]PCUSTUCOE)")>0
  [M]PCUSTUCOE(LLIN)=WCOEF
  If WSAICOEF=2 Actzo PCUSTUCOE(LLIN) Else Diszo PCUSTUCOE(LLIN) : Endif
Endif
If evalue("dim([M:"+LABR+"]UOMSTUCOE)")>0
  [M]UOMSTUCOE(LLIN)=WCOEF
  If WSAICOEF=2 Actzo [M]UOMSTUCOE(LLIN) Else Diszo [M]UOMSTUCOE(LLIN) : Endif
Endif
If evalue("dim([M:"+LABR+"]SAUSTUCOE)")>0
  [M]SAUSTUCOE(LLIN)=WCOEF
  If WSAICOEF=2 Actzo [M]SAUSTUCOE(LLIN) Else Diszo [M]SAUSTUCOE(LLIN) : Endif
Endif
If WSAICOEF<>2 WSAIFLG=left$(WSAIFLG,2)+"2"+right$(WSAIFLG,4) : Endif
If LAFF
  If evalue("dim([M:"+LABR+"]PCU)")>0       Affzo PCU(LLIN)       : Endif
  If evalue("dim([M:"+LABR+"]PCUSTUCOE)")>0 Affzo PCUSTUCOE(LLIN) : Endif
  If evalue("dim([M:"+LABR+"]UOM)")>0       Affzo UOM(LLIN)       : Endif
  If evalue("dim([M:"+LABR+"]UOMSTUCOE)")>0 Affzo UOMSTUCOE(LLIN) : Endif
  If evalue("dim([M:"+LABR+"]STU)")>0       Affzo STU(LLIN)       : Endif
Endif
Return

#-------------------------------------------#
# Cherche le lot fournisseur
#-------------------------------------------#
$INIT_BPSLOT
    Local Char WSLO(GLONSLO) : WSLO=""
    If evalue("dim([M:"+LABR+"]SLO)")>0 WSLO=[M]SLO(LLIN) Endif
    Call SEARCHLOTENTW( LITM, [M]LOT(LLIN), WSLO, -1, WLIGLOT) From STKENTA
    If WLIGLOT>0
        [M]BPSLOT(LLIN) = [M:ENTW]BPSLOT(WLIGLOT)
    Endif
Return

########################################################################
######################## - Action - ####################################
########################################################################
$ACTION
# Question Ă  choix multiple si qtĂŠ sĂŠlectionnĂŠe < qtĂŠ Ă  traiter
If GACTION="DIVCHX1"
   Case ACTION
    When "OUVRE"  : Gosub OUVRE_DIVCHX1
    When "TITRE"  : Gosub TITRE_DIVCHX1
    When "DEBUT"  : Gosub DEBUT_DIVCHX1
    When "BOUTON" : Gosub BOUT_DIVCHX1
    When "FINSAI" : Gosub FINSAI_DIVCHX1
   Endcase
Endif

Return

##########################################################################
# Action DIVCHX1 : Choix stock                                           #
#   PARAM(1) = NOMESS  : NumĂŠro du message Ă  afficher                    #
#   PARAM(2) = NUMCHAP : NumĂŠro du chapitre                              #
#   PARAM(3) = WBOUT   : (A,B,F)                                         #
##########################################################################
#--------------------------------------------------------------#
# Avant la dĂŠfinition des boutons et l'ouverture de la fenĂŞtre #
#--------------------------------------------------------------#
$OUVRE_DIVCHX1
Local Char     WBOUT(1)
Local Shortint WNOMESS  : WNOMESS =val(PARAM(1))
Local Shortint WNUMCHAP : WNUMCHAP=val(PARAM(2))
Return
#---------------------#
# Titre de la fenĂŞtre #
#---------------------#
$TITRE_DIVCHX1
TIT=mess(10,188,1)
Return
#---------------------------------#
# AprĂ¨s l'ouverture de la fenĂŞtre #
#---------------------------------#
$DEBUT_DIVCHX1
[M:CHX]TEXTE=mess(WNOMESS,WNUMCHAP,1)
Affzo [CHX]1-99
Return
#--------#
# Bouton #
#--------#
$BOUT_DIVCHX1
WBOUT=BOUT : FIN=1
Return
#------------------------------------------#
# Avant de revenir Ă  la fenĂŞtre prĂŠcĂŠdente #
#------------------------------------------#
$FINSAI_DIVCHX1
PARAM(3)=WBOUT
Return

