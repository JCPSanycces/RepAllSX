Subprog APRES_NBRFAM
Local Integer NBR_NBRFAM
NBR_NBRFAM = [M:POT6]NBRFAM
# En cas d'ajout ou d'insertion on a une ligne en plus
# Le status est à 1 qu'on soit en modif, insertion ou ajout d'1 ligne
If status<>65 & status<>83 & status<>68 : NBR_NBRFAM +=1 : Endif
Call LECTURE("JOT",[M:POT1]JOBPOT,"") From CONTOBJ
If fstat : Raz [F:JOT] : Endif
Gosub INIT_CPC
Affzo [POT4]
End

Subprog IB_CPCFAM
GFLAG="4"
End

Subprog C_CPCFAM(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:POT6]CPCFAM(0..[M:POT6]NBRFAM-1)) From OBJDIV
If mkstat : End : Endif # SEGAY 25/10/12 US 930 81085
# SEGAY 25/10/12 US 930 81085
If VALEUR<>""
 If clalev([F:ADI])=0 : Local File ATABDIV       [ADI] : Endif
 ## Action CONTADI
 Call CONTADI(VALEUR,"10461","") From SUBADI
 If mkstat : GERR = 1  : End Endif
# If !mkstat
#  ## Action %CNTOBJ
#  Call CONTSEL("ADI","",VALEUR,"10461",mkstat) From CONTOBJ

 Read [F:ADI]CODE=10461;VALEUR
 If !fstat
  If dim([V]GCURLEG)>0 & [V]GCURLEG = "" & [F:ADI]LEG <> [V]GCURLEG
    GMESSAGE = mess(4,10937,1)-":"-VALEUR+chr$(10)+chr$(13)+mess(62,127,1)-":"-[F:ADI]LEG : # Réservé à la législation
    mkstat = 2
    GERR=1
    End
  Else
   Call CONTROLE("ADI","",VALEUR,"10461",mkstat) From CONTOBJ
   If mkstat : GERR = 1  : End Endif
  Endif
 Else
   If dim(GAUTOSEL)>0 & GAUTOSEL=2 & GWEBSERV<>1
     Local Char    CRITERE_JOT(250)
     Call CRIT_LEG_HLEG ([L]VALEUR,"10461","[F:ADI]CODE","NUMTAB","ADI","[F:ADI]LEG",GCURLEG,CRITERE_JOT) From TOOLSHRLEG

     Filter [F:ADI] Where  evalue(CRITERE_JOT)
     If rowcount([F:ADI]) > 1
# ## Action SELADILH
      Filter [F:ADI]
      If !GWEBSERV
        Local Char    PARMSK(250)(1..20) , SAVACT(20)
        SAVACT = GACTION : GACTION = "SELADILH"
        PARMSK(1) = "10461"
        PARMSK(2) = GCURLEG
        Call S_TAB_CHAR(VALEUR,PARMSK,"SELADILH","TOOLSHRLEG","") From GACTION
        GACTION = SAVACT
      Endif
      Gosub AFF From GSAISIE
     Endif
     If rowcount([F:ADI])=  1
       Read [F:ADI]CODE First
       If !fstat
         [L]VALEUR = num$([F:ADI]CODE)
       Endif
       Filter [F:ADI]
     Endif
     If !rowcount([F:ADI])
        Filter [F:ADI]
        Call CONTROLE("ADI","",VALEUR,"10461",mkstat) From CONTOBJ
        If mkstat : GERR = 1  : End Endif
     Endif
     Filter [F:ADI]
   Else
     Call CONTROLE("ADI","",VALEUR,"10461",mkstat) From CONTOBJ
     If mkstat : GERR = 1  : End Endif
   Endif
 Endif
Endif

End
######################################################################################
$INIT_CPC
Local Integer  NIVEAU, WNIVEAU
Local Char     L_CPC(GLONCPC)(0..)                    : # JML 30/07/10 LOT P02 To charge GRPCPCD [HRGCD]
Local Char     L_NIV(GLONNIV)(0..)                    : # JML 30/07/10 LOT P02 To charge GRPCPCD [HRGCD]
Local Char     L_LEVDES(GDIMFIC)(0..)                 : # JML 04/08/10 LOT P02 To charge GRPCPCD [HRGCD]
Local Shortint L_LEVREF(0..)                          : # JML 04/08/10 LOT P02 To charge GRPCPCD [HRGCD]
Local Char     L_CODSCA(GLONSCA)(0..)                 : # JML 19/08/10 LOT P02 To charge GRPCPCD [HRGCD]
Local Integer  L_NB_CPC
Local Integer  L_IJ
Local Integer  ORIGINE                                : # JML 04/08/10 Better when declared
Local Integer  L_I_CPC                                : # SEGAY - 24/11/10 - EXI 66105 LOT P01 indice courant du tableau de CPC

I = 0 : NIVEAU=0 : WNIVEAU=0
FAMORI=""
# SEGAY - 24/11/10 - EXI 66105 LOT P01
# Suppression lignes du tableau liste de compétence sauf les lignes
#Raz [M:POT4]
For I=[M:POT4]NBRLIG-1 To 0 Step -1
# SEGAY 25/10/12 US 930 81085 CPC of CPE in a different legislation than the contract
#  If [M:POT4]ORI(I)<>len(mess(0,10937,1)) & (dim([M:POT0]LEG)< 0 | !func TOOLSHRLEG.CHECKLEG_CPC([M:POT4]CPC(I),[M:POT0]LEG,0))  :  #manuelle
  If ([M:POT4]ORI(I)<>len(mess(0,10937,1)) ) Then
    Dela I, 1 [M:POT4]NBRLIG
    [M:POT4]NBRLIG -= 1
  Endif
Next

If [M:POT4]NBRLIG > 0
  L_I_CPC = [M:POT4]NBRLIG
Else
  L_I_CPC = 0
Endif

If [M:POT1]JOBPOT <> "" & [M:POT6]JOBGRP<> "" # Bug 71019 récupération des compétences dossier, famille, métier que si l'emploi type est renseigné
  # Niveau dossier
  Read [GCP]GCP0=1;"";"";""
  If !fstat # Bug 70929 rajout du fstat
    ORIGINE=1 : FAMORI=""
    Gosub RECUP_CPC
  Endif
Endif # END_Bug 71019 récupération des compétences dossier, famille, métier que si l'emploi type est renseigné

# Niveau Famille
If [M:POT6]UOMGRP<>""
 Read [GCP]GCP0=2;[M:POT6]UOMGRP;"";""
 If !fstat # Bug 70929 rajout du fstat
   ORIGINE=2 : FAMORI=""
   Gosub RECUP_CPC
 Endif
Endif

# Niveau Métier
If [M:POT6]JOBGRP<>""
 Read [GCP]GCP0=3;"";[M:POT6]JOBGRP;""
 If !fstat # Bug 70929 rajout du fstat
   ORIGINE=3 : FAMORI=""
   Gosub RECUP_CPC
 Endif
Endif

# Niveau groupe de compétences
For K=0 To NBR_NBRFAM-1
 If [M:POT6]CPCFAM(K)<>""
  Read [GCP]GCP0=4;"";"";[M:POT6]CPCFAM(K)
  If !fstat # Bug 70929 rajout du fstat
    ORIGINE=4 : FAMORI=[M:POT6]CPCFAM(K)
    Gosub RECUP_CPC
  Endif
 Endif
Next
[M:POT4]NBRLIG=L_I_CPC

# On hérite des compétences du nouvel emploi type (JML 29/09/10 CG a initialiser avant les CPC générales
Gosub INIT_CPC_JOT

Sorta [M:POT4]NBRLIG [M:POT4]NBRLIG Order By ORI([S]indice),CPC([S]indice)
Return

###############################
$RECUP_CPC
# JML 30/07/10 LOT P02
Raz L_CPC, L_NIV, L_NB_CPC, L_LEVDES, L_LEVREF, L_CODSCA
For [HRGCD]GCD0 Where [F:HRGCD]LEVGRP=[F:GCP]LEVGRP & [F:HRGCD]UOMGRP=[F:GCP]UOMGRP
&                   & [F:HRGCD]JOBGRP=[F:GCP]JOBGRP & [F:HRGCD]CPCFAM=[F:GCP]CPCFAM
 If dim([M:POT0]LEG)< 0 | (func TOOLSHRLEG.CHECKLEG_CPC([F:HRGCD]CPC,[M:POT0]LEG,0))  # SEGAY 25/10/12 US 930 81085 CPC of CPE in a different legislation than the contract
   L_CPC(L_NB_CPC) = [F:HRGCD]CPC
   L_NIV(L_NB_CPC) = [F:HRGCD]NIV
   # JML 04/08/10 Text of the scale
   Call LECTURE("CPC",[F:HRGCD]CPC,"") From CONTOBJ
   L_CODSCA(L_NB_CPC) = [F:CPC]CODSCA
   Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
   L_IJ = find([F:HRGCD]NIV,[F:HRSCA]LEV)
   Read [HRSDD]SDD0=[F:CPC]CODSCA;L_IJ
   If !fstat
    L_LEVDES(L_NB_CPC) = [F:HRSDD]LEVDES
   Endif
   L_LEVREF(L_NB_CPC)  = [F:HRSCA]LEVREF
   #
   L_NB_CPC += 1
 Endif
Next : # [HRGCD]GCD0
For J=0 To L_NB_CPC-1
 If L_CPC(J)<>""
  Call LECTURE("CPC",L_CPC(J),"") From CONTOBJ
  L = find(L_CPC(J),[M:POT4]CPC)
  If !L
   # SEGAY - 24/11/10 - EXI 66105 LOT P01
   If L_I_CPC>=dim([M:POT4]CPC)
    #Tableau des compétences plein
    Call ERREUR(mess(5,10720,1)-num$(dim([M:POT4]CPC))) From GESECRAN
    Break
   Endif

   # JML 27/08/10 We need more information from CPC, a good idea for a transclass !
   nolign = L_I_CPC + 1
   [M:POT4] = [F:CPC]
   [M:POT4]CPC(L_I_CPC)     = L_CPC(J)
   [M:POT4]NIV(L_I_CPC)     = L_NIV(J)
   [M:POT4]CODSCA(L_I_CPC)  = L_CODSCA(J)
   If dim([M:POT4]LEVDES)>0
    [M:POT4]LEVDES(L_I_CPC)  = L_LEVDES(J)
   Endif
   [M:POT4]ORI(L_I_CPC)     = ORIGINE
   [M:POT4]CODORI(L_I_CPC)  = FAMORI
   [M:POT4]WEI(L_I_CPC)     = 1
   L_I_CPC += 1
  Else
   Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
   # Niveau déjà défini dans l'écran
   N = find([M:POT4]NIV(L-1),[F:HRSCA]LEV)
   If N
    WNIVEAU = [F:HRSCA]LEVREF(N-1)
   Else
    WNIVEAU = [F:HRSCA]LEVREF(0)
   Endif
   # Niveau défini dans le groupe de compétence
   N = find(L_NIV(J),[F:HRSCA]LEV)
   If N
    NIVEAU = [F:HRSCA]LEVREF (N-1)
   Else
    NIVEAU = [F:HRSCA]LEVREF (0)
   Endif
   #C'est le niveau le + élevé qui gagne
   # SEGAY - 24/11/10 - EXI 66105 LOT P01
   #Le niveau défini dans la compétence (niveau d’échelle),
   #   n’est pas pris en compte pour initialiser les compétences dans les emplois type et postes ;
   # (de la même manière qu’il n’est pas pris en compte dans les traitements de MàJ héritage).
   #Si on n'est pas sur une compétence manuelle et l'origine de la maj <> 4 ML 2400 Groupe de compétence
#   If WNIVEAU<NIVEAU
   If [M:POT4]ORI(L-1) <> len(mess(0,10937,1)) & ORIGINE<>4 : # ML 2400 Groupe de compétence
    # JML 27/08/10 We need more information from CPC, a good idea for a transclass !
    nolign = L
    [M:POT4] = [F:CPC]
    [M:POT4]NIV(L-1)    = L_NIV(J)
    [M:POT4]CODSCA(L-1) = L_CODSCA(J)
    If dim([M:POT4]LEVDES)>0
     [M:POT4]LEVDES(L-1) = L_LEVDES(J)
    Endif
    [M:POT4]ORI(L-1)    = ORIGINE
    [M:POT4]CODORI(L-1) = FAMORI
   Endif
  Endif
 Elsif L_CPC(J)=""
  Break
 Endif
Next J
Return
