Subprog C_JOBPOT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
# Call CONTSEL("JOT","!",VALEUR,"",mkstat) From CONTOBJ
 If clalev([F:JOT])=0 : Local File JOBTYP     [JOT] : Endif
 Read [F:JOT]JOT0=VALEUR
 If !fstat
  If dim([V]GCURLEG)>0 & [V]GCURLEG = "" & [F:JOT]LEG <> [V]GCURLEG
    GMESSAGE = mess(5,10937,1)-":"-VALEUR+chr$(10)+chr$(13)+mess(62,127,1)-":"-[F:JOT]LEG : # Réservé à la législation
    mkstat = 2
    GERR=1
    End
  Else
    Call CONTROLE("JOT","!",VALEUR,"",mkstat) From CONTOBJ
    If mkstat : GERR = 1  : End Endif
   Endif
 Else
   If dim(GAUTOSEL)>0 & GAUTOSEL=2 & GWEBSERV<>1
     Local Char    CRITERE_JOT(250)
     Call CRIT_LEG_HLEG ([L]VALEUR,"","[F:JOT]COD","","JOT","[F:JOT]LEG",GCURLEG,CRITERE_JOT) From TOOLSHRLEG

     Filter [F:JOT] Where  evalue(CRITERE_JOT)
     If rowcount([F:JOT]) > 1
# ## Action SELJOTH
      Filter [F:JOT]
      If !GWEBSERV
        Local Char    PARMSK(250)(1..20) , SAVACT(20)
        SAVACT = GACTION : GACTION = "SELJOTH"
        PARMSK(1) = GCURLEG
        Call S_TAB_CHAR(VALEUR,PARMSK,"SELJOTH","SUBJOT","") From GACTION
        GACTION = SAVACT
      Endif
      Gosub AFF From GSAISIE
     Endif
     If rowcount([F:JOT])=  1
       Read [F:JOT]JOT0 First
       If !fstat
         [L]VALEUR = num$([F:JOT]COD)
       Endif
       Filter [F:JOT]
     Endif
     If !rowcount([F:JOT])
        Filter [F:JOT]
        Call CONTROLE("JOT","!",VALEUR,"",mkstat) From CONTOBJ
        If mkstat : GERR = 1  : End Endif
     Endif
     Filter [F:JOT]
   Else
     Call CONTROLE("JOT","!",VALEUR,"",mkstat) From CONTOBJ
     If mkstat : GERR = 1  : End Endif
   Endif
 Endif
Endif
End


