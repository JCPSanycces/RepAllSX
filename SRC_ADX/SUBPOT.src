# FQ81085 - 17/09/13 - Récupération du Nom-Prénom après saisie du matricule
Subprog AM_EMPMDL(VALEUR)
Variable Char    VALEUR()

  If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
  Read [F:ID]ID0=VALEUR
  If !fstat Then
    [M:POT2]NAMMDL=[F:ID]NAM-[F:ID]SRN
    Affzo [M:POT2]NAMMDL
  Endif
End


