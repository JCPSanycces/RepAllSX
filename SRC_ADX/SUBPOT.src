# SEGAY 25/10/12 US 930 81085
$CONTROLE_LEG_OK
# controle LEG
Local Char WLEGCOUR(GLONADI)
Local Char WORIFIELD(250)
Local Char WDESFIELD(250)
Local Integer WOK,POK
Local Integer WTYP
Local Char WFIELD(30)
Local Char ZFIELD(30)
Local Char WVALFIELD(30)

Local Char WECR(30)
Local Char WMES(250)
Local Integer NOL
If clalev([F:AMZ_])=0 : Local File AMSKZON [AMZ_] : Endif

WORIFIELD = "LEG"
WLEGCOUR=VALEUR
WOK = 1

WECR="POT1"
ZFIELD="JOBPOT"
WFIELD=func TOOLSHRLEG.LIB_FIELD(WECR,ZFIELD)
WVALFIELD=[M:POT1]JOBPOT

If WOK & WVALFIELD<> ""
    WTYP=5
    POK=0
    WLEGDEST=""
    Call GET_LEGJOBPOT(WVALFIELD,POK,WLEGDEST,0)  From TOOLSHRLEG
    If POK
      Call LEGOK_H(WORIFIELD,WLEGCOUR,WVALFIELD,WLEGDEST,WTYP , WOK,WMES, 0)  From TOOLSHRLEG
      If !WOK
         zonsui =ZFIELD
         GMESSAGE = WMES:  mkstat = 2 :Return
      Endif
    Endif
Endif

If WOK & func SUBJOT.IS_CAR
  WTYP=4
  NOL=0
  While (NOL<[M:POT6]NBRFAM) &  mkstat<>2
      WVALFIELD=[M:POT6]CPCFAM(NOL)
      If WVALFIELD<> ""
        POK=0
        WLEGDEST=""
        Call GET_LEGADI("10461",WVALFIELD,POK,WLEGDEST,0)  From TOOLSHRLEG
        If POK
          Call LEGOK_H(WORIFIELD,WLEGCOUR,WVALFIELD,WLEGDEST,WTYP , WOK,WMES, 0)  From TOOLSHRLEG
          If !WOK
             GMESSAGE = WMES:  mkstat = 2
          Endif
        Endif
      Endif
      NOL+=1
  Wend
Endif

If WOK & func SUBJOT.IS_CAR
  WTYP=0
  NOL=0
  While (NOL<[M:POT4]NBRLIG) &  mkstat<>2
      WVALFIELD=[M:POT4]CPC(NOL)
      If WVALFIELD<> ""
        POK=0
        WLEGDEST=""
        Call GET_LEGCPC(WVALFIELD,POK,WLEGDEST,0)  From TOOLSHRLEG
        If POK
          Call LEGOK_H(WORIFIELD,WLEGCOUR,WVALFIELD,WLEGDEST,WTYP , WOK,WMES, 0)  From TOOLSHRLEG
          If !WOK
             GMESSAGE = WMES:  mkstat = 2
          Endif
        Endif
      Endif
      NOL+=1
  Wend
Endif

# FQ81085 - 25/04/13 - Contrôle des législations de l'onglet Administratif
If WOK & WLEGCOUR<>""
  WTYP=0
  NOL=0
  While (NOL<[M:POT2]NBRDIC) &  mkstat<>2
      WVALFIELD=num$([M:POT2]LEV(NOL))
      If WVALFIELD="2" : # Niveau Législation
        POK=0
        WLEGDEST=""
        If [M:POT2]LEGLEV(NOL)<>"" & [M:POT2]LEGLEV(NOL)<>WLEGCOUR Then
          WOK=0
          GMESSAGE = mess(5,9009,1)+chr$(10)+chr$(13)+mess(62,127,1)-":"- [M:POT2]LEGLEV(NOL)
          mkstat = 2
        Endif
      Endif
      NOL+=1
  Wend
Endif
# Fin FQ81085
Return


# END SEGAY 25/10/12 US 930 81085

######################################################################################
##14/08/2012 PCA Changes for the LEGLEV field
######################################################################################

Subprog AS_VALDEF(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)=2 and [M]LEGLEV(nolign-1)<>GCURLEG
  GCURLEG=[M]LEGLEV(nolign-1)
Else
  GCURLEG=[M]LEG
Endif
End

Subprog AP_VALDEF(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)=2 and [M]LEG<>GCURLEG
GCURLEG=[M]LEG
Endif
End

Subprog AS_LEGLEV(VALEUR)
Variable Char    VALEUR()
#PCA Legislation
If [M]LEV(nolign-1)<>2
  mkstat=1
Else
  If [M:POT0]LEG<>""
    VALEUR = [M:POT0]LEG
    mkstat=2
  Endif
Endif
#PCA
End
End

#JOJAC - 2016-03-14 - REQ114309 US87 - START
Subprog CTRL_OVERLAP(WPEN,WINDIC,WSTRDAT,WENDDAT)
Value Char WPEN
Value Integer WINDIC
Value Date WSTRDAT, WENDDAT
Local Integer WOK, I

WOK=0
For I=0 To [M]NBRPEN-1
  If I<>WINDIC & WPEN=[M]PEN(I)

   If WENDDAT= [0/0/0]
      If [M]ENDDATPEN(I)=[0/0/0]   : WOK=2 : Endif
      If [M]ENDDATPEN(I)>= WSTRDAT : WOK=2 : Endif

   Else
      If [M]ENDDATPEN(I)<>[0/0/0]
        If !([M]STRDATPEN(I)> WENDDAT | [M]ENDDATPEN(I)<WSTRDAT)
          WOK=2
        Endif
        Else
         If [M]STRDATPEN(I)<= WENDDAT
           WOK=2
         Endif
      Endif
   Endif

   If WOK =2
      #ADNGO - 2017-05-02 - X3-33737 - START
      #GMESSAGE = mess(50,709,1) -num$(I+1)-" & "-num$(WINDIC+1)
      GMESSAGE = mess(50,10709,1) -num$(I+1)-" & "-num$(WINDIC+1)
      #ADNGO - 2017-05-02 - X3-33737 - END
      # Chevauchement de période entre les lignes
      mkstat=2 : Break
   Endif
  Endif
  Next
 End

#JOJAC - 2016-03-14 - REQ114309 US87 - END


