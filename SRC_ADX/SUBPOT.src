# JML 20/08/10 Forget what was done, POSTE is Now on EMPLOCTR
Raz [M:POT5]
For [LID]CTR0 Where [F:HRCTR]POT=[M:POT0]COD
 nolign = [M:POT5]NBRLIG+1
 #JOJAC - 2016-03-11 - REQ114309 US87 - START
 #If nolign>=dim([M:POT5]REFNUM) : Break : Endif
 If nolign>dim([M:POT5]REFNUM) : Break : Endif
 #JOJAC - 2016-03-11 - REQ114309 US87 - END
 [M:POT5] = [F:HRCTR]
 [M:POT5] = [F:ID]
 # FQ81085 - MABON 05/07/12 - Find the good local menu for the title, depending on the site
 Local Char NUMLIB(10)
 Call PARAM([F:HRCTR]ETRFCY,"CIVIL",NUMLIB) From ADOVAL
 If [F:HRCTR]CIVCTR>0 Then [M:POT5]CIVCTRA(nolign-1)=mess([F:HRCTR]CIVCTR,val(NUMLIB),1) : Endif
 # End MABON
 [M:POT5]NBRLIG += 1
Next : # [LID]
##################################################################################################

# JML 21/07/10 Loading new table POSTEDEF LOT P01
#76381
#Raz [M:POT2]

Effzo [M:POT2]5
#[M:POT2] = [F:POT]
For [POD]POD0 Where [F:POD]COD=[M:POT0]COD
 nolign = [M:POT2]NBRDIC+1

 If nolign>=dim([M:POT2]FLD) : Break : Endif
 [M:POT2] = [F:POD]
 #83971
 Read [ATY]CODTYP=[F:POD]CODTYP
 If !fstat
  [M:POT2]CODOBJ(nolign-1) = [F:ATY]OBJLIEN
 Endif
 [M:POT2]NBRDIC += 1
Next : # [POD]

# SEGAY 19/11/10 EXI 68086 POSTEHAB LOT P01
Raz [M:POT7]
For [PHA]PHA0 Where [F:PHA]COD=[M:POT0]COD
 nolign = [M:POT7]NBRHAB+1
#JOJAC - 2016-03-10 - REQ114309 US87 - START
# If nolign>=dim([M:POT7]HAB) : Break : Endif
 If nolign>dim([M:POT7]HAB) : Break : Endif
#JOJAC - 2016-03-10 - REQ114309 US87 - END
 [M:POT7] = [F:PHA]
 [M:POT7]NBRHAB += 1
Next : # [PHA]

# JML 17/08/10 CG MINI/MAXI
Call AM_CCV([F:POT]CCV) From SUBPOT

# DBA 30/08/10
#* Test si code activité Carrière
#* SEGAY 28/02/11 Bug 71973
If func SUBJOT.IS_CAR
  If [M:POT1]JOBPOT<>""
   Diszo [M:POT6]JOBGRP
  Else
   Actzo [M:POT6]JOBGRP
  Endif
Endif #* END_Bug 71973

#JOJAC - 2016-03-11 - REQ114309 US87 - START
#Painfulness
If dim([M:POT8]PEN) > 0
    Effzo [M:POT8] 10 - 90
    nolign = 0
    For [HRPEN]HRPEN0 Where [F:HRPEN]COD=[M:POT0]COD
        If nolign >= dim([M:POT8]PEN)
            # Tableau plein
            Call ERREUR(mess(26,100,1)) From GESECRAN
            Break
        Endif
        nolign += 1
        [M:POT8] = [F:HRPEN]
    Next : # [HRPEN]
    [M:POT8]NBRPEN = nolign
    If [M:POT8]NBRPEN > 0
        nolign = 1
        Call AS_NBRPEN From SUBPOT
    Endif
Else
    If dim([M:POT1]PEN)>0
        Effzo [M:POT1]40
        For [HRPEN]HRPEN0 Where [F:HRPEN]COD=[M:POT0]COD
            nolign = [M:POT1]NBRPEN+1
            If nolign>dim([M:POT1]PEN) : Break : Endif
            [M:POT1] = [F:HRPEN]
            [M:POT1]NBRPEN += 1
        Next : # [HRPEN]
    Endif
Endif
#JOJAC - 2016-03-11 - REQ114309 US87 - END

If func AFNC.ACTIV("EVAEN")>0
  Local Integer FIRSTMIS, X
  Filter [MPI] Where POT = [M:POT0]COD
  nolign = 0
  For [MPI]MPI0
    FIRSTMIS = 1
    If nolign<=dim([M:POT1]MIS)-1
      nolign += 1
      [M:POT1]MIS(nolign-1)         = [F:MPI]MIS
      [M:POT1]WMIS(nolign-1)        = [F:MPI]MIS
      [M:POT1]MISWEI(nolign-1)      = [F:MPI]MISWEI
      For X = 1 To dim([F:MPI]IND)
        If [F:MPI]IND(X-1) <> ""
          If FIRSTMIS = 1 : FIRSTMIS = 2 : Else nolign += 1  :Endif
          [M:POT1]WMIS(nolign-1)    = [F:MPI]MIS
          [M:POT1]IND(nolign-1)     = [F:MPI]IND(X-1)
          [M:POT1]INDWEI(nolign-1)  = [F:MPI]INDWEI(X-1)
        Else
          Break
        Endif
      Next X
    Endif
  Next
  Assign "[M:POT1]NBRMIS" With nolign
  Filter [MPI]
  Affzo [M:POT1]
  Endif

#ADNGO - 2017-11-30 - X3-47444 - START
 For nolign=1 To dim([M:POT7]HAB)
  If [M:POT7]HAB(nolign-1)="":Break:Endif
  Filter [F:HRLIC] Where COD = [M:POT7]HAB(nolign-1)
  Read [F:HRLIC] First
  Filter [F:HRLIC]
  If !fstat Then
    If [F:HRLIC]LEG <> ""
      Call LECTEXTRA([M:POT7]DES(nolign-1),"HRLICAUT","DESAXX",[M:POT7]HAB(nolign-1),[F:HRLIC]LEG) From ATEXTRA
    Else
      Call LECTEXTRA([M:POT7]DES(nolign-1),"HRLICAUT","DESAXX",[M:POT7]HAB(nolign-1),"") From ATEXTRA
    Endif
  Endif
 Next
#ADNGO - 2017-11-30 - X3-47444 - END

Return

########################
$RAZDUP
Effzo [M:POT5]
Return

###############################
# JML 20/07/10 Loading new table JOBTYPDEF LOT P01
$CRE_MOD
Gosub ANNULE
If GOK<1 : Return : Endif

  ###############################
  #03/08/12 - DKA - Handle translatable texts
  If GREP="D"
   ## In duplication mode we keep the translated text
   Call DUPTEXTRA("POSTE","DES",   CLECUR1,"","POSTE","DES",   [F:POT]COD,"")  From ATEXTRA
   Call DUPTEXTRA("POSTE","DESSHO",CLECUR1,"","POSTE","DESSHO",[F:POT]COD,"")  From ATEXTRA
  Endif
  Call MAJTEXTRA([M:POT0]DES,   "POSTE","DES",   [F:POT]COD,"") From ATEXTRA
  Call MAJTEXTRA([M:POT1]DESSHO,"POSTE","DESSHO",[F:POT]COD,"") From ATEXTRA
  ###############################

For nolign=1 To [M:POT2]NBRDIC
 Raz [F:POD]
 [F:POD] = [M:POT0]
 [F:POD] = [M:POT2]
 Write [POD]
 If fstat
  GOK = 0 : Call FSTA("POD") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif

# SEGAY 19/11/10 EXI 68086 POSTEHAB LOT P01
For nolign=1 To [M:POT7]NBRHAB
 Raz [F:PHA]
 [F:PHA] = [M:POT0]
 [F:PHA] = [M:POT7]
 [F:PHA]NUMLIG = nolign
 Write [PHA]
 If fstat
  GOK = 0 : Call FSTA("PHA") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif

#JOJAC - 2016-03-11 - REQ114309 US87 - START
#Painfulness
If dim([M:POT8]PEN) > 0
    For nolign=1 To [M:POT8]NBRPEN
        Raz [F:HRPEN]
        [F:HRPEN] = [M:POT0]
        [F:HRPEN] = [M:POT8]
        Write [F:HRPEN]
        If fstat
            GOK = 0 : Call FSTA("HRPEN") From GLOCK : Break
        Endif
    Next nolign
    If GOK<1 : Return : Endif
Else
    If dim([M:POT1]PEN)>0
        For nolign=1 To [M:POT1]NBRPEN
            Raz [F:HRPEN]
            [F:HRPEN] = [M:POT0]
            [F:HRPEN] = [M:POT1]
            Write [F:HRPEN]
            If fstat
                GOK = 0 : Call FSTA("HRPEN") From GLOCK : Break
            Endif
        Next nolign
        If GOK<1 : Return : Endif
    Endif
Endif

If func AFNC.ACTIV("EVAEN")>0
  Local Integer Y,Z,K
  Delete [F:MPI] Where [F:MPI]POT=[M:POT0]COD
  If fstat=1 | fstat>5
    GOK=0 : Call RSTA("MPI",[M:POT0]COD) From GLOCK : Return
  Endif
  Delete [F:MPI] Where [F:MPI]POT=""
  If fstat=1 | fstat>5
    GOK=0 : Call RSTA("MPI",[M:POT0]COD) From GLOCK : Return
  Endif

  For nolign = 1 To [M:POT1]NBRMIS

    If [M:POT1]WMIS(nolign-1) = "" : Break: Endif
    If [M:POT1]MIS(nolign-1) = [M:POT1]WMIS(nolign-1)
      Raz [F:MPI]
      Y = nolign
      [F:MPI]POT      = [M:POT0]COD
      [F:MPI]MIS      = [M:POT1]MIS(nolign-1)
      [F:MPI]MISWEI   = [M:POT1]MISWEI(nolign-1)
      K = 0
      For Z = Y To [M:POT1]NBRMIS
        If K > 0 and [M:POT1]MIS(Z-1) = [M:POT1]WMIS(Z-1) : nolign-=1 : Break : Endif
        [F:MPI]IND(K)     = [M:POT1]IND(Z-1)
        [F:MPI]INDWEI(K)  = [M:POT1]INDWEI(Z-1)
        K+=1
        nolign+=1
      Next
    Endif
    Write [F:MPI]
      If fstat
      GOK=0 : Call FSTA("MPI") From GLOCK : Break
    Endif
  Next
Endif

#JOJAC - 2016-03-11 - REQ114309 US87 - END
Return

$ANNULE
  ###############################
  #03/08/12 - DKA - Handle translatable texts
  If(dim(SUPP)>0)
    Call SUPTEXTRA("POSTE","DES",   [L]CODE,"") From ATEXTRA
    Call SUPTEXTRA("POSTE","DESSHO",[L]CODE,"") From ATEXTRA
  Endif
  ###############################

Delete [POD] Where [F:POD]COD=[M:POT0]COD

If fstat=1 : GOK=-1 : Call RSTA("POD",[M:POT0]COD) From GLOCK : Return : Endif

# SEGAY 19/11/10 EXI 68086 POSTEHAB LOT P01
Delete [PHA] Where [F:PHA]COD=[M:POT0]COD
If fstat=1 : GOK=-1 : Call RSTA("PHA",[M:PHA0]COD) From GLOCK : Return : Endif

#JOJAC - 2016-03-11 - REQ114309 US87 - START
#Painfulness
If dim([M:POT8]PEN) > 0
    Delete [HRPEN] Where [F:HRPEN]COD=[M:POT0]COD
    If fstat <> 0 & fstat <> 4
        [V]GOK = 0
        Call FSTA("HRPEN") From GLOCK
        Return
    Endif
Else
    If dim([M:POT1]PEN)>0
      Delete [HRPEN] Where [F:HRPEN]COD=[M:POT0]COD
      If fstat=1 : GOK=-1 : Call RSTA("HRPEN",[M:PHA0]COD) From GLOCK : Return : Endif
    Endif
Endif
Return

$VERIF_MOD
$VERIF_CRE
#ADNGO - 2017-04-25 - X3-33737 - START
##109374
#If dim([M:POT8]NBRPEN)>0 & [M:POT8]NBRPEN>0
# FLGPEN=0
# For I=0 To dim([M:POT8]PEN)-1
#  If [M:POT1]DATSTRVLY>[M:POT8]ENDDATPEN(I) & [M:POT8]ENDDATPEN(I)<>[0/0/0] & [M:POT1]DATSTRVLY<>[0/0/0]
#   FLGPEN+=1
#   Break
#  Endif
#  If [M:POT1]DATENDVLY<>[0/0/0] & [M:POT1]DATENDVLY<[M:POT8]STRDATPEN(I) & [M:POT8]STRDATPEN(I)<>[0/0/0]
#   FLGPEN+=1
#   Break
#  Endif
# Next
# If FLGPEN
#  Call AVERTIR (mess(21,10724,1), [L]VOK) From GESECRAN :#Veuillez contrôler la cohérence des dates des facteurs de pénibilité
#  If [L]VOK = 1
#   OK=0 : Return
#  Endif
# Endif
#Endif
If func AFNC.ACTIV("EVAEN")>0
  Local Integer CELLCOUNT : CELLCOUNT = 0
  If [M:POT1]INDFLG = 2
    CELLCOUNT = find("",[M:POT1]IND(0..[M:POT1]NBRMIS-1)(0..NOL-1),[M:POT1]IND(0..[M:POT1]NBRMIS-1)(NOL+1..dim([M:POT1]IND(0..[M:POT1]NBRMIS-1))-1))
  Endif
  If CELLCOUNT = 0
  #109374
    If dim([M:POT8]NBRPEN)>0 & [M:POT8]NBRPEN>0
     FLGPEN=0
     For I=0 To dim([M:POT8]PEN)-1
      If [M:POT1]DATSTRVLY>[M:POT8]ENDDATPEN(I) & [M:POT8]ENDDATPEN(I)<>[0/0/0] & [M:POT1]DATSTRVLY<>[0/0/0]
       FLGPEN+=1
       Break
      Endif
      If [M:POT1]DATENDVLY<>[0/0/0] & [M:POT1]DATENDVLY<[M:POT8]STRDATPEN(I) & [M:POT8]STRDATPEN(I)<>[0/0/0]
       FLGPEN+=1
       Break
      Endif
     Next
     If FLGPEN
      Call AVERTIR (mess(21,10724,1), [L]VOK) From GESECRAN :#Veuillez contrôler la cohérence des dates des facteurs de pénibilité
      If [L]VOK = 1
       OK=0 : Return
      Endif
     Endif
    Endif

    If func AFNC.ACTIV("EVAEN")>0
      Local Integer STAT, K : STAT = 1
      Local Char ERRMESS(50),RETMSG(250)
      Local Char MISARR(GLONMIS)(0..)
      Local Decimal MISWEIARR(0..)
      Local Char WMISARR(GLONMIS)(0..)
      Local Decimal INDWEIARR(0..)
      Local Integer MISEQ,INDEQ,INDFLG
      If [M:POT1]MISWEIFLG <> 2 : [M:POT1]MISEQ = 2 : Endif
      If [M:POT1]INDWEIFLG <> 2 : [M:POT1]INDEQ = 2 : Endif
      MISEQ   = [M:POT1]MISEQ
      INDFLG  = [M:POT1]INDFLG
      INDEQ   = [M:POT1]INDEQ


      K = 0
      #Storing grid values
      If [M:POT1]NBRMIS >0
        For nolign = 1 To [M:POT1]NBRMIS
          MISARR(K)      = [M:POT1]MIS(nolign-1)
          MISWEIARR(K)   = [M:POT1]MISWEI(nolign-1)
          WMISARR(K)     = [M:POT1]WMIS(nolign-1)
          INDWEIARR(K)   = [M:POT1]INDWEI(nolign-1)
          K+=1
        Next

        Call VALID_MISIND(STAT,MISEQ,MISARR,MISWEIARR,INDFLG,INDEQ,WMISARR,INDWEIARR,RETMSG) From EVAFNC
        If STAT = 0
          GMESSAGE = RETMSG
          OK=0
        Else
          #Fill the grid on the screen with calculated values
          K = 0
          For nolign = 1 To [M:POT1]NBRMIS
            [M:POT1]MISWEI(nolign-1) = MISWEIARR(K)
            [M:POT1]INDWEI(nolign-1) = INDWEIARR(K)
            K+=1
          Next
          Affzo [M:POT1]
        Endif
      Endif
    Endif
  Else
    GMESSAGE = mess(00001,10002,1)
    GOK=0
  Endif
Endif
#ADNGO - 2017-04-25 - X3-33737 - END
#JOJAC - 2016-03-11 - REQ114309 US87 - END
Return
