If func SUBJOT.IS_CAR
  NBR_NBRFAM = [M:POT6]NBRFAM
  [M:POT1]JOBPOT = VALEUR #Bug 71019 récupération des compétences dossier, famille, métier que si l'emploi type est renseigné
  Gosub INIT_CPC
 #fin DBA
  If VALEUR<>"" & ![M:POT1]NBRMIS
   # On hérite du classement conv du nouvel emploi type
   # On hérite des missions du nouvel emploi type
   For I=0 To dim([M:POT1]MIS)-1
    If [F:JOT]MIS(I)<>"" & !find([F:JOT]MIS(I),[M:POT1]MIS(0..[M:POT1]NBRMIS-1))
     [M:POT1]MIS([M:POT1]NBRMIS) = [F:JOT]MIS(I)
     [M:POT1]NBRMIS +=1
    Endif
   Next
  Endif
Endif #* END_Bug 71973

Affzo [M:POT3]CCV
Affzo [M:POT1]30
#* Test si code activité Carrière
#* SEGAY 28/02/11 Bug 71973
If func SUBJOT.IS_CAR
  Affzo [M:POT4]
  Affzo [M:POT6]5
Endif #* END_Bug 71973
End

