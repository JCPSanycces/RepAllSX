######################################################################################
## Etiquette ajoutée par le superviseur (écran POT2) 23/08/2010 15:18:44 (JML)
######################################################################################
Subprog C_LEV(VALEUR)
Variable Integer VALEUR
# JML 17/08/10 CG She doesn't want CLLCVT, No 23/08/10 just prohibit it with LEV
If VALEUR=8 & [M]FLD(nolign-1)="CLLCVT"
 # ML 508 Convention collective
 GMESSAGE = mess(172,10702,1) : # Paramétrage interdit
 mkstat = 2 : End
Endif
End
