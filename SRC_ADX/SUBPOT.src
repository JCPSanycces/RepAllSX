Subprog C_STRDATPEN(VALEUR)
Variable Date    VALEUR
Gosub SETNOL
# => Date de début obligatoire
If [L]VALEUR = [0/0/0] : mkstat = 2 : End : Endif
If [L]VALEUR < [M:POT1]DATSTRVLY or ( [M:POT1]DATENDVLY <> [0/0/0] & [L]VALEUR > [M:POT1]DATENDVLY )
#ADNGO - 2017-05-02 - X3-33737 - START
  #GMESSAGE =mess(151,720,1) :# Date incompatible avec la période de validité du poste'
  GMESSAGE =mess(151,10720,1) :# Date incompatible avec la période de validité du poste'
#ADNGO - 2017-05-02 - X3-33737 - END
  mkstat=2 : End
Endif

Call CTRL_OVERLAP([M:POT8]PEN([L]NOL), [L]NOL, [L]VALEUR, [L]VALEUR)
If mkstat=2 : End : Endif
End

