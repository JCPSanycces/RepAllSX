#JOJAC - 2016-03-14 - REQ114309 US87 - START
#Painfulness
#**
#* Test Painfulness period with POST validity
#*
#* @param WDATSTRVLY : Starting Date of the post
#* @param WDATENDVLY : Ending Date of the post
#* @param WSTRDAT    : Starting Date of the current line of PEN
#* @param WENDDAT    : Ending Date of the current line of PEN
#*!
Subprog CTRL_DATE_POSTE(WDATSTRVLY,WDATENDVLY, WSTRDAT,WENDDAT)
Value Date WDATSTRVLY,WDATENDVLY
Value Date WSTRDAT, WENDDAT

If    (WDATENDVLY<>[0/0/0] & (WSTRDAT>WDATENDVLY  |  WENDDAT>WDATENDVLY | WENDDAT=[0/0/0]) )
&   | (WDATSTRVLY<>[0/0/0] &  WSTRDAT<WDATSTRVLY)
  #ADNGO - 2017-05-02 - X3-33737 - START
  #GMESSAGE =mess(151,720,1) :# Date incompatible avec la période de validité du poste'
  GMESSAGE =mess(151,10720,1) :# Date incompatible avec la période de validité du poste'
  #ADNGO - 2017-05-02 - X3-33737 - END
  mkstat=2 : End
Endif
End
#JOJAC - 2016-03-14 - REQ114309 US87 - END

