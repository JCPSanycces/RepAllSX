# For I=0 To [M:POT1]NBRMIS-1
#  If [M:POT1]MIS(I)<>"" & find([M:POT1]MIS(I),[F:JOT]MIS(0..dim([M:POT1]MIS)-1))
#   Dela I,1 [M:POT1]NBRMIS
#   [M:POT1]NBRMIS -=1
#   I=-1 :#pour repartir du début
#  Endif
# Next
# # Suppression des compétences héritées (de l'ancien emploi type)
# For I=0 To [M:POT4]NBRLIG-1
#  If [M:POT4]CPC(I)<>"" & [M:POT4]ORI(I)<>6    :#Pas manuelle
#   Dela I,1 [M:POT4]NBRLIG
#   [M:POT4]NBRLIG -=1
#   I=-1 :#pour repartir du début
#  Endif
# Next
#Endif
Raz [F:JOT]
If VALEUR<>""
 Call LECTURE("JOT",VALEUR,"") From CONTOBJ
 If fstat : Raz [F:JOT] : Endif
 # JML 31/08/10 CG Change only if empty
 If [M:POT3]CCV=""
  [M:POT3]CCV = [F:JOT]CCV : # From POT1 to POT3
 Endif
 # DBA 30/08/10
#* Test si code activité Carrière
#* SEGAY 28/02/11 Bug 71973
 If func SUBJOT.IS_CAR
   [M:POT6]JOBGRP = [F:JOT]JOBGRP
   [M:POT6]UOMGRP = [F:JOT]UOMGRP
 Endif #* END_Bug 71973
#* Test si code activité Carrière
#* SEGAY 28/02/11 Bug 71973
#Else
# Effzo[M:POT6]JOBGRP,UOMGRP
#Endif
Elsif func SUBJOT.IS_CAR
 Effzo[M:POT6]JOBGRP,UOMGRP
Endif
