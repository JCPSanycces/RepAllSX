#ADNGO - 2017-10-18 - X3-29326 - START
Subprog AS_MIS(VALEUR)
Variable Char    VALEUR()
  If func AFNC.ACTIV("EVAEN")=0 : End : Endif
  Raz [M:POT1]MISWEI(nolign-1)
End
#ADNGO - 2017-10-18 - X3-29326 - END

#ADNGO - 2017-10-18 - X3-29326 - START
Subprog AP_MIS(VALEUR)
Variable Char    VALEUR()
Local Char PREVMIS : PREVMIS =[M:POT1]WMIS(nolign-1)
If func AFNC.ACTIV("EVAEN")=0 : End : Endif
#Need to set WMIS even if there were no change
If VALEUR = ""
  Actzo [M:POT1]WMIS(nolign-1)
  [M:POT1]WMIS(nolign-1)    = [M:POT1]WMIS(nolign-2)
  Diszo [M:POT1]MISWEI(nolign-1)
  Diszo [M:POT1]MIS(nolign-1)
Else
  Actzo [M:POT1]MISWEI(nolign-1)
  [M:POT1]WMIS(nolign-1) = VALEUR
Endif
Affzo [M:POT1]MISWEI(nolign-1)
For nolign = 1 To [M:POT1]NBRMIS
  If [M:POT1]WMIS(nolign-1) = PREVMIS
     [M:POT1]WMIS(nolign-1) = VALEUR
  Endif
Next
Affzo [M:POT1]WMIS(nolign-1)
End
#ADNGO - 2017-10-18 - X3-29326 - END

#ADNGO - 2017-10-18 - X3-29326 - START
Subprog AM_MIS(VALEUR)
Variable Char    VALEUR()
If func AFNC.ACTIV("EVAEN")=0 : End : Endif
#Need to set WMIS even if there were no change
If VALEUR = ""
  Actzo [M:POT1]WMIS(nolign-1)
  [M:POT1]WMIS(nolign-1)    = [M:POT1]WMIS(nolign-2)
  Diszo [M:POT1]MISWEI(nolign-1)
  Diszo [M:POT1]MIS(nolign-1)
Else
  Actzo [M:POT1]MISWEI(nolign-1)
  [M:POT1]WMIS(nolign-1) = VALEUR
Endif
Affzo [M:POT1]MISWEI(nolign-1)
For nolign = 1 To [M:POT1]NBRMIS
  If [M:POT1]WMIS(nolign-1) = VALEUR
    [M:POT1]IND(nolign-1) = ""
  Endif
Next
Affzo [M:POT1]IND(nolign-1)
End
#ADNGO - 2017-10-18 - X3-29326 - END

#ADNGO - 2017-10-18 - X3-29326 - START
Subprog C_MISWEI(VALEUR)
Variable Decimal VALEUR
If func AFNC.ACTIV("EVAEN")=0 : End : Endif
If VALEUR < 0
  mkstat = 1 : GMESSAGE = mess(00180,00141,1)
Endif
If [M:POT1]MISWEIFLG = 2 and [M:POT1]MIS(nolign-1) <> "" and [M:POT1]MISEQ <> 2
  If VALEUR = 0
    mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
Endif
End
#ADNGO - 2017-10-18 - X3-29326 - END

Subprog C_IND(VALEUR)
Variable Char    VALEUR()
Local Integer FOUND : FOUND = 0
If clalev([F:MIS1])=0  : Local File MISIND     [MIS1] : Endif
  For [MIS1] Where MIS = [M:POT1]WMIS(nolign-1)
    If [F:MIS1]COD = VALEUR Then
      FOUND = 1
    Endif
  Next
If FOUND = 0 Then
  GMESSAGE = mess(00104,00199,1)
  mkstat=2 : End
Endif
If func AFNC.ACTIV("EVAEN")=0 : End : Endif
#Test for duplication
If VALEUR <> ""
  Call UNICITE(VALEUR,[M:POT1]IND(0..[M:POT1]NBRMIS-1)) From OBJDIV
Endif
If [M:POT1]INDFLG = 2
  If VALEUR = ""
    mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
Endif
End


