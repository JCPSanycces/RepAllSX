  If VALEUR <> ""
    Call UNICITE(VALEUR,[M:POT1]MIS(0..[M:POT1]NBRMIS-1)) From OBJDIV
  Endif
Else
  Call UNICITE(VALEUR,[M:POT1]MIS(0..[M:POT1]NBRMIS-1)) From OBJDIV
Endif

If func AFNC.ACTIV("EVAEN")>0
  If nolign = 1 and VALEUR = ""
    mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
