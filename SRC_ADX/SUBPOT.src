######################################################################################
Subprog AM_CCV(VALEUR)
Variable Char    VALEUR()
Read [HRCCV]CCV0=VALEUR
If !fstat
 [M:POT3] = [F:HRCCV]
#JOJAC - 2016-03-14 - REQ114309 US87 - START
  If func AFNC.ACTIV("FKSQS") > 0
    If func DIVPAYE.EXISTE_KXX("SUBPOTKSA") Then
      Call AM_CCV(VALEUR) From SUBPOTKSA
    Endif
  Endif
#JOJAC - 2016-03-14 - REQ114309 US87 - END
Endif
# FQ81085 - MABON 22/06/12 - Object HRCCV selection
If VALEUR="" Then [M:POT3]DES="" : Endif
# End MABON
#ADNGO - 2017-04-25 - X3-33737 - START
If VALEUR <> ""
  Call LECTEXTRA([M]DES,"CLASSCONV","DES",VALEUR,GCURLEG) From ATEXTRA
Endif
#ADNGO - 2017-04-25 - X3-33737 - END
Affzo [POT3]10-99
End
