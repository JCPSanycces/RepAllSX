Subprog AM_FCYPOT(VALEUR)
Variable Char     VALEUR
If clalev([M:FCY])=0 : Local File FACILITY [FCY] : Endif
If [M]CPYPOT=""
 Read [FCY]FCY0=VALEUR
 If !fstat
  [M]CPYPOT = [F:FCY]LEGCPY
  Affzo [M]CPYPOT, ZCPYPOT
 Endif
Endif
End

Subprog AM_DATSTRVLY(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0]
 Filter [F:EPO] Where POT=[M:POT0]COD & DATPOT<VALEUR
 Read [F:EPO]EPO2 First
 Filter [F:EPO]
 If !fstat
  #Poste déjà occupé par xxx
  GMESSAGE=num$([F:EPO]DATPOT)-":"-mess(3,10720,1)-[F:EPO]REFNUM
  mkstat=2 : End
 Endif
#JOJAC - 2016-03-11 - REQ114309 US87 - START
 #Painfulness
 If dim([M]PEN)>0
  Local Integer I,OK,FLGPEN
  If VALEUR > [M]DATSTRVLY
    FLGPEN=0
    For I=0 To [M]NBRPEN-1
      # starting date < new date of validity
      If [M]STRDATPEN(I)=[0/0/0] | [M]STRDATPEN(I)< VALEUR
        If VALEUR > [M]ENDDATPEN(I) & [M]ENDDATPEN(I)<>[0/0/0]
          FLGPEN=1
          Break
        Endif
      Endif
    Next
    If FLGPEN
    #ADNGO - 2017-05-02 - X3-33737 - START
     #Call AVERTIR (mess(21,724,1), [L]OK) From GESECRAN :#Veuillez contrôler la cohérence des dates des facteurs de pénibilité
     Call AVERTIR (mess(21,10724,1), [L]OK) From GESECRAN :#Veuillez contrôler la cohérence des dates des facteurs de pénibilité
    #ADNGO - 2017-05-02 - X3-33737 - END
     If [L]OK = 1
      mkstat = 2 : End
     Endif
    Else
     For I=0 To [M]NBRPEN-1
      If [M]STRDATPEN(I)=[0/0/0] | [M]STRDATPEN(I)< VALEUR
       If VALEUR <= [M]ENDDATPEN(I) | [M]ENDDATPEN(I)=[0/0/0]
        [M]STRDATPEN(I)=VALEUR
        Affzo [M:POT8]STRDATPEN(I)
       Endif
      Endif
     Next
     Affzo [M:POT1]40
    Endif
  Endif
 Endif
#JOJAC - 2016-03-11 - REQ114309 US87 - END
Endif
End

Subprog AM_DATENDVLY(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0]
 Filter [F:EPO] Where POT=[M:POT0]COD & DATPOT>VALEUR
 Read [F:EPO]EPO2 First
 Filter [F:EPO]
 If !fstat
  #Poste déjà occupé par xxx
  GMESSAGE=num$([F:EPO]DATPOT)-":"-mess(3,10720,1)-[F:EPO]REFNUM
  mkstat=2 : End
 Endif
#JOJAC - 2016-03-11 - REQ114309 US87 - START
 #Painfulness
 If dim([M:POT8]ENDDATPEN) > 0
  Local Integer IND, OK, FLGPEN
  FLGPEN=0
  For [L]IND = 0 To [M:POT8]NBRPEN - 1
  #109374
   If [M:POT8]PEN([L]IND) <> "" & ([M:POT8]ENDDATPEN([L]IND) <> [0/0/0] & [L]VALEUR < [M:POT8]ENDDATPEN([L]IND) )
    FLGPEN+=1
    Break
   Endif
   If VALEUR<[M:POT8]STRDATPEN([L]IND) & [M:POT8]STRDATPEN([L]IND)<>[0/0/0]
    FLGPEN+=1
    Break
   Endif
  Next
  If FLGPEN
  #ADNGO - 2017-05-02 - X3-33737 - START
   #Call AVERTIR (mess(21,724,1), [L]OK) From GESECRAN :#Veuillez contrôler la cohérence des dates des facteurs de pénibilité
   Call AVERTIR (mess(21,10724,1), [L]OK) From GESECRAN :#Veuillez contrôler la cohérence des dates des facteurs de pénibilité
  #ADNGO - 2017-05-02 - X3-33737 - END
   If [L]OK = 1
    mkstat = 2 : End
   Endif
  Endif
 Endif
#JOJAC - 2016-03-11 - REQ114309 US87 - END
Endif
End

Subprog C_POT2(VALEUR)
Variable Char    VALEUR()

If VALEUR="" : End : Endif
If VALEUR=[M]COD
 # Un poste ne peut être rattaché hiérarchiquement à lui-même
 GMESSAGE = mess(2,10720,1)
 mkstat = 2 : End
Endif
If clalev([F:POT2])=0 : Local File POSTE   [POT2] : Endif
Local Char SUPH (GLONPOT)
SUPH=VALEUR
While SUPH<>""
 Read[F:POT2]POT0=SUPH
 If fstat | [F:POT2]POT2=[M:POT0]COD
  # Un poste ne peut être rattaché hiérarchiquement à son subordonné
  GMESSAGE = mess(39,10720,1)
  mkstat = 2 : Break
 Else
  SUPH=[F:POT2]POT2
 Endif
Wend
If mkstat : End: Endif
End

