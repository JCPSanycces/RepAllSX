Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
# ML 508 Société
If [M]LEV(nolign-1)<>4 : mkstat=1 : End : Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
# ML 508 Site
If [M]LEV(nolign-1)<>5 : mkstat=1 : End : Endif
End

Subprog AS_CLLCVT(VALEUR)
Variable Char    VALEUR()
# ML 508 Convention collective
If [M]LEV(nolign-1)<>9 : mkstat=1 : End : Endif
End

