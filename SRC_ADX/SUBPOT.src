If VALEUR="" : Call BASNIVCPC([M:POT4]CPC(nolign-1),VALEUR) From SUBCPC : Endif
End

Subprog AM_NIV(VALEUR)
Variable Char    VALEUR()
[M:POT4]ORI(nolign-1)=len(mess(0,10937,1)) :#manuelle
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran POT2) 21/07/2010 09:05:07 (JML)
######################################################################################
Subprog C_FLD(VALEUR)
Variable Char    VALEUR()
Read [DIC]DIC0 = VALEUR
If fstat
 GMESSAGE = VALEUR - mess(41,100,1) : # Champ inexistant
 mkstat = 2 : End
# SEGAY - 11/03/11 - Bug 72320
#Elsif [F:DIC]POTFLG=1
# GMESSAGE = VALEUR - mess(106,10702,1) : # Champ inactif
# mkstat = 2 : End
Elsif [F:DIC]ENAFLG=1
 GMESSAGE = VALEUR - mess(106,10702,1) : # Champ inactif
 mkstat = 2 : End
Elsif [F:DIC]TBL<>"EMPLOCTR"
 GMESSAGE = mess(14,10715,1) : # Seule la table EMPLOCTR est utilisable
 mkstat = 2 : End
Endif
If VALEUR<>[M]FLD(nolign-1)
 Call TEXTE([F:DIC]DES,[M]TIT(nolign-1)) From OBJDIV
 [M]TBL(nolign-1) = [F:DIC]TBL
 [M]FRM(nolign-1) = ""
 #83971 : In the If !
 Gosub CHARGE_DICO
Endif
End
######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran POT2) 04/08/2010 16:57:17 (JML)
# JML 04/08/10 LOT P01 To be able to add a filter...
######################################################################################
Subprog S_FLD(VALEUR)
Variable Char    VALEUR()

If !GWEBSERV
# SEGAY - 11/03/11 - Bug Bug 72320
# Filter [DIC] Where [DIC]TBL="EMPLOCTR" & [DIC]POTFLG=2
 Filter [DIC] Where [DIC]TBL="EMPLOCTR"
 ## Action SELOBJW
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJW"
 PARMSK(1) = "DIC"
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 GACTION = SAVACT
 Filter [DIC]
Endif
Gosub AFF From GSAISIE
End
######################################################################################
Subprog B1_NBRDIC

Local Integer NB_LIG
Local Decimal L_LONG

# JML 17/08/10 CG She doesn't want CLLCVT, No 23/08/10 just prohibit it with LEV
Filter [DIC] Where [F:DIC]TBL="EMPLOCTR" & [F:DIC]POTFLG=2 : # & !find([F:DIC]FLD,"CLLCVT")
Raz NB_LIG
For [DIC]DIC3
 # SEGAY - 11/03/11 - Bug 72320 dépassement capacité
 If [M]NBRDIC>=dim([M:POT2]FLD)
     # Tableau plein
    Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
    Break
 Endif
 If !find([F:DIC]FLD,[M]FLD(0..[M]NBRDIC-1))
  [M]NBRDIC += 1
  nolign = [M]NBRDIC
  [M] = [F:DIC]
  Call TEXTE([F:DIC]DES,[M]TIT(nolign-1)) From OBJDIV
  Gosub CHARGE_DICO
#SEGAY 31/03/11 BUG 72823 convention que si GPAYE
  If GPAYE
    [M:POT2]UNQ(nolign-1) = [M:POT2]FLD(nolign-1)+"~"+[M:POT2]CPY(nolign-1)+"~"+[M:POT2]FCY(nolign-1)
&                        +"~"+[M:POT2]CLLCVT(nolign-1)+"~"+[M:POT2]POP(nolign-1)
  Else
    [M:POT2]UNQ(nolign-1) = [M:POT2]FLD(nolign-1)+"~"+[M:POT2]CPY(nolign-1)+"~"+[M:POT2]FCY(nolign-1)
&                        +"~"+[M:POT2]POP(nolign-1)
  Endif
  NB_LIG += 1
 Endif : # If !find([F:DIC]FLD,[M]FLD(0..[M]NBRDIC-1))
Next : # [DIC]DIC3
Filter [DIC]


Affzo [POT2]
If NB_LIG
 mkstat = 4
Endif
End
######################################################################################
$CHARGE_DICO
[M:POT2]LEV(nolign-1) = 1 : # ML 508 Société
Read [ATZ]CODZONE="EMPLOCTR";[F:DIC]FLD
If !fstat
 Read [ATY]CODTYP=[F:ATZ]CODTYP
 If !fstat
  [M:POT2]CODTYP(nolign-1) = [F:ATZ]CODTYP
  [M:POT2]NOLIB(nolign-1)  = [F:ATZ]NOLIB
  L_LONG = [F:ATZ]LONG
  If !L_LONG
   L_LONG = [F:ATY]LNGTYP
  Endif
  [M:POT2]LONG(nolign-1)   = L_LONG
  [M:POT2]CODOBJ(nolign-1) = [F:ATY]OBJLIEN
 Else
  Raz [F:ATY]
 Endif : # If !fstat ATY
Else
 Raz [F:ATZ]
Endif
Case [F:ATZ]CODTYP
 When "ADI"
 Read [AMP]CODPAR=2;"EMPLOCTR";[F:DIC]FLD;[F:ATZ]CODTYP
 If !fstat
  # Certains paramètres ADI ont des " ou des '
  [F:AMP]VALPAR = ctrans([F:AMP]VALPAR,'"','')
  [F:AMP]VALPAR = ctrans([F:AMP]VALPAR,"'","")
  [M:POT2]VALPAR(nolign-1) = [F:AMP]VALPAR
 Endif
 When "ORG","RUB","CUM","PRF"
  [M:POT2]VALPAR(nolign-1) ="GCURLEG"
 Endcase
 #24/08/12 - PCA - DO NOT DEFAULT THE LEGLEV WITH LEGFIL
 [M:POT2]LEGLEV(nolign-1) =""
Return
######################################################################################
Subprog AS_LEV(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
# Desactivation
#GMENLOC(5)=1 : # ML 508 Salarié
#GMENLOC(6)=1 : # ML 508 Contrat
#GMENLOC(7)=1 : # ML 508 Service
# FQ66382 - MABON 10/05/11 - Ajout de l'entrée 9 dans le menu, donc désactivation ici
#GMENLOC(9)=1 : # ML 508 Profil
#PCA 21/08/12 Changed index in local menu 10508

GMENLOC(6)=1 : #Salarié
GMENLOC(7)=1 : #Contrat
GMENLOC(8)=1 : #Service
GMENLOC(10)=1 : #Profil
End
