######################################################################################
Subprog C_INDWEI(VALEUR)
Variable Decimal VALEUR
If func AFNC.ACTIV("EVAEN")=0 : End : Endif
If VALEUR < 0
  mkstat = 1 : GMESSAGE = mess(00180,00141,1)
Endif
If [M:POT1]INDFLG = 2 and [M:POT1]INDWEIFLG = 2 and [M:POT1]INDEQ <> 2
  If VALEUR = 0
    mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
Endif
End


