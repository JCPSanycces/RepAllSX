Subprog AM_JOBPOT(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Integer NBR_NBRFAM

#JOJAC - 2016-03-11 - REQ114309 US87 - START
If func AFNC.ACTIV("FKSEQ")>0 & func DIVPAYE.EXISTE_KXX("SUBPOTKSA") Then
  Call AM_JOBPOT(VALEUR) From SUBPOTKSA

Endif

##JOJAC - TEST
