#ADNGO - 2017-10-18 - X3-29326 - START
Subprog AM_MISWEIFLG(VALEUR)
Variable Integer VALEUR
If func AFNC.ACTIV("EVAEN")=0 : End : Endif
If VALEUR = 2
  Chgfmt [M:POT1]MISWEI     With "+Nz:3.2"
  [M:POT1]MISEQ = 2
  Actzo [M:POT1]MISEQ
Else
  Chgfmt [M:POT1]MISWEI     With "-Nz:3.2"         #: Raz [M:POT1]MISWEI
  [M:POT1]MISEQ = 2
  Diszo [M:POT1]MISEQ
Endif
Affzo [M:POT1]
End
#ADNGO - 2017-10-18 - X3-29326 - END
#ADNGO - 2017-10-18 - X3-29326 - START
Subprog AM_INDFLG(VALEUR)
Variable Integer VALEUR
If func AFNC.ACTIV("EVAEN")=0 : End : Endif
If VALEUR = 2
  Chgfmt [M:POT1]IND      With "+K:10X"
  Chgfmt [M:POT1]INDWEI   With "+Nz:3.2"
  [M:POT1]INDWEIFLG = 2
  Actzo [M:POT1]INDWEIFLG
  [M:POT1]INDEQ = 2
  Actzo [M:POT1]INDEQ
Else
  Chgfmt [M:POT1]IND      With "-K:10X"           : Raz [M:POT1]IND
  Chgfmt [M:POT1]INDWEI   With "-Nz:3.2"          : Raz [M:POT1]INDWEI
  [M:POT1]INDEQ = 1
  Diszo [M:POT1]INDEQ
  [M:POT1]INDWEIFLG = 1
  Diszo [M:POT1]INDWEIFLG
Endif
Affzo [M:POT1]
End
#ADNGO - 2017-10-18 - X3-29326 - END

#ADNGO - 2017-10-18 - X3-29326 - START
Subprog AM_INDWEIFLG(VALEUR)
Variable Integer VALEUR
If func AFNC.ACTIV("EVAEN")=0 : End : Endif
If VALEUR = 2
  Chgfmt [M:POT1]INDWEI     With "+Nz:3.2"
  [M:POT1]INDEQ = 2
  Actzo [M:POT1]INDEQ
Else
  Chgfmt [M:POT1]INDWEI     With "-Nz:3.2"         #: Raz [M:POT1]INDWEI
  [M:POT1]INDEQ = 2
  Diszo [M:POT1]INDEQ
Endif
Affzo [M:POT1]
End
#ADNGO - 2017-10-18 - X3-29326 - END

