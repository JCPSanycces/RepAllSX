## Etiquette de l'écran POT4
######################################################################################
# SEGAY - 24/11/10 - EXI 66105 LOT P01
#**
#* Init bouton du tableau des compétences
#* Bouton si l'héritage est <> manuelle
#*!
Subprog IB_NBRLIG
If [M:POT4]ORI(nolign-1)<>0 and [M:POT4]ORI(nolign-1)<>len(mess(0,10937,1))
  GBOUT3 = mess(65,10720,1) #Héritage manuel
Else
  Raz GBOUT3
Endif
End

# SEGAY - 24/11/10 - EXI 66105 LOT P01
#**
#* bouton de passage en héritage manuel
#*!
Subprog B3_NBRLIG
If [M:POT4]ORI(nolign-1)<>0 and [M:POT4]ORI(nolign-1)<>len(mess(0,10937,1))
   [M:POT4]ORI(nolign-1)=len(mess(0,10937,1))
   [M:POT4]CODORI(nolign-1)="" : # Pas de groupe de compétence
   Affzo [M:POT4]ORI(nolign-1)
   mkstat = 4
Endif
End

Subprog C_CPC(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:POT4]CPC(0..[M:POT4]NBRLIG-1)) From OBJDIV
# SEGAY 25/10/12 US 930 81085
If mkstat : End : Endif # SEGAY 25/10/12 US 930 81085
If VALEUR<>""
 If clalev([F:CPC])=0 : Local File COMPETENCE     [CPC] : Endif
 Read [F:CPC]CPC0=VALEUR
 If !fstat
  If dim([V]GCURLEG)>0 & [V]GCURLEG = "" & [F:CPC]LEG <> [V]GCURLEG
    GMESSAGE = mess(37,10720,1)-":"-VALEUR+chr$(10)+chr$(13)+mess(62,127,1)-":"-[F:CPC]LEG : # Réservé à la législation
    mkstat = 2
    GERR=1
    End
  Else
    Call CONTROLE("CPC","!",VALEUR,"",mkstat) From CONTOBJ
    If mkstat : GERR = 1  : End Endif
   Endif
 Else
   If dim(GAUTOSEL)>0 & GAUTOSEL=2 & GWEBSERV<>1
     Local Char    CRITERE_CPC(250)
     Call CRIT_LEG_HLEG ([L]VALEUR,"","[F:CPC]COD","","CPC","[F:CPC]LEG",GCURLEG,CRITERE_CPC) From TOOLSHRLEG

     Filter [F:CPC] Where  evalue(CRITERE_CPC)
     If rowcount([F:CPC]) > 1
# ## Action SELCPCLEGH
      Filter [F:CPC]
      If !GWEBSERV
        Local Char    PARMSK(250)(1..20) , SAVACT(20)
        SAVACT = GACTION : GACTION = "SELCPCLEGH"
        PARMSK(1) = GCURLEG
        Call S_TAB_CHAR(VALEUR,PARMSK,"SELCPCLEGH","TOOLSHRLEG","") From GACTION
        GACTION = SAVACT
      Endif
      Gosub AFF From GSAISIE
     Endif
     If rowcount([F:CPC])=  1
       Read [F:CPC]CPC0 First
       If !fstat
         [L]VALEUR = num$([F:CPC]COD)
       Endif
       Filter [F:CPC]
     Endif
     If !rowcount([F:CPC])
        Filter [F:CPC]
        Call CONTROLE("CPC","!",VALEUR,"",mkstat) From CONTOBJ
        If mkstat : GERR = 1  : End Endif
     Endif
     Filter [F:CPC]
   Else
     Call CONTROLE("CPC","!",VALEUR,"",mkstat) From CONTOBJ
     If mkstat : GERR = 1  : End Endif
   Endif
 Endif
Endif
End

#SEGAY 22/06/12 FQ83078
Subprog AM_CPC(VALEUR)
Variable Char    VALEUR()
Call LECTURE("CPC",VALEUR,"") From CONTOBJ
[M:POT4]FLGKEY(nolign-1)=[F:CPC]FLGKEY
Affzo [M:POT4]FLGKEY(nolign-1)
#JOJAC - 2016-03-14 - REQ114309 US87 - START
#FRLAA - 2015-08-25 - REQUIREMENT 109427 US 3817 - START
If func AFNC.ACTIV("FKSSD")>0
  If func DIVPAYE.EXISTE_KXX("SUBPOTKSA") Then
    Call AM_CPC(VALEUR) From SUBPOTKSA
  Endif
Endif
#FRLAA - 2015-08-25 - REQUIREMENT 109427 US 3817 - START
#JOJAC - 2016-03-14 - REQ114309 US87 - END
End

##Init du niveau le plus faible par défaut en saisie
