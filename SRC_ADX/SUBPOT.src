######################################################################################
Raz GPILOBJ
Call OBJET("POT",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################

$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "LIENS"    : Gosub LIENS
 When "RAZDUP"   : Gosub RAZDUP
 When "SETBOUT"  : Gosub SETBOUT
 When "CREATION" : Gosub CRE_MOD
 When "MODIF"    : Gosub CRE_MOD
 When "ANNULE"   : Gosub ANNULE
 When "FERME"      : Gosub FERME
#JOJAC - 2016-03-14 - REQ114309 US87 - START
 When "VERIF_CRE"  : Gosub VERIF_CRE
 When "VERIF_MOD"  : Gosub VERIF_MOD
#JOJAC - 2016-03-14 - REQ114309 US87 - END
 When "ABANDON"    : Gosub ABANDON
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "FIN_TABLE" : Gosub FIN_TABLE
 When "RAZCRE"    : Gosub RAZCRE
 When "APRES_CRE" : Gosub APRES_CRE #ADNGO - 2017-10-18 - X3-29326
# JOJAC - 2016-04-21 - REQ114309 US87 - START
 When "STYLE"    : Gosub STYLE
# JOJAC - 2016-04-21 - REQ114309 US87 - END

 When Default
Endcase
#JOJAC - 2016-03-11 REQ114309 US87 - START
If func AFNC.ACTIV("FKSQS")>0 & func DIVPAYE.EXISTE_KXX("SUBPOTKSA") Then
  Gosub ACTION From SUBPOTKSA
Endif
#JOJAC - 2016-03-11 REQ114309 US87 - END
Return

########################
$OUVRE
If clalev([F:JOT])=0    : Local File JOBTYP     [JOT]   : Endif
If clalev([F:EPO])=0    : Local File EMPLOPOT   [EPO]   : Endif
#46171
If clalev([F:HRCTR])=0  : Local File EMPLOCTR   [HRCTR] : Endif
If clalev([F:EPO2])=0   : Local File EMPLOPOT   [EPO2]  : Endif
If clalev([F:ATZ])=0    : Local File ATABZON    [ATZ]   : Endif
If clalev([F:ATY])=0    : Local File ATYPE      [ATY]   : Endif
If clalev([F:AMP])=0    : Local File AMSKPAR    [AMP]   : Endif
If clalev([F:GCP])=0    : Local File GRPCPC     [GCP]   : Endif : # JML 05/08/10
If clalev([F:HRSCA])=0  : Local File SCALE      [HRSCA] : Endif : # JML 05/08/10
If clalev([F:HRGCD])=0  : Local File GRPCPCD    [HRGCD] : Endif : # JML 05/08/10
If clalev([F:HRSDD])=0  : Local File SCALED     [HRSDD] : Endif : # JML 05/08/10
If clalev([F:CPC])=0    : Local File COMPETENCE [CPC]   : Endif : # JML 05/08/10
If clalev([F:ID])=0     : Local File EMPLOID    [ID]    : Endif : # JML 20/08/10
If clalev([F:HRCCV])=0  : Local File CLASSCONV  [HRCCV] : Endif
#ADNGO - 2017-11-30 - X3-47444 - START
If clalev([F:HRLIC])=0  : Local File HRLICAUT  [HRLIC] : Endif
#ADNGO - 2017-11-30 - X3-47444 - END
#ADNGO - 2017-10-18 - X3-29326 - START
If func AFNC.ACTIV("EVAEN")>0
  If clalev([F:MPI])=0  : Local File MISPOTIND  [MPI] : Endif
  If clalev([F:MJI])=0  : Local File MISJOTIND  [MJI] : Endif
Endif
#ADNGO - 2017-10-18 - X3-29326 - END

#JOJAC - 2016-03-11 - REQ114309 US 87 - START
#Painfulness
If func AFNC.ACTIV("KFR")
  If clalev([F:HRPEN])=0 : Local File HRPOTPEN [HRPEN] : Endif
Endif
#JOJAC - 2016-03-11 - REQ114309 US 87 - START

Link [HRCTR] With [ID]ID0=[F:HRCTR]REFNUM
&            As [LID]
&          Where [HRCTR]XITDAT=[0/0/0]

Local Integer I, L_IJ, L_JK
Local Integer NBR_NBRFAM
#JOJAC - 2016-03-11 - REQ114309 US87 - START
Local Integer FLGPEN,VOK
#JOJAC - 2016-03-11 - REQ114309 US87 - END

#02/08/12 - DKA - Add Leg field
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

###############################
$SETBOUT
If instr(1,GUSRVID,"2")
 [L]CHMEN = "2"
Endif
#JOJAC - 2016-03-11 - REQ114309 US87 - START
# Add CPN Update
If [V]GREP = "" & func AFNC.ACTIV("KFR") & [M:POT0]COD <> "" & [M:POT8]FLGEXCPEN=2
    [L]CHMEN += "3"
Endif
#JOJAC - 2016-03-11 - REQ114309 US87 - END
Return

########################
$LIENS
  ###############################
  #01/08/12 - DKA - Add Leg field
  GCURLEG = [F:POT]LEG : [M:POT0]LEG=GCURLEG
  If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
  #02/08/12 - DKA - Description is translatable
  Call LECTEXTRA([M]DES,"POSTE","DES",[M]COD,"") From ATEXTRA
  Call LECTEXTRA([M]DESSHO,"POSTE","DESSHO",[M]COD,"") From ATEXTRA
  #ADNGO - 2017-04-25 - X3-33737 - START
  Call LECTEXTRA([M]DES,"CLASSCONV","DES",[M]CCV,GCURLEG) From ATEXTRA
  #ADNGO - 2017-04-25 - X3-33737 - END
  #02/08/12 - DKA - Hide fields based on Leg
  Call DISPLAY_HIDE()From SUBPOTLEG
  ###############################

#* Test si code activité Carrière
#* SEGAY 28/02/11 Bug 71973
If func SUBJOT.IS_CAR
  # Charge tableau des missions
  For I=0 To dim([F:POT]MIS)-1
   If I<=dim([M:POT1]MIS)-1 & [F:POT]MIS(I)<>""
    [M:POT1]MIS(I) = [F:POT]MIS(I)
   Else
    Break
   Endif
  Next
  [M:POT1]NBRMIS = I

  # Charge tableau des familles de compétences
  For I=0 To dim([F:POT]CPCFAM)-1
   If I<=dim([M:POT6]CPCFAM)-1 & [F:POT]CPCFAM(I)<>""
    [M:POT6]CPCFAM(I) = [F:POT]CPCFAM(I)
   Else
    Break
   Endif
  Next
  [M:POT6]NBRFAM = I

  ##########################################
  # JML 06/09/10 CG compétences héritées (Onglet Répertoires, Ligne 75, initiale 48)
  # JML 29/09/10 c'est la fonction héritage qui gère tout, ici $LIENS on garde ce qu'il y a dans les fichiers comme X3 le fait
  #NBR_NBRFAM = [M:POT6]NBRFAM
  #Call LECTURE("JOT",[M:POT1]JOBPOT,"") From CONTOBJ
  #If fstat : Raz [F:JOT] : Endif
  #Gosub INIT_CPC
  #Raz L_IJ
  #For I=[M:POT4]NBRLIG-1 To 0 Step -1
  # If [M:POT4]ORI(I)=4 : # ML 2400 Groupe de compétence
  #  Dela I,1 [M:POT4]NBRLIG
  #  L_IJ += 1
  # Endif
  #Next I
  #[M:POT4]NBRLIG -= L_IJ
  ###########################################

  ## Charge tableau des compétences
  #L_IJ = [M:POT4]NBRLIG
  #For I=0 To dim([F:POT]CPC)-1
  # If L_IJ<=dim([M:POT4]CPC)-1 & [F:POT]CPC(I)<>""
  #  If [F:POT]ORI(I)=4 : # JML 06/09/10 # ML 2400 Groupe de compétence
  #   [M:POT4]CPC(L_IJ)    = [F:POT]CPC(I)
  #   [M:POT4]ORI(L_IJ)    = [F:POT]ORI(I)
  #   [M:POT4]WEI(L_IJ)    = [F:POT]WEI(I)
  #   [M:POT4]CODORI(L_IJ) = [F:POT]CODORI(I)
  #   Call LECTURE("CPC",[F:POT]CPC(I),"") From CONTOBJ
  #   [M:POT4]CODSCA(L_IJ) = [F:CPC]CODSCA
  #   [M:POT4]FLGKEY(L_IJ) = [F:CPC]FLGKEY
  #   [M:POT4]NIV(L_IJ)    = [F:POT]NIV(I)
  #   L_IJ += 1
  #  Endif
  # Else
  #  Break
  # Endif
  #Next
  #[M:POT4]NBRLIG = L_IJ
  #Sorta [M:POT4]NBRLIG [M:POT4]NBRLIG Order By [M:POT4]ORI([S]indice),[M:POT4]CPC([S]indice)
  For L_IJ=0 To dim([F:POT]CPC)-1
   # JML 13/07/10 CPC is now on JOT5 (instead of JOT2)
   If L_IJ<=dim([M:POT4]CPC)-1 & [F:POT]CPC(L_IJ)<>""
    [M:POT4]CPC(L_IJ)    = [F:POT]CPC(L_IJ)
    [M:POT4]NIV(L_IJ)    = [F:POT]NIV(L_IJ)
    [M:POT4]ORI(L_IJ)    = [F:POT]ORI(L_IJ)
    [M:POT4]WEI(L_IJ)    = [F:POT]WEI(L_IJ)
    [M:POT4]CODORI(L_IJ) = [F:POT]CODORI(L_IJ)
    Call LECTURE("CPC",[M:POT4]CPC(L_IJ),"") From CONTOBJ
    [M:POT4]CODSCA(L_IJ) = [F:CPC]CODSCA
#JOJAC - 2016-03-11 - REQ114309 US87 - START
    If func AFNC.ACTIV("FKZSD")>0 Then
      [M:POT4]CRSFLG(L_IJ) = [F:CPC]CRSFLG
    Endif
#JOJAC - 2016-03-11 - REQ114309 US87 - END
    # JML 04/08/10 Text of the scale
    If dim([M:POT4]LEVDES)>0
     Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
     L_JK = find([M:POT4]NIV(L_IJ),[F:HRSCA]LEV)
     Read [HRSDD]SDD0=[F:CPC]CODSCA;L_JK
     If !fstat
      [M:POT4]LEVDES(L_IJ) = [F:HRSDD]LEVDES
     Endif
    Endif
    [M:POT4]FLGKEY(L_IJ) = [F:CPC]FLGKEY
   Else
    Break
   Endif
  Next
  [M:POT4]NBRLIG = L_IJ
  Sorta [M:POT4]NBRLIG [M:POT4]NBRLIG Order By [M:POT4]ORI([S]indice),[M:POT4]CPC([S]indice)
Endif #* END_Bug 71973

#### FIN JML 29/09/10

