########################
$INIT_CPC_JOT
ORIGINE=5 : #ML 2400 emploi type

For I=0 To dim([F:JOT]CPC)-1
 If [F:JOT]CPC(I)<>""
  Call LECTURE("CPC",[F:JOT]CPC(I),"") From CONTOBJ
  If fstat : Raz [F:CPC] : Endif
  If dim([M:POT0]LEG)< 0 | (func TOOLSHRLEG.CHECKLEG_CPC([F:JOT]CPC(I),[M:POT0]LEG,0))  # SEGAY 25/10/12 US 930 81085 CPC of CPE in a different legislation than the contract
    L = find([F:JOT]CPC(I),[M:POT4]CPC)
    If !L
     # SEGAY - 24/11/10 - EXI 66105 LOT P01
     If [M:POT4]NBRLIG>=dim([M:POT4]CPC)
       #Tableau des compétences plein
      Call ERREUR(mess(5,10720,1)-num$(dim([M:POT4]CPC))) From GESECRAN
      Break
     Endif

     nolign = [M:POT4]NBRLIG + 1
     [M:POT4] = [F:CPC]
     [M:POT4]CPC([M:POT4]NBRLIG) = [F:JOT]CPC(I)
     [M:POT4]NIV([M:POT4]NBRLIG) = [F:JOT]NIV(I)
     [M:POT4]WEI([M:POT4]NBRLIG) = [F:JOT]WEI(I)
     # JML 19/08/10 CODSCA...
     Call LECTURE("CPC",[F:JOT]CPC(I),"") From CONTOBJ
     [M:POT4]CODSCA([M:POT4]NBRLIG) = [F:CPC]CODSCA
      # SEGAY - 24/11/10 - EXI 66105 LOT P01
      # Si emploi type à origine = "manuelle" ou = "groupe"
      # on prend l'origine = 5 ML 2400 emploi type
      # sinon on prend l'origine qui est dans la compétence de l'emploi type
  #   [M:POT4]ORI([M:POT4]NBRLIG)    = 5 :#ML 2400 emploi type
      # si emploi type à origine = "manuelle" ou = "groupe"
      If [F:JOT]ORI(I) = 0 or [F:JOT]ORI(I)= len(mess(0,10937,1)) or [F:JOT]ORI(I) = 4
         [M:POT4]ORI([M:POT4]NBRLIG) = ORIGINE :#ML 2400 emploi type
      Else
         [M:POT4]ORI([M:POT4]NBRLIG) = [F:JOT]ORI(I)
      Endif
     [M:POT4]CODORI([M:POT4]NBRLIG) = "" : # Pas de groupe de compétence
     [M:POT4]NBRLIG += 1
    Else
     Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
     If fstat : Raz [F:HRSCA] : Endif
     # Niveau déjà défini dans l'écran
     N = find([M:POT4]NIV(L-1),[F:HRSCA]LEV)
     If N
      WNIVEAU = [F:HRSCA]LEVREF(N-1)
     Else
      WNIVEAU = [F:HRSCA]LEVREF(0)
     Endif
     # Niveau défini dans le groupe de compétence
     N = find([F:JOT]NIV(I),[F:HRSCA]LEV)
     If N
      NIVEAU = [F:HRSCA]LEVREF (N-1)
     Else
      NIVEAU = [F:HRSCA]LEVREF (0)
     Endif
     #C'est le niveau le + élevé qui gagne
     # SEGAY - 24/11/10 - EXI 66105 LOT P01
     #Le niveau défini dans la compétence (niveau d’échelle),
     #   n’est pas pris en compte pour initialiser les compétences dans les emplois type et postes ;
     # (de la même manière qu’il n’est pas pris en compte dans les traitements de MàJ héritage).
     #Si on n'est pas sur une compétence manuelle et l'origine de la maj <> 4 ML 2400 Groupe de compétence
  #   If WNIVEAU<NIVEAU
     If [M:POT4]ORI(L-1) <> len(mess(0,10937,1)) & ORIGINE<>4 : # ML 2400 Groupe de compétence
      # JML 27/08/10 We need more information from CPC, a good idea for a transclass !
      nolign = L
      [M:POT4] = [F:CPC]
      [M:POT4]NIV(L-1)    = [F:JOT]NIV(I)
      [M:POT4]CODSCA(L-1) = [F:CPC]CODSCA
      If dim([M:POT4]LEVDES)>0
       [M:POT4]LEVDES(L-1) = L_LEVDES(J)
      Endif
      # SEGAY - 24/11/10 - EXI 66105 LOT P01
      # Si emploi type à origine = "manuelle" ou = "groupe"
      # on prend l'origine = 5 ML 2400 emploi type
      # sinon on prend l'origine qui est dans la compétence de l'emploi type
  #    [M:POT4]ORI(L-1)    = 5 :#ML 2400 emploi type
      # si emploi type à origine = "manuelle" ou = "groupe"
      If [F:JOT]ORI(I) = 0 or [F:JOT]ORI(I)= len(mess(0,10937,1)) or [F:JOT]ORI(I) = 4
         [M:POT4]ORI(L-1) = ORIGINE :#ML 2400 emploi type
      Else
         [M:POT4]ORI(L-1) = [F:JOT]ORI(I)
      Endif
      [M:POT4]CODORI(L-1) = "" : # Pas de groupe de compétence
     Endif
    Endif
  Endif # SEGAY 25/10/12 US 930 81085 CPC of CPE in a different legislation than the contract
 Else
  Break
 Endif
Next
Sorta [M:POT4]NBRLIG [M:POT4]NBRLIG Order By ORI([S]indice),CPC([S]indice)
Return

$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$ABANDON
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

# DKA - 10/08/12 selection object with leg
$SEL_TABLE
  If GFONCTION<>"GESPOT"
    Gosub SAVE_GLEGFIL From TOOLSHRLEG
    GLEGFIL=GCURLEG
    If find(GFONCTION,"GESECP","GESEVA") & dim(GCURLEG2)>0 & GCURLEG2 <> "" Then
      GLEGFIL=GCURLEG2
      If(dim(SAVS_GCURLEG)<0) Then Global Char SAVS_GCURLEG : Endif
      SAVS_GCURLEG=GCURLEG
      GCURLEG=GLEGFIL
    Endif
  Else
    If(dim(GLEGFIL)>0 and dim(GCURLEG)>0)
      If(dim(SAVS_GCURLEG)<0) Then Global Char SAVS_GCURLEG : Endif
      SAVS_GCURLEG=GCURLEG
      GCURLEG=GLEGFIL
    Endif
  Endif

# JOJAC - 2016-04-21 - REQ114309 US87 - START
#  Case TABLE
#    When "SELPOT"
#      If clalev ([F:POT])=0 : Local File POSTE [POT] : Endif
#      Filter [F:POT]
#      OBJET     = "POT"
#      START     = "[F:POT]COD"
#      EXPSTART  = "[F:POT]COD>='"+VALEUR+"'"
#      # deplacement dans toolshrleg
##      If dim([M]LEG)>0 & !find(GFONCTION,"GESECP","GESEVA") & !find(maskcou,"GENCSI")
##&       & !find(maskcou,"GENCEV")& !find(maskcou,"CEV0") Then
##81085-US1831
##      If func TOOLSHRLEG.ADDLEG_EXPSTART()
##        #MABOS-08/03/2013-FQ81085-US1332-generic rules in GENCEV
##        EXPSTART += '& [F:POT]LEG="'+[M]LEG+'"'
##      Endif
##
#      OPTIONS = "|"
#      SUPP    = VALEUR
#      #Filter based on code legislation
#      If PARAM(1)<>""
#        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:POT]LEG="'+PARAM(1)+'" | [F:POT]LEG="")',"&") From GOBJSUB
#      Endif
#  Endcase


  Case TABLE
    When "SELPOT"
    Local Char    CRITERE_POT(250) # SEGAY 25/10/12 US 930 81085
    If clalev ([F:POT])=0 : Local File POSTE [POT] : Endif
      Filter [F:POT]
      OBJET     = "POT"
      START     = "[F:POT]COD"
# JOJAC - 2016-04-21 - REQ114309 US87 - START
#EXPSTART  = "[F:JOT]COD>='"+VALEUR+"'"
# JOJAC - 2016-04-21 - REQ114309 US87 - END

 OPTIONS = "|"
      SUPP    = VALEUR
      #MABOS-08/03/2013-FQ81085-US1332-generic rules in GENCEV
#      If find(GFONCTION,"GESECP","GESEVA") Then
      If !func TOOLSHRLEG.ADDLEG_EXPSTART()
        ORDRE   = "[F:POT]COD"
      Endif
   #ADNGO - 2017-10-18 - X3-29326 - START
   When "SELINDPOT"
   OBJET = "MID"
   CRITERE = 'MIS=[M]WMIS(nolign-1)'
   #ADNGO - 2017-10-18 - X3-29326 - END
   Endcase
# JOJAC - 2016-04-21 - REQ114309 US87 - END
Return

# DKA - 10/08/12 Restore GLEGFIL
$FIN_TABLE
  Gosub RESTAURE_GLEGFIL From TOOLSHRLEG

  If(dim(SAVS_GCURLEG)>0)
    GCURLEG=SAVS_GCURLEG
    Kill SAVS_GCURLEG
  Endif
Return

# DKA - 10/08/2012 - Reinit GCURLEG in case of creation
$RAZCRE
  GCURLEG = ""
  Call DISPLAY_HIDE()From SUBPOTLEG
Return


