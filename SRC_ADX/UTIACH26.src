#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTIACH25      Utilitaire de réajustement des              Module ACHAT #
#               commandes PORDERP suite au bug 69046       GA 10/11/2010 #
# ---------------------------------------------------------------------- #
##########################################################################


Call MAJ_UTIACH26
End


Subprog MAJ_UTIACH26
Local Char WDOSSIER(30)
Local Libelle WTRACE  : WTRACE=2     : # WTRACE=2 --> Trace détaillée
Local Libelle WSIMUL  : WSIMUL=1     : # 0=normale, 1=simulation (pas de màj)
WDOSSIER=nomap
Call SAIDOS(WDOSSIER,"UTIACH26 - Control table PORDERP for v6") From SAIDOS
If WDOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  If WTRACE
    Call OUVRE_TRACE("UTIACH26 : Control table PORDERP for v6") From LECFIC
    Call ECR_TIME("UTIACH26 : Starting process on folder "+WDOSSIER) From DOSSUB
  Endif
  Call EXE_UTIACH26(WDOSSIER,WTRACE,WSIMUL)
  Call TEMPOFF From GESECRAN
  If WTRACE
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
Endif
End


Subprog EXE_UTIACH26(WDOSSIER,WTRACE,WSIMUL)
Value Char     WDOSSIER
Value Libelle  WTRACE
Value Libelle  WSIMUL : WSIMUL=1
#----- Variables locales -----#

#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=WDOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If dim(GMAXUPDTRS)<1  Global Integer GMAXUPDTRS : Endif
Local File =[F:ADS]DOSSIER+".ADOVAL" [ADW] 
Read [ADW] ADW0="";"";"MAXUPDTRS" : If fstat  Raz [F:ADW] : Endif
If val([F:ADW]VALEUR)>0
  GMAXUPDTRS=val([F:ADW]VALEUR)
Else
  GMAXUPDTRS=1000
Endif
Close Local File [ADW]
#-----
Gosub TRT_POP
#-----
$FIN_UTIACH26
If dim([V]GSOC_ACTIVE2)>0  Raz [V]GSOC_ACTIVE2 : Endif
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
Endif
#-----
End


#-------------------------------------------------------#
# Vérification de PORDERP                               #
#------------------------------------------------------ #
#-------------------------------------------------------#
$TRT_POP
Local File =[F:ADS]DOSSIER+".PORDER"     [POH]
Local File =[F:ADS]DOSSIER+".PORDERQ"    [POQ]
Local File =[F:ADS]DOSSIER+".PORDERP"    [POP]
Local Integer WDEL, WINS
Raz WDEL,WINS
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
Endif


Trbegin [POP]

# Recherche des lignes [F:POQ] dont l'entête a été supprimée
For [POQ]
    Read [POH]POH0=[F:POQ]POHNUM
    If fstat # ligne orpheline
       Gosub DELETE_POQ
    Endif
Next


# Recherche des lignes [F:POQ] pour lesquelles [F:POP] a été supprimée
For [POQ]
    Read [POH]POH0=[F:POQ]POHNUM
    If [F:POH]POHTYP=2 Goto NEXT_POQ Endif

    Read [POP]POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
    If fstat # ligne orpheline
       Gosub INSERT_POP
    Endif
$NEXT_POQ
Next

#-----
If WSIMUL
   Rollback
   Call ECR_TRACE("UTIACH26 :"-num$(WDEL)-mess(20,133,1)-" : "-"Rollbacked",0) From GESECRAN
   Call ECR_TRACE("UTIACH26 :"-num$(WINS)-mess(103,141,1)-" : "-"Rollbacked",0) From GESECRAN
Else
   Commit
   Call ECR_TRACE("UTIACH26 :"-num$(WDEL)-mess(20,133,1)-" : "-"Commited",0) From GESECRAN
   Call ECR_TRACE("UTIACH26 :"-num$(WINS)-mess(103,141,1)-" : "-"Commited",0) From GESECRAN
Endif
Close Local File [POH], [POQ], [POP]

Return

$DELETE_POQ
Call ECR_TRACE("Row POQ to be deleted:"-[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ),0) From GESECRAN
WDEL+=1
If WSIMUL Return Endif
Delete [F:POQ]
Return

$DELETE_POP
Call ECR_TRACE("Row POP to be deleted:"-[F:POP]POHNUM-num$([F:POP]POPLIN)-num$([F:POP]POQSEQ),0) From GESECRAN
WDEL+=1
If WSIMUL Return Endif
Delete [F:POP]
Return

$INSERT_POP
Call ECR_TRACE("Row POP to be created:"-[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ),0) From GESECRAN
WINS+=1
If WSIMUL Return Endif
[F:POP]=[F:POQ]
# + rech tarif  
# + CPTANALIN en V6
Write [F:POP]
Return

###################################################
# Pour exécution automatique  en gestion de patch #
###################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call ECR_TRACE("UTIACH26 - Control table PORDERP for v6",0) From GESECRAN
  Call EXE_UTIACH26(DOSSIER,1,0)
Endif
#-----       
End


#########################################################
# Pour exécution depuis DOSMAJ au changement de version #
#########################################################
Subprog UTI_MOUL(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call ECR_TRACE("UTIACH26 - Control table PORDERP for v6",0) From GESECRAN
  Call EXE_UTIACH26(DOSSIER,1,0)
Endif
#-----
End

