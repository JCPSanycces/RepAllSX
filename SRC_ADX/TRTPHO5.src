#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
# Etape 5 de la définition d'une campagne d'appels                  Module CRM           6 décembre 2000 #
##########################################################################################################
# Sélection des téléacteurs
##########################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When Default
Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GIALL
Global Date GDMAXOPGEND
GIALL = 0
GDMAXOPGEND = [00/00/00]
If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
If !clalev([F:OMP]) : Local File PHONING [OMP] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
#Obtient la date de fin de la campagne d'appel
Read [OMP] OMP0 = GSZOPGNUM
If fstat
    GDMAXOPGEND = date$
Else
    GDMAXOPGEND = [F:OMP]OMPEND
Endif
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$FINSAI
#Nettoie l'écran avant de partir.
Raz [M:PHO5]
Kill GIALL
Kill GDMAXOPGEND
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$AVANT_BOUTON
Case BOUT
    When "A"
        Gosub ONTELE
    When "B"
        Gosub ONALL
    When "C"
        Gosub ONCONFIRM
    When Default
Endcase
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################

##########################################################################################################
$ONTELE
GIALL = 2
If !GINTRA
    FIN = 1
Endif
Return

##########################################################################################################
$ONALL
GIALL = 1
If !GINTRA
    FIN = 1
Endif
Return

##########################################################################################################
$ONCONFIRM
GIALL = 0
If !GINTRA
    FIN = 1
Endif
Return

##########################################################################################################
$CANCELSTEP
If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif
If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif

Local Integer ITRANSFLG
If adxlog
    ITRANSFLG = 1
Else
    ITRANSFLG = 0
Endif

If !ITRANSFLG
    Call DEBTRANS From GLOCK
    Trbegin [CLL], [DVA]
Endif
Delete [CLL] Where [F:CLL]CLLOPGNUM = GSZOPGNUM
&              and [F:CLL]CLLDON <> 2
&              and [F:CLL]CLLCMGFLG > 0
If fstat
    If ITRANSFLG
        GOK = 0
        Call FSTA("CLL") From GLOCK
        Return
    Else
        Rollback
        Return
    Endif
Endif

Delete [DVA] Where [F:DVA]OBC = "OMP"
&              and [F:DVA]ALHX(0) = GSZOPGNUM
If fstat
    If ITRANSFLG
        GOK = 0
        Call FSTA("DVA") From GLOCK
        Return
    Else
        Rollback
        Return
    Endif
Endif

If !ITRANSFLG
    Commit
Endif
Return

