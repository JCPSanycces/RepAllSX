#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
Case ACTION
 When "IMPORT"      : Gosub IMPORT
Endcase
Return

$IMPORT
Case IMPFIC
 When "PDM"
  GBIDC2 = [F:PDM]COA
  If GREP="M" & find([F:PDM]ACCSTR,[M]ACCSTR(0..[M]NBLIG))
   nolign = find([F:PDM]ACCSTR,[M]ACCSTR(0..[M]NBLIG))
  Else
   [M]NBLIG += 1
   nolign = [M]NBLIG
  Endif
Endcase
Return

