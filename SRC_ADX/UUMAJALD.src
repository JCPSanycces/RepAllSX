#<AdxTL>@(#)7.0.0.0 $Revision$
###################################################
# Maj champ avec type de données et format variable
###################################################
Call PATCH(nomap)
End

Subprog PATCH(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".ALISTED"   [ALD] 
Local File =DOSSIER+".ATYPE"     [ATY]

# Mise à jour de la table ALISTED
Call ECR_TRACE(mess(81,125,1)-"ALISTED:"-time$,0) From GESECRAN
Trbegin [ALD]
 For [ALD]ALD0
  Call LECTURE("ATY",[F:ALD]CODTYP,"") From CONTOBJ
  If [F:ATY]LNGTYP>0 & !instr(1,num$([F:ATY]LNGTYP),".") & instr(1,[F:ATY]OPTION,"F")
   [F:ALD]LNG = 0
   Rewrite [F:ALD]
  Endif
 Next
Commit

Close Local File [ALD],[ATY]
End

