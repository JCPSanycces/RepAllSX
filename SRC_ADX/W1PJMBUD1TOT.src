#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMBUD1TOT 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:45"
A_USER  = "DOC"
A_STAMP = "20181109230545"
Return

$TITRES
Chgtzn [M:PJBUTT]PSCBUDQTY With func SUBPJBU1D.COL_GET_TITLE(3)
Chgtzn [M:PJBUTT]PSCBUDAMT With func SUBPJBU1D.COL_GET_TITLE(4)
Chgtzn [M:PJBUTT]PSCQTY1 With func SUBPJBU1D.COL_GET_TITLE(5)
Chgtzn [M:PJBUTT]PSCAMT1 With func SUBPJBU1D.COL_GET_TITLE(6)
