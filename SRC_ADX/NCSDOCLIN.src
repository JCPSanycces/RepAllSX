#<AdxTL>@(#)0.0.0.0 $Revision$ 
######################################################################################
## Non-conformance add sereial and lot number to selctin screen
######################################################################################
# Issue X3-88163 - 2018-05-29 by ALSHE : Display lot and serial number
# Issue X3-94378 - 2018-06-08 by ALSHE : Resructure data base
# Issue X3-92124 - 2018-06-08 by ALSHE : change of quantity in document lines
# Issue X3-104585 - 2018-09-03 by BAKHA : Display stock unit

$ACTION
Case ACTION
  When "OUVRE"    Gosub OUVRE
  When "DEBUT"    Gosub DEBUT
  When "OK"       Gosub OK             # Issue X3-92124 - 2018-06-21 by JUSYN : Save quantity changes
  When "MEN"      Gosub MEN_EXEBOUT    # Issue X3-92124 - 2018-06-21 by JUSYN : Save quantity changes
  When "END"      Gosub CLOSE_PAGE     # Issue X3-92124 - 2018-06-26 by JUSYN : Save quantity changes
  When "SETBOUT"  Gosub SETBOUT        # Issue X3-97893 - 2018-09-20 by JUSYN : do not display buttons for select/deselect if screen blocked.
  When Default
Endcase
Return

######################################################################################

$OUVRE
Local    Char       WVCRNUM(GLONVCR)
Local    Integer    WVCRLIN
Local    Decimal    WNCSQTY
Local    Integer    WDOCLIN
Local    Decimal    WDOCQTY  # Issue X3-92124 - 2018-06-21 by JUSYN : Pass original quantity
Local    Integer NI
Local    Char       WDOCSTU(GLONUOM)  # X3-104585 - stock unit

If clalev([M:NCSH9])=0 : Local Mask NCSH9   [NCSH9] : Endif

WVCRNUM = PARAM(1)
WVCRLIN = val(PARAM(2))
WNCSQTY = val(PARAM(3))
WDOCLIN = val(PARAM(4))
WDOCQTY = val(PARAM(5)) # Issue X3-92124 - 2018-06-21 by JUSYN : Pass original quantity
WDOCSTU = PARAM(6)      # X3-104585 - stock unit
Return

######################################################################################

$DEBUT
Local Integer J

[M:NCSH9]DOCNUM = WVCRNUM
[M:NCSH9]DOCLIN = WVCRLIN
[M:NCSH9]DOCNCSQTY = WNCSQTY
[M:NCSH9]DOCDOCQTY = WDOCQTY # Issue X3-92124 - 2018-06-21 by JUSYN : Pass original quantity
[M:NCSH9]DOCSTU = WDOCSTU # X3-104585 - stock unit
Affzo [M:NCSH9]5

nolign = 0
# Issue X3-94378 - 2018-06-08 by ALSHE : replace CCMNCSDOC with NCSDOCHDR
For NI = 1 To maxtab(WNCSRECENT.NCSDOCHDR(WDOCLIN).NCSDOCLIN)
  # ------------------------------------
#  If WNCSRECENT.CCMCRORIGC(NI) <> null and find(WNCSRECENT.CCMCRORIGC(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
  If WNCSRECENT.NCSDOCHDR(WDOCLIN).NCSDOCLIN(NI) <> null and find(WNCSRECENT.NCSDOCHDR(WDOCLIN).NCSDOCLIN(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
    nolign += 1
    SetInstance [M:NCSH9]10 With WNCSRECENT.NCSDOCHDR(WDOCLIN).NCSDOCLIN(NI)
    [M:NCSH9]SUBLIN(nolign-1) = NI   # Line index in the collection
#    [M:NCSH9]SUBLIN(nolign-1) = WNCSRECENT.CCMNCSDOC(WDOCLIN).NCSDOCLIN(NI).SUBLIN
#    [M:NCSH9]DOCQTY(nolign-1) = WNCSRECENT.CCMNCSDOC(WDOCLIN).NCSDOCLIN(NI).DOCQTY
  Endif
  # ------------------------------------
Next NI

[M:NCSH9]NBLIG9 = nolign

# Issue X3-92124 - 2018-06-21 by JUSYN : Nothing to change if quantity equal to 1 in NCSQTY field. Tick or untick line.
For J = 0 To NBLIG9-1
    If [M:NCSH9]DOCQTY(J) = 1
      Grizo [M:NCSH9]NCSQTY(J)
    Else
      Actzo [M:NCSH9]NCSQTY(J)
    Endif
Next
# End issue X3-92124

# Issue X3-97893 - 2018-09-19 by JUSYN : do not allow to change but view document lines if work on actions started
If [M:NCSH0]NCSSTA >= 6
    Grizo [M:NCSH9]
Else
    If PNCSDOCCHG = "1"
        # No changes on document lines allowed - except if NC not completed/closed or implemented but no work on actions started
        If ([M:NCSH0]NCSSTA > 5) | ([M:NCSH0]NCSSTA = 5 & func SUBNCSH.CHECK_PROGRESS_COMPLETION())
            Grizo [M:NCSH9]
        Endif
    Endif
Endif
# End issue X3-97893

Affzo [M:NCSH9]1-99

Return

# Issue X3-92124 - 2018-06-21 by JUSYN : Save quantity changes
######################################################################################
$OK
Local Integer J
Local Integer NI

# Issue X3-97893 - 2018-09-19 by JUSYN : do not work on modifications if no modifications could be done because blocked.
If ([M:NCSH0]NCSSTA >= 6) | ((PNCSDOCCHG = "1") & ([M:NCSH0]NCSSTA = 5 & func SUBNCSH.CHECK_PROGRESS_COMPLETION()))
    Return
Endif
# End issue X3-97893

# update class NCSDOCLIN
For J = 0 To NBLIG9-1
    WNCSRECENT.NCSDOCHDR(WDOCLIN).NCSDOCLIN([M:NCSH9]SUBLIN(J)).SELLIN = [M:NCSH9]SELLIN(J)
    WNCSRECENT.NCSDOCHDR(WDOCLIN).NCSDOCLIN([M:NCSH9]SUBLIN(J)).NCSQTY = [M:NCSH9]NCSQTY(J)
Next

# update quantity NCSDOCHDR
WNCSRECENT.NCSDOCHDR(WDOCLIN).NCSQTY = 0
For J = 0 To NBLIG9-1
    WNCSRECENT.NCSDOCHDR(WDOCLIN).NCSQTY += WNCSRECENT.NCSDOCHDR(WDOCLIN).NCSDOCLIN([M:NCSH9]SUBLIN(J)).NCSQTY
Next

Return
######################################################################################
$MEN_EXEBOUT
Case BOUT
  When "1"      : Gosub SELECT_ALL   # Select all
  When "2"      : Gosub DESELECT_ALL # Deselect all
Endcase
Return
######################################################################################
$SELECT_ALL
Local Integer J

For J = 0 To NBLIG9-1
    [M:NCSH9]SELLIN(J) = 2
    [M:NCSH9]NCSQTY(J) = [M:NCSH9]DOCQTY(J)
Next
Affzo [NCSH9]1-99

Call UPDATE_TOTAL_NCSQUANTITY From SUBNCSH
Affzo [NCSH9]1-99

Return
######################################################################################
$DESELECT_ALL
Local Integer J

For J = 0 To NBLIG9-1
    [M:NCSH9]SELLIN(J) = 1
    [M:NCSH9]NCSQTY(J) = 0
Next
Affzo [NCSH9]1-99

Call UPDATE_TOTAL_NCSQUANTITY From SUBNCSH
Affzo [NCSH9]1-99

Return
######################################################################################
$CLOSE_PAGE

# Issue X3-97893 - 2018-09-19 by JUSYN : do not ask about modifications if no modifications could be done because blocked.
If [M:NCSH0]NCSSTA >= 6
    FIN = 1
Else
    If PNCSDOCCHG = "1"
        # No changes on document lines allowed - except if NC not completed/closed or implemented but no work on actions started
        If ([M:NCSH0]NCSSTA = 5 & func SUBNCSH.CHECK_PROGRESS_COMPLETION())
            FIN = 1
        Else
            Call OUINON(mess(265,126,1), OK) From GESECRAN
            If OK = 1
                FIN = 0  # Response was No, do not exit
            Elsif OK = 2
                FIN = 1
            Endif
        Endif
    Else
        Call OUINON(mess(265,126,1), OK) From GESECRAN
        If OK = 1
            FIN = 0  # Response was No, do not exit
        Elsif OK = 2
            FIN = 1
        Endif
    Endif
Endif
# End issue X3-97893
Return
# Issue X3-92124
######################################################################################
$SETBOUT
# Issue X3-97893 - 2018-09-19 by JUSYN : do not work on modifications if no modifications could be done because blocked.
Raz CHMEN
If ([M:NCSH0]NCSSTA >= 6) | ((PNCSDOCCHG = "1") & ([M:NCSH0]NCSSTA = 5 & func SUBNCSH.CHECK_PROGRESS_COMPLETION()))
    # do not select or deselect
Else
    CHMEN = "12"
Endif
# End issue X3-97893
Return
######################################################################################

