#------------------------------------------------------------------------
$OPEN_INT
If !clalev([F:XCLT]) : Local File =SI_DOSSIER+".XICLT"      [XCLT] : Endif  : # Integrale Clients
If !clalev([F:XART]) : Local File =SI_DOSSIER+".XIART"      [XART] : Endif  : # Integrale Articles
If !clalev([F:XACT]) : Local File =SI_DOSSIER+".XIARTCDT"   [XACT] : Endif  : # Integrale Articles conditonnés

If !clalev([F:XVH0]) : Local File =SI_DOSSIER+".XIEPV"      [XVH0] : Endif  : # Entete piece vente
If !clalev([F:XVHT]) : Local File =SI_DOSSIER+".XIEPVTVA"   [XVHT] : Endif  : # Entete piece vente TVA
If !clalev([F:XVLI]) : Local File =SI_DOSSIER+".XILPV"      [XVLI] : Endif  : # Ligne piece vente
If !clalev([F:XVAD]) : Local File =SI_DOSSIER+".XILPVADR"   [XVAD] : Endif  : # Ligne piece vente adresse
If !clalev([F:XVAN]) : Local File =SI_DOSSIER+".XILPVANA"   [XVAN] : Endif  : # Ligne piece vente analytique
If !clalev([F:XVFD]) : Local File =SI_DOSSIER+".XILPVFADIV" [XVFD] : Endif  : # Ligne piece vente frais divers
If !clalev([F:XVFF]) : Local File =SI_DOSSIER+".XILPVFAFIX" [XVFF] : Endif  : # Ligne piece vente frais fixe
If !clalev([F:XVFC]) : Local File =SI_DOSSIER+".XILPVFMCAL" [XVFC] : Endif  : # Ligne piece vente formule calcul
If !clalev([F:XVMR]) : Local File =SI_DOSSIER+".XILPVMDRGL" [XVMR] : Endif  : # Ligne piece vente mode reglement
