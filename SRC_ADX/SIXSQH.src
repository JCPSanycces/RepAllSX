#########################################################################
#    Pour GENSQH composant calcul facture
#    chargement masques SQH0 SQH1 SQH2 SQH3 SQH4
#    Actions appelées dans le TRTVENDEVG
#########################################################################
$ACTION_GS

Case GWACTION_GS
     When "READ_DETAIL"     Gosub READ_DETAIL
     When "MSK_ENTETE"      Gosub MSK_ENTETE
     When "MSK_DETAIL"      Gosub MSK_DETAIL
     When "AP_READ_DETAIL"  Gosub AP_READ_DETAIL
     When "INICRE"          Gosub INICRE
     When "ERREUR"          Gosub ERREUR
     When "CREATION"        Gosub CREATION
Endcase
Return

#------------------------------------------------------------------------
# Chargement des ecrans entete de devis
#------------------------------------------------------------------------
$MSK_ENTETE

#Setmode
#Infbox  IMPZON

Case IMPZON
     When "SALFCY"     :  [M]SALFCY=[F:SPX]FCY            :  #--- Masque SQH0

     When "CUSQUOREF"  :  [M]CUSQUOREF=[F:XVH0]REFCMD
#                          [M]CUSQUOREF=num$([F:XVH0]NUMORD)

     When "QUODAT"     :  [M]QUODAT=[F:XVH0]DATPIE
     When "BPCORD"     :  If [F:XVH0]CODCLT<>"" [M]BPCORD=func SIXFONCTION.SI_COR("XICLT",[F:XVH0]CODCLT,"","") Endif
                          # Chargement champs affiches et invisibles sur appel champ saisissable obligatoire
                          If [F:XVH0]NBREXL>0 [M]COPNBR=[F:XVH0]NBREXL Endif : # V6
                        #--- Masque SQH1
     When "STOFCY"     :  If [F:XVH0]CODDPO<>"" [M]STOFCY=func SIXFONCTION.SI_COR("XIDPO",[F:XVH0]CODDPO,"","") Endif
     When "REP"
          Case indice
               When 0  :  If [F:XVH0]CODREP<>""
                              [M]REP(0)=func SIXFONCTION.SI_COR("XIREP",[F:XVH0]CODREP,"","")
                          Else
                              [M]REP(0)=""
                          Endif
          Endcase
     When "VACBPR"     :  [M]VACBPR=func SIXFONCTION.SI_VACBPR("C",[F:XVH0]ASJTVA,[F:XVH0]ASJTPF,[F:XVH0]ASJTAXADD,[M:SIW0]CODPAY)
                          If [M]VACBPR="" : # Bug 48060 : Amélio trace
                            Call ECR_TRACE (SI_MES(276),1) From GESECRAN
                            Call ECR_TRACE (SI_MES(277)-":"-[F:XVH0]ASJTVA-SI_MES(278)-":"-[F:XVH0]ASJTPF-SI_MES(279)-":"-[F:XVH0]ASJTAXADD-SI_MES(280)-":"-[M:SIW0]CODPAY,1) From GESECRAN
                          Endif
     When "CUR"        :  If [F:XVH0]CODDVS=""   [M]CUR=[F:SPX]CUR
                            Else                 [M]CUR=func SIXFONCTION.SI_COR("XIDVS",[F:XVH0]CODDVS,"","")
                          Endif
     When "PRITYP"     :  If [F:XVH0]FACTTC="O"  [M]PRITYP=2
                            Else                 [M]PRITYP=1
                          Endif
                        #--- masque SQH3
     When "PTE"        :  If [F:XVH0]MODRGL1<>""
                              Local Char WCLERGL1, WCLERGL2                                       : # Bug 79385
                              If len([F:XVH0]MODRGL1)>2
                                 WCLERGL1=left$([F:XVH0]MODRGL1,2)                                : # Bug 79385
                                 WCLERGL2=right$([F:XVH0]MODRGL1,3)                               : # Bug 79385
                              Else
                                 WCLERGL1=[F:XVH0]MODRGL1                                         : # Bug 79385
                              Endif
                              [M]PTE=func SIXFONCTION.SI_COR2("XIMODRGL",WCLERGL1,WCLERGL2,"","") : # Bug 79385
                          Endif
     When "NBFAC"      :  [M]NBFAC=[M:SIW0]NBFAC
                          For I=0 To [M:SIW0]NBFAC-1 : [M]INVDTAAMT(I)=[M:SIW0]INVDTAAMT(I) : Next I

Endcase

Return

#------------------------------------------------------------------------
# Lecture des enregistrements details
# - le filter des lignes doit être actif
# - on ne fait que de la création de lignes
#------------------------------------------------------------------------
$READ_DETAIL
nolign=0 : LIG_DETAIL="C"     : # uniquement de la creation
Local Decimal CUMQTY

If LEC_DETAIL=0
    Read [XVLI] First
Else
    Read [XVLI] Next
Endif
If    !fstat        : # lecture ok
   LEC_DETAIL=1
   # Bug 48758 : Qté à 0 : Ligne non reprise
   If sum([F:XVLI]QTELIV, [F:XVLI]QTERLQ)=0
       GBIDC3=SI_MES(273)-":"-SI_MES(274)
       GBIDC3-="<"-mess(3,40,1)-num$([F:XVLI]NUMLIG)-mess(18,7,1)-[F:XVLI]CODART-">"
       LEC_DETAIL=4
   Endif
Elsif fstat=4       : # fin lecture
   LEC_DETAIL=2
Elsif fstat         : # erreur
   LEC_DETAIL=3   : GBIDC3="XILPV [XVLI]"
Endif

Return

#------------------------------------------------------------------------
# Chargement d'une ligne dans l'ecran SQH2 de devis
#------------------------------------------------------------------------
$MSK_DETAIL
Local Char WSAU(GLONUOM)

#Setmode
#Infbox IMPZON

Case IMPZON
     When "ITMREF"     :  If [F:XVLI]CODART<>""
                              [M]ITMREF(nolign-1) =func SIXFONCTION.SI_COR("XIART",[F:XVLI]CODART,"","")
                          Endif
     When "ITMDES"     :  [M]ITMDES(nolign-1) =[F:XVLI]NOMART
     When "DSTOFCY"    :  If [F:XVLI]CODDPO<>""
                              [M]DSTOFCY(nolign-1)=func SIXFONCTION.SI_COR("XIDPO",[F:XVLI]CODDPO,"","")
                          Endif
     When "SAU"        :  WSAU=[M]SAU(nolign-1)
                          If [F:XVLI]UNIVEN<>""
                              [M]SAU(nolign-1)=func SIXFONCTION.SI_COR("XIUNIFAC",[F:XVLI]UNIVEN,"","")
                          Endif
                          If WSAU<>[M]SAU(nolign-1) & [M]SAU(nolign-1)<>""
                              # Bug 47303
                              # On vérifie si l'unité du devis fait partie des unités définies dans l'article
                              # Si ce n'est pas la cas, pour ne pas bloquer :
                              # On garde l'unité initialisée au départ (unité de vente définie ds l'article)
                              #----- Lecture de l'article et article-client si nécessaire -----#
                              If [F:ITM]ITMREF<>[M:SQH2]ITMREF(nolign-1)
                                  Read [ITM] ITM0=[M:SQH2]ITMREF(nolign-1)
                                  If fstat Raz [F:ITM] : Endif
                              Endif
                              If [F:ITU]ITMREF<>[M:SQH2]ITMREF(nolign-1) | [F:ITU]BPCNUM<>[M:SQH0]BPCORD
                                  Read [ITU] ITU0=[M:SQH2]ITMREF(nolign-1);[M:SQH0]BPCORD
                                  If fstat Raz [F:ITU] : Endif
                              Endif
                              #----- Contrôle que l'unité est présente dans l'article ou article-client -----#
                              If !find([M:SQH2]SAU(nolign-1),[F:ITM]STU,[F:ITM]SAU,[F:ITM]PCU,[F:ITU]SAU,[F:ITU]PCU1,[F:ITU]PCU2)
                                  #----- Si ce n'est pas le cas, on remplace par l'unité de vente -----#
                                  [M:SQH2]SAU(nolign-1)=WSAU
                              Endif
                              #-----
                          Endif
     When "QTY"        :  If [F:XVLI]QTELIV<>0
                              [M]QTY(nolign-1)=[F:XVLI]QTELIV
                          Else
                              [M]QTY(nolign-1)=[F:XVLI]QTECMD
                          Endif
                          Gosub RECH_VACITM  : # Bug 47592
                          Gosub TRAIT_VACITM
     When "GROPRI"     :  [M]GROPRI(nolign-1)=[F:XVLI]PRXUNI
                          Gosub CHARG_DISCRGNUM
                          Gosub RAZ_DISCRGVAL
     When "DISCRGVAL1" :  Gosub CHARG_DISCRGVAL
     When "DISCRGVAL2" :  Gosub CHARG_DISCRGVAL
     When "DISCRGVAL3" :  Gosub CHARG_DISCRGVAL
     When "DISCRGVAL4" :  Gosub CHARG_DISCRGVAL
     When "DISCRGVAL5" :  Gosub CHARG_DISCRGVAL
     When "DISCRGVAL6" :  Gosub CHARG_DISCRGVAL
     When "DISCRGVAL7" :  Gosub CHARG_DISCRGVAL
     When "DISCRGVAL8" :  Gosub CHARG_DISCRGVAL
     When "DISCRGVAL9" :  Gosub CHARG_DISCRGVAL
     When "CPRPRI"     :  [M]CPRPRI(nolign-1)=[F:XVLI]PRXVALFRS : # Bug 48023
                          Gosub TRAIT_NETPRI
     When "REP1"       :  If [F:XVLI]CODREP<>""
                               [M]REP1(nolign-1)=func SIXFONCTION.SI_COR("XIREP",[F:XVLI]CODREP,"","")
                          Else
                               [M]REP1(nolign-1)=""
                          Endif
     When "REPRAT1"    :  If [M]REP1(nolign-1)<>"" [M]REPRAT1(nolign-1)=[F:XVLI]TAUCOM Endif
     When "CCE1"       :  Call SI_INICCE("XILPVANA",[F:XVLI]NUMORD,[F:XVLI]LETRLQ,[F:XVLI]NUMLIG,
&                             "[M:SQH2]CCE",nolign-1)  From SIXFONCTION

Endcase

# pour avoir le no. de la piece et la reference article dans l'erreur
#GCLE =[F:XVH0]TYPPIE+" "+[F:XVH0]NUMSER+[F:XVH0]NUMPIE
GCLE=mess(3,40,1)-num$([F:XVLI]NUMLIG)-mess(18,7,1)-[M]ITMREF(nolign-1)

Return

#------------------------------------------------------------------------------
# Vérification existence des croisements régime-niveaux
# Vérification concordance niveaux-code taxe (suite au tassement des codes taxes par ALITAXEV)
#------------------------------------------------------------------------------
$TRAIT_VACITM

# Bug 63863 : En V6 l'existence des croisements régime-niveaux n'est plus systématique
# et plus d'utilisation d'ALITAXEV donc plus de tassement

#If [M]VACITM2(nolign-1)<>""
##    Read [TVC]TVC0 = [M]VACBPR;[M]VACITM2(nolign-1)  : # V6
#    Read [TVC]TVC1 = [M]VACBPR;[M]VACITM2(nolign-1)   : # V6
#    If fstat | [F:TVC]ENAFLG<>2 | [F:TVC]LEG<>GCURLEG : # V6
##    If fstat
#        Raz [M]VACITM2(nolign-1)
#    Endif
#Endif
#If [M]VACITM3(nolign-1)<>""
##    Read [TVC]TVC0 = [M]VACBPR;[M]VACITM3(nolign-1)  : # V6
#    Read [TVC]TVC1 = [M]VACBPR;[M]VACITM3(nolign-1)   : # V6
#    If fstat | [F:TVC]ENAFLG<>2 | [F:TVC]LEG<>GCURLEG : # V6
##   If fstat
#        Raz [M]VACITM3(nolign-1)
#    Endif
#Endif
#If [M]VAT2(nolign-1)<>"" & [M]VACITM2(nolign-1)=""
#    [M]VACITM2(nolign-1)=[M]VACITM3(nolign-1) : Raz [M]VACITM3(nolign-1)
#Endif

Return

#------------------------------------------------------------------------------
# Bug 47592 :
# Détermination des bons niveaux de taxe
#------------------------------------------------------------------------------
$RECH_VACITM
Local Char WTVADBTENC (1)
Local Char WVACITM(GLONTVI)(0..2), WVAT(GLONVAT)(0..2)

## Si les codes taxes donnés par les niveaux de taxe de la fiche article sont les mêmes que les codes taxe de la pièce :
## --> C'est ok on ne fait rien
#If [F:XVLI]CODTVA<>0
#    WVAT(0)=func SIXFONCTION.SI_COR2("XITVAVEN",num$([F:XVLI]CODTVA),[M:SIW0]CODPAY,"TABVAT","")
#Endif
#If [F:XVLI]CODTPF<>0
#    WVAT(1)=func SIXFONCTION.SI_COR2("XITAXPFC",num$([F:XVLI]CODTPF),[M:SIW0]CODPAY,"TABVAT","")
#Endif
#If WVAT(0)=[M]VAT1(nolign-1) & WVAT(1)=[M]VAT2(nolign-1) Return Endif

# Les codes taxes donnés par les niveaux de taxe de la fiche article sont différents des codes taxe de la pièce :
# --> If faut retrouver les bons niveaux

#If WVAT(0)<>[M]VAT1(nolign-1)
    # Récupération dans le paramétrage de la migration du niveau de taxe 1
    If [F:XVLI]TVADBTENC=""
        WTVADBTENC=[F:XVH0]TVADBTENC
        If WTVADBTENC<>"E" WTVADBTENC="D" Endif
    Else
        WTVADBTENC=[F:XVLI]TVADBTENC
    Endif
    If [F:XART]CODART<>[F:XVLI]CODART
        Read [XART]IND0=[F:XVLI]CODART
        # Bug 49147 : Si ce n'est pas un article, aller voir si c'est un article conditionné
        If fstat
            Read [XACT]IND0=[F:XVLI]CODART
            If !fstat
                Read [XART]IND0=[F:XACT]ARTPCP
            Endif
            If fstat Raz [F:XART] Endif
        Endif
    Endif
    Read [SPV]SPV0=[F:SPX]CLE;[F:XVLI]CODTVA;[F:XART]CODTVAACH;WTVADBTENC;0
    If !fstat WVACITM(0) = [F:SPV]VACITM1 Endif

    # On a trouvé un niveau : On lit le croisement et s'il existe on le garde
    If WVACITM(0)<>""
#        Read [TVC]TVC0 = [M]VACBPR;WVACITM(0)             : # V6
#        Read [TVC]TVC1 = [M]VACBPR;WVACITM(0)             : # V6
#        If fstat | [F:TVC]ENAFLG<>2 | [F:TVC]LEG<>GCURLEG : # V6
#        If fstat Raz WVACITM(0) Endif                     : # V6
        Filter [TVC] Where VACBPR=[M]VACBPR & VACITM=WVACITM(0) & ENAFLG=2 & LEG=GCURLEG : # V6
        Read [TVC]First                                    : # V6
        If fstat Raz WVACITM(0) Endif                      : # V6
        Filter [TVC]                                       : # V6
    Endif

    # On a pas trouvé de niveau ou le croisement n'existe pas
    # On va rechercher le 1er niveau correspondant au code taxe et au régime
    If WVACITM(0)=""
        If [F:XVLI]CODTVA<>0
            WVAT(0)=func SIXFONCTION.SI_COR2("XITVAVEN",num$([F:XVLI]CODTVA),[M:SIW0]CODPAY,"TABVAT","")
        Endif
        If WVAT(0)<>""
#           Filter [TVC] Where VACBPR=[M]VACBPR & VAT=WVAT(0)
            Filter [TVC] Where VACBPR=[M]VACBPR & VAT=WVAT(0) & ENAFLG=2 & LEG=GCURLEG : # V6
            Read [TVC]First
#           Bug 64842 : On recharge le bon code taxe
#            If !fstat WVACITM(0)=[F:TVC]VACITM Endif
            If !fstat WVACITM(0)=[F:TVC]VACITM : [M]VAT1(nolign-1)=WVAT(0) Endif
#           Bug 64842
            Filter [TVC]
        Endif
    Endif
    If WVACITM(0)="" : # Bug 48060 : Amélio trace
        Call ECR_TRACE (SI_MES(281),1) From GESECRAN
        Call ECR_TRACE (SI_MES(282)-":"-[M]VACBPR-SI_MES(283)-":"-WVAT(0),1) From GESECRAN
    Endif
    [M]VACITM1(nolign-1)=WVACITM(0)
#Endif

#If WVAT(1)<>[M]VAT2(nolign-1)
    # Récupération dans le paramétrage de la migration du niveau de taxe 2
    # Bug 48742 : Recherche le niveau de taxe 2 ssi la pièce est soumise à TPF
    If [F:XVLI]CODTPF>0 & [F:XVH0]ASJTPF="O"
        Read [SPV]SPV0=[F:SPX]CLE;0;0;"";[F:XVLI]CODTPF
        If !fstat WVACITM(1) = [F:SPV]VACITM2 Endif

        # On a trouvé un niveau : On lit le croisement et s'il existe on le garde
        If WVACITM(1)<>""
#            Read [TVC]TVC0 = [M]VACBPR;WVACITM(1)             : # V6
#            Read [TVC]TVC1 = [M]VACBPR;WVACITM(1)             : # V6
#            If fstat | [F:TVC]ENAFLG<>2 | [F:TVC]LEG<>GCURLEG : # V6
#            If fstat Raz WVACITM(1) Endif                     : # V6
            Filter [TVC] Where VACBPR=[M]VACBPR & VACITM=WVACITM(1) & ENAFLG=2 & LEG=GCURLEG : # V6
            Read [TVC]First                                    : # V6
            If fstat Raz WVACITM(1) Endif                      : # V6
            Filter [TVC]                                       : # V6
        Endif

        # On a pas trouvé de niveau ou le croisement n'existe pas
        # On va rechercher le 1er niveau correspondant au code taxe et au régime
        If WVACITM(1)=""
            If [F:XVLI]CODTPF<>0
                WVAT(1)=func SIXFONCTION.SI_COR2("XITAXPFC",num$([F:XVLI]CODTPF),[M:SIW0]CODPAY,"TABVAT","")
            Endif
            If WVAT(1)<>""
#                Filter [TVC] Where VACBPR=[M]VACBPR & VAT=WVAT(1)
                Filter [TVC] Where VACBPR=[M]VACBPR & VAT=WVAT(1) & ENAFLG=2 & LEG=GCURLEG : # V6
                Read [TVC]First
#               Bug 64842 : On recharge le bon code taxe
#                If !fstat WVACITM(1)=[F:TVC]VACITM Endif
                If !fstat WVACITM(1)=[F:TVC]VACITM : [M]VAT2(nolign-1)=WVAT(1) Endif
#               Bug 64842
                Filter [TVC]
            Endif
        Endif
    Endif
    [M]VACITM2(nolign-1)=WVACITM(1)
#Endif

Return

#------------------------------------------------------------------------------
# Détermination du numéro des colonnes à garnir avec les 2 remises intégrales
# -- > On détermine les colonnes en fonction du paramétrage
#      [F:SPX]DISCRGVEN (0) : Num colonne pour Rem art % +
#      [F:SPX]DISCRGVEN (1) : Num colonne pour Rem art % -
#      [F:SPX]DISCRGVEN (2) : Num colonne pour Rem art mnt +
#      [F:SPX]DISCRGVEN (3) : Num colonne pour Rem art mnt -
#      [F:SPX]DISCRGVEN (4) : Num colonne pour Rem cli % +
#      [F:SPX]DISCRGVEN (5) : Num colonne pour Rem cli % -
#------------------------------------------------------------------------------
$CHARG_DISCRGNUM

If [F:XVLI]TAUREM1>=0
    GDISCRGNUM1=[F:SPX]DISCRGVEN(0)
Else
    GDISCRGNUM1=[F:SPX]DISCRGVEN(1)
Endif
If [F:XVLI]TAUREM2>=0
    GDISCRGNUM2=[F:SPX]DISCRGVEN(4)
Else
    GDISCRGNUM2=[F:SPX]DISCRGVEN(5)
Endif

Return

#------------------------------------------------------------------------------
# Remise à 0 des colonnes frais/remise
# -- > Il faut remettre à 0 les colonnes qui ont pu être alimentées par la recherche tarif
#      Les colonnes sont alimentées en fonction des champs [F:XVLI]TAUREM1 et [F:XVLI]TAUREM2
#------------------------------------------------------------------------------
$RAZ_DISCRGVAL
Local Integer I

For I=1 To 9
    If evalue("dim([M]DISCRGVAL"+num$(I)+"(nolign-1))")>0
        Assign "[M]DISCRGVAL"+num$(I)+"(nolign-1)" With 0
        Assign "[M]DISCRGREN"+num$(I)+"(nolign-1)" With 0
    Endif
Next

Return

#------------------------------------------------------------------------------
# Chargement d'une colonne frais/remise     :
# -- > Pour retrouver tjs leur prix net si on a besoin de le recalculer :
#      On récupère leur prix net arrondi avec GDECPRI (Prérequis GSALRND=1)
#      Si différence avec notre prix net calculé :
#      On initialise le prix brut avec le prix net et on raz les frais/remises
#------------------------------------------------------------------------------
$CHARG_DISCRGVAL
If [F:XVH0]TYPPIE="AC" Return Endif : # V6 : S'il s'agit d'un avoir en valeur, pas de chargement des colonnes

If find(val(mid$(IMPZON, 10,1)), GDISCRGNUM1, GDISCRGNUM2)
    If GDISCRGNUM1=GDISCRGNUM2
        Assign "[M]DISCRGVAL"+num$(GDISCRGNUM1)+"(nolign-1)" With abs(arr((([F:XVLI]PRXUNINET-[F:XVLI]PRXUNI)/[F:XVLI]PRXUNI*100), 0.01))
    Else
        If val(mid$(IMPZON, 10,1))=GDISCRGNUM1
            Assign "[M]DISCRGVAL"+num$(GDISCRGNUM1)+"(nolign-1)" With abs(arr([F:XVLI]TAUREM1, 0.01))
        Endif
        If val(mid$(IMPZON, 10,1))=GDISCRGNUM2
            Assign "[M]DISCRGVAL"+num$(GDISCRGNUM2)+"(nolign-1)" With abs(arr([F:XVLI]TAUREM2, 0.01))
        Endif
    Endif
Endif

Return

#------------------------------------------------------------------------------
# Traitement particulier pour le prix net   :
# -- > Pour retrouver tjs leur prix net si on a besoin de le recalculer :
#      On récupère leur prix net arrondi avec GDECPRI (Prérequis GSALRND=1)
#      Si différence avec notre prix net calculé :
#      On initialise le prix brut avec le prix net et on raz les frais/remises
#------------------------------------------------------------------------------
$TRAIT_NETPRI

Local Decimal WPRXUNINET : WPRXUNINET=arr([F:XVLI]PRXUNINET,10^-GDECPRI)
Local Decimal WDIFNETPRI : WDIFNETPRI=[M]NETPRI(nolign-1)-WPRXUNINET
Local Integer I

If WPRXUNINET<0 Return Endif : # Bug 64396

If WDIFNETPRI<>0
    [M]GROPRI(nolign-1)=WPRXUNINET
    For I=1 To 9
        If evalue("dim([M]DISCRGVAL"+num$(I)+"(nolign-1))")>0
            Assign "[M]DISCRGVAL"+num$(I)+"(nolign-1)" With 0
        Endif
    Next
Endif
[M]NETPRI(nolign-1)=WPRXUNINET

Return


#------------------------------------------------------------------------------
# Bug 47519 : Traitement particulier pour le tiers payeur :
# Le client facturé est différent du client cde :
# -- > prendre la centrale du client facturé (XCLT.CEN) si celle-ci est payeur (XCLT.CEN_PYE)
#      sinon prendre le client facturé
# Le client facturé est égal au client cde :
# -- > prendre la centrale du client cde (XCLT.CEN) si celle-ci est payeur (XCLT.CEN_PYE)
#      sinon prendre le client cde
#------------------------------------------------------------------------------
$CHARG_BPCPYR
Local Char WCLT(GLONBPC)

If [F:XVH0]CLTFAC<>[F:XVH0]CODCLT & [F:XVH0]CLTFAC<>""
    WCLT=[F:XVH0]CLTFAC
Else
    WCLT=[F:XVH0]CODCLT
Endif
Read [XCLT]IND0=WCLT
If fstat Raz [F:XCLT] Endif
If [F:XCLT]CEN <> "" & [F:XCLT]CENPYE = "O"
    WBPCPYR   = func SIXFONCTION.SI_COR("XICLT",[F:XCLT]CEN ,"","")
Else
    WBPCPYR   = func SIXFONCTION.SI_COR("XICLT",WCLT,"","")
Endif

Return

#------------------------------------------------------------------------
# V6 : Stockage Adresse tiers payeur (pour les factures)
#------------------------------------------------------------------------
$CHARG_BPYADD
Local Integer WIND_ADD

If WBPCPYR=[F:XVH0]CODCLT | WBPCPYR=[F:XVH0]CLTFAC
    If WBPCPYR=[F:XVH0]CODCLT
        # Tiers payeur=Client commande : Adresse tiers payeur=Adresse clt commande
        WIND_ADD=0
    Else
        # Tiers payeur=Client facture  : Adresse tiers payeur=Adresse clt facture
        WIND_ADD=2
    Endif
    [M:SIW0]BPCNUM(3)=WBPCPYR
    [M:SIW0]NAM1(3)  =[M:SIW0]NAM1(WIND_ADD)   : [M:SIW0]SAT(3)   =[M:SIW0]SAT(WIND_ADD)
    [M:SIW0]NAM2(3)  =[M:SIW0]NAM2(WIND_ADD)   : [M:SIW0]CRY(3)   =[M:SIW0]CRY(WIND_ADD)
    [M:SIW0]ADR1(3)  =[M:SIW0]ADR1(WIND_ADD)   : [M:SIW0]CRYNAM(3)=[M:SIW0]CRYNAM(WIND_ADD)
    [M:SIW0]ADR2(3)  =[M:SIW0]ADR2(WIND_ADD)   : [M:SIW0]TEL(3)   =[M:SIW0]TEL(WIND_ADD)
    [M:SIW0]ADR3(3)  =[M:SIW0]ADR3(WIND_ADD)   : [M:SIW0]FAX(3)   =[M:SIW0]FAX(WIND_ADD)
    [M:SIW0]POSCOD(3)=[M:SIW0]POSCOD(WIND_ADD) : [M:SIW0]WEB(3)   =[M:SIW0]WEB(WIND_ADD)
    [M:SIW0]CTY(3)   =[M:SIW0]CTY(WIND_ADD)    : [M:SIW0]RAZCNT(3)=[M:SIW0]RAZCNT(2)
Else
    # Tiers payeur=Autre Client    : Recherche de son adresse par défaut
    Read [BPR]BPR0=WBPCPYR
    Read [BPA]BPA0=1;WBPCPYR;"001"
    If !fstat
        [M:SIW0]BPCNUM(3) =[F:BPR]BPRNUM
        [M:SIW0]NAM1(3)   =[F:BPR]BPRNAM(0)    : [M:SIW0]SAT(3)   =[F:BPA]SAT
        [M:SIW0]NAM2(3)   =[F:BPR]BPRNAM(1)    : [M:SIW0]CRY(3)   =[F:BPA]CRY
        [M:SIW0]ADR1(3)   =[F:BPA]BPAADDLIG(0) : [M:SIW0]CRYNAM(3)=[F:BPA]CRYNAM
        [M:SIW0]ADR2(3)   =[F:BPA]BPAADDLIG(1) : [M:SIW0]TEL(3)   =[F:BPA]TEL
        [M:SIW0]ADR3(3)   =[F:BPA]BPAADDLIG(2) : [M:SIW0]FAX(3)   =[F:BPA]FAX
        [M:SIW0]POSCOD(3) =[F:BPA]POSCOD       : [M:SIW0]WEB(3)   =[F:BPA]WEB
        [M:SIW0]CTY(3)    =[F:BPA]CTY          : [M:SIW0]RAZCNT(3)=2
    Endif
Endif

Return

#------------------------------------------------------------------------
# AP_READ_DETAIL : Après chargement de la ligne dans l'écran
#                  (Après SAI_NBLIG)
#------------------------------------------------------------------------
$AP_READ_DETAIL

# Forcer LINTYP à 1 pour les composés
# G_LINTYP a évité la déclinaison de la nomenclature mais LINTYP reste positionné
[M]LINTYP(nolign-1)=1

# 58798 : Vérification des codes taxes
# Message alerte si Code TPF dans intégrale mais pas de code taxe2 dans X3 et inversement
#                si Code taxe additionnelle dans intégrale mais pas de code taxe3 dans X3 et inversement
If  ([F:XVLI]CODTPF>0 & [F:XVH0]ASJTPF="O"     & [M:SQH2]VAT2(nolign-1)="") |
&  (([F:XVLI]CODTPF=0 | [F:XVH0]ASJTPF<>"O")   & [M:SQH2]VAT2(nolign-1)<>"") |
&   ([F:XART]TAXADD="O" & [F:XVH0]ASJTAXADD="O"     & [M:SQH2]VAT3(nolign-1)="") |
&  (([F:XART]TAXADD<>"O" | [F:XVH0]ASJTAXADD<>"O")  & [M:SQH2]VAT3(nolign-1)<>"")
    Call ECR_TRACE (SI_MES(287)-num$(nolign)-":"-[M:SQH2]ITMREF(nolign-1)-":"-SI_MES(285),-1) From GESECRAN
    If ([F:XVLI]CODTPF>0 & [F:XVH0]ASJTPF="O"    & [M:SQH2]VAT2(nolign-1)="") |
&      (([F:XVLI]CODTPF=0 | [F:XVH0]ASJTPF<>"O") & [M:SQH2]VAT2(nolign-1)<>"")
        Call ECR_TRACE (SI_MES(39)+SI_MES(278)+":"+[F:XVH0]ASJTPF-SI_MES(283)+":"+num$([F:XVLI]CODTPF),-1) From GESECRAN
        Call ECR_TRACE (SI_MES(284)+"="+SI_MES(286)+":"+[M:SQH2]VACITM2(nolign-1)-SI_MES(283)+":"+[M:SQH2]VAT2(nolign-1),-1) From GESECRAN
    Endif
    If ([F:XART]TAXADD="O" & [F:XVH0]ASJTAXADD="O"     & [M:SQH2]VAT3(nolign-1)="") |
&      (([F:XART]TAXADD<>"O" | [F:XVH0]ASJTAXADD<>"O") & [M:SQH2]VAT3(nolign-1)<>"")
        Call ECR_TRACE (SI_MES(39)+SI_MES(279)+":"+[F:XVH0]ASJTAXADD-[F:XART]TAXADD,-1) From GESECRAN
        Call ECR_TRACE (SI_MES(284)+"="+SI_MES(286)+":"+[M:SQH2]VACITM3(nolign-1)-SI_MES(283)+":"+[M:SQH2]VAT3(nolign-1),-1) From GESECRAN
    Endif
Endif

Return

#------------------------------------------------------------------------
# INICRE specifique a reprise intégrale ( apres INICRE objet )
#------------------------------------------------------------------------
$INICRE
#-- Stockage des donnees adresse
Gosub SIADD
#-- Stockage du no document Integrale
Gosub SINUM
#-- Ecriture du texte entete et des textes lignes
Gosub SIWRKTXT
#-- Stockage des sections analytiques des éléments de facturation
Gosub SIWRKSFICCE : # V6
Return

#------------------------------------------------------------------------
# Erreur lors du garnissage des ecrans facture
#------------------------------------------------------------------------
$ERREUR

If LERR=4
   GBIDC3=GBIDC3-mess(532,197,1)-[F:SGD]VCRNUM+"   "+mess(18,7,1)-[M:SQH2]ITMREF(nolign-1)
Endif

Return

#------------------------------------------------------------------------
# Tables mises a jour lors de la creation de devis
# ( on est dans une transaction : en cas d'erreur positionner GOK )
#------------------------------------------------------------------------
$CREATION
#----- Mise à jour indicateur "traité" sur entête devis "Intégrale" -----#
# Bug 47682 : Maj du flag ssi on est pas en simulation
If find (GWLTEST,1,2)
#  Update [XVH0] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ With FLGREP=2
  Local Integer WNUMORD : WNUMORD=[F:XVH0]NUMORD
  Local Char    WLETRLQ : WLETRLQ=[F:XVH0]LETRLQ
  Update [XVH0] Where NUMORD=WNUMORD & LETRLQ=WLETRLQ With FLGREP=2
Endif
#-----

# 58798 : Vérification du montant TTC
# Message alerte montant TTC dans intégrale différent montant TTC dans X3
If [M:SQH2]QUOINVATI<>[F:XVH0]MNTTOTTTC
    Call ECR_TRACE (SI_MES(129),-1) From GESECRAN
Endif

Return


#########################################################################
# Traitement commun aux documents Devis / Commande / Factures
#                                SIXSQH   SIXSOH     SIXSIH
#------------------------------------------------------------------------
# Stockage dans [M] SIWRKEPV des données integrales
# $SIWRKEPV  ( Les données entete )
# - les adresses
# - les taxes
# - les elements de facturation
# - la repartition des taxes secondaires dans SIHV ( uniquement factures )
# $SIWRKTXT  ( Le texte entête et les textes lignes )
#
#########################################################################

$SIWRKEPV
Raz [M:SIW0]
Local Integer JL, JL1, JL2
Local Decimal JLMNT, JLECART
Local Char    JLV (3)
Local Char    CRITERE (250)
Local Char    DOC_CUR_X3 (5)      : # devise X3 du document

Read [XCLT]IND0=[XVH0]CODCLT

If [F:XVH0]CODDVS=""
   DOC_CUR_X3=[F:SPX]CUR
 Else
   DOC_CUR_X3=func SIXFONCTION.SI_COR("XIDVS",[F:XVH0]CODDVS,"","")
Endif
Read [TCU]TCU0=DOC_CUR_X3

Case SI_SUBPRG
  When "SI_SQH"
       Gosub SIW0_ADR
       Gosub SIW0_TAX
       Gosub SIW0_SFI

  When "SI_SOH"
       Gosub SIW0_ADR
       Gosub SIW0_TAX
       Gosub SIW0_SFI
       Gosub SIW0_EAV From SIXSOH

  When "SI_SIH"
       Gosub SIW0_ADR
       Gosub SIW0_TAX
       Gosub SIW0_SFI
Endcase

Return

#------------------------------------------------------------------------
# Adresse stockée : 0=Client cde / 1=Client livré / 2=Client facture
#------------------------------------------------------------------------
$SIW0_ADR

Read [BPR]BPR0=func SIXFONCTION.SI_COR("XICLT",[F:XVH0]CODCLT,"","")
Read [BPA]BPA0=1;func SIXFONCTION.SI_COR("XICLT",[F:XVH0]CODCLT,"","");"001"

If !fstat
   For JL=0 To dim([M:SIW0]BPCNUM)-1
       [M:SIW0]BPCNUM(JL)=[F:BPR]BPRNUM
       [M:SIW0]NAM1(JL)  =[F:BPR]BPRNAM(0)    : [M:SIW0]SAT(JL)   =[F:BPA]SAT
       [M:SIW0]NAM2(JL)  =[F:BPR]BPRNAM(1)    : [M:SIW0]CRY(JL)   =[F:BPA]CRY
       [M:SIW0]ADR1(JL)  =[F:BPA]BPAADDLIG(0) : [M:SIW0]CRYNAM(JL)=[F:BPA]CRYNAM
       [M:SIW0]ADR2(JL)  =[F:BPA]BPAADDLIG(1) : [M:SIW0]TEL(JL)   =[F:BPA]TEL
       [M:SIW0]ADR3(JL)  =[F:BPA]BPAADDLIG(2) : [M:SIW0]FAX(JL)   =[F:BPA]FAX
       [M:SIW0]POSCOD(JL)=[F:BPA]POSCOD       : [M:SIW0]WEB(JL)   =[F:BPA]WEB
       [M:SIW0]CTY(JL)   =[F:BPA]CTY          : [M:SIW0]RAZCNT(JL)=2
   Next JL
Endif

Filter [XVAD] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ
Read [XVAD]First
If !fstat
   Raz [M:SIW0]BPCNUM, [M:SIW0]NAM1, [M:SIW0]NAM2, [M:SIW0]ADR1, [M:SIW0]ADR2, [M:SIW0]ADR3
   Raz [M:SIW0]POSCOD, [M:SIW0]CTY, [M:SIW0]SAT, [M:SIW0]CRY, [M:SIW0]CRYNAM
   Raz [M:SIW0]TEL, [M:SIW0]FAX, [M:SIW0]WEB, [M:SIW0]RAZCNT

   For JL=0 To dim([M:SIW0]BPCNUM)-1
       [M:SIW0]BPCNUM(JL)=func SIXFONCTION.SI_COR("XICLT",[F:XVH0]CODCLT,"","")
       [M:SIW0]NAM1(JL)  =[F:XVAD]NOMCLT  : [M:SIW0]POSCOD(JL)=[F:XVAD]CODPST
       [M:SIW0]ADR1(JL)  =[F:XVAD]ADR1CLT : [M:SIW0]CTY(JL)   =[F:XVAD]VIL
       [M:SIW0]ADR2(JL)  =[F:XVAD]ADR2CLT : [M:SIW0]RAZCNT(JL)=1
       [M:SIW0]ADR3(JL)  =[F:XVAD]ADR3CLT :
   Next JL
   [M:SIW0]CRY(0)=func SIXFONCTION.SI_COR("XIPAY",[F:XVAD]CODPAY,"","")
   If [F:TCY]CRY<>[M:SIW0]CRY(0)
      Read [TCY]TCY0=[M:SIW0]CRY(0)
      If fstat : Raz [F:TCY]  : Endif : #VOIR ATEXTRA
   Endif
   If dim([F:TCY]CRYNAM)>0       : # V140
      [M:SIW0]CRYNAM(0)=[F:TCY]CRYNAM
   Endif
   If dim([F:TCY]CRYDES)>0       : # V5 V6
      Call LECTEXTRA([M:SIW0]CRYNAM(0),"TABCOUNTRY","CRYDES",[F:TCY]CRY,"") From ATEXTRA
   Endif
   [M:SIW0]CRY(1)   =[M:SIW0]CRY(0)    : [M:SIW0]CRY(2)   =[M:SIW0]CRY(0)
   [M:SIW0]CRYNAM(1)=[M:SIW0]CRYNAM(0) : [M:SIW0]CRYNAM(2)=[M:SIW0]CRYNAM(0)

   # Alimentation du code pays de la pièce (utile pour la détermination des taxes)
   [M:SIW0]CODPAY=[F:XVAD]CODPAY
Endif

# Si le code pays n'est pas renseigné dans les adresses on prend le code pays du tiers
If [M:SIW0]CODPAY="" [M:SIW0]CODPAY=[F:XCLT]CODPAY Endif

# Vu 14/03/08 :
# Si clt facture de la pièce <> clt cde ou clt facture du clt cde <> ""
# --> L'adresse de facture doit être reprise de la fiche tiers de ce facturé
If [F:XVH0]CODCLT<>[F:XVH0]CLTFAC | [F:XCLT]CODFAC<>""
   Read [BPR]BPR0=func SIXFONCTION.SI_COR("XICLT",[F:XVH0]CODCLT,"","")
   Read [BPA]BPA0=1;func SIXFONCTION.SI_COR("XICLT",[F:XVH0]CLTFAC,"","");"001"
   If !fstat
       [M:SIW0]BPCNUM(2) =[F:BPR]BPRNUM
       [M:SIW0]NAM1(2)   =[F:BPR]BPRNAM(0)    : [M:SIW0]SAT(2)   =[F:BPA]SAT
       [M:SIW0]NAM2(2)   =[F:BPR]BPRNAM(1)    : [M:SIW0]CRY(2)   =[F:BPA]CRY
       [M:SIW0]ADR1(2)   =[F:BPA]BPAADDLIG(0) : [M:SIW0]CRYNAM(2)=[F:BPA]CRYNAM
       [M:SIW0]ADR2(2)   =[F:BPA]BPAADDLIG(1) : [M:SIW0]TEL(2)   =[F:BPA]TEL
       [M:SIW0]ADR3(2)   =[F:BPA]BPAADDLIG(2) : [M:SIW0]FAX(2)   =[F:BPA]FAX
       [M:SIW0]POSCOD(2) =[F:BPA]POSCOD       : [M:SIW0]WEB(2)   =[F:BPA]WEB
       [M:SIW0]CTY(2)    =[F:BPA]CTY          : [M:SIW0]RAZCNT(2)=2
   Endif
Endif

Return

#------------------------------------------------------------------------
# Constitution du tableau des taxes
#   0 à  9 : les TVA / 11 à 19 : les TPF / 20 : la taxe additionnelle
#------------------------------------------------------------------------
$SIW0_TAX
Local Integer WRET :#--CPO 71937
Raz JL, JLV

#-- constitution du tableau pour les TVA à partir des lignes
#   ( obligatoire a partir des lignes car pas de stockage enr. taxe taux 0 )
#   Nota : dans cette boucle poste garni par code TVA utilisé comme indice
Filter [XVLI] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ & TYPLIG="L"
For [XVLI]
   [M:SIW0]XVTYP([F:XVLI]CODTVA)    =1           : # Type taxe TVA
   [M:SIW0]VATCODINT([F:XVLI]CODTVA) =[F:XVLI]CODTVA
   [M:SIW0]XVNOT([F:XVLI]CODTVA) +=[F:XVLI]MNTHT
   If [F:XVLI]CODTPF>0 & [F:XVLI]CODTPF<10        : # Base TPF de la ligne
      JLMNT  =evalue("[M:SIW0]B_TS"+num$([F:XVLI]CODTPF)+"("+num$([F:XVLI]CODTVA)+")")
      JLMNT +=[F:XVLI]MNTHT
      Assign "[M:SIW0]B_TS"+num$([F:XVLI]CODTPF)+"("+num$([F:XVLI]CODTVA)+")" With JLMNT
   Endif
   If [F:XVH0]MNTTAXADD<>0                        : # Si Taxe additionnelle sur document
      Read [XART]IND0=[F:XVLI]CODART
      # Bug 49147 : Si ce n'est pas un article, aller voir si c'est un article conditionné
      If fstat
          Read [XACT]IND0=[F:XVLI]CODART
          If !fstat
              Read [XART]IND0=[F:XACT]ARTPCP
          Endif
      Endif
      If !fstat
         If [F:XART]TAXADD="O"                    : # et article soumis à Taxe addtionnelle
           JLMNT  =evalue("[M:SIW0]B_TSA ("+num$([F:XVLI]CODTVA)+")")
           JLMNT +=[F:XVLI]MNTHT
           Assign "[M:SIW0]B_TSA ("+num$([F:XVLI]CODTVA)+")" With JLMNT
         Endif
      Endif
   Endif
Next
Filter [XVLI]


#-- les taxes contenues dans XIEPV : Integrale EPV  ( TPF: 0 ou 1 / Taxe additionnelle : 0 ou 1 )
If [F:XVH0]BASHTTPF1<>0
   JL=10+[F:XVH0]CODTPF1     : # Taxe parafiscale de 1 a 9 ( postes 11 a 19 )
   [M:SIW0]XVTYP(JL)=2
   [M:SIW0]VATCODINT(JL)=[F:XVH0]CODTPF1
   [M:SIW0]XVTAX(JL)=func SIXFONCTION.SI_COR2("XITAXPFC",num$([F:XVH0]CODTPF1),[F:XCLT]CODPAY,"","")
   [M:SIW0]XVSMI(JL)=[F:XVH0]BASHTTPF1
   [M:SIW0]XVRAT(JL)=[F:XVH0]TAUTPF1
   [M:SIW0]XVAMT(JL)=[F:XVH0]MNTTPF1
Endif

If [F:XVH0]MNTBASTAXADD<>0
   JL=20                     : # Taxe additionnelle ( poste 20)
   [M:SIW0]XVTYP(JL)=3
   [M:SIW0]VATCODINT(JL)=0   : # Pas dans une table Integrale
   [M:SIW0]XVTAX(JL)=[F:SPX]VATADD
   [M:SIW0]XVSMI(JL)=[F:XVH0]MNTBASTAXADD
   [M:SIW0]XVRAT(JL)=[F:XVH0]TAUTAXADD
   [M:SIW0]XVAMT(JL)=[F:XVH0]MNTTAXADD
Endif

#-- les taxes contenues dans XIEPVTVA : Integrale EPV_TVA  ( TVA : 1 par enregistrement / de 1 a 4 par enregistrement)
Filter [XVHT] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ
For [XVHT]
   JL=[F:XVHT]CODTVA
   [M:SIW0]XVTYP(JL)=1      : # Taxe TVA
   [M:SIW0]VATCODINT(JL)=[F:XVHT]CODTVA
   [M:SIW0]XVTAX(JL)=func SIXFONCTION.SI_COR2("XITVAVEN",num$([F:XVHT]CODTVA),[F:XCLT]CODPAY,"#","")
   If [M:SIW0]XVTAX(JL)="" : [M:SIW0]XVTAX(JL)=GEXETAX : Endif
   [M:SIW0]XVSMI(JL)=[F:XVHT]BASHTTVA
   [M:SIW0]XVRAT(JL)=[F:XVHT]TAUTVA
   [M:SIW0]XVAMT(JL)=[F:XVHT]MNTTVA
Next
Filter [XVHT]

#-- les taxes contenues dans XILPVTVA : Integral LPV_TVA  ( TVA : 1 par enregistrement )
Filter [XVTV] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ
For [XVTV]
   JL=[F:XVTV]CODTVA
   [M:SIW0]XVTYP(JL)=1      : # Taxe TVA
   [M:SIW0]VATCODINT(JL)=[F:XVTV]CODTVA
   [M:SIW0]XVTAX(JL)=func SIXFONCTION.SI_COR2("XITVAVEN",num$([F:XVTV]CODTVA),[F:XCLT]CODPAY,"#","")
   If [M:SIW0]XVTAX(JL)="" : [M:SIW0]XVTAX(JL)=GEXETAX : Endif
   [M:SIW0]XVSMI(JL)=[F:XVTV]MNTBASHTTVA
   [M:SIW0]XVRAT(JL)=[F:XVTV]TAUTVA
   [M:SIW0]XVAMT(JL)=[F:XVTV]MNTTVA
Next
Filter [XVTV]

#-- Si dans le tableau [M:SIW0]NBVA pour les taxes principales issues des lignes
#   il n y a pas de stockage dans Intégrale ( Ex : CEE )
#   --> garnir le code taxe XVTAX par recherche de correspondance
#   --> charger le montant soumis XVSMI = XVNOT ( pas mieux en magasin )
#       impossible de mettre un XVSMI correct mais puisque le taux = 0 !..
For JL=0 To 9
   If [M:SIW0]XVNOT(JL)<>0 & [M:SIW0]XVSMI(JL)=0
      If [M:SIW0]XVTAX(JL)=""
         [M:SIW0]XVTAX(JL)=func SIXFONCTION.SI_COR2("XITVAVEN",num$([M:SIW0]VATCODINT(JL)),[F:XCLT]CODPAY,"#","")
      Endif
      If [M:SIW0]XVTAX(JL)=""
         [M:SIW0]XVTAX(JL)=GEXETAX
      Endif
      [M:SIW0]XVSMI(JL)=[M:SIW0]XVNOT(JL)
   Endif
Next JL

#-- les taxes contenues dans XILPVTPF : Integrale LPV_TPF  ( TPF : 1 par enregistrement )
Filter [XVTP] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ
For [XVTP]
   JL=10+[F:XVTP]CODTPF
   [M:SIW0]XVTYP(JL)=2      : # Taxe parafiscale
   [M:SIW0]VATCODINT(JL)=[F:XVTP]CODTPF
   [M:SIW0]XVTAX(JL)=func SIXFONCTION.SI_COR2("XITAXPFC",num$([F:XVTP]CODTPF),[F:XCLT]CODPAY,"","")
   [M:SIW0]XVSMI(JL)=[F:XVTP]MNTBASHTTPF
   [M:SIW0]XVRAT(JL)=[F:XVTP]TAUTPF
   [M:SIW0]XVAMT(JL)=[F:XVTP]MNTTPF
Next
Filter [XVTP]

[M:SIW0]NBVAT=21

#-- repartition des taxes secondaires par taxe principale
#   eclatement de chaque taxe secondaire
For JL=0 To 9
   If sum([M:SIW0]B_TS1)<>0
      If [M:SIW0]B_TS1(JL)<>0
         [M:SIW0]R_TS1(JL)=arr(([M:SIW0]XVAMT(11)*[M:SIW0]B_TS1(JL))/sum([M:SIW0]B_TS1) ,[F:TCU]CURRND)
      Endif
   Endif
   If sum([M:SIW0]B_TS2)<>0
      If [M:SIW0]B_TS2(JL)<>0
         [M:SIW0]R_TS2(JL)=arr(([M:SIW0]XVAMT(12)*[M:SIW0]B_TS2(JL))/sum([M:SIW0]B_TS2) ,[F:TCU]CURRND)
      Endif
   Endif
   If sum([M:SIW0]B_TS3)<>0
      If [M:SIW0]B_TS3(JL)<>0
         [M:SIW0]R_TS3(JL)=arr(([M:SIW0]XVAMT(13)*[M:SIW0]B_TS3(JL))/sum([M:SIW0]B_TS3) ,[F:TCU]CURRND)
      Endif
   Endif
   If sum([M:SIW0]B_TS4)<>0
      If [M:SIW0]B_TS4(JL)<>0
         [M:SIW0]R_TS4(JL)=arr(([M:SIW0]XVAMT(14)*[M:SIW0]B_TS4(JL))/sum([M:SIW0]B_TS4) ,[F:TCU]CURRND)
      Endif
   Endif
   If sum([M:SIW0]B_TS5)<>0
      If [M:SIW0]B_TS5(JL)<>0
         [M:SIW0]R_TS5(JL)=arr(([M:SIW0]XVAMT(15)*[M:SIW0]B_TS5(JL))/sum([M:SIW0]B_TS5) ,[F:TCU]CURRND)
      Endif
   Endif
   If sum([M:SIW0]B_TS6)<>0
      If [M:SIW0]B_TS6(JL)<>0
         [M:SIW0]R_TS6(JL)=arr(([M:SIW0]XVAMT(16)*[M:SIW0]B_TS6(JL))/sum([M:SIW0]B_TS6) ,[F:TCU]CURRND)
      Endif
   Endif
   If sum([M:SIW0]B_TS7)<>0
      If [M:SIW0]B_TS7(JL)<>0
         [M:SIW0]R_TS7(JL)=arr(([M:SIW0]XVAMT(17)*[M:SIW0]B_TS7(JL))/sum([M:SIW0]B_TS7) ,[F:TCU]CURRND)
      Endif
   Endif
   If sum([M:SIW0]B_TS8)<>0
      If [M:SIW0]B_TS8(JL)<>0
         [M:SIW0]R_TS8(JL)=arr(([M:SIW0]XVAMT(18)*[M:SIW0]B_TS8(JL))/sum([M:SIW0]B_TS8) ,[F:TCU]CURRND)
      Endif
   Endif
   If sum([M:SIW0]B_TS9)<>0
      If [M:SIW0]B_TS9(JL)<>0
         [M:SIW0]R_TS9(JL)=arr(([M:SIW0]XVAMT(19)*[M:SIW0]B_TS9(JL))/sum([M:SIW0]B_TS9) ,[F:TCU]CURRND)
      Endif
   Endif
   If sum([M:SIW0]B_TSA)<>0
      If [M:SIW0]B_TSA(JL)<>0
         [M:SIW0]R_TSA(JL)=arr(([M:SIW0]XVAMT(20)*[M:SIW0]B_TSA(JL))/sum([M:SIW0]B_TSA) ,[F:TCU]CURRND)
      Endif
   Endif
Next JL

#-- repartition des taxes secondaires par taxe principale
#   ajustement de ecart sur plus gros montant
If sum([M:SIW0]B_TS1)<>0
   JLECART=sum([M:SIW0]R_TS1)-[M:SIW0]XVAMT(11)
   If JLECART
      JL=find(max([M:SIW0]R_TS1),[M:SIW0]R_TS1)
      If JL : [M:SIW0]R_TS1(JL-1) -= JLECART : Endif
   Endif
Endif
If sum([M:SIW0]B_TS2)<>0
   JLECART=sum([M:SIW0]R_TS2)-[M:SIW0]XVAMT(12)
   If JLECART
      JL=find(max([M:SIW0]R_TS2),[M:SIW0]R_TS2)
      If JL : [M:SIW0]R_TS2(JL-1) -= JLECART : Endif
   Endif
Endif
If sum([M:SIW0]B_TS3)<>0
   JLECART=sum([M:SIW0]R_TS3)-[M:SIW0]XVAMT(13)
   If JLECART
      JL=find(max([M:SIW0]R_TS3),[M:SIW0]R_TS3)
      If JL : [M:SIW0]R_TS3(JL-1) -= JLECART : Endif
   Endif
Endif
If sum([M:SIW0]B_TS4)<>0
   JLECART=sum([M:SIW0]R_TS4)-[M:SIW0]XVAMT(14)
   If JLECART
      JL=find(max([M:SIW0]R_TS4),[M:SIW0]R_TS4)
      If JL : [M:SIW0]R_TS4(JL-1) -= JLECART : Endif
   Endif
Endif
If sum([M:SIW0]B_TS5)<>0
   JLECART=sum([M:SIW0]R_TS5)-[M:SIW0]XVAMT(15)
   If JLECART
      JL=find(max([M:SIW0]R_TS5),[M:SIW0]R_TS5)
      If JL : [M:SIW0]R_TS5(JL-1) -= JLECART : Endif
   Endif
Endif
If sum([M:SIW0]B_TS6)<>0
   JLECART=sum([M:SIW0]R_TS6)-[M:SIW0]XVAMT(16)
   If JLECART
      JL=find(max([M:SIW0]R_TS6),[M:SIW0]R_TS6)
      If JL : [M:SIW0]R_TS6(JL-1) -= JLECART : Endif
   Endif
Endif
If sum([M:SIW0]B_TS7)<>0
   JLECART=sum([M:SIW0]R_TS7)-[M:SIW0]XVAMT(17)
   If JLECART
      JL=find(max([M:SIW0]R_TS7),[M:SIW0]R_TS7)
      If JL : [M:SIW0]R_TS7(JL-1) -= JLECART : Endif
   Endif
Endif
If sum([M:SIW0]B_TS8)<>0
   JLECART=sum([M:SIW0]R_TS8)-[M:SIW0]XVAMT(18)
   If JLECART
      JL=find(max([M:SIW0]R_TS8),[M:SIW0]R_TS8)
      If JL : [M:SIW0]R_TS8(JL-1) -= JLECART : Endif
   Endif
Endif
If sum([M:SIW0]B_TS9)<>0
   JLECART=sum([M:SIW0]R_TS9)-[M:SIW0]XVAMT(19)
   If JLECART
      JL=find(max([M:SIW0]R_TS9),[M:SIW0]R_TS9)
      If JL : [M:SIW0]R_TS9(JL-1) -= JLECART : Endif
   Endif
Endif
If sum([M:SIW0]B_TSA)<>0
   JLECART=sum([M:SIW0]R_TSA)-[M:SIW0]XVAMT(20)
   If JLECART
      JL=find(max([M:SIW0]R_TSA),[M:SIW0]R_TSA)
      If JL : [M:SIW0]R_TSA(JL-1) -= JLECART : Endif
   Endif
Endif

#-- Calcul de la colonne TTC produit par type de taxe principale
For JL=0 To 9
    [M:SIW0]XVSUP(JL)  =[M:SIW0]R_TS1(JL)
    [M:SIW0]XVSUP(JL) +=[M:SIW0]R_TS2(JL)
    [M:SIW0]XVSUP(JL) +=[M:SIW0]R_TS3(JL)
    [M:SIW0]XVSUP(JL) +=[M:SIW0]R_TS4(JL)
    [M:SIW0]XVSUP(JL) +=[M:SIW0]R_TS5(JL)
    [M:SIW0]XVSUP(JL) +=[M:SIW0]R_TS6(JL)
    [M:SIW0]XVSUP(JL) +=[M:SIW0]R_TS7(JL)
    [M:SIW0]XVSUP(JL) +=[M:SIW0]R_TS8(JL)
    [M:SIW0]XVSUP(JL) +=[M:SIW0]R_TS9(JL)
    [M:SIW0]XVSUP(JL) +=[M:SIW0]R_TSA(JL)
    [M:SIW0]XVATI(JL)  =[M:SIW0]XVNOT(JL)+[M:SIW0]XVAMT(JL)+[M:SIW0]XVSUP(JL)
Next JL

#-- Si dans le tableau [M:SIW0]NBVAT plusieurs lignes de code taxe identique --> regrouper les lignes
For JL=0 To 9
   If [M:SIW0]XVTAX(JL)<>""
      For JL1= JL+1 To 10
         If [M:SIW0]XVTAX(JL)=[M:SIW0]XVTAX(JL1) & [M:SIW0]XVRAT(JL)=[M:SIW0]XVRAT(JL1)
            [M:SIW0]XVTYP(JL1)=0 : [M:SIW0]VATCODINT(JL1)=0 : [M:SIW0]XVTAX(JL1)=""
            [M:SIW0]XVNOT(JL) +=[M:SIW0]XVNOT(JL1) : [M:SIW0]XVNOT(JL1)=0
            [M:SIW0]XVSMI(JL) +=[M:SIW0]XVSMI(JL1) : [M:SIW0]XVSMI(JL1)=0
            [M:SIW0]XVAMT(JL) +=[M:SIW0]XVAMT(JL1) : [M:SIW0]XVAMT(JL1)=0
            [M:SIW0]XVSUP(JL) +=[M:SIW0]XVSUP(JL1) : [M:SIW0]XVSUP(JL1)=0
            [M:SIW0]XVATI(JL) +=[M:SIW0]XVATI(JL1) : [M:SIW0]XVATI(JL1)=0
         Endif
      Next JL1
   Endif
Next JL

#-- tri des taxes par type et code taxe X3 et tassement du tableau

Sorta [M:SIW0]NBVAT [M:SIW0]NBVAT Order By [M:SIW0]XVTYP(indice), [M:SIW0]XVTAX(indice)

Raz JL1
For JL=0 To dim ([M:SIW0]XVTAX)-1
   If [M:SIW0]XVTAX(JL)<>"" : JL1=JL : Break : Endif
Next

If JL1
   Dela 0, JL1 [M:SIW0]NBVAT
   [M:SIW0]NBVAT=find("",[M:SIW0]XVTAX)-1
Else
   [M:SIW0]NBVAT=0
Endif

Return


# VOIR UTILITE AVANT SUPPRESSION
#-- recherche du niveau de chaque ligne
If dim([F:TVC]COD)>0  JLV="V6"               : # Table TABVAC de V6
  Else                JLV="V5"               : # Table TABVAC de V5
Endif

For JL=0 To dim ([M:SIW0]XVTYP)-1
#   Filter [TVC] Where VACBPR=[M:SIW0]VACBPR & VAT=[M:SIW0]XVTAX(JL)
	 #--CPO 71937
   #Filter [TVC] Where VACBPR=[M:SIW0]VACBPR & VAT=[M:SIW0]XVTAX(JL) & ENAFLG=2 & LEG=GCURLEG : # V6
   Filter [TVC] Where VACBPR=[M:SIW0]VACBPR & VAT=[M:SIW0]XVTAX(JL) & ENAFLG=2 & (LEG=GCURLEG | LEG="") Order By MACLE= COD Asc;LEG Desc : # >V6
   For [TVC]MACLE
   #--/CPO
       If JLV="V5"
       		#--CPO 71937 TVT et multi-lèg
       		Call LEC_TVT_LEG(GCURLEG,[F:TVC]VAT,WRET) From TRTLECLEG
       		If WRET : Raz [F:TVT] Endif
          #Read [TVT]TVT0=[F:TVC]VAT
          #If !fstat
             If [F:TVT]XVTYP=[M:SIW0]XVTYP(JL) :                 [M:SIW0]VACITM(JL)=[F:TVC]VACITM : Break : Endif
             If [M:SIW0]XVTYP(JL)>1 & find([F:TVT]XVTYP,2,3,4) : [M:SIW0]VACITM(JL)=[F:TVC]VACITM : Break : Endif
          #Endif
          #--/CPO
       Endif
       If JLV="V6"
          If [F:TVC]XVTYP=[M:SIW0]XVTYP(JL) :                    [M:SIW0]VACITM(JL)=[F:TVC]VACITM : Break : Endif
          If [M:SIW0]XVTYP(JL)>1 & find([F:TVC]XVTYP,2,3,4) :    [M:SIW0]VACITM(JL)=[F:TVC]VACITM : Break : Endif
      Endif
   Next
Next JL
Filter [TVC]

Return

#------------------------------------------------------------------------
#------------------------------------------------------------------------
SIW0_SFI
If    SI_SUBPRG="SI_SQH" | SI_SUBPRG="SI_SOH"
   Filter [SFI] Where DACORD<>0 Order By DACORD
   For [SFI]
       [M:SIW0]INVDTA([F:SFI]DACORD-1)       =[F:SFI]SFINUM  : # No element
       [M:SIW0]INVDTATYP([F:SFI]DACORD-1)    =[F:SFI]CLCBAS  : # HT / TTC ( pour utilisation en V6 )
       [M:SIW0]INVDTACOD([F:SFI]DACORD-1)    =[F:SFI]AMTCOD  : # % ou montant
       If dim([F:SFI]DSP)>0
          [M:SIW0]INVDTADSP([F:SFI]DACORD-1) =[F:SFI]DSP     : # cle de repartition en V6
       Endif
   Next
   Filter [SFI]
Endif

If  SI_SUBPRG="SI_SIH"
   Filter [SFI] Where DACINV<>0 Order By DACINV
   For [SFI]
       [M:SIW0]INVDTA([F:SFI]DACINV-1)       =[F:SFI]SFINUM  : # No element
       [M:SIW0]INVDTATYP([F:SFI]DACINV-1)    =[F:SFI]CLCBAS  : # HT / TTC ( pour utilisation en V6 )
       [M:SIW0]INVDTACOD([F:SFI]DACINV-1)    =[F:SFI]AMTCOD  : # % ou montant
       If dim([F:SFI]DSP)>0
          [M:SIW0]INVDTADSP([F:SFI]DACINV-1) =[F:SFI]DSP     : # cle de repartition en V6
       Endif
   Next
   Filter [SFI]
Endif

For JL=0 To dim([M:SIW0]INVDTA)-1
    If [M:SIW0]INVDTA(JL)<>0 : [M:SIW0]NBFAC +=1 : Endif
Next JL

#-- stockage remise
Raz JL
If sum([F:XVH0]TAUREMPED,[F:XVH0]MNTREMPED)>0 & [F:SPX]DTAREM<>0
   JL=find([F:SPX]DTAREM,[M:SIW0]INVDTA)
   If JL
      If [M:SIW0]INVDTACOD(JL-1)=1 : [M:SIW0]INVDTAAMT(JL-1)=[F:XVH0]TAUREMPED : Endif
      If [M:SIW0]INVDTACOD(JL-1)=2 : [M:SIW0]INVDTAAMT(JL-1)=arr([F:XVH0]MNTREMPED,[F:TCU]CURRND) : Endif
      [M:SIW0]DTANOT(JL-1)   = -[F:XVH0]MNTREMPED
      [M:SIW0]DTAVAT(JL-1)   = GEXETAX              : # taxe directement dans tableau des taxes
   Endif
Endif

#-- stockage escompte
Raz JL
If sum([F:XVH0]TAUEPT,[F:XVH0]MNTEPT)>0 & [F:SPX]DTAESC<>0
   JL=find([F:SPX]DTAESC,[M:SIW0]INVDTA)
   If JL
      If [M:SIW0]INVDTACOD(JL-1)=1 : [M:SIW0]INVDTAAMT(JL-1)=[F:XVH0]TAUEPT : Endif
      If [M:SIW0]INVDTACOD(JL-1)=2 : [M:SIW0]INVDTAAMT(JL-1)=arr([F:XVH0]MNTEPT,[F:TCU]CURRND) : Endif
      [M:SIW0]DTANOT(JL-1)   = -[F:XVH0]MNTEPT
      [M:SIW0]DTAVAT(JL-1)   = GEXETAX              : # taxe directement dans tableau des taxes
   Endif
Endif

#-- stockage port
Raz JL,JL1,JL2
Filter [XVPO] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ
For [XVPO]
   For JL=0 To dim([F:SPX]CODART)-1
      If [F:SPX]TYP(JL)=1 & [F:SPX]CODART(JL)=[F:XVPO]CODARTFRAPOR
         JL1=[F:SPX]SFINUM(JL)
         Break
      Endif
   Next
   Break                                : # un seul article port
Next
If JL1
   JL2=find(JL1,[M:SIW0]INVDTA)
   If JL2
      If [M:SIW0]INVDTACOD(JL2-1)=2
         [M:SIW0]INVDTAAMT(JL2-1)=arr([F:XVPO]MNTHTFRAPOR,[F:TCU]CURRND)
      Endif
      [M:SIW0]DTANOT(JL2-1)   = [F:XVPO]MNTHTFRAPOR
      [M:SIW0]DTAVAT(JL2-1)   = GEXETAX              : # taxe directement dans tableau des taxes
      [M:SIW0]SFICCE(JL2-1)   = [F:XVPO]SECANAFRAPOR : # V6
   Endif
Endif
Filter [XVPO]

#-- stockage frais divers
Raz JL,JL1,JL2
Filter [XVFD] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ
For [XVFD]
   For JL=0 To dim([F:SPX]CODART)-1
      If [F:SPX]TYP(JL)=2 & [F:SPX]CODART(JL)=[F:XVFD]CODARTFRADIV
         JL1=[F:SPX]SFINUM(JL)
         Break
      Endif
   Next
   Break                                : # un seul article frais divers
Next
If JL1
   JL2=find(JL1,[M:SIW0]INVDTA)
   If JL2
      If [M:SIW0]INVDTACOD(JL2-1)=2
         [M:SIW0]INVDTAAMT(JL2-1)=arr([F:XVFD]MNTHTFRADIV,[F:TCU]CURRND)
      Endif
      [M:SIW0]DTANOT(JL2-1)   = [F:XVFD]MNTHTFRADIV
      [M:SIW0]DTAVAT(JL2-1)   = GEXETAX              : # taxe directement dans tableau des taxes
      [M:SIW0]SFICCE(JL2-1)   = [F:XVFD]SECANAFRADIV : # V6
   Endif
Endif
Filter [XVFD]

#-- stockage frais fixe
Raz JL,JL1,JL2
Filter [XVFF] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ
For [XVFF]
   For JL=0 To dim([F:SPX]CODART)-1
      If [F:SPX]TYP(JL)=3 & [F:SPX]CODART(JL)=[F:XVFF]CODARTFRAFIX
         JL1=[F:SPX]SFINUM(JL)
         Break
      Endif
   Next
   Break                                : # un seul article frais fixe
Next
If JL1
   JL2=find(JL1,[M:SIW0]INVDTA)
   If JL2
      If [M:SIW0]INVDTACOD(JL2-1)=2
         [M:SIW0]INVDTAAMT(JL2-1)=arr([F:XVFF]MNTHTFRAFIX,[F:TCU]CURRND)
      Endif
      [M:SIW0]DTANOT(JL2-1)   = [F:XVFF]MNTHTFRAFIX
      [M:SIW0]DTAVAT(JL2-1)   = GEXETAX              : # taxe directement dans tableau des taxes
      [M:SIW0]SFICCE(JL2-1)   = [F:XVFF]SECANAFRAFIX : # V6
   Endif
Endif
Filter [XVFF]

Return


#------------------------------------------------------------------------
# Ecriture textes clobs X3 a partir des enregistrements textes de XILPVTXT
# Dans masque SIWRKEPV ( Bloc tableau NBLIG )
# - Une ligne par ligne du document Integrale
#   - TYPLIG : Code ligne Intégrale ( L=ligne article / T=texte )
#   - LIG    : No de ligne ( nolign )dans le masque X3 des lignes
#   - CODART : Article ligne Integrale ( format X3 ) pour recherche ligne X3
#------------------------------------------------------------------------
# Nota : Pas de recuperation des donnees integrale du Bloc-note
#------------------------------------------------------------------------

$SIWRKTXT
Local Integer JL,JL1,JL2

#-- stockage des TYPLIG "T"
Filter [XVTX] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ
If rowcount([XVTX])=0 : Filter [XVTX] : Gosub SIW1_TXT : Return : Endif      : # pas de texte dans le document Integrale
For [XVTX]
   # Bug 48153 : Ajout ctrl dimension du tableau des lignes dans SIWRKEPV
   If [F:XVTX]NUMLIG >= dim([M:SIW0]TYPLIG) Break Endif
   [M:SIW0]TYPLIG([F:XVTX]NUMLIG)=[F:XVTX]TYPLIG
Next
Filter [XVTX]

#-- stockage des TYPLIG "L"
Filter [XVLI] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ
For [XVLI]
   # Bug 48886 : Ajout ctrl dimension du tableau des lignes dans SIWRKEPV
   If [F:XVLI]NUMLIG >= dim([M:SIW0]TYPLIG) Break Endif
   [M:SIW0]TYPLIG([F:XVLI]NUMLIG)=[F:XVLI]TYPLIG
   [M:SIW0]CODART([F:XVLI]NUMLIG)=func SIXFONCTION.SI_COR("XIART",[F:XVLI]CODART,"","")
Next
Filter [XVLI]

#-- recherche correspondance ligne article Integrale --> X3 ( SQH2 / SOH4 / SIH4 )
For JL=1 To dim([M:SIW0]LIG)-1
   If [M:SIW0]CODART(JL)<>""
   Raz JL2
      Case SI_SUBPRG
        When "SI_SQH"
             JL2=find([M:SIW0]CODART(JL),[M:SQH2]ITMREF(JL1..[M:SQH2]NBLIG-1))
             If JL2
                [M:SIW0]LIG(JL)=JL1+JL2 : JL2=JL1  : # GROS DOUTE SI ARTICLE IDEM DANS X3 --> Mettre JL1=JL2 ( a tester )
             Endif
        When "SI_SOH"
             JL2=find([M:SIW0]CODART(JL),[M:SOH4]ITMREF(JL1..[M:SOH4]NBLIG-1))
             If JL2
                [M:SIW0]LIG(JL)=JL1+JL2 : JL2=JL1  : # GROS DOUTE SI ARTICLE IDEM DANS X3 --> Mettre JL1=JL2 ( a tester )
             Endif
        When "SI_SIH"
             JL2=find([M:SIW0]CODART(JL),[M:SIH4]ITMREF(JL1..[M:SIH4]NBLIG-1))
             If JL2
                [M:SIW0]LIG(JL)=JL1+JL2 : JL2=JL1  : # GROS DOUTE SI ARTICLE IDEM DANS X3 --> Mettre JL1=JL2 ( a tester )
             Endif
      Endcase
   Endif
Next JL

#-- constitution tableau des lignes un texte SI_CLOB pour appel fonction
#   association texte a une ligne article X3 ( si 0 = texte entete )
Raz JL,JL1,JL2
For JL=0 To dim([M:SIW0]LIG)-1
   If [M:SIW0]TYPLIG(JL)="L"
      Gosub SIW0_TXT
      JL1=[M:SIW0]LIG(JL)    : # no ligne article dans tableau X3
   Endif
   If [M:SIW0]TYPLIG(JL)="T"
      Raz [F:XVTX]
      Read [XVTX]IND0=[F:XVH0]NUMORD;[F:XVH0]LETRLQ;JL;"T"
      If dim(SI_CLOB)> JL2
         SI_CLOB(JL2)=[F:XVTX]TXT : JL2 +=1
      Endif
   Endif
Next JL
Gosub SIW0_TXT               : # ecriture eventuel dernier texte

Gosub SIW1_TXT               : # boucle de suppression des textes venant de l'article

Return

#------------------------------------------------------------------------
$SIW0_TXT
If sum(SI_CLOB)="" : Raz JL1,JL2 : Return : Endif

Case SI_SUBPRG
  When "SI_SQH"
       If JL1=0
          [F:SQH]SQHTEX1=func SIXFONCTION.SI_CLOB("SQH")         : # Dans F : M-->F deja fait
       Else
          [M:SQH2]SQDTEX(JL1-1)=func SIXFONCTION.SI_CLOB("SQD")
       Endif
  When "SI_SOH"
       If JL1=0
          [F:SOH]SOHTEX1=func SIXFONCTION.SI_CLOB("SOH")         : # Dans F : M-->F deja fait
       Else
          [M:SOH4]SOQTEX(JL1-1)=func SIXFONCTION.SI_CLOB("SOQ")
       Endif
  When "SI_SIH"
       If JL1=0
          [F:SIV]SIHTEX1=func SIXFONCTION.SI_CLOB("SIV")         : # Dans F : M-->F deja fait
       Else
          [M:SIH4]SIDTEX(JL1-1)=func SIXFONCTION.SI_CLOB("SID")
       Endif
  When Default
Endcase
Raz SI_CLOB : Raz JL2
Return


#---------------------------------------------------------------------------------------------
# Bug 48043 : Boucle sur les lignes pour ne pas récupérer les textes vente venant de l'article
#---------------------------------------------------------------------------------------------
$SIW1_TXT

Case SI_SUBPRG
  When "SI_SQH"
        For JL=0 To [M:SQH2]NBLIG-1
          If find(left$([M:SQH2]SQDTEX(JL),3),"ITS","ITU")
            Raz [M:SQH2]SQDTEX(JL)
          Endif
        Next JL
  When "SI_SOH"
        For JL=0 To [M:SOH4]NBLIG-1
          If find(left$([M:SOH4]SOQTEX(JL),3),"ITS","ITU")
            Raz [M:SOH4]SOQTEX(JL)
          Endif
        Next JL
  When "SI_SIH"
        For JL=0 To [M:SIH4]NBLIG-1
          If find(left$([M:SIH4]SIDTEX(JL),3),"ITS","ITU")
            Raz [M:SIH4]SIDTEX(JL)
          Endif
        Next JL
  When Default
Endcase
Return

#------------------------------------------------------------------------
# Stockage des donnees adresse dans enregistrement X3
#------------------------------------------------------------------------
$SIADD
SAUV_DEFAULT=dbgstr(2)

Case SI_SUBPRG
  When "SI_SQH"   Default File [SQH]
  When "SI_SOH"   Default File [SOH]
  When "SI_SIH"   Default File [SIV]
Endcase

#-- client commande
If dim([F]BPCNAM)>0     : [F]BPCNAM(0)   =[M:SIW0]NAM1(0)   : Endif
If dim([F]BPCNAM)>1     : [F]BPCNAM(1)   =[M:SIW0]NAM2(0)   : Endif
If dim([F]BPCADDLIG)>0  : [F]BPCADDLIG(0)=[M:SIW0]ADR1(0)   : Endif
If dim([F]BPCADDLIG)>1  : [F]BPCADDLIG(1)=[M:SIW0]ADR2(0)   : Endif
If dim([F]BPCADDLIG)>2  : [F]BPCADDLIG(2)=[M:SIW0]ADR3(0)   : Endif
If dim([F]BPCPOSCOD)>0  : [F]BPCPOSCOD   =[M:SIW0]POSCOD(0) : Endif
If dim([F]BPCCTY)>0     : [F]BPCCTY      =[M:SIW0]CTY(0)    : Endif
If dim([F]BPCSAT)>0     : [F]BPCSAT      =[M:SIW0]SAT(0)    : Endif
If dim([F]BPCCRY)>0     : [F]BPCCRY      =[M:SIW0]CRY(0)    : Endif
If dim([F]BPCCRYNAM)>0  : [F]BPCCRYNAM   =[M:SIW0]CRYNAM(0) : Endif
If dim([F]CNTNAM)>0 & [M:SIW0]RAZCNT(0)=2  : Raz [F]CNTNAM  : Endif
#-- client livre
If dim([F]BPDNAM)>0     : [F]BPDNAM(0)   =[M:SIW0]NAM1(1)   : Endif
If dim([F]BPDNAM)>1     : [F]BPDNAM(1)   =[M:SIW0]NAM2(1)   : Endif
If dim([F]BPDADDLIG)>0  : [F]BPDADDLIG(0)=[M:SIW0]ADR1(1)   : Endif
If dim([F]BPDADDLIG)>1  : [F]BPDADDLIG(1)=[M:SIW0]ADR2(1)   : Endif
If dim([F]BPDADDLIG)>2  : [F]BPDADDLIG(2)=[M:SIW0]ADR3(1)   : Endif
If dim([F]BPDPOSCOD)>0  : [F]BPDPOSCOD   =[M:SIW0]POSCOD(1) : Endif
If dim([F]BPDCTY)>0     : [F]BPDCTY      =[M:SIW0]CTY(1)    : Endif
If dim([F]BPDSAT)>0     : [F]BPDSAT      =[M:SIW0]SAT(1)    : Endif
If dim([F]BPDCRY)>0     : [F]BPDCRY      =[M:SIW0]CRY(1)    : Endif
If dim([F]BPDCRYNAM)>0  : [F]BPDCRYNAM   =[M:SIW0]CRYNAM(1) : Endif
If dim([F]CNDNAM)>0 & [M:SIW0]RAZCNT(1)=2  : Raz [F]CNDNAM  : Endif
#-- client facture
If dim([F]BPINAM)>0     : [F]BPINAM(0)   =[M:SIW0]NAM1(2)   : Endif
If dim([F]BPINAM)>1     : [F]BPINAM(1)   =[M:SIW0]NAM2(2)   : Endif
If dim([F]BPIADDLIG)>0  : [F]BPIADDLIG(0)=[M:SIW0]ADR1(2)   : Endif
If dim([F]BPIADDLIG)>1  : [F]BPIADDLIG(1)=[M:SIW0]ADR2(2)   : Endif
If dim([F]BPIADDLIG)>2  : [F]BPIADDLIG(2)=[M:SIW0]ADR3(2)   : Endif
If dim([F]BPIPOSCOD)>0  : [F]BPIPOSCOD   =[M:SIW0]POSCOD(2) : Endif
If dim([F]BPICTY)>0     : [F]BPICTY      =[M:SIW0]CTY(2)    : Endif
If dim([F]BPISAT)>0     : [F]BPISAT      =[M:SIW0]SAT(2)    : Endif
If dim([F]BPICRY)>0     : [F]BPICRY      =[M:SIW0]CRY(2)    : Endif
If dim([F]BPICRYNAM)>0  : [F]BPICRYNAM   =[M:SIW0]CRYNAM(2) : Endif
If dim([F]CNINAM)>0 & [M:SIW0]RAZCNT(2)=2  : Raz [F]CNINAM  : Endif

If SI_SUBPRG="SI_SIH"
   Default File [SIH]
   If dim([F]BPRNAM)>0     : [F]BPRNAM(0)   =[M:SIW0]NAM1(2)   : Endif
   If dim([F]BPRNAM)>1     : [F]BPRNAM(1)   =[M:SIW0]NAM2(2)   : Endif
   If dim([F]BPRADDLIG)>0  : [F]BPRADDLIG(0)=[M:SIW0]ADR1(2)   : Endif
   If dim([F]BPRADDLIG)>1  : [F]BPRADDLIG(1)=[M:SIW0]ADR2(2)   : Endif
   If dim([F]BPRADDLIG)>2  : [F]BPRADDLIG(2)=[M:SIW0]ADR3(2)   : Endif
   If dim([F]POSCOD)>0     : [F]POSCOD      =[M:SIW0]POSCOD(2) : Endif
   If dim([F]CTY)>0        : [F]CTY         =[M:SIW0]CTY(2)    : Endif
   If dim([F]SAT)>0        : [F]SAT         =[M:SIW0]SAT(2)    : Endif
   If dim([F]CRY)>0        : [F]CRY         =[M:SIW0]CRY(2)    : Endif
   If dim([F]CRYNAM)>0     : [F]CRYNAM      =[M:SIW0]CRYNAM(2) : Endif
   # V6 : Adresse Tiers payeur
   If dim([F]BPYNAM)>0     : [F]BPYNAM(0)   =[M:SIW0]NAM1(3)   : Endif
   If dim([F]BPYNAM)>1     : [F]BPYNAM(1)   =[M:SIW0]NAM2(3)   : Endif
   If dim([F]BPYADDLIG)>0  : [F]BPYADDLIG(0)=[M:SIW0]ADR1(3)   : Endif
   If dim([F]BPYADDLIG)>1  : [F]BPYADDLIG(1)=[M:SIW0]ADR2(3)   : Endif
   If dim([F]BPYADDLIG)>2  : [F]BPYADDLIG(2)=[M:SIW0]ADR3(3)   : Endif
   If dim([F]BPYPOSCOD)>0  : [F]BPYPOSCOD   =[M:SIW0]POSCOD(3) : Endif
   If dim([F]BPYCTY)>0     : [F]BPYCTY      =[M:SIW0]CTY(3)    : Endif
   If dim([F]BPYSAT)>0     : [F]BPYSAT      =[M:SIW0]SAT(3)    : Endif
   If dim([F]BPYCRY)>0     : [F]BPYCRY      =[M:SIW0]CRY(3)    : Endif
   If dim([F]BPYCRYNAM)>0  : [F]BPYCRYNAM   =[M:SIW0]CRYNAM(3) : Endif
Endif

Default File SAUV_DEFAULT

Return

#------------------------------------------------------------------------
# Stockage du no de document Integrale dans enregistrement X3
#------------------------------------------------------------------------
$SINUM
# Vu 14/03/08 : Ajout LET_RLQ_2
Case SI_SUBPRG
  When "SI_SQH"
       If dim([F:SQH]SINUM)>0 : [F:SQH]SINUM=[F:XVH0]TYPPIE+" "+[F:XVH0]NUMSER+[F:XVH0]NUMPIE+[F:XVH0]LETRLQ2 : Endif
  When "SI_SOH"
       If dim([F:SOH]SINUM)>0 : [F:SOH]SINUM=[F:XVH0]TYPPIE+[F:XVH0]CODSTT+[F:XVH0]NUMSER+[F:XVH0]NUMPIE+[F:XVH0]LETRLQ2 : Endif
  When "SI_SIH"
       If dim([F:SIH]SINUM)>0 : [F:SIH]SINUM=[F:XVH0]TYPPIE+" "+[F:XVH0]NUMSER+[F:XVH0]NUMPIE+[F:XVH0]LETRLQ2 : Endif
  When Default
Endcase

Return

#------------------------------------------------------------------------
# V6
# Récupération des sections analytiques des éléments de facturation
#------------------------------------------------------------------------
$SIWRKSFICCE
Local Integer WI, WJ

For WI=0 To dim([M:SIHV]XFNUM)-1
   WJ=find([M:SIHV]XFNUM(WI),[M:SIW0]INVDTA)
   If WJ>0 & [M:SIW0]SFICCE(WJ-1)<>""
       Call INICCE([M:SIW0]SFICCE(WJ-1),"[M:SIHV]SFICCE",WI) From SIXGAS
   Endif
Next

Return


#------------------------------------------------------------------------
# Barre deroulement
#------------------------------------------------------------------------
$SINUM_AFF
Local Char SINUM (30)
# Vu 14/03/08 : Ajout LET_RLQ_2
Case SI_SUBPRG
  When "SI_SQH"   SINUM=[F:XVH0]TYPPIE+" "+[F:XVH0]NUMSER+[F:XVH0]NUMPIE+[F:XVH0]LETRLQ2
  When "SI_SOH"   SINUM=[F:XVH0]TYPPIE+[F:XVH0]CODSTT+[F:XVH0]NUMSER+[F:XVH0]NUMPIE+[F:XVH0]LETRLQ2
  When "SI_SIH"   SINUM=[F:XVH0]TYPPIE+" "+[F:XVH0]NUMSER+[F:XVH0]NUMPIE+[F:XVH0]LETRLQ2
  When Default
Endcase

Return

