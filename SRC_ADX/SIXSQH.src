#<AdxTL>@(#)5.0.0.0 $Revision$
#########################################################################
#  SIXSQH: pour traitements de bascule Integrale --> X3                 #
#########################################################################
# Subprog SI_SQH                                                        #
#     Création des devis                                                #
#########################################################################

Gosub SI_CONTEXT From SIXFONCTION
#SI_SIMU=2
Local File SIPARX3  [SPX]
Local File SIPARVAC [SPV]
Read [SPX] First
Call EXEC From SIXSQH
End


#########################################################################
Subprog EXEC
Local Integer WOUV_TRACE, WERR
Local Char    WMSG

If GTRACE = ""
    Call OUVRE_TRACE("SI_SQH : "+SI_MES(52)) From LECFIC
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR
#----- Vérification cohérence nbre d'axes définis dans "Intégrale" et code activité ANA -----#
Call VARGLOBANA(WMSG,WERR) From SIXGAS
If WERR
    Call ECR_TRACE(WMSG,1) From GESECRAN
Else
    #---- Création enregistrements SQUOTE / SQUOTED ------#
    Call ECR_TIME("SI_SQH : "+mess(213,124,1)+" SQUOTE / SQUOTED") From DOSSUB
    Call SI_SQUOTE
Endif

$FIN_SQH
Onerrgo
If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End


$TRT_ERR
    Call ECR_TRACE( errp-"ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
    GIMPORT=0    # Bug 47776
Resume

#########################################################################

Subprog SI_SQUOTE

#--- pour appel GENSQH

Local Integer LCOD   : LCOD=1                : # 1=Création complète / 2=Garnissage uniquement des classes [M]
Local Char    LMAJ   : LMAJ="C"              : # C=Création
Local Integer LTEST  : LTEST=1               : # 1=Pas ecriture du fichier trace / 2=Ecriture de la trace
Local Char    LTRT   : LTRT="SIXSQH"         : # Traitement contenant les actions appelees par TRTVENDEVG
Local Char    LORINUM                        : # No du document origine ( utilisation facultative )
Local Char    LNEWNUM                        : # No du devis cree
Local Integer LERR   : LERR=0                : # Code retour erreur
Local Integer LNBSQH, LNBERR : LNBSQH=0 : LNBERR=0

If SI_SIMU=2 LTEST+=2 Endif

#--- Ouverture standard documents ventes
Gosub OPEN_STD

#--- Ouverture des tables Integrale
Gosub OPEN_INT

#--- Ouverture specifique des tables et masques de l'objet SQH
If !clalev([F:SQH])  : Local File =SI_DOSSIER+".SQUOTE"     [SQH] : Endif
If !clalev([F:SQD])  : Local File =SI_DOSSIER+".SQUOTED"    [SQD] : Endif
If !clalev([M:SQH0]) : Local Mask =SI_DOSSIER+".SQH0"       [SQH0] : Endif
If !clalev([M:SQH1]) : Local Mask =SI_DOSSIER+".SQH1"       [SQH1] : Endif
If !clalev([M:SQH2]) : Local Mask =SI_DOSSIER+".SQH2"       [SQH2] : Endif
If !clalev([M:SQH3]) : Local Mask =SI_DOSSIER+".SQH3"       [SQH3] : Endif

# Pour les articles gérés avec des nomenclatures, pour ne pas décliner la nomenclature
Global Integer G_LINTYP : G_LINTYP=1

# Numéro des colonnes à garnir avec les 2 remises intégrales
Global Integer GDISCRGNUM1, GDISCRGNUM2

SI_SUBPRG = "SI_SQH"
SI_TABLE = "XIEPV"

Local Char CRITERE (250)
CRITERE  = 'TYPPIE="DV"'               : # type de piece devis
CRITERE += '& FLGREP<2'                : # pas encore migre dans X3
CRITERE += '& FLGMAJ<>"S"'             : # non supprime
CRITERE += '& DATPIE>=[F:SPX]STRPER'   : # date >= date premier exercice

CRITDET='LIGSUP<>"S" & !find(NATART, "SD", "ST", "TD", "TP")'

Gosub SI_CRITSUP From SIXFONCTION    : # dans PE : variable SI_SUBPRG a tester car XIEPV commun (devis,cde,facture)

#--- Boucle de creation du fichier de travail ( un enr. par no ordre avec la + grande lettre reliquat )
For [XVH0] Where evalue(CRITERE)
&              & evalue(SI_CRITERE)

   Gosub SINUM_AFF From SIXSQH :  Call AFFBOITE(SINUM) From SUBSIM
   If GTRACE<>"" Call ECR_TRACE(mess(1,432,1)-SINUM,0) From GESECRAN Endif

   # -- alimenter les classes [F] nécessaires à l'entete ainsi que le masque SIWRKEPV
   Gosub SIWRKEPV

   # 01/04/08 : Il manquait l'évaluation de CRITDET
   # Bug 48749 : Ne pas prendre les lignes dont la qté = 0
#   Filter [XVLI] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ & evalue(CRITDET) &
#& sum([F:XVLI]QTELIV, [F:XVLI]QTECMD)<>0
   # Bug 48758 : On prend les lignes dont la qté = 0 uniquement pour les mettre dans la trace
   Filter [XVLI] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ & evalue(CRITDET)

   Call GENSQH (LCOD,LMAJ,LTEST,LTRT,LORINUM,LNEWNUM,LERR) From TRTVENDEVG
   If LERR=0 LNBSQH+=1 Else LNBERR+=1 Endif

Next

Call ECR_TIME("SIXSQH :"-SI_MES(171)-num$(LNBSQH)-SI_MES(174)-num$(LNBERR)) From DOSSUB

Kill G_LINTYP
Kill GDISCRGNUM1, GDISCRGNUM2

End

#------------------------------------------------------------------------
#--- Ouverture standard documents ventes ( commum SIXSQH SIXSOH SIXSIH )
#------------------------------------------------------------------------
$OPEN_STD
If !clalev([F:FCY])  : Local File =SI_DOSSIER+".FACILITY"   [FCY] : Endif  : # Sites
