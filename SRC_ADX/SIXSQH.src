If !clalev([F:REP])  : Local File =SI_DOSSIER+".SALESREP"   [REP] : Endif  : # Representants

If !clalev([F:ITM])  : Local File =SI_DOSSIER+".ITMMASTER"  [ITM] : Endif  : # Articles
If !clalev([F:ITS])  : Local File =SI_DOSSIER+".ITMSALES"   [ITS] : Endif  : # Articles ventes
If !clalev([F:ITU])  : Local File =SI_DOSSIER+".ITMBPC"     [ITU] : Endif  : # Articles clients
If !clalev([F:ITF])  : Local File =SI_DOSSIER+".ITMFACILIT" [ITF] : Endif  : # Articles sites
If !clalev([F:ITV])  : Local File =SI_DOSSIER+".ITMMVT"     [ITV] : Endif  : # Cumuls articles sites
If !clalev([F:ITG])  : Local File =SI_DOSSIER+".ITMCATEG"   [ITG] : Endif  : # Categrories articles
If !clalev([F:BOH])  : Local File =SI_DOSSIER+".BOM"        [BOH] : Endif  : # Nomenclature entete
If !clalev([F:BOD])  : Local File =SI_DOSSIER+".BOMD"       [BOD] : Endif  : # Nomenclature detail

If !clalev([F:SFI])  : Local File =SI_DOSSIER+".SFOOTINV"   [SFI] : Endif  : # Elements facturation vente
If !clalev([F:PRS])  : Local File =SI_DOSSIER+".PRICSTRUCT" [PRS] : Endif  : # Structure tarifs
If !clalev([F:SPK])  : Local File =SI_DOSSIER+".SPRICLINK"  [SPK] : Endif  : # Buffer recherche tarifs vente
If !clalev([F:SPL])  : Local File =SI_DOSSIER+".SPRICLIST"  [SPL] : Endif  : # Buffer recherche tarifs vente
If !clalev([F:PPL])  : Local File =SI_DOSSIER+".PPRICLIST"  [PPL] : Endif  : # Buffer recherche tarifs vente
If !clalev([F:SPR])  : Local File =SI_DOSSIER+".SPREASON"   [SPR] : Endif  : # Motifs tarifs vente
If !clalev([F:SLT])  : Local File =SI_DOSSIER+".SALTRS"     [SLT] : Endif  : # Transactions de saisie vente
If !clalev([F:SVV])  : Local File =SI_DOSSIER+".SVCRVAT"    [SVV] : Endif  : # Documents vente taxe
If !clalev([F:SVF])  : Local File =SI_DOSSIER+".SVCRFOOT"   [SVF] : Endif  : # Documents vente éléments
If !clalev([F:CAL])  : Local File =SI_DOSSIER+".CPTANALIN"  [CAL] : Endif  : # Lignes comptables analytiques

If !clalev([M:ADB1]) : Local Mask =SI_DOSSIER+".ADRBPC"     [ADB1] : Endif : # Fenetres adresse
If !clalev([M:ADB2]) : Local Mask =SI_DOSSIER+".ADRBPC"     [ADB2] : Endif : # -- idem
If !clalev([M:ADB3]) : Local Mask =SI_DOSSIER+".ADRBPC"     [ADB3] : Endif : # -- idem
If !clalev([M:ADI4]) : Local Mask =SI_DOSSIER+".ADRBPC"     [ADI4] : Endif : # -- idem
If !clalev([M:SIW0]) : Local Mask =SI_DOSSIER+".SIWRKEPV"   [SIW0] : Endif : # Fenetre stockage donnees entête
If !clalev([M:ACL])  : Local Mask =SI_DOSSIER+".ACLOB"      [ACL]  : Endif : # Gestion des textes clob

If !clalev([F:GTE])  : Local File =SI_DOSSIER+".GTYPACCENT" [GTE] : Endif
If !clalev([F:CAC])  : Local File =SI_DOSSIER+".GACCCODE"   [CAC] : Endif
If !clalev([F:GAC])  : Local File =SI_DOSSIER+".GACCOUNT"   [GAC] : Endif
If !clalev([F:CON])  : Local File =SI_DOSSIER+".CONTSERV"   [CON] : Endif
If !clalev([F:CCE])  : Local File =SI_DOSSIER+".CACCE"      [CCE] : Endif

Return

#------------------------------------------------------------------------
