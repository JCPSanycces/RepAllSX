If !clalev([F:ACV])  : Local File =SI_DOSSIER+".ACTIV"      [ACV]   Endif  : # Codes activites
If !clalev([F:TCC])  : Local File =SI_DOSSIER+".TEXCPT"     [TCC] : Endif  : # compteur des textes par table
