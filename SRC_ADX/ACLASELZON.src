#<AdxTL>@(#)1.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("ACLA",GBIDC1,GBIDC2) From GOBJET
End
###

Local Char PARAM(10)(1..2) , VALEUR(10)
PARAM(2) = "GACCENTRYD"
Call TRAITE_CHAR(VALEUR,PARAM,"","ACLASELZON","ACLASELZON",3,"") From GTRAITE
End
######################################################################################
######################################################################################
$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
 When "SORTIE"  : If SAVNOLI<> NOLI : mkstat = 4 : Endif
Endcase
Return
######################################################################################
$INIT
Local Integer NOLI,NOL,SAVNOLI
NOLI = nolign-1
SAVNOLI = NOLI
If clalev([F:ACLA])=0 : Local File ACLASSE  [ACLA] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
If clalev([F:ACV])=0  : Local File CODACT      [ACV]  : Endif

If filinfo(filpath("FIL","AVIEWTAB","fde",nomap),0)<0
& or filinfo(filpath("FIL","AVIEWFLD","fde",nomap),0)<0
& or filinfo(filpath("FIL","AVIEWIND","fde",nomap),0)<0
 Local File ATABLE [ATB]
 Local File ATABZON [ATZ]
 Local File ATABIND [ATI]
Else
 Local File AVIEWTAB [ATB]
 Local File AVIEWFLD [ATZ]
 Local File AVIEWIND [ATI]
Endif

Local Mask ACLASELZON [DIA]
Raz [M:DIA]
[M:DIA]TYPTAB  = val(PARAM(1))
If PARAM(2)<>""
 Read [ATB]CODFIC = PARAM(2)
 If !fstat
  [M:DIA]FICHIER = PARAM(2)
  Call AM_FICHIER([M:DIA]FICHIER)
 Endif
Endif
Return

######################################################################################
$EXEC
Local Integer OKFLD , NUMTEX, NUMTEXC
Local Char    TEXTE(80) , TEXTEC(80), CHAMP(GLONAVA)
Local Char CASEPRO(5) : CASEPRO = "AM"
Read [ATB]CODFIC = [M:DIA]FICHIER
Case [M:DIA]TYPTAB
 When 1 : Gosub STRUCTURE
Endcase
Return

######################################################################################
$STRUCTURE
For WI=0 To [M:DIA]NBLIG-1
 CHAMP = [M:DIA]CODZONE(WI)
 If [M:DIA]SELECT(WI)=2
  OKFLD  = !find(CHAMP,[M:ACLA6]FLDCLA(0..[M:ACLA6]NBRFLD-1))
  OKFLD *= [M:ACLA6]NBRFLD<dim([M:ACLA6]FLDCLA)
  If OKFLD
   Read [ATZ]CODZONE = [M:DIA]FICHIER;CHAMP

   NUMTEX=[F:ATZ]NOLONG
   Call TEXTE(NUMTEX,TEXTE) From OBJDIV
   If TEXTE = ""
    NUMTEX=[F:ATZ]NOCOURT
    Call TEXTE(NUMTEX,TEXTE) From OBJDIV
   Endif
   NUMTEXC = [F:ATZ]NOABREG
   Call TEXTE(NUMTEXC,TEXTEC) From OBJDIV
   If TEXTEC = ""
    NUMTEXC=[F:ATZ]NOCOURT
    Call TEXTE(NUMTEXC,TEXTEC) From OBJDIV
   Endif

   If OKFLD
    Read [ATZ]CODZONE = [M:DIA]FICHIER;CHAMP
    Read [ATY]CODTYP  = [F:ATZ]CODTYP
    Insa  NOLI,1,[M:ACLA6]NBRFLD [M:ACLA6]NBRFLD
    NOL = NOLI
    NOLI += 1
    [M:ACLA6]NBRFLD += 1
    [M:ACLA6]FLDCLA(NOL)  = [M:DIA]CODZONE(WI)
    [M:ACLA6]NUMFLD(NOL)  = NOLI*10
    [M:ACLA6]INTFLD(NOL)  = NUMTEX
    [M:ACLA6]ZINTFLD(NOL) = TEXTE
    [M:ACLA6]INTSHTFLD(NOL)  = NUMTEXC
    [M:ACLA6]ZINTSHTFLD(NOL) = TEXTEC
    [M:ACLA6]OBLIG(NOL)   = [F:ATZ]OBLIG
    [M:ACLA6]CODTYP(NOL)  = [F:ATZ]CODTYP
    If [ATY]CODCLA<>""
     Read [ACLA]ACLA0 = [ATY]CODCLA
     If !fstat & [ACLA]FLGSEARCH=2
      [M:ACLA6]FLDSEARCH(NOL)     = 2
     Endif
    Endif
    If [F:ATY]TYPTYP=1
     [M:ACLA6]NOLIB(NOL)   = [F:ATZ]NOLIB
    Endif
    If [F:ATY]FORTYP<>"" or [F:ATY]LNGTYP<>0 or find([F:ATY]TYPTYP,8)
     [M:ACLA6]LONG(NOL) = 0
    Else
     [M:ACLA6]LONG(NOL)    = [F:ATZ]LONG
    Endif
   [M:ACLA6]ACTFLD(NOL)  = [F:ATZ]CODACT
   Read [ACV]CODACT =  [ATZ]CODACT
   If !fstat
    If [ACV]TYP=2 :  [M:ACLA6]ACTFLD(NOL)="" : Endif
   Endif
    [M:ACLA6]LNKCLA(NOL)  = ""
    [M:ACLA6]FLDCUR = [M:ACLA6]FLDCLA(NOL)
    [M:ACLA6]CODTYPCUR = [M:ACLA6]CODTYP(NOL)
    Gosub DEL_PARAM_FLDCLA From SUBACLA2
    [M:ACLA6]FLDCUR = [M:ACLA6]FLDCLA(NOL)
    Call L_LOAD_PARAM_ATY(nomap, [M:ACLA0]CODCLA, [F:ATY]CODTYP, [M:ACLA6]FLDCUR, 1, 1) From SUBACLA2
    GMODIFPAR=0
    If [ATY]CODCLA<>""
     Gosub L_LOAD_KEY From SUBACLA2
     Local Integer M
     For I=0 To [M:ACLA8]WNBRPARALL-1
#94793
#      If [M:ACLA8]WTYPKEY(I)=2
      If [M:ACLA8]WTYPKEY(I)=2 &  [M:ACLA8]WFLDCLA(I)=[M:ACLA6]FLDCLA(NOL)
       Raz M
       For J=0 To [M:ACLA8]WNBRPARALL-1
#94793
#        If  [M:ACLA8]WFLDCLA(I) =  [M:ACLA8]WFLDCLA(J)
        If  [M:ACLA8]WFLDCLA(I) =  [M:ACLA8]WFLDCLA(J) & [M:ACLA8]WTYPKEY(J)=2
         M += 1
        Endif
       Next
       If M=1
         [M:ACLA8]WVALEUR(I) = [M:ACLA8]WFLDCLA(I)
       Endif
      Endif
     Next
    Endif
    # style
    If find([M:ACLA6]FLDCLA(NOL),[M:ACLA8]WFLDCLA(0..[M:ACLA8]WNBRPARALL-1))
     Chgstl [ACLA6]CODTYP(NOL) With "AMKACT"
    Else
     Chgstl [ACLA6]CODTYP(NOL) With ""
    Endif
   Endif
  Endif
 Endif
Next

Affzo [ACLA6]
For I=0 To [ACLA6]NBRFLD-1
 If find([M:ACLA6]FLDCLA(I),[M:ACLA8]WFLDCLA(0..[M:ACLA8]WNBRPARALL-1))
  Chgstl [ACLA6]CODTYP(I) With "AMKACT"
 Else
  Chgstl [ACLA6]CODTYP(I) With ""
 Endif
Next
Return

######################################################################################
## Etiquettes Ecrans
######################################################################################
Subprog IB_NBLIG
GBOUT2 = mess(202,124,1) : # Oui à tout le reste
GBOUT3 = mess(203,124,1) : # Non à tout le reste
End

Subprog B2_NBLIG
Local Integer I
For I=nolign To [M]NBLIG
 [M]SELECT(I-1) = 2
Next I
Affzo 10
End

Subprog B3_NBLIG
Local Integer I
For I=nolign To [M]NBLIG
 [M]SELECT(I-1) = 1
Next I
Affzo 10
End

Subprog IB_FICHIER
End

Subprog AM_FICHIER(VALEUR)
Variable Char VALEUR()
Local Integer OK
Effzo 10
nolign = 0
For [ATZ]NUMLIG Where CODFIC=VALEUR
 OK = 1
 If !find([F:ATZ]CODZONE,[M:ACLA6]FLDCLA(0..[M:ACLA6]NBRFLD-1))
  nolign += 1
  [M] = [F:ATZ]
  Call TEXTE([F:ATZ]NOCOURT,[M]INTITCOURT(nolign-1)) From OBJDIV
  [M]SELECT(nolign-1) = 2
 Endif
Next
[M]NBLIG = nolign
Affzo 10
End


######################################################################################
