#<AdxTL>@(#)10.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Génération du fichier folders.XML 
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Validation folders.xml file") From LECFIC
Call PATCH(GDOSX3)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub GENFOLDER
End

#-------------------#
$GENFOLDER

Onerrgo ER
Local Char APPLI(30) , SYMBOLE(30)

If clalev([F:ADS])>0
 APPLI = [F:ADS]DOSSIER
Else
 Local File ADOSSIER [ADS]
 APPLI = ""
Endif

SYMBOLE = "VALLANG"
Lock =SYMBOLE From =GDOSX3 With lockwait=0
If fstat=0
  Call ECR_TRACE(mess(12,125,1)-"folders.xml",0) From GESECRAN : # Création du fichier
  Call CREFOLDERS From VALCSTWEB
  Unlock =SYMBOLE From =GDOSX3
Endif
If APPLI<>""
 Read [ADS]DOSSIER = APPLI
Endif

Onerrgo

Return

$ER
Resume

