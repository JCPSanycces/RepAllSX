#<AdxTL>@(#)10.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Rajout des champs timestamp et uid dans toutes les tables
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("Add supervisor field on file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2] Where DOSSIER=GDOSX3
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub ADDFLD
End

#-------------------#
$ADDFLD
If dim(GINFO)<=0
Global Integer GINFO
GINFO = 0
Endif
If dim(GCOEFTAB)<=0
Global Decimal GCOEFTAB
GCOEFTAB = 0.5
Endif

Local Integer I , UPD , TIM , ARRET , CD , CT , UD , UT , ID , CS , US , ER
Local Integer NEWLIG , MAXFIL , NBTAB, NEWATZ
Local Char    TABTAB(GLONATB)(1..3000) , DAT(30)
Local Char    OTRP(GLONADC) , OTRL(GLONASU)

# New fields
#119254 need to read texts on main folder in migration because texts have not been copied
Local File =GDOSX3+".ATYPE"  [ATY]
Gosub SET_FLDSYS From SUBATB
Close Local File [ATY]

If DOSSIER=nomap
 Local File ATABLE [ATB] , ATABZON [ATZ] , ATYPE [ATY]
Else
 Local File =DOSSIER+".ATABLE" [ATB] , =DOSSIER+".ATABZON" [ATZ] , =DOSSIER+".ATYPE"  [ATY]
Endif

# Tables non concernées

Gosub SET_TABSYS From SUBATB

# Tables superviseur

Gosub SET_TABDIC

# Ajout des nouveaux champs

NBTAB = 0
Trbegin [ATB]
 #93128
 #For [ATB]CODFIC Where find(CODFIC,TABSYS(1..NBSYS))=0
 For [ATB]CODFIC Where find(CODFIC,TABSYS(1..NBSYS))=0 & FLG130<>2
  Call AFF_BOITE([F:ATB]CODFIC,NBTAB,ARRET) From GESECRAN
  NEWATZ=0
  #107271
  If func DOSVUE.ISVIEW(DOSSIER,[F:ATB]CODFIC)=0
   NEWLIG = 0
   Filter [ATZ] Where CODFIC=[F:ATB]CODFIC
   For I=1 To dim(FLDSYS)
    If FLDSYS(I)<>""
     Read [ATZ]CODZONE=[F:ATB]CODFIC;FLDSYS(I)
     If fstat
      If NEWLIG=0
       If [F:ATB]TYPFIC<>3 or (GADONIX=2 & DOSSIER=GDOSX3)
        NBTAB += 1
        TABTAB(NBTAB) = [F:ATB]CODFIC
       Endif
       Read [ATZ]NUMLIG Last
       NEWLIG = [F:ATZ]NUMLIG+1
      Else
       NEWLIG += 1
      Endif
      Raz [F:ATZ]
      [F:ATZ]CODFIC  = [F:ATB]CODFIC
      [F:ATZ]CODZONE = FLDSYS(I)
      [F:ATZ]CODTYP  = TYPFLD(I)
      [F:ATZ]NUMLIG  = NEWLIG
      [F:ATZ]DIME    = 1
      [F:ATZ]NOABREG = INTFLD(I)
      [F:ATZ]NOCOURT = INTFLD(I)
      [F:ATZ]NOLONG  = INTFLD(I)
      If TYPFLD(I)="AUS"
       [F:ATZ]VERIF  = 1
      Endif
      [F:ATZ]ANNUL   = ANUFLD(I)
      [F:ATZ]LIEN    = LNKFLD(I)
      [F:ATZ]OBLIG   = 1
      [F:ATZ]ZERO    = 1
      Write [ATZ]
      If fstat
       Call ERREUR("ATABZON"-[F:ATZ]CODFIC-[F:ATZ]CODZONE,1) From DOSDIC
      Endif
      NEWATZ=1
     Endif
    Endif
   Next I
   Filter [ATZ]
  Endif
  If NEWATZ
   [F:ATB]UPDFLG=1 : #110678
   Rewrite [ATB]
   If fstat
    Call ERREUR("ATABLE"-[F:ATB]CODFIC,2) From DOSDIC
   Endif
  Endif
 Next ATB
Commit

MAXFIL = NBTAB

Close Local File

Call OUVRE_BOITE("valfil"-DOSSIER,0) From GESECRAN
Call SET_BOITE("",MAXFIL) From GESECRAN

NBTAB = 0

# Validation des tables non superviseur

Gosub OUVTAB

For I=1 To MAXFIL
 If find(TABTAB(I),TABDIC(1..NBDIC))=0
  TABLE = TABTAB(I)
  NBTAB += 1
  Call AFF_BOITE(TABLE,NBTAB,ARRET) From GESECRAN
  Gosub VALFIC
 Endif
Next I

Close Local File

# Validation des tables superviseur

For I=1 To MAXFIL
 If find(TABTAB(I),TABDIC(1..NBDIC))<>0
  TABLE = TABTAB(I)
  NBTAB += 1
  Gosub OUVTAB
  Call AFF_BOITE(TABLE,NBTAB,ARRET) From GESECRAN
  Gosub VALFIC
  Close Local File
 Endif
Next I

Call FERME_BOITE From GESECRAN

Return

#----------------#
$ER
ER = errn
Resume

#----------------#
$SET_TABDIC
Local Char    TABDIC(GLONATB)(1..20)
Local Integer NBDIC
NBDIC = 0
NBDIC += 1 : TABDIC(NBDIC) = "ATABLE"
NBDIC += 1 : TABDIC(NBDIC) = "ATABZON"
NBDIC += 1 : TABDIC(NBDIC) = "ATABIND"
NBDIC += 1 : TABDIC(NBDIC) = "ATEXTE"
NBDIC += 1 : TABDIC(NBDIC) = "ATEXTRA"
NBDIC += 1 : TABDIC(NBDIC) = "ATYPE"
NBDIC += 1 : TABDIC(NBDIC) = "ACTIV"
NBDIC += 1 : TABDIC(NBDIC) = "AINDEX"
NBDIC += 1 : TABDIC(NBDIC) = "ADOSSIER"
NBDIC += 1 : TABDIC(NBDIC) = "ADOSDIM"
NBDIC += 1 : TABDIC(NBDIC) = "ADOSACT"
NBDIC += 1 : TABDIC(NBDIC) = "ADOSSOL"
Return

#------------------------------------------------------------------------#
$VALFIC
If DOSSIER=nomap
 Lock ="ATB"+TABLE With lockwait=0
Else
 Lock ="ATB"+TABLE From =DOSSIER With lockwait=0
Endif
If fstat=0
 Call MAJTABDOS(DOSSIER,TABLE,0) From DOSTAB
 #Call MAJFIC(TABLE,DOSSIER,0) From VALDIC
 #Call MAJTRIG(TABLE,DOSSIER) From VALDIC
 If DOSSIER=nomap
  Unlock ="ATB"+TABLE With lockwait=0
 Else
  Unlock ="ATB"+TABLE From =DOSSIER With lockwait=0
 Endif
Else
 Call ECR_TRACE(TABLE-":"-mess(10,100,1),1) From GESECRAN : # Modification en cours sur un autre poste
Endif
Return

#----------------------#
$OUVTAB
If DOSSIER="" or DOSSIER=nomap
 Local File ACTIV   [ACV]
 Local File ATEXTE  [ATX]
 Local File ATEXTRA [AXX]

  Local File ATABLE   [ATB]
  Local File ATABLE   [AT2]
  Local File ATABZON  [ATZ]
  Local File ATABIND  [ATI]
  Local File AMSKPAR  [AMP]
  Local File AINDEX   [ANX]
  Local File ATYPE    [ATY]
  If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
  If [F:ADS]DOSSIER<>[L]DOSSIER
   Read [ADS]DOSSIER = [L]DOSSIER
  Endif

Else
 Local File =DOSSIER+".ACTIV"   [ACV]
 Local File =DOSSIER+".ATEXTE"  [ATX]
 Local File =DOSSIER+".ATEXTRA" [AXX]

  Local File =DOSSIER+".ATABLE"   [ATB]
  Local File =DOSSIER+".ATABLE"   [AT2]
  Local File =DOSSIER+".ATABZON"  [ATZ]
  Local File =DOSSIER+".ATABIND"  [ATI]
  Local File =DOSSIER+".AMSKPAR"  [AMP]
  Local File =DOSSIER+".AINDEX"   [ANX]
  Local File =DOSSIER+".ATYPE"    [ATY]
  Local Char     APPLI(GDIMFIC), MACHINE(GDIMFIC) , VOLUME(GDIMFIC)
  Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
  Call VOLUME(MACHINE,APPLI,VOLUME) From ORDSYS
  APPLI = toupper(APPLI)
  # Issue 83164 - 2012-06-28 by VPO : pb ouverture ADOSSIER
  If pat(DOSSIER,"*@*")
    Local File =DOSSIER+".ADOSSIER" [ADS]
  Else
    If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
  Endif
  If [F:ADS]DOSSIER<>[L]APPLI
   Read [ADS]DOSSIER = [L]APPLI
  Endif

Endif
Return

#------------------------------------------------#
# Conversion date$ et time -> timestamp
#------------------------------------------------#

Funprog CNVTIM(DAT,TIM)
Value Date    DAT
Value Integer TIM
Local Integer J
Local Decimal T
If DAT<[01/01/1970]
 End ""
Endif
J = DAT-[01/01/1970]
T = J*24*3600*1000
If TIM>0 & TIM<24*3600
 T += TIM*1000
Endif
End num$(T)

