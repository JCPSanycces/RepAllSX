#<AdxTL>@(#)4.0.0.0 $Revision$
#######################################################################################################################
#  Affichage XML d'un ciblage fonctionnel                                        Module CRM          9 Septembre 2004 #
#######################################################################################################################
##########################################################
# Détail des paramètres
# PARAM(1) : Code ciblage
# PARAM(2) : Support de présentation
# PARAM(3) : Calcul du ciblage. Vide = Non. Rempli = Oui
# PARAM(4) : Feuille XSLT.
# PARAM(5) : Contexte d'exécution.
#########################################################
#######################################################################################################################
$ACTION
  Case ACTION
    When "INIT"        : Gosub INITMGG
    When "EXEC"        : Gosub EXECMGG
    When Default
  Endcase
Return

#######################################################################################################################
$INITMGG
Local Char SZXSLTSHEET(type(PARAM)-10)

  SZXSLTSHEET = PARAM(4)
  If PARAM(1) = "" Then
    #Aucun ciblage n'est précisé. Action abandonnée.
    GMESSAGE = mess(146,177,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  If !clalev([F:MQR]) : Local File MKGQUR [MQR] : Endif
  If !clalev([F:TGP]) : Local File TGRSSP [TGP] : Endif
  Read [MQR]MQR0=PARAM(1)
  If fstat Then
    #Le ciblage indiqué est incorrect. Action abandonnée.
    GMESSAGE = mess(147,177,1)
    GERR = 1
    FIN = 1
    Return
  Else
    If PARAM(2) = "" Then
      If [F:MQR]TGPNUM = "" Then
        #Aucun support de présentation n'a pu être obtenu. Action abandonnée.
        GMESSAGE = mess(148,177,1)
        GERR = 1
        FIN = 1
        Return
      Else
        PARAM(2) = [F:MQR]TGPNUM
      Endif
    Else
      Read [TGP]TGP0=PARAM(2)
      If fstat Then
        #Le support de présentation indiqué est incorrect. Action abandonnée.
        GMESSAGE = mess(150,177,1)
        GERR = 1
        FIN = 1
        Return
      Endif
    Endif
  Endif
  Gosub CHECKXSL From TRTMGGXSL1
  If FIN = 1 Then
    Return
  Endif
Return

#######################################################################################################################
#Vérifie si la feuille XSL existe dans le répertoire REPORT client.
#####################################################
$CHECKXSL
  If SZXSLTSHEET <> "" Then
    Local Integer IXSLEXIST
    Local Char SZXSLTPLNAME(100)
    Local Integer ILENPARAM4
    Local Char SZTPLEND(30)

    ILENPARAM4 = len(SZXSLTSHEET)-4
    SZTPLEND = right$(SZXSLTSHEET, len(SZXSLTSHEET)-3)
    If SZTPLEND = ".xsl" Then
      SZXSLTPLNAME = left$(SZXSLTSHEET, ILENPARAM4)
    Else
      SZXSLTPLNAME = SZXSLTSHEET
    Endif
    IXSLEXIST = 1
    Call CTLFILE("xsl", SZXSLTPLNAME, IXSLEXIST) From TRTMAY5
    If IXSLEXIST = 0 Then
      #La feuille de transformation XSLT n'existe pas dans le répertoire REPORT de la machine cliente. Action abandonnée.
      GMESSAGE = mess(151,177,1)
      GERR = 1
      FIN = 1
      Return
    Endif
  Endif
Return

#######################################################################################################################
$EXECMGG
Local Char RETOUR(1)
Local Char SZFULLFILENAME(250)
Local Char SZFILENAME(250)
Local Integer ICHAPTER
Local Integer IERRINF

  IERRINF = 0
  ICHAPTER = 0
  If PARAM(3) <> "" Then
    Call RUNMGG(PARAM(1)) From CRMUTIL140
    If GERR Then
      Return
    Endif
  Endif
  If PARAM(4) = "" Then
    Call MGGINXML(PARAM(1), PARAM(2), 1, "STD", PARAM(5), SZFULLFILENAME, SZFILENAME, ICHAPTER, IERRINF) From SUBMGGXML
  Else
    Call MGGINXML(PARAM(1), PARAM(2), 1, PARAM(4), PARAM(5), SZFULLFILENAME, SZFILENAME, ICHAPTER, IERRINF) From SUBMGGXML
  Endif
  If IERRINF = 0 Then
    Callui RETOUR = "" With "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) + "Report",
&                           "UILocalFile="+ chr$(1) + SZFILENAME
  Endif
Return
