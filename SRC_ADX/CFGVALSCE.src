#<AdxTL>@(#)4.0.0.0 $Revision$
# Sous programme de revalidation automatique inter release des scénarios
############################################################
Subprog PATCH(LMAP)
Value Char LMAP
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=LMAP
If fstat = 0
  GMODU(8) = [F:ADS]MODULE(7)
  If LMAP <> "X3"
    GFONCTION = "" 
    GFONC1    = "FUNCFGUTI" 
    Global Char  S_DOSSIER   : S_DOSSIER = LMAP
    Local Char   W_APPLI     : W_APPLI   = LMAP
    Local Integer IVALREL
    Local File    =W_APPLI+".ACTIV" [ACV]
    Read [ACV]CODACT="CFG"
    If fstat = 0 & [F:ACV]FLACT = 2
      Local Mask =W_APPLI+".CFGUTI" [CFGU]
      Gosub DEBUT_CFGUTI From SUBCFGU
      [M:CFGU]TLPFLG = 1
      [M:CFGU]SELFLG = 1
      [M:CFGU]SHAFLG = 1
      [M:CFGU]SCEFLG = 2
      [M:CFGU]MSTFLG = 1
      [M:CFGU]CFMFLG = 1
      Gosub OK_CFGUTI From SUBCFGU
      Close Local Mask [CFGU]
    Endif
    Close Local File [ACV]
  Endif
Endif
End

