######################################################################################
## Etiquette ajoutée par le superviseur (écran ADRBPC) 21/10/2010 16:20:21 (CPO)
######################################################################################
#FQ 64695
Subprog C_CNTNAM(VALEUR)
Variable Char    VALEUR()

If VALEUR<>"" and !GWEBSERV :# !GWEBSERV car il parait que le [M]ADBBPR n'est pas chargé
  If clalev([F:CNT])<= 0 : Local File CONTACT [CNT] : Endif
  # Bug 67868 : En import, la classe est ADB1 ADB2 ou ADB3 mais pas ADC
  #Read [CNT]CNT0=1;[M:ADC]ADBBPR;VALEUR
  Read [CNT]CNT0=1;[M]ADBBPR;VALEUR
  If fstat GMESSAGE=mess(153,7774,1)+mess(372,183,1) : mkstat=2 : Endif
Endif

End
#fin FQ 64695

