######################################################################################
## Etiquette ajoutée par le superviseur (écran ADRBPC) 02/09/2008 15:41:32 (ACA)
######################################################################################
Subprog AS_BPAADD(VALEUR)
Variable Char    VALEUR()
# Bug 57682 : Pas de saisie du code adresse en Web Service
If GWEBSERV mkstat=2 Endif
End

Subprog C_BPAADD(VALEUR)
Variable Char    VALEUR()

If clalev([F:BPA]) = 0 Local File BPADDRESS  [BPA] : Endif
# Bug 57682 : Pas de saisie du code adresse en Web Service
#             (Dans ce contexte [M]ADRBPR n'est pas chargé)
If !GWEBSERV
    Read [BPA] BPA0=1;[M]ADBBPR;VALEUR
    If fstat Raz [F:BPA] : mkstat=1 : Endif
Endif

End

Subprog AM_BPAADD(VALEUR)
Variable Char    VALEUR()
If clalev([F:BPA]) = 0 Local File BPADDRESS  [BPA] : Endif
If clalev([F:BPD]) = 0 Local File BPDLVCUST  [BPD] : Endif
If clalev([F:TCY]) = 0 Local File TABCOUNTRY [TCY] : Endif
# Bug 57682 : Pas de saisie du code adresse en Web Service
If !GWEBSERV
    # Bug 67868 : En import, la classe est ADB1 ADB2 ou ADB3 mais pas ADC
    # Classe F positionnée dans C_BPAADD
    #[M:ADC]BPAADD      =[F:BPA]BPAADD
    #[M:ADC]BPAADDLIG(0)=[F:BPA]BPAADDLIG(0)
    #[M:ADC]BPAADDLIG(1)=[F:BPA]BPAADDLIG(1)
    #[M:ADC]BPAADDLIG(2)=[F:BPA]BPAADDLIG(2)
    #[M:ADC]CRY         =[F:BPA]CRY
    #[M:ADC]CRYNAM      =[F:BPA]CRYNAM
    #[M:ADC]SAT         =[F:BPA]SAT
    #[M:ADC]POSCOD      =[F:BPA]POSCOD
    #[M:ADC]CTY         =[F:BPA]CTY
    #[M:ADC]ADBFLG      =1
    [M]BPAADD      =[F:BPA]BPAADD
    [M]BPAADDLIG(0)=[F:BPA]BPAADDLIG(0)
    [M]BPAADDLIG(1)=[F:BPA]BPAADDLIG(1)
    [M]BPAADDLIG(2)=[F:BPA]BPAADDLIG(2)
    [M]CRY         =[F:BPA]CRY
    [M]CRYNAM      =[F:BPA]CRYNAM
    [M]SAT         =[F:BPA]SAT
    [M]POSCOD      =[F:BPA]POSCOD
    [M]CTY         =[F:BPA]CTY
    [M]ADBFLG      =1
    # Bug 67868
    If func AFNC.ACTIV("DEB") & dim([M]EECNUMX) > 0
      Read [F:BPD]BPD0=[F:BPA]BPANUM;VALEUR
      If !fstat
        [M]EECNUMX     =[F:BPD]EECNUM
      Endif
      If [M]EECNUMX = ""
        Read [F:TCY]TCY0=[M]CRY
        If !fstat & [F:TCY]EECFLG = 2
          If dim([F:BPR]EECNUM) > 0 : [M]EECNUMX = [F:BPR]EECNUM : Endif
        Endif
      Endif
    Endif
    Affzo [M:ADC]
Endif
End


