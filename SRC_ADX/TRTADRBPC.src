## Etiquette ajoutée par le superviseur 08/12/2003 09:09:11 (LD)
##########################################################################
Subprog C_CRY(VALEUR)
Variable Char    VALEUR()
#If dim([M]SAT)>0
# If [F:TCY]ETAT<>2
#  Effzo SAT
#  Grizo SAT
# Else
#  Actzo SAT
# Endif
#Endif
If VALEUR<>""
 Diszo CRYNAM
Else
 Actzo CRYNAM
Endif
End
##########################################################################
## Etiquette ajoutée par le superviseur 01/07/2003 08:17:42 (JL)
##########################################################################
Subprog AM_CRY(VALEUR)
# Après modification du code pays --> Chargement et affichage nom du pays
Variable Char    VALEUR()

Call LECTEXTRA([M]CRYNAM,"TABCOUNTRY","CRYDES",[F:TCY]CRY,"") From ATEXTRA
Affzo CRYNAM
If dim([M]SAT)>0 and [M]CRY<>VALEUR : Raz [M]SAT : Endif :#CPO 105977 Changing the country implies deleting the actual SAT division

If !GWEBSERV Then  # FGR 04/05/2015 : X3SUIVI108062 : ne pas faire en WS
# If func AFNC.ACTIV("LTA") and GLOCUSATAX and func TRTADRLIB.CHKADR_CRY(VALEUR)  #LTA.sn   # 106867.o
  If func AFNC.ACTIV("LTA") and func TRTTAXSST.CHK_SSTTAXACT(GSOCIETE) and func TRTADRLIB.CHKADR_CRY(VALEUR)  #LTA.sn   # 106867.n
    Chgfmt [M:ADC]VALADR  With "K:10X"
    Affzo [M:ADC]VALADR # Need to execute the init action so the icon displays
    Chgfmt [M:ADC]ADRVAL  With "LA:1"
  Else
    Chgfmt [M:ADC]VALADR With "-K:10X"
    Chgfmt [M:ADC]ADRVAL With "-LA:1"
  Endif #LTA.en
Endif

# X3-84945:Review mandatory mentions / Sales invoices (French law) X3-85350 (LCC 22/05/18)
If GFONCTION="GESSIH" #X3-102030: This is only needed for invoices management (LCC 24/07/18)
 If dim([M:ADC]FORMAT)>0
  If [F:TCY]CRTFMTFLG=2
   [M:ADC]CRN=[M:SIH0]CRN
   [M:ADC]FORMAT="K:"+[F:TCY]CRTFMT
   If !clalev([F:BPC]): Local File BPCUSTOMER: Endif
   If [F:BPC]BPCNUM<>[M:SIH0]BPCINV
     Read [F:BPC]BPC0=[M:SIH0]BPCINV
     If fstat: Raz [F:BPC]: Endif
   Endif
   If [F:BPC]BPCTYP<>2: [M:ADC]FORMAT="KP:"+[F:TCY]CRTFMT: Endif
  Else
   [M:ADC]FORMAT="-K:20X"
   [M:ADC]CRN=[M:SIH0]CRN
  Endif
  [M:ADC]CRY=[F:TCY]CRY:If !GWEBSERV: Affzo [M:ADC]CRN: Endif
 Endif
Endif #X3-102030: This is only needed for invoices management (LCC 24/07/18)
# End X3-84945:Review mandatory mentions / Sales invoices (French law) X3-85350 (LCC 22/05/18)
End
##########################################################################
Subprog AS_SAT(VALEUR)
Variable Char    VALEUR()
Call LECTURE("TCY",[M]CRY,"") From CONTOBJ
#If [F:TCY]ETAT<>2
# mkstat = 1
#Endif
End
