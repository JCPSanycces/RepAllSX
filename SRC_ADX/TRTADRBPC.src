Subprog IB_POSCOD
# Si on est en gestion facture validee, il faut supprimer la selection
If GFONCTION="GESSIH"
    If dim([M:SIH1]INVSTA)>0 & [M:SIH1]INVSTA=3 : Raz GBOUTS : Endif
Endif
End

