#Fq 78930
Subprog AV_SAT(VALEUR)
Variable Char    VALEUR()
 If GFMT<>"" Then
  Chgfmt [M:ADC]SAT With "K:"+GFMT
 Else
  Chgfmt [M:ADC]SAT With "-K:1X"
 Endif
End
