Funprog CAL_DAT_ISNOTNULL( PDAT )
Value Date     PDAT
Local Shortint RTRN
  RTRN = 0
  If ( PDAT <> [0/0/0] ) Then : RTRN = 1  : Endif
End RTRN
Funprog CAL_DAT_ISNULL( PDAT )
Value Date      PDAT
Local Shortint  RTRN
  RTRN = 0
  If ( PDAT = [0/0/0] ) Then : RTRN = 1  : Endif
End RTRN
Funprog CAL_DAT_INSIDE( PDAT, PDEB, PFIN, PBORNES )
Value    Date     PDAT, PDEB, PFIN
Value    Char     PBORNES
Local    Shortint RTRN : RTRN = 0
  If ( PDAT <> [0/0/0] and PDEB <> [0/0/0]  and PFIN <> [0/0/0] ) Then
    If ( PBORNES = "I" and PDAT >= PDEB and PDAT <= PFIN ) Then : RTRN = 1 : Endif
    If ( PBORNES = "E" and PDAT >  PDEB and PDAT <  PFIN ) Then : RTRN = 1 : Endif
  Endif
End RTRN
Funprog CAL_DAT_BISS( PANN )
Value Integer    PANN
Local Shortint   RTRN
  RTRN = gdat$(31,12,PANN)-gdat$(01,01,PANN)+1
End RTRN
Funprog CAL_DAT_DERN( PDAT, PTYP )
Value Date    PDAT
Value Char    PTYP
Local Date    RTRN
Local Decimal WRNG
  RTRN = [0/0/0]
  If ( PDAT <> [0/0/0] ) Then
    Case PTYP
      When "Y"     : RTRN = gdat$(31,12,year(PDAT))
      When "M"     : RTRN = eomonth(PDAT)
      When "Q"
        If ( day(PDAT) >= 01 and day(PDAT) <= 15 ) Then
          RTRN = gdat$(15,month(PDAT),year(PDAT))
        Else
          RTRN = eomonth(PDAT)
        Endif
      When "T"
        If    (PDAT > gdat$(15,11,year(PDAT))) Then
          RTRN = gdat$(31,12,year(PDAT))
        Elsif (PDAT > gdat$(30,09,year(PDAT))) Then
          RTRN = gdat$(15,11,year(PDAT))
        Elsif (PDAT > gdat$(15,08,year(PDAT))) Then
          RTRN = gdat$(30,09,year(PDAT))
        Elsif (PDAT > gdat$(30,06,year(PDAT))) Then
          RTRN = gdat$(15,08,year(PDAT))
        Elsif (PDAT > gdat$(15,05,year(PDAT))) Then
          RTRN = gdat$(30,06,year(PDAT))
        Elsif (PDAT > gdat$(31,03,year(PDAT))) Then
          RTRN = gdat$(15,05,year(PDAT))
        Elsif (PDAT > gdat$(15,02,year(PDAT))) Then
          RTRN = gdat$(31,03,year(PDAT))
        Else
          RTRN = gdat$(15,02,year(PDAT))
        Endif
      When "W"
        Local Integer WINCR : WFIN_SEM
        If ([M:DIV2]WEESTRDAY = 0 ) Then : [M:DIV2]WEESTRDAY = 1 : Endif
        Case [M:DIV2]WEESTRDAY
          When 1
            WFIN_SEM = 7
          When Default
            WFIN_SEM = [M:DIV2]WEESTRDAY - 1
        Endcase
        If ([M:DIV2]WEESTRDAY = 0 ) Then : [M:DIV2]WEESTRDAY = 1 : Endif
        RTRN = PDAT
        While dayn(RTRN) <> WFIN_SEM
          RTRN += 1
        Wend
      When Default : RTRN = [0/0/0]
    Endcase
  Endif
End RTRN
Funprog CAL_DAT_ISENDOFMONTH( PDAT )
  Value Date    PDAT
  Local Integer LANN
    LANN = year(PDAT)
    If ( day(PDAT) = 31 or
&      ( day(PDAT) = 30 and ( month(PDAT)= 4 or month(PDAT)=6 or month(PDAT)= 9 or month(PDAT)= 11 )) or
&      ( day(PDAT) = 28 and month(PDAT) = 2 and func GLOBB9.CAL_DAT_BISS(LANN) = 365 ) ) or
&      ( day(PDAT) = 29 and month(PDAT) = 2  ) Then
      RTRN = 1
    Else
      RTRN = 0
    Endif
End RTRN
Funprog CAL_DAT_ISENDOFHLFM( PDAT )
  Value Date    PDAT
  Local Integer RTRN
    If (day(PDAT) = 15 or func GLOBB9.CAL_DAT_ISENDOFMONTH(PDAT)) Then
      RTRN = 1
    Else
      RTRN = 0
    Endif
End RTRN
Funprog CAL_DAT_ISENDOFHLFQ( PDAT )
  Value Date    PDAT
  Local Integer RTRN
  Local Integer WMOIS
    RTRN = 0
    WMOIS = month(PDAT)
    If ( WMOIS <> 1 and WMOIS <> 4 and WMOIS <> 7 and WMOIS <> 10) Then
      Local Integer WJOUR
      WJOUR = day(PDAT)
      If ( ( WJOUR = 15 and ( WMOIS = 2 or WMOIS =  5 or WMOIS = 8 or WMOIS = 11 ) ) or
&          ( WJOUR = 30 and ( WMOIS = 6 or WMOIS =  9 ) ) or
&          ( WJOUR = 31 and ( WMOIS = 3 or WMOIS = 12 ) ) ) Then
        RTRN = 1
      Endif
    Endif
End RTRN
Funprog CAL_DAT_ISENDOFWEEK( PDAT )
  Value Date    PDAT
  Local Integer RTRN
    Local Integer WFIN_SEM
    If ([M:DIV2]WEESTRDAY = 0 ) Then : [M:DIV2]WEESTRDAY = 1 : Endif
    Case [M:DIV2]WEESTRDAY
      When 1
        WFIN_SEM = 7
      When Default
        WFIN_SEM = [M:DIV2]WEESTRDAY - 1
    Endcase
    If (dayn(PDAT) = WFIN_SEM) Then
      RTRN = 1
    Else
      RTRN = 0
    Endif
End RTRN
Funprog CAL_DAT_ISBEGINNINGOFWEEK( PDAT )
  Value Date    PDAT
  Local Integer RTRN
  If ([M:DIV2]WEESTRDAY = 0 ) Then : [M:DIV2]WEESTRDAY = 1 : Endif
  If (dayn(PDAT) = [M:DIV2]WEESTRDAY) Then
      RTRN = 1
    Else
      RTRN = 0
    Endif
End RTRN
Funprog CAL_DAT_PREM( PDAT, PTYP )
Value Date    PDAT
Value Char    PTYP
Local Date    RTRN
Local Decimal WRNG
  RTRN = [0/0/0]
  If ( PDAT <> [0/0/0] ) Then
    Case PTYP
      When "Y"
        RTRN = gdat$(01,01,year(PDAT))
      When "M"
        RTRN = gdat$(01,month(PDAT),year(PDAT))
      When "Q"
        If ( day(PDAT) >= 01 and day(PDAT) <= 15 ) Then
          RTRN = gdat$(01,month(PDAT),year(PDAT))
        Else
          RTRN = gdat$(16,month(PDAT),year(PDAT))
        Endif
      When "T"
        If    (PDAT > gdat$(15,11,year(PDAT))) Then
          RTRN = gdat$(16,11,year(PDAT))
        Elsif (PDAT > gdat$(30,09,year(PDAT))) Then
          RTRN = gdat$(01,10,year(PDAT))
        Elsif (PDAT > gdat$(15,08,year(PDAT))) Then
          RTRN = gdat$(16,08,year(PDAT))
        Elsif (PDAT > gdat$(30,06,year(PDAT))) Then
          RTRN = gdat$(01,07,year(PDAT))
        Elsif (PDAT > gdat$(15,05,year(PDAT))) Then
          RTRN = gdat$(16,05,year(PDAT))
        Elsif (PDAT > gdat$(31,03,year(PDAT))) Then
          RTRN = gdat$(01,04,year(PDAT))
        Elsif (PDAT > gdat$(15,02,year(PDAT))) Then
          RTRN = gdat$(16,02,year(PDAT))
        Else
          RTRN = gdat$(01,01,year(PDAT))
        Endif
      When "W"
        If ([M:DIV2]WEESTRDAY = 0 ) Then : [M:DIV2]WEESTRDAY = 1 : Endif
        RTRN = PDAT
        While dayn(RTRN) <> [M:DIV2]WEESTRDAY
          RTRN -= 1
        Wend
      When Default : RTRN = [0/0/0]
    Endcase
  Else
    RTRN = [0/0/0]
  Endif
End RTRN
Subprog CAL_DAT_DIFF( Z01DTDB, Z01DTFN, Z01TYP, X01DIFF )
Value    Date      Z01DTDB
Value    Date      Z01DTFN
Value    Char      Z01TYP
Variable Decimal   X01DIFF
Local Shortint CALL_Z01
Goto $DEB_CAL_DAT_DIFF
$GSB_CAL_DAT_DIFF
  Local Date      Z01DTDB      : Z01DTDB = [M:DIV]PD(0)
  Local Date      Z01DTFN      : Z01DTFN = [M:DIV]PD(1)
  Local Char      Z01TYP       : Z01TYP  = [M:DIV]PC(0)
  Local Decimal   X01DIFF
$DEB_CAL_DAT_DIFF
Local Integer   Z01RTRN
Local Date      Z01LDAT
  Z01RTRN = 0
  If ( Z01DTDB <> [0/0/0] and Z01DTFN <> [0/0/0]) Then
    Case Z01TYP
      When "Y"     : Z01RTRN = (year(Z01DTFN)-year(Z01DTDB))+1
      When "M"     : Z01RTRN = ((year(Z01DTFN)-year(Z01DTDB))*12)+ (month(Z01DTFN)-month(Z01DTDB))+1
      When "W"     : Z01RTRN = arr(((Z01DTFN-Z01DTDB)+1)/7,1)
      When "D"     : Z01RTRN = (Z01DTFN-Z01DTDB)+1
      When "Q"     : Z01RTRN = ((year(Z01DTFN)-year(Z01DTDB))*24)+ ((month(Z01DTFN)-month(Z01DTDB))*2)+2
                     If (day(Z01DTDB) > 15 ) Then : Z01RTRN -= 1 : Endif
                     If (day(Z01DTFN) < 16 ) Then : Z01RTRN -= 1 : Endif
      When "T"     : Z01RTRN = ((year(Z01DTFN)-year(Z01DTDB))*24)+ ((month(Z01DTFN)-month(Z01DTDB))*2)+2
                     If (day(Z01DTDB) > 15 ) Then : Z01RTRN -= 1 : Endif
                     If (day(Z01DTFN) < 16 ) Then : Z01RTRN -= 1 : Endif
      When Default : Z01RTRN = 0
    Endcase
  Endif
  X01DIFF = Z01RTRN
If (dim(CALL_Z01)<0) Then
 [M:DIV]RV(0) = X01DIFF
 Return
Endif
End
Funprog CAL_DAT_PLUS( PDAT, PVALINCR, PTYPINCR )
Value    Date      PDAT
Value    Decimal   PVALINCR
Value    Char      PTYPINCR
Local    Date      RTRN
Local Char    LTYPINCR
Local Decimal LVALINCR
  If ( PDAT = [0/0/0] )  Then : RTRN = [0/0/0] : End RTRN : Endif
  LTYPINCR = PTYPINCR
  LVALINCR = PVALINCR
  If (LTYPINCR = "Y" ) Then
    LTYPINCR="M"
    LVALINCR= arr(LVALINCR*12,1)
  Endif
  If ( LVALINCR <> 0 ) Then
    Case LTYPINCR
      When "M"     : RTRN = addmonth(PDAT,LVALINCR)
      When "W"     : RTRN = PDAT+(LVALINCR*7)
      When "D"     : RTRN = PDAT+LVALINCR
      When Default : RTRN = [0/0/0]
    Endcase
  Else
    RTRN = PDAT
  Endif
End RTRN
Funprog CAL_LOCALISE_DAT (PDAT, PTABDATD, PTABDATF, P_DEB, P_FIN)
Value Date     PDAT
Value Date     PTABDATD(0..), PTABDATF(0..)
Value Integer  P_DEB
Value Integer  P_FIN
Local Integer  RTRN
Local Integer  I
  If ( PDAT < PTABDATD(P_DEB) ) Then
    RTRN = -1
  Elsif ( PDAT > PTABDATF(P_FIN) ) Then
    RTRN = -2
  Else
    RTRN = sigma (I= P_DEB, P_FIN, PTABDATF(I) < PDAT)
  Endif
End RTRN
Subprog CAL_DAT_FIN_SELON_DUREE ( PDTDB, PDUR, PTYPPRO, RDTFN )
Value    Date      PDTDB
Value    Decimal   PDUR
Value    Integer   PTYPPRO
Variable Date      RDTFN
Local    Decimal   LDECI   : LDECI = PDUR - fix(PDUR)
Local    Decimal   LENT    : LENT  = PDUR - LDECI
Local    Decimal   WINCR
Local    Date      LDTFN
Local    Integer   LANN
Local    Integer   LTAB30(4)
  If ( PDTDB = [0/0/0] )  Then : RDTFN = [0/0/0] : End  : Endif
  RDTFN = func GLOBB9.CAL_DAT_PLUS( PDTDB, LENT , "Y")
  LDTFN = RDTFN
  If ( LDECI  <> 0 ) Then
    LANN = year(PDTDB)
    If ( day(PDTDB) = 1 or func GLOBB9.CAL_DAT_ISENDOFMONTH(PDTDB) ) Then
      Local Decimal WDECI : WDECI = arr(LDECI, 0.01)
      Case WDECI
        When 0.08
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 1  , "M")
        When 0.16 , 0.17
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 2  , "M")
        When 0.25
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 3  , "M")
        When 0.33
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 4  , "M")
        When 0.41 , 0.42
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 5  , "M")
        When 0.50
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 6  , "M")
        When 0.58
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 7  , "M")
        When 0.66 , 0.67
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 8  , "M")
        When 0.75
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 9  , "M")
        When 0.83
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 10 , "M")
        When 0.91 , 0.92
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 11 , "M")
        When Default
          LDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN , -1 , "D")
          LANN = year(LDTFN)
          WINCR = arr( (func GLOBB9.CAL_DAT_BISS(LANN) * LDECI), 1 )
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, WINCR , "D")
      Endcase
    Else
      LDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN , -1 , "D")
      LANN = year(LDTFN)
      WINCR = arr( (func GLOBB9.CAL_DAT_BISS(LANN) * LDECI), 1 )
      RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, WINCR , "D")
    Endif
  Endif
  RDTFN = func GLOBB9.CAL_DAT_PLUS( RDTFN , -1 , "D")
  Case PTYPPRO
    When GVML_TPSEMA
      If !( func GLOBB9.CAL_DAT_ISENDOFWEEK (RDTFN) ) Then
         RDTFN = func GLOBB9.CAL_DAT_PLUS( RDTFN , -7, "D")
         RDTFN = func GLOBB9.CAL_DAT_DERN( RDTFN , "W")
      Endif
    When GVML_TPMOIS
      RDTFN = func GLOBB9.CAL_DAT_DERN( RDTFN , "M")
    When GVML_TPHLFY
      RDTFN = func GLOBB9.CAL_DAT_DERN( RDTFN , "M")
    When GVML_TPHLFM
      RDTFN = func GLOBB9.CAL_DAT_DERN( RDTFN , "Q")
    When GVML_TPHLFQ
      RDTFN = func GLOBB9.CAL_DAT_DERN( RDTFN , "T")
    When Default
  Endcase
End
Subprog CAL_RETRAITE_DUREE_EN_MOIS ( PDUR, RDUR )
Value    Decimal   PDUR
Variable Decimal   RDUR
Local    Decimal   LDECI   : LDECI = PDUR - fix(PDUR)
Local    Decimal   LENT    : LENT  = PDUR - LDECI
Local    Decimal   LDECR   : LDECR = 0.                  : # Partie décimale retraitée
  If LDECI > 0.958
    LDECR = 1.
  Elsif LDECI > 0.875
    LDECR = 0.917
  Elsif LDECI > 0.791
    LDECR = 0.833
  Elsif LDECI > 0.708
    LDECR = 0.75
  Elsif LDECI > 0.625
    LDECR = 0.667
  Elsif LDECI > 0.541
    LDECR = 0.583
  Elsif LDECI > 0.458
    LDECR = 0.5
  Elsif LDECI > 0.375
    LDECR = 0.417
  Elsif LDECI > 0.291
    LDECR = 0.333
  Elsif LDECI > 0.208
    LDECR = 0.25
  Elsif LDECI > 0.125
    LDECR = 0.167
  Elsif LDECI > 0.041
    LDECR = 0.083
  Else
    LDECR = 0.
  Endif
  RDUR = LENT + LDECR
End
Subprog CAL_DUREE_OU_NBMOIS ( PTYP, PDUR, PNBM, RDUR, RNBM )
Value    Char      PTYP
Value    Decimal   PDUR
Value    Integer   PNBM
Variable Decimal   RDUR
Variable Integer   RNBM
  If ( find( PTYP, "D","M") = 0 ) Then : RDUR = PDUR : RNBM = PNBM : End : Endif
  If ( PTYP = "D" ) Then
    Local    Decimal   LDECI   : LDECI = PDUR - fix(PDUR)
    Local    Decimal   LENT    : LENT  = PDUR - LDECI
    Local    Decimal   LDECM   : LDECM = 0.                  : # Partie décimale exprimée en mois
    If LDECI > 0.958
      LDECM = 12
    Elsif LDECI > 0.875
      LDECM = 11
    Elsif LDECI > 0.791
      LDECM = 10
    Elsif LDECI > 0.708
      LDECM = 9
    Elsif LDECI > 0.625
      LDECM = 8
    Elsif LDECI > 0.541
      LDECM = 7
    Elsif LDECI > 0.458
      LDECM = 6
    Elsif LDECI > 0.375
      LDECM = 5
    Elsif LDECI > 0.291
      LDECM = 4
    Elsif LDECI > 0.208
      LDECM = 3
    Elsif LDECI > 0.125
      LDECM = 2
    Elsif LDECI > 0.041
      LDECM = 1
    Else
      LDECM = 0.
    Endif
    RDUR = PDUR
    RNBM = (LENT*12) + LDECM
  Endif
  If ( PTYP = "M" ) Then
    Local Integer NBA
    Local Integer RST
    NBA = PNBM /12
    RST = PNBM - (NBA*12)
    Local Decimal LDECR  : # Partie décimale résultante
    Case RST
      When 0
        LDECR = 0.
      When 1
        LDECR = 0.083
      When 2
        LDECR = 0.167
      When 3
        LDECR = 0.25
      When 4
        LDECR = 0.333
      When 5
        LDECR = 0.417
      When 6
        LDECR = 0.5
      When 7
        LDECR = 0.583
      When 8
        LDECR = 0.667
      When 9
        LDECR = 0.75
      When 10
        LDECR = 0.833
      When 11
        LDECR = 0.917
    Endcase
    RNBM = PNBM
    RDUR = NBA + LDECR
  Endif
End
Funprog CAL_DAT_NBJ_BISS ( PDTDB, PDTFN )
Value    Date      PDTDB
Variable Date      PDTFN
Local    Shortint  RTRN
Local Date         LDAT
Local Integer      LANN
Local Integer      LDEB
Local Integer      LFIN
  LANN = year(PDTDB)
  If ( func GLOBB9.CAL_DAT_BISS(LANN) = 366 ) Then
    LDAT = gdat$(29,02,LANN)
    If ( func GLOBB9.CAL_DAT_INSIDE(LDAT,PDTDB,PDTFN,"I") ) Then
      RTRN += 1
    Endif
  Endif
  If ( year(PDTDB) <> year(PDTFN) ) Then
    LANN = year(PDTFN)
    If ( func GLOBB9.CAL_DAT_BISS(LANN) = 366 ) Then
      LDAT = gdat$(29,02,LANN)
      If ( func GLOBB9.CAL_DAT_INSIDE(LDAT,PDTDB,PDTFN,"I") ) Then
        RTRN += 1
      Endif
    Endif
    If ( year(PDTFN) - year(PDTDB) > 1 ) Then
      LDEB = year(PDTDB) + 1
      LFIN = year(PDTFN) - 1
      For LANN = LDEB To LFIN
        If ( func GLOBB9.CAL_DAT_BISS(LANN) = 366 ) Then : RTRN += 1 : Endif
      Next LANN
    Endif
  Endif
End RTRN
Subprog  CAL_DAT_BORNES ( Z02DTDB1, Z02DTFN1,
&                         Z02DTDB2, Z02DTFN2, Z02DTDB3, Z02DTFN3, Z02DTFN4, Z02DTFN5,  X02DTDB, X02DTFN)
Value    Date      Z02DTDB1, Z02DTDB2, Z02DTDB3, Z02DTFN1, Z02DTFN2, Z02DTFN3, Z02DTFN4, Z02DTFN5
Variable Date      X02DTDB , X02DTFN
Local Shortint CALL_Z02
Goto $DEB_CAL_DAT_BORNES
$GSB_CAL_DAT_BORNES
  Local Date      Z02DTDB1        : Z02DTDB1     = [M:DIV]PD(0)
  Local Date      Z02DTFN1        : Z02DTFN1     = [M:DIV]PD(1)
  Local Date      Z02DTDB2        : Z02DTDB2     = [M:DIV]PD(2)
  Local Date      Z02DTFN2        : Z02DTFN2     = [M:DIV]PD(3)
  Local Date      Z02DTDB3        : Z02DTDB3     = [M:DIV]PD(4)
  Local Date      Z02DTFN3        : Z02DTFN3     = [M:DIV]PD(5)
  Local Date      Z02DTFN4        : Z02DTFN4     = [M:DIV]PD(6)
  Local Date      Z02DTFN5        : Z02DTFN5     = [M:DIV]PD(7)
  Local Date      X02DTDB
  Local Date      X02DTFN
$DEB_CAL_DAT_BORNES
Local Date    W02DTFN2, W02DTFN3, W02DTFN4, W02DTFN5
  If ( Z02DTDB1 = [0/0/0] or Z02DTFN1 = [0/0/0] ) Then
    [M:DIV]ERRID = 26 : Call ERRFND From   GLOBB0  : # Dépilement suite à erreur logique
    If (dim(CALL_Z02)<0) Then :  Return : Else : End : Endif
  Endif
  X02DTDB = max( Z02DTDB1, Z02DTDB2, Z02DTDB3 )
  W02DTFN2 = Z02DTFN2 : W02DTFN3 = Z02DTFN3 : W02DTFN4 = Z02DTFN4 : W02DTFN5 = Z02DTFN5
  If ( W02DTFN2 = [0/0/0] ) Then : W02DTFN2 = Z02DTFN1 : Endif
  If ( W02DTFN3 = [0/0/0] ) Then : W02DTFN3 = Z02DTFN1 : Endif
  If ( W02DTFN4 = [0/0/0] ) Then : W02DTFN4 = Z02DTFN1 : Endif
  If ( W02DTFN5 = [0/0/0] ) Then : W02DTFN5 = Z02DTFN1 : Endif
  X02DTFN = min( Z02DTFN1, W02DTFN2, W02DTFN3, W02DTFN4, W02DTFN5 )
If (dim(CALL_Z02)<0) Then
 [M:DIV]RD(1) = X02DTDB
 [M:DIV]RD(2) = X02DTFN
 Return
Endif
End
Subprog CAL_DAT_DEBUT_SEMESTRE ( PDTDBEXE, PDTFNEXE, PDTDBAMT,  RDTDBSEM )
Value    Date      PDTDBEXE
Value    Date      PDTFNEXE
Value    Date      PDTDBAMT
Variable Date      RDTDBSEM
Local Date  WDTDBSEM
  WDTDBSEM = PDTFNEXE
  While WDTDBSEM >= PDTDBAMT
    WDTDBSEM = func GLOBB9.CAL_DAT_PLUS( WDTDBSEM , -6, "M" )
    WDTDBSEM = func GLOBB9.CAL_DAT_DERN( WDTDBSEM , "M" )
  Wend
  If (WDTDBSEM < PDTDBEXE) Then
    RDTDBSEM = PDTDBEXE
  Else
    RDTDBSEM = func GLOBB9.CAL_DAT_PLUS( WDTDBSEM , 1, "D")
  Endif
End
Subprog CAL_DAT_FIN_SEMESTRE ( PDTDBEXE, PDTFNEXE, PDTDBAMT,  RDTFNSEM )
Value    Date      PDTDBEXE
Value    Date      PDTFNEXE
Value    Date      PDTDBAMT
Variable Date      RDTFNSEM
Local Date  WDATE
Local Date  WDTDBSEM
  If ( day(PDTDBAMT) = 31 ) Then
    WDATE = gdat$( 30, month(PDTDBAMT), year(PDTDBAMT))
  Else
    WDATE = PDTDBAMT
  Endif
  WDATE = func GLOBB9.CAL_DAT_PLUS( WDATE , +6, "M" )
  If (WDATE > PDTFNEXE) Then
    RDTFNSEM = PDTFNEXE
  Else
    Call CAL_DAT_DEBUT_SEMESTRE ( PDTDBEXE, PDTFNEXE, WDATE,  WDTDBSEM ) From   GLOBB9
    RDTFNSEM = func GLOBB9.CAL_DAT_PLUS( WDTDBSEM , -1, "D")
  Endif
End
Subprog CAL_ORANOLOG (PDOSSIER,PTABLE)
Value Char PDOSSIER
Value Char PTABLE
  If ( GTYPDBA = 1 ) Then : #Oracle
    Local Char SQLREQLOG (250)
    SQLREQLOG = "ALTER TABLE "+PDOSSIER+"."+PTABLE+" NOLOGGING"
    Execsql From "3" Sql SQLREQLOG
  Endif
End
Subprog CAL_ORALOG (PDOSSIER,PTABLE)
Value Char PDOSSIER
Value Char PTABLE
  If ( GTYPDBA = 1 ) Then : #Oracle
    Local Char SQLREQLOG (250)
    SQLREQLOG = "ALTER TABLE "+PDOSSIER+"."+PTABLE+" LOGGING"
    Execsql From "3" Sql SQLREQLOG
  Endif
End
Funprog CAL_TAB_DIFF (PDOSSIER,PTABORI,PTABDES)
Value Char PDOSSIER
Value Char PTABORI
Value Char PTABDES
Local Shortint B_DIFF
B_DIFF=0
Local Char REQSQL (250)(2)
  If ( GTYPDBA = 1 ) Then
    REQSQL(0)="select COLUMN_NAME,DATA_TYPE from all_tab_columns T1 where T1.OWNER='"+PDOSSIER+"' AND T1.TABLE_NAME='"+PTABORI+"' "
    REQSQL(1)="AND NOT EXISTS ( SELECT 'X' from all_tab_columns T2 where T2.OWNER=T1.OWNER AND T2.COLUMN_NAME=T1.COLUMN_NAME AND T2.TABLE_NAME='"+PTABDES+"') ORDER BY COLUMN_NAME"
    For (Char VCOL(50),Char VTYP(50)) From num$(GTYPDBA*2+1) Sql REQSQL(0..1) As [BZZ]
      B_DIFF = 1
    Next
    If not(B_DIFF) Then
      REQSQL(0)="select COLUMN_NAME,DATA_TYPE from all_tab_columns T1 where T1.OWNER='"+PDOSSIER+"' AND T1.TABLE_NAME='"+PTABDES+"' "
      REQSQL(1)="AND NOT EXISTS ( SELECT 'X' from all_tab_columns T2 where T2.OWNER=T1.OWNER AND T2.COLUMN_NAME=T1.COLUMN_NAME AND T2.TABLE_NAME='"+PTABORI+"') ORDER BY COLUMN_NAME"
      For (Char VCOL(50),Char VTYP(50)) From num$(GTYPDBA*2+1) Sql REQSQL(0..1) As [BZZ]
        B_DIFF = 1
      Next
    Endif
  Else
    REQSQL(0)="select t1.name,t3.name from syscolumns t1, sys.types t3 where t1.xtype=t3.user_type_id and t1.id=object_id('"+PDOSSIER+"."+PTABORI+"') "
    REQSQL(1)="and not exists(select 'x' from syscolumns t2 where t1.name=t2.name and t2.id=object_id('"+PDOSSIER+"."+PTABDES+"')) order by t1.name"
    For (Char VCOL(50),Char VTYP(50)) From num$(GTYPDBA*2+1) Sql REQSQL(0..1) As [BZZ]
      If [BZZ]VCOL<>"ROWID"
        B_DIFF = 1
      Endif
    Next
    If not(B_DIFF) Then
      REQSQL(0)="select t1.name,t3.name from syscolumns t1, sys.types t3 where t1.xtype=t3.user_type_id and t1.id=object_id('"+PDOSSIER+"."+PTABDES+"') "
      REQSQL(1)="and not exists(select 'x' from syscolumns t2 where t1.name=t2.name and t2.id=object_id('"+PDOSSIER+"."+PTABORI+"')) order by t1.name"
      For (Char VCOL(50),Char VTYP(50)) From num$(GTYPDBA*2+1) Sql REQSQL(0..1) As [BZZ]
        If [BZZ]VCOL<>"ROWID"
          B_DIFF = 1
        Endif
      Next
    Endif
  Endif
End B_DIFF
Subprog CAL_TAB_RAZ (PDOSSIER,PTABLE)
Value Char PDOSSIER
Value Char PTABLE
If filinfo(filpath("FIL",PTABLE,"fde",PDOSSIER),0) < 0 : End : Endif
Local File =PDOSSIER+"."+PTABLE  [TB1]
Local Char REQTSQL (250)
Trbegin [TB1]
REQTSQL(0)="TRUNCATE TABLE "-PDOSSIER+"."+PTABLE
Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
Commit
Close File [TB1]
End
Subprog CAL_CONNECTED_USERS(DOSSIER,NBCON,RERR)
Value Char       DOSSIER
Variable Integer NBCON
Variable Integer RERR
RERR = 0
Local Char       SID(12) , SCLI(80) , SDOS(30) , STYP(12)
Local Char       MACHINE(GLONAMC) , APPLI(GLONADS)
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
Local File (SID,SCLI,SDOS,STYP,SLOG) From System MACHINE+"@psadx -tf -b"-APPLI As [SYS_] Where [SYS_]SDOS=APPLI
NBCON = 0
For [SYS_]
 If !find([SYS_]STYP,"4","5","7") : # Web services/Terminal/Bridge Java
  NBCON += 1
  If (NBCON > 1) Then
    RERR = 1
  Endif
 Endif
Next SYS_
Close Local File [SYS_]
End
Subprog CAL_VERROU_DOSSIER(PDOSSIER,RERR)
Value    Char    PDOSSIER
Variable Integer RERR
Local Integer    NBUSR
  RERR = 0
  If (PDOSSIER = GDOSX3) Then
    Call ECR_TRACE("Verrouillage du dossier racine interdit ",1) From GESECRAN
    RERR = 39
    End
  Endif
  Call CAL_CONNECTED_USERS(nomap,NBUSR, RERR)
  If ( RERR ) Then
    Call ECR_TRACE(num$(NBUSR)-mess(48,125,1),1) From GESECRAN
    RERR = 40
    End
  Endif
  Local File =nomap+".ADOVAL" [ADW]
  Read [ADW]ADW0 = "";"";"MONO"
  MONO = val([F:ADW]VALEUR)
  If (fstat) Then
    Call ECR_TRACE(mess(49,125,1)-"ADOVAL"-"MONO",1) From GESECRAN
    RERR = 41
    End
  Endif
  If (MONO) Then
     Call ECR_TRACE(mess(47,125,1),1) From GESECRAN
     RERR = 42
     End
   Endif
   Trbegin [ADW]
     [F:ADW]VALEUR = "2"
     Rewrite [ADW]
     If fstat
       Call ECR_TRACE(mess(26,125,1)-"ADOVAL"-"MONO",1) From GESECRAN
       RERR = 41
     Endif
   Commit
End
Subprog CAL_DEVERROU_DOSSIER(PDOSSIER,RERR)
Value    Char    PDOSSIER
Variable Integer RERR
  RERR = 0
  Local File =PDOSSIER+".ADOVAL" [ADW]
  Trbegin [ADW]
    Read [ADW]ADW0 = "";"";"MONO"
    If (fstat) Then
      RERR = 44
      Call ECR_TRACE(mess(49,125,1)-"ADOVAL"-"MONO",1) From GESECRAN
    Else
      [F:ADW]VALEUR = "0"
      Rewrite [ADW]
      If fstat
        RERR = 44
        Call ECR_TRACE(mess(26,125,1)-"ADOVAL"-"MONO",1) From GESECRAN
      Endif
    Endif
  Commit
End
Subprog CAL_DELIND (PDOSSIER,PTABLE)
Value Char PDOSSIER
Value Char PTABLE
  Local File =PDOSSIER+".ATABIND"     [ATI]   : # index
  Read [ATI]NUMLIG=PTABLE;1
  If fstat : Raz [ATI] : Endif
  If GTYPDBA=1 : #Oracle
    Local Char SQLREQIND (250)
    For (Char VTAB(50),Char VIND(50)) From '3' Sql
&   "SELECT table_name,index_name"
&  -"From ALL_INDEXES"
&  -"where substr(index_name,1,6)!='SYS_IL'"
&  -"and table_name='"+PTABLE+"'"
&  -"and owner='"+PDOSSIER+"'"
&  -"Order BY 1,2"
&   As [BXX]
      If [BXX]VIND<>PTABLE+'_'+[F:ATI]CODIND
        SQLREQIND = "DROP INDEX "+PDOSSIER+"."+[BXX]VIND
        Execsql From "3" Sql SQLREQIND
      Else
        SQLREQIND = "ALTER INDEX "+PDOSSIER+"."+[BXX]VIND+" NOLOGGING"
        Execsql From "3" Sql SQLREQIND
      Endif
    Next
  Else : # SQLServer
    Trbegin [ATI]
    Local Char SQLREQIND (250)
    Local Char REQSQL (250) (2)
    Local Integer RERR
    REQSQL(0) = "SELECT cast(o.name as varchar),i.name "
    Local Char WVERSSQL
    Call NOVERS_SQL(WVERSSQL,RERR) From SQLPROP
    If RERR<>0 : Return : Endif
    If WVERSSQL="8"
      REQSQL(1) ="From sysindexes i,sysobjects o,sysusers u"
&     -"where o.id=i.id and o.uid=u.uid and i.name<>o.name"
&     -"and i.name not like '%ROWID'"
&     -"and i.name<>'t'+o.name"
&     -"and i.status in (0,2)"
&     -"and u.name='"+PDOSSIER+"'"
&     -"and cast(o.name as varchar)='"+PTABLE+"'"
&     -"order by o.name,i.name"
    Else
      REQSQL(1) ="From sysindexes i,sysobjects o"
&     -"where o.id=i.id and i.name<>o.name"
&     -"and i.name not like '%ROWID'"
&     -"and i.name<>'t'+o.name"
&     -"and i.status in (0,2)"
&     -"and SCHEMA_NAME(o.uid)='"+PDOSSIER+"'"
&     -"and cast(o.name as varchar)='"+PTABLE+"'"
&     -"order by o.name,i.name"
    Endif
    For (Char VTAB(50),Char VIND(50)) From '5' Sql REQSQL As [BXX]
      If [BXX]VIND<>PTABLE+'_'+[F:ATI]CODIND
        SQLREQIND = "DROP INDEX ["+PDOSSIER+"].["+PTABLE+"]."+[BXX]VIND
        Execsql From "5" Sql SQLREQIND
      Endif
    Next
    Commit
  Endif
End
Subprog CAL_CREIND (PDOSSIER,PTABLE,RERR)
Value    Char PDOSSIER
Value    Char PTABLE
Variable Integer RERR
  Local Char    ORDSYS(250)(1..2)
  Local Char    MESSAGE(80)(1..5) , FICTRA(250)
  Local Integer STAT
  RERR = 0
  FICTRA  = filpath("tmp",PTABLE,"tra",PDOSSIER)
  If filinfo(FICTRA,0)>=0
   Call EFFACE(FICTRA ,STAT) From ORDSYS
  Endif
  ORDSYS(1) = "valfil -s -e"
  ORDSYS(1) -= PDOSSIER-PTABLE
  ORDSYS(2) = FICTRA
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
  adxifs = ""
  adxirs = chr$(10)
  Openi FICTRA
  Raz MESSAGE
  Rdseq MESSAGE(1)
  Rdseq MESSAGE(2)
  Rdseq MESSAGE(3)
  Openi
  If (MESSAGE(1)<>"") Then
   RERR= 43 : # Erreur en validation de la table
   Call ECR_TRACE(mess(51,123,1)-PDOSSIER-PTABLE+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3),1) From GESECRAN
  Endif
End
Subprog CAL_DELTAB (PDOSSIER,PTABLE,PREQ, PIR)
Value Char    PDOSSIER
Value Char    PTABLE
Value Char    PREQ() (1..)
Value Integer PIR
Local Char WTABCOL(250)(1..200) : Raz WTABCOL
Local Integer WNBCOL
  Local File =PDOSSIER+".ATABLE"  [ATB2]
  WNBCOL =1 : WTABCOL(WNBCOL)="DELETE"-PDOSSIER+"."
  WNBCOL+=1 : WTABCOL(WNBCOL)=PTABLE
  If (PIR) Then
    WNBCOL+=1 : WTABCOL(WNBCOL)=" WHERE "
    Local Integer IR
    For IR = 1 To PIR
      WNBCOL+=1 : WTABCOL(WNBCOL) = PREQ(IR)
    Next IR
  Endif
  Execsql From num$(GTYPDBA*2+1) Sql WTABCOL(1..WNBCOL)
End
Subprog CAL_REQ_DAT (PDATE,RDATE)
Value Date PDATE
Variable Char RDATE
  RDATE = ""
  If ( GTYPDBA = 1 ) Then
    RDATE = "to_date('"+format$("D:YYYYMMDD",PDATE)+"','YYYYMMDD')"
  Else
    RDATE = "convert(datetime,'"+format$("D:YYYYMMDD",PDATE)+"',112)"
  Endif
End
Subprog CAL_INSTAB (PDOSSIER,PTABORI,PTABDES,PREQ, PIR)
Value Char    PDOSSIER
Value Char    PTABORI
Value Char    PTABDES
Value Char    PREQ() (1..)
Value Integer PIR
Local Char WTABCOL(80)(1..1000) : Raz WTABCOL
Local Integer WNBCOL  : WNBCOL=0
Local Char REQSQL (250)(2)
Local File =PDOSSIER+".ATABLE"  [ATB2]
Trbegin [ATB2]
  If GTYPDBA=1 : #Oracle
    WNBCOL=1
    WTABCOL(WNBCOL)="INSERT INTO"-PDOSSIER+"." : WNBCOL+=1
    WTABCOL(WNBCOL)=PTABDES+"(": WNBCOL+=1
    PREM=0
    For (Char VCOL(50)) From num$(GTYPDBA*2+1) Sql "select COLUMN_NAME from all_tab_columns where OWNER='"+PDOSSIER+"' AND TABLE_NAME='"+PTABORI+"' ORDER BY COLUMN_NAME" As [BXX]
        If PREM
            WTABCOL(WNBCOL)=","
        Endif
        PREM=1
        WTABCOL(WNBCOL)+=[BXX]VCOL : WNBCOL+=1
    Next
    WTABCOL(WNBCOL)=") SELECT " : WNBCOL+=1
    PREM=0
    For (Char VCOL(50)) From num$(GTYPDBA*2+1) Sql "select COLUMN_NAME from all_tab_columns where OWNER='"+PDOSSIER+"' AND TABLE_NAME='"+PTABORI+"' ORDER BY COLUMN_NAME" As [BXX]
        If PREM
            WTABCOL(WNBCOL)=","
        Endif
        PREM=1
        WTABCOL(WNBCOL)+=[BXX]VCOL : WNBCOL+=1
    Next
    WTABCOL(WNBCOL)=" FROM"-PDOSSIER+"." : WNBCOL+=1
    WTABCOL(WNBCOL)=PTABORI+" D1"
    If (PIR) Then
      WNBCOL+=1 : WTABCOL(WNBCOL)=" WHERE "
      Local Integer IR
      For IR = 1 To PIR
        WNBCOL+=1 : WTABCOL(WNBCOL) = PREQ(IR)
      Next IR
    Endif
    Execsql From num$(GTYPDBA*2+1) Sql WTABCOL(1..WNBCOL)
  Else  : # SQL Server
    WNBCOL=1
    WTABCOL(WNBCOL)="INSERT INTO"-PDOSSIER+"." : WNBCOL+=1
    WTABCOL(WNBCOL)=PTABDES+"(": WNBCOL+=1
    PREM=0
    For (Char VCOL(50)) From num$(GTYPDBA*2+1) Sql "select name from syscolumns where id=object_id('"+PDOSSIER+"."+PTABORI+"') order by name" As [BXX]
      If [BXX]VCOL<>"ROWID"
        If PREM
            WTABCOL(WNBCOL)=","
        Endif
        PREM=1
        WTABCOL(WNBCOL)+=[BXX]VCOL : WNBCOL+=1
      Endif
    Next
    WTABCOL(WNBCOL)=") SELECT " : WNBCOL+=1
    PREM=0
    For (Char VCOL(50)) From num$(GTYPDBA*2+1) Sql "select name from syscolumns where id=object_id('"+PDOSSIER+"."+WTABLE(NOTAB)+"') order by name" As [BXX]
      If [BXX]VCOL<>"ROWID"
        If PREM
            WTABCOL(WNBCOL)=","
        Endif
        PREM=1
        WTABCOL(WNBCOL)+=[BXX]VCOL : WNBCOL+=1
      Endif
    Next
    WTABCOL(WNBCOL)=" FROM"-PDOSSIER+"." : WNBCOL+=1
    WTABCOL(WNBCOL)=PTABORI+" D1"
    If (PIR) Then
      WNBCOL+=1 : WTABCOL(WNBCOL)=" WHERE "
      Local Integer IR
      For IR = 1 To PIR
        WNBCOL+=1 : WTABCOL(WNBCOL) = PREQ(IR)
      Next IR
    Endif
    Execsql From num$(GTYPDBA*2+1) Sql WTABCOL(1..WNBCOL)
  Endif
Commit
End
Funprog CAL_CMP_MNT (PMNT1, POPE, PMNT2, PMNTREF)
Value Decimal PMNT1
Value Char    POPE
Value Decimal PMNT2
Value Decimal PMNTREF
Local Integer RRES
  Local Decimal MNT1
  Local Decimal MNT2
  If (PMNTREF < 0) Then
    MNT1 = PMNT1 * -1
    MNT2 = PMNT2 * -1
  Else
    MNT1 = PMNT1
    MNT2 = PMNT2
  Endif
  RRES = 0
  Case POPE
    When "<"
      If (MNT1 < MNT2)  : RRES = 1 : Endif
    When "<="
      If (MNT1 <= MNT2) : RRES = 1 : Endif
    When "="
      If (MNT1 = MNT2)  : RRES = 1 : Endif
    When ">="
      If (MNT1 >= MNT2) : RRES = 1 : Endif
    When ">"
      If (MNT1 >  MNT2) : RRES = 1 : Endif
  Endcase
End RRES
