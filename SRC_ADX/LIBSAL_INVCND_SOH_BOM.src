# Issue 107888 - 2016-09-09 by CPO : US150 Free products not deliverable invoicing
# Issue 107888 - 2016-09-09 by CPO : US155 Kit & flexible kit scheduled invoices

$INSERE_AV_INSA
  #--Here, in case of a free product, the insertion has to be aborted if no invoice condition set
  If   FUNCTION = 2  :  #--- Commande ---#
    If [M]SOHCAT=1 and dim([M]INVCND)>0
      If TYPINS = "P" #--Grouped
        #--Need to know if the inserted item is a free product
        #--For now, only if ITM and ITS contain the present free product
        If clalev([F:ITM])>0 and clalev([F:ITS])>0 and
&                 [F:ITM]ITMREF=WITM_INSERE and [F:ITS]ITMREF=WITM_INSERE
          # 107888 : Scheduled invoices : X3-4962 (LD:12/10/16)
#          If [F:ITM]SCSFLG=2 and [F:ITM]DLVFLG<>2 #--Free undeliverable service
          If [F:ITM]DLVFLG<>2 #--Free undeliverable service
          # 107888 : Scheduled invoices : X3-4962 (LD:12/10/16)
            #--1st step : taking dedicated free product invoice condition
            #--           from the company level general parameter
            If func AFNC.PARAM("INVCNDFREE", [M]STOFCY)="" and [M]INVCND="" and [F:ITS]INVCND=""
              #--Taking value from ORI line
              #--Error raised
              LIBMES1 = LIBMES-WITM_INSERE+"."-mess(864,197,1) #"Condition de facturation obligatoire"
              Gosub ERR_INSERE From TRTVENBOM
              Return
            Endif
          Endif
        Endif
      Endif
    Endif
  Elsif FUNCTION = 4  : #--- Facture ---#
#    #--No insertion wanted if invoicing a schedule invoice with sales order origin
#    If [M]INVTYP=1 and [M]SIHORI=10 and [M:SIH4]VCRINVCNDTYP(ORI)=10 and [M:SIH4]VCRINVCNDLIN(ORI)>0 and find(GFONC1,"GESSOH","FUNAUTINVSCH")>0
#      If    TYPINS = "G" #--Free product
#        #TODO
#      Elsif TYPINS = "P" #--Grouped
#        #TODO
#      Elsif TYPINS = "N" and [M]LINTYP(ORI) = 2 #--Fixed kits
#        RET = 2
#        If dim(WINSERT_OK)>0 : WINSERT_OK = 0 : Endif
#        Return
#      Elsif TYPINS = "N" and [M]LINTYP(ORI) = 6 #--Flexible kits
#        RET = 2
#        If dim(WINSERT_OK)>0 : WINSERT_OK = 0 : Endif
#        Return
#      Endif
#    Endif
  Endif
Return
#-----------------------------------------------------------------------------------
###################################################################
##  $INSERE : Insertion d'une ligne dans tableau du document      #
##           TYPINS  : N : Nomenclature                           #
##                     G : Gratuit                                #
##                     P : grouPé                                 #
##           ORI      : numéro de la ligne d'origine (nolign-1)   #
##           NL       : ligne gratuit/nomenclature                #
##           FUNCTION : 1=Devis / 2=Cde / 3=Liv / 4=Fac           #
##                                                                #
###################################################################
$INSERE

  If   FUNCTION = 2  :  #--- Commande ---#
    If [M]SOHCAT=1 and dim([M]DINVCND(ORI))>0 and [M]DLVFLG(NL)<>2 #[M]DINVCND(ORI)<>""
      If    TYPINS = "G" #--Free product
        If [M]FOCFLG(NL)=3 #--Free product
          #--1st step : taking dedicated free product invoice condition
          #--           from the company level general parameter
          [M]DINVCND(NL) = func AFNC.PARAM("INVCNDFREE", [M]STOFCY)
          If [M]DINVCND(NL)=""
            If [M]INVCND<>""
              [M]DINVCND(NL)=[M]INVCND
            Else
              #--Taking value from ITMREF
              #--For now, only if ITM and ITS contain the present free product
              #  ITS and ITM are charged in $INSERE From TRTVENBOM
              If clalev([F:ITM])>0 and clalev([F:ITS])>0 and
&                       [F:ITM]ITMREF=[M]ITMREF(NL) and [F:ITS]ITMREF=[M]ITMREF(NL)
                [M]DINVCND(NLIG)=[F:ITS]INVCND
              Endif
            Endif
            If [M]DINVCND(NL)=""
              #--Taking value from ORI line
              If [M]DINVCND(ORI) <> ""
                [M]DINVCND(NL)=[M]DINVCND(ORI)
              Else
                #--Error raised ?

              Endif
            Endif
          Endif
        Endif
      Elsif TYPINS = "P" #--Grouped
        If [M]FOCFLG(NL)=3 #--Free product in flexible kit
          #--1st step : taking dedicated free product invoice condition
          #--           from the company level general parameter
          [M]DINVCND(NL) = func AFNC.PARAM("INVCNDFREE", [M]STOFCY)
          If [M]DINVCND(NL)=""
            If [M]INVCND<>""
              [M]DINVCND(NL)=[M]INVCND
            Else
              #--Taking value from ITMREF
              #--For now, only if ITM and ITS contain the present free product
              If clalev([F:ITM])>0 and clalev([F:ITS])>0 and
&                       [F:ITM]ITMREF=[M]ITMREF(NL) and [F:ITS]ITMREF=[M]ITMREF(NL)
                [M]DINVCND(NLIG)=[F:ITS]INVCND
              Endif
            Endif
            If [M]DINVCND(NL)=""
              #--Taking value from ORI line
              #--Error raised before (see $INSERE_AV_INSA)
            Endif
          Endif
        Elsif [M]DLVFLG(NL)<>2
          Raz [M]DINVCND(NL)
        Endif
      Elsif TYPINS = "N" and [M]LINTYP(ORI) = 2 #--Fixed kits
        #--No scheduling invoice for now
        Raz [M]DINVCND(NL)

      Elsif TYPINS = "N" and [M]LINTYP(ORI) = 6 #--Flexible kits
        If [M]FOCFLG(NL)=3 #--Free product in flexible kit
          #--1st step : taking dedicated free product invoice condition
          #--           from the company level general parameter
          [M]DINVCND(NL) = func AFNC.PARAM("INVCNDFREE", [M]STOFCY)
          If [M]DINVCND(NL)=""
            If [M]INVCND<>""
              [M]DINVCND(NL)=[M]INVCND
            Else
              #--Taking value from ITMREF
              #--For now, only if ITM and ITS contain the present free product
              If clalev([F:ITM])>0 and clalev([F:ITS])>0 and
&                       [F:ITM]ITMREF=[M]ITMREF(NL) and [F:ITS]ITMREF=[M]ITMREF(NL)
                [M]DINVCND(NLIG)=[F:ITS]INVCND
              Endif
            Endif
            If [M]DINVCND(NL)=""
              #--Taking value from ORI line
              If [M]DINVCND(ORI) <> ""
                [M]DINVCND(NL)=[M]DINVCND(ORI)
              Else
                #--Error raised ?

              Endif
            Endif
          Endif
        Else
          #--TODO
        Endif
      Endif
    Elsif dim([M]DINVCND(ORI))>0
      Raz [M]DINVCND(NL)
    Endif
  Else
    Return
  Endif

Return
#-----------------------------------------------------------------------------------
# Issue 107888 - 2016-09-09 by CPO : US155 Kit & flexible kit scheduled invoices
$SUPNOM

  If   FUNCTION = 2  :  #--- Commande ---#
    If [M]SOHCAT=1 and dim([M]DINVCND(NL))>0 and [M]DINVCND(NL)<>""
      #--1. Calling the Dela on the GSOHVCRINVCND_UPD array list of instances
      #--Freeing the instance
      If dim(GSOHVCRINVCND_UPD)>0 and GSOHVCRINVCND_UPD(NL)<>null
        FreeGroup GSOHVCRINVCND_UPD(NL)
        GSOHVCRINVCND_UPD(NL)=null
      Endif
      #--Re-ordering the indexes (to keep the bijection nolign-1 => GSOHVCRINVCND_UPD(noling-1)
      If NL<=maxtab(GSOHVCRINVCND_UPD)
        Dela NL, 1 , maxtab(GSOHVCRINVCND_UPD) GSOHVCRINVCND_UPD
      Endif
    Endif
  Endif

Return
#-----------------------------------------------------------------------------------
# Issue 107888 - 2016-09-09 by CPO : US155 Kit & flexible kit scheduled invoices
$MODNOM
#--Au sens de nolign-1
#  ORI - n° ligne composé
#  NL  - n° ligne composant en cours de traitement

# 107888 : Scheduled invoices : X3-4962 (LD:12/10/16)
#Local Integer IS_FROM_MODBOM : IS_FROM_MODBOM=[V]CST_AYES
#If dim(IS_FROM_MODBOM_SET_SAME_ANSWER)<=0
#  Local Integer IS_FROM_MODBOM_SET_SAME_ANSWER : IS_FROM_MODBOM_SET_SAME_ANSWER = 0
#Endif
# 107888 : Scheduled invoices : X3-4962 (LD:12/10/16)

  Case GMODIF
    When 0 :
             #------ Modification composé --> Modification des composants
             If FUNCTION = 2
               # 107888 : Scheduled invoices : X3-4962 (LD:12/10/16)
               Local Integer IS_FROM_MODBOM : IS_FROM_MODBOM=[V]CST_AYES
               If dim(IS_FROM_MODBOM_SET_SAME_ANSWER)<=0
                 Local Integer IS_FROM_MODBOM_SET_SAME_ANSWER : IS_FROM_MODBOM_SET_SAME_ANSWER = 0
               Endif
               # 107888 : Scheduled invoices : X3-4962 (LD:12/10/16)

               If [M]SOHCAT=1 and dim([M]DINVCND(NL))>0 and [M]DLVFLG(NL)<>2
                 #--Case : change of the invoice condition on ORI line
                 If [M:SOH4]DINVCNDTODEL(ORI)=[V]CST_AYES or [M:SOH4]DINVCNDUPDK(ORI)=[V]CST_AYES #--Invoice condition changed or deleted
                   #---------------------------------------------
                   #--The "C_DINVCND" done above will prevent changing an invoice condition if already invoiced lines
                   #--If an existing invoice condition is code is changed, the new one will be generated and the existing deleted
                   #--As the invoice condition is created into the database at the same time at the order,
                   #--the rule only apply while modifying the order lien
                   #--New invoice condition => we start from scratch
                   If dim(GSOHVCRINVCND_UPD)>0 and GSOHVCRINVCND_UPD(NL)<>null
                     FreeGroup GSOHVCRINVCND_UPD(NL)
                     GSOHVCRINVCND_UPD(NL)=null
                   Endif

                   #--Setting the "to delete" flag and filling the invoice condition code to be deleted
                   If find(GREP,"C","D")=0
                     [M:SOH4]DINVCNDTODEL(NL)=[V]CST_AYES
                     [M:SOH4]DINVCNDPREV (NL)=[M:SOH4]DINVCND(NL)
                   Endif
                   [M:SOH4]DINVCNDTOUPD(NL)=[V]CST_AYES #CPO 18/01/2016 Optimisation
                   [M:SOH4]DINVCNDTODIS(NL)=[V]CST_ANO  #CPO 18/01/2016 Thus, we only do it once after an order line modification

                   [M:SOH4]DINVCND(NL)=[M:SOH4]DINVCND(ORI)
                   #---------------------------------------------
                 Else
                   [M]DINVCNDTODIS(NL)=[V]CST_AYES
                   [M]DINVCNDTOUPD(NL)=[V]CST_AYES
                   If dim(NOL)>0
                     Local Integer WSAVE_NOL : WSAVE_NOL = NOL
                   Else
                     Local Integer NOL
                   Endif
                   NOL=NL
                   Gosub P1_NBLIG_DINVCND_UPD From LIBSAL_INVCND_SOH
                   If dim(WSAVE_NOL)>0
                     NOL = WSAVE_NOL
                     Kill WSAVE_NOL
                   Endif
                 Endif
               Endif
             Endif
    When 4 :
             #--- Composé supprimé ou soldé seul --> Les composants deviennent normaux
             #[M]LINTYP(NL)=1
             If FUNCTION = 2
               #Nothing to do here for scheduling invoices
             Endif
    When 5 :
             #--- Solde/désolde composé          --> Solde/désolde des composants
             If FUNCTION = 2
               #--Mark the schedule invoice as Closed/To be invoiced
               If [M]SOHCAT=1 and dim([M]DINVCND(NL))>0 and [M]DINVCND(NL)<>""
                 If dim(NLIG)>0
                   Local Integer WSAVE_NLIG : WSAVE_NLIG = NLIG
                 Else
                   Local Integer NLIG
                 Endif
                 NLIG = NL
                 If [M]SOQSTA(NL) = 3
                   #--Set to 'To be invoiced'
                   Gosub TRT_CLESOQ_CLOSED    From LIBSAL_INVCND_SOH
                 Else
                   #--Set to 'Closed'
                   Gosub TRT_CLESOQ_NOTCLOSED From LIBSAL_INVCND_SOH
                 Endif
                 If dim(WSAVE_NLIG)>0
                   NLIG = WSAVE_NLIG
                   Kill WSAVE_NLIG
                 Endif
               Endif
             Endif
    When 6 :
             #----- Particularité d'une facture validée
             #----- Modification composé  --> Modification des composants uniquement pour les champs prestation
             If FUNCTION = 2
               #--Nothing to do here as it concerns only invoices...
             Endif
  Endcase

Return
#-----------------------------------------------------------------------------------

