#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion des demandes de garantie    Module CRM       16 septembre 2003.
#
#   CHECKSERNUM : Vérification de la saisie des numéros de série.
#   DISPCCN     : Affichage de l'interlocuteur.
#   DELRQWVCR   : Suppression des pièces générées par une demande de garantie.
#   VALIDATERQW : Validation de la demande de garantie.
#
##########################################################################################################

##########################################################################################################
# Chargement du tableau des prestations couvertes
###########################################################
$CHECKSERNUM
Local Integer ITER
Local Integer ITER2
Local Char SZITMREF
Local Char SZSERNUM
Local Char SZMESS(250)

  SZMESS = ""
  SZITMREF = ""
  SZSERNUM = ""
  #Vérifie la présence des numéros de série
  For ITER = 0 To [M:RQW1]NBLIG - 1
    Read [ITM]ITM0=[M:RQW1]ITMREF(ITER)
    If !fstat Then
      If [F:ITM]STOMGTCOD > 1 Then
        #Article géré en stock
        If [F:ITM]SERMGTCOD > 1 Then
          #Article géré en numéro de série
          If [M:RQW1]MACSERNUM(ITER) = "" Then
            #L'article saisi en ligne n° XXXX est géré en numéro de série.
            #Son numéro de série doit donc être renseigné.
            SZMESS = mess(429,182,1) - num$(ITER + 1) - mess(430,182,1) - mess(431,182,1)
            GMESSAGE = SZMESS
            GERR = 2
            OK = 0
            Break
          Endif
        Endif
      Endif
    Endif
  Next
  If GERR Then
    Return
  Endif
  #Vérifie l'absence de doublons de numéros de série
  For ITER = 0 To [M:RQW1]NBLIG-1
    SZITMREF = [M:RQW1]ITMREF(ITER)
    SZSERNUM = [M:RQW1]MACSERNUM(ITER)
    For ITER2 = 0 To [M:RQW1]NBLIG - 1
      If ITER2 <> ITER Then
        If [M:RQW1]ITMREF(ITER2) <> "" Then
          If [M:RQW1]MACSERNUM(ITER2) <> "" Then
            If [M:RQW1]ITMREF(ITER2) = [M:RQW1]ITMREF(ITER) Then
              If [M:RQW1]MACSERNUM(ITER2) = [M:RQW1]MACSERNUM(ITER) Then
                #Des doublons de numéros de série ont été détectés.
                GMESSAGE = mess(468,182,1)
                GERR = 2
                OK = 0
                Break
              Endif
            Endif
          Endif
        Endif
      Endif
    Next
    If GERR Then
      Break
    Endif
  Next
  If GERR Then
    Return
  Endif
Return

##########################################################################################################
#Affichage de l'interlocuteur
######################################################
$DISPCCN
  If [M:RQW1]CCN = "" Then
    [M:RQW1]CCNCLA = ""
  Else
    Read [AIN]AIN0=[M:RQW1]CCN
    If fstat Then
      [M:RQW1]CCNCLA = ""
    Else
      Call BUILDFULNAM("AIN", [M:RQW1]CCNCLA) From CRMUTIL140
    Endif
  Endif
Return

##########################################################################################################
# Suppression des pièces générées par une demande de garantie
######################################################
$DELRQWVCR
Local Integer IMAIMAC
Local Integer IERRMAI
Local Integer IDELCON

  If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif
  If !clalev([F:MAI]) : Local File MACITN [MAI] : Endif
  If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
  If !clalev([F:CCV]) : Local File CONTCOV [CCV] : Endif
  If !clalev([F:CQL]) : Local File CONTQUAL [CQL] : Endif
  If !clalev([F:CAM]) : Local File CONTAMT [CAM] : Endif
  If !clalev([F:CRE]) : Local File CONTREW [CRE] : Endif
  IMAIMAC = 0
  IERRMAI = 0
  IDELCON = 0
  Filter [MAC] Where [F:MAC]MACORI = 5 and [F:MAC]MACORIVCR = [M:RQW0]RQWNUM
  For [MAC]
    IMAIMAC = 0
    Filter [MAI] Where [F:MAI]MACNUM = [M:MAC0]MACNUM
    For [MAI]MAI1
      Call MAIRULE(1, [F:MAC]MACNUM, [F:MAI]CLSNUM, IERRMAI) From TRTMAIRULE
      If IERRMAI Then
        Call FSTA("MAI") From GLOCK
        #Erreur lors de la restauration d'une implantation de parc.
        GMESSAGE = mess(56,177,1)
        GERR = 1
        GOK = 0
      Endif
      IMAIMAC += 1
      Break
    Next
    Filter [MAI]
    If GERR Then
      Break
    Endif
    If IMAIMAC = 0 Then
      Delete [MAC] Curr
      If fstat Then
        Call FSTA("MAC") From GLOCK
        #Erreur lors de la suppression des fiches parc.
        GMESSAGE = mess(55,177,1)
        GERR = 1
        GOK = 0
        Break
      Endif
    Endif
    IDELCON = 0
    Gosub CHKDELCON
    If IDELCON Then
      Gosub DELCON
    Else
      Gosub DELCOV
    Endif
  Next
  Filter [MAC]
Return

##########################################################################################################
# Détermine si la totalité d'un contrat de service peut être supprimé.
#################################################
$CHKDELCON
Return

##########################################################################################################
# Supprime un contrat de service.
#################################################
$DELCON
  Delete [CON] Where [F:CON]CONORI = 5 and [F:CON]CONORIVCR = [M:RQW0]RQWNUM
Return

##########################################################################################################
# Supprime la couverture d'un contrat de service
#################################################
$DELCOV
Return

##########################################################################################################
# Validation de la demande de garantie
#####################################################+
Subprog VALIDATERQW(IERRMAC)
Variable Integer IERRMAC

#Intégration du parc client
Local Integer ITER
Local Integer ICHAPTER
Local Integer IBRETOUR

  Local Mask MACW [MACW]
  # FGR 29/05/2008 : X3SUIVI47027 Déduire la société du site... (début)
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif  # FGR 27/08/2012 : X3SUIVI84034
  # FGR 29/05/2008 : X3SUIVI47027 Déduire la société du site... (fin)
  # FGR 04/01/2011 : X3SUIVI70100 (début) : dès le début pour que tout soit dans la même transaction
  Call DEBTRANS From GLOCK
  Trbegin [RQW]
  # FGR 04/01/2011 : X3SUIVI70100 (fin) : dès le début pour que tout soit dans la même transaction
  #
  ICHAPTER = 0
  IBRETOUR = 1
  IERRMAC = 0
  #Mise à jour du parc client.
  Call TEMPON(mess(90,182,1)) From GESECRAN
  For ITER = 0 To [M:RQW1]NBLIG-1
    If [M:RQW1]ITMREF(ITER) <> "" Then
      Read [ITM]ITM0=[M:RQW1]ITMREF(ITER)
      If !fstat Then
        #Chargement des informations sur le masque parc
        Raz [MACW]
        #Obligatoires
        [M:MACW]MACPDTCOD = [M:RQW1]ITMREF(ITER)
        [M:MACW]MACITNTYP = 1
        [M:MACW]MACORI = 5
        [M:MACW]MACORIVCR = [M:RQW0]RQWNUM
        [M:MACW]MACORIVCRL = [M:RQW1]RQWNUMLIN(ITER)
        #Complémentaires.
        [M:MACW]BPCNUM = [M:RQW1]BPC
        [M:MACW]FCYITN = [M:RQW1]BPAADD
        [M:MACW]CCNNUM = ""
        [M:MACW]MACITNDAT = [M:RQW1]MACBPCDAT(ITER)
        [M:MACW]MACITNLND = 1
        [M:MACW]MACRSL = [M:RQW1]RSL(ITER)
        [M:MACW]MACQTY = [M:RQW1]QTY(ITER)
        [M:MACW]MACSERNUM = [M:RQW1]MACSERNUM(ITER)
        [M:MACW]MACBPCPRI = [M:RQW1]MACBPCPRI(ITER)
        [M:MACW]MACBPCCUR = [M:RQW1]MACBPCCUR(ITER)
        [M:MACW]MACBPCDAT = [M:RQW1]MACBPCDAT(ITER)
        # FGR 27/08/2012 : X3SUIVI84034 (début)
        Read [F:MAC]MAC5=[M:MACW]MACPDTCOD;[M:MACW]MACSERNUM
        If !fstat Then
          [M:MACW]MACSALPRI = [F:MAC]MACSALPRI
          [M:MACW]CUR = [F:MAC]CUR
          [M:MACW]MACPURDAT = [F:MAC]MACPURDAT
        Endif
        # FGR 27/08/2012 : X3SUIVI84034 (fin)
        [M:MACW]MACBRA = [M:RQW1]MACBRA(ITER)
        [M:MACW]PLE = [M:RQW1]PLE(ITER)
        [M:MACW]SALFCY = [M:RQW0]FCY
        # FGR 29/05/2008 : X3SUIVI47027 Déduire la société du site ... (début)
        If [M:MACW]SALFCY <> "" Then
          # Déduit le code société
          Read [FCY]FCY0=[M:MACW]SALFCY
          If !fstat Then
            [M:MACW]CPY = [F:FCY]LEGCPY
          Endif
        Endif
        Read [BPR]BPR0=[M:MACW]BPCNUM
        If !fstat Then
          If [F:BPR]CUR <> "" Then
            [M:MACW]MACBPCCUR = [F:BPR]CUR
          Endif
        Endif
        # FGR 29/05/2008 : X3SUIVI47027 Déduire la société du site (fin)
        #Appel du composant d'intégration
        Call MACRULE(1, [M:RQW1]BPC, IERRMAC) From TRTMACRULE
      Endif
    Endif
    If IERRMAC Then
      Break
    Endif
    #On crédite les points
    Call CDTPOINT([M:RQW1]BPC, [M:RQW1]ITMREF(ITER), [M:RQW1]QTY(ITER), "", "", IERRMAC, ICHAPTER, IBRETOUR) From TRTPOINT
    If IERRMAC Then
      Break
    Endif
  Next
  Call TEMPOFF From GESECRAN
  Close Local Mask [MACW]
  If IERRMAC Then
    GMESSAGE = mess(IERRMAC,182,1)
    GERR = 2
    Rollback  # FGR 04/01/2011 : X3SUIVI70100
    End
  Endif
  #Mise à jour du statut de validation de la demande de garantie
  # FGR 04/01/2011 : X3SUIVI70100 (début) : mis dès le début pour que tout soit dans la même transaction
  #Call DEBTRANS From GLOCK
  #Trbegin [RQW]
  # FGR 04/01/2011 : X3SUIVI70100 (fin) : mis dès le début pour que tout soit dans la même transaction
  Readlock [RQW]RQW0=[M:RQW0]RQWNUM
  If fstat Then
    #La validation de la demande de garantie a échoué.
    GMESSAGE = mess(138,177,1)
    GERR = 1
    Rollback
    Unlock [RQW]
    IERRMAC = 1
    End
  Endif
  [F:RQW]RQWCFMFLG = 2
  [F:RQW]CFMDAT = date$
  [F:RQW]CFMHOU = left$(time$,2) + mid$(time$,4,2)
  [F:RQW]CFMUSR = GUSER
  Rewrite [RQW]
  If fstat Then
    #La validation de la demande de garantie a échoué.
    GMESSAGE = mess(138,177,1)
    GERR = 1
    Rollback
    Unlock [RQW]
    IERRMAC = 1
    End
  Else
    Commit
    Unlock [RQW]
  Endif
  [M:RQW0]RQWCFMFLG = 2
  [M:RQW1]CFMDAT = date$
  [M:RQW1]CFMHOU = left$(time$,2) + mid$(time$,4,2)
  [M:RQW1]CFMUSR = GUSER
  #Nom du valideur de la demande
  If [M:RQW1]CFMUSR = "" Then
    Raz [M:RQW1]CFMDAT
    Raz [M:RQW1]CFMHOU
    Raz [M:RQW1]CFMUSR
    Raz [M:RQW1]CFMUSRCLA
  Else
    Read [AUS]CODUSR=[M:RQW1]CFMUSR
    If fstat Then
      [M:RQW1]CFMUSRCLA = [M:RQW1]CFMUSR
    Else
      [M:RQW1]CFMUSRCLA = [F:AUS]NOMUSR
    Endif
  Endif
  Grizo [M:RQW0]
  Grizo [M:RQW1]
  Affzo [M:RQW0]1-99
  Affzo [M:RQW1]1-99
End
