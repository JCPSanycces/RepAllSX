######################################################################################################################

#-------------------------------------------------------------------------------------
$CRIT_IMLRVEISS
 L_CRIT2  = "AASREF=[F:FAS]AASREF"
 L_CRIT3  = "IMLBLC<>0"
Return

#-------------------------------------------------------------------------------------
$NBR_IMLRVEISS
 Gosub CRIT_IMLRVEISS From UPDWAICOM
# For [FAS] Where CPY=[F:CPY]CPY & ISSDAT<>[0/0/0] & EXTISSFLG<>G_OUI : # FQ67765
For [FAS] Where evalue(L_CRITFAS) & ISSDAT<>[0/0/0] & EXTISSFLG<>G_OUI
  Gosub NBR_BCO From UPDWAICNX
 Next
Return

#-------------------------------------------------------------------------------------
$MAJ_IMLRVEISS
 L_PARNAM = "IMLRVEISS"
 Gosub CRIT_IMLRVEISS From UPDWAICOM
 Gosub DET_TRC From UPDWAITRT
 Gosub SET_OK  From UPDWAITRT : # FQ87970
# For [FAS] Where CPY=[F:CPY]CPY & ISSDAT<>[0/0/0] & EXTISSFLG<>G_OUI : # FQ67765
 For [FAS] Where evalue(L_CRITFAS) & ISSDAT<>[0/0/0] & EXTISSFLG<>G_OUI
  Gosub UPD_BCO From UPDWAITRT
 Next
Return

