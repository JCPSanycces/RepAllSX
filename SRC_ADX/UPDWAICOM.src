  Gosub UPD_BCO From UPDWAITRT
 Next
Return

###################################################################################################################### FQ66894
# MODIFICATION DES FLUX                                                                                              #
######################################################################################################################

#-------------------------------------------------------------------------------------
CRIT_FLUX
 L_CRIT1  = "CPY=L_CPY & (ISSDAT>=L_DEBEXE | ISSDAT=[0/0/0])"
 L_CRIT2  = "1=1"
 L_CRIT3  = "1=1"
Return

#-------------------------------------------------------------------------------------
$NBR_FLUX
 Gosub CRIT_FLUX From UPDWAICOM
 Filter [F:FAS] Where evalue(L_CRIT1) & evalue(L_CRIT2) & evalue(L_CRIT3)
 L_NBBCO=rowcount([F:FAS])
 L_NBENR=L_NBBCO
 Filter [F:FAS]
Return

#-------------------------------------------------------------------------------------
$MAJ_FLUX
 L_PARNAM = "FLUX"
 Gosub CRIT_FLUX From UPDWAICOM
 Gosub DET_TRC From UPDWAITRT
 Gosub UPD_FAS From UPDWAITRT
Return


