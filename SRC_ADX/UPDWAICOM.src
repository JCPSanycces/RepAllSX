 # For [FAS] Where CPY=[F:CPY]CPY & ISSDAT<>[0/0/0] & EXTISSFLG<>G_OUI : # FQ67765
 For [FAS] Where LCRIT_FAS & CPY=[F:CPY]CPY & ISSDAT<>[0/0/0] & EXTISSFLG<>G_OUI
