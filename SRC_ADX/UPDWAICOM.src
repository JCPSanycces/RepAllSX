######################################################################################################################
# MODIFICATION DU PARAMETRE GENERAL "DEROGATOIRE SUR IMMO EN COURS"                                                  #
######################################################################################################################

#-------------------------------------------------------------------------------------
$CRIT_DEROENCOUR
 L_CRIT2  = "AASREF=[F:FAS]AASREF"
 L_CRIT3  = "DPRPLN=G301FIS"
Return

#-------------------------------------------------------------------------------------
$NBR_DEROENCOUR
 Gosub CRIT_DEROENCOUR From UPDWAICOM
# For [FAS] Where CPY=[F:CPY]CPY & ENAFAS=G_OUI & ( GACACN=GVML_NIENCOU | IASACN=GVML_NIENCOU ) : # FQ67765
 For [FAS] Where evalue(L_CRITFAS) & ( GACACN=GVML_NIENCOU | IASACN=GVML_NIENCOU )
  Gosub NBR_BCO From UPDWAICNX
 Next
Return

#-------------------------------------------------------------------------------------
$MAJ_DEROENCOUR
 L_PARNAM = "DEROENCOUR"
 Gosub CRIT_DEROENCOUR From UPDWAICOM
 Gosub DET_TRC From UPDWAITRT
 Gosub SET_OK  From UPDWAITRT : # FQ87970
# For [FAS] Where CPY=[F:CPY]CPY  & ( GACACN=GVML_NIENCOU | IASACN=GVML_NIENCOU ) : # FQ67765
 For [FAS] Where evalue(L_CRITFAS) & ( GACACN=GVML_NIENCOU | IASACN=GVML_NIENCOU )
  Gosub UPD_BCO From UPDWAITRT
 Next
Return

