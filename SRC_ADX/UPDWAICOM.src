########################################################################################################################

#-------------------------------------------------------------------------------------
$CRIT_CALCNX
 # L_CRIT2="1=1" : # FQ67765
 L_CRIT2="AASREF=[F:FAS]AASREF"
 L_CRIT3="1=1"
Return

#-------------------------------------------------------------------------------------
$NBR_CALCNX
 Gosub CRIT_CALCNX From UPDWAICOM
 For [FAS] Where evalue(L_CRITFAS) : # FQ67765
   Gosub NBR_BCO From UPDWAICNX
 Next
Return

#-------------------------------------------------------------------------------------
$MAJ_CALCNX
 L_PARNAM = "CALCNX"
 Gosub CRIT_CALCNX From UPDWAICOM
 Gosub DET_TRC From UPDWAITRT
 Gosub SET_OK  From UPDWAITRT : # FQ87970
 For [FAS] Where evalue(L_CRITFAS) : # FQ67765
  Gosub UPD_BCO From UPDWAITRT
 Next
Return

