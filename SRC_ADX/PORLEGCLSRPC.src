#<AdxTL>@(#)0.0.0.0 $Revision$
#example :http://localhost:8124/sdata/x3/erp/X3/$service/rpc?module=PORLEGCLSRPC&name=SUBMITCB
Funprog _EXPORTED() : End 1
################################################################
################################################################
# PORLEGCLS
################################################################
################################################################
$ACTION

Case ACTION
  When "SUBMITCB" : Gosub SUBMITCB
Endcase

Return
################################################################
################################################################
$SUBMITCB

#parameters in PAYLOADCLB
#return value in RETURNCLB

If !clalev([F:DKD]) : Local File DKSDATA [DKD] : Endif

Local Char EFAT_STAT(2)
Local Char EFAT_NUM(GLONVCR+5)
Local Char EFAT_CREATED(40)
Local Char EFAT_RESPONDED(40)
Local Char EFAT_CODE(10)
Local Char EFAT_MESSAGE(255)
Local Char EFAT_SOURCE(30)
Local Char EFAT_UDEXPIRES(40)
Local Char EFAT_UDPRIVATEURL(255)
Local Char EFAT_UDURL(255)
Local Char EFAT_UDSENT(40)
Local Char EFAT_UDACCESS(50)
Local Char EFAT_UDACCESSIP(50)

Local Char    X3DOCTYP(GLONTSV)
Local Char    X3DOCNUM(GLONVCR)
Local Integer I

EFAT_STAT = func AJSONLIB.GET_PROP(PAYLOADCLB,"STAT")
EFAT_NUM = func AJSONLIB.GET_PROP(PAYLOADCLB,"NUM")
EFAT_CREATED = func AJSONLIB.GET_PROP(PAYLOADCLB,"CREATED")
EFAT_RESPONDED = func AJSONLIB.GET_PROP(PAYLOADCLB,"RESPONDED")
EFAT_CODE = func AJSONLIB.GET_PROP(PAYLOADCLB,"CODE")
EFAT_MESSAGE = func AJSONLIB.GET_PROP(PAYLOADCLB,"MESSAGE")
EFAT_SOURCE = func AJSONLIB.GET_PROP(PAYLOADCLB,"SOURCE")
EFAT_UDEXPIRES = func AJSONLIB.GET_PROP(PAYLOADCLB,"UDEXPIRES")
EFAT_UDPRIVATEURL = func AJSONLIB.GET_PROP(PAYLOADCLB,"UDPRIVATEURL")
EFAT_UDURL = func AJSONLIB.GET_PROP(PAYLOADCLB,"UDURL")
EFAT_UDSENT = func AJSONLIB.GET_PROP(PAYLOADCLB,"UDSENT")
EFAT_UDACCESS = func AJSONLIB.GET_PROP(PAYLOADCLB,"UDACCESS")
EFAT_UDACCESSIP = func AJSONLIB.GET_PROP(PAYLOADCLB,"UDACCESSIP")

I = instr(1,EFAT_NUM," ")
X3DOCTYP = left$(EFAT_NUM,I-1)
X3DOCNUM = right$(EFAT_NUM,I+1)

If len(EFAT_UDSENT) <10 : EFAT_UDSENT = "" : Endif #date when efat sent the e-mail with the document link to the customer
If len(EFAT_UDACCESS) <10 : EFAT_UDACCESS = "" : Endif #date when the customer accessed the document pdf
If len(EFAT_UDEXPIRES) <10 : EFAT_UDEXPIRES = "" : Endif #date when the link to access the document pdf expires
If len(EFAT_UDACCESSIP) <12 : EFAT_UDACCESSIP = "" : Endif #IP from which the customer accessed the document pdf
If len(EFAT_UDPRIVATEURL) <18 : EFAT_UDPRIVATEURL = "" : Endif #Private url that can be used to access the document pdf without trigger the 'accessed'
If len(EFAT_SOURCE) <2 : EFAT_SOURCE = "" : Endif #Source (\ATService)
If len(EFAT_MESSAGE) <2 : EFAT_MESSAGE = "" : Endif #Private url that can be used to access the document pdf without trigger the 'accessed'

# Issue X3-91732 by MRDAB
Filter [F:DKD] Where ctrans([F:DKD]DOCNUM, "-_", "") = ctrans([L]EFAT_NUM, "-_", "") & [F:DKD]DOCTYP = X3DOCTYP
# Issue end

Read [F:DKD] First
If !fstat

  If EFAT_SOURCE = "ATService"
    If EFAT_CODE = "0"
      [F:DKD]ATEI = 5
      [F:DKD]EFATMESS = ""
    Else
      [F:DKD]ATEI = 2
      [F:DKD]EFATMESS = EFAT_CODE+"-"+EFAT_MESSAGE
    Endif
  Endif

  #MailService
  #[F:DKD]BPEI
  If EFAT_UDACCESS <> "" #& [F:DKD]ACCESSDATE = [0/0/0]
    [F:DKD]ACCESSDATE = gdat$(val(mid$(EFAT_UDACCESS,9,2)),val(mid$(EFAT_UDACCESS,6,2)),val(left$(EFAT_UDACCESS,4)))
    [F:DKD]ACCESSTIME = right$(EFAT_UDACCESS,12)
    [F:DKD]BPEI = 5
  Endif

  If EFAT_UDPRIVATEURL <> "" : [F:DKD]DOCLINK = EFAT_UDPRIVATEURL : Endif
  If EFAT_UDEXPIRES <> "" : [F:DKD]EXPDATE = gdat$(val(mid$(EFAT_UDEXPIRES,9,2)),val(mid$(EFAT_UDEXPIRES,6,2)),val(left$(EFAT_UDEXPIRES,4))) : Endif
  If EFAT_UDACCESSIP <> "" : [F:DKD]ACCESSIP = EFAT_UDACCESSIP : Endif
  #If EFAT_UDSENT <> "" : [F:DKD]EFATSENT = gdat$(val(mid$(EFAT_UDSENT,9,2)),val(mid$(EFAT_UDSENT,6,2)),val(left$(EFAT_UDSENT,4))) : Endif
  If EFAT_UDSENT <> "" : [F:DKD]EFATSENT = EFAT_UDSENT : Endif

  Rewrite [F:DKD]

Endif
Filter [F:DKD]

RETURNCLB=""

Return
################################################################
################################################################

