#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","MAJPAIEMS","MAJPAIEMS",4,"") From GTRAITE
End

#########################################
## Traitement des actions : MAJPAIEMS
#########################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "OUVRE_BATCH" : Gosub OUVFIC : #LS 27/11/07 pour tâche batch lancée en web
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "DEBUT"       : Affzo [DIA]: Setmok [DIA] With 0
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 :# GOK = 0
 When "FERME"       : Gosub FERME
Endcase
Return

#######################################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#######################################################
## (Actions nécessaires à la saisie des paramètres)
#######################################################
$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG = 'FRA' #Total Payroll is FRA only

Local Char    VALPAR(10) , MATRI(GLONEML) , CTR(GLONHRCTR)
Local Integer NBRUB , MAXMCH , CRIOK , M , NEWEMP , CTRLEMP
Local Date    DATMAT , DATPAY

Local Char    CRITERE(250)
Local Char    CRITERE2(250) #70009
Local Char    CRITMHS(250)

Local Date    SAVDAT
Local Char    SAVEMP (GLONEML)
Local Char    SAVCTR (GLONHRCTR)
Local Integer SAVNRUB

# Tableaux des scénarii traités
Local Char    MCHCOD (GLONMCH)(1..200)

Local Date    MCHDAT (1..dim(MCHCOD))
Local Integer MCHOK  (1..dim(MCHCOD))
Local Integer EMPOK  (1..dim(MCHCOD))

Local Char    MESSMS(250)

#70018
Local Integer I
Local Char    FCYGRP(GLONFCY)(1..999)
#end 70018

Gosub OUVFIC

TIT = mess(24,10722,1)     : # Mise à jour des paies dans la Masse Salariale

Local Mask MAJPAIEMS [DIA]
Raz [M:DIA]
[M:DIA]DATPAYSTR = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
[M:DIA]DATPAYEND = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
Call LECMEMO("STD","[M:DIA]","mms") From GMEMO
Return

######################################################
## Ouverture des tables
######################################################
$OUVFIC
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ADW])=0 : Local File ADOVAL     [ADW] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
If clalev([F:CRB])=0 : Local File CALRUB     [CRB] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE   [RUB] : Endif
If clalev([F:HRPOA])=0 : Local File POPULA     [HRPOA] : Endif
If clalev([F:ECT])=0 : Local File EMPCTR     [ECT] : Endif
If clalev([F:HSP])=0 : Local File HISTOPAYE  [HSP] : Endif
If clalev([F:MHS])=0 : Local File MSHISTO    [MHS] : Endif
If clalev([F:MH2])=0 : Local File MSHISTO    [MH2] : Endif
If clalev([F:MCH])=0 : Local File MSSCENAH   [MCH] : Endif
If clalev([F:MCL])=0 : Local File MSSCENAL   [MCL] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
If clalev([F:MHH])=0 : Local File MSHISTOH   [MHH] : Endif

#70018
If !clalev([F:FGR]) : Local File FACGROUP [FGR] : Endif
#end 70018

Gosub OUVRE From WPDEFTABLE
Return

#######################################################
## Contrôle des paramètres
#######################################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
 Return
Else
 TMP = 1
 TRA = 1
Endif
#Seul les scénarii déjà calculés sont mis à jour
#On vérifie que le calcul MS a déjà été lancé
Gosub SEL_MHS
Filter [F:MHS] Where evalue(CRITMHS)
Look [F:MHS] First
If fstat
 GERR=1
 GMESSAGE = mess(26,10722,1) : #Aucun scénario calculé à ces dates
Endif
Filter [MHS]

Return

#######################################################
##
#######################################################
$EXEC
Local Integer NOK, T , INTE
Local Char    SYMBOLE(80)

# ouverture de la trace et écriture de l'en-tête

If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN


#---
Call TEMPON (mess(29,10722,1)) From GESECRAN : # Initialisation du calcul

# Effacement de l'historique MS
If [M:DIA]ENAFLG = 2
 Call DEBTRANS From GLOCK
 Gosub TR_EFFACE
 If GOK<=0 : Return : Endif
Endif

Call OUVRE_BOITE(mess(33,10722,1),0) From GESECRAN : # Mise à jour masse salariale

#Filtre Historique de paye
CRITERE  =   '[F:HSP]DAT>=['+format$(GFMD,[M:DIA]DATPAYSTR)+']'
CRITERE -= '& [F:HSP]DAT<=['+format$(GFMD,[M:DIA]DATPAYEND)+']'
CRITERE2 = "1=1" #70009
#70018
If [M:DIA]ALLFCY<>2
 CRITERE -= '& [F:ECT]FCY="'+[M:DIA]FCY+'"'
Elsif [M:DIA]ALLCPY<>2  #société
 Read [CPY]CPY0=[M:DIA]CPY
 If !fstat & [F:CPY]CPYLEGFLG=2    : # Société juridique
  CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
 Elsif !fstat & [F:CPY]CPYLEGFLG=1 : # Société non juridique
  I=1
  For [FGR]FGR0 Where CPY=[M:DIA]CPY
   If !find([F:FGR]FCY,FCYGRP(1..I))
    FCYGRP(I) = [F:FGR]FCY
    I +=1
   Endif
  Next
  If I>1
   CRITERE -= '& find([F:ECT]FCY, FCYGRP(1..'+num$(I-1)+'))'
  Endif
 Endif
Endif
#end 70018

If [M:DIA]ALLSRV<>2
 CRITERE -= '& [F:ECT]SRV="'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLPRF<>2
 CRITERE -= '& [F:ECT]PRF="'+[M:DIA]PRF+'"'
Endif
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITERE -= '& [F:HSP]EMP>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITERE -= '& [F:HSP]EMP<="'+[M:DIA]MATFIN+'"'
Endif
#70009
If [M:DIA]JOBPOT<>""
  CRITERE2 = '[F:HRCTR]JOBPOT="'+[M:DIA]JOBPOT+'"'
Endif
If [M:DIA]POT<>""
  CRITERE2 -= '& [F:HRCTR]POT="'+[M:DIA]POT+'"'
Endif

#end 70009

# Alimentation historique MS
# 63613 : Ajout clause Order by
If [M:DIA]POP<>""
 Link [F:HSP] With
&   [F:ID]ID0    = [F:HSP]EMP
&,  [F:ECT]ECT0  = [F:HSP]EMP;[F:HSP]CTRNUM
&,  [FCY]FCY0    = [F:ECT]FCY
&,  [F:HRPOA]POA0  = [M:DIA]POP;[F:HSP]EMP
&,  [F:HRCTR]CTR0  = [F:HSP]EMP;[F:HSP]CTRNUM
&   As [LNK]
&   Where [F:HRPOA]REFNUM<>"" & evalue(CRITERE) & evalue(CRITERE2)
&   Order By Key CLE=[F:HSP]EMP;[F:HSP]CTRNUM;[F:HSP]DAT;[F:HSP]ROW
Else
 Link [F:HSP] With
&   [F:ID]ID0    = [F:HSP]EMP
&,  [F:ECT]ECT0  = [F:HSP]EMP;[F:HSP]CTRNUM
&,  [FCY]FCY0    = [F:ECT]FCY
&,  [F:HRCTR]CTR0  = [F:HSP]EMP;[F:HSP]CTRNUM
&   As [LNK]
&   Where evalue(CRITERE) & evalue(CRITERE2)
&   Order By Key CLE=[F:HSP]EMP;[F:HSP]CTRNUM;[F:HSP]DAT;[F:HSP]ROW
Endif

Call SET_BOITE(mess(33,10722,1),rowcount([LNK])) From GESECRAN : # Mise à jour masse salariale

Call DEBTRANS From GLOCK
Gosub TR1

Filter [MHS]
Unlock =SYMBOLE

# Sauvegarde date maj sur scénarii
If GOK = 1
 Call DEBTRANS From GLOCK
 Gosub TR2
Endif

If GOK = 1
 If !NBRUB
  Call ECR_TRACE(mess(2,10703,1),0) From GESECRAN : # Aucun matricule à traiter
 Else
  Call ECR_TRACE(num$(NBRUB)-mess(192,124,1),0) From GESECRAN : # Enregistrements mis à jour
 Endif
Endif

Call FERME_BOITE From GESECRAN

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif

Return

################################################################################
$TR_EFFACE
GOK = 1
Raz CRITMHS
Gosub FILT_MHS : # Filtre des enreg histo MS à supprimer

Trbegin [MH2]
 If [M:DIA]POP =""
  Delete [MH2] Where evalue(CRITMHS)
  Delete [MHH] Where evalue(CRITMHS)
 Else
  For [LN2] Where evalue(CRITMHS)
   Delete [F:MH2]Curr
   If fstat : Break : Endif
  Next
  For [LN3] Where evalue(CRITMHS)
   Delete [F:MHH]Curr
   If fstat : Break : Endif
  Next
 Endif
 If fstat=1 | fstat>5
  GOK=-1 : Goto ROLL_TR_EFFACE
 Endif
Commit
Return

$ROLL_TR_EFFACE
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_EFFACE: Endif

################################################################################
$TR1
GOK = 1
T = 0

#Filtre historique MS
Gosub SEL_MHS
Filter [MHS] Where evalue(CRITMHS)

SYMBOLE = "MCH"
Lock =SYMBOLE
If fstat
 Call ECR_TRACE(MCHCOD(M)-":"-mess(10,100,1),1) From GESECRAN :#modif en cours sur un autre poste
 GOK = 0 : Return
Endif

NEWEMP = 0

Trbegin [MHS]
 #63613
 #For [LNK]HSP0      :#Parcours par salarié
 For [LNK]CLE        :#Parcours par salarié
  If [F:CTR]CTRDAT <= [F:HSP]DAT
    T+=1
    Call AFF_BOITE([F:HSP]EMP-[F:HSP]CTRNUM,T,INTE) From GESECRAN
    NEWEMP = 0
    If [F:HSP]EMP <> SAVEMP | [F:HSP]CTRNUM <> SAVCTR
     NEWEMP = 1
     If NBRUB <> SAVNRUB    :# au moins une maj de l'histo a été efféctuée
      Commit
      Trbegin [MHS]
     Endif
     SAVEMP = [F:HSP]EMP
     SAVCTR = [F:HSP]CTRNUM
     SAVNRUB = NBRUB
    Endif

    If [F:HSP]AMT <> 0
     Gosub RUBRIQUE
     If GOK<1 : Break : Endif
    Endif
  Endif
 Next

 If GOK
  Commit
 Else
  Gosub AB_TR
 Endif
Return

$AB_TR
Rollback
GMESSAGE = mess (17,107,1) :#Rollback suite à une erreur dans la transaction
Return

$RIEN
Resume

################################################################################
#   fiches scénarii : mise à jour des dates d'intégration
#   des montants réels dans l'historique MS

$TR2
If M > 0
 GOK = 1
 Trbegin [MCH]
  For M = 1 To MAXMCH
   Readlock [F:MCH]MCH0 = MCHCOD(M)
   If fstat=1
    GOK = -1 : GLOCK = "$MCHUPD"-MCHCOD(M) : Break
   Elsif fstat
    GOK = 0 : Call RSTA("MCH",MCHCOD(M)) From GLOCK : Break
   Endif
   #59615 : Ajout du test
   # Sauvegarde de la date si elle est supérieure à la précédente sinon la consultation de la projection est erronnée
   If [F:MCH]DATMAJREA<MCHDAT(M)
    [F:MCH]DATMAJREA = MCHDAT(M)
    Rewrite [F:MCH]
    If fstat
     GOK = 0 : Call FSTA("MCH") From GLOCK : Break
    Endif
   Endif
  Next
  If   GOK<0 : Goto ROLL_TR2
  Elsif !GOK : Goto AB_TR2
  Endif
 Commit
Endif
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

################################################################################
$RUBRIQUE
#Alimentation du montant réel dans l'historique MS
#63613
#If NEWEMP
 #T +=1
 # Matricule ... bulletin du
 #Call ECR_TRACE(mess(80,10703,1)-[F:HSP]EMP-"("-[F:HSP]CTRNUM-")"-mess(34,10722,1)-format$("D:"+GFMDAT,[F:HSP]DAT),0) From GESECRAN
 #Call AFF_BOITE([F:HSP]EMP-[F:HSP]CTRNUM-format$("D:"+GFMDAT,[F:HSP]DAT),T,INTE) From GESECRAN
#Endif

# Vérification que les scénarii ont un historique calculé à la date paie
# On vérifie les témoins du scénario et la présence de calcul dans l'historiqe
If  [F:HSP]DAT <> SAVDAT
 Raz MCHOK
 #59615 : simplification
 #For [F:MCH] Where [F:MCH]STA = 2 & [F:MCH]FLGCLO = 2
#&               & (   ([F:MCH]STRDAT >= [M:DIA]DATPAYSTR & [F:MCH]STRDAT <= [M:DIA]DATPAYEND )
#&                   | ([F:MCH]ENDDAT >= [M:DIA]DATPAYSTR & [F:MCH]ENDDAT <= [M:DIA]DATPAYEND ))
# Corrigé en même temps que 63616 mais sans rapport
# For [F:MCH] Where [F:MCH]STA = 2 & [F:MCH]FLGCLO = 2 & [M:DIA]DATPAYEND>=[F:MCH]STRDAT & [F:MCH]STRDAT<=[F:MCH]ENDDAT
 For [F:MCH] Where [F:MCH]STA = 2 & [F:MCH]FLGCLO = 2 & [M:DIA]DATPAYEND>=[F:MCH]STRDAT & [M:DIA]DATPAYSTR<=[F:MCH]ENDDAT
  Gosub CADRAGE_DATE                           : # recherche de DATPAY
  Look [F:MHS]MHS3 = [F:MCH]COD;DATPAY         : #nb : la classe [MHS] est filtrée
  If !fstat
   M = find([F:MCH]COD,MCHCOD(1..MAXMCH))
   If M <> 0
    MCHOK(M) = 1
    #59615
    #CTRLEMP = 1                                : # pour déclencher la vérification du salarié
   Else
    MAXMCH += 1
    If MAXMCH <= dim(MCHCOD)
     M = MAXMCH
     MCHCOD(M) = [F:MCH]COD
     MCHOK(M)  = 1
     # 59615
     CTRLEMP   = 1                             : # pour déclencher la vérification du salarié
    Else
     Call ECR_TRACE(mess (27,10722,1),1) From GESECRAN : # Tableau des scénarii valides plein
     Break
    Endif
   Endif
   MCHDAT(M) = [F:HSP]DAT : # sauvegarde de la date pour la stocker dans le scénario
  Endif
 Next
 SAVDAT = [F:HSP]DAT
Endif

## Vérification que le salarié répond au critère libre de la mise à jour
If NEWEMP
 CRIOK=1
 If [M:DIA]CRI<>""
  MATRI = [F:HSP]EMP
  CTR   = [F:HSP]CTRNUM
  DATMAT= datesyst
  Gosub LECEMP From WPDEFTABLE
  If !evalue([M:DIA]CRI)
   CRIOK = 0
  Endif
 Endif
 Raz EMPOK
 # 59613 : gestion de la variable CTRLEMP
 # 63613
 CTRLEMP = 1
Endif

# Vérification que le salarié répond aux critères des scénarii calculés et définitifs
If CRIOK & CTRLEMP
 Local Char    LSTFCY(5)(0..)
 Local Integer I
 For M = 1 To MAXMCH
  If MCHOK(M) = 1
   Read [F:MCH]MCH0 = MCHCOD(M)
   If !fstat
    # FQ76308 - MABON 16/09/11 - Il faut prendre en compte les groupes de sites
    If [F:MCH]CPY<>"" Then
      I=0 : Raz LSTFCY
      Filter [F:FGR] Where CPY=[F:MCH]CPY
      For [F:FGR]
        LSTFCY(I)=[F:FGR]FCY
        I+=1
      Next
      Filter [F:FGR]
    Endif
    # Fin MABON + Ajout find() sur ligne sur [F:MCH]CPY
    If ([F:MCH]STRMAT = "" | [F:MCH]STRMAT <= [F:HSP]EMP)
&   &  ([F:MCH]ENDMAT = "" | [F:MCH]ENDMAT >= [F:HSP]EMP)
&   &  ([F:MCH]CPY = ""    | [F:MCH]CPY     = [F:FCY]LEGCPY)
&   &  ([F:MCH]FCY = ""    | [F:MCH]FCY     = [F:ECT]FCY)
&   &  ([F:MCH]SRV = ""    | [F:MCH]SRV     = [F:ECT]SRV)
&   &  ([F:MCH]PRF = ""    | [F:MCH]PRF     = [F:ECT]PRF)
&   &  ([F:MCH]JOBPOT = "" | [F:MCH]JOBPOT  = [F:HRCTR]JOBPOT)
&   &  ([F:MCH]POT = ""    | [F:MCH]POT     = [F:HRCTR]POT)
     #63613 [F:MCH]POP au lieu de [M:DIA]POP

     # / 73282
     If   NEWEMP & [F:MCH]CRI <> "" & [F:HSP]EMP <> [F:HRCTR]REFNUM & [F:HSP]CTRNUM <> [F:HRCTR]CTRNUM
      MATRI = [F:HSP]EMP
      CTR   = [F:HSP]CTRNUM
      DATMAT= [F:HSP]DAT
      Gosub LECEMP From WPDEFTABLE
     Endif
     #   73282 /

     If [F:MCH]POP <> ""
      Read [F:HRPOA]POA0=[F:MCH]POP;[F:HSP]EMP
     Endif
     If !fstat & ( [F:MCH]CRI = "" | evalue([F:MCH]CRI) )  : # 73282
      EMPOK(M) = 1
     Endif
    Endif
   Endif
  Endif
  CTRLEMP = 0  : # pour ne faire cette vérif qu'une fois par salarié mis dans la boucle pour être
                 # maj qd on est passé sur un scénario calculé
 Next
Endif
# fin 59613

# parcours des scénarii éligibles pour mise à jour
For M = 1 To MAXMCH
 If MCHOK(M) & EMPOK(M)
  Call DEBTRANS From GLOCK
  #63613
  #Read [F:MHS]MHS0 = MCHCOD(M);0;[F:HSP]EMP;[F:HSP]CTRNUM;"";[F:HSP]DAT;[F:HSP]RUB;[F:HSP]TYP
  Read [F:MHS]MHS0 = MCHCOD(M);0;[F:HSP]EMP;[F:HSP]CTRNUM;"";[F:HSP]DAT;[F:HSP]RUB;[F:HSP]TYP;1
  Gosub ECRIT_MSHISTO
  If GOK<1 : Break : Endif
 Endif
Next

Return


################################################################################
# Création ou mise à jour dans l'historique Masse Salariale
################################################################################
$ECRIT_MSHISTO
GOK = 1
#63613
#If !fstat : # Paie salarié déjà dans la MS
# MESSMS = mess(44,187,1)-".: "-MCHCOD(M) : # Non effectué
#Else      : # Salarié nouveau dans la MS
# MESSMS = mess(32,141,1)-".....: "-MCHCOD(M) : # Création de

If fstat
# fin 63613
 Raz [F:MHS]
 [F:MHS]COD    = MCHCOD(M)
 [F:MHS]EMP    = [F:HSP]EMP
 [F:MHS]CTR    = [F:HSP]CTRNUM
 [F:MHS]DAT    = [F:HSP]DAT
 [F:MHS]RUB    = [F:HSP]RUB
 [F:MHS]TYP    = [F:HSP]TYP
 [F:MHS]BAS    = [F:HSP]BAS
 [F:MHS]RAT    = [F:HSP]RAT
 [F:MHS]REA    = [F:HSP]AMT
 [F:MHS]FCY    = [F:ECT]FCY
 [F:MHS]PRF    = [F:ECT]PRF
 [F:MHS]SRV    = [F:ECT]SRV
 [F:MHS]CPY    = [F:FCY]LEGCPY
# [F:MHS]POT    = POSTE
# [F:MHS]JOBPOT = EMPLOITYP
 [F:MHS]SIM    = 1
 Read [F:RUB]RUB0 = GCURLEG;[F:HSP]RUB
 If !fstat
  [F:MHS]GRP = [F:RUB]CODGRP
  Read [F:ADI]CODE=10654;[F:RUB]CODGRP
  If !fstat
   [F:MHS]CAT = [F:ADI]A1
  Endif
 Endif
 Write [F:MHS]
 If [F:MHS]GRP <> "" : # Dans cette tables uniquement ce qui servira pour les consultations
  [F:MHH] = [F:MHS]
  [F:MHH]POT    = [F:HRCTR]POT
  [F:MHH]JOBPOT = [F:HRCTR]JOBPOT
  Write [MHH]
  If fstat
   GOK = 0 : Call FSTA("MHH") From GLOCK
  Endif
 Endif

 #63613
 If fstat
  GOK = 0 : Call FSTA("MHS") From GLOCK : Return
 Else
  NBRUB += 1
  If NEWEMP
   # Matricule ... bulletin du
   Call ECR_TRACE(mess(80,10703,1)-[F:HSP]EMP-[F:ID]NAM-[F:ID]SRN-"("+[F:HSP]CTRNUM+")",0) From GESECRAN
  Endif
  # Création de .....: scénario bulletin du jj/mm/aa rubrique/cumul
  MESSMS = mess(32,141,1)-".....: "-MCHCOD(M)
  MESSMS-= mess(34,10722,1)-format$("D:"+GFMDAT,[F:HSP]DAT)-[F:HSP]RUB
  If [F:HSP]TYP=2
   MESSMS -= mess(1,10344,1)
  Elsif TYP<7
   MESSMS -= mess([F:HSP]TYP,10344,1)
  #Tax Band
  Elsif TYP>9
   MESSMS -= mess([F:HSP]TYP-2,10344,1)
  Endif
  Call ECR_TRACE(MESSMS,0) From GESECRAN
 Endif
 # fin 63613
Endif

#63613
#If fstat
# GOK = 0 : Call FSTA("MHS") From GLOCK
#Else
# NBRUB += 1
#Endif

#MESSMS -= [F:HSP]EMP-[F:HSP]CTRNUM-format$("D:"+GFMDAT,[F:HSP]DAT)-[F:HSP]RUB-num$([F:HSP]TYP)
#Call ECR_TRACE(MESSMS,0) From GESECRAN
#fin 63613

Return
################################################################################
$SEL_MHS
Raz CRITMHS
CRITMHS  =   '[F:MHS]DAT>=['+format$(GFMD,[M:DIA]DATPAYSTR)+']'
CRITMHS -= '& [F:MHS]DAT<=['+format$(GFMD,[M:DIA]DATPAYEND)+']'
If [M:DIA]CODSTR<>""  : #Scénario début
 CRITMHS -= '& [F:MHS]COD>="'+[M:DIA]CODSTR+'"'
Endif
If [M:DIA]CODEND<>""  : #Scénario fin
 CRITMHS -= '& [F:MHS]COD<="'+[M:DIA]CODEND+'"'
Endif
Return
################################################################################
$FILT_MHS
#Filtre réel dans Historique Masse Salariale
If [M:DIA]POP<>""
 Link [F:MH2] With
&   [F:HRPOA]POA0  = [M:DIA]POP;[F:MH2]EMP
&   As [LN2]
&   Where [F:HRPOA]REFNUM<>""

 Link [F:MHH] With
&   [F:HRPOA]POA0  = [M:DIA]POP;[F:MHH]EMP
&   As [LN3]
&   Where [F:HRPOA]REFNUM<>""

Endif
Raz CRITMHS
#63613
#CRITMHS = '[F:MH2]BUD=""'
CRITMHS = 'SIM=1'
CRITMHS -= '& DAT>=['+format$(GFMD,[M:DIA]DATPAYSTR)+']'
CRITMHS -= '& DAT<=['+format$(GFMD,[M:DIA]DATPAYEND)+']'

If [M:DIA]CODSTR<>""  : #Scénario début
 CRITMHS -= '& COD>="'+[M:DIA]CODSTR+'"'
Endif
If [M:DIA]CODEND<>""  : #Scénario fin
 CRITMHS -= '& COD<="'+[M:DIA]CODEND+'"'
Endif

#70018
If [M:DIA]ALLFCY<>2
 CRITMHS -= '& FCY="'+[M:DIA]FCY+'"'
Elsif [M:DIA]ALLCPY<>2  #société
 Read [CPY]CPY0=[M:DIA]CPY
 If !fstat & [F:CPY]CPYLEGFLG=2    : # Société juridique
  CRITMHS -= '& CPY="'+[M:DIA]CPY+'"'
 Elsif !fstat & [F:CPY]CPYLEGFLG=1 : # Société non juridique
  I=1
  For [FGR]FGR0 Where CPY=[M:DIA]CPY
   If !find([F:FGR]FCY, FCYGRP(1..I))
    FCYGRP(I) = [F:FGR]FCY
    I +=1
   Endif
  Next
  If I>1
   CRITMHS -= '& find(FCY, FCYGRP(1..'+num$(I-1)+'))'
  Endif
 Endif
Endif
#end 70018

If [M:DIA]ALLSRV<>2
 CRITMHS -= '& SRV="'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLPRF<>2
 CRITMHS -= '& PRF="'+[M:DIA]PRF+'"'
Endif

If [M:DIA]MATDEB<>"" #borne début matricule
 CRITMHS -= '& EMP>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITMHS -= '& EMP<="'+[M:DIA]MATFIN+'"'
Endif
Return

################################################################################
$CADRAGE_DATE
#Recherche de la date de paye concernée par l'enreg courant
DATPAY = [F:HSP]DAT
Call CADRE_PYRDAT(DATPAY,[F:ECT]FCY) From TPSSUB
If mkstat
 Raz mkstat
 Call ECR_TRACE(num$([F:HSP]DAT)-mess(12,10709,1),1) From GESECRAN : # Pas de paye définie à cette date
Endif
Return

################################################################################
## Etiquettes écran MAJPAIEMS
################################################################################

Subprog AM_ENAFLG(VALEUR)
Variable Integer VALEUR
#La suppressions des maj précédentes ne gère pas les critères libres
If VALEUR = 2
 Effzo [M:DIA]CRI : Grizo [M:DIA]CRI
Else
 Actzo [M:DIA]CRI
Endif
End

## Sélection matricule
$SEL_TABLE
Case TABLE
 When "SELEMP"
  OBJET   = "EML"
  CRITERE = "ENAFLG=2"
Endcase
Return
######################################################################################
