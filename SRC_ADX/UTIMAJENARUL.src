#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Initialisation of short description
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Initialisation colonne ENARUL") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTAB
End

#----------------------------------------------------------------------------------------#
$ERRFIC
OKFIC = 0
Resume

#----------------------------------------------------------------------------------------#
$MAJTAB
Local Integer OKFIC : OKFIC=1
Onerrgo ERRFIC
If DOSSIER=nomap
 Local File ATYPERUL  [ATYR] : # TYPINTPAR
Else
 Local File =DOSSIER+".ATYPERUL" [ATYR]: # TYPINTPAR
Endif
Onerrgo
If !OKFIC : Return : Endif

If dim([F:ATYR]ENARUL)>0
 Trbegin [ATYR]
  For [ATYR]ATYR0 Where ENARUL=0
   [ATYR]ENARUL=2
   Rewrite [ATYR]
   If fstat
    Call ERREUR("ATYPERUL"-[ATYR]CODTYP-"~"-num$([ATYR]TYPRUL)-"~"-[ATYR]TRTRUL-"~"-[ATYR]PRGRUL,2) From DOSDIC
   Endif
  Next
 Commit
Endif

Close Local File [ATYR]

Return
