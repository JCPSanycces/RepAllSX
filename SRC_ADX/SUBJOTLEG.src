#  If dim([M:JOT3]HDCTYP)>0    : Chgfmt [M:JOT3]HDCTYP   With "K:20X" : Raz [M:JOT3]HDCTYP : Endif
#  If dim([M:JOT3]HDCSTR)>0    : Chgfmt [M:JOT3]HDCSTR   With "D:"+GFMDAT4 : Raz [M:JOT3]HDCSTR : Endif
#  If dim([M:JOT3]HDCEND)>0    : Chgfmt [M:JOT3]HDCEND   With "D:"+GFMDAT4 : Raz [M:JOT3]HDCEND : Endif
  If dim([M:JOT3]PDIFLG)>0    : Chgfmt [M:JOT3]PDIFLG   With "LA:1" : Endif
  If dim([M:JOT3]RCEGRP)>0    : Chgfmt [M:JOT3]RCEGRP   With "LA:11658" : Endif
  If dim([M:JOT3]SEX)>0       : Chgfmt [M:JOT3]SEX   With "LA:314" : Endif
  If dim([M:JOT3]PDISTR)>0    : Chgfmt [M:JOT3]PDISTR   With "D:"+GFMDAT4 : Endif
  If dim([M:JOT3]PDIEND)>0    : Chgfmt [M:JOT3]PDIEND   With "D:"+GFMDAT4 :Endif
  If dim([M:JOT3]HDCFLG)>0    : Chgfmt [M:JOT3]HDCFLG   With "LA:1" : Endif
  If dim([M:JOT3]HDCTYP)>0    : Chgfmt [M:JOT3]HDCTYP   With "K:20X" : Endif
  If dim([M:JOT3]HDCSTR)>0    : Chgfmt [M:JOT3]HDCSTR   With "D:"+GFMDAT4 : Endif
  If dim([M:JOT3]HDCEND)>0    : Chgfmt [M:JOT3]HDCEND   With "D:"+GFMDAT4 :Endif
  #LIPET - X3-34467 - 2017-04-26 - END
Endif

#If (GCURLEG <> "" and GCURLEG <>'ZAF')  | !func AFNC.ACTIV("EQM")
If GCURLEG <>'ZAF'  | !func AFNC.ACTIV("EQM")
#ADNGO - 2017-05-26 - JIRA X3-33736 - START
  If dim([M:JOT3]JOBGRA)>0 : Chgfmt [M:JOT3]JOBGRA   With "-K:20X" : Raz [M:JOT3]JOBGRA : Endif
  If dim([M:JOT3]OCPLEV)>0 : Chgfmt [M:JOT3]OCPLEV   With "-LA:11670" : Raz [M:JOT3]OCPLEV : Endif
 # If dim([M:JOT3]JOBGRA)>0 : Chgfmt [M:JOT3]JOBGRA   With "-K:20X"  : Endif
 # If dim([M:JOT3]OCPLEV)>0 : Chgfmt [M:JOT3]OCPLEV   With "-LA:11670"  : Endif
#ADNGO - 2017-05-26 - JIRA X3-33736 - END
Endif

#If (GCURLEG <> "" and GCURLEG <>'ZAF') | !func AFNC.ACTIV("SDM")
If GCURLEG <>'ZAF' | !func AFNC.ACTIV("SDM")
#LIPET - 2017-05-02 - X3-34467 - START
  If dim([M:JOT3]SCACPC)>0 : Chgfmt [M:JOT3]SCACPC   With "-K:20X" : Raz [M:JOT3]SCACPC : Endif
  If dim([M:JOT3]OFOCOD)>0 : Chgfmt [M:JOT3]OFOCOD   With "-K:20X" : Raz [M:JOT3]OFOCOD : Endif
  If dim([M:JOT3]EQUEMPTYP)>0 : Chgfmt [M:JOT3]EQUEMPTYP   With "-LA:11671" : Raz [M:JOT3]EQUEMPTYP : Endif
  If dim([M:JOT3]STG)>0 : Chgfmt [M:JOT3]STG   With "-LA:1" : Raz [M:JOT3]STG : Endif

#  If dim([M:JOT3]SCACPC)>0 : Chgfmt [M:JOT3]SCACPC   With "-K:20X"  : Endif
#  If dim([M:JOT3]OFOCOD)>0 : Chgfmt [M:JOT3]OFOCOD   With "-K:20X"  : Endif
#  If dim([M:JOT3]EQUEMPTYP)>0 : Chgfmt [M:JOT3]EQUEMPTYP   With "-LA:11671"  : Endif
#  If dim([M:JOT3]STG)>0 : Chgfmt [M:JOT3]STG   With "-LA:1"  : Endif


  If dim([M:JOT3]PDIFLG)>0 : Chgfmt [M:JOT3]PDIFLG   With "-LA:1" : Raz [M:JOT3]PDIFLG : Endif
  If dim([M:JOT3]RCEGRP)>0 : Chgfmt [M:JOT3]RCEGRP   With "-LA:11658" : Raz [M:JOT3]RCEGRP :Endif
  If dim([M:JOT3]SEX)>0 : Chgfmt [M:JOT3]SEX   With "-LA:314" : Raz [M:JOT3]SEX : Endif
  If dim([M:JOT3]PDISTR)>0 : Chgfmt [M:JOT3]PDISTR   With "-D:"+GFMDAT4 : Raz [M:JOT3]PDISTR : Endif
  If dim([M:JOT3]PDIEND)>0 : Chgfmt [M:JOT3]PDIEND   With "-D:"+GFMDAT4 : Raz [M:JOT3]PDIEND : Endif

#  If dim([M:JOT3]PDIFLG)>0 : Chgfmt [M:JOT3]PDIFLG   With "-LA:1"  : Endif
#  If dim([M:JOT3]RCEGRP)>0 : Chgfmt [M:JOT3]RCEGRP   With "-LA:11658"  : Endif
#  If dim([M:JOT3]SEX)>0 : Chgfmt [M:JOT3]SEX   With "-LA:314"  : Endif
#  If dim([M:JOT3]PDISTR)>0 : Chgfmt [M:JOT3]PDISTR   With "-D:"+GFMDAT4  : Endif
#  If dim([M:JOT3]PDIEND)>0 : Chgfmt [M:JOT3]PDIEND   With "-D:"+GFMDAT4  : Endif


  If dim([M:JOT3]HDCFLG)>0 : Chgfmt [M:JOT3]HDCFLG   With "-LA:1" : Raz [M:JOT3]HDCFLG : Endif
  If dim([M:JOT3]HDCTYP)>0 : Chgfmt [M:JOT3]HDCTYP   With "-K:20X" : Raz [M:JOT3]HDCTYP : Endif
  If dim([M:JOT3]HDCSTR)>0 : Chgfmt [M:JOT3]HDCSTR   With "-D:"+GFMDAT4 : Raz [M:JOT3]HDCSTR : Endif
  If dim([M:JOT3]HDCEND)>0 : Chgfmt [M:JOT3]HDCEND   With "-D:"+GFMDAT4 : Raz [M:JOT3]HDCEND : Endif

#  If dim([M:JOT3]HDCFLG)>0 : Chgfmt [M:JOT3]HDCFLG   With "-LA:1" : Endif
