############################################################

Subprog DISPLAY_HIDE()
Local Char WSIGN(1)
#show name block
Local Integer WDISPBLCK
Local Char WNAMEBLCK
# 3 fields to hide if GCURLEG<>FRA
#block with 2 fields to hide if GCURLEG<>FRA
If clalev([F:AMKW])=0 : Local File AMSK [AMKW] : Endif
Read [F:AMKW]CODMSK = "JOT3"
Case GCURLEG
When "" :
      WSIGN="-"
      WDISPBLCK=0
When Default:
      WSIGN=""
      WDISPBLCK=1
Endcase
# name block

If WDISPBLCK=1
  WNAMEBLCK=func AFNC.TEXTE([F:AMKW]TITBLOC(0))
Endif
Chgtbk [M:JOT3]5  With WNAMEBLCK
If WDISPBLCK=1
  WNAMEBLCK=func AFNC.TEXTE([F:AMKW]TITBLOC(1))
Endif
Chgtbk [M:JOT3]10        With WNAMEBLCK
Chgfmt [M:JOT3]CCV       With WSIGN+"K:"+num$(GLONCCV)+"B"
Chgfmt [M:JOT3]DES       With WSIGN+"KP:30X"
Chgfmt [M:JOT3]SALMIN    With WSIGN+"N:6.2"
Chgfmt [M:JOT3]SALMAX    With WSIGN+"N:6.2"

#JOJAC - 2016-03-23 - REQ114309 US86 - START
If WSIGN="-"
If dim([M:JOT3]PDISTR)>0    : Chgfmt [M:JOT3]PDISTR   With WSIGN+"D:"+GFMDAT4 : Endif
If dim([M:JOT3]PDIEND)>0    : Chgfmt [M:JOT3]PDIEND   With WSIGN+"D:"+GFMDAT4 : Endif
If dim([M:JOT3]HDCSTR)>0    : Chgfmt [M:JOT3]HDCSTR   With WSIGN+"D:"+GFMDAT4 : Endif
If dim([M:JOT3]HDCEND)>0    : Chgfmt [M:JOT3]HDCEND   With WSIGN+"D:"+GFMDAT4 : Endif
Endif
#JOJAC - 2016-03-23 - REQ114309 US86 - END

If WSIGN=""
  If [M:JOT3]CCV="" Then [M:JOT3]DES="" : Endif
  Affzo [M:JOT3]5-10
Endif
If WSIGN="-"
  Raz [M:JOT3]CCV
  Raz [M:JOT3]DES
  Raz [M:JOT3]SALMIN
  Raz [M:JOT3]SALMAX
  Raz [M:JOT3]PDISTR
#JOJAC - 2016-03-23 - REQ114309 US86 - START
  Raz [M:JOT3]PDIEND
  Raz [M:JOT3]HDCSTR
  Raz [M:JOT3]HDCEND
  Raz [M:JOT3]HDCEND
#JOJAC - 2016-03-23 - REQ114309 US86 - END
Endif

#JOJAC - 2016-03-23 - REQ114309 US86 - START
#If (GCURLEG ='ZAF' | GCURLEG = "") & func AFNC.ACTIV("EQM")
If GCURLEG ='ZAF' & func AFNC.ACTIV("EQM")
#ADNGO - 2017-05-26 - JIRA X3-33736 - START
#  If dim([M:JOT3]JOBGRA)>0    : Chgfmt [M:JOT3]JOBGRA   With "K:20X" : Raz [M:JOT3]JOBGRA : Endif
#  If dim([M:JOT3]OCPLEV)>0    : Chgfmt [M:JOT3]OCPLEV   With "LA:11670" : Raz [M:JOT3]OCPLEV : Endif
  If dim([M:JOT3]JOBGRA)>0    : Chgfmt [M:JOT3]JOBGRA   With "K:20X"  : Endif
  If dim([M:JOT3]OCPLEV)>0    : Chgfmt [M:JOT3]OCPLEV   With "LA:11670" : Endif
#ADNGO - 2017-05-26 - JIRA X3-33736 - END
Endif
#If (GCURLEG ='ZAF' | GCURLEG = "") & func AFNC.ACTIV("SDM")
If GCURLEG ='ZAF' & func AFNC.ACTIV("SDM")
#ADNGO - 2017-05-26 - JIRA X3-33736 - START
#  If dim([M:JOT3]SCACPC)>0    : Chgfmt [M:JOT3]SCACPC   With "K:20X" : Raz [M:JOT3]SCACPC : Endif
