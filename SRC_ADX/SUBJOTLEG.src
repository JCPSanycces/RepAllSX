Endif


If GCURLEG = ""
#ADNGO - 2017-05-26 - JIRA X3-33736 - START
  If dim([M:JOT2]EMPMDL) > 0 : Chgfmt [M:JOT2]EMPMDL   With "-K:15X" : Raz [M:JOT2]EMPMDL : Endif
  If dim([M:JOT2]NAMMDL) > 0 : Chgfmt [M:JOT2]NAMMDL   With "-K:15X" : Raz [M:JOT2]NAMMDL : Endif
#  If dim([M:JOT2]EMPMDL) > 0 : Chgfmt [M:JOT2]EMPMDL   With "-K:15X"  : Endif
#  If dim([M:JOT2]NAMMDL) > 0 : Chgfmt [M:JOT2]NAMMDL   With "-K:15X"  : Endif
  If dim([M:JOT3]PDISTR)>0    : Chgfmt [M:JOT3]PDISTR   With "-D:"+GFMDAT4 : Endif : Raz [M:JOT3]PDISTR
  If dim([M:JOT3]PDIEND)>0    : Chgfmt [M:JOT3]PDIEND   With "-D:"+GFMDAT4 : Endif : Raz [M:JOT3]PDIEND
#  If dim([M:JOT3]PDISTR)>0    : Chgfmt [M:JOT3]PDISTR   With "-D:"+GFMDAT4 : Endif
