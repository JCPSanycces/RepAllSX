#  If dim([M:JOT3]STG)>0       : Chgfmt [M:JOT3]STG   With "LA:1" : Raz [M:JOT3]STG : Endif
  If dim([M:JOT3]SCACPC)>0    : Chgfmt [M:JOT3]SCACPC   With "K:20X"  : Endif
  If dim([M:JOT3]OFOCOD)>0    : Chgfmt [M:JOT3]OFOCOD   With "K:20X"  : Endif
  If dim([M:JOT3]EQUEMPTYP)>0 : Chgfmt [M:JOT3]EQUEMPTYP  With "LA:11671"  : Endif
  If dim([M:JOT3]STG)>0       : Chgfmt [M:JOT3]STG   With "LA:1"  : Endif
#ADNGO - 2017-05-26 - JIRA X3-33736 - END
