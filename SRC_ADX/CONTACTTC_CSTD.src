Return

#######################################################################################
$PROPERTIES
  Case CURPTH
    When ""
      Case CURPRO
        When "TCDEFFLG"                :  Gosub PROPERTIES_TCDEFFLG
        When Default
      Endcase
    When Default
  Endcase
Return

#######################################################################################
$PROPERTIES_TCDEFFLG
  Case ACTION
    When "GET"                         : Gosub GET_TCDEFFLG
    When Default                       : Return
  Endcase
Return

#######################################################################################
$GET_TCDEFFLG
  If this.APARENT = null Then
    Return
  Endif
  # -----------------------------------
  Case this.APARENT.OBJECTTYPE
    When "C_BPARTNER"
      If this.APARENT.APARENT = null Then
        # On peut être soit en lecture de classe BPARTNER toute seule dans un traitement...
        If this.APARENT.CNTNAM = this.CCNCRM Then
          this.TCDEFFLG = [V]CST_AYES
        Else
          this.TCDEFFLG = [V]CST_ANO
        Endif
      Else
        Case this.APARENT.APARENT.OBJECTTYPE
          When "R_BPARTNER"
            # ... soit en affichage de classe BPARTNER dans une représentation
            If this.APARENT.CNTNAM = this.CCNCRM Then
              this.TCDEFFLG = [V]CST_AYES
            Else
              this.TCDEFFLG = [V]CST_ANO
            Endif
          When "C_BPCUSTOMER"
            If this.APARENT.APARENT.CNTNAM = this.CCNCRM Then
              this.TCDEFFLG = [V]CST_AYES
            Else
              this.TCDEFFLG = [V]CST_ANO
            Endif
          When Default
        Endcase
      Endif
    When Default
  Endcase
Return

