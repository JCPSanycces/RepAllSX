#<AdxTL>@(#)9.0.0.0 $Revision$ Consultation SII
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz[M:CSII]: Transmask [M:SII1] To [M:CSII]# Issue 25606 [M:CSII] = [M:SII1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:STE]) = 0 : Local File STOPAR     [STE] : Endif
If GWRHACT = 2                                                    # hcb 62371
   If clalev([F:ITW]) = 0 : Local File ITMWRH    [ITW] : Endif
   If clalev([F:WRH]) = 0 : Local File WAREHOUSE [WRH] : Endif
Endif
Local Date    WNEXCUNDAT                                          # hcb 62371

#
Local Char    WFIL1(250), WFIL2(250),WFILS(250), WFILSPE(250)
Local Date    WDAT
Local Integer WFSTAT, WREAD, WSKIP, WLIG, WCOD, WSEL
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSII"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SII1]FLG = 0
[M:SII1]    = [M:CSII]
Return
############################################################
$AP_MAGNETO
[M:SII1]FLG = 0
Return
############################################################
$FERME
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SII1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SII1]ITMREFSTR = [F:ITM]ITMREF
        Endif
      Endif
    When 4 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SII1]ITMREFEND = [F:ITM]ITMREF
        Endif
      Endif
    When 5 :
      If PARAM(I) <> ""
        [M:SII1]TCLCODSTR = PARAM(I)
      Endif
    When 6 :
      If PARAM(I) <> ""
        [M:SII1]TCLCODEND = PARAM(I)
      Endif
    When 7 :
      If PARAM(I) <> ""
        [M:SII1]BUYSTR    = PARAM(I)
      Endif
    When 8 :
      If PARAM(I) <> ""
        [M:SII1]BUYEND    = PARAM(I)
      Endif
    When 9 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I
If clalev([M:CSII]) <> 0 & [M:CSII]MEMO = "STD"
  [M:SII1] = [M:CSII]
Endif
Return
############################################################
$LECTURE
If [M:SII1]FCY = "" | [M:SII1]FLG = 2
  [M:SII1]FLG = 0
  NBLU = 0
  Return
Endif
# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [LNK]
      Gosub TRT_SEL
      If WSEL = 0
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [LNK]
      Gosub TRT_SEL
      If WSEL = 0
        If WLIG >= WSKIP
          If nolign <= MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
            NOL    += 1
          Else
            Break
          Endif
        Else
          WLIG += 1
        Endif
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:SII2]
    WLIG = 0
    For [LNK]
      Gosub TRT_SEL
      If WSEL = 0
        WLIG += 1
      Endif
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [LNK]
      Gosub TRT_SEL
      If WSEL = 0
        If WLIG >= WSKIP
          If nolign <= MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
            NOL    -= 1
          Else
            Break
          Endif
        Else
          WLIG += 1
        Endif
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [LNK]
      Gosub TRT_SEL
      If WSEL = 0
        If WLIG >= WSKIP
          If nolign <= MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
          Else
            Break
          Endif
        Else
          WLIG += 1
        Endif
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
Return
############################################################
$TRT_FILTER
If [M:SII1]FLG = 0
  [M:SII1]FLG = 1
  Raz [M:SII2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
#                         hcb 62371 deb
  If  GWRHACT = 2  & [F:FCY]WRHGES = 2
      Link [ITW] With [ITM]ITM0=[F:ITW]ITMREF,[ITF]ITF0=[F:ITW]ITMREF;[F:ITW]STOFCY,[ITV]ITV0=[F:ITW]ITMREF;[F:ITW]STOFCY
&          As [LNK]
&          Where evalue(WFIL1)    &
&                evalue(WFIL2)    &
&                evalue(WFILS)    &
&                evalue(WFILSPE)
&          Order By Key ITW1
  Raz [F:ITW]
  Else
      Link [ITF] With [ITV]ITV0=[F:ITF]ITMREF;[F:ITF]STOFCY,[ITM]ITM0=[F:ITF]ITMREF
&          As [LNK]
&          Where evalue(WFIL1) &
&                evalue(WFIL2) &
&                evalue(WFILS) &
&                evalue(WFILSPE)
&          Order By Key ITF1
  Endif
#                         hcb 62371 fin
  Raz [F:ITF]
  Raz [F:ITM]
  Raz [F:ITV]
Endif
Return
############################################################
$LOAD_FILTER
#Préparation filtre [ITF] ou ITF et ITW si depot
# Filtre dépôt
#                                               # hcb 62371 deb
If GWRHACT = 2 & [F:FCY]WRHGES = 2
   WFIL1 = "1=1"
   If dim([M:SII1]WRH)>0 & [M:SII1]WRH <> ""
      WFIL1 += "&[F:ITW]WRH=[M:SII1]WRH"
   Endif
   WFIL1 += "&(([F:ITW]CUNWRHFLG=2 & [F:ITW]CUNCOD = [M:SII1]CUNCODSEL)|([F:ITW]CUNWRHFLG=1 & [F:ITF]CUNCOD=[M:SII1]CUNCODSEL))"
   WFIL1 += "&[F:ITF]ABCCLS<5"
   # Filtre site
   If [M:SII1]FCY <> ""
       WFIL1 += "&[F:ITW]STOFCY=[M:SII1]FCY"
   Endif
Else
   WFIL1 = "[F:ITF]CUNCOD=[M:SII1]CUNCODSEL&[F:ITF]ABCCLS<5"
Endif
#                                                 # hcb 62371 fin
# Filtre site
If [M:SII1]FCY <> ""
  WFIL1 += "&[F:ITF]STOFCY=[M:SII1]FCY"
Endif
# Filtre article
WFIL2 = "1=1"
If [M:SII1]ITMREFSTR <> "" | [M:SII1]ITMREFEND <> ""
  If [M:SII1]ITMREFSTR = [M:SII1]ITMREFEND
    WFIL2 += "&[F:ITF]ITMREF=[M:SII1]ITMREFSTR"
  Else
    WFIL2 += "&[F:ITF]ITMREF>=[M:SII1]ITMREFSTR&[F:ITF]ITMREF<=[M:SII1]ITMREFEND"
  Endif
Endif
# Filtre gestionnaire
If [M:SII1]BUYSTR <> "" | [M:SII1]BUYEND <> ""
  If [M:SII1]BUYSTR = [M:SII1]BUYEND
    WFIL2 += "&[F:ITF]BUY=[M:SII1]BUYSTR"
  Else
    WFIL2 += "&[F:ITF]BUY>=[M:SII1]BUYSTR&[F:ITF]BUY<=[M:SII1]BUYEND"
  Endif
Endif
# Filtre catégorie
If [M:SII1]TCLCODSTR <> "" | [M:SII1]TCLCODEND <> ""
  If [M:SII1]TCLCODSTR = [M:SII1]TCLCODEND
    WFIL2 += "&[F:ITM]TCLCOD=[M:SII1]TCLCODSTR"
  Else
    WFIL2 += "&[F:ITM]TCLCOD>=[M:SII1]TCLCODSTR&[F:ITM]TCLCOD<=[M:SII1]TCLCODEND"
  Endif
Endif
Return
############################################################
$LOA_LIGNE
[M:SII2] = [F:ITF]
[M:SII2] = [F:ITV]
[M:SII2] = [F:ITM]
[M:SII2]BUY(nolign-1)    = [F:ITF]BUY
#                                    # hcb 62371 deb
If GWRHACT = 2 & [F:FCY]WRHGES = 2
   [M:SII2]WRH(nolign-1) = [F:ITW]WRH
Endif
[M:SII2]NEXCUNDAT(nolign-1) = WNEXCUNDAT
#                                    # hcb 62371 fin

[M:SII2]INTSTO(nolign-1) = [F:ITV]PHYSTO   +[F:ITV]CTLSTO   +[F:ITV]REJSTO
[M:SII2]PLFSTO(nolign-1) = [F:ITV]PLFPHYSTO+[F:ITV]PLFCTLSTO+[F:ITV]PLFREJSTO
[M:SII2]BPRSTO(nolign-1) = [F:ITV]BPRPHYSTO+[F:ITV]BPRCTLSTO+[F:ITV]BPRREJSTO
[M:SII2]SCOSTO(nolign-1) = [F:ITV]SCOPHYSTO+[F:ITV]SCOCTLSTO+[F:ITV]SCOREJSTO
[M:SII2]TOTSTO(nolign-1) = [F:ITV]PHYSTO   +[F:ITV]CTLSTO   +[F:ITV]REJSTO    +
&                          [F:ITV]PLFPHYSTO+[F:ITV]PLFCTLSTO+[F:ITV]PLFREJSTO +
&                          [F:ITV]BPRPHYSTO+[F:ITV]BPRCTLSTO+[F:ITV]BPRREJSTO +
&                          [F:ITV]SCOPHYSTO+[F:ITV]SCOCTLSTO+[F:ITV]SCOREJSTO
Return
############################################################
$TRT_SEL
WSEL = 1
# Filtre date
# hcb 62371 deb (trt_sel refait entierement)
If GWRHACT = 2 & [F:FCY]WRHGES = 2
   WNEXCUNDAT = [F:ITV]NEXCUNDAT
   If [F:ITW]CUNWRHFLG = 2
      If [F:ITW]NEXCUNDAT = [0/0/0]
         If [F:ITW]CREDAT = [0/0/0]
             WDAT = [F:ITF]CREDAT
         Else
             WDAT = [F:ITW]CREDAT
         Endif
         WCOD = [F:ITW]CUNCOD
         Call CAL_NEXINVITW([F:ITF]STOFCY,[F:ITM]TCLCOD,WDAT,WCOD) From STKINV
      Endif
      WNEXCUNDAT = [F:ITW]NEXCUNDAT
   Else
      If [F:ITV]NEXCUNDAT = [0/0/0]
         If [F:ITV]CREDAT = [0/0/0]
            WDAT = [F:ITF]CREDAT
         Else
            WDAT = [F:ITV]CREDAT
         Endif
         WCOD = [F:ITF]CUNCOD
         Call CAL_NEXINV([F:ITF]STOFCY,[F:ITM]TCLCOD,WDAT,WCOD) From STKINV
      Endif
      WNEXCUNDAT = [F:ITV]NEXCUNDAT
   Endif
Else
   If [F:ITV]NEXCUNDAT = [0/0/0]
      If [F:ITV]CREDAT = [0/0/0]
         WDAT = [F:ITF]CREDAT
      Else
         WDAT = [F:ITV]CREDAT
      Endif
      WCOD = [F:ITF]CUNCOD
      Call CAL_NEXINV([F:ITF]STOFCY,[F:ITM]TCLCOD,WDAT,WCOD) From STKINV
   Endif
   WNEXCUNDAT = [F:ITV]NEXCUNDAT
Endif
If [M:SII1]CUNCODSEL = 1 | [M:SII1]CUNCODSEL = 2
   If WNEXCUNDAT <= [M:SII1]CUNDATREF
      WSEL = 0
   Endif
Else
   WSEL = 0
Endif
Return
############################################################
$LOA_LIGNE_SUI
Return
############################################################
$SETBOUT
Return
############################################################
$EXEBOUT
Return
############################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:SII1]FLG = 0
#             hcb 62371 deb
If dim([M:SII1]WRH) > 0
   Raz   [M:SII1]WRH
   Affzo [M:SII1]WRH
Endif
#             hcb 62371 fin

End
############################################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
[M:SII1]FLG = 0
End
############################################################
Subprog AM_ITMREFEND(VALEUR)
Variable Char    VALEUR()
[M:SII1]FLG = 0
End
############################################################
Subprog AV_ITMREFEND(VALEUR)
Variable Char     VALEUR
If VALEUR = ""
  VALEUR = [M]ITMREFSTR
Endif
End
############################################################
Subprog AV_TCLCODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]TCLCODSTR
Endif
End
############################################################
Subprog AV_BUYEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]BUYSTR
Endif
End
############################################################
Subprog AM_CUNDATREF(VALEUR)
Variable Date    VALEUR
[M:SII1]FLG = 0
End
############################################################
Subprog AM_CUNCODSEL(VALEUR)
Variable Integer VALEUR
[M:SII1]FLG = 0
End
############################################################
Subprog AM_TCLCODSTR(VALEUR)
Variable Char    VALEUR()
[M:SII1]FLG = 0
End
############################################################
Subprog AM_TCLCODEND(VALEUR)
Variable Char    VALEUR()
[M:SII1]FLG = 0
End
############################################################
Subprog AM_BUYSTR(VALEUR)
Variable Char    VALEUR()
[M:SII1]FLG = 0
End
############################################################
Subprog AM_BUYEND(VALEUR)
Variable Char    VALEUR()
[M:SII1]FLG = 0
End

# FQ 57754 Module Stocks GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(7)<>2 End Endif

Call VALGTC(APPLI,"SII") From SUBGTC

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSSBI1) 05/02/2010  # hcb 62371
######################################################################################
Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
[M:SII1]FLG = 0
End

Subprog AS_WRH(VALEUR)
Variable Char     VALEUR
If GCONSULT <> 0
   mkstat = 2
   End
Endif
# Actzo ou Grizo des dépôts selon le site  #
#------------------------------------------#
If [M]FCY <>[F:FCY]FCY
  Read [FCY]FCY0=[M]FCY
Endif
If [F:FCY]WRHGES <> 2
  Raz   [M]WRH
  Affzo [M]WRH
  mkstat = 2
Endif
End
#                                                     # hcb x3-47481 deb
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
#lecture valeurs par défaut du site
Read [STE]STE0=VALEUR;""
If fstat
  GMESSAGE= mess(174,199,1)
  mkstat=2
  End
Endif
End
#                                                     # hcb x3-47481 end

