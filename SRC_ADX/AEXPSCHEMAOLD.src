#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char PARAM(30)(1..10) , VALEUR(10)
PARAM = "TESTPAYSX"
Call TRAITE_CHAR(VALEUR,PARAM,"","AEXPSCHEMA","",2,"") From GTRAITE
End

#-------------------------------------------#
$ACTION
Case ACTION
 When "INIT"      : Gosub INIT
 When "AVANT_PAR" : Gosub AVANT_PAR
 When "CONTROLE"  : Gosub CONTROLE
 When "EXEC"      : Gosub EXEC
 When "TERMINE"   : Gosub TERMINE
Endcase
Return

#-------------------------------------------#
# Export schéma modèle d'import XML
#-------------------------------------------#

$INIT
If clalev([F:AOE])=0 : Local File AOBJEXT   [AOE] : Endif
If clalev([F:AOD])=0 : Local File AOBJEXTD  [AOD] : Endif
If clalev([F:AOR])=0 : Local File AOBJEXTR  [AOR] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ATI])=0 : Local File ATABIND   [ATI] : Endif
If clalev([F:AOB])=0 : Local File AOBJET    [AOB] : Endif
If clalev([F:AMP])=0 : Local File AMSKPAR   [AMP] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV   [ADI] : Endif
If clalev([F:ATY])=0 : Local File ATYPE     [ATY] : Endif
If clalev([F:ACV])=0 : Local File ACTIV     [ACV] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE    [ATX] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA   [AXX] : Endif
Return

#--------------------------------------------------------------------------------------------#
$AVANT_PAR
TIT = func AFNC.MES(mess(172,141,1),PARAM(1)) : # Export Schéma du modèle #
Return

#--------------------------------------------------------------------------------------------#
$TERMINE
Call OUVRE_TRACE(mess(104,121,1)-":\|"+FICHIER) From LECFIC : # Fichier généré
Openi FICHIER,0 Using [HTI_]
Iomode adxifs "" Using [HTI_]
Iomode adxirs chr$(10) Using [HTI_]
Iomode adxium GUTF8 Using [HTI_]
Rdseq CHAINE Using [HTI_]
While !fstat
 Call ECR_TRACE(CHAINE,0) From GESECRAN
 Rdseq CHAINE Using [HTI_]
Wend 
Openi Using [HTI_]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
Return

#--------------------------------------------------------------------------------------------#
$CONTROLE
Local Char    MODELE(GLONAOE) , CHAINE(250)
Local Char    CLE(GLONAVA)(1..16) , NOMFIC(GLONATB)
Local Integer I , J , K , IND , NBCLE
Local Char    FLD(30) , ZONE(50) , INTIT(50)
Local Char    TYP(GLONATY)
Local Integer LNG , MNL , NBTAB , DIME , NUMTAB
Local Char    TAB(30)(1..50)
MODELE = PARAM
Read [AOE]AOE0=MODELE
If fstat
 GMESSAGE = MODELE-":"-mess(30,141,1) : # Modèle inexistant
 FIN = 1 : Return
Elsif [F:AOE]TYPFIL<>5
 GMESSAGE = MODELE+"("+mess([F:AOE]TYPFIL,94,1)+")"-":"-mess(72,141,1) : # Modèle incorrect
 FIN = 1 : Return
Endif
Return

#--------------------------------------------------------------------------------------------#
$EXEC
FICHIER = filpath("tmp",func NOMFIC(MODELE),"xsd")
Openo FICHIER,0 Using [AXML]
Iomode adxifs "" Using [AXML]
Iomode adxirs chr$(10) Using [AXML]
Iomode adxium GUTF8 Using [AXML]
Wrseq '<?xml version="1.0" encoding="'+tolower(mess(2,945,1))+'" ?>' Using [AXML]
Wrseq '<!--------------------------------------------------------------->' Using [AXML]
Wrseq '<!---             X   X  XXX       X   X   XX                  -->' Using [AXML]
Wrseq '<!---              X X     X       X   X  X                    -->' Using [AXML]
Wrseq '<!---               X     X   XXX  X   X  XXXX                 -->' Using [AXML]
Wrseq '<!---              X X     X        X X   X  X                 -->' Using [AXML]
Wrseq '<!---             X   X  XXX         X     XX                  -->' Using [AXML]
Wrseq '<!--------------------------------------------------------------->' Using [AXML]
Wrseq '<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">' Using [AXML]
For IND=1 To dim([F:AOE]FLGREC)
 If [F:AOE]FLGREC(IND-1)<>""
  Gosub TABLE
 Endif
Next IND
Wrseq '</xs:schema>' Using [AXML]
Openo Using [AXML]
Return

#--------------------------------------------------------------------------------------------#
Funprog NOMFIC(MODELE)
Value Char MODELE
#End "Schema XML du WS "+func TEXTRA("AOBJEXT","INTIT",MODELE,"")
End MODELE

#--------------------------------------------------------------------------------------------#
$TABLE
Wrseq '    <xs:element name="'+[F:AOE]FLGFIL(IND-1)+'">' Using [AXML]
For [AOD]AOD0 Where EXT=[F:AOE]EXT & TYP=[F:AOE]FLGREC(IND-1)
 Raz TYP , LNG , MNL , INTIT , NUMTAB
 If find(left$([F:AOD]FLD,1),"/","*","=","'",'"',"")
  TYP = "A"
  LNG = 10
  ZONE = [F:AOD]TYP+"__"+num$([F:AOD]NUMLIG)
  INTIT = [F:AOD]COM
 Else
  K = instr(1,[F:AOD]FLD,"(")
  If K
   DIME = val(right$([F:AOD]FLD,K+1))
   FLD  = left$([F:AOD]FLD,K-1)
   ZONE = FLD+"_"+num$(DIME)
  Else
   FLD  = [F:AOD]FLD
   ZONE = [F:AOD]FLD
  Endif
  Read [ATZ]CODZONE=[F:AOD]FIL;[L]FLD
  If !fstat and func ACTIV([F:ATZ]CODACT) 
   TYP   = [F:ATZ]CODTYP
   LNG   = [F:ATZ]LONG
   MNL   = [F:ATZ]NOLIB
   INTIT = func TEXTE([F:ATZ]NOCOURT)
   If MNL>1
    INTIT = mess(1,30,1)-num$(MNL)-string$(INTIT<>"","("+INTIT+")") : # Menu local
   Endif
  Else
   INTIT = [F:AOD]COM
   TYP   = "A"
   LNG   = 10 
  Endif
 Endif
 Gosub SETTYP
 If NUMTAB<>0
  INTIT = mess(63,139,1)-num$(NUMTAB)-string$(INTIT<>"","("+INTIT+")")  : # Table diverse
 Endif
 Wrseq '        <xs:element name="'+ZONE+'"'; Using [AXML]
 If MNL=1 & LNG=3
  Wrseq ' type="xs:boolean"';Using [AXML]
 Elsif find([F:ATY]TYPTYP,2,3,4)
  Wrseq ' type="xs:int"';Using [AXML]
 Elsif find([F:ATY]TYPTYP,5,6)
  Wrseq ' type="xs:decimal"';Using [AXML]
 Elsif [F:ATY]TYPTYP=8
  Wrseq ' type="xs:date"';Using [AXML]
 Endif
 Wrseq '>' Using [AXML]
 Gosub ZONE  
 Wrseq '        </xs:element>' Using [AXML]
Next AOD
Wrseq '    </xs:element>' Using [AXML]
Return

#-------------------------------------------#
$SETTYP
Read [ATY]CODTYP=TYP
If !fstat
 If [F:ATY]LNGTYP>0
  LNG = [F:ATY]LNGTYP
 Elsif TYP="ATX"
  LNG = GLONDES
 Elsif find(TYP,"AXX","AX1","AX2","AX3")
  Read [AMP]CODPAR = 2;[F:AOD]FIL;[L]FLD;[F:ATY]OBJLIEN
  CHAINE = [F:AMP]VALPAR
  If left$(CHAINE,1)="'" or left$(CHAINE,1)='"'
   CHAINE = seg$(PARTAB,2,len(CHAINE)-1)
  Endif
  NUMTAB = val(CHAINE)
 Endif
 If [F:ATY]TYPTYP=1
  Case [F:AOE]OPTMNL
   When 0       : LNG = 3
   When 1       : LNG = 1
   When Default : LNG = [F:AOE]OPTMNL
  Endcase
  If [F:ATY]NOLIB<>0
   MNL = [F:ATY]NOLIB
  Endif
 Endif
Else
 TYP = "A"
 LNG = 10
Endif
Read [ATY]CODTYP=TYP
Return

#-------------------------------------------#
Funprog ACTIV(CODACT)
Value Char CODACT
If CODACT<>""
 Read [ACV]CODACT=[F:ATZ]CODACT
 If fstat or [F:ACV]FLACT<>2
  End 0
 Endif
Endif
End 1

#-------------------------------------------#
$ZONE
Wrseq '                    <xs:annotation>' Using [AXML]
Wrseq '                            <xs:documentation>'+func CARSPEXML(INTIT)+'</xs:documentation>' Using [AXML]
Wrseq '                    </xs:annotation>' Using [AXML]
Case [F:ATY]TYPTYP
 When 1 : # Menu local
  If MNL<>1 or LNG<>3
   Wrseq '                    <xs:simpleType>' Using [AXML]
   Wrseq '                           <xs:restriction base="xs:string">' Using [AXML]
   Wrseq '                                  <xs:maxLength value="'+num$(LNG)+'"/>' Using [AXML]
   If [F:AOD]NUMTAB=0
    For I=1 To len(mess(0,MNL,1))
     CHAINE = func CARSPEXML(func AFNC.MES(mess(173,141,1),num$(I)))-":"-func CODMNL(I,MNL,[F:AOE]OPTMNL) : # Valeur # du menu local
     Wrseq '                             <xs:enumeration value="'+func CODMNL(I,MNL,[F:AOE]OPTMNL)+'">' Using [AXML]
     Wrseq '                                     <xs:annotation>' Using [AXML]
     Wrseq '                                            <xs:documentation>'+CHAINE+'</xs:documentation>' Using [AXML]
     Wrseq '                                     </xs:annotation>' Using [AXML]
     Wrseq '                             </xs:enumeration>' Using [AXML]
    Next I
   Endif
   Wrseq '                           </xs:restriction>' Using [AXML]
   Wrseq '                    </xs:simpleType>' Using [AXML]
  Endif
 When 2,3,4 : # Numérique
 When 5,6 : # Numérique (décimal
 When 8 : # Date
 When Default : # Char/Blob/Clob
  Wrseq '                    <xs:simpleType>' Using [AXML]
  Wrseq '                           <xs:restriction base="xs:string">' Using [AXML]
  Wrseq '                                  <xs:maxLength value="'+num$(LNG)+'"/>' Using [AXML]
  Wrseq '                           </xs:restriction>' Using [AXML]
  Wrseq '                    </xs:simpleType>' Using [AXML]
  If [L]NUMTAB<>0
   For [ADI] Where NUMTAB=[L]NUMTAB
    # Valeur # de la table diverse
    CHAINE = func CARSPEXML(func AFNC.MES(mess(174,141,1),[F:ADI]CODE))-":"-func TEXTRA("ATABDIV","LNGDES",num$(NUMTAB),[F:ADI]CODE)
    Wrseq '                             <xs:enumeration value="'+[F:ADI]CODE+'">' Using [AXML]
    Wrseq '                                     <xs:annotation>' Using [AXML]
    Wrseq '                                            <xs:documentation>'+CHAINE+'</xs:documentation>' Using [AXML]
    Wrseq '                                     </xs:annotation>' Using [AXML]
    Wrseq '                             </xs:enumeration>' Using [AXML]
   Next ADI
  Endif
Endcase
Return

#--------------------------------------------------------------------------------------------#
$SETCLE
CHAINE = ""
If [F:AOE]FLGFIL=""
 Read [AOB]ABREV=[F:AOE]OBJ
 If !fstat & [F:AOB]NOMFIC<>""
  Read [ATI]NUMLIG(2)=[F:AOB]NOMFIC
  If !fstat
   NOMFIC = [F:AOB]NOMFIC
   CHAINE = [F:ATI]DESCRIPT
  Endif
 Endif
Elsif [F:AOE]FLGKEY<>""
 NOMFIC = [F:AOE]FLGFIL
 Read [ATI]CODIND=[F:AOE]FLGKEY
 If !fstat
  CHAINE = [F:ATI]DESCRIPT
 Endif
Endif
Raz CLE, NBCLE
While CHAINE<>""
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 NBCLE += 1
 If I
  CLE(NBCLE) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
Return

#--------------------------------------------------------------------------------------------#
Funprog CODMNL(I,MNL,OPT)
Value Integer I,MNL,OPT
Local Char TEXTE(250)
Case OPT
 When 0       : TEXTE = num$(I)
 When 1       : TEXTE = mid$(mess(0,MNL,1),I,1)
 When Default : TEXTE = left$(mess(I,MNL,1),OPT)
Endcase
Call MODVAL(TEXTE) From INTRUTILA : # Transformation des caractères <>"& pour le script XML
End TEXTE

#-------------------------------------------#
Funprog FICHIER(CHEMIN)
Value Char CHEMIN
Local Char CHAINE(250)
Local Integer I
CHAINE = CHEMIN
I = max(instr(1,CHAINE,"/"),instr(1,CHAINE,"\"))
While I
 CHAINE = right$(CHAINE,I+1)
 I = max(instr(1,CHAINE,"/"),instr(1,CHAINE,"\"))
Wend
Call MODVAL(CHAINE) From INTRUTILA : # Transformation des caractères <>"& pour le script XML
End CHAINE

#-------------------------------------------#
Funprog TEXTE(NUMERO)
Value Integer NUMERO
Local Char TEXTE(250)
Call TEXTE(NUMERO,TEXTE) From OBJDIV
Call MODVAL(TEXTE) From INTRUTILA : # Transformation des caractères <>"& pour le script XML
End TEXTE

#-------------------------------------------#
Funprog TEXTRA(TABLE,CHAMP,CLE1,CLE2)
Value Char TABLE
Value Char CHAMP
Value Char CLE1
Value Char CLE2
Local Char TEXTE(250)
Call LECTEXTRA(TEXTE,TABLE,CHAMP,CLE1,CLE2) From ATEXTRA
Call MODVAL(TEXTE) From INTRUTILA : # Transformation des caractères <>"& pour le script XML
End TEXTE

#--------------------------------#
Funprog CARSPEXML(CHAINE)
Value Char CHAINE
Local Char CHAINE2(255)
CHAINE2 = CHAINE
Call MODVAL(CHAINE2) From INTRUTILA : # Transformation des caractères <>"& pour le script XML
End CHAINE2

