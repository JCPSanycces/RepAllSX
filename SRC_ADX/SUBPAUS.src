#<AdxTL>@(#)0.0.0.0 $Revision$ Object Management PAUS
######################################################################################
## Section automatically added (Object PAUS)
######################################################################################
$ACTION
  Case ACTION
    When Default
  Endcase
Return

######################################################################################
Subprog AM_PAUSPA(VALEUR)
# Issue X3-17872/121095 - 2017-01-23 by SINGC
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    [M:PAUS]PAUSTT = [V]CST_AYES
    Diszo [M:PAUS]PAUSTT
    Affzo [M:PAUS]PAUSTT
  Else
    Actzo [M:PAUS]PAUSTT
  Endif
End

# Issue X3-47484 - 2017-10-03 by SINGC : START
######################################################################################
Subprog AS_NBLIG

  If !GIMPORT Then
    If [M:PAUS]STRDAT(nolign-1) = AVOID.ADATE Then
      GBOUT1 = ""
    Endif
  Endif
End

######################################################################################
Subprog APRES_NBLIG
Local Integer NI

  Case status
    When 65:        # Annulation simple
      NI = nolign-1
      Gosub SUP_TEX
    When 68,83:     # Annulation multiple
      For NI = nolign-1 To nolign1-1
        Gosub SUP_TEX
      Next NI
  Endcase
End

Return

######################################################################################
Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR = AVOID.ADATE Then
    If nolign = 1 Then
      VALEUR = date$
    Else
      VALEUR = [M:PAUS]ENDDAT(nolign-2) + 1
    Endif
  Endif
End

######################################################################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
Local Integer NI

  If [M:PAUS]ENDDAT(nolign-1) <> AVOID.ADATE & VALEUR > [M:PAUS]ENDDAT(nolign-1) Then
    GMESSAGE = mess(104,119,1)
    mkstat = 2
    End
  Endif
  # -----------------------------
  For NI = 0 To dim([M:PAUS]STRDAT)-1
    If VALEUR >= [M:PAUS]STRDAT(NI) & VALEUR <= [M:PAUS]ENDDAT(NI) & NI <> nolign-1 Then
      GMESSAGE = mess(142,193,1) - num$(NI+1)
      mkstat = 1
      Break
    Endif
  Next NI
End

######################################################################################
Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR = AVOID.ADATE Then
    VALEUR = [M:PAUS]STRDAT(nolign-1)
  Endif
End

######################################################################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
Local Integer NI

  If VALEUR < [M:PAUS]STRDAT(nolign-1) Then
    GMESSAGE = mess(99,177,1)
    mkstat = 2
  Endif
  # -----------------------------
  For NI = 0 To dim([M:PAUS]STRDAT)-1
    If [M:PAUS]STRDAT(nolign-1) < [M:PAUS]STRDAT(NI) & VALEUR >= [M:PAUS]STRDAT(NI) Then
      If VALEUR <= [M:PAUS]ENDDAT(NI) Then
        GMESSAGE = mess(142,193,1) - num$(NI+1)
      Else
        GMESSAGE = mess(142,193,1) - num$(NI+1)
      Endif
      mkstat = 1
      Break
    Endif
  Next NI
End

######################################################################################
Subprog UPDATE_CAPVAR()
Local Integer NI
Local Integer IRET
Local Integer ISEQNUM
Local Integer ICOUNT_UPD
Local Integer ICOUNT_DEL
Local Integer ISEQNUM_UPD(0..)
Local Integer ISEQNUM_DEL(0..)
Local Char SVARTEX(GLONTXC)(0..)

  Filter [PJCV] Where PAUS = [M:AUS0]USR
  For [PJCV]
    IRET = func PAUSSEQ_EXIST([F:PJCV]PAUSSEQ)
    If IRET = [V]CST_AYES Then
      ISEQNUM_UPD(ICOUNT_UPD) = [F:PJCV]PAUSSEQ
      ICOUNT_UPD += 1
    Else
      ISEQNUM_DEL(ICOUNT_DEL) = [F:PJCV]PAUSSEQ
      SVARTEX(ICOUNT_DEL) = [F:PJCV]VARTEX
      ICOUNT_DEL += 1
    Endif
  Next
  Filter [PJCV]
  # ----------------------------------
  If ICOUNT_DEL > 0 Then
    For NI = 0 To ICOUNT_DEL
      Call SUP_CLOB(SVARTEX(NI), IRET) From TRTX3TEX
      Delete [PJCV] Where PAUS = [M:AUS0]USR and PAUSSEQ = ISEQNUM_DEL(NI)
    Next NI
  Endif
  # ----------------------------------
  If ICOUNT_UPD > 0 Then
    ISEQNUM = max(ISEQNUM_UPD(0..ICOUNT_UPD-1))
  Endif
  # ----------------------------------
  nolign = 0
  For NI = 0 To [M:PAUS]NBLIG-1
    Raz [F:PJCV]
    nolign += 1
    # ----------------------------------
    If [M:PAUS]PAUSSEQ(nolign-1) = 0 Then
      ISEQNUM += 10
      [M:PAUS]PAUSSEQ(nolign-1) = ISEQNUM
      [F:PJCV]PAUS = [M:AUS0]USR
      [F:PJCV] = [M:PAUS]
      # ----------------------------------
      If [M:PAUS]VARTEX(nolign-1) <> AVOID.ACHAR Then
        Call CRE_CLOB([F:PJCV]VARTEX, IRET) From TRTX3TEX
      Endif
      Write [PJCV]
    Else
      Readlock [PJCV]PJCV0 = [M:AUS0]USR;[M:PAUS]PAUSSEQ(nolign-1)
      [F:PJCV]PAUS = [M:AUS0]USR
      [F:PJCV] = [M:PAUS]
      # ----------------------------------
      If [M:PAUS]VARTEX(nolign-1) <> AVOID.ACHAR Then
        Call CRE_CLOB([F:PJCV]VARTEX, IRET) From TRTX3TEX
      Endif
      Rewrite [PJCV]
    Endif
    # ----------------------------------
    If fstat Then
      GOK = 0
      GERR = 1
    Endif
  Next NI
End

###################################################################################################
Funprog PAUSSEQ_EXIST(PAUSSEQ)
Value Integer PAUSSEQ

Local Integer IRET_VALUE
Local Integer NI

  IRET_VALUE = [V]CST_ANO
  If [M:PAUS]NBLIG > 0 Then
    If find(PAUSSEQ, [M:PAUS]PAUSSEQ(0..[M:PAUS]NBLIG-1)) > 0 Then
      IRET_VALUE = [V]CST_AYES
    Endif
  Endif
End IRET_VALUE

######################################################################################
$SUP_TEX
Local Integer IRET

  If [M:PAUS]VARTEX(NI) <> AVOID.ACHAR Then
    IRET = 0
    Call SUP_CLOB([M:PAUS]VARTEX(NI), IRET) From TRTX3TEX
  Endif
Return
# Issue X3-47484 - 2017-10-03 by SINGC : END

