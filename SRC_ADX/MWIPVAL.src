#<AdxTL>@(#)1.0.0.0 $Revision$
##################################################################
# Traitement de l'état WIPVAL
# Alimente le fichier WIPRESW qui sert à au résumé dans l'état
##################################################################

$ACTION
Case ACTION
    When "INIPAR" : Gosub INIPAR
    When "CONT1"  : Gosub CONT1
    When "CONT2"  : Gosub CONT2
Endcase
Return

$INIPAR
If [M]PARCOD(nolign-1)="datemax"
    Local Date LDATEMAX
    LDATEMAX = VALEUR
    If LDATEMAX<[01/01/1980]
        LDATEMAX =[31/12/2999]
    Endif
    LDATEMAX = VALEUR
Endif
Return


$CONT1
# Issue 78041 - 2011-11-21 by CCC
If [M]PARCOD(nolign-1)="vcrtyp"
    # Issue 88147 - 2013-02-20 by CCC
    #If !find(VALEUR,mess(10,701,1),mess(36,701,1),10,36,"10","36")
    If !find(VALEUR,mess(10,701,1),mess(36,701,1),"10","36")
        mkstat=2
    Endif
Endif
Return


$CONT2
Return

##################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

If !clalev([F:MWI]) : Local File WIPCOST [MWI] : Endif
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
If !clalev([F:MFG]) : Local File MFGHEAD [MFG] : Endif
If !clalev([F:SCO]) : Local File SCOHEAD [SCO] : Endif
If !clalev([F:SCI]) : Local File SCOITM  [SCI] : Endif
If !clalev([F:MFI]) : Local File MFGITM  [MFI] : Endif
If !clalev([F:WRW]) : Local File WIPRESW [WRW] : Endif
If !clalev([F:WRW2]): Local File WIPRESW [WRW2] : Endif
If !clalev([F:TFO]) : Local File TABFOR  [TFO] : Endif   # FQ 62959 GA 03/2010 pouvoir filtrer les OF

Local Integer LVCRTYP, LBRD
Local Char VALEUR(30)
Local Char LVCRNUMDEB(GLONVCR), LVCRNUMFIN(GLONVCR)
Local Char LIFAFLG,LDATMAX
Local Date LDATEMAX
Local Char LFCYSTR(GLONFCY), LFCYEND(GLONFCY), LCPY(GLONCPY)
Local Char CRIT(250)
Local Integer ICRIT, LMFGSTADEB, LMFGSTAFIN
Local Integer WDIM, WADXUID(1..500)
# FQ 62959 GA 03/2010 Formule de sélection des articles lancés
Local Char CRITMFI(250), CRITSCI(250),LFORCOD(GLONFOR)
Local Integer LTYPFOR
Local Char LMFGTRKFLG(20)   # Issue 78010 - 2011-12-22 by CCC

Trbegin [WRW]

    Call GETPARAM("stofcydeb",NBPAR,PARAMETRE,LFCYSTR) From ETAT
    #Call GETPARAM("stofcydeb",NBPAR,PARAMETRE,LFCYEND) From ETAT : # GH 28/01/2014 bug 94629
    Call GETPARAM("stofcyfin",NBPAR,PARAMETRE,LFCYEND) From ETAT
    Call GETPARAM("cpy",NBPAR,PARAMETRE,LCPY) From ETAT
    Call GETPARAM("vcrtyp",NBPAR,PARAMETRE,VALEUR) From ETAT
    LVCRTYP = val(VALEUR)
    Call GETPARAM("vcrnumdeb",NBPAR,PARAMETRE,LVCRNUMDEB) From ETAT
    Call GETPARAM("vcrnumfin",NBPAR,PARAMETRE,LVCRNUMFIN) From ETAT
    Call GETPARAM("ifaflg",NBPAR,PARAMETRE,LIFAFLG) From ETAT
    Call GETPARAM("datemax",NBPAR,PARAMETRE,LDATMAX) From ETAT
    Call GETPARAM("mfgstadeb",NBPAR,PARAMETRE,VALEUR) From ETAT
    LMFGSTADEB = val(VALEUR)
    Call GETPARAM("mfgstafin",NBPAR,PARAMETRE,VALEUR) From ETAT
    LMFGSTAFIN = val(VALEUR)
    Call GETPARAM("formule",NBPAR,PARAMETRE,LFORCOD) From ETAT   # FQ 62959 GA 03/2010
    Call GETPARAM("mfgtrkflg",NBPAR,PARAMETRE,LMFGTRKFLG) From ETAT   # Issue 78010 - 2011-12-22 by CCC

    LDATEMAX = LDATMAX

    Call UIDADX(WADXUID,WDIM) From TRTX3

    Delete [WRW] Where UID = adxuid(1) | !find(UID,WADXUID)

    Raz CRIT,ICRIT
    If LVCRNUMDEB<>""
        Call ADDCRIT(CRIT,ICRIT,"","VCRNUM>= LVCRNUMDEB","&") From GOBJSUB
    Endif
    If LVCRNUMFIN<>""
        Call ADDCRIT(CRIT,ICRIT,"","VCRNUM<= LVCRNUMFIN","&") From GOBJSUB
    Endif

    If LFCYSTR<>""
        Call ADDCRIT(CRIT,ICRIT,"","MFGFCY>= LFCYSTR","&") From GOBJSUB
    Endif
    If LFCYEND<>""
        Call ADDCRIT(CRIT,ICRIT,"","MFGFCY<= LFCYEND","&") From GOBJSUB
    Endif
#Dbgaff
    If LVCRTYP=10
        Call ADDCRIT(CRIT,ICRIT,"","[MFG]MFGSTA>= LMFGSTADEB","&") From GOBJSUB
        Call ADDCRIT(CRIT,ICRIT,"","[MFG]MFGSTA<= LMFGSTAFIN","&") From GOBJSUB
        If LMFGTRKFLG<>""
            Call ADDCRIT(CRIT,ICRIT,"","find([MFG]MFGTRKFLG,"+LMFGTRKFLG+")<>0","&") From GOBJSUB
        Endif
        Case [L]LIFAFLG
          When "1" : # Etat en-cours global
            Call ADDCRIT(CRIT,ICRIT,"","CREDAT<=[L]LDATEMAX","&") From GOBJSUB
          When "2" : # Etat des en-cours comptabilisés
            # Issue 92767 - 2013-09-24 by CCC : GLPSTA test
            Call ADDCRIT(CRIT,ICRIT,"","GLPSTA=2 & GLPDAT<=[L]LDATEMAX","&") From GOBJSUB
        Endcase
        Link [MWI] With [MFG]MFG0=[MWI]VCRNUM
&                     , [FCY]FCY0=[MWI]MFGFCY
&                    As [LNK]
&                  Where [FCY]LEGCPY=LCPY
&                      & VCRTYP = LVCRTYP
&                      & evalue(CRIT)
&                      & find(TXNTYP,15,16,18,19,20)=0
        If LFORCOD<>""             # Formule de sélection sur [F:MFI]
           Read [F:TFO]TFO0=38;LFORCOD     # FQ 62959 GA 03/2010
           If !fstat
              Call ADDCRIT(CRITMFI,ICRIT,"",[F:TFO]FORFOR,"&") From GOBJSUB
           Else
              CRITMFI="1=1"
           Endif
        Else
          CRITMFI="1=1"
        Endif
    Elsif LVCRTYP=36
        Call ADDCRIT(CRIT,ICRIT,"","[SCO]SCOSTA>= LMFGSTADEB","&") From GOBJSUB
        Call ADDCRIT(CRIT,ICRIT,"","[SCO]SCOSTA<= LMFGSTAFIN","&") From GOBJSUB
        If LMFGTRKFLG<>""
            Call ADDCRIT(CRIT,ICRIT,"","find([SCO]SCOTRKFLG,"+LMFGTRKFLG+")<>0","&") From GOBJSUB
        Endif
        Case [L]LIFAFLG
          When "1" : # Etat en-cours global
            Call ADDCRIT(CRIT,ICRIT,"","CREDAT<=[L]LDATEMAX","&") From GOBJSUB
          When "2" : # Etat des en-cours comptabilisés
            # Issue 92767 - 2013-09-24 by CCC : GLPSTA test
            Call ADDCRIT(CRIT,ICRIT,"","GLPSTA=2 & GLPDAT<=[L]LDATEMAX","&") From GOBJSUB
        Endcase
        Link [MWI] With [SCO]SCO0=[MWI]VCRNUM
&                     , [FCY]FCY0=[MWI]MFGFCY
&                    As [LNK]
&                  Where [FCY]LEGCPY=LCPY
&                      & VCRTYP = LVCRTYP
&                      & evalue(CRIT)
&                      & find(TXNTYP,15,16,18,19,20)=0
        If LFORCOD<>""             # Formule de sélection sur [F:SCI]
           Read [F:TFO]TFO0=47;LFORCOD     # FQ 62959 GA 03/2010
           If !fstat
              Call ADDCRIT(CRITSCI,ICRIT,"",[F:TFO]FORFOR,"&") From GOBJSUB
           Else
              CRITSCI="1=1"
           Endif
        Else
           CRITSCI="1=1"
        Endif
    Else
        Commit    # Issue 78041 - 2011-11-21 by CCC
        End
    Endif

    For [LNK]
        Raz [F:WRW]
        [F:WRW]UID = adxuid(1)
        [F:WRW]MFGFCY = [F:MWI]MFGFCY : # GH 28/01/2014 dm 94629
        [F:WRW]VCRTYP = [F:MWI]VCRTYP
        [F:WRW]VCRNUM = [F:MWI]VCRNUM
        If LVCRTYP=10
            If [F:MFG]MFGNUM<>[F:MWI]VCRNUM
                Read [MFG]MFG0=[F:MWI]VCRNUM
            Endif
            # FQ 62959 GA 03/2010 & evalue(CRITMFI)
            Filter [MFI] Where MFGNUM=[F:MWI]VCRNUM & evalue(CRITMFI)
            LNBMFI = rowcount([F:MFI])
            Filter [MFI]
            # Issue 106308 - 2016-06-07 by CCC : Take into account by-products for real expenses as if it was a component
            If [F:MWI]ITMTYP=2
                Read [MFI]MFI0=[F:MWI]VCRNUM;[F:MWI]VCRLIN
                If !fstat
                    [F:MWI]VCRLIN = [F:MFI]ITMLIN
                Endif
                [F:MWI]TXNTYP=1
            Endif

            For [MFI] Where MFGNUM=[F:MWI]VCRNUM
&                        & (MFGLIN=[F:MWI]VCRLIN | [F:MWI]VCRLIN=0)
&                        & ITMTYP=1 &  evalue(CRITMFI)
                If [F:MWI]VCRLIN=0
                    If [F:MFG]CPLQTY<>0
                        LCOE = [F:MFI]CPLQTY / [F:MFG]CPLQTY
                    Else
                        LCOE = 1
                    Endif
                Else
                    LCOE = 1
                Endif
               [F:WRW]VCRLIN=[F:MFI]MFGLIN
               Gosub LOA_TXNTYP
            Next  # [F:MFI]
        Elsif LVCRTYP=36
            If [F:SCO]SCONUM<>[F:MWI]VCRNUM
                Read [SCO]SCO0=[F:MWI]VCRNUM
            Endif
            # FQ 62959 GA 03/2010 & evalue(CRITSCI)
            Filter [SCI] Where SCONUM=[F:MWI]VCRNUM & evalue(CRITSCI)
            LNBMFI = rowcount([F:SCI])  # Une seule ligne dans les premières versions ...
            Filter [SCI]
            For [SCI] Where SCONUM=[F:MWI]VCRNUM & ([F:MWI]VCRLIN=0 | SCILIN=[F:MWI]VCRLIN)
&                        &  evalue(CRITSCI)
                LCOE = 1
                [F:WRW]VCRLIN=[F:SCI]SCILIN
               Gosub LOA_TXNTYP
            Next  # [F:SCI]
        Endif
    Next
    GPOINT = "IMPWIPVAL"
    Gosub ENTREE From EXEFNC
Commit

End

$LOA_TXNTYP
If find([F:MWI]TXNTYP,14,17)
    For I=1 To 8
      # Les valeurs proviennent du mono-niveau mais ne sont pas détaillées par famille de coût
        LTYP = I
        LAMT = -[F:MWI]CSTELM(I-1)
        Raz LBRD
        If LAMT<>0
            Gosub ALIM_WRW
        Endif
    Next
Elsif [F:MWI]TXNTYP=13
    LTYP = 5
    LAMT = -[F:MWI]OVEMATCST
    If LAMT<>0
        Gosub ALIM_WRW
    Endif
    LTYP = 6
    LAMT = -[F:MWI]OVELABCST
    If LAMT<>0
        Gosub ALIM_WRW
    Endif
    LTYP = 7
    LAMT = -[F:MWI]OVEMACCST
    If LAMT<>0
        Gosub ALIM_WRW
    Endif
    LTYP = 8
    LAMT = -[F:MWI]OVESCOCST
    If LAMT<>0
        Gosub ALIM_WRW
    Endif
Else
    LTYP = [F:MWI]TXNTYP
    If [F:MWI]TXNTYP>8
        LAMT = -[F:MWI]AMOUNT
    Else
        LAMT = [F:MWI]AMOUNT
    Endif
    Raz LBRD
    Case LTYP
        When 1 : LBRD = [F:MWI]MATGRP
        When 2 : LBRD = [F:MWI]OPEGRP
        When 3 : LBRD = [F:MWI]OPEGRP
    Endcase
    If LAMT<>0
        Gosub ALIM_WRW
    Endif
Endif
Return

$ALIM_WRW
    [F:WRW]BRDCOD = LBRD
    Case LTYP
        When 1, 9 :  [F:WRW]TYPCST = 1
        When 2, 10 : [F:WRW]TYPCST = 3
        When 3, 11 : [F:WRW]TYPCST = 2
        When 4, 12 : [F:WRW]TYPCST = 4
        When 5,6,7,8 : [F:WRW]TYPCST = 5
                       Case [F:MWI]TXNTYP
                           When 5 : [F:WRW]OVETYPCST = 1
                           When 6 : [F:WRW]OVETYPCST = 3
                           When 7 : [F:WRW]OVETYPCST = 2
                           When 8 : [F:WRW]OVETYPCST = 4
                           When 13 :
                                If LTYP=5 : [F:WRW]OVETYPCST = 1 : Endif
                                If LTYP=6 : [F:WRW]OVETYPCST = 3 : Endif
                                If LTYP=7 : [F:WRW]OVETYPCST = 2 : Endif
                                If LTYP=8 : [F:WRW]OVETYPCST = 4 : Endif
                           When 14 : [F:WRW]OVETYPCST = 1
                       Endcase
    Endcase

    Readlock [WRW2]WRW0=[F:WRW]UID;[F:WRW]VCRTYP;[F:WRW]VCRNUM;[F:WRW]VCRLIN;[F:WRW]TYPCST;[F:WRW]OVETYPCST;[F:WRW]BRDCOD
    If fstat=0
        If [F:MWI]TXNTYP > 8
          #X3-91472.n MJH put all variances into a new field
          If find([F:MWI]TXNTYP,9,10,11,12,13)
            [F:WRW2]VARAMT += LAMT
          Else
            [F:WRW2]EXTAMT += LAMT #original
          Endif
        Else
            [F:WRW2]CPLAMT += LAMT*LCOE
        Endif
        Rewrite [WRW2]
    Else
        If [F:MWI]TXNTYP > 8
          #X3-91472.n MJH put all variances into a new field
          If find([F:MWI]TXNTYP,9,10,11,12,13)
            [F:WRW]VARAMT = LAMT
          Else
            [F:WRW]EXTAMT = LAMT #original
          Endif
        Else
            [F:WRW]CPLAMT = LAMT*LCOE
        Endif
        Write [WRW]
    Endif
Return

