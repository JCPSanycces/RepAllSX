# Classe SIDHYBHANDLE
#------------------------------------------------------------------------------
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS

  Case [L]CURPTH
     When "SIDTOSVIC.SVCRINVCND"
      Case [L]AEVENT
        When "AREAD" : Gosub SIDTOSVIC_SVCRINVCND_AREAD
      Endcase
  Endcase

Return
#------------------------------------------------------------------------------
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES

  #Case [L]CURPRO
  #   Case [L]ARULE
  #   Endcase
  #Endcase

Return
#------------------------------------------------------------------------------
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS

  Case [L]AMETHOD
    When "GET_INDEX"                   : Gosub GET_INDEX
    When "GET_INDEX_WITH_INSTANCE_ADD" : Gosub GET_INDEX_WITH_INSTANCE_ADD
    When "REMOVE_INDEX_INSTANCE"       : Gosub REMOVE_INDEX_INSTANCE
    When "UPDATE_INSTANCE"             : Gosub UPDATE_INSTANCE
    When "UPDATE_ALL"                  : Gosub UPDATE_ALL
    #--'Private' methods => not to be used outside the present class
    When "_INSTANCE_ADD"               : Gosub _INSTANCE_ADD
    When "_INSTANCE_REMOVE"            : Gosub _INSTANCE_REMOVE
  Endcase

Return
#------------------------------------------------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return
#------------------------------------------------------------------------------
$SIDTOSVIC_SVCRINVCND_AREAD

Return
#------------------------------------------------------------------------------
#**
#* Gives the SVCRINVCND instance's index in the SIDHYBHANDLE.SVCRINVCND() collection, if present.
#* If not present, the VINDEX is returned as [V]cst_anotdefined
#* @param IN     : PVCRTYP
#* @param IN     : PVCRNUMORI
#* @param IN     : PVCRLINORI
#* @param IN     : PVCRSEQORI
#* @param IN     : PVCRINVCNDLIN -
#* @param OUT    : VAUUID - the char(AUUID) of the header SVCRINVCND instance
#* @param OUT    : VINDEX - the index of the SVCRINVCND collection instance's record
#*!
$GET_INDEX

Local Integer WLINE,WLINE1,WIJCPO,WSVIC_INDEX

  VINDEX = [V]CST_ANOTDEFINED

  #--No need to continue if no entry given
  If PVCRTYP=AVOID.AINT or PVCRNUMORI=AVOID.ACHAR or PVCRLINORI=0
    Return
  Endif

  For WLINE=1 To maxtab(this.SIDTOSVIC)
    If this.SIDTOSVIC(WLINE)<>null and find(this.SIDTOSVIC(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      If this.SIDTOSVIC(WLINE).VCRTYP   = PVCRTYP    and this.SIDTOSVIC(WLINE).VCRNUMORI = PVCRNUMORI and
&        this.SIDTOSVIC(WLINE).VCRLINORI= PVCRLINORI and this.SIDTOSVIC(WLINE).VCRSEQORI = PVCRSEQORI
        VINDEX = WLINE
        WSVIC_INDEX = this.SIDTOSVIC(WLINE).SVIC_INDEX
        If WSVIC_INDEX>0 and this.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC_INDEX)<>null and
&     find(this.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
          #--
          For WIJCPO = 1 To maxtab(this.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN)
            If this.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WIJCPO)<>null and
&         find(this.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WIJCPO).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and
&              this.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WIJCPO).VCRINVCNDLIN = PVCRINVCNDLIN
              If VAUUID<>""
                #--The instance might be already loaded, let's test if UUID matches
                If toUuid(VAUUID) <> this.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WIJCPO).AUUID
                  [L]ARET_VALUE = fmet this.ASETERROR("","UUID mismatch between entry parameter and loaded record",[V]CST_AERROR)
                  [L]ASTATUS = [L]ARET_VALUE
                Endif
              Else
                VAUUID = num$(this.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC_INDEX).VCRINVCNDLIN(WIJCPO).AUUID)
              Endif
              Break
            Endif
          Next
        Endif
        Break
      Endif
    Endif
  Next

Return
#------------------------------------------------------------------------------
#**
#* Gives the SVCRINVCND instance's index in the SIDHYBHANDLE.SVCRINVCND() collection, if present.
#* If not present, then the entry is loaded with the right record
#* @param IN     : PVCRTYP
#* @param IN     : PVCRNUMORI
#* @param IN     : PVCRLINORI
#* @param IN     : PVCRSEQORI
#* @param IN     : PVCRINVCNDLIN -
#* @param OUT    : VAUUID - the char(AUUID) of the header SVCRINVCND instance
#* @param OUT    : VINDEX - the index of the SVCRINVCND collection instance's record
#*!
$GET_INDEX_WITH_INSTANCE_ADD

Local Integer WLINE

  VINDEX = [V]CST_ANOTDEFINED

  #--No need to continue if no entry given
  If PVCRTYP=AVOID.AINT or PVCRNUMORI=AVOID.ACHAR or PVCRLINORI=0
    Return
  Endif

  [L]ARET_VALUE = fmet this.GET_INDEX(PVCRTYP,PVCRNUMORI,PVCRLINORI,PVCRSEQORI,PVCRINVCNDLIN,VAUUID,VINDEX)
  If [L]ARET_VALUE>=[V]CST_AERROR
    Return
  Endif

  #--If nothing found, let's add the record
  If VINDEX=[V]CST_ANOTDEFINED
    [L]ARET_VALUE = fmet this._INSTANCE_ADD(PVCRTYP,PVCRNUMORI,PVCRLINORI,PVCRSEQORI,PVCRINVCNDLIN,VAUUID,VINDEX)
    If [L]ARET_VALUE>=[V]CST_AERROR
      Return
    Endif
  Endif

Return
#------------------------------------------------------------------------------
#**
#* Remove all modifications asked for the PVCRINVCNDLIN schedule invoice line (SIDTOSVICD entries).
#* Also, it removes the SVCRINVCND schedule invoice instance, if no other lines for the present schedule invoice
#* @param IN     : PVCRTYP
#* @param IN     : PVCRNUMORI
#* @param IN     : PVCRLINORI
#* @param IN     : PVCRSEQORI
#* @param IN     : PVCRINVCNDLIN -
#* @param IN     : PAUUID - the char(AUUID) of the header SVCRINVCND instance
#* @param IN     : PSIHNUM
#*!
$REMOVE_INDEX_INSTANCE
Local Integer  WLINE,WSVIC
Local Shortint IS_LAST_LINE

  #--No need to continue if no entry given
  If PVCRTYP=AVOID.AINT or PVCRNUMORI=AVOID.ACHAR or PVCRLINORI=0
    Return
  Endif

  [L]ARET_VALUE = fmet this.GET_INDEX(PVCRTYP,PVCRNUMORI,PVCRLINORI,PVCRSEQORI,PVCRINVCNDLIN,PAUUID,WLINE)
  If [L]ARET_VALUE>=[V]CST_AERROR
    Return
  Endif

  #--If found, let's remove the entries
  If WLINE<>[V]CST_ANOTDEFINED
    #--First, removing all marked changes
    [L]ARET_VALUE = fmet this.SIDTOSVIC(WLINE).UNSET_NEW(PVCRINVCNDLIN,PSIHNUM,IS_LAST_LINE)
    If [L]ARET_VALUE>=[V]CST_AERROR
      Return
    Endif
    #--Setting line's status to 'To be invoiced'
    [L]ARET_VALUE = fmet this.SIDTOSVIC(WLINE).SET_LIG_INVCNDSTA(PVCRINVCNDLIN,1)
    If [L]ARET_VALUE>=[V]CST_AERROR
      Return
    Endif
    #--Setting invoice number and line number to void
    [L]ARET_VALUE = fmet this.SIDTOSVIC(WLINE).SET_LIG_SIHNUM(PVCRINVCNDLIN,AVOID.ACHAR,AVOID.AINT)
    If [L]ARET_VALUE>=[V]CST_AERROR
      Return
    Endif

#    If IS_LAST_LINE=[V]CST_AYES
#      #--Secondly, removing the schedule invoice instance (if no other lines from it are marked for changing)
#      WSVIC = this.SIDTOSVIC(WLINE).SVIC_INDEX
#      If WSVIC>AVOID.AINT and this.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC)<>null and
#&        find(this.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
#        [L]ARET_VALUE = fmet this.SIDTOSVIC(WLINE).ADELLINE("SVCRINVCND",this.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).AORDER)
#        If [L]ARET_VALUE=[V]CST_ANOTDEFINED
#          Return
#        Endif
#        this.SIDTOSVIC(WLINE).SVIC_INDEX =AVOID.AINT
#      Endif
#      #--Finally, removing the working schedule invoice
#      [L]ARET_VALUE = fmet this.ADELLINE("SIDTOSVIC",this.SIDTOSVIC(WLINE).AORDER)
#      If [L]ARET_VALUE=[V]CST_ANOTDEFINED
#        Return
#      Endif
#    Endif
  Endif

Return
#------------------------------------------------------------------------------
#**
#* Addind a SVCRINVCND instance to the SIDHYBHANDLE.SVCRINVCND() collection, if not present yet
#* @param IN     : PVCRTYP
#* @param IN     : PVCRNUMORI
#* @param IN     : PVCRLINORI
#* @param IN     : PVCRSEQORI
#* @param IN     : PVCRINVCNDLIN -
#* @param OUT    : VAUUID - the char(AUUID) of the header SVCRINVCND instance
#* @param OUT    : VINDEX - the index of the SVCRINVCND collection instance's record
#*!
$_INSTANCE_ADD
Local Integer WLINE,WLINE1,WIJCPO,WRET

  If VINDEX>AVOID.AINT : Return : Endif

  #--No need to continue if no entry given
  If PVCRTYP=AVOID.AINT or PVCRNUMORI=AVOID.ACHAR or PVCRLINORI=0
    Return
  Endif

  VINDEX = [V]CST_ANOTDEFINED

  WLINE = fmet this.ADDLINE("SIDTOSVIC",[V]CST_ALASTPOS)
  If WLINE = [V]CST_ANOTDEFINED
    [L]ARET_VALUE = [V]CST_AERROR
    Return
  Endif
  #--
  this.SIDTOSVIC(WLINE).VCRTYP     = PVCRTYP
  this.SIDTOSVIC(WLINE).VCRNUMORI  = PVCRNUMORI
  this.SIDTOSVIC(WLINE).VCRLINORI  = PVCRLINORI
  this.SIDTOSVIC(WLINE).VCRSEQORI  = PVCRSEQORI
  #--Others
  this.SIDTOSVIC(WLINE).IS_CHANGED = [V]CST_ANO
  this.SIDTOSVIC(WLINE).TO_UPDATE  = [V]CST_ANO
  #--
  WLINE1 = fmet this.SIDTOSVIC(WLINE).ADDLINE("SVCRINVCND",[V]CST_ALASTPOS)
  If WLINE1 = [V]CST_ANOTDEFINED
    [L]ARET_VALUE = [V]CST_AERROR
    Return
  Endif

  [L]ARET_VALUE = fmet this.SIDTOSVIC(WLINE).SVCRINVCND(WLINE1).AREAD(PVCRTYP,PVCRNUMORI,PVCRLINORI,PVCRSEQORI)

  If [L]ARET_VALUE>=[V]CST_AERROR : Return : Endif
  #--The wanted index
  VINDEX = WLINE
  #--The SVIC instance's index for further use
  this.SIDTOSVIC(WLINE).SVIC_INDEX = WLINE1

  #--The instance wasn't loaded before
  For WIJCPO = 1 To maxtab(this.SIDTOSVIC(WLINE).SVCRINVCND(WLINE1).VCRINVCNDLIN)
    If this.SIDTOSVIC(WLINE).SVCRINVCND(WLINE1).VCRINVCNDLIN(WIJCPO)<>null and
& find(this.SIDTOSVIC(WLINE).SVCRINVCND(WLINE1).VCRINVCNDLIN(WIJCPO).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and
&      this.SIDTOSVIC(WLINE).SVCRINVCND(WLINE1).VCRINVCNDLIN(WIJCPO).VCRINVCNDLIN = PVCRINVCNDLIN
      If VAUUID<>""
        #--The instance might be already loaded, let's test if UUID matches
        If toUuid(VAUUID) <> this.SIDTOSVIC(WLINE).SVCRINVCND(WLINE1).VCRINVCNDLIN(WIJCPO).AUUID
          [L]ARET_VALUE = fmet this.ASETERROR("","UUID mismatch between entry parameter and loaded record",[V]CST_AERROR)
          [L]ASTATUS = [L]ARET_VALUE
        Endif
      Else
        VAUUID = num$(this.SIDTOSVIC(WLINE).SVCRINVCND(WLINE1).VCRINVCNDLIN(WIJCPO).AUUID)
      Endif
      Break
    Endif
  Next

Return
#------------------------------------------------------------------------------
#**
#* Removing a SVCRINVCND instance from the SIDHYBHANDLE.SVCRINVCND() collection, if present
#* @param IN     : PVCRTYP
#* @param IN     : PVCRNUMORI
#* @param IN     : PVCRLINORI
#* @param IN     : PVCRSEQORI
#* @param IN     : PVCRINVCNDLIN -
#* @param IN     : PAUUID - the char(AUUID) of the header SVCRINVCND instance
#*!
$_INSTANCE_REMOVE

Return
#------------------------------------------------------------------------------
#**
#* Updates the SVCRINVCND instance from the SIDHYBHANDLE.SVCRINVCND() collection, if present
#* @param IN     : PVCRTYP
#* @param IN     : PVCRNUMORI
#* @param IN     : PVCRLINORI
#* @param IN     : PVCRSEQORI
#* @param IN     : PVCRINVCNDLIN -
#* @param IN/OUT : VAUUID - the char(AUUID) of the header SVCRINVCND instance
#*!
$UPDATE_INSTANCE


Return
#------------------------------------------------------------------------------
#**
#* Updates all the SVCRINVCND instances from the SIDHYBHANDLE.SVCRINVCND() collection
#*!
$UPDATE_ALL
Local Integer WLINE,WSVIC,WTMP

  For WLINE=1 To maxtab(this.SIDTOSVIC)
    If this.SIDTOSVIC(WLINE)<>null and find(this.SIDTOSVIC(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      WSVIC = this.SIDTOSVIC(WLINE).SVIC_INDEX
      If WSVIC>0 and this.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC)<>null and
&               find(this.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        #--Calling the update method
        [L]ARET_VALUE = fmet this.SIDTOSVIC(WLINE).SVCRINVCND(WSVIC).AUPDATE()
        If ([L]ARET_VALUE >= [V]CST_AERROR)
          Break
        Endif
      Endif
    Endif
  Next

Return
#------------------------------------------------------------------------------

