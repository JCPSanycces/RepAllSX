# Gestion du masque VISUCUN

Subprog IB_BASPAG
GBOUT2 = mess(51,184,1)

End

Subprog B2_BASPAG
GCONSULT = 2
Call OBJET("SNX",[M:VCUN]CUNSSSNUM(nolign-1),GBIDC1)From GOBJET   
GCONSULT = 0

End
Subprog B3_BASPAG
Gosub SET_NOL From STKINV
GCONSULT = 2
Call OBJET("SNL",[M:VCUN]CUNLISNUM(nolign-1),[M:VCUN]CUNSSSNUM(nolign-1)) From GOBJET   
GCONSULT = 0

End
