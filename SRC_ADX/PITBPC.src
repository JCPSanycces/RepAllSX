#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################
# Sous-pro pour pivot de type : clients
#                             cf AML 2240 : 37
###################################################
# FQ 64773 GA 05/2010 préfixe des noms de variables BPCWPIV devient WK, CRIBPCWPIV devient CRIWK
######################################################################
$OUVTAB_BPC
If !clalev([F:AXX]) Local File ATEXTRA   [AXX] Endif
If !clalev([F:BPR]) Local File BPARTNER  [BPR] Endif
If !clalev([F:BPR_]) Local File BPARTNER  [BPR_] Endif
If !clalev([F:BPC]) Local File BPCUSTOMER[BPC] Endif
If !clalev([F:BPA]) Local File BPADDRESS [BPA] Endif   
If !clalev([F:BCG]) Local File BPCCATEG  [BCG] Endif   
If !clalev([F:FCY]) Local File FACILITY[FCY] Endif
If !clalev([F:CPY]) Local File COMPANY [CPY] Endif
Raz [F:FCY],[F:CPY],[F:BPR],[F:BPC]
Return

######################################################################
Subprog TRT_BPC(ID,CLETRT,PITBPC,P_CRITERE,PITCRIBPC,OK)
Value Char ID()
Value Char CLETRT () 
Value Char PITBPC () 
Value Char P_CRITERE() 
Value Char PITCRIBPC () 
Variable Integer OK

If PITBPC="" : Return : Endif

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
If ID="SCMA"
adxium = GASCII
Else
adxium = GUTF8
Endif
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs


Gosub OUVTAB_BPC
Gosub OUVREPIVOT From CONNECTFCT


If PITBPC<>""
    Local Integer WNBBPC  : Raz WNBBPC 
    Local Integer WPREBPC : Raz WPREBPC
    Local Char    OPTBPC(GDIMFIC)
    If ID="SCMA"
        OPTBPC = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitfcy")
    Else
        OPTBPC = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitbpc")
    Endif
    Local Integer WKNBZON        : Raz WKNBZON
    Local Char    WKNORECMES (50): Raz WKNORECMES 
    Local Integer WKHEATYP       : Raz WKHEATYP 
    Local Char    WKHEADMES (250): Raz WKHEADMES 
    
    Call READPIT(PITBPC,WKNBZON,WKNORECMES,WKHEATYP ,WKHEADMES ) From CONNECTFCT
    Local Char WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
    Local Char WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
    Local Char WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
    Local Char WKFRM(150)(1..WKNBZON) : Raz WKFRM
    Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
    Local Char WKVAL(255)(1..WKNBZON) : Raz WKVAL
    Local Char WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC
    Call LOADPIVZON(PITBPC,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
    If ID="SCMA"
        #pas entête si SCMA
        WPREBPC = 1
        WNBBPC = 1
    Else
        #pas entête si SCMA
        Call WRPIVOT_HEAD(PITBPC,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPREBPC,OPTBPC) From CONNECTFCT
    Endif
Endif

If PITCRIBPC<>""
    Local Integer WNBCRIBPC  : Raz WNBCRIBPC 
    Local Integer WPRECRIBPC : Raz WPRECRIBPC
    Local Char    OPTCRIBPC(GDIMFIC)
    If ID="SCMA"
        OPTCRIBPC = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitcrifcy")
    Else
        OPTCRIBPC = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitcribpc")
    Endif
    Local Integer CRIWKNBZON        : Raz CRIWKNBZON
    Local Char    CRIWKNORECMES (50): Raz CRIWKNORECMES 
    Local Integer CRIWKHEATYP       : Raz CRIWKHEATYP 
    Local Char    CRIWKHEADMES (250): Raz CRIWKHEADMES 
    
    Call READPIT(PITCRIBPC,CRIWKNBZON,CRIWKNORECMES,CRIWKHEATYP ,CRIWKHEADMES ) From CONNECTFCT
    Local Char    CRIWKTABZON(GLONATB+GLONAVA+2)(1..CRIWKNBZON) : Raz CRIWKTABZON
    Local Char    CRIWKTABABR(GLONABR)(1..CRIWKNBZON) : Raz CRIWKTABABR
    Local Char    CRIWKZON(GLONAVA)(1..CRIWKNBZON) : Raz CRIWKTABZON
    Local Char    CRIWKFRM(150)(1..CRIWKNBZON) : Raz CRIWKFRM
    Local Integer CRIWKWRK(1..CRIWKNBZON) : Raz CRIWKWRK
    Local Char    CRIWKVAL(255)(1..CRIWKNBZON) : Raz CRIWKVAL
    Local Char    CRIWKVALFIC(GLONAVA)(1..CRIWKNBZON) : Raz CRIWKVALFIC
    Call LOADPIVZON(PITCRIBPC,CRIWKNBZON,CRIWKTABZON,CRIWKTABABR,CRIWKZON,CRIWKFRM,CRIWKWRK) From CONNECTFCT
    If ID="SCMA"
        If [M:DIA]CRYFLG  = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPARTNER"+"/"+"CRY",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]BCGCODFLG  = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPCUSTOMER"+"/"+"BCGCOD",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]TSCCOD0FLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPCUSTOMER"+"/"+"WTSCCOD0",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]TSCCOD1FLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPCUSTOMER"+"/"+"WTSCCOD1",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]TSCCOD2FLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPCUSTOMER"+"/"+"WTSCCOD2",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]TSCCOD3FLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPCUSTOMER"+"/"+"WTSCCOD3",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]TSCCOD4FLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPCUSTOMER"+"/"+"WTSCCOD4",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]BPCINVFLG  = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPCUSTOMER"+"/"+"BPCINV",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]BPCGRUFLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPCUSTOMER"+"/"+"BPCGRU",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        #pas entête si SCMA
        WPRECRIBPC = 1
        WNBCRIBPC = 1
    Else
        #pas entête si SCMA
        Call WRPIVOT_HEAD(PITCRIBPC,CRIWKNBZON,CRIWKTABZON,CRIWKTABABR,CRIWKZON,CRIWKWRK,CRIWKHEATYP,CRIWKHEADMES,WPRECRIBPC,OPTCRIBPC) From CONNECTFCT
    Endif
Endif

#######
Link [BPC] With [BPR]BPR0~=[F:BPC]BPCNUM
& As [LNK]
& Where [F:BPR]BPCFLG=2

For [LNK]BPC0 Where evalue(P_CRITERE)
    #Raz [BPA]
    #Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
    Gosub WR_BPC
    Gosub WR_CRIBPC
Next
#######
If PITBPC<>"" : Call WRPIVOT_END(PITBPC ,WNBBPC ,WKNORECMES ,WPREBPC ,OPTBPC) From CONNECTFCT : Endif
If PITCRIBPC<>"" : Call WRPIVOT_END(PITCRIBPC ,WNBCRIBPC ,CRIWKNORECMES ,WPRECRIBPC ,OPTCRIBPC) From CONNECTFCT : Endif
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End

######################################################################
$WR_BPC
If PITBPC<>""
    ################################
    # fichiers BPC
    ################################
    #     Ouverture du fichier OPTBPC en écriture
    If WPREBPC = 0
      Openo OPTBPC,0 Using [FPIV]
      WPREBPC = 1
    Else
      Openo OPTBPC Using [FPIV]
    Endif
    WNBBPC += 1
    Call RAZVALPIVOT(PITBPC,WKNBZON,WKVAL,WKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITBPC,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    Call WRPIVOT(WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return

######################################################################
$WR_CRIBPC
If PITCRIBPC<>""
    ################################
    # fichiers CRIBPC
    ################################
    #     Ouverture du fichier OPTCRIBPC en écriture
    If WPRECRIBPC = 0
      Openo OPTCRIBPC,0 Using [FPIV]
      WPRECRIBPC = 1
    Else
      Openo OPTCRIBPC Using [FPIV]
    Endif
    WNBCRIBPC += 1
    Call RAZVALPIVOT(PITCRIBPC,CRIWKNBZON,CRIWKVAL,CRIWKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITCRIBPC,CRIWKNBZON,CRIWKTABZON,CRIWKTABABR,CRIWKZON,CRIWKFRM,CRIWKWRK,CRIWKVAL,CRIWKVALFIC) From CONNECTFCT
    Call WRPIVOT(CRIWKNBZON,CRIWKTABZON,CRIWKTABABR,CRIWKZON,CRIWKFRM,CRIWKWRK,CRIWKVAL,CRIWKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return

######################################################################
Funprog BCG_GETDES(CODE,CHAMP)
Value Char CODE
Value Char CHAMP
If pat(GVERSION,"1.5.*")
    If !clalev([F:BCG]) Local File BPCCATEG  [BCG] Endif
    If [F:BCG]BCGCOD <> CODE
        Read [BCG]BCG0=CODE
        If fstat : End "" : Endif
    Endif
    If CHAMP="DESAXX"
        End [F:BCG]BCGDES
    Else
        End [F:BCG]BCGSHO
    Endif
Else
    End func AFNC.TEXTRA("BPCCATEG",CHAMP,CODE,"")
Endif
End ""
######################################################################
Funprog BPR_GETDES(CODE,CHAMP)
Value Char CODE
Value Char CHAMP
If !clalev([F:BPR_]) Local File BPARTNER  [BPR_] Endif
If [F:BPR_]BPRNUM <> CODE
    Read [BPR_]BPR0=CODE
    If fstat : End "" : Endif
Endif
End evalue("[F:BPR_]"+CHAMP)
######################################################################

