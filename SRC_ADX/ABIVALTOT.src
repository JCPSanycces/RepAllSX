#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ABIVALTOT","ABIVALTOT",3,"") From GTRAITE
End

#------------------------------------------------------------#
Call VALTOT("SUPERV",1,1,1,GBIDI1)
End

#------------------------------------------------------------#
Subprog VALTOT(APPLI,VALID,SYNCHRO,UNIVERS,OK)
Value Char APPLI
Value Integer VALID , SYNCHRO , UNIVERS
Variable Integer OK
Local Char VALBOUT(250) , PARBOUT(250)(1..20)
PARBOUT(1) = APPLI
PARBOUT(2) = num$(VALID)
PARBOUT(3) = num$(SYNCHRO)
PARBOUT(4) = num$(UNIVERS)
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","ABIVALTOT","ABIVALTOT",1,"") From GTRAITE
OK = val(PARBOUT(5))
End

#------------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
Endcase
Return

#------------------------------------------------------------#
$OUVRE_BATCH
$INIT
Local Char APPLI(GLONADS)
Local Integer VALID , SYNCHRO , UNIVERS
APPLI = PARAM(1)
VALID = val(PARAM(2))
SYNCHRO = val(PARAM(3))
UNIVERS = val(PARAM(4))
TIT = mess(96,148,1) : # Validation globale d'un datawarehouse
Local Integer ABIVALTOT : ABIVALTOT = 2
Return

#------------------------------------------------------------#
$INIT_DIA
[M] = [L]
[M]VALID   = [L]VALID+1
[M]SYNCHRO = [L]SYNCHRO+1
[M]UNIVERS = [L]UNIVERS+1
Return

#------------------------------------------------------------#
$EXEC
If TYPPRG=3
 [L]VALID   = [M]VALID-1
 [L]SYNCHRO = [M]SYNCHRO-1
 [L]UNIVERS = [M]UNIVERS-1
 [L]APPLI   = [M]APPLI
Endif

TRA = 1
If GSERVEUR or GTRACE<>""
 TRA = 0
Endif
If !GSERVEUR & !GIMPORT
 GINFO = 1
Else
 GINFO = 0
Endif

If TRA
 Call OUVRE_TRACE(TIT) From LECFIC : # Validation globale d'un datawarehouse
Endif

If GINFO
 Call OUVRE_VLC(mess(96,148,1) ,"","") From GESECRAN : # : Validation globale d'un datawarehouse
 Call AFF_VLC(mess(2,100,1),APPLI) From GESECRAN  : #  : Vérification en cours ...
Endif

OK = 1

If filinfo(filpath("FIL","ABIDATWRH","fde",APPLI),0)<=0 : Goto FIN : Endif

# Verif adxadmin
Local Char SERVEUR(250),PORT
Call RECHPROP("component.busobj.servername",SERVEUR,GBIDI1) From INTRUTILA
Call RECHPROP("busobj.adxadmin.port",PORT,GBIDI1) From INTRUTILA
Raz GBIDC1
Call VARADX("ADXDIR",SERVEUR+":"+PORT,GBIDC1) From ADXD
If GBIDC1=""
 OK = 0 : Call ECR_TRACE("("+SERVEUR+":"+PORT+") busobj.adxadmin not available" ,1) From GESECRAN
 Goto FIN
Endif

Local File =APPLI+".ABIDATWRH" [ABW9]

# Mise à jour des flags audits "bi" sur les tables des dossiers d'extractions

If VALID
 Call MAJFLG_AUDIT(APPLI) From ABIVALBAS
Endif

# Validation des datawhare

If VALID
 If GINFO : Call AFF_VLC(mess(2,148,1),"") From GESECRAN : Endif
 For [ABW9]
  If GINFO : Call AFF_VLC(mess(2,148,1),[F:ABW9]COD) From GESECRAN : Endif
  Call VALIDATION(APPLI,[F:ABW9]COD,1,0,1,OK) From ABIVALBAS
  If !OK : Break: Endif
 Next ABW9
 If !OK : Goto FIN : Endif
Endif

# Synchronisation Datawarehouse

If clalev([F:ADW])   : Close Local File [ADW]  : Endif
If clalev([F:ADP])   : Close Local File [ADP]  : Endif
If clalev([F:ADW])=0 : Local File =APPLI+".ADOVAL" [ADW] : Endif
If clalev([F:ADP])=0 : Local File =APPLI+".ADOPAR" [ADP] : Endif

Local Char DAT_DEB,DAT_FIN
Local Date DATDEB,DATFIN

Call PARAM("","STRDAT",DAT_DEB) From ADOVAL
Call PARAM("","ENDDAT",DAT_FIN) From ADOVAL
DATDEB = format$("YYYYMMDD",DAT_DEB)
DATFIN = format$("YYYYMMDD",DAT_FIN)
DATFIN = min(DATFIN,gdat$(31,12,int(year(DATDEB)/100)*100+99))
If GPRODUIT=2
 DATDEB = min(DATDEB,gdat$(1,1,year(DATDEB)-70))
Endif

If SYNCHRO
 If GINFO : Call AFF_VLC(mess(8,148,1) ,"") From GESECRAN : Endif
 For [ABW9]
  If GINFO : Call AFF_VLC(mess(8,148,1) ,[F:ABW9]COD) From GESECRAN : Endif
  Call SYNCHRO(APPLI,[F:ABW9]COD,1
&    , 2 , 2 , 1 , 1 ,  1 , 2 , 2 , 2 , 2 , 2 , 2 , 2
&    , 2 , 2 , "" , "" , DATDEB , DATFIN , "" , ""
&    , 0 , 0 , 0 , 0 , "" , "" , "" , ""
&    , "" , "") From ABIMAJBAS
 Next ABW9
Endif

# Creation des univers et mapping des états
Local Mask ABICREUNV [DIA]
Local File =APPLI+".ABIDATMRT" [ABM9]
Local Integer NBTOT

If UNIVERS
 If GINFO : Call AFF_VLC(mess(39,148,1),"") From GESECRAN : Endif
 For [ABW9]ABW0
  For  NBTOT=0 To [F:ABW9]NBRABM-1
   Raz [M:DIA]
   [M:DIA]EXPORT  = 1
   [M:DIA]AUTSIT  = 1
   [M:DIA]LANGORI = "FRA"
   [M:DIA]LANGDES = [F:ABW9]LAN
   [M:DIA]DATAM   = [F:ABW9]CODABM(NBTOT)
   [M:DIA]DATAW   = [F:ABW9]COD
   [M:DIA]EXPORT  = 2
   [M:DIA]TRAD = 2
   If GINFO : Call AFF_VLC(mess(39,148,1),[F:ABW9]CODABM(NBTOT)) From GESECRAN : Endif
   Gosub CREA_UNIVERS From ABICREUNV
  Next NBTOT
 Next
Endif

#-----------------------#
$FIN
PARAM(5) = num$(OK)
If GINFO
 Call FERME_VLC From GESECRAN 
Endif
If TRA
 Call FERME_TRACE From LECFIC
Endif
Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran ABIVALTOT) 02/01/2009 10:26:09 (CCL)
######################################################################################
Subprog C_APPLI(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Onerrgo ERRS
Local File =VALEUR+".ABIDATWRH" [ABW8]
Onerrgo
If OK=1 
 GMESSAGE = mess(128,148,1) : # Module BI non actif
 mkstat = 2 : End
Endif
Read [ABW8]ABW0 First
If fstat
 GMESSAGE = mess(129,148,1) : #  "Aucun Datawarehouse dans ce dossier"
 mkstat = 2 : End
Endif
End

$ERRS
OK=1
Resume

######################################################################################

