#<AdxTL>@(#)10.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"VISULIC","VISULIC","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "DEBUT"       : Gosub DEBUT
Endcase
Return

$OUVRE
Call MESSAGE(mess(1,133,1) ) From GESECRAN : FIN =1 : Return : # : Fonction incompatible avec l'environnement
Local Integer USER
Local Integer DIVERS(1..9)
Local Integer NOMBRE(1..12)
Return

$DEBUT
Local Integer I
Diszo 30-99
[M]FICHIER=""
I=func GLOBSUP.FICSERIAL(GPRODUIT,"",[M]FICHIER)
Gosub LIRE
Return

$APRES_MODIF
Case COUZON
 When "FICHIER" : [M]FICHIER = CZ : Gosub LIRE
Endcase
Return

$LIRE
If filinfo([M]FICHIER,0)>=0
 Call SERIAL([M]FICHIER,[M]LICENCE,[M]CHCLI,[M]CHDIS,[M]DATDEB,[M]DATFIN,USER,DIVERS,NOMBRE)
Endif
#[M]USERS = USER

# Type de produit (menu 2902)

[M]N6 = NOMBRE(6) : # Type produit : 1=X3, 2=Paye, 4=Géode
[M]PRODUIT = ""
For I=len(mess(0,2902,1)) To 1 Step -1
 If [M]N6>=2^(I-1)
  [M]PRODUIT = mess(I,2902,1)-[M]PRODUIT
  [M]N6 -= 2^(I-1)
 Endif
Next
[M]PRODUIT = vireblc([M]PRODUIT,2)
If [M]PRODUIT=""
 [M]PRODUIT = mess(1,2902,1)
Endif

# Nombre de sessions

[M]P1 = DIVERS(1) : # Sessions primaires
[M]P2 = DIVERS(2) : # Sessions secondaires
[M]P3 = DIVERS(3) : # Batchs
[M]P4 = DIVERS(4) : # Web services
[M]P5 = DIVERS(5) : # Terminal
If dim([M]P6)>0
 [M]P6 = DIVERS(6) : # Eclipse
Endif
If dim([M]P6)>0
 [M]P7 = DIVERS(7) : # Bridge java
Endif

# Theme graphique

[M]THEME = mess(max(1,DIVERS(8)),7856,1)

# Le dernier nombre est une série de Oui/non

[M]PORT  = 1 + (mod(DIVERS(9),2)<>0)    : # 1 : Portail
[M]MLEG  = 1 + (mod(DIVERS(9),4)>=2)    : # 2 : Multi-législations
[M]BI    = 1 + (mod(DIVERS(9),8)>=4)    : # 4 : Business intelligence
[M]NOMME = 1 + (mod(DIVERS(9),16)>=8)   : # 8 : Utilisateurs nommés

# Limites fonctionnelles applicatives (menu 933)

If mess(01,933,1)="" : Chgfmt N1  With "-N:8#" : Endif
If mess(02,933,1)="" : Chgfmt N2  With "-N:8#" : Endif
If mess(03,933,1)="" : Chgfmt N3  With "-N:8#" : Endif
If mess(04,933,1)="" : Chgfmt N4  With "-N:8#" : Endif
If mess(05,933,1)="" : Chgfmt N5  With "-N:8#" : Endif
If mess(06,933,1)="" : Chgfmt N6  With "-N:8#" : Endif
If mess(07,933,1)="" : Chgfmt N7  With "-N:8#" : Endif
If mess(08,933,1)="" : Chgfmt N8  With "-N:8#" : Endif
If mess(09,933,1)="" : Chgfmt N9  With "-N:8#" : Endif
If mess(10,933,1)="" : Chgfmt N10 With "-N:8#" : Endif
If mess(11,933,1)="" : Chgfmt N11 With "-N:8#" : Endif
If mess(12,933,1)="" : Chgfmt N12 With "-N:8#" : Endif

For I=1 To len(mess(0,933,1))
 If vireblc(mess(I,933,1),2)<>""
  Case I
   When 1  : [M]N1  = NOMBRE(1) : # (X3=Immobilisations)
   When 2  : [M]N2  = NOMBRE(2) : # (X3=Configurateur)
   When 3  : [M]N3  = NOMBRE(3) : # (X3=Ordonnancement)
   When 4  : [M]N4  = NOMBRE(4) : # (X3=Optimisation)
   When 5  : [M]N5  = NOMBRE(5) : # (X3=Balances)
   When 7  : [M]N7  = NOMBRE(7)
   When 8  : [M]N8  = NOMBRE(8)
   When 9  : [M]N9  = NOMBRE(9)
   When 10 : [M]N10 = NOMBRE(10)
   When 11 : [M]N11 = NOMBRE(11)
   When 12 : [M]N12 = NOMBRE(12)
  Endcase
 Endif
Next I

Affzo
Return

##########################################################################
Subprog SERIAL(FICHIER,LICENCE,CH1,CH2,DATDEB,DATFIN,USER,DIVERS,NOMBRE)
Value    Char    FICHIER
Variable Char    LICENCE()
Variable Char    CH1()(1..)
Variable Char    CH2()(1..)
Variable Date    DATDEB
Variable Date    DATFIN
Variable Integer USER
Variable Integer DIVERS(1..)
Variable Integer NOMBRE(1..)

Local Libelle CRYLIC(1..12)
Local Libelle CRYPT(1..12)
Local Libelle CRYCH(1..48)
Local Libelle CHAINE1(1..192)
Local Libelle CHAINE2(1..192)
Local Libelle CHAINE3(1..48)
Local Libelle CHAINE4(1..48)
Local Integer ENTIER(1..12)
Local Integer I , J , K
Local Integer X1 , X2 , X3 , X4
Local Integer OLD

## Lecture du fichier

If filinfo(FICHIER,0)<0
 Infbox mess(101,100,1)+"\|"+FICHIER+"|"
 End
Endif

Openi FICHIER

## No licence crypté

Getseq 12,CRYLIC

## Première chaine de 192

For I=1 To 16
 Raz CRYPT
 Getseq 12,CRYPT
 Call CRI(CRYPT)
 Call TRIP12(CRYPT,CRYLIC)
 For J=1 To 12
  CHAINE1(12*(I-1)+J) = CRYPT(J)
 Next J
Next I

## Deuxième chaîne de 192

For I=1 To 16
 Raz CRYPT
 Getseq 12,CRYPT
 Call CRI(CRYPT)
 Call TRIP12(CRYPT,CRYLIC)
 For J=1 To 12
  CHAINE2(12*(I-1)+J) = CRYPT(J)
 Next J
Next I

## Chaîne de 48 caractères

For I=1 To 4
 Raz CRYPT
 Getseq 12,CRYPT
 Call CRI(CRYPT)
 Call TRIP12(CRYPT,CRYLIC)
 For J=1 To 12
  CHAINE3(12*(I-1)+J) = CRYPT(J)
 Next J
Next I

## Chaîne de 48 caractères

OLD = 0
For I=1 To 4
 Raz CRYPT
 Getseq 12,CRYPT
 If fstat : OLD = 1 : Break : Endif
 Call CRI(CRYPT)
 Call TRIP12(CRYPT,CRYLIC)
 For J=1 To 12
  CHAINE4(12*(I-1)+J) = CRYPT(J)
 Next J
Next I

## Tripatouillage des octets d'une chaîne de 192 caractères

Call TRIP192(CHAINE1)
Call TRIP192(CHAINE2)

## Tripatouillage des octets d'une chaîne de 48 caractères

For I=1 To 4
 For J=1 To 48
  CRYCH(J) = CHAINE1(48*(I-1)+J)
 Next J
 Call TRIP48(CRYCH)
 CH1(I) = ""
 For J=1 To 48
  CH1(I) += chr$(CRYCH(J))
 Next J
Next I

For I=1 To 4
 For J=1 To 48
  CRYCH(J) = CHAINE2(48*(I-1)+J)
 Next J
 Call TRIP48(CRYCH)
 CH2(I) = ""
 For J=1 To 48
  CH2(I) += chr$(CRYCH(J))
 Next J
Next I

## Décodage des entiers

Call TRIP192(CHAINE3)
Call TRIP48(CHAINE3)
For I=1 To 12
 X1 = CHAINE3(4*(I-1)+1)
 X2 = CHAINE3(4*(I-1)+2)
 X3 = CHAINE3(4*(I-1)+3)
 X4 = CHAINE3(4*(I-1)+4)
 ENTIER(I) = X1*256*256*256 + X2*256*256 + X3*256 + X4
Next I

## Décodage des entiers

If !OLD
 Call TRIP192(CHAINE4)
 Call TRIP48(CHAINE4)
 For I=1 To 12
  X1 = CHAINE4(4*(I-1)+1)
  X2 = CHAINE4(4*(I-1)+2)
  X3 = CHAINE4(4*(I-1)+3)
  X4 = CHAINE4(4*(I-1)+4)
  NOMBRE(I) = X1*256*256*256 + X2*256*256 + X3*256 + X4
 Next I
Else
 Raz NOMBRE
Endif

## Restitution dates, users, ....

DATDEB = ENTIER(1) + [0/0/0]
DATFIN = ENTIER(2) + [0/0/0]
USER   = ENTIER(3)
For I=1 To 9
 DIVERS(I) = ENTIER(3+I)
Next I

## Décryptonisation du numero de licence

Call CRI(CRYLIC)
LICENCE = ""
For I=1 To 12
 LICENCE += chr$(CRYLIC(I))
Next I

Openi
End

#############################################
## Tripatouillage 1                        ##
#############################################
Subprog TRIP12(TRIP1,TRIP2)
Variable Libelle TRIP1(1..)
Variable Libelle TRIP2(1..)
Local Integer B1 , B2 , B3 , B4 , B5 , B6 , B7 , B8
Local Integer XB1 , XB2 , XB3 , XB4 , XB5 , XB6 , XB7 , XB8
Local Integer I
For I=1 To 12
 B1  =  TRIP1(I)/128
 B2  = (TRIP1(I)-128*B1)/64
 B3  = (TRIP1(I)-128*B1-64*B2)/32
 B4  = (TRIP1(I)-128*B1-64*B2-32*B3)/16
 B5  = (TRIP1(I)-128*B1-64*B2-32*B3-16*B4)/8
 B6  = (TRIP1(I)-128*B1-64*B2-32*B3-16*B4-8*B5)/4
 B7  = (TRIP1(I)-128*B1-64*B2-32*B3-16*B4-8*B5-4*B6)/2
 B8  =  TRIP1(I)-128*B1-64*B2-32*B3-16*B4-8*B5-4*B6-2*B7
 XB1 =  TRIP2(I)/128
 XB2 = (TRIP2(I)-128*XB1)/64
 XB3 = (TRIP2(I)-128*XB1-64*XB2)/32
 XB4 = (TRIP2(I)-128*XB1-64*XB2-32*XB3)/16
 XB5 = (TRIP2(I)-128*XB1-64*XB2-32*XB3-16*XB4)/8
 XB6 = (TRIP2(I)-128*XB1-64*XB2-32*XB3-16*XB4-8*XB5)/4
 XB7 = (TRIP2(I)-128*XB1-64*XB2-32*XB3-16*XB4-8*XB5-4*XB6)/2
 XB8 =  TRIP2(I)-128*XB1-64*XB2-32*XB3-16*XB4-8*XB5-4*XB6-2*XB7
 B1 = B1 xor XB1
 B2 = B2 xor XB2
 B3 = B3 xor XB3
 B4 = B4 xor XB4
 B5 = B5 xor XB5
 B6 = B6 xor XB6
 B7 = B7 xor XB7
 B8 = B8 xor XB8
 TRIP1(I) = 128*B1+64*B2+32*B3+16*B4+8*B5+4*B6+2*B7+B8
Next I
End

#############################################
## Tripatouillage 2                        ##
#############################################
Subprog TRIP48(TRIP)
Variable Libelle TRIP(1..)
Local Integer I , J , K0 , K1
For I=1 To 12 Step 2
 For J=4 To 2 Step -1
  K0 = 12*(J-2)+I
  K1 = 12*(J-1)+I
  TRIP(K1) = mod(TRIP(K1)+256-TRIP(K0),256)
 Next J
Next I
End

#############################################
## Tripatouillage 3                        ##
#############################################
Subprog TRIP192(TRIP)
Variable Libelle TRIP(1..)
Local Integer I , X , N
N = dim(TRIP)
For I=1 To N/2-1 Step 2
 X          = TRIP(I)
 TRIP(I)    = TRIP(I+N/2)
 TRIP(I+N/2) = X
Next I
End

#############################################
## Le bon vieux Crypton                    ##
#############################################
Subprog CRI(STR)
Variable Libelle STR(1..12)

Local Integer I , DEB , P(1..4) , R(1..4) , K(1..4)
Local Libelle C
Local Decimal PM , L, B1, B2

Gosub SWB12
DEB=0 : P(1)=191  : P(2)=193  : P(3)=197  : P(4)=199  : Gosub CRYPTON
DEB=4 : P(1)=101  : P(2)=103  : P(3)=107  : P(4)=109  : Gosub CRYPTON
DEB=8 : P(1)=1481 : P(2)=1483 : P(3)=17   : P(4)=19   : Gosub CRYPTON

# 2, 4217, 4219, 7, 11
# 6, 5, 13, 2741, 2749
# 4, 227, 229, 151, 157
DEB=2 : P(1)=4217 : P(2)=4219 : P(3)=7    : P(4)=11   : Gosub CRYPTON
DEB=6 : P(1)=5    : P(2)=13   : P(3)=2741 : P(4)=2749 : Gosub CRYPTON
DEB=4 : P(1)=227  : P(2)=229  : P(3)=151  : P(4)=157  : Gosub CRYPTON


C = STR(1)  : STR(1)  = STR(5)  : STR(5)  = C
C = STR(2)  : STR(2)  = STR(12) : STR(12) = C
C = STR(3)  : STR(3)  = STR(6)  : STR(6)  = C
C = STR(4)  : STR(4)  = STR(7)  : STR(7)  = C
C = STR(8)  : STR(8)  = STR(9)  : STR(9)  = C
C = STR(10) : STR(10) = STR(11) : STR(11) = C

DEB=4 : P(1)=227  : P(2)=229  : P(3)=151  : P(4)=157  : Gosub CRYPTON
DEB=6 : P(1)=5    : P(2)=13   : P(3)=2741 : P(4)=2749 : Gosub CRYPTON
DEB=2 : P(1)=4217 : P(2)=4219 : P(3)=7    : P(4)=11   : Gosub CRYPTON
DEB=8 : P(1)=1481 : P(2)=1483 : P(3)=17   : P(4)=19   : Gosub CRYPTON
DEB=4 : P(1)=101  : P(2)=103  : P(3)=107  : P(4)=109  : Gosub CRYPTON
DEB=0 : P(1)=191  : P(2)=193  : P(3)=197  : P(4)=199  : Gosub CRYPTON

Gosub SWB12
End

$CRYPTON
L = 0
For I = 1 To 4
 L = L*256 + STR(DEB+I)
Next

For I = 1 To 4
 R(I) = mod(L,P(I))
 K(I) = int(L/P(I))
 L = K(I)
Next

PM = 4278386431
PM = int(PM/(P(1)*P(2)))

If (K(4) < int(PM/(P(3)*P(4))))
 For I = 4 To 1 Step -1
  R(I) = P(I)-1-R(I)
 Next
Elsif (K(3) < int(PM/P(3)))
 For I = 3 To 1 Step -1
  R(I) = P(I)-1-R(I)
 Next
Elsif (K(2) < PM)
 For I = 2 To 1 Step -1
  R(I) = P(I)-1-R(I)
 Next
Endif

L = K(4)
For I = 4 To 1 Step -1
 L = L*P(I)+R(I)
Next
For I = 4 To 1 Step -1
 STR(DEB+I) = mod(L,256)
 L = int(L/256)
Next
Return

$SWB12
For I = 1 To 12
 B1         = mod(STR(DEB+I),16)
 B2         = STR(DEB+I)/16
 STR(DEB+I) = 16*B1+B2
Next
Return

