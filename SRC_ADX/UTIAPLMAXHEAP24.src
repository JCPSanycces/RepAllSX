#<AdxTL>@(#)3.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour MAXHEAP (mini 24 Mo) dans APLI.ini
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update maxheap parameter on APL.ini file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Local Char    WDOSSIER(250) , MACHINE(250) , APPLI(GLONADS)
WDOSSIER=DOSSIER
Call MACHINE([L]WDOSSIER,MACHINE,APPLI) From ORDSYS

Gosub MAJAPL
Gosub MAJADS
If WDOSHIS<>""
 If instr(1,[L]WDOSSIER,'@')>0
  [L]WDOSSIER= func AFNC.TRANSF([L]WDOSSIER,'@'+APPLI,'@'+WDOSHIS)
 Else
  [L]WDOSSIER=WDOSHIS
 Endif
 Call MACHINE([L]WDOSSIER,MACHINE,APPLI) From ORDSYS
 Gosub MAJAPL
Endif
End

#-------------------#
$MAJAPL

Local Char    NOMFIC(GDIMFIC) , NOMFIC2(GDIMFIC) , NOMFIC3(GDIMFIC)
Local Char    VALEUR(250) , VARIA(250) , LIGNE(250)
Local Integer K , TROUVE , STAT , NEWVAL , MODIF , OLDVAL,NEWVALINT

NEWVALINT = 24
NEWVAL = NEWVALINT*1024 : # Nouvelle valeur

Call ECR_TRACE("Folder"-[L]APPLI-"Update maxheap minimum : "-num$(NEWVAL)-time$,0) From GESECRAN

# Fichier APL.ini
NOMFIC = filpath("","APL","ini",[L]WDOSSIER)
If filinfo(NOMFIC,0)<=0
 Return
Endif

NOMFIC2 = filpath("","APL","new",[L]WDOSSIER)

Openi NOMFIC Using [IN]
Openo NOMFIC2 , 0 Using [OUT]
Iomode adxifs ""       Using [IN]
Iomode adxirs chr$(10) Using [IN]
Iomode adxium GASCII   Using [IN]
Iomode adxifs ""       Using [OUT]
Iomode adxirs chr$(10) Using [OUT]
Iomode adxium GASCII   Using [OUT]

Raz fstat , TROUVE , MODIF , OLDVAL

Repeat
 Rdseq LIGNE Using [IN]
 If !fstat
  K = instr(1,LIGNE,"=")
  If K
   VARIA = vireblc(left$(LIGNE,K-1),2)
   VALEUR = vireblc(right$(LIGNE,K+1),2)
   If VARIA="maxheap"
    TROUVE = 1
    OLDVAL = val(VALEUR)
    NEWVAL = max(NEWVAL,OLDVAL)
    If NEWVAL<>val(VALEUR)
     MODIF = 1
     LIGNE = "maxheap = "+num$(NEWVAL)
    Endif
   Endif
  Endif
  Wrseq LIGNE Using [OUT]
 Endif
Until fstat
If !TROUVE
 Wrseq "maxheap = "+num$(NEWVAL) Using [OUT]
 MODIF = 1
Endif

If MODIF
 Call ECR_TRACE("Folder"-[L]APPLI-": maxheap"-num$(OLDVAL)-"->"-num$(NEWVAL),0) From GESECRAN
Else
 Call ECR_TRACE("Folder"-[L]APPLI-": maxheap current value"-num$(OLDVAL),0) From GESECRAN
Endif

Openi Using [IN]
Openo Using [OUT]

If MODIF
 NOMFIC3 = filpath("","APL","old",[L]WDOSSIER)
 Call MOVE(NOMFIC,NOMFIC3,STAT) From ORDSYS
 Call MOVE(NOMFIC2,NOMFIC,STAT) From ORDSYS
Else
 Call EFFACE(NOMFIC2,STAT) From ORDSYS
Endif

Return

#########################################
$MAJADS
Local Char WDOSHIS(GLONADS)

 Local File =[L]WDOSSIER+".ADOVAL" [ADW]
 Read [ADW]ADW0="";"";"SUPDOS"
 If !fstat & [F:ADW]VALEUR<>""
  DOSX3 = [F:ADW]VALEUR
 Endif
 Close Local File [ADW]

 If MACHINE="" or DOSX3=""
  Local File ADOSSIER [ADX3]
 Else
  Local File =MACHINE+"@"+DOSX3+".ADOSSIER" [ADX3]
 Endif

 Read [ADX3]DOSSIER=APPLI
 WDOSHIS=[F:ADX3]DOSHIS
 NEWVAL = max(NEWVALINT,OLDVAL/1024,[F:ADX3]SYSPAR(5))
 #If MODIF
 If [F:ADX3]SYSPAR(5) <> int(NEWVAL)
  Trbegin [ADX3]
   [F:ADX3]SYSPAR(5) = int(NEWVAL)
   Rewrite [ADX3]
   If fstat : Call ERREUR("ADOSSIER",2) From DOSDIC : Endif
  Commit
 Endif

 Close Local File [ADX3]


Return

