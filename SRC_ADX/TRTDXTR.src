Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
If val(GFLAG)=2 :
 [M:DIA]YEADDS=num$(year(VALEUR))
 [M:DIA]ENDDAT=eomonth(VALEUR)
Else
 [M:DIA]ENDDAT=addmonth(VALEUR,12)-1
Endif
End

Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
If val(GFLAG)=2 : mkstat=2 : End : Endif
End
