#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion objet HRXGD
Raz GPILOBJ
Raz GBIDC1, GBIDC2
Call OBJET("HRXGD",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "FERME"       : Gosub FERME
 When "LIENS"       : Gosub LIENS
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "ANNULE"      : Gosub ANNULE
 When "CHGCOD"      : Gosub CHGCOD
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "AS_COD"      : Raz GCURLEG        :#Used in SELOBJETL action to disable the filter under the current legislation
 When "INICRE"      : Gosub INICRE   : # SBA-114309
 When "RAZCRE"      : Gosub RAZCRE   : # SBA-114309
Endcase
Return

########################################
$OUVRE
If clalev ([F:HRXGD])=0 : Local File HRXITGRD  [HRXGD] : Endif
If clalev ([F:HRXGD2])=0 : Local File HRXITGRD [HRXGD2] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

#LIPET - 2017-08-22 - START
If dim([M:HRXGD1]LEG)=0:If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif:Endif
#LIPET - 2017-08-22 - END
Return

########################################
$LIENS

GCURLEG = [F:HRXGD]LEG
#LIPET - 2017-08-22 - START
#If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If dim([M:HRXGD1]LEG)=0:If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif:Endif
#LIPET - 2017-08-22 - END

# To manage translated texts (data type AX3 & AX1)
Call LECTEXTRA([M]DESAXX,"HRXITGRD","DESAXX",[M]COD,GCURLEG) From ATEXTRA
Call LECTEXTRA([M]SHOAXX,"HRXITGRD","SHOAXX",[M]COD,GCURLEG) From ATEXTRA
# To display or to hide fields based on legislation code
Gosub DISPLAY_HIDE
Return

# SBA-114309
$RAZCRE
If func AFNC.ACTIV("LEG")=0
  [M]LEG=GDOSLEG(1)
  Affzo [M]LEG
Endif
GCURLEG=[M]LEG
Gosub DISPLAY_HIDE
Return

# SBA-114309
$INICRE
If !func DIVPAYE.IS_KFR()
  Raz [F]CODN4H, [F]CODMVT,[F]CODDSN
  [F]POLEMP=1
  [F]REGSTR=1
Endif

Return

########################################
$CREATION
$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

########################################
# To manage translated texts (data type AX3 & AX1) in creation and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("HRXITGRD","DESAXX",CLECUR1,"","HRXITGRD","DESAXX",[F:HRXGD]COD,GCURLEG)  From ATEXTRA
 Call DUPTEXTRA("HRXITGRD","SHOAXX",CLECUR1,"","HRXITGRD","SHOAXX",[F:HRXGD]COD,GCURLEG)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESAXX,"HRXITGRD","DESAXX",[F:HRXGD]COD,GCURLEG) From ATEXTRA
Call MAJTEXTRA([M]SHOAXX,"HRXITGRD","SHOAXX",[F:HRXGD]COD,GCURLEG) From ATEXTRA
Return

########################################
$VERIF_CRE
$VERIF_MOD
If [M]DEFVAL=2
 Filter [F:HRXGD2] Where COD<>[M]COD & LEG=GCURLEG & DEFVAL=2
 Read [F:HRXGD2]HRXGD0 First
 Filter [F:HRXGD2]
 If !fstat
  # A default value already exist for this legislation
  GMESSAGE = mess(1,10712,1)-":'"-[F:HRXGD2]COD+"'"
  OK = 0 : Return
 Endif
Endif
Return

########################################
$DISPLAY_HIDE
Local Char W_SIGN(1)
# SBA-114309
Case GCURLEG
 When "FRA",""
    W_SIGN=""
 When Default
    W_SIGN="-"
Endcase

Chgfmt [M]CODN4H  With W_SIGN+"K:10X"
Chgfmt [M]CODMVT  With W_SIGN+"K:10X"
Chgfmt [M]POLEMP  With W_SIGN+"LA1:10X"
Chgfmt [M]REGSTR  With W_SIGN+"LA1:10X"
Chgfmt [M]CODDSN  With W_SIGN+"K:10X"
If W_SIGN="-"
  Raz [M]CODN4H, [M]CODMVT, [M]POLEMP,[M]REGSTR,[M]CODDSN
Endif
Affzo[M]
#MIPEA - 2016-10-11 - X3PEOP-751 - START
Case GCURLEG
 When "ZAF","NAM",""
    W_SIGN=""
 When Default
    W_SIGN="-"
Endcase

Chgfmt [M]LEGCOD  With W_SIGN+"K:2X"

If W_SIGN="-"
  Raz [M]LEGCOD
Endif
Affzo[M]
#MIPEA - 2016-10-11 - X3PEOP-751 - END
Return

########################################
#To change the main code
$CHGCOD
Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return

########################################
# To change translated texts (data type AX3 & AX1) when you change the main code
$AP_CHANGE
Call CHGTEXTRA("HRXITGRD","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("HRXITGRD","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
Call SUPTEXTRA("HRXITGRD","DESAXX",SUPP,[L]CODE) From ATEXTRA
Call SUPTEXTRA("HRXITGRD","SHOAXX",SUPP,[L]CODE) From ATEXTRA
Return

########################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif

# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONHRXGD) : Endif
VCOD = CLE2
Return

###############################################################################
##  Button 'Copy'
###############################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File HRXITGRD  [HRXGD1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".HRXITGRD" [HRXGD1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File HRXITGRD [HRXGD2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".HRXITGRD" [HRXGD2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [HRXGD1], [HRXGD2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

# SBA-114309 - check leg
$TR_COP
GOK = 1

Gosub CHECK_COPYLEG From DIVPAYE
If !GOK : Return : Endif


Trbegin [HRXGD2]
 Delete [HRXGD2] Where TYP=TABLE & LEG=LEGDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".HRXITGRD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("HRXGD2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [HRXGD1] Where TYP=TABLE & LEG=TABLE2
  [F:HRXGD2] = [F:HRXGD1]
  [F:HRXGD2]LEG=LEGDES
  If TABLE2=LEGDES
    Call COPTEXTRA("HRXITGRD","DESAXX",TABLE,TABLE2) From ATEXTRA
    Call COPTEXTRA("HRXITGRD","SHOAXX",TABLE,TABLE2) From ATEXTRA
  Else
    Call COPTEXTRA1("HRXITGRD","DESAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
    Call COPTEXTRA1("HRXITGRD","SHOAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
  Endif
  If dim([F:HRXGD2]UPDUSR)>0 : [F:HRXGD2]UPDUSR = GUSER : Endif
  If dim([F:HRXGD2]UPDDAT)>0 : [F:HRXGD2]UPDDAT = date$ : Endif
  Write [HRXGD2]
  If fstat
   GOK = 0 : Call FSTA("HRXGD2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return


$TR_COP_OLD
GOK = 1

Trbegin [HRXGD2]
 Delete [HRXGD2] Where TYP=TABLE & LEG=TABLE2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".HRXITGRD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("HRXGD2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [HRXGD1] Where TYP=TABLE & LEG=TABLE2
  [F:HRXGD2] = [F:HRXGD1]
  Call COPTEXTRA("HRXITGRD","DESAXX",TABLE,TABLE2) From ATEXTRA
  Call COPTEXTRA("HRXITGRD","SHOAXX",TABLE,TABLE2) From ATEXTRA
  If dim([F:HRXGD2]UPDUSR)>0 : [F:HRXGD2]UPDUSR = GUSER : Endif
  If dim([F:HRXGD2]UPDDAT)>0 : [F:HRXGD2]UPDDAT = date$ : Endif
  Write [HRXGD2]
  If fstat
   GOK = 0 : Call FSTA("HRXGD2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

######################################################################################
## Subprog of screen HRCGD1
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
Gosub DISPLAY_HIDE
End

############################################################################################
## Action on the datatype
############################################################################################

#Selection
########################################
$SEL_TABLE
Case TABLE
 When "SELHRXGD"
  If clalev ([F:HRXGD])=0 : Local File HRXITGRD [HRXGD] : Endif
  OBJET="HRXGD"
  TIT=mess(2959,200,1)    :#End reason
  START   = "[F:HRXGD]COD"
  #Filter based on code legislation
  If PARAM(1)<>""
   Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRXGD]LEG="'+PARAM(1)+'" | [F:HRXGD]LEG="")',"&") From GOBJSUB
  Endif
  #Filter based on group of company
  If PARAM(2)<>""
    #SBA - pb sel
    #OBJET=""
    DEFPAG = 1    :# To have page up and page down
    Gosub NOMFIC From ="WOHRXGD"
    Call  TRANSCOL("HRXGD",NBCOL,COL,TIT,FMTCOL) From OBJDIV
    If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
    If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
    If clalev([F:ACC])=0 : Local File ACCES   [ACC] : Endif

    If GUSRACS=2
      Link [HRXGD] With
&     [AGC]AGC0=[F:HRXGD]GRP,
&     [AXX]AXX0="HRXITGRD";"DESAXX";GLANGUE;[F:HRXGD]COD;[F:HRXGD]LEG
&     As [LNK]
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AGC]CPY="'+PARAM(2)+'" | [F:HRXGD]GRP="")',"&") From GOBJSUB
    Else
      Link [HRXGD] With
&     [AGC]AGC0=[F:HRXGD]GRP,
&     [AXX]AXX0="HRXITGRD";"DESAXX";GLANGUE;[F:HRXGD]COD;[F:HRXGD]LEG,
&     [ACC]CODACC=GUSER;[F:HRXGD]CODACS
&     As [LNK]
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AGC]CPY="'+PARAM(2)+'" | [F:HRXGD]GRP="") & ([F:HRXGD]CODACS="" | [F:ACC]CONSUL=2)',"&") From GOBJSUB
    Endif

    Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:HRXGD]ENAFLG=2',"&") From GOBJSUB

    NBCOL+=1 : COL(NBCOL)="[F:HRXGD]GRP" : COLTYP(NBCOL)=type([F:HRXGD]GRP) : TIT(NBCOL)=mess(237,133,1)
    Default File [LNK]
   Endif
Endcase
Return

# To do a generic Call CONTSEL... from
##################################################
Subprog CONTSEL(COD,LEG,SOC)
Value    Char    COD
Value    Char    LEG()
Value    Char    SOC()
Call CONTHRXGD(COD,LEG,SOC)
End


# Controls
##################################################
Subprog CONTHRXGD(COD,LEG,SOC)
Value    Char    COD
Value    Char    LEG()
Value    Char    SOC()
Local Integer    CAS


#MIPEA - 2016-10-17 - X3PEOP-751 - START
If GFONCTION = "GESHRXGD" | COD="" : End : Endif
#If GFONCTION = "GESHRXGD" | COD="" : End : Endif
#MIPEA - 2016-10-17 - X3PEOP-751 - START
If clalev([F:HRXGD])=0 : Local File HRXITGRD [HRXGD] : Endif

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

# CAS=1 => Record without Legislation (LEG = "")
# CAS=2 => Record with    Legislation (LEG <>"")

CAS = 1 : # Legislation is empty

If LEG<>""
 Read [HRXGD]HRXGD0=[L]COD;[L]LEG
 If fstat
  Read [HRXGD]HRXGD0=[L]COD;""
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Read [HRXGD]HRXGD0(1)=[L]COD
 If !fstat
  LEG = [F:HRXGD]LEG
  CAS = 2
 Endif
Endif

If fstat
Filter [HRXGD] Where [HRXGD]COD=[L]COD
 Read [HRXGD]HRXGD0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  GMESSAGE = [L]COD-":"-mess(14,10712,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  GMESSAGE = [L]COD-":"-mess(23,100,1)
 Endif
 Filter [HRXGD]
 mkstat = 2 : End
Endif

If CAS=2
 Call CONTROLE("HRXGD","",LEG,COD,mkstat) From CONTOBJ
Else
 Call CONTROLE("HRXGD","","",COD,mkstat) From CONTOBJ
Endif

If [F:HRXGD]GRP<>"" & SOC<>""
  If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
  Look [AGC]AGC0 = [F:HRXGD]GRP;SOC
  If fstat
   GMESSAGE = [L]COD-":"-mess(63,127,1)-":"-[F:HRXGD]GRP : # Réservé au groupe de société
   mkstat = 2 : End
  Endif
Endif

If GUSRACS <> 2  #the user doesn't have access to all access codes
  If [F:HRXGD]CODACS <> ""
    If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
    Read [F:ACC]CODACC = GUSER;[F:HRXGD]CODACS
    If fstat or [F:ACC]CONSUL <> 2
      GMESSAGE = [F:HRXGD]COD-":"-mess(3,104,1) :#Access denied
      mkstat = 2 : End
    Endif
  Endif
Endif



End

#Zoom
##################################################
Subprog TUNHRXGD(COD,LEG,SOC)
Variable Char    COD
Value    Char    LEG
Value    Char    SOC

Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONHRXGD)
 TOKILL = 1
Endif

If clalev([F:HRXGD])=0 : Local File HRXITGRD [HRXGD] : Endif

# To update the HRXGD code after the tunnel order
VCOD = COD

If GNBLEG = 1
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Elsif LEG=""              : # If LEG="" then firstly we search a HRXGD record with LEG="" secondly a HRXGD record with LEG<>""
 Read [HRXGD]HRXGD0 = VCOD;LEG
 If fstat
  Read [HRXGD]HRXGD0(1)=VCOD
  If !fstat
   LEG = [F:HRXGD]LEG
  Endif
 Endif
Endif

If VCOD="" & GLECOBJ=2
  #If no code is specified, it's better to select one of the curent legislation
  Filter [HRXGD] Where LEG=[L]LEG
  Read [F:HRXGD] First
  Filter [HRXGD]
  If !fstat : VCOD=[F:HRXGD]COD : Endif
Else
  Read [HRXGD]HRXGD0 = VCOD;LEG
Endif

If fstat : LEG = "" : Endif

Call OBJET("HRXGD",LEG,VCOD) From GOBJET
COD = VCOD

If TOKILL : Kill VCOD : Endif
End

##Return the default value
###################################################
Subprog DEFHRXGD(COD,LEG,SOC)
Variable Char    COD()
Value    Char    LEG
Value    Char    SOC

If GFONCTION = "GESHRXGD" | COD<>"" : End : Endif

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

If clalev([F:HRXGD])=0  : Local File HRXITGRD [HRXGD]  : Endif

If LEG<>""
 Filter [F:HRXGD] Where LEG=[L]LEG & DEFVAL=2 : #23/04/12 - DKA - Added [L] to make sure local var LEG is used for comparison
 Read[F:HRXGD]HRXGD0 First
 Filter [F:HRXGD]
 If !fstat
  COD=[F:HRXGD]COD
  End
 Endif
Endif

Filter [F:HRXGD] Where LEG="" & DEFVAL=2
Read[F:HRXGD]HRXGD0 First
Filter [F:HRXGD]
If !fstat
 COD=[F:HRXGD]COD
 End
Endif
End

##################################
Subprog SIMPLEREAD(COD,LEG,ERR)
Value Char COD ()
Value Char LEG ()
Variable Integer ERR         :#return the 'fstat' about the read

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

If clalev([F:HRXGD])=0  : Local File HRXITGRD [HRXGD]  : Endif

[L]ERR=1

If [L]LEG<>""
 Read[F:HRXGD]HRXGD0=[L]COD;[L]LEG
 [L]ERR=fstat
Endif
If [L]ERR
 Read[F:HRXGD]HRXGD0=[L]COD;""
 [L]ERR=fstat
Endif

End

######################################################################################

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
#handles the GCURLEG when the LEGFIL is on
If VALEUR <> ""
  GCURLEG = VALEUR
Endif
End

######################################################################################
Subprog AS_DESAXX(VALEUR)
Variable Char    VALEUR()
Gosub DISPLAY_HIDE
End


######################################################################################

