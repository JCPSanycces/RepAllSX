#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AHISTO","AHISTO",3,"") From GTRAITE
End

#-------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "EXEC"     : Gosub EXEC
Endcase
Return

#-------------------------------------------------#
$INIT
Local Mask AHISTO [DIA]
Gosub DEFVAR
TMP = 1
TRA = 1
TIT = mess(15,133,1) : # Historisation / Epuration
Return

#-------------------------------------------------#
$DEFVAR
Local Char    APPLI(GLONADS) , HISAPL(GLONADS)
Local Char    TABLE(GLONATB) , NEWTAB(GLONATB)
Local Char    FORMU(250) , FILTRE(250) , FILTSUP(250) , FILDAT(250)
Local Integer TEMPS , AGE , TYPDBA
Local Integer NBDEL , NPDEL , NRDEL , NBRES , MAXDEL , DLREC
Local Integer NBLNK , SIMUL , TOTHIS , TOTDEL
Local Integer NBCLE , I , I1 , I2 , I3 , OKHIS , OKEPU , HISTO , STAT , OKSTD
Local Integer NBLIEN
Local Char    CLE(GLONAVA)(1..16)
Local Char    TBLIEN(GLONATB)(1..99)
Local Char    CHAINE(80) , TEXTE(80) , TIM(10) , HEURE(4)
Local Integer TRACEDET
Local Char    CRITERE(250)
Local Char    PROGEPU(GLONADC) , PROGEPUSPE(GLONADC) , WACTION(20) , SAVACT(20)
Local Char    CODEPU(GLONAHI) , FILEPU(250)
Local Char    SOCIETE(GLONCPY) , SITE(GLONFCY)
Local Char    FICORG(250) , FICDES(250)
Local Char    LIGNE(250) , DBA(10) , INITIAL(20) , FNEXT(20) , PCTINC(20)
Local Char    SAVIFS(5) , SAVIRS(5)
Local Decimal COEFF , TAILLE
Local Char    MESSA(250)
Local Integer VUE
Local Date    REFDAT , HISDAT , EPUDAT
MAXDEL   = 1000      : # Nb max par transaction
Return

#-------------------------------------------------#
$EXEC
SIMUL    = ([M:DIA]SIM=2)
TRACEDET = ([M:DIA]TRDET=2)
CODEPU   = [M:DIA]COD
SOCIETE  = [M:DIA]CPY
If !GSERVEUR
 If SIMUL
  Call OUVRE_TRACE(mess(16,133,1)) From LECFIC : # Simulation Historisation/épuration
 Else
  Call OUVRE_TRACE(mess(15,133,1)) From LECFIC : # Historisation/épuration
 Endif
Endif
APPLI  = nomap
HISAPL = ""
Gosub OUVRE_TABLE
Read [ADW]ADW0 = "";"";"TYPDBA"
TYPDBA = val([F:ADW]VALEUR)
Read [ADW]ADW0 = "";"";"HISDOS"
If !fstat
 HISAPL = [F:ADW]VALEUR
Endif
If [M:DIA]HISTO=2
 If HISAPL=""
  Call ECR_TRACE(mess(17,133,1),1) From GESECRAN : # Dossier historique non défini
  Return
 Elsif filinfo(filpath("","","",HISAPL),0)<0
  Call ECR_TRACE(HISAPL-":"-mess(18,133,1),1) From GESECRAN : # Dossier historique inexistant
  Return
 Endif
Endif
Read [ADW]ADW0 = "";"";"HISCOE"
If fstat or val([F:ADW]VALEUR)=0
 COEFF = 1
Else
 COEFF = val([F:ADW]VALEUR)
Endif
If [M:DIA]HISTO=2
 Gosub HISTO
Endif
If [M:DIA]EPUR=2
 Gosub EPUR
Endif
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(num$(TOTHIS)-mess(19,133,1),0) From GESECRAN : # enregistrements historisés
Call ECR_TRACE(num$(TOTDEL)-mess(20,133,1),0) From GESECRAN : # enregistrements effacés
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

#---------------------------------------------------------------------#
$OUVRE_TABLE
If clalev([F:AHI])=0  : Local File =APPLI+".AHISTO"   [AHI]  : Endif
If clalev([F:AHD])=0  : Local File =APPLI+".AHISTOD"  [AHD]  : Endif
If clalev([F:AHD2])=0 : Local File =APPLI+".AHISTOD"  [AHD2] : Endif
If clalev([F:ATB])=0  : Local File =APPLI+".ATABLE"   [ATB]  : Endif
If clalev([F:ATI])=0  : Local File =APPLI+".ATABIND"  [ATI]  : Endif
If clalev([F:ATX])=0  : Local File =APPLI+".ATEXTE"   [ATX]  : Endif
If clalev([F:ADW])=0  : Local File =APPLI+".ADOVAL"   [ADW]  : Endif
If clalev([F:FGR])=0  : Local File =APPLI+".FACGROUP" [FGR]  : Endif
Return

#----------------------------------------#
$SETTRT
PROGEPU = ""
If [F:AHI]CTLTRT<>""
 Call EXISTE_ADX("","",[F:AHI]CTLTRT,I3) From ORDSYS
 If I3>0
  PROGEPU = [F:AHI]CTLTRT
 Endif
Endif
PROGEPUSPE = ""
If [F:AHI]SPETRT<>""
 Call EXISTE_ADX("","",[F:AHI]SPETRT,I3) From ORDSYS
 If I3>0
  PROGEPUSPE = [F:AHI]SPETRT
 Endif
Endif
Return

#----------------------------------------#
$WACTION
GPE = 0
If [L]PROGEPUSPE<>""
 [L]SAVACT = [L]ACTION
 [L]ACTION = [L]WACTION
 Onerrgo ERRACT
 Gosub ACTION From =[L]PROGEPUSPE
 Onerrgo
 [L]ACTION = [L]SAVACT
Endif
If !GPE & [L]PROGEPU<>""
 [L]SAVACT = [L]ACTION
 [L]ACTION = [L]WACTION
 Onerrgo ERRACT
 Gosub ACTION From =[L]PROGEPU
 Onerrgo
 [L]ACTION = [L]SAVACT
Endif
Return

$ERRACT
Call ECR_TRACE(mess(6,123,1)-num$(errn)-errmes$(errn)-errm-errp-mess(61,100,1)-num$(errl),1) From GESECRAN
# Erreur...ligne no...
Resume

#------------------------------------------------------------------------------#
## Historisations
#------------------------------------------------------------------------------#

$HISTO
TOTHIS = 0
FILEPU = "ENAFLG=2 & FLG1=2"
If CODEPU<>""
 FILEPU -= '& COD="'+CODEPU+'"'
Endif
For [AHI]AHI0 Where evalue(FILEPU)
 OKHIS = 1
 Call TEXTE([F:AHI]DES,TEXTE) From OBJDIV
 If date$-[F:AHI]DAT1<[F:AHI]FRQ1
  OKHIS = 0
  Call ECR_TRACE([F:AHI]COD-TEXTE-":"-mess(21,133,1)-format$("D:"+GFMDAT,[F:AHI]DAT1),0) From GESECRAN
  # Historisation effectuée le
  Call ECR_TRACE("",0) From GESECRAN
 Endif
 If OKHIS
  For [AHD]AHD0 Where COD=[F:AHI]COD & LNKTBL=""
   Read [ATB]CODFIC = [F:AHD]TBL
   If !fstat & [F:ATB]TYPFIC=3 & APPLI<>GDOSX3
    OKHIS = 0 : Break
   Endif
  Next AHD
  # Historisation impossible des tables systèmes
 Endif
 If OKHIS
  Gosub SETTRT
  TEMPS = [F:AHI]TIM1
  HISDAT = date$
  REFDAT = HISDAT-TEMPS
  Call ECR_TRACE(mess(22,133,1)-":"-[F:AHI]COD-TEXTE,0) From GESECRAN : # Historisation
  Gosub HIS_BOUCLE
 Endif
Next AHI
Return

#---------------------------------------------#
# Appelé par TRT HISTO de GEODE
#---------------------------------------------#

$HIS_BOUCLE
For [AHD]AHD0 Where COD=[F:AHI]COD & LNKTBL=""
 TABLE = [F:AHD]TBL
 Read [ATB]CODFIC = TABLE
 Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
 Call ECR_TRACE(time$-mess(23,133,1)-TABLE-TEXTE,0) From GESECRAN : # Historisation table
 Gosub HIS_TABLE
 If NRDEL
  MESSA = "--"-num$(NRDEL)-mess(19,133,1)-"("+num$(NPDEL)+")" : # Enregistrements historisés
 Else
  MESSA = "--"-mess(24,133,1) : # Pas d'enregistrement historisé
 Endif
 If SIMUL
  MESSA -= "("+mess(25,133,1)+")" : # Simulation
 Endif
 Call ECR_TRACE(MESSA,0) From GESECRAN
 Call ECR_TRACE("--"-mess(26,133,1)-":"-num$(NBRES),0) From GESECRAN : # Nb enregs restants
 TOTHIS += NRDEL
 If GOK<1
  Call ECR_TRACE("--"-mess(27,133,1),1) From GESECRAN : # Transaction interrompue
 Elsif !SIMUL
  Trbegin [AHI]
   [F:AHI]DAT1 = [L]HISDAT
   Rewrite [AHI] =
  Commit
 Endif
 Call ECR_TRACE("",0) From GESECRAN
Next AHD
Return

#---------------------------------------------#
$HIS_TABLE
If filinfo(filpath("FIL",TABLE,"fde",APPLI),0)<0
 Call ECR_TRACE(APPLI-TABLE-mess(32,133,1),1) From GESECRAN : # Table inexistante
 Return
Endif
Call VUE_OK(TABLE,HISAPL,"FIL",VUE) From DOSVUE
If VUE
 Call CRETABLE(APPLI,HISAPL,TYPDBA,TABLE,COEFF,0) From CREHISTO
 Call TABLEHIS(APPLI,HISAPL,0,0,TABLE) From DOSTAB : #107271
Endif
HISTO = 1
Local File =APPLI+"."+TABLE [F1], =HISAPL+"."+TABLE [F2]
Gosub CLE
Gosub LNK
WACTION = "OUVRE" : Gosub WACTION
Gosub HIS_TABSIT
NBRES = nbrecord([F1])
If SIMUL : NBRES -= NPDEL : Endif
Close Local File [F1] , [F2]
Gosub LNK_CLOSE
WACTION = "FERME" : Gosub WACTION
Return

#------------------------------------------#
$CLE
Read [ATI]NUMLIG(2) = TABLE;1
CHAINE = [F:ATI]DESCRIPT
NBCLE  = 0
While CHAINE<>""
 I1 = instr(1,CHAINE,"+")
 I2 = instr(1,CHAINE,"-")
 If    I1 & I2  : I1 = min(I1,I2)
 Elsif I2 & !I1 : I1 = I2
 Endif
 NBCLE += 1
 If I1
  CLE(NBCLE) = left$(CHAINE,I1-1) : CHAINE = right$(CHAINE,I1+1)
 Else
  CLE(NBCLE) = CHAINE : CHAINE = ""
 Endif
Wend
Return

#-------------------------------------------#
$LNK
NBLIEN = 0
For [AHD2]AHD0 Where COD=[F:AHI]COD & LNKTBL=TABLE
 If filinfo(filpath("FIL",[F:AHD2]TBL,"fde",APPLI),0)<0
  Call ECR_TRACE(APPLI-[F:AHD2]TBL-mess(32,133,1),1) From GESECRAN : # Table inexistante
 Else
  NBLIEN += 1
  TBLIEN(NBLIEN) = [F:AHD2]TBL
  Case NBLIEN
   When  1 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L1]
   When  2 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L2]
   When  3 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L3]
   When  4 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L4]
   When  5 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L5]
   When  6 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L6]
   When  7 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L7]
   When  8 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L8]
   When  9 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L9]
   When 10 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L10]
   When 11 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L11]
   When 12 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L12]
   When 13 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L13]
   When 14 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L14]
   When 15 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L15]
   When 16 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L16]
   When 17 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L17]
   When 18 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L18]
   When 19 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L19]
   When 20 : Local File =APPLI+"."+TBLIEN(NBLIEN) [L20]
  Endcase
 Endif
 If HISTO
  Call VUE_OK([F:AHD2]TBL,HISAPL,"FIL",VUE) From DOSVUE
  If VUE
   Call CRETABLE(APPLI,HISAPL,TYPDBA,[F:AHD2]TBL,COEFF,0) From CREHISTO
   Call TABLEHIS(APPLI,HISAPL,0,0,[F:AHD2]TBL) From DOSTAB : #107271
  Endif
  Case NBLIEN
   When  1 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H1]
   When  2 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H2]
   When  3 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H3]
   When  4 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H4]
   When  5 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H5]
   When  6 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H6]
   When  7 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H7]
   When  8 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H8]
   When  9 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H9]
   When 10 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H10]
   When 11 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H11]
   When 12 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H12]
   When 13 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H13]
   When 14 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H14]
   When 15 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H15]
   When 16 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H16]
   When 17 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H17]
   When 18 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H18]
   When 19 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H19]
   When 20 : Local File =HISAPL+"."+TBLIEN(NBLIEN) [H20]
  Endcase
 Else
  If filinfo(filpath("FIL",[F:AHD2]TBL,"fde",APPLI),0)<0
   Call ECR_TRACE(APPLI-[F:AHD2]TBL-mess(32,133,1),1) From GESECRAN : # Table inexistante
   NBLIEN -= 1
  Else
   Case NBLIEN
    When  1 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H1]
    When  2 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H2]
    When  3 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H3]
    When  4 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H4]
    When  5 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H5]
    When  6 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H6]
    When  7 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H7]
    When  8 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H8]
    When  9 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H9]
    When 10 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H10]
    When 11 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H11]
    When 12 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H12]
    When 13 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H13]
    When 14 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H14]
    When 15 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H15]
    When 16 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H16]
    When 17 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H17]
    When 18 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H18]
    When 19 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H19]
    When 20 : Local File =APPLI+"."+TBLIEN(NBLIEN) [H20]
   Endcase
  Endif
 Endif
Next : # [AHD2]
Return

#----------------------------------------------#
$LNK_CLOSE
For I1=1 To NBLIEN
 Case I1
  When  1 : Close Local File [L1]  , [H1]
  When  2 : Close Local File [L2]  , [H2]
  When  3 : Close Local File [L3]  , [H3]
  When  4 : Close Local File [L4]  , [H4]
  When  5 : Close Local File [L5]  , [H5]
  When  6 : Close Local File [L6]  , [H6]
  When  7 : Close Local File [L7]  , [H7]
  When  8 : Close Local File [L8]  , [H8]
  When  9 : Close Local File [L9]  , [H9]
  When 10 : Close Local File [L10] , [H10]
  When 11 : Close Local File [L11] , [H11]
  When 12 : Close Local File [L12] , [H12]
  When 13 : Close Local File [L13] , [H13]
  When 14 : Close Local File [L14] , [H14]
  When 15 : Close Local File [L15] , [H15]
  When 16 : Close Local File [L16] , [H16]
  When 17 : Close Local File [L17] , [H17]
  When 18 : Close Local File [L18] , [H18]
  When 19 : Close Local File [L19] , [H19]
  When 20 : Close Local File [L20] , [H20]
 Endcase
Next I1
Return

#----------------------------------------------#
$LNK_CRITERE
[L]CRITERE = ""
For [L]I1=1 To [L]NBCLE
 If [L]I1>1 : [L]CRITERE += " & " : Endif
 [L]CRITERE += [L]CLE([L]I1)+"="
 Case evalue("type([F:F1]"+[L]CLE([L]I1)+")")
  When 1,2,4,5,6,7,8,9
   [L]CRITERE += num$(evalue("[F:F1]"+[L]CLE([L]I1)))
  When 3
   [L]CRITERE += "["+format$(GFMD,evalue("[F:F1]"+[L]CLE([L]I1)))+"]"
  When Default
   [L]CRITERE += '"'+evalue("[F:F1]"+[L]CLE([L]I1))+'"'
 Endcase
Next [L]I1
Return

#----------------------------------------------#
$FILSIT
If [F:AHD]FCYFLD<>"" & SITE<>""
 If FILTRE<>"" : FILTRE -= "&" : Endif
 FILTRE -= '('+[F:AHD]FCYFLD+'="'+SITE+'")'
Endif
Gosub FILSOC
Return

#----------------------------------------------#
$FILSOC
If [F:AHD]CPYFLD<>"" & SOCIETE<>""
 If FILTRE<>"" : FILTRE -= "&" : Endif
 FILTRE -= '('+[F:AHD]CPYFLD+'="'+SOCIETE+'")'
Endif
If FILDAT<>""
 If FILTRE<>"" : FILTRE -= "&" : Endif
 FILTRE -= "("+FILDAT+")"
Endif
FILTRE = vireblc(FILTRE,2)
If FILTRE="" : FILTRE = "1=1" : Endif
WACTION = "FILSOC" : Gosub WACTION
Return

#----------------------------------------------#
$FORMU
FORMU = vireblc(format$("KT:250X",[F:AHD]FRM),2)
If FORMU="" : FORMU = "1=1" : Endif
Return

#----------------------------------------------#
$FILDAT
If [F:AHD]DATFLD<>""
 FILDAT = [F:AHD]DATFLD+"<=["+format$(GFMD,REFDAT)+"]"
Else
 FILDAT = ""
Endif
Return

#----------------------------------------------#
$FILTSUP
FILTSUP = ""
WACTION = "FILTRE" : Gosub WACTION
FILTSUP = vireblc(FILTSUP,2)
If FILTSUP="" : FILTSUP = "1=1" : Endif
Return

#----------------------------------------------#
$HIS_TABSIT
NBDEL = 0
NPDEL = 0
NRDEL = 0
NBEPU = 0
Gosub FORMU
Gosub FILDAT
Gosub FILTSUP
If SOCIETE="" or [F:AHD]FCYFLD=""
 FILTRE = ""
 Gosub FILSOC
 Call DEBTRANS From GLOCK
 Gosub TR1
Else
 For [FGR]FGR0 Where CPY=SOCIETE
  SITE = [F:FGR]FCY
  FILTRE = ""
  Gosub FILSIT
  NBDEL = 0
  Call DEBTRANS From GLOCK
  Gosub TR1
 Next
Endif
Return

#----------------------------------------------#
$TR1
GOK   = 1
Trbegin [F2]
 For [F1] Where evalue(FILTRE) & evalue(FORMU) & evalue(FILTSUP) With Stability
  Default File [F1]
  Default [F] , [V] , [L] , [S] , [M]
  [L]OKHIS = evalue([L]FILTRE) & evalue([L]FORMU) & evalue([L]FILTSUP) : # Au cas où... (1=0)
  If [L]OKHIS
   [L]WACTION = "HISTO" : Gosub WACTION
  Endif
  If [L]OKHIS
   [F:F2] = [F:F1]
   If dim([F:F2]CREHISDAT)>0 : [F:F2]CREHISDAT = HISDAT   : Endif
   If dim([F:F2]CREHISUSR)>0 : [F:F2]CREHISUSR = [V]GUSER : Endif
   If ![L]SIMUL
    Write [F2]
    If fstat
     [V]GOK = 0 : Call FSTA("F2") From GLOCK : Break
    Endif
   Endif
   [V]GCLE = ""
   For [L]I1=1 To [L]NBCLE
    [V]GCLE += num$(evalue("[F:F1]"+[L]CLE([L]I1)))
    If [L]I1<>[L]NBCLE : [V]GCLE += " " : Endif
   Next [L]I1
   If ![L]SIMUL
    Delete [F1]
    If fstat=1
     [V]GOK = -1 : [V]GLOCK = "$"+[L]TABLE-[V]GCLE : Break
    Endif
   Endif
   [L]NBDEL += 1
   [L]NPDEL += 1
   [L]NBEPU += 1
   If [L]TRACEDET
    Call ECR_TRACE("--"-mess(22,133,1)-[V]GCLE,0) From GESECRAN : # Historisation
   Endif
   If [L]NBLIEN
    Gosub LNK_CRITERE
    For [L]I1=1 To [L]NBLIEN
     Case [L]I1
      When  1 : Default File [L1]
      When  2 : Default File [L2]
      When  3 : Default File [L3]
      When  4 : Default File [L4]
      When  5 : Default File [L5]
      When  6 : Default File [L6]
      When  7 : Default File [L7]
      When  8 : Default File [L8]
      When  9 : Default File [L9]
      When 10 : Default File [L10]
      When 11 : Default File [L11]
      When 12 : Default File [L12]
      When 13 : Default File [L13]
      When 14 : Default File [L14]
      When 15 : Default File [L15]
      When 16 : Default File [L16]
      When 17 : Default File [L17]
      When 18 : Default File [L18]
      When 19 : Default File [L19]
      When 20 : Default File [L20]
     Endcase
     [L]NBLNK = 0
     For [F] Where evalue([L]CRITERE) With Stability
      Case [L]I1
       When  1 : [F:H1]  = [F:L1]
       When  2 : [F:H2]  = [F:L2]
       When  3 : [F:H3]  = [F:L3]
       When  4 : [F:H4]  = [F:L4]
       When  5 : [F:H5]  = [F:L5]
       When  6 : [F:H6]  = [F:L6]
       When  7 : [F:H7]  = [F:L7]
       When  8 : [F:H8]  = [F:L8]
       When  9 : [F:H9]  = [F:L9]
       When 10 : [F:H10] = [F:L10]
       When 11 : [F:H11] = [F:L11]
       When 12 : [F:H12] = [F:L12]
       When 13 : [F:H13] = [F:L13]
       When 14 : [F:H14] = [F:L14]
       When 15 : [F:H15] = [F:L15]
       When 16 : [F:H16] = [F:L16]
       When 17 : [F:H17] = [F:L17]
       When 18 : [F:H18] = [F:L18]
       When 19 : [F:H19] = [F:L19]
       When 20 : [F:H20] = [F:L20]
      Endcase
      If evalue("dim([F:H"+num$([L]I1)+"]CREHISDAT)")>0
       Assign "[F:H"+num$([L]I1)+"]CREHISDAT" With HISDAT
      Endif
      If evalue("dim([F:H"+num$([L]I1)+"]CREHISUSR)")>0
       Assign "[F:H"+num$([L]I1)+"]CREHISUSR" With GUSER
      Endif
      If ![L]SIMUL
       Case [L]I1
        When  1 : Write [H1]
        When  2 : Write [H2]
        When  3 : Write [H3]
        When  4 : Write [H4]
        When  5 : Write [H5]
        When  6 : Write [H6]
        When  7 : Write [H7]
        When  8 : Write [H8]
        When  9 : Write [H9]
        When 10 : Write [H10]
        When 11 : Write [H11]
        When 12 : Write [H12]
        When 13 : Write [H13]
        When 14 : Write [H14]
        When 15 : Write [H15]
        When 16 : Write [H16]
        When 17 : Write [H17]
        When 18 : Write [H18]
        When 19 : Write [H19]
        When 20 : Write [H20]
       Endcase
       If fstat
        [V]GOK = 0 : Call FSTA("H"+num$([L]I1)) From GLOCK : Break 3
       Endif
      Endif
      [V]GCLE = ""
      For [L]I2=1 To [L]NBCLE
       [V]GCLE += num$(evalue("[F:L"+num$([L]I1)+"]"+[L]CLE([L]I2)))
       If [L]I2<>[L]NBCLE : [V]GCLE += " " : Endif
      Next [L]I2
      If ![L]SIMUL
       Case I1
        When  1 : Delete [L1]
        When  2 : Delete [L2]
        When  3 : Delete [L3]
        When  4 : Delete [L4]
        When  5 : Delete [L5]
        When  6 : Delete [L6]
        When  7 : Delete [L7]
        When  8 : Delete [L8]
        When  9 : Delete [L9]
        When 10 : Delete [L10]
        When 11 : Delete [L11]
        When 12 : Delete [L12]
        When 13 : Delete [L13]
        When 14 : Delete [L14]
        When 15 : Delete [L15]
        When 16 : Delete [L16]
        When 17 : Delete [L17]
        When 18 : Delete [L18]
        When 19 : Delete [L19]
        When 20 : Delete [L20]
       Endcase
       If fstat=1
        [V]GOK = -1 : [V]GLOCK = "$"+[L]TBLIEN([L]I1)-[V]GCLE : Break 3
       Endif
      Endif
      [L]NBDEL += 1
      [L]NBLNK += 1
     Next
     If [L]TRACEDET
      Call ECR_TRACE("----"-[L]TBLIEN([L]I1)-mess(22,133,1)-[V]GCLE-"("+num$([L]NBLNK)+")",0) From GESECRAN
      # Historisation
     Endif
    Next [L]I1
   Endif
   If [L]NBDEL>=[L]MAXDEL
    Commit
    [L]NRDEL += [L]NBDEL
    [L]NBDEL  = 0
    Trbegin [F2]
   Endif
  Endif
  Default [V] , [L] , [S] , [M] , [F]
 Next
 Default [V] , [L] , [S] , [M] , [F]
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
NRDEL += NBDEL
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#------------------------------------------------------------------------------#
## Epurations
#------------------------------------------------------------------------------#

$EPUR
TOTDEL = 0
FILEPU = "ENAFLG=2 & FLG2=2"
If CODEPU<>""
 FILEPU -= '& COD="'+CODEPU+'"'
Endif
For [AHI]AHI0 Where evalue(FILEPU)
 Call TEXTE([F:AHI]DES,TEXTE) From OBJDIV
 OKEPU = 1
 If date$-[F:AHI]DAT2<[F:AHI]FRQ2
  OKEPU = 0
  Call ECR_TRACE([F:AHI]COD-TEXTE-":"-mess(28,133,1)-format$("D:"+GFMDAT,[F:AHI]DAT2),0) From GESECRAN
  # Epuration effectuée le
  Call ECR_TRACE("",0) From GESECRAN
 Endif
 If OKEPU
  For [AHD]AHD0 Where COD=[F:AHI]COD & LNKTBL=""
   Read [ATB]CODFIC = [F:AHD]TBL
   If !fstat & [F:ATB]TYPFIC=3 & APPLI<>GDOSX3
    OKEPU = 0 : Break
   Endif
  Next AHD
  If !OKEPU
   Call ECR_TRACE([F:AHI]COD-TEXTE-":"-mess(258,133,1)-"("+GDOSX3+")",0) From GESECRAN
   # Cette épuration doit être lancée depuis le dossier racine ()
   Call ECR_TRACE("",0) From GESECRAN
  Endif
 Endif
 If OKEPU
  Gosub SETTRT
  TEMPS = [F:AHI]TIM2
  EPUDAT = date$
  REFDAT = EPUDAT-TEMPS
  Call ECR_TRACE(mess(29,133,1)-":"-[F:AHI]COD-TEXTE,0) From GESECRAN : # Epuration
  Gosub EPU_BOUCLE
 Endif
Next AHI
Return

#---------------------------------------------#
# Appelé par TRT HISTO de GEODE
#---------------------------------------------#

$EPU_BOUCLE
For [AHD]AHD0 Where COD=[F:AHI]COD & LNKTBL=""
 TABLE = [F:AHD]TBL
 Read [ATB]CODFIC = TABLE
 Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
 Call ECR_TRACE(time$-mess(30,133,1)-TABLE-TEXTE,0) From GESECRAN : # Epuration table
 Gosub EPU_TABLE
 TOTDEL += NRDEL
 If NRDEL
  MESSA = "--"-num$(NRDEL)-mess(20,133,1)-"("+num$(NPDEL)+")" : # Enregistrements epurés
 Else
  MESSA = "--"-mess(31,133,1) : # Pas d'enregistrement épuré
 Endif
 If SIMUL
  MESSA -= "("+mess(25,133,1)+")" : # Simulation
 Endif
 Call ECR_TRACE(MESSA,0) From GESECRAN
 Call ECR_TRACE("--"-mess(26,133,1)-":"-num$(NBRES),0) From GESECRAN : # Nb enreg restants
 If GOK<1
  Call ECR_TRACE("--"-mess(27,133,1),1) From GESECRAN : # Transaction interrompue
 Elsif !SIMUL
  Trbegin [AHI]
   [F:AHI]DAT2 = EPUDAT
   Rewrite [AHI] =
  Commit
 Endif
 Call ECR_TRACE("",0) From GESECRAN
Next AHD
Return

#----------------------------------------------#
$EPU_TABLE
If [F:AHI]FLG1<>2 or HISAPL=""
 HISTO = 0
 If filinfo(filpath("FIL",TABLE,"fde",APPLI),0)<0
  Call ECR_TRACE(APPLI-TABLE-":"-mess(32,133,1),1) From GESECRAN : # Table inexistante
  Return
 Endif
 Local File =APPLI+"."+TABLE [F1]
Else
 HISTO = 1
 Call VUE_OK(TABLE,HISAPL,"FIL",VUE) From DOSVUE
 If VUE
  Call ECR_TRACE(HISAPL-TABLE-":"-mess(32,133,1)-"("+mess(212,133,1)+")",1) From GESECRAN
  # Table inexistante (Historisation non encore effectuée)
  Return
 Endif
 Local File =HISAPL+"."+TABLE [F1]
Endif
Gosub CLE
Gosub LNK
WACTION = "OUVRE" : Gosub WACTION
Call DEBTRANS From GLOCK
Gosub EPU_TABSIT
NBRES = nbrecord([F1])
If SIMUL : NBRES -= NPDEL : Endif
Close Local File [F1]
Gosub LNK_CLOSE
WACTION = "FERME" : Gosub WACTION
Return

#----------------------------------------------#
$EPU_TABSIT
NBDEL = 0
NPDEL = 0
NRDEL = 0
If !HISTO
 Gosub FORMU
 Gosub FILDAT
 Gosub FILTSUP
Else
 FORMU = "1=1"
 If dim([F:F1]CREHISDAT)>0
  # Cas de l'épuration des tables locales dans le dossier historique
  If [F:AHD]DATFLD<>"" & evalue("dim([F:F1]"+[F:AHD]DATFLD+")")>0
   FILDAT = "(CREHISDAT<>[0/0/0] & CREHISDAT<=["+format$(GFMD,REFDAT)+"])"
   FILDAT += " or "
   FILDAT += "(CREHISDAT=[0/0/0] & "+[F:AHD]DATFLD+"<=["+format$(GFMD,REFDAT)+"])"
  Else
   FILDAT = "CREHISDAT<=["+format$(GFMD,REFDAT)+"]"
  Endif
 Else
  FILDAT = ""
 Endif
 FILTSUP = "1=1"
Endif
If SOCIETE="" or [F:AHD]FCYFLD=""
 FILTRE = ""
 Gosub FILSOC
 Call DEBTRANS From GLOCK
 Gosub TR2
Else
 For [FGR]FGR0 Where CPY=SOCIETE
  SITE = [F:FGR]FCY
  FILTRE = ""
  Gosub FILSIT
  NBDEL = 0
  Call DEBTRANS From GLOCK
  Gosub TR2
 Next
Endif
Return

#----------------------------------------------#
$TR2
GOK   = 1
Trbegin [F1]
 Default File [F1]
 For [F1] Where evalue(FILTRE) & evalue(FORMU) & evalue(FILTSUP)
  GCLE = ""
  For I1=1 To NBCLE
   GCLE += num$(evalue("[F:F1]"+CLE(I1)))
   If I1<>NBCLE : GCLE += " " : Endif
  Next I1
  Default [F] , [V] , [L] , [S] , [M]
  [L]OKEPU = evalue([L]FILTRE) & evalue([L]FORMU) & evalue([L]FILTSUP)
  If [L]OKEPU
   [L]WACTION = "EPURE" : Gosub WACTION
  Endif
  If [L]OKEPU
   If ![L]SIMUL
    Delete [F1]
    If fstat=1
     [V]GOK = -1 : [V]GLOCK = "$"+[L]TABLE-[V]GCLE : Break
    Endif
   Endif
   [L]NBDEL += 1
   [L]NPDEL += 1
   If [L]TRACEDET
    Call ECR_TRACE("--"-mess(29,133,1)-[V]GCLE,0) From GESECRAN : # Epuration
   Endif
   If [L]NBLIEN
    Gosub LNK_CRITERE
    For [L]I1=1 To [L]NBLIEN
     If ![L]SIMUL
      Case [L]I1
       When  1 : Delete [H1]  Where evalue([L]CRITERE)
       When  2 : Delete [H2]  Where evalue([L]CRITERE)
       When  3 : Delete [H3]  Where evalue([L]CRITERE)
       When  4 : Delete [H4]  Where evalue([L]CRITERE)
       When  5 : Delete [H5]  Where evalue([L]CRITERE)
       When  6 : Delete [H6]  Where evalue([L]CRITERE)
       When  7 : Delete [H7]  Where evalue([L]CRITERE)
       When  8 : Delete [H8]  Where evalue([L]CRITERE)
       When  9 : Delete [H9]  Where evalue([L]CRITERE)
       When 10 : Delete [H10] Where evalue([L]CRITERE)
       When 11 : Delete [H11] Where evalue([L]CRITERE)
       When 12 : Delete [H12] Where evalue([L]CRITERE)
       When 13 : Delete [H13] Where evalue([L]CRITERE)
       When 14 : Delete [H14] Where evalue([L]CRITERE)
       When 15 : Delete [H15] Where evalue([L]CRITERE)
       When 16 : Delete [H16] Where evalue([L]CRITERE)
       When 17 : Delete [H17] Where evalue([L]CRITERE)
       When 18 : Delete [H18] Where evalue([L]CRITERE)
       When 19 : Delete [H19] Where evalue([L]CRITERE)
       When 20 : Delete [H20] Where evalue([L]CRITERE)
      Endcase
      If fstat=1
       [V]GOK = -1 : [V]GLOCK = "$"+[L]TBLIEN([L]I1)-[L]CRITERE : Break 2
      Endif
      [L]DLREC = adxdlrec
     Else
      Case [L]I1
       When  1 : Filter [H1]  Where evalue([L]CRITERE) : [L]DLREC = rowcount([H1])
       When  2 : Filter [H2]  Where evalue([L]CRITERE) : [L]DLREC = rowcount([H2])
       When  3 : Filter [H3]  Where evalue([L]CRITERE) : [L]DLREC = rowcount([H3])
       When  4 : Filter [H4]  Where evalue([L]CRITERE) : [L]DLREC = rowcount([H4])
       When  5 : Filter [H5]  Where evalue([L]CRITERE) : [L]DLREC = rowcount([H5])
       When  6 : Filter [H6]  Where evalue([L]CRITERE) : [L]DLREC = rowcount([H6])
       When  7 : Filter [H7]  Where evalue([L]CRITERE) : [L]DLREC = rowcount([H7])
       When  8 : Filter [H8]  Where evalue([L]CRITERE) : [L]DLREC = rowcount([H8])
       When  9 : Filter [H9]  Where evalue([L]CRITERE) : [L]DLREC = rowcount([H9])
       When 10 : Filter [H10] Where evalue([L]CRITERE) : [L]DLREC = rowcount([H10])
       When 11 : Filter [H11] Where evalue([L]CRITERE) : [L]DLREC = rowcount([H11])
       When 12 : Filter [H12] Where evalue([L]CRITERE) : [L]DLREC = rowcount([H12])
       When 13 : Filter [H13] Where evalue([L]CRITERE) : [L]DLREC = rowcount([H13])
       When 14 : Filter [H14] Where evalue([L]CRITERE) : [L]DLREC = rowcount([H14])
       When 15 : Filter [H15] Where evalue([L]CRITERE) : [L]DLREC = rowcount([H15])
       When 16 : Filter [H16] Where evalue([L]CRITERE) : [L]DLREC = rowcount([H16])
       When 17 : Filter [H17] Where evalue([L]CRITERE) : [L]DLREC = rowcount([H17])
       When 18 : Filter [H18] Where evalue([L]CRITERE) : [L]DLREC = rowcount([H18])
       When 19 : Filter [H19] Where evalue([L]CRITERE) : [L]DLREC = rowcount([H19])
       When 20 : Filter [H20] Where evalue([L]CRITERE) : [L]DLREC = rowcount([H20])
      Endcase
     Endif
     [L]NBDEL += [L]DLREC
     If [L]TRACEDET
      Call ECR_TRACE("----"-[L]TBLIEN([L]I1)-"("+num$([L]DLREC)+")",0) From GESECRAN : # Epuration
     Endif
    Next [L]I1
   Endif
   If [L]NBDEL>=[L]MAXDEL
    Commit
    [L]NRDEL += [L]NBDEL
    [L]NBDEL  = 0
    Trbegin [F1]
   Endif
  Endif
  Default [V] , [L] , [S] , [M] , [F]
 Next
 Default [V] , [L] , [S] , [M] , [F]
 If   GOK<0 : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
NRDEL += NBDEL
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

#----------------------------------------------#
## Ecran AHISTO
#----------------------------------------------#

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CPY
 Grizo CPY
Else
 Actzo CPY
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char VALEUR()
If [M]ALLCPY=2 : mkstat = 1 : End : Endif
End

Subprog D_INI(VALEUR)
Variable Char VALEUR()
If [M]ALLCPY=2
 Grizo CPY
Else
 Actzo CPY
Endif
End

