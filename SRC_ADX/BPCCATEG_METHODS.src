#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe BPCCATEG
#######################################################################################
End

#######################################################################################
$AREAD_AFTER
Local Integer IRET

  IRET = fmet this.INIT_TSCCODADI()
Return

#######################################################################################
$AINIT
Local Integer IRET

  IRET = fmet this.INIT_TSCCODADI()
Return

#######################################################################################
$INIT_TSCCODADI
Local Integer DIM_STC
Local Integer NI

  DIM_STC = func ASYRFNC.ACTIV("STC")
  # -------------------
  For NI = 1 To DIM_STC
    this.C_TSCCOD(NI).TSCCODADI = NI + 30
  Next NI
  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
Return

