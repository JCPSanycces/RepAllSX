Subprog GET_CYCLE_START_DATE (CTRNUMBER, LVESUBTYPE, FILTERINGDATE, CYCLESTARTDATE, CYCLEENDDATE,RF_IS_SOA)
Value Integer RF_IS_SOA
Value Char CTRNUMBER
Value Char LVESUBTYPE
Value Date FILTERINGDATE
Variable Date CYCLESTARTDATE
Variable Date CYCLEENDDATE
  If (CTRNUMBER = "" | LVESUBTYPE = "" | FILTERINGDATE = [0/0/0])
    End
  Endif

  If dim(VARDAT)=0
    Local Date VARDAT
  Endif

  Local Date CCYCLDAT, CHECKD, LASTACCRUAL, ACCDAT, FILTERDATE
  Local Integer COUNTER, RCOUNTACCR
  Local Date CYCARRSTR(0..)
  Local Date CYCARREND(0..)

  If clalev([F:HRLSTHBA]) = 0: Local File HRLVESUBHEA [HRLSTHBA]: Endif
  If clalev([F:HRCTRD]) = 0  : Local File EMPLOCTR [HRCTRD]     : Endif
  If clalev([F:ACCRU]) = 0   : Local File HRLVEACCRU [ACCRU]    : Endif
  If clalev([F:VEP2]) = 0    : Local File VALEMP [VEP2]         : Endif

  Filter [HRCTRD] Where [HRCTRD]CTRNUM = CTRNUMBER
  Read [HRCTRD] First

  Filter [VEP2] Where CTRNUM = CTRNUMBER Order By [F:VEP2]ENDDAT
  Read [VEP2] Last

  Filter [HRLSTHBA] Where [F:HRLSTHBA]COD = LVESUBTYPE
  Read [HRLSTHBA] First

  If parse(evalue([F:HRLSTHBA]CYCSTRCAL), 0) <> 10 & parse(evalue([F:HRLSTHBA]CYCSTRCAL), 0) <> 0
    VARDAT = GLMCYCLE
  Else
    VARDAT = evalue([F:HRLSTHBA]CYCSTRCAL)
  Endif

  If parse(evalue([F:HRLSTHBA]CYCSTRCAL), 0) <> 10 & parse(evalue([F:HRLSTHBA]CYCSTRCAL), 0) <> 0
    ACCDAT =GLMCYCLE
  Else
    ACCDAT = evalue([F:HRLSTHBA]CYCSTRCAL)
  Endif

  If ACCDAT=[0/0/0]
    ACCDAT=VARDAT
  Endif

  If ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
    Filter [ACCRU]
    Filter [ACCRU] Where [ACCRU]LVEACCLST =LVESUBTYPE and [ACCRU]CTR=CTRNUMBER Order By [ACCRU]LVEACCDAT
    Read [ACCRU] Last
    Filter [ACCRU]
    CYCSTRDAT=[ACCRU]LVEACCDAT
  Endif

  Local Integer CYCLETRACE
  FILTERDATE = FILTERINGDATE
  Onerrgo CYCLECHECKERROR

  Gosub CYCLE_CHECK_DCG From SUBDCGGLM

  CYCLETRACE = 0

  For COUNTER = 0 To maxtab(CYCARR)
    If CYCARR(COUNTER, 1) <> [0/0/0] and (FILTERINGDATE >= CYCARR(COUNTER, 1) and FILTERINGDATE < CYCARR(COUNTER, 2))
      CYCLESTARTDATE = CYCARR(COUNTER, 1)
      CYCLEENDDATE = CYCARR(COUNTER, 2)
      Break
    Endif
  Next
  Filter [HRCTRD]
  Filter [VEP2]
  Filter [HRLSTHBA]
End

Subprog GET_CYCLE_START_DATE_EXTRACTION(CTRNUMBER, LVESUBTYPE, FILTERINGDATE, CYCLESTARTDATE, CYCLEENDDATE,RF_IS_SOA,STR_GCURLEG)
Value Integer RF_IS_SOA
Value Char STR_GCURLEG
Value Char CTRNUMBER
Value Char LVESUBTYPE
Value Date FILTERINGDATE
Variable Date CYCLESTARTDATE
Variable Date CYCLEENDDATE

  Local Date CTR_DATE
  Local Date CTR_DATE_PREV
  Local Integer GRAR

  If dim(GCTRNUM)<0
   Global Char GCTRNUM(GLONHRCTR)
    GCTRNUM = CTRNUMBER
    Gosub POPULATE_CTRARRAY
  Else
     #Check if it was still the same
    If GCTRNUM <> CTRNUMBER
      Gosub POPULATE_CTRARRAY
      GCTRNUM = CTRNUMBER
    Endif
  Endif

  If dim(GCTRARRAY)<0
    Gosub POPULATE_CTRARRAY
  Endif

  #Filter the array to populate the CTR_DATE
  For GRAR = 1 To maxtab(GCTRARRAY)
    If GCTRARRAY(GRAR,1) = [0/0/0] : Break : Endif
    If GCTRARRAY(GRAR,1) <= FILTERINGDATE and (GCTRARRAY(GRAR,2) = [0/0/0] or GCTRARRAY(GRAR,2)>= FILTERINGDATE)
      If GCTRARRAY(GRAR,1) > [L]CTR_DATE_PREV #Will always be true in the first loop
        [L]CTR_DATE = GCTRARRAY(GRAR,1)
        [L]CTR_DATE_PREV = [L]CTR_DATE
      Endif
    Endif
  Next

  Local Char GLMCYCLESTR(250)
  Local Date GLMCYCLE,COMPDATCCHK
  Local Integer LINKED

  Call GET_LEAVE_SUB_TYPE_STR_DATE(CTRNUMBER,FILTERINGDATE,LVESUBTYPE,COMPDATCCHK,LINKED) From SUBHRBAL
  GLMCYCLE = func GET_GLM_CYCLE(CTRNUMBER,[L]CTR_DATE)

  If (CTRNUMBER = "" | LVESUBTYPE = "" | FILTERINGDATE = [0/0/0])
    End
  Endif

  If dim(VARDAT)=0
    Local Date VARDAT
  Endif

  Local Date CCYCLDAT, CHECKD, LASTACCRUAL, ACCDAT, FILTERDATE
  Local Integer COUNTER, RCOUNTACCR
  Local Date CYCARRSTR(0..)
  Local Date CYCARREND(0..)

  If clalev([F:HRLSTHBA]) = 0: Local File HRLVESUBHEA [HRLSTHBA]: Endif
  If clalev([F:HRPEOBAL]) = 0 : Local File HRPEODET [HRPEOBAL] : Endif

  If RF_IS_SOA
    If clalev([F:HRLSTH]) = 0: Local File HRLVESUBHEA [HRLSTH]: Endif
    Read [HRLSTH]HRLST0=STR_GCURLEG;LVESUBTYPE
  Else
    If GFONCTION = "CONSLTA" | GFONCTION = "GESHRLAF" | GFONCTION = "GESDCG" | GFONCTION = "SAIWRKMAN"
      If clalev([F:HRLSTH]) = 0: Local File HRLVESUBHEA [HRLSTH]: Endif
      Read [HRLSTH]HRLST0=GCURLEG;LVESUBTYPE
    Endif
  Endif

  Filter [HRLSTHBA] Where [F:HRLSTHBA]COD = LVESUBTYPE
  Read [HRLSTHBA] First
  If parse(evalue([F:HRLSTHBA]CYCSTRCAL), 0) <> 10 & parse(evalue([F:HRLSTHBA]CYCSTRCAL), 0) <> 0
    If COMPDATCCHK<>GLMCYCLE
      VARDAT = CYCLESTARTDATE
    Else
      VARDAT = GLMCYCLE
    Endif
  Else
    VARDAT = evalue([F:HRLSTHBA]CYCSTRCAL)
  Endif
  If parse(evalue([F:HRLSTHBA]CYCSTRCAL), 0) <> 10 & parse(evalue([F:HRLSTHBA]CYCSTRCAL), 0) <> 0
    ACCDAT =GLMCYCLE
  Else
    ACCDAT = evalue([F:HRLSTHBA]CYCSTRCAL)
  Endif
  If ACCDAT=[0/0/0]
    ACCDAT=VARDAT
  Endif

  If ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
    If clalev([F:ACCRU]) = 0: Local File HRLVEACCRU [ACCRU] : Endif
    Filter [F:ACCRU]
  Endif
  If ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
    Filter [ACCRU] Where [ACCRU]LVEACCLST =LVESUBTYPE and [ACCRU]CTR=CTRNUMBER Order By [ACCRU]LVEACCDAT
    Read [ACCRU] Last
    Filter [ACCRU]
    CYCSTRDAT=[ACCRU]LVEACCDAT
  Endif

  Local Integer CYCLETRACE
  FILTERDATE = FILTERINGDATE
  CHECKD = FILTERINGDATE
  Onerrgo CYCLECHECKERROR
  Gosub CYCLE_CHECK From SUBDCGGLM
  CYCLETRACE = 0

  For COUNTER = 0 To maxtab(CYCARR)
    If CYCARR(COUNTER, 1) <> [0/0/0]
      If (FILTERINGDATE >= CYCARR(COUNTER, 1) and FILTERINGDATE < CYCARR(COUNTER, 2)) | (FILTERINGDATE<=CYCARR(COUNTER, 1))
        If COMPDATCCHK>CYCARR(COUNTER, 1)
         CYCLESTARTDATE = COMPDATCCHK
        Else
          CYCLESTARTDATE = CYCARR(COUNTER, 1)
        Endif
        If CYCLEENDDATE<>[0/0/0]
          CYCLEENDDATE = CYCLEENDDATE
        Else
          CYCLEENDDATE = CYCARR(COUNTER, 2)
        Endif
        Break
      Endif
      If [HRLSTHBA]LVEACCOPT = 1 | [HRLSTHBA]LVEACCOPT = 3 | [HRLSTHBA]LVEACCOPT = 4 | [HRLSTHBA]LVEACCOPT = 5 | [HRLSTHBA]LVEACCOPT = 2
        Filter [HRPEOBAL] Where [HRPEOBAL]PERCOD=[HRCTR]PERCOD & [HRPEOBAL]PERSTR(1)<=CYCARR(COUNTER, 1) & [HRPEOBAL]PEREND(1)>=CYCARR(COUNTER, 1) & [HRPEOBAL]PERSTR(1)<=FILTERINGDATE & [HRPEOBAL]
&       PEREND(1)>=FILTERINGDATE Order By [HRPEOBAL]PERSTR(1)
        Read [HRPEOBAL] First
        If !fstat
          If COMPDATCCHK>CYCARR(COUNTER, 1)
            CYCLESTARTDATE = COMPDATCCHK
          Else
            CYCLESTARTDATE = CYCARR(COUNTER, 1)
          Endif
          If CYCLEENDDATE<>[0/0/0]
            CYCLEENDDATE = CYCLEENDDATE
          Else
            CYCLEENDDATE = CYCARR(COUNTER, 2)
          Endif
          Break
        Endif
        Filter [HRPEOBAL]
      Endif
    Endif
  Next

  If ([HRLSTHBA]LVEACCOPT = 1 | [HRLSTHBA]LVEACCOPT = 3 | [HRLSTHBA]LVEACCOPT = 4 | [HRLSTHBA]LVEACCOPT = 5 |[HRLSTHBA]LVEACCOPT = 2) & CYCLESTARTDATE <> [0/0/0]
    Filter [HRPEOBAL]
    Filter [HRPEOBAL] Where [HRPEOBAL]PERCOD = [HRCTR]PERCOD & [HRPEOBAL]PERSTR(1) <= CYCLESTARTDATE & [HRPEOBAL]PEREND(1) >= CYCLESTARTDATE Order By [HRPEOBAL]PERSTR(1)
    Read [HRPEOBAL] First
      CYCLESTARTDATE = [HRPEOBAL]PERSTR(1)
      Filter [HRPEOBAL]
      Filter [HRPEOBAL] Where [HRPEOBAL]PERCOD = [HRCTR]PERCOD & [HRPEOBAL]PERSTR(1) <= CYCLEENDDATE & [HRPEOBAL]PEREND(1) >= CYCLEENDDATE
      Read [HRPEOBAL] First
      If !fstat
        CYCLEENDDATE = [HRPEOBAL]PERSTR(1) - 1
        If FILTERINGDATE > CYCLEENDDATE
          For COUNTER = 0 To maxtab(CYCARR)
            If CYCARR(COUNTER, 1) <> [0/0/0] and [HRPEOBAL]PEREND(1) >= CYCARR(COUNTER, 1) and [HRPEOBAL]PEREND(1) < CYCARR(COUNTER, 2)
              CYCLESTARTDATE = CYCARR(COUNTER, 1)
              CYCLEENDDATE = CYCARR(COUNTER, 2)
              Break
            Endif
          Next
          Local Date LCYCLESTARTDATE, LCYCLEENDDATE
          LCYCLESTARTDATE = CYCLESTARTDATE
          LCYCLEENDDATE = CYCLEENDDATE
          Call GET_EXTRACTION_START_DATE(CTRNUMBER, FILTERINGDATE, LCYCLESTARTDATE, LCYCLEENDDATE, CYCLESTARTDATE, CYCLEENDDATE)
        Endif
      Endif
    Filter [HRPEOBAL]
  Else
    If CYCLEENDDATE <> [0/0/0]
      CYCLEENDDATE = CYCLEENDDATE - 1
    Endif
  Endif
  If CYCLEENDDATE + 1 < FILTERINGDATE
    CYCLESTARTDATE = [0/0/0]
    CYCLEENDDATE = [0/0/0]
  Endif
  Filter [HRLSTHBA]
End

$CYCLECHECKERROR
  CYCLETRACE = 1
Resume

Subprog GET_EXTRACTION_START_DATE(CTRNUMBER, FILTERINGDATE, CYCLESTARTDATE, CYCLEENDDATE, EXTRACTIONSTARTDATE, EXTRACTIONENDDATE)
Value Char CTRNUMBER
Value Date FILTERINGDATE
Value Date CYCLESTARTDATE
Value Date CYCLEENDDATE
Variable Date EXTRACTIONSTARTDATE
Variable Date EXTRACTIONENDDATE

  If clalev([F:HRCTR]) = 0: Local File EMPLOCTR [HRCTR]: Endif
  If clalev([F:HRPEOSD]) = 0 : Local File HRPEODET [HRPEOSD] : Endif

  Filter [HRCTR] Where [HRCTR]CTRNUM = CTRNUMBER
  Read [HRCTR] First
  Filter [HRCTR]

  Filter [HRPEOSD] Where [HRPEOSD]PERCOD = [HRCTR]PERCOD & [HRPEOSD]PERSTR(1) <= CYCLESTARTDATE & [HRPEOSD]PEREND(1) >= CYCLESTARTDATE
  Read [HRPEOSD] First
  EXTRACTIONSTARTDATE = [HRPEOSD]PERSTR(1)
  Filter [HRPEOSD]

  Filter [HRPEOSD] Where [HRPEOSD]PERCOD = [HRCTR]PERCOD & [HRPEOSD]PERSTR(1) <= CYCLEENDDATE & [HRPEOSD]PEREND(1) >= CYCLEENDDATE
  Read [HRPEOSD] First
  EXTRACTIONENDDATE = [HRPEOSD]PERSTR(1) - 1
  Filter [HRPEOSD]
End

Subprog GET_BALANCE_FCST(CTRNUMBER, NEVENT, LVESUBTYPE, FILTERINGDATE, FUTBALS, BALANCE, ACCRUAL, TOTALTAKENINCYCLE,IS_SOA,SSSTR,EEDAT,GCURLEG,CARFUTBALS)
Value Integer IS_SOA
Value Char CTRNUMBER
Value Char NEVENT
Value Char LVESUBTYPE
Value Char GCURLEG
Value Date FILTERINGDATE,SSSTR,EEDAT
Value Char FUTBALS()(0..,0..10)
Variable Decimal BALANCE
Variable Decimal ACCRUAL
Variable Decimal TOTALTAKENINCYCLE
Variable Char CARFUTBALS()(0..,0..10)
  If (CTRNUMBER = "" | NEVENT = "" | LVESUBTYPE = "")
    End
  Endif

  Local Date CCYCLDAT, CCYCLENDDATE, EXTRACTIONSTARTDATE, EXTRACTIONENDDATE, QUERYSTARTDATE, QUERYENDDATE
  Local Decimal ALREADYTAKENINCYCLE
  Local Integer M, X, H
  Local Char CRITHRLST(250)

  BALANCE = 0: ACCRUAL = 0: ALREADYTAKENINCYCLE = 0: TOTALTAKENINCYCLE = 0:

  If clalev([F:HRCTR]) = 0 : Local File EMPLOCTR [HRCTR]    : Endif
  If clalev([F:ACCRU]) = 0 : Local File HRLVEACCRU [ACCRU]  : Endif
  If clalev([F:DCG]) = 0   : Local File DEMCONGE [DCG]      : Endif
  If clalev([F:HRLSTH]) = 0: Local File HRLVESUBHEA [HRLSTH]: Endif
  If clalev([F:DCGSP]) = 0 : Local File DEMSPLITS [DCGSP]   : Endif


  CRITHRLST="1=0 | ([F:HRCTR]CTRNUM = '"+CTRNUMBER+"')"
  Local Char LVE_ERRMESSAGE(250)
  Local Integer LVE_GOK

  Call LVE_ENG("",CRITHRLST,"",NEVENT, CTRNUMBER, LVESUBTYPE, FILTERINGDATE, FUTBALS,IS_SOA,LVE_ERRMESSAGE,LVE_GOK,[0/0/0],[0/0/0],0) From SUBACCRUAL

  Local Char VGURLEG(GLONADI)
  If IS_SOA
    Filter [F:HRCTR] Where [F:HRCTR]CTRNUM = CTRNUMBER and [F:HRCTR]CTRDAT <= FILTERINGDATE and ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=FILTERINGDATE)
    Read [F:HRCTR] First
    Filter [F:HRCTR]
    VGCURLEG = func DIVPAYE_SOA.GET_LEG_CTR([F:HRCTR]REFNUM, [F:HRCTR]CTRNUM, [F:HRCTR]CTRDAT, 1)
  Else
    VGCURLEG = GCURLEG
  Endif

  Filter [F:HRCTR] Where [F:HRCTR]CTRNUM = CTRNUMBER and [F:HRCTR]CTRDAT <= FILTERINGDATE and ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=FILTERINGDATE)
  Read [F:HRCTR] First
  Filter [F:HRCTR]

  Local Date COMPDATLTAACCCRF,STARTDATEACCRF,GLMCYCLEGBF
  Local Integer LINKED
  If IS_SOA
    GLMCYCLESTR = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 5, GCURLEG, "GLMCYCLE")
    Call CONVERT_TO_DATE(evalue(GLMCYCLESTR), GLMCYCLEGBF) From SUBHRBAL
  Else
    GCURLEG=func DIVPAYE_SOA.GET_LEG_CTR([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,1)
    GLMCYCLEGBF = func GET_GLM_CYCLE([F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT)
  Endif

  Call GET_LEAVE_SUB_TYPE_STR_DATE(CTRNUMBER,FILTERINGDATE,LVESUBTYPE,COMPDATLTAACCCRF,LINKED) From SUBHRBAL
  If COMPDATLTAACCCRF<>GLMCYCLEGBF
    CCYCLDAT=COMPDATLTAACCCRF
  Endif

  Call GET_CYCLE_START_DATE_EXTRACTION(CTRNUMBER, LVESUBTYPE, FILTERINGDATE, CCYCLDAT, CCYCLENDDATE, IS_SOA, VGCURLEG)

  Filter [ACCRU] Where [ACCRU]CTR = CTRNUMBER and [ACCRU]LVEACCLST = LVESUBTYPE and ([F:ACCRU]LVEACCTYP <> "Linking")
&   and [ACCRU]LVEACCDAT >= COMPDATLTAACCCRF and LVEACCDAT >= CCYCLDAT and LVEACCDAT <= FILTERINGDATE Order By [ACCRU]LVEACCDAT
  For [ACCRU]
    ACCRUAL += val([F:ACCRU]LVEACCAMT)
  Next
  Filter [ACCRU]

  QUERYSTARTDATE = CCYCLDAT
  If GLMCYCLE > CCYCLDAT
    If clalev([F:HRPEOD]) = 0 : Local File HRPEODET [HRPEOD] : Endif
    Filter [HRPEOD] Where [HRPEOD]PERCOD = [HRCTR]PERCOD & [HRPEOD]PERSTR(1) <= QUERYSTARTDATE & [HRPEOD]PEREND(1) >= QUERYSTARTDATE & [HRPEOD]PERSTR(1) <= GLMCYCLE & [HRPEOD]PEREND(1) >= GLMCYCLE
    If (rowcount([F:HRPEOD]) = 0)
      QUERYSTARTDATE =GLMCYCLE
    Endif
    Filter [HRPEOD]
  Endif

  QUERYENDDATE = CCYCLENDDATE
  H = 0
  For M = 0 To maxtab(CARFUTBALS)
    If CARFUTBALS(M,1) <> ""
      H += 1
    Endif
  Next
  For M = 1 To dim(FUTBALS)
    If (FUTBALS(M-1, 1) <> "" and FUTBALS(M-1, 1) = NEVENT and FUTBALS(M-1, 2) <> LVESUBTYPE)
      H+=1
      CARFUTBALS(H,1)=FUTBALS(M-1, 1)
      CARFUTBALS(H,2)=FUTBALS(M-1, 2)
      CARFUTBALS(H,3)=FUTBALS(M-1, 3)
      CARFUTBALS(H,4)=FUTBALS(M-1, 4)
      CARFUTBALS(H,5)=FUTBALS(M-1, 5)
    Endif
    If (FUTBALS(M-1, 1) <> "" and FUTBALS(M-1, 1) = NEVENT and FUTBALS(M-1, 2) = LVESUBTYPE)
      If FUTBALS(M-1, 3) >= QUERYSTARTDATE and FUTBALS(M-1, 3) <= FILTERINGDATE
        ACCRUAL += val(FUTBALS(M-1, 5))
      Endif
    Endif
  Next

#PEVAN - 2018-10-10 - X3-111790 - START
  Link [DCG] With [DCGSP]DCGSP1=[DCG]UID As [SPLITS]
& Where [F:DCG]CTRNUM = CTRNUMBER and [F:DCGSP]LVESUBTYP = LVESUBTYPE and [F:DCGSP]LVESUBBAL > 0
&   and ([DCG]STA = 1 | [DCG]STA = 2 | [DCG]STA = 3 or [DCG]STA = 5 or [DCG]STA = 7)
&   and ([DCGSP]LVEDAT >= QUERYSTARTDATE and [DCGSP]LVEDAT <= FILTERINGDATE)

  Columns [SPLITS] ([F:DCGSP]LVESUBTYP, [F:DCGSP]LVESUBBAL)
  For [SPLITS]
    ALREADYTAKENINCYCLE += [DCGSP]LVESUBBAL
  Next
  Columns [SPLITS]

  Link [DCG] With [DCGSP]DCGSP1=[DCG]UID As [SPLITS]
& Where [F:DCG]CTRNUM = CTRNUMBER and [F:DCGSP]LVESUBTYP = LVESUBTYPE and [F:DCGSP]LVESUBBAL > 0
&   and ([DCG]STA = 1 | [DCG]STA = 2 | [DCG]STA = 3 or [DCG]STA = 5 or [DCG]STA = 7)
&   and ([DCGSP]LVEDAT >= QUERYSTARTDATE and [DCGSP]LVEDAT <= QUERYENDDATE)

  Columns [SPLITS] ([F:DCGSP]LVESUBTYP, [F:DCGSP]LVESUBBAL)
  For [SPLITS]
    TOTALTAKENINCYCLE += [DCGSP]LVESUBBAL
  Next
  Columns [SPLITS]


#  Filter [DCG] Where [F:DCG]CTRNUM = CTRNUMBER and [DCG]UID > 0 and ([DCG]STA = 1 | [DCG]STA = 2 | [DCG]STA = 3 or [DCG]STA = 5 or [DCG]STA = 7)
#& & ([F:DCG]STRDAT  >= QUERYSTARTDATE and [F:DCG]STRDAT <= FILTERINGDATE)
#  For [DCG]
#    For X = 1 To dim([DCG]LVESUBTYP)
#      If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = LVESUBTYPE and [DCG]LVESUBBAL(X-1) > 0
#        ALREADYTAKENINCYCLE += [DCG]LVESUBBAL(X-1)
#      Endif
#    Next
#  Next
#  Filter [DCG]
#
#  Filter [DCG] Where [F:DCG]CTRNUM = CTRNUMBER and [DCG]UID > 0 and ([DCG]STA = 1 | [DCG]STA = 2 | [DCG]STA = 3 or [DCG]STA = 5 or [DCG]STA = 7) and ([F:DCG]STRDAT >= QUERYSTARTDATE and [F:DCG]
#& STRDAT <= QUERYENDDATE)
#  For [DCG]
#    For X = 1 To dim([DCG]LVESUBTYP)
#      If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = LVESUBTYPE and [DCG]LVESUBBAL(X-1) > 0
#        If [F:DCG]ENDDAT > QUERYENDDATE - 1
#          Local Decimal NRDAYS, NRHOURS
#          Call VALORIS_L([F:DCG]STRDAT, (QUERYENDDATE - 1), [HRCTR]REFNUM, NEVENT, NRDAYS, NRHOURS, [HRCTR]ETRFCY, CTRNUMBER, IS_SOA, VGCURLEG, [0/0/0]) From SUBACCRUAL
#          TOTALTAKENINCYCLE += NRDAYS
#        Else
#          TOTALTAKENINCYCLE += [DCG]LVESUBBAL(X-1)
#        Endif
#      Endif
#    Next
#  Next
#  Filter [DCG]
#
#  Filter [DCG] Where [F:DCG]CTRNUM = CTRNUMBER and [DCG]UID > 0 and ([DCG]STA = 1 | [DCG]STA = 2 | [DCG]STA = 3 or [DCG]STA = 5 or [DCG]STA = 7) and ([F:DCG]ENDDAT < QUERYENDDATE and [F:DCG] STRDAT <
#& QUERYSTARTDATE)
#  For [DCG]
#    For X = 1 To dim([DCG]LVESUBTYP)
#      If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = LVESUBTYPE and [DCG]LVESUBBAL(X-1) > 0
#        Local Decimal NRDAYS, NRHOURS
#        Call VALORIS_L(QUERYSTARTDATE, [F:DCG]ENDDAT, [HRCTR]REFNUM, NEVENT, NRDAYS, NRHOURS, [HRCTR]ETRFCY, CTRNUMBER, IS_SOA, VGCURLEG, [0/0/0]) From SUBACCRUAL
#        TOTALTAKENINCYCLE += NRDAYS
#      Endif
#    Next
#  Next
#  Filter [DCG]
#PEVAN - 2018-10-10 - X3-111790 - END

  BALANCE = ACCRUAL - ALREADYTAKENINCYCLE
End

Subprog GET_BALANCE(CTRNUMBER, LVESUBTYPE, FILTERINGDATE, BALANCE, ACCRUAL, TOTALTAKENINCYCLE, IS_SOA, VGCURLEG)
Value Char CTRNUMBER
Value Char LVESUBTYPE
Value Date FILTERINGDATE
Variable Decimal BALANCE
Variable Decimal ACCRUAL
Variable Decimal TOTALTAKENINCYCLE
Value Integer IS_SOA
Value Char VGCURLEG
  If (CTRNUMBER = "")
    End
  Endif
  If (LVESUBTYPE = "")
    End
  Endif
  If (FILTERINGDATE = [0/0/0])
    End
  Endif

  If dim(GLMCYCLESTR) < 1
    Local Char GLMCYCLESTR(250)
  Endif

  Local Date CCYCLDAT, CCYCLENDDATE, EXTRACTIONSTARTDATE, EXTRACTIONENDDATE, QUERYSTARTDATE, QUERYENDDATE
  Local Decimal ALREADYTAKENINCYCLE
  Local Integer X

  BALANCE = 0: ACCRUAL = 0: ALREADYTAKENINCYCLE = 0: TOTALTAKENINCYCLE = 0:

  If clalev([F:HRCTRGB]) = 0 : Local File EMPLOCTR [HRCTRGB]   : Endif
  If clalev([F:ACCRU]) = 0   : Local File HRLVEACCRU [ACCRU]   : Endif
  If clalev([F:DCG]) = 0     : Local File DEMCONGE [DCG]       : Endif
  If clalev([F:HRLSTH]) = 0  : Local File HRLVESUBHEA [HRLSTH] : Endif
  If clalev([F:DCGSP]) = 0   : Local File DEMSPLITS [DCGSP]    : Endif

  Local Date COMPDATLTAACCCR,STARTDATEACCR,GLMCYCLEGB
  Local Integer LINKED
  Filter [HRCTRGB] Where [F:HRCTRGB]CTRNUM=CTRNUMBER and [F:HRCTRGB]CTRDAT <= FILTERINGDATE and ([F:HRCTRGB]XITDAT = [0/0/0] or [F:HRCTRGB]XITDAT >= FILTERINGDATE)
  Read [HRCTRGB] First
  Filter [HRCTRGB]

  If IS_SOA
    GLMCYCLESTR = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 5, VGCURLEG, "GLMCYCLE")
    Call CONVERT_TO_DATE(evalue(GLMCYCLESTR), GLMCYCLEGB) From SUBHRBAL
  Else
    GCURLEG=func DIVPAYE_SOA.GET_LEG_CTR([F:HRCTRGB]REFNUM,[F:HRCTRGB]CTRNUM,[F:HRCTRGB]CTRDAT,1)
    GLMCYCLEGB = func GET_GLM_CYCLE([F:HRCTRGB]CTRNUM,[F:HRCTRGB]CTRDAT)
  Endif

  Call GET_LEAVE_SUB_TYPE_STR_DATE(CTRNUMBER,FILTERINGDATE,LVESUBTYPE,COMPDATLTAACCCR,LINKED) From SUBHRBAL
  If COMPDATLTAACCCR<>GLMCYCLEGB
    CCYCLDAT=COMPDATLTAACCCR
  Endif

  If IS_SOA
    Call GET_CYCLE_START_DATE_EXTRACTION(CTRNUMBER, LVESUBTYPE, FILTERINGDATE, CCYCLDAT, CCYCLENDDATE, 1, VGCURLEG)
  Else
    Call GET_CYCLE_START_DATE_EXTRACTION(CTRNUMBER, LVESUBTYPE, FILTERINGDATE, CCYCLDAT, CCYCLENDDATE, 0, GCURLEG)
  Endif
  QUERYSTARTDATE = CCYCLDAT
  QUERYENDDATE = CCYCLENDDATE

  If LINKED>1
    Filter [ACCRU] Where [ACCRU]CTR = CTRNUMBER and [ACCRU]LVEACCLST = LVESUBTYPE and ([F:ACCRU]LVEACCTYP <> "Linking") and [ACCRU]LVEACCDAT >= COMPDATLTAACCCR and LVEACCDAT >= QUERYSTARTDATE and
&   LVEACCDAT <= FILTERINGDATE Order By [ACCRU]LVEACCDAT
  Else
    Filter [ACCRU] Where [ACCRU]CTR = CTRNUMBER and [ACCRU]LVEACCLST = LVESUBTYPE and ([F:ACCRU]LVEACCTYP <> "Linking") and LVEACCDAT >= QUERYSTARTDATE and
&   LVEACCDAT <= FILTERINGDATE Order By [ACCRU]LVEACCDAT
  Endif
  For [ACCRU]
    ACCRUAL += val([F:ACCRU]LVEACCAMT)
  Next
  Filter [ACCRU]


#PEVAN - 2018-10-10 - X3-111790 - START
  Link [DCG] With [DCGSP]DCGSP1=[DCG]UID As [SPLITS]
& Where [F:DCG]CTRNUM = CTRNUMBER and [F:DCGSP]LVESUBTYP = LVESUBTYPE and [F:DCGSP]LVESUBBAL > 0
&   and ([DCG]STA = 1 | [DCG]STA = 2 | [DCG]STA = 3 or [DCG]STA = 5 or [DCG]STA = 7)
&   and ([DCGSP]LVEDAT >= QUERYSTARTDATE and [DCGSP]LVEDAT <= FILTERINGDATE)

  Columns [SPLITS] ([F:DCGSP]LVESUBTYP, [F:DCGSP]LVESUBBAL)
  For [SPLITS]
    ALREADYTAKENINCYCLE += [DCGSP]LVESUBBAL
  Next
  Columns [SPLITS]

  Link [DCG] With [DCGSP]DCGSP1=[DCG]UID As [SPLITS]
& Where [F:DCG]CTRNUM = CTRNUMBER and [F:DCGSP]LVESUBTYP = LVESUBTYPE and [F:DCGSP]LVESUBBAL > 0
&   and ([DCG]STA = 1 | [DCG]STA = 2 | [DCG]STA = 3 or [DCG]STA = 5 or [DCG]STA = 7)
&   and ([DCGSP]LVEDAT >= QUERYSTARTDATE and [DCGSP]LVEDAT <= QUERYENDDATE)

  Columns [SPLITS] ([F:DCGSP]LVESUBTYP, [F:DCGSP]LVESUBBAL)
  For [SPLITS]
    TOTALTAKENINCYCLE += [DCGSP]LVESUBBAL
  Next
  Columns [SPLITS]
#  Filter [DCG] Where [F:DCG]CTRNUM = CTRNUMBER and [DCG]UID > 0 and ([DCG]STA = 1 | [DCG]STA = 2 | [DCG]STA = 3 or [DCG]STA = 5 or [DCG]STA = 7) and ([F:DCG]STRDAT >= QUERYSTARTDATE and [F:DCG]
#& STRDAT <= FILTERINGDATE)
#  For [DCG]
#    For X = 1 To dim([DCG]LVESUBTYP)
#      If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = LVESUBTYPE and [DCG]LVESUBBAL(X-1) > 0
#        ALREADYTAKENINCYCLE += [DCG]LVESUBBAL(X-1)
#      Endif
#    Next
#  Next
#  Filter [DCG]
#
#  Filter [DCG] Where [F:DCG]CTRNUM = CTRNUMBER and [DCG]UID > 0 and ([DCG]STA = 1 | [DCG]STA = 2 | [DCG]STA = 3 or [DCG]STA = 5 or [DCG]STA = 7) and ([F:DCG]STRDAT >= QUERYSTARTDATE and [F:DCG]
#& STRDAT <= QUERYENDDATE)
#  For [DCG]
#    For X = 1 To dim([DCG]LVESUBTYP)
#      If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = LVESUBTYPE and [DCG]LVESUBBAL(X-1) > 0
#        If [F:DCG]ENDDAT > QUERYENDDATE - 1
#          Local Decimal NRDAYS, NRHOURS
#          If IS_SOA
#            Call VALORIS_L([F:DCG]STRDAT, (QUERYENDDATE - 1), [F:HRCTR]REFNUM, [F:DCG]TIM, NRDAYS, NRHOURS, [F:HRCTR]ETRFCY, CTRNUMBER, 1, VGCURLEG, [0/0/0]) From SUBACCRUAL
#          Else
#            Call VALORIS_L([F:DCG]STRDAT, (QUERYENDDATE - 1), [F:HRCTR]REFNUM, [F:DCG]TIM, NRDAYS, NRHOURS, [F:HRCTR]ETRFCY, CTRNUMBER, 0, GCURLEG, [0/0/0]) From SUBACCRUAL
#          Endif
#          TOTALTAKENINCYCLE += NRDAYS
#        Else
#          TOTALTAKENINCYCLE += [DCG]LVESUBBAL(X-1)
#        Endif
#      Endif
#    Next
#  Next
#  Filter [DCG]
#
#  Filter [DCG] Where [F:DCG]CTRNUM = CTRNUMBER and [DCG]UID > 0 and ([DCG]STA = 1 | [DCG]STA = 2 | [DCG]STA = 3 or [DCG]STA = 5 or [DCG]STA = 7) and ([F:DCG]ENDDAT < QUERYENDDATE and [F:DCG]
#& STRDAT < QUERYSTARTDATE)
#  For [DCG]
#    For X = 1 To dim([DCG]LVESUBTYP)
#      If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = LVESUBTYPE and [DCG]LVESUBBAL(X-1) > 0
#        Local Decimal NRDAYS, NRHOURS
#        If IS_SOA
#          Call VALORIS_L(QUERYSTARTDATE, [F:DCG]ENDDAT, [HRCTR]REFNUM, [F:DCG]TIM, NRDAYS, NRHOURS, [HRCTR]ETRFCY, CTRNUMBER, 1, VGCURLEG, [0/0/0]) From SUBACCRUAL
#        Else
#          Call VALORIS_L(QUERYSTARTDATE, [F:DCG]ENDDAT, [HRCTR]REFNUM, [F:DCG]TIM, NRDAYS, NRHOURS, [HRCTR]ETRFCY, CTRNUMBER, 0, GCURLEG, [0/0/0]) From SUBACCRUAL
#        Endif
#        TOTALTAKENINCYCLE += NRDAYS
#      Endif
#    Next
#  Next
#  Filter [DCG]
#PEVAN - 2018-10-10 - X3-111790 - END

  BALANCE = ACCRUAL - ALREADYTAKENINCYCLE
End

Subprog EMPLOYEE_SUB_TYPE_CHECK(CTRNUMBER, LVESUBTYPE, ACTIVE)
Value Char CTRNUMBER
Value Char LVESUBTYPE
Variable Integer ACTIVE

  If (CTRNUMBER = "" | LVESUBTYPE = "")
    End
  Endif

  ACTIVE = 0

  If clalev ([TIM]) = 0 : Local File TIMCOD [TIM] Endif
  If clalev ([HRLSTD]) = 0 : Local File HRLVESUBDET [HRLSTD] Endif
  If clalev ([HRLSTH]) = 0 : Local File HRLVESUBHEA [HRLSTH] Endif
  If clalev ([HRLSTH1]) = 0 : Local File HRLVESUBHEA [HRLSTH1] Endif
  If clalev ([HRCTR]) = 0 : Local File EMPLOCTR [HRCTR] Endif
  If clalev ([HRCTR2]) = 0 : Local File EMPLOCTR [HRCTR2] Endif
  If clalev ([ID]) = 0 : Local File EMPLOID [ID] Endif
  If clalev ([FCY]) = 0 : Local File FACILITY [FCY] Endif
  If clalev ([CPY]) = 0 : Local File COMPANY [CPY] Endif
  If clalev ([HRCLV]) = 0   : Local File HRCLLCVT [HRCLV] Endif
  If clalev ([SRV]) = 0   : Local File SERVICE [SRV] Endif
  If clalev ([PRF]) = 0   : Local File PROFIL [PRF] Endif
  If clalev ([HRPOA]) = 0 : Local File POPULA [HRPOA] Endif
  If clalev ([HRACCR]) = 0 : Local File HRLVEACCRU [HRACCR] Endif
  If clalev ([HRACCR1]) = 0 : Local File HRLVEACCRU [HRACCR1] Endif
  If clalev ([F:HRPEOD]) = 0 : Local File HRPEODET   [HRPEOD] : Endif
  If clalev ([F:VEP2]) = 0 : Local File VALEMP     [VEP2]  : Endif
  If clalev ([F:DCG]) = 0 : Local File DEMCONGE   [DCG] : Endif

  Local Integer S(1)
  Local Char CRITACC(250),CRITACCCHK(250), REFNUM(250)
  Local Integer CRFCHK

  Filter [HRCTR2] Where CTRNUM = CTRNUMBER
  Read [HRCTR2] First
  Filter [HRCTR2]
  REFNUM = [HRCTR2]REFNUM


  Filter [TIM] Where ([TIM]CATTIM=3 |[TIM]CATTIM=2) and [TIM]ENAFLG=2
  #Looping 1. HRTIM 2. HRLST 3.HRCTR/HRMAT
  For [TIM]
    For S=1 To dim([TIM]LVESUBTYP)
      CRITACC1 = "1=0"
      CRITACC2 = "1=0"
      If [TIM]LVESUBTYP(S-1) <> "" and [TIM]LVESUBTYP(S-1) = LVESUBTYPE
        CRITCOUNT=1
        For [HRLSTD] Where [HRLSTD]COD = [TIM]LVESUBTYP(S-1) and [HRLSTD]LEG = [TIM]LEG
          If len(CRITACC1)>=200 : CRITCOUNT=2 : Endif
          If CRITCOUNT=1
            Case [HRLSTD]LEV
              When 1  : CRITACC1 = CRITACC1 - " | 1=1"  #Folder
              When 2  : CRITACC1 = CRITACC1 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
              When 3  : CRITACC1 = CRITACC1 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
              When 4  : CRITACC1 = CRITACC1 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
              When 5  : CRITACC1 = CRITACC1 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
              When 6  : CRITACC1 = CRITACC1 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
              When 7  : CRITACC1 = CRITACC1 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
              When 8  : CRITACC1 = CRITACC1 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
              When 9  : CRITACC1 = CRITACC1 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
              When 10 : CRITACC1 = CRITACC1 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
            Endcase
          Else
            Case [HRLSTD]LEV
              When 1  : CRITACC2 = CRITACC2 - " | 1=1"  #Folder
              When 2  : CRITACC2 = CRITACC2 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
              When 3  : CRITACC2 = CRITACC2 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
              When 4  : CRITACC2 = CRITACC2 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
              When 5  : CRITACC2 = CRITACC2 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
              When 6  : CRITACC2 = CRITACC2 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
              When 7  : CRITACC2 = CRITACC2 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
              When 8  : CRITACC2 = CRITACC2 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
              When 9  : CRITACC2 = CRITACC2 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
              When 10 : CRITACC2 = CRITACC2 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
            Endcase
          Endif
        Next

        If [HRLSTD]LEV=3
          Link [HRCTR] With
&           [ID]ID0=[F:HRCTR]REFNUM,
&           [FCY]FCY0=[F:HRCTR]ETRFCY,
&           [CPY]CPY0=[F:FCY]LEGCPY,
&           [SRV]SRV0=[F:HRCTR]ETRSRV,
&           [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&           [PRF]PRF0=[F:HRCTR]PROPRF,
&           [HRPOA]POA0=[F:HRLSTD]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&           As [LNK] Where evalue(CRITACC1) or evalue(CRITACC2)
        Else
          Link [HRCTR] With
&           [ID]ID0=[F:HRCTR]REFNUM,
&           [FCY]FCY0=[F:HRCTR]ETRFCY,
&           [CPY]CPY0=[F:FCY]LEGCPY,
&           [SRV]SRV0=[F:HRCTR]ETRSRV,
&           [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&           [PRF]PRF0=[F:HRCTR]PROPRF
&           As [LNK] Where evalue(CRITACC1) or evalue(CRITACC2)
        Endif

        For [LNK]
          If [LNK]CTRNUM = CTRNUMBER
            ACTIVE = 1
            Filter [LNK]
            Break 3
          Endif
        Next
        Filter [LNK]
      Endif
    Next
  Next

  Filter [TIM]
End

Subprog EMPLOYEE_LEAVE_SUB_TYPES(CTRNUMBER, LVESTARR, NEVENTARR)
Value Char CTRNUMBER
Variable Char LVESTARR()(0..)
Variable Char NEVENTARR()(0..)

  If (REFNUM = "")
    Call ERREUR(mess(255,10702,1)) From GESECRAN
    End
  Endif

  ACTIVE = 0

  If clalev([TIM]) = 0 : Local File TIMCOD [TIM] Endif
  If clalev([HRLSTD]) = 0 : Local File HRLVESUBDET [HRLSTD] Endif
  If clalev([HRLSTH]) = 0 : Local File HRLVESUBHEA [HRLSTH] Endif
  If clalev([HRLSTH1]) = 0 : Local File HRLVESUBHEA [HRLSTH1] Endif
  If clalev([HRCTR]) = 0 : Local File EMPLOCTR [HRCTR] Endif
  If clalev ([ID]) = 0 : Local File EMPLOID [ID] Endif
  If clalev ([FCY]) = 0 : Local File FACILITY [FCY] Endif
  If clalev ([CPY]) = 0 : Local File COMPANY [CPY] Endif
  If clalev ([HRPOA]) = 0 : Local File POPULA [HRPOA] Endif
  If clalev ([HRACCR]) = 0 : Local File HRLVEACCRU [HRACCR] Endif
  If clalev ([HRACCR1]) = 0 : Local File HRLVEACCRU [HRACCR1] Endif
  If clalev([F:HRPEOD]) = 0 : Local File HRPEODET   [HRPEOD] : Endif
  If clalev([F:VEP2]) = 0 : Local File VALEMP     [VEP2]  : Endif
  If clalev([F:DCG]) = 0 : Local File DEMCONGE   [DCG] : Endif
  If clalev ([HRCLV]) = 0   : Local File HRCLLCVT [HRCLV] Endif
  If clalev ([SRV]) = 0   : Local File SERVICE [SRV] Endif
  If clalev ([PRF]) = 0   : Local File PROFIL [PRF] Endif

  Local Integer S(1), L, FOUND
  Local Char CRITACC(250),CRITACCCHK(250)
  Local Integer CRFCHK
  L = 0
  FOUND = 0

  Filter [TIM] Where ([TIM]CATTIM=3 |[TIM]CATTIM=2)  and [TIM]ENAFLG=2
  #Looping 1. HRTIM 2. HRLST 3.HRCTR/HRMAT
  For [TIM]
    For S=1 To dim([TIM]LVESUBTYP)
      CRITACC1 = "1=0"
      CRITACC2 = "1=0"
      If [TIM]LVESUBTYP(S-1) <> ""
        CRITCOUNT=1
        For [HRLSTD] Where [HRLSTD]COD = [TIM]LVESUBTYP(S-1) and [HRLSTD]LEG = [TIM]LEG
          If len(CRITACC1)>=200 : CRITCOUNT=2 : Endif
          If CRITCOUNT=1
            Case [HRLSTD]LEV
              When 1  : CRITACC1 = CRITACC1 - " | 1=1"  #Folder
              When 2  : CRITACC1 = CRITACC1 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
              When 3  : CRITACC1 = CRITACC1 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
              When 4  : CRITACC1 = CRITACC1 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
              When 5  : CRITACC1 = CRITACC1 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
              When 6  : CRITACC1 = CRITACC1 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
              When 7  : CRITACC1 = CRITACC1 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
              When 8  : CRITACC1 = CRITACC1 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
              When 9  : CRITACC1 = CRITACC1 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
              When 10 : CRITACC1 = CRITACC1 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
            Endcase
          Else
            Case [HRLSTD]LEV
              When 1  : CRITACC2 = CRITACC2 - " | 1=1"  #Folder
              When 2  : CRITACC2 = CRITACC2 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
              When 3  : CRITACC2 = CRITACC2 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
              When 4  : CRITACC2 = CRITACC2 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
              When 5  : CRITACC2 = CRITACC2 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
              When 6  : CRITACC2 = CRITACC2 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
              When 7  : CRITACC2 = CRITACC2 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
              When 8  : CRITACC2 = CRITACC2 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
              When 9  : CRITACC2 = CRITACC2 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
              When 10 : CRITACC2 = CRITACC2 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
            Endcase
          Endif
        Next
        #loop for accrual

        If [HRLSTD]LEV=3
          Link [HRCTR] With
&           [ID]ID0=[F:HRCTR]REFNUM,
&           [FCY]FCY0=[F:HRCTR]ETRFCY,
&           [CPY]CPY0=[F:FCY]LEGCPY,
&           [SRV]SRV0=[F:HRCTR]ETRSRV,
&           [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&           [PRF]PRF0=[F:HRCTR]PROPRF,
&           [HRPOA]POA0=[F:HRLSTD]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&           As [LNK] Where evalue(CRITACC1) or evalue(CRITACC2)
        Else
          Link [HRCTR] With
&           [ID]ID0=[F:HRCTR]REFNUM,
&           [FCY]FCY0=[F:HRCTR]ETRFCY,
&           [CPY]CPY0=[F:FCY]LEGCPY,
&           [SRV]SRV0=[F:HRCTR]ETRSRV,
&           [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&           [PRF]PRF0=[F:HRCTR]PROPRF
&           As [LNK] Where evalue(CRITACC1) or evalue(CRITACC2)
        Endif
        For [LNK] Where [LNK]CTRNUM = CTRNUMBER
          Local Date CHECKD
          Local Integer MDIFF,FOUND
          CRITCOUNT   = 1
          CRITACCCHK1 = "1=0"
          CRITACCCHK2 = "1=0"
          For [HRLSTD] Where [HRLSTD]COD = [TIM]LVESUBTYP(S-1) and [HRLSTD]LEG = [TIM]LEG
            If len(CRITACCCHK1)>=200 : CRITCOUNT=2 : Endif
            If CRITCOUNT = 1
              Case [HRLSTD]LEV
                When 1  : CRITACCCHK1 = CRITACCCHK1 - " | 1=1"  #Folder
                When 2  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                When 3  : CRITACCCHK1 = CRITACCCHK1 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                When 4  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                When 5  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                When 6  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                When 7  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                When 8  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                When 9  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                When 10 : CRITACCCHK1 = CRITACCCHK1 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
              Endcase
            Else
              Case [HRLSTD]LEV
                When 1  : CRITACCCHK2 = CRITACCCHK2 - " | 1=1"  #Folder
                When 2  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                When 3  : CRITACCCHK2 = CRITACCCHK2 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                When 4  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                When 5  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                When 6  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                When 7  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                When 8  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                When 9  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                When 10 : CRITACCCHK2 = CRITACCCHK2 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
              Endcase
            Endif
          Next

          If [HRLSTD]LEV=3
            Link [HRCTR] With
&             [ID]ID0=[F:HRCTR]REFNUM,
&             [FCY]FCY0=[F:HRCTR]ETRFCY,
&             [CPY]CPY0=[F:FCY]LEGCPY,
&             [SRV]SRV0=[F:HRCTR]ETRSRV,
&             [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&             [PRF]PRF0=[F:HRCTR]PROPRF,
&             [HRPOA]POA0=[F:HRLSTD]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&             As [LNK] Where evalue(CRITACC1) or evalue(CRITACC2)
          Else
            Link [HRCTR] With
&             [ID]ID0=[F:HRCTR]REFNUM,
&             [FCY]FCY0=[F:HRCTR]ETRFCY,
&             [CPY]CPY0=[F:FCY]LEGCPY,
&             [SRV]SRV0=[F:HRCTR]ETRSRV,
&             [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&             [PRF]PRF0=[F:HRCTR]PROPRF
&             As [LNK] Where evalue(CRITACC1) or evalue(CRITACC2)
          Endif

          Filter [LNK2] Where CTRNUM = [LNK]CTRNUM
          Read [LNK2] First
          Filter [LNK2]
          If fstat = 0
            ACTIVE = 1
            FOUND = find([TIM]LVESUBTYP(S-1), LVESTARR)
            If (FOUND = 0)
              LVESTARR(L) = [TIM]LVESUBTYP(S-1)
              NEVENTARR(L) = [TIM]COD
              L += 1
              Break 1
            Endif
          Endif
        Next
      Endif
    Next
  Next

  Filter [TIM]
End

Subprog CONVERT_TO_DATE(STRINGDATE, DATEDATE)
Value Char STRINGDATE
Variable Date DATEDATE
  Local Integer YEARVAL, MONTHVAL, DAYVAL
  YEARVAL = val(left$(STRINGDATE, 4))
  MONTHVAL = val(seg$(STRINGDATE, 5, 6))
  DAYVAL = val(right$(STRINGDATE, 7))
  DATEDATE = gdat$(DAYVAL, MONTHVAL, YEARVAL)
End

Subprog CONVERT_TO_DATE_SCR(STRINGDATE, DATEDATE)
Value Char STRINGDATE
Variable Date DATEDATE
  Local Integer YEARVAL, MONTHVAL, DAYVAL
  YEARVAL = 2000 + val(seg$(STRINGDATE, 7, 8))
  DAYVAL = val(seg$(STRINGDATE, 4, 5))
  MONTHVAL = val(left$(STRINGDATE, 2))
  DATEDATE = gdat$(DAYVAL, MONTHVAL, YEARVAL)
End

Subprog SUBTRACT_ONE_DAY(ORIGINALDATE, UPDATEDDATE)
Value Date ORIGINALDATE
Variable Date UPDATEDDATE
  Local Integer YEARVAL, MONTHVAL, DAYVAL
  YEARVAL = year(ORIGINALDATE)
  MONTHVAL = month(ORIGINALDATE)
  DAYVAL = day(ORIGINALDATE)
  If DAYVAL = 1
    If MONTHVAL = 1
      YEARVAL = YEARVAL - 1
      MONTHVAL = 12
      DAYVAL = 31
    Else
      UPDATEDDATE = eomonth(addmonth(ORIGINALDATE, -1))
    Endif
  Else
    DAYVAL = DAYVAL - 1
  Endif
  UPDATEDDATE = gdat$(DAYVAL, MONTHVAL, YEARVAL)
End

Subprog GET_NATURE_OF_EVENT (LVESUBTYPE,NATUREOFEVENT)
Value Char LVESUBTYPE
Variable Char NATUREOFEVENT
  NATUREOFEVENT = "NOTFOUND"
  If clalev ([TIM]) = 0 : Local File TIMCOD [TIM] Endif
  Local Integer DIMCOUNT
  Filter [F:TIM] Where [F:TIM]LVEENHANCE = 2

  For [F:TIM]
    For DIMCOUNT = 1 To dim([F:TIM]LVESUBTYP)
      If LVESUBTYPE = [F:TIM]LVESUBTYP(DIMCOUNT - 1)
        NATUREOFEVENT = [F:TIM]COD
        Break 2
      Endif
    Next
  Next
  Filter [F:TIM]
End NATUREOFEVENT

Subprog GET_LEAVE_SUB_TYPES(VCTRNUM, VFILTERDATE,VTIM, VFINALVALS)
Value Char VCTRNUM,VTIM
Value Date VFILTERDATE
Variable Char VFINALVALS()(0..,0..9)

  If !clalev([F:ACCRHR]) : Local File HRLVEACCRU [F:ACCRHR] : Endif
  If !clalev([F:TIMHR])  : Local File TIMCOD [F:TIMHR]      : Endif

  Local Date LCTRSTRDAT, LCTRENDDAT

  Local Char ALLSUBTYPES(100)(0..100,0..5)
  Local Char FINALVALS(100)(0..100,0..5)
  Local Char ALLNATURES(GLONTPS)(0..30)
  Local Char ALLSUBTYPESFOUND(100)(0..100)
  Local Char TEMPALLSUBTYPES(100)(0..100,0..5)
  Local Integer L, M, ALLN, FOUND, ROW
  L = 0 : ALLN = 0

  Local Char CTRNUMBER(GLONHRCTR) : CTRNUMBER = VCTRNUM

  If dim(GCTRNUM)<0
    Global Char GCTRNUM(GLONHRCTR)
    GCTRNUM = CTRNUMBER
    Gosub POPULATE_CTRARRAY
  Else
     #Check if it was still the same
    If GCTRNUM <> CTRNUMBER
      Gosub POPULATE_CTRARRAY
      GCTRNUM = CTRNUMBER
    Endif
  Endif

  If dim(GCTRARRAY)<0
    Gosub POPULATE_CTRARRAY
  Endif

  For I = 1 To maxtab(GCTRARRAY)
    If GCTRARRAY(I,1) = [0/0/0] : Break : Endif
    If GCTRARRAY(I,1) <= VFILTERDATE and (GCTRARRAY(I,2) = [0/0/0] or GCTRARRAY(I,2)>= VFILTERDATE)
      LCTRSTRDAT = GCTRARRAY(I,1)
      LCTRENDDAT = GCTRARRAY(I,2)
      Break
    Endif
  Next

  If LCTRSTRDAT = [0/0/0]
    LCTRSTRDAT = GCTRARRAY(1,1)
  Endif

  If VTIM=""
    Filter [F:ACCRHR] Where [F:ACCRHR]CTR = VCTRNUM and [F:ACCRHR]LVEACCTYP = "Linking" and [F:ACCRHR]CTRDAT = LCTRSTRDAT
  Else
    Filter [F:ACCRHR] Where [F:ACCRHR]CTR = VCTRNUM and [F:ACCRHR]LVEACCTIM=VTIM and [F:ACCRHR]LVEACCTYP = "Linking" and [F:ACCRHR]CTRDAT = LCTRSTRDAT
  Endif

  For [F:ACCRHR]ACC1
    FOUND = find([F:ACCRHR]LVEACCLST, ALLSUBTYPESFOUND)
    If (FOUND = 0)
      ALLSUBTYPESFOUND(L) = [F:ACCRHR]LVEACCLST
      FINALVALS(L,1) = [F:ACCRHR]LVEACCLST
      FINALVALS(L,3) = [F:ACCRHR]LVEACCTIM
      FINALVALS(L,4) = [F:ACCRHR]CTRDAT
      FINALVALS(L,5) = [F:ACCRHR]XITDAT
      FOUND = find([F:ACCRHR]LVEACCTIM, ALLNATURES)
      If (FOUND = 0)
        ALLNATURES(ALLN) = [F:ACCRHR]LVEACCTIM
        ALLN += 1
      Endif
      Filter [F:TIMHR] Where [F:TIMHR]COD = [F:ACCRHR]LVEACCTIM
      Read [F:TIMHR] First
      For M = 1 To dim([TIM]LVESUBTYP)
        If ([F:TIMHR]LVESUBTYP(M-1) <> "" and [F:TIMHR]LVESUBTYP(M-1) = [F:ACCRHR]LVEACCLST)
          FINALVALS(L,2) = num$([F:TIMHR]LVESUBPRI(M-1))
        Endif
      Next
      Filter [F:TIMHR]
      L += 1
    Endif
  Next
  Filter [F:ACCRHR]

  If ALLN > 1
    Repeat
      ALLNSWAPPEDAROUND = 0
      For M = 0 To ALLN - 1
        Local Integer ALLNSWAPPEDAROUND
        Local Char TEMPNATUREOFEVENT(250)
          If (ALLNATURES(M) > ALLNATURES(M+1))
            TEMPNATUREOFEVENT = ALLNATURES(M+1)
            ALLNATURES(M+1) = ALLNATURES(M)
            ALLNATURES(M) = TEMPNATUREOFEVENT
            ALLNSWAPPEDAROUND = 1
          Endif
      Next
    Until ALLNSWAPPEDAROUND = 0
  Endif
  ## SORT LEAVE SUB TYPES WITHIN NATURE OF EVENTS BASED ON THE PRIORITY ## PEVAN
  L = 0
  For LOOPM = 0 To ALLN
    Raz TEMPALLSUBTYPES
    For ROW = 0 To maxtab(FINALVALS)
      If (FINALVALS(ROW,1) <> "" and FINALVALS(ROW,3) = ALLNATURES(LOOPM))
        TEMPALLSUBTYPES(ROW,1) = FINALVALS(ROW,1)
        TEMPALLSUBTYPES(ROW,2) = FINALVALS(ROW,2)
        TEMPALLSUBTYPES(ROW,3) = FINALVALS(ROW,3)
        TEMPALLSUBTYPES(ROW,4) = FINALVALS(ROW,4)
        TEMPALLSUBTYPES(ROW,5) = FINALVALS(ROW,5)
      Endif
    Next

    Local Integer SWAPPEDAROUND
    Local Char TEMPSUBTYPE(250)
    Local Integer TEMPPRIORITY
    Local Char TEMPTIM(250)
    Local Date TEMPCTRDAT, TEMPXITDAT
    Repeat
      SWAPPEDAROUND = 0
      For M = 0 To (maxtab(TEMPALLSUBTYPES) - 1)
        If TEMPALLSUBTYPES(M,1) <> "" and TEMPALLSUBTYPES(M+1,1) <> ""
          If val(TEMPALLSUBTYPES(M,2)) > val(TEMPALLSUBTYPES(M+1,2))
            SWAPPEDAROUND = 1
            TEMPSUBTYPE = TEMPALLSUBTYPES(M+1,1)
            TEMPPRIORITY = val(TEMPALLSUBTYPES(M+1,2))
            TEMPTIM = TEMPALLSUBTYPES(M+1,3)
            TEMPCTRDAT = TEMPALLSUBTYPES(M+1,4)
            TEMPXITDAT = TEMPALLSUBTYPES(M+1,5)
            TEMPALLSUBTYPES(M+1,1) = TEMPALLSUBTYPES(M,1)
            TEMPALLSUBTYPES(M+1,2) = TEMPALLSUBTYPES(M,2)
            TEMPALLSUBTYPES(M+1,3) = TEMPALLSUBTYPES(M,3)
            TEMPALLSUBTYPES(M+1,4) = TEMPALLSUBTYPES(M,4)
            TEMPALLSUBTYPES(M+1,5) = TEMPALLSUBTYPES(M,5)
            TEMPALLSUBTYPES(M,1) = TEMPSUBTYPE
            TEMPALLSUBTYPES(M,2) = num$(TEMPPRIORITY)
            TEMPALLSUBTYPES(M,3) = TEMPTIM
            TEMPALLSUBTYPES(M,4) = TEMPCTRDAT
            TEMPALLSUBTYPES(M,5) = TEMPXITDAT
          Endif
        Endif
      Next
    Until SWAPPEDAROUND = 0

    For M = 0 To maxtab(TEMPALLSUBTYPES)
      If (TEMPALLSUBTYPES(M,1) <> "")
        VFINALVALS(L,1) = TEMPALLSUBTYPES(M,1)
        VFINALVALS(L,2) = TEMPALLSUBTYPES(M,2)
        VFINALVALS(L,3) = TEMPALLSUBTYPES(M,3)
        VFINALVALS(L,4) = TEMPALLSUBTYPES(M,4)
        VFINALVALS(L,5) = TEMPALLSUBTYPES(M,5)
        L += 1
      Endif
    Next
  Next
End

Subprog GET_LEAVE_SUB_TYPE_STR_DATE(VCTRNUM, VFILTERDATE,VLVESUBTYPE, VCTRSTRDAT,LINKED)
Value Char VCTRNUM,VLVESUBTYPE
Value Date VFILTERDATE
Variable Date VCTRSTRDAT
Variable Integer LINKED
  Local Integer U,F
  Local Date CCYCLDATSTSD,CCYCLENDDATESTSD

  Raz VCTRSTRDAT, LINKED
  Local Integer L
  Local Char CTRNUMBER(GLONHRCTR) : CTRNUMBER = VCTRNUM

  If dim(GCTRNUM)<0
    Global Char GCTRNUM(GLONHRCTR)
    GCTRNUM = CTRNUMBER
    Gosub POPULATE_CTRARRAY
  Else
    #Check if it was still the same
    If GCTRNUM <> CTRNUMBER
      Gosub POPULATE_CTRARRAY
      GCTRNUM = CTRNUMBER
    Endif
  Endif

  If dim(GCTRARRAY)<0
    Gosub POPULATE_CTRARRAY
  Endif

  For I = 1 To maxtab(GCTRARRAY)
    If GCTRARRAY(I,1) = [0/0/0] : Break : Endif
    LINKED+=1
    F+=1
    If GCTRARRAY(I,1) <= VFILTERDATE and (GCTRARRAY(I,2) = [0/0/0] or GCTRARRAY(I,2)>= VFILTERDATE)
      VCTRSTRDAT = GCTRARRAY(I,1)
      Break
    Endif
  Next
  If (maxtab(GCTRARRAY) = 1) | (F=1)
    VCTRSTRDAT = max(GCTRARRAY(1..maxtab(GCTRARRAY),3))
  Endif
End

$POPULATE_CTRARRAY
  Local Integer CTRAR

  If dim(GCTRARRAY)<0
    Global Date GCTRARRAY(1..1000,1..3)
  Else
    Raz GCTRARRAY
  Endif

  #Populate the array
  If !clalev([F:HRCTR7]) : Local File EMPLOCTR [F:HRCTR7] : Endif
  Filter [F:HRCTR7] Where CTRNUM = CTRNUMBER Order By CTRDAT
  For [F:HRCTR7]
    [L]CTRAR+=1
    GCTRARRAY(CTRAR,1) = [F:HRCTR7]CTRDAT #Contract date
    GCTRARRAY(CTRAR,2) = [F:HRCTR7]XITDAT #Exit date
    GCTRARRAY(CTRAR,3) = [F:HRCTR7]DATANC #Seniority date
  Next

  Filter [F:HRCTR7]
Return

#Function will return the default date based on the parameter value GLMCYCLE
#1 = Seniority Date
#2 = Contract Date
Funprog GET_GLM_CYCLE(VCTRNUMBER,VCTRDAT)
Value Char VCTRNUMBER
Value Date VCTRDAT
Local Date GLMCYCLEDATE
Local Char LOCALMENUVALUE(2)
Local Integer COUNTER

  Local Char CTRNUMBER(GLONHRCTR) : [L]CTRNUMBER =  VCTRNUMBER
  #Need to populate the CTR_DATE
  If dim(GCTRNUM)<0
    Global Char GCTRNUM(GLONHRCTR)
    GCTRNUM = VCTRNUMBER
    Gosub POPULATE_CTRARRAY
  Else
  #Check if it was still the same
    If GCTRNUM <> VCTRNUMBER
      Gosub POPULATE_CTRARRAY
      GCTRNUM = VCTRNUMBER
    Endif
  Endif

  If dim(GCTRARRAY)<0
    Gosub POPULATE_CTRARRAY
  Endif

  Call PARAM(GCURLEG,"GLMCYCLE",LOCALMENUVALUE) From ADOVAL

  For COUNTER = 1 To maxtab(GCTRARRAY)
    If GCTRARRAY(COUNTER,1) = [0/0/0] : Break : Endif
    If GCTRARRAY(COUNTER,1) = VCTRDAT
      Case LOCALMENUVALUE
        When "1" :
          GLMCYCLEDATE = GCTRARRAY(COUNTER,3)
        When "2" :
          GLMCYCLEDATE = GCTRARRAY(COUNTER,1)
        When Default :
          GLMCYCLEDATE = GCTRARRAY(COUNTER,3)
      Endcase
    Endif
  Next
End GLMCYCLEDATE

Subprog KILL_GLM_GLOBALS
  If dim(GCTRNUM) > 0
    Kill GCTRNUM
  Endif
  If dim(GCTRARRAY) > 0
    Kill GCTRARRAY
  Endif
End

