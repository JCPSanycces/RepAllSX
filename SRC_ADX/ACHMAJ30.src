#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
# ACHMAJ30 : Mises à jour à effectuer lors du passage à la v6    Module achats #
# ---------------------------------------------------------------------------- #
################################################################################


################################################################################
# Moulinettes avec anciens et nouveaux champs màj concernant le module Achat   #
################################################################################
Subprog AACHMAJ30
If filinfo(filpath("FIL","PURTRS",      "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PFOOTINV",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PORDER",      "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PORDERQ",     "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PORDERP",     "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PORDERC",     "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","UPORDER",     "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","UPORDERQ",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","UPORDERP",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","UPORDERC",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PINVOICE",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PINVOICEV",   "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PINVOICED",   "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PQUOTAT",     "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PQUOTATD",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PQUOTATF",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PRESP",       "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PRESPD",      "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PREQUIS",     "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PREQUISD",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PRECEIPT",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PRECEIPTD",   "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PRETURN",     "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","PRETURND",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","BPSUPPLIER",  "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","GACCOUNT",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","GAUTACE",     "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","GAUTACED",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","GAUTACEF",    "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
If filinfo(filpath("FIL","TABVAC",      "fde",[F:ADS]DOSSIER),0) < 0  End : Endif
#----- Définition et chargement des GLONxx et GACTxx nécessaires aux moulinettes achats -----#
Local File =[F:ADS]DOSSIER+".ATYPE" [ATY]
Local File =[F:ADS]DOSSIER+".ACTIV" [ACV]
#-----
If dim(GLONAOB)<1  Global Shortint GLONAOB : Endif
If dim(GLONAMK)<1  Global Shortint GLONAMK : Endif
If dim(GLONAVA)<1  Global Shortint GLONAVA : Endif
If dim(GLONADI)<1  Global Shortint GLONADI : Endif
If dim(GLONAWR)<1  Global Shortint GLONAWR : Endif
If dim(GLONAUS)<1  Global Shortint GLONAUS : Endif
If dim(GLONLAN)<1  Global Shortint GLONLAN : Endif
If dim(GLONCPY)<1  Global Shortint GLONCPY : Endif
If dim(GLONFCY)<1  Global Shortint GLONFCY : Endif
If dim(GLONCUR)<1  Global Shortint GLONCUR : Endif
If dim(GLONUOM)<1  Global Shortint GLONUOM : Endif
If dim(GLONGAC)<1  Global Shortint GLONGAC : Endif
If dim(GLONCOA)<1  Global Shortint GLONCOA : Endif
If dim(GLONVCR)<1  Global Shortint GLONVCR : Endif
If dim(GLONPQH)<1  Global Shortint GLONPQH : Endif
If dim(GLONPSH)<1  Global Shortint GLONPSH : Endif
If dim(GLONPOH)<1  Global Shortint GLONPOH : Endif
If dim(GLONPTH)<1  Global Shortint GLONPTH : Endif
If dim(GLONPNH)<1  Global Shortint GLONPNH : Endif
If dim(GLONPIH)<1  Global Shortint GLONPIH : Endif
If dim(GLONBPR)<1  Global Shortint GLONBPR : Endif
If dim(GLONBPS)<1  Global Shortint GLONBPS : Endif
If dim(GLONITM)<1  Global Shortint GLONITM : Endif
If dim(GACTDEB)<1  Global Libelle  GACTDEB : Endif
If dim(GACTSAD)<1  Global Libelle  GACTSAD : Endif
#-----
Read [ATY] CODTYP="AOB"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3  : Endif
GLONAOB=[F:ATY]LNGTYP
Read [ATY] CODTYP="AMK"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=10 : Endif
GLONAMK=[F:ATY]LNGTYP
Read [ATY] CODTYP="AVA"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=10 : Endif
GLONAVA=[F:ATY]LNGTYP
Read [ATY] CODTYP="ADI"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3  : Endif
GLONADI=[F:ATY]LNGTYP
Read [ATY] CODTYP="AWR"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=10 : Endif
GLONAWR=[F:ATY]LNGTYP
Read [ATY] CODTYP="AUS"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=5  : Endif
GLONAUS=[F:ATY]LNGTYP
Read [ATY] CODTYP="LAN"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3  : Endif
GLONLAN=[F:ATY]LNGTYP
Read [ATY] CODTYP="CPY"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=5  : Endif
GLONCPY=[F:ATY]LNGTYP
Read [ATY] CODTYP="FCY"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=5  : Endif
GLONFCY=[F:ATY]LNGTYP
Read [ATY] CODTYP="CUR"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3  : Endif
GLONCUR=[F:ATY]LNGTYP
Read [ATY] CODTYP="UOM"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3  : Endif
GLONUOM=[F:ATY]LNGTYP
Read [ATY] CODTYP="GAC"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=15 : Endif
GLONGAC=[F:ATY]LNGTYP
Read [ATY] CODTYP="COA"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3  : Endif
GLONCOA=[F:ATY]LNGTYP
Read [ATY] CODTYP="VCR"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=15 : Endif
GLONVCR=[F:ATY]LNGTYP
Read [ATY] CODTYP="PQH"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=15 : Endif
GLONPQH=[F:ATY]LNGTYP
Read [ATY] CODTYP="PSH"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=15 : Endif
GLONPSH=[F:ATY]LNGTYP
Read [ATY] CODTYP="POH"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=15 : Endif
GLONPOH=[F:ATY]LNGTYP
Read [ATY] CODTYP="PTH"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=15 : Endif
GLONPTH=[F:ATY]LNGTYP
Read [ATY] CODTYP="PNH"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=15 : Endif
GLONPNH=[F:ATY]LNGTYP
Read [ATY] CODTYP="PIH"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=15 : Endif
GLONPIH=[F:ATY]LNGTYP
Read [ATY] CODTYP="BPR"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=10 : Endif
GLONBPR=[F:ATY]LNGTYP
Read [ATY] CODTYP="BPS"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=10 : Endif
GLONBPS=[F:ATY]LNGTYP
Read [ATY] CODTYP="ITM"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=20 : Endif
GLONITM=[F:ATY]LNGTYP
#----- Code activité "SAD" Stockage systématique des adresses -----#
Read [ACV] CODACT="SAD"
If !fstat
  GACTSAD=[F:ACV]FLACT
Else
  GACTSAD=1
Endif
#----- Code activité "DEB" Déclaration échange de biens CEE -----#
Read [ACV] CODACT="DEB"
If !fstat
  GACTDEB=[F:ACV]FLACT
Else
  GACTDEB=2
Endif
#-----
# Issue 74485 - 2011-06-20 by VPO : lecture des codes activité : garder ACV ouverte
# Close Local File [ATY], [ACV]
Close Local File [ATY]
#-----
Gosub SET_FIRST   From TRTFIRST
Gosub AV_AWR                : # Reprise des paramétrages de signature (règles d'affectation)
# Issue 74060 - 2011-10-11 by VPO : cf UUMGTRTPUR42
# Gosub AV_AWV                : # Reprise des règles de signature (valeurs de règle)
# Issue 74060 - 2011-10-11 by VPO : cf UUMGTRTPUR43
# Gosub AV_AWS                : # Reprise des signatures (historique suivi workflow)
# Issue 74060 - 2011-10-11 by VPO : cf UUMGTRTPUR44
# Gosub AV_DEL                : # Suppression des fenêtres, écrans et traitements anciennes signatures
Gosub AV_TRS                : # Alimentation des nouveaux champs dans les transactions de saisie
Gosub AV_PFI                : # Alimentation des nouveaux champs dans les éléments de facturation
# Issue 74060 - 2011-10-11 by VPO : cf UUMGTRTPUR02,UUMGTRTPUR03
# Gosub AV_POH From ACH1MAJ30 : # Alimentation des nouveaux champs dans les commandes d'achat
# Issue 74060 - 2011-10-11 by VPO : cf UUMGTRTPUR04,UUMGTRTPUR05
# Gosub AV_UOH From ACH1MAJ30 : # Alimentation des nouveaux champs dans les historiques commandes
# Issue 74060 - 2011-10-11 by VPO : cf UUMGTRTPUR08
# Gosub AV_PIH                : # Alimentation des nouveaux champs dans les factures d'achat
Gosub AV_PQH                : # Alimentation des nouveaux champs dans les appels d'offre
# Issue 74060 - 2011-10-11 by VPO : cf UUMGTRTPUR01
# Gosub AV_PSH                : # Alimentation des nouveaux champs dans les demandes d'achat
# Issue 74060 - 2011-10-11 by VPO : cf UUMGTRTPUR06
# Gosub AV_PTH From ACH2MAJ30 : # Alimentation des nouveaux champs dans les réceptions
# Issue 74060 - 2011-10-11 by VPO : cf UUMGTRTPUR07
# Gosub AV_PNH                : # Alimentation des nouveaux champs dans les retours
#----- Réajustement valeurs par défaut de l'état BONRCP -----#
Call UTI_MOUL([F:ADS]DOSSIER) From UTIACH21
#----- Màj du numéro d'engagement sur lignes de facture -----#
# Issue 74060 - 2011-10-11 by VPO : cf UUMGTRTPUR08
# Call UTI_MOUL([F:ADS]DOSSIER) From UTIACH23
#-----
Gosub UNSET_FIRST From TRTFIRST
End


################################################################################
# Moulinettes avec champs version v6 uniquement màj concernant le module Achat #
################################################################################
Subprog ACHMAJ30
End


#--------------------------------------------------------------#
# Reprise des paramétrages de signature (règles d'affectation) #
# ------------------------------------------------------------ #
# Table AWRKREG - Règles d'affectation                         #
#   Chargement de cette nouvelle table à partir de PAPPCONF    #
#--------------------------------------------------------------#
$AV_AWR
#----- Si la table n'existe plus, la reprise a déjà été effectuée -----#
If filinfo(filpath("FIL","PAPPCONF","fde",[F:ADS]DOSSIER),0)<0  Return : Endif
#----- Copie des règles de Workflow à partir du dossier de référence -----#
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","POCSIG","","","")    From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","POCSIGCAN","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","POCSIGNCR","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","POCSIGNOT","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","POCSIGREJ","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","POCSIGVAL","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","POHSIG","","","")    From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","POHSIGCAN","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","POHSIGNCR","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","POHSIGNOT","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","POHSIGREJ","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","POHSIGVAL","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","PSDSIG","","","")    From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","PSDSIGCAN","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","PSDSIGNCR","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","PSDSIGNOT","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","PSDSIGREJ","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","PSDSIGVAL","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","PSHSIG","","","")    From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","PSHSIGCAN","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","PSHSIGNCR","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","PSHSIGNOT","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","PSHSIGREJ","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","PSHSIGVAL","","","") From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","VALPIH","","","")    From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWA","VALPNH","","","")    From ACOPIE
#----- Copie des règles d'affectation à partir du dossier de référence -----#
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWR","POCSIG","","","")    From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWR","POHSIG","","","")    From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWR","PSDSIG","","","")    From ACOPIE
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWR","PSHSIG","","","")    From ACOPIE
#----- Copie du plan de travail à partir du dossier de référence -----#
Call COPOBJ([F:ADS]DOSREF,[F:ADS]DOSSIER,"AWW","PUR","","","")       From ACOPIE
#-----
Local File =[F:ADS]DOSSIER+".PAPPCONF"  [PAC]
Local File =[F:ADS]DOSSIER+".AWRKLNK"   [AWM]
Local File =[F:ADS]DOSSIER+".AWRKREG"   [AWR]
Local File =[F:ADS]DOSSIER+".ADOVAL"    [ADW]
Local File =[F:ADS]DOSSIER+".ADOPAR"    [ADP]
Local File =[F:ADS]DOSSIER+".ATEXTRA"   [AXX]
Local File =[F:ADS]DOSSIER+".ATABZON"   [ATZ]
#-----
Local Char     WPARAME(10), SAV_GLANGUE(GLONLAN)
Local Integer  WNBR
Local Integer  I
SAV_GLANGUE=GLANGUE
GLANGUE="FRA"
#-----
Raz WNBR
Call ECR_TIME("DOSMAJ30 Approval Assignment rules Process 1 : Write AWRKREG") From DOSSUB
Look [AWM] AWM0="PREQUIS"
If fstat
  Raz [F:AWM]
  [F:AWM]MODELE   ="PREQUIS"
  [F:AWM]ENAFLG   =2
  [F:AWM]MODULE   =6
  [F:AWM]TABREF   ="PREQUIS"
  [F:AWM]NBRLNK   =5
  [F:AWM]TABLNK(0)="PREQUISD"
  [F:AWM]TABLNK(1)="BPSUPPLIER"
  [F:AWM]TABLNK(2)="ITMMASTER"
  [F:AWM]TABLNK(3)="ITMBPS"
  [F:AWM]TABLNK(4)="CPTANALIN"
  [F:AWM]TABORI(0)="PREQUIS"
  [F:AWM]TABORI(1)="PREQUISD"
  [F:AWM]TABORI(2)="PREQUISD"
  [F:AWM]TABORI(3)="PREQUISD"
  [F:AWM]TABORI(4)="PREQUISD"
  [F:AWM]ABRLNK(0)="PSD"
  [F:AWM]ABRLNK(1)="BPS"
  [F:AWM]ABRLNK(2)="ITM"
  [F:AWM]ABRLNK(3)="ITP"
  [F:AWM]ABRLNK(4)="CAL"
  [F:AWM]TYPLNK(0)=2
  [F:AWM]TYPLNK(1)=1
  [F:AWM]TYPLNK(2)=1
  [F:AWM]TYPLNK(3)=1
  [F:AWM]TYPLNK(4)=1
  [F:AWM]CLELNK(0)="PSD0"
  [F:AWM]CLELNK(1)="BPS0"
  [F:AWM]CLELNK(2)="ITM0"
  [F:AWM]CLELNK(3)="ITP0"
  [F:AWM]CLELNK(4)="CAL0"
  [F:AWM]EXPLNK(0)="[F:PSH]PSHNUM"
  [F:AWM]EXPLNK(1)="[F:PSD]BPSNUM"
  [F:AWM]EXPLNK(2)="[F:PSD]ITMREF"
  [F:AWM]EXPLNK(3)="[F:PSD]ITMREF;[F:PSD]BPSNUM"
  [F:AWM]EXPLNK(4)='"PSD";0;[F:PSD]PSHNUM";[F:PSD]PSDLIN;0;"";1'
  [F:AWM]FLDFCY   ="[F:PSH]PSHFCY"
 #[F:AWM]FLDDAT   ="[F:PSH]PRQDAT" : # Champs supprimé de la table AWRKLNK !
  [F:AWM]CREUSR   ="ADMIN"
  [F:AWM]CREDAT   =date$
  [F:AWM]CRETIM   =0
  Write [AWM]
  If fstat
    Call ECR_TRACE("File AWRKLNK PREQUIS, Error ="-num$(fstat),1) From GESECRAN
  Endif
  Call MAJTEXTRA ("Demandes d'achat","AWRKLNK","INTIT",[F:AWM]MODELE,"") From ATEXTRA
  If GOK<1
    Call ECR_TRACE("File ATEXTRA AWRKLNK INTIT FRA PREQUIS, Error ="-num$(fstat),1) From GESECRAN
    GOK=1
  Endif
Endif
Delete [AWR] Where REGLE="PSDSIG" & CRETIM=0 & UPDTIM=0
If fstat
  Call ECR_TRACE("File AWRKREG PSDSIG, Error ="-num$(fstat),1) From GESECRAN
Endif

# Issue 74060 - 2011-10-11 by VPO : cf UUMGTRTPUR41
Goto FIN_AWRPSH

Filter [AWR] Where REGLE="PSDSIG" & CPY<>""
Look [AWR] AWR1 First
Filter [AWR]
If !fstat  Goto FIN_AWRPSH : Endif
Trbegin [AWR]
  For [PAC] PAC1 Where APPRUL=1 & CPY<>""
    Raz [F:AWR]
    [F:AWR]=[F:PAC]
    [F:AWR]REGLE="PSDSIG"
    [F:AWR]MODELE="PREQUIS"
    [F:AWR]TABLIG="PREQUISD"
    Call PARAM([F:PAC]CPY,"PSHAPPNBR",WPARAME) From ADOVAL
    [F:AWR]NBRUSR=val(WPARAME)
    For I=0 To 4
      If [F:PAC]FIL(I)<>""
        [F:AWR]TABFLD(I)=[F:PAC]FIL(I)
        [F:AWR]OPEFLD(I)=8
        [F:AWR]EXPFLD(I)="[F:"+[F:PAC]ABB(I)+"]"+[F:PAC]FLD(I)
        [F:AWR]INTFLD(I)='"'+[F:PAC]CRIDES(I)+'"'
        [F:AWR]TYPFLD(I)=[F:PAC]FLDTYP(I)
        [F:AWR]LNGFLD(I)=[F:PAC]CRILEN(I)
        [F:AWR]LIBFLD(I)=[F:PAC]PPUMNU(I)
        Read [ATZ] CODZONE=[F:PAC]FIL(I);[F:PAC]FLD(I)
        If !fstat & ([F:ATZ]DIME>1 | [F:ATZ]CODACT<>"")
          [F:AWR]EXPFLD(I)+="("+num$([F:PAC]CRIIND(I))+")"
        Endif
        [F:AWR]NBRFLD+=1
      Else
        Break
      Endif
    Next I
    I=[F:AWR]NBRFLD
    [F:AWR]TABFLD(I)="PREQUISD"
    [F:AWR]OPEFLD(I)=7
    [F:AWR]EXPFLD(I)="func TRTX3FNC.CNVCPY([F:PSD]PSHFCY,[F:PSD]CUR,[F:PSD]CHGTYP,datesyst,[F:PSD]LINAMT)"
    [F:AWR]INTFLD(I)='"Valeur maximum"'
    [F:AWR]TYPFLD(I)="DCB"
    [F:AWR]LNGFLD(I)=11.2
    [F:AWR]NBRFLD+=1
    Call PARAM([F:PAC]CPY,"PSHFBUCIR",WPARAME) From ADOVAL
    If val(WPARAME)=2
      I=[F:AWR]NBRFLD
      [F:AWR]TABFLD(I)="PREQUISD"
      [F:AWR]OPEFLD(I)=2
      [F:AWR]EXPFLD(I)="[F:PSD]FBUFLG"
      [F:AWR]INTFLD(I)='"Dépassement budgétaire"'
      [F:AWR]TYPFLD(I)="M"
      [F:AWR]LIBFLD(I)=1
      [F:AWR]NBRFLD+=1
    Endif
    Write [AWR]
    If fstat
      Call ECR_TRACE("File AWRKREG"-[F:AWR]CPY-"PSDSIG, Error ="-num$(fstat),1) From GESECRAN
    Endif
    Call MAJTEXTRA ("Signature demandes d'achat","AWRKREG","INTIT",[F:AWR]REGLE,[F:AWR]CPY) From ATEXTRA
    If GOK<1
      Call ECR_TRACE("File ATEXTRA AWRKREG INTIT FRA PSDSIG, Error ="-num$(fstat),1) From GESECRAN
      GOK=1
    Endif
    WNBR+=1
  Next
Commit
$FIN_AWRPSH
Call ECR_TIME("DOSMAJ30 Approval Assignment rules Process 1 : Ended ("+num$(WNBR)+")") From DOSSUB
#-----
Raz WNBR
Call ECR_TIME("DOSMAJ30 Approval Assignment rules Process 2 : Write AWRKREG") From DOSSUB
Look [AWM] AWM0="PORDER"
If fstat
  Raz [F:AWM]
  [F:AWM]MODELE   ="PORDER"
  [F:AWM]ENAFLG   =2
  [F:AWM]MODULE   =6
  [F:AWM]TABREF   ="PORDER"
  [F:AWM]NBRLNK   =2
  [F:AWM]TABLNK(0)="BPSUPPLIER"
  [F:AWM]TABLNK(1)="AUTILIS"
  [F:AWM]TABORI(0)="PORDER"
  [F:AWM]TABORI(1)="PORDER"
  [F:AWM]ABRLNK(0)="BPS"
  [F:AWM]ABRLNK(1)="AUS"
  [F:AWM]TYPLNK(0)=1
  [F:AWM]TYPLNK(1)=1
  [F:AWM]CLELNK(0)="BPS0"
  [F:AWM]CLELNK(1)="CODUSR"
  [F:AWM]EXPLNK(0)="[F:POH]BPSNUM"
  [F:AWM]EXPLNK(1)="[F:POH]BUY"
  [F:AWM]FLDFCY   ="[F:POH]POHFCY"
 #[F:AWM]FLDDAT   ="[F:POH]ORDDAT" : # Champs supprimé de la table AWRKLNK !
  [F:AWM]CREUSR   ="ADMIN"
  [F:AWM]CREDAT   =date$
  [F:AWM]CRETIM   =0
  Write [AWM]
  If fstat
    Call ECR_TRACE("File AWRKLNK PORDER, Error ="-num$(fstat),1) From GESECRAN
  Endif
  Call MAJTEXTRA ("Commandes d'achat","AWRKLNK","INTIT",[F:AWM]MODELE,"") From ATEXTRA
  If GOK<1
    Call ECR_TRACE("File ATEXTRA AWRKLNK INTIT FRA PORDER, Error ="-num$(fstat),1) From GESECRAN
    GOK=1
  Endif
Endif
Delete [AWR] Where REGLE="POHSIG" & CRETIM=0 & UPDTIM=0
If fstat
  Call ECR_TRACE("File AWRKREG POHSIG, Error ="-num$(fstat),1) From GESECRAN
Endif

# Issue 74060 - 2011-10-11 by VPO : cf UUMGTRTPUR41
Goto FIN_AWRPOH

Filter [AWR] Where REGLE="POHSIG" & CPY<>""
Look [AWR] AWR1 First
Filter [AWR]
If !fstat  Goto FIN_AWRPOH : Endif
Trbegin [AWR]
  For [PAC] PAC1 Where APPRUL=2 & CPY<>""
    Raz [F:AWR]
    [F:AWR]=[F:PAC]
    [F:AWR]REGLE="POHSIG"
    [F:AWR]MODELE="PORDER"
    Call PARAM([F:PAC]CPY,"POHAPPNBR",WPARAME) From ADOVAL
    [F:AWR]NBRUSR=val(WPARAME)
    For I=0 To 4
      If [F:PAC]FIL(I)<>""
        [F:AWR]TABFLD(I)=[F:PAC]FIL(I)
        [F:AWR]OPEFLD(I)=8
        [F:AWR]EXPFLD(I)="[F:"+[F:PAC]ABB(I)+"]"+[F:PAC]FLD(I)
        [F:AWR]INTFLD(I)='"'+[F:PAC]CRIDES(I)+'"'
        [F:AWR]TYPFLD(I)=[F:PAC]FLDTYP(I)
        [F:AWR]LNGFLD(I)=[F:PAC]CRILEN(I)
        [F:AWR]LIBFLD(I)=[F:PAC]PPUMNU(I)
        Read [ATZ] CODZONE=[F:PAC]FIL(I);[F:PAC]FLD(I)
        If !fstat & ([F:ATZ]DIME>1 | [F:ATZ]CODACT<>"")
          [F:AWR]EXPFLD(I)+="("+num$([F:PAC]CRIIND(I))+")"
        Endif
        [F:AWR]NBRFLD+=1
      Else
        Break
      Endif
    Next I
    I=[F:AWR]NBRFLD
    [F:AWR]TABFLD(I)="PORDER"
    [F:AWR]OPEFLD(I)=7
    [F:AWR]EXPFLD(I)="func TRTX3FNC.CNVCPY([F:POH]POHFCY,[F:POH]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,[F:POH]TOTORD)"
    [F:AWR]INTFLD(I)='"Valeur maximum"'
    [F:AWR]TYPFLD(I)="DCB"
    [F:AWR]LNGFLD(I)=11.2
    [F:AWR]NBRFLD+=1
    Call PARAM([F:PAC]CPY,"POHFBUCIR",WPARAME) From ADOVAL
    If val(WPARAME)=2
      I=[F:AWR]NBRFLD
      [F:AWR]TABFLD(I)="PORDER"
      [F:AWR]OPEFLD(I)=2
      [F:AWR]EXPFLD(I)="[F:POH]FBULINNBR>0"
      [F:AWR]INTFLD(I)='"Dépassement budgétaire"'
      [F:AWR]TYPFLD(I)="M"
      [F:AWR]LIBFLD(I)=1
      [F:AWR]NBRFLD+=1
    Endif
    Write [AWR]
    If fstat
      Call ECR_TRACE("File AWRKREG"-[F:AWR]CPY-"POHSIG, Error ="-num$(fstat),1) From GESECRAN
    Endif
    Call MAJTEXTRA ("Signature commandes d'achat","AWRKREG","INTIT",[F:AWR]REGLE,[F:AWR]CPY) From ATEXTRA
    If GOK<1
      Call ECR_TRACE("File ATEXTRA AWRKREG INTIT FRA POHSIG, Error ="-num$(fstat),1) From GESECRAN
      GOK=1
    Endif
    WNBR+=1
  Next
Commit
$FIN_AWRPOH
Call ECR_TIME("DOSMAJ30 Approval Assignment rules Process 2 : Ended ("+num$(WNBR)+")") From DOSSUB
#-----
Raz WNBR
Call ECR_TIME("DOSMAJ30 Approval Assignment rules Process 3 : Write AWRKREG") From DOSSUB
Delete [AWR] Where REGLE="POCSIG" & CRETIM=0 & UPDTIM=0
If fstat
  Call ECR_TRACE("File AWRKREG POCSIG, Error ="-num$(fstat),1) From GESECRAN
Endif

# Issue 74060 - 2011-10-11 by VPO : cf UUMGTRTPUR41
Goto FIN_AWRPOC

Filter [AWR] Where REGLE="POCSIG" & CPY<>""
Look [AWR] AWR1 First
Filter [AWR]
If !fstat  Goto FIN_AWRPOC : Endif
Trbegin [AWR]
  For [PAC] PAC1 Where APPRUL=3 & CPY<>""
    Raz [F:AWR]
    [F:AWR]=[F:PAC]
    [F:AWR]REGLE="POCSIG"
    [F:AWR]MODELE="PORDER"
    Call PARAM([F:PAC]CPY,"POCAPPNBR",WPARAME) From ADOVAL
    [F:AWR]NBRUSR=val(WPARAME)
    For I=0 To 4
      If [F:PAC]FIL(I)<>""
        [F:AWR]TABFLD(I)=[F:PAC]FIL(I)
        [F:AWR]OPEFLD(I)=8
        [F:AWR]EXPFLD(I)="[F:"+[F:PAC]ABB(I)+"]"+[F:PAC]FLD(I)
        [F:AWR]INTFLD(I)='"'+[F:PAC]CRIDES(I)+'"'
        [F:AWR]TYPFLD(I)=[F:PAC]FLDTYP(I)
        [F:AWR]LNGFLD(I)=[F:PAC]CRILEN(I)
        [F:AWR]LIBFLD(I)=[F:PAC]PPUMNU(I)
        Read [ATZ] CODZONE=[F:PAC]FIL(I);[F:PAC]FLD(I)
        If !fstat & ([F:ATZ]DIME>1 | [F:ATZ]CODACT<>"")
          [F:AWR]EXPFLD(I)+="("+num$([F:PAC]CRIIND(I))+")"
        Endif
        [F:AWR]NBRFLD+=1
      Else
        Break
      Endif
    Next I
    I=[F:AWR]NBRFLD
    [F:AWR]TABFLD(I)="PORDER"
    [F:AWR]OPEFLD(I)=7
    [F:AWR]EXPFLD(I)="func TRTX3FNC.CNVCPY([F:POH]POHFCY,[F:POH]CUR,[F:POH]CHGTYP,GHIDATE,[F:POH]TOTVLT)"
    [F:AWR]INTFLD(I)='"Valeur maximum"'
    [F:AWR]TYPFLD(I)="DCB"
    [F:AWR]LNGFLD(I)=11.2
    [F:AWR]NBRFLD+=1
    Write [AWR]
    If fstat
      Call ECR_TRACE("File AWRKREG"-[F:AWR]CPY-"POCSIG, Error ="-num$(fstat),1) From GESECRAN
    Endif
    Call MAJTEXTRA ("Signature contrats d'achat","AWRKREG","INTIT",[F:AWR]REGLE,[F:AWR]CPY) From ATEXTRA
    If GOK<1
      Call ECR_TRACE("File ATEXTRA AWRKREG INTIT FRA POCSIG, Error ="-num$(fstat),1) From GESECRAN
      GOK=1
    Endif
    WNBR+=1
  Next
Commit
$FIN_AWRPOC
Call ECR_TIME("DOSMAJ30 Approval Assignment rules Process 3 : Ended ("+num$(WNBR)+")") From DOSSUB
#-----
GLANGUE=SAV_GLANGUE
Close Local File [PAC], [AWM], [AWR], [ADW], [ADP], [AXX], [ATZ]
Return


#------------------------------------------------------------#
# Reprise des règles de signature (valeurs de règle)         #
# Reprise des suppléants (utilisateurs délégués)             #
# ---------------------------------------------------------- #
# Table AWRKREGVAL - Valeurs de règle                        #
#   Chargement de cette nouvelle table à partir de PAPPROVAL #
# Table AWRKUSR - Utilisateurs délégués                      #
#   Chargement de cette nouvelle table à partir de PAPPROVAL #
#------------------------------------------------------------#
$AV_AWV
#----- Si les tables n'existent plus, la reprise a déjà été effectuée -----#
If filinfo(filpath("FIL","PAPPROVAL","fde",[F:ADS]DOSSIER),0)<0  Return : Endif
If filinfo(filpath("FIL","PAPPCONF" ,"fde",[F:ADS]DOSSIER),0)<0  Return : Endif
#-----
Local File =[F:ADS]DOSSIER+".PAPPROVAL" [PAP]
Local File =[F:ADS]DOSSIER+".PAPPCONF"  [PAC]
Local File =[F:ADS]DOSSIER+".AWRKREGVAL"[AWV]
Local File =[F:ADS]DOSSIER+".AWRKUSR"   [AWU]
#-----
Local Char     CLE1(GLONCPY), CRITERE(30)
Local Integer  CLE2, COMPTEUR, STOP, WNBR
Local Char     RUPTURE(GLONAWR+GLONCPY+1), WREGLE(GLONAWR), WCPY(GLONCPY)
Local Char     WUSER(GLONAUS), WUSRDEL(GLONAUS)
Local Integer  WNUMLIG, I, J, K
#-----
Raz CLE1, CLE2, STOP, WNBR, RUPTURE, WNUMLIG
Call ECR_TIME("DOSMAJ30 Approval rule's values Process 1 : Write AWRKREGVAL") From DOSSUB
$BOUCLE_PAP
If STOP=1
  CRITERE='CPY="'+CLE1+'" & APPRUL>'+num$(CLE2)
  STOP=2
Elsif STOP=2
  CRITERE='CPY>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [AWV]
  For [PAP] PAP0 Where evalue(CRITERE)
    If [F:PAC]CPY<>[F:PAP]CPY | [F:PAC]APPRUL<>[F:PAP]APPRUL
      Read [PAC] PAC0=[F:PAP]CPY;[F:PAP]APPRUL
      If fstat  Raz [F:PAC] : Endif
    Endif
    Case [F:PAP]APPRUL
      When 1 : WREGLE="PSDSIG"
      When 2 : WREGLE="POHSIG"
      When 3 : WREGLE="POCSIG"
    Endcase
    WCPY=[F:PAP]CPY
    If RUPTURE=""
      RUPTURE=WREGLE+"~"+WCPY
    Endif
    If RUPTURE<>WREGLE+"~"+WCPY
      Raz WNUMLIG
    Endif
    WNUMLIG+=1
    Look [AWV] AWV0=WREGLE;WCPY;WNUMLIG
    If fstat
      Raz [F:AWV]
      [F:AWV]REGLE =WREGLE
      [F:AWV]CPY   =WCPY
      [F:AWV]NUMLIG=WNUMLIG
      For I=0 To dim([F:AWV]USER)-1
        If evalue("[F:PAP]SAPFLG"+num$(I+1))<>1
          WUSER  =evalue("[F:PAP]APPUSR"+num$(I+1))
          WUSRDEL=evalue("[F:PAP]SBSAPPUSR"+num$(I+1))
        Else
          WUSER  =evalue("[F:PAP]SBSAPPUSR"+num$(I+1))
          WUSRDEL=evalue("[F:PAP]APPUSR"+num$(I+1))
        Endif
        [F:AWV]USER(I)=WUSER
        If WUSRDEL<>""
          Filter [AWU] Where USER=WUSER & USRDEL=WUSRDEL
          Read [AWU] AWU0 First
          If fstat
            Filter [AWU] Where USER=WUSER
            Read [AWU] AWU0 Last : If fstat  Raz [F:AWU] : Endif
            Filter [AWU]
            If [F:AWU]NUMDEL<99
              [F:AWU]USER=WUSER
              [F:AWU]NUMDEL+=1
              [F:AWU]USRDEL=WUSRDEL
              [F:AWU]TYPDEL=2
              Raz [F:AWU]NATURE, [F:AWU]VLYSTR, [F:AWU]VLYEND
              COMPTEUR+=1
              Write [AWU]
              If fstat
                Call ECR_TRACE("File AWRKUSR"-WUSER+", ERROR ="-num$(fstat),1) From GESECRAN
              Endif
            Endif
          Else
            Filter [AWU]
          Endif
        Endif
      Next I
      I=1 : J=1 : K=0
      If [F:PAC]FIL(0)<>""
        While J>0
          J=instr(I,[F:PAP]APPCRI,"~")
          If J>I
            [F:AWV]VALREG(K)=mid$([F:PAP]APPCRI,I,J-I) : K+=1
          Else J=I
            [F:AWV]VALREG(K)="*" : K+=1
          Endif
          I=J+1
          If K>4 | [F:PAC]FIL(K)=""  J=0 : Endif
        Wend
      Endif
      [F:AWV]VALREG(K)=num$([F:PAP]MAXVAL) : K+=1
      If [F:PAP]FBUFLG>0
        [F:AWV]VALREG(K)=num$([F:PAP]FBUFLG) : K+=1
      Endif
      COMPTEUR+=1
      Write [AWV]
      If fstat
        Call ECR_TRACE("File AWRKREGVAL"-WREGLE-WCPY-num$(WNUMLIG)+", ERROR ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    RUPTURE=WREGLE+"~"+WCPY
    WNBR+=1
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PAP]CPY : CLE2=[F:PAP]APPRUL : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PAP : Endif
#-----
Close Local File [PAP], [PAC], [AWV], [AWU]
Call ECR_TIME("DOSMAJ30 Approval rule's values Process 1 : Ended ("+num$(WNBR)+")") From DOSSUB
Return


#--------------------------------------------------------------------#
# Reprise des enregistrements signatures (historique suivi workflow) #
# ------------------------------------------------------------------ #
# Table AWRKHISSUI - Historique suivi workflow                       #
#   Chargement de cette nouvelle table à partir de PAPPRECORD        #
#--------------------------------------------------------------------#
$AV_AWS
#----- Si les tables n'existent plus, la reprise a déjà été effectuée -----#
If filinfo(filpath("FIL","PAPPROVAL" ,"fde",[F:ADS]DOSSIER),0)<0  Return : Endif
If filinfo(filpath("FIL","PAPPRECORD","fde",[F:ADS]DOSSIER),0)<0  Return : Endif
#-----
Local File =[F:ADS]DOSSIER+".PAPPROVAL"   [PAP]
Local File =[F:ADS]DOSSIER+".PAPPRECORD"  [PAD]
Local File =[F:ADS]DOSSIER+".PAPPRECORD"  [PAD2]
Local File =[F:ADS]DOSSIER+".PREQUISD"    [PSD]
Local File =[F:ADS]DOSSIER+".PORDER"      [POH]
Local File =[F:ADS]DOSSIER+".AWRKHISSUI"  [AWS]
Local File =[F:ADS]DOSSIER+".ACODNUM"     [ANM]
Local File =[F:ADS]DOSSIER+".AVALNUM"     [AVN]
Local File =[F:ADS]DOSSIER+".AUTILIS"     [AUS]
#-----
Local Libelle  WFLAG_WRK,  WFLAG_WRG, WCLEFLG
Local Integer  WCTEUR_WRK, WCTEUR_WRG, WRET
Local Integer  CLE1
Local Char     CLE2(GLONVCR),  CRITERE(30), WOBJ(GLONAOB), WCHRONO_PREC(GLONVCR)
Local Integer  COMPTEUR, STOP, WNBR
Local Char     WRUPTGRP1(GLONVCR+GLONAUS+8), WRUPTGRP2(GLONVCR+GLONAUS+8)
#-----
Raz CLE1, CLE2, STOP, WNBR, WRUPTGRP1, WRUPTGRP2, [F:AWS]
Call ECR_TIME("DOSMAJ30 Workflow monitoring history Process 1 : Write AWRKHISSUI") From DOSSUB
Read [ANM] ANM0="WRK" : If !fstat  WFLAG_WRK=1  Else  WFLAG_WRK=0 : Endif
Read [ANM] ANM0="WRG" : If !fstat  WFLAG_WRG=1  Else  WFLAG_WRG=0 : Endif
$BOUCLE_PAD
If STOP=1
  CRITERE='APPRUL='+num$(CLE1)+' & NUM>"'+CLE2+'"'
  STOP=2
Elsif STOP=2
  CRITERE='APPRUL>'+num$(CLE1)
  STOP=0
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [AWS]
  For [PAD] PAD0 Where evalue(CRITERE) & SAPFLG<2
    If [F:PAD]ENAFLG=2 | [F:PAD]APPDAT<>[0/0/0]
      #----- Traitement du chrono workflow suivi -----#
      If WFLAG_WRK
        Call NUMERO("WRK","",date$,"",[F:AWS]CHRONO,WRET) From SUBANM
        If GOK<1 | WRET<>0
          WRET=0 : GOK=1 : Call ECR_TRACE("WRK"-mess(60,199,1),1) From GESECRAN
          WCTEUR_WRK+=1 : [F:AWS]CHRONO=WCTEUR_WRK
        Endif
      Else
        WCTEUR_WRK+=1 : [F:AWS]CHRONO=WCTEUR_WRK
      Endif
      #----- Traitement du chrono workflow groupe -----#
      If WRUPTGRP1=""  WRUPTGRP1=[F:PAD]APPUSR+[F:PAD]NUM+num$([F:PAD]LIN) : Endif
      WRUPTGRP2=[F:PAD]APPUSR+[F:PAD]NUM+num$([F:PAD]LIN)
      If [F:AWS]NUMGRP="" | WRUPTGRP1<>WRUPTGRP2
        If WFLAG_WRG
          Call NUMERO("WRG","",date$,"",[F:AWS]NUMGRP,WRET) From SUBANM
          If GOK<1 | WRET<>0
            WRET=0 : GOK=1 : Call ECR_TRACE("WRG"-mess(60,199,1),1) From GESECRAN
            WCTEUR_WRG+=1 : [F:AWS]NUMGRP=WCTEUR_WRG
          Endif
        Else
          WCTEUR_WRG+=1 : [F:AWS]NUMGRP=WCTEUR_WRG
        Endif
      Endif
      WRUPTGRP1=WRUPTGRP2
      #-----
      Case [F:PAD]APPRUL
        When 1
          WOBJ="PSH"
          [F:AWS]CLEDEC  =[F:PAD]NUM+"~"+num$([F:PAD]LIN)
          [F:AWS]TEXSUI  ="Purchase request"-[F:PAD]NUM+"/"+num$([F:PAD]LIN)
          [F:AWS]IDENTRET="GESPSH/"+[F:PAD]NUM
          [F:AWS]IDENTGRP="PREQUISD/"+[F:PAD]NUM+"~"+num$([F:PAD]LIN)
          If [F:PSD]PSHNUM<>[F:PAD]NUM | [F:PSD]PSDLIN<>[F:PAD]LIN
            Read [PSD] PSD0=[F:PAD]NUM;[F:PAD]LIN : If fstat  Raz [F:PSD] : Endif
          Endif
          If [F:PSD]LINCLEFLG=2  WCLEFLG=2  Else  WCLEFLG=0 : Endif
        When 2
          WOBJ="POH"
          [F:AWS]CLEDEC  =[F:PAD]NUM
          [F:AWS]TEXSUI  ="Purchase order"-[F:PAD]NUM
          [F:AWS]IDENTRET="GESPOH/"+[F:PAD]NUM
          [F:AWS]IDENTGRP="PORDER/"+[F:PAD]NUM
          If [F:POH]POHNUM<>[F:PAD]NUM
            Read [POH] POH0=[F:PAD]NUM : If fstat  Raz [F:POH] : Endif
          Endif
          If [F:POH]CLEFLG=2  WCLEFLG=2  Else  WCLEFLG=0 : Endif
        When 3
          WOBJ="POC"
          [F:AWS]CLEDEC  =[F:PAD]NUM
          [F:AWS]TEXSUI  ="Supplier contract"-[F:PAD]NUM
          [F:AWS]IDENTRET="GESPOC/"+[F:PAD]NUM
          [F:AWS]IDENTGRP="PORDER/"+[F:PAD]NUM
          If [F:POH]POHNUM<>[F:PAD]NUM
            Read [POH] POH0=[F:PAD]NUM : If fstat  Raz [F:POH] : Endif
          Endif
          If [F:POH]CLEFLG=2  WCLEFLG=2  Else  WCLEFLG=0 : Endif
      Endcase
      If [F:PAD]SAPFLG<>1
        [F:AWS]DEST=[F:PAD]APPUSR
      Else
        [F:AWS]DEST=[F:PAD]SBSAPPUSR
      Endif
      If [F:AUS]USR<>[F:AWS]DEST
        Read [AUS] CODUSR=[F:AWS]DEST : If fstat  Raz [F:AUS] : Endif
      Endif
      [F:AWS]EMAIL  =[F:AUS]ADDEML
      [F:AWS]CPY    =[F:PAD]CPY
      [F:AWS]LEVSIG =[F:PAD]APPLEV-1
      [F:AWS]DELEGUE=1
      [F:AWS]ENVOI  =2
      [F:AWS]USRTOP =[F:AWS]DEST
      If [F:PAD]ENAFLG<>2 & [F:PAD]APPDAT<>[0/0/0]
        [F:AWS]ACTSIG="VAL"
        [F:AWS]FLGSIG=5
        [F:AWS]USRSIG=[F:AWS]DEST
        [F:AWS]MAISIG=[F:AWS]EMAIL
        [F:AWS]DATSIG=[F:PAD]APPDAT
      Else
        [F:AWS]FLGSIG=3-WCLEFLG
        [F:AWS]ACTSIG=""
        [F:AWS]USRSIG=""
        [F:AWS]MAISIG=""
        [F:AWS]DATSIG=[0/0/0]
      Endif
      If [F:AWS]LEVSIG=0
        Case [F:PAD]APPRUL
          When 1
            [F:AWS]EMETTEUR =[F:PSD]CREUSR
            [F:AWS]DATENV   =[F:PSD]CREDAT
            [F:AWS]IDENTREF ="PREQUIS/"+[F:PAD]NUM
            [F:AWS]CONTXT   ="GESPSH/1/PSH/C/"+[F:PAD]NUM
          When 2,3
            [F:AWS]EMETTEUR =[F:POH]CREUSR
            [F:AWS]DATENV   =[F:POH]CREDAT
            [F:AWS]IDENTREF ="PORDER/"+[F:PAD]NUM
            If [F:PAD]APPRUL=2
              [F:AWS]CONTXT ="GESPOH/1/POH/C/"+[F:PAD]NUM
            Else
              [F:AWS]CONTXT ="GESPOC/1/POC/C/"+[F:PAD]NUM
            Endif
        Endcase
        [F:AWS]ABROBJ   =WOBJ
        [F:AWS]CODEVT   =WOBJ
        [F:AWS]TYPEVT   =2
        [F:AWS]CODWRK   =WOBJ+"SIG"
        [F:AWS]OPERATION="C"
        [F:AWS]CLEOBJ   =[F:PAD]NUM
        [F:AWS]NUMORG   =""
        [F:AWS]USRORG   =""
      Else
        [F:AWS]EMETTEUR =[F:PAD2]APPUSR
        [F:AWS]DATENV   =[F:PAD2]APPDAT
        [F:AWS]IDENTREF =""
        [F:AWS]ABROBJ   =""
        [F:AWS]CODEVT   =WOBJ+"SIG"
        [F:AWS]TYPEVT   =9
        [F:AWS]CODWRK   =WOBJ+"SIGVAL"
        [F:AWS]OPERATION="VAL"
        [F:AWS]CLEOBJ   =WCHRONO_PREC
        [F:AWS]NUMORG   =WCHRONO_PREC
        [F:AWS]USRORG   =[F:PAD2]APPUSR
        [F:AWS]CONTXT   ="SAIWRKPLN/1/"+WOBJ+"SIG/VAL/"+WCHRONO_PREC
      Endif
      If [F:AUS]USR<>[F:AWS]EMETTEUR
        Read [AUS] CODUSR=[F:AWS]EMETTEUR : If fstat  Raz [F:AUS] : Endif
      Endif
      [F:AWS]MAIENV   =[F:AUS]ADDEML
      [F:AWS]DATMAXSIG=[F:AWS]DATENV+7
      If [F:PAP]CPY   <>[F:PAD]CPY    |
&        [F:PAP]APPRUL<>[F:PAD]APPRUL |
&        [F:PAP]APPCRI<>[F:PAD]APPCRI |
&        [F:PAP]MAXVAL<>[F:PAD]MAXVAL |
&        [F:PAP]FBUFLG<>[F:PAD]FBUFLG
        Read [PAP] PAP0=[F:PAD]CPY;[F:PAD]APPRUL;[F:PAD]APPCRI;[F:PAD]MAXVAL;[F:PAD]FBUFLG
        If fstat  Raz [F:PAP] : Endif
      Endif
      Raz [F:AWS]NBRUSR
      If [F:PAP]APPUSR1<>""  [F:AWS]NBRUSR+=1 : Endif
      If [F:PAP]APPUSR2<>""  [F:AWS]NBRUSR+=1 : Endif
      If [F:PAP]APPUSR3<>""  [F:AWS]NBRUSR+=1 : Endif
      If [F:PAP]APPUSR4<>""  [F:AWS]NBRUSR+=1 : Endif
      If [F:PAP]APPUSR5<>""  [F:AWS]NBRUSR+=1 : Endif
      If [F:PAP]APPUSR6<>""  [F:AWS]NBRUSR+=1 : Endif
      If [F:PAP]APPUSR7<>""  [F:AWS]NBRUSR+=1 : Endif
      If [F:PAP]APPUSR8<>""  [F:AWS]NBRUSR+=1 : Endif
      If [F:PAP]APPUSR9<>""  [F:AWS]NBRUSR+=1 : Endif
      #-----
      COMPTEUR+=1
      Write [AWS]
      If fstat
        Call ECR_TRACE("File AWRKHISSUI"-[F:AWS]CHRONO-[F:AWS]DEST+", ERROR ="-num$(fstat),1) From GESECRAN
      Endif
      [F:PAD2]=[F:PAD] : WCHRONO_PREC=[F:AWS]CHRONO
      COMPTEUR+=1
      Update [PAD] Where APPRUL=[F:PAD2]APPRUL
&                      & NUM   =[F:PAD2]NUM
&                      & LIN   =[F:PAD2]LIN
&                      & APPLEV=[F:PAD2]APPLEV  With  SAPFLG+=2
      WNBR+=1
      If COMPTEUR>GMAXUPDTRS & CLE1=[F:PAD]APPRUL : CLE2=[F:PAD]NUM : STOP=1 : Break : Endif
    Endif
  Next
Commit
If STOP Goto BOUCLE_PAP : Endif
#-----
Close Local File [PAP], [PAD], [PAD2], [PSD], [POH], [AWS], [ANM], [AVN], [AUS]
Call ECR_TIME("DOSMAJ30 Workflow monitoring history Process 1 : Ended ("+num$(WNBR)+")") From DOSSUB
Return


#---------------------------------------------------------------------------#
# Suppression des fenêtres, écrans et traitements ancien système signatures #
# ------------------------------------------------------------------------- #
# - Suppression des écrans   WCxxxy1                                        #
# - Suppression des fenêtres WOPAPxxxy et des traitements liés WGOPAPxxxy   #
# - Suppression des traitements FUNPAD, FUNPAP, FUNPAPX, FUNPACVAL, FUNSAP, #
#                               SUBPAC et SUBPAP                            #
#---------------------------------------------------------------------------#
$AV_DEL
#----- Si la table n'existe plus, la reprise a déjà été effectuée -----#
If filinfo(filpath("FIL","PAPPCONF","fde",[F:ADS]DOSSIER),0)<0  Return : Endif
#-----
Local File =[F:ADS]DOSSIER+".PAPPCONF"  [PAC]
Local File =[F:ADS]DOSSIER+".AWINDOW"   [AWI]
Local File =[F:ADS]DOSSIER+".AWINPAR"   [AWP]
Local File =[F:ADS]DOSSIER+".AWINBRO"   [AWB]
Local File =[F:ADS]DOSSIER+".AWINBOUT"  [AWT]
#-----
Local Char     NOMWIN(GLONFEN)
Local Char     MFROM (GLONAMK)
Local Char     MTO   (GLONAMK)
Local Integer  TBLOC (15)
Local Char     TZONE (GLONAVA)(200)
Local Integer  TMOD  (200)
Local Char     TINT  (30)(200)
Local Char     TTAB  (GLONATB)(200)
Local Char     TFLD  (GLONAVA)(200)
Local Integer  WRET, WNBR
Local Integer  IBLO, IZON
#-----
Call ECR_TIME("DOSMAJ30 Deletion of unused screens-windows Process 1 : Delete AWINDOW") From DOSSUB
Raz TBLOC, TZONE, TMOD, WRET, WNBR, MFROM
For [PAC] PAC0
  #----- Suppression écran WCxxxy1 -----#
  MTO   ="WC"+[F:PAC]CPY+num$([F:PAC]APPRUL)+"1"
  Call GENECR([F:ADS]DOSSIER,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,9,0,0,WRET) From GENECR
  #----- Suppression fenêtre WCxxxy -----#
  NOMWIN="WOPAP" +[F:PAC]CPY+num$([F:PAC]APPRUL)
  Call DELWIN(NOMWIN,[F:ADS]DOSSIER) From MSKDIV
  #-----
  WNBR+=1
Next
#-----
Close Local File [PAC], [AWI], [AWP], [AWB], [AWT]
Call ECR_TIME("DOSMAJ30 Deletion of unused screens-windows Process 1 : Ended ("+num$(WNBR)+")") From DOSSUB
Return


#------------------------------------------------------------------#
# Alimentation des nouveaux champs dans les transactions de saisie #
# ---------------------------------------------------------------- #
# Table PURTRS - Transactions de saisie achats                     #
#   Transactions demandes d'achat                                  #
#   Transactions commandes                                         #
#   Transactions contrats                                          #
#   Transactions réceptions                                        #
#   Transactions retours fournisseurs                              #
#   Transactions factures/avoirs                                   #
#------------------------------------------------------------------#
$AV_TRS
Local File =[F:ADS]DOSSIER+".PURTRS"   [PTR]
Local File =[F:ADS]DOSSIER+".DIETRS"   [DTR]
Local File =[F:ADS]DOSSIER+".GDIE"     [DIE]
#-----
# Issue 116559 - 2016-05-13 by SR : Déclaration de I
Local Integer WNBR, FLAG, WI, I
Raz WNBR
Call ECR_TIME("DOSMAJ30 Purchase Transactions Process 1 : Update PURTRS") From DOSSUB
#----- S'assurer que la table contient les anciens champs supprimés -----#
If dim([F:PTR]ITMDES1COD)>0
  Trbegin [PTR]
    For [PTR] PTR0
      #----- Alimentation ITMDESCOD(1) et ITMDESSCR(1) -----#
      [F:PTR]ITMDESCOD(1)=[F:PTR]ITMDES1COD
      [F:PTR]ITMDESSCR(1)=[F:PTR]ITMDES1SCR
      #-----
      [F:PTR]STOFCYCOD(1)=[F:PTR]STOFCY1COD
      [F:PTR]BPSLOTCOD(1)=[F:PTR]BPSLOTCOD1
      [F:PTR]MVTPRICOD(1)=[F:PTR]MVTPRICOD1
      [F:PTR]SERECOD  (1)=[F:PTR]SERECOD1
      [F:PTR]MVTDESCOD(1)=[F:PTR]MVTDESCOD1
      [F:PTR]BPSLOTSCR(1)=[F:PTR]BPSLOTSCR1
      [F:PTR]SERESCR  (1)=[F:PTR]SERESCR1
      #----- Alimentation VATCOD(0..2) et VATSCR(0..2) -----#
      [F:PTR]VATCOD(0)   =[F:PTR]VAT1COD
      [F:PTR]VATCOD(1)   =[F:PTR]VAT2COD
      [F:PTR]VATCOD(2)   =[F:PTR]VAT3COD
      [F:PTR]VATSCR(0)   =[F:PTR]VAT1SCR
      [F:PTR]VATSCR(1)   =[F:PTR]VAT2SCR
      [F:PTR]VATSCR(2)   =[F:PTR]VAT3SCR
      #----- Alimentation DISCRGCOD(0..8) et DISCRGSCR(0..8) -----#
# Issue 116559 - 2016-05-13 by SR : Présence de l'ancienne ET de la nouvelle zone
      For I=1 To 9
        If evalue("dim([F:PTR]DISCRGCOD"+num$(I)+")")>0 & I<=dim([F:PTR]DISCRGCOD)
         Case I
          When 1 :     [F:PTR]DISCRGCOD(0)=[F:PTR]DISCRGCOD1
                       [F:PTR]DISCRGSCR(0)=[F:PTR]DISCRGSCR1
          When 2 :     [F:PTR]DISCRGCOD(1)=[F:PTR]DISCRGCOD2
                       [F:PTR]DISCRGSCR(1)=[F:PTR]DISCRGSCR2
          When 3 :     [F:PTR]DISCRGCOD(2)=[F:PTR]DISCRGCOD3
                       [F:PTR]DISCRGSCR(2)=[F:PTR]DISCRGSCR3
          When 4 :     [F:PTR]DISCRGCOD(3)=[F:PTR]DISCRGCOD4
                       [F:PTR]DISCRGSCR(3)=[F:PTR]DISCRGSCR4
          When 5 :     [F:PTR]DISCRGCOD(4)=[F:PTR]DISCRGCOD5
                       [F:PTR]DISCRGSCR(4)=[F:PTR]DISCRGSCR5
          When 6 :     [F:PTR]DISCRGCOD(5)=[F:PTR]DISCRGCOD6
                       [F:PTR]DISCRGSCR(5)=[F:PTR]DISCRGSCR6
          When 7 :     [F:PTR]DISCRGCOD(6)=[F:PTR]DISCRGCOD7
                       [F:PTR]DISCRGSCR(6)=[F:PTR]DISCRGSCR7
          When 8 :     [F:PTR]DISCRGCOD(7)=[F:PTR]DISCRGCOD8
                       [F:PTR]DISCRGSCR(7)=[F:PTR]DISCRGSCR8
          When 9 :     [F:PTR]DISCRGCOD(8)=[F:PTR]DISCRGCOD9
                       [F:PTR]DISCRGSCR(8)=[F:PTR]DISCRGSCR9
        Endcase
       Else
         Break
       Endif
      Next I
#      [F:PTR]DISCRGCOD(0)=[F:PTR]DISCRGCOD1
#      [F:PTR]DISCRGCOD(1)=[F:PTR]DISCRGCOD2
#      [F:PTR]DISCRGCOD(2)=[F:PTR]DISCRGCOD3
#      [F:PTR]DISCRGCOD(3)=[F:PTR]DISCRGCOD4
#      [F:PTR]DISCRGCOD(4)=[F:PTR]DISCRGCOD5
#      [F:PTR]DISCRGCOD(5)=[F:PTR]DISCRGCOD6
#      [F:PTR]DISCRGCOD(6)=[F:PTR]DISCRGCOD7
#      [F:PTR]DISCRGCOD(7)=[F:PTR]DISCRGCOD8
#      [F:PTR]DISCRGCOD(8)=[F:PTR]DISCRGCOD9
#      [F:PTR]DISCRGSCR(0)=[F:PTR]DISCRGSCR1
#      [F:PTR]DISCRGSCR(1)=[F:PTR]DISCRGSCR2
#      [F:PTR]DISCRGSCR(2)=[F:PTR]DISCRGSCR3
#      [F:PTR]DISCRGSCR(3)=[F:PTR]DISCRGSCR4
#      [F:PTR]DISCRGSCR(4)=[F:PTR]DISCRGSCR5
#      [F:PTR]DISCRGSCR(5)=[F:PTR]DISCRGSCR6
#      [F:PTR]DISCRGSCR(6)=[F:PTR]DISCRGSCR7
#      [F:PTR]DISCRGSCR(7)=[F:PTR]DISCRGSCR8
#      [F:PTR]DISCRGSCR(8)=[F:PTR]DISCRGSCR9
# End issue 116559

      #----- Alimentation nouveaux champs pour comptes -----#
      If find([F:PTR]PTRTYP,3,6,7,8)
        [F:PTR]LEDTYPCOD(0)=[F:PTR]ACCCOD
        [F:PTR]LEDTYPCOD(1)=[F:PTR]CNACOD
        [F:PTR]LEDTYPSCR   =[F:PTR]ACCSCR
      Endif
      #----- Alimentation nouvelle table pour axes analytiques -----#
      Look [DTR] DTR0="PTR";[F:PTR]PTRTYP;[F:PTR]PTRNUM;0;0
      If fstat
        If [F:PTR]HEACCECOD=0  [F:PTR]HEACCECOD=3 : Endif
        If [F:PTR]CCECODS=0    [F:PTR]CCECODS=3   : Endif
        Raz [F:DTR]
        [F:DTR]ABRFIC="PTR"
        [F:DTR]DTRTYP=[F:PTR]PTRTYP
        [F:DTR]DTRNUM=[F:PTR]PTRNUM
        [F:DTR]DIE   =""
        [F:DTR]HEACCECOD=[F:PTR]HEACCECOD
        [F:DTR]STOCCECOD=[F:PTR]CCECODS
        [F:DTR]DSPCOD =3
        [F:DTR]DSPSCR =1
        [F:DTR]CCESCR =max([F:PTR]CCESCR(0),1)
        [F:DTR]CCESCR2=1
        [F:DTR]CCESCR3=1
        Write [DTR]
        If fstat
          Call ECR_TRACE("File DIETRS"-[F:DTR]ABRFIC-num$([F:DTR]DTRTYP)+", ERROR ="-num$(fstat),1) From GESECRAN
        Endif
        Raz WI
        For [DIE] DIE0
          Look [DTR] DTR1="PTR";[F:PTR]PTRTYP;[F:PTR]PTRNUM;1;[F:DIE]DIE
          If fstat
            [F:DTR]DTRTNU=1
            [F:DTR]DTRLIN=WI+1
            [F:DTR]DIE   =[F:DIE]DIE
            If dim([F:PTR]CCECOD)>WI & [F:PTR]CCECOD(WI)>0 & [F:PTR]CCECOD(WI)<3
              [F:DTR]CCECOD=[F:PTR]CCECOD(WI)
              Write [DTR]
              If fstat
                Call ECR_TRACE("File DIETRS"-[F:DTR]ABRFIC-num$([F:DTR]DTRTYP)+", ERROR ="-num$(fstat),1) From GESECRAN
              Endif
            Endif
          Endif
          WI+=1
        Next
      Endif
      #-----
      Rewrite [PTR]
      If fstat
        Call ECR_TRACE("File PURTRS"-num$([F:PTR]PTRTYP)-[F:PTR]PTRNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
      WNBR+=1
    Next
  Commit
Endif
Call ECR_TIME("DOSMAJ30 Purchase Transactions Process 1 : Ended ("+num$(WNBR)+")") From DOSSUB
#-----
Raz WNBR
Call ECR_TIME("DOSMAJ30 Purchase Transactions Process 2 : Update PURTRS") From DOSSUB
Trbegin [PTR]
  For [PTR] PTR0 Where PTRTYP=2
    #----- Alimentation des nouveau champs -----#
    Raz FLAG
    If [F:PTR]APPFLG=0     [F:PTR]APPFLG=1    : FLAG=1 : Endif
    If [F:PTR]APPSCR=0     [F:PTR]APPSCR=1    : FLAG=1 : Endif
    If [F:PTR]PURTYPCOD=0  [F:PTR]PURTYPCOD=3 : FLAG=1 : Endif
    If [F:PTR]PURTYPSCR=0  [F:PTR]PURTYPSCR=1 : FLAG=1 : Endif
    If [F:PTR]VATCOD(0)=0  [F:PTR]VATCOD(0)=3 : FLAG=1 : Endif
    If [F:PTR]VATSCR(0)=0  [F:PTR]VATSCR(0)=1 : FLAG=1 : Endif
    If [F:PTR]VATCOD(1)=0  [F:PTR]VATCOD(1)=3 : FLAG=1 : Endif
    If [F:PTR]VATSCR(1)=0  [F:PTR]VATSCR(1)=1 : FLAG=1 : Endif
    If [F:PTR]VATCOD(2)=0  [F:PTR]VATCOD(2)=3 : FLAG=1 : Endif
    If [F:PTR]VATSCR(2)=0  [F:PTR]VATSCR(2)=1 : FLAG=1 : Endif
    If [F:PTR]VATCOD(3)=0  [F:PTR]VATCOD(3)=3 : FLAG=1 : Endif
    If [F:PTR]VATSCR(3)=0  [F:PTR]VATSCR(3)=1 : FLAG=1 : Endif
    If [F:PTR]VATCOD(4)=0  [F:PTR]VATCOD(4)=3 : FLAG=1 : Endif
    If [F:PTR]VATSCR(4)=0  [F:PTR]VATSCR(4)=1 : FLAG=1 : Endif
    If [F:PTR]VATCOD(5)=0  [F:PTR]VATCOD(5)=3 : FLAG=1 : Endif
    If [F:PTR]VATSCR(5)=0  [F:PTR]VATSCR(5)=1 : FLAG=1 : Endif
    If [F:PTR]VATCOD(6)=0  [F:PTR]VATCOD(6)=3 : FLAG=1 : Endif
    If [F:PTR]VATSCR(6)=0  [F:PTR]VATSCR(6)=1 : FLAG=1 : Endif
    #-----
    If FLAG
      Rewrite [PTR]
      If fstat
        Call ECR_TRACE("File PURTRS 2"-[F:PTR]PTRNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    WNBR+=1
  Next
Commit
Call ECR_TIME("DOSMAJ30 Purchase Transactions Process 2 : Ended ("+num$(WNBR)+")") From DOSSUB
#-----
Raz WNBR
Call ECR_TIME("DOSMAJ30 Purchase Transactions Process 3 : Update PURTRS") From DOSSUB
Trbegin [PTR]
  For [PTR] PTR0 Where PTRTYP=3
    #----- Alimentation des nouveau champs -----#
    Raz FLAG
    If [F:PTR]EECICTCOD=0   [F:PTR]EECICTCOD=3   : FLAG=1 : Endif
    If [F:PTR]BPSCOD(1)=0   [F:PTR]BPSCOD(1)=3   : FLAG=1 : Endif
    If [F:PTR]BPSCOD(2)=0   [F:PTR]BPSCOD(2)=3   : FLAG=1 : Endif
    If [F:PTR]VATCOD(3)=0   [F:PTR]VATCOD(3)=3   : FLAG=1 : Endif
    If [F:PTR]VATSCR(3)=0   [F:PTR]VATSCR(3)=1   : FLAG=1 : Endif
    If [F:PTR]VATCOD(4)=0   [F:PTR]VATCOD(4)=3   : FLAG=1 : Endif
    If [F:PTR]VATSCR(4)=0   [F:PTR]VATSCR(4)=1   : FLAG=1 : Endif
    If [F:PTR]VATCOD(5)=0   [F:PTR]VATCOD(5)=3   : FLAG=1 : Endif
    If [F:PTR]VATSCR(5)=0   [F:PTR]VATSCR(5)=1   : FLAG=1 : Endif
    If [F:PTR]VATCOD(6)=0   [F:PTR]VATCOD(6)=3   : FLAG=1 : Endif
    If [F:PTR]VATSCR(6)=0   [F:PTR]VATSCR(6)=1   : FLAG=1 : Endif
    If [F:PTR]LINTYPFLG=0   [F:PTR]LINTYPFLG=1   : FLAG=1 : Endif
    If [F:PTR]LINTYPSCR=0   [F:PTR]LINTYPSCR=1   : FLAG=1 : Endif
    #-----
    If FLAG
      Rewrite [PTR]
      If fstat
        Call ECR_TRACE("File PURTRS 3"-[F:PTR]PTRNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    WNBR+=1
  Next
Commit
Call ECR_TIME("DOSMAJ30 Purchase Transactions Process 3 : Ended ("+num$(WNBR)+")") From DOSSUB
#-----
Raz WNBR
Call ECR_TIME("DOSMAJ30 Purchase Transactions Process 4 : Update PURTRS") From DOSSUB
Trbegin [PTR]
  For [PTR] PTR0 Where PTRTYP=5
    #----- Alimentation des nouveau champs -----#
    Raz FLAG
    If [F:PTR]BPSCOD(1)=0  [F:PTR]BPSCOD(1)=3  : FLAG=1 : Endif
    If [F:PTR]BPSCOD(2)=0  [F:PTR]BPSCOD(2)=3  : FLAG=1 : Endif
    If [F:PTR]ACCCOD=0     [F:PTR]ACCCOD=1     : FLAG=1 : Endif
    If [F:PTR]PURTYPCOD=0  [F:PTR]PURTYPCOD=1  : FLAG=1 : Endif
    #-----
    If FLAG
      Rewrite [PTR]
      If fstat
        Call ECR_TRACE("File PURTRS 5"-[F:PTR]PTRNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    WNBR+=1
  Next
Commit
Call ECR_TIME("DOSMAJ30 Purchase Transactions Process 4 : Ended ("+num$(WNBR)+")") From DOSSUB
#-----
Raz WNBR
Call ECR_TIME("DOSMAJ30 Purchase Transactions Process 5 : Update PURTRS") From DOSSUB
Trbegin [PTR]
  For [PTR] PTR0 Where PTRTYP=6
    #----- Alimentation des nouveau champs -----#
    Raz FLAG
    If [F:PTR]VLTFDRCOD=0   [F:PTR]VLTFDRCOD=2   : FLAG=1 : Endif
    If [F:PTR]VATCOD(3)=0   [F:PTR]VATCOD(3)=3   : FLAG=1 : Endif
    If [F:PTR]VATSCR(3)=0   [F:PTR]VATSCR(3)=1   : FLAG=1 : Endif
    If [F:PTR]VATCOD(4)=0   [F:PTR]VATCOD(4)=3   : FLAG=1 : Endif
    If [F:PTR]VATSCR(4)=0   [F:PTR]VATSCR(4)=1   : FLAG=1 : Endif
    If [F:PTR]VATCOD(5)=0   [F:PTR]VATCOD(5)=3   : FLAG=1 : Endif
    If [F:PTR]VATSCR(5)=0   [F:PTR]VATSCR(5)=1   : FLAG=1 : Endif
    If [F:PTR]VATCOD(6)=0   [F:PTR]VATCOD(6)=3   : FLAG=1 : Endif
    If [F:PTR]VATSCR(6)=0   [F:PTR]VATSCR(6)=1   : FLAG=1 : Endif
    If [F:PTR]IDECOD01=0    [F:PTR]IDECOD01=3    : FLAG=1 : Endif
    If [F:PTR]IDESCR01=0    [F:PTR]IDESCR01=1    : FLAG=1 : Endif
    If [F:PTR]IDECOD02=0    [F:PTR]IDECOD02=3    : FLAG=1 : Endif
    If [F:PTR]IDESCR02=0    [F:PTR]IDESCR02=1    : FLAG=1 : Endif
    #-----
    If FLAG
      Rewrite [PTR]
      If fstat
        Call ECR_TRACE("File PURTRS 6"-[F:PTR]PTRNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    WNBR+=1
  Next
Commit
Call ECR_TIME("DOSMAJ30 Purchase Transactions Process 5 : Ended ("+num$(WNBR)+")") From DOSSUB
#-----
Raz WNBR
Call ECR_TIME("DOSMAJ30 Purchase Transactions Process 6 : Update PURTRS") From DOSSUB
Trbegin [PTR]
  For [PTR] PTR0 Where PTRTYP=7
    #----- Alimentation des nouveau champs -----#
    Raz FLAG
    If [F:PTR]VATCOD(3)=0   [F:PTR]VATCOD(3)=3   : FLAG=1 : Endif
    If [F:PTR]VATSCR(3)=0   [F:PTR]VATSCR(3)=1   : FLAG=1 : Endif
    If [F:PTR]VATCOD(4)=0   [F:PTR]VATCOD(4)=3   : FLAG=1 : Endif
    If [F:PTR]VATSCR(4)=0   [F:PTR]VATSCR(4)=1   : FLAG=1 : Endif
    If [F:PTR]VATCOD(5)=0   [F:PTR]VATCOD(5)=3   : FLAG=1 : Endif
    If [F:PTR]VATSCR(5)=0   [F:PTR]VATSCR(5)=1   : FLAG=1 : Endif
    If [F:PTR]VATCOD(6)=0   [F:PTR]VATCOD(6)=3   : FLAG=1 : Endif
    If [F:PTR]VATSCR(6)=0   [F:PTR]VATSCR(6)=1   : FLAG=1 : Endif
    If [F:PTR]IDECOD01=0    [F:PTR]IDECOD01=3    : FLAG=1 : Endif
    If [F:PTR]IDESCR01=0    [F:PTR]IDESCR01=1    : FLAG=1 : Endif
    If [F:PTR]IDECOD02=0    [F:PTR]IDECOD02=3    : FLAG=1 : Endif
    If [F:PTR]IDESCR02=0    [F:PTR]IDESCR02=1    : FLAG=1 : Endif
    #-----
    If FLAG
      Rewrite [PTR]
      If fstat
        Call ECR_TRACE("File PURTRS 7"-[F:PTR]PTRNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    WNBR+=1
  Next
Commit
Call ECR_TIME("DOSMAJ30 Purchase Transactions Process 6 : Ended ("+num$(WNBR)+")") From DOSSUB
#-----
Raz WNBR
Call ECR_TIME("DOSMAJ30 Purchase Transactions Process 7 : Update PURTRS") From DOSSUB
Trbegin [PTR]
  For [PTR] PTR0 Where PTRTYP=8
    #----- Alimentation des nouveau champs -----#
    Raz FLAG
    If [F:PTR]EECICTCOD=0  [F:PTR]EECICTCOD=3             : FLAG=1 : Endif
    If [F:PTR]VATCOD(3)=0  [F:PTR]VATCOD(3)=3             : FLAG=1 : Endif
    If [F:PTR]VATSCR(3)=0  [F:PTR]VATSCR(3)=1             : FLAG=1 : Endif
    If [F:PTR]VATCOD(4)=0  [F:PTR]VATCOD(4)=3             : FLAG=1 : Endif
    If [F:PTR]VATSCR(4)=0  [F:PTR]VATSCR(4)=1             : FLAG=1 : Endif
    If [F:PTR]VATCOD(5)=0  [F:PTR]VATCOD(5)=3             : FLAG=1 : Endif
    If [F:PTR]VATSCR(5)=0  [F:PTR]VATSCR(5)=1             : FLAG=1 : Endif
    If [F:PTR]VATCOD(6)=0  [F:PTR]VATCOD(6)=3             : FLAG=1 : Endif
    If [F:PTR]VATSCR(6)=0  [F:PTR]VATSCR(6)=1             : FLAG=1 : Endif
    #-----
    If FLAG
      Rewrite [PTR]
      If fstat
        Call ECR_TRACE("File PURTRS 8"-[F:PTR]PTRNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    WNBR+=1
  Next
Commit
Call ECR_TIME("DOSMAJ30 Purchase Transactions Process 7 : Ended ("+num$(WNBR)+")") From DOSSUB
Close Local File [PTR], [DTR], [DIE]
Return

#-------------------------------------------------------------------#
# Alimentation des nouveaux champs dans les éléments de facturation #
# ----------------------------------------------------------------- #
# Table PFOOTINV - Eléments de facturation achats                   #
#   CUR     Devise de la valeur par défaut                          #
#   TRFINV  Transfert cde vers facture                              #
#   CLCDEB  Prise en compte pour la DEB                             #
#   DIE     Codes axes analytiques                                  #
#-------------------------------------------------------------------#
$AV_PFI
Local File =[F:ADS]DOSSIER+".PFOOTINV"   [PFI]
#Local File =[F:ADS]DOSSIER+".GDIE"       [DIE]
Local File =[F:ADS]DOSSIER+".CADIEDEF"    [CDI]
#-----
Local Integer WNBR, WI
Raz WNBR
Call ECR_TIME("DOSMAJ30 Purchase Foot Invoice Process 1 : Update PFOOTINV") From DOSSUB
Trbegin [PFI]
  For [PFI] PFI0
    #----- Alimentation devise, fournisseur origine, codes transfert et DEB -----#
    If [F:PFI]CUR=""    [F:PFI]CUR=GSYSCUR : Endif
    If [F:PFI]BPSORI=0  [F:PFI]BPSORI=1    : Endif
    If [F:PFI]TRFINV=0  [F:PFI]TRFINV=1    : Endif
    If [F:PFI]CLCDEB=0
      If !func AFNC.ACTIV("DEB")
        [F:PFI]CLCDEB=1
      Else
        [F:PFI]CLCDEB=2
      Endif
    Endif
    #----- récupération des codes axes analytiques -----#
    Raz WI
    #MAE, bg 54027
    #For [DIE] DIE0
    #  If [F:PFI]DIE(WI)=""  [F:PFI]DIE(WI)=[F:DIE]DIE : Endif
    #  WI+=1
    #  If dim([F:PFI]DIE)<=WI  Break : Endif
    #Next
    Read [CDI]CDI0 = 14
    If !fstat
       For WI=0 To [F:CDI]NBRDIE-1
          If WI<dim([F:PFI]DIE)
            If [F:PFI]DIE(WI)=""  [F:PFI]DIE(WI)=[F:CDI]DIE(WI) : Endif
          Else
            Break
          Endif
       Next
    Endif
    #-----
    Rewrite [PFI]
    If fstat
      Call ECR_TRACE("File PFOOTINV"-num$([F:PFI]PFINUM)+", Error ="-num$(fstat),1) From GESECRAN
    Endif
    WNBR+=1
  Next
Commit
Close Local File [PFI], [CDI]
Call ECR_TIME("DOSMAJ30 Purchase Foot Invoice Process 1 : Ended ("+num$(WNBR)+")") From DOSSUB
Return


#------------------------------------------------------------#
# Alimentation des nouveaux champs dans les factures d'achat #
# ---------------------------------------------------------- #
# Table PINVOICE - Entête facture d'achat :                  #
#   FFWADD     Code adresse transitaire                      #
#   EECNAT     Nature transaction 2 car (sup "0" devant)     #
#   EECNUM     Identification CEE                            #
#   BPAPAY     Code adresse fournisseur payé                 #
#   LED        Codes référenciel comptabilité                #
#   CURLED     Devises référenciel                           #
#   RATMLT     Cours multiplicateurs                         #
#   RATDIV     Cours diviseurs                               #
# Table PINVOICEV - Complément entête facture d'achat :      #
#   CPY        Code société                                  #
#   DSPWEU     Unité poids                                   #
#   DSPVOU     Unité volume                                  #
#   TOTLINWEU  Total poids lignes                            #
#   TOTLINVOU  Total volumes lignes                          #
# Table PINVOICED - Lignes facture d'achat                   #
#   CPY        Code société                                  #
#   QTYWEU     Poids                                         #
#   QTYVOU     Volume                                        #
#   ORIQTYWEU  Poids origine                                 #
#   ORIQTYVOU  Volume origine                                #
#   CLCAMT1-7  Bases spéciales 1-7 calcul taxe               #
#   LINFLG     Type de ligne                                 #
#   EECFLOPHY  Indicateur Flux physique                      #
#   STRDAT     Date début prestation                         #
#   ENDDAT     Date fin prestation                           #
# Table PVCRFOOT  - Eléments de facturation                  #
#   Création d'enregistrements dans cette nouvelle table     #
#   en remplacement des champs éléments de facturation       #
#   INVLINFLG  Répart. sur ligne (6 au lieu de 4 pour tarif) #
# Table PVCRVAT   - Tableau des taxes                        #
#   Création d'enregistrements dans cette nouvelle table     #
#   en remplacement du tableau des taxes du PINVOICE         #
# Table CPTANALIN - Lignes comptables analytiques            #
#   Création d'enregistrements dans cette nouvelle table     #
#   en remplacement des champs comptes et sections           #
# Table GACCDUDATE - Echéances                               #
#   BPAPAY     Code adresse fournisseur payé                 #
#------------------------------------------------------------#
$AV_PIH
Local File =[F:ADS]DOSSIER+".PINVOICE"   [PIH]
Local File =[F:ADS]DOSSIER+".PINVOICEV"  [PIV]
Local File =[F:ADS]DOSSIER+".PINVOICED"  [PID]
Local File =[F:ADS]DOSSIER+".PINVOICED"  [PID2]
Local File =[F:ADS]DOSSIER+".PVCRFOOT"   [PVF]
Local File =[F:ADS]DOSSIER+".PVCRVAT"    [PVV]
Local File =[F:ADS]DOSSIER+".CPTANALIN"  [CAL]
Local File =[F:ADS]DOSSIER+".PFOOTINV"   [PFI]
Local File =[F:ADS]DOSSIER+".BPARTNER"   [BPR]
Local File =[F:ADS]DOSSIER+".BPSUPPLIER" [BPS]
Local File =[F:ADS]DOSSIER+".ITMMASTER"  [ITM]
Local File =[F:ADS]DOSSIER+".ITMBPS"     [ITP]
Local File =[F:ADS]DOSSIER+".PRICSTRUCT" [PRS]
Local File =[F:ADS]DOSSIER+".TABVAT"     [TVT]
Local File =[F:ADS]DOSSIER+".TABRATVAT"  [TRA]
Local File =[F:ADS]DOSSIER+".TABUNIT"    [TUN]
Local File =[F:ADS]DOSSIER+".TABCOEFF"   [TCO]
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU]
Local File =[F:ADS]DOSSIER+".TABCHANGE"  [TCH]
Local File =[F:ADS]DOSSIER+".GACCDUDATE" [DUD]
Local File =[F:ADS]DOSSIER+".GACM"       [GCM]
#-----
Local Integer  COMPTEUR, STOP, WNBR
Local Integer  I, J, WSTA
Local Char     CLE1(GLONPIH), CRITERE(90)
Local Decimal  WQTE, WCOE, WCOURS
Local Date     WDATE
Local Decimal  WCLCAMT1, WCLCAMT2, WCLCAMT(1..7)
Local Libelle  WCLCFLG1, WCLCFLG2, WCLCFLG(1..7)
Local Char     WTAX(GLONVAT)
#-----
Raz CLE1, STOP, WNBR
Call ECR_TIME("DOSMAJ30 Purchase Invoice Process 1 : Update PINVOICE-V-D") From DOSSUB
$BOUCLE_PIV
If  STOP=1
  CRITERE = 'NUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1"
Endif
Raz COMPTEUR
Trbegin [PIV],[PID]
  For [PIV] PIV0 Where evalue(CRITERE)
    Read [PIH] PIH0=[F:PIV]NUM
    If fstat
      Call ECR_TRACE("File PINVOICE"-[F:PIV]NUM+", Error ="-num$(fstat),1) From GESECRAN
    Else
      Call PARAM([F:PIH]FCY,"SALDSPWEU",[F:PIV]DSPWEU) From ADOVAL
      Call PARAM([F:PIH]FCY,"SALDSPVOU",[F:PIV]DSPVOU) From ADOVAL
      #----- Alimentation des nouveaux champs -----#
      If ([F:PIH]FFWNUM<>"" & [F:PIH]FFWADD="") | len([F:PIH]EECNAT)>2 | [F:PIH]EECNUM=""
&                                               | [F:PIH]BPAPAY=""     | [F:PIH]RATDIV=0
        #----- Alimentation code adresse transitaire -----#
        If [F:PIH]FFWNUM<>"" & [F:PIH]FFWADD=""
          If [F:BPR]BPRNUM<>[F:PIH]FFWNUM
            Read [BPR] BPR0=[F:PIH]FFWNUM : If fstat  Raz [F:BPR] : Endif
          Endif
          [F:PIH]FFWADD=[F:BPR]BPAADD
        Endif
        #----- Passage de la nature transaction CEE à 2 caractères -----#
        If len([F:PIH]EECNAT)>2 & left$([F:PIH]EECNAT,1)="0"
          [F:PIH]EECNAT=right$([F:PIH]EECNAT,2)
        Endif
        #----- Alimentation de l'identification CEE -----#
        If GACTDEB=2 & [F:PIH]EECNUM=""
          If [F:BPR]BPRNUM<>[F:PIH]BPR
            Read [BPR] BPR0=[F:PIH]BPR : If fstat  Raz [F:BPR] : Endif
          Endif
          [F:PIH]EECNUM=[F:BPR]EECNUM
        Endif
        #----- Alimentation code adresse fournisseur payé -----#
        If [F:PIH]BPAPAY=""
          If [F:BPS]BPSNUM<>[F:PIH]BPR
            Read [BPS] BPS0=[F:PIH]BPR : If fstat  Raz [F:BPS] : Endif
          Endif
          If [F:BPS]BPRPAY=[F:PIH]BPRPAY
            [F:PIH]BPAPAY=[F:BPS]BPAPAY
          Else
            If [F:BPS]BPSNUM<>[F:PIH]BPRPAY
              Read [BPS] BPS0=[F:PIH]BPRPAY : If fstat  Raz [F:BPS] : Endif
            Endif
            [F:PIH]BPAPAY=[F:BPS]BPAADD
          Endif
        Endif
        #----- Alimentation champs pour le multi-référenciels comptabilité -----#
        Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:PIH]FCY) From TRTX3CPT
        If [F:PIH]LED(0)=""
          For I=1 To max(GNBCOA,2)
            [F:PIH]LED   (I-1)=GLEDSOC(I)
            [F:PIH]CURLED(I-1)=GDEVLED(I)
            [F:PIH]RATDIV(I-1)=1
            If GDEVLED(I)=GLOCALDEV
              [F:PIH]RATMLT(I-1)=[F:PIH]RATCUR
            Elsif GDEVLED(I)=GSYSCUR
              [F:PIH]RATMLT(I-1)=[F:PIH]RATRPT
            Else
              [F:PIH]RATMLT(I-1)=0
            Endif
          Next I
        Endif
        If dim([F:PIH]DIE)>0 & [F:PIH]DIE=""
          For I=1 To max(GNBDIE,GOPTCANA)
            [F:PIH]DIE(I-1)=GDIE(I)
          Next I
        Endif
        #----- Chargement HT et TTC facture en devise société -----#
        I=find(GLOCALDEV,[F:PIH]CURLED)
        If I>0 & [F:PIH]RATDIV(I-1)<>0
          WCOURS=[F:PIH]RATMLT(I-1)/[F:PIH]RATDIV(I-1)
        Else
          WCOURS=0
        Endif
        Call COURMNT([F:PIH]CUR,GLOCALDEV,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]RATDAT,1,
&                    [F:PIH]AMTNOT,[F:PIH]AMTNOTL,WCOURS,WSTA) From TRTDEV
        If WSTA
          Call ECR_TRACE("     1-File PINVOICE"-[F:PIV]NUM+", Error ="-num$(WSTA),-1) From GESECRAN
        Endif
        Call COURMNT([F:PIH]CUR,GLOCALDEV,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]RATDAT,1,
&                    [F:PIH]AMTATI,[F:PIH]AMTATIL,WCOURS,WSTA) From TRTDEV
        If WSTA
          Call ECR_TRACE("     2-File PINVOICE"-[F:PIV]NUM+", Error ="-num$(WSTA),-1) From GESECRAN
        Endif
        #-----
        COMPTEUR+=1
        Rewrite [PIH]
        If fstat
          Call ECR_TRACE("File PINVOICE"-[F:PIV]NUM+", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
      #----- Mise à jour code adresse tiers âyeur sur échéances -----#
      COMPTEUR+=1
      Update [DUD] Where TYP=[F:PIH]GTE & NUM=[F:PIV]NUM & BPAPAY=""
&                  With  BPAPAY=[F:PIH]BPAPAY
      If fstat
        Call ECR_TRACE("File GACCDUDATE"-[F:PIH]GTE-[F:PIV]NUM+",Error ="-num$(fstat),1) From GESECRAN
      Endif
      #----- Alimentation de la société sur le complément entête facture -----#
      [F:PIV]CPY=[F:PIH]CPY
      #----- Alimentation nouvelle table des taxes PVCRVAT -----#
      If dim([F:PIH]TAX)>0
        For I=0 To [F:PIH]NBRTAX-1
          Look [PVV] PVV0=[F:PIV]NUM;8;I+1
          If fstat
            Raz [F:PVV]
            [F:PVV]VCRTYP=8
            [F:PVV]VCRNUM=[F:PIH]NUM
            [F:PVV]NUM   =[F:PIH]NUM
            [F:PVV]IND   =I+1
            [F:PVV]TAX   =[F:PIH]TAX   (I)
            [F:PVV]BASTAX=[F:PIH]BASTAX(I)
            [F:PVV]AMTTAX=[F:PIH]AMTTAX(I)
            [F:PVV]DEDTAX=[F:PIH]DEDTAX(I)
            [F:PVV]PURTYP=[F:PIH]PURTYP(I)
            If [F:TVT]VAT<>[F:PIH]TAX(I)
              Read [TVT] TVT0=[F:PIH]TAX(I) : If fstat  Raz [F:TVT] : Endif
            Endif
            [F:PVV]VATTYP=[F:TVT]VATTYP
            #----- Chargement des taux de taxe -----#
            If [F:PIH]PIHTYP=3 & dim([F:PIH]VATDAT)>0 & [F:PIH]VATDAT<>[0/0/0]
              WDATE=[F:PIH]VATDAT
            Else
              WDATE=[F:PIH]ACCDAT
            Endif
            Filter [TRA] Where CPY=[F:PIH]CPY & VAT=[F:PVV]TAX & STRDAT<=WDATE
            Read [TRA] TRA0 Last
            If fstat>2
              Filter [TRA] Where CPY="" & VAT=[F:PVV]TAX & STRDAT<=WDATE
              Read [TRA]TRA0 Last
              If fstat>2  Raz [F:TRA] : Endif
            Endif
            [F:PVV]VATRAT=[F:TRA]VATRAT
            [F:PVV]DEDRAT=[F:TRA]DEDRAT
            #-----
            [F:PVV]CREDAT=date$
            [F:PVV]CREUSR=GUSER
            COMPTEUR+=1
            Write [PVV]
            If fstat
              Call ECR_TRACE("File PVCRVAT"-[F:PVV]VCRNUM-"8"-num$([F:PVV]IND)+
&                            ",Error ="-num$(fstat),1) From GESECRAN
            Endif
          Endif
        Next I
      Endif
      #----- Alimentation nouvelles tables PVCRFOOT et CPTANALIN -----#
      If dim([F:PIV]INVDTA)>0
        #----- Lecture du fournisseur si nécessaire -----#
        If [F:BPS]BPSNUM<>[F:PIH]BPR
          Read [BPS] BPS0=[F:PIH]BPR : If fstat  Raz [F:BPS] : Endif
        Endif
        Call TYPREM(2,[F:BPS]PLISTC) From TRTPRICE
        #-----
        For I=0 To dim([F:PIV]INVDTA)-1
          If [F:PIV]INVDTA(I)<>0
            Read [PFI] PFI0=[F:PIV]INVDTA(I) : If fstat  Raz [F:PFI] : Endif
            #----- Présence sur ligne tarif (valeur 4 devient 6) -----#
            If [F:PIV]TOTLINWEU=0 & [F:PIV]TOTLINVOU=0
              If [F:PIV]INVLINFLG(I)=4  [F:PIV]INVLINFLG(I)=6 : Endif
            Endif
            #----- Création des éléments de facturation dans table PVCRFOOT -----#
            Look [PVF] PVF0=[F:PIV]NUM;8;I+1
            If fstat
              Raz [F:PVF]
              [F:PVF]VCRTYP   =8
              [F:PVF]VCRNUM   =[F:PIV]NUM
              [F:PVF]NUM      =[F:PIV]NUM
              [F:PVF]IND      =I+1
              [F:PVF]INVDTA   =[F:PIV]INVDTA   (I)
              [F:PVF]INVDTAAMT=[F:PIV]INVDTAAMT(I)
              [F:PVF]INVORDAMT=[F:PIV]INVORDAMT(I)
              [F:PVF]INVLINAMT=[F:PIV]INVLINAMT(I)
              If find([F:PIV]INVDTA(I),[F:BPS]INVDTA) |
&                find([F:PIV]INVDTA(I),GINVDTALIN)
                [F:PVF]INVDTAFLG=1
              Else
                [F:PVF]INVDTAFLG=2
              Endif
              [F:PVF]INVLINFLG=[F:PIV]INVLINFLG(I)
              [F:PVF]INVORDFLG=[F:PFI]DACORD
              [F:PVF]DEBCDT   =[F:PIV]DEBCDT   (I)
              [F:PVF]INVDTAVAT=[F:PIV]INVDTAVAT(I)
              [F:PVF]DTAAMTTAX=[F:PIV]DTAAMTTAX(I)
              [F:PVF]DTADEDTAX=[F:PIV]DTADEDTAX(I)
              [F:PVF]AMTCOD   =2
              [F:PVF]CLCORD   =[F:PFI]CLCORD
              [F:PVF]CLCBAS   =[F:PFI]CLCBAS
              [F:PVF]CREDAT   =date$
              [F:PVF]CREUSR   =GUSER
              COMPTEUR+=1
              Write [PVF]
              If fstat
                Call ECR_TRACE("File PVCRFOOT"-[F:PVF]VCRNUM-"8"-num$([F:PVF]IND)+
&                              ",Error ="-num$(fstat),1) From GESECRAN
              Endif
            Endif
            #----- Création lignes comptables analytiques des éléments de facturation -----#
            Look [CAL] CAL0="PVF";8;[F:PIV]NUM;0;I+1;"";1
            If fstat
              Raz [F:CAL]
              [F:CAL]ABRFIC="PVF"
              [F:CAL]VCRTYP=8
              [F:CAL]VCRNUM=[F:PIV]NUM
              [F:CAL]VCRSEQ=I+1
              [F:CAL]ANALIG=1
              For J=1 To max(GNBCOA,2)
                [F:CAL]LED(J-1)=GLEDSOC(J)
                [F:CAL]COA(J-1)=GCOA(J)
              Next J
              [F:CAL]ACC(0)=[F:PIV]ACC(I)
              [F:CAL]ACC(1)=[F:PIV]CNA(I)
              For J=1 To max(GNBDIE,GOPTCANA)
                [F:CAL]DIE(J-1)=GDIE(J)
                If dim([F:PFI]CCE)>=J
                  [F:CAL]CCE(J-1)=[F:PFI]CCE(J-1)
                Endif
              Next J
              COMPTEUR+=1
              Write [CAL]
              If fstat
                Call ECR_TRACE("File CPTANALIN PIV 0"-[F:PIV]NUM+"0, Error ="-num$(fstat),1) From GESECRAN
              Endif
            Endif
            #-----
          Endif
        Next I
      Endif
      #-----
      Raz [F:PIV]TOTLINWEU, [F:PIV]TOTLINVOU
      For [PID] PID0 Where NUM=[F:PIV]NUM
        #----- Mise à jour des quantités poids et volume -----#
        If [F:ITM]ITMREF<>[F:PID]ITMREF
          Read [ITM] ITM0=[F:PID]ITMREF : If fstat  Raz [F:ITM] : Endif
        Endif
        #----- Par sécurité, chargement des unités de l'article si nécessaire -----#
        If [F:PIV]DSPWEU=""  [F:PIV]DSPWEU=[F:ITM]WEU : Endif
        If [F:PIV]DSPVOU=""  [F:PIV]DSPVOU=[F:ITM]VOU : Endif
        #-----
        [F:PID]QTYWEU=[F:ITM]ITMWEI*[F:PID]QTYSTU
        [F:PID]QTYVOU=[F:ITM]ITMVOU*[F:PID]QTYSTU
        Call CONVERT_QTY([F:ITM]WEU,[F:PIV]DSPWEU,[F:PID]QTYWEU) From TRTX3
        Call CONVERT_QTY([F:ITM]VOU,[F:PIV]DSPVOU,[F:PID]QTYVOU) From TRTX3
        [F:PIV]TOTLINWEU+=[F:PID]QTYWEU
        [F:PIV]TOTLINVOU+=[F:PID]QTYVOU
        #----- Mise à jour des quantités poids et volume d'origine -----#
        Raz WQTE
        If [F:PID]TYPORI=4 & [F:PID]ORIQTYPUU<>0
          Read [PID2] PID0=[F:PID]NUMORI;[F:PID]LINORI
          If !fstat
            If [F:ITM]ITMREF<>[F:PID2]ITMREF
              Read [ITM] ITM0=[F:PID2]ITMREF : If fstat  Raz [F:ITM] : Endif
            Endif
            Call PCAL_QTY([F:PID]ORIQTYPUU,[F:PID]PUU,WQTE,[F:PID2]STU,
&                         [F:PID2]ITMREF,[F:PID2]BPSNUM,1,WCOE) From TRTACHQTE1
          Endif
        Else
          Call PCAL_QTY([F:PID]ORIQTYPUU,[F:PID]PUU,WQTE,[F:PID]STU,
&                       [F:PID]ITMREF,[F:PID]BPSNUM,1,WCOE) From TRTACHQTE1
        Endif
        [F:PID]ORIQTYWEU=[F:ITM]ITMWEI*WQTE
        [F:PID]ORIQTYVOU=[F:ITM]ITMVOU*WQTE
        Call CONVERT_QTY([F:ITM]WEU,[F:PIV]DSPWEU,[F:PID]ORIQTYWEU) From TRTX3
        Call CONVERT_QTY([F:ITM]VOU,[F:PIV]DSPVOU,[F:PID]ORIQTYVOU) From TRTX3
        #----- Alimentation des bases spéciales 1-7 calcul taxe -----#
        If ([F:PID]CLCAMT1<>0 | [F:PID]CLCAMT2<>0)
&         & [F:PID]CLCAMT3=0
&         & [F:PID]CLCAMT4=0
&         & [F:PID]CLCAMT5=0
&         & [F:PID]CLCAMT6=0
&         & [F:PID]CLCAMT7=0
          #-----
          Raz WCLCAMT, WCLCFLG
          WCLCAMT1=[F:PID]CLCAMT1 : WCLCFLG1=0
          WCLCAMT2=[F:PID]CLCAMT2 : WCLCFLG2=0
          For I=1 To 7
            Case I
              When 1 : WTAX=[F:PID]VAT(I-1) : Gosub TRT_BASE
              When 2 : WTAX=[F:PID]VAT(I-1) : Gosub TRT_BASE
              When 3 : WTAX=[F:PID]VAT(I-1) : Gosub TRT_BASE
              When 4 : WTAX=[F:PID]TAXRCP   : Gosub TRT_BASE
              When 5 : WTAX=[F:PID]TAXISS   : Gosub TRT_BASE
              When 6 : WTAX=[F:PID]TAXOTH1  : Gosub TRT_BASE
              When 7 : WTAX=[F:PID]TAXOTH2  : Gosub TRT_BASE
            Endcase
          Next I
          If WCLCFLG1 | WCLCFLG2
            If WCLCFLG1  Raz [F:PID]CLCAMT1 : Endif
            If WCLCFLG2  Raz [F:PID]CLCAMT2 : Endif
            For I=1 To 7
              If WCLCFLG(I)=1
                Assign "[F:PID]CLCAMT"+num$(I) With WCLCAMT(I)
              Endif
            Next I
          Endif
        Endif
        #----- Alimentation du type de ligne -----#
        If dim([F:PID]LINTYP)>0 & [F:PID]LINTYP=0  [F:PID]LINTYP=1 : Endif
        #----- Création lignes comptables analytiques des lignes de facture -----#
        Look [CAL] CAL0="PID";0;[F:PID]NUM;[F:PID]PIDLIN;0;"";1
        If fstat
          Raz [F:CAL]
          [F:CAL]ABRFIC="PID"
          [F:CAL]VCRNUM=[F:PID]NUM
          [F:CAL]VCRLIN=[F:PID]PIDLIN
          [F:CAL]ANALIG=1
          For I=1 To max(GNBCOA,2)
            [F:CAL]LED(I-1)=GLEDSOC(I)
            [F:CAL]COA(I-1)=GCOA(I)
          Next I
          [F:CAL]ACC(0)=[F:PID]LINACC
          [F:CAL]ACC(1)=[F:PID]LINCNA
          For I=1 To max(GNBDIE,GOPTCANA)
            [F:CAL]DIE(I-1)=GDIE(I)
            If evalue("dim([F:PID]CCE"+num$(I)+")")>0
              [F:CAL]CCE(I-1)=evalue("[F:PID]CCE"+num$(I))
            Endif
          Next I
          COMPTEUR+=1
          Write [CAL]
          If fstat
            Call ECR_TRACE("File CPTANALIN PID 0"-[F:PID]NUM-num$([F:PID]PIDLIN)
&                           +", Error ="-num$(fstat),1) From GESECRAN
          Endif
        Endif
        #----- Alimentation de la société sur les lignes de facture d'achat -----#
        [F:PID]CPY=[F:PIH]CPY
        #----- Alimentation de l'indicateur de flux physique -----#
        If [F:PID]EECFLOPHY=0  [F:PID]EECFLOPHY=1 : Endif
        # Bug 72056 : Init. dates de prestation lignes à partir de l'entête (V6.1)
        If [F:PID]ENDDAT=[0/0/0] [F:PID]ENDDAT=[F:PIH]ENDDATSVC Endif
        If [F:PID]STRDAT=[0/0/0] [F:PID]STRDAT=[F:PIH]STRDATSVC Endif
        COMPTEUR+=1
        Rewrite [PID]
        If fstat
          Call ECR_TRACE("File PINVOICED"-[F:PIV]NUM+", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Next
      #-----
      COMPTEUR+=1
      Rewrite [PIV]
      If fstat
        Call ECR_TRACE("File PINVOICEV"-[F:PIV]NUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
      #-----
    Endif
    WNBR+=1
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PIV]NUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PIV : Endif
Close Local File [PIH], [PIV], [PID], [PID2], [PVF], [PVV], [CAL], [PFI], [BPR], [BPS],
&                [ITM], [ITP], [PRS],  [TVT], [TRA], [TUN], [TCO], [TCU], [TCH], [DUD],
&                [GCM]
Call ECR_TIME("DOSMAJ30 Purchase Invoice Process 1 : Ended ("+num$(WNBR)+")") From DOSSUB
Return


#----------------------------------------------------------#
# Alimentation des nouveaux champs dans les appels d'offre #
# -------------------------------------------------------- #
# Table PQUOTAT - Entête appel d'offre :                   #
#   CPY     Code société                                   #
# Table PQUOTATD - Lignes article appel d'offre :          #
#   CPY     Code société                                   #
# Table PQUOTATF - Lignes fournisseur appel d'offre :      #
#   CPY     Code société                                   #
# Table PRESP - Entête réponse appel d'offre :             #
#   CPY     Code société                                   #
# Table PRESPD - Lignes réponse appel d'offre :            #
#   CPY     Code société                                   #
# Table CPTANALIN - Lignes comptables analytiques          #
#   Création d'enregistrements dans cette nouvelle table   #
#   en remplacement des champs sections de PQUOTATD        #
#----------------------------------------------------------#
$AV_PQH
Local File =[F:ADS]DOSSIER+".PQUOTAT"    [PQH]
Local File =[F:ADS]DOSSIER+".PQUOTATD"   [PQD]
Local File =[F:ADS]DOSSIER+".CPTANALIN"  [CAL]
Local File =[F:ADS]DOSSIER+".PQUOTATF"   [PQF]
Local File =[F:ADS]DOSSIER+".PRESP"      [PPH]
Local File =[F:ADS]DOSSIER+".PRESPD"     [PPD]
Local File =[F:ADS]DOSSIER+".GACM"       [GCM]
#-----
Local Integer  COMPTEUR, STOP, WNBR
Local Char     CLE1(GLONPQH), CRITERE(90)
Local Integer  I
Raz CLE1, STOP, WNBR
Call ECR_TIME("DOSMAJ30 Request for quotations Process 1 : Update PQUOTAT-D-F") From DOSSUB
$BOUCLE_PQH
If  STOP=1
  CRITERE = 'PQHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1"
Endif
Raz COMPTEUR
Trbegin [PQH],[PQD],[PQF],[PPH],[PPD]
  For [PQH] PQH0 Where evalue(CRITERE)
    #----- Alimentation de la société sur l'entête de l'appel d'offre -----#
    Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:PQH]PQHFCY) From TRTX3CPT
    [F:PQH]CPY=GSOCIETE
    COMPTEUR+=1
    Rewrite [PQH]
    If fstat
      Call ECR_TRACE("File PQUOTAT"-[F:PQH]PQHNUM+", Error ="-num$(fstat),1) From GESECRAN
    Endif
    #-----
    For [PQD] PQD0 Where PQHNUM=[F:PQH]PQHNUM
      #----- Création lignes comptables analytiques des lignes appel d'offre -----#
      Look [CAL] CAL0="PQD";0;[F:PQD]PQHNUM;[F:PQD]PQDLIN;0;"";1
      If fstat
        Raz [F:CAL]
        [F:CAL]ABRFIC="PQD"
        [F:CAL]VCRNUM=[F:PQD]PQHNUM
        [F:CAL]VCRLIN=[F:PQD]PQDLIN
        [F:CAL]ANALIG=1
        For I=1 To max(GNBCOA,2)
          [F:CAL]LED(I-1)=GLEDSOC(I)
          [F:CAL]COA(I-1)=GCOA(I)
        Next I
        For I=1 To max(GNBDIE,GOPTCANA)
          [F:CAL]DIE(I-1)=GDIE(I)
          If evalue("dim([F:PQD]CCE"+num$(I)+")")>0
            [F:CAL]CCE(I-1)=evalue("[F:PQD]CCE"+num$(I))
          Endif
        Next I
        COMPTEUR+=1
        Write [CAL]
        If fstat
          Call ECR_TRACE("File CPTANALIN PQD 0"-[F:PQD]PQHNUM-num$([F:PQD]PQDLIN)
&                         +", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
      #----- Alimentation de la société sur lignes article de l'appel d'offre -----#
      [F:PQD]CPY=[F:PQH]CPY
      COMPTEUR+=1
      Rewrite [PQD]
      If fstat
        Call ECR_TRACE("File PQUOTATD"-[F:PQH]PQHNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
    Next
    #-----
    For [PQF] PQF0 Where PQHNUM=[F:PQH]PQHNUM
      #----- Alimentation de la société sur les lignes fournisseur de l'appel d'offre -----#
      [F:PQF]CPY=[F:PQH]CPY
      COMPTEUR+=1
      Rewrite [PQF]
      If fstat
        Call ECR_TRACE("File PQUOTATF"-[F:PQH]PQHNUM-[F:PQF]BPSNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
      #----- Alimentation de la société sur l'entête réponse de l'appel d'offre -----#
      COMPTEUR+=1
      Update [PPH] Where BPSNUM=[F:PQF]BPSNUM & PQHNUM=[F:PQH]PQHNUM With CPY=[F:PQH]CPY
      If fstat
        Call ECR_TRACE("File PRESP"-[F:PQF]BPSNUM-[F:PQH]PQHNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
      #----- Alimentation de la société sur les lignes réponse de l'appel d'offre -----#
      COMPTEUR+=1
      Update [PPD] Where BPSNUM=[F:PQF]BPSNUM & PQHNUM=[F:PQH]PQHNUM With CPY=[F:PQH]CPY
      If fstat
        Call ECR_TRACE("File PRESPD"-[F:PQF]BPSNUM-[F:PQH]PQHNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
      #-----
    Next
    #-----
    WNBR+=1
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PQH]PQHNUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PQH : Endif
Close Local File [PQH], [PQD], [CAL], [PQF], [PPH], [PPD], [GCM]
Call ECR_TIME("DOSMAJ30 Request for quotations Process 1 : Ended ("+num$(WNBR)+")") From DOSSUB
Return


#----------------------------------------------------------------#
#   Alimentation des nouveaux champs dans les demandes d'achat   #
# -------------------------------------------------------------- #
# Table PREQUIS - Entête demande d'achat :                       #
#   CPY          Code société                                    #
#   FBULINNBR    Nombre de lignes en dépassement de budget       #
#   APPFLG       Indicateur signature réajustement si nécessaire #
#                                                                #
# Table PREQUISD - Lignes demande d'achat                        #
#   CPY          Code société                                    #
#   CHGTYP       Type de cours (récupéré du fournisseur si <>""  #
#   VACBPR       Régime de taxe                                  #
#   VACTYP       Type de régime                                  #
#   VAT1         Code taxe 1                                     #
#   VAT2         Code taxe 2                                     #
#   VAT3         Code taxe 3                                     #
#   CMMPRPTAX    Type de pré-engagement (HT/HTND/TTC)            #
#   CMMPRPFLG    Indicateur pré-engagement                       #
#   CLCAMT1-3    Base 1-3 calcul taxe                            #
#   BASTAXLIN1   Base taxe ligne                                 #
#   AMTTAXLIN1-3 Montant taxe 1-3                                #
#   DEDTAXLIN1-3 Montant taxe 1-3 déductible                     #
#   LINATIAMT    Montant TTC ligne                               #
#                                                                #
# Table CPTANALIN - Lignes comptables analytiques                #
#   Création d'enregistrements dans cette nouvelle table         #
#   en remplacement des champs comptes et sections               #
#----------------------------------------------------------------#
$AV_PSH
Local File =[F:ADS]DOSSIER+".PREQUIS"    [PSH]
Local File =[F:ADS]DOSSIER+".PREQUISD"   [PSD]
Local File =[F:ADS]DOSSIER+".CPTANALIN"  [CAL]
Local File =[F:ADS]DOSSIER+".GACM"       [GCM]
Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]
Local File =[F:ADS]DOSSIER+".BPCUSTOMER" [BPC]
Local File =[F:ADS]DOSSIER+".BPSUPPLIER" [BPS]
Local File =[F:ADS]DOSSIER+".ITMMASTER"  [ITM]
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU]
Local File =[F:ADS]DOSSIER+".TABVAC"     [TVC]
Local File =[F:ADS]DOSSIER+".TABVAT"     [TVT]
Local File =[F:ADS]DOSSIER+".TABRATVAT"  [TRA]
Local File =[F:ADS]DOSSIER+".ATABDIV"    [ADI]
Local File =[F:ADS]DOSSIER+".ADOPAR"     [ADP]
Local File =[F:ADS]DOSSIER+".ADOVAL"     [ADW]
Local File =[F:ADS]DOSSIER+".PRICSTRUCT" [PRS]
Local File =[F:ADS]DOSSIER+".PFOOTINV"   [PFI]
# Issue 74485 - 2011-06-20 by VPO : lecture des codes activité : garder ACV ouverte
#Local File =[F:ADS]DOSSIER+".ACTIV"      [ACV]
If func AFNC.ACTIV("MUL")
  Local File =[F:ADS]DOSSIER+".BPEXCEPT"   [BPE]
Endif
#----- Variables locales pour le calcul de TVA -----#
Local Char     ABREV(8)
Local Integer  STAT, TYPREG
Local Decimal  BASE, MONTANT(1..3), MONTDED(1..3)
Local Char     TAXE(GLONVAT)(1..3)
Local Decimal  WRND
Local Char     WCUR(GLONCUR)
Local Char     WITMREF(GLONITM)
Local Char     WBPSNUM(GLONBPS)
Local Date     WDOCDAT
Local Char     WVACBPR(GLONADI)
Local Integer  WVACTYP
Local Decimal  WQTYPUU
Local Decimal  WLINAMT, WLINATIAMT
Local Decimal  WCLCAMT(1..7)
#-----
Local Char     ABREV(8)
Local Integer  COMPTEUR, STOP, WNBR, WFBULINNBR
Local Char     CLE1(GLONPSH), CRITERE(90), WPARAM(10)
Local Integer  I
Raz CLE1, STOP, WNBR
Call ECR_TIME("DOSMAJ30 Purchase Request Process 1 : Update PREQUIS-D") From DOSSUB
$BOUCLE_PSH
If  STOP=1
  CRITERE = 'PSHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1"
Endif
Raz COMPTEUR
Trbegin [PSH],[PSD]
  For [PSH] PSH0 Where evalue(CRITERE)
    #----- Alimentation de la société sur l'entête de demande d'achat -----#
    Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:PSH]PSHFCY) From TRTX3CPT
    [F:PSH]CPY=GSOCIETE
    #-----
    Raz WFBULINNBR
    For [PSD] PSD0 Where PSHNUM=[F:PSH]PSHNUM
      If [F:PSD]FBUFLG=2  WFBULINNBR+=1 : Endif
      #----- Alimentation de la société sur les lignes de demande d'achat -----#
      [F:PSD]CPY=[F:PSH]CPY
      #----- Alimentation du régime de taxe -----#
      If [F:PSD]VACBPR=""
        If [F:PSD]BPSNUM<>""
          If [F:BPS]BPSNUM<>[F:PSD]BPSNUM
            Read [BPS] BPS0=[F:PSD]BPSNUM : If fstat  Raz [F:BPS] : Endif
          Endif
          [F:PSD]CHGTYP=[F:BPS]CHGTYP
          [F:PSD]VACBPR=[F:BPS]VACBPR
          Call INIT_REGIME([F:PSD]BPSNUM,[F:PSH]PSHFCY,"F",[F:PSD]VACBPR) From CPTSUB
        Else
          Call PARAM([F:PSH]PSHFCY,"PURVACBPR",WPARAM) From ADOVAL
          If WPARAM<>""
            [F:PSD]VACBPR=WPARAM
          Else
            Filter [ADI] Where NUMTAB=1 & DEFVAL=2
            Read [ADI] CODE First
            Filter [ADI]
            If !fstat
              [F:PSD]VACBPR=[F:ADI]CODE
            Else
              Filter [ADI] Where NUMTAB=1 & LEG=GCURLEG & N1=1
              Read [ADI] CODE First
              Filter [ADI]
              If !fstat
                [F:PSD]VACBPR=[F:ADI]CODE
              Else
                Filter [ADI] Where NUMTAB=1 & LEG="" & N1=1
                Read [ADI] CODE First
                Filter [ADI]
                If !fstat
                  [F:PSD]VACBPR=[F:ADI]CODE
                Endif
              Endif
            Endif
          Endif
        Endif
        If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[F:PSD]VACBPR
          Read [ADI] CODE=1;[F:PSD]VACBPR : If fstat Raz [F:ADI] : Endif
        Endif
        [F:PSD]VACTYP=[F:ADI]N1
      Endif
      #----- Alimentation des codes taxe -----#
      If [F:PSD]VAT(0)=""
        Raz [F:PSD]VAT
        If [F:ITM]ITMREF<>[F:PSD]ITMREF
          Read [ITM] ITM0=[F:PSD]ITMREF : If fstat  Raz [F:ITM] : Endif
        Endif
        If [F:ITM]VACITM(0)<>""
          Read [TVC] TVC0=[F:PSD]VACBPR;[F:ITM]VACITM(0) : If !fstat [F:PSD]VAT(0)=[F:TVC]VAT : Endif
        Endif
        If [F:ITM]VACITM(1)<>""
          Read [TVC] TVC0=[F:PSD]VACBPR;[F:ITM]VACITM(1) : If !fstat [F:PSD]VAT(1)=[F:TVC]VAT : Endif
        Endif
        If [F:ITM]VACITM(2)<>""
          Read [TVC] TVC0=[F:PSD]VACBPR;[F:ITM]VACITM(2) : If !fstat [F:PSD]VAT(2)=[F:TVC]VAT : Endif
        Endif
        #----- Calcul des bases et taxes de la ligne de DA -----#
        ABREV="PSD" : Gosub MAJ_CALTAX_LIG
      Endif
      #----- Mise à jour indicateur de pré-engagement (0=inactif, 1=actif) -----#
      If [F:PSD]CMMPRPNUM<>"" & [F:PSD]LINCLEFLG<>2
        [F:PSD]CMMPRPFLG=1
      Else
        [F:PSD]CMMPRPFLG=0
      Endif
      #-----
      If [F:PSD]CMMPRPTAX=0  [F:PSD]CMMPRPTAX=1 : Endif
      #----- Création lignes comptables analytiques -----#
      Look [CAL] CAL0="PSD";0;[F:PSD]PSHNUM;[F:PSD]PSDLIN;0;"";1
      If fstat
        Raz [F:CAL]
        [F:CAL]ABRFIC="PSD"
        [F:CAL]VCRNUM=[F:PSD]PSHNUM
        [F:CAL]VCRLIN=[F:PSD]PSDLIN
        [F:CAL]ANALIG=1
        For I=1 To max(GNBCOA,2)
          [F:CAL]LED(I-1)=GLEDSOC(I)
          [F:CAL]COA(I-1)=GCOA(I)
        Next I
        [F:CAL]ACC(0)=[F:PSD]LINACC
        [F:CAL]ACC(1)=[F:PSD]LINCNA
        For I=1 To max(GNBDIE,GOPTCANA)
          [F:CAL]DIE(I-1)=GDIE(I)
          If evalue("dim([F:PSD]CCE"+num$(I)+")")>0
            [F:CAL]CCE(I-1)=evalue("[F:PSD]CCE"+num$(I))
          Endif
        Next I
        COMPTEUR+=1
        Write [CAL]
        If fstat
          Call ECR_TRACE("File CPTANALIN PSD 0"-[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)
&                         +", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
      #-----
      COMPTEUR+=1
      Rewrite [PSD]
      If fstat
        Call ECR_TRACE("File PREQUISD"-[F:PSD]PSHNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
    Next
    #----- Réajustement indicateur signature si nécessaire -----#
    If [F:PSH]APPFLG<2
      Filter [PSD] Where PSHNUM=[F:PSH]PSHNUM & LINAPPFLG>1
      Look [PSD] PSD0 First
      If fstat
        [F:PSH]APPFLG=1
      Else
        [F:PSH]APPFLG=2
      Endif
      Filter [PSD]
    Endif
    #----- Màj nombre de lignes en dépassement budgétaire -----#
    [F:PSH]FBULINNBR=WFBULINNBR
    #----- Alimentation des codes axes pour le multi-référenciels comptabilité -----#
    If dim([F:PSH]DIE)>0 & [F:PSH]DIE(0)=""
      For I=1 To max(GNBDIE,GOPTCANA)
        [F:PSH]DIE(I-1)=GDIE(I)
      Next I
    Endif
    #-----
    COMPTEUR+=1
    Rewrite [PSH]
    If fstat
      Call ECR_TRACE("File PREQUIS"-[F:PSH]PSHNUM+", Error ="-num$(fstat),1) From GESECRAN
    Endif
    #-----
    WNBR+=1
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PSH]PSHNUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PSH : Endif
If func AFNC.ACTIV("MUL")  Close Local File [BPE] : Endif
# Issue 74485 - 2011-06-20 by VPO : lecture des codes activité : garder ACV ouverte
Close Local File [PSH], [PSD], [CAL], [GCM], [CPY], [BPC], [BPS], [ITM], [TCU],
&                [TVC], [TVT], [TRA], [ADI], [ADP], [ADW], [PRS], [PFI] : # [ACV]
Call ECR_TIME("DOSMAJ30 Purchase Request Process 1 : Ended ("+num$(WNBR)+")") From DOSSUB
Return


#--------------------------------------------------------#
# Alimentation des nouveaux champs dans les retours      #
# ------------------------------------------------------ #
# Table PRETURN - Entête retour :                        #
#   CPY     Code société                                 #
#   FFWADD  Code adresse transitaire                     #
#   BPAINV  Code adresse fournisseur facturant           #
#   BPRPAY  Tiers payé                                   #
#   BPAPAY  Code adresse tiers payé                      #
#   VACTYP  Type de régime de taxe                       #
#   EECNAT  Nature transaction 2 car (sup "0" devant)    #
#   EECNUM  Identification CEE                           #
#   DIE     Code axes analytiques                        #
#                                                        #
# Table PRETURND - Lignes retour :                       #
#   CPY     Code société                                 #
#   POHTYP  Type commande                                #
#   BPAINV  Code adresse fournisseur facturant           #
#   BPOCRY       Pays expéditeur                         #
#   SATISS       Province de sortie                      #
#   LINTYP       Type de ligne retour    (1=Normale)     #
#   LINCAT       Catégorie de mouvement  (1=Standard)    #
#   CLCAMT1-3    Base 1-3 calcul taxe                    #
#   BASTAXLIN1   Base taxe ligne                         #
#   AMTTAXLIN1-3 Montant taxe 1-3                        #
#   DEDTAXLIN1-3 Montant taxe 1-3 déductible             #
#   LINATIAMT    Montant TTC ligne                       #
#                                                        #
# Table CPTANALIN - Lignes comptables analytiques        #
#   Création d'enregistrements dans cette nouvelle table #
#   en remplacement des champs comptes et sections       #
#--------------------------------------------------------#
$AV_PNH
Local File =[F:ADS]DOSSIER+".PRETURN"    [PNH]
Local File =[F:ADS]DOSSIER+".PRETURND"   [PND]
Local File =[F:ADS]DOSSIER+".CPTANALIN"  [CAL]
Local File =[F:ADS]DOSSIER+".BPARTNER"   [BPR]
Local File =[F:ADS]DOSSIER+".BPSUPPLIER" [BPS]
Local File =[F:ADS]DOSSIER+".PORDER"     [POH]
Local File =[F:ADS]DOSSIER+".BPADDRESS"  [BPA]
Local File =[F:ADS]DOSSIER+".FACILITY"   [FCY]
Local File =[F:ADS]DOSSIER+".ATABDIV"    [ADI]
Local File =[F:ADS]DOSSIER+".GACM"       [GCM]
Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU]
Local File =[F:ADS]DOSSIER+".TABVAT"     [TVT]
Local File =[F:ADS]DOSSIER+".TABRATVAT"  [TRA]
Local File =[F:ADS]DOSSIER+".PRICSTRUCT" [PRS]
Local File =[F:ADS]DOSSIER+".PFOOTINV"   [PFI]
#----- Variables locales pour le calcul de TVA -----#
Local Char     ABREV(8)
Local Integer  STAT, TYPREG
Local Decimal  BASE, MONTANT(1..3), MONTDED(1..3)
Local Char     TAXE(GLONVAT)(1..3)
Local Decimal  WRND
Local Char     WCUR(GLONCUR)
Local Char     WITMREF(GLONITM)
Local Char     WBPSNUM(GLONBPS)
Local Date     WDOCDAT
Local Char     WVACBPR(GLONADI)
Local Integer  WVACTYP
Local Decimal  WQTYPUU
Local Decimal  WLINAMT, WLINATIAMT
Local Decimal  WCLCAMT(1..7)
#-----
Local Integer  COMPTEUR, STOP, WNBR
Local Char     CLE1(GLONPNH), CRITERE(90)
Local Integer  I
Raz CLE1, STOP, WNBR
Call ECR_TIME("DOSMAJ30 Purchase Return Process 1 : Update PRETURN-D") From DOSSUB
$BOUCLE_PNH
If  STOP=1
  CRITERE = 'PNHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1"
Endif
Raz COMPTEUR
Trbegin [PNH],[PND]
  For [PNH] PNH0 Where evalue(CRITERE)
    #----- Alimentation de la société sur l'entête de retour -----#
    Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:PNH]PNHFCY) From TRTX3CPT
    [F:PNH]CPY=GSOCIETE
    #----- Alimentation code adresse transitaire -----#
    If [F:PNH]FFWNUM<>"" & [F:PNH]FFWADD=""
      If [F:BPR]BPRNUM<>[F:PNH]FFWNUM
        Read [BPR] BPR0=[F:PNH]FFWNUM : If fstat  Raz [F:BPR] : Endif
      Endif
      [F:PNH]FFWADD=[F:BPR]BPAADD
    Endif
    #----- Alimentation code adresse fournisseur facturant -----#
    If [F:PNH]BPAINV=""
      If [F:BPS]BPSNUM<>[F:PNH]BPSINV
        Read [BPS] BPS0=[F:PNH]BPSINV : If fstat  Raz [F:BPS] : Endif
      Endif
      [F:PNH]BPAINV=[F:BPS]BPAADD
    Endif
    #----- Alimentation tiers payé et code adresse tiers payé -----#
    If [F:PNH]BPRPAY=""
      If [F:BPS]BPSNUM<>[F:PNH]BPSNUM
        Read [BPS] BPS0=[F:PNH]BPSNUM : If fstat  Raz [F:BPS] : Endif
      Endif
      [F:PNH]BPRPAY=[F:BPS]BPRPAY
      [F:PNH]BPAPAY=[F:BPS]BPAPAY
    Endif
    #----- Alimentation du type de régime de taxe -----#
    If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[F:PNH]VACBPR
      Read [ADI] CODE=1;[F:PNH]VACBPR : If fstat Raz [F:ADI] : Endif
    Endif
    [F:PNH]VACTYP=[F:ADI]N1
    #----- Passage de la nature transaction CEE à 2 caractères -----#
    If len([F:PNH]EECNAT)>2 & left$([F:PNH]EECNAT,1)="0"
      [F:PNH]EECNAT=right$([F:PNH]EECNAT,2)
    Endif
    #----- Alimentation de l'identification CEE -----#
    If GACTDEB=2 & [F:PNH]EECNUM=""
      If [F:BPR]BPRNUM<>[F:PNH]BPSINV
        Read [BPR] BPR0=[F:PNH]BPSINV : If fstat  Raz [F:BPR] : Endif
      Endif
      [F:PNH]EECNUM=[F:BPR]EECNUM
    Endif
    #----- Alimentation champs pour le multi-référentiels comptabilité -----#
    If dim([F:PNH]DIE)>0 & [F:PNH]DIE(0)=""
      For I=1 To max(GNBDIE,GOPTCANA)
        [F:PNH]DIE(I-1)=GDIE(I)
      Next I
    Endif
    #-----
    COMPTEUR+=1
    Rewrite [PNH]
    If fstat
      Call ECR_TRACE("File PRETURN"-[F:PNH]PNHNUM+", Error ="-num$(fstat),1) From GESECRAN
    Endif
    #-----
    For [PND] PND0 Where PNHNUM=[F:PNH]PNHNUM
      #----- Alimentation société et adresse fourniss. facturant sur lignes retour -----#
      [F:PND]CPY   =[F:PNH]CPY
      [F:PND]BPAINV=[F:PNH]BPAINV
      #----- Alimentation dy type commande -----#
      If [F:PND]POHTYP=0 & [F:PND]POHNUM<>""
        If [F:POH]POHNUM<>[F:PND]POHNUM
          Read [POH] POH0=[F:PND]POHNUM : If fstat  Raz [F:POH] : Endif
        Endif
        [F:PND]POHTYP=[F:POH]POHTYP
      Endif
      #----- Alimentation de la province de sortie et du pays expéditeur -----#
      # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
      #If (func AFNC.ACTIV("PTX") & [F:PND]SATISS="") | [F:PND]BPOCRY=""
      If (func TRTX3.ACTIV_PTX & [F:PND]SATISS="") | [F:PND]BPOCRY=""
        If [F:PND]POHNUM<>""
          If [F:POH]POHNUM<>[F:PND]POHNUM
            Read [POH] POH0=[F:PND]POHNUM : If fstat  Raz [F:POH] : Endif
          Endif
          If [F:POH]BPOSAT<>"" | [F:POH]BPOCRY<>""
            If func TRTX3.ACTIV_PTX & len([F:POH]BPOSAT)<=4 & toupper([F:POH]BPOSAT)=[F:POH]BPOSAT
              [F:PND]SATISS=[F:POH]BPOSAT
            Endif
            [F:PND]BPOCRY=[F:POH]BPOCRY
          Else
            #----- Lecture de l'adresse d'expédition si nécessaire -----#
            If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:POH]BPSNUM | [F:BPA]BPAADD<>[F:POH]BPOADD
              Read [BPA] BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD : If fstat  Raz [F:BPA] : Endif
            Endif
            #-----
            [F:PND]SATISS=[F:BPA]SAT
            If func TRTX3.ACTIV_PTX & len([F:BPA]SAT)<=4 & toupper([F:BPA]SAT)=[F:BPA]SAT
              [F:PND]SATISS=[F:BPA]SAT
            Endif
            [F:PND]BPOCRY=[F:BPA]CRY
          Endif
        Elsif [F:PNH]BETFCY=2 & [F:PND]LINSTOFCY<>""
          #----- Lecture du site d'expédition si nécessaire -----#
          If [F:FCY]FCY<>[F:PND]LINSTOFCY
            Read [FCY] FCY0=[F:PND]LINSTOFCY : If fstat  Raz [F:FCY] : Endif
          Endif
          #----- Lecture de l'adresse d'expédition si nécessaire -----#
          If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[F:PND]LINSTOFCY | [F:BPA]BPAADD<>[F:FCY]BPAADD
            Read [BPA] BPA0=3;[F:PND]LINSTOFCY;[F:FCY]BPAADD : If fstat  Raz [F:BPA] : Endif
          Endif
          #-----
          If func TRTX3.ACTIV_PTX & len([F:BPA]SAT)<=4 & toupper([F:BPA]SAT)=[F:BPA]SAT
            [F:PND]SATISS=[F:BPA]SAT
          Endif
          [F:PND]BPOCRY=[F:BPA]CRY
        Else
          #----- Lecture fournisseur si nécessaire -----#
          If [F:BPS]BPSNUM<>[F:PNH]BPSNUM
            Read [BPS] BPS0=[F:PNH]BPSNUM : If fstat  Raz [F:BPS] : Endif
          Endif
          #----- Lecture de l'adresse d'expédition si nécessaire -----#
          If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:PNH]BPSNUM | [F:BPA]BPAADD<>[F:BPS]BPAADD
            Read [BPA] BPA0=1;[F:PNH]BPSNUM;[F:BPS]BPAADD : If fstat  Raz [F:BPA] : Endif
          Endif
          #-----
          [F:PND]SATISS=[F:BPA]SAT
          If func TRTX3.ACTIV_PTX & len([F:BPA]SAT)<=4 & toupper([F:BPA]SAT)=[F:BPA]SAT
            [F:PND]SATISS=[F:BPA]SAT
          Endif
          [F:PND]BPOCRY=[F:BPA]CRY
        Endif
      Endif
      #----- Calcul des bases et taxes de la ligne de retour -----#
      If [F:PND]BASTAXLIN1=0  ABREV="PND" : Gosub MAJ_CALTAX_LIG : Endif
      #----- Alimentation Type ligne et catégorie de mouvement -----#
      If [F:PND]LINTYP=0  [F:PND]LINTYP=1 : Endif
      If [F:PND]LINCAT=0  [F:PND]LINCAT=1 : Endif
      #----- Création lignes comptables analytiques -----#
      Look [CAL] CAL0="PND";0;[F:PND]PNHNUM;[F:PND]PNDLIN;0;"";1
      If fstat
        Raz [F:CAL]
        [F:CAL]ABRFIC="PND"
        [F:CAL]VCRNUM=[F:PND]PNHNUM
        [F:CAL]VCRLIN=[F:PND]PNDLIN
        [F:CAL]ANALIG=1
        For I=1 To max(GNBCOA,2)
          [F:CAL]LED(I-1)=GLEDSOC(I)
          [F:CAL]COA(I-1)=GCOA(I)
        Next I
        [F:CAL]ACC(0)=[F:PND]LINACC
        [F:CAL]ACC(1)=[F:PND]LINCNA
        For I=1 To max(GNBDIE,GOPTCANA)
          [F:CAL]DIE(I-1)=GDIE(I)
          If evalue("dim([F:PND]CCE"+num$(I)+")")>0
            [F:CAL]CCE(I-1)=evalue("[F:PND]CCE"+num$(I))
          Endif
        Next I
        COMPTEUR+=1
        Write [CAL]
        If fstat
          Call ECR_TRACE("File CPTANALIN PND 0"-[F:PND]PNHNUM-num$([F:PND]PTDLIN)
&                         +", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
      #-----
      COMPTEUR+=1
      Rewrite [PND]
      If fstat
        Call ECR_TRACE("File PRETURND"-[F:PNH]PNHNUM+", Error ="-num$(fstat),1) From GESECRAN
      Endif
    Next
    #-----
    WNBR+=1
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PNH]PNHNUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_PNH : Endif
Close Local File [PNH], [PND], [CAL], [BPR], [BPS], [POH], [BPA], [FCY], [ADI], [GCM],
&                [CPY], [TCU], [TVT], [TRA], [PRS], [PFI]
Call ECR_TIME("DOSMAJ30 Purchase Return Process 1 : Ended ("+num$(WNBR)+")") From DOSSUB
Return


#########################################################################
# MAJ_CALTAX_LIG   : S/P de calcul des bases et des taxes  MBT 02/10/09 #
#                     de la ligne de DA ou de retour                    #
#########################################################################
$MAJ_CALTAX_LIG
#-----
Case ABREV
  When "PSD"
    WCUR   =[F:PSD]CUR
    WITMREF=[F:PSD]ITMREF
    WBPSNUM=[F:PSD]BPSNUM
    WQTYPUU=[F:PSD]QTYPUU
    WDOCDAT=[F:PSH]PRQDAT
    WVACBPR=[F:PSD]VACBPR
    WVACTYP=[F:PSD]VACTYP
    WLINAMT=[F:PSD]LINAMT
  When "PND"
    WCUR   =[F:PND]NETCUR
    WITMREF=[F:PND]ITMREF
    WBPSNUM=[F:PND]BPSNUM
    WQTYPUU=[F:PND]QTYUOM
    WDOCDAT=[F:PND]RTNDAT
    WVACBPR=[F:PNH]VACBPR
    WVACTYP=[F:PNH]VACTYP
    WLINAMT=[F:PND]LINAMT
Endcase
#----- Calcul des taxes du montant ligne (marchandise) -----#
Call ALICLCAMT2(WITMREF,WQTYPUU,-1,ABREV,WCLCAMT) From TRTX3
#-----
TAXE(1)=evalue("[F:"+ABREV+"]VAT(0)")
TAXE(2)=evalue("[F:"+ABREV+"]VAT(1)")
TAXE(3)=evalue("[F:"+ABREV+"]VAT(2)")
#-----
Call CALTAXE2(GSOCIETE,WDOCDAT,WVACBPR,WCUR,3,TAXE,1,WLINAMT,
&             WCLCAMT,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
#-----
Assign "[F:"+ABREV+"]BASTAXLIN1" With evalue("[F:"+ABREV+"]LINAMT")
Assign "[F:"+ABREV+"]CLCAMT1"    With WCLCAMT(1)
Assign "[F:"+ABREV+"]AMTTAXLIN1" With MONTANT(1)
Assign "[F:"+ABREV+"]DEDTAXLIN1" With MONTDED(1)
#-----
If evalue("[F:"+ABREV+"]VAT(1)")=""
  Assign "[F:"+ABREV+"]CLCAMT2"    With 0
  Assign "[F:"+ABREV+"]AMTTAXLIN2" With 0
  Assign "[F:"+ABREV+"]DEDTAXLIN2" With 0
Else
  Assign "[F:"+ABREV+"]CLCAMT2"    With WCLCAMT(2)
  Assign "[F:"+ABREV+"]AMTTAXLIN2" With MONTANT(2)
  Assign "[F:"+ABREV+"]DEDTAXLIN2" With MONTDED(2)
  Read [TVT] TVT0=TAXE(2) : If fstat  Raz [F:TVT] : Endif
  If [F:TVT]VATCHA=2
    Assign "[F:"+ABREV+"]BASTAXLIN1"
&     With evalue("[F:"+ABREV+"]BASTAXLIN1")+evalue("[F:"+ABREV+"]AMTTAXLIN2")
  Endif
Endif
#-----
If evalue("[F:"+ABREV+"]VAT(2)")=""
  Assign "[F:"+ABREV+"]CLCAMT3"    With 0
  Assign "[F:"+ABREV+"]AMTTAXLIN3" With 0
  Assign "[F:"+ABREV+"]DEDTAXLIN3" With 0
Else
  Assign "[F:"+ABREV+"]CLCAMT3"    With WCLCAMT(3)
  Assign "[F:"+ABREV+"]AMTTAXLIN3" With MONTANT(3)
  Assign "[F:"+ABREV+"]DEDTAXLIN3" With MONTDED(3)
  Read [TVT] TVT0=TAXE(3) : If fstat  Raz [F:TVT] : Endif
  If [F:TVT]VATCHA=2
    Assign "[F:"+ABREV+"]BASTAXLIN1"
&     With evalue("[F:"+ABREV+"]BASTAXLIN1")+evalue("[F:"+ABREV+"]AMTTAXLIN3")
  Endif
Endif
#-----
If WVACTYP<>4
  Assign "[F:"+ABREV+"]LINATIAMT"
&   With  evalue("[F:"+ABREV+"]LINAMT")
&        +evalue("[F:"+ABREV+"]AMTTAXLIN1")
&        +evalue("[F:"+ABREV+"]AMTTAXLIN2")
&        +evalue("[F:"+ABREV+"]AMTTAXLIN3")
Else
  Assign "[F:"+ABREV+"]LINATIAMT"
&   With  evalue("[F:"+ABREV+"]LINAMT")
Endif
#----- Calcul de la taxe des montants remises/frais de la ligne tarif -----#
If [F:BPS]BPSNUM<>evalue("[F:"+ABREV+"]BPSNUM")
  Read [BPS] BPS0=evalue("[F:"+ABREV+"]BPSNUM")
  If fstat  Raz [F:BPS] : Endif
Endif
If [F:PRS]BPCBPS<>2 | [F:PRS]PLISTC<>[F:BPS]PLISTC
  Read [PRS] PRS0=2;[F:BPS]PLISTC : If fstat  Raz [F:PRS] : Endif
Endif
#-----
If [F:TCU]CUR<>WCUR
  Read [TCU] TCU0=WCUR
  If !fstat  WRND=[F:TCU]CURRND  Else  WRND=0.01 : Endif
Else
  WRND=[F:TCU]CURRND
Endif
#-----
For I=1 To 9
  If evalue("dim([F:"+ABREV+"]DISCRGVAL"+num$(I)+")")>0
    If [F:PRS]NPRNOTFLG(I-1)=1 & [F:PRS]INVDTA(I-1)<>0
      #----- C'est un montant -----#
      If [F:PRS]VALTYP(I-1)=1
        If [F:PRS]CLCRUL(I-1)=1 : # Par unité
          BASE=arr(evalue("[F:"+ABREV+"]DISCRGVAL"+num$(I))*evalue("[F:"+ABREV+"]QTYPUU"),WRND)
        Else              : # Par ligne
          BASE=evalue("[F:"+ABREV+"]DISCRGVAL"+num$(I))
        Endif
      #----- C'est un pourcentage -----#
      Else
        BASE=arr(evalue("[F:"+ABREV+"]LINAMT")*evalue("[F:"+ABREV+"]DISCRGVAL"+num$(I))/100,WRND)
      Endif
      #----- Inversion du montant si minoration -----#
      If [F:PRS]INCDCR(I-1)=2  BASE=-BASE : Endif
      #----- Màj base et mt taxe ligne si taux produit -----#
      If [F:PFI]PFINUM<>[F:PRS]INVDTA(I-1)
        Read [PFI] PFI0=[F:PRS]INVDTA(I-1) : If fstat  Raz [F:PFI] : Endif
      Endif
      If [F:PFI]VATRUL=1
        Raz TAXE : TAXE(1)=evalue("[F:"+ABREV+"]VAT(0)")
        If BASE<>0
          Call CALTAXE(GSOCIETE,WDOCDAT,WVACBPR,WCUR,1,TAXE,1,
&                      BASE,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
          Assign "[F:"+ABREV+"]BASTAXLIN1" With evalue("[F:"+ABREV+"]BASTAXLIN1")+BASE
          Assign "[F:"+ABREV+"]AMTTAXLIN1" With evalue("[F:"+ABREV+"]AMTTAXLIN1")+MONTANT(1)
          Assign "[F:"+ABREV+"]DEDTAXLIN1" With evalue("[F:"+ABREV+"]DEDTAXLIN1")+MONTDED(1)
        Endif
      Endif
    Endif
  Endif
Next I
#-----
Return


##################################
# Traitement des bases spéciales #
##################################
$TRT_BASE
If WTAX<>""
  If [F:TVT]VAT<>WTAX
    Read [TVT] TVT0=WTAX : If fstat  Raz [F:TVT] : Endif
  Endif
  If [F:TVT]VATBAS=2 & WCLCAMT1<>0
    WCLCFLG1=1 : WCLCAMT(I)=WCLCAMT1 : WCLCFLG(I)=1
  Endif
  If [F:TVT]VATBAS=3 & WCLCAMT2<>0
    WCLCFLG2=1 : WCLCAMT(I)=WCLCAMT2 : WCLCFLG(I)=1
  Endif
Endif
Return

