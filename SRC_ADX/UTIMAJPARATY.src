#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Initialisation of short description
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("init MNL 10030 ") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTAB
End

#----------------------------------------------------------------------------------------#

#----------------------------------------------------------------------------------------#
$MAJTAB
Local Integer VERIF_OK

If DOSSIER=nomap
 Local File ACLAPARDEF  [ACLPD] : # TYPINTPAR
 Local File ACLAPARFLD [ACLFP]: # TYPINT
 Local File ASHWPAR    [ASWP] : # TYPINT
 Local File ASHWPARMET [ASWMP] : # TYPPARMET
 Local File ATYPELPAR [ATYLP] : # PARTYP
 Local File ATYPERPAR [ATYRP] : # PARTYP
Else
 Local File =DOSSIER+".ACLAPARDEF" [ACLPD]: # TYPINTPAR
 Local File =DOSSIER+".ACLAPARFLD" [ACLFP]: # TYPINT
 Local File =DOSSIER+".ASHWPAR" [ASWP]: # TYPINT
 Local File =DOSSIER+".ASHWPARMET" [ASWMP] : # TYPPARMET
 Local File =DOSSIER+".ATYPELPAR" [ATYLP] : # PARTYP
 Local File =DOSSIER+".ATYPERPAR" [ATYRP] : # PARTYP
Endif

Gosub VERIF

If VERIF_OK>0
 Trbegin [ACLPD]
  Gosub MAJ_ACLPD
  Gosub MAJ_ACLFP
  Gosub MAJ_ASWP
  Gosub MAJ_ASWMP
  Gosub MAJ_ATYRP
  Gosub MAJ_ATYLP
 Commit
Endif

Close Local File [ACLPD],[ACLFP],[ASWP],[ASWMP],[ATYRP],[ATYLP]

Return

$VERIF
VERIF_OK = 1
For [F:ACLPD]ACLPD0
 If [F:ACLPD]AWMAJTYP=1
  VERIF_OK = 0 : Break
 Endif
Next
If VERIF_OK = 0 : Return : Endif

For [F:ATYRP]ATYRP0
 If [F:ATYRP]AWMAJTYP=1
  VERIF_OK = 0 : Break
 Endif
Next
If VERIF_OK = 0 : Return : Endif

For [F:ATYLP]ATYLP0
 If [F:ATYLP]AWMAJTYP=1
  VERIF_OK = 0 : Break
 Endif
Next
If VERIF_OK = 0 : Return : Endif

For [F:ASWMP]ASWMP0
 If [F:ASWMP]AWMAJTYP=1
  VERIF_OK = 0 : Break
 Endif
Next
If VERIF_OK = 0 : Return : Endif

For [F:ASWP]ASWP0
 If [F:ASWP]AWMAJTYP=1
  VERIF_OK = 0 : Break
 Endif
Next
If VERIF_OK = 0 : Return : Endif

For [F:ACLFP]ACLFP0
 If [F:ACLFP]AWMAJTYP=1
  VERIF_OK = 0 : Break
 Endif
Next
If VERIF_OK = 0 : Return : Endif

Return

##----------------------------------------------------------------------------------------#
$MAJ_ATYRP
If dim([F:ATYRP]AWMAJTYP)>0
 For [F:ATYRP]ATYRP0
  If [F:ATYRP]AWMAJTYP=0
   [F:ATYRP]AWMAJTYP=1
   [F:ATYRP]PARTYP = func AFNC.TYP33_10030( [F:ATYRP]PARTYP)
   Rewrite [F:ATYRP]
   If fstat
    Call ERREUR("ATYPERPAR"-[F:ATYRP]CODTYP-"~"-[F:ATYRP]TYPRUL-"~"-[F:ATYRP]TRTRUL+"~"+[F:ATYRP]PRGRUL+"~"+[F:ATYRP]PARCOD,2) From DOSDIC
   Endif
  Endif
 Next
Endif
Return

##----------------------------------------------------------------------------------------#
$MAJ_ATYLP
If dim([F:ATYLP]AWMAJTYP)>0
 For [F:ATYLP]ATYLP0
  If [F:ATYLP]AWMAJTYP=0
   [F:ATYLP]AWMAJTYP=1
   [F:ATYLP]PARTYP = func AFNC.TYP33_10030( [F:ATYLP]PARTYP)
   Rewrite [F:ATYLP]
   If fstat
    Call ERREUR("ATYPELPAR"-[F:ATYLP]CODTYP-"~"-[F:ATYLP]CODLNK-"~"-[F:ATYLP]PARCOD,2) From DOSDIC
   Endif
  Endif
 Next
Endif
Return

##----------------------------------------------------------------------------------------#
$MAJ_ASWMP
If dim([F:ASWMP]AWMAJTYP)>0
 For [F:ASWMP]ASWMP0
  If [F:ASWMP]AWMAJTYP=0
   [F:ASWMP]AWMAJTYP=1
   [F:ASWMP]TYPPARMET = func AFNC.TYP33_10030( [F:ASWMP]TYPPARMET)
   Rewrite [F:ASWMP]
   If fstat
    Call ERREUR("ASHWPARMET"-[F:ASWMP]CODREP-"~"-[F:ASWMP]CODFLD-"~"-[F:ASWMP]CODPAR,2) From DOSDIC
   Endif
  Endif
 Next
Endif
Return

##----------------------------------------------------------------------------------------#
$MAJ_ASWP
If dim([F:ASWP]AWMAJTYP)>0
 For [F:ASWP]ASWP0
  If [F:ASWP]AWMAJTYP=0
   [F:ASWP]AWMAJTYP=1
   [F:ASWP]TYPINT= func AFNC.TYP33_10030( [F:ASWP]TYPINT)
   Rewrite [F:ASWP]
   If fstat
    Call ERREUR("ASHWPAR"-[F:ASWP]CODREP-"~"-[F:ASWP]CODFLD-"~"-[F:ASWP]CODPAR,2) From DOSDIC
   Endif
  Endif
 Next
Endif
Return

##----------------------------------------------------------------------------------------#
$MAJ_ACLPD
If dim([F:ACLPD]AWMAJTYP)>0
 For [F:ACLPD]ACLPD0
  If [F:ACLPD]AWMAJTYP=0
   [F:ACLPD]AWMAJTYP=1
   [F:ACLPD]TYPINTPAR = func AFNC.TYP33_10030( [F:ACLPD]TYPINTPAR)
   Rewrite [F:ACLPD]
   If fstat
    Call ERREUR("ACLAPARDEF"-[F:ACLPD]FLDCLA-"~"-[ACLPD]CODFLD-"~"-[F:ACLPD]CODPAR,2) From DOSDIC
   Endif
  Endif
 Next
Endif
Return

##----------------------------------------------------------------------------------------#
$MAJ_ACLFP
If dim([F:ACLFP]AWMAJTYP)>0
 For [F:ACLFP]ACLFP0
  If [F:ACLFP]AWMAJTYP=0
   [F:ACLFP]AWMAJTYP=1
   [F:ACLFP]TYPINT = func AFNC.TYP33_10030( [F:ACLFP]TYPINT)
   Rewrite [F:ACLFP]
   If fstat
    Call ERREUR("ACLAPARFLD"-[F:ACLFP]FLDCLA-"~"-[F:ACLFP]CODFLD-"~"-[F:ACLFP]CODPAR,2) From DOSDIC
   Endif
  Endif
 Next
Endif
Return
