#<AdxTL>@(#)5.0.0.0 $Revision$
############################################################################################
## CONTACC(ACCES)                           => Contrôle que le code d'accès est autorisé
## CONSACC(ACCES,DROIT)                     => Lecture du droit de consulter la fiche
## LECACC(ACCES,DROIT)                      => Lecture du droit de modifier la fiche
## CONTEXE(ACCES)                           => Contrôle droit d'exécution
## CONTUSR(SOCIETE,SITE)                    => Droit de modifier la zone utilisateur
## CONTAUZ(SOCIETE,SITE,OPT)                => Contrôle droit pour une option d'une fonction
## DROITSITE(SITE,AUZ,OK)                   => Droits sur site pour la fonction, avec recherche droit sur la fonction associée à l'option
## DROITSITEF(FNC,SITE,AUZ,OK)              => Droits sur site pour une fonction
## CONTFCY(VALEUR)                          => Contrôle que le site est autorisé pour la fonction courante
## CONTCPY(SOC)                             => Contrôle que la société est autorisée pour la fonction courante
## INIFCY(SITE,SOC)                         => Recherche du site par défaut d'une société
## INICPY(SOC)                              => Recherche de la société par par défaut
## CONTALLFCY(SOC)                          => Contrôle que tous les sites d'une société sont accessibles
## CONTFCYCPY(SITE,SOC)                     => Contrôle que le site/société sont cohérents
## CONTALLCPY(GROUPE)                       => Contrôle que toutes les sociétés d'un groupe sont accessibles
## DATDEBFIN(DATFIN,DATDEB)                 => Contrôle qu'une date de fin est inférieure à date début
## FILTRE(CHAINE,LISTE)                     => Ne garde que les caractères voulus dans une chaine
## GETEXE(SOC,TYPLED,DAT,EXE)               => Détermination no exercice d'une société d'après une date
## GETPER(SIT,TYPLED,DAT,EXE,PER)           => Définition exercice et période d'après la date (site)
## GETPERSOC(SOC,TYPLED,DAT,EXE,PER)        => Définition exercice et période d'après la date (société)
## NBPER(SOC,TYPLED,EXE,NBPER)              => Nombre de périodes d'un exercice
## PREMEX(SOC,TYPLED,DAT)                   => Date début premier exercice ouvert
## DEREX(SOC,TYPLED,DAT)                    => Dernière date dernière période ouverte
## DEFPER(SOC,TYPLED,DATDEB,DATFIN)         => Dates début et fin de l'exercice par défaut
## DEFEXE(SOC,TYPLED,EXE)                   => Exercice par défaut pour une société
## DATEXE(SOC,TYPLED,EXE,DATDEB,DATFIN)     => Dates début et fin d'un exercice
## DATPER(SOC,TYPLED,EXE,PER,DATDEB,DATFIN) => Dates début et fin d'une période
## CONTSAC(SAC)                             => OBSOLETE
## CTLVLYDAT(DAT,DATDEB,DATFIN)             => Contrôle de limite de validité d'une date
## CTLDATMOD(MODULE,DAT)                    => Contrôle de la date de création d'un document selon date du module
##
## Conversion en devises
## CONVERT_TAB(NB,ORG,DES,COURS,ARRONDI)    => OBSOLETE
## CONVERT_DEV(DEVORG,DEVDES,DEVSOC,NB,ORG,DES,COURS,TYPCOURS,DATCOURS,ARRONDI)
##                                          => OBSOLETE
## CONVERT_SIT(DEVORG,DEVDES,DEVSOC,NB,DEBORG,DEBDES,CREORG,CREDES
##             ,FLTRICHE,TRICHE,SITE,TYPCOURS,DATCOURS,COURS,ARRONDI,STAT)
##                                          => OBSOLETE
## CONVERT3(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,COURS,STAT)
##                                          => Conversion montant
##
## CONTCPT(VALEUR,PLAN)                     => Contrôle du compte utilisé par le type de données GAC
## CONTPER(VALEUR,TYPLED,SIT)               => Contrôle périodes
## CONTBAN(DAT,BANQ,DEV)                    => Contrôle de la devise de tenue du compte de banque
## CONTBPRCPY(VALEUR,SIT,COA,COLL,BPRTYP)   => Contrôle Tiers/Société Zone tiers
## CONTBPRCP2(VALEUR,SIT,COA,BPRNUM,BPRTYP) => Contrôle Tiers/Société Zone collectif
## INIT_REGIME(TIERS,SIT,BPRTYP,REGIME)     => Recherche du régime taxe du tiers
##
############################################################################################
# Issue X3-70764 - 2018-01-19 by FHA : Excluding proformas

################################################################
## Contrôle que le code d'accès est autorisé                  ##
################################################################
Subprog CONTACC(ACCES)
Value    Char     ACCES
If ACCES="" : End : Endif
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC = GUSER;ACCES
If GUSRACS=2
 If fstat
  # Code inexistant
  GMESSAGE = ACCES-":"-mess(84,141,1) : mkstat = 2 : End
 Endif
Else
 If fstat
  # Vous n'avez pas accès à ce code
  GMESSAGE = ACCES-":"-mess(3,104,1) : mkstat = 2 : End
 Endif
 If [F:ACC]MODIF<>2
  # Vous n'avez pas les droits pour ce code
  GMESSAGE = ACCES-":"-mess(4,104,1) : mkstat = 2 : End
 Endif
Endif
End

################################################################
## Lecture du droit de consulter la fiche                     ##
################################################################
Subprog CONSACC(ACCES,DROIT)
Value    Char    ACCES
Variable Integer DROIT
If ACCES="" or GUSRACS=2 : DROIT = 1 : End : Endif
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC = GUSER;ACCES
If !fstat & [F:ACC]CONSUL=2
 DROIT = 1
Else
 DROIT = 0
Endif
End

################################################################
## Lecture du droit de modifier la fiche                      ##
################################################################
Subprog LECACC(ACCES,DROIT)
Value    Char    ACCES
Variable Integer DROIT
If ACCES="" or GUSRACS=2 : DROIT = 1 : End : Endif
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC = GUSER;ACCES
If !fstat & [F:ACC]MODIF=2
 DROIT = 1
Else
 DROIT = 0
Endif
End

################################################################
## Contrôle droit d'exécution                                 ##
################################################################
Subprog CONTEXE(ACCES)
Value    Char    ACCES
If ACCES="" or GUSRACS=2 : mkstat = 0 : End : Endif
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC = GUSER;ACCES
If fstat | [F:ACC]EXEC<>2
 # Vous n'avez pas les droits d'exécution
 GMESSAGE = mess(7,104,1)
 mkstat = 1
Else
 mkstat = 0
Endif
End

################################################################
## Droit de modifier la zone utilisateur                      ##
################################################################
Subprog CONTUSR(SOCIETE,SITE)
Value Char    SOCIETE, SITE
Call CONTAUZ(SOCIETE,SITE,"U")
End

################################################################
## Contrôle droit pour une option d'une fonction              ##
################################################################
Subprog CONTAUZ(SOCIETE,SITE,OPT)
Value Char    SOCIETE, SITE, OPT
Local Char    AUZ(15)
Local Integer I, OK

If OPT="" : End : Endif

If clalev([F:AFT])=0 : Local File AFCTFCT   [AFT] : Endif
Read [AFT]AFT0 = GPROFIL
If [F:AFT]ALLFCT=2 : End : Endif

If SITE<>""
 Call DROITSITE(SITE,AUZ,OK)
 If !OK | !instr(1,AUZ,OPT)
  mkstat = 2
 Endif
Elsif SOCIETE=""
 For I=1 To GNBSITE
  Call DROITSITE(GSITE(I),AUZ,OK)
  If !OK | !instr(1,AUZ,OPT)
   mkstat = 2 : Break
  Endif
 Next I
Else
 For I=1 To GNBSITE
  If GSOCSITE(I)=SOCIETE
   Call DROITSITE(GSITE(I),AUZ,OK)
   If !OK | !instr(1,AUZ,OPT)
    mkstat = 2 : Break
   Endif
  Endif
 Next I
Endif
End

################################################################
##  Droits sur site pour la fonction                          ##
##  Avec recherche droit sur la fonction associée à l'option  ##
################################################################
Subprog DROITSITE(SITE,AUZ,OK)
Value    Char     SITE
Variable Char     AUZ
Variable Integer  OK
Local    Integer  I, J, ISITE
Local    Char     BID(15), AUZAFC(15), OCODINT(10)

Gosub DROIT : # Droit sur la fonction courante
If !OK : End : Endif

If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
OCODINT = [F:AFC]CODINT
If [F:AFC]CODINT<>GFONCTION
 Read [AFC]CODINT = GFONCTION
Endif

Raz AUZAFC
For I=1 To len(AUZ)
 Raz OK
 J = find(mid$(AUZ,I,1),[F:AFC]FLAG(0..dim([F:AFC]FLAG)-1)) : # Fonction associée à l'option ?
 If J & [F:AFC]FNCOPT(J-1)<>""
  Call DROITSITEF([F:AFC]FNCOPT(J-1),SITE,BID,OK)
  If [F:AFC]CODINT<>GFONCTION
   Read [AFC]CODINT = GFONCTION
  Endif
 Else
  OK = 1
 Endif
 If OK : AUZAFC += mid$(AUZ,I,1) : Endif
Next I
AUZ = AUZAFC
OK  = 1 : # Il a quand même droit à la fonction courante

If OCODINT<>[F:AFC]CODINT & OCODINT<>""
 If [F:AFC]CODINT<>OCODINT
  Read [AFC]CODINT = OCODINT
 Endif
Endif
End

$DROIT
Raz OK, AUZ
If GNBAUZ=0
 # mkstat = 1 : GMESSAGE = mess(1,123,1) : # Fonction non autorisée
Elsif GUSRFCY(1)="\"
 AUZ = GUSRAUZ(1)
 OK  = 1
Elsif SITE<>""
 ISITE = find(SITE,GUSRFCY(1..GNBAUZ))
 If ISITE
  AUZ = GUSRAUZ(ISITE)
  OK  = 1
 Else
  # mkstat = 1 : GMESSAGE = SITE-":"-mess(2,104,1) : # Vous n'avez pas les droits pour ce site
 Endif
Elsif SITE="" : # Condensé des autorisations tous sites confondus
 For I=1 To GNBAUZ
  For J=1 To len(GUSRAUZ)
   If !instr(1,AUZ,mid$(GUSRAUZ(I),J,1))
    AUZ += mid$(GUSRAUZ(I),J,1)
   Endif
  Next J
 Next I
 OK = 1
Endif
Return

################################################################
## Droits sur site pour une fonction                          ##
################################################################
Subprog DROITSITEF(FNC,SITE,AUZ,OK)
Value    Char    FNC
Value    Char    SITE
Variable Char    AUZ
Variable Integer OK
Local    Integer ISITE
Local    Char    OGFONCTION(10)
OGFONCTION = GFONCTION
If FNC<>GFONCTION
 GFONCTION  = FNC
 Call AUTORIS From EXEFNC
Endif
Gosub DROIT
If GFONCTION<>OGFONCTION
 GFONCTION = OGFONCTION
 Call AUTORIS From EXEFNC
Endif
End

#################################################################
## Contrôle que le site est autorisé pour la fonction courante ##
#################################################################
Subprog CONTFCY(VALEUR)
Value Char     VALEUR
If VALEUR="" : End : Endif
Raz mkstat
If GUSRFCY(1)<>"\" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
 GMESSAGE = VALEUR-":"-mess(2,104,1) : # Vous n'avez pas les droits pour ce site
 mkstat = 2
Endif
End

Subprog CONTCPY(SOC)
Value Char    SOC
Local    Integer ISITE, I, OK
If [L]SOC="" : End : Endif
If GUSRFCY(1)="\" : End : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
Raz mkstat, OK
Call LEC_CPY([L]SOC) From CPTLEC
Case [F:CPY]CPYLEGFLG
 When 2  : # Société juridique
  For I=1 To GNBSITE
   If [L]SOC=GSOCSITE(I) & find(GSITE(I),GUSRFCY(1..GNBAUZ))
    OK = 1 : Break
   Endif
  Next I
 When Default
  For [FGR]FGR0 Where CPY=[L]SOC
   If find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
    OK = 1 : Break
   Endif
  Next
Endcase
If !OK
 GMESSAGE = [L]SOC-mess(31,104,1) : # Aucun site n'est accessible dans cette société
 mkstat = 1
Endif
End

#################################################################
## Recherche du site par défaut d'une société                  ##
#################################################################
Subprog INIFCY(SITE,SOC)
Variable Char    SITE
Value    Char    SOC
Local    Integer I, K
Local    Char    NEWSITE(10)
If mkstat : End : Endif   :# GB 260301 : ajout mkstat
K = 0
If [L]SOC=""
 If GUSRFCY(1)="\"
  [L]NEWSITE = GFCYDEF(0)
 Elsif find(GFCYDEF(0),GUSRFCY(1..GNBAUZ)) : # A-t-on les autorisations pour le site par défaut ?
  [L]NEWSITE = GFCYDEF(0)
  If GNBAUZ=1
   K = 1 : # C'est le seul site
  Endif
 Else
  [L]NEWSITE = GUSRFCY(1) : # On prend le premier site autorisé
  If GNBAUZ=1
   K = 1 : # C'est le seul site
  Endif
 Endif
Else
 If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
 If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
 Call LEC_CPY([L]SOC) From CPTLEC
 Case [F:CPY]CPYLEGFLG
  When 2 : # Société juridique
   I = find(GFCYDEF(0),GSITE(1..GNBSITE))
   If I & GSOCSITE(I)=[L]SOC & (GUSRFCY(1)="\" | find(GFCYDEF(0),GUSRFCY(1..GNBAUZ)))
    [L]NEWSITE = GFCYDEF(0)
   Else
    I = find([F:CPY]MAIFCY,GSITE(1..GNBSITE))
    If I & GSOCSITE(I)=[L]SOC & (GUSRFCY(1)="\" | find([F:CPY]MAIFCY,GUSRFCY(1..GNBAUZ)))
     [L]NEWSITE = [F:CPY]MAIFCY
    Endif
   Endif
   For I=1 To GNBSITE
    If [L]SOC=GSOCSITE(I) & (GUSRFCY(1)="\" | find(GSITE(I),GUSRFCY(1..GNBAUZ)))
     If [L]NEWSITE=""
      [L]NEWSITE = GSITE(I)
     Endif
     K += 1
    Endif
   Next I
  When Default
   For [FGR]FGR0 Where CPY=[L]SOC
    If GUSRFCY(1)="\" | find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
     If [L]NEWSITE="" | [F:FGR]FCY=GFCYDEF(0)
      [L]NEWSITE = [F:FGR]FCY
     Endif
     K += 1
    Endif
   Next
 Endcase
Endif
If [L]SITE="" | ([L]SITE<>[L]NEWSITE & K=1)  # GB 28/09/01: si site<>"", il n'était pas réaffecté
 [L]SITE = [L]NEWSITE
Endif
## PP 06/11/2001 : Ce mkstat=2 posait problème dans les écrans qui appelaient l'action
## INIFCY et qui appelaient d'autres actions en contrôle, après zone, après modif
## (écrans saisie pièces, saisie par lot, fiche immo,...)
#If K=1 : # Un seul site accessible dans la société
# mkstat = 2
#Endif
End

Subprog INICPY(SOC)
Variable Char     SOC
Local    Integer  ISITE, OK, I
If [L]SOC<>"" : End : Endif
If GUSRFCY(1)="\" : # Pas d'autorisation par site -> on prend la société du site par défaut
 ISITE = find(GFCYDEF(0),GSITE(1..GNBSITE))
 If ISITE
  [L]SOC = GSOCSITE(ISITE)
 Endif
Elsif GNBAUZ=1 : # Accès qu'à un site
 ISITE = find(GUSRFCY(1),GSITE(1..GNBSITE))
 If ISITE
  [L]SOC = GSOCSITE(ISITE)
  # mkstat = 2 : # PP 08/03/2001 : Bug 13335 (Idem ce qui a été corrigé dans INIFCY le 06/11/01)
 Endif
Else  : # On prend le site par défaut du module
 ISITE = find(GFCYDEF(0),GSITE(1..GNBSITE))
 If ISITE
  OK = 0
  For I=1 To GNBSITE
   If GSOCSITE(I)=GSOCSITE(ISITE) & find(GSITE(I),GUSRFCY(1..GNBAUZ))
    OK = 1 : Break : # Il existe au moins un site accessible dans cette société
   Endif
  Next I
  If OK
   [L]SOC = GSOCSITE(ISITE)
  Else : # On prend le premier site accessible
   ISITE = find(GUSRFCY(1),GSITE(1..GNBSITE))
   If ISITE
    [L]SOC = GSOCSITE(ISITE)
   Endif
  Endif
 Endif
Endif
End

################################################################
## Contrôle que tous les sites d'une société sont accessibles  #
################################################################
Subprog CONTALLFCY(SOC)
Variable Char     SOC
Local    Integer  I, OK
If [L]SOC="" : End : Endif
If GUSRFCY(1)="\" : End : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
Call LEC_CPY([L]SOC) From CPTLEC
Raz mkstat, OK
Case [F:CPY]CPYLEGFLG
 When 2 : # Société juridique
  OK = find([L]SOC,GSOCSITE(1..GNBSITE))
  For I=1 To GNBSITE
   If [L]SOC=GSOCSITE(I) & !find(GSITE(I),GUSRFCY(1..GNBAUZ))
    OK = -1 : Break
   Endif
  Next I
 When Default
  For [FGR]FGR0 Where CPY=[L]SOC
   OK = 1
   If !find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
    OK = -1 : Break
   Endif
  Next
Endcase
Case OK
 When  0
  GMESSAGE = [L]SOC-mess(31,104,1) : # Aucun site n'est accessible dans cette société
  mkstat = 2 : End
 When -1
  GMESSAGE = mess(32,104,1)-[L]SOC : # Tous les sites ne sont pas accessibles dans la société
  mkstat = 2 : End
Endcase
End

################################################
## Contrôle que site et société sont cohérent  #
################################################
Subprog CONTFCYCPY(SITE,SOC)
Value    Char    SITE
Value    Char    SOC
If [L]SITE="" or [L]SOC="" : End : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
If [F:CPY]CPY<>[L]SOC
 Read [CPY]CPY0 = [L]SOC
Endif
If [F:FCY]FCY<>[L]SITE
 Read [FCY]FCY0 = [L]SITE
Endif
Raz mkstat
Case [F:CPY]CPYLEGFLG
 When 2
  If [F:FCY]LEGCPY<>[L]SOC
   GMESSAGE = [L]SITE-mess(30,106,1)-[F:FCY]LEGCPY : # Ce site est dans la société
   mkstat = 2 : End
  Endif
 When Default
  Look [FGR]FGR0 = [L]SOC ; [L]SITE
  If fstat
   GMESSAGE = [L]SITE-mess(34,104,1)-[L]SOC : # Le site doit appartenir au groupe
   mkstat = 2 : End
  Endif
Endcase
End

##################################################################
## Contrôle que toutes les sociétés d'un groupe sont accessibles #
##################################################################
Subprog CONTALLCPY(GROUPE)
Variable Char    GROUPE
Local    Integer I
If GROUPE="" : End : Endif
If GUSRFCY(1)="\" : End : Endif
If clalev([F:AGC])=0 : Local File =GTABCPT+"AGRPCPY" [AGC] : Endif
Raz mkstat
For [AGC]AGC0 Where GRP=GROUPE
 For I=1 To GNBSITE
  If GSOCSITE(I)=[F:AGC]CPY & !find(GSITE(I),GUSRFCY(1..GNBAUZ))
   GMESSAGE = GROUPE-mess(32,104,1)-[F:AGC]CPY : # Tous les sites ne sont pas accessibles dans la société
   mkstat = 1 : Break 2
  Endif
 Next I
Next
End

################################################################
## Contrôle qu'une date de fin est inférieure à date début    ##
################################################################
Subprog DATDEBFIN(DATFIN,DATDEB)
Value Date DATDEB
Value Date DATFIN
If DATFIN<>[0/0/0] & DATFIN<DATDEB
 GMESSAGE = mess(1,104,1)
 mkstat = 2
# Date incorrecte
Endif
End

###############################################################
## Ne garde que les caractères voulus dans une chaine        ##
###############################################################
Subprog FILTRE(CHAINE,LISTE)
Variable Char CHAINE
Value    Char LISTE
Local Integer I , CHIFFRE , MAJUS , MINUS , OK
Local Char    C(1) , LISTE1(10) , LISTE2(80)
I = instr(1,LISTE,"\")
If I
 LISTE1 = left$(LISTE,I-1)
 LISTE2 = right$(LISTE,I+1)
Else
 LISTE1 = LISTE
Endif
If instr(1,LISTE1,"#")
 CHIFFRE = 1
Endif
If instr(1,LISTE1,"A")
 MAJUS = 1
Endif
If instr(1,LISTE1,"B")
 CHIFFRE = 1 : MAJUS = 1
Endif
If instr(1,LISTE1,"L")
 MAJUS = 1 : MINUS = 1
Endif
I = 1
While I<=len(CHAINE)
 C = mid$(CHAINE,I,1)
 If MAJUS & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ",C) : OK = 1
 Elsif MINUS & instr(1,"abcdefghijklmnopqrstuvwxyz",C) : OK = 1
 Elsif CHIFFRE & instr(1,"0123456789",C) : OK = 1
 Elsif instr(1,LISTE2,C) : OK = 1
 Else : OK = 0
 Endif
 If !OK
  CHAINE = left$(CHAINE,I-1)+right$(CHAINE,I+1)
 Else
  I += 1
 Endif
Wend
End

#################################################################
#   Détermination no exercice d'une société d'après une date    #
#################################################################
Subprog GETEXE(SOC,TYPLED,DAT,EXE)
Value    Char    SOC
Value    Integer TYPLED
Value    Date    DAT
Variable Decimal EXE
Gosub GET_FISCALYEAR
End

#Fiscalyear number from a company and a date #
Subprog GETFIY(CPY,LEDTYP,DAT,FIY)
Value    Char    CPY
Value    Integer LEDTYP
Value    Date    DAT
Variable Integer FIY
#
Local Char SOC
Local Integer TYPLED,EXE
SOC = CPY
TYPLED = LEDTYP
Gosub GET_FISCALYEAR
FIY = EXE
End

$GET_FISCALYEAR
If TYPLED<1 : End : Endif
# Si Référentiel automatique, il faut recherche les exercices/périodes du référentiel saisi.
Local Char    MODELE(GLONGCM)
Call SETGCM(SOC,MODELE) From CPTDIV
If !clalev([GCM]) : Local File GACM [GCM] : Endif
Call LEC_GCM(MODELE) From CPTLEC
If [F:GCM]CFMAUT(TYPLED-1)=2
 TYPLED = [F:GCM]ORILEDTYP(TYPLED-1)
Endif

Raz EXE
If clalev([F:FIY])=0 : Local File =GTABCPT+"FISCALYEAR" [FIY] : Endif
If DAT>=[F:FIY]FIYSTR & DAT<=[F:FIY]FIYEND & SOC=[F:FIY]CPY & TYPLED=[F:FIY]LEDTYP
 EXE = [F:FIY]FIYNUM
 Return
Endif
For [FIY]FIY0 Where CPY=SOC & DAT>=[F:FIY]FIYSTR & DAT<=[F:FIY]FIYEND & TYPLED=[F:FIY]LEDTYP
 EXE = [F:FIY]FIYNUM
 Break
Next
Return

#################################################################
#   Définition exercice et période d'après la date              #
#################################################################
Subprog GETPER(SIT,TYPLED,DAT,EXE,PER)
Value    Char    SIT
Value    Integer TYPLED
Value    Date    DAT
Variable Decimal EXE
Variable Decimal PER
#
Gosub SETSOC
Gosub SETPER
End

Subprog GETPERIOD(FCY,LEDTYP,DAT,FIY,PER)
Value    Char    FCY
Value    Integer LEDTYP
Value    Date    DAT
Variable Integer FIY
Variable Integer PER
#
Local Char SIT
Local Integer TYPLED,EXE
SIT = FCY
TYPLED = LEDTYP
Gosub SETSOC
Gosub SETPER
FIY = EXE
End

Subprog GETPERSOC(SOC,TYPLED,DAT,EXE,PER)
Value    Char    SOC
Value    Integer TYPLED
Value    Date    DAT
Variable Decimal EXE
Variable Decimal PER
#
Gosub SETPER
End

Subprog GETPERCPY(CPY,LEDTYP,DAT,FIY,PER)
Value    Char    CPY
Value    Integer LEDTYP
Value    Date    DAT
Variable Integer FIY
Variable Integer PER
#
Local Char SIT,SOC
Local Integer TYPLED,EXE
SOC = CPY
TYPLED = LEDTYP
Gosub SETPER
FIY = EXE
End


$SETPER
If clalev([F:GCM])=0 : Local File =GTABCPT+"GACM"   [GCM] : Endif
If clalev([F:PER])=0 : Local File =GTABCPT+"PERIOD" [PER] : Endif
Raz EXE, PER

If TYPLED < 1 : Return : Endif
# Si Référentiel automatique, il faut recherche les exercices/périodes du référentiel saisi.
Local Char    MODELE(GLONGCM)
Call SETGCM(SOC,MODELE) From CPTDIV
Call LEC_GCM(MODELE) From CPTLEC
If [F:GCM]CFMAUT(TYPLED-1)=2
 TYPLED = [F:GCM]ORILEDTYP(TYPLED-1)
Endif

If DAT>=[F:PER]PERSTR & DAT<=[F:PER]PEREND & SOC=[F:PER]CPY & TYPLED=[F:PER]LEDTYP
 EXE = [F:PER]FIYNUM
 PER = [F:PER]PERNUM
 Return
Endif
For [PER]PER0 Where CPY=SOC & PERSTR<=DAT & PEREND>=DAT & LEDTYP=[L]TYPLED
 EXE = [F:PER]FIYNUM
 PER = [F:PER]PERNUM
Next
Return

$SETSOC
Local Char SOC(GLONCPY)
If clalev([F:PER])=0 : Local File =GTABCPT+"PERIOD"   [PER] : Endif
If clalev([F:FCY])=0 : Local File FACILITY            [FCY] : Endif
If SIT = ""
 SOC = GDEFSOC
Else
 If [F:FCY]FCY<>SIT
  Read [FCY]FCY0 = SIT
 Endif
 SOC = [F:FCY]LEGCPY
Endif
Return

#################################################################
#   Nombre de périodes d'un exercice                           ##
#################################################################
Subprog NBPER(SOC,TYPLED,EXE,NBPER)
Value    Char    SOC
Value    Integer TYPLED
Value    Decimal EXE
Variable Integer NBPER
Goto NUMBER_OF_PERIOD
############################################
# Number of period defined in a fiscalyear #
############################################
Subprog NBPERIOD(CPY,LEDTYP,FIY,NBPER)
Value    Char    CPY
Value    Integer LEDTYP
Value    Integer FIY
Variable Integer NBPER
#
Local Char SOC
Local Integer TYPLED,EXE
SOC = CPY
TYPLED = LEDTYP
EXE = FIY
Goto NUMBER_OF_PERIOD

$NUMBER_OF_PERIOD
If !clalev([F:PER]) : Local File PERIOD     [PER] : Endif

Filter [PER] Where CPY=SOC & FIYNUM=EXE & LEDTYP=[L]TYPLED
Read [PER]PER0 Last
If !fstat
 NBPER=[F:PER]PERNUM
Endif
Filter [PER]
End

#################################################################
#   Date début premier exercice ouvert                          #
#################################################################
Subprog PREMEX(SOC,TYPLED,DAT)
Value    Char    SOC
Value    Integer TYPLED
Variable Date    DAT
Goto FIRST_FISCALYEAR
###############################################
#  First date of the first opened fiscalyear  #
###############################################
Subprog FIRSTFIY(CPY,LEDTYP,DAT)
Value    Char    CPY
Value    Integer LEDTYP
Variable Date    DAT
#
Local Char SOC
Local Integer TYPLED
SOC = CPY
TYPLED = LEDTYP
Goto FIRST_FISCALYEAR

$FIRST_FISCALYEAR
If !clalev([F:PER]) : Local File PERIOD [PER] : Endif
Raz DAT
Filter [PER] Where CPY=SOC & LEDTYP=[L]TYPLED & PERSTA=2
Read [PER]PER0 First
Filter [PER]
If !fstat
 DAT = [F:PER]PERSTR
Endif
End

#################################################################
#   Dernière date dernière période ouverte                      #
#################################################################
Subprog DEREX(SOC,TYPLED,DAT)
Value    Char    SOC
Value    Integer TYPLED
Variable Date    DAT
Goto LAST_FISCALYEAR
#########################################
#  Last date of the last opened period  #
#########################################
Subprog LASTFIY(CPY,LEDTYP,DAT)
Value    Char    CPY
Value    Integer LEDTYP
Variable Date    DAT
#
Local Char SOC
Local Integer TYPLED
SOC = CPY
TYPLED = LEDTYP
Goto LAST_FISCALYEAR

$LAST_FISCALYEAR
If !clalev([F:PER]) : Local File PERIOD [PER] : Endif
Raz DAT
Filter [PER] Where CPY=SOC & LEDTYP=[L]TYPLED & PERSTA=2
Read [PER]PER0 Last
Filter [PER]
If !fstat
 DAT = [F:PER]PEREND
Endif
End

#################################################################
#   Dates début et fin de l'exercice par défaut                 #
#################################################################
Subprog DEFPER(SOC,TYPLED,DATDEB,DATFIN)
Value    Char    SOC
Value    Integer TYPLED
Variable Date    DATDEB
Variable Date    DATFIN
#
Local Decimal    EXEDEF
Call DEFEXE(SOC,TYPLED,EXEDEF)
Call DATEXE(SOC,TYPLED,EXEDEF,DATDEB,DATFIN)
End
##################################################
# Start and end dates of the default fiscalyear  #
##################################################
Subprog DEFPERIOD(CPY,LEDTYP,STRDAT,ENDDAT)
Value    Char    CPY
Value    Integer LEDTYP
Variable Date    STRDAT
Variable Date    ENDDAT
#
Local Integer FIYDEF
Call DEFFIY(CPY,LEDTYP,FIYDEF)
Call DATFIY(CPY,LEDTYP,FIYDEF,STRDAT,ENDDAT)
End

#################################################################
## Exercice par défaut pour une société                         #
#################################################################
Subprog DEFEXE(SOC,TYPLED,EXE)
Value    Char    SOC
Value    Integer TYPLED
Variable Decimal EXE
Gosub DEFAULT_FISCALYEAR
End
###################################
# Default fiscalyear of a company #
###################################
Subprog DEFFIY(CPY,LEDTYP,FIY)
Value    Char    CPY
Value    Integer LEDTYP
Variable Integer FIY
#
Local Char SOC
Local Integer TYPLED,EXE
SOC = CPY
TYPLED = LEDTYP
Gosub DEFAULT_FISCALYEAR
FIY = EXE
End

$DEFAULT_FISCALYEAR
If clalev([F:FIY])=0 : Local File =GTABCPT+"FISCALYEAR" [FIY] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS [AUS]    : Endif

# JML 29/03/00 V130 Suggestion 1475, Exercice en fonction utilisateur
EXE = 0
If [F:AUS]USR<>GUSER
 Read [AUS]CODUSR = GUSER
Endif

Local Char LSTRDAT(10), LENDDAT(10)
Local Date DSTRDAT, DENDDAT
Call PARAMUTIL("DATEFINDFT",LENDDAT,"","") From SUBAUS
Call PARAMUTIL("DATEDEBDFT",LSTRDAT,"","") From SUBAUS
DSTRDAT = LSTRDAT
DENDDAT = LENDDAT

If DSTRDAT<>[0/0/0] | DENDDAT<>[0/0/0]
 For [FIY]FIY0 Where CPY=SOC & LEDTYP=[L]TYPLED
  If DSTRDAT<>[0/0/0]
   If [F:FIY]FIYSTR>=DSTRDAT
    EXE = [F:FIY]FIYNUM : Break
   Endif
  Elsif DENDDAT<>[0/0/0]
   If [F:FIY]FIYEND<=DENDDAT
    EXE = [F:FIY]FIYNUM : Break
   Endif
  Endif
 Next
Endif

If !EXE
 For [FIY]FIY0 Where CPY=SOC & LEDTYP=[L]TYPLED
  EXE = [F:FIY]FIYNUM
  If GDATEDEB<>[0/0/0]
   If [F:FIY]FIYSTR>=GDATEDEB : Break : Endif
  Elsif GDATEFIN<>[0/0/0]
   If [F:FIY]FIYEND<=GDATEFIN : Break : Endif
  Else
   If [F:FIY]FIYSTA=2 : Break : Endif
  Endif
 Next
Endif
Return

#################################################################
#   Dates début et fin d'un exercice                            #
#################################################################
Subprog DATEXE(SOC,TYPLED,EXE,DATDEB,DATFIN)
Value    Char    SOC
Value    Integer TYPLED
Value    Decimal EXE
Variable Date    DATDEB
Variable Date    DATFIN
Gosub FISCALYEAR_DATES
End
#######################################
# Start and end dates of a fiscalyear #
#######################################
Subprog DATFIY(CPY,LEDTYP,FIY,STRDAT,ENDDAT)
Value    Char    CPY
Value    Integer LEDTYP
Value    Integer FIY
Variable Date    STRDAT
Variable Date    ENDDAT
#
Local Char SOC : SOC=CPY
Local Integer TYPLED,EXE
TYPLED = LEDTYP
EXE = FIY
Local Date DATDEB,DATFIN
Gosub FISCALYEAR_DATES
STRDAT=DATDEB
ENDDAT=DATFIN
End

$FISCALYEAR_DATES
If !clalev([F:PER]) : Local File PERIOD [PER] : Endif
Raz DATDEB, DATFIN
Filter [PER] Where CPY=SOC & LEDTYP=[L]TYPLED & FIYNUM=EXE
Read [PER]PER0 First
If !fstat : DATDEB = [F:PER]PERSTR : Endif
Read [PER]PER0 Last
If !fstat : DATFIN = [F:PER]PEREND : Endif
Filter [PER]
Return


#################################################################
#   Dates début et fin d'une période                            #
#################################################################
Subprog DATPER(SOC,TYPLED,EXE,PER,DATDEB,DATFIN)
Value    Char SOC
Value    Integer TYPLED
Value    Decimal EXE
Value    Decimal PER
Variable Date DATDEB
Variable Date DATFIN
Gosub PERIOD_DATES
End
###################################
# Start and End dates of a period #
###################################
Subprog DATPERIOD(CPY,LEDTYP,FIY,PER,STRDAT,ENDDAT)
Value    Char CPY
Value    Integer LEDTYP
Value    Integer FIY
Value    Integer PER
Variable Date STRDAT
Variable Date ENDDAT
#
Local Char SOC
Local Integer TYPLED,EXE
SOC = CPY
TYPLED = LEDTYP
EXE = FIY
Local Date DATDEB,DATFIN
Gosub PERIOD_DATES
STRDAT=DATDEB
ENDDAT=DATFIN
End

$PERIOD_DATES
If !clalev([F:GCM]) : Local File GACM   [GCM] : Endif
If !clalev([F:PER]) : Local File PERIOD [PER] : Endif
Raz DATDEB, DATFIN

# Si Référentiel automatique, il faut recherche les exercices/périodes du référentiel saisi.
Local Char    MODELE(GLONGCM)
Call SETGCM(SOC,MODELE) From CPTDIV
If [F:GCM]CFMAUT(TYPLED-1)=2
 TYPLED = [F:GCM]ORILEDTYP(TYPLED-1)
Endif

Filter [PER] Where CPY=SOC & FIYNUM=EXE & PERNUM=PER & LEDTYP=[L]TYPLED
Read [PER]PER0 First
Filter [PER]
If !fstat
 DATDEB = [F:PER]PERSTR
 DATFIN = [F:PER]PEREND
Endif
Return



#################################################################
#   Contrôle que le compte est collectif                        #
#################################################################
Subprog CONTSAC(SAC)
Variable Char SAC()
If SAC="" : End : Endif
If clalev([F:GAC])=0 : Local File =GTABCPT+"GACCOUNT" [GAC] : Endif
Read [GAC]GAC1 = SAC
If fstat | [F:GAC]SAC<>2
 # Collectif inexistant
 GMESSAGE = mess(9,106,1) : mkstat = 2 : End
Endif
End

#################################################################
#   Contrôle de limite de validité d'une date                   #
#################################################################
Subprog CTLVLYDAT(DAT,DATDEB,DATFIN)
Value    Date     DAT
Value    Date     DATDEB
Value    Date     DATFIN
If !(DAT>=DATDEB & (DATFIN=[0/0/0] | DAT<=DATFIN))
 GMESSAGE = mess(13,104,1) : # Hors limite des dates de validité
 mkstat = 2
Endif
End

## KC Dates pas modules ##
#################################################################
#  Contrôle de la date de création d'un document par rapport à  #
#  un intervalle de dates par module                            #
#################################################################
Subprog CTLDATMOD(MODULE,DAT,LCPY)
Value  Date    DAT
Value  Integer MODULE
Value Char     LCPY
Local Char LDATSTR(10),LDATEND(10),MODULESTR(15)
Local Date DATSTR ,DATEND

# Récupérer les param Compta ou Tiers selon le module d'appel
If MODULE = 2 #Comptabilité
 Call PARAMUTIL("CPTSTRDAT",LDATSTR,"",LCPY) From SUBAUS
 Call PARAMUTIL("CPTENDDAT",LDATEND,"",LCPY) From SUBAUS
 If LDATSTR<>""
  DATSTR = LDATSTR
 Endif
 If LDATEND<>""
  DATEND = LDATEND
 Endif
 MODULESTR = mess(2,14,1)
Elsif MODULE = 3 #Tiers
 Call PARAMUTIL("TRSSTRDAT",LDATSTR,"",LCPY) From SUBAUS
 Call PARAMUTIL("TRSENDDAT",LDATEND,"",LCPY) From SUBAUS
 If LDATSTR<>""
  DATSTR = LDATSTR
 Endif
 If LDATEND<>""
  DATEND = LDATEND
 Endif
 MODULESTR = mess(3,14,1)
Endif

If (DATSTR<>[0/0/0] & DAT<DATSTR) | (DATEND<>[0/0/0] & DAT>DATEND)
 # Date Interdite pour le module MODULESTR
 GMESSAGE = mess(140,104,1)- MODULESTR
 mkstat = 2 : End
Endif
End


#################################################################################################
# Invoice Date Control                                                                          #
# If the 'CTLPERINV' parameter is selected for the company, verification there are not invoices #
# created in the following accounting period                                                    #
#################################################################################################
Subprog CTLPERINV(CAS,DAT)
Value Integer CAS : # 1:Sales invoices    2:Purchases invoices
Value Date    DAT : # Accounting date

If func AFNC.PARAM("CTLPERINV",GSOCIETE)<>"2" : End : Endif

Local Decimal FIY1, PER1
Local Decimal FIY2, PER2
Local Integer NBPER, OK
Local Date    STRDAT, ENDDAT
Call GETPERSOC(GSOCIETE,1,DAT,FIY1,PER1) From CPTSUB
Call DATPER(GSOCIETE,1,FIY1,PER1,STRDAT,ENDDAT) From CPTSUB

OK = 1
Case CAS
 When 1
  # Sales Invoices Header Table
  If clalev([F:HEA])=0
   Local File SINVOICE [HEA] Order By Key CLE = CPY;ACCDAT;NUM
  Endif
 When 2
  # Purchases Invoices Header Table
  If clalev([F:HEA])=0
   Local File PINVOICE [HEA] Order By Key CLE = CPY;ACCDAT;NUM
  Endif
Endcase
Filter [HEA] Where CPY=GSOCIETE & ACCDAT>ENDDAT & INVTYP<>5       :# Issue X3-70764 excluding proformas (invtyp=5)
Read [HEA]CLE Last
Filter [HEA]
If !fstat
 ## Un document a été créé sur la période comptable suivante
 OK = 0 : GMESSAGE = mess(68,101,1)+"\"+"("+mess([F:HEA]INVTYP,645,1)-[F:HEA]NUM+","-tolower(mess(14,105,1))-":"-format$("D:"+GFMDAT,[F:HEA]ACCDAT)+")"
Endif
If !OK
 mkstat = 2 : End
Endif
End


##########################################################
## Conversion d'un tableau en devises        Obsolète   ##
##########################################################
Subprog CONVERT_TAB(NB,ORG,DES,COURS,ARRONDI)
Value    Integer NB
Value    Decimal ORG(1..)
Variable Decimal DES(1..)
Value    Decimal COURS
Value    Decimal ARRONDI
Local Decimal SOMME
Local Integer I
SOMME = 0
For I=1 To NB
 DES(I) = arr((ORG(I)+SOMME)*COURS,ARRONDI)-arr(SOMME*COURS,ARRONDI)
 SOMME += ORG(I)
Next I
End

##########################################################
## Conversion d'un tableau en devises                   ##
##########################################################
Subprog CONVERT_DEV(DEVORG,DEVDES,DEVSOC,NB,ORG,DES,COURS,TYPCOURS,DATCOURS,ARRONDI)
Value    Char    DEVORG
Value    Char    DEVDES
Value    Char    DEVSOC
Value    Integer NB
Value    Decimal ORG(1..)
Variable Decimal DES(1..)
Value    Decimal COURS
Value    Integer TYPCOURS
Value    Date    DATCOURS
Value    Decimal ARRONDI
Local Decimal SOMORG, SOMDES
Local Integer I , STAT
Local Integer ORGFLG, DESFLG      : # Flags monnaie 'In'
Local Decimal AMTINT              : # Montant intermédiaire

ORGFLG=1 : DESFLG=1
I = find(DEVORG, GDEVISE(1..GNBDEV))
If GDEVDAT(I) <= DATCOURS : ORGFLG = 2 : Endif    : # Si devise 'Out', GDEVDAT=31/12/9999
I = find(DEVDES, GDEVISE(1..GNBDEV))
If GDEVDAT(I) <= DATCOURS : DESFLG = 2 : Endif

If COURS<>0
 SOMORG=0 : SOMDES=0
 For I=1 To NB
  #------ Cas où on a saisi le cours de l'Euro (pour monnaie 'In' <> GEURO)
  If ORGFLG=1 & DESFLG=2 & DEVDES<>GEURO
    AMTINT = arr((ORG(I)+SOMORG)*COURS, 10^(-GAROEURO))
    Call CONVERT(GEURO,DEVDES,DEVSOC,TYPCOURS,DATCOURS,AMTINT,DES(I),STAT) From TRTDEV
    DES(I) -= SOMDES
  Elsif ORGFLG=2 & DESFLG=1 & DEVORG<>GEURO
    Call CONVERT(DEVORG,GEURO,DEVSOC,TYPCOURS,DATCOURS,(ORG(I)+SOMORG),AMTINT,STAT) From TRTDEV
    DES(I) = arr((AMTINT)*COURS, ARRONDI)-SOMDES
  Else
    DES(I) = arr((ORG(I)+SOMORG)*COURS, ARRONDI)-SOMDES
  Endif
  SOMORG += ORG(I)
  SOMDES += DES(I)
 Next I
Else
 If NB>0
  Call CONVERT_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS
&  ,ORG(1..NB),DES(1..NB),STAT) From TRTDEV
 Endif
Endif
End

##################################################################################
## Le même en prenant en compte la notion de site                               ##
##################################################################################
Subprog CONVERT_SIT(DEVORG,DEVDES,DEVSOC,NB,DEBORG,DEBDES,CREORG,CREDES
&         ,FLTRICHE,TRICHE,SITE,TYPCOURS,DATCOURS,COURS,ARRONDI,STAT)
Value    Char    DEVORG
Value    Char    DEVDES
Value    Char    DEVSOC
Value    Integer NB
Value    Decimal DEBORG(1..)
Variable Decimal DEBDES(1..)
Value    Decimal CREORG(1..)
Variable Decimal CREDES(1..)
Value    Integer FLTRICHE(1..)
Value    Decimal TRICHE(1..)
Value    Char    SITE()(1..)
Value    Integer TYPCOURS
Value    Date    DATCOURS
Value    Decimal COURS
Value    Decimal ARRONDI
Variable Integer STAT

# Il faut le faire même si le cours vaut 1 à cause de l'arrondi
Local Integer I
Local Integer ISITE , NBSITE
Local Char    TBSITE(GLONFCY) (1..GNBSITE)
Local Decimal SOMORG , SOMDES
Local Integer NBLIBRE , ILIBRE
Local Integer ORGFLG, DESFLG      : # Flags monnaie 'In'
Local Decimal AMTINT              : # Montant intermédiaire

# Table des sites
For I=1 To NB
 DEBDES(I)=0 : CREDES(I)=0
 ISITE = find(SITE(I),TBSITE(1..NBSITE))
 If !ISITE
  NBSITE += 1 : TBSITE(NBSITE) = SITE(I)
 Endif
Next I

ORGFLG=1 : DESFLG=1
I = find(DEVORG, GDEVISE(1..GNBDEV))
If GDEVDAT(I) <= DATCOURS : ORGFLG = 2 : Endif    : # Si devise 'Out', GDEVDAT=31/12/9999
I = find(DEVDES, GDEVISE(1..GNBDEV))
If GDEVDAT(I) <= DATCOURS : DESFLG = 2 : Endif

## Conversion par rapport à un cours imposé
If COURS<>0
 For ISITE=1 To NBSITE
  SOMORG = 0 : SOMDES = 0
  For I=1 To NB
   If FLTRICHE(I)<>0 & SITE(I)=TBSITE(ISITE)
    If CREORG(I)<>0
     SOMORG   -= CREORG(I)
     SOMDES   -= TRICHE(I)
     CREDES(I) = TRICHE(I)
    Else : # si Credit=Debit=0, les mts forces sont des debits par convention
     SOMORG   += DEBORG(I)
     SOMDES   += TRICHE(I)
     DEBDES(I) = TRICHE(I)
    Endif
   Endif
  Next I
  For I=1 To NB
   If FLTRICHE(I)=0 & SITE(I)=TBSITE(ISITE)
    If DEBORG(I)<>0
     If ORGFLG=1
       If DESFLG=1
         #---- 'Out' --> 'Out'
         DEBDES(I) = arr((SOMORG+DEBORG(I))*COURS, ARRONDI)-SOMDES
       Else
         #---- 'Out' --> 'In'
         If DEVDES = GEURO
            DEBDES(I) = arr((SOMORG+DEBORG(I))*COURS, ARRONDI)-SOMDES
         Else      : # Si on a un cours, c'est celui de l'Euro
            AMTINT = arr((SOMORG+DEBORG(I))*COURS, 10^(-GAROEURO))
            Call CONVERT(GEURO,DEVDES,DEVSOC,TYPCOURS,DATCOURS,AMTINT,DEBDES(I),STAT) From TRTDEV
            DEBDES(I) -= SOMDES
            If STAT : # Pas de cours de devises GEURO -> DEVDES (ACCDAT)
              GMESSAGE=mess(16,114,1)-GEURO-"->"-DEVDES-"("+format$("D:"+GFMDAT,DATCOURS)+")"
              mkstat=2 : Break 2
            Endif
         Endif
       Endif
     Else
       If DESFLG=1
         #---- 'In' --> 'Out'
         If DEVORG = GEURO
            DEBDES(I) = arr((SOMORG+DEBORG(I))*COURS, ARRONDI)-SOMDES
         Else
            Call CONVERT(DEVORG,GEURO,DEVSOC,TYPCOURS,DATCOURS,DEBORG(I),AMTINT,STAT) From TRTDEV
            DEBDES(I) = arr((SOMORG+AMTINT)*COURS, ARRONDI)-SOMDES
            If STAT : # Pas de cours de devises DEVORG -> GEURO (ACCDAT)
              GMESSAGE=mess(16,114,1)-DEVORG-"->"-GEURO-"("+format$("D:"+GFMDAT,DATCOURS)+")"
              mkstat=2 : Break 2
            Endif
         Endif
       Else
         #---- 'In' --> 'In'
         DEBDES(I) = arr((SOMORG+DEBORG(I))*COURS, ARRONDI)-SOMDES
       Endif
     Endif
     SOMORG += DEBORG(I)
     SOMDES += DEBDES(I)
    Elsif CREORG(I)<>0
     If ORGFLG=1
       If DESFLG=1
         #---- 'Out' --> 'Out'
         CREDES(I) = -(arr((SOMORG-CREORG(I))*COURS,ARRONDI)-SOMDES)
       Else
         #---- 'Out' --> 'In'
         If DEVDES = GEURO
           CREDES(I) = -(arr((SOMORG-CREORG(I))*COURS, ARRONDI)-SOMDES)
         Else
           AMTINT = arr((SOMORG-CREORG(I))*COURS, 10^(-GAROEURO))
           Call CONVERT(GEURO,DEVDES,DEVSOC,TYPCOURS,DATCOURS,AMTINT,CREDES(I),STAT) From TRTDEV
           CREDES(I) = -(CREDES(I)-SOMDES)
           If STAT : # Pas de cours de devises GEURO -> DEVDES (ACCDAT)
             GMESSAGE=mess(16,114,1)-GEURO-"->"-DEVDES-"("+format$("D:"+GFMDAT,DATCOURS)+")"
             mkstat=2 : Break 2
           Endif
         Endif
       Endif
     Else
       If DESFLG=1
         #---- 'In' --> 'Out'
         If DEVORG<>GEURO   : # Si on a un cours, c'est celui de l'Euro
           Call CONVERT(DEVORG,GEURO,DEVSOC,TYPCOURS,DATCOURS,CREORG(I),AMTINT,STAT) From TRTDEV
           CREDES(I) = -(arr((SOMORG-AMTINT)*COURS, ARRONDI)-SOMDES)
           If STAT : # Pas de cours de devises GEURO -> DEVDES (ACCDAT)
             GMESSAGE=mess(16,114,1)-GEURO-"->"-DEVDES-"("+format$("D:"+GFMDAT,DATCOURS)+")"
             mkstat=2 : Break 2
           Endif
         Else
           CREDES(I) = -(arr((SOMORG-CREORG(I))*COURS, ARRONDI)-SOMDES)
         Endif
       Else
         #---- 'In' --> 'In'
         CREDES(I) = -(arr((SOMORG-CREORG(I))*COURS, ARRONDI)-SOMDES)
       Endif
     Endif
     SOMORG -= CREORG(I)
     SOMDES -= CREDES(I)
    Endif
   Endif
  Next I
 Next ISITE
Else
## Conversion standard
 Local Decimal MTDORG(1..NB) , MTCORG(1..NB)
 Local Decimal MTDDES(1..NB) , MTCDES(1..NB)
 Local Integer PT(1..NB) , NB2
 For ISITE=1 To NBSITE
  NB2 = 0
  For I=1 To NB
   If SITE(I)=TBSITE(ISITE)
    NB2 += 1 : PT(NB2) = I
    MTDORG(NB2) = DEBORG(I)
    MTCORG(NB2) = CREORG(I)
   Endif
  Next I
  If NB2>0
   Call CONVERT_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS
&   ,MTDORG(1..NB2),MTDDES(1..NB2),STAT) From TRTDEV
   If STAT : # Pas de cours de devises DEVORG -> DEVDES (ACCDAT)
    GMESSAGE=mess(16,114,1)-DEVORG-"->"-DEVDES-"("+format$("D:"+GFMDAT,DATCOURS)+")"
    mkstat=2 : Break
   Endif
   Call CONVERT_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS
&   ,MTCORG(1..NB2),MTCDES(1..NB2),STAT) From TRTDEV
   If STAT : # Pas de cours de devises DEVORG -> DEVDES (ACCDAT)
    GMESSAGE=mess(16,114,1)-DEVORG-"->"-DEVDES-"("+format$("D:"+GFMDAT,DATCOURS)+")"
    mkstat=2 : Break
   Endif
  Endif
  SOMDES = 0
  NBLIBRE = 0
  For I=1 To NB2
   If FLTRICHE(PT(I))<>0
    If CREORG(PT(I))<>0
     CREDES(PT(I)) = TRICHE(PT(I))
     SOMDES -= CREDES(PT(I))
    Else
     DEBDES(PT(I)) = TRICHE(PT(I))
     SOMDES += DEBDES(PT(I))
    Endif
   Else
    NBLIBRE += 1
    ILIBRE = I
    DEBDES(PT(I)) = MTDDES(I)
    CREDES(PT(I)) = MTCDES(I)
    SOMDES += DEBDES(PT(I))-CREDES(PT(I))
   Endif
  Next I
  If SOMDES<>0
   If NBLIBRE=1
    If CREDES(PT(ILIBRE))<>0
     CREDES(PT(ILIBRE)) += SOMDES
    Else
     DEBDES(PT(ILIBRE)) -= SOMDES
    Endif
   Else
    While SOMDES<>0
     For I=1 To NB2
      If FLTRICHE(PT(I))=0
       If SOMDES>0
        If DEBDES(PT(I))<>0
         DEBDES(PT(I)) -= ARRONDI
        Else
         CREDES(PT(I)) += ARRONDI
        Endif
        SOMDES -= ARRONDI
       Else
        If DEBDES(PT(I))<>0
         DEBDES(PT(I)) += ARRONDI
        Else
         CREDES(PT(I)) -= ARRONDI
        Endif
        SOMDES += ARRONDI
       Endif
      Endif
      If SOMDES=0 : Break : Endif
     Next I
    Wend
   Endif
  Endif
 Next ISITE
Endif
End

#####################################################################
## Conversion d'un montant en devises (cours éventuellement fourni) # # En V150 : Utilisation de COURMNT de TRTDEV
#####################################################################
Subprog CONVERT3(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,COURS,STAT)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise de destination
Value    Char    DEVSOC           : # Devise société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG            : # Montant origine
Variable Decimal MTDES            : # Montant destination
Value    Decimal COURS            : # Cours devise -> destination eventuelt donné
Variable Integer STAT             : # Status de retour (0 = OK)

Local  Decimal AMTINT             : # Montant intermédiaire
Local  Integer ORGFLG, DESFLG     : # Flags monnaies origine et destination
Local  Decimal ARRONDI
Local  Integer I
If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif
If [F:TCU]CUR<>DEVDES
 Read [TCU]TCU0 = DEVDES
Endif
ARRONDI = [F:TCU]CURRND

STAT=0
If DEVORG="" | DEVDES=""
  # Devise inexistante
  Call ERREUR(mess(151,105,1)) From GESECRAN : STAT=1
  End
Endif

If DEVORG=DEVDES
 MTDES =MTORG
 End
Endif

ORGFLG=1 : DESFLG=1
I = find(DEVORG, GDEVISE(1..GNBDEV))
If GDEVDAT(I) <= DATCOURS : ORGFLG = 2 : Endif   : # Si devise 'Out', GDEVDAT=31/12/9999
I = find(DEVDES, GDEVISE(1..GNBDEV))
If GDEVDAT(I) <= DATCOURS : DESFLG = 2 : Endif

If COURS<>0
  If ORGFLG=1
    #-------- 'Out' --> 'Out'
    If DESFLG=1
       MTDES = arr(MTORG*COURS, ARRONDI)
    Else
      #-------- 'Out' --> 'In'
      If DEVDES = GEURO
         MTDES = arr(MTORG*COURS, ARRONDI)
      Else      : # Si on a un cours, c'est celui de l'Euro
         AMTINT = arr(MTORG*COURS, 10^(-GAROEURO))
         Call CONVERT(GEURO,DEVDES,DEVSOC,TYPCOURS,DATCOURS,AMTINT,MTDES,STAT) From TRTDEV
      Endif
    Endif
  Else
    If DESFLG=1
      #-------- 'In' --> 'Out'
      If DEVORG=GEURO
         MTDES = arr(MTORG*COURS, ARRONDI)
      Else
         Call CONVERT(DEVORG,GEURO,DEVSOC,TYPCOURS,DATCOURS,MTORG,AMTINT,STAT) From TRTDEV
         MTDES = arr(AMTINT*COURS, ARRONDI)
      Endif
    Else
      #-------- 'In' --> 'In'  : # si cours renseigné, on n'en tient pas compte
     Call CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV
    Endif
  Endif
Else
  Call CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV
Endif
End

#############################################################
## Appel d'un compte par son code court                    ##
#############################################################
Subprog CONTCPT(VALEUR,PLAN)
Variable Char VALEUR
Value    Char PLAN

If VALEUR<>""
 If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
 Call LEC_GAC(VALEUR,PLAN) From CPTLEC
 If fstat
  Read [GAC]GAC1 = PLAN;VALEUR
  If !fstat
   VALEUR = [F:GAC]ACC
  Elsif GFONCTION<>"GESGAS" : # Bug 58416
   IPLAN = find(PLAN,GCOACOD(1..GCOANBR))
   If IPLAN & GCOALEN(IPLAN)<>0
    VALEUR = left$(VALEUR+string$(GCOALEN(IPLAN),"0"),GCOALEN(IPLAN))
   Endif
  Endif
 Endif
Endif
End

#####################################
## Contrôle périodes                #
#####################################
Subprog CONTPER(VALEUR,TYPLED,SIT)
Value    Date     VALEUR
Value    Integer  TYPLED
Value    Char     SIT

Local Decimal EXE, PER
Local Char    SOC(GLONCPY)
Local Integer ISITE

#JASMI - 2017-04-24 - Req. 122336 - START
If func TRTHRCPT.IS_X3PEOPLE_EXT_ACC() #if X3 People and External Accounting
  End
Endif
#JASMI - 2017-04-24 - Req. 122336 - END

If !clalev([F:FIY]) : Local File =GTABCPT+"FISCALYEAR" [FIY] : Endif
If !clalev([F:PER]) : Local File =GTABCPT+"PERIOD"     [PER] : Endif

ISITE = find(SIT,GSITE(1..GNBSITE))
If !ISITE : End : Endif
SOC = GSOCSITE(ISITE)
Call GETEXE(SOC,TYPLED,VALEUR,EXE) From CPTSUB
If !EXE | [F:FIY]FIYSTA<>2
 # Exercice non ouvert
 GMESSAGE=mess(20,101,1) : mkstat=2 : End
Elsif [F:FIY]FIYSTA=3
 # Exercice fermé
 GMESSAGE=mess(42,101,1) : mkstat=2 : End
Endif
Call GETPER(GFINSITE(ISITE),TYPLED,VALEUR,EXE,PER) From CPTSUB
If !PER | [F:PER]PERSTA<>2
 # Période non ouverte
 GMESSAGE=mess(35,101,1) : mkstat=2 : End
Elsif [F:PER]PERSTA=3
 # Période fermée
 GMESSAGE=mess(36,101,1) : mkstat=2 : End
Endif
End

#######################################################
## Contrôle de la devise de tenue du compte de banque #
#######################################################
Subprog CONTBAN(DAT,BANQ,DEV)
Value Date DAT
Value Char BANQ, DEV
Raz GERR, GMESSAGE
If BANQ="" : End : Endif
If clalev([F:BAN])=0 : Local File BANK  [BAN] : Endif
If [F:BAN]BAN<>BANQ
 Read [BAN]BAN0 = BANQ
Endif
If dim([F:BAN]CHGDAT)<0 : End : Endif
If !fstat
 If DAT >= [F:BAN]CHGDAT
  If DEV <> [F:BAN]CUR
   GERR=2
   If [F:BAN]CHGDAT<>[0/0/0]
    GMESSAGE = mess(13,602,1)-BANQ+","-mess(18,105,1)-[F:BAN]CUR-mess(68,119,1)
&            -format$(GFMD,[F:BAN]CHGDAT)
    # Banque ..., Devise ... à partir du ...
   Else
    GMESSAGE = mess(13,602,1)-BANQ+","-mess(18,105,1)-[F:BAN]CUR
    # Banque ..., Devise ...
   Endif
  Endif
 Else
  If DEV <> [F:BAN]OLDCUR & [F:BAN]OLDCUR<>"" & [F:BAN]CHGDAT<>[0/0/0]
   GERR=2
   GMESSAGE = mess(13,602,1)-BANQ+","-mess(18,105,1)-[F:BAN]OLDCUR-mess(69,119,1)
&            -format$(GFMD,[F:BAN]CHGDAT-1)
   # Banque ..., Devise ... jusqu'au ...
  Endif
 Endif
Endif
End

########################################
## Contrôle Tiers/Société Zone tiers  ##
########################################
Subprog CONTBPRCPY(VALEUR,SIT,PLAN,COLL,BPRTYP)
Value Char    VALEUR
Value Char    SIT
Value Char    PLAN
Value Char    COLL
Value Char    BPRTYP
Local Char    SOC(GLONCPY)
Local Integer ISITE
Local Integer OK

If GCOMPTA=3 : End : Endif

If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:ACV]) : Local File ACTIV      [ACV] : Endif
If !clalev([F:BPC]) : Local File =GTABCPT+"BPCUSTOMER" [BPC] : Endif
If !clalev([F:BPR]) : Local File =GTABCPT+"BPARTNER"   [BPR] : Endif
If !clalev([F:GAC]) : Local File =GTABCPT+"GACCOUNT"   [GAC] : Endif

Read[CPY]CPY0=SIT
If !fstat
 SOC   = [F:CPY]CPY
Else
 ISITE = find(SIT,GSITE(1..GNBSITE))
 If ISITE>0 : SOC   = GSOCSITE(ISITE) : Endif
Endif

If SOC<>""
 Read[ACV]CODACT="MUL"
 If !fstat & [F:ACV]FLACT=2
  If !clalev([F:BPE]) : Local File =GTABCPT+"BPEXCEPT" [BPE] : Endif
  Read[BPE]BPE0=VALEUR;SOC
  If !fstat
   If [F:BPE]ACEAUZ<>2
    GMESSAGE=mess(29,104,1) : mkstat=2 : End
    # Tiers non autorisé pour cette société
   Else
    End
   Endif
  Endif
 Endif
Endif
If COLL<>"" & BPRTYP<>"F"
 If [L]PLAN=""
  Call LECMAINPLAN(1,SOC,PLAN) From CPTDIV
 Endif
 Read[GAC]GAC0=PLAN;COLL
 Read[BPR]BPR0=VALEUR
 Read[BPC]BPC0=VALEUR
 If !fstat & [F:BPC]BPCTYP=4 & [F:GAC]AUZBPR(0)=2
  OK = 0
  If BPRTYP<>"C"
   If [F:BPR]BPSFLG=2 & [F:GAC]AUZBPR(1)=2 : OK = 1 : Endif
   If [F:BPR]BPTFLG=2 & [F:GAC]AUZBPR(2)=2 : OK = 1 : Endif
   If [F:BPR]FCTFLG=2 & [F:GAC]AUZBPR(3)=2 : OK = 1 : Endif
   If [F:BPR]REPFLG=2 & [F:GAC]AUZBPR(4)=2 : OK = 1 : Endif
   If [F:BPR]BPRACC=2 & [F:GAC]AUZBPR(5)=2 : OK = 1 : Endif
  Endif
  If OK=0
   GMESSAGE=mess(30,104,1) : mkstat=2 : End
   # Prospect non autorisé
  Endif
 Endif
Endif
End

#############################################
## Contrôle Tiers/Société Zone collectif   ##
#############################################
Subprog CONTBPRCP2(VALEUR,SIT,PLAN,BPRNUM,BPRTYP)
Value Char    VALEUR
Value Char    SIT
Value Char    PLAN
Value Char    BPRNUM
Value Char    BPRTYP
Local Char    COLL(GLONGAC),PLAN(GLONCOA)

If GCOMPTA=3 : End : Endif
If BPRNUM="" : End : Endif
If !clalev([F:GAC]) : Local File =GTABCPT+"GACCOUNT"   [GAC] : Endif
If PLAN=""
 Call LECMAINPLAN(1,SIT,PLAN) From CPTDIV
Endif
Read[GAC]GAC1=PLAN;VALEUR
If !fstat
 COLL=[F:GAC]ACC
 Call CONTBPRCPY(BPRNUM,SIT,PLAN,COLL,BPRTYP)
Endif
End

#######################################
## Recherche du régime taxe du tiers  #
#######################################
Subprog INIT_REGIME(TIERS,SIT,BPRTYP,REGIME)
Value    Char    TIERS        # INPUT : Numero de tiers
Value    Char    SIT          #         Société ou Site
Value    Char    BPRTYP       #         Type de tiers ("C" ou "F" ou " ")
Variable Char    REGIME       # I-O   : Régime de taxe

  If TIERS="" : End : Endif

  #
  # Entry point CALVACBPR
  #
  # Be able to choose tax rule
  #
  # Notes:
  # - There is no database transaction open at the moment
  # - Interesting variables: REGIME - the tax rule
  #
  Raz REGIME
  GPOINT = "CALVACBPR" : Gosub ENTREE From EXEFNC
  If REGIME <> "" Then
    End
  Endif

  # JPGA : Ouvertures tables, Initialisation Société ou site, Recherche enregistrement BPEXCEPT
  Gosub INIT_BPEXCEPT

  # JPGA : Déclinaisons Société / BPEXCEPT : Alimentation selon Client/Fournisseur/Tiers ou autre
  Case BPRTYP
    When "C", " "
      # Priorité d'alimentation du Régime : 1/BPEXCEPT - 2/ BPCUSTOMER - 3/ BPSUPPLIER
      If [L]BPE_TROUVE  &  [F:BPE]VACBPC <> ""
        REGIME = [F:BPE]VACBPC
      Else
        Gosub LECTURE_BPC
        If [L]BPC_TROUVE  &  [F:BPC]VACBPR<>""
          REGIME = [F:BPC]VACBPR
        Else
          Gosub LECTURE_BPS
          If [L]BPS_TROUVE  &  [F:BPS]VACBPR<>""
            REGIME = [F:BPS]VACBPR
          Endif
        Endif
      Endif
    When "F"
      # Priorité d'alimentation du Régime : 1/BPEXCEPT - 2/ BPSUPPLIER - 3/ BPCUSTOMER
      If [L]BPE_TROUVE  &  [F:BPE]VACBPS <> ""
        REGIME = [F:BPE]VACBPS
      Else
        Gosub LECTURE_BPS
        If [L]BPS_TROUVE  &  [F:BPS]VACBPR<>""
          REGIME = [F:BPS]VACBPR
        Else
          Gosub LECTURE_BPC
          If [L]BPC_TROUVE  &  [F:BPC]VACBPR<>""
            REGIME = [F:BPC]VACBPR
          Endif
        Endif
      Endif
    When Default
  Endcase
End

##################################################
## Recherche des conditions de paiement du tiers #
##################################################
Subprog INIT_CONDITIONS(TIERS,SIT,BPRTYP,CONDITIONS)
Value    Char    TIERS        # INPUT : Numero de tiers
Value    Char    SIT          #         Société ou Site
Value    Char    BPRTYP       #         Type de tiers ("C" ou "F" ou " ")
Variable Char    CONDITIONS   # I-O   : Conditions de paiement

  If TIERS="" : End : Endif

  # JPGA : Ouvertures tables, Initialisation Société ou site, Recherche enregistrement BPEXCEPT
  Gosub INIT_BPEXCEPT

  # JPGA : Déclinaisons Société / BPEXCEPT : Alimentation selon Client/Fournisseur/Tiers ou autre
  Case BPRTYP
    When "C"
      # Priorité d'alimentation des conditions de paiement : 1/BPEXCEPT - 2/ BPCUSTOMER
      If [L]BPE_TROUVE  &  [F:BPE]PTEBPC <> ""
        CONDITIONS = [F:BPE]PTEBPC
      Else
        Gosub LECTURE_BPC
        If [L]BPC_TROUVE  &  [F:BPC]PTE <> ""
          CONDITIONS = [F:BPC]PTE
        Endif
      Endif
    When "F"
      # Priorité d'alimentation des conditions de paiement : 1/BPEXCEPT - 2/ BPSUPPLIER
      If [L]BPE_TROUVE  &  [F:BPE]PTEBPS <> ""
        CONDITIONS = [F:BPE]PTEBPS
      Else
        Gosub LECTURE_BPS
        If [L]BPS_TROUVE  &  [F:BPS]PTE <> ""
          CONDITIONS = [F:BPS]PTE
        Endif
      Endif
    When Default
  Endcase
End

##################################################
## Recherche des Escompte et agios du tiers      #
##################################################
Subprog INIT_ESCOMPTE(TIERS,SIT,BPRTYP,ESCOMPTE)
Value    Char    TIERS        # INPUT : Numero de tiers
Value    Char    SIT          #         Société ou Site
Value    Char    BPRTYP       #         Type de tiers ("C" ou "F" ou " ")
Variable Char    ESCOMPTE     # I-O   : Escompte et agios

  If TIERS="" : End : Endif

  # JPGA : Ouvertures tables, Initialisation Société ou site, Recherche enregistrement BPEXCEPT
  Gosub INIT_BPEXCEPT

  # JPGA : Déclinaisons Société / BPEXCEPT : Alimentation selon Client/Fournisseur/Tiers ou autre
  Case BPRTYP
    When "C"
      # Priorité d'alimentation des escomptes et agios : 1/BPEXCEPT - 2/ BPCUSTOMER
      If [L]BPE_TROUVE  &  [F:BPE]DEPBPC <> ""
        ESCOMPTE = [F:BPE]DEPBPC
      Else
        Gosub LECTURE_BPC
        # Bug 54743 : DEP est un champ non obligatoire, il faut toujours le charger
#        If [L]BPC_TROUVE  &  [F:BPC]DEP <> ""
        If [L]BPC_TROUVE
          ESCOMPTE = [F:BPC]DEP
        Endif
      Endif
    When "F"
      # Priorité d'alimentation des escomptes et agios : 1/BPEXCEPT - 2/ BPSUPPLIER
      If [L]BPE_TROUVE  &  [F:BPE]DEPBPS <> ""
        ESCOMPTE = [F:BPE]DEPBPS
      Else
        Gosub LECTURE_BPS
        # Bug 54743 : DEP est un champ non obligatoire, il faut toujours le charger
#        If [L]BPS_TROUVE  &  [F:BPS]DEP <> ""
        If [L]BPS_TROUVE
          ESCOMPTE = [F:BPS]DEP
        Endif
      Endif
    When Default
  Endcase
End

##################################################
## Recherche du code comptable du tiers          #
##################################################
Subprog INIT_COMPTE(TIERS,SIT,BPRTYP,COMPTE)
Value    Char    TIERS        # INPUT : Numero de tiers
Value    Char    SIT          #         Société ou Site
Value    Char    BPRTYP       #         Type de tiers ("C" ou "F" ou " ")
Variable Char    COMPTE       # I-O   : Code comptable

  If TIERS="" : End : Endif

  # JPGA : Ouvertures tables, Initialisation Société ou site, Recherche enregistrement BPEXCEPT
  Gosub INIT_BPEXCEPT

  # JPGA : Déclinaisons Société / BPEXCEPT : Alimentation selon Client/Fournisseur/Tiers ou autre
  Case BPRTYP
    When "C"
      # Priorité d'alimentation du code comptable : 1/BPEXCEPT - 2/ BPCUSTOMER
      If [L]BPE_TROUVE  &  [F:BPE]ACCBPC <> ""
        COMPTE = [F:BPE]ACCBPC
      Else
        Gosub LECTURE_BPC
        If [L]BPC_TROUVE  &  [F:BPC]ACCCOD <> ""
          COMPTE = [F:BPC]ACCCOD
        Endif
      Endif
    When "F"
      # Priorité d'alimentation du code comptable : 1/BPEXCEPT - 2/ BPSUPPLIER
      If [L]BPE_TROUVE  &  [F:BPE]ACCBPS <> ""
        COMPTE = [F:BPE]ACCBPS
      Else
        Gosub LECTURE_BPS
        If [L]BPS_TROUVE  &  [F:BPS]ACCCOD <> ""
          COMPTE = [F:BPS]ACCCOD
        Endif
      Endif
    When Default
  Endcase
End

$INIT_BPEXCEPT
############## Appelé depuis INIT_REGIME, INIT_CONDITIONS, INIT_ESCOMPTE, INIT_COMPTE
Local    Char    SOC(GLONCPY)
Local    Integer ISITE
Local    Integer BPE_TROUVE

  If clalev([F:CPY])=0 : Local File COMPANY    [CPY]            : Endif
  If clalev([F:ACV])=0 : Local File ACTIV      [ACV]            : Endif
  If clalev([F:BPC])=0 : Local File =GTABCPT+"BPCUSTOMER" [BPC] : Endif
  If clalev([F:BPS])=0 : Local File =GTABCPT+"BPSUPPLIER" [BPS] : Endif

  # Issue 74556 - 2011-06-23 by VPO : lecture ssi besoin
  If [F:CPY]CPY<>SIT
    Read[CPY]CPY0=SIT
    If !fstat
      SOC   = [F:CPY]CPY
    Else
      ISITE = find(SIT,GSITE(1..GNBSITE))
      If ISITE>0 : SOC   = GSOCSITE(ISITE) : Endif
    Endif
  Else
    SOC   = [F:CPY]CPY
  Endif

  [L]BPE_TROUVE = 0

  If SOC <> ""
    # Issue 74556 - 2011-06-23 by VPO : lecture ssi besoin
    If [F:ACV]CODACT<>"MUL"
      Read [ACV]CODACT="MUL" : If fstat  Raz [F:ACV] : Endif
    Endif
    If [F:ACV]FLACT = 2
      If clalev([F:BPE])=0 : Local File =GTABCPT+"BPEXCEPT"   [BPE] : Endif
      # Issue 74556 - 2011-06-23 by VPO : lecture ssi besoin
      If [F:BPE]BPRNUM<>TIERS | [F:BPE]CPY<>SOC
        Read [BPE]BPE0=TIERS;SOC
        If !fstat
          [L]BPE_TROUVE = 1
        Endif
      Else
        [L]BPE_TROUVE = 1
      Endif
    Endif
  Endif
Return

$LECTURE_BPC
############## Appelé depuis INIT_REGIME, INIT_CONDITIONS, INIT_ESCOMPTE, INIT_COMPTE
Local Integer   BPC_TROUVE

  [L]BPC_TROUVE = 0

  If [F:BPC]BPCNUM = TIERS
    [L]BPC_TROUVE = 1
  Else
    Read [BPC]BPC0=TIERS
    If !fstat
      [L]BPC_TROUVE = 1
    Endif
  Endif
Return

$LECTURE_BPS
############## Appelé depuis INIT_REGIME, INIT_CONDITIONS, INIT_ESCOMPTE, INIT_COMPTE
Local Integer   BPS_TROUVE

  [L]BPS_TROUVE = 0

  If [F:BPS]BPSNUM = TIERS
    [L]BPS_TROUVE = 1
  Else
    Read [BPS]BPS0=TIERS
    If !fstat
      [L]BPS_TROUVE = 1
    Endif
  Endif
Return

