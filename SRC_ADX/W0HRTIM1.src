If varinit([M]DAYDAC,indice)=0
 IMPENT = 1
Endif
If varmode([M]DAYDAC,indice)=0
 [M]DAYDAC(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DAYDAC" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DAYDAC(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_DAYDAC(IMPENT) From SUBHRTIM
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "DAYDAC" : GZNUM = 436 : Endif
  Gosub AFF From GSAISIE
