############################################################
#
# Library of Legislation procedures for Training period screens
#
# Window  : OINS
# Screens : INS2,INS3
#
############################################################

########################################
#21/05/12 - SBA - Display\Hide fields based on legislation
########################################
Subprog DISPLAY_HIDE()
Local Char WSIGN(1)
#show name block
Local Integer WDISPBLCK
Local Char WNAMEBLCK
# 3 fields to hide if GCURLEG<>FRA
#block with 2 fields to hide if GCURLEG<>FRA
If clalev([F:AMKW])=0 : Local File AMSK [AMKW] : Endif
Read [F:AMKW]CODMSK = "INS2"
Case GCURLEG
When "FRA" :
      WSIGN=""
      WDISPBLCK=1
When Default:
      WSIGN="-"
      WDISPBLCK=0
Endcase
# name block
If WDISPBLCK=1
  WNAMEBLCK=func AFNC.TEXTE([F:AMKW]TITBLOC(1))
Endif
Chgtbk [M:INS2]15  With WNAMEBLCK
# fields CATFRT=CATTRG in STG
Chgfmt [M:INS2]CATFRT    With WSIGN+"K:20BX"     #CATFRT=CATTRG in STG
Chgfmt [M:INS2]ZCATFRT   With WSIGN+"KP:20X"
#Chgfmt [M:INS2]DESNATFIS With WSIGN+"LA:10452"  #DESNATFIS = NATFIS in STG
#Chgfmt [M:INS2]DESCATACN With WSIGN+"LA:10453"  #DESCATACN = CATACN in STG
#Chgfmt [M:INS2]DESTYPFRT With WSIGN+"LA:10455"
#Chgfmt [M:INS3]TYPFRT With WSIGN+"LA:10455"
Chgfmt [M:INS2]DESNATFIS With WSIGN+"K:5X"  #DESNATFIS = NATFIS in STG
Chgfmt [M:INS2]DESCATACN With WSIGN+"K:5X"  #DESCATACN = CATACN in STG
Chgfmt [M:INS2]DESTYPFRT With WSIGN+"K:5X"
Chgfmt [M:INS3]TYPFRT With WSIGN+"K:5X"

If WSIGN="-" Then
  # FQ81491 US902 - MABON 05/11/12 - On ne doit pas perdre ces valeurs initialisées par la session, car si on revient sur du FRA,
  # on veut pouvoir les retrouver de nouveau
#  Raz [M:INS2]CATFRT
#  Raz [M:INS2]ZCATFRT
#  Raz [M:INS2]DESNATFIS
#  Raz [M:INS2]DESCATACN
#  Raz [M:INS2]DESTYPFRT
#  Raz [M:INS3]TYPFRT
  # Fin MABON
Else
  # FQ81491 US902 - MABON 05/11/12 - Affichage des écrans pour récupérer les valeurs initialisées
  Affzo [M:INS2]
  Affzo [M:INS3]
  # Fin MABON
Endif
End

