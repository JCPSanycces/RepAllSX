 ######################################################################################
 ## Section added (screen MAT1) 20/01/2016 12:55:10 (MAPAD)
 ######################################################################################
 #MAPAD 2015-05-26 - Requirement 113638  US 4202  - START
Subprog C_DEFAULTRES(VALEUR)
Variable Integer VALEUR, RESIND, LINENUM

RESIND = 0

If VALEUR = 4
    For I=0 To [M:EMP1]ADDTYP
      If [M:EMP1]ADDTYP(I) = 1
         LINENUM =  I
         RESIND = 1
      Endif
    Next

    If RESIND = 0
       GERR=1
       GMESSAGE=mess(50 ,11662,1)

       [M:EMP1]ADDTYP(nolign - 1) = 1
       Affzo [M:EMP1]ADDTYP(nolign-1)

       [M:EMP1]ADDSRVTYP(nolign - 1) = 0
       Affzo [M:EMP1]ADDSRVTYP(nolign-1)

    Else
       [M:EMP1]ADDPOSOTH(nolign - 1) = [M:EMP1]ADDPOSOTH(LINENUM)
       [M:EMP1]ADDPOSNUM(nolign - 1) = [M:EMP1]ADDPOSNUM(LINENUM)
       [M:EMP1]ADDPOSNAM(nolign - 1) = [M:EMP1]ADDPOSNAM(LINENUM)
       [M:EMP1]ADDPOSAGN(nolign - 1) = [M:EMP1]ADDPOSAGN(LINENUM)
       [M:EMP1]ADDCPX(nolign - 1)    = [M:EMP1]ADDCPX(LINENUM)
       [M:EMP1]ADDSTRNUM(nolign - 1) = [M:EMP1]ADDSTRNUM(LINENUM)
       [M:EMP1]ADDSTRNAM(nolign - 1) = [M:EMP1]ADDSTRNAM(LINENUM)
       [M:EMP1]ADDSUB(nolign - 1)    = [M:EMP1]ADDSUB(LINENUM)
       [M:EMP1]ADDTWN(nolign - 1)    = [M:EMP1]ADDTWN(LINENUM)
       [M:EMP1]ADDPOSCDE(nolign - 1) = [M:EMP1]ADDPOSCDE(LINENUM)
       [M:EMP1]ADDCNTCDE(nolign - 1) = [M:EMP1]ADDCNTCDE(LINENUM)
       [M:EMP1]ADDPRV(nolign - 1)    = [M:EMP1]ADDPRV(LINENUM)
       [M:EMP1]ADDPOSCOF(nolign - 1) = [M:EMP1]ADDPOSCOF(LINENUM)
       [M:EMP1]ADDPOSINM(nolign - 1) = [M:EMP1]ADDPOSINM(LINENUM)
       [M:EMP1]ADDSTA(nolign - 1)    = [M:EMP1]ADDSTA(LINENUM)

       Affzo [M:EMP1]ADDPOSOTH(nolign - 1)
       Affzo [M:EMP1]ADDPOSNUM(nolign - 1)
       Affzo [M:EMP1]ADDPOSNAM(nolign - 1)
       Affzo [M:EMP1]ADDPOSAGN(nolign - 1)
       Affzo [M:EMP1]ADDCPX(nolign - 1)
       Affzo [M:EMP1]ADDSTRNUM(nolign - 1)
       Affzo [M:EMP1]ADDSTRNAM(nolign - 1)
       Affzo [M:EMP1]ADDSUB(nolign - 1)
       Affzo [M:EMP1]ADDTWN(nolign - 1)
       Affzo [M:EMP1]ADDPOSCDE(nolign - 1)
       Affzo [M:EMP1]ADDCNTCDE(nolign - 1)
       Affzo [M:EMP1]ADDPRV(nolign - 1)
       Affzo [M:EMP1]ADDPOSCOF(nolign - 1)
       Affzo [M:EMP1]ADDPOSINM(nolign - 1)
       Affzo [M:EMP1]ADDSTA(nolign - 1)

       Grizo [M:EMP1]ADDPOSOTH(nolign-1)
       Grizo [M:EMP1]ADDPOSNUM(nolign-1)
       Grizo [M:EMP1]ADDPOSNAM(nolign-1)
       Grizo [M:EMP1]ADDPOSAGN(nolign-1)
       Grizo [M:EMP1]ADDCPX(nolign-1)
       Grizo [M:EMP1]ADDSTRNUM(nolign-1)
       Grizo [M:EMP1]ADDSTRNAM(nolign-1)
       Grizo [M:EMP1]ADDSUB(nolign-1)
       Grizo [M:EMP1]ADDTWN(nolign-1)
       Grizo [M:EMP1]ADDPOSCDE(nolign-1)
       Grizo [M:EMP1]ADDCNTCDE(nolign-1)
       Grizo [M:EMP1]ADDPRV(nolign-1)
       Grizo [M:EMP1]ADDPOSCOF(nolign-1)
       Grizo [M:EMP1]ADDPOSINM(nolign-1)

    Endif
Endif
 #MAPAD 20/01/2016 - Requirement 113638  US 4202   - END
End

# JOJAC - 2016-01-18 - Requirement 114553  US 1 - START
Subprog AM_BIDNUM(VALEUR)
Variable Char VALEUR()

  If VALEUR<>""
    If clalev ([F:BID1]) = 0: Local File EMPLORIB [BID1] : Endif
    Filter [BID1] Where [BID1]BIDNUM=VALEUR and [BID1]REFNUM<>[M]REFNUM
    If rowcount([BID1])>0
      GERR=1
      GMESSAGE=mess(48 ,11662,1)
      mkstat=0
    Endif
    Filter [BID1]
  Endif

End
# JOJAC - 2016-01-18 - Requirement 114553  US 1 - END

#JOJAC - 2016-02-22 - Requirement 113637 US 4204 - START
Subprog AM_SECNAM(VALEUR)
Variable Char VALEUR ()

  Raz [M:EMP2]NCKNAM
  Raz [M:EMP2]SECNAM
  Call CAL_NCKNAM([M:EMP0]SRN-VALEUR,"") From SUBEML2

End
#JOJAC - 2016-02-22 - Requirement 113637 US 4204 - END

#ADNGO - 2018-07-19 - X3-92892 - START
Subprog C_RFGNBR(VALEUR)
Variable Char    VALEUR()

  For nolign = 1 To dim([M:EMP4]HAB)
    If [M:EMP4]HAB(nolign-1) = "RA" Then
      If VALEUR="0" or VALEUR=""
        mkstat=2 : GMESSAGE=mess(10,123,1)
        End
      Endif
      If len(VALEUR) = 13 Then
        Local Integer RSAID_NUM(1..13)
        Local Integer COUNTER
        Local Integer TEMP_CALC1, TEMP_CALC2, TEMP_CALC3, TEMP_CALC4
        Local Char    TEMP_CHAR1(30)

        COUNTER=0
        For COUNTER=1 To 13
          If ascii(mid$(VALEUR,COUNTER,1))>=48 &ascii(mid$(VALEUR,COUNTER,1)) <=57
            RSAID_NUM(COUNTER)=val(mid$(VALEUR,COUNTER,1))
          Else
            GMESSAGE=mess(3,11662,1)-num$(COUNTER)-mess(4,11662,1)
            mkstat=2
            End
          Endif
        Next
        TEMP_CALC1=RSAID_NUM(1)+RSAID_NUM(3)+RSAID_NUM(5)+RSAID_NUM(7)+RSAID_NUM(9)+RSAID_NUM(11)
        TEMP_CALC2=(RSAID_NUM(2)*100000)+(RSAID_NUM(4)*10000)
&                 +(RSAID_NUM(6)*1000)+(RSAID_NUM(8)*100)+(RSAID_NUM(10)*10)+(RSAID_NUM(12))
        TEMP_CALC2=TEMP_CALC2*2
        TEMP_CHAR1=num$(TEMP_CALC2)
        For COUNTER=1 To val(string$(TEMP_CALC2<1000000,"6")+string$(TEMP_CALC2>=1000000,"7"))
          TEMP_CALC3+=val(mid$(TEMP_CHAR1,COUNTER,1))
        Next
        TEMP_CALC3+=TEMP_CALC1
        TEMP_CALC3=mod(TEMP_CALC3,10)
        If TEMP_CALC3<>0
          TEMP_CALC3=10-TEMP_CALC3
        Endif
        If TEMP_CALC3<>RSAID_NUM(13)
          GMESSAGE=mess(1,11662,1)
          mkstat=2
          End
        Endif
      Else
        mkstat=2 : GMESSAGE=mess(1,11662,1)
      Endif
    Endif
    If [M:EMP4]HAB(nolign-1) = "AS" Then
      If VALEUR="0" or VALEUR=""
        mkstat=2 : GMESSAGE=mess(10,123,1)
      Endif
    Endif
  Next
End
#ADNGO - 2018-07-19 - X3-92892 - END

