# JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
######################################################################################
######################################################################################
## Section automatically added (screen MAT1) 01/12/2015 10:36:28 (JASMI)
######################################################################################
Subprog C_ADDPOSNUM(VALEUR)
Variable Char    VALEUR()
  If [M:EMP1]ADDTYP(nolign-1)=2 Then
    If find([M:EMP1]ADDSRVTYP(nolign-1), 1, 2, 3) > 0 Then
      If VALEUR = "" Then
        GMESSAGE=mess(10,123,1)
        mkstat=2
      Endif
    Endif
  Endif
End

Subprog C_ADDPOSNAM(VALEUR)
Variable Char    VALEUR()
  If [M:EMP1]ADDTYP(nolign-1)=2 Then
    If find([M:EMP1]ADDSRVTYP(nolign-1), 1, 2, 3) > 0 Then
      If VALEUR = "" Then
        GMESSAGE=mess(10,123,1)
        mkstat=2
      Endif
    Endif
  Endif
End

Subprog C_ADDTWN(VALEUR)
Variable Char    VALEUR()
  If [M:EMP1]ADDTYP(nolign-1)=2 Then
    If [M:EMP1]ADDSRVTYP(nolign-1)=5 Then
      If VALEUR="" & [M:EMP1]ADDSUB(nolign-1)="" Then
        GMESSAGE = mess(26,11662,1)
        mkstat=2
      Endif
    Endif
  Else
    If VALEUR="" & [M:EMP1]ADDSUB(nolign-1)="" Then
      GMESSAGE = mess(26,11662,1)
      mkstat=2
    Endif
  Endif
End
