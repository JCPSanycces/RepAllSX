Subprog AM_ADDPOSCOF(VALEUR)
Variable Integer VALEUR
  If VALEUR=1 Then
    Grizo [M:EMP1]ADDPOSINM(nolign-1)
    Effzo [M:EMP1]ADDPOSINM(nolign-1)
  Else
    Actzo [M:EMP1]ADDPOSINM(nolign-1)
  Endif
End

