######################################################################################
## FLIP 27/11/2013 - This section defaults a bank account holder name if it is empty
######################################################################################
Subprog AV_BNKACCNAM(VALEUR)
Variable Char    VALEUR()
Local    Char    ZONE(10)
Local    Char    M_CIVA(15),M_NCKNAM(5),M_NAM(40)

  ZONE = "CIVA"
  Gosub SET_ZONE From SUBEML2
  If MA Then M_CIVA=[M]CIVA : Endif

  ZONE = "NCKNAM"
  Gosub SET_ZONE From SUBEML2
  If MA Then M_NCKNAM=[M]NCKNAM : Endif

  ZONE = "NAM"
  Gosub SET_ZONE From SUBEML2
  If MA Then M_NAM=[M]NAM : Endif

  VALEUR = M_CIVA-M_NCKNAM-M_NAM
End

######################################################################################
## FLIP 18/11/2013 - This section automatically assigns a priority number to an address
## transaction when entered
######################################################################################
Subprog AS_ADDPRI(VALEUR)
Variable Decimal VALEUR
Local Integer AC
Local Integer PRNR

  If VALEUR=0
    PRNR=1
    For AC=0 To dim([M]ADDPRI)-1
      If [M]ADDPRI(AC)=PRNR
        PRNR+=1
      Endif
    Next
    VALEUR=PRNR
  Endif
End

######################################################################################
## FLIP 21/11/2013 - This section determines the default values of address type according
## to what's already been chosen
######################################################################################
Subprog AM_ADDPRI(VALEUR)
Variable Decimal VALEUR
Local    Integer TYP1, TYP2, TYP3

  If [M]ADDTYP(nolign-1) = 0
    If !find(1,[M]ADDTYP) Then [M]ADDTYP(nolign-1)=1 : End : Endif
    If !find(2,[M]ADDTYP) Then [M]ADDTYP(nolign-1)=2 : End : Endif
    If !find(3,[M]ADDTYP) Then [M]ADDTYP(nolign-1)=3 : End : Endif
  Endif

# JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
  If VALEUR < 1 or VALEUR > 3 Then
    GMESSAGE=mess(83,123,1)
    mkstat=2
  Endif
# JASMI - 2015-01-12 - Requirement 104630 US 3276 - END

End

######################################################################################
## FLIP 22/11/2013 - This section disable adr serv type if not postal address
######################################################################################
Subprog AV_ADDSRVTYP(VALEUR)
Variable Integer VALEUR


#JASMI - 2015-11-27 - Req 112521 - START
#  If [M:EMP1]ADDTYP(nolign-1)<>2
## JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
#    [M:EMP1]ADDSRVTYP(nolign-1)=0
## JASMI - 2015-01-12 - Requirement 104630 US 3276 - END
#    Grizo [M:EMP1]ADDSRVTYP(nolign-1)
#  Else
## JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
#    [M:EMP1]ADDSRVTYP(nolign-1)=1
## JASMI - 2015-01-12 - Requirement 104630 US 3276 - END
#    Actzo [M:EMP1]ADDSRVTYP(nolign-1)
#  Endif
#
## JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
#  Call ENABLE_DISABLE_FOR_POSTAL_ADDRESS([M:EMP1]ADDSRVTYP(nolign-1))
## JASMI - 2015-01-12 - Requirement 104630 US 3276 - END
  If [M:EMP1]ADDTYP(nolign-1)<>2
    VALEUR=0
    Grizo [M:EMP1]ADDSRVTYP(nolign-1)
  Else
    Actzo [M:EMP1]ADDSRVTYP(nolign-1)
  Endif

  Call ENABLE_DISABLE_FOR_POSTAL_ADDRESS(VALEUR)
#JASMI - 2015-11-27 - Req 112521 - END

End

######################################################################################
## FLIP 22/11/2013 - This section toggles the mandatory indictor according to postal type
######################################################################################
Subprog C_ADDPOSCDE(VALEUR)
Variable Char    VALEUR()
# JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
  If [M:EMP1]ADDTYP(nolign-1)<>2 or [M:EMP1]ADDSRVTYP(nolign-1)<>4 Then
    If VALEUR="" Then
      mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
  Endif
# JASMI - 2015-01-12 - Requirement 104630 US 3276 - END
End

Subprog C_ADDSTRNAM(VALEUR)
Variable Char    VALEUR()
# JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
  If [M:EMP1]ADDTYP(nolign-1)<>2 Then
    If VALEUR ="" Then
      GMESSAGE = mess(10,123,1)
      mkstat=2
    Endif
  Endif
# JASMI - 2015-01-12 - Requirement 104630 US 3276 - END
End

######################################################################################
## FLIP 20/11/2013 - This section ensure that only one address can be flagged as
## correspondence address
######################################################################################
Subprog C_ADDCOR(VALEUR)
Variable Integer VALEUR
Local    Integer ADDCNT

  If VALEUR=2
    For ADDCNT=0 To dim([M]ADDPRI)-1
      If ADDCNT<>nolign-1
        [M]ADDCOR(ADDCNT)=1
        Affzo [M]ADDCOR(ADDCNT)
# JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
      Else
        [M:EMP1]ADDSTA([L]ADDCNT)=2
        Affzo [M:EMP1]ADDSTA([L]ADDCNT)
# JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
      Endif
    Next
  Endif
End

Subprog AS_ADDCNTCDE(VALEUR)
Variable Char    VALEUR()

  If VALEUR=""
    VALEUR="SA"
  Endif
End

######################################################################################
## Logic added for validation of RSA ID number
######################################################################################
Subprog C_RSAID(VALEUR)
Variable Char    VALEUR()

  If VALEUR="0" or VALEUR=""
    End
  Endif
#MIPEA - 2018/05/07 - X3-90361 - START
#JASMI - 2018-01-09 - X3-70791 - START
  [V]GPE = 0
  GPOINT = "RSA_ID_NO_OVERRIDE" : Gosub ENTREE From EXEFNC
  If [V]GPE=1 : End : Endif
#JASMI - 2018-01-09 - X3-70791 - END
#MIPEA - 2018/05/07 - X3-90361 - END
# JOJAC - 2016-01-18 - Requirement 113637  US 4203 - START
  If clalev([F:ESA1])=0 : Local File EMPLOIDSA    [ESA1]         : Endif
  Filter [ESA1] Where [ESA1]RSAID = VALEUR and [M]REFNUM <> [ESA1]REFNUM
  If rowcount([ESA1])>0
    GERR=1
    GMESSAGE=mess(47 ,11662,1)
    mkstat=2
    End
  Endif
  Filter [ESA1]
# JOJAC - 2016-01-18 - Requirement 113637  US 4203 - END

Local Integer RSAID_NUM(1..13)
Local Integer COUNTER
Local Integer TEMP_CALC1, TEMP_CALC2, TEMP_CALC3, TEMP_CALC4
Local Char    TEMP_CHAR1(30)


  COUNTER=0
  For COUNTER=1 To 13
    If ascii(mid$(VALEUR,COUNTER,1))>=48 &ascii(mid$(VALEUR,COUNTER,1)) <=57
      RSAID_NUM(COUNTER)=val(mid$(VALEUR,COUNTER,1))
    Else
#      GMESSAGE = "Digit number"-num$(COUNTER)-"is not numeric"
      GMESSAGE=mess(3,11662,1)-num$(COUNTER)-mess(4,11662,1)
      mkstat=2
      End
    Endif
  Next
  TEMP_CALC1=RSAID_NUM(1)+RSAID_NUM(3)+RSAID_NUM(5)+RSAID_NUM(7)+RSAID_NUM(9)+RSAID_NUM(11)
  TEMP_CALC2=(RSAID_NUM(2)*100000)+(RSAID_NUM(4)*10000)
&           +(RSAID_NUM(6)*1000)+(RSAID_NUM(8)*100)+(RSAID_NUM(10)*10)+(RSAID_NUM(12))
  TEMP_CALC2=TEMP_CALC2*2

  TEMP_CHAR1=num$(TEMP_CALC2)

  For COUNTER=1 To val(string$(TEMP_CALC2<1000000,"6")+string$(TEMP_CALC2>=1000000,"7"))
    TEMP_CALC3+=val(mid$(TEMP_CHAR1,COUNTER,1))
  Next
  TEMP_CALC3+=TEMP_CALC1
  TEMP_CALC3=mod(TEMP_CALC3,10)
  If TEMP_CALC3<>0OJ
    TEMP_CALC3=10-TEMP_CALC3
  Endif
  If TEMP_CALC3<>RSAID_NUM(13)
#    GMESSAGE="wrong ID number entered"
    GMESSAGE=mess(1,11662,1)
    mkstat=2
    End
  Endif

# JOJAC - 2016-01-15 - Requirement 113637  US 4203 - START
Local Char BIRTHYEAR(4),BIRTHMONTH(2),BIRTHDAY(2),IDYEAR(4),IDMONTH(2),IDDAY(2)

  If ([M:EMP2]DATBRN <> [0/0/0]) and len(num$(VALEUR)) > 6
  #get birthday elements
    BIRTHYEAR = mid$(num$(year([M:EMP2]DATBRN)),3,2)
    BIRTHMONTH = format$("N0:2",num$(month([M:EMP2]DATBRN)))
    BIRTHDAY= format$("N0:2",num$(day([M:EMP2]DATBRN)))

  #get ID number elements
    IDYEAR = num$(mid$(VALEUR,1,2))
    IDMONTH =mid$(VALEUR,3,2)
    IDDAY =mid$(VALEUR,5,2)

  #compare elements
    If BIRTHYEAR<>IDYEAR or BIRTHMONTH<>IDMONTH or BIRTHDAY<>IDDAY
      GMESSAGE=mess(46,11662,1)
      mkstat=2
      End
    Endif
  Endif
# JOJAC - 2016-01-18 - Requirement 113637  US 4203 - END
End

######################################################################################
## Logic added for validation of Employee tax Number
######################################################################################
Subprog C_EMPTAXNR(VALEUR)
Variable Char    VALEUR()

  If VALEUR="0" or VALEUR=""
    End
  Endif

Local Integer RSATAX_NUM(1..10)
Local Integer RSATAX_NUM2
Local Integer COUNTER2
Local Integer TEMP_CALC4, TEMP_CALC5

  COUNTER2=0
  For COUNTER2=1 To 10
    If ascii(mid$(VALEUR,COUNTER2,1))>=48 &ascii(mid$(VALEUR,COUNTER2,1)) <=57
      RSATAX_NUM(COUNTER2)=val(mid$(VALEUR,COUNTER2,1))
    Else
#      GMESSAGE = "Digit number"-num$(COUNTER2)-"is not numeric"
      GMESSAGE=mess(3,11662,1)-num$(COUNTER2)-mess(4,11662,1)
      mkstat=2
      End
    Endif
  Next
  RSATAX_NUM2=(RSATAX_NUM(1)*100)+(RSATAX_NUM(2)*10)+RSATAX_NUM(3)
  If RSATAX_NUM2<799 & RSATAX_NUM2>700
    RSATAX_NUM(1)=4
  Endif
  TEMP_CALC4=RSATAX_NUM(2)+RSATAX_NUM(4)+RSATAX_NUM(6)+RSATAX_NUM(8)

  For COUNTER2=1 To 9
    TEMP_CALC5=(RSATAX_NUM(COUNTER2)*2)
    If TEMP_CALC5>9
      TEMP_CALC5=TEMP_CALC5-9
    Endif
    TEMP_CALC4=TEMP_CALC4+TEMP_CALC5
    COUNTER2=COUNTER2+1
  Next
  TEMP_CALC5=(10-mod(TEMP_CALC4,10))
#JASMI - 2015-05-21 - Requirement number: 108372 - START
  If TEMP_CALC5=10
    TEMP_CALC5=0
  Endif
#JASMI - 2015-05-21 - Requirement number: 108372 - END

  If TEMP_CALC5<>RSATAX_NUM(10)
  #   GMESSAGE="wrong TAX number entered"
    GMESSAGE=mess(2,11662,1)
    mkstat=2
    End
  Endif
End

######################################################################################
## FLIP - 15/11/2013 - Added Actzo and Grizo for DISRSN, as this field must also be enabled
##                     and disabled depending on the disability flag only for SA
######################################################################################
Subprog GRISE_HANDICAP(VALEUR)
Value Integer VALEUR
  #LIPET - 2017-05-02 - X3-34892 - START
  #If func AFNC.ACTIV("KSA")>0
  If func AFNC.ACTIV("KGZA")>0
  #LIPET - 2017-05-02 - X3-34892 - END
    If VALEUR=2
      Actzo [M]DISRSN
    Else
      DISRSN=""
      Affzo [M]DISRSN
      Grizo [M]DISRSN
    Endif
  Endif
End

######################################################################################
## Tests for mandatory as well as fields that should not be enabled for RSA tax status reasons
##FLNEL on 3 Feb 2014
######################################################################################
Subprog AV_TAXDMD(VALEUR)
Variable Decimal VALEUR
#Dbgaff
If [M]TAXSTA(nolign-1)=4 or [M]TAXSTA(nolign-1)=5 or [M]TAXSTA(nolign-1)=7 or [M]TAXSTA(nolign-1)=16
 Actzo [M]TAXDMD(nolign-1)
Else
  Grizo [M]TAXDMD(nolign-1)
Endif
End

Subprog C_TAXDMD(VALEUR)
Variable Decimal VALEUR()

  If [M]TAXSTA(nolign-1)=7
    If VALEUR=0
      mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
  Endif
End

Subprog AV_TAXDIRNMB(VALEUR)
Variable Char    VALEUR()
If [M]TAXSTA(nolign-1)=2 or [M]TAXSTA(nolign-1)=6 or [M]TAXSTA(nolign-1)=7 or [M]TAXSTA(nolign-1)=16
&  or [M]TAXSTA(nolign-1)=17
 Actzo [M]TAXDIRNMB(nolign-1)
Else
  Grizo [M]TAXDIRNMB(nolign-1)
Endif
End

Subprog AV_TAXDIRPCT(VALEUR)
Variable Decimal VALEUR
If [M]TAXSTA(nolign-1)=2 or [M]TAXSTA(nolign-1)=6
 Actzo [M]TAXDIRPCT(nolign-1)
Else
  Grizo [M]TAXDIRPCT(nolign-1)
Endif
End

