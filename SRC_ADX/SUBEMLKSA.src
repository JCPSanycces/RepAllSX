# JASMI - 2014/03/10 - Requirement 93909 US 2439
# End

#JASMI - 2015-06-08 - Requirement 104630 US 3682 - START
    If clalev([F:HREXR])=0 : Local File HREXTRACTRES  [HREXR] : Endif
    If clalev([F:ETR])=0   : Local File EMPLOTAXREC   [ETR]   : Endif
#JASMI - 2015-06-08 - Requirement 104630 US 3682 - END
  Endif
#FRLAA and JASMI - 2015-02-19 - Requirement 104592 US 3261 - END
Return

