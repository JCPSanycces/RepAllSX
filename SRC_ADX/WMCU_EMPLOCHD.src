#<AdxTL>@(#)0.0.0.0 $Revision$Class Children
# Supervisor
## CRUD-CLASSE ## EMPLOCHD
# 2018-11-06 07:06:02 168


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(EMPLOCHD,ASTATUS)
Variable Instance EMPLOCHD Using C_EMPLOCHD
Variable Integer ASTATUS

If EMPLOCHD = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOCHD

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_EMPLOCHD

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(EMPLOCHD,ASTATUS)
Variable Instance EMPLOCHD Using C_EMPLOCHD
Variable Integer ASTATUS

If EMPLOCHD = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOCHD
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
EMPLOCHD.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_EMPLOCHD
Else
 Gosub AUPDATE_EMPLOCHD
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = EMPLOCHD.freeSnapshot
EMPLOCHD.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOCHD._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOCHD._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOCHD._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If EMPLOCHD.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOCHD.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(EMPLOCHD.ASTALIN)<>""
 [L]A_ASTALIN = EMPLOCHD.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER

If [V]CST_ASTALIN(EMPLOCHD.ASTALIN)<>""
 [L]A_ASTALIN = EMPLOCHD.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_EMPLOCHD
Trbegin [F:CHD]
 Gosub AUPDATE_EMPLOCHD
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_EMPLOCHD
[L]A_ASTALIN = EMPLOCHD.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOCHD._MAJSQL_EMPLOCHD(EMPLOCHD))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


[L]A_ASTALIN = EMPLOCHD.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If EMPLOCHD.snapshotEnabled=1
 [L]A_RETIK = EMPLOCHD.revertUpdTick
Endif

[L]ASTATUS = max(fmet EMPLOCHD.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(EMPLOCHD.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EMPLOCHD.ASTALIN = [V]CST_ALL
Endif
Return



