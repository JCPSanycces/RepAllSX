#<AdxTL>@(#)6.0.0.0 $Revision$
##############################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "AS_LIBEL"    : Gosub AS_LIBEL
Endcase
Return

##############################################################
$OUVRE
# Maj des intitulés familles statistiques à partir des menus locaux
Local Char SZBRAND
Local Char SZTXTNUM

If GPRODUIT=0 & !GHISTO
   Local Integer WML
   For WML=0 To 24
      If    WML<5  Call MAJTEXTRA(mess(WML+1,206,1),"ATABTAB","LNGDES",num$(WML+20),"") From ATEXTRA
      Elsif WML<10 Call MAJTEXTRA(mess(WML-4,207,1),"ATABTAB","LNGDES",num$(WML+25),"") From ATEXTRA
      Elsif WML<15 Call MAJTEXTRA(mess(WML-9,208,1),"ATABTAB","LNGDES",num$(WML+30),"") From ATEXTRA
      Elsif WML<20 Call MAJTEXTRA(mess(WML-14,3005,1),"ATABTAB","LNGDES",num$(WML+425),"") From ATEXTRA
      Else         Call MAJTEXTRA(mess(WML-19,3007,1),"ATABTAB","LNGDES",num$(WML+425),"") From ATEXTRA
      Endif
   Next WML

   Call PARAM("", "MACBRAUSE", SZTXTNUM) From ADOVAL
   Call TEXTE(val(SZTXTNUM), SZBRAND) From OBJDIV
   If SZBRAND = ""
       Call TEXTE(14543, SZBRAND) From OBJDIV
   Endif
   Call MAJTEXTRA(SZBRAND,"ATABTAB","LNGDES","408","") From ATEXTRA
Endif

Return

$AS_LIBEL
If find(NUMTAB,20,21,22,23,24,30,31,32,33,34,40,41,42,43,44,440,441,442,443,444,445,446,447,448,449)
 OK = 0
Endif
Return
