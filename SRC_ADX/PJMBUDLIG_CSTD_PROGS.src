#######################################################################################
Funprog GET_PLBSEQ_FROM_PCCCOD(CTX, SOPPNUM, SPBUCOD, SPCCCOD)
Variable Instance CTX Using =[V]CST_C_NAME_CLASS_CONTEXT   # Issue X3-68131 - 2018-02-12 by FGR
Value Char SOPPNUM
Value Char SPBUCOD
Value Char SPCCCOD

Local Integer IARENDRE

  # Issue X3-46735 - 2017-06-28 by FGR
  IARENDRE = 0
  # ------------------------------
  Local File PJMBUDLIG [PJLB]
  # ------------------------------
  Filter [PJLB] Where [F:PJLB]OPPNUM = SOPPNUM and [F:PJLB]PBUCOD = SPBUCOD and [F:PJLB]PCCCOD = SPCCCOD
  For [PJLB]PJLB0
    IARENDRE = [F:PJLB]PLBSEQ
    Break
  Next
  Filter [PJLB]
End IARENDRE

#######################################################################################
Funprog GET_PLBU(CTX, SOPPNUM, SPBUCOD, IPLBSEQ)
Variable Instance CTX Using =[V]CST_C_NAME_CLASS_CONTEXT   # Issue X3-68131 - 2018-02-12 by FGR
Value Char SOPPNUM
Value Char SPBUCOD
Value Integer IPLBSEQ

Local Char SARENDRE(GLONUOM)

  # Issue X3-46735 - 2017-06-28 by FGR
  Raz SARENDRE
  # ------------------------------
  Local File PJMBUDLIG [PJLB]
  # ------------------------------
  Read [PJLB]PJLB0=SOPPNUM;SPBUCOD;IPLBSEQ
  If !fstat Then
    SARENDRE = [F:PJLB]PLBU
  Endif
End SARENDRE

#######################################################################################
Funprog GET_KEYCONCAT(CTX, SOPPNUM, SPBUCOD)
Variable Instance CTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SOPPNUM
Value Char SPBUCOD

Local Char SARENDRE(GLONVPJ)

  # Issue X3-68131 - 2018-02-12 by FGR
  SARENDRE = SOPPNUM + "~" + SPBUCOD
End SARENDRE

#######################################################################################
Funprog GET_PLBDESAXX(CTX, SOPPNUM, SPBUCOD, IPLBSEQ)
Variable Instance CTX Using OBJECT
Value Char SOPPNUM
Value Char SPBUCOD
Value Integer IPLBSEQ

Local Char SARENDRE(GLONDCO)
Local Char SKEYCONCAT(GLONVPJ)

  # Issue X3-68131 - 2018-02-12 by FGR
  Raz SARENDRE
  SKEYCONCAT = func GET_KEYCONCAT(CTX.ACTX, SOPPNUM, SPBUCOD)
  Call LECTEXTRA_SYR(CTX, AVOID.ACHAR, SARENDRE, "PJMBUDLIG", "PLBDESAXX", SKEYCONCAT, num$(IPLBSEQ)) From ATEXTRA
End SARENDRE

