# PROGS
#######################################################################################
Funprog PLBDESTEX_EXIST(ACTX, SIDENT2, IIDENT3)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SIDENT2
Value Integer IIDENT3

Local Integer IARENDRE

  # Issue X3-6422/120397 - 2017-03-15 by SINGC
  IARENDRE = func OPPORPJM_CSTD_PROGS.IS_PJMCLOB_EXIST(ACTX, "PJMBUDLIG", "PLBDESTEX", SIDENT2, num$(IIDENT3), AVOID.ACHAR)
End IARENDRE

#######################################################################################
Funprog PLBCOMTEX_EXIST(ACTX, SIDENT2, IIDENT3)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SIDENT2
Value Integer IIDENT3

Local Integer IARENDRE

  # Issue X3-6422/120397 - 2017-03-15 by SINGC
  IARENDRE = func OPPORPJM_CSTD_PROGS.IS_PJMCLOB_EXIST(ACTX, "PJMBUDLIG", "PLBCOMTEX", SIDENT2, num$(IIDENT3), AVOID.ACHAR)
