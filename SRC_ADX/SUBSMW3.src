#<AdxTL>@(#)8.0.0.0 $Revision$
# Gestion du masque SMBENCHW3 selon MBENCHW3
# Traitement de la fenêtre dans BENCHLIBS
# - action SAICREEOX, fenetre DCREEOX (selon SAICREWOX)


########################################
Subprog AM_PUU2(VALEUR)
#-----------------------------#
# Contrôle de l'unité d'achat #
#-----------------------------#
Variable Char    VALEUR()
#----- contrôle que l'unité d'achat convienne pour le couple article/fournisseur -----#
# Issue 88337 GA 10/2013 ctrl PUU
If !clalev([F:ITP])   Local File ITMBPS     [ITP]   Endif
If [F:ITP]ITMREF <> [M:SMW3]ITMREF | [F:ITP]BPSNUM <> [M:SMW3]BPRNUM2
    Read [ITP]ITP0=[M:SMW3]ITMREF;[M:SMW3]BPRNUM2
    If fstat : Raz [F:ITP] : End : Endif
Endif
Local Char WUOM(GLONUOM) : WUOM=VALEUR
If    WUOM=[F:ITP]PUU
      [M:SMW3]PUUSTUCOE=[F:ITP]PUUSTUCOE
Elsif WUOM=[F:ITM]PUU
      [M:SMW3]PUUSTUCOE=[F:ITM]PUUSTUCOE
Else
      Call CTLUOM([M:SMW3]ITMREF,1,[M:SMW3]BPRNUM2,WUOM,[M:SMW3]PUUSTUCOE,
&                 GBIDC2,GBIDC3,GBIDI1) From STKACT
      If mkstat  End : Endif
Endif
End

########################################
Subprog B1_QTYPUU2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:SMW3]ITMREF
    Read [ITF]ITF0=[M:SMW3]ITMREF;[M:SMW3]POHFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]MFGLOTQTY*[M:SMW3]PUUSTUCOE
End

########################################
Subprog B2_QTYPUU2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:SMW3]ITMREF
    Read [ITF]ITF0=[M:SMW3]ITMREF;[M:SMW3]POHFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]REOMINQTY*[M:SMW3]PUUSTUCOE
End

########################################
Subprog AS_QTYPUU2(VALEUR)
Variable Decimal VALEUR
GBOUT1 = mess(151,198,1)
GBOUT2 = mess(150,198,1)
If [M:SMW3]BOMALT2 = 0
    GBOUT3 = ""
Else
    GBOUT3 = mess(282,198,1)
Endif
End

########################################
Subprog C_QTYPUU2(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : mkstat = 2 : Endif
#Issue X3-58162 15/12/2017 by GEBIL : The quantity must be greater than or equal to the quantity selected
#If VALEUR < [M:SMW3]COVQTY * [M:SMW3]PUUSTUCOE
If VALEUR * [M:SMW3]PUUSTUCOE < [M:SMW3]COVQTY
    GMESSAGE = mess(120,193,1)-"("+num$([M:SMW3]COVQTY)-[M:SMW3]STU2+")"
    mkstat = 2
Endif
End

########################################
Subprog AM_QTYPUU2(VALEUR)
Variable Decimal VALEUR
Local    Integer OK
Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI
Local    Char    WART(GLONITM)
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI,WAVAOFS,WQUALTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Integer WALT            # llc 05.03 18397

If VALEUR = 0 : mkstat = 2 : End : Endif

# conversion de la qté UA en US
Call PCAL_QTY(VALEUR,[M:SMW3]PUU2,[M:SMW3]EXTQTY2,[M:SMW3]STU2,
&             [M:SMW3]ITMREF,[M:SMW3]BPRNUM2,1,[M:SMW3]PUUSTUCOE) From TRTACHQTE1

Call AM_EXTQTY2([M:SMW3]EXTQTY2)

End

########################################
Subprog B1_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:SMW3]ITMREF
    Read [ITF]ITF0=[M:SMW3]ITMREF;[M:SMW3]POHFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]MFGLOTQTY
End

########################################
Subprog B2_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:SMW3]ITMREF
    Read [ITF]ITF0=[M:SMW3]ITMREF;[M:SMW3]POHFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]REOMINQTY
End

########################################
Subprog AS_EXTQTY2(VALEUR)
Variable Decimal VALEUR
GBOUT1 = mess(151,198,1)
GBOUT2 = mess(150,198,1)
If [M:SMW3]BOMALT2 = 0
    GBOUT3 = ""
Else
    GBOUT3 = mess(282,198,1)
Endif
End

########################################
Subprog C_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : mkstat = 2 : Endif
If VALEUR < [M:SMW3]COVQTY
    GMESSAGE = mess(120,193,1)-"("+num$([M:SMW3]COVQTY)+")"
    mkstat = 2
Endif
End

########################################
Subprog AM_EXTQTY2(VALEUR)
Variable Decimal VALEUR
Local    Integer OK
Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI
Local    Char    WART(GLONITM)
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Integer WALT            # llc 05.03 18397

WQTY = VALEUR

If [M:SMW3]STRDAT2 = [0/0/0] | [M:SMW3]ENDDAT2 = [0/0/0] : End : Endif

WORIFCY=[M:SMW3]POHFCY
WLTI=0

WRET = func ITMLIB.READ_ITM_ITF ([M:SMW3]ITMREF, [M:SMW3]POHFCY)

WQTY = VALEUR
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# calcul date
WORIDAT=[M:SMW3]ENDDAT2
WMEMDAT=[M:SMW3]STRDAT2

# révision calendriers (llc 06.00)
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:SMW3]STRDAT2) From MFGLIB

Affzo [M:SMW3]STRDAT2
Call CHECK_PAST([M:SMW3]STRDAT2, 2) From MFGLIB
End

########################################
Subprog AS_STRDAT2(VALEUR)
Variable Date    VALEUR

If VALEUR=[0/0/0] : VALEUR=date$ : Endif

End

########################################
Subprog C_STRDAT2(VALEUR)
Variable Date    VALEUR

If VALEUR=[0/0/0] : mkstat=2 : End : Endif

# FQ 66569 GA 09/2010 ne pas tenir compte des schémas hebdomadaires sur achats de sous-traitance
# révision calendriers (llc 06.00)
#Call CONTROL_DATE_PLN(VALEUR, [M:SMW3]POHFCY) From MFGLIB

# Epic: 55934 (STLIG) default bom code (product supplier)
If ([M:SMW3]BPRNUM2 <> "")
  Local Integer WBOMALT : WBOMALT=0
  Call FIND_BOMALT([M:SMW3]ITMREF,[M:SMW3]BPRNUM2,WBOMALT) From SCOLIB
  If (WBOMALT <> 0 &
&     func SUBSMW1.VALBOMALT(WBOMALT,[M:SMW3]PRHFCY,[M:SMW3]ITMREF,[M:SMW3]STRDAT2,0) > 0)
    [M:SMW3]BOMALT2 = WBOMALT
  Endif
Endif
If [M:SMW3]BOMALT2 = 0 & [F:ITM]ITMREF = [M:SMW3]ITMREF
    [M:SMW3]STRDAT2 = VALEUR
    Call RECH_NOM([M:SMW3]POHFCY, [M:SMW3]STRDAT2, [M:SMW3]BOMALT2,3) From BENCHLIB
Endif

# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:SMW3]ECCVALMAJ)>0
    Call C_STRDAT2(VALEUR, "SMW3") From SUBSMWECC
Endif
End

########################################
Subprog AM_STRDAT2(VALEUR)
Variable Date    VALEUR
Local    Integer WRET
Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI
Local    Char    WART(GLONITM)
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY


# FQ 66569 GA 09/2010 ne pas tenir compte des schémas hebdomadaires sur achats de sous-traitance
# calendrier
#Call CONTROL_DATE_PLN(VALEUR, [M:SMW3]POHFCY) From MFGLIB
#If mkstat = 2 : End : Endif

# antériorité par rapport à la date du jour ?
Call CHECK_PAST(VALEUR, 2)  From MFGLIB

WORIDAT=VALEUR
WORIFCY=[M:SMW3]POHFCY
WLTI=0

# lecture article site
Read [ITF]ITF0=[M:SMW3]ITMREF;[M:SMW3]POHFCY
If fstat : End : Endif
WQTY = [M:SMW3]EXTQTY2
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# calcul date
If WLTI>0
  # révision calendriers (llc 06.00)
  Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:SMW3]ENDDAT2) From MFGLIB
  Affzo [M:SMW3]ENDDAT2
Endif

End

########################################
Subprog AS_ENDDAT2(VALEUR)
Variable Date    VALEUR

If [M:SMW3]STRDAT2=[0/0/0] : mkstat=2 : End : Endif

End

########################################
Subprog C_ENDDAT2(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : mkstat=2 : End : Endif

# FQ 66569 GA 09/2010 ne pas tenir compte des schémas hebdomadaires sur achats de sous-traitance
# révision calendriers (llc 06.00)
#Call CONTROL_DATE_PLN(VALEUR, [M:SMW3]POHFCY) From MFGLIB
#If mkstat : End : Endif

End

########################################
Subprog AM_ENDDAT2(VALEUR)
Variable Date    VALEUR
Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI
Local    Char    WART(GLONITM)
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY

If VALEUR < [M:SMW3]STRDAT2 : mkstat = 2 : End : Endif

  # calcul de la date de début selon date fin
    WORIDAT=VALEUR
    WORIFCY=[M:SMW3]POHFCY
    WLTI=0

    # lecture article site
    Read [ITF]ITF0=[M:SMW3]ITMREF;[M:SMW3]POHFCY
    If fstat : End : Endif
    WQTY = [M:SMW3]EXTQTY2
    Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
    ILTI    = int(XLTI)
    WRMD    = XLTI - ILTI
    If WRMD <> 0 : ILTI += 1 : Endif
    WLTI=ILTI
    If [M:SMW3]STRDAT2=[0/0/0]
       # révision calendriers (llc 06.00)
       Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:SMW3]STRDAT2) From MFGLIB

       Affzo [M:SMW3]STRDAT2
       Call CHECK_PAST([M:SMW3]STRDAT2, 2) From MFGLIB
    Endif
    If [M:SMW3]BOMALT2 = 0
       Call RECH_NOM([M:SMW3]POHFCY, [M:SMW3]STRDAT2, [M:SMW3]BOMALT2,3) From BENCHLIB
    Endif

End

Subprog AS_BOMALT2(VALEUR)
Variable Decimal VALEUR

# Epic: 55934 (STLIG) default bom code
If (VALEUR = 0)
    Call RECH_NOM([M:SMW3]PRHFCY,[M:SMW3]STRDAT2,VALEUR,3) From BENCHLIB
Endif

End

Subprog C_BOMALT2(VALEUR)
Variable Decimal VALEUR

#Epic: 55934 (STLIG) validate bom code
If (func SUBSMW1.VALBOMALT(VALEUR,[M:SMW3]PRHFCY,[M:SMW3]ITMREF,[M:SMW3]STRDAT2,1) = 0)
  mkstat = 2
Endif

End

########################################
Subprog AM_BOMALT2(VALEUR)
Variable Decimal VALEUR

End

########################################
Subprog C_POHFCY(VALEUR)
Variable Char    VALEUR()

Local    Integer WOK

If [F:FCY]FCY <> VALEUR
    If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
    Read [FCY]FCY0=VALEUR
    If fstat : mkstat = 2 : End : Endif
Endif

If [M:SMW3]ITMREF<>""
   WOK = func ITMLIB.READ_ITM_ITF ([M:SMW3]ITMREF, VALEUR)
   If WOK=1 : mkstat = 1 : End : Endif
Endif
End

########################################
Subprog AM_POHFCY(VALEUR)
Variable Char    VALEUR()
If GFCY <> VALEUR
    GFCY = VALEUR
Endif

# GA 08/2006 à revoir plan car globale GMGLNUM non definie
# Gosub CHARG_PARAM From FUNGBENCH
# GH  12/03/2013 bug 76100
Gosub CHARG_PARAM From FUNGBENCH

# Issue 86437 GA 12/2012
#----- Contrôle et chargement des zones inter-sites -----#
  Call CTRL_INTERSITE (VALEUR,[M:SMW3]BPRNUM2)
  If mkstat
    GERR=1 : mkstat=1 : End
  Endif
End

End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()

Local    Integer WOK

WOK = func ITMLIB.READ_ITM_ITF (VALEUR, [M:SMW3]POHFCY)
If WOK=1 : mkstat = 1 : End : Endif
#
Call CONTSCOITM([M:SMW3]POHFCY, 1) From SCOLIB

#    Contrôle filtre par planificateur
Call CTLPLNFLT([M:SMW3]POHFCY, VALEUR, [M:SMW3]PLANNER) From MFGLIB
If GMESSAGE <> ""
    mkstat=1
    End
Endif

End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char   VALEUR()
Local    Integer    WLTI, WQUALTI, WMFGLTI
Local    Decimal    XLTI
Local    Integer    ILTI
Local    Decimal    WRMD

[M:SMW3]EXTQTY2 = [F:ITF]REOMINQTY
[M:SMW3]STU2 = [F:ITM]STU

# délai fabrication
XLTI    = [F:ITF]MFGLTI
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WMFGLTI = ILTI

# délai qualité
XLTI    = [F:ITF]QUALTI
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WQUALTI = ILTI

If WQUALTI = 0
    [M:SMW3]AVAOFS = num$(WMFGLTI)
Else
    [M:SMW3]AVAOFS = num$(WMFGLTI)-"(+"+num$(WQUALTI)+")"
Endif

Affzo [M:SMW3]10

# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:SMW3]ECCVALMAJ)>0
    Call AM_ITMREF_SMW3(VALEUR) From SUBSMWECC
Endif

# Epic: 55934 (STLIG) - supplier initialisation
If ([M:SMW3]BPRNUM2 = "")
  Local Integer ITMBPS
  Call DEFBPSNUM(VALEUR,"",[M:SMW3]POHFCY,"",1,[M:SMW3]BPRNUM2,ITMBPS) From TRTACHDEF1
  If (ITMBPS > 0)
    Read [ITP]ITP0=VALEUR;[M:SMW3]BPRNUM2
    If (fstat)
      Raz [F:ITP]
    Else
      [M:SMW3]PUU2 = [F:ITP]PUU
    Endif
    Affzo [M:SMW3]BPRNUM2
  Endif
Endif

End

######################################################################################
Subprog AS_BPRNUM2(VALEUR)
Variable Char    VALEUR()
#---------------------------------------------------#
#      Avant saisie du fournisseur                  #
#---------------------------------------------------#
Local Char       WBPS(GLONBPR)
Local Integer    WBOMALT : WBOMALT = [M:SMW3]BOMALT2
Raz WBPS

Call FIND_BPRNUM ([M:SMW3]ITMREF,WBOMALT,[M:SMW3]POHFCY,[M:SMW3]PRHFCY,VALEUR) From SCOLIB

If VALEUR = "" & WBPS <> ""
   VALEUR          = WBPS
   [M:SMW3]BPRNUM2 = WBPS
   Affzo [M:SMW3]BPRNUM2
Endif

# Epic: 55934 (STLIG) enable/disable product selection on parameter: ITMBPSFCY
If (GITMBPSFCY = 1)
  GBOUT2 = ""
Else
  GBOUT2 = mess(1,3505,1)
Endif
GBOUT3 = mess(2,3505,1) # product-site suppliers

End

Subprog C_BPRNUM2(VALEUR)
Variable Char VALEUR

# Epic: 55934 (STLIG) validate 1. blocking flag, and 2. product and product-site reference
Local Integer WITMBPS
Local Integer WRETOUR
If (VALEUR <> "")
  Call CTRL_DOUFLG(1,[M:SMW3]ITMREF,VALEUR,[M:SMW3]POHFCY,WITMBPS,WRETOUR) From TRTACHCTL1
  If (WRETOUR <> 0)
    mkstat = 2
  Endif
Else
  GERR = 1 : GMESSAGE = mess(69,197,1)
  mkstat = 2
Endif

End

Subprog AM_BPRNUM2(VALEUR)
Variable Char    VALEUR()
#----- Lecture BPARTNER si nécessaire pour chargement CUR, LAN -----#
If [F:BPR]BPRNUM<>VALEUR
  Read [BPR] BPR0=VALEUR
  If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
GCUR=[F:BPR]CUR
#----- Contrôle et chargement des zones inter-sites -----#
Call CTRL_INTERSITE ([M:SMW3]POHFCY,VALEUR)
If mkstat
  GERR=1 : mkstat=1 : End
Endif

# Issue 88337 GA 10/2013 ctrl PUU
Local Char WBPRNUM(GLONBPR) : WBPRNUM=VALEUR
If !clalev([F:ITP])   Local File ITMBPS     [ITP]   Endif
If [F:ITP]ITMREF <> [M:SMW3]ITMREF | [F:ITP]BPSNUM <> WBPRNUM
    Read [ITP]ITP0=[M:SMW3]ITMREF;WBPRNUM
    If fstat : Raz [F:ITP] : End : Endif
Endif
If [F:ITP]PUU<>""
   [M:SMW3]PUU2 = [F:ITP]PUU
Elsif [F:ITM]PUU<>""
   [M:SMW3]PUU2 = [F:ITM]PUU
Endif
Affzo [M:SMW3]PUU2
If    [M:SMW3]PUU2=[F:ITP]PUU
      [M:SMW3]PUUSTUCOE=[F:ITP]PUUSTUCOE
Elsif [M:SMW3]PUU2=[F:ITM]PUU :
      [M:SMW3]PUUSTUCOE=[F:ITM]PUUSTUCOE
Else
      Call CTLUOM([M:SMW3]ITMREF,1,WBPRNUM,[M:SMW3]PUU2,[M:SMW3]PUUSTUCOE,
&                 GBIDC2,GBIDC3,GBIDI1) From STKACT
      If mkstat  End : Endif
Endif

If [M:SMW3]EXTQTY2<>0
   # Issue 58162 GH 11/01/2018 - wrong calculation of STK qty
   # [M:SMW3]QTYPUU2 = [M:SMW3]EXTQTY2 * [M:SMW3]PUUSTUCOE
   # Affzo [M:SMW3]QTYPUU2
   Local Decimal WUSQTY
   WUSQTY = [M:SMW3]EXTQTY2
   Call PCAL_QTY([M:SMW3]EXTQTY2,[M:SMW3]STU2,[M:SMW3]QTYPUU2,[M:SMW3]PUU2,
&                [M:SMW3]ITMREF,VALEUR,1,GBIDD1) From TRTACHQTE1
   [M:SMW3]EXTQTY2 = [M:SMW3]QTYPUU2 * [M:SMW3]PUUSTUCOE
   Call QTEARR([M:SMW3]EXTQTY2,[M:SMW3]STU2) From TRTDIV
   If  [M:SMW3]EXTQTY2 < [M:SMW3]COVQTY
       [M:SMW3]EXTQTY2 = WUSQTY
       Call PCAL_QTY([M:SMW3]EXTQTY2,[M:SMW3]STU2,[M:SMW3]QTYPUU2,[M:SMW3]PUU2,
&                    [M:SMW3]ITMREF,VALEUR,11,GBIDD1) From TRTACHQTE1
       [M:SMW3]EXTQTY2 = [M:SMW3]QTYPUU2 * [M:SMW3]PUUSTUCOE
       Call QTEARR([M:SMW3]EXTQTY2,[M:SMW3]STU2) From TRTDIV
   Endif
   Affzo [M:SMW3]QTYPUU2, EXTQTY2
Endif

# Epic: 55934 (STLIG) default bom code (product supplier)
If (VALEUR <> "" & [M:SMW3]BPRNUM2 <> VALEUR)
  Local Integer WBOMALT : WBOMALT=0
  Call FIND_BOMALT([M:SMW3]ITMREF,VALEUR,WBOMALT) From SCOLIB
  If (WBOMALT <> 0)
    [M:SMW3]BOMALT2 = WBOMALT
    Affzo [M:SMW3]BOMALT2
    If (func SUBSMW1.VALBOMALT([M:SMW3]BOMALT2,[M:SMW3]PRHFCY,[M:SMW3]ITMREF,[M:SMW3]STRDAT2,1) = 0)
      GERR = 1
      zonsui = "BOMALT2"
    Endif
  Endif
Endif

End

######################################################################################
Subprog CTRL_INTERSITE (LPOHFCY,LBPSNUM)
Variable Char    LPOHFCY
Variable Char    LBPSNUM

Local Char    WSALFCY(GLONFCY)
Local Char    WINVFCY(GLONFCY)
Local Char    WMFGFCY(GLONFCY)
Local Char    WBPCORD(GLONBPR)
Local Char    WBPCINV(GLONBPR)
Local Integer WDME

#-----------------------------------------------------#
# Contrôle et chargement des zones pour l'inter-sites #
# --------------------------------------------------- #
# LPOHFCY : Site de commande                          #
# LBPSNUM : Fournisseur de la commande                #
#-----------------------------------------------------#
If LBPSNUM="" | LPOHFCY="" : End : Endif

Raz GRCPFCY
Call CTRL_INTERSITE(LPOHFCY,LBPSNUM,2,[M:SMW3]BETFCY,[M:SMW3]BETCPY,WSALFCY,
&                   WMFGFCY,WBPCORD,WINVFCY,WBPCINV,
&                   WDME) From TRTACHCTL1
If mkstat  GERR=1 : End : Endif
#-----
# Demande LLC: afficher un libellé plutôt que BETFCY et BETCPY
If [M:SMW3]BETCPY = 2
   [M:SMW3]ZBETCPY = mess(491,197,1)
Elsif [M:SMW3]BETFCY = 2
   [M:SMW3]ZBETCPY = mess(645,197,1)
Else
   [M:SMW3]ZBETCPY = ""
Endif
Affzo [M:SMW3]ZBETCPY

End

######################################################################################
Subprog D_PRHFCY(VALEUR)
Variable Char     VALEUR
VALEUR=[M:SMW3]POHFCY
End

Subprog AS_PRHFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   VALEUR=[M:SMW3]POHFCY
Endif
End

Subprog AM_PRHFCY(VALEUR)
Variable Char    VALEUR()
End

######################################################################################
## Section automatically added (screen SMBENCHW3) 06/24/2015 14:16:24 (BEEBE)
## Issue 104943 by BEEBE - 06/30/2015 - Implementing Versioning
######################################################################################
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Call AS_ECCVALMAJ(VALEUR) From SUBSMWECC
End

Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Call C_ECCVALMAJ(VALEUR, "SMW3") From SUBSMWECC
If VALEUR<>[M:SMW3]ECCVALMAJ
    GMODIF=3
Endif
End

Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
Call AS_ECCVALMIN(VALEUR) From SUBSMWECC
End

Subprog C_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
Call C_ECCVALMIN(VALEUR, "SMW3") From SUBSMWECC
If VALEUR<>[M:SMW3]ECCVALMIN
    GMODIF=3
Endif
End


######################################################################################

