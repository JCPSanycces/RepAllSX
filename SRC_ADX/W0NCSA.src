#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque NCSA 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone ACTIONID
mkstat = 0
zoncou = "ACTIONID"
indice = 0
If varmode([M]ACTIONID,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ACTIONID" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]ACTIONID,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "ACTIONID" : GZNUM = 89 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone TRANACTION
mkstat = 0
zoncou = "TRANACTION"
indice = 0
If varinit([M]TRANACTION,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]TRANACTION,"806","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]TRANACTION,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "TRANACTION" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]TRANACTION,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "TRANACTION" : GZNUM = 90 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]TRANACTION,"806","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TRANACTION" : GZNUM = 90 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]TRANACTION,"806",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "TRANACTION" : GZNUM = 90 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone TRANTYPE
mkstat = 0
zoncou = "TRANTYPE"
indice = 0
If varinit([M]TRANTYPE,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]TRANTYPE,"807","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]TRANTYPE,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "TRANTYPE" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]TRANTYPE,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "TRANTYPE" : GZNUM = 3209 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]TRANTYPE,"807","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TRANTYPE" : GZNUM = 3209 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]TRANTYPE,"807",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "TRANTYPE" : GZNUM = 3209 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "NCSA"
Return

