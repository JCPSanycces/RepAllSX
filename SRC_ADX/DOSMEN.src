#<AdxTL>@(#)67.0.0.0 $Revision$
#########################################################
## DOSMEN Validation de tous les menus d'admin         ##
#########################################################
Subprog GENMEN
Call ECR_TIME(mess(38,125,1)) From DOSSUB : # MAJ des menus 
If GINFO
 Call AFF_VLC(mess(38,125,1),"") From GESECRAN
Endif
Local Char    APPLI(GLONADS) , LANGUE(GLONLAN) 
Local Integer LANCUR
APPLI = [F:ADS]DOSSIER
Gosub DECLARE From VALMENU
Read [ADW]ADW0 = "";"";"ADMUSR"
SUPERU = [F:ADW]VALEUR
PROFIL = SUPERU
USRMEN = ""
SEP    = ""

Call DEBTRANS From GLOCK
Gosub TR1 From VALMENU
If GOK<1 : End : Endif
 
If GINFO
 Call AFF_VLC(mess(38,125,1),[F:ADS]LAN(LANCUR)-SUPERU) From GESECRAN
Endif
Call VALPROFAPP(SUPERU,APPLI) From VALMENU
End

#########################################################
## Validation des menus utilisateurs                   ##
#########################################################
Subprog MENUSER

Local Integer I , OK , NBPROF
Local Char    PROFCUR(GLONAFT) , TBPROF(GLONAFT)(1..500) , LANGUE(GLONLAN)

# Elimination des fonctions inexistantes

Call ECR_TRACE(mess(39,125,1),0) From GESECRAN
# MAJ des menus utilisateurs 
If GINFO
 Call AFF_VLC(mess(39,125,1),"") From GESECRAN
Endif
Local File =[F:ADS]DOSSIER+".AFONCTION" [AFC]
&        , =[F:ADS]DOSSIER+".AMENUSER"  [AMU]

Trbegin [AMU]
 For [AMU]MENFCT(1)
  OK = 1
  PROFCUR = [F:AMU]CODPRF
  For [AMU]MENFCT
   Read [AFC]CODINT = [F:AMU]FONCTION
   If fstat
    Delete [AMU]
    If fstat=1 : Call ERREUR("AMENUSER",3) From DOSDIC : Endif
    OK = 0
   Endif
  Next
  If !OK or GCRE
   NBPROF += 1
   TBPROF(NBPROF) = PROFCUR
  Endif
 Next AMU
Commit

For I=1 To NBPROF 
 If GINFO
  Call AFF_VLC(mess(39,125,1),TBPROF(I)) From GESECRAN
 Endif
 Call ECR_TRACE(mess(16,130,1)-TBPROF(I),0) From GESECRAN : # Profil menu
 Call VALPROFAPP(TBPROF(I),[F:ADS]DOSSIER) From VALMENU
Next I

End



