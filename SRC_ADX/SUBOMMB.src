#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
# Programmes utilitaires pour la gestion des publipostages        Module CRM             18 Novembre 2003
#
#   CLEANHISTO  : Supprime le code de l'opération marketing sur toutes les actions associées.
#   DISPICON    : Affichage des icônes
#   SAVECLOB    : Enregistrement des CLOBs
#   DELCLOB     : Suppression des CLOBs
#   LOADCLOB    : Chargement du CLOB compte-rendu
#   CHECKMODIF  : Contrôle de la modification d'une opération.
#
##########################################################################################################
##########################################################################################################
# Supprime le code de l'opération marketing sur toutes les actions associées.
###########################################################
$CLEANHISTO
  If !clalev([F:BAP2]) : Local File BAPPOINT [BAP2] : Endif
  If !clalev([F:CLL2]) : Local File PHONECALL [CLL2] : Endif
  If !clalev([F:TSK2]) : Local File TASK [TSK2] : Endif
  If !clalev([F:OPP2]) : Local File OPPOR [OPP2] : Endif
  If !clalev([F:SOH2]) : Local File SORDER [SOH2] : Endif
  If !clalev([F:SIV2]) : Local File SINVOICEV [SIV2] : Endif
  Filter [BAP2] Where [F:BAP2]APTOPGNUM = GSZOPGNUM
  For [BAP2]
    #[F:BAP2]APTORI = 1
    [F:BAP2]APTORIADI = "MAN1"  # FGR 05/03/2010 : X3SUIVI62924
    [F:BAP2]APTORIVCR = ""
    [F:BAP2]APTORIVCRL = 0
    [F:BAP2]APTCMGNUM = ""
    [F:BAP2]APTOPGNUM = ""
    [F:BAP2]APTOPGTYP = ""
    Rewrite [BAP2]
    If fstat Then
      GOK = 0
      Call FSTA("BAP2") From GLOCK
      Break
    Endif
  Next
  Filter [BAP2]
  If GOK = 0 Then
    Return
  Endif
  If IDELTODOCALL = 0 Then
    Filter [CLL2] Where [F:CLL2]CLLOPGNUM = GSZOPGNUM
    For [CLL2]
      #[F:CLL2]CLLORI = 1
      [F:CLL2]CLLORIADI = "MAN1"  # FGR 05/03/2010 : X3SUIVI62924
      [F:CLL2]CLLORIVCR = ""
      [F:CLL2]CLLORIVCRL = 0
      [F:CLL2]CLLCMGNUM = ""
      [F:CLL2]CLLOPGNUM = ""
      [F:CLL2]CLLOPGTYP = ""
      [F:CLL2]CLLCMGFLG = 0
      Rewrite [CLL2]
      If fstat Then
        GOK = 0
        Call FSTA("CLL2") From GLOCK
        Break
      Endif
    Next
    Filter [CLL2]
  Endif
  If GOK = 0 Then
    Return
  Endif
  Filter [TSK2] Where [F:TSK2]TSKOPGNUM = GSZOPGNUM
  For [TSK2]
    #[F:TSK2]TSKORI = 1
    #[F:CLL2]TSKORIADI = "MAN1"  # FGR 08/03/2010 : X3SUIVI62924
    [F:TSK2]TSKORIADI = "MAN1"   # FGR 23/08/2010 : X3SUIVI66826
    [F:TSK2]TSKORIVCR = ""
    [F:TSK2]TSKORIVCRL = 0
    [F:TSK2]TSKCMGNUM = ""
    [F:TSK2]TSKOPGNUM = ""
    [F:TSK2]TSKOPGTYP = ""
    Rewrite [TSK2]
    If fstat Then
      GOK = 0
      Call FSTA("TSK2") From GLOCK
      Break
    Endif
  Next
  Filter [TSK2]
  If GOK = 0 Then
    Return
  Endif
  Filter [OPP2] Where [F:OPP2]OPPOPGNUM = GSZOPGNUM
  For [OPP2]OPP3
    [F:OPP2]OPPORI = 1
    [F:OPP2]OPPORIVCR = ""
    [F:OPP2]OPPORIVCRL = 0
    [F:OPP2]OPPCMGNUM = ""
    [F:OPP2]OPPOPGNUM = ""
    [F:OPP2]OPPOPGTYP = ""
    Rewrite [OPP2]
    If fstat Then
      GOK = 0
      Call FSTA("OPP2") From GLOCK
      Break
    Endif
  Next
  Filter [OPP2]
  If GOK = 0 Then
    Return
  Endif
  Filter [SOH2] Where [F:SOH2]OPGNUM = GSZOPGNUM
  For [SOH2]
    [F:SOH2]CMGNUM = ""
    [F:SOH2]OPGNUM = ""
    [F:SOH2]OPGTYP = ""
    Rewrite [SOH2]
    If fstat Then
      GOK = 0
      Call FSTA("SOH2") From GLOCK
      Break
    Endif
  Next
  Filter [SOH2]
  If GOK = 0 Then
    Return
  Endif
  Filter [SIV2] Where [F:SIV2]OPGNUM = GSZOPGNUM
  For [SIV2]
    [F:SIV2]CMGNUM = ""
    [F:SIV2]OPGNUM = ""
    [F:SIV2]OPGTYP = ""
    Rewrite [SIV2]
    If fstat Then
      GOK = 0
      Call FSTA("SIV2") From GLOCK
      Break
    Endif
  Next
  Filter [SIV2]
  If GOK = 0 Then
    Return
  Endif
Return

##########################################################################################################
#Affichage des icônes
######################################################
$DISPICON
  Gosub DEFICONNUM From CRMUTIL150
  ##Synthèse Objet de l'action
  If len([M:OMM1]FULOBJ) > GLONCLE Then
    If [M:OMM1]OBJFLG Then
      [M:OMM1]OBJICO = SZICOSYNDON
    Else
      [M:OMM1]OBJICO = SZICOSYN
    Endif
    Actzo [M:OMM1]OBJICO
  Else
    [M:OMM1]OBJICO = "-1"    
    Grizo [M:OMM1]OBJICO
  Endif
Return

##########################################################################################################
#Enregistrement des CLOBs
######################################################
$SAVECLOB
  Gosub DELCLOB
  If GOK < 1 Then
    Return
  Endif

#Objet de l'action
Local Char SZCTLCLOB(250)

  Raz SZCTLCLOB
  Setlob SZCTLCLOB With [M:OMM1]FULOBJ
  If SZCTLCLOB <> "" Then
    Raz [F:HD5]
    [F:HD5]NUM = [M:OMM1]NUMFULOBJ
    [F:HD5]TYP = [M:OMM1]TYPFULOBJ
    [F:HD5]CLOB = [M:OMM1]FULOBJ
    Write [HD5]
    If fstat Then
      #Erreur lors de l'enregistrement de la description de l'opération marketing. Transaction abandonnée.
      GMESSAGE = mess(880,182,1)
      GERR = 1
      Call FSTA("HD5") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
######################################################
$DELCLOB
  Delete [HD5] Where [F:HD5]NUM = [M:OMM1]NUMFULOBJ and [F:HD5]TYP = [M:OMM1]TYPFULOBJ
  If fstat Then
    #Erreur lors de la suppression de la description de l'opération marketing. Transaction abandonnée.
    GMESSAGE = mess(881,182,1)
    GERR = 1
    Call FSTA("HD5") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
######################################################
$DELCLOB2
  Delete [HD5] Where [F:HD5]NUM = GSZOPGNUM and [F:HD5]TYP = "OMM"
  If fstat Then
    #Erreur lors de la suppression de la description de l'opération marketing. Transaction abandonnée.
    GMESSAGE = mess(881,182,1)
    GERR = 1
    Call FSTA("HD5") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
# Chargement du CLOB compte-rendu
######################################################
$LOADCLOB
Local Integer ILOOKFORCLOB

  ILOOKFORCLOB = 1
  If [M:OMM1]NUMFULOBJ = "" Then
    Raz [M:OMM1]FULOBJ
    ILOOKFORCLOB = 0
  Endif
  If [M:OMM1]TYPFULOBJ = "" Then
    Raz [M:OMM1]FULOBJ
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD5]HD50=[M:OMM1]NUMFULOBJ;[M:OMM1]TYPFULOBJ
    If fstat Then
      Raz [M:OMM1]FULOBJ
    Else
      [M:OMM1]FULOBJ = [F:HD5]CLOB
    Endif
  Endif
Return

##########################################################################################################
# Contrôle de la modification d'une opération.
######################################################
$CHECKMODIF
  #La description doit être renseignée.
  If [M:OMM1]DES = "" Then
    GMESSAGE = mess(342,196,1) #Aucune description n'a été saisie. Cette information est obligatoire.
    GERR = 2
    OK = 0
    Return
  Endif
  #La devise doit être renseignée.
  If [M:OMM1]CUR = "" Then
    GMESSAGE = mess(385,196,1) #Aucun code devise n'est renseigné. Modification refusée.
    GERR = 2
    OK = 0
    Return
  Endif
  Read [TCU]TCU0=[M:OMM1]CUR
  If fstat Then
    GMESSAGE = mess(84, 116, 1) #Devise incorrecte.
    GERR = 2
    OK = 0
    Return
  Else
    If [F:TCU]EURFLG = 2 Then
      If [F:TCU]CURENDDAT <> [00/00/00] Then
        If [F:TCU]CURENDDAT < date$ Then
          GMESSAGE = mess(84,116,1) #Devise incorrecte.
          GERR = 2
          OK = 0
          Return
        Endif        
      Endif
    Endif
  Endif
Return
