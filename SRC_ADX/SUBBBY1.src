#<AdxTL>@(#)8.0.0.0 $Revision$

# ECRAN BBY1   Composants Sortie
########################################################################
$ACTION
Case ACTION
 When "AAPRES_NBLIG" : Gosub AAPRES_NBLIG From SUBBBY1
 When "AB3_NBLIG"    : Gosub AB3_NBLIG    From SUBBBY1

 When Default
Endcase
Return

$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return

# suppression d un composant non gere en stock
#             delete SMVTD
#             recalcul priord du composé
$SUPP_NONGERE
Global Decimal GSTK_NONGERE
Local  Decimal WCNVRPT    # Taux de conversion devise société vers devise dossier
Local  Integer WRET
Local Decimal LDELTA_AMT

Raz GSTK_NONGERE

If !clalev([M:SDP]) : Local Mask SAIDECPRI [SDP] : Endif
Raz [M:SDP]

Call DEBTRANS From GLOCK
Trbegin [SMD]

For I=NOL To NOL1
    If [M:BBY1]PRIORD(I) <> 0
        LDELTA_AMT = [M:BBY1]PRIORD(I) *  [M:BBY1]QTYSTU (I)
        GSTK_NONGERE   -= LDELTA_AMT
        If [F:ITM]ITMREF<>[M:BBY1]ITMREF(I)
            Read [ITM]ITM0 = [M:BBY1]ITMREF(I)
            If fstat
              GOK = 0
              Call FSTA("ITM") From GLOCK
              Rollback
              Return
            Endif
        Endif

        [M:SDP]PRI    -= LDELTA_AMT
        [M:SDP]QTY     = 0    # On passe un delta
        [M:SDP]AMTTOT -= LDELTA_AMT

        [M:SDP]MATCST([F:ITM]BRDCOD-1) -= LDELTA_AMT
    Endif

    Readlock [SMD]SMD0=31;[M:BBY0]VCRNUM;[M:BBY1]VCRLIN(I)
    If fstat = 1
       GOK = -1
       GLOCK = "$SMVTD"-[M:BBY0]VCRNUM-num$([M:BBY1]VCRLIN(I))
       Rollback
       mkstat = 2
       Return
    Elsif fstat
       GOK =  0
       Call RSTA ("SMD",[M:BBY0]VCRNUM-num$([M:BBY1]VCRLIN(I))) From GLOCK
       Rollback
       mkstat = 2
       Return
    Endif

    If fstat = 0 & [F:SMD]UPDPRI=1    # Si le prix a été calculé on met à jour les mouvements et la ligne de doc du composé
        Delete [SMD] Curr
        If fstat
            Rollback
            mkstat = 2
            Return
        Endif
    #----- Suppression  sections de la ligne de document  -----#     # ana
        Delete [CAL] Where ABRFIC="SMD" & VCRTYP=[F:SMD]VCRTYP & VCRNUM=[F:SMD]VCRNUM & VCRLIN=[F:SMD]VCRLIN # ana
        If fstat=1                                                                                           # ana
           GOK=-1 : GLOCK="$CPTANALIN SMD 0"-[F:SMD]VCRNUM-num$([F:SMD]VCRLIN) : Return                      # ana
        Endif                                                                                                # ana

    Endif
Next

If [F:SMD]VCRTYP<>31 | [F:SMD]VCRNUM<>[M:BBY0]VCRNUM | [F:SMD]VCRLIN<>1
    Read [SMD]SMD0=31;[M:BBY0]VCRNUM;1
    If fstat
        GOK=0
        Rollback
        mkstat=2
        Return
    Endif
Endif

If [F:SMD]UPDPRI=1    # Si le prix a été calculé on met à jour les mouvements et la ligne de doc du composé
    If GSTK_NONGERE <> 0
        If [M:BBY0]PNTMVTCOD <> 1
            Call CONVERT2(GLOCALDEV,GSYSCUR,GLOCALDEV,GCHGTYP,[M:BBY0]IPTDAT,
&                         1,WCNVRPT,WRET) From TRTDEV

            # [M:SDP] est rempli juste avant
            Call REGPRIX([M:BBY0]STOFCY, 1, [M:BBY0]ITMREF(0), [M:BBY0]IPTDAT,
&                        [M:BBY0]TRSCOD, [M:BBY0]VCRTYP, [M:BBY0]VCRNUM , 1,
&                        [M:BBY0]VCRTYP, [M:BBY0]VCRNUM, [M:BBY0]VCRLIN(0), WCNVRPT,
&                        WRET) From STKVALREG
            If WRET
                Call ERREUR([M:BBY0]VCRNUM-mess(519,197,1)-"("+num$(WRET)+")") From GESECRAN
                GOK=0
                Rollback
                mkstat = 2
                Return
            Endif
        Endif
    Endif

    If GSTK_NONGERE <>  0
       If [M:BBY0]QTYSTU(0) <> 0
          [M:BBY0]PRIORD(0) +=  GSTK_NONGERE / [M:BBY0]QTYSTU(0)
       Endif
       Readlock [SMD]SMD0=31;[M:BBY0]VCRNUM;1
       If fstat = 1
          GOK = -1
          GLOCK = "$SMVTD"-[M:BBY0]VCRNUM-num$(1)
          Rollback
          mkstat = 2
          Return
       Elsif fstat
          GOK =  0
          Call RSTA ("SMD",[M:BBY0]VCRNUM-num$(1)) From GLOCK
          Rollback
          mkstat = 2
          Return
       Endif
       [F:SMD]PRIORD =  [M:BBY0]PRIORD(0)
       Rewrite [SMD]
       If fstat
          GOK=0
          Call FSTA("SMD") From GLOCK
          Rollback
          mkstat = 2
          Return
       Endif
       Affzo [M:BBY0]PRIORD(0)
    Endif
Endif
Commit
Kill GSTK_NONGERE
Global Integer GSUP
Return


########################################
Subprog C_NBLIG
Local Integer WRET, I
Local Integer NOL1                                  # hcb 28654
Local Integer WNONGERE                              # hcb 28654
Gosub SET_NOL
    Case status
        When 65     :                                # Suppression d'une ligne
            If [M:BBY1]CREFLG(NOL)=0
               [M:BBY1]QTYSTU (NOL) = 0
                Call DELSTOSORW(NOL,NOL,"BBY1",[M:BBY0]STOFCY,WRET) From STKSOR
                If WRET<>0 : mkstat=2 : Endif
            Else
               If [M:BBY1]VCRNUMORI (NOL) <> ""
                  GMESSAGE = mess (91,184,1)   # Suppression interdite ! Cette ligne à été désassemblée.
                  mkstat = 2
               Else
                  If [M:BBY1]STOMGTCOD (NOL) > 1       # hcb 28654
                     GMESSAGE = mess (6,184,1)    # La suppression d'une ligne validée doit se faire via la fenêtre de modification
                     mkstat = 2
                  Else                                 # hcb 28654
                     NOL1 = NOL                        # hcb 28654
                     Gosub SUPP_NONGERE                # hcb 28654
                  Endif                                # hcb 28654
               Endif
            Endif

        When 68, 83 :                                # Suppression d'un groupe de lignes
           Raz WNONGERE                        # hcb 28654
            For I=nolign-1 To nolign1-1
                If [M:BBY1]CREFLG(I)<>0
                   If  [M:BBY1]STOMGTCOD (I) > 1
                       GMESSAGE = mess (6,184,1)            # La suppression d'une ligne validée doit se faire via la fenêtre de modification
                       mkstat=2
                       Raz WNONGERE                        # hcb 28654
                       Break
                   Else
                       If [M:BBY1]VCRNUMORI (I) <> ""
                          GMESSAGE = mess (91,184,1)   # Suppression interdite ! Cette ligne à été désassemblée.
                          mkstat = 2
                          Raz WNONGERE                        # hcb 28654
                          Break
                       Else                           # hcb 28654
                          WNONGERE = 1                # hcb 28654
                       Endif                          # hcb 28654
                   Endif                              # hcb 28654
                Else
                   Raz WNONGERE                        # hcb 28654
                Endif                                # hcb 28654
            Next
            If WNONGERE = 1
               NOL1 = nolign1-1                  # hcb 28654
               Gosub SUPP_NONGERE                # hcb 28654
            Else                                 # hcb 28654
               If !mkstat
                  Call DELSTOSORW(NOL,nolign1-1,"BBY1",[M:BBY0]STOFCY,WRET) From STKSOR
                  If WRET<>0 : mkstat=2 : Endif
                  For I=nolign-1 To nolign1-1
                      [M:BBY1]QTYSTU (NOL) = 0
                  Next
               Endif
            Endif                             ## hcb 28654

#        When 73 :   # insertion                             # hcb 44489
#         If [M:BBY1]VCRLIN(NOL) < 5                         # hcb 44489
#            Call MESSAGE(mess(467,199,1)) From GESECRAN     # hcb 44489
#            mkstat = 2                                      # hcb 44489
#         Endif                                              # hcb 44489
         When 73, 82 :
         If status = 73                                      # hcb 44489
            If [M:BBY1]VCRLIN(NOL) < 5                       # hcb 44489
               Call MESSAGE(mess(467,199,1)) From GESECRAN   # hcb 44489
               mkstat = 2                                    # hcb 44489
            Endif                                            # hcb 44489
         Endif                                               # hcb 44489

           Call STKACTLIGM(nolign-1,"BBY1") From STKECR
#            Actzo [M]ITMREF(nolign-1),ITMDES1(nolign-1)     # hcb 44489
#            If dim([M]PCU)>0                                # hcb 44489
#                Actzo [M]PCU(nolign-1),QTYPCU(nolign-1)     # hcb 44489
#            Endif                                           # hcb 44489
#            If dim([M]PCUSTUCOE)>0                          # hcb 44489
#                Actzo [M]PCUSTUCOE(nolign-1)                # hcb 44489
#            Endif                                           # hcb 44489

        When 75     :
            If [M:BBY1]CREFLG(nolign-1)<> 0 & [M:BBY1]STOMGTCOD (nolign-1) > 1   # hcb 28654
                mkstat=2
            Endif
    Endcase

End

########################################
Subprog AVANT_NBLIG
If status=73 | status=82
   If GREP = "M"
      If dim(GCTRDATBBY) <= 0
          If [M:BBY0]IPTDAT < date$
             Global Integer GCTRDATBBY
             # Attention ! la date d imputation est antérieure à la date du jour
             Call MESSAGE(mess(162,184,1)) From GESECRAN
          Endif
      Endif
   Endif
Endif

Gosub SET_NOL

# Lecture article et règle de gestion
Call INIZONSOR("BBY1",[M:BBY1]ITMREF(NOL),[M:BBY0]STOFCY,NOL,[M:BBY0]TRSTYP,[M:BBY0]TRSCOD,"") From STKECR
If [M:BBY1]UPDFLG(nolign-1) = 0                   # hcb 69460
    Actzo [M:BBY1]ITMREF(nolign-1),ITMDES1(nolign-1)     # hcb 44489
    If dim([M:BBY1]PCU)>0                                # hcb 44489
       Actzo [M:BBY1]PCU(nolign-1),QTYPCU(nolign-1)      # hcb 44489
    Endif                                                # hcb 44489
    If dim([M:BBY1]PCUSTUCOE)>0                          # hcb 44489
       Actzo [M:BBY1]PCUSTUCOE(nolign-1)                 # hcb 44489
    Endif                                                # hcb 44489
Endif                                            # hcb 69460

#                                                  # hcb 71276 deb
If status<>73 & status<>82
  If dim([M:BBY1]ECCVALMAJ)>0
    Diszo [M:BBY1]ECCVALMAJ(nolign-1)
  Endif
  If dim([M:BBY1]ECCVALMIN)>0
    Diszo [M:BBY1]ECCVALMIN(nolign-1)
  Endif
Endif
End

########################################
Subprog IB_NBLIG

# Bouton  2 : Saisie des sorties
# Bouton  3 : Modification des sorties
# Bouton  4 : Stock par site
# Bouton  5 : Stock par lot
# Bouton  6 : Nomenclature
Gosub SET_NOL

GOUVSOR = 1

If [M]ITMREF(NOL) = ""
   Raz GBOUT2, GBOUT3 , GBOUT6
   End
Endif

If [M:BBY1]CREFLG(NOL) <> 0
    GBOUT2 = ""                 # Saisie détail
Endif

# Si l'article n'est pas géré en stock
If [M]STOMGTCOD(NOL) <= 1
   Raz GBOUT2, GBOUT3
Endif


If GCONSULT = 2                       # hcb 22993
   GBOUT3 = ""                        # hcb 22993
   GBOUT6 = ""                        # hcb 22993
   End                                # hcb 22993
Endif                                 # hcb 22993
If [M:BBY1]CREFLG(NOL)=0
&    | GREP<>"" & [M:BBY0]CFMFLG=2
&    | [M:BBY0]CFMFLG<>2
        GBOUT3 = ""    # Modif détail
Endif

If GREP<>""
        GBOUT3 = ""    # Modif détail
Endif
If [M:BBY1]VCRNUMORI(NOL) <> ""
        GBOUT3 = ""    # Modif détail
Endif
If [M:BBY1]VCRNUMORI(NOL) = ""
        GBOUT5 = ""    # consultation mvt
Endif

Read [BOH]BOH0=[M:BBY1]ITMREF(NOL);[M:BBY0]BOMALT(0);[M:BBY0]BOMALTTYP(0)
If fstat
   GBOUT6 = ""
Else
   If [F:ITM]ITMREF <> [M:BBY1]ITMREF(NOL)
       Read [F:ITM]ITM0 = [M:BBY1]ITMREF(NOL)
       If fstat
          Raz [F:ITM]
       Endif
   Endif

   If [F:ITM]PHAFLG = 2
      GBOUT6 = mess(153,198,1) # Nomenclature
   Else
      GBOUT6 = ""
   Endif
Endif
End

#########################################################################
# Etiquette exécutée avant l'action SAISTOSOR
#########################################################################

$AB3_NBLIG
#-- Habilitation Modification mvts stock si on trouve K dans la chaine des boutons autorisés
# hcb 27842
Raz GBIDI2
GFCY=[M:BBY0]STOFCY
GBIDC2="K" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GMESSAGE=mess(2,104,1)
   GOUVSOR=0
   Return
Else
   GOUVSOR = 1
Endif
Return



$AAPRES_NBLIG

Local Integer WRET
Raz WRET
Raz GOUVSOR
Gosub SET_NOL
# test rajouté sinon erreur enregistrement article inexistant si escape sur la ligne
If [M:BBY1]ITMREF(NOL) = ""
   Return
Endif
# Si sortie tableau validante
If adxgtb<>1 & !find(status,65,68,83)
   # Si ligne saisie mais non créée ou
   # ligne déjà créée et pièce avec validation non validée
   If [M:BBY1]CREFLG(NOL)=0 | ([M:BBY1]CREFLG(NOL)<>0 & [M:BBY0]CFMFLG<>2)
      # Alimentation de [M:ALP]
      Gosub ALI_ALP From SUBBBYA
      # Détermination du stock à sortir (automatisme, saisie)
        Diszo [M:BBY1]ITMREF(NOL)
        Call OUVSOR("BBY1",NOL,[M:BBY1]NBLIG,[M:BBY1]WSTOSEQ(NOL),[M:BBY0]STKFLG,WRET) From STKSOR            # hcb 50197
        Affzo [M:BBY1]ITMREF(NOL)
    Endif
Endif
Return

########################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Decimal WQTY
Local    Integer J, NOL

NOL=nolign-1
pcolor=GCOUL(0)
# Colorisation de l'article
# - si tout le stock à sortir n'a pas été renseigné
# - s'il y a une qunatité en rupture
# Nouvelle ligne ou ligne modifiée

If [M:BBY1]STOMGTCOD(NOL) > 1                 # hcb 28654
    If [M:BBY1]CREFLG(NOL)=0 | ([M:BBY1]CREFLG(NOL)<>0 & [M:BBY1]UPDFLG(NOL)<>0)
   # Si ligne en cours de saisie
      If [M:BBY1]QTYSTU(NOL)=0
         pcolor=GCOUL(1)
      Else
         WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*([M:SOW]WSTOSEQ(J)=[M:BBY1]WSTOSEQ(NOL)))
      # Tout le stock à sortir n'a pas été renseigné
         If WQTY<>[M:BBY1]QTYSTU(NOL)
            pcolor=GCOUL(1)
         Else
            WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*
&                  ([M:SOW]WSTOSEQ(J)=[M:BBY1]WSTOSEQ(NOL)&[M:SOW]WSTOCOU(J)<>0))
         # Il y a une quantité en rupture
            If WQTY<>[M:BBY1]QTYSTU(NOL)
               pcolor=GCOUL(2)
            Endif
         Endif
         Diszo [M:BBY1]ITMREF(NOL)   # hcb 74203
      Endif
   Elsif [M:BBY1]FLGRUP(NOL)=1
      pcolor=GCOUL(2)
   Endif
#   Diszo [M:BBY1]ITMREF(NOL)   # hcb 74203
Endif                        # hcb 28654
End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

Gosub SET_NOL
Local Integer I
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif
Read [ITF]ITF0 = VALEUR;[M:BBY0]STOFCY
If fstat
   mkstat = 2
   GMESSAGE = mess(25,192,1)
   End
Endif
If [F:ITF]STOMGTCOD = 1           # hcb 28654 deb
   I= 1
   Call OUINON(VALEUR-mess(2,196,1)+"  "+mess(36,100,1),I) From GESECRAN
   If I = 1
      mkstat = 2
      End
   Endif
Endif

[M:BBY1]STOMGTCOD(NOL) = [F:ITF]STOMGTCOD

#---------------------------------------------------------------------#
# Cas d'un fantôme : --> Controle du disponible en statut "A"         #
#                    --> si Descente de la nomenclature               #
#                    --> Suppression de la ligne fantôme              #
#---------------------------------------------------------------------#
If  [F:ITM]PHAFLG = 2
    Local Decimal LSTUACTDIS
    Raz LSTUACTDIS
    Read [ITV]ITV0=[F:ITM]ITMREF;[M:BBY0]STOFCY
    If fstat
       Raz [F:ITV]
    Endif
# lecture ITMCATEG
    Read [ITG]ITG0=[M:BBY0]STOFCY;[F:ITM]TCLCOD
    If fstat
       Read [ITG]ITG1=[F:ITM]TCLCOD;""
       If fstat
          Raz [ITG]
       Endif
    Endif
    Call STODISTOT("",1,0,"",LSTUACTDIS) From STKLIB
    If  LSTUACTDIS = 0
        mkstat = 2
        GMESSAGE = mess(94,184,1)
        End
    Else
       [M:BBY1]WDISPO(NOL) = LSTUACTDIS
    Endif
Endif


# Lecture article et règle de gestion
Call INIZONSOR("BBY1",VALEUR,[M:BBY0]STOFCY,nolign-1,[M:BBY0]TRSTYP,[M:BBY0]TRSCOD,"") From STKECR

# test inventaire ici car dans inizonsor il est desactivé pour l ecran BBY1 (fait ds descente nomenclature)
If [F:ITF]CUNFLG=2
    Call MESSAGE(mess(185,199,1)) From GESECRAN
Endif

#[M:BBY1]STOMGTCOD(NOL) = [F:ITM]STOMGTCOD
#[M:BBY1]ITMDES1(NOL) = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:BBY1]ITMDES1(NOL), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:BBY1]PCU(NOL)        = [F:ITM]STU
[M:BBY1]PCUSTUCOE(NOL)  = 1
[M:BBY1]STU(NOL)        = [F:ITM]STU
Diszo [M:BBY1]PCUSTUCOE(NOL)
Affzo [M:BBY1]PCU(NOL),PCUSTUCOE(NOL),STU(NOL)
If [M]STOMGTCOD(NOL)<>1 & dim([M:BBY1]LOC)>0
   Call STKINIEMPS([M:BBY1]LOC(NOL)) From STKLOC
Endif

End

########################################
Subprog AM_PCU(VALEUR)
Variable Char    VALEUR()

Local Integer LMODIF
Local Decimal LCOEF

    Gosub SET_NOL
    # Recherche du nouveau coefficient UC-US
    Call CTLUOM([M]ITMREF(NOL),3,"",VALEUR,LCOEF,GBIDC1,GBIDC2,LMODIF) From STKACT
    If mkstat=2 End Endif
    [M]PCUSTUCOE(NOL) = LCOEF
    If LMODIF < 2
        Diszo [M:BBY1]PCUSTUCOE(NOL)
    Else
        Actzo [M:BBY1]PCUSTUCOE(NOL)
    Endif
    Call QTEARR( [M:BBY1]QTYPCU(NOL), VALEUR ) From TRTDIV
    [M:BBY1]QTYSTU(NOL) = [M:BBY1]QTYPCU(NOL)*[M:BBY1]PCUSTUCOE(NOL)
    Call QTEARR( [M:BBY1]QTYSTU(NOL), [M:BBY1]STU(NOL) ) From TRTDIV
    Affzo [M:BBY1]PCUSTUCOE(NOL), QTYSTU(NOL)

End

########################################
Subprog C_QTYPCU(VALEUR)
Variable Decimal VALEUR
    If VALEUR<=0
        mkstat=2
    Endif
End

########################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
[M:BBY1]QTYSTU(NOL) = VALEUR * [M:BBY1]PCUSTUCOE(NOL)
#--- Bug 61614
Call QTEARR( [M:BBY1]QTYSTU(NOL), [M:BBY1]STU(NOL) ) From TRTDIV
#If [M:BBY1]WDISPO (NOL) <> 0
#   If [M:BBY1]WDISPO (NOL) <  [M:BBY1]QTYSTU(NOL)
#      mkstat = 2
#   GMESSAGE = mess(95,184,1)
#      End
#   Endif
#Endif
Affzo [M:BBY1]QTYSTU(NOL)
End

########################################
Subprog AM_PCUSTUCOE(VALEUR)
Variable Decimal VALEUR
    Gosub SET_NOL
    [M:BBY1]QTYSTU(NOL) = [M:BBY1]QTYPCU(NOL) * VALEUR
    #--- Bug 61614
    Call QTEARR( [M:BBY1]QTYSTU(NOL), [M:BBY1]STU(NOL) ) From TRTDIV
    Affzo [M:BBY1]QTYSTU(NOL)
End

########################################
# Dépôt
########################################
Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2
  VALEUR = [M:BBY0]WRHE : mkstat=2 : End
Endif
If VALEUR=""
  VALEUR = [M:BBY0]WRHE
Endif
End

Subprog C_WRH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M:BBY1]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M:BBY1]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

##########################################################################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL
Local    Char    LSERF(GLONSER)
Local    Decimal LQTYF
NOL=nolign-1

If VALEUR<>""
   # Alimentation de [M:ALP]
   Gosub ALI_ALP From SUBBBYA
   # Détermination no série fin
   Call CTLSORSER("BBY1",NOL,VALEUR,[M:BBY1]QTYSTU(NOL),LSERF,LQTYF) From STKSOR
   If LQTYF=0
      Raz VALEUR, [M:BBY1]SERNUMF(NOL)
   Else
      [M:BBY1]SERNUMF(NOL)=LSERF
   Endif
Else
   Raz [M:BBY1]SERNUMF(NOL)
Endif
End

########################################################################
#SUP_LIG                       Suppression d'une ligne dans le tableau #
########################################################################
Subprog SUP_LIG(NLIG, WRET)
Value Integer NLIG
Variable Integer WRET    : WRET = 0

If   dim([M]ITMREF) = [M]NBLIG
     Dela NLIG,1 [M:BBY1]NBLIG
Else Dela NLIG,1,[M:BBY1]NBLIG-1 [M:BBY1]NBLIG : Endif
[M:BBY1]NBLIG -=1

End

##########################################################################
## Etiquette ajoutée par le superviseur 20/02/2004 11:39:27 (HCB)
##########################################################################
Subprog B6_NBLIG
Gosub SET_NOL
Local Char    ALTALP(3)
GCONSULT    = 2
GBOMALT(0)  = [M:BBY0]BOMALT(0)
GDATEREF    = date$
ALTALP      = num$(GBOMALT(0))
GFONBOD     = "BOMP"

# FGR 15/01/2010 : X3SUIVI60986
#WSUPP = num$(ALTALP) + "~" + num$([M:BBY1]BOMALTTYP(NOL))

# GH 17/08/11 bug 74528
#Local Char WSUPP
#WSUPP = num$(ALTALP) + "~" + num$([M:BBY0]BOMALTTYP(NOL))
#Call OBJET("BOD", [M:BBY1]ITMREF(NOL), WSUPP) From GOBJET
Local Char WSUPP(GLONITM)(2)
WSUPP(0)=[M:BBY1]ITMREF(NOL) : WSUPP(1)=num$([M:BBY0]BOMALTTYP(NOL))
Call OBJET("BOD",ALTALP,WSUPP) From GOBJET

GCONSULT = 0
End

##########################################################################

##########################################################################
## Etiquette ajoutée par le superviseur 20/02/2004 14:21:49 (HCB)
##########################################################################
Subprog B4_ITMREF(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL
If VALEUR  = ""
   End
Endif
Read [BOH]BOH0=VALEUR;[M:BBY0]BOMALT(0);[M:BBY0]BOMALTTYP(0)
If fstat
   End
Else
   If [F:ITM]ITMREF <> VALEUR
       Read [F:ITM]ITM0 = VALEUR
       If fstat
          End
       Endif
   Endif
   If [F:ITM]PHAFLG = 2
      Local Char    ALTALP(3)
      GCONSULT    = 2
      GBOMALT(0)  = [M:BBY0]BOMALT(0)
      GDATEREF    = date$
      ALTALP      = num$(GBOMALT(0))
      GFONBOD     = "BOMP"
      GFLAG       = "BOMP"
      # FGR 15/01/2010 : X3SUIVI60986
      #WSUPP = num$(ALTALP) + "~" + num$([M:BBY1]BOMALTTYP(0))

      # GH 17/08/11 bug 74528
      #Local Char WSUPP
      #WSUPP = num$(ALTALP) + "~" + num$([M:BBY0]BOMALTTYP(0))
      #Call OBJET("BOD", VALEUR, WSUPP) From GOBJET
      Local Char WSUPP(GLONITM)(2)
      WSUPP(0)=VALEUR : WSUPP(1)=num$([M:BBY0]BOMALTTYP(0))
      Call OBJET("BOD",ALTALP,WSUPP) From GOBJET

      GCONSULT = 0
   Else
      End
   Endif
Endif
End


Subprog IB_ITMREF
# Bouton  4 : Nomenclature
GBOUT4 = mess(153,198,1) # Nomenclature
End


