Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local Integer    LRET

Call CTLECCVAL(VALEUR,[M:BBY0]STOFCY,[M:BBY1]ITMREF(nolign-1),
&             [M:BBY0]TRSTYPC,[M:BBY0]TRSCOD,[M:BBY0]IPTDAT,LRET) From STKSOR
If LRET>0 mkstat=2 Endif
End

