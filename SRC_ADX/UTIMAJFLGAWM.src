#<AdxTL>@(#)5.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise a jour champ dans les modeles de données
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Mise a jour champ dans les modeles de données") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Else
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJFLG
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJFLG
End

#-------------------#
$MAJFLG
If filinfo(filpath("FIL","AWRKLNK","fde",[L]DOSSIER),0)<0 : Return : Endif
Local File =DOSSIER+".AWRKLNK"   [AWM]
Local Integer MODIF
# Mise à jour de la table AWRKLNK
Call ECR_TRACE(mess(81,125,1)-"AWRKLNK:"-time$,0) From GESECRAN
Trbegin [AWM]
For [AWM]AWM0
 MODIF = 0
 If dim([AWM]FLGWRK)>0 & [AWM]FLGWRK=0
  If [AWM]FLDCPY<>"" or [AWM]FLDFCY<>""
   [AWM]FLGWRK=2
  Else
   [AWM]FLGWRK=1
  Endif
  MODIF = 1
 Endif
 If dim([AWM]FLGAPH)>0 & [AWM]FLGAPH=0
  If [AWM]FLDLEG<>""
   [AWM]FLGAPH=2
  Else
   [AWM]FLGAPH=1
  Endif
  MODIF = 1
 Endif
 If MODIF
  Rewrite [AWM]
  If fstat
   Call ERREUR("AWRKLNK"-[F:AWM]MODELE,1) From DOSDIC
  Endif
 Endif
Next
Commit

Close Local File [AWM]

Return
