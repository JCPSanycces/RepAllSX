#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
#JOJAC - 2017-03-15 - REQUIREMENT
#Handling all properties for EVAEMP_CSTD

$PROPERTIES

#Handling all the property code in EVAEMP_CSTD_PRO
Case [L]CURPRO
  When "RSAID"                            : Gosub EMPESSSA_RSAID
  When "EMPADR.ADDPRI"                    : Gosub EMPESSSA_ADDPRI
  When "EMPADR.ADDSRVTYP"                 : Gosub EMPESSSA_ADDSRVTYP
  When "EMPADR.ADDPOSNUM"                 : Gosub EMPESSSA_ADDPOSNUM
  When "EMPADR.ADDPOSNAM"                 : Gosub EMPESSSA_ADDPOSNAM
  When "EMPADR.ADDSTRNAM"                 : Gosub EMPESSSA_ADDSTRNAM
  When "EMPADR.ADDTWN"                    : Gosub EMPESSSA_ADDTWN
  When "EMPADR.ADDPOSCDE"                 : Gosub EMPESSSA_ADDPOSCDE
  When "EMPADR.ADDCNTCDE"                 : Gosub EMPESSSA_ADDCNTCDE
  When "EMPADR.ADDCOR"                    : Gosub EMPESSSA_ADDCOR
  When "EMPADR.ADDPOSCOF"                 : Gosub EMPESSSA_ADDPOSCOF
Endcase
Return

$EMPESSSA_RSAID
Case [L]ARULE
  When "CONTROL"
    Gosub EMPLOIDSA_RSAID_CONTROL From EMPLOIDSA_CSTD_PRO
Endcase
Return

$EMPESSSA_ADDPRI
Case [L]ARULE
  When "INIT"
   Gosub EMPLOIDSA_ADDPRI_INIT From EMPLOIDSA_CSTD_PRO
  When "PROPAGATE"
   Gosub EMPLOIDSA_ADDPRI_PROPOGATE From EMPLOIDSA_CSTD_PRO
Endcase
Return

$EMPESSSA_ADDSRVTYP
Case [L]ARULE
  When "INIT"
    Gosub EMPLOIDSA_ADDSRVTYP_INIT From EMPLOIDSA_CSTD_PRO
  When "PROPAGATE"
    Gosub EMPLOIDSA_ADDSRVTYP_PROPOGATE From EMPLOIDSA_CSTD_PRO
Endcase
Return

$EMPESSSA_ADDPOSNUM
Case [L]ARULE
  When "CONTROL"
    Gosub EMPLOIDSA_ADDPOSNUM_CONTROL From EMPLOIDSA_CSTD_PRO
Endcase
Return

$EMPESSSA_ADDPOSNAM
Case [L]ARULE
  When "CONTROL"
    Gosub EMPLOIDSA_ADDPOSNAM_CONTROL From EMPLOIDSA_CSTD_PRO
Endcase
Return

$EMPESSSA_ADDSTRNAM
Case [L]ARULE
  When "CONTROL"
    Gosub EMPLOIDSA_ADDSTRNAM_CONTROL From EMPLOIDSA_CSTD_PRO
Endcase
Return

$EMPESSSA_ADDTWN
Case [L]ARULE
  When "CONTROL"
    Gosub EMPLOIDSA_ADDTWN_CONTROL From EMPLOIDSA_CSTD_PRO
Endcase
Return

$EMPESSSA_ADDPOSCDE
Case [L]ARULE
  When "CONTROL"
    Gosub EMPLOIDSA_ADDPOSCDE_CONTROL From EMPLOIDSA_CSTD_PRO
Endcase
Return

$EMPESSSA_ADDCNTCDE
Case [L]ARULE
  When "INIT"
    Gosub EMPLOIDSA_ADDCNTCDE_INIT From EMPLOIDSA_CSTD_PRO
Endcase
Return

$EMPESSSA_ADDCOR
Case [L]ARULE
  When "CONTROL"
    Gosub EMPLOIDSA_ADDCOR_CONTROL From EMPLOIDSA_CSTD_PRO
Endcase
Return

$EMPESSSA_ADDPOSCOF
Case [L]ARULE
  When "PROPAGATE"
    Gosub EMPLOIDSA_ADDPOSCOF_PROPOGATE From EMPLOIDSA_CSTD_PRO
Endcase
Return

