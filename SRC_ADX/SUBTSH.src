#<AdxTL>@(#)12.0.0.0 $Revision$
################################################################################
#    PARAMETRAGE TRANSACTION SAISIE DES OBJETS METIERS
#    GBN
#    Création le : 09/07/2003
#
#    Modification le :
#
# - USR - xx.xx.xxxx - Fq yyyyy - Comptabilisation par période agrégées
#
# - MWA - 28.07.2015 - Fq109836 - Suppression des élements physiques de la liste des objets
# - GLE - 07.10.2009 - Fq 58489 - Test de la présence du module Immo dans les sous-pro PATCH et GENDOS
# - GBO - 20.08.2009 - Fq 57309 - Complément à la fiche 49468
#
################################################################################
Call OBJET("TSH",GBIDC1,GBIDC2) From GOBJET
End
$ACTION
  #If GUSER="MDJ" : Infbox ACTION : Endif
  Case ACTION
    When "OUVRE"            : Gosub OUVRE
    When "LIENS"            : Gosub LIENS
    When "INICRE"           : Gosub INICRE
    When "INIMOD"           : Gosub INICRE
    When "CREATION"         : Gosub CREATION
    When "AP_ANNULE"        : Gosub AP_ANNULE
    When "MODIF"            : Gosub MODIFICATION
    When "INICRE"           : Gosub INICRE
    When "SETBOUT"          : Gosub SETBOUT
    When "AVANTBOUT"        : Gosub AVANTBOUT
    When Default
  Endcase

Return
################################################################################

#-------------------------------------------------------------------------------
$OUVRE

  #Call INIT_VAR_ZONE_LIBRES From GLOZLIBR
  #-------------------------

  If clalev([F:HST])=0  : Local File SAITRS    [HST]    : Endif : # En-tête transaction
  If clalev([F:DST])=0  : Local File SAITRSDET [DST]    : Endif : # Détail transaction

  If clalev([F:HSTB])=0 : Local File SAITRS    [HSTB]   : Endif : # En-tête transaction
  If clalev([F:DSTB])=0 : Local File SAITRSDET [DSTB]   : Endif : # Détail transaction

  If clalev([F:AWIB])=0 : Local File AWINDOW   [AWIB]   : Endif : # Dictionnaire des fenêtres
  If clalev([F:AMKB])=0 : Local File AMSK      [AMKB]   : Endif : # Dictionnaire des écrans
  If clalev([F:AMZB])=0 : Local File AMSKZON   [AMZB]   : Endif : # Dictionnaire des champs écran
  If clalev([F:AMZS])=0 : Local File AMSKZON   [AMZS]   : Endif : # Dictionnaire des champs écran
  If clalev([F:ATZB])=0 : Local File ATABZON   [ATZB]   : Endif : # Dictionnaire des champs des tables
  If clalev([F:AOBB])=0 : Local File AOBJET    [AOBB]   : Endif : # Dictionnaire des objets
Return

#-------------------------------------------------------------------------------
$LIENS

If GUSER="XXX"

 For nolign=1 To [F:SAI]NBRMSK
  [M:TSH1]CODMSK(nolign-1)    = [F:SAI]LISMSK(nolign-1)
  [M:TSH1]FLGINV(nolign-1)    = [F:SAI]FLGINV(nolign-1)
  # Ajout FLGINVORI pour ne par pouvoir rendre visible les onglets invisibles en standard
  If dim([M:TSH1]FLGINVORI)>0
   [M:TSH1]FLGINVORI(nolign-1) = [F:SAI]FLGINVORI(nolign-1)
  Endif
  [M:TSH1]NUMMSK(nolign-1)    = [F:SAI]NUMMSK(nolign-1)
 Next nolign
 [M:TSH1]NBRMSK=nolign-1

Else

 Local Integer I_MSK : Raz I_MSK
 Local Integer I_INVMSK, I_VISMSK
 I_VISMSK=1
 I_INVMSK=1
 For I_MSK = 1 To [F:SAI]NBRMSK
  If    [F:SAI]FLGINVORI(I_MSK-1)=G_OUI
   [M:TSH1]CODMSK(I_VISMSK-1)    = [F:SAI]LISMSK(I_MSK-1)
   [M:TSH1]FLGINV(I_VISMSK-1)    = [F:SAI]FLGINV(I_MSK-1)
   [M:TSH1]FLGINVORI(I_VISMSK-1) = [F:SAI]FLGINVORI(I_MSK-1)
   [M:TSH1]NUMMSK(I_VISMSK-1)    = [F:SAI]NUMMSK(I_MSK-1)
   I_VISMSK+=1
  Elsif [F:SAI]FLGINVORI(I_MSK-1)=G_NON
   [M:TSH1]CODMSKINV(I_INVMSK-1) = [F:SAI]LISMSK(I_MSK-1)
   [M:TSH1]NUMMSKINV(I_INVMSK-1) = [F:SAI]NUMMSK(I_MSK-1)
   I_INVMSK+=1
  Endif
 Next I_MSK

 [M:TSH1]NBRMSK=I_VISMSK-1
 [M:TSH1]NBRINV=I_INVMSK-1

Endif

Return

#-------------------------------------------------------------------------------
$INICRE

 #> Alimentation du tableau des masques

If GUSER="XXX"

 For nolign=1 To [M:TSH1]NBRMSK
  [F:SAI]LISMSK(nolign-1)    = [M:TSH1]CODMSK(nolign-1)
  [F:SAI]FLGINV(nolign-1)    = [M:TSH1]FLGINV(nolign-1)
  If dim([M:TSH1]FLGINVORI)>0 : [F:SAI]FLGINVORI(nolign-1) = [M:TSH1]FLGINVORI(nolign-1) : Endif
  [F:SAI]NUMMSK(nolign-1)    = [M:TSH1]NUMMSK(nolign-1) # gbn 06/07/04
 Next nolign

Endif

 #> Alimentation du tableau des masques invisibles

 Local Integer I_MSK

 For I_MSK=1 To [M:TSH1]NBRMSK
  [F:SAI]LISMSK([M:TSH1]NUMMSK(I_MSK-1)-1) = [M:TSH1]CODMSK(I_MSK-1)
  [F:SAI]FLGINV([M:TSH1]NUMMSK(I_MSK-1)-1) = [M:TSH1]FLGINV(I_MSK-1)
  If dim([M:TSH1]FLGINVORI)>0 : [F:SAI]FLGINVORI([M:TSH1]NUMMSK(I_MSK-1)-1) = [M:TSH1]FLGINVORI(I_MSK-1) : Endif
  [F:SAI]NUMMSK([M:TSH1]NUMMSK(I_MSK-1)-1) = [M:TSH1]NUMMSK(I_MSK-1)
 Next I_MSK

 For I_MSK=1 To [M:TSH1]NBRINV
  [F:SAI]LISMSK([M:TSH1]NUMMSKINV(I_MSK-1)-1) = [M:TSH1]CODMSKINV(I_MSK-1)
  [F:SAI]FLGINV([M:TSH1]NUMMSKINV(I_MSK-1)-1) = G_NON
  If dim([M:TSH1]FLGINVORI)>0 : [F:SAI]FLGINVORI([M:TSH1]NUMMSKINV(I_MSK-1)-1) = G_NON : Endif
  [F:SAI]NUMMSK([M:TSH1]NUMMSKINV(I_MSK-1)-1) = [M:TSH1]NUMMSKINV(I_MSK-1)
 Next I_MSK

 [F:SAI]NBRMSK=[M:TSH1]NBRMSK+[M:TSH1]NBRINV

 #> Alimentation de la zone TRSCOP utilisé par ACOPTRS utilitaire de copie de dossier à dossier (Gbn-13102004)

  [F:SAI]TRSCOP=num$([M:TSH0]REFOBJ)+[M:TSH0]TRSCOD

Return

#-------------------------------------------------------------------------------
$CREATION

#--> En création d'une transaction dans SAITRS, création des enregistrements détail correspondants
#    dans la table SAITRSDET

Local Integer I_MSK           # Indice de parcours des onglets
Local Integer RETOUR          # Code retour des sous programmes
Local Char    SAVMZSZON       # Zone de sauvegarde du champ associé à un flag de type MZS
Local Char    TABREF          # Table de donnée associée à un objet métier
Local Char    OBJREF          # Objet métier de référence de la transaction
Local Integer LIS_BLK_AUZ(14) # Liste des numeros de bloc autorisés dans le masque (pas de création d'enregistrements)
Local Integer CODACT_AUT      # Champ porteur d'un code activité - Est-il actif ?

Case [F:SAI]REFOBJ
 When GVML_OMBIEN   : OBJREF="FAS"
 When GVML_OMDEPEN  : OBJREF="LOF"
 When GVML_OMSUBV   : OBJREF="GRT"
 When GVML_OMLOCFI  : OBJREF="LEA"
 When Default       : Raz OBJREF
Endcase

If OBJREF<>""
 Read [AOBB]ABREV=OBJREF
 If !fstat
  TABREF=[F:AOBB]NOMFIC
 Endif
Endif

GOK=1
For I_MSK=0 To [F:SAI]NBRMSK-1
 If [F:SAI]FLGINV(I_MSK)=G_OUI
  # Remplissage de la liste des blocs autorisés
  Call GET_BLK_AUZ(nomap,[F:SAI]LISMSK(I_MSK),LIS_BLK_AUZ,RETOUR)
  # Sélection des zones
  Filter [AMZB] Where (CODMSK=[F:SAI]LISMSK(I_MSK) and !(SAIAFF>2) and CODTYP<>"W" and find(NUMBLOC,LIS_BLK_AUZ)<>0)
  For [AMZB]CODZON
   If [F:AMZB]CODTYP="MZS"
    Raz SAVMZSZON
    SAVMZSZON=[F:AMZB]CODZON
   Else
    # Si le champ est porteur d'un code activité : fonction pour déterminer si le code activité est actif
    If [F:AMZB]CODACT<>""
     Case [F:AMZB]CODACT
      When "LEA"
       If G_ACTLEA=G_OUI
        CODACT_AUT=1
       Else
        CODACT_AUT=0
       Endif
      When "GRT"
       If G_ACTGRT=G_OUI
        CODACT_AUT=1
       Else
        CODACT_AUT=0
       Endif
      When Default
       CODACT_AUT=1
     Endcase
    Else
     CODACT_AUT=1
    Endif
    # Création de l'enregistrement correspondant dans SAITRSDET
    If CODACT_AUT
     Raz [F:DST]
     [F:DST]REFOBJ    = [F:SAI]REFOBJ
     [F:DST]TRSCOD    = [F:SAI]TRSCOD
     [F:DST]NUMMSK    = I_MSK+1
     [F:DST]CODMSK    = [F:SAI]LISMSK(I_MSK)
     Read [AMKB]CODMSK= [F:SAI]LISMSK(I_MSK)
     [F:DST]INTMSK    = [F:AMKB]INTMSK
     [F:DST]BROMSK    = num$([F:DST]NUMMSK)-[F:DST]CODMSK
     [F:DST]CODZON    = [F:AMZB]CODZON
     [F:DST]CODTYP    = [F:AMZB]CODTYP
     [F:DST]INTIT    = [F:AMZB]INTIT
     [F:DST]SAIAFF    = [F:AMZB]SAIAFF
     [F:DST]SAIAFFORI = [F:AMZB]SAIAFF
     [F:DST]MODE      = [F:AMZB]MODE
     [F:DST]MODEORI   = [F:AMZB]MODE
     [F:DST]OBLIG     = [F:AMZB]OBLIG
     [F:DST]OBLIGORI  = [F:AMZB]OBLIG
     [F:DST]VALDEF    = [F:AMZB]VALDEF
     [F:DST]VALDEFORI = [F:AMZB]VALDEF
     [F:DST]NUMBLOC   = [F:AMZB]NUMBLOC
     [F:DST]CREUSR    = [V]GUSER
     [F:DST]CREDAT    = [S]datesyst
     [F:DST]MODFLG    = 1
     If SAVMZSZON<>""
      [F:DST]MZSZON    = SAVMZSZON
      Raz SAVMZSZON
     Endif
     Write [F:DST]
     If fstat
      GOK=0
      Call FSTA("DST")From GLOCK
      Break
     Endif
    Endif
    Endif
  Next
  Filter [AMZB]
 Endif
 If !GOK : Break : Endif
Next nolign
Return

#-------------------------------------------------------------------------------
$AP_ANNULE

#--> Suppression des masques et de la fenêtre générée si on supprime la transaction
 Call SUPENTGEN([F:SAI]WIN,[F:SAI]NBRMSK,[F:SAI]TRSCOD,nomap)

Return

#-------------------------------------------------------------------------------
$MODIFICATION

 Local Integer LIS_BLK_AUZ(14)
 Local Integer RETOUR

#--> En modification d'enregistrement, on détruit les enregistrements détails des masques devenus
#    invisibles et on créé ceux des masques devenus visibles

 For nolign=1 To [M:TSH1]NBRMSK
  Case [M:TSH1]FLGINV(nolign-1)
   When G_NON
    Delete [DST] Where REFOBJ=[F:SAI]REFOBJ & TRSCOD=[F:SAI]TRSCOD & CODMSK=[M:TSH1]CODMSK(nolign-1)
   When G_OUI
    Filter [DST] Where REFOBJ=[F:SAI]REFOBJ & TRSCOD=[F:SAI]TRSCOD & CODMSK=[M:TSH1]CODMSK(nolign-1)
    Read [DST] First
    If fstat>3
 #-> Bizarre ce truc ... (RAF)
     Call GET_BLK_AUZ(nomap,[M:TSH1]CODMSK(nolign-1),LIS_BLK_AUZ,RETOUR)
     Filter [AMZB] Where (CODMSK=[M:TSH1]CODMSK(nolign-1) and !(CODTYP="ABS") and find(NUMBLOC,LIS_BLK_AUZ)<>0)
     For [AMZB]
      Raz [F:DST]
      [F:DST]REFOBJ    = [F:SAI]REFOBJ
      [F:DST]TRSCOD    = [F:SAI]TRSCOD
      [F:DST]NUMMSK    = nolign
      [F:DST]CODMSK    = [M:TSH1]CODMSK(nolign-1)
      Read [AMKB]CODMSK= [M:TSH1]CODMSK(nolign-1)
      [F:DST]INTMSK    = [F:AMKB]INTMSK
      [F:DST]BROMSK    = num$([F:DST]NUMMSK)-[F:DST]CODMSK
      [F:DST]CODZON    = [F:AMZB]CODZON
      [F:DST]INTIT     = [F:AMZB]INTIT
      [F:DST]SAIAFF    = [F:AMZB]SAIAFF
      [F:DST]SAIAFFORI = [F:AMZB]SAIAFF
      [F:DST]MODE      = [F:AMZB]MODE
      [F:DST]OBLIG     = [F:AMZB]OBLIG
      [F:DST]VALDEF    = [F:AMZB]VALDEF
      [F:DST]NUMBLOC   = [F:AMZB]NUMBLOC
      Write [F:DST]
      If fstat
       GOK=0
       Call FSTA("DST")From GLOCK
       Break
      Endif
     Next
     Filter [AMZB]
    Endif
  Endcase
  Filter [DST]
 Next nolign

#--> On vérifie que le ENAFLG de la transaction est cohérent avec celui de la fenêtre générée si elle
#    existe. Si ce n'est pas le cas, on met à jour le ENAFLG de la fenêtre puis validation de la fenêtre.
#    NB : La validation de la fenêtre est silencieuse - pas de boîte pendant qu'elle se déroule.

 Local Char    NOMGENWIN
 Local Integer RETOUR
 If clalev([F:AWI])=0 : Local File AWINDOW   [AWI] : Endif : # Dictionnaire des fenêtres
 NOMGENWIN="W"+[M:TSH0]WIN+[M:TSH0]TRSCOD
 Read [AWI]AWI0=NOMGENWIN
 If !fstat & [F:AWI]ENAFLG<>[M:TSH0]ENAFLG
  [F:AWI]ENAFLG=[M:TSH0]ENAFLG
  Rewrite [AWI]
  If fstat
   GOK=0 : Call FSTA("AWI") From GLOCK
  Else
   # Validation de la fenêtre #
   If GOK : Call VALID(NOMGENWIN,nomap,1,RETOUR) From VALWIN Endif
  Endif
 Endif
Return

#-------------------------------------------------------------------------------
$SETBOUT

#-> Activation / désactivation des boutons supplémentaire en fonction du statut de saisie

  If GREP = "C" or GREP = "D" or GREP = "A" Then
   Call VIREBOUT (CHAINE, "1") From GOBJET                      : # Validation
   Call VIREBOUT (CHAINE, "2") From GOBJET                      : # Visu
   Call VIREBOUT (CHAINE, "4") From GOBJET                      : # Détail
  Endif

  If GREP = "M"
   Call VIREBOUT (CHAINE, "1") From GOBJET                      : # Validation
  Endif

  If GREP = "" and !VERROU
   Call VIREBOUT (CHAINE, "1") From GOBJET : # Validation
   Call VIREBOUT (CHAINE, "2") From GOBJET                      : # Visu
   Call VIREBOUT (CHAINE, "4") From GOBJET                      : # Détail
  Endif

 # Si mode différent de C/S, le bouton visu n'est pas disponible

  If adxtyp>1
   Call VIREBOUT (CHAINE, "2") From GOBJET                      : # Visu
  Endif

Return

#-------------------------------------------------------------------------------
$AVANTBOUT

#-> Aiguillage vers les traitements associés aux boutons "Validation" et "Suppression"

  Case BOUT
    When "1"        : # Bouton "Validation"
     Gosub VALID      # validation de la transaction
    When "3"        : # Bouton "Suppression"        #Dev
     Gosub AP_ANNULE
    When "2"          # Bouton Visu
     Local Char NOMGENWIN : NOMGENWIN="W"+[M:TSH0]WIN+[M:TSH0]TRSCOD
     Call SIMUL(NOMGENWIN) From SUBAWI
    When Default
  Endcase
Return

################################################################################
# ECRAN : TSH0
################################################################################

#> Avant saisie REFOBJ - Type d'objet métier

Subprog AS_REFOBJ(VALEUR)
Variable Integer VALEUR
 GMENLOC(5)=1
 # FQ109836
 GMENLOC(6)=1
End

#> Après modification REFOBJ - Type d'objet métier

Subprog AM_REFOBJ(VALEUR)
Variable Integer VALEUR

#
# Contrôle que le paramètrage de FREFLD existe bien pour le type d'objet métier choisi
#
If !(clalev([F:FRF])) Then : Local File FREFLD  [FRF] : Endif
Read [FRF]FRF0=VALEUR;""
If fstat=5
 GERR=1
 GMESSAGE=mess(VALEUR,3141,1)-":"-mess(160,7770,1) # "OBJET métier"+":"+"Le paramètrage par défaut des zones libres est inexistant"
 mkstat = 2
 End
Endif

Local Integer I_MSK

Call GET_WIN_ON_341 (VALEUR, [M:TSH0]WIN) From GLOBIENS
Filter [AWIB] Where WIN=[M:TSH0]WIN
Read [AWIB] First

#Gbn - Amélio 24740 - Ne plus faire apparaite les masque invisible de la fenêtre standard
# A la lecture de AWIB - aguiller vers le bloc onglet ou vers le bloc invisible

If GUSER<>"XXX"

Local Integer I_WINMSK
Local Integer I_VISMSK
Local Integer I_INVMSK
For I_WINMSK=1 To [F:AWIB]NBMSK
 If    [F:AWIB]FLGMSK(I_WINMSK-1)=G_OUI
  I_VISMSK+=1
  [M:TSH1]CODMSK(I_VISMSK-1) = [F:AWIB]NOMMSK(I_WINMSK-1)
  [M:TSH1]FLGINV(I_VISMSK-1) = [F:AWIB]FLGMSK(I_WINMSK-1)
  If dim([M:TSH1]FLGINVORI)>0 : [M:TSH1]FLGINVORI(I_VISMSK-1) = [F:AWIB]FLGMSK(I_WINMSK-1) : Endif
  [M:TSH1]NUMMSK(I_VISMSK-1) = I_WINMSK
 Elsif [F:AWIB]FLGMSK(I_WINMSK-1)=G_NON
  I_INVMSK+=1
  [M:TSH1]CODMSKINV(I_INVMSK-1)=[F:AWIB]NOMMSK(I_WINMSK-1)
  [M:TSH1]NUMMSKINV(I_INVMSK-1)= I_WINMSK
 Endif
Next I_WINMSK
[M:TSH1]NBRMSK=I_VISMSK
[M:TSH1]NBRINV=I_INVMSK

Else

For nolign = 1 To [F:AWIB]NBMSK
 #If [F:AWIB]FLGMSK(nolign-1)=G_OUI # gbn 06/07/04
  [M:TSH1]CODMSK(nolign-1)    = [F:AWIB]NOMMSK(nolign-1)
  [M:TSH1]FLGINV(nolign-1)    = [F:AWIB]FLGMSK(nolign-1)
  If dim([M:TSH1]FLGINVORI)>0 : [M:TSH1]FLGINVORI(nolign-1) = [F:AWIB]FLGMSK(nolign-1) : Endif
  [M:TSH1]NUMMSK(nolign-1)    = nolign  # gbn 06/07/04
 #Endif
Next nolign
[M:TSH1]NBRMSK=nolign-1

Endif


Affzo [M:TSH1]
Filter [AWIB]

End

#> Contrôle TRSCOD - Code transaction

Subprog C_TRSCOD(VALEUR)
Variable Char    VALEUR()
 If VALEUR="STD"
  GERR=1
  GMESSAGE=mess(2,79,1) # "STD code interdit"
  mkstat=2
  End
 Endif
End

################################################################################
# ECRAN : TSH1
################################################################################

#=====================================================================#
Subprog AV_FLGINV(VALEUR)
Variable Integer VALEUR
 If [M:TSH1]FLGINVORI(nolign-1)=G_NON
  mkstat=1
 Endif
End

# Bug n°26457 - Contrôler qu'au moins un onglet est visible.
#=====================================================================#
Subprog AM_FLGINV(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_NON
  Local Integer I_FLGINV, NBVIS
  Raz NBVIS
  For I_FLGINV=1 To [M:TSH1]NBRMSK
   If ((I_FLGINV<>nolign) & ([M:TSH1]FLGINV(I_FLGINV-1)=G_OUI))
    NBVIS+=1
   Endif
  Next I_FLGINV
  If NBVIS=0
   GERR=1
   GMESSAGE=mess(158,7770,1)  # Un onglet au moins doit être visible
   mkstat=2
  Endif
 Endif
End

################################################################################
# TRAITEMENTS ET SOUS-PROGRAMME DIVERS
################################################################################

################################################################################
# TRAITEMENTS ET SOUS-PROGRAMME DE VALIDATION DES TRANSACTIONS
################################################################################

#=====================================================================#
# Fixe les globales lié à la transaction utilisée                     #
#   - Groupe de société                                               #
#=====================================================================#
$SET_TRS_PARM
 If GFLAG<>"STD"
  Local Integer LOBJTYP
  If dim(LLOFTRS)>0 : LOBJTYP=1 : Endif
  If dim(LFASTRS)>0 : LOBJTYP=2 : Endif
  If dim(LGRTTRS)>0 : LOBJTYP=3 : Endif
  If dim(LLEATRS)>0 : LOBJTYP=4 : Endif
  If dim(LPHYTRS)>0 : LOBJTYP=6 : Endif
  If clalev ([F:SAI])=0 : Local File SAITRS [SAI] : Endif
  Read [F:SAI]HST0=LOBJTYP;GFLAG
  GGRPFCY = [F:SAI]GFY
 Endif
Return

#=====================================================================#
# Traitement de copie de transaction appelé par ACOPTRS               #
#=====================================================================#
$TRTCOP
Return

#=====================================================================#
# Traitement de validation appelé par le bouton validation            #
#=====================================================================#
$VALID
 If !GIMPORT
  Call VALIDATION([F:SAI]REFOBJ,[F:SAI]TRSCOD,nomap)
 Endif
Return

#=====================================================================#
# Sous-programme de validation de dossier  GENDOS                     #
# Appelé par le traitement de validation en masse des transactions    #
#                                                                     #
#   Paramètres :                                                      #
#                                                                     #
#      - APP   Application                                            #
#                                                                     #
#=====================================================================#
Subprog GENDOS(APPLI)
Value Char APPLI

 # On  regarde si le module Immobilisation est à "Oui" FQ58489
 If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
 Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
 If [F:ADS]MODULE(13) <> 2 : End : Endif

 If clalev([F:HST])=0  : Local File =APPLI+".SAITRS"    [HST]  : Endif : # En-tête transaction
 If clalev([F:DST])=0  : Local File =APPLI+".SAITRSDET" [DST]  : Endif : # Détail transaction

 Local Char    LCRITMODULE(255)
 Local Integer LNOTRS
 LCRITMODULE="1=1"
 LNOTRS=1
 For [HST] Where ENAFLG=2 & evalue(LCRITMODULE)
  Call ECR_TRACE(num$([F:HST]REFOBJ)-[F:HST]TRSCOD,0) From GESECRAN
  Call VALIDATION([F:HST]REFOBJ,[F:HST]TRSCOD,APPLI)
  LNOTRS=0
 Next

 If LNOTRS
  Call ECR_TRACE(mess(202,7770,1),0) From GESECRAN
 Endif

End

#=====================================================================#
# Sous-programme de Suppression des entités générées (masques et      #
# fenêtre) lors de la validation d'une transaction :                  #
# Developpement / Utilitaire / Dictionnaire / Validation des transac. #
#                                                                     #
#   Paramètres :                                                      #
#                                                                     #
#      - WIN    Fenêtre de référence de l'objet standard              #
#      - NBRMSK Nombre de masque générés                              #
#      - TRS    Code transaction                                      #
#      - APPL   Application                                           #
#                                                                     #
#=====================================================================#
Subprog SUPENTGEN(WIN,NBRMSK,TRS,APPL)
Value Char    WIN
Value Integer NBRMSK
Value Char    TRS
Value Char    APPL

Local Char NOMWIN(GLONFEN)
Local Integer I_MSK
Local Char NOMMSK(GLONAMK)
Local Char OBJ(3)

#-> Destruction de la fenêtre générée

#Dbgaff # Dev

NOMWIN = "W"+WIN+TRS
Call DELWIN(NOMWIN,APPL) From MSKDIV

#-> Destruction des masques générés

OBJ = right$(WIN,2)
For I_MSK=1 To NBRMSK
 NOMMSK = "W"+"E"+left$(OBJ,2)+TRS+num$(I_MSK)
 Call DELMSK(NOMMSK,APPL) From MSKDIV
Next I_MSK

End

#=====================================================================#
# Sous-programme pour récupérer dans une variable dimensionnée les    #
# bloc autorisés par rapport au code aactivité qu'ils portent         #
# Application                                                         #
#=====================================================================#
Subprog GET_BLK_AUZ(PAPPLI,PMSK,RBLKAUZTAB,RCOD)
Value    Char    PAPPLI
Value    Char    PMSK
Variable Integer RBLKAUZTAB
Variable Integer RCOD

Local Integer I_BLK           # Indice de parcours des blocs
Local Integer I_FIL           # Indice de remplissage de la liste des blocs autorisés

Raz RCOD
Raz RBLKAUZTAB

If clalev([F:AMKB])=0 : Local File =PAPPLI+".AMSK"      [AMKB] : Endif : # Dictionnaire des écrans
If clalev([F:ACVB])=0 : Local File =PAPPLI+".ACTIV"     [ACVB] : Endif : # Dictionnaire des écrans

#->Remarque EL / pas de prise en compte des codes activités quand validation du dossier de recette
#  est lancée à partir du dossier de développement.
# Piste : les globales G_ACTxxx sont celles de ABELX3 et non de TSTABELX3


Read [AMKB]CODMSK=PMSK
If fstat
 RCOD=1
 End
Endif
Raz I_FIL

#For I_BLK=1 To [F:AMKB]NBBLOC
# If [F:AMKB]ACTBLOC(I_BLK-1)<>""
#  Case [F:AMKB]ACTBLOC(I_BLK-1)
#   When "LEA"
#    If G_ACTLEA=G_OUI
#     RBLKAUZTAB(I_FIL)=I_BLK
#     I_FIL+=1
#    Endif
#   When "GRT"
#     If G_ACTGRT=G_OUI
#      RBLKAUZTAB(I_FIL)=I_BLK
#      I_FIL+=1
#     Endif
#   When Default
#    RBLKAUZTAB(I_FIL)=I_BLK
#    I_FIL+=1
#  Endcase
# Else
#  RBLKAUZTAB(I_FIL)=I_BLK
#  I_FIL+=1
# Endif
#Next I_BLK

For I_BLK=1 To [F:AMKB]NBBLOC
 If [F:AMKB]ACTBLOC(I_BLK-1)<>""
  #Call ACVMK2([F:AMKB]ACTBLOC(I_BLK-1)) From SUBACV
  #If mkstat<>2
  # RBLKAUZTAB(I_FIL)=I_BLK
  # I_FIL+=1
  #Endif
  Read [ACVB]CODACT=[F:AMKB]ACTBLOC(I_BLK-1)
  If !fstat & [F:ACVB]FLACT=G_OUI
   RBLKAUZTAB(I_FIL)=I_BLK
   I_FIL+=1
  Endif
 Else
  RBLKAUZTAB(I_FIL)=I_BLK
  I_FIL+=1
 Endif
Next I_BLK

End

#=====================================================================#
# Sous-programme de lancement auto de la validation des transaction   #
# après intégration patch                                             #
# Fiche n° 27860                                                      #
#=====================================================================#
Subprog PATCH(APPLI)
 Value Char APPLI

 # On  regarde si le module Immobilisation est à "Oui" FQ58489
 If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
 Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
 If [F:ADS]MODULE(13) <> 2 : End : Endif

 If clalev([F:HSTB])=0 : Local File =APPLI+".SAITRS"   [HSTB] : Endif : # En-tête transaction
 For [F:HSTB]
  Call VALIDATION([F:HSTB]REFOBJ,[F:HSTB]TRSCOD,APPLI)
 Next
End

#=====================================================================#
# Sous-programme de validation d'une transaction VALIDATION           #
#                                                                     #
#   Paramètres :                                                      #
#                                                                     #
#      - OBJ   Objet métier                                           #
#      - TRS   Code transaction à valider                             #
#      - APP   Application                                            #
#                                                                     #
#   Fonctionnement :                                                  #
#                                                                     #
#      Ce sous-programme génére les masques et la fenêtre associés à  #
#      la transaction passée en paramètre.                            #
#                                                                     #
#=====================================================================#
Subprog VALIDATION(OBJ,TRS,APPLI)
Value Integer OBJ
Value Char TRS
Value Char APPLI


#-> Ouverture tables nécessaires à la validation des masques

If clalev([F:HSTB])=0 : Local File =APPLI+".SAITRS"    [HSTB] : Endif : # En-tête transaction
If clalev([F:DSTB])=0 : Local File =APPLI+".SAITRSDET" [DSTB] : Endif : # Détail transaction
If clalev([F:AWIB])=0 : Local File =APPLI+".AWINDOW"   [AWIB] : Endif : # Dictionnaire des fenêtres
If clalev([F:AMKB])=0 : Local File =APPLI+".AMSK"      [AMKB] : Endif : # Dictionnaire des écrans
If clalev([F:AMZB])=0 : Local File =APPLI+".AMSKZON"   [AMZB] : Endif : # Dictionnaire des champs écran
If clalev([F:ACVB])=0 : Local File =APPLI+".ACTIV"     [ACVB] : Endif : # Dictionnaire des codes activités

#-> Ouverture tables nécessaires à la validation de la fenêtre

If clalev([F:AWI])=0  : Local File =APPLI+".AWINDOW"   [AWI] : Endif  : # Dictionnaire fenêtres
If clalev([F:AWP])=0  : Local File =APPLI+".AWINPAR"   [AWP] : Endif  : # Paramètre fenêtres
If clalev([F:AWB])=0  : Local File =APPLI+".AWINBRO"   [AWB] : Endif  : # Dictionnaire browser
If clalev([F:AWT])=0  : Local File =APPLI+".AWINBOUT"  [AWT] : Endif  : # Dictionnaire browser
If clalev([F:AMK])=0  : Local File =APPLI+".AMSK"      [AMK] : Endif  : # Dictionnaire écrans

#-> Variables pour la génération des masques

Local Integer  REFOBJ
Local Char     ORIMSKNAM(GLONAMK)
Local Char     GENMSKNAM(GLONAMK)
Local Char     GENMSKABR(4)
Local Char     GENMSKNAMB(GLONAMK)
Local Integer  TBLOC(15)
Local Char     TZONE(80)(300) #- GBN - 09092004 - # accroissement de la taille des variables passées à GENECR
Local Integer  TMOD(300)      #
Local Char     TINT(100)(300) #
Local Char     TTAB(1)(1)
Local Char     TFLD(1)(1)
Local Integer  OPT1, OPT2, OPT3, RETOUR
Local Integer  IZON, I, FLAG
Local Char     BOUTONS(10)(4)
Local Char     TEXTE(40), LISTE(3), REPONS(1)
Local Char     WNOMMSK(GLONAMK)
Local Shortint WFLGMSK
Local Char     OBJ1(10)
Local Char     WINREF1(GLONFEN)
Local Char     NOMWIN1(GLONFEN)
Local Char     NOMTRT1(GLONADC)
Local Integer  N_MSK, N_BLK
Local Integer  CACHE_BLOC
Local Integer  RETOUR

#-> Variables pour la génération de la fenêtre

Local Char     FOBJ (3)
Local Char     NOMWIN(GLONFEN)
Local Char     WINREF(GLONFEN)
Local Char     NOMTRW(GLONADC)
Local Char     WNOMMSK(GLONAMK)
Local Shortint WFLGMSK

#================ Synchronisation masque standard / transaction

# Ce sous-programme s'exécute pour une transaction donnée.
# L'objectif de ce chapitre est de vérifier la cohérence entre
# la description de l'écran personnalisée

 Call VERIF_STD_TRS(OBJ,TRS,APPLI,0,RETOUR)

#================ Génération validation masques ===============#

Read [HSTB]HST0=OBJ;TRS
Filter [AWIB] Where WIN=[HSTB]WIN : Read [AWIB]AWI0 First : Filter [AWIB]
For N_MSK = 0 To [AWIB]NBMSK-1
  If [F:AWIB]ACTMSK(N_MSK)<>"" Then
   Read [ACVB]CODACT=[F:AWIB]ACTMSK(N_MSK)
   If fstat
    GOK=0
    Call ECR_TRACE(mess(237,GML_MSGFASPR,1)-[F:AWIB]NOMMSK(N_MSK)+"/"+[F:AWIB]ACTMSK(N_MSK),1) From GESECRAN
    Break
   Elsif [F:ACVB]FLACT=G_NON
    #<GBN-FQ57309>
    #Break
    Goto NEXT_MASK
   Endif
  Endif

  Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
  Filter [AMKB] Where CODMSK=[F:AWIB]NOMMSK(N_MSK)
  Read [AMKB]CODMSK First
  Filter [AMKB]

  If [F:HSTB]FLGINV(N_MSK)=G_OUI
   For N_BLK = 1 To [AMKB]NBBLOC
    CACHE_BLOC=1
    For [DSTB]DST0 Where REFOBJ=OBJ & TRSCOD=TRS & CODMSK=[F:AWIB]NOMMSK(N_MSK) & NUMBLOC=N_BLK
     If [F:DSTB]SAIAFF<>3 Then : CACHE_BLOC=0 : Break : Endif
    Next
    TBLOC(N_BLK-1) = CACHE_BLOC
   Next N_BLK
  Endif

  OBJ1        = [F:AWIB]OBJ                         : # "LOF"
  WINREF1     = [F:AWIB]WIN                         : # "OLOF"
  NOMWIN1     = "W"+WINREF1+[F:HSTB]TRSCOD          : # "WOLOFx"
  NOMTRT1     = "WG"+WINREF1+[F:HSTB]TRSCOD         : # "WGOLOFx"
  REFOBJ      = [F:HSTB]REFOBJ
  ORIMSKNAM   = [F:AWIB]NOMMSK(N_MSK)
  GENMSKABR   = ""

  #-> Determination de l'abréviation du masque généré si FREEZON9

  If ORIMSKNAM="FREEZON9" Then
   If !(clalev([F:FRF])) Then : Local File =APPLI+".FREFLD"      [FRF] : Endif
   Read [FRF]FRF0=REFOBJ;""
   If fstat
    GOK=0 : Call RSTA("FRF",num$(REFOBJ)+"") From GLOCK : Break
   Else
    GENMSKABR=[F:FRF]ABRMSK
   Endif
  Endif


  GENMSKNAM   = "W"+"E"+left$(num$(OBJ1),2)+TRS+num$(N_MSK+1)
  For [DSTB]DST0 Where REFOBJ=OBJ and TRSCOD=TRS and CODMSK=[F:AWIB]NOMMSK(N_MSK)
   #-> Report des chgt de caractèristiques de saitrsdet dans les var parm de GENECR

    TZONE(IZON) = [F:DSTB]CODZON
    TMOD(IZON)  = [F:DSTB]SAIAFF       : # Type de saisie
    IZON       += 1

    TZONE(IZON) = [F:DSTB]CODZON
    TMOD(IZON)  = 4                 : # Changer l'intitulé
    TINT(IZON)  = num$([F:DSTB]INTIT)
    IZON       += 1

    TZONE(IZON) = [F:DSTB]CODZON
   # Gbn - Bug 24773 - 09092004 - Prise en compte des modifs Fiche, Fiche+Tableau, Tableau
    TMOD(IZON)  = 9                 : # Changer la présentation des données de type tableau
    TINT(IZON)  = num$([F:DSTB]MODE)
    IZON       += 1

    TZONE(IZON) = [F:DSTB]CODZON
   # Gbn - Bug 24773 - Fin
    TMOD(IZON)  = 10                : # Obligatoire/Facultatif
    TINT(IZON)  = num$([F:DSTB]OBLIG)
    IZON       += 1

    TZONE(IZON) = [F:DSTB]CODZON
    TMOD(IZON)  = 11                : # Valeur par défaut
    TINT(IZON)  = num$([F:DSTB]VALDEF)
    IZON       += 1

   #-> Si la zone MZSZON est alimentée
    If [F:DSTB]MZSZON<>""
     TZONE(IZON) = [F:DSTB]MZSZON
     TMOD(IZON)  = [F:DSTB]SAIAFF
     IZON       += 1
    Endif
  Next
  # Validation de l'écran
  OPT1         = 2   : # Pour pas recalculer la position des blocs
  OPT2         = 0   : # Pas d'affichage du masque généré !!!
  OPT3         = 0   : # Présentation d'origine !!!
  Call GENECR(APPLI,ORIMSKNAM,GENMSKNAM,GENMSKABR,TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECRABEL # Notre version

  If RETOUR<>0 Then : GOK=0 : Break : Endif
  Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
 $NEXT_MASK
Next N_MSK

If GOK=0 : Call ECR_TRACE(mess(236,GML_MSGFASPR,1)-[F:HSTB]TRSCOD,1) From GESECRAN : End : Endif

#================== Génération validation fenêtre ====================#

FOBJ   = [F:AWIB]OBJ              : # "LOF"
WINREF = [F:AWIB]WIN              : # "OLOF"
NOMWIN = NOMWIN1                  : # "WOLOFx"
NOMTRW = "O"+NOMWIN1              : # "OLOFx"

#--> suppression de la fenetre precedemment générée (sauf si celle de base)
If NOMWIN<>WINREF Then : Call DELWIN(NOMWIN,APPLI) From MSKDIV : Endif

#--> Accès à la fenêtre de référence
Read [F:AWI]AWI0 = WINREF

#--> Génération de la fenêtre associée à la transaction
If !fstat Then
 [F:AWI]WIN    = NOMWIN
 For N_MSK = 0 To  [AWI]NBMSK-1
  WNOMMSK = "W"+"E"+left$(num$(OBJ1),2)+TRS+num$(N_MSK+1)
  Gosub ONGLET_INVISIBLE
  [F:AWI]NOMMSK(N_MSK)=WNOMMSK
  [F:AWI]FLGMSK(N_MSK)=WFLGMSK
 Next N_MSK
 [F:AWI]ACS    = [F:HSTB]ACSCOD                     : # Code d'accès
 [F:AWI]LIBEL  = [F:HSTB]DES                        : # Désignation (titre !)
 [F:AWI]ENAFLG = [F:HSTB]ENAFLG                     : # Enable = celui de la transaction
 [F:AWI]TRN    = TRS                                : # "LOFx"
 If NOMWIN<>WINREF Then
  Write [AWI]

#--> Duplication des paramétres
  For [AWP]AWP0 Where WIN=WINREF
   [F:AWP]WIN=NOMWIN
   Write [AWP]
   If fstat : GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
  Next
  If GOK<1 : End : Endif

#--> Duplication des browsers
  Read [AWB]AWB0=WINREF
  [F:AWB]WIN=NOMWIN
  Write [AWB]
  If fstat : GOK=0 : Call FSTA("AWB") From GLOCK : Endif
  If GOK<1 : End : Endif

#--> Duplication des boutons
  For [AWT]AWT0 Where WIN=WINREF
   [F:AWT]WIN=NOMWIN
   Write [AWT]
   If fstat : GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
  Next
  If GOK<1 : End : Endif

 Else
   Rewrite [AWI]
 Endif
 If fstat : GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
Endif
Call VALID(NOMWIN,APPLI,1,RETOUR) From VALWIN

End

#######################################################################
# Recherche si l'onglet doit être invisible                           #
#######################################################################
$ONGLET_INVISIBLE
Local Integer I

WFLGMSK=1
# Si écran défini comme invisible dans paramétrage transaction
 If [F:HSTB]FLGINV(N_MSK)=1 : WFLGMSK=1 : Return : Endif
# Si tous les blocs sont invisible, onglet invisible
Read [AMK]CODMSK=WNOMMSK
If !fstat Then
 For I=0 To [F:AMK]NBBLOC-1
  If [F:AMK]TYPBLOC(I)<>5 Then WFLGMSK=2 : Break Endif
 Next I
Endif
Return

#=====================================================================#
#                                                                     #
# S/P permettant, en cas de modification de la description d'un       #
# écran standard, de rétablir la cohérence des tables transaction     #
#                                                                     #
#=====================================================================#
Subprog VERIF_STD_TRS(POBJ,PTRS,PAPPLI,PMOD,RCDRET)
Value    Integer POBJ
Value    Char    PTRS
Value    Char    PPAPPLI
Value    Integer PMOD
Variable Integer RCDRET

# Constantes

Local Integer DVTMODE     :  DVTMODE     = 0     # Mode développement si 1 -> détail traitement dans la trace (si ouverte)
Local Integer TRACEMODE   :  TRACEMODE   = 0     # Mode trace si 1 -> Emet un CR des mises à jour dans la trace (si ouverte)
Local Integer MAX_NB_MSK  :  MAX_NB_MSK  = 15    # Nombre maximum d'onglets dans une fenêtre
Local Integer MSKACT_RIEN :  MSKACT_RIEN = 0     # Action masque - on ne fait rien
Local Integer MSKACT_SUPP :  MSKACT_SUPP = 1     # Action masque - Onglet à supprimer de la transaction
Local Integer MSKACT_MOVE :  MSKACT_MOVE = 2     # Action masque - Onglet à déplacer dans la transaction
Local Integer MSKACT_CREE :  MSKACT_CREE = 3     # Action masque - Onglet à créer dans la transaction

If GUSER="GBO" & 1=0 : DVTMODE=1 : TRACEMODE=1 : Endif

# Variables

Local Char    MSK_STD_NAM(15)(0..MAX_NB_MSK-1)   # Fenêtre standard : nom des onglets
Local Integer MSK_STD_VIS    (0..MAX_NB_MSK-1)   # Fenêtre standard : Flag visible / invisible
Local Char    MSK_TRS_NAM(15)(0..MAX_NB_MSK-1)   # Fenêtre transac  : nom des onglets
Local Integer MSK_TRS_ORD    (0..MAX_NB_MSK-1)   # Fenêtre transac  : Numéro d'ordre de l'onglet
Local Integer MSK_TRS_VIS    (0..MAX_NB_MSK-1)   # Fenêtre transac  : Flag visible / invisible
Local Integer MSK_TRS_ACT    (0..MAX_NB_MSK-1)   # Fenêtre transac  : action à réaliser
Local Integer MSK_TRS_PAR    (0..MAX_NB_MSK-1)   # Fenêtre transac  : paramètre de l'action à réaliser
Local Integer MSK_TRS_EPY    (0..MAX_NB_MSK-1)   # Fenêtre transac  : Flag occurrence vide pour le tri sorta
Local Integer NBR_STD_MSK                        # Nombre d'onglet de la fenêtre standard
Local Integer NBR_TRS_MSK                        # Nombre d'onglet de la transaction
Local Integer I_MSK                              # Indice de parcours d'une liste de masques
Local Integer I_STD_MSK                          # Indice d'un masque dans la liste des onglet de la fenêtre standard
Local Integer I_TRS_MSK                          # Indice d'un masque dans la liste des onglet de la transaction
Local Integer I_TRS_MSKSUP                       # Indice des masques à ajouter dans la liste
Local Integer NBR_DEL_REC                        # Nombre d'enregistrements supprimés dans SAITRSDET
Local Integer NBR_CRE_REC                        # Nombre d'enregistrements créés dans SAITRSDET
Local Char    STDWINNAM                          # Nom de la fenêtre standard de l'objet métier

# Ouverture des tables

If clalev([F:HSTB])=0 : Local File =PAPPLI+".SAITRS"    [HSTB] : Endif : # En-tête transaction
If clalev([F:DSTB])=0 : Local File =PAPPLI+".SAITRSDET" [DSTB] : Endif : # Détail transaction
If clalev([F:DSTW])=0 : Local File =PAPPLI+".SAITRSDET" [DSTW] : Endif : # Détail transaction pour réécriture
If clalev([F:AWIB])=0 : Local File =PAPPLI+".AWINDOW"   [AWIB] : Endif : # Dictionnaire des fenêtres
If clalev([F:AMKB])=0 : Local File =PAPPLI+".AMSK"      [AMKB] : Endif : # Dictionnaire des écrans
If clalev([F:AMZB])=0 : Local File =PAPPLI+".AMSKZON"   [AMZB] : Endif : # Dictionnaire des champs écran

# Ouverture d'une boîte de validation

Call TEMPON("F") From GESECRAN

# ouverture trace si nécessaire

If ((TRACEMODE | DVTMODE) & GTRACE="" & !GSERVEUR)
 Call OUVRE_TRACE("Vérification de la transaction "-PTRS) From LECFIC
 Local Integer OPEN_TRC_ICI
Endif

# Détermination du nom de la fenêtre standard en fonction de l'objet métier

Case POBJ
 When GVML_OMBIEN   : STDWINNAM="OFAS" # STDWINNAM="OFAS"
 When GVML_OMDEPEN  : STDWINNAM="OLOF"
 When GVML_OMLOCFI  : STDWINNAM="OLEA"
 When GVML_OMSUBV   : STDWINNAM="OGRT"
 When Default
  RCDRET=1  # Référence objet métier incorrecte
  End
Endcase

# Contrôle du nom de la transaction à vérifier

If PTRS=""
 RCDRET=2   # Absence de code transaction
 End
Endif

# Accès à la fenêtre standard et remplissage des variables MSK_STD_***

Read [AWIB]AWI0=STDWINNAM
If fstat
 RCDRET=10+fstat  # Erreur d'accès à la table des fenêtres (Code retour de 11 à 15)
 End
Endif

For I_MSK=1 To [F:AWIB]NBMSK
 MSK_STD_NAM(I_MSK-1)=[F:AWIB]NOMMSK(I_MSK-1)
 MSK_STD_VIS(I_MSK-1)=[F:AWIB]FLGMSK(I_MSK-1)
Next I_MSK

# Accès au paramétrage de la transaction (SAITRS) et remplissage des variables MSK_TRS_***

Read [HSTB]HST0=POBJ;PTRS
If fstat
 RCDRET=20+fstat  # Erreur d'accès à la table des transactions (Code retour de 21 à 25)
 End
Endif

For I_MSK=1 To [F:HSTB]NBRMSK
 MSK_TRS_NAM(I_MSK-1)=[F:HSTB]LISMSK(I_MSK-1)
 MSK_TRS_ORD(I_MSK-1)=I_MSK
 MSK_TRS_VIS(I_MSK-1)=[F:HSTB]FLGINV(I_MSK-1)
 MSK_TRS_ACT(I_MSK-1)=0
 MSK_TRS_PAR(I_MSK-1)=0
 MSK_TRS_EPY(I_MSK-1)=-1
Next I_MSK

NBR_STD_MSK = [F:AWIB]NBMSK
NBR_TRS_MSK = [F:HSTB]NBRMSK

# Affichage dans la trace pour contrôle développement

If DVTMODE | TRACEMODE
 Gosub AFFICHE_TRS_INFOS
 Gosub AFFICHE_MSK_STD
Endif
If DVTMODE
 Gosub AFFICHE_MSK_TRS
Endif

# Comparaison des deux variables dimensionnées pour savoir ce qu'il y a a faire :

 # Première comparaison à partir de MSK_TRS_NAM
 # Traite les modification à apporter aux onglets existants dans la transaction

For I_MSK=1 To NBR_TRS_MSK
 I_STD_MSK=find (MSK_TRS_NAM(I_MSK-1),MSK_STD_NAM)
 # Pas trouvé, on le supprime
 If I_STD_MSK=0
  MSK_TRS_ACT(I_MSK-1)=MSKACT_SUPP
 Endif
 # Trouvé à la même place, on compare les flag visible / invisible : si différent TRS_VIS prend la valeur de STD_VIS
 # pour le flag visible voir si c'est bien ça qu'il faut faire ???
 If I_STD_MSK<>0 & I_STD_MSK=I_MSK
  If MSK_STD_VIS(I_STD_MSK-1)<>MSK_TRS_VIS(I_MSK-1) & MSK_STD_VIS(I_STD_MSK-1)=G_NON
   #MSK_TRS_ORD(I_MSK-1)=I_STD_MSK
   #MSK_TRS_VIS(I_MSK-1)=MSK_STD_VIS(I_STD_MSK-1)
    MSK_TRS_VIS(I_MSK-1)=G_NON
  Endif
 Endif
 # Trouvé mais à une place différente
 If I_STD_MSK<>0 & I_STD_MSK<>I_MSK
  MSK_TRS_ORD(I_MSK-1)=I_STD_MSK
  MSK_TRS_ACT(I_MSK-1)=MSKACT_MOVE
  MSK_TRS_PAR(I_MSK-1)=I_MSK
  If MSK_STD_VIS(I_STD_MSK-1)<>MSK_TRS_VIS(I_MSK-1) & MSK_STD_VIS(I_STD_MSK-1)=G_NON
   MSK_TRS_VIS(I_MSK-1)=G_NON
  Endif
 Endif
Next I_MSK

 # Deuxième comparaison à partir de MSK_STD_NAM
 # Traite le cas des nouveaux onglets

For I_MSK=1 To NBR_STD_MSK
 I_TRS_MSK=find(MSK_STD_NAM(I_MSK-1),MSK_TRS_NAM)
 # Pas trouvé, on le crée dans MSK_TRS_***
 If !I_TRS_MSK
  MSK_TRS_NAM(NBR_TRS_MSK)=MSK_STD_NAM(I_MSK-1)
  MSK_TRS_ORD(NBR_TRS_MSK)=I_MSK
  MSK_TRS_VIS(NBR_TRS_MSK)=MSK_STD_VIS(I_MSK-1)
  MSK_TRS_ACT(NBR_TRS_MSK)=MSKACT_CREE
  MSK_TRS_PAR(NBR_TRS_MSK)=0
  MSK_TRS_EPY(NBR_TRS_MSK)=-1
  NBR_TRS_MSK+=1
 Endif
Next I_MSK

# Tri des variables MSK_TRS_***

  Sorta MSK_TRS_EPY,MSK_TRS_ORD,MSK_TRS_ACT,MSK_TRS_PAR,MSK_TRS_VIS,MSK_TRS_NAM
& Order By MSK_TRS_EPY(indice),MSK_TRS_ORD(indice),MSK_TRS_ACT(indice)

# Affichage dans la trace pour contrôle développement

If DVTMODE | TRACEMODE
 Gosub AFFICHE_CODACT
 Gosub AFFICHE_MSK_TRS
Endif

# Début de la transaction de mise à jour des tables SAISTRS et SAITRSDET

Trbegin [HSTB], [DSTB] : GOK=1

# Exploitation des variables MSK_TRS_*** et mise à jour de SAITRSDET

For I_MSK=1 To NBR_STD_MSK
 If DVTMODE | TRACEMODE : Gosub AFFICHE_INFOS_MASK : Endif
 Case MSK_TRS_ACT(I_MSK-1)
  When MSKACT_RIEN : Gosub MSK_RIEN : If MSK_TRS_VIS(I_MSK-1)=G_OUI : Gosub MSK_VERIF_ZON : Endif
  When MSKACT_SUPP : Gosub MSK_SUPP
  When MSKACT_MOVE : Gosub MSK_MOVE : If MSK_TRS_VIS(I_MSK-1)=G_OUI : Gosub MSK_VERIF_ZON : Endif
  When MSKACT_CREE : Gosub MSK_CREE
  When Default
 Endcase
 If GOK<1 : Break : Endif
Next I_MSK

# Mise à jour de la liste des onglets dans SAITRS et réécriture de l'enregistrement

If GOK
 Raz [F:HSTB]LISMSK, [F:HSTB]FLGINV, [F:HSTB]NUMMSK
 For I_MSK=1 To NBR_TRS_MSK
  If MSK_TRS_ACT(I_MSK-1)<>MSKACT_SUPP
   [F:HSTB]NUMMSK(MSK_TRS_ORD(I_MSK-1)-1)   = MSK_TRS_ORD(I_MSK-1)
   [F:HSTB]LISMSK(MSK_TRS_ORD(I_MSK-1)-1)   = MSK_TRS_NAM(I_MSK-1)
   [F:HSTB]FLGINV(MSK_TRS_ORD(I_MSK-1)-1)   = MSK_TRS_VIS(I_MSK-1)
   [F:HSTB]FLGINVORI(MSK_TRS_ORD(I_MSK-1)-1)= MSK_STD_VIS(I_MSK-1)
  Endif
 Next I_MSK
 [F:HSTB]NBRMSK=NBR_STD_MSK
 Rewrite [HSTB]
 If fstat
  RCDRET=40+fstat  # Erreur d'accès à la table des transactions (Code retour de 41 à 45)
  GOK=0
  End
 Endif
Endif

# Terminaison de la transaction

If GOK<1
 Rollback
Else
 Commit
Endif

# Fermeture de la boîte de validation

Call TEMPOFF From GESECRAN

# fermeture trace si nécessaire

If ((TRACEMODE | DVTMODE) & dim(OPEN_TRC_ICI)>0)
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif

End

#======> Routines communes

# Pas d'action sur le masque mais vérif du flag visible invisible
$MSK_RIEN
 # Si le flag du masque est invisible, on supprime les enregistrements correspondants dans SAITRSDET
 If MSK_TRS_VIS(I_MSK-1)=G_NON
  Call MSK_SUP(POBJ,PTRS,MSK_TRS_NAM(I_MSK-1),nomap,NBR_DEL_REC,RCDRET)
  If RCDRET
   GOK=0
  Endif
 Endif
Return

# Suppression d'un onglet de la fenêtre
$MSK_SUPP
 # Dans tous les cas, on supprime
 Call MSK_SUP(POBJ,PTRS,MSK_TRS_NAM(I_MSK-1),nomap,NBR_DEL_REC,RCDRET)
 If RCDRET
  GOK=0
 Endif
Return

# Déplacement d'un onglet dans la fenêtre
$MSK_MOVE
 # Si l'onglet est invisible, on supprime les enregistrements dans SAITRSDET au lieu de les déplacer
 If MSK_TRS_VIS(I_MSK-1)=G_NON
  Call MSK_SUP(POBJ,PTRS,MSK_TRS_NAM(I_MSK-1),nomap,NBR_DEL_REC,RCDRET)
  If RCDRET
   GOK=0
  Endif
 # Si l'onglet est visible, on déplace les enregistrements dans SAITRSDET
 Elsif MSK_TRS_VIS(I_MSK-1)=G_OUI
  Call MSK_MOV(POBJ,PTRS,MSK_TRS_NAM(I_MSK-1),nomap,MSK_TRS_ORD(I_MSK-1),RCDRET)
  If RCDRET
   GOK=0
  Endif
 Endif
Return

# Ajout d'un nouvel onglet dans la fenêtre
$MSK_CREE
 Call MSK_CRE(POBJ,PTRS,MSK_TRS_ORD(I_MSK-1),MSK_TRS_NAM(I_MSK-1),nomap,NBR_CRE_REC,RCDRET)
 If RCDRET
  GOK=0
 Endif
Return

# Vérif si les champs de l'onglet standard sont les mêmes que ceux de l'onglet de la transaction
$MSK_VERIF_ZON
 # Première boucle de comparaison : on vérifie si les champs de AMSKZON sont présents dans
 # SAITRSDET. S'ils n'existent pas, on les crée, s'ils existent, on vérifie leurs attributs
 # respectifs.

 Local Integer LIS_BLK_AUZ(14)
 Local Integer RETOUR

 Call GET_BLK_AUZ(PAPPLI,MSK_TRS_NAM(I_MSK-1),LIS_BLK_AUZ,RETOUR)

 Filter [AMZB] Where (CODMSK=MSK_TRS_NAM(I_MSK-1) & !(SAIAFF>2) & CODTYP<>"W" and find(NUMBLOC,LIS_BLK_AUZ)<>0)

 For [AMZB]
  Read [DSTB]DST0=POBJ;PTRS;MSK_TRS_ORD(I_MSK-1);MSK_TRS_NAM(I_MSK-1);[F:AMZB]CODZON
  If fstat=5
   # Pas trouvé, il faut le créer
   If DVTMODE | TRACEMODE : Call ECR_TRACE([F:AMZB]CODZON-"->"-"Création",0) From GESECRAN : Endif
   Gosub ZON_CREE
  Elsif fstat=0
   # Trouvé, il faut vérifier la concordance des attributs
   If DVTMODE | TRACEMODE  : Call ECR_TRACE([F:AMZB]CODZON-"->"-"Contrôle attribut",0) From GESECRAN : Endif
   Gosub ZON_CTRL
  Else
   # Erreur
   RCDRET=30+fstat  # Erreur d'accès à la table des transactions détail (codes retour 31 à 35)
   GOK=0
   Break
  Endif
 Next
 Filter [AMZB]

 # Deuxième étape, on supprime tous les champs de SAITRSDET qui n'ont pas été flagés à la première
 # étape : ce cas signifie qu'ils ne sont pas présents dans AMSKZON. Puis tous les flags de trt
 # sont remis à 0
 If GOK
  If DVTMODE | TRACEMODE
   Call ECR_TRACE("-> Suppression des champs :",0) From GESECRAN
   Filter [DSTB] Where (REFOBJ=POBJ & TRSCOD=PTRS & CODMSK=MSK_TRS_NAM(I_MSK-1) & !(FLGTRT=1))
   For [DSTB]
    Call ECR_TRACE([F:DSTB]CODZON,0) From GESECRAN
   Next
   Filter [DSTB]
  Endif
  Delete [DSTB] Where (REFOBJ=POBJ & TRSCOD=PTRS & CODMSK=MSK_TRS_NAM(I_MSK-1) & !(FLGTRT=1))
  If fstat
   RCDRET=30+fstat  # Erreur d'accès à la table des transactions détail (codes retour 31 à 35)
   GOK=0
  Else
   If DVTMODE | TRACEMODE : Call ECR_TRACE(num$(adxdlrec)-"champs supprimés ",0) From GESECRAN : Endif
  Endif
 Endif

 # Dernière étape, on remet le flag à 0 pour tous les enregistrements de l'onglet dans SAITRSDET
 If GOK
  Update [DSTB] Where REFOBJ=POBJ & TRSCOD=PTRS & CODMSK=MSK_TRS_NAM(I_MSK-1) & FLGTRT=1
&               With  FLGTRT=0
 Endif

Return

# Nouveau champ dans l'écran standard : on le crée dans SAITRSDET
$ZON_CREE
 Local Char SAVMZSZON(20)
 If [F:AMZB]CODTYP="MZS"
  Raz SAVMZSZON
  SAVMZSZON=[F:AMZB]CODZON
 Else
  Raz [F:DSTB]
  [F:DSTB]REFOBJ    = POBJ
  [F:DSTB]TRSCOD    = PTRS
  [F:DSTB]NUMMSK    = MSK_TRS_ORD(I_MSK-1)
  [F:DSTB]CODMSK    = MSK_TRS_NAM(I_MSK-1)
  Read [AMKB]CODMSK = MSK_TRS_NAM(I_MSK-1)
  [F:DSTB]INTMSK    = [F:AMKB]INTMSK
  [F:DSTB]BROMSK    = num$([F:DSTB]NUMMSK)-[F:DSTB]CODMSK
  [F:DSTB]CODZON    = [F:AMZB]CODZON
  [F:DSTB]CODTYP    = [F:AMZB]CODTYP
  [F:DSTB]INTIT     = [F:AMZB]INTIT
  [F:DSTB]SAIAFF    = [F:AMZB]SAIAFF
  [F:DSTB]SAIAFFORI = [F:AMZB]SAIAFF
  [F:DSTB]MODE      = [F:AMZB]MODE
  [F:DSTB]MODEORI   = [F:AMZB]MODE
  [F:DSTB]OBLIG     = [F:AMZB]OBLIG
  [F:DSTB]OBLIGORI  = [F:AMZB]OBLIG
  [F:DSTB]VALDEF    = [F:AMZB]VALDEF
  [F:DSTB]VALDEFORI = [F:AMZB]VALDEF
  [F:DSTB]NUMBLOC   = [F:AMZB]NUMBLOC
  [F:DSTB]CREUSR    = [V]GUSER
  [F:DSTB]CREDAT    = [S]datesyst
  [F:DSTB]MODFLG    = 1
  If SAVMZSZON<>""
   [F:DSTB]MZSZON    = SAVMZSZON
   Raz SAVMZSZON
  Endif
  [F:DSTB]FLGTRT=1
  Write [F:DSTB]
  If fstat
   RCDRET=30+fstat  # Erreur d'accès à la table des transactions détail (codes retour 31 à 35)
   GOK=0
  Endif
 Endif
Return

# Le champ existe dans l'écran standard et dans la transaction : on effectue les contrôle et on réécrit SAITRSDET
$ZON_CTRL
 # On dispose des infos suivantes :
 #  Champs de l'écran standard         [F:AMZB]
 #  Champs de l'écran de la transac    [F:DSTB]

 # 1 - Numéro de bloc

 If [F:DSTB]NUMBLOC<>[F:AMZB]NUMBLOC
  If DVTMODE | TRACEMODE
   Call ECR_TRACE("      +"-"Déplacement du bloc"-num$([F:DSTB]NUMBLOC)-"dans le bloc"-num$([F:AMZB]NUMBLOC),0) From GESECRAN
  Endif
  [F:DSTB]NUMBLOC=[F:AMZB]NUMBLOC
 Endif

 # 2 - Type de saisie

 If [F:DSTB]SAIAFF<>[F:AMZB]SAIAFF
  If [F:AMZB]SAIAFF>[F:DSTB]SAIAFFORI
   If DVTMODE | TRACEMODE
    Call ECR_TRACE("      +"-"Ancien type de saisie"-mess([F:DSTB]SAIAFF,936,1)-"nouveau"-mess([F:AMZB]SAIAFF,936,1),0) From GESECRAN
   Endif
   [F:DSTB]SAIAFF=[F:AMZB]SAIAFF
  Endif
  [F:DSTB]SAIAFFORI=[F:AMZB]SAIAFF
 Endif

 # 3 - Mode de saisie

 #Gbn - Bug 24773 - 09092004 - On conserve les modifications de paramètrage utilisateur sauf si valeur origine=0
 #If [F:DSTB]MODE<>[F:AMZB]MODE
 # If DVTMODE | TRACEMODE
 #  Call ECR_TRACE("      +"-"Ancien mode de saisie"-mess([F:DSTB]MODE,99,1)-"nouveau"-mess([F:AMZB]MODE,99,1),0) From GESECRAN
 # Endif
 # [F:DSTB]MODE   =[F:AMZB]MODE
 # [F:DSTB]MODEORI=[F:AMZB]MODE
 #Endif

 If [F:AMZB]MODE<>[F:DSTB]MODEORI
  If ((([F:DSTB]MODE<>[F:DSTB]MODEORI) & [F:AMZB]MODE=0) | ([F:DSTB]MODE=[F:DSTB]MODEORI))
   If DVTMODE | TRACEMODE
    Call ECR_TRACE("      +"-"Ancien mode de saisie"-mess([F:DSTB]MODE,99,1)-"nouveau"-mess([F:AMZB]MODE,99,1),0) From GESECRAN
   Endif
   [F:DSTB]MODE=[F:AMZB]MODE
  Endif
  [F:DSTB]MODEORI=[F:AMZB]MODE
 Endif

 #Gbn - Bug 24773 - 09092004 - Fin

 # 4 - Zone obligatoire

 #Gbn - Bug 33334 - 22112005 - On conserve le paramétrage utilisateur sauf si la zone devient obligatoire
 #If [F:DSTB]OBLIG<>[F:AMZB]OBLIG
 #  If DVTMODE | TRACEMODE
 #   Call ECR_TRACE("      +"-"Ancien obligatoire"-mess([F:DSTB]OBLIG,1,1)-"nouveau"-mess([F:AMZB]OBLIG,1,1),0) From GESECRAN
 #  Endif
 # [F:DSTB]OBLIG    = [F:AMZB]OBLIG
 # [F:DSTB]OBLIGORI = [F:AMZB]OBLIG
 #Endif

 If [F:DSTB]OBLIGORI<>[F:AMZB]OBLIG
   If DVTMODE | TRACEMODE
     Call ECR_TRACE("      +"-"Ancien obligatoire"-mess([F:DSTB]OBLIG,1,1)-"nouveau"-mess([F:AMZB]OBLIG,1,1),0) From GESECRAN
   Endif
   If [F:AMZB]OBLIG=G_OUI
    [F:DSTB]OBLIG    = [F:AMZB]OBLIG
   Endif
   [F:DSTB]OBLIGORI = [F:AMZB]OBLIG
 Endif

 #Gbn - Bug 33334 - 22112005 - Fin

 # 5 - Valeur par défaut

 If [F:DSTB]VALDEF<>[F:AMZB]VALDEF
  If [F:DSTB]VALDEF=[F:DSTB]VALDEFORI
   If DVTMODE | TRACEMODE : Call ECR_TRACE("      +"-"Mise à jour de la valeur par défaut"-[F:AMZB]VALDEF,0) From GESECRAN : Endif
   [F:DSTB]VALDEF=[F:AMZB]VALDEF
  Endif
   If DVTMODE | TRACEMODE : Call ECR_TRACE("      +"-"Conservation de VALDEF défini dans la transaction",0) From GESECRAN : Endif
  [F:DSTB]VALDEFORI=[F:AMZB]VALDEF
 Endif

 # 6 - Changement d'intitulé

 If [F:DSTB]INTIT<>[F:AMZB]INTIT
  If DVTMODE | TRACEMODE
   Call ECR_TRACE("      +"-"Ancien intitulé"-num$([F:DSTB]INTIT)-"nouveau"-num$([F:AMZB]INTIT),0) From GESECRAN
  Endif
  [F:DSTB]INTIT=[F:AMZB]INTIT
 Endif

 # réécriture de [DSTB]
 [F:DSTB]FLGTRT=1
 Rewrite [DSTB]
 If fstat
  RCDRET=30+fstat  # Erreur d'accès à la table des transactions détail (codes retour 31 à 35)
  GOK=0
 Endif

Return

######### Sous-programmes communs

#==> Déplacement des enregistrements d'un onglet dans SAITRSDET
#
Subprog MSK_MOV(PREFOBJ,PTRANSAC,PCODMSK,PAPPL,PORDNEW,RRETOUR)
Value    Integer PREFOBJ
Value    Char    PTRANSAC
Value    Char    PCODMSK
Value    Char    PAPPL
Value    Integer PORDNEW
Variable Integer RRETOUR

If clalev([F:DSTB])=0 : Local File =PAPPL+".SAITRSDET" [DSTB] : Endif

Update [DSTB] Where (REFOBJ=PREFOBJ & TRSCOD=PTRANSAC & CODMSK=PCODMSK)
&              With  NUMMSK=PORDNEW, BROMSK=num$(PORDNEW)-PCODMSK
If fstat
 RRETOUR=30+fstat # Erreur d'accès à la table des transactions détail (codes retour 31 à 35)
Else
Endif

End

#==> Suppression des enregistrements d'un onglet dans SAITRSDET
#
Subprog MSK_SUP(PREFOBJ,PTRANSAC,PCODMSK,PAPPL,RNBRENRSUP,RRETOUR)
Value    Integer PREFOBJ
Value    Char    PTRANSAC
Value    Char    PCODMSK
Value    Char    PAPPL
Variable Integer RNBRENRSUP
Variable Integer RRETOUR

If clalev([F:DSTB])=0 : Local File =PAPPL+".SAITRSDET" [DSTB] : Endif

Delete [DSTB] Where (REFOBJ=PREFOBJ & TRSCOD=PTRANSAC & CODMSK=PCODMSK)
If fstat
 RRETOUR=30+fstat # Erreur d'accès à la table des transactions détail (codes retour 31 à 35)
Else
 RNBRENRSUP=adxdlrec
Endif
End

#==> Création des enregistrements d'un onglet dans SAITRSDET
#
Subprog MSK_CRE(PREFOBJ,PTRANSAC,PNUMMSK,PCODMSK,PAPPL,RNBRENRCRE,RRETOUR)
Value    Integer PREFOBJ
Value    Char    PTRANSAC
Value    Integer PNUMMSK
Value    Char    PCODMSK
Value    Char    PAPPL
Variable Integer RNBRENRCRE
Variable Integer RRETOUR

Local Char    SAVMZSZON, I_MSK
Local Integer LIS_BLK_AUZ(14)
Local Integer RETOUR

If clalev([F:DSTB])=0 : Local File =PAPPL+".SAITRSDET" [DSTB] : Endif
If clalev([F:AMKB])=0 : Local File =PAPPL+".AMSK"      [AMKB] : Endif
If clalev([F:AMZB])=0 : Local File =PAPPL+".AMSKZON"   [AMZB] : Endif

Call GET_BLK_AUZ(PAPPL,PCODMSK,LIS_BLK_AUZ,RETOUR)

Filter [AMZB] Where (CODMSK=PCODMSK and !(SAIAFF>2) and CODTYP<>"W" and find(NUMBLOC,LIS_BLK_AUZ)<>0)
For [AMZB]CODZON
 If [F:AMZB]CODTYP="MZS"
  Raz SAVMZSZON
  SAVMZSZON=[F:AMZB]CODZON
 Else
  Raz [F:DSTB]
  [F:DSTB]REFOBJ    = PREFOBJ
  [F:DSTB]TRSCOD    = PTRANSAC
  [F:DSTB]NUMMSK    = PNUMMSK
  [F:DSTB]CODMSK    = PCODMSK
  Read [AMKB]CODMSK = PCODMSK
  [F:DSTB]INTMSK    = [F:AMKB]INTMSK
  [F:DSTB]BROMSK    = num$([F:DSTB]NUMMSK)-[F:DSTB]CODMSK
  [F:DSTB]CODZON    = [F:AMZB]CODZON
  [F:DSTB]CODTYP    = [F:AMZB]CODTYP
  [F:DSTB]INTIT     = [F:AMZB]INTIT
  [F:DSTB]SAIAFF    = [F:AMZB]SAIAFF
  [F:DSTB]SAIAFFORI = [F:AMZB]SAIAFF
  [F:DSTB]MODE      = [F:AMZB]MODE
  [F:DSTB]MODEORI   = [F:AMZB]MODE
  [F:DSTB]OBLIG     = [F:AMZB]OBLIG
  [F:DSTB]OBLIGORI  = [F:AMZB]OBLIG
  [F:DSTB]VALDEF    = [F:AMZB]VALDEF
  [F:DSTB]VALDEFORI = [F:AMZB]VALDEF
  [F:DSTB]NUMBLOC   = [F:AMZB]NUMBLOC
  [F:DSTB]CREUSR    = [V]GUSER
  [F:DSTB]CREDAT    = [S]datesyst
  [F:DSTB]MODFLG    = 1
  If SAVMZSZON<>""
   [F:DSTB]MZSZON    = SAVMZSZON
   Raz SAVMZSZON
  Endif
  Write [F:DSTB]
  If fstat
   RRETOUR=30+fstat  # Erreur d'accès à la table des transactions détail (codes retour 31 à 35)
   Break
  Endif
 Endif
Next
Filter [AMZB]

End

######### Utilitaires de développement

$AFFICHE_TRS_INFOS
 Local Char LIGNE(120)
 LIGNE="==> Transaction "-PTRS : Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

$AFFICHE_MSK_STD
 Local Char LIGNE(120)
 LIGNE="----------------------------------------------" : Call ECR_TRACE(LIGNE,0)From GESECRAN
 LIGNE="Contenu de la fenêtre standard" : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE="" : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE="Nom masque / Visible" : Call ECR_TRACE(LIGNE,0) From GESECRAN
 For I_MSK=1 To NBR_STD_MSK
  LIGNE=MSK_STD_NAM(I_MSK-1)+"/"+mess(MSK_STD_VIS(I_MSK-1),1,1) : Call ECR_TRACE(LIGNE,0) From GESECRAN
 Next I_MSK
Return

$AFFICHE_MSK_TRS
 Local Char LIGNE(120)
 LIGNE="----------------------------------------------" : Call ECR_TRACE(LIGNE,0)From GESECRAN
 LIGNE="Contenu de la transaction "-PTRS : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE="" : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE="N° masque / Nom masque / Visible / Code action / Paramètre action" : Call ECR_TRACE(LIGNE,0) From GESECRAN
 For I_MSK=1 To NBR_TRS_MSK
  LIGNE=num$(MSK_TRS_ORD(I_MSK-1))+"/"
&      +MSK_TRS_NAM(I_MSK-1)+"/"
&      +mess(MSK_TRS_VIS(I_MSK-1),1,1)+"/"
&      +num$(MSK_TRS_ACT(I_MSK-1))+"/"
&      +num$(MSK_TRS_PAR(I_MSK-1))+"/"
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Next I_MSK
Return

$AFFICHE_CODACT
 LIGNE="----------------------------------------------" : Call ECR_TRACE(LIGNE,0)From GESECRAN
 Call ECR_TRACE("Codes actions sur les onglets :",0) From GESECRAN
 Call ECR_TRACE("0  -> Ne rien faire",0) From GESECRAN
 Call ECR_TRACE("1  -> Suppression",0) From GESECRAN
 Call ECR_TRACE("2  -> Déplacement",0) From GESECRAN
 Call ECR_TRACE("3  -> Création",0) From GESECRAN
Return

$AFFICHE_INFOS_MASK
 Local Char LIGNE(120)
 LIGNE="----------------------------------------------" : Call ECR_TRACE(LIGNE,0)From GESECRAN
 LIGNE=MSK_TRS_NAM(I_MSK-1)                             : Call ECR_TRACE(LIGNE,0)From GESECRAN
 LIGNE=""                                               : Call ECR_TRACE(LIGNE,0)From GESECRAN
Return

$AFFICHE_INFO_ZON
 Local Char LIGNE(120)
 LIGNE=""
Return

