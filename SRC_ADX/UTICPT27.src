#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTICPT27   Squelette pour Moulinette                      Module CPT   #
#                                                                        #                     
##########################################################################
#                                                                        #                     
# Initialisation du nouveau flag DUDCASFLG à "Oui"                       #
#   pour tous les types de pièces de type FACTURE                        #
#                                                                        #                     
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTICPT27:"-"Initialization 'DUDCASFLG' Field (GTYPACCENT Table)") From LECFIC

  Call MAJ_UTICPT27(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT27(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR
Local Integer OK

Call ECR_TRACE("UTICPT27 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:GTE])  = 0 : Local File =DOSSIER+".GTYPACCENT"   [GTE] : Endif
If clalev([F:ACV])  = 0 : Local File =DOSSIER+".ACTIV"        [ACV] : Endif

Read [ACV]CODACT="CASIN"
If !fstat & [F:ACV]FLACT=2

 Raz COMPTEUR
 Call DEBTRANS From GLOCK

 Trbegin [GTE]

 OK = 1
 Filter [GTE] Where DUDTYP=2 & DUDDATFLG=2 & (FUP=2 or DAS2=2) & (AUZJOU(0)=2 or AUZJOU(1)=2)
 For [GTE]GTE0 Where DUDCASFLG=0
  Readlock [GTE] Curr    
  If !fstat
   # --- alimentation des champs et réécriture enreg
   [F:GTE]DUDCASFLG = 2
   Rewrite [GTE]
   If !fstat 
    COMPTEUR += 1 
   Else
    OK = 0 : Call ECR_TRACE(mess(13,100,1)-"GTYPACCENT"-":"-[F:GTE]TYP,1) From GESECRAN
    Break
   Endif
  Endif
 Next
 Filter [GTE]

 Commit
Endif

Close Local File [GTE], [ACV]

Call ECR_TRACE("UTICPT27 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif 
#If [F:ADS]MODULE(N)<>2 : End : Endif                                    : # N= no module
If filinfo(filpath("FIL","GTYPACCENT","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= code table  
Call MAJ_UTICPT27(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
#If [F:ADS]MODULE(N)<>2 : End : Endif                                    : # N= no module
If filinfo(filpath("FIL","GTYPACCENT","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= code table  
Call MAJ_UTICPT27(APPLI)
End

