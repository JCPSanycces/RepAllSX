#<AdxTL>@(#)0.0.0.0 $Revision$Class Representation
# Supervisor
## ATY-ATYPE ## ESH
# 2018-11-09 07:14:15 249

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,CODREP,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char CODREP
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File ASHW [ASW]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".ASHW" [ASW]
Endif

Default File [F:ASW]
Read [F:ASW]ASW0 = [L]CODREP
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]CODREP)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]CODREP)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


