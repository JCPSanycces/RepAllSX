#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque GENHREXT3 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:26"
A_USER  = "DOC"
A_STAMP = "20181109230426"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "GRPNBR"
  If [M]GRPNBR=0
  Endif
 When "DFNNBR"
  If [M]DFNNBR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask GENHREXT3 [HREXE3]
Gosub HORODAT
Local Inpbox "GENHREXT3" From GFONCTION At A_STAMP With A_WINDPREV Mask [HREXE3] As [SIM_]
Grizo [HREXE3]10
Grizo [HREXE3]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HREXE3]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=13
X1(1)=1 : X2(1)=74 : Y1(1)=14 : Y2(1)=25
Return

$ON_GRPDTALVL
Onevent INIT_AREA Call D_GRPDTALVL(zc) From W1GENHREXT3
Onevent BEFORE_INPUT Call AS_GRPDTALVL(zc) From W1GENHREXT3
Return

Subprog D_GRPDTALVL(VALEUR)
Variable Integer VALEUR
If varinit([M]GRPDTALVL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_GRPDTALVL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_GRPDTACLC
Onevent BEFORE_INPUT Call AS_GRPDTACLC(zc) From W1GENHREXT3
Onevent CONTROL Call C_GRPDTACLC(zc) From W1GENHREXT3
Return

Subprog AS_GRPDTACLC(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1484,GBOUT1) From OBJDIV
Call TEXTE(27108,GBOUT2) From OBJDIV
Call TEXTE(29795,GBOUT3) From OBJDIV
If !GWEBSERV
 ## Action AFRIB
 Call IB_FORMULE From AFORMULE
 If mkstat=2
  [M]GRPDTACLC(INDIC) = VALEUR
  Affzo GRPDTACLC(INDIC) : mkstat = 2
 Endif
Endif
Onkey 129 Titled GBOUT1 Call B1_GRPDTACLC(zc) From W1GENHREXT3
Onkey 130 Titled GBOUT2 Call B2_GRPDTACLC(zc) From W1GENHREXT3
Onkey 131 Titled GBOUT3 Call B3_GRPDTACLC(zc) From W1GENHREXT3
Gosub _AFF
End

Subprog C_GRPDTACLC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFRCONT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFRCONT"
 PARMSK(1) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"AFRCONT","AFORMULE","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "GRPDTACLC" : GZNUM = 5935 : Endif
Endif
Gosub _AFF
End

Subprog B1_GRPDTACLC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFRB1
 Call B1_FORMULE(VALEUR,"","","","","") From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_GRPDTACLC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFFMESS
 Call AFFMESS From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_GRPDTACLC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ANAFOR
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ANAFOR"
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 Call TRAITE_CHAR(VALEUR,PARMSK,"","ANAFOR","ANAFOR",3,"") From GTRAITE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

