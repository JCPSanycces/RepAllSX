#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################################################
# Traitement de gestion de la saisie des contraintes qualité                   Module CRM 9 Avril 2003
#                d'un contrat de service
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "RAF"          : Gosub REFRESH
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer CON3ISDIRTY
Global Integer GPRECON3NOL
Global Integer GICON3JSAVED

  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  If !clalev([F:CQL]) : Local File CONTQUAL [CQL] : Endif
  CON3ISDIRTY = 0
  GPRECON3NOL = 0
  GICON3JSAVED = 0
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If CON3ISDIRTY Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
  #Menu Rafraichissement
  ETABOU(GRAFF) = 1
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  [M:CON3]CONNUM = PARAM(1)
  [M:CON3]TPL = val(PARAM(2))
  [M:CON3]CONCUR1 = PARAM(3)
  #Charge le tableau des niveaux de gravité
  Call LOADGRALEV
  #Charge les contraintes qualité du premier niveau de gravité
  Call LOADQUAL(0)
  Affzo [M:CON3]1-99
  # FGR 06/06/2012 : X3SUIVI60482 (début)
  If GCONSULT = 2 Then
    Diszo [M:CON3]
  Endif
  # FGR 06/06/2012 : X3SUIVI60482 (fin)
Return

##########################################################################################################
$REFRESH
  [M:CON3]CONNUM = PARAM(1)
  [M:CON3]TPL = val(PARAM(2))
  [M:CON3]CONCUR1 = PARAM(3)
  #Charge le tableau des niveaux de gravité
  Call LOADGRALEV
  #Charge les contraintes qualité du premier niveau de gravité
  Call LOADQUAL(0)
  Affzo [M:CON3]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:CON3]
  Kill CON3ISDIRTY
  Kill GPRECON3NOL
  Kill GICON3JSAVED
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
  CON3ISDIRTY = 1
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONOK
  Gosub ONSAVE
  FIN = 0
Return

#########################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONSAVE
Local Integer ITER

  Call SAVEMASK(GPRECON3NOL)
  #
  Call DEBTRANS From GLOCK
  Trbegin [CQL]
  Delete [CQL] Where [F:CQL]CONNUM = [M:CON3]CONNUM and [F:CQL]TPL = [M:CON3]TPL
  If fstat Then
    #L'enregistrement des contraintes qualité a échoué. Transaction abandonnée.
    Rollback
    GMESSAGE = mess(140,182,1)
    GERR = 1
  Else
    Commit
  Endif
  If GERR Then
    Return
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [CQL]
  For ITER = 0 To [M:CON3]NBGRA-1
    If [M:CON3]GRACOD(ITER) <> "" Then
      [F:CQL]CONNUM = [M:CON3]CONNUM
      [F:CQL]TPL = [M:CON3]TPL
      [F:CQL]GRALEV = [M:CON3]GRACOD(ITER)
      [F:CQL]ITTFCY = [M:CON3]ITTFCYX(ITER)
      [F:CQL]ITTDUR = [M:CON3]ITTDURX(ITER)
      [F:CQL]ITTDURBAS = [M:CON3]ITTDURBASX(ITER)
      [F:CQL]ITTDATEND = [M:CON3]ITTDATENDX(ITER)
      [F:CQL]ITTLTIMAX = [M:CON3]ITTLTIMAXX(ITER)
      [F:CQL]BASEXXITT = [M:CON3]BASEXXITTX(ITER)
      [F:CQL]SOLLTIMAX = [M:CON3]SOLLTIMAXX(ITER)
      [F:CQL]BASEXXSOL = [M:CON3]BASEXXSOLX(ITER)
      [F:CQL]AMTPLY = [M:CON3]AMTPLYX(ITER)
      [F:CQL]BASEXXAMT = [M:CON3]BASEXXAMTX(ITER)
      [F:CQL]OTHCNI = [M:CON3]OTHCNIX(ITER)
      Write [CQL]
      If fstat Then
        #L'enregistrement des contraintes qualité a échoué. Transaction abandonnée.
        GMESSAGE = mess(140,182,1)
        GERR = 1
        Rollback
        Break
      Endif
    Endif
  Next
  If GERR Then
    Return
  Endif
  Commit
  CON3ISDIRTY = 0
  ETABOU(GVALI) = 0
  GICON3JSAVED = 2
  Call LOADQUAL(GPRECON3NOL)
Return

##########################################################################################################
# Chargement de la liste des niveaux de gravité
#########################################################################
Subprog LOADGRALEV
Local Integer I

  Raz [M:CON3]NBGRA
  Raz [M:CON3]NBGRASEL
  Raz [M:CON3]GRACOD
  Raz [M:CON3]GRACODCLA
  Raz [M:CON3]ITTFCYX
  Raz [M:CON3]ITTDURX
  Raz [M:CON3]ITTDURBASX
  Raz [M:CON3]ITTDATENDX
  Raz [M:CON3]ITTLTIMAXX
  Raz [M:CON3]BASEXXITTX
  Raz [M:CON3]SOLLTIMAXX
  Raz [M:CON3]BASEXXSOLX
  Raz [M:CON3]AMTPLYX
  Raz [M:CON3]BASEXXAMTX
  Raz [M:CON3]OTHCNIX
  I = 0
  Filter [ADI] Where [F:ADI]NUMTAB = 428 Order By [F:ADI]CODE Asc
  For [ADI]
    If I >= dim([M:CON3]GRACOD) Then
      Break
    Endif
    If I = 0 Then
      [M:CON3]NBGRASEL(I) = "->"
    Else
      [M:CON3]NBGRASEL(I) = ""
    Endif
    [M:CON3]GRACOD(I) = [F:ADI]CODE
    Call LECTEXTRA([M:CON3]GRACODCLA(I), "ATABDIV", "LNGDES", "428", [F:ADI]CODE) From ATEXTRA
    Read [CQL]CQL0=[M:CON3]CONNUM;[M:CON3]TPL;[M:CON3]GRACOD(I)
    If !fstat Then
      [M:CON3]ITTFCYX(I) = [F:CQL]ITTFCY
      [M:CON3]ITTDURX(I) = [F:CQL]ITTDUR
      [M:CON3]ITTDURBASX(I) = [F:CQL]ITTDURBAS
      [M:CON3]ITTDATENDX(I) = [F:CQL]ITTDATEND
      [M:CON3]ITTLTIMAXX(I) = [F:CQL]ITTLTIMAX
      [M:CON3]BASEXXITTX(I) = [F:CQL]BASEXXITT
      [M:CON3]SOLLTIMAXX(I) = [F:CQL]SOLLTIMAX
      [M:CON3]BASEXXSOLX(I) = [F:CQL]BASEXXSOL
      [M:CON3]AMTPLYX(I) = [F:CQL]AMTPLY
      [M:CON3]BASEXXAMTX(I) = [F:CQL]BASEXXAMT
      [M:CON3]OTHCNIX(I) = [F:CQL]OTHCNI
    Endif
    I += 1
  Next
  Filter [ADI]
  [M:CON3]NBGRA = I
End

##########################################################################################################
# Chargement des contraintes qualité d'un niveau de gravité
#########################################################################
Subprog LOADQUAL(I)
Value Integer I

  Raz [M:CON3]ITTFCY
  Raz [M:CON3]ITTDUR
  Raz [M:CON3]ITTDURBAS
  Raz [M:CON3]ITTDATEND
  Raz [M:CON3]ITTLTIMAX
  Raz [M:CON3]BASEXXITT
  Raz [M:CON3]SOLLTIMAX
  Raz [M:CON3]BASEXXSOL
  Raz [M:CON3]AMTPLY
  Raz [M:CON3]BASEXXAMT
  Raz [M:CON3]OTHCNI
  [M:CON3]ITTFCY = [M:CON3]ITTFCYX(I)
  [M:CON3]ITTDUR = [M:CON3]ITTDURX(I)
  [M:CON3]ITTDURBAS = [M:CON3]ITTDURBASX(I)
  [M:CON3]ITTDATEND = [M:CON3]ITTDATENDX(I)
  [M:CON3]ITTLTIMAX = [M:CON3]ITTLTIMAXX(I)
  [M:CON3]BASEXXITT = [M:CON3]BASEXXITTX(I)
  [M:CON3]SOLLTIMAX = [M:CON3]SOLLTIMAXX(I)
  [M:CON3]BASEXXSOL = [M:CON3]BASEXXSOLX(I)
  [M:CON3]AMTPLY = [M:CON3]AMTPLYX(I)
  [M:CON3]BASEXXAMT = [M:CON3]BASEXXAMTX(I)
  [M:CON3]OTHCNI = [M:CON3]OTHCNIX(I)
  Gosub GRAYFIELDS
End

##########################################################################################################
# Transfert des infos du masque dans le tableau
#########################################################################
Subprog SAVEMASK(I)
Value Integer I

  [M:CON3]ITTFCYX(I) = [M:CON3]ITTFCY
  [M:CON3]ITTDURX(I) = [M:CON3]ITTDUR
  [M:CON3]ITTDURBASX(I) = [M:CON3]ITTDURBAS
  [M:CON3]ITTDATENDX(I) = [M:CON3]ITTDATEND
  [M:CON3]ITTLTIMAXX(I) = [M:CON3]ITTLTIMAX
  [M:CON3]BASEXXITTX(I) = [M:CON3]BASEXXITT
  [M:CON3]SOLLTIMAXX(I) = [M:CON3]SOLLTIMAX
  [M:CON3]BASEXXSOLX(I) = [M:CON3]BASEXXSOL
  [M:CON3]AMTPLYX(I) = [M:CON3]AMTPLY
  [M:CON3]BASEXXAMTX(I) = [M:CON3]BASEXXAMT
  [M:CON3]OTHCNIX(I) = [M:CON3]OTHCNI
End

##########################################################################################################
# Gestion du grisage des champs
#########################################################################
$GRAYFIELDS
  #Active ou désactive les durées d'intervention sur site
  #Interventions pour problèmes non bloquants
  If [M:CON3]ITTFCY = 2 Then
    Actzo [M:CON3]ITTDUR
    Actzo [M:CON3]ITTDURBAS
  Else
    [M:CON3]ITTDUR = 0
    [M:CON3]ITTDURBAS = 6
    Grizo [M:CON3]ITTDUR
    Grizo [M:CON3]ITTDURBAS
  Endif
  #Durée d'intervention pour pb non bloquants
  If [M:CON3]ITTDUR > 0 Then
    Actzo [M:CON3]ITTDURBAS
  Else
    [M:CON3]ITTDURBAS = 6
    Grizo [M:CON3]ITTDURBAS
  Endif
  Affzo [M:CON3]ITTDUR
  Affzo [M:CON3]ITTDURBAS
  #Active ou désactive les champs associés aux pénalités de retard
  #Pénalités pour problèmes non bloquants
  If [M:CON3]AMTPLY > 0 Then
    Actzo [M:CON3]CONCUR1
    Actzo [M:CON3]BASEXXAMT
  Else
    [M:CON3]BASEXXAMT = 6
    Grizo [M:CON3]CONCUR1
    Grizo [M:CON3]BASEXXAMT
  Endif
  Affzo [M:CON3]CONCUR1
  Affzo [M:CON3]BASEXXAMT
  #Active ou désactive les champs associés aux délais d'intervention
  #Délai d'intervention max pour problèmes non bloquants
  If [M:CON3]ITTLTIMAX > 0 Then
    Actzo [M:CON3]BASEXXITT
  Else
    [M:CON3]BASEXXITT = 6
    Grizo [M:CON3]BASEXXITT
  Endif
  Affzo [M:CON3]BASEXXITT
  #Délai de résolution max pour problèmes non bloquants
  If [M:CON3]SOLLTIMAX > 0 Then
    Actzo [M:CON3]BASEXXSOL
  Else
    [M:CON3]BASEXXSOL = 6
    Grizo [M:CON3]BASEXXSOL
  Endif
  Affzo [M:CON3]BASEXXSOL
Return

##########################################################################################################
# Met à jour les pénalités de retard suite à une modification de la devise du contrat.
#####################################################################################
Subprog UPDQUALCUR(SZOLDCUR, SZNEWCUR, ITPL)
Value Char SZOLDCUR
Value Char SZNEWCUR
Value Integer ITPL

Local Char SZSITE(GLONFCY)
Local Decimal IAMTPLY
Local Integer IERROR   # FGR 08/02/2010 : X3SUIVI60986

  IERROR = 0   # FGR 08/02/2010 : X3SUIVI60986
  SZSITE = ""
  IAMTPLY = 0
  #Obtient le site
  If ITPL = 2 Then
    SZSITE = func CRM_UTIL.GET_SITE_DEFAUT ("HDK", "")
  Else
    SZSITE = func CRM_UTIL.GET_SITE_DEFAUT ("HDK", [M:CON0]SALFCY)
  Endif
  If ITPL = 2 Then
    Filter [CQL] Where [F:CQL]CONNUM = [M:COT0]CONNUM and [F:CQL]TPL = 2
  Else
    Filter [CQL] Where [F:CQL]CONNUM = [M:CON0]CONNUM and [F:CQL]TPL <> 2
  Endif
  For [CQL]
    Call DEBTRANS From GLOCK
    Trbegin [CQL]
    IAMTPLY = [F:CQL]AMTPLY
    #
    Call SETCOVAMT(SZSITE, SZOLDCUR, SZNEWCUR, IAMTPLY, [F:CQL]AMTPLY) From SUBCOND
    #
    Rewrite [CQL]
    If fstat Then
      #Erreur lors de la conversion des montants relatifs aux pénalités de retard.
      GMESSAGE = mess(345,182,1)
      GERR = 1
      Rollback
      # FGR 08/02/2010 : X3SUIVI60986
      #End
      IERROR = 1
      Break
    Else
      Commit
    Endif
  Next
  Filter [CQL]
  If IERROR Then
    # FGR 08/02/2010 : X3SUIVI60986
    End
  Endif
End

##########################################################################################################
# Annulation de toutes les contraintes qualité pour un contrat.
############################################################
Subprog RAZQUAL(SZOBJTYP, SZCONNUM, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZOBJTYP
Value Char SZCONNUM
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IBDEBTRANSFLG

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [CQL]
  Endif
  #
  If SZOBJTYP = "CON" Then
    Delete [CQL] Where [F:CQL]CONNUM = SZCONNUM and [F:CQL]TPL <> 2
  Else
    Delete [CQL] Where [F:CQL]CONNUM = SZCONNUM and [F:CQL]TPL = 2
  Endif
  If fstat Then
    IBRETOUR = 0
    IERRINF = 614
    ICHAPTER = 177
    If IBDEBTRANSFLG = 0 Then
      Rollback
      End
    Endif
  Else
    If IBDEBTRANSFLG = 0 Then
      Commit
    Endif
  Endif
End
