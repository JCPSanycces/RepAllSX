#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
    Case [L]CURPRO
        When "TYP"    : Gosub PROPERTY_TYP
    Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

########################################################################################################################

#control and set propertys depending on the field type and the file type
$PROPERTY_TYP
    Case [L]ARULE
        When "CONTROL"
            If this.TYP = 4 and this.APARENT.FILTYP = 1
              ASTATUS = fmet this.ASETERROR("TYP", mess(83,7703,1), [V]CST_AERROR)  # 'Type ‘Constant’ not allowed for filetype MT940'
            Elsif (this.TYP = 2 or this.TYP = 3) and this.APARENT.FILTYP = 2
              ASTATUS = fmet this.ASETERROR("TYP", mess(84,7703,1), [V]CST_AERROR)  # 'Type is not allowed for filetype CSV'
            Elsif ( this.TYP = 2 or this.TYP = 3 ) and ( this.APARENT.FILTYP = 3 )
              ASTATUS = fmet this.ASETERROR("TYP", mess(196,7703,1), [V]CST_AERROR) #'Type is not allowed for filetype CAMT'
            Endif
        When "PROPAGATE"
            #angre
            If this.APARENT.FILTYP = 2
              Gosub SET_CSV_LINE_ATTRIBUTES
            Elsif this.APARENT.FILTYP = 3
              Gosub SET_CAMT_LINE_ATTRIBUTES
            Else

              Case this.TYP
                  When 1 : # Data
                      this.FLDIDT = ""
                      ASTATUS = fmet this.ASETATTRIBUTE("FLD", "$isMandatory", "true")
                      ASTATUS = fmet this.ASETATTRIBUTE("FLD", "$isDisabled", "false")
                      ASTATUS = fmet this.ASETATTRIBUTE("FLDIDT", "$isMandatory", "false")
                      ASTATUS = fmet this.ASETATTRIBUTE("FLDIDT", "$isDisabled", "true")
                  When 2 : # Segment ID
                      this.FLD = ""
                      ASTATUS = fmet this.ASETATTRIBUTE("FLD", "$isMandatory", "false")
                      ASTATUS = fmet this.ASETATTRIBUTE("FLD", "$isDisabled", "true")
                      ASTATUS = fmet this.ASETATTRIBUTE("FLDIDT", "$isMandatory", "true")
                      ASTATUS = fmet this.ASETATTRIBUTE("FLDIDT", "$isDisabled", "false")
                  When 3 : # Field ID
                      this.FLD = ""
                      ASTATUS = fmet this.ASETATTRIBUTE("FLD", "$isMandatory", "false")
                      ASTATUS = fmet this.ASETATTRIBUTE("FLD", "$isDisabled", "true")
                      ASTATUS = fmet this.ASETATTRIBUTE("FLDIDT", "$isMandatory", "true")
                      ASTATUS = fmet this.ASETATTRIBUTE("FLDIDT", "$isDisabled", "false")
              Endcase
            Endif
    Endcase
Return

$SET_CSV_LINE_ATTRIBUTES
  ASTATUS = fmet this.ASETATTRIBUTE("POS", "$isMandatory", "false")    # Position
  ASTATUS = fmet this.ASETATTRIBUTE("POS", "$isDisabled", "true")
  ASTATUS = fmet this.ASETATTRIBUTE("LNG", "$isMandatory", "false")    # Length
  ASTATUS = fmet this.ASETATTRIBUTE("LNG", "$isDisabled", "true")
  ASTATUS = fmet this.ASETATTRIBUTE("LNGTYP", "$isMandatory", "false") # Length type
  ASTATUS = fmet this.ASETATTRIBUTE("LNGTYP", "$isDisabled", "true")
  ASTATUS = fmet this.ASETATTRIBUTE("FLDIDT", "$isDisabled", "true")   # Identifier
  ASTATUS = fmet this.ASETATTRIBUTE("FLDOBY", "$isDisabled", "true")   # Mandatory
  ASTATUS = fmet this.ASETATTRIBUTE("CTL", "$isDisabled", "true")      # Control type > not yet used
Return


$SET_CAMT_LINE_ATTRIBUTES
  ASTATUS = fmet this.ASETATTRIBUTE("POS", "$isMandatory", "true")     # Position
  ASTATUS = fmet this.ASETATTRIBUTE("POS", "$isDisabled", "false")
  ASTATUS = fmet this.ASETATTRIBUTE("LNG", "$isMandatory", "false")    # Length
  ASTATUS = fmet this.ASETATTRIBUTE("LNG", "$isDisabled", "true")
  ASTATUS = fmet this.ASETATTRIBUTE("LNGTYP", "$isMandatory", "false") # Length type
  ASTATUS = fmet this.ASETATTRIBUTE("LNGTYP", "$isDisabled", "true")
  ASTATUS = fmet this.ASETATTRIBUTE("FLDIDT", "$isDisabled", "true")   # Identifier
  ASTATUS = fmet this.ASETATTRIBUTE("FLDOBY", "$isDisabled", "true")   # Mandatory
  ASTATUS = fmet this.ASETATTRIBUTE("CTL", "$isDisabled", "true")      # Control type > not yet used
Return

$SET_MT940_LINE_ATTRIBUTES
  ASTATUS = fmet this.ASETATTRIBUTE("POS", "$isMandatory", "true")     # Position
  ASTATUS = fmet this.ASETATTRIBUTE("POS", "$isDisabled", "false")
  ASTATUS = fmet this.ASETATTRIBUTE("LNG", "$isMandatory", "true")     # Length
  ASTATUS = fmet this.ASETATTRIBUTE("LNG", "$isDisabled", "false")
  ASTATUS = fmet this.ASETATTRIBUTE("LNGTYP", "$isMandatory", "true")  # Length type
  ASTATUS = fmet this.ASETATTRIBUTE("LNGTYP", "$isDisabled", "false")
  ASTATUS = fmet this.ASETATTRIBUTE("FLDIDT", "$isDisabled", "false")  # Identifier
  ASTATUS = fmet this.ASETATTRIBUTE("FLDOBY", "$isDisabled", "false")  # Mandatory
  ASTATUS = fmet this.ASETATTRIBUTE("CTL", "$isDisabled", "true")      # Control type > not yet used
Return


########################################################################################################################

