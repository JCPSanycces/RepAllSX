#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TRAP 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:15:56"
A_USER  = "DOC"
A_STAMP = "20181109231556"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask TRAP [TRAP]
Gosub HORODAT
Local Inpbox "TRAP" From GFONCTION At A_STAMP With A_WINDPREV Mask [TRAP] As [SIM_]
Grizo [TRAP]5
Grizo [TRAP]10
Grizo [TRAP]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [TRAP]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=17 : X2(0)=96 : Y1(0)=7 : Y2(0)=10
X1(1)=17 : X2(1)=96 : Y1(1)=11 : Y2(1)=17
X1(2)=17 : X2(2)=96 : Y1(2)=18 : Y2(2)=21
Return

$ON_CPY
Return

$ON_ZCPY
Onevent BEFORE_AREA Gosub AV_ZCPY From W1TRAP
Return

$AV_ZCPY
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",num$([M]CPY(indice)),"") From CONTOBJ
zc = [F:CPY]CPYNAM
Gosub _AFF
Return

$ON_DATDEB
Onevent BEFORE_AREA Gosub AV_DATDEB From W1TRAP
Return

$AV_DATDEB
Chgfmt [M]DATDEB(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_DATFIN
Onevent BEFORE_AREA Gosub AV_DATFIN From W1TRAP
Return

$AV_DATFIN
Chgfmt [M]DATFIN(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_SUBMITTER
Onevent INIT_AREA Call D_SUBMITTER(zc) From W1TRAP
Onevent BEFORE_INPUT Call AS_SUBMITTER(zc) From W1TRAP
Return

Subprog D_SUBMITTER(VALEUR)
Variable Integer VALEUR
If varinit([M]SUBMITTER,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SUBMITTER(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

