## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "NOREC" : GZNUM = 26811 : Endif
If !mkstat
 ## Action STD
 Call C_NOREC(VALEUR) From TRAP
 If mkstat : GERR = 1 : GZONE = "NOREC" : GZNUM = 26811 : Endif
Endif
Gosub _AFF
End

$CHG_STY
Return


