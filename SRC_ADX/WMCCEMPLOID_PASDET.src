####################################################################
# _ACONTROL
####################################################################

$_ACONTROL
Gosub _AMANDATORY     : [L]ASTATUS = max([L]ASTATUS,[L]ALLSTAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AFORMAT        : [L]ASTATUS = max([L]ASTATUS,[L]ALLSTAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS        : [L]ASTATUS = max([L]ASTATUS,[L]ALLSTAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

####################################################################
# MANDATORY
####################################################################

$_AMANDATORY
Gosub DECLARE_VAR From WMC0EMPLOID_PASDET
Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AMANDATORY_PASCRY From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AMANDATORY_PASNUM From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AMANDATORY_PASDTE From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AMANDATORY_PLCISS From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AMANDATORY_ISSAUZ From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AMANDATORY_EXPDAT From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AMANDATORY_ETRPITTYP From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AMANDATORY_ETRPITDAT From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AMANDATORY_ETRPITEXPDAT From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AMANDATORY_ESSUIDPAS From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AMANDATORY_PASDATNEW From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AMANDATORY_PASDATAMD From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
Return

####################################################################
# FORMAT
####################################################################

$_AFORMAT
Gosub DECLARE_VAR From WMC0EMPLOID_PASDET
Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_PASCRY From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_PASNUM From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_PASDTE From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_PLCISS From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_ISSAUZ From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_EXPDAT From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_ETRPITTYP From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_ETRPITDAT From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_ETRPITEXPDAT From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_ESSUIDPAS From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_PASDATNEW From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_PASDATAMD From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
Return

####################################################################
# OTHERS
####################################################################

$_AOTHERS
Gosub DECLARE_VAR From WMC0EMPLOID_PASDET
Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_PASCRY From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_PASCRY From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_PASNUM From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_PASNUM From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_PASDTE From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_PASDTE From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_PLCISS From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_PLCISS From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_ISSAUZ From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_ISSAUZ From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_EXPDAT From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_EXPDAT From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_ETRPITTYP From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_ETRPITTYP From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_ETRPITDAT From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_ETRPITDAT From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_ETRPITEXPDAT From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_ETRPITEXPDAT From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_ESSUIDPAS From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_ESSUIDPAS From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_PASDATNEW From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_PASDATNEW From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_PASDATAMD From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_PASDATAMD From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT :  Endif
[L]ASTATUS = fmet this.ACONTROL
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



