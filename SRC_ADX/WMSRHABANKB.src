$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 23741: RES='Banques (guichets)'
   When 263: RES='Pays'
   When 7475: RES='Banque'
   When 23740: RES='Domiciliation'
   When 7415: RES='Code BIC'
  Endcase
 When "ENG":
  Case _ID
   When 23741: RES='Bank sort codes'
   When 263: RES='Country'
   When 7475: RES='Bank'
   When 23740: RES='Paying bank'
   When 7415: RES='BIC code'
  Endcase
 When "ITA":
  Case _ID
   When 23741: RES='Banche (agenzie)'
   When 263: RES='Paese'
   When 7475: RES='Banca'
   When 23740: RES='Domiciliazione'
   When 7415: RES='Codice BIC'
  Endcase
 When "POR":
  Case _ID
   When 23741: RES='Bancos (agências)'
   When 263: RES='País'
   When 7475: RES='Banco'
   When 23740: RES='Domiciliação'
   When 7415: RES='Código'
  Endcase
 When "SPA":
  Case _ID
   When 23741: RES='Bancos (sucursales)'
   When 263: RES='País'
   When 7475: RES='Banco'
   When 23740: RES='Domiciliación'
   When 7415: RES='Código BIC'
  Endcase
 When "BRI":
  Case _ID
   When 23741: RES='Bank  (counter)'
   When 263: RES='Country'
   When 7475: RES='Bank'
   When 23740: RES='Domicile'
   When 7415: RES='BIC code'
  Endcase
 When "GER":
  Case _ID
   When 23741: RES='Bankleitzahlen'
   When 263: RES='Land'
   When 7475: RES='Bank'
   When 23740: RES='Adresse'
   When 7415: RES='BIC'
  Endcase
 When "POL":
  Case _ID
   When 23741: RES='Banki (okienka)'
   When 263: RES='Kraj'
   When 7475: RES='Bank'
   When 23740: RES='Oddział'
   When 7415: RES='BIC'
  Endcase
 When "CHI":
  Case _ID
   When 23741: RES='银行(柜台)'
   When 263: RES='国家'
   When 7475: RES='银行'
   When 23740: RES='住址'
   When 7415: RES='BIC代码'
  Endcase
 When "ARB":
  Case _ID
   When 23741: RES='المصارف (الفروع)ّ'
   When 263: RES='البلد'
   When 7475: RES='البنك'
   When 23740: RES='توطين'
   When 7415: RES='BIC رمز'
  Endcase
Endcase
Return
