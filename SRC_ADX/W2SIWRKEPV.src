#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SIWRKEPV 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_XVTAX
Return

$ON_XVTYP
Onevent INIT_AREA Call D_XVTYP(zc) From W2SIWRKEPV
Return

Subprog D_XVTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]XVTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_VACITM
Return

$ON_INVDTA
Return

$ON_INVDTATYP
Onevent INIT_AREA Call D_INVDTATYP(zc) From W2SIWRKEPV
Return

Subprog D_INVDTATYP(VALEUR)
Variable Integer VALEUR
If varinit([M]INVDTATYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_INVDTADSP
Return

$ON_INVDTACOD
Onevent INIT_AREA Call D_INVDTACOD(zc) From W2SIWRKEPV
Return

Subprog D_INVDTACOD(VALEUR)
Variable Integer VALEUR
If varinit([M]INVDTACOD,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$TIT_COL
Gosub TIT_COL From W3SIWRKEPV
Return


