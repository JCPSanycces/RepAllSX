#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################################
## Gestion des ordres de paiements et récibos :
## Saisie de données complémentaires liés au mode de règlements
#############################################################################
# Issue X3-107197 - 2018-09-12 by CBO : PARAMETER AND ACTIVITY CODE

GBIDI1 = 1
Call OBJET("PAH",GBIDC1,GBIDC2) From GOBJET
End

$ACTION

Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub OK
 When "END"         : Gosub FIN
 When "FINSAI"      : Gosub FINSAI
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "FIN_LISTE"   : Gosub FIN_LISTE
Endcase
Return


$OUVRE
If clalev([F:PYH])=0 : Local File PAYMENTH  [PYH] : Endif
If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
If clalev([F:TAM])=0 : Local File TABPAM    [TAM] : Endif
Global Char    GPAM(GLONTAM)
Global Integer GNOL
GPAM = PARAM(2)
GNOL = val(PARAM(3))
Return

$DEBUT
GPAM = PARAM(2)
GNOL = val(PARAM(3))
Raz [M:PPM]
If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
Call LECTURE("BPR",[M:PAH0]BPR,"") From CONTOBJ
[M:PPM]CRY = [F:BPR]CRY
If [M:PAH1]BAN(GNOL)<>"" | [M:PAH1]CAISSE(GNOL)<>""
 [M:PPM]BAN    = [M:PAH1]BAN(GNOL)
 [M:PPM]CAISSE = [M:PAH1]CAISSE(GNOL)
 [M:PPM]CHQNUM = [M:PAH1]CHQNUM(GNOL)
 [M:PPM]CHQBAN = [M:PAH1]CHQBAN(GNOL)
 [M:PPM]SENDAT = [M:PAH1]SENDAT(GNOL)
 [M:PPM]DUDDAT = [M:PAH1]DUDDAT(GNOL)
 [M:PPM]SENCRN = [M:PAH1]SENCRN(GNOL)
 [M:PPM]SENORI = [M:PAH1]SENORI(GNOL)
 If dim([M:PPM]PAYNUMEND)>0
  [M:PPM]SENBPR     = [M:PAH1]SENBPR(GNOL)
  [M:PPM]PAYNUMEND  = [M:PAH1]PAYNUMEND(GNOL)
  [M:PPM]CURPAYEND  = [M:PAH1]CUR(GNOL)
  [M:PPM]AMTPAYEND  = [M:PAH1]AMTLIN(GNOL)
  [M:PPM]AMTPAYEND2 = [M:PAH1]AMTLIN2(GNOL)
 Endif
 Affzo [M:PPM]
Endif
Return

$OK
[M:PAH1]BAN(GNOL)    = [M:PPM]BAN
[M:PAH1]CAISSE(GNOL) = [M:PPM]CAISSE
[M:PAH1]CHQNUM(GNOL) = [M:PPM]CHQNUM
[M:PAH1]SENDAT(GNOL) = [M:PPM]SENDAT
[M:PAH1]CHQBAN(GNOL) = [M:PPM]CHQBAN
[M:PAH1]DUDDAT(GNOL) = [M:PPM]DUDDAT
[M:PAH1]SENCRN(GNOL) = [M:PPM]SENCRN
[M:PAH1]SENORI(GNOL) = [M:PPM]SENORI
If dim([M:PPM]PAYNUMEND)>0
 [M:PAH1]SENBPR(GNOL) = [M:PPM]SENBPR
 [M:PAH1]PAYNUMEND(GNOL) = [M:PPM]PAYNUMEND
 [M:PAH1]CUR(GNOL)       = [M:PPM]CURPAYEND
 [M:PAH1]AMTLIN(GNOL)    = [M:PPM]AMTPAYEND
 [M:PAH1]AMTLIN2(GNOL)   = [M:PPM]AMTPAYEND2
 Affzo [M:PAH1]CUR(GNOL) : Affzo [M:PAH1]AMTLIN(GNOL) : Affzo [M:PAH1]AMTLIN2(GNOL)
Endif
Return


$FIN
Return

$FINSAI
Return


$SEL_LISTE
Case GACTION
 When "GSELLIS"
  Case COUZON
   When "PAYNUMEND" : Gosub S_PAYNUMEND
  Endcase
 When "SELCHQNUM"   : Gosub S_CHQNUM
Endcase
Return

$FIN_LISTE
Case GACTION
 When "GSELLIS"
  Case COUZON
   When "PAYNUMEND" : Gosub F_PAYNUMEND
  Endcase
 Endcase
Return

$S_PAYNUMEND
If clalev([F:PYH])=0 : Local File PAYMENTH  [PYH] : Endif
If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
Local Integer K, I : K=dim(TEX)-1
Local Char    TABPAYTYP(GLONTPY)(1..99)
Local Integer NBTAB
NBTAB = 0
## Le règlement (client) endossé doit :
##    - être porté sur une transaction flaguée 'Endossement autorisé' et qui comporte
##      une étape de comptabilisation portefeuille
##    - doit être mis en portefeuille (compte client soldé)
##    - ne doit pas être remis en banque
##    - ne doit pas être déjà endossé
For [TPY]TPY0 Where FLGEND = 2
 NBTAB += 1
 TABPAYTYP(NBTAB) = [F:TPY]PAYTYP
Next
For [PYH]PYH0 Where find(PAYTYP,TABPAYTYP(1..NBTAB)) & FLGEND<>2 & SNS=2 & BPR=[M:PPM]SENBPR & STAFLG(8)<>2 & STAFLG(2)=2
 If NBTEX+1>K : Break : Endif
 NBTEX += 1
 TEXTE(NBTEX) = format$("K:30X",[F:PYH]NUM)+" "+[F:PYH]BPR
 TEX(NBTEX)   = [F:PYH]NUM
Next
Return

$F_PAYNUMEND
Local Char    CURLIN2(GLONCUR)
Local Integer INIT, NOLI
If VALEUR<>""
 If clalev([F:PYH])=0 : Local File PAYMENTH [PYH] : Endif
 If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
 Read [PYH]PYH0 = VALEUR
 If !fstat
  Call LECTURE("BPR",[F:PYH]BPR,"") From CONTOBJ
  [M:PPM]CRY = [F:BPR]CRY
  # Issue X3-107197
  If [M:PAH0]TYP = 1 & func AFNC.ACTIV("KAG") and func AFNC.PARAM("ARGCHQ",[F:PYH]CPY)="2" &
&   [M:PPM]CHQNUM<>"" & [M:PPM]SENORI="" : # Cas où le mode de règlement est passé de 'chèque' à 'chèque tiers' (endoss)
   If clalev([F:CHN])=0 : Local File CHQNUM [CHN] : Endif
   Local Char OLDCHE(20), NEWCHE(20)      : # => il faut dans ce cas remettre le chèque à l'état 'Disponible'
   OLDCHE = [M:PPM]CHQNUM
   NEWCHE = ""
   Call DEBTRANS From GLOCK
   Gosub TR_CHN
  Endif
  [M:PPM]CHQNUM = [F:PYH]CHQNUM
  [M:PPM]SENCRN = [F:PYH]SENCRN
  [M:PPM]SENORI = [F:PYH]SENORI
  [M:PPM]CURPAYEND  = [F:PYH]CUR
  [M:PPM]AMTPAYEND  = [F:PYH]AMTCUR
  [M:PPM]AMTPAYEND2 = [F:PYH]AMTCUR
  Gosub INI_AMTLIN2
 Endif
Endif
zonsui = "SENDAT" : mkstat = 2
Return


$S_CHQNUM
## Sélection des chèques disponibles associés à la banque : sélection appelée uniquement en gestion des ordres de paiements
## et si le code activités CHQ (Gestion des chèquiers) est actif
If clalev([F:CHN])=0 : Local File CHQNUM  [CHN] : Endif
Local Integer K, I : K=dim(TEX)-1
For [CHN]CHN0 Where BAN = [M:PPM]BAN & STA = 1
 If NBTEX+1>K : Break : Endif
 NBTEX += 1
 TEXTE(NBTEX) = format$("K:20X",[F:CHN]CHQNUM)+" "+[F:CHN]BAN
 TEX(NBTEX)   = [F:CHN]CHQNUM
Next
Return


$INI_AMTLIN2
## - [M]CUR contient la devise de la ligne de règlement
## - [M]CURLIN2 contient la devise des échéances règlées : on s'est fixé la règle que toutes les échéances de l'ordre
## de paiement ou récibo devaient être associées à la même devise
If [M:PAH1]CURVCR(0)<>"" : CURLIN2 = [M:PAH1]CURVCR(0) : Endif
If [M:PPM]CURPAYEND = CURLIN2
 # Devise règlement=devise échéances... => les montants sont identiques(cas simple)
 [M:PPM]AMTPAYEND2 = [M:PPM]AMTPAYEND : INIT = 1
Elsif [M:PPM]CURPAYEND = [M:PAH1]CURCPY & find([M:PPM]AMTPAYEND,[M:PAH1]AMTLOCLIN(0..[M:PAH1]NBDOC-1))
 # Devise règlement=devise société et montant règlement=montant d'une échéance en dev société
 # => Si le montant du règlement est égal au montant d'une ligne d'imputation des documents appliqués en devise société
 # (AMTLOCLIN = montant échéance +/- esc/agio) alors on peut initialiser le montant imputé tiers par le montant
 # de l'échéance +/- l'escompte
 NOLI = find([M:PPM]AMTPAYEND,[M:PAH1]AMTLOCLIN(0..[M:PAH1]NBDOC-1))
 [M:PPM]AMTPAYEND2 = [M:PAH1]AMTVCR(NOLI-1)-[M:PAH1]AMTDEP(NOLI-1)
 INIT = 1
Elsif [M:PPM]CURPAYEND = GCURSHR & find([M:PPM]AMTPAYEND,[M:PAH1]AMTRPTLIN(0..[M:PAH1]NBDOC-1))
 # Devise règlement=devise reporting et montant règlement=montant d'une échéance en dev société
 NOLI = find([M:PPM]AMTPAYEND,[M:PAH1]AMTRPT(0..[M:PAH1]NBDOC-1))
 [M:PPM]AMTPAYEND2 = [M:PAH1]AMTVCR(NOLI-1)-[M:PAH1]AMTDEP(NOLI-1)
 INIT = 1
Endif
If !INIT
 Call CONVERT([M:PPM]CURPAYEND,CURLIN2,[M:PAH1]CURCPY,1,[M:PAH0]DAT,[M:PPM]AMTPAYEND,[M:PPM]AMTPAYEND2,STAT) From TRTDEV
 If STAT : # Pas de cours de devises CUR -> CURLIN2 (DAT)
  GMESSAGE=mess(16,114,1)-[M:PPM]CURPAYEND-"->"-CURLIN2-"("+format$("D:"+GFMDAT,[M:PAH0]DAT)-")"
  mkstat=2 : End
 Endif
Endif
Return

######################################################################################
## Etiquette liée aux écrans PAYPTHPAM et PAYORDPAM (données complémentaires aux
## modes de règlements)
######################################################################################
Subprog AS_BAN(VALEUR)
Variable Char    VALEUR()
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
Call LEC_TAM(GCURLEG, GPAM) From CPTLEC
If !fstat & find([F:TAM]TYP,1) : # banque NON saisissable si mode règlement = Espèces
 mkstat = 1 : End
Endif
End

Subprog D_BAN(VALEUR)
Variable Char     VALEUR
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:CAC])=0 : Local File GACCCODE   [CAC] : Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:BAN])=0 : Local File BANK       [BAN] : Endif

Local Char    COLL(GLONSAC), INTERM(GLONGAC), COMPTE(GLONGAC), CODCPT(GLONCAC)
Local Libelle BPRTYP
Local Integer I
For I=0 To [M:PAH1]NBDOC-1
 If [M:PAH1]DUDNUM(I)<>0
  Read [DUD]DUD1 = DUDNUM(I);DUDLIG(I)
  If !fstat
   COLL = [F:DUD]SAC
   Break
  Endif
 Endif
Next
If COLL = ""
 Case [M:PAH0]TYP
  When 1
   Call LECTURE("BPS",[M:PAH0]BPR,"") From CONTOBJ
   Call INIT_COMPTE([M:PAH0]BPR,[M:PAH0]CPY,"F",CODCPT) From CPTSUB
   If [L]CODCPT<>""
    Call LECTURE("CAC",[L]CODCPT,"3~"+GPLAN(1)) From CONTOBJ
    INTERM = [F:CAC]ACC(0)
   Endif
   If INTERM<>""
    Call LECTURE("GAC",INTERM,GPLAN(1)) From CONTOBJ
    If !fstat & [F:GAC]SAC=2
     COLL = [F:GAC]ACCSHO
    Else
     COLL = ""
    Endif
   Endif
  When 2
   Call LECTURE("BPC",[M:PAH0]BPR,"") From CONTOBJ
   Call INIT_COMPTE([M:PAH0]BPR,[M:PAH0]CPY,"F",CODCPT) From CPTSUB
   If [L]CODCPT<>""
    Call LECTURE("CAC",[L]CODCPT,"2~"+GPLAN(1)) From CONTOBJ
    INTERM = [F:CAC]ACC(0)
   Endif
   If INTERM<>""
    Call LECTURE("GAC",INTERM,GPLAN(1)) From CONTOBJ
    If !fstat & [F:GAC]SAC=2
     COLL = [F:GAC]ACCSHO
    Else
     COLL = ""
    Endif
   Endif
 Endcase
Endif

Read [GAC]GAC1 = GPLAN(1);COLL
If !fstat
 COMPTE = [F:GAC]ACC
Endif

Call CLIFOU([M:PAH0]BPR,GPLAN(1),COMPTE,[M:PAH0]TYP,[L]BPRTYP) From PAYDIV
If [M:PAH0]BPR<>""
 If [L]BPRTYP=1
  Call LECTURE("BPC",[M:PAH0]BPR,"") From CONTOBJ
  VALEUR=[F:BPC]PAYBAN
 Else
  Call LECTURE("BPS",[M:PAH0]BPR,"") From CONTOBJ
  VALEUR=[F:BPS]PAYBAN
 Endif
 Gosub VERF_BAN
Endif
If VALEUR="" :
 VALEUR=GBANDEF : Gosub VERF_BAN
 If VALEUR=""
  Call LECTURE("FCY",[M:PAH0]FCY,"") From CONTOBJ
  VALEUR=[F:FCY]PAYBAN : Gosub VERF_BAN
 Endif
Endif
End


$VERF_BAN
If VALEUR<>""
 Call LECTURE("BAN",VALEUR,"") From CONTOBJ
 If [F:BAN]CPY<>"" & [M:PAH0]CPY<>[F:BAN]CPY
  VALEUR=""
 Elsif [F:BAN]FCY<>"" & [M:PAH0]FCY<>[F:BAN]FCY
  VALEUR=""
 Elsif dim([F:BAN]ACS)>0 & [F:BAN]ACS<>""
  Call CONTEXE([F:BAN]ACS) From CPTSUB
  If mkstat : GMESSAGE="" : VALEUR="" : mkstat=0 : Endif
 Endif
Endif
Return


Subprog C_BAN(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
 If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
 Raz [F:BAN] : # si par tunnel, on a changé la devise de banque
 Call LECTURE("BAN",VALEUR,"") From CONTOBJ
 If [F:BAN]FCY<>"" & [M:PAH0]FCY<>[F:BAN]FCY
  # Banque/Caisse du site FCY
  GMESSAGE=mess(1,653,1)-mess(4,117,1)-[F:BAN]FCY : mkstat=2 : End
 Elsif [F:BAN]CPY<>"" & [M:PAH0]CPY<>[F:BAN]CPY
  # Banque/Caisse de la société CPY
  GMESSAGE=mess(1,653,1)-mess(5,117,1)-[F:BAN]CPY : mkstat=2 : End
 Elsif dim([F:BAN]ACS)>0 & [F:BAN]ACS<>""
  Call CONTEXE([F:BAN]ACS) From CPTSUB
  If mkstat : End : Endif
 Endif
 Call CONTDEV([F:BAN]CUR,[M:PAH0]DAT) From TRTDEV
 If fstat | mkstat : End : Endif
 If [M:PAH1]CUR(GNOL)<>"" & VALEUR<>[M:PPM]BAN
  Call CONTBAN([M:PAH0]DAT,VALEUR,[M:PAH1]CUR(GNOL)) From CPTSUB
 Endif
Endif
End

Subprog AS_CAISSE(VALEUR)
Variable Char    VALEUR()
Call LEC_TAM(GCURLEG, GPAM) From CPTLEC
If !fstat & !find([F:TAM]TYP,1) : # caisse saisissable ssi mode règlement = Espèces
 mkstat = 1 : End
Endif
End

Subprog C_CAISSE(VALEUR)
Variable Char    VALEUR()
Call C_BAN(VALEUR)
End

Subprog AM_CAISSE(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Grizo BAN, CHQNUM, CRDTYP, CRDNUM, SENDAT, DUDDAT, SENCRN, SENORI
 If dim([M:PPM]PAYNUMEND)>0
  Grizo SENBPR, PAYNUMEND
 Endif
Else
 Actzo BAN, CHQNUM, CRDTYP, CRDNUM, SENDAT, DUDDAT, SENCRN, SENORI
 If dim([M:PPM]PAYNUMEND)>0
  Grizo SENBPR, PAYNUMEND
 Endif
Endif
End

Subprog AS_CHQBAN(VALEUR)
Variable Char    VALEUR()
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
## Type de carte saisissable dans le cas des modes de règlements :
##    - Chèques (type 2)
##    - Chèques diférés (type 3)
Call LEC_TAM(GCURLEG, GPAM) From CPTLEC
If !fstat & !find([F:TAM]TYP,2,3)
 mkstat = 1 : End
Endif
End


Subprog AS_CRDTYP(VALEUR)
Variable Char    VALEUR()
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
## Type de carte saisissable dans le cas des modes de règlements :
##    - Tarjetas (type 5)
Call LEC_TAM(GCURLEG, GPAM) From CPTLEC
If !fstat & !find([F:TAM]TYP,5)
 mkstat = 1 : End
Endif
End


Subprog AS_CRDNUM(VALEUR)
Variable Char    VALEUR()
## N° carte saisissable dans le cas des modes de règlements :
##    - Tarjetas (type 5)
Call LEC_TAM(GCURLEG, GPAM) From CPTLEC
If !fstat & !find([F:TAM]TYP,5)
 mkstat = 1 : End
Endif
End

Subprog C_CRDNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : Call CONTCB([M]CRDTYP,VALEUR) From CONTNUM : Endif
End


Subprog AS_CHQNUM(VALEUR)
Variable Char    VALEUR()
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
## Côté ordres de paiements : N° chèque saisissable dans le cas des modes de règlements :
##    - Cheques al dia (type 2)
##    - Cheques diferidos (type 3). (Pour les chèques de tiers, le n° chèque du règlement client endossé
##                                   est repris...)
## Côté récibos : N° chèque saisissable dans le cas des modes de règlements :
##    - Cheques al dia (type 2)
##    - Cheques diferidos (type 3)
##    - Cheques de tiers (type 4)
Call LEC_TAM(GCURLEG, GPAM) From CPTLEC
If !fstat
 If [M:PAH0]TYP = 1 : # Ordre de paiements
  If !find([F:TAM]TYP,2,3,4)
   mkstat = 1 : End
   If [M:PPM]CHQNUM<>"" &  dim([M:PPM]PAYNUMEND)>0 & [M:PPM]PAYNUMEND=""
    Local Char OLDCHE(20), NEWCHE(20)
    OLDCHE = [M:PPM]CHQNUM
    NEWCHE = ""
    Call DEBTRANS From GLOCK
    Gosub TR_CHN
   Endif
  Elsif find([F:TAM]TYP,4) & VALEUR<>"" : # Chèque initialisé par rapport au règlement X3 endossé
   mkstat = 2 : End
  Endif
 Elsif [M:PAH0]TYP = 2 : # récibos
  If !find([F:TAM]TYP,2,3,4)
   mkstat = 1 : End
  Endif
 Endif
Endif
End

Subprog D_CHQNUM(VALEUR)
Variable Char    VALEUR()
If clalev([F:CHN])=0 : Local File CHQNUM [CHN] : Endif
Filter [CHN] Where BAN = [M:PPM]BAN & STA=1
Read [CHN]CHN0 First
Filter [CHN]
If !fstat
 VALEUR = [F:CHN]CHQNUM
Endif
End

Subprog C_CHQNUM(VALEUR)
Variable Char    VALEUR()
# Issue X3-107197
If VALEUR<>"" & [M:PAH0]TYP = 1 & func AFNC.ACTIV("KAG") and func AFNC.PARAM("ARGCHQ",[M:PAH0]CPY)="2" : # Gestion des chèquiers => On contrôle que le chèque existe...
 If clalev([F:CHN])=0 : Local File CHQNUM [CHN] : Endif
 Read [CHN]CHN0 = [M:PPM]BAN ; VALEUR
 If fstat
  ## Chèque inexistant
  GMESSAGE = mess(216,117,1)
  mkstat = 2 : End
 Elsif [F:CHN]STA>1 & [F:CHN]PAYORDNUM<>[M:PAH0]NUM
  ## Chèque utilisé/annulé/validé
  GMESSAGE = mess([F:CHN]STA,2658,1)
  mkstat = 2 : End
 Endif
 ## Ecriture dans la table des chèques => Maj de l'état du chèque (si paiement par chèque) pour le mettre à l'état 'Utilisé'
 If dim([M:PPM]PAYNUMEND)>0 & [M:PPM]PAYNUMEND="" : # Si endoss, le n° de chèque est celui du client...
  Gosub MAJ_CHN
 Endif
Endif
End


Subprog AM_CHQNUM(VALEUR)
Variable Char    VALEUR()
End

$MAJ_CHN
Local Char OLDCHE(20), NEWCHE(20)
OLDCHE = [M:PPM]CHQNUM
NEWCHE = VALEUR
Call DEBTRANS From GLOCK
Gosub TR_CHN
Return


$TR_CHN
Trbegin [CHN]
 ## L'ancien chèque est flagué 'Disponible'
 If OLDCHE<>""
  Readlock [CHN]CHN0 = [M:PPM]BAN;OLDCHE
  If fstat=1
   GOK=-1 : GLOCK="$CHQNUM"-[M:PPM]BAN-OLDCHE : Goto ROLL_TR_CHN
  Elsif fstat
   GOK=0 : Call RSTA("CHN",[M:PPM]BAN-OLDCHE) From GLOCK : Goto AB_TR_CHN
  Elsif !fstat
   [F:CHN]STA = 1
   [F:CHN]PAYORDNUM = ""
   Rewrite [CHN]
   If fstat
    GOK=0 : Call FSTA("CHN") From GLOCK : Goto AB_TR_CHN
   Endif
   If   GOK<0 : Goto ROLL_TR_CHN
   Elsif !GOK : Goto AB_TR_CHN
   Endif
  Endif
 Endif
 ## Le nouveau chèque est flagué 'Utilisé'
 If NEWCHE<>""
  Readlock [CHN]CHN0 = [M:PPM]BAN;NEWCHE
  If fstat=1
   GOK=-1 : GLOCK="$CHQNUM"-[M:PPM]BAN-NEWCHE : Goto ROLL_TR_CHN
  Elsif fstat
   GOK=0 : Call RSTA("CHN",[M:PPM]BAN-NEWCHE) From GLOCK : Goto AB_TR_CHN
  Elsif !fstat
   [F:CHN]STA = 2
   [F:CHN]PAYORDNUM = [M:PAH0]NUM
   Rewrite [CHN]
   If fstat
    GOK=0 : Call FSTA("CHN") From GLOCK : Goto AB_TR_CHN
   Endif
   If   GOK<0 : Goto ROLL_TR_CHN
   Elsif !GOK : Goto AB_TR_CHN
   Endif
  Endif
 Endif
Commit
Return


$AB_TR_CHN
Rollback
Return

$ROLL_TR_CHN
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_CHN : Endif
Return

Subprog AS_SENDAT(VALEUR)
Variable Date    VALEUR
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
## Date émission saisissable dans le cas des modes de règlements :
##    - Cheques al dia (type 2)
##    - Cheques diferidos (type 3)
##    - Cheques de terceros (type 4)
##    - Tarjetas (type 5)
##    - Débit en compte (type 6)
Call LEC_TAM(GCURLEG, GPAM) From CPTLEC
If !fstat & !find([F:TAM]TYP,2,3,4,5,6)
 mkstat = 1 : End
Endif
End


Subprog D_SENDAT(VALEUR)
Variable Date    VALEUR
Case [M:PAH0]TYP
 When 1 : # Ordres de paiements : Date émission = date de l'ordre de paiement
  VALEUR = [M:PAH0]DAT
 When 2 : # Récibos : Date émission = date du récibo
  VALEUR = [M:PAH0]DAT
Endcase
End


Subprog AS_DUDDAT(VALEUR)
Variable Date    VALEUR
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
## Date échéance saisissable dans le cas des modes de règlements :
##    - Cheques diferidos (type 3)
##    - Cheques de terceros (type 4)
##    - Tarjetas (type 5)
Call LEC_TAM(GCURLEG, GPAM) From CPTLEC
If !fstat & !find([F:TAM]TYP,3,4,5)
 mkstat = 1 : End
Endif
End

Subprog D_DUDDAT(VALEUR)
Variable Date    VALEUR
Case [M:PAH0]TYP
 When 1 : # Ordres de paiements : Date échéance = date de la la facture (échéance) plus lointaine
  If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
  Local Integer I
  Local Date DATMAX
  DATMAX =  [0/0/0]
  For I = 0 To [M:PAH1]NBDOC-1
   Read [DUD]DUD1 = [M:PAH1]DUDNUM(I) ; [M:PAH1]DUDLIG(I)
   If !fstat & DATMAX<[F:DUD]DUDDAT
    DATMAX = [F:DUD]DUDDAT
   Endif
  Next
  If DATMAX<>[0/0/0]
   VALEUR = DATMAX
  Else
   VALEUR = [M:PAH0]DAT
  Endif
 When 2 : # Récibos : Date échéance = date du récibo
  VALEUR = [M:PAH0]DAT
Endcase
End


Subprog AS_SENBPR(VALEUR)
Variable Char    VALEUR()
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
## Emetteur saisissable dans le cas des modes de règlements :
##    - Cheques de terceros (type 4)
Call LEC_TAM(GCURLEG, GPAM) From CPTLEC
If !fstat & !find([F:TAM]TYP,4)
 mkstat = 1 : End
Endif
End

Subprog C_SENBPR(VALEUR)
Variable Char    VALEUR()
If clalev([F:PYH])=0 : Local File PAYMENTH  [PYH] : Endif
If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
Local Char    TABPAYTYP(GLONTPY)(1..99)
Local Integer NBTAB, NBREG
NBTAB = 0 : NBREG = 0
## Le règlement (client) endossé doit :
##    - être porté sur une transaction flaguée 'Endossement autorisé' et qui comporte
##      une étape de comptabilisation portefeuille
##    - doit être mis en portefeuille (compte client soldé)
##    - ne doit pas être remis en banque
##    - ne doit pas être déjà endossé
For [TPY]TPY0 Where FLGEND = 2
 NBTAB += 1
 TABPAYTYP(NBTAB) = [F:TPY]PAYTYP
Next
For [PYH]PYH0 Where find(PAYTYP,TABPAYTYP(1..NBTAB)) & FLGEND<>2 & SNS=2 & BPR=VALEUR & STAFLG(8)<>2 & STAFLG(2)=2
 NBREG += 1
 Break
Next
If NBREG = 0
 ## Pas de règlement endossable pour cet émetteur
 GMESSAGE = mess(26,8890,1)
 mkstat = 2 : End
Endif
End

Subprog AS_PAYNUMEND(VALEUR)
Variable Char    VALEUR()
## B° règlement X3 endossé saisissable dans le cas de la gestion des ordres de paiements et des modes de règlements :
##    - Cheques de terceros (type 4)
If [M:PAH0]STA = 3 : mkstat = 2 : End : Endif
Call LEC_TAM(GCURLEG, GPAM) From CPTLEC
If !fstat & !find([F:TAM]TYP,4)
 mkstat = 1 : End
Endif
End

Subprog C_PAYNUMEND(VALEUR)
Variable Char    VALEUR()
If clalev([F:PYH])=0 : Local File PAYMENTH [PYH] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
Read [PYH]PYH0 = VALEUR
If !fstat
 Call LECTURE("BPR",[F:PYH]BPR,"") From CONTOBJ
 [M:PPM]CRY = [F:BPR]CRY
 If [F:PYH]FLGEND = 2
  ## Règlement déjà endossé
  #GMESSAGE = mess(25,8890,1)
  #mkstat = 2 : End
 Endif
Else
 ## Règlement inexistant
 #GMESSAGE = mess(26,8890,1)
 #mkstat = 2 : End
Endif
End

