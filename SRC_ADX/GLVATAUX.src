#<AdxTL>@(#)6.0.0.0 $Revision$
$ACTION
Case ACTION
 When "OUVRE"   : Gosub OUVRE
 When "INIPAR"  : Gosub INIPAR
 When "INIPAR2" : Gosub INIPAR2
 When "FIN_TABLE"   : Gosub FIN_TABLE
Endcase
Return

$OUVRE
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
Return

$INIPAR
Local Char    SOCIETE(GLONCPY)
Case [M]PARCOD(nolign-1)
 When "societe"
  Read [CPY]CPY0 = [M:RPT]VALINT1(nolign-1)
  GCURLEG = [F:CPY]LEG
 When "gacdeb","cptdeb"
  Gosub SETSOC
  If SOCIETE<>""
   Read [GCM]GCM0 = [F:CPY]ACM
   Read [LED]LED0 = [F:GCM]LED([F:GCM]GENLEDTYP-1)
   Read [COA]COA0 = [F:LED]COA
   Call INIACCFMT([F:LED]COA) From SETGLBCOA
  Endif
 Endcase
Return

$INIPAR2
Case [M]PARCOD(nolign-1)
 When "gacdeb","cptdeb" : Gosub INIPAR
Endcase
Return

$SETSOC
SOCIETE = ""
K = find("societe",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
If K
 SOCIETE = [M:RPT]VALINT1(K-1)
 Read [CPY]CPY0 = SOCIETE
 If [F:CPY]CPYLEGFLG<>2
  Read [FGR]FGR0(1) = SOCIETE
  Read [FCY]FCY0 = [F:FGR]FCY
  SOCIETE = [F:FCY]LEGCPY
  Read [CPY]CPY0 = SOCIETE
  GCURLEG = [F:CPY]LEG
 Endif
Endif
Return

$FIN_TABLE
Case [M]PARCOD(nolign-1)
 When "gacdeb","cptdeb" : Gosub INIPAR
Endcase
Return

####################################################
## Exécution
####################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif
If clalev([F:ARM])=0 : Local File AREPORTM   [ARM] : Endif
If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
If clalev([F:TVT])=0 : Local File TABVAT     [TVT] : Endif

Call IMPRIME(NBPAR,PARAMETRE) From CPTRPT
If GOK<1 : End : Endif

Local Char VALEUR(200)
Local Char SOCIETE(GLONCPY), SOCREF(GLONCPY)
Local Char PLAN(GLONCOA)
Local Char TYPREF(1)

Call GETPARAM("grpcol",NBPAR,PARAMETRE,VALEUR) From ETAT
Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE) From ETAT

Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
If [F:CPY]CPYLEGFLG=2
 SOCREF = SOCIETE
Else
 Filter [FGR] Where CPY=SOCIETE
 Read [FGR]FGR0 First
 Filter [FGR]
 Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
 SOCREF = [F:FCY]LEGCPY
Endif

Call SETMAINREF(SOCREF,GTYPGEN,GTYPANA) From CPTDIV
Call LECPLAN(SOCREF,GTYPGEN,PLAN) From CPTDIV
Call SETPARAM("plan",NBPAR,PARAMETRE,PLAN) From ETAT
[L]TYPREF = num$(GTYPGEN)
Call SETPARAM("referentiel",NBPAR,PARAMETRE,TYPREF) From ETAT

If VALEUR<>""
 If clalev([F:GSC])=0 : Local File GRPSAC     [GSC] : Endif

 GROUPE = VALEUR
 VALEUR = ""
 For [GSC]GSC0 Where COA=PLAN & GRU=GROUPE
  VALEUR += "/"+format$("K:4X",[F:GSC]SAC)
 Next
 Call SETPARAM("liscol",NBPAR,PARAMETRE,VALEUR) From ETAT
Else
 VALEUR = ""
 Call SETPARAM("liscol",NBPAR,PARAMETRE,VALEUR) From ETAT
Endif

# EMERAUDE - Feature MULTILEG- Requirement 71216
Local Integer NBRLEG : NBRLEG    = 1
Local Char TABLEG(GLONADI)(1..NBRLEG) : TABLEG(NBRLEG) = [F:CPY]LEG
Local Char    PARAM(50)
Local Integer NUMREQ
Gosub TRTGTE From RPTLEG
Gosub TRT_TVT From RPTLEG
End
