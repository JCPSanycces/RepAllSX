Call OUVRE_TRACE("") From LECFIC
Local File ADOSSIER [ADS]
GTRACE =''
Read [ADS]DOSSIER = "X3DEV"
Call TRCMAJ60

End

#################################################################################
#CHECK MIGRATE_SOURCE
# ----------------------------------------------------------------------------- #
# TRCMAJ60 : M.a.j à effectuer lors du passage à version 9  Module Tronc commun #
# ----------------------------------------------------------------------------- #
#                                                                               #
# Avant mise à jour : ATRCMAJ60                                                 #
#                                                                               #
#################################################################################
#                                                                               #
# Après mise à jour : TRCMAJ60                                                  #
#                                                                               #
#   - UPDSRU   : Met à jour la table TABSTORUL                                  #
#   - UPDSFI   : Update of the SFOOTINV table                                   #
#   - UPDBCL   : Update of BETCPYL table  (Intercompany parameters)             # : # Issue 26113 - 20150707 by LD : Inter-site : Price recalculation
#   - MAJ_UTITRC06 :                                                            # : # Issue 111940 - 20151028 by LD : Mobility U9 and migration folder
#     Automatic copy Graphical query tool,Statistical parameters,Dashboard views# : # Issue 111940 - 20151028 by LD : Mobility U9 and migration folder
#################################################################################
# Issue 111940 - 20151028 by LD : Mobility U9 and migration folder

#################################################################################
# Moulinette : Structure tables avec anciens et nouveaux champs                 #
#################################################################################

Subprog ATRCMAJ60

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ60 : Process for common data") From LECFIC
    WOUV_TRACE=1
Endif

#109831.sn
#---- Copy fields from LTAPAR to COMPANY ------#
Call MAJ_UTITRC05([F:ADS]DOSSIER) From UTITRC05
#109831.en

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End

#################################################################################
# Moulinette : Structure définitive des tables                                  #
#################################################################################

Subprog TRCMAJ60

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ60 : Process for common data") From LECFIC
    Call ECR_TRACE( ' ', 0) From GESECRAN
    WOUV_TRACE=1
Endif

Local Integer NUMPROC
Raz NUMPROC

Onerrgo TRT_ERR

#---- Init nouveaux champs TABSTORUL ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ60 TC Transactions Process "+num$(NUMPROC)+": Update TABSTORUL") From DOSSUB
Call UPDSRU([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif
#---- Init new entries SFOOTINV ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ60 TC Transactions Process "+num$(NUMPROC)+": Update SFOOTINV") From DOSSUB
Call UPDSFI([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif
# Issue 26113 - 20150707 by LD : Inter-site : Price recalculation
#---- Init new entries BETCPYL ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ60 TC Transactions Process "+num$(NUMPROC)+": Update BETCPYL") From DOSSUB
Call UPDBCL([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif
# Issue 26113 - 20150707 by LD : Inter-site : Price recalculation

#111104.sn
#Verify SEPP activty code is active
#111476 Change the abreviation of the ACTIVE table to avoid conflict with the class opened by the supervisor
If !clalev([F:ACVY]) : Local File =[F:ADS]DOSSIER+".ACTIV"     [ACVY] : Endif
Read [ACVY]CODACT="SEPP"
If fstat | [F:ACVY]FLACT<>2
Else
  #109235.sn
  #---- Init new entries SEPRC ------#
  NUMPROC += 1
  Call ECR_TIME("DOSMAJ60 TC Transactions Process "+num$(NUMPROC)+": Update SEPRC") From DOSSUB
  Call UPDSEP([F:ADS]DOSSIER)
  If GOK<>1 : Onerrgo : End : Endif

  #---- Init new entries SETXN ------#
  NUMPROC += 1
  Call ECR_TIME("DOSMAJ60 TC Transactions Process "+num$(NUMPROC)+": Update SETXN") From DOSSUB
  Call UPDSEX([F:ADS]DOSSIER)
  If GOK<>1 : Onerrgo : End : Endif
  #109235.en
Endif
Close Local File [ACVY]
#111104.en

# Issue 111940
# Utility to copy automatically Graphical query tool (ALT),Statistical parameters (PS2),Dashboard views (APV)
Call MAJ_UTITRC06([F:ADS]DOSSIER) From UTITRC06
# End issue 111940

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End

#################################################################################
$TRT_ERR
    Call ECR_TRACE( "ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
Resume


#################################################################################
# Met à jour la table TABSTORUL
#################################################################################
# Init AUZPRO, AUZACT, AUZSTP et ORDVER (exigence 106217)
#################################################################################
Subprog UPDSRU(PDOS)
Value Char PDOS

Local File =PDOS+".TABSTORUL"  [SRU]

Call DEBTRANS From GLOCK
Trbegin [SRU]
For [SRU] Where find([F:SRU]TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
  If [F:SRU]TRSTYP=11 | [F:SRU]TRSTYP=32
    If [F:SRU]AUZPRO=0 [F:SRU]AUZPRO=3 Endif
    If [F:SRU]AUZACT=0 [F:SRU]AUZACT=3 Endif
    If [F:SRU]AUZSTP=0 [F:SRU]AUZSTP=3 Endif
    If [F:SRU]ORDVER=0 [F:SRU]ORDVER=1 Endif
  Else
    If [F:SRU]AUZPRO=0 [F:SRU]AUZPRO=2 Endif
    If [F:SRU]AUZACT=0 [F:SRU]AUZACT=2 Endif
    If [F:SRU]AUZSTP=0 [F:SRU]AUZSTP=2 Endif
    If [F:SRU]ORDVER=0 [F:SRU]ORDVER=1 Endif
  Endif
  Rewrite [SRU]
  If fstat
    Call FSTA("SRU") From GLOCK
    Break
  Endif
Next
Commit

End
#################################################################################
# Update of the SFOOTINV table
#################################################################################
# New transfer rules (feature 79550)
# Initialized fields :
# --RULE : Sales return to Credit memo
#   ORIVCR(5) : entry 3 "Return"      of local menu 476 - 'Type de document ventes'
#   DESVCR(5) : entry 5 "Credit memo" of local menu 476 - 'Type de document ventes'
#   BRDRUL(5) : same as the value of each invoicing element's existing rule Invoice to Credit memo
#   GRUFLG(5) : same as the value of each invoicing element's existing rule Invoice to Credit memo
#   GRURUL(5) : same as the value of each invoicing element's existing rule Invoice to Credit memo
# --RULE : Service contracts to Invoice
#   ORIVCR(6) : entry 23 "Service contracts"    of local menu 476 - 'Type de document ventes'
#   DESVCR(6) : entry 4  "Invoice"              of local menu 476 - 'Type de document ventes'
#   BRDRUL(6) : entry 7  "All invoices"         of local menu 473 - 'Règles éclatement'
#   GRUFLG(6) : entry 1  "Yes"                  of local menu 474 - 'Regroupement'
#   GRURUL(6) : entry 16 "1st service contract" of local menu 472 - 'Règles regroupement'
#
#################################################################################
Subprog UPDSFI(PDOS)
Value Char PDOS

Local File =PDOS+".SFOOTINV"  [SFI]

Call DEBTRANS From GLOCK

Trbegin [SFI]

For [SFI]
  [SFI]ORIVCR(5)=3
  [SFI]DESVCR(5)=5
  [SFI]BRDRUL(5)=[SFI]BRDRUL(4) :#--it's ok to use the same value (destination doc is the same)
  [SFI]GRUFLG(5)=[SFI]GRUFLG(4)
  #--
  Case [SFI]GRURUL(4)
    When 4
      [SFI]GRURUL(5)= 14 :#--"1st return"
    When 8
      [SFI]GRURUL(5)= 15 :#--"Return amount sum"
    When 9,10,11,12,13
      [SFI]GRURUL(5) = [SFI]GRURUL(4)
    When Default
  Endcase
  #--
  [SFI]ORIVCR(6)=23
  [SFI]DESVCR(6)=4
  [SFI]BRDRUL(6)=7
  [SFI]GRUFLG(6)=1
  [SFI]GRURUL(6)=16
  Rewrite [SFI]
  If fstat
    Call FSTA("SFI") From GLOCK
    Break
  Endif
Next

Commit

End

# Issue 26113 - 20150707 by LD : Inter-site : Price recalculation
#################################################################################
# Update the TRFPRI table : Intercompany parameters
#################################################################################
# Initialized field :
# -- TRFPRI : Price Transfert
#    2 (Yes) if VCRTYP (Origin document)=Sales invoice
#    1 (No)  if VCRTYP (Origin document)=Purchase order
#################################################################################
Subprog UPDBCL(PDOS)
Value Char PDOS

Local Integer WI
Local File =PDOS+".BETCPYL"    [BCL]

Call DEBTRANS From GLOCK
Trbegin [BCL]
For [BCL] Where [F:BCL]TRFPRI=0
    If [F:BCL]VCRTYP=5  [F:BCL]TRFPRI=2 Endif
    If [F:BCL]VCRTYP=14 [F:BCL]TRFPRI=1 Endif
    WI+=1
    Rewrite [BCL]
    If fstat
        Call FSTA("BCL") From GLOCK
        Break
    Endif
Next

Call ECR_TRACE( '    --> ' + num$(WI) - "Update", 0) From GESECRAN
Commit

End
# Issue 26113 - 20150707 by LD : Inter-site : Price recalculation

#109235.sn
#################################################################################
# Update the SEPRC table : Payment gateway
#################################################################################
# Initialized field :
# -- PAYPRC : Payment Processor
#    1 (Sage Exchange)
#    2 (Sage Pay)
#################################################################################
Subprog UPDSEP(PDOS)
Value Char PDOS

Local Integer WI
Local File =PDOS+".SEPRC"    [SEP]

Call DEBTRANS From GLOCK
Trbegin [SEP]

Update [SEP] Where PAYPRC=0 With PAYPRC=1
WI+=adxuprec

If fstat
  Call FSTA("SEP") From GLOCK
Endif

Call ECR_TRACE( '    --> ' + num$(WI) - "Update", 0) From GESECRAN
Commit

End

#################################################################################
# Update the SETXN table : Credit card transactions
#################################################################################
# Initialized field :
# -- PAYPRC : Payment Processor
#    1 (Sage Exchange)
#    2 (Sage Pay)
#################################################################################
Subprog UPDSEX(PDOS)
Value Char PDOS

Local Integer WI
Local File =PDOS+".SETXN"    [SEX]

Call DEBTRANS From GLOCK
Trbegin [SEX]

Update [SEX] Where PAYPRC=0 With PAYPRC=1
WI+=adxuprec

If fstat
  Call FSTA("SEX") From GLOCK
Endif

Call ECR_TRACE( '    --> ' + num$(WI) - "Update", 0) From GESECRAN
Commit

End
#109235.en

