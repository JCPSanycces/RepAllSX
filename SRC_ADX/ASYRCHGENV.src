#<AdxTL>@(#)0.0.0.0 $Revision$ 
# ZTEST_ASYRCHGENV
Call LOAD()
End

#To be called when opening a session for loading additionnal properties
Subprog LOAD()
#Test that adxenvsys exists:
If dim(ADXENVSYS) >= 0
 Call LOAD_APP_CNX_DATA_JSON(ADXENVSYS)
Endif
End

#To be called when reusing a session for loading additionnal properties
Subprog LOAD_APP_CNX_DATA(DATA)
Variable Clbfile DATA

Local Clbfile JSON

If len(DATA) >2
 JSON = unescJson(DATA)
 If left$(JSON,1) = '"'
  JSON = mid$(unescJson(JSON),2,len(JSON)-1)
 Endif
 Call LOAD_APP_CNX_DATA_JSON(JSON)
Endif
End

Subprog LOAD_APP_CNX_DATA_JSON(DATA)
Variable Clbfile DATA

Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  NODE        Using C_ASYRJSO
Local Integer ASTATUS : ASTATUS=[V]CST_AOK
If len(DATA)
 ASTATUS = func ASYRJSONPARSE.PARSEJSON(GACTX,DATA,NODES,NODE)
 If ASTATUS = [V]CST_AOK
  Call LOAD_APP_CNX_DATA_OBJ(NODE)
 Endif
Endif
End

Subprog LOAD_APP_CNX_DATA_OBJ(NODE)
Variable Instance  NODE        Using C_ASYRJSO

Local Integer DIME,TYP
Local Char VARNAME(30),VALVAL(250),VARFLD(10)
Local Char MAPIN(10)(1..),MAPOUT(10)(1..),MAPADOVAL(10)(1..)
Local Integer AI

Local Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
ACTX=NewInstance [ALOG] With =[V]CST_C_NAME_CLASS_CONTEXT

If dim(GDEP) < 0 : Global Char     GDEP(GLONDEP)    : Endif : # Déposant courant
If dim(GFCY) < 0 : Global Char     GFCY(GLONFCY)     : Endif : # Site courant

MAPIN(1) ="AFCYREF"   : MAPOUT(1) = "GFCY":MAPADOVAL(1)="FCY"
MAPIN(2) ="ADEPREF"   : MAPOUT(2) = "GDEP":MAPADOVAL(2)="DEP"
MAPIN(3) ="ADATEREF" : MAPOUT(3) = "datesyst":MAPADOVAL(3)=""
#set a default value for datesyst
datesyst = date$
While NODE <> null
  If left$(toupper(NODE.PRO),1) ="A"
      VALVAL=fmet NODE.AGETCNT
      # Let's try on the context
      If evalue("dim(GACTX.AENV)") >= 0
       GACTX.AENV.isReadonly = 0
       VARNAME = "GACTX.AENV."+NODE.PRO
       Gosub SET_VAR
       GACTX.AENV.isReadonly = 1
     Endif
     # Let's try on gloal variables
     AI = find(NODE.PRO, MAPIN)
     If AI
      VARNAME = MAPOUT(AI)
      VARFLD = MAPADOVAL(AI)
      Gosub SET_VAR
     Endif
  Endif
  NODE = NODE.NEX
Wend

# In case of having datesyst reset, force the value to date$
If datesyst=[0/0/0]
    datesyst = date$
Endif
# To be sure to have equality between GACTX.AENV.DATEREF and datesyst
If dim(GACTX.AENV.ADATEREF) >= 0
    GACTX.AENV.isReadonly = 0
    GACTX.AENV.ADATEREF= datesyst
Endif

GACTX.isReadonly = 1
End


$SET_VAR
Onerrgo SET_VAR_ERROR
DIME = evalue("dim("+VARNAME+")")
If DIME >= 0
 TYP = evalue("type("+VARNAME+")")
 Case TYP
  When 1,2,4,5
   Assign VARNAME With val(VALVAL)
  When 3
   Local Char TMP(20)
   If len(VALVAL)=12
    TMP = mid$ (VALVAL,2 ,4) + mid$(VALVAL,7 ,2) + mid$(VALVAL,10 ,2)
    Assign VARNAME With TMP
   Endif
  When Default
   Assign VARNAME With mid$(VALVAL,2,len(VALVAL)-2)
  Endcase
  If len(VARFLD)
   Local File ADOVALAUS [ADU]
   Read [ADU]ADU0=GUSER;VARFLD
   If fstat
    #New row
    [F:ADU]CODUSR =GUSER
    [F:ADU]PARAM  = VARFLD
    [F:ADU]CREDAT = date$
    [F:ADU]CREDATTIM = time
    [F:ADU]CREUSR = GUSER
   Endif
   [F:ADU]VALEUR = evalue(VARNAME)
   [F:ADU]UPDDAT = date$
   [F:ADU]UPDDATTIM = time
   [F:ADU]UPDUSR = GUSER
   If fstat : Write [ADU] : Else : Rewrite [ADU] : Endif
   Close File [ADU]
  Endif
Endif
Raz VARNAME,VARFLD
Return

$SET_VAR_ERROR
Resume

