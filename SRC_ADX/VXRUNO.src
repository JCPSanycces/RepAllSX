#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management VXRUNO
####################################################################################
$ACTION

Case ACTION
  When "DEBUT"         : Gosub DEBUT
  When "OUVRE"         : Gosub OUVRE
  When "OK"            : Gosub OK
Endcase

Return
####################################################################################
$OUVRE

  Global Char    GMTSNUM(GLONTRS) : GMTSNUM = GFLAG

  If !clalev([SFTX])  : Local File SFTTXN   [SFTX]  : Endif
  If !clalev([F:TMA]) : Local File TABMAT   [TMA]  : Endif

Return
####################################################################################
$DEBUT

  Raz [M:VXRUNO]
  Affzo [M:VXRUNO]

  # Default to disable reject qty and reject reason fields
  Grizo [M:VXRUNO]REJCPLQTY
  Grizo [M:VXRUNO]SCANUM

Return
######################################################################################
Subprog C_EMPNUM(VALEUR)
Variable Decimal  VALEUR

  Local Integer EMPTYP

  #Check if employee exist
  Read [TMA]TMA0=VALEUR
  If fstat
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(23,100,1)
    mkstat = 2
    End
  Endif

  EMPTYP =  [TMA]EMPTYP

  # Check if employee is active
  If func SFTLIB.EMPLOYEEACTIVE(VALEUR) = [V]CST_ANO
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(2,126,1)
    mkstat = 2
    End
  Endif

  Local Integer EMPLIST(1..)
  EMPLIST(1) = VALEUR
  Call TEAM_LIST (VALEUR, "A", EMPLIST) From SFTLIB
  [M:VXRUNO]EMPLST = EMPLIST(1) #CT-1993

  #Check if an employee or team is on a break or on an exclusive indirect
  If func SFTLIB.EMPLOYEE_ON_BREAK(EMPLIST(1)) = [V]CST_AYES
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV

    #X3-1801 sn
    Case EMPTYP
      When 0,1 #Employee
        GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(18,2422,1)
      When 2 #Detail Team
        GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(122,2422,1)
      When 3 #Summary Team
        GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(121,2422,1)
    Endcase
    #X3-1801 en

    mkstat = 2
    End
  Endif

End
######################################################################################
Subprog AM_EMPNUM(VALEUR)
Variable Decimal VALEUR

  Call CLEAR_FIELDS

  Read [TMA]TMA0=VALEUR
  If !fstat
    # Default employee description and the site if populated
    [M:VXRUNO]EMPDES  = [F:TMA]EMPDES
    [M:VXRUNO]FCY     = [F:TMA]DEFFCY
    [M:VXRUNO]EMPTYP  = [F:TMA]EMPTYP

    Affzo [M:VXRUNO]FCY
  Else    # Not found
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(23,100,1)
    mkstat = 2
    End
  Endif
End
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  Local Integer  EMP_LIST(1..)

  # Make sure the global variables and parameters are updated
  GFCY=VALEUR : Gosub CHARG_PARAM From SUBMTKA

  Local Char PARAMRET(4)
  Raz PARAMRET

  Call PARAM(VALEUR,"SFTEMPCLK",PARAMRET) From ADOVAL
  If val([L]PARAMRET) = [V]CST_AYES
    If [M:VXRUNO]EMPTYP = 2
      #X3-1717 sn
      # Check if team members are clocked in or not on any individual activities
      Call TEAM_LIST ([M:VXRUNO]EMPNUM, 'A', EMP_LIST) From SFTLIB
      If maxtab(EMP_LIST) = 0   # No team member found
        Call ERREUR(func AFNC.MES1(mess(110,2422,1), num$([M:VXRUNO]EMPNUM))) From GESECRAN
        mkstat = 1
        End
      Endif
      #X3-1717 en
    Else #Detailed teams dont clock in
      If func SFTLIB.EMPLOYEE_CLOCKED_IN([M:VXRUNO]EMPNUM) = [V]CST_ANO
        Call ERREUR(func AFNC.MES1(mess(12,2422,1), num$([M:VXRUNO]EMPNUM))) From GESECRAN #CT-1797
        mkstat = 1
        End
      Endif
    Endif
  Elsif [M:VXRUNO]EMPTYP = 2 #Detailed teams must be on sites that require clock-in
    GMESSAGE = func AFNC.MES1(mess(111,2422,1), "SFTEMPCLK")
    mkstat = 1
    End
  Endif


End
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  Call CLEAR_FIELDS

End
######################################################################################
Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()

  # Manually enter the WO. Check if the order running
  Filter [F:SFTX] Where EMPNUM = [M:VXRUNO]EMPLST & SFTTYP = 5 & FCY = [M:VXRUNO]FCY & VCRNUM = VALEUR & UTCENDDATTIM = AVOID.ADATTIM &
&                       (MACFLG <> [V]CST_AYES | TXNUUID = AVOID.AUUID |
&                       (TEAMNUM <> [M:VXRUNO]EMPLST & TEAMNUM <> 0 & MACFLG = [V]CST_AYES)) #CT-1993
  Look [F:SFTX]SFT0 First
  Filter [F:SFTX]
  If fstat
    GERR=1 : GMESSAGE = func AFNC.MES1(mess(82,2422,1),num$(VALEUR))  # ...: Not in process
    mkstat = 2
  Endif

End
######################################################################################
Subprog C_OPENUM(VALEUR)
Variable Decimal VALEUR

  # Manually enter the operation. Check if the operation running
  Filter [F:SFTX] Where EMPNUM = [M:VXRUNO]EMPLST & SFTTYP = 5 & FCY = [M:VXRUNO]FCY & VCRNUM = [M:VXRUNO]VCRNUM & OPENUM = VALEUR & UTCENDDATTIM = AVOID.ADATTIM &
&                       (MACFLG <> [V]CST_AYES | TXNUUID = AVOID.AUUID |
&                       (TEAMNUM <> [M:VXRUNO]EMPLST & TEAMNUM <> 0 & MACFLG = [V]CST_AYES)) #CT-1993
  Read [F:SFTX]SFT0 First
  Filter [F:SFTX]
  If fstat
    GERR=1 : GMESSAGE = func AFNC.MES1(mess(82,2422,1),num$(VALEUR))  # ...: Not in process
    mkstat = 2
  Else
    [M:VXRUNO]SFTSEQ =  [F:SFTX]SFTSEQ
  Endif

End
######################################################################################
Subprog AM_CPLQTY(VALEUR)
Variable Decimal VALEUR
Local Integer OK, CPLQTY_HIGHER,  OPERCLOSE

  OPERCLOSE = [V]CST_ANO

  # Check if the completed qty and more than the estimated/planned qty
  Call VAL_COMPLETEQTY([M:VXRUNO]VCRNUM,[M:VXRUNO]OPENUM,VALEUR, CPLQTY_HIGHER, OPERCLOSE) From SFTLIB
  If CPLQTY_HIGHER = [V]CST_AYES
    Call AVERTIR(mess(54,190,1),OK) From GESECRAN   # Actual quantity larger than estimated quantity. Continue?
    If OK = 1     # Cancel
      mkstat = 2
      End
    Endif
  Endif

  # Assign and refresh Close value
  [M:VXRUNO]CLEFLG = OPERCLOSE
  Affzo [M:VXRUNO]CLEFLG
  # Enable/disable rejected field
  Call REJECTQTY(VALEUR)
  # Enable/disable the rejected code field
  Call REJECTCODE([M:VXRUNO]REJCPLQTY)

End
######################################################################################
Subprog C_REJCPLQTY(VALEUR)
Variable Decimal VALEUR

  # Display message when rejected qty is > completed qty
  If VALEUR > [M:VXRUNO]CPLQTY
    GERR=1 : GMESSAGE = mess (25,2422,1)
    mkstat = 2
  Endif

End
######################################################################################
Subprog AM_REJCPLQTY(VALEUR)
Variable Decimal VALEUR

    Call REJECTCODE(VALEUR)

End
######################################################################################
Subprog C_SCANUM(VALEUR)
Variable Decimal VALEUR

  Local Char WSCANUM(12) : WSCANUM = num$(VALEUR)
  # Reason code valid?
  If VALEUR <> 0
    Call CONTROLE("TSR","",WSCANUM,"",mkstat) From CONTOBJ
  Endif

End
######################################################################################
Subprog REJECTCODE(I)
Value Decimal I

  If I > 0
    Actzo [M:VXRUNO]SCANUM
  Else
    Raz [M:VXRUNO]SCANUM
    Grizo [M:VXRUNO]SCANUM
  Endif
  Affzo [M:VXRUNO]SCANUM

End
######################################################################################
Subprog REJECTQTY(I)
Value Decimal I

  If I > 0
    Actzo [M:VXRUNO]REJCPLQTY
  Else
    Raz [M:VXRUNO]REJCPLQTY
    Grizo [M:VXRUNO]REJCPLQTY
  Endif
  Affzo [M:VXRUNO]REJCPLQTY

End
####################################################################################
Subprog CLEAR_FIELDS

  Raz [M:VXRUNO]VCRNUM, OPENUM, CPLQTY, REJCPLQTY, SCANUM, CLEFLG
  Grizo [M:VXRUNO]REJCPLQTY, SCANUM
  Affzo [M:VXRUNO]VCRNUM, OPENUM, CPLQTY, REJCPLQTY, SCANUM, CLEFLG

End
######################################################################################
$OK
  Local Integer   STOP_COUNT, MY_STATUS, RESTART_OPER
  Local Datetime  STOPTIME
  Local Date      ODATE
  Local Char      OTIME(5)
  Local Integer   ERRNUM
  Local Char      ERRMSG(255)
  Local Char      STRYEAR(4), STRMONTH(2), STRDAY(2), STRHOUR(2), STRMIN(2)

  Local Integer   CPLQTY(1)    # Completed Quantity
  Local Integer   REJQTY(1)    # Rejected Quantity
  Local Integer   SCANUM(1)    # Rejection Code
  Local Integer   CLEFLG(1)    # Completed (Binary)
  Local Integer   BLANK_INT(1) # uneeded info

  # Initialization
  STOP_COUNT    = 1

  Local Integer   SFTTYP(1)     : SFTTYP(0) = 5
  Local Char      VCRNUM(20)(1) : VCRNUM(0) = [M:VXRUNO]VCRNUM
  Local Integer   SFTSEQ(1)     : SFTSEQ(0) = [M:VXRUNO]SFTSEQ

  # Add the record to a collection
  CPLQTY(0)   = [M:VXRUNO]CPLQTY
  REJQTY(0)   = [M:VXRUNO]REJCPLQTY
  SCANUM(0)   = [M:VXRUNO]SCANUM
  CLEFLG(0)   = [M:VXRUNO]CLEFLG


  Call STOP_OPERATIONS([M:VXRUNO]EMPNUM, [M:VXRUNO]FCY, SFTTYP, VCRNUM, [M:VXRUNO]OPENUM, SFTSEQ,
&                      BLANK_INT, CPLQTY, REJQTY, SCANUM, CLEFLG, STOP_COUNT) From SFTLIB


  Call TIMESTAMP([M:VXRUNO]FCY, ODATE, OTIME) From SFTLIB
  Call MESSAGE(func AFNC.MES2(mess(78,2422,1), [M:VXRUNO]VCRNUM+" "+num$([M:VXRUNO]OPENUM), left$(OTIME,2) + ":" + right$(OTIME,3))) From GESECRAN


Return
######################################################################################

