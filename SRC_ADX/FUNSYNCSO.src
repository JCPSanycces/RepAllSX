#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################
# FUNSYNCSO : Resynchronisation des ordres SOP,SOF          LD  20/04/04 #
# ---------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais une fonction                     #
#  - Recréation des encours SOP,SOF,TPP,TPF manquants pour les cdes & DL #
# ---------------------------------------------------------------------- #
# Ce traitement est appelé depuis le FUNSYNCW                            #
#  - Le masque écran SYNCW [DIA] doit être ouvert et chargé              #
# Ce traitement peut également être lancé manuellement                   #
##########################################################################


Call OUVRE_TRACE("Recréation des encours manquants (module vente)") From LECFIC
#-----
Local Mask    SYNCW [DIA] : Raz [M:DIA]
Local Libelle WFLAG       : WFLAG=1
Local Integer OK
#-----
GCONSDIA=0
Call DIALWIN(OK,mess(188,195,1),"DSYNCW") From GESECRAN
If OK=2 & [M:DIA]SOREGEN=2
  Gosub REGEN_SO
  Call ECR_TRACE("Nombre de contrôles effectués     : "+num$(NBANA),0) From GESECRAN
  If [M:DIA]AUTCOR<>2
    Call ECR_TRACE("Nombre de corrections à effectuer : "+num$(NBMAJ),0) From GESECRAN
  Else
    Call ECR_TRACE("Nombre de corrections effectuées  : "+num$(NBMAJ),0) From GESECRAN
  Endif
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
#-----
End


####################################
# Recréation des encours manquants #
####################################
$REGEN_SO
#----- Ouverture des tables si nécessaire -----#
If !clalev([F:ORD])  Local File ORDERS   [ORD]  : Endif
If !clalev([F:SOQ])  Local File SORDERQ  [SOQ]  : Endif
If !clalev([F:SOH])  Local File SORDER   [SOH]  : Endif
If GMODU(6)=2
    If !clalev([F:POQ])  Local File PORDERQ  [POQ]  : Endif
Endif
#----- Ouverture masque écran si nécessaire -----#
If !clalev([M:ORDK]) Local Mask ORDK     [ORDK] : Endif
#----- Variables locales -----#
Local Integer SAV_NBMAJ
If dim(CRITERE)<1  Local Char    CRITERE(60) : Endif
If dim(NBANA)  <1  Local Integer NBANA       : Endif
If dim(WMSG)   <1  Local Char    WMSG(100)   : Endif
If dim(WFLAG)  <1  Local Libelle WFLAG       : Endif
If dim(WNBSOQ) <1  Local Integer WNBSOQ      : Endif
If dim(WWIPTYP)<1  Local Integer WWIPTYP     : Endif
If dim(WCPLQTY)<1  Local Decimal WCPLQTY     : Endif
If dim(WTRTORD)<1  Local Char    WTRTORD     : Endif 
If dim(NBMAJ)<1
  Local Integer NBMAJ
  Raz SAV_NBMAJ
Else
  SAV_NBMAJ=NBMAJ
Endif
WTRTORD="C"
#-----
Raz WMSG, WNBSOQ
Call DEBTRANS From GLOCK
#----- Traitement des lignes de commandes ou DL non soldées et gérées en stock -----#
If [M:DIA]STOFCY<>""
  CRITERE ='STOFCY="'+[M:DIA]STOFCY+'"'   : # Site d'expédition
Else
  CRITERE ="1=1"
Endif
If [M:DIA]ITMREF<>""
  CRITERE-='& ITMREF="'+[M:DIA]ITMREF+'"' : # Référence article              
Endif
#----- Trace uniquement si lancement direct -----#
If WFLAG
  WMSG="- "+mess(599,197,1)+" " : WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
#----- Sélectionne les lignes en attente
# ou les lignes soldées mais dont la livraison n'est pas validée - 47951
For [SOQ] SOQ4 Where ( SOQSTA=1 or ( SOQSTA=3 and ODLQTYSTU<>0 )) & DEMNUM<>"" & evalue(CRITERE)
  NBANA+=1 : WNBSOQ+=1 : Gosub REGEN_SOQ : If GOK<1  Break : Endif
Next
#----- Trace uniquement si lancement direct -----#
If WFLAG
  WMSG="- ("+num$(WNBSOQ)+") " : WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN : Call ECR_TRACE(" ",0)  From GESECRAN
Endif
#-----
If [M:DIA]AUTCOR<>2 & dim(NBORD)>0
  NBORD+=NBMAJ
  NBMAJ=SAV_NBMAJ
Endif
#-----
If GOK<1  Return : Endif
Return


#------------------------------------#
# Traitement d'une ligne de commande #
#------------------------------------#
$REGEN_SOQ

# On doit lire l'entête de commande pour déterminer le type d'en-cours
If [F:SOH]SOHNUM<>[F:SOQ]SOHNUM 
    Read [SOH]SOH0 = [F:SOQ]SOHNUM
    If fstat Raz [F:SOH] : Endif    
Endif
If [F:SOH]BETFCY=2 & [F:SOH]BETCPY<>2
   WWIPTYP  = 8                   : # C'est une Demande inter_site/intra-société : TP
Else
   WWIPTYP  = 1                   : # C'est une Commande de vente  : SO
Endif
If [F:SOH]SOHCAT = 3
    WCPLQTY = [F:SOQ]INVQTYSTU 
Else
    WCPLQTY = [F:SOQ]DLVQTYSTU
Endif

# Pas besoin de recréér l'en-cours si le cde n'est pas signée et encours article cde signée = "Non"
If find([F:SOH]APPFLG,1,2) & GSOHAPPORD=1 Return Endif
# Pas besoin de recréér l'en-cours si qté prévue <= qté réalisée
If [F:SOQ]QTYSTU-WCPLQTY<=0  Return : Endif

If dim([M:DIA]CTLDAT)>0 & [M:DIA]CTLDAT=2   # FQ 69974 GA 12/2010 Ctrl des dates de l'encours
  If [F:SOQ]ORDDAT > [F:SOQ]DEMDLVDAT 
     Call ECR_TRACE(mess(583,197,1)-"SORDERQ"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-[F:SOQ]ITMREF
&                  -"\        Date début"-num$([F:SOQ]ORDDAT)
&                  -"Date fin"-num$([F:SOQ]DEMDLVDAT)-num$([F:SOQ]SHIDAT)
&                  ,0) From GESECRAN 
     Return
  Endif
  Read [ORD] ORD0=WWIPTYP;[F:SOQ]DEMNUM;[F:SOQ]ITMREF
  If !fstat & ([F:ORD]STRDAT=[F:SOQ]ORDDAT & find([F:ORD]ENDDAT,[F:SOQ]DEMDLVDAT,[F:SOQ]SHIDAT) )
    Return 
  Endif
  Call ECR_TRACE(mess(53,183,1)-"ORDERS"-mess(WWIPTYP,341,1)-mess([F:ORD]WIPSTA,342,1)-
&                  [F:SOQ]DEMNUM-[F:SOQ]ITMREF
&                  -"\        Date début"-num$([F:ORD]STRDAT)-num$([F:SOQ]ORDDAT)
&                  -"Date fin"-num$([F:ORD]ENDDAT)-num$([F:SOQ]DEMDLVDAT)-num$([F:SOQ]SHIDAT)
&                  ,0) From GESECRAN 
  Return     # 76376
Else
  Look [ORD] ORD0=WWIPTYP;[F:SOQ]DEMNUM;[F:SOQ]ITMREF
  If !fstat  Return : Endif
Endif
#----- Trace uniquement si lancement direct -----#
If WFLAG
  Call ECR_TRACE(mess(51,197,1)-mess(600,197,1)-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-
&                num$([F:SOQ]SOQSEQ)-[F:SOQ]DEMNUM,0) From GESECRAN
Endif
If [M:DIA]AUTCOR<>2  NBMAJ+=1 : Return : Endif
#----- Recréation de l'encours -----#
GOK=1
Trbegin [ORD]

  Gosub APPELWIP From TRTVENMAJ
  If GOK<1
    Rollback
    Call ECR_TRACE(mess(13,100,1)-"ORDERS"-num$(WWIPTYP)-num$([F:ORD]WIPSTA)-
&                  [F:SOQ]DEMNUM-[F:SOQ]ITMREF,1) From GESECRAN
    Return
  Endif

Commit
NBMAJ+=1
Return

