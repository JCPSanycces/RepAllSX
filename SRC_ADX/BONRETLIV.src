#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#########################################################################
# BRBAN 25/11/2014 - 97101 - Printing requirements for POR legislation
#########################################################################
#########################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

# Table declaration
Gosub OUVRE
# Variable declaration
Gosub DECLARE

[L]CRITERE(0) = "1=1"
[L]CRITERE(1) = "1=1"

For I=1 To [L]NBPAR
  J=instr(1,[L]PARAMETRE(I),"=")
  If J
    [L]PARAM  = left$([L]PARAMETRE(I),J-1)
    Call GETPARAM ([L]PARAM,[L]NBPAR,[L]PARAMETRE,VALEUR) From ETAT
    Case [L]PARAM
      When "X3ETA"          : [L]ETAT     = [L]VALEUR
      When "__REQUETE"      : [L]NUMREQ   = val([L]VALEUR)
      When "sitedeb"        : [L]CRITERE(0) -= "& STOFCY>='"+[L]VALEUR+"'"
      When "sitefin"        : [L]CRITERE(0) -= "& STOFCY<='"+[L]VALEUR+"'"
      When "clientdeb"      : [L]CRITERE(0) -= "& BPCORD>='"+[L]VALEUR+"'"
      When "clientfin"      : [L]CRITERE(0) -= "& BPCORD<='"+[L]VALEUR+"'"
      When "retourdeb"      : [L]CRITERE(0) -= "& SRHNUM>='"+[L]VALEUR+"'"
      When "retourfin"      : [L]CRITERE(0) -= "& SRHNUM<='"+[L]VALEUR+"'"
      When "typeretdeb"     : [L]CRITERE(0) -= "& SRHTYP>='"+num$([L]VALEUR)+"'"
      When "typeretfin"     : [L]CRITERE(0) -= "& SRHTYP<='"+num$([L]VALEUR)+"'"
      When "datedeb"        : [L]DATREF   = gdat$(val(right$([L]VALEUR,7)),
&                                        val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                              [L]CRITERE(0) -= "& RTNDAT >=["+format$(GFMD,[L]DATREF)+']'
      When "datefin"        : [L]DATREF   = gdat$(val(right$([L]VALEUR,7)),
&                                        val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                              [L]CRITERE(0) -= "& RTNDAT <=["+format$(GFMD,[L]DATREF)+']'
      When "categretdeb"    : [L]CRITERE(1) -= "& SRHCAT >="+[L]VALEUR
      When "categretfin"    : [L]CRITERE(1) -= "& SRHCAT <="+[L]VALEUR
      When "numedt"         : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
      When "seqedt"         : [L]PARAMETRE(I) = "seqedt=0"
      When "usr"            : [L]PARAMETRE(I) = "usr="+GUSER
      When "etat"           : [L]PARAMETRE(I) = "etat="+[L]ETAT
    Endcase
  Endif
Next

Call DEBTRANS From GLOCK
Trbegin [ARM], [TRPT]

Raz [F:ARM] #Do not move this to ALIM_ARM

For [SRH] Where evalue([L]CRITERE(0)) & evalue([L]CRITERE(1))
  Gosub ALIM_ARM
Next

If GOK<1  Rollback  Else  Commit : Endif

End
#########################################################################
#########################################################################
$OUVRE

Local File TMPSRPT    [TRPT]
Local File SRETURN    [SRH]
Local File AREPORTM   [ARM]

Return
#########################################################################
#########################################################################
$DECLARE

Local Integer I, J , NBRCOPIE    # Issue 18041 - 2017-02-03 by VAVIL : Original\Duplicate\Triplicate transport docs
Local Char    PARAM(30), VALEUR(30)
Local Char    CRITERE(255)(0..1), ETAT(15)
Local Integer NUMREQ , KPOACT ,GLBDOCFLG # Issue 18041 - 2017-02-03 by VAVIL : Original\Duplicate\Triplicate transport docs
Local Date    DATREF

Return
#########################################################################
#########################################################################
$ALIM_ARM

[F:ARM]CLEA1   = [F:SRH]SRHNUM
[F:ARM]CREDAT  = date$
[F:ARM]NUMREQ  = [L]NUMREQ
[F:ARM]RPTCOD  = [F:ARP]RPTCOD
[F:ARM]USR     = GUSER
[F:ARM]NUMCOP  = 0

# Issue 18041 - 2017-02-03 by VAVIL : Original\Duplicate\Triplicate transport docs
# Issue 18041
[L]KPOACT = func AFNC.ACTIV("KPO")
[L]GLBDOCFLG = 1
If [L]KPOACT
  [L]GLBDOCFLG = [F:SRH]GLBDOCR
Endif

If  [L]GLBDOCFLG = 2
  For [L]NBRCOPIE = 1 To 3
    [F:ARM]NUMLIG += 1
    [F:ARM]NUMCOP  = [L]NBRCOPIE
    Write [F:ARM]
    If fstat : GOK=0 : Call FSTA("ARM") From GLOCK : Endif
  Next
Else
  [F:ARM]NUMLIG += 1
  Write [F:ARM]
  If fstat : GOK=0 : Call FSTA("ARM") From GLOCK : Endif
Endif

If [L]KPOACT :  Gosub ALIM_TMPSRPT :  Endif

Return
#########################################################################
#########################################################################
$ALIM_TMPSRPT

Raz [F:TRPT]

[F:TRPT] = [F:ARM]
[F:TRPT]VCRNUM = [F:SRH]SRHNUM

Write [F:TRPT]
If fstat : GOK=0 : Call FSTA("TRPT") From GLOCK : Endif

Return
#########################################################################
#########################################################################

