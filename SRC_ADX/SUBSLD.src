#<AdxTL>@(#)208.0.0.0 $Revision$
Call OBJET ("SLD",GBIDC1,GBIDC2) From GOBJET
End
#######################################################################
# SUBSLD : Transactions de saisie des livraisons         JL  23/04/98 #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:SLQ]SALTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                                                                     #
# Génération des  écrans de saisie à partir des écrans de base SDH1   #
#                                                              SDH2   #
#                                                              SDH3   #
#                                                                     #
# Nom des écrans générés : WKxyyyz                                    #
#                            x = type de la transaction (STRTYP)      #
#                                1 -    devis                         #
#                                2 -    commandes                     #
#                                3 -    commandes ouvertes            #
#                                4 -    livraison                     #
#                                5 -    factures / avoirs             #
#                                6 -    retours                       #
#                                7 -    retours prêt                  #
#                                                                     #
#                          yyy = no de la transaction   (STRNUM)      #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                1 et 2     devis                     #
#                                1 2 3 et 4 commande                  #
#                                1 et 2     cde ouverte               #
#                                1 2 3      livraison                 #
#                                1 2 et 4   facture                   #
#######################################################################
$ACTION

Case ACTION
 When "OUVRE"       : Gosub OUVRE
                      Gosub OUVRE From SUBSLX
                      Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="SLT"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=4
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "EFFMASK"     : [M]STRTYP = 4
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="SLT"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
                      Gosub ANNULE From SUBSLX
 When "LIENS"       : Gosub TRT_DIETRS From SUBDST : Gosub LIENS  : Gosub LIENS From SUBSLX
 When "APRES_MODIF" : Gosub APRES_MODIF From SUBSLX
 When "INICRE"      : Gosub INICRE From SUBSLX
 When "INIMOD"      : Gosub INICRE From SUBSLX
 When "SEL_TABLE"   : Gosub SEL_TABLE  : # Sélection sur code pièce auto stock
 When Default
Endcase
Return

#-------------------------------------------------------#
#                                                       #
#-------------------------------------------------------#
$OUVRE
GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto stock
Local Char APPLI
APPLI=nomap
Return

#-------------------------------------------------------#
$SEL_TABLE
#---------------------#
# Sélection sur champ #
#---------------------#
Case COUZON
  When "ENTCOD"   : # Pièce auto de sortie stock
    OBJET="GAU"
    CRITERE="TBL='STJTMP'"
Endcase
Return

#-------------------------------------------------------#
# Ne traiter que les transactions de type livraison     #
#-------------------------------------------------------#
$FILTRE
FILTSUP="STRTYP=4"
Return

#---------------------------------#
# Désactivation des boutons       #
#---------------------------------#
$SETBOUT
If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif

GMENLOC(4)=1

Return

#-------------------------------------#
# Après appui sur les boutons         #
#-------------------------------------#
$EXEBOUT
Case BOUT
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

$LIENS
If dim([M:SLD1]WRHCOD)>0
   If [M:SLD1]WRHCOD=0   [M:SLD1]WRHCOD=3  Endif
   If [M:SLD1]WRHOBY = 2
      Grizo [M:SLD1]WRHCOD
   Else
      Actzo [M:SLD1]WRHCOD
   Endif
Endif
If dim([M:SLS1]WRHCOD1)>0
   If [M:SLS1]WRHCOD1=0  [M:SLS1]WRHCOD1=3  : Endif
   Actzo [M:SLS1]WRHCOD1
   If [M:SLS1]WRHCOD1=3  Grizo [SLS1]WRHSCR1  Else Actzo [SLS1]WRHSCR1  : Endif
Endif

Return

$RAZCRE
[M:SLD0]ENAFLG = 2
#--- Dépôt
If dim([M:SLD1]WRHCOD)>0
  If [M:SLD1]WRHOBY=2
    [M:SLD1]WRHCOD=1
    Diszo [M:SLD1]WRHCOD
  Else
    [M:SLD1]WRHCOD=3
    Actzo [M:SLD1]WRHCOD
  Endif
Endif
If dim([M:SLS1]WRHCOD1)>0
  [M:SLS1]WRHCOD1=3
  [M:SLS1]WRHSCR1=1
Endif

Return

#------------------------------------------------#
# Génération ou suppression de l'écran de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(APPLI)<0 Local Char APPLI : Endif
If APPLI=""     APPLI=nomap      : Endif
Local Char    MFROM(GLONAMK)
Local Char    MTO(GLONAMK)
Local Integer TBLOC(15)
Local Char    TZONE(GLONAVA)(200)
Local Integer TMOD(200)
Local Char    TINT(1)(200)
Local Char    TTAB(1)(1)
Local Char    TFLD(1)(1)
Local Integer OPT1, OPT2, OPT3, RETOUR
Local Integer IZON, I, FLAG
# Local Char BOUTONS(10)(4), TEXTE(40), LISTE(3), REPONS(1)

#------------------------- écran SDH1 -------------------------#
Local Char    ZT : # nom de zone dans table transaction
Local Char    ZM : # nom de zone dans le masque
Local Integer ZI : # pour les zones indicées

MFROM="SDH1"
MTO="WK"+num$([M:SLD0]STRTYP)+[M:SLD0]STRNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If   ACTION <> "ANNULE"
     #---- Dépôt
     If dim([M:SLD1]WRHCOD)>0
        If [M:SLD1]WRHCOD>1 TZONE(IZON)="WRHE"
                            TMOD(IZON) =[M:SLD1]WRHCOD
                            IZON+=1
        Endif     : # Bug 72355
     Else
        # Bug 63618
        # Gestion des dépots désactivée (Code activité WRH inactif) : Forcer le champ WRHE invisible
        TZONE(IZON)="WRHE"
        TMOD(IZON) =3
        IZON+=1
        # Bug 63618
     Endif
     #---- date expédition
     If   [M:SLD2]SHIDATCOD > 1 TZONE(IZON)="SHIDAT"
                                TMOD(IZON) =[M:SLD2]SHIDATCOD
                                IZON+=1
     Endif
     #---- délai livraison
     If   [M:SLD2]DAYLTICOD > 1 TZONE(IZON)="DAYLTI"
                                TMOD(IZON) =[M:SLD2]DAYLTICOD
                                IZON+=1
     Endif
     #---- date livraison
     If   [M:SLD2]DLVDATCOD > 1 TZONE(IZON)="DLVDAT"
                                TMOD(IZON) =[M:SLD2]DLVDATCOD
                                IZON+=1
     Endif
     #---- date retour prêt
     If   [M:SLD2]LNDRTNCOD > 1 TZONE(IZON)="LNDRTNDAT"
                                TMOD(IZON) =[M:SLD2]LNDRTNCOD
                                IZON+=1
     Endif
     #---- inter-sites
     If   [M:SLD4]BETFCYCOD = 1 TZONE(IZON)="BETFCY"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- inter-sociétés
     If   [M:SLD4]BETCPYCOD = 1 TZONE(IZON)="BETCPY"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- devise
     If   [M:SLD2]CURCOD    > 1 TZONE(IZON)="CUR"
                                TMOD(IZON) =[M:SLD2]CURCOD
                                IZON+=1
     Endif
     #---- prix HT/TTC
     If   [M:SLD2]PRITYPCOD > 1 TZONE(IZON)="PRITYP"
                                TMOD(IZON) =[M:SLD2]PRITYPCOD
                                IZON+=1
     Endif
     #---- Tableau des lignes détail
     #---- désignation traduite de l'article
     If   [M:SLD3]ITMDESCOD > 1 TZONE(IZON)="ITMDES"
                                TMOD(IZON) =[M:SLD3]ITMDESCOD
                                IZON+=1
     Endif
     If   [M:SLD3]ITMDESCOD = 1 | [M:SLD3]ITMDESCOD = 2
        ZT="ITMDESSCR" : ZM="ITMDES" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- désignation standard de l'article
     If   [M:SLD3]ITMDES1COD> 1 TZONE(IZON)="ITMDES1"
                                TMOD(IZON) =[M:SLD3]ITMDES1COD
                                IZON+=1
     Endif
     If   [M:SLD3]ITMDES1COD = 1 | [M:SLD3]ITMDES1COD = 2
        ZT="ITMDES1SCR" : ZM="ITMDES1" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     # FGR 04/02/2015 : X3SUIVI105605 (début)
     If func AFNC.ACTIV("ECC") Then
       #---- Version majeure
       If   [M:SLD3]ECCCOD> 1     TZONE(IZON)="ECCVALMAJ"
                                  TMOD(IZON) =[M:SLD3]ECCCOD
                                  IZON+=1
       Endif
       If   [M:SLD3]ECCCOD = 1 | [M:SLD3]ECCCOD = 2
          ZT="ECCSCR" : ZM="ECCVALMAJ" : Gosub TABLEAU_FICHE From SUBSLX
       Endif
       #---- Version mineure
       If   [M:SLD3]ECCCODMIN> 1  TZONE(IZON)="ECCVALMIN"
                                  TMOD(IZON) =[M:SLD3]ECCCODMIN
                                  IZON+=1
       Endif
       If   [M:SLD3]ECCCODMIN = 1 | [M:SLD3]ECCCODMIN = 2
          ZT="ECCSCRMIN" : ZM="ECCVALMIN" : Gosub TABLEAU_FICHE From SUBSLX
       Endif
     Endif
     # FGR 04/02/2015 : X3SUIVI105605 (fin)
     #---- unité de vente
     If   [M:SLD3]SAUCOD    > 1 TZONE(IZON)="SAU"
                                TMOD(IZON) =[M:SLD3]SAUCOD
                                IZON+=1
     Endif
     If   [M:SLD3]SAUCOD = 1 | [M:SLD3]SAUCOD = 2
        ZT="SAUSCR" : ZM="SAU" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- coef UV-US
     If   [M:SLD3]SAUCOECOD > 1 TZONE(IZON)="SAUSTUCOE"
                                TMOD(IZON) =[M:SLD3]SAUCOECOD
                                IZON+=1
     Endif
     If   [M:SLD3]SAUCOECOD = 1 | [M:SLD3]SAUCOECOD = 2
        ZT="SAUCOESCR" : ZM="SAUSTUCOE" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- unité de stock
     If   [M:SLD4]STUCOD = 1    TZONE(IZON)="STU"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="STUSCR" : ZM="STU" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- prix brut
     If   [M:SLD3]GROPRICOD > 1 TZONE(IZON)="GROPRI"
                                TMOD(IZON) =[M:SLD3]GROPRICOD
                                IZON+=1
     Endif
     If   [M:SLD3]GROPRICOD = 1 | [M:SLD3]GROPRICOD = 2
        ZT="GROPRISCR" : ZM="GROPRI" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- valeur1 remise/frais
     If   dim([M:SLX1]DISCRGCOD1) > 0
          If  [M:SLX1]DISCRGCOD1 > 1 TZONE(IZON)="DISCRGVAL1"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD1
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD1 = 1 | [M:SLX1]DISCRGCOD1 = 2
             ZT="DISCRGSCR1" : ZM="DISCRGVAL1" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif
     #---- valeur2 remise/frais
     If   dim([M:SLX1]DISCRGCOD2) > 0
          If  [M:SLX1]DISCRGCOD2 > 1 TZONE(IZON)="DISCRGVAL2"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD2
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD2 = 1 | [M:SLX1]DISCRGCOD2 = 2
             ZT="DISCRGSCR2" : ZM="DISCRGVAL2" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif
     #---- valeur3 remise/frais
     If   dim([M:SLX1]DISCRGCOD3) > 0
          If  [M:SLX1]DISCRGCOD3 > 1 TZONE(IZON)="DISCRGVAL3"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD3
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD3 = 1 | [M:SLX1]DISCRGCOD3 = 2
             ZT="DISCRGSCR3" : ZM="DISCRGVAL3" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif
     #---- valeur4 remise/frais
     If   dim([M:SLX1]DISCRGCOD4) > 0
          If  [M:SLX1]DISCRGCOD4 > 1 TZONE(IZON)="DISCRGVAL4"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD4
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD4 = 1 | [M:SLX1]DISCRGCOD4 = 2
             ZT="DISCRGSCR4" : ZM="DISCRGVAL4" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif
     #---- valeur5 remise/frais
     If   dim([M:SLX1]DISCRGCOD5) > 0
          If  [M:SLX1]DISCRGCOD5 > 1 TZONE(IZON)="DISCRGVAL5"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD5
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD5 = 1 | [M:SLX1]DISCRGCOD5 = 2
             ZT="DISCRGSCR5" : ZM="DISCRGVAL5" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif
     #---- valeur6 remise/frais
     If   dim([M:SLX1]DISCRGCOD6) > 0
          If  [M:SLX1]DISCRGCOD6 > 1 TZONE(IZON)="DISCRGVAL6"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD6
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD6 = 1 | [M:SLX1]DISCRGCOD6 = 2
             ZT="DISCRGSCR6" : ZM="DISCRGVAL6" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif
     #---- valeur7 remise/frais
     If   dim([M:SLX1]DISCRGCOD7) > 0
          If  [M:SLX1]DISCRGCOD7 > 1 TZONE(IZON)="DISCRGVAL7"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD7
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD7 = 1 | [M:SLX1]DISCRGCOD7 = 2
             ZT="DISCRGSCR7" : ZM="DISCRGVAL7" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif
     #---- valeur8 remise/frais
     If   dim([M:SLX1]DISCRGCOD8) > 0
          If  [M:SLX1]DISCRGCOD8 > 1 TZONE(IZON)="DISCRGVAL8"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD8
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD8 = 1 | [M:SLX1]DISCRGCOD8 = 2
             ZT="DISCRGSCR8" : ZM="DISCRGVAL8" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif
     #---- valeur9 remise/frais
     If   dim([M:SLX1]DISCRGCOD9) > 0
          If  [M:SLX1]DISCRGCOD9 > 1 TZONE(IZON)="DISCRGVAL9"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD9
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD9 = 1 | [M:SLX1]DISCRGCOD9 = 2
             ZT="DISCRGSCR9" : ZM="DISCRGVAL9" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif
     #---- prix net
     If   [M:SLD4]NETPRICOD = 1 TZONE(IZON)="NETPRI"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="NETPRISCR" : ZM="NETPRI" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- prix revient
     If   [M:SLD3]CPRPRICOD > 1 TZONE(IZON)="CPRPRI"
                                TMOD(IZON) =[M:SLD3]CPRPRICOD
                                IZON+=1
     Endif
     If   [M:SLD3]CPRPRICOD = 1 | [M:SLD3]CPRPRICOD = 2
        ZT="CPRPRISCR" : ZM="CPRPRI" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- marge détail
     If   [M:SLD4]PFMCOD    = 1 TZONE(IZON)="PFM"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="PFMSCR" : ZM="PFM"    : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- niveau de taxe
     If   [M:SLD3]VACITMCOD > 1 TZONE(IZON)="VACITM1"
                                TMOD(IZON) =[M:SLD3]VACITMCOD
                                IZON+=1
                                TZONE(IZON)="VACITM2"
                                TMOD(IZON) =[M:SLD3]VACITMCOD
                                IZON+=1
                                TZONE(IZON)="VACITM3"
                                TMOD(IZON) =[M:SLD3]VACITMCOD
                                IZON+=1
                                TZONE(IZON)="SSTCOD"            # 101380.n
                                TMOD(IZON) =[M:SLD3]VACITMCOD   # 101380.n
                                IZON+=1                         # 101380.n
     Endif
     If   [M:SLD3]VACITMCOD = 1 | [M:SLD3]VACITMCOD = 2
        ZT="VACITMSCR" : ZM="VACITM1" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="VACITMSCR" : ZM="VACITM2" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="VACITMSCR" : ZM="VACITM3" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="VACITMSCR" : ZM="SSTCOD"  : Gosub TABLEAU_FICHE From SUBSLX   # 101380.n
     Endif
     #---- emballage / capacité embal.
     If   [M:SLD3]PCKCOD    > 1 TZONE(IZON)="PCK"
                                TMOD(IZON) =[M:SLD3]PCKCOD
                                IZON+=1
                                TZONE(IZON)="PCKCAP"
                                TMOD(IZON) =[M:SLD3]PCKCOD
                                IZON+=1
     Endif
     If   [M:SLD3]PCKCOD = 1 | [M:SLD3]PCKCOD = 2
        ZT="PCKSCR" : ZM="PCK"    : Gosub TABLEAU_FICHE From SUBSLX
        ZT="PCKSCR" : ZM="PCKCAP" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- unité poids / poids unitaire.
     If   [M:SLD3]WEICODD   > 1 TZONE(IZON)="XWEU"
                                TMOD(IZON) =[M:SLD3]WEICODD
                                IZON+=1
                                TZONE(IZON)="UNTWEI"
                                TMOD(IZON) =[M:SLD3]WEICODD
                                IZON+=1
     Endif
     If   [M:SLD3]WEICODD = 1 | [M:SLD3]WEICODD = 2
        ZT="WEISCRD" : ZM="XWEU"   : Gosub TABLEAU_FICHE From SUBSLX
        ZT="WEISCRD" : ZM="UNTWEI" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- lieu de consommation
     If   [M:SLD3]USEPLCCOD > 1 TZONE(IZON)="USEPLC"
                                TMOD(IZON) =[M:SLD3]USEPLCCOD
                                IZON+=1
     Endif
     If   [M:SLD3]USEPLCCOD = 1 | [M:SLD3]USEPLCCOD = 2
        ZT="USEPLCSCR" : ZM="USEPLC" : Gosub TABLEAU_FICHE From SUBSLX
     Endif

     If [M:DST]CCESCR>1
       For I=0 To 19
         TZONE(IZON)="CCE"+num$(I+1)
         TMOD(IZON) =9
         TINT(IZON) =num$([M:DST]CCESCR)
         IZON+=1
       Next I
     Endif

     #---- quantité retour
     If   [M:SLD4]RTNQTYCOD = 1 TZONE(IZON)="RTNQTY"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="RTNQTYSCR" : ZM="RTNQTY" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- no commande
     If   [M:SLD4]ORDCODD   = 1 TZONE(IZON)="XSOHNUM"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="ORDSCRD" : ZM="XSOHNUM" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- no piece origine (ordre fabrication ou de sous-traitance)
     If   [M:SLD4]VCRNUMOCOD = 1 TZONE(IZON)="VCRNUMORI"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="VCRNUMOSCR" : ZM="VCRNUMORI" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- montant de la livraison
     If   [M:SLD4]AMTCOD    = 1 TZONE(IZON)="DLVNOT"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="DLVINVNOT"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="DLVINVATI"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- état livraison (BP imprimé, BL imprimé, Etat livraison, facture)
     If   [M:SLD4]STACOD = 1 TZONE(IZON)="PRNNPR"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="PRNNDE"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="CFMFLG"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="INVFLG"
                             TMOD(IZON) =3
                             IZON+=1
                             # 40127 : Return status management
                             TZONE(IZON)="RTNSTA"
                             TMOD(IZON) =3
                             IZON+=1
                             # 40127
Endif
     #---- numéro de facture
     If   [M:SLD4]INVNUMCOD = 1  TZONE(IZON)="SIHNUM"
                                 TMOD(IZON) =3
                                 IZON+=1
     Endif

     #---- Lot
     If   dim([M:SLS1]LOTCOD) > 0
          If  [M:SLS1]LOTCOD > 1 TZONE(IZON)="LOT"
                                     TMOD(IZON) =[M:SLS1]LOTCOD
                                     IZON+=1
          Endif
          If   [M:SLS1]LOTCOD = 1 | [M:SLS1]LOTCOD = 2
             ZT="LOTSCR" : ZM="LOT" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- Sous-Lot
     If   dim([M:SLS1]SLOCOD) > 0
          If  [M:SLS1]SLOCOD > 1 TZONE(IZON)="SLO"
                                     TMOD(IZON) =[M:SLS1]SLOCOD
                                     IZON+=1
          Endif
          If   [M:SLS1]SLOCOD = 1 | [M:SLS1]SLOCOD = 2
             ZT="SLOSCR" : ZM="SLO" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- Statut
     If   dim([M:SLS1]AQRCOD) > 0
          If  [M:SLS1]AQRCOD > 1 TZONE(IZON)="STA"
                                     TMOD(IZON) =[M:SLS1]AQRCOD
                                     IZON+=1
          Endif
          If   [M:SLS1]AQRCOD = 1 | [M:SLS1]AQRCOD = 2
             ZT="AQRSCR" : ZM="STA" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- Emplacement
     If   dim([M:SLS1]LOCCOD) > 0
          If  [M:SLS1]LOCCOD > 1 TZONE(IZON)="LOC"
                                     TMOD(IZON) =[M:SLS1]LOCCOD
                                     IZON+=1
          Endif
          If   [M:SLS1]LOCCOD = 1 | [M:SLS1]LOCCOD = 2
             ZT="LOCSCR" : ZM="LOC" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- Série début
     If   dim([M:SLS1]SERCOD) > 0
          If  [M:SLS1]SERCOD > 1 TZONE(IZON)="SERNUM"
                                     TMOD(IZON) =[M:SLS1]SERCOD
                                     IZON+=1
          Endif
          If   [M:SLS1]SERCOD = 1 | [M:SLS1]SERCOD = 2
             ZT="SERSCR" : ZM="SERNUM" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- Série fin
     If   dim([M:SLS1]SERECOD) > 0
          If  [M:SLS1]SERECOD > 1 TZONE(IZON)="SERNUMF"
                                     TMOD(IZON) =[M:SLS1]SERECOD
                                     IZON+=1
          Endif
          If   [M:SLS1]SERECOD = 1 | [M:SLS1]SERECOD = 2
             ZT="SERESCR" : ZM="SERNUMF" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- Dépôt
     If dim([M:SLS1]WRHCOD1)>0
        If [M:SLS1]WRHCOD1>1  TZONE(IZON)="WRH"
                              TMOD(IZON) =[M:SLS1]WRHCOD1
                              IZON+=1
        Endif
        If [M:SLS1]WRHSCR1>1  TZONE(IZON)="WRH"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SLS1]WRHSCR1)
                              IZON+=1
        Endif
     Endif

     #---- Identifiant 1
     If   dim([M:SLS1]IDECOD01) > 0
          If  [M:SLS1]IDECOD01 > 1 TZONE(IZON)="PALNUM"
                                     TMOD(IZON) =[M:SLS1]IDECOD01
                                     IZON+=1
          Endif
          If   [M:SLS1]IDECOD01 = 1 | [M:SLS1]IDECOD01 = 2
             ZT="IDESCR01" : ZM="PALNUM" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif
     #---- Identifiant 2
     If   dim([M:SLS1]IDECOD02) > 0
          If  [M:SLS1]IDECOD02 > 1 TZONE(IZON)="CTRNUM"
                                     TMOD(IZON) =[M:SLS1]IDECOD02
                                     IZON+=1
          Endif
          If   [M:SLS1]IDECOD02 = 1 | [M:SLS1]IDECOD02 = 2
             ZT="IDESCR02" : ZM="CTRNUM" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif
     #---- Désigation mouvement
     If   dim([M:SLS1]MVTDESCOD) > 0
          If  [M:SLS1]MVTDESCOD > 1 TZONE(IZON)="MVTDES"
                                     TMOD(IZON) =[M:SLS1]MVTDESCOD
                                     IZON+=1
          Endif
          If   [M:SLS1]MVTDESCOD = 1 | [M:SLS1]MVTDESCOD = 2
             ZT="MVTDESSCR" : ZM="MVTDES" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif
     #--CPO 71065 Code affaire en-tête / lignes
     If   [M:SLD3]PJTCODD > 1   TZONE(IZON)="DPJT"
                                TMOD(IZON) =[M:SLD3]PJTCODD
                                IZON+=1
     Endif

#### X3-81835  : LPN - sales Issues documents / X3-81989 (LCC 20/03/18)

     If dim([M:SLS1]LPNCOD)>0
      If [M:SLS1]LPNCOD>1    TZONE(IZON)="LPNNUM"             : # Numéro de contenant
                             TMOD(IZON) =[M:SLS1]LPNCOD
                             IZON+=1
      Endif
      If [M:SLS1]LPNSCR>1    TZONE(IZON)="LPNNUM"             : # Numéro de contenant
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SLS1]LPNSCR)
                             IZON+=1
      Endif
     Endif
#### End X3-81835  : LPN - sales Issues documents / X3-81989 (LCC 20/03/18)

     # Issue X3-69499 - 2018-06-08 by TS
     #---- Flag ligne livraison validée et validée partiellement invisibles
     #---- si code activité CDV actif (validation livraison complète)
     #---- ou si pas d'affichage de l'état livraison
     If func AFNC.ACTIV("CDV") | [M:SLD4]STACOD=1
       TZONE(IZON)="LINCFMFLG" : TMOD(IZON)=3 : IZON+=1
       TZONE(IZON)="CFMPAR"    : TMOD(IZON)=3 : IZON+=1
     Endif
     # End issue X3-69499

     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX

     #---- VISUALISATION DU MASQUE GéNéRé
     OPT1 = 2
#     If ACTION<>"MASSE"
#        BOUTONS(1)=mess(2,1,1)    : # Oui
#        BOUTONS(2)=mess(1,1,1)    : # Non
#        BOUTONS(3)=mess(71,198,1) : # Abandon
#        TEXTE= " "+mess(1,196,1)  : LISTE="ONA" : REPONS="N"
#        Call CHOIXM(BOUTONS,TEXTE,LISTE,REPONS) From TRTX3
#        If REPONS="A" GOK=0  : Return : Endif
#        If REPONS="O" OPT2=1 : Endif
#     Endif
     #---- suppression du masque
Else OPT1=9
Endif
Local Char NBRC_MSK   (12) : NBRC_MSK=MFROM
Local Char NBRC_NBLIG (12) : NBRC_NBLIG="NBLIG"
Gosub NBR_COL_AV From SUBSLX   : If GOK<1 Return Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif
Gosub NBR_COL_AP From SUBSLX   : If GOK<1 Return Endif

#------------------------- écran SDH2 -------------------------#
MFROM="SDH2"
MTO="WK"+num$([M:SLD0]STRTYP)+[M:SLD0]STRNUM+"2"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
     #---- tiers payeur
     If   [M:SLD2]BPCPYRCOD > 1 TZONE(IZON)="BPCPYR"
                                TMOD(IZON) =[M:SLD2]BPCPYRCOD
                                IZON+=1
     Endif
     #---- client groupe
     If   [M:SLD2]BPCGRUCOD > 1 TZONE(IZON)="BPCGRU"
                                TMOD(IZON) =[M:SLD2]BPCGRUCOD
                                IZON+=1
     Endif
     #---- no tournée
     If   [M:SLD2]DRNCOD > 1    TZONE(IZON)="DRN"
                                TMOD(IZON) =[M:SLD2]DRNCOD
                                IZON+=1
     Endif
     #---- mode livraison
     If   [M:SLD2]MDLCOD    > 1 TZONE(IZON)="MDL"
                                TMOD(IZON) =[M:SLD2]MDLCOD
                                IZON+=1
     Endif
     #---- transporteur
     If   [M:SLD2]BPTNUMCOD > 1 TZONE(IZON)="BPTNUM"
                                TMOD(IZON) =[M:SLD2]BPTNUMCOD
                                IZON+=1
     Endif
     #---- CPO 65018
     #---- Incoterm et ville Incoterm
     If   [M:SLD2]EECICTCOD > 1 TZONE(IZON)="EECICT"
                                TMOD(IZON) =[M:SLD2]EECICTCOD
                                IZON+=1
                                TZONE(IZON)="ICTCTY"
                                TMOD(IZON) =[M:SLD2]EECICTCOD
                                IZON+=1
     Endif
     #---- 101090 - Bill of lading fields
     If   [M:SLD2]BOLCOD > 1    TZONE(IZON)="BOLNUM"
                                TMOD(IZON) =[M:SLD2]BOLCOD
                                IZON+=1
                                TZONE(IZON)="SCAC"
                                TMOD(IZON) =[M:SLD2]BOLCOD
                                IZON+=1
                                TZONE(IZON)="PRONUM"
                                TMOD(IZON) =[M:SLD2]BOLCOD
                                IZON+=1
                                TZONE(IZON)="TRAILER"
                                TMOD(IZON) =[M:SLD2]BOLCOD
                                IZON+=1
     Endif
     #---- numéro de proforma
     If   [M:SLD4]PRFNUMCOD = 1  TZONE(IZON)="PRFNUM"
                                 TMOD(IZON) =3
                                 IZON+=1
     Endif
     #---- condition de paiement
     If   [M:SLD2]PTECOD    > 1 TZONE(IZON)="PTE"
                                TMOD(IZON) =[M:SLD2]PTECOD
                                IZON+=1
     Endif
     # V6.2 : 60763 Settlements Discounts
     #---- escompte
     If   [M:SLD2]DEPCOD    > 1 TZONE(IZON)="DEP"
                                TMOD(IZON) =[M:SLD2]DEPCOD
                                IZON+=1
     Endif
     # V6.2 : 60763 Settlements Discounts
     #---- régime de taxe
     If   [M:SLD2]VACBPRCOD > 1 TZONE(IZON)="VACBPR"
                                TMOD(IZON) =[M:SLD2]VACBPRCOD
                                IZON+=1
     Endif
     #LTA.sn entity/use code for local taxing
     If func AFNC.ACTIV("LTA") and [M:SLD2]SSTENTCOD > 1
                                TZONE(IZON)="SSTENTCOD"
                                TMOD(IZON) =[M:SLD2]SSTENTCOD
                                IZON+=1
     Endif
     #LTA.en
     #---- représentants
     If   [M:SLD2]REPCOD > 1    TZONE(IZON)="REP"
                                TMOD(IZON) =[M:SLD2]REPCOD
                                IZON+=1
     Endif
     #--CPO 71065 Code affaire en-tête / lignes
     If   [M:SLD2]PJTCOD > 1   TZONE(IZON)="PJT"
                               TMOD(IZON) =[M:SLD2]PJTCOD
                               IZON+=1
     Endif
     #---- poids
     If   [M:SLD2]WEICOD    > 1 TZONE(IZON)="WEU"
                                TMOD(IZON) =[M:SLD2]WEICOD
                                IZON+=1
                                TZONE(IZON)="NETWEI"
                                TMOD(IZON) =[M:SLD2]WEICOD
                                IZON+=1
                                TZONE(IZON)="GROWEI"
                                TMOD(IZON) =[M:SLD2]WEICOD
                                IZON+=1
     Endif
     #---- volume
     If   [M:SLD2]VOLCOD    > 1 TZONE(IZON)="VOU"
                                TMOD(IZON) =[M:SLD2]VOLCOD
                                IZON+=1
                                TZONE(IZON)="VOL"
                                TMOD(IZON) =[M:SLD2]VOLCOD
                                IZON+=1
     Endif
     #---- nb colis
     If   [M:SLD2]PACNBRCOD > 1 TZONE(IZON)="PACNBR"
                                TMOD(IZON) =[M:SLD2]PACNBRCOD
                                IZON+=1
     Endif
     #------- Test si tous les éléments de facturation sont affichées --------#
     If   [M:SLD1]INVDTACOD= 2 TZONE(IZON)="INVDTAAMT"
                               TMOD(IZON)=2
                               #TBLOC(4)=2 ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
                               IZON+=1
                               TZONE(IZON)="INVDTATYP"
                               TMOD(IZON) =2
                               #TBLOC(4)=2 ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
                               IZON+=1
                               TZONE(IZON)="SFISSTCOD" # 101380.n
                               TMOD(IZON) =2           # 101380.n
                               #TBLOC(4)=2              # 101380.n ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
                               IZON+=1                 # 101380.n
     Endif
     #------- Test si tous les éléments de facturation sont invisibles --------#
     If   [M:SLD1]INVDTACOD=3  TBLOC(4)=1 Endif

     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX

Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
#---- erreur
If RETOUR<>0 GOK=0 : Return : Endif

#------------------------- écran SDH3 -------------------------#
MFROM="SDH3"
MTO="WK"+num$([M:SLD0]STRTYP)+[M:SLD0]STRNUM+"3"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
     #---- matricule
     If   [M:SLD2]LICPLATCOD > 1 TZONE(IZON)="LICPLATE"
                                TMOD(IZON) =[M:SLD2]LICPLATCOD
                                IZON+=1
     Endif
     #---- matricule remorque          # FGR 04/07/2014 : X3SUIVI91606
     If   [M:SLD2]TRAPLTCOD > 1 TZONE(IZON)="TRLLICPLATE"
                                TMOD(IZON) =[M:SLD2]TRAPLTCOD
                                IZON+=1
     Endif
     #---- date départ                 # FGR 04/07/2014 : X3SUIVI91606
     If   [M:SLD2]DPEDATCOD > 1 TZONE(IZON)="DPEDAT"
                                TMOD(IZON) =[M:SLD2]DPEDATCOD
                                IZON+=1
     Endif
     #---- date arrivée                # FGR 04/07/2014 : X3SUIVI91606
     If   [M:SLD2]ARVDATCOD > 1 TZONE(IZON)="ARVDAT"
                                TMOD(IZON) =[M:SLD2]ARVDATCOD
                                IZON+=1
     Endif
     #---- heure départ
     If   [M:SLD2]ETDCOD     > 1 TZONE(IZON)="ETD"
                                TMOD(IZON) =[M:SLD2]ETDCOD
                                IZON+=1
     Endif
     #---- heure arrivée
     If   [M:SLD2]ETACOD     > 1 TZONE(IZON)="ETA"
                                TMOD(IZON) =[M:SLD2]ETACOD
                                IZON+=1
     Endif
     #---- famille mouvement
     If   [M:SLD2]TRSFAMCOD  > 1 TZONE(IZON)="TRSFAM"
                                TMOD(IZON) =[M:SLD2]TRSFAMCOD
                                IZON+=1
     Endif
     #---- emplacement
     If   [M:SLD2]BPCLOCCOD  > 1 TZONE(IZON)="BPCLOC"
                                TMOD(IZON) =[M:SLD2]BPCLOCCOD
                                IZON+=1
     Endif
     #----- Test si les sections d'entête sont affichées -----#
     If dim([M:DST]HEACCECOD)>0 & [M:DST]HEACCECOD=2
        TZONE(IZON)="CCE"
        TMOD(IZON)=2
        # TBLOC(2)=2 ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
        IZON+=1
     Endif
     #----- Test si les sections d'entête sont invisibles -----#
     If (dim([M:DST]HEACCECOD)>0 & [M:DST]HEACCECOD=3) | dim([M:DST]HEACCECOD)<1
        TZONE(IZON)="CCE"
        TMOD(IZON)=3
        IZON+=1

        TBLOC(2)=1
     Endif
     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX

Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
#---- erreur
If RETOUR<>0 GOK=0 : Return : Endif

#---- suppression ou génération fenêtre AWINDOW
If ACTION="ANNULE"
  Gosub TRT_SUP_FEN From SUBSLX
Else
  Gosub TRT_GEN_FEN From SUBSLX
Endif
If GOK<1 : Return : Endif
Return


########################################
Subprog AV_ENAFLG(VALEUR)
Variable Integer VALEUR
If GREP<>"C" & VALEUR=0 VALEUR=2 : Endif
End
########################################
Subprog AM_PKGTYP(VALEUR)
Variable Integer VALEUR
Raz [M:SLD1]PKTNUM

End

#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(4)<>2 End Endif

# Validation transactions livraisons depuis génération des patchs
Call GENPATCH(4,APPLI) From FUNSALTRS

End
###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

# Génération transactions vente à partir du dico des types de transaction
Call GENDOS(4,APPLI) From FUNSALTRS

End

##########################################################################
# Vérification des paramètres transactions livraison (TRSLIV & TRSLND)   #
##########################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value    Char    PARAM
Value    Char    VALEUR
Variable Integer OK
Local    Integer TYP
#
If VALEUR = ""
  End
Else
  VALEUR = toupper(VALEUR)
Endif
Case PARAM
  When "TRSLIV" : TYP = 1
  When "TRSLND" : TYP = 2
  When Default     : End
Endcase
#
If clalev ([F:SLT]) = 0 : Local File SALTRS [SLT] : Endif
Read [SLT]SLT0 = 4;VALEUR

# X3-1152 : Non invoiceable deliveries
#If fstat | ([F:SLT]DLVTYP<>4 & [F:SLT]DLVTYP<>TYP) : # 75115 : V7 : Extension of Digital Signature
If fstat | ([F:SLT]DLVTYP<>4 & [F:SLT]DLVTYP<>TYP) : # 75115 : V7 : Extension of Digital Signature
# X3-1152 : Non invoiceable deliveries
  OK = 0
  GMESSAGE = mess(83,123,1) :  # ---  valeur incorrecte
Endif

End

########################################################
# Pour exécution de la copie en masse depuis le menu : #
# Utilitaires - Dictionnaire - Copie transactions      #
########################################################
$TRTCOP
Local Integer MODULE    : MODULE=5
Local Integer TYP       : TYP=4
Local Char    CODTAB(GLONTRS) : CODTAB=TABLE
#-----
Gosub OUVRE_COPTRS From SELTRS
Gosub EXEC_COPTRS  From SELTRS
Gosub FERME_COPTRS From SELTRS
Return

######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran SLD1) 23/09/2009 10:40:48 (TS)
######################################################################################
Subprog AM_WRHOBY(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
    [M:SLD1]WRHCOD = 1
    Grizo [M:SLD1]WRHCOD
    If [M:SLS1]WRHCOD1=1
       [M:SLS1]WRHCOD1=3
       [M:SLS1]WRHSCR1=1
    Endif
    If [M:SLS1]WRHCOD1=3
       Grizo [M:SLS1]WRHSCR1
    Else
       Actzo [M:SLS1]WRHSCR1
    Endif
Else
    Actzo [M:SLD1]WRHCOD
Endif
Affzo [M:SLD1]WRHCOD
Affzo [M:SLS1]WRHCOD1
Affzo [M:SLS1]WRHSCR1
End

######################################################################################
Subprog AS_BOLCOD(VALEUR)
Variable Integer VALEUR
# 101090 - Only allow BOL information to be displayed or hidden, not enterable.
GMENLOC(1)=1
End


