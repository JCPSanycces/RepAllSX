#** #####################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #####################################################################################

$ACTION
    Case ACTION
        When "OUVRE"    : Gosub OUVRE                 # Basic initialization.
        When "AV_CHOIX" : Gosub AV_CHOIX              # Initialize the fields by reading the parent screen.
        When "OK"       : VALEUR = "OK" : Gosub OK    # Write back the entered information.
        When Default    : Gosub ACTION From BIDLOCDE
    Endcase
Return



#** #####################################################################################
#*
#* Sub chunk:  OUVRE
#*
#* Purpose:    Handler before opening a window.
#*             Opens some needed tables and initializes some variables for further use.
#*
#*! #####################################################################################

$OUVRE
    Gosub OUVRE From BIDLOCDE
    [L]LENBANCOD = 0                                  # Reset size of bank sort code.
    [L]LENBANACC = 0                                  # Reset size of bank account number.
Return


#** #####################################################################################
#*
#* Sub chunk:  AV_CHOIX
#*
#* Purpose:    Handler before entering the window
#*             Reads data from the parent screen and prefills the local BID screen.
#*
#*! #####################################################################################

$AV_CHOIX
    Gosub AV_CHOIX From BIDLOCDE

    # Case distinction between BAN1 screen (GESBAN function) and the BIDxxx screens for
    # there are different field names and sometimes indexed fields (table view):
    If PARENTSCREEN = "BAN1"
        [M]IBACOD    = evalue( "[M:" + PARENTSCRABR + "]IBACOD" )
    Else
        Local Char IBAN(4)           # IBAN prefix (e. g. "DE91")
        Local Char BIDNUM(GLONBID)   # BIDNUM
        BIDNUM = evalue( "[M:" + PARENTSCRABR + "]BIDNUM("    + TABINDEX + ")" )
        IBAN   = evalue( "[M:" + PARENTSCRABR + "]IBAN("    + TABINDEX + ")" )
        [M]IBACOD = IBAN + BIDNUM
    Endif

    zonsui = "IBACOD"
Return



#** #####################################################################################
#*
#* Sub chunk:  OK
#*
#* Purpose:    Handler for the OK button. Insert the data in the parent screen.
#*
#*! #####################################################################################

$OK
    Gosub OK From BIDLOCDE

    # Case distinction between BAN1 screen (GESBAN function) and the BIDxxx screens for
    # there are differend field names and sometimes indexed fields (table view):
    If PARENTSCREEN = "BAN1"
        # GESBAN function:
        Assign "[M:" + PARENTSCRABR + "]BIDNUM" With right$( [M]IBACOD, 5 )
        Assign "[M:" + PARENTSCRABR + "]IBACOD" With [M]IBACOD
    Else
        # BIDxxx screens (GESBPR, GESBPC, ... function):
        Assign "[M:" + PARENTSCRABR + "]BIDNUM("    + TABINDEX + ")" With right$( [M]IBACOD, 5 )
        Assign "[M:" + PARENTSCRABR + "]IBAN("      + TABINDEX + ")" With left$( [M]IBACOD, 4 )
    Endif
Return



# ############################################################################################# #
# ##########                                                                                    #
# ########## Event: After changing the IBAN                                                     #
# ########## Does:  Checks the validity of the IBAN and restores bank sort code and bank        #
# ##########        account number.                                                             #
# ##########                                                                                    #
# ############################################################################################# #

Subprog C_IBACOD( VALEUR )
Variable Char VALEUR()

    # If the IBAN is empty there is nothing to do.
    If VALEUR = ""
        End
    Endif

    # Make sure the ISO code part is in upper case.
    VALEUR= toupper( VALEUR )

    # Check the beginning of the IBAN against the country.
    #
    # Note: We can be sure that the record exists for it is validated in the parent window.
    #       So we don't have to check fstat.
    Call LEC_TCY( [M]BIDCRY ) From CPTLEC

    If left$( VALEUR, 2 ) <> [F:TCY]ISO
        GMESSAGE = func AFNC.MES1( mess(341,107,1), [M]BIDCRY ) # Message: "This local BID dialog is restricted to IBANs of country $1$"
        mkstat = 2
        End
    Endif

    # Create BIDNUM and the according reference IBAN.
    Local Char BIDNUM(GLONBID)      : BIDNUM = right$( VALEUR, 5 )          # BIDNUM
    Local Char IBAN(4)                                                      # IBAN prefix (e. g. "DE91")

    # Calculate the IBAN prefix (check sum) for the given BIDNUM.
    Call IBAN( [M]BIDCRY, BIDNUM, IBAN ) From TRTBPA

    Local Char IBACOD(34)           : IBACOD = IBAN + BIDNUM                # Reference IBAN

    # Check if the entered IBAN coincides with the reference IBAN.
    If VALEUR <> IBACOD
        # If not raise an error message.
        GMESSAGE= mess(342,107,1) # Message: "The IBAN is not valid. Please enter a valid IBAN."
        mkstat = 2
        End
    Endif
End


Subprog AM_IBACOD( VALEUR )
Variable Char VALEUR()

    # Create BIDNUM, bank sort code
    Local Char BIDNUM(GLONBID)      : BIDNUM = right$( VALEUR, 5 )                             # BIDNUM
    # Note: We can be sure that the record exists for it is validated in the parent window.
    #       So we don't have to check fstat.
    Call LEC_TCY( [M]BIDCRY ) From CPTLEC
    If [F:TCY]BANLNG > 0
        Local Char BANCOD([F:TCY]BANLNG) : BANCOD = left$( BIDNUM, [F:TCY]BANLNG )             # Bank sort code
        Call LEC_ABN( [M]BIDCRY, BANCOD ) From CPTLEC
        If !fstat
            [M]PAB1   = [F:ABN]PAB  : Affzo [M]PAB1
            [M]BICCOD = [F:ABN]BIC  : Affzo [M]BICCOD
        Endif
    Endif
End

