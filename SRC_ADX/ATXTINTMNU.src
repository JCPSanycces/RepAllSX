#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "SETBOUT"   : Gosub SETBOUT
 When "ENR"       : Gosub ENR
 When "ABANDON"   : Gosub ABANDON
 When "APRES_MODIF"   Gosub APRES_MODIF
 When Default
Endcase
Return

$OUVRE
  # Limit use to supervisor team
  If !find(GUSER,"ERB","RBU","CG","DLE","LSE", "LATRA", "CCC" )
    GMESSAGE="Don't use this function, you must contact SUPERVISOR TEAM"
    GERR=1
    [L]FIN = [V]CST_ATRUE
    Return
  Endif
  If !clalev([F:TLA]) : Local File TABLAN [TLA]  : Endif
  If !clalev([F:AST2]): Local File APLSTD [AST2] : Endif    # For read and updates
  If !clalev([F:AST3]): Local File APLSTD [AST3] : Endif    # for aplstd codes
  If !clalev([F:AST4]): Local File APLSTD [AST4] : Endif    # for local menu titles
  If !clalev([F:AML]) : Local File AMENLOC [AML] : Endif
Return

$APRES_MODIF
  If COUZON="LANNUMA" | (COUZON="LAN" & [M:ATMU]LANNUMA<>"")
    If COUZON="LANNUMA"
      Call GET_TEXT([M:ATMU]LANCHP,val(CZ),[M:ATMU]LAN)
    Else
      Call GET_TEXT([M:ATMU]LANCHP,[M:ATMU]LANNUM,CZ)
    Endif
    If ([M:ATMU]TXTSRVTEXTE<>[M:ATMU]ATXTEXTE | [M:ATMU]TXTSRVCODE<>[M:ATMU]ATXCODE
&       | [M:ATMU]TXTSRVLANORI<>[M:ATMU]ATXLANORI)
      REP="M"
      GREP="M"
    Else
      Raz REP,GREP
    Endif
  Elsif COUZON="LANCHP"
    Raz REP,GREP
  Elsif find(COUZON,"UPDTEXTE","UPDLANORI","UPDCODE")
    REP="M" : GREP="M"
  Endif
Return

$SETBOUT
  # Do not reset GREP if already in modify mode - GREP will be set if one of the update fields has been modified
  If GREP="M" : Return : Endif

  # Check Text server valid against ATEXTE values if different set "Save" and "Cancel" button
  If ([M:ATMU]TXTSRVLANORI<>[M:ATMU]ATXLANORI | [M:ATMU]TXTSRVTEXTE<>[M:ATMU]ATXTEXTE | [M:ATMU]TXTSRVCODE<>[M:ATMU]ATXCODE)
&  & BOUT<>"A"
    REP="M"
  Else
    REP=""
  Endif
  GREP=REP
Return

$ENR
  Gosub TEXT_MODIF
Return

#**
#* TEXT_MODIF - Update ATEXTE and text server to new text for the language being displayed
#*!
$TEXT_MODIF
Local Char ERRMSG(250)
Local Integer ASTATUS, I
Local Char VTXTSRVCODE, VTXTSRVTEXTE, VTXTSRVLANORI

  If !adxlog
    Trbegin [AST2]
  Endif

  # Update text into APLSTD
  If [M:ATMU]LANNUM=0 & [F:AML]MENLOCAL=[V]CST_AYES
    If [M:ATMU]LANCHP<200
      Readlock [F:AST2]CLE=0;[M:ATMU]LANCHP;[M:ATMU]LAN
    Else
      Readlock [F:AST2]CLE=200;[M:ATMU]LANCHP-200;[M:ATMU]LAN
    Endif
  Else
    Readlock [F:AST2]CLE=[M:ATMU]LANCHP;[M:ATMU]LANNUM;[M:ATMU]LAN
  Endif
  If !fstat
    [F:AST2]LANMES   = [M:ATMU]UPDTEXTE
    [F:AST2]LANORI   = [M:ATMU]UPDLANORI
    Rewrite [F:AST2]
    If fstat
      Rollback
      GERR=1
      GMESSAGE=mess(9,123,1)-"APLSTD"
      Return
    Endif
  Elsif fstat=[V]CST_ANOREC
    Rollback
    GERR=1
    GMESSAGE=mess(7,123,1)-"APLSTD"
    Return
  Else
    Rollback
    GERR=1
    GMESSAGE=mess(20,100,1) -"APLSTD"
    Return
  Endif

  # Update 0 lannum with codes
  If [F:AML]MENLOCAL=[V]CST_AYES & [M:ATMU]LANNUM<>0 & [M:ATMU]ATXCODE <> [M:ATMU]UPDCODE
    Readlock [F:AST2]CLE=[M:ATMU]LANCHP;0;[M:ATMU]LAN
    If !fstat
      If [F:AST2]LANMES=""
        [F:AST2]LANMES+=space$([M:ATMU]LANNUM-1)+[M:ATMU]UPDCODE
      Else
        If [M:ATMU]LANNUM=1
          [F:AST2]LANMES=[M:ATMU]UPDCODE+right$([F:AST2]LANMES,2)
        Else
          I=len([F:AST2]LANMES)
          If I>=[M:ATMU]LANNUM
            [F:AST2]LANMES=left$([F:AST2]LANMES,[M:ATMU]LANNUM-1)+[M:ATMU]UPDCODE+right$([F:AST2]LANMES,[M:ATMU]LANNUM+1)
          Else
            [F:AST2]LANMES+=space$([M:ATMU]LANNUM-I+1)+[M:ATMU]UPDCODE
          Endif
        Endif
      Endif

      Rewrite [F:AST2]
      If fstat
        Rollback
        GERR=1
        GMESSAGE=mess(9,123,1)-"APLSTD"
        Return
      Endif
    Elsif fstat=[V]CST_ANOREC
      Rollback
      GERR=1
      GMESSAGE=mess(7,123,1)-"APLSTD"
      Return
    Else
      Rollback
      GERR=1
      GMESSAGE=mess(20,100,1) -"APLSTD"
      Return
    Endif
  Endif

  # Update/insert text in text server
  If ([M:ATMU]TXTSRVTEXTE<>[M:ATMU]UPDTEXTE | [M:ATMU]TXTSRVLANORI<>[M:ATMU]UPDLANORI
&     | [M:ATMU]TXTSRVCODE<>[M:ATMU]UPDCODE) # Update

    [L]ASTATUS = func ATXTSVC.UPDATE_MESSAGE([M:ATMU]TXTPDTCOD, [M:ATMU]LANCHP, [M:ATMU]LANNUM, [M:ATMU]UPDLANORI, [M:ATMU]LAN, [M:ATMU]UPDCODE, [M:ATMU]UPDTEXTE,[L]ERRMSG)

    If [L]ASTATUS<>[V]CST_AOK
      Rollback
      GERR=1
      GMESSAGE=mess(9,123,1)-"Text Server"-[L]ERRMSG
      Return
    Endif
  Endif

  Commit

  # Display updated texts

  Call GET_TEXT([M:ATMU]LANCHP,[M:ATMU]LANNUM,[M:ATMU]LAN)

  #manually clear modif flags
  Raz REP,GREP
Return

# Abandon changes
$ABANDON
  Raz REP,GREP
  Call GET_TEXT([M:ATMU]LANCHP,[M:ATMU]LANNUM,[M:ATMU]LAN)
Return

#**
#* GET_TEXT-Retrieve text from APLSTD and text server
#*
#* @param LANCHP - APLSTD chapter
#* @param LANNUM - APLSTD number
#* @param LAN  - Language
#*!
Subprog GET_TEXT(LANCHP,LANNUM,LAN)
Value Integer LANCHP,LANNUM
Value Char LAN

  ###Text SERVER
  Call GET_TEXTSERVER([M:ATMU]TXTPDTCOD,LANCHP,LANNUM,LAN)
  Call GET_PDT([M:ATMU]TXTPDTCOD)
  ###

  ###Link APLSTD
  Raz [M:ATMU]ATXTEXTE,[M:ATMU]ATXLANORI,[M:ATMU]ATXCODE
  Read [F:AML]MENLOC=[L]LANCHP
  If fstat>1
    GMESSAGE=mess(208,115,1)
    mkstat = 2 : End
  Endif
  If [L]LANNUM=0 & [F:AML]MENLOCAL=[V]CST_AYES
    If [L]LANCHP<200
      Read [F:AST2]CLE=0;[L]LANCHP;[L]LAN
    Else
      Read [F:AST2]CLE=200;[L]LANCHP-200;[L]LAN
    Endif
  Else
      Read [F:AST2]CLE=[L]LANCHP;[L]LANNUM;[L]LAN
  Endif
  If !fstat
    [M:ATMU]ATXLANORI  =[F:AST2]LANORI
    [M:ATMU]ATXTEXTE   =[F:AST2]LANMES
    If [F:AML]MENLOCAL=[V]CST_AYES & [L]LANNUM<>0
      Read [F:AST3]CLE=[L]LANCHP;0;[L]LAN
      If !fstat
        [M:ATMU]ATXCODE = seg$([F:AST3]LANMES,[L]LANNUM,[L]LANNUM)
      Endif
    Endif
  Endif
  ###

  ###MAJ Texte
  # Set update text default
  If [F:AML]MENLOCAL=[V]CST_AYES & [L]LANNUM<>0
    If [M:ATMU]TXTSRVCODE <> "" & [M:ATMU]TXTSRVCODE <> space$(1)
      [M:ATMU]UPDCODE = [M:ATMU]TXTSRVCODE
    Else
      [M:ATMU]UPDCODE = [M:ATMU]ATXCODE
    Endif
  Else
    Raz [M:ATMU]UPDCODE
  Endif

  If [M:ATMU]TXTSRVLANORI <> ""
    [M:ATMU]UPDLANORI = [M:ATMU]TXTSRVLANORI
  Else
    [M:ATMU]UPDLANORI = [M:ATMU]ATXLANORI
  Endif

  If [M:ATMU]TXTSRVTEXTE <> ""
    [M:ATMU]UPDTEXTE = [M:ATMU]TXTSRVTEXTE
  Else
    [M:ATMU]UPDTEXTE = [M:ATMU]ATXTEXTE
  Endif

  Affzo [M:ATMU]
End

#**
#* GET_TEXTSERVER-Retrieve text from text server only
#*
#* @param LANCHP - APLSTD chapter
#* @param LANNUM - APLSTD number
#* @param LAN  - Language
#*!
Subprog GET_TEXTSERVER(PDTCOD, LANCHP,LANNUM,LAN)
Value Integer LANCHP,LANNUM, PDTCOD
Value Char LAN
Local Integer ASTATUS, I
Local Char MESSAGE(250)

  [L]ASTATUS = func ATXTSVC.GET_MESSAGE(PDTCOD, [L]LANCHP, [L]LANNUM, [L]LAN, [M:ATMU]TXTSRVCODE, [M:ATMU]TXTSRVTEXTE, [M:ATMU]TXTSRVLANORI, [L]MESSAGE)
  If [L]ASTATUS<>[V]CST_AOK
    #We are going to look if this message exist for another product
    For I=-2 To 3
      If I<>PDTCOD
        [L]ASTATUS = func ATXTSVC.GET_MESSAGE(I, [L]LANCHP, [L]LANNUM, [L]LAN, [M:ATMU]TXTSRVCODE, [M:ATMU]TXTSRVTEXTE, [M:ATMU]TXTSRVLANORI, [L]MESSAGE)
        If [L]ASTATUS=[V]CST_AOK : Break : Endif
      Endif
    Next I

    If [L]ASTATUS=[V]CST_AOK
      [M:ATMU]TXTPDTCODA = num$(I) : [M:ATMU]TXTPDTCOD = I
    Else
      Raz [M:ATMU]TXTSRVCODE, [M:ATMU]TXTSRVTEXTE, [M:ATMU]TXTSRVLANORI
    Endif
  Endif
End

###############################################################################
# Field [M:ATMU]LANCHP
###############################################################################
Subprog C_LANCHP(VALEUR)
Variable Decimal VALEUR

  If VALEUR=0 | VALEUR=200
    GMESSAGE=mess(140,143,1)
    mkstat = 2 : End
  Endif

  Look [F:AML]MENLOC=VALEUR
  If fstat
    GMESSAGE=mess(81,75,1)
    mkstat = 2 : End
  Endif
End

Subprog AM_LANCHP(VALEUR)
Variable Decimal VALEUR
Local Char OLDLAN(GLONLAN)

  OLDLAN=[M:ATMU]LAN
  Raz [M:ATMU]
  [M:ATMU]LANCHP=VALEUR : [M:ATMU]LAN=OLDLAN

  Read [F:AML]MENLOC=VALEUR
  If !fstat | fstat=1
    If [F:AML]MENLOCAL=[V]CST_AYES
      Actzo [M:ATMU]UPDCODE
    Else
      Grizo [M:ATMU]UPDCODE
    Endif

    Call INIT_TXTPDTCODA([F:AML]MENLOC)

    [M:ATMU]NONTRA = [F:AML]NONTRA
  Endif

  Call GET_PDT([M:ATMU]TXTPDTCOD)

  Affzo [M:ATMU]
End

###############################################################################
# Field [M:ATMU]LAN
###############################################################################
Subprog C_LAN(VALEUR)
Variable Char    VALEUR()

  Read [TLA]TLA0 = VALEUR
  If !fstat & [TLA]LANSTD<>2
   GMESSAGE = func ASYRFNC.MES1(mess(144,127,1),VALEUR) # The language $1$ is not a standard one
   mkstat =2 : End
  Endif
End

Subprog S_LAN(VALEUR)
Variable Char VALEUR
  Local Integer NBTEX, CHOI,I
  Local Char    TEX(GLONDES)(1..,1..5) , TIT(GLONDES)(0..3)

  Filter [F:TLA] Where [TLA]LANSTD=2 Order By LAN
  For [F:TLA]
   NBTEX+=1
   TEX(NBTEX,1) = [F:TLA]LAN
   TEX(NBTEX,2) = func ASYRFNC.TEXTRA("TABLAN","INTDES",[F:TLA]LAN,"")
   TEX(NBTEX,3) = func ASYRFNC.TEXTRA("TABLAN","INTSHO",[F:TLA]LAN,"")
  Next

  CHOI = 0
  TIT(0) = func ASYRFNC.TEXTE(18654)          # All the standard languages
  TIT(1) = func ASYRFNC.TEXTE(15057)          # Standard language
  TIT(2) = mess(36,105,1)                     # Description
  TIT(3) = func ASYRFNC.TEXTE(4010)           # Short title
  If NBTEX>0
   Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
   If status<>7 & CHOI<>0
    VALEUR = TEX(CHOI,1)
   Endif
  Endif
  Filter [F:TLA]
End

###############################################################################
# Field [M:ATMU]LANNUMA
###############################################################################
Subprog AM_LANNUMA(VALEUR)
Variable Char VALEUR
  [M:ATMU]LANNUM = val(VALEUR)
End

Subprog C_LANNUMA(VALEUR)
Variable Char VALEUR
  Look [F:AST2]CLE=[M:ATMU]LANCHP;val(VALEUR);[M:ATMU]LAN
  If fstat>1
    GMESSAGE=mess(84,141,1)
    mkstat = 2 : End
  Endif
End

Subprog B1_LANNUMA(VALEUR)
Variable Char VALEUR
Local Integer NBTEX, CHOI,I
Local Char    TEX(GLONDES)(1..,1..2) , TIT(GLONDES)(0..2)

  Link [F:AST2] With [F:TLA]TLA0=[F:AST2]LAN As [LNK1] Where [F:TLA]LANSTD=2 & [F:AST2]LANCHP=[M:ATMU]LANCHP &
&   [F:AST2]LAN=[M:ATMU]LAN & [F:AST2]LANNUM>0 Order By [F:AST2]LANNUM

  For [LNK1]
   NBTEX+=1
   TEX(NBTEX,1) = num$([F:AST2]LANNUM)
   TEX(NBTEX,2) = [F:AST2]LANMES
  Next
  LogicClose File [LNK1]

  If NBTEX>0
    CHOI = 0
    TIT(0) = func ASYRFNC.TEXTE(22656)          # ATEXTE link
    TIT(0) -= mess(78,100,1)-num$([M:ATMU]LANCHP)
    TIT(1) = mess(17,104,1)                     # Line number
    TIT(2) = mess(4,38,1)                       # Text

    Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
    If CHOI=0                                 # No selection made
      End
    Elsif status<>7 & CHOI<>0
      VALEUR = TEX(CHOI,1) : [M:ATMU]LANNUM = val(VALEUR)
    Endif
  Else
    GMESSAGE=mess(96,115,15)                  # Text not found
    GERR=1
  Endif
End

######################################################################################
# Field [M:ATMU]TXTPDTCODA
######################################################################################
Subprog AM_TXTPDTCODA(VALEUR)
Variable Char VALEUR
  If VALEUR<>""
    [M]TXTPDTCOD=val(VALEUR)
    Call GET_PDT(val(VALEUR))
    Affzo [M]TXTPDTDES
  Endif
End

Subprog C_TXTPDTCODA(VALEUR)
Variable Char VALEUR
Local Integer ASTATUS
Local Char MESSAGE(250)

  If VALEUR<>"0" & val(VALEUR)=0
    GMESSAGE=mess(112,123,1)
    mkstat = 2 : End
  Endif

  If val(VALEUR)<>-2 & func ATXTSVC.ADD_PRODUCT(val(VALEUR))=""
    GMESSAGE=mess(84,141,1)
    mkstat = 2 : End
  Endif

  [L]ASTATUS = func ATXTSVC.GET_MESSAGE(val(VALEUR), [M:ATMU]LANCHP, [M:ATMU]LANNUM, [M:ATMU]LAN, [M:ATMU]TXTSRVCODE, [M:ATMU]TXTSRVTEXTE, [M:ATMU]TXTSRVLANORI, [L]MESSAGE)
  If [L]ASTATUS<>[V]CST_AOK
    GMESSAGE=[L]MESSAGE
    mkstat = 2 : End
  Endif
End

Subprog INIT_TXTPDTCODA(CODAML)
  Value Integer CODAML

# Issue 55442 - 2017-09-11 by CCC : FLGPRO doesn't exist except in SUPERV => use APLSTD.GET_CODE_PRODUCT
#  If !clalev([F:AML2]): Local File AMENLOC [AML2]: Endif
#
#  Read [F:AML2]MENLOC=[L]CODAML
#  If !fstat & [F:AML2]FLGPRO=[V]CST_AYES
#    #one description by product
#    [M:ATMU]TXTPDTCODA=num$(GPRODUIT) : [M:ATMU]TXTPDTCOD=GPRODUIT
#    Actzo [M:ATMU]TXTPDTCODA
#  Else
#    #one description for all products
#    [M:ATMU]TXTPDTCODA="-2" : [M:ATMU]TXTPDTCOD=-2
#    Diszo [M:ATMU]TXTPDTCODA
#  Endif
    Local Integer LPROD
    Local Char    LERRMSG(250)
    LPROD = func APLSTD.GET_CODE_PRODUCT(CODAML, "",LERRMSG)
    [M:ATMU]TXTPDTCODA = num$(LPROD)
    [M:ATMU]TXTPDTCOD  = LPROD
    If LPROD=-100
        Call ERREUR(LERRMSG) From GESECRAN
    Endif
    If LPROD=-2
        Diszo [M:ATMU]TXTPDTCODA
    Else
        Actzo [M:ATMU]TXTPDTCODA
    Endif
End

###############################################################################
Subprog GET_PDT(PDTCOD)
Value Decimal PDTCOD

  If PDTCOD=-2
    [M]TXTPDTDES="Shared components"
  Else
    [M]TXTPDTDES=func ATXTSVC.ADD_PRODUCT(PDTCOD)
  Endif
End

######################################################################################
#**
#* Copies a chapter from a product to another one. The origin can be deleted afterwards
#*
#* @param PLANCHP  : Chapter number
#* @param PFROMPDT : Product from
#* @param PTOPDT   : Product to
#* @param PDEL     : set 1 to delete the origin
#* @param PERRMSG  : error message if return code is [V]CST_AWARNING or [V]CST_AERROR
#*
#* @return [V]CST_AOK or [V]CST_AWARNING or [V]CST_AERROR
#*!
Funprog COPY_PRODUCT_CHP(PLANCHP,PFROMPDT,PTOPDT,PDEL, PERRMSG)
Value    Integer PLANCHP
Value    Integer PFROMPDT
Value    Integer PTOPDT
Value    Integer PDEL
Variable Char    PERRMSG

Local Integer LASTATUS
Local Integer LCOUNT
Local Integer LTBNUM(1..)
Local Char LTBCODE(1)(1..)
Local Char LTBLANMES(250)(1..)
Local Char LTBLANORI (GLONLAN) (1..)
Local Char  LERRMSG (250)
Local Integer I

Raz PERRMSG

# Check the chapter exists
LASTATUS = func ATXTSVC.GET_MESSAGES(PFROMPDT, PLANCHP, "",0, 32760 ,LCOUNT, LTBNUM, LTBCODE, LTBLANMES,LTBLANORI, LERRMSG)
If LASTATUS<>[V]CST_AOK
    # An error occured
    PERRMSG = func AFNC.MES3("Product=$1$ LANCHP=$2$ : $3$", num$(PFROMPDT), num$(PLANCHP), LERRMSG-"(GET_MESSAGES)")
    End [V]CST_AERROR
Endif

For I=1 To LCOUNT
    # Copy each message
    LASTATUS = func COPY_MESSAGE(PFROMPDT,PLANCHP,LTBNUM(I), PTOPDT, PLANCHP, LTBNUM(I),LERRMSG)
    If LASTATUS<>[V]CST_AOK
        # An error occured
        PERRMSG = "Copy error"-LERRMSG
        If GTRACE<>""
            Call ECR_TRACE (PERRMSG,1) From GESECRAN
            Raz [L]LASTATUS, [L]LERRMSG
        Else
            Break
        Endif
    Endif
Next
If GTRACE="" & LASTATUS<>[V]CST_AOK
    # An error occured
    PERRMSG = LERRMSG
    End [V]CST_AERROR
Endif

# Delete original message
If PDEL=1
    LASTATUS= func ATXTSVC.DELETE_MESSAGES_CHAPTER(PFROMPDT, PLANCHP, LERRMSG)
    If LASTATUS<>[V]CST_AOK
        # An error occured
        PERRMSG = func AFNC.MES3("Product=$1$ LANCHP=$2$ : $3$", num$(PFROMPDT), num$(PLANCHP), LERRMSG-"(DELETE_MESSAGES_CHAPTER)")
        End [V]CST_AERROR
    Endif
Endif

End [V]CST_AOK
#**
#* Copies a message to another one (FRA and ENG are all copied)
#*
#* @param PFROMPDT : Product number
#* @param PFROMCHP : Chapter number
#* @param PFROMNUM : Message number
#* @param PTOPDT   : Product number to copy to
#* @param PTOCHP   : Chapter to copy to
#* @param PTONUM   : Message number to copy to
#* @param PERRMSG  : error message if return code is [V]CST_AWARNING or [V]CST_AERROR
#*
#* @return [V]CST_AOK or [V]CST_AWARNING or [V]CST_AERROR
#*!
Funprog COPY_MESSAGE(PFROMPDT,PFROMCHP,PFROMNUM,
&                    PTOPDT,  PTOCHP,  PTONUM,  PERRMSG)
Value Integer PFROMCHP
Value Integer PFROMNUM
Value Integer PFROMPDT
Value Integer PTOCHP
Value Integer PTONUM
Value Integer PTOPDT
Variable Char PERRMSG

Local Integer LASTATUS
Local Char LCODE(1)
Local Char LMESSAGE(250)
Local Char LLANORI(GLONLAN)
Local Char LERRMSG (250)
Local Char LLAN(GLONLAN)

# Check destination already exists for at least 1 language
LASTATUS= func ATXTSVC.GET_MESSAGE(PTOPDT, PTOCHP, PTONUM, "ENG", LCODE, LMESSAGE, LLANORI, LERRMSG)
If [L]LASTATUS=[V]CST_AOK
    PERRMSG = func AFNC.MES3("Product=$1$ LANCHP=$2$ LANNUM=$3$ : message already exists", num$(PTOPDT), num$(PTOCHP), num$(PTONUM))
    End [V]CST_AERROR
Endif

# As we don't know which language is recorded on texts server, we suppose it's only FRA and ENG
For LLAN="FRA","ENG"
    LASTATUS= func ATXTSVC.GET_MESSAGE(PFROMPDT, PFROMCHP, PFROMNUM, LLAN, LCODE, LMESSAGE, LLANORI, LERRMSG)
    If [L]LASTATUS<>[V]CST_AOK
        PERRMSG = func AFNC.MES5("Product=$1$ LANCHP=$2$ LANNUM=$3$ LAN=$4$ : $5$", num$(PFROMPDT), num$(PFROMCHP), num$(PFROMNUM), LLAN, LERRMSG)
        End [V]CST_AERROR
    Endif

    # Create the message with new key
    LASTATUS= func ATXTSVC.UPDATE_MESSAGE(PTOPDT, PTOCHP, PTONUM, LLANORI, LLAN, LCODE, LMESSAGE, LERRMSG)
    If [L]LASTATUS<>[V]CST_AOK
        PERRMSG = func AFNC.MES5("Product=$1$ LANCHP=$2$ LANNUM=$3$ LAN=$4$ : $5$", num$(PTOPDT), num$(PTOCHP), num$(PTONUM), LLAN, LERRMSG-"(UPDATE_MESSAGE)")
        End [L]LASTATUS
    Endif
Next

End [V]CST_AOK

