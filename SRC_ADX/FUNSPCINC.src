#<AdxTL>@(#)12.0.0.0 $Revision$
########################################################################
#                                                 JL - Septembre 2000  #
#    REVISION DES TARIFS VENTE : LANCEMENT                             #
#                                                                      #
#    - Traitement        : FUNSPCINC                                   #
#    - Action e_commerce : SAISPCINC (Saisie fenêtre)                  #
#                          TRTSPCINC (Traitement standard)             #
#                          VISUSINCL (Saisie fenêtre)                  #
#----------------------------------------------------------------------#
# Table mise à jour  : SPRICFICH [F:SPF]                               #
#                      SPRICLIST [F:SPL]                               #
# Attention : Ce traitement contient aussi les actions sur champ       #
#             de l'écran SPCINCR [M:SPCI]                              #
########################################################################

########################################################################
# Etiquettes ACTION
########################################################################
$ACTION
#--- Actions liées à la saisie fenêtre des variables
Case ACTION
  When "OUVRE"        : Case GACTION
                          When "SAISPCINC"    : Gosub OUVRE_SAISPCINC
                        Endcase
  When "DEBUT"        : Case GACTION
                          When "SAISPCINC"    : Gosub DEBUT_SAISPCINC
                       Endcase
  When "SETBOUT"      : Case GACTION
                          When "SAISPCINC"    : Gosub SETBOUT_SAISPCINC
                        Endcase
  When "BOUTON"       : Case GACTION
                          When "SAISPCINC"    : Gosub BOUCLE_SAISPCINC
                        Endcase
  When "OK"           : Case GACTION
                          When "SAISPCINC"    : Gosub BOUCLE_SAISPCINC
                        Endcase
  When "FIN"          : Case GACTION
                          When "SAISPCINC"    : Gosub FIN_SAISPCINC
                        Endcase
  When Default
Endcase

#--- Actions liées au traitement standard de mise à jour
Case ACTION
  When "INIT"         : Case GACTION
                          When "TRTSPCINC"    : Gosub INIT_TRTSPCINC
                        Endcase
  When "AVANT_PAR"    : Case GACTION
                          When "TRTSPCINC"    : Gosub AVANT_PAR_TRTSPCINC
                        Endcase
  When "CONTROLE"     : Case GACTION
                          When "TRTSPCINC"    : Gosub CONTROLE_TRTSPCINC
                        Endcase

#      dans gsaisie
  When "DEBUT"        : Case GACTION
                          When "TRTSPCINC"    : Gosub DEBUT_TRTSPCINC
                        Endcase
  When "TITRE"        : Case GACTION
                          When "TRTSPCINC"    : Gosub TITRE_TRTSPCINC
                        Endcase
  When "SETBOUT"      : Case GACTION
                          When "TRTSPCINC"    : Gosub SETBOUT_TRTSPCINC
                        Endcase
  When "END", "ABA"   : Case GACTION
                          When "TRTSPCINC"    : FIN=1 : JGOKMAJ=1
                        Endcase
  When "ENR", "CRE"   : Case GACTION
                          When "TRTSPCINC"    : FIN=1 : JGOKMAJ=2
                        Endcase
  When "EDI"          : Case GACTION
                          When "TRTSPCINC"    : Gosub EDI_TRTSPCINC
                        Endcase

#      dans gtraite
  When "EXEC"         : Case GACTION
                          When "TRTSPCINC"    : Gosub EXEC_TRTSPCINC
                        Endcase
  When "SORTIE"       : Case GACTION
                          When "TRTSPCINC"    : Gosub SORTIE_TRTSPCINC
                        Endcase
  When Default
Endcase

#--- Actions liées a la visualisation des données de la dernière execution
Case ACTION
  When "TITRE"        : Case GACTION
                          When "VISUSINCL"    : Gosub TITRE_VISUSINCL
                        Endcase
  When "DEBUT"        : Case GACTION
                          When "VISUSINCL"    : Gosub DEBUT_VISUSINCL
                        Endcase
  When Default
Endcase

Return

########################################################################
# Détail des actions liées à la saisie fenêtre des variables
########################################################################
$OUVRE_SAISPCINC

Global Integer JGOKMAJ, JGOKCOUL, JGFINLEC
Global Char    JGTITMAJ (250), JGTITTRA (250)
Global Integer JGCOMPTAGE
Global Decimal JGARRRAT (0..8)         : # arrondi standard des % (type donnée RAT)
Local  Integer I

JGTITTRA=mess(162,196,1)-mess(5,14,1)
If clalev ([F:SNE])=0  : Local File SINCENT    [SNE]  : Endif
If clalev ([F:SND])=0  : Local File SINCDET    [SND]  : Endif
If clalev ([F:SPI])=0  : Local File SPRICINCR  [SPI]  : Endif
If clalev ([F:SPC])=0  : Local File SPRICCONF  [SPC]  : Endif
If clalev ([F:SPR])=0  : Local File SPREASON   [SPR]  : Endif
If clalev ([F:PRS])=0  : Local File PRICSTRUCT [PRS]  : Endif
If clalev ([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev ([F:SPF])=0  : Local File SPRICFICH  [SPF]  : Endif
If clalev ([F:SPFN])=0 : Local File SPRICFICH  [SPFN] : Endif
If clalev ([F:SPL])=0  : Local File SPRICLIST  [SPL]  : Endif
If clalev ([F:ATY])=0  : Local File ATYPE      [ATY]  : Endif
If clalev ([F:AXX])=0  : Local File ATEXTRA    [AXX]  : Endif

#Read [F:ATY]CODTYP="RAT"
#If !fstat
#  I=int(([F:ATY]LNGTYP-int([F:ATY]LNGTYP))*10)
#  Case I
#    When 0       : JGARRRAT=1
#    When 1       : JGARRRAT=0.1
#    When 2       : JGARRRAT=0.01
#    When 3       : JGARRRAT=0.001
#    When 4       : JGARRRAT=0.0001
#    When 5       : JGARRRAT=0.00001
#    When 6       : JGARRRAT=0.000001
#    When Default : JGARRRAT=1
#  Endcase
#Endif

Read [F:PRS]PRS0=1;""
Call COLREM("C",1,"") From TRTPRICE

# -- Alimentation du compteur fiche tarif
If clalev ([F:TCA])<=0 : Local File TABCOUAFF [TCA] : Endif
Read [TCA]TCA0=5
If fstat
  GERR=1 : GMESSAGE=mess(64,199,1)  : # aucun compteur n'est affecté à ce document
  FIN=1 : Return
Endif
GMANCOU = [F:TCA]MANCOU(8)
GCODNUM = [F:TCA]CODNUM(8)

Return

########################################################################
$DEBUT_SAISPCINC
# -- Si appel direct en création/modif de paramétrage
If PARAM(1)<>""
  Call LECTURE("SNE",PARAM(1),"") From CONTOBJ
  Call LECTURE("SPC",[F:SNE]PLI,"") From CONTOBJ

  Read [F:PRS]PRS0=1;[F:SNE]PLISTC
  Call COLREM("C",1,[F:SNE]PLISTC) From TRTPRICE

  [M:SPCI]SIMFLG=2
  [M:SPCI]SEEFLG=2
  [M:SPCI]=[F:SNE]
#  [M:SPCI]PLIDES=[F:SPC]PLIDES
  Call LECTEXTRA ([M:SPCI]PLIDES,"SPRICCONF","DESAXX",[F:SPC]PLI,"") From ATEXTRA
  For I=0 To dim([M:SPCI]VARCOD)-1
    [M:SPCI]VARVAL(I)=[M:SPCI]VARDEF(I)
  Next I
  GFLTPLI=[F:SNE]PLI
Else
  Raz [F:SNE]
  Raz [M:SPCI]
Endif
Affzo [M:SPCI]1-99
Return

########################################################################
$SETBOUT_SAISPCINC

If [F:SNE]COD=""
    Call VIREBOUT(CHMEN, "1") From GOBJET         : # dernière execution
Endif
If COUZON="COD"
    If [F:SNE]LASDATPRO=[0/0/0]
        Call VIREBOUT(CHMEN, "1") From GOBJET     : # dernière execution
    Endif
Endif
Return

########################################################################
$BOUCLE_SAISPCINC

#--- Si on ne vient pas du paramétrage on revient sur choix
If PARAM(1)="" : FIN=0 : Endif

Return
########################################################################
$FIN_SAISPCINC

#--- Trace
If !GSERVEUR & GTRACE<>""
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif

#--- Sup. des globales perso
If dim(JGOKMAJ)>0    : Kill JGOKMAJ    : Endif
If dim(JGOKCOUL)>0   : Kill JGOKCOUL   : Endif
If dim(JGFINLEC)>0   : Kill JGFINLEC   : Endif
If dim(JGTITMAJ)>0   : Kill JGTITMAJ   : Endif
If dim(JGTITTRA)>0   : Kill JGTITTRA   : Endif
If dim(JGCOMPTAGE)>0 : Kill JGCOMPTAGE : Endif
If dim(JGARRRAT)>0   : Kill JGARRRAT   : Endif

#--- Hard Copy
Call IMPSCR From ATRTX3

Return


########################################################################
########################################################################
$INIT_TRTSPCINC

#-- nom de la fenêtre générée lors du paramétrage tarifs
BOITE="WB3"+num$([F:SNE]PLI)

#-- nom du traitement de révision généré
Local Char NOMTRT (10)
NOMTRT="WBI"+[F:SNE]COD
Call DEBTRANS From GLOCK
#-- ouverture de la trace
If !GSERVEUR & GTRACE=""
  Call OUVRE_TRACE(JGTITTRA) From LECFIC
  Call ECR_TRACE(JGTITTRA,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

#--
Read [SPR]SPR0=[F:SPC]PRIREN

#-- génération du traitement si inexistant
#Local Char FICTRT (GDIMFIC)
#FICTRT=filpath("TRT","WBI"+num$([F:SNE]COD),"adx",nomap)
#If filinfo (FICTRT,0)<0
Local Integer STAT
Call EXISTE_ADX("",nomap,"WBI"+num$([F:SNE]COD),STAT) From ORDSYS
If STAT=0
  Call VALID([M:SPCI]COD,nomap) From SUBSNE
Endif

Gosub VARIABLES From =NOMTRT      : # Reservation et chargement des variables parametrees
If sum([F:SNE]TBL)<>""
  Gosub OPEN_TBL From =NOMTRT     : # Ouverture des tables liees
Endif

#-- mise a jour des tarifs (création des fiches)
If !GSERVEUR
  Call ECR_TRACE("-"-mess(168,195,1)-[F:SNE]COD+" /"-mess(49,198,1)-[F:SNE]PLI,0) From GESECRAN
Endif

Local Char CRDOLD           : # no. de la fiche origine
Local Char CRDNEW           : # no. de la fiche crée
Local Char FILTRESPF (250)  : # expression de sélection des fiches à traiter

#-- constitution du filtre des fiches à augmenter
FILTRESPF="1=1"
If [M:SPCI]PLISTRCRD<>""
  FILTRESPF += " & PLICRD>=[M:SPCI]PLISTRCRD"
Endif
If [M:SPCI]PLIENDCRD<>""
  FILTRESPF += " & PLICRD<=[M:SPCI]PLIENDCRD"
Endif
If [M:SPCI]VLYDAT<>[00/00/00]
  FILTRESPF += " & PLISTRDAT<=[M:SPCI]VLYDAT & PLIENDDAT>=[M:SPCI]VLYDAT"
Endif

# PE : permet d'ajouter des éléments au filtre
GPOINT="SPCINCFIL" : Gosub ENTREE From EXEFNC

Filter [SPF] Where PLI=[F:SNE]PLI & evalue(FILTRESPF)
Raz JGFINLEC

Global Integer JGCURRSPF
If rowcount([SPF])>0
    Global Char JGNBSPF(GLONVCR)(rowcount([SPF]))
    Read [SPF] SPF0 First
    If fstat : JGFINLEC=2 : Endif
    Local Shortint I : I=0
    While !fstat
        JGNBSPF(I) = [F:SPF]PLICRD
        I+=1
        Read [F:SPF] Next
    Wend
Else
    JGFINLEC=2
Endif

Return

########################################################################
$AVANT_PAR_TRTSPCINC

Raz JGOKMAJ, JGOKCOUL
If JGFINLEC=2 : Return : Endif
If JGFINLEC=0
  JGCURRSPF=0
  Read [SPF] SPF0=[F:SNE]PLI;JGNBSPF(JGCURRSPF)
  JGFINLEC=1
Elsif dim(JGNBSPF)>JGCURRSPF+1
  JGCURRSPF+=1
  Read [SPF] SPF0=[F:SNE]PLI;JGNBSPF(JGCURRSPF)
  JGFINLEC=1
Else
  JGFINLEC=2 : Return
Endif

# PE : permet de déterminer si la fiche lue doit être traitée
Local Integer SAUVGPE     : SAUVGPE=GPE : GPE=0
GPOINT="SPCINCCTL" : Gosub ENTREE From EXEFNC
If GPE : GPE=SAUVGPE : Return : Endif

CRDOLD=[F:SPF]PLICRD

#---
# On garnit la variable arrondi des colonnes frais/remise
Local Integer WI, WARR
For WI=0 To 8
    If !instr(1, GFMTCOL(WI), "[F:TCU]") : # Si ce n'est pas un arrondi en fct de la devise
        WARR=int((val(GFMTCOL(WI))-int(val(GFMTCOL(WI))))*10) : # Arrondi en fonction du format de la colonne
        Case WARR
            When 0       : JGARRRAT(WI)=1
            When 1       : JGARRRAT(WI)=0.1
            When 2       : JGARRRAT(WI)=0.01
            When 3       : JGARRRAT(WI)=0.001
            When 4       : JGARRRAT(WI)=0.0001
            When 5       : JGARRRAT(WI)=0.00001
            When 6       : JGARRRAT(WI)=0.000001
            When Default : JGARRRAT(WI)=1
        Endcase
    Endif
Next

#---
$TRTCAL
GOK=1
Trbegin SPRICINCR
#   on vide le fichier de travail [SPI] pour cette fiche
Delete [SPI] Where PLI=[F:SPF]PLI & PLICRD=[F:SPF]PLICRD
Gosub CALCUL
If     GOK<0 : Goto ROL_TRTCAL
Elsif !GOK   : Goto AB_TRTCAL
Endif
Commit

Return

#----------------------------------------------------------------------
# Rollback
#----------------------------------------------------------------------
#-- nouvelle tentative et si echec --> rollback
$ROL_TRTCAL
Call ROLL From GLOCK
If GROLL Goto AB_MESTRTCAL Else Goto TRTCAL Endif

#-- rollback
$AB_TRTCAL
Rollback

$AB_MESTRTCAL
# mess : rollback suite à une erreur dans la transaction
Call ECR_TRACE([F:SPF]PLI-[F:SPF]PLICRD-mess(17,107,1),1) From GESECRAN

Filter [SPI]
Delete [SPI] Where PLI=[F:SPF]PLI & PLICRD=[F:SPF]PLICRD

Return

########################################################################
$CONTROLE_TRTSPCINC

#--- pour positionner les flags de mise à jour et de visu
JGOKMAJ=2 : JGOKCOUL=0
If [M:SPCI]SEEFLG<>2 : BOITE="" : Endif
If JGFINLEC=2 : FIN=1 : Endif
TMP=1

Return

########################################################################
$DEBUT_TRTSPCINC

Local Integer RG
nolign=0
Filter [SPI] Where PLI=[F:SPF]PLI & PLICRD=[F:SPF]PLICRD
[M:SPLW]X1PRIREN=[F:SPR]PRIREN
#[M:SPLW]X2PRIREN=[F:SPR]DES
Call GET_ATEXTRA("SPREASON","DESAXX",GLANGUE,[M:SPLW]X2PRIREN) From TRTX3TEX


For [SPI]
  nolign += 1
  [M:SPLW] = [F:SPI]
  For RG=1 To 9
    Assign "[M:SPLW]XFRAREM"+num$(RG)+"(nolign-1)" With [F:SPI]DCGVAL(RG-1)
  Next RG
Next
[M:SPLW]NBLIG = nolign

If [F:SNE]TYP=2  : # si modification
  [M:SPLW]PLICRD=[F:SPF]PLICRD
Else             : # si duplication ou chgt devise
  Raz [M:SPLW]PLICRD
Endif
[M:SPLW]PLISTRDAT=[M:SPCI]NEWSTRDAT
[M:SPLW]PLIENDDAT=[M:SPCI]NEWENDDAT
[M:SPLW]PLICRDIDX=[F:SPF]PLICRDIDX

Affzo [SPLW]
Diszo [SPLW]
#Grizo [SPLW]
Return

########################################################################
$TITRE_TRTSPCINC

Raz TIT
#                            "Simulation"
If [M:SPCI]SIMFLG=2 : TIT += mess(6,115,1)+"  " : Endif
# "Duplication fiche / Modification devise / Changement devise"  "Fiche"
TIT += mess([F:SNE]TYP,454,1)-mess(2,99,1)-[F:SPF]PLICRD

Return

########################################################################
$SETBOUT_TRTSPCINC

ETABOU(GNOUV)=0 : ETABOU(GPREM)=0 : ETABOU(GDERN)=0 : ETABOU(GSUIV)=0
ETABOU(GPREC)=0 : ETABOU(GSELE)=0 : ETABOU(GCHAN)=0
ETABOU(GJOIN)=0 : ETABOU(GCOMM)=0 : ETABOU(GDATC)=0
ETABOU(GENRE)=0 : ETABOU(GCREE)=0 : ETABOU(GSUPP)=0 : ETABOU(GABAN)=0
ETABOU(GEDIT)=1

If [M:SPCI]SIMFLG<>2
  If [F:SNE]TYP=1 : ETABOU(GCREE)=1 : ETABOU(GABAN)=1 : Endif
  If [F:SNE]TYP=2 : ETABOU(GENRE)=1 : ETABOU(GABAN)=1 : Endif
  If [F:SNE]TYP=3 : ETABOU(GCREE)=1 : ETABOU(GABAN)=1 : Endif
Endif

Return


########################################################################
$EDI_TRTSPCINC

Call PRTSCR("WB1"+num$([F:SNE]PLI)+"1","SPLW","-"+TIT,0,0) From ATRTX3
Return

########################################################################
$EXEC_TRTSPCINC

#--- Traitement de mise à jour (sauf simulation ou refus)
If [M:SPCI]SIMFLG=2   : # si simulation
  Goto FIN_FICHE
Endif

If JGOKMAJ=1            : # si traitement et maj refusée a la visu
  Goto FIN_FICHE
Endif

If [F:SNE]TYP=2
  Gosub VERROU
  If OK=1 : Goto FINFIN_FICHE Endif
Endif

#---
$TRTMAJ
GOK=1
Trbegin SPRICINCR

# PE : permet de modifier le contenu de la fiche de mise a jour
# 73596 Possibilité d'affecter un nouveau code au tarif
Local Char WNEW_PLI(GLONSPC) : Raz WNEW_PLI
GPOINT="UPDNEWCRD" : Gosub ENTREE From EXEFNC
If GOK < 1 : Rollback : GOK=1 : Goto TRTMAJ1  : Endif

If [F:SNE]TYP=1 : Gosub MAJ_DUPLI  : Endif
If [F:SNE]TYP=2 : Gosub MAJ_MODIF  : Endif
If [F:SNE]TYP=3 : Gosub MAJ_DEVISE : Endif

If     GOK<0 : Goto ROL_TRTMAJ
Elsif !GOK   : Goto AB_TRTMAJ
Endif
Commit

$TRTMAJ1
#--- Si modification : on enleve le lock symbole
If [F:SNE]TYP=2 :  Gosub DEVERROU : Endif

#--- En fin de fiche  : ecriture ficher trace
$FIN_FICHE
Filter [SPI]
Delete [SPI] Where PLI=[F:SPF]PLI & PLICRD=[F:SPF]PLICRD

Raz JGTITMAJ
JGOKCOUL=0                                   : # ligne trace en noir

If [M:SPCI]SIMFLG=2
  JGTITMAJ += mess(6,115,1)+"  "               : # Simulation
Endif

If [M:SPCI]SIMFLG=1 & JGOKMAJ=1
  JGTITMAJ += mess(43,187,1)+"  "              : # Attention
  JGTITMAJ += mess([F:SNE]TYP,454,1)+" "       : # suivant traitement
  JGTITMAJ += num$(CRDOLD)+"  "
  JGTITMAJ += mess(44,187,1)                   : # non effectué(e)
  JGOKCOUL=1                                 : # ligne trace en rouge
Else
  JGTITMAJ += mess([F:SNE]TYP,454,1)+" "       : # suivant traitement
  JGTITMAJ += num$(CRDOLD)+"  "
  If [M:SPCI]SIMFLG=1 & [F:SNE]TYP<>2
    JGTITMAJ += mess(42,187,1)+" "             : # Fiche crée
    JGTITMAJ += num$(CRDNEW)+" "
  Endif
Endif

If JGTITMAJ<>""
  Call ECR_TRACE(JGTITMAJ,JGOKCOUL) From GESECRAN
Endif

#---
$FINFIN_FICHE

If JGFINLEC=1 : SAI=1 : Endif

Return

#----------------------------------------------------------------------
# Positionnement d'un verrou sur l'entête commande
#----------------------------------------------------------------------
$VERROU
Local Integer OK
SYMBOLE = "SPF"+[F:SPF]PLICRD+"\"+[F:SPF]PLI
Lock = SYMBOLE With lockwait = 0
OK=2
If fstat = 1
    Call ECR_TRACE([F:SPF]PLI - [F:SPF]PLICRD - mess(10,100,1),1) From GESECRAN
    OK=1
Elsif fstat
    # problème sur la table
    Call ECR_TRACE(mess(150,199,1)-"$SPRICFICH",1) From GESECRAN
    OK=1
Endif
Return

#----------------------------------------------------------------------
# Suppression du verrou sur l'entête commande
#----------------------------------------------------------------------
$DEVERROU
Unlock=SYMBOLE
Return


#----------------------------------------------------------------------
# Rollback
#----------------------------------------------------------------------
#-- nouvelle tentative et si echec --> rollback
$ROL_TRTMAJ
Call ROLL From GLOCK
If GROLL Goto AB_MESTRTMAJ Else Goto TRTMAJ Endif

#-- rollback
$AB_TRTMAJ
Rollback

$AB_MESTRTMAJ
# mess : rollback suite à une erreur dans la transaction
Call ECR_TRACE([F:SPF]PLI-[F:SPF]PLICRD-mess(17,107,1),1) From GESECRAN

Filter [SPI]
Delete [SPI] Where PLI=[F:SPF]PLI & PLICRD=[F:SPF]PLICRD

Return

########################################################################
$SORTIE_TRTSPCINC

#-- mise à jour données dernière execution
If [M:SPCI]SIMFLG=1
  Readlock [SNE]SNE0=[M:SPCI]COD
  If !fstat
    [F:SNE]LASDATPRO = date$
    [F:SNE]LASSTRCRD = [M:SPCI]PLISTRCRD
    [F:SNE]LASENDCRD = [M:SPCI]PLIENDCRD
    [F:SNE]LASVLYDAT = [M:SPCI]VLYDAT
    [F:SNE]LASSTRDAT = [M:SPCI]PLISTRDAT
    [F:SNE]LASENDDAT = [M:SPCI]PLIENDDAT
    [F:SNE]LASCUROLD = [M:SPCI]CUROLD
    [F:SNE]LASCURNEW = [M:SPCI]CURNEW
    [F:SNE]LASCHGTYP = [M:SPCI]CHGTYP
    For I=0 To [M:SPCI]NBVAR-1
      [F:SNE]VARLAS(I) = [M:SPCI]VARVAL(I)
    Next I
    Rewrite [SNE]
  Endif
Endif
#--
Filter [SPF]
Filter [SPI]

Return

########################################################################
########################################################################
$TITRE_VISUSINCL

TIT=mess(344,198,1)-format$(GFMD,[F:SNE]LASDATPRO)
Return

########################################################################
$DEBUT_VISUSINCL

[M:SPCL]=[F:SNE]
#[M:SPCL]PLIDES=[F:SPC]PLIDES
Call LECTEXTRA ([M:SPCL]PLIDES,"SPRICCONF","DESAXX",[F:SPC]PLI,"") From ATEXTRA
Affzo [SPCL]
Diszo [SPCL]
#Grizo [SPCL]

Return

########################################################################
########################################################################
########################################################################


########################################################################
$MAJ_TARIFS
For [SPF]
  CRDOLD=[F:SPF]PLICRD
Next

#-- mise à jour données dernière execution
If [M:SPCI]SIMFLG=1
  Readlock [SNE]SNE0=[M:SPCI]COD
  If !fstat
    [F:SNE]LASDATPRO = date$
    [F:SNE]LASSTRCRD = [M:SPCI]PLISTRCRD
    [F:SNE]LASENDCRD = [M:SPCI]PLIENDCRD
    [F:SNE]LASVLYDAT = [M:SPCI]VLYDAT
    [F:SNE]LASSTRDAT = [M:SPCI]PLISTRDAT
    [F:SNE]LASENDDAT = [M:SPCI]PLIENDDAT
    [F:SNE]LASCUROLD = [M:SPCI]CUROLD
    [F:SNE]LASCURNEW = [M:SPCI]CURNEW
    [F:SNE]LASCHGTYP = [M:SPCI]CHGTYP
    For I=0 To [M:SPCI]NBVAR-1
      [F:SNE]VARLAS(I) = [M:SPCI]VARVAL(I)
    Next I
    Rewrite [SNE]
  Endif
Endif
#--
Filter [SPF]
Filter [SPI]

Return

#######################################################################
# Traitement dans fichier manoeuvre SPRICINCR [SPI]
#######################################################################
$CALCUL

#-- nouvelles dates de validité
Raz [M:SPCI]NEWSTRDAT, [M:SPCI]NEWENDDAT
If [M:SPCI]PLISTRDAT<>[0/0/0]
           [M:SPCI]NEWSTRDAT=[M:SPCI]PLISTRDAT
  Else     [M:SPCI]NEWSTRDAT=[F:SPF]PLISTRDAT
Endif
If [M:SPCI]PLIENDDAT<>[0/0/0]
           [M:SPCI]NEWENDDAT=[M:SPCI]PLIENDDAT
  Else     [M:SPCI]NEWENDDAT=[F:SPF]PLIENDDAT
Endif

#-- On copie les ligne [SPL] de la fiche [SPF] dans ficher de travail [SPI]
#   si changement devise, on ne copie que les lignes à changer
Local Char FILTRESPL (50)
FILTRESPL="PLICRD=[F:SPF]PLICRD"
If [F:SNE]TYP=3 : FILTRESPL += " & CUR=[M:SPCI]CUROLD" : Endif

Filter [SPL] Where PLI=[F:SPF]PLI & evalue (FILTRESPL)
For [SPL]
  Raz [F:SPI]
  [F:SPI]=[F:SPL]
# éclatement des critères
  MANIP=[F:SPL]PLICRI
  For RG=1 To dim([F:SPC]FLD)
    JK=instr(1,MANIP,"~")
    If JK
      Assign "[F:SPI]CRIT"+num$(RG) With left$(MANIP,JK-1)
      MANIP=(right$(MANIP,JK+1))
    Endif
  Next RG

# si changement de divise appel du traitement généré
  If [F:SNE]TYP=3 : Gosub CHGDEV_LIGNE From = "WBI"+num$([F:SNE]COD) : Endif

  Write [SPI]
  If fstat
    GOK=0 : Call FSTA("SPI") From GLOCK
    Break
  Endif
Next
Filter [SPL]

If GOK<>1 : Return : Endif

#----------------------------------------------------------------------
# pour chaque ligne du paramétrage de revision
#----------------------------------------------------------------------

Filter [SND] Where COD=[F:SNE]COD
For [SND]
  If sum([F:SNE]TBL)=""
    Gosub CAL_SANSTBL   : # suppression et/ou calcul des lignes sans tables liees
  Else
    Gosub CAL_AVECTBL   : # suppression et/ou calcul des lignes avec tables liees
  Endif
  If GOK<>1 : Break : Endif
Next
Filter [SPI]
Filter [SND]

Return

#---
$ERR_SEL
GERREUR=errn
#            erreur a l'évaluation de
Call ERREUR (mess(18,71,1)+"\"+[F:SND]SELFRM+"\"+
&            errmes$(GERREUR)+"\|"+errm+"|") From GESECRAN
Call ECR_TRACE(mess(18,71,1)+" "+[F:SND]SELFRM+"  "+
&            errmes$(GERREUR),1) From GESECRAN
Resume

#----------------------------------------------------------------------
# Si absence de tables liees :
# - si parametrage de suppression : pas de lecture des lignes de la fiche

$CAL_SANSTBL
# --- constitution de la clé du filtre
Local Char    EXPRESSION (250)
Local Integer IAFF
EXPRESSION="1=1"
If [F:SND]SELFRM<>""                        : # il y a un filtre sur la selection
  IAFF = find([F:SND]SELFRM,[F:SNE]VARCOD)
  If IAFF & [F:SNE]VARTYP(IAFF-1)="AFF"
    EXPRESSION += " & "+evalue([F:SNE]VARCOD(IAFF-1)) : # selection dans une variable
  Else
    EXPRESSION += " & "+[F:SND]SELFRM                 : # selection dans la donnée
  Endif
Endif
If [F:SND]DELFLG=2
  Onerrgo ERR_SEL
  Delete [SPI] Where PLI=[F:SPF]PLI & PLICRD=[F:SPF]PLICRD & evalue(EXPRESSION)
  Onerrgo ERREUR From CONTROLE
  If    fstat=1 : GOK=-1 : GLOCK="$SPRICINCR"-[F:SPF]PLI-[F:SPF]PLICRD : Goto PAS_OK
  Elsif fstat>5 : GOK=0  : Call FSTA("SPI") From GLOCK                 : Goto PAS_OK
  Endif
Else
  Onerrgo ERR_SEL
  Filter [SPI] Where PLI=[F:SPF]PLI & PLICRD=[F:SPF]PLICRD & evalue(EXPRESSION)
  Onerrgo ERREUR From CONTROLE
  For [SPI]
    Readlock [SPI] Curr
    If fstat=1
      GOK=-1 : GLOCK="$SPRICINCR"-[F:SPI]PLI-[F:SPI]PLICRD-[F:SPI]PLILIN : Goto PAS_OK
    Elsif fstat
      GOK=0  : Call RSTA("SPI","") From GLOCK : Goto PAS_OK
    Endif
    Gosub MAJ_UNE_LIGNE
    Rewrite [SPI]
    If fstat
      GOK=0 : Call FSTA("SPI") From GLOCK : Goto PAS_OK
    Endif
  Next
  Filter [SPI]
Endif
Return


#----------------------------------------------------------------------
# Si presence de tables liees :
# - si parametrage de suppression : boucle de lecture des lignes de la fiche
#                                   pour tester les conditions de suppression

$CAL_AVECTBL
Local Char    EXPRESSION (250)
Local Integer IAFF
EXPRESSION="1=1"
If [F:SND]SELFRM<>""                        : # il y a un filtre sur la selection
  IAFF = find([F:SND]SELFRM,[F:SNE]VARCOD)
  If IAFF & [F:SNE]VARTYP(IAFF-1)="AFF"
    EXPRESSION += " & "+evalue([F:SNE]VARCOD(IAFF-1)) : # selection dans une variable
  Else
    EXPRESSION += " & "+[F:SND]SELFRM                 : # selection dans la donnée
  Endif
Endif
Filter [SPI] Where PLI=[F:SPF]PLI & PLICRD=[F:SPF]PLICRD
For [SPI]
  Gosub LECT_TBL From =NOMTRT
  Onerrgo ERR_SEL
  If evalue(EXPRESSION)
    Onerrgo ERREUR From CONTROLE
    If [F:SND]DELFLG=2    : # suppression de la ligne
      Delete [SPI]Curr
      If    fstat=1 : GOK=-1 : GLOCK="$SPRICINCR"-[F:SPF]PLI-[F:SPF]PLICRD : Goto PAS_OK
      Elsif fstat>5 : GOK=0  : Call FSTA("SPI") From GLOCK                 : Goto PAS_OK
      Endif
    Else                  : # maj de la ligne
      Readlock [SPI] Curr
      If fstat=1
        GOK=-1 : GLOCK="$SPRICINCR"-[F:SPI]PLI-[F:SPI]PLICRD-[F:SPI]PLILIN : Goto PAS_OK
      Elsif fstat
        GOK=0  : Call RSTA("SPI","") From GLOCK : Goto PAS_OK
      Endif
      Gosub MAJ_UNE_LIGNE
        Rewrite [SPI]
        If fstat
          GOK=0 : Call FSTA("SPI") From GLOCK : Goto PAS_OK
        Endif
    Endif
  Else
    Onerrgo ERREUR From CONTROLE
  Endif

Next
Filter [SPI]
Return

#---
$PAS_OK
Filter [SPI]
Return

#----------------------------------------------------------------------
# Mise a jour d'une ligne dans le fichier de travail
#----------------------------------------------------------------------
$MAJ_UNE_LIGNE

Local Decimal MNTV   : # montant à ajouter en valeur ou %
Local Decimal MNT    : # nouveau montant calculé
Local Integer IZ

For I=0 To dim([F:SND]INCFLD)-1
  If [F:SND]INCFLDUPD(I)>1
    Raz MNTV, MNT, IZ
    Case [F:SND]INCFLD(I)
      When "PRI"      : MNT=[F:SPI]PRI       : IZ=0 : Gosub MAJ_VALEUR : [F:SPI]PRI=MNT
      When "XFRAREM1" : MNT=[F:SPI]DCGVAL(0) : IZ=1 : Gosub MAJ_VALEUR : [F:SPI]DCGVAL(0)=MNT
      When "XFRAREM2" : MNT=[F:SPI]DCGVAL(1) : IZ=2 : Gosub MAJ_VALEUR : [F:SPI]DCGVAL(1)=MNT
      When "XFRAREM3" : MNT=[F:SPI]DCGVAL(2) : IZ=3 : Gosub MAJ_VALEUR : [F:SPI]DCGVAL(2)=MNT
      When "XFRAREM4" : MNT=[F:SPI]DCGVAL(3) : IZ=4 : Gosub MAJ_VALEUR : [F:SPI]DCGVAL(3)=MNT
      When "XFRAREM5" : MNT=[F:SPI]DCGVAL(4) : IZ=5 : Gosub MAJ_VALEUR : [F:SPI]DCGVAL(4)=MNT
      When "XFRAREM6" : MNT=[F:SPI]DCGVAL(5) : IZ=6 : Gosub MAJ_VALEUR : [F:SPI]DCGVAL(5)=MNT
      When "XFRAREM7" : MNT=[F:SPI]DCGVAL(6) : IZ=7 : Gosub MAJ_VALEUR : [F:SPI]DCGVAL(6)=MNT
      When "XFRAREM8" : MNT=[F:SPI]DCGVAL(7) : IZ=8 : Gosub MAJ_VALEUR : [F:SPI]DCGVAL(7)=MNT
      When "XFRAREM9" : MNT=[F:SPI]DCGVAL(8) : IZ=9 : Gosub MAJ_VALEUR : [F:SPI]DCGVAL(8)=MNT
    Endcase
  Endif
Next I
Return

#----------------------------------------------------------------------
# Type augment.: 1=non / 2=variation en % / 3=var. en mnt / 4=affectation
#----------------------------------------------------------------------
$MAJ_VALEUR

Onerrgo ERR_VAL
Case [F:SND]INCFLDUPD(I)
  When 1       : Goto SUITE
  When 2       : MNTV=evalue([F:SND]INCFRM(I))
                 MNT=MNT+((MNT*MNTV)/100)
                 Goto ARRONDI_VAL
  When 3       : MNTV=evalue([F:SND]INCFRM(I))
                 MNT=MNT+MNTV
                 Goto ARRONDI_VAL
  When 4       : MNTV=evalue([F:SND]INCFRM(I))
                 MNT=MNTV
                 Goto ARRONDI_VAL
  When Default : Goto SUITE
Endcase

#---
$ARRONDI_VAL
#   pas de résultat négatif
If MNT<0 : MNT=0 : Endif

If IZ>0                                   : # uniquement pour colonnes frais/remise
    If instr(1, GFMTCOL(IZ-1), "[F:TCU]") : # Arrondi devise
        Call ARRDEV(MNT,[F:SPI]CUR) From TRTDIV
    Else
        MNT=arr(MNT,JGARRRAT(IZ-1))
    Endif
Endif

#If IZ>0                    : # uniquement pour colonnes frais/remise
#  If[F:PRS]VALTYP(IZ-1)=1  : # si c'est un montant arrondi devise
#    Call ARRDEV(MNT,[F:SPI]CUR) From TRTDIV
#  Else                     : # si c'est un taux arrondi type donnée RAT
#    MNT=arr(MNT,JGARRRAT)
#  Endif
#Endif

#   arrondi paramétré 1=non / 2=plus proche (adonix) / 3=inférieur / 4=supérieur
Case [F:SND]INCRNDTYP(I)
  When 1       : Goto SUITE
  When 2       : MNT=arr(MNT,[F:SND]INCRND(I))
                 Goto SUITE
  When 3       : If [F:SND]INCRND(I)>0
                   MNT=[F:SND]INCRND(I)*int(MNT/[F:SND]INCRND(I))
                 Endif
                 Goto SUITE
  When 4       : If [F:SND]INCRND(I)>0
                   MNT=-[F:SND]INCRND(I)*int(-MNT/[F:SND]INCRND(I))
                 Endif
                 Goto SUITE
  When Default : Goto SUITE
Endcase

#---
$SUITE
Onerrgo ERREUR From CONTROLE
Return

$ERR_VAL
GERREUR=errn
#            erreur à l'évaluation de
Call ERREUR (mess(18,71,1)+"\"+[F:SND]INCFRM(I)+"\"+
&            errmes$(GERREUR)+"\|"+errm+"|") From GESECRAN
Call ECR_TRACE(mess(18,71,1)+" "+[F:SND]INCFRM(I)+"  "+
&            errmes$(GERREUR),1) From GESECRAN
Resume


#-----------------------------------------------------------------------
# Duplication de fiche : création d'une nouvelle fiche
#-----------------------------------------------------------------------
# - recherche d'un code fiche (lecture compteur)
# - écriture des lignes [SPL] de la nouvelle fiche et comptage des lignes
# - écriture entête nouvelle fiche [SPFN] (autre abbréviation)
# - si date fin de fiche origine supérieure à date début de nelle fiche,
#   la fiche origine est ajustée (date fin = date début nelle fiche -1)
#-----------------------------------------------------------------------
$MAJ_DUPLI

Local Integer STAT
Local Char    SITE                     : # site : permet egalement de retrouver la societe
Local Char    COMPLEMENT (15)
[F:SPFN]=[F:SPF]
# 73596 Possibilité d'affecter un nouveau code au tarif
If WNEW_PLI<>""
  [F:SPFN]PLI=WNEW_PLI
Endif

If [F:SPFN]PLICRDIDX<>"" COMPLEMENT=[F:SPFN]PLICRDIDX
   Else                  COMPLEMENT=[F:SPFN]PLI
Endif

If GMANCOU<>2
  SITE=GFCYDEF(5)                      : # site de vente par défaut
  Call NUMERO(GCODNUM,SITE,[M:SPCI]NEWSTRDAT,COMPLEMENT,[F:SPFN]PLICRD,STAT) From SUBANM
  If STAT=0
    [F:SPFN]PLICRD=vireblc([F:SPFN]PLICRD,4)
    CRDNEW=[F:SPFN]PLICRD
  Else
    Call ECR_TRACE(mess(60,199,1),1) From GESECRAN
#   problème lors de la récupération du compteur
    GOK=0 : Return
  Endif
Else
    Call ECR_TRACE(mess(253,199,1),1) From GESECRAN
#   le compteur doit être automatique
    GOK=0 : Return
Endif

Filter [SPI] Where PLI=[F:SPF]PLI & PLICRD=[F:SPF]PLICRD
Raz JGCOMPTAGE
For [SPI]
  [F:SPL]=[F:SPI]
  [F:SPL]PLI=[F:SPFN]PLI : # 73596 Possibilité d'affecter un nouveau code au tarif
  [F:SPL]PLICRD=[F:SPFN]PLICRD
  [F:SPL]PLISTRDAT=[M:SPCI]NEWSTRDAT
  [F:SPL]PLIENDDAT=[M:SPCI]NEWENDDAT
  Raz [F:SPL] IMPNUMLIG, [F:SPL]EXPNUM, [F:SPL]UPDUSR, [F:SPL]UPDDAT
  [F:SPL]CREUSR=GUSER : [F:SPL]CREDAT=date$
  Write [SPL]
  If fstat
    GOK=0  : Call FSTA("SPL") From GLOCK : Break
  Endif
  JGCOMPTAGE +=1
Next
If GOK<>1 : Return : Endif

If JGCOMPTAGE>0
  [F:SPFN]PLISTRDAT=[M:SPCI]NEWSTRDAT
  [F:SPFN]PLIENDDAT=[M:SPCI]NEWENDDAT
  [F:SPFN]LINNBR=JGCOMPTAGE
  Raz [F:SPFN]EXPNUM, [F:SPFN]UPDUSR, [F:SPFN]UPDDAT
  [F:SPFN]CREUSR=GUSER : [F:SPFN]CREDAT=date$
  Write [SPFN]
  If fstat
    GOK=0  : Call FSTA("SPFN") From GLOCK : Return
  Endif
Endif

#     m.a.j. date fin dans la fiche origine [SPF]
#     m.a.j. date de fin dans les lignes [SPL]

If [F:SPF]PLISTRDAT<[M:SPCI]NEWSTRDAT & [F:SPF]PLIENDDAT>=[M:SPCI]NEWSTRDAT
  [F:SPF]PLIENDDAT=[M:SPCI]NEWSTRDAT-1
  [F:SPF]UPDUSR=GUSER : [F:SPF]UPDDAT=date$
  Rewrite [SPF]
  If fstat=1
    GOK=-1 : GLOCK="$SPRICFICH"-[F:SPF]PLI-[F:SPF]PLICRD : Return
  Elsif fstat
    GOK=0  : Call FSTA("SPF") From GLOCK                 : Return
  Endif
  Update [SPL] Where PLI=[F:SPF]PLI & PLICRD=[F:SPF]PLICRD
&              With PLIENDDAT=[M:SPCI]NEWSTRDAT-1, UPDUSR=GUSER, UPDDAT=date$
  If fstat=1
    GOK=-1 : GLOCK="$SPRICLIST"-[F:SPF]PLI-[F:SPF]PLICRD : Return
  Elsif fstat=3 | fstat>5
    GOK=0  : Call FSTA("SPL") From GLOCK                 : Return
  Endif
Endif

Return

#-----------------------------------------------------------------------
# Modification de fiche
#-----------------------------------------------------------------------
# - suppression des anciennes lignes [SPL]
# - écriture des nouvelles lignes [SPL] et comptage des lignes
# - récriture entête fiche [SPF]
#-----------------------------------------------------------------------
$MAJ_MODIF

Delete [SPL] Where PLI=[F:SPF]PLI & PLICRD=[F:SPF]PLICRD
If fstat=1
  GOK=-1 : GLOCK="$SPRICLIST"-[F:SPF]PLI-[F:SPF]PLICRD   : Return
Elsif fstat>5
  GOK=0  : Call FSTA("SPL") From GLOCK                   : Return
Endif

Filter [SPI] Where PLI=[F:SPF]PLI & PLICRD=[F:SPF]PLICRD
Raz JGCOMPTAGE
For [SPI]
  [F:SPL]=[F:SPI]
  [F:SPL]PLISTRDAT=[M:SPCI]NEWSTRDAT
  [F:SPL]PLIENDDAT=[M:SPCI]NEWENDDAT
  [F:SPL]UPDUSR=GUSER : [F:SPL]UPDDAT=date$
  Write [SPL]
  If fstat
    GOK=0  : Call FSTA("SPL") From GLOCK : Break
  Endif
  JGCOMPTAGE +=1
Next
If GOK<>1 : Return : Endif

Raz [F:SPF]EXPNUM : [F:SPF]LINNBR=JGCOMPTAGE
[F:SPF]PLISTRDAT=[M:SPCI]NEWSTRDAT
[F:SPF]PLIENDDAT=[M:SPCI]NEWENDDAT
[F:SPF]UPDUSR=GUSER : [F:SPF]UPDDAT=date$
Rewrite [SPF]
If fstat=1
  GOK=-1 : GLOCK="$SPRICFICH"-[F:SPF]PLI-[F:SPF]PLICRD : Return
Elsif fstat
  GOK=0  : Call FSTA("SPF") From GLOCK                 : Return
Endif

Return


#-----------------------------------------------------------------------
# Changement devise : création d'une nouvelle fiche
# - recherche d'un code fiche (lecture compteur)
# - ecriture des lignes [SPL] de la nouvelle fiche et comptage des lignes
# - ecriture entête nouvelle fiche [SPFN] (autre abbréviation)
#-----------------------------------------------------------------------
$MAJ_DEVISE

Local Integer STAT
Local Char    SITE                     : # site : permet egalement de retrouver la societe
Local Char    COMPLEMENT (15)
[F:SPFN]=[F:SPF]
# 73596 Possibilité d'affecter un nouveau code au tarif
If WNEW_PLI<>""
  [F:SPFN]PLI=WNEW_PLI
Endif

If [F:SPFN]PLICRDIDX<>"" COMPLEMENT=[F:SPFN]PLICRDIDX
   Else                  COMPLEMENT=[F:SPFN]PLI
Endif

If GMANCOU<>2
  SITE=GFCYDEF(5)                      : # site de vente par défaut
  Call NUMERO(GCODNUM,SITE,[M:SPCI]NEWSTRDAT,COMPLEMENT,[F:SPFN]PLICRD,STAT) From SUBANM
  If STAT=0
    [F:SPFN]PLICRD=vireblc([F:SPFN]PLICRD,4)
    CRDNEW=[F:SPFN]PLICRD
  Else
    Call ECR_TRACE(mess(60,199,1),1) From GESECRAN
#   problème lors de la récupération du compteur
    GOK=0 : Return
  Endif
Else
    Call ECR_TRACE(mess(253,199,1),1) From GESECRAN
#   le compteur doit être automatique
    GOK=0 : Return
Endif

Filter [SPI] Where PLI=[F:SPF]PLI & PLICRD=[F:SPF]PLICRD
Raz JGCOMPTAGE
For [SPI]
  [F:SPL]=[F:SPI]
  [F:SPL]PLI=[F:SPFN]PLI : # 73596 Possibilité d'affecter un nouveau code au tarif
  [F:SPL]PLICRD=[F:SPFN]PLICRD
  [F:SPL]PLISTRDAT=[M:SPCI]NEWSTRDAT
  [F:SPL]PLIENDDAT=[M:SPCI]NEWENDDAT
  Raz [F:SPL] IMPNUMLIG, [F:SPL]EXPNUM, [F:SPL]UPDUSR, [F:SPL]UPDDAT
  [F:SPL]CREUSR=GUSER : [F:SPL]CREDAT=date$
  Write [SPL]
  If fstat
    GOK=0  : Call FSTA("SPL") From GLOCK : Break
  Endif
  JGCOMPTAGE +=1
Next
If GOK<>1 : Return : Endif

If JGCOMPTAGE>0
  [F:SPFN]PLISTRDAT=[M:SPCI]NEWSTRDAT
  [F:SPFN]PLIENDDAT=[M:SPCI]NEWENDDAT
  [F:SPFN]LINNBR=JGCOMPTAGE
  Raz [F:SPFN]EXPNUM, [F:SPFN]UPDUSR, [F:SPFN]UPDDAT
  [F:SPFN]CREUSR=GUSER : [F:SPFN]CREDAT=date$
  Write [SPFN]
  If fstat
    GOK=0  : Call FSTA("SPFN") From GLOCK : Return
  Endif
Endif

Return

#######################################################################
# Actions champs ecran SPCINCR [SPCI]
#######################################################################

######################################## Code augmentation
Subprog AS_COD(VALEUR)
Variable Char    VALEUR()
If GFONCTION="GESSNE"
  VALEUR=[F:SNE]COD
  Gosub ALI_MSK
  mkstat=2
Endif
End

#---------------------------------------
Subprog C_COD(VALEUR)
Variable Char    VALEUR()
Call CONTROLE("SNE","",VALEUR,"",mkstat) From CONTOBJ
If mkstat : End : Endif
Gosub CONT_ACCES
End

#---------------------------------------
Subprog AM_COD(VALEUR)
Variable Char    VALEUR()
Gosub ALI_MSK
End

#---------------------------------------

$ALI_MSK
Call LECTURE("SNE",VALEUR,"") From CONTOBJ
Call LECTEXTRA ([M:SPCI]DES,"SINCENT","DESAXX",VALEUR,"") From ATEXTRA  # FGR 28/02/2014 : X3SUIVI97253

Call LECTURE("SPC",[F:SNE]PLI,"") From CONTOBJ
[M:SPCI]SIMFLG=2
[M:SPCI]SEEFLG=2
[M:SPCI]=[F:SNE]
#[M:SPCI]PLIDES=[F:SPC]PLIDES
Call LECTEXTRA ([M:SPCI]PLIDES,"SPRICCONF","DESAXX",[F:SPC]PLI,"") From ATEXTRA
For I=0 To dim([M:SPCI]VARCOD)-1
  [M:SPCI]VARVAL(I)=[M:SPCI]VARDEF(I)
  # Bug 75378
  Call LECTEXTRA ([M:SPCI]VARDES(I),"SINCENT","VARDESAXX",[F:SNE]COD,[F:SNE]VARCOD(I)) From ATEXTRA
Next I

Gosub T_FORMULE

Affzo [M:SPCI]1-99
GFLTPLI=[F:SNE]PLI
Return

######################################## Flag simulation
Subprog AM_SIMFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M:SPCI]SEEFLG=2 : Affzo [M:SPCI]SEEFLG
Endif
End

######################################## Flag visualisation
Subprog AS_SEEFLG(VALEUR)
Variable Integer VALEUR
If [M:SPCI]SIMFLG=2 : VALEUR=2 : mkstat=2 : Endif
End

######################################## No fiche début
Subprog IB_PLISTRCRD
GBOUT1=mess(9,432,1)
End

#---------------------------------------
Subprog AS_PLISTRCRD(VALEUR)
Variable Char    VALEUR()
If [M]UPDCRDFLG<>2 : mkstat=2 : Endif
End

#---------------------------------------
Subprog C_PLISTRCRD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   Look [SPF] SPF0=[M]PLI;VALEUR
   If fstat
      GMESSAGE = mess(129,192,1) : # fiche n'appartenant pas au tarif
      mkstat=2
   Endif
Endif
End

######################################## No fiche fin
Subprog IB_PLIENDCRD
GBOUT1=mess(9,432,1)
End

#---------------------------------------
Subprog AS_PLIENDCRD(VALEUR)
Variable Char    VALEUR()
If [M]UPDCRDFLG<>2 : mkstat=2 : Endif
End

#---------------------------------------
Subprog C_PLIENDCRD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   Look [SPF] SPF0=[M]PLI;VALEUR
   If fstat
      GMESSAGE = mess(129,192,1) : # fiche n'appartenant pas au tarif
      mkstat=2
   Endif
Endif
End

####################################### Valide au
Subprog AS_VLYDAT(VALEUR)
Variable Date    VALEUR
If [M]UPDCRDFLG<>2 : mkstat=2 : Endif
End

######################################## Date début validité
Subprog AS_PLISTRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & [M]UPDDATFLG<>2 : mkstat=2 : Endif
End

######################################## Date fin validité
Subprog AS_PLIENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & [M]UPDDATFLG<>2 : mkstat=2 : Endif
End

######################################## Ancienne devise
Subprog AS_CUROLD(VALEUR)
Variable Char    VALEUR()
If [M]TYP<>3 : mkstat=2 : Endif
End

#---------------------------------------
Subprog C_CUROLD(VALEUR)
Variable Char    VALEUR()
If [M]TYP=3 & VALEUR="" : mkstat=2 : End : Endif
If [M]TYP=3 & VALEUR=[M]CURNEW : mkstat=2 : End : Endif
End

######################################## Nouvelle devise
Subprog AS_CURNEW(VALEUR)
Variable Char    VALEUR()
If [M]TYP<>3 : mkstat=2 : Endif
End

#---------------------------------------
Subprog C_CURNEW(VALEUR)
Variable Char    VALEUR()
If [M]TYP=3 & VALEUR="" : mkstat=2 : End : Endif
If [M]TYP=3 & VALEUR=[M]CUROLD : mkstat=2 : End : Endif
End

######################################## Type de cours
Subprog AS_CHGTYP(VALEUR)
Variable Integer VALEUR
If [M]TYP<>3 : mkstat=2 : Endif
End

#---------------------------------------
Subprog C_CHGTYP(VALEUR)
Variable Integer VALEUR
If [M]TYP=3 & VALEUR=0 : mkstat=2 : End :  Endif
End

######################################## Valeur des variables
Subprog IB_VARVAL
Raz GBOUT2
Read [ATY]CODTYP=[F:SNE]VARTYP(nolign-1)
If !fstat & [F:ATY]OBJLIEN<>""
  GBOUT2=mess(18,100,1)
Endif
# si type de donnee <>"AFF" : suppression du bouton "Editeur de formule"
If [F:SNE]VARTYP(nolign-1)<>"AFF"
   Raz GBOUT1
Endif

End

#---------------------------------------
Subprog C_VARVAL(VALEUR)
Variable Char    VALEUR()       : # VALEUR est toujours alpha (type donnee = AFF)
Local    Char    WJ_VALCHR

If [F:ATY]CODTYP<>[M]VARTYP(nolign-1)
   Read [ATY]CODTYP = [M]VARTYP(nolign-1)
   If fstat : Raz [F:ATY] : mkstat=2 : End : Endif
Endif

Case [F:ATY]TYPTYP
     When 1         : Local Libelle  WJ_VAL
     When 2         : Local Shortint WJ_VAL
     When 3         : Local Integer  WJ_VAL
     When 4,5,6     : Local Decimal  WJ_VAL
     When 7         : Local Char     WJ_VAL (250)
     When 8         : Local Date     WJ_VAL

     When Default   : End
Endcase

If VALEUR <>""

   If [F:ATY]OBJLIEN<>""                        : # si type donnee avec lien --> majuscule
      VALEUR = vireblc(toupper(VALEUR),2)
   Endif

   If find([F:ATY]TYPTYP,1,2,3,4,5,6)           : # Controle valeur numerique
      WJ_VAL=val(VALEUR)
      If num$(WJ_VAL)<>VALEUR
         mkstat=2 : End
      Endif
   Endif

   If [F:ATY]TYPTYP=7                           : # Controle valeur alpha
      WJ_VAL=vireblc(VALEUR,2)   :              : #   enlever guillemets
      If find ((mid$(WJ_VAL,1,1)),"'",'"') & find((mid$(WJ_VAL,len(WJ_VAL),1)),"'",'"')
         WJ_VAL=right$(WJ_VAL,2)
         WJ_VAL=left$(WJ_VAL,len(WJ_VAL)-1)
      Endif
   Endif

   If [F:ATY]OBJLIEN<>""                        : # Controle par objet
      WJ_VALCHR=num$(WJ_VAL)
      Call CONTROLE ([F:ATY]OBJLIEN,"",WJ_VALCHR,"",mkstat) From CONTOBJ
      If mkstat : End : Endif
   Endif

   If [F:ATY]TYPTYP=8                  : # Controle valeur date
      Call CONTROLE(VALEUR,"D",0,0,WJ_VALCHR) From FMTVAR
      If mkstat : GERR=1 : GZONE="VARVAL" : GZNUM=0 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
      WJ_VAL=WJ_VALCHR
   Endif

   If [M]VARCTL(nolign-1)<>""                   : # Controle avec Table de controle
      Case [F:ATY]TYPTYP
           When 1         :  Call CONTACL_LIB ([M]VARCTL(nolign-1),"",WJ_VAL) From SUBACL
           When 2,3,4,5,6 :  Call CONTACL_NUM ([M]VARCTL(nolign-1),"",WJ_VAL) From SUBACL
           When 7         :  Call CONTACL_CHAR([M]VARCTL(nolign-1),"",WJ_VAL) From SUBACL
           When 8         :  Call CONTACL_DAT ([M]VARCTL(nolign-1),"",WJ_VAL) From SUBACL
      Endcase
      If mkstat : End : Endif
   Endif
Endif

End

#######################################################################

$CONT_ACCES
If [F:SNE]ACS<>"" & GUSRACS<>2
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  Read [ACC]CODACC = GUSER;[F:SNE]ACS
  If fstat
    GERR=1 : GMESSAGE=mess(3,104,1) : mkstat=2 : End
    # Vous n'avez pas accès à ce code
  Elsif [F:ACC]EXEC<>2
    GERR=1 : GMESSAGE=mess(4,104,1) : mkstat=2 : End
    # Vous n'avez pas accès à ce code
  Endif
Endif
Return

#---------------------------------------

#--- c'est une formule (type=AFF)
$T_FORMULE
Local    Integer I,IJ
Raz [M:SPCI]FLTTAB, XXCONV, XXVAR, XXPRS

#Read [F:PRS]PRS0=1;""
Read [F:PRS]PRS0=1;[F:SNE]PLISTC
Call COLREM("C",1,[F:SNE]PLISTC) From TRTPRICE

Read [SPC]SPC0=[F:SNE]PLI
If fstat : Raz [F:SPC] : Endif
For I=0 To dim([F:PRS]INVDTA)-1
  If [F:SPC]DISCRGPRO(I)=1
     Call LECTEXTRA ([M:SPCI]XXPRS(I),"PRICSTRUCT","DESAXX("+num$(I)+")","1",[F:PRS]PLISTC)
&                    From ATEXTRA
  Endif
Next I

[M:SPCI]FLTTAB="find(ABRFIC,'SPI')"
#   critères variables du tarif
For I=0 To dim([F:SPC]ABB)-1
  If [F:SPC]ABB(I)<>""
    [M:SPCI]XXCONV(IJ)="SPRICINCR,CRIT"+num$(I+1)+","+[F:SPC]CRIDES(I)
    IJ += 1
    [M:SPCI]XXCONV(IJ)="SPRICINCR,PLICRI"+num$(I+1)+","+[F:SPC]CRIDES(I)
    IJ += 1
  Else
    [M:SPCI]XXCONV(IJ)="SPRICINCR,CRIT"+num$(I+1)+","
    IJ += 1
    [M:SPCI]XXCONV(IJ)="SPRICINCR,PLICRI"+num$(I+1)+","
    IJ += 1
  Endif
Next I
For I=0 To dim([F:PRS]INVDTA)-1
  If [M:SPCI]XXPRS(I)<>""
    [M:SPCI]XXCONV(IJ)="SPRICINCR,DCGVAL("+num$(I)+"),"+[M:SPCI]XXPRS(I)
    IJ += 1
  Else
    [M:SPCI]XXCONV(IJ)="SPRICINCR,DCGVAL("+num$(I)+"),"
    IJ += 1
  Endif
Next I
#   variables du traitement
For I=0 To dim([F:SNE]VARCOD)-1
  If [F:SNE]VARCOD(I)<>""
    [M:SPCI]XXVAR(I)=[F:SNE]VARCOD(I)+","+[F:SNE]VARDES(I)
  Endif
Next I
Return

#######################################################################
