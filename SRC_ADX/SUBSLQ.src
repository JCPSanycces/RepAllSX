#<AdxTL>@(#)1.0.0.0 $Revision$
Call OBJET ("SLQ",GBIDC1,GBIDC2) From GOBJET
End
#######################################################################
# SUBSLQ : Transactions de saisie des devis              EB  03/12/97 #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:SLQ]SALTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des parmètres fenêtres  #
#                                                                     #
# Génération de 3 écrans de saisie à partir des écrans de base SQH1   #
#                                                              SQH2   #
#                                                              SQH3   #
#                                                                     #
# Nom des écrans générés : WKxyyyz                                    #
#                            x = type de la transaction (STRTYP)      #
#                                1 -    devis                         #
#                                2 -    commandes                     #
#                                3 -    commandes ouvertes            #
#                                                                     #
#                          yyy = no de la transaction   (STRNUM)      #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                1 et 2 devis                         #
#######################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
                      Gosub OUVRE From SUBSLX
                      Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="SLT"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=1
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "EFFMASK"     : [M]STRTYP = 1
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="SLT"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
                      Gosub ANNULE From SUBSLX
 When "LIENS"       : Gosub TRT_DIETRS From SUBDST : Gosub LIENS From SUBSLX
 When "APRES_MODIF" : Gosub APRES_MODIF From SUBSLX
 When "INICRE"      : Gosub INICRE From SUBSLX
 When "INIMOD"      : Gosub INICRE From SUBSLX
 When Default
Endcase
Return
#-------------------------------------------------------#
#                                                       #
#-------------------------------------------------------#
$OUVRE
Local Char APPLI
APPLI=nomap
Return

#-------------------------------------------------------#
# Ne traiter que les transactions de type devis         #
#-------------------------------------------------------#
$FILTRE
FILTSUP="STRTYP=1"
Return


#---------------------------------#
# Désactivation des boutons       #
#---------------------------------#
$SETBOUT
If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Return

#-------------------------------------#
# Après appui sur les boutons         #
#-------------------------------------#
$EXEBOUT
Case BOUT
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

$RAZCRE
[M:SLQ0]ENAFLG = 2

Return

#------------------------------------------------#
# Génération ou suppression de l'écran de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(APPLI)<0 Local Char APPLI : Endif
If APPLI=""     APPLI=nomap      : Endif
Local Char    MFROM(GLONAMK)
Local Char    MTO(GLONAMK)
Local Integer TBLOC(15)
Local Char    TZONE(GLONAVA)(200)
Local Integer TMOD(200)
Local Char    TINT(1)(200)
Local Char    TTAB(1)(1)
Local Char    TFLD(1)(1)
Local Integer OPT1, OPT2, OPT3, RETOUR
Local Integer IZON
# Local Char    BOUTONS(10)(4), TEXTE(40), LISTE(3), REPONS(1)

#------------------------- écran SQH1 -------------------------#
MFROM="SQH1"
MTO="WK"+num$([M:SLQ0]STRTYP)+[M:SLQ0]STRNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If   ACTION <> "ANNULE"
     #---- adresse livraison
     If   [M:SLQ2]BPAADDCOD > 1 TZONE(IZON)="BPAADD"
                                TMOD(IZON) =[M:SLQ2]BPAADDCOD
                                IZON+=1
                                TZONE(IZON)="BPDNAM"
                                TMOD(IZON) =[M:SLQ2]BPAADDCOD
                                IZON+=1
     Endif
     # 71065 : PJT
     #---- affaire
     If   [M:SLQ2]PJTCOD > 1    TZONE(IZON)="PJT"
                                TMOD(IZON) =[M:SLQ2]PJTCOD
                                IZON+=1
#                                TZONE(IZON)="PJTCLA"
#                                TMOD(IZON) =[M:SLQ2]PJTCOD
#                                IZON+=1
     Endif
     # 71065 : PJT
     #---- site expédition
     If   [M:SLQ2]STOFCYCOD > 1 TZONE(IZON)="STOFCY"
                                TMOD(IZON) =[M:SLQ2]STOFCYCOD
                                IZON+=1
     Endif
     #---- délai de livraison
     If   [M:SLQ2]DAYLTICOD > 1 TZONE(IZON)="DAYLTI"
                                TMOD(IZON) =[M:SLQ2]DAYLTICOD
                                IZON+=1
     Endif
     #---- CPO 65018
     #---- Incoterm et ville Incoterm
     If   [M:SLQ2]EECICTCOD > 1 TZONE(IZON)="EECICT"
                                TMOD(IZON) =[M:SLQ2]EECICTCOD
                                IZON+=1
                                TZONE(IZON)="ICTCTY"
                                TMOD(IZON) =[M:SLQ2]EECICTCOD
                                IZON+=1
     Endif
     #---- représentant
     If   [M:SLQ2]REPCOD > 1    TZONE(IZON)="REP"
                                TMOD(IZON) =[M:SLQ2]REPCOD
                                IZON+=1
     Endif
     #---- régime de taxe
     If   [M:SLQ2]VACBPRCOD > 1 TZONE(IZON)="VACBPR"
                                TMOD(IZON) =[M:SLQ2]VACBPRCOD
                                IZON+=1
     Endif
     #LTA.sn entity/use code for local taxing
     If func AFNC.ACTIV("LTA") and [M:SLQ2]SSTENTCOD > 1
                                TZONE(IZON)="SSTENTCOD"
                                TMOD(IZON) =[M:SLQ2]SSTENTCOD
                                IZON+=1
     Endif
     #LTA.en
     #---- devise
     If   [M:SLQ2]CURCOD > 1    TZONE(IZON)="CUR"
                                TMOD(IZON) =[M:SLQ2]CURCOD
                                IZON+=1
     Endif
     #---- prix HT/TTC
     If   [M:SLQ2]PRITYPCOD > 1 TZONE(IZON)="PRITYP"
                                TMOD(IZON) =[M:SLQ2]PRITYPCOD
                                IZON+=1
     Endif
     #---- date de validité
     If   [M:SLQ2]VLYDATCOD > 1 TZONE(IZON)="VLYDAT"
                                TMOD(IZON) =[M:SLQ2]VLYDATCOD
                                IZON+=1
     Endif
     #---- taux de probabilité cde
     If   [M:SLQ2]PBYPRCCOD > 1 TZONE(IZON)="PBYPRC"
                                TMOD(IZON) =[M:SLQ2]PBYPRCCOD
                                IZON+=1
     Endif
     #---- état devis (signé, état devis, devis imprimé)
     If   [M:SLQ1]STACOD = 1 TZONE(IZON)="APPFLG"
                             TMOD(IZON) =3
                             IZON+=1

                             TZONE(IZON)="QUOSTA"
                             TMOD(IZON) =3
                             IZON+=1

                             TZONE(IZON)="QUOPRN"
                             TMOD(IZON) =3
                             IZON+=1
     Endif
     #---- type commande   FGR 23/02/2015 : X3SUIVI104383
     If   [M:SLQ1]SOHTYPCOD<> 2 TZONE(IZON)="SOHTYP"
                                TMOD(IZON) =3
                                IZON+=1
     Endif

     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX

     #---- visualisation du masque généré
     OPT1 = 2
#     If ACTION<>"MASSE"
#        BOUTONS(1)=mess(2,1,1)    : # Oui
#        BOUTONS(2)=mess(1,1,1)    : # Non
#        BOUTONS(3)=mess(71,198,1) : # Abandon
#        TEXTE= " "+mess(1,196,1)  : LISTE="ONA" : REPONS="N"
#        Call CHOIXM(BOUTONS,TEXTE,LISTE,REPONS) From TRTX3
#        If REPONS="A" GOK=0  : Return : Endif
#        If REPONS="O" OPT2=1 : Endif
#     Endif
     #---- suppression du masque
Else OPT1=9
Endif

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
#---- erreur
If RETOUR<>0 GOK=0 : Return : Endif

#------------------------- écran SQH3 -------------------------#
MFROM="SQH3"
MTO="WK"+num$([M:SLQ0]STRTYP)+[M:SLQ0]STRNUM+"3"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON

If   ACTION <> "ANNULE"
     #---- condition de paiement
     If   [M:SLQ2]PTECOD    > 1 TZONE(IZON)="PTE"
                                TMOD(IZON) =[M:SLQ2]PTECOD
                                IZON+=1
     Endif
     #---- escompte
     If   [M:SLQ2]DEPCOD    > 1 TZONE(IZON)="DEP"
                                TMOD(IZON) =[M:SLQ2]DEPCOD
                                IZON+=1
     Endif
     #---- facture proforma
     If   [M:SLQ1]PRFNUMCOD = 1 TZONE(IZON)="PRFNUM"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #----- Test si les sections d'entête sont affichées -----#
     If dim([M:DST]HEACCECOD)>0 & [M:DST]HEACCECOD=2
        TZONE(IZON)="CCE"
        TMOD(IZON)=2
        #TBLOC(2)=2 ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
        IZON+=1
     Endif
     #----- Test si les sections d'entête sont invisibles -----#
     If (dim([M:DST]HEACCECOD)>0 & [M:DST]HEACCECOD=3) | dim([M:DST]HEACCECOD)<1
        TBLOC(2)=1
     Endif
     #------- Test si tous les éléments de facturation sont affichées --------#
     If   [M:SLQ1]INVDTACOD = 2 TZONE(IZON)="INVDTAAMT"
                                TMOD(IZON)=2
                                #TBLOC(3)=2 ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
                                IZON+=1
                                TZONE(IZON)="INVDTATYP"
                                TMOD(IZON) =2
                                #TBLOC(3)=2 ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
                                IZON+=1
                                TZONE(IZON)="SFISSTCOD" # 101380.n
                                TMOD(IZON) =2           # 101380.n
                                #TBLOC(3)=2              # 101380.n ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
                                IZON+=1                 # 101380.n
     Endif
     #------- Test si tous les éléments de facturation sont invisibles --------#
     If   [M:SLQ1]INVDTACOD = 3 TBLOC(3)=1 Endif

     #---- commande (dern no, dern date, nb)
     If   [M:SLQ1]ORDCOD = 1 TZONE(IZON)="SOHNUM"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="ORDDAT"
                             TMOD(IZON) =3
                             IZON+=1
#                             TZONE(IZON)="ORDNBR"
#                             TMOD(IZON) =3
#                             IZON+=1
     Endif

     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX

Endif

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
#---- erreur
If RETOUR<>0 GOK=0 : Return : Endif
#------------------------- écran SQH2 -------------------------#
Local Char    ZT : # nom de zone dans table transaction
Local Char    ZM : # nom de zone dans le masque
Local Integer ZI : # pour les zones indicées
MFROM="SQH2"
MTO="WK"+num$([M:SLQ0]STRTYP)+[M:SLQ0]STRNUM+"2"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
     #---- désignation traduite de l'article
     If   [M:SLQ3]ITMDESCOD > 1 TZONE(IZON)="ITMDES"
                                TMOD(IZON) =[M:SLQ3]ITMDESCOD
                                IZON+=1
     Endif
     If   [M:SLQ3]ITMDESCOD = 1 | [M:SLQ3]ITMDESCOD = 2
        ZT="ITMDESSCR" : ZM="ITMDES" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- désignation standard de l'article
     If   [M:SLQ3]ITMDES1COD> 1 TZONE(IZON)="ITMDES1"
                                TMOD(IZON) =[M:SLQ3]ITMDES1COD
                                IZON+=1
     Endif
     If   [M:SLQ3]ITMDES1COD = 1 | [M:SLQ3]ITMDES1COD = 2
        ZT="ITMDES1SCR" : ZM="ITMDES1" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     # FGR 04/02/2015 : X3SUIVI105605 (début)
     If func AFNC.ACTIV("ECC") Then
       #---- Version majeure
       If   [M:SLQ3]ECCCOD> 1     TZONE(IZON)="ECCVALMAJ"
                                  TMOD(IZON) =[M:SLQ3]ECCCOD
                                  IZON+=1
       Endif
       If   [M:SLQ3]ECCCOD = 1 | [M:SLQ3]ECCCOD = 2
          ZT="ECCSCR" : ZM="ECCVALMAJ" : Gosub TABLEAU_FICHE From SUBSLX
       Endif
       #---- Version mineure
       If   [M:SLQ3]ECCCODMIN> 1  TZONE(IZON)="ECCVALMIN"
                                  TMOD(IZON) =[M:SLQ3]ECCCODMIN
                                  IZON+=1
       Endif
       If   [M:SLQ3]ECCCODMIN = 1 | [M:SLQ3]ECCCODMIN = 2
          ZT="ECCSCRMIN" : ZM="ECCVALMIN" : Gosub TABLEAU_FICHE From SUBSLX
       Endif
     Endif
     # FGR 04/02/2015 : X3SUIVI105605 (fin)
     #---- unité de vente
     If   [M:SLQ3]SAUCOD    > 1 TZONE(IZON)="SAU"
                                TMOD(IZON) =[M:SLQ3]SAUCOD
                                IZON+=1
     Endif
     If   [M:SLQ3]SAUCOD = 1 | [M:SLQ3]SAUCOD = 2
        ZT="SAUSCR" : ZM="SAU" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- coef UV-US
     If   [M:SLQ3]SAUCOECOD > 1 TZONE(IZON)="SAUSTUCOE"
                                TMOD(IZON) =[M:SLQ3]SAUCOECOD
                                IZON+=1
     Endif
     If   [M:SLQ3]SAUCOECOD = 1 | [M:SLQ3]SAUCOECOD = 2
        ZT="SAUCOESCR" : ZM="SAUSTUCOE" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- unité de stock
     If   [M:SLQ1]STUCOD = 1    TZONE(IZON)="STU"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="STUSCR" : ZM="STU" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- prix brut
     If   [M:SLQ3]GROPRICOD > 1 TZONE(IZON)="GROPRI"
                                TMOD(IZON) =[M:SLQ3]GROPRICOD
                                IZON+=1
     Endif
     If   [M:SLQ3]GROPRICOD = 1 | [M:SLQ3]GROPRICOD = 2
        ZT="GROPRISCR" : ZM="GROPRI" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- valeur1 remise/frais
     If   dim([M:SLX1]DISCRGCOD1) > 0
          If  [M:SLX1]DISCRGCOD1 > 1 TZONE(IZON)="DISCRGVAL1"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD1
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD1 = 1 | [M:SLX1]DISCRGCOD1 = 2
             ZT="DISCRGSCR1" : ZM="DISCRGVAL1" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur2 remise/frais
     If   dim([M:SLX1]DISCRGCOD2) > 0
          If  [M:SLX1]DISCRGCOD2 > 1 TZONE(IZON)="DISCRGVAL2"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD2
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD2 = 1 | [M:SLX1]DISCRGCOD2 = 2
             ZT="DISCRGSCR2" : ZM="DISCRGVAL2" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur3 remise/frais
     If   dim([M:SLX1]DISCRGCOD3) > 0
          If  [M:SLX1]DISCRGCOD3 > 1 TZONE(IZON)="DISCRGVAL3"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD3
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD3 = 1 | [M:SLX1]DISCRGCOD3 = 2
             ZT="DISCRGSCR3" : ZM="DISCRGVAL3" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur4 remise/frais
     If   dim([M:SLX1]DISCRGCOD4) > 0
          If  [M:SLX1]DISCRGCOD4 > 1 TZONE(IZON)="DISCRGVAL4"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD4
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD4 = 1 | [M:SLX1]DISCRGCOD4 = 2
             ZT="DISCRGSCR4" : ZM="DISCRGVAL4" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur5 remise/frais
     If   dim([M:SLX1]DISCRGCOD5) > 0
          If  [M:SLX1]DISCRGCOD5 > 1 TZONE(IZON)="DISCRGVAL5"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD5
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD5 = 1 | [M:SLX1]DISCRGCOD5 = 2
             ZT="DISCRGSCR5" : ZM="DISCRGVAL5" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur6 remise/frais
     If   dim([M:SLX1]DISCRGCOD6) > 0
          If  [M:SLX1]DISCRGCOD6 > 1 TZONE(IZON)="DISCRGVAL6"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD6
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD6 = 1 | [M:SLX1]DISCRGCOD6 = 2
             ZT="DISCRGSCR6" : ZM="DISCRGVAL6" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur7 remise/frais
     If   dim([M:SLX1]DISCRGCOD7) > 0
          If  [M:SLX1]DISCRGCOD7 > 1 TZONE(IZON)="DISCRGVAL7"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD7
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD7 = 1 | [M:SLX1]DISCRGCOD7 = 2
             ZT="DISCRGSCR7" : ZM="DISCRGVAL7" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur8 remise/frais
     If   dim([M:SLX1]DISCRGCOD8) > 0
          If  [M:SLX1]DISCRGCOD8 > 1 TZONE(IZON)="DISCRGVAL8"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD8
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD8 = 1 | [M:SLX1]DISCRGCOD8 = 2
             ZT="DISCRGSCR8" : ZM="DISCRGVAL8" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur9 remise/frais
     If   dim([M:SLX1]DISCRGCOD9) > 0
          If  [M:SLX1]DISCRGCOD9 > 1 TZONE(IZON)="DISCRGVAL9"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD9
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD9 = 1 | [M:SLX1]DISCRGCOD9 = 2
             ZT="DISCRGSCR9" : ZM="DISCRGVAL9" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif
     #---- prix net
     If   [M:SLQ1]NETPRICOD = 1 TZONE(IZON)="NETPRI"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="NETPRISCR" : ZM="NETPRI" : Gosub TABLEAU_FICHE From SUBSLX
     Endif

     #---- prix revient
     If   [M:SLQ3]CPRPRICOD > 1 TZONE(IZON)="CPRPRI"
                                TMOD(IZON) =[M:SLQ3]CPRPRICOD
                                IZON+=1
     Endif
     If   [M:SLQ3]CPRPRICOD = 1 | [M:SLQ3]CPRPRICOD = 2
        ZT="CPRPRISCR" : ZM="CPRPRI" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- marge détail et totale
     If   [M:SLQ1]PFMCOD    = 1 TZONE(IZON)="PFM"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="LINPFM"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="PFMTOT"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="PFMSCR" : ZM="PFM"    : Gosub TABLEAU_FICHE From SUBSLX
        ZT="PFMSCR" : ZM="LINPFM" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- niveau de taxe
     If   [M:SLQ3]VACITMCOD > 1 TZONE(IZON)="VACITM1"
                                TMOD(IZON) =[M:SLQ3]VACITMCOD
                                IZON+=1
                                TZONE(IZON)="VACITM2"
                                TMOD(IZON) =[M:SLQ3]VACITMCOD
                                IZON+=1
                                TZONE(IZON)="VACITM3"
                                TMOD(IZON) =[M:SLQ3]VACITMCOD
                                IZON+=1
                                TZONE(IZON)="SSTCOD"            # 101380.n
                                TMOD(IZON) =[M:SLQ3]VACITMCOD   # 101380.n
                                IZON+=1                         # 101380.n
     Endif
     If   [M:SLQ3]VACITMCOD = 1 | [M:SLQ3]VACITMCOD = 2
        ZT="VACITMSCR" : ZM="VACITM1" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="VACITMSCR" : ZM="VACITM2" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="VACITMSCR" : ZM="VACITM3" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="VACITMSCR" : ZM="SSTCOD"  : Gosub TABLEAU_FICHE From SUBSLX   # 101380.n
     Endif
     #---- représentants / tx comm
     If   [M:SLQ3]REPCODD   > 1 TZONE(IZON)="REP1"
                                TMOD(IZON) =[M:SLQ3]REPCODD
                                IZON+=1
                                TZONE(IZON)="REP2"
                                TMOD(IZON) =[M:SLQ3]REPCODD
                                IZON+=1
                                TZONE(IZON)="REPRAT1"
                                TMOD(IZON) =[M:SLQ3]REPCODD
                                IZON+=1
                                TZONE(IZON)="REPRAT2"
                                TMOD(IZON) =[M:SLQ3]REPCODD
                                IZON+=1
                                TZONE(IZON)="REPCOE"
                                TMOD(IZON) =[M:SLQ3]REPCODD
                                IZON+=1
     Endif
     If   [M:SLQ3]REPCODD = 1 | [M:SLQ3]REPCODD = 2
        ZT="REPSCRD" : ZM="REP1"    : Gosub TABLEAU_FICHE From SUBSLX
        ZT="REPSCRD" : ZM="REP2"    : Gosub TABLEAU_FICHE From SUBSLX
        ZT="REPSCRD" : ZM="REPRAT1" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="REPSCRD" : ZM="REPRAT2" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="REPSCRD" : ZM="REPCOE"  : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- délai livraison
     If   [M:SLQ3]DAYLTICODD >1 TZONE(IZON)="DDAYLTI"
                                TMOD(IZON) =[M:SLQ3]DAYLTICODD
                                IZON+=1
     Endif
     If   [M:SLQ3]DAYLTICODD = 1 | [M:SLQ3]DAYLTICODD = 2
        ZT="DAYLTISCRD" : ZM="DDAYLTI" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- adresse livraison
     If   [M:SLQ3]BPAADDCODD >1 TZONE(IZON)="DBPAADD"
                                TMOD(IZON) =[M:SLQ3]BPAADDCODD
                                IZON+=1
     Endif
     If   [M:SLQ3]BPAADDCODD = 1 | [M:SLQ3]BPAADDCODD = 2
        ZT="BPAADDSCRD" : ZM="DBPAADD" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- site expédition
     If   [M:SLQ3]STOFCYCODD >1 TZONE(IZON)="DSTOFCY"
                                TMOD(IZON) =[M:SLQ3]STOFCYCODD
                                IZON+=1
     Endif
     If   [M:SLQ3]STOFCYCODD = 1 | [M:SLQ3]STOFCYCODD = 2
        ZT="STOFCYSCRD" : ZM="DSTOFCY" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- contact livraison
     If   [M:SLQ3]CNDNAMCOD > 1 TZONE(IZON)="CNDNAM"
                                TMOD(IZON) =[M:SLQ3]CNDNAMCOD
                                IZON+=1
     Endif
     If   [M:SLQ3]CNDNAMCOD = 1 | [M:SLQ3]CNDNAMCOD = 2
        ZT="CNDNAMSCR" : ZM="CNDNAM" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     # 71065 : PJT
     #---- Affaire
     If   [M:SLQ3]PJTCODD >1 TZONE(IZON)="DPJT"
                                TMOD(IZON) =[M:SLQ3]PJTCODD
                                IZON+=1
     Endif
     If   [M:SLQ3]PJTCODD = 1 | [M:SLQ3]PJTCODD = 2
        ZT="PJTSCRD" : ZM="DPJT" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     # 71065 : PJT
     If [M:DST]CCESCR>1
       For I=0 To 19
         TZONE(IZON)="CCE"+num$(I+1)
         TMOD(IZON) =9
         TINT(IZON) =num$([M:DST]CCESCR)
         IZON+=1
       Next I
     Endif

 #---- montants ligne
     If   [M:SLQ1]LINAMTCOD = 1 TZONE(IZON)="LINQUONOT"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="LINQUOATI"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="LINAMTSCR" : ZM="LINQUONOT" : Gosub TABLEAU_FICHE From SUBSLX
        ZT="LINAMTSCR" : ZM="LINQUOATI" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- type de ligne
     If   [M:SLQ1]LINTYPCOD = 1 TZONE(IZON)="LINTYP"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="LINTYPSCR" : ZM="LINTYP" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- gratuit
     If   [M:SLQ1]FOCFLGCOD = 1 TZONE(IZON)="FOCFLG"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="FOCFLGSCR" : ZM="FOCFLG" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     #---- no commande
     If   [M:SLQ1]ORDCODD   = 1 TZONE(IZON)="DSOHNUM"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="ORDSCRD": ZM="DSOHNUM" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     If   [M:SLQ1]AMTCOD    = 1 TZONE(IZON)="QUONOT"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="QUOATI"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="QUOINVNOT"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="QUOINVATI"
                                TMOD(IZON) =3
                                IZON+=1
     Endif

     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX

Endif

Local Char NBRC_MSK   (12) : NBRC_MSK=MFROM
Local Char NBRC_NBLIG (12) : NBRC_NBLIG="NBLIG"
Gosub NBR_COL_AV From SUBSLX   : If GOK<1 Return Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif
Gosub NBR_COL_AP From SUBSLX   : If GOK<1 Return Endif

#If [M:SLQ1]INVDTACOD=3
#   Gosub RESTAUR_ECRAN3 : If GOK<1 Return : Endif
#Endif
#---- suppression ou génération fenêtre AWINDOW
If ACTION="ANNULE"
  Gosub TRT_SUP_FEN From SUBSLX
Else
  Gosub TRT_GEN_FEN From SUBSLX
Endif
If GOK<1 : Return : Endif
#----
Return

########################################
Subprog AV_ENAFLG(VALEUR)
Variable Integer VALEUR
If GREP<>"C" & VALEUR=0 VALEUR=2 : Endif
End

######################################################################################
#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(4)<>2 End Endif

# Validation transactions devis depuis génération des patchs
Call GENPATCH(1,APPLI) From FUNSALTRS

End

###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

# Génération transactions vente à partir du dico des types de transaction
Call GENDOS(1,APPLI) From FUNSALTRS

End

########################################################
# Pour exécution de la copie en masse depuis le menu : #
# Utilitaires - Dictionnaire - Copie transactions      #
########################################################
$TRTCOP
Local Integer MODULE    : MODULE=5
Local Integer TYP       : TYP=1
Local Char    CODTAB(GLONTRS) : CODTAB=TABLE
#-----
Gosub OUVRE_COPTRS From SELTRS
Gosub EXEC_COPTRS  From SELTRS
Gosub FERME_COPTRS From SELTRS
Return
