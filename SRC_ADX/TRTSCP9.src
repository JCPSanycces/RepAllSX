#<AdxTL>@(#)8.0.0.0 $Revision$
################################################################################################################
# Etape 6 de la définition d'une campagne d'appels                        Module CRM           2 janvier 2001  #
################################################################################################################
# Saisie d'un script d'appel
################################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GISCPDEF
Global Integer GICANDEFI

  If clalev ([F:SCP])<=0 Local File SCRIPT [SCP] : Endif
  If clalev ([F:SCQ])<=0 Local File SCPQST [SCQ] : Endif
  If clalev ([F:SQC])<=0 Local File SCPQSTCND [SQC] : Endif
  #
  GISCPDEF = 0
  GICANDEFI = 0
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  #Bouton Confirmer
  If GISCPDEF Then
    If [M:PHO6]SCPNUM = "" Then
      ETABOU(GSPE2) = 0
    Else
      ETABOU(GSPE2) = 1
    Endif
  Else
    ETABOU(GSPE2) = 0
  Endif
  #Bouton Définir
  If GICANDEFI Then
    ETABOU(GSPE1) = 1
  Else
    ETABOU(GSPE1) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Return

##########################################################################################################
$AV_CHOIX
Return

AP_CHOIX
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:PHO6]
  Kill GISCPDEF
  Kill GICANDEFI
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return
