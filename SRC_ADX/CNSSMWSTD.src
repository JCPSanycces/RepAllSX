#<AdxTL>@(#)12.0.0.0 $Revision$ Consultation SMV
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz[M:CSMV]:Transmask [M:SMV1] To [M:CSMV] # Issue 25606[M:CSMV] = [M:SMV1]
                      [M:CSMV]FIL001 = mess(28,197,1)
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:STJ]) = 0 : Local File STOJOU     [STJ] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY]) = 0 : Local File COMPANY    [CPY] : Endif
If clalev([F:TCU]) = 0 : Local File TABCUR     [TCU] : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR     [TFO] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif

#
Local Char    WFIL1(250), WFILS(250), WFILF(250), WFILX(250), WSTR(250)
Local Integer WNOLIGN, WFSTAT, WREAD, WSKIP, WLIG, WCLA, WSEL, WPAGE
Local Decimal WACT, WSTO, WWSTO
Local Char    WSAP
Local Char    WCOL(13) : WCOL = "1111110001110"
Local Integer WBUT
Local Integer I, J
Local Integer WOK
#
Local Char    WPAR
Local Integer WLTI
#
WNOLIGN = nolign
Gosub LOAD_SCREEN
#
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SMV1]FLG = 0
[M:SMV1] = [M:CSMV]
Return
############################################################
$AP_MAGNETO
[M:SMV1]FLG = 0
Return
############################################################
$FERME
Filter [STJ]
GCONSULT = 0
If dim(WNOLIGN) > 0
  nolign = WNOLIGN
Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SMV1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SMV1] = [F:ITM]
        Endif
      Endif
    When 4 :
      If PARAM(I) <> "" & dim([M:SMV1]LOTSEL) > 0
        If PARAM(I) = mess(142,124,1)
          [M:SMV1]LOTSEL = "*"
        Else
          [M:SMV1]LOTSEL = PARAM(I)
        Endif
      Endif
    When 5 :
      [M:SMV1]STOCOUSEL = val(PARAM(I))
    When 6 :
      If PARAM(I) <> ""
        [M:SMV1]VCRTYPSEL = val(PARAM(I)) + 1
      Else
        [M:SMV1]VCRTYPSEL = 1
      Endif
    When 7 :
      [M:SMV1]VCRNUMSEL = PARAM(I)
    When 8 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I

# Détermination délai d'interrogation (défaut 30 jours)
Call PARAM([M:SMV1]FCY,"INQMVSLTI",WPAR) From ADOVAL
If val(WPAR) <> 0
  WLTI = val(WPAR)
Endif
If WLTI = 0
  WLTI = 30
Endif
#
[M:SMV1]SRTCOD = 7
If [M:SMV1]STOCOUSEL <> 0 | WFILS <> "1=1" | GCONSULT <> 0
  [M:SMV1]INQLTI    = 0
  [M:SMV1]STDFLG    = 2
  [M:SMV1]MISFLG    = 2
Else
  If clalev([M:CSMV]) <> 0 & [M:CSMV]MEMO = "STD"
    [M:SMV1] = [M:CSMV]
  Else
    [M:SMV1]INQLTI = WLTI
    [M:SMV1]STDFLG = 2
    [M:SMV1]MISFLG = 1
  Endif
Endif
Return
############################################################
$LECTURE
If [M:SMV1]ITMREF = ""
  NBLU = 0
  Return
Endif
# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
WBUT   = 0
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [STJ]
      If nolign <= MAXLIG
        Gosub LOA_LIGNE
        NBLU    = 2
        nolign += 1
        NOL    += 1
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [STJ]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
      Else
        If dim([M:SMV2]BEFSTO) > 0
          If WSEL = 0 & WBUT = 0
            If [M:SMV1]SRTCOD = 7 | [M:SMV1]SRTCOD = 10
              WSTO -= [F:STJ]QTYSTU
            Else
              WSTO += [F:STJ]QTYSTU
            Endif
          Endif
        Endif
        WLIG += 1
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Raz [M:SMV2]
    WLIG = 0
    For [STJ]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [STJ]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    -= 1
        Else
          Break
        Endif
      Else
        If dim([M:SMV2]BEFSTO) > 0
          If WSEL = 0 & WBUT = 0
            If [M:SMV1]SRTCOD = 7 | [M:SMV1]SRTCOD = 10
              WSTO -= [F:STJ]QTYSTU
            Else
              WSTO += [F:STJ]QTYSTU
            Endif
          Endif
        Endif
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [STJ]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
        Else
          Break
        Endif
      Else
        If dim([M:SMV2]BEFSTO) > 0
          If WSEL = 0 & WBUT = 0
            If [M:SMV1]SRTCOD = 7 | [M:SMV1]SRTCOD = 10
              WSTO -= [F:STJ]QTYSTU
            Else
              WSTO += [F:STJ]QTYSTU
            Endif
          Endif
        Endif
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
Return
############################################################
$TRT_FILTER
#
If [M:SMV1]FLG = 0
  [M:SMV1]FLG = 1
  Raz [M:SMV2]
  Gosub LOAD_FILTER
# Chargement stock initial
  WSTO = 0
  If WSEL = 0
    If [M:SMV1]SRTCOD = 7 | [M:SMV1]SRTCOD = 10
      Filter [STO] Where evalue(WFILX)
&                  Order By Key STO3
      For [STO]
        WSTO += [F:STO]QTYSTU
      Next
      Filter [STO]
    Else
      WSTO = 0
    Endif
  Endif
  WWSTO = WSTO

  Case [M:SMV1]SRTCOD
    When 1 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFILS) & evalue(WFILF)
&                  Order By Key STJ0
    When 3 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFILS) & evalue(WFILF)
&                  Order By ITMREF; LOT; STOFCY; IPTDAT; MVTSEQ; UPDCOD
    When 4 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFILS) & evalue(WFILF)
&                  Order By ITMREF; LOC; STOFCY; IPTDAT; MVTSEQ; UPDCOD
    When 5 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFILS) & evalue(WFILF)
&                 Order By ITMREF; STA; STOFCY; IPTDAT; MVTSEQ; UPDCOD
    When 6 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFILS) & evalue(WFILF)
&                  Order By ITMREF; PCU; PCUSTUCOE; STOFCY; IPTDAT; MVTSEQ; UPDCOD
    When 9 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFILS) & evalue(WFILF)
&                  Order By ITMREF; IPTDAT; STOFCY; MVTSEQ; UPDCOD
    When 10 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFILS) & evalue(WFILF)
&                  Order By ITMREF; CREDAT Desc; CRETIM Desc; IPTDAT Desc; MVTSEQ
    When 11 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFILS) & evalue(WFILF)
&                  Order By ITMREF; CREDAT; CRETIM; IPTDAT; MVTSEQ
    When Default :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFILS) & evalue(WFILF)
&                  Order By ITMREF; IPTDAT Desc; STOFCY; MVTSEQ; UPDCOD
  Endcase
  Raz [F:STJ]
  fstat = 0
Else
  WSTO = WWSTO
Endif
Return
############################################################
$LOAD_FILTER
# Chargement des filtres
# WSEL = 1 pour interdir le calcul des champs stock avant et stock après
If [M:SMV1]SRTCOD = 0
  [M:SMV1]SRTCOD = 7
Endif
If find([M:SMV1]SRTCOD,7,9,10,11)
  WSEL = 0
Else
  WSEL = 1
Endif
[M:SMV1]STRDAT = date$-[M:SMV1]INQLTI
# Sélection numéro article
WFIL1 = "[F:STJ]ITMREF=[M]ITMREF"
WFILX = "[F:STO]ITMREF=[M]ITMREF"
# Pas de selction date et tous mouvements si filtre chrono stock
If [M]STOCOUSEL <> 0
  WFILX += "&[F:STO]STOCOU=[M]STOCOUSEL"
Endif
# Filtre date
If [M]INQLTI <> 0
  WFIL1 += "&[F:STJ]IPTDAT>=[M:SMV1]STRDAT"
Endif
# Filtre site
If [M]FCY <> ""
  WFIL1 += "&[F:STJ]STOFCY=[M]FCY"
  WFILX += "&[F:STO]STOFCY=[M]FCY"
Endif
# Filtre lot (pat)
If dim([M]LOTSEL) > 0 & [M]LOTSEL <> ""
  WFIL1 += "&pat([F:STJ]LOT,[M]LOTSEL)"
  WFILX += "&pat([F:STO]LOT,[M]LOTSEL)"
Endif
# Autres filtres
# Filtre code mise à jour
#If [M]UPDFLG = 1
# sr 08.03 Pour avoir quelque chose par défaut (dans le cas d'un lancement par clic droit avec demande d'affichage)
If [M]UPDFLG <> 2
  WFIL1 += "&[F:STJ]UPDCOD=2"
Else
  WSEL   = 1
  WFIL1 += "&[F:STJ]UPDCOD=1"
Endif
# Filtre types de mvts
If !([M]MISFLG = 2 & [M]STDFLG = 2)
  If [M]MISFLG = 2
    WFIL1 += "&find([F:STJ]TRSTYP,7,8,9,13,21,22,23)"
  Else
    WFIL1 += "&!find([F:STJ]TRSTYP,7,8,9,13,21,22,23)"
  Endif
Endif
# Pour filtre les enregistrements bidon d'inventaire
WFIL1 += "&[F:STJ]TRSTYP<>0"
# Filtre type pièce
If [M]VCRTYPSEL > 1
  WSEL   = 1
  WFIL1 += "&[F:STJ]VCRTYP=[M]VCRTYPSEL-1"
Endif
# Filtre numéro pièce
If [M]VCRNUMSEL <> ""
  WSEL   = 1
  WFIL1 += "&[F:STJ]VCRNUM=[M]VCRNUMSEL"
Endif
# Filtre formule
WFILF = "1=1"
If [M]SELFOR <> ""
  Read [TFO]TFO0=11;[M]SELFOR
  If fstat = 0
    WSEL  = 1
    WFILF = [F:TFO]FORFOR
  Endif
Endif
Return
############################################################
############################################################
$LOA_LIGNE
[M:SMV2]               = [F:STJ]

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [F:STJ]STOFCY | [F:ITF]ITMREF <> [F:STJ]ITMREF
   Read [ITF]ITF0 = [F:STJ]ITMREF;[F:STJ]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif




If dim([M:SMV2]POT) > 0 & [F:ITF]STOMGTCOD <> 3
  [M:SMV2]POT(nolign-1) = 0
Endif
If dim([M:SMV2]ACT) > 0 & [F:ITF]STOMGTCOD <> 4
  [M:SMV2]ACT(nolign-1) = 0
Endif
If [F:STJ]VCRTYP = 0
  [M:SMV2]VCRTYPTXT(nolign-1) = ""
Else
  [M:SMV2]VCRTYPTXT(nolign-1) =  mess([F:STJ]VCRTYP,701,1)
Endif
If [F:STJ]VCRTYPORI = 0
  [M:SMV2]VCRTYPORIT(nolign-1) = ""
Else
  [M:SMV2]VCRTYPORIT(nolign-1) =  mess([F:STJ]VCRTYPORI,701,1)
Endif
If [F:FCY]FCY<>[F:STJ]STOFCY
    Read [F:FCY]FCY0=[F:STJ]STOFCY
Endif
If [F:CPY]CPY<>[F:FCY]LEGCPY
    Read [F:CPY]CPY0=[F:FCY]LEGCPY
Endif
[M:SMV2]ACCCUR(nolign-1)=[F:CPY]ACCCUR

If dim([M:SMV2]BEFSTO) > 0
  [M:SMV2]AFTSTO(nolign-1) = 0
  [M:SMV2]BEFSTO(nolign-1) = 0
  If WSEL = 0 & WBUT = 0
    If [M:SMV1]SRTCOD = 7 | [M:SMV1]SRTCOD = 10
      [M:SMV2]AFTSTO(nolign-1) = WSTO
      WSTO -= [F:STJ]QTYSTU
      [M:SMV2]BEFSTO(nolign-1) = WSTO
    Else
      [M:SMV2]BEFSTO(nolign-1) = WSTO
      WSTO += [F:STJ]QTYSTU
      [M:SMV2]AFTSTO(nolign-1) = WSTO
    Endif
  Endif
Endif
#--- calcul du no série de fin
If [M:SMV2]SERNUM(nolign-1) <> ""
   If abs([M:SMV2]QTYSTU(nolign-1)) = 1
        [M:SMV2]SERFIN(nolign-1) = [M:SMV2]SERNUM(nolign-1)
   Else Call PLUS_NB([M:SMV2]SERNUM(nolign-1),abs([M:SMV2]QTYSTU(nolign-1)),[M:SMV2]SERFIN(nolign-1),WOK) From STKLIB
   Endif
Endif
Return
############################################################
$SETBOUT
Return
############################################################
$EXEBOUT
Return
############################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Local    Char WPAR
[M:SMV1]FLG = 0
# Détermination délai d'interrogation (défaut 30 jours)
If [M:SMV1]INQLTI <>  0
  Call PARAM(VALEUR,"INQMVSLTI",WPAR) From ADOVAL
  If val(WPAR) <> 0
    [M:SMV1]INQLTI = val(WPAR)
  Endif
  If [M:SMV1]INQLTI = 0
    [M:SMV1]INQLTI = 30
  Endif
Endif
End
############################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SMV1]FLG = 0
End
############################################################
Subprog AM_INQLTI(VALEUR)
Variable Decimal VALEUR
[M:SMV1]FLG = 0
End
############################################################
Subprog C_LOTSEL(VALEUR)
Variable Char     VALEUR
VALEUR = toupper(VALEUR)
End
############################################################
Subprog AM_LOTSEL(VALEUR)
Variable Char    VALEUR()
[M:SMV1]FLG = 0
End
############################################################
Subprog AS_SRTCOD(VALEUR)
Variable Integer VALEUR
GMENLOC(2) = 1
GMENLOC(8) = 1
End
############################################################
Subprog AP_SRTCOD(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
End
#############################################################
Subprog AS_MISFLG(VALEUR)
Variable Integer VALEUR
End
#############################################################
Subprog AM_SRTCOD(VALEUR)
Variable Integer  VALEUR
[M:SMV1]FLG = 0
End
############################################################
Subprog AV_QTYPCU(VALEUR)
Variable Decimal VALEUR
If nolign > 0
  If VALEUR < 0
    pcolor = GCOUL(1)
  Else
    pcolor = GCOUL(0)
  Endif
Endif
End
############################################################
Subprog AV_QTYSTU(VALEUR)
Variable Decimal VALEUR
If nolign > 0
  If VALEUR < 0
    pcolor = GCOUL(1)
  Else
    pcolor = GCOUL(0)
  Endif
Endif
End
############################################################
Subprog AM_MISFLG(VALEUR)
Variable Integer VALEUR
End
############################################################
Subprog AM_STDFLG(VALEUR)
Variable Integer VALEUR
End

# FQ 57754 Module Stocks GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(7)<>2 End Endif

Call VALGTC(APPLI,"SMW") From SUBGTC

End

