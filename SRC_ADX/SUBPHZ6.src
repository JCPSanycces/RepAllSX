#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du masque PHZ6
##########################################################################################################
Subprog B1_NBSCP

  If [M:PHZ6]SCPFLG(nolign-1) = 2 Then
    #On désactive le script
    Call SETSCPFLG(1)
  Else
    Call SETSCPFLG(2)
  Endif
End

##########################################################################################################
Subprog IB_NBSCP

  If GFONCTION = "FUNSCP8" Then
    If [M:PHZ6]SCPFLG(nolign-1) = 2 Then
      #Désactiver le script
      GBOUT1 = mess(652,196,1)
    Else
      #Activer le script
      GBOUT1 = mess(651,196,1)
    Endif
  Else
    Raz GBOUT1
  Endif
End

##########################################################################################################
Subprog AM_SCPFLG(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    #On active
    Call SETSCPFLG(2)
  Else
    #On désactive
    Call SETSCPFLG(1)
  Endif
  [M:PHZ6]SCPFLG(nolign-1) = VALEUR
  Affzo [M:PHZ6]SCPFLG(nolign-1)
End

##########################################################################################################
Subprog SETSCPFLG(IFLG)
Value Integer IFLG

  If IFLG = 2 Then
    #On active le script
    Read [SCP]SCP0=[M:PHZ6]SCPNUMY(nolign-1)
    If !fstat Then
      Call DEBTRANS From GLOCK
      Trbegin [SCP]
      If [F:SCP]CREDAT = [00/00/00] Then
        [F:SCP]CREDAT = date$
        [F:SCP]CREUSR = GUSER
      Endif
      [F:SCP]SCPFLG = 1
      Rewrite [SCP]
      If fstat Then
        #Erreur lors de la désactivation du script.
        GMESSAGE = mess(653,196,1)
        GERR = 1
        Rollback
        End
      Else
        Commit
        [M:PHZ6]SCPFLG(nolign-1) = 2
        Affzo [M:PHZ6]SCPFLG(nolign-1)
      Endif
    Endif
  Else
    #On désactive le script
    Read [SCP]SCP0=[M:PHZ6]SCPNUMY(nolign-1)
    If !fstat Then
      Call DEBTRANS From GLOCK
      Trbegin [SCP]
      [F:SCP]SCPFLG = 2
      If [F:SCP]CREDAT = [00/00/00] Then
        [F:SCP]CREDAT = date$
        [F:SCP]CREUSR = GUSER
      Endif
      Rewrite [SCP]
      If fstat Then
        #Erreur lors de l'activation du script.
        GMESSAGE = mess(654,196,1)
        GERR = 1
        Rollback
        End
      Else
        Commit
        [M:PHZ6]SCPFLG(nolign-1) = 1
        Affzo [M:PHZ6]SCPFLG(nolign-1)
      Endif
    Endif
  Endif
End
