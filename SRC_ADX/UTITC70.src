#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTITC70   Moulinette d'initialisation des types dans ADI30   Module TC #
#                                                                        #
##########################################################################
# FGR 18/05/2015 : X3SUIVI108223
##########################################################################
Local Char DOSSIER(30)

  [L]DOSSIER = nomap
  # Issue 108760 - 2015-08-07 by MAE :
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    # Issue 108760 - 2015-08-07 by MAE :
    #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
    If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTITC70([L]DOSSIER)
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC70(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR

  Call ECR_TRACE("UTITC70: Process Start on :" - DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".ATABDIV" [ADI]
  Raz COMPTEUR
  # -----------------------------------------------------
  Trbegin [ADI]
  Filter [ADI] Where [F:ADI]NUMTAB = 30 and [F:ADI]N1 = 0
  For [ADI]
    [F:ADI]N1 = 1
    Rewrite [ADI]
    # -----------
    COMPTEUR += 1
  Next
  Filter [ADI]
  Commit
  # -----------------------------------------------------
  Close Local File [ADI]
  Call ECR_TRACE("UTITC70 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI
  #If fstat Then
  #  Raz [F:ADS]
  #Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If filinfo(filpath("FIL","ATABDIV","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"ATABDIV") : End : Endif
  Call MAJ_UTITC70(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If filinfo(filpath("FIL","ATABDIV","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"ATABDIV") : End : Endif
  Call MAJ_UTITC70(APPLI)
End

