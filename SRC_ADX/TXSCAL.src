#<AdxTL>@(#)3.0.0.0 $Revision$
############################################################################
# Traitement de calcul ou de recalcul d'un tableau
# Des parties de ce traitement sont aussi appelées depuis
# le trt TXSGRP de calcul en masse des tableaux
#
############################################################################
Raz GPILCOD, GBIDC1 : Call OBJET("TXW",GBIDC1,GBIDC2) From GOBJET : End
Local Char PARAM(30)(1..4) , VALEUR(10)
PARAM(1) = "GRP/1" : PARAM(2) = "GB103/012" : PARAM(3) = "SAC"
PARAM(1) = "" : PARAM(2) = "" : PARAM(3) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","TXSCAL","DTXSCAL",3,"") From GTRAITE : End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "AVANT_PAR"   : Gosub AVANT_PAR
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "SEL_LISTE"   : Gosub SEL_LISTE
Endcase
Return

$INIT
$INIT_DIA
Gosub OUVRE
Gosub DECLARE
Default Mask [DIA]
Raz [M]
[M]LSTGRP  = PARAM(1)
[M]TXSNAM  = PARAM(2)
[M]VERSION = PARAM(3)
If [M]TXSNAM<>""
 Gosub CHARGE_TAB
 Gosub CHARGE_VALTAB
 Gosub OPT_CALC
 [M]CALCUL = OPT_CAL
 zonsui = "[M]VERSION"
Endif
Return

$AVANT_PAR
TIT = mess(128,105,1)   : # Recalcul des cumuls ?
Return

$CONTROLE
If RECALCUL : Return : Endif
# on vérifie la présence des paramètres (société et dates) et des valeurs des variables
Gosub CTL_COL : If GERR : Return : Endif
Gosub CTL_VAR : If GERR : Return : Endif
PARAM(1) = [M:DIA]LSTGRP
PARAM(2) = [M:DIA]TXSNAM
PARAM(3) = [M:DIA]VERSION
PARAM(4) = "1"
Return

$CTL_COL
If GSERVEUR
 Read [TXS]TXS1 = [M]TXSNAM
Endif
For [TXA]TXA0 Where TXSNAM=[M]TXSNAM
 I = [F:TXA]NUMCOL-1
 If [F:TXA]COLNUM="" & ([M]STRDAT(I)=[0/0/0] | [M]ENDDAT(I)=[0/0/0] | [M]CURPRN(I)="")
  GERR=1 : GMESSAGE = mess(180,126,1)-mess(61,100,1)-num$(I+1) : Break
  # Paramètres non saisis ligne no ...
 Endif
Next I
If GERR : Return : Endif
If GUSRFCY(1)<>"\"
 For [TXP]TXP0 Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION
  COL = [F:TXP]COL
  SOC = [F:TXP]CPY
  SIT = [F:TXP]FCY
  AUTSIT(COL)=1
  Gosub AUTORIS From SUBTXW
  If AUTSIT(COL)=0
   GERR=1 : GMESSAGE = SIT-":"-mess(2,104,1) : Break
   # Vous n'avez pas les droits pour ce site
  Endif
 Next
Endif
Return

$CTL_VAR
For I=0 To [M]NBVAR-1
 If [M]VARVAL(I)=""
  GERR = 1 : GMESSAGE = mess(135,111,1)-mess(61,100,1)-num$(I+1) : Break
  # Variable non saisie ligne no ...
 Else
  Gosub TST_VAR
  If GERR : Break : Endif
 Endif
Next I
Return

$TST_VAR
ZONE = ctrans(toupper([M]VARVAL(I)),'"','')
ABR = [M]VARTYP(I)
If ABR<>"" & ZONE<>"" & !instr(1,ZONE,"*") & !instr(1,ZONE,"?") & !instr(1,ZONE,".")
 Call CONTROLE(ABR,"",ZONE,[M]VARPAR(I),mkstat) From CONTOBJ
 If mkstat
  GERR = 1 : GMESSAGE = mess(83,123,1)-":"-[M]VARNAM(I)-"("+[M]VARVAL(I)+")"   # Valeur incorrecte
 Endif
Endif
Return

$EXEC
## Calcul tableau de bord, Colonne.
Call OUVRE_BOITE(mess(139,111,1)-[F:TXS]TXSNAM,[F:TXS]NBRCOL*[F:TXS]NBLIG) From GESECRAN
Call OUVRE_TRACE(mess(139,111,1)-[F:TXS]TXSNAM) From LECFIC
NBERR = 0
# On fait 2 transactions :
# la 1ere pour sauvegarder les paramètres et les valeurs des variables,
# la seconde pour le calcul
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 # Calcul
 Call DEBTRANS From GLOCK
 Gosub TR2
Endif
Call FERME_BOITE From GESECRAN
Call FERME_TRACE From LECFIC
If NBERR
 Call LEC_TRACE From LECFIC
Endif
Return

$TR1
# (TXSGRP)
Trbegin [TXP], [TXW], [TXX]
 GOK=1
# Numéro de version
 If [M:DIA]VERSION=""
  Gosub SET_VERSION
  If GOK<0   : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
 Endif
# Sauvegarde infos version, paramètres du calcul, variables et en-tete/pied de page
 If !RECALCUL
  Gosub MAJ_VER
  If GOK<0   : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
 Endif
Commit
Return

$SET_VERSION
SITE = [M]FCY(0)
If SITE=""
 Read [FCY]FCY1(1) = [M]CPY(0)
 SITE = [F:FCY]FCY
Endif
Read [TCA]TCA0 = 2   : # Compta
If [F:TXS]AUTVER=2   : # Numérotation auto des versions
 COMPTEUR = "TBD"
 If [F:TCA]MANCOU(7)<>2   : # compteur auto
  If [F:TCA]CODNUM(7)<>""   : # 7 = Versions tableaux de bord
   COMPTEUR = [F:TCA]CODNUM(7)
  Endif
 Endif
Else
 If [F:TCA]MANCOU(7)=2   :# compteur manuel
  GOK = 0 : GMESSAGE = mess(143,111,1)   :# Version obligatoire
  GERR = 1 : Return
 Else
  If [F:TCA]CODNUM(7)<>""
   COMPTEUR = [F:TCA]CODNUM(7)
  Else
   COMPTEUR = "TBD"
  Endif
 Endif
Endif
Call NUMERO(COMPTEUR,SITE,datesyst,[M]TXSNAM,[M:DIA]VERSION,STAT) From SUBANM
If GOK<0
 Return
Elsif GOK<1 | STAT
 # Problème lors de la récupération du compteur
 Gosub MESSAGE From SUBANM
 GMESSAGE = mess(60,199,1)-"("+COMPTEUR+") : "+MESSA
 GOK = 0
Else
 PARAM(3) = [M:DIA]VERSION
Endif
Return

Subprog REMPLACE(CHAINE,COL)
Variable Char    CHAINE()
Value    Integer COL
Local Integer J , K
Local Char    PAR(80)
Repeat
 J = instr(1,CHAINE,"%")
 If J
  K = instr(J+1,CHAINE,"%")
  If K=0 : K = len(CHAINE)+1 : Endif
  PAR = toupper(seg$(CHAINE,J+1,K-1))
  If left$(PAR,2)="V_"
   Call REPLACE(PAR,PAR) From SUBTXSB
  Elsif val(PAR)>0 & val(PAR)<=9
   Case val(PAR)
    When 1  : PAR = [F:TXP]CPY
    When 2  : PAR = [F:TXP]FCY
    When 3  : PAR = format$("D:"+GFMDAT,[F:TXP]STRDAT)
    When 4  : PAR = format$("D:"+GFMDAT,[F:TXP]ENDDAT)
    When 5  : PAR = [F:TXP]CURSEL
    When 6  : PAR = [F:TXP]CURPRN
    When 7  : If [F:TXP]TYPRAT=0
               PAR = mess(1,43,1)
              Else
               PAR = mess([F:TXP]TYPRAT,202,1)
              Endif
    When 8  : PAR = mess([F:TXP]TYPMNT,2665,1)
    When 9  :
    If [F:TXA]TXSNAM<>[M]TXSNAM | [F:TXA]NUMCOL<>COL
     Read [TXA]TXA0=[M]TXSNAM;COL
    Endif
    If !fstat
     PAR = num$([F:TXA]DIVCOL)
    Endif
   Endcase
  Endif
  CHAINE = left$(CHAINE,J-1)+PAR+right$(CHAINE,K+1)
 Endif
Until J=0
End


$MAJ_VER
GCLE = [M]TXSNAM-[M]VERSION
Delete [TXP] Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION
If fstat=1
 GOK=-1 : GLOCK="$TXSP"-GCLE : Return
Endif
For I=0 To [M]NBRCOL-1
 Raz [F:TXP]
 [F:TXP]TXSNAM  = [M]TXSNAM
 [F:TXP]VERSION = [M]VERSION
 [F:TXP]COL = I+1
 [F:TXP]CPY = [M]CPY(I)
 [F:TXP]FCY = [M]FCY(I)
 [F:TXP]STRDAT = [M]STRDAT(I)
 [F:TXP]ENDDAT = [M]ENDDAT(I)
 [F:TXP]CURSEL = [M]CURSEL(I)
 [F:TXP]CURPRN = [M]CURPRN(I)
 [F:TXP]TYPRAT = [M]TYPRAT(I)
 [F:TXP]TYPMNT = [M]TYPMNT(I)
 Call LECTEXTRA([F:TXP]NAMCOL,"TXSAC","NAMCOL",[M]TXSNAM,num$(I+1)) From ATEXTRA
 Call REMPLACE([F:TXP]NAMCOL,I+1)
 Write [TXP]
 If fstat
  GOK=0 : Call FSTA("TXP") From GLOCK : Break
 Endif
Next I
If GOK<1 : Return : Endif
#
Delete [TXW] Where LSTGRP=[M]LSTGRP & TXSNAM=[M]TXSNAM & VERSION=[M]VERSION
If fstat=1
 GOK=-1 : GLOCK="$TXSW"-[M]LSTGRP-GCLE : Return
Endif
Read [TXS]TXS1 = [M]TXSNAM
Raz [F:TXW]
[F:TXW]LSTGRP  = [M]LSTGRP
[F:TXW]TXSNAM  = [M]TXSNAM
[F:TXW]VERSION = [M]VERSION
[F:TXW]VERDES  = [M]VERDES
[F:TXW]GENDAT  = datesyst
[F:TXW]GENTIM  = ctrans(time$,":","")
[F:TXW]NBVAR   = [M]NBVAR
[F:TXW]DETACC = [F:TXS]DETACC
[F:TXW]DETBPR = [F:TXS]DETBPR
[F:TXW]DETCCE = [F:TXS]DETCCE
Onerrgo ERR
For I=0 To [F:TXS]NBLIG1-1
 Call EVAL([F:TXW]TL(I),[F:TXS]TL(I),[M]VARNAM,[M]VARVAL)
 Call EVAL([F:TXW]TC(I),[F:TXS]TC(I),[M]VARNAM,[M]VARVAL)
 Call EVAL([F:TXW]TR(I),[F:TXS]TR(I),[M]VARNAM,[M]VARVAL)
Next I
For I=0 To [F:TXS]NBLIG2-1
 Call EVAL([F:TXW]FL(I),[F:TXS]FL(I),[M]VARNAM,[M]VARVAL)
 Call EVAL([F:TXW]FC(I),[F:TXS]FC(I),[M]VARNAM,[M]VARVAL)
 Call EVAL([F:TXW]FR(I),[F:TXS]FR(I),[M]VARNAM,[M]VARVAL)
Next I
Onerrgo
[F:TXW]CREUSR = GUSER
[F:TXW]CREDAT = datesyst
[F:TXW]ACS    = [F:TXS]ACS
Write [TXW]
If fstat
 GOK=0 : Call FSTA("TXW") From GLOCK : Return
Endif

Delete [TXX] Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION
If fstat=1
 GOK=-1 : GLOCK="$TXSV"-GCLE : Return
Endif
For I=0 To [M]NBVAR-1
 Raz [F:TXX]
 [F:TXX]LSTGRP  = [M]LSTGRP
 [F:TXX]TXSNAM  = [M]TXSNAM
 [F:TXX]VERSION = [M]VERSION
 [F:TXX]VARNAM  = [M]VARNAM(I)
 Call LECTEXTRA([F:TXX]VARDES,"TXSV","VARTRA",[M]TXSNAM,[M]VARNAM(I)) From ATEXTRA
 [F:TXX]VARVAL  = [M]VARVAL(I)
 [F:TXX]VARTYP  = [M]VARTYP(I)
 [F:TXX]VARPAR  = [M]VARPAR(I)
 Write [TXX]
 If fstat
  GOK=0 : Call FSTA("TXX") From GLOCK : Break
 Endif
Next I
If GOK<1 : Return : Endif
Return

Subprog EVAL(RESULT,FORMULE,VARNAM,VARVAL)
Variable Char RESULT()
Value    Char FORMULE
Variable Char VARNAM()(1..)
Variable Char VARVAL()(1..)
Local Integer I , J , K
Local Char    VARIA(10) , VALEUR(250)
If FORMULE<>""
 FORMULE = vireblc(format$("KT:250X",FORMULE),2)
 K = instr(1,FORMULE,"V_")
 While K
  J = K
  While J<=len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,J+1,1))
   J += 1
  Wend
  VARIA = seg$(FORMULE,K,J)
  Call REPLACE(VARIA,VALEUR) From SUBTXSB
  FORMULE = left$(FORMULE,K-1)+'"'+VALEUR+'"'+right$(FORMULE,J+1)
  K = instr(1,FORMULE,"V_")
 Wend
 Onerrgo ERR
 RESULT = num$(evalue(FORMULE))
 Onerrgo
Endif
End

$ERR
Resume

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return

$TR2
# (TXSGRP)
Trbegin [TXM]
 GOK=1
 Gosub CALCUL
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
Return

$CALCUL
Raz VALSAI
If [M]FLDRAZ<>2   :# Pas de raz des valeurs saisies
 For [TXM]TXM0 Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION & COL>0 & IND=0 & UPDVAL<>""
  VALSAI([F:TXM]LIG,[F:TXM]COL) = [F:TXM]UPDVAL
 Next
Endif
If !RECALCUL
 Delete [TXM] Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION
 If fstat=1
  GOK = -1 : GLOCK = "$TXSM"-GCLE : Return
 Endif
Endif
# Sauvegarde des variables
Local Integer LNGNOMVAR(MAXVAR)
Raz NBRVAR, NOMVAR, VALVAR, LNGNOMVAR
For I=0 To [M]NBVAR-1
 NOMVAR(I) = [M]VARNAM(I)
 VALVAR(I) = [M]VARVAL(I)
 TYPVAR(I) = [M]VARTYP(I)
 LNGNOMVAR(I) = len([M]VARNAM(I))
Next I
NBRVAR = [M]NBVAR
Sorta LNGNOMVAR, NOMVAR, VALVAR, TYPVAR Desc
[L]DETACC = [F:TXS]DETACC
[L]DETBPR = [F:TXS]DETBPR
[L]DETCCE = [F:TXS]DETCCE
Gosub SETLIB    : # le champ représentant l'info complémentaire est-il un menu local ?
Gosub GENER From CALTBD
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$AB_TR2
Rollback
Return

$SETLIB
TRFCY = 0
TRACC = 0
TRCCE = 0
TRBPR = 0
If [F:TXS]FCYINF<>""
 Read [ATZ]CODZONE = "FACILITY";[F:TXS]FCYINF
 If !fstat
  If left$([F:ATZ]CODTYP,2)="AX"
   TRFCY = 1
  Else
   MLFCY = [F:ATZ]NOLIB
  Endif
 Endif
Endif
If [F:TXS]ACCINF<>""
 Read [ATZ]CODZONE = "GACCOUNT";[F:TXS]ACCINF
 If !fstat
  If left$([F:ATZ]CODTYP,2)="AX"
   TRACC = 1
  Else
   MLACC = [F:ATZ]NOLIB
  Endif
 Endif
Endif
If [F:TXS]CCEINF<>""
 Read [ATZ]CODZONE = "CACCE";[F:TXS]CCEINF
 If !fstat
  If left$([F:ATZ]CODTYP,2)="AX"
   TRCCE = 1
  Else
   MLCCE = [F:ATZ]NOLIB
  Endif
 Endif
Endif
If [F:TXS]BPRINF<>""
 Read [ATZ]CODZONE = "BPARTNER";[F:TXS]BPRINF
 If !fstat
  If left$([F:ATZ]CODTYP,2)="AX"
   TRBPR = 1
  Else
   MLBPR = [F:ATZ]NOLIB
  Endif
 Endif
Endif
Return

###################################
#### Etiquettes du masque TXSCAL
###################################
Subprog C_TXSNAM(VALEUR)
Variable Char    VALEUR()
Read [TXS]TXS1 = VALEUR
If !fstat
 If ([F:TXS]NBRCOL>20 & GFLAG="LIMIT") or ([F:TXS]NBRCOL<=20 & GFLAG="NOLIMIT")
  # Accès impossible à cette fiche
  GMESSAGE = mess(8,123,1) : mkstat=2 : End
 Endif
 Call CONTEXE([F:TXS]ACS) From SUBACS
 If mkstat : End : Endif
 Call LECTEXTRA([M]TXSDES,"TXSA","TXSDES",VALEUR,"") From ATEXTRA
Else
 GMESSAGE=mess(23,100,1) : mkstat=2 : End
Endif
End

Subprog AM_TXSNAM(VALEUR)
Variable Char    VALEUR()
[M]TXSNAM = VALEUR
Effzo [M]VERSION, VERDES
Gosub CHARGE_TAB
Affzo [M]15, 20
End

$CHARGE_TAB
# (TXSGRP)
Read [TXS]TXS1 = [M]TXSNAM
If !fstat
 [M]LSTGRP = [F:TXS]LSTGRP
 #75140
 #Call LECTEXTRA([M]GRPDES,"TXSA","GRPDES",[M]TXSNAM,"") From ATEXTRA
 Call LECTEXTRA([M]GRPDES,"TXSA","GRPDES",[M]LSTGRP,"") From ATEXTRA
 Affzo [M]LSTGRP, GRPDES
 Effzo [M]15, 20
 For I=0 To [F:TXS]NBRCOL-1
  Call LECTEXTRA([M]NAMCOL(I),"TXSAC","NAMCOL",[M]TXSNAM,num$(I+1)) From ATEXTRA
 Next I
 [M]NBRCOL = [F:TXS]NBRCOL
 I=0
 For [TXX]TXX0 Where TXSNAM=[M]TXSNAM & VERSION=""
  [M]VARNAM(I) = [F:TXX]VARNAM
  Call LECTEXTRA([M]VARDES(I),"TXSV","VARTRA",[M]TXSNAM,[M]VARNAM(I)) From ATEXTRA
  [M]VARTYP(I) = [F:TXX]VARTYP
  [M]VARPAR(I) = [F:TXX]VARPAR
  [M]VARVAL(I) = toupper([F:TXX]VARDEF)
  I+=1
 Next
 [M]NBVAR = I
Endif
Return

Subprog AS_VERSION(VALEUR)
Variable Char    VALEUR()
End

Subprog C_VERSION(VALEUR)
Variable Char    VALEUR()
Local Integer I, J
If VALEUR="" & [F:TXS]AUTVER<>2   :# pas de numérotation automatique des versions
 Read [TCA]TCA0 = 2
 If [F:TCA]MANCOU(7)=2
  GMESSAGE = mess(143,111,1)   :# Compteur manuel, version obligatoire
  mkstat=2 : End
 Endif
Endif
If [M]VERSION<>VALEUR
 [M]VERSION = VALEUR
 Gosub CHARGE_VALTAB
 Affzo 15, 20
Endif
End

$CHARGE_VALTAB
Read [TXW]TXW1 = [M]TXSNAM;[M]VERSION
If !fstat
 [M]VERDES = [F:TXW]VERDES
Else
 Raz [M]VERDES
Endif
For [TXX]TXX0 Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION
 J = find([F:TXX]VARNAM,[M]VARNAM(0..[M]NBVAR-1))
 If J & [F:TXX]VARVAL<>""
  [M]VARVAL(J-1) = toupper([F:TXX]VARVAL)
 Endif
Next
Raz nolign
For [TXP]TXP0 Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION
 nolign+=1
 [M] = [F:TXP]
Next
Return

Subprog AS_NBRCOL
If nolign>[M]NBRCOL : mkstat=2 : Endif
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Gosub SAIPAR
If mkstat : VALEUR="" : End : Endif
If VALEUR="" & nolign>1 : VALEUR = [M]CPY(nolign-2) : Endif
End

$SAIPAR
If [F:TXA]TXSNAM<>[M]TXSNAM | [F:TXA]NUMCOL<>nolign
 Read [TXA]TXA0=[M]TXSNAM;nolign
 If fstat : Return : Endif
Endif
If [F:TXA]COLNUM<>""
 mkstat=2
Endif
Return

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Gosub SAIPAR
If [M]CPY(nolign-1)="" | mkstat : VALEUR="" : mkstat=2 : End : Endif
If VALEUR="" & nolign>1 : VALEUR = [M]FCY(nolign-2) : Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & GUSRFCY(1)<>"\"
 For [FCY]FCY1 Where LEGCPY=[M]CPY(nolign-1)
  If !find([F:FCY]FCY,GUSRFCY(1..GNBAUZ))
   GMESSAGE = [F:FCY]FCY-":"-mess(2,104,1) : # Vous n'avez pas les droits pour ce site
   mkstat = 2 : Break
  Endif
 Next
Endif
End

Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
Gosub SAIPAR
If mkstat : VALEUR=[0/0/0] : End : Endif
If VALEUR=[0/0/0] & nolign>1 : VALEUR = [M]STRDAT(nolign-2) : Endif
End

Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
Local Char SOC(GLONCPY), SIT(GLONFCY)
Local Date DAT
Local Decimal EXE, PER
Gosub DEFDAT
If EXE & PER
 VALEUR = [F:PER]PERSTR
Else
 GMESSAGE = mess(1,104,1)   :# Date incorrecte
 mkstat=2
Endif
End

$DEFDAT
SOC = [M]CPY(nolign-1)
SIT = [M]FCY(nolign-1)
DAT = VALEUR
If SOC=""
 SOC = GSOC(1)
Endif
Read [CPY]CPY0 = SOC
If [F:CPY]CPYLEGFLG=2 : # Juridique
 Call GETPERSOC(SOC,[F:TXS]GENLEDTYP,DAT,EXE,PER) From CPTSUB
Else
 If SIT<>""
  Call GETPER(SIT,[F:TXS]GENLEDTYP,DAT,EXE,PER) From CPTSUB
 Else
  Read [FGR]FGR0(1) = SOC
  If !fstat
   Call GETPER([F:FGR]FCY,[F:TXS]GENLEDTYP,DAT,EXE,PER) From CPTSUB
  Endif
 Endif
Endif
Return

Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
Gosub SAIPAR
If mkstat : VALEUR=[0/0/0] : End : Endif
If VALEUR=[0/0/0] & nolign>1 : VALEUR = [M]ENDDAT(nolign-2) : Endif
Gosub SAIPAR
End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
Local Char SOC(GLONCPY), SOCIETE(GLONCPY), SIT(GLONFCY)
Local Date DAT, DATDEB, DATFIN, DDEB, DFIN, TBPER(1..100)
Local Integer ER, NBPER, EDEB, EFIN, K
Local Decimal EXE, PER
Gosub DEFDAT
If EXE & PER
 VALEUR = [F:PER]PEREND
Endif
# Controles dates compatibles si société non juridique
If SIT=""
 SOCIETE = [M]CPY(nolign-1)
 If SOCIETE="" : SOCIETE=SOC : Endif
 DATDEB = [M]STRDAT(nolign-1)
 DATFIN = VALEUR
 Gosub CTLPER
Endif
End

$CTLPER
If [F:CPY]CPYLEGFLG=2 : # Juridique
 SOC = SOCIETE : Gosub DEFPER
 If mkstat : Return : Endif
Else
 DDEB = [0/0/0]
 DFIN = [0/0/0]
 ER = 0
 For [FGR]FGR0 Where CPY=SOCIETE
  Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  If DDEB=[0/0/0]
   SOC = [F:CPY]CPY : Gosub DEFPER
   If mkstat : Break : Endif
   NBPER = 0
   For [PER]PER0 Where CPY=SOC &  LEDTYP=[F:TXS]GENLEDTYP & FIYNUM>=EDEB & FIYNUM<=EFIN
    NBPER += 1
    TBPER(NBPER) = [F:PER]PERSTR
   Next
  Elsif [F:CPY]CPY<>SOC
   K = 0
   For [PER]PER0 Where CPY=[F:CPY]CPY & LEDTYP=[F:TXS]GENLEDTYP & PERSTR>=TBPER(1) & PERSTR<=TBPER(NBPER)
    K += 1
    If [F:PER]PERSTR<>TBPER(K) : ER = 1 : Break : Endif
   Next
   If K<>NBPER : ER = 1 : Break : Endif
  Endif
 Next
 If mkstat : Return : Endif
 If ER
  GMESSAGE = mess(11,101,1)-SOCIETE   :# Périodes incompatibles sur la société
  mkstat=2 : Return
 Endif
Endif
Return

$DEFPER
Call GETPERSOC(SOC,[F:TXS]GENLEDTYP,DATDEB,EXE,PER) From CPTSUB
If EXE=0 | PER=0
 GMESSAGE = mess(10,116,1)   :# Période incorrecte
 mkstat=2 : Return
Endif
DDEB = [F:PER]PERSTR
EDEB = [F:PER]FIYNUM
Call GETPERSOC(SOC,[F:TXS]GENLEDTYP,DATFIN,EXE,PER) From CPTSUB
If EXE=0 | PER=0
 GMESSAGE = mess(10,116,1)   :# Période incorrecte
 mkstat=2 : Return
Endif
DFIN = [F:PER]PEREND
EFIN = [F:PER]FIYNUM
Return

Subprog AS_CURSEL(VALEUR)
Variable Char    VALEUR()
Gosub SAIPAR
If mkstat : VALEUR="" : End : Endif
End

Subprog AS_CURPRN(VALEUR)
Variable Char    VALEUR()
Local Char SOC(GLONCPY)
Gosub SAIPAR
If mkstat : VALEUR="" : End : Endif
If VALEUR=""
 If nolign=1
  SOC = [M]CPY(nolign-1)
  If SOC="" : SOC = GSOC(1) : Endif
  Read [CPY]CPY0 = SOC
  VALEUR = [F:CPY]ACCCUR
 Else
  VALEUR = [M]CURPRN(nolign-2)
 Endif
Endif
End

Subprog AS_TYPRAT(VALEUR)
Variable Decimal VALEUR
Local Libelle ES, EP
Gosub SAIPAR
If mkstat : VALEUR=0 : End : Endif
If [M]CURSEL(nolign-1)=""
 ES = 1
Else
 Call LECTURE("TCU",[M]CURSEL(nolign-1),"") From CONTOBJ
 ES = ([F:TCU]EURFLG=2)
Endif
Call LECTURE("TCU",[M]CURPRN(nolign-1),"") From CONTOBJ
EP = ([F:TCU]EURFLG=2)
If [M]CURSEL(nolign-1)=[M]CURPRN(nolign-1) | (ES & EP)
 VALEUR=0 : mkstat=2
Endif
End

Subprog C_TYPRAT(VALEUR)
Variable Decimal VALEUR
Local Integer I, STAT
Local Decimal MTDES
Local Char DEVORG(GLONCUR)
Local Char SOC(GLONCPY)
Local Char CODLED(GLONLED)
Local Integer NUMREF

If VALEUR>len(mess(0,202,1))
 GMESSAGE = mess(154,124,1) : mkstat=2
Else
 I = nolign-1
 DEVORG = [M]CURSEL(I)
 If DEVORG=""
  SOC = [M]CPY(I)
  If SOC="" : SOC = GSOC(1) : Endif
  NUMREF = [F:TXS]GENLEDTYP
  If NUMREF<>0
   Call GET_LEDCUR(GACTX,SOC,NUMREF,CODLED,DEVORG,GMESSAGE) From FINACM_SYRA
  Else
   Read [CPY]CPY0 = SOC
   DEVORG = [F:CPY]ACCCUR
  Endif
 Endif
 Call CONVERT(DEVORG,[M]CURPRN(I),DEVORG,VALEUR,datesyst,10,MTDES,STAT) From TRTDEV
 If STAT
  # Pas de cours de devise DEVORG -> [M]CURPRN (datesyst)
  GMESSAGE = mess(16,114,1)-DEVORG-"->"-[M]CURPRN(I)-"("+format$(GFMDAT,datesyst)+")"
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_TYPMNT(VALEUR)
Variable Integer VALEUR
Gosub SAIPAR
If mkstat : VALEUR=0 : End : Endif
If !VALEUR
 VALEUR = 2
Endif
End

Subprog AS_NBVAR
If nolign>[M]NBVAR : mkstat=2 : Endif
End

Subprog C_NBRCOL
If clalev([F:TXA])=0  : Local File TXSAC      [TXA]  : Endif
Local Integer I
For [TXA] Where TXSNAM=[M]TXSNAM
 If [F:TXA]COLNUM<>""
  I = [F:TXA]NUMCOL-1
  Raz [M]CPY(I), FCY(I), STRDAT(I), ENDDAT(I), CURSEL(I), CURPRN(I)
 Endif
Next
Affzo [M]15
End

Subprog C_VARVAL(VALEUR)
Variable Char    VALEUR()
Local Char ZONE(20), ABR(5)
Local Integer K
VALEUR = toupper(VALEUR)
ZONE   = ctrans(VALEUR,'"','')
ABR    = [M]VARTYP(nolign-1)
If ABR<>"" & ZONE<>"" & !instr(1,ZONE,"*") & !instr(1,ZONE,".") & !instr(1,ZONE,"?")
 Call CONTROLE(ABR,"",VALEUR,[M]VARPAR(nolign-1),mkstat) From CONTOBJ
Endif
End

$SEL_TABLE
OBJET = [M]VARTYP(nolign-1)
SUPP  = [M]VARPAR(nolign-1)
Return

$OPT_CALC   :# étiquette utilisée aussi dans $INIT_DIA
OPT_CAL=1
For I=0 To [M:TXM1]NBLIG-1
 If instr(1,[M:TXM1]UPDCOL(I),"1")
  OPT_CAL=2 : Break   :# il y a une zone modifiée (au moins)
 Endif
Next I
Return

Subprog AS_FLDRAZ(VALEUR)
Variable Integer VALEUR
Look [TXW]TXW1 = [M]TXSNAM;[M]VERSION
If !fstat
 Filter [TXM] Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION & UPDVAL<>""
 Look [TXM]TXM0 First
 Filter [TXM]
Endif
If [M]VERSION="" | fstat
 VALEUR=1 : mkstat=2
Endif
End

Subprog AS_CALCUL(VALEUR)
Variable Integer VALEUR
#Look [TXW]TXW1 = [M]TXSNAM;[M]VERSION
#If !fstat
# Filter [TXM] Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION & UPDVAL<>""
# Look [TXM]TXM0 First
# Filter [TXM]
#Endif
#If [M]VERSION="" | fstat | [M]FLDRAZ=2
If [M]VERSION="" | [M]FLDRAZ=2
 VALEUR=1 : mkstat=2
Endif
End

$SEL_LISTE
Case GACTION
 When "SELTYPRAT"  : Gosub SEL_TYPRAT
 When "SELVERSION" : Gosub SEL_VERSION
 When "SELFGR"     : Gosub SEL_FGR
Endcase
Return

$SEL_TYPRAT
# Boite liste contenant le menu local 202 Type de cours0
TIT = mess(12,123,1)-mess(21,105,1)  :# Choix type de cours
NBTEX = 1 : TEX(NBTEX) = "0" : TEXTE(NBTEX) = mess(1,43,1)   :# Aucun
For I=1 To len(mess(0,202,1))
 NBTEX += 1
 TEX(NBTEX)=num$(I)
 TEXTE(NBTEX)=mess(I,202,1)
Next I
Return

$SEL_VERSION
# Boite liste contenant les versions d'un tableau
If clalev([F:TXW])=0 : Local File TXSW [TXW] : Endif
Local Char TABLEAU(GLONTXS), VERSION(15)
TIT = mess(12,123,1)-mess(126,105,1)   :# Choix version
NBTEX = 0
If find(zoncou,"VALEUR1","VALEUR2") : # On est en impression
 TABLEAU = [M]VALEUR1(nolign-2)
 VERSION = VALEUR
Else
 TABLEAU = [M]TXSNAM
 VERSION = VALEUR
Endif
For [TXW]TXW1 Where TXSNAM=TABLEAU & VERSION>=[L]VERSION
 If NBTEX+1>=dim(TEX) | NBTEX+1>=dim(TEXTE)
  Break
 Endif
 Call CONTEXE([F:TXW]ACS) From SUBACS
 If !mkstat
  NBTEX += 1
  TEX(NBTEX)=[F:TXW]VERSION
  TEXTE(NBTEX)=[F:TXW]VERSION-":"-[F:TXW]VERDES
 Endif
Next
Raz mkstat, GMESSAGE
Return

$SEL_FGR
# Boite liste contenant les sites d'un regroupement
Local Char SOC(GLONCPY)
Local Integer MAXSIT
MAXSIT = 0
TIT = mess(12,123,1)-mess(12,105,1)   :# Choix site
NBTEX = 0
SOC = PARAM(1)
Read [CPY]CPY0 = SOC
If [F:CPY]CPYLEGFLG=2   :# Juridique
 For [FCY]FCY1 Where LEGCPY=SOC & FINFLG=2
  MAXSIT +=1
 Next
 Local Char TEX(50) (0..max(200,MAXSIT)), TEXTE(80) (0..max(200,MAXSIT))
 For [FCY]FCY1 Where LEGCPY=SOC & FINFLG=2
  NBTEX += 1
  TEX(NBTEX)=[F:FCY]FCY
  TEXTE(NBTEX)=[F:FCY]LEGCPY-":"-[F:FCY]FCY-":"-[F:FCY]FCYNAM
 Next
Else
 Link [FGR] With [FCY]FCY0=[F:FGR]FCY
& As [LNK]
& Where [FGR]CPY=SOC & [FCY]FINFLG=2
 For [LNK]FGR0
  MAXSIT +=1
 Next
 Local Char TEX(50) (0..max(200,MAXSIT)), TEXTE(80) (0..max(200,MAXSIT))
 For [LNK]FGR0
  NBTEX += 1
  TEX(NBTEX)=[F:FGR]FCY
  Read [FCY]FCY0 = [F:FGR]FCY
  TEXTE(NBTEX)=[F:FGR]CPY-":"-[F:FGR]FCY-":"-[F:FCY]FCYNAM
 Next
Endif
Return

$OUVRE
# (TXSGRP)
If clalev([F:TXS])=0  : Local File TXSA       [TXS]  : Endif
If clalev([F:TXS2])=0 : Local File TXSA       [TXS2] : Endif
If clalev([F:TXA])=0  : Local File TXSAC      [TXA]  : Endif
If clalev([F:TXA2])=0 : Local File TXSAC      [TXA2] : Endif
If clalev([F:TXD])=0  : Local File TXSD       [TXD]  : Endif
If clalev([F:TXM])=0  : Local File TXSM       [TXM]  : Endif
If clalev([F:TXM2])=0 : Local File TXSM       [TXM2] : Endif
If clalev([F:TXP])=0  : Local File TXSP       [TXP]  : Endif
If clalev([F:TXX])=0  : Local File TXSV       [TXX]  : Endif
If clalev([F:TXW])=0  : Local File TXSW       [TXW]  : Endif
If clalev([F:TXW2])=0 : Local File TXSW       [TXW2] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:FGR])=0  : Local File FACGROUP   [FGR]  : Endif
