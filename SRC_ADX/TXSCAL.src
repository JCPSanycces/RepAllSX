# Masks with more than 20 columns are opened
If GFONCTION="TXSGRP" | (GFONCTION="GESTXW" & GFLAG="NOLIMIT")
 If clalev([M:DIA])=0  : Local Mask TXSCALA   [DIA]  : Endif
 If clalev([M:TXA1])=0 : Local Mask TXSAA     [TXA1] : Endif
Else
 If clalev([M:TXA1])=0 : Local Mask TXSA1     [TXA1] : Endif
 If clalev([M:DIA])=0  : Local Mask TXSCAL    [DIA]  : Endif
Endif

If clalev([M:TXM1])=0 : Local Mask TXSM1      [TXM1] : Endif
