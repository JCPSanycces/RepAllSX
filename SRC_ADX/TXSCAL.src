Return

$DECLARE
# (TXSGRP)
Local Integer I, J, K, S
Local Integer IC, IL, COL, LIG, ISITE, NBSOC, NBSITE, INDTXM, NOCOL, NBRVAR, NUM
Local Integer PO, PF, BI, BS, OPT_CAL, MTTMOD, NBPER, EXPL
Local Integer DETACC, DETBPR, DETCCE, DETAIL, DETDEL, DETTRS, CPT, REFC, MAXLIG, MAXCOL, MAXVAR
Local Integer STAT, TYPCOURS, I_M, STOMAX, C_CAT, ER
Local Integer IMMNUM, OLDIE, L_MONT, NBARG, NBNAT, NBS1, NBS2, NBS3, OK, OKCCE
Local Integer NOLIB, MLFCY, MLACC, MLBPR, MLCCE, MLFAS, TYPCUMUL
Local Integer TRFCY , TRACC , TRCCE , TRBPR
If dim(RECALCUL)<0
 Local Integer RECALCUL   :# recalcul des cumuls uniquement
 If GACTION="TXSRCAL"
  RECALCUL = 1
 Else
  RECALCUL = 0
 Endif
Endif
STOMAX = dim([M:CNS]FRM0)      : # (500) stockage en table pour test du solde (formules I, H)
MAXLIG = dim([M:TXM1]AMTVAL1)
MAXCOL = dim([M:TXA1]NAMCOL)
MAXVAR = dim([M:TXA3]VARNAM)
Local Char    NOMVAR(10)(MAXVAR), TYPVAR(3)(MAXVAR), VALVAR(30)(MAXVAR), VARTMP(30)(MAXVAR)
Local Char    TSOC(GLONCPY)(1..GNBSOC) , TSITE(GLONFCY)(1..GNBSITE) , TSOCSIT(GLONCPY)(1..GNBSITE)
Local Integer ISITE , ISOC , NNSITE , INAT , ISEC , KSEC
Local Char    TTSITE(GLONFCY)(1..GNBSITE)
Local Char    SOC(GLONCPY), SIT(GLONFCY), DEVSOC(GLONCUR), DEVSEL(GLONCUR)
Local Integer TEDEB(1..max(GNBSOC, GNBSITE)) , TEFIN(1..max(GNBSOC, GNBSITE)) , TPDEB(1..max(GNBSOC, GNBSITE)) , TPFIN(1..max(GNBSOC, GNBSITE)) , GROUPE
Local Char    DEVPRN(GLONCUR), DEVCOL(GLONCUR), DEVLEC(GLONCUR), SOC1(GLONCPY) , SOCJUR(GLONCPY)
Local Char    FORMULE(250), SAVFORMULE(250), EXPR(250), CAR(1), CAR1(1), CARS(1), CRITERE(250)(1..5)
Local Integer ICRIT , NBERR, AUTSIT(1..MAXCOL)
Local Char    ABR(5), Z2(250)
Local Char    SITE(GLONFCY), COMPTE(GLONGAC), TIERS(GLONBPR), PLAN(GLONCOA)
Local Char    CPTE(GLONGAC)
Local Char    COLL(5), COD_BIL(10), M_FCY(GLONFCY)(STOMAX), CMD(250), ARG(250), ZONE(250)
Local Char    M_ACC(GLONGAC)(STOMAX), M_BPR(GLONBPR)(STOMAX), C_VAR(20), C_TYP(1), ZT(100)
Local Char    VALSAI(30)(1..MAXLIG,1..MAXCOL), COMPTEUR(GLONANM), TABLEAU(GLONTXS), VRSN(15)
Local Char    SITINF(GLONDES), CPTINF(GLONDES), TRSINF(GLONDES), CCEINF(GLONDES)
#
Local Date    DAT_DEBEX, DAT_FINEX
Local Decimal EDEB, EFIN, PDEB, PFIN, PMAX, EXE, PERDEB, PERFIN, AROPRN, MT_TMP
Local Decimal SIT_DEB(1..GNBSITE), SIT_CDT(1..GNBSITE), SAI_DEB, MTDEB, MTCDT, CPTDEB, CPTCDT
Local Decimal SIT_CPTDEB(1..GNBSITE) , SIT_CPTCDT(1..GNBSITE)
Local Decimal BPRDEB, BPRCDT, L(1..MAXLIG,1..MAXCOL), LC(1..MAXLIG,1..MAXCOL)
Local Decimal L2(1..MAXLIG,1..MAXCOL), M_DBT(STOMAX), M_CDT(STOMAX), MTDES
Local Integer BALANA : BALANA = 1
Local Integer BALGEN : BALGEN = 1
Local Integer NBGRPNAT , NBGRPSEC(1..3)
Local Char    TBGRPNAT(GLONGAC)(1..300) , TBGRPSEC(GLONCCE)(1..3,1..300)
Local Integer TBNIVNAT(1..300) , TBNIVSEC(1..3,1..300)
Local Integer OKGRP
Local Integer TYPNAT
Local Integer INDDIE
Local Char CODLED(GLONLED), DEVLED(GLONCUR)
Return

