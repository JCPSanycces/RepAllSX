#<AdxTL>@(#)3.0.0.0 $Revision$
$ACTION
Case ACTION
  When "INIT"      : Gosub INIT
  When "AVANT_PAR" : Gosub AVANT_PAR
  When "INIT_DIA"  : Gosub INIT_DIA
  When "CONTROLE"  : Gosub CONTROLE
  When "EXEC"      : Gosub EXEC
Endcase

############################################################################################
## BOM codes for BOM versioning in development/available to use
## GH 03/2015
############################################################################################

$INIT
If !clalev([F:EVL])  : Local File ECCVAL    [EVL]  : Endif
If !clalev([F:ITM])  : Local File ITMMASTER [ITM]  : Endif
If !clalev([F:TBO])  : Local File TABBOMALT [TBO]  : Endif

Local Integer NIV
Read [ITM]ITM0 = [L]PARAM(1)
If !fstat
   NIV = func ECCLIB.NBRCPN([L]PARAM(1))
Endif
If NIV<1
   GERR=1 : GMESSAGE = mess(153,187,1)-[L]PARAM(1) : # Versions not managed on this product
   FIN=1 : Return
Endif
Return

#############################################################

$AVANT_PAR
If SAI : Raz [M:EVLA]INV : Endif : # to redo diszo instructions
Return

#############################################################

$INIT_DIA
Raz [M:EVLA]
[M:EVLA]ITMREF    = [L]PARAM(1)
[M:EVLA]BOMALTTYP = val([L]PARAM(2))

# BOM code for BOMs in development
Filter [EVL] Where ITMREF=[M:EVLA]ITMREF & ECCTYP=[M:EVLA]BOMALTTYP & USESTA=1
Read [EVL]EVL0 Last
Filter [EVL]
If !fstat : [M:EVLA]BOMALT1 = [F:EVL]BOMALT                                : [M:EVLA]EVL1=2
Else      : [M:EVLA]BOMALT1 = evalue("[F:ITM]ECCBOMALT"+[L]PARAM(2)+"(0)") : [M:EVLA]EVL1=1
Endif
Read [TBO]TBO0 = [M:EVLA]BOMALTTYP;[M:EVLA]BOMALT1
If !fstat : [M:EVLA]FCY1 = [F:TBO]FCY : Endif

# BOM code for BOMs available to use
Filter [EVL] Where ITMREF=[M:EVLA]ITMREF & ECCTYP=[M:EVLA]BOMALTTYP & USESTA=2
Read [EVL]EVL0 Last
Filter [EVL]
If !fstat : [M:EVLA]BOMALT2 = [F:EVL]BOMALT                                : [M:EVLA]EVL2=2
Else      : [M:EVLA]BOMALT2 = evalue("[F:ITM]ECCBOMALT"+[L]PARAM(2)+"(1)") : [M:EVLA]EVL2=1
Endif
Read [TBO]TBO0 = [M:EVLA]BOMALTTYP;[M:EVLA]BOMALT2
If !fstat : [M:EVLA]FCY2 = [F:TBO]FCY : Endif
Return

#############################################################

$CONTROLE
If [M:EVLA]BOMALT1<>0 & [M:EVLA]BOMALT1=[M:EVLA]BOMALT2
   GERR=1 : GMESSAGE = mess(314,193,1) : # Same BOM codes
   SAI=1
Elsif [M:EVLA]BOMALT1<>0 & [M:EVLA]BOMALT2<>0 & [M:EVLA]FCY1<>[M:EVLA]FCY2
   GERR=1 : GMESSAGE = mess(310,193,1) : # Incompatible sites between BOM codes for versioning
   SAI=1
Endif
Return

#############################################################

$EXEC
GOK=1
Trbegin [ITM]
  Readlock [ITM]ITM0 = [M:EVLA]ITMREF
  If fstat
     GOK=0 : Call RSTA("ITM",[M:EVLA]ITMREF) From GLOCK
  Else
    Assign "[F:ITM]ECCBOMALT"+[L]PARAM(2)+"(0)" With [M:EVLA]BOMALT1
    Assign "[F:ITM]ECCBOMALT"+[L]PARAM(2)+"(1)" With [M:EVLA]BOMALT2
    Rewrite [ITM]
    If fstat
       GOK=0 : Call FSTA("ITM") From GLOCK
    Endif
  Endif
If GOK=1 : Commit
Else     : Rollback : SAI=1
Endif
Return

######################################################################################
## Labels for screen TBOEVL  16/02/2015 16:44:35 (GH)
######################################################################################

Subprog D_INV(VALEUR)
Variable Char    VALEUR()
If [M:EVLA]EVL1=2 : Diszo [EVLA]BOMALT1 : Endif
If [M:EVLA]EVL2=2 : Diszo [EVLA]BOMALT2 : Endif
End

Subprog AM_BOMALT1(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 : Raz [F:TBO] : Endif
[M:EVLA]FCY1=[F:TBO]FCY : Affzo [EVLA]FCY1
End

Subprog AM_BOMALT2(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 : Raz [F:TBO] : Endif
[M:EVLA]FCY2=[F:TBO]FCY : Affzo [EVLA]FCY2
End
