#<AdxTL>@(#)11.0.0.0 $Revision$
########################################################################
#              Gestion Des DEMANDES D'ACHAT  (suite du SUBPSH)         #
# ---------------------------------------------------------------------#
# gcur    contient la devise societe                                   #
# gsyscur contient la devise dossier                                   #
# gfinrsp contient le site financier ou responsable financier          #
#                                                     cg decembre 1997 #
########################################################################

#######################################################################
#############  ACTIONS STANDARDS    ###################################
#######################################################################
$DEFTRANS
#--------------------------------------------------------#
# Avant lecture des transactions de saisie disponibles : #
# Si GFLAG est renseigné la transaction est déja choisie #
# par le menu. Vérifier si elle est valide               #
#--------------------------------------------------------#
Local Shortint OUVFICFLG
If !clalev([F:PTR])  Local File PURTRS [PTR] : Endif
If GFLAG<>""
  Read [PTR] PTR0=2;GFLAG
  If fstat | [F:PTR]ENAFLG=1 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  If [F:PTR]ACSCOD<>"" & GPROFIL<>GSUPER
    If !clalev([F:ACC])  Local File ACCES  [ACC] : OUVFICFLG=1 : Endif
    Read [ACC] CODACC=GUSER;[F:PTR]ACSCOD
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG=1  Close Local File [ACC] : Raz OUVFICFLG : Endif
Return

#######################################################################
$VARIANTE
#---------------------------------------#
# Après lecture de chaque transaction : #
# La transaction est-elle valide ?      #
# VARCOD contient le code transaction.  #
# Mettre OK à zéro si non valide.       #
#---------------------------------------#
Read [PTR] PTR0=2;VARCOD
If fstat | [F:PTR]ENAFLG=1 OK=0 : Endif
Return

#######################################################################
$SETTRANS
#-------------------------------------#
# Après sélection de la transaction : #
# GFLAG = code transaction choisie    #
#-------------------------------------#
If clalev ([F:PTR])=0 Local File PURTRS [PTR] : Endif
Read [PTR] PTR0=2;GFLAG : If fstat Raz [F:PTR] : Endif

#MAE, le 30/01/08, GRP_SITE
GGRPFCY = [F:PTR]GFY
Return


#######################################################################
$OUVRE
Raz GSOC_ACTIVE
#---------------------------------------------------------------------#
# Dans EXEFNC si pas de site par défaut pour le module concerné       #
# GFCYDEF(0) = premier site de la table sites (modif Beinat 15/12/99) #
# FAUX, il faut toujours avoir GFCYDEF(0) = site par défaut du module #
# même si ce site par défaut est vide !                               #
#---------------------------------------------------------------------#
GFCYDEF(0)=GFCYDEF(6)
GFCY = GFCYDEF(6)
Call GETFCYDEF(GFCY,"[F:FCY]PURFLG=2") From TRTX3
If !clalev([F:GCM])  Local File GACM       [GCM] : Endif
#---------------------------------------------------------------#
# Ouverture fichiers BALANA, BUD, BUDPAR si module Compta à Oui #
#---------------------------------------------------------------#
If GMODU(2)=2  : # Compta
  If !clalev([F:BLA])  Local File BALANA     [BLA] : Endif
  If !clalev([F:BUD])  Local File BUD        [BUD] : Endif
  If !clalev([F:BUP])  Local File BUDPAR     [BUP] : Endif
Endif
#----- Ouverture fichiers pour inter-sites / inter-sociétés -----#
If GMODU(5)=2 : # Si module Ventes présent
  If !clalev([F:BPC])  Local File BPCUSTOMER [BPC] : Endif
Endif
#-----régime de taxe--------#
If !clalev([F:TVB])  Local File TABVACBPR     [TVB] : Endif
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
GCONSDIA=0 : # Rend saisissable les écrans avec abréviation [DIA]
GPTRNUM=[F:PTR]PTRNUM
#----------------------------------------------------------#
# Il faut choisir une transaction DA                       #
# et ouvrir les masques correspondants                     #
# Utilisation de GFLAG pour passer le choix de transaction #
# en parametre lors de l'appel de la fonction              #
# GWAPPLIN : Nbre de ligne avec pas de gestion signature   #
#----------------------------------------------------------#
Raz GRCPFCY, GPLISTC, GWAPPLIN
#----- Variable locales et globale -----#
Local  Char     WCODE(3), PARAMA(10), SYMBOL2(30)
Local  Integer  I, WRETOUR, WCOD
Local  Shortint WFBUNBR
Local  Libelle  WLINCLEFLG
Global Integer  GPSH_VERROU
#---------------------------------------------------------#
# déclaration des variables pour gestion entete et detail #
#---------------------------------------------------------#
Gosub DECLARE From TABLEAUX
Local Mask ORDK     [ORDK]
If GFONC1="GESPSH"
  Gosub EFFAC_PWRKORDERS From SUBPSH  : # Effacement fichier travail sauf si tunnel
Endif
#--------------------------------------#
# on charge la structure par défaut "" #
# obligation pour fenetre remise-frais #
#--------------------------------------#
Call COLREM ("C",2,"") From TRTPRICE
GPLISTC="" : Call TARIFCHGT (6) From TRTPRICE
#------------------------#
# ouverture de la trace  #
#------------------------#
If !GIMPORT Call OUVRE_TRACE(mess(173,197,1)) From LECFIC : Endif
GPURTRACE =0
GORITITCOL=1
Return


###################################################################################
$SETBOUT
#---------------------------------------------------------------------------------#
# A  : Menu texte                                       Action                    #
#      AF : Texte entête               ETAMEN(1)         ACLOB                    #
#      AG : Texte pied                 ETAMEN(2)         ACLOB                    #
# B  : Menu Option                                                                #
#      BH : Visu commandes de la DA    ETAMEN(3)         VISUPOHPSH               #
#      BI : Transaction (visu)         ETAMEN(4)         VISUPTD                  #
#      BN : Traçabilité pièces                           CONSPIA SYMEU 09/12/2008 #
#                                                                                 #
# Bouton de bas d'écran                                                           #
#      1  : Signataires (visu)                           VISUPAD                  #
#      2  : Commande (transfo DA en cde)                 TRTPSHGEN                #
#      3  : Solde                                        TRTCLEPSH                #
#---------------------------------------------------------------------------------#
GPSH_VERROU=VERROU
#---------------------------------------------------------------------------------#
# Activation / Désactivation menus "Texte entête" et "Texte pied" dans la ToolBar #
#---------------------------------------------------------------------------------#
If GREP="C" | GREP="D" | [M:PSH0]PSHNUM<>""
  CHMEN+="FG"
Endif
#------------------------------------------------------------#
# Activation menu "Visu commandes de la DA" et "Transaction" #
#------------------------------------------------------------#
If CLECUR  CHMEN+="H" : Endif
CHMEN+="I"

If !find(GREP,"C","D") and !find("CONSPIA",GNAVIG(1..GPILNAV)) Then CHMEN += "N" Endif # SYMEU 09/12/2008 : branchement traçabilité pièces

#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
Gosub SET_BOUT_SPE From GSAISIE
#----------------------------------------#
# suppression du bouton #code            #
# on ne doit pas pouvoir modifier la clé #
#----------------------------------------#
Call VIREBOUT (CHAINE,"H") From GOBJET
#--------------------------#
# On désactive les boutons #
#--------------------------#
If CLECUR
  If [M:PSH1]XAPPFLG=4
    Call VIREBOUT(CHAINE,"1") From GOBJET
  Endif
  If [F:PTR]GENBUT=1 | [M:PSH1]XCLEFLG=2 | (GPSHPRTORD<>2 & [M:PSH1]XAPPFLG<3)
    Call VIREBOUT(CHAINE,"2") From GOBJET
  Else
    #----- L'utilisateur a-t-il droit à la transfo DA en commande ? -----#
    GBIDC2="G": GFCY=[M:PSH0]PSHFCY : Gosub AUTORIS_OPT From CONTX3
    If !GBIDI2  Call VIREBOUT(CHAINE,"2") From GOBJET : Endif
  Endif
  If [F:PTR]CLEBUT<>2 | [M:PSH1]XCLEFLG=2
    Call VIREBOUT(CHAINE,"3") From GOBJET
  Else
    #----- L'utilisateur a-t-il droit au solde ? -----#
    GBIDC2="T": GFCY=[M:PSH0]PSHFCY : Gosub AUTORIS_OPT From CONTX3
    If !GBIDI2  Call VIREBOUT(CHAINE,"3") From GOBJET : Endif
  Endif
  If [M:PSH1]XAPPFLG=3 | [M:PSH1]XCLEFLG=2
    Call VIREBOUT(CHAINE,"A")  From GOBJET
  Endif
  #----- Si en cours de modif on enlève boutons "Commande" et "Solde" -----#
  If GREP="M"
    Call VIREBOUT(CHAINE,"23") From GOBJET
  Endif
Else
  Call VIREBOUT(CHAINE,"123") From GOBJET
Endif
Return

##############################################################################
$AVANTBOUT
GPSH_VERROU=VERROU : Raz SYMBOL2
If [M:PSH0]PSHNUM<>"" & GPSH_VERROU=0 & find(BOUT,"2","3")
  SYMBOL2="PSH"+[M:PSH0]PSHNUM : Lock =SYMBOL2
  If !fstat  GPSH_VERROU=1  Else  Raz SYMBOL2 : Endif
Endif
#-----
Case BOUT
  When "2" : Gosub AVTBOUT_GENERE : # Génération de commande
  When "3" : Gosub AVTBOUT_SOLDE  : # Solde de la DA
  When "F","G" : If GREP="" & dim(ACTMOD)>0 & !ACTMOD  GCONSDIA=2 : Endif
Endcase
#-----
If !OK & SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Return


##############################################################################
$AVTBOUT_GENERE
#-------------------------------------#
# Transformation de la DA en commande #
#-------------------------------------#
If !GPSH_VERROU  GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return : Endif
#----------------------------#
# Génération des commandes ? #
#----------------------------#
OK=2 : Call AVERTIR(mess(86,194,1),OK) From GESECRAN
If OK=1
  OK=0
Else
  OK=1
  If GTRACE<>""  GPURTRACE=1 : Endif
Endif
Return


##############################################################################
$AVTBOUT_SOLDE
#----------------#
# Solde de la DA #
#----------------#
If !GPSH_VERROU  GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return : Endif
#------------------------------------------------------#
# DA va etre entierement soldée voulez vous continuer  #
#------------------------------------------------------#
OK=2 : Call AVERTIR(mess(158,194,1),OK) From GESECRAN
If OK=1  OK=0 : Return Else OK=1 : Endif
Return


$EXEBOUT
#------------------------------------#
# Après exécution des boutons du bas #
# 2 = Commande (Transfo DA en cde)   #
# 3 = Solde                          #
#------------------------------------#
If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Case BOUT
  When "2" : Gosub RELIT    From GOBJSUB : # Commande
  When "3" : Gosub RELIT    From GOBJSUB : # Solde
Endcase
Return


$STATUT
#-------------------------------------------#
# Après exécution des boutons de la ToolBar #
#-------------------------------------------#
If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Case BOUT
  When "F" : If mkstat=4 & GREP=""       : # Texte entête modifié
               Gosub ENTRE_MODIF From GOBJSUB
             Endif
             If !GIMPORT
               If [M:PSH1]TEX1<>""
                 Call SET_IMAGE (4)   From GESECRAN
               Else
                 Call RESET_IMAGE (4) From GESECRAN
               Endif
             Endif
  When "G" : If mkstat=4 & GREP=""       : # Texte pied modifié
               Gosub ENTRE_MODIF From GOBJSUB
             Endif
             If !GIMPORT
               If [M:PSH1]TEX2<>""
                 Call SET_IMAGE (4)   From GESECRAN
               Else
                 Call RESET_IMAGE (4) From GESECRAN
               Endif
             Endif
  When "H" : Gosub RELIT    From GOBJSUB : # Visu commandes de la DA
Endcase
Return


##############################################################################
$FILTRE
#---- besoin pour activer les habilitations sur operateurs
#---- sinon le filtre ne fonctionne pas
Default File [PSH]
Return

##############################################################################
$LIENS
GFCY=[M:PSH0]PSHFCY
# Issue 93463 - 2014-01-27 by SR
[M:PSH0]WMODIF=1
# Issue 113581 - 2016-02-15 by SR
[M:PSH0]ANCLINNBR = [F:PSH]LINNBR
#-----
Gosub CHARG_PARAM From SUBPSH1
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL  From SUBPSH1
#-----
[M:PSH1]XAPPFLG = [F:PSH]APPFLG
[M:PSH1]XCLEFLG = [F:PSH]CLEFLG
[M:PSH1]XPRNFLG = [F:PSH]PRNFLG
[M:PSH1]XORDFLG = [F:PSH]ORDFLG
Gosub LIENS From TABLEAUX
#-----
If GFONC1="GESPSH"  Call RAZ_CLOB From ACLOB   : Endif
If [F:PSH]CLEFLG=2  GCONSDIA=2 Else GCONSDIA=0 : Endif
# Issue 71069 - 2013-08-13 by SR : PJT
# A faire avant tout le reste
If GPJTSNGDOC = G_NON Then
 Call PJT_MODFCY([M:PSH0]PSHFCY,"[M:PSH1]PJT") From TRTPJT
Endif
 #----- Affichage icone texte -----#
If [M:PSH1]TEX1<>"" | [M:PSH1]TEX2<>""
  Call SET_IMAGE (4) From GESECRAN
Else
  Call RESET_IMAGE (4) From GESECRAN
Endif
#----- Ouverture de la trace -----#
If GTRACE = ""
  Call OUVRE_TRACE(mess(173,197,1)) From LECFIC
  GPURTRACE = 0
Endif

#VPO 04/01/10 gestion bouton pour URL MMS
Gosub GRIZEBUTMMS

If !GIMPORT
  If [M:PSH1]XCLEFLG=2
    Diszo [PSH0]REQUSR,PSHFCY,PRQDAT : Diszo [PSH1]5
  Else
    If GPLNFLT>1 Diszo [PSH0]REQUSR Else Actzo [PSH0]REQUSR : Endif
    Diszo [PSH0]PSHFCY
    Actzo [PSH0]PRQDAT : Actzo [PSH1]5
  Endif
Endif
# Issue 71069 - 2013-08-13 by SR : PJT
# A faire après tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY([M:PSH0]PSHFCY,"[M:PSH1]PJT") From TRTPJT
Endif

Return

########################################################################
$AV_IMPRIME
#-----------------------------------------------#
# Avant impression : Chargement nom du document #
#-----------------------------------------------#
#----- Relecture transaction de saisie si nécessaire -----#
If [F:PTR]PTRTYP<>2 | [F:PTR]PTRNUM<>GPTRNUM
   Read [PTR] PTR0=2;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
#----- Si document renseigné dans la transaction, prendre celui-la -----#
If [F:PTR]DOCNAM<>"" [L]REPORT1=[F:PTR]DOCNAM : Endif

Return

########################################################################
$AP_IMPRIME
#-----------------------------------#
# il faut se remettre sur bon enreg #
#-----------------------------------#
Gosub RELIT From GOBJSUB
Return

######################################################################
$DEFLIG
#--------------------------------------------#
# fichier PREQUISD est le fichier par defaut #
# masque détail PSH1 par defaut              #
#--------------------------------------------#
Default File [PSD]
Default Mask [PSH1]

#------ critère de lecture ----#
CRIT = 'PSHNUM="'+[M:PSH0]PSHNUM+'"'
#------ fichier details ------#
FICLIG = "PREQUISD"
#------- abreviation ------#
ABLIG = "PSD"
#-------zone ligne --------#
ZONLIG = "PSDLIN"

Return


#######################################################################
$LIENS_LIG
#-----------------------------------------------------------#
# ici on se trouve dans la boucle de chargement des details #
# en ligne à ligne, je renseigne une zone de l'ecran qui    #
# peut contenir un numero de message  pour savoir si la     #
# ligne est modifiable ou pas                               #
# blomsg = 0  pour ligne est modifiable                     #
# blomsg = 18 pour non modifiable car signée  ou partielle  #
#             attention valeur = 4 pas de gestion des visas #
# blomsg = 19 pour non modifiable car partiellement cdée    #
# blomsg = 20 pour non modifiable car commandée             #
# blomsg = 21 pour non modifiable car soldée                #
# message affichée lors accés sur la ligne (chapitre 194)   #
#-----------------------------------------------------------#
[M:PSH1]VAT1(nolign-1)=[F:PSD]VAT(0)
[M:PSH1]VAT2(nolign-1)=[F:PSD]VAT(1)
[M:PSH1]VAT3(nolign-1)=[F:PSD]VAT(2)
#-----
[M:PSH1]LINFLG (nolign-1) = 1
[M:PSH1]BLOMSG (nolign-1) = 0
[M:PSH1]PRIFLG (nolign-1) = 2 : # pas de recherche tarif

If dim([M:PSH1]ECCSAIFLG) > 0      # hcb 71276
   [M:PSH1]ECCSAIFLG = 1           # hcb 71276
Endif
#-----
# Issue 91052 - 2013-07-25 by SR
# Issue 92916 - 2013-10-07 by SR : Retour sur correction 91052
If [F:PSD]LINAPPFLG>1 & [F:PSD]LINAPPFLG<4 & GPSHAPPHEA<2
#If [F:PSD]LINAPPFLG>1 & [F:PSD]LINAPPFLG<4
  [M:PSH1]BLOMSG(nolign-1) = 18
Endif
If [F:PSD]ORDQTYPUU <> 0 : [M:PSH1]BLOMSG(nolign-1) = 19 : Endif
If [F:PSD]LINCLEFLG = 2  : [M:PSH1]BLOMSG(nolign-1) = 21 : Endif
If [F:PSD]LINORDFLG = 2  : [M:PSH1]BLOMSG(nolign-1) = 20 : Endif
#----- Chargement comptes et sections analytiques -----#
Call CHARG_ACCCCE(nolign-1,"[M:PSH1]LINACC","","[M:PSH1]CCE",
&                "PSD",0,[F:PSD]PSHNUM,[F:PSD]PSDLIN,0,"") From TRTX3CPT
#VPO 09/11/10 68973 on stocke LINAMT pour CTLBUD et affect FBUFLG
[M:PSH1]LINAMTOLD(nolign-1)=[M:PSH1]LINAMT(nolign-1)
[M:PSH1]QTYPUUOLD(nolign-1)=[M:PSH1]QTYPUU(nolign-1)
[M:PSH1]QTYSTUOLD(nolign-1)=[M:PSH1]QTYSTU(nolign-1)

# Issue 78167 - 2011-11-24 by VPO : designation traduite selon la langue du fourn
If [M:PSH1]BPSNUM(nolign-1)<>""
   #lecture BPR
   If [F:BPR]BPRNUM<>[M:PSH1]BPSNUM(nolign-1)
     Read [BPR] BPR0=[M:PSH1]BPSNUM(nolign-1)
     If fstat Raz [F:BPR] : Endif
   Endif
   If [F:BPR]LAN=""
     [M:PSH1]LAN(nolign-1)=GLANGUE
   Else
     [M:PSH1]LAN(nolign-1)=[F:BPR]LAN
   Endif
Else
   [M:PSH1]LAN(nolign-1)=GLANGUE
Endif
# Issue 88103 - 2013-02-25 by SR : Par défaut, tout est impactant pour les signatures
[M:PSH1]WAPPFLG(nolign-1) = 2
# Issue 112933 - 2015-12-04 by SR : Zones impactantes
[M:PSH1]APPUPDFLG(nolign-1) = 0
Return

#######################################################################
$RAZCRE
#------------------------------------------------------#
# Valeurs par défaut et initialisations avant création #
#------------------------------------------------------#
[M:PSH0]REQUSR=GUSER
[M:PSH0]PRQDAT=date$
# Issue 93463 - 2014-01-27 by SR
[M:PSH0]WMODIF=1
# Issue 113581 - 2016-02-15 by SR
Raz [M:PSH0]ANCLINNBR
If !GIMPORT  Actzo [PSH0]1-99 : Actzo [PSH1]5 : Endif
GFCY = GFCYDEF(6)
Call GETFCYDEF(GFCY,"[F:FCY]PURFLG=2") From TRTX3
[M:PSH0]PSHFCY=GFCY
If !GIMPORT
  If GNBAUZ=1 & GFCY<>""  Diszo [PSH0]PSHFCY  Else  Actzo [PSH0]PSHFCY : Endif
Endif
#-----
Gosub CHARG_PARAM From SUBPSH1
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL  From SUBPSH1
# Issue 71069 - 2013-08-13 by SR : PJT
# A faire avant tout le reste
If GPJTSNGDOC = G_NON Then
 Call PJT_MODFCY([M:PSH0]PSHFCY,"[M:PSH1]PJT") From TRTPJT
Endif
#------------------------#
# ouverture de la trace  #
#------------------------#
If GTRACE = ""
  Call OUVRE_TRACE(mess(173,197,1)) From LECFIC
  GPURTRACE = 0
Endif
#----- Gestion des textes -----#
Call RAZ_CLOB From ACLOB : GCONSDIA=0 : # Rend saisissable le texte
Raz [M:PSH1]TEX1, [M:PSH1]TEX2, [M:PSH1]LINTEX
Call RESET_IMAGE (4) From GESECRAN
#-----
[M:PSH1]XAPPFLG=1
[M:PSH1]XCLEFLG=1
[M:PSH1]XORDFLG=1
[M:PSH1]XPRNFLG=1

#VPO 04/01/10 gestion bouton pour URL MMS
Gosub GRIZEBUTMMS

If !GIMPORT
  Affzo [PSH0]1-99
  Affzo [PSH1]10
Endif
# Issue 71069 - 2013-08-13 by SR : PJT
# A faire après tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY([M:PSH0]PSHFCY,"[M:PSH1]PJT") From TRTPJT
Endif
Return

#######################################################################
$RAZDUP
[M:PSH0]PRQDAT=date$
# Issue 93463 - 2014-01-27 by SR
[M:PSH0]WMODIF=1
# Issue 113581 - 2016-02-15 by SR
Raz [M:PSH0]ANCLINNBR
[M:PSH1]XAPPFLG=1
[M:PSH1]XCLEFLG=1
[M:PSH1]XORDFLG=1
[M:PSH1]XPRNFLG=1
Gosub CHARG_PARAM From SUBPSH1
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL  From SUBPSH1
# Issue 71069 - 2013-08-13 by SR : PJT
# A faire avant tout le reste
If GPJTSNGDOC = G_NON Then
 Call PJT_MODFCY([M:PSH0]PSHFCY,"[M:PSH1]PJT") From TRTPJT
Endif
#VPO ajout PSHNUMMMS, raz des zones de MMS
If dim([M:PSH1]PSHNUMMMS)>0
    Raz [M:PSH1]PSHNUMMMS : Affzo [M:PSH1]PSHNUMMMS
    Raz [M:PSH1]MMSURL    : Affzo [M:PSH1]MMSURL
Endif
#VPO 04/01/10 gestion bouton pour URL MMS
Gosub GRIZEBUTMMS

If !GIMPORT
  Actzo [PSH0]PRQDAT
  Affzo [PSH0]PRQDAT
  Actzo [PSH1]5
  Affzo [PSH1]10
Endif

#----- Le demandeur ne peut être modifié que s'il n'y a pas de filtre -----#
If GPLNFLT<2
  [M:PSH0]REQUSR=GUSER : Actzo [PSH0]REQUSR : Affzo [PSH0]5
Endif
#------------------------#
# ouverture de la trace  #
#------------------------#
If GTRACE = ""
  Call OUVRE_TRACE(mess(173,197,1)) From LECFIC
  GPURTRACE = 0
Endif
#----- Gestion des textes entête et pied -----#
Call RAZ_CLOB From ACLOB : GCONSDIA=0 : # Rend saisissable le texte
If left$([M:PSH1]TEX1,3)="PSH"
  Call DUP_CLOB("PSH",[M:PSH1]TEX1,WRETOUR) From TRTX3TEX
  If WRETOUR<1  Raz [M:PSH1]TEX1 : Endif
Endif
If left$([M:PSH1]TEX2,3)="PSH"
  Call DUP_CLOB("PSH",[M:PSH1]TEX2,WRETOUR) From TRTX3TEX
  If WRETOUR<1  Raz [M:PSH1]TEX2 : Endif
Endif
# Issue 71069 - 2013-08-13 by SR :PJT
# Code affaire à la ligne (Partie : rajout paramètre société pour contrôle documents mono-affaire)
#--Duplication avec paramètre à OUI => si le code affaire de la ligne est <> de celui de l'en-tête, on reprend l'en-tête
Call TRAITE_DUPLICATION("[M:PSH0]PJTH") From TRTPJT
#--/CPO

#----- Déclaration des variables locales utilisées si nécessaire -----#
If dim(J)<0         Local Shortint J               : Endif
If dim(STAT)<0      Local Integer  STAT            : Endif
If dim(MT1)<0       Local Decimal  MT1             : Endif
If dim(MT2)<0       Local Decimal  MT2             : Endif
If dim(DISCRGVAL)<0 Local Decimal  DISCRGVAL(0..8) : Endif
If dim(WPRIREN)<0   Local Char     WPRIREN(2)      : Endif
#------------------------------------------------------#
# remise à zero de certaines colonnes dans les détails #
# de toute la colonne dans le cas de la duplication    #
#------------------------------------------------------#
Raz [M:PSH0]PSHNUM, GBIDC2, GMESSAGE, mkstat
For I=0 To [M:PSH1]NBLIG-1
  [M:PSH1]LINFLG(I)=1
  Raz [M:PSH1]CMMPRPNUM(I), [M:PSH1]CREFLG(I), [M:PSH1]UPDFLG(I)
  If [F:ITM]ITMREF<>[M:PSH1]ITMREF(I)
    Read [ITM] ITM0=[M:PSH1]ITMREF(I)
    If fstat Raz [F:ITM] : Endif
  Endif
  If [F:ITF]ITMREF<>[M:PSH1]ITMREF(I) | [F:ITF]STOFCY<>[M:PSH0]PSHFCY
    Read [ITF] ITF0=[M:PSH1]ITMREF(I);[M:PSH0]PSHFCY
    If fstat Raz [F:ITF] : Endif
  Endif
  If [F:ITF]OFS<>0
    [M:PSH1]OFS(I)=[F:ITF]OFS
  Else
    [M:PSH1]OFS(I)=[F:ITM]OFS
  Endif
  Call CONTDEV([M:PSH1]CUR(I),[M:PSH0]PRQDAT) From TRTDEV
  If mkstat
    Raz GMESSAGE, mkstat
    GBIDC3=[M:PSH1]CUR(I)
    If [M:PSH1]BPSNUM(I)<>""
      If [F:BPR]BPRNUM<>[M:PSH1]BPSNUM(I)
        Read [BPR] BPR0=[M:PSH1]BPSNUM(I)
        If fstat  Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : Endif
      Endif
      If [F:BPS]BPSNUM<>[M:PSH1]BPSNUM(I)
        Read [BPS] BPS0=[M:PSH1]BPSNUM(I)
        If fstat  Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
      Endif
      [M:PSH1]CUR(I)=[F:BPS]CUR
    Else
      [M:PSH1]CUR(I)=GLOCALDEV
    Endif
    If [M:PSH1]CUR(I)<>GBIDC3
      Call CONTDEV([M:PSH1]CUR(I),[M:PSH0]PRQDAT) From TRTDEV
      If mkstat
        GBIDC2=GMESSAGE : Raz GMESSAGE, mkstat
      Endif
      WPRIREN=num$([M:PSH1]PRIREN(I))
      Call CONTROLE("PPR","A",WPRIREN,"",mkstat) From CONTOBJ
      If [M:PSH1]PRIREN(I)<>GUPDPRIPUR & mkstat
        Raz [M:PSH1]NETPRI(I), mkstat : [M:PSH1]PRIFLG(I)=1
        nolign=I+1 : Gosub INI_TARIF From SUBPSH
        If GBIDC2="" GBIDC2=mess(235,194,1) : Endif
      Else
        If [F:BPS]BPSNUM<>[M:PSH1]BPSNUM(I)
          Read [BPS] BPS0=[M:PSH1]BPSNUM(I)
          If fstat Raz [F:BPS] : Endif
        Endif
        If GPLISTC<>[F:BPS]PLISTC
          GPLISTC=[F:BPS]PLISTC
          Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
          Call TARIFCHGT(6)                From TRTPRICE
        Endif
        Call CONVERT2(GBIDC3,[M:PSH1]CUR(I),GLOCALDEV,[M:PSH1]CHGTYP(I),[M:PSH0]PRQDAT,
&                     [M:PSH1]GROPRI(I),MT2,STAT) From TRTDEV
        [M:PSH1]GROPRI(I)=arr(MT2,10^-GDECPRI)
        For J=1 To 9
          If evalue ("dim([M:PSH1]DISCRGVAL"+num$(J)+"(I))")>0
            If GFMTREM(J-1)="M"
              MT1=evalue ("[M:PSH1]DISCRGVAL"+num$(J)+"(I)")
              Call CONVERT(GBIDC3,[M:PSH1]CUR(I),GLOCALDEV,[M:PSH1]CHGTYP(I),
&                          [M:PSH0]PRQDAT,MT1,MT2,STAT) From TRTDEV
              Assign "[M:PSH1]DISCRGVAL"+num$(J)+"(I)" With MT2
            Endif
            DISCRGVAL(J-1)=evalue ("[M:PSH1]DISCRGVAL"+num$(J)+"(I)")
          Endif
        Next J
        If dim(GCALNETLIN)>0  GCALNETLIN=I+1        : Endif
        If dim(GCALNETABR)>0  GCALNETABR="[M:PSH1]" : Endif
        Call CALNET(2,[F:BPS]PLISTC,[M:PSH1]GROPRI(I),DISCRGVAL,[M:PSH1]QTYPUU(I),
&                   [M:PSH1]NETPRI(I),[M:PSH1]CUR(I)) From TRTPRICE
        [M:PSH1]LINAMT(I)=[M:PSH1]NETPRI(I)*[M:PSH1]QTYPUU(I)
        Call ARRDEV([M:PSH1]LINAMT(I),[M:PSH1]CUR(I)) From TRTDIV
        If GBIDC2="" GBIDC2=mess(235,194,1) : Endif
      Endif
    Endif
  Endif
  If [M:PSH1]EXTORDDAT(I)<[M:PSH0]PRQDAT
    If GBIDC2="" GBIDC2=mess(235,194,1) : Endif
    [M:PSH1]EXTORDDAT(I)=[M:PSH0]PRQDAT
    [M:PSH1]EXTRCPDAT(I)=[M:PSH1]EXTORDDAT(I)+[M:PSH1]OFS(I)
    If [F:FCY]FCY<>[M:PSH1]PRHFCY(I)
      Read [FCY] FCY0=[M:PSH1]PRHFCY(I)
      If fstat Raz [F:FCY] : Endif
    Endif
    Call CTL_JOU2([M:PSH1]EXTRCPDAT(I),[M:PSH0]PRQDAT,
&                 [F:FCY]UVYDAY,[F:FCY]UVYCOD,1) From CONTX3
    # Issue 113777 - 2016-01-22 by MUARN : en dup. et changement de date ajoute recherche tarif
    [M:PSH1]PRIFLG(I)=1
    nolign=I+1 : Gosub INI_TARIF From SUBPSH
  Endif
  If GAPPPSH>1
    [M:PSH1]LINAPPFLG(I)=1
  Else
    [M:PSH1]LINAPPFLG(I)=4
  Endif
  #----- Gestion des textes lignes article -----#
  If left$([M:PSH1]LINTEX(I),3)="PSD"
    Call DUP_CLOB("PSD",[M:PSH1]LINTEX(I),WRETOUR) From TRTX3TEX
    If WRETOUR<1  Raz [M:PSH1]LINTEX(I) : Endif
  Endif
  #-----
  [M:PSH1]LINCLEFLG(I)=1
  [M:PSH1]LINORDFLG(I)=1
  #VPO 09/11/10 68973 on stocke LINAMT pour CTLBUD et affect FBUFLG
  [M:PSH1]LINAMTOLD(nolign-1)=0
  [M:PSH1]QTYPUUOLD(nolign-1)=0
  [M:PSH1]QTYSTUOLD(nolign-1)=0
  #----- Mise à jour indicateur dépassement de budget -----#
  If GMODU(2)=2
    If dim(OK)<1  Local Integer OK : Endif
    nolign=I+1
    Call CTLBUD(OK) From SUBPSH1
    If OK<1
      [M:PSH1]FBUFLG(I)=2
      #VPO 08/02/11 71412 : message à tort suite appel CTLBUD (ex: en dupli)
      OK=1 : Raz GMESSAGE
    Else
      [M:PSH1]FBUFLG(I)=1
    Endif
  Endif
Next I
Raz [M:PSH1]BLOMSG
Raz [M:PSH1]PQHNUM
Raz [M:PSH1]PPDLIN
Raz [M:PSH1]WQTYORDPUU
Raz [M:PSH1]WQTYORDSTU
Raz [M:PSH1]XAPPFLG
Raz [M:PSH1]XCLEFLG
Raz [M:PSH1]XORDFLG
Raz [M:PSH1]XPRNFLG
If !GIMPORT  Affzo [PSH1]1-99 : Endif
If GBIDC2<>""  Call MESSAGE(GBIDC2) From GESECRAN : Endif
# Issue 71069 - 2013-08-13 by SR : PJT
# A faire après tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY([M:PSH0]PSHFCY,"[M:PSH1]PJT") From TRTPJT
Endif
Return

$EFFMASK
#VPO 04/01/10 gestion bouton pour URL MMS
Gosub GRIZEBUTMMS
Return

# Issue 93463 - 2014-01-27 by SR
$APRES_MODIF
# Point d'entrée permettant de positionner WMODIFà 2 si modification de zones entête
# devant impacterla relance du circuit de signature
GPOINT = "APPFLGMGT" : Gosub ENTREE From EXEFNC
Return

$GRIZEBUTMMS
If dim([M:PSH1]MMSURL)>0
    If [M:PSH1]MMSURL=""
        Grizo [M:PSH1]BUTMMSURL
    Else
        Actzo [M:PSH1]BUTMMSURL
    Endif
Endif
If dim([M:PSH1]BUTMMSURL)>0
    If [M:PSH1]BUTMMSURL=""
       [M:PSH1]BUTMMSURL="63"
       Affzo [M:PSH1]BUTMMSURL
    Endif
Endif
Return

########################################################################
$VERIF
If [M:PSH1]NBLIG = 0 Goto VERIF_10 : Endif
#-------------------------------------------------------------#
# verification controle budgetaire                            #
# ne pouvant bloquer le controle et revenir sur la ligne      #
# en apres-ligne ---> je controle les lignes à la validation  #
#  si le controle est bloquant on refuse la saisie            #
#-------------------------------------------------------------#
#---------------------------------------#
# Si une ligne a une quantité à 0       #
# attention a la modification rejet     #
#---------------------------------------#
Local Integer NBPOSTE                     : #-- nbre de lignes avant controle
Local Integer TABLIG (0..[M:PSH1]NBLIG-1) : #-- tableau contient les rangs à supprimer
# Issue 111613 - 2015-10-23 by SR
If dim(SAVNOLIGN) < 0 :  Local Integer  SAVNOLIGN : Endif
SAVNOLIGN = nolign

NBPOSTE = [M:PSH1]NBLIG
For I = 0 To NBPOSTE-1
 # Issue 111613 - 2015-10-23 by SR
  nolign = I+1
  If [M:PSH1]QTYPUU(I) = 0
    If GREP = "M"
      GMESSAGE =mess(7,194,1) : OK=0 : Break
    Endif
    TABLIG(I) = -(I+1)
  Else
    TABLIG (I) = 0
    If [M:PSH1]FBUFLG (I) = 2 & GCTLBUD = 2 & GBUDCTLPSL=2
      GMESSAGE = mess(39,194,1)-num$(I+1) : OK=0 : Break
    Endif
  Endif
  #----- Contrôle validité des articles si duplication -----#
  If GREP="D"
    If [F:ITM]ITMREF<>[M:PSH1]ITMREF(I)
      Read [ITM] ITM0=[M:PSH1]ITMREF(I) : If fstat  Raz [F:ITM] : [F:ITM]ITMSTA=6 : Endif
    Endif
    GMESSAGE=mess(18,197,1)-num$(I+1)-[M:PSH1]ITMREF(I)
    #----- Contrôle de l'approvisionneur (PLANNER) -----#
    If (GPLNFLT=2 & [F:ITM]PLANNER<>[M:PSH0]REQUSR & [F:ITM]PLANNER<>"") |
&      (GPLNFLT=3 & [F:ITM]PLANNER<>[M:PSH0]REQUSR)
      GMESSAGE-=mess(61,193,1) : OK=0 : Break
    Endif
    #----- Contrôle article en fin de vie ------#
    If [F:ITM]LIFENDDAT<>[0/0/0] & [F:ITM]LIFENDDAT<[M:PSH0]PRQDAT
      GMESSAGE-=mess(12,318,1) : OK=0 : Break
    Endif
    #----- Contrôle statut de l'article -----#
    If [F:ITM]ITMSTA<>1 & [F:ITM]ITMSTA<>3
      GMESSAGE-=mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")" : OK=0 : Break
    Endif
    Raz GMESSAGE
# Issue 112933 - 2015-12-04 by SR : Modifications impactantes ou non APPUPDFLG pend les valeurs 0 ou 1 comme UPDFLG
  Elsif GREP = "M"
     [M:PSH1]APPUPDFLG(I)    =  [M:PSH1]UPDFLG(I)
     If [M:PSH1]APPUPDFLG(I) =  1  # Peut être égal à 2 dans le cas du solde de la ligne: Dans ce cas on le laisse ainsi
       If [M:PSH1]WAPPFLG(I) =  1 : [M:PSH1]APPUPDFLG(I) = 0 : Endif
    Endif
  # End issue 112933
  Endif
  #--CPO 71937 Contrôle de cohérence champs invisibles
  If [M:PSH1]VACBPR(I)<>"" and [M:PSH1]PRHFCY(I)<>""
      mkstat=0
      Call CONTTVB([M:PSH1]VACBPR(I),"","PSH1","VACBPR",[M:PSH1]PRHFCY(I),"","") From SUBTVB
      If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","PSH1~VACBPR")+'"\'+GMESSAGE : Break : Endif
  Endif
  #--/

  # Issue 106269 - 2015-02-13 by MUARN : contrôle axes invisibles et duplication
  For J = 1 To GNBDIE
    WVAL = evalue("[M:PSH1]CCE"+num$(J)+"("+num$(I) +")")
    Call SAIS_CCE(WVAL,J,"[M:PSH1]LINACC","") From TRTX3CPT
    If !mkstat
      Call CTRL_CCE(WVAL,J,"[M:PSH1]LINACC",GFINRSP,[M:PSH0]PRQDAT) From TRTX3CPT
      If GMESSAGE <> ""
        GERR = 1
        GMESSAGE -= mess(18,197,1) - num$(I+1)
        OK = 0
        Break 2
      Endif
    Endif
    Raz mkstat
    Call CTLCCE(WVAL,GDIE(J),GFINRSP,[M:PSH1]EXTRCPDAT(nolign-1),nolign-1,
&         "GDIE(1","[M:PSH1]CCE#","GCOA(1","[M:PSH1]LINACC#") From SELCCE
    If mkstat : Raz mkstat : OK=0 : GERR=1 : Break 2 : Endif
  Next

Next I
# Issue 111613 - 2015-10-23 by SR
nolign = SAVNOLIGN
If OK=0  Return : Endif

#--------------------------------------------------------------------#
# tri du tableau     le tableau contient des valeurs < 0             #
# si il existe des rangs à supprimer dans [m]NBLIG, ils se trouvent  #
# en debut du tableau TABLIG . On commence à supprimer le plus grand #
# jusqu'au plus petit rang ---> pas de problème de perte de l'indice #
#--------------------------------------------------------------------#
Sorta TABLIG
For I = 0 To NBPOSTE-1
  If TABLIG (I) = 0   : Break : Endif
    nolign = -TABLIG(I)-1
    If dim([M:PSH1]ITMREF) = [M:PSH1]NBLIG
             Dela nolign,1 [M:PSH1]NBLIG   : # pas de borne sinon plantage
    Else     Dela nolign,1,[M:PSH1]NBLIG-1 [M:PSH1]NBLIG
    Endif
    [M:PSH1]NBLIG -=1
Next I

If NBPOSTE <> [M:PSH1]NBLIG & !GIMPORT
  Affzo [PSH1]1-99
Endif

# Issue 71069 - 2013-08-13 by SR : PJT
Call PJT_CONTROLE_HEAD_DETAIL("[M:PSH0]PJTH", "[M:PSH1]PJT") From TRTPJT
If GERR <> 0
  OK = 0
  Return
Endif

$VERIF_10
#-----------------------------------------------#
# mise à jour impossible si pas de ligne saisie #
#-----------------------------------------------#
If [M:PSH1]NBLIG = 0
  GERR = 1 : GMESSAGE =mess(61,199,1) : OK = 0
Endif
Return


#######################################################################
$INICRE
Local Integer WSTAT
#---------------------------#
# récupération du numéro DA #
# code retour <> 0 problème #
#---------------------------#
If GMANCOU<>2 | (GMANCOU=2 & vireblc([M:PSH0]PSHNUM,2)="")
  Call NUMERO(GCODNUM,[M:PSH0]PSHFCY,[M:PSH0]PRQDAT,"",[M:PSH0]PSHNUM,WSTAT) From SUBANM
  If GOK<0
    Return
  Elsif GOK<1 | WSTAT<>0
    GOK=0 : GERR=1 : GMESSAGE=GCODNUM-mess(60,199,1)
    Return
  Endif
  [F:PSH]PSHNUM=[M:PSH0]PSHNUM
Endif
#------------------------------------------------#
# On relit si un tunnel a cassé buffer  PURTRS   #
#------------------------------------------------#
If !GIMPORT
   If [F:PTR]PTRTYP<>2 | [F:PTR]PTRNUM<>GPTRNUM
      Read [PTR] PTR0=2;GPTRNUM : If fstat Raz [F:PTR] : Endif
   Endif
Endif
#-----------------#
# zones entete    #
#-----------------#
[F:PSH]CPY    = GSOCIETE
[F:PSH]LINNBR = [M:PSH1]NBLIG
[F:PSH]PRNFLG = 1
Call MAJPSH From SUBPSH1
#---------------------------------------------------#
# Création ou duplication des textes entête et pied #
#---------------------------------------------------#
Gosub CHARG_TEXT_ENTETE
Return

#######################################################################
$INICRE_LIG
Local Integer WSTAT
#-----------------#
# Zones du détail #
#-----------------#
# Issue 121687 - 2017-02-24 by SR : si modif et signature à l'entête et DA pas encore signée,
# mettre 1 dans LINAPPFLG puisqu'on ne relancera pas le circuit de signature
# Issue X3-77157 - 2018-02-26 by SR : Retour arrière
If GAPPPSH>1  & [F:PSD]LINCLEFLG<>2  [F:PSD]LINAPPFLG=0 : Endif
#If GAPPPSH>1
#   If  GREP = "M" & [F:PSH]APPFLG = 1 & GPSHAPPHEA=2 :  [F:PSD]LINAPPFLG=1
#   Elsif [F:PSD]LINCLEFLG<>2 : [F:PSD]LINAPPFLG=0
#   Endif
#Endif
# End issue 121687
# End issue X3-77157
[F:PSD]PSHNUM = [M:PSH0]PSHNUM
[F:PSD]CPY    = GSOCIETE
[F:PSD]PSHFCY = [M:PSH0]PSHFCY
#-----
[F:PSD]CMMPRPTAX           =max(GPURCMMTAX,1) : # Indicateur Type d'engagement
[M:PSH1]CMMPRPTAX(nolign-1)=max(GPURCMMTAX,1) : # Indicateur Type d'engagement
#-----
[F:PSD]VAT(0)=[M:PSH1]VAT1(nolign-1)
[F:PSD]VAT(1)=[M:PSH1]VAT2(nolign-1)
[F:PSD]VAT(2)=[M:PSH1]VAT3(nolign-1)
#---------------------------------------------#
# Relecture des fichiers article              #
#                        fournisseur          #
#                        article-fournisseur  #
#                        article-site demande #
#---------------------------------------------#
Gosub RELECTURE
#-----
If [F:ITF]BUY <> ""
      [F:PSD]LINBUY =  [F:ITF]BUY
Elsif [F:ITM]BUY <> ""
      [F:PSD]LINBUY =  [F:ITM]BUY
Else  [F:PSD]LINBUY = ""
Endif
[F:PSD]ORI = 1
#------------------------------------------------------#
# recherche du cours entre devise DA et devise societe #
#------------------------------------------------------#
If [F:PSD]CUR  <> GCUR
  # Issue 83106 - 2012-06-22 by MUARN : arrondi taux de change
  #Call COURDEV([F:PSD]CUR,GCUR,[F:PSD]CHGTYP,GHIDATE,[F:PSD]CHGCOE,WSTAT) From TRTDIV
  Call COURSITE([F:PSD]CUR,[F:PSD]PSHFCY,[F:PSD]CHGTYP,GHIDATE,[F:PSD]CHGCOE,WSTAT) From TRTDEV
Else
  [F:PSD]CHGCOE = 1
Endif
#----- Récupération du chrono pour les encours -----#
If [F:ITF]ITMREF<>[F:PSD]ITMREF | [F:ITF]STOFCY<>[F:PSD]PRHFCY
  Read [ITF] ITF0=[F:PSD]ITMREF;[F:PSD]PRHFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
If [F:ITF]STOMGTCOD>1
  Call NUMERO(GWIP,[F:PSD]PRHFCY,[F:PSD]EXTORDDAT,"",[F:PSD]WIPNUM,WSTAT) From SUBANM
  If GOK<0
    Return
  Elsif GOK<1 | WSTAT<>0
    GOK=0 : GERR=1 : GMESSAGE=GWIP-mess(60,199,1)
    Return
  Endif
Endif
#----------------------------------------#
# Création ou duplication du texte ligne #
#----------------------------------------#
Gosub CHARG_TEXT_LIGNE
Return

#######################################################################
$CREATION
#-----------------------------#
# on a deja écrit l'entete DA #
# on ecrit les lignes         #
#-----------------------------#
GMODIF = 0
Gosub CREATION From TABLEAUX
If GOK<1 : Return : Endif
#----- Réajustement si nécessaire nbre lignes dépassant le budget -----#
Gosub REAJUST_ENTETE
#----- Mise à jour statistiques entête DA -----#
SIGN=1 : Call VALSTA("PSH",SIGN) From SUBPS2 : If GOK<1 Return : Endif
Return


#######################################################################
$APRES_CRE
If !GIMPORT  Affzo [PSH0]PSHNUM : Endif : # Affichage numéro DA
Gosub EFFAC_PWRKORDERS From SUBPSH      : # Effacement fichier de travail
#----- Affichage de la trace le cas échéant -----#
If !GIMPORT
  Call FERME_TRACE From LECFIC
  If GPURTRACE>0  Call LEC_TRACE From LECFIC : Endif
Endif
Raz GPURTRACE
#----- Impression bon de DA -----#
If [F:PTR]DOCFLG=2 & [F:PSH]APPFLG>2
  Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
  Gosub SET_CLE From GOBJSUB : CLECUR=1 : # SET_CLE parce que création
  Call ETAT([F:PTR]DOCNAM,"GESPSH",TBPAR,TBVAL) From ETAT
  If !GIMPORT
    Gosub RELIT From GOBJSUB
  Else
    Gosub LIENS From SUBPSH1
  Endif
Else
  Gosub LIENS From SUBPSH1
Endif
If !GIMPORT  Affzo [PSH1]1-99 : Endif
Return


#######################################################################
$AB_CREATION
# Issue 80029 - 2012-03-05 by SR : idem 69241 en AB_MODIF
Gosub AB_MODIF
#Gosub RAZ_CMMPRPNUM
Return


#######################################################################
$AVANT_MOD
#---------------------------------------------------------#
# Attention on peut désolder une ligne par clic droit,    #
# ce qui explique la présence du test "!sigma(I=0,..etc)" #
#---------------------------------------------------------#

#----- Demande d'achat soldée, modification interdite ! -----#
If [M:PSH1]XCLEFLG=2 & !sigma(I=0,[M:PSH1]NBLIG-1,[M:PSH1]LINCLEFLG(I)=1)
  GMESSAGE=mess(24,194,1) : GERR=1 : OK=0 : Return
Endif
Return


#######################################################################
$AVANT_MODFIC
#----- Cas particulier où l'on modifie le texte en le supprimant -----#
Local Integer WRETOUR
If [M:PSH1]TEX1="" & left$([F:PSH]TEX1,3)="PSH"
  Call SUP_CLOB([F:PSH]TEX1,WRETOUR) From TRTX3TEX
Endif
If [M:PSH1]TEX2="" & left$([F:PSH]TEX2,3)="PSH"
  Call SUP_CLOB([F:PSH]TEX2,WRETOUR) From TRTX3TEX
Endif
#----- Mise à jour statistiques entête DA -----#
Local Integer SIGN
SIGN=-1 : Call VALSTA("PSH",SIGN) From SUBPS2 : If GOK<1 Return : Endif
#----- Positionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
# Issue 121687 - 2017-02-24 by SR : Seulement si la signature à commencé
# Issue X3-77157 - 2018-02-26 by SR : Retour arrière
#If GAPPPSH>1 & GPSHAPPHEA=2 & [F:PSH]APPFLG <> 1
If GAPPPSH>1 & GPSHAPPHEA=2
  #----- Solde/désolde ligne (UPDFLG=2) et totalement signé, ne rien faire ! -----#
  # Issue 92916 - 2013-10-07 by SR : Tester Si ligne supprimée
  # Issue 112933 - 2015-12-04 by SR : Prise en compte des zones impactantes
  # Issue 121687 - 2017-02-24 by SR  Tester aussi si ligne ajoutée
  # If  find(1,[M:PSH1]UPDFLG(0..[M:PSH1]NBLIG-1)) | [F:PSH]APPFLG < 3 | [F:PSH]LINNBR>[M:PSH1]NBLIG
  # If  find(1,[M:PSH1]APPUPDFLG(0..[M:PSH1]NBLIG-1)) |([F:PSH]APPFLG < 3 & find(2,[M:PSH1]APPUPDFLG(0..[M:PSH1]NBLIG-1))) | [F:PSH]LINNBR>[M:PSH1]NBLIG
  # Issue X3-102918 - 2018-08-03 by SR :
  # Tester [M:PSH0]WMODIF = indicateur de modif d'une zone d'entête impactante
  # If  find(1,[M:PSH1]APPUPDFLG(0..[M:PSH1]NBLIG-1)) |([F:PSH]APPFLG < 3 & find(2,[M:PSH1]APPUPDFLG(0..[M:PSH1]NBLIG-1))) | [F:PSH]LINNBR<>[M:PSH1]NBLIG
   If  find(1,[M:PSH1]APPUPDFLG(0..[M:PSH1]NBLIG-1)) |([F:PSH]APPFLG < 3 & find(2,[M:PSH1]APPUPDFLG(0..[M:PSH1]NBLIG-1))) |
&    [F:PSH]LINNBR<>[M:PSH1]NBLIG | [M:PSH0]WMODIF = 2
    If dim(I)<1       Local Integer I          : Endif
    If dim(WMOTIF)<1  Local Char    WMOTIF(30) : Endif
    If !sigma(I=0,[M:PSH1]NBLIG-1,[M:PSH1]LINCLEFLG(I)<>2)
      WMOTIF=mess(654,197,1)
    Else
      WMOTIF=mess(652,197,1)
    Endif
    Call ANNULE_SUIVI("PSH",WMOTIF,1,WRETOUR) From TRTACHDIV1
    If GOK<1  Return : Endif
   Endif
Endif
Return

#######################################################################
$INIMOD
#------------------------------------------------#
# on relit si un tunnel a cassé buffer  PURTRS   #
#------------------------------------------------#
If !GIMPORT
   If [F:PTR]PTRTYP<>2 | [F:PTR]PTRNUM<>GPTRNUM
      Read [PTR] PTR0=2;GPTRNUM : If fstat Raz [F:PTR] : Endif
   Endif
Endif
#------------------------------------------------------------------#
# on remet à jour le nombre de ligne dans cas suppression ou ajout #
#------------------------------------------------------------------#
[F:PSH]LINNBR = [M:PSH1]NBLIG
Call MAJPSH From SUBPSH1
#---------------------------------------------------#
# Création ou duplication des textes entête et pied #
#---------------------------------------------------#
Gosub CHARG_TEXT_ENTETE
Return

#######################################################################
$INIMOD_LIG
Local Integer WSTAT
#-----
[F:PSD]VAT(0)=[M:PSH1]VAT1(nolign-1)
[F:PSD]VAT(1)=[M:PSH1]VAT2(nolign-1)
[F:PSD]VAT(2)=[M:PSH1]VAT3(nolign-1)
#-----
Gosub RELECTURE
If GAPPPSH>1
# Issue 88103 - 2013-02-25 by SR : Seulement si modification de zones impactantes
  # Issue 112933 - 2015-12-04 by SR : Modification zones impactantes CMMPRPFLG doit être mis à jour
#  If [M:PSH1]WAPPFLG(nolign-1) = 2
      #----- Solde/désolde ligne (UPDFLG=2) et totalement signé, ne rien faire ! -----#
      # Issue 112933 - 2015-12-04 by SR : Modification zones impactantes
      #If [F:PSD]LINCLEFLG<>2 & ([M:PSH1]UPDFLG(nolign-1)=1 | [F:PSD]LINAPPFLG<3)
      If [F:PSD]LINCLEFLG<>2 & ([M:PSH1]APPUPDFLG(nolign-1)=1 | [F:PSD]LINAPPFLG<3)
        [F:PSD]LINAPPFLG=0
      Endif
      [F:PSD]CMMPRPFLG=0
#  Endif
Endif
#------------------------------------------------------#
# recherche du cours entre devise DA et devise societe #
#------------------------------------------------------#
If [F:PSD]CUR  <> GCUR
  # Issue 83106 - 2012-06-22 by MUARN : arrondi taux de change
  #Call COURDEV([F:PSD]CUR,GCUR,[F:PSD]CHGTYP,GHIDATE,[F:PSD]CHGCOE,WSTAT) From TRTDIV
  Call COURSITE([F:PSD]CUR,[F:PSD]PSHFCY,[F:PSD]CHGTYP,GHIDATE,[F:PSD]CHGCOE,WSTAT) From TRTDEV
Else
  [F:PSD]CHGCOE = 1
Endif
#----------------------------------------#
# Création ou duplication du texte ligne #
#----------------------------------------#
Gosub CHARG_TEXT_LIGNE
Return

#######################################################################
$MODIF
GMODIF = 0
Gosub MODIF From TABLEAUX
If GOK<1 : Return : Endif
#----- Réajustement si nécessaire nbre lignes dépassant le budget -----#
Gosub REAJUST_ENTETE
#----- Mise à jour statistiques entête DA -----#
SIGN=1 : Call VALSTA("PSH",SIGN) From SUBPS2 : If GOK<1 Return : Endif
Return


#######################################################################
$APRES_MOD
Gosub EFFAC_PWRKORDERS From SUBPSH : # Effacement fichier de travail
Gosub LIENS From SUBPSH1
If !GIMPORT  Affzo [PSH1]1-99 : Endif
#----- Affichage de la trace le cas échéant -----#
If !GIMPORT
  Call FERME_TRACE From LECFIC
  If GPURTRACE>0  Call LEC_TRACE From LECFIC : Endif
Endif
Raz GPURTRACE
Return


######################################################################
$AB_MODIF
#VPO 19/11/10 FQ69241 pb sur retour erreur workflow signature
If GOK=0
    If GPURMESSAGE<>""
        Call ERREUR (GPURMESSAGE)     From GESECRAN
        Raz GPURMESSAGE
    Endif
Endif
Gosub RAZ_CMMPRPNUM
Return


#----------------------------------------------------------------------#
# Traitements complémentaires ligne DA                                 #
# SIGN vaut +1 en création ou modification                             #
#      vaut -1 en annulation (TRTLIG="A") ou avant modif. (TRTLIG="M") #
#----------------------------------------------------------------------#
$VALLIG
Local Integer WRETOUR, STAT
Case SIGN
  When -1       : Goto TRTANNUL
  When  1       : Goto TRTCREATION
  When Default  : Goto FINVALLIG
Endcase

#----------------------------#
# Création ou modification + #
#----------------------------#
$TRTCREATION
#----- Ecriture des comptes et sections de la ligne de DA -----#
Call ENREG_ACCCCE(nolign-1,"[M:PSH1]LINACC","[M:PSH1]LINDSP","[M:PSH1]CCE","PSD",
&                 0,[F:PSD]PSHNUM,[F:PSD]PSDLIN,0,"",TRTLIG) From TRTX3CPT
If GOK<1  Return : Endif
#----- Si ligne soldée suppression encours et pas recréation signataire et budget -----#
If [M:PSH1]LINCLEFLG(nolign-1)=2
  If [F:PSD]WIPNUM<>"" & TRTLIG="M"
    [M:ORDK]MAJCOD = "A"
    [M:ORDK]WIPTYP = 2
    [M:ORDK]WIPNUM = [F:PSD]WIPNUM
    [M:ORDK]ITMREF = [F:PSD]ITMREF
    Call WIP From TRTWIP
    If GOK<1  Return : Endif
  Endif
  Goto FINVALLIG
Endif
#----- Mise à jour des encours uniquement si article géré en stock -----#
If [F:ITF]ITMREF<>[F:PSD]ITMREF | [F:ITF]STOFCY<>[F:PSD]PRHFCY
  Read [ITF] ITF0=[F:PSD]ITMREF;[F:PSD]PRHFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
If [F:ITF]STOMGTCOD>1
  Raz [M:ORDK]
  If TRTLIG="M"
    Read [ORD] ORD0=2;[F:PSD]WIPNUM;[F:PSD]ITMREF
    If fstat  Raz [F:ORD] : Endif
    [M:ORDK]=[F:ORD]
  Endif
  [M:ORDK]MAJCOD    = TRTLIG
  [M:ORDK]WIPTYP    = 2
  [M:ORDK]WIPSTA    = 2
  [M:ORDK]WIPNUM    = [F:PSD]WIPNUM
  [M:ORDK]ITMREF    = [F:PSD]ITMREF
  [M:ORDK]STOFCY    = [F:PSD]PRHFCY
  [M:ORDK]PJT       = [F:PSD]PJT
  [M:ORDK]BPRNUM    = [F:PSD]BPSNUM
  [M:ORDK]STRDAT    = [F:PSD]EXTORDDAT
  [M:ORDK]ENDDAT    = [F:PSD]EXTRCPDAT
  [M:ORDK]VCRTYP    = 14
  [M:ORDK]VCRNUM    = [F:PSD]PSHNUM
  [M:ORDK]VCRLIN    = [F:PSD]PSDLIN
  [M:ORDK]VCRSEQ    = 0
  [M:ORDK]EXTQTY    = [F:PSD]QTYSTU
  [M:ORDK]CPLQTY    = [F:PSD]ORDQTYSTU
  [M:ORDK]ALLQTY    = 0
  [M:ORDK]SHTQTY    = 0
  [M:ORDK]FMI       = 1
  [M:ORDK]MRPMES    = 1
  # Issue 71276 - 2015-02-27 by SR : Versions
  If dim([M:ORDK]ECCVALMAJ)> 0
   [M:ORDK]ECCVALMAJ = [F:PSD]ECCVALMAJ
   [M:ORDK]ECCVALMIN = [F:PSD]ECCVALMIN
  Endif
  # End issue 71276
  #----- Chargement pièce origine si création autrement conservation valeurs -----#
  If [M:ORDK]MAJCOD="C" | [F:ORD]WIPNUM=""
    [M:ORDK]ORIFCY    = [F:PSD]PSHFCY
    [M:ORDK]VCRTYPORI = 0
    [M:ORDK]VCRNUMORI = ""
    [M:ORDK]VCRLINORI = 0
    [M:ORDK]VCRSEQORI = 0
  Endif
  #-----
  [M:ORDK]BOMALT    = 0
  [M:ORDK]ORI       = 1
  [M:ORDK]ABBFIL    = "PSD"
  Call WIP From TRTWIP
  If GOK<1 Return : Endif
Endif
#----- Mise à jour des besoins pris "POS", "POP" et "SCF" -----#
If [M:PSH1]WQTYORDPUU(nolign-1)<>0 | [M:PSH1]WQTYORDSTU(nolign-1)<>0
  Gosub POSMAJ_PWO  From SUBPSH : If GOK<1  Return : Endif
Endif
#----- Pas de gestion de signature ou déclenchement à la création, màj pré-engagement -----#
If (GAPPPSH<2 | GPSHCMMLEV=3 | [F:PSD]LINAPPFLG>2) & GMODU(2)=2
  If TRTLIG="C"
    GBIDC2="PSD"  : # Création ligne DA
  Elsif WLINCLEFLG=2 & [F:PSD]LINCLEFLG<>2
    GBIDC2="PSD2" : # Désolde ligne DA
  Else
    GBIDC2="PSD1" : # Modification ligne DA
  Endif
  Call TRTMAJCMM([F:PSD]PSHNUM,[F:PSD]PSDLIN,0,+1,1,GBIDC2,3,STAT) From TRTACHDIV1
  If GOK<1  Return : Endif
  #----- Màj du numéro de pré-engagement sur la ligne DA -----#
  GBIDC2=[F:PSD]PSHNUM
  GBIDI2=[F:PSD]PSDLIN
  GBIDC3=[F:PSD]CMMPRPNUM
  GBIDI3=[F:PSD]FBUFLG
  Update [PSD] Where PSHNUM=GBIDC2 & PSDLIN=GBIDI2
&              With  CMMPRPNUM=GBIDC3, FBUFLG=GBIDI3, CMMPRPFLG=1
  If fstat  GOK=0 : Call FSTA("PSD") From GLOCK : Return : Endif
Endif
Goto FINVALLIG

#------------------------------#
# Annulation ou modification - #
#------------------------------#
$TRTANNUL
If TRTLIG="M"  WLINCLEFLG=[F:PSD]LINCLEFLG : Endif
#----- Suppression du pré-engagement -----#
If GMODU(2)=2 & [F:PSD]LINCLEFLG<>2
  If GAPPPSH<2 | [F:PSD]CMMPRPFLG=1
    If TRTLIG="A"
      GBIDC2="PSD"  : # Suppression ligne DA
    Elsif [M:PSH1]LINCLEFLG(nolign-1)=2 & [F:PSD]LINCLEFLG<>2
      GBIDC2="PSD2" : # Solde ligne DA
    Else
      GBIDC2="PSD1" : # Modification ligne DA
    Endif
    Call TRTMAJCMM([F:PSD]PSHNUM,[F:PSD]PSDLIN,0,-1,1,GBIDC2,3,STAT) From TRTACHDIV1
    If GOK<1 Return : Endif
  Endif
Endif
If TRTLIG="A"
  #----- Suppression comptes et sections de la ligne de commande -----#
  Call ENREG_ACCCCE(0,"","","","PSD",0,[F:PSD]PSHNUM,[F:PSD]PSDLIN,0,"","A") From TRTX3CPT
  If GOK<1  Return : Endif
  #----- Suppression du texte ligne si nécessaire -----#
  If left$([F:PSD]LINTEX,3)="PSD"
    Local Integer WRETOUR
    Call SUP_CLOB([F:PSD]LINTEX,WRETOUR) From TRTX3TEX
  Endif
Elsif TRTLIG="M"
  #----- Cas particulier où l'on modifie le texte en le supprimant -----#
  If [M:PSH1]LINTEX(nolign-1)="" & left$([F:PSD]LINTEX,3)="PSD"
    Call SUP_CLOB([F:PSD]LINTEX,WRETOUR) From TRTX3TEX
  Endif
Endif
#----- Si ligne soldée pas de mise a jour
If [F:PSD]LINCLEFLG=2  Goto FINVALLIG : Endif
#----- Suppression de l'encours -----#
If [F:PSD]WIPNUM<>"" & TRTLIG="A"
  [M:ORDK]MAJCOD = "A"
  [M:ORDK]WIPTYP = 2
  [M:ORDK]WIPNUM = [F:PSD]WIPNUM
  [M:ORDK]ITMREF = [F:PSD]ITMREF
  Call WIP From TRTWIP
  If GOK<1 Return : Endif
Endif
#----- Positionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
If GAPPPSH>1 & GPSHAPPHEA<2
  #----- Solde/désolde ligne (UPDFLG=2) et totalement signé, ne rien faire ! -----#
  # Issue 112933 - 2015-12-04 by SR : Modification zones impactantes
  #If [M:PSH1]UPDFLG(nolign-1)=1 & [M:PSH1]WAPPFLG(nolign-1) = 2 | [M:PSH1]LINAPPFLG(nolign-1)<3 | TRTLIG="A"
  If [M:PSH1]APPUPDFLG(nolign-1)=1 | [M:PSH1]LINAPPFLG(nolign-1)<3 | TRTLIG="A"
    If dim(WMOTIF)<1  Local Char WMOTIF(30) : Endif
    If TRTLIG="A"
      WMOTIF=mess(653,197,1)
    Elsif [M:PSH1]LINCLEFLG(nolign-1)=2
      WMOTIF=mess(654,197,1)
    Else
      WMOTIF=mess(652,197,1)
    Endif
    Call ANNULE_SUIVI("PSD",WMOTIF,1,WRETOUR) From TRTACHDIV1
    If GOK<1  Return : Endif
  Endif
Endif

#--------------#
# Fin de ligne #
#--------------#
$FINVALLIG
#----- Mise à jour statistiques ligne DA -----#
Call VALSTA("PSD",SIGN) From SUBPS2
If GOK<1  Return : Endif
Return


#######################################################################
$VERF_ANU
GMESSAGE = ""
#-------------------------------------------------------#
#on ne peut supprimer la DA si signée ou commandée      #
#de même si une ligne est signée ou commandée ou soldée #
#et même si une ligne est partiellement signée          #
#-------------------------------------------------------#
If [F:PSH]ORDFLG = 2 | [F:PSH]CLEFLG = 2
&   | [F:PSH]ORDLINNBR <> 0 | [F:PSH]CLELINNBR <> 0
      If [F:PSH]ORDLINNBR <> 0 : GMESSAGE = mess(20,194,1) : Endif
      If [F:PSH]CLELINNBR <> 0 : GMESSAGE = mess(21,194,1) : Endif
      If [F:PSH]ORDFLG = 2     : GMESSAGE = mess(23,194,1) : Endif
      If [F:PSH]CLEFLG = 2     : GMESSAGE = mess(24,194,1) : Endif
      If GMESSAGE <> "" : GERR = 1 : OK = 0 : Return : Endif
Endif
#--- DA signée
If [F:PSH]APPFLG = 3 : GMESSAGE = mess(22,194,1) : GERR = 1 : OK = 0 : Return : Endif
#------------------------------#
# verification sur les détails #
# suppression possible si signature auto sur la ligne
#------------------------------#
Filter [PSD] Where PSHNUM = [F:PSH]PSHNUM
For [PSD] PSD0
  If [F:PSD]LINAPPFLG > 1 & [F:PSD]LINAPPFLG < 4
    GMESSAGE = mess(18,194,1)
    GERR = 1
    OK = 0
    Break
  Endif
Next
Filter [PSD]

Return


#######################################################################
$ANNULE
#----- Supression des textes entête et pied -----#
Local Integer WRETOUR
If left$([F:PSH]TEX1,3)="PSH"
  Call SUP_CLOB([F:PSH]TEX1,WRETOUR) From TRTX3TEX
Endif
If left$([F:PSH]TEX2,3)="PSH"
  Call SUP_CLOB([F:PSH]TEX2,WRETOUR) From TRTX3TEX
Endif
#-----
GMODIF=0
Gosub ANNULE From TABLEAUX
If GOK<1  Return : Endif
#----- Positionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
If GAPPPSH>1 & GPSHAPPHEA=2
  Call ANNULE_SUIVI("PSH",mess(653,197,1),1,WRETOUR) From TRTACHDIV1
  If GOK<1  Return : Endif
Endif
#----- Mise à jour statistiques entête DA -----#
SIGN=-1 : Call VALSTA("PSH",SIGN) From SUBPS2 : If GOK<1 Return : Endif
Return


#######################################################################
$ABANDON
Gosub EFFAC_PWRKORDERS From SUBPSH
#----- Suppression des textes après un abandon -----#
Local Integer I, WRETOUR
#----- Suppression texte entête et pied -----#
If GREP="D"
  If left$([M:PSH1]TEX1,3)="PSH"
    Call SUP_CLOB([M:PSH1]TEX1,WRETOUR) From TRTX3TEX
  Endif
  If left$([M:PSH1]TEX2,3)="PSH"
    Call SUP_CLOB([M:PSH1]TEX2,WRETOUR) From TRTX3TEX
  Endif
Endif
#----- Suppression des textes ligne -----#
For I=0 To [M:PSH1]NBLIG-1
  If left$([M:PSH1]LINTEX(I),3)="PSD" & [M:PSH1]CREFLG(I)=0
    Call SUP_CLOB([M:PSH1]LINTEX(I),WRETOUR) From TRTX3TEX
  Endif
Next I
#-----
Call RAZ_CLOB From ACLOB
Return


$FERME
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB
#-----
If GFONC1="GESPSH"
  Gosub EFFAC_PWRKORDERS From SUBPSH  : # Effacement fichier travail sauf si tunnel
  Raz GCONSDIA, GORITITCOL
Endif
#----- Effacement icone texte -----#
Call RESET_IMAGE (4) From GESECRAN
#----- Suppression de la trace vide si nécessaire -----#
If !GIMPORT & GWEBSERV<>1
  Call FERME_TRACE  From LECFIC
  If GPURTRACE>0
    Call SUPP_TRACE From LECFIC
  Endif
Endif
GPURTRACE=0
#-----
If GFONC1 = "GESPSH"  Raz GMENBOUT : Endif
If dim(GPSH_VERROU)>0  Kill GPSH_VERROU : Endif
Return


########################################################################
#####################    Subprog   #####################################
########################################################################
Subprog MAJPSH
# Issue 92916 - 2013-10-07 by SR : ajout de WSUPLIG
Local Integer STAT, I, WSUPLIG
# Issue 113581 - 2016-02-15 by SR
Local Integer WCRELIG
#-------------------------------------------------------------------#
# calcul du total de la DA en devise comptable Gcur                 #
# si la ligne a une devise <> il faut convertir le mt               #
#                                                                   #
# mise à jour des indicateurs entete                                #
#-------------------------------------------------------------------#
GWAPPLIN = 0
[F:PSH]TOTPRQ = 0
[F:PSH]ORDFLG = 1
[F:PSH]CLEFLG = 1
GBIDI1 = 1
# Issue 92916 - 2013-10-07 by SR : initialisation de WSUPLIG
WSUPLIG = 1
# Issue 113581 - 2016-02-15 by SR
#If [F:PSH]APPLINNBR > [F:PSH]LINNBR : WSUPLIG = 2 : Endif
If !find(GREP,"C","D") & [M:PSH0]ANCLINNBR > [F:PSH]LINNBR : WSUPLIG = 2 : Endif

#
#----- Màj nbre de lignes Soldées, commandées et en dépassement de budget -----#
Raz [F:PSH]APPLINNBR, [F:PSH]CLELINNBR, [F:PSH]ORDLINNBR, [F:PSH]FBULINNBR
# Issue 113581 - 2016-02-15 by SR
Raz WCRELIG

For I=0 To [M:PSH1]NBLIG-1
  If [M:PSH1]CUR(I)<>GCUR
    Call CONVERT([M:PSH1]CUR(I),GCUR,GCUR,[M:PSH1]CHGTYP(I),datesyst,[M:PSH1]LINAMT(I),
&                GBIDD2,STAT) From TRTDEV
  Else
    GBIDD2=[M:PSH1]LINAMT (I)
  Endif
  [F:PSH]TOTPRQ+=GBIDD2
  #----- Indicateurs solde - signée - commandée -----#
  If [M:PSH1]LINAPPFLG(I)=3 | [M:PSH1]LINAPPFLG(I)=4 | [M:PSH1]LINAPPFLG(I)=5
    [F:PSH]APPLINNBR+=1
    If [M:PSH1]LINAPPFLG(I)=5
      GWAPPLIN+=1
    Endif
  Elsif [M:PSH1]LINAPPFLG(I)=2
    GBIDI1=2
  Endif
  If [M:PSH1]LINCLEFLG(I)=2  [F:PSH]CLELINNBR+=1 : Endif
  If [M:PSH1]LINORDFLG(I)=2  [F:PSH]ORDLINNBR+=1 : Endif
  If [M:PSH1]FBUFLG(I)=2     [F:PSH]FBULINNBR+=1 : Endif
  # Issue 113581 - 2016-02-15 by SR
  If [M:PSH1]CREFLG(I) = 0 : WCRELIG += 1 : Endif

Next I
#------
If [F:PSH]ORDLINNBR >= [F:PSH]LINNBR
  [F:PSH]ORDFLG = 2
Endif
If [F:PSH]CLELINNBR >= [F:PSH]LINNBR
  [F:PSH]CLEFLG = 2
Endif
If [F:PSH]APPLINNBR >= [F:PSH]LINNBR
  If GAPPPSH <= 1
    [F:PSH]APPFLG = 4
  Elsif GWAPPLIN = [F:PSH]LINNBR
    [F:PSH]APPFLG = 5
  Else
    [F:PSH]APPFLG = 3
  Endif
Elsif [F:PSH]APPLINNBR <> 0
  If GAPPPSH <= 1
    [F:PSH]APPFLG = 4
  Elsif GWAPPLIN = [F:PSH]LINNBR
    [F:PSH]APPFLG = 5
  Else
    [F:PSH]APPFLG = 2
  Endif
Else
  [F:PSH]APPFLG = GBIDI1
Endif
#-----
 If GAPPPSH>1
  # Issue 121687 - 2017-02-24 by SR : En création/Dupli ou en modif si DA au moins en partie signée
  # Issue X3-77157 - 2018-02-26 by SR : Retour arrière
  #If find(GREP,"C","D") | [F:PSH]APPFLG <> 1
    #----- Solde/désolde ligne (UPDFLG=2) et totalement signé, ne rien faire ! -----#
    # Issue 92916 - 2013-10-07 by SR : Tester si DA complétement signée à l'entête mais manque des lignes
    # Issue 93463 - 2014-01-27 by SR : Tester si DA complétement signée à l'entête et modif de zones entêtes impactantes
    # Issue 112933 - 2015-12-04 by SR : Prise en compte des modif impactantes ou non sur la ligne
    # Issue 113509 - 2016-01-07 by SR : Test UPDFLG = 2 inutile incorrect dans ce contexte
    #  If [F:PSH]CLEFLG<>2 & (find(1,[M:PSH1]UPDFLG(0..[M:PSH1]NBLIG-1)) | ([F:PSH]APPFLG<3 & GPSHAPPHEA=2)
    #If [F:PSH]CLEFLG<>2 & (find(1,[M:PSH1]APPUPDFLG(0..[M:PSH1]NBLIG-1)) | (find(2,[M:PSH1]APPUPDFLG(0..[M:PSH1]NBLIG-1)) & [F:PSH]APPFLG<3 & GPSHAPPHEA=2)
  # Issue 113581 - 2016-02-15 by SR : Exploitation de WCRELIG et test valeur APPFLG <=3
  #  If [F:PSH]CLEFLG<>2 & (find(1,[M:PSH1]APPUPDFLG(0..[M:PSH1]NBLIG-1)) | ([F:PSH]APPFLG<3 & GPSHAPPHEA=2)
  #&    | ([F:PSH]APPFLG=3 & GPSHAPPHEA = 2  & WSUPLIG = 2 )
  #&    | ([F:PSH]APPFLG=3 & GPSHAPPHEA = 2  & [M:PSH0]WMODIF = 2))
  If [F:PSH]CLEFLG<>2 & (find(1,[M:PSH1]APPUPDFLG(0..[M:PSH1]NBLIG-1))
&    | ([F:PSH]APPFLG<=3 & GPSHAPPHEA = 2  & WCRELIG <> 0 )
&    | ([F:PSH]APPFLG<=3 & GPSHAPPHEA = 2  & WSUPLIG = 2 )
&    | ([F:PSH]APPFLG<=3 & GPSHAPPHEA = 2  & [M:PSH0]WMODIF = 2))
  # End issue 113581
      [F:PSH]APPFLG=0
    Endif
  #Endif
  # End issue 121687
  # End issue X3-77157
Else
  [F:PSH]APPFLG=4
Endif
If [F:PSH]CLEFLG=2 & [F:PSH]APPFLG=0
  [F:PSH]APPFLG=1
Endif
End

#----------------------------------------------------------------------#
#----------------------------------------------------------------------#
Subprog DUPLI(NUMLIG)
Value Integer NUMLIG
Local Integer I
#------------------------------------------------------#
# duplication ligne                                    #
# la ligne que l'on duplique se trouve avant la ligne  #
# dupli sur ligne vide on prend ligne précédente       #
#------------------------------------------------------#
[M:PSH1]ITMREF    (NUMLIG) = [M:PSH1]ITMREF    (NUMLIG-1)
[M:PSH1]ITMDES    (NUMLIG) = [M:PSH1]ITMDES    (NUMLIG-1)
[M:PSH1]ITMDES1   (NUMLIG) = [M:PSH1]ITMDES1   (NUMLIG-1)
[M:PSH1]PRHFCY    (NUMLIG) = [M:PSH1]PRHFCY    (NUMLIG-1)
[M:PSH1]EXTRCPDAT (NUMLIG) = [M:PSH1]EXTRCPDAT (NUMLIG-1)
[M:PSH1]PUU       (NUMLIG) = [M:PSH1]PUU       (NUMLIG-1)
[M:PSH1]QTYPUU    (NUMLIG) = [M:PSH1]QTYPUU    (NUMLIG-1)
[M:PSH1]STU       (NUMLIG) = [M:PSH1]STU       (NUMLIG-1)
[M:PSH1]QTYSTU    (NUMLIG) = [M:PSH1]QTYSTU    (NUMLIG-1)
[M:PSH1]BPSNUM    (NUMLIG) = [M:PSH1]BPSNUM    (NUMLIG-1)
[M:PSH1]PJT       (NUMLIG) = [M:PSH1]PJT       (NUMLIG-1)
[M:PSH1]EXTORDDAT (NUMLIG) = [M:PSH1]EXTORDDAT (NUMLIG-1)
[M:PSH1]NETPRI    (NUMLIG) = [M:PSH1]NETPRI    (NUMLIG-1)
[M:PSH1]LINAMT    (NUMLIG) = [M:PSH1]LINAMT    (NUMLIG-1)
[M:PSH1]VACBPR    (NUMLIG) = [M:PSH1]VACBPR    (NUMLIG-1)
[M:PSH1]VACTYP    (NUMLIG) = [M:PSH1]VACTYP    (NUMLIG-1)
[M:PSH1]CHGTYP    (NUMLIG) = [M:PSH1]CHGTYP    (NUMLIG-1)
[M:PSH1]CUR       (NUMLIG) = [M:PSH1]CUR       (NUMLIG-1)
[M:PSH1]OFS       (NUMLIG) = [M:PSH1]OFS       (NUMLIG-1)
# Issue 71276 - 2015-03-27 by SR : Versions
If dim([M:PSH1]ECCVALMAJ)>0
  [M:PSH1]ECCVALMAJ(NUMLIG) = [M:PSH1]ECCVALMAJ(NUMLIG-1)
Endif
If dim([M:PSH1]ECCVALMIN)>0
  [M:PSH1]ECCVALMIN(NUMLIG) = [M:PSH1]ECCVALMIN(NUMLIG-1)
Endif
# End issue 71276
# Issue 112754 - 2016-12-09 by SR : Services
[M:PSH1]ITMKND    (NUMLIG) = [M:PSH1]ITMKND    (NUMLIG-1)
#----- Comptes -----#
For I=1 To GNBCOA
  Assign "[M:PSH1]LINACC"+num$(I)+"(NUMLIG)" With evalue("[M:PSH1]LINACC"+num$(I)+"(NUMLIG-1)")
Next I
#-----
[M:PSH1]LINPURTYP (NUMLIG) = [M:PSH1]LINPURTYP (NUMLIG-1)
#----- Sections analytiques -----#
For I=1 To GNBDIE
  Assign "[M:PSH1]CCE"+num$(I)+"(NUMLIG)" With evalue("[M:PSH1]CCE"+num$(I)+"(NUMLIG-1)")
Next I
#----- Code taxes -----#
[M:PSH1]VAT1      (NUMLIG) = [M:PSH1]VAT1      (NUMLIG-1)
[M:PSH1]VAT2      (NUMLIG) = [M:PSH1]VAT2      (NUMLIG-1)
[M:PSH1]VAT3      (NUMLIG) = [M:PSH1]VAT3      (NUMLIG-1)
If func AFNC.ACTIV("PTX") & dim([M:PSH1]TAXRCP)>0
  [M:PSH1]TAXRCP     (NUMLIG) = [M:PSH1]TAXRCP     (NUMLIG-1)
  [M:PSH1]TAXISS     (NUMLIG) = [M:PSH1]TAXISS     (NUMLIG-1)
  [M:PSH1]TAXOTH1    (NUMLIG) = [M:PSH1]TAXOTH1    (NUMLIG-1)
  [M:PSH1]TAXOTH2    (NUMLIG) = [M:PSH1]TAXOTH2    (NUMLIG-1)
Endif
#-----
[M:PSH1]GROPRI    (NUMLIG) = [M:PSH1]GROPRI    (NUMLIG-1)
[M:PSH1]PRIREN    (NUMLIG) = [M:PSH1]PRIREN    (NUMLIG-1)
If dim([M:PSH1]DISCRGREN1)>0
  [M:PSH1]DISCRGREN1 (NUMLIG) = [M:PSH1]DISCRGREN1 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGREN2)>0
  [M:PSH1]DISCRGREN2 (NUMLIG) = [M:PSH1]DISCRGREN2 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGREN3)>0
  [M:PSH1]DISCRGREN3 (NUMLIG) = [M:PSH1]DISCRGREN3 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGREN4)>0
  [M:PSH1]DISCRGREN4 (NUMLIG) = [M:PSH1]DISCRGREN4 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGREN5)>0
  [M:PSH1]DISCRGREN5 (NUMLIG) = [M:PSH1]DISCRGREN5 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGREN6)>0
  [M:PSH1]DISCRGREN6 (NUMLIG) = [M:PSH1]DISCRGREN6 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGREN7)>0
  [M:PSH1]DISCRGREN7 (NUMLIG) = [M:PSH1]DISCRGREN7 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGREN8)>0
  [M:PSH1]DISCRGREN8 (NUMLIG) = [M:PSH1]DISCRGREN8 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGREN9)>0
  [M:PSH1]DISCRGREN9 (NUMLIG) = [M:PSH1]DISCRGREN9 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGVAL1)>0
  [M:PSH1]DISCRGVAL1 (NUMLIG) = [M:PSH1]DISCRGVAL1 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGVAL2)>0
  [M:PSH1]DISCRGVAL2 (NUMLIG) = [M:PSH1]DISCRGVAL2 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGVAL3)>0
  [M:PSH1]DISCRGVAL3 (NUMLIG) = [M:PSH1]DISCRGVAL3 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGVAL4)>0
  [M:PSH1]DISCRGVAL4 (NUMLIG) = [M:PSH1]DISCRGVAL4 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGVAL5)>0
  [M:PSH1]DISCRGVAL5 (NUMLIG) = [M:PSH1]DISCRGVAL5 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGVAL6)>0
  [M:PSH1]DISCRGVAL6 (NUMLIG) = [M:PSH1]DISCRGVAL6 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGVAL7)>0
  [M:PSH1]DISCRGVAL7 (NUMLIG) = [M:PSH1]DISCRGVAL7 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGVAL8)>0
  [M:PSH1]DISCRGVAL8 (NUMLIG) = [M:PSH1]DISCRGVAL8 (NUMLIG-1)
Endif
If dim([M:PSH1]DISCRGVAL9)>0
  [M:PSH1]DISCRGVAL9 (NUMLIG) = [M:PSH1]DISCRGVAL9 (NUMLIG-1)
Endif
#-----
[M:PSH1]WQTYORDSTU (NUMLIG)= 0
[M:PSH1]WQTYORDPUU (NUMLIG)= 0
[M:PSH1]BLOMSG(NUMLIG)     = 0
[M:PSH1]FBUFLG(NUMLIG)     = 1
[M:PSH1]PQHNUM (NUMLIG)    = ""
#----- Duplication du texte si nécessaire -----#
[M:PSH1]LINTEX(NUMLIG)=[M:PSH1]LINTEX(NUMLIG-1)
If left$([M:PSH1]LINTEX(NUMLIG),3)="PSD"
  Local Integer WRETOUR
  Call DUP_CLOB("PSD",[M:PSH1]LINTEX(NUMLIG),WRETOUR) From TRTX3TEX
  If WRETOUR<1  Raz [M:PSH1]LINTEX(NUMLIG) : Endif
Endif
#-----
[M:PSH1]PPDLIN (NUMLIG)    = 0
[M:PSH1]LINCLEFLG (NUMLIG) = 1
If GAPPPSH>1
  [M:PSH1]LINAPPFLG (NUMLIG) = 1
Else
  [M:PSH1]LINAPPFLG (NUMLIG) = 4
Endif
[M:PSH1]LINORDFLG (NUMLIG) = 1
[M:PSH1]PRIFLG (NUMLIG)    = 2
[M:PSH1]CREFLG (NUMLIG)    = 0
[M:PSH1]UPDFLG (NUMLIG)    = 0
[M:PSH1]CMMPRPTAX (NUMLIG) = max(GPURCMMTAX,1)
[M:PSH1]CMMPRPNUM (NUMLIG) = ""
#-----
End


###################################################
# Solde ou désolde d'une ligne de demande d'achat #
###################################################
Subprog SOLDE (NUMLIG)
Value Integer NUMLIG
#--------------------------------------------------------#
# ligne déjà soldée avec possibilité de la réactiver     #
# attention au cas ligne commandée                       #
# si la ligne a déjà fait l'objet d'une commande (totale)#
# on ne peut pas dé - solder                             #
# de plus on ne peut solder en creation et ajout de ligne#
#--------------------------------------------------------#
Local Integer WRETOUR
If GREP = "C" | GREP = "D" | [M:PSH1]CREFLG (NUMLIG-1) = 0 : End : Endif
If [M:PSH1]LINCLEFLG (NUMLIG-1) = 2
  #--------desolde ligne ------#
  Call OUINON(mess(43,194,1),WRETOUR) From GESECRAN
  If WRETOUR = 1 : End :  Endif
  [M:PSH1]LINCLEFLG (NUMLIG-1) = 1
  #---------------------------------------------------------------#
  # Dans le cas d'un solde ou désolde de ligne totalement signée, #
  #     il ne faut pas redéclencher le circuit de signature       #
  #---------------------------------------------------------------#
  If find(1,[M:PSH1]UPDFLG(0..[M:PSH1]NBLIG-1)) | [M:PSH1]LINAPPFLG(NUMLIG-1)<3
    If GAPPPSH>1
      [M:PSH1]LINAPPFLG(NUMLIG-1)=1
    Else
      [M:PSH1]LINAPPFLG(NUMLIG-1)=4
    Endif
  Endif
  #----- Mise à jour indicateur dépassement de budget -----#
  If GMODU(2)=2 : # Test module comptabilité actif
    Call CTLBUD (WRETOUR) From SUBPSH1
    If WRETOUR<1
      [M:PSH1]FBUFLG(NUMLIG-1)=2
      #VPO 08/02/11 71412 : message à tort suite appel CTLBUD (ex: en dupli)
      WRETOUR=1 : Raz GMESSAGE
    Else
      [M:PSH1]FBUFLG(NUMLIG-1)=1
    Endif
  Endif
  #-----
  If [M:PSH1]UPDFLG(NUMLIG-1)=0  [M:PSH1]UPDFLG(NUMLIG-1)=2 : Endif
  If !GIMPORT Affzo [PSH1]LINCLEFLG (NUMLIG-1) : Endif
Else
  #------ solde ligne --------#
  [M:PSH1]LINCLEFLG (NUMLIG-1) = 2
  If [M:PSH1]UPDFLG(NUMLIG-1)=0  [M:PSH1]UPDFLG(NUMLIG-1)=2 : Endif
  If !GIMPORT Affzo [PSH1]LINCLEFLG (NUMLIG-1) : Endif
Endif
End


#-------------------------------------#
# Relecture des tables pour lignes DA #
#-------------------------------------#
$RELECTURE
#----- Relecture de l'article -----#
If [F:ITM]ITMREF<>[F:PSD]ITMREF
  Read [ITM] ITM0=[F:PSD]ITMREF : If fstat  Raz [F:ITM] : Endif
Endif
#----- Relecture du fournisseur -----#
If [F:PSD]BPSNUM=""
  Raz [F:BPS]
Elsif [F:BPS]BPSNUM<>[F:PSD]BPSNUM
  Read [BPS] BPS0=[F:PSD]BPSNUM : If fstat  Raz [F:BPS] : Endif
Endif
#----- Relecture de l'article - fournisseur -----#
If [F:PSD]BPSNUM=""
  Raz  [F:ITP]
Elsif [F:ITP]ITMREF<>[F:PSD]ITMREF | [F:ITP]BPSNUM<>[F:PSD]BPSNUM
  Read [ITP] ITP0=[F:PSD]ITMREF;[F:PSD]BPSNUM : If fstat  Raz [F:ITP] : Endif
Endif
#----- Relecture de l'article - site de la demande -----#
If [F:ITF]ITMREF<>[F:PSD]ITMREF | [F:ITF]STOFCY<>[F:PSD]PSHFCY
  Read [ITF] ITF0=[F:PSD]ITMREF;[F:PSD]PSHFCY : If fstat  Raz [F:ITF] : Endif
Endif
Return


#######################################
# Contrôle du budget à la ligne de DA #
#######################################
Subprog CTLBUD (OK)
Variable Integer OK
#-----
OK=1
#----- Test présence du module compta et si gestion des pré-engagements -----#
If GMODU(2)<>2 | GNBDIE<1  | GPURCMMPRP<>2  End : Endif
#-----
Local Integer NOL : NOL=nolign-1
Local Char    WCPTANA(GLONGAC)
#----- Initialisation des comptes de la ligne si nécessaire -----#
If [M:PSH1]LINACC1(NOL)="" & [M:PSH1]LINACC2(NOL)="" & [M:PSH1]LINACC3(NOL)=""
  Call INIT_COMPTES_LIGNE(NOL) From SUBPSH
Endif
#----- Test si pas de compte ou pas de compte pour la nature analytique -----#
If [M:PSH1]LINACC1(NOL)="" & [M:PSH1]LINACC2(NOL)="" & [M:PSH1]LINACC3(NOL)=""
  GMESSAGE=mess(36,194,1) : GERR=1 : End
Else
  Call RECH_ACC(2,"[M:PSH1]LINACC",NOL,WCPTANA) From TRTX3CPT
  If WCPTANA=""  End : Endif
Endif
#-----
Local Integer STAT, I
Local Char    TBCCE (GLONCCE)(1..max(GNBDIE,GOPTCANA))
Local Char    TBDIE2(GLONDIE)(1..max(GNBDIE,GOPTCANA))
Local Char    TBCCE2(GLONCCE)(1..max(GNBDIE,GOPTCANA))
Local Decimal WQUANTITE
Local Decimal WQUANTITEOLD : #VPO 09/11/10 68973
Local Decimal WCOEUOM
#-----
For I=1 To GNBDIE : TBCCE(I)=evalue("[M:PSH1]CCE"+num$(I)+"(NOL)") : Next I
#----- Filtrage des codes et sections analytiques sur référentiel analytique -----#
Call SETCCEAXE(GSOCIETE,GTYPANA,GDIE,TBCCE,TBDIE2,TBCCE2) From CPTDIV
#----- Récupération unité oeuvre -----#
WQUANTITE=[M:PSH1]QTYPUU(NOL)
If [F:GAC]UOM<>[M:PSH1]PUU(NOL)
  If [F:GAC]UOM=[M:PSH1]STU(NOL)
    WQUANTITE=[M:PSH1]QTYSTU(NOL)
  Else
    Call PCAL_QTY([M:PSH1]QTYPUU(NOL),[M:PSH1]PUU(NOL),WQUANTITE,[F:GAC]UOM,
&                   [M:PSH1]ITMREF(NOL),[M:PSH1]BPSNUM(NOL),1,WCOEUOM) From TRTACHQTE1
    If [F:TCO]UOM1="" & [F:TCO]COEUOM=1
      Call PCAL_QTY([M:PSH1]QTYSTU(NOL),[M:PSH1]STU(NOL),WQUANTITE,[F:GAC]UOM,
&                   [M:PSH1]ITMREF(NOL),[M:PSH1]BPSNUM(NOL),1,WCOEUOM) From TRTACHQTE1
    Endif
  Endif
Endif
#-----
#VPO 09/11/10 68973 on stocke LINAMT pour CTLBUD et affect FBUFLG
If [M:PSH1]CREFLG(NOL)=0 | [M:PSH1]CMMPRPNUM(NOL)=""
Call BUDGET([M:PSH1]EXTRCPDAT(NOL),GFINRSP,GTYPANA,[M:PSH1]CUR(NOL),WCPTANA,
&           TBDIE2,TBCCE2,[M:PSH1]LINAMT(NOL),WQUANTITE,0,OK,GMESSAGE)  From CPTBUD
Else
    WQUANTITEOLD=[M:PSH1]QTYPUUOLD(NOL)
    If [F:GAC]UOM<>[M:PSH1]PUU(NOL)
      If [F:GAC]UOM=[M:PSH1]STU(NOL)
        WQUANTITEOLD=[M:PSH1]QTYSTUOLD(NOL)
      Else
        Call PCAL_QTY([M:PSH1]QTYPUUOLD(NOL),[M:PSH1]PUU(NOL),WQUANTITEOLD,[F:GAC]UOM,
&                   [M:PSH1]ITMREF(NOL),[M:PSH1]BPSNUM(NOL),1,WCOEUOM) From TRTACHQTE1
        If [F:TCO]UOM1="" & [F:TCO]COEUOM=1
          Call PCAL_QTY([M:PSH1]QTYSTUOLD(NOL),[M:PSH1]STU(NOL),WQUANTITEOLD,[F:GAC]UOM,
&                   [M:PSH1]ITMREF(NOL),[M:PSH1]BPSNUM(NOL),1,WCOEUOM) From TRTACHQTE1
        Endif
      Endif
    Endif

    Call BUDGET([M:PSH1]EXTRCPDAT(NOL),GFINRSP,GTYPANA,[M:PSH1]CUR(NOL),WCPTANA,
&           TBDIE2,TBCCE2,[M:PSH1]LINAMT(NOL)-[M:PSH1]LINAMTOLD(NOL),WQUANTITE-WQUANTITEOLD,0,OK,GMESSAGE)  From CPTBUD

Endif
End


###########################
# Visualisation du budget #
###########################
Subprog BUDVISU
#----- Test présence du module compta et si gestion des pré-engagements -----#
If GMODU(2)<>2 | GNBDIE<1  End : Endif
#-----
Local Integer NOL : NOL=nolign-1
Local Char    WCPTANA(GLONGAC)
#----- Initialisation des comptes de la ligne si nécessaire -----#
If [M:PSH1]LINACC1(NOL)="" & [M:PSH1]LINACC2(NOL)="" & [M:PSH1]LINACC3(NOL)=""
  Call INIT_COMPTES_LIGNE(NOL) From SUBPSH
Endif
#----- Test si pas de compte ou pas de compte pour la nature analytique -----#
If [M:PSH1]LINACC1(NOL)="" & [M:PSH1]LINACC2(NOL)="" & [M:PSH1]LINACC3(NOL)=""
  End
Else
  Call RECH_ACC(2,"[M:PSH1]LINACC",NOL,WCPTANA) From TRTX3CPT
  If WCPTANA=""  End : Endif
Endif
#-----
Local Integer I
Local Char    TBCCE (GLONCCE)(1..max(GNBDIE,GOPTCANA))
Local Char    TBDIE2(GLONDIE)(1..max(GNBDIE,GOPTCANA))
Local Char    TBCCE2(GLONCCE)(1..max(GNBDIE,GOPTCANA))
#-----
For I=1 To GNBDIE : TBCCE(I)=evalue("[M:PSH1]CCE"+num$(I)+"(NOL)") : Next I
#----- Filtrage des codes et sections analytiques sur référentiel analytique -----#
Call SETCCEAXE(GSOCIETE,GTYPANA,GDIE,TBCCE,TBDIE2,TBCCE2) From CPTDIV
#-----
Call VISU([M:PSH1]EXTRCPDAT(NOL),GFINRSP,GTYPANA,WCPTANA,TBCCE2) From CPTBUD
End


#--------------------------------------#
# Chargement des textes entête et pied #
#--------------------------------------#
$CHARG_TEXT_ENTETE
If [M:PSH1]TEX1<>""
  If left$([M:PSH1]TEX1,3)="PSH"
    Call CRE_CLOB([M:PSH1]TEX1,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif left$([M:PSH1]TEX1,3)<>"BPS"
    Call DUP_CLOB("PSH",[M:PSH1]TEX1,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:PSH]TEX1=[M:PSH1]TEX1
Endif
If [M:PSH1]TEX2<>""
  If left$([M:PSH1]TEX2,3)="PSH"
    Call CRE_CLOB([M:PSH1]TEX2,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif left$([M:PSH1]TEX2,3)<>"BPS"
    Call DUP_CLOB("PSH",[M:PSH1]TEX2,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:PSH]TEX2=[M:PSH1]TEX2
Endif
Return


#---------------------------------#
# Chargement du texte de la ligne #
#---------------------------------#
$CHARG_TEXT_LIGNE
If [M:PSH1]LINTEX(nolign-1)<>""
  If left$([M:PSH1]LINTEX(nolign-1),3)="PSD"
    Call CRE_CLOB([M:PSH1]LINTEX(nolign-1),GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif !find(left$([M:PSH1]LINTEX(nolign-1),3),"ITM","ITP")
    Call DUP_CLOB("PSD",[M:PSH1]LINTEX(nolign-1),GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:PSD]LINTEX=[M:PSH1]LINTEX(nolign-1)
Endif
Return


#-----------------------------------------------------------------#
# Mise à jour du nbre de lignes dépassant le budget si nécessaire #
#-----------------------------------------------------------------#
$REAJUST_ENTETE
If dim(I)<1       Local Integer I        : Endif
If dim(WFBUNBR)<1 Local Shortint WFBUNBR : Endif
Raz WFBUNBR
For I=0 To [M:PSH1]NBLIG-1
    If [M:PSH1]FBUFLG(I)=2 WFBUNBR+=1 : Endif
Next I
If [F:PSH]FBULINNBR=WFBUNBR  Return : Endif
#-----
Update [PSH] Where PSHNUM=[M:PSH0]PSHNUM With FBULINNBR=WFBUNBR
If fstat  GOK=0 : Call FSTA("PSH") From GLOCK : Endif
[F:PSH]FBULINNBR=WFBUNBR : # La classe [F] n'est pas màj par l'Update
Return


#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & (dim([M:PSH1]LINACC1)>0 | dim([M:PSH1]CCE1)>0)
  Local Char BASPAG(10)
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WE2"+GPTRNUM+"1"
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:PSH1]NBLIG=0
    [M:PSH1]NBLIG=1 : Affzo [PSH1]5 : Effzo [PSH1]5
  Endif
  #-----
Endif
Raz GSOC_UPDFLG
Return


#-------------------------------------------------#
# Il faut charger la societe juridique par defaut #
# ainsi que le site financier et les parametres   #
# Rem  si le site est financier -> FINRSPFCY = "" #
# ----------------------------------------------- #
# rechargement société juridique   Gsociete       #
# rechargement du site financier   Gfinrsp        #
# rechargement la devise societe   Gcur           #
# initialisation site reception    grcpfcy        #
#-------------------------------------------------#
$CHARG_PARAM
If dim(OK)<1      Local Integer OK         : Endif
If dim(PARAMA)<1  Local Char    PARAMA(10) : Endif
#-----
Call DEFSITE     (GFCY) From TRTACHDEF1
Call DEFRCPFCY   (GFCY) From TRTACHDEF1
Call DEFBUD("PSH",GFCY) From TRTACHDEF1
Call GLOBVAR     (GFCY) From WWGLOBACH
#----- Test présence du module compta -----#
If GMODU(2)=2
  Call GLOBVAR(GFINRSP) From WWGLOBBUD
Endif
#----- Chargement des globales référentiels, comptes et sections de la société -----#
Call GETCPY(GFCY,"PTR",2,GPTRNUM) From TRTX3CPT
#----- Lecture des affectations compteur si changement société -----#
If GSOC_UPDFLG
  #----- Compteur des demandes d'achat -----#
  Call LECTCA(6,OK) From SUBTCA
  If fstat | !OK
    GERR=1 : GMESSAGE=mess(64,199,1) : OK=0 : Return
  Endif
  GMANCOU=[F:TCA]MANCOU(1) : GCODNUM=[F:TCA]CODNUM(1)
  #------ Compteur des encours article ------#
  Call LECTCA(7,OK) From SUBTCA
  If fstat | !OK
    GERR=1 : GMESSAGE=mess(64,199,1) : OK=0 : Return
  Endif
  GWIP=[F:TCA]CODNUM(8)
  #Call CTRCPT(GWIP,25,WRETOUR) From STKLIB
  #If WRETOUR<>0  GERR = 1 : GMESSAGE =mess(222,199,1) : OK=0 : Return : Endif
  # Issue 71069 - 2013-08-13 by SR : PJT
  GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC(GFCY)
Endif

#-----
Call PARAM(GFCY,"GPLNFLT",PARAMA) From ADOVAL
GPLNFLT=val(PARAMA)
Return


#---------------------------------------------------------------------#
# Effacement des éventuels numéros de pré-engagement non encore créés #
#---------------------------------------------------------------------#
$RAZ_CMMPRPNUM
For I=0 To [M:PSH1]NBLIG-1
  If [M:PSH1]CREFLG(I)=0  Raz [M:PSH1]CMMPRPNUM(I) : Endif
Next I
Return

# Issue 71276 - 2015-03-03 by SR : Versions
######################################################################################
$C_ITMREF_ECC
If VALEUR <> [M:PSH1]ITMREF (NOL)
   If dim([M:PSH1]ECCVALMAJ) > 0
      Raz [M:PSH1]ECCVALMAJ(NOL)
      Raz [M:PSH1]ECCVALMIN(NOL)
      Raz [M:PSH1]ECCSAIFLG(NOL)
   Endif
Endif
Return

$AM_ITMREF_ECC
If dim([M:PSH1]ECCVALMAJ) > 0
   If [F:ITM]ECCFLG < 2 | [F:ITM]ECCSTO < 2
      Grizo  [M:PSH1]ECCVALMAJ(NOL)
      Grizo  [M:PSH1]ECCVALMIN(NOL)
   Endif
   If [F:ITM]ECCSTO<3
      Grizo  [M:PSH1]ECCVALMIN(NOL)
   Endif
Endif
Return
#
# End issue 71276

