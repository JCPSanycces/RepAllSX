#<AdxTL>@(#)7.0.0.0 $Revision$
###########################################################################
# CNSCSNSTD : Consultation des retours de vente (entête) SYMEU 27/10/2008 #
# ECRAN 1   : CONSCSN1                                                    #
# ECRAN 2   : CONSCSN2                                                    #
# ECRAN CRIT: CRITCSN                                                     #
###########################################################################

$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "DEB_CRIT"   : Gosub DEB_CRIT
  When "FIN_CRIT"   : Gosub FIN_CRIT
 When Default
Endcase
Return

############################################################
$AUTORIS
Return

############################################################
$SETBOUT
#CHMEN+="BCDE"
Return

####################################################################
# analyse paramètres, initialisations, ouvertures et déclarations  #
####################################################################
$OUVRE
NAVIG="CONSCSN"
Local Char    WFIL(250),WFIL1(250),WFIL2(250),WFIL3(250),WFILF(250)
Local Char    DEBNUM(GLONSRH), FINNUM(GLONSRH)
Local Date    DEBDAT, FINDAT

Gosub DEFCRIT
Return
# --------------------------------------------------------------------------#
# Analyse paramètres, initialisations CSN1, CCSN                            #
# --------------------------------------------------------------------------#
$DEFCRIT
If GNBAUZ=1 : PARAM(2)=GUSRFCY(1) : Endif
For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre client
      If PARAM(I) <> ""
        If [F:BPC]BPCNUM <> PARAM(I) Then
           Read [BPC] BPC0 = PARAM(I)
           If fstat  Raz [F:BPC], PARAM(I) : Endif
        Endif
        [M:CSN1]BPCNUM = PARAM(I)
      Endif
    When 2 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I) Then
           Read [FCY] FCY0 = PARAM(I)
           If fstat  Raz [F:FCY], PARAM(I) : Endif
        Endif
        If (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
          [M:CSN1]RTNFCY = PARAM(I)
          Call GETDEV([M:CSN1]RTNFCY) From DEVSUB
          [M:CSN1]CPY = GSOCIETE
          [M:CSN1]CUR = GLOCALDEV
        Endif
      Endif
  Endcase
Next I
[M:CSN1]CURD=GSYSCUR
If [M:CSN1]CUR=""  [M:CSN1]CUR=GSYSCUR : Endif

# retour normal oui
If !find([M:CSN1]RTNTYPNOR,1,2) : [M:CSN1]RTNTYPNOR= 2 : Endif
# retour prêt oui
If !find([M:CSN1]RTNTYPLND,1,2) : [M:CSN1]RTNTYPLND= 2 : Endif
# retour sous-traitance oui
If !find([M:CSN1]RTNTYPSCO,1,2) : [M:CSN1]RTNTYPSCO= 2 : Endif

# retour normal oui
If !find([M:CCSN]RTNTYPNOR,1,2) : [M:CCSN]RTNTYPNOR= 2 : Endif
# retour prêt oui
If !find([M:CCSN]RTNTYPLND,1,2) : [M:CCSN]RTNTYPLND= 2 : Endif
# retour sous-traitance oui
If !find([M:CCSN]RTNTYPSCO,1,2) : [M:CCSN]RTNTYPSCO= 2 : Endif

# tri par numéro ou par date
If !find([M:CCSN]TRI,1,2)       : [M:CCSN]TRI = 1   : Endif

#----- Initialisation dates début et fin -----#
Gosub INIT_DATES From TRTACHGRH1
[M:CSN1]RTNDATDEB=WDATDEB
[M:CSN1]RTNDATFIN=WDATFIN
#----- Copie du masque 1 (CSN1) vers l'écran critères (CCSN) -----#
Gosub CRITENT From =PROGCNS
Return


############################################################
$LECTURE

If GPILNAV>1 Then
   # Si on vient de la fiche client, on grise le code client
   If find(GNAVIG(GPILNAV-1),"GESBPC")
      Diszo [M:CSN1]BPCNUM
   Endif

    # GRNA 16/05/2011
    Local Char CUSSEAORI : CUSSEAORI = "CSN1"
    Gosub LECTURE From CUSSEALIB
Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# Lien entre SRETURN et BPCUSTOMER
Link [SRH] With [BPC]BPC0=[SRH]BPCORD As [LNK]

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCSN]TRI
      When 1 : # tri par numéro
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFILF)
&                    Order By Key SRH0
      When 2 : # tri par date
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFILF)
&                    Order By Key SRH3
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCSN]TRI
      When 1 : # tri par numéro
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFILF)
&                    Order By Key SRH0 Desc
      When 2 : # tri par date
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFILF)
&                    Order By Key SRH3 Desc
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CSN2] : Endif

#-- lecture
$BOUCLE
For [LNK]
  # Filtre sur la société
  If [M:CSN1]CPY <> ""
      If [F:FCY]FCY <> [F:SRH]STOFCY Then
         Read [FCY] FCY0 = [F:SRH]STOFCY
         If fstat  Raz [F:FCY] : Endif
      Endif
      If [F:FCY]LEGCPY <> [M:CSN1]CPY Goto SUIV : Endif
  Endif

  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:CSN2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1
     If NOL=0
         DEBNUM = [F:SRH]SRHNUM
         DEBDAT = [F:SRH]RTNDAT
     Endif
     FINNUM = [F:SRH]SRHNUM
     FINDAT = [F:SRH]RTNDAT
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1
     If NOL=MAXLIG-1
         FINNUM = [F:SRH]SRHNUM
         FINDAT = [F:SRH]RTNDAT
     Endif
     DEBNUM = [F:SRH]SRHNUM
     DEBDAT = [F:SRH]RTNDAT
  Endif

  nolign = NOL+1

  # trans-classe de SRETURN
  [M:CSN2]=[F:SRH]

  # Retour de prêt : au cas où il n'est pas renseigné
  If !find([M:CSN2]LNDRTN(nolign-1),1,2) : [M:CSN2]LNDRTN(nolign-1)= 1 : Endif
  # Retour de sous-traitance : au cas où il n'est pas renseigné
  If !find([M:CSN2]SCORTN(nolign-1),1,2) : [M:CSN2]SCORTN(nolign-1)= 1 : Endif

  # Contact livraison
  If [F:SRH]CNDNAM<>"" Then
     Read [AIN]AIN0=[F:SRH]CNDNAM
     If !fstat Then
        [M:CSN2]CNDNAM(nolign-1)=[AIN]CNTLNA
     Endif
  Endif

  # Adresse de livraison
  If [F:SRH]BPAADD<>"" Then
     Read [BPA]BPA0=1;[F:SRH]BPCORD;[F:SRH]BPAADD
     If !fstat Then
        [M:CSN2]BPADES(nolign-1)=[BPA]BPADES
     Endif
  Endif

  # Numéro de livraison
  # Si la livraison de prêt est renseignée, on va chercher certains renseignements
  # dans la livraison, sinon dans le client livré
  If [F:SRH]LNDRTN=2 and [F:SRH]SDHNUM<>"" Then
     Filter [SDH] Where SDHNUM=[F:SRH]SDHNUM
     For [SDH]
         [M:CSN2]VACBPR(nolign-1)=[F:SDH]VACBPR # régime
         [M:CSN2]PTE(nolign-1)=[F:SDH]PTE       # condition paiement
         [M:CSN2]DEP(nolign-1)=[F:SDH]DEP       # escompte
         [M:CSN2]BPCPYR(nolign-1)=[F:SDH]BPCPYR # tiers payeur
         [M:CSN2]BPCGRU(nolign-1)=[F:SDH]BPCGRU # client groupe
         [M:CSN2]EECICT(nolign-1)=[F:SDH]EECICT # incoterm
         [M:CSN2]FFWNUM(nolign-1)=[F:SDH]FFWNUM # transitaire
     Next
     Filter [SDH]
  Else
     Filter [BPC] Where BPCNUM=[F:SRH]BPCORD
     For [BPC]
         [M:CSN2]VACBPR(nolign-1)=[F:BPC]VACBPR # régime
         [M:CSN2]PTE(nolign-1)=[F:BPC]PTE       # condition paiement
         [M:CSN2]DEP(nolign-1)=[F:BPC]DEP       # escompte
         [M:CSN2]BPCPYR(nolign-1)=[F:BPC]BPCPYR # tiers payeur
         [M:CSN2]BPCGRU(nolign-1)=[F:BPC]BPCGRU # client groupe
     Next
     Filter [BPC]
  Endif

  $SUIV
Next
Filter [LNK]
Return

############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"
WFIL3 = "1=1"
WFILF = "1=1"

# Site de retour
If [M:CSN1]RTNFCY <> ""
   WFIL += "&[F:SRH]STOFCY=[M:CSN1]RTNFCY"
Endif
# Autorisation site
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
   WFIL += "& find([F:SRH]STOFCY,GUSRFCY(1..GNBAUZ))"
Endif
# Numéro de client
If [M:CSN1]BPCNUM <> ""
   WFIL += "&[F:SRH]BPCORD =[M:CSN1]BPCNUM"
Endif

# Numéro de pièce de retour
If [M:CCSN]RTNNUMDEB <> ""
   WFIL += "&[F:SRH]SRHNUM>=[M:CCSN]RTNNUMDEB"
Endif
If [M:CCSN]RTNNUMFIN <> ""
   WFIL += "&[F:SRH]SRHNUM<=[M:CCSN]RTNNUMFIN"
Endif

# Date de retour
If [M:CCSN]RTNDATDEB <> [0/0/0]
   WFIL += "&[F:SRH]RTNDAT>=[M:CCSN]RTNDATDEB"
Endif
If [M:CCSN]RTNDATFIN <> [0/0/0]
   WFIL += "&[F:SRH]RTNDAT<=[M:CCSN]RTNDATFIN"
Endif

# type de retour : normal, prêt, sous-traitance
If [M:CSN1]RTNTYPNOR = 2 Then         # Normal = Oui
   If [M:CSN1]RTNTYPLND = 2 Then        # Prêt = Oui
      If [M:CSN1]RTNTYPSCO = 2 Then       # Sous-traitance = Oui
                                              # Pas de filtre supplémentaire
      Else                                # Sous-traitance = Non
         WFIL1 += "&[F:SRH]SCORTN<>2"
      Endif
   Else                                 # Prêt = Non
      If [M:CSN1]RTNTYPSCO = 2 Then       # Sous-traitance = Oui
         WFIL1 += "&[F:SRH]LNDRTN<>2"
      Else                                # Sous-traitance = Non
         WFIL1 += "&[F:SRH]LNDRTN<>2&[F:SRH]SCORTN<>2"
      Endif
   Endif
Else                                  # Normal = Non
     If [M:CSN1]RTNTYPLND = 2 Then      # Prêt = Oui
      If [M:CSN1]RTNTYPSCO = 2 Then       # Sous-traitance = Oui
         WFIL1 += "&([F:SRH]LNDRTN=2|[F:SRH]SCORTN=2)"
      Else                                # Sous-traitance = Non
         WFIL1 += "&[F:SRH]LNDRTN=2"
      Endif
   Else                                 # Prêt = Non
      If [M:CSN1]RTNTYPSCO = 2 Then       # Sous-traitance = Oui
         WFIL1 += "&[F:SRH]SCORTN=2"
      Else                                # Sous-traitance = Non
         WFIL1 += "&1=2"
      Endif
   Endif
Endif

#--CPO 75115 Prise en compte du "Type retour"
#---Retours normaux
If [M:CSN1]RTNTYPNOR=2
	If [M:CSN1]SRHTYPNOR<>"" : WFIL1 += "&(([F:SRH]SRHCAT=1 & [F:SRH]SRHTYP=[M:CSN1]SRHTYPNOR)|[F:SRH]SRHCAT<>1)" : Endif
Endif
#---Retours de prêt
If [M:CSN1]RTNTYPLND=2
	If [M:CSN1]SRHTYPLND<>"" : WFIL1 += "&(([F:SRH]SRHCAT=2 & [F:SRH]SRHTYP=[M:CSN1]SRHTYPLND)|[F:SRH]SRHCAT<>2)" : Endif
Endif
#---Retours pour sous-traitance
If [M:CSN1]RTNTYPSCO=2
	If [M:CSN1]SRHTYPSCO<>"" : WFIL1 += "&(([F:SRH]SRHCAT=3 & [F:SRH]SRHTYP=[M:CSN1]SRHTYPSCO)|[F:SRH]SRHCAT<>3)" : Endif
Endif
#--/CPO

# 71065 : PJT
If [M:CSN1]PJTDEB <> ""
   WFIL1 += "&[F:SRH]PJT>=[M:CSN1]PJTDEB"
Endif
If [M:CSN1]PJTFIN <> ""
   WFIL1 += "&[F:SRH]PJT<=[M:CSN1]PJTFIN"
Endif
# 71065 : PJT

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCSN]TRI
       When 1 : # tri par numéro
           WFIL2 += "&[F:SRH]SRHNUM>=DEBNUM"
       When 2 : # tri par date
           WFIL2 += "&([F:SRH]RTNDAT>DEBDAT | ([F:SRH]RTNDAT=DEBDAT & [F:SRH]SRHNUM>=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CCSN]TRI
       When 1 : # tri par numéro
           WFIL2 += "&[F:SRH]SRHNUM>FINNUM"
       When 2 : # tri par date
           WFIL2 += "&([F:SRH]RTNDAT>FINDAT | ([F:SRH]RTNDAT=FINDAT & [F:SRH]SRHNUM>FINNUM))"
     Endcase
   When -2 : # retour
     Case [M:CCSN]TRI
       When 1 : # tri par numéro
           WFIL2 += "&[F:SRH]SRHNUM<DEBNUM"
       When 2 : # tri par date
           WFIL2 += "&([F:SRH]RTNDAT<DEBDAT | ([F:SRH]RTNDAT=DEBDAT & [F:SRH]SRHNUM<DEBNUM))"
     Endcase
Endcase

# Familles statistiques clients
If dim([M:CCSN]TSCCOD) > 0
  For I = 0 To dim([M:CCSN]TSCCOD)-1
    If [M:CCSN]TSCCOD(I) <> ""
        WFIL3 += "&[F:BPC]TSCCOD("+num$(I)+")='"+[M:CCSN]TSCCOD(I)+"'"
    Endif
  Next I
Endif

# Formule supplémentaire
If [M:CCSN]SELFOR <> ""
  Read [TFO]TFO0=34;[M:CCSN]SELFOR  # 34 = "Sélection ventes" du chapitre 213
  If fstat = 0
     WFILF = [F:TFO]FORFOR
  Endif
Endif

Return

############################################################
$DEB_CRIT
If GPILNAV>1
   # Si on vient de la fiche client, on grise le code client
   If find(GNAVIG(GPILNAV-1),"GESBPC")
      Diszo [M:CCSN]BPCNUM
   Endif
Endif
Return

############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT
Return

#############################################################
##     Etiquettes masques CONSCSN1 & CONSCSN2 & CRITCSN    ##
#############################################################

Subprog AV_CPY(VALEUR)
#----------------------#
# Avant zone           #
#----------------------#
Variable Char     VALEUR
If GNBAUZ=1 : Diszo [M]CPY, RTNFCY : Endif
End

#############################################################
# Contrôle de la société                                    #
#############################################################
Subprog C_CPY(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
  [M]CUR = [F:CPY]ACCCUR : GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]RTNFCY = ""
  # GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
  # mkstat = 2
  # Raz [M]CUR
  [M]CUR=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Endif
End

#############################################################
# Après modif de la société                                 #
#############################################################
Subprog AM_CPY(VALEUR)
Variable Char     VALEUR
Affzo CUR, ZCPY : # Utilisé par 2 écrans on ne précise pas la classe
Raz [M]RTNFCY, [M]ZRTNFCY
Affzo RTNFCY, ZRTNFCY : # Utilisé par 2 écrans on ne précise pas la classe
If VALEUR<>""  GSOCIETE=VALEUR : Endif
End

#############################################################
# Chargement de la devise                                   #
#############################################################
Subprog C_RTNFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
    [M]CUR = GLOCALDEV
Elsif [M]CPY = ""
    # GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    # mkstat = 2
    [M]CUR=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End

#############################################################
# Après modif du site                                       #
#############################################################
Subprog AM_RTNFCY(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
  Affzo CUR, CPY, ZCPY : # Utilisé par 2 ecrans
Endif
End

#############################################################
# Initialisation  bouton                                    #
#############################################################
Subprog IB_NBLIG
Raz GBOUT1, GBOUT2, GBOUT3
If [M:CSN2]NBLIG<>0
   If clalev([M:SRH1])=0
      # Même message, mais bouton différent qui pointe sur un objet différent (cf écran CONSCSN2)
      If [M:CSN2]LNDRTN(nolign-1) = 2 Then     # Retour de prêt
         GBOUT2=mess(192,198,1)-[M:CSN2]SRHNUM(nolign-1)   # Retour
      Elsif [M:CSN2]SCORTN(nolign-1) = 2 Then  # Retour de sous-traitance
         GBOUT3=mess(192,198,1)-[M:CSN2]SRHNUM(nolign-1)   # Retour
      Else                           # Retour normal
         GBOUT1=mess(192,198,1)-[M:CSN2]SRHNUM(nolign-1)   # Retour
      Endif
   Endif
Endif
End
# 71065 : PJT
######################################################################################
Subprog AM_PJTDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]PJTFIN= VALEUR : Affzo [M]PJTFIN Endif
End
# 71065 : PJT
#############################################################
# Après modification de la date début                       #
#############################################################
Subprog AM_RTNDATDEB(VALEUR)
Variable Date     VALEUR
#----- Recalcul date fin en fonction de la périodicité et du nbre de périodes -----#
If dim([M]PERCOD)>0
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"+",[M]RTNDATDEB,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]RTNDATFIN=WDATE : Affzo RTNDATFIN
  Endif
Elsif VALEUR>[M]RTNDATFIN
  [M]RTNDATFIN=VALEUR
Endif
End

#############################################################
# Après modification de la date fin                         #
#############################################################
Subprog AM_RTNDATFIN(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)<1  End : Endif
#----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
Local Date WDATE
Call CALDATPER([M]PERCOD,[M]PERNBR,"-",[M]RTNDATFIN,VALEUR,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]RTNDATDEB=WDATE : Affzo RTNDATDEB
Endif
End

#############################################################
#      Controle du numéro de retour   fin                   #
#############################################################
Subprog C_RTNNUMFIN(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & VALEUR<[M]RTNNUMDEB : mkstat = 1 : End : Endif
End

#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(4)<>2 End Endif

Call VALGTC(APPLI,"CSN") From SUBGTC

End
######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSCSN1) 10/09/2012 11:28:50 (CPO)
######################################################################################
######################################################################################
#--CPO 75115 : V7 : Extension of Digital Signature : New field return type
######################################################################################
Subprog AM_RTNTYPNOR(VALEUR)
Variable Integer VALEUR

If VALEUR = 1
  Raz [M]SRHTYPNOR : Diszo [M]SRHTYPNOR
Else
  Actzo [M]SRHTYPNOR
Endif
Affzo [M]SRHTYPNOR : Affzo [M]ZSRHTYPNOR

End
#-------------------------------------------------------------------------------------
Subprog AM_RTNTYPLND(VALEUR)
Variable Integer VALEUR

If VALEUR = 1
  Raz [M]SRHTYPLND : Diszo [M]SRHTYPLND
Else
  Actzo [M]SRHTYPLND
Endif
Affzo [M]SRHTYPLND : Affzo [M]ZSRHTYPLND

End
#-------------------------------------------------------------------------------------
Subprog AM_RTNTYPSCO(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  Raz [M]SRHTYPSCO : Diszo [M]SRHTYPSCO
Else
	Actzo [M]SRHTYPSCO
Endif
#Affzo [M]10
Affzo [M]SRHTYPSCO : Affzo [M]ZSRHTYPSCO

End
######################################################################################

