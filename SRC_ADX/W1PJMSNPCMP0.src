#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMSNPCMP0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:52"
A_USER  = "DOC"
A_STAMP = "20181109230552"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMSNPCMP0 [PJSC0]
Gosub HORODAT
Local Inpbox "PJMSNPCMP0" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJSC0] As [SIM_]
Grizo [PJSC0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJSC0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=171 : Y1(0)=1 : Y2(0)=5
X1(1)=1 : X2(1)=-2 : Y1(1)=1 : Y2(1)=0
Return

$ON_OPPNUM
Return

$ON_ZOPPNUM
Onevent BEFORE_AREA Gosub AV_ZOPPNUM From W1PJMSNPCMP0
Return

$AV_ZOPPNUM
Call LECTEXTRA(zc,"PIMPL","PIMDESAXX",num$([M]OPPNUM(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_KEYEXTN1
Onevent AFTER_CHANGE Gosub AMM_KEYEXTN1 From W1PJMSNPCMP0
Onevent BEFORE_INPUT Call AS_KEYEXTN1(zc) From W1PJMSNPCMP0
Onevent CONTROL Call C_KEYEXTN1(zc) From W1PJMSNPCMP0
Return

Subprog AS_KEYEXTN1(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_KEYEXTN1(zc) From W1PJMSNPCMP0
Onkey 144 Titled GBOUTP Call P_KEYEXTN1(zc) From W1PJMSNPCMP0
Onkey 146 Titled GBOUTA Call SA_KEYEXTN1(zc) From W1PJMSNPCMP0
Gosub _AFF
End

Subprog C_KEYEXTN1(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "KEYEXTN1" : GZNUM = 1003799 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("PJMSNPD","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "KEYEXTN1" : GZNUM = 1003799 : Endif
Endif
Gosub _AFF
End

$AMM_KEYEXTN1
Call AM_KEYEXTN1(zc)
If !mkstat & GOBJET
 zoncou = "KEYEXTN1" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_KEYEXTN1(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_KEYEXTN1(VALEUR) From PJMSNPCMP
If mkstat : GERR = 1 : GZONE = "KEYEXTN1" : GZNUM = 1003799 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZKEYEXTN1)")>indice
 [M]KEYEXTN1(indice) = VALEUR
 Affzo ZKEYEXTN1(indice)
Endif
Gosub _AFF
End

Subprog S_KEYEXTN1(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPJMSNP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPJMSNP"
 PARMSK(1) = num$([V]CST_ANO)
 PARMSK(2) = string$([M:PJSC0]CALLBY="","")+string$([M:PJSC0]CALLBY<>"",[M:PJSC0]OPPNUM)
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 PARMSK(6) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPJMSNP","PJMSELECT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_KEYEXTN1(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "PJMSNPD"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_KEYEXTN1(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("PJMSNPD",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZKEYEXTN1
Onevent BEFORE_AREA Gosub AV_ZKEYEXTN1 From W1PJMSNPCMP0
Return

$AV_ZKEYEXTN1
Call LECTEXTRA(zc,"PJMSNPD","DDESAXX",num$([M]KEYEXTN1(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_SNPDTEN1
Onevent BEFORE_AREA Gosub AV_SNPDTEN1 From W1PJMSNPCMP0
Return

$AV_SNPDTEN1
Chgfmt [M]SNPDTEN1(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_SNPCODN1
Return

$ON_ZSNPCODN1
