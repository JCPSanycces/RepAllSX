Subprog S_KEYEXTN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPJMSNP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPJMSNP"
 PARMSK(1) = num$([V]CST_ANO)
 PARMSK(2) = [M:PJSC0]OPPNUM
 PARMSK(3) = ""
 PARMSK(4) = [M:PJSC0]SHOWGRP
 PARMSK(5) = [M:PJSC0]SHOWUOM
 PARMSK(6) = [M:PJSC0]SHOWCUR
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPJMSNP","PJMSELECT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

