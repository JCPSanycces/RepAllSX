Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_KEYEXTN(zc) From W1PJMSNPCMP0
Onkey 144 Titled GBOUTP Call P_KEYEXTN(zc) From W1PJMSNPCMP0
Onkey 146 Titled GBOUTA Call SA_KEYEXTN(zc) From W1PJMSNPCMP0
Gosub _AFF
End

Subprog C_KEYEXTN(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("PJMSNPD","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "KEYEXTN" : GZNUM = 1003800 : Endif
Gosub _AFF
End

$AMM_KEYEXTN
