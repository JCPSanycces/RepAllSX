Call AM_KEYEXTN(VALEUR) From PJMSNPCMP
If mkstat : GERR = 1 : GZONE = "KEYEXTN" : GZNUM = 1003800 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZKEYEXTN)")>indice
 [M]KEYEXTN(indice) = VALEUR
 Affzo ZKEYEXTN(indice)
Endif
Gosub _AFF
