Subprog D_CURRSIT(VALEUR)
Variable Integer VALEUR
If varinit([M]CURRSIT,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_CURRSIT(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_CURRSIT(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CURRSIT" : GZNUM = 1003781 : Endif
Gosub _AFF
End

$AMM_CURRSIT
Call AM_CURRSIT(zc)
If !mkstat & GOBJET
 zoncou = "CURRSIT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CURRSIT(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_CURRSIT(VALEUR) From PJMSNPCMP
If mkstat : GERR = 1 : GZONE = "CURRSIT" : GZNUM = 1003781 : Endif
Gosub _AFF
End

