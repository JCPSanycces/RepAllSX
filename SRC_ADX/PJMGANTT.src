###################################################################################################
# PJMGANTT
# Issue X3-52216 - 2017-08-08 by FGR
###################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"                       : Gosub OUVRE
    When "DEBUT"                       : Gosub DEBUT
    When "BOUTON"                      : Gosub BOUTON
  Endcase
Return

###################################################################################################
$OUVRE
  NAVIG = GACTION
  GOK = 1
Return

###################################################################################################
$DEBUT
  # ------------------------------
  [M:PGANT0]OPPNUM = PARAM(1)
  #
  [M:PGANT0]EVRLEV = [V]CST_ANO     # Display All levels
  [M:PGANT0]MULPRJ = [V]CST_ANO     # Display multi project
  [M:PGANT0]DSYITMRET = [V]CST_ANO  # Display product requirements
  [M:PGANT0]DSYOPE = [V]CST_ANO     # Display operation
  Affzo [M:PGANT0]1-99
  # ------------------------------
  Call LOAD_GANTT()
  # ------------------------------
Return

###################################################################################################
$BOUTON
  Case BOUT
    When "C"
      Call LOAD_GANTT()
  Endcase
Return

###################################################################################################
# SUBROUTINES
###################################################################################################
Subprog LOAD_GANTT()

Local Integer NBLIGRES
Local Char SPRJLST(GLONPIM)(1..)
Local Integer NBPRJLST
Local Integer NI

  # ------------------------------
  Effzo [M:PGANT1]
  Effzo [M:PGANT2]
  # ------------------------------
  Call LOAD_PRJLST(NBPRJLST, SPRJLST)
  For NI = 1 To NBPRJLST
    Call LOAD_PROJECT(NBLIGRES, SPRJLST(NI))
  Next NI
  # ------------------------------
  If NBLIGRES = 0 Then
    Call DISPLAY_EMPTY_GRID(NBLIGRES)
  Endif
  [M:PGANT1]NBLIG = NBLIGRES
  Affzo [M:PGANT1]1-99
  [M:PGANT2]NBPGANT2 = [M:PGANT2]LINE
  Affzo [M:PGANT2]1-99
  # ------------------------------
End

###################################################################################################
Subprog LOAD_PROJECT(ILIGRES, SPROJECT)
Variable Integer ILIGRES
Value Char SPROJECT

Local Integer ISAV_ILIGRES
Local Char SPIMDESAXX(GLONDCO)
Local Date DMINDATDEB
Local Char SMINHOUDEB(GLONDCO)
Local Date DMAXDATEND
Local Char SMAXHOUEND(GLONDCO)
Local Date DDATE1
Local Date DDATE2
Local Decimal LLTI

  # ------------------------------
  Local File PIMPL [PIM]
  # ------------------------------
  Raz DMINDATDEB
  Raz SMINHOUDEB
  Raz DMAXDATEND
  Read [PIM]PIM0=SPROJECT
  If [F:PIM] PIMTYP = 2 or [F:PIM] PIMTYP = 3 Then
    SPIMDESAXX = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, SPROJECT)
    Call DISPLAY_LINE_HEAD(ILIGRES, SPROJECT, SPIMDESAXX, [0/0/0], AVOID.ACHAR, [0/0/0], AVOID.ACHAR, func GET_EVENT_TYPE_VALUE(1))
    ISAV_ILIGRES = ILIGRES - 1
    Call LOAD_TASKS(SPROJECT, AVOID.ACHAR, ILIGRES, DMINDATDEB, SMINHOUDEB, DMAXDATEND, SMAXHOUEND)
    # ------------------------------
    LLTI = func COMPUTE_DURATION(DMINDATDEB, SMINHOUDEB, DMAXDATEND, SMAXHOUEND)
    [M:PGANT1]LTIAFF(ISAV_ILIGRES) = LLTI               # Displayed duraction
    [M:PGANT1]LTI(ISAV_ILIGRES) = LLTI                  # Internal duration
    Call LOAD_DATE_COLUMNS(ISAV_ILIGRES, func GET_INTERNAL_DATE(DMINDATDEB, SMINHOUDEB), func GET_INTERNAL_DATE(DMAXDATEND, SMAXHOUEND))
  Endif
End

###################################################################################################
Subprog LOAD_TASKS(SPROJECT, STASK, ILIGRES, RMINDATDEB, SMINHOUDEB, RMAXDATEND, SMAXHOUEND)
Value Char SPROJECT
Value Char STASK
Variable Integer ILIGRES
Variable Date RMINDATDEB
Variable Char SMINHOUDEB
Variable Date RMAXDATEND
Variable Char SMAXHOUEND

Local Integer NI
Local Integer INB
Local Char STASCOD(GLONTAC)(1..)
Local Char SPIMDESAXX(GLONDCO)(1..)
Local Integer ISTATUS(1..)
Local Integer ISPARENT(1..)
Local Date DTASSTARTDT(1..)
Local Date DTASENDDT(1..)
Local Char SHOUDEB(GLONDES)(1..)
Local Char SHOUEND(GLONDES)(1..)

  # ------------------------------
  If [M:PGANT0]EVRLEV = [V]CST_ANO Then
    Local File PJMTSK [PJTA] Where [F:PJTA]TASPAE = AVOID.ACHAR
  Else
    Local File PJMTSK [PJTA]
  Endif
  # ------------------------------
  INB = 0
  If STASK = AVOID.ACHAR Then
    Filter [PJTA] Where [F:PJTA]OPPNUM = SPROJECT
  Else
    Filter [PJTA] Where [F:PJTA]OPPNUM = SPROJECT and [F:PJTA]TASPAE = STASK
  Endif
  For [PJTA]PTA0
    If [F:PJTA]TASSTARTDT <> [0/0/0] and [F:PJTA]TASENDDT <> [0/0/0] Then
      If [F:PJTA]TASPAE <> AVOID.ACHAR Then
        ITODO = [V]CST_ANO
        If find([F:PJTA]TASPAE,[M:PGANT1]TASCOD(0..ILIGRES-1)) > 0 Then
          ITODO = [V]CST_AYES
        Endif
      Else
        ITODO = [V]CST_AYES
      Endif
      If ITODO = [V]CST_AYES Then
        INB += 1
        STASCOD(INB) = [F:PJTA]TASCOD
        SPIMDESAXX(INB) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:PJTA]KEYCONCAT)
        ISPARENT(INB) = func PJMTSK_CSTD_PROGS.IS_TASCOD_PARENT(GACTX, [F:PJTA]OPPNUM, [F:PJTA]TASCOD)
        If ISPARENT(INB) = [V]CST_AYES Then
          Case [F:PJTA]TASSTATE
            When 4
              # Closed
              ISTATUS(INB) = 7        # Parent task (not closed) planned
            When Default
              ISTATUS(INB) = 7        # Parent task (not closed)
          Endcase
        Else
          Case [F:PJTA]TASSTATE
            When 1
              # New
              ISTATUS(INB) = 2
            When 2, 3, 5
              # Launched, Started, Planned
              ISTATUS(INB) = 4
            When 4
              # Closed
              ISTATUS(INB) = 5
            When 9
              # Suspended
              ISTATUS(INB) = 3
          Endcase
        Endif
        DTASSTARTDT(INB) = [F:PJTA]TASSTARTDT
        DTASENDDT(INB) = [F:PJTA]TASENDDT
        SHOUDEB(INB) = "0800"
        SHOUEND(INB) = "1800"
        # ------------------------------
        If RMINDATDEB = [0/0/0] or func GET_INTERNAL_DATE(RMINDATDEB, SMINHOUDEB) > func GET_INTERNAL_DATE(DTASSTARTDT(INB), SHOUDEB(INB)) Then
          RMINDATDEB = DTASSTARTDT(INB)
          SMINHOUDEB = SHOUDEB(INB)
        Endif
        If RMAXDATEND = [0/0/0] or func GET_INTERNAL_DATE(RMAXDATEND, SMAXHOUEND) < func GET_INTERNAL_DATE(DTASENDDT(INB), SHOUEND(INB)) Then
          RMAXDATEND = DTASENDDT(INB)
          SMAXHOUEND = SHOUEND(INB)
        Endif
      Endif
    Else
      Call ADD_MESSAGE(func AFNC.MES2(mess(956,2260,1), SPROJECT, [F:PJTA]TASCOD))
    Endif
  Next
  Filter [PJTA]
  Close Local File [PJTA]    # Mandatory to close table. This is a recursive subroutine. So, if not, we can have an error "too many tables open"
  # ------------------------------
  For NI = 1 To INB
    [M:PGANT1]TASCOD(ILIGRES) = STASCOD(NI)
    Call DISPLAY_LINE_HEAD(ILIGRES, SPROJECT + "~" + STASCOD(NI), SPIMDESAXX(NI), DTASSTARTDT(NI), SHOUDEB(NI), DTASENDDT(NI), SHOUEND(NI), func GET_EVENT_TYPE_VALUE(ISTATUS(NI)))
    # ------------------------------
    # Load operation et articles
    Call LOAD_OPERATION(SPROJECT, STASCOD(NI), ILIGRES)
    Call LOAD_PRODUCT_REQUIREMENT(SPROJECT, STASCOD(NI), DTASSTARTDT(NI), SHOUDEB(NI), ILIGRES)
    # ------------------------------
    If ISPARENT(NI) = [V]CST_AYES Then
      Call LOAD_TASKS(SPROJECT, STASCOD(NI), ILIGRES, RMINDATDEB, SMINHOUDEB, RMAXDATEND, SMAXHOUEND)
    Endif
  Next NI
  # ------------------------------
End

###################################################################################################
Subprog LOAD_OPERATION(SPROJECT, STASK, ILIGRES)
Value Char SPROJECT
Value Char STASK
Variable Integer ILIGRES

Local Integer ISTATUS

  If [M:PGANT0]DSYOPE = [V]CST_AYES Then
    # ------------------------------
    Local File PJMTSKOPE [PTKO]
    # ------------------------------
    Filter [PTKO] Where [F:PTKO]OPPNUM = SPROJECT and [F:PTKO]TASCOD = STASK
    For [PTKO]PTKO0
      If [F:PTKO]OPESTR <> [0/0/0] and [F:PTKO]OPEEND <> [0/0/0] Then
        Case [F:PTKO]OPESTA
          When 1
            # Pending
            ISTATUS = 9
          When 4
            # In process
            ISTATUS = 8
          When 5
            # Closed
            ISTATUS = 10
        Endcase
        Call DISPLAY_LINE_HEAD(ILIGRES, SPROJECT + "~" + STASK + "~" + num$([F:PTKO]OPENUM), num$([F:PTKO]OPENUM), [F:PTKO]OPESTR, "0800", [F:PTKO]OPEEND, "1800", func GET_EVENT_TYPE_VALUE(ISTATUS))
      Else
        Call ADD_MESSAGE(func AFNC.MES3(mess(955,2260,1), SPROJECT, STASK, num$([F:PTKO]OPENUM)))
      Endif
    Next
    Filter [PTKO]
  Endif
End

###################################################################################################
Subprog LOAD_PRODUCT_REQUIREMENT(SPROJECT, STASK, DTASSTARTDT, SHOUDEB, ILIGRES)
Value Char SPROJECT
Value Char STASK
Value Date DTASSTARTDT
Value Char SHOUDEB
Variable Integer ILIGRES

Local Char SKEYCONCAT(250)

  If [M:PGANT0]DSYITMRET = [V]CST_AYES Then
    Local File PJMTSKITM [JTT]
    # ------------------------------
    SKEYCONCAT = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(GACTX, SPROJECT, STASK)
    Filter [JTT] Where [F:JTT]OPPNUM = SPROJECT and [F:JTT]TASCOD = STASK
    For [JTT]JTT0
      If [F:JTT]REQDAT <> [0/0/0] Then
        Call DISPLAY_LINE_HEAD(ILIGRES,  SPROJECT + "~" + STASK + "~" + [F:JTT]ITMREF, [F:JTT]ITMREF, DTASSTARTDT, SHOUDEB, [F:JTT]REQDAT, "1800", func GET_EVENT_TYPE_VALUE(6))
      Else
        Call ADD_MESSAGE(func AFNC.MES3(mess(957,2260,1), SPROJECT, STASK, [F:JTT]ITMREF))
      Endif
    Next
    Filter [JTT]
  Endif
End

###################################################################################################
Subprog DISPLAY_LINE_HEAD(ILIGRES, SNUM, SDES, DDATEDEB, SHOUDEB, DDATEEND, SHOUEND, ITYPE)
Variable Integer ILIGRES
Value Char SNUM
Value Char SDES
Value Date DDATEDEB
Value Char SHOUDEB
Value Date DDATEEND
Value Char SHOUEND
Value Integer ITYPE

  [M:PGANT1]COD(ILIGRES) = SNUM                  # key
  [M:PGANT1]DES(ILIGRES) = SNUM - SDES
  ILIGRES += 1
  Call DISPLAY_LINE(ILIGRES, "", SNUM, SDES, DDATEDEB, SHOUDEB, DDATEEND, SHOUEND, ITYPE)
End

###################################################################################################
Subprog DISPLAY_LINE(ILIGRES, SDAD, SNUM, SDES, DDATEDEB, SHOUDEB, DDATEEND, SHOUEND, ITYPE)
Variable Integer ILIGRES
Value Char SDAD
Value Char SNUM
Value Char SDES
Value Date DDATEDEB
Value Char SHOUDEB
Value Date DDATEEND
Value Char SHOUEND
Value Integer ITYPE

Local Decimal LLTI

  LLTI = func COMPUTE_DURATION(DDATEDEB, SHOUDEB, DDATEEND, SHOUEND)
  # ------------------------------
  If SDAD <> "" Then
    [M:PGANT1]COD(ILIGRES) = SDAD + "~" + SNUM   # Key
  Else
    [M:PGANT1]COD(ILIGRES) = SNUM                # Key
  Endif
  Call LOAD_DATE_COLUMNS(ILIGRES, func GET_INTERNAL_DATE(DDATEDEB, SHOUDEB), func GET_INTERNAL_DATE(DDATEEND, SHOUEND))
  [M:PGANT1]LTIAFF(ILIGRES) = LLTI               # Displayed duraction
  [M:PGANT1]LTI(ILIGRES) = LLTI                  # Internal duration
  [M:PGANT1]TYPTPS(ILIGRES) = ITYPE              # Event
  ILIGRES += 1
End

###################################################################################################
Subprog LOAD_DATE_COLUMNS(ILIGRES, SDATBEG, SDATEND)
Value Integer ILIGRES
Value Char SDATBEG
Value Char SDATEND

  [M:PGANT1]STRDAT(ILIGRES) = SDATBEG # Internal start date
  [M:PGANT1]ENDDAT(ILIGRES) = SDATEND # Internal end date
End

###################################################################################################
Subprog DISPLAY_EMPTY_GRID(ILIGRES)
Variable Integer ILIGRES

  [M:PGANT1]COD(ILIGRES) = space$(GLONAUS)
  [M:PGANT1]DES(ILIGRES) = "No task defined"
  Call DISPLAY_LINE(ILIGRES, "", "", "", date$, "0800", date$, "1800", 0)
  ILIGRES += 1
End

###################################################################################################
Subprog ADD_MESSAGE(SMSG)
Value Char SMSG

  [M:PGANT2]MSG([M:PGANT2]LINE) = SMSG
  [M:PGANT2]LINE += 1
End

###################################################################################################
Subprog LOAD_PRJLST(INBPRJLST, SPRJLST)
Variable Integer INBPRJLST
Variable Char SPRJLST()(1..)

  Raz SPRJLST
  INBPRJLST = 0
  INBPRJLST += 1
  SPRJLST(INBPRJLST) = [M:PGANT0]OPPNUM
  If [M:PGANT0]MULPRJ = [V]CST_AYES Then
    Local File OPPORSBB [OBB]
    Filter [OBB] Where [F:OBB]OPPNUM = [M:PGANT0]OPPNUM
    For [OBB]
      INBPRJLST += 1
      SPRJLST(INBPRJLST) = [F:OBB]SBBPJT
    Next
    Filter [OBB]
  Endif
End

###################################################################################################
Funprog GET_EVENT_TYPE_VALUE(ITYP)
Value Integer ITYP

Local Integer IARENDRE

  Case ITYP
    When 1
      # Project
      IARENDRE = 1
    When 2
      # New
      IARENDRE = 2
    When 3
      # Suspended
      IARENDRE = 2
    When 4
      # Opened
      IARENDRE = 2
    When 5
      # Closed
      IARENDRE = 2
    When 6
      # Product requirement
      IARENDRE = 3
    When 7
      # Parent task
      IARENDRE = 5
    When 8
      # In process operation
      IARENDRE = 4
    When 9
      # Pending operation
      IARENDRE = 4
    When 10
      # Closed operation
      IARENDRE = 4
  Endcase
End IARENDRE

###################################################################################################
Funprog GET_INTERNAL_DATE(DDATE, SHOUR)
Value Date DDATE
Value Char SHOUR

Local Char SARENDRE(GLONDCO)

  SARENDRE = DDATE + SHOUR
End SARENDRE

###################################################################################################
Funprog COMPUTE_DURATION(DDATEDEB, SHOUDEB, DDATEEND, SHOUEND)
Value Date DDATEDEB
Value Char SHOUDEB
Value Date DDATEEND
Value Char SHOUEND

Local Decimal ARENDRE
Local Decimal IHHDEB
Local Decimal IMMDEB
Local Decimal IHHFIN
Local Decimal IMMFIN
Local Decimal ITEMPS1
Local Decimal ITEMPS2

  If DDATEDEB = DDATEEND Then
    # C'est dans la même journée
    IHHDEB = func GET_DURATION(SHOUDEB)
    IHHFIN = func GET_DURATION(SHOUEND)
    ARENDRE = IHHFIN - IHHDEB
  Else
    # C'est sur plusieurs jours
    ARENDRE = DDATEEND - DDATEDEB + 0
    IHHDEB = func GET_DURATION("0000")
    IHHFIN = func GET_DURATION(SHOUDEB)
    ITEMPS1 = IHHFIN - IHHDEB
    IHHDEB = func GET_DURATION("0000")
    IHHFIN = func GET_DURATION(SHOUEND)
    ITEMPS2 = IHHFIN - IHHDEB
    ARENDRE = ARENDRE - ITEMPS1 + ITEMPS2
  Endif
End ARENDRE

###################################################################################################
Funprog GET_DURATION(SHOUR)
Value Char SHOUR

Local Decimal ARENDRE
Local Decimal IHHDEB
Local Decimal IMMDEB

  IHHDEB = val(left$(SHOUR, 2)) / 24
  IMMDEB = (val(right$(SHOUR, 3)) / 60) / 24
  ARENDRE = IHHDEB + IMMDEB
End ARENDRE

