## Etiquette ajoutée par le superviseur (écran MFGWEIGH) 30/07/2007 11:59:34 (MM)
######################################################################################
Subprog C_CPNITMREF(VALEUR)
Variable Char    VALEUR()
# 107513
#Local Char     WFCY
#
## 42003 mm 07.07
#If [F:ITM]ITMREF <> VALEUR
#    Read [ITM]ITM0=VALEUR
#Endif
#
## lecture article site
#If [F:ITF]ITMREF<>VALEUR | [F:ITF]STOFCY<>[M:MWG]FCY
#   Read [ITF] ITF0=VALEUR;[M:MWG]FCY
#   If fstat : GMESSAGE = mess(260,199,1) : End : Endif
#Endif
#
#WFCY = [F:ITF]STOFCY
#Call CONTMATITM(WFCY, 1) From MFGLIB

# mm X3-38517 / 121333 08.2017
If VALEUR<>""
  Call CONTMATITM(VALEUR, [M:MWG]FCY, "MKM", GERR, GMESSAGE) From MFGLIB
  If find(GERR,1,4)
      GERR = 1
      mkstat=2
      End
  Endif
Endif

End


