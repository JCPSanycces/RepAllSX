#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#                                    1.4.0 action SAIBENWEI
#               F U N W E I G H
#    ATTENTION : la zone "cochage" est en deuxième position dans le tableau
#   et c'est fait exprès (sinon boucle si contrôle  pas OK
#########################################################################
# Fonction Plan pesée                                                   #
$ACTION
Case ACTION
    When "INIT"          : Gosub INIT
    When "SEL_LISTE"     : Gosub SEL_LISTE
    When "FIN_LISTE"     : Gosub FIN_LISTE
    When "CONTROLE"      : Gosub CONTROLE
    When "OUVRE"         : Gosub OUVRE
    When "TITRE"         : Gosub TIT
    When "DEBUT"         : Gosub DEBUT
    When "BOUTON"        : Gosub BOUTON
    When "SETBOUT"       : Gosub SETBOUT
    When "AP_CHOIX"      : Gosub AP_CHOIX
    When "ABA"           : Gosub ABA
    When "FIN"           : Gosub FIN
    When Default
Endcase
Return

###########################################################################
$INIT
Global Char    GMGLNUM(GLONTRS)
GMGLNUM = ""
Raz GSTATUT

Return

###########################################################################
# selection de la transaction
$SEL_LISTE
# sr 10.05 demande 32570
Local Char     TABACS(10)(100)
Local Integer  NBACS
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX

If clalev ([F:BTS])=0  : Local File BENCHTRS [BTS] : Endif
If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif
CRITERE = "BTSTYP=90&ENAFLG=2"
# sr 10.05 demande 32570
If GPROFIL <> GSUPER
    For [ACC]CODACC Where USR=GUSER
       If [F:ACC]EXEC=2 [L]TABACS(NBACS)=vireblc([F:ACC]CODACC,1) : NBACS +=1
       Endif
       If NBACS>99 Break : Endif
    Next
    CRITERE += "& (ACSCOD = ''  | find(ACSCOD,TABACS(0..99)))"
Endif
If GFLAG=""
    Filter [BTS] Where evalue(CRITERE)
    If rowcount([BTS])=1
        Read [BTS] First
        If !fstat
            GFLAG=[F:BTS]BTSNUM
        Endif
    Endif
    Filter [BTS]
Endif
If GFLAG<>""
    Filter [BTS] Where evalue(CRITERE)
    Read [BTS]BTS0=90;GFLAG
    Filter [BTS]
    If !fstat
        If dim(GMGLNUM)<=0
            Global Char    GMGLNUM(GLONTRS)
        Endif
        GMGLNUM = [F:BTS]BTSNUM
        OK=0
    Endif
Endif
If GMGLNUM=""
    For [F:BTS] Where evalue(CRITERE)
        NBTEX+= 1
        TEX(NBTEX)   =[F:BTS]BTSNUM
        Call LECTEXTRA(TEXTE(NBTEX),"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
        TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
    Next
    TIT(0) = mess(3,126,1) # Choix transactions
Endif
Return

###########################################################################
$FIN_LISTE
GMGLNUM = TEX(CHOIX)
Return

###########################################################################
$CONTROLE
If clalev ([F:BTS]) <= 0  : Local File BENCHTRS [BTS] : Endif
Read [BTS]BTS0=90;GMGLNUM
If fstat  | [F:BTS]ENAFLG = 1 : FIN = 1 : Return : Endif

Return

###########################################################################
$OUVRE
Local Integer  VALOK

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub CHARG_PARAM
Gosub OPEN_FILE


Gosub LECTURE_BTS
#
# substitution fenêtre
BOITE     = "WIMWG"+GMGLNUM
WMASQUE   = "WT90"+GMGLNUM+"1"

#MAE, le 31/01/08, GRP_SITE
GGRPFCY = [F:BTS]GFY

Gosub CHANGE_AWI From BENCHLIB
Return



###################################################################################
$OPEN_FILE
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif
If clalev ([F:TUN]) <= 0 : Local File TABUNIT    [TUN] : Endif
If clalev ([F:MFG]) <= 0 : Local File MFGHEAD    [MFG] : Endif
If clalev ([F:MFI]) <= 0 : Local File MFGITM     [MFI] : Endif
If clalev ([F:MFM]) <= 0 : Local File MFGMAT     [MFM] : Endif    # 42003 mm 07.07
If clalev ([F:TFO]) <= 0 : Local File TABFOR     [TFO] : Endif
If clalev ([F:BTS]) <= 0 : Local File BENCHTRS   [BTS] : Endif
# masque pour paramètres mises à jour
Local Mask MFGK [MFGK]
Local Mask ORCK [ORCK]
Return


#########################################################################
$TIT
    Call LECTEXTRA(TIT,"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-[F:BTS]BTSNUM-":"-TIT
Return

###################################################################################
$DEBUT
Raz [M:MWG]
[M:MWG]FCY        = GFCY
[M:MWG]PLANNER    = GUSER
[M:MWG]ENDDATEND  = date$+(GPLNHOR*7)

Grizo [M:MWG]13
Affzo [M:MWG]5-13

Return

#########################################################################
$SETBOUT
ETABOU(GSPE1) = 1                                     # recherche
ETABOU(GSPE2) = 1                                     # critères
ETABOU(GSPE3) = 1                                     # validation
ETABOU(GABAN) = 1
Return

########################################################################
$BOUTON
Case BOUT
    When "1"       :     Gosub CHARG_MASK
    When "2"       :     If [M:MWG]REACT = 2 : Gosub CHARG_MASK : [M:MWG]REACT = 1 : Endif
    When "3"       :     Gosub VALIDATION
Endcase
Return

#########################################################################
$AP_CHOIX
# interception de la touche return
If REPONSE = GSTARET
    Gosub CHARG_MASK
Endif
Return




########################################################################
# Préparation du filtre critere1 sur la table MFGHEAD                  #
########################################################################
$LOAD_FILTER
Raz CRITERE
Raz CRITERE1

# si choix Of non alloue
If [F:BTS]ALLO = 2
    CRITERE  = "([F:MFG]ALLSTA=1)"
    Gosub LOAD_CRITERE
Endif
# si allocation globale et pas detailles
If [F:BTS]OVRALL = 2
    CRITERE  = "([F:MFG]OVRALLNBR <> 0 )"
    Gosub LOAD_CRITERE
    Endif
# si pas allocation globale mais detailles

If [F:BTS]DETALL = 2
    CRITERE  = "([F:MFG]DETALLNBR <> 0)"
    Gosub LOAD_CRITERE
Endif
Return


########################################################################
# Préparation des filtres critere11 critere12 sur la table MFGHEAD     #
########################################################################

$LOAD_FILTER2
Raz CRITERE

Raz CRITERE11
Raz CRITERE12
# critères dynamiques, dépendant des paramètres
If [M:MWG]FCY <> ""
   CRITERE = "[F:MFG]MFGFCY=[M:MWG]FCY"               # filtre site
   Gosub LOAD_CRITERE2
Endif

    CRITERE = "[F:MFG]MFGSTA<2"                       # filtre statut ordre
    Gosub LOAD_CRITERE2

    CRITERE = "[F:MFG]WGGFLG>1 & [F:MFG]WGGFLG<4"    # filtre plan de pesée
    Gosub LOAD_CRITERE2

#    CRITERE = "[F:MFG]WGGSTA<2" enlever le 6 11 01  # filtre situation de pesée
#    Gosub LOAD_CRITERE2

# ordre
If [M:MWG]MFGNUMSTR <> ""
   CRITERE = "[F:MFG]MFGNUM>=[M:MWG]MFGNUMSTR"       # borne début ordre
   Gosub LOAD_CRITERE2
Endif
If [M:MWG]MFGNUMEND<>""
   CRITERE = "[F:MFG]MFGNUM<=[M:MWG]MFGNUMEND"       # borne fin   ordre
   Gosub LOAD_CRITERE2
Endif

# date fin
If [M:MWG]ENDDATSTR <> [0/0/0]
   CRITERE = "[F:MFG]ENDDAT>=[M:MWG]ENDDATSTR"       # borne debut date fin
   Gosub LOAD_CRITERE2
Endif
If [M:MWG]ENDDATEND <> [0/0/0]
   CRITERE = "[F:MFG]ENDDAT<=[M:MWG]ENDDATEND"       # borne fin date fin
   Gosub LOAD_CRITERE2
Endif

# date debut
If [M:MWG]STRDATSTR <> [0/0/0]
   CRITERE = "[F:MFG]STRDAT>=[M:MWG]STRDATSTR"       # borne debut date début
   Gosub LOAD_CRITERE2
Endif
If [M:MWG]STRDATEND <> [0/0/0]
   CRITERE = "[F:MFG]STRDAT<=[M:MWG]STRDATEND"       # borne fin date debut
   Gosub LOAD_CRITERE2
Endif

# priorite
If [M:MWG]MFGPIOSTR <> 0
   CRITERE = "[F:MFG]MFGPIO>=[M:MWG]MFGPIOSTR"       # borne début priorite
   Gosub LOAD_CRITERE2
Endif
If [M:MWG] MFGPIOEND <> 0
   CRITERE = "[F:MFG]MFGPIO<=[M:MWG]MFGPIOEND"       # borne fin   priorite
   Gosub LOAD_CRITERE2
Endif
#
Return


########################################################################
# Préparation du filtre critere3 sur la table MFGHITM                  #
########################################################################

$LOAD_FILTER3
Raz CRITERE
Raz CRITERE3

  CRITERE = "[F:MFI]MFGSTA<2"                       # filtre statut ordre
    Gosub LOAD_CRITERE3

# article
If [M:MWG]ITMREFSTR <> ""
    CRITERE = "[F:MFI]ITMREF>=[M:MWG]ITMREFSTR"      # borne début article
    Gosub LOAD_CRITERE3
Endif
If [M:MWG]ITMREFEND<>""
    CRITERE = "[F:MFI]ITMREF<=[M:MWG]ITMREFEND"      # borne fin   article
    Gosub LOAD_CRITERE3
Endif
# Affaire
If [M:MWG]PJTSTR <> ""
    CRITERE = "[F:MFI]PJT>=[M:MWG]PJTSTR"      # borne début affaire
    Gosub LOAD_CRITERE3
Endif
If [M:MWG]PJTEND<>""
    CRITERE = "[F:MFI]PJT<=[M:MWG]PJTEND"      # borne fin   affaire
    Gosub LOAD_CRITERE3
Endif
# categorie
If [M:MWG]TCLCODSTR <> ""
    CRITERE = "[F:MFI]TCLCOD>=[M:MWG]TCLCODSTR"      # borne début categorie
    Gosub LOAD_CRITERE3
Endif
If [M:MWG]TCLCODEND<>""
    CRITERE = "[F:MFI]TCLCOD<=[M:MWG]TCLCODEND"      # borne fin   categorie
    Gosub LOAD_CRITERE3
Endif

Return



########################################################################
# Préparation du filtre critere4 sur la table MFGMAT                   #
########################################################################

$LOAD_FILTER4
If [M:MWG]CPNITMREF <>""
    CRITERE4 ="[F:MFM]ITMREF =[M:MWG]CPNITMREF"
Endif
Return



############################################################
$LOAD_CRITERE
 If CRITERE1 <> ""
      CRITERE1 += "|"
  Endif
  CRITERE1 += CRITERE
 Return

############################################################
$LOAD_CRITERE2

If len(CRITERE)+len(CRITERE11)+1 < 255
  If CRITERE11 <> ""
      CRITERE11 += "&"
  Endif
  CRITERE11 += CRITERE
Else
  If CRITERE12 <> ""
     CRITERE12 += "&"
  Endif
  CRITERE12 += CRITERE
Endif

Return


############################################################
$LOAD_CRITERE3
 If CRITERE3 <> ""
      CRITERE3 += "&"
  Endif
  CRITERE3 += CRITERE
Return

############################################################
# Chargement du masque de détail des allocations
$CHARG_MASK
Local Integer WMAX

Local Char    CRITERE(255)
Local Char    CRITERE1(255)
Local Char    CRITERE11(255)
Local Char    CRITERE12(255)
Local Char    CRITERE3(255)
Local Char    CRITERE4(255)
Local Char    FORMULE1(250)
Local Char    WMFGNUM(GLONVCR)
Local Integer WMFGLIN

Local Date    TODAY : TODAY = date$

If clalev([M:MFW1])=0 Local Mask MFGWCRIT1 [MFW1] : Endif



WMAX = dim([M:MWG]COCHAGE)     # 01.06 demande 34108
Effzo [M:MWG]20

Gosub LOAD_FILTER
Gosub LOAD_FILTER2
Gosub LOAD_FILTER3
Gosub LOAD_FILTER4

If CRITERE1  = "" CRITERE1  = "1=1"  : Endif
If CRITERE12 = "" CRITERE12 = "1=1"  : Endif
If CRITERE4  = "" CRITERE4  = "1=1"  : Endif

# analyse présence formule de sélection
If [M:MWG]FORMULE  = ""
    FORMULE1 = "1=1"
Else
    Read [F:TFO]TFO0=12;[M:MWG]FORMULE
    If fstat
        FORMULE1 = "1=1"
    Else
        FORMULE1 = [F:TFO]FORFOR
    Endif
Endif


If CRITERE4 <>"1=1"
# 42003 mm 07.07 - filtrer les OF en fonction de la matière qu'on souhaite peser
    Link [MFI]
&   With [F:MFG]MFG0=[F:MFI]MFGNUM,
&        [F:MFM]MFM0 = [F:MFI]MFGNUM;[F:MFI]MFGLIN
&   As [MFIX]
&   Where evalue(CRITERE1)&evalue(CRITERE11)&evalue(CRITERE12)&evalue(CRITERE3)&
&   evalue(CRITERE4)&evalue(FORMULE1)
&   Order By Key MFI0
Else
# 44344 mm 12.09
    Link [MFI]
&   With [F:MFG]MFG0=[F:MFI]MFGNUM,
&        [F:MFM]MFM0(0) = [F:MFG]MFGNUM
&   As [MFIX]
&   Where evalue(CRITERE1)&evalue(CRITERE11)&evalue(CRITERE12)&evalue(CRITERE3)&
&   evalue(FORMULE1)
&   Order By Key MFI0
Endif
nolign = 1

For [MFIX]

    If nolign = WMAX : Break : Endif
    If CRITERE4 <>"1=1"
        If WMFGNUM = [F:MFM]MFGNUM & WMFGLIN = [F:MFM]MFGLIN : Goto NXT1 : Endif
        WMFGNUM = [F:MFM]MFGNUM
        WMFGLIN = [F:MFM]MFGLIN
    Else
        # 61390 mm 01.10 - pour que chaque OF n'apparaisse qu'une fois dans la tableau
        If WMFGNUM = [F:MFM]MFGNUM: Goto NXT1 : Endif
        WMFGNUM = [F:MFM]MFGNUM
    Endif
    [M:MWG] = [F:MFI]
    Read [ITM]ITM0=[F:MFI]ITMREF
    #[M:MWG]ITMDES1(nolign-1) = [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MWG]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
     If   [F:MFG]WGGFLG = 2
          [M:MWG]COCHAGE(nolign-1)    = 1
          [M:MWG]COCHAGE_AV(nolign-1) = 1
     Endif
     If   [F:MFG]WGGFLG = 3
          [M:MWG]COCHAGE(nolign-1)    = 2
          [M:MWG]COCHAGE_AV(nolign-1) = 2
     Endif

    [M:MWG]ALLSTA(nolign-1)     = [F:MFG]ALLSTA
    [M:MWG]DETALLNBR(nolign-1)  = [F:MFG]DETALLNBR
    [M:MWG]OVRALLNBR(nolign-1)  = [F:MFG]OVRALLNBR
    [M:MWG]MFGMOD(nolign-1)     = [F:MFG]MFGMOD
    [M:MWG]MATLINNBR(nolign-1)  = [F:MFG]MATLINNBR
    [M:MWG]MFGTRKFLG(nolign-1)  = [F:MFG]MFGTRKFLG


    If [F:MFG]ITMLINNBR <> 1 [M:MWG]WX(nolign-1)     = "*" : Endif
    nolign += 1
$NXT1
Next
If nolign = WMAX : Call MESSAGE(mess(168,190,1)) From GESECRAN: Endif   # 01.06 demande 34108

[M:MWG]NBLIG  = nolign-1
Gosub TRI_TAB
Affzo [M:MWG]5,10,20

#
Return

###########################################################################
$TRI_TAB
If [M:MWG]NBLIG <> 0
    Case [M:MWG]SRTCOD
        When 1: Sorta [M:MWG]NBLIG [M:MWG]NBLIG Order By [M:MWG]MFGFCY(indice),
&                                                        [M:MWG]MFGNUM(indice),
&                                                        [M:MWG]STRDAT(indice)
        When 2: Sorta [M:MWG]NBLIG [M:MWG]NBLIG Order By [M:MWG]ITMREF(indice),
&                                                        [M:MWG]STRDAT(indice)
        When 3: Sorta [M:MWG]NBLIG [M:MWG]NBLIG Order By [M:MWG]STRDAT(indice)
    Endcase
Endif
Return

########################################################################
$LECTURE_BTS
#----- Relecture transaction de saisie  -----#
If [F:BTS]BTSTYP <> 90 | [F:BTS]BTSNUM <> GMGLNUM
    Read [BTS]BTS0=90;GMGLNUM : If fstat Raz [F:BTS] : Endif
Endif

Return

########################################################################
$FIN
Local Integer WRET
Kill GMGLNUM
Call IMPSCR From ATRTX3
#PARAM(8) = num$(LRETOK)
Return


########################################################################
$ABA
Effzo [M:MWG]
Return

######################################################################
$VALIDATION
Gosub PLAN_PESEE
#If VALOK = 2
#   Effzo [M:MWG]20
#Endif
Return

########################################
$PLAN_PESEE
Local Integer I,WOK
Local Integer  WRET
Local    Char    WSITE
Local    Integer WTRK

#
# Y a-t-il quelque chose de modifier ?
If [M:MWG]NBLIG = 0 : Return : Endif

VALOK = 0
For I = 0 To [M:MWG]NBLIG-1

        If [M:MWG]COCHAGE_AV(I) <> [M:MWG]COCHAGE(I)
           VALOK = 1
           Break
        Endif
Next I
If VALOK = 0 : Return : Endif
#
# Message de confirmation...
VALOK = 1
Call OUINON(mess(20,196,1),VALOK) From GESECRAN
If VALOK = 1 : Return : Endif
#
#On y va ...
#
I = 0
For I = 0 To [M:MWG]NBLIG-1

   If [M:MWG]COCHAGE_AV(I) <> [M:MWG]COCHAGE(I)

# MAJ entête d'OF
# allocation
#    si plan de pesée est a OUI
#    si nbre de matiere different de 0
#    si non alloué
#    si mode d allocation n est pas Manuel dans le parametrage de la transaction
      If [M:MWG]COCHAGE(I) = 2
         If [M:MWG]MATLINNBR(I) <> 0
#            If [M:MWG]ALLSTA(I)    = 1
               If [F:BTS]MODALL  <> 1
                  LMFGNUM = [M:MWG]MFGNUM(I)
#
                  Global Char   GGREP  : GGREP = ""
                  Local Integer WRET   : WRET = 0
                  Local Char    WNUM
                  Local Integer WALL
                  WALL = [F:BTS]MODALL
                  WALL -= 1
                  Call ALLOC_OF("C", 1, LMFGNUM,WALL, 1, WRET) From MFGALL
               Endif
#           Endif
         Endif
      Endif



    Call DEBTRANS From GLOCK
    Trbegin ADOVAL
      Readlock [F:MFG]MFG0 = [M:MWG]MFGNUM(I)
         If fstat=1     GOK=-1 : GLOCK="$MFGHEAD"-[M:MWG]MFGNUM(I) : Return
               Elsif fstat GOK=0  : Call RSTA("MFG",[M:MWG]MFGNUM(I)) From GLOCK
            Return
         Endif
         If [M:MWG]COCHAGE(I)    = 2
            [F:MFG]WGGFLG  = 3
         Endif
         If [M:MWG]COCHAGE(I)    = 1
            [F:MFG]WGGFLG  = 2
         Endif

       Rewrite [F:MFG]
         If fstat
               GOK = 0 : Call FSTA("MFG") From GLOCK : Return
         Endif
    Commit
   Endif
Next I
Return



###########################################################################
# ETIQUETTES                                                              #
###########################################################################

########################################

########################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
If GFCY <> VALEUR
    GFCY = VALEUR
Endif
Gosub CHARG_PARAM
End

########################################
Subprog C_ITMREFSTR(VALEUR)
Variable Char    VALEUR()

Local    Char    WFCY : WFCY = [M:MWG]FCY
Local    Char    WART : WART = VALEUR
Local    Char    WUSR : WUSR = [M:MWG]PLANNER

If VALEUR = "" : End : Endif

If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
Endif

If WFCY <> ""
    Call CTLPLNFLT(WFCY, WART, WUSR) From MFGLIB
    If GMESSAGE <> ""
        mkstat = 2
    Endif
Endif



End

########################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()

If [M:MWG]ITMREFEND = ""     : [M:MWG]ITMREFEND = VALEUR : Affzo [M:MWG]ITMREFEND : Endif
If [M:MWG]ITMREFEND < VALEUR : [M:MWG]ITMREFEND = VALEUR : Affzo [M:MWG]ITMREFEND : Endif



End


########################################
Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY : WFCY = [M:MWG]FCY
Local    Char    WART : WART = VALEUR
Local    Char    WUSR : WUSR = [M:MWG]PLANNER

If VALEUR = "" : End : Endif

If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
Endif

If WFCY <> ""
    Call CTLPLNFLT(WFCY, WART, WUSR) From MFGLIB
    If GMESSAGE <> ""
        mkstat = 2
    Endif
Endif
End


########################################
Subprog AM_MFGNUMSTR(VALEUR)
Variable Char    VALEUR()

If [M:MWG]MFGNUMEND = ""     : [M:MWG]MFGNUMEND = VALEUR : Affzo [M:MWG]MFGNUMEND : Endif
If [M:MWG]MFGNUMEND < VALEUR : [M:MWG]MFGNUMEND = VALEUR : Affzo [M:MWG]MFGNUMEND : Endif

End


########################################
Subprog C_STRDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:MFW1]STRDATSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End

########################################################################
$CHARG_PARAM
Return


########################################
Subprog C_MFGPIOEND(VALEUR)
Variable Integer VALEUR
If VALEUR < [M:MFW1]MFGPIOSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog C_ENDDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]ENDDATSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End

########################################
Subprog AM_COCHAGE(VALEUR)
Variable Integer VALEUR
Local Integer  WRET   : WRET = 0
Local Integer  WTEST  : WTEST = 0
Local Integer  WALLSTA

If VALEUR = 1  : End : Endif

If clalev ([F:MFM]) <= 0 : Local File MFGMAT     [MFM] : Endif
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif

# y a t il au  moins une matière bloquante si rupture
For [MFM] Where MFGNUM = [M:MWG]MFGNUM(nolign-1)
        # 44044 mm 01.08 - ligne soldée ou exclue
        If [F:MFM]MATSTA >= 3 : Goto NEXT1 : Endif
        Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
        If fstat : Raz [F:ITF] : Endif
        If [F:ITF]MFGSHTCOD = 1
           WTEST = 1
           WALLSTA = [F:MFM]ALLSTA     # 44044 mm 01.08

           Break
        Endif
$NEXT1
Next

# pas de matière bloquante si rupture, on part
If WTEST = 0 End : Endif

#sinon allocation et vérification qu'il n'y a pas de rupture
Call ALLOC_OF("C", 1, [M:MWG]MFGNUM(nolign-1),2, 1, WRET) From MFGALL

# boucle d'analyse des matières bloquantes si rupture
For [MFM] Where MFGNUM = [M:MWG]MFGNUM(nolign-1)
    If [F:MFM]MATSTA >= 3 : Goto NEXT2 : Endif    # 44044 mm 01.08
    If [F:MFM]SHTQTY <> 0
        Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
        If fstat : Raz [F:ITF] : Endif
        If [F:ITF]MFGSHTCOD = 1
           GMESSAGE = mess(28,2324,1) : mkstat = 1

           Break
        Endif
    Endif
$NEXT2
Next

Case WALLSTA
    When 1 : # matière non allouée
             Call ALLOC_OF("A", 1,[M:MWG]MFGNUM(nolign-1), 2,1,WRET) From MFGALL
    When 2,3 : # Allocation globale avec ou sans rupture
             Call ALLOC_OF("A", 1,[M:MWG]MFGNUM(nolign-1), 2,1,WRET) From MFGALL
             Call ALLOC_OF("C", 1,[M:MWG]MFGNUM(nolign-1), 1,1,WRET)From MFGALL

Endcase

End

##########################################################################
## Etiquette ajoutée par le superviseur 25/11/2003 13:19:10 (SR)
##########################################################################
Subprog IB_NBLIG
Local Integer WB
If [M:MWG]NBLIG = 0 : End : Endif

If [M:MWG]RMNEXTQTY(nolign-1) <= 0
    Raz GBOUT4
Endif
If [M:MWG]RMNEXTQTY(nolign-1) <= 0
    Raz GBOUT5
Endif

WB = 2
# pas d'allocation si pas plan pesée à oui
If [M:MWG]COCHAGE(nolign-1)    <> 2 : WB = 1 : Endif

 # pas d'allocation si mode de lancemant est à operations seules
If [M:MWG]MFGMOD(nolign-1)    = 3 : WB = 1 : Endif

# pas d'allocation si of non ferme
If [M:MWG]MFGSTA(nolign-1)    <> 1: WB = 1 : Endif

 # pas d'allocation of soldé ou prix de revient calculé
If [M:MWG]MFGTRKFLG(nolign-1) > 4 : WB = 1 : Endif

# pas d'allocation si pas de matiere
If [M:MWG]MATLINNBR(nolign-1) = 0 : WB = 1 : Endif

If WB <> 2
   Raz GBOUT6
Endif
End




