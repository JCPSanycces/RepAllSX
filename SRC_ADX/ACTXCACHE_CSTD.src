#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe ACONTEXTACACHE

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#  When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
  When "GET_PARAM_CHAR"      : Gosub GET_PARAM
  When "GET_PARAM_NUM"       : Gosub GET_PARAM
  When "GET_PARAM_DATE"      : Gosub GET_PARAM
  When "GET_PARAM_USER_CHAR" : Gosub GET_PARAM_USER
  When "GET_PARAM_USER_NUM"  : Gosub GET_PARAM_USER
  When "GET_PARAM_USER_DATE" : Gosub GET_PARAM_USER
  When "GET_PARAM_ERROR"     : Gosub GET_PARAM_ERROR
  When "CLEAN"               : Gosub CLEAN
Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return






##########################################################################################

$INIT_LIST_LEG
 If fmet this.AGETATTRIBUTE("LIST_LEG","STA")<>"1"
  Local Integer J,RES,T_NBLEG
  Local Char T_FOLDLEG(10)(1..40)
  Raz this.LIST_LEG
  Call SETLEG(this.APARENT.AFOLDER ,T_FOLDLEG,T_NBLEG) From DOSCONT
  For J = 1 To T_NBLEG
   this.LIST_LEG(J) = T_FOLDLEG(J)
  Next
  RES = fmet this.ASETATTRIBUTE("LIST_LEG","STA","1")
  Kill J,RES,T_NBLEG, T_FOLDLEG
 Endif
Return

$INIT_LIST_CPY
 If fmet this.AGETATTRIBUTE("LIST_CPY","STA")<>"1"
  Local Integer J, RES
  Local File =this.APARENT.AFOLDER +".COMPANY" [CPY]
  Raz this.LIST_CPY
  For [CPY]
   J += 1
   this.LIST_CPY(J) = [CPY]CPY
  Next
  RES = fmet this.ASETATTRIBUTE("LIST_CPY","STA","1")
  Close Local File [CPY]
  Kill J,RES
 Endif
Return

$INIT_LIST_SITE
 If fmet this.AGETATTRIBUTE("LIST_SITE","STA")<>"1"
  Local Integer J, RES
  Local File =this.APARENT.AFOLDER +".FACILITY" [FCY]
  Raz this.LIST_SITE
  For [FCY]
   J += 1
   this.LIST_SITE(J) = [FCY]FCY
  Next
  RES = fmet this.ASETATTRIBUTE("LIST_CPY","STA","1")
  Close Local File [FCY]
  Kill J,RES
 Endif
Return

# ---------- for $GET_PARAM internal use only ---------- #
$L_IDENTIFY_TYPCOD
 # check if TYPVAL is a "Dossier" code:
 If TYPVAL = this.APARENT.AFOLDER
  TYPCOD = 1
 Endif
 If TYPCOD = 0
  # check if TYPVAL is a "Legislation" code:
  Gosub INIT_LIST_LEG
  If (func L_CHECK_EXIST(TYPVAL, this.LIST_LEG))>0
   TYPCOD = 5
  Endif
 Endif
 If TYPCOD = 0
  # check if TYPVAL is a "Company" code:
  Gosub INIT_LIST_CPY
  If (func L_CHECK_EXIST(TYPVAL, this.LIST_CPY))>0
   TYPCOD = 2
  Endif
 Endif
 If TYPCOD = 0
  # check if TYPVAL is a "Site" code:
  Gosub INIT_LIST_SITE
  If (func L_CHECK_EXIST(TYPVAL, this.LIST_SITE))>0
   TYPCOD = 3
  Endif
 Endif
 If TYPCOD = 0
  # Error 8: can not identify TYPVAL
  this.ERRCOD = 8
  Gosub L_END
  Return
 Endif
Return



##########################################################################################

$GET_PARAM
Local Integer I
Local Integer L_FOUND_CACHE, L_FOUND_DB
Local Char PARAM_KEY(50), L_VALEUR(255)
Local Char L_LEG(GLONADI), L_CPY(GLONCPY)
Local File =this.APARENT.AFOLDER+".ADOPAR" [ADP]

this.isReadonly = 0
this.ERRCOD = 0

If PARAM = ""
 # Error 2: PARAM empty
 this.ERRCOD = 2
 Gosub L_END
 Return
Endif

Case TYPCOD
 When 1:
  If TYPVAL = "" : TYPVAL =  this.APARENT.AFOLDER : Endif
  If TYPVAL <> this.APARENT.AFOLDER
   # Error 3: this method can only be used to get parameter value for the current folder
   this.ERRCOD = 3
   Gosub L_END
   Return
  Endif
 When 0,2,3,5:
  If TYPVAL = ""
   # Error 4: TYPVAL can not be empty
   this.ERRCOD = 4
   Gosub L_END
   Return
  Endif
  If TYPCOD = 0
   Gosub L_IDENTIFY_TYPCOD
  Endif
 When Default :
  # Error 1: Wrong TYPCOD
  this.ERRCOD = 1
  Gosub L_END
  Return
Endcase


#############################################
# build the key : TYPCOD~TYPVAL~PARAM       #
#############################################
PARAM_KEY = func L_BUILD_PARAM_KEY(TYPCOD, TYPVAL, PARAM)


#############################################
# Try to find the value in the cache table: #
#############################################
Case ACTION
 When "GET_PARAM_CHAR" :
  I = find(PARAM_KEY,this.TAB_CHA1_IND)
  If I>0
   [L]ARET_VALUE = this.TAB_CHA1_VAL(I)
   L_FOUND_CACHE = 1
  Else
   I = find(PARAM_KEY,this.TAB_CHA2_IND)
   If I>0
    [L]ARET_VALUE = this.TAB_CHA2_VAL(I)
    L_FOUND_CACHE = 1
   Else
    I = find(PARAM_KEY,this.TAB_CHA3_IND)
    If I>0
     [L]ARET_VALUE = this.TAB_CHA3_VAL(I)
     L_FOUND_CACHE = 1
    Endif
   Endif
  Endif
 When "GET_PARAM_NUM"  :
  I = find(PARAM_KEY,this.TAB_NUM_IND)
  If I>0
   [L]ARET_VALUE = this.TAB_NUM_VAL(I)
   L_FOUND_CACHE = 1
  Endif
 When "GET_PARAM_DATE" :
  I = find(PARAM_KEY,this.TAB_DAT_IND)
  If I>0
   [L]ARET_VALUE = this.TAB_DAT_VAL(I)
   L_FOUND_CACHE = 1
  Endif

Endcase
#-------------------------------------------------#

# in case not found from the cache, search in database:
If !L_FOUND_CACHE
 Read [ADP]ADP1 = PARAM

 ############################################
 # error checks                             #
 ############################################
 If fstat
  # Error 5: PARAM does not exist
  this.ERRCOD = 5
  Gosub L_END
  Return
 Endif

 Case ACTION
  When "GET_PARAM_CHAR" :
   If [ADP]TYPVAL <> 1
    # Error 6: PARAM is not of the right type : Alpha
    this.ERRCOD = 6
    Gosub L_END
    Return
   Endif
  When "GET_PARAM_NUM"  :
   If [ADP]TYPVAL <> 2 and [ADP]TYPVAL <> 4
    # Error 6: PARAM is not of the right type : numeric
    this.ERRCOD = 6
    Gosub L_END
    Return
   Endif
  When "GET_PARAM_DATE" :
   If [ADP]TYPVAL <> 3
    # Error 6: PARAM is not of the right type : Date
    this.ERRCOD = 6
    Gosub L_END
    Return
   Endif
 Endcase

 If [ADP]NIVDEF = 4 and [ADP]VALDEF <> 2
  # Error 7: PARAM can only be defined at User level
  this.ERRCOD = 7
  Gosub L_END
  Return
 Endif

 Case TYPCOD
  When 5: # looking for value at "Législation" level
   Gosub INIT_LIST_LEG
   If !(func L_CHECK_EXIST(TYPVAL, this.LIST_LEG))
    # Error 8:  Législation code does not exist
    this.ERRCOD = 8
    Gosub L_END
    Return
   Endif
  When 2: # looking for value at "Société" level
   Gosub INIT_LIST_CPY
   If ! (func L_CHECK_EXIST(TYPVAL, this.LIST_CPY))
    # Error 8:  Company code does not exist
    this.ERRCOD = 8
    Gosub L_END
    Return
   Endif
  When 3: # looking for value at "Site" level
   Gosub INIT_LIST_SITE
   If !(func L_CHECK_EXIST(TYPVAL, this.LIST_SITE))
    # Error 8:  Site code does not exist
    this.ERRCOD = 8
    Gosub L_END
    Return
   Endif
 Endcase

 #-------------------------------------------------#


 ############################################
 # search in the database                   #
 ############################################

 Call GET_PARAM_SUB(this.APARENT.AFOLDER , TYPCOD, TYPVAL, PARAM, L_FOUND_DB, L_VALEUR) From ADP_TOOL

  #-------------------------------------------------#
  If L_FOUND_DB
   # add the value into the cache table
   Case ACTION
    When "GET_PARAM_CHAR" :
     [L]ARET_VALUE = L_VALEUR
     If len([L]ARET_VALUE)<=32
      this.TAB_CHA1_IND(maxtab(this.TAB_CHA1_IND)+1) = PARAM_KEY
      this.TAB_CHA1_VAL(maxtab(this.TAB_CHA1_VAL)+1) = [L]ARET_VALUE
     Elsif len([L]ARET_VALUE)<=128
      this.TAB_CHA2_IND(maxtab(this.TAB_CHA2_IND)+1) = PARAM_KEY
      this.TAB_CHA2_VAL(maxtab(this.TAB_CHA2_VAL)+1) = [L]ARET_VALUE
     Else
      this.TAB_CHA3_IND(maxtab(this.TAB_CHA3_IND)+1) = PARAM_KEY
      this.TAB_CHA3_VAL(maxtab(this.TAB_CHA3_VAL)+1) = [L]ARET_VALUE
     Endif
    When "GET_PARAM_NUM"  :
     [L]ARET_VALUE = val(L_VALEUR)
     this.TAB_NUM_IND(maxtab(this.TAB_NUM_IND)+1) = PARAM_KEY
     this.TAB_NUM_VAL(maxtab(this.TAB_NUM_VAL)+1) = [L]ARET_VALUE
    When "GET_PARAM_DATE" :
     If len(L_VALEUR)=6 or len(L_VALEUR)=8
      [L]ARET_VALUE = L_VALEUR
     Else
      [L]ARET_VALUE = "00000000"
      If L_VALEUR <> ""
       # Error 9: incorrect Date format
       this.ERRCOD = 9
      Endif
     Endif
     this.TAB_DAT_IND(maxtab(this.TAB_DAT_IND)+1) = PARAM_KEY
     this.TAB_DAT_VAL(maxtab(this.TAB_DAT_VAL)+1) = [L]ARET_VALUE
   Endcase

  Endif
 Endif

$L_END
this.isReadonly = 1
Kill I, PARAM_KEY, L_FOUND_CACHE, L_FOUND_DB, L_VALEUR,L_LEG, L_CPY
Close Local File [ADP]
Return




##########################################################################################

$GET_PARAM_USER
Local Integer I
Local Integer L_FOUND_CACHE, L_FOUND_DB, L_MODULE
Local Char L_SITE(GLONFCY), L_PROFILE(GLONAFT), L_VALEUR(255)
#Local File =this.APARENT.AFOLDER+".ADOPAR"    [ADP]
If clalev([F:ADP])=0 : Local File =this.APARENT.AFOLDER+".ADOPAR"  [ADP] : Endif


this.isReadonly = 0
this.ERRCOD = 0

If PARAM = ""
 # Error 2: PARAM empty
 this.ERRCOD = 2
 Gosub L_END_USER
 Return
Endif


#############################################
# Try to find the value in the cache table: #
#############################################
Case ACTION
 When "GET_PARAM_USER_CHAR" :
  I = find(PARAM,this.TAB_CH1U_IND)
  If I>0
   [L]ARET_VALUE = this.TAB_CH1U_VAL(I)
   L_FOUND_CACHE = 1
  Else
   I = find(PARAM,this.TAB_CH2U_IND)
   If I>0
    [L]ARET_VALUE = this.TAB_CH2U_VAL(I)
    L_FOUND_CACHE = 1
   Else
    I = find(PARAM,this.TAB_CH3U_IND)
    If I>0
     [L]ARET_VALUE = this.TAB_CH3U_VAL(I)
     L_FOUND_CACHE = 1
    Endif
   Endif
  Endif
 When "GET_PARAM_USER_NUM"  :
  I = find(PARAM,this.TAB_NUMU_IND)
  If I>0
   [L]ARET_VALUE = this.TAB_NUMU_VAL(I)
   L_FOUND_CACHE = 1
  Endif
 When "GET_PARAM_USER_DATE" :
  I = find(PARAM,this.TAB_DATU_IND)
  If I>0
   [L]ARET_VALUE = this.TAB_DATU_VAL(I)
   L_FOUND_CACHE = 1
  Endif
Endcase
#-------------------------------------------------#

# in case not found from the cache, search in database:
If !L_FOUND_CACHE
 ############################################
 # error checks                             #
 ############################################
 Read [ADP]ADP1 = PARAM
 If fstat
  # Error 5: PARAM does not exist
  this.ERRCOD = 5
  Gosub L_END_USER
  Return
 Endif
 If [ADP]NIVDEF <> 4
  # Error 10: PARAM is not defined at User level
  this.ERRCOD = 10
  Gosub L_END_USER
  Return
 Endif
 Case ACTION
  When "GET_PARAM_USER_CHAR" :
   If [ADP]TYPVAL <> 1
    # Error 6: PARAM is not of the right type: Alpha
    this.ERRCOD = 6
    Gosub L_END_USER
    Return
   Endif
  When "GET_PARAM_USER_NUM"  :
   If [ADP]TYPVAL <> 2 and [ADP]TYPVAL <> 4
    # Error 6: PARAM is not of the right type: numeric
    this.ERRCOD = 6
    Gosub L_END_USER
    Return
   Endif
  When "GET_PARAM_USER_DATE" :
   If [ADP]TYPVAL <> 3
    # Error 6: PARAM is not of the right type: Date
    this.ERRCOD = 6
    Gosub L_END_USER
    Return
   Endif
 Endcase
 #-------------------------------------------------#


 ############################################
 # search in the database                   #
 ############################################
 Call GET_PARAM_USER_SUB(this.APARENT.AFOLDER , this.APARENT.USER, PARAM, L_FOUND_DB, L_VALEUR) From ADP_TOOL

 If L_FOUND_DB
  # add the value into the cache table
  Case ACTION
   When "GET_PARAM_USER_CHAR" :
    [L]ARET_VALUE = L_VALEUR
    If len([L]ARET_VALUE)<=32
     this.TAB_CH1U_IND(maxtab(this.TAB_CH1U_IND)+1) = PARAM
     this.TAB_CH1U_VAL(maxtab(this.TAB_CH1U_VAL)+1) = [L]ARET_VALUE
    Elsif len([L]ARET_VALUE)<=128
     this.TAB_CH2U_IND(maxtab(this.TAB_CH2U_IND)+1) = PARAM
     this.TAB_CH2U_VAL(maxtab(this.TAB_CH2U_VAL)+1) = [L]ARET_VALUE
    Else
     this.TAB_CH3U_IND(maxtab(this.TAB_CH3U_IND)+1) = PARAM
     this.TAB_CH3U_VAL(maxtab(this.TAB_CH3U_VAL)+1) = [L]ARET_VALUE
    Endif
   When "GET_PARAM_USER_NUM"  :
    [L]ARET_VALUE = val(L_VALEUR)
    this.TAB_NUMU_IND(maxtab(this.TAB_NUMU_IND)+1) = PARAM
    this.TAB_NUMU_VAL(maxtab(this.TAB_NUMU_VAL)+1) = [L]ARET_VALUE
   When "GET_PARAM_USER_DATE" :
    If len(L_VALEUR)=6 or len(L_VALEUR)=8
     [L]ARET_VALUE = L_VALEUR
    Else
     [L]ARET_VALUE = "00000000"
     If L_VALEUR <> ""
      # Error 9: incorrect Date format
      this.ERRCOD = 9
     Endif
    Endif
    this.TAB_DATU_IND(maxtab(this.TAB_DATU_IND)+1) = PARAM
    this.TAB_DATU_VAL(maxtab(this.TAB_DATU_VAL)+1) = [L]ARET_VALUE
  Endcase
 Endif

Endif

$L_END_USER
this.isReadonly = 1
Kill I, L_FOUND_CACHE, L_FOUND_DB, L_VALEUR
#Close Local File [ADP]
Return


##########################################################################################
# Error 1: Wrong TYPCOD
# Error 2: PARAM empty
# Error 3: This method can only be used to get parameter value for the current folder
# Error 4: TYPVAL cannot be empty
# Error 5: PARAM does not exist
# Error 6: PARAM is not of the right type
# Error 7: PARAM can only be defined at User level
# Error 8: Code TYPVAL does not exist
# Error 9: Incorrect Date format
# Error 10: PARAM is not defined at User level

$GET_PARAM_ERROR
[L]ARET_VALUE = this.ERRCOD
Return


##########################################################################################
# restore the cache tables
$CLEAN
 this.isReadonly = 0
 Local Integer RES

 Raz this.TAB_NUM_IND
 Raz this.TAB_NUM_VAL
 Raz this.TAB_CHA1_IND
 Raz this.TAB_CHA1_VAL
 Raz this.TAB_CHA2_IND
 Raz this.TAB_CHA2_VAL
 Raz this.TAB_CHA3_IND
 Raz this.TAB_CHA3_VAL
 Raz this.TAB_DAT_IND
 Raz this.TAB_DAT_VAL

 Raz this.TAB_NUMU_IND
 Raz this.TAB_NUMU_VAL
 Raz this.TAB_CH1U_IND
 Raz this.TAB_CH1U_VAL
 Raz this.TAB_CH2U_IND
 Raz this.TAB_CH2U_VAL
 Raz this.TAB_CH3U_IND
 Raz this.TAB_CH3U_VAL
 Raz this.TAB_DATU_IND
 Raz this.TAB_DATU_VAL

 Raz this.LIST_LEG
 Raz this.LIST_CPY
 Raz this.LIST_SITE

 Raz this.ERRCOD

 RES = fmet this.ASETATTRIBUTE("LIST_LEG","STA","0")
 RES = fmet this.ASETATTRIBUTE("LIST_CPY","STA","0")
 RES = fmet this.ASETATTRIBUTE("LIST_SITE","STA","0")

 Kill RES
 this.isReadonly = 1
Return

##########################################################################################
Funprog L_CHECK_EXIST(ELEMENT, LIST)
Value Char ELEMENT
Variable Char LIST()(1..)
 Local Integer I,OK
 I = find(ELEMENT, LIST)
 If I>0 : OK = 1 : Endif
End OK

##########################################################################################
Funprog L_BUILD_PARAM_KEY(TYPCOD, TYPVAL, PARAM)
Value Integer TYPCOD
Value Char TYPVAL, PARAM
 Local Char RES_PARAM_KEY(50)
 RES_PARAM_KEY = num$([L]TYPCOD)+"~"+[L]TYPVAL+"~"+[L]PARAM
End RES_PARAM_KEY
$ACTION
Case ACTION
 When Default
Endcase
Return

