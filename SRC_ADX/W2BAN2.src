Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_FLDFIFCP
Call AM_FLDFIFCP(zc)
If !mkstat & GOBJET
 zoncou = "FLDFIFCP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_FLDFIFCP(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_FLDFIFCP(VALEUR) From SUBBAN
If mkstat : GERR = 1 : GZONE = "FLDFIFCP" : GZNUM = 1003189 : Endif
Gosub _AFF
End

