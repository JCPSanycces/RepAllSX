#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque BAN2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_ZCUR
Onevent BEFORE_AREA Gosub AV_ZCUR From W2BAN2
Return

$AV_ZCUR
Call LECTEXTRA(zc,"TABCUR","INTSHO",num$([M]CUR(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_CHGTYP
Onevent BEFORE_INPUT Call AS_CHGTYP(zc) From W2BAN2
Onevent INIT_AREA Call D_CHGTYP(zc) From W2BAN2
Return

Subprog D_CHGTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]CHGTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_CHGTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_CHGTYP(VALEUR) From SUBBAN
If mkstat=2
 [M]CHGTYP(INDIC) = VALEUR
 Affzo CHGTYP(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CHGDAT
Onevent BEFORE_INPUT Call AS_CHGDAT(zc) From W2BAN2
Onevent CONTROL Call C_CHGDAT(zc) From W2BAN2
Onevent BEFORE_AREA Gosub AV_CHGDAT From W2BAN2
Return

$AV_CHGDAT
Chgfmt [M]CHGDAT(indice) With "DzZ:"+GFMDAT
Gosub _AFF
Return

Subprog AS_CHGDAT(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_CHGDAT(VALEUR) From SUBBAN
If mkstat=2
 [M]CHGDAT(INDIC) = VALEUR
 Affzo CHGDAT(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_CHGDAT(VALEUR)
Variable Date    VALEUR
## Action STD
Call C_CHGDAT(VALEUR) From SUBBAN
If mkstat : GERR = 1 : GZONE = "CHGDAT" : GZNUM = 18907 : Endif
Gosub _AFF
End

