$ON_BIDEXS
Onevent BEFORE_AREA Gosub AV_BIDEXS From W2BAN2
Onevent CONTROL Call C_BIDEXS(zc) From W2BAN2
Onevent AFTER_CHANGE Gosub AMM_BIDEXS From W2BAN2
Return

$AV_BIDEXS
If !GWEBSERV
 ## Action FMTBIDPAY
 Call FMTBIDPAY([M:BAN1]CRY) From TRTDIV
Endif
If GFMT<>""
 Chgfmt [M]BIDEXS(indice) With "K:"+GFMT
Else
 Chgfmt [M]BIDEXS(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog C_BIDEXS(VALEUR)
Variable Char    VALEUR()
## Action CONTRIB
Call CONTRIB(VALEUR,[M:BAN1]CRY) From CONTNUM
If mkstat : GERR = 1 : GZONE = "BIDEXS" : GZNUM = 352 : Endif
Gosub _AFF
End

$AMM_BIDEXS
Call AM_BIDEXS(zc)
If !mkstat & GOBJET
 zoncou = "BIDEXS" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_BIDEXS(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_BIDEXS(VALEUR) From SUBBAN
If mkstat : GERR = 1 : GZONE = "BIDEXS" : GZNUM = 352 : Endif
Gosub _AFF
End

$ON_CUREXS
Onevent BEFORE_INPUT Call AS_CUREXS(zc) From W2BAN2
Onevent CONTROL Call C_CUREXS(zc) From W2BAN2
Return

Subprog AS_CUREXS(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3837,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_CUREXS(VALEUR) From SUBBAN
If mkstat=2
 [M]CUREXS(INDIC) = VALEUR
 Affzo CUREXS(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CUREXS(zc) From W2BAN2
Onkey   2 Titled GBOUTS Call S_CUREXS(zc) From W2BAN2
Onkey 144 Titled GBOUTP Call P_CUREXS(zc) From W2BAN2
Onkey 146 Titled GBOUTA Call SA_CUREXS(zc) From W2BAN2
Gosub _AFF
End

Subprog C_CUREXS(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("TCU","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "CUREXS" : GZNUM = 323 : Endif
If !mkstat
 ## Action STD
 Call C_CUREXS(VALEUR) From SUBBAN
 If mkstat : GERR = 1 : GZONE = "CUREXS" : GZNUM = 323 : Endif
Endif
Gosub _AFF
End

Subprog S_CUREXS(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TCU"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_CUREXS(VALEUR)
Variable Char    VALEUR()
Call OBJET("TCU",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CUREXS(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TCU"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CUREXS(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TCU",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

