$ACTION
Case ACTION
  When "SETBOUT"        : Gosub SETBOUT
  When "EXEBOUT"        : Gosub EXEBOUT
  When "LIENS"          : Gosub LIENS
  When "CREATION"       : Gosub MAJ            # FQ 52915 
  When "MODIF"          : Gosub MAJ            # FQ 52915 
  When "VERIF_CRE"      : Gosub VERIF
  When "VERIF_MOD"      : Gosub VERIF
  When "AV_IMPRIME"     : Gosub COP_ECRAN
                          OK = 0 
  When "ANNULE"         : Gosub ANNULE         # FGR 15/02/2010 : X3SUIVI62541
  When "CHANGE"         : Gosub CHANGE         # FGR 15/02/2010 : X3SUIVI62541
  When "FERME"          : Call IMPSCR From ATRTX3
  When Default
Endcase
Return
