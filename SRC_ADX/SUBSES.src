$LIENS
Local Integer I
# FQ 52915 on affiche les dates sur l'année courante
For I = 0 To [M]SESNBR-1
    Call ANNEE_COURANTE([M]STRDAT(I))
    Call ANNEE_COURANTE([M]ENDDAT(I))
Next
# Recherche de la chaine date vide pour determiner premiere ligne inutilisee
#[M]SESNBR = find([0/0/0],[M]STRDAT(0..(dim([M]STRDAT)-1))) - 1
Gosub CALPOURCENT
# 49144 V5 chargement d'un bloc graphique Flash: les Ocx sont obsolètes
Gosub VISU_GRAPH
Affzo [M]
Return

