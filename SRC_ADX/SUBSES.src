#############################################################
$ANNULE
# FGR 15/02/2010 : X3SUIVI62541 : Textes traduisibles non gérés (début)
  #--- maj de la table des libéllés traduisibles
  Call SUPTEXTRA("SEASON","SESDESAXX",[L]CODE,"") From ATEXTRA
  Call SUPTEXTRA("SEASON","SESSHOAXX",[L]CODE,"") From ATEXTRA
# FGR 15/02/2010 : X3SUIVI62541 : Textes traduisibles non gérés (fin)
Return

############################################################
$MAJ
# FGR 15/02/2010 : X3SUIVI62541 : Textes traduisibles non gérés (début)
  Call MAJTEXTRA([M:SES1]SESDESAXX,"SEASON","SESDESAXX",num$([M:SES1]SESCOD),"") From ATEXTRA
  Call MAJTEXTRA([M:SES1]SESSHOAXX,"SEASON","SESSHOAXX",num$([M:SES1]SESCOD),"") From ATEXTRA
# FGR 15/02/2010 : X3SUIVI62541 : Textes traduisibles non gérés (fin)

Local Integer I
# FQ 52915 on enregistre les dates sur l'année 2999
For I = 0 To [M]SESNBR-1
    Call ANNEE_2999([M]STRDAT(I))
    Call ANNEE_2999([M]ENDDAT(I))
Next
Return

############################################################
$VERIF
#--> Vérification cohérence de la courbe (0101 jusqu'au 3112 sans trou) 
# FQ 44732          If [M]STRDAT(0) <> [01/01/2999]
If  day([M]STRDAT(0))>1 | month([M]STRDAT(0))>1 
    GMESSAGE = mess(1,104,1)-mess(61,100,1)-"1"
    OK = 0 : Return 
Endif 
# FQ 44732         If  [M]ENDDAT([M]SESNBR-1) <> [31/12/2999]
If  day([M]ENDDAT([M]SESNBR-1))<31 | month([M]ENDDAT([M]SESNBR-1))<12 
    GMESSAGE = mess(1,104,1)-mess(61,100,1)-num$([M]SESNBR)
    OK = 0 : Return 
Endif 
For I = 1 To [M]SESNBR-1
    If  [M]STRDAT(I) <> [M]ENDDAT(I-1)+1
        GMESSAGE = mess(1,104,1)-mess(61,100,1)-num$(I+1)
        OK = 0 : Break 
    Endif
Next I 
Return
############################################################
Subprog AS_STRDAT(VALEUR)
Variable Date     VALEUR
If    VALEUR=[0/0/0]
   If   nolign = 1
        VALEUR=gdat$(01, 01, year(date$)) # FQ 52915 avant [01/01/2999]
        mkstat = 2
   Else 
        VALEUR = [M]ENDDAT(nolign-2)+1
   Endif
Endif
End
############################################################
Subprog AS_ENDDAT(VALEUR)
Variable Date     VALEUR
# -- init
If   VALEUR=[0/0/0]
     VALEUR = eomonth([M]STRDAT(nolign-1)+1)
     # -- insertion
     If   [M]STRDAT(nolign) <> [0/0/0] & VALEUR >= [M]STRDAT(nolign)
          VALEUR = [M]STRDAT(nolign)-1
     Endif  
Endif
End
############################################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
Local Integer I
If year(VALEUR)<>year(date$)                                   # FQ 52915 avant 2999
   VALEUR=gdat$(day(VALEUR), month(VALEUR), year(date$))       # FQ 52915 avant 2999
Endif
For  I = 0 To dim([M]STRDAT)-1
     If  VALEUR >= [M]STRDAT(I) & VALEUR <= [M]ENDDAT(I) & I <> nolign-1
         GMESSAGE = mess(19,199,1) -num$(I+1)
         mkstat   = 1
         Break
     Endif
Next I
End
############################################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
Local Integer I
For  I = 0 To dim([M]STRDAT)-1
     If  [M]STRDAT(nolign-1) < [M]STRDAT(I) & VALEUR >= [M]STRDAT(I)
         If   VALEUR <= [M]ENDDAT(I)
              GMESSAGE = mess(19,199,1) -num$(I+1) : #  Date comprise dans période    
         Else GMESSAGE = mess(20,199,1) -num$(I+1) : #  Date au delà de la période
         Endif
         mkstat   = 1
         Break
     Endif
Next I
End
############################################################ 
Subprog AM_SESAMT(VALEUR) 
Variable Decimal VALEUR 
#CALCUL DES TOTAUX   
[M]SESAMT(nolign-1)=VALEUR  
Gosub CALPOURCENT   
Affzo [M] 10,20,25   
End 
############################################################ 
Subprog C_SESNBR
# -- reprise impossible après le 31.12 (rajout de ligne)
If   status = 82     #####| status = 1 n'est plus géré ! (13/03/01)
     If  nolign > 1
         If [M]ENDDAT(nolign-2) = gdat$(31, 12, year(date$)) # FQ 52915 avant [31/12/2999]
            GMESSAGE = mess(122,199,1)
            mkstat = 2
         Endif 
     Endif
Endif
End
############################################################ 
Subprog APRES_SESNBR
If   status = 65 | status = 68 | status = 83
     [M]SESAMT(nolign-1)=0
     Gosub CALPOURCENT
     Affzo [M] 10,20,25
Endif
End
############################################################### 
$CALPOURCENT
# Calcul pourcentage
Local Integer I,J
[M]TOTAL1 = sum([M]SESAMT)
[M]TOTAL2 = 100
If  [M]TOTAL1 = 0 : [M]TOTAL2 = 0 : Return : Endif
For I = 0 To dim([M]STRDAT)-1
    If [M]STRDAT(I) = [0/0/0] : I-=1: Break : Endif
    [M]SESPRC(I) = ([M]SESAMT(I) * 100) / [M]TOTAL1
    [M]SESPRC(I) = arr([M]SESPRC(I),0.01)
Next I

For J = I To 0 Step -1
    If [M]SESAMT(J) <> 0
       [M]SESPRC(J) =  0
       [M]SESPRC(J) =  100 - sum([M]SESPRC)
       Break
    Endif
Next J
Return
############################################################ 
$SETNOL
Local Integer NOL
NOL = nolign-1
Return

############################################################
Subprog AM_STRDAT(VALEUR)  # FQ 44732
Variable Date    VALEUR
   Call ANNEE_COURANTE(VALEUR) # FQ 52915 avant ANNEE_2999
End
############################################################
Subprog AM_ENDDAT(VALEUR)  # FQ 44732
Variable Date    VALEUR
   Call ANNEE_COURANTE(VALEUR) # FQ 52915 avant ANNEE_2999
End

############################################################
Subprog ANNEE_2999(VALEUR)  # FQ 44732
Variable Date    VALEUR
#If year(VALEUR)<>2999
#   VALEUR=gdat$(day(VALEUR), month(VALEUR), 2999)
#Endif
End

############################################################
Subprog ANNEE_COURANTE(VALEUR)  # FQ 52915 
Variable Date    VALEUR
# année courante pour faciliter l'utilisation du calendrier
If year(VALEUR)<>year(date$)
   VALEUR=gdat$(day(VALEUR), month(VALEUR), year(date$))
Endif
End

