#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque APASSMNTSYRA
Local Char VALEUR(GLONADD) , PARAM(250)(1..3)
Call SAISIE_CHAR(VALEUR,PARAM,"APASSMNTSYRA","APASSMNTSYRA","") From GSAISIE
Infbox num$(mkstat)
End

#-----------------------------------#
$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When "DEBUT" : Gosub DEBUT
 When "END"   : PARAM(2) = "" : mkstat = 1
 When "OK"    : PARAM(2) = [M]MOTIF
Endcase
Return

#-----------------------------------#
$OUVRE
Local Integer K , M , ER
Local Char    DOSSIER(GDIMFIC) , USER(GLONAUS) , MOTIF(GLONADI)
If PARAM(1)<>""
 DOSSIER = PARAM(1)
Else
 DOSSIER = nomap
Endif
MOTIF   = PARAM(2)
If dim(PARAM)>=3 & PARAM(3)<>""
 USER = PARAM(3)
Else
 USER = GUSER
Endif
If (func AFNC.PARAMUTIL("ASIGMNT","","")<>"2" or GADONIX=2)
 FIN = 1 : Return
Endif
If DOSSIER=nomap
 Local File AUTILIS [AUS]
Else
 Local File =DOSSIER+".AUTILIS" [AUS]
Endif
Return

#-----------------------------------#
$DEBUT
Raz [M]
[M]DOSSIER = DOSSIER
[M]MOTIF   = MOTIF
Affzo DOSSIER
#If USER<>""
# Call CONTROLE("AUS","",USER,"",mkstat) From CONTOBJ
# If !mkstat
#  [M]USER = USER
#  Affzo USER
#  zonsui = "PASSE"
# Endif
#Else
# [M]USER = GUSER
#Endif
GMESSAGE = ""
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran APASSMNTSYRA) 04/12/2015 11:32:05 (CCL)
######################################################################################
Subprog C_PASSE(VALEUR)
Variable Char    VALEUR()
Local Integer ASTATUS
Local Char MESSAGE(250)
ASTATUS = func ASYRFNC.ACHECKCONNECT(GACTX,VALEUR,MESSAGE)
If ASTATUS>=[V]CST_AERROR
 mkstat = 2 : GMESSAGE = MESSAGE : End
Endif
End


