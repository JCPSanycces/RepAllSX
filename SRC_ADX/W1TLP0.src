#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TLP0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:48"
A_USER  = "DOC"
A_STAMP = "20181109230648"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask TLP0 [TLP0]
Gosub HORODAT
Local Inpbox "TLP0" From GFONCTION At A_STAMP With A_WINDPREV Mask [TLP0] As [SIM_]
Grizo [TLP0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [TLP0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=3
Return

$ON_CFGLIN
Onevent CONTROL Call C_CFGLIN(zc) From W1TLP0
Onevent BEFORE_INPUT Call AS_CFGLIN(zc) From W1TLP0
Return

Subprog AS_CFGLIN(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_CFGLIN(zc) From W1TLP0
Gosub _AFF
End

Subprog C_CFGLIN(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CFGLIN" : GZNUM = 13622 : Endif
If !mkstat
 ## Action STD
 Call C_CFGLIN(VALEUR) From SUBTLP
 If mkstat : GERR = 1 : GZONE = "CFGLIN" : GZNUM = 13622 : Endif
Endif
Gosub _AFF
End

Subprog S_CFGLIN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELOBJET
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJET"
 PARMSK(1) = "TLP"
 PARMSK(2) = "CFGLIN"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJET","SELOBJ","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_CFGLINAXX
Onevent INIT_AREA Call D_CFGLINAXX(zc) From W1TLP0
Onevent BEFORE_INPUT Call AS_CFGLINAXX(zc) From W1TLP0
Return

Subprog IB_CFGLINAXX(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_CFGLINAXX(VALEUR)
Variable Char    VALEUR()
If varinit([M]CFGLINAXX,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"TABLINCFG","CFGLINAXX",[M]CFGLIN,"") From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_CFGLINAXX(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_CFGLINAXX(VALEUR)
## Action STD
Call AS_CFGLINAXX(VALEUR) From SUBTLP
If mkstat=2
 [M]CFGLINAXX(INDIC) = VALEUR
 Affzo CFGLINAXX(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CFGLINAXX(zc) From W1TLP0
Gosub _AFF
End

Subprog B1_CFGLINAXX(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_CFGLINAXX" : PROGSUB = "SUBTLP" : PROGSPE = "SPETLP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "TABLINCFG"
 PARMSK(2) = "CFGLINAXX"
 PARMSK(3) = [M]CFGLIN
 PARMSK(4) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_CFGLINAXX" : PROGSUB = "SUBTLP" : PROGSPE = "SPETLP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_SCENUM
Onevent CONTROL Call C_SCENUM(zc) From W1TLP0
Onevent BEFORE_INPUT Call AS_SCENUM(zc) From W1TLP0
Onevent AFTER_CHANGE Gosub AMM_SCENUM From W1TLP0
Return

Subprog AS_SCENUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_SCENUM(zc) From W1TLP0
Onkey 144 Titled GBOUTP Call P_SCENUM(zc) From W1TLP0
Onkey 146 Titled GBOUTA Call SA_SCENUM(zc) From W1TLP0
Gosub _AFF
End

Subprog C_SCENUM(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("CFG","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "SCENUM" : GZNUM = 1295 : Endif
Gosub _AFF
End

$AMM_SCENUM
Call AM_SCENUM(zc)
If !mkstat & GOBJET
 zoncou = "SCENUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_SCENUM(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZSCENUM)")>indice
 [M]SCENUM(indice) = VALEUR
 Affzo ZSCENUM(indice)
Endif
Gosub _AFF
End

Subprog S_SCENUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "CFG"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_SCENUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CFG"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_SCENUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CFG",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZSCENUM
Onevent BEFORE_AREA Gosub AV_ZSCENUM From W1TLP0
Return

$AV_ZSCENUM
Call LECTEXTRA(zc,"CFGSCE","SCEAXX",num$([M]SCENUM(indice)),"") From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


