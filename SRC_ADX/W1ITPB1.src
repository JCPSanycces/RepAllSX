#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ITPB1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:12"
A_USER  = "DOC"
A_STAMP = "20181109230512"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ITPB1 [ITPB]
Gosub HORODAT
Local Inpbox "ITPB1" From GFONCTION At A_STAMP With A_WINDPREV Mask [ITPB] As [SIM_]
Grizo [ITPB]10
Grizo [ITPB]15
Grizo [ITPB]20
Grizo [ITPB]25
Grizo [ITPB]30
Grizo [ITPB]35
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ITPB]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=93 : Y1(0)=1 : Y2(0)=9
X1(1)=1 : X2(1)=93 : Y1(1)=10 : Y2(1)=18
X1(2)=1 : X2(2)=93 : Y1(2)=19 : Y2(2)=25
X1(3)=1 : X2(3)=39 : Y1(3)=26 : Y2(3)=33
X1(4)=1 : X2(4)=39 : Y1(4)=34 : Y2(4)=39
X1(5)=40 : X2(5)=93 : Y1(5)=34 : Y2(5)=39
Return

$ON_ITMREF
Return

$ON_ZITMREF
Onevent BEFORE_AREA Gosub AV_ZITMREF From W1ITPB1
Return

$AV_ZITMREF
Call LECTEXTRA(zc,"ITMMASTER","DES1AXX",num$([M]ITMREF(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_XBPSNUM
Onevent CONTROL Call C_XBPSNUM(zc) From W1ITPB1
Onevent BEFORE_INPUT Call AS_XBPSNUM(zc) From W1ITPB1
Onevent AFTER_CHANGE Gosub AMM_XBPSNUM From W1ITPB1
Return

Subprog AS_XBPSNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1500,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_XBPSNUM(zc) From W1ITPB1
Onkey   2 Titled GBOUTS Call S_XBPSNUM(zc) From W1ITPB1
Onkey 144 Titled GBOUTP Call P_XBPSNUM(zc) From W1ITPB1
Onkey 146 Titled GBOUTA Call SA_XBPSNUM(zc) From W1ITPB1
Gosub _AFF
End

Subprog C_XBPSNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "XBPSNUM" : GZNUM = 3680 : Endif
If !GWEBSERV
 If !mkstat
  ## Action BPRCHOICE
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "BPRCHOICE"
  Call S_TAB_CHAR(VALEUR,PARMSK,"BPRCHOICE","TRTSEL","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "XBPSNUM" : GZNUM = 3680 : Endif
 Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("BPR","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "XBPSNUM" : GZNUM = 3680 : Endif
Endif
Gosub _AFF
End

$AMM_XBPSNUM
Call AM_XBPSNUM(zc)
If !mkstat & GOBJET
 zoncou = "XBPSNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_XBPSNUM(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZXBPSNUM)")>indice
 [M]XBPSNUM(indice) = VALEUR
 Affzo ZXBPSNUM(indice)
Endif
Gosub _AFF
End

Subprog S_XBPSNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "BPR"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_XBPSNUM(VALEUR)
Variable Char    VALEUR()
Call OBJET("BPR",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_XBPSNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "BPR"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_XBPSNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("BPR",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZXBPSNUM
Onevent BEFORE_AREA Gosub AV_ZXBPSNUM From W1ITPB1
Return

$AV_ZXBPSNUM
If clalev([F:BPR])=0
 If dim(GTABCPT)>0 & GTABCPT<>"" & find("BPR",GABRCPT(1..GNBTABCPT))
  Local File =GTABCPT+"BPARTNER" [BPR]
 Else 
  Local File BPARTNER [BPR]
 Endif
Endif
Call LECTURE("BPR",num$([M]XBPSNUM(indice)),"") From CONTOBJ
zc = [F:BPR]BPRNAM
Gosub _AFF
Return

$ON_ITPPUU
Return

$ON_QLYCRD
