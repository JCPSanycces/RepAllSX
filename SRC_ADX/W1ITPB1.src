$ON_CPRAMT
Onevent BEFORE_AREA Gosub AV_CPRAMT From W1ITPB1
Return

$AV_CPRAMT
## Action PARDEV
Gosub _AFF
Return

$ON_CUR
Return

$ON_STCNUM
Return

$ON_STCNUMITF
Onevent BEFORE_INPUT Call AS_STCNUMITF(zc) From W1ITPB1
Onevent INIT_AREA Call D_STCNUMITF(zc) From W1ITPB1
Return

Subprog D_STCNUMITF(VALEUR)
Variable Char    VALEUR()
If varinit([M]STCNUMITF,indice)=0
 VALEUR = 131
Endif
Gosub _AFF
End

Subprog AS_STCNUMITF(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(52022,GBOUTI) From OBJDIV
Onkey 178 Titled GBOUTI Call CL_STCNUMITF(zc) From W1ITPB1
Gosub _AFF
End

Subprog CL_STCNUMITF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STCITF
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "STCITF"
 PARMSK(1) = [M]ITMREF
 PARMSK(2) = [M:BPS0]BPSNUM
 PARMSK(3) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"FSTCITF","TRTSTCITF","SPESTCITF") From GSAISIE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_PUU
Return

$ON_ZPUU
Onevent BEFORE_AREA Gosub AV_ZPUU From W1ITPB1
Return

$AV_ZPUU
Call LECTEXTRA(zc,"TABUNIT","DES",num$([M]PUU(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_PURMINQTY
Onevent BEFORE_AREA Gosub AV_PURMINQTY From W1ITPB1
Return

$AV_PURMINQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find([M]ITPPUU (nolign-1),GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]PURMINQTY(indice) With "NPz:"+GUNTFMT
Gosub _AFF
Return

$ON_PUU2
Onevent BEFORE_AREA Gosub AV_PUU2 From W1ITPB1
