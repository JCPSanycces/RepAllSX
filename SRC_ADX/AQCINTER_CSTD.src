# Class AQCUBTER


##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "KEY1"
    Case [L]ARULE
      When "PROPAGATE"  : Gosub REFRESH_ACTIVITIES
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Case [L]AOPERATION
Endcase
Return

##########################################################################################################


$REFRESH_ACTIVITIES
  Local Integer LINENUM, I
  For I = maxtab(this.COLAQC) To 1 Step -1
    If ((this.COLAQC(I).ASTALIN <> CST_ADEL) & (this.COLAQC(I).ASTALIN <> CST_ANEWDEL))
      [L]ASTATUS = fmet this.ASETERROR("",num$(this.COLAQC(I).AORDER)-num$(I),[V]CST_AINFO)
      #[L]ASTATUS = fmet this.ADELLINE("COLAQC", this.COLAQC(I).AORDER)
      If [L]ASTATUS = [V]CST_ANOTDEFINED
        #--The deletion was not possible
        [L]ASTATUS = fmet this.ASETERROR ("COLAQC(I)", "Unable to delete the row"-num$(this.COLAQC(I).AORDER)-num$(I), [V]CST_AERROR)
        Return
      Endif
    Endif
  Next

  Local File AQCINTER [AQCIN]

  I=0
  Filter [AQCIN] Where KEY1=this.KEY1
  For [AQCIN]
    [L]LINENUM = fmet this.ADDLINE("COLAQC",[V]CST_ALASTPOS)
    this.COLAQC(LINENUM).KEY2       = [F:AQCIN]KEY2
    this.COLAQC(LINENUM).LINE       = [F:AQCIN]LINE
    this.COLAQC(LINENUM).SEQ        = [F:AQCIN]SEQ
    this.COLAQC(LINENUM).TEXT       = [F:AQCIN]TEXT
    I+=1
  Next

  # Extra line needed to fix single record error (only do if we have at least one row)
If this.BLKLIN = [V]CST_AYES
  If I>0 : [L]LINENUM = fmet this.ADDLINE("COLAQC",[V]CST_ALASTPOS) : Endif
Endif
  LogicClose File [AQCIN]
Return

