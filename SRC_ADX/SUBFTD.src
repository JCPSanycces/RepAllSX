#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion du fichier FILTDS
Raz GBIDC1, GBIDC2
Call OBJET("FTD",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "LIENS"      : Gosub LIENS
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
 When Default
Endcase
Return

$LIENS
[M:FTD1]HLPFOR(0)  = "[M]TDSGENE"
[M:FTD1]HLPFOR(1)  = "[F:AIX]CONTACTCRM"
[M:FTD1]HLPFOR(2)  = "[F:AID]CONTACTCRM"
[M:FTD1]HLPFOR(3)  = "[F:AIS]CONTACTCRM"
[M:FTD1]HLPFOR(4)  = "[F:BPX]BPADDRESS"
[M:FTD1]HLPFOR(5)  = "[F:BPD]BPADDRESS"
[M:FTD1]HLPFOR(6)  = "[F:BPS]BPADDRESS"
[M:FTD1]HLPFOR(7)  = "[F:HLN]HONLIN"
[M:FTD1]HLPFOR(8)  = "[F:PRV]HONPRV"
[M:FTD1]HLPFOR(9)  = "[F:PRM]PRMDADSU"
[M:FTD1]HLPFOR(10) = "[F:FTD]FILTDS"
[M:FTD1]HLPFOR(11) = "[F:FCX]FACILITY"
[M:FTD1]HLPFOR(12) = "[F:FCD]FACILITY"
[M:FTD1]HLPFOR(13) = "[F:FCS]FACILITY"
Return

$INICRE
If GNBLEG = 1 : [F:FTD]LEG = GDOSLEG(1) : Endif
Return

$INIMOD
Gosub INICRE
Return


$TRTCOP
Local File =[M]DOSORG+".FILTDS" [FTD1]
Local File =[M]DOSDES+".FILTDS" [FTD2]

# effacement des enregistrements destination pour le groupe sélectionné, s'ils existent déjà
Trbegin [FTD2]
Delete [FTD2] Where GRP=[M:FTD1]GRP
Local Integer N
N=0
For [FTD1] Where GRP=[M:FTD1]GRP
 [F:FTD2] = [F:FTD1]
 Write [FTD2]
 N=N+1
Next
Commit
Return

Subprog IB_XPSRES
End

