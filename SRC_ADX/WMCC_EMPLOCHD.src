#<AdxTL>@(#)0.0.0.0 $Revision$Class Children
# Supervisor
## CRUD-CLASSE ## EMPLOCHD
# 2018-11-06 07:06:01 740


############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(EMPLOCHD,ASTATUS)
Variable Instance EMPLOCHD Using C_EMPLOCHD
Variable Integer ASTATUS

If EMPLOCHD = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOCHD

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_EMPLOCHD

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(EMPLOCHD,ASTATUS)
Variable Instance EMPLOCHD Using C_EMPLOCHD
Variable Integer ASTATUS

If EMPLOCHD = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOCHD
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_EMPLOCHD
Else
 Gosub AINSERT_EMPLOCHD
Endif

Gosub _AINSERT_AFTER
[L]A_I = EMPLOCHD.freeSnapshot
EMPLOCHD.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOCHD._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOCHD._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOCHD._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If EMPLOCHD.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOCHD.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_EMPLOCHD
Trbegin [F:CHD]
 Gosub AINSERT_EMPLOCHD
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_EMPLOCHD
Raz [F:CHD]
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOCHD._MAJSQL_EMPLOCHD(EMPLOCHD))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If EMPLOCHD.snapshotEnabled=1
 [L]A_RETIK = EMPLOCHD.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLOCHD.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(EMPLOCHD.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EMPLOCHD.ASTALIN = [V]CST_ALL
Endif
Return



