#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRCCV0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:34"
A_USER  = "DOC"
A_STAMP = "20181109230434"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRCCV0 [HRCCV0]
Gosub HORODAT
Local Inpbox "HRCCV0" From GFONCTION At A_STAMP With A_WINDPREV Mask [HRCCV0] As [SIM_]
Grizo [HRCCV0]5
Grizo [HRCCV0]10
Grizo [HRCCV0]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HRCCV0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=74 : Y1(1)=4 : Y2(1)=10
X1(2)=1 : X2(2)=74 : Y1(2)=11 : Y2(2)=28
Return

$ON_COD
Onevent BEFORE_INPUT Call AS_COD(zc) From W1HRCCV0
Onevent CONTROL Call C_COD(zc) From W1HRCCV0
Return

Subprog AS_COD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_COD(zc) From W1HRCCV0
Gosub _AFF
End

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 11208 : Endif
Gosub _AFF
End

Subprog S_COD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRCCV
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRCCV"
 PARMSK(1) = GLEGFIL
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRCCV","SUBHRCCV","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1HRCCV0
Onevent CONTROL Call C_LEG(zc) From W1HRCCV0
Onevent AFTER_AREA Call AP_LEG(zc) From W1HRCCV0
Onevent BEFORE_INPUT Call AS_LEG(zc) From W1HRCCV0
Onevent AFTER_CHANGE Gosub AMM_LEG From W1HRCCV0
Return

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEG,indice)=0
 VALEUR = GLEGFIL
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_LEG(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"909") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_LEG(zc) From W1HRCCV0
Onkey   2 Titled GBOUTS Call S_LEG(zc) From W1HRCCV0
Onkey 144 Titled GBOUTP Call P_LEG(zc) From W1HRCCV0
Onkey 146 Titled GBOUTA Call SA_LEG(zc) From W1HRCCV0
If VALEUR="" : Call INIADI(VALEUR,"909") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"909","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"909",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AP_LEG(VALEUR) From SUBHRCCV
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
Gosub _AFF
End

$AMM_LEG
Call AM_LEG(zc)
If !mkstat & GOBJET
 zoncou = "LEG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZLEG)")>indice
 [M]LEG(indice) = VALEUR
 Affzo ZLEG(indice)
Endif
Gosub _AFF
End

Subprog S_LEG(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "909"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_LEG(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"909") From GOBJET
Gosub _AFF
End

Subprog SA_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "909"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "909"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZLEG
Onevent BEFORE_AREA Gosub AV_ZLEG From W1HRCCV0
Return

$AV_ZLEG
Call LECTEXTRA(zc,"ATABDIV","LNGDES","909",num$([M]LEG(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_DES
Onevent INIT_AREA Call D_DES(zc) From W1HRCCV0
Onevent BEFORE_INPUT Call AS_DES(zc) From W1HRCCV0
Onevent CONTROL Call C_DES(zc) From W1HRCCV0
Return

Subprog IB_DES(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_DES(VALEUR)
Variable Char    VALEUR()
If varinit([M]DES,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"CLASSCONV","DES",[M]COD,GCURLEG) From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_DES(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_DES(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_DES(zc) From W1HRCCV0
Gosub _AFF
End

Subprog C_DES(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DES" : GZNUM = 8 : Endif
Gosub _AFF
End

Subprog B1_DES(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_DES" : PROGSUB = "SUBHRCCV" : PROGSPE = "SPEHRCCV" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "CLASSCONV"
 PARMSK(2) = "DES"
 PARMSK(3) = [M]COD
 PARMSK(4) = GCURLEG
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_DES" : PROGSUB = "SUBHRCCV" : PROGSPE = "SPEHRCCV" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_DESSHO
Onevent INIT_AREA Call D_DESSHO(zc) From W1HRCCV0
Onevent BEFORE_INPUT Call AS_DESSHO(zc) From W1HRCCV0
Return

Subprog IB_DESSHO(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_DESSHO(VALEUR)
Variable Char    VALEUR()
If varinit([M]DESSHO,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"CLASSCONV","DESSHO",[M]COD,[M]LEG) From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_DESSHO(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_DESSHO(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_DESSHO(zc) From W1HRCCV0
Gosub _AFF
End

Subprog B1_DESSHO(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_DESSHO" : PROGSUB = "SUBHRCCV" : PROGSPE = "SPEHRCCV" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "CLASSCONV"
 PARMSK(2) = "DESSHO"
 PARMSK(3) = [M]COD
 PARMSK(4) = [M]LEG
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_DESSHO" : PROGSUB = "SUBHRCCV" : PROGSPE = "SPEHRCCV" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_CATCSP
Onevent BEFORE_INPUT Call AS_CATCSP(zc) From W1HRCCV0
Onevent CONTROL Call C_CATCSP(zc) From W1HRCCV0
Onevent AFTER_CHANGE Gosub AMM_CATCSP From W1HRCCV0
Return

Subprog AS_CATCSP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44777,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action DEFHRCSP
Call DEFHRCSP(VALEUR,GCURLEG,GSOCIETE) From SUBHRCSP
If mkstat=2
 [M]CATCSP(INDIC) = VALEUR
 Affzo CATCSP(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CATCSP(zc) From W1HRCCV0
Onkey   2 Titled GBOUTS Call S_CATCSP(zc) From W1HRCCV0
Onkey 144 Titled GBOUTP Call P_CATCSP(zc) From W1HRCCV0
Onkey 146 Titled GBOUTA Call SA_CATCSP(zc) From W1HRCCV0
Gosub _AFF
End

Subprog C_CATCSP(VALEUR)
Variable Char    VALEUR()
## Action CONTHRCSP
Call CONTHRCSP(VALEUR,GCURLEG,GSOCIETE) From SUBHRCSP
If mkstat : GERR = 1 : GZONE = "CATCSP" : GZNUM = 44777 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CATCSP" : GZNUM = 44777 : Endif
Endif
Gosub _AFF
End

$AMM_CATCSP
Call AM_CATCSP(zc)
If !mkstat & GOBJET
 zoncou = "CATCSP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CATCSP(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCATCSP)")>indice
 [M]CATCSP(indice) = VALEUR
 Affzo ZCATCSP(indice)
Endif
Gosub _AFF
End

Subprog S_CATCSP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRCSP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRCSP"
 PARMSK(1) = GCURLEG
 PARMSK(2) = GSOCIETE
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRCSP","SUBHRCSP","SPEHRCSP") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CATCSP(VALEUR)
Variable Char    VALEUR()
Call OBJET("HRCSP",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CATCSP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRCSP"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CATCSP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRCSP",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCATCSP
Onevent BEFORE_AREA Gosub AV_ZCATCSP From W1HRCCV0
Return

$AV_ZCATCSP
Call LECTEXTRA(zc,"HRCATCSP","DESAXX",num$([M]CATCSP(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_OCPLEV
Onevent INIT_AREA Call D_OCPLEV(zc) From W1HRCCV0
Onevent BEFORE_INPUT Call AS_OCPLEV(zc) From W1HRCCV0
Return

Subprog D_OCPLEV(VALEUR)
Variable Integer VALEUR
If varinit([M]OCPLEV,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_OCPLEV(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_SALMIN
Onevent CONTROL Call C_SALMIN(zc) From W1HRCCV0
Return

Subprog C_SALMIN(VALEUR)
Variable Decimal VALEUR
Gosub _AFF
End

$ON_SALMAX
Onevent BEFORE_INPUT Call AS_SALMAX(zc) From W1HRCCV0
Onevent CONTROL Call C_SALMAX(zc) From W1HRCCV0
Return

Subprog AS_SALMAX(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_SALMAX(VALEUR) From SUBHRCCV
If mkstat=2
 [M]SALMAX(INDIC) = VALEUR
 Affzo SALMAX(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_SALMAX(VALEUR)
Variable Decimal VALEUR
## Action STD
Call C_SALMAX(VALEUR) From SUBHRCCV
If mkstat : GERR = 1 : GZONE = "SALMAX" : GZNUM = 860 : Endif
Gosub _AFF
End

$CHG_STY
Return


