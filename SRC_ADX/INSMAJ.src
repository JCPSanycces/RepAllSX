Subprog AVANT_NBLIG6
Call INILIGLEG([M:DIA]TYPCRG4(nolign-1),[M:DIA]TYPFIN4(nolign-1),[M:DIA]ORGFIN4(nolign-1),[M:DIA]WLEGLIG(nolign-1)) From SUBSTG
End


Subprog AM_TYPCRG4(VALEUR)
Variable Char    VALEUR()
[M:DIA]NEWLIG(nolign-1)=0
End

Subprog C_TYPCRG4(VALEUR)
Variable Char    VALEUR()
#Call UNICITE(VALEUR,[M:DIA]TYPCRG4(0..[M:DIA]NBLIG6-1)) From OBJDIV
#If mkstat=2 : End : Endif
If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
Read[F:ADI]CODE=10451;VALEUR
# FQ70854 - MABON 28/01/11 - On peut finalement avoir tous les types de coûts, à condition qu'ils soient Non calculés
# Pas de coûts relatif au formateur interne ni de coût participant calculable (SAL / PAT)
#If !fstat & ([F:ADI]N2=1 & [F:ADI]N1<3) | [F:ADI]N2=2
If !fstat & [F:ADI]N1<3
 GMESSAGE=VALEUR-":"-mess(35,10717,1)-mess(71,10717,1) :#Type de coût non autorisé au niveau Inscription
 mkstat=2 : End
Endif
# SEGAY 81085 US 460
Local Integer INDEX : INDEX=1
Local Integer WOK : WOK=1
Call CHECKLEG_LIGCOST(VALEUR,[M]TYPFIN4(nolign-1),[M]ORGFIN4(nolign-1),INDEX,1,[M]WLEGLIG(nolign-1),WOK) From SUBSTG

End

# SEGAY 81085 US 460
Subprog C_TYPFIN4(VALEUR)
Variable Char     VALEUR
Local Integer INDEX : INDEX=2
Local Integer WOK : WOK=1
Call CHECKLEG_LIGCOST([M]TYPFIN4(nolign-1),VALEUR,[M]ORGFIN4(nolign-1),INDEX,1,[M]WLEGLIG(nolign-1),WOK) From SUBSTG
End


Subprog AS_CSTTOTCLL4(VALEUR)
Variable Decimal VALEUR

  If VALEUR=0 & [M:DIA]CSTTOTIDV4(nolign-1)<>0 : mkstat=2 : End : Endif
End

Subprog AM_CSTTOTCLL4(VALEUR)
Variable Decimal VALEUR

# FQ71124 - MABON 03/02/11 - On ne calcule plus le montant individuel : soit c'est du collectif, soit c'est
# de l'individuel
#If VALEUR<>0
#  Read [F:ADI]CODE=10451;[M:DIA]TYPCRG4(nolign-1)
#  If !fstat Then
#    [M:DIA]CSTTOTIDV4(nolign-1)=arr((VALEUR/[M:HRSES5]NBLIG4),0.01)
#    [M:DIA]RESTE(nolign-1)=VALEUR-([M:DIA]CSTTOTIDV4(nolign-1)*[M:HRSES5]NBLIG4)
#    Affzo [M:DIA]CSTTOTIDV4(nolign-1)
#  Endif
#Endif

  # FQ71124 - MABON 31/01/11 - Si coût collectif dans la session, doit rester collectif
  If VALEUR=0 & [M:DIA]CSTTOTCLL4(nolign-1)<>0 & [M:DIA]NEWLIG(nolign-1)=2 : mkstat=2 : End : Endif
End

Subprog AS_CSTTOTIDV4(VALEUR)
Variable Decimal VALEUR

  If [M:DIA]CSTTOTCLL4(nolign-1)<>0 : mkstat=2 : End : Endif
End

Subprog AM_CSTTOTIDV4(VALEUR)
Variable Decimal VALEUR

  # FQ71124 - MABON 31/01/11 - Si coût individuel dans la session, doit rester individuel
  If VALEUR=0 & [M:DIA]CSTTOTIDV4(nolign-1)<>0 & [M:DIA]NEWLIG(nolign-1)=2 : mkstat=2 : End : Endif
End

Subprog AS_CSTIPTCLL4(VALEUR)
Variable Decimal VALEUR

  If VALEUR=0 & [M:DIA]CSTIPTIDV4(nolign-1)<>0 : mkstat=2 : End : Endif
End

Subprog C_CSTIPTCLL4(VALEUR)
Variable Decimal VALEUR

  # FQ71546 - MABON 14/02/11 - Le coût total peut être négatif
  If [M:DIA]CSTTOTCLL4(nolign-1)>0 Then
    If VALEUR>[M:DIA]CSTTOTCLL4(nolign-1) Then
      GMESSAGE=mess(7,10717,1) :#Coût imputable supérieur au coût total
      mkstat=2 : End
    Endif
    # FQ71546 - MABON 14/02/11 - Si le coût total est positif, le coût imputable doit l'être aussi
    If VALEUR<0 Then
      GMESSAGE=mess(231,10717,1) :# Le coût imputable doit être positif
      mkstat=2 : End
    Endif
  Endif
  If [M:DIA]CSTTOTCLL4(nolign-1)<0 Then
    If VALEUR<=0 Then
      If abs(VALEUR)>abs([M:DIA]CSTTOTCLL4(nolign-1)) Then
        #Coût imputable supérieur au coût total
        GMESSAGE=mess(7,10717,1)
        mkstat=2 : End
      Endif
    Else
      GMESSAGE=mess(228,10717,1) : # Le coût imputable ne peut pas être supérieur à 0
      mkstat=2 : End
    Endif
  Endif
  # Fin MABON
End

Subprog AM_CSTIPTCLL4(VALEUR)
Variable Decimal VALEUR
# FQ71124 - MABON 03/02/11 - On ne calcule plus le montant individuel
#If VALEUR<>0
#  Read [F:ADI]CODE=10451;[M:DIA]TYPCRG4(nolign-1)
#  If !fstat Then
#    [M:DIA]CSTIPTIDV4(nolign-1)=arr((VALEUR/[M:HRSES5]NBLIG4),0.01)
#    [M:DIA]RESTE2(nolign-1)=VALEUR-([M:DIA]CSTIPTIDV4(nolign-1)*[M:HRSES5]NBLIG4)
#    Affzo [M:DIA]CSTIPTIDV4(nolign-1)
#  Endif
#Endif

  # FQ71124 - MABON 31/01/11 - Si coût collectif dans la session, doit rester collectif
  If VALEUR=0 & [M:DIA]CSTIPTCLL4(nolign-1)<>0 & [M:DIA]NEWLIG(nolign-1)=2 : mkstat=2 : End : Endif
End

Subprog AS_CSTIPTIDV4(VALEUR)
Variable Decimal VALEUR

  If [M:DIA]CSTIPTCLL4(nolign-1)<>0 : mkstat=2 : End : Endif
  #Frais d'hebergement imputable individuel = 5*MG*Nb jours
  If [M:DIA]TYPCRG4(nolign-1)="HEB" & VALEUR=0
    Local Decimal VALMG
    Call RECUP_MG("", "", "",[F:HRSES]ENDDAT,VALMG) From TRTCOUT
    If [M:DIA]CSTTOTIDV4(nolign-1)<arr(5*VALMG*[M:HRSES2]NBRDAY,0.1)
      VALEUR=[M:DIA]CSTTOTIDV4(nolign-1)
    Else
      VALEUR=arr(5*VALMG*[M:HRSES2]NBRDAY,0.1)
    Endif
  Endif
End

Subprog C_CSTIPTIDV4(VALEUR)
Variable Decimal VALEUR
Local    Decimal CSTTOTIDV

  # FQ71546 - MABON 14/02/11 - Le coût total peut être négatif
  CSTTOTIDV=[M:DIA]CSTTOTIDV4(nolign-1)
  If [M:DIA]CSTTOTIDV4(nolign-1)=0 & [M:DIA]CSTTOTCLL4(nolign-1)<>0 & [M:HRSES5]NBLIG4>0 Then : # C'est qu'on a saisi un coût collectif
    CSTTOTIDV=[M:DIA]CSTTOTCLL4(nolign-1)/[M:HRSES5]NBLIG4
  Endif

  If CSTTOTIDV>0 Then
    If VALEUR>CSTTOTIDV Then
      GMESSAGE=mess(7,10717,1) :#Coût imputable supérieur au coût total
      mkstat=2 : End
    Endif
    # FQ71546 - MABON 14/02/11 - Si le coût total est positif, le coût imputable doit l'être aussi
    If VALEUR<0 Then
      GMESSAGE=mess(231,10717,1) :# Le coût imputable doit être positif
      mkstat=2 : End
    Endif
  Endif
  If CSTTOTIDV<0 Then
    If VALEUR<=0 Then
      If abs(VALEUR)>abs(CSTTOTIDV) Then
        #Coût imputable supérieur au coût total
        GMESSAGE=mess(7,10717,1)
        mkstat=2 : End
      Endif
    Else
      GMESSAGE=mess(228,10717,1) : # Le coût imputable ne peut pas être supérieur à 0
      mkstat=2 : End
    Endif
  Endif
  # Fin MABON
  If [M:DIA]TYPCRG4(nolign-1)="HEB"
    Local Decimal VALMG
    Call RECUP_MG("", "", "",[F:HRSES]ENDDAT,VALMG) From TRTCOUT
    If VALEUR>arr(5*VALMG*[M:HRSES2]NBRDAY,0.1)
      # FQ97638 - 21/03/14 - Mettre un message plus complet
#      GMESSAGE=mess(51,10717,1) :#Coût imputable supérieur au minimum garanti
      #Incohérence de données : / - Coût imputable supérieur au minimum garanti / - Le nombre de jours n'est pas renseigné
      GMESSAGE=mess(305,10717,1)-":"+chr$(10)+"- "+mess(51,10717,1)+chr$(10)+"- "+mess(306,10717,1)
      # Fin FQ97638
      mkstat=2 : End
    Endif
  Endif
End

Subprog AM_CSTIPTIDV4(VALEUR)
Variable Decimal VALEUR

  # FQ71124 - MABON 31/01/11 - Si coût individuel dans la session, doit rester individuel
  If VALEUR=0 & [M:DIA]CSTIPTIDV4(nolign-1)<>0 & [M:DIA]NEWLIG(nolign-1)=2 : mkstat=2 : End : Endif
End

Subprog AS_TYPFIN4(VALEUR)
Variable Char    VALEUR()

  If VALEUR="" & nolign>1
   VALEUR = [M]TYPFIN4(nolign-2)
  Endif
End

Subprog AM_TYPFIN4(VALEUR)
Variable Char    VALEUR()

  [M:DIA]NEWLIG(nolign-1)=0
End

Subprog AS_ORGFIN4(VALEUR)
Variable Char    VALEUR()

  If VALEUR=""
    If nolign>1
      VALEUR = [M]ORGFIN4(nolign-2)
    Else
      # Pour l'inscription on alimente avant GOFIDEF avev le paramètre niveau société
      If dim(GOFIDEF )>0 Then
       # SEGAY 81085 US 460
#      VALEUR = GOFIDEF
       Local Char WLEG(GLONADI)
       Local Integer WOK
#      Call PARAM(GSOCIETE,"OFIDEF",WOFI) From ADOVAL : # CCL
       WLEG=[M]WLEGLIG(nolign-1)
       INDEX=3
       Call CHECKLEG_CRGFINOFT(GOFIDEF,INDEX,0,WLEG,WOK) From SUBSTG
       If WOK
        VALEUR = GOFIDEF
       Endif
      Endif
    Endif
  Endif
End

Subprog C_ORGFIN4(VALEUR)
Variable Char    VALEUR()

  # On teste l'unicité de la ligne sur les zones : TYPCRG/TYPFIN/ORGFIN
  Local Integer I, OK
  OK = 1
  For I=0 To nolign-2
    If [M]TYPCRG4(I)=[M]TYPCRG4(nolign-1) & [M]TYPFIN4(I)=[M]TYPFIN4(nolign-1) & [M]ORGFIN4(I)=VALEUR
      OK = 0 : Break
    Endif
  Next
  If OK=1
    For I=nolign To [M:DIA]NBLIG6-1
      If [M]TYPCRG4(I)=[M]TYPCRG4(nolign-1) & [M]TYPFIN4(I)=[M]TYPFIN4(nolign-1) & [M]ORGFIN4(I)=VALEUR
        OK = 0 : Break
      Endif
    Next
  Endif
  If OK=0
    # Ligne de coût déjà existante en ligne xx
    GMESSAGE = mess(84,10717,1)-num$(I+1)
    mkstat = 2 : End
  Endif

# SEGAY 81085 US 460
Local Integer INDEX : INDEX=3
Local Integer WOK : WOK=1
Call CHECKLEG_LIGCOST([M]TYPCRG4(nolign-1),[M]TYPFIN4(nolign-1),VALEUR,INDEX,1,[M]WLEGLIG(nolign-1),WOK) From SUBSTG

End

Subprog AM_ORGFIN4(VALEUR)
Variable Char    VALEUR()

  [M:DIA]NEWLIG(nolign-1)=0
End


