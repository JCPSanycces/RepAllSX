#<AdxTL>@(#)4.0.0.0 $Revision$
##################################################################################
# Cette action INSMAJ sert à mettre à jour globalement les couts réels  des inscriptions
######################################################################################
# Modifications :
#     SEGAY - 18/01/11 - EXI 66191 LOT 1
#              - Remplacement table ADI 463 par ORGANISME TYP=6 (financeur)
##################################################################################
Raz GPILOBJ
Call OBJET("HRSES",GBIDC1,"") From GOBJET
End

########
$ACTION
Case ACTION
 When "INIT_DIA"   : Gosub INIT_DIA
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
Endcase
Return

#####################################
$INIT_DIA
Gosub OUVRE From SUBHRSES
If clalev([F:ADI2])=0 : Local File ATABDIV    [ADI2] : Endif
I=1
# FQ71124 - MABON 03/02/11 - Dorénavant, on part des coûts présents dans le prévisionnel
#For nolign=1 To [M:HRSES4]NBLIG5
# Read[F:ADI]CODE=10451;[M:HRSES4]TYPCRG3(nolign-1)
# # Pas de coûts participant calculable (SAL / PAT)
# If !fstat & [F:ADI]N2<>2 & [F:ADI]N1=3
#  [M:DIA]TYPCRG4(I-1)   = [M:HRSES4]TYPCRG3(nolign-1)
#  [M:DIA]CSTTOTCLL4(I-1)= [M:HRSES4]CSTTOTIDV3(nolign-1)
#  [M:DIA]CSTTOTIDV4(I-1)= arr(([M:DIA]CSTTOTCLL4(I-1)/[M:HRSES5]NBLIG4),0.1)
#  [M:DIA]CSTIPTCLL4(I-1)= [M:HRSES4]CSTIPTIDV3(nolign-1)
#  [M:DIA]CSTIPTIDV4(I-1)= arr(([M:DIA]CSTIPTCLL4(I-1)/[M:HRSES5]NBLIG4),0.1)
#  [M:DIA]CSTTOTIDV4(I-1)= arr(([M:HRSES4]CSTTOTIDV3(nolign-1)/[M:HRSES5]NBLIG4),0.1)
#  [M:DIA]CSTIPTIDV4(I-1)= arr(([M:HRSES4]CSTIPTIDV3(nolign-1)/[M:HRSES5]NBLIG4),0.1)
#  [M:DIA]NEWLIG(I-1)    = 2
#  I+=1
# Endif
#Next
For nolign=1 To [M:HRSES3]NBLIG
  Read[F:ADI]CODE=10451;[M:HRSES3]TYPCRG(nolign-1)
  If !fstat & [F:ADI]N1=3 Then : # Pas de coûts calculable (SAL / PAT)
    [M:DIA]TYPCRG4(I-1)   = [M:HRSES3]TYPCRG(nolign-1)
    [M:DIA]TYPFIN4(I-1)   = [M:HRSES3]TYPFIN(nolign-1)
    [M:DIA]ORGFIN4(I-1)   = [M:HRSES3]ORGFIN(nolign-1)
    [M:DIA]NEWLIG(I-1)    = 2
    [M:DIA]FLGDEL(I-1)    = 1
    If [M:HRSES3]CSTTOTCLL(I-1)>0 Then
      [M:DIA]CSTTOTCLL4(I-1)= [M:HRSES3]CSTTOTCLL(nolign-1)
      [M:DIA]CSTIPTCLL4(I-1)= [M:HRSES3]CSTIPTCLL(nolign-1)
    Else
      [M:DIA]CSTTOTIDV4(I-1)= [M:HRSES3]CSTTOTIDV(nolign-1)
      [M:DIA]CSTIPTIDV4(I-1)= [M:HRSES3]CSTIPTIDV(nolign-1)
    Endif
    I+=1
  Endif
Next
# Fin MABON
[M:DIA]NBLIG6=I-1
Return

#####################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

#####################################
$EXEC
Local Decimal TAUX, TOTCST1, TOTCST2, IPTCST1, IPTCST2,MTTTOT,MTTIPT
Local Integer NBENREG, NBCOUFOR, NBRCOUT, OKCALC
#--SEGAY STA_EXI 66191 LOT 1
Local Char LOFIDEF
Local Char CPYSAL(GLONCPY), FCYSAL(GLONFCY), JOTSAL(GLONJOT), POTSAL(GLONPOT)
#--END_STA_EXI 66191 LOT 1

TIT = mess(53,10717,1)    #MAJ des coûts réels des inscriptions
Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(TIT-mess(34,10717,1)-":"-[M:HRSES0]COD,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

SYMBOLE = "MAJINS"
Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 Unlock =SYMBOLE
 GERR = 1 : SAI = 1 : Return
Endif

Call DEBTRANS From GLOCK
Gosub TR1

Unlock =SYMBOLE

Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
If NBENREG>0 Then
 #Nombre d'inscriptions mises à jour
 Call ECR_TRACE(mess(54,10717,1)-":"-num$(NBENREG),0) From GESECRAN
Else
 #Aucune inscription à traiter
 Call ECR_TRACE(mess(55,10717,1),0) From GESECRAN
Endif
If NBCOUFOR>0 Then
 #Nombre de coûts formateur mis à jour
 Call ECR_TRACE(mess(221,10717,1)-":"-num$(NBCOUFOR),0) From GESECRAN
Else
 #Aucun coût formateur à traiter
 Call ECR_TRACE(mess(222,10717,1),0) From GESECRAN
Endif
Call FERME_TRACE From LECFIC
Return

#####################################
$TR1

  Trbegin [HRCOR]
  NBENREG=0 : NBCOUFOR=0
  # Parcours des inscriptions
  For K=0 To [M:HRSES5]NBLIG4-1
    Read[F:INS]INS0=[M:HRSES0]STG;[M:HRSES0]COD;[M:HRSES5]REFNUM(K)
    # FQ66191 - MABON 29/10/10 - Ajout d'un état donc décalage pour le clôturé
#   If !fstat & [F:INS]STA<3 :#On touche pas les inscriptions validées
    If !fstat & [F:INS]STA<4 :#On touche pas les inscriptions validées
      #--SEGAY STA_EXI 66191 LOT 1
      ## Recherche des infos du salarié/contrat
      Call INFOS_SAL([F:INS]REFNUM,[F:INS]CTRNUM,CPYSAL,FCYSAL,JOTSAL,POTSAL) From SUBDEM
      LOFIDEF = ""
      Call PARAM(CPYSAL,"OFIDEF",LOFIDEF) From ADOVAL
      #--END STA_EXI 66191 LOT 1
      Gosub CALCOUT1
      If GOK<=0 : Break : Endif
      # MABON 03/02/11 - CALCOUT2 lance le recalcul des coûts calculés participants dans les inscriptions
      # Du fait du nouveau bouton "Recalcul coûts réels", cela n'a plus lieu d'être
#      Gosub CALCOUT2
#      If GOK<=0 : Break : Endif
      If OKCALC=2 Then
        Call ECR_TRACE(mess(56,10717,1)-":"-[F:INS]REFNUM,0) From GESECRAN : # Mise à jour des coûts du matricule
        NBENREG+=1
      Endif
      # On répartit le reliquat sur la première inscription. Donc on l'efface pour les inscriptions suivantes
      Raz [M:DIA]RESTE
      Raz [M:DIA]RESTE2
    Endif
  Next
  # Mise à jour des coûts formateurs
  Gosub CALCOUT3
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
  Commit
Return

#####################################
# Calcul du 1er numéro libre
Funprog CALC_NUMLIG(TYPC, CODSES, MAT)
Value Integer TYPC
Value Char    CODSES, MAT
Local Integer NUMLIG

  If MAT<>"" Then
    Filter [HRCOR] Where TYPCOU=TYPC & SES=CODSES & REFNUM=MAT
  Else
    Filter [HRCOR] Where TYPCOU=TYPC & SES=CODSES
  Endif
  Read [HRCOR]COR0 Last
  Filter [HRCOR]
  If !fstat Then
    NUMLIG = [F:HRCOR]NUMLIG+1
  Else
    NUMLIG = 1
  Endif
End NUMLIG

#####################################
# Création d'un enregistrement dans la table COUTREEL
$CRECOR

  Raz [F:HRCOR]
  [F:HRCOR]TYPCOU    = TYPC
  [F:HRCOR]SES       = [M:HRSES0]COD
  [F:HRCOR]REFNUM    = [M:HRSES5]REFNUM(K)
  [F:HRCOR]NUMLIG    = ILIG
  [F:HRCOR]TYPCRG2   = TYPCRG
  [F:HRCOR]CSTTOTIDV2= CSTTOTIDV
  [F:HRCOR]CSTIPTIDV2= CSTIPTIDV
  [F:HRCOR]CUR       = [M:HRSES4]CUR
  [F:HRCOR]TYPFIN2   = TYPFIN
  [F:HRCOR]ORGFIN2   = ORGFIN
  [F:HRCOR]CREDAT    = date$
  [F:HRCOR]CREUSR    = GUSER
  [F:HRCOR]CRETIM    = time
#  I = find([F:HRCOR]TYPCRG2 ,[M:HRSES4]TYPCRG2)
#  If I
#    [F:HRCOR]TYPFIN2 = [M:HRSES4]TYPFIN2(I-1)
#    [F:HRCOR]ORGFIN2 = [M:HRSES4]ORGFIN2(I-1)
#  Else
#    #--SEGAY STA_EXI 66191 LOT 1
#    # Que prendre en valeur par défaut
#    If dim(LOFIDEF )>0 & LOFIDEF <>"" Then
#      [F:HRCOR]ORGFIN2 = LOFIDEF
#    Endif
##      For I=462 To 463
##       Filter [ADI] Where NUMTAB=I & DEFVAL=2
##       Read [ADI]CODE First
##       If !fstat & I=462
##         [F:HRCOR]TYPFIN2 = [F:ADI]CODE
##       Elsif !fstat & I=463
##         [F:HRCOR]ORGFIN2 = [F:ADI]CODE
##       Endif
##       Filter [ADI]
##     Next
#    Filter [ADI] Where NUMTAB=462 & DEFVAL=2
#    Read [ADI]CODE First
#    If !fstat
#      [F:HRCOR]TYPFIN2 = [F:ADI]CODE
#    Endif
#    Filter [ADI]
#    #--END_EXI 66191 LOT 1
#  Endif
  # MABON - 03/09/10 - On n'a plus de flag DIF : c'est géré maintenant en dispositif comme un autre, donc dans TYPFRT
#   If [M:HRSES1]FLGDIF=2
#  If [M:HRSES1]TYPFRT=3
#    [F:HRCOR]DESTYPFRT2 = 3
#  Else
    [F:HRCOR]DESTYPFRT2 = [M:HRSES1]TYPFRT
#  Endif
Return

#####################################
# Mise à jour ces coûts Participants ou Autres non calculés
$CALCOUT1
Local Integer TYPC, ILIG
Local Char    TYPCRG, TYPFIN, TYPORG
Local Decimal CSTIPTIDV, CSTTOTIDV

  OKCALC=1
  ## Parcours des coûts à mettre à jour qui ont été saisis dans [DIA]
  For J=0 To [M:DIA]NBLIG6-1
    Read [F:ADI]CODE=10451;[M:DIA]TYPCRG4(J)
    # FQ71124 - MABON 31/01/11 - On peut forcer tous les coûts non calculés, Participants, Formateurs ou Autres
    # Donc, ici, on accepte les coûts Participants ou Autres
#    If [F:ADI]N2=1 Then : # Coût Participant
    If [F:ADI]N2<>2 Then : # Coût Participant ou Autres
      OKCALC=2
      Raz NBRCOUT,MTTTOT,MTTIPT
      ## On peut avoir plusieurs lignes de même coût pour une inscriptions
      Filter [HRCOR] Where TYPCOU=3 & SES=[M:HRSES0]COD & REFNUM=[M:HRSES5]REFNUM(K) & TYPCRG2=[M:DIA]TYPCRG4(J)
&                        & TYPFIN2=[M:DIA]TYPFIN4(J) & ORGFIN2=[M:DIA]ORGFIN4(J)
      For [HRCOR]COR1
        NBRCOUT +=1
        MTTTOT  +=[F:HRCOR]CSTTOTIDV2
        MTTIPT  +=[F:HRCOR]CSTIPTIDV2
      Next
      If [M:DIA]CSTTOTIDV4(J)=0 Then
        [M:DIA]CSTTOTIDV4(J)=arr(([M:DIA]CSTTOTCLL4(J)/[M:HRSES5]NBLIG4),0.01)
        [M:DIA]RESTE(J)=[M:DIA]CSTTOTCLL4(J)-([M:DIA]CSTTOTIDV4(J)*[M:HRSES5]NBLIG4)
      Endif
      CSTTOTIDV=[M:DIA]CSTTOTIDV4(J)+[M:DIA]RESTE(J)

      If [M:DIA]CSTIPTIDV4(J)=0 Then
        [M:DIA]CSTIPTIDV4(J)=arr(([M:DIA]CSTIPTCLL4(J)/[M:HRSES5]NBLIG4),0.01)
        [M:DIA]RESTE2(J)=[M:DIA]CSTIPTCLL4(J)-([M:DIA]CSTIPTIDV4(J)*[M:HRSES5]NBLIG4)
      Endif
      CSTIPTIDV=[M:DIA]CSTIPTIDV4(J)+[M:DIA]RESTE2(J)
      If NBRCOUT=0 & ([M:DIA]CSTTOTIDV4(J)>0 | [M:DIA]CSTIPTIDV4(J)>0)
        ## L'inscription ne contient pas ce coût => On le crée
        TYPC=3 : TYPCRG=[M:DIA]TYPCRG4(J) : TYPFIN=[M:DIA]TYPFIN4(J) : ORGFIN=[M:DIA]ORGFIN4(J)
        # Recherche du 1er numéro de ligne libre
        ILIG = func CALC_NUMLIG(TYPC, [M:HRSES0]COD, [M:HRSES5]REFNUM(K))
        Gosub CRECOR
        Write [HRCOR]
        If fstat
          GOK = 0 : Call FSTA("HRCOR") From GLOCK : Break 2
        Endif
      Else
        ## On parcourt les coûts de l'inscription = [M:DIA]TYPCRG4(J)
        Raz TOTCST1, TOTCST2, IPTCST1, IPTCST2
        For [HRCOR]COR1
          # FQ71393 - MABON 22/03/11 - Ajout test sur FLGDEL
          If [M:DIA]FLGDEL(J)=2 | ([M:DIA]CSTTOTIDV4(J)=0 & [M:DIA]RESTE(J)=0 & [M:DIA]CSTIPTIDV4(J)=0 & [M:DIA]RESTE2(J)=0)
            Delete [HRCOR] Curr
            If fstat
              GOK = 0 : Call FSTA("HRCOR") From GLOCK : Break 2
            Endif
          Else
            Readlock [HRCOR]COR1 Curr
            If fstat=1
              GOK = -1 : GLOCK = "COUTREEL"-[M:HRSES0]COD-[M:HRSES5]REFNUM(K)-[M:DIA]TYPCRG4(J) : Break 2
            Elsif !fstat
              #41034 Test MTTTOT<>0
              If MTTTOT<>0
                TOTCST1 = ([M:DIA]CSTTOTIDV4(J)+[M:DIA]RESTE(J))*([F:HRCOR]CSTTOTIDV2/MTTTOT)
              Endif
              [F:HRCOR]CSTTOTIDV2= arr(TOTCST2+[M:DIA]CSTTOTIDV4(J)+[M:DIA]RESTE(J),0.01)-arr(TOTCST2,0.01)
              TOTCST2 +=TOTCST1
              #41034 Test MTTIPT<>0
              If MTTIPT<>0
                IPTCST1 = ([M:DIA]CSTIPTIDV4(J)+[M:DIA]RESTE2(J))*([F:HRCOR]CSTIPTIDV2/MTTIPT)
              Endif
              [F:HRCOR]CSTIPTIDV2= arr(IPTCST2+[M:DIA]CSTIPTIDV4(J)+[M:DIA]RESTE2(J),0.01)-arr(IPTCST2,0.01)
              IPTCST2 +=IPTCST1
              Rewrite [HRCOR]
              If fstat
                GOK = 0 : Call FSTA("HRCOR") From GLOCK : Break 2
              Endif
            Endif
          Endif
        Next
      Endif
    Endif
  Next
  Filter [HRCOR]
Return

#####################################
$CALCOUT2
Local Integer TYPC, ILIG
Local Char    TYPCRG
Local Decimal CSTIPTIDV, CSTTOTIDV

  # Mise à jour des coûts participants calculables
  For [ADI]CODE Where NUMTAB=10451 & N1<3 & N2=1
    MTTIPT=0 : MTTTOT=0
    Call TAUX_HORAIRE ([F:INS]REFNUM,[F:INS]CTRNUM,[M:HRSES1]ENDDAT,TAUX,[F:ADI]N1,2,1) From TRTCOUT
    MTTTOT=arr(TAUX*[M:HRSES2]NBRHOUIPT,0.1) :# Nb d'heures imputables
    Call TAUX_HORAIRE ([F:INS]REFNUM,[F:INS]CTRNUM,[M:HRSES1]ENDDAT,TAUX,[F:ADI]N1,2,2) From TRTCOUT
    MTTIPT=arr(TAUX*[M:HRSES2]NBRHOUIPT,0.1) :# Nb d'heures imputables
    If MTTIPT<>0 | MTTTOT<>0
      Filter [HRCOR] Where TYPCOU=3 & SES=[M:HRSES0]COD & REFNUM=[M:HRSES5]REFNUM(K) & TYPCRG2=[F:ADI]CODE
      Readlock [HRCOR]COR1 First
      If fstat=1
        GOK = -1 : GLOCK = "COUTREEL"-[M:HRSES0]COD-[M:HRSES5]REFNUM(K)-[F:ADI]CODE : Break
      Elsif fstat
        TYPC=3 : TYPCRG=[F:ADI]CODE
        CSTIPTIDV= MTTIPT
        CSTTOTIDV= MTTTOT
        ILIG = func CALC_NUMLIG(TYPC, [M:HRSES0]COD, [M:HRSES5]REFNUM(K))
        Gosub CRECOR
#        Raz [F:HRCOR]
#        [F:HRCOR]TYPCOU    = 3
#        [F:HRCOR]SES       = [M:HRSES0]COD
#        [F:HRCOR]REFNUM    = [M:HRSES5]REFNUM(K)
#        [F:HRCOR]NUMLIG    = I
#        [F:HRCOR]TYPCRG2   = [F:ADI]CODE
#        [F:HRCOR]CSTIPTIDV2= MTTIPT
#        [F:HRCOR]CSTTOTIDV2= MTTTOT
#        [F:HRCOR]CUR       = [M:HRSES4]CUR
#        [F:HRCOR]CREDAT    = date$
#        [F:HRCOR]CREUSR    = GUSER
#        [F:HRCOR]CRETIM    = time
#        # MABON - 03/09/10 - On n'a plus de flag DIF : c'est géré maintenant en dispositif comme un autre, donc dans TYPFRT
#  #      If [M:HRSES1]FLGDIF=2
#        If [M:HRSES1]TYPFRT=3
#          [F:HRCOR]DESTYPFRT2 = 3
#        Else
#          [F:HRCOR]DESTYPFRT2 = [M:HRSES1]TYPFRT
#        Endif
#        #--SEGAY STA_EXI 66191 LOT 1
#        # Que prendre en valeur par défaut
#        If dim(LOFIDEF )>0 & LOFIDEF <>"" Then
#          [F:HRCOR]ORGFIN2 = LOFIDEF
#        Endif
#  #      For I=462 To 463
#  #        Filter [ADI2] Where NUMTAB=I & DEFVAL=2
#  #        Read [ADI2]CODE First
#  #        If !fstat & I=462
#  #          [F:HRCOR]TYPFIN2 = [F:ADI2]CODE
#  #        Elsif !fstat & I=463
#  #          [F:HRCOR]ORGFIN2 = [F:ADI2]CODE
#  #        Endif
#  #        Filter [ADI2]
#  #      Next
#        Filter [ADI2] Where NUMTAB=462 & DEFVAL=2
#        Read [ADI2]CODE First
#        If !fstat
#          [F:HRCOR]TYPFIN2 = [F:ADI2]CODE
#        Endif
#        Filter [ADI2]
#        #--END_EXI 66191 LOT 1
        Write [F:HRCOR]
        If fstat
          GOK = 0 : Call FSTA("HRCOR") From GLOCK : Break
        Endif
      Else
        [F:HRCOR]CSTIPTIDV2 = MTTIPT
        [F:HRCOR]CSTTOTIDV2 = MTTTOT
        Rewrite [F:HRCOR]
        If fstat
          GOK = 0 : Call FSTA("HRCOR") From GLOCK : Break
        Endif
      Endif
      Filter [HRCOR]
    Endif
  Next
Return

#####################################
# Mise à jour ces coûts formateurs non calculés
$CALCOUT3
Local Integer J, TYPC, ILIG
Local Char    TYPCRG, TYPFIN, TYPORG
Local Decimal CSTIPTIDV, CSTTOTIDV

  For J=0 To [M:DIA]NBLIG6-1
    Read [F:ADI]CODE=10451;[M:DIA]TYPCRG4(J)
    If [F:ADI]N2=2 Then : # Coût Formateur
      Raz NBRCOUT,MTTTOT,MTTIPT
      ## On peut avoir plusieurs lignes de même coût pour une session
      Filter [HRCOR] Where TYPCOU=2 & SES=[M:HRSES0]COD & TYPCRG2=[M:DIA]TYPCRG4(J)
&                       & TYPFIN2=[M:DIA]TYPFIN4(J) & ORGFIN2=[M:DIA]ORGFIN4(J)
      For [HRCOR]COR1
        NBRCOUT +=1
        MTTTOT  +=[F:HRCOR]CSTTOTIDV2
        MTTIPT  +=[F:HRCOR]CSTIPTIDV2
      Next
      If [M:DIA]CSTTOTCLL4(J)=0 Then
        [M:DIA]CSTTOTCLL4(J)=arr(([M:DIA]CSTTOTIDV4(J)*[M:HRSES5]NBLIG4),0.01)
        [M:DIA]RESTE(J)=[M:DIA]CSTTOTCLL4(J)-([M:DIA]CSTTOTIDV4(J)*[M:HRSES5]NBLIG4)
      Endif
      CSTTOTIDV=[M:DIA]CSTTOTCLL4(J)+[M:DIA]RESTE(J)

      If [M:DIA]CSTIPTCLL4(J)=0 Then
        [M:DIA]CSTIPTCLL4(J)=arr(([M:DIA]CSTIPTIDV4(J)*[M:HRSES5]NBLIG4),0.01)
        [M:DIA]RESTE2(J)=[M:DIA]CSTIPTCLL4(J)-([M:DIA]CSTIPTIDV4(J)*[M:HRSES5]NBLIG4)
      Endif
      CSTIPTIDV=[M:DIA]CSTIPTCLL4(J)+[M:DIA]RESTE2(J)
      If NBRCOUT=0
        ## La session ne contient pas ce coût => On le crée
        TYPC=2 : TYPCRG=[M:DIA]TYPCRG4(J) : TYPFIN=[M:DIA]TYPFIN4(J) : ORGFIN=[M:DIA]ORGFIN4(J)
        # Recherche du 1er numéro de ligne libre
        ILIG = func CALC_NUMLIG(2, [M:HRSES0]COD, "")
        If ILIG>dim([M:HRSES4]TYPCRG2) Then
          Call ECR_TRACE(mess(220,10717,1),0) From GESECRAN : : # Nombre maximum de coûts réels formateurs atteint
          GOK=0 : Break
        Endif
        Gosub CRECOR
        Write [HRCOR]
        If fstat
          GOK = 0 : Call FSTA("HRCOR") From GLOCK : Break
        Else
          NBCOUFOR += 1
          Call ECR_TRACE([M:DIA]TYPCRG4(J)+"/"+[M:DIA]TYPFIN4(J)+"/"+[M:DIA]ORGFIN4(J)-":"-mess(223,10717,1),0) From GESECRAN : # coût formateur mis à jour
        Endif
      Else
        ## On parcourt les coûts de la session = [M:DIA]TYPCRG4(J)
        Raz TOTCST1, TOTCST2, IPTCST1, IPTCST2
        For [HRCOR]COR1
          # FQ71393 - MABON 22/03/11 - Ajout test sur FLGDEL
          If [M:DIA]FLGDEL(J)=2 | ([M:DIA]CSTTOTCLL4(J)=0 & [M:DIA]RESTE(J)=0 & [M:DIA]CSTIPTCLL4(J)=0 & [M:DIA]RESTE2(J)=0 )
            Delete [HRCOR] Curr
            If fstat
              GOK = 0 : Call FSTA("HRCOR") From GLOCK : Break 2
            Else
              NBCOUFOR += 1
              Call ECR_TRACE([M:DIA]TYPCRG4(J)+"/"+[M:DIA]TYPFIN4(J)+"/"+[M:DIA]ORGFIN4(J)-":"-mess(223,10717,1),0) From GESECRAN : # coût formateur mis à jour
            Endif
          Else
            Readlock [HRCOR]COR1 Curr
            If fstat=1
              GOK = -1 : GLOCK = "COUTREEL"-[M:HRSES0]COD-[M:DIA]TYPCRG4(J) : Break 2
            Elsif !fstat
              #41034 Test MTTTOT<>0
              If MTTTOT<>0 Then
                TOTCST1 = ([M:DIA]CSTTOTCLL4(J)+[M:DIA]RESTE(J))*([F:HRCOR]CSTTOTIDV2/MTTTOT)
              Endif
              [F:HRCOR]CSTTOTIDV2= arr(TOTCST2+[M:DIA]CSTTOTCLL4(J)+[M:DIA]RESTE(J),0.01)-arr(TOTCST2,0.01)
              TOTCST2 +=TOTCST1
              #41034 Test MTTIPT<>0
              If MTTIPT<>0 Then
                IPTCST1 = ([M:DIA]CSTIPTCLL4(J)+[M:DIA]RESTE2(J))*([F:HRCOR]CSTIPTIDV2/MTTIPT)
              Endif
              [F:HRCOR]CSTIPTIDV2= arr(IPTCST2+[M:DIA]CSTIPTCLL4(J)+[M:DIA]RESTE2(J),0.01)-arr(IPTCST2,0.01)
              IPTCST2 +=IPTCST1
              Rewrite [HRCOR]
              If fstat
                GOK = 0 : Call FSTA("HRCOR") From GLOCK : Break 2
              Else
                NBCOUFOR += 1
                Call ECR_TRACE([M:DIA]TYPCRG4(J)+"/"+[M:DIA]TYPFIN4(J)+"/"+[M:DIA]ORGFIN4(J)-":"-mess(223,10717,1),0) From GESECRAN : # coût formateur mis à jour
              Endif
            Endif
          Endif
        Next
      Endif
      Filter [HRCOR]
    Endif
  Next
Return

#####################################
$AB_TR1
Rollback
Return

#####################################
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

