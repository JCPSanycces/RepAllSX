#<AdxTL>@(#)2.0.0.0 $Revision$
################################
# DECLARATION DE TVA ITALIENNE #
################################
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","DCLVATIT","FDCLVATIT",3,"") From GTRAITE
End


############################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
Endcase
Return

############################################
$INIT
Local Char    SYMBOLE(30)                 : # Pour lock...
Local Char    TTYP(GLONGTE)(1..200)       : # Table types pièces
Local Char    TTYPCOU(3)(1..200)          : # Table des compteurs associés aux types de pièces
Local Char    TTYPCOUCEE(3)(1..200)       : # Table des compteurs de taxes CEE (types pièces)
Local Char    TTAX(GLONVAT)(1..200)       : # Table des codes taxes
Local Char    TTAXCEE(GLONVAT)(1..200)    : # Table des codes taxes CEE
Local Char    TTAXENC(GLONVAT)(1..200)    : # Table des codes taxes / encaissements
Local Char    TSIT(GLONFCY)(1..GNBSITE)   : # Table des sites financiers
Local Char    PLAN(GLONCOA)
Local Integer NBTYP              : # Nombre de types de pièces chargés en table
Local Integer NBTAX              : # Nombre de codes taxes       "       "   
Local Integer NBTAXCEE           : # Nombre de codes taxes CEE
Local Integer NBTAXENC           : # Nombre de codes taxes / encaissements
Local Integer NBSIT              : # Nombre de sites financiers
Local Integer DCLVAT             : # Si 1, la déclaration TVA a déjà été effectuée pour la société
Local Integer OK, I, SIMUL, ITYP : # Variables diverses
Local Date    DATDEB, DATFIN     : # Dates du masque
Local Char    SOC(GLONCPY), SIT(GLONFCY)     : # Variables du masque
Local Decimal MNTEUR
Local Decimal TVALOC, BASLOC, TVACUR, BASCUR, TVAEUR, BASEUR             : # Mtts de TVA pour fichier détail
Local Decimal AMTTVAT, AMTTDUT, AMTTCUR, AMTTDUTCUR, AMTTEUR, AMTTDUTEUR : # Mtts de TVA pour fichier cumul
Local Decimal VMTTVAT, VMTTDUT, VMTTCUR, VMTTDUTCUR, VMTTEUR, VMTTDUTEUR : # Mtts de TVA (ventes)
Local Decimal SOMTVA, SOMTVAEUR  : # Cumuls annuels TVA 
Local Char    BPRNUM(GLONBPR), COMPTE(GLONGAC), COLL(GLONSAC), LVATREG(3), LTYP(GLONGTE), LJOU(GLONJOU)
Local Integer TYPTIERS, EXERCICE, TAXCEE, IMPTAX, TYPFAC, ENREG2
Local Integer TPER(15), NBPER    : # Table des périodes demandées
Local Char    TBPAR(10)(1..5), TBVAL(30)(1..5)  : # Editions
Local Decimal ADEDVAT, ADEDDUT : # Variables pour cumuler les montants déductibles sur DCLVATITA2 pour les achats
Local Decimal VDEDVAT, VDEDDUT : # Variables pour cumuler les montants déductibles sur DCLVATITA2 pour les ventes
Local Decimal INDRAT           : # Pourcentage indéductible       
Local Decimal DEDVAT           : # Valeur IVA indeductible récuperée de GACCENTRYD

# EMERAUDE - Feature MULTILEG- Requirement 71216
Local Integer INDCPY, NBRLEG
Local Char TABCPY(GLONCPY)(1..GNBSOC)
Local Char TABLEG(GLONADI)(1..GNBSOC)
Local Char WLEG(GLONADI)

If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif  # Sociétés
If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif  # Sites
If !clalev([F:GTE])  : Local File GTYPACCENT [GTE]  : Endif  # Types de pièces
If !clalev([F:TVT])  : Local File TABVAT     [TVT]  : Endif  # Codes taxes
If !clalev([F:DVI])  : Local File DCLVATITA  [DVI]  : Endif  # Déclaration de TVA détail
If !clalev([F:DV2])  : Local File DCLVATITA2 [DV2]  : Endif  # Déclaration de TVA total mensuel
If !clalev([F:DV3])  : Local File DCLVATITA3 [DV3]  : Endif  # Déclaration de TVA annuelle   
If !clalev([F:DAE])  : Local File GACCENTRYD [DAE]  : Endif  # Lignes des pièces comptables 
If !clalev([F:DAE2]) : Local File GACCENTRYD [DAE2] : Endif  # 
If !clalev([F:HAE])  : Local File GACCENTRY  [HAE]  : Endif  # En-tête des pièces comptables
If !clalev([F:DUD])  : Local File GACCDUDATE [DUD]  : Endif  # Echéances
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif  # Comptes 
If !clalev([F:TRA])  : Local File TABRATVAT  [TRA]  : Endif  # Taux de taxes    
If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif  # Business Partner
If !clalev([F:PIH])  : Local File PINVOICE   [PIH]  : Endif  # Factures d'achat fournisseur
If !clalev([F:JOU])  : Local File GJOURNAL   [JOU]  : Endif  # Journaux
If !clalev([F:TVB])  : Local File TABVACBPR  [TVB]  : Endif  # Régime de taxes tiers

Local Mask DCLVATITA [DIA] 
Raz [M:DIA]  
Return

############################################
$CONTROLE
TMP = 1  :# Pour afficher des tempon/tempoff
Return

############################################
$EXEC 
If GSERVEUR 
 [M:DIA]TRC = 2 
Endif
If !GSERVEUR & [M]TRC=2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif  
If [M]TRC=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

SYMBOLE = "DCL"+[M]STRDAT
Lock =SYMBOLE With lockwait=0
If fstat
 # Opération en cours sur autre poste
 Call ECR_TRACE(mess(30,100,1),1) From GESECRAN : Goto SORTIE
Endif

If [M:DIA]ALLCPY<>2
 INDCPY+=1
 TABCPY(INDCPY) = [M:DIA]CPY
Else
 For [CPY]CPY0 Where CPYLEGFLG=2
  If func AFNC.PARAM("ITAVAT",[F:CPY]CPY)="2"
   INDCPY+=1
   TABCPY(INDCPY) = [F:CPY]CPY
  Endif
 Next
Endif
Call LEGCPY(TABCPY,NBRLEG,TABLEG) From CPTDIV
If NBRLEG=1
 WLEG=TABLEG(1)
 Gosub LEC_GTE_TVB
 Gosub LEC_TVT_TVB
Endif

SIT    =  [M:DIA]FCY
SIMUL  = [M:DIA]SIM 
DATDEB = [M:DIA]STRDAT
DATFIN = [M:DIA]ENDDAT
GOK = 1
## Pour la ou les sociétés juridiques demandées
For [CPY]CPY0 Where ([M:DIA]ALLCPY=2 | CPY=[M:DIA]CPY) & CPYLEGFLG=2
 # Test paramètre TVA Italienne
 If func AFNC.PARAM("ITAVAT",[F:CPY]CPY)="2"
  SOC = [F:CPY]CPY

  Local Integer OK
  Call LOCKCPY(SOC, OK) From AX3MONO
  If !OK : Break : Endif

  GSOCIETE = SOC
  Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
  Call LECPLAN(GSOCIETE,GTYPGEN,PLAN) From CPTDIV

  Call ECR_TRACE(mess(2,116,1)-SOC,0) From GESECRAN   # Société
  Gosub CONTROL  : # Déclaration déjà lancée en réel ?
  If DCLVAT
   # Déclaration déjà lancée en réel pour la société
   Call ECR_TRACE(mess(13,131,1),0) From GESECRAN
  Endif
  Raz TSIT, NBSIT
  ## Chargement en table des sites financiers
  For [FCY]FCY0 Where LEGCPY=SOC & FINFLG=2
   NBSIT+=1 : TSIT(NBSIT)=[F:FCY]FCY 
  Next
  If SIT<>''
   If !find(SIT, TSIT(1..NBSIT))  # Site non financier
     Call ECR_TRACE(SIT-":"-mess(13,122,1),0) From GESECRAN
   Endif
  Endif

  # EMERAUDE - Feature MULTILEG- Requirement 71216
  If NBRLEG>1 : WLEG=[F:CPY]LEG
   Gosub LEC_GTE_TVB
   Gosub LEC_TVT_TVB
  Endif

  ## Détail de TVA
  If !DCLVAT
   Call DEBTRANS From GLOCK 
   Gosub TR_DELDVI  :  If GOK<1 : Break : Endif
   Gosub TR1        :  If GOK<1 : Break : Endif
  Endif

  ## Cumul mensuel de TVA (recalcul des périodes impactées)
  Call DEBTRANS From GLOCK 
  Gosub TR_DELDV2  :  If GOK<1 : Break : Endif
  Gosub TR2        :  If GOK<1 : Break : Endif

  ## Cumul annuel de TVA par exercice/période
  If !DCLVAT
   Call DEBTRANS From GLOCK 
   Gosub TR_DELDV3  :  If GOK<1 : Break : Endif
   Gosub TR3        :  If GOK<1 : Break : Endif
  Endif

  ## Impression état
  TBPAR(1)='societe' : TBVAL(1)=SOC
  TBPAR(2)='site'    : TBVAL(2)=SIT
  TBPAR(3)='datdeb'  : TBVAL(3)=DATDEB
  TBPAR(4)='datfin'  : TBVAL(4)=DATFIN
  TBPAR(5)='simul'   : TBVAL(5)=num$(SIMUL)
  Call ETAT("DCLVATIT",GFONCTION,TBPAR,TBVAL) From ETAT
  Call UNLOCKCPY() From AX3MONO # <JFL>
 Endif
Next

$SORTIE
Unlock =SYMBOLE
If !GSERVEUR & [M:DIA]TRC=2 
 Call FERME_TRACE From LECFIC
Endif
Return

$FIN
If !GSERVEUR & [M]TRC=2 
 TRA = 1
Else
 TRA = 0
Endif
Return

$CONTROL
# Si la déclaration de TVA a déjà été lancée en réel pour la meme borne de dates
# on ne peut pas la relancer
DCLVAT=0
Filter [DVI] Where CPY=SOC & ([M:DIA]ALLFCY=2 | FCY=SIT) & SIM<>2
&                & ACCDAT>=DATDEB & ACCDAT<=DATFIN
Look [DVI]DVI0 First
If !fstat : DCLVAT=1 : Endif
Filter [DVI]
Return

$LEC_GTE_TVB
# Chargement en table des types de pièces
Raz NBTYP, TTYP, TTYPCOU, TTYPCOUCEE
#--- Type de pièces TVA/débits uniquement, et normaux (par opposition aux A nouveaux et Clôtures)
Filter [GTE] Where LEG=[L]WLEG | LEG="" Order By Key CLE=TYP Asc ; LEG Desc
For [GTE]CLE(1)
 If [F:GTE]VAT=2 & [F:GTE]VATPAI<>2 & [F:GTE]PER=1
  NBTYP += 1
  TTYP(NBTYP) = [F:GTE]TYP
  TTYPCOU(NBTYP) = [F:GTE]COU
  TTYPCOUCEE(NBTYP) = [F:GTE]COUVATCEE
 Endif
Next
Return

$LEC_TVT_TVB
#--- Chargement en table des codes taxes, taxes/encaissements et taxes CEE
Raz NBTAX, TTAX, NBTAXCEE, TTAXCEE, NBTAXENC, TTAXENC
Filter [TVT] Where LEG=[L]WLEG | LEG="" Order By Key CLE=VAT Asc ; LEG Desc
For [TVT]CLE(1)
 If [F:TVT]VATTYP=1
  NBTAX += 1
  TTAX(NBTAX)=[F:TVT]VAT
  If [F:TVT]VATPAY = 2 : NBTAXENC += 1  :  TTAXENC(NBTAXENC)=[F:TVT]VAT : Endif
  #--- Régimes de taxe tiers
  If [F:TVT]VATVAC <> ''
   Call LEC_TVB([L]WLEG,[F:TVT]VATVAC) From CPTLEC
   If fstat : Call RSTA("TVB",[F:TVT]VATVAC-[L]WLEG) From GLOCK : Endif
   If [F:TVB]REGVAC = 4 : NBTAXCEE += 1 : TTAXCEE(NBTAXCEE)=[F:TVT]VAT : Endif
  Endif
 Endif
Next
Filter [TVT]
Return


########################################################################################
## On supprime les enreg de simulation de TVA détails correspondant à la borne de dates
$TR_DELDVI 
Trbegin [DVI] 
GOK=1
Delete [DVI] Where CPY=SOC & ([M:DIA]ALLFCY=2 | FCY=SIT) 
&                & SIM=2 & ACCDAT>=DATDEB & ACCDAT<=DATFIN
If fstat>5
 GOK=0 : Call RSTA("DVI",SOC) From GLOCK : Rollback : Return
Elsif fstat=1
 Goto ROLL_TR_DELDVI 
Endif 
Commit
Return

$ROLL_TR_DELDVI 
Rollback 
Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR_DELDVI : Endif 


###############################################################
## Déclaration de TVA : détail des pièces                     #
###############################################################
$TR1
Trbegin [DVI], [DAE]
GOK=1
Filter [HAE] Where CPY=SOC & ([M:DIA]ALLFCY=2 | FCY=SIT) & CAT<3
&                & ACCDAT>=DATDEB & ACCDAT<=DATFIN
&                & find([HAE]FCY, TSIT(1..NBSIT))
&                & find([HAE]TYP, TTYP(1..NBTYP))
&            Order By Key CLE = FCY;TYP

Filter [DAE] Where ([M:DIA]ALLFCY=2 | FCYLIN=SIT)
&                & LEDTYP=GTYPGEN
&                & TAX<>'' & TAX<>'999' & find([DAE]TAX, TTAX(1..NBTAX))
&                & find([DAE]FCYLIN, TSIT(1..NBSIT))
&            Order By Key CLE = TYP;NUM;TAX

For [HAE]CLE(1)   # site
 Call ECR_TRACE([F:HAE]FCY,0) From GESECRAN

 For [HAE]CLE(2)   # type de pièce
  ITYP = find([F:HAE]TYP, TTYP(1..NBTYP))
  Raz TPER, NBPER

  For [HAE]CLE
   ## Recherche du tiers pour alimenter le type de tiers
   Raz BPRNUM, COLL, TYPTIERS
   Filter [DAE2] Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & LEDTYP=GTYPGEN & SAC<>''
   Read [DAE2]DAE0 First
   If !fstat
    BPRNUM = [F:DAE2]BPR : COLL = [F:DAE2]SAC
    Read [DUD]DUD1 = [F:DAE2]ACCNUM;1
    If !fstat : TYPTIERS = [F:DUD]BPRTYP : Endif
   Endif
   Filter [DAE2]
   ## Tiers
   If BPRNUM='' : Raz [F:BPR]
   Else
    Read [BPR]BPR0 = BPRNUM 
    If fstat : Call FSTA("BPR") From GLOCK : Raz [F:BPR] : Endif
   Endif
   # Lecture journal pour déterminer l'imputation
   Call LEC_JOU_LEG([F:CPY]LEG,[F:HAE]JOU) From CPTLEC
   If !fstat 
    If [F:JOU]TYP = 1 
     IMPTAX = 1
    Else
     IMPTAX = 3
    Endif
   Endif   
   ## Pour fichier récap mensuel : on mémorise les périodes impactées
   If !find([F:HAE]PER, TPER(1..NBPER)) : NBPER+=1 : TPER(NBPER)=[F:HAE]PER : Endif
   EXERCICE=[F:HAE]FIY
 
   ## On parcourt les différents codes taxes pour faire la somme des mtts, sauf pour
   ## les taxes CEE où on créé un enregistrement pour chaque ligne d'écriture
   For [DAE]CLE(3) Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & LEDTYP=GTYPGEN
    TAXCEE=0 : TYPFAC=0
    Read [PIH]PIH0 = [F:DAE]NUM
    If !fstat
     If [F:PIH]CEEFLG=2    : # Facture CEE ?
      TAXCEE = 1 : TYPFAC = [F:PIH]INVTYP
     Endif
    Endif
    ## Taux de taxe : cas particulier société
    Call LEC_TVT_LEG([F:CPY]LEG,[F:DAE]TAX) From CPTLEC
    Filter [TRA] Where CPY=[F:DAE]CPY & VAT=[F:DAE]TAX & STRDAT<=[F:DAE]ACCDAT & LEG=[F:TVT]LEG
    Read [TRA]TRA0 Last
    If fstat>2
     Filter [TRA] Where CPY="" & VAT=[F:DAE]TAX & STRDAT<=[F:DAE]ACCDAT & LEG=[F:TVT]LEG
     Read [TRA]TRA0 Last
     If fstat>2 : GOK=0 : Raz [F:TRA] : Endif
    Endif
    Filter [TRA]

    ## Si plusieurs lignes avec le meme code taxe, on fait la somme des mtts.
    Raz TVALOC, BASLOC, TVACUR, BASCUR, TVAEUR, BASEUR, MNTEUR, COMPTE, DEDVAT
    For [DAE]CLE 
     Read [GAC]GAC0 = [L]PLAN;[F:DAE]ACC
     If fstat
      GOK=0 : Call RSTA("GAC",[F:DAE]COA-[F:DAE]ACC) From GLOCK : Break 5
     Endif
     Case [F:GAC]FLGVAT
      When 2, 5 :  # Compte soumis
       COMPTE = [F:DAE]ACC     :#   IMPTAX = [F:GAC]VATIPT
       BASLOC += [F:DAE]SNS*[F:DAE]AMTLED
       BASCUR += [F:DAE]SNS*[F:DAE]AMTCUR
       If [F:DAE]CUR=GEURO
        BASEUR += [F:DAE]SNS*[F:DAE]AMTCUR
       Elsif [F:DAE]CURLED=GEURO
        BASEUR += [F:DAE]SNS*[F:DAE]AMTLED
       Else
        Call CONVERT([F:DAE]CUR,GEURO,[F:DAE]CURLED,[F:HAE]TYPRAT,[F:HAE]ACCDAT
&                   ,[F:DAE]AMTCUR,MNTEUR,STAT) From TRTDEV
        BASEUR += [F:DAE]SNS*[L]MNTEUR
        If STAT : # Pas de cours de devises [F:DAE]CUR -> GEURO (ACCDAT)
         GMESSAGE=mess(16,114,1)-[F:DAE]CUR-"->"-GEURO-"("+format$("D:"+GFMDAT,[F:HAE]ACCDAT)-")"
         GOK=0 : Break 5
        Endif
       Endif
      When 3, 4 :  # Comptes de TVA et TVA CEE
       If COMPTE='' : COMPTE=[F:DAE]ACC : Endif      :#   IMPTAX=[F:GAC]VATIPT
       TVALOC += [F:DAE]SNS*[F:DAE]AMTLED
       TVACUR += [F:DAE]SNS*[F:DAE]AMTCUR
       If [F:DAE]CUR=GEURO
        TVAEUR += [F:DAE]SNS*[F:DAE]AMTCUR
       Elsif [F:DAE]CURLED=GEURO
        TVAEUR += [F:DAE]SNS*[F:DAE]AMTLED
       Else
        Call CONVERT([F:DAE]CUR,GEURO,[F:DAE]CURLED,[F:HAE]TYPRAT,[F:HAE]ACCDAT
&                   ,[F:DAE]AMTCUR,MNTEUR,STAT) From TRTDEV
        TVAEUR += [F:DAE]SNS*[L]MNTEUR
        If STAT : # Pas de cours de devises [F:DAE]CUR -> GEURO (ACCDAT)
         GMESSAGE=mess(16,114,1)-[F:DAE]CUR-"->"-GEURO-"("+format$("D:"+GFMDAT,[F:HAE]ACCDAT)-")"
         GOK=0 : Break 5
        Endif
       Endif
       If dim([F:DAE]INDEDVAT)>0
        DEDVAT += [F:DAE]SNS*[F:DAE]INDEDVAT   # Recupération IVA indeduc. de GACCCENTRYD
       Endif
       If TAXCEE
        TVALOC = [F:DAE]SNS*[F:DAE]AMTLED
        TVACUR = [F:DAE]SNS*[F:DAE]AMTCUR
        If [F:DAE]CUR=GEURO
         TVAEUR = [F:DAE]SNS*[F:DAE]AMTCUR
        Elsif [F:DAE]CURLED=GEURO
         TVAEUR = [F:DAE]SNS*[F:DAE]AMTLED
        Else
         Call CONVERT([F:DAE]CUR,GEURO,[F:DAE]CURLED,[F:HAE]TYPRAT,[F:HAE]ACCDAT
&                    ,[F:DAE]AMTCUR,MNTEUR,STAT) From TRTDEV
         TVAEUR = [F:DAE]SNS*[L]MNTEUR
         If STAT : # Pas de cours de devises [F:DAE]CUR -> GEURO (ACCDAT)
          GMESSAGE=mess(16,114,1)-[F:DAE]CUR-"->"-GEURO-"("+format$("D:"+GFMDAT,[F:HAE]ACCDAT)-")"
          GOK=0 : Break 5
         Endif
        Endif
        If dim([F:DAE]INDEDVAT)>0
         DEDVAT = [F:DAE]SNS*[F:DAE]INDEDVAT
        Endif
       Endif
       ## Si lancement en réel, on met à jour la zone TVA déclarée
       If SIMUL=1
        [F:DAE]AMTVAT = [F:DAE]AMTLED 
        Rewrite [DAE]
        If fstat
         GOK=0 : Call FSTA("DAE") From GLOCK : Break 5
        Endif
       Endif
      Endcase
     Next  # [DAE]CLE
     LVATREG=TTYPCOU(ITYP) : LTYP=[F:DAE]TYP : LJOU=[F:HAE]JOU 
     ENREG2 = 0
     Gosub ENREG_DVI  :  If GOK<1 : Break 4 : Endif
     If TAXCEE
      LVATREG = TTYPCOUCEE(ITYP) : ENREG2 = 1
      LTYP = TTYPCOUCEE(ITYP) : LJOU = TTYPCOUCEE(ITYP)
      If find(IMPTAX,1,2) : IMPTAX=3 
      Elsif find(IMPTAX,3,4) : IMPTAX=1 : Endif
      Gosub ENREG_DVI
      If GOK<1 : Break 4 : Endif
     Else
     Endif
   Next  # [DAE]CLE(3)
   If GOK<1 : Break 3 : Endif
  Next  # pièce
 Next  # type de pièce
Next  # site
Filter [DAE]
Filter [HAE]
If GOK<0   : Goto ROLL_TR1
Elsif !GOK : Goto AB_TR1
Endif 
Commit
Return

$ROLL_TR1
Rollback  
Call ROLL From GLOCK  
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return

$ENREG_DVI
Raz [F:DVI]
[F:DVI]CPY = SOC
[F:DVI]FCY = SIT
[F:DVI]VATREG = LVATREG
Case IMPTAX
 When 1, 2 : [F:DVI]REGTYP = "V"   # TVA collectée
 When 3, 4 : [F:DVI]REGTYP = "A"   # TVA déductible
Endcase
[F:DVI]VATTYP = [F:DVI]VATREG + [F:DVI]REGTYP
[F:DVI]VAT    = [F:DAE]TAX
[F:DVI]VATRAT = [F:TRA]VATRAT
[F:DVI]ACCDAT = [F:DAE]ACCDAT 
If SIMUL=1 & [F:HAE]BOLLATO<>'' 
 [F:DVI]NUM   = [F:HAE]BOLLATO
Else
 [F:DVI]NUM   = [F:HAE]NUM 
Endif
[F:DVI]DEDRAT = [F:TRA]DEDRAT  : [F:DVI]ACC  = COMPTE
[F:DVI]PER    = [F:HAE]PER     : [F:DVI]FIY  = [F:HAE]FIY
[F:DVI]TYP    = LTYP           : [F:DVI]JOU  = LJOU
[F:DVI]DESVCR = [F:DAE]DES
If TAXCEE
 Case TYPFAC
  When 1,4 : If ENREG2 : [F:DVI]SNS=2 : Else : [F:DVI]SNS=1 : Endif
  When 2,3 : If ENREG2 : [F:DVI]SNS=1 : Else : [F:DVI]SNS=2 : Endif
 Endcase
Else
 If BASLOC < 0 : [F:DVI]SNS = 2 : Else : [F:DVI]SNS = 1 : Endif
Endif
[F:DVI]AMTVAT = abs(TVALOC)    : [F:DVI]AMTCUR = abs(TVACUR)
[F:DVI]AMTEUR = abs(TVAEUR)    : [F:DVI]AMTDUT = abs(BASLOC)
[F:DVI]AMTDUTCUR = abs(BASCUR) : [F:DVI]AMTDUTEUR = abs(BASEUR)
[F:DVI]CUR    = [F:DAE]CUR     : [F:DVI]EURCUR = GEURO
[F:DVI]SIM    = SIMUL
[F:DVI]VATPAY = 0
If find([F:DAE]TAX, TTAXENC(1..NBTAXENC)) : [F:DVI]VATPAY = 1 : Endif
[F:DVI]BPRNAM(0) = [F:BPR]BPRNAM(0)
[F:DVI]BPRNAM(1) = [F:BPR]BPRNAM(1)
[F:DVI]EECNUM = [F:BPR]EECNUM
[F:DVI]FCYNUM = [F:DAE]FCYLIN  
[F:DVI]VATNUM = [F:BPR]VATNUM  : # GB 20/07/01 Ajout chp VATNUM pour cohérence 120
If TYPTIERS <> 0 : [F:DVI]BPRTYP = TYPTIERS
Elsif BPRNUM<>''
 #--- Si le tiers est à la fois client et fournisseur, on va lire le collectif
 #--- S'il y a toujours ambiguïté, on regarde la mise à jour du solde
 If [F:BPR]BPCFLG = 2   # Si  client
  If [F:BPR]BPSFLG = 2   # Si  fournisseur
   Read [GAC]GAC1 = PLAN;COLL
   If fstat
    GOK=0 : Call RSTA("GAC",COLL) From GLOCK : Return
   Endif
   If [F:GAC]AUZBPR(0) = 2   # Autorisation client
    If [F:GAC]AUZBPR(1) = 2   # Autorisation fournisseur
     Case [F:GAC]UPDBLC
      When 1 :  #--- ??? Pas de màj de solde
       [F:DVI]BPRTYP = 1
      When 2 :  #--- Mise à jour solde client
       [F:DVI]BPRTYP = 1
      When 3 :  #--- Mise à jour solde fournisseur
       [F:DVI]BPRTYP = 2
     Endcase
    Else
     [F:DVI]BPRTYP = 1   # Client
    Endif
   Elsif [F:GAC]AUZBPR(1) = 2
    [F:DVI]BPRTYP = 2    # Fournisseur
   Endif
  Else  # BPSFLG=2
   [F:DVI]BPRTYP = 1
  Endif
 Elsif [F:BPR]BPSFLG = 2 
  [F:DVI]BPRTYP = 2
 Endif
Endif
[F:DVI]BPRNUM = BPRNUM
[F:DVI]INVNUM = [F:HAE]BPRVCR
[F:DVI]INVDAT = [F:HAE]BPRDATVCR
If [F:DVI]DEDRAT = 100 
 INDRAT = 0
 [F:DVI]DEDDUT = 0
 [F:DVI]DEDVAT = 0
Else
 INDRAT = 100 - [F:DVI]DEDRAT
 [F:DVI]DEDDUT = arr([F:DVI]AMTDUT*INDRAT/100,0.01)
 If DEDVAT = 0    :# recuperation TVA indeductible
  [F:DVI]DEDVAT = arr([F:DVI]AMTVAT*INDRAT/100,0.01)
 Else
  [F:DVI]DEDVAT = abs(DEDVAT)
 Endif
Endif 
Write [DVI]
If fstat 
 OK=0 : Call FSTA("DVI") From GLOCK
Endif  
Return


###############################################################
## Déclaration de TVA mensuelle / période                     #
###############################################################
$TR2
Trbegin [DV2]
GOK=1
Filter [DVI] Where CPY=SOC & FCY=SIT & ACCDAT>=DATDEB & ACCDAT<=DATFIN
&            & find([F:DVI]PER, TPER(1..NBPER))
#--- Cumul par période des pièces achats, ventes regroupées par taxe/taux/%ded
For [DVI]DVI1(4)
 Raz AMTTVAT, AMTTCUR, AMTTEUR, AMTTDUT, AMTTDUTCUR, AMTTDUTEUR
 Raz VMTTVAT, VMTTCUR, VMTTEUR, VMTTDUT, VMTTDUTCUR, VMTTDUTEUR
 Raz ADEDVAT, ADEDDUT, VDEDVAT, VDEDDUT 
 For [DVI]DVI1
  If [F:DVI]SNS=2 : [F:DVI]SNS=-1 : Endif
  If [F:DVI]REGTYP = "A"
   AMTTVAT += [F:DVI]SNS*[F:DVI]AMTVAT
   AMTTCUR += [F:DVI]SNS*[F:DVI]AMTCUR 
   AMTTEUR += [F:DVI]SNS*[F:DVI]AMTEUR
   AMTTDUT += [F:DVI]SNS*[F:DVI]AMTDUT 
   AMTTDUTCUR += [F:DVI]SNS*[F:DVI]AMTDUTCUR
   AMTTDUTEUR += [F:DVI]SNS*[F:DVI]AMTDUTEUR
   ADEDVAT += [F:DVI]SNS*[F:DVI]DEDVAT
   ADEDDUT += [F:DVI]SNS*[F:DVI]DEDDUT
  Elsif [F:DVI]REGTYP = "V"
   VMTTVAT += [F:DVI]SNS*[F:DVI]AMTVAT
   VMTTCUR += [F:DVI]SNS*[F:DVI]AMTCUR
   VMTTEUR += [F:DVI]SNS*[F:DVI]AMTEUR
   VMTTDUT += [F:DVI]SNS*[F:DVI]AMTDUT
   VMTTDUTCUR += [F:DVI]SNS*[F:DVI]AMTDUTCUR
   VMTTDUTEUR += [F:DVI]SNS*[F:DVI]AMTDUTEUR
   VDEDVAT += [F:DVI]SNS*[F:DVI]DEDVAT
   VDEDDUT += [F:DVI]SNS*[F:DVI]DEDDUT
  Endif
 Next
 Raz [F:DV2]
 [F:DV2]CPY = SOC
 [F:DV2]FCY = SIT
 [F:DV2]FIY = [F:DVI]FIY
 [F:DV2]PER = [F:DVI]PER
 [F:DV2]VAT = [F:DVI]VAT
 [F:DV2]CUR = [F:DVI]CUR
 [F:DV2]VATRAT = [F:DVI]VATRAT
 [F:DV2]DEDRAT = [F:DVI]DEDRAT
 [F:DV2]EURCUR = [F:DVI]EURCUR
 [F:DV2]VATPAY = [F:DVI]VATPAY
 If AMTTDUT < 0 : [F:DV2]SNS = -1 : Else : [F:DV2]SNS = 1 : Endif
 [F:DV2]REGIVA = "A01"
 [F:DV2]REGTYP = "A"
 [F:DV2]AMTVAT = abs(AMTTVAT)
 [F:DV2]AMTCUR = abs(AMTTCUR)
 [F:DV2]AMTEUR = abs(AMTTEUR)
 [F:DV2]AMTDUT = abs(AMTTDUT)
 [F:DV2]AMTDUTEUR = abs(AMTTDUTEUR)
 [F:DV2]AMTDUTCUR = abs(AMTTDUTCUR)
 [F:DV2]DEDVAT = abs(ADEDVAT)
 [F:DV2]DEDDUT = abs(ADEDDUT)
 Gosub ENREG_DV2 : If GOK<1 : Break : Endif
 If VMTTDUT < 0 : [F:DV2]SNS = -1 : Else : [F:DV2]SNS = 1 : Endif
 [F:DV2]REGIVA = "V01"
 [F:DV2]REGTYP = "V"
 [F:DV2]AMTVAT = abs(VMTTVAT)
 [F:DV2]AMTCUR = abs(VMTTCUR)
 [F:DV2]AMTEUR = abs(VMTTEUR)
 [F:DV2]AMTDUT = abs(VMTTDUT)
 [F:DV2]AMTDUTEUR = abs(VMTTDUTEUR)
 [F:DV2]AMTDUTCUR = abs(VMTTDUTCUR)
 [F:DV2]DEDVAT = abs(VDEDVAT)
 [F:DV2]DEDDUT = abs(VDEDDUT)
 Gosub ENREG_DV2 : If GOK<1 : Break : Endif
 If (VMTTDUT + AMTTDUT) < 0 : [F:DV2]SNS = -1 : Else : [F:DV2]SNS = 1 : Endif
 [F:DV2]REGIVA = "Z01"
 [F:DV2]REGTYP = " "
 [F:DV2]AMTVAT = abs(VMTTVAT + AMTTVAT)
 [F:DV2]AMTCUR = abs(VMTTCUR + AMTTCUR)
 [F:DV2]AMTEUR = abs(VMTTEUR + AMTTEUR)
 [F:DV2]AMTDUT = abs(VMTTDUT + AMTTDUT)
 [F:DV2]AMTDUTEUR = abs(VMTTDUTEUR + AMTTDUTEUR) 
 [F:DV2]AMTDUTCUR = abs(VMTTDUTCUR + AMTTDUTCUR)
 [F:DV2]DEDVAT = abs(VDEDVAT+ADEDVAT)
 [F:DV2]DEDDUT = abs(VDEDDUT+ADEDDUT)
 Gosub ENREG_DV2 : If GOK<1 : Break : Endif
Next
Filter [DVI]
If GOK<0   : Goto ROLL_TR2
Elsif !GOK : Goto AB_TR2
Endif 
Commit
Return

$ENREG_DV2
If [F:DV2]AMTVAT<>0 | [F:DV2]AMTCUR<>0 | [F:DV2]AMTEUR<>0 | [F:DV2]AMTDUT<>0 |
&   [F:DV2]AMTDUTEUR<>0 | [F:DV2]AMTDUTCUR<>0
 Write [DV2]
 If fstat
  GOK=0 : Call FSTA("DV2") From GLOCK
 Endif
Endif
Return

$ROLL_TR2
Rollback  
Call ROLL From GLOCK  
If GROLL : Return : Else : Goto TR2 : Endif  

$AB_TR2
Rollback
Return

########################################################
## On supprime les périodes demandées du fichier récap
$TR_DELDV2
Trbegin [DV2]
GOK=1
Delete [DV2] Where CPY=SOC & ([M:DIA]ALLFCY=2 | FCY=SIT) & FIY=EXERCICE & find([F:DV2]PER, TPER(1..NBPER))
If fstat>5 
 GOK=0 : Call RSTA("DV2",SOC-SIT) From GLOCK : Rollback : Return
Elsif fstat=1
 Goto ROLL_TR_DELDV2
Endif 
Commit 
Return

$ROLL_TR_DELDV2
Rollback 
Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR_DELDV2 : Endif
   

#####################################################
## Déclaration de TVA annuelle par exercice/période #
#####################################################
$TR3
Trbegin [DV3]
GOK=1
For I=1 To NBPER
 Raz SOMTVA, SOMTVAEUR
 If TPER(I) > 1
  Read [DV3]DV30= SOC;SIT;EXERCICE;TPER(I)-1
  If !fstat
   SOMTVA = [F:DV3]VATCRE - [F:DV3]VATDEB
   SOMTVAEUR = [F:DV3]EURVATCRE - [F:DV3]EURVATDEB
  Endif
 Else
  Filter [DV3] Where CPY=SOC & FCY=SIT & FIY=EXERCICE-1
  Read [DV3]DV30 Last
  If !fstat
   SOMTVA = [F:DV3]VATCRE - [F:DV3]VATDEB
   SOMTVAEUR = [F:DV3]EURVATCRE - [F:DV3]EURVATDEB
  Endif
  Filter [DV3]
 Endif
 If SOMTVA<0 & I=1
   Raz SOMTVA, SOMTVAEUR
 Endif
 For [DV2] Where CPY=SOC & ([M:DIA]ALLFCY=2 | FCY=SIT) & FIY=EXERCICE & PER=TPER(I)
&              & (REGTYP="A" | REGTYP="V") & VATRAT<>0
  #SOMTVAEUR += [F:DV2]SNS*(([F:DV2]AMTEUR*[F:DV2]DEDRAT)/100)
  SOMTVA += [F:DV2]SNS*([F:DV2]AMTVAT-[F:DV2]DEDVAT)     :# 23/10/02
  SOMTVAEUR += [F:DV2]SNS*([F:DV2]AMTEUR-[F:DV2]DEDVAT)
 Next
 Gosub ENREG_DV3 : If GOK<1 : Break : Endif
Next I
If GOK<0   : Goto ROLL_TR3
Elsif !GOK : Goto AB_TR3
Endif 
Commit
Return

$ROLL_TR3
Rollback  
Call ROLL From GLOCK  
If GROLL : Return : Else : Goto TR3 : Endif

$AB_TR3
Rollback
Return

$ENREG_DV3
Raz [F:DV3]
[F:DV3]CPY = SOC         : [F:DV3]FCY = SIT
[F:DV3]FIY = EXERCICE    : [F:DV3]PER = TPER(I)
If SOMTVA > 0 
 [F:DV3]VATCRE = SOMTVA  : [F:DV3]EURVATCRE = SOMTVAEUR
Else 
 [F:DV3]VATDEB = abs(SOMTVA)  : [F:DV3]EURVATDEB = abs(SOMTVAEUR)
Endif
[F:DV3]BASVAT = 0        : [F:DV3]SPSVAT = 0
[F:DV3]EURBASVAT = 0     : [F:DV3]EURSPSVAT = 0
Write [DV3]
If fstat
 GOK=0 : Call FSTA("DV3") From GLOCK
Endif
Return


#########################################################
## On supprime du fichier annuel les périodes impactées
$TR_DELDV3
Trbegin [DV3] 
 GOK=1
 Delete [DV3] Where CPY=SOC & ([M:DIA]ALLFCY=2 | FCY=SIT) & FIY=EXERCICE 
&                 & find([F:DV3]PER, TPER(1..NBPER))
 If fstat>5 
  GOK=0 : Call RSTA("DV3",SOC-SIT) From GLOCK
  Rollback : Return
 Elsif fstat=1
  Goto ROLL_TR_DELDV3
 Endif 
Commit 
Return


$ROLL_TR_DELDV3
Rollback 
Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR_DELDV3 : Endif


##################################
# Etiquettes du masque DCLVATITA # 
################################## 
Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo [M]CPY, FCY : [M]ALLFCY=2
 Grizo [M]CPY, ALLFCY, FCY
Else
 Actzo [M]CPY, ALLFCY
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call AS_CPY(VALEUR) From CPTTRT
End

Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo [M]FCY : Grizo [M]FCY
Else
 Actzo [M]FCY
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From CPTTRT
End

Subprog D_STRDAT(VALEUR)
Variable Date    VALEUR 
VALEUR = gdat$(1,month(date$),year(date$))
End
 
Subprog D_ENDDAT(VALEUR) 
Variable Date    VALEUR 
VALEUR = eomonth([M]STRDAT) 
End

