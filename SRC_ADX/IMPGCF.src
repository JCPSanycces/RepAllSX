#<AdxTL>@(#)10.0.0.0 $Revision$

$ACTION
 Case ACTION
  When "IMP_OUVRE"     : Gosub IMP_OUVRE
  When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CRE
  When "IMP_VERIF_MOD" : Gosub IMP_VERIF_MOD
 Endcase
Return


$IMP_OUVRE
If clalev([COA]) = 0 : Local File GCOA     [COA] : Endif
If clalev([GAC]) = 0 : Local File GACCOUNT [GAC] : Endif

Return


$IMP_VERIF_CRE
$IMP_VERIF_MOD

OK=1
Gosub CONTROLE
Return


$CONTROLE
#--------- Le champs COAORI est obligatoire et existant
If [F:GCF]COAORI=""
 GMESSAGE ="COAORI"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Else
 Read [COA]COA0=[F:GCF]COAORI
 If fstat
  GMESSAGE = "COAORI"-mess(83,123,1)-[F:GCF]COAORI  # Valeur incorrecte
  OK=0 : Return
 Endif
Endif

#--------- Le champs COADEN est obligatoire et existant
If [F:GCF]COADEN=""
 GMESSAGE ="COADEN"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Else
 Read [COA]COA0=[F:GCF]COADEN
 If fstat
  GMESSAGE = "COADEN"-mess(83,123,1)-[F:GCF]COADEN  # Valeur incorrecte
  OK=0 : Return
 Endif
Endif

#--------- Le champs COASTR est obligatoire
If [F:GCF]COASTR=""
 GMESSAGE = "COASTR"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Else
 If [F:COA]FXDLEN=2 & [F:GCF]COASTR<>"*"
  If vireblc([F:GCF]COASTR,2)<>vireblc(format$([F:COA]ACCFMT,[F:GCF]COASTR),2) 
   # Format incorrect
   GMESSAGE = [F:GCF]COASTR-mess(149,100,1)
   OK=0 : Return
  Endif
 Endif
Endif 

#--------- Le champs ACC est obligatoire et doit existé
If [F:GCF]COASTR<>"*"
 If [F:GCF]ACC=""
  GMESSAGE = "ACC"-mess(10,123,1) # Zone obligatoire
  OK=0 : Return
 Else
  Read [F:GAC]GAC0 = [F:GCF]COADEN;[F:GCF]ACC
  If fstat
   GMESSAGE = [F:GCF]ACC-mess(44,102,1) # Compte inexistant
   OK=0 : Return
  Endif
 Endif
Endif
Return


