$PROPERTIES
Case [L]CURPRO
  When "CIV"                        : Gosub EMPESS_CIV
  When "CIVA"                       : Gosub EMPESS_CIVA
  When "SRN"                        : Gosub EMPESS_SRN
  When "NCKNAM"                     : Gosub EMPESS_NCKNAM
  When "CTYBRN"                     : Gosub EMPESS_CTYBRN
  When "NAM"                        : Gosub EMPESS_NAM
  When "PSD"                        : Gosub EMPESS_PSD
  When "SECNAM"                     : Gosub EMPESS_SECNAM
  When "CTYBRN"                     : Gosub EMPESS_CTYBRN
  When "ADDPOSCOF"                  : Gosub EMPESS_ADDPOSCOF
  When "SEX"                        : Gosub EMPESS_SEX
  When "PERCNT.SRNCNT"              : Gosub EMPESS_PERCNT_SRNCNT
  When "PERCNT.NAMCNT"              : Gosub EMPESS_PERCNT_NAMCNT
  When "PERCNT.CNTTYP"              : Gosub EMPESS_PERCNT_CNTTYP
Endcase
Return

$EMPESS_CIV
Case [L]ARULE
  When "INIT"
    Gosub EMPESS_CIV_INIT
  When "PROPOGATE"
    Gosub EMPESS_CIV_PROPOGATE
Endcase
Return

$EMPESS_CIVA
Case [L]ARULE
