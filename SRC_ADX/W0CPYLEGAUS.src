#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPYLEGAUS 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone TRDNAM
mkstat = 0
zoncou = "TRDNAM"
indice = 0
If varmode([M]TRDNAM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TRDNAM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ABNNUM
mkstat = 0
zoncou = "ABNNUM"
indice = 0
If varmode([M]ABNNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ABNNUM" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ABNNUM([M]ABNNUM) From TRTCPYLEGAUS
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ABNNUM" : GZNUM = 56088 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone WPNNUM
mkstat = 0
zoncou = "WPNNUM"
indice = 0
If varmode([M]WPNNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WPNNUM" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_WPNNUM([M]WPNNUM) From TRTCPYLEGAUS
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "WPNNUM" : GZNUM = 56090 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone ADDID
mkstat = 0
zoncou = "ADDID"
indice = 0
status = 1
zoncou = "ADDID"
If varmode([M]ADDID,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ADDID" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]ADDID
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]ADDID = nolign
   status = 75
   Call SAI_ADDID(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_ADDID(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone ADDID
mkstat = 0
zoncou = "ADDID"

## Zone ADDTYP
mkstat = 0
zoncou = "ADDTYP"
IMPENT = [M]ADDTYP(indice)
If varinit([M]ADDTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]ADDTYP,indice)=0
 [M]ADDTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ADDTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ADDTYP(indice)
 Endif
Endif
[M]ADDTYP(indice) = IMPENT

## Zone ADDR1
mkstat = 0
zoncou = "ADDR1"
SAVACT = GACTION : GACTION = "FMTADRPAY"
Call FMTADRPAY("") From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]ADDR1(indice) : Endif
If !mkstat
 If varmode([M]ADDR1,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "ADDR1" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone ADDR2
mkstat = 0
zoncou = "ADDR2"
SAVACT = GACTION : GACTION = "FMTADRPAY"
Call FMTADRPAY("") From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]ADDR2(indice) : Endif
If !mkstat
 If varmode([M]ADDR2,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "ADDR2" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone ADDR3
mkstat = 0
zoncou = "ADDR3"
SAVACT = GACTION : GACTION = "FMTADRPAY"
Call FMTADRPAY("") From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]ADDR3(indice) : Endif
If !mkstat
 If varmode([M]ADDR3,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "ADDR3" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone ADDR4
mkstat = 0
zoncou = "ADDR4"
SAVACT = GACTION : GACTION = "FMTADRPAY"
Call FMTADRPAY("") From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]ADDR4(indice) : Endif
If !mkstat
 If varmode([M]ADDR4,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "ADDR4" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone ADDSUB
mkstat = 0
zoncou = "ADDSUB"
If varmode([M]ADDSUB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ADDSUB" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone POSCOD
mkstat = 0
zoncou = "POSCOD"
If varmode([M]POSCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "POSCOD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone XSAT
mkstat = 0
zoncou = "XSAT"
If varmode([M]XSAT,indice)=0
 SAVACT = GACTION : GACTION = "SAISAT"
 Call SAISAT(CRY,"") From TRTDIV
 GACTION = SAVACT
 If mkstat=1 : Raz [M]XSAT(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "XSAT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CTLSAT"
  PARAM(1) = CRY
  PARAM(2) = ""
  Local Char    VALEUR(250)
  VALEUR = [M]XSAT(indice)
  Call S_AFF_CHAR(VALEUR,PARAM,"CTLSAT","TRTDIV","") From GACTION
  [M]XSAT(indice) = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "XSAT" : GZNUM = 51590 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CRY
mkstat = 0
zoncou = "CRY"
If varinit([M]CRY,indice)=0
 [M]CRY(indice) = GPAYS
Endif
If varmode([M]CRY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CRY" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TCY","!",[M]CRY(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 263 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone ADDID
mkstat = 0
zoncou = "ADDID"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CPYLEGAUS"
Return

