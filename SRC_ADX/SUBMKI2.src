########################################
Subprog AS_NBLIG
GBOUT1 = ""
GBOUT2 = ""
If [M:MKI2]NBLIG = 0 : End : Endif
If [M:MKI2]MFMITMREF(nolign-1) = ""  : End : Endif
GBOUT1 = mess(16,198,1)
If clalev ([M:MTK0]) <= 0 : GBOUT2 = mess(313,198,1) : Endif
End

########################################
Subprog AV_USEQTY(VALEUR)
Variable Decimal VALEUR
If [M:MKI2]MATTYP(nolign-1) = 3 
    pcolor = GCOUL(3)
Else
    pcolor = GCOUL(0)
Endif

End

