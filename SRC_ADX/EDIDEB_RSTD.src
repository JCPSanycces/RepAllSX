#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Representation EDIDEB                                                       #
# Author : RBA                                                                #
###############################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub AREAD_AFTER
      Endcase
    When "EDB"
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EDB_AREAD_AFTER
      Endcase
    When "EDB.EDEBD"
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EDB_EDEBD_AREAD_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_LOAD_DETAIL"               : Gosub MET_LOAD_DETAIL
    When "MET_AFTER_LOAD_REPRESENTATION" : Gosub MET_AFTER_LOAD_REPRESENTATION
  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "EDB.CPY"
      Case [L]ARULE
        When 'PROPAGATE'  : Gosub EDB_CPY_PROPAGATE
      Endcase
    When "EDB.DEBYEAR"
      Case [L]ARULE
        When 'PROPAGATE'  : Gosub EDB_DEBYEAR_PROPAGATE
      Endcase
    When "EDB.DEBMONTH"
      Case [L]ARULE
        When 'PROPAGATE'  : Gosub EDB_DEBMONTH_PROPAGATE
      Endcase

  Endcase
Return
####################################################################

$EDB_CPY_PROPAGATE
  Local Integer WOK
  WOK = fmet this.APARENT.MET_LOAD_DETAIL()
  ASTATUS = WOK
Return

####################################################################

$EDB_DEBYEAR_PROPAGATE
  Local Integer WOK
  WOK = fmet this.APARENT.MET_LOAD_DETAIL()
  ASTATUS = WOK
Return

####################################################################

$EDB_DEBMONTH_PROPAGATE
  Local Integer WOK
  WOK = fmet this.APARENT.MET_LOAD_DETAIL()
  ASTATUS = WOK
Return

####################################################################

$EDB_AREAD_AFTER
  Call EDB_DISPLAY(this)
Return

####################################################################

$EDB_EDEBD_AREAD_AFTER
  Call EDB_EDEBD_DISPLAY(this)
Return

####################################################################

$AREAD_AFTER
  Gosub GETVALPARAMURL From TRTFUNEDI

  this.DEBEDIDAT  = format$("D:4Y[-]2M[-]2D",this.EDB.DEBDATTIM)
  this.DEBEDITIM  = format$("D:hh[:]mm[:]ss",this.EDB.DEBDATTIM)
  this.SOFTWARE = "Sage Cloud EM"

  Local Integer WOK
  WOK = fmet this.MET_LOAD_DETAIL()
  ASTATUS = WOK
Return

#####################################################################

#********************************************************************
# Subprog DISPLAY
#********************************************************************
#
#* @param WOBJECT
#*!
Subprog EDB_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer I, WOK
End

#********************************************************************
# Subprog EPT_EPTD_DISPLAY
#********************************************************************
#
#* @param WOBJECT
#*!
Subprog EDB_EDEBD_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer I, WOK
End

##############################################################################

$MET_LOAD_DETAIL
  Local Integer WOK : WOK = [V]CST_AOK

  Local Integer WI  : WI  = 0
  Local Integer WJ  : WJ  = 0

  Call DELETELINES(this.EDB,"EDEBD") From EDILIBA
  If this.EDB.CPY <> "" and this.EDB.DEBYEAR <> 0 and this.EDB.DEBMONTH <> 0
    #Query
    Local File DEB [DEB]
    Filter [DEB] Where [DEB]CPY = this.EDB.CPY
&     and year([DEB]DEBDAT) = this.EDB.DEBYEAR
&     and month([DEB]DEBDAT) = this.EDB.DEBMONTH
&     Order By [DEB]CPY;[DEB]FLO;[DEB]DEBDAT;[DEB]VCRTYP;[DEB]VCRNUM;[DEB]VCRLIN
    For [DEB]
      WI = fmet this.EDB.ADDLINE("EDEBD",[V]CST_ALASTPOS)
      #detail
      SetInstance this.EDB.EDEBD(WI) With [DEB]
      this.EDB.EDEBD(WI).REFPERIOD = num$(this.EDB.DEBYEAR) + "-" + num$(format$("N0:2",this.EDB.DEBMONTH))
      this.EDB.EDEBD(WI).PSIID     = this.EDB.PARTY(1).PARTYID #there is only one party
      this.EDB.EDEBD(WI).FUNCOD    = "O"
      Case this.EDB.EDEBD(WI).FLO
        When 1       : this.EDB.EDEBD(WI).FLOCOD    = "A"
        When 2       : this.EDB.EDEBD(WI).FLOCOD    = "D"
        When Default : this.EDB.EDEBD(WI).FLOCOD    = "A" #error
      Endcase #A : Introduction // D : expédition

      WJ  = 0
      WJ = fmet this.EDB.EDEBD(WI).ADDLINE("ITEM",[V]CST_ALASTPOS)
      this.EDB.EDEBD(WI).ITEM(WJ).ITMNUM  = "000001"
      this.EDB.EDEBD(WI).ITEM(WJ).CUSREF  = [DEB]CUSREF
      this.EDB.EDEBD(WI).ITEM(WJ).DESCRY  = [DEB]DESCRY
      this.EDB.EDEBD(WI).ITEM(WJ).ORICRY  = [DEB]ORICRY
      this.EDB.EDEBD(WI).ITEM(WJ).NETMAS  = [DEB]NETMAS
      this.EDB.EDEBD(WI).ITEM(WJ).FISAMT  = [DEB]FISAMT

      Local File BPARTNER [BPA]
      Read [BPA]BPR0 = [DEB]BPRNUM
      If !fstat
        this.EDB.EDEBD(WI).ITEM(WJ).EECNUM  = [BPA]EECNUM
      Endif
      LogicClose File [BPA]

      this.EDB.EDEBD(WI).ITEM(WJ).EECSCH  = [DEB]EECSCH
      this.EDB.EDEBD(WI).ITEM(WJ).EECNAT  = [DEB]EECNAT
      this.EDB.EDEBD(WI).ITEM(WJ).EECUNT  = [DEB]EECUNT
      Local Char WEECNAT(5) :     WEECNAT = [DEB]EECNAT
      this.EDB.EDEBD(WI).ITEM(WJ).EECNAT  = WEECNAT
      If len(WEECNAT) > 2
        WEECNAT = right$(WEECNAT, len(WEECNAT) + 1 -2)
      Endif
      If WEECNAT <> ""
        this.EDB.EDEBD(WI).ITEM(WJ).EECNATA = left$(WEECNAT, 1)
        this.EDB.EDEBD(WI).ITEM(WJ).EECNATB = right$(WEECNAT, 2)
      Endif
      this.EDB.EDEBD(WI).ITEM(WJ).EECTRN  = [DEB]EECTRN
      this.EDB.EDEBD(WI).ITEM(WJ).REG     = [DEB]REG

    Next
    LogicClose File [DEB]

    this.DOCID = this.EDB.CPY+"!"+num$(this.EDB.DEBYEAR)+"!"+num$(this.EDB.DEBMONTH)
  Endif
  ARET_VALUE = WOK
Return

##############################################################################

#********************************************************************
# Method MET_AFTER_LOAD_REPRESENTATION
#********************************************************************
#
#*
#* @param WCATACT
#* @param WCATCOD
#* @param WPARCOD
#* @param WDUPLICATE
#* @param WTEST
#* @param WSEPDEC #114721
#* @param WERR
#* @return [V]CST_AOK/[V]CST_AERROR
#*!
$MET_AFTER_LOAD_REPRESENTATION
  Local Integer WSTATUS    : WSTATUS = [V]CST_AOK
  ARET_VALUE = WSTATUS
Return

