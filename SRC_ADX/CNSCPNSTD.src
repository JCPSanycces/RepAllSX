#<AdxTL>@(#)3.0.0.0 $Revision$
#########################################################################
# CNSCPNSTD : Consultation des retours    d'achat          HN  15/05/00 #
# ECRAN 1   : CONSCPN1                                                  #
# ECRAN 2   : CONSCPN2                                                  #
# ECRAN CRIT: CRITCPN                                                   #
#########################################################################
Local Char PARAM(20)(1..2)
PARAM(1) = "2204"
PARAM(2) = "GAL"
Call GCONSULT("CPN","",PARAM) From GCONSULT
End

#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When Default
Endcase
Return

############################################################
$AUTORIS
Return

############################################################
$SETBOUT
CHMEN+="BCDE"
Return

###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
NAVIG="CONSCPN"
Local Char    WFIL(250),WFIL1(250),WFIL2(250),WFIL3(250) #,WFIL4(250) # Issue X3-106549 - 2018-08-29 by MUARN : WFIL4 non utilisé dans filter
Local Char    DEBNUM(GLONPNH), FINNUM(GLONPNH)
Local Date    DEBDAT, FINDAT
Gosub DEFCRIT
Return

# --------------------------------------------------------------------------#
# Analyse paramères, initialisations                                        #
# --------------------------------------------------------------------------#
$DEFCRIT
If GNBAUZ=1 : PARAM(2)=GUSRFCY(1) : Endif
For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre fournisseur
      If PARAM(I) <> ""
        If [F:BPS]BPSNUM <> PARAM(I) Read [BPS] BPS0 = PARAM(I)
                                     If fstat  Raz [F:BPS], PARAM(I) : Endif
        Endif
#US 71069/138  by RBA
#        [M:CPN1]BPSNUM = PARAM(I)
        [M:CPN1]BPSNUMDEB = PARAM(I)
        [M:CPN1]BPSNUMFIN = PARAM(I)
#/US 71069/138  by RBA
      Endif
    When 2 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [FCY] FCY0 = PARAM(I)
                                     If fstat  Raz [F:FCY], PARAM(I) : Endif
        Endif
        If (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
          [M:CPN1]PNHFCY = PARAM(I)
          Call GETDEV([M:CPN1]PNHFCY) From DEVSUB
          [M:CPN1]CPY = GSOCIETE
          [M:CPN1]CUR = GLOCALDEV
        Endif
      Endif
  Endcase
Next I
[M:CPN1]CURD=GSYSCUR
If [M:CPN1]CUR=""  [M:CPN1]CUR=GSYSCUR : Endif
# validé oui
If !find([M:CPN1]CFMFLGO,1,2) : [M:CPN1]CFMFLGO= 2 : Endif
# validé non
If !find([M:CPN1]CFMFLGN,1,2) : [M:CPN1]CFMFLGN= 2 : Endif
# facturée oui
If !find([M:CPN1]INVFLGO,1,2) : [M:CPN1]INVFLGO= 2 : Endif
# facturée non
If !find([M:CPN1]INVFLGN,1,2) : [M:CPN1]INVFLGN= 2 : Endif
# comptabilisée oui
If !find([M:CCPN]PSTFLGO,1,2) : [M:CCPN]PSTFLGO= 2 : Endif
# comptabilisée non
If !find([M:CCPN]PSTFLGN,1,2) : [M:CCPN]PSTFLGN= 2 : Endif
# imprimée oui
If !find([M:CCPN]PRNFLGO,1,2) : [M:CCPN]PRNFLGO= 2 : Endif
# imprimée non
If !find([M:CCPN]PRNFLGN,1,2) : [M:CCPN]PRNFLGN= 2 : Endif
If !find([M:CCPN]TRI,1,2)     : [M:CCPN]TRI = 1   : Endif
#----- Initialisation dates début et fin -----#
Gosub INIT_DATES From TRTACHGRH1
[M:CPN1]RTNDATDEB=WDATDEB
[M:CPN1]RTNDATFIN=WDATFIN
#----- Copie du masque 1 (CPN1) vers l'écran critères (CCPN) -----#
Gosub CRITENT From =PROGCNS
Return

############################################################
$LECTURE
Local   Decimal  WMNTORG(0..1), WMNTDES(0..1)
Local   Integer  SPSTAT
#----- Grisage du champ fournisseur si consultation depuis celui-ci -----#
If GPILNAV>1
  If find(GNAVIG(GPILNAV-1),"GESBPS")
#    Diszo [CPN1]BPSNUM :
    Diszo [M:CPN1]BPSNUMDEB : Diszo [M:CPN1]BPSNUMFIN
  Endif
Endif
#-----
Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCPN]TRI
      When 1 : # tri par numéro
        Filter [PNH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) Order By Key PNH0
      When 2 : # tri par date
        Filter [PNH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&                    Order By Key PNH2
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCPN]TRI
      When 1 : # tri par numéro
        Filter [PNH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) Order By Key PNH0 Desc
      When 2 : # tri par date
        Filter [PNH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&                    Order By Key PNH2 Desc
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CPN2] : Endif

#-- lecture
$BOUCLE
For [PNH]

# Filtre sur la société
  If [M:CPN1]CPY <> ""
      If [F:FCY]FCY <> [F:PNH]PNHFCY Read [FCY] FCY0 = [F:PNH]PNHFCY
                                     If fstat  Raz [F:FCY] : Endif
                                     Endif
      If [F:FCY]LEGCPY <> [M:CPN1]CPY Goto SUIV : Endif
  Endif

  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:CPN2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1
     If NOL=0
         DEBNUM = [F:PNH]PNHNUM
         DEBDAT = [F:PNH]RTNDAT
     Endif
     FINNUM = [F:PNH]PNHNUM
     FINDAT = [F:PNH]RTNDAT
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1
     If NOL=MAXLIG-1
         FINNUM = [F:PNH]PNHNUM
         FINDAT = [F:PNH]RTNDAT
     Endif
     DEBNUM = [F:PNH]PNHNUM
     DEBDAT = [F:PNH]RTNDAT
  Endif

  nolign = NOL+1
  [M:CPN2] = [F:PNH]
  If [F:PNH]PSTFLG = 0
    [M:CPN2]PSTFLG(nolign-1)   = 1
  Endif
# Flag d'impression
  [M:CPN2]PRNFLG(nolign-1)     = [F:PNH]PRNFLG

  #US 71069/13  PJT by RBA
  [M:CPN2]PJTH(nolign-1)       = [F:PNH]PJTH
  #/US 71069/13  PJT by RBA

  $SUIV
Next
Filter [PNH]
Return

############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"
WFIL3 = "1=1"

# Site de retour
If [M:CPN1]PNHFCY <> ""
   WFIL2 += "&[F:PNH]PNHFCY=[M:CPN1]PNHFCY" # Issue X3-106549 - 2018-08-29 by MUARN : WFIL4 non utilisé dans filter
Endif
# Autorisation site
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
   WFIL2 += "& find([F:PNH]PNHFCY,GUSRFCY(1..GNBAUZ))" # Issue X3-106549 - 2018-08-29 by MUARN : WFIL4 non utilisé dans filter
Endif
## Numéro de fournisseur
#If [M:CPN1]BPSNUM <> ""
#   WFIL += "&[F:PNH]BPSNUM =[M:CPN1]BPSNUM"
#Endif

# Numéro de fournisseur
If [M:CPN1]BPSNUMDEB <> ""
   WFIL2 += "&[F:PNH]BPSNUM >=[M:CPN1]BPSNUMDEB" # Issue X3-106549 - 2018-08-29 by MUARN : WFIL4 non utilisé dans filter
Endif
If [M:CPN1]BPSNUMFIN <> ""
   WFIL2 += "&[F:PNH]BPSNUM <=[M:CPN1]BPSNUMFIN" # Issue X3-106549 - 2018-08-29 by MUARN : WFIL4 non utilisé dans filter
Endif

#    Prise en compte des retours validés
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPN1]CFMFLGO= 1
   WFIL1 += "&[F:PNH]CFMFLG<>2"
Endif

#    Prise en compte des retours non validés
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPN1]CFMFLGN= 1
   WFIL1 += "&[F:PNH]CFMFLG=2"
Endif

#    Prise en compte des retours facturées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPN1]INVFLGO= 1
   WFIL1 += "&[F:PNH]INVFLG<3"
Endif

#    Prise en compte des retours non facturées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPN1]INVFLGN= 1
   WFIL1 += "&[F:PNH]INVFLG>2"
Endif

#    Prise en compte des retours comptabilisées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPN]PSTFLGO= 1
   WFIL1 += "&[F:PNH]PSTFLG<>2"
Endif

#    Prise en compte des retours non comptabilisées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPN]PSTFLGN= 1
   WFIL1 += "&[F:PNH]PSTFLG=2"
Endif

#    Prise en compte des retours    imprimées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPN]PRNFLGO= 1
   WFIL1 += "&[F:PNH]PRNFLG<>2"
Endif

#    Prise en compte des retours    non imprimées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPN]PRNFLGN= 1
   WFIL1 += "&[F:PNH]PRNFLG=2"
Endif


If [M:CCPN]PNHNUMDEB <> ""
   WFIL3 += "&[F:PNH]PNHNUM>=[M:CCPN]PNHNUMDEB"
Endif
If [M:CCPN]PNHNUMFIN <> ""
   WFIL3 += "&[F:PNH]PNHNUM<=[M:CCPN]PNHNUMFIN"
Endif

If [M:CCPN]RTNDATDEB <> [0/0/0]
   WFIL3 += "&[F:PNH]RTNDAT>=[M:CCPN]RTNDATDEB"
Endif
If [M:CCPN]RTNDATFIN <> [0/0/0]
   WFIL3 += "&[F:PNH]RTNDAT<=[M:CCPN]RTNDATFIN"
Endif

#US 71069/13  PJT by RBA
If [M:CCPN]PJTHDEB <> ""
   WFIL3 += "&[F:PNH]PJTH>=[M:CCPN]PJTHDEB"
Endif
If [M:CCPN]PJTHFIN <> ""
   WFIL3 += "&[F:PNH]PJTH<=[M:CCPN]PJTHFIN"
Endif
#/US 71069/13  PJT by RBA

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCPN]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:PNH]PNHNUM>=DEBNUM"
       When 2 : # tri par date
           WFIL += "&([F:PNH]RTNDAT>DEBDAT | ([F:PNH]RTNDAT=DEBDAT & [F:PNH]PNHNUM>=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CCPN]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:PNH]PNHNUM>FINNUM"
       When 2 : # tri par date
           WFIL += "&([F:PNH]RTNDAT>FINDAT | ([F:PNH]RTNDAT=FINDAT & [F:PNH]PNHNUM>FINNUM))"
     Endcase
   When -2 : # retour
     Case [M:CCPN]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:PNH]PNHNUM<DEBNUM"
       When 2 : # tri par date
           WFIL += "&([F:PNH]RTNDAT<DEBDAT | ([F:PNH]RTNDAT=DEBDAT & [F:PNH]PNHNUM<DEBNUM))"
     Endcase
Endcase

Return

############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT
Return


#############################################################
##     Etiquettes masques CONSPOH1 & CONSPOH2 & CRITPOH    ##
#############################################################

Subprog AV_CPY(VALEUR)
#----------------------#
# Avant zone           #
#----------------------#
Variable Char     VALEUR
If GNBAUZ=1 : Diszo [M]CPY, PNHFCY : Endif
End

Subprog C_CPY(VALEUR)
#-------------------------------#
# Contrôle de la société        #
#-------------------------------#
Variable Char     VALEUR
If VALEUR <> ""
  [M]CUR = [F:CPY]ACCCUR : GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]PNHFCY = ""
  # GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
  # mkstat = 2
  # Raz [M]CUR
  [M]CUR=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Endif
End

Subprog AM_CPY(VALEUR)
#-------------------------------#
# Après modif de la société     #
#-------------------------------#
Variable Char     VALEUR
Affzo CUR, ZCPY : # Utilisé par 2 écrans on ne précise pas la classe
Raz [M]PNHFCY, [M]ZPNHFCY
Affzo PNHFCY, ZPNHFCY : # Utilisé par 2 écrans on ne précise pas la classe
If VALEUR<>""  GSOCIETE=VALEUR : Endif
End

Subprog C_PNHFCY(VALEUR)
#------------------------------------------------#
# Chargement de la devise
#------------------------------------------------#
Variable Char    VALEUR()
If VALEUR <> ""
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
    [M]CUR = GLOCALDEV
Elsif [M]CPY = ""
    # GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    # mkstat = 2
    [M]CUR=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End

#-------------------------------#
# Après modif du site           #
#-------------------------------#
Subprog AM_PNHFCY(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
  Affzo CUR, CPY, ZCPY : # Utilisé par 2 ecrans
Endif
End

#----------------------------#
# Initialisation  bouton     #
#----------------------------#
Subprog IB_NBLIG
Raz GBOUT1
If [M:CPN2]NBLIG<>0
   If clalev([M:PNH1])=0
     GBOUT1=mess(192,198,1)-[M:CPN2]PNHNUM(nolign-1) : # Retours
   Endif
Endif
End

#-------------------------------------#
# Après modification de la date début #
#-------------------------------------#
Subprog AM_RTNDATDEB(VALEUR)
Variable Date     VALEUR
#----- Recalcul date fin en fonction de la périodicité et du nbre de périodes -----#
If dim([M]PERCOD)>0
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"+",[M]RTNDATDEB,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]RTNDATFIN=WDATE : Affzo RTNDATFIN
  Endif
Elsif VALEUR>[M]RTNDATFIN
  [M]RTNDATFIN=VALEUR
Endif
End

#-----------------------------------#
# Après modification de la date fin #
#-----------------------------------#
Subprog AM_RTNDATFIN(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)<1  End : Endif
#----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
Local Date WDATE
Call CALDATPER([M]PERCOD,[M]PERNBR,"-",[M]RTNDATFIN,VALEUR,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]RTNDATDEB=WDATE : Affzo RTNDATDEB
Endif
#-----
End

#---------------------------------------------------#
#      Controle du numéro de retour   fin           #
# ------------------------------------------------- #
Subprog C_PNHNUMFIN(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & VALEUR<[M]PNHNUMDEB : mkstat = 1 : End : Endif
End

#--------------------------#
# Avant saisie périodicité #
#--------------------------#
Subprog AS_PERCOD(VALEUR)
Variable Integer VALEUR
GMENLOC(1)=0 : # Jour      Ok
GMENLOC(2)=0 : # Semaine   Ok
GMENLOC(3)=1 : # Quinzaine
GMENLOC(4)=0 : # Mois      Ok
GMENLOC(5)=0 : # Trimestre Ok
GMENLOC(6)=0 : # Semestre  Ok
GMENLOC(7)=0 : # Année     Ok
GMENLOC(8)=1 : # décade
End

#-------------------------#
# Après modif périodicité #
#-------------------------#
Subprog AM_PERCOD(VALEUR)
Variable Integer VALEUR
#----- Recalcul du nbre de périodes -----#
Call CALPERNBR([M]PERCOD,VALEUR,[M]PERNBR) From TRTX3DAT
Affzo PERNBR
[M]PERCOD=VALEUR
Call AM_PERNBR([M]PERNBR)
#-----
End

#------------------------------#
# Après modif nbre de périodes #
#------------------------------#
Subprog AM_PERNBR(VALEUR)
Variable Decimal VALEUR
#----- Recalcul fin début en fonction de la périodicité et du nbre de périodes -----#
Local Date WDATE
Call CALDATPER([M]PERCOD,VALEUR,"+",[0/0/0],[M]RTNDATDEB,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]RTNDATFIN=WDATE : Affzo RTNDATFIN
Endif
#-----
End


#########################################################################
# Pour exécution de la validation des consultations en gestion de patch #
#########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(5)<>2 End : Endif
Call VALGTC(APPLI,"CPN") From SUBGTC
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran CRITCPN) 18/01/2016 13:41:57 (RBA)
######################################################################################
#US 71069/13  PJT by RBA
Subprog AS_PJTHFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]PJTHDEB
Endif
End

Subprog C_PJTHFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]PJTHDEB
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End
#/US 71069/12  PJT by RBA

#US 71069/138  by RBA
Subprog AS_BPSNUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]BPSNUMDEB
Endif
End

Subprog C_BPSNUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]BPSNUMDEB
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End

Subprog AS_PNHNUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]PNHNUMDEB
Endif
End
#/US 71069/138  by RBA

