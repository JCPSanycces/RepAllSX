# Superviseur
## CRUD-CLASSE ## CCMCRORIGS
# 2018-10-19 07:50:19 525


############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(CCMCRORIGS,ASTATUS)
Variable Instance CCMCRORIGS Using C_CCMCRORIGS
Variable Integer ASTATUS

If CCMCRORIGS = null : End : Endif

Gosub _AVARIABLES From WMC00CCMCRORIGS

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CCMCRORIGS

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(CCMCRORIGS,ASTATUS)
Variable Instance CCMCRORIGS Using C_CCMCRORIGS
Variable Integer ASTATUS

If CCMCRORIGS = null : End : Endif

Gosub AVARIABLES From WMC00CCMCRORIGS
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_CCMCRORIGS
Else
 Gosub AINSERT_CCMCRORIGS
Endif

Gosub _AINSERT_AFTER
[L]A_I = CCMCRORIGS.freeSnapshot
CCMCRORIGS.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGS._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGS._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGS._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If CCMCRORIGS.ASTALIN = [V]CST_ANEWDEL : Return : Endif
CCMCRORIGS.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_CCMCRORIGS
Trbegin [F:CCMCROS]
 Gosub AINSERT_CCMCRORIGS
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_CCMCRORIGS
Raz [F:CCMCROS]
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00CCMCRORIGS._MAJSQL_CCMCRORIGS(CCMCRORIGS))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If CCMCRORIGS.snapshotEnabled=1
 [L]A_RETIK = CCMCRORIGS.revertUpdTick
Endif
[L]ASTATUS = max(fmet CCMCRORIGS.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(CCMCRORIGS.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 CCMCRORIGS.ASTALIN = [V]CST_ALL
Endif
Return



