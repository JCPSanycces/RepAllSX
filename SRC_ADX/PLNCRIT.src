Subprog C_DATENDINI(VALEUR)
Variable Date    VALEUR

# FQ78132 - FRRIC - 25/11/2011
# tableau PRE de 365 à 366 + test sur nbre jours année
Local Date    CALDATD, CALDATF
Local Integer ANNEE, MOISD, MOISF, JOURD, JOURF , NBJAN
ANNEE=year(VALEUR)
MOISD=1
JOURD=1
MOISF=12
JOURF=31
CALDATD=gdat$(JOURD,MOISD,ANNEE)
CALDATF=gdat$(JOURF,MOISF,ANNEE)
NBJAN=day(CALDATF)
NBJAN=day(CALDATD)
If (VALEUR-[M]DATSTRINI)> (CALDATF-CALDATD)
 # La période dépasse une année
 #ADNGO - 2017-01-17 - X3-11992 - START
 #GMESSAGE = mess(139,709,1)
 GMESSAGE = mess(139,10709,1)
 #ADNGO - 2017-01-13 - X3-11992 - END
 mkstat = 2 : End
Endif
End

