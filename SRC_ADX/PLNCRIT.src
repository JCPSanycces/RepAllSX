#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque PLNCRIT
######################################################################################
# Modifications :
#     SEGAY - 26/03/12 - Bug 88191 US1418
#              - Test contrat successif 82073
#    FQ85820 - 30/04/13 - prise en compte date d'effet + fiches de rétroactivité
######################################################################################

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "DEBUT"    : Gosub DEBUT
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
 When "SORTIE"   : Gosub SORTIE
 When "OK"       : Gosub OK #ADNGO - 2017-04-05 - X3-24432
 When Default
Endcase
Return

$INIT
Local Mask PLNCRIT [DIA]
Local Integer ANDEB, ANFIN, I, IP, ANNEE, OK, OLDANNEE, AXE, NB
Local Integer SEMDEB, SEMFIN, SEMD, SEMF, SEMAINE, OLDSEMAINE
#ADNGO - 2017-01-17 - X3-11992 - START
#Local Char    CRITERE (250), CTR(GLONCTR), CCE(GLONCCE),CRITEMP (250),CRITERE2 (250),CRITERE3 (250) #88191
Local Char    CRITERE (250), CTR(GLONHRCTR), CCE(GLONCCE),CRITEMP (250),CRITERE2 (250),CRITERE3 (250) #88191
#ADNGO - 2017-01-17 - X3-11992 - END
Local Char    LPLNTYP(GLONPLN)#88191
Local Date    DAT, DATCTR
#ADNGO - 2017-01-18 - X3-11992 - START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#ADNGO - 2017-01-18 - X3-11992 - END

# FQ78132 - FRRIC - 25/11/2011
# tableau PRE de 365 à 366
Local Integer JJ(1..7), PRE(1..366)

Gosub OUVRE
Return

$OUVRE
If clalev([F:POA])=0  : Local File POPULA   [POA]   : Endif
If clalev([F:FCY])=0  : Local File FACILITY [FCY]   : Endif
If clalev([F:FCY2])=0 : Local File FACILITY [FCY2]  : Endif #88191
If clalev([F:ID])=0   : Local File EMPLOID  [ID]    : Endif
#ADNGO - 2017-01-17 - X3-11992 - START
#If clalev([F:CTR])=0  : Local File EMPLOCTR [CTR]   : Endif
#If clalev([F:CTR2])=0 : Local File EMPLOCTR [CTR2]  : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR]   : Endif
If clalev([F:HRCTR2])=0 : Local File EMPLOCTR [HRCTR2]  : Endif
#ADNGO - 2017-01-17 - X3-11992 - END
If clalev([F:PLE])=0  : Local File PLANEMP  [PLE]   : Endif
If clalev([F:PLN])=0  : Local File PLANTYP  [PLN]   : Endif
If clalev([F:WTY])=0  : Local File TYPWEEK  [WTY]   : Endif
If clalev([F:NAT])=0  : Local File NATACTIV [NAT]   : Endif
If clalev([F:ECT])=0  : Local File EMPCTR   [ECT]   : Endif
If clalev([F:CPY])=0  : Local File COMPANY  [CPY]   : Endif
#57346
If clalev([F:HLY])=0  : Local File HLYDAY   [HLY]   : Endif
Return
#ADNGO - 2017-01-18 - X3-11992 - START
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#ADNGO - 2017-01-18 - X3-11992 - END
$DEBUT
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","pln") From GMEMO
Affzo [M:DIA]
#ADNGO - 2017-01-18 - X3-11992 - START
If [M:DIA]LEG<>""
  GCURLEG = [M:DIA]LEG
Endif
#ADNGO - 2017-01-18 - X3-11992 - END
Return
#ADNGO - 2017-04-05 - X3-24432 - START
$OK
If [M:DIA]LEG="" Then
   GERR  = 1
   GMESSAGE = mess(232,143,1)
   zonsui = "[M:DIA]LEG" #Put the focus on the field.
   FIN = 0 # Instruct the supervisor to keep the window open
   GOK = 0
   Return
Endif
Return
#ADNGO - 2017-04-05 - X3-24432 - END
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return


$EXEC
GOK = 1
# Initialisation des plannings opérationnels du xx/xx/xx au xx/xx/xx
#ADNGO - 2017-01-17 - X3-11992 - START
#TIT = mess(137,709,1)-mess(94,100,1)-num$([M:DIA]DATSTRINI)-mess(95,100,1)-num$([M:DIA]DATENDINI)
TIT = mess(137,10709,1)-mess(94,100,1)-num$([M:DIA]DATSTRINI)-mess(95,100,1)-num$([M:DIA]DATENDINI)
#ADNGO - 2017-01-17 - X3-11992 - END
Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

CRITERE = "[F:ID]ENAFLG=2 & [F:ID]FLGTPS=2" : # Salarié actif + géré dans les temps
# Société
If [M:DIA]ALLCPY<>2  : CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'  : Endif
# Site
#ADNGO - 2017-01-17 - X3-11992 - START
#If [M:DIA]ALLFCY<>2  : CRITERE -= '& [F:CTR]ETRFCY = "'+[M:DIA]FCY+'"'      : Endif
If [M:DIA]ALLFCY<>2  : CRITERE -= '& [F:HRCTR]ETRFCY = "'+[M:DIA]FCY+'"'      : Endif
#ADNGO - 2017-01-17 - X3-11992 - END
# FQ85820 - 30/04/13 - La vérification se fait maintenant dans VERIF_FLD, selon la rétroactivité
## Service
#If [M:DIA]ALLSRV<>2  : CRITERE -= '& [F:CTR]ETRSRV = "'+[M:DIA]SRV+'"'      : Endif
## Profil
#If [M:DIA]ALLPRF<>2  : CRITERE -= '& [F:CTR]PROPRF = "'+[M:DIA]PRF+'"'      : Endif
# Fin FQ85820
# Borne de salariés
If [M:DIA]MATDEB<>"" : CRITERE -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"' : Endif
If [M:DIA]MATFIN<>"" : CRITERE -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"' : Endif

##**88191
# FQ85820 - 30/04/13 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#CRITEMP = '[F:CTR]CTRDAT<=['+num$([M:DIA]DATENDINI)+'] & ([F:CTR]XITDAT=[0/0/0] | [F:CTR]XITDAT>=['+num$([M:DIA]DATSTRINI)+'])'
#ADNGO - 2017-01-17 - X3-11992 - START
#CRITEMP = '([F:CTR]CTRDAT<=['+num$([M:DIA]DATENDINI)+'] | ([F:CTR]FLGRET=2 & [F:CTR]RETDATEFF<=['+format$(GFMD,[M:DIA]DATENDINI)+']))'
#CRITEMP-= '& ([F:CTR]XITDAT=[0/0/0] | [F:CTR]XITDAT>=['+num$([M:DIA]DATSTRINI)+'])'
CRITEMP = '([F:HRCTR]CTRDAT<=['+num$([M:DIA]DATENDINI)+'] | ([F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<=['+format$(GFMD,[M:DIA]DATENDINI)+']))'
CRITEMP-= '& ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=['+num$([M:DIA]DATSTRINI)+'])'
#ADNGO - 2017-01-17 - X3-11992 - END
# Fin FQ85820
CRITERE2="1=1"
# FQ85820 - 30/04/13 - La vérification se fait maintenant dans VERIF_FLD, selon la rétroactivité
## Service
#If [M:DIA]ALLSRV<>2  : CRITERE2 -= '& [F:CTR2]ETRSRV = "'+[M:DIA]SRV+'"'      : Endif
## Profil
#If [M:DIA]ALLPRF<>2  : CRITERE2 -= '& [F:CTR2]PROPRF = "'+[M:DIA]PRF+'"'      : Endif


##**88191
#If [M:DIA]POP<>""
# Link [ECT] With
#&   [ID]ID0   = [F:ECT]REFNUM
#& , [CTR]CTR2 = [F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR
#& , [FCY]FCY0 = [F:CTR]ETRFCY
#& , [CPY]CPY0 = [F:FCY]LEGCPY
#& , [POA]POA0 = [M:DIA]POP;[F:ECT]REFNUM
#&   As [LNK]
#&   Where evalue(CRITERE) & [F:POA]REFNUM<>""
#Else
# Link [ECT] With
#&   [ID]ID0   = [F:ECT]REFNUM
#& , [CTR]CTR2 = [F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR
#& , [FCY]FCY0 = [F:CTR]ETRFCY
#& , [CPY]CPY0 = [F:FCY]LEGCPY
#&   As [LNK]
#&   Where evalue(CRITERE)
#Endif

#ADNGO - 2017-01-17 - X3-11992 - START
#If [M:DIA]POP<>""
# Link [CTR] With
#&   [ID]ID0   = [F:CTR]REFNUM
#& , [FCY]FCY0 = [F:CTR]ETRFCY
#& , [CPY]CPY0 = [F:FCY]LEGCPY
#& , [POA]POA0 = [M:DIA]POP;[F:CTR]REFNUM
#&   As [LNK]
#&   Where evalue(CRITERE) & [F:POA]REFNUM<>"" & evalue(CRITEMP)
#Else
# Link [CTR] With
#&   [ID]ID0   = [F:CTR]REFNUM
#& , [FCY]FCY0 = [F:CTR]ETRFCY
#& , [CPY]CPY0 = [F:FCY]LEGCPY
#&   As [LNK]
#&   Where evalue(CRITERE) & evalue(CRITEMP)
#Endif
If [M:DIA]POP<>""
 Link [HRCTR] With
&   [ID]ID0   = [F:HRCTR]REFNUM
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
& , [POA]POA0 = [M:DIA]POP;[F:CTR]REFNUM
&   As [LNK]
&   Where evalue(CRITERE) & [F:POA]REFNUM<>"" & evalue(CRITEMP)
Else
 Link [HRCTR] With
&   [ID]ID0   = [F:HRCTR]REFNUM
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
&   As [LNK]
&   Where evalue(CRITERE) & evalue(CRITEMP)
Endif
#ADNGO - 2017-01-17 - X3-11992 - END
#MIPEA - 2017-11-20- US X3-63170- START
#Call DAT([M]DATSTRINI,ANDEB,SEMDEB) From SUBPLN
#Call DAT([M]DATENDINI,ANFIN,SEMFIN) From SUBPLN
#MIPEA - 2017-11-20- US X3-63170- END

Gosub VERROU

If GOK=1
#MIPEA - 2017-11-20- US X3-63170- START
# For I=1 To 7
#  # JJ contient le premier jour de la semaine dans l'indice 1
#  JJ(I) = mod(GFIRDAY+I-1,7) : # Renvoie 1=Lundi, 2=Mardi .... 6=Vendredi, 0=Dimanche
#  If JJ(I)=0 : JJ(I)=7 : Endif
# Next I
#MIPEA - 2017-11-20- US X3-63170- END
 Call DEBTRANS From GLOCK
 Gosub TR1
Endif

Gosub DEVERROU

Call ECR_TRACE("",0) From GESECRAN
# xx plannings initialisés
#ADNGO - 2017-01-17 - X3-11992 - START
#Call ECR_TRACE(num$(NB)-mess(158,709,1),0) From GESECRAN
Call ECR_TRACE(num$(NB)-mess(158,10709,1),0) From GESECRAN
#ADNGO - 2017-01-17 - X3-11992 - END

Return

$TR1
Local Char    CTR2_PLNTYP(GLONPLN),CTR2_ETRFCY(GLONFCY)
Local Date    DATINI
GOK = 1
Trbegin [PLE]
# For [LNK]
  # Effacement du calendrier existant
#  If [M:DIA]ENAFLG=2
 For [LNK]CTR0 #**88191
  # Effacement du calendrier existant
  # FQ85820 - 30/04/13 - Vérification profil/service selon rétroactivité
  #ADNGO - 2017-01-17 - X3-11992 - START
#  If func SUBCTRRET.VERIF_FLD([F:CTR]REFNUM,[F:CTR]CTRNUM,[F:CTR]CTRDAT,[M:DIA]DATENDINI,"PROPRF",[M:DIA]ALLPRF,[M:DIA]PRF,"CTR")=2
#&  & func SUBCTRRET.VERIF_FLD([F:CTR]REFNUM,[F:CTR]CTRNUM,[F:CTR]CTRDAT,[M:DIA]DATENDINI,"ETRSRV",[M:DIA]ALLSRV,[M:DIA]SRV,"CTR")=2 Then
    If func SUBCTRRET.VERIF_FLD([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[M:DIA]DATENDINI,"PROPRF",[M:DIA]ALLPRF,[M:DIA]PRF,"HRCTR")=2
&  & func SUBCTRRET.VERIF_FLD([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[M:DIA]DATENDINI,"ETRSRV",[M:DIA]ALLSRV,[M:DIA]SRV,"HRCTR")=2 Then
  #ADNGO - 2017-01-17 - X3-11992 - END
  # Fin FQ85820
  #  If [M:DIA]ENAFLG=2
    If [M:DIA]ENAFLG=2 & evalue(CRITERE) & evalue(CRITEMP)
    #ADNGO - 2017-01-17 - X3-11992 - START
     #Delete [PLE] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:CTR]CTRNUM & DAT>=[M]DATSTRINI & DAT<=[M]DATENDINI
     Delete [PLE] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & DAT>=[M]DATSTRINI & DAT<=[M]DATENDINI
     #ADNGO - 2017-01-17 - X3-11992 - END
     If fstat=1
      GOK=-1 : Call FSTA("PLE") From GLOCK : Break
     Endif
    Endif
  Endif
 Next
# For [LNK]CTR0(2) #**88191
 For [LNK]CTR0 #**88191
  # FQ85820 - 30/04/13 - Vérification profil/service selon rétroactivité
  #ADNGO - 2017-01-17 - X3-11992 - START
#  If func SUBCTRRET.VERIF_FLD([F:CTR]REFNUM,[F:CTR]CTRNUM,[F:CTR]CTRDAT,[M:DIA]DATENDINI,"PROPRF",[M:DIA]ALLPRF,[M:DIA]PRF,"CTR")=2
#&  & func SUBCTRRET.VERIF_FLD([F:CTR]REFNUM,[F:CTR]CTRNUM,[F:CTR]CTRDAT,[M:DIA]DATENDINI,"ETRSRV",[M:DIA]ALLSRV,[M:DIA]SRV,"CTR")=2 Then
    If func SUBCTRRET.VERIF_FLD([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[M:DIA]DATENDINI,"PROPRF",[M:DIA]ALLPRF,[M:DIA]PRF,"HRCTR")=2
&  & func SUBCTRRET.VERIF_FLD([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[M:DIA]DATENDINI,"ETRSRV",[M:DIA]ALLSRV,[M:DIA]SRV,"HRCTR")=2 Then
  #ADNGO - 2017-01-17 - X3-11992 - END

#MIPEA - 2017-11-20- US X3-63170- START
         Call SET_GFIRDAY([F:HRCTR]PERCOD) From SUBHRPEO
         For I=1 To 7
          # JJ contient le premier jour de la semaine dans l'indice 1
          JJ(I) = mod(GFIRDAY+I-1,7) : # Renvoie 1=Lundi, 2=Mardi .... 6=Vendredi, 0=Dimanche
          If JJ(I)=0 : JJ(I)=7 : Endif
         Next I
#MIPEA - 2017-11-20- US X3-63170- END

  # Fin FQ85820
    Gosub PRESENCE
  #  If OK : Gosub PLANTYP : Endif
    If OK #**88191
     Raz OLDANNEE
     DAT = [M:DIA]DATSTRINI
     IP = 1
  #   While DAT<=[M:DIA]DATENDINI
  #    # Salarié présent
  #    If PRE(IP)=1
     # FQ92876 - US2808 - 04/09/14 - Si le contrat démarre après la date de début des critères, il faut quand même initialiser son
     # planning à partir de la date où il entre. Donc, recalcul de DAT et IP
     #ADNGO - 2017-01-17 - X3-11992 - START
#     Filter [CTR2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:CTR]CTRNUM & (CTRDAT<=[M:DIA]DATENDINI | (FLGRET=2 & RETDATEFF<=[M:DIA]DATENDINI))
#     If rowcount([F:CTR2])>0
#      Read [CTR2]CTR0 First
#      DATINI = max([F:CTR2]CTRDAT,[F:CTR2]RETDATEFF,DAT)
#      IP += DATINI-DAT
#      DAT = DATINI
#     Endif
#     Filter [CTR2]
     Filter [HRCTR2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & (CTRDAT<=[M:DIA]DATENDINI | (FLGRET=2 & RETDATEFF<=[M:DIA]DATENDINI))
     If rowcount([F:HRCTR2])>0
      Read [HRCTR2]CTR0 First
      DATINI = max([F:HRCTR2]CTRDAT,[F:HRCTR2]RETDATEFF,DAT)
      IP += DATINI-DAT
      DAT = DATINI
     Endif
     Filter [HRCTR2]
     #ADNGO - 2017-01-17 - X3-11992 - END
     # Fin FQ92876
     #**88191
     While DAT<=[M:DIA]DATENDINI & OK
      If OK : Gosub PLANTYP : Endif

      # Salarié présent
      If PRE(IP)=1 & OK
      #ADNGO - 2017-01-17 - X3-11992 - START
       #Look [PLE]PLE0=[F:ID]REFNUM;DAT;[F:CTR]CTRNUM
       Look [PLE]PLE0=[F:ID]REFNUM;DAT;[F:HRCTR]CTRNUM
      #ADNGO - 2017-01-17 - X3-11992 - END
       If fstat
        # Pas d'enregistrement, on peut créer
        Call DAT(DAT,ANNEE,SEMAINE) From SUBPLN
  #      If OLDANNEE<>ANNEE #**88191
         OLDANNEE = ANNEE
         # FQ85820 - 29/04/13 - On cherche si on a une fiche de rétroactivité relative aux champs PLNTYP et ETRFCY
#         Read [PLN]PLN0=ANNEE;[F:CTR2]PLNTYP #**88191
#         Read [HLY]HLY0 = year(DAT);[F:CTR2]ETRFCY #**88191
         #ADNGO - 2017-01-17 - X3-11992 - START
         #CTR2_PLNTYP=func SUBCTRRET.FIND_RETRO_FLD([F:ID]REFNUM,[F:CTR2]CTRNUM,[F:CTR2]CTRDAT,[M:DIA]DATENDINI,"PLNTYP","CTR2")
         CTR2_PLNTYP=func SUBCTRRET.FIND_RETRO_FLD([F:ID]REFNUM,[F:HRCTR2]CTRNUM,[F:HRCTR2]CTRDAT,[M:DIA]DATENDINI,"PLNTYP","HRCTR2")
         #ADNGO - 2017-01-17 - X3-11992 - END
         #ADNGO - 2017-01-26 - X3-11992 - START
         #Read [PLN]PLN0=ANNEE;CTR2_PLNTYP #**88191
         Read [PLN]PLN0=ANNEE;CTR2_PLNTYP;GCURLEG #**88191
         #ADNGO - 2017-01-26 - X3-11992 - END
         #ADNGO - 2017-01-17 - X3-11992 - START
         #CTR2_ETRFCY=func SUBCTRRET.FIND_RETRO_FLD([F:ID]REFNUM,[F:CTR2]CTRNUM,[F:CTR2]CTRDAT,[M:DIA]DATENDINI,"ETRFCY","CTR2")
         CTR2_ETRFCY=func SUBCTRRET.FIND_RETRO_FLD([F:ID]REFNUM,[F:HRCTR2]CTRNUM,[F:HRCTR2]CTRDAT,[M:DIA]DATENDINI,"ETRFCY","HRCTR2")
         #ADNGO - 2017-01-17 - X3-11992 - END
         #ADNGO - 2017-01-26 - X3-11992 - START
         #Read [HLY]HLY0 = year(DAT);CTR2_ETRFCY #**88191
         Read [HLY]HLY0 = year(DAT);CTR2_ETRFCY;GCURLEG #**88191
         #ADNGO - 2017-01-26 - X3-11992 - END
         #57346 : prendre year(DAT) au lieu de ANNEE (cas du 01/01/2010 sur année 2009)
         If fstat
         #ADNGO - 2017-01-26 - X3-11992 - START
          #Read [HLY]HLY0 = year(DAT);""
          Read [HLY]HLY0 = year(DAT);"";GCURLEG
         #ADNGO - 2017-01-26 - X3-11992 - END
         Endif
         #fin 57346
  #      Endif
  #      If OLDSEMAINE<>SEMAINE #**88191
         OLDSEMAINE = SEMAINE
         #ADNGO - 2017-01-31 - X3-11992 - START
         #Read [WTY]WTY0=[F:PLN]WEKTYP(SEMAINE-1)
         Read [WTY]WTY0=GCURLEG;[F:PLN]WEKTYP(SEMAINE-1)
         #ADNGO - 2017-01-31 - X3-11992 - START
         If fstat : Raz [F:WTY] : Endif
  #      Endif
        I = find(dayn(DAT),JJ(1..7)) : # avec dayn 1=Lundi, 2=Mardi .... 7=Dimanche
        If I>0
         Raz [F:PLE]
         [F:PLE]REFNUM    = [F:ID]REFNUM
         #ADNGO - 2017-01-17 - X3-11992 - START
         #[F:PLE]CTRNUM    = [F:CTR]CTRNUM
         [F:PLE]CTRNUM    = [F:HRCTR]CTRNUM
         #ADNGO - 2017-01-17 - X3-11992 - END
         [F:PLE]YEA       = ANNEE
         [F:PLE]DAT       = DAT
         #57346
         If find(DAT,[F:HLY]HLYDAY(0..[F:HLY]NBRDAY-1))
          [F:PLE]TYPDAY   = 3 : # Chômé
         Else
          # fin 57346
          [F:PLE]TYPDAY    = [F:WTY]TYPDAY(I-1)
          [F:PLE]NBRHOU    = [F:WTY]NBRHRS1(I-1)
          [F:PLE]NBRDAY    = [F:WTY]NBRDAY1(I-1)
          [F:PLE]STRTIM(0) = [F:WTY]STRTIM0(I-1)
          [F:PLE]ENDTIM(0) = [F:WTY]ENDTIM0(I-1)
          [F:PLE]BRKTIM(0) = [F:WTY]BRKTIM0(I-1)
          [F:PLE]NATCOD(0) = [F:WTY]NATCOD0(I-1)
          [F:PLE]STRTIM(1) = [F:WTY]STRTIM1(I-1)
          [F:PLE]ENDTIM(1) = [F:WTY]ENDTIM1(I-1)
          [F:PLE]BRKTIM(1) = [F:WTY]BRKTIM1(I-1)
          [F:PLE]NATCOD(1) = [F:WTY]NATCOD1(I-1)
          [F:PLE]STRTIM(2) = [F:WTY]STRTIM2(I-1)
          [F:PLE]ENDTIM(2) = [F:WTY]ENDTIM2(I-1)
          [F:PLE]BRKTIM(2) = [F:WTY]BRKTIM2(I-1)
          [F:PLE]NATCOD(2) = [F:WTY]NATCOD2(I-1)
          Gosub INI_CCE
         Endif
         [F:PLE]CREDAT    = date$
         [F:PLE]CREUSR    = GUSER
         [F:PLE]CRETIM    = time
         Write [PLE]
         If fstat
          GOK=0 : Call FSTA("PLE") From GLOCK
          Break 2
         Endif
  #       If CTR<>[F:ECT]CTRNUM
  #        CTR = [F:ECT]CTRNUM
  #        Call ECR_TRACE(format$("K:15X",[F:ID]REFNUM)+space$(1)+format$("K:60X",[F:ID]NAM-[F:ID]SRN)+space$(1)
  #&                     +mess(138,709,1)+space$(1)+[F:CTR]PLNTYP+space$(1)+"/"+[F:ECT]CTRNUM,0) From GESECRAN
  #       If CTR<>[F:CTR]CTRNUM
         #**88191
#         If CTR<>[F:CTR]CTRNUM | ([L]DATCTR <> [F:CTR2]CTRDAT & [L]LPLNTYP<>[F:CTR2]PLNTYP) : # 85820
         #ADNGO - 2017-01-17 - X3-11992 - START
#         If CTR<>[F:CTR]CTRNUM | ([L]DATCTR <> [F:CTR2]CTRDAT & [L]LPLNTYP<>CTR2_PLNTYP)
#          CTR = [F:CTR]CTRNUM
#          [L]DATCTR = [F:CTR2]CTRDAT
          If CTR<>[F:HRCTR]CTRNUM | ([L]DATCTR <> [F:HRCTR2]CTRDAT & [L]LPLNTYP<>CTR2_PLNTYP)
            CTR = [F:HRCTR]CTRNUM
            [L]DATCTR = [F:HRCTR2]CTRDAT
          #ADNGO - 2017-01-17 - X3-11992 - END
#          [L]LPLNTYP= [F:CTR2]PLNTYP : # 85820
#          Call ECR_TRACE(format$("K:15X",[F:ID]REFNUM)+space$(1)+format$("K:60X",[F:ID]NAM-[F:ID]SRN)+space$(1)
#&                      +mess(138,709,1)+space$(1)+[F:CTR2]PLNTYP+"/"+[F:CTR]CTRNUM-num$([L]DATCTR),0) From GESECRAN
          [L]LPLNTYP= CTR2_PLNTYP
          #ADNGO - 2017-01-17 - X3-11992 - START
#          Call ECR_TRACE(format$("K:15X",[F:ID]REFNUM)+space$(1)+format$("K:60X",[F:ID]NAM-[F:ID]SRN)+space$(1)
#&                      +mess(138,709,1)+space$(1)+CTR2_PLNTYP+"/"+[F:CTR]CTRNUM-num$([L]DATCTR),0) From GESECRAN
          Call ECR_TRACE(format$("K:15X",[F:ID]REFNUM)+space$(1)+format$("K:60X",[F:ID]NAM-[F:ID]SRN)+space$(1)
&                      +mess(138,10709,1)+space$(1)+CTR2_PLNTYP+"/"+[F:HRCTR]CTRNUM-num$([L]DATCTR),0) From GESECRAN
          #ADNGO - 2017-01-17 - X3-11992 - END
          NB +=1
         Endif
        Endif
       Endif
      Endif
      DAT +=1
      IP +=1
     Wend
    Endif
  Endif
 Next
 If GOK=0  : Goto AB_TR1   : Endif
 If GOK=-1 : Goto ROLL_TR1 : Endif
Commit
Return


$AB_TR1
Rollback
Return


$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif


$PRESENCEOLD
Local Date    DATDEBCTR
Raz PRE
OK = 1
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#For [CTR2]CTR0 Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:CTR]CTRNUM & CTRDAT<=[M]DATENDINI
#ADNGO - 2017-01-17 - X3-11992 - START
#For [CTR2]CTR0 Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:CTR]CTRNUM & (CTRDAT<=[M]DATENDINI | (FLGRET=2 & RETDATEFF<=[M]DATENDINI))
# DATDEBCTR=[F:CTR2]CTRDAT
# If [F:CTR2]FLGRET=2 & [F:CTR2]RETDATEFF<>[0/0/0] Then
#  DATDEBCTR=[F:CTR2]RETDATEFF
# Endif
For [HRCTR2]CTR0 Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & (CTRDAT<=[M]DATENDINI | (FLGRET=2 & RETDATEFF<=[M]DATENDINI))
 DATDEBCTR=[F:HRCTR2]CTRDAT
 If [F:HRCTR2]FLGRET=2 & [F:HRCTR2]RETDATEFF<>[0/0/0] Then
  DATDEBCTR=[F:HRCTR2]RETDATEFF
 Endif
#ADNGO - 2017-01-17 - X3-11992 - END
 # Fin MABON
 #ADNGO - 2017-01-17 - X3-11992 - START
 #If [F:CTR2]XITDAT=[0/0/0]
 If [F:HRCTR2]XITDAT=[0/0/0]
 #ADNGO - 2017-01-17 - X3-11992 - END
  # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#  For I=max([M]DATSTRINI,[F:CTR2]CTRDAT)-[M]DATSTRINI+1 To [M]DATENDINI-[M]DATSTRINI+1
#   PRE(I) = 1
#  Next I
# Elsif [F:CTR2]XITDAT>=[M]DATSTRINI
#  For I=max([M]DATSTRINI,[F:CTR2]CTRDAT)-[M]DATSTRINI+1 To min([M]DATENDINI,[F:CTR2]XITDAT)-[M]DATSTRINI+1
#   PRE(I) = 1
#  Next
  For I=max([M]DATSTRINI,DATDEBCTR)-[M]DATSTRINI+1 To [M]DATENDINI-[M]DATSTRINI+1
   PRE(I) = 1
  Next I
 #ADNGO - 2017-01-17 - X3-11992 - START
# Elsif [F:CTR2]XITDAT>=[M]DATSTRINI
#  For I=max([M]DATSTRINI,DATDEBCTR)-[M]DATSTRINI+1 To min([M]DATENDINI,[F:CTR2]XITDAT)-[M]DATSTRINI+1
  Elsif [F:HRCTR2]XITDAT>=[M]DATSTRINI
   For I=max([M]DATSTRINI,DATDEBCTR)-[M]DATSTRINI+1 To min([M]DATENDINI,[F:HRCTR2]XITDAT)-[M]DATSTRINI+1
 #ADNGO - 2017-01-17 - X3-11992 - END
   PRE(I) = 1
  Next
  # Fin MABON
 Endif
Next
If sigma(I=1,dim(PRE),PRE(I))=0 : OK = 0 : Endif
Return

#**88191
$PRESENCE
Local Date    DATDEBCTR
Local Char    CTR2_FCY(GLONFCY)
Raz PRE
OK = 1
CRITERE3='1=1'
If [M:DIA]ALLCPY<>2  : CRITERE3 -= '& [F:FCY2]LEGCPY = "'+[M:DIA]CPY+'"'  : Endif

# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#For [CTR2]CTR0 Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:CTR]CTRNUM & CTRDAT<=[M]DATENDINI
#ADNGO - 2017-01-17 - X3-11992 - START
#For [CTR2]CTR0 Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:CTR]CTRNUM & (CTRDAT<=[M]DATENDINI | (FLGRET=2 & RETDATEFF<=[M]DATENDINI)) & evalue(CRITERE2)
# If func SUBCTRRET.VERIF_FLD([F:CTR2]REFNUM,[F:CTR2]CTRNUM,[F:CTR2]CTRDAT,[M:DIA]DATENDINI,"PROPRF",[M:DIA]ALLPRF,[M:DIA]PRF,"CTR2")=2
#& & func SUBCTRRET.VERIF_FLD([F:CTR2]REFNUM,[F:CTR2]CTRNUM,[F:CTR2]CTRDAT,[M:DIA]DATENDINI,"ETRSRV",[M:DIA]ALLSRV,[M:DIA]SRV,"CTR2")=2 Then
For [HRCTR2]CTR0 Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & (CTRDAT<=[M]DATENDINI | (FLGRET=2 & RETDATEFF<=[M]DATENDINI)) & evalue(CRITERE2)
 If func SUBCTRRET.VERIF_FLD([F:HRCTR2]REFNUM,[F:HRCTR2]CTRNUM,[F:HRCTR2]CTRDAT,[M:DIA]DATENDINI,"PROPRF",[M:DIA]ALLPRF,[M:DIA]PRF,"HRCTR2")=2
& & func SUBCTRRET.VERIF_FLD([F:HRCTR2]REFNUM,[F:HRCTR2]CTRNUM,[F:HRCTR2]CTRDAT,[M:DIA]DATENDINI,"ETRSRV",[M:DIA]ALLSRV,[M:DIA]SRV,"HRCTR2")=2 Then
#ADNGO - 2017-01-17 - X3-11992 - END
   # FQ85820 - 29/04/13 - On cherche si on a une fiche de rétroactivité relative au champ ETRFCY
#   Read [FCY2]FCY0=[F:CTR2]ETRFCY
   #ADNGO - 2017-01-17 - X3-11992 - START
   #CTR2_FCY=func SUBCTRRET.FIND_RETRO_FLD([F:CTR2]REFNUM,[F:CTR2]CTRNUM,[F:CTR2]CTRDAT,[M:DIA]DATENDINI,"ETRFCY","CTR2")
   CTR2_FCY=func SUBCTRRET.FIND_RETRO_FLD([F:HRCTR2]REFNUM,[F:HRCTR2]CTRNUM,[F:HRCTR2]CTRDAT,[M:DIA]DATENDINI,"ETRFCY","HRCTR2")
   #ADNGO - 2017-01-17 - X3-11992 - END
   Read [FCY2]FCY0=CTR2_FCY
   # Fin FQ85820
   If fstat=0 & evalue(CRITERE3)
   #ADNGO - 2017-01-17 - X3-11992 - START
   DATDEBCTR=[F:HRCTR2]CTRDAT
   #If [F:CTR2]FLGRET=2 & [F:CTR2]RETDATEFF<>[0/0/0] Then
   If [F:HRCTR2]FLGRET=2 & [F:CTR2]RETDATEFF<>[0/0/0] Then
    #DATDEBCTR=[F:CTR2]RETDATEFF
    DATDEBCTR=[F:HRCTR2]RETDATEFF
   #ADNGO - 2017-01-17 - X3-11992 - END
   Endif
   # Fin MABON
   #ADNGO - 2017-01-17 - X3-11992 - START
   #If [F:CTR2]XITDAT=[0/0/0]
   If [F:HRCTR2]XITDAT=[0/0/0]
   #ADNGO - 2017-01-17 - X3-11992 - END
    # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
  #  For I=max([M]DATSTRINI,[F:CTR2]CTRDAT)-[M]DATSTRINI+1 To [M]DATENDINI-[M]DATSTRINI+1
  #   PRE(I) = 1
  #  Next I
  # Elsif [F:CTR2]XITDAT>=[M]DATSTRINI
  #  For I=max([M]DATSTRINI,[F:CTR2]CTRDAT)-[M]DATSTRINI+1 To min([M]DATENDINI,[F:CTR2]XITDAT)-[M]DATSTRINI+1
  #   PRE(I) = 1
  #  Next
    For I=max([M]DATSTRINI,DATDEBCTR)-[M]DATSTRINI+1 To [M]DATENDINI-[M]DATSTRINI+1
     PRE(I) = 1
    Next I
   #ADNGO - 2017-01-17 - X3-11992 - START
#   Elsif [F:CTR2]XITDAT>=[M]DATSTRINI
#    For I=max([M]DATSTRINI,DATDEBCTR)-[M]DATSTRINI+1 To min([M]DATENDINI,[F:CTR2]XITDAT)-[M]DATSTRINI+1
    Elsif [F:HRCTR2]XITDAT>=[M]DATSTRINI
     For I=max([M]DATSTRINI,DATDEBCTR)-[M]DATSTRINI+1 To min([M]DATENDINI,[F:HRCTR2]XITDAT)-[M]DATSTRINI+1
   #ADNGO - 2017-01-17 - X3-11992 - END
     PRE(I) = 1
    Next
    # Fin MABON
   Endif
   Endif
 Endif
Next
If sigma(I=1,dim(PRE),PRE(I))=0 : OK = 0 : Endif
Return


#**88191
$PLANTYPOLD
#
#Filter [CTR2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:CTR]CTRNUM & CTRDAT<=[M]DATSTRINI
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#Filter [CTR2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:CTR]CTRNUM & CTRDAT<=[M]DATENDINI
#ADNGO - 2017-01-17 - X3-11992 - START
#Filter [CTR2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:CTR]CTRNUM & (CTRDAT<=[M]DATENDINI | (FLGRET=2 & RETDATEFF<=[M]DATENDINI))
Filter [HRCTR2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & (CTRDAT<=[M]DATENDINI | (FLGRET=2 & RETDATEFF<=[M]DATENDINI))
#ADNGO - 2017-01-17 - X3-11992 - END
# Fin MABON
#ADNGO - 2017-01-17 - X3-11992 - START
#Read [CTR2]CTR0 Last
#Filter [CTR2]
#If fstat | [F:CTR2]PLNTYP=""
Read [HRCTR2]CTR0 Last
Filter [HRCTR2]
If fstat | [F:HRCTR2]PLNTYP=""
#ADNGO - 2017-01-17 - X3-11992 - END
 OK = 0
 If CTR<>[F:ECT]CTRNUM
  CTR = [F:ECT]CTRNUM
  # Salarié sans planning
  #ADNGO - 2017-01-17 - X3-11992 - START
#  Call ECR_TRACE(format$("K:15X",[F:ID]REFNUM)+space$(1)+format$("K:60X",[F:ID]NAM-[F:ID]SRN)
#&                +space$(1)+mess(124,709,1)+space$(1)+"/"+[F:CTR]CTRNUM,-1) From GESECRAN
    Call ECR_TRACE(format$("K:15X",[F:ID]REFNUM)+space$(1)+format$("K:60X",[F:ID]NAM-[F:ID]SRN)
&                +space$(1)+mess(124,10709,1)+space$(1)+"/"+[F:HRCTR]CTRNUM,-1) From GESECRAN
  #ADNGO - 2017-01-17 - X3-11992 - END
 Endif
Endif
Return

#**88191
$PLANTYP
#
#Filter [CTR2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:CTR]CTRNUM & CTRDAT<=[M]DATSTRINI
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#Filter [CTR2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:CTR]CTRNUM & CTRDAT<=[M]DATENDINI
#ADNGO - 2017-01-17 - X3-11992 - START
#Filter [CTR2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:CTR]CTRNUM & (CTRDAT<=[L]DAT | (FLGRET=2 & RETDATEFF<=[L]DAT))
Filter [HRCTR2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & (CTRDAT<=[L]DAT | (FLGRET=2 & RETDATEFF<=[L]DAT))
#ADNGO - 2017-01-17 - X3-11992 - END
# Fin MABON
#ADNGO - 2017-01-17 - X3-11992 - START
#Read [CTR2]CTR0 Last
#Filter [CTR2]
Read [HRCTR2]CTR0 Last
Filter [HRCTR2]
#ADNGO - 2017-01-17 - X3-11992 - END
# FQ85820 - 29/04/13 - On cherche si on a une fiche de rétroactivité relative au champ PLNTYP
#If fstat | [F:CTR2]PLNTYP=""
#ADNGO - 2017-01-17 - X3-11992 - START
#If fstat | (func SUBCTRRET.FIND_RETRO_FLD([F:CTR2]REFNUM,[F:CTR2]CTRNUM,[F:CTR2]CTRDAT,[L]DAT,"PLNTYP","CTR2"))=""
If fstat | (func SUBCTRRET.FIND_RETRO_FLD([F:HRCTR2]REFNUM,[F:HRCTR2]CTRNUM,[F:HRCTR2]CTRDAT,[L]DAT,"PLNTYP","HRCTR2"))=""
#ADNGO - 2017-01-17 - X3-11992 - END
 OK = 0
 #ADNGO - 2017-01-17 - X3-11992 - START
# If CTR<>[F:CTR]CTRNUM
#  CTR = [F:CTR]CTRNUM
   If CTR<>[F:HRCTR]CTRNUM
    CTR = [F:HRCTR]CTRNUM
 #ADNGO - 2017-01-17 - X3-11992 - END
  # Salarié sans planning
  #ADNGO - 2017-01-17 - X3-11992 - START
#  Call ECR_TRACE(format$("K:15X",[F:ID]REFNUM)+space$(1)+format$("K:60X",[F:ID]NAM-[F:ID]SRN)
#&                +space$(1)+mess(124,709,1)+space$(1)+"/"+[F:CTR]CTRNUM,-1) From GESECRAN
    Call ECR_TRACE(format$("K:15X",[F:ID]REFNUM)+space$(1)+format$("K:60X",[F:ID]NAM-[F:ID]SRN)
&                +space$(1)+mess(124,10709,1)+space$(1)+"/"+[F:HRCTR]CTRNUM,-1) From GESECRAN
  #ADNGO - 2017-01-17 - X3-11992 - END
 Endif
Endif
Return

$INI_CCE
Local Char SAU_GSOCIETE(GLONCPY)
Local Char CPY_TIP(GLONCPY)
SAU_GSOCIETE=GSOCIETE
GSOCIETE=func DIVPAYE.GETSOC(CTR2_ETRFCY)
If GSOCIETE="" Then GSOCIETE=SAU_GSOCIETE : Endif
If clalev([F:TIM])=0  : Local File TIMCOD    [TIM]  : Endif
# FQ92876 - 17/07/14 - Une seule lecture du TIM suffit
#ADNGO - 2017-01-17 - X3-11992 - START
#Call LECTURE("TIM",GTPSW,"") From CONTOBJ
Call LECTURE("HRTIM",GTPSW,GCURLEG) From CONTOBJ
#ADNGO - 2017-01-17 - X3-11992 - END
CPY_TIP=GSOCIETE
Gosub LISTDIE From TPSSUB
For I=0 To 2
 If [F:PLE]NATCOD(I)<>""
  #ADNGO - 2017-01-17 - X3-11992 - START
  #Call LECTURE("NAT",[F:PLE]NATCOD(I),"") From CONTOBJ
  Call LECTURE("NAT",[F:PLE]NATCOD(I),GCURLEG) From CONTOBJ
  #ADNGO - 2017-01-17 - X3-11992 - END
 Else
  Raz [F:NAT]
 Endif
 For AXE=1 To GOPTCANA
  Raz CCE
  # FQ92876 - 23/06/14 - Nouveau INICCE de TPSDIV
#  Call INICCE(GTPSW,AXE,CCE) From TPSSTD
  If find ([F:TIM]DIE(AXE-1), WLSTDIE(1..WNBRDIE)) Then
    Call INICCE([F:PLE]NATCOD(I),GTPSW,AXE,CCE) From TPSDIV
#    If clalev([F:TIM])=0  : Local File TIMCOD    [TIM]  : Endif
#    Call LECTURE("TIM",GTPSW,"") From CONTOBJ
    Case AXE
     When 1 : [F:PLE]CCE1(I) = CCE
     When 2 : [F:PLE]CCE2(I) = CCE
     When 3 : [F:PLE]CCE3(I) = CCE
     When 4 : [F:PLE]CCE4(I) = CCE
     When 5 : [F:PLE]CCE5(I) = CCE
     When 6 : [F:PLE]CCE6(I) = CCE
     When 7 : [F:PLE]CCE7(I) = CCE
     When 8 : [F:PLE]CCE8(I) = CCE
     When 9 : [F:PLE]CCE9(I) = CCE
    Endcase
    [F:PLE]DIE(AXE-1)=[F:TIM]DIE(AXE-1)
   Endif
 Next
Next
GSOCIETE=SAU_GSOCIETE
Return

$VERROU
For [LNK]

#MIPEA - 2017-11-20- US X3-63170- START
Call SET_GFIRDAY([F:HRCTR]PERCOD) From SUBHRPEO
Call DAT([M]DATSTRINI,ANDEB,SEMDEB) From SUBPLN
Call DAT([M]DATENDINI,ANFIN,SEMFIN) From SUBPLN
#MIPEA - 2017-11-20- US X3-63170- END

 For AN=ANDEB To ANFIN
  Raz SEMD,SEMF
  If AN=ANDEB : SEMD = SEMDEB : Endif
  If AN=ANFIN : SEMF = SEMFIN : Endif
  If SEMD=0   : SEMD = 1      : Endif
  If SEMF=0   : SEMF = 52     : Endif
  For SEM=SEMD To SEMF
   #ADNGO - 2017-01-17 - X3-11992 - START
   #SYMBOLE = "PLE"+num$(AN)+"\"+[F:ID]REFNUM+"\"+num$(SEM)+"\"+[F:CTR]CTRNUM
   SYMBOLE = "PLE"+num$(AN)+"\"+[F:ID]REFNUM+"\"+num$(SEM)+"\"+[F:HRCTR]CTRNUM
   #ADNGO - 2017-01-17 - X3-11992 - END
   Lock =SYMBOLE
   If fstat
    # Opération en cours sur autre poste
    #ADNGO - 2017-01-17 - X3-11992 - START
    #Call ECR_TRACE(mess(30,100,1)-":"-[F:ID]REFNUM-num$(SEM)-num$(AN)-[F:CTR]CTRNUM,0) From GESECRAN
    Call ECR_TRACE(mess(30,100,1)-":"-[F:ID]REFNUM-num$(SEM)-num$(AN)-[F:HRCTR]CTRNUM,0) From GESECRAN
    #ADNGO - 2017-01-17 - X3-11992 - END
    GOK = 0 : Break 3
   Endif
  Next
 Next
Next
Return

$DEVERROU
For [LNK]
 For AN=ANDEB To ANFIN
  Raz SEMD,SEMF
  If AN=ANDEB : SEMD = SEMDEB : Endif
  If AN=ANFIN : SEMF = SEMFIN : Endif
  If SEMD=0   : SEMD = 1      : Endif
  If SEMF=0   : SEMF = 52     : Endif
  For SEM=SEMD To SEMF
  #ADNGO - 2017-01-17 - X3-11992 - START
   #SYMBOLE = "PLE"+num$(AN)+"\"+[F:ID]REFNUM+"\"+num$(SEM)+"\"+[F:CTR]CTRNUM
   SYMBOLE = "PLE"+num$(AN)+"\"+[F:ID]REFNUM+"\"+num$(SEM)+"\"+[F:HRCTR]CTRNUM
  #ADNGO - 2017-01-17 - X3-11992 - END
   Unlock =SYMBOLE
  Next
 Next
Next
Return

