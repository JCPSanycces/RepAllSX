#<AdxTL>@(#)3.0.0.0 $Revision$
#############################################################################
## TVA Legislation=FRA ancienne version                                     #
#                                                                           #
# Issue X3-107197 - 2018-09-12 by CBO : PARAMETER AND ACTIVITY CODE
# Issue X3-61616 - 2017-11-07 by BEFOU : VAT report performance issue       #
#############################################################################
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","DCLVATSTD","DDCLVAT",4,"") From GTRAITE
End

#############################################################################
## Actions
#############################################################################
$ACTION

Case ACTION
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "SORTIE"      : Gosub SORTIE
 When "OUVRE"       : Gosub OUVRE
 #JOJAC - 2018-08-08 - X3-103256 - START
 When "DEBUT"       : Gosub DEBUT
 #When "DEBUT"       : Raz [M:DIA]INI : Affzo [DIA]
 #JOJAC - 2018-08-08 - X3-103256 - END
 When "END"         : GOK = 0
Endcase

If GFONCTION="DCLVATSWI"
 Gosub ACTION From =GFONCTION
Endif
Return

#############################################################################
# Actions called from TRAITE_CHAR - GTRAITE
#############################################################################
$INIT
If GSERVEUR=1
 Case PARAM(1)
  When "SWI" : Local Mask DCLVATSWI [DIA] : BCRIT="DCLVATSWI"
  When "BRI" : Local Mask DCLVATBRI [DIA] : BCRIT="DCLVATBRI"
  When "OTH" : Local Mask DCLVATOTH [DIA] : BCRIT="DCLVATOTH"
 Endcase
Else
 Local Mask =GFONCTION [DIA]
 Raz [M:DIA]
 Case GFONCTION
  When "DCLVATSWI" : Call LECMEMO("STD","[M:DIA]","dclswi") From GMEMO
  When "DCLVATBRI" : Call LECMEMO("STD","[M:DIA]","dclbri") From GMEMO
  When "DCLVATOTH" : Call LECMEMO("STD","[M:DIA]","dcloth") From GMEMO
 Endcase
Endif

Global Char GFNCLEG(GLONADI)

If GSERVEUR=1
 Case PARAM(1)
  When "SWI" : GFNCLEG="SWI"
  When "BRI" : GFNCLEG="BRI"
  When "OTH" : GFNCLEG="OTH"
 Endcase
Else
 Case GFONCTION
  When "DCLVATSWI" : GFNCLEG="SWI"
  When "DCLVATBRI" : GFNCLEG="BRI"
  When "DCLVATOTH" : GFNCLEG="OTH"
 Endcase
Endif

Return

#############################################################################
$CONTROLE
Gosub OUVRE_FIC
Gosub DECLARE

Return

#############################################################################
$EXEC
# End button
If GOK=0
 GOK = 1 : FIN = 1
 Return
Endif

# OK button
Gosub CONTROLE2
If FIN=1 : Return : Endif

If GSERVEUR
 [M:DIA]TRACE = 2
Endif

If !GSERVEUR
 Call OUVRE_VLC(TIT,"","") From GESECRAN
Endif

If !GSERVEUR & dim([M:DIA]VATPAY)>0 & [M:DIA]VATPAY=2 & [M:DIA]TRACE=2
 # Log file is created for the tax declaration on collection
 Call OUVRE_TRACE(TIT) From LECFIC
 Call ECR_TRACE(mess(89,107,1)+","-mess(38,114,1)-":"-num$(GNUMRPT2)+","
&              -mess(4,95,1)-tolower(mess(29,114,1))-":"-GTRACE+"\"+string$(120,"-"),0) From GESECRAN
Endif

#JOJAC - 2018-08-07 - X3-103256 - START
If [M:DIA]SIM <> 3
  Gosub DECLARATION
Endif
#Gosub DECLARATION
#JOJAC - 2018-08-07 - X3-103256 - END

If !GSERVEUR & dim([M:DIA]VATPAY)>0 & [M:DIA]VATPAY=2 & [M:DIA]TRACE=2
 Call FERME_TRACE From LECFIC
Endif

If !GSERVEUR
Call FERME_VLC From GESECRAN
Endif

Return

#############################################################################
$CONTROLE2
Local Char    TSYMBOLE(50)(1..GNBSOC)
Local Integer NBLOCK
NBLOCK = 0
If [M:DIA]ALLCPY<>2
 NBLOCK=1
 TSYMBOLE(NBLOCK) = "DCLVAT\"+[M:DIA]CPY
 Lock =TSYMBOLE(NBLOCK) With lockwait=0
 If fstat
  # Opération en cours sur autre poste
  GERR=2 : GMESSAGE=mess(30,100,1)
  FIN=1 : Return
 Endif
 INDCPY+=1
 TABCPY(INDCPY) = [M:DIA]CPY
Else
 Local Integer DOMORE : DOMORE=0
 For [CPY]CPY0 Where CPYLEGFLG=2
  DOMORE=0
  Case GFNCLEG
   When "BRI"
    If func AFNC.ACTIV("KUK") and func AFNC.PARAM("BRIVAT",[F:CPY]CPY)="2"   # Issue X3-107197
     DOMORE=1
    Endif
   When "SWI"
    If func AFNC.ACTIV("KSW") and func AFNC.PARAM("SWIVAT",[F:CPY]CPY)="2"  # Issue X3-107197
     DOMORE=1
    Endif
   When "OTH"
    If func AFNC.ACTIV("DCLOT") and func AFNC.PARAM("OTHVAT",[F:CPY]CPY)="2"  # Issue X3-107197
     DOMORE=1
    Endif
  Endcase

  If DOMORE
   NBLOCK+=1
   TSYMBOLE(NBLOCK) = "DCLVAT\"+[F:CPY]CPY
   Lock =TSYMBOLE(NBLOCK) With lockwait=0
   If fstat
    # Opération en cours sur autre poste
    GERR=2 : GMESSAGE=mess(30,100,1)
    FIN=1 : Break
   Endif
   INDCPY+=1
   TABCPY(INDCPY) = [F:CPY]CPY
  Endif
 Next
 If FIN=1 : Return : Endif
Endif

If [M:DIA]VAT = 2 : # TVA sur débits
 COMPTEUR1 = ""
 Call LECTURE("TCA","","2") From CONTOBJ
 If !fstat : COMPTEUR1 = [F:TCA]CODNUM(3) : Endif
 If COMPTEUR1="" : COMPTEUR1 = "DLV" : Endif
 Call NUMERO(COMPTEUR1,"",[0/0/0],"",NUMIMP,STAT) From SUBANM
 If STAT
  # Problème lors de la récupération du compteur
  Gosub MESSAGE From SUBANM
  Call ERREUR(mess(60,199,1)-"("+COMPTEUR1+") : "-MESSA) From GESECRAN
  FIN = 1 : Return
 Endif
 #JOJAC
 If [M:DIA]SIM=3
  GNUMRPT = [M:DIA]NUMRPT
 Else
  GNUMRPT = val(NUMIMP)
 Endif
 #JOJAC
Endif

If dim([M:DIA]VATPAY)>0 & [M:DIA]VATPAY = 2 : # TVA sur encaissements
 COMPTEUR2 = ""
 Call LECTURE("TCA","","2") From CONTOBJ
 If !fstat : COMPTEUR2 = [F:TCA]CODNUM(4) : Endif
 If COMPTEUR2 = "" : COMPTEUR2 = "DVP" : Endif
 Call NUMERO(COMPTEUR2,"",[0/0/0],"",NUMIMP,STAT) From SUBANM
 If STAT
  # Problème lors de la récupération du compteur
  Gosub MESSAGE From SUBANM
  Call ERREUR(mess(60,199,1)-"("+COMPTEUR2+") : "-MESSA) From GESECRAN
  FIN = 1 : Return
 Endif
  #JOJAC
 If [M:DIA]SIM=3
  GNUMRPT2 = [M:DIA]NUMRPT
 Else
  GNUMRPT2 = val(NUMIMP)
 Endif
 #JOJAC
 #GNUMRPT2 = val(NUMIMP)
Endif

Filter [GTE] Where VAT = 2
NBTYPDEB = rowcount([F:GTE])
Filter [GTE]
Local Char    TTYPDEB(GLONGTE)(1..NBTYPDEB) : # Table types pièces à prendre en cpte pour décl TVA/débits

Filter [GTE] Where VATPAI = 2
NBTYPPAY = rowcount([F:GTE])
Filter [GTE]
If NBTYPPAY>=1
 Local Char    TTYPPAY(GLONGTE)(1..NBTYPPAY) : # Table types pièces à prendre en cpte pour décl TVA/encaiss.
Else
 Local Char    TTYPPAY(GLONGTE)              : # Table types pièces à prendre en cpte pour décl TVA/encaiss.
Endif

Call LEGCPY(TABCPY,NBRLEG,TABLEG) From CPTDIV

If NBRLEG=1
 WLEG=TABLEG(1)
 Gosub LECPARAM_GTE
 Gosub LECPARAM_TVT
Endif

If [M:DIA]ALLCPY=2
 SOC=""
Else
 SOC=[M:DIA]CPY
Endif
Call LOCKCPY(SOC, OK) From AX3MONO
If !OK : FIN=1 : Return : Endif
Return

#############################################################################
$LECPARAM_GTE
Filter [GTE] Where LEG=[L]WLEG | LEG="" Order By Key CLE=TYP Asc ; LEG Desc
If [M:DIA]VAT = 2 : # On a demandé la TVA sur débits
 # Table des types de pièces qui doivent être pris en compte pour la déclaration de TVA sur débits
 Raz NBTYPDEB, TTYPDEB
 For [GTE]CLE(1)
  If [F:GTE]VAT = 2
   NBTYPDEB += 1
   TTYPDEB(NBTYPDEB) = [F:GTE]TYP
  Endif
 Next
Endif
If dim([M:DIA]VATPAY)>0 & [M:DIA]VATPAY = 2 : # On a demandé la TVA sur encaissements
 # Table des types de pièces qui doivent être pris en compte pour  la déclaration de TVA sur encaissements
 Raz NBTYPPAY, TTYPPAY
 For [GTE]CLE(1)
  If [F:GTE]VATPAI = 2
   NBTYPPAY += 1
   TTYPPAY(NBTYPPAY) = [F:GTE]TYP
  Endif
 Next
Endif
Filter [GTE]
Return

$LECPARAM_TVT
If [M:DIA]VAT = 2 : # On a demandé la TVA sur débits
 Filter [TVT] Where LEG=[L]WLEG | LEG="" Order By Key CLE=VAT Asc ; LEG Desc
 # Table des taxes qui sont dues sur les débits
 Raz NBTAX, TTAX
 For [TVT]CLE(1)
  If [F:TVT]VATPAY = 1
   NBTAX += 1
   TTAX(NBTAX) = [F:TVT]VAT
  Endif
 Next
 Filter [TVT]
Endif
Return


#############################################################################
$TERMINE
Local Char    ETAT_DEB(GLONARP)
Local Char    ETAT_ENC(GLONARP)
Local Integer INDLOCK, NBPAR1, NBPAR2
Local Char    TBPAR1(20)(1..10) , TBVAL1(50)(1..10)
Local Char    TBPAR2(20)(1..10) , TBVAL2(50)(1..10)
Local Char    NAM_PRT(GLONADP)

ETAT_DEB = "DCLVATDEB1"
ETAT_ENC = "DCLVATENC1"

If GFONCTION="DCLVATSWI"
 ACTION = "NOM_ETAT"
 Gosub ACTION From =GFONCTION
Endif

If GCALL_PT : GPOINT = "NOM_ETAT" : Gosub ENTREE From EXEFNC : Endif

# Batch
If GSERVEUR=1
 NBPAR1 = 0
 NBPAR1 +=1 : TBPAR1(NBPAR1) = "numrpt"       : TBVAL1(NBPAR1) = num$(GNUMRPT)
 NBPAR1 +=1 : TBPAR1(NBPAR1) = "detail_piece" : TBVAL1(NBPAR1) = num$([M:DIA]DETVCR)
 NBPAR1 +=1 : TBPAR1(NBPAR1) = "site"         : TBVAL1(NBPAR1) = [M:DIA]FCY
 NBPAR1 +=1 : TBPAR1(NBPAR1) = "etattva"      : TBVAL1(NBPAR1) = ETAT_DEB
 NBPAR2 = 0
 NBPAR2 +=1 : TBPAR2(NBPAR2) = "numrpt"       : TBVAL2(NBPAR2) = num$(GNUMRPT2)
 NBPAR2 +=1 : TBPAR2(NBPAR2) = "detail"       : TBVAL2(NBPAR2) = num$([M:DIA]DETAIL)
Endif

If [M:DIA]FCY<>""
 GFCYSOC = [M:DIA]FCY
Elsif [M:DIA]CPY<>""
 GFCYSOC = [M:DIA]CPY
Else
 Raz GFCYSOC
Endif

Call PARAM(GFCYSOC,"VATRPTBAT",NAM_PRT) From ADOVAL

If [M:DIA]VAT = 2
 [M:DIA]NUMRPT = GNUMRPT
 If !GSERVEUR
  Call IMPRIME([L]ETAT_DEB,"DCLVAT") From ETAT
 Else
  Call ETAT([L]ETAT_DEB,NAM_PRT,"",0,"",TBPAR1,TBVAL1) From AIMP3
 Endif
Endif
If dim([M:DIA]VATPAY)>0 & [M:DIA]VATPAY = 2
 [M:DIA]NUMRPT2 = GNUMRPT2
 If !GSERVEUR
  Call IMPRIME([L]ETAT_ENC,"DCLVAT") From ETAT
 Else
  Call ETAT([L]ETAT_ENC,NAM_PRT,"",0,"",TBPAR2,TBVAL2) From AIMP3
 Endif
Endif

If dim(TSYMBOLE)>0
 For INDLOCK=1 To NBLOCK
  Unlock =TSYMBOLE(INDLOCK)
 Next
Endif

If !GSERVEUR & dim([M:DIA]VATPAY)>0 & [M:DIA]VATPAY=2 & [M:DIA]TRACE=2
 TRA = 1
Else
 TRA = 0
Endif

Return

#############################################################################
$SORTIE
Call UNLOCKCPY() From AX3MONO
Kill GNUMRPT, GNUMRPT2, GFCYSOC, GFNCLEG
Return

#############################################################################
$DECLARE
Local Integer NTAX
NTAX = nbrecord([F:TVT])

Local Char    OPT(1)              : # "1":on prend la date comptable "2":date document origine
Local Char    OPTPAY(1)           : # Option => "1":TVA/débits d'abord "2":Prorata
Local Char    TTAX(GLONVAT)(1..NTAX)     : # Table des codes taxes qui sont dues sur les débits
Local Char    CRITERE(250)        : # Variable disponible dans le point d'entrée FILTRE
Local Char    NUMIMP(8)           : # Numéro requête
Local Char    COMPTEUR1(GLONANM)  : # Compteur utilisé pour gérer le no requête pour TVA/débits
Local Char    COMPTEUR2(GLONANM)  : # Compteur utilisé pour gérer le no requête pour TVA/encaiss.

Local Integer STAT                : # Variables diverses
Local Integer NBTYPDEB            : # Nombre de types de pièces
Local Integer NBTAX               : # Nombre de codes taxes dues sur les débits
Local Integer NBTYPPAY            : # Nombre de types de pièce
Local Integer DCLVAT              : # Si 1, la décl. TVA/débits a déjà été effectuée pour la société
Local Integer DCLVATPAY           : # Si 1, la décl. TVA/enc. a déjà été effectuée pour la société
Local Integer IMPUTACPT           : # Si vaut 1, on est sur pièce d'imputation d'acompte (TVA/encais.)

Global Integer GNUMRPT            : # Numéro de requête pour impression déclaration TVA/débits
Global Integer GNUMRPT2           : # Numéro de requête pour impression déclaration TVA/encaissements
Global Char    GFCYSOC(GLONFCY)

# This global variable tells us if the DCLVAT's entry points are used
Global Integer GCALL_PT : Raz GCALL_PT
If dim(GNBENTREE)>0 & GNBENTREE>0 & find("DCLVATOTH",GENTSTD(1..GNBENTREE))
 GCALL_PT=1
Endif

Local Integer INDCPY, NBRLEG
Local Char TABCPY(GLONCPY)(1..GNBSOC)
Local Char TABLEG(GLONADI)(1..GNBSOC)
Local Char WLEG(GLONADI)

Local Char LEG(GLONADI)
Return


########################################################

$DECLARATION
GOK = 1
#-----------------------------
#Finance Sprint 1 US2 71253

For [CPY]CPY0 Where ([M:DIA]ALLCPY=2 | CPY=[M:DIA]CPY) & CPYLEGFLG=2
 Call CTLLEGVAT([F:CPY]CPY,GFNCLEG,OK) From DCLVATSTD
 If OK
  Call LEC_TCU([F:CPY]ACCCUR) From CPTLEC
  GARODEV = [F:TCU]CURRND
  Call PARAM([F:CPY]CPY,"DCLVATDAT",OPT) From ADOVAL

  # EMERAUDE - Feature MULTILEG- Requirement 71216
  If NBRLEG>1 : WLEG=[F:CPY]LEG :  Gosub LECPARAM_GTE  : Endif
  If NBRLEG>1 : WLEG=[F:CPY]LEG :  Gosub LECPARAM_TVT  : Endif

  # Point d'entrée FILTRE
  Raz [L]CRITERE
  If GCALL_PT : GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC : Endif
  If [L]CRITERE="" : [L]CRITERE="1=1" : Endif

  If [M:DIA]FCY<>"" : [L]CRITERE-='& [F:FCY]FCY = "'+[M:DIA]FCY+'"' : Endif

  For [FCY]FCY0 Where LEGCPY=[F:CPY]CPY & FINFLG=2 & evalue(CRITERE)
   If [M:DIA]VAT = 2 : # On a demandé la TVA sur débits
    If !DCLVAT & NBTAX>0
     Call DCLVATDEB([F:CPY]CPY,[F:FCY]FCY,[M:DIA]STRDAT,[M:DIA]ENDDAT,[M:DIA]SIM,OPT,
&                  TTYPDEB,NBTYPDEB,TTAX,NBTAX)
    Else
     DCLVAT=0 : Break : # On change de société
    Endif
   Endif
   If GOK<1 : Break 2 : Endif
   If dim([M:DIA]VATPAY)>0 & [M:DIA]VATPAY = 2 : # On a demandé la TVA sur encaissements
    Call PARAM([F:CPY]CPY,"DCLOPTPAY",OPTPAY) From ADOVAL
    If !DCLVATPAY & NBTYPPAY>0
     Call DCLVATPAY([F:CPY]CPY,[F:FCY]FCY,[M:DIA]STRDAT2,[M:DIA]ENDDAT2,[M:DIA]SIM,
&                  OPTPAY,TTYPPAY,NBTYPPAY)
    Else
     DCLVATPAY=0 : Break : # On change de société
    Endif
   Endif
   If GOK<1 : Break 2 : Endif
  Next
 Endif :#OK
Next

If GOK<1 : Return : Endif

# S'il n'y a pas de TVA/débits et/ou TVA/encaissements à déclarer, on crée
# quand même un enregistrement dans les fichiers temporaires afin de pouvoir
# afficher les critères sélectionnés (notamment dans une réimpression)
If [M:DIA]VAT = 2
 Filter [DLV] Where NUMRPT = GNUMRPT
 Look [DLV]DLV0 First
 If fstat
  Call DEBTRANS From GLOCK
  Gosub TR_DLV0
  If GOK<1 : Return : Endif
 Endif
 Filter [DLV]
Endif
If dim([M:DIA]VATPAY)>0 & [M:DIA]VATPAY = 2
 Filter [DVP] Where NUMRPT = GNUMRPT2
 Look [DVP]DVP0 First
 If fstat
  Call DEBTRANS From GLOCK
  Gosub TR_DVP0
  If GOK<1 : Return : Endif
 Endif
 Filter [DVP]
Endif
Return

$TR_DLV0
Trbegin [DLV]
 Raz [F:DLV]
 [F:DLV]CPY = [M:DIA]CPY
 [F:DLV]STRDAT = [M:DIA]STRDAT
 [F:DLV]ENDDAT = [M:DIA]ENDDAT
 [F:DLV]SIM    = [M:DIA]SIM
 [F:DLV]OPTDAT = val(OPT)
 [F:DLV]NUMRPT = GNUMRPT
 If GCALL_PT :  GPOINT = "BEFWRIDLV" : Gosub ENTREE From EXEFNC : Endif
 Write [DLV]
 If fstat
  GOK=0 : Call FSTA("DLV") From GLOCK
 Endif
 If GOK<0   : Goto ROLL_TR_DLV0
 Elsif !GOK : Goto AB_TR_DLV0
 Endif
Commit
Return

$AB_TR_DLV0
Rollback
Return

$ROLL_TR_DLV0
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_DLV0 : Endif


$TR_DVP0
Trbegin [DVP]
 # On crée cet enregistrement juste pour stocker les critères sélectionnés
 # dans le cas où il n'y a pas de TVA/encaissements à déclarer (notamment dans le cas
 # d'une réimpression)
 Raz [F:DVP]
 [F:DVP]CPY    = [M:DIA]CPY
 [F:DVP]STRDAT = [M:DIA]STRDAT2
 [F:DVP]ENDDAT = [M:DIA]ENDDAT2
 [F:DVP]DATMAX = [M:DIA]DATPCE
 [F:DVP]SIM    = [M:DIA]SIM
 [F:DVP]OPT    = val(OPTPAY)
 [F:DVP]NUMRPT = GNUMRPT2
 [F:DVP]TYPREC = 0
 Gosub POINT_ENTREE
 Write [DVP]
 If fstat
  GOK=0 : Call FSTA("DVP") From GLOCK
 Endif
 If GOK<0   : Goto ROLL_TR_DVP0
 Elsif !GOK : Goto AB_TR_DVP0
 Endif
Commit
Return

$AB_TR_DVP0
Rollback
Return

$ROLL_TR_DVP0
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_DVP0 : Endif
Return

###########################
#  TVA SUR DEBITS         #
###########################
Subprog DCLVATDEB(SOC,SIT,DATDEB,DATFIN,SIMUL,OPT,TTYP,NBTYP,TTAX,NBTAX)
Value Char    SOC()       : # Société pour laquelle on fait la déclaration de TVA
Value Char    SIT()       : # Site pour lequel on fait la déclaration
Value Date    DATDEB      : # Date début de la déclaration de TVA
Value Date    DATFIN      : # Date fin de la déclaration de TVA
Value Integer SIMUL       : # Si <>2, on lance la déclaration en réel (MAJ du montant TVA déclarée)
Value Char    OPT()       : # "1":on prend la date comptable "2":date document origine
Value Char    TTYP()(1..) : # Table types pièces à prendre en cpte pour décl TVA/débits
Value Integer NBTYP       : # Nombre de types de pièces
Value Char    TTAX()(1..) : # Table des codes taxes qui sont dues sur les débits
Value Integer NBTAX       : # Nombre de codes taxes dues sur les débits

# NB : En France, la déclaration de TVA se fait tous les mois. Par contre,
# dans d'autres pays la périodicité n'est pas la même : en Espagne, il y a une
# déclaration trimestrielle.
# C'est pourquoi, on ne raisonne pas sur une période ou sur un mois mais
# sur une date de début et une date de fin de déclaration.

Local Char    PLAN(GLONCOA)      : # Plan de compte
Local Char    CRITDEB(250)       : # Demande de point d'entrée 41014 - filtre sur les débits

Local Integer SIGN               : # Signe
Local Integer IND, I,READ_OK     : # Variables diverses
Local Decimal TMONTANT(1..NBTAX) : # Table des montants de TVA par code taxe
Local Decimal TMONTRAT(1..NBTAX) : # Table des montants soumis à la TVA par code taxe
Local Decimal MTTTC, MTTVA, VTRAT

If clalev([F:DLV])=0  : Local File DCLVAT     [DLV]  : Endif : # Déclaration de TVA sur débits
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif : # En-tête des pièces comptables
If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif : # Lignes des pièces comptables
If clalev([F:HAE2])=0   : Local File GACCENTRY    [HAE2]     : Endif # Issue X3-61616 for updating
If clalev([F:DAE2])=0   : Local File GACCENTRYD   [DAE2]     : Endif # Issue X3-61616 for updating
If clalev([F:DAE3])=0 : Local File GACCENTRYD [DAE3] : Endif : # Lignes des pièces comptables
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif : # Comptes
If clalev([F:GAC2])=0 : Local File GACCOUNT   [GAC2] : Endif : # Comptes
If clalev([F:TRA])=0  : Local File TABRATVAT  [TRA]  : Endif : # Taux de taxes

GSOCIETE = SOC
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Call LECPLAN(GSOCIETE,GTYPGEN,PLAN) From CPTDIV

If GCALL_PT : GPOINT = "FILTREDEB" : Gosub ENTREE From EXEFNC : Endif

#############################################################################################
# Issue X3-61616 - 2017-11-07 by BEFOU : VAT report performance issue       Adding LINK
Link [DAE] With [HAE]HAE0=[DAE]TYP;[DAE]NUM As [LNK_E]

# Issue X3-61616 - 2017-11-07 by BEFOU : Changing Filter / Adding HAE filter
If CRITDEB="" & NBTYP<=50
 # Option Perf.
 If OPT = "1"
  Filter [LNK_E] Where [DAE]CPY=SOC & [DAE]FCYLIN=SIT & [DAE]LEDTYP=GTYPGEN & find([DAE]TYP,TTYP(1..NBTYP))<>0
&                  & [DAE]ACCDAT>=DATDEB & [DAE]ACCDAT<=DATFIN  & ([HAE]CAT=1)
 Else
  Filter [LNK_E] Where [DAE]CPY=SOC & [DAE]FCYLIN=SIT & [DAE]LEDTYP=GTYPGEN & find([DAE]TYP,TTYP(1..NBTYP))<>0
&                  & (([HAE]BPRDATVCR>=DATDEB & [HAE]BPRDATVCR<=DATFIN) | [HAE]BPRDATVCR=[0/0/0])
&                  & ([HAE]BPRDATVCR<>[0/0/0] | ([DAE]ACCDAT>=DATDEB & [DAE]ACCDAT<=DATFIN)) & ([HAE]CAT=1)
 Endif
Else
 If CRITDEB="" : CRITDEB = "1=1" : Endif
 If OPT = "1"
  Filter [LNK_E] Where [DAE]CPY=SOC & [DAE]FCYLIN=SIT & [DAE]LEDTYP=GTYPGEN & find([DAE]TYP,TTYP(1..NBTYP))
&                  & [DAE]ACCDAT>=DATDEB & [DAE]ACCDAT<=DATFIN & ([HAE]CAT=1) & evalue(CRITDEB)
 Else
  Filter [LNK_E] Where [DAE]CPY=SOC & [DAE]FCYLIN=SIT & [DAE]LEDTYP=GTYPGEN & find([DAE]TYP,TTYP(1..NBTYP))
&                  & (([HAE]BPRDATVCR>=DATDEB & [HAE]BPRDATVCR<=DATFIN) | [HAE]BPRDATVCR=[0/0/0])
&                  & ([HAE]BPRDATVCR<>[0/0/0] | ([DAE]ACCDAT>=DATDEB & [DAE]ACCDAT<=DATFIN)) & ([HAE]CAT=1) & evalue(CRITDEB)
 Endif
Endif

Look [LNK_E] First  With Nohint
If fstat : End : Endif

# End Issue X3-61616

Call DEBTRANS From GLOCK
Gosub TR_DELDLV
If GOK<1
 End
Endif
Gosub TR_DLV
End
#################################################################################
#
# Browse DAE of the Compagny / Site By Account
# Issue X3-61616 : Change with loop on LNK_E instead of multiple loop DAE /  HAE
#
$TR_DLV
Trbegin [DLV], [HAE], [DAE] , [HAE2], [DAE2] # Issue X3-61616 adding HAE2 & DAE2
 # On parcourt les comptes de TVA et ceux soumis à la TVA
 For [GAC]GAC0 Where COA=[L]PLAN & FLGVAT>1 & FLGVAT<=5
  # Société,site,compte
  Call AFF_VLC(mess(2,45,1)-":"-SOC-"-"-mess(3,45,1)-":"-SIT,mess(45,102,1)-":"-[F:GAC]ACC) From GESECRAN
  # On parcourt les lignes d'écritures qui mouvementent le compte
  # de TVA ou soumis à la TVA
   Raz TMONTANT, TMONTRAT
   For [LNK_E]DAE0 Where LEDTYP=GTYPGEN & ACC=[F:GAC]ACC & AMTVAT=0 & AMTLED<>0
     TVADEC = 0
     Gosub MONTANT
     If GOK<1 : Break 2 : Endif
   Next
  # end Issue X3-61616
  For I=1 To NBTAX
   If TMONTANT(I)<>0
    [F:DLV]CPY = SOC
    [F:DLV]FCY = SIT
    [F:DLV]STRDAT = DATDEB
    [F:DLV]ENDDAT = DATFIN
    [F:DLV]SIM = SIMUL
    [F:DLV]COA = [F:GAC]COA
    [F:DLV]ACC = [F:GAC]ACC
    [F:DLV]VAT = TTAX(I)
    Case [F:GAC]FLGVAT
     When 2, 5 : [F:DLV]TYPAMT = 1 : # Compte soumis à TVA (base)
     When 3, 4 : [F:DLV]TYPAMT = 2 : # Compte de TVA (montant)
    Endcase
    [F:DLV]FLGVAT = [F:GAC]FLGVAT
    [F:DLV]VATIPT = [F:GAC]VATIPT
    [F:DLV]AMT    = TMONTANT(I)
    [F:DLV]AMTTAX = TMONTRAT(I)
    [F:DLV]OPTDAT = val(OPT)
    [F:DLV]NUMRPT = GNUMRPT
    If GCALL_PT :  GPOINT = "BEFWRIDLV" : Gosub ENTREE From EXEFNC : Endif
    Write [DLV]
    If fstat
     GOK=0 : Call FSTA("DLV") From GLOCK : Break
    Endif
   Endif
  Next
 Next
 If GOK<0   : Goto ROLL_TR_DLV
 Elsif !GOK : Goto AB_TR_DLV
 Endif
Commit
Return

$AB_TR_DLV
Rollback
Return

$ROLL_TR_DLV
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_DLV : Endif

$MONTANT
# S'il y a un code taxe associé à la ligne d'écriture et que
# cette taxe est due sur les débits, on doit prendre en compte
# la base TVA ou le montant de TVA
Gosub LECTAXD
If [F:GAC]FLGVAT<>5
 IND = find([F:DAE]TAX,TTAX(1..NBTAX))
 If IND
  If [F:GAC]VATIPT <= 2 : # TVA collectée ventes ou collectée immos
   SIGN=-1
  Else
   SIGN=1 : # TVA déductible sur achats ou immos
  Endif
  # Pour la V130...
  Gosub UPD_NUMDCL # Issue X3-61616
  If GOK<1 : Return : Endif
  TMONTANT(IND) += SIGN*[F:DAE]SNS*[F:DAE]AMTLED : # Compte soumis à la TVA
  If VTRAT<>0
   TMONTRAT(IND) += SIGN*[F:DAE]SNS*[F:DAE]AMTLED
  Endif
  If SIMUL=1
   # On lance la déclaration de TVA sur débits en réel. On va donc
   # mettre à jour le montant de TVA déclarée dans la ligne d'écriture
   # (GACCENTRYD).
   Gosub UPD_AMTVAT # Issue X3-61616
   If GOK<1 : Return : Endif
  Endif
 Endif
## On traite les comptes d'acompte associés à un code taxe TVA/débits : Demande 26642
Elsif [F:GAC]FLGVAT=5 : # Compte d'acompte
 IND = find([F:DAE]TAX,TTAX(1..NBTAX))
 If IND
  If [F:GAC]VATIPT <= 2 : # TVA collectée ventes ou collectée immos
   SIGN=-1
  Else
   SIGN=1 : # TVA déductible sur achats ou immos
  Endif
  Raz MTTTC, MTTVA
  For [DAE3]DAE0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LEDTYP=GTYPGEN & AMTVAT=0
   If [DAE3]ACC=[F:GAC]ACC
    MTTTC += [F:DAE3]AMTLED*[F:DAE3]SNS*SIGN
    If SIMUL = 1
     # On lance la déclaration de TVA sur débits en réel. On va donc
     # mettre à jour le montant de TVA déclarée dans la ligne d'écriture
     # (GACCENTRYD).
     Gosub UPD_AMTVAT # Issue X3-61616
     If GOK<1 : Break : Endif
    Endif
   Elsif [F:DAE3]TAX<>"" & [F:DAE3]AMTVAT=0
    READ_OK=1
    If [L]PLAN<>[F:GAC2]COA or [F:DAE3]ACC<>[F:GAC2]ACC
     Read [F:GAC2]GAC0 = [L]PLAN;[F:DAE3]ACC
     If fstat : READ_OK=0 : Endif
    Endif
    If READ_OK & find([F:GAC2]FLGVAT,3,4) : # C'est un compte de TVA
     Call LEC_TVT_LEG([F:CPY]LEG,[F:DAE3]TAX) From CPTLEC
     If [F:TVT]VATPAY = 1 : # Taxe due sur les débits
      If [F:GAC]VATIPT=1 | [F:GAC]VATIPT=2
       SIGN=-1
      Else
       SIGN=1
      Endif
      MTTVA += [F:DAE3]AMTLED*[F:DAE3]SNS*SIGN
      ## On ne met pas à jour le compte de TVA, c'est fait dans le parcours des comptes de TVA
     Endif
    Endif
   Endif
  Next
  If GOK<1 : Return : Endif
  If MTTVA<>0
   TMONTANT(IND) += MTTTC-MTTVA
   If VTRAT<>0
    TMONTRAT(IND) += MTTTC-MTTVA
   Endif
   # Pour la V130...
   Gosub UPD_NUMDCL # Issue X3-61616
   If GOK<1 : Return : Endif
  Endif
 Endif
Endif
Return

$LECTAXD
VTRAT=99
Call LEC_TVT_LEG([F:CPY]LEG,[F:DAE]TAX) From CPTLEC
Filter [TRA] Where VAT=[F:DAE]TAX & CPY=SOC & STRDAT<=[F:DAE]ACCDAT & LEG=[F:TVT]LEG
Read [TRA]TRA0 Last
If !fstat
 If [F:TRA]VATRAT*[F:TRA]DEDRAT=0 : VTRAT=0 : Endif
Else
 Filter [TRA] Where VAT=[F:DAE]TAX & CPY="" & STRDAT<=[F:DAE]ACCDAT & LEG=[F:TVT]LEG
 Read [TRA]TRA0 Last
 If !fstat
  If [F:TRA]VATRAT*[F:TRA]DEDRAT=0 : VTRAT=0 : Endif
 Endif
Endif
Filter [TRA]
Return

#####################################################################################
# Update the request number NUMDCL in GACCENTRY
# Issue X3-61616 - 2017-11-07 by BEFOU : use of HAE2 ( Can't update a link )
$UPD_NUMDCL
If [F:HAE]NUMDCL<>GNUMRPT
 # We update the request number in GACCENTRY table if the update has not been done before
 # by processing another line of the journal entry
 Readlock [HAE2]HAE0=[F:HAE]TYP;[F:HAE]NUM
 If !fstat
  [F:HAE2]NUMDCL = GNUMRPT
  Rewrite [HAE2]
  If fstat
   GOK=0 : Call FSTA("HAE2") From GLOCK
  Endif
 Endif
Endif
Return
######################################################################################
# Update the tax amount declared in the GACCENTRYD table
# Issue X3-61616 - 2017-11-07 by BEFOU : USE of DAE2 ( Can't update a link )
$UPD_AMTVAT
If find([F:GAC]FLGVAT,2,3,4,5) : # Compte soumis à TVA et compte de TVA et compte d'acompte
 Readlock [DAE2]DAE2=[F:DAE]ACCNUM
 If !fstat
  [F:DAE2]AMTVAT = SIGN*[F:DAE2]SNS*[F:DAE2]AMTLED
  Rewrite [DAE2]
  If fstat
   GOK=0 : Call FSTA("DAE2") From GLOCK
  Endif
 Endif
Endif
Return

# On commence par effacer les simulations...
$TR_DELDLV
GOK = 1
Trbegin [DLV]
 Delete [DLV] Where CPY=SOC & FCY=SIT & SIM=2
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("DLV",SOC-SIT) From GLOCK : Goto AB_TR_DELDLV
 Endif
 If   GOK<0 : Goto ROLL_TR_DELDLV
 Elsif !GOK : Goto AB_TR_DELDLV
 Endif
Commit
Return

$AB_TR_DELDLV
Rollback
Return

$ROLL_TR_DELDLV
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_DELDLV : Endif
Return


###########################
#  TVA SUR ENCAISSEMENTS  #
###########################
#####################################################################
# Notes diverses :
# 1°) On met à jour les montants déclarés ([DAE]AMTVAT) pour :
#    - Les comptes de TVA sur encaissements
#    - Les comptes soumis à TVA sur encaissements
# 2°) Si une ligne d'écriture ne contient pas de code taxe
# on considère le compte comme non soumis.
# Il existe obligatoirement au moins un code taxe 'exonéré' dans
# le paramétrage de codes de taxes. Une ligne peut contenir un
# compte de type 'soumis à TVA' alors qu'il n'y a pas de code taxe
# associé. Dans ce cas, il ne faut pas la prendre en compte
#######################################################################

#############################################################################################
# Contraintes (règles de gestion)
# 1°) Les comptes doivent être correctement paramétrés en ce qui concerne les zones 'Gestion
# de TVA' (soumis, non soumis, compte de TVA) et 'Imputation taxe' (collectée ventes,
# collectée immos, déductible achats, déductible immos)
# 2°) Les types de pièces "déclenchants" (règlements) doivent être correctement
# paramétrés dans le paramétrage des types de pièces
# 3°) La pièce à utiliser pour le versement ou la réception d'un acompte
# peut être non déclenchante ou déclenchante
# 4°) La pièce à utiliser pour l'imputation de l'acompte sur la facture doit être
# déclenchante
# 5°) Dans le cas d'un versement ou de la réception d'un acompte relatif à une
# prestation de service, le compte de TVA à régulariser doit être paramétré comme
# compte non soumis
# 6°) Dans le cas où les pièces ne sont pas générées automatiquement mais saisies
# diretement en comptabilité, les codes taxes au niveau des lignes d'écritures
# doivent être correctement renseignés et le lettrage des écritures doit être correct
#######################################################################################

###########################
#  TVA SUR ENCAISSEMENTS  #
###########################
Subprog DCLVATPAY(SOC,SIT,DATDEB,DATFIN,SIMUL,OPTPAY,TTYP,NBTYP)
Value Char    SOC()       : # Société pour laquelle on fait la déclaration de TVA
Value Char    SIT()       : # Site pour lequel on fait la déclaration
Value Date    DATDEB      : # Date début exploration pièces
Value Date    DATFIN      : # Date fin exploration pièces
Value Integer SIMUL       : # Si <>2, on lance la déclaration en réel (MAJ du montant TVA déclarée)
Value Char    OPTPAY      : # Option => 1:TVA/débits payée d'abord  2:Prorata
Value Char    TTYP()(1..) : # Table types pièces à prendre en cpte pour décl TVA/encaiss.
Value Integer NBTYP       : # Nombre de types de pièces

Local Char    PLAN(GLONCOA)          : # Plan de compte
Local Char    TACPT(GLONGAC)(1..100) : # Table des comptes d'acomptes
Local Integer NBACPT                 : # Nombre de comptes d'acomptes

Local Integer NBMAXCODDEB         : # Nombre de codes taxes TVA/débits paramétrés * 2
Local Integer NBMAXCODENC         : # Nombre de codes taxes TVA/encaissements paramétrés * 2

Local Integer NB_CODDEB           : # Nombre de codes taxes TVA/débits paramétrés
Local Integer NB_CODENC           : # Nombre de codes taxes TVA/encaissements paramétrés

Local Integer READ_OK             : # Si vaut 1, lecture OK

GSOCIETE = SOC
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Call LECPLAN(GSOCIETE,GTYPGEN,PLAN) From CPTDIV

# Table des comptes d'acomptes (pour exclure les comptes d'acomptes dans la TVA/encaissements)
Raz NBACPT, TACPT
For [GAC]GAC0 Where COA=[L]PLAN & FLGVAT = 5
 NBACPT += 1
 TACPT(NBACPT) = [F:GAC]ACC
Next

NBMAXCODDEB = 0 : NB_CODDEB = 0
NBMAXCODENC = 0 : NB_CODENC = 0

Filter [TVT] Where LEG=[F:CPY]LEG | LEG="" Order By Key CLE=VAT Asc ; LEG Desc
For [TVT]CLE(1)
 If [F:TVT]VATPAY = 1
  NBMAXCODDEB += 2
  NB_CODDEB += 1
 Else
  NBMAXCODENC += 2
  # +=2 car cette variable va nous servir à dimensionner les tableaux tels que BASENC, TVAENC, ...
  # et ces tableaux contiennent les montants d'un groupe de lettrage par CATCOD (code taxe/
  # Imputation taxe). On considère donc qu'on a pour un groupe de lettrage soit du collectée
  # (Ventes ou Immos), soit du déductible (Achats ou Immos) (Donc 2 imputations de taxe possibles
  # par code taxe dans un groupe de lettrage)
  NB_CODENC += 1
 Endif
Next
Filter [TVT]


If NBMAXCODENC=0 : End : Endif
If NBMAXCODDEB=0 : NBMAXCODDEB=1 : NB_CODDEB=1 : Endif

## Ces tableaux vont servir pour les contrôles effectuées dans dans $CONT_CODDEB et $CONT_CODENC
Local Char    T_CODDEB(10)(1..NB_CODDEB)  : # Table des codes taxes TVA sur débits existants
Local Char    T_CODENC(10)(1..NB_CODENC)  : # Table des codes taxes TVA sur encaissements existants
Local Integer T_TYPREGDEB(1..NB_CODDEB)   : # Table des types régime des codes taxes TVA/débits
Local Integer T_TYPREGENC(1..NB_CODENC)   : # Table des types régime des codes taxes TVA/encaissements
Local Decimal T_RATDEB(1..NB_CODDEB)      : # Table des taux des codes taxes TVA/débits
Local Decimal T_RATENC(1..NB_CODENC)      : # Table des taux des codes taxes TVA/encaissements

If clalev([F:TRA])=0  : Local File TABRATVAT  [TRA]  : Endif : # Taux de taxes
If clalev([F:ADI])=0  : Local File ATABDIV    [ADI]  : Endif : # Tables diverses
If clalev([F:TVB])=0  : Local File TABVACBPR  [TVB]  : Endif : # Régime de taxes tiers

NB_CODDEB = 0 : NB_CODENC = 0
Filter [TVT] Where LEG=[F:CPY]LEG | LEG="" Order By Key CLE=VAT Asc ; LEG Desc
For [TVT]CLE(1)
 If [F:TVT]VATPAY = 1
  NB_CODDEB += 1
  T_CODDEB(NB_CODDEB) = [F:TVT]VAT
  Call LEC_TVB([F:CPY]LEG,[F:TVT]VATVAC) From CPTLEC
  If !fstat
   T_TYPREGDEB(NB_CODDEB) = [F:TVB]REGVAC
  Endif
  Filter [TRA] Where CPY = SOC & VAT = [F:TVT]VAT & LEG = [F:TVT]LEG
  Read [TRA]TRA0 Last
  If !fstat
   T_RATDEB(NB_CODDEB) = [F:TRA]VATRAT*[TRA]DEDRAT
  Else
   # On se rabat sur le code dossier
   Filter [TRA] Where CPY = "" & VAT = [F:TVT]VAT & LEG = [F:TVT]LEG
   Read [TRA]TRA0 Last
   If !fstat
    T_RATDEB(NB_CODDEB) = [F:TRA]VATRAT*[TRA]DEDRAT
   Endif
  Endif
  Filter [TRA]
 Else
  NB_CODENC += 1
  T_CODENC(NB_CODENC) = [F:TVT]VAT
  Call LEC_TVB([F:CPY]LEG,[F:TVT]VATVAC) From CPTLEC
  If !fstat
   T_TYPREGENC(NB_CODENC) = [F:TVB]REGVAC
  Endif
  Filter [TRA] Where CPY = SOC & VAT = [F:TVT]VAT & LEG = [F:TVT]LEG
  Read [TRA]TRA0 Last
  If !fstat
   T_RATENC(NB_CODENC) = [F:TRA]VATRAT*[TRA]DEDRAT
  Else
   # On se rabat sur le code dossier
   Filter [TRA] Where CPY = "" & VAT = [F:TVT]VAT & LEG = [F:TVT]LEG
   Read [TRA]TRA0 Last
   If !fstat
    T_RATENC(NB_CODENC) = [F:TRA]VATRAT*[TRA]DEDRAT
   Endif
  Endif
  Filter [TRA]
 Endif
Next
Filter [TVT]


Local Integer MAXLIG , OKDIM
Local Char    PARAM(10)
Call PARAM("","MAXDCLVAT",PARAM) From ADOVAL
MAXLIG = max(val(PARAM),300)

Local Char    COMPTE(GLONGAC)
Local Char    TIERS(GLONBPR)
Local Char    LETTRE(5)
Local Char    TCODENC(15)(1..NBMAXCODENC)       : # Table codes taxes dues sur les encaissements
Local Char    TCODDEB(15)(1..NBMAXCODDEB)       : # Table codes taxes dues sur les débits
Local Char    TYPPCE(GLONGTE)                   : # Type de pièce
Local Char    NUMPCE(GLONVCR)                   : # Numéro de pièce
Local Char    DAEFILTRE(255)
Local Char    DAE3FILTRE(255)

Local Date    DATLET                            : # Date de lettrage

Local Integer NBCODENC                          : # Nb codes taxes dues sur les encaissements
Local Integer NBCODDEB                          : # Nb codes taxes dues sur les débits
Local Integer TBACCNUM(1..NBMAXCODENC,1..MAXLIG): # Table des lignes de pièces ayant même CATCOD et auquel
                                                : # est associé un code taxe TVA sur encaissements
Local Integer NBACCNUM(1..NBMAXCODENC)          : # Nombre de lignes de pièces ayant même lettrage et même CATCOD

Local Integer TBREGACCNUM(1..MAXLIG)            : # Table des lignes de pièces de règlement
Local Integer NBREGACCNUM                       : # Nombre de lignes de pièces de règlement

Local Integer NUMACPT                           : # Numéro chrono pour les acomptes
Local Integer SIGN, IND, IND2
Local Integer STAT

Local Integer LETTRAGE
Local Integer DELETTRAGE
Local Integer NBCPTLET                          : # Nb de comptes lettrables

Local Integer OKCODENC, OKCODDEB
Local Integer OKMAJ

Local Integer TYPREG

Local Decimal TAMTLED(1..NBMAXCODENC,1..MAXLIG): # Table des montants (AMTLED) des lignes de pièces ayant même
                                               : # CATCOD, auquel est associé un code taxe TVA/encaissements

Local Decimal TAMTVAT(1..NBMAXCODENC,1..MAXLIG): # Table des montants déclarés (AMTVAT) des lignes de pièces ayant
                                               : # CATCOD, auquel est associé un code taxe TVA/encaissements


Local Decimal TOTREG               : # Montant des règlements (des pièces d'un même groupe de lettrage)
Local Decimal TOTAL
Local Decimal MTREG                : # Montant règlements traités pour l'option TVA/débits d'abord
Local Decimal TOTDEB               : # TVA+base TVA sur débits d'un groupe de lettrage (montants déjà déclarés compris)
Local Decimal TOTENC               : # TVA+base TVA sur encaissements d'un groupe de lettrage (montants déjà déclarés compris)
Local Decimal TOTDECLAR            : # TVA+base TVA sur encaissements d'un groupe de lettrage déjà déclaré

Local Decimal MTHT, MTTVA, MTTTC

Local Decimal VAT_RAT
Local Decimal BASENC(1..NBMAXCODENC)     : # Tableau des montants des bases de TVA sur encaissements
Local Decimal TVAENC(1..NBMAXCODENC)     : # Tableau des montants de TVA sur encaissements
Local Decimal AMTVAT_BASE(1..NBMAXCODENC): # Tableau des montants déclarés (base) pour la TVA/encaiss.
Local Decimal AMTVAT_TVA(1..NBMAXCODENC) : # Tableau des montants déclarés (montant TVA) pour la TVA/encaiss.
Local Decimal BASDEB(1..NBMAXCODDEB)     : # Tableau des montants des bases de TVA sur débits
Local Decimal TVADEB(1..NBMAXCODDEB)     : # Tableau des montants de TVA sur débits
Local Decimal TOTREG_DEB                 : # TVA+base TVA sur débits d'un grp de lettrage à déclarer
Local Decimal TOTREG_ENC                 : # TVA+base TVA sur encaissements d'un grp de lettrage à déclarer

Local Decimal BASVAT_PAY          : # Montant déclaré d'une écriture si compte soumis à TVA
Local Decimal AMTVAT_PAY          : # Montant déclaré d'une écriture si compte de TVA

Local Integer OK_DAE2

Local File GACCENTRYD [DAE]  Order By Key CLE = LEDTYP;ACC;BPR;MTC;TYP;NUM;LIN
Local File GACCENTRYD [DAE1] Order By Key CLE = LEDTYP;ACC;BPR;MTC;TYP;NUM;LIN


If clalev([F:DVP])=0  : Local File DCLVATPAY  [DVP]  : Endif : # Fichier temp. pour décl. TVA/enc
If clalev([F:DVP2])=0 : Local File DCLVATPAY  [DVP2] : Endif : # Fichier temp. pour décl. TVA/enc
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif : # En-tête de pièces
If clalev([F:DAE2])=0 : Local File GACCENTRYD [DAE2] : Endif : # Lignes d'écritures
If clalev([F:DAE3])=0 : Local File GACCENTRYD [DAE3] : Endif : # Lignes d'écritures
If clalev([F:DAE4])=0 : Local File GACCENTRYD [DAE4] : Endif : # Lignes d'écritures
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif : # Comptes
If clalev([F:GAC2])=0 : Local File GACCOUNT   [GAC2] : Endif : # Comptes

Call DEBTRANS From GLOCK
Gosub TR_DELDVP
If GOK<1
 End
Endif
Gosub TR_DVP
End


$TR_DVP
Trbegin [DVP]
 DELETTRAGE = 0
 If GTRACE<>""
  Call ECR_TRACE("\"+mess(2,45,1)-":"-SOC-","-mess(3,45,1)-":"-SIT-":\"+string$(50,"-"),0) From GESECRAN
 Endif

 Raz [L]DAEFILTRE
 If GCALL_PT : GPOINT = "DAEFILTRE" : Gosub ENTREE From EXEFNC : Endif

 If [L]DAEFILTRE="" & NBTYP<=50
  # Option Perf.
  If [M]ECRAUX = 1 : # On prend toutes les écritures comment avant (auxiliarisées ou pas)
   Filter [DAE] Where CPY=SOC & FCYLIN=SIT & LEDTYP=GTYPGEN
&                  & MTCDAT>=DATDEB & MTCDAT<=DATFIN
&                  & find([F:DAE]TYP,TTYP(1..NBTYP))<>0
  Else
   Filter [DAE] Where CPY=SOC & FCYLIN=SIT & LEDTYP=GTYPGEN
&                 & MTCDAT>=DATDEB & MTCDAT<=DATFIN & BPR<>""
&                 & find([F:DAE]TYP,TTYP(1..NBTYP))<>0
  Endif
 Else
  If [L]DAEFILTRE="" : [L]DAEFILTRE = "1=1" : Endif
  If [M]ECRAUX = 1 : # On prend toutes les écritures comment avant (auxiliarisées ou pas)
   Filter [DAE] Where CPY=SOC & FCYLIN=SIT & LEDTYP=GTYPGEN
&                  & MTCDAT>=DATDEB & MTCDAT<=DATFIN
&                  & find([F:DAE]TYP,TTYP(1..NBTYP)) & evalue([L]DAEFILTRE)
  Else
   Filter [DAE] Where CPY=SOC & FCYLIN=SIT & LEDTYP=GTYPGEN
&                 & MTCDAT>=DATDEB & MTCDAT<=DATFIN & BPR<>""
&                 & find([F:DAE]TYP,TTYP(1..NBTYP)) & evalue([L]DAEFILTRE)
  Endif
 Endif


 # Parcours des groupes de lettrage (compte,tiers,lettre)
 For [DAE]CLE(4) Where MTC<>"" With Nohint
  Raz NBCODDEB, NBCODENC, TCODDEB, TCODENC
  Raz BASDEB, TVADEB, BASENC,TVAENC
  Raz AMTVAT_BASE, AMTVAT_TVA
  Raz TOTREG_ENC, TOTREG_DEB
  Raz TBACCNUM, NBACCNUM
  Raz TAMTLED, TAMTVAT
  Raz TOTREG
  COMPTE    = [F:DAE]ACC
  TIERS     = [F:DAE]BPR
  LETTRE    = [F:DAE]MTC
  DATLET    = [F:DAE]MTCDAT
  # Société,site, compte, tiers
  Call AFF_VLC(mess(2,45,1)-":"-SOC-"-"-mess(3,45,1)-":"-SIT,mess(45,102,1)-":"-COMPTE-mess(31,105,1)-":"-TIERS) From GESECRAN

  # Parcours des pièces par groupe de lettrage. Les pièces lettrées
  # ensemble peuvent être soit des factures, soit des pièces de règlements
  # Les acomptes seront traités plus loin...
  # Ajout de "& CPY=SOC & FCYLIN=SIT" car suite à une fusion tiers, certains codes lettrage
  # peuvent être identiques sur 2 sites différents. Exemple 401000 tiers 1 fusionne avec 401000 tiers2.
  # L'attribution du code lettrage (MATCHCODE) se fait par compte/tiers/COA. On peut donc avoir un
  # même code lettrage qui lettre 401000 tiers1 avec 5121 sur soc1 et 401000 tiers2 avec 5122 sur soc2
  # Si tiers1 fusionne avec tiers2 on a le même code lettrage => En simulation en lançant toutes sociétés
  # on prendra 2 fois les 2 factures et les 2 règlements
  For [DAE1]CLE(6) Where LEDTYP=GTYPGEN & ACC=COMPTE & BPR=TIERS & MTC=LETTRE & CPY=SOC & FCYLIN=SIT
   IMPUTACPT = 0
   If !find([F:DAE1]ACC,TACPT(1..NBACPT)) : # C'est pas un compte d'acompte
    # Le compte du groupe de lettrage n'est pas un compte d'acompte mais il peut
    # y avoir dans la pièce une ligne avec un compte d'acompte si on est sur une pièce
    # d'imputation d'acompte. Dans ce cas, il ne faut pas prendre en compte cette pièce
    # dans le calcul des bases et montants ($CALTVA) puisqu'on déclare cette pièce
    # en sens inverse quand on traite le cas des acomptes. Cependant, on ne peut pas exclure
    # cette pièce à ce niveau car le montant du compte tiers contenu dans COMPTE doit être
    # cumulé à TOTREG
    If NBACPT>0
     Filter [DAE2] Where TYP = [F:DAE1]TYP & NUM = [F:DAE1]NUM & LEDTYP=GTYPGEN & find([F:DAE2]ACC,TACPT(1..NBACPT))
     Read [DAE2]DAE0 First
     If fstat = 0 : # C'est une pièce d'imputation d'acompte
      IMPUTACPT = 1
     Endif
     Filter [DAE2]
    Endif
    OKDIM = 1
    For [DAE2]DAE0 Where TYP = [F:DAE1]TYP & NUM = [F:DAE1]NUM & LEDTYP = [F:DAE1]LEDTYP
     If GCALL_PT
      OK_DAE2 = 1
      GPOINT = "CHECKDAE2" : Gosub ENTREE From EXEFNC
      If !OK_DAE2 : Goto NEXTDAE2 : Endif
     Endif
     # Parcours des lignes d'écritures de la pièce [F:DAE1]TYP-[F:DAE1]NUM
     # appartenant au groupe de lettrage.
     # On regarde si c'est une pièce règlement pour MAJ le montant du règlement
     #If find([F:DAE2]TYP,TTYP(1..NBTYP)) & [F:DAE2]MTC=LETTRE & (IMPUTACPT=0 | ([F:DAE2]ACC=COMPTE & [F:DAE2]BPR=TIERS))
     If find([F:DAE2]TYP,TTYP(1..NBTYP)) & [F:DAE2]MTC=LETTRE & [F:DAE2]ACC=COMPTE & [F:DAE2]BPR=TIERS
      # On ne déclare la TVA qu'à l'échéance du règlement
      READ_OK=1
      If [F:DAE2]TYP<>[F:HAE]TYP or [F:DAE2]NUM<>[F:HAE]NUM
       Read [HAE]HAE0 = [F:DAE2]TYP ; [F:DAE2]NUM
       If fstat : READ_OK=0 : Endif
      Endif
      If READ_OK & [F:HAE]DUDDAT<=[M]DATPCE
       TOTREG += [F:DAE2]SNS*[F:DAE2]AMTLED
      Elsif READ_OK & [F:HAE]DUDDAT>[M]DATPCE & GTRACE<>""
       # On mentionne les règlements lettrés mais non échus dans le fichier de trace
       Call ECR_TRACE(mess(12,107,1)-[F:HAE]TYP-[F:HAE]NUM
&                     -","-mess(15,105,1)-format$("D:"+GFMDAT,[F:HAE]DUDDAT)
&                     -":"-mess(87,107,1),0) From GESECRAN
      Endif
      #Elsif [F:DAE2]MTC<>"" & [F:DAE2]MTC<>LETTRE
      # C'est pas une pièce de règlement. Si on est sur une autre lettre, on est dans la
      # cas d'une facture multi-tiers.
      #Call ECR_TRACE(mess(12,107,1)-[F:DAE2]TYP-[F:DAE2]NUM-":"-"factures multi-tiers",1) From GESECRAN
     Endif
     # On va calculer ici les bases, montants de TVA, et les montants de TVA
     # déclarés par code TVA.
     # La TVA déclarée est mise à jour pour les comptes de TVA et les comptes
     # soumis à la TVA
     If !IMPUTACPT
      Gosub CALTVA
      If !OKDIM & GTRACE<>""
       # Groupe de lettrage non traité
       Call ECR_TRACE(COMPTE-TIERS-LETTRE-":"-mess(90,107,1)-"(>"+num$(MAXLIG)+")",1) From GESECRAN
       Break 2
      Endif
     Endif
     $NEXTDAE2
    Next
    Gosub CONT_CODENC
    If !OKCODENC & GTRACE<>""
     # Groupe de lettrage non traité : Code taxe incohérent
     Call ECR_TRACE(COMPTE-TIERS-LETTRE-mess(90,107,1)-":"-mess(93,107,1)-"("+mid$(TCODENC(I),2,GLONVAT)+")",1) From GESECRAN
     Break
    Endif
    Gosub CONT_CODDEB
    If !OKCODDEB
     If NBCODENC > 0 & GTRACE<>""
      # Groupe de lettrage non traité : Code taxe incohérent
      Call ECR_TRACE(COMPTE-TIERS-LETTRE-mess(90,107,1)-":"-mess(93,107,1)-"("+mid$(TCODDEB(I),2,GLONVAT)+")",1) From GESECRAN
      Break
     Endif
    Endif
   Endif
  Next
  # Demande 22603 : Cas de la facture CEE
  For IND=1 To NBCODENC
   If AMTVAT_BASE(IND)=0 and AMTVAT_TVA(IND)<>0
    # Détermination du signe selon [GAC]VATIPT
    CAT= val(left$(TCODENC(IND),1))
    If CAT=1 | CAT=2: SIGN=-1 : Else : SIGN=1 : Endif
    # Détermination du type de régime
    COD= mid$(TCODENC(IND),2,GLONVAT)
    Call LEC_TVT_LEG([F:CPY]LEG,COD) From CPTLEC
    Call LEC_TVB([F:CPY]LEG,[F:TVT]VATVAC) From CPTLEC
    If !fstat & [F:TVB]REGVAC=4
     AMTVAT_TVA(IND)=AMTVAT_TVA(IND)*SIGN
     For I=1 To NBACCNUM(IND)
      TAMTVAT(IND,I)=TAMTVAT(IND,I)*SIGN
     Next
    Endif
   Endif
  Next
  #
  If OKDIM & OKCODENC & OKCODDEB
   TOTDEB = sum(BASDEB(1..NBCODDEB))+sum(TVADEB(1..NBCODDEB))
   TOTENC = sum(BASENC(1..NBCODENC))+sum(TVAENC(1..NBCODENC))
   TOTDECLAR = sum(AMTVAT_BASE(1..NBCODENC))+sum(AMTVAT_TVA(1..NBCODENC)) : # TOTDECLAR : montant déjà déclaré pr le grp lettrage
   Gosub CAL_DECLAR
  Endif
 Next
 If GOK<0   : Goto ROLL_TR_DVP
 Elsif !GOK : Goto AB_TR_DVP
 Endif
 Filter [DAE]

 Gosub DELETTRAGE
 If GOK<0   : Goto ROLL_TR_DVP
 Elsif !GOK : Goto AB_TR_DVP
 Endif
 Filter [DAE]

 # On traite maintenant le cas des acomptes...
 Gosub ACOMPTES
 If GOK<0   : Goto ROLL_TR_DVP
 Elsif !GOK : Goto AB_TR_DVP
 Endif
 Filter [DAE]

 Gosub REG_NONLET

Commit
Return

$AB_TR_DVP
Rollback
Return

$ROLL_TR_DVP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_DVP : Endif


$REG_NONLET
# On met dans le fichier de trace les règlements échus et non lettrés
For [HAE]HAE0 Where [F:HAE]DUDDAT <= [M]DATPCE & find([F:HAE]TYP,TTYP(1..NBTYP)) & CPY=SOC & FCY=SIT
&                 & NUMDCL<>0 With Nohint
 # <PP 08/10/02> Bug 15959 : rajout critère NUMDCL<>0
 LETTRAGE = 0 : NBCPTLET = 0
 For [DAE4]DAE0 Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & LEDTYP=GTYPGEN & BPR<>""
  Call LEC_GAC([F:DAE4]ACC,[L]PLAN) From CPTLEC
  ## <PP 02/03/04> Bug 21449
  If !fstat & [F:GAC]FLGVAT<>3 & [F:GAC]MTC=2 : NBCPTLET += 1 : Endif
  ## <Fin PP>
  If [F:DAE4]MTC<>"" : LETTRAGE = 1 : Break : Endif
 Next
 If !LETTRAGE & NBCPTLET>0 & GTRACE<>""
  # Le règlement est échu et il n'y a aucune ligne d'écriture
  # de la pièce de règlement déclenchante lettrée ==> on affiche l'anomalie
  Call ECR_TRACE(mess(12,107,1)-[F:HAE]TYP-[F:HAE]NUM
&                 -","-mess(15,105,1)-format$("D:"+GFMDAT,[F:HAE]DUDDAT)
&                 -":"-mess(88,107,1),0) From GESECRAN
 Endif
Next
Return


$CALTVA
# Calcul des bases et montants de TVA
If [F:DAE2]TAX<>""
 Call LEC_GAC([F:DAE2]ACC,[L]PLAN) From CPTLEC
 If !fstat
  CAT = [F:GAC]VATIPT : # TVA coll.ven/coll.immo/déduc.achats/déduc.immos
  NBBLC = GLONVAT-len([F:DAE2]TAX)
  COD = [F:DAE2]TAX+space$(NBBLC)
  Call LEC_TVT_LEG([F:CPY]LEG,[F:DAE2]TAX) From CPTLEC
  Filter [TRA] Where VAT=[F:DAE2]TAX & CPY=SOC & STRDAT<=[F:DAE2]ACCDAT & LEG=[F:TVT]LEG
  Read [TRA]TRA0 Last
  If !fstat
   VAT_RAT = [F:TRA]VATRAT
  Else
   Filter [TRA] Where VAT=[F:DAE2]TAX & CPY="" & STRDAT<=[F:DAE2]ACCDAT & LEG=[F:TVT]LEG
   Read [TRA]TRA0 Last
   If !fstat
    VAT_RAT = [F:TRA]VATRAT
   Endif
  Endif
  Filter [TRA]
  CATCOD = num$(CAT)+COD+num$(VAT_RAT)
  If !DELETTRAGE
   If [F:TVT]VATPAY = 2 : # Taxe due sur les encaissements
    IND = find(CATCOD,TCODENC(1..NBCODENC))
    If !IND
     NBCODENC += 1 : IND = NBCODENC : TCODENC(IND) = CATCOD
    Endif
    Case [F:GAC]FLGVAT
     When 2
      BASENC(IND)      += [F:DAE2]SNS*[F:DAE2]AMTLED
      AMTVAT_BASE(IND) += [F:DAE2]AMTVAT
      #If [F:DAE2]AMTLED<>[F:DAE2]AMTVAT : # car pour le cas des impayés, on veut déclarer en sens inverse !!!
      If NBACCNUM(IND)>=MAXLIG
       OKDIM = 0 : Return
      Endif
      NBACCNUM(IND)  += 1 : TBACCNUM(IND,NBACCNUM(IND)) = [F:DAE2]ACCNUM
      TAMTLED(IND,NBACCNUM(IND)) = [F:DAE2]SNS*[F:DAE2]AMTLED : # Montant de l'écriture
      TAMTVAT(IND,NBACCNUM(IND)) = [F:DAE2]AMTVAT             : # Montant déjà déclaré de l'écriture
      #Endif
     When 3, 4
      TVAENC(IND)     += [F:DAE2]SNS*[F:DAE2]AMTLED
      AMTVAT_TVA(IND) += [F:DAE2]AMTVAT
      #If [F:DAE2]AMTLED<>[F:DAE2]AMTVAT : # car pour le cas des impayés, on veut déclarer en sens inverse !!!
      If NBACCNUM(IND)>=MAXLIG
       OKDIM = 0 : Return
      Endif
      NBACCNUM(IND)  += 1 : TBACCNUM(IND,NBACCNUM(IND)) = [F:DAE2]ACCNUM
      TAMTLED(IND,NBACCNUM(IND)) = [F:DAE2]SNS*[F:DAE2]AMTLED : # Montant de l'écriture
      TAMTVAT(IND,NBACCNUM(IND)) = [F:DAE2]AMTVAT             : # Montant déjà déclaré de l'écriture
      #Endif
    Endcase
   Else : # Taxe due sur les débits
    IND = find(CATCOD,TCODDEB(1..NBCODDEB))
    If !IND
     NBCODDEB += 1 : IND = NBCODDEB : TCODDEB(IND) = CATCOD
    Endif
    Case [F:GAC]FLGVAT
     When 2
      BASDEB(IND)    += [F:DAE2]SNS*[F:DAE2]AMTLED
     When 3, 4
      TVADEB(IND)    += [F:DAE2]SNS*[F:DAE2]AMTLED
    Endcase
   Endif
  Else : # On est dans le cas du délettrage
   If [F:TVT]VATPAY = 2 : # Taxe due sur les encaissements
    IND = find(CATCOD,TCODENC(1..NBCODENC))
    If !IND
     NBCODENC += 1 : IND = NBCODENC : TCODENC(IND) = CATCOD
    Endif
    If NBACCNUM(IND)>=MAXLIG
     OKDIM = 0 : Return
    Endif
    NBACCNUM(IND)  += 1 : TBACCNUM(IND,NBACCNUM(IND)) = [F:DAE2]ACCNUM
    TAMTVAT(IND,NBACCNUM(IND)) = [F:DAE2]AMTVAT : # Montant déjà déclaré de l'écriture
   Endif
  Endif
 Endif
Endif
Return


$CAL_DECLAR
TOTAL  = TOTDEB + TOTENC
If TOTREG<0 : # Le règlement est une recette
 TOTREG    = -TOTREG
 TOTDEB    = -TOTDEB
 TOTENC    = -TOTENC
 TOTAL     = -TOTAL
Endif
If TOTDECLAR<0
 TOTDECLAR = -TOTDECLAR
Endif
## Bug 55172
If TOTREG>0 & TOTAL>0 & TOTDECLAR>0 & TOTENC<0
 TOTDECLAR = -TOTDECLAR
Endif
## Fin bug 55172
Case OPTPAY
 When "1"
  # On suppose que la TVA sur débits est payée en premier.
  # Par conséquence,  on diminue le règlement du montant sur débits.
  # Ex : Fact. 1000 Euros HT + 200 Euros TVA sur débits
  #            1000 Euros HT + 200 Euros TVA sur encaissements
  #            Total = 2400 Euros TTC
  # On a un règlement de 1500 Euros. Dans ce cas, le montant de
  # la TVA sur débits sera de 1200 Euros et la TVA sur encaissements
  # sera de 300 Euros.
  # En fait la TVA sur encaissements à déclarer sera égale à :
  # (300/1200)*200 soit 50 Euros
  If TOTREG = 0
   TOTREG_ENC = -TOTDECLAR
  Else
   TOTREG_DEB = min(TOTREG,TOTDEB)
   TOTREG_ENC = TOTREG-TOTREG_DEB-TOTDECLAR
   If TOTREG_ENC>TOTENC-TOTDECLAR
    TOTREG_ENC = TOTENC-TOTDECLAR
   Endif
  Endif
 When "2"
  # On suppose qu'on paye on prorata. On proratise le règlement
  # par rapport au rapport base+TVA sur encaissements/
  # Total base+TVA (TVAENC/TOTAL)
  If TOTREG = 0
   TOTREG_ENC = -TOTDECLAR
  Elsif TOTREG <= TOTAL & TOTAL<>0
   TOTREG_ENC = (TOTREG)*(TOTENC/TOTAL)-TOTDECLAR
  Elsif TOTAL>0
   # le montant du règlement est supérieur au montant restant à déclarer
   # (sur les factures lettrées avec le (ou les) réglement(s), il y a des comptes
   # non soumis à la TVA...)
   TOTREG_ENC = TOTENC-TOTDECLAR
  Endif
Endcase

If TOTREG_ENC<>0
 For IND=1 To NBCODENC
  CAT     = val(left$(TCODENC(IND),1))
  COD     = mid$(TCODENC(IND),2,GLONVAT)
  VAT_RAT = val(right$(TCODENC(IND),GLONVAT+2))
  If CAT=1 | CAT=2: SIGN=-1 : Else : SIGN=1 : Endif

  # Issue X3-75723
  Local Integer W_REGVACCEE
  If AMTVAT_BASE(IND)=0 and AMTVAT_TVA(IND)<>0
      Call LEC_TVT_LEG([F:CPY]LEG,COD) From CPTLEC
      Call LEC_TVB([F:CPY]LEG,[F:TVT]VATVAC) From CPTLEC
      If !fstat & [F:TVB]REGVAC=4
       [L]W_REGVACCEE = 2
      Endif
  Endif
  # End issue X3-75723

  If TVAENC(IND)<>0 | BASENC(IND)<>0 | (TVAENC(IND)=0 & BASENC(IND)=0 & TOTREG_ENC<>0 & AMTVAT_BASE(IND)<>0 & AMTVAT_TVA(IND)<>0)
   MTHT       = SIGN*BASENC(IND)
   MTTVA      = SIGN*TVAENC(IND)

   MTTTC      = TOTENC
   If TOTREG<>0 & MTTTC<>0
    If MTTTC>0
     MTPCE = min(TOTREG_ENC,MTTTC)
    Else
     MTPCE = max(TOTREG_ENC,MTTTC)
    Endif
    MONTANT    = arr(MTTVA*MTPCE/MTTTC,GARODEV)
    BASE       = arr(MTHT*MTPCE/MTTTC,GARODEV)
   Else
    # Montant règlement=0 => on déclare en sens inverse !!!
    # ou Montant règlement<>0, pas de TVA/enc à déclarer pourtant des montants de TVA déjà déclarés => On déclare en sens inverse !!
    MONTANT = -AMTVAT_TVA(IND)
    BASE    = -AMTVAT_BASE(IND)
   Endif

   For I=1 To NBACCNUM(IND)
    Read [DAE3]DAE2 = TBACCNUM(IND,I)
    If !fstat
     Call LEC_GAC([F:DAE3]ACC,[L]PLAN) From CPTLEC
     If ([F:GAC]FLGVAT=2 & BASE<>0) | (find([F:GAC]FLGVAT,3,4) & MONTANT<>0)
      Raz [F:DVP]
      [F:DVP]CPY = SOC
      [F:DVP]FCY = SIT
      [F:DVP]STRDAT = DATDEB
      [F:DVP]ENDDAT = DATFIN
      [F:DVP]COA    = PLAN
      [F:DVP]ACC    = COMPTE
      [F:DVP]BPR    = TIERS
      [F:DVP]MTC    = LETTRE
      [F:DVP]VATRAT = vireblc(COD,1)+" "+num$(VAT_RAT)
      [F:DVP]VAT    = vireblc(COD,1)
      [F:DVP]ACCNUM = TBACCNUM(IND,I)
      [F:DVP]VATIPT = [F:GAC]VATIPT : # Imputation taxe (LA609)
      [F:DVP]MTCDAT = DATLET
      [F:DVP]SIM    = SIMUL
      [F:DVP]AMTVCR = TOTREG
      [F:DVP]TOTAMTATI = SIGN*BASENC(IND)+MTTVA
      [F:DVP]TOTAMTVAT = MTTVA
      [F:DVP]OPT       = val(OPTPAY)
      # La date maximale d'échéance est stockée dans le fichier pour pouvoir l'indiquer en
      # en-tête dans l'impression ou la réimpression de l'état (suggestion soumise)
      If SIMUL = 1 : OKMAJ = 1 : Endif
      [F:DVP]DATMAX    = [M:DIA]DATPCE
      [F:DVP]TYPREC    = 1 : # sert à différencier les diff cas : acomptes, pièces délettrées
      # On proratise les montants à déclarer par rapport au montant total des pièces
      # du même groupe de lettrage
      If [F:GAC]FLGVAT = 2
       If BASENC(IND)<>0
        BASVAT_PAY = SIGN*TAMTLED(IND,I)*((AMTVAT_BASE(IND)+BASE)/(SIGN*BASENC(IND)))
        [F:DVP]BASVATPAY = BASVAT_PAY-TAMTVAT(IND,I)
       Elsif BASENC(IND)=0 & AMTVAT_BASE(IND)<>0 & TAMTVAT(IND,I)=AMTVAT_BASE(IND)
        BASVAT_PAY = 0
        [F:DVP]BASVATPAY = BASVAT_PAY-TAMTVAT(IND,I)
       Else
        OKMAJ = 0
       Endif
      Elsif find([F:GAC]FLGVAT,3,4) & MONTANT<>0

       # Issue X3-75723
       If dim([L]W_REGVACCEE)>0 and [L]W_REGVACCEE = 2 and TOTREG<>0
         AMTVAT_TVA(IND)=AMTVAT_TVA(IND)*SIGN
         TAMTVAT(IND,I)=TAMTVAT(IND,I)*SIGN
       Endif
       # End issue X3-75723

       If TVAENC(IND)<>0
        AMTVAT_PAY = SIGN*TAMTLED(IND,I)*((AMTVAT_TVA(IND)+MONTANT)/(SIGN*TVAENC(IND)))
        [F:DVP]AMTVATPAY = AMTVAT_PAY-TAMTVAT(IND,I)
       Elsif TVAENC(IND)=0 & AMTVAT_TVA(IND)<>0 & TAMTVAT(IND,I)=AMTVAT_TVA(IND)
        AMTVAT_PAY = 0
        [F:DVP]AMTVATPAY = AMTVAT_PAY-TAMTVAT(IND,I)
       Else
        OKMAJ = 0
       Endif
      Endif
      [F:DVP]NUMRPT = GNUMRPT2
      Gosub POINT_ENTREE
      Write [DVP]
      If fstat
       GOK = 0 : Call FSTA("DVP") From GLOCK : Break 2
      Endif

      If SIMUL = 1
       # On lance la déclaration en réel ==> MAJ du montant de TVA déclarée
       If [F:GAC]FLGVAT = 2 : # Compte soumis à TVA
        [F:DAE3]AMTVAT = BASVAT_PAY
       Elsif find([F:GAC]FLGVAT,3,4) : # Compte de TVA
        [F:DAE3]AMTVAT = AMTVAT_PAY
       Endif
       Rewrite [DAE3]
       If fstat
        GOK = 0 : Call FSTA("DAE3") From GLOCK
       Endif
       If GOK<1 : Break 2 : Endif
      Endif
        # Issue X3-75723 local sign correction restore in CEE case
        If find([F:GAC]FLGVAT,3,4) & MONTANT<>0
         If dim([L]W_REGVACCEE)>0 and [L]W_REGVACCEE = 2 and TOTREG<>0
           AMTVAT_TVA(IND)=AMTVAT_TVA(IND)*SIGN
           TAMTVAT(IND,I)=TAMTVAT(IND,I)*SIGN
         Endif
        Endif
        # End issue X3-75723
     Endif
    Endif
   Next
  Endif
 Next
 If GOK < 1 : Return : Endif
Endif
Return

$DELETTRAGE
# On ne va trouver ici que des factures puisque les règlements ne comportent pas de TVA
# déclarée. On teste donc par rapport à la date de pièce et non par rapport à la date d'échéance
# NB : quand on délettre une pièce, seule la lettre est remise à zéro. On conserve
# la date de lettrage de façon à pouvoir borner ici sur la date lettrage.
# Donc si une ligne d'écriture a la zone MTC à vide et la zone MTCDAT différente de vide,
# cela veut dire que le pièce a été délettrée. MTCDAT contient la date du délettrage.
DELETTRAGE = 1

Raz [L]DAE3FILTRE
If GCALL_PT : GPOINT = "DAE3FILTRE" : Gosub ENTREE From EXEFNC : Endif
If [L]DAE3FILTRE="" : [L]DAE3FILTRE="1=1" : Endif

Filter [DAE3] Where CPY=SOC & FCYLIN=SIT & LEDTYP=GTYPGEN & BPR<>""
&                 & MTCDAT>=DATDEB & MTCDAT<=DATFIN & MTC=""
&                 & ACCDAT<=[M]DATPCE
&                 & evalue([L]DAE3FILTRE)

For [DAE3]DAE0(2) With Nohint
 MAJVAT = 0
 Raz NBCODENC, TCODENC
 Raz NBACCNUM, TBACCNUM
 Raz TAMTVAT
 For [DAE2]DAE0 Where TYP = [F:DAE3]TYP & NUM = [F:DAE3]NUM & LEDTYP = [F:DAE3]LEDTYP
  If [F:DAE2]AMTVAT<>0
   MAJVAT = 1
   Gosub CALTVA
  Endif
 Next
 If MAJVAT
  Gosub RAZAMTVAT
 Endif
Next
Filter [DAE3]
Return

$RAZAMTVAT
For IND=1 To NBCODENC
 CAT     = val(left$(TCODENC(IND),1))
 COD     = mid$(TCODENC(IND),2,GLONVAT)
 VAT_RAT = val(right$(TCODENC(IND),5))
 If CAT=1 | CAT=2: SIGN=-1 : Else : SIGN=1 : Endif
 For I=1 To NBACCNUM(IND)
  Read [DAE4]DAE2 = TBACCNUM(IND,I)
  If !fstat & TAMTVAT(IND,I)<>0
   Raz [F:DVP]
   [F:DVP]CPY = SOC
   [F:DVP]FCY = SIT
   [F:DVP]STRDAT = DATDEB
   [F:DVP]ENDDAT = DATFIN
   [F:DVP]COA    = ""
   [F:DVP]ACC    = ""
   [F:DVP]BPR    = ""
   [F:DVP]MTC    = ""
   [F:DVP]VATRAT = vireblc(COD,1)+" "+num$(VAT_RAT)
   [F:DVP]VAT    = vireblc(COD,1)
   [F:DVP]ACCNUM = TBACCNUM(IND,I)
   Call LEC_GAC([F:DAE4]ACC,[L]PLAN) From CPTLEC
   [F:DVP]VATIPT = [F:GAC]VATIPT : # Imputation taxe (LA609)
   [F:DVP]MTCDAT = [0/0/0]
   [F:DVP]SIM    = SIMUL
   [F:DVP]AMTVCR = 0
   [F:DVP]TOTAMTATI = 0
   [F:DVP]TOTAMTVAT = 0
   [F:DVP]OPT       = val(OPTPAY)
   [F:DVP]DATMAX    = [M:DIA]DATPCE
   [F:DVP]TYPREC    = 2 : # Cas des pièces déléttrées
   If [F:GAC]FLGVAT = 2
    [F:DVP]BASVATPAY = TAMTVAT(IND,I)*-1
   Elsif find([F:GAC]FLGVAT,3,4)
    [F:DVP]AMTVATPAY = TAMTVAT(IND,I)*-1
   Endif
   [F:DVP]NUMRPT = GNUMRPT2
   Gosub POINT_ENTREE
   Write [DVP]
   If fstat
    GOK = 0 : Call FSTA("DVP") From GLOCK : Break 2
   Endif
   If SIMUL = 1
    # On lance la déclaration en réel ==> RAZ du montant déclaré
    [F:DAE4]AMTVAT = 0
    Rewrite [DAE4]
    If fstat
     GOK = 0 : Call FSTA("DAE4") From GLOCK
    Endif
    If GOK<1 : Break 2 : Endif
   Endif
  Endif
 Next
Next
Return

$ACOMPTES
## Cas des acomptes
# Lors d'un versement ou de la réception d'un acompte relatif
# à une prestation de service, l'acompte est considéré comme
# porteur de TVA qu'il faut déclarer.
# Le compte d'acompte (409, 419) reçu ou versé relatif à une prestation
# de service doit être paramétré en "Compte d'acompte".
# La pièce constatant le règlement ou le versement d'un
# acompte peut être déclenchante ou non déclenchante.
# Par contre, la pièce d'imputation d'acompte doit être
# déclenchante.
# On parcourt les comptes d'acompte (pour lesquels FLGVAT=5)
# pour traiter le cas des acomptes
Raz TYPPCE, NUMPCE, NUMACPT
Filter [DAE2] Where CPY=SOC & FCYLIN=SIT & LEDTYP=GTYPGEN
For [GAC]GAC0 Where COA=[L]PLAN & FLGVAT=5
 For [DAE2]DAE1 Where ACC=[F:GAC]ACC
  If !([F:DAE2]TYP=TYPPCE & [F:DAE2]NUM=NUMPCE)
   Read [HAE]HAE0 = [F:DAE2]TYP ; [F:DAE2]NUM

   # BY pour les acomptes il faut prendre la date maximum de pièce
   # Ca pose un problème pour la date mini

   # If fstat=0 & [F:HAE]DUDDAT>=DATDEB & [F:HAE]DUDDAT<=DATFIN

   ## <PP 26/02/04> Bug 21393 : rajout de la condition [F:HAE]FLGREP<>2 pour exclure les pièces d'AN
   If fstat=0 & [F:HAE]DUDDAT>=DATDEB & [F:HAE]DUDDAT<=[M]DATPCE & [F:HAE]FLGREP<>2
    TYPPCE = [F:DAE2]TYP
    NUMPCE = [F:DAE2]NUM
    COMPTE = [F:DAE2]ACC
    TIERS  = [F:DAE2]BPR
    Raz MTTTC, MTTVA
    For [DAE3]DAE0 Where TYP=TYPPCE & NUM=NUMPCE & LEDTYP=[F:DAE2]LEDTYP & AMTVAT=0
     If [DAE3]ACC=[F:GAC]ACC
      MTTTC += [F:DAE3]AMTLED*[F:DAE3]SNS
      If SIMUL = 1
       [F:DAE3]AMTVAT = [F:DAE3]AMTLED
       Rewrite [DAE3]
       If fstat
        GOK=0 : Call FSTA("DAE3") From GLOCK
       Endif
      Endif
     Elsif [F:DAE3]TAX<>"" & [F:DAE3]AMTVAT=0
      READ_OK=1
      If [L]PLAN<>[F:GAC2]COA or [F:DAE3]ACC<>[F:GAC2]ACC
       Read [F:GAC2]GAC0 = [L]PLAN;[F:DAE3]ACC
       If fstat : READ_OK=0 : Endif
      Endif
      If READ_OK & find([F:GAC2]FLGVAT,3,4) : # C'est un compte de TVA
       Call LEC_TVT_LEG([F:CPY]LEG,[F:DAE3]TAX) From CPTLEC
       If [F:TVT]VATPAY = 2 : # Taxe due sur les encaissements
        If [F:GAC]VATIPT=1 | [F:GAC]VATIPT=2
         SIGN=-1
        Else
         SIGN=1
        Endif
        MTTVA += [F:DAE3]AMTLED*[F:DAE3]SNS*SIGN
        If SIMUL = 1
         [F:DAE3]AMTVAT = [F:DAE3]AMTLED
         Rewrite [DAE3]
         If fstat
          GOK=0 : Call FSTA("DAE3") From GLOCK
         Endif
        Endif
       Endif
      Endif
     Endif
    Next
    If MTTVA<>0
     MTTTC = MTTTC*SIGN
     NUMACPT += 1           : # Juste pour l'état Crystal Report...
     LETTRE = num$(NUMACPT)
     Raz [F:DVP]
     Gosub LECTAX
     [F:DVP]CPY       = SOC
     [F:DVP]FCY       = SIT
     [F:DVP]STRDAT    = DATDEB
     [F:DVP]ENDDAT    = DATFIN
     [F:DVP]COA       = PLAN
     [F:DVP]ACC       = COMPTE
     [F:DVP]BPR       = TIERS
     [F:DVP]MTC       = LETTRE
     [F:DVP]VAT       = [F:DAE2]TAX
     [F:DVP]VATRAT    = [F:DAE2]TAX+" "+num$(VAT_RAT)
     [F:DVP]MTCDAT    = [F:DAE2]ACCDAT
     [F:DVP]ACCNUM    = [F:DAE2]ACCNUM
     [F:DVP]VATIPT    = [F:GAC]VATIPT : # Imputation taxe (LA609)
     [F:DVP]SIM       = SIMUL
     [F:DVP]AMTVCR    = abs(MTTTC)
     [F:DVP]BASVATPAY = MTTTC-MTTVA
     [F:DVP]AMTVATPAY = MTTVA
     [F:DVP]TOTAMTATI = MTTTC
     [F:DVP]TOTAMTVAT = MTTVA
     [F:DVP]TYPREC    = 3 : # Cas des acomptes
     [F:DVP]DATMAX    = [M:DIA]DATPCE
     [F:DVP]OPT       = val(OPTPAY)
     [F:DVP]NUMRPT    = GNUMRPT2
     Gosub POINT_ENTREE
     Write [DVP]
     If fstat
      GOK=0 : Call FSTA("DVP") From GLOCK : Break 2
     Endif
    Endif
   Endif
  Endif
 Next
Next
Filter [DAE2]
Return


$LECTAX
NBBLC = GLONVAT-len([F:DAE2]TAX)
COD = [F:DAE2]TAX+space$(NBBLC)
Call LEC_TVT_LEG([F:CPY]LEG,[F:DAE2]TAX) From CPTLEC
Filter [TRA] Where VAT=[F:DAE2]TAX & CPY=SOC & STRDAT<=[F:DAE2]ACCDAT & LEG=[F:TVT]LEG
Read [TRA]TRA0 Last
If !fstat
 VAT_RAT = [F:TRA]VATRAT
Else
 Filter [TRA] Where VAT=[F:DAE2]TAX & CPY="" & STRDAT<=[F:DAE2]ACCDAT & LEG=[F:TVT]LEG
 Read [TRA]TRA0 Last
 If !fstat
  VAT_RAT = [F:TRA]VATRAT
 Endif
Endif
Filter [TRA]
Return


# On contrôle qu'on n'ait pas dans le groupe de lettrage une base = 0
# et un montant de TVA<>0 (ou le contraire) pour un code taxe.
# Exception à cela :
#   1°) Code taxe exonéré (taux=0) pour lequel on aura une base<>0 et un
#       montant de TVA=0
#   2°) Code taxe auquel correspond un régime de taxe export (régime de type 2)
#       pour lequel on aura une base<>0 et un montant de TVA=0
#   3°) Code taxe auquel correspond un régime de taxe suspension de taxe (régime de type 3)
#       pour lequel on aura une base<>0 et un montant de TVA=0
#   4°) Code taxe auquel correspond un régime de taxe CEE (régime de type 4)
#       pour lequel on aura une base=0 et un montant de TVA<>0

$CONT_CODENC
OKCODENC = 1
For I=1 To NBCODENC
 IND2 = find(vireblc(mid$(TCODENC(I),2,GLONVAT),4),T_CODENC(1..NB_CODENC))
 If IND2 & T_RATENC(IND2)<>0 & !find(T_TYPREGENC(IND2),2,3,4) & (BASENC(I)=0 | TVAENC(I)=0) & (BASENC(I)+TVAENC(I)<>0)
  OKCODENC = 0 : Break
 Endif
Next
Return


$CONT_CODDEB
OKCODDEB = 1
For I=1 To NBCODDEB
 IND2 = find(vireblc(mid$(TCODDEB(I),2,GLONVAT),4),T_CODDEB(1..NB_CODDEB))
 If IND2 & T_RATDEB(IND2)<>0 & !find(T_TYPREGDEB(IND2),2,3,4) & (BASDEB(I)=0 | TVADEB(I)=0) & (BASDEB(I)+TVADEB(I)<>0)
  OKCODDEB = 0 : Break
 Endif
Next
Return


# On commence par effacer les enregistrements pour la déclaration
# de TVA sur encaissements qu'on est en train de lancer et pour
# lequels SIM=2

$TR_DELDVP
GOK = 1
Trbegin [DVP]
 Delete [DVP] Where CPY=SOC & FCY=SIT & SIM=2
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("DVP",SOC-SIT) From GLOCK : Goto AB_TR_DELDVP
 Endif
 If   GOK<0 : Goto ROLL_TR_DELDVP
 Elsif !GOK : Goto AB_TR_DELDVP
 Endif
Commit
Return

$AB_TR_DELDVP
Rollback
Return

$ROLL_TR_DELDVP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_DELDVP : Endif

$POINT_ENTREE
If GCALL_PT : GPOINT = "AV_ECRDVP" : Gosub ENTREE From EXEFNC : Endif
Return


#############################################################################
# Actions called from SAISIE_CHAR - GSAISIE
#############################################################################

$OUVRE
Gosub OUVRE_FIC
Return

$OUVRE_FIC
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif : # Company
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif : # Facility
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif : # Account
If clalev([F:DLV])=0 : Local File DCLVAT     [DLV] : Endif : # Tax declaration on the debits
If clalev([F:DVP])=0 : Local File DCLVATPAY  [DVP] : Endif : # Tax declaration on collection
If clalev([F:ADW])=0 : Local File ADOVAL     [ADW] : Endif : # Parameter values
If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif : # Document types
If clalev([F:TVT])=0 : Local File TABVAT     [TVT] : Endif : # Tax codes
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif : # Currendies
If clalev([F:AWI])=0 : Local File AWINDOW    [AWI] : Endif : # Window
Return


#JOJAC - 2018-08-08 - X3-103256 - START
$DEBUT
Raz [M:DIA]INI : Affzo [DIA]
If [M:DIA]SIM <> 3 : Grizo [M:DIA]NUMRPT  : Affzo [M:DIA]NUMRPT : Endif
Return
#JOJAC - 2018-08-08 - X3-103256 - END

#############################################################################
## BATCH
#############################################################################
$OUVRE_BATCH
# Initializes the right window in a batch process
BCRIT = "DCLVAT"+PARAM(1)
Gosub OUVRE
Gosub DECLARE
Return


#############################################################################
## This sub-program controls the parameters capture.
## The batch process needs these parameters
#############################################################################

Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK

If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif

Case PARAM
 When "VATRPTBAT"
  If VALEUR="" : End : Endif
  Read [AIM]AIM0=VALEUR
  If [F:AIM]PRT<>2 & [F:AIM]PRT<>4
   # La destination renseignée dans le paramètre '$1' doit être de type 'Fichier' ou 'Imprimante'.
   GMESSAGE = mess(327,117,1)
   Call DYNAMIC(GMESSAGE,"$1", PARAM) From TEXTE
   OK = 0 : End
  Endif
  If [AIM]PRTSRV=""
   # La destination renseignée dans le paramètre '$1' doit être associée à un serveur d'impression.
   GMESSAGE = mess(254,117,1)
   Call DYNAMIC(GMESSAGE,"$1", PARAM) From TEXTE
   OK = 0 : End
  Endif
 When "VATRPTDIR"
  If VALEUR<>"" & (right$(VALEUR, len(VALEUR))<>"/" and right$(VALEUR, len(VALEUR))<>"\")
   # La valeur doit finir par le caractère / ou |\
   GMESSAGE = mess(256,117,1)
   OK = 0
   End
  Endif
Endcase
End


#############################################################################
## Etiquettes du masque DCLVATOTH et autres
#############################################################################

Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 Grizo ALLCPY
 Actzo CPY
 mkstat = 1 : End
Endif
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CPY,FCY : Diszo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY : Diszo ALLFCY
Else
 Actzo CPY,ALLFCY
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Call AS_CPY(VALEUR) From CPTTRT
End
#Finance Sprint 1 US2 71253
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

If GFONCTION="DCLVATBAT"
 If dim([M:ABA1]TACHE)>0
  Call LECTURE("ABT",[M:ABA1]TACHE,"") From CONTOBJ
 Endif
 If [F:ABT]PARAM<>""
  Call CTLCPYLEGVAT(VALEUR,[F:ABT]PARAM) From DCLVATSTD
 Endif
Else
 Call CTLCPYLEGVAT(VALEUR,GFNCLEG) From DCLVATSTD
Endif

End

## Suggestion 10822
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Local Char  PARAM(10)
Call PARAM(VALEUR,"DCLVATPAY",PARAM) From ADOVAL
If dim([M]VATPAY)>0
 If PARAM="2" : [M]VATPAY=2 : Else [M]VATPAY=1 : Endif
 Affzo [M]VATPAY
Endif
If dim([M]VATPAY)>0
 Call AP_VATPAY([M]VATPAY)
Endif
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
If [M]ALLCPY=2 : VALEUR = 2 : End : Endif
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
#JOJAC - 2018-08-07 - X3-103256 - START
If [M]SIM<>3
  If VALEUR=2 : Effzo FCY : Diszo FCY : Else : Actzo FCY : [M]SIM=2 : Affzo [M]SIM : Endif
Endif
#If VALEUR=2 : Effzo FCY : Diszo FCY : Else : Actzo FCY : [M]SIM=2 : Affzo [M]SIM : Endif
#JOJAC - 2018-08-07 - X3-103256 - END
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR
If [M]ALLFCY=2 : mkstat = 1 : End : Endif
End

## Suggestion 11462
## Si on choisit un site en particulier c'est forcement une simulation !
Subprog AS_SIM(VALEUR)
Variable Integer VALEUR
#JOJAC - 2018-08-07 - X3-103256 - START
If [M]SIM<>3
  If [M]ALLFCY<>2 : VALEUR=2 : mkstat = 2 : End : Endif
Endif
#If [M]ALLFCY<>2 : VALEUR=2 : mkstat = 2 : End : Endif
#JOJAC - 2018-08-07 - X3-103256 - END
End

## Etiquettes pour le bloc TVA sur débits

Subprog AP_VAT(VALEUR)
Variable Integer VALEUR
#JOJAC - 2018-08-07 - X3-103256 - START
If [M]SIM<>3
  If VALEUR = 1
   Grizo STRDAT, ENDDAT, DETVCR
  Else
   Actzo STRDAT, ENDDAT, DETVCR
  Endif
Endif
#If VALEUR = 1
#  Grizo STRDAT, ENDDAT, DETVCR
#Else
#   Actzo STRDAT, ENDDAT, DETVCR
#Endif
#JOJAC - 2018-08-07 - X3-103256 - END
End

Subprog D_STRDAT(VALEUR)
Variable Date    VALEUR
#JOJAC - 2018-08-07 - X3-103256 - START
If [M]SIM<>3
  VALEUR = gdat$(1,month(date$)-1,year(date$))
Endif
#VALEUR = gdat$(1,month(date$)-1,year(date$))
#JOJAC - 2018-08-07 - X3-103256 - END
End

Subprog D_ENDDAT(VALEUR)
Variable Date    VALEUR
#JOJAC - 2018-08-07 - X3-103256 - START
If [M]SIM<>3
  VALEUR = eomonth([M]STRDAT)
Endif
#VALEUR = eomonth([M]STRDAT)
#JOJAC - 2018-08-07 - X3-103256 - END
End

Subprog AP_ENDDAT(VALEUR)
Variable Date    VALEUR
Local Integer OK, SIMUL
#JOJAC - 2018-08-07 - X3-103256 - START
If [M]SIM<>3
  OK=0
  If [M]VAT=2
   For [DLV]DLV0 Where ([M]CPY="" | CPY=[M]CPY) & STRDAT=[M]STRDAT & ENDDAT=VALEUR
    OK=1 : SIMUL = [F:DLV]SIM : Break
   Next
  Endif
Endif
#OK=0
#If [M]VAT=2
#  For [DLV]DLV0 Where ([M]CPY="" | CPY=[M]CPY) & STRDAT=[M]STRDAT & ENDDAT=VALEUR
#    OK=1 : SIMUL = [F:DLV]SIM : Break
#   Next
#Endif
#JOJAC - 2018-08-07 - X3-103256 - END
End

## Etiquettes pour le bloc TVA sur encaissements

## Suggestion 10822
Subprog D_VATPAY(VALEUR)
Variable Integer VALEUR
Local Char  PARAM(10)
#JOJAC - 2018-08-07 - X3-103256 - START
If [M]SIM<>3
  Call PARAM([M]CPY,"DCLVATPAY",PARAM) From ADOVAL
  If PARAM="2" : VALEUR=2 : Else VALEUR=1 : Endif
  Call AP_VATPAY(VALEUR)
Endif
#Call PARAM([M]CPY,"DCLVATPAY",PARAM) From ADOVAL
#If PARAM="2" : VALEUR=2 : Else VALEUR=1 : Endif
#Call AP_VATPAY(VALEUR)
#JOJAC - 2018-08-07 - X3-103256 - END
End

Subprog AP_VATPAY(VALEUR)
Variable Integer VALEUR
#JOJAC - 2018-08-07 - X3-103256 - START
If [M]SIM<>3
  If VALEUR = 1
   Grizo STRDAT2, ENDDAT2, DATPCE, DETAIL, TRACE
  Else
   Actzo STRDAT2, ENDDAT2, DATPCE, DETAIL, TRACE
  Endif
Endif
#If VALEUR = 1
#   Grizo STRDAT2, ENDDAT2, DATPCE, DETAIL, TRACE
#Else
#   Actzo STRDAT2, ENDDAT2, DATPCE, DETAIL, TRACE
#Endif
#JOJAC - 2018-08-07 - X3-103256 - END
End

Subprog D_STRDAT2(VALEUR)
Variable Date    VALEUR
#JOJAC - 2018-08-07 - X3-103256 - START
If [M]SIM<>3
  VALEUR = gdat$(1,month(date$)-1,year(date$))
Endif
#VALEUR = gdat$(1,month(date$)-1,year(date$))
#JOJAC - 2018-08-07 - X3-103256 - END
End

Subprog D_ENDDAT2(VALEUR)
Variable Date    VALEUR
#JOJAC - 2018-08-07 - X3-103256 - START
If [M]SIM<>3
  VALEUR = eomonth([M]STRDAT)
Endif
#VALEUR = eomonth([M]STRDAT)
#JOJAC - 2018-08-07 - X3-103256 - END
End

Subprog D_DATPCE(VALEUR)
Variable Date     VALEUR
VALEUR = [M]ENDDAT2
End

Subprog AV_INI(VALEUR)
Variable Char    VALEUR()
#JOJAC - 2018-08-07 - X3-103256 - START
If [M]SIM<>3
  #DdM39267
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
   [M]ALLCPY = 1 : Affzo ALLCPY
  Endif
  If [M]ALLCPY=2
   Effzo CPY,FCY : Grizo CPY,FCY
   [M]ALLFCY=2 : Affzo ALLFCY : Grizo ALLFCY
  Else
   Actzo CPY,ALLFCY
  Endif
  If [M]VAT=1
   Grizo STRDAT, ENDDAT, DETVCR
  Else
   Actzo STRDAT, ENDDAT, DETVCR
  Endif
  If dim([M]VATPAY)>0
   If [M]VATPAY = 1
    Grizo STRDAT2, ENDDAT2, DATPCE, DETAIL, TRACE
   Else
    Actzo STRDAT2, ENDDAT2, DATPCE, DETAIL, TRACE
   Endif
  Endif
