######################################################################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
#Dbgaff
#--- jmr
#JOJAC - 2018-08-07 - X3-103256 - START
If [M]SIM<>3
  Local Date WENDPER1 : Raz WENDPER1 : WENDPER1 = [30/09/2017] # "20170930"

  Local Date WSTRPER2 : Raz WSTRPER2 : WSTRPER2 = [01/10/2017] # "20171001"
  Local Date WENDPER2 : Raz WENDPER2 : WENDPER2 = [31/12/2017] # "20171231"

  Local Date WSTRPER3 : Raz WSTRPER3 : WSTRPER3 = [01/01/2018] # "20180101"

  If ((STRDAT <= WENDPER1) and (VALEUR >= STRDAT and VALEUR <= WENDPER1))
& or ((STRDAT >= WSTRPER2 and STRDAT <= WENDPER2) and (VALEUR >= STRDAT and VALEUR <= WENDPER2))
& or ((STRDAT >= WSTRPER3) and (VALEUR >= STRDAT))
  Else
    GMESSAGE = mess(1,104,1) # Incorrect date
    mkstat = 2
  Endif
Endif
#--- jmr
#Local Date WENDPER1 : Raz WENDPER1 : WENDPER1 = [30/09/2017] # "20170930"
