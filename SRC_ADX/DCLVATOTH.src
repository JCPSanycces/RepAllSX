End

######################################################################################
## Section automatically added (screen DCLVATSWI) 08/07/2018 15:01:27 (JOJAC)
######################################################################################
Subprog AM_SIM(VALEUR)
Variable Integer VALEUR
#[M]SIM = VALEUR
Call GRISE(VALEUR)
If VALEUR <> 3 and [M]SIM=3
  [M:DIA]STRDAT = gdat$(1,month(date$)-1,year(date$))
  [M:DIA]ENDDAT = eomonth([M]STRDAT)

  Effzo [M:DIA]ALLCPY,ALLFCY,CPY,FCY
  If [M:DIA]CPY = "" : [M:DIA]ALLCPY=2 : Affzo [M:DIA]ALLCPY : Endif
  If [M:DIA]FCY = "" : [M:DIA]ALLFCY=2 : Affzo [M:DIA]ALLFCY : Endif
  #Grizo [M:DIA]ALLCPY, ALLFCY,STRDAT,ENDDAT
  Affzo [M:DIA]
Endif
[M]SIM = VALEUR
End

Subprog GRISE(LTYPGEN)
Value Integer LTYPGEN
Case LTYPGEN
  When 1 : # Actual
   Raz [M:DIA]NUMRPT,FCY,CPY
   Actzo [DIA]
   Grizo [DIA]NUMRPT, FCY,CPY
  When 2 : # Simulation
   Raz [M:DIA]NUMRPT,FCY,CPY
   Actzo [DIA]
   Grizo [DIA]NUMRPT, FCY,CPY
  When 3 : # Regeneration
   Actzo [DIA]
   Effzo [DIA]CPY, FCY, STRDAT, ENDDAT
   Grizo [DIA]CPY, FCY, STRDAT, ENDDAT
   Affzo [M:DIA]
Endcase

End

######################################################################################
## Section automatically added (screen DCLVATSWI) 08/08/2018 10:19:30 (JOJAC)
######################################################################################
Subprog C_NUMRPT(VALEUR)
Variable Decimal VALEUR
Filter [F:DLV] Where NUMRPT = VALEUR
Read [F:DLV] First

If !fstat
  Filter [F:DLV]
  Effzo [M:DIA]ALLCPY,ALLFCY,CPY,FCY
  If [F:DLV]CPY <> "" : [M:DIA]ALLCPY=1 :  [M:DIA]CPY=[F:DLV]CPY : Endif
  If [F:DLV]FCY <> "" : [M:DIA]ALLFCY=1 :  [M:DIA]FCY=[F:DLV]FCY : Endif
  [M:DIA]STRDAT = [F:DLV]STRDAT
  [M:DIA]ENDDAT = [F:DLV]ENDDAT
  Grizo [M:DIA]ALLCPY, ALLFCY,STRDAT,ENDDAT
  Affzo [M:DIA]
Else
  [V]GMESSAGE = mess(00023,00100,1) : mkstat=2
Endif
End
