#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : GLE
# LE          : 09 Décembre  2014 10:41:38
# Moulinette pour initialiser le nouveau champ FASDSPLIN de la table TABPIVTYP à 1
# FQ96016
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIIMM040: FASDSPLIN init") From LECFIC
  Call EXE_UTIIMM040(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
 Subprog EXE_UTIIMM040(APPLI)
 Value Char APPLI
  If clalev([F:TPV]) : Close Local File [TPV] : Endif
  Local File =APPLI+".TABPIVTYP" [TPV]
  Call ECR_TRACE("UTIIMM040: Process Start on : "+APPLI,0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM040
  Call ECR_TRACE("UTIIMM040: Process End on : "+APPLI,0) From GESECRAN
 End

########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTIIMM040
  Trbegin [TPV]

  Update [TPV] Where (COD<>"PIHI" and COD<>"PIHI3") With FASDSPLIN = 1
  Update [TPV] Where (COD="PIHI"  or  COD="PIHI3")  With FASDSPLIN = 2

  If !GOK Then
    Goto AB_UTIIMM040
  Else
    Commit
  Endif
Return

$AB_UTIIMM040
 Rollback
Return

########################################
#### Corps de la moulinette - fin ######
########################################

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","TABPIVTYP","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM040(APPLI)
End

#**
#* Pour exécution depuis dosmajx (validation dossier)
#* @param APPLI  Dossier à traiter
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","TABPIVTYP","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM040(APPLI)
End
