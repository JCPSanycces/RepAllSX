####################################################################
# Traitments
####################################################################
$_ADDTRT
this.AINF.TRT(1) = "WMCM_EMPLOID"
this.AINF.TYP(1) = 1
this.AINF.PTH(1) = ""
this.AINF.TRT(2) = "EMPLOID_CSTD"
this.AINF.TYP(2) = 1
this.AINF.PTH(2) = ""
this.AINF.NBTRT = 2
Return

####################################################################
#Declaration of variables
####################################################################

$DECLARE_VAR
Local Char    ACTION(50) , CURPRO(250) , VALPRO(250) , CURQRY(50) , CURPTH(250)
Local Char    AMETHOD(50) ,AOPERATION(50),AEVENT(50),ARULE(50)
Local Integer ALLSTAT,AISMET,ASTATUS
Return


####################################################################
# Global methods & standards
####################################################################
$AINIT
Gosub DECLARE_VAR
[L]AEVENT = "AINIT" : [L]ACTION = "AINIT" : [L]CURPRO = "" : Gosub ACTION From ASYRSUB
Return

####################################################################
# AERRORS
####################################################################

$_AERROR
Gosub DECLARE_VAR From WMC0EMPLOID
Local Integer ALLSTAT
Call ALLERRORS(this,_CTX,_SUPP) From ASYRSUB
For AINDCLA=1 To 3
 If this.PERCNT(AINDCLA)<>null
  [L]ASTATUS = fmet this.PERCNT(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
If this.EMPLOIDSA<>null
 [L]ASTATUS = fmet this.EMPLOIDSA._AERROR(_CTX,_SUPP)
Endif
If this.EMPLOIDUKI<>null
 [L]ASTATUS = fmet this.EMPLOIDUKI._AERROR(_CTX,_SUPP)
Endif
For AINDCLA=1 To maxtab(this.EMPLOCHD)
 If this.EMPLOCHD(AINDCLA)<>null
  [L]ASTATUS = fmet this.EMPLOCHD(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EMPLOJNT)
 If this.EMPLOJNT(AINDCLA)<>null
  [L]ASTATUS = fmet this.EMPLOJNT(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
For AINDCLA=1 To 3
 If this.PASDET(AINDCLA)<>null
  [L]ASTATUS = fmet this.PASDET(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EMPLOEXM)
 If this.EMPLOEXM(AINDCLA)<>null
  [L]ASTATUS = fmet this.EMPLOEXM(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EMPLOTRY)
 If this.EMPLOTRY(AINDCLA)<>null
  [L]ASTATUS = fmet this.EMPLOTRY(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EMPLORIB)
 If this.EMPLORIB(AINDCLA)<>null
  [L]ASTATUS = fmet this.EMPLORIB(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
Return

####################################################################
# Delete all errors
####################################################################

$_ADELERRORS
Gosub DECLARE_VAR From WMC0EMPLOID
Local Integer ALLSTAT
[L]ASTATUS = fmet this.ADELETEERROR([L]_APARAM)
For AINDCLA=1 To 3
 If this.PERCNT(AINDCLA)<>null
  [L]ASTATUS = fmet this.PERCNT(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
If this.EMPLOIDSA<>null
 [L]ASTATUS = fmet this.EMPLOIDSA._ADELERRORS(_APARAM)
Endif
If this.EMPLOIDUKI<>null
 [L]ASTATUS = fmet this.EMPLOIDUKI._ADELERRORS(_APARAM)
Endif
For AINDCLA=1 To maxtab(this.EMPLOCHD)
 If this.EMPLOCHD(AINDCLA)<>null
  [L]ASTATUS = fmet this.EMPLOCHD(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EMPLOJNT)
 If this.EMPLOJNT(AINDCLA)<>null
  [L]ASTATUS = fmet this.EMPLOJNT(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
For AINDCLA=1 To 3
 If this.PASDET(AINDCLA)<>null
  [L]ASTATUS = fmet this.PASDET(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EMPLOEXM)
 If this.EMPLOEXM(AINDCLA)<>null
  [L]ASTATUS = fmet this.EMPLOEXM(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EMPLOTRY)
 If this.EMPLOTRY(AINDCLA)<>null
  [L]ASTATUS = fmet this.EMPLOTRY(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EMPLORIB)
 If this.EMPLORIB(AINDCLA)<>null
  [L]ASTATUS = fmet this.EMPLORIB(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
Return

####################################################################
# _ASEARCHINFOS
####################################################################

$_ASEARCHINFOS
Gosub DECLARE_VAR From WMC0EMPLOID
ASTATUS= func ASYRSUB.ASEARCHINFOS(this,[L]AINS_ORI,[L]ERR_TYPE,[L]PROPERTY,[L]ASTAT,[L]SELSTAT,[L]PATH)
If [L]ERR_TYPE=[V]CST_ACURRENT : Return : Endif
For AINDCLA=1 To 3
 If this.PERCNT(AINDCLA)<>null
  [L]ASTATUS = fmet this.PERCNT(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'PERCNT('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
If this.EMPLOIDSA<>null
 [L]ASTATUS = fmet this.EMPLOIDSA._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'EMPLOIDSA')
Endif
If this.EMPLOIDUKI<>null
 [L]ASTATUS = fmet this.EMPLOIDUKI._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'EMPLOIDUKI')
Endif
For AINDCLA=1 To maxtab(this.EMPLOCHD)
 If this.EMPLOCHD(AINDCLA)<>null
  [L]ASTATUS = fmet this.EMPLOCHD(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'EMPLOCHD('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EMPLOJNT)
 If this.EMPLOJNT(AINDCLA)<>null
  [L]ASTATUS = fmet this.EMPLOJNT(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'EMPLOJNT('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
For AINDCLA=1 To 3
 If this.PASDET(AINDCLA)<>null
  [L]ASTATUS = fmet this.PASDET(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'PASDET('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EMPLOEXM)
 If this.EMPLOEXM(AINDCLA)<>null
  [L]ASTATUS = fmet this.EMPLOEXM(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'EMPLOEXM('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EMPLOTRY)
 If this.EMPLOTRY(AINDCLA)<>null
  [L]ASTATUS = fmet this.EMPLOTRY(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'EMPLOTRY('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EMPLORIB)
 If this.EMPLORIB(AINDCLA)<>null
  [L]ASTATUS = fmet this.EMPLORIB(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'EMPLORIB('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
Return

####################################################################
# AGETERRORSFROM
####################################################################

$_AGETERRORSFROM
Gosub DECLARE_VAR From WMC0EMPLOID
If AINS_FROM<>null
 [L]ASTATUS = fmet AINS_FROM.ASEARCHINFOS( [V]CST_ALL, "", [V]CST_AFATAL, 0)
Endif
Call AGETERRORSFROM(AINS_FROM,this,ENVIRONNEMENT) From ASYRSUB
Return

####################################################################
$ACONTROL
####################################################################
Gosub DECLARE_VAR
[L]AEVENT = "ACONTROL" : [L]ACTION = "ACONTROL" : [L]CURPRO = "" : Gosub ACTION From ASYRSUB
Return

####################################################################
# ADELLINE
####################################################################
$ADELLINE
Case _ACOLLECTION
 When "EMPLOCHD"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"EMPLOCHD",this)
 When "EMPLOEXM"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"EMPLOEXM",this)
 When "EMPLOIDSA"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"EMPLOIDSA",this)
 When "EMPLOIDUKI"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"EMPLOIDUKI",this)
 When "EMPLOJNT"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"EMPLOJNT",this)
 When "EMPLORIB"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"EMPLORIB",this)
 When "EMPLOTRY"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"EMPLOTRY",this)
 When "PASDET"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"PASDET",this)
 When "PERCNT"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"PERCNT",this)
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# ADDLINE
####################################################################
$ADDLINE
Case _ACOLLECTION
 When "EMPLOCHD"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"EMPLOCHD","C_EMPLOCHD",this)
 When "EMPLOEXM"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"EMPLOEXM","C_EMPLOEXM",this)
 When "EMPLOIDSA"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"EMPLOIDSA","C_EMPLOIDSA",this)
 When "EMPLOIDUKI"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"EMPLOIDUKI","C_EMPLOIDUKI",this)
 When "EMPLOJNT"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"EMPLOJNT","C_EMPLOJNT",this)
 When "EMPLORIB"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"EMPLORIB","C_EMPLORIB",this)
 When "EMPLOTRY"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"EMPLOTRY","C_EMPLOTRY",this)
 When "PASDET"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"PASDET","C_EMPLOID_PASDET",this)
 When "PERCNT"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"PERCNT","C_EMPLOID_PERCNT",this)
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# AGETDIM
####################################################################
$AGETDIM
Case _ACOLLECTION
 When "EMPLOCHD"
  [L]_ALINE = 0
 When "EMPLOEXM"
  [L]_ALINE = 0
 When "EMPLOIDSA"
  [L]_ALINE = 1
 When "EMPLOIDUKI"
  [L]_ALINE = 1
 When "EMPLOJNT"
  [L]_ALINE = 0
 When "EMPLORIB"
  [L]_ALINE = 0
 When "EMPLOTRY"
  [L]_ALINE = 0
 When "PASDET"
  [L]_ALINE = 3
 When "PERCNT"
  [L]_ALINE = 3
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# AGETMIN
####################################################################
$AGETMIN
Case _ACOLLECTION
 When "EMPLOCHD"
  [L]_ALINE = 1
 When "EMPLOEXM"
  [L]_ALINE = 1
 When "EMPLOIDSA"
  [L]_ALINE = 1
 When "EMPLOIDUKI"
  [L]_ALINE = 1
 When "EMPLOJNT"
  [L]_ALINE = 1
 When "EMPLORIB"
  [L]_ALINE = 1
 When "EMPLOTRY"
  [L]_ALINE = 1
 When "PASDET"
  [L]_ALINE = 1
 When "PERCNT"
  [L]_ALINE = 1
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# _ALOAD_KEYS
####################################################################
$_ALOAD_KEYS
this.AKEYS(1) = "REFNUM"
Return

