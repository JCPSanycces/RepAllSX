#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional RSA fields
# Supervisor
## CRUD-CLASSE ## EMPLOIDSA
# 2018-11-06 07:05:54 471


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File EMPLOIDSA [ESA_]

If !SILENCE : Call TRACE("2 --> Local Instance C_EMPLOIDSA") From ASYRCOM : Endif
Local Instance EMPLOIDSA Using C_EMPLOIDSA

If !SILENCE : Call TRACE("3 --> New Instance C_EMPLOIDSA") From ASYRCOM : Endif
EMPLOIDSA = NewInstance C_EMPLOIDSA AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [ESA_]ESA0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of EMPLOIDSA") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.AREAD([ESA_]REFNUM))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("EMPLOIDSA.REFNUM ="-num$(EMPLOIDSA.REFNUM)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(EMPLOIDSA.AKEYS)
  Call TRACE("-"-num$(I)-":"-EMPLOIDSA.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [ESA_]
FreeGroup EMPLOIDSA
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(EMPLOIDSA,ACLE,ASTATUS,_ETAG)
Variable Instance EMPLOIDSA Using C_EMPLOIDSA
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _REFNUM(15)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
Raz [L]_ETAG
Local File EMPLOIDSA [ESA]
Default File [F:ESA]
Read [F:ESA]ESA0 = [L]_REFNUM
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:ESA]UPDTICK)>0
 [L]_ETAG = num$([F:ESA]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(EMPLOIDSA,ACLE,ASTATUS)
Variable Instance EMPLOIDSA Using C_EMPLOIDSA
Value Char ACLE
Variable Integer ASTATUS
Local Char _REFNUM(15)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.AREAD([L]_REFNUM))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(EMPLOIDSA,_REFNUM,ASTATUS)
Variable Instance EMPLOIDSA Using C_EMPLOIDSA
Value Char _REFNUM
Variable Integer ASTATUS

If EMPLOIDSA = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOIDSA
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If EMPLOIDSA.APARENT=null
 [L]A_I = EMPLOIDSA.freeSnapshot
 EMPLOIDSA.snapshotEnabled = 0
 EMPLOIDSA.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & EMPLOIDSA.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If EMPLOIDSA.APARENT=null
 EMPLOIDSA.snapshotEnabled = 1
 EMPLOIDSA.setAccessorEnabled = 1
Endif
LogicClose File [ESA]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA._ACTION_PARAM("AREAD_BEFORE",[L]_REFNUM))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:ESA]
Read [F:ESA]ESA0 = [L]_REFNUM
If fstat
[L]A_ERROR = [L]_REFNUM
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(EMPLOIDSA,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:ESA]AUUID)>0 & [F:ESA]AUUID=NullUuid
 [F:ESA]AUUID = getUuid
Endif
SetInstance EMPLOIDSA With [F:ESA]
EMPLOIDSA.ASTALIN = [V]CST_ALL

[L]A_NEWCOL = 0
For [L]A_I=1 To 3
 If ([F:ESA]ADDPRI([L]A_I-1)<>0 or [F:ESA]ADDTYP([L]A_I-1)<>0 or [F:ESA]ADDSRVTYP([L]A_I-1)<>0 or [F:ESA]ADDPOSOTH([L]A_I-1)<>""
& or [F:ESA]ADDPOSNUM([L]A_I-1)<>"" or [F:ESA]ADDPOSNAM([L]A_I-1)<>"" or [F:ESA]ADDPOSAGN([L]A_I-1)<>""
& or [F:ESA]ADDPOSCOF([L]A_I-1)<>0 or [F:ESA]ADDPOSINM([L]A_I-1)<>"" or [F:ESA]ADDCPX([L]A_I-1)<>"" or [F:ESA]ADDSTRNUM([L]A_I-1)<>""
& or [F:ESA]ADDSTRNAM([L]A_I-1)<>"" or [F:ESA]ADDSUB([L]A_I-1)<>"" or [F:ESA]ADDTWN([L]A_I-1)<>"" or [F:ESA]ADDPOSCDE([L]A_I-1)<>""
& or [F:ESA]ADDCNTCDE([L]A_I-1)<>"" or [F:ESA]ADDPRV([L]A_I-1)<>"" or [F:ESA]ADDCOR([L]A_I-1)<>0 or [F:ESA]ADDSTA([L]A_I-1)<>0)
  [L]A_NEWCOL += 1
  EMPLOIDSA.EMPADR(A_NEWCOL) = NewInstance  C_EMPLOIDSA_EMPADR(EMPLOIDSA.ACTX,NullUuid,[L]A_I,EMPLOIDSA,"EMPADR") AllocGroup EMPLOIDSA
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDPRI = [F:ESA]ADDPRI([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDTYP = [F:ESA]ADDTYP([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDSRVTYP = [F:ESA]ADDSRVTYP([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDPOSOTH = [F:ESA]ADDPOSOTH([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDPOSNUM = [F:ESA]ADDPOSNUM([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDPOSNAM = [F:ESA]ADDPOSNAM([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDPOSAGN = [F:ESA]ADDPOSAGN([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDPOSCOF = [F:ESA]ADDPOSCOF([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDPOSINM = [F:ESA]ADDPOSINM([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDCPX = [F:ESA]ADDCPX([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDSTRNUM = [F:ESA]ADDSTRNUM([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDSTRNAM = [F:ESA]ADDSTRNAM([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDSUB = [F:ESA]ADDSUB([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDTWN = [F:ESA]ADDTWN([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDPOSCDE = [F:ESA]ADDPOSCDE([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDCNTCDE = [F:ESA]ADDCNTCDE([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDPRV = [F:ESA]ADDPRV([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDCOR = [F:ESA]ADDCOR([L]A_I-1)
  EMPLOIDSA.EMPADR(A_NEWCOL).ADDSTA = [F:ESA]ADDSTA([L]A_I-1)
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.EMPADR(A_NEWCOL).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next
[L]A_NEWCOL = 0
For [L]A_I=1 To 3
 If ([F:ESA]PASCRY([L]A_I-1)<>"" or [F:ESA]PASNUM([L]A_I-1)<>"" or [F:ESA]PASDTE([L]A_I-1)<>[00/00/0000]
& or [F:ESA]ESSUIDPAS([L]A_I-1)<>0)
  [L]A_NEWCOL += 1
  EMPLOIDSA.PASDET(A_NEWCOL) = NewInstance  C_EMPLOIDSA_PASDET(EMPLOIDSA.ACTX,NullUuid,[L]A_I,EMPLOIDSA,"PASDET") AllocGroup EMPLOIDSA
  EMPLOIDSA.PASDET(A_NEWCOL).PASCRY = [F:ESA]PASCRY([L]A_I-1)
  EMPLOIDSA.PASDET(A_NEWCOL).PASNUM = [F:ESA]PASNUM([L]A_I-1)
  EMPLOIDSA.PASDET(A_NEWCOL).PASDTE = [F:ESA]PASDTE([L]A_I-1)
  EMPLOIDSA.PASDET(A_NEWCOL).ESSUIDPAS = [F:ESA]ESSUIDPAS([L]A_I-1)
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.PASDET(A_NEWCOL).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next
[L]A_NEWCOL = 0
For [L]A_I=1 To 3
 If ([F:ESA]CNTTYP([L]A_I-1)<>0 or [F:ESA]ESSUIDCNT([L]A_I-1)<>0)
  [L]A_NEWCOL += 1
  EMPLOIDSA.PERCNT(A_NEWCOL) = NewInstance  C_EMPLOIDSA_PERCNT(EMPLOIDSA.ACTX,NullUuid,[L]A_I,EMPLOIDSA,"PERCNT") AllocGroup EMPLOIDSA
  EMPLOIDSA.PERCNT(A_NEWCOL).CNTTYP = [F:ESA]CNTTYP([L]A_I-1)
  EMPLOIDSA.PERCNT(A_NEWCOL).ESSUIDCNT = [F:ESA]ESSUIDCNT([L]A_I-1)
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.PERCNT(A_NEWCOL).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



