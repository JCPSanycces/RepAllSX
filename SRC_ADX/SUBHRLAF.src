######################################################################################
Subprog AM_NBRLIG
  If nolign > [M:LAF]NBRLIG
    nolign = [M:LAF]NBRLIG
    mkstat = 2
  Endif
End


######################################################################################
## Section automatically added (screen HRLAF) 10/16/2017 14:08:02 (PEVAN)
######################################################################################
Subprog C_TRANSDAT(VALEUR)
Variable Date    VALEUR
#JASMI - 2017-11-30 - X3-64868 - START
#  [M:LAF]TRANSDAT = VALEUR
#  Call CHARGE_BAL([M:LAF]REFNUM,[M:LAF]CTRNUM)
  Call CHARGE_BAL([M:LAF]REFNUM,[M:LAF]CTRNUM,VALEUR)
#JASMI - 2017-11-30 - X3-64868 - END
End


