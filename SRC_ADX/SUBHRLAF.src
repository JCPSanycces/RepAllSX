GUSRAUZ(1) = "123456"
GFONCTION = "GESHRLAF"
Local Char PARAM(30)(1..3) ,  VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"OHRLAF","SUBHRLAF","",5,"XWHRLAF") From GTRAITE
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "ABA"         : Gosub ABANDON
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "OK"          : Gosub OK
Endcase
Return
