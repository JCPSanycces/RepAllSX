$GET_TRANSNR
  If clalev([F:TCA])=0  : Local File TABCOUAFF [TCA]  : Endif
  Local Integer STAT
  Local Char    COMPTEUR(GLONANM)
  Read [TCA]TCA0 = 15 : # Module Human resources
  Local Char    ACC(GLONVCR)
  COMPTEUR = [F:TCA]CODNUM(24)
  Call NUMERO([L]COMPTEUR,[F:HRCTR]ETRFCY,[F:HRCTR]DATANC,[F:HRCTR]CTRNUM,[L]ACC,[L]STAT) From SUBANM
If STAT
 Call ERREUR(mess(4,10702,1)-COMPTEUR) From GESECRAN : # "Erreur sur compteur"
 GOK = 0 : End
Endif
Return
######################################################################################
Subprog CHECK_MULTCTR(VALEUR,CHOK)
Variable Char VALEUR()
Variable Integer CHOK
Local Integer CTRNO : CTRNO=0

Filter [HRCTR] Where REFNUM=VALEUR and XITDAT = [0/0/0]
#If rowcount([HRCTR])<2 Then
If rowcount([HRCTR])=1 Then
   CHOK=1
   Else If rowcount([HRCTR])=0
   CHOK=5
   Else
   CHOK=0
  Endif
Endif
Filter [HRCTR]
End
######################################################################################

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Integer CHOK
CHOK=0
#Call CHECK_MULTCTR(VALEUR,CHOK)
If CHOK =5 :GMESSAGE=mess(158,10702,1) : mkstat=2 :End:Endif
If GSET = 0 Then
  Actzo [M:LAF]NBRLIG
Endif
End


