Subprog LOCK_CELL(CLOCK)
Variable Integer CLOCK
CLOCK = 0
If [M]LVEACCTIM(nolign-1) = "" | [M]LVEACCLST(nolign-1) = "" Then
 Effzo [M]LVETIMDES(nolign-1)
 Effzo [M]LVEACCLST(nolign-1)
 CLOCK = 1
Endif
End

Subprog C_LVEADJ(VALEUR)
Variable Decimal VALEUR
Local Integer CLOCK
#LIPET - X3-54807 - 2017-09-06 - START
#If VALEUR = 0 and VALEUR = -0 :GERR=1:GMESSAGE=mess(14,11691,1) :mkstat=2:Endif
#If VALEUR = -0 :GERR=1:GMESSAGE=mess(14,11691,1) :mkstat=2:Endif
#LIPET - X3-54807 - 2017-09-06 - END
Call LOCK_CELL(CLOCK)
If CLOCK = 1 : mkstat=2:End:Endif
End

Subprog C_LVECLBAL(VALEUR)
Variable Decimal VALEUR
#LIPET - X3-54807 - 2017-09-06 - START
#If VALEUR = 0 and VALEUR = -0 :GERR=1:GMESSAGE=mess(14,11691,1)  :mkstat=2:Endif
#If VALEUR = -0 :GERR=1:GMESSAGE=mess(14,11691,1)  :mkstat=2:Endif
#LIPET - X3-54807 - 2017-09-06 - END
Local Integer CLOCK
Call LOCK_CELL(CLOCK)
If CLOCK = 1 : mkstat=2:End:Endif
End

