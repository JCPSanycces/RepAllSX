$OK
 Gosub WRITE_ADJ
Return

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Integer NUM,CHKOK
NUM=0
#Call CHECK_MULTCTR(VALEUR,NUM)

Read [ID]ID0 = VALEUR
[M:LAF]NAM = [F:ID]NAM
[M:LAF]FNAME = [F:ID]SRN
Affzo [M:LAF]NAM
Affzo [M:LAF]FNAME
Raz [M]CTRNUM

If NUM=1
   Effzo CTRNUM
   Diszo CTRNUM
   Affzo CTRNUM
   Affzo LEG
  Else If NUM=0
   Actzo CTRNUM
   Affzo CTRNUM
   Effzo LEG
   Affzo [M]5
   Effzo [M]10
  Endif
Endif
If NUM=1 Then
    Filter [HRCTR] Where REFNUM=VALEUR
    Read[HRCTR]CTR1 Last
    Filter [HRCTR]
    If !fstat
     [M]FCY= [F:HRCTR]ETRFCY
     [M]SRV= [F:HRCTR]ETRSRV
     [M]CTRNUM = [F:HRCTR]CTRNUM
     Call GET_LEG([M]CTRNUM,[M]LEG)
     Call CHARGE_LAST_ACC_DAT([M]CTRNUM,CHKOK,[M]LDATACC)
     If CHKOK=1 : mkstat=2 : End : Endif
#     Call CHARGE_BAL(VALEUR,[M]CTRNUM)
    Endif
    Affzo FCY, SRV,CTRNUM
  Else If NUM=0
    Filter [HRCTR] Where REFNUM=VALEUR
    Read [HRCTR]CTR1 Last
    Filter [HRCTR]
    If !fstat
     [M]FCY    = [F:HRCTR]ETRFCY
     [M]SRV    = [F:HRCTR]ETRSRV
    Endif
    Affzo FCY, SRV
  Endif
Endif
Raz GSET
Affzo [M:LAF]NBRLIG
Affzo [M]LEG,LVEADJ
Affzo [M]5
End


Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Integer CHKOK
  Call GET_LEG(VALEUR,[M]LEG)
  Call CHARGE_LAST_ACC_DAT(VALEUR, CHKOK,[M]LDATACC)
  If CHKOK=1 : mkstat=2 : End : Endif
#  Call CHARGE_BAL([M]REFNUM,VALEUR)
  Affzo [M]5
  Affzo [M]LVEADJ
End
##############################################
$OUVRE
#PEVAN - 2018-09-27 - X3-109636 - START
  Call KILL_GLM_GLOBALS From SUBHRBAL
#PEVAN - 2018-09-27 - X3-109636 - END
Local Mask HRLAF [LAF]
Case GACTION
 When "HRLAF" : GFONCTION = "GESHRLAF"
Endcase

If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR]  : Endif
If clalev([F:ID])=0  : Local File EMPLOID [ID]  : Endif
If clalev([F:HRACCR])=0  : Local File HRLVEACCRU [HRACCR]  : Endif
If !clalev([TIM]) : Local File TIMCOD [TIM] Endif
Raz [LAF]
Global Integer GSET : GSET = 0

TIT = "Leave balance adjustment"
Return
##############################################
$SETBOUT

If GREP="M"
 CHBOU = "AO"
 STADEF = GSTAENR
Else If GREP="T"
 CHBOU = "A"
Else
 CHBOU = "09"
 CHBOU = "<>"
 STADEF = GSTAENR
Endif
Endif
Gosub SET_BOUT_STD From GSAISIE
Gosub SET_BOUT_SPE From GSAISIE
Return

############################################
$ABANDON
GREP = "" : REP = ""
Effzo [LAF]
Return

###########################################
Subprog GET_LEG(VALEUR,FLD)
Variable Char    VALEUR()
Variable Char FLD
If clalev([F:HRCTR2])=0 : Local File EMPLOCTR [HRCTR2] : Endif
If clalev([F:FCY2])=0 : Local File FACILITY [FCY2]  : Endif

If VALEUR<>""
  Filter  [HRCTR2] Where CTRNUM=VALEUR
   Read [HRCTR2] Last
   Filter [HRCTR2]
   Read [FCY2]FCY0 = [F:HRCTR2]ETRFCY
   If !fstat
    GCURLEG = [F:FCY2]LEG
    FLD  = GCURLEG
    #Affzo [M]LEG
   Endif
Endif
End
###########################################

Subprog CHARGE_LAST_ACC_DAT(VALEUR, CHKOK,FLD)
Variable Char    VALEUR()
Variable Integer CHKOK
Variable Date FLD
## PEVAN 2017-09-01 X3-54279 START
#Filter [HRACCR] Where CTR = VALEUR
Filter [HRACCR] Where CTR = VALEUR and [HRACCR]LVEACCAMT <> "0" Order By [HRACCR]LVEACCDAT
## PEVAN 2017-09-01 X3-54279 END
Read [HRACCR] Last
Filter [HRACCR]
If !fstat
  FLD = [F:HRACCR]LVEACCDAT
  #Else
  #GERR = 1 : GMESSAGE = "No accrual date available for this employee" : CHKOK=1
  #End
Endif
#Affzo FLD
End

###########################################
$CALC_ADJ
Local Decimal CLBAL
CLBAL = 0
If VALEUR <> 0 Then
 CLBAL = arr(VALEUR, 0.0001) - arr([M]LVEBALDAYS(nolign-1), 0.0001)
Else
 CLBAL = [M]LVEADJ(nolign-1)
Endif
[M]LVEADJ(nolign-1) = CLBAL
Affzo [M]LVEADJ
Return
###########################################

$CALC_CL_BAL
Local Decimal CLBAL
CLBAL = 0
If VALEUR <> 0 Then
  CLBAL = arr([M]LVEBALDAYS(nolign-1), 0.0001) + arr(VALEUR, 0.0001)
Else
 CLBAL = [M]LVECLBAL(nolign-1)
Endif
[M]LVECLBAL(nolign-1) = CLBAL
Affzo [M]LVECLBAL
Return
###########################################
Subprog CHARGE_BAL(REFNUM,CTRNUM,THISTRANSDATE)
Value Char REFNUM()
Value Char CTRNUM()
Value Date THISTRANSDATE

  Global Char CARFUTBALS(GLONHRLST)(0..,0..10)

  If THISTRANSDATE <> [0/0/0]

    If !clalev([F:HRCTRR]) : Local File EMPLOCTR [F:HRCTRR] : Endif
    Local Char VCTRNUM(250) : VCTRNUM = CTRNUM
    Filter [F:HRCTRR] Where [F:HRCTRR]CTRNUM = VCTRNUM Order By [F:HRCTRR]CTRDAT
    If rowcount([F:HRCTRR]) > 1
      Local Date STRDATE
      For [F:HRCTRR]
        If [F:HRCTRR]CTRDAT <= THISTRANSDATE and ([F:HRCTRR]XITDAT = [0/0/0] or [F:HRCTRR]XITDAT >= THISTRANSDATE)
          STRDATE = [F:HRCTRR]CTRDAT
          If !clalev([F:HRCTRRR]) : Local File EMPLOCTR [F:HRCTRRR] : Endif
          Filter [F:HRCTRRR] Where [F:HRCTRRR]CTRNUM = VCTRNUM and [F:HRCTRRR]CTRDAT > STRDATE
          If rowcount([F:HRCTRRR]) > 0
            mkstat = 2
            Filter [F:HRCTRRR]
            [M:LAF]NBRLIG = 0
            Affzo [M:LAF]10
            End
          Endif
          Filter [F:HRCTRRR]
        Endif
      Next
    Endif
    Filter [F:HRCTRR]

    Local Char PREVLST(50)
    Local Integer M, N,L, FOUND, ROW, ALLN, LOOPM, VALIDROWS
    Local Decimal AMOUNT
    Local Char FINALVALS(100)(0..,0..9)
    Local Char FINALSUBTYPES(250)(0..,0..9)
    Local Char ALLSUBTYPES(100)(0..,0..9)
    Local Char ALLSUBTYPESFOUND(100)(0..)
    Local Char LVESTARR(100)(0..)
    Local Char ALLNATURES(100)(0..)
    Local Decimal  BALANCE, ACCRUAL, TAKENINCYCLE, TOTALTAKENINCYCLE
    Local Date QUERYDATE
    M = 0: N = 0: L = 0: ALLN = 0: LOOPM = 0: VALIDROWS = 0:
    nolign=0

    If !clalev([F:HRLSTH]): Local File HRLVESUBHEA [HRLSTH]: Endif
    If !clalev([F:TIM])   : Local File TIMCOD [TIM]        : Endif
    If !clalev([F:ACCRU]) : Local File HRLVEACCRU [ACCRU]  : Endif

    Call GET_LEAVE_SUB_TYPES(CTRNUM, THISTRANSDATE, "", FINALSUBTYPES) From SUBHRBAL

    For ROW = 0 To maxtab(FINALSUBTYPES)

      BALANCE = 0
      ACCRUAL = 0
      TAKENINCYCLE = 0
      Local Date STARTDATE, ENDDATE

      QUERYDATE = THISTRANSDATE
      Call GET_CYCLE_START_DATE_EXTRACTION (CTRNUM, FINALSUBTYPES(ROW, 1), QUERYDATE, STARTDATE, ENDDATE, 0, GCURLEG) From SUBHRBAL
      If STARTDATE <> [0/0/0]
        Filter [ACCRU] Where [ACCRU]CTR = CTRNUM and [ACCRU]LVEACCLST = FINALSUBTYPES(ROW,1) and [ACCRU]LVEACCTYP = "Accrual"  Order By [ACCRU]LVEACCDAT
        Read [ACCRU] Last
        If fstat = 0
          If [ACCRU]LVEACCDAT < THISTRANSDATE
            GOFURBALLS = 1
          Else
            GOFURBALLS = 2
          Endif
        Else
          GOFURBALLS = 1
        Endif
        Filter [ACCRU]

        If (GOFURBALLS = 2)
          Call GET_BALANCE(CTRNUM, FINALSUBTYPES(ROW, 1), THISTRANSDATE, BALANCE, ACCRUAL, TAKENINCYCLE, 0, GCURLEG) From SUBHRBAL
        Else
          Local Char FUTBALS(250)(0..,0..10)
          #PEVAN - 2018-06-14 - X3-93568 - START
          #Call GET_BALANCE_FCST(CTRNUM, FINALSUBTYPES(ROW,3), FINALSUBTYPES(ROW,1), THISTRANSDATE, FUTBALS, BALANCE, ACCRUAL, TOTALTAKENINCYCLE, 0, [0/0/0], [0/0/0], GCURLEG) From SUBHRBAL
          Local Char CARFUTBALS(GLONHRLST)(0..,0..10)
          Call GET_BALANCE_FCST(CTRNUM, FINALSUBTYPES(ROW,3), FINALSUBTYPES(ROW,1), THISTRANSDATE, FUTBALS, BALANCE, ACCRUAL, TOTALTAKENINCYCLE, 0, [0/0/0], [0/0/0], GCURLEG, CARFUTBALS) From SUBHRBAL
          #PEVAN - 2018-06-14 - X3-93568 - END
        Endif
        [M]LVEACCTIM(VALIDROWS) = FINALSUBTYPES(ROW,3)
        Call LECTEXTRA([M]LVETIMDES(VALIDROWS),"TIMCOD","DES",GCURLEG,FINALSUBTYPES(ROW,3)) From ATEXTRA
        [M]LVEACCLST(VALIDROWS) = FINALSUBTYPES(ROW, 1)
        Call LECTEXTRA([M]LVELSTDES(VALIDROWS),"HRLVESUBHEA","DES",GCURLEG,FINALSUBTYPES(ROW, 1)) From ATEXTRA
        [M]LVEBALDAYS(VALIDROWS) = arr(BALANCE, 0.0001)
        VALIDROWS += 1
      Endif
    Next
    [M]NBRLIG=VALIDROWS
    Affzo [M:LAF]
  Endif
End

$WRITE_ADJ

  If !clalev([F:HRLSTH]) : Local File HRLVESUBHEA [HRLSTH] : Endif
  If !clalev([F:HRCTR])  : Local File EMPLOCTR [HRCTR]     : Endif
  Local Date CTRDAT

  If !GSERVEUR
   Call OUVRE_TRACE(TIT) From LECFIC
  Endif
  Call ECR_TRACE(TIT,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

## PEVAN - 2018-06-01 - X3-92881 - START
  Filter [F:HRCTR] Where [F:HRCTR]CTRNUM=[M:LAF]CTRNUM and [F:HRCTR]CTRDAT <= [M:LAF]TRANSDAT and ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=[M:LAF]TRANSDAT)
  Read [F:HRCTR] First
  If !fstat
    CTRDAT = [F:HRCTR]CTRDAT
  Endif
## PEVAN - 2018-06-01 - X3-92881 - END

  For nolign=1 To [M:LAF]NBRLIG

    If [M]LVEADJ (nolign-1) <> 0 Then
## PEVAN - 2017-10-16 - X3-59895 - START
      Local Date TRANSACTION_DATE, CYCLE_START_DATE, CYCLE_END_DATE
### PEVAN 2017-09-08 X3-54990 START
#    Filter [HRLSTH] Where [HRLSTH]COD = [M]LVEACCLST(nolign-1)
#    Read [HRLSTH] First
#    If fstat = 0
#      If [HRLSTH]LVEACCOPT = 3 | [HRLSTH]LVEACCOPT = 4 | [HRLSTH]LVEACCOPT = 5 #Use the last accrual date
#        Filter [HRACCR] Where CTR = [M]CTRNUM and [HRACCR]LVEACCAMT <> "0" Order By [HRACCR]LVEACCDAT
#        Read [HRACCR] Last
#        Filter [HRACCR]
#        If fstat = 0
#          TRANSACTION_DATE = [HRACCR]LVEACCDAT
#        Else
#          TRANSACTION_DATE = datesyst
#        Endif
#      Else
#        TRANSACTION_DATE = datesyst
#      Endif
#    Endif
### PEVAN 2017-09-08 X3-54990 END
#PEVAN - 2017-10-23 - X3-60670 - START
      Trbegin HRLVEACCRU [HRACCR]
#PEVAN - 2017-10-23 - X3-60670 - END
      TRANSACTION_DATE = [M:LAF]TRANSDAT
#MIPEA 2018-02-21 X3-74480 - START
#PEVAN - 2018-07-30 - X3-90320 - START
#      Call DELETE_FUTURE_ACCRUALS([M:LAF]CTRNUM, TRANSACTION_DATE, [M]LVEACCTIM(nolign-1), 0, GCURLEG) From SUBDCGGLM
      Call DELETE_FUTURE_ACCRUALS([M:LAF]CTRNUM, [0/0/0], TRANSACTION_DATE, [M]LVEACCTIM(nolign-1), 0, GCURLEG) From SUBDCGGLM
#PEVAN - 2018-07-30 - X3-90320 - END
      Call GET_CYCLE_START_DATE_EXTRACTION([M:LAF]CTRNUM, [M]LVEACCLST(nolign-1), TRANSACTION_DATE, CYCLE_START_DATE, CYCLE_END_DATE, 0, GCURLEG) From SUBHRBAL
#      Call DELETE_FUTURE_ACCRUALS([M:LAF]CTRNUM, TRANSACTION_DATE, [M]LVEACCTIM(nolign-1)) From SUBDCGGLM
#      Call GET_CYCLE_START_DATE_EXTRACTION([M:LAF]CTRNUM, [M]LVEACCLST(nolign-1), TRANSACTION_DATE, CYCLE_START_DATE, CYCLE_END_DATE) From SUBHRBAL
      #MIPEA 2018-02-21 X3-74480 - END
## PEVAN - 2017-10-16 - X3-59895 - END
      #FRLAA X3-104022 2018-08-29 - START
      Local Char    ACC(GLONVCR)
      [L]ACC = func SUBDCG.GET_GLM_UNILVENUM([F:HRCTR]REFNUM)
      #Gosub GET_TRANSNR
      #FRLAA X3-104022 2018-08-29 - END
      [F:HRACCR]LVEACCTRS        = [L]ACC
      [F:HRACCR]CTR              = [M]CTRNUM
      [F:HRACCR]LVEACCLST        = [M]LVEACCLST(nolign-1)
      [F:HRACCR]LVEACCTIM        = [M]LVEACCTIM(nolign-1)
      [F:HRACCR]LVEACCAMT        = num$([M]LVEADJ (nolign-1))
      [F:HRACCR]SYSDAT           = datesyst
      [F:HRACCR]LVEACCTYP        = mess(417,198,1)
      [F:HRACCR]LVEACCDAT        = TRANSACTION_DATE
## PEVAN - 2018-06-01 - X3-92881 - START
      [F:HRACCR]CTRDAT           = CTRDAT
## PEVAN - 2018-06-01 - X3-92881 - EMD
## PEVAN - 2018-04-25 - X3-88013 - START
      [F:HRACCR]REFNUM           = [M]REFNUM
## PEVAN - 2018-04-25 - X3-88013 - END
## PEVAN - 2017-10-16 - X3-59895 - START
      [F:HRACCR]LVEACCEXP        = CYCLE_END_DATE
## PEVAN - 2017-10-16 - X3-59895 - END
      Write [HRACCR]
#PEVAN - 2017-10-23 - X3-60670 - START
      Commit
#PEVAN - 2017-10-23 - X3-60670 - END
      Call ECR_TRACE("Leave sub type " - [M]LVEACCLST(nolign-1) - " has been adjusted with "- num$([M]LVEADJ (nolign-1))-" day(s)" ,0) From GESECRAN
      If fstat<>0
        GOK = 0 : Call FSTA("HRACCR") From GLOCK : Gosub AB_TR1
      Endif
    Endif
  Next
  Call FERME_BOITE From GESECRAN

  #Closing the trace file with a message
  If !GSERVEUR
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE From LECFIC #Displaying Log file
  Endif
 #SAVAN - 2018/02/01 - X3-74664 - After Delete of future accruals is done and adjustment made - Re-Accru  start
    Local Char FUTBALS(250)(0..,0..10),CRITHRLST(250),CRITHRCTR(250),CRITHRTIM(250)
    CRITHRLST="1=0 | ([F:HRCTR]CTRNUM = '"+[M]CTRNUM+"')"
#MIPEA 2018-02-21 X3-74480 - START
    Local Char LVE_ERRMESSAGE(250)
    Local Integer LVE_GOK
    Call LVE_ENG(CRITHRTIM,CRITHRLST,CRITHRCTR,"","","",[0/0/0],FUTBALS,0,LVE_ERRMESSAGE,LVE_GOK,[0/0/0],[0/0/0],0) From SUBACCRUAL


    #Call LVE_ENG("",CRITERE,"","","","",[0/0/0],FUTBALS,0,ERRMESSAGE,ACC_GOK,[0/0/0],[0/0/0]) From SUBACCRUAL

#    Call LVE_ENG(CRITHRTIM,CRITHRLST,CRITHRCTR,"","","",[0/0/0],FUTBALS) From SUBACCRUAL
#MIPEA 2018-02-21 X3-74480 - END
  #SAVAN - 2018/02/01 - X3-74664 - After Delete of future accruals is done and adjustment made - Re-Accru  end
Return
###########################################
$AB_TR1
Rollback
Call ERREUR(mess(17,107,1)) From GESECRAN
Return
