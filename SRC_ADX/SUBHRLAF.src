Variable Decimal VALEUR
Gosub CALC_CL_BAL
GREP = "M" : REP = "M"
End

Subprog AM_LVECLBAL(VALEUR)
Variable Decimal VALEUR
Gosub CALC_ADJ
GREP = "M" : REP = "M"
End
