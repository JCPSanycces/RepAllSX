#<AdxTL>@(#)9.0.0.0 $Revision$
Local Integer NBBOUT , NBMEN
Local Char    LISBOUT(30)(1..20) , ABRBOUT(1)(1..30)
Local Char    TMEN(30)(1..20),CMEN(30)(1..20)
Local Integer NMEN(1..30)

NBBOUT = 0
NBBOUT += 1 : LISBOUT(NBBOUT) = "Enregistrer"
NBBOUT += 1 : LISBOUT(NBBOUT) = "Créer"
NBBOUT += 1 : LISBOUT(NBBOUT) = "Supprimer"
NBBOUT += 1 : LISBOUT(NBBOUT) = "Abandon"
NBBOUT += 1 : LISBOUT(NBBOUT) = "Copie"
NBBOUT += 1 : LISBOUT(NBBOUT) = "Fin"
NBMEN = 0
NBMEN += 1 : NMEN(NBMEN) = 10 : TMEN(NBMEN) = "Options"
NBMEN += 1 : NMEN(NBMEN) = 20 : TMEN(NBMEN) = "Fonctions"

Call RACCOURCI(NBBOUT,LISBOUT,ABRBOUT,NBMEN,CMEN,NMEN,TMEN)

Infbox sigma(1,NBBOUT,ABRBOUT(indcum)+" ")+"\"+sigma(1,NBMEN,TMEN(indcum)+" ")

End

########################################################
Subprog RACCOURCI(NBBOUT,LISBOUT,ABRBOUT,NBMEN,CMEN,NMEN,TMEN)
Value    Integer NBBOUT
Value    Char    LISBOUT()(1..)
Variable Char    ABRBOUT()(1..)
Value    Integer NBMEN
Value    Char    CMEN()(1..)
Value    Integer NMEN(1..)
Variable Char    TMEN()(1..)

Local Integer NBTEX
Local Integer I , J , K , JJ
Local Char    TEX(30)(1..300) , RAC(1)(1..300)
Local Integer FLRAC(1..300)
Local Char    RACCLI(20) , C(1) , ALPHABET(50)

ALPHABET = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789éèàùç"

## 1er niveau

For I=1 To NBBOUT
 TEX(I) = LISBOUT(I)
Next I
NBTEX = NBBOUT
For I=1 To NBMEN
 If mod(NMEN(I),10)=0 & CMEN(I)=""
  NBTEX += 1
  TEX(NBTEX) = TMEN(I)
 Endif
Next I
RACCLI = ""
For J=1,5,15,39,105,116,193 : # Fichier,Edition,Affichage,?,Editeur,Outil,Sélection
 K = instr(1,mess(J,9138,1),"&")
 If K
  RACCLI += toupper(mid$(mess(J,9138,1),K+1,1))
 Endif
Next J
Gosub RACC
For I=1 To NBBOUT
 ABRBOUT(I) = RAC(I)
Next I
NBTEX = NBBOUT
For I=1 To NBMEN
 If mod(NMEN(I),10)=0 & CMEN(I)=""
  NBTEX += 1
  If FLRAC(NBTEX)
   TMEN(I) = left$(TMEN(I),FLRAC(NBTEX)-1)+"&"+right$(TMEN(I),FLRAC(NBTEX))
  Endif
 Endif
Next I

## 2ème niveau

RACCLI = ""
For JJ=1 To 9
 NBTEX = 0
 For I=1 To NBMEN
  If int(NMEN(I)/10)=JJ & ((mod(NMEN(I),10)=0 & CMEN(I)<>"") | (mod(NMEN(I),10)<>0 & CMEN(I)=""))
   NBTEX += 1
   TEX(NBTEX) = TMEN(I)
  Endif
 Next I
 If NBTEX
  Gosub RACC
  NBTEX = 0
  For I=1 To NBMEN
   If int(NMEN(I)/10)=JJ & ((mod(NMEN(I),10)=0 & CMEN(I)<>"") | (mod(NMEN(I),10)<>0 & CMEN(I)=""))
    NBTEX += 1
    If FLRAC(NBTEX)
     TMEN(I) = left$(TMEN(I),FLRAC(NBTEX)-1)+"&"+right$(TMEN(I),FLRAC(NBTEX))
    Endif
   Endif
  Next I
 Endif
Next JJ

## 3ème niveau


For JJ=1 To 9
 NBTEX = 0
 For I=1 To NBMEN
  If int(NMEN(I)/10)=JJ & mod(NMEN(I),10)<>0 & CMEN(I)<>""
   NBTEX += 1
   TEX(NBTEX) = TMEN(I)
  Endif
 Next I
 If NBTEX
  Gosub RACC
  NBTEX = 0
  For I=1 To NBMEN
   If int(NMEN(I)/10)=JJ & mod(NMEN(I),10)<>0 & CMEN(I)<>""
    NBTEX += 1
    If FLRAC(NBTEX)
     TMEN(I) = left$(TMEN(I),FLRAC(NBTEX)-1)+"&"+right$(TMEN(I),FLRAC(NBTEX))
    Endif
   Endif
  Next I
 Endif
Next JJ

End

$RACC
I = 1
While I<=NBTEX

$RAC1
 FLRAC(I) = 0

 For J=1 To len(TEX(I))
  C = toupper(mid$(TEX(I),J,1))
  If !find(C,RAC(1..I-1)) & !instr(1,RACCLI,C)
   RAC(I) = C
   FLRAC(I) = J : Break
  Endif
 Next J
  
 If FLRAC(I)=0
  K = I
  While 1
   K -= 1
   If K<=0
    Break
   Else
    J = FLRAC(K)
    While J<len(TEX(K))
     J += 1
     C = toupper(mid$(TEX(K),J,1))
     If !find(C,RAC(1..K-1)) &  !instr(1,RACCLI,C)
      FLRAC(K) = J
      RAC(K) = C
      Break 2
     Endif
    Wend
   Endif
  Wend
  If K>0
   I = K+1
   Goto RAC1
  Else
   RAC(I) = ""
  Endif
 Endif

 I += 1
Wend

Raz RAC
For I=1 To NBTEX
 If FLRAC(I)
  RAC(I) = mid$(TEX(I),FLRAC(I),1)
 Else
  RAC(I) = "?"
 Endif
Next I
Return

