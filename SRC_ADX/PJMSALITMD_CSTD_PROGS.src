# PROGS
#######################################################################################
# ISSUE PJM_X3_19726_AMO_SPLDAUTO - 2016-02-08 ALMON : Build SPLD Reference for PJMTSKOPE, PJMTSKITM and PJMBUDLIG
Funprog GET_SPLD_KEYCONCAT(ACTX, SOPPNUM, SPBUCOD, STASCOD, ISEQ)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SOPPNUM
Value Char SPBUCOD
Value Char STASCOD
Value Integer ISEQ

Local Char SARENDRE(250)
  SARENDRE = SOPPNUM + "~" + SPBUCOD + "~" + STASCOD + "~" + num$(ISEQ)
End SARENDRE
# ISSUE PJM_X3_19726_AMO_SPLDAUTO - 2016-02-08 ALMON :  END
#######################################################################################
# ISSUE PJM_X3_19726_AMO_SPLDAUTO - 2016-02-08 ALMON :  Split Concatenated key into its elements
Funprog SPLD_KEY_SPLIT(ACTX, INPKEY, PROJECT, BUDGET, TASK)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char INPKEY ()
Variable Char PROJECT ()
Variable Char BUDGET ()
Variable Char TASK ()

Local Char SSEPARCODE(1)
Local Integer NI
Local Integer NE

  #SSEPARCODE = fmet ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, ACTX.AFOLDER, "SEPARCODE") ALMON only use at tech level
  SSEPARCODE = "~"
  Raz PROJECT
  Raz BUDGET
  Raz TASK
  If instr(1,INPKEY,SSEPARCODE) = 0 Then
    PROJECT = INPKEY
  Else
    NI = instr(1,INPKEY,SSEPARCODE)
    PROJECT = mid$(INPKEY,1,NI-1)
    NE = instr(NI+1,INPKEY,SSEPARCODE)
    If NE <> 0 Then
      BUDGET = mid$(INPKEY,NI+1,NE-NI-1)
      NI = instr(NE+1,INPKEY,SSEPARCODE)
      If NI <> 0 Then
        TASK = mid$(INPKEY,NE+1,NI-NE-1)
      Endif
    Endif
  Endif
End [V]CST_AOK
# ISSUE PJM_X3_19726_AMO_SPLDAUTO - 2016-02-08 ALMON :  END
#######################################################################################

