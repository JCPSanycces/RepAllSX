#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ITF10 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:00"
A_USER  = "DOC"
A_STAMP = "20181109230500"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBITF"
  If [M]NBITF=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ITF10 [ITF10]
Gosub HORODAT
Local Inpbox "ITF10" From GFONCTION At A_STAMP With A_WINDPREV Mask [ITF10] As [SIM_]
Grizo [ITF10]5
Grizo [ITF10]10
Grizo [ITF10]15
Grizo [ITF10]20
Grizo [ITF10]25
Grizo [ITF10]30
Grizo [ITF10]35
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ITF10]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=36 : Y1(0)=1 : Y2(0)=19
X1(1)=37 : X2(1)=87 : Y1(1)=1 : Y2(1)=2
X1(2)=37 : X2(2)=87 : Y1(2)=3 : Y2(2)=3
X1(3)=37 : X2(3)=87 : Y1(3)=4 : Y2(3)=4
X1(4)=37 : X2(4)=87 : Y1(4)=5 : Y2(4)=8
X1(5)=37 : X2(5)=87 : Y1(5)=9 : Y2(5)=19
X1(6)=1 : X2(6)=36 : Y1(6)=20 : Y2(6)=24
X1(7)=1 : X2(7)=-2 : Y1(7)=1 : Y2(7)=0
Return

$ON_NBITF
Onevent BEFORE_INPUT Call AS_NBITF From W1ITF10
Onevent CONTROL Call C_NBITF From W1ITF10
Onevent AFTER_LINE Call APRES_NBITF From W1ITF10
Return

Subprog AS_NBITF
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBITF From SUBITF
Gosub _AFF
End

Subprog C_NBITF
Local Decimal BASPAG
## Action STD
Call C_NBITF From SUBITF
If mkstat : GERR = 1 : GZONE = "NBITF" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog APRES_NBITF
Local Decimal BASPAG
## Action STD
Call APRES_NBITF From SUBITF
If mkstat : End : Endif
Gosub _AFF
End

$ON_BPSNUM
Onevent CONTROL Call C_BPSNUM(zc) From W1ITF10
Onevent AFTER_CHANGE Gosub AMM_BPSNUM From W1ITF10
Onevent BEFORE_INPUT Call AS_BPSNUM(zc) From W1ITF10
Return

Subprog AS_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1515,GBOUT1) From OBJDIV
Call TEXTE(1004236,GBOUT5) From OBJDIV
Call TEXTE(20355,GBOUT11) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_BPSNUM(zc) From W1ITF10
Onkey 133 Titled GBOUT5 Call B5_BPSNUM(zc) From W1ITF10
Onkey 139 Titled GBOUT11 Call B11_BPSNUM(zc) From W1ITF10
Onkey   2 Titled GBOUTS Call S_BPSNUM(zc) From W1ITF10
Onkey 144 Titled GBOUTP Call P_BPSNUM(zc) From W1ITF10
Onkey 146 Titled GBOUTA Call SA_BPSNUM(zc) From W1ITF10
Gosub _AFF
End

Subprog C_BPSNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
If !GWEBSERV
 If !mkstat
  ## Action BPSCHOICE
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "BPSCHOICE"
  Call S_TAB_CHAR(VALEUR,PARMSK,"BPSCHOICE","TRTSEL","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
 Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("BPS","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
 If !mkstat
  ## Action STD
  Call C_BPSNUM(VALEUR) From SUBITF
  If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_BPSNUM
Call AM_BPSNUM(zc)
If !mkstat & GOBJET
 zoncou = "BPSNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_BPSNUM(VALEUR) From SUBITF
If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZBPSNUM)")>indice
 [M]BPSNUM(indice) = VALEUR
 Affzo ZBPSNUM(indice)
Endif
Gosub _AFF
End

Subprog S_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "BPS"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_BPSNUM(VALEUR)
Variable Char    VALEUR()
Call OBJET("BPS",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog B5_BPSNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELBPSITM3
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELBPSITM3"
 PARMSK(1) = [M:ITF0]ITMREF
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELBPSITM3","SELBPS","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B11_BPSNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action USASUPSEAS
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "USASUPSEAS"
 Call SAISIE_CHAR(VALEUR,PARMSK,"USASUPSEA","USATRTSEA","XWUSASUPSEA") From GSAISIE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "BPS"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("BPS",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZBPSNUM
Onevent BEFORE_AREA Gosub AV_ZBPSNUM From W1ITF10
Return

$AV_ZBPSNUM
If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
Call LECTURE("BPS",num$([M]BPSNUM(indice)),"") From CONTOBJ
zc = [F:BPS]BPSNAM
Gosub _AFF
Return

