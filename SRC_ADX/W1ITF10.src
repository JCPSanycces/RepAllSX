$ON_XDOUFLG
Onevent BEFORE_INPUT Call AS_XDOUFLG(zc) From W1ITF10
Onevent AFTER_CHANGE Gosub AMM_XDOUFLG From W1ITF10
Onevent INIT_AREA Call D_XDOUFLG(zc) From W1ITF10
Return

Subprog D_XDOUFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]XDOUFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_XDOUFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_XDOUFLG(VALEUR) From SUBITF
If mkstat=2
 [M]XDOUFLG(INDIC) = VALEUR
 Affzo XDOUFLG(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_XDOUFLG
Call AM_XDOUFLG(zc)
If !mkstat & GOBJET
 zoncou = "XDOUFLG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_XDOUFLG(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_XDOUFLG(VALEUR) From SUBITF
If mkstat : GERR = 1 : GZONE = "XDOUFLG" : GZNUM = 3935 : Endif
Gosub _AFF
End

