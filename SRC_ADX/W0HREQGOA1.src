# Superviseur
# Gestion du masque HREQGOA1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone EQGOANUM
mkstat = 0
zoncou = "EQGOANUM"
indice = 0
status = 1
zoncou = "EQGOANUM"
If varmode([M]EQGOANUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EQGOANUM" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]EQGOANUM
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]EQGOANUM = nolign
   status = 75
   Call SAI_EQGOANUM(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

