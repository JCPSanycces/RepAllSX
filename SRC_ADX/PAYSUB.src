#<AdxTL>@(#)3.0.0.0 $Revision$


##################################################################
## Divers paye
##################################################################
$ACTION
Case ACTION
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "VERF_TABLE"   : Gosub VERF_TABLE
 When "FIN_TABLE"    : mkstat=4
Endcase
Return

$SEL_TABLE
Case TABLE
 When "SELPAY","SELPAYBUL" : Gosub SELPAY
Endcase
Return

$VERF_TABLE
Case TABLE
 When "SELPAYBUL" : Gosub SELBUL
Endcase
Return

$SELPAY
Local Integer TUNNEL
OBJET = "VEP"
If PARAM(1)<>""
 CRITERE(1) = 'EMP="'+PARAM(1)+'"'
Endif
##**82073 : Add param CTRNUM, CTRDAT & CRIT1
If PARAM(2)<>""
 If CRITERE(1)<>"" : CRITERE(1)-='& ' : Endif
 CRITERE(1) += 'CTRNUM="'+PARAM(2)+'"'
Endif
If PARAM(3)<>""
 If CRITERE(1)<>"" : CRITERE(1)-='& ' : Endif
 CRITERE(1) += 'CTRDAT=['+format$(GFMD,PARAM(3))+']'
Endif
If PARAM(4)<>""
If CRITERE(1)<>"" : CRITERE(1)-='& ' : Endif
 CRITERE(1) += PARAM(4)
Endif
#
SENS = 2
Return

$SELBUL
PARAM(2) = [F]BUL
Return
