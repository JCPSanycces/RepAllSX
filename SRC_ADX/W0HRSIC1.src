#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRSIC1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone SICDIV
mkstat = 0
zoncou = "SICDIV"
indice = 0
If varinit([M]SICDIV,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]SICDIV,"11672","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SICDIV,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SICDIV" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]SICDIV,"11672","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SICDIV" : GZNUM = 14850 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]SICDIV,"11672",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "SICDIV" : GZNUM = 14850 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone SICGRP
mkstat = 0
zoncou = "SICGRP"
indice = 0
If varinit([M]SICGRP,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]SICGRP,"11673","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SICGRP,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SICGRP" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]SICGRP,"11673","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SICGRP" : GZNUM = 616 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]SICGRP,"11673",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "SICGRP" : GZNUM = 616 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone ETIAGEEXO
mkstat = 0
zoncou = "ETIAGEEXO"
indice = 0
IMPENT = [M]ETIAGEEXO
If varinit([M]ETIAGEEXO,indice)=0
 IMPENT = 1
Endif
If varmode([M]ETIAGEEXO,indice)=0
 [M]ETIAGEEXO(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ETIAGEEXO" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ETIAGEEXO(indice)
 Endif
Endif
[M]ETIAGEEXO = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HRSIC1"
Return

