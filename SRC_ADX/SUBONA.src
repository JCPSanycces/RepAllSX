#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion du fichier OVENAT
# Objet : Natures de frais généraux
##############################################
$ACTION
Case ACTION
 When "LIENS"    Gosub LIENS
 When "RAZCRE"   Gosub RAZCRE
 When "RAZDUP"   Gosub RAZCRE
 When "INICRE"   Gosub INICRE
 When "INIMOD"   Gosub INICRE
 When "ANNULE"   Gosub ANNULE
 When "CHANGE" : Call CHANGE_AXX ("OVENAT", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When default
Endcase
Return

$RAZCRE
#---------------------------------#
# Initialisation tableau des axes #
#---------------------------------#
If dim([M:ONA1]NBAXE)>0
    Call INIT_DIE(6,"","ONA1","NBAXE") From TRTX3CPT
Endif

Return

$LIENS
#---------------------------------#
# Initialisation tableau des axes #
#---------------------------------#
If dim([M:ONA1]NBAXE)>0
    Call CHARG_DIE(6,"","ONA1","NBAXE") From TRTX3CPT
Endif

Return

$INICRE
    Call MAJTEXTRA([M:ONA1]ONAAXX,"OVENAT","ONAAXX",[M:ONA1]OVENAT,"") From ATEXTRA
    Call MAJTEXTRA([M:ONA1]ONASHOAXX,"OVENAT","ONASHOAXX",[M:ONA1]OVENAT,"") From ATEXTRA
Return

$ANNULE
    Delete [AXX] Where CODFIC="OVENAT" & ZONE="ONAAXX" & CLE1= [M:ONA1]OVENAT
    Delete [AXX] Where CODFIC="OVENAT" & ZONE="ONASHOAXX" & CLE1= [M:ONA1]OVENAT
Return

#CHECK UNUSED_SOURCE
##############################################
Subprog C_CCE(VALEUR)
Variable Char     VALEUR
Call SECTION(VALEUR,1,"",[0/0/0]) From CONTX3
End
#CHECK UNUSED_END
##########################################################################
## Etiquette ajoutée par le superviseur 24/04/2003 10:56:04 (TB)
##########################################################################
Subprog AV_CCEINT(VALEUR)
Variable Integer VALEUR
VALEUR = nolign
End


##########################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran ONA1) 03/11/2005 15:24:07 (CCC)
######################################################################################
Subprog AS_TYPCST(VALEUR)
Variable Integer VALEUR
GMENLOC(5) = 1
GMENLOC(6) = 1
End


