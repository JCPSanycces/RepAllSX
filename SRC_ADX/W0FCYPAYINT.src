  IMPMOD = 0 : IMPZON = "AEMFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]AEMFLG(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_AEMFLG(IMPENT) From SUBFCYB
