 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]AEMFLG = IMPENT

## Zone AEMFCY
mkstat = 0
zoncou = "AEMFCY"
indice = 0
If varmode([M]AEMFCY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "AEMFCY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTFCY"
 Call CONTSITE([M]AEMFCY) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "AEMFCY" : GZNUM = 47545 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("FCY","!$",[M]AEMFCY,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "AEMFCY" : GZNUM = 47545 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_AEMFCY([M]AEMFCY) From SUBFCYB
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "AEMFCY" : GZNUM = 47545 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

