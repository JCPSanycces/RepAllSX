# Superviseur
# Gestion du masque FCYPAYINT 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone FLGLIC
mkstat = 0
zoncou = "FLGLIC"
indice = 0
IMPENT = [M]FLGLIC
If varinit([M]FLGLIC,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGLIC,indice)=0
 [M]FLGLIC(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGLIC" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGLIC(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_FLGLIC(IMPENT) From SUBFCYB
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FLGLIC" : GZNUM = 47427 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]FLGLIC = IMPENT

## Zone NUMLIC
mkstat = 0
zoncou = "NUMLIC"
indice = 0
If varmode([M]NUMLIC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NUMLIC" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone FLGLAB
mkstat = 0
zoncou = "FLGLAB"
indice = 0
IMPENT = [M]FLGLAB
