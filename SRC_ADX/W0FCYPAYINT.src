 If !mkstat
  Call CONTROLE("FCY","!$",[M]CCSFCY,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CCSFCY" : GZNUM = 46288 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_CCSFCY([M]CCSFCY) From SUBFCYB
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CCSFCY" : GZNUM = 46288 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NUMCCS
mkstat = 0
zoncou = "NUMCCS"
indice = 0
If varmode([M]NUMCCS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NUMCCS" : Gosub ACTION From =IMPTRT
 Endif
