#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
Local Char OFONCTION(20)
OFONCTION=GFONCTION
If GFONCTION<>"BANAFFA"
 GFONCTION="BANAFFA" : Call AUTORIS From EXEFNC
Endif
GACTION = "BANAFFA"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","BANAFFA","DBANAFFA",3,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub INIT
 When "CONT_BATCH"  : Gosub CONTROLE
Endcase
Return

#####
$INIT
#####
Onerrgo CHUT From CONTROLE
If clalev([F:CPY])=0 : Local File COMPANY    [CPY]    : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY]    : Endif
If clalev([F:TPY])=0 : Local File TABPAYTYP  [TPY]    : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC]    : Endif
If clalev([F:GCU])=0 : Local File GRPCUR     [GCU]    : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU]    : Endif
If clalev([F:PYL])=0 : Local File PAYLOT     [PYL]    : Endif
If clalev([F:POO])=0 : Local File POOL       [POO]    : Endif
If clalev([F:BAN])=0 : Local File BANK       [BAN]    : Endif
If clalev([F:PYH])=0 : Local File PAYMENTH   [PYH]    : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER]    : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC]    : Endif
If clalev([F:BAL])=0 : Local File BALANCE    [BAL]    : Endif
If clalev([F:GSC])=0 : Local File GRPSAC     [GSC]    : Endif
If clalev([F:RBK])=0 : Local File RELBANK    [RBK]    : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE]    : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE]    : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY]    : Endif
Onerrgo
If GERREUR : GERREUR=0 : Endif
Return

#########
$INIT_DIA
#########
Raz [M:DIA]
Return

#########
$CONTROLE
#########
If [M]AMT=0 | sum([M]AMTBAN(0..[M]NB-1))=0
 GERR=1 : GMESSAGE=mess(9,135,1) : SAI=1 : Return
Endif
TMP=1 : TIT="V"
Return


#####
$EXEC
#####
Onerrgo ERREUR From CONTROLE
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]    : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]    : Endif
If clalev([F:TPY])=0  : Local File TABPAYTYP  [TPY]    : Endif
If clalev([F:ACC])=0  : Local File ACCES      [ACC]    : Endif
If clalev([F:GCU])=0  : Local File GRPCUR     [GCU]    : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]    : Endif
If clalev([F:POO])=0  : Local File POOL       [POO]    : Endif
If clalev([F:BAN])=0  : Local File BANK       [BAN]    : Endif
If clalev([F:PYH])=0  : Local File PAYMENTH   [PYH]    : Endif
If clalev([F:PYH2])=0 : Local File PAYMENTH   [PYH2]   : Endif
If clalev([F:PYD])=0  : Local File PAYMENTD   [PYD]    : Endif
If clalev([F:PIH])=0  : Local File PINVOICE   [PIH]    : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD]    : Endif
Onerrgo
If GERREUR : GERREUR=0 : Endif

Local Integer OK, STAT, SIGN, I, J, K
Local Decimal MT, MT2, MTE, MTE2
Local Char    FILTSUP(255), CRITCUR(255), CRITTPY(255), FILTSPE(255)
Local Char    SYMBOLE(35), RTZCUR(GLONCUR)

Call PARAM("","RTZCUR",[L]RTZCUR) From ADOVAL

If !GSERVEUR
 Call TITAWI(BCRIT,CRITTPY) From OBJDIV
 Call OUVRE_TRACE(CRITTPY) From LECFIC
Endif

Gosub CRITTPY From BANAFFM
If [L]CRITTPY<>""
 Gosub FILTRE From BANAFFM
 If [L]CRITCUR="" : [L]CRITCUR="1" : Endif
 If [L]FILTSPE="" : [L]FILTSPE="1" : Endif   :# Filtre spécifique utilisateur
 Case [M:DIA]ALLMOD
  When 1  :# Priorité date d'échéance
   Filter [PYH2] Where evalue([L]FILTSUP) & evalue([L]CRITTPY) & evalue([L]CRITCUR)
&              & evalue([L]FILTSPE)
&                Order By Key CLE=DUDDAT
  When 2  :# Priorité montant
   Filter [PYH2] Where evalue([L]FILTSUP) & evalue([L]CRITTPY) & evalue([L]CRITCUR)
&              & evalue([L]FILTSPE)
&                Order By Key CLE=AMTCUR Desc
 Endcase
 For [PYH2]CLE
  Call DEBTRANS From GLOCK
  Gosub TR
 Next : # [PYH2]
 Filter [PYH2]
Endif
GOK=1
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE (mess(54,121,1),0) From GESECRAN
For I=0 To [M]NB-1
 Call ECR_TRACE([M]BANAFF(I)-":"-num$([M]AMTAFF(I))-[M]BANCUR(I),0) From GESECRAN
Next I
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(55,121,1)-":"-num$([M]AMT)-[M]CURAMT,0) From GESECRAN
If !GSERVEUR
 Call FERME_TRACE From LECFIC
 TRA=1
Endif
Return

$TR
GOK=1 : OK=1
Trbegin [PYH]

 Readlock [PYH]PYH0=[F:PYH2]NUM
 If fstat=1
  GOK=-1 : GLOCK="$PAYMENTH"-num$([F:PYH2]NUM)
  Goto ROLL_TR
 Elsif fstat
  GOK=0 : Call RSTA("PYH",num$([F:PYH2]NUM)) From GLOCK
  Goto AB_TR
 Endif
 # Lock du règlement
 SYMBOLE = "PYH"+num$([F:PYH]NUM)
 Lock =SYMBOLE
 If fstat
  GOK=-1 : GLOCK="%PYH"+num$([F:PYH]NUM)
  Goto ROLL_TR
 Endif

 Call LEC_TPY_LEG(GCURLEG,[F:PYH]PAYTYP) From CPTLEC
 Call CONVERT([F:PYH]CUR,[M]CURAMT,[M]CURAMT,[F:TPY]RATTYP,[F:PYH]ACCDAT,
&             [F:PYH]AMTCUR,[L]MT,[L]STAT) From TRTDEV
 If [L]STAT
  Call ECR_TRACE(mess(16,114,1)-[F:PYH]CUR-"->"-[M]CURAMT-"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)
&      -")",[L]STAT) From GESECRAN
  GOK=0 : Goto AB_TR
 Endif
 [L]MTE = [L]MT
 If [M]EURCUR<>"" & [M]CURAMT<>[M]EURCUR
  Call CONVERT([F:PYH]CUR,[M]EURCUR,[M]CURAMT,[F:TPY]RATTYP,[F:PYH]ACCDAT,
&              [F:PYH]AMTCUR,[L]MTE,[L]STAT) From TRTDEV
  If [L]STAT
   Call ECR_TRACE(mess(16,114,1)-[F:PYH]CUR-"->"-[M]EURCUR-"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)
&       -")",[L]STAT) From GESECRAN
   GOK=0 : Goto AB_TR
  Endif
 Endif
 OK=-1
 For I=0 To [M]NB-1
 #Issue X3-75462 by MRDAB
 If func AFNC.ACTIV("FIFRC")
  If (func AFNC.PARAM("FIFRC", [M:DIA]CPY) = "2")
    If func FIFOCONVAR_CSTD.FLDFIFCP_CTL([M]BANAFF(I),[F:PYH]ACCDAT)
     If func FIFOCONVAR_CSTD.IS_FIFO_EXIST([M]BANAFF(I),[F:PYH]ACCDAT) = 1
      Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":"-mess(29,7708,1),1) From GESECRAN
      Goto ITERATE
     Endif
    Endif
  Endif
 Endif
 #Issue end
  If [M]BANCUR(I)=[M]CURAMT
   [L]MT2 = [M]AMTBAN(I)-[M]AMTAFF(I)
   If [M]AMTBAN(I)-[M]AMTAFF(I) >= [L]MT
    OK=I : Break
   Elsif [M:DIA]SNS=2 & [M]AMTBAN(I)>[M]AMTAFF(I) & ([M]AMTBAN(I)-[M]AMTAFF(I))>[L]MT2
    # Recette mise sur la banque avec la + grande différence entre le montant à affecter
    # et le montant déjà affecté
    [L]MT2=[M]AMTBAN(I)-[M]AMTAFF(I)
    OK=I
   Endif
  Else
   [L]MTE2 = [M]AMTBAN(I)-[M]AMTAFF(I)
   If [M]AMTBAN(I)-[M]AMTAFF(I) >= [L]MTE
    OK=I : Break
   Elsif [M:DIA]SNS=2 & [M]AMTBAN(I)>[M]AMTAFF(I) & ([M]AMTBAN(I)-[M]AMTAFF(I))>[L]MTE2
    # Recette mise sur la banque avec la + grande différence entre le montant à affecter
    # et le montant déjà affecté
    [L]MTE2=[M]AMTBAN(I)-[M]AMTAFF(I)
    OK=I
   Endif
  Endif
  $ITERATE
 Next I
 If OK=-1 : Goto AB_TR : Endif
 I=OK : Gosub REGOK
 If GOK<0: Goto ROLL_TR
 Elsif !GOK : Goto AB_TR
 Endif
Commit
Return

$REGOK
# Maj de PAYMENTH
Call LEC_BAN([M]BANAFF(I)) From CPTLEC
[F:PYH]BAN = [M]BANAFF(I)

Call CONTBAN([F:PYH]ACCDAT,[F:PYH]BAN,[F:PYH]CUR) From CPTSUB
If GERR=2
 Call ECR_TRACE([F:PYH]NUM-":"-GMESSAGE,0) From GESECRAN
 Raz GERR, GMESSAGE
Endif

[F:PYH]BANPAYTPY=0
[F:PYH]AMTBAN=0

# Détermination de AMTBAN et BANPAYTPY
If [F:PYH]CUR=[F:BAN]CUR
 [F:PYH]AMTBAN=[F:PYH]AMTCUR
 Call SIGN2(1,[F:PYH]SNS,0,0,0,SIGN) From PAYDIV
 If [F:PYH]SNS=1 : SIGN*=-1 : Endif
 [F:PYH]BANPAYTPY = SIGN*[F:PYH]AMTBAN
Endif

GPOINT = "TRTDATB" : Gosub ENTREE From EXEFNC
If GOK<1 : Return : Endif

For [PYD]PYD0 Where NUM=[F:PYH]NUM
 If ([F:PYH]AMTBAN=0 & [F:PYD]ACCTYP=1) | [F:PYD]ACCTYP=2
  If [F:PYD]AMTLIN=0
   [L]MT=0
  Elsif [F:PYH]CUR=[F:BAN]CUR & [F:PYD]ACCTYP=1
   [L]MT=sgn([F:PYD]AMTLIN)*abs([F:PYD]AMTLIN2-[F:PYD]RITAMT2)
  Elsif [F:PYD]CURLIN=[F:BAN]CUR
   [L]MT=[F:PYD]AMTLIN
  Elsif [F:PYD]DUDNUM<>0 & [M]CURAMT=[F:BAN]CUR
   [L]MT=sgn([F:PYD]AMTLIN)*abs([F:PYD]PAYLOCLIN)
  Else
   Call CONVERT([F:PYD]CURLIN,[F:BAN]CUR,[M]CURAMT,[F:TPY]RATTYP
&              ,[F:PYH]ACCDAT,[F:PYD]AMTLIN,[L]MT,[L]STAT) From TRTDEV
   If [L]STAT
    Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":"-mess(16,114,1)-[F:PYD]CURLIN-"->"-[F:BAN]CUR
&      -"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")",1) From GESECRAN
    GOK=0 : Break
   Endif
  Endif
  Call SIGN2([F:PYD]ACCSNS,[F:PYH]SNS,[F:PYD]DUDNUM,[F:PYD]DUDLIG,[F:PYD]IPTTYP,SIGN) From PAYDIV
  If [F:PYH]SNS=1 : SIGN*=-1 : Endif
  [F:PYH]BANPAYTPY+=[L]MT*SIGN

  If [F:PYD]RITAMT<>0
   If [L]RTZCUR=[F:BAN]CUR
    [L]MT=[F:PYD]RITAMT
   Elsif [F:PYH]CUR=[F:BAN]CUR
    [L]MT=sgn([F:PYD]RITAMT)*abs([F:PYD]RITAMT2)
   Else
    Call CONVERT([L]RTZCUR,[F:BAN]CUR,[M]CURAMT,[F:TPY]RATTYP
&               ,[F:PYH]ACCDAT,[F:PYD]RITAMT,[L]MT,[L]STAT) From TRTDEV
    If STAT
     Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":"-mess(16,114,1)-[L]RTZCUR-"->"-[F:BAN]CUR
&       -"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")",1) From GESECRAN
     GOK=0 : Break
    Endif
   Endif
   Call LECTURE("BIS",[F:PYD]VCRNUM,"") From CONTOBJ
   If find([F:PIH]INVTYP,2,4) : J=3 : Else J=2 : Endif
   Call SIGN2(J,[F:PYH]SNS,0,0,0,SIGN) From PAYDIV
   If [F:PYH]SNS=1 : SIGN*=-1 : Endif
   [F:PYH]BANPAYTPY+=[L]MT*SIGN
  Endif
 Endif
Next : # [PYD]
If !GOK : Return : Endif

Rewrite [PYH]
If fstat
 GOK=0 : Call FSTA("PYH") From GLOCK : Return
Endif

# Maj BANK
SIGN=1 : Gosub MAJBAN From BANAFFM
If GOK<1 : Return : Endif

[M]VIRBLC(I) += [L]MT
[M]AMTAFF(I) += [L]MT
If [F:PYH]CUR<>[F:BAN]CUR
 [L]MT = [F:PYH]AMTCUR
Endif
[M]AMT       -= [L]MT

Call ECR_TRACE([M]BANAFF(I)-mess(117,117,1)-[F:PYH]NUM-":"-
&              [F:PYH]BPR+","-num$([F:PYH]AMTCUR)-[F:PYH]CUR,0) From GESECRAN
Return

$ROLL_TR
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR : Endif

$AB_TR
Rollback
Return

