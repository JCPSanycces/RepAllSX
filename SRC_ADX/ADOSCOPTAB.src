#<AdxTL>@(#)0.0.0.0 $Revision$ Copie des tables sans modèle d
Local Char TBLEG(10)(1..2)
Local Char TBLAN(5)(1..30)

Local Integer NBLAN , MODULE(1..30)
For I=1 To dim(MODULE) : MODULE(I) = 2 : Next I
Call OUVRE_TRACE("test ADOSCOPTAB") From LECFIC
Call COPY(nomap,"","",3,TBLEG,1,TBLAN,NBLAN,"",1,0,MODULE,"AQTABCOUNTRY",1) From ADOSCOPTAB
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#---------------------------------------------------------------------------------------------------------------------#
Subprog COPY(DOSSIER,DOSCOP,DOSREF,ORIGIN,TBLEG,NBLEG,TBLAN,NBLAN,CRYDEF,LEGNUL,ONELEG,MODULE,TABLE,DETAIL)
Value    Char    DOSSIER , DOSCOP , DOSREF
Value    Integer ORIGIN
Value    Char    TBLEG()(1..)
Value    Integer NBLEG
Variable Char    TBLAN()(1..)
Variable Integer NBLAN
Value    Char    CRYDEF
Value    Integer LEGNUL
Value    Integer ONELEG
Value    Integer MODULE(1..)
Value    Char    TABLE
Value    Integer DETAIL

Local Integer STAT
Local Char    NOMPROG(250) , DOSORG(GLONADS)

Case ORIGIN
 When 1 : DOSORG = DOSCOP
 When 2 : DOSORG = DOSREF
 When 3 : DOSORG = GDOSX3
Endcase
If DOSORG=""
 DOSORG = nomap
Endif

If clalev([F:ATB])=0 : Local File =DOSORG+".ATABLE"    [ATB] : Endif
If clalev([F:ATI])=0 : Local File =DOSORG+".ATABIND"   [ATI] : Endif
If clalev([F:AMP])=0 : Local File =DOSORG+".AMSKPAR"   [AMP] : Endif
If clalev([F:ATZ])=0 : Local File =DOSORG+".ATABZON"   [ATZ] : Endif
If clalev([F:ATY])=0 : Local File =DOSORG+".ATYPE"     [ATY] : Endif

If clalev([F:ACV8])=0 : Local File =DOSSIER+".ACTIV"    [ACV8]  : Endif
If clalev([F:AXX2])=0 : Local File =DOSSIER+".ATEXTRA"  [AXX2] : Endif

# WMVTAB*
NOMPROG = format$("KTv2:30X",func APREFIXTRT.GET_COPTAB+TABLE+num$(adxuid(2)))
Call VALID(DOSSIER,DOSORG,TABLE,NOMPROG,DETAIL,STAT)
If !STAT
 # Erreur pendant la copie du fichier
 Call ECR_TRACE(mess(33,143,1)-TABLE,-1) From GESECRAN
 Call MOVE(filpath("TRT",NOMPROG,"src"),filpath("TRT","WWERR_"+TABLE+num$(adxuid(2)),"src"),STAT) From ORDSYS
Else
 Gosub COPY From =NOMPROG
 Call EFFACE_ADX("","",NOMPROG,STAT) From ORDSYS
 Call EFFACE(filpath("TRT",NOMPROG,"adx"),STAT) From ORDSYS
 #113657
 #Call MOVE(filpath("TRT",NOMPROG,"src"),filpath("TRT","WWOLD_"+TABLE+num$(adxuid(2)),"src"),STAT) From ORDSYS
 Call EFFACE(filpath("TRT",NOMPROG,"src"),STAT) From ORDSYS
Endif

Close Local File

End

#---------------------------------------------------------------------------------#
Subprog VALID(DOSSIER,DOSORG,TABLE,NOMPROG,DETAIL,OK)
Value    Char    DOSSIER
Value    Char    DOSORG
Value    Char    TABLE
Value    Char    NOMPROG
Value    Integer DETAIL
Variable Integer OK

Local Char     FICSRC(GDIMFIC) , IDENT(20) , FLDLEG(50) , ABREV(240)
Local Char     CHAINE(250) , MAGIC(80) , BUF(250) , FORMULE(255)
Local Integer  I , J , K , L , M , N , OK
Local Shortint DIME : DIME = 20
Local Char     LNKTAB(GLONATB) , LNKCLE(GLONANX) , LNKABR(GLONABR) , LNKEXP(250)
Local Char     REFTAB(GLONATB) , ABRREF(GLONABR) , CLEREF(GLONANX)

MAGIC = mess(77,133,1) : # Superviseur Adonix
IDENT = "##"-func APREFIXTRT.GET_COPTAB-"##"

OK = 1
If [L]TABLE=""
 Call ECR_TRACE(mess(134,141,1)-"***",1) From GESECRAN : # Erreur de syntaxe
 OK = 0
Endif

Look [ATB]CODFIC=TABLE
If fstat
 Call ECR_TRACE([F:AWM]TABREF-":"-mess(124,124,1),1) From GESECRAN : # Table inexistante
 OK = 0
Endif

If OK
 Gosub TRT_DEB
 If OK
  Gosub ETIQ
  Gosub TRT_FIN
 Endif
Endif

End

#-------------------------------------------------------#
$TRT_DEB
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
FICSRC = filpath("TRT",NOMPROG,"src")
If filinfo(FICSRC,0)>=0
 Openi FICSRC Using [SSS_]
 Raz I, OK
 Rdseq CHAINE Using [SSS_]
 While !fstat
  I += 1 : If I>5 : Break : Endif
  If left$(CHAINE,len(IDENT))=IDENT
   OK = 1 : Break
  Endif
  Rdseq CHAINE Using [SSS_]
 Wend
 Openi Using [SSS_]
 If !OK
  # Ce traitement est déjà utilisé par un autre paramétrage
  Call ECR_TRACE(NOMPROG-":"-mess(215,139,1),1) From GESECRAN
  Return
 Endif
Else
 OK = 1
Endif
Openo FICSRC , 0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq IDENT-mess(264,143,1)-TABLE-'('+num$(datetime$)+')' : # Livrable ou kit
Wrseq
Return

#-------------------------------------------------------#
$TRT_FIN
Wrseq
Openo
Call VALID("TRT",NOMPROG,nomap,OK) From VALMSKSUB
Return

#------------------------------------------------------------------------------#
$ETIQ
Wrseq "#-----------------------#"
Wrseq "$COPY"
Wrseq

REFTAB = TABLE
Read [ATB]CODFIC=TABLE
ABRREF = [F:ATB]ABRFIC
Read [ATI]NUMLIG(2)=TABLE;1
CLEREF = [F:ATI]CODIND

FLDLEG = ""
If [F:ATB]FLGLEG=2 & [F:ATB]CODFIC<>"TABFOR"
 For [ATZ]CODZONE Where CODFIC=TABLE & CHPLEG=2
  If [F:ATZ]CODTYP="ADI"
   Read [AMP]CODPAR=2;[F:ATZ]CODFIC;[F:ATZ]CODZONE;"ADI"
   If !fstat & num$(evalue([F:AMP]VALPAR))="909"
    FLDLEG = [F:ATZ]CODZONE
    Break : # Comment pourrait-il en être autrement ???
   Endif
  Endif
  If [F:ATZ]LIEN<>""
   LNKTAB = [F:ATZ]LIEN
   LNKEXP = [F:ATZ]EXPLIEN
   If LNKEXP=""
    LNKEXP = '['+ABRREF+']'+[F:ATZ]CODZONE
   Endif
   Read [ATB]CODFIC=LNKTAB
   LNKABR = [F:ATB]ABRFIC
   Read [ATI]NUMLIG(2)=LNKTAB;1
   LNKCLE = [F:ATI]CODIND
  Endif
  Break
 Next ATZ_
 If LNKTAB<>""
  For [ATZ]CODZONE Where CODFIC=LNKTAB & CHPLEG=2
   If [F:ATZ]CODTYP="ADI"
    Read [AMP]CODPAR=2;[F:ATZ]CODFIC;[F:ATZ]CODZONE;"ADI"
    If !fstat & num$(evalue([F:AMP]VALPAR))="909"
     FLDLEG = "[F:"+LNKABR+"]"+[F:ATZ]CODZONE
     Break : # Comment pourrait-il en être autrement ???
    Endif
   Endif
  Next ATZ_
 Endif
Endif

# Open files
Wrseq 'Local File =DOSORG+".'+REFTAB+'" ['+ABRREF+']'
If LNKTAB<>""
 Wrseq 'Local File =DOSORG+".'+LNKTAB+'" ['+LNKABR+']'
Endif
Wrseq 'Local File =DOSORG+".ATEXTRA" [AXX1]'
Wrseq
Wrseq 'Local File =DOSSIER+".'+REFTAB+'" [DEST_]'
Wrseq

# Tables spéciales
If find(TABLE,"ALISTEH","AOBJEXT")
 Wrseq 'Local File =DOSORG+".AREPORTX"  [ARX]'
 Wrseq 'Local File =DOSORG+".AREPORTV"  [ARV]'
 Wrseq 'Local File =DOSSIER+".AREPORTX" [DEST_ARX]'
 Wrseq 'Local File =DOSSIER+".AREPORTV" [DEST_ARV]'
Endif
If TABLE="ALISTEH"
 Wrseq 'Local File =DOSORG+".ACLOB"  [ACB]'
 Wrseq 'Local File =DOSSIER+".ACLOB" [DEST_ACB]'
Endif

Wrseq 'Local Integer I , J , K , OK'
Wrseq 'Local Char    KEYVAL(50) , CHAINE(250)'
Wrseq

# Link
If LNKTAB<>""
 Wrseq 'Link ['+ABRREF+'] With ['+LNKABR+']'+LNKCLE+"="+LNKEXP-'as [LNK_]'
 ABREV = 'LNK_'
Else
 ABREV = ABRREF
Endif

# Field 'Législation'
If [L]FLDLEG<>"" & TABLE<>"TABFOR"
 Wrseq 'If !LEGNUL'
 Wrseq ' If ONELEG'
 Wrseq '  Filter ['+ABREV+'] Where '+[L]FLDLEG+'=TBLEG(1)'
 Wrseq ' Else'
 Wrseq '  Filter ['+ABREV+'] Where '+[L]FLDLEG+'<>"" & find('+[L]FLDLEG+',TBLEG(1..NBLEG))<>0'
 Wrseq ' Endif'
 Wrseq 'Else'
 Wrseq ' If ONELEG'
 Wrseq '  Filter ['+ABREV+'] Where '+[L]FLDLEG+'=TBLEG(1) or '+[L]FLDLEG+'=""'
 Wrseq ' Else'
 Wrseq '  Filter ['+ABREV+'] Where '+[L]FLDLEG+'="" or find('+[L]FLDLEG+',TBLEG(1..NBLEG))<>0'
 Wrseq ' Endif'
 Wrseq 'Endif'
Endif

Wrseq 'Trbegin [DEST_]'
Case TABLE
 When "TABFOR"    : Wrseq ' Gosub UPDATE_TFO'
 When "TABCOUAFF" : Wrseq ' Gosub UPDATE_TCA'
 When Default     : Wrseq ' Gosub UPDATE_RECORD'
Endcase
Wrseq 'Commit'
Wrseq

# Close files
Wrseq 'Close local File ['+ABRREF+']'
Wrseq 'Close local File [AXX1]'
If LNKTAB<>""
 Wrseq 'Close local File ['+LNKABR+']'
Endif
Wrseq
Wrseq 'Close local File [DEST_]'
Wrseq

Wrseq 'Return'
Wrseq

Wrseq '#------------------------------#'
Wrseq '$UPDATE_TFO'
Wrseq 'For ['+ABREV+']'
Wrseq ' Gosub COPY_TFO From ADOSCOPDAT'
Wrseq 'Next '+ABREV
Wrseq 'Return'
Wrseq

Wrseq '#------------------------------#'
Wrseq '$UPDATE_TCA'
Wrseq 'For ['+ABREV+']'
Wrseq ' OK = 1'
Wrseq ' If [L]MODULE([F:'+ABREV+']MODULE)<>2 : OK = 0 : Endif'
Wrseq ' If OK'
Wrseq '  Gosub COPY_TCA From ADOSCOPDAT'
Wrseq ' Endif'
Wrseq 'Next '+ABREV
Wrseq 'Return'
Wrseq

Wrseq '#------------------------------#'
Wrseq '$UPDATE_RECORD'

Wrseq 'For ['+ABREV+']'
Read [ATB]CODFIC=REFTAB
Read [ATI]CODIND=REFTAB;CLEREF
Gosub SETCLE
Wrseq ' OK = 1'
Read [ATZ]CODZONE=REFTAB;"CODACT"
If !fstat
 Wrseq ' If [F:'+ABRREF+']CODACT<>""'
 Wrseq '  Read [ACV8]CODACT = [F:'+ABRREF+']CODACT'
 Wrseq '  If fstat or [F:ACV8]FLACT<>2 : OK = 0 : Endif'
 Wrseq ' Endif'
Endif
Read [ATZ]CODZONE=REFTAB;"MODULE"
If !fstat
 Wrseq ' If [F:'+ABRREF+']MODULE>0 & [L]MODULE([F:'+ABRREF+']MODULE)<>2 : OK = 0 : Endif'
Endif
If REFTAB="POSCOD"
 Wrseq ' If dim([F:'+ABRREF+']CRY)>0 & [F:'+ABRREF+']CRY<>[L]CRYDEF : OK = 0 : Endif'
Endif
If LNKTAB<>""
 Read [ATZ]CODZONE=LNKTAB;"CODACT"
 If !fstat
  Wrseq ' If [F:'+LNKABR+']CODACT<>""'
  Wrseq '  Read [ACV8]CODACT = [F:'+LNKABR+']CODACT'
  Wrseq '  If fstat or [F:ACV8]FLACT<>2 : OK = 0 : Endif'
  Wrseq ' Endif'
 Endif
 Read [ATZ]CODZONE=LNKTAB;"MODULE"
 If !fstat
  Wrseq ' If [F:'+LNKABR+']MODULE>0 & [L]MODULE([F:'+LNKABR+']MODULE)<>2 : OK = 0 : Endif'
 Endif
Endif
Wrseq ' If OK'
Wrseq '  [F:DEST_] = [F:'+ABRREF+']'
If [L]FLDLEG<>"" & !instr(1,[L]FLDLEG,"[")
 Wrseq '  If ONELEG & LEGNUL & [F:DEST_]'+[L]FLDLEG+'=""'
 Wrseq '   [F:DEST_]'+[L]FLDLEG+' = TBLEG(1)'
 Wrseq '  Endif'
Endif
Wrseq '  Look [F:DEST_] ='
Gosub NAMKEY
Wrseq '  If !fstat'
If [L]FLDLEG<>"" & !instr(1,[L]FLDLEG,"[")
 Wrseq '   If ONELEG & LEGNUL & [F:'+ABRREF+']'+[L]FLDLEG+'<>""'
 Wrseq '    Read [F:DEST_] ='
 Wrseq '    [F:DEST_] = [F:'+ABRREF+']'
 Wrseq '    Rewrite [F:DEST_]'
 Wrseq '    If fstat'
 Wrseq '     Call ERREUR('+CHAINE+',1) From DOSDIC'
 Wrseq '    Elsif DETAIL'
 Wrseq '     Call ECR_TIME(mess(104,141,1)-'+CHAINE+') From DOSSUB : # Enregistrements modifiés'
 Wrseq '    Endif'
 Wrseq '   Elsif DETAIL'
Else
 Wrseq '   If DETAIL'
Endif
Wrseq '    Call ECR_TRACE(mess(224,115,1)-'+CHAINE+',-1) From GESECRAN : # Enregistrement existant'
Wrseq '   Endif'
Wrseq '  Else'
Gosub RAZ_ZONE
Wrseq '   Write [F:DEST_]'
Wrseq '   If fstat'
Gosub NAMKEY
Wrseq '    Call ERREUR('+CHAINE+',1) From DOSDIC'
Wrseq '   Else'
Wrseq '    If DETAIL'
Wrseq '     Call ECR_TIME(mess(36,149,1)-'+CHAINE+') From DOSSUB : # Enregistrement créé'
Wrseq '    Endif'
Gosub UPD_AXX
Case TABLE
 When "ALISTEH"
  Wrseq '    Case [F:'+ABRREF+']TYP'
  Wrseq '     When 1,3 : Call COPY_LNKFILES(3,[F:'+ABRREF+']COD) From ADOSCOPDAT'
  Wrseq '     When 2   : Call COPY_LNKFILES(2,[F:'+ABRREF+']COD) From ADOSCOPDAT'
  Wrseq '    Endcase'
 When "AOBJEXT" :
  Wrseq '    Call COPY_LNKFILES(4,[F:'+ABRREF+']EXT) From ADOSCOPDAT'
Endcase
Wrseq '   Endif'
Wrseq '  Endif'
Wrseq ' Endif'
Wrseq 'Next '+ABREV
Wrseq

Wrseq 'Return'
Wrseq
Return

#-------------------------------------------------#
$NAMKEY
CHAINE = '"'+REFTAB+'"-'
For I=1 To NBCLE
 If len(CHAINE)>200
  Break
 Endif
 If I>1
  CHAINE += '+"~"+'
 Endif
 Case TYP(I)
  When 1,2,3,4,5,6 : CHAINE += 'num$([F:'+ABRREF+']'+CLE(I)+')'
  When 8           : CHAINE += 'num$([F:'+ABRREF+']'+CLE(I)+')'
  When Default     : CHAINE += '[F:'+ABRREF+']'+CLE(I)
 Endcase
Next I
Return

#---------------------------------------------------#
$UPD_AXX
Local Char TABLE1(250), ZONE (250), CLECUR1 (250), CLECUR2(250)
For [ATZ]CODZONE Where CODFIC=REFTAB & find(CODTYP,"AXX","AX1","AX2","AX3")
 Raz TABLE1 , ZONE , CLECUR1 , CLECUR2
 For [AMP] Where TYPAFF=2 & CODAFF=[F:ATZ]CODFIC & CODZON=[ATZ]CODZONE
  Case [AMP]CODPAR
   When "TABLE1"   : TABLE1  = '"'+ctrans([AMP]VALPAR,'"',"¨")+'"'
   When "ZONE"     : ZONE    = '"'+ctrans([AMP]VALPAR,'"',"¨")+'"'
   When "CLECUR1"  : CLECUR1 = '"'+ctrans([AMP]VALPAR,'"',"¨")+'"'
   When "CLECUR2"  : CLECUR2 = '"'+ctrans([AMP]VALPAR,'"',"¨")+'"'
  Endcase
 Next AMP_
 If TABLE1<>"" and ZONE<>""
  Gosub SET_REPET
  Wrseq '    Call UPDATE_TEXTRA(TBLAN,NBLAN,'+num$(REPET)+',"'+ABRREF+'","'+"DEST_"+string$(L>0,num$(L))+'"';
  Wrseq ','+TABLE1+','+ZONE+','+CLECUR1+','+CLECUR2+') From ADOSCOPDAT'
 Endif
Next ATZ_
Return

#-----------------------------------------------------#
$RAZ_ZONE
For [ATZ]CODZONE Where CODFIC=REFTAB & ZERO=2
 Read [ATY]CODTYP=[F:ATZ]CODTYP
 Gosub SET_REPET
 For I=1 To REPET
  If I=1
   Wrseq '    [F:DEST_'+string$(L>0,num$(L))+']'+[F:ATZ]CODZONE+' = ';
  Else
   Wrseq '    [F:DEST_'+string$(L>0,num$(L))+']'+[F:ATZ]CODZONE+'('+num$(I-1)+') = ';
  Endif
  Case [F:ATY]TYPTYP
   When 1,2,3,4,5,6 : Wrseq '0'
   When 8           : Wrseq '[0/0/0]'
   When Default     : Wrseq '""'
  Endcase
 Next I
Next ATZ_
Return

#---------------------------#
$SET_REPET
Local Integer REPET
REPET = 0
If [ATZ]DIME>0
 REPET = [F:ATZ]DIME
Elsif [F:ATZ]CODACT <> ""
 Read [ACV8]CODACT = [F:ATZ]CODACT
 If !fstat
  If [F:ACV8]DIMFIL>0 & [F:ACV8]DIME>0 & [F:ACV8]DIMMAX>0
   REPET = min(max([F:ACV8]DIMFIL,[F:ACV8]DIME),[F:ACV8]DIMMAX)
  Elsif ([F:ACV8]DIMFIL<>0 | [F:ACV8]DIME<>0)
   REPET = max([F:ACV8]DIMFIL,[F:ACV8]DIME)
  Endif
 Endif
 REPET = max(REPET,1)
Endif
Return

#-----------------------#
$SETEXP
Local Char    EXPCLE(GLONID1)(1..16)
Local Integer NBEXP , POS
Raz NBEXP , EXPCLE
While CHAINE<>""
 NBEXP += 1
 POS = instr(1,CHAINE,"~")
 If POS
  EXPCLE(NBEXP) = left$(CHAINE,POS-1)
  CHAINE = right$(CHAINE,POS+1)
 Else
  EXPCLE(NBEXP) = CHAINE
  CHAINE = ""
 Endif
Wend
Return

#-----------------------#
$SETCLE
Local Char    CLE(GLONID1)(1..16)
Local Integer NBCLE , POS , TYP(1..16)
CHAINE = [F:ATI]DESCRIPT
Raz NBCLE , CLE
While CHAINE<>""
 NBCLE += 1
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 If I
  CLE(NBCLE) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
 Read [ATZ]CODZONE=[F:ATB]CODFIC;CLE(NBCLE)
 Read [ATY]CODTYP=[F:ATZ]CODTYP
 TYP(NBCLE) = [F:ATY]TYPTYP
Wend
Return

