#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
# SUBSADB : Address entry                                 RMA 04/10/16 #
# -------------------------------------------------------------------- #
# This script is used by screen SAIADR, along with TRTX3 to manage     #
# SAIADR action                                                        #
########################################################################

Subprog S_BPAADD(VALEUR)
#---------------------------#
# Address code selection    #
#---------------------------#
Variable Char    VALEUR()
Call SELADR([M:ADR]BPATYP,[M:ADR]BPANUM,[M:ADR]NAM,VALEUR) From TRTX3
If VALEUR="" VALEUR=BPAADD : mkstat=1 : Endif
End

Subprog C_BPAADD(VALEUR)
#-----------------------#
# Address code control  #
#-----------------------#
Variable Char    VALEUR()
Read [BPA] BPA0=[M:ADR]BPATYP;[M:ADR]BPANUM;VALEUR
If fstat Raz [F:BPA] : mkstat=1 : Endif
End

Subprog AM_BPAADD(VALEUR)
#--------------------------------------------#
# After the modification of the address code #
#--------------------------------------------#
Variable Char    VALEUR()
[M]BPAADD      =[F:BPA]BPAADD
[M]BPAADDLIG(0)=[F:BPA]BPAADDLIG(0)
[M]BPAADDLIG(1)=[F:BPA]BPAADDLIG(1)
[M]BPAADDLIG(2)=[F:BPA]BPAADDLIG(2)
[M]CRY         =[F:BPA]CRY
[M]CRYNAM      =[F:BPA]CRYNAM
[M]SAT         =[F:BPA]SAT
[M]POSCOD      =[F:BPA]POSCOD
[M]CTY         =[F:BPA]CTY
[M]ADBFLG      =1
Affzo [M]
End

Subprog AM_CRY(VALEUR)
#--------------------------------------------#
# After the modification of the country code #
# Update country name                        #
#--------------------------------------------#
Variable Char    VALEUR()
Call LECTEXTRA([M]CRYNAM,"TABCOUNTRY","CRYDES",[F:TCY]CRY,"") From ATEXTRA
Affzo CRYNAM
End

Subprog AS_BPAADD(VALEUR)
Variable Char     VALEUR
#If ADBTRT <>0 : mkstat = 2 : Endif
End


######################################################################################

