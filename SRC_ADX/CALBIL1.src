# Planning (jours de congés consécutifs)

Subprog PLANNING(MATRI,CTR,NBENT,DATDEB,DATFIN,CONGE,NUIT,ALTERNE,PERSO)
Value    Char    MATRI
Value    Char    CTR
Value    Integer NBENT
Value    Date    DATDEB(1..)
Value    Date    DATFIN(1..)
Variable Integer CONGE
Variable Integer NUIT
Variable Integer ALTERNE
Variable Integer PERSO

Local Date    DAT , DEBCTR , FINCTR , SDEB , SFIN , DEBUT , FIN
Local Integer REP , ANNEE , SEMAINE , WOK
Local Integer I , J , K
Local Char    SEMTYP(GLONSTY) , PLNCUR(GLONPLN)
Local Char    TBSEM(GLONSTY)(1..60)
Local Integer NBSEM , NBNAT
Local Decimal NBHRE(1..400)
Local Char    TBNAT(GLONNAT)(1..100)

NBSEM   = 0
ALTERNE = 0
NBNAT   = 0
PERSO   = 0
NUIT    = 0
CONGE   = 1

For I=1 To NBENT

# Tableau des heures travaillées par jour

 Filter [PLE] Where DAT>=DATDEB(I) & DAT<=DATFIN(I)
 Read [PLE]PLE0(1) = MATRI
 Filter [PLE]
 If !fstat     : # Planning opérationnel
  PERSO = 1
  For [PLE]PLE0 Where REFNUM=MATRI & CTRNUM=CTR & DAT>=DATDEB(I) & DAT<=DATFIN(I)
   K = [F:PLE]DAT-DATDEB(I)+1
   If K>0 & K<=dim(NBHRE)
    NBHRE(K) = [F:PLE]NBRHOU
    If NBHRE(K)
     For J=0 To 2
      If [F:PLE]NATCOD(J)<>"" & !find([F:PLE]NATCOD(J),TBNAT(1..NBNAT))
       NBNAT += 1 : TBNAT(NBNAT) = [F:PLE]NATCOD(J)
      Endif
     Next J
    Endif
   Endif
  Next
 Else          : # Planning type
  REP = 0
  DAT = DATDEB(I)
  While DAT<=DATFIN(I)
#MIPEA - 2017-11-26- US X3-63170- START
   If clalev([F:HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif
   Filter [F:HRCTR8] Where [F:HRCTR8]REFNUM = MATRI & [F:HRCTR8]CTRNUM = CTR
   Read [F:HRCTR8] Last
   Filter [F:HRCTR8]
   Call SET_GFIRDAY([F:HRCTR8]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-26- US X3-63170- END
   Call DAT(DAT,ANNEE,SEMAINE) From SUBHRPLN
   Call SEMAINE(ANNEE,SEMAINE,SDEB,SFIN) From SUBHRPLN
   Gosub SETSEM From SUBHRPLN
   If !find(SEMTYP,TBSEM(1..NBSEM))
    NBSEM += 1
    TBSEM(NBSEM) = SEMTYP
   Endif
   For J=1 To 7
    K = (SDEB+J-1) - DATDEB(I) + 1
    If K>0 & K<=dim(NBHRE)
     NBHRE(K) = [F:WTY]NBRHRS1(J-1)
     If NBHRE(K)
      If [F:WTY]NATCOD0(J-1)<>"" & !find([F:WTY]NATCOD0(J-1),TBNAT(1..NBNAT))
       NBNAT += 1 : TBNAT(NBNAT) += [F:WTY]NATCOD0(J-1)
      Endif
      If [F:WTY]NATCOD1(J-1)<>"" & !find([F:WTY]NATCOD1(J-1),TBNAT(1..NBNAT))
       NBNAT += 1 : TBNAT(NBNAT) += [F:WTY]NATCOD1(J-1)
      Endif
      If [F:WTY]NATCOD2(J-1)<>"" & !find([F:WTY]NATCOD2(J-1),TBNAT(1..NBNAT))
       NBNAT += 1 : TBNAT(NBNAT) += [F:WTY]NATCOD2(J-1)
      Endif
     Endif
    Endif
   Next J
   DAT = SFIN+1
  Wend
 Endif

# 2 jours de repos consécutif hebdomadaire

 For K=1 To DATFIN(I)-DATDEB(I)+1 Step 7
  WOK = 0
  For J=0 To 5
   If NBHRE(K+J)=0 & NBHRE(K+J+1)=0
    WOK = 1
   Endif
  Next J
  If !WOK
   CONGE = 0 : Break
  Endif
 Next K

# Travail tout ou partie de nuit

 For J=1 To NBNAT
  Read [NAT]NAT0 = TBNAT(J)
  If find([F:NAT]DAYNGT,2,5)
   NUIT = 1 : Break
  Endif
 Next J

# Horaires alternés

 If PERSO
  If NBSEM>1
   ALTERNE = 1
  Endif
 Endif

Next I
End

#################################################################
# Participation
#################################################################

# Réserve de participation

$RESERVE
RESERVE = 0
If SITE="" & PARTI
 For [PAC] Where CPY=SOCIETE & EXO=EXERCICE & TYPREP=1
  RESERVE += [F:PAC]AMTTOT
 Next
Endif
Return

# Participation individuelle

$PARTICIPE
PARTICIPE = 0
If PARTI
 For [PAI] Where CPY=SOCIETE & REFNUM=MATRI & CTRNUM=CTR & EXO=EXERCICE
  Read [HRREP]REP0 = [F:PAI]CODREP
  If [F:HRREP]TYPREP=1
   PARTICIPE += [F:PAI]AMTGRO
  Endif
 Next
Endif
Return

#################################################################
# Infos diverses
#################################################################
$DIVERS
NBMOIS = 12*(year(DATFIN)-year(DATDEB))+(month(DATFIN)-month(DATDEB))+1
Raz FERIE
# SEGAY 18/01/12 - Spécifique PAIE
#For I2=year(DATDEB) To year(DATFIN)
# #DBA le 25/11/04
# Read [HLY]HLY0 = I2;SITE
# If fstat
#  Read [HLY]HLY0 = I2;""
# Endif
# If !fstat
#  For I1=1 To [F:HLY]NBRDAY
#   If [F:HLY]HLYDAY(I1-1)>=DATDEB & [F:HLY]HLYDAY(I1-1)<=DATFIN
#    FERIE(0) += 1
#    FERIE(dayn([F:HLY]HLYDAY(I1-1))) += 1
#   Endif
#  Next I1
# Endif
#Next I2
If SITE<>""
 Read [FCY]FCY0 = SITE
 Filter [WAR] Where DATWAC<=DATFIN
 Read [WAR]WAR0 Last
 Filter [WAR]
 If fstat<=2
  TAUXAT = [F:WAR]RATWAC
 Endif
Endif
Return

#################################################################
# Lecture des paramètres
#################################################################
$PARAM

# Secteur d'activité

Call PARAM(SOCIETE,"BILSEC",VALPAR) From ADOVAL
SECTEUR = val(VALPAR)
If SECTEUR<1 or SECTEUR>len(mess(0,10503,1)) : SECTEUR = 1 : Endif

# Tables diverses âge, ancienneté, maladie, salaire

For ADI=10503,10504,10505,10506
 NBADI = 0
 For [ADI]CODE Where NUMTAB=ADI
  If NBADI>=MAXCAT
   Call ECR_TRACE(mess(8,10716,1)-num$(ADI)-"("+num$(MAXCAT)+")",1) From GESECRAN
#   Trop de catégories dans la table
   Break
  Endif
  If [F:ADI]N1=0 : [F:ADI]N1 = 999999 : Endif
  NBADI += 1
  Case ADI
   When 503 : TRAGE(NBADI) = [F:ADI]N1
   When 504 : TRANC(NBADI) = [F:ADI]N1
   When 505 : TRMAL(NBADI) = [F:ADI]N1
   When 506 : TRSAL(NBADI) = [F:ADI]N1
  Endcase
 Next
 Case ADI
  When 503 : NBAGE = NBADI
  When 504 : NBANC = NBADI
  When 505 : NBMAL = NBADI : NBACC = NBADI : # FQ74555 - MABON 24/06/11 - Le nombre de lignes dans la table diverse NBACC doit être calculé
  When 506 : NBSAL = NBADI
 Endcase
Next ADI

# Catégorie socio-professionnelle

Call PARAM(SOCIETE,"BILCSP",CSP) From ADOVAL
Call PARAM(SOCIETE,"BILCSPA",VALPAR) From ADOVAL
ADI = val(VALPAR)
Call PARAM(SOCIETE,"BILCSPC",VALPAR) From ADOVAL
COLADI = val(VALPAR)
###46095
Call PARAM(SOCIETE,"BILCSPC2",VALPAR) From ADOVAL
COLADI2 = val(VALPAR)
###
NBCSP = 0
ER = 0
For [ADI]CODE Where NUMTAB=ADI
 If NBCSP>=MAXCAT
  Call ECR_TRACE(mess(8,10716,1)-num$(ADI)-"("+num$(MAXCAT)+")",1) From GESECRAN
#  Trop de catégories dans la table
  Break
 Endif

 ###46905
 #NBCSP += 1
 #TRCSP(NBCSP) = [F:ADI]CODE

 Case COLADI2
  When 1       :
   K = find ([F:ADI]A1,TRCSP(1..NBCSP))
   If K=0
    NBCSP += 1
    TRCSP(NBCSP) = [F:ADI]A1
    Case COLADI
     When 2       : TRCS1(NBCSP) = [F:ADI]N2
     When Default : TRCS1(NBCSP) = [F:ADI]N1
    Endcase
   Else
    Case COLADI
     When 2       : If TRCS1(K)<>[F:ADI]N2 : ER = 1 : Endif
     When Default : If TRCS1(K)<>[F:ADI]N1 : ER = 1 : Endif
    Endcase
   Endif
  When Default :
   K = find ([F:ADI]A2,TRCSP(1..NBCSP))
   If K=0
    NBCSP += 1
    TRCSP(NBCSP) = [F:ADI]A2
    Case COLADI
     When 2       : TRCS1(NBCSP) = [F:ADI]N2
     When Default : TRCS1(NBCSP) = [F:ADI]N1
    Endcase
   Else
    Case COLADI
     When 2       : If TRCS1(K)<>[F:ADI]N2 : ER = 1 : Endif
     When Default : If TRCS1(K)<>[F:ADI]N1 : ER = 1 : Endif
    Endcase
   Endif
 Endcase

 ###
Next
If ER
 Call ECR_TRACE(mess(17,10704,1)-num$(ADI),1) From GESECRAN
# Erreur sur la table diverse no
Endif

#47929 : Tri par ordre alpha + 51312
Sorta NBCSP TRCSP, TRCS1

# Paramètres divers

Call PARAM(SOCIETE,"BILMAL",CODMAL)   From ADOVAL
Call PARAM(SOCIETE,"BILMAT",CODMAT)   From ADOVAL
Call PARAM(SOCIETE,"BILPAT",CODPAT)   From ADOVAL
Call PARAM(SOCIETE,"BILAUT",CODAUTOR) From ADOVAL
Call PARAM(SOCIETE,"BILFOR1",CODFOR1) From ADOVAL
Call PARAM(SOCIETE,"BILFOR2",CODFOR2) From ADOVAL
Call PARAM(SOCIETE,"BILAT",CODAT)     From ADOVAL
Call PARAM(SOCIETE,"BILATJ",CODATJ)   From ADOVAL
Call PARAM(SOCIETE,"BILCHO",CODCHOM)  From ADOVAL
Call PARAM(SOCIETE,"BILINT",CODINT)   From ADOVAL
Call PARAM(SOCIETE,"BILRCL",CODREP1)  From ADOVAL
Call PARAM(SOCIETE,"BILRCC",CODREP2)  From ADOVAL
Call PARAM(SOCIETE,"BILSAL",RUBSAL)   From ADOVAL
Call PARAM(SOCIETE,"BILHRS",RUBHRS)   From ADOVAL
Call PARAM(SOCIETE,"BILCAT",RUBAT)    From ADOVAL
Call PARAM(SOCIETE,"BILREN",RUBREN)   From ADOVAL

#81271 : Chargement de variables pour ventilations supplémentaires
ACTION = "LOAVTL"
Gosub CALL_ACTION

Return

