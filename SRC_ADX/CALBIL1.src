#<AdxTL>@(#)0.0.0.0 $Revision$
Call CALBIL("APS","","2008",[01/01/2008],[31/12/2008],"111","111",1)
End

#############################################################################
## Bilan social : Calcul des éléments de présence (chapitre I)
#############################################################################
# Modifications :
#     FQ81491 - 22/10/13 - Prise en compte date d'effet
#############################################################################

Subprog CALBIL(SOCIETE,SITE,EXERCICE,DATDEB,DATFIN,IDEB,IFIN,TRACE)
Value Char    SOCIETE
Value Char    SITE
Value Char    EXERCICE
Value Date    DATDEB
Value Date    DATFIN
Value Char    IDEB
Value Char    IFIN
Value Integer TRACE

Local Integer MAXIND : MAXIND = 150    : # Maximum d'indicateurs
Local Integer MAXCAT : MAXCAT = 20     : # Maximum de catégories
###46095
Local Char    VALPAR(80)
Local Integer MAXENT                   : # Maximum d'entrées-sortie / salarié
Call PARAM(SOCIETE,"BILNBES",VALPAR) From ADOVAL
MAXENT=val(VALPAR)
If !MAXENT : MAXENT=20 : Endif
###
Local Integer NBSITE
Local Char    TBSITE(GLONFCY)(1..GNBSITE)
Local Integer NBENT
Local Date    DATENT(1..MAXENT) , DATSOR(1..MAXENT)
Local Char    CONTRAT(GLONADI)(1..MAXENT) , CATCONT(2)(1..MAXENT)
Local Integer TYPCONT(1..MAXENT)
Local Integer DEPART(1..MAXENT)
#56926
Local Integer NOUV(1..MAXENT)
Local Char    CATENT(3)(1..MAXENT) , CATSOR(3)(1..MAXENT)
Local Char    TYPENT(GLONADI)(1..MAXENT) , TYPSOR(GLONADI)(1..MAXENT)
Local Char    STATUT(GLONADI)(1..MAXENT) , CATSTA(3)(1..MAXENT)
Local Char    MATRI(GLONEML) , CTR(GLONVCR)
Local Date    DATMAT
Local Integer NBINDIC , FLINDIC(1..MAXIND)
Local Char    INDIC(GLONBIN)(1..MAXIND) , INDICATEUR(GLONBIN)
Local Integer DECIM(1..MAXIND)
Local Integer ILIG(1..MAXIND) , ICOL(1..MAXIND)
Local Integer MLIG(1..MAXIND) , MCOL(1..MAXIND)
Local Decimal TOTAL(1..MAXIND,1..MAXCAT,1..MAXCAT)
Local Char    CRITERE(250)
Local Integer I , J , K , FL0 , FLWR
Local Integer ER , OKIND , OKVAL
Local Integer I1 , I2 , I3
Local Date    DATCUR
Local Char    STDBIL(GLONADC) , SPEBIL(GLONADC) , ACTION(20)
Local Decimal ABSENCE , MALADIE , MATERNITE , PATERNITE
Local Decimal ACCIDENT , ACCTRAJ , NBACC , NBACCJ , ABSAUTOR , AUTABS , CHOMAGE , INTEMP
Local Decimal REPOS1 , REPOS2 , CONGES
Local Integer FLCONGE , NUIT , ALTERNE , PERSO
Local Decimal PARTICIPE , RESERVE
# SEGAY 18/01/12 - Spécifique PAIE
#Local Char    CODMAL(GLONTPS) , CODMAT(GLONTPS) , CODPAT(GLONTPS)
#Local Char    CODAUTOR(GLONTPS) , CODAT(GLONTPS) , CODATJ(GLONTPS) , DEREVT(GLONTPS)
#Local Char    CODFOR1(GLONTPS) , CODFOR2(GLONTPS) , CODCHOM(GLONTPS)
#Local Char    EVENEMENT(GLONTPS) , CODREP1(GLONTPS) , CODREP2(GLONTPS)
#Local Char    CODINT(GLONTPS)
Local Char    CODMAL(5) , CODMAT(5) , CODPAT(5)
Local Char    CODAUTOR(5) , CODAT(5) , CODATJ(5) , DEREVT(5)
Local Char    CODFOR1(5) , CODFOR2(5) , CODCHOM(5)
Local Char    EVENEMENT(5) , CODREP1(5) , CODREP2(5)
Local Char    CODINT(5)


Local Decimal JOURS , HEURES
Local Decimal VALEUR , TABLEAU(1..MAXCAT) , SOMME , MAXI
Local Integer FLMAL , IMAL
# FQ72365 - MABON 17/03/11
Local Integer FLACC, IACC
Local Integer ISAL
Local Decimal DURMAL , MALDUR(1..MAXCAT)
# FQ72365 - MABON 17/03/11
Local Decimal DURACC , ACCDUR(1..MAXCAT)
Local Integer FORM1 , FORM2
Local Date    D1 , D2
Local Date    DATPAY
Local Decimal MASSE , SALAIRE , HTRAV , HSTAGE , TAUXAT , COTISAT , MTBRUT
Local Integer TYPRUB
Local Char    RUBRIQUE(GLONRUB)
Local Decimal MTRUB
Local Integer NOMBRE , PRESENT , PERMANENT , PAYE , NBPAYE
Local Integer DIX , NBPART , RENDEMENT
Local Integer NBOUV , NBOUVMOIS
Local Char    RUBSAL(GLONRUB) , RUBHRS(GLONRUB) , RUBAT(GLONRUB) , RUBREN(GLONRUB)
Local Char    LIBCOL(30)(1..len(mess(0,10501,1)),1..MAXCAT)
Local Char    LIBLIG(30)(1..len(mess(0,10501,1)),1..MAXCAT)
Local Integer TYP , LONG
Local Integer NIND , NEMP , NBMOIS , FERIE(0..7)
Local Char    DIV(GLONBIN)
Local Integer AGE , ANCIEN
Local Integer ISEX , IAGE , IANC , INAT , ICS1 , ICS2
Local Char    CATEG(GLONADI)
Local Integer NBAGE , TRAGE(1..MAXCAT)
Local Integer NBANC , TRANC(1..MAXCAT)
Local Integer NBMAL , TRMAL(1..MAXCAT)
Local Integer NBSAL , TRSAL(1..MAXCAT)
Local Integer NBCSP , ADI , NBADI , COLADI
Local Integer PARTI
Local Integer SECTEUR
Local Char    TRCSP(GLONADI)(1..MAXCAT) , TRCS2(GLONADI)(1..MAXCAT)
Local Integer TRCS1(1..MAXCAT)
Local Char    CSP(80)
Local Integer MOYENNE
Local Integer R
Local Char    BULLETIN(GLONVCR)
###46095
Local Integer COLADI2

# Cause code DNA
Local Integer JADI

#62414
Local Integer PROMU
Local Integer LEVQLF (1..MAXENT)    :# Niveau de qualification
Local Date    CTRDATREF

If clalev([F:ACV])=0 : Local File ACTIV     [ACV] : Endif
Read [ACV]CODACT = "PAR"
If fstat or [F:ACV]FLACT<>2
 PARTI = 0
Else
 PARTI = 1
Endif

Gosub OUVRE From WPDEFTABLE
If clalev([F:FGR])=0  : Local File FACGROUP  [FGR]  : Endif
If clalev([F:ADW])=0  : Local File ADOVAL    [ADW]  : Endif
If clalev([F:WCTR])=0 : Local File EMPLOCTR  [WCTR] : Endif
If clalev([F:WID])=0  : Local File EMPLOID   [WID]  : Endif
If clalev([F:BIN])=0  : Local File BILIND    [BIN]  : Endif
If clalev([F:BIL])=0  : Local File BILRES    [BIL]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV   [ADI]  : Endif
If clalev([F:VEP])=0  : Local File VALEMP    [VEP]  : Endif
If clalev([F:HSP])=0  : Local File HISTOPAYE [HSP]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY  [FCY]  : Endif
If clalev([F:WAR])=0  : Local File TRVACCRAT [WAR]  : Endif
# SEGAY 18/01/12 - Spécifique PAIE
#If clalev([F:TIM])=0  : Local File TIMCOD    [TIM]  : Endif
##58643 : ces tables sont dans le module TC maintenant..
#If clalev([F:TIP])=0  : Local File TIMEMP    [TIP]  : Endif
#If clalev([F:PLN])=0 : Local File PLANTYP   [PLN] : Endif
#If clalev([F:WTY])=0 : Local File TYPWEEK   [WTY] : Endif
#If clalev([F:HLY])=0 : Local File HLYDAY    [HLY] : Endif
#If GTPS
# If clalev([F:TIG])=0 : Local File TIMREGUL  [TIG] : Endif
# If clalev([F:PLE])=0 : Local File PLANEMP   [PLE] : Endif
# If clalev([F:NAT])=0 : Local File NATACTIV  [NAT] : Endif
#Endif
If PARTI
 If clalev([F:PAI])=0 : Local File PARIND    [PAI] : Endif
 If clalev([F:PAC])=0 : Local File PARCOL    [PAC] : Endif
 If clalev([F:HRREP])=0 : Local File REPART    [HRREP] : Endif
Endif
###46095
If clalev([F:ADV])=0 : Local File ATABTAB  [ADV] : Endif
###
If clalev([F:HRNCT])=0  : Local File HRNATCON [HRNCT]  : Endif
If clalev([F:HRXGD])=0  : Local File HRXITGRD [HRXGD]  : Endif
If clalev([F:HRCGD])=0  : Local File HRCTRGRD [HRCGD]  : Endif
If clalev([F:HRCSP])=0  : Local File HRCATCSP [HRCSP]  : Endif

Local Decimal TBSAL(1..nbrecord([ID]))

Gosub PARAM
Gosub DIVERS
STDBIL = "WWBILSOC"
SPEBIL = "SPECALBIL"
Call EXISTE_ADX("","",STDBIL,R) From ORDSYS
If R=0 : STDBIL = "" : Endif
Call EXISTE_ADX("","",SPEBIL,R) From ORDSYS
If R=0 : SPEBIL = "" : Endif

For TYP=1 To len(mess(0,10501,1))
 LONG = 1
 Gosub TEXTES From SUBBIL
 For I=1 To NBTEX
  LIBLIG(TYP,I) = TEXTE(I)
 Next I
 LONG = 0
 Gosub TEXTES From SUBBIL
 For I=1 To NBTEX
  LIBCOL(TYP,I) = TEXTE(I)
 Next I
Next TYP

ACTION = "DEBUT"
Gosub CALL_ACTION

# Lecture des indicateurs à calculer

NBINDIC  = 0
CRITERE  = "SEC("+num$(SECTEUR-1)+")=2"
CRITERE -= "& CALFLG=2 & TXTFLG<>2"
If SITE=""
 CRITERE -= '& CPYFLG=2'
Else
 CRITERE -= '& FCYFLG=2'
Endif
If IDEB<>""
 CRITERE -= '& COD>="'+IDEB+'"'
Endif
If IFIN<>""
 CRITERE -= '& COD<="'+IFIN+'"'
Endif

For [BIN]BIN0 Where evalue(CRITERE)
 INDICATEUR = [F:BIN]COD
 OKIND = 1
 ACTION = "LECTURE"
 Gosub CALL_ACTION
 If OKIND
  If NBINDIC>=MAXIND
   Call ECR_TRACE(mess(4,10716,1)-"("+num$(MAXIND)+")",1) From GESECRAN
#  Trop d'indicateurs à calculer
   Break
  Endif
  NBINDIC += 1
  INDIC(NBINDIC)   = [F:BIN]COD
  FLINDIC(NBINDIC) = 1
  ILIG(NBINDIC)    = [F:BIN]LIG
  ICOL(NBINDIC)    = [F:BIN]COL
  DECIM(NBINDIC)   = [F:BIN]DEC
  Case ILIG(NBINDIC)
   When  1 : MLIG(NBINDIC) = 1
   When  2 : MLIG(NBINDIC) = 2
   When  3 : MLIG(NBINDIC) = NBAGE
   When  4 : MLIG(NBINDIC) = NBANC
   When  5 : MLIG(NBINDIC) = 2
   When  6 : MLIG(NBINDIC) = len(mess(0,10504,1))
   When  7 : MLIG(NBINDIC) = NBCSP
   When  8 : MLIG(NBINDIC) = NBMAL
   When  9 : MLIG(NBINDIC) = NBSAL
   When 10 : MLIG(NBINDIC) = [F:BIN]NBLIG
  Endcase

  #81271 : Chargements complèmentaires des variables std MLIG/MCOL
  ACTION = "LOAIND"
  Gosub CALL_ACTION

  Case ICOL(NBINDIC)
   When  1 : MCOL(NBINDIC) = 1
   When  2 : MCOL(NBINDIC) = 2
   When  3 : MCOL(NBINDIC) = NBAGE
   When  4 : MCOL(NBINDIC) = NBANC
   When  5 : MCOL(NBINDIC) = 2
   When  6 : MCOL(NBINDIC) = len(mess(0,10504,1))
   When  7 : MCOL(NBINDIC) = NBCSP
   When  8 : MCOL(NBINDIC) = NBMAL
   When  9 : MCOL(NBINDIC) = NBSAL
   When 10 : MCOL(NBINDIC) = [F:BIN]NBCOL
  Endcase
  If OKIND=2
   NBINDIC += 1
   INDIC(NBINDIC)   = "@"+[F:BIN]COD
   FLINDIC(NBINDIC) = 1
   ILIG(NBINDIC)    = [F:BIN]LIG
   ICOL(NBINDIC)    = [F:BIN]COL
   MLIG(NBINDIC)    = MLIG(NBINDIC-1)
   MCOL(NBINDIC)    = MCOL(NBINDIC-1)
  Endif
 Endif
Next

If SITE=""
 NBSITE = 0
 For [FGR]FGR0 Where CPY=SOCIETE
  NBSITE += 1
  TBSITE(NBSITE) = [F:FGR]FCY
 Next
Else
 NBSITE = 1
 TBSITE(1) = SITE
Endif

Gosub RESERVE
NBPAYE    = 0 : # Nb de salariés payés en décembre
NEMP      = 0 : # Nb de salariés
NBOUV     = 0 : # Nb d'ouvriers
NBOUVMOIS = 0 : # Nb d'ouvriers payés au mois

# Parcours par salarié

Link [WCTR] With [WID]ID0=[F:WCTR]REFNUM As [LNK]

For [LNK]CTR2(1) Where [F:WID]FLGNEWSAL<>2 : # Salarié
 For [LNK]CTR2(2)                          : # Contrat
  NBENT = 0
  Raz [L]DATENT, [L]DATSOR, [L]TYPENT, [L]CATENT, [L]DEPART, [L]TYPSOR,[L]CATSOR
  Raz [L]CONTRAT, [L]CATCONT, [L]TYPCONT
  Raz [L]STATUT, [L]CATSTA
  Raz [L]LEVQLF
  Raz [L]NOUV

  #81271 : RAZ de variables spécifiques
  ACTION = "RAZVARCTR"
  Gosub CALL_ACTION

  For [LNK]CTR2

   # Multi_leg & multi_société
   Call LECTURE("FCY",[F:WCTR]ETRFCY,"") From CONTOBJ
   Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
   GSOCIETE=[F:CPY]CPY
   GCURLEG=[F:CPY]LEG

   # FQ81491 - 22/10/13 - Prise en compte date d'effet
#   If find([F:WCTR]ETRFCY,TBSITE(1..NBSITE)) & [F:WCTR]CTRDAT<=DATFIN
#&   & ([F:WCTR]XITDAT=[0/0/0] or [F:WCTR]XITDAT>=DATDEB)
   If find([F:WCTR]ETRFCY,TBSITE(1..NBSITE)) & ([F:WCTR]CTRDAT<=DATFIN | ([F:WCTR]FLGRET=2 & [F:WCTR]RETDATEFF<=DATFIN))
&   & ([F:WCTR]XITDAT=[0/0/0] or [F:WCTR]XITDAT>=DATDEB)
    If NBENT>=MAXENT
     Call ECR_TRACE(mess(5,10716,1)-[F:WID]REFNUM-"("+num$(MAXENT)+")",1) From GESECRAN
#     Trop d'entrées-sorties
     Break
    Endif

   #Exclure les VAR en entrée
    Read [HRCGD]HRCGD0 = [F:WCTR]CTRGRD;GCURLEG
    If [F:HRCGD]CODN4H<>'095'
     NBENT += 1
     # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#     DATENT(NBENT) = max(DATDEB,[F:WCTR]CTRDAT)
     CTRDATREF=[F:WCTR]CTRDAT
     If [F:WCTR]FLGRET=2 & [F:WCTR]RETDATEFF<>[0/0/0] Then
      CTRDATREF=[F:WCTR]RETDATEFF
     Endif
     DATENT(NBENT) = max(DATDEB,CTRDATREF)
     # Fin FQ81491
     DATSOR(NBENT) = DATFIN
     # Entrée
     TYPENT(NBENT)  = [F:WCTR]CTRGRD
     CATENT(NBENT)  = [F:HRCGD]CODN4H
     # 56926 : nouvelle embauche
#     If [F:WCTR]CTRDAT>=DATDEB & [F:WCTR]CTRDAT<=DATFIN
     If CTRDATREF>=DATDEB & CTRDATREF<=DATFIN
      NOUV(NBENT) = 1
     Endif
     # fin 56926
     If [F:WCTR]XITDAT<>[0/0/0] & [F:WCTR]XITDAT<=DATFIN
      # Cause code DNA
      # BY 20/10/2009
      Call SIMPLEREAD([F:WCTR]XITGRD,GCURLEG,GERRHRM) From SUBHRXGD
      If !GERRHRM
        JADI=instr (1,[F:HRXGD]CODN4H,"|")
        If JADI
         CATSOR(NBENT)=seg$([F:HRXGD]CODN4H,1,JADI-1)
        Else
         CATSOR(NBENT)  = [F:HRXGD]CODN4H
        Endif
      Endif
      DATSOR(NBENT) = [F:WCTR]XITDAT
      # Sortie
      DEPART(NBENT)  = [F:WCTR]XITFNL
      TYPSOR(NBENT)  = [F:WCTR]XITGRD
     Endif

     # Contrat
     CONTRAT(NBENT) = [F:WCTR]NATCON

     Call SIMPLEREAD([F:WCTR]NATCON,GCURLEG,GERRHRM) From SUBHRNCT
     If !GERRHRM
      # Cause code DNA
      JADI=instr (1,[F:HRNCT]CODN4H,"|")
      If JADI
       CATCONT(NBENT)=seg$([F:HRNCT]CODN4H,1,JADI-1)
      Else
       CATCONT(NBENT) = [F:HRNCT]CODN4H
      Endif
     Endif

     TYPCONT(NBENT) = [F:WCTR]TYPJOB

     # Statut professionnel
     STATUT(NBENT)  = [F:WCTR]CATJOB
     Read [ADI]CODE = 10357;[F:WCTR]CATJOB
     CATSTA(NBENT)  = [F:ADI]A1

     #62414
     Call SIMPLEREAD([F:WCTR]CATCSP, GCURLEG, GERRHRM) From SUBHRCSP
     LEVQLF(NBENT)  = [F:HRCSP]LEVNUM

     #81271 : Initialisation de variables spécifiques
     ACTION = "SETVARCTR"
     Gosub CALL_ACTION

    Endif
   Endif
  Next
  If NBENT
   Gosub SALARIE
  Endif
 Next : # Contrat
Next  : # Salarié

# Moyennes

For I=1 To NBINDIC
 If FLINDIC(I) &  left$(INDIC(I),1)<>"@"
  INDICATEUR = INDIC(I)
  ACTION = "MOYENNE"
  MOYENNE = 0
  Gosub CALL_ACTION
  If !MOYENNE
   I1 = find("@"+INDIC(I),INDIC(1..NBINDIC))
   If I1
    For J=1 To MLIG(I)
     For K=1 To MCOL(I)
      If TOTAL(I1,J,K)
       TOTAL(I,J,K) /= TOTAL(I1,J,K)
      Endif
     Next K
    Next J
   Endif
  Endif
  For J=1 To MLIG(I)
   For K=1 To MCOL(I)
    TOTAL(I,J,K) = arr(TOTAL(I,J,K),10^(-DECIM(I)))
   Next K
  Next J
 Endif
Next I

# Ecriture

ACTION = "FIN"
Gosub CALL_ACTION

Call DEBTRANS From GLOCK
Gosub TR1

End

# Appel des actions STD/SPE

$CALL_ACTION
Onerrgo ERREUR
If STDBIL<>""
 Gosub ACTION From =STDBIL
Endif
If SPEBIL<>""
 Gosub ACTION From =SPEBIL
Endif
Onerrgo
Return

$ERREUR
Call ECR_TRACE(errp-num$(errl)-errmes$(errn)-errm,1) From GESECRAN
Resume

# Ecriture table BILRES

$TR1
GOK = 1
If TRACE
 Call ECR_TRACE(mess(6,10716,1),0) From GESECRAN : # Indicateurs calculés
Endif
NIND = 0
Trbegin [BIL]
 For I=1 To NBINDIC
  If FLINDIC(I) & left$(INDIC(I),1)<>"@"
   Read [BIN]BIN0 = INDIC(I)
   Delete [BIL] Where COD=INDIC(I) & CPY=SOCIETE & FCY=SITE & EXE=EXERCICE
   If fstat=1
    GOK = -1 : GLOCK = "$BILRES"-INDIC(I)-SOCIETE-SITE-EXERCICE : Break
   Endif
   FLWR = 0
   For J=1 To MLIG(I)
    For K=1 To MCOL(I)
     Raz [F:BIL]
     [F:BIL]COD = INDIC(I)
     [F:BIL]CPY = SOCIETE
     [F:BIL]FCY = SITE
     [F:BIL]EXE = EXERCICE
     [F:BIL]LIG = J
     [F:BIL]COL = K
     If [F:BIN]LIG<>10
      [F:BIL]LIBLIG = LIBLIG([F:BIN]LIG,J)
     Else
      [F:BIL]LIBLIG = [F:BIN]LIBLIG(J-1)
     Endif
     If [F:BIN]COL<>10
      [F:BIL]LIBCOL = LIBCOL([F:BIN]COL,K)
     Else
      [F:BIL]LIBCOL = [F:BIN]LIBCOL(K-1)
     Endif
     [F:BIL]VALEUR = TOTAL(I,J,K)
     [F:BIL]CREDAT = date$
     [F:BIL]CREUSR = GUSER
     [F:BIL]CRETIM = time
     [F:BIL]AUT    = 2
     Write [BIL]
     If fstat
      GOK = 0 : Call FSTA("BIL") From GLOCK : Break 3
     Endif
     If [F:BIL]VALEUR<>0 : FLWR += 1 : Endif
    Next K
   Next J
   If TRACE
    Call ECR_TRACE(INDIC(I)-[F:BIN]DES-"("+num$(FLWR)+")",0) From GESECRAN
   Endif
   NIND += 1
  Endif
 Next I
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
If GOK=1
 If TRACE
  Call ECR_TRACE("",0) From GESECRAN
 Endif
 Call ECR_TRACE(num$(NEMP)-mess(17,10716,1),0) From GESECRAN : # Salariés parcourus
 Call ECR_TRACE(num$(NIND)-mess(6,10716,1),0) From GESECRAN : # Indicateurs calculés
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#################################################################
# Calculs pour un salarié
#################################################################
$SALARIE
MATRI  = [F:WID]REFNUM
CTR    = [F:WCTR]CTRNUM
DATMAT = DATFIN
Gosub LECEMP From WPDEFTABLE
NEMP += 1
If TRACE & (IDEB<>IFIN or IDEB="")
 Call ECR_TRACE(mess(7,10716,1)-[F:ID]REFNUM-[F:ID]NAM-[F:ID]SRN-"("+mess(23,10716,1)-[F:HRCTR]CTRNUM+")",0) From GESECRAN : # Salarié
Endif
Gosub CATEGORIES
# FQ67756 MABON 21/10/10 - Ajout test sur DEPART(NBENT) : si la sortie n'est pas définitive, on considère que le
# salarié est toujours présent
If DATSOR(NBENT)>=DATFIN | DEPART(NBENT)<>2
 PRESENT = 1
Else
 PRESENT = 0
Endif
#SEGAY 17/12/12 FQ86641
#Si le salarié est présent sur toute la période demandée, (= pas de sortie définitive) qu'il ait 1 fiche contrat ou N
# Il doit être considéré comme un PERMANENT
#If NBENT=1 & DATENT(1)<=DATDEB & DATSOR(1)>=DATFIN
# PERMANENT = 1
#Else
# PERMANENT = 0
#Endif
For I1=1 To NBENT
  If  I1=1
    If DATENT(I1)<=DATDEB & (DATSOR(I1)>=DATFIN | DEPART(I1)<>2)
      PERMANENT = 1
    Else
      PERMANENT = 0 : Break
    Endif
  Else
    If PERMANENT = 1 & (DATSOR(I1)>=DATFIN | DEPART(I1)<>2)
     PERMANENT = 1
    Else
     PERMANENT = 0 : Break
    Endif
  Endif
Next


#62414
If NBENT>1
 For I1=1 To NBENT-1
  #Si pas de sortie définitive entre 2 fiches contrats et evolution du niveau de qualif alors promotion!
  If DEPART(I1)<>2 & LEVQLF(I1)< LEVQLF(I1+1)
   PROMU=1 : Break
  Else
   PROMU=0
  Endif
 Next
Else
 PROMU=0
Endif

Gosub PAYE
Gosub TEMPS
If SITE="" & PARTI
 Gosub PARTICIPE
Endif
For I=1 To NBINDIC
 Case ILIG(I)
  When  1 : J = 1
  When  2 : J = ISEX
  When  3 : J = IAGE
  When  4 : J = IANC
  When  5 : J = INAT
  When  6 : J = ICS1
  When  7 : J = ICS2
  When  8 : J = 0
  When  9 : J = ISAL
  When 10 : J = 0
 Endcase
 Case ICOL(I)
  When  1 : K = 1
  When  2 : K = ISEX
  When  3 : K = IAGE
  When  4 : K = IANC
  When  5 : K = INAT
  When  6 : K = ICS1
  When  7 : K = ICS2
  When  8 : K = 0
  When  9 : K = ISAL
  When 10 : K = 0
 Endcase

 #81271 : Initialisation des indices std J & K en fonction des ventilations complémentaires
 ACTION = "POSIND"
 Gosub CALL_ACTION

 VALEUR = 0
 Raz TABLEAU
 OKVAL = 1
 If left$(INDIC(I),1)="@"
  INDICATEUR = right$(INDIC(I),2)
  ACTION = "DIVISE"
 Else
  INDICATEUR = INDIC(I)
  ACTION = "CALCUL"
 Endif
 Gosub CALL_ACTION
 If OKVAL
  If TRACE & IDEB=IFIN & IDEB<>"" & VALEUR<>0
   Call ECR_TRACE(mess(7,10716,1)-[F:ID]REFNUM-[F:ID]NAM-[F:ID]SRN-"("+INDIC(I)+")"
&  -":"-num$(VALEUR)-"("+num$(J)+","+num$(K)+")",0) From GESECRAN : # Salarié
  Endif
  If J & K
   TOTAL(I,J,K) += VALEUR
  Elsif J
   For K=1 To MCOL(I)
    TOTAL(I,J,K) += TABLEAU(K)
   Next K
  Elsif K
   For J=1 To MLIG(I)
    TOTAL(I,J,K) += TABLEAU(J)
   Next J
  Endif
 Endif
Next I
Return

# Affectation des catégories aux salariés

$CATEGORIES
ISEX = [F:ID]SEX
AGE = year(DATFIN)-year([F:ID]DATBRN)
If    month([F:ID]DATBRN)>month(DATFIN)
&  | (month([F:ID]DATBRN)=month(DATFIN) & day([F:ID]DATBRN)>day(DATFIN))
 AGE -= 1
Endif
IAGE = NBAGE
For I=1 To NBAGE
 If AGE<TRAGE(I)
  IAGE = I : Break
 Endif
Next I
ANCIEN = year(DATFIN)-year([F:HRCTR]DATANC)
If    month([F:HRCTR]DATANC)>month(DATFIN)
&  | (month([F:HRCTR]DATANC)=month(DATFIN) & day([F:HRCTR]DATANC)>day(DATFIN))
 ANCIEN -= 1
Endif
IANC = NBANC
For I=1 To NBANC
 If ANCIEN<TRANC(I)
  IANC = I : Break
 Endif
Next I
If [F:ID]NTT=GPAYS
 INAT = 1
Else
 INAT = 2
Endif
ICS2 = 1
If CSP<>""
 ER = 0
 Onerrgo RIEN

 ###46095
 #CATEG = evalue(CSP)
 # BY 20/10/2009
 Read [ADI]CODE = ADI;evalue(CSP)
 Case COLADI2
  When 1       : CATEG = [F:ADI]A1
  When Default : CATEG = [F:ADI]A2
 Endcase
 ###

 Onerrgo
 If !ER
  ICS2 = find(CATEG,TRCSP(1..NBCSP))
  If ICS2=0 : ICS2 = NBCSP : Endif
 Endif
Endif
ICS1 = TRCS1(ICS2)

#81271 : Initialisation d'indices complémentaires (IXXX)
ACTION = "SETIND"
Gosub CALL_ACTION

Return

$RIEN
ER = errn
Resume

#################################################################
# Calculs liés à la paye
#################################################################
$PAYE
MASSE     = 0
NOMBRE    = 0
SALAIRE   = 0
HTRAV     = 0
HSTAGE    = 0
PAYE      = 0
RENDEMENT = 0
DATPAY    = [0/0/0]
If RUBSAL="" & RUBHRS="" & (SITE<>"" or RUBAT="") : Return : Endif

# Parcours de toutes les payes de la période

For [VEP] Where EMP=MATRI & CTRNUM=CTR & STRDAT<=DATFIN & ENDDAT>=DATDEB

 BULLETIN = [F:VEP]BUL
 If find([F:VEP]FCY,TBSITE(1..NBSITE))
  DATPAY = [F:VEP]PYRDAT

# Masse salariale => Rubrique "RUBSAL"

  If RUBSAL<>""
   TYPRUB = 1 : RUBRIQUE = RUBSAL : Gosub LECRUB : MASSE += MTRUB
# BY 20/10/2009
#  If PERMANENT & TYPCONT(1)=1  & CATCONT(1)="01"     : # Permanent,temps plein et CDI
#   If PERMANENT & [F:HRCTR]RATMIDWRK=0 & CATCONT(1)="01"  : # Permanent,taux TP=0 et CDI
   If PRESENT & [F:HRCTR]RATMIDWRK=0 & CATCONT(1)="01"  : # Présent,taux TP=0 et CDI : FQ67756 MABON 21/10/10
    If month([F:VEP]ENDDAT)=month(DATFIN)             : # Salaire de décembre
     PAYE    = 1
     SALAIRE += MTRUB
     If RUBREN<>""
      TYPRUB = 1 : RUBRIQUE = RUBREN : Gosub LECRUB
      If MTRUB<>0 : RENDEMENT = 1 : Endif
     Endif
    Endif
   Endif
  Endif

# Heures travaillées

  If RUBHRS<>""
   TYPRUB = 1 : RUBRIQUE = RUBHRS : Gosub LECRUB : HTRAV += MTRUB

# Heures de stage (rémunérées...)

   For I1=1 To NBENT
    If find(CATCONT(I1),"09","10","11")
&    & [F:VEP]STRDAT<=DATSOR(I1) & [F:VEP]ENDDAT>=DATENT(I1)
     HSTAGE += MTRUB : Break
    Endif
   Next I1
  Endif

# Cotis accident du travail

  If SITE<>"" & RUBAT<>""
   TYPRUB = 2 : RUBRIQUE = RUBAT : Gosub LECRUB : COTISAT += MTRUB
  Endif

  #81271 : Initialisation de variables spécifiques
  ACTION = "SETVARVEP"
  Gosub CALL_ACTION

 Endif : # (site)
Next : # [VEP]
If DATPAY=[0/0/0] : Return : Endif

# Nombre de fin de mois où le salarié est présent

For I1=1 To NBENT
 DATCUR = eomonth(DATENT(I1))
 While DATCUR<=DATSOR(I1)
  NOMBRE += 1
  DATCUR = eomonth(DATCUR+1)
 Wend
Next I1

# Tableau des salaires (pour 10+gros et rapport des 10%)

If PAYE
 NBPAYE += 1
 TBSAL(NBPAYE) = SALAIRE

# Grille de salaire

 ISAL = NBSAL
 For I2=1 To NBSAL
  If SALAIRE<TRSAL(I2)
   ISAL = I2 : Break
  Endif
 Next I2
Endif

Return

$LECRUB
MTRUB = 0
Read [HSP]HSP3 = BULLETIN;RUBRIQUE;TYPRUB
If !fstat
 MTRUB += [F:HSP]AMT
Endif
Read [HSP]HSP3 = BULLETIN;RUBRIQUE;TYPRUB+6
If !fstat
 MTRUB += [F:HSP]AMT
Endif
Return

