Raz ABSENCE,MALADIE,MATERNITE,PATERNITE,ACCIDENT,ACCTRAJ,ABSAUTOR,AUTABS,NBACCJ#,NBACC : # FQ74555 - MABON 24/06/11 - Le nombre de lignes NBACC n'a pas être raz ici
Raz MALDUR,FORM1,FORM2,CHOMAGE,INTEMP,REPOS1,REPOS2,CONGES,ACCDUR : # FQ74555 - MABON 24/06/11 - Ajout RAZ de ACCDUR
FLMAL  = 0
DURMAL = 0
