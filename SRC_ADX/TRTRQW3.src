#########################################################################################################
#   Fenêtre générique de sélection d'un site tiers                  Module CRM             2 avril 2003 #
#########################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When "OK"           : Gosub ONOK
 When Default
Endcase
Return


$OUVRE
Return

$DEFBOUT
Return

$SETBOUT
Return

$OUVRE_BOITE
Return

$DEBUT
Return

$AV_CHOIX
Return

AP_CHOIX
Return

$AVANT_BOUTON
Return

$FINSAI
#Nettoie l'écran avant de partir.
Raz [M:RQW3]
Return

$FIN
Return

$ABANDON
Return

$APRES_MODIF
Return

$BOUTON
Return

$ONMENU
Return

$ONOK
Local Integer INBLINE
Local Integer ITER
Local Integer ISERIAL
ITER = 0
INBLINE = 0
ISERIAL = 0

Read [ITM] ITM0 = [M:RQW1]ITMREF(val(PARAM(1)))
If fstat
    ISERIAL = 1
Else
    If [F:ITM]STOMGTCOD = 1
        #Article non géré en stock
        ISERIAL = 0
    Else
        #Article géré en stock
        If [F:ITM]SERMGTCOD = 1 
            ISERIAL = 0
        Else
            ISERIAL = 1
        Endif
    Endif
Endif

For ITER = 0 To dim([M:RQW1]ITMREF) - 1

    If INBLINE = [M:RQW3]GNRQTY : Break : Endif

    If [M:RQW1]ITMREF(ITER) = ""
        [M:RQW1]ITMREF(ITER) = [M:RQW1]ITMREF(val(PARAM(1)))
        [M:RQW1]MACSERNUM(ITER) = ""
        If ISERIAL
            Actzo [M:RQW1]MACSERNUM(ITER)
        Else
            Grizo [M:RQW1]MACSERNUM(ITER)
        Endif
        [M:RQW1]QTY(ITER) = 1
        [M:RQW1]MACBPCDAT(ITER) = [M:RQW1]MACBPCDAT(val(PARAM(1)))
        [M:RQW1]MACBPCPRI(ITER) = [M:RQW1]MACBPCPRI(val(PARAM(1)))
        [M:RQW1]MACBPCCUR(ITER) = [M:RQW1]MACBPCCUR(val(PARAM(1)))
        [M:RQW1]RSL(ITER) = [M:RQW1]RSL(val(PARAM(1)))
        [M:RQW1]PLE(ITER) = [M:RQW1]PLE(val(PARAM(1)))
        [M:RQW1]MACBRA(ITER) = [M:RQW1]MACBRA(val(PARAM(1)))
        INBLINE += 1
    Endif
Next

[M:RQW1]NBLIG += INBLINE

Affzo [M:RQW1]
Return


