#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management LTPAR1

######################################################################################
$ACTION

Case ACTION
  When "INIT"        : Gosub INIT
  When "EXEC"        : Gosub EXEC
  When "SORTIE"      : Gosub SORTIE
  When Default
Endcase

Return
######################################################################################
$INIT
  Local Mask LTPAR1 [LTPAR1]

  If  !clalev([F:LTP])  : Local File LTAPAR    [LTP] : Endif

  Lock [LTP]
  If fstat
    GBIDI1    = 1  # Lock out other users
    GCONSDIA  = 1  # This is to lock the fields
  Else
    GBIDI1    = 0
    GCONSDIA  = 0
  Endif

  #Read current folder parameters
  Read [LTP]LTP0= nomap
  If fstat
   #new record so lets set defaults and save so they appear on screen
   Trbegin [LTP]
   Raz [F:LTP]
   [F:LTP]DOSSIER = nomap
   [F:LTP]AVRREQ = 2    # Y - require Validation
   [F:LTP]CLCALL  = 2   # Y - calculate all Documents
   [F:LTP]USEPRDURL = 1 # Use Test
   Write [F:LTP]
   If !fstat
     Commit
   Else
     Rollback
     Call RSTA("LTP",nomap) From GLOCK
     OK=0
    Endif
  Else  # Record existed
    [M:LTPAR1]  = [F:LTP]

    # Country Block
    [M:LTPAR1]NBCRY = find("",[M:LTPAR1]CRY(0..dim([M:LTPAR1]CRY)-1)) # Number of Countries
    If [M:LTPAR1]NBCRY > 0 : [M:LTPAR1]NBCRY -= 1 : Endif
    Affzo [M:LTPAR1]NBCRY
  Endif

Return
######################################################################################
$EXEC
  If !GBIDI1
    Call DEBTRANS From GLOCK
    Gosub TR1
  Endif
Return
######################################################################################
$TR1
  GOK = 1
  Trbegin [LTP]
  Readlock [LTP]LTP0 = nomap
  If fstat=1
    GOK = -1 : GLOCK = "$LTAPAR" : Goto ROLL_TR1
  Endif

  [F:LTP] = [M:LTPAR1]

  Rewrite [LTP]

  If fstat
    GOK = 0 : Call FSTA("LTP") From GLOCK : Goto AB_TR1
  Else
    Commit
  Endif
Return
######################################################################################
$AB_TR1
  Rollback
Return
######################################################################################
$ROLL_TR1
  Rollback
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR1 : Endif
######################################################################################
$SORTIE
If !GBIDI1
  Read [LTP]LTP0 First
  If fstat
    Gosub EXEC
  Endif
  Unlock [LTP]
Endif
Raz GBIDI1
Raz GCONSDIA

Return
######################################################################################
Subprog CL_APING(VALEUR)
Variable Char    VALEUR()
Local Char ERRMSG(250)
Local Integer ERR
Local Clbfile PING_RESULT(25)

  Call SST_PING(PING_RESULT,ERR,ERRMSG) From SSTLIB   # Ping Sage Tax

  # Show result - Err and Errmsg are handled, logged, dispalyed in SST_PING
  # result may contain avatax error or standard ping  error for user.
  If ERR
    Call MESSAGE(ERRMSG)  From GESECRAN
  Else
    Call MESSAGE(PING_RESULT) From GESECRAN
  Endif
End

