#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion des campagnes marketing        Module CRM     03/11/2000
#
#   LOAD_OPG   : Chargement du tableau des opérations marketing associées.
#
#   CAL_BUD_OPG  : Calcul du budget engagé pour une campagne
#   DISPICON   : Affichage des icônes
#   SAVECLOB   : Enregistrement des CLOBs
#   DELCLOB    : Suppression des CLOBs
#   LOADCLOB   : Chargement du CLOB compte-rendu
#LSE 17/10/2005
#   CLOOPGCL   : Cloture de toutes les opérations appels d'une campagne
#   CMGCTRLFCY   : verifie que le site est bien en phase avec celui de la campagne
#   CMGCTRLDATEDEB  : verifie que la date de début est  en phase avec celle de la campagne
#   CMGCTRLDATEFIN  : verifie que la date de fin est  en phase avec celle de la campagne
#   CMGINIDATES  : Initialise les dates début fin opération par rapport à celles de la campagne
##########################################################################################################
##########################################################################################################
# Chargement du tableau des opérations marketing associées.
###########################################################
Subprog LOAD_OPG
Local Integer INBLIG
Local Decimal ITOTBUD
Local Decimal IBUD1
Local Decimal IBUD2

  INBLIG = 0
  ITOTBUD = 0
  IBUD1 = 0
  IBUD2 = 0
  Raz [M:CMG1]BUDCMM
  Raz [M:CMG1]OPEMKGNUM
  Raz [M:CMG1]OPEMKGTYP
  Raz [M:CMG1]OPEMKGSTR
  Raz [M:CMG1]OPEMKGDES
  Raz [M:CMG1]NBLIG
  If [M:CMG0]NUM = "" Then
    End
  Endif
  Filter [OMM] Where [F:OMM]CMGNUM = [M:CMG0]NUM Order By [F:OMM]CREDAT Desc
  For [OMM] Hint Key OMM1
    If INBLIG >= dim([M:CMG1]OPEMKGNUM)-1 Then
      Break
    Endif
    [M:CMG1]OPEMKGNUM(INBLIG) = [F:OMM]OMMNUM
    [M:CMG1]OPEMKGTYP(INBLIG) = 1
    [M:CMG1]OPEMKGSTR(INBLIG) = [F:OMM]SHIDAT
    [M:CMG1]OPEBUD(INBLIG) = [F:OMM]BUD
    [M:CMG1]OPECUR(INBLIG) = [F:OMM]CUR
    [M:CMG1]OPEMKGDES(INBLIG) = [F:OMM]DES
    Call SETBUD([M:CMG1]CUR, [F:OMM]CUR, [F:OMM]FCY, [F:OMM]BUD, IBUD1) From TRTPLGB
    [M:CMG1]BUDCMM += IBUD1
    INBLIG += 1
  Next
  Filter [OMM]
  Filter [OMP] Where [F:OMP]CMGNUM = [M:CMG0]NUM Order By [F:OMP]OMPSTR Desc
  For [OMP] Hint Key OMP1
    If INBLIG >= dim([M:CMG1]OPEMKGNUM)-1 Then
      Break
    Endif
    [M:CMG1]OPEMKGNUM(INBLIG) = [F:OMP]OMPNUM
    [M:CMG1]OPEMKGTYP(INBLIG) = 2
    [M:CMG1]OPEMKGSTR(INBLIG) = [F:OMP]OMPSTR
    [M:CMG1]OPEBUD(INBLIG) = [F:OMP]BUD
    [M:CMG1]OPECUR(INBLIG) = [F:OMP]CUR
    [M:CMG1]OPEMKGDES(INBLIG) = [F:OMP]DES
    Call SETBUD([M:CMG1]CUR, [F:OMP]CUR, [F:OMP]FCY, [F:OMP]BUD, IBUD1) From TRTPLGB
    [M:CMG1]BUDCMM += IBUD1
    INBLIG += 1
  Next
  Filter [OMP]
  Filter [OMT] Where [F:OMT]CMGNUM = [M:CMG0]NUM Order By [F:OMT]OMTSTR Desc
  For [OMT] Hint Key OMT1
    If INBLIG >= dim([M:CMG1]OPEMKGNUM)-1 Then
      Break
    Endif
    [M:CMG1]OPEMKGNUM(INBLIG) = [F:OMT]OMTNUM
    [M:CMG1]OPEMKGTYP(INBLIG) = 3
    [M:CMG1]OPEMKGSTR(INBLIG) = [F:OMT]OMTSTR
    [M:CMG1]OPEBUD(INBLIG) = [F:OMT]BOOCST + [F:OMT]OTHCST
    [M:CMG1]OPECUR(INBLIG) = [F:OMT]CUR
    [M:CMG1]OPEMKGDES(INBLIG) = [F:OMT]DES
    Call SETBUD([M:CMG1]CUR, [F:OMT]CUR, [F:OMT]FCY, [F:OMT]BOOCST, IBUD1) From TRTPLGB
    Call SETBUD([M:CMG1]CUR, [F:OMT]CUR, [F:OMT]FCY, [F:OMT]OTHCST, IBUD2) From TRTPLGB
    ITOTBUD = IBUD1 + IBUD2
    [M:CMG1]BUDCMM += ITOTBUD
    INBLIG += 1
  Next
  Filter [OMT]
  Filter [OMN] Where [F:OMN]CMGNUM = [M:CMG0]NUM Order By [F:OMN]OMNSTR Desc
  For [OMN] Hint Key OMN1
    If INBLIG >= dim([M:CMG1]OPEMKGNUM)-1 Then
      Break
    Endif
    [M:CMG1]OPEMKGNUM(INBLIG) = [F:OMN]OMNNUM
    [M:CMG1]OPEMKGTYP(INBLIG) = 4
    [M:CMG1]OPEMKGSTR(INBLIG) = [F:OMN]OMNSTR
    [M:CMG1]OPEBUD(INBLIG) = [F:OMN]BUD
    [M:CMG1]OPECUR(INBLIG) = [F:OMN]CUR
    [M:CMG1]OPEMKGDES(INBLIG) = [F:OMN]DES
    Call SETBUD([M:CMG1]CUR, [F:OMN]CUR, [F:OMN]FCY, [F:OMN]BUD, IBUD1) From TRTPLGB
    [M:CMG1]BUDCMM += IBUD1
    INBLIG += 1
  Next
  Filter [OMN]
  [M:CMG1]NBLIG = INBLIG
  Sorta [M:CMG1]NBLIG [M:CMG1]NBLIG Order By [M:CMG1]OPEMKGSTR(indice) Desc  # FGR 19/12/2013 : X3SUIVI92373
  Affzo [M:CMG1]1-99
End

##########################################################################################################
#Calcul du budget engagé pour une campagne
Subprog CAL_BUD_OPG (SZCMGNUM, SZCUR, MTPRE, MTENG, SZMESSAGE, IBRETOUR)
Value Char SZCMGNUM
Value Char SZCUR
Variable Decimal MTPRE
Variable Decimal MTENG
Variable Char SZMESSAGE
Variable Integer IBRETOUR

Local Decimal MTTOTENG
Local Decimal MTVALEUR

  Raz SZMESSAGE
  IBRETOUR = 1
  MTTOTENG = 0
  MTVALEUR = 0
  If SZCMGNUM = "" or SZCUR = "" Then
    MTBUDPRE = 0
    MTBUDENG = 1
    End
  Endif
  Filter [OMM] Where [F:OMM]CMGNUM = SZCMGNUM
  For [OMM] Hint Key OMM1
    Raz MTVALEUR
    Call SETBUD(SZCUR, [F:OMM]CUR, [F:OMM]FCY, [F:OMM]BUD, MTVALEUR) From TRTPLGB
    MTTOTENG = MTTOTENG + MTVALEUR
  Next
  Filter [OMM]
  Filter [OMP] Where [F:OMP]CMGNUM = SZCMGNUM
  For [OMP] Hint Key OMP1
    Raz MTVALEUR
    Call SETBUD(SZCUR, [F:OMP]CUR, [F:OMP]FCY, [F:OMP]BUD, MTVALEUR) From TRTPLGB
    MTTOTENG = MTTOTENG + MTVALEUR
  Next
  Filter [OMP]
  Filter [OMT] Where [F:OMT]CMGNUM = SZCMGNUM
  For [OMT] Hint Key OMT1
    Raz MTVALEUR
    Call SETBUD(SZCUR, [F:OMT]CUR, [F:OMT]FCY, [F:OMT]BOOCST, MTVALEUR) From TRTPLGB
    MTTOTENG = MTTOTENG + MTVALEUR
    Raz MTVALEUR
    Call SETBUD(SZCUR, [F:OMT]CUR, [F:OMT]FCY, [F:OMT]OTHCST, MTVALEUR) From TRTPLGB
    MTTOTENG = MTTOTENG + MTVALEUR
  Next
  Filter [OMT]
  Filter [OMN] Where [F:OMN]CMGNUM = SZCMGNUM
  For [OMN] Hint Key OMN1
    Raz MTVALEUR
    Call SETBUD(SZCUR, [F:OMN]CUR, [F:OMN]FCY, [F:OMN]BUD, MTVALEUR) From TRTPLGB
    MTTOTENG = MTTOTENG + MTVALEUR
  Next
  Filter [OMN]
  MTENG = MTTOTENG
End

##########################################################################################################
#Affichage des icônes
######################################################
$DISPICON
  Gosub DEFICONNUM From CRMUTIL150
  #Synthèse Objet de l'action
  If len([M:CMG2]FULOBJ) > GLONCLE Then
    If [M:CMG2]OBJFLG Then
      [M:CMG2]OBJICO = SZICOSYNDON
    Else
      [M:CMG2]OBJICO = SZICOSYN
    Endif
    Actzo [M:CMG2]OBJICO
  Else
    [M:CMG2]OBJICO = "-1"
    Grizo [M:CMG2]OBJICO
  Endif
Return

##########################################################################################################
#Enregistrement des CLOBs
######################################################
$SAVECLOB
Local Char SZCTLCLOB(250)

  Gosub DELCLOB
  If GOK < 1 Then
    Return
  Endif
  #Objet de l'action
  Raz SZCTLCLOB
  Setlob SZCTLCLOB With [M:CMG2]FULOBJ
  If SZCTLCLOB <> "" Then
    Raz [F:HD5]
    [F:HD5]NUM = [M:CMG2]NUMFULOBJ
    [F:HD5]TYP = [M:CMG2]TYPFULOBJ
    [F:HD5]CLOB = [M:CMG2]FULOBJ
    Write [HD5]
    If fstat Then
      #Erreur lors de l'enregistrement de la description de la campagne. Transaction abandonnée.
      GMESSAGE = mess(877,182,1)
      GERR = 1
      Call FSTA("HD5") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
######################################################
$DELCLOB
  Delete [HD5] Where [F:HD5]NUM = [M:CMG2]NUMFULOBJ and [F:HD5]TYP = [M:CMG2]TYPFULOBJ
  If fstat Then
    #Erreur lors de la suppression de la description de la campagne. Transaction abandonnée.
    GMESSAGE = mess(878,182,1)
    GERR = 1
    Call FSTA("HD5") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
# Chargement du CLOB
######################################################
$LOADCLOB
Local Integer ILOOKFORCLOB

  ILOOKFORCLOB = 1
  If [M:CMG2]NUMFULOBJ = "" Then
    Raz [M:CMG2]FULOBJ
    ILOOKFORCLOB = 0
  Endif
  If [M:CMG2]TYPFULOBJ = "" Then
    Raz [M:CMG2]FULOBJ
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD5]HD50=[M:CMG2]NUMFULOBJ;[M:CMG2]TYPFULOBJ
    If fstat Then
      Raz [M:CMG2]FULOBJ
    Else
      [M:CMG2]FULOBJ = [F:HD5]CLOB
    Endif
  Endif
Return

##########################################################################################################
# Modification du clob
######################################################
Subprog MNGUPDCLOB(SZTYPCLOB, SZNUMCLOB)
Value Char SZTYPCLOB
Value Char SZNUMCLOB

Local Char SZCLE(GLONCLL)
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF
Local Char SZMESS(250)
Local Integer IMESSREP
Local Integer IASKUPDCLOB

  IASKUPDCLOB = 0
  IMESSREP = 0
  If SZTYPCLOB = "CMG" Then
    If [M:CMG0]PREFULOBJ = [M:CMG2]FULOBJ Then
      End
    Endif
    #La description de cette campagne marketing a été modifiée.
    #Souhaitez-vous conserver l'ancien texte sur les appels générés et effectués ?
    SZMESS = mess(978,182,1) - mess(979,182,1)
    #On vérifie s'il y a des appels effectués pour cette campagne marketing
    Filter [OMP] Where [F:OMP]CMGNUM = [M:CMG0]NUM
    For [OMP]
      Filter [CLL] Where [F:CLL]CLLCMGNUM = [F:OMP]CMGNUM and [F:CLL]CLLOPGNUM = [F:OMP]OMPNUM and [F:CLL]CLLOPGTYP = "OMP" and [F:CLL]CLLCMGFLG > 0
&                    and [F:CLL]CLLDON = 2 and [F:CLL]TYPFULOBJ <> "CLLOBJ"
      For [CLL]CLL6
        IASKUPDCLOB = 1
        Break
      Next
      Filter [CLL]
      If IASKUPDCLOB Then
        Break
      Endif
    Next
    Filter [OMP]
  Elsif SZTYPCLOB = "OMP" Then
    If [M:OMP0]PREFULOBJ = [M:OMP1]FULOBJ Then
      End
    Endif
    #L'objectif de cette campagne d'appels a été modifié.
    #Souhaitez-vous conserver l'ancien texte sur les appels générés et effectués ?
    SZMESS = mess(980,182,1) - mess(979,182,1)
    Filter [CLL] Where [F:CLL]CLLCMGNUM = [M:OMP0]CMGNUM and [F:CLL]CLLOPGNUM = [M:OMP0]OMPNUM and [F:CLL]CLLOPGTYP = "OMP" and [F:CLL]CLLCMGFLG > 0
&                  and [F:CLL]CLLDON = 2 and [F:CLL]TYPFULOBJ <> "CLLOBJ"
    For [CLL]CLL6
      IASKUPDCLOB = 1
      Break
    Next
    Filter [CLL]
  Endif
  If IASKUPDCLOB = 0 Then
    End
  Endif
  Call OUINON(SZMESS, IMESSREP) From GESECRAN
  If IMESSREP <> 2 Then
    End
  Endif
  SZCLE = ""
  ICUT = 2500
  ICLECOUNT = ICUT
  IPERF = 0
  INTR = 0
  While ICLECOUNT >= ICUT
    ICLECOUNT = 0
    Filter [CLL] Where [F:CLL]CLLDON = 2 and [F:CLL]CLLCMGFLG > 0 and [F:CLL]TYPFULOBJ = SZTYPCLOB and [F:CLL]NUMFULOBJ = SZNUMCLOB and [F:CLL]CLLNUM > SZCLE
    For [CLL]CLL0
      SZCLE = [F:CLL]CLLNUM
      If IPERF = 0 Then
        Trbegin [CLL], [HD5]
        INTR = 1
      Endif
      #Création du clob
      Raz [F:HD5]
      [F:HD5]NUM = [F:CLL]CLLNUM
      [F:HD5]TYP = "CLLOBJ"
      If SZTYPCLOB = "CMG" Then
        [F:HD5]CLOB = [M:CMG0]PREFULOBJ
      Elsif SZTYPCLOB = "OMP" Then
        [F:HD5]CLOB = [M:OMP0]PREFULOBJ
      Endif
      Write [HD5]
      If fstat Then
        #Erreur lors de l'enregistrement de l'ancien texte sur les appels effectués.
        GMESSAGE = mess(981,182,1)
        GERR = 1
        Rollback
        INTR = 0
        Break
      Endif
      [F:CLL]TYPFULOBJ = "CLLOBJ"
      [F:CLL]NUMFULOBJ = [F:CLL]CLLNUM
      If SZTYPCLOB = "CMG" Then
        [F:CLL]CLLOBJ = [M:CMG0]PREDES
        [F:CLL]OBJFLG = [M:CMG2]OBJFLG
      Elsif SZTYPCLOB = "OMP" Then
        [F:CLL]CLLOBJ = [M:OMP0]PREOBJ
        [F:CLL]OBJFLG = [M:OMP1]OBJFLG
      Endif
      Rewrite [CLL]
      If fstat Then
        #Erreur lors de l'enregistrement de l'ancien texte sur les appels effectués.
        GMESSAGE = mess(981,182,1)
        GERR = 1
        Rollback
        INTR = 0
        Break
      Else
        If IPERF >= 478 Then
          Commit
          IPERF = 0
          INTR = 0
        Else
          IPERF += 1
        Endif
      Endif
      ICLECOUNT += 1
      If ICLECOUNT >= ICUT Then
        Break
      Endif
    Next
    Filter [CLL]
    If GERR Then
      Break
    Endif
  Wend
  If INTR Then
    If !GERR Then
      Commit
    Endif
  Endif
End

##########################################################################################################
# Modification de la synthèse
######################################################
Subprog MNGUPDSYN(SZTYPCLOB, SZNUMCLOB)
Value Char SZTYPCLOB
Value Char SZNUMCLOB

Local Char SZCLE(GLONCLL)
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF
Local Char SZTYP2CLOB(GLONAOB)

  SZTYP2CLOB = SZTYPCLOB
  If SZTYPCLOB = "CMG" Then
    If [M:CMG0]PREDES = [M:CMG2]DES Then
      End
    Endif
  Elsif SZTYPCLOB = "CMGSYN" Then
    If [M:CMG0]PREDES = [M:SYN1]SYN Then
      End
    Endif
    SZTYP2CLOB = "CMG"
  Elsif SZTYPCLOB = "OMP" Then
    If [M:OMP0]PREOBJ = [M:OMP1]OBJ Then
      End
    Endif
  Elsif SZTYPCLOB = "OMPSYN" Then
    If [M:OMP0]PREOBJ = [M:SYN1]SYN Then
      End
    Endif
    SZTYP2CLOB = "OMP"
  Endif
  SZCLE = ""
  ICUT = 2500
  ICLECOUNT = ICUT
  IPERF = 0
  INTR = 0
  While ICLECOUNT >= ICUT
    ICLECOUNT = 0
    Filter [CLL] Where [F:CLL]CLLCMGFLG > 0 and [F:CLL]TYPFULOBJ = SZTYP2CLOB and [F:CLL]NUMFULOBJ = SZNUMCLOB and [F:CLL]CLLNUM > SZCLE
    For [CLL]CLL0
      SZCLE = [F:CLL]CLLNUM
      If IPERF = 0 Then
        Trbegin [CLL]
        INTR = 1
      Endif
      If SZTYPCLOB = "CMG" Then
        [F:CLL]CLLOBJ = [M:CMG2]DES
        [F:CLL]OBJFLG = [M:CMG2]OBJFLG
      Elsif SZTYPCLOB = "OMP" Then
        [F:CLL]CLLOBJ = [M:OMP1]OBJ
        [F:CLL]OBJFLG = [M:OMP1]OBJFLG
      Elsif SZTYPCLOB = "CMGSYN" or SZTYPCLOB = "OMPSYN" Then
        [F:CLL]CLLOBJ = [M:SYN1]SYN
        [F:CLL]OBJFLG = 1
      Endif
      Rewrite [CLL]
      If fstat Then
        #Erreur lors de l'enregistrement de la nouvelle synthèse sur les appels générés.
        GMESSAGE = mess(982,182,1)
        GERR = 1
        Rollback
        INTR = 0
        Break
      Else
        If IPERF >= 478 Then
          Commit
          IPERF = 0
          INTR = 0
        Else
          IPERF += 1
        Endif
      Endif
      ICLECOUNT += 1
      If ICLECOUNT >= ICUT Then
        Break
      Endif
    Next
    Filter [CLL]
    If GERR Then
      Break
    Endif
  Wend
  If INTR Then
    If !GERR Then
      Commit
    Endif
  Endif
End

##########################################################################################################
# Clos les appels d'une campagne d'appels
##########################################################################################################
Subprog CLOOMPCLL(SOMPNUM, SMESSAGE, IBRETOUR)
Value Char SOMPNUM
Variable Char SMESSAGE
Variable Integer IBRETOUR

  # FGR 09/10/2012 : X3SUIVI84266
  Raz SMESSAGE
  IBRETOUR = 1
  If SOMPNUM <> "" Then
    Readlock [OMP]OMP0=SOMPNUM
    If !fstat Then
      If [F:OMP]CLO = 2 Then
        If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif
        Delete [CLL] Where [F:CLL]CLLOPGTYP = "OMP" and [F:CLL]CLLOPGNUM = SOMPNUM and [F:CLL]CLLCMGFLG > 0 and [F:CLL]CLLDON <> 2
        If fstat Then
          SMESSAGE = mess(10,100,1)
          IBRETOUR = 0
        Else
          [F:OMP]NBRCLLPCDX = 0
          Rewrite [OMP]
          If fstat Then
            SMESSAGE = mess(101,141,1)
            IBRETOUR = 0
          Endif
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
# Cloture de toutes les opérations appels d'une campagne
######################################################
Subprog CLOOPGCALL(SZCMGNUM, INUMMES, ICHAPTER, IBRETOUR)
Value Char SZCMGNUM
Variable Integer INUMMES
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  #Clôture toutes les opérations d'appels de la campagne
  Filter [OMP] Where [F:OMP]CMGNUM = SZCMGNUM and [F:OMP]CLO <> 2
  For [OMP]
    #Efface tous les appels de la campagne non effectués.
    Delete [CLL] Where [F:CLL]CLLOPGTYP = "OMP" and [F:CLL]CLLOPGNUM = [F:OMP]OMPNUM and [F:CLL]CLLCMGFLG > 0 and [F:CLL]CLLDON <> 2
    If fstat Then
      IBRETOUR = 0
      ICHAPTER = 100
      INUMMES = 10
      Break
    Endif
    #Flag la opération d'appel en tant que clôturée.
    Readlock [OMP]Curr
    If !fstat Then
      [F:OMP]CLO = 2
      [F:OMP]CLODAT = date$
      [F:OMP]NBRCLLPCDX = 0
      Rewrite [OMP]
      If fstat Then
        IBRETOUR = 0
        ICHAPTER = 141
        INUMMES = 101
        Break
      Endif
    Else
      IBRETOUR = 0
      ICHAPTER = 100
      INUMMES = 10
      Break
    Endif
  Next
  Filter [OMP]
  #Clôture toutes les opérations de mailing de la campagne
  If IBRETOUR = 1 Then
    Filter [OMM] Where [F:OMM]CMGNUM = SZCMGNUM and [F:OMM]CLO <> 2
    For [OMM]
      Readlock [OMM]Curr
      If !fstat Then
        [F:OMM]CLO = 2
        [F:OMM]CLODAT = date$
        Rewrite [OMM]
        If fstat Then
          IBRETOUR = 0
          ICHAPTER = 141
          INUMMES = 101
          Break
        Endif
      Else
        IBRETOUR = 0
        ICHAPTER = 100
        INUMMES = 10
        Break
      Endif
    Next
    Filter [OMM]
  Endif
  #Clôture toutes les opérations de salon de la campagne
  If IBRETOUR = 1 Then
    Filter [OMT] Where [F:OMT]CMGNUM = SZCMGNUM and [F:OMT]CLO <> 2
    For [OMT]
      Readlock [OMT]Curr
      If !fstat Then
        [F:OMT]CLO = 2
        [F:OMT]CLODAT = date$
        Rewrite [OMT]
        If fstat Then
          IBRETOUR = 0
          ICHAPTER = 141
          INUMMES = 101
          Break
        Endif
      Else
        IBRETOUR = 0
        ICHAPTER = 100
        INUMMES = 10
        Break
      Endif
    Next
    Filter [OMT]
  Endif
  #Clôture toutes les opérations de campagne de presse de la campagne
  If IBRETOUR = 1 Then
    Filter [OMN] Where [F:OMN]CMGNUM = SZCMGNUM and [F:OMN]CLO <> 2
    For [OMN]
      Readlock [OMN]Curr
      If !fstat Then
        [F:OMN]CLO = 2
        [F:OMN]CLODAT = date$
        Rewrite [OMN]
        If fstat Then
          IBRETOUR = 0
          ICHAPTER = 141
          INUMMES = 101
          Break
        Endif
      Else
        IBRETOUR = 0
        ICHAPTER = 100
        INUMMES = 10
        Break
      Endif
    Next
    Filter [OMN]
  Endif
End

##########################################################################################################
# Clôture une campagne marketing et toutes ses opérations.
#########################################################
Subprog CLOCMG(SZCMGNUM, INUMMES, ICHAPTER, IBRETOUR)
Value Char SZCMGNUM
Variable Integer INUMMES
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Char SYMBOLE(250)

  If !clalev([F:CMG]) : Local File CMARKETING [CMG] : Endif
  If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
  If !clalev([F:OMP]) : Local File PHONING [OMP] : Endif
  If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif
  If !clalev([F:OMT]) : Local File TRADESHOW [OMT] : Endif
  If !clalev([F:OMN]) : Local File MEDIA [OMN] : Endif
  SYMBOLE = ""
  Call DEBTRANS From GLOCK
  Trbegin [CMG]
  SYMBOLE = "CMG" + SZCMGNUM
  Lock =SYMBOLE
  If fstat Then
    #Modification en cours sur un autre poste
    INUMMES = 10
    ICHAPTER = 100
    IBRETOUR = 0
  Endif
  If IBRETOUR = 1 Then
    #Clôture toutes les opérations d'appels de la campagne
    Call CLOOPGCALL(SZCMGNUM, INUMMES, ICHAPTER, IBRETOUR)
  Endif
  If IBRETOUR = 1 Then
    #Flag la campagne marketing en tant que clôturée.
    Readlock [CMG]CMG0=SZCMGNUM
    If !fstat Then
      [F:CMG]CLO = 2
      Rewrite [CMG]
      If fstat Then
        #Erreur modification
        INUMMES = 101
        ICHAPTER = 141
        IBRETOUR = 0
      Endif
    Endif
  Endif
  If IBRETOUR = 1 Then
    Commit
  Else
    Rollback
  Endif
  Unlock SYMBOLE
End

##########################################################################################################
# verifie que le site est bien en phase avec celui de la campagne
Subprog CMGCTRLFCY(SZSITE, SZCMGNUM, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZSITE
Value Char SZCMGNUM
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Char SZSOC(GLONCPY)
Local Char SZSITECMG(GLONFCY)

  Raz SZSOC
  Raz SZSITECMG
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If SZSITE = "" Then
    End
  Endif
  If SZCMGNUM = "" Then
    End
  Endif
  If !clalev([F:CMGL]) : Local File CMARKETING [CMGL] : Endif
  If !clalev([F:FCY]) : Local File FACILITY[FCY] : Endif
  Read [FCY]FCY0=SZSITE
  If fstat <> 0 Then
    #Valeur incorrect.
    IERRINF = 83
    ICHAPTER = 123
    IBRETOUR = 0
    End
  Endif
  SZSOC = [F:FCY]LEGCPY
  Read [CMGL]CMG0=SZCMGNUM
  If fstat <> 0 Then
    IERRINF = 83
    ICHAPTER = 123
    IBRETOUR = 0
    End
  Endif
  SZSITECMG = [F:CMGL]FCY
  Read [FCY]FCY0=SZSITECMG
  If fstat <> 0 Then
    IERRINF = 83
    ICHAPTER = 123
    IBRETOUR = 0
    End
  Endif
  If [F:FCY]LEGCPY <> SZSOC Then
    #Le site n'est pas sur la même société juridique
    IERRINF = 2
    ICHAPTER = 194
    IBRETOUR = 0
  Endif
End

##########################################################################################################
# verifie que la date de début est  en phase avec celle de la campagne
Subprog CMGCTRLDATEDEB(DTDATEDEB, SZCMGNUM, IERRINF, ICHAPTER, IBRETOUR)
Value Date  DTDATEDEB
Value Char SZCMGNUM
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If DTDATEDEB = [00/00/00] Then
    End
  Endif
  If SZCMGNUM = "" Then
    End
  Endif
  If !clalev([F:CMGL]) : Local File CMARKETING [CMGL] : Endif
  Read [CMGL]CMG0=SZCMGNUM
  If fstat <> 0 Then
    IERRINF = 83
    ICHAPTER = 123
    IBRETOUR = 0
    End
  Endif
  If [F:CMGL]DATSTR > DTDATEDEB or DTDATEDEB > [F:CMGL]DATEND Then
    #La date de début de l'opération doit être comprise entre la date de début et de fin de la campagne.
    IERRINF = 416
    ICHAPTER = 177
    IBRETOUR = 0
    End
  Endif
End

##########################################################################################################
# verifie que la date de fin  est  en phase avec celle de la campagne
Subprog CMGCTRLDATEFIN(DTDATEFIN, SZCMGNUM, IERRINF, ICHAPTER, IBRETOUR)
Value Date  DTDATEFIN
Value Char SZCMGNUM
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If DTDATEFIN = [00/00/00] Then
    End
  Endif
  If SZCMGNUM = "" Then
    End
  Endif
  If !clalev([F:CMGL]) : Local File CMARKETING [CMGL] : Endif
  Read [CMGL]CMG0=SZCMGNUM
  If fstat <> 0 Then
    IERRINF = 83
    ICHAPTER = 123
    IBRETOUR = 0
    End
  Endif
  If [F:CMGL]DATSTR > DTDATEFIN or DTDATEFIN > [F:CMGL]DATEND Then
    #La date de fin de l'opération doit être comprise entre la date de début et de fin de la campagne.
    IERRINF = 416
    ICHAPTER = 177
    IBRETOUR = 0
    End
  Endif
End

##########################################################################################################
# Initialise les dates début fin opération par rapport à celles de la campagne
Subprog CMGINIDATES(SZCMGNUM, DTDATEDEB, DTDATEFIN, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZCMGNUM
Variable Date DTDATEDEB
Variable Date DTDATEFIN
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If SZCMGNUM = "" Then
    End
  Endif
  If !clalev([F:CMGL]) : Local File CMARKETING [CMGL] : Endif
  Read [CMGL]CMG0=SZCMGNUM
  If fstat <> 0 Then
    IERRINF = 83
    ICHAPTER = 123
    IBRETOUR = 0
    End
  Endif
  DTDATEDEB = [F:CMGL]DATSTR
  DTDATEFIN = [F:CMGL]DATEND
End
