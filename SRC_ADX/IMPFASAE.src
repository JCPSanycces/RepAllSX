#<AdxTL>@(#)3.0.0.0 $Revision$
#
#*********************************************************************
#
#              IMPORT BIENS COMPTABLES ABEL ENTREPRISE
#
#*********************************************************************
#    Création
#    GLE - 04.05.2010 - FQ64491
#
#*********************************************************************
#    Modification
#
#    GLE - 10.04.2014 - FQ99136 : Erreur sur le numéro de la table diverse pour le type de véhicule
#    GLE - 10.04.2014 - FQ98650 : Type de carburant initialisé à "4" "Autre"
#    GLE - 24.06.2013 - FQ90644 : Perte des cumuls périodique de dérogatoire après reprise
#                                 Avertissement si REPDPRCUM est à Non
#    GLE - 20.06.2013 - FQ90641 : Gestion d'une version du traitement d'extraction AE
#    CBO - 09.01.2013 - FQ85865 : suppression de [F:PFD]GACACN = PGACACN
#    CBO - 04.12.2012 - FQ85865 : poste de liasse : GIMP(79) est celui de AE
#    GLE - 17.01.2012 - FQ79283 : Les associations sont écrasées par des valeurs nulles si les champs sont dans le modèle d'import
#    GLE - 31.03.2011 - FQ72796 : Forçage de la dotation exercice pour régulariser la saisie d'un cumul de dot. > valeur amortissable
#    GLE - 03.01.2011 - FQ70352 : erreur si code comptable et compte renseignés dans le fichier d'import
#
#*********************************************************************

Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("FAS",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
  Case ACTION
    When "IMP_AVANT_OUVRE"  : Gosub IMP_AVANT_OUVRE : # FQ90644
    When "IMP_OUVRE"        : Gosub IMP_OUVRE
    When "IMP_FERME"        : Gosub IMP_FERME
    When "IMPORT"           : Gosub IMPORT

    When "IMP_ZONE"         : Gosub IMP_ZONE

    When "SET_IMPMOD"       : IMPMOD = 1

    When "IMP_VERIF_CRE"    : Gosub IMP_VERIF_CRE
    When "IMP_INICRE"       : Gosub IMP_INICRE
    When "IMP_CREATION"     : Gosub IMP_CREATION
    When "IMP_APRES_CRE"    : Gosub IMP_APRES_CRE

    When Default
  Endcase
Return

#################################################################### FQ90644
# Toute première action de l'import
#
$IMP_AVANT_OUVRE

  #######################
  # Contrôle de l'existence et de la valorisation de la table de transcodage pour les booléens
  # Le traitement s'appuie sur le champ ENDDPRFLG qui est un booléen alimenté par AE
  #######################
  If !clalev([F:AOD]) : Local File AOBJEXTD [AOD] : Endif : # Lignes de paramétrage des imports/exports
  If !clalev([F:AOR]) : Local File AOBJEXTR [AOR] : Endif : # Transcodage des imports/exports

  Local Shortint LNUMTAB : # numéro de la table de transcodage sur ENDDPRFLG

  # lecture de la ligne "ENDDPRFLG" du modèle d'import pour déterminer le numéro de la table de transcodage des booléens
  Filter [F:AOD] Where EXT=[M:IMP2]MODIMP and FLD="ENDDPRFLG"
  Read [F:AOD] First
  Filter [F:AOD]
  If fstat
    # Le champ ENDDPRFLG n'a pas été trouvé
    Call ECR_TRACE([M:IMP2]MODIMP-": field ENDDPRFLG not found"-num$(fstat),1) From GESECRAN
    OK=0
    Return
  Endif

  LNUMTAB = [F:AOD]NUMTAB

  If LNUMTAB = 0
    # Il n'est pas normal de ne pas avoir de table de transcodage pour le champ ENDDPRFLG
    Call ECR_TRACE([M:IMP2]MODIMP-": transcribe table issue on field ENDDPRFLG",1) From GESECRAN
    OK=0
    Return
  Endif

  Trbegin [AOR]

  # Contrôle du 0 -> 1
  Filter [F:AOR] Where NUMTAB=LNUMTAB and CODEXT="0" and CODLOC="1"
  If rowcount([F:AOR]) = 0
    # Création du code
    Raz [F:AOR]
    [F:AOR]NUMTAB = LNUMTAB
    [F:AOR]NUMLIG = 1
    [F:AOR]CODEXT = "0"
    [F:AOR]CODLOC = "1"
    [F:AOR]NUMCAR = "100"
    Write [F:AOR]
    If fstat
      Call ECR_TRACE("Error creating transcribe table"-num$(LNUMTAB)-"entry 0 -> 1 :"-num$(fstat),1) From GESECRAN
      OK = 0
    Endif
  Endif
  Filter  [F:AOR]

  # Contrôle du 1 -> 2
  Filter [F:AOR] Where NUMTAB=LNUMTAB and CODEXT="1" and CODLOC="2"
  If rowcount([F:AOR]) = 0
    # Création du code
    Raz [F:AOR]
    [F:AOR]NUMTAB = LNUMTAB
    [F:AOR]NUMLIG = 2
    [F:AOR]CODEXT = "1"
    [F:AOR]CODLOC = "2"
    [F:AOR]NUMCAR = "100"
    Write [F:AOR]
    If fstat
      Call ECR_TRACE("Error creating transcribe table"-num$(LNUMTAB)-"entry 1 -> 2 :"-num$(fstat),1) From GESECRAN
      OK = 0
    Endif
  Endif
  Filter  [F:AOR]

  If OK = 0
    Rollback
  Else
    Commit
  Endif

  Gosub IMP_AVANT_OUVRE From IMPFAS
Return

####################################################################
# Au début de l'import
#
$IMP_OUVRE
  Local Integer L_I
  Local Shortint INDIC_RAE : # Indique si le lancement se fait par la fenêtre de reprise dédiée REPRISEAE
  If clalev([M:RAE]) : INDIC_RAE = 1 : Endif

  Global Integer CRESAC           : # Indicateur de création auto du secteur d'activité
  Global Integer CREGAC           : # Indicateur de création auto du code comptable
  Global Integer CREACC           : # Indicateur de création auto du compte comptable

  Global Char    AEAXE(GLONDIE)(1..4) : # Correspondance entre les 4 axes gérés par Abel Entreprise et les axes du modèle comptable de la société
  Global Char    AESCT(GLONDIE)(1..2) : # Correspondance entre les 2 secteurs gérés par Abel Entreprise et les axes du modèle IAS de la société

  Local  Char    EXPECTEDVER      : # Niveau de version attendu du traitement d'extraction Abel Entreprise FQ90641
  EXPECTEDVER = "1"               : # A mettre à jour en cas d'évolution côté Abel Entreprise              FQ90641

  Local  Shortint IMP_BCO         : # Indicateur d'arrêt d'import d'un bien FQ90641

  Gosub IMP_OUVRE From IMPFAS

  If OK = 0 : Return : Endif      : # A EMBARQUER A L'OCCASION D'UNE CORRECTION

  If !clalev([F:GAC])  : Local File =GTABCPT+"GACCOUNT" [GAC]  : Endif
  If !clalev([F:CAC])  : Local File GACCCODE            [CAC]  : Endif
  If !clalev([F:SAC])  : Local File SECACT              [SAC]  : Endif
  If !clalev([F:SFAS]) : Local File FXDASSETS           [SFAS] : Endif : # Sauvegarde de la classe [F:FAS]
  If !clalev([F:WFAS]) : Local File FXDASSETS           [WFAS] : Endif : # recherche des biens principaux
# FQ85865 poste de liasse
  If !clalev([F:PFL])  : Local File PARFLUX             [PFL] : Endif : # recherche des biens principaux
  If !clalev([F:PFD])  : Local File PARFLUXDET          [PFD] : Endif : # recherche des biens principaux
  If !clalev([F:CNX])  : Local File CONTEXT             [CNX] : Endif : # recherche des biens principaux

  # Variables de travail
  Local Char      AASREFORI(50)

  Global Shortint G_AEPLNL(1..8)

  # Flags de création automatique du référentiel
  If INDIC_RAE
    CREBPR    = [M:RAE]FLGBPR
    CRESAC    = [M:RAE]FLGSAC
    CREGAC    = [M:RAE]FLGGAC
    CREACC    = [M:RAE]FLGACC
    CREACGGRP = [M:RAE]FLGFAM
    For L_I = 0 To GOPTCANA-1
      CRECCE(L_I) = G_NON : # on court-circuite la création automatique dans IMPFAS pour s'en occuper dans ce traitement
    Next
  Else
    CREBPR    = G_OUI
    CRESAC    = G_OUI
    CREGAC    = G_OUI
    CREACC    = G_OUI
    CREACGGRP = G_OUI
    For L_I = 0 To GOPTCANA-1
      CRECCE(L_I) = G_NON : # on court-circuite la création automatique dans IMPFAS pour s'en occuper dans ce traitement
    Next
  Endif
  CRELOC    = G_NON : # la notion n'est pas gérée sur les biens AE

  GCOUSIT = "" : # Pour forcer le rechargement
Return

####################################################################
# A chaque chargement de la classe F à partir du fichier d'import
#
$IMPORT
  Case SEPNUM
    When 1 :
      # FQ90641 : Contrôle de la version du fichier à importer
      IMP_BCO = 1
      If !func GLOFUNCIMP.CTRL_VERSION(GIMP(40),EXPECTEDVER)
        Call ECR_TRACE(mess(103,100,1)-GIMP(40),1) From GESECRAN
        OK = 0
        IMP_BCO = 0
        Return
      Else
        Call ECR_TRACE(mess(126,105,1)-GIMP(40),0) From GESECRAN
      Endif

      If [F:FAS]FCY <> GCOUSIT
        Call ACTION_FCY([F:FAS]FCY,[F:FAS]CPY) From GLOFCYCPY
        Gosub LEC_PARAM_AE
      Else
        [F:FAS]CPY = GCOUSOC
      Endif

      [F:SFAS] = [F:FAS] : # Sauvegarde de la classe [F:FAS] juste après le chargement depuis le fichier d'import

      [L]AASREFORI = [F:FAS]AASREF

      # Traitement bien principal/bien composant
      If [F:FAS]CMP<>""
        If [F:FAS]CMP = [F:FAS]AASREF
          [F:FAS]CMP    = ""
          [F:FAS]CMPSTA = GVML_SBPRINC
        Else
          [F:FAS]CMPSTA = GVML_SBCOMPO
        Endif
      Endif

      # CONVERSION DES CHAMPS NON SAISISSABLES
      # Conversion du type de sortie
      [F:FAS]ISSTYP = func GLOFUNCIMP.CONV_ISSTYP_AE(GIMP(81))

      Gosub IMPORT From IMPFAS

      # FQ85865 Maj du poste de liasse
      Call MAJ_POSTE([F:FAS]CPY, [F:FAS]GAC, GIMP(79))

      REPDPRCUM    = G_OUI : # On reprend toujours le cumul de dotation antérieur
    When 2 :
      If !IMP_BCO : # FQ90641
        OK = 0
        Return
      Endif

      Gosub ALI_FAS3_PRE
      Gosub ALI_FAS3
  Endcase
Return

####################################################################
# Déclenchement de traitements spécifiques lors du passage
# sur certaines zones
#
$IMP_ZONE
  Case IMPZON
    When "AASDES1"
      If [F:FAS]AASDES1=""
        [F:FAS]AASDES1=[F:FAS]AASREF
      Endif
    When "AASTYP"
      [F:FAS]AASTYP = func GLOFUNCIMP.CONV_AASTYP_AE([F:FAS]AASTYP)
    When "PURNAT"
      [F:FAS]PURNAT = func GLOFUNCIMP.CONV_PURNAT_AE([F:FAS]PURNAT)
    When "ISRTYP"
      [F:FAS]ISRTYP = func GLOFUNCIMP.CONV_ISRTYP_AE(GIMP(1))
    When "AASCND"
      Call TRT_TABDIV(511,[F:FAS]AASCND,GIMP(2),"","",0,0) From GLOFUNCIMP
    When "CMP"
      Gosub RECH_BIEN_PRINCIPAL
    When "ACCCOD"
      Gosub TRAITE_ACCCOD
    When "OWNTYP"
      [F:FAS]OWNTYP = func GLOFUNCIMP.CONV_OWNTYP_AE(GIMP(5))
    When "STABILTYP"
      [F:FAS]STABILTYP = func GLOFUNCIMP.CONV_STABILTYP_AE([F:FAS]STABILTYP)
    When "ETRNAT"
      [F:FAS]ETRNAT = func GLOFUNCIMP.CONV_ETRNAT_AE([F:FAS]ETRNAT)
    When "TAXTYP"
      [F:FAS]TAXTYP = func GLOFUNCIMP.CONV_TAXTYP_AE([F:FAS]TAXTYP)
    When "INVTYP"
      Call TRT_TABDIV(515,[F:FAS]INVTYP,GIMP(61),"","",0,0) From GLOFUNCIMP
    When "AASBUS"
      If CRESAC = G_OUI
        Call CRE_SAC([F:FAS]CPY,[F:FAS]AASBUS,GIMP(10),
&                    func GLOFUNC.VALSEP(GIMP(11), GSEPDEC), func GLOFUNC.VALSEP(GIMP(12), GSEPDEC),
&                    func GLOFUNC.VALSEP(GIMP(13), GSEPDEC), func GLOFUNC.VALSEP(GIMP(14), GSEPDEC)) From GLOFUNCIMP
      Endif
    When "INVPLN"
      Call TRT_TABDIV(614,[F:FAS]INVPLN,GIMP(65),"","",0,0) From GLOFUNCIMP
    When "BUDREF"
      Call TRT_TABDIV(615,[F:FAS]BUDREF,GIMP(66),"","",0,0) From GLOFUNCIMP
    When "INVREQ"
      Call TRT_TABDIV(616,[F:FAS]INVREQ,GIMP(67),"","",0,0) From GLOFUNCIMP
    When "IASCGU"
      Call TRT_TABDIV(613,[F:FAS]IASCGU,GIMP(69),"","",0,0) From GLOFUNCIMP

    When "IVCVATAMT"
      # Avant les alimentations complémentaires
      Gosub TRAITE_VEHICULE

    When "CCE"
      Local Integer N_I
      For N_I = 1 To 4
        If [M:FAS2]DIE(nolign-1) = AEAXE(N_I)
          [M:FAS2]CCE(nolign-1) = [F:FAS]CCE(N_I-1)
          If !clalev([M:RAE]) or (clalev([M:RAE]) and [M:RAE]FLGCCE=G_OUI)
            Call CRE_CCE([M:FAS2]DIE(nolign-1),[M:FAS2]CCE(nolign-1),GIMP(3+nolign-1)) From GLOFUNCIMP
          Else
            Look [F:CCE]CCE0=[M:FAS2]DIE(nolign-1);[M:FAS2]CCE(nolign-1)
            If fstat
              Call ECR_TRACE(mess(206,111,1)-[M:FAS2]DIE(nolign-1)-":"-[M:FAS2]CCE(nolign-1)-mess(35,106,1),-1) From GESECRAN
            Endif
          Endif
          Break
        Endif
      Next
      For N_I = 1 To 2
        If [M:FAS2]DIE(nolign-1) = AESCT(N_I)
          [M:FAS2]CCE(nolign-1) = GIMP(85+N_I)
          If !clalev([M:RAE]) or (clalev([M:RAE]) and [M:RAE]FLGCCE=G_OUI)
            Call CRE_CCE([M:FAS2]DIE(nolign-1),[M:FAS2]CCE(nolign-1),GIMP(62+N_I)) From GLOFUNCIMP
          Else
            Look [F:CCE]CCE0=[M:FAS2]DIE(nolign-1);[M:FAS2]CCE(nolign-1)
            If fstat
              Call ECR_TRACE(mess(206,111,1)-[M:FAS2]DIE(nolign-1)-":"-[M:FAS2]CCE(nolign-1)-mess(35,106,1),-1) From GESECRAN
            Endif
          Endif
          Break
        Endif
      Next
      OK = 0

    # Amortissements
    When Default
      If IMPMSK = "FAS3"
        If !(evalue("dim([F:"-IMPFIC-"]"+IMPZON+")") < 0)
          Assign IMPZON+"("+num$(indice)+")" With evalue("[F:"-IMPFIC-"]"+IMPZON)
        Endif
      Endif
  Endcase

  Gosub IMP_ZONE From IMPFAS

  Case IMPZON
  Endcase

  Gosub IMP_ZONE_ASSOC From GLOFUNCIMP : # FQ79283
Return

####################################################################
# Verification avant l'enregistrement.
#
$IMP_VERIF_CRE
  # Acheteur
  If [F:FAS]BUY <> "" and CREBPR = G_OUI
    Call CRE_BPR([F:FAS]BUY, GIMP(62)) From GLOFUNCIMP
  Endif

  Gosub IMP_VERIF_CRE From IMPFAS
Return

####################################################################
# Alimentation de certaines zones de la classe [F] absentes de la
# classe [M] avant enregistrement.
#
$IMP_INICRE
  Gosub IMP_INICRE From IMPFAS

  # Coefficient repris à l'identique d'AE
  [F:FAS]R76COE     = [F:SFAS]R76COE
  [F:FAS]ASJCOER    = [F:SFAS]ASJCOER
  [F:FAS]TAXCOER    = [F:SFAS]TAXCOER
  [F:FAS]ADMCOER    = [F:SFAS]ADMCOER
  [F:FAS]DEDCOER    = [F:SFAS]DEDCOER
  [F:FAS]ASJCOE     = [F:SFAS]ASJCOE
  [F:FAS]TAXCOE     = [F:SFAS]TAXCOE
  [F:FAS]TAXCOEFLG  = [F:SFAS]TAXCOEFLG
  [F:FAS]ADMCOE     = [F:SFAS]ADMCOE
  [F:FAS]DEDCOE     = [F:SFAS]DEDCOE
  [F:FAS]ASJCOEF    = [F:SFAS]ASJCOEF
  [F:FAS]ASJCOEFGLO = [F:SFAS]ASJCOEFGLO
  [F:FAS]TAXCOEF    = [F:SFAS]TAXCOEF
  [F:FAS]TAXCOEFGLO = [F:SFAS]TAXCOEFGLO
  [F:FAS]ADMCOEF    = [F:SFAS]ADMCOEF
  [F:FAS]ADMCOEFGLO = [F:SFAS]ADMCOEFGLO
  [F:FAS]DEDCOEF    = [F:SFAS]DEDCOEF

  # On force tous les montants
  # PCG
  [F:FAS]ACGETRNOT   = [F:SFAS]ACGETRNOT
  [F:FAS]IVCVATRAT   = ar2([F:SFAS]IVCVATRAT * 100)
  [F:FAS]IVCVATAMT   = [F:SFAS]IVCVATAMT
  [F:FAS]IVCVATFLG   = G_OUI
  [F:FAS]DEDVATRAT   = ar2([F:SFAS]DEDVATRAT * 100)
  [F:FAS]DEDVATAMT   = [F:SFAS]DEDVATAMT
  [F:FAS]DEDVATFLG   = G_OUI
  # IAS
  [F:FAS]IASETRNOT   = [F:SFAS]IASETRNOT
  [F:FAS]IVCVATRATI  = ar2([F:SFAS]IVCVATRATI * 100)
  [F:FAS]IVCVATAMTI  = [F:SFAS]IVCVATAMTI
  [F:FAS]IVCVATFLGI  = G_OUI
  [F:FAS]DEDVATRATI  = ar2([F:SFAS]DEDVATRATI * 100)
  [F:FAS]DEDVATAMTI  = [F:SFAS]DEDVATAMTI
  [F:FAS]DEDVATFLGI  = G_OUI
  # TVA
  [F:FAS]VATYEAFLG      = [F:SFAS]VATYEAFLG
  [F:FAS]VATREGDAT      = [F:SFAS]VATREGDAT
  # Pour ne pas importer THESLI à 0
  If [F:SFAS]THESLI<>0
   [F:FAS]THESLI        = [F:SFAS]THESLI
  Endif
  [F:FAS]VATRSD         = [F:SFAS]VATRSD
  [F:FAS]VATREGAMT      = [F:SFAS]VATREGAMT
  [F:FAS]VATREGDED      = [F:SFAS]VATREGDED
  [F:FAS]VATREGCUM      = [F:SFAS]VATREGCUM
  [F:FAS]IASVATREG      = [F:SFAS]IASVATREG
  [F:FAS]VATREGDEDI     = [F:SFAS]VATREGDEDI
  [F:FAS]IASREGCUM      = [F:SFAS]IASREGCUM
  [F:FAS]INIDEDVAT      = [F:SFAS]INIDEDVAT

  # C.I.G.
  [F:FAS]ISSOPETYP = func GLOFUNCIMP.CONV_ISSOPETYP_AE(GIMP(68))
  If [F:FAS]ISSOPETYP = 0
    [F:FAS]FISOPETYP = 0
  Else
    [F:FAS]FISOPETYP = func GLOFUNCIMP.CONV_FISOPETYP_AE([F:SFAS]FISOPETYP)
  Endif
  [F:FAS]GRUORICPY = [F:SFAS]GRUORICPY
  [F:FAS]GRUORIAAS = [F:SFAS]GRUORIAAS
  [F:FAS]AASORINBV = [F:SFAS]AASORINBV
  [F:FAS]ORIPURAMT = [F:SFAS]ORIPURAMT
  [F:FAS]ORIPURDAT = [F:SFAS]ORIPURDAT
  [F:FAS]CIGCOD    = [F:SFAS]CIGCOD

  # Divers
  [F:FAS]FLGSPL     = [F:SFAS]FLGSPL
  [F:FAS]CMPORI     = [F:SFAS]CMPORI
  [F:FAS]AASREFORI  = [L]AASREFORI

  # TVA due sur vente à multiplier par 100
  If [F:SFAS]ISSDAT = [0/0/0]
    [F:FAS]ISSVATRAT = 0
  Else
    [F:FAS]ISSVATRAT = [F:SFAS]ISSVATRAT * 100
  Endif
Return

####################################################################
# Après la création du bien.
#
$IMP_CREATION
  Gosub IMP_CREATION From IMPFAS
Return

####################################################################
# Après la création du bien, après le commit
#
$IMP_APRES_CRE
  Gosub IMP_APRES_CRE From IMPFAS
Return

####################################################################
# A la fin de l'import
#
$IMP_FERME
  Gosub IMP_FERME From IMPFAS
Return

$TRAITE_VEHICULE
    # Conversions
    [F:FAS]VEHTYP    = func GLOFUNCIMP.CONV_VEHTYP_AE([F:FAS]VEHTYP)
    [F:FAS]TAXPLI    = func GLOFUNCIMP.CONV_TAXPLI_AE(func GLOFUNC.VALSEP(GIMP(6), GSEPDEC))
    [F:FAS]VEHTAXRUL = func GLOFUNCIMP.CONV_VEHTAXRUL_AE([F:FAS]VEHTAXRUL)

    # Création du référentiel
    Call TRT_TABDIV(965,[F:FAS]VEHTYP,[F:FAS]VEHTYP,"","",G_NON,0) From GLOFUNCIMP : # FQ99136 : table diverse 955 -> 965
    Call TRT_TABDIV(534,[F:FAS]VEHBRA,[F:FAS]VEHBRA,"","",0,0) From GLOFUNCIMP
    Call TRT_TABDIV(535,[F:FAS]CWKTYP,[F:FAS]CWKTYP,"","",0,0) From GLOFUNCIMP

    # Si le genre est différent de "VP", on impose une exonération totale
    If [F:FAS]VEHTYP <> "VP"
      [F:FAS]TAXPLI = GVML_TIEXONT
    Endif

    # FQ98650 Si c'est un véhicule le type de carburant est initialisé à "4" "Autre"
    If [F:FAS]VEHTYP <> ""
      [F:FAS]FUEL = 4
    Endif
Return

####################################################################
# Gestion du code comptable
#
# Si le code comptable est renseigné
#  |-> si les comptes sont renseignées, contrôle de cohérence
#  |-> si les comptes ne sont pas renseignée, ils sont hérités du code comptable
# Si le code comptable n'est pas renseigné
#  |-> si les comptes sont renseignées, recherche et si besoin création du code comptable
#  |-> si les comptes ne sont pas renseignée, erreur
#
$TRAITE_ACCCOD
  Local Char     ACCDES(GLONDES)
  Local Shortint GAC_OK

  If [F:FAS]ACCCOD <> ""
    # Le code comptable est renseigné
    If [F:FAS]GAC <> ""
      # Ainsi que le compte PCG
      Call LECTURE("CAC",[F:FAS]ACCCOD,"") From CONTOBJ
      If [F:CAC]ACC(0) <> [F:FAS]GAC or ([F:FAS]IASACC <> "" and [F:CAC]ACC(15) <> [F:FAS]IASACC) : # FQ70352 : IACC -> IASACC
        Call ECR_TRACE("",1) From GESECRAN
        OK = 0
      Endif
    Endif
  Else
    # Le code comptable n'est pas renseigné
    If [F:FAS]GAC <> ""
      If [F:FAS]IASACC = ""
        Filter [F:CAC] Where [F:CAC]TYP=15 and [F:CAC]COA=[M:FPC]COA([M:FPC]GENLEDTYP-1) and [F:CAC]ACC(0)=[F:FAS]GAC
        Read [F:CAC] First
        Filter [F:CAC]
        If !fstat
          [F:FAS]ACCCOD = [F:CAC]ACCCOD
        Endif
      Else
        If !clalev([WCAC]) : Local File GACCCODE [WCAC] : Endif
        Link [CAC] With [WCAC]CAC1=TYP;ACCCOD As [LIEN]
&       Where [CAC]TYP=15 and [CAC]ACC(0)=[F:FAS]GAC and [CAC]COA=[M:FPC]COA([M:FPC]GENLEDTYP-1)
&         and [WCAC]ACC(0)=[F:FAS]IASACC and [WCAC]COA=[M:FPC]COA([M:FPC]IASLEDTYP-1)
        Read [LIEN] First
        If !fstat
          [F:FAS]ACCCOD = [F:LIEN]ACCCOD
        Endif
      Endif

      If [F:FAS]ACCCOD <> ""
        # Il existe un code comptable compatible avec les comptes
      Elsif CREGAC = G_OUI
        # Il n'existe pas de code comptable compatible avec les comptes, il va falloir en créer un
        GAC_OK = 1
        # Pour créer le code comptable, il faut soit que les comptes existent, soit que la création des comptes soit autorisée
        Look [F:GAC]GAC0=[M:FPC]COA([M:FPC]GENLEDTYP-1);[F:FAS]GAC
        If fstat and CREACC <> G_OUI
          GAC_OK = 0
        Endif
        If GAC_OK and [F:FAS]IASACC <> ""
          Look [F:GAC]GAC0=[M:FPC]COA([M:FPC]IASLEDTYP-1);[F:FAS]IASACC
          If fstat and CREACC <> G_OUI
            GAC_OK = 0
          Endif
        Endif

        If GAC_OK
          # Création du code comptable
          Local Char    ACCCOD(GLONCAC)
          Local Integer NB
          [L]ACCCOD=[F:FAS]GAC
          # Création du code comptable avec les comptes
          Look [F:CAC]CAC1=15;[L]ACCCOD
          If !fstat
            # Recherche d'une référence de code comptable inexistante pour créer notre code comptable
            Repeat
              NB += 1
              [L]ACCCOD = [F:FAS]GAC+num$(NB)
              Look [F:CAC]CAC1=15;[L]ACCCOD
            Until fstat<>0
          Endif
          [L]ACCDES = [L]ACCCOD
          If [F:FAS]GAC = [F:FAS]IASACC or [F:FAS]IASACC=""
            # Si les comptes PCG et IAS sont les mêmes, ou qu'il n'y a pas de compte IAS,
            # l'intitulé du code comptable sera celui du compte PCG s'il existe
            Read [F:GAC]GAC0=[F:FAS]GAC
            If !fstat
              [L]ACCDES = [F:GAC]DES
            Endif
          Endif
          Call CRE_CAC([M:FPC]COA([M:FPC]GENLEDTYP-1),15,[L]ACCCOD,[L]ACCDES,[F:FAS]GAC) From GLOFUNCIMP
          If [F:FAS]IASACC <> ""
            Call CRE_CAC([M:FPC]COA([M:FPC]IASLEDTYP-1),15,[L]ACCCOD,[L]ACCDES,[F:FAS]IASACC) From GLOFUNCIMP
          Endif

          # Création des comptes
          Local Integer ACN
          [L]ACN = func GLOFUNCIMP.CONV_CLS_AE([F:FAS]GACACN)
          Call CRE_ACC([M:FPC]COA([M:FPC]GENLEDTYP-1),[F:FAS]GAC,GIMP(3),[L]ACN) From GLOFUNCIMP
          If [F:FAS]IASACC <> ""
            [L]ACN = func GLOFUNCIMP.CONV_CLS_AE([F:FAS]IASACN)
            Call CRE_ACC([M:FPC]COA([M:FPC]IASLEDTYP-1),[F:FAS]IASACC,GIMP(4),[L]ACN) From GLOFUNCIMP
          Endif

          [F:FAS]ACCCOD = [L]ACCCOD
        Else
          Call ECR_TRACE(mess(215,GML_MSGFAS,1)-":"-mess(14,GML_MSGMIS,1),1) From GESECRAN
        Endif
      Else
        Call ECR_TRACE(mess(215,GML_MSGFAS,1)-":"-mess(14,GML_MSGMIS,1),1) From GESECRAN
      Endif
    Endif
  Endif
Return

####################################################################
# Arrêt du traitement en cas de problème
#
$ARRETE
  mkstat = 2 : GERR = 1 : End
Return

####################################################################
# On continue le traitement en cas de problème
#
$CONTINUE
  Resume
Return

# Recherche du bien principal par rapport à sa numérotation d'origine
$RECH_BIEN_PRINCIPAL
  Filter [F:WFAS] Where AASREFORI=[F:FAS]CMP
  Read [F:WFAS]FAS1(1)=[F:FAS]CPY
  Filter [F:WFAS]
  If fstat
    Call TRACE(-2,mess(7,GML_MSGMIS,1)-[F:PHY]AASREF) From SUBIMPOBJ
    mkstat=2
    Return
  Else
    [M:FAS1]CMP = [F:WFAS]AASREF
    OK          = 0 : # pour ne pas alimenter la classe [M] avec la classe [F]
  Endif
Return

$ALI_FAS3_PRE
  # Aide fiscale
  [F:DEP]ALWCOD = func GLOFUNCIMP.CONV_ALWCOD_AE(GIMP(15))

  # Conversions Abel Entreprise
  Call CONV_DPM_AE([F:DEP]DPMT, [F:DEP]DPMT, [F:DEP]ALWCOD, [F:DEP]PRATYP, [F:DEP]ACLCOE) From GLOFUNCIMP
  Call CONV_DPM_AE([F:DEP]DPMI, [F:DEP]DPMI, [F:DEP]ALWCOD, [F:DEP]PRATYP, [F:DEP]ACLCOE) From GLOFUNCIMP
  Call CONV_DPM_AE([F:DEP]DPM,  [F:DEP]DPM,  [F:DEP]ALWCOD, [F:DEP]PRATYP, [F:DEP]ACLCOE) From GLOFUNCIMP

  If [F:DEP]DPMT = "" : [F:DEP]DPMT = [F:DEP]DPM : Endif
  If [F:DEP]DPMI = "" : [F:DEP]DPMI = [F:DEP]DPM : Endif

  [F:DEP]DPRPLN    = func GLOFUNCIMP.CONV_DPRPLN_AE(GIMP(20))
  [F:DEP]CRBVEHCOD = func GLOFUNCIMP.CONV_CRBVEHCOD_AE([F:DEP]CRBVEHCOD)

  # Si l'indicateur de taux forçé n'est pas à Oui, le taux doit être à 0 pour les modes autres que IT et LV
  If [F:DEP]DPRRATFLG <> G_OUI and not ([F:DEP]DPM = G_DPMIT or [F:DEP]DPM = G_DPMLV)
    [F:DEP]DPRRAT = 0
  Endif

  # Si l'indicateur de forçage de date de fin d'amortissement n'est pas à Oui, la date de fin d'amortissement est à [0/0/0]
  If [F:DEP]ENDDPRFLG <> G_OUI and [F:FAS]ISSDAT = [0/0/0]
    [F:DEP]ENDDPRDAT = [0/0/0]
  Endif

  # Recherche de la ligne dans le tableau correspondant au plan
  Local Shortint N_PLAN
  N_PLAN = find([F:DEP]DPRPLN,[M:FAS3]DPRPLN(0..[M:FAS3]NBLIG1-1))

  If !N_PLAN
    If [F:DEP]DPRPLN=0
      Call ECR_TRACE(mess(82,GML_MSGFASPR,1)-GIMP(20)-mess(42,9003,1),1) From GESECRAN
    Else
      Call ECR_TRACE(mess(82,GML_MSGFASPR,1)-GIMP(20)+"/"+mess([F:DEP]DPRPLN,3101,1)-mess(42,9003,1),1) From GESECRAN
    Endif
    OK=0
    Return
  Endif

  # Contrôle des dates de début d'exercice et de début de période courants
  If ([F:DEP]FIYSTRDAT <> [M:FAS3]FIYSTRDAT(N_PLAN-1))
    Call ECR_TRACE(mess(82,GML_MSGFASPR,1)-mess([F:DEP]DPRPLN,3101,1)-":"-mess(2,3268,1)-[F:DEP]FIYSTRDAT-"<>"-[M:FAS3]FIYSTRDAT(N_PLAN-1),1) From GESECRAN
    OK=0
    Return
  Endif
  If ([F:DEP]PERSTRDAT <> [M:FAS3]PERSTRDAT(N_PLAN-1))
    Call ECR_TRACE(mess(82,GML_MSGFASPR,1)-mess([F:DEP]DPRPLN,3101,1)-":"-mess(6,3130,1)-[F:DEP]PERSTRDAT-"<>"-[M:FAS3]PERSTRDAT(N_PLAN-1),1) From GESECRAN
    OK=0
    Return
  Endif

  Case [M:FAS3]ORIBAS(N_PLAN-1)
    When GVML_OBPCG, GVML_OBSUB, GVML_OBSAI
      If [M:FAS1]GACACN = GVML_NIENCOU and val(GIMP(21)) <> G_OUI
        [F:DEP]DPM    = "SA"
        [F:DEP]DPMT   = "SA"
        [F:DEP]DPMI   = "SA"
        [F:DEP]DPRDUR = 0
        [F:DEP]DPRRAT = 0
        [F:DEP]DPRRATFLG = G_NON
        [F:DEP]ENDDPE  = 0
        [F:DEP]ENDDPET = 0
        [F:DEP]ENDDPEI = 0
      Endif
    When GVML_OBIAS
      If [M:FAS1]IASACN = GVML_NIENCOU
        [F:DEP]DPM    = "SA"
        [F:DEP]DPMT   = "SA"
        [F:DEP]DPMI   = "SA"
        [F:DEP]DPRDUR = 0
        [F:DEP]DPRRAT = 0
        [F:DEP]DPRRATFLG = G_NON
        [F:DEP]ENDDPE  = 0
        [F:DEP]ENDDPET = 0
        [F:DEP]ENDDPEI = 0
      Endif
  Endcase

  # Calcul de la valeur amortissable
  [M:FAS3]DPRVAL(N_PLAN-1)     = [F:DEP]DPRBAS - [F:DEP]RSDVAL

  # Réévaluation
  [M:FAS3]RVATYP(N_PLAN-1)     = func GLOFUNCIMP.CONV_RVATYP_AE(GIMP(16))
  [M:FAS3]RVACOE(N_PLAN-1)     = [F:DEP]RVACOE
  [M:FAS3]RVACRB(N_PLAN-1)     = [F:DEP]RVACRB
  [M:FAS3]RVAAMT(N_PLAN-1)     = [F:DEP]RVAAMT
  [M:FAS3]RVADAT(N_PLAN-1)     = [F:DEP]RVADAT
  [M:FAS3]EXERVADEV(N_PLAN-1)  = [F:DEP]EXERVADEV

  [M:FAS3]NSPVAL(N_PLAN-1)     = [F:DEP]NSPVAL
  [M:FAS3]RSDVAL(N_PLAN-1)     = [F:DEP]RSDVAL

  [M:FAS3]EXCDPR(N_PLAN-1)     = [F:DEP]EXCDPR
  [M:FAS3]ENDDPEI(N_PLAN-1)    = [F:DEP]ENDDPEI
  [M:FAS3]ENDDPET(N_PLAN-1)    = [F:DEP]ENDDPET
  [M:FAS3]ALWAMT(N_PLAN-1)     = [F:DEP]ALWAMT
  [M:FAS3]ALWCUM(N_PLAN-1)     = [F:DEP]ALWCUM
  [M:FAS3]CRBAMT(N_PLAN-1)     = [F:DEP]CRBAMT
  [M:FAS3]CRBCUM(N_PLAN-1)     = [F:DEP]CRBCUM
  [M:FAS3]PERLEGCUM(N_PLAN-1)  = [F:DEP]PERLEGCUM
  [M:FAS3]PERLEGRVE(N_PLAN-1)  = [F:DEP]PERLEGRVE
  [M:FAS3]LEGCUM(N_PLAN-1)     = [F:DEP]LEGCUM
  [M:FAS3]LEGRVECUM(N_PLAN-1)  = [F:DEP]LEGRVECUM

  # Dépréciation
  [M:FAS3]EXTIMLTYP(N_PLAN-1)  = [F:DEP]EXTIMLTYP
  Call TRT_TABDIV(516,[F:DEP]EXTIMLTYP,GIMP(22),"","",0,0) From GLOFUNCIMP

  [M:FAS3]INTIMLTYP(N_PLAN-1)  = [F:DEP]INTIMLTYP
  Call TRT_TABDIV(519,[F:DEP]INTIMLTYP,GIMP(23),"","",0,0) From GLOFUNCIMP

  [M:FAS3]PERIMLCUM(N_PLAN-1)  = [F:DEP]PERIMLCUM
  [M:FAS3]EXEIMLCUM(N_PLAN-1)  = [F:DEP]EXEIMLCUM
  [M:FAS3]IMLRVELIM(N_PLAN-1)  = [F:DEP]IMLRVELIM
  [M:FAS3]PERRVECUM(N_PLAN-1)  = [F:DEP]PERRVECUM
  [M:FAS3]EXERVECUM(N_PLAN-1)  = [F:DEP]EXERVECUM
  [M:FAS3]IMLBLC(N_PLAN-1)     = [F:DEP]IMLBLC

  [M:FAS3]MTCDPEDEV(N_PLAN-1)  = [F:DEP]MTCDPEDEV

  [M:FAS3]MTCDEVADJ(N_PLAN-1)  = func GLOFUNCIMP.CONV_RVATYP_AE(GIMP(17))

  [M:FAS3]PERCLOCUM(N_PLAN-1)  = [F:DEP]PERCLOCUM
  [M:FAS3]PERQTYCUM(N_PLAN-1)  = [F:DEP]PERQTYCUM
  [M:FAS3]EXECLOCUMI(N_PLAN-1) = [F:DEP]EXECLOCUMI
  [M:FAS3]PERCLOCUMI(N_PLAN-1) = [F:DEP]PERCLOCUMI
  [M:FAS3]EXECLOCUMT(N_PLAN-1) = [F:DEP]EXECLOCUMT
  [M:FAS3]PERCLOCUMT(N_PLAN-1) = [F:DEP]PERCLOCUMT

  [M:FAS3]DFDLIM(N_PLAN-1)     = [F:DEP]DFDLIM
  [M:FAS3]DFD(N_PLAN-1)        = [F:DEP]DFD
  [M:FAS3]DFDRVE(N_PLAN-1)     = [F:DEP]DFDRVE
Return

####################################################################
# Alimentation des différents plans
#
$ALI_FAS3
  Local Shortint N_PLAN
  N_PLAN = find([F:DEP]DPRPLN,[M:FAS3]DPRPLN)

  If N_PLAN
    If ( [M:FAS3]DPRPLN(N_PLAN-1) = G301FIS ) Then
      [M:FAS0]FISLIG = N_PLAN
    Endif

    # Exécution des contrôles et des actions pour la ligne d'amortissement
    # !!! setmode pour que les actzo, diszo, ... fonctionnent sur les masques en mémoire !!!
    Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
    nolign = N_PLAN
    indice = nolign-1
    Default Mask [FAS3]
    Call SAI_NBLIG1(IMPFIC,"IMP_ZONE","SUBIMPOBJ") From W0FAS3
    Setmode
    # DEBUT FQ79283
    If mkstat
     GREP = ""
     Call TRACE2(2,GMESSIMP,-10) From SUBIMPOBJ
    Endif
    Raz GERREUR
    # FIN FQ79283

    # Une dotation a pu être forcé dans C_DPRCUM de SUBFAS, si c'est le cas on ne touche à rien
    If [M:FAS3]ENDDPEFLG(nolign-1) = G_NON : # FQ72796
      [M:FAS3]ENDDPE(nolign-1)  = [F:DEP]ENDDPE     : # dotation exercice
      [M:FAS3]ENDDPEI(nolign-1) = [M:FAS3]ENDDPE(nolign-1)
      [M:FAS3]ENDDPET(nolign-1) = [M:FAS3]ENDDPE(nolign-1)

      #If ISSANT = G_NON : # FQ68980
      If [F:FAS]ISSDAT = [0/0/0]
        [M:FAS3]ENDDPEFLG(nolign-1) = REPENDDPE         : # flag de forçage de la dotation exercice
      Else
        [M:FAS3]ENDDPEFLG(nolign-1) = G_NON
      Endif
    Endif

    [M:FAS3]ENDDPRDAT(nolign-1)   = [F:DEP]ENDDPRDAT

    # Flag de cumul d'amortissement
    # FQ90644 : utilisation de REPDPRCUM plutôt que de [F:DEP]DPRCUMFLG*
    If REPDPRCUM = G_OUI
      [M:FAS3]DPRCUMFLG(nolign-1) = G_OUI
    Else
      [M:FAS3]DPRCUMFLG(nolign-1) = G_NON
    Endif
  Endif
Return

####################################################################
# Lecture de paramètres propres à l'import AE
#
$LEC_PARAM_AE
  Local Shortint N_PARAM
  Local Char     LPARM

  Call ECR_TRACE("----------------------------------------------------------------",0) From GESECRAN
  Call ECR_TRACE(mess(49,126,1)-[F:FAS]CPY,0) From GESECRAN

  For N_PARAM = 1 To 4
    Call PARAM([F:FAS]CPY,"AEAXE"+num$(N_PARAM),LPARM) From ADOVAL
    AEAXE(N_PARAM) = LPARM
    If LPARM <> ""
      Call ECR_TRACE("  "+mess(82,GML_MSGPHY,1)-"AEAXE"+num$(N_PARAM)-":"-AEAXE(N_PARAM),0) From GESECRAN
    Endif
  Next

  For N_PARAM = 1 To 2
    Call PARAM([F:FAS]CPY,"AESCT"+num$(N_PARAM),LPARM) From ADOVAL
    AESCT(N_PARAM) = LPARM
    If LPARM <> ""
      Call ECR_TRACE("  "+mess(82,GML_MSGPHY,1)-"AESCT"+num$(N_PARAM)-":"-AESCT(N_PARAM),0) From GESECRAN
    Endif
  Next

  For N_PARAM = 1 To 8
    Call PARAM([F:FAS]CPY,"AEPLNL"+num$(N_PARAM),LPARM) From ADOVAL

    If val(LPARM) = 10
      G_AEPLNL(N_PARAM) = 0
    Else
      G_AEPLNL(N_PARAM) = val(LPARM) + 6
      Call ECR_TRACE("  "+mess(82,GML_MSGPHY,1)-"AEPLNL"+num$(N_PARAM)-":"-mess(G_AEPLNL(N_PARAM),3101,1),0) From GESECRAN
    Endif
  Next

  Call PARAM([F:FAS]CPY,"PRVSITUPD",LPARM) From ADOVAL
  Call ECR_TRACE("  "+mess(685,GML_MSGFAS,1)-":"-mess(val(LPARM),1,1),0) From GESECRAN
  Call ECR_TRACE("----------------------------------------------------------------",0) From GESECRAN
Return

# FQ85865 poste de liasse
#**
#* si le poste de liasse n'existe pas : il est créé
#*
#* @param PCPY
#* @param PGAC
#* @param PIMP79 poste de liasse code Abel Entreprise
#*!
Subprog MAJ_POSTE(PCPY, PGAC, PIMP79)
Value Char PCPY, PGAC, PIMP79

    Local Integer WPSTELIA, I
    WPSTELIA = func GLOFUNCIMP.CONV_POSTEFLUX_AE(PIMP79)

    For [CNX] Where CPY = PCPY

    # flux plan poste compte
        For I = 0 To [F:CNX]NBPLC - 1
            If [F:CNX]COA(I) <> "" and [F:CNX]FLUTRATXS(I) <> ""

                If I = 0 or (I and
&                 ([F:CNX]COA(I) <> [F:CNX]COA(I - 1) or
&                  [F:CNX]FLUTRATXS(I) <> [F:CNX]FLUTRATXS(I - 1)))

                    Read[F:PFD]PFD1 = [F:CNX]FLUTRATXS(I); [F:CNX]COA(I); PGAC
                    If fstat
                        [F:PFD]CODTXS = [F:CNX]FLUTRATXS(I)
                        [F:PFD]COA = [F:CNX]COA(I)
                        [F:PFD]GAC = PGAC
                        [F:PFD]POSTXS = WPSTELIA
                        Write [PFD]

                    Read[F:PFL]PFL0 = [F:CNX]FLUTRATXS(I); [F:CNX]COA(I); WPSTELIA
                    If fstat
                        [F:PFL]CODTXS = [F:CNX]FLUTRATXS(I)
                        [F:PFL]COA = [F:CNX]COA(I)
                        [F:PFL]POSTXS = WPSTELIA
                        [F:PFL]CLATXS = 2
                        If WPSTELIA = 99
                            [F:PFL]OUTFUNDS = G_OUI
                        Else
                            [F:PFL]OUTFUNDS = G_NON
                        Endif
                        Write [PFL]
                    Endif
                #    Else
                #        If WPSTELIA <> [F:PFD]POSTXS
                #            # rien...
                #        Endif
                    Endif
                Endif
            Endif
        Next
    Next
End
