#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMBUD0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBLIG From SUBPJBU
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBLIG : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone ICO
mkstat = 0
zoncou = "ICO"
If varinit([M]ICO,indice)=0
 [M]ICO(indice) = "Folder.gif"
Endif

## Zone EXPFLG
mkstat = 0
zoncou = "EXPFLG"
If varinit([M]EXPFLG,indice)=0
 [M]EXPFLG(indice) = 1
Endif

## Zone CMT1
mkstat = 0
zoncou = "CMT1"
IMPENT = [M]CMT1(indice)
If varinit([M]CMT1,indice)=0
 IMPENT = 1
Endif
[M]CMT1(indice) = IMPENT

## Zone CMT5
mkstat = 0
zoncou = "CMT5"
SAVACT = GACTION : GACTION = "INIDEV"
GACTION = SAVACT
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PJBU0]CMT4(nolign-1),GDEVISE(1..GNBDEV)),1))
If mkstat=1 : Raz [M]CMT5(indice) : Endif

## Zone CMT6
mkstat = 0
zoncou = "CMT6"
SAVACT = GACTION : GACTION = "INIDEV"
GACTION = SAVACT
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PJBU0]CMT4(nolign-1),GDEVISE(1..GNBDEV)),1))
If mkstat=1 : Raz [M]CMT6(indice) : Endif

## Zone CMT2
mkstat = 0
zoncou = "CMT2"
IMPENT = [M]CMT2(indice)
If varinit([M]CMT2,indice)=0
 IMPENT = 1
Endif
[M]CMT2(indice) = IMPENT

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMBUD0"
Return

