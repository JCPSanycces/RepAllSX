#<AdxTL>@(#)0.0.0.0 $Revision$Class Asset
# Supervisor
## ACLA-CLASSE ## FXDASSETS_KPORVA
# 2018-11-06 07:07:22 787

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0FXDASSETS_KPORVA
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_KANOREAV From WMC1FXDASSETS_KPORVA : Gosub TESTALLSTAT
Gosub INIT_KVREAV From WMC1FXDASSETS_KPORVA : Gosub TESTALLSTAT
Gosub INIT_KAREAV From WMC1FXDASSETS_KPORVA : Gosub TESTALLSTAT
Gosub INIT_KCOEF From WMC1FXDASSETS_KPORVA : Gosub TESTALLSTAT
Gosub INIT_KANOUTIL From WMC1FXDASSETS_KPORVA : Gosub TESTALLSTAT
Gosub AINIT From WMC0FXDASSETS_KPORVA : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0FXDASSETS_KPORVA
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0FXDASSETS_KPORVA
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



