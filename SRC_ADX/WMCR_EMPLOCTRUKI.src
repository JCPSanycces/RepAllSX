#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional fields
# Supervisor
## CRUD-CLASSE ## EMPLOCTRUKI
# 2018-11-06 07:05:29 271


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File EMPLOCTRUKI [CTRUKI_]

If !SILENCE : Call TRACE("2 --> Local Instance C_EMPLOCTRUKI") From ASYRCOM : Endif
Local Instance EMPLOCTRUKI Using C_EMPLOCTRUKI

If !SILENCE : Call TRACE("3 --> New Instance C_EMPLOCTRUKI") From ASYRCOM : Endif
EMPLOCTRUKI = NewInstance C_EMPLOCTRUKI AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [CTRUKI_]CTRUKI0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of EMPLOCTRUKI") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI.AREAD([CTRUKI_]REFNUM,[CTRUKI_]CTRNUM,[CTRUKI_]CTRDAT))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("EMPLOCTRUKI.REFNUM ="-num$(EMPLOCTRUKI.REFNUM)) From ASYRCOM
 Call TRACE("EMPLOCTRUKI.CTRNUM ="-num$(EMPLOCTRUKI.CTRNUM)) From ASYRCOM
 Call TRACE("EMPLOCTRUKI.CTRDAT ="-num$(EMPLOCTRUKI.CTRDAT)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(EMPLOCTRUKI.AKEYS)
  Call TRACE("-"-num$(I)-":"-EMPLOCTRUKI.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [CTRUKI_]
FreeGroup EMPLOCTRUKI
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(EMPLOCTRUKI,ACLE,ASTATUS,_ETAG)
Variable Instance EMPLOCTRUKI Using C_EMPLOCTRUKI
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _REFNUM(15)
Local Char _CTRNUM(20)
Local Date _CTRDAT
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_CTRNUM = num$([L]CLE(2)) : Endif
If [L]CLE(3)<>"" : [L]_CTRDAT = func ASYRSUB.DATE_TO_ADX([L]CLE(3)) : Endif
Raz [L]_ETAG
Local File EMPLOCTRUKI [CTRUKI]
Default File [F:CTRUKI]
Read [F:CTRUKI]CTRUKI0 = [L]_REFNUM;[L]_CTRNUM;[L]_CTRDAT
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:CTRUKI]UPDTICK)>0
 [L]_ETAG = num$([F:CTRUKI]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(EMPLOCTRUKI,ACLE,ASTATUS)
Variable Instance EMPLOCTRUKI Using C_EMPLOCTRUKI
Value Char ACLE
Variable Integer ASTATUS
Local Char _REFNUM(15)
Local Char _CTRNUM(20)
Local Date _CTRDAT
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_CTRNUM = num$([L]CLE(2)) : Endif
If [L]CLE(3)<>"" : [L]_CTRDAT = func ASYRSUB.DATE_TO_ADX([L]CLE(3)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI.AREAD([L]_REFNUM,[L]_CTRNUM,[L]_CTRDAT))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(EMPLOCTRUKI,_REFNUM,_CTRNUM,_CTRDAT,ASTATUS)
Variable Instance EMPLOCTRUKI Using C_EMPLOCTRUKI
Value Char _REFNUM
Value Char _CTRNUM
Value Date _CTRDAT
Variable Integer ASTATUS

If EMPLOCTRUKI = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOCTRUKI
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If EMPLOCTRUKI.APARENT=null
 [L]A_I = EMPLOCTRUKI.freeSnapshot
 EMPLOCTRUKI.snapshotEnabled = 0
 EMPLOCTRUKI.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & EMPLOCTRUKI.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If EMPLOCTRUKI.APARENT=null
 EMPLOCTRUKI.snapshotEnabled = 1
 EMPLOCTRUKI.setAccessorEnabled = 1
Endif
LogicClose File [CTRUKI]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI._ACTION_PARAM("AREAD_BEFORE",[L]_REFNUM,[L]_CTRNUM,[L]_CTRDAT))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:CTRUKI]
Read [F:CTRUKI]CTRUKI0 = [L]_REFNUM;[L]_CTRNUM;[L]_CTRDAT
If fstat
[L]A_ERROR = [L]_REFNUM+"~"+[L]_CTRNUM+"~"+num$([L]_CTRDAT)
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(EMPLOCTRUKI,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:CTRUKI]AUUID)>0 & [F:CTRUKI]AUUID=NullUuid
 [F:CTRUKI]AUUID = getUuid
Endif
SetInstance EMPLOCTRUKI With [F:CTRUKI]
EMPLOCTRUKI.ASTALIN = [V]CST_ALL

[L]A_NEWCOL = 0
For [L]A_I=1 To 3
 If ([F:CTRUKI]ADDLIN1([L]A_I-1)<>"" or [F:CTRUKI]ADDLIN2([L]A_I-1)<>"" or [F:CTRUKI]TWN([L]A_I-1)<>""
& or [F:CTRUKI]CUY([L]A_I-1)<>"" or [F:CTRUKI]POS([L]A_I-1)<>"" or [F:CTRUKI]CRYCNT([L]A_I-1)<>"" or [F:CTRUKI]TEL([L]A_I-1)<>""
& or [F:CTRUKI]EML([L]A_I-1)<>"" or [F:CTRUKI]TYP([L]A_I-1)<>0 or [F:CTRUKI]SETDEF([L]A_I-1)<>0 or [F:CTRUKI]NUKADD([L]A_I-1)<>0
& or [F:CTRUKI]PIO([L]A_I-1)<>0 or [F:CTRUKI]MOB([L]A_I-1)<>"" or [F:CTRUKI]WRKMOB([L]A_I-1)<>"" or [F:CTRUKI]FAX([L]A_I-1)<>""
& or [F:CTRUKI]ETS([L]A_I-1)<>"" or [F:CTRUKI]OTHEML([L]A_I-1)<>"")
  [L]A_NEWCOL += 1
  EMPLOCTRUKI.UKADD(A_NEWCOL) = NewInstance  C_EMPLOCTRUKI_UKADD(EMPLOCTRUKI.ACTX,NullUuid,[L]A_I,EMPLOCTRUKI,"UKADD") AllocGroup EMPLOCTRUKI
  EMPLOCTRUKI.UKADD(A_NEWCOL).ADDLIN1 = [F:CTRUKI]ADDLIN1([L]A_I-1)
  EMPLOCTRUKI.UKADD(A_NEWCOL).ADDLIN2 = [F:CTRUKI]ADDLIN2([L]A_I-1)
  EMPLOCTRUKI.UKADD(A_NEWCOL).TWN = [F:CTRUKI]TWN([L]A_I-1)
  EMPLOCTRUKI.UKADD(A_NEWCOL).CUY = [F:CTRUKI]CUY([L]A_I-1)
  EMPLOCTRUKI.UKADD(A_NEWCOL).POS = [F:CTRUKI]POS([L]A_I-1)
  EMPLOCTRUKI.UKADD(A_NEWCOL).CRYCNT = [F:CTRUKI]CRYCNT([L]A_I-1)
  EMPLOCTRUKI.UKADD(A_NEWCOL).TEL = [F:CTRUKI]TEL([L]A_I-1)
  EMPLOCTRUKI.UKADD(A_NEWCOL).EML = [F:CTRUKI]EML([L]A_I-1)
  EMPLOCTRUKI.UKADD(A_NEWCOL).TYP = [F:CTRUKI]TYP([L]A_I-1)
  EMPLOCTRUKI.UKADD(A_NEWCOL).SETDEF = [F:CTRUKI]SETDEF([L]A_I-1)
  EMPLOCTRUKI.UKADD(A_NEWCOL).NUKADD = [F:CTRUKI]NUKADD([L]A_I-1)
  EMPLOCTRUKI.UKADD(A_NEWCOL).PIO = [F:CTRUKI]PIO([L]A_I-1)
  EMPLOCTRUKI.UKADD(A_NEWCOL).MOB = [F:CTRUKI]MOB([L]A_I-1)
  EMPLOCTRUKI.UKADD(A_NEWCOL).WRKMOB = [F:CTRUKI]WRKMOB([L]A_I-1)
  EMPLOCTRUKI.UKADD(A_NEWCOL).FAX = [F:CTRUKI]FAX([L]A_I-1)
  EMPLOCTRUKI.UKADD(A_NEWCOL).ETS = [F:CTRUKI]ETS([L]A_I-1)
  EMPLOCTRUKI.UKADD(A_NEWCOL).OTHEML = [F:CTRUKI]OTHEML([L]A_I-1)
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI.UKADD(A_NEWCOL).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



