Subprog AS_OPENUM(VALEUR)
Variable Decimal  VALEUR
If GREP<>"C" & VALEUR <> 0 & [M:ROU1]CREFLG(nolign-1) > 0 : mkstat=2 : Endif
GBOUT1=mess(19,195,1)
End

########################################################################
Subprog S_ITMREF(VALEUR)
Variable Char     VALEUR
#Si la selection porte sur la table des gammes, on récupère l'alternative
If !find(GREP,"C","D") & VALEUR <> ""
   Read [F:ROH]ROH0 Curr
   If !fstat & [F:ROH]ITMREF = VALEUR
        [M:ROU0]ROUALT = [F:ROH]ROUALT
        [M:ROU0]FCY    = [F:ROH]FCY
   Endif
Endif
End

