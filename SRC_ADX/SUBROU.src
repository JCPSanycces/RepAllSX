# Ticket 101397 Automatically conversion of setup and run time in routings
######################################################################################
## Recalculate setup and run time from hours to minutes and vice versa
######################################################################################
Subprog CHANGETIMVALUE(UNIT)
Variable Integer UNIT
# UNIT = 1 = hours (minutes before, divide by 60)
# UNIT = 2 = minutes (hours before, multiply with 60)

Local Integer I

For I = 0 To [M:ROU1]NBLIG-1
    # hours
    If UNIT = 1
      # Run time
      If [M:ROU1]OPETIM(I) <> 0
        [M:ROU1]OPETIM(I) = [M:ROU1]OPETIM(I) / 60
      Endif
      # Setup time
      If [M:ROU1]SETTIM(I) <> 0
        [M:ROU1]SETTIM(I) = [M:ROU1]SETTIM(I) / 60
      Endif
    Endif

    # minutes
    If UNIT = 2
      # Run time
      If [M:ROU1]OPETIM(I) <> 0
        [M:ROU1]OPETIM(I) = [M:ROU1]OPETIM(I) * 60
      Endif
      # Setup time
      If [M:ROU1]SETTIM(I) <> 0
        [M:ROU1]SETTIM(I) = [M:ROU1]SETTIM(I) * 60
      Endif
    Endif

    Affzo [ROU1]OPETIM(I)
    Affzo [ROU1]SETTIM(I)
    [M:ROU1]UPDFLG(I)  = 2

Next I

End

######################################################################################
## Section automatically added (screen ROU0) 01/09/2015 12:33:05 (FRHOL)
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

# Issue 104494 - 2014-12-23 by FRHOL : Title must be initialized with product description
Call CHARGE_DEFITMDES("DES1AXX", GLANGUE, [F:ITM]ITMREF, [M:ROU0]ROUDESAXX, "[F:ITM]") From TRTX3
Affzo[M:ROU0]ROUDESAXX

Call AM_ITMREF(VALEUR) From ECCROU # Issue 104937 - 2015-11 by GH : versioning

# Issue 110957 - 2015-09-21 by CCC
If !mkstat & !GIMPORT & dim([M:ROU0]CRID)=1
    [M:ROU0]CRID = func TRTX3FNC.CCMID(VALEUR,"","")
    Affzo [ROU0]CRID
    If dim([M:ROU0]CRFLG)>0
       [M:ROU0]CRFLG = string$([M:ROU0]CRID<>"","151")
       Affzo [ROU0]CRFLG
    Endif
Endif

End

