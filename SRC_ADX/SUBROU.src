########################################
Subprog AM_ROUALT(VALEUR)
Variable Decimal VALEUR
# FQ56381 - MABON 09/07/09 - Le site n'est pas initialisé si on arrive dans la gestion des Gammes depuis les articles
# Ajout du test GREP=""
If GREP = "C" or GREP="" Then
    If clalev([F:TRO]) = 0 : Local File TABROUALT [TRO] : Endif
    Read [F:TRO]TRO0 = VALEUR
    If !fstat Then
      # MHB 20/10/08 : En création, [M:ROU0]FCY est vide
#      If [F:TRO]FCY <> "" & [M:ROU0]FCY <> "" & ([F:TRO]FCY <> [M:ROU0]FCY)
# FQ60130 - MABON 30/11/09 - La vérification n'était plus faite : elle est remise, mais avec ajout vérif sur GREP
#      If [F:TRO]FCY <> "" & ([F:TRO]FCY <> [M:ROU0]FCY)

# FQ72951 GBE 06/04/11 Quand on arrive depuis les nomenclatures de production le GREP est à NULL
#      If [F:TRO]FCY <> "" & ([M:ROU0]FCY <> "" | GREP="C") & ([F:TRO]FCY <> [M:ROU0]FCY)
      If [F:TRO]FCY <> "" & ([M:ROU0]FCY <> "" | GREP="C" | GFONC1="GESBOD") & ([F:TRO]FCY <> [M:ROU0]FCY)
        [M:ROU0]FCY = [F:TRO]FCY
        If !GIMPORT : Affzo [M:ROU0]FCY : Endif
      Endif
    Endif
Endif
End

########################################
Subprog S_WST(VALEUR)
Variable Char    VALEUR()
If VALEUR="" mkstat=1 : End : Endif

If [F:MWS]WST = "" : End : Endif

Read [F:MWS]WST0 Curr
If !fstat & [F:MWS]WST = VALEUR & [F:MWS]WCRFCY = [M:ROU0]FCY
    If GIMPORT
        [M:ROU1]WCR(nolign-1)=[F:MWS]WCR
        [M:ROU1]WSTTYP(nolign-1)=[F:MWS]WSTTYP
    Else
       If instr(1,dbgstr(1),"ROF1")
          [M:ROF1]WCR=[F:MWS]WCR
          [M:ROF1]WSTTYP=[F:MWS]WSTTYP
          Affzo [M:ROF1]WCR, WSTTYP
       Else
          [M:ROU1]WCR(nolign-1)=[F:MWS]WCR
          [M:ROU1]WSTTYP(nolign-1)=[F:MWS]WSTTYP
          Affzo [M:ROU1]WCR(nolign-1), WSTTYP(nolign-1)
       Endif
    Endif
Endif
End

########################################
Subprog S_LABWST(VALEUR)
Variable Char    VALEUR()
If VALEUR="" mkstat=1 : End : Endif
Read [F:MWS]WST0 Curr
If !fstat & [F:MWS]WST = VALEUR & [F:MWS]WCRFCY = [M:ROU0]FCY
    If GIMPORT
        [M:ROU1]LABWCR(nolign-1)=[F:MWS]WCR
        [M:ROU1]LABWSTTYP(nolign-1)=[F:MWS]WSTTYP
    Else
        If instr(1,dbgstr(1),"ROF1")
           [M:ROF1]LABWCR=[F:MWS]WCR
           [M:ROF1]LABWSTTYP=[F:MWS]WSTTYP
           Affzo [M:ROF1]LABWCR, LABWSTTYP
        Else
           [M:ROU1]LABWCR(nolign-1)=[F:MWS]WCR
           [M:ROU1]LABWSTTYP(nolign-1)=[F:MWS]WSTTYP
           Affzo [M:ROU1]LABWCR(nolign-1), LABWSTTYP(nolign-1)
        Endif
    Endif
Endif
End

########################################
Subprog S_SCOWST(VALEUR)
Variable Char    VALEUR()
If VALEUR="" mkstat=1 : End : Endif
Read [F:MWS]WST0 Curr
If !fstat & [F:MWS]WST = VALEUR & [F:MWS]WCRFCY = [M:ROU0]FCY & WSTTYP = 3
    If GIMPORT
        [M:ROU1]SCOWCR(nolign-1)=[F:MWS]WCR
        [M:ROU1]SCOWSTTYP(nolign-1)=[F:MWS]WSTTYP
    Else
        If instr(1,dbgstr(1),"ROF2")
           [M:ROF2]SCOWCR=[F:MWS]WCR
           [M:ROF2]SCOWSTTYP=[F:MWS]WSTTYP
           Affzo [M:ROF2]SCOWCR, SCOWSTTYP
        Else
           [M:ROU1]SCOWCR(nolign-1)=[F:MWS]WCR
           [M:ROU1]SCOWSTTYP(nolign-1)=[F:MWS]WSTTYP
           Affzo [M:ROU1]SCOWCR(nolign-1), SCOWSTTYP(nolign-1)
        Endif
    Endif
Endif
End

