########################################
Subprog AS_SCOITMREF(VALEUR)
Variable Char     VALEUR
# article sous-traitance non saisissable si code sous-traitance à Non
If instr(1,dbgstr(1),"ROU1") | GIMPORT
   If [M:ROU1]SCOCOD(nolign-1)=1 : mkstat=2 : Endif
Elsif instr(1,dbgstr(1),"ROF2")
   If [M:ROF2]SCOCOD=1 : mkstat=2 : Endif
Endif
End

########################################
Subprog AM_SCOITMREF(VALEUR)    # Demande 12647 MM 03.02
Variable Char    VALEUR()
If VALEUR<>""
    If clalev ([F:ITP]) = 0 : Local File ITMBPS [ITP] : Endif
    For [ITP]ITP1 Where ITMREF=VALEUR & PIO=1
        Read [ITP]ITP1 First
        If fstat : [M:ROU1]BPRNUM(nolign-1)=""
        Else     : [M:ROU1]BPRNUM(nolign-1)= [F:ITP]BPSNUM
        Endif
        Affzo [M:ROU1]BPRNUM(nolign-1)
        Break
    Next
Endif
If maskcou = "ROF2" : OMODIF = 1 : Endif
End


#####################################
Subprog C_SCOCOD(VALEUR)
Variable Integer  VALEUR
# si type poste principal=sous-traitance, la sous-traitance=structurelle
If instr(1,dbgstr(1),"ROU1") | GIMPORT
   If VALEUR=2 & [M:ROU1]WSTTYP(nolign-1) <> 3 : GMESSAGE=mess(6,193,1) : mkstat=2 : Endif
Endif
If instr(1,dbgstr(1),"ROF2") : Gosub C_SCOCOD From SUBROUA : Endif
End

##############################################
Subprog AP_WST(VALEUR)
Variable Char     VALEUR
# affichage du centre choisi en retour de la consultation des postes
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
If VALEUR <> ""
   Read [MWS]WST0=VALEUR;[M:ROU0]FCY
   If !fstat
      If GIMPORT
          [M:ROU1]WCR(nolign-1)=[F:MWS]WCR
      Else
          If instr(1,dbgstr(1),"ROU1")
             [M:ROU1]WCR(nolign-1)=[F:MWS]WCR : Affzo [ROU1]WCR(nolign-1)
          Else
             [M:ROF1]WCR=[F:MWS]WCR : Affzo [ROF1]WCR
          Endif
      Endif
   Endif
Endif
End

###################################
Subprog AP_SCOWST(VALEUR)
Variable Char     VALEUR
# affichage du centre choisi en retour de la consultation des postes
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
If VALEUR <> ""
   Read [MWS]WST0=VALEUR;[M:ROU0]FCY
   If !fstat
      If GIMPORT
          [M:ROU1]SCOWCR(nolign-1)=[F:MWS]WCR
      Else
          If instr(1,dbgstr(1),"ROU1")
             [M:ROU1]SCOWCR(nolign-1)=[F:MWS]WCR : Affzo [ROU1]SCOWCR(nolign-1)
          Else
             [M:ROF2]SCOWCR=[F:MWS]WCR : Affzo [ROF2]SCOWCR
          Endif
      Endif
   Endif
Endif
End

###################################
Subprog AP_LABWST(VALEUR)
Variable Char     VALEUR
# affichage du centre choisi en retour de la consultation des postes
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
If VALEUR <> ""
   Read [MWS]WST0=VALEUR;[M:ROU0]FCY
   If !fstat
      If GIMPORT
          [M:ROU1]LABWCR(nolign-1)=[F:MWS]WCR
      Else
          If instr(1,dbgstr(1),"ROU1")
             [M:ROU1]LABWCR(nolign-1)=[F:MWS]WCR : Affzo [ROU1]LABWCR(nolign-1)
          Else
             [M:ROF1]LABWCR=[F:MWS]WCR : Affzo [ROF1]LABWCR
          Endif
      Endif
   Endif
Else
    If GIMPORT
        [M:ROU1]SETLABCOE(nolign-1)=0
        [M:ROU1]OPELABCOE(nolign-1)=0
    Else
        If instr(1,dbgstr(1),"ROU1")
            [M:ROU1]SETLABCOE(nolign-1)=0 : [M:ROU1]OPELABCOE(nolign-1)=0
            Affzo [ROU1]SETLABCOE(nolign-1), OPELABCOE(nolign-1)
        Else
            [M:ROF1]SETLABCOE=0 : [M:ROF1]OPELABCOE=0        # llc 10.01 10821
            Affzo [ROF1]SETLABCOE, OPELABCOE
        Endif
    Endif
Endif
End

#######################################
Subprog AS_STDOPENUM(VALEUR)
Variable Decimal VALEUR
GBOUT1=""
GBOUT2=""
GBOUT1=mess(247,198,1)
End

########################################
Subprog C_STDOPENUM(VALEUR)
Variable Decimal VALEUR
Local Integer NOL : NOL = nolign-1
If VALEUR = 0 : End : Endif
If clalev([ROT])=0 : Local File ROUOPESTD  [ROT] : Endif
If clalev([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
Read [ROT]ROT0=VALEUR;[M:ROU0]FCY
# If fstat : GMESSAGE = mess(133,193,1)
If fstat : GMESSAGE = mess(273,193,1) : # Opération standard inexistante sur ce site
           mkstat = 1
           End
Endif
End

#######################################
Subprog AM_STDOPENUM(VALEUR) : # récup possible des données opé std
Variable Decimal  VALEUR
OMODIF=1

Gosub B2_STDOPENUM From SUBROUA

# 17809 MM 07.05 : gestion d'un coef multiplicateur des temps liés à une opération standard
If VALEUR<>0
    If instr(1,dbgstr(1),"ROF0")
        [M:ROF1]CTIMCOE = 1 : [M:ROF1]HCTIMCOE = 1
        Affzo [M:ROF1]CTIMCOE,HCTIMCOE
        Actzo [M:ROF1]CTIMCOE,HCTIMCOE
    Elsif instr(1,dbgstr(1),"ROU1") | GIMPORT
        [M:ROU1]CTIMCOE(nolign-1) = 1 : [M:ROU1]HCTIMCOE(nolign-1) = 1
        Affzo  [M:ROU1]CTIMCOE(nolign-1),HCTIMCOE(nolign-1)
    Endif
Endif
End

