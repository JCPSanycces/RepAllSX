######################################################################################
## Etiquette ajoutée par le superviseur (écran ROU0) 22/10/2008 14:52:18 (MABON)
######################################################################################
# MHB 22/10/08 : pour forcer la relecture de la gamme, si seul le site a été changé par la sélection
Subprog S_ROUALT(VALEUR)
Variable Decimal VALEUR
Local    Char    FCYS(GLONFCY)

If !find(GREP,"C","D") & VALEUR <> 0
  Read [F:ROH] Curr
  FCYS = [M:ROU0]FCY
  If !fstat Then
    [M:ROU0]FCY = [F:ROH]FCY
  Endif
  # Même si ROUALT n'a pas changé, FCY a pu changer quant à lui : il faut donc recharger les nouveaux éléments
  If VALEUR=[M:ROU0]ROUALT Then
    If FCYS<>[F:ROH]FCY Then
      [M:ROU0]ROUALT = VALEUR
      [M:ROU1]NBLIG = 0
      Effzo [M:ROU1] : Effzo [M:ROU2] : Effzo [M:ROU3]
      ACTION = 'LIENS' : Gosub ACTION
      Affzo [M:ROU0] : Affzo [M:ROU1] : Affzo [M:ROU2] : Affzo [M:ROU3]
    Endif
  Endif
Endif
End

