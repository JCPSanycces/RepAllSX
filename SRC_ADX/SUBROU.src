######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Local Integer I
#Issue X3-69914 22/02/2018 By GEBIL : Problem in routing duplication
#If [M:ROU1]NBLIG <> 0
If VALEUR <> [M:ROU0]FCY & [M:ROU1]NBLIG <> 0
    For I = 0 To [M:ROU1]NBLIG-1
            Raz [M:ROU1]STDOPENUM(I)
    Next
    If !GIMPORT
        Affzo [M:ROU1]1-99
    Endif
Endif
End

