Endif
End

########################################
Subprog AM_TIMUOMCOD(VALEUR)
Variable Integer  VALEUR
Local Integer OK
# 02.08 Bug 46078 Il n'y avait aucun message lors du changement
#       d'unité en création de gamme
If (GREP<>"C" & GREP<>"D" | (GREP="C" & [M:ROU1]NBLIG <>0))
    # If VALEUR<>0 : Call MESSAGE(mess(23,193,1)) From GESECRAN : Endif
    # Issue 101397 - 2014-11-10 by JUSYN : Automatically conversion of setup and run time in routings
    Call OUINON(mess(302,193,1),OK) From GESECRAN
    If OK = 2
        Call CHANGETIMVALUE(VALEUR)
        If VALEUR = 1
            # Setup and Run time have been converted from minutes to hours
            Call MESSAGE(mess(300,193,1)) From GESECRAN
        Else
            # Setup and Run time have been converted from hours to minutes
            Call MESSAGE(mess(301,193,1)) From GESECRAN
        Endif
    Else
        If VALEUR<>0 : Call MESSAGE(mess(23,193,1)) From GESECRAN : Endif
    Endif
Endif
If instr(1,dbgstr(1),"ROF1") : OMODIF = 1 : Endif
End

