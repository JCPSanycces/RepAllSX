#   Endif
#Endif
End

#########################################
Subprog AM_SCOCOD(VALEUR) : # zones remises à blanc si code ss-trce à Non
Variable Integer  VALEUR

If instr(1,dbgstr(1),"ROF2")
   If VALEUR=1
      Grizo [M:ROF2]30 : Actzo [M:ROF2]SCOCOD : Gosub AM_SCOCOD From SUBROUA
   Else
      Actzo [M:ROF2]30
   Endif
   OMODIF = 1
Elsif VALEUR = 1
   [M:ROU1]SCOITMREF(nolign-1)="" : [M:ROU1]SCOWST(nolign-1)=""
   [M:ROU1]SCOWCR(nolign-1)="" : [M:ROU1]SCOWSTTYP(nolign-1)=0
   [M:ROU1]XSCOWSTTYP(nolign-1)=""
   [M:ROU1]BPRNUM(nolign-1)=""
   [M:ROU1]BPAADD(nolign-1)=""
   If !GIMPORT
       Affzo [ROU1]SCOITMREF(nolign-1), SCOWST(nolign-1), SCOWCR(nolign-1)
       Affzo [ROU1]XSCOWSTTYP(nolign-1)
   Endif
Endif
End

########################################################
Subprog AV_WST(VALEUR)
Variable Char     VALEUR
# affichage des zones liées au poste de charge principal
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
If VALEUR <> ""
  Read [MWS]WST0=VALEUR;[M:ROU0]FCY
  If !fstat
      If instr(1,dbgstr(1),"ROU1") | GIMPORT
          [M:ROU1]WCR(nolign-1)=[F:MWS]WCR : [M:ROU1]WSTTYP(nolign-1)=[F:MWS]WSTTYP
          [M:ROU1]XWSTTYP(nolign-1)=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
          If !GIMPORT : Affzo [ROU1]WCR(nolign-1), XWSTTYP(nolign-1) : Endif
      Endif
      If instr(1,dbgstr(1),"ROF1") : Gosub AV_WST From SUBROUA : Endif
  Endif
Endif
End

###########################################################
Subprog AM_WST(VALEUR)
Variable Char     VALEUR
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
If VALEUR <> ""
    Read [MWS]WST0=VALEUR;[M:ROU0]FCY
    If !fstat
        If instr(1,dbgstr(1),"ROU1") | GIMPORT
            [M:ROU1]WCR(nolign-1)=[F:MWS]WCR : [M:ROU1]WSTTYP(nolign-1)=[F:MWS]WSTTYP
            [M:ROU1]XWSTTYP(nolign-1)=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
            [M:ROU1]WSTNBR(nolign-1) = [F:MWS]WSTNBR
            Case GWSTEFFINH
                When 1:        # ben rien
                When Default:  [M:ROU1]EFF(nolign-1) = [F:MWS]EFF
            Endcase
            [M:ROU1]SHR(nolign-1) = [F:MWS]SHR
            If !GIMPORT
                Affzo [ROU1]WCR(nolign-1)
                Affzo [ROU1]XWSTTYP(nolign-1)
                Affzo [ROU1]EFF(nolign-1)
                Affzo [ROU1]SHR(nolign-1)
            Endif
            If [F:MWS]WSTTYP=3
                [M:ROU1]SCOCOD(nolign-1)=2 : [M:ROU1]SCOWST(nolign-1)=VALEUR
                [M:ROU1]LABWCR(nolign-1)="" : [M:ROU1]LABWST(nolign-1)=""
                [M:ROU1]LABWSTTYP(nolign-1)=0
                [M:ROU1]XLABWSTTYP(nolign-1)=""
                [M:ROU1]SETLABCOE(nolign-1)=0 : [M:ROU1]OPELABCOE(nolign-1)=0
                If !GIMPORT
                    Affzo [ROU1]LABWCR(nolign-1), XLABWSTTYP(nolign-1), LABWST(nolign-1)
                    Affzo [ROU1]SETLABCOE(nolign-1), OPELABCOE(nolign-1), WSTNBR(nolign-1)
                Endif
            Endif
            If [F:MWS]WSTTYP<>3 & [M:ROU1]SCOCOD(nolign-1)=2 : [M:ROU1]SCOCOD(nolign-1)=3 : Endif
        Endif
        If instr(1,dbgstr(1),"ROF1") : OMODIF=1 : Gosub AM_WST From SUBROUA : Endif
    Endif
Else
    [M:ROU1]WCR(nolign-1)="" : [M:ROU1]WSTTYP(nolign-1)=0
    [M:ROU1]XWSTTYP(nolign-1)=""
    [M:ROU1]WSTNBR(nolign-1) = 0
    [M:ROU1]EFF(nolign-1) = 100
    [M:ROU1]SHR(nolign-1) = 0
    If instr(1,dbgstr(1),"ROU1") | GIMPORT
        [M:ROU1]WCR(nolign-1)="" : [M:ROU1]WSTTYP(nolign-1)=0
        [M:ROU1]XWSTTYP(nolign-1)=""
        If !GIMPORT
            Affzo [ROU1]WCR(nolign-1)
            Affzo [ROU1]XWSTTYP(nolign-1)
            Affzo [ROU1]EFF(nolign-1)
            Affzo [ROU1]SHR(nolign-1)
        Endif
    Endif
    If instr(1,dbgstr(1),"ROF1") : OMODIF=1 : Gosub AM_WST From SUBROUA : Endif
Endif
End

########################################################
Subprog AV_LABWST(VALEUR)
Variable Char     VALEUR
# affichage des zones liées au poste main-d'oeuvre
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
If instr(1,dbgstr(1),"ROU1") | GIMPORT
    If [M:ROU1]WSTTYP(nolign-1)=3
        VALEUR="" : [M:ROU1]LABWCR(nolign-1)="" : [M:ROU1]LABWSTTYP(nolign-1)=0
        [M:ROU1]XLABWSTTYP(nolign-1)=""
        If !GIMPORT : Affzo [ROU1]LABWCR(nolign-1), XLABWSTTYP(nolign-1) : Endif
    Endif
    If VALEUR <> ""
        Read [MWS]WST0=VALEUR;[M:ROU0]FCY
        If !fstat
            [M:ROU1]LABWCR(nolign-1)=[F:MWS]WCR : [M:ROU1]LABWSTTYP(nolign-1)=[F:MWS]WSTTYP
            [M:ROU1]XLABWSTTYP(nolign-1)=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
            If !GIMPORT : Affzo [ROU1]LABWCR(nolign-1), XLABWSTTYP(nolign-1) : Endif
        Endif
    Endif
Endif
If instr(1,dbgstr(1),"ROF1") : Gosub AV_LABWST From SUBROUA : Endif
End

#######################################
Subprog AM_LABWST(VALEUR) : # idem AV_LABWST
Variable Char     VALEUR
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif

If instr(1,dbgstr(1),"ROU1") | GIMPORT
    If VALEUR <> ""
        Read [MWS]WST0=VALEUR;[M:ROU0]FCY
        If !fstat
            [M:ROU1]LABWCR(nolign-1)=[F:MWS]WCR : [M:ROU1]LABWSTTYP(nolign-1)=[F:MWS]WSTTYP
            [M:ROU1]LABNBR(nolign-1)=[F:MWS]WSTNBR
            [M:ROU1]XLABWSTTYP(nolign-1)=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
            If !GIMPORT : Affzo [ROU1]LABWCR(nolign-1), XLABWSTTYP(nolign-1), LABNBR(nolign-1) : Endif
        Endif
        If [M:ROU1]SETLABCOE(nolign-1)=0 : [M:ROU1]SETLABCOE(nolign-1)=1 : Endif
        If [M:ROU1]OPELABCOE(nolign-1)=0 : [M:ROU1]OPELABCOE(nolign-1)=1 : Endif
    Else
        [M:ROU1]LABWCR(nolign-1)="" : [M:ROU1]LABWSTTYP(nolign-1)=0 : [M:ROU1]LABNBR(nolign-1)=0
        [M:ROU1]XLABWSTTYP(nolign-1)=""
        If !GIMPORT : Affzo [ROU1]LABWCR(nolign-1), XLABWSTTYP(nolign-1), LABNBR(nolign-1) : Endif
    Endif
Endif
If instr(1,dbgstr(1),"ROF1") : OMODIF = 1 : Gosub AM_LABWST From SUBROUA : Endif
End

###########################################
Subprog AV_SCOWST(VALEUR)
Variable Char     VALEUR
# affichage des zones liées au poste de sous-traitance
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
If instr(1,dbgstr(1),"ROU1") | GIMPORT
    If VALEUR <> ""
        Read [MWS]WST0=VALEUR;[M:ROU0]FCY
        If !fstat
            [M:ROU1]SCOWCR(nolign-1)=[F:MWS]WCR : [M:ROU1]SCOWSTTYP(nolign-1)=[F:MWS]WSTTYP
            [M:ROU1]XSCOWSTTYP(nolign-1)=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
            If !GIMPORT : Affzo [ROU1]SCOWCR(nolign-1), XSCOWSTTYP(nolign-1) : Endif
        Endif
    Endif
Endif
If instr(1,dbgstr(1),"ROF2") : Gosub AV_SCOWST From SUBROUA : Endif
End

########################################
Subprog AM_SCOWST(VALEUR)
Variable Char     VALEUR
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
If instr(1,dbgstr(1),"ROU1") | GIMPORT
    If VALEUR <> ""
        Read [MWS]WST0=VALEUR;[M:ROU0]FCY
        If !fstat
            [M:ROU1]SCOWCR(nolign-1)=[F:MWS]WCR : [M:ROU1]SCOWSTTYP(nolign-1)=[F:MWS]WSTTYP
            [M:ROU1]XSCOWSTTYP(nolign-1)=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
            If !GIMPORT : Affzo [ROU1]SCOWCR(nolign-1), XSCOWSTTYP(nolign-1) : Endif
        Endif
    Else
        [M:ROU1]SCOWCR(nolign-1)="" : [M:ROU1]SCOWSTTYP(nolign-1)=0
        [M:ROU1]XSCOWSTTYP(nolign-1)=""
        If !GIMPORT : Affzo [ROU1]SCOWCR(nolign-1), XSCOWSTTYP(nolign-1) : Endif
    Endif
Endif
If instr(1,dbgstr(1),"ROF2") : OMODIF=1 : Gosub AM_SCOWST From SUBROUA : Endif
End

#####################################################
Subprog AV_NOLIG(VALEUR) : # alimentation des zones liées aux postes de charge
Variable Decimal  VALEUR
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
If VALEUR <> 0
   If instr(1,dbgstr(1),"ROU1") | GIMPORT
      If [M:ROU1]WST(nolign-1) <> ""
         Read [MWS]WST0=[M:ROU1]WST(nolign-1);[M:ROU0]FCY
         If !fstat
            [M:ROU1]WCR(nolign-1)=[F:MWS]WCR
            [M:ROU1]WSTTYP(nolign-1)=[F:MWS]WSTTYP
            [M:ROU1]XWSTTYP(nolign-1)=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
         Endif
      Endif
      If [M:ROU1]LABWST(nolign-1) <> ""
         Read [MWS]WST0=[M:ROU1]LABWST(nolign-1);[M:ROU0]FCY
         If !fstat
            [M:ROU1]LABWCR(nolign-1)=[F:MWS]WCR
            [M:ROU1]LABWSTTYP(nolign-1)=[F:MWS]WSTTYP
            [M:ROU1]XLABWSTTYP(nolign-1)=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
         Endif
      Endif
      If [M:ROU1]SCOWST(nolign-1) <> ""
         Read [MWS]WST0=[M:ROU1]SCOWST(nolign-1);[M:ROU0]FCY
         If !fstat
            [M:ROU1]SCOWCR(nolign-1)=[F:MWS]WCR
            [M:ROU1]SCOWSTTYP(nolign-1)=[F:MWS]WSTTYP
            [M:ROU1]XSCOWSTTYP(nolign-1)=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
         Endif
      Endif
   Endif
Endif
End

###########################################
Subprog C_WST(VALEUR)
Variable Char     VALEUR
Local Integer NOL : NOL = nolign-1
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
# contrôle existence
If VALEUR <> ""
   Read [MWS]WST0=VALEUR;[M:ROU0]FCY
   If fstat
      GMESSAGE=VALEUR+"\"+mess(133,193,1) : mkstat=2
   Else
# contrôle site de rattachement du poste = site de la gamme
         If [F:MWS]WCRFCY <> [M:ROU0]FCY
             mkstat=2 : GMESSAGE = mess(116,193,1)
         Endif
         End
   Endif
Endif
End

##########################################
Subprog C_LABWST(VALEUR)
Variable Char     VALEUR
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
# contrôle existence et poste de type main-d'oeuvre
If VALEUR <> ""
   If (instr(1,dbgstr(1),"ROU1") | GIMPORT) & VALEUR=[M:ROU1]WST(nolign-1)
       GMESSAGE=mess(26,193,1)
       mkstat=2
   Endif
   If instr(1,dbgstr(1),"ROF1") & VALEUR=[M:ROF1]WST : GMESSAGE=mess(26,193,1) : mkstat=2 : Endif
   Read [MWS]WST0=VALEUR;[M:ROU0]FCY
   If fstat
      GMESSAGE=VALEUR+"\"+mess(133,193,1) : mkstat=2
   Else
      If [F:MWS]WSTTYP <> 2
         GMESSAGE=VALEUR - mess(4,193,1) : mkstat=2
         End
      Endif
# contrôle site de rattachement du poste = site gamme
      If [F:MWS]WCRFCY <> [M:ROU0]FCY
             mkstat=2 : GMESSAGE = mess(116,193,1)
      Endif
    Endif
Endif
End

#########################################
Subprog AV_ROOTIMCOD(VALEUR)
Variable Integer  VALEUR
# si type tps opératoire = unitaire, seul le temps opératoire est saisi
# si type tps opératoire = cadence, seule la cadence est saisie
# ici, remise à zéro des tps non saisis
If instr(1,dbgstr(1),"ROU1") | GIMPORT
   If VALEUR <> 0
      If VALEUR = 2
         [M:ROU1]OPETIM(nolign-1)=0 : If !GIMPORT : Affzo [ROU1]OPETIM(nolign-1) : Endif
      Else
         [M:ROU1]CAD(nolign-1)=0    : If !GIMPORT : Affzo [ROU1]CAD(nolign-1) : Endif
      Endif
      If VALEUR<>1
         [M:ROU1]TIMCOD(nolign-1)=0
         [M:ROU1]BASQTY(nolign-1)=0
         If !GIMPORT : Affzo [ROU1]TIMCOD(nolign-1), BASQTY(nolign-1) : Endif
      Endif
   Endif
Endif
If instr(1,dbgstr(1),"ROF1") : Gosub AV_ROOTIMCOD From SUBROUA : Endif
End

############################################
Subprog AM_ROOTIMCOD(VALEUR)
Variable Integer  VALEUR
If instr(1,dbgstr(1),"ROU1") | GIMPORT
   If VALEUR <> 0
      If VALEUR = 2
         [M:ROU1]OPETIM(nolign-1)=0 : If !GIMPORT : Affzo [ROU1]OPETIM(nolign-1) : Endif
      Else
         [M:ROU1]CAD(nolign-1)=0    : If !GIMPORT : Affzo [ROU1]CAD(nolign-1) : Endif
      Endif
      If VALEUR<>1
         [M:ROU1]TIMCOD(nolign-1)=0
         [M:ROU1]BASQTY(nolign-1)=0
         If !GIMPORT : Affzo [ROU1]TIMCOD(nolign-1), BASQTY(nolign-1) : Endif
      Else
         [M:ROU1]TIMCOD(nolign-1)=1
         [M:ROU1]BASQTY(nolign-1)=1
         If !GIMPORT : Affzo [ROU1]TIMCOD(nolign-1), BASQTY(nolign-1) : Endif
      Endif
   Endif
Endif
If instr(1,dbgstr(1),"ROF1") : OMODIF=1 : Gosub AM_ROOTIMCOD From SUBROUA : Endif
End

#####################################
Subprog C_SCOWST(VALEUR)
Variable Char     VALEUR
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
# contrôle existence et type poste sous-traitance
If VALEUR <> ""
   Read [MWS]WST0=VALEUR;[M:ROU0]FCY
   If fstat
      GMESSAGE=VALEUR+"\"+mess(133,193,1) : mkstat=2
   Else
      If [F:MWS]WSTTYP <> 3 : GMESSAGE=VALEUR - mess(3,193,1) : mkstat=2 : End : Endif
# contrôle site de rattachement du poste = site gamme
      If [F:MWS]WCRFCY <> [M:ROU0]FCY
             mkstat=2 : GMESSAGE = mess(116,193,1)
      Endif
    Endif
Endif
End

