Subprog AM_HCTIMCOE(VALEUR)
Variable Decimal VALEUR
GPE = 0
#---------
# PE permettant de modifier l'application du coef multiplicateur des temps hors charge
GPOINT = "ROTCHGOFF"
Gosub  ENTREE From EXEFNC
#---------

If instr(1,dbgstr(1),"ROF1")
    If !GPE
        [M:ROF1]PRPTIM = [M:ROF1]PRPTIMTMP * VALEUR    # tmps prep
        [M:ROF1]WAITIM = [M:ROF1]WAITIMTMP * VALEUR    # tmps attente
        [M:ROF1]PSPTIM = [M:ROF1]PSPTIMTMP * VALEUR    # tmps post-ope
    Endif
    Affzo [ROF1]30
    OMODIF = 1
Elsif instr(1,dbgstr(1),"ROU1") | GIMPORT
    If !GPE
        [M:ROU1]PRPTIM(nolign-1) = [M:ROU1]PRPTIMTMP(nolign-1) * VALEUR    # tmps prep
        [M:ROU1]WAITIM(nolign-1) = [M:ROU1]WAITIMTMP(nolign-1) * VALEUR    # tmps attente
        [M:ROU1]PSPTIM(nolign-1) = [M:ROU1]PSPTIMTMP(nolign-1) * VALEUR    # tmps post-ope
    Endif
Endif
End


