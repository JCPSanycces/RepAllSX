Subprog AM_CTIMCOE(VALEUR)
Variable Decimal VALEUR
GPE = 0
#---------
# PE permettant de modifier l'application du coef multiplicateur des temps de charge
GPOINT = "ROTCHGTIM"
Gosub  ENTREE From EXEFNC
#---------

If instr(1,dbgstr(1),"ROF1")
    If !GPE
        [M:ROF1]SETTIM = [M:ROF1]SETTIMTMP * VALEUR    # tmps réglage
        [M:ROF1]OPETIM = [M:ROF1]OPETIMTMP * VALEUR    # tmps ope
    Endif
    Affzo [ROF1]20
    OMODIF = 1
Elsif instr(1,dbgstr(1),"ROU1") | GIMPORT
    If  !GPE
        [M:ROU1]SETTIM(nolign-1) = [M:ROU1]SETTIMTMP(nolign-1) * VALEUR    # tmps réglage
        [M:ROU1]OPETIM(nolign-1) = [M:ROU1]OPETIMTMP(nolign-1) * VALEUR    # tmps ope
    Endif
Endif
End

