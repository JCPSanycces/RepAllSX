$BB1_STDOPENUM

  If instr(1,dbgstr(1),"ROF0") and [F:ROT]STDOPENUM<>0 Then
    [M:ROF0]STDOPENUM=[F:ROT]STDOPENUM
    Affzo [M:ROF0]STDOPENUM
  Endif
Return

$BB1_WST

  If instr(1,dbgstr(1),"ROF1") and [F:MWS]WST<>"" Then
    [M:ROF1]WST=[F:MWS]WST
    Affzo [M:ROF1]WST
  Endif
Return

$BB1_LABWST

  If instr(1,dbgstr(1),"ROF1") and [F:MWS]WST<>"" Then
    [M:ROF1]LABWST=[F:MWS]WST
    Affzo [M:ROF1]LABWST
  Endif
Return

