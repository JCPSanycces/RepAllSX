#########################################################################
## revu et adapté par LLC 1998
## revue en Janvier 99 par SR pour gestion des textes
#########################################################################
Call OBJET("ROU",GBIDC1,GBIDC2) From GOBJET
End

#########################################################################
$ACTION
Case ACTION
 When "OUVRE"              : Gosub OUVRE         From SUBROUA
 When "OUVRE_BOITE"        : Gosub OUVRE_BOITE   From SUBROUA
 When "DEFLIG"             : Gosub DEFLIG        From SUBROUA
 When "STATUT"             : Gosub STATUT        From SUBROUA
 When "LIENS"              : Gosub LIENS         From SUBROUA
 When "FILTRE"             : Gosub FILTRE        From SUBROUA
 When "RAZCRE"             : Gosub RAZCRE        From SUBROUA
 When "RAZDUP"             : Gosub RAZDUP        From SUBROUA
 When "VERIF_CRE"          : Gosub VERIF_CRE     From SUBROUA
 When "CREATION"           : Gosub CREATION      From SUBROUA
 When "INICRE"             : Gosub INICRE        From SUBROUA
 When "INIMOD"             : Gosub INICRE        From SUBROUA
 When "INICRE_LIG"         : Gosub INICRE_LIG    From SUBROUA
 When "VALLIG"             : Gosub VALLIG        From SUBROUA
 When "AB_CREATION"        : Gosub SUPPRESS_TEX  From SUBROUA
 When "AVANT_MOD"          : Gosub AVANT_MOD     From SUBROUA
 When "VERIF_MOD"          : Gosub VERIF_MOD     From SUBROUA
 When "AVANT_MODFIC"       : Gosub AVANT_MODFIC  From SUBROUA
 When "SETBOUT"            : Gosub SETBOUT       From SUBROUA
 When "AVANTBOUT"          : Gosub AVANTBOUT     From SUBROUA
 When "EXEBOUT"            : Gosub EXEBOUT       From SUBROUA
 When "AVANT_CHOI"         : Gosub AVANT_CHOI    From SUBROUA
 When "APRES_CHOI"         : Gosub APRES_CHOI    From SUBROUA
 When "MODIF"              : Gosub MODIF         From SUBROUA
 When "VERIF_MOD"          : Gosub VERIF_MOD     From SUBROUA
 When "APRES_MOD"          : Gosub APRES_MOD     From SUBROUA
 When "APRES_MODIF"        : Gosub APRES_MODIF   From SUBROUA
 When "APRES_CRE"          : Gosub APRES_CRE     From SUBROUA
 When "VERF_ANU"           : Gosub VERF_ANU      From SUBROUA
 When "ANNULE"             : Gosub ANNULE        From SUBROUA
 When "ABANDON"            : Gosub ABANDON       From SUBROUA
 When "FERME"              : Gosub FERME         From SUBROUA
 When "AFFMASK"            : Gosub AFFMASK       From SUBROUA
 When "AB1_NBLIG"          : Gosub AB1_NBLIG
 When "BB1_NBLIG"          : Gosub BB1_NBLIG
 When "BB1_STDOPENUM"      : Gosub BB1_STDOPENUM
 When "BB1_WST"            : Gosub BB1_WST
 When "BB1_LABWST"         : Gosub BB1_LABWST
 When "AB4_NBLIG"          : Gosub AB4_NBLIG From ECCROU # Issue 104937 - 2015-11 by GH : versioning
 When "BB4_NBLIG"          : Gosub BB4_NBLIG From ECCROU # Issue 104937 - 2015-11 by GH : versioning
Endcase
Return

#########################################################################
## Etiquettes de l'écran
#########################################################################
Subprog C_NBLIG

Call C_NBLIG From ECCROU # Issue 104937 - 2015-11 by GH : versioning
If mkstat : End : Endif

Local Integer NOL
# contrôle pour vérifier qu'on peut annuler une ligne
If status=65       : # annulation simple
   NOL=nolign-1 : Gosub TEST_ANU
Endif
If status=68 | status=83    : # annulation multiple
   For NOL=nolign-1 To nolign1-1
       Gosub TEST_ANU : If mkstat : Break : Endif
   Next NOL
Endif
If mkstat : End : Endif
# tester validation en création et nblig=0 ou en Verif_cre
#If [M:ROU1]NBLIG=0 & (status = 92 | status = 93)
If [M:ROU1]NBLIG=0 & status = 93
    mkstat=1
    GMESSAGE=mess(9,193,1)
    End
Endif

If find(status,1,4,5,20,21,26,92,93)
    If (GREP="C" | GREP="D")
        Gosub INISCD From SUBROU3
    Else
        # GH 03/11/2014 bug 102304
        #Gosub LIENS From SUBROU3
        #If !GIMPORT : Affzo [M:ROU3]1-99 : Endif
        Gosub ADD_ROU3
    Endif
Elsif status=65             : # annulation simple  : # GH 03/11/2014 bug 102304
   Gosub DEL_ROU3
Elsif find(status,68,83)    : # annulation multiple : # GH 03/11/2014 bug 102304
   NOL=nolign
   For nolign=NOL To nolign1
       Gosub DEL_ROU3
   Next
   nolign=NOL
Endif
End

$TEST_ANU : # contrôle pour autorisation d'annulation
# call erreur("annulation impossible de la ligne"-num$(nol+1)) from gesecran
Return

########################################################################
Subprog APRES_NBLIG

[M:ROU1]CONCATKEY(nolign-1)=num$([M:ROU1]OPENUM(nolign-1))+num$([M:ROU1]RPLIND(nolign-1))
If [M:ROU1]UPDFLG(nolign-1)=0 : [M:ROU1]UPDFLG(nolign-1)=1 : Endif
# si création opé ou modif de la date de remplacement, le flag "validée"
# passe à Non
If [M:ROU1]CREFLG(nolign-1)=0 | [M:ROU1]UPDFLG(nolign-1)=2
   [M:ROU0]CFMFLG=1
   If !GIMPORT : Affzo [ROU0]CFMFLG : Endif
Endif

## sr 06.02 demande 14664
#Local Integer SNOLIGN
#Local Integer WNBLIG : WNBLIG = [M:ROU1]NBLIG
#
#If [M:ROU1]CREFLG(nolign-1)=0  : [M:ROU1]NBLIG += 1 : Endif
#SNOLIGN = nolign
# # If (!GIMPORT | GREP <> "M") : Gosub LIENS From SUBROU3 : Endif        # 09.05 31944
#Gosub LIENS From SUBROU3 # 10.07 41142
#nolign = SNOLIGN
#If !GIMPORT : Affzo [M:ROU3]1-99 :  Endif
#If [M:ROU1]CREFLG(nolign-1)=0  : [M:ROU1]NBLIG = WNBLIG : Endif

# GH 03/11/2014 bug 102304
Gosub ADD_ROU3

# Attribution  de l'indice de la variante d'opération
#If  [M:ROU1]CREFLG(nolign-1)=0 & INDEXIST=1 # Issue 112674 - 2015-11-20 by GH : index not calculated
If  [M:ROU1]CREFLG(nolign-1)=0 & [M:ROU1]INDEXIST(nolign-1)<>2
    Gosub ATTRIBUE_IND
Endif
End

$DEL_ROU3
If [M:ROU1]OPENUM(nolign-1)=0 : Return : Endif

I=find([M:ROU1]OPENUM(nolign-1),[M:ROU1]OPENUM(0..nolign-2))
J=find([M:ROU1]OPENUM(nolign-1),[M:ROU1]OPENUM(nolign..[M:ROU1]NBLIG-1))
If !I & !J
   I=find([M:ROU1]OPENUM(nolign-1),[M:ROU3]OPENUM(0..[M:ROU3]BASTAB-1))
   If I
     # La ligne supprimée est la seule avec ce numéro d'opération
     # => on supprime l'opération de l'onglet Jalonnement
      Dela I-1,1 [M:ROU3]BASTAB
      [M:ROU3]BASTAB-=1
      Gosub RAF_ROU3
   Endif
Elsif !I & J
   # La ligne supprimée est la première d'un groupe de plusieurs avec ce no d'opération
   J+=nolign
   I=find([M:ROU1]OPENUM(nolign-1),[M:ROU3]OPENUM(0..[M:ROU3]BASTAB-1))
   If I & J
      [M:ROU1]OPENUM(nolign-1)=0
      Gosub MOD_ROU3
   Endif
Endif
Return

$ADD_ROU3
If [M:ROU1]OPENUM(nolign-1)=0 : Return : Endif

I=find([M:ROU1]OPENUM(nolign-1),[M:ROU3]OPENUM(0..[M:ROU3]BASTAB-1))
If !I
  # L'opération n'est pas dans l'onglet Jalonnement, on l'ajoute
  I=[M:ROU3]BASTAB
  [M:ROU3]OPENUM(I)=[M:ROU1]OPENUM(nolign-1)
  [M:ROU3]WSTTYP(I)=[M:ROU1]WSTTYP(nolign-1)
  [M:ROU3]WST(I)=[M:ROU1]WST(nolign-1)
  [M:ROU3]DACMST(I)=2
  [M:ROU3]MFGMST(I)=1
  [M:ROU3]NEXOPENUM(I)=0
  [M:ROU3]SCDCOD(I)=1
  [M:ROU3]SCDTIM(I)=0
  [M:ROU3]SCDQTY(I)=0
  [M:ROU3]SCDLOT(I)=0
  [M:ROU3]BASTAB+=1
  Sorta [M:ROU3]BASTAB [M:ROU3]BASTAB Order By [M:ROU3]OPENUM(indice)
  Gosub RAF_ROU3
Elsif !find([M:ROU1]OPENUM(nolign-1),[M:ROU1]OPENUM(0..nolign-2))
  # La ligne est la première de la gamme avec ce no d'opération
  # et l'opération est bien dans l'onglet Jalonnement
  J=nolign
  Gosub MOD_ROU3
Endif
Return

$MOD_ROU3
If [M:ROU1]WST(J-1)=[M:ROU3]WST(I-1) : Return : Endif

# Maj du poste de charge (et ses type et centre) dans l'onglet Jalonnement
# selon la 1ère ligne de gamme pour un no opération
[M:ROU3]WST(I-1)=[M:ROU1]WST(J-1)
#[M:ROU3]WSTTYP(I-1)=[M:ROU1]WSTTYP(J-1) : # GH 07/01/2015 bug 104615
[M:ROU3]WCR(I-1)=[M:ROU1]WCR(J-1)
If !GIMPORT : Affzo [ROU3]WST(I-1), WSTTYP(I-1), WCR(I-1) : Endif
Return

$RAF_ROU3
For I = 0 To [M:ROU3]BASTAB-1
  If I = [M:ROU3]BASTAB-1
      [M:ROU3]NEXOPENUM(I) = 0
  Else
      [M:ROU3]NEXOPENUM(I) = [M:ROU3]OPENUM(I+1)
  Endif
Next I
If !GIMPORT : Affzo [ROU3]1-99 :  Endif
Return

########################################################################
# Attribution  de l'indice de la variante d'opération
$ATTRIBUE_IND
Local Integer MANOLIGN   # MANOLIGN = indice de la ligne qui suit la ligne insérée
Local Integer WOK, V   # V = indice des lignes du tableau ROU1

# cas particulier : insertion au dessus de l'OP initiale
Call VERIF_VARIANTE(2,nolign,WOK)From SUBROUA
If [M:ROU1]RPLIND(nolign)=0 & WOK=1
    # Il y a d'autres variantes derrière
    MANOLIGN = nolign
    Gosub INSERE_VAR
Elsif nolign>1
    # est-ce une variante ?
    Call VERIF_VARIANTE (1,nolign,WOK)From SUBROUA
    If WOK=0
         [M:ROU1]RPLIND(nolign-1)=0
    Else
         # c'est une variante
         # y-a-t-il d'autres variantes derrière ?
         WOK =0
         Call VERIF_VARIANTE(2,nolign,WOK)From SUBROUA
         [M:ROU1]RPLIND(nolign-1)=[M:ROU1]RPLIND(nolign-2)+1
         Affzo [M:ROU1]RPLIND(nolign-1)
         If WOK=1
           # Il y a d'autres variantes derrière
             MANOLIGN = nolign
             Gosub INSERE_VAR
         Endif
   Endif
Endif

[M:ROU1]INDEXIST(nolign-1)=2 : # Issue 112674 - 2015-11-20 by GH : index not calculated
Return

########################################################################
# renumérotation des opérations
$INSERE_VAR
# renuméroter les indices des variantes qui suivent l'insertion
For V=[M:ROU1]NBLIG-1   To MANOLIGN Step-1
  If [M:ROU1]OPENUM(V)= [M:ROU1]OPENUM(nolign-1)
    [M:ROU1]RPLIND(V)+=1 : Affzo [M:ROU1]RPLIND(V)
    [M:ROU1]CREFLG(V) = 0     # signale enregistrement nouveau
  Endif
Next
Return

#########################################################################
Subprog AP_DATREF(VALEUR)
Variable Date    VALEUR
If VALEUR<>GDATEREF
   GDATEREF = VALEUR
   SDATEREF = VALEUR
Endif
End

###########################################################################
Subprog C_ROUALT(VALEUR)
Variable Decimal  VALEUR

Look [ROH]ROH0=[M:ROU0]ITMREF;VALEUR;[M:ROU0]FCY   : # Beryl Site en fin de clé primaire
If !fstat : End : Endif

Read [F:TRO]TRO0 = VALEUR
If fstat : GMESSAGE = mess(23,100,1)
           mkstat = 1
           End
Endif

# FQ60130 - MABON 30/11/09 - La vérification n'était plus faite : elle est remise
#If [F:TRO]FCY <> "" & [M:ROU0]FCY <> "" & ([F:TRO]FCY <> [M:ROU0]FCY)
#   [M:ROU0]FCY = [F:TRO]FCY
#Endif

If [F:TRO]FCY <> "" & [M:ROU0]FCY <> "" & ([F:TRO]FCY <> [M:ROU0]FCY)
   mkstat=1 : GMESSAGE = mess(117,193,1)
Endif

If VALEUR=[M:ROU0]ROUALT & !GIMPORT : mkstat=4 : Endif : # GH 25/11/2013 bug 94517 + GH 28/02/2014 bug 97326
End

##########################################################################
