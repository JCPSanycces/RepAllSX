Subprog AVANT_NBLIG
If [M:ROU1]BPRNUM(nolign-1)<>GBPCNUM  # Issue 86564
  GBPCNUM= [M:ROU1]BPRNUM(nolign-1)
Endif
End

##########################################################################
# GH 14/01/2014 bug 95827 Code adresse non saisissable si Tiers non renseigné
Subprog AS_BPAADD(VALEUR)
Variable Char    VALEUR()
If instr(1,dbgstr(1),"ROU1") | GIMPORT
   If [M:ROU1]BPRNUM(nolign-1)="" : mkstat=1 : Endif
Elsif instr(1,dbgstr(1),"ROF2")
   If [M:ROF2]BPRNUM="" : mkstat=1 : Endif
Endif
End

