$AB1_NBLIG
Global Integer SAVNOLIGN

# Sauvegarde du n° de ligne car tunnel sur unité d'opération met nolign à jour !
SAVNOLIGN=nolign
Return

#---------------------------------------------------------------------- #
# Action apres bouton    12.05 33609                                    #
#---------------------------------------------------------------------- #
$BB1_NBLIG
#Affzo [M:ROU1]1-99 # Issue 112678 - 2015-11-20 by GH : already done
#Affzo [M:ROU3]1-99 # Issue 112689 - 2015-11-23 by GH : already done
If OMODIF = 1 : mkstat = 4 : Endif                 # 01.06 34482
nolign=SAVNOLIGN
Kill SAVNOLIGN
Return

