#<AdxTL>@(#)12.0.0.0 $Revision$
#
#***********************************************************************************
#
#        SAISIE FENETRE SUR CONTRAT DE LOCATION-FINANCEMENT (LEA)
#
#      LEALEV  :  Levée de l'option d'achat (LEAL)
#      LEARES  :  Résiliation du contrat (LEAR)
#      LEAEND  :  Enregistrer la fin du contrat (LEAE)
#      LEASUP  :  Supprimer le contrat (LEAS)
#
#***********************************************************************************
#    Création V5 
#    MDR - 01.12.2007
#
#*********************************************************************
#    Modification
#    MDR - 99.99.9999    description de la modif. ...
#
#*********************************************************************
#
$ACTION
#  Infbox "ACTION = "-num$(ACTION)

Case ACTION
  When "OUVRE"               : Gosub OUVRE                  
  When "DEBUT"               : Gosub DEBUT              
  When "APRES_MODIF"         : Gosub APRES_MODIF       
  When "OK"                  : Gosub OK                       
  When "ABA"                 : Gosub ABA                  
Endcase

Return
#
#=====================================================================
#
$OUVRE

Case GACTION
  When "LEALEV"  : Gosub OUVRE_LEALEV      
  When "LEARES"  : Gosub OUVRE_LEARES   
  When "LEAEND"  : Gosub OUVRE_LEAEND      
  When "LEASUP"  : Gosub OUVRE_LEASUP        
Endcase

Return
#=====================================================================
#
$DEBUT

Case GACTION
  When "LEALEV"  : Gosub DEBUT_LEALEV      
  When "LEARES"  : Gosub DEBUT_LEARES   
 When "LEAEND"  : Gosub DEBUT_LEAEND  
 When "LEASUP"  : Gosub DEBUT_LEASUP  
Endcase

Return
#
#=====================================================================
#
$APRES_MODIF
 
Case GACTION
  When "LEALEV"  : Gosub APRES_MODIF_LEALEV      
  When "LEARES"  : Gosub APRES_MODIF_LEARES  
  When "LEAEND"  : Gosub APRES_MODIF_LEAEND   
  When "LEASUP"  : Gosub APRES_MODIF_LEASUP   
Endcase

Return
#
#=====================================================================
#
$OK

Case GACTION
  When "LEALEV"  : Gosub OK_LEALEV      
  When "LEARES"  : Gosub OK_LEARES   
  When "LEAEND"  : Gosub OK_LEAEND  
  When "LEASUP"  : Gosub OK_LEASUP      
Endcase

Return
#=====================================================================
#
$ABA

Case GACTION
  When "LEALEV"  : Gosub ABA_LEALEV     
  When "LEARES"  : Gosub ABA_LEARES    
  When "LEAEND"  : Gosub ABA_LEAEND  
  When "LEASUP"  : Gosub ABA_LEASUP  
Endcase

Return
#=====================================================================
#
$OUVRE_LEALEV

#----- Variables pour sauvegarde du masque -----#

# conditionnement et affichage
If  [M:LEA0]LEASTA<> GVML_STENCOU
  GERR=1
  GMESSAGE = mess(35,7771,1) : # le statut du contrat doit être "en cours"
  FIN=1
Endif

If  [M:LEA0]LEATYP<> GVML_CREBAIL
  GERR=1
  GMESSAGE = mess(38,7771,1) : # le type  du contrat doit être "crédit-bail"
  FIN=1
Endif

Return
#=====================================================================
#
$OUVRE_LEARES

# conditionnement et affichage
If  [M:LEA0]LEASTA<> GVML_STENCOU
  GERR=1
  GMESSAGE = mess(35,7771,1) : # le statut du contrat doit être "en cours"
  FIN=1
Endif

Return
#=====================================================================
#
$OUVRE_LEAEND

# conditionnement et affichage
If  [M:LEA0]LEASTA<> GVML_STENCOU 
  GMESSAGE = mess(35,7771,1) : # le statut du contrat doit être "en cours"
  FIN=1
Endif

Return
#=====================================================================
#
$OUVRE_LEASUP

# conditionnement et affichage
If  [M:LEA0]LEASTA<> GVML_STRESIL or  [M:LEA0]LEASTA<> GVML_STECHU
  GERR=1
  GMESSAGE = mess(35,7771,1) : # le statut du contrat doit être "résilié" ou "échu"
  FIN=1
Endif

Return

#=====================================================================
#
$DEBUT_LEALEV


 Global Integer G_ACT_MOD           : Raz G_ACT_MOD # Global pour retour à la fonction LEA

Raz[M:LEAL]

# Récupération des informations du contrat
[M:LEAL]RPUDAT = [M:LEA1]RPUDAT
[M:LEAL]RPUVAL = [M:LEA1]RPUVAL
[M:LEAL]CUR = [M:LEA0]CUR

# conditionnement et affichage

Affzo [M]1-99

Return
#=====================================================================
#
$DEBUT_LEARES

 Global Integer G_ACT_MOD           : Raz G_ACT_MOD # Global pour retour à la fonction LEA

# Récupération des informations date de résiliation
[M:LEAR]TRMLEADAT = [M:LEA1]TRMLEADAT


# conditionnement et affichage.
Affzo [M]1-99

Return
#=====================================================================
#
$DEBUT_LEAEND


 Global Integer G_ACT_MOD           : Raz G_ACT_MOD # Global pour retour à la fonction LEA



Return
#=====================================================================
#
$DEBUT_LEASUP


 Global Integer G_ACT_MOD           : Raz G_ACT_MOD # Global pour retour à la fonction LEA



Return

#=====================================================================
#
$APRES_MODIF_LEALEV


REP="M"

Return
#=====================================================================
#
$APRES_MODIF_LEARES

  REP="M"

Return
#=====================================================================
#
$APRES_MODIF_LEAEND

  REP="M"

Return
#=====================================================================
#
$APRES_MODIF_LEASUP

  REP="M"

Return
#=====================================================================
#
$OK_LEALEV

  # Affectation pour mise à jour en sortie

  [M:LEA0]LEASTA = GVML_STRACHA  :  Affzo   [M:LEA0]LEASTA
  [M:LEA1]RPUDAT = [M:LEAL]RPUDAT   :  Affzo   [M:LEA1]RPUDAT
  [M:LEA1]RPUVAL = [M:LEAL]RPUVAL   :  Affzo   [M:LEA1]RPUVAL
  G_ACT_MOD=1

  mkstat = 4
  FIN=1   
Affzo   [M:LEA0]

Return
###!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
### Débranchement depuis les actions de SUBFAS pour test MAJ lot de biens  !
###!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

$LEA_FINACTION # Débranchement à partir de SUBLEA
# En retour d'une action, celle-ci a créé la globale G_ACT_MOD qui permet de savoir si des modifs ont
# été validée et doivent être reportées dans le masque courant et si on doit passer le contrat en modif.
# Cette globale est détruite quand c'est fait. On ne passe en modif que si la globale existe.
 Default Mask "[M:LEA0],[M:LEA1]"
 If dim(G_ACT_MOD)>0
  If G_ACT_MOD
   REP="M" : GREP="M"     # Si modif on met l'enregistrement en mode modif
  Endif 
  Kill G_ACT_MOD 
 Endif
Return

#=====================================================================
#
$OK_LEARES

  # Affectation pour mise à jour en sortie
  [M:LEA0]LEASTA = GVML_STRESIL   :  Affzo   [M:LEA0]LEASTA
  [M:LEA1]TRMLEADAT = [M:LEAR]TRMLEADAT  :  Affzo   [M:LEA1]TRMLEADAT
  G_ACT_MOD=1
  mkstat = 4
  FIN=1   

Return
#=====================================================================
#
$OK_LEAEND

  # Affectation pour mise à jour en sortie
  [M:LEA0]LEASTA = GVML_STECHU   :  Affzo   [M:LEA0]LEASTA
  G_ACT_MOD=1
  mkstat = 4
  FIN=1   

Return
#=====================================================================
#
$OK_LEASUP

  # Affectation pour mise à jour en sortie
  

Return
#=====================================================================
#
$ABA_LEALEV

  REP=""

  Affzo [M]1-99

Return
#=====================================================================
#
$ABA_LEARES

  REP=""
  Affzo [M]1-99

Return
#=====================================================================
#
$ABA_LEAEND

  REP=""
  Affzo [M]1-99

Return
#=====================================================================
#
$ABA_LEASUP

  REP=""
  Affzo [M]1-99

Return
#=====================================================================





