#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTINCS201809001
# Issue X3-107160 - 2018-09-26 by JUSYN : responsive design change for NCS - combine screens into one - delete obsolete screens
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Deletion of obsolete NCS screens") From LECFIC
    # -------------------------
    Call MAJ_UTINCS201809001(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTINCS201809001(DOSSIER)
Value Char DOSSIER

  Call ECR_TRACE("MAJ_UTINCS201809001: Process Start on : "+DOSSIER,0) From GESECRAN

  Call TR_DELMSK("NCSH5",DOSSIER) From MSKDIV
  Call TR_DELMSK("NCSH6",DOSSIER) From MSKDIV
  Call TR_DELMSK("NCSH7",DOSSIER) From MSKDIV
  Call TR_DELMSK("NCSH8",DOSSIER) From MSKDIV

  Call ECR_TRACE("MAJ_UTINCS201809001: Process End", 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOVAL") : End : Endif
  # -------------------------
  Call MAJ_UTINCS201809001(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOVAL") : End : Endif
  # -------------------------
  Call MAJ_UTINCS201809001(APPLI)
End

