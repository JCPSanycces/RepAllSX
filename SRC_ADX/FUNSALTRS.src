#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################################
# FUNSALTRS : Contient                                                       #
#     - Le S/P de validation des transactions de saisie des ventes           #
#     - Le traitement permettant de lancer manuellement le S/P de validation #
##############################################################################
Local Integer OK
Local File    SALTRS [SLT]
Local Mask    SALTRS [DIA] : Raz [M:DIA]
Call DIALWIN(OK,mess(100,196,1),"ISALTRS") From GESECRAN
If OK=2
   Call OUVRE_TRACE(mess(100,196,1)-[M]LIB-[M]STRNUM) From LECFIC
   Call VAL_SALTRS([M]STRTYP,[M]STRNUM,nomap)
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE   From LECFIC
Endif
Close Local File [SLT]
Close Local Mask [DIA]
End

#-------------------------------------------#
# Actions sur champ de l'écran SALTRS [DIA] #
#-------------------------------------------#
Subprog AV_LIB(VALEUR)
Variable Char    VALEUR()
If [M]STRTYP>0 & [M]STRTYP<9 VALEUR=mess([M]STRTYP,435,1)
                        Else VALEUR=mess(19,197,1) : Endif
End
Subprog AV_STRDES(VALEUR)
Variable Char    VALEUR()
If [M]STRNUM<>"" & [M]STRTYP>0 & [M]STRTYP<9
  Read [SLT] SLT0=[M]STRTYP;[M]STRNUM : If fstat Raz [F:SLT] : Endif
#  VALEUR=[F:SLT]STRDES
  Call LECTEXTRA (VALEUR,"SALTRS","DESAXX",num$([F:SLT]STRTYP),[F:SLT]STRNUM) From ATEXTRA
Endif
End

############################################################################################
#    Programme appelé dans SUBSLQ,SUBSLC,SUBSLO,SUBSLD,SUBSLI,SUBSLA,SUBSLR,SUBSLL,SUBSLS  #
#    Pour éxécution validation transaction par gestion de dossier                          #
#                                          par l'utilitaire de revalidation                #
#         à partir du dictionnaire des types de transaction (ATN)                          #
############################################################################################
Subprog GENDOS(TYP, APPLI)
Value Integer  TYP
Value Char APPLI
Local Char    TABFEN(GLONFEN)(0..2), TABECR(GLONAMK)(0..10)
Local Integer I, TOK(1..52)
Raz TOK
Local File =APPLI+".SALTRS"    [SLT]
Local File =APPLI+".AWINDOW"   [AWI]
Local File =APPLI+".AWINPAR"   [AWP]
Local File =APPLI+".AWINBRO"   [AWB]
Local File =APPLI+".AWINBOUT"  [AWT]
Local File =APPLI+".AMSK"      [AMK]
Local File =APPLI+".AMSKZON"   [AMZ]
Local File =APPLI+".AMSKACT"   [AMA]
Local File =APPLI+".AMSKPAR"   [AMP]
Local File =APPLI+".ATYPE"     [ATY]
Local File =APPLI+".ACTION"    [ACT]
Local File =APPLI+".ACTPAR"    [ATR]
Local File =APPLI+".ACTCODPAR" [AAR]
Local File =APPLI+".ATABLE"    [ATB]
Local File =APPLI+".ATABZON"   [ATZ]
Local File =APPLI+".ACTIV"     [ACV]
Local File =APPLI+".AOBJET"    [AOB]
Local File =APPLI+".ATEXTE"    [ATX]
Local File =APPLI+".ATABTAB"   [ADV]

If dim(GVALTRANS)>0 & GVALTRANS(5)=2
   TOK(TYP) = 1
Else
   Raz TABECR
   Case TYP
       When 1 : # Devis
           TABECR(0)="SQH0":TABECR(1)="SQH1":TABECR(2)="SQH2":TABECR(3)="SQH3"
           TABFEN(0)="OSQH"
       When 2 : # Commandes
           TABECR(0)="SOH0":TABECR(1)="SOH1":TABECR(2)="SOH2":TABECR(3)="SOH3":TABECR(4)="SOH4"
           TABFEN(0)="OSOH"
       When 3 : # Commandes ouverte
           TABECR(0)="SOR1":TABECR(1)="SOI1"
           TABFEN(0)="OSOR":TABFEN(1)="OSOI"
       When 4 : # Livraisons
           TABECR(0)="SDH0":TABECR(1)="SDH1":TABECR(2)="SDH2":TABECR(3)="SDH3"
           TABFEN(0)="OSDH"
       When 5,52 : # Factures et avoirs
           TABECR(0)="SIH0":TABECR(1)="SIH1":TABECR(2)="SIH2":TABECR(3)="SIH4":TABECR(4)="SIHV"
           TABFEN(0)="OSIH"
       When 6 : # Retours clients
           TABECR(0)="SRH0":TABECR(1)="SRH1":TABECR(2)="SRH2"
           TABFEN(0)="OSRH"
       When 7 : # Retours prêt
           TABECR(0)="SRL0":TABECR(1)="SRL1":TABECR(2)="SRL2"
           TABFEN(0)="OSRL"
       When 8 : # Retours matières sous-traitancec
           TABECR(0)="SRS0":TABECR(1)="SRS1":TABECR(2)="SRS2"
           TABFEN(0)="OSRS"
   Endcase
   I=0
   While TABFEN(I)<>"" & I<2
       Read [AWI]AWI0 = TABFEN(I)
       If fstat Raz [F:AWI] : Endif
       If [F:AWI]UPDFLG = 1 : TOK(TYP) = 1 : Break : Endif
       I+=1
   Wend
   If TOK(TYP)<>1
       I=0
       While TABECR(I)<>"" & I<10
           Read [AMK]CODMSK = TABECR(I)
           If fstat Raz [F:AMK] : Endif
           If [F:AMK]UPDFLG = 1 : TOK(TYP) = 1 : Break : Endif
           I+=1
       Wend
   Endif
Endif

If sum(TOK(1..52)) = 9
   Call VAL_SALTRS(0,"",APPLI)
Else
   If TOK(1) = 1 : Call VAL_SALTRS(1,"",APPLI) : Endif
   If TOK(2) = 1 : Call VAL_SALTRS(2,"",APPLI) : Endif
   If TOK(3) = 1 : Call VAL_SALTRS(3,"",APPLI) : Endif
   If TOK(4) = 1 : Call VAL_SALTRS(4,"",APPLI) : Endif
   If TOK(5) = 1 : Call VAL_SALTRS(5,"",APPLI) : Endif
   If TOK(6) = 1 : Call VAL_SALTRS(6,"",APPLI) : Endif
   If TOK(7) = 1 : Call VAL_SALTRS(7,"",APPLI) : Endif
   If TOK(8) = 1 : Call VAL_SALTRS(8,"",APPLI) : Endif
   If TOK(52)= 1 : Call VAL_SALTRS(52,"",APPLI) : Endif
Endif

End

############################################################################################
#    Programme appelé dans SUBSLQ,SUBSLC,SUBSLO,SUBSLD,SUBSLI,SUBSLA,SUBSLR,SUBSLL,SUBSLS  #
#    Pour éxécution validation transaction en gestion de patch                             #
############################################################################################
Subprog GENPATCH(TYP,APPLI)
Value Integer  TYP
Value Char     APPLI
Local File =APPLI+".SALTRS"    [SLT]
Local File =APPLI+".AWINDOW"   [AWI]
Local File =APPLI+".AWINPAR"   [AWP]
Local File =APPLI+".AWINBRO"   [AWB]
Local File =APPLI+".AWINBOUT"  [AWT]
Local File =APPLI+".AMSK"      [AMK]
Local File =APPLI+".AMSKZON"   [AMZ]
Local File =APPLI+".AMSKACT"   [AMA]
Local File =APPLI+".AMSKPAR"   [AMP]
Local File =APPLI+".ATYPE"     [ATY]
Local File =APPLI+".ACTION"    [ACT]
Local File =APPLI+".ACTPAR"    [ATR]
Local File =APPLI+".ACTCODPAR" [AAR]
Local File =APPLI+".ATABLE"    [ATB]
Local File =APPLI+".ATABZON"   [ATZ]
Local File =APPLI+".ACTIV"     [ACV]
Local File =APPLI+".AOBJET"    [AOB]
Local File =APPLI+".ATEXTE"    [ATX]
Local File =APPLI+".ATABTAB"   [ADV]
Call VAL_SALTRS(TYP,"",APPLI)

End

#========================================================================================
# FGR 16/11/2009 : X3SUIVI57491 (début)
#----------------------------------------------------------------------------------------
Subprog GET_TRTSALTRS (SZWIN, SZABRFIC, SZONGLET, SZREQ, IREQ)
Value Char SZWIN
Value Char SZABRFIC
Value Char SZONGLET
Variable Char SZREQ()(,)
Variable Integer IREQ

Local Char SZEVALUE(250)
Local Integer NI

  Raz SZREQ
  IREQ = 0
  Read [AWI]AWI0=SZWIN
  For NI=0 To [F:AWI]NBMSK-1
    Read [AMK]CODMSK=[F:AWI]NOMMSK(NI)
    SZEVALUE = 'find("[' + [F:AMK]ABRMSK + ']",' + SZONGLET +')'
    If evalue(SZEVALUE) = 0 Then
      # l'écran n'est pas dans la liste
      SZREQ(0,0) = SZREQ(0,0) + ',[' + [F:AMK]ABRMSK + ']'
      If SZREQ(0,2) <> "" Then
        SZREQ(0,2) = SZREQ(0,2) + ':'
      Endif
      SZREQ(0,2) = SZREQ(0,2) + '[M:' + [F:AMK]ABRMSK + ']=[F:' + SZABRFIC + ']'
      SZREQ(IREQ,1) = 'If clalev ([M:' + [F:AMK]ABRMSK +'])<=0 : Local Mask =APPLI+".' + [F:AMK]CODMSK + '" [' + [F:AMK]ABRMSK + '] : Endif #Spécifique'
      IREQ += 1
    Endif
  Next NI
End

#----------------------------------------------------------------------------------------
$DYN_TRTSALTRS
Local Char SZWIN(GLONFEN)
Local Char SZABRFIC(GLONABR)
Local Char SZONGLET(250)

  SZABRFIC = 'SLT'
  # 1
  SZWIN = 'OSLQ'
  SZONGLET = '"[SLQ0]","[SLQ1]","[SLQ2]","[SLQ3]","[SLX1]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ1, IREQ1)
  # 2
  SZWIN = 'OSLC'
  SZONGLET = '"[SLC0]","[SLC1]","[SLC2]","[SLC3]","[SLC4]","[SLC5]","[SLX1]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ2, IREQ2)
  # 3
  SZWIN = 'OSLO'
  SZONGLET = '"[SLO0]","[SLO1]","[SLO2]","[SLO3]","[SLX1]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ3, IREQ3)
  # 4
  SZWIN = 'OSLD'
  SZONGLET = '"[SLD0]","[SLD1]","[SLD2]","[SLD3]","[SLD4]","[SLX1]","[SLS1]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ4, IREQ4)
  # 5
  SZWIN = 'OSLI'
  SZONGLET = '"[SLI0]","[SLI2]","[SLI3]","[SLI4]","[SLX1]","[SLS1]","[SLI1]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ5, IREQ5)
  # 52
  SZWIN = 'OSLA'
  SZONGLET = '"[SLI0]","[SLI2]","[SLI3]","[SLI4]","[SLX1]","[ETR2]","[SLA1]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ52, IREQ52)
  # 6
  SZWIN = 'OSLR'
  SZONGLET = '"[SLR0]","[SLR1]","[SLR2]","[ETR2]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ6, IREQ6)
  # 7
  SZWIN = 'OSLL'
  SZONGLET = '"[SLL0]","[SLL1]","[SLL2]","[ETR2]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ7, IREQ7)
  # 8
  SZWIN = 'OSLS'
  SZONGLET = '"[SSC0]","[SSC1]","[SSC2]","[ETR2]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ8, IREQ8)
Return

#----------------------------------------------------------------------------------------
$GEN_TRTSALTRS
Local Char SZADXIFS(type(adxifs)-10)
Local Char SZADXIRS(type(adxirs)-10)
Local Integer IVALIDOK
Local Integer IEXIST
Local Char SZPROGNAME(GLONADC)
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Integer NI
# 20 lignes
#  5 colonnes :
#               (0) = Complément "Close Local Mask" et "Default Mask"
#               (1) = Listes des autres Mask à ouvrir
#               (2) = Complément affectation classe [F] dans classe [M]
Local Char SZREQ1(250)(20,5)
Local Char SZREQ2(250)(20,5)
Local Char SZREQ3(250)(20,5)
Local Char SZREQ4(250)(20,5)
Local Char SZREQ5(250)(20,5)  # Sauf INVTYP=2
Local Char SZREQ52(250)(20,5) # Que INVTYP=2
Local Char SZREQ6(250)(20,5)
Local Char SZREQ7(250)(20,5)
Local Char SZREQ8(250)(20,5)
Local Integer IREQ1
Local Integer IREQ2
Local Integer IREQ3
Local Integer IREQ4
Local Integer IREQ5  # Sauf INVTYP=2
Local Integer IREQ52 # Que INVTYP=2
Local Integer IREQ6
Local Integer IREQ7
Local Integer IREQ8
  #------------------------------------------
  Raz SZREQ1
  Raz SZREQ2
  Raz SZREQ3
  Raz SZREQ4
  Raz SZREQ5  # Sauf INVTYP=2
  Raz SZREQ52 # Que INVTYP=2
  Raz SZREQ6
  Raz SZREQ7
  Raz SZREQ8
  IREQ1 = 0
  IREQ2 = 0
  IREQ3 = 0
  IREQ4 = 0
  IREQ5 = 0  # Sauf INVTYP=2
  IREQ52 = 0 # Que INVTYP=2
  IREQ6 = 0
  IREQ7 = 0
  IREQ8 = 0
  #------------------------------------------
  Gosub DYN_TRTSALTRS
  #------------------------------------------
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  #------------------------------------------
  SZPROGNAME = "WSAL" + num$(adxpid)
  SZFULLSRC = filpath("TRT", SZPROGNAME, "src", APPLI)
  SZFULLADX = filpath("TRT", SZPROGNAME, "adx", APPLI)
  #------------------------------------------
  #Ouverture du traitement à générer
  Openo SZFULLSRC, 0 Using [TRS_]
  #------------------------------------------
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"  Using [TRS_]
  Wrseq "#Traitement généré pour les transactions vente en masse"  Using [TRS_]
  Wrseq "$TRANSAC_SAL"  Using [TRS_]
  Wrseq 'For [SLT] Where' - CRITERES  Using [TRS_]
  Wrseq '  If [F:SLT]STRTYP<>WTYP | ([F:SLT]STRTYP=5 & ([F:SLT]INVTYP<>WINVTYP))'  Using [TRS_]
  Wrseq '     Case WTYP'  Using [TRS_]
  Wrseq '       When 1 : Close Local Mask [SLQ0],[SLQ1],[SLQ2],[SLQ3],[SLX1],[DST]' + SZREQ1(0,0)  Using [TRS_]
  Wrseq '       When 2 : Close Local Mask [SLC0],[SLC1],[SLC2],[SLC3],[SLC4],[SLC5],[SLX1],[DST]' + SZREQ2(0,0)  Using [TRS_]
  Wrseq '       When 3 : Close Local Mask [SLO0],[SLO1],[SLO2],[SLO3],[SLX1],[DST]' + SZREQ3(0,0)  Using [TRS_]
  Wrseq '       When 4 : Close Local Mask [SLD0],[SLD1],[SLD2],[SLD3],[SLD4],[SLX1],[SLS1],[DST]' + SZREQ4(0,0)  Using [TRS_]
  Wrseq '       When 5 : Close Local Mask [SLI0],[SLI2],[SLI3],[SLI4],[SLX1],[DST]' + SZREQ5(0,0)  Using [TRS_]
  Wrseq '       When 6 : Close Local Mask [SLR0],[SLR1],[SLR2],[ETR2],[DST]' + SZREQ6(0,0)  Using [TRS_]
  Wrseq '       When 7 : Close Local Mask [SLL0],[SLL1],[SLL2],[ETR2],[DST]' + SZREQ7(0,0)  Using [TRS_]
  Wrseq '       When 8 : Close Local Mask [SSC0],[SSC1],[SSC2],[ETR2],[DST]' + SZREQ8(0,0)  Using [TRS_]
  Wrseq '       When 52: Close Local Mask [SLI0],[SLA1],[SLI2],[SLI3],[SLI4],[SLX1],[ETR2],[DST]' + SZREQ52(0,0)  Using [TRS_]
  Wrseq '     Endcase'  Using [TRS_]
  Wrseq '     Case [F:SLT]STRTYP'  Using [TRS_]
  Wrseq '       When 1 : If clalev ([M:SLQ0])<=0 : Local Mask =APPLI+".SLQ0" [SLQ0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLQ1])<=0 : Local Mask =APPLI+".SLQ1" [SLQ1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLQ2])<=0 : Local Mask =APPLI+".SLQ2" [SLQ2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLQ3])<=0 : Local Mask =APPLI+".SLQ3" [SLQ3] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLX1])<=0 : Local Mask =APPLI+".SLX1" [SLX1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif'  Using [TRS_]
  For NI = 0 To IREQ1-1
    Wrseq '                ' + SZREQ1(NI,1)  Using [TRS_]
  Next NI
  Wrseq '                Default Mask "[SLQ0],[SLQ1],[SLQ2],[SLQ3],[SLX1],[DST]' +  SZREQ1(0,0) + '"'  Using [TRS_]
  Wrseq '       When 2 : If clalev ([M:SLC0])<=0 : Local Mask =APPLI+".SLC0" [SLC0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLC1])<=0 : Local Mask =APPLI+".SLC1" [SLC1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLC2])<=0 : Local Mask =APPLI+".SLC2" [SLC2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLC3])<=0 : Local Mask =APPLI+".SLC3" [SLC3] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLC4])<=0 : Local Mask =APPLI+".SLC4" [SLC4] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLC5])<=0 : Local Mask =APPLI+".SLC5" [SLC5] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLX1])<=0 : Local Mask =APPLI+".SLX1" [SLX1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif'  Using [TRS_]
  For NI = 0 To IREQ2-1
    Wrseq '                ' + SZREQ2(NI,1)  Using [TRS_]
  Next NI
  Wrseq '                Default Mask "[SLC0],[SLC1],[SLC2],[SLC3],[SLC4],[SLC5],[SLX1],[DST]' +  SZREQ2(0,0) + '"'  Using [TRS_]
  Wrseq '       When 3 : If clalev ([M:SLO0])<=0 : Local Mask =APPLI+".SLO0" [SLO0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLO1])<=0 : Local Mask =APPLI+".SLO1" [SLO1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLO2])<=0 : Local Mask =APPLI+".SLO2" [SLO2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLO3])<=0 : Local Mask =APPLI+".SLO3" [SLO3] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLX1])<=0 : Local Mask =APPLI+".SLX1" [SLX1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif'  Using [TRS_]
  For NI = 0 To IREQ3-1
    Wrseq '                ' + SZREQ3(NI,1)  Using [TRS_]
  Next NI
  Wrseq '                Default Mask "[SLO0],[SLO1],[SLO2],[SLO3],[SLX1],[DST]' +  SZREQ3(0,0) + '"'  Using [TRS_]
  Wrseq '       When 4 : If clalev ([M:SLD0])<=0 : Local Mask =APPLI+".SLD0" [SLD0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLD1])<=0 : Local Mask =APPLI+".SLD1" [SLD1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLD2])<=0 : Local Mask =APPLI+".SLD2" [SLD2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLD3])<=0 : Local Mask =APPLI+".SLD3" [SLD3] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLD4])<=0 : Local Mask =APPLI+".SLD4" [SLD4] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLX1])<=0 : Local Mask =APPLI+".SLX1" [SLX1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLS1])<=0 : Local Mask =APPLI+".SLS1" [SLS1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif'  Using [TRS_]
  For NI = 0 To IREQ4-1
    Wrseq '                ' + SZREQ4(NI,1)  Using [TRS_]
  Next NI
  Wrseq '                Default Mask "[SLD0],[SLD1],[SLD2],[SLD3],[SLD4],[SLX1],[SLS1],[DST]' +  SZREQ4(0,0) + '"'  Using [TRS_]
  Wrseq '       When 5 : If clalev ([M:SLI0])<=0 : Local Mask =APPLI+".SLI0" [SLI0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLI2])<=0 : Local Mask =APPLI+".SLI2" [SLI2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLI3])<=0 : Local Mask =APPLI+".SLI3" [SLI3] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLI4])<=0 : Local Mask =APPLI+".SLI4" [SLI4] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLX1])<=0 : Local Mask =APPLI+".SLX1" [SLX1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif'  Using [TRS_]
  Wrseq '                If [F:SLT]INVTYP=2'  Using [TRS_]
  Wrseq '                    If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif'  Using [TRS_]
  Wrseq '                    If clalev ([M:SLA1])<=0 : Local Mask =APPLI+".SLA1" [SLA1] : Endif'  Using [TRS_]
  For NI = 0 To IREQ52-1
    Wrseq '                    ' + SZREQ52(NI,1)  Using [TRS_]
  Next NI
  Wrseq '                    Default Mask "[SLI0],[SLI2],[SLI3],[SLI4],[SLX1],[ETR2],[SLA1],[DST]' +  SZREQ52(0,0) + '"'  Using [TRS_]
  Wrseq '                Else'  Using [TRS_]
  Wrseq '                    If clalev ([M:SLS1])<=0 : Local Mask =APPLI+".SLS1" [SLS1] : Endif'  Using [TRS_]
  Wrseq '                    If clalev ([M:SLI1])<=0 : Local Mask =APPLI+".SLI1" [SLI1] : Endif'  Using [TRS_]
  For NI = 0 To IREQ5-1
    Wrseq '                    ' + SZREQ5(NI,1)  Using [TRS_]
  Next NI
  Wrseq '                    Default Mask "[SLI0],[SLI2],[SLI3],[SLI4],[SLX1],[SLS1],[SLI1],[DST]' +  SZREQ5(0,0) + '"'  Using [TRS_]
  Wrseq '                Endif'  Using [TRS_]
  Wrseq '       When 6 : If clalev ([M:SLR0])<=0 : Local Mask =APPLI+".SLR0" [SLR0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLR1])<=0 : Local Mask =APPLI+".SLR1" [SLR1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLR2])<=0 : Local Mask =APPLI+".SLR2" [SLR2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif'  Using [TRS_]
  For NI = 0 To IREQ6-1
    Wrseq '                ' + SZREQ6(NI,1)  Using [TRS_]
  Next NI
  Wrseq '                Default Mask "[SLR0],[SLR1],[SLR2],[ETR2],[DST]' +  SZREQ6(0,0) + '"'  Using [TRS_]
  Wrseq '       When 7 : If clalev ([M:SLL0])<=0 : Local Mask =APPLI+".SLL0" [SLL0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLL1])<=0 : Local Mask =APPLI+".SLL1" [SLL1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SLL2])<=0 : Local Mask =APPLI+".SLL2" [SLL2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif'  Using [TRS_]
  For NI = 0 To IREQ7-1
    Wrseq '                ' + SZREQ7(NI,1)  Using [TRS_]
  Next NI
  Wrseq '                Default Mask "[SLL0],[SLL1],[SLL2],[ETR2],[DST]' +  SZREQ7(0,0) + '"'  Using [TRS_]
  Wrseq '       When 8 : If clalev ([M:SSC0])<=0 : Local Mask =APPLI+".SLSCO0" [SSC0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SSC1])<=0 : Local Mask =APPLI+".SLSCO1" [SSC1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SSC2])<=0 : Local Mask =APPLI+".SLSCO2" [SSC2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif'  Using [TRS_]
  For NI = 0 To IREQ8-1
    Wrseq '                ' + SZREQ8(NI,1)  Using [TRS_]
  Next NI
  Wrseq '                Default Mask "[SSC0],[SSC1],[SSC2],[ETR2],[DST]' +  SZREQ8(0,0) + '"'  Using [TRS_]
  Wrseq '     Endcase'  Using [TRS_]
  Wrseq '     WTYP=[F:SLT]STRTYP'  Using [TRS_]
  Wrseq '     If find([F:SLT]INVTYP, 1,3,4) WINVTYP=1'  Using [TRS_]
  Wrseq '     Else WINVTYP=[F:SLT]INVTYP Endif'  Using [TRS_]
  Wrseq '  Endif'  Using [TRS_]
  Wrseq '  WDIE_DTRTYP=[F:SLT]STRTYP'  Using [TRS_]
  Wrseq '  ACTION="OUVRE" : Gosub TRT_DIETRS From SUBDST'  Using [TRS_]
  Wrseq '  Call DEBTRANS From GLOCK'  Using [TRS_]
  Wrseq '  Trbegin [SLT]'  Using [TRS_]
  Wrseq '  Case [F:SLT]STRTYP'  Using [TRS_]
  Wrseq '    When 1 : [M:SLQ0]=[F:SLT] : [M:SLQ1]=[F:SLT] : [M:SLQ2]=[F:SLT] : [M:SLQ3]=[F:SLT]'  Using [TRS_]
  Wrseq '             [M:SLX1]=[F:SLT]'  Using [TRS_]
  Wrseq '             ' + SZREQ1(0,2)  Using [TRS_]
  Wrseq '             ACTION="LIENS" : Gosub ACTION     From SUBSLQ'  Using [TRS_]
  Wrseq '             ACTION="MASSE" : Gosub TRT_ECRAN  From SUBSLQ'  Using [TRS_]
  Wrseq '             Close Local Mask [SLQ0],[SLQ1],[SLQ2],[SLQ3],[SLX1],[DST]' Using [TRS_]   #Gbn-98393
  Wrseq '    When 2 : [M:SLC0]=[F:SLT] : [M:SLC1]=[F:SLT] : [M:SLC2]=[F:SLT] : [M:SLC3]=[F:SLT]'  Using [TRS_]
  Wrseq '             [M:SLC4]=[F:SLT] : [M:SLC5]=[F:SLT] : [M:SLX1]=[F:SLT]'  Using [TRS_]
  Wrseq '             ' + SZREQ2(0,2)  Using [TRS_]
  Wrseq '             ACTION="LIENS" : Gosub ACTION     From SUBSLC'  Using [TRS_]
  Wrseq '             ACTION="MASSE" : Gosub TRT_ECRAN  From SUBSLC'  Using [TRS_]
  Wrseq '             Close Local Mask [SLC0],[SLC1],[SLC2],[SLC3],[SLC4],[SLC5],[SLX1],[DST]' Using [TRS_] #Gbn-98393
  Wrseq '    When 3 : [M:SLO0]=[F:SLT] : [M:SLO1]=[F:SLT] : [M:SLO2]=[F:SLT] : [M:SLO3]=[F:SLT]'  Using [TRS_]
  Wrseq '             [M:SLX1]=[F:SLT]'  Using [TRS_]
  Wrseq '             ' + SZREQ3(0,2)  Using [TRS_]
  Wrseq '             ACTION="LIENS" : Gosub ACTION     From SUBSLO'  Using [TRS_]
  Wrseq '             ACTION="MASSE" : Gosub TRT_ECRAN  From SUBSLO'  Using [TRS_]
  Wrseq '             Close Local Mask [SLO0],[SLO1],[SLO2],[SLO3],[SLX1],[DST]' Using [TRS_] #Gbn-98393
  Wrseq '    When 4 : [M:SLD0]=[F:SLT] : [M:SLD1]=[F:SLT] : [M:SLD2]=[F:SLT] : [M:SLD3]=[F:SLT]'  Using [TRS_]
  Wrseq '             [M:SLD4]=[F:SLT] : [M:SLX1]=[F:SLT] : [M:SLS1]=[F:SLT]'  Using [TRS_]
  Wrseq '             ' + SZREQ4(0,2)  Using [TRS_]
  Wrseq '             ACTION="LIENS" : Gosub ACTION     From SUBSLD'  Using [TRS_]
  Wrseq '             ACTION="MASSE" : Gosub TRT_ECRAN  From SUBSLD'  Using [TRS_]
  Wrseq '             Close Local Mask [SLD0],[SLD1],[SLD2],[SLD3],[SLD4],[SLX1],[SLS1],[DST]' Using [TRS_] #Gbn-98393
  Wrseq '    When 5 : '  Using [TRS_]
  Wrseq '             If [F:SLT]INVTYP=2'  Using [TRS_]
  Wrseq '               [M:SLA1]=[F:SLT] : [M:ETR2]=[F:SLT]'  Using [TRS_]
  Wrseq '               ' + SZREQ52(0,2)  Using [TRS_]
  Wrseq '             Else'  Using [TRS_]
  Wrseq '               [M:SLI1]=[F:SLT] : [M:SLS1]=[F:SLT]'  Using [TRS_]
  Wrseq '               ' + SZREQ5(0,2)  Using [TRS_]
  Wrseq '             Endif'  Using [TRS_]
  Wrseq '             [M:SLI0]=[F:SLT] : [M:SLI2]=[F:SLT] : [M:SLI3]=[F:SLT]'  Using [TRS_]
  Wrseq '             [M:SLI4]=[F:SLT] : [M:SLX1]=[F:SLT]'  Using [TRS_]
  Wrseq '             ACTION="LIENS" : Gosub ACTION     From SUBSLI'  Using [TRS_]
  Wrseq '             ACTION="MASSE" : Gosub TRT_ECRAN  From SUBSLI'  Using [TRS_]
  Wrseq '             Close Local Mask [SLI0],[SLI2],[SLI3],[SLI4],[SLX1],[DST]' Using [TRS_] #Gbn-98393
  Wrseq '    When 6 : [M:SLR0]=[F:SLT] : [M:SLR1]=[F:SLT] : [M:SLR2]=[F:SLT]'  Using [TRS_]
  Wrseq '             [M:ETR2]=[F:SLT] '  Using [TRS_]
  Wrseq '             ' + SZREQ6(0,2)  Using [TRS_]
  Wrseq '             ACTION="LIENS" : Gosub ACTION     From SUBSLR'  Using [TRS_]
  Wrseq '             ACTION="MASSE" : Gosub TRT_ECRAN  From SUBSLR'  Using [TRS_]
  Wrseq '             Close Local Mask [SLR0],[SLR1],[SLR2],[ETR2],[DST]' Using [TRS_] #Gbn-98393
  Wrseq '    When 7 : [M:SLL0]=[F:SLT] : [M:SLL1]=[F:SLT] : [M:SLL2]=[F:SLT]'  Using [TRS_]
  Wrseq '             [M:ETR2]=[F:SLT] '  Using [TRS_]
  Wrseq '             ' + SZREQ7(0,2)  Using [TRS_]
  Wrseq '             ACTION="LIENS" : Gosub ACTION     From SUBSLL'  Using [TRS_]
  Wrseq '             ACTION="MASSE" : Gosub TRT_ECRAN  From SUBSLL'  Using [TRS_]
  Wrseq '             Close Local Mask [SLL0],[SLL1],[SLL2],[ETR2],[DST]' Using [TRS_] #Gbn-98393
  Wrseq '    When 8 : [M:SSC0]=[F:SLT] : [M:SSC1]=[F:SLT] : [M:SSC2]=[F:SLT]'  Using [TRS_]
  Wrseq '             [M:ETR2]=[F:SLT] '  Using [TRS_]
  Wrseq '             ' + SZREQ8(0,2)  Using [TRS_]
  Wrseq '             ACTION="LIENS" : Gosub ACTION     From SUBSLS'  Using [TRS_]
  Wrseq '             ACTION="MASSE" : Gosub TRT_ECRAN  From SUBSLS'  Using [TRS_]
  Wrseq '             Close Local Mask [SSC0],[SSC1],[SSC2],[ETR2],[DST]' Using [TRS_] #Gbn-98393
  Wrseq '  Endcase'  Using [TRS_]
  Wrseq '  If GOK<1'  Using [TRS_]
  Wrseq '     Call ECR_TRACE(mess(21,123,1)-mess([F:SLT]STRTYP,435,1)-[F:SLT]STRNUM,1) From GESECRAN'  Using [TRS_]
  Wrseq '     Rollback'  Using [TRS_]
  Wrseq '  Else'  Using [TRS_]
  Wrseq '     Call ECR_TRACE(mess(14,123,1)-mess([F:SLT]STRTYP,435,1)-[F:SLT]STRNUM,0) From GESECRAN'  Using [TRS_]
  Wrseq '     Commit'  Using [TRS_]
  Wrseq '  Endif'  Using [TRS_]
  Wrseq 'Next'  Using [TRS_]
  Wrseq 'Return'  Using [TRS_]
  Wrseq ''  Using [TRS_]
  Openo Using [TRS_]
  #------------------------------------------
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
  #------------------------------------------
  IVALIDOK = 1
  Call VALID("TRT", SZPROGNAME, APPLI, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur lors de la génération : on appelle l'ancien pour que ça fonctionne au moins en standard
    # Je ne l'efface pas. Ca permettrait de trouver ce qui ne va pas
    #IEXIST = 1
    #Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
    Call OLD_VAL_SALTRS(TYP,NUM,APPLI)
    Return
  Endif
  #------------------------------------------
  Gosub TRANSAC_SAL From =APPLI + "." + SZPROGNAME
  #------------------------------------------
  # A mettre dans l'appelant
  IEXIST = 1
  Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  IEXIST = 1
  Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
Return
# FGR 16/11/2009 : X3SUIVI57491 (fin)
#========================================================================================

##############################################################################
# VAL_SALTRS : S/P Validation en masse des transactions de saisie des ventes #
# -------------------------------------------------------------------------- #
# Subprog VAL_SALTRS (TYP,NUM,APPLI)                                         #
#    TYP  : Type des transactions à valider (1n)                             #
#           0 = Toutes                                                       #
#           1 = Devis                                                        #
#           2 = Commande                                                     #
#           3 = Commande ouverte                                             #
#           4 = Livraison                                                    #
#           5 = Facture                                                      #
#           6 = Retour client                                                #
#           7 = Retour prêt                                                  #
#           8 = Retour matières sous-traitance                               #
#           52= Avoir                                                        #
#    NUM  : Code de la transaction à valider (3c)                            #
#           "" = Toutes                                                      #
#    APPLI : Dossier                                                         #
# -------------------------------------------------------------------------- #
# Table à partir de laquelle la validation est effectuée :                   #
#          [F:SLT]SALTRS   Table des transactions                            #
# Le fichier trace doit être ouvert avant l'appel du sous-programme          #
##############################################################################
Subprog VAL_SALTRS(TYP,NUM,APPLI)
Value  Integer  TYP
Value  Char     NUM
Value  Char     APPLI
Local  Integer  WTYP, OK, WINVTYP
Local  Char     ACTION(15), CRITERES(30)
Local Char      WDIE_ABRFIC(3) : WDIE_ABRFIC="SLT"
Local Integer   WDIE_DTRTYP
ACTION="MASSE"
Case TYP
  When 0 : CRITERES="1=1"
  When 1 : CRITERES="STRTYP=1"
  When 2 : CRITERES="STRTYP=2"
  When 3 : CRITERES="STRTYP=3"
  When 4 : CRITERES="STRTYP=4"
  When 5 : CRITERES="STRTYP=5 & find(INVTYP,1,3,4)"
  When 6 : CRITERES="STRTYP=6"
  When 7 : CRITERES="STRTYP=7"
  When 8 : CRITERES="STRTYP=8"
  When 52: CRITERES="STRTYP=5 & INVTYP=2"
  When Default : CRITERES=""
Endcase
If NUM<>"" & CRITERES<>"" CRITERES+=" & STRNUM=NUM" : Endif
If clalev([F:SLT])<=0 Local File =APPLI+".SALTRS" [SLT] : Endif

  Gosub GEN_TRTSALTRS
End

#====================================
Subprog OLD_VAL_SALTRS(TYP,NUM,APPLI)
Value  Integer  TYP
Value  Char     NUM
Value  Char     APPLI
Local  Integer  WTYP, OK, WINVTYP
Local  Char     ACTION(15), CRITERES(30)
Local Char      WDIE_ABRFIC(3) : WDIE_ABRFIC="SLT"
Local Integer   WDIE_DTRTYP
ACTION="MASSE"
Case TYP
  When 0 : CRITERES="1=1"
  When 1 : CRITERES="STRTYP=1"
  When 2 : CRITERES="STRTYP=2"
  When 3 : CRITERES="STRTYP=3"
  When 4 : CRITERES="STRTYP=4"
  When 5 : CRITERES="STRTYP=5 & find(INVTYP,1,3,4)"
  When 6 : CRITERES="STRTYP=6"
  When 7 : CRITERES="STRTYP=7"
  When 8 : CRITERES="STRTYP=8"
  When 52: CRITERES="STRTYP=5 & INVTYP=2"
  When Default : CRITERES=""
Endcase
If NUM<>"" & CRITERES<>"" CRITERES+=" & STRNUM=NUM" : Endif
If clalev([F:SLT])<=0 Local File =APPLI+".SALTRS" [SLT] : Endif
For [SLT] Where evalue(CRITERES)
  If [F:SLT]STRTYP<>WTYP | ([F:SLT]STRTYP=5 & ([F:SLT]INVTYP<>WINVTYP))
     Case WTYP
       When 1 : Close Local Mask [SLQ0],[SLQ1],[SLQ2],[SLQ3],[SLX1],[DST]
       When 2 : Close Local Mask [SLC0],[SLC1],[SLC2],[SLC3],[SLC4],[SLC5],[SLX1],[DST]
       When 3 : Close Local Mask [SLO0],[SLO1],[SLO2],[SLO3],[SLX1],[DST]
       When 4 : Close Local Mask [SLD0],[SLD1],[SLD2],[SLD3],[SLD4],[SLX1],[SLS1],[DST]
       When 5 : Close Local Mask [SLI0],[SLI2],[SLI3],[SLI4],[SLX1],[DST]
       When 6 : Close Local Mask [SLR0],[SLR1],[SLR2],[ETR2],[DST]
       When 7 : Close Local Mask [SLL0],[SLL1],[SLL2],[ETR2],[DST]
       When 8 : Close Local Mask [SSC0],[SSC1],[SSC2],[ETR2],[DST]
       When 52: Close Local Mask [SLI0],[SLA1],[SLI2],[SLI3],[SLI4],[SLX1],[ETR2],[DST]
     Endcase
     Case [F:SLT]STRTYP
       When 1 : If clalev ([M:SLQ0])<=0 : Local Mask =APPLI+".SLQ0" [SLQ0] : Endif
                If clalev ([M:SLQ1])<=0 : Local Mask =APPLI+".SLQ1" [SLQ1] : Endif
                If clalev ([M:SLQ2])<=0 : Local Mask =APPLI+".SLQ2" [SLQ2] : Endif
                If clalev ([M:SLQ3])<=0 : Local Mask =APPLI+".SLQ3" [SLQ3] : Endif
                If clalev ([M:SLX1])<=0 : Local Mask =APPLI+".SLX1" [SLX1] : Endif
                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif
                Default Mask "[SLQ0],[SLQ1],[SLQ2],[SLQ3],[SLX1],[DST]"
       When 2 : If clalev ([M:SLC0])<=0 : Local Mask =APPLI+".SLC0" [SLC0] : Endif
                If clalev ([M:SLC1])<=0 : Local Mask =APPLI+".SLC1" [SLC1] : Endif
                If clalev ([M:SLC2])<=0 : Local Mask =APPLI+".SLC2" [SLC2] : Endif
                If clalev ([M:SLC3])<=0 : Local Mask =APPLI+".SLC3" [SLC3] : Endif
                If clalev ([M:SLC4])<=0 : Local Mask =APPLI+".SLC4" [SLC4] : Endif
                If clalev ([M:SLC5])<=0 : Local Mask =APPLI+".SLC5" [SLC5] : Endif
                If clalev ([M:SLX1])<=0 : Local Mask =APPLI+".SLX1" [SLX1] : Endif
                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif
                Default Mask "[SLC0],[SLC1],[SLC2],[SLC3],[SLC4],[SLC5],[SLX1],[DST]"
       When 3 : If clalev ([M:SLO0])<=0 : Local Mask =APPLI+".SLO0" [SLO0] : Endif
                If clalev ([M:SLO1])<=0 : Local Mask =APPLI+".SLO1" [SLO1] : Endif
                If clalev ([M:SLO2])<=0 : Local Mask =APPLI+".SLO2" [SLO2] : Endif
                If clalev ([M:SLO3])<=0 : Local Mask =APPLI+".SLO3" [SLO3] : Endif
                If clalev ([M:SLX1])<=0 : Local Mask =APPLI+".SLX1" [SLX1] : Endif
                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif
                Default Mask "[SLO0],[SLO1],[SLO2],[SLO3],[SLX1],[DST]"
       When 4 : If clalev ([M:SLD0])<=0 : Local Mask =APPLI+".SLD0" [SLD0] : Endif
                If clalev ([M:SLD1])<=0 : Local Mask =APPLI+".SLD1" [SLD1] : Endif
                If clalev ([M:SLD2])<=0 : Local Mask =APPLI+".SLD2" [SLD2] : Endif
                If clalev ([M:SLD3])<=0 : Local Mask =APPLI+".SLD3" [SLD3] : Endif
                If clalev ([M:SLD4])<=0 : Local Mask =APPLI+".SLD4" [SLD4] : Endif
                If clalev ([M:SLX1])<=0 : Local Mask =APPLI+".SLX1" [SLX1] : Endif
                If clalev ([M:SLS1])<=0 : Local Mask =APPLI+".SLS1" [SLS1] : Endif
                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif
                Default Mask "[SLD0],[SLD1],[SLD2],[SLD3],[SLD4],[SLX1],[SLS1],[DST]"
       When 5 : If clalev ([M:SLI0])<=0 : Local Mask =APPLI+".SLI0" [SLI0] : Endif
                If clalev ([M:SLI2])<=0 : Local Mask =APPLI+".SLI2" [SLI2] : Endif
                If clalev ([M:SLI3])<=0 : Local Mask =APPLI+".SLI3" [SLI3] : Endif
                If clalev ([M:SLI4])<=0 : Local Mask =APPLI+".SLI4" [SLI4] : Endif
                If clalev ([M:SLX1])<=0 : Local Mask =APPLI+".SLX1" [SLX1] : Endif
                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif
                If [F:SLT]INVTYP=2
                    If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif
                    If clalev ([M:SLA1])<=0 : Local Mask =APPLI+".SLA1" [SLA1] : Endif
                    Default Mask "[SLI0],[SLI2],[SLI3],[SLI4],[SLX1],[ETR2],[SLA1],[DST]"
                Else
                    If clalev ([M:SLS1])<=0 : Local Mask =APPLI+".SLS1" [SLS1] : Endif
                    If clalev ([M:SLI1])<=0 : Local Mask =APPLI+".SLI1" [SLI1] : Endif
                    Default Mask "[SLI0],[SLI2],[SLI3],[SLI4],[SLX1],[SLS1],[SLI1],[DST]"
                Endif
       When 6 : If clalev ([M:SLR0])<=0 : Local Mask =APPLI+".SLR0" [SLR0] : Endif
                If clalev ([M:SLR1])<=0 : Local Mask =APPLI+".SLR1" [SLR1] : Endif
                If clalev ([M:SLR2])<=0 : Local Mask =APPLI+".SLR2" [SLR2] : Endif
                If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif
                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif
                Default Mask "[SLR0],[SLR1],[SLR2],[ETR2],[DST]"
       When 7 : If clalev ([M:SLL0])<=0 : Local Mask =APPLI+".SLL0" [SLL0] : Endif
                If clalev ([M:SLL1])<=0 : Local Mask =APPLI+".SLL1" [SLL1] : Endif
                If clalev ([M:SLL2])<=0 : Local Mask =APPLI+".SLL2" [SLL2] : Endif
                If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif
                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif
                Default Mask "[SLL0],[SLL1],[SLL2],[ETR2],[DST]"
       When 8 : If clalev ([M:SSC0])<=0 : Local Mask =APPLI+".SLSCO0" [SSC0] : Endif
                If clalev ([M:SSC1])<=0 : Local Mask =APPLI+".SLSCO1" [SSC1] : Endif
                If clalev ([M:SSC2])<=0 : Local Mask =APPLI+".SLSCO2" [SSC2] : Endif
                If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif
                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif
                Default Mask "[SSC0],[SSC1],[SSC2],[ETR2],[DST]"
     Endcase
     WTYP=[F:SLT]STRTYP
     If find([F:SLT]INVTYP, 1,3,4) WINVTYP=1
     Else WINVTYP=[F:SLT]INVTYP Endif
  Endif
  WDIE_DTRTYP=[F:SLT]STRTYP
  ACTION="OUVRE" : Gosub TRT_DIETRS From SUBDST
  Call DEBTRANS From GLOCK
  Trbegin [SLT]
  Case [F:SLT]STRTYP
    When 1 : [M:SLQ0]=[F:SLT] : [M:SLQ1]=[F:SLT] : [M:SLQ2]=[F:SLT] : [M:SLQ3]=[F:SLT]
             [M:SLX1]=[F:SLT]
#             Gosub TRT_ECRAN From SUBSLQ
             ACTION="LIENS" : Gosub ACTION     From SUBSLQ
             ACTION="MASSE" : Gosub TRT_ECRAN  From SUBSLQ
    When 2 : [M:SLC0]=[F:SLT] : [M:SLC1]=[F:SLT] : [M:SLC2]=[F:SLT] : [M:SLC3]=[F:SLT]
             [M:SLC4]=[F:SLT] : [M:SLC5]=[F:SLT] : [M:SLX1]=[F:SLT]
#             Gosub TRT_ECRAN From SUBSLC
             ACTION="LIENS" : Gosub ACTION     From SUBSLC
             ACTION="MASSE" : Gosub TRT_ECRAN  From SUBSLC
    When 3 : [M:SLO0]=[F:SLT] : [M:SLO1]=[F:SLT] : [M:SLO2]=[F:SLT] : [M:SLO3]=[F:SLT]
             [M:SLX1]=[F:SLT]
#             Gosub TRT_ECRAN From SUBSLO
             ACTION="LIENS" : Gosub ACTION     From SUBSLO
             ACTION="MASSE" : Gosub TRT_ECRAN  From SUBSLO
    When 4 : [M:SLD0]=[F:SLT] : [M:SLD1]=[F:SLT] : [M:SLD2]=[F:SLT] : [M:SLD3]=[F:SLT]
             [M:SLD4]=[F:SLT] : [M:SLX1]=[F:SLT] : [M:SLS1]=[F:SLT]
#             Gosub TRT_ECRAN From SUBSLD
             ACTION="LIENS" : Gosub ACTION     From SUBSLD
             ACTION="MASSE" : Gosub TRT_ECRAN  From SUBSLD
    When 5 :
             If [F:SLT]INVTYP=2 [M:SLA1]=[F:SLT] : [M:ETR2]=[F:SLT]
             Else               [M:SLI1]=[F:SLT] : [M:SLS1]=[F:SLT] : Endif
             [M:SLI0]=[F:SLT] : [M:SLI2]=[F:SLT] : [M:SLI3]=[F:SLT]
             [M:SLI4]=[F:SLT] : [M:SLX1]=[F:SLT]
#             Gosub TRT_ECRAN From SUBSLI
             ACTION="LIENS" : Gosub ACTION     From SUBSLI
             ACTION="MASSE" : Gosub TRT_ECRAN  From SUBSLI
    When 6 : [M:SLR0]=[F:SLT] : [M:SLR1]=[F:SLT] : [M:SLR2]=[F:SLT]
             [M:ETR2]=[F:SLT]
#             Gosub TRT_ECRAN From SUBSLR
             ACTION="LIENS" : Gosub ACTION     From SUBSLR
             ACTION="MASSE" : Gosub TRT_ECRAN  From SUBSLR
    When 7 : [M:SLL0]=[F:SLT] : [M:SLL1]=[F:SLT] : [M:SLL2]=[F:SLT]
             [M:ETR2]=[F:SLT]
#             Gosub TRT_ECRAN From SUBSLL
             ACTION="LIENS" : Gosub ACTION     From SUBSLL
             ACTION="MASSE" : Gosub TRT_ECRAN  From SUBSLL
    When 8 : [M:SSC0]=[F:SLT] : [M:SSC1]=[F:SLT] : [M:SSC2]=[F:SLT]
             [M:ETR2]=[F:SLT]
#             Gosub TRT_ECRAN From SUBSLL
             ACTION="LIENS" : Gosub ACTION     From SUBSLS
             ACTION="MASSE" : Gosub TRT_ECRAN  From SUBSLS
  Endcase
  If GOK<1
     Call ECR_TRACE(mess(21,123,1)-mess([F:SLT]STRTYP,435,1)-[F:SLT]STRNUM,1) From GESECRAN
     Rollback
  Else
     Call ECR_TRACE(mess(14,123,1)-mess([F:SLT]STRTYP,435,1)-[F:SLT]STRNUM,0) From GESECRAN
     Commit
  Endif
Next
End

##############################################################################
#    Programme appelé dans DOSWWW                                            #
##############################################################################
Subprog GENDOSSVG(APPLI)
Value Char APPLI

Local Char    ECRAN(GLONAMK)
Local Integer I, TOK(1..10)
Raz TOK
If clalev([F:SLT])<=0 : Local File =APPLI+".SALTRS"    [SLT] : Endif
Local File =APPLI+".AWINDOW"   [AWI] : # Déjà ouvert en local, le réouvrir !
Local File =APPLI+".AWINPAR"   [AWP] : # Déjà ouvert en local, le réouvrir !
If clalev([F:AMK])<=0 : Local File =APPLI+".AMSK"      [AMK] : Endif
If clalev([F:AMZ])<=0 : Local File =APPLI+".AMSKZON"   [AMZ] : Endif
If clalev([F:AMA])<=0 : Local File =APPLI+".AMSKACT"   [AMA] : Endif
If clalev([F:AMP])<=0 : Local File =APPLI+".AMSKPAR"   [AMP] : Endif
If clalev([F:ATY])<=0 : Local File =APPLI+".ATYPE"     [ATY] : Endif
If clalev([F:ACT])<=0 : Local File =APPLI+".ACTION"    [ACT] : Endif
If clalev([F:ATR])<=0 : Local File =APPLI+".ACTPAR"    [ATR] : Endif
If clalev([F:AAR])<=0 : Local File =APPLI+".ACTCODPAR" [AAR] : Endif
If clalev([F:ATB])<=0 : Local File =APPLI+".ATABLE"    [ATB] : Endif
If clalev([F:ATZ])<=0 : Local File =APPLI+".ATABZON"   [ATZ] : Endif
# DéJà ouvert en local, le réouvrir !
Local File =APPLI+".ACTIV"     [ACV]
Local File =APPLI+".AOBJET"    [AOB]
#
If clalev([F:ATX])<=0 : Local File =APPLI+".ATEXTE"    [ATX] : Endif
If clalev([F:ADV])<=0 : Local File =APPLI+".ATABTAB"   [ADV] : Endif

If (GCRE or GVALIDE(7))
   For I=1 To 10 : TOK(I) = 1 : Next I
Else
   # Devis
   Read [AWI]AWI0 = "OSQH"
   If [F:AWI]UPDFLG = 1
      TOK(1) = 1
   Else
      For ECRAN = "SQH0","SQH1","SQH2","SQH3"
          Read [AMK]CODMSK = ECRAN
          If [F:AMK]UPDFLG = 1 : TOK(1) = 1 : Break : Endif
      Next ECRAN
   Endif
   # Commandes
   Read [AWI]AWI0 = "OSOH"
   If [F:AWI]UPDFLG = 1
      TOK(2) = 1
   Else
      For ECRAN = "SOH0","SOH1","SOH2","SOH3","SOH4"
         Read [AMK]CODMSK = ECRAN
         If [F:AMK]UPDFLG = 1 : TOK(2) = 1 : Break : Endif
      Next ECRAN
   Endif
   # Commandes ouvertes
   Read [AWI]AWI0 = "OSOR"
   If [F:AWI]UPDFLG = 1
      TOK(3) = 1
   Else
      Read [AWI]AWI0 = "OSOI"
      If [F:AWI]UPDFLG = 1
         TOK(3) = 1
      Else
         For ECRAN = "SOR1","SOI1"
            Read [AMK]CODMSK = ECRAN
            If [F:AMK]UPDFLG = 1 : TOK(3) = 1 : Break : Endif
         Next ECRAN
      Endif
   Endif
   # Livraisons
   Read [AWI]AWI0 = "OSDH"
   If [F:AWI]UPDFLG = 1
      TOK(4) = 1
   Else
      For ECRAN = "SDH0","SDH1","SDH2","SDH3"
         Read [AMK]CODMSK = ECRAN
         If [F:AMK]UPDFLG = 1 : TOK(4) = 1 : Break : Endif
      Next ECRAN
   Endif
   # Factures
   Read [AWI]AWI0 = "OSIH"
   If [F:AWI]UPDFLG = 1
      TOK(5) = 1
   Else
      For ECRAN = "SIH0","SIH1","SIH2","SIH4","SIHV"
         Read [AMK]CODMSK = ECRAN
         If [F:AMK]UPDFLG = 1 : TOK(5) = 1 : Break : Endif
      Next ECRAN
   Endif
   # Retours client
   Read [AWI]AWI0 = "OSRH"
   If [F:AWI]UPDFLG = 1
      TOK(6) = 1
   Else
      Read [AMK]CODMSK = "SRH1"
      If [F:AMK]UPDFLG = 1 : TOK(6) = 1 : Endif
   Endif
   # Retours prêt
   Read [AWI]AWI0 = "OSRL"
   If [F:AWI]UPDFLG = 1
      TOK(7) = 1
   Else
      Read [AMK]CODMSK = "SRL1"
      If [F:AMK]UPDFLG = 1 : TOK(7) = 1 : Endif
   Endif
Endif

If sum(TOK(1..7)) = 7
   Call VAL_SALTRS(0,"",APPLI)
Else
   If TOK(1) = 1 : Call VAL_SALTRS(1,"",APPLI) : Endif
   If TOK(2) = 1 : Call VAL_SALTRS(2,"",APPLI) : Endif
   If TOK(3) = 1 : Call VAL_SALTRS(3,"",APPLI) : Endif
   If TOK(4) = 1 : Call VAL_SALTRS(4,"",APPLI) : Endif
   If TOK(5) = 1 : Call VAL_SALTRS(5,"",APPLI) : Endif
   If TOK(6) = 1 : Call VAL_SALTRS(6,"",APPLI) : Endif
   If TOK(7) = 1 : Call VAL_SALTRS(7,"",APPLI) : Endif
Endif

End
