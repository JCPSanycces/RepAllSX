Return

#########################################################################
$REWRITE_SCS                               # suite Issue 87818 GA 04/2013
#
  # maj encours SCx
   Call UPDATE_SCX("M") From SCOLIB

   #----- Ecriture des comptes et sections de la ligne de document -----#
   #Call UPDATE_SCS_CPTANALIN ("M") From SCOCPTLIB
   # Issue 90716 GA 06/2013
   Gosub MAJSCS_CPTANALIN From SCOCPTLIB

   Gosub REWRITE_SCS From SCOLIB

Return
#########################################################################
$CTRL_FCY   : # init par défaut des différents codes FCY en création/maj
If [M:SCOK]POHFCY="" & [M:SCOK]STOFCY<>""
   [M:SCOK]POHFCY=[M:SCOK]STOFCY
Endif
# Issue 86439 GA 12/2012
# lecture alternative nomenclature: ctrl du site de réception
If [M:SCOK]BOMALT<>0
  Read [TBO]TBO0=3;[M:SCOK]BOMALT
  If fstat : End : Endif
  If [F:TBO]FCY<>""
     If [M:SCOK]PRHFCY=""
        [M:SCOK]PRHFCY=[F:TBO]FCY
     Elsif [M:SCOK]PRHFCY<>[F:TBO]FCY
        Call ECR_TRACE([M:SCOK]PRHFCY-mess(48,193,1)-num$([M:SCOK]BOMALT),1) From GESECRAN
        WOK=0 : Return
     Endif
  Endif
Endif
If [M:SCOK]PRHFCY="" & [M:SCOK]POHFCY<>""
   [M:SCOK]PRHFCY=[M:SCOK]POHFCY
Endif
# Issue 86437 GA 12/2012 before [M:SCOK]POHFCY
# Issue 80579 Import PEO: STOFCY is empty
If [M:SCOK]STOFCY="" & [M:SCOK]PRHFCY<>""
   [M:SCOK]STOFCY=[M:SCOK]PRHFCY
Endif
# [M:SCOK]MFGFCY renseigné uniquement en inter-site = site associé au fournisseur
#If [M:SCOK]MFGFCY="" & [M:SCOK]POHFCY<>""
#   [M:SCOK]MFGFCY=[M:SCOK]POHFCY
#Endif

# Issue 86437 GA 12/2012
#If [M:SCOK]POHFCY<>[M:SCOK]PRHFCY
  If clalev([F:FCY1]) = 0 : Local File FACILITY   [FCY1] : Endif
  If clalev([F:FCY2]) = 0 : Local File FACILITY   [FCY2] : Endif
  Read [FCY1]FCY0=[M:SCOK]POHFCY : If fstat : Raz [F:FCY1] : Endif
  Read [FCY2]FCY0=[M:SCOK]PRHFCY : If fstat : Raz [F:FCY2] : Endif
  If [F:FCY1]PURFLG<>2
     # Le site n'est pas un site d'achat
     Call ECR_TRACE([F:FCY1]FCY-mess(145,194,1),1) From GESECRAN
     WOK=0 : Return
  Endif
  If [F:FCY2]WRHFLG<>2
     # Le site n'est pas un site de stock
     Call ECR_TRACE([F:FCY2]FCY-mess(61,187,1),1) From GESECRAN
     WOK=0 : Return
  Endif
  If [F:FCY1]LEGCPY<>[F:FCY2]LEGCPY
     # Le site n'est pas sur la même société juridique
     Call ECR_TRACE([F:FCY1]FCY-"/"-[F:FCY2]FCY-mess(2,194,1)-[F:FCY1]LEGCPY-"/"-[F:FCY2]LEGCPY,1) From GESECRAN
     WOK=0 : Return
  Endif
#Endif
Return
##################################################################
#-----------------------------------------------------#
# Contrôle et chargement des zones pour l'inter-sites #
# --------------------------------------------------- #
# LPOHFCY : Site de commande                          #
# LBPRNUM : Fournisseur de la commande                #
#-----------------------------------------------------#
Subprog CTRL_INTERSITE (LPOHFCY,LBPRNUM)
Variable Char    LPOHFCY
Variable Char    LBPRNUM

If LBPRNUM="" : End : Endif
Local Char    WBPCORD(GLONBPR),WBPCINV(GLONBPR)
Local Char    WSALFCY(GLONFCY)
Local Integer WDME,WBETFCY,WBETCPY

Raz [F:SCO]MFGFCY
Call CTRL_INTERSITE(LPOHFCY,LBPRNUM,2,WBETFCY,WBETCPY,WSALFCY,
&                   [F:SCO]MFGFCY,WBPCORD,[F:SCO]INVFCY,WBPCINV,
&                   WDME) From TRTACHCTL1
[F:SCO]BETFCY = WBETFCY
[F:SCO]BETCPY = WBETCPY
End

$INIT_TARIF
# FQ 72413 GA 03/2011 appel Tarif achat
If clalev([F:BPC]) = 0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPD]) = 0 : Local File BPDLVCUST  [BPD] : Endif
If clalev([F:BPS]) = 0 : Local File BPSUPPLIER [BPS] : Endif  # FQ 73060 GA 04/2011 pour UTIACH28
If clalev([F:BPR]) = 0 : Local File BPARTNER   [BPR] : Endif  # FQ 73060 GA 04/2011 pour UTIACH28
If clalev([F:MVS]) = 0 : Local File BPSUPPMVT  [MVS] : Endif
If clalev([F:TCY]) = 0 : Local File TABCOUNTRY [TCY] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:POS]) = 0 : Local File POSCOD     [POS] : Endif
If clalev([F:PPK]) = 0 : Local File PPRICLINK  [PPK] : Endif
If clalev([F:TCU]) = 0 : Local File TABCUR     [TCU] : Endif
#----- Ouverture fichiers pour inter-sites / inter-sociétés -----#
If GMODU(5)=2 : # Si module Ventes présent
  If !clalev([F:ITS]) : Local File ITMSALES   [ITS] : Endif
  If !clalev([F:MVC]) : Local File BPCUSTMVT  [MVC] : Endif
  If !clalev([F:SOH]) : Local File SORDER     [SOH] : Endif
Endif

#-----------------------------------------------------#
# Contrôle existence de la structure tarif par défaut #
# et chargement des libellés colonnes par défaut      #
#-----------------------------------------------------#
#####Raz GRCPFCY, GPLISTC, GPUU, GREVFLG, GAPPFLG, GPLIFLG, GVACFLG, GDATFLG,
#####&   GCOEUOM, GPURTRACE
Local Libelle  WMODULE : WMODULE=6
Local Integer  I, WRET
#Local Char     CODE(3)
#Local Shortint OUVFICFLG
#Local Integer  I, WRET, WCOD, MAJCDE
#Local Libelle  WPE_POHCLEFLG, WCLEFLG, WTRAIT
Call CTLSTRUCT(2,WRET) From TRTPRICE
If WRET<>0 OK=0 : Return : Endif

#----- Chargement libellés et formats colonnes tarif -----#
# FQ 72413 GA 05/2011 1er passage, on devrait avoir GPLISTC="none" => ajout | GPLISTC=""
If GPLISTC<>[F:BPS]PLISTC | GPLISTC=""
  GPLISTC=[F:BPS]PLISTC
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
  Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
  Call TARIFCHGT(6)                From TRTPRICE
Endif


Return

##################################################################
#---------------------------------------------#
# Messages en cas d'abandon de la transaction #
#---------------------------------------------#
$AB_TRANSACTION_MSG
  If GMESSAGE<>""   # FQ 68321 GA 10/2010 afficher d'abord le message d'erreur ;-)
     Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Endif
  GMESSAGE=mess(157,199,1)  : # Transaction abandonnée
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Raz GMESSAGE
Return

# ---------------------------------------------------------------------------
# Issue 105251 GA 04/2015
# New entry point: how to select components validity date in a BOM
# ---------------------------------------------------------------------------
# Variable must be declared: Local Integer WBOMDATCTL
# - WBOMDATCTL=2 start date is used (standard behavior)
# - WBOMDATCTL=1 end   date is used
# ---------------------------------------------------------------------------
$PE_BOMDATCTL
If dim(WBOMDATCTL)<0 Return Endif
GPE=0 : GPOINT = "BOMDATCTL" : Gosub ENTREE From EXEFNC
If GPE : WBOMDATCTL=GPE : Endif
Return

