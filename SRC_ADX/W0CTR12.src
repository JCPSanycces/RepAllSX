#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR12 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone HRLSTNR
mkstat = 0
zoncou = "HRLSTNR"
indice = 0
status = 1
zoncou = "HRLSTNR"
If varmode([M]HRLSTNR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "HRLSTNR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]HRLSTNR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]HRLSTNR = nolign
   status = 75
   Call SAI_HRLSTNR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_HRLSTNR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone HRLSTNR
mkstat = 0
zoncou = "HRLSTNR"

## Zone CODLST
mkstat = 0
zoncou = "CODLST"
If varmode([M]CODLST,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODLST" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CODLST(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CODLST" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTHRLST"
  Call CONTHRLST([M]CODLST(indice)) From SUBHRLST
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODLST" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]CODLST(indice)
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]CODLST(indice) = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CODLST" : GZNUM = 5296 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_CODLST([M]CODLST(indice)) From SUBCTR2
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CODLST" : GZNUM = 5296 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone STRDATLVE
mkstat = 0
zoncou = "STRDATLVE"
If varmode([M]STRDATLVE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "STRDATLVE" : Gosub ACTION From =IMPTRT
 Endif
 If [M]STRDATLVE(indice)=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "STRDATLVE" : GZNUM = 1805 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_STRDATLVE([M]STRDATLVE(indice)) From SUBCTR2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "STRDATLVE" : GZNUM = 1805 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone ENDDATLVE
mkstat = 0
zoncou = "ENDDATLVE"
If varmode([M]ENDDATLVE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENDDATLVE" : Gosub ACTION From =IMPTRT
 Endif
 If [M]ENDDATLVE(indice)=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "ENDDATLVE" : GZNUM = 1806 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "DATDEBFIN"
  Call DATDEBFIN([M]ENDDATLVE(indice),[M]STRDATLVE(nolign-1)) From EXEFNC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ENDDATLVE" : GZNUM = 1806 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_ENDDATLVE([M]ENDDATLVE(indice)) From SUBCTR2
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "ENDDATLVE" : GZNUM = 1806 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone HRLSTNR
mkstat = 0
zoncou = "HRLSTNR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CTR12"
Return

