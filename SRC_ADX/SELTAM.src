#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(30)(1..5) , VALEUR(10)
Call S_TAB_CHAR(VALEUR,PARAM,"SELTAM","SELTAM","") From GACTION
End

#######################################################################
# Action SELTAM
#######################################################################
$ACTION
Case ACTION
 When "SEL_TABLE"
  Case TABLE
    When "SELTAM"    : Gosub SELTAM
    When "SELTAM2"   : Gosub SELTAM2
  Endcase
Endcase
Return

$SELTAM
If clalev([F:TAM])=0 : Local File TABPAM       [TAM] : Endif
If clalev([F:TAMS])=0 : Local File LEGTAMSEL  [TAMS] : Endif  # Vues
If clalev([F:TAMG])=0 : Local File LEGTAMGFY  [TAMG] : Endif  # Vues
If clalev([F:TAMP])=0 : Local File LEGTAMPAR  [TAMP] : Endif  # Vues
If clalev([F:TAMY])=0 : Local File LEGTAMYGRP [TAMY] : Endif  # Vues
If clalev([F:TAMZ])=0 : Local File LEGTAMZGRP [TAMZ] : Endif  # Vues

If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif

Local Char    FCY(GLONFCY)
Local Char    CPY(GLONFCY)
Local Char    LEG(GLONADI)
Local Char    GRP(GLONAGC)

Local Char SAVE_FCY(GLONFCY) : SAVE_FCY=GCURFCY
Local Char SAVE_CPY(GLONCPY) : SAVE_CPY=GSOCIETE
Local Char SAVE_LEG(GLONADI) : SAVE_LEG=GCURLEG
Local Char SAVE_GRP(GLONAGC) : SAVE_GRP=GGRPFCY

#--------------------------------------------------------------------------------------------------
# Récupération des paramètres
#--------------------------------------------------------------------------------------------------

If dim([M:RPT]ETAT)>0  #GACTION="AFMTSEL" : # = Sélection paramètres d'édition
 If [M:RPT]RPTCOD="RELFAC"
  I = find("cpy",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
 Else
  I = find("societe",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
 Endif
 If I
  CPY = [M:RPT]VALINT1(I-1)
  Call LEC_CPY(CPY) From CPTLEC
  LEG = [F:CPY]LEG
 Endif
Elsif GFONCTION<>"GEXPOBJ"
 LEG    = PARAM(1)
 GRP    = PARAM(2)
 If GCURFCY  <>""  & [L]FCY="" : [L]FCY = GCURFCY  : Endif
 If GSOCIETE <>""  & [L]CPY="" : [L]CPY = GSOCIETE : Endif
 If GCURLEG  <>""  & [L]LEG="" : [L]LEG = GCURLEG  : Endif
 If GGRPFCY  <>""  & [L]GRP="" : [L]GRP = GGRPFCY  : Endif
Endif

# Initialisations diverses FCY/CPY/LEG & GCURFCY/GSOCIETE/GCURLEG
If [L]FCY<>""
 Call LEC_FCY([L]FCY) From CPTLEC
 Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
 [L]CPY = [F:CPY]CPY : GSOCIETE = [L]CPY
 [L]LEG = [F:CPY]LEG : GCURLEG  = [L]LEG
 [L]GRP = ""
Elsif [L]CPY<>""
 Call LEC_CPY([L]CPY) From CPTLEC
 [L]CPY = [F:CPY]CPY : GSOCIETE = [L]CPY
 [L]LEG = [F:CPY]LEG : GCURLEG  = [L]LEG
 [L]GRP = ""
Endif
# Si groupe de société (non société juridique) alors GCURLEG et LEG à vide pour que la sélection présente toutes les données.
If [L]CPY<>""
 Call LEC_CPY([L]CPY) From CPTLEC
 If [F:CPY]CPYLEGFLG<>2
  [L]LEG="" : GCURLEG="" : [L]GRP = [L]CPY : [L]CPY="" : [L]FCY=""
 Endif
Endif

#--------------------------------------------------------------------------------------------------
## Position et taille de la fenêtre
#--------------------------------------------------------------------------------------------------
Gosub OUVRE_LISTE From WOTAM

For I=1 To NBSEL
 If SELEXP(I)<>""
  COL(I) = SELEXP(I)
 Else
  COL(I) = SELZON(I)
 Endif
 TIT(I) = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I

NBCOL  = NBSEL
SIZCOL = 240
SIZLIG = 100
TIT(0) = mess(12,123,1)  # Choix
Call TITOBJ("TAM","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START  = "[F:TAM]PAM"
ORDRE  = "[F:TAM]PAM;[F:TAM]LEG"
OBJET  = ""

#--------------------------------------------------------------------------------------------------
## Critères pour la sélection standard
#--------------------------------------------------------------------------------------------------

## Critères de sélection
## Le link fait des liaisons "externes gauches"
## Toute la subtilité de la chose est de mettre des fonctions qui
## ne sont pas transmises à la base de données : len() , num$()
## sinon celle-ci ne renvoie rien du tout


CRITERE(1)   = "[F:TAM]ENAFLG=2"

If [L]LEG<>""
 CRITERE(1) -= '& ([F:TAM]LEG="'+[L]LEG+'" | [F:TAM]LEG="")'
Endif

If [L]FCY<>""
 CRITERE(1) -= '& ([F:TAM]GFY="" | ([F:TAM]GFY<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
Elsif [L]CPY<>""
 CRITERE(1) -= '& ([F:TAM]GFY="" | ([F:TAM]GFY<>"" & [F:TAMG]LEGCPY="'+[L]CPY+'"))'
Elsif [L]GRP<>""
 If [L]LEG<>""
  CRITERE(1) -= '& ([F:TAM]GFY="" | ([F:TAM]GFY<>"" & [F:TAMY]GRPORI="'+[L]GRP+'"))'
 Else
  CRITERE(1) -= '& ([F:TAM]GFY="" | ([F:TAM]GFY<>"" & [F:TAMZ]GRPORI="'+[L]GRP+'"))'
 Endif
Endif

If dim(SELCAR)>0 & SELCAR<>0
 CRITERE(1) = 'left$([F:TAM]PAM,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

ICRITERE = 2
Call FILROLE("TAM",FILROLE) From SUBARL
If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif

#--------------------------------------------------------------------------------------------------
# Critères pour la sélection spécifique
#--------------------------------------------------------------------------------------------------
Case GFONCTION
 When "GESPAY" :
  CRITERE(2) -= "& find([F:TAM]PAM,[F:TPY]PAM(0.."+num$([F:TPY]NBRPAM-1)+"))"
Endcase


#--------------------------------------------------------------------------------------------------
## Appel à la vue
#--------------------------------------------------------------------------------------------------
#
If [L]LEG<>""
 # Vues via LEG/FCY
 If [L]FCY<>""
  Link [F:TAM] With [AXX]AXX0     = "TABPAM";"DESAXX";GLANGUE;[F:TAM]PAM;[F:TAM]LEG
&                 , [FGR]FGR1     =  [L]FCY;[F:TAM]GFY
&                 , [TAMS]TAM0   ~=  [F:TAM]PAM;[F:TAM]LEG;[L]LEG
&                 , [TAMG]TAM0    =  [F:TAM]PAM;[F:TAM]LEG;[F:TAM]GFY;[L]CPY
& As [LNC]
 Elsif [L]CPY<>""
  # Vues via LEG/CPY
  Link [F:TAM] With [AXX]AXX0     = "TABPAM";"DESAXX";GLANGUE;[F:TAM]PAM;[F:TAM]LEG
&                 , [TAMS]TAM0   ~=  [F:TAM]PAM;[F:TAM]LEG;[L]LEG
&                 , [TAMG]TAM0    =  [F:TAM]PAM;[F:TAM]LEG;[F:TAM]GFY;[L]CPY
& As [LNC]
 Elsif [L]GRP<>""
  # Vues via LEG/GRP
  Link [F:TAM] With [AXX]AXX0     = "TABPAM";"DESAXX";GLANGUE;[F:TAM]PAM;[F:TAM]LEG
&                 , [TAMS]TAM0   ~=  [F:TAM]PAM;[F:TAM]LEG;[L]LEG
&                 , [TAMY]TAMY0  ~=  [L]GRP;[F:TAM]PAM;[F:TAM]GFY;[F:TAM]LEG
& As [LNC]
 Else
  # Vues via LEG/No FCY, No CPY, No GRP
  Link [F:TAM] With [AXX]AXX0     = "TABPAM";"DESAXX";GLANGUE;[F:TAM]PAM;[F:TAM]LEG
&                 , [TAMS]TAM0   ~=  [F:TAM]PAM;[F:TAM]LEG;[L]LEG
& As [LNC]
 Endif

Else
 If [L]FCY<>""
  # Vues via No LEG but FCY
  Link [F:TAM] With [AXX]AXX0     = "TABPAM";"DESAXX";GLANGUE;[F:TAM]PAM;[F:TAM]LEG
&                 , [FGR]FGR1     =  [L]FCY;[F:TAM]GFY
&                 , [TAMP]TAM0   ~=  [F:TAM]PAM;[F:TAM]LEG
&                 , [TAMG]TAM0    =  [F:TAM]PAM;[F:TAM]LEG;[F:TAM]GFY;[L]CPY
& As [LNC]
 Elsif [L]CPY<>""
  # Vues via No LEG but CPY
  Link [F:TAM] With [AXX]AXX0     = "TABPAM";"DESAXX";GLANGUE;[F:TAM]PAM;[F:TAM]LEG
&                 , [TAMP]TAM0   ~=  [F:TAM]PAM;[F:TAM]LEG
&                 , [TAMG]TAM0    =  [F:TAM]PAM;[F:TAM]LEG;[F:TAM]GFY;[L]CPY
& As [LNC]
 Elsif [L]GRP<>""
  # Vues via No LEG but GRP
  Link [F:TAM] With [AXX]AXX0     = "TABPAM";"DESAXX";GLANGUE;[F:TAM]PAM;[F:TAM]LEG
&                 , [TAMP]TAM0   ~=  [F:TAM]PAM;[F:TAM]LEG
&                 , [TAMZ]TAMZ0  ~=  [L]GRP;[F:TAM]PAM;[F:TAM]GFY;[F:TAM]LEG
& As [LNC]

 Else
  # Vues via No LEG and No FCY/CPY/GRP
  Link [F:TAM] With [AXX]AXX0     = "TABPAM";"DESAXX";GLANGUE;[F:TAM]PAM;[F:TAM]LEG
&                 , [TAMP]TAM0   ~=  [F:TAM]PAM;[F:TAM]LEG
& As [LNC]
 Endif
Endif

Default File [LNC]
DEFPAG = 1

GCURFCY  = SAVE_FCY
GSOCIETE = SAVE_CPY
GCURLEG  = SAVE_LEG
GGRPFCY  = SAVE_GRP
Return

###########################################################################
# $SELTAM2 : selection mode regelement depuis les conditions de paiements
###########################################################################
$SELTAM2
If clalev([F:TAM])=0  : Local File TABPAM     [TAM] : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX] : Endif

Local Char    LEG(GLONADI)

LEG = PARAM(1)
CPY = PARAM(2)

#--------------------------------------------------------------------------------------------------
## Position et taille de la fenêtre
#--------------------------------------------------------------------------------------------------
Gosub OUVRE_LISTE From WOTAM

For I=1 To NBSEL
 If SELEXP(I)<>""
  COL(I) = SELEXP(I)
 Else
  COL(I) = SELZON(I)
 Endif
 TIT(I) = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I

NBCOL  = NBSEL
SIZCOL = 240
SIZLIG = 100
TIT(0) = mess(12,123,1)  # Choix
Call TITOBJ("TAM","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START  = "[F:TAM]PAM"
ORDRE  = "[F:TAM]PAM;[F:TAM]LEG"
OBJET  = ""

#--------------------------------------------------------------------------------------------------
## Critères pour la sélection standard
#--------------------------------------------------------------------------------------------------

## Critères de sélection
## Le link fait des liaisons "externes gauches"
## Toute la subtilité de la chose est de mettre des fonctions qui
## ne sont pas transmises à la base de données : len() , num$()
## sinon celle-ci ne renvoie rien du tout


CRITERE(1)   = "[F:TAM]ENAFLG=2"

CRITERE(1) -= '& [F:TAM]LEG="' + [L]LEG +'"'
CRITERE(1) -= '& [F:TAM]GFY="' + CPY +'"'

If dim(SELCAR)>0 & SELCAR<>0
 CRITERE(1) = 'left$([F:TAM]PAM,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

#--------------------------------------------------------------------------------------------------
## Appel à la vue
#--------------------------------------------------------------------------------------------------
#

 Link [F:TAM] With [AXX]AXX0     = "TABPAM";"DESAXX";GLANGUE;[F:TAM]PAM;[F:TAM]LEG
& As [LNC]

Default File [LNC]
DEFPAG = 1

Return

