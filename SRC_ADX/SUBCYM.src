#<AdxTL>@(#)3.0.0.0 $Revision$
Raz GPILOBJ
Raz GBIDC1, GBIDC2
Call OBJET("CYM",GBIDC1,GBIDC2) From  GOBJET
End

$ACTION
Case GACTION
 When "CYMCPT" : Gosub CYMCPT
 When "CYMGRP" : Gosub CYMGRP
 When "CYMMOD" : Gosub CYMMOD
 When Default
  Case ACTION
   When "OUVRE"        : Gosub OUVRE
   When "LIENS"        : Gosub LIENS
   When "EXEACT"       : Gosub EXEACT
   When "CREATION"     : Gosub CREATION
   When "MODIF"        : Gosub MODIF
   When "APRES_CRE"    : Gosub APRES_CRE
   When "APRES_MOD"    : Gosub APRES_MOD
   When "RAZCRE"       : Gosub RAZCRE
   When "RAZDUP"       : Gosub RAZDUP
   When "INICRE"       : Gosub INICRE
   When "INIMOD"       : Gosub INIMOD
   When "AVANT_MOD"    : Gosub AVANT_MOD
   When "SETBOUT"      : Gosub SETBOUT
   When "AVANTBOUT"    : Gosub AVANTBOUT
   When "STATUT"       : Gosub STATUT
   When "DEGRISE"      : Gosub DEGRISE
   When "STYLE"        : Gosub STYLE
   When "AP_CHANGE"    : Gosub AP_CHANGE
   When "ANNULE"       : Gosub ANNULE
   When "VERIF_CRE"    : Gosub VERIF_CRE
   When "VERIF_MOD"    : Gosub VERIF_MOD
  Endcase
Endcase
Return

$CYMCPT
# Boite de création de section
Case ACTION
 When "DEBUT" : Gosub DEBUT_CYMCPT
Endcase
Return

$CYMGRP
# Boite de création de groupe
Case ACTION
 When "DEBUT" : Gosub DEBUT_CYMGRP
Endcase
Return

$CYMMOD
# Boite de modification de groupe
Case ACTION
 When "DEBUT" : Gosub DEBUT_CYMMOD
Endcase
Return

$OUVRE
If clalev([F:CRY])=0 : Local File GCCEGRUPYM [CRY] : Endif
If clalev([F:CCE])=0 : Local File CACCE      [CCE] : Endif
If clalev([F:DIE])=0 : Local File GDIE       [DIE] : Endif
If clalev([F:ASB])=0 : Local File ABLBSYS    [ASB] : Endif
Local Integer FLMOD
Local Mask CYMCPT [CYMC]
Local Mask CYMGRP [CYMR]
For I=1 To 4
 Call CHARGE_IMAGE(func SUBGYM.DEFIMG(I)) From SUBGYM
Next IMG
Return

$EXEACT
If BOUT="S"
 Gosub RELIT From GOBJSUB
 OK = 0
Endif
Return

$LIENS
Call LECTEXTRA([M]DESTRA,"GCCEPYM","DESTRA",[M]PYM,"") From ATEXTRA
Call LECTEXTRA([M]SHOTRA,"GCCEPYM","SHOTRA",[M]PYM,"") From ATEXTRA
Actzo 30
Diszo DIE
Read [DIE]DIE0 = [F:CYM]DIE
Call CHARGE_PYR([F:CYM]DIE,[F:CYM]PYM)
Return

$VERIF_CRE
$VERIF_MOD
# Group added without section or sub group linked
For ILNK=0 To [M]NBLNK-1
 If [M]SBBGRU(ILNK)<>"" & !find([M]SBBGRU(ILNK),[M]GROUPE(0..[M]NBLNK-1))
  OK = 0
  #Création de ce groupe impossible. Il ne contient aucune section et aucun sous-groupe
  GMESSAGE = [M]SBBGRU(ILNK)-mess(111,103,1)
  Break
 Endif
Next
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Call TEMPON("V") From GESECRAN
Call VALPYR
FLMOD = 1
Call TEMPOFF From GESECRAN
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
If [M]FLMOD
 Call TEMPON("V") From GESECRAN
 Call VALPYR
 FLMOD = 1
 Call TEMPOFF From GESECRAN
Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GCCEPYM","DESTRA",CLECUR1,"","GCCEPYM","DESTRA",[M]PYM,"")  From ATEXTRA
 Call DUPTEXTRA("GCCEPYM","SHOTRA",CLECUR1,"","GCCEPYM","SHOTRA",[M]PYM,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESTRA,"GCCEPYM","DESTRA",[M]PYM,"") From ATEXTRA
Call MAJTEXTRA([M]SHOTRA,"GCCEPYM","SHOTRA",[M]PYM,"") From ATEXTRA
Return

$INICRE
$INIMOD
If dim([F:CYM]DES)>0
 [F:CYM]DES = [M]DESTRA
Endif
Return

$APRES_CRE
Actzo 30

$APRES_MOD
If FLMOD
 Call TEMPON("V") From GESECRAN
 Call PYRAMPRT([M]PYM,[M]DIE,nomap) From LIENPYRCCE
 Call PYRAMLIK([M]PYM,[M]DIE,nomap) From LIENPYRCCE
 Call TEMPOFF From GESECRAN
Endif
Call CHARGE_PYR([F:CYM]DIE,[F:CYM]PYM)
Affzo 30
Return

$RAZCRE
Actzo DIE
Effzo 30
Gosub DEFVAR
[M]NBGRU     = 1
[M]GRU(0)    = mess(115,102,1) : # TOTAL
[M]DES(0)    = mess(116,102,1) : # Groupe racine
[M]SHO(0)    = ""
[M]LEV(0)    = 10
[M]PRNROW(0) = 10
[M]BUDTRK(0) = 1
[M]NBLNK     = 1
[M]GROUPE(0) = [M]GRU(0)
[M]SBBGRU(0) = ""
[M]ACC(0)    = ""
[M]NBCMP     = 1
[M]PARENT(0)   = ""
[M]KEYC(0)     = PFIXG+[M]GRU(0)
[M]LIBSHORT(0) = [M]GRU(0)
[M]LIBL(0)     = [M]DES(0)
[M]IMG(0)      = IMGDEP
Call INIXSL([M]XSL1,"PYRAMIDE") From INTRUTILA
Affzo [M]XSL1
Affzo 30
Return

$RAZDUP
[M]FLMOD = 1
Return

$SETBOUT
CHMEN = ""
Call LECTURE("DIE",[M:CYM]DIE,"") From CONTOBJ
If REP=""
 If instr(1,GUSRAUZ(1),"2") &  ([F:DIE]ENV<>2 & [F:DIE]ENT<>2)
  CHMEN += "2"
 Endif
 If instr(1,GUSRAUZ(1),"3") &  ([F:DIE]ENV<>2 & [F:DIE]ENT<>2)
  CHMEN += "3"
 Endif
 CHMEN += "4"
Endif
Return

$AVANT_MOD
If func AFNC.ACTIV("GDD")
 Call LECTURE("DIE",[M:CYM]DIE,"") From CONTOBJ
 If [F:DIE]ENV=2 | [F:DIE]ENT=2
  OK=0
  If zoncou<>"DEPART"
   # Modification impossible : Pyramide Budgets opérationnels
   Call MESSAGE(mess(9,123,1)-":"-mess(50,103,1)-mess(45,97,1)) From GESECRAN
  Endif
 Endif
Endif
Return

$AVANTBOUT
If BOUT = "3" : # Génération auto
 Filter [CRY] Where PYM=[M]PYM
 Read [CRY]CRY0 First
 Filter [CRY]
 If !fstat
  # Groupes existants  pour cette pyramide
  OK = 2 : Call AVERTIR(mess(97,102,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
Return

$STATUT
Case BOUT
 When "2" : # Duplication
  If GBIDC3<>""
   CLECUR1 = GBIDC3
   Gosub RELIT From GOBJSUB
  Endif
 When "3" : # Génération
  Gosub RELIT From GOBJSUB
Endcase
Return

$DEGRISE
$STYLE
Setmok [CYM] With 0
Return

$ANNULE
Call SUPTEXTRA("GCCEPYM","DESTRA",[M]PYM,"") From ATEXTRA
Call SUPTEXTRA("GCCEPYM","SHOTRA",[M]PYM,"") From ATEXTRA
Return

$AP_CHANGE
#Class[M] à éviter car $AP_CHANGE peut être appelé d'un utilitaire externe ACHANGE
#Call CHGTEXTRA("GCCEPYM","DESTRA",[M]PYM,"",NCODE,"") From ATEXTRA
#Call CHGTEXTRA("GCCEPYM","SHOTRA",[M]PYM,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GCCEPYM","DESTRA",OCODE,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GCCEPYM","SHOTRA",OCODE,"",NCODE,"") From ATEXTRA

#chgmt de cle PYRAMIDE ANA alors MAJ des textes traduisibles pour les groupes section associés à nouvel PYRAMIDE
If clalev([F:CRY])=0 : Local File GCCEGRUPYM [CRY] : Endif
Filter [CRY] Where PYM=NCODE
For [CRY]
 #Call CHGTEXTRA("GCCEGRUPYM","DESTRA",[M]PYM,[F:CRY]GRU,NCODE,[F:CRY]GRU) From ATEXTRA
 #Call CHGTEXTRA("GCCEGRUPYM","SHOTRA",[M]PYM,[F:CRY]GRU,NCODE,[F:CRY]GRU) From ATEXTRA
 Call CHGTEXTRA("GCCEGRUPYM","DESTRA",OCODE,[F:CRY]GRU,NCODE,[F:CRY]GRU) From ATEXTRA
 Call CHGTEXTRA("GCCEGRUPYM","SHOTRA",OCODE,[F:CRY]GRU,NCODE,[F:CRY]GRU) From ATEXTRA
Next
Filter [CRY]


Return

#################################################################################
## Variables diverses
#################################################################################
$DEFVAR
Gosub DEFVAR From SUBGYM
Return

#################################################################################
## Chargement de la pyramide
#################################################################################
Subprog CHARGE_PYR(AXE,PYRAM)
Value Char    AXE
Value Char    PYRAM

Local Integer IGRP , RABG , OKPYR
Local Char    COMPTE(GLONCCE)
Local Char    GRPDEP(GLONCYR)

Gosub DEFVAR

If clalev([F:CRY])=0 : Local File GCCEGRUPYM [CRY] : Endif
If clalev([F:CCE])=0 : Local File CACCE      [CCE] : Endif
Effzo 15-30

OKPYR  = 1
nolign = 0

#
# Chargement de 2 tableaux:
# NBGRU : Liste des groupes et de leurs caractéristiques
# NBLNK : Liste des liens
#
# On force le niveau (LEV) et les rangs (PRNROW) de 10 en 10
#

Filter [CRY] Where PYM=PYRAM Order By Key CLE=LEV;PRNROW;GRU;LIN
[M]NBGRU = 0
[M]NBLNK = 0
NIV = 0
For [CRY]CLE(1)
 RANG = 0
 NIV += 10
 For [CRY]CLE(3)
  RANG += 10
  If [M]NBGRU>=dim([M]GRU)
   OKPYR = 0 : Break 2
  Endif
  [M]NBGRU += 1
  nolign = [M]NBGRU
  [M]GRU(nolign-1) = [F:CRY]GRU
  Call LECTEXTRA([M]DES(nolign-1),"GCCEGRUPYM","DESTRA",PYRAM,[F:CRY]GRU) From ATEXTRA
  Call LECTEXTRA([M]SHO(nolign-1),"GCCEGRUPYM","SHOTRA",PYRAM,[F:CRY]GRU) From ATEXTRA
  [M]LEV(nolign-1)    = NIV
  [M]PRNROW(nolign-1) = RANG
  [M]BUDTRK(nolign-1) = [F:CRY]BUDTRK
  For [CRY]CLE
   If [M]NBLNK>=dim([M]GROUPE)
    OKPYR = 0 : Break 3
   Endif
   [M]NBLNK += 1
   nolign = [M]NBLNK
   [M]GROUPE(nolign-1) = [F:CRY]GRU
   [M]SBBGRU(nolign-1) = [F:CRY]SBBGRU
   [M]ACC(nolign-1)    = [F:CRY]CCE
   GPOINT = "UPDENQCRY" : Gosub ENTREE From EXEFNC
  Next
 Next
Next
Filter [CRY]

#
# Premier groupe
#

If OKPYR
 Filter [CRY] Where PYM=PYRAM Order By Key CLE=LEV;GRU;LIN
 Read [CRY]CLE First
 Filter [CRY]
 If fstat<=2
  GRPDEP = [F:CRY]GRU
 Else
  End
 Endif
 Call CHARGE_GROUPE(GRPDEP)
Else
 Effzo 30
 Grizo DEPART
Endif
End

#################################################################################
## Chargement du groupe de départ
#################################################################################
Subprog CHARGE_GROUPE(GRPDEP)
Value Char GRPDEP

Local Integer IGRP , IGRU , IPAPA , NPAPA
Local Char    PAPA(15)(1..2000)
Local Char    MESSA(250)
Gosub DEFVAR

IGRU = find(GRPDEP,[M]GRU(0..[M]NBGRU-1))
If !IGRU : End : Endif

#
# Partie "visible" de la pyramide : Tableau NBCMP
#

Effzo 30
[M]DEPART = GRPDEP
[M]LIBDEP = [M]DES(IGRU-1)
[M]PARENT(0)   = ""
[M]KEYC(0)     = PFIXG+GRPDEP
[M]LIBSHORT(0) = GRPDEP
[M]LIBL(0)     = [M]DES(IGRU-1)
If IGRU=1
 [M]IMG(0)     = IMGDEP
Else
 [M]IMG(0)     = IMGGRP
Endif

NPAPA   = 1
PAPA(1) = GRPDEP
IPAPA   = 1
nolign  = 1
While IPAPA<=NPAPA
 For IGRP=0 To [M]NBLNK-1
  If [M]GROUPE(IGRP)=PAPA(IPAPA)
   If [M]SBBGRU(IGRP)<>""
    nolign += 1
    [M]PARENT(nolign-1)   = PFIXG+PAPA(IPAPA)
    [M]KEYC(nolign-1)     = PFIXG+[M]SBBGRU(IGRP)
    [M]LIBSHORT(nolign-1) = [M]SBBGRU(IGRP)
    [M]IMG(nolign-1)      = IMGGRP
    [M]LINLNK(nolign-1)   = IGRP
    IGRU = find([M]SBBGRU(IGRP),[M]GRU(0..[M]NBGRU-1))
    If IGRU
     [M]LINGRU(nolign-1) = IGRU-1
     [M]LIBL(nolign-1)   = [M]DES(IGRU-1)
     [M]ROW(nolign-1)    = [M]PRNROW(IGRU-1)
    Endif
    NPAPA += 1
    PAPA(NPAPA) = [M]SBBGRU(IGRP)
   Elsif [M]ACC(IGRP)<>""
    nolign += 1
    [M]PARENT(nolign-1)   = PFIXG+PAPA(IPAPA)
    [M]KEYC(nolign-1)     = PFIXC+func COMPTE([M]ACC(IGRP))
    [M]LIBSHORT(nolign-1) = [M]ACC(IGRP)
    If func JOKER([M]ACC(IGRP))
     [M]IMG(nolign-1)     = IMGJOK
    Else
     [M]IMG(nolign-1)     = IMGCPT
    Endif
    [M]LINLNK(nolign-1)   = IGRP
    [M]LINGRU(nolign-1)   = -1
    [M]ROW(nolign-1)      = 0
    If !func JOKER([M]ACC(IGRP))
     Call LECTEXTRA([M]LIBL(nolign-1),"CACCE","DESTRA",[M]DIE,[M]ACC(IGRP)) From ATEXTRA
    Endif
   Endif
  Endif
 Next IGRP
 IPAPA += 1
Wend
[M]NBCMP = nolign
MESSA = mess(50,103,1)-[M]PYM-":"-[M]DESTRA : # Pyramide
IGRU = find(GRPDEP,[M]GRU(0..[M]NBGRU-1))
If IGRU>1
 MESSA -= "("+mess(96,103,1)-[M]GRU(IGRU-1)-":"-[M]DES(IGRU-1)+")" : # Zoom à partir du groupe
Else
 MESSA -= "("+mess(95,103,1)+")" : # Complète
Endif
Chgtbk 30 With MESSA
Gosub AFFPYR
End

$AFFPYR
Sorta [M]NBCMP [M]NBCMP Order By [M]PARENT(indice),[M]ROW(indice),[M]KEYC(indice)
Affzo
Return

######################################################################################
## Changement de groupe de départ
######################################################################################
Subprog AM_DEPART(VALEUR)
Variable Char    VALEUR()
Local Integer K
If VALEUR=""
 VALEUR = [M]GRU(0)
Endif
K = find(VALEUR,[M]GRU(0..[M]NBGRU-1))
If !K
 GMESSAGE = mess(113,102,1) : # Groupe inexistant
 mkstat = 2 : End
Else
 [M]LIBDEP = [M]DES(K-1)
Endif
Call CHARGE_GROUPE(VALEUR)
End

Subprog AP_DEPART(VALEUR)
Variable Char    VALEUR()
mkstat=4
End

##################################################################
## Traitement des modifications
##################################################################
# MAJHIER est dans SUBGYM
######################################################################################

######################################################################################
## Enregistrement de la pyramide
######################################################################################
Subprog VALPYR
Local Integer ILNK , IGRP , NB
Local Char    SOUGROUPE(GLONCYR) , COMPTE(GLONCCE)
Default Mask [CYM]
Call TEMPON("V") From GESECRAN
Sorta [M]NBLNK [M]NBLNK Order By [M]GROUPE(indice),[M]ACC(indice),[M]SBBGRU(indice)
Gosub MAJPYR
Call TEMPOFF From GESECRAN
End

$MAJPYR
#
# On efface tout et on récréé...
#
Delete [CRY] Where PYM=[M]PYM
If fstat=1
 GOK = -1 : GLOCK = "$GCCEGRUPYM"-[M]PYM : Return
Endif

ILNK = 0
Raz [M]FLGRP
While ILNK<=[M]NBLNK-1
 IGRP = find([M]GROUPE(ILNK),[M]GRU(0..[M]NBGRU-1))-1
 If IGRP<0
  Call ERREUR(mess(114,102,1)-[M]GROUPE(ILNK)) From GESECRAN : # malaise dans la pyramide
  GOK = 0 : Break
 Endif
 NB = 0
 While ILNK<=[M]NBLNK-1 & [M]GROUPE(ILNK)=[M]GRU(IGRP)
  SOUGROUPE = [M]SBBGRU(ILNK)
  COMPTE    = [M]ACC(ILNK)
  If SOUGROUPE<>"" or COMPTE<>""
   [M]FLGRP(IGRP) = 1
   Gosub CRE_GROUPE
   If GOK<1 : Break 2 : Endif
  Endif
  ILNK += 1
 Wend
Wend
If GOK<1 : Return : Endif
# Texte et groupes sans liens
For IGRP=0 To [M]NBGRU-1
 Call MAJTEXTRA([M]DES(IGRP),"GCCEGRUPYM","DESTRA",[M]PYM,[M]GRU(IGRP)) From ATEXTRA
 Call MAJTEXTRA([M]SHO(IGRP),"GCCEGRUPYM","SHOTRA",[M]PYM,[M]GRU(IGRP)) From ATEXTRA
 If ![M]FLGRP(IGRP)
  NB = 0
  SOUGROUPE = ""
  COMPTE    = ""
  Gosub CRE_GROUPE
  If GOK<1 : Break : Endif
 Endif
Next IGRP
Return

$CRE_GROUPE
NB += 1
Raz [F:CRY]
[F:CRY]PYM    = [M]PYM
[F:CRY]GRU    = [M]GRU(IGRP)
[F:CRY]LEV    = [M]LEV(IGRP)
[F:CRY]PRNROW = [M]PRNROW(IGRP)
[F:CRY]BUDTRK = [M]BUDTRK(IGRP)
[F:CRY]LIN    = NB
[F:CRY]SBBGRU = SOUGROUPE
[F:CRY]CCE    = COMPTE
GPOINT = "BEFWRICRY" : Gosub ENTREE From EXEFNC
Write [CRY]
If fstat
 GOK = 0 : Call FSTA("CRY") From GLOCK
Endif
Return

######################################################################################
## Etiquettes gestion pyramide
######################################################################################
Subprog IB_NBCMP
Gosub DEFVAR
If left$([M]KEYC(nolign-1),len(PFIXG))=PFIXC
 Raz GBOUT1,GBOUT2,GBOUT4,GBOUT5
 If func JOKER(ctrans(right$([M]KEYC(nolign-1),len(PFIXG)+1),"xyzw","*?!#"))
  Raz GBOUT6
 Else
  GBOUT6 = mess(179,111,1) : # Sections
 Endif
Else
 GBOUT6 = mess(28,135,1) : # Groupes
Endif
If nolign=1
 Raz GBOUT3
Endif
[M]FLNOL = nolign
End

#
# Ajout d'un groupe
#

$DEBUT_CYMGRP
If [M:CYM]NBGRU>=dim([M:CYM]GRU) or [M:CYM]NBLNK>=dim([M:CYM]GROUPE)
 Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
 SAI = 0 : FIN = 1 : GSTATUT = GSTAFIN
Endif
Return

Subprog B1_NBCMP
If GSTATUT=GSTAOK
 Gosub DEFVAR
 Local Integer NOL , RANG , NIV
 Local Char    GROUPE(GLONCYR)

 RANG = 10
 For NOL=0 To [M]NBCMP-1
  If [M]PARENT(NOL)=[M]KEYC(nolign-1)
   RANG = max(RANG,[M]ROW(NOL)+10)
  Endif
 Next NOL
 NOL = find(right$([M]KEYC(nolign-1),len(PFIXG)+1),[M]GRU(0..[M]NBGRU-1))-1
 NIV = [M]LEV(NOL)+10

 NOL = [M]NBGRU
 [M]NBGRU += 1
 [M]GRU(NOL)    = [M:CYMR]GROUPE
 [M]DES(NOL)    = [M:CYMR]DESTRA
 [M]SHO(NOL)    = [M:CYMR]SHOTRA
 [M]LEV(NOL)    = NIV
 [M]PRNROW(NOL) = RANG
 [M]BUDTRK(NOL) = [M:CYMR]BUDTRK

 NOL = [M]NBCMP
 [M]NBCMP += 1
 [M]PARENT(NOL)   = [M]KEYC(nolign-1)
 [M]KEYC(NOL)     = PFIXG+[M:CYMR]GROUPE
 [M]LIBSHORT(NOL) = [M:CYMR]GROUPE
 [M]IMG(NOL)      = IMGGRP
 [M]ROW(NOL)      = RANG
 [M]LINGRU(NOL)   = [M]NBGRU-1
 [M]LINLNK(NOL)   = [M]NBLNK
 [M]LIBL(NOL)     = [M:CYMR]DESTRA

 NOL = [M]NBLNK
 [M]NBLNK += 1
 [M]GROUPE(NOL) = right$([M]KEYC(nolign-1),len(PFIXG)+1)
 [M]SBBGRU(NOL) = [M:CYMR]GROUPE
 [M]ACC(NOL)    = ""

 Gosub AFFPYR
 [M]FLMOD = 1
 mkstat = 4
Endif
End

#
# Ajout d'un compte
#

$DEBUT_CYMCPT
If [M:CYM]NBLNK>=dim([M:CYM]GROUPE)
 Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
 SAI = 0 : FIN = 1 : GSTATUT = GSTAFIN
Endif
Return

Subprog B2_NBCMP
If GSTATUT=GSTAOK
 Gosub DEFVAR
 Local Integer NOL

 NOL = [M]NBCMP
 [M]NBCMP += 1
 [M]PARENT(NOL)   = [M]KEYC(nolign-1)
 [M]KEYC(NOL)     = PFIXC+func COMPTE([M:CYMC]COMPTE)
 [M]LIBSHORT(NOL) = [M:CYMC]COMPTE
 If func JOKER([M:CYMC]COMPTE)
  [M]IMG(NOL)     = IMGJOK
 Else
  [M]IMG(NOL)     = IMGCPT
 Endif
 [M]ROW(NOL)      = 0
 [M]LINGRU(NOL)   = -1
 [M]LINLNK(NOL)   = [M]NBLNK
 If !func JOKER([M:CYMC]COMPTE)
  Call LECTEXTRA([M]LIBL(NOL),"CACCE","DESTRA",[M]DIE,[M:CYMC]COMPTE) From ATEXTRA
 Endif

 NOL = [M]NBLNK
 [M]NBLNK += 1
 [M]GROUPE(NOL) = right$([M]KEYC(nolign-1),len(PFIXG)+1)
 [M]SBBGRU(NOL) = ""
 [M]ACC(NOL)    = [M:CYMC]COMPTE

 Gosub AFFPYR
 [M]FLMOD = 1
 mkstat = 4
Endif
End

#
# Suppression d'une branche
#

Subprog B3_NBCMP
Gosub DEFVAR
Local Integer IPAPA , NPAPA , IGRU , ILNK
Local Char    PAPA(20)(1..300) , CPTSUP(20)
Local Char    GRPERE(GLONCYR)(1..300)
#
# 1) On vire du tableau d'affichage (en pointant les pères)
#
If left$([M]KEYC(nolign-1),len(PFIXG))=PFIXG
 NPAPA = 1
 PAPA(NPAPA) = [M]KEYC(nolign-1)
Else
 CPTSUP = right$([M]KEYC(nolign-1),len(PFIXG)+1)
Endif
Dela nolign-1,1,[M]NBCMP [M]NBCMP
[M]NBCMP -= 1
IPAPA = 1
While IPAPA<=NPAPA
 I = 0
 While I<=[M]NBCMP-1
  If [M]PARENT(I)=PAPA(IPAPA)
   If left$([M]KEYC(I),len(PFIXG))=PFIXG
    NPAPA += 1
    PAPA(NPAPA) = [M]KEYC(I)
   Endif
   Dela I,1,[M]NBCMP [M]NBCMP
   [M]NBCMP -= 1
  Else
   I += 1
  Endif
 Wend
 IPAPA += 1
Wend
#
# 2) On vire les groupes
#
For IPAPA=1 To NPAPA
 GRPERE(IPAPA) = right$(PAPA(IPAPA),len(PFIXG)+1)
 IGRU = find(GRPERE(IPAPA),[M]GRU(0..[M]NBGRU-1))-1
 If IGRU>=0
  Dela IGRU,1,[M]NBGRU [M]NBGRU
  [M]NBGRU -= 1
  For I=0 To [M]NBCMP-1
   If [M]LINGRU(I)>=IGRU
    [M]LINGRU(I) -= 1
   Endif
  Next I
 Endif
Next IPAPA
#
# 3) On vire les liens obsolètes
#
ILNK = 0
While ILNK<=[M]NBLNK-1
 If find([M]SBBGRU(ILNK),GRPERE(1..NPAPA)) or find([M]GROUPE(ILNK),GRPERE(1..NPAPA))
&   or (CPTSUP<>"" & func COMPTE([M]ACC(ILNK))=CPTSUP)
  Dela ILNK,1,[M]NBLNK [M]NBLNK
  [M]NBLNK -= 1
  For I=0 To [M]NBCMP-1
   If [M]LINLNK(I)>=ILNK
    [M]LINLNK(I) -= 1
   Endif
  Next I
 Else
  ILNK += 1
 Endif
Wend
#
# 4) On réaffiche le tout
#
Gosub AFFPYR
[M]FLMOD = 1
mkstat = 4
End

#
# Modification groupe
#

$DEBUT_CYMMOD : # (Action CYMMOD)
Local Char    GROUPE(GLONCYR)
Local Integer IGRU
Gosub DEFVAR
GROUPE = right$([M:CYM]KEYC([M:CYM]FLNOL-1),len(PFIXG)+1)
IGRU = find(GROUPE,[M:CYM]GRU(0..[M:CYM]NBGRU-1))-1
[M:CYMR]GROUPE = GROUPE
[M:CYMR]DESTRA = [M:CYM]DES(IGRU)
[M:CYMR]SHOTRA = [M:CYM]SHO(IGRU)
[M:CYMR]BUDTRK = [M:CYM]BUDTRK(IGRU)
Grizo GROUPE
Affzo
Return

Subprog B4_NBCMP
If GSTATUT=GSTAOK : # (Le bouton)
 Local Integer I , IGRU
 Gosub DEFVAR
 IGRU = find([M:CYMR]GROUPE,[M]GRU(0..[M]NBGRU-1))-1
 [M:CYM]DES(IGRU)    = [M:CYMR]DESTRA
 [M:CYM]SHO(IGRU)    = [M:CYMR]SHOTRA
 [M:CYM]BUDTRK(IGRU) = [M:CYMR]BUDTRK
 I = find(PFIXG+[M:CYMR]GROUPE,[M]KEYC(0..[M]NBCMP-1))
 If I
  [M]LIBL(I-1) = [M:CYMR]DESTRA
  Affzo LIBL(I-1)
 Endif
Endif
End

#
# Zoom
#

Subprog B5_NBCMP
Gosub DEFVAR
Local Integer ILNK
Local Char    GROUPE(20)
If nolign=1
 ILNK = find(right$([M]KEYC(nolign-1),len(PFIXG)+1),[M]SBBGRU(0..[M]NBLNK))-1
 If ILNK>=0
  GROUPE = [M]GROUPE(ILNK)
 Endif
Else
 GROUPE = right$([M]KEYC(nolign-1),len(PFIXG)+1)
Endif
Call CHARGE_GROUPE(GROUPE)
End

#
# Tunnel
#

Subprog B6_NBCMP
Local Char OBJET(GLONAOB) , CLE1(30) , CLE2(30)
Gosub DEFVAR
If left$([M]KEYC(nolign-1),len(PFIXG))=PFIXC
 OBJET = "CCE"
 CLE1  = right$([M]KEYC(nolign-1),len(PFIXG)+1)
 CLE2  = [M]DIE
Else
 OBJET = "CRY"
 CLE1  = right$([M]KEYC(nolign-1),len(PFIXG)+1)
 CLE2  = [M]PYM
Endif
Call OBJET(OBJET,CLE1,CLE2) From GOBJET
End

######################################################################################
## Ecrans divers
######################################################################################
#
# Contrôle création d'un compte (CYMCPT)
#

Subprog C_COMPTE(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
If find(VALEUR,[M:CYM]ACC(0..[M]NBLNK-1))
 GMESSAGE = VALEUR-":"-mess(101,103,1) : # déjà présent dans la pyramide
 mkstat = 2 : End
Endif
If !func JOKER(VALEUR)
 Read [CCE]CCE0 = [M]DIE;VALEUR
 If fstat
  GMESSAGE = mess(35,106,1) : # Section inexistante
  mkstat = 2 : End
 Endif
Endif
End

#
# Contrôle création d'un groupe (CYMGRP)
#

Subprog AV_GROUPE(VALEUR)
Variable Char VALEUR()
End

Subprog C_GROUPE(VALEUR)
Variable Char VALEUR()
VALEUR = toupper(VALEUR)
If find(VALEUR,[M:CYM]GRU(0..[M:CYM]NBGRU-1))
 GMESSAGE = VALEUR-":"-mess(101,103,1) : # déjà présent dans la pyramide
 mkstat = 2 : End
Endif
End

######################################################################################
## Fonctions
######################################################################################
Funprog COMPTE(CHAINE)
Value Char CHAINE
End ctrans(CHAINE,"*?!#","xyzw")

Funprog JOKER(CHAINE)
Value Char CHAINE
End instr(1,CHAINE,"*") or instr(1,CHAINE,"?") or instr(1,CHAINE,"!") or instr(1,CHAINE,"#")
