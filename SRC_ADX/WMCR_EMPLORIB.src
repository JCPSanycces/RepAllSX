#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank ID statement
# Supervisor
## CRUD-CLASSE ## EMPLORIB
# 2018-11-06 07:06:27 066


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File EMPLORIB [RIB_]

If !SILENCE : Call TRACE("2 --> Local Instance C_EMPLORIB") From ASYRCOM : Endif
Local Instance EMPLORIB Using C_EMPLORIB

If !SILENCE : Call TRACE("3 --> New Instance C_EMPLORIB") From ASYRCOM : Endif
EMPLORIB = NewInstance C_EMPLORIB AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [RIB_]RIB0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of EMPLORIB") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB.AREAD([RIB_]REFNUM,[RIB_]NUMLIG))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("EMPLORIB.REFNUM ="-num$(EMPLORIB.REFNUM)) From ASYRCOM
 Call TRACE("EMPLORIB.NUMLIG ="-num$(EMPLORIB.NUMLIG)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(EMPLORIB.AKEYS)
  Call TRACE("-"-num$(I)-":"-EMPLORIB.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [RIB_]
FreeGroup EMPLORIB
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(EMPLORIB,ACLE,ASTATUS,_ETAG)
Variable Instance EMPLORIB Using C_EMPLORIB
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _REFNUM(15)
Local Shortint _NUMLIG
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_NUMLIG = val([L]CLE(2)) : Endif
Raz [L]_ETAG
Local File EMPLORIB [RIB]
Default File [F:RIB]
Read [F:RIB]RIB0 = [L]_REFNUM;[L]_NUMLIG
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:RIB]UPDTICK)>0
 [L]_ETAG = num$([F:RIB]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(EMPLORIB,ACLE,ASTATUS)
Variable Instance EMPLORIB Using C_EMPLORIB
Value Char ACLE
Variable Integer ASTATUS
Local Char _REFNUM(15)
Local Shortint _NUMLIG
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_NUMLIG = val([L]CLE(2)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB.AREAD([L]_REFNUM,[L]_NUMLIG))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(EMPLORIB,_REFNUM,_NUMLIG,ASTATUS)
Variable Instance EMPLORIB Using C_EMPLORIB
Value Char _REFNUM
Value Shortint _NUMLIG
Variable Integer ASTATUS

If EMPLORIB = null : End : Endif

Gosub AVARIABLES From WMC00EMPLORIB
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If EMPLORIB.APARENT=null
 [L]A_I = EMPLORIB.freeSnapshot
 EMPLORIB.snapshotEnabled = 0
 EMPLORIB.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & EMPLORIB.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If EMPLORIB.APARENT=null
 EMPLORIB.snapshotEnabled = 1
 EMPLORIB.setAccessorEnabled = 1
Endif
LogicClose File [RIB]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB._ACTION_PARAM("AREAD_BEFORE",[L]_REFNUM,[L]_NUMLIG))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:RIB]
Read [F:RIB]RIB0 = [L]_REFNUM;[L]_NUMLIG
If fstat
[L]A_ERROR = [L]_REFNUM+"~"+num$([L]_NUMLIG)
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(EMPLORIB,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:RIB]AUUID)>0 & [F:RIB]AUUID=NullUuid
 [F:RIB]AUUID = getUuid
Endif
SetInstance EMPLORIB With [F:RIB]
EMPLORIB.ASTALIN = [V]CST_ALL

[L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



