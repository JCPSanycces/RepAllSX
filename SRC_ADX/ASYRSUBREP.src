Subprog ASET_AREPLNK(AREPLNK,COD,TYP,FCT,CLA,CMP,REP,NAM,AFF,RET,ANC,DET,EDT,QRY,LOO,SRY)
Variable Instance AREPLNK Using C_AREPLNK
Value Char    COD
Value Integer TYP
Value Char    FCT
Value Char    CLA
Value Integer CMP
Value Char    REP
Value Integer NAM
Value Integer AFF
Value Char    RET
Value Char    ANC
Value Integer DET
Value Integer EDT
Value Integer QRY
Value Integer LOO
Value Integer SRY

AREPLNK.COD = [L]COD
AREPLNK.TYP = [L]TYP
AREPLNK.FCT = [L]FCT
AREPLNK.CLA = [L]CLA
AREPLNK.CMP = [L]CMP
AREPLNK.REP = [L]REP
AREPLNK.NAM = [L]NAM
AREPLNK.AFF = [L]AFF
AREPLNK.RET = [L]RET
AREPLNK.ANC = [L]ANC
AREPLNK.DET = [L]DET
AREPLNK.EDT = [L]EDT
AREPLNK.QRY = [L]QRY
AREPLNK.LOO = [L]LOO
AREPLNK.SRY = [L]SRY
End

#---------------------------------------------------------#
#PAR 10  CODE PARAMÈTRE
#TYP 20  type    M 33
#PROTYP 25  type PROTOTYPE    A       50
#VPR 30  VALEUR    A       250
#PRO 40  ALIAS   AVB
#DES 50  INTITULÉ    ATX
#LNG 60  LONGUEUR    DCB       3.2
#MNL 70  MENU Local    MNL
#AFF 80  SAISIE    M 1     4
#RON 90  LECTURE SEULE   M 1     4
#LOO 100 ALIAS LOOKUP    AVB
Subprog ASET_AREPPAR(AREPPAR,PAR,TYP,VPR,PRO,DES,MNL,LNG,AFF,LOO,FIL,ENT)
Variable Instance AREPPAR Using C_AREPPAR
Value Char    PAR
Value Integer TYP
Value Char    VPR
Value Char    PRO
Value Integer DES
Value Integer MNL
Value Integer LNG
Value Integer AFF
Value Char    LOO
Value Integer FIL
Value Integer ENT
AREPPAR.PAR = [L]PAR
AREPPAR.TYP = [L]TYP
AREPPAR.VPR = [L]VPR
AREPPAR.PRO = [L]PRO
AREPPAR.DES = [L]DES
AREPPAR.MNL = [L]MNL
AREPPAR.LNG = [L]LNG
AREPPAR.AFF = [L]AFF
AREPPAR.LOO = [L]LOO
AREPPAR.FIL = [L]FIL
AREPPAR.ENT = [L]ENT
End


#---------------------------------------------------------#
Subprog ASET_AREPNIV(AREPNIV,REP,ICL,GRI)
Variable Instance AREPNIV Using C_AREPNIV
Value Char    REP
Value Char ICL
Value Char GRI

AREPNIV.REP = [L]REP
AREPNIV.ICL = [L]ICL
AREPNIV.GRI = [L]GRI

End

#---------------------------------------------------------#
Subprog ASET_AREPCOL(AREPCOL,IMN,IMX,ICL,GRI,ONE,DEB,INS,NEW,SRT,DEL,NBR,NAM)
Variable Instance AREPCOL Using C_AREPCOL
Value Integer IMN
Value Integer IMX
Value Char ICL
Value Char GRI
Value Integer ONE
Value Integer DEB
Value Integer INS
Value Integer NEW
Value Integer SRT
Value Integer DEL
Value Integer NBR
Value Integer NAM

AREPCOL.IMN = [L]IMN
AREPCOL.IMX = [L]IMX
AREPCOL.ICL = [L]ICL
AREPCOL.GRI = [L]GRI
AREPCOL.ONE = [L]ONE
AREPCOL.DEB = [L]DEB
AREPCOL.INS = [L]INS
AREPCOL.NEW = [L]NEW
AREPCOL.SRT = [L]SRT
AREPCOL.DEL = [L]DEL
AREPCOL.NBR = [L]NBR
AREPCOL.NAM = [L]NAM

End
