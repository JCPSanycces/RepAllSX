#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
# Traitement STKLPN - Librairie de composants stock de gestion des LPN #
########################################################################

########################################################################
# Actions de type traitement divers (S/P)
#-----------------------------------------------------------------------
# CONTROLLPN    Contrôle de saisie d'un LPN en flux d'entrée
# CONTROLPN2    Contrôle de saisie d'un LPN en flux de sortie/inventaire
#	APMODIFLPN    Après modification d'un LPN en flux d'entrée/inventaire
#
########################################################################

########################################################################
# Sous-programmes
#-----------------------------------------------------------------------
# CALCUL_NBLPN    Calcul du nombre de LPN d'une ligne d'entrée
# CALCUL_NBENTW   Calcul du nombre de LPN et de leurs capacités
#                 d'une ligne d'entrée pour splitter les STOENTW
# ECRLPB          Ecrit dans la table LABELPRN pour les impressions
#                 des étiquettes LPN
#
########################################################################

########################################################################
# CONTROL_LPN   Sous programme de contrôle d'un LPN par rapport à son
#               contenu stocké en base
#               - en saisie ligne de document
#               - en saisie détail stock
#               - ...
########################################################################
# Paramètres E : LLPN     = LPN
#                LCTN     = Contenant
#                LITM     = Article
#                LLOT     = Lot
#                LFCY     = Site stock
#                LWRH     = Dépôt
#                LABR     = Abréviation écran courant
# Paramètres S : mkstat est positionné à 2 si erreur
# Prérequis    : Ces tables doivent être ouvertes
#                - LPN     [LPN]
#                - STOCK   [STO]
########################################################################
Subprog CONTROL_LPN (LLPN, LCTN, LITM, LLOT, LFCY, LWRH, LABR)
Value    Char     LLPN
Value    Char     LCTN
Value    Char     LITM
Value    Char     LLOT
Value    Char     LFCY
Value    Char     LWRH
Value    Char     LABR
Local Char    SMESSAGE(240)
Local Char    CRITERE(100) : Raz CRITERE
Local Char    PAR1, PAR2
Local Char    LLOC(GLONLOC)
Local Char    SYMBOLE(30)
Raz SMESSAGE
If LLPN="" : End : Endif

If !clalev([F:LPN])
  SMESSAGE = mess(11,112,1)-"LPN"
  Goto CTRL_LPN_FIN
Endif
If !clalev([F:STO])
  SMESSAGE = mess(11,112,1)-"STOCK"
  Goto CTRL_LPN_FIN
Endif

Read [LPN]LPN0=LLPN
If fstat
  SMESSAGE = LLPN-":"-mess(243,107,1)-"LPN"
  Goto CTRL_LPN_FIN
Endif

If [F:LPN]ENAFLG<>2
  SMESSAGE = mess(520,184,1)
  PAR1 = LLPN
  Goto CTRL_LPN_FIN
Endif

# Vérification que le LPN n'est pas locké logiquement
SYMBOLE = "LPN"+[F:LPN]LPNNUM
Lock = SYMBOLE
If fstat
  # Modification en cours sur un autre poste
  SMESSAGE=LLPN-":"-mess(10,100,1)
  Goto CTRL_LPN_FIN
Else
  Unlock = SYMBOLE
Endif

If [F:LPN]STOFCY<>LFCY
  SMESSAGE = mess(518,184,1)-LFCY
  PAR1 = LLPN
  Goto CTRL_LPN_FIN
Endif

If (LWRH<>"" & [F:LPN]WRH<>"") & [F:LPN]WRH<>LWRH
  SMESSAGE = mess(519,184,1)-LWRH
  PAR1 = LLPN
  Goto CTRL_LPN_FIN
Endif

If LCTN<>"" & [F:LPN]TCTRNUM<>LCTN
  SMESSAGE = mess(522,184,1)
  PAR1 = LLPN
  PAR2 = LCTN
  Goto CTRL_LPN_FIN
Endif
# dans le cas d'un controle qualité si la transaction n'autorise pas le changement d'emplacement, l'emplacement du LPN
# doit etre identique à l emplacement de la ligne en controle qualité
If find(LABR,"STQ1","SQD","SQC","SMP","SMP1")
   If LABR = "SQC"
      LLOC = [M:SQC]LOC
   Else
      LLOC = [M]LOCDES(nolign-1)
   Endif
   If [F:SRT]CHGEMPCOD <> 2 & [F:LPN]LOC <> "" & [F:LPN]LOC <> LLOC
      SMESSAGE = mess(538,184,1)  # l emplacement du contenant doite etre identique à l emplacement de la ligne en CQ
      Goto CTRL_LPN_FIN
   Endif
Endif

If [F:LPN]MONITMFLG=2
  CRITERE+="ITMREF<>LITM"
Endif
If [F:LPN]MONLOTFLG=2 & !find(LLOT,"","*")
  If CRITERE<>""
    CRITERE+="|"
  Endif
  CRITERE+="LOT<>LLOT"
Endif

If CRITERE<>""
  Filter [STO] Where LPNNUM=LLPN & evalue(CRITERE)
  Read [STO]STO6 First
  If !fstat
    If [F:LPN]MONLOTFLG=2
      SMESSAGE = mess(516,184,1)
    Else
      SMESSAGE = mess(517,184,1)
    Endif
    PAR1 = LLPN
    Filter [STO]
    Goto CTRL_LPN_FIN
  Endif
  Filter [STO]
Endif

#--- Désactivation zone emplacement si LPN avec emplacement
Case LABR
     When "STQ1", "SQD", "SMP", "SMP1" :
          If dim([M]LOCDES)>0
             If [F:LPN]LOC<>""
                Diszo [M]LOCDES(nolign-1),LOCTYPDES(nolign-1)
             Endif
          Endif
     When "SQC":
     When Default      :
          If dim([M]LOC)>0
             If [F:LPN]LOC<>""
                Diszo [M]LOC(nolign-1),LOCTYP(nolign-1)
             Endif
          Endif
Endcase

$CTRL_LPN_FIN
If SMESSAGE<>""
  If PAR1=""
    Call ERREUR(SMESSAGE) From GESECRAN
  Else
    Call ERREUR(func AFNC.MES2(SMESSAGE,PAR1,PAR2)) From GESECRAN
  Endif
  mkstat=2
Endif
End

########################################################################
# CONTROL_LPN_2 Sous programme de contrôle simplifié d'un LPN  par rapport à son
#               contenu stocké en base
#              - pas de blocage si erreur
#                exemples d'utilisation : flux de sortie
#                                         détail inventaire (SNL1)
########################################################################
# Paramètres E : LLPN     = LPN
#                LCTN     = Contenant
#                LITM     = Article
#                LLOT     = Lot
#                LFCY     = Site stock
#                LWRH     = Dépôt
# # Prérequis    : Ces tables doivent être ouvertes
#                - LPN     [LPN]
#                - STOCK   [STO]
########################################################################
Subprog CONTROL_LPN_2 (LLPN, LCTN, LITM, LFCY, LWRH)
Value    Char     LLPN
Value    Char     LCTN
Value    Char     LITM
Value    Char     LFCY
Value    Char     LWRH

Local Char    SMESSAGE(240)
Local Char    PAR1, PAR2
Local Integer  WBLO
Local Integer WOK
Raz WBLO
Raz SMESSAGE
Raz WOK
If LLPN="" : End : Endif
If !clalev([F:LPN])
  SMESSAGE = mess(11,112,1)-"LPN"           # table  non ouverte
  WBLO = 2
  Goto CTRL_LPN_FIN_2
Endif
If !clalev([F:STO])
  SMESSAGE = mess(11,112,1)-"STOCK"          # table non ouverte
  WBLO = 2
  Goto CTRL_LPN_FIN_2
Endif

Read [LPN]LPN0=LLPN
If fstat
  SMESSAGE = LLPN-":"-mess(243,107,1)-"LPN"   # enregistrement inexistant
  Goto CTRL_LPN_FIN_2
  WBLO = 2
Endif

If [F:LPN]ENAFLG<>2
  SMESSAGE = mess(520,184,1)
  PAR1 = LLPN
  WBLO=2
  Goto CTRL_LPN_FIN_2
Endif

If [F:LPN]STOFCY<>LFCY
  SMESSAGE = mess(518,184,1)-LFCY   # le contenant n'est pas sur le site
  PAR1 = LLPN
  WBLO = 2
  Goto CTRL_LPN_FIN_2
Endif
If LWRH<>"" & [F:LPN]WRH<>"" & [F:LPN]WRH<>LWRH
  SMESSAGE = mess(519,184,1)-LWRH   # le contenant n'est pas sur le dépot
  PAR1 = LLPN
  WBLO = 2
  Goto CTRL_LPN_FIN_2
Endif


$CTRL_LPN_FIN_2
If SMESSAGE<>""
   If WBLO = 2
      If PAR1=""
         Call ERREUR(SMESSAGE) From GESECRAN
      Else
         Call ERREUR(func AFNC.MES2(SMESSAGE,PAR1,PAR2)) From GESECRAN
      Endif
      mkstat = 2
   Else
      If PAR1=""
         Call AVERTIR(SMESSAGE,WOK) From GESECRAN
      Else
         Call AVERTIR(func AFNC.MES2(SMESSAGE,PAR1,PAR2),WOK) From GESECRAN
      Endif
      If WOK = 1
         mkstat = 2
      Else
         mkstat = 0
      Endif
   Endif
Endif
End

########################################################################
# AP_MODIF_LPN   Après modification d'un LPN
#               - en saisie ligne de document
#               - en saisie détail stock
#               - ...
########################################################################
# Paramètres E : LLPN    = No contenant
#                LABR    = Abréviation écran courant (contenant LOC)
#                LLIG    = No ligne écran
#                LOLDLPN = Ancien no contennat
# Paramètres S : mkstat est positionné à 2 si erreur
# Prérequis    : Ces tables doivent être ouvertes
#                - LPN     [LPN]
########################################################################
Subprog AP_MODIF_LPN (LLPN, LABR, LLIG,LOLDLPN)
Value    Char     LLPN
Value    Char     LABR
Value    Integer  LLIG
Value    Char     LOLDLPN

Local Char    SMESSAGE(240)
Local Char    WMSKCOU(10)
Local Char    LMABR(10)
Raz SMESSAGE

WMSKCOU=func STKLIB.MSKDEF

If WMSKCOU<>"["+LABR+"]"
  Default Mask "["+LABR+"]"
Endif
LMABR  = "[M:"+LABR+"]"
# Si l'ancien LPN était sur un emplacement identique à celui
# de la ligne écran, effacement de l'emplacement de la ligne
Case LABR
     When "STQ1", "SQD", "SMP", "SMP1","SCS1","SCD" :
          If dim([M]LOCDES)>0
             If LOLDLPN<>"" & [M]LOCDES(LLIG)<>""
                If [F:LPN]LPNNUM<>LOLDLPN
                   Read [LPN]LPN0=LOLDLPN
                Endif
                If [F:LPN]LOC=[M]LOCDES(LLIG)
                   Raz [M]LOCDES(LLIG)
                   If dim([M]LOCTYPDES)> 0
                      Raz [M]LOCTYPDES(LLIG)
                   Endif
                Endif
             Endif
             Actzo [M]LOCDES(LLIG)
             If evalue("dim("+LMABR+"LOCTYP)")>0
                Actzo [M]LOCTYPDES(LLIG)
             Endif
          Endif
     When Default
          If dim([M]LOC)>0
             If LOLDLPN<>"" & [M]LOC(LLIG)<>""
                If [F:LPN]LPNNUM<>LOLDLPN
                   Read [LPN]LPN0=LOLDLPN
                Endif
                If [F:LPN]LOC=[M]LOC(LLIG)
                   Raz [M]LOC(LLIG)
                   If dim([M]LOCTYP)> 0
                      Raz [M]LOCTYP(LLIG)
                   Endif
                Endif
             Endif
             Actzo [M]LOC(LLIG)
             If evalue("dim("+LMABR+"LOCTYP)")>0
                Actzo [M]LOCTYP(LLIG)
             Endif
          Endif
Endcase
If LLPN="" : Goto AP_MODIF_LPN_FIN : Endif

If !clalev([F:LPN])
  SMESSAGE = mess(11,112,1)-"LPN"
  Goto AP_MODIF_LPN_FIN
Endif

If [F:LPN]LPNNUM<>LLPN
  Read [LPN]LPN0=LLPN
  If fstat
    SMESSAGE = LLPN-":"-mess(243,107,1)-"LPN"
    Goto AP_MODIF_LPN_FIN
  Endif
Endif
If dim([M]TCTRNUM)>0
  [M]TCTRNUM(LLIG)=[F:LPN]TCTRNUM
  Affzo [M]TCTRNUM(LLIG)
Endif
Case LABR
     When "STQ1", "SQD", "SMP", "SMP1","SCS1","SCD" :
          If dim([M]LOCDES)>0
             If [F:LPN]LOC<>""
                [M]LOCDES(LLIG)   =[F:LPN]LOC
                Diszo [M]LOCDES(LLIG)
                If evalue("dim("+LMABR+"LOCTYPDES)")>0
                   [M]LOCTYPDES(LLIG)=[F:LPN]LOCTYP
                   Diszo [M]LOCTYPDES(LLIG)
                   Affzo [M]LOCTYPDES(LLIG)
                Endif
             Endif
          Endif
     When Default
          If dim([M]LOC)>0
             If [F:LPN]LOC<>""
                [M]LOC(LLIG)   =[F:LPN]LOC
                Diszo [M]LOC(LLIG)
                If evalue("dim("+LMABR+"LOCTYP)")>0
                   [M]LOCTYP(LLIG)=[F:LPN]LOCTYP
                   Diszo [M]LOCTYP(LLIG)
                   Affzo [M]LOCTYP(LLIG)
                Endif
             Endif
          Endif
Endcase
$AP_MODIF_LPN_FIN
If WMSKCOU<>"["+LABR+"]"
  Default Mask WMSKCOU
Endif
If SMESSAGE<>""
  Call ERREUR(SMESSAGE) From GESECRAN
  mkstat=2
Endif
End

########################################################################
# CALCUL_NBLPN  Calcul du nombre de LPN d'une ligne d'entrée de stock
#               en saisie détail stock
########################################################################
# Paramètres E : LLPN   = LPN
#                LTCTR  = Contenant
#                LITM   = Article
#                LFCY   = Site
#                LPCU   = Unité
#                LQTY   = Quantité
# Paramètres S : LNBLPN = Nombre de LPN
########################################################################
Subprog CALCUL_NBLPN (LLPN,LTCTR,LITM,LFCY,LPCU,LQTY,LNBLPN)
Value    Char    LLPN
Value    Char    LTCTR
Value    Char    LITM
Value    Char    LFCY
Value    Char    LPCU
Value    Decimal LQTY
Variable Integer LNBLPN

Local Integer I

If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif

LNBLPN=0

If LTCTR="" | LQTY=0   : End : Endif
If LLPN<>"" : LNBLPN=1 : End : Endif
If [F:SRU]DACCTR <> 2  : End : Endif

If [F:ITF]ITMREF<>LITM | [F:ITF]STOFCY<>LFCY
  Read [ITF]ITF0=LITM;LFCY
Endif

For I=0 To dim([F:ITF]TCTRNUM)-1
  If LTCTR=[F:ITF]TCTRNUM(I) & LPCU=[F:ITF]PCU(I)
    LNBLPN=int(LQTY/[F:ITF]TCTRPCUCOE(I))
    If mod(LQTY,[F:ITF]TCTRPCUCOE(I))>0
      LNBLPN+=1
    Endif
    Break
  Endif
Next I
End

########################################################################
# CALCUL_NBENTW  Calcul du nombre de LPN et de leur capacité d'une ligne
#                d'entrée de stock en interface de maj stock
########################################################################
# Paramètres E : LTCTR   = Contenant
#                LITM    = Article
#                LFCY    = Site
#                LPCU    = Unité
#                LQTY    = Quantité
# Paramètres S : LNBLPN  = Nombre de LPN
#                LQTYLPN = Quantité par LPN
#                LQTYDER = Quantité dernier LPN (si partiel)
########################################################################
Subprog CALCUL_NBENTW (LTCTR,LITM,LFCY,LPCU,LQTY,LNBLPN,LQTYLPN,LQTYDER)
Value    Char    LTCTR
Value    Char    LITM
Value    Char    LFCY
Value    Char    LPCU
Value    Decimal LQTY
Variable Integer LNBLPN
Variable Decimal LQTYLPN
Variable Decimal LQTYDER

Local Integer I

If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif

LNBLPN  = 0
LQTYLPN = 0
LQTYDER = 0

If LTCTR="" | LQTY=0   : End : Endif

If [F:ITF]ITMREF<>LITM | [F:ITF]STOFCY<>LFCY
  Read [ITF]ITF0=LITM;LFCY
Endif

For I=0 To dim([F:ITF]TCTRNUM)-1
  If LTCTR=[F:ITF]TCTRNUM(I) & LPCU=[F:ITF]PCU(I)
    LNBLPN  = int(LQTY/[F:ITF]TCTRPCUCOE(I))
    LQTYDER = mod(LQTY,[F:ITF]TCTRPCUCOE(I))
    If LNBLPN>0
      LQTYLPN = [F:ITF]TCTRPCUCOE(I)
    Endif
    If LQTYDER>0
      LNBLPN += 1
    Else
      LQTYDER = LQTYLPN
    Endif
    Break
  Endif
Next I
End
########################################################################
#  Ecrit dans la table LABELPRN pour les impressions
#  des étiquettes LPN
########################################################################
Subprog ECRLBP(LRET)
Variable Integer LRET

LRET = 1
[F:LBP]CREDAT = date$
[F:LBP]CREUSR = GUSER
GPOINT = "BEFWRILBP"
Gosub ENTREE From EXEFNC
Write [LBP]
If fstat
   LRET = 0
Endif
End
########################################################################
#  Remplit la table LABELPRN pour les étiquettes LPN
########################################################################
Subprog REMPLBP(LLPNNUM,LNUMREQ,LNUMLIG,LRPTCOD,LDET,LRET)
Value    Char    LLPNNUM
Value    Integer LNUMREQ
Value    Integer LNUMLIG
Value    Char    LRPTCOD
Value    Integer LDET
Variable Integer LRET

Call DEBTRANS From GLOCK
Trbegin [LBP]
If LLPNNUM = AVOID.ACHAR or LRPTCOD = AVOID.ACHAR
   End
Endif

[F:LBP]USR        = GUSER
[F:LBP]NUMREQ     = LNUMREQ
[F:LBP]NUMLIG     = LNUMLIG
[F:LBP]LPNNUM     = LLPNNUM
[F:LBP]RPTCOD     = LRPTCOD
[F:LBP]PCKSTKFLG  = LDET

Call ECRLBP(LRET)

If LRET = 0 : Rollback : Else : Commit : Endif
End

