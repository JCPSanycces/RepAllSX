#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SIPAR3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone SOHTYP
mkstat = 0
zoncou = "SOHTYP"
indice = 0
If varmode([M]SOHTYP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SOHTYP" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTTSO"
 Call CONTTSO([M]SOHTYP,"","","","","","") From SUBTSO
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "SOHTYP" : GZNUM = 32288 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]SOHTYP
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]SOHTYP = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SOHTYP" : GZNUM = 32288 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone SIVTYP
mkstat = 0
zoncou = "SIVTYP"
indice = 0
If varmode([M]SIVTYP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SIVTYP" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTTSV"
 Call CONTTSV([M]SIVTYP,"","","","","","") From SUBTSV
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "SIVTYP" : GZNUM = 15620 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]SIVTYP
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]SIVTYP = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SIVTYP" : GZNUM = 15620 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CNOTYP
mkstat = 0
zoncou = "CNOTYP"
indice = 0
If varmode([M]CNOTYP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CNOTYP" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTTSV"
 Call CONTTSV([M]CNOTYP,"","","","","","") From SUBTSV
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CNOTYP" : GZNUM = 32393 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]CNOTYP
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]CNOTYP = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CNOTYP" : GZNUM = 32393 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_CNOTYP([M]CNOTYP) From SUBSIP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CNOTYP" : GZNUM = 32393 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone CNVTYP
mkstat = 0
zoncou = "CNVTYP"
indice = 0
If varmode([M]CNVTYP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CNVTYP" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTTSV"
 Call CONTTSV([M]CNVTYP,"","","","","","") From SUBTSV
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CNVTYP" : GZNUM = 32394 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]CNVTYP
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]CNVTYP = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CNVTYP" : GZNUM = 32394 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_CNVTYP([M]CNVTYP) From SUBSIP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CNVTYP" : GZNUM = 32394 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBSFI
mkstat = 0
zoncou = "NBSFI"
indice = 0
status = 1
zoncou = "NBSFI"
If varmode([M]NBSFI,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBSFI" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBSFI
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBSFI = nolign
   status = 75
   Call SAI_NBSFI(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone DTAREM
mkstat = 0
zoncou = "DTAREM"
indice = 0
If varmode([M]DTAREM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DTAREM" : Gosub ACTION From =IMPTRT
 Endif
 If [M]DTAREM=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DTAREM" : GZNUM = 2542 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTNUM("SFI","",[M]DTAREM,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "DTAREM" : GZNUM = 2542 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_DTAREM([M]DTAREM) From SUBSIP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DTAREM" : GZNUM = 2542 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone DTAESC
mkstat = 0
zoncou = "DTAESC"
indice = 0
If varmode([M]DTAESC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DTAESC" : Gosub ACTION From =IMPTRT
 Endif
 If [M]DTAESC=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "DTAESC" : GZNUM = 1669 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTNUM("SFI","",[M]DTAESC,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "DTAESC" : GZNUM = 1669 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_DTAESC([M]DTAESC) From SUBSIP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DTAESC" : GZNUM = 1669 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBSFI(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBSFI
mkstat = 0
zoncou = "NBSFI"

## Zone TYP
mkstat = 0
zoncou = "TYP"
IMPENT = [M]TYP(indice)
If varinit([M]TYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]TYP,indice)=0
 [M]TYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYP(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TYP" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]TYP(indice) = IMPENT

## Zone CODART
mkstat = 0
zoncou = "CODART"
If varmode([M]CODART,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODART" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CODART(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CODART" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_CODART([M]CODART(indice)) From SUBSIP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODART" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone SFINUM
mkstat = 0
zoncou = "SFINUM"
If varmode([M]SFINUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SFINUM" : Gosub ACTION From =IMPTRT
 Endif
 If [M]SFINUM(indice)=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "SFINUM" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTNUM("SFI","",[M]SFINUM(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "SFINUM" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_SFINUM([M]SFINUM(indice)) From SUBSIP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "SFINUM" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NBSFI
mkstat = 0
zoncou = "NBSFI"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "SIPAR3"
Return

