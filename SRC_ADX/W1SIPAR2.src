$ON_DISCRGVEN
Onevent CONTROL Call C_DISCRGVEN(zc) From W1SIPAR2
Onevent AFTER_CHANGE Gosub AMM_DISCRGVEN From W1SIPAR2
Onevent BEFORE_INPUT Call AS_DISCRGVEN(zc) From W1SIPAR2
Return

Subprog AS_DISCRGVEN(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_DISCRGVEN(zc) From W1SIPAR2
Gosub _AFF
End

Subprog C_DISCRGVEN(VALEUR)
Variable Decimal VALEUR
## Action STD
Call C_DISCRGVEN(VALEUR) From SUBSIP
If mkstat : GERR = 1 : GZONE = "DISCRGVEN" : GZNUM = 2808 : Endif
Gosub _AFF
End

$AMM_DISCRGVEN
Call AM_DISCRGVEN(zc)
If !mkstat & GOBJET
 zoncou = "DISCRGVEN" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DISCRGVEN(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_DISCRGVEN(VALEUR) From SUBSIP
If mkstat : GERR = 1 : GZONE = "DISCRGVEN" : GZNUM = 2808 : Endif
Gosub _AFF
End

Subprog S_DISCRGVEN(VALEUR)
Variable Decimal VALEUR
If !GWEBSERV
 ## Action SELSIXCOR1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELSIXCOR1"
 PARMSK(1) = num$(nolign)
 Call S_LIS_NUM(VALEUR,PARMSK,"SELSIXCOR1","SIXACTION","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$CHG_STY
Gosub CHG_STY From W2SIPAR2
Return

$TIT_COL
Gosub TIT_COL From W2SIPAR2
