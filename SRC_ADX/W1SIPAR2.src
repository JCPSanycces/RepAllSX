$ON_SPLFINHT1
Onevent BEFORE_AREA Gosub AV_SPLFINHT1 From W1SIPAR2
Return

$AV_SPLFINHT1
Chgfmt [M]SPLFINHT1(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_SPLCRIHT1
Onevent BEFORE_INPUT Call AS_SPLCRIHT1(zc) From W1SIPAR2
Onevent AFTER_CHANGE Gosub AMM_SPLCRIHT1 From W1SIPAR2
Onevent INIT_AREA Call D_SPLCRIHT1(zc) From W1SIPAR2
Onevent CONTROL Call C_SPLCRIHT1(zc) From W1SIPAR2
Return

Subprog D_SPLCRIHT1(VALEUR)
Variable Integer VALEUR
If varinit([M]SPLCRIHT1,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SPLCRIHT1(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(2232) From COMBOS
## Action STD
Call AS_SPLCRIHT1(VALEUR) From SUBSIP
If mkstat=2
 [M]SPLCRIHT1(INDIC) = VALEUR
 Affzo SPLCRIHT1(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,2232,1))))
Endif
If !mkstat
 Discombo 0 From SPLCRIHT1(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From SPLCRIHT1(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_SPLCRIHT1(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$AMM_SPLCRIHT1
Call AM_SPLCRIHT1(zc)
If !mkstat & GOBJET
 zoncou = "SPLCRIHT1" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_SPLCRIHT1(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_SPLCRIHT1(VALEUR) From SUBSIP
If mkstat : GERR = 1 : GZONE = "SPLCRIHT1" : GZNUM = 5935 : Endif
Gosub _AFF
End

