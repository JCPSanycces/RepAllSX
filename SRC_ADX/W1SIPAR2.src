$ON_SPLCRIQAR
Onevent BEFORE_INPUT Call AS_SPLCRIQAR(zc) From W1SIPAR2
Onevent INIT_AREA Call D_SPLCRIQAR(zc) From W1SIPAR2
Onevent CONTROL Call C_SPLCRIQAR(zc) From W1SIPAR2
Return

Subprog D_SPLCRIQAR(VALEUR)
Variable Integer VALEUR
If varinit([M]SPLCRIQAR,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SPLCRIQAR(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(2232) From COMBOS
## Action STD
Call AS_SPLCRIQAR(VALEUR) From SUBSIP
If mkstat=2
 [M]SPLCRIQAR(INDIC) = VALEUR
 Affzo SPLCRIQAR(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,2232,1))))
Endif
If !mkstat
 Discombo 0 From SPLCRIQAR(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From SPLCRIQAR(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_SPLCRIQAR(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

