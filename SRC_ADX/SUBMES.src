######################################################################################
## Etiquette ajoutée par le superviseur (Objet MES) 19/02/2009 16:33:32 (VPO)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE : #entrée en Interactif
 When Default
Endcase
Return


######################################################################################
$OUVRE
If clalev ([F:AOE]) = 0 : Local File AOBJEXT[AOE] : Endif
 If dim(GSCSAUZSST)<=0
        Global Char    GSCSAUZSST(50)  #50 par sécurité
 Endif
 GSCSAUZSST = "A*,Q*"
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran MES1) 20/02/2009 15:34:37 (VPO)
######################################################################################
Subprog C_TMATPL(VALEUR)
Variable Char    VALEUR()
Call CONTROLE("AOE","",VALEUR,"",mkstat) From CONTOBJ
If mkstat : End : Endif
Call CONTEXE([F:AOE]ACS) From SUBACS
If mkstat : End : Endif
If [F:AOE]EXPORT<>2
 GMESSAGE = mess(110,141,1) : # Export impossible sur ce modèle
 mkstat = 1 : End
Endif
End

