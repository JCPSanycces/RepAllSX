#<AdxTL>@(#)0.0.0.0 $Revision$
#--------------------------------------------------------------------------
#                       Budgets Opérationnels
#--------------------------------------------------------------------------
#   Action   : DETAPPMUL - Détail approbation
#   Fenêtre  : DETAPPMUL
#   Ecran concerné : DETAPPMUL
#   Description : Dans le cas d'une approbation multiple, offre dans un 
#                 tableau la liste les objets concerné par la demande
#                 
#--------------------------------------------------------------------------

$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When "DEBUT" : Gosub DEBUT
Endcase
Return

$OUVRE
If !clalev([BOA]) : Local File BUDAPP    [BOA] : Endif
If !clalev([BAD]) : Local File BUDAPPDET [BAD] : Endif
If !clalev([ENV]) : Local File ENVELOPPE [ENV] : Endif
If !clalev([ENF]) : Local File ENVFIY    [ENF] : Endif
If !clalev([BUD]) : Local File BUD       [BUD] : Endif
Local Mask DETAPPMUL [DAM]
Return

$DEBUT
If PARAM(1)<>""
 Gosub CHARGE_TAB
Else
 FIN=1
Endif
Return

$CHARGE_TAB
Read [BOA]BOA0 = PARAM(1)
If !fstat
 Filter [BAD] Where NUMAPP=[F:BOA]NUM
 I=0
 For [BAD]BAD0
  [M:DAM]TYP(I)    = [F:BAD]TYP
  [M:DAM]ENV(I)    = [F:BAD]ENV
  [M:DAM]FIY(I)    = [F:BAD]FIY
  [M:DAM]ACC(I)    = [F:BAD]ACC
  [M:DAM]CUR(I)    = [F:BAD]CUR
  [M:DAM]AMT(I)    = [F:BAD]AMT
  I+=1
 Next
 Filter [BAD]
 [M:DAM]NBLIG=I
 Affzo [M:DAM]
 Gosub COLORIZE
Endif
Return

$COLORIZE
For I=0 To [M]NBLIG-1
 Chgstl [M]NBLIG(I) With "GDD"+num$([M]TYP(I))
Next
Affzo [M]
Return

