#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################
#   vérification du dico des actions sur les sources
# - présence dans le dico des actions
# - subprog avec du code ou non
#
#  le traitement est complémentaire de VERIFAUTRE
#
######################################################

Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
    Call TRAITE_CHAR(VALBOUT,PARBOUT, "", "AVERIFSRC", "AVERIFSRC", 3, "") From GTRAITE
End
#------------------------------------------------------------------------------------------------------------------------#


Subprog AVERIFDAC (CHEMINTRA, PATCH, CHEMINSRC, PNOMTRT, DOSSIER, PMODULE, OWNER, EXCLSUP,
&                 PORT, MACHINE, CHEMINTRAW, NBERRTOT, NBWARTOT, PNUMERREUR, PDEMANDEUR, PLIBVERIF)


Value Char CHEMINTRA    :  # Chemin où seront créés les fichiers de trace
Value Char PATCH        :  # Si patch, on ne vérifie que les traitement modifiés
Value Char CHEMINSRC     :  # Si patch, chemin où sont les sources patchés
Value Char PNOMTRT       :  # Nom du masque à analyser (jokers autorisés) correspond à NOMTRT
Value Char DOSSIER      :  # Si non patch, dossier analysé

Value Integer PMODULE   :  # Si travail sur sources d'un module particulier
Value Integer OWNER     :  # Si on veut travailler sur les sources d'un owner particulier
Value Integer EXCLSUP   :  # exclure le module superviseur
Value Integer PORT      :  # port du dossier
Value Char MACHINE      :  # machine du dossier
Value Char CHEMINTRAW
Variable Integer NBERRTOT, NBWARTOT
Value Integer PNUMERREUR
Value Integer PDEMANDEUR : # niveau indus, dev, distri, spe...
Value Char PLIBVERIF


Local Char ZADXIFS, ZADXIRS, WTEXTE(100)


Local Char DOSSIER2(100)
Local Integer WBOK, WNBMSQ, NBTRAITES, NBERREUR, NBWARNING, NBMSPE, IP
Local Shortint SAUVEMODULE

Local Char WNOMTRT(GLONADC), WTMSQ(20)(50), WTABR(6)(50), WTACTION(10)(50), CLE(100), TXTPROG(10), WSAVTXTPROG(10)
Local Integer WNBACTION, INDERREUR, TERREUR(50)
Local Char WACTION(10), TXTERR2(80)


ZADXIFS=adxifs
ZADXIRS=adxirs
adxifs=chr$(0)
adxirs=chr$(10)

PNUMERREUR = mod(PNUMERREUR, 100)

If MACHINE = ""
    DOSSIER2 = DOSSIER
Else
    DOSSIER2 = MACHINE + ":" + num$(PORT) + "@" + DOSSIER
Endif

If clalev ([F:AMK])
    Close File [AMK]
Endif
If clalev ([F:AMA])
    Close File [AMA]
Endif

If clalev ([F:AMZ])
    Close File [AMZ]
Endif
If clalev ([F:AST])
    Close File [AST]
Endif
If clalev ([F:ADC])
    Close File [ADC]
Endif


Local File = DOSSIER2 + ".AMSK"    [AMK]
Local File = DOSSIER2 + ".AMSKACT" [AMA]
Local File = DOSSIER2 + ".AMSKZON" [AMZ]
Local File = DOSSIER2 + ".APLSTD"  [AST]

Local File = DOSSIER2 + ".ADICTRT" [ADC]   : # table des traitements


Call TEMPON("Vérifications des" - PLIBVERIF - num$(nbrecord([AMK])) - "Masques") From GESECRAN
Call CHGACT(WNBACTION, WTACTION)


#----------------#
#Fichier de trace
#----------------#
#CBO Openo CHEMINTRA, -1
#CBO Call ECRDEBUT()


Openo CHEMINTRAW, -1
Call ECRDEBUT(PLIBVERIF)

Openo
Openo CHEMINTRAW, -1 Using [FWR]
#Openo CHEMINTRA, -1


# ----------------------------------------------------------------------------------------
    WNBMSQ = 0
    SAUVEMODULE = -1
    Raz INDERREUR, TERREUR

        
    WACTION = "STD"
    If PMODULE
        Filter [AMK] Where TRTSTD <> "" and CODMSK < "X" and MODULE = PMODULE Order By Key CLE=TRTSTD;CODMSK
    Else
        Filter [AMK] Where TRTSTD <> "" and CODMSK < "X" Order By Key CLE=TRTSTD;CODMSK
    Endif
    Gosub BOUCLEMSK

    If PDEMANDEUR >= 10
        WACTION = "SPV"
        If PMODULE
            Filter [AMK] Where TRTSPV <> "" and CODMSK < "Z" and MODULE = PMODULE Order By Key CLE=TRTSPE;CODMSK
        Else
            Filter [AMK] Where TRTSPV <> "" and CODMSK < "Z" Order By Key CLE=TRTSPE;CODMSK
        Endif
        Gosub BOUCLEMSK
    Endif

    If PDEMANDEUR = 15
        WACTION = "SPE"
        If PMODULE
            Filter [AMK] Where TRTSPE <> "" and MODULE = PMODULE Order By Key CLE=TRTSPE;CODMSK
        Else
            Filter [AMK] Where TRTSPE <> "" Order By Key CLE=TRTSPE;CODMSK
        Endif
        Gosub BOUCLEMSK
    Endif


# ----------------------------------------------------------------------------------------

    Goto FINFIN

# ----------------------------------------------------------------------------------------
    



$BOUCLEMSK


    Wrseq "Traitement du" - WACTION - " _____________________________________________________________"
&                 Using [FWR]
    Wrseq "" Using [FWR]


    For [AMK]CLE(1)

        If WACTION = "STD"
            WNOMTRT = [AMK]TRTSTD
        Elsif WACTION = "SPV"
            WNOMTRT = [AMK]TRTSPV
        Elsif WACTION = "SPE"
            WNOMTRT = [AMK]TRTSPE
        Endif
        
        NBMSPE = 0
        Raz WTMSQ, WTABR
        # Traitement à controler ?
###        Call TRTACTLER(WNOMTRT, DOSSIER2, WBOK, CHEMINSRC, PATCH, OWNER, PMODULE, EXCLSUP, PNOMTRT, WACTION)

        If func AVERIFSRC.SRCAPASTRAITER (WNOMTRT, PNOMTRT, DOSSIER2, PMODULE, EXCLSUP, PATCH,
&               CHEMINSRC, OWNER, TXTERR2, PDEMANDEUR) = 0

            For [AMK]CLE
                NBMSPE += 1
                WNBMSQ +=1
                If NBMSPE < 50
                    WTMSQ(NBMSPE) = [AMK]CODMSK           
                    WTABR(NBMSPE) = [AMK]ABRMSK
                Else
#Infbox num$(NBMSPE) - [AMK]ABRMSK - [AMK]CODMSK
#NBMSPE =NBMSPEELSE
                Endif
            Next  
            If NBMSPE >= 50
                NBMSPE = 49
            Endif

            Call ANALYSE(WNOMTRT, SAUVEMODULE, NBTRAITES, WNBMSQ,
&                NBERREUR, NBWARNING, PATCH, DOSSIER2, WTACTION, WNBACTION, WTMSQ, WTABR, NBMSPE, TERREUR,
&                PNUMERREUR, PMODULE, PNOMTRT, CHEMINSRC, PDEMANDEUR, EXCLSUP, OWNER, WACTION)
        Endif
        
        If WNBMSQ > 50000
            Break
        Endif

    Next
    Filter [AMK]

Return

# ----------------------------------------------------------------------------------------

$FINFIN


    Wrseq Using [FWR]
    Wrseq Using [FWR]
    Wrseq num$(NBWARNING) - "anomalies sur" - num$(WNBMSQ) - "masques et" - num$(NBTRAITES) - "sources contrôlés." Using [FWR]
    Wrseq Using [FWR]

    For INDERREUR = 1 To GNBERREUR(GNUMMOUL)
    
        WTEXTE = "Ano" - num$(INDERREUR + 300) + " Nombre :" - num$(TERREUR(INDERREUR))
        
        IP = len(WTEXTE)
        IP = 40 - IP

        If IP > 0
            WTEXTE = WTEXTE + string$(IP, " ")
        Else
            WTEXTE = WTEXTE
        Endif
        Wrseq WTEXTE + GTLIBERREUR(GNUMMOUL, INDERREUR) Using [FWR]
    
    Next INDERREUR
    Wrseq Using [FWR]
    Wrseq "Fin de vérifications des" - PLIBVERIF + "." - time$ Using [FWR]

    
    adxifs=ZADXIFS : adxirs=ZADXIRS
    Openo Using [FWR]

    NBERRTOT += NBERREUR
    NBWARTOT += NBWARNING

    Call TEMPOFF From GESECRAN


    Close File [AMK]
    Close File [AMA]
    Close File [AMZ]
    Close File [AST]
    Close File [ADC]

End

Subprog ECRDEBUT(PLIBVERIF)
Value Char PLIBVERIF

Wrseq
Wrseq
Wrseq
Wrseq "-------------------------### Vérification des" - PLIBVERIF + ". ###---------------------------"
Wrseq
Wrseq


Wrseq "Traitement des masques :" - time$
Wrseq ""

End


#------------------------------------------------------------------------------------------------------------------------#

Subprog ANALYSE(WNOMTRT, SAUVEMODULE, NBTRAITES, WNBMSQ,
&       NBERREUR, NBWARNING, PATCH, DOSSIER2, WTACTION, WNBACTION, WTMSQ, WTABR, NBMSPE, TERREUR,
&       PNUMERREUR, PMODULE, PNOMTRT, PCHEMINSRC, PDEMANDEUR, PEXCLSUP, POWNER, PACTION)
Value Char WNOMTRT
Value Shortint SAUVEMODULE
Variable Integer NBTRAITES, WNBMSQ, NBERREUR, NBWARNING
Value Char PATCH, DOSSIER2
Variable Char WTACTION()
Value Integer WNBACTION
Variable Char WTMSQ(), WTABR()
Value Integer NBMSPE
Variable Integer TERREUR()
Value Integer PNUMERREUR, PMODULE
Value Char PNOMTRT, PCHEMINSRC
Value Integer PDEMANDEUR, PEXCLSUP, POWNER
Value Char PACTION


Local Integer MAX_LGSSPRO, WMIGRATE
MAX_LGSSPRO = 50

Local Clbfile CHAINE(3), CHAINE1(3), CHAININS(3), CHAINELEC(3), CHBOUCLE
Local Integer FST, WFINTRV, WCODETRVE, WBFUNP, IP, IP2, NLIG, WIGNWRSEQ, WIGNWRTRT
Local Integer TITAECRIRE, TITAECRIREW, BWARNING
Local Char WNOMSUB(MAX_LGSSPRO), WSAVSUB(MAX_LGSSPRO), WFILE(10), WABREV(10), TXTERR2(130), WTITRE(150), WTITRE2(150)
Local Char TXTPROG(5), WSAVTXTPROG(5)
Local Integer INDERREUR, BCHAINELEC, NSK, NSKL, WBACTION, WFINSUBPROG


    Read [ADC]ADC0 = WNOMTRT
    WTITRE = "Source/Masque(s)" - WNOMTRT + ".src (" + [F:ADC]DES + ")" 
    For IP = 1 To NBMSPE
        WTITRE = WTITRE - WTMSQ(IP) + "[" + WTABR(IP) + "]"
    Next
    WTITRE  = WTITRE + ")   "
    
    If PMODULE = 0
        WTITRE2 = "   (module" - num$([F:ADC]MODULE) - "(" - func AVERIFSRC.LIBMODULE ([F:ADC]MODULE, SAUVEMODULE) - ")"
        IP = len(WTITRE) + len(WTITRE2)
        IP = 150 - IP
        
        If IP > 0
            WTITRE = WTITRE + string$(IP, "_") + WTITRE2
        Else
            WTITRE = WTITRE - WTITRE2
        Endif
    Endif

    TITAECRIRE  = 1
    TITAECRIREW = 1

#-------------------#
#On traite le source
#-------------------#



    NBTRAITES += 1
    If mod(NBTRAITES, 100) = 0
        If PNUMERREUR
            Call TEMPON("VERIFDAC" - PACTION - "(" - num$(WNBMSQ) - [AMK]CODMSK + ") (" - num$(NBTRAITES) - WNOMTRT + 
&               ") module" - num$(PMODULE))     From GESECRAN
        Else
            Call TEMPON("VERIFDAC" - PACTION - "(" - num$(WNBMSQ) - [AMK]CODMSK + ") (" - num$(NBTRAITES) - WNOMTRT + 
&               ") Ano" - num$(NBWARNING))     From GESECRAN
        Endif
    Endif

    If func AVERIFSRC.SRCAPASTRAITER (WNOMTRT, PNOMTRT, DOSSIER2, PMODULE, PEXCLSUP, PATCH, PCHEMINSRC,
&    POWNER, TXTERR2, PDEMANDEUR)
        End
    Endif

    If PATCH=""
        Openi filpath("TRT", WNOMTRT, "src", DOSSIER2), 0
    Else
        If filinfo(PCHEMINSRC + "/" + WNOMTRT + ".src", 0) <= 0
            End
        Endif
        Openi PCHEMINSRC + "/" + WNOMTRT + ".src", 0
    Endif


    FST = 0
    NLIG = -1
    BWARNING = 0

    WFINSUBPROG = 1
    WFINTRV = 0       # on a trouvé RETURN ou END mais il faut voir si on n'est pas dans un test
                      # si instruction suivante contient Subprog ou Funprog : cela en est bien 1
    WSAVSUB = ""

    WCODETRVE = 0

    CHAINELEC = ""
    BCHAINELEC = 0
    WBACTION = 0
    WMIGRATE = 0
    
    While FST=0
        Call LIREETFMT(CHAINE, CHAINELEC, BCHAINELEC, FST, NLIG, NSK, NSKL) From AVERIFSRC
        Call VIRECOMCHK (CHAINE, 1, 0, WFILE, WABREV, WIGNWRSEQ, WIGNWRTRT, WMIGRATE) From AVERIFSRC
        # CBO 20110124 FQ70150
        If WIGNWRTRT >= 20 and WIGNWRTRT < 30
            WIGNWRTRT -= 20
        Elsif WIGNWRTRT >= 30 and WIGNWRTRT < 40
            WIGNWRTRT -= 30
        Endif

        If WIGNWRTRT = 1 or WIGNWRTRT = 3
            End
        Endif
        
        CHAININS = CHAINE
        CHAINE = func AVERIFSRC.DECOUPCH (CHAININS, WIGNWRSEQ)
        CHAINE = vireblc(CHAINE, 2)
        While CHAINE <> ""  

            WBFUNP = 0
            IP = instr(1, CHAINE, "Subprog")
            If IP = 0
                IP = instr(1, CHAINE, "Funprog")
                If IP
                    WBFUNP = 1
                    TXTPROG = "Funprog"
                Endif
            Else
                TXTPROG = "Subprog"
            Endif

            # vérifie que pas dans une chaine genre Wrseq "Subprog toto(x)"
            If func AVERIFSRC.DANSQUOTE (CHAINE, IP)
                IP = 0
            Endif


            # On commence un nouveau Subprog (ou funprog)
            If IP
           
                WSAVSUB = WNOMSUB
                WSAVTXTPROG = TXTPROG
                WNOMSUB = right$(CHAINE, IP + 7)

                IP2 = instr(1, WNOMSUB, "(")
                If IP2
                    WNOMSUB = left$(WNOMSUB, IP2 - 1)
                Endif
                WNOMSUB = vireblc(WNOMSUB, 4)
                If WSAVSUB <> ""

                    # on n'a pas fini le précédent subprog (qui est 1 action)
                    If WFINTRV = 0 and WBACTION
                        TXTERR2 = "Début du" - TXTPROG - WNOMSUB - "alors que" - WSAVSUB - "n'est pas fini"
                        Call ECRERREUR(1, WTITRE, TXTERR2,
&                         TITAECRIRE, TITAECRIREW, "", NBERREUR, NBWARNING, NLIG, TERREUR, PNUMERREUR, CHBOUCLE, PATCH)
                    Endif
                    # le précédent (qui est 1 action) n'a pas de code
                    If WCODETRVE = 0 and WBACTION
                        TXTERR2 = "Le" - WSAVTXTPROG - WSAVSUB - "ne contient aucun code"
                        Call ECRERREUR(2, WTITRE, TXTERR2,
&                         TITAECRIRE, TITAECRIREW, "", NBERREUR, NBWARNING, NLIG, TERREUR, PNUMERREUR, CHBOUCLE, PATCH)
                    Endif
                Endif
            
                WFINTRV = 0
                WCODETRVE = 0

                # contrôle par rapport au dictionnaire des actions
                If WBFUNP
                    WBACTION = 0
                Else
                    Call TRTACTION(TXTPROG, WNOMSUB, WTACTION, WNBACTION, TXTERR2, WTMSQ, WTABR, NBMSPE, INDERREUR, WBACTION)
                    If TXTERR2 <> "" and WBACTION
                        Call ECRERREUR(INDERREUR, WTITRE, TXTERR2,
&                         TITAECRIRE, TITAECRIREW, CHAINE, NBERREUR, NBWARNING, NLIG, TERREUR, PNUMERREUR, CHBOUCLE, PATCH)
                    Endif
                Endif
            Else
                #on recherche si fin de subprog
                IP = instr(1, CHAINE, "End")
                If IP
                    IP2 = instr(1, CHAINE, "Endif")
                    If IP2 = IP
                        IP = 0
                    Else
                        IP2 = instr(1, CHAINE, "Endcase")
                        If IP2 = IP
                            IP = 0
                        Else                
                            If func AVERIFSRC.DANSQUOTE (CHAINE, IP)
                                IP = 0
#                            Else
#                                NLIGENDRT = NLIG
                            Endif
                        Endif
                    Endif
                Endif
                
                
                If IP
                    WFINTRV = 1
                Else
                    If pat(CHAINE, "Variable*") or pat(CHAINE, "Value*")
                        IP = IP
                    Elsif WFINTRV and left$(CHAINE, 1) = "$"
                    # si l'instruction précédente est un End et que l'on a $etiquette...
                    # c'est qu'on quitte un Subprog et on attaque 1 étiquette (Gosub)

                        # le subprog n'a pas de code
                        If WCODETRVE = 0 and WNOMSUB <> "" and WBACTION

                            TXTERR2 = "Le" - TXTPROG - WNOMSUB - "ne contient aucun code"
                            Call ECRERREUR(2, WTITRE, TXTERR2,
&                             TITAECRIRE, TITAECRIREW, "", NBERREUR, NBWARNING, NLIG, TERREUR, PNUMERREUR, CHBOUCLE, PATCH)
                        Endif

                        WNOMSUB = ""
                        WSAVSUB = ""
 
                        WFINTRV = 0
                        WCODETRVE = 0
                    Elsif left$(CHAINE, 1) = "&"
                        # on ne devrait jamais passer ici
                        IP = 0
                    Else
                            
                        # 1 instruction différente : c'est du code !!!
                        WFINTRV = 0
                        WCODETRVE = 1
                    Endif
                Endif
                #
            Endif

            CHAINE = func AVERIFSRC.DECOUPCH (CHAININS, WIGNWRSEQ)
            CHAINE = vireblc(CHAINE, 2)
        Wend
    Wend

    # traitement du dernier Subprog
    If WNOMSUB <> "" and WBACTION
        # on n'a pas fini le subprog
        If WFINTRV = 0
            TXTERR2 = "Fin du source et le" - TXTPROG - WNOMSUB - "n'est pas fini"
            Call ECRERREUR(1, WTITRE, TXTERR2,
&             TITAECRIRE, TITAECRIREW, "", NBERREUR, NBWARNING, NLIG, TERREUR, PNUMERREUR, CHBOUCLE, PATCH)
        Endif
                
        # le subprog n'a pas de code
        If WCODETRVE = 0
            TXTERR2 = "Le" - TXTPROG - WNOMSUB - "ne contient aucun code"
            Call ECRERREUR(2, WTITRE, TXTERR2,
&             TITAECRIRE, TITAECRIREW, "", NBERREUR, NBWARNING, NLIG, TERREUR, PNUMERREUR, CHBOUCLE, PATCH)
        Endif
    Endif

    Openi
End


#------------------------------------------------------------------------------------------------------------------------#
# vérifie si à un C_CHP, correspond bien une action dans un des masques concerné.
Subprog TRTACTION(TXTPROG,WNOMSUB, WTACTION, WNBACTION, TXTERR2, WTMSQ, WTABR, NBMSPE, INDERR, WBACTION)
Variable Char TXTPROG
Variable Char WNOMSUB
Variable Char WTACTION()
Variable Integer WNBACTION
Variable Char TXTERR2, WTMSQ(), WTABR()
Variable Integer NBMSPE, INDERR, WBACTION


Local Integer IP, INDACT, J, WCHAMPTROUVE, WACTIONTROUVEE
Local Char NOMACTION(10), NOMCHAMP(10), MSQDUCHP(250)

    WBACTION = 0
    IP = instr(1, WNOMSUB, "_")
    If IP = 0
        End
    Endif

    INDERR  = 0
    TXTERR2 = ""
    NOMACTION = left$(WNOMSUB, IP - 1)
    NOMCHAMP  = right$(WNOMSUB, IP + 1)
    MSQDUCHP = ""

    If NOMACTION = ""
        End
    Endif
    
    INDACT = find(NOMACTION, WTACTION(1..WNBACTION))
    If INDACT = 0
        End
    Endif


    WBACTION = 1
    WCHAMPTROUVE = 0
    WACTIONTROUVEE = 0

    For J = 1 To NBMSPE
        Read [AMZ]CODE = WTMSQ(J); NOMCHAMP
        If fstat = 0
            WCHAMPTROUVE = 1
            
            If MSQDUCHP = ""
                MSQDUCHP = WTMSQ(J)
            Else
                MSQDUCHP = MSQDUCHP - "/" - WTMSQ(J)
            Endif
        
            Read [AMA]NOACT(3) = WTMSQ(J); NOMCHAMP; INDACT
            If fstat = 0
                WACTIONTROUVEE = 1


                # champ en affichage : on ne peut le : contrôler, après zone, après modif
                If [AMZ]SAIAFF = 2
                    If NOMACTION = "C" or NOMACTION = "AP" or NOMACTION = "AM"
                        If INDERR = 0
                            INDERR = 5
                            TXTERR2 = "Le" - TXTPROG - WNOMSUB - "correspond au champ" - NOMCHAMP - "qui est en affichage."
                            TXTERR2 = TXTERR2 - "C'est une action non éxécutée."
                        Endif
                    Else
                        INDERR = 0
                    Endif
                # champ invisible : on ne peut (doit) que l'initialiser
                Elsif [AMZ]SAIAFF = 3
                    If NOMACTION <> "D" and NOMACTION <> "AV"
                    # on sortira la première erreur (si on ne trouve pas un cas Ok)
                        If INDERR = 0
                            INDERR = 4
                            TXTERR2 = "Le" - TXTPROG - WNOMSUB - "correspond au champ" - NOMCHAMP - "qui est invisible."
                            TXTERR2 = TXTERR2 - "C'est une action non éxécutée."
                        Endif
                    Else
                        INDERR = 0
                    Endif
                Else
                    INDERR = 0
                Endif
                
                # au moins (ou déjà) 1 action sur champ trouvée et Ok : c'est Ok même si il y a des non Ok
                If INDERR = 0
                    TXTERR2 = ""
                    Break
                Endif
            Endif
        Endif
    Next J


    If WCHAMPTROUVE = 0
        INDERR = 3
        TXTERR2 = TXTPROG - WNOMSUB - ": aucune action correspondante trouvée."
        TXTERR2 = TXTERR2 - "(aucun couple masque/champ trouvé)"
    Elsif WACTIONTROUVEE = 0
        INDERR = 3
        TXTERR2 = TXTPROG - WNOMSUB - ": aucune action correspondante trouvée."
        TXTERR2 = TXTERR2 - "(Champ du masque(s)" - MSQDUCHP + ")"
    Endif

End

Subprog CHGACT(WNBACTION, WTACTION)
Variable Integer WNBACTION
Variable Char WTACTION()

    Raz WTACTION

    WNBACTION = 1                   # n° 1
    WTACTION(WNBACTION) = "IB"      # init bouton 
    WNBACTION += 1
    WTACTION(WNBACTION) = "AV"      # avant zone
    WNBACTION += 1
    WTACTION(WNBACTION) = "D"       # init
    WNBACTION += 1
    WTACTION(WNBACTION) = "AS"      # avant saisie
    WNBACTION += 1
    WTACTION(WNBACTION) = "C"       # controle
    
    WNBACTION += 1                   # n° 6
    WTACTION(WNBACTION) = "AP"      # apres zone
    WNBACTION += 1
    WTACTION(WNBACTION) = "AM"      # apres modif
    WNBACTION += 1
    WTACTION(WNBACTION) = "S"       # sélection
    WNBACTION += 1
    WTACTION(WNBACTION) = "B1"
    WNBACTION += 1
    WTACTION(WNBACTION) = "B2"

    WNBACTION += 1                   # n° 11
    WTACTION(WNBACTION) = "B3"
    WNBACTION += 1
    WTACTION(WNBACTION) = "B4"
    WNBACTION += 1
    WTACTION(WNBACTION) = "AVANT"    # var bas de tableau
    WNBACTION += 1
    WTACTION(WNBACTION) = "APRES"    # var bas de tableau
    WNBACTION += 1
    WTACTION(WNBACTION) = "B5"

    WNBACTION += 1                   # n° 16
    WTACTION(WNBACTION) = "B6"
    WNBACTION += 1
    WTACTION(WNBACTION) = "B7"
    WNBACTION += 1
    WTACTION(WNBACTION) = "B8"
    WNBACTION += 1
    WTACTION(WNBACTION) = "B9"
    WNBACTION += 1
    WTACTION(WNBACTION) = "B10"

    WNBACTION += 1                   # n° 21
    WTACTION(WNBACTION) = "B11"
    WNBACTION += 1
    WTACTION(WNBACTION) = "B12"
    WNBACTION += 1
    WTACTION(WNBACTION) = "B13"
    WNBACTION += 1
    WTACTION(WNBACTION) = "B14"
    WNBACTION += 1
    WTACTION(WNBACTION) = "B15"

    WNBACTION += 1                   # n° 26
    WTACTION(WNBACTION) = "B16"
    WNBACTION += 1
    WTACTION(WNBACTION) = "B17"
    WNBACTION += 1
    WTACTION(WNBACTION) = "B18"
    WNBACTION += 1
    WTACTION(WNBACTION) = "B19"
    WNBACTION += 1
    WTACTION(WNBACTION) = "B20"

    WNBACTION += 1                   # n° 31
    WTACTION(WNBACTION) = "CL"       # click

End

#------------------------------------------------------------------------------------------------------------------------#

Subprog ECRERREUR(INDERREUR, WTITRE, TXTERR2, TITAECRIRE, TITAECRIREW, CHAINE,
&       NBERREUR, NBWARNING, NLIG, TERREUR, PNUMERREUR, PCHBOUCLE, PATCH)
Value Integer INDERREUR
Variable Char WTITRE
Variable Char TXTERR2
Variable Integer TITAECRIRE, TITAECRIREW
Value Clbfile CHAINE
Variable Integer NBERREUR, NBWARNING
Variable Integer NLIG, TERREUR()
Value Integer PNUMERREUR
Value Clbfile PCHBOUCLE
Value Char PATCH


Local Char TXTERR(150)
Local Integer BWARNING


    If PNUMERREUR
        If PNUMERREUR <> INDERREUR
            End
        Endif
    Else
        # désactivation temporaire de certaines erreurs
###        If INDERREUR <> 3 and INDERREUR <> 4
#        If INDERREUR < 10 or INDERREUR > 15
#            End
#        Endif
    Endif
#CBO
    BWARNING = GBTWARNING(GNUMMOUL, INDERREUR)
    BWARNING = 1
#CBO 

    TERREUR(INDERREUR) += 1
    GTRECAPERR(GNUMMOUL, [F:ADC]MODULE, INDERREUR) += 1
    If BWARNING
        NBWARNING += 1
        
        Wrseq Using [FWR]
        If TITAECRIREW
            Wrseq WTITRE Using [FWR]
            TITAECRIREW = 0
        Endif
    Else
        NBERREUR += 1

        Wrseq Using [FER]
        If TITAECRIRE
            Wrseq WTITRE Using [FER]
            TITAECRIRE = 0
        Endif
    Endif
        
        
    TXTERR = "  *** (Ligne" - num$(NLIG) - "Ano" - num$(INDERREUR + 300) + ")"

    If BWARNING
        Wrseq TXTERR - TXTERR2 Using [FWR]
        TXTERR2 = ""
        If INDERREUR > 10 and INDERREUR < 20
            If PCHBOUCLE <> ""
                Wrseq "  début de boucle       -->" - PCHBOUCLE Using [FWR]
            Endif
            If CHAINE <> ""
                Wrseq "  Instruction de sortie -->" - CHAINE Using [FWR]
            Endif
        Else
            If CHAINE <> "" and PATCH <> ""
                Wrseq "  -->" - CHAINE Using [FWR]
            Endif
        Endif
    Else
        Wrseq TXTERR - TXTERR2 Using [FER]
        TXTERR2 = ""
        If INDERREUR > 10 and INDERREUR < 20
            If PCHBOUCLE <> ""
                Wrseq "  début de boucle       -->" - PCHBOUCLE Using [FER]
            Endif
            If CHAINE <> ""
                Wrseq "  Instruction de sortie -->" - CHAINE Using [FER]
            Endif
        Else
            If CHAINE <> "" and PATCH <> ""
                Wrseq "  -->" - CHAINE Using [FER]
            Endif
        Endif
    Endif

    If BWARNING
        TITAECRIREW = 0
        BWARNING = 0
    Else
        TITAECRIRE = 0
    Endif
End
