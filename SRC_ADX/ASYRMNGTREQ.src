#<AdxTL>@(#)11.0.0.0 $Revision$
# create request in folder X3
Local Integer NBPAR , REQUETE , ASTATUS
Local Char TBPAR(30)(1..10) , TBVAL(250)(1..10) , TIM(8) , MESSAGE(250) , TACHE(30) , DOSSIER(30) , USER(10)
Local Date DAT
DAT = date$
TIM = left$(time$,5)
TACHE = "VALDOS"
DOSSIER = nomap
USER = GACTX.USER
NBPAR  = 1 : TBPAR(NBPAR) = "DOSSIER(0)" : TBVAL(NBPAR) = "TEST2"
NBPAR += 1 : TBPAR(NBPAR) = "NBDOS"      : TBVAL(NBPAR) = "1"
NBPAR += 1 : TBPAR(NBPAR) = "TRADIF"     : TBVAL(NBPAR) = "1"
NBPAR += 1 : TBPAR(NBPAR) = "VALDIF"     : TBVAL(NBPAR) = "2"
ASTATUS = func CRERQT(GACTX,DOSSIER,USER,TACHE,DAT,TIM,TBPAR,TBVAL,NBPAR,REQUETE,MESSAGE)
Infbox "status="+num$(ASTATUS)-"request="+num$(REQUETE)-"message="+MESSAGE
End

#---------------------------------------------------------------------------------------------------#
# This treatment create a request in the batch server
#---------------------------------------------------------------------------------------------------#

#--------------------------------------------------------------------------------------------------#
# Create a request in batch server
#--------------------------------------------------------------------------------------------------#

Funprog CRERQT(ACTX,FOLD,USER,TASK,DAT,TIM,ARYPAR,ARYVAL,NBPAR,REQUEST,MESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    FOLD
Value    Char    USER
Value    Char    TASK
Value    Date    DAT
Value    Char    TIM
Value    Char    ARYPAR()(1..)
Value    Char    ARYVAL()(1..)
Value    Integer NBPAR
Variable Integer REQUEST
Variable Char    MESSAGE
Local Char    LAN(GLONLAN) : LAN=""
Goto CREATE_RQT

#--------------------------------------------------------------------------------------------------#
# Create a request in batch server
#--------------------------------------------------------------------------------------------------#

Funprog CRERQTLAN(ACTX,FOLD,USER,LAN,TASK,DAT,TIM,ARYPAR,ARYVAL,NBPAR,REQUEST,MESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    FOLD
Value    Char    USER
Value    Char    LAN
Value    Char    TASK
Value    Date    DAT
Value    Char    TIM
Value    Char    ARYPAR()(1..)
Value    Char    ARYVAL()(1..)
Value    Integer NBPAR
Variable Integer REQUEST
Variable Char    MESSAGE
Goto CREATE_RQT

#####################################################
$CREATE_RQT
Local File ABATPAR  [ABP_]
Local File ABATTAC  [ABT_]
Local File ABATRQT  [ABR_]
Local File ABATRQTL [ABL_]

Local Integer I , K , LL , NBRROL , MAXROL , ASTAT
Local Integer FLG , GRPNUM
Local Char    SERVICE(5) , GROUP(10)

FLG     = 1 : # En attente
SERVICE = ""
TIM     = left$(ctrans(TIM,":",""),4)
GROUP   = ""
GRPNUM  = 0

ASTAT   = CST_AOK
MAXROL  = 3
NBRROL  = 0

Gosub CTL_RQT
If ASTAT<>CST_AOK
 # Erreur soumission requête
 MESSAGE = mess(112,134,1)-":"-MESSAGE
Else
 Gosub CRE_RQT
 If ASTAT=CST_AOK
  # Requête transmise au serveur
  MESSAGE = TASK-":"-mess(29,134,1)+" ("+num$(REQUEST)+")"
 Else
  Case ASTAT
   When 1       : MESSAGE = mess(60,100,1)  : # Enregistrement verrouillé
   When 2       : MESSAGE = mess(153,115,1) : # Clé suivante lue
   When 3       : MESSAGE = mess(22,100,1)  : # Clé déjà existante
   When 4       : MESSAGE = mess(11,100,1)  : # Début/fin de fichier
   When 5       : MESSAGE = mess(154,115,1) : # Pas d'enregistrement courant
   When 6       : MESSAGE = mess(240,115,1) : # Enregistrement obsolète
   When Default : MESSAGE = mess(6,123,1)   : # Erreur
  Endcase
  # Erreur soumission requête
  MESSAGE = mess(112,134,1)-":"-MESSAGE
 Endif
Endif

End ASTAT

#-------------------#
$CTL_RQT
# User
Local File AUTILIS [AUS_]
Read [AUS_]CODUSR=USER
If fstat
 MESSAGE = func ASYRFNC.MES1(mess(58,149,1),USER) : # L'utilisateur $1$ n'existe pas
 ASTAT = CST_AERROR : Return
Endif
# Folder
If FOLD=""
 MESSAGE = mess(149,7900,1) : # Dossier non renseigné !
 ASTAT = CST_AERROR : Return
Else
 ASTAT = func CTLFOL([L]FOLD,MESSAGE)
 If ASTAT : Return : Endif
Endif
# Task
Read [ABT_]CODTAC=TASK
If fstat
 MESSAGE = TASK-":"-mess(56,134,1) : # Tâche inexistante
 ASTAT = CST_AERROR : Return
Endif
Return

#-----------------------#
$CRE_RQT
If !adxlog
 Trbegin [ABP_] , [ABR_]
 Gosub WR_RQT
 If ASTAT<>CST_AOK
  Rollback
 Else
  Commit
 Endif
Else
 Gosub WR_RQT
Endif
Return

#----------------------------#
$WR_RQT
Readlock [ABP_]SPOOL First
If fstat=1
 NBRROL += 1
 If NBRROL>MAXROL
  ASTAT = CST_AERROR
  Return
 Else
  Sleep 2
  Goto WR_RQT
 Endif
Elsif fstat
 ASTAT = CST_AERROR
Else
 REQUEST = [F:ABP_]NUMREQ
 Read [ABT_]CODTAC = TASK
 Raz [F:ABR_]
 [F:ABR_] = [F:ABT_]
 [F:ABR_]DOSSIER = FOLD
 [F:ABR_]USER    = USER
 #109897
 [F:ABR_]LAN    = LAN
 [F:ABR_]TACHE   = TASK
 [F:ABR_]ETAT    = [F:ABT_]TRAIT
 [F:ABR_]NUMREQ  = [F:ABP_]NUMREQ
 [F:ABR_]FLAG    = FLG
 [F:ABR_]DAT     = DAT
 [F:ABR_]HEURE   = TIM
 #109897
 #[F:ABR_]SERVICE = SERVICE
 [F:ABR_]GRP     = GROUP
 [F:ABR_]NUMGRP  = GRPNUM
 LL = [F:ABR_]NUMREQ
 Call ECRIT(ARYPAR,ARYVAL,NBPAR,LL,ASTAT)
 If ASTAT=CST_AOK
  Write [ABR_]
  If fstat
   ASTAT = CST_AERROR
  Else
   [F:ABP_]NUMREQ  += 1
   Rewrite [ABP_]
   If fstat
    ASTAT = CST_AERROR
   Endif
  Endif
 Endif
Endif
Return

#----------------------------------------------------#
# Copy parameters to default file
#----------------------------------------------------#

Subprog ECRIT(ARYPAR,ARYVAL,NBPAR,NUMREQ,ASTAT)
Value    Char    ARYPAR()(1..) , ARYVAL()(1..)
Value    Integer NBPAR
Value    Integer NUMREQ
Variable Integer ASTAT
Local Integer I , LNG , LMAX , NUMERO
Local Char    PARAM(30) , VALEUR(250)
Local Clbfile CHAINE(7)
If clalev([F:ABL_])=0 : Local File ABATRQTL [ABL_] : Endif
Default File [ABL_]
LMAX = type([F]VALEUR)-10
NUMERO = 0
For I=1 To NBPAR
 [L]PARAM = ARYPAR(I)
 LNG = len(ARYVAL(I))
 If LNG<>0
  CHAINE = ARYVAL(I)
  Repeat
   [L]VALEUR   = left$(CHAINE,LMAX)
   Gosub ECRIT_PAR
   If ASTAT<>CST_AOK : Break 2 : Endif
   CHAINE = right$(CHAINE,LMAX+1)
  Until CHAINE=""
 Endif
Next I
If NUMERO=0
 Gosub ECRIT_PAR : # Pour forcer l'écriture au moins d'un enregistrement
Endif
End

#------------------------------------#
$ECRIT_PAR
Raz [F]
[F] = [L]
[L]NUMERO += 1
[F]NUM    = [L]NUMERO
Write [F]
If fstat
 ASTAT = CST_AERROR
Endif
Return

#-----------------------------------------------------#
Funprog CTLFOL(DOS,MESSAGE)
Value    Char DOS
Variable Char MESSAGE
Local Integer FSTA , ER
Local File ADOSSIER [ADS]
#107271
#Read [ADS]DOSSIER=[L]DOS
#If fstat
If func DOSSUB.FILL_ADS([L]DOS)=0
 MESSAGE = DOS-":"-mess(7,125,1) : # Dossier inexistant
 End CST_AERROR
Endif
If filinfo(filpath("FIL","ADOVAL","fde",DOS),0)<0
 MESSAGE = DOS-":"-mess(7,125,1) : # Dossier inexistant
 End CST_AERROR
Endif
Onerrgo ERDOS
Local File =DOS+".ADOVAL" [ADW_]
Read [ADW_]ADW0 = "";"";"SUPDOS"
FSTA = fstat
Close Local File [ADW_]
Onerrgo
If ER or FSTA
 MESSAGE = DOS-":"-mess(106,125,1) : # Dossier inaccessible
 End CST_AERROR
Endif
End CST_AOK

#------------#
$ERDOS
ER = errn
Resume

