########################################################################################
#                                     SUBPROG DIVERS
########################################################################################
########################################################################################

Subprog CRE_CODACT_TYP1
#--------------------------------------------#
# creation des codes activités  typacv = 1  ou 3  #
#--------------------------------------------#

# on supprime d abord
Delete [ADLD] Where COD=[M]COD and TYPACV <> 2
If fstat=1
 GOK=-1 : GLOCK="$ADELIVERD" : End
Elsif fstat
 GOK = 0 : Call FSTA("ADLD") From GLOCK : End
Endif

For nolign=1 To [M:ADLV2]NBRACT
 Raz [F:ADLD]
 [F:ADLD]COD     = [M]COD
 [F:ADLD]CODACT  = [M:ADLV2]CODACT(nolign-1)
  # on controle encore que code act est bien present dans activ
  # sinon code act n est plus present on vire la ligne
  Read [ACV]CODACT = [F:ADLD]CODACT
  If fstat = 0
     [F:ADLD]FLGACT     = [M:ADLV2]FLGACT(nolign-1)
     If [M]ADLVTYP = 2
         [F:ADLD]LICACT     = 1
         [F:ADLD]NOTAVAACT  = 1
     Else
         [F:ADLD]LICACT     = [M:ADLV2]LICACT(nolign-1)
         [F:ADLD]NOTAVAACT  = [M:ADLV2]NOTAVAACT(nolign-1)
     Endif
     [F:ADLD]DIMACT     = 0
     [F:ADLD]TYPACV     = [M:ADLV2]TYPACV(nolign-1)
     Call FLDCRE("ADLD") From OBJDIV
     Write [ADLD]
     If fstat
      GOK = 0 : Call FSTA("ADLD") From GLOCK : Break
     Endif
  Endif
Next nolign
If GOK<1 : End : Endif

End

########################################################################################
Subprog CRE_CODACT_TYP2
#--------------------------------------------#
# creation des codes activités  typact = 2   #
#--------------------------------------------#

# on supprime d abord
Delete [ADLD] Where COD=[M]COD and TYPACV = 2
If fstat=1
 GOK=-1 : GLOCK="$ADELIVERD" : End
Elsif fstat
 GOK = 0 : Call FSTA("ADLD") From GLOCK : End
Endif

For nolign=1 To [M:ADLV5]NBRDIM
 Raz [F:ADLD]
 [F:ADLD]COD     = [M]COD
 [F:ADLD]CODACT  = [M:ADLV5]CODDIM(nolign-1)
 [F:ADLD]DIMACT  = [M:ADLV5]DIMACT(nolign-1)
 [F:ADLD]TYPACV  = 2
 Call FLDCRE("ADLD") From OBJDIV
 Write [ADLD]
 If fstat
  GOK = 0 : Call FSTA("ADLD") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : End : Endif

End


########################################################################################
Subprog CRE_PARAM
#--------------------------#
# creation des parametres  #
#--------------------------#

# on supprime d abord
Delete [ADLP] Where COD=[M]COD
If fstat=1
 GOK=-1 : GLOCK="$ADELIVERP" : End
Elsif fstat
 GOK = 0 : Call FSTA("ADLP") From GLOCK : End
Endif

For nolign=1 To [M:ADLV3]NBRSET
 Raz [F:ADLP]
 [F:ADLP]COD      = [M]COD
 If [M:ADLV3]PARAM(nolign-1) <> ""
     [F:ADLP]PARAM    = [M:ADLV3]PARAM(nolign-1)
     [F:ADLP]CLEPARAM = [M:ADLV3]CLEPARAM(nolign-1)
     [F:ADLP]VALPARAM = [M:ADLV3]VALPARAM(nolign-1)
     [F:ADLP]TYPPARAM = [M:ADLV3]TYPPARAM(nolign-1)
     Call FLDCRE("ADLP") From OBJDIV
     Write [ADLP]
     If fstat
      GOK = 0 : Call FSTA("ADLP") From GLOCK : Break
     Endif
  Endif
Next nolign
If GOK<1 : End : Endif

End

########################################################################################
Subprog CRE_OBJ
#--------------------------#
# creation des cles fichiers  #
#--------------------------#

# on supprime d abord
Delete [ADLO] Where COD=[M]COD
If fstat=1
 GOK=-1 : GLOCK="$ADELIVERO" : End
Elsif fstat
 GOK = 0 : Call FSTA("ADLO") From GLOCK : End
Endif

For nolign=1 To [M:ADLV6B]NBROBJ
 Raz [F:ADLO]
 [F:ADLO]COD      = [M]COD
 If [M:ADLV6B]TABCOD(nolign-1) <> ""
     [F:ADLO]TABCOD     = [M:ADLV6B]TABCOD(nolign-1)
     [F:ADLO]TABKEY     = [M:ADLV6B]TABKEY(nolign-1)
     [F:ADLO]TABLEG     = [M:ADLV6B]TABLEG(nolign-1)
     [F:ADLO]TABKEYNAM  = [M:ADLV6B]TABKEYNAM(nolign-1)
     [F:ADLO]TABKEYFMT  = [M:ADLV6B]TABKEYFMT(nolign-1)
     [F:ADLO]TABAWM     = [M:ADLV6B]TABAWM(nolign-1)
     [F:ADLO]NULRECFLG  = [M:ADLV6B]NULRECFLG(nolign-1)
     [F:ADLO]TABADINUM =  [M:ADLV6B]TABADINUM(nolign-1)

     Call FLDCRE("ADLO") From OBJDIV
     Write [ADLO]
     If fstat
      GOK = 0 : Call FSTA("ADLO") From GLOCK : Break
     Endif
 Endif
Next nolign
If GOK<1 : End : Endif

End

########################################################################################
Subprog CRE_FNCBDG
#--------------------------#
# creation des bagdes/fcts
#--------------------------#

# on supprime d abord
Delete [ADLB] Where COD=[M:ADLV0]COD
If fstat=1
 GOK=-1 : GLOCK="$ADELIVERB" : End
Elsif fstat
 GOK = 0 : Call FSTA("ADLB") From GLOCK : End
Endif

For nolign=1 To [M:ADLV7]NBRBDG
 Raz [F:ADLB]
 [F:ADLB]COD      = [M:ADLV0]COD
 If [M:ADLV7]CODFNC(nolign-1) <> ""
     [F:ADLB]CODFNC   = [M:ADLV7]CODFNC(nolign-1)
     [F:ADLB]CODBDG   = [M:ADLV7]CODBDG(nolign-1)
     Call FLDCRE("ADLB") From OBJDIV
     Write [ADLB]
     If fstat
      GOK = 0 : Call FSTA("ADLB") From GLOCK : Break
     Endif
  Endif
Next nolign
If GOK<1 : End : Endif

End

