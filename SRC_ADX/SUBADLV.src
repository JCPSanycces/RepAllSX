########################################################################################
##                             Etiquette - écran ADLV3
########################################################################################
########################################################################################

Subprog IB_NBRSET
If GFONCTION <> "GESADLK"
    Raz GBOUT3
Endif
End



Subprog AS_NBRSET
End


Subprog B1_NBRSET
Gosub SETNOL
If [M]CHAPITRE(NOL) <> "" and [M]PARAM(NOL) <> ""
    Hlpbox "ADP_"+[M]CHAPITRE(NOL)+"_"+[M]PARAM(NOL)
Endif

End

Subprog AS_PARAM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
# on bloque la modif du code si ligne deja saisie
# il faudra passer par la suppression de la linge
If [M:ADLV3]CHAPITRE(NOL)<>""
      mkstat = 2
Endif
End


Subprog C_PARAM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
# controle prametre existe, on peut les prendre tous
# et doit etre modifiable ..
Local Integer WRETOUR
WRETOUR = 0
Call READ_ADOPAR (VALEUR,0,WRETOUR)
If WRETOUR  = 3
    #"Code paramètre inexistant"
    GMESSAGE= mess(2,114,1)
    mkstat = 2
Else
   If WRETOUR = 0
       # controle double si param dossier (leg =vide et non saississable)
       If [F:ADP]NIVDEF = 1
            Local Char WLEGPARAM (250)
            WLEGPARAM= VALEUR+"~"
            Call UNICITE(WLEGPARAM,[M:ADLV3]LEGPARAM(0..[M:ADLV3]NBRSET-1)) From OBJDIV
            If mkstat : End : Endif
            [M:ADLV3]LEGPARAM (NOL)= VALEUR+"~"
        Endif
        If mkstat <> 2
               Call TEXTE([F:ADP]NAM, [M:ADLV3]NAM (NOL)) From OBJDIV
               Affzo [M:ADLV3]NAM (NOL)
               Call CHARGE_PARAM (NOL)
        Endif
   Else
        #"code non modifiable, saisie impossible"
        GMESSAGE = mess (59,143,1)
        mkstat = 2
   Endif
Endif
End



Subprog AS_CLEPARAM(VALEUR)
Variable Char    VALEUR()
# saisie uniquement si param n est pas un param DOSSIER
# on controlera que la leg sasie fait partie de la liste des leg du livrable
Gosub SETNOL
If [M:ADLV3]NIVDEF (NOL) = 1
    # chargement valeur courante dans valads
    Call CHARGE_ADS_PARAM ([M:ADLV3]PARAM(NOL),VALEUR,NOL)
    Affzo [M:ADLV3]VALADS (NOL)
    mkstat = 2
Endif
End


Subprog C_CLEPARAM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
# saisie uniquement si param n est pas un param DOSSIER
# on controlera que la leg sasie fait partie de la liste des leg du livrable
# unqiuement sur livrable , on ne fait pas ce controle sur le kit
If VALEUR <> ""
    If GFONCTION <> "GESADLK"
        If !find(VALEUR,[M:ADLV4]DOSLEG(0..[M]NBRLEG-1))
            # 'La lég doit être définie dans le livrable'
            GMESSAGE= func AFNC.MES2(mess(132,127,1),num$(VALEUR),num$(VALEUR))
            mkstat = 2
        Endif
    Endif
Endif
If mkstat : End : Endif

# on controlera que si param +sieurs fois dans le tableau , on ne peut saisir une leg identique
# sinon on aura un duplicate key.
Local Char WLEGPARAM (250)
WLEGPARAM= [M:ADLV3]PARAM(NOL)+"~"+VALEUR
Call UNICITE(WLEGPARAM,[M:ADLV3]LEGPARAM(0..[M:ADLV3]NBRSET-1)) From OBJDIV
If mkstat : End : Endif
[M:ADLV3]LEGPARAM (NOL)= [M:ADLV3]PARAM (NOL)+"~"+VALEUR

# chargement valeur courante dans valads
Call CHARGE_ADS_PARAM ([M:ADLV3]PARAM(NOL),VALEUR,NOL)
Affzo [M:ADLV3]VALADS (NOL)
End

Subprog AM_CLEPARAM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
End


Subprog IB_VALSAI
Gosub SETNOL
Local Integer WRETOUR
WRETOUR = 0
Call READ_ADOPAR ([M:ADLV3]PARAM (NOL),0,WRETOUR)
If WRETOUR  = 0
    If [F:ADP]NBVAL<>0
&    & [F:ADP]OBJET=""    # Issue X3-44568 - 2017-06-12 by CCC : NBVAL=1 if a parameter of object is set
        GBOUT6 = mess(133,126,1) : # Liste de valeurs
    Else
        Raz GBOUT6
    Endif
Else
    Raz GBOUT6
Endif
End

Subprog B1_VALSAI(VALEUR)
Variable Char    VALEUR()
# tunnel
Gosub SETNOL
Call B1_VALEUR(VALEUR) From ASAIPARVAL

End

Subprog C_VALSAI(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Local Integer WOK
WOK  = 0
Local Integer WRETOUR
WRETOUR = 0
Call READ_ADOPAR ([M:ADLV3]PARAM (NOL),0,WRETOUR)
If WRETOUR  = 0
    Call CTRL_VALPARAM ([M:ADLV3]PARAM(NOL),[M:ADLV3]VALPARAM(NOL),[M:ADLV3]CLEPARAM(NOL),WOK,GMESSAGE)
    If WOK <> 0
         mkstat = 2
    Endif
Endif

End




########################################################################################
##                             Etiquette - écran ADLV5
########################################################################################
########################################################################################

Subprog IB_NBRDIM
If GFONCTION <> "GESADLK"
    Raz GBOUT2
Endif
End


Subprog AS_NBRDIM
End

Subprog AS_CODDIM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL

End

Subprog C_CODDIM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Local Integer WRETOUR

If VALEUR>="X"
    # 'code spé #Le code ne doit pas être supérieur à X'
    GMESSAGE= mess (230,133,1)
    mkstat = 1
Else
    Call UNICITE(VALEUR,[M:ADLV5]CODDIM(0..[M:ADLV5]NBRDIM-1)) From OBJDIV
    If !mkstat
        # on ne doit pas saisir des codes act formules
        # on ne doit pas saisir des codes act dependance inverse
        # uniquement les codes de dim
        # utiliser le read_activ
        WRETOUR = 0
        Call READ_ACTIV (VALEUR,"D",WRETOUR)
        If WRETOUR = 3
                mkstat = 1
        Elsif WRETOUR = 1
               # Code activité n est pas de dimension
               Call ERREUR(mess(311,123,1)-mess([F:ACV]DEP,74,1)) From GESECRAN
               mkstat = 1
        Elsif WRETOUR = 2
               If [F:ACV]DEP = 2
                   # Code activité avec dépendance
                   Call ERREUR(mess(68,139,1)-mess([F:ACV]DEP,74,1)) From GESECRAN
               Elsif [F:ACV]DEP = 4
                   # Code activité avec formule
                   Call ERREUR(mess(68,139,1)-mess([F:ACV]DEP,74,1)) From GESECRAN
               Endif
               mkstat = 1
        Else
              Call CHARGE_DEFAULT_DIM (VALEUR,NOL)
              #
              [M:ADLV5]DIMACT (NOL) = [F:ADA]DIME
              Affzo [M:ADLV5]DIMMOD (NOL)
              Affzo [M:ADLV5]DIMADS (NOL)
              Affzo [M:ADLV5]DIMMIN (NOL)
              Affzo [M:ADLV5]DIMMAX (NOL)

        Endif
    Else
        mkstat =1
    Endif
Endif
End


Subprog AS_DIMACT(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
End

Subprog C_DIMACT(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
# les messages de plus petit pas bloquant
If VALEUR < [M:ADLV5]DIMMIN(NOL)
    # valeur trop petite
    GMESSAGE = mess (8,133,1)
    mkstat = 2
Else
    If VALEUR > [M:ADLV5]DIMMAX(NOL) and [M:ADLV5]DIMMAX(NOL) <> 0
            #GMESSAGE = 'Valeur trop grande (maximum #)'
            GMESSAGE = func AFNC.MES(mess(115,75,1),num$([M:ADLV5]DIMMAX(NOL)))
            mkstat = 2
    Endif
Endif
End

Subprog AM_DIMACT(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
End


########################################################################################
##                             Etiquettes ecran ADLV6
########################################################################################
########################################################################################
Subprog AS_NBRTAB
Gosub SETNOL
If [M:ADLV6]NBRTAB<>0
    Local Char WTABREF(GLONATB)
    Local Integer WTABADINUM
    WTABREF    = [M:ADLV6]TABCOD1 (NOL)
    WTABADINUM = [M:ADLV6]TABADINUM1 (NOL)
    Gosub CHARG_LIGKEY
Endif
End

Subprog IB_NBRTAB
Raz GBOUT1, GBOUT3
# flgko = 2 si la ligne est incorrrecte
# et donc on ne peut pas aller faire selection sur le modele en cours
# prob de cohérence trouvé
If [M:ADLV6]TABCOD1 (nolign-1) <> "" and [M:ADLV6]FLGKO (nolign-1) <>2
    GBOUT1 = mess (9,7999,1)
Endif
GBOUT3 = mess (10,7999,1)
End

Subprog C_NBRTAB
Gosub SETNOL
If    status=65             : # Annulation simple
    # demande d une confirmation
    Local Integer WOK
    WOK = 0
    Call OUINON (mess (49,7999,1), WOK) From GESECRAN
    If WOK = 2
        Local Char WTABREF (GLONATB)
        Local Integer WTABADINUM
        WTABREF    = [M:ADLV6]TABCOD1 (NOL)
        WTABADINUM = [M:ADLV6]TABADINUM1 (NOL)
        Local Char WSUPLIG(1)
        # il ne faut pas virer la ligne car pris en compte par moteur
        WSUPLIG = "N"
        Gosub SUP_LIGTAB
        Gosub RAZ_NBRKEY
        mkstat = 4
        Affzo [M:ADLV6]15
    Else
        mkstat = 2
    Endif
Elsif status=68 | status=83 : # Annulation multiple (ici on interdit au cas ou)
    mkstat = 2
Elsif status = 75
    mkstat = 2
Elsif status=73 | status=82
    mkstat = 2
Endif

End

Subprog C_TABCOD1(VALEUR)
Variable Char    VALEUR()
# insertion
Gosub SETNOL
# pas possible d avoir une ligne vide
If VALEUR = ""
        mkstat = 2
Endif

End


