Subprog AS_COD(VALEUR)
#-----------------------#
# Avant saisie code     #
#-----------------------#
Variable Char    VALEUR()
[M:ADLV0]ADLVTYP=1
End


Subprog C_COD(VALEUR)
Variable Char    VALEUR()
If len(VALEUR) > 15
    GMESSAGE= mess(98,7999,1)
    mkstat=1
    #----------------#
    # en duplication controle #
    # si des lignes sont invalides , on ne permet pas de dupliquer"
    #----------------#
Elsif [M:ADLV6]NBRTAB > 0
    If find(2,[M:ADLV6]FLGKO(0..[M:ADLV6]NBRTAB-1))
         #mess --- Des lignes sont invalides , la duplication est interdite !"
         GMESSAGE = mess(18,7999,1)
         mkstat = 1
    Endif
Endif

End


Subprog AS_PDT(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
Local Integer I
For I=1 To len(mess(0,7884,1))
   If left$(mess(I,7884,1),1)="#"
        GMENLOC (I)=1
   Endif
Next I
End


