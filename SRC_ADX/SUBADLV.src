Subprog C_FNCLIM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
    Local Integer WRETOUR
    Call READ_LIMITES (VALEUR,"",[M:ADLV0]PDT,WRETOUR) From SUBADLV
    If WRETOUR <>0
        GMESSAGE =mess (87,7999,1)
        mkstat = 2
    Else
        Call UNICITE(VALEUR,[M:ADLV8]FNCLIM(0..[M:ADLV8]NBRLIM-1)) From OBJDIV
    Endif
Endif
If mkstat : End : Endif
End


