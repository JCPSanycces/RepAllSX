     Write [ADLL]
     If fstat
      GOK = 0 : Call FSTA("ADLL") From GLOCK : Break
     Endif
  Endif
Next nolign
If GOK<1 : End : Endif

End


########################################################################################
Subprog DEL_CODACT
#------------------------------------------#
# suppression de tous les codes activités  #
#------------------------------------------#
Delete [ADLD] Where COD=[M]COD

# Vérification si un enregistrement est locké : si oui : fin
If fstat=1  : GOK=-1 : Call RSTA("ADLD",[M]COD) From GLOCK : End  : Endif
End

########################################################################################
Subprog DEL_PARAM
#------------------------#
# suppression des param  #
#------------------------#
Delete [ADLP] Where COD=[M]COD

# Vérification si un enregistrement est locké : si oui : fin
If fstat=1  : GOK=-1 : Call RSTA("ADLP",[M]COD) From GLOCK : End  : Endif
End

########################################################################################
Subprog DEL_OBJ
#--------------------------------#
# suppression des cles fichiers  #
#--------------------------------#

Delete [ADLO] Where COD=[M]COD

# Vérification si un enregistrement est locké : si oui : fin
If fstat=1  : GOK=-1 : Call RSTA("ADLO",[M]COD) From GLOCK : End  : Endif
End

########################################################################################
Subprog DEL_FNCBDG
#------------------------#
# suppression des fct/badges
#------------------------#
Delete [ADLB] Where COD=[M]COD

# Vérification si un enregistrement est locké : si oui : fin
If fstat=1  : GOK=-1 : Call RSTA("ADLB",[M]COD) From GLOCK : End  : Endif
End
########################################################################################
Subprog DEL_ASWBDG
#------------------------#
# suppression des representations/badges
#------------------------#
Delete [ADLR] Where COD=[M]COD

# Vérification si un enregistrement est locké : si oui : fin
If fstat=1  : GOK=-1 : Call RSTA("ADLR",[M]COD) From GLOCK : End  : Endif
End

########################################################################################
Subprog DEL_SES
#------------------------#
# suppression des sessions/devcies
#------------------------#
Delete [ADLT] Where COD=[M]COD

# Vérification si un enregistrement est locké : si oui : fin
If fstat=1  : GOK=-1 : Call RSTA("ADLT",[M]COD) From GLOCK : End  : Endif
End
########################################################################################
Subprog DEL_LIM
#------------------------#
# suppression des limites/licences
#------------------------#
Delete [ADLL] Where COD=[M]COD

# Vérification si un enregistrement est locké : si oui : fin
If fstat=1  : GOK=-1 : Call RSTA("ADLL",[M]COD) From GLOCK : End  : Endif
End


########################################################################################
Subprog CHARGE_PARAM (RLIGNE)
Value Integer RLIGNE
#------------------------#
# chargement format pour param
#------------------------#
Local Integer K

Case [F:ADP]TYPVAL
           When 1 : [M:ADLV3]FMT(RLIGNE) ="Kf:"+num$(GLONADW)+"X"
           When 2 : [M:ADLV3]FMT(RLIGNE) = "Nf:10F"
           When 3 : [M:ADLV3]FMT(RLIGNE) = "Df:"+GFMDAT4
           When 4 : [M:ADLV3]FMT(RLIGNE) = "Nf:2#"
Endcase
Case [F:ADP]TYPVAL
           When 1 : [M:ADLV3]TYP(RLIGNE) = "A"   : [M:ADLV3]LONG(RLIGNE)  = GLONADW
           When 2 : [M:ADLV3]TYP(RLIGNE) = "DCB" : [M:ADLV3]LONG(RLIGNE)  = 15
           When 3 : [M:ADLV3]TYP(RLIGNE) = "D"   : [M:ADLV3]LONG(RLIGNE)  = 0
           When 4 : [M:ADLV3]TYP(RLIGNE) = "M"   : [M:ADLV3]NOLIB(RLIGNE) = [F:ADP]NOLIB
Endcase
#---------------------------------- #
# on charge dans type code de objet
#---------------------------------- #
If [F:ADP]OBJET<>""
   Filter [ATY_] Where OBJLIEN=[F:ADP]OBJET
   K = 0
   For [ATY_]
        K += 1 : If K>1 : Break : Endif
   Next
   Filter [ATY_]
   If K=1 & left$([F:ATY_]FORTYP,1)<>"="
        [M:ADLV3]TYP(RLIGNE) = [F:ATY_]CODTYP
   Else
        Call EXISTE_ADX("","","WO"+[F:ADP]OBJET,K) From ORDSYS
        If K
             Gosub SETCLE From    = "WO"+[F:ADP]OBJET
             Read [AOB_]ABREV     = [F:ADP]OBJET
             Read [ATZ_]CODZONE   = [F:AOB_]NOMFIC;CLEPRIM
             Read [ATY_]CODTYP    = [F:ATZ_]CODTYP
             If fstat =0
                 [M:ADLV3]TYP(RLIGNE) = [F:ATY_]CODTYP
             Endif
        Endif
    Endif
Endif
#
[M:ADLV3]NIVDEF(RLIGNE)    = [F:ADP]NIVDEF
[M:ADLV3]GRPPAR(RLIGNE)    = [F:ADP]GRPPAR
[M:ADLV3]CHAPITRE(RLIGNE)  = [F:ADP]CHAPITRE
[M:ADLV3]TYPPARAM(RLIGNE)  = [F:ADP]TYPVAL

End


########################################################################################
Subprog CHARGE_CODACT (RLIGNE)
Value Integer RLIGNE
#------------------------#
# chargement des codes activites tous sauf les typ 2
#------------------------#

RLIGNE = 0
Filter [ACV] Where TYP <> 2 and CODACT < "X" and DEP = 1
For [ACV]
 [M:ADLV2]CODACT(RLIGNE)   = [F:ACV]CODACT
 [M:ADLV2]FLGACT(RLIGNE)   = 1
 [M:ADLV2]LICACT(RLIGNE)   = 1
 [M:ADLV2]NOTAVAACT(RLIGNE)= 1
 [M:ADLV2]TYPACV(RLIGNE)   = [F:ACV]TYP
 [M:ADLV2]MODACV(RLIGNE)   = [F:ACV]MODULE
 [M:ADLV2]NBRACT += 1
 RLIGNE +=1
 If [M:ADLV2]NBRACT = GMAXCODACT
        # 'tableau plein'
        GMESSAGE=mess (26,100,1)+"\[M:ADLV2]NBRACT"
        Call MESSAGE(GMESSAGE) From GESECRAN
        Raz GMESSAGE
        Break
 Endif
Next
Filter [ACV]

End



########################################################################################
Subprog CHARGE_DEFAULT_DIM (RCOD,RLIGNE)
Value Char    RCOD
Value Integer RLIGNE

# la classe acv est en ligne
[M:ADLV5]DIMMOD(RLIGNE)  = [F:ACV]MODULE
[M:ADLV5]DIMMIN(RLIGNE)  = min ([F:ACV]DIMFIL,[F:ACV]DIME)
[M:ADLV5]DIMMAX(RLIGNE)  = [F:ACV]DIMMAX
# lecture valeur dossier
Read [ADA]ADA0 = nomap;RCOD
If fstat = 0
      [M:ADLV5]DIMADS(RLIGNE)  = [F:ADA]DIME
Endif

End

########################################################################################
Subprog CHARGE_DEFAULT_PARAM (RPARAM,RVALPARAM,RCLEPARAM,RLIGNE)
Value Char    RPARAM
Value Char    RVALPARAM
Value Char    RCLEPARAM
Value Integer RLIGNE

Local Char WNAM(250)
# la clasee adp est en ligne
WNAM = ""
Call TEXTE([F:ADP]NAM, WNAM) From OBJDIV
[M:ADLV3]NAM (RLIGNE)      = WNAM
Call CHARGE_PARAM (RLIGNE)
[M:ADLV3]VALSAI   (RLIGNE)= RVALPARAM
[M:ADLV3]VALPARAM (RLIGNE)= RVALPARAM
Call CHARGE([M:ADLV3]VALSAI(RLIGNE),[M:ADLV3]TYP(RLIGNE),[M:ADLV3]NOLIB(RLIGNE),[M:ADLV3]LONG(RLIGNE),[M:ADLV3]VALPARAM(RLIGNE)) From FMTVAR
[M:ADLV3]CLEPARAM (RLIGNE)  = RCLEPARAM
[M:ADLV3]LEGPARAM (RLIGNE)  = [M:ADLV3]PARAM(RLIGNE)+"~"+[M:ADLV3]CLEPARAM(RLIGNE)

# chargement valeur courante dans valads
Call CHARGE_ADS_PARAM (RPARAM,RCLEPARAM,RLIGNE)
End

########################################################################################
Subprog CHARGE_ADS_PARAM (RPARAM,RCLEPARAM,RLIGNE)
Value Char    RPARAM
Value Char    RCLEPARAM
Value Integer RLIGNE

Local Char WVALPARAM(250)
Local Integer WRETOUR

# chargement valeur courante dans valads
WRETOUR = 0
WVALPARAM = ""
Call READ_ADOVAL (RCLEPARAM,RPARAM,WVALPARAM,WRETOUR)
If WRETOUR = 0
    [M:ADLV3]VALADS(RLIGNE) = WVALPARAM
    Call CHARGE([M:ADLV3]VALADS(RLIGNE),[M:ADLV3]TYP(RLIGNE),[M:ADLV3]NOLIB(RLIGNE),[M:ADLV3]LONG(RLIGNE),WVALPARAM) From FMTVAR
Endif
End

########################################################################################
Subprog VERIF_NEWCODACT(RNBRACT)
Value Integer RNBRACT

GNEWACTIVITY = 0

#------------------------#
# verif des nouveaux codes act de type <> 2
#------------------------#

# on les ajoute en auto à la fin

Local Integer WIND
WIND =[M:ADLV2]NBRACT
If WIND = GMAXCODACT
    # 'tableau plein'
     GMESSAGE=mess (26,100,1)+"\[M:ADLV2]NBRACT"
     Call MESSAGE(GMESSAGE) From GESECRAN
     Raz GMESSAGE
Else
    Filter [ACV] Where TYP <> 2 and CODACT < "X" and DEP = 1
    For [ACV]
        If !find([F:ACV]CODACT,[M:ADLV2]CODACT(0..[M:ADLV2]NBRACT-1))
             WIND +=1
             [M:ADLV2]CODACT(WIND-1)= [F:ACV]CODACT
             [M:ADLV2]FLGACT(WIND-1)= 1
             [M:ADLV2]LICACT(WIND-1)= 1
             [M:ADLV2]NOTAVAACT(WIND-1)= 1
             [M:ADLV2]TYPACV(WIND-1)= [F:ACV]TYP
             [M:ADLV2]MODACV(WIND-1)= [F:ACV]MODULE
             If WIND = GMAXCODACT
                # 'tableau plein'
                GMESSAGE=mess (26,100,1)+"\[M:ADLV2]NBRACT"
                Call MESSAGE(GMESSAGE) From GESECRAN
                Raz GMESSAGE
                Break
            Endif
        Endif
    Next
    Filter [ACV]
    If RNBRACT <> WIND
       [M:ADLV2]NBRACT = WIND
        # "nouveaux codes act, veuillez controler la valeur'
        GMESSAGE=mess (189,126,1)+"\"+mess(251,133,1)
        Call MESSAGE(GMESSAGE) From GESECRAN
        Raz GMESSAGE
        # degriser bouton enreg pour isntant uniquement si new codact
        GACTMODIF    = 1
        GNEWACTIVITY = 1
    Endif
Endif
End

########################################################################################
Subprog READ_ADLK (RCOD,RRETOUR)
Value Char RCOD
Variable Integer RRETOUR

# RRETOUR = 0 correct
# RRETOUR = 1 type incorrect
# RRETOUR = 3 n existe plus

RRETOUR = 0

# on lit
Read [ADLK]ADLV0 =RCOD
If fstat = 0
       If [F:ADLK]ADLVTYP <> 2
              RRETOUR = 1
       Endif
Else
    RRETOUR = 3
Endif

End


########################################################################################
Subprog READ_ACTIV (RCOD,RTYPE,RRETOUR)
Value Char RCOD
Value Char RTYPE
Variable Integer RRETOUR

# RTYPE pour type de code act
# RTYPE = F pour fonctionnel : options et localisations
# RTYPE = D pour dimension : dimensionnement

# on part du principe que c est deja mauvais et que type est incorrect
# RRETOUR = 0 correct
# RRETOUR = 1 type incorrect
# RRETOUR = 2 dependance ncorrecte
# RRETOUR = 3 n existe pas

RRETOUR = 1
# on lit les codes activités avant et on regarde si tjs coherent
Read [ACV]CODACT =RCOD
If fstat = 0
        If RTYPE = "F"
            If [F:ACV]TYP <> 2 and [F:ACV]DEP = 1
                    RRETOUR = 0
            Elsif [F:ACV]TYP <> 2 and [F:ACV]DEP <> 1
                    RRETOUR = 2
            Endif
        Elsif RTYPE = "D"
            If [F:ACV]TYP = 2 and [F:ACV]DEP = 1
                    RRETOUR = 0
            Elsif [F:ACV]TYP = 2 and [F:ACV]DEP <> 1
                    RRETOUR = 2
            Endif
        Endif
Else
    RRETOUR = 3
Endif

End

########################################################################################
Subprog READ_ADOPAR (RCOD,RTYPPARAM,RRETOUR)
Value Char RCOD
Value Libelle RTYPPARAM
Variable Integer RRETOUR

# RRETOUR = 0 correct
# RRETOUR = 1 type incorrect , a changé
# RRETOUR = 2 saisie pas possible
# RRETOUR = 3 n existe pas

RRETOUR = 0
# on lit le parametre avant et on regarde si tjs coherent
Read [ADP]ADP1 = RCOD
If fstat = 0
    RRETOUR = 0
    # test du type et du param modifiable
   If [F:ADP]MODIF <> 2
        RRETOUR = 2
   Elsif RTYPPARAM <>0
        If [F:ADP]TYPVAL <>RTYPPARAM
            RRETOUR = 1
        Endif
   Endif
Else
    RRETOUR = 3
Endif
End


########################################################################################
Subprog READ_ADOVAL (RLEG,RPARAM,RVALADS,RRETOUR)
Value Char RLEG
Value Char RPARAM
Variable Char    RVALADS
Variable Integer RRETOUR
# code retour RRETOUR
# RRETOUR = 0  correct
# RRETOUR = 1  incorrect
# on ne peut pas utiliser le sous programme ADOVAL car lit en fct de la leg de la societe ou de la leg en cours.
RRETOUR = 0
Read [ADW]ADW0 = "";"";RPARAM
If fstat = 0
    If RLEG <> ""
        Read [ADW]ADW0 = "*";RLEG;RPARAM
        If fstat = 0
            RVALADS = [F:ADW]VALEUR
        Endif
    Else
            RVALADS = [F:ADW]VALEUR
    Endif
Else
    RRETOUR = 1
Endif

End



########################################################################################
Subprog READ_FONCTION (RCOD,RBDG,RRETOUR)
Value Char RCOD
Value Char RBDG
Variable Integer RRETOUR

# RCODE =  code fonction
# RBDG  = code bagde

# on part du principe que c est deja mauvais et que badge est incorrect
# RRETOUR = 0 correct
# RRETOUR = 1 code badge incorrect
# RRETOUR = 2 code fonction n est plus une fct mais un menu
# RRETOUR = 3 code fonction n existe pas

RRETOUR = 1
# on lit les codes fcts avant et on regarde si tjs coherent
Read [AFC]CODINT =RCOD
If fstat = 0
    If [F:AFC]TYPTRAIT <>1
        RRETOUR = 2
    Else
        # lecture du code bagde
        Read [ADI]CODE= 83;RBDG
        If fstat = 0
            RRETOUR = 0
        Endif
    Endif
Else
    RRETOUR = 3
Endif

End


########################################################################################
Subprog READ_ASHW (RCOD,RBDG,RRETOUR)
Value Char RCOD
Value Char RBDG
Variable Integer RRETOUR

# RCODE =  code representation
# RBDG  = code bagde

# on part du principe que c est deja mauvais et que badge est incorrect
# RRETOUR = 0 correct
# RRETOUR = 1 code representation incorrect
# RRETOUR = 2 code representation n est plus une representation principale mais une rep enfant
# RRETOUR = 3 code representation n existe pas

RRETOUR = 1
# on lit les codes representation avant et on regarde si tjs coherent
Read [ASW]ASW0 =RCOD
If fstat = 0
    If [F:ASW]TYPREP <>1
        RRETOUR = 2
    Else
        # lecture du code bagde
        Read [ADI]CODE= 83;RBDG
        If fstat = 0
            RRETOUR = 0
        Endif
    Endif
Else
    RRETOUR = 3
Endif

End



########################################################################################
Subprog READ_MODELE (RCOD,RFILE,RRETOUR)
Value Char RCOD
Value Char RFILE
Variable Integer RRETOUR

# RCODE =  code modele
# RFILE  = code table ou vide
# si rfile vide c'est qu on se trouve en saisie du code modele donc pas de test sur le code fichier


# RRETOUR = 0 correct
# RRETOUR = 1
# RRETOUR = 2 code table a changer ou incorrect
# RRETOUR = 3 code modele n existe pas
# RRETOUR = 4 modele inactif
# RRETOUR = 5 type incorrect

RRETOUR = 0
# lecture modele
#

Read [AWM]AWM0 = RCOD
If fstat <> 0
    #"prob modele n existe plus"
    RRETOUR  = 3
Elsif [F:AWM]ENAFLG <> 2
    #"prob modele n est plus actif"
    RRETOUR = 4
Elsif [F:AWM]FLGAPH <> 2
    #"prob type modele n est plus modele et/ou livrable"
    RRETOUR = 5
Elsif [F:AWM]FLGADLV <> 2
    #"prob type modele n est plus modele et/ou livrable"
    RRETOUR = 5
Elsif RFILE <> ""
    If [F:AWM]TABREF <> RFILE
        # vois si on reste aussi le typ de livraison sur la table et docn lecture de atb
        #"prob modele n est plus conforme"
        RRETOUR = 2
    Endif
Endif
End

########################################################################################
Subprog READ_SESSION (RSES,RDVC,RRETOUR)
Value Char RSES
Value Char RDVC
Variable Integer RRETOUR

# Rses =  type session
# Rdvc  = device

# on part du principe que c est deja mauvais et que session est incorrect
# RRETOUR = 0 correct
# RRETOUR = 1 code session/device incorrect
# RRETOUR = 2 code session n existe plus
# RRETOUR = 3 code device  n existe plus

RRETOUR = 1
# lecture du type session en premier
Read [ADI]CODE= 924;RSES
If fstat = 0
    Read [ADI]CODE= 928;RDVC
    If fstat = 0
        RRETOUR  = 0
    Else
        RRETOUR = 3
    Endif
Else
    RRETOUR = 2
Endif

End


########################################################################################
Subprog READ_LIMITES (RFNCLIM,RTYPFNCLIM,RPDT,RRETOUR)
Value Char       RFNCLIM
Value Char       RTYPFNLIM
Value Integer    RPDT
Variable Integer RRETOUR

# si type est vide , on controle que le premier code

# on part du principe que c est deja mauvais
# RRETOUR = 0 correct
# RRETOUR = 1 limites/licence  type incorrect, n est plus sur le meme produiT
#              c cas n existe plus on a mis la table en special produit
# RRETOUR = 2 code limites n existe plus
# RRETOUR = 3 code type n existe plus

RRETOUR = 1
# lecture du type session en premier
Read [ADI]CODE= 926;RFNCLIM
If fstat = 0
     If RTYPFNCLIM <> ""
           Read [ADI]CODE= 925;RTYPFNCLIM
           If fstat <> 0
               RRETOUR  = 3
           Else
               RRETOUR  = 0
           Endif
      Else
           RRETOUR  = 0
      Endif
Else
    RRETOUR = 2
Endif

End

########################################################################################
Subprog HISTO_ADLV (RDELIVER,RNBR_ERRORS,RTYP)
Value Char RDELIVER
Variable Integer RNBR_ERRORS
Value Char RTYP
#--------------------------------------------------------------------#
# pre requis
# il faut que le record soit lu.....dans classe [f:ADLV]
# lancer à la demande
# bouton dans fenetre oadvl , fct n est pas possible en batch
#
# le type  RTYP = ""  pour un seul , on ouvre trace et lectrace
# la variable rnbr_errors contient le nombre d erreurs detectés
#--------------------------------------------------------------------#

# nbre erreur trouvé
RNBR_ERRORS = 0

Local Integer WOK
Local Integer WIND
Local Char WMESSAGE (250)
Local Char WINTIT(30)
Local Char WTABDES(30)
Local Integer WRETOUR
Local Char WERROR_GLOBLAN (2)

If GSERVEUR
    End
Endif
If [M]RPBUSR <> GUSER
    # cas ou le user n est pas le reponsable du livrable
    #----- voulez-vous continuer ? -----#
    Call AVERTIR(mess(94,7999,1),WOK) From GESECRAN
    If WOK=1 : End : Endif
Endif

# ouverture des fichiers pour copie
Local File ADELIVER    [HADLV]
Local File ADELIVERD   [HADLD]
Local File ADELIVERP   [HADLP]
Local File ADELIVERO   [HADLO]
Local File ADELIVERB   [HADLB]
Local File ADELIVERT   [HADLT]
Local File ADELIVERL   [HADLL]
Local File ADELIVERR   [HADLR]


#mess --->historisation pour le livrable
If GFONCTION <> "GESADLK"
     Call OUVRE_TRACE(mess(95,7999,1)) From LECFIC
Else
     Call OUVRE_TRACE(mess(96,7999,1)) From LECFIC
Endif

If clalev([F:ADLV])=0
    #mess --->Mauvais paramètre
    Call ECR_TRACE(mess(97,7999,1),1) From GESECRAN
    RNBR_ERRORS += 1
    Goto FIN_HISTO
Elsif [F:ADLV]COD <> RDELIVER
    #mess --->Mauvais paramètre
    Call ECR_TRACE(mess(97,7999,1),1) From GESECRAN
    RNBR_ERRORS += 1
    Goto FIN_HISTO
Elsif RTYP <> ""
    Call ECR_TRACE(mess(97,7999,1),1) From GESECRAN
    RNBR_ERRORS += 1
    Goto FIN_HISTO
Elsif len(RDELIVER) > 15
    # le code du livrable depasse les 16 on va avoir un  soucis
    # le type de donnes est 20 et dans ecran la saisie est 15 ce qui est normal...
    Call ECR_TRACE(mess(98,7999,1),1) From GESECRAN
    RNBR_ERRORS += 1
    Goto FIN_HISTO
Endif

#mess --->hsito pour le(s) livrable(s)
If [F:ADLV]ADLVTYP = 2
        Call ECR_TRACE(mess(96,7999,1),0) From GESECRAN
Else
        Call ECR_TRACE(mess(95,7999,1),0) From GESECRAN
Endif
Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN

If [F:ADLV]ADLVTYP = 2
    Call ECR_TRACE(mess(68,7999,1)-RDELIVER,0) From GESECRAN
Else
    Call ECR_TRACE(mess(51,7999,1)-RDELIVER,0) From GESECRAN
Endif

Call ECR_TRACE("  ",0) From GESECRAN

If [F:ADLV]ENAFLG <> 2
    #mess --->doit etre actif
    If [F:ADLV]ADLVTYP = 2
        Call ECR_TRACE(mess(78,7999,1),1) From GESECRAN
    Else
        Call ECR_TRACE(mess(62,7999,1),1) From GESECRAN
    Endif
    RNBR_ERRORS += 1
    Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
    Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
    Goto FIN_HISTO
Endif

# on lance la verif avant mais sans trace
# et si des erreurs on interdit l historisation
Local Integer WNBR_ERRORS
WNBR_ERRORS = 0
Call CHECK_DELIVER ([F:ADLV]COD,WNBR_ERRORS,"S")
If  WNBR_ERRORS <> 0
    #mess --->corriger il y a des erreurs
    If [F:ADLV]ADLVTYP = 2
        Call ECR_TRACE(mess(79,7999,1),1) From GESECRAN
    Else
        Call ECR_TRACE(mess(63,7999,1),1) From GESECRAN
    Endif
    RNBR_ERRORS += 1
    Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
    Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
    Goto FIN_HISTO
Endif

# historisation pour livrable, pour les kits
# code livrable sur 20 mias à la saisie c est 15 de maniere a pouvoir ajouter le code de histo
Local Char WHISTO (3)
Local Char WCOD(20)

WHISTO = "V"+right$(ctrans(GVERSION,".",""),2)
WCOD=RDELIVER+"~"+WHISTO
Read [HADLV]=WCOD
If fstat = 0
    Call ECR_TRACE(mess(99,7999,1),1) From GESECRAN
    RNBR_ERRORS += 1
    Goto FIN_HISTO
Endif
GOK = 1
Trbegin [HADLV],[HADLD],[HADLP],[HADLO],[HADLB],[HADLT],[HADLL],[HADLR]
    [F:HADLV]    =[F:ADLV]
    [F:HADLV]COD =WCOD
    Write [HADLV]
    If fstat
          GOK = 0 : Call FSTA("HADLV") From GLOCK
    Endif
    If GOK<1 : Goto HISTO_SUITE : Endif

    Filter [ADLD] Where COD=RDELIVER
    For [ADLD]
        [F:HADLD]    =[F:ADLD]
        [F:HADLD]COD =[F:HADLV]COD
        Write [HADLD]
        If fstat
              GOK = 0 : Call FSTA("HADLD") From GLOCK
              Break
        Endif
    Next
    Filter [ADLD]
    If GOK<1 : Goto HISTO_SUITE : Endif

    Filter [ADLP] Where COD=RDELIVER
    For [ADLP]
        [F:HADLP]    =[F:ADLP]
        [F:HADLP]COD =[F:HADLV]COD
        Write [HADLP]
        If fstat
              GOK = 0 : Call FSTA("HADLP") From GLOCK
              Break
        Endif
    Next
    Filter [ADLP]
    If GOK<1 : Goto HISTO_SUITE : Endif

    Filter [ADLO] Where COD=RDELIVER
    For [ADLO]
        [F:HADLO]    =[F:ADLO]
        [F:HADLO]COD =[F:HADLV]COD
        Write [HADLO]
        If fstat
              GOK = 0 : Call FSTA("HADLO") From GLOCK
              Break
        Endif
    Next
    Filter [ADLO]
    If GOK<1 : Goto HISTO_SUITE : Endif

    Filter [ADLB] Where COD=RDELIVER
    For [ADLB]
        [F:HADLB]    =[F:ADLB]
        [F:HADLB]COD =[F:HADLV]COD
        Write [HADLB]
        If fstat
              GOK = 0 : Call FSTA("HADLB") From GLOCK
              Break
        Endif
    Next
    Filter [ADLB]
    If GOK<1 : Goto HISTO_SUITE : Endif

    Filter [ADLT] Where COD=RDELIVER
    For [ADLT]
        [F:HADLT]    =[F:ADLT]
        [F:HADLT]COD =[F:HADLV]COD
        Write [HADLT]
        If fstat
              GOK = 0 : Call FSTA("HADLT") From GLOCK
              Break
        Endif
    Next
    Filter [ADLT]
    If GOK<1 : Goto HISTO_SUITE : Endif

    Filter [ADLL] Where COD=RDELIVER
    For [ADLL]
        [F:HADLL]    =[F:ADLL]
        [F:HADLL]COD =[F:HADLV]COD
        Write [HADLL]
        If fstat
              GOK = 0 : Call FSTA("HADLL") From GLOCK
              Break
        Endif
    Next
    Filter [ADLL]
    If GOK<1 : Goto HISTO_SUITE : Endif

    Filter [ADLR] Where COD=RDELIVER
    For [ADLR]
        [F:HADLR]    =[F:ADLR]
        [F:HADLR]COD =[F:HADLV]COD
        Write [HADLR]
        If fstat
              GOK = 0 : Call FSTA("HADLR") From GLOCK
              Break
        Endif
    Next
    Filter [ADLR]
    If GOK<1 : Goto HISTO_SUITE : Endif

    Call MAJTEXTRA([M]DLVDES,"ADELIVER","DLVDES",[F:HADLV]COD,"") From ATEXTRA

$HISTO_SUITE
If GOK<1
    Rollback
Else
    Commit
Endif


Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN

$FIN_HISTO
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
GMESSAGE= ""


Close Local File [HADLV],[HADLD],[HADLP],[HADLO],[HADLB],[HADLT],[HADLL],[HADLR]

End

########################################################################################
Subprog CHECK_DELIVER (RDELIVER,RNBR_ERRORS,RTYP)
Value Char RDELIVER
Variable Integer RNBR_ERRORS
Value Char RTYP

#--------------------------------------------------------------------#
# controle de la cohérence du paramètrage
# pre requis
# il faut que le record soit lu.....dans classe [f:ADLV]
# lancer à la demande ou par une action avant de faire la version
# bouton dans fenetre oadvl ou oadlk
#
# le type  RTYP = "T" pour tous les livrables ou kits et donc ouvre trace est deja fait
#          RTYP = ""  pour un seul , on ouvre trace et lectrace
#          RTYP = "S"  pas de trace à ouvrir ou ecrire
# la variable rnbr_errors contient le nombre d erreurs detectés
#--------------------------------------------------------------------#

# nbre erreur trouvé
RNBR_ERRORS = 0


Local Integer WOK
Local Integer WIND
Local Char WMESSAGE (250)
Local Char WINTIT(30)
Local Char WTABDES(30)

Local Integer WRETOUR
Local Char WOLD_TABCOD(GLONATB)


If !GSERVEUR
   If RTYP = ""
       #mess --->Vérification cohérence pour le livrable
       If GFONCTION <> "GESADLK"
           Call OUVRE_TRACE(mess(16,7999,1)) From LECFIC
       Else
           Call OUVRE_TRACE(mess(67,7999,1)) From LECFIC
       Endif
   Endif
Endif

If clalev([F:ADLV])=0
    #mess --->Mauvais paramètre pour la Vérification cohérence
    If RTYP <> "S"
        Call ECR_TRACE(mess(17,7999,1),1) From GESECRAN
    Endif
    RNBR_ERRORS += 1
    Goto FIN_CHECK
Elsif [F:ADLV]COD <> RDELIVER
    #mess --->Mauvais paramètre pour la Vérification cohérence
    If RTYP <> "S"
        Call ECR_TRACE(mess(17,7999,1),1) From GESECRAN
    Endif
    RNBR_ERRORS += 1
    Goto FIN_CHECK
Endif

If RTYP = ""
    #mess --->Vérification cohérence pour le(s) livrable(s)
    If [F:ADLV]ADLVTYP = 2
        Call ECR_TRACE(mess(67,7999,1),0) From GESECRAN
    Else
        Call ECR_TRACE(mess(16,7999,1),0) From GESECRAN
    Endif
    Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
    Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
Endif
If RTYP <> "S"
    If [F:ADLV]ADLVTYP = 2
        Call ECR_TRACE(mess(68,7999,1)-RDELIVER,0) From GESECRAN
    Else
        Call ECR_TRACE(mess(51,7999,1)-RDELIVER,0) From GESECRAN
    Endif
    Call ECR_TRACE("  ",0) From GESECRAN
Endif


#-------------------------
# pas de module pour les kits
# pas de controle de leg et de langue pour les kits
#-------------------------
If [F:ADLV]ADLVTYP <> 2
    #-------------------------
    # Controle du module
    #-------------------------
    If RTYP <> "S"
        Call ECR_TRACE(mess (19,7999,1)-":",0) From GESECRAN
    Endif
    If dim ([F:ADLV]MODULE) < len(mess(0,14,1))
        #-------------------------------------------#
        # attention , les modules peuvent évolués en cours de route..
        # il faut etre capable de les detecter et les tracer
        # ce n est pas une erreur
        #-------------------------------------------#
        # message : Pour information, des modules ont été ajoutés
        If RTYP <> "S"
            Call ECR_TRACE("   "+mess(261,125,1),0) From GESECRAN
        Endif
    Else
        # message : correct
        If RTYP <> "S"
            Call ECR_TRACE("   "-mess(52,7999,1),0) From GESECRAN
        Endif
    Endif
    If RTYP <> "S"
        Call ECR_TRACE("  ",0) From GESECRAN
    Endif

    #-------------------------------------------#
    # Il doit y avoir au moins 1 langue
    #-------------------------------------------#
    If RTYP <> "S"
        Call ECR_TRACE(mess (20,7999,1)-":",0) From GESECRAN
    Endif
    WOK = 0
    For WIND = 0 To dim ([F:ADLV]LAN)-1
        If [F:ADLV]LAN (WIND) <> ""
            WOK = 1
            Break
        Endif
    Next
    If WOK = 0
        If RTYP <> "S"
            Call ECR_TRACE("   "-mess(8,125,1),1) From GESECRAN
        Endif
        RNBR_ERRORS += 1
    Else
        # message : correct
        If RTYP <> "S"
            Call ECR_TRACE("   "-mess(52,7999,1),0) From GESECRAN
        Endif
    Endif
    If RTYP <> "S"
        Call ECR_TRACE("  ",0) From GESECRAN
    Endif

    #-------------------------------------------#
    # Il doit y avoir au moins 1 leg
    #-------------------------------------------#
    WOK = 0
    If RTYP <> "S"
        Call ECR_TRACE(mess (21,7999,1)-":",0) From GESECRAN
    Endif
    For WIND = 0 To dim ([F:ADLV]DOSLEG)-1
        If [F:ADLV]DOSLEG (WIND) <> ""
            WOK = 1
            Break
        Endif
    Next
    If WOK = 0
        #"Une leg doit etre saisie"
        If RTYP <> "S"
            Call ECR_TRACE("   "-mess (241,133,1),1) From GESECRAN
        Endif
        RNBR_ERRORS += 1
    Else
        # message : correct
        If RTYP <> "S"
            Call ECR_TRACE("   "-mess(52,7999,1),0) From GESECRAN
        Endif
    Endif
    If RTYP <> "S"
        Call ECR_TRACE("  ",0) From GESECRAN
    Endif
Endif


#-------------------------
# Controle des codes act  typ 1 ou 3 (options ou localisation)
#------------------------#
#----------------------#
# On lit les codes
#----------------------#
WOK = 0
If RTYP <> "S"
    Call ECR_TRACE(mess (22,7999,1)-":",0) From GESECRAN
Endif
Filter [ADLD] Where COD=RDELIVER and TYPACV <> 2
For [ADLD]
    WRETOUR = 0
    Call READ_ACTIV ([F:ADLD]CODACT,"F",WRETOUR) From SUBADLV
    If WRETOUR = 3
           If RTYP <> "S"
               Call ECR_TRACE(num$([F:ADLD]CODACT)-":"-mess (24,7999,1),1) From GESECRAN
           Endif
           RNBR_ERRORS += 1
           WOK = 1
    Elsif WRETOUR =1
           If RTYP <> "S"
               Call ECR_TRACE(num$([F:ADLD]CODACT)-":"-mess (31,7999,1),1) From GESECRAN
           Endif
           RNBR_ERRORS += 1
           WOK = 1
    Elsif WRETOUR = 2
           If RTYP <> "S"
               Call ECR_TRACE(num$([F:ADLD]CODACT)-":"-mess (31,7999,1),1) From GESECRAN
           Endif
           RNBR_ERRORS += 1
           WOK = 1
    Endif
Next
Filter [ADLD]
If WOK = 0
    # message : correct
    If RTYP <> "S"
        Call ECR_TRACE("   "-mess(52,7999,1),0) From GESECRAN
    Endif
Endif

#-----------------------------
# les codes activités peuvent évolués en cours de route..
# nouveaux codes act unqiuement ceux en options ou localisations
#-------------------------------------------#
WOK = 0
Filter [ACV] Where TYP <> 2 and CODACT < "X" and DEP = 1
For [ACV]
    Read [ADLD]ADLD0 =RDELIVER;[F:ACV]CODACT
    If fstat <> 0
        # "nouveaux codes act ------en vert
        If RTYP <> "S"
            Call ECR_TRACE(num$([F:ACV]CODACT)-mess (189,126,1),-1) From GESECRAN
        Else
           # comme pas de trace on signale en erreur
           RNBR_ERRORS += 1
        Endif
    Endif
Next
Filter [ACV]
If RTYP <> "S"
    Call ECR_TRACE("  ",0) From GESECRAN
Endif

#-------------------------
# Controle des codes de dim typ 2
#------------------------#
#----------------------#
# On lit les codes
#----------------------#
WOK = 0
If RTYP <> "S"
    Call ECR_TRACE(mess (23,7999,1)-":",0) From GESECRAN
Endif
Filter [ADLD] Where COD=RDELIVER and TYPACV = 2
For [ADLD]
    WRETOUR = 0
    Call READ_ACTIV ([F:ADLD]CODACT,"D",WRETOUR) From SUBADLV
    If WRETOUR = 3
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLD]CODACT)-":"-mess (24,7999,1),1) From GESECRAN
            Endif
            RNBR_ERRORS += 1
            WOK = 1
    Elsif WRETOUR = 1
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLD]CODACT)-":"-mess (32,7999,1),1) From GESECRAN
            Endif
            RNBR_ERRORS += 1
            WOK = 1
    Elsif WRETOUR = 2
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLD]CODACT)-":"-mess (31,7999,1),1) From GESECRAN
            Endif
            RNBR_ERRORS += 1
            WOK = 1
    Endif
Next
Filter [ADLD]
If WOK = 0
    # message : correct
    If RTYP <> "S"
        Call ECR_TRACE("   "-mess(52,7999,1),0) From GESECRAN
    Endif
Endif
If RTYP <> "S"
    Call ECR_TRACE("  ",0) From GESECRAN
Endif


#-------------------------
# Controle des paramètres
#------------------------#
#----------------------#
# On lit les codes
#----------------------#
WOK = 0
If RTYP <> "S"
    Call ECR_TRACE(mess (25,7999,1)-":",0) From GESECRAN
Endif
Filter [ADLP] Where COD=RDELIVER
For [ADLP]
    WRETOUR = 0
    Call READ_ADOPAR ([F:ADLP]PARAM,0,WRETOUR)
    If WRETOUR = 3
        If RTYP <> "S"
            Call ECR_TRACE(num$([F:ADLP]PARAM)-":"-mess (24,7999,1),1) From GESECRAN
        Endif
        RNBR_ERRORS += 1
        WOK = 1
    Else
        #--------------------------#
        # controle leg sur param
        #--------------------------#
        If [F:ADLP]CLEPARAM <> ""
           #--------------------------#
           # test pour voir si le niveau de def du param a changé
           # ex si on a saisie un param avec une leg et que le pram a entre temps changé de niveau
           # si niveau def = 1 ---> LE Param est DEVENU DOSSIER et donc on signale
           #--------------------------#
            If [F:ADP]NIVDEF = 1
                If RTYP <> "S"
                    Call ECR_TRACE(num$([F:ADLP]PARAM)-":"-mess (34,7999,1),1) From GESECRAN
                Endif
                RNBR_ERRORS += 1
                WOK = 1
            Else
                # pas de leg sur le kit
                If [F:ADLV]ADLVTYP <> 2
                    If !find([F:ADLP]CLEPARAM,[F:ADLV]DOSLEG(0..39))
                        # "Une leg a été saisie sur un param et n existe plus dans le tableau"
                        GMESSAGE= func AFNC.MES2(mess(132,127,1),num$([F:ADLP]CLEPARAM),num$([F:ADLP]CLEPARAM))
                        If RTYP <> "S"
                            Call ECR_TRACE(num$([F:ADLP]PARAM)-":"-GMESSAGE,1) From GESECRAN
                        Endif
                        GMESSAGE  =""
                        RNBR_ERRORS += 1
                        WOK = 1
                    Endif
                Endif
            Endif
        Endif
    Endif
Next
Filter [ADLP]
If WOK = 0
    # message : correct
    If RTYP <> "S"
        Call ECR_TRACE("   "-mess(52,7999,1),0) From GESECRAN
    Endif
Endif
If RTYP <> "S"
    Call ECR_TRACE("  ",0) From GESECRAN
Endif
#-------------------------
# Controle des valeurs de paramètres
# on verifie que la valeur saisie est tjs correcte par rapport au param
# on verifie aussi le type
#------------------------#
WOK = 0
If RTYP <> "S"
    Call ECR_TRACE(mess (29,7999,1)-":",0) From GESECRAN
Endif
Filter [ADLP] Where COD=RDELIVER
For [ADLP]
    WRETOUR = 0
    Call READ_ADOPAR ([F:ADLP]PARAM,[F:ADLP]TYPPARAM,WRETOUR)
    If WRETOUR = 0
        Local Integer WWOK
        WWOK = 0
        WMESSAGE = ""
        Call CTRL_VALPARAM ([F:ADLP]PARAM,[F:ADLP]VALPARAM,[F:ADLP]CLEPARAM,WWOK,WMESSAGE)
        If WWOK <> 0
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLP]PARAM)-":"-mess (83,123,1),1) From GESECRAN
            Endif
            RNBR_ERRORS += 1
            WOK = 1
        Endif
    Elsif WRETOUR = 2
        If RTYP <> "S"
            Call ECR_TRACE(num$([F:ADLP]PARAM)-":"-mess (59,143,1),1) From GESECRAN
        Endif
        RNBR_ERRORS += 1
        WOK = 1
    Elsif WRETOUR = 1
        If RTYP <> "S"
            Call ECR_TRACE(num$([F:ADLP]PARAM)-":"-mess (33,7999,1),1) From GESECRAN
        Endif
        RNBR_ERRORS += 1
        WOK = 1
    Endif
Next
Filter [ADLP]
If WOK = 0
    # message : correct
    If RTYP <> "S"
        Call ECR_TRACE("   "-mess(52,7999,1),0) From GESECRAN
    Endif
Endif
If RTYP <> "S"
    Call ECR_TRACE("  ",0) From GESECRAN
Endif

#-------------------------
# Controle des cles fichiers
# en fct des modeles
# verif couple : modele-tabekl unique
# verif si table diverse que c'est tjs le même modele sur toute les lignes de atabdiv
#-------------------------------------------#
WOK = 0
If RTYP <> "S"
    Call ECR_TRACE(mess (26,7999,1)-":",0) From GESECRAN
Endif
Filter [ADLO] Where COD=RDELIVER
#For [ADLO]ADLO0 (2)
# lecture sur table+modele
WOLD_TABCOD = ""
For [ADLO]ADLO1 (3)
    WRETOUR = 0
    Call READ_MODELE ([F:ADLO]TABAWM,[F:ADLO]TABCOD,WRETOUR)
    If WRETOUR = 0
        WMESSAGE = ""
        Gosub READ_FILE
        If WMESSAGE <> ""
                If RTYP <> "S"
                    Call ECR_TRACE(WMESSAGE,1) From GESECRAN
                Endif
                RNBR_ERRORS += 1
                WOK = 1
                If RTYP <> "S"
                    Call ECR_TRACE(mess (46,7999,1),0) From GESECRAN
                Endif
        Endif
        # verif unicité du couple modele-table
        If WOLD_TABCOD <> "" and [F:ADLO]TABCOD = WOLD_TABCOD
                # prob
                RNBR_ERRORS += 1
                WOK = 1
                If RTYP <> "S"
                    # message couple modele table non unique
                    Call ECR_TRACE(num$([F:ADLO]TABAWM)-num$([F:ADLO]TABCOD)-mess (82,7999,1),1) From GESECRAN
                Endif
        Endif
    Else
        If WRETOUR = 3
            #"prob modele n existe plus"
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLO]TABAWM)-mess (7,140,1),1) From GESECRAN
            Endif
        Elsif WRETOUR = 2
            #"prob modele n est plus conforme"
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLO]TABAWM)-num$([F:ADLO]TABCOD)-mess (1,7999,1),1) From GESECRAN
                Call ECR_TRACE(mess (46,7999,1),0) From GESECRAN
            Endif
        Elsif WRETOUR = 4
            If RTYP <> "S"
                #"prob modele n est plus actif "
                Call ECR_TRACE(num$([F:ADLO]TABAWM)-num$([F:ADLO]TABCOD)-mess (44,7999,1),1) From GESECRAN
            Endif
        Elsif WRETOUR = 5
            If RTYP <> "S"
                #"prob modele n est plus conforme type incorrect "
                Call ECR_TRACE(num$([F:ADLO]TABAWM)-num$([F:ADLO]TABCOD)-mess (43,7999,1),1) From GESECRAN
            Endif
        Endif
        WOK = 1
        RNBR_ERRORS += 1
    Endif
    WOLD_TABCOD = [F:ADLO]TABCOD
Next
Filter [ADLO]
If WOK = 0
    If RTYP <> "S"
        # message : correct
        Call ECR_TRACE("   "-mess(52,7999,1),0) From GESECRAN
    Endif
Endif

If RTYP <> "S"
    Call ECR_TRACE("  ",0) From GESECRAN
Endif

#---------------------
# PAS de leg sur le kit
#---------------------
If [F:ADLV]ADLVTYP <> 2
    GMESSAGE= ""
    WOK = 0
    If RTYP <> "S"
        Call ECR_TRACE(mess (27,7999,1)-":",0) From GESECRAN
    Endif

    Filter [ADLO] Where COD=RDELIVER and TABLEG <> ""
    For [ADLO]
        #-------------------------------------------#
        # controle leg  des cles fichiers
        #-------------------------------------------#
        If !find([F:ADLO]TABLEG,[F:ADLV]DOSLEG(0..39))
            # "Une leg a été saisie sur cet objet et n existe plus dans le tableau"
            GMESSAGE= func AFNC.MES2(mess(136,127,1),num$([F:ADLO]TABLEG),num$([F:ADLO]TABCOD))
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLO]TABKEY)-":"-GMESSAGE,1) From GESECRAN
            Endif
            GMESSAGE  =""
            WOK = 1
            RNBR_ERRORS += 1
        Endif
    Next
    Filter [ADLO]
    If WOK = 0
        If RTYP <> "S"
            # message : correct
            Call ECR_TRACE("   "-mess(52,7999,1),0) From GESECRAN
        Endif
    Endif
    If RTYP <> "S"
        Call ECR_TRACE("  ",0) From GESECRAN
    Endif
Endif

#-------------------------------------------#
# controle des cles verif si existe tjs dans le fichier
#-------------------------------------------#
GMESSAGE= ""
WOK = 0
If RTYP <> "S"
    Call ECR_TRACE(mess (28,7999,1)-":",0) From GESECRAN
Endif
Filter [ADLO] Where COD=RDELIVER
For [ADLO]
    GFLGKO = 1
    If [F:ADLO]TABKEY <> "" and [F:ADLO]NULRECFLG <> 2
           Gosub READ_FILE
           # les autres erreurs sont deja dans la trace
           # là c'est uniquement les cles sur des fichiers et modeles correctes
           If GFLGKO <> 2
               WTABDES= ""
               Call RECUP_DESTAB ([F:ADLO]TABCOD, [F:ADLO]TABKEY,[F:ADLO]TABKEYFMT, WINTIT,WTABDES)
               If WTABDES = "?????????????"
                    If RTYP <> "S"
                        Call ECR_TRACE(num$([F:ADLO]TABAWM)-num$([F:ADLO]TABCOD)-num$([F:ADLO]TABKEY)-mess (24,7999,1),1) From GESECRAN
                    Endif
                    RNBR_ERRORS += 1
                    WOK = 1
               Endif
           Endif
    Endif
Next
Filter [ADLO]
If WOK = 0
    If RTYP <> "S"
        # message : correct
        Call ECR_TRACE("   "-mess(52,7999,1),0) From GESECRAN
    Endif
Endif
If RTYP <> "S"
    Call ECR_TRACE("  ",0) From GESECRAN
Endif


#---------------------
# PAS de badges sur le kit
#---------------------
If [F:ADLV]ADLVTYP <> 2
    #-------------------------
    # Controle fct/badges
    #------------------------#
    #----------------------#
    # On lit les codes
    #----------------------#
    WOK = 0
    If RTYP <> "S"
        Call ECR_TRACE(mess (41,7999,1)-":",0) From GESECRAN
    Endif
    Filter [ADLB] Where COD=RDELIVER
    For [ADLB]
        WRETOUR = 0
        Call READ_FONCTION ([F:ADLB]CODFNC,[F:ADLB]CODBDG,WRETOUR)
        If WRETOUR = 3
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLB]CODFNC)-":"-mess (24,7999,1),1) From GESECRAN
            Endif
            RNBR_ERRORS += 1
            WOK = 1
        Elsif WRETOUR = 2
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLB]CODFNC)-":"-mess (48,7999,1),1) From GESECRAN
            Endif
            RNBR_ERRORS += 1
            WOK = 1
        Elsif WRETOUR = 1
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLB]CODFNC)-num$([F:ADLB]CODBDG)-":"-mess (42,7999,1),1) From GESECRAN
            Endif
            RNBR_ERRORS += 1
            WOK = 1
        Endif
    Next
    Filter [ADLB]
    If WOK = 0
        If RTYP <> "S"
            # message : correct
            Call ECR_TRACE("   "-mess(52,7999,1),0) From GESECRAN
        Endif
    Endif
    If RTYP <> "S"
        Call ECR_TRACE("  ",0) From GESECRAN
    Endif
Endif

#---------------------
# PAS de badges sur le kit
#---------------------
If [F:ADLV]ADLVTYP <> 2
    #-------------------------
    # Controle rep/badges
    #------------------------#
    #----------------------#
    # On lit les codes
    #----------------------#
    WOK = 0
    If RTYP <> "S"
        Call ECR_TRACE(mess (92,7999,1)-":",0) From GESECRAN
    Endif
    Filter [ADLR] Where COD=RDELIVER
    For [ADLR]
        WRETOUR = 0
        Call READ_ASHW ([F:ADLR]CODASW,[F:ADLR]CODBDG,WRETOUR)
        If WRETOUR = 3
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLR]CODASW)-":"-mess (24,7999,1),1) From GESECRAN
            Endif
            RNBR_ERRORS += 1
            WOK = 1
        Elsif WRETOUR = 2
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLR]CODASW)-":"-mess (93,7999,1),1) From GESECRAN
            Endif
            RNBR_ERRORS += 1
            WOK = 1
        Elsif WRETOUR = 1
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLR]CODASW)-num$([F:ADLR]CODBDG)-":"-mess (42,7999,1),1) From GESECRAN
            Endif
            RNBR_ERRORS += 1
            WOK = 1
        Endif
    Next
    Filter [ADLR]
    If WOK = 0
        If RTYP <> "S"
            # message : correct
            Call ECR_TRACE("   "-mess(52,7999,1),0) From GESECRAN
        Endif
    Endif
    If RTYP <> "S"
        Call ECR_TRACE("  ",0) From GESECRAN
    Endif
Endif


#---------------------
# controle des sessions devices
# pas pour les kits
#---------------------
If [F:ADLV]ADLVTYP <> 2
    #----------------------#
    # On lit les codes
    #----------------------#
    WOK = 0
    If RTYP <> "S"
        Call ECR_TRACE(mess (89,7999,1)-":",0) From GESECRAN
    Endif
    Filter [ADLT] Where COD=RDELIVER
    For [ADLT]
        WRETOUR = 0
        Call READ_SESSION ([F:ADLT]CODSES,[F:ADLT]CODDVC,WRETOUR)
        If WRETOUR = 3
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLT]CODDVC)-":"-mess (24,7999,1),1) From GESECRAN
            Endif
            RNBR_ERRORS += 1
            WOK = 1
        Elsif WRETOUR = 2
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLT]CODSES)-":"-mess (85,7999,1),1) From GESECRAN
            Endif
            RNBR_ERRORS += 1
            WOK = 1
        Elsif WRETOUR = 1
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLT]CODSES)-num$([F:ADLT]CODDVC)-":"-mess (88,7999,1),1) From GESECRAN
            Endif
            RNBR_ERRORS += 1
            WOK = 1
        Endif
    Next
    Filter [ADLT]
    If WOK = 0
        If RTYP <> "S"
            # message : correct
            Call ECR_TRACE("   "-mess(52,7999,1),0) From GESECRAN
        Endif
    Endif
    If RTYP <> "S"
        Call ECR_TRACE("  ",0) From GESECRAN
    Endif
Endif

#---------------------
# controle des limites licences
# pas pour les kits
#---------------------
If [F:ADLV]ADLVTYP <> 2
    #----------------------#
    # On lit les codes
    #----------------------#
    WOK = 0
    If RTYP <> "S"
        Call ECR_TRACE(mess (90,7999,1)-":",0) From GESECRAN
    Endif
    Filter [ADLL] Where COD=RDELIVER
    For [ADLL]
        WRETOUR = 0
        Call READ_LIMITES ([F:ADLL]FNCLIM,[F:ADLL]TYPFNCLIM,[F:ADLV]PDT,WRETOUR)
        If WRETOUR = 3
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLL]FNCLIM)-":"-mess (24,7999,1),1) From GESECRAN
            Endif
            RNBR_ERRORS += 1
            WOK = 1
        Elsif WRETOUR = 2
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLL]FNCLIM)-":"-mess (87,7999,1),1) From GESECRAN
            Endif
            RNBR_ERRORS += 1
            WOK = 1
        Elsif WRETOUR = 1
            If RTYP <> "S"
                Call ECR_TRACE(num$([F:ADLL]FNCLIM)-num$([F:ADLL]TYPFNCLIM)-":"-mess (86,7999,1),1) From GESECRAN
            Endif
            RNBR_ERRORS += 1
            WOK = 1
        Endif
    Next
    Filter [ADLL]
    If WOK = 0
        If RTYP <> "S"
            # message : correct
            Call ECR_TRACE("   "-mess(52,7999,1),0) From GESECRAN
        Endif
    Endif
    If RTYP <> "S"
        Call ECR_TRACE("  ",0) From GESECRAN
    Endif
Endif

#---------------------
# controle des kits sur le livrable
#---------------------
If [F:ADLV]ADLVTYP <> 2
    WOK = 0
    If RTYP <> "S"
        Call ECR_TRACE(mess (80,7999,1)-":",0) From GESECRAN
    Endif
    #-------------------------
    # Controle  typ = 2 attention ouvrir table sur autre abrev.
    #------------------------#
    For WIND = 0 To  dim ([F:ADLV]ITYKIT)-1
        If [F:ADLV]ITYKIT (WIND) <>  ""
            WRETOUR = 0
            Call READ_ADLK ([F:ADLV]ITYKIT (WIND),WRETOUR)
            If WRETOUR = 3
                If RTYP <> "S"
                    Call ECR_TRACE(num$([F:ADLV]ITYKIT(WIND))-":"-mess (24,7999,1),1) From GESECRAN
                Endif
                RNBR_ERRORS += 1
                WOK = 1
            Elsif WRETOUR = 1
                If RTYP <> "S"
                    Call ECR_TRACE(num$([F:ADLV]ITYKIT (WIND))-":"-mess (81,7999,1),1) From GESECRAN
                Endif
                RNBR_ERRORS += 1
                WOK = 1
            Endif
        Endif
    Next WIND
    If WOK = 0
        If RTYP <> "S"
            # message : correct
            Call ECR_TRACE("   "-mess(52,7999,1),0) From GESECRAN
        Endif
    Endif
    If RTYP <> "S"
        Call ECR_TRACE("  ",0) From GESECRAN
    Endif

Endif




If RTYP <> "S"
    Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
    Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
Endif

$FIN_CHECK
If !GSERVEUR
    If RTYP = ""
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
Endif
GMESSAGE= ""

End

########################################################################################
Subprog CHECK_ALL_ADLV (RRET,RTYP)
Value Integer RRET
Value Integer RTYP

# rtyp = 1 pour les livrables
# rtyp = 2 pour les kits

# controle tous les livrables actifs ou kits
# sous prog appelé aussi dans la fct batch AVERIFADLV


Local Integer WNBR_ERRORS
# il faut que la table adelivere soit ouverte en ADLV idem avec les fichiers filles
# commun au check_all_adlv et json_all_adlv
Gosub DECLARE_ADLV_FILES

If !GSERVEUR
    #mess --->Vérification cohérence pour livrable actifs ou kits
    If RTYP = 2
        Call OUVRE_TRACE(mess(66,7999,1)) From LECFIC
    Else
        Call OUVRE_TRACE(mess(55,7999,1)) From LECFIC
    Endif
Endif
#mess --->Vérification cohérence pour le(s) livrable(s)
If RTYP = 2
    Call ECR_TRACE(mess(66,7999,1),0) From GESECRAN
Else
    Call ECR_TRACE(mess(55,7999,1),0) From GESECRAN
Endif

Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN

# filtre sur le type livrable : kit ou livrable
Filter [ADLV] Where ENAFLG = 2 and ADLVTYP = RTYP
For [ADLV]
    WNBR_ERRORS = 0
    # mais pas sur les histo
    If !pat ([F:ADLV]COD,"*~*")
        Call CHECK_DELIVER ([F:ADLV]COD,WNBR_ERRORS,"T")
    Endif
Next
Filter [ADLV]

If !GSERVEUR
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif
End

########################################################################################
Subprog JSON_ALL_ADLV (RRET,RTYP)
Value Integer RRET
Value Integer RTYP

# rtyp = 1 pour les livrables
# rtyp = 2 pour les kits


# generation sur tous les livrables actifs
# sous prog appelé aussi dans la fct batch AJSONADLV

Local Integer WNBR_ERRORS

# il faut que la table adelivere soit ouverte en ADLV idem avec les fichiers filles
# commun au check_all_adlv et json_all_adlv
Gosub DECLARE_ADLV_FILES


If !GSERVEUR
    #mess --->Génération json pour livrable ou kits  actifs
    If RTYP = 2
        Call OUVRE_TRACE(mess(76,7999,1)) From LECFIC
    Else
        Call OUVRE_TRACE(mess(58,7999,1)) From LECFIC
    Endif
Endif
#mess --->Génération json pour livrable  ou kits actifs
If RTYP = 2
    Call ECR_TRACE(mess(76,7999,1),0) From GESECRAN
Else
    Call ECR_TRACE(mess(58,7999,1),0) From GESECRAN
Endif

Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN

# filtre sur le livrables
Filter [ADLV] Where ENAFLG = 2 and ADLVTYP = RTYP
For [ADLV]
    WNBR_ERRORS = 0
    # mais pas sur les histo
    If !pat ([F:ADLV]COD,"*~*")
        Call JSON_ADLV ([F:ADLV]COD,WNBR_ERRORS,"T")
    Endif
Next
Filter [ADLV]

If !GSERVEUR
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif
End

########################################################################################
Subprog JSON_ADLV (RDELIVER,RNBR_ERRORS,RTYP)
Value Char RDELIVER
Variable Integer RNBR_ERRORS
Value Char RTYP
#--------------------------------------------------------------------#
# pre requis
# il faut que le record soit lu.....dans classe [f:ADLV]
# lancer à la demande ou par une action avant de faire la version
# bouton dans fenetre oadvl
#
# le type  RTYP = "T" pour tous les livrables ou kits et donc ouvre trace est deja fait
#          RTYP = ""  pour un seul , on ouvre trace et lectrace
# la variable rnbr_errors contient le nombre d erreurs detectés
#--------------------------------------------------------------------#

# nbre erreur trouvé
RNBR_ERRORS = 0

Local Integer WOK
Local Integer WIND
Local Char WMESSAGE (250)
Local Char WINTIT(30)
Local Char WTABDES(30)
Local Integer WRETOUR
Local Char WERROR_GLOBLAN (2)

If !GSERVEUR
   If RTYP = ""
       #mess --->generation json  pour le livrable
       If GFONCTION <> "GESADLK"
           Call OUVRE_TRACE(mess(59,7999,1)) From LECFIC
       Else
           Call OUVRE_TRACE(mess(77,7999,1)) From LECFIC
       Endif
   Endif
Endif

If clalev([F:ADLV])=0
    #mess --->Mauvais paramètre pour generation
    Call ECR_TRACE(mess(60,7999,1),1) From GESECRAN
    RNBR_ERRORS += 1
    Goto FIN_JSON
Elsif [F:ADLV]COD <> RDELIVER
    #mess --->Mauvais paramètre
    Call ECR_TRACE(mess(60,7999,1),1) From GESECRAN
    RNBR_ERRORS += 1
    Goto FIN_JSON
Endif

If RTYP <> "T"
    #mess --->generation json pour le(s) livrable(s)
    If [F:ADLV]ADLVTYP = 2
        Call ECR_TRACE(mess(77,7999,1),0) From GESECRAN
    Else
        Call ECR_TRACE(mess(59,7999,1),0) From GESECRAN
    Endif
    Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
    Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
Endif

If [F:ADLV]ADLVTYP = 2
    Call ECR_TRACE(mess(68,7999,1)-RDELIVER,0) From GESECRAN
Else
    Call ECR_TRACE(mess(51,7999,1)-RDELIVER,0) From GESECRAN
Endif

Call ECR_TRACE("  ",0) From GESECRAN

If [F:ADLV]ENAFLG <> 2
    #mess --->doit etre actif
    If [F:ADLV]ADLVTYP = 2
        Call ECR_TRACE(mess(78,7999,1),1) From GESECRAN
    Else
        Call ECR_TRACE(mess(62,7999,1),1) From GESECRAN
    Endif
    RNBR_ERRORS += 1
    Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
    Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
    Goto FIN_JSON
Endif

# on lance la verif avant mais sans trace
# et si des erreurs on interdit la generation
Local Integer WNBR_ERRORS
WNBR_ERRORS = 0
Call CHECK_DELIVER ([F:ADLV]COD,WNBR_ERRORS,"S")
If  WNBR_ERRORS <> 0
    #mess --->corriger il y a des erreurs
    If [F:ADLV]ADLVTYP = 2
        Call ECR_TRACE(mess(79,7999,1),1) From GESECRAN
    Else
        Call ECR_TRACE(mess(63,7999,1),1) From GESECRAN
    Endif
    RNBR_ERRORS += 1
    Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
    Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
    Goto FIN_JSON
Endif

# generation policy pour livrable, pas besoin pour les kits
If [F:ADLV]ADLVTYP <> 2
    WERROR_GLOBLAN =  ""
    Call WRITE_JSON_POLICY (WERROR_GLOBLAN) From AJSONADLV
    If WERROR_GLOBLAN <> ""
        #mess --->corriger il y a des erreurs
        Call ECR_TRACE(mess(63,7999,1),1) From GESECRAN
        RNBR_ERRORS += 1
        Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
        Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
        Goto FIN_JSON
    Else
        Call ECR_TRACE(mess(83,7999,1),0) From GESECRAN
    Endif
Endif
# generation settings
# cg 24 fev 2014 : on ne genere plus ce ficheir car on livre les tables
#Call WRITE_JSON_SETTINGS From AJSONADLV
#Call ECR_TRACE(mess(84,7999,1),0) From GESECRAN

Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN

$FIN_JSON
If !GSERVEUR
    If RTYP <> "T"
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
Endif
GMESSAGE= ""
End

########################################################################################
Subprog DEL_INVALID_LINES (RDELIVER,RADLVTYP,RRET)
Value Char    RDELIVER
Value Integer RADLVTYP
Value Integer RRET

Local Libelle WLOCK
Local Char WMESSAGE(250)

GOK  = 1
RRET = 0
Raz WLOCK
If RDELIVER=""
    RRET=11 : Gosub TRT_ERR_ADLV_INV
    End
Endif
If [M:ADLV6]NBRTAB = 0
        RRET=11 : Gosub TRT_ERR_ADLV_INV
        End
Endif
If clalev([F:ADLV])=0 :   Local File ADELIVER  [ADLV] : Endif

Call DEBTRANS From GLOCK

$TR_ADLV_INV
GOK=1
Trbegin ADOVAL

#-------------#
# Traitement  #
#-------------#
$ADLV_INV
#----- Contrôle lock logique -----#
Call JELOCKE("ADLV"+RDELIVER,RRET) From OBJDIV

If RRET=0
  Lock="ADLV"+RDELIVER
  If fstat   RRET=12 : Gosub TRT_ERR_ADLV_INV : End : Endif
  WLOCK=1
Else
  RRET = 0
  Raz WLOCK
Endif
#----- ouverture fichier si pas le cas
If clalev([F:ADLO]) = 0 :   Local File ADELIVERO    [ADLO] : Endif

#----- Lecture -----#
Read [ADLV]ADLV0=RDELIVER
If fstat
   GOK=0 : RRET=14 : Gosub TRT_ERR_ADLV_INV : Goto FIN_ADLV_INV
Else
    # livrable = 1
    # kit = 2
   # on reverifie que type est identique
   If [F:ADLV]ADLVTYP <> RADLVTYP
        # ne devrait pas etre possible
       GOK=0 : RRET=20 : Gosub TRT_ERR_ADLV_INV : Goto FIN_ADLV_INV
   Endif
Endif

RRET = 0
For nolign=1 To [M:ADLV6]NBRTAB
     If [M:ADLV6]FLGKO(nolign-1) = 2
        Delete [ADLO] Where COD=RDELIVER and  TABCOD =[M:ADLV6]TABCOD1(nolign-1) and TABKEYNAM = [M:ADLV6]TABKEYNAM1(nolign-1) and TABADINUM =[M:ADLV6]TABADINUM1(nolign-1)
        # Vérification si un enregistrement est locké : si oui : fin
        If fstat=1
            GOK=-1
            Call RSTA("ADLO",RDELIVER) From GLOCK
            RRET=15 : Gosub TRT_ERR_ADLV_INV
            Break
        Endif
     Endif
Next nolign

If RRET <> 0
    Goto FIN_ADLV_INV
Endif

#-----
$FIN_ADLV_INV
If WLOCK  Unlock="ADLV"+RDELIVER : Endif

If GOK=-1  Goto ROLL_ADLV_INV : Endif
If GOK=0   Goto AB_ADLV_INV   : Endif
Commit
End


#-----
$ROLL_ADLV_INV
Rollback : Call ROLL From GLOCK
If GROLL  End  Else  Goto TR_ADLV_INV : Endif
#-----
$AB_ADLV_INV
Rollback
End


#------------------------------------------------------------------------------#
#                           Traitement des erreurs                             #
# -----------------------------------------------------------------------------#
# 11 = RDELIVER Paramètre non renseigné                                        #
# 12 = $ADELIVER xxxxxxxx Modification en cours sur un autre poste             #
# 13 = Erreur d'accès sur le fichier ADELIVER xxxxxxxx                         #
# 14 = xxxxxxxxxx Erreur de lecture                                            #
# 15 = Erreur d'écriture sur le fichier ADELIVER xxxxxxxx                      #
# 16 = Erreur d'accès sur le fichier ADELIVER xxxxxxxx                         #
# 20 = Type incorrect
#------------------------------------------------------------------------------#
$TRT_ERR_ADLV_INV
Case RRET
  When 11 : WMESSAGE="RDELIVER"-mess(171,133,1)              : GOK=0
  When 12 : WMESSAGE="$ADELIVER"-RDELIVER-mess(10,100,1)     : GOK=0
  When 13 : WMESSAGE=mess(12,100,1)-"ADELIVER"-RDELIVER
  When 14 : WMESSAGE=RDELIVER-mess(49,125,1)
  When 15 : WMESSAGE=mess(13,100,1)-"ADELIVER"-RDELIVER
  When 16 : WMESSAGE=mess(12,100,1)-"ADELIVER"-RDELIVER
  When 20 : WMESSAGE=mess(74,7999,1)-"ADELIVER"-RDELIVER-"ADLVTYP"-RADLVTYP
Endcase

If GOK=1
    Call MESSAGE (WMESSAGE)    From GESECRAN
Else
    Call ERREUR (WMESSAGE)     From GESECRAN
Endif
Return


########################################################################################
Subprog RECUP_DESTAB (RNAMEFILE, RTABKEY, RTABKEYFMT, RINTIT,RTABDES)
Value Char  RNAMEFILE
Value Char  RTABKEY
Value Char  RTABKEYFMT
Value Char  RINTIT
Variable Char RTABDES

Local Char    CLE(GLONAVA)(1..16) , CHAINE(250) , VALCLE(250)
Local Integer I , J , NBCLE

If RTABKEYFMT = ""
    RTABDES = "?????????????"
Elsif RTABKEY = ""
    RTABDES = "?????????????"
Else
    CHAINE = RTABKEYFMT
    Gosub SETCLE
    CHAINE = RTABKEY

    J = 0
    While CHAINE<>""
          J += 1
          I = instr(1,CHAINE,"~")
          If I
               VALCLE = left$(CHAINE,I-1)
               CHAINE = right$(CHAINE,I+1)
          Else
               VALCLE = CHAINE
               CHAINE = ""
          Endif
          Case evalue("type([F:WWW]"+CLE(J)+")")
               When 1,2,4,5,6,7 : Assign "[F:WWW]"+CLE(J) With val(VALCLE)
               When Default     : Assign "[F:WWW]"+CLE(J) With VALCLE
          Endcase
    Wend
    Read [F:WWW] =
    If fstat = 0
       If RINTIT <> ""
         # on verifie que champ est present dans la table cas des atextra
         If evalue("dim([F:WWW]"+RINTIT+")") >= 0
             RTABDES = num$(evalue("[F:WWW]"+RINTIT))
         Else
             # cas des types AXX etc...
              Call SET_IDENT_ATEXTRA (RNAMEFILE,RINTIT,RTABDES) From SUBADLVW
         Endif
       Endif
    Else

        RTABDES = "?????????????"
    Endif
Endif
End



########################################################################################
Subprog CTRL_VALPARAM (RPARAM,RVALPARAM,RLEG,RERROR,RMESSAGE)
Value Char RPARAM
Value Char RVALPARAM
Value Char RLEG
Variable Integer RERROR
Variable Char    RMESSAGE

RERROR = 0

# voir comment etre sur que le call existe dans le prog ? et que dans ce call on ne fait pas appele a ecran
# cas trouve sur trt BICPT ou ecran ADWP est en ligne or ici il n existe pas ????????
# là on ouvre ecran ADWP pour ne pas planter les controles dans les sub
Local Mask ADWP [ADWP]
[M:ADWP]LEG = RLEG
[M:ADWP]CMP = ""
[M:ADWP]FCY = ""

Local Char    WVALINT(GLONADW)
Local Char    WVALEUR(GLONADW)
Local Char    SAV_GFONCTION(GLONAFC)

WVALEUR =  RVALPARAM
# controle valeur
# le soucis qu on a c'est que dans certaines valeurs de param comme exetax
# on appele verf_param dans un sub et dans ces derniers on teste la valeur GFONCTION
# ex dans subtvt
# donc on sauve le gfonction pour inti comme si on etait dans adpval
SAV_GFONCTION = GFONCTION
GFONCTION = "ADPVAL"
Call CTRL_VALEUR (RPARAM,RVALPARAM,RLEG,1,RERROR,RMESSAGE,WVALINT,WVALEUR) From ASAIPARVAL
GFONCTION = SAV_GFONCTION
Close Local Mask [ADWP]
End


