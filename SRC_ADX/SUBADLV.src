Subprog S_ITYKIT(VALEUR)
Variable Char    VALEUR()

## Action ASELADLV
Local Decimal BASPAG
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "ASELADLV"
PARMSK(1) = ""
PARMSK(2) = "K"
PARMSK(3) = ""
Call SAISIE_NUM(BASPAG,PARMSK,"ASELADLV","ASELADLV","") From GSAISIE
GACTION = SAVACT
If PARMSK (1 ) <> ""
    VALEUR =PARMSK (1 )
Endif
End


Subprog C_ITYKIT(VALEUR)
Variable Char    VALEUR()
# on controle que kit existe, on ne passe pas par controle objet car même abrev que les livrables
# et comme on filtre la table adlv on ne trouve jamais.
If VALEUR <> ""
    Local Integer WRETOUR
    Call READ_ADLK (VALEUR,WRETOUR) From SUBADLV
    If WRETOUR <>0
        GMESSAGE =mess (64,7999,1)
        mkstat = 2
    Else
        Call UNICITE(VALEUR,[M:ADLV4]ITYKIT(0..[M:ADLV4]NBRITY-1)) From OBJDIV
    Endif
Endif
If mkstat : End : Endif

End


Subprog C_ITYKITROW(VALEUR)
Variable Decimal VALEUR
If [M:ADLV4]ITYKIT <> "" and VALEUR = 0
    mkstat = 2
Else
    Call UNICITE(VALEUR,[M:ADLV4]ITYKITROW(0..[M:ADLV4]NBRITY-1)) From OBJDIV
    If mkstat : End : Endif
Endif

End


