#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion objet ADLV
#######################################################################################
# GESTION d un livrable GESADLV
# GESTION d un kit      GESADLK
# c'est deux fcts sont presques identiques
# on utilise les mêmes abréviations ecrans dans les deux fcts. certains ecrans ne sont pas identiques -zones invisbles
#
#
# ADELIVER sert aux livrables et aux kits. la notion de type ne fait pas parti de la clé.
# Nous ne pourrons avoir un kit de même code qu un livrable
#        type = 1 livrable
#        type = 2 kit
#
# un livrable est defini avec:
#           un code et sa désignation --  ADELIVER
#           un code produit  Sage ERP X3 , HRM management etc...
#           une  edition : Standard, premium, standard NA etc...
#           une liste de module - tous les modules - affichage de tous les codes
#           une liste de code langue : au moins une
#           une liste de legislations : au moins une
#           une liste de codes activités ,  affichage de tous les codes de typ non dimension ------ ADELIVERD
#           une liste de valuer de parametres si dfiifrentes du dossier de ref. idem pas de test sur module
#                  et on peut tous les saisir ----- ADELIVERP
#                  ADELIVERP = CLEPARAM = vide si paramtres niveau dossier
#                  ADELIVERP = CLEPARAM = LEG  si paramtres niveau LEG
#           une liste de codes activités de dimension ,  a sasir à la demande ------ ADELIVERD
#
#           une liste de cle de fichiers a filtrer
#                  et on peut tous les saisir ----- ADELIVERO
#                  ADELIVERO = Le code LEG peut être vide
#
# ADELIVERB : table des badges/fonctions
# ADELIVERR : table des badges/representations
# ADELIVERT : table des Types sessions/ devices
# ADELIVERL : table des limites fonctionnelles - licence (fct/licence)
#
# Sous prog commun SUBADLV + SUBADLK
#
# on bloque acces a cette fct si on est pas en interne
#######################################################################################

$ACTION
Case ACTION
 When "AVANT_OUVRE"  : Gosub AVANT_OUVRE
 When "OUVRE"        : Gosub OUVRE
 When "FILTRE"       : Gosub FILTRE
 When "FERME"        : Gosub FERME
 When "LIENS"        : Gosub LIENS
 When "CREATION"     : Gosub CREATION
 When "ABANDON"      : Gosub ABANDON
 When "RAZCRE"       : Gosub RAZCRE
 When "MODIF"        : Gosub MODIF
 When "ANNULE"       : Gosub ANNULE
 When "VERIF_CRE"    : Gosub VERIF
 When "VERIF_MOD"    : Gosub VERIF
 When "RAZDUP"       : Gosub RAZDUP
 When "AB1_NBRTAB"   : Gosub AB1_NBRTAB
 When "AB3_NBRTAB"   : Gosub AB3_NBRTAB
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANTBOUT"    : Gosub AVANTBOUT
 When "EXEBOUT"      : Gosub EXEBOUT
 When "EFFMASK"      : [M:ADLV0]ADLVTYP=1
 When Default
Endcase
Return

#----------------------#
$ACTIONB
Local Integer PSUBB
Call EXISTE_ADX("","","ASAIPARVALB",PSUBB) From ORDSYS
If PSUBB
    Gosub ACTION From ASAIPARVALB
Endif
Return


########################################################################################
#                             Etiquettes GOBJET
########################################################################################
########################################################################################
$AVANT_OUVRE
# fonction accessible uniquement dans nos environnements
If filinfo(filpath("","sophia_gaillard",""),0)< 0
     GMESSAGE = mess(1,133,1)
     OK  = 1
Endif
Return

$OUVRE
#-------------------#
# Globles workflow  #
#-------------------#
Global Char    GWRKTEX1(100)
Global Char    GWRKTEX2(100)
Global Char    GWRKTEX3(100)
Global Char    GWRKTEX4(100)

# nbre ligne codes act ecran adlv2 ou adlk2
Global Integer GMAXCODACT
GMAXCODACT = 600
# nbre ligne codes param ecran adlv3
Global Integer GMAXPARAM
GMAXPARAM = 300

# nbre ligne codes dimension ecran adlv5
Global Integer GMAXDIMACT
GMAXDIMACT = 300

# nbre ligne codes dimension ecran adlv6b
# attention ce tabelau sert à garnir la table adelivero
# il est invisible
Global Integer GMAXDIMOBJ
GMAXDIMOBJ = 15000

# nbre ligne codes dimension ecran adlv6
Global Integer GMAXDIMTAB
GMAXDIMTAB = 500

# nbre ligne codes dimension ecran adlv6
Global Integer GMAXDIMKEY
GMAXDIMKEY = 3000

# nbre ligne codes dimension ecran adlvw
Global Integer GMAXELEMENT
GMAXELEMENT = 3000

# nbre ligne sur fct/badge ecran adlv7
Global Integer GMAXDIMBDG
GMAXDIMBDG = 300

# nbre ligne sur representation/badge ecran adlv7
Global Integer GMAXDIMASW
GMAXDIMASW = 300

# nbre ligne sur session/device ecran adlv8
Global Integer GMAXDIMSES
GMAXDIMSES = 300

# nbre ligne sur paramètre/licence ecran adlv8
Global Integer GMAXDIMLIM
GMAXDIMLIM = 300

# variable pour savoir si ligne est correcte
# gflgko = 2 si incorrecte
Global Integer GFLGKO
GFLGKO =1

# varaible pour degriser bouton enreg
Global Integer GACTMODIF
GACTMODIF = 0

# variable pour savoir si new codes activités
Global Integer GNEWACTIVITY
GNEWACTIVITY = 0
# variable pour savoir si livrable version
Global Integer GADLV_HISTO
GADLV_HISTO = 0

# verif si fichiers ouverts
If clalev([F:ACV])=0  : Local File ACTIV     [ACV]  : Endif
If clalev([F:ADP])=0  : Local File ADOPAR    [ADP]  : Endif
If clalev([F:ATB])=0  : Local File ATABLE    [ATB]  : Endif
If clalev([F:AWM])=0  : Local File AWRKLNK   [AWM]  : Endif
If clalev([F:AFC])=0  : Local File AFONCTION [AFC]  : Endif
If clalev([F:ASW])=0  : Local File ASHW      [ASW]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV   [ADI]  : Endif
If clalev([F:ADA])=0  : Local File ADOSACT   [ADA]  : Endif
If clalev([F:ADW])=0  : Local File ADOVAL    [ADW]  : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA   [AXX]  : Endif


If clalev([F:ATI_])=0 : Local File ATABIND   [ATI_]  : Endif
If clalev([F:ATZ_])=0 : Local File ATABZON   [ATZ_]  : Endif
If clalev([F:ATY_])=0 : Local File ATYPE     [ATY_]  : Endif
If clalev([F:AOB_])=0 : Local File AOBJET    [AOB_]  : Endif

If clalev([F:AMP_])=0 : Local File AMSKPAR   [AMP_]  : Endif
If clalev([F:AXX_])=0 : Local File ATEXTRA   [AXX_]  : Endif

#
If clalev([F:ATXJ])=0 : Local File ATEXTE    [ATXJ]  : Endif
If clalev([F:ASTJ])=0 : Local File APLSTD    [ASTJ]  : Endif
If clalev([F:AXXJ])=0 : Local File ATEXTRA   [AXXJ]  : Endif
# utile pour les selectinos sur kits dans le livrable
If clalev([F:ADLK])=0 : Local File ADELIVER  [ADLK]  : Endif

#
# variables locales
# ne sont pas toutes la car des appels dans trts comme subadlvw font des gosub
Local Clbfile WMESS_LIENS (4)
Local Clbfile WAFF_MESSAGE (4)
Local Char WMESSAGE (250)
Local Integer WRETOUR

Local Integer W_GCONSULT
W_GCONSULT = GCONSULT


Return

########################################################################################
$FERME
#-------------------#
# Globles workflow  #
#-------------------#
If dim(GWRKTEX1)>0
    Kill GWRKTEX1
Endif
If dim(GWRKTEX2)>0
    Kill GWRKTEX2
Endif
If dim(GWRKTEX3)>0
    Kill GWRKTEX3
Endif
If dim(GWRKTEX4)>0
    Kill GWRKTEX4
Endif
If dim(GMAXCODACT)>0
    Kill GMAXCODACT
Endif
If dim(GMAXPARAM)>0
    Kill GMAXPARAM
Endif

If dim(GMAXDIMACT)>0
    Kill GMAXDIMACT
Endif

If dim(GMAXDIMOBJ)>0
    Kill GMAXDIMOBJ
Endif

If dim(GMAXDIMTAB)>0
    Kill GMAXDIMTAB
Endif

If dim(GMAXDIMKEY)>0
    Kill GMAXDIMKEY
Endif

If dim(GMAXELEMENT)>0
    Kill GMAXELEMENT
Endif

If dim(GMAXDIMBDG)>0
    Kill GMAXDIMBDG
Endif

If dim(GMAXDIMASW)>0
    Kill GMAXDIMASW
Endif


If dim(GMAXDIMSES)>0
    Kill GMAXDIMSES
Endif

If dim(GMAXDIMLIM)>0
    Kill GMAXDIMLIM
Endif


If dim(GFGLKO)>0
    Kill GFLGKO
Endif

If dim(GACTMODIF)>0
    Kill GACTMODIF
Endif

If dim(GNEWACTIVITY)>0
    Kill GNEWACTIVITY
Endif

If dim(GADLV_HISTO)>0
    Kill GADLV_HISTO
Endif

Return

########################################################################################
$FILTRE

If GFONCTION = "GESADLK"
    # filtre les kits
    FILTSUP="ADLVTYP=2"
Elsif GFONCTION = "GESADLV"
    # ajout test fct gesadlv car on utilse objet dans la fct ADOSCOPDAT
    # et dans ces cas pas de filtre a mettre
    # filtre les livrables
    FILTSUP="ADLVTYP=1"
Endif

Return


########################################################################################
$SETBOUT

If [M]COD<>"" & GADLV_HISTO = 1
    # aucun bouton dispo
    Call VIREBOUT (CHAINE,"256") From GOBJET
    If GFONCTION <> "GESADLK"
            Grizo [M:ADLV0]COD
    Else
            Grizo [M:ADLK0]COD
    Endif
Elsif [M]COD<>"" & GACTMODIF=1
    #-----------------------------------
    # il faut degriser bouton enreg - Gactmodif = 1
   If !VERROU : Gosub VERROU From GOBJET : Endif
   If !VERROU
        Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
   Else
        REP="M" : #Activation bouton enregistrer
        # ici en retour aon a un souci sur la clasee [m]cod .. donc on met en dur le nom ecran
        If GFONCTION <> "GESADLK"
            Grizo [M:ADLV0]COD
        Else
            Grizo [M:ADLK0]COD
        Endif
        # si new codes act on se positonne dessus
        If GNEWACTIVITY = 1
            SUIZON = "[ADLV2]NBRACT("+num$([M:ADLV2]NBRACT-1)+")"
        Endif
        #on laisse la possibilité du bouton verif coherence
        #Call VIREBOUT(CHAINE,"2") From GOBJET
        # on vire le bouton generation
        Call VIREBOUT(CHAINE,"56") From GOBJET
   Endif
   GACTMODIF=0
Else
    #----- Menus "Fonctions" dans la ToolBar -----#
    If GREP = ""
        CHMEN+="3"
    Endif
    If CLECUR
        If [M:ADLV6]NBRTAB > 0
            If find(2,[M:ADLV6]FLGKO(0..[M:ADLV6]NBRTAB-1))
              CHMEN+="1"
            Endif
        Endif
    Endif
    #----- Menus "Actions" dans la ToolBar -----#
    # generation json sur tous les actifs mais voir comment bloquer botuon uniquement pour indus ?
    # idem pour les kits
    If CLECUR
            CHMEN+="4"
    Endif
    #----- Boutons en bas ecran -----#
    If !CLECUR   :  Call VIREBOUT (CHAINE,"256") From GOBJET : Endif
    # en duplication on vire ces boutons
    If GREP = "D":  Call VIREBOUT (CHAINE,"256") From GOBJET : Endif
    # en consult on vire ces boutons
    If GCONSULT = 1 :  Call VIREBOUT (CHAINE,"256") From GOBJET : Endif
Endif
Return

########################################################################################
$AVANTBOUT
#----------------------------------------------------#
# Exécution tool barre                               #
# 1 = Suppression des lignes invalides               #
# 3 = Vérification cohérence pour tous les livrables actifs ou kits#
# 4 = generation json
#----------------------------------------------------#
Case BOUT
  When "1" : If GREP=""
                # personne ne doit verrouiller l enreg. et si en modif , on ne doit pas pouvoir faire cette option
                Gosub AVANTBOUT_INVALID
             Endif
  When "3" : If GREP=""
                # si en modif , on ne doit pas pouvoir faire cette option
                Gosub AVANTBOUT_CHECK
             Endif
  When "4" : If GREP=""
                # si en modif , on ne doit pas pouvoir faire cette option
                Gosub AVANTBOUT_JSON
             Endif
Endcase
Return

########################################################################################
$AVANTBOUT_INVALID
#----- Vérification si enreg bloqué logiquement -----#
If !VERROU  GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return : Endif

OK=2
If GFONCTION = "GESADLK"
    #----- voulez-vous continuer ? -----#
    Call AVERTIR(mess(69,7999,1),OK) From GESECRAN
Else
    #----- voulez-vous continuer ? -----#
    Call AVERTIR(mess(30,7999,1),OK) From GESECRAN
Endif

If OK=1  OK=0 : Return : Endif

OK=0
Call DEL_INVALID_LINES ([F:ADLV]COD,[F:ADLV]ADLVTYP,OK)
If OK = 0
    # affichage message tout est ok
    Call MESSAGE (mess(56,7999,1))    From GESECRAN
    #
    Gosub DEVERROU From GOBJET
    Gosub RELIT    From GOBJSUB
Endif

Return

########################################################################################
$AVANTBOUT_CHECK

#----- voulez-vous continuer ? -----#
OK=2
If GFONCTION = "GESADLK"
    #----- voulez-vous continuer ? -----#
    Call AVERTIR(mess(65,7999,1),OK) From GESECRAN
Else
    #----- voulez-vous continuer ? -----#
    Call AVERTIR(mess(54,7999,1),OK) From GESECRAN
Endif

If OK=1  OK=0 : Return : Endif

OK=0
If GFONCTION = "GESADLK"
    # verif cohérence tous kits actifs
    Call CHECK_ALL_ADLV (OK,2)
Else
    # verif cohérence tous livrables actifs
    Call CHECK_ALL_ADLV (OK,1)
Endif

# on se repostionne sur le livrable
Gosub RELIT    From GOBJSUB
Return

########################################################################################
$AVANTBOUT_JSON

#----- voulez-vous continuer ? -----#
OK=2
If GFONCTION = "GESADLK"
    Call AVERTIR(mess(75,7999,1),OK) From GESECRAN
Else
    Call AVERTIR(mess(61,7999,1),OK) From GESECRAN
Endif

If OK=1  OK=0 : Return : Endif
OK=0
If GFONCTION = "GESADLK"
    # generation des fichiers json pour tous les kits actifs
    Call JSON_ALL_ADLV (OK,2)
Else
    Call JSON_ALL_ADLV (OK,1)
Endif

# on se repositionne sur le livrable
Gosub RELIT    From GOBJSUB
Return


########################################################################################
$EXEBOUT
#--------------------------------------#
# Exécution des boutons du bas         #
# apres execution barre tools
# 2 = Vérif cohérence                  #
# 5 = Generation json                  #
# 6 = historisation                    #
#--------------------------------------#
Case BOUT
   When "2" : Local Integer WNBR_ERRORS : WNBR_ERRORS = 0 : Call CHECK_DELIVER ([F:ADLV]COD,WNBR_ERRORS,"")
   When "5" : Local Integer WNBR_ERRORS : WNBR_ERRORS = 0 : Call JSON_ADLV ([F:ADLV]COD,WNBR_ERRORS,"")
   When "6" : Local Integer WNBR_ERRORS : WNBR_ERRORS = 0 : Call HISTO_ADLV ([F:ADLV]COD,WNBR_ERRORS,"")
Endcase
Return


########################################################################################
$AB1_NBRTAB
Global Char GBIDC1(30)
GBIDC1 = "2"
Return

########################################################################################
$AB3_NBRTAB
Global Char GBIDC1(30)
GBIDC1 = "1"
Return

########################################################################################
$LIENS

GNEWACTIVITY = 0

Local Integer WIND

# utilisation de wmess_liens pour charger tous les messages non grave
# et ensuite l afficher en une seule fois si besoin attention c est un clob
# init des var...
Raz WMESS_LIENS
Raz WMESSAGE
WRETOUR = 0
WIND = 0

# si un ~dans le nom du code
# dans ce cas on ne fait que afficher sans rien d autres.
# ces enregs sont alors non modifiable - enreg historiques en fct des versions
If pat ([F:ADLV]COD,"*~*")
    # uniquement en consult et vara à 1
    GADLV_HISTO =1
    GCONSULT =1
Else
    GADLV_HISTO =0
   # on remet le gconsult comme avant
    GCONSULT =W_GCONSULT
Endif

#---------------------------#
# pas de module sur les kits ni de code langue ni de leg
#---------------------------#

If GFONCTION <> "GESADLK"
    #-------------------------------------------#
    # attention , les modules peuvent évolués en cours de route..
    # il faut etre capable de les detecter. pour instant on met une alerte seule
    #-------------------------------------------#
    If dim ([F:ADLV]MODULE) < len(mess(0,14,1))
        # message : Pour information, des modules ont été ajoutés
        # pas de message si historique adlv
        GMESSAGE = mess(261,125,1)
        If GADLV_HISTO <> 1
            Call MESSAGE(GMESSAGE) From GESECRAN
        Endif
        Raz GMESSAGE
    Endif

    #-------------------------------------------#
    # chargement des zones ecrans
    # ADLV1 ADLV4
    #-------------------------------------------#
    [M:ADLV1]NBRMOD = 0
    For WIND = 0 To dim ([F:ADLV]MODULE)-1
        If [F:ADLV]MODULE (WIND) <> 0
            [M:ADLV1]MODULE(WIND) = [F:ADLV]MODULE (WIND)
            If [M:ADLV1]NBRMOD = 20
                # 'tableau plein'
                GMESSAGE=mess (26,100,1)+"\[M:ADLV1]NBRMOD"
                If GADLV_HISTO <> 1
                    Call MESSAGE(GMESSAGE) From GESECRAN
                Endif
                Raz GMESSAGE
                Break
            Else
                [M:ADLV1]NBRMOD +=1
            Endif
        Endif
    Next WIND
    # dans superv le aml 14 a bien 20 elements mais se finit par des # a ne pas prendre en compte
    For WIND =1 To len(mess(0,14,1))
        If left$(mess(WIND,14,1),1)="#"
              [M:ADLV1]NBRMOD = WIND-1
              Break
        Endif
    Next WIND


    [M:ADLV4]NBRLAN = 0
    For WIND = 0 To dim ([F:ADLV]LAN)-1
        If [F:ADLV]LAN (WIND) <> ""
            [M:ADLV4]LAN(WIND) = [F:ADLV]LAN (WIND)
            [M:ADLV4]NBRLAN +=1
        Endif
    Next WIND

    [M:ADLV4]NBRLEG = 0
    For WIND = 0 To dim ([F:ADLV]DOSLEG)-1
        If [F:ADLV]DOSLEG (WIND) <> ""
            [M:ADLV4]DOSLEG (WIND)= [F:ADLV]DOSLEG (WIND)
            [M:ADLV4]NBRLEG +=1
        Endif
    Next WIND

    [M:ADLV4]NBRITY = 0
    For WIND = 0 To dim ([F:ADLV]ITYKIT)-1
        If [F:ADLV]ITYKIT (WIND) <> ""
            [M:ADLV4]ITYKIT (WIND)= [F:ADLV]ITYKIT (WIND)
            # on controle kit est là....
            # maios on charge quand même l info ....
            WRETOUR = 0
            Call READ_ADLK ([F:ADLV]ITYKIT (WIND),WRETOUR) From SUBADLV
            If WRETOUR = 3
                # si pas correct on affiche quand même
                WMESS_LIENS+=[F:ADLV]ITYKIT (WIND)+" : "+mess (24,7999,1)+chr$(10)
            Elsif WRETOUR = 1
                # si pas correct on affiche quand même
                WMESS_LIENS+=[F:ADLV]ITYKIT (WIND)+" : "+mess (81,7999,1)+chr$(10)
            Endif
            [M:ADLV4]NBRITY +=1
        Endif
    Next WIND

Endif


#-------------------------------------------#
#   init du message workflow
#   Le livrable $1$ a été modifié par $2$.
#-------------------------------------------#
GWRKTEX1= func AFNC.MES2(mess(262,125,1),num$([M]COD),num$(GUSER))
GWRKTEX2= func AFNC.MES2(mess(262,125,1),num$([M]COD),num$(GUSER))
GWRKTEX3=""
GWRKTEX4=""

#-------------------------------------------#
# chargement onglet codes act actif/inactif
# ADLV2
#-------------------------------------------#

Raz [M:ADLV2]
[M:ADLV2]NBRACT = 0
WIND = 0
#----------------------#
# On charge les codes act typ = 1 ou 3 (options localisation)
#----------------------#
Filter [ADLD] Where COD=[F:ADLV]COD and TYPACV <> 2
For [ADLD]
    WRETOUR = 0
    Call READ_ACTIV ([F:ADLD]CODACT,"F",WRETOUR) From SUBADLV
    If WRETOUR = 0
            [M:ADLV2]CODACT(WIND)     = [F:ADLD]CODACT
            [M:ADLV2]FLGACT(WIND)     = [F:ADLD]FLGACT
            [M:ADLV2]LICACT(WIND)     = [F:ADLD]LICACT
            [M:ADLV2]NOTAVAACT(WIND)  = [F:ADLD]NOTAVAACT
            [M:ADLV2]TYPACV(WIND)     = [F:ADLD]TYPACV
            # lecture code act et recup module
            # il faut également charger le module qui n est pas stocké volontairement
            # a cause des modifs
            [M:ADLV2]MODACV(WIND)  = [F:ACV]MODULE
            [M:ADLV2]NBRACT += 1
            WIND +=1
      Elsif WRETOUR = 3
            # si pas correct on ne l affiche pas
            # pas contre il faudra enregistrer le record pour que la modif soit pris en compte
            # degriser le bouton enreg dans ce cas. pas pour l instant
            #GACTMODIF = 1
            WMESS_LIENS+=[F:ADLD]CODACT+" : "+mess (24,7999,1)+chr$(10)
      Elsif WRETOUR = 1
            # si pas correct on ne l affiche pas
            # pas contre il faudra enregistrer le record pour que la modif soit pris en compte
            # degriser le bouton enreg dans ce cas. pas pour l instant
            #GACTMODIF = 1
            WMESS_LIENS+=[F:ADLD]CODACT+" : "+mess (31,7999,1)+chr$(10)
      Elsif WRETOUR = 2
            # si pas correct on ne l affiche pas
            # pas contre il faudra enregistrer le record pour que la modif soit pris en compte
            # degriser le bouton enreg dans ce cas. pas poru instant
            #GACTMODIF = 1
            WMESS_LIENS+=[F:ADLD]CODACT+" : "+mess (31,7999,1)+chr$(10)
     Endif
     If [M:ADLV2]NBRACT = GMAXCODACT
           # 'tableau plein'
            GMESSAGE=mess (26,100,1)+"\[M:ADLV2]NBRACT"
            If GADLV_HISTO <> 1
                Call MESSAGE(GMESSAGE) From GESECRAN
            Endif
            Raz GMESSAGE
            Break
     Endif
Next
Filter [ADLD]

#-------------------------------------------#
# attention , les codes activités peuvent évolués en cours de route..
# il faut etre capable de les detecter.
# on degrise alors le bouton enreg uniquement si ce message .....
# utilisation var globale gactmodif
#-------------------------------------------#
If GADLV_HISTO <> 1
    Call VERIF_NEWCODACT (WIND)
Endif


#-------------------------------------------#
# chargement ecran parametres
# ADLV3
#-------------------------------------------#
Raz [M:ADLV3]
[M:ADLV3]NBRSET = 0
WIND = 0
#----------------------#
# On charge les codes
#----------------------#
Filter [ADLP] Where COD=[F:ADLV]COD
For [ADLP]
    [M:ADLV3]PARAM(WIND)  = [F:ADLP]PARAM
    WRETOUR = 0
    Call READ_ADOPAR ([F:ADLP]PARAM,[F:ADLP]TYPPARAM,WRETOUR)
    If WRETOUR = 3
        [M:ADLV3]NAM (WIND)      = "???????????????"
        [M:ADLV3]FMT(WIND)       = "Kf:"+num$(GLONADW)+"X"
        [M:ADLV3]TYP(WIND)       = "A"
        [M:ADLV3]TYPPARAM(WIND)  = 1
        [M:ADLV3]LONG(WIND)      = GLONADW
        [M:ADLV3]VALSAI (WIND)   = [F:ADLP]VALPARAM
        [M:ADLV3]VALPARAM (WIND) = [F:ADLP]VALPARAM
        Call CHARGE([M:ADLV3]VALSAI(WIND),[M]TYP(WIND),[M]NOLIB(WIND),[M]LONG(WIND),[M:ADLV3]VALPARAM(WIND)) From FMTVAR
        [M:ADLV3]CLEPARAM(WIND)  = [F:ADLP]CLEPARAM
        [M:ADLV3]LEGPARAM (WIND) = [M:ADLV3]PARAM(WIND)+"~"+[M:ADLV3]CLEPARAM(WIND)
    Else
        # voir a afficher un message si le type a changé  rretour = 1
        # affichage message si le param n est plus modifiable rretour = 2
        If WRETOUR = 1
            WMESS_LIENS+=[F:ADLP]PARAM+" : "+mess (33,7999,1)+chr$(10)
        Elsif WRETOUR = 2
            WMESS_LIENS+=[F:ADLP]PARAM+" : "+mess (59,143,1)+chr$(10)
        Endif
        Call CHARGE_DEFAULT_PARAM ([F:ADLP]PARAM,[F:ADLP]VALPARAM,[F:ADLP]CLEPARAM,WIND)
    Endif
    #
    [M:ADLV3]NBRSET += 1
    WIND +=1
    If [M:ADLV3]NBRSET = GMAXPARAM
       # 'tableau plein'
        GMESSAGE=mess (26,100,1)+"\[M:ADLV3]NBRSET"
        If GADLV_HISTO <> 1
            Call MESSAGE(GMESSAGE) From GESECRAN
        Endif
        Raz GMESSAGE
        Break
    Endif
Next
Filter [ADLP]


#-------------------------------------------#
# chargement code act de dim
# ADLV5
#-------------------------------------------#
Raz [M:ADLV5]
[M:ADLV5]NBRDIM = 0
WIND = 0
#----------------------#
# On charge les codes de dim
#----------------------#
Filter [ADLD] Where COD=[F:ADLV]COD and TYPACV = 2
For [ADLD]
    WRETOUR = 0
    Call READ_ACTIV ([F:ADLD]CODACT,"D",WRETOUR) From SUBADLV
    # dans tous les cas on charge
    [M:ADLV5]CODDIM(WIND)     = [F:ADLD]CODACT
    [M:ADLV5]DIMACT(WIND)     = [F:ADLD]DIMACT
    [M:ADLV5]NBRDIM += 1
    If WRETOUR = 3
        [M:ADLV5]DIMMOD(WIND)  = 11
        [M:ADLV5]DIMADS(WIND)  = 0
        WMESS_LIENS+=[F:ADLD]CODACT+" : "+mess (45,7999,1)+chr$(10)
    Else
        # on charge dans tous les cas
        Call CHARGE_DEFAULT_DIM ([F:ADLD]CODACT,WIND)
        If WRETOUR = 1
            # si pas correct mais on l affiche quand même
            # degriser le bouton enreg dans ce cas. pas pour l instant
            #GACTMODIF = 1
            WMESS_LIENS+=[F:ADLD]CODACT+" : "+mess (32,7999,1)+chr$(10)
        Elsif WRETOUR = 2
            # si pas correct mais on l affiche quand même
            # degriser le bouton enreg dans ce cas. pas pour l instant
            #GACTMODIF = 1
            WMESS_LIENS+=[F:ADLD]CODACT+" : "+mess (31,7999,1)+chr$(10)
        Endif
    Endif
    WIND +=1
    If [M:ADLV5]NBRDIM = GMAXDIMACT
       # 'tableau plein'
        GMESSAGE=mess (26,100,1)+"\[M:ADLV5]NBRDIM"
        If GADLV_HISTO <> 1
            Call MESSAGE(GMESSAGE) From GESECRAN
        Endif
        Raz GMESSAGE
        Break
    Endif
Next
Filter [ADLD]

#-------------------------------------------#
# chargement des cles fichiers a filtrer
# attention trois tableaux
# un pour les codes fichiers
# un pour les clés mais par code fichier
# un globale invisible qui permet de charger le fichier ensuite
# ADLV6 ADLV6B
#-------------------------------------------#
Local Char WINTIT(30)

Raz [M:ADLV6]
Raz [M:ADLV6B]
[M:ADLV6B]NBROBJ = 0
[M:ADLV6]NBRTAB = 0
[M:ADLV6]NBRKEY = 0
WIND = 0
WINDTAB = 0
#----------------------#
# On charge les codes
#----------------------#
Filter [ADLO] Where COD=[F:ADLV]COD

For [ADLO]
    # flag pour savoir si ligne est correct ou pas
    # valeur 1 : ligne ok valeur 2 ligne avec un prob
    GFLGKO = 1
    If [F:ADLO]TABCOD <>  ""
        #ecran invisible
        [M:ADLV6B]TABCOD(WIND)     = [F:ADLO]TABCOD
        [M:ADLV6B]TABKEY(WIND)     = [F:ADLO]TABKEY
        [M:ADLV6B]TABLEG(WIND)     = [F:ADLO]TABLEG
        # pas de controle leg pour les kits
        If GFONCTION <> "GESADLK"
            # verif de la leg encore valable
            If [M:ADLV6B]TABLEG (WIND) <> ""
                If !find([M:ADLV6B]TABLEG (WIND),[M:ADLV4]DOSLEG(0..[M:ADLV4]NBRLEG-1))
                    # "Une leg a été saisie sur cet objet et n existe plus dans le tableau"
                    GMESSAGE= func AFNC.MES2(mess(136,127,1),num$([M:ADLV6B]TABLEG (WIND)),num$([M:ADLV6B]TABCOD (WIND)))
                    WMESS_LIENS+=GMESSAGE+chr$(10)
                    Raz GMESSAGE
                Endif
            Endif
        Endif
        [M:ADLV6B]TABKEYNAM(WIND)  = [F:ADLO]TABKEYNAM
        [M:ADLV6B]TABKEYFMT(WIND)  = [F:ADLO]TABKEYFMT
        [M:ADLV6B]TABAWM(WIND)     = [F:ADLO]TABAWM
        [M:ADLV6B]NULRECFLG(WIND)  = [F:ADLO]NULRECFLG
        [M:ADLV6B]TABADINUM(WIND)  = [F:ADLO]TABADINUM
        [M:ADLV6B]TABKEYDES(WIND)  = ""
        # voir pour charger la designation dans tabkeydes sur chaque ligne
        # on verifie aussi si la clé a changer en même temps
        # on verifie aussi que la table existe encore
        # affichage d un message si c'est le cas mais en fin .. utilisation wmess_leins
        Raz GMESSAGE
        Raz WMESSAGE
        If [M:ADLV6B]TABKEY (WIND) <> "" and [F:ADLO]NULRECFLG <> 2
            If WIND <> 0
                # on ne le fait qu une fois
                If [F:ADLO]TABCOD <> [M:ADLV6B]TABCOD(WIND-1)
                      Gosub READ_FILE
                Else
                      # on ne le fait qu une fois verif du couple
                      If [F:ADLO]TABAWM <> [M:ADLV6B]TABAWM(WIND-1)
                            GFLGKO = 2
                            # prob couple non unique ligne invalide......
                            WMESS_LIENS+=num$([F:ADLO]TABAWM)-num$([F:ADLO]TABCOD)-mess (82,7999,1)+chr$(10)
                     Endif
                Endif
            Else
                Gosub READ_FILE
            Endif
            If WINTIT <> ""
                Call RECUP_DESTAB ([F:ADLO]TABCOD, [F:ADLO]TABKEY,[F:ADLO]TABKEYFMT, WINTIT,[M:ADLV6B]TABKEYDES(WIND))
            Endif
        Elsif[F:ADLO]NULRECFLG = 2
            # cas ou aucun element dans table
            # pas besoin de la cle et du reste , pas de controle
        Else
            If WIND <>0
                 # on ne le fait qu une fois verif du couple
                 If [F:ADLO]TABAWM <> [M:ADLV6B]TABAWM(WIND-1)
                     GFLGKO = 2
                     # prob couple non unique ligne invalide......
                     WMESS_LIENS+=num$([F:ADLO]TABAWM)-num$([F:ADLO]TABCOD)-mess (82,7999,1)+chr$(10)
                 Endif
            Endif
        Endif
        If WMESSAGE <> ""
                WMESS_LIENS +=WMESSAGE+chr$(10)
        Endif
        Raz GMESSAGE
        Raz WMESSAGE
        [M:ADLV6B]NBROBJ += 1
        # ecran visible
        If WINDTAB = 0
            [M:ADLV6]TABCOD1(WINDTAB)     = [F:ADLO]TABCOD
            [M:ADLV6]TABAWM1(WINDTAB)     = [F:ADLO]TABAWM
            [M:ADLV6]NULRECFLG1(WINDTAB)  = [F:ADLO]NULRECFLG
            [M:ADLV6]TABADINUM1(WINDTAB)  = [F:ADLO]TABADINUM
            [M:ADLV6]TABKEYFMT1(WINDTAB)  = [F:ADLO]TABKEYFMT
            [M:ADLV6]TABKEYNAM1(WINDTAB)  = [F:ADLO]TABKEYNAM
            # flag pour savoir si ligne est correct ou pas
            # valeur 1 : ligne ok valeur 2 ligne avec un prob
            [M:ADLV6]FLGKO (WINDTAB)      = GFLGKO
            [M:ADLV6]NBRTAB += 1
             WINDTAB +=1
             If [M:ADLV6]NBRTAB = GMAXDIMTAB
               # 'tableau plein'
                GMESSAGE=mess (26,100,1)+"\[M:ADLV6]NBRTAB"
                If GADLV_HISTO <> 1
                    Call MESSAGE(GMESSAGE) From GESECRAN
                Endif
                Raz GMESSAGE
                Break
            Endif
        Elsif [M:ADLV6]TABCOD1(WINDTAB-1) <> [F:ADLO]TABCOD
            [M:ADLV6]TABCOD1(WINDTAB)     = [F:ADLO]TABCOD
            [M:ADLV6]TABAWM1(WINDTAB)     = [F:ADLO]TABAWM
            [M:ADLV6]NULRECFLG1(WINDTAB)  = [F:ADLO]NULRECFLG
            [M:ADLV6]TABADINUM1(WINDTAB)  = [F:ADLO]TABADINUM
            [M:ADLV6]TABKEYFMT1(WINDTAB)  = [F:ADLO]TABKEYFMT
            [M:ADLV6]TABKEYNAM1(WINDTAB)  = [F:ADLO]TABKEYNAM
            # flag pour savoir si ligne est correct ou pas
            # valeur 1 : ligne ok valeur 2 ligne avec un prob
            [M:ADLV6]FLGKO (WINDTAB)      = GFLGKO
            [M:ADLV6]NBRTAB += 1
             WINDTAB +=1
             If [M:ADLV6]NBRTAB = GMAXDIMTAB
               # 'tableau plein'
                GMESSAGE=mess (26,100,1)+"\[M:ADLV6]NBRTAB"
                If GADLV_HISTO <> 1
                    Call MESSAGE(GMESSAGE) From GESECRAN
                Endif
                Raz GMESSAGE
                Break
            Endif
        Elsif [M:ADLV6]TABADINUM1(WINDTAB-1) <> [F:ADLO]TABADINUM
            [M:ADLV6]TABCOD1(WINDTAB)     = [F:ADLO]TABCOD
            [M:ADLV6]TABAWM1(WINDTAB)     = [F:ADLO]TABAWM
            [M:ADLV6]NULRECFLG1(WINDTAB)  = [F:ADLO]NULRECFLG
            [M:ADLV6]TABADINUM1(WINDTAB)  = [F:ADLO]TABADINUM
            [M:ADLV6]TABKEYFMT1(WINDTAB)  = [F:ADLO]TABKEYFMT
            [M:ADLV6]TABKEYNAM1(WINDTAB)  = [F:ADLO]TABKEYNAM
            # flag pour savoir si ligne est correct ou pas
            # valeur 1 : ligne ok valeur 2 ligne avec un prob
            [M:ADLV6]FLGKO (WINDTAB)      = GFLGKO
            [M:ADLV6]NBRTAB += 1
             WINDTAB +=1
             If [M:ADLV6]NBRTAB = GMAXDIMTAB
               # 'tableau plein'
                GMESSAGE=mess (26,100,1)+"\[M:ADLV6]NBRTAB"
                If GADLV_HISTO <> 1
                    Call MESSAGE(GMESSAGE) From GESECRAN
                Endif
                Raz GMESSAGE
                Break
            Endif
        Endif
        # voir a faire une verif avant affichage
        WIND +=1
        If [M:ADLV6B]NBROBJ = GMAXDIMOBJ
           # 'tableau plein'
            GMESSAGE=mess (26,100,1)+"\[M:ADLV6B]NBROBJ"
            If GADLV_HISTO <> 1
                Call MESSAGE(GMESSAGE) From GESECRAN
            Endif
            Raz GMESSAGE
            Break
        Endif
    Endif
Next
Filter [ADLO]

# on active la colonne invalide si on trouve une ligne en erreur
# sinon on n affiche pas cette colonne
# juste ici car ensuite en saisie il n y a pas de raison que ce soit mauvais
If [M:ADLV6]NBRTAB > 0
    If find(2,[M:ADLV6]FLGKO(0..[M:ADLV6]NBRTAB-1))
       Chgfmt [M:ADLV6]FLGKO With "LA:1X"
    Else
       Chgfmt [M:ADLV6]FLGKO With "-LA:1X"
    Endif
Else
    Chgfmt [M:ADLV6]FLGKO With "-LA:1X"
Endif



#-------------------------------------------#
# pas de badge pour les kits ni session/device ni limites fct
# chargement code fct + badge + represnetation/badges
# ADLV7
#-------------------------------------------#
If GFONCTION <> "GESADLK"
    Raz [M:ADLV7]
    [M:ADLV7]NBRBDG = 0
    WIND = 0
    #----------------------#
    # On charge les codes
    #----------------------#
    Filter [ADLB] Where COD=[F:ADLV]COD
    For [ADLB]
        WRETOUR = 0
        Call READ_FONCTION ([F:ADLB]CODFNC,[F:ADLB]CODBDG,WRETOUR) From SUBADLV
        # dans tous les cas on charge
        [M:ADLV7]CODFNC(WIND)     = [F:ADLB]CODFNC
        [M:ADLV7]CODBDG(WIND)     = [F:ADLB]CODBDG
        [M:ADLV7]FNCBDG(WIND)     = [F:ADLB]CODFNC+"~"+[F:ADLB]CODBDG
        [M:ADLV7]NBRBDG += 1
        If WRETOUR = 3
            [M:ADLV7]FNCMOD(WIND)  = 11
            WMESS_LIENS+=[F:ADLB]CODFNC+" : "+mess (24,7999,1)+chr$(10)
        Else
            [M:ADLV7]FNCMOD(WIND)  = [F:AFC]MODULE
            If WRETOUR = 1
                # si pas correct on l affiche quand même
                # degriser le bouton enreg dans ce cas. pas pour l instant
                #GACTMODIF = 1
                WMESS_LIENS+=[F:ADLB]CODFNC+"/"+[F:ADLB]CODBDG+" : " +mess (42,7999,1)+chr$(10)
            Elsif WRETOUR = 2
                # si type incorrect sur fct on l affiche quand même
                # degriser le bouton enreg dans ce cas. pas pour l instant
                #GACTMODIF = 1
                WMESS_LIENS+=[F:ADLB]CODFNC+" : "+mess (48,7999,1)+chr$(10)
            Endif
        Endif
        WIND +=1
        If [M:ADLV7]NBRBDG = GMAXDIMBDG
           # 'tableau plein'
            GMESSAGE=mess (26,100,1)+"\[M:ADLV7]NBRBDG"
            If GADLV_HISTO <> 1
                Call MESSAGE(GMESSAGE) From GESECRAN
            Endif
            Raz GMESSAGE
            Break
        Endif
    Next
    Filter [ADLB]
    #
    WIND = 0
    #----------------------#
    # On charge les codes
    #----------------------#
    Filter [ADLR] Where COD=[F:ADLV]COD
    For [ADLR]
        WRETOUR = 0
        Call READ_ASHW ([F:ADLR]CODASW,[F:ADLR]CODBDG,WRETOUR) From SUBADLV
        # dans tous les cas on charge
        [M:ADLV7]CODASW(WIND)     = [F:ADLR]CODASW
        [M:ADLV7]CODBDGASW(WIND)  = [F:ADLR]CODBDG
        [M:ADLV7]ASWBDG(WIND)     = [F:ADLR]CODASW+"~"+[F:ADLR]CODBDG
        [M:ADLV7]NBRASW += 1
        If WRETOUR = 3
            [M:ADLV7]ASWMOD(WIND)  = 11
            WMESS_LIENS+=[F:ADLR]CODASW+" : "+mess (24,7999,1)+chr$(10)
        Else
            [M:ADLV7]ASWMOD(WIND)  = [F:ASW]MODULE
            If WRETOUR = 1
                # si pas correct on l affiche quand même
                # degriser le bouton enreg dans ce cas. pas pour l instant
                #GACTMODIF = 1
                WMESS_LIENS+=[F:ADLR]CODASW+"/"+[F:ADLR]CODBDG+" : " +mess (42,7999,1)+chr$(10)
            Elsif WRETOUR = 2
                # si type incorrect sur repres on l affiche quand même
                # degriser le bouton enreg dans ce cas. pas pour l instant
                #GACTMODIF = 1
                WMESS_LIENS+=[F:ADLR]CODASW+" : "+mess (93,7999,1)+chr$(10)
            Endif
        Endif
        WIND +=1
        If [M:ADLV7]NBRASW = GMAXDIMASW
           # 'tableau plein'
            GMESSAGE=mess (26,100,1)+"\[M:ADLV7]NBRASW"
            If GADLV_HISTO <> 1
                Call MESSAGE(GMESSAGE) From GESECRAN
            Endif
            Raz GMESSAGE
            Break
        Endif
    Next
    Filter [ADLR]

Endif


#-------------------------------------------#
# pas de session/device ni limites pour les kits
# chargement ADLV8
#-------------------------------------------#
If GFONCTION <> "GESADLK"
    Raz [M:ADLV8]
    #
    [M:ADLV8]NBRSES = 0
    WIND = 0
    #----------------------#
    # On charge les sessions/devices
    #----------------------#
    Filter [ADLT] Where COD=[F:ADLV]COD
    For [ADLT]
        WRETOUR = 0
        Call READ_SESSION ([F:ADLT]CODSES,[F:ADLT]CODDVC,WRETOUR) From SUBADLV
        # dans tous les cas on charge
        [M:ADLV8]CODSES(WIND)     = [F:ADLT]CODSES
        [M:ADLV8]CODDVC(WIND)     = [F:ADLT]CODDVC
        [M:ADLV8]SESDVC(WIND)     = [F:ADLT]CODSES+"~"+[F:ADLT]CODDVC
        [M:ADLV8]NBRSES += 1
        If WRETOUR = 3
            WMESS_LIENS+=[F:ADLT]CODDVC+" : "+mess (24,7999,1)+chr$(10)
        Else
            If WRETOUR = 1
                # si session/device incorrect on l affiche quand même
                # degriser le bouton enreg dans ce cas. pas pour l instant
                #GACTMODIF = 1
                WMESS_LIENS+=[F:ADLT]CODSES+"/"+[F:ADLT]CODDVC+" : " +mess (88,7999,1)+chr$(10)
            Elsif WRETOUR = 2
                # si type session n existe plus on l affiche quand même
                # degriser le bouton enreg dans ce cas. pas pour l instant
                #GACTMODIF = 1
                WMESS_LIENS+=[F:ADLT]CODSES+" : "+mess (85,7999,1)+chr$(10)
            Endif
        Endif
        WIND +=1
        If [M:ADLV8]NBRSES = GMAXDIMSES
           # 'tableau plein'
            GMESSAGE=mess (26,100,1)+"\[M:ADLV8]NBRSES"
            If GADLV_HISTO <> 1
                Call MESSAGE(GMESSAGE) From GESECRAN
            Endif
            Raz GMESSAGE
            Break
        Endif
    Next
    Filter [ADLT]

    [M:ADLV8]NBRLIM = 0
    WIND = 0
    #----------------------#
    # On charge les limites fcts
    #----------------------#
    Filter [ADLL] Where COD=[F:ADLV]COD
    For [ADLL]
        WRETOUR = 0
        Call READ_LIMITES ([F:ADLL]FNCLIM,[F:ADLL]TYPFNCLIM,[F:ADLV]PDT,WRETOUR) From SUBADLV
        # dans tous les cas on charge
        [M:ADLV8]FNCLIM(WIND)     = [F:ADLL]FNCLIM
        [M:ADLV8]TYPFNCLIM(WIND)  = [F:ADLL]TYPFNCLIM
        [M:ADLV8]NBRLIM += 1
        If WRETOUR = 3
            WMESS_LIENS+=[F:ADLL]FNCLIM+" : "+mess (24,7999,1)+chr$(10)
        Else
            If WRETOUR = 1
                # si pas correct on l affiche quand même
                # degriser le bouton enreg dans ce cas. pas pour l instant
                #GACTMODIF = 1
                WMESS_LIENS+=[F:ADLL]FNCLIM+"/"+[F:ADLL]TYPFNCLIM+" : " +mess (86,7999,1)+chr$(10)
            Elsif WRETOUR = 2
                # si type inexistant on l affiche quand même
                # degriser le bouton enreg dans ce cas. pas pour l instant
                #GACTMODIF = 1
                WMESS_LIENS+=[F:ADLL]FNCLIM+" : "+mess (87,7999,1)+chr$(10)
            Endif
        Endif
        WIND +=1
        If [M:ADLV8]NBRLIM = GMAXDIMLIM
           # 'tableau plein'
            GMESSAGE=mess (26,100,1)+"\[M:ADLV8]NBRLIM"
            If GADLV_HISTO <> 1
                Call MESSAGE(GMESSAGE) From GESECRAN
            Endif
            Raz GMESSAGE
            Break
        Endif
    Next
    Filter [ADLL]
Endif

# affichage des messages si non enreg histo_version
If GADLV_HISTO <> 1
    # afficher en une seule fois des messages
    If WMESS_LIENS <> ""
          # affichage en clob du message car + des 250 caractères
          # question sur la verif de coherence
          Raz WAFF_MESSAGE
          If GFONCTION = "GESADLK"
              WAFF_MESSAGE = WMESS_LIENS+chr$(10)+chr$(10)+mess (70,7999,1)
          Else
              WAFF_MESSAGE = WMESS_LIENS+chr$(10)+chr$(10)+mess (15,7999,1)
          Endif
          # plus de question on lance la verif si on sort avec le bouton oui
          Local Integer WOK
          WOK = 0
          Call MESCTL(WAFF_MESSAGE,WOK) From GESECRAN
          Raz GMESSAGE
          If WOK = 2
                Local Integer WNBR_ERRORS
                WNBR_ERRORS = 0
                Call CHECK_DELIVER ([F:ADLV]COD,WNBR_ERRORS,"")
                If WNBR_ERRORS <> 0
                    # degriser le bouton enreg.
                    GACTMODIF = 1
                Endif
          Endif
    Endif
Endif

If clalev([F:WWW])<>0
      Close Local File [WWW]
Endif
Return

########################################################################################
$ABANDON
GACTMODIF=0

Return
########################################################################################
$VERIF

WIND = 0
If GFONCTION = "GESADLK"
    # avoir le prob de la leg car non saissible sur le kit
    # donc aucun controle ne peut être fait
    Return
Endif

#-------------------------------------------#
# Il doit y avoir au moins 1 langue
#-------------------------------------------#
If [M:ADLV4]NBRLAN<1
    GMESSAGE = mess(8,125,1)
    OK = 0 : SUIZON = "[ADLV4]NBRLAN" : Return
Endif

#-------------------------------------------#
# Il doit y avoir au moins 1 leg
#-------------------------------------------#
If [M:ADLV4]NBRLEG<1
    #"Une leg doit etre saisie"
    GMESSAGE = mess (241,133,1)
    OK = 0 : SUIZON = "[ADLV4]NBRLEG" : Return
Endif


#-------------------------------------------#
# pas de verif que les codes activités ont changé entre le moment de la saisie
# et l enreg. on a un bouton de verif et a la lecture les codes sont deja controles
#-------------------------------------------#

#-------------------------------------------#
# attention la leg des param doit etre dans le tableau
# a verifier et bloquer si n existe plus
#-------------------------------------------#
For WIND = 0 To [M:ADLV3]NBRSET-1
    If [M:ADLV3]CLEPARAM (WIND) <> ""
        If !find([M:ADLV3]CLEPARAM (WIND),[M:ADLV4]DOSLEG(0..[M:ADLV4]NBRLEG-1))
            # "Une leg a été saisie sur un param et n existe plus dans le tableau"
            GMESSAGE= func AFNC.MES2(mess(132,127,1),num$([M:ADLV3]CLEPARAM (WIND)),num$([M:ADLV3]CLEPARAM (WIND)))
            OK = 0 : SUIZON = "[ADLV3]NBRSET("+num$(WIND)+")" : Return
        Endif
    Endif
Next WIND

#-------------------------------------------#
# attention la leg des cles fihciers doit etre dans le tableau
# a verifier et bloquer si n existe plus
#-------------------------------------------#
WIND = 0
For WIND = 0 To [M:ADLV6B]NBROBJ-1
    If [M:ADLV6B]TABLEG (WIND) <> ""
        If !find([M:ADLV6B]TABLEG (WIND),[M:ADLV4]DOSLEG(0..[M:ADLV4]NBRLEG-1))
            # "Une leg a été saisie sur cet objet et n existe plus dans le tableau"
            GMESSAGE= func AFNC.MES2(mess(136,127,1),num$([M:ADLV6B]TABLEG (WIND)),num$([M:ADLV6B]TABCOD (WIND)))
            # voir a recup le numero ligne de la table pour afficher la ligne en cause
            Local Integer WINDTAB
            WINDTAB = find([M:ADLV6B]TABCOD (WIND),[M:ADLV6]TABCOD1(0..[M:ADLV6]NBRTAB-1))
            OK = 0
            If WINDTAB <> 0
                SUIZON = "[ADLV6]NBRTAB("+num$(WINDTAB)+")"
            Else
                SUIZON = "[ADLV6]NBRTAB"
            Endif
            Return
        Endif
    Endif
Next WIND


#-------------------------------------------#
# Il doit y avoir au moins 1 module
#-------------------------------------------#
If [M:ADLV1]NBRMOD <1
    GMESSAGE = mess(263,125,1)
    OK = 0 : SUIZON = "[ADLV1]NBRMOD" : Return
Endif

Return

########################################################################################
$RAZDUP
GACTMODIF = 0

If GFONCTION = "GESADLK"
    [M:ADLK0]ADLVTYP= 2
Else
    [M:ADLV0]ADLVTYP= 1
Endif
Return

########################################################################################
$RAZCRE
GACTMODIF = 0

If GFONCTION = "GESADLK"
    [M:ADLK0]ADLVTYP= 2
    Gosub INIT_NBRACT
Else
    [M:ADLV0]ADLVTYP= 1
    Gosub INIT_NBRMOD
    Gosub INIT_NBRACT
Endif

Return

########################################################################################
$MODIF
Call MAJTEXTRA([M]DLVDES,"ADELIVER","DLVDES",[M]COD,"") From ATEXTRA
Call CRE_CODACT_TYP1
Call CRE_PARAM
Call CRE_CODACT_TYP2
Call CRE_OBJ
If GFONCTION <> "GESADLK"
    Call CRE_FNCBDG
    Call CRE_ASWBDG
    Call CRE_SES
    Call CRE_LIM
Endif
Return

########################################################################################
$CREATION
Call MAJTEXTRA([M]DLVDES,"ADELIVER","DLVDES",[M]COD,"") From ATEXTRA
Call CRE_CODACT_TYP1
Call CRE_PARAM
Call CRE_CODACT_TYP2
Call CRE_OBJ
If GFONCTION <> "GESADLK"
    Call CRE_FNCBDG
    Call CRE_ASWBDG
    Call CRE_SES
    Call CRE_LIM
Endif

Return

########################################################################################
$ANNULE
Call DEL_CODACT
Call DEL_PARAM
Call DEL_OBJ
If GFONCTION <> "GESADLK"
    Call DEL_FNCBDG
    Call DEL_ASWBDG
    Call DEL_SES
    Call DEL_LIM
Endif
Call SUPTEXLAN("ADELIVER","DLVDES","",[M]COD,"") From ATEXTRA
Return


########################################################################################
#                              ETIQUETTES DIVERSES
########################################################################################
########################################################################################
$SETNOL
Local Shortint NOL
NOL=nolign-1
Return

########################################################################################
$INIT_NBRMOD
If [M:ADLV1]NBRMOD=0
    # on ne peut pas savoir quel module pour quel produit
    # donc on init tout à non
    Local Integer I
    [M:ADLV1]NBRMOD = len(mess(0,14,1))
    For I=1 To len(mess(0,14,1))
       If left$(mess(I,14,1),1)<>"#"
          [M:ADLV1]MODULE(I-1) = I
          # pour instant on autorise tout, on affiche tous les modules AML 14
          # par defaut valuer = non
          # les modules portes par la licence, pour instant on ne controle rien
          # car on ne sait pas comment ?
          [M:ADLV1]MODENAFLG(I-1) = 1
          # soumis licence activé en fev 2013
          [M:ADLV1]LICMODULE(I-1) = 1
          # non disponible juin 2013
          [M:ADLV1]MODNOTAVA(I-1) = 1
       Else
          [M:ADLV1]NBRMOD = I-1
          # on s arrete au premier # dasn x3 on a les 20 de renseigner pas dans superv
          Break
       Endif
    Next I
    [M:ADLV1]NBRMOD = I-1
    Affzo [M:ADLV1]30
Endif
Return

########################################################################################
$INIT_NBRACT
If [M:ADLV2]NBRACT=0
    Local Integer WIND
    # on charge tous les codes act de typ <> 2
    WIND  = 0
    Call CHARGE_CODACT(WIND)
    Affzo [M:ADLV2]
Endif
Return

########################################################################################
$CHARG_DEFAULT_NBRACT
If [M:ADLV2]NBRACT<>0
    Local Integer WIND
    #------------------------------------------------------------------------#
    # on recharge  les valeurs de la fiche dossier courant pour les typ  <> 2
    #------------------------------------------------------------------------#
    WIND  = 0
    For WIND = 0 To [M:ADLV2]NBRACT
       # lecture fiche dossier
       Read [ADA]ADA0 = nomap;[M:ADLV2]CODACT(WIND)
       If fstat = 0
         [M:ADLV2]FLGACT(WIND)   = [F:ADA]FLACT
         [M:ADLV2]LICACT(WIND)   = 1
         [M:ADLV2]NOTAVAACT(WIND)= 1
       Endif
    Next WIND
    Affzo [M:ADLV2]
Endif
Return


########################################################################################
$SUP_LIGTAB
Local Integer WNBRSUP
Local Integer WDEBLIGSUP
Local Integer WIND

WIND = 0
# suppression dans adlv6b de toutes les lignes se referant à une table
If [M:ADLV6B]NBROBJ=0
    Infbox 'action impossible pas de ligne'
Else
    # faire une boucle pour chercher le premier et le nombre a virer
    # ils sont triés deja par code table
    WNBRSUP = 0
    WDEBLIGSUP = 0
    For WIND = 0  To [M:ADLV6B]NBROBJ-1
        If [M:ADLV6B]TABCOD (WIND) = WTABREF and [M:ADLV6B]TABADINUM (WIND) = WTABADINUM
                If WNBRSUP = 0
                     WDEBLIGSUP = WIND
                Endif
                WNBRSUP +=1
        Endif
    Next WIND

    # là on vire les lignes dans adlv6b de indice debut à indice fin
    If WNBRSUP <> 0
        If dim([M:ADLV6B]TABCOD)=[M:ADLV6B]NBROBJ
              Dela WDEBLIGSUP,WNBRSUP [M:ADLV6B]NBROBJ
        Else
              Dela WDEBLIGSUP,WNBRSUP,[M:ADLV6B]NBROBJ-1 [M:ADLV6B]NBROBJ
        Endif
        [M:ADLV6B]NBROBJ-=WNBRSUP
    Endif
    If WSUPLIG = "Y"
        # si on vient de adlvw il faut virer la ligne
        # si c'est le supressiion ligne dans le tableau adlv6 pas besoin
        #
        # faire une boucle pour chercher le premier et le nombre a virer
        # ils sont triés deja par code table
        WNBRSUP = 0
        WDEBLIGSUP = 0
        For WIND = 0  To [M:ADLV6]NBRTAB-1
            If [M:ADLV6]TABCOD1 (WIND) = WTABREF and [M:ADLV6]TABADINUM1 (WIND) = WTABADINUM
                If WNBRSUP = 0
                     WDEBLIGSUP = WIND
                Endif
                WNBRSUP +=1
            Endif
        Next WIND
        # là on vire les lignes dans adlv6 de indice debut à indice fin
        If WNBRSUP <> 0
            If dim([M:ADLV6]TABCOD1)=[M:ADLV6]NBRTAB
              Dela WDEBLIGSUP,WNBRSUP [M:ADLV6]NBRTAB
            Else
              Dela WDEBLIGSUP,WNBRSUP,[M:ADLV6]NBRTAB-1 [M:ADLV6]NBRTAB
            Endif
            [M:ADLV6]NBRTAB-=WNBRSUP
        Endif
    Endif
Endif
Return


########################################################################################
$RAZ_NBRKEY
Local Integer WIND
WIND = 0
# on vire toutes les lignes
WIND = [M:ADLV6]NBRKEY
If WIND <> 0
        If dim([M:ADLV6]TABCOD2)=[M:ADLV6]NBRKEY
              Dela 0,WIND [M:ADLV6]NBRKEY
        Else
              Dela 0,WIND,[M:ADLV6]NBRKEY-1 [M:ADLV6]NBRKEY
        Endif
Endif
[M:ADLV6]NBRKEY = 0
Return


########################################################################################
$CHARG_LIGKEY
# chargement des cles fichiers a filtrer
[M:ADLV6]NBRKEY = 0
WIND = 0
WINDKEY = 0
#----------------------#
# On charge les codes
#----------------------#
For WIND = 0  To [M:ADLV6B]NBROBJ-1
    If [M:ADLV6B]TABCOD (WIND) = WTABREF and [M:ADLV6B]TABADINUM (WIND) = WTABADINUM
        If [M:ADLV6B]NULRECFLG (WIND) <> 2
            [M:ADLV6]TABCOD2(WINDKEY)     = [M:ADLV6B]TABCOD(WIND)
            [M:ADLV6]TABKEY2(WINDKEY)     = [M:ADLV6B]TABKEY(WIND)
            [M:ADLV6]TABLEG2(WINDKEY)     = [M:ADLV6B]TABLEG(WIND)
            [M:ADLV6]TABKEYDES2(WINDKEY)  = [M:ADLV6B]TABKEYDES(WIND)
            [M:ADLV6]NBRKEY += 1
            # voir a faire une verif avant affichage
            WINDKEY +=1
            If [M:ADLV6]NBRKEY = GMAXDIMKEY
               # 'tableau plein'
                GMESSAGE=mess (26,100,1)+"\[M:ADLV6]NBRKEY"
                Call MESSAGE(GMESSAGE) From GESECRAN
                Raz GMESSAGE
                Break
            Endif
        Endif
    Endif
Next WIND
Affzo [M:ADLV6]15
Return

########################################################################################
$READ_FILE
WINTIT =""
If clalev([F:WWW])<>0
      Close Local File [WWW]
Endif
# on lit aussi le modele
Read [F:AWM]AWM0 = [F:ADLO]TABAWM
If fstat <> 0
       # il peut y avoir +siuers erreur dans le livrable et donc pour ne pas toutes les afficher une a une
       # on affiche donc seulement le fait de lancer la verif de cohérence (bouton)
       GMESSAGE = mess (15,7999,1)
       # pour la trace et message en une fois
       #"prob modele n existe plus"
       WMESSAGE = num$([F:ADLO]TABAWM)-mess (7,140,1)
       GFLGKO = 2
Elsif [F:AWM]TABREF <> [F:ADLO]TABCOD
       # il peut y avoir +siuers erreur dans le livrable et donc pour ne pas toutes les afficher une a une
       # on affiche donc seulement le fait de lancer la verif de cohérence (bouton)
       GMESSAGE = mess (15,7999,1)
       # pour la trace
       #"prob modele n est plus conforme"
       WMESSAGE = num$([F:ADLO]TABAWM)-mess (1,7999,1)
       GFLGKO = 2
Endif

Read [ATB]CODFIC=[F:ADLO]TABCOD
If fstat = 0
   If [F:ATB]INTIT<>""
        WINTIT = [F:ATB]INTIT
   Endif
   If filinfo(filpath("FIL",[F:ADLO]TABCOD,"fde"),0)>=0
        # si aucune donnée a prendre pas besoin de chercher le format de cle et la cle
        If [F:ADLO]NULRECFLG <> 2
            Local File =[F:ADLO]TABCOD [WWW]
            Local Char WELTKEY   (250)
            Local Char WELTKEYFMT(250)
            Local Char WELTFIELD (250)
            Call SET_IDENT_KEY ([F:ADLO]TABCOD,WELTKEY,WELTKEYFMT,WELTFIELD) From SUBADLVW
            If WELTKEYFMT <> [F:ADLO]TABKEYFMT
                # il peut y avoir +siuers erreur dans le livrable et donc pour ne pas toutes les afficher une a une
                # on affiche donc seulement le fait de lancer la verif de cohérence (bouton)
                GMESSAGE = mess (15,7999,1)
                # pour la trace
                # 'prob la cle ne correspond plus, il faut supprimer vos élements avant de refaire une sel pour
                WMESSAGE = num$([F:ADLO]TABAWM)-num$([F:ADLO]TABCOD)-mess (12,7999,1)
                GFLGKO = 2
            Endif
        Endif
    Else
        # il peut y avoir +siuers erreur dans le livrable et donc pour ne pas toutes les afficher une a une
        # on affiche donc seulement le fait de lancer la verif de cohérence (bouton)
        GMESSAGE = mess (15,7999,1)
        # pour la trace
        # 'prob le fichier n existe plus dans le dossier
        WMESSAGE = num$([F:ADLO]TABAWM)-num$([F:ADLO]TABCOD)-mess (14,7999,1)
        GFLGKO = 2
        # ok mais on fait quoi ??????????????????
    Endif
Else
    # il peut y avoir +siuers erreur dans le livrable et donc pour ne pas toutes les afficher une a une
    # on affiche donc seulement le fait de lancer la verif de cohérence (bouton)
    GMESSAGE = mess (15,7999,1)
    # pour la trace
    # 'prob le fichier n existe plus dans le dossier
    WMESSAGE = num$([F:ADLO]TABAWM)-num$([F:ADLO]TABCOD)-mess (14,7999,1)
    GFLGKO = 2
    # ok mais on fait quoi ??????????????????
Endif
Return

########################################################################################
$SETCLE
# formatage cle fichiers
Raz CLE, NBCLE
While CHAINE<>""
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 NBCLE += 1
 If I
  CLE(NBCLE) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
Return

