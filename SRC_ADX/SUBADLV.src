Subprog AS_NBRACT
Gosub INIT_NBRACT
End


Subprog B1_NBRACT
# chargement des valeurs par defaut des codes activités fonctionnelles
# par rapport à la fiche dossier

# demande d une confirmation
Local Integer WOK
WOK = 0
Call OUINON (mess (50,7999,1), WOK) From GESECRAN
If WOK = 2
        Gosub CHARG_DEFAULT_NBRACT
        mkstat = 4
Else
        mkstat = 2
Endif
End

Subprog B2_NBRACT
# là on demande sur quel livrable
# action ASELADLV

End


Subprog AM_LICACT(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If VALEUR = 2
    [M:ADLV2]FLGACT (NOL)   = 1
    [M:ADLV2]NOTAVAACT (NOL)= 1
    Affzo [M:ADLV2]FLGACT (NOL)
    Affzo [M:ADLV2]NOTAVAACT (NOL)
Endif
End


