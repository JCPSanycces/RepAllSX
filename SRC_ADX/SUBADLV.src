     Call FLDCRE("ADLT") From OBJDIV
     Write [ADLT]
     If fstat
      GOK = 0 : Call FSTA("ADLT") From GLOCK : Break
     Endif
  Endif
Next nolign
If GOK<1 : End : Endif

End

