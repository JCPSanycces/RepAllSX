#<AdxTL>@(#)3.0.0.0 $Revision$
A1 =2
Local Char   FENETRE(10),APPLI(10)
APPLI=nomap
Local Integer OK,I
FENETRE = "OAWI"
#FENETRE = "AASELECT"
#FENETRE = "AACHOOSE"
#FENETRE = "AQFA"
FENETRE = "ASSOPASX3"
GTRACE = ""
#Dbgaff
Call VALID(FENETRE,APPLI,1,OK) From VALWIN
End
#  Validation Web des écrans - Création de l'XML



$VALWEB
#If APPLI<>"SUP140" : Return : Endif
Local Char WE_SEP,WE_SEP1    :  # Séparateur de répertoire
Case GOS(1)
  When "dos"  : WE_SEP="\"
  When Default : WE_SEP="/"
Endcase
WE_SEP1="/"
If dim(GI_DOSS)=-1 or GI_DOSS<>APPLI : Call GLOBWEB(APPLI) From INTRUTILA : Endif

Local Integer WE_I,WE_J,WE_K,WE_JJ   : # Variables de travail
Local Integer WE_1,WE_2,WE_3,WE_4    : # Variables de travail
Local Char    WE_ALPHAB(26) : WE_ALPHAB="ABCDEFGHIJKLMNOPQRSTUVWXYZ"
Local Char    WE_PROP(100)           : # Propriété du noeud
Local Char    WE_VALUE(100)          : # Valeur de la propriété
Local Char    WE_NOMFIC(200)         : # Nom du fichier WIND produit
Local Char    WE_NOMFIC1(200)        : # Nom du fichier WINA produit
Local Char    WE_LANG                : # Langue courante
Local Char    WE_VALL1(250)          : # Zone de stockage des tags XML
Local Integer WE_NTEX                : # No du texte à traiter
Local Char    WE_NTEXKEY(80)         : # clé unique du texte à traiter
Local Char    WE_CAPDEF(100)         : # Caption dans la langue par défaut
Local Char    VALLM(200)             : # Caption pour MODVAL
Local Char    WE_INTEV(100)          : # Intitulé évalué
Local Integer WE_NOMEN               : # Numéro de menu local
Local Integer WE_NOMES               : # Numéro de message
Local Integer WE_NIVEAU              : # Niveau de menu
Local Integer WE_MENCOU              : # Niveau courant de menu ouvert
Local Integer WE_ADXF(1..3)          : # Adxid du menu "père"
Local Integer WE_ISTD                : # Indice de la liste standard dans la liste des listes
Local Integer WE_LAST                : # Indice de la liste derniers lus dans la liste des listes
Local Integer WE_INDL                : # Indice de la liste traitée
Local Integer WE_LMENU(1..200)       : # Liste des menus locaux utilisés par la fenêtre
Local Integer WE_ILM                 : # Indice dans la liste des menus
Local Integer WE_ILAN                : # Indice dans la liste des langues
Local Integer WE_GF                  : # Flag de génération de GFOLDER
Local Integer WE_COU                 : # Indice courant
Local Integer WE_BCO                 : # Indice bouton courant
Local Integer WE_TREC                : # Transaction en cours
Local Integer WE_INDIG               : # Indice du folder courant
Local Char WE_VER                    : # Version de générateur
Local Char AWT_RAC(1)(1..MAXBOU,1..GI_NBLAN) : # Touches de raccourci pour les boutons et menus
Local Char AWI_RAC(1)(1..10,1..GI_NBLAN) : # Touches de raccourci pour les boutons "standard"
Local Char AWI_RACF(1)(1..GI_NBLAN)      : # Touches de raccourci pour le bouton Fin

# Contrôle si les écrans constituant la fenêtre sont générés et valides
# Sinon on force leur génération : Vérifie si les menus locaux de l'écran sont générés
Raz GI_VLAN
For WE_COU=1 To AWI_NBRMSK
  If AWI_NOMMSK(WE_COU)<>""
    Call ISSCRINV(APPLI,AWI_NOMMSK(WE_COU),WE_J,1) From INTRUTILB
    If(not(ISJSONONLY) or ISVT)
      Call ISMENGEN(APPLI,AWI_NOMMSK(WE_COU),WE_J,1,WE_HORDAT) From INTRUTILB
    Endif
  Endif
Next WE_COU

# Contrôle si les objets utilisés dans les listes browser de la fenêtre sont générés et valides
# Sinon on force leur génération
For WE_COU=1 To AWB_NBR
  If !find(AWB_OBJ(WE_COU),AWB_OBJ(1..WE_COU-1))
    Call ISOBJINV(APPLI,AWB_OBJ(WE_COU),WE_J,1) From INTRUTILB
    If(not(ISJSONONLY) or ISVT)
      Call ISMENOBJGEN(APPLI,AWB_OBJ(WE_COU),WE_J,1,WE_HORDAT) From INTRUTILB
    Endif
  Endif
Next WE_COU

If(not(ISJSONONLY) or ISVT)
  # Création des raccourcis
  Gosub WE_RAC

  # Ouverture fichier XML produit
  If FENETRE="AASELECT" : FENETRE="_SELBOX" : Endif
  If FENETRE="AACHOOSE" : FENETRE="_CHOOSE" : Endif
  If FENETRE="AAFORMULA" : FENETRE="_FORMULA" : Endif
  Call NAMEFIC(APPLI,"WIND","",FENETRE,WE_NOMFIC) From INTRUTILA
  Openo WE_NOMFIC,0 Using [HTM_]
  Iomode adxifs "" Using [HTM_]
  Iomode adxirs chr$(10) Using [HTM_]
  Iomode adxium GUTF8 Using [HTM_]


  # Ecriture En-tête fenêtre
  WE_VALL1='<?xml version="1.0" encoding="utf-8" ?>'
  Wrseq WE_VALL1 Using [HTM_]

  # Traitement des Include
  Gosub WE_ADDINCL

  Gosub WECR_WINDOW

  # Faut-il générer GFOLDER : Oui si il y a une entête ou plusieurs onglets
  If AWI_NOMMSK(1)<>"" : WE_GF=1 : Endif
  If WE_GF=0
    For WE_COU=2 To AWI_NBRMSK
      If AWI_FLGMSK(WE_COU)=2
        WE_GF+=1
      Endif
    Next WE_COU
    WE_GF-=1
  Endif

  If AWI_NOMMSK(1)<>"" : WE_INDIG=1 : WE_COU=1 : Gosub WECR_FOLDER : Endif
  If WE_GF=1 : Gosub WECR_GFOLDER : Endif
  For WE_COU=2 To AWI_NBRMSK
    If AWI_FLGMSK(WE_COU)=2
      WE_INDIG+=1
      Gosub WECR_FOLDER
    Endif
  Next WE_COU

  If WE_GF=1 : Gosub WECR_FGFOLDER : Endif

  # Boutons standard en bas de fenêtre
  WI_MAXBST=5        : #  Les 5 premiers sur tous les modèles sauf les consultations
  If AWI_WINTYP=3 or AWI_WINTYP=4 : WI_MAXBST=MAXBST : Endif
  For WE_COU=1 To WI_MAXBST
    If AWI_STA(WE_COU)<>0 and AWI_STA(WE_COU)<>GSTAEND
      WE_BCO+=1
      Gosub WECR_BTN_STD
    Endif
  Next WE_COU


  # Boutons spéciaux
  For WE_COU=1 To AWT_NBR
    If AWT_NIV(WE_COU)=0
      WE_BCO+=1
      Gosub WECR_BOUT
    Endif
  Next WE_COU

   # Ajout du bouton Fin
  WE_I=find(GSTAEND,AWI_STA(1..MAXBST))
  If WE_I>0 and AWI_STA(WE_I)<>0
    WE_BCO+=1
    Gosub WECR_BTN_FIN
  Endif
  # Menus et items de menus
  WE_NIVEAU=0
  WE_MENCOU=0
  WE_1=0
  For WE_COU=1 To AWT_NBR
    If AWT_NIV(WE_COU)<>0
      WE_K=AWT_NIV(WE_COU)/10
      If WE_K<>WE_NIVEAU
        Gosub WE_CHGNIV
      Else
        If AWT_COD(WE_COU)=""        : #  C'est un sous-menu
          If WE_MENCOU=2 : Gosub WECR_FMENU : Endif
          WE_MENCOU=2 : WE_ADXF(WE_MENCOU)=WE_COU : Gosub WECR_MENU
        Else                         : #  C'est un Item de menu
          If AWT_NIV(WE_COU)<>WE_1 : WE_MENCOU=1 : Gosub WECR_FMENU : Endif  : # Bug 23039
          Gosub WECR_ITEM
        Endif
      Endif
    Endif
    WE_1=AWT_NIV(WE_COU)
  Next WE_COU


  For WE_COU=1 To WE_MENCOU
    Gosub WECR_FMENU
  Next WE_COU


  # Listes de browser
  Raz WE_GF
  For WE_COU=1 To AWB_NBR
    Case AWB_NUM(WE_COU)
      When ""        : WE_INDL=1
      When "9"       : WE_INDL=2
      When Default   : WE_INDL=3
    Endcase
    WE_GF+=1
    If WE_GF=1 : Gosub WECR_GLISTE : Endif
    Gosub WECR_LISTE
  Next WE_COU
  If WE_GF<>0 : Gosub WECR_FGLISTE : Endif


  Gosub WECR_FWINDOW



  Openo Using [HTM_]

  # Génération FENX et FENW
    Gosub WE_GENFEN
    If WE_3=0 : Goto WE_FGWIN : Endif
Endif
#  Mise à jour des liens
If adxlog=0
  WE_TREC=1
  Trbegin [AEL],[AEK]
Endif
Gosub WI_CREWIND From INTRUTILB
If WE_TREC=1 : Commit : Endif

$WE_FGWIN:
Raz WE_VALUE
For WE_3=1 To GI_NBLAN
  If GI_VLAN(WE_3)=1 : WE_VALUE-=GI_LLAN(WE_3) : Endif
Next WE_3
If WE_VALUE<>"" :
  If mess(193,151,1)<>""
    WE_PROP=mess(193,151,1)
  Else
    WE_PROP="Fenêtre non assemblée en langue(s) : "
  Endif
  Call ECR_TRACE(WE_PROP-WE_VALUE,1) From GESECRAN
Endif
Raz GI_VLAN
If FENETRE="_SELBOX"  : FENETRE="AASELECT"  : Endif
If FENETRE="_CHOOSE"  : FENETRE="AACHOOSE"  : Endif
If FENETRE="_FORMULA" : FENETRE="AAFORMULA" : Endif


Gosub JSON From VALWINJSON


Return



#  On change de niveau
$WE_CHGNIV
  For indice=1 To WE_MENCOU
    Gosub WECR_FMENU
  Next indice
  WE_MENCOU=1
  WE_ADXF(WE_MENCOU)=WE_COU
  Gosub WECR_MENU
  WE_NIVEAU=AWT_NIV(WE_COU)/10
Return



# -------------------------------------------------------------------------------
#   Ecriture par type d'élément
# -------------------------------------------------------------------------------


#  1 - Type WINDOW

$WECR_WINDOW:
  # Ecriture Entête fenêtre
  WE_VALL1="<WIND"
  WE_PROP="NAM"   : WE_VALUE=FENETRE : Gosub WE_ADDPROP
  WE_PROP="TIM"   : WE_VALUE=WE_HORDAT : Gosub WE_ADDPROP
  WE_PROP="APP"   : WE_VALUE=APPLI : Gosub WE_ADDPROP
  WE_PROP="VER"   : WE_VALUE=GI_VGEN : Gosub WE_ADDPROP
  WE_NTEX=AWI_DES : WE_CAPDEF="" : WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub WE_ADDNTEX From VALMSKWEB
  If AWI_TYP=9 : AWI_TYP=2 : Endif
  WE_PROP="TYF"  : WE_VALUE=num$(AWI_TYP) : Gosub WE_ADDPROP
  WE_PROP="WTY"  : WE_VALUE=num$(AWI_WINTYP) : Gosub WE_ADDPROP
  WE_PROP="GPO"
  Case GPRODUIT
     When -1 : WE_VALUE = "ADX"
     When  0 : WE_VALUE = "ADX"  : # X3
     When  1 : WE_VALUE = "GEO"  : # Géode
     When  2 : WE_VALUE = "INN"  : # Paye
     When  3 : WE_VALUE = "ABE"  : # Biens
     When  Default : WE_VALUE = "ADX"
  Endcase
  Gosub WE_ADDPROP
  If AWB_NBR>0
    WE_PROP="ALG"  : WE_VALUE=num$(max(1,AWB_AFL)) : Gosub WE_ADDPROP
  Endif
  WE_PROP="PRO"
  WE_VALUE=".."+WE_SEP1+".."+WE_SEP1+".."+WE_SEP1+".."+WE_SEP1+"X3_ROOT"+WE_SEP1+"XSL"+WE_SEP1
  Case AWI_WINTYP
    When 5        :
              If    FENETRE="_SELBOX" : WE_VALUE+="SELBOX.xsl"
              Elsif FENETRE="_CHOOSE"  : WE_VALUE+="CHOOSE.xsl"
              Elsif FENETRE="_FORMULA"  : WE_VALUE+="FORMULA.xsl"
              Else  WE_VALUE+="BOX.xsl" : Endif
    When Default  : WE_VALUE+="BOX.xsl"
  Endcase
  Gosub WE_ADDPROP
  Gosub WE_FINF
Return

$WECR_FWINDOW:
  # Ecriture Fin En-tête fenêtre
  WE_VALL1="</WIND"
  Gosub WE_FINF
Return


#  2 - Type GFOLDER

$WECR_GFOLDER:
  # Ecriture Groupe d'onglets
  WE_VALL1="<GFO"
  WE_PROP="XID" : WE_VALUE=num$(35*256*256) : Gosub WE_ADDPROP
  Gosub WE_FINF
Return

$WECR_FGFOLDER:
  # Ecriture Fin Groupe d'onglets
  WE_VALL1="</GFO"
  Gosub WE_FINF
Return


#  3 - Type FOLDER

$WECR_FOLDER:
  # Ecriture onglet
  WE_VALL1="<FOL "
  WE_PROP="NAM" : WE_VALUE=AWI_NOMMSK(WE_COU) : Gosub WE_ADDPROP
  WE_PROP="XID" : WE_VALUE=num$(WE_INDIG*256*256) : Gosub WE_ADDPROP
  WE_PROP="XD1" : WE_VALUE=mid$(WE_ALPHAB,WE_INDIG,1) : Gosub WE_ADDPROP
  WE_NTEX=AWI_INTMSK(WE_COU) : WE_CAPDEF=""  : WE_INTEV=""
  If WE_NTEX=0 and WE_INDIG>1 : WE_NTEX=-100016 : Endif
  WE_FORCE=0 : WE_LCH=0 : Gosub WE_ADDNTEX From VALMSKWEB
  Gosub WE_FINF
  WE_VALL1="&"+AWI_NOMMSK(WE_COU)+"; "
  Wrseq WE_VALL1 Using [HTM_]
  Gosub WECR_FFOLDER
Return

$WECR_FFOLDER:
  # Ecriture Fin onglets
  WE_VALL1="</FOL"
  Gosub WE_FINF
Return


#  4 - Type Bouton standard

$WECR_BTN_STD:
  # Ecriture Bouton
  WE_VALL1="<BOU"
  WE_PROP="NAC"       : WE_VALUE=num$(AWI_STA(WE_COU)+1024) : Gosub WE_ADDPROP
  WE_PROP="XID" : WE_VALUE=num$(33*256*256+256+WE_BCO) : Gosub WE_ADDPROP
  WE_PROP="XD1" : WE_VALUE="A"+num$(WE_BCO) : Gosub WE_ADDPROP
  WE_NTEX=AWI_TXT(WE_COU) : WE_CAPDEF=""
  WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub WE_ADDNTEX From VALMSKWEB
  Gosub WE_TYPB
  Gosub WE_ECRRACI
  Gosub WE_FINFF
Return

$WECR_BTN_FIN:
  # Ecriture Bouton Fin
  WE_VALL1="<BOU"
  WE_PROP="NAC"
  WE_VALUE=num$(GSTAEND+1024)
  If FENETRE="DEBUGGER": WE_VALUE=num$(GSTAESC+1024) : Endif
  Gosub WE_ADDPROP
  WE_PROP="XID" : WE_VALUE=num$(33*256*256+256+WE_BCO) : Gosub WE_ADDPROP
  WE_PROP="XD1" : WE_VALUE="A"+num$(WE_BCO) : Gosub WE_ADDPROP
  WE_NTEX=-123065 : WE_CAPDEF=""
  WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub WE_ADDNTEX From VALMSKWEB
  WE_PROP="BTX" : WE_VALUE="END" : Gosub WE_ADDPROP
  Gosub WE_ECRRACF
  Gosub WE_FINFF
Return

#  5 - Menu Actions Fenêtre

$WECR_MENU:
  # Ecriture Menu
#Local Integer AWT_VAL(1..MAXBOU)                         : # Code (1)Invalidant/(2)Validant
#Local Integer AWT_TYP(1..MAXBOU)                         : # Type bouton (Bouton/Menu/Ligne)
  WE_VALL1="<MAW"
  WE_PROP="XID" : WE_VALUE=num$(33*256*256+256*2+WE_COU) : Gosub WE_ADDPROP
  If WE_MENCOU > 1
    WE_PROP="IDF" : WE_VALUE=num$(33*256*256+256*2+WE_ADXF(WE_MENCOU-1)) : Gosub WE_ADDPROP
  Endif
  WE_NTEX=AWT_TXT(WE_COU) : WE_CAPDEF=""
  WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub WE_ADDNTEX From VALMSKWEB
  WE_PROP="NIV"       : WE_VALUE=num$(100+AWT_NIV(WE_COU)) : Gosub WE_ADDPROP
  WE_PROP="RG"       : WE_VALUE=num$(WE_COU) : Gosub WE_ADDPROP
#  WE_PROP="ACC"       : WE_VALUE=num$(WE_COU) : Gosub WE_ADDPROP  : #  Accélérateur Menu Adonix
  Gosub WE_ECRRAC
  Gosub WE_FINF
Return

$WECR_FMENU:
  # Ecriture Fin Groupe d'onglets
  WE_VALL1="</MAW"
  Gosub WE_FINF
Return


#  6 - Item de menu

$WECR_ITEM:
  # Ecriture Item de menu
#Local Integer AWT_VAL(1..MAXBOU)                         : # Code (1)Invalidant/(2)Validant
#Local Integer AWT_TYP(1..MAXBOU)                         : # Type bouton (Bouton/Menu/Ligne)
  WE_VALL1="<ITM"
  WE_PROP="XID" : WE_VALUE=num$(33*256*256+256*2+WE_COU) : Gosub WE_ADDPROP
  If WE_MENCOU > 0
    WE_PROP="IDF" : WE_VALUE=num$(33*256*256+256*2+WE_ADXF(WE_MENCOU)) : Gosub WE_ADDPROP
  Endif
  WE_PROP="NAC"       : WE_VALUE=num$(AWT_STA(WE_COU)+1024) : Gosub WE_ADDPROP
  WE_NTEX=AWT_TXT(WE_COU) : WE_CAPDEF=""
  WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub WE_ADDNTEX From VALMSKWEB
  WE_PROP="NIV"       : WE_VALUE=num$(100+AWT_NIV(WE_COU)) : Gosub WE_ADDPROP
  WE_PROP="RG"       : WE_VALUE=num$(WE_COU) : Gosub WE_ADDPROP
  WE_PROP="COD"       : WE_VALUE=num$(AWT_COD(WE_COU)) : Gosub WE_ADDPROP
  Gosub WE_ECRRAC
  Gosub WE_FINFF
Return


#  7 - Bouton

$WECR_BOUT:
  # Ecriture Bouton
  WE_VALL1="<BOU"
  If FENETRE="DEBUGGER"
    Case AWT_COD(WE_COU)
      When "L" : AWT_STA(WE_COU)=201
      When "C" : AWT_STA(WE_COU)=203
      When "V" : AWT_STA(WE_COU)=GSTABOU2
    Endcase
  Endif
  If FENETRE="_FORMULA"
    Case AWT_COD(WE_COU)
      When "a" : AWT_STA(WE_COU)=1
      When "b" : AWT_STA(WE_COU)=7
      When "c" : AWT_STA(WE_COU)=46
    Endcase
  Endif
  WE_PROP="NAC"       : WE_VALUE=num$(AWT_STA(WE_COU)+1024) : Gosub WE_ADDPROP
  WE_PROP="XID" : WE_VALUE=num$(33*256*256+256+WE_BCO) : Gosub WE_ADDPROP
  WE_PROP="XD1" : WE_VALUE="A"+num$(WE_BCO) : Gosub WE_ADDPROP
  If AWT_ACT(WE_COU)>0 and ACT_COD(AWT_ACT(WE_COU))="AVTPAGE"
    WE_PROP="PAG" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  WE_NTEX=AWT_TXT(WE_COU) : WE_CAPDEF=""
  WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub WE_ADDNTEX From VALMSKWEB
  WE_PROP="COD"       : WE_VALUE=num$(AWT_COD(WE_COU)) : Gosub WE_ADDPROP
  Gosub WE_ECRRAC
  Gosub WE_FINFF
Return


#  6 - Type Gliste

$WECR_GLISTE:
  # Ecriture Liste
  WE_VALL1="<GLI"
  Gosub WE_FINF
Return

$WECR_FGLISTE:
  # Ecriture Liste
  WE_VALL1="</GLI"
  Gosub WE_FINF
Return


#  7 - Type Liste

$WECR_LISTE:
  # Ecriture Liste
  WE_VALL1="<LST"
  WE_PROP="XID" : WE_VALUE=num$(34*256*256+WE_COU*256) : Gosub WE_ADDPROP
  WE_NTEX=AWB_INT(WE_COU) : WE_CAPDEF=""
  WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub WE_ADDNTEX From VALMSKWEB
  WE_PROP="OBJ"        : WE_VALUE=AWB_OBJ(WE_COU) : Gosub WE_ADDPROP
  WE_PROP="FLI"        : WE_VALUE=num$(WE_INDL) : Gosub WE_ADDPROP
  WE_PROP="TRI"        : WE_VALUE=num$(AWB_ORD(WE_COU)) : Gosub WE_ADDPROP
  WE_VALUE=num$(AWB_TRE(WE_COU))
  If WE_INDL=2 : WE_VALUE="1" : Endif
  WE_PROP="TYL"        : Gosub WE_ADDPROP
  If WE_VALUE="2" or WE_VALUE="3"
    WE_3=1 : WE_2=1
    If AWB_IND(WE_COU)<>""
      For WE_1=1 To len(AWB_IND(WE_COU))
        If mid$(AWB_IND(WE_COU),WE_1,1)="+" or mid$(AWB_IND(WE_COU),WE_1,1)="-" : WE_3+=1 : Endif
      Next WE_1
    Else
      WE_3=AWB_NBSEL(WE_COU)
    Endif
    WE_PROP="NBK"        : WE_VALUE=num$(WE_3) : Gosub WE_ADDPROP
  Endif
  WE_PROP="NBZ"        : WE_VALUE=num$(AWB_NBSEL(WE_COU)) : Gosub WE_ADDPROP
  If AWB_FLE(WE_COU)=1 or WE_INDL=2 : # Liste sans fleches de défilement (dont derniers lus)
    WE_PROP="NPS"        : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  Gosub WE_FINF
  WE_VALL1="&Q_"+AWB_OBJ(WE_COU)+"; "
  Wrseq WE_VALL1 Using [HTM_]
  Gosub WECR_FLISTE
Return

$WECR_FLISTE:
  # Ecriture Fin liste
  WE_VALL1="</LST"
  Gosub WE_FINF
Return


# -------------------------------------------------------------------------------
# -------------------------------------------------------------------------------
# -------------------------------------------------------------------------------
#   Utilitaires d'écriture



$WE_FINF
#      Ferme le tag et écrit l'enregistrement
  WE_VALL1+=">"
  Wrseq WE_VALL1 Using [HTM_]
Return


$WE_FINFF
#      Ferme le tag avec / et écrit l'enregistrement
  WE_VALL1+="/>"
  Wrseq WE_VALL1 Using [HTM_]
Return


$WE_ECRRAC
  For WE_J=1 To GI_NBLAN
    WE_PROP="R_"+GI_LLAN(WE_J)
    WE_VALUE=AWT_RAC(WE_COU,WE_J)
    If AWT_RAC(WE_COU,WE_J)<>"<" and AWT_RAC(WE_COU,WE_J)<>">" and AWT_RAC(WE_COU,WE_J)<>"&"
      VALLM=WE_VALUE
      Gosub MVALC From INTRUTILA
      WE_VALUE=VALLM
      Gosub WE_ADDPROP
    Endif
  Next WE_J
Return

$WE_ECRRACI
  For WE_J=1 To GI_NBLAN
    WE_PROP="R_"+GI_LLAN(WE_J)
    WE_VALUE=AWI_RAC(WE_COU,WE_J)
    VALLM=WE_VALUE
    Gosub MVALC From INTRUTILA
    WE_VALUE=VALLM
    Gosub WE_ADDPROP
  Next WE_J
Return

$WE_ECRRACF
  For WE_J=1 To GI_NBLAN
    WE_PROP="R_"+GI_LLAN(WE_J)
    WE_VALUE=AWI_RACF(WE_J)
    VALLM=WE_VALUE
    Gosub MVALC From INTRUTILA
    WE_VALUE=VALLM
    Gosub WE_ADDPROP
  Next WE_J
Return

$WE_ADDPROP
#      Ajoute une propriété et écrit un enreg si la longueur de la ligne est > 100
  If len(WE_VALL1)+len(WE_PROP)+len(WE_VALUE) > 100
    Wrseq WE_VALL1 Using [HTM_]
    WE_VALL1=WE_PROP+'="'+WE_VALUE+'"'
  Else
    WE_VALL1-=WE_PROP+'="'+WE_VALUE+'"'
  Endif
Return



$WE_ADDINCL
For indice=1 To GI_NBLAN
  If GI_LLAN(indice)="" : Break 1 : Endif
  WE_LANG=GI_LLAN(indice)
  Call NAMEFIC(APPLI,"WINA",WE_LANG,FENETRE,WE_NOMFIC1) From INTRUTILA
  Openo WE_NOMFIC1,0 Using [INA_]
  Iomode adxifs "" Using [INA_]
  Iomode adxirs chr$(10) Using [INA_]
  Iomode adxium GUTF8 Using [INA_]
  WE_VALL1='<?xml version="1.0" encoding="utf-8" standalone="yes" ?>'
  Wrseq WE_VALL1 Using [INA_]
  WE_VALUE=".."+WE_SEP1+".."+WE_SEP1+".."+WE_SEP1+".."+WE_SEP1+"X3_ROOT"+WE_SEP1+"XSL"+WE_SEP1
  Case AWI_WINTYP
    When 5        :
              If    FENETRE="_SELBOX" : WE_VALUE+="SELBOX.xsl"
              Elsif FENETRE="_CHOOSE"  : WE_VALUE+="CHOOSE.xsl"
              Elsif FENETRE="_FORMULA"  : WE_VALUE+="FORMULA.xsl"
              Else  WE_VALUE+="BOX.xsl" : Endif
    When Default  : WE_VALUE+="BOX.xsl"
  Endcase
  WE_VALL1='<?xml-stylesheet type="text/xsl" href="'+WE_VALUE+'"?>'
  Wrseq WE_VALL1 Using [INA_]
  WE_VALL1="<!DOCTYPE WINDOW ["
  Wrseq WE_VALL1 Using [INA_]
  If AWI_NOMMSK(1)<>""
    WE_COU=1
    WE_VALL1='<!ENTITY '+AWI_NOMMSK(1)+' PUBLIC "SCRN,ALL" "..'+WE_SEP1+'..'
    WE_VALL1+=WE_SEP1+'ALL'+WE_SEP1+'SCRN'+WE_SEP1+AWI_NOMMSK(1)+'.xml">'
    Wrseq WE_VALL1 Using [INA_]
    Gosub WE_LISTMEN
  Endif
  For WE_COU=2 To AWI_NBRMSK
    If AWI_FLGMSK(WE_COU)=2
      WE_VALL1='<!ENTITY '+AWI_NOMMSK(WE_COU)+' PUBLIC "SCRN,ALL" "..'+WE_SEP1+'..'
      WE_VALL1+=WE_SEP1+'ALL'+WE_SEP1+'SCRN'+WE_SEP1+AWI_NOMMSK(WE_COU)+'.xml">'
      Wrseq WE_VALL1 Using [INA_]
      Gosub WE_LISTMEN
    Endif
  Next WE_COU

# Inclut les objets
  For WE_COU=1 To AWB_NBR
    If !find(AWB_OBJ(WE_COU),AWB_OBJ(1..WE_COU-1))
      WE_VALL1='<!ENTITY Q_'+AWB_OBJ(WE_COU)+' PUBLIC "OBJT,ALL" "..'+WE_SEP1+'..'
      WE_VALL1+=WE_SEP1+'ALL'+WE_SEP1+'OBJT'+WE_SEP1+"OBJ_"+AWB_OBJ(WE_COU)+'.xml">'
      Wrseq WE_VALL1 Using [INA_]
      Gosub WE_OBJMEN
    Endif
  Next WE_COU


  WE_VALL1='<!ENTITY W_'+FENETRE+' PUBLIC "WIND,ALL" "..'+WE_SEP1
  WE_VALL1+='..'+WE_SEP1+'ALL'+WE_SEP1+'WIND'+WE_SEP1+FENETRE+'.xml">'
  Wrseq WE_VALL1 Using [INA_]
  Local Char WE_MENU
  For WE_I=1 To WE_ILM
    WE_VALUE="M"+format$("N0:"+func GENMENULOC.FMTMNL(WE_LMENU(WE_I)),WE_LMENU(WE_I))
    WE_VALL1='<!ENTITY '+WE_VALUE+' PUBLIC "MENL,'+WE_LANG+'" "..'+WE_SEP1
    WE_VALL1+='..'+WE_SEP1+WE_LANG+WE_SEP1+'MENL'+WE_SEP1+WE_VALUE+'.xml">'
    Wrseq WE_VALL1 Using [INA_]
  Next WE_I
#  If AWI_WINTYP<>5
#    WE_VALL1='<!ENTITY M0152   PUBLIC "SRVL,'+WE_LANG+',X3" "..'+WE_SEP1
#    WE_VALL1+='..'+WE_SEP1+'..'+WE_SEP1+'..'+WE_SEP1+'X3_ROOT'+WE_SEP1+'GEN'+WE_SEP1+WE_LANG
#    WE_VALL1+=WE_SEP1+'SRVL'+WE_SEP1+'M0152.xml">'
#    Wrseq WE_VALL1 Using [INA_]
#  Endif
  If AWI_WINTYP<>5
    WE_VALL1='<!ENTITY M9804 PUBLIC "SRVL,'+WE_LANG+'" "..'+WE_SEP1
    WE_VALL1+='..'+WE_SEP1+WE_LANG+WE_SEP1+'SRVL'+WE_SEP1+'M9804.xml">'
    Wrseq WE_VALL1 Using [INA_]
  Endif
  WE_VALL1=']>'
  Wrseq WE_VALL1 Using [INA_]
  WE_VALL1='<MAIN LANG="_'+WE_LANG+'">&W_'+FENETRE+'; '
  Wrseq WE_VALL1 Using [INA_]


# Appel des copies des menus locaux
  WE_VALL1="<MENLOC>"
  If AWI_WINTYP<>5 :  WE_VALL1+="&M9804;" : Endif
  For WE_COU=1 To WE_ILM
    If len(WE_VALL1)>120 : Wrseq WE_VALL1 Using [INA_] : WE_VALL1="" : Endif
    WE_VALL1+="&M"+format$("N0:"+func GENMENULOC.FMTMNL(WE_LMENU(WE_COU)),WE_LMENU(WE_COU))+";"
  Next WE_COU
  WE_VALL1+="</MENLOC></MAIN>"
  Wrseq WE_VALL1 Using [INA_]
  Openo Using [INA_]
Next indice
Return



#  Recherche les menus locaux liés à chaque écran
$WE_LISTMEN:
  Filter [AEK] Where ELTTYP="SCRN" and ELT=AWI_NOMMSK(WE_COU)
  For [AEK]
    If [F:AEK]ELTTYPLK="MENL"
      WE_NOMEN=val(right$([F:AEK]ELTLK,2))
      If !find(WE_NOMEN,WE_LMENU(1..WE_ILM))
        WE_ILM+=1
        WE_LMENU(WE_ILM)=WE_NOMEN
      Endif
    Endif
  Next
  Filter [AEK]
Return


#  Recherche les menus locaux liés à chaque objet
$WE_OBJMEN:
  Filter [AEK] Where ELTTYP="OBJT" and ELT=AWB_OBJ(WE_COU)
  For [AEK]
    If [F:AEK]ELTTYPLK="MENL"
      WE_NOMEN=val(right$([F:AEK]ELTLK,2))
      If !find(WE_NOMEN,WE_LMENU(1..WE_ILM))
        WE_ILM+=1
        WE_LMENU(WE_ILM)=WE_NOMEN
      Endif
    Endif
  Next
  Filter [AEK]
Return


$WE_GENHTML
  Local Char WK_RESULT(200)(1..10),WK_FICTRA(200),WK_ORDERC(250)
  Local Integer WK_RG
  WK_ORDERC="ae_buildhtml "
  WK_FICTRA=filpath(APPLI,"","","X3_PUB")
  WK_RG=instr(1,WK_FICTRA,"@")
  If WK_RG<>0 : WK_FICTRA=right$(WK_FICTRA,WK_RG+1) : Endif
  If GOS(1)<>"dos" : WK_ORDERC+="-a" : Endif
  WK_ORDERC+=WK_FICTRA+" "
  If GOS(1)<>"dos" : WK_ORDERC+="-f" : Endif
  WK_ORDERC-=FENETRE
  WE_3=0
  For WE_COU=1 To GI_NBLAN
    If GI_LLAN(WE_COU)="" : Break 1 : Endif
    If GI_VLAN(WE_COU)=0 : WK_ORDERC-=GI_LLAN(WE_COU) : WE_3+=1 : Endif
  Next WE_COU
  If WE_3=0 : Return : Endif      : # On ne génère pas (langue invalidée)
  System WK_RESULT = adxmac(0)+"@"+WK_ORDERC

  WK_FICTRA = filpath(APPLI+WE_SEP+"TMP",FENETRE,"tmp","X3_PUB")
  Gosub WE_EFFACE1
Return


$WE_GENFEN
  Local Char WK_RESULT(200)(1..10),WK_FICTRA(200),WK_ORDERC(250)
  Local Integer WK_RG
  WK_ORDERC="ae_parse "
  If GOS(1)<>"dos" : WK_ORDERC+="-t" : Endif
#  Call PARAM("","WEBPAGE",WE_VALUE) From ADOVAL
  WE_VALUE="1"
  If WE_VALUE="2"
    WK_ORDERC+="X "
  Else
    WK_ORDERC+="T "
  Endif

  WK_FICTRA=filpath(APPLI,"","","X3_PUB")
  WK_RG=instr(1,WK_FICTRA,"@")
  If WK_RG<>0 : WK_FICTRA=right$(WK_FICTRA,WK_RG+1) : Endif
  If GOS(1)<>"dos" : WK_ORDERC+="-a" : Endif
  WK_ORDERC+=WK_FICTRA+" "
  If GOS(1)<>"dos" : WK_ORDERC+="-f" : Endif
  WK_ORDERC-=FENETRE
  WE_3=0
  For WE_COU=1 To GI_NBLAN
    If GI_LLAN(WE_COU)="" : Break 1 : Endif
    If GI_VLAN(WE_COU)=0 : WK_ORDERC-=GI_LLAN(WE_COU) : WE_3+=1 : Endif
  Next WE_COU
#Infbox(WK_ORDERC)
  If WE_3=0 : Return : Endif      : # On ne génère pas (langue invalidée)
  System WK_RESULT = adxmac(0)+"@"+WK_ORDERC

  WK_FICTRA = filpath(APPLI+WE_SEP+"TMP",FENETRE,"tmp","X3_PUB")
  Gosub WE_EFFACE1
#  Call PARAM("","WEBPAGE",WE_VALUE) From ADOVAL
#  If WE_VALUE="2" : Gosub WE_GENHTML : Endif
If ISVT : Gosub WE_GENFENVT : Endif
  Gosub WE_EFFACE
Return


$WE_GENFENVT
  Gosub VERIFREP
  Local Char WK_RESULT(200)(1..10),WK_FICTRA(200),WK_ORDERC(250)
  Local Integer WK_RG
  Local Integer WS_K,WS_S
  Case GOS(1)
    When "dos"   : WS_SEP="\"
    When Default : WS_SEP="/"
  Endcase

  WK_ORDERC="ae_parsevt "

  WK_FICTRA=filpath(APPLI,"","","X3_PUB")
  WK_RG=instr(1,WK_FICTRA,"@")
  If WK_RG<>0 : WK_FICTRA=right$(WK_FICTRA,WK_RG+1) : Endif
  If GOS(1)<>"dos" : WK_ORDERC+="-a" : Endif
  WK_ORDERC+=WK_FICTRA+" "
  If GOS(1)<>"dos" : WK_ORDERC+="-f" : Endif
  WK_ORDERC-=FENETRE
  WE_3=0
  For WE_COU=1 To GI_NBLAN
    If GI_LLAN(WE_COU)="" : Break 1 : Endif
    If GI_VLAN(WE_COU)=0 : WK_ORDERC-=GI_LLAN(WE_COU) : WE_3+=1 : Endif
  Next WE_COU
#Infbox(WK_ORDERC)
  If WE_3=0 : Return : Endif      : # On ne génère pas (langue invalidée)
  System WK_RESULT = adxmac(0)+"@"+WK_ORDERC

  WK_FICTRA = filpath(APPLI+WS_SEP+"TMP",FENETRE,"tmp","X3_PUB")
  Gosub WE_EFFACE1

#  Gosub WE_EFFACE
Return


$VERIFREP
                                   #  Inutile à présent (environnements stabilisés)
                                   #  Remis pour FENT seulement
  Local Char WS_REPERT(200),WS_ORDSYS(200),WS_SEP
  Local Integer WS_K,WS_S
  Case GOS(1)
    When "dos"   : WS_SEP="\"
    When Default : WS_SEP="/"
  Endcase
  If dim(GI_LLAN)<0 : Call GLOBWEB(APPLI) From INTRUTILA : Endif
  For WS_S=1 To GI_NBLAN
    If GI_LLAN(WS_S)="" : Break 1 : Endif
    WS_ORDSYS=APPLI+WS_SEP+"GEN"+WS_SEP+GI_LLAN(WS_S)+WS_SEP+"FENT"
    WS_REPERT = filpath(WS_ORDSYS,"","","X3_PUB")
    If filinfo(WS_REPERT,0)<0
      WS_K = instr(1,WS_REPERT,"@")
      If WS_K
        WS_ORDSYS = 'ae_mkdir'-'"'+right$(WS_REPERT,WS_K+1)+'"'
      Else
        WS_ORDSYS = 'ae_mkdir'-'"'+WS_REPERT+'"'
      Endif
      Call SYSTEME(adxmac(0),WS_ORDSYS,"",WS_S) From ORDSYS
    Endif
   Next WS_S
Return



$WE_GENFENW:
$WE_GENFENCS:
  Local Char WK_RESULT(200)(1..10),WK_FICTRA(200),WK_ORDERC(250),WK_VALUE
  Local Integer WK_RG

  WK_ORDERC="ae_parse "
  If GOS(1)<>"dos" : WK_ORDERC+="-t" : Endif
  Case TYP
     When "FENX" : WK_ORDERC+="C "
     When "FENW"
                  # Call PARAM("","WEBPAGE",WK_VALUE) From ADOVAL
                   WK_VALUE="1"
                   If WK_VALUE="2"
                     WK_ORDERC+="U "
                   Else
                     WK_ORDERC+="W "
                   Endif
     When Default
                  # Call PARAM("","WEBPAGE",WK_VALUE) From ADOVAL
                   WK_VALUE="1"
                   If WK_VALUE="2"
                     WK_ORDERC+="X "
                   Else
                     WK_ORDERC+="T "
                   Endif
  Endcase
  WK_FICTRA=filpath(APPLI,"","","X3_PUB")
  WK_RG=instr(1,WK_FICTRA,"@")
  If WK_RG<>0 : WK_FICTRA=right$(WK_FICTRA,WK_RG+1) : Endif
  If GOS(1)<>"dos" : WK_ORDERC+="-a" : Endif
  WK_ORDERC+=WK_FICTRA+" "
  If GOS(1)<>"dos" : WK_ORDERC+="-f" : Endif
  WK_ORDERC-=FENETRE
  WK_ORDERC-=WK_LAN
#Infbox(WK_ORDERC)
  System WK_RESULT = adxmac(0)+"@"+WK_ORDERC
  Local Char WK_SEP
  Case GOS(1)
    When "dos"   : WK_SEP="\"
    When Default : WK_SEP="/"
  Endcase
  WK_FICTRA = filpath(APPLI+WK_SEP+"TMP",FENETRE,"tmp","X3_PUB")
  Gosub WE_EFFACE1
#  Recherche si c'est une fenêtre VT auquel cas il faut la générer
  If dim(ISFENGVT)>0 and ISFENGVT=2
    Gosub WE_GENFENVT
  Endif
  Gosub WE_EFFACE
Return


$WE_EFFACE1:
  Local Integer WE_NBL,WE_RG
  If sum(WK_RESULT(1..10))<>""
     For indice=1 To 10
       If WK_RESULT(indice)<>""
         Call ECR_TRACE("|"+WK_RESULT(indice),1) From GESECRAN
       Endif
     Next indice
  Endif
  If filinfo(WK_FICTRA,7)>0
     Openi WK_FICTRA Using [LTA_]
     Iomode adxifs "" Using [LTA_]
     Iomode adxirs chr$(10) Using [LTA_]
     Iomode adxium GUTF8 Using [LTA_]
     While fstat=0
       Rdseq WK_RESULT Using [LTA_]
       If WK_RESULT<>""
         WE_NBL+=1
         If WE_NBL>3 : Break 1 : Endif
         Call ECR_TRACE("|"+WK_RESULT,1) From GESECRAN
       Endif
     Wend
     Openi Using [LTA_]
   Endif
Return



$WE_EFFACE:
  WE_RG=instr(1,WK_FICTRA,"@")   : # pour traiter le multi tiers
  If WE_RG<>0 : WK_FICTRA=right$(WK_FICTRA,WE_RG+1) : Endif
  System WK_RESULT = adxmac(0)+"@ae_rm "+WK_FICTRA
Return


$WE_CSYST
 Local Char WK_MESSAG(250)
 Local Integer WK_I
 System WK_RESULT = "@"+WK_ORDERC
 If filinfo(WK_FICTRA,7)>0
   Openi WK_FICTRA Using [LTA_]
   Iomode adxifs "" Using [LTA_]
   Iomode adxirs chr$(10) Using [LTA_]
   Iomode adxium GUTF8 Using [LTA_]
   For WK_I=1 To 3
     Rdseq WK_RESULT Using [LTA_]
     If WK_RESULT<>"" : WK_MESSAG-=WK_RESULT : Endif
   Next WK_I
   Openi Using [LTA_]
 Call ECR_TRACE(WK_MESSAG,1) From GESECRAN
 Endif
Return


#   Calcule les raccourcis claviers dans toutes les langues
$WE_RAC:

# Le Bouton Fin est rajouté en dur
Local Integer WE_NBTEX
Local Char    WE_TEX(30)(1..MAXBOU) , WE_RAC(1)(1..MAXBOU)
Local Integer WE_FLRAC(1..100),WE_INDIC(1..100)
Local Char    WE_RACCLI(20) , WE_C(1)

For WE_ILAN=1 To GI_NBLAN

## 1er niveau
  WI_MAXBST=5        : #  On prend les 5 premiers boutons sur tous les modèles sauf les consultations
  If AWI_WINTYP=3 or AWI_WINTYP=4 : WI_MAXBST=MAXBST : Endif
  For WE_COU=1 To WI_MAXBST
    If AWI_STA(WE_COU)<>0
      WE_NBTEX += 1
      WE_NTEX=AWI_TXT(WE_COU) : Gosub WE_DTEXT
      WE_TEX(WE_NBTEX) = WE_VALUE
      WE_INDIC(WE_NBTEX)=-WE_COU
    Endif
  Next WE_COU
  WE_NBTEX += 1     :  # On rajoute le bouton Fin
  WE_NTEX=-123065 : Gosub WE_DTEXT
  WE_TEX(WE_NBTEX) = WE_VALUE : WE_INDIC(WE_NBTEX)=0

  For WE_I=1 To AWT_NBR
    If mod(AWT_NIV(WE_I),10)=0 & AWT_COD(WE_I)="" | AWT_NIV(WE_I)=0
      WE_NBTEX += 1
      WE_NTEX=AWT_TXT(WE_I) : Gosub WE_DTEXT
      WE_TEX(WE_NBTEX) = WE_VALUE
      WE_INDIC(WE_NBTEX)=WE_I
    Endif
  Next WE_I
  WE_RACCLI = ""
  For WE_J=1,5,15,39,105,116,193 : # Fichier,Edition,Affichage,?,Editeur,Outil,Sélection
    WE_K = instr(1,mess(WE_J,9138,1),"&")
    If WE_K
      WE_RACCLI += toupper(mid$(mess(WE_J,9138,1),WE_K+1,1))
    Endif
  Next WE_J
  Gosub WE_RACC
  For WE_I=1 To WE_NBTEX
    If WE_INDIC(WE_I)>0
      AWT_RAC(WE_INDIC(WE_I),WE_ILAN)=WE_RAC(WE_I)
    Elsif WE_INDIC(WE_I)=0
      AWI_RACF(WE_ILAN)=WE_RAC(WE_I)
    Elsif WE_INDIC(WE_I)<0
      AWI_RAC(-WE_INDIC(WE_I),WE_ILAN)=WE_RAC(WE_I)
    Endif
  Next WE_I

## 2ème niveau

  RACCLI = ""
  For WE_JJ=1 To 9
    WE_NBTEX = 0
    For WE_I=1 To AWT_NBR
      If int(AWT_NIV(WE_I)/10)=WE_JJ & ((mod(AWT_NIV(WE_I),10)=0 & AWT_COD(WE_I)<>"") |
&        (mod(AWT_NIV(WE_I),10)<>0 & AWT_COD(WE_I)=""))
        WE_NBTEX += 1
        WE_NTEX=AWT_TXT(WE_I) : Gosub WE_DTEXT
        WE_TEX(WE_NBTEX) = WE_VALUE
        WE_INDIC(WE_NBTEX)=WE_I
      Endif
    Next WE_I
    If WE_NBTEX
      Gosub WE_RACC
      For WE_I=1 To WE_NBTEX
        AWT_RAC(WE_INDIC(WE_I),WE_ILAN)=WE_RAC(WE_I)
      Next WE_I
    Endif
  Next WE_JJ

## 3ème niveau


  For WE_JJ=1 To 9
    WE_NBTEX = 0
    For WE_I=1 To AWT_NBR
      If int(AWT_NIV(WE_I)/10)=WE_JJ & mod(AWT_NIV(WE_I),10)<>0 & AWT_COD(WE_I)<>""
        WE_NBTEX += 1
        WE_NTEX=AWT_TXT(WE_I) : Gosub WE_DTEXT
        WE_TEX(WE_NBTEX) = WE_VALUE
        WE_INDIC(WE_NBTEX)=WE_I
      Endif
    Next WE_I
    If WE_NBTEX
      Gosub WE_RACC
      For WE_I=1 To WE_NBTEX
        AWT_RAC(WE_INDIC(WE_I),WE_ILAN)=WE_RAC(WE_I)
      Next WE_I
    Endif
  Next WE_JJ
Next WE_ILAN

Return

$WE_RACC
  WE_I = 1
  While WE_I<=WE_NBTEX
$WE_RAC1
    WE_FLRAC(WE_I) = 0

    For WE_J=1 To len(WE_TEX(WE_I))
      WE_C = toupper(mid$(WE_TEX(WE_I),WE_J,1))
      If !find(WE_C,WE_RAC(1..WE_I-1)) & !instr(1,WE_RACCLI,WE_C) & WE_C<>" "
        WE_RAC(WE_I) = WE_C
        WE_FLRAC(WE_I) = WE_J : Break
      Endif
    Next WE_J

    If WE_FLRAC(WE_I)=0
      WE_K = WE_I
      While 1
        WE_K -= 1
        If WE_K<=0
          Break
        Else
          WE_J = WE_FLRAC(WE_K)
          While WE_J<len(WE_TEX(WE_K))
            WE_J += 1
            WE_C = toupper(mid$(WE_TEX(WE_K),WE_J,1))
            If !find(WE_C,WE_RAC(1..WE_K-1)) &  !instr(1,WE_RACCLI,WE_C) & WE_C<>" "
&             & instr(1,WE_RAC(WE_I),WE_C)<>0
              WE_FLRAC(WE_K) = WE_J
              WE_RAC(WE_K) = WE_C
              Break 2
            Endif
          Wend
        Endif
      Wend
      If WE_K>0
        WE_I = WE_K+1
        Goto WE_RAC1
      Else
        WE_RAC(WE_I) = ""
      Endif
    Endif

    WE_I += 1
  Wend

  Raz WE_RAC
  For WE_I=1 To WE_NBTEX
    If WE_FLRAC(WE_I)
      WE_RAC(WE_I) = mid$(WE_TEX(WE_I),WE_FLRAC(WE_I),1)
    Else
      WE_RAC(WE_I) = "?"
    Endif
  Next WE_I
Return


$WE_DTEXT
  If WE_NTEX<0
    WE_NOMEN=-WE_NTEX/1000
    WE_NOMES=-WE_NTEX-WE_NOMEN*1000
    Read [AST]CLE=WE_NOMEN;WE_NOMES;GI_LLAN(WE_ILAN)
    If fstat=0 Then
      WE_VALUE=[F:AST]LANMES
    Else
      If GI_LLAN(WE_ILAN)<>GLANGUE
        Read [AST]CLE=WE_NOMEN;WE_NOMES;GLANGUE
      Else
        Read [AST]CLE=WE_NOMEN;WE_NOMES;GLANDEF
      Endif
      If fstat=0 : WE_VALUE=[F:AST]LANMES : Else : WE_VALUE="" : Endif
    Endif
  Else
    Read [ATX]NUMERO = GI_LLAN(WE_ILAN);WE_NTEX
    If fstat=0
      WE_VALUE = [F:ATX]TEXTE
    Else
      If GI_LLAN(WE_ILAN)<>GLANGUE
        Read [ATX]NUMERO = GLANGUE;WE_NTEX
      Else
        Read [ATX]NUMERO = GLANDEF;WE_NTEX
      Endif
      If fstat=0
        WE_VALUE = [F:ATX]TEXTE
      Else
        WE_VALUE = ""
      Endif
    Endif
  Endif
Return

$WE_TYPB
 WE_VALUE=""
 Case AWI_STA(WE_COU)
      When  GSTAENR  : WE_VALUE = "ENR"  : # Enregistrer
      When  GSTACRE  : WE_VALUE = "CRE"  : # Créer
      When  GSTAANU  : WE_VALUE = "ANU"  : # Supprimer
      When  GSTAFIN  : WE_VALUE = "FIN"  : # Abandon
      When  GSTAOK   : WE_VALUE = "OK"   : # Ok
      When  GSTANEW  : WE_VALUE = "NEW"  : # Nouveau
      When  GSTAFIR  : WE_VALUE = "FIR"  : # Premier
      When  GSTALAS  : WE_VALUE = "LAS"  : # Dernier
      When  GSTAPRE  : WE_VALUE = "PRE"  : # Précédent
      When  GSTASUI  : WE_VALUE = "SUI"  : # Suivant
      When  GSTASEL  : WE_VALUE = "SEL"  : # Sélection
      When  GSTACHG  : WE_VALUE = "CHG"  : # Changement de clé
      When  GSTAEDI  : WE_VALUE = "EDI"  : # Impression
      When  GSTALIS  : WE_VALUE = "LIS"  : # Liste
      When  GSTAJOI  : WE_VALUE = "JOI"  : # Pièces jointes
      When  GSTACOM  : WE_VALUE = "COM"  : # Commentaires
      When  GSTADAT  : WE_VALUE = "DAT"  : # Propriétés
      When  GSTAPCK  : WE_VALUE = "PCK"  : # Sélection Picking
      When  GSTAEND  : WE_VALUE = "END"  : # Fin
 Endcase
 If WE_VALUE<>""
    WE_PROP="BTX" : Gosub WE_ADDPROP
 Endif
Return

