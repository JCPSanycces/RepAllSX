#<AdxTL>@(#)12.0.0.0 $Revision$ Saisie d'un critÃĻre de sÃĐlection pour une table
## Action FILTSAI
Local Char FILTRE(250)
FILTRE='[ATB]CODFIC="CACCE" & [ATB]CRE=2 & [ATB]CREDAT<[01/01/2001]'
Local Char PARBOUT(250)(1..3)
Local Char VALBOUT(30)
PARBOUT(1) = "ATB"
PARBOUT(2) = "ATB"
PARBOUT(3) = FILTRE
Call SAISIE_CHAR(VALBOUT,PARBOUT,"DFILTSAI","FILTSAI","") From GSAISIE
FILTRE = PARBOUT(3)
Infbox FILTRE
End

$ACTION
Case ACTION
 When "OUVRE"  : Gosub VERIF
 When "DEBUT"  : Gosub DEBUT 
 When "OK"     : Gosub OK 
Endcase
Return

$VERIF
Onerrgo ERREUR From CONTROLE
If !clalev([F:ATB]) : Local File ATABLE  [ATB] : Endif
If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
If !clalev([F:ATY]) : Local File ATYPE   [ATY] : Endif
If !clalev([F:ACV]) : Local File ACTIV   [ACV] : Endif
Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Endif
Read [ATB]ABRFIC = PARAM(1)
If fstat : FIN=1 : Endif
Return

$DEBUT
Raz [M]
[M]FICH = [F:ATB]CODFIC
Call FILRECH(PARAM(3),[F:ATB]CODFIC,"","")
Affzo
Return

$OK
Local Char    CRITERE(250), ZVAL(50), ZZ(20), ZABR(3)
Local Integer I
PARAM(3)=""
If [M]ZONE(0)<>""
 If PARAM(2)="" : ZABR=PARAM(1) : Else ZABR=PARAM(2) : Endif
 For I=0 To [M]NBLIG-1
  If [M]ZONE(I)<>""
   If I<>0 : CRITERE += " & " : Endif
   Case [M]TYPZON(I)
    When 1
     ZVAL= num$([M]VALRECH(I))
    When 2,3,4,5,6
     ZVAL = num$([M]VALRECH(I))
    When 7
     ZVAL = '"'+[M]VALRECH(I)+'"'
    When 8
     If [M]VALRECH(I)=[0/0/0]
      ZVAL = "[00/00/0000]"
     Else
      ZVAL = "["+format$(GFMD,gdat$([M]VALRECH(I)))+"]"
     Endif
   Endcase
   ZZ=[M]ZONE(I)
   ZZ="["+ZABR+"]"+ZZ
   Case [M]OPER(I)
    When 1
     If instr(1,ZVAL,"*")=0 & instr(1,ZVAL,"?")=0
      CRITERE += ZZ + "="  + ZVAL
     Else
      CRITERE += "pat(" + ZZ + "," + ZVAL + ")"
     Endif
    When 2 : CRITERE += ZZ + ">"  + ZVAL
    When 3 : CRITERE += ZZ + "<"  + ZVAL
    When 4
     If instr(1,ZVAL,"*")=0 & instr(1,ZVAL,"?")=0
      CRITERE += ZZ + "<>" + ZVAL
     Else
      CRITERE += "!pat(" + ZZ + "," + ZVAL + ")"
     Endif
   Endcase
  Endif
 Next I
 PARAM(3) = CRITERE
Endif
FIN=1
Return

#####################################################
## Remplit le masque FILTSAI d'abrÃĐviation   ABMSK ##
## en fonction du CRITERE                          ##
## pour la table FICH d'abrÃĐviation ABFIC          ##
#####################################################
Subprog FILRECH(CRITERE,FICH,ABFIC,ABMSK)
Value Char CRITERE(), FICH(), ABFIC(), ABMSK()
Local Integer I, J, K, L, NOL, AA,MM, JJ, PATTERN
Local Char    SEP(1), ZVAL(20), ZZ(20)

If ABMSK="" : ABMSK="[M]" : Endif
If [L]FICH<>""
 Assign ABMSK+"FICH" With [L]FICH
Endif
If CRITERE="" : Goto FIN_FILRECH : Endif

If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
If !clalev([F:ATY]) : Local File ATYPE [ATY]  : Endif
If ABFIC="" & FICH<>""
 Read [ATB]CODFIC = FICH
 If fstat=0 : ABFIC=[F:ATB]ABRFIC : Endif
Elsif FICH="" & ABFIC<>""
 Read [ATB]ABRFIC = ABFIC
 If fstat=0
  FICH=[F:ATB]CODFIC
  Assign ABMSK+"FICH" With [L]FICH
 Endif
Endif
If FICH="" or ABFIC="" : End : Endif

I = instr(1,CRITERE,"["+ABFIC+"]")
L = len(ABFIC)
While I
 # Recherche de la zone
 J=0
 For SEP = "<", ">", "=", "," 
  K = instr(I+2+L,CRITERE,SEP) 
  If K & (!J | K<J) : J=K : Endif 
 Next
 If !J : Break : Endif
 SEP = mid$(CRITERE,J,1)
 Assign ABMSK+"ZONE("+num$(NOL)+")" With vireblc(seg$(CRITERE,I+2+L,J-1),2)

 # Recherche de l'opÃĐrateur
 K = 0
 Case SEP
  When "=" : K = 1 : PATTERN = 0
  When ">" : K = 2 : PATTERN = 0
  When "<" : If mid$(CRITERE,J+1,1)=">" : K = 4 : J += 1
             Else                       : K = 3
             Endif
             PATTERN = 0
  When "," : If mid$(CRITERE,I-5,5)="!pat("   : K = 4
             Elsif mid$(CRITERE,I-4,4)="pat(" : K = 1 
             Endif
             PATTERN = 1
 Endcase
 If !K : Break : Endif
 Assign ABMSK+"OPER("+num$(NOL)+")" With K

 # Recherche de la valeur
 K = instr(J+1,CRITERE,"&") : If !K : K=len(CRITERE)+1 : Endif
 ZVAL=vireblc(seg$(CRITERE,J+1,K-1),2)

 # Autres affectations
 CRITERE = right$(CRITERE,K+1)
 ZZ = evalue(ABMSK+"ZONE("+num$(NOL)+")")
 K = instr(1,ZZ,"(")
 If K : ZZ = left$(ZZ,K-1) : Endif
 Read [ATZ]CODZONE = FICH ; ZZ
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 Assign ABMSK+"TYPZON("+num$(NOL)+")" With [F:ATY]TYPTYP
 Assign ABMSK+"NOLIB("+num$(NOL)+")"  With [F:ATZ]NOLIB
 Assign ABMSK+"OPT("+num$(NOL)+")"    With [F:ATZ]OPTION
 If evalue(ABMSK+"NOLIB("+num$(NOL)+")")=999
  Assign ABMSK+"NOLIB("+num$(NOL)+")"  With 0
  Assign ABMSK+"TYPZON("+num$(NOL)+")" With 2
 Endif
 Assign ABMSK+"CODTYP("+num$(NOL)+")" With [F:ATY]CODTYP
 If [F:ATY]TYPTYP=7
  If [F:ATY]LNGTYP<>0
   Assign ABMSK+"LNGTYP("+num$(NOL)+")"  With [F:ATY]LNGTYP
  Else
   Assign ABMSK+"LNGTYP("+num$(NOL)+")"  With [F:ATZ]LONG
  Endif
 Endif

 K = 0
 Case evalue(ABMSK+"TYPZON("+num$(NOL)+")")
  When 1 : # Menu local
   J = evalue(ABMSK+"NOLIB("+num$(NOL)+")")
  When 7 : # on supprime les ""
   ZVAL=mid$(ZVAL,2,len(ZVAL)-2-PATTERN)
  When 8
   JJ=val(mid$(ZVAL,2,2))
   MM=val(mid$(ZVAL,5,2))
   AA=val(mid$(ZVAL,8,4))
   ZVAL=gdat$(JJ,MM,AA)
 Endcase 
 Assign ABMSK+"VALSAI("+num$(NOL)+")" With ZVAL 
 Call CHARGE([M]VALSAI(NOL),[M]CODTYP(NOL),[M]NOLIB(NOL),[M]LNGTYP(NOL),[M]VALRECH(NOL)) From FMTVAR
 I = instr(1,CRITERE,"["+ABFIC+"]")
 NOL+=1
Wend

$FIN_FILRECH
Assign ABMSK+"NBLIG" With NOL
End

######################################################
Subprog C_ZONE(VALEUR)
Variable Char VALEUR()
Local Integer DIME, I, OK
Local Char    ZZ(15)
Gosub SETNOL
VALEUR = toupper(VALEUR)
I = instr(1,VALEUR,"(")
If I<>0
 ZZ = left$(VALEUR,I-1)
 DIME = val(right$(VALEUR,I+1))
 VALEUR = ZZ+"("+num$(DIME)+")"
Else
 ZZ = VALEUR : DIME = 0
Endif
OK = 1
Read [ATZ]CODZONE = [F:ATB]CODFIC ; ZZ
If fstat
 OK = 0
Elsif [F:ATZ]CODACT<>""
 Read [ACV]CODACT = [F:ATZ]CODACT
 If !fstat
  If [F:ACV]DIME<>0 & DIME>[F:ACV]DIME-1
   OK = 0
  Elsif [F:ATZ]DIME<>0 & DIME>[F:ATZ]DIME-1
   OK = 0
  Endif
 Endif
Elsif [F:ATZ]DIME<>0 & DIME>[F:ATZ]DIME-1
 OK = 0
Endif
If !OK
 # Champ inexistant
 GMESSAGE = mess(41,100,1) : mkstat=2 : End
Endif
End

Subprog AP_ZONE(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Read [ATY]CODTYP = [F:ATZ]CODTYP
[M]TYPZON(NOL) = [F:ATY]TYPTYP
[M]NOLIB(NOL)  = [F:ATZ]NOLIB
[M]OPT(NOL)    = [F:ATZ]OPTION
If [M]NOLIB(NOL)=999
 [M]NOLIB(NOL)  = 0
 [M]TYPZON(NOL) = 2
Endif
[M]CODTYP(NOL) = [F:ATZ]CODTYP
If [F:ATY]TYPTYP=7
 If [F:ATY]LNGTYP<>0
  [M]LNGTYP(NOL) = [F:ATY]LNGTYP
 Else
  [M]LNGTYP(NOL) = [F:ATZ]LONG
 Endif
Endif
End

Subprog AS_OPER(VALEUR)
Variable Integer VALEUR
If [M]ZONE(nolign-1)="" : mkstat=1 : End : Endif
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

