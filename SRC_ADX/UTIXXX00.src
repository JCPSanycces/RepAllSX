#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIXXXNN   UTI process                                    Module XXX   #
#            correction utility
#    XXX for module :  must be replaced (GPA ACH STO ...)
#    NN  number of sequence : must be replaced (01 02 ...)
##########################################################################


Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTIXXXNN(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTIXXXNN(DOSSIER)
Value Char DOSSIER

Local Integer WCOMPTEUR
Call ECR_TRACE("UTIXXXNN : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:XXX])  =0  Local File =DOSSIER+".XXXXXX"   [XXX] : Endif

WCOMPTEUR = 0
Call DEBTRANS From GLOCK

Trbegin [XXX]
For [XXX]
   Readlock [XXX] Curr
   If fstat = 0
      # --- fields and rewrite
      [F:XXX]FIEQTY = "Example"
      Rewrite [F:XXX]
      If !fstat COMPTEUR += 1 Endif
   Endif
Next
Commit

Close Local File [XXX]

Call ECR_TRACE("UTIXXXNN : "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif

If [F:ADS]MODULE(N)<>2 : End : Endif                                 : # N= module

If filinfo(filpath("FIL","XXXXXX","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
If func DOSVUE.ISVIEW(APPLI,"XXXXXX") : End : Endif                  : # For Archive folder

Call MAJ_UTIXXXNN(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(N)<>2 : End : Endif                                 : # N= module
If filinfo(filpath("FIL","XXXXXX","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
If func DOSVUE.ISVIEW(APPLI,"XXXXXX") : End : Endif                  : # For Archive folder

Call MAJ_UTIXXXNN(APPLI)
End

