  #=============================================================
  GML_TYPEXERC  = 3102        : # Numéro de menu local "Type d'exercice"
    GVML_TEPREC   = 1         : # PRECEDENT
    GVML_TECOURA  = 2         : # COURANT
    GVML_TESUIV   = 3         : # SUIVANT
    GVML_TESUIV2  = 4         : # SUIVANT2
  #=============================================================
  GML_TYPMDAMT  = 3103        : # Numéro de menu local "Type de mode d'amortissement"
    GVML_TMLIBRE  = 1         : # LIBRE
    GVML_TMSTAND  = 2         : # STANDARD
  #=============================================================
  GML_TYPDBAMT  = 3104        : # Numéro de menu local "Type date de début d'amortissement"
    GVML_DAJOURP  = 1         : # AU JOUR PRECISE
    GVML_DA1ERM   = 2         : # AU 1er JOUR DU MOIS d'investissement
    GVML_DA1ERMS  = 3         : # AU 1er JOUR DU MOIS SUIVANT l'investissement
    GVML_DA1ERE   = 4         : # AU 1er JOUR DE L'EXERCICE d'investissement
