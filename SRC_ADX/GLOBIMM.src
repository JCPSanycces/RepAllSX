  Call DPM( GVML_MASYRUS, G_DPMSR ) From TRTFAS           : # SOFTY FQ59941
  Call DPM( GVML_MAUORUS, G_DPMUR ) From TRTFAS           : # UNITE D'OEUVRE RUSSE FQ59941
  Call DPM( GVML_MALIPOL, G_DPMML ) From TRTFAS           : # LINEAIRE POLONAIS FQ67577
  Call DPM( GVML_MADGPOL, G_DPMMD ) From TRTFAS           : # DEGRESSIF POLONAIS FQ72372
  Call DPM( GVML_MALIROM, G_DPMRL ) From TRTFAS           : # LINEAIRE ROUMAIN FQ77877
  Call DPM( GVML_MAACROM, G_DPMRX ) From TRTFAS           : # ACCELERE ROUMAIN FQ77877
  Call DPM( GVML_MADGROM, G_DPMRD ) From TRTFAS           : # DEGRESSIF ROUMAIN FQ77877
  Call DPM( GVML_MALISPA, G_DPMSL ) From TRTFAS           : # LINEAIRE ESPAGNOL FQ82075
  Call DPM( GVML_MAONEP , G_DPM1P ) From TRTFAS           : # ONE PERIOD FQ84110
  Call DPM( GVML_MAPRIMC, G_DPMAL ) From TRTFAS           : # PRIME COST FQ84283
  Call DPM( GVML_MADVALU, G_DPMAD ) From TRTFAS           : # DIMINISHING VALUE FQ84283
  Call DPM( GVML_MALISUI, G_DPMHL ) From TRTFAS           : # LINEAIRE SUISSE FQ84281
  Call DPM( GVML_MADGSUI, G_DPMHD ) From TRTFAS           : # DEGRESSIF SUISSE FQ84281
  Call DPM( GVML_MALITUR, G_DPMTL ) From TRTFAS           : # LINEAIRE TURQUE FQ105809
  Call DPM( GVML_MADGTUR, G_DPMTD ) From TRTFAS           : # DEGRESSIF TURQUE FQ105809
  #=============================================================
  G_RSDDPMTGR     = G_DPMRE
  #=============================================================

  # Dossier Migré (Valeur 2)
  If clalev([F:ZADW])=0 : Local File "ADOVAL" [ZADW]  : Endif

  Read [ZADW]ADW1="UPGFLG";"";""
  If (fstat)  Then
    GUPGFLG = G_NON
  Else
    GUPGFLG = val([F:ZADW]VALEUR)
  Endif

  # Initialisation des globales / codes activités du dossier
  Local Integer OUVACVFLG                 : # Indicateur ouverture table des codes activités
  If clalev ([F:ACV])=0 : Local File ACTIV [ACV] : OUVACVFLG=1 : Endif

  # Initialisation des globales / codes activités du dossier
  # Local Integer OUVACVFLG                 : # Indicateur ouverture table des codes activités
  # If clalev ([F:ACV])=0 : Local File ACTIV [ACV] : OUVACVFLG=1 : Endif

  Read [ACV] CODACT="IAS"                 : # Dossier avec IAS
  If fstat : Raz [F:ACV] : Endif
  G_ACTIAS = [F:ACV]FLACT
  If G_ACTIAS <> G_OUI : G_ACTIAS = G_NON : Endif

  Read [ACV] CODACT="LEA"                 : # Dossier avec Contrats de location financement
  If fstat : Raz [F:ACV] : Endif
  G_ACTLEA = [F:ACV]FLACT
  If G_ACTLEA <> G_OUI : G_ACTLEA = G_NON : Endif

  Read [ACV] CODACT="GRT"                 : # Dossier avec Subventions
  If fstat : Raz [F:ACV] : Endif
  G_ACTGRT = [F:ACV]FLACT
  If G_ACTGRT <> G_OUI : G_ACTGRT = G_NON : Endif

  Read [ACV] CODACT="CIG"                 : # Dossier avec Cessions intra-groupe
  If fstat : Raz [F:ACV] : Endif
  G_ACTCIG = [F:ACV]FLACT
  If G_ACTCIG <> G_OUI : G_ACTCIG = G_NON : Endif

  # Code activité des éléments physiques du bien comptable
  Read [ACV] CODACT="PHY"                 : # Dossier avec Eléments physiques
  If fstat : Raz [F:ACV] : Endif
  GPHY = [F:ACV]FLACT
  If GPHY <> G_OUI : GPHY = G_NON : Endif

  # Code activité localisation française FQ57624
  Read [ACV] CODACT="KFR"
  If fstat : Raz [F:ACV] : Endif
  GKFR = [F:ACV]FLACT
  If GKFR <> G_OUI : GKFR = G_NON : Endif

  # FQ54343
  Read [ACV] CODACT="CCN"                 : # Dossier avec Concession
  If fstat : Raz [F:ACV] : Endif
  G_ACTCCN = [F:ACV]FLACT
  If G_ACTCCN <> G_OUI : G_ACTCCN = G_NON : Endif

  # FQ59941
  Read [ACV] CODACT="KRU"                 : # Dossier localisation russe
  If fstat : Raz [F:ACV] : Endif
  G_ACTKRU = [F:ACV]FLACT
  If G_ACTKRU <> G_OUI : G_ACTKRU = G_NON : Endif

  # FQ67577
  Read [ACV] CODACT="KPL"                 : # Dossier localisation polonaise
  If fstat : Raz [F:ACV] : Endif
  G_ACTKPL = [F:ACV]FLACT
  If G_ACTKPL <> G_OUI : G_ACTKPL = G_NON : Endif

  # FQ80825
  Read [ACV] CODACT="DRO"                 : # Dossier Addon roumanie
  If fstat : Raz [F:ACV] : Endif
  G_ACTDRO = [F:ACV]FLACT
  If G_ACTDRO <> G_OUI : G_ACTDRO = G_NON : Endif

  # FQ64544
  Read [ACV] CODACT="LNK"                 : # Dossier avec Gestion des écarts entre plans
  If fstat : Raz [F:ACV] : Endif
  G_ACTLNK = [F:ACV]FLACT
  If G_ACTLNK <> G_OUI : G_ACTLNK = G_NON : Endif

  # FQ67848
  Read [ACV] CODACT="DPM"                 : # Nombre de modes d'amortissement
  If fstat : Raz [F:ACV] : Endif
  If [F:ACV]DIME > 0
    GMXDPMLB = [F:ACV]DIME
  Endif

  If OUVACVFLG : Close Local File [ACV] : Endif

  # FQ97426 : on n'affiche plus le message à la connexion.
  #           Le contrôle se fait lorsqu'on entre dans une fonction Immo (traitement EXEFNCB) et lors
  #           du calcul massif (traitement FASCALC) et de la clôture (traitement GLOCLO)
  #Call INFMSG From TRTLIC

  If GTABCPT<>""
   Inftxt mess(112,7778,1)-GTABCPT At 2 #"Lié avec le dossier compta X3"
  Endif

  #=============================================================
  # Lecture du paramètre Société DISAFAS
  Local Char WPARAM
  Call PARAM("","DISAFAS",WPARAM) From ADOVAL : # Paramètre autorisant l'utilisation des biens "Inactif"
  If val(WPARAM) = 0
    GDISAFAS = G_NON
  Else
    GDISAFAS = val(WPARAM)
  Endif

  # Alimentation de GDEVRND
  If clalev([F:TCU])=0  :  Local File TABCUR  [TCU] : Endif
  Local Integer IC
  For IC = 1 To GNBDEV
    Read [TCU]TCU0 = GDEVISE(IC)
    GDEVRND(IC)  = [F:TCU]CURRND
  Next IC

End

################################################################################
Subprog VARUSR
  If GMODU(14) <> 2 : End : Endif  : # Lorsque le module Immo n'est pas actif

  Local Char PARAM(20)
  Call PARAMUTIL("REMAFCY",PARAM,"","") From SUBAUS
  GREMAFCY = val(PARAM)

  If GREMAFCY = G_NON : GCOUSIT = "" : Endif : # pour être dynamique en cas de changement de valeur du
                                               # paramètre en cours de session
End

