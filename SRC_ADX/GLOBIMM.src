################################################################################
Subprog DEFVAR

If GMODU(14) <> 2 : End : Endif  : # Lorsque le module Immo n'est pas actif

Call DEFVAR From WWAGLOBIMM

#=============================================================
# Initialisation des constantes de ACTION_BLOCK dans GLOBIENS
Global Integer ACB_AFFZO          : # Affzo
Global Integer ACB_EFFZO          : # Effzo
Global Integer ACB_ACTZO          : # Actzo
Global Integer ACB_DISZO          : # Diszo
Global Integer ACB_GRIZO          : # Grizo
#=============================================================
#Global Integer GIASAXE           : # Axe analytique portant le compte IAS (provisoire)
#Global Integer GSZ_PAQ
Global Integer GSZ_EVT_PAQ        : # Taille des paquets en nombre d'événements
End

################################################################################
Subprog INIVAR

 If GMODU(14) <> 2 : End : Endif : # Lorsque le module Immo n'est pas actif

 Gosub DEF_CAL_GLOBALES From GLOBI

 #GVERSION = "1.5.0"            : # Surcharge du GVERSION déclaré et initialisé par GLOBVAR

 #G_DEFTVA      = 19.6          : # Taux de TVA par défaut # Gbn-171204
 #G_MSGQUILOCK = ""             : # Chaine contenant (éventuellement) de l'utilisateur qui empêche de locker
  #=============================================================
  If GDOSCPT <> "" : # Il y a un dossier comptable X3
  # Chargement du tableau des tables partagés avec X3
   #GCOMPTA     = 2             : # Validation comptable dans un dossier X3 externe
    GABRCPT(1)  = "GAC"         : # Table partagée : Compte général
    GABRCPT(2)  = "CCE"         : # Table partagée : Section analytique
    GABRCPT(3)  = "CNA"         : # Table partagée : Nature
    GABRCPT(4)  = "PYC"         : # Table partagée : Pyramide section
    GABRCPT(5)  = "PGC"         : # Table partagée : Groupe de sections
    GABRCPT(6)  = "PYN"         : # Table partagée : Pyramide nature
    GABRCPT(7)  = "PGN"         : # Table partagée : Groupe de natures
    GABRCPT(8)  = "TCH"         : # Table partagée : Cours devise
    GABRCPT(9)  = "BPR"         : # Table partagée : Tiers
    GABRCPT(10) = "TCK"         : # Table partagée : Compte de liaison
    GABRCPT(11) = "CDE"         : # Table partagée : Section par défaut
    GABRCPT(12) = "DSP"         : # Table partagée : Répartition à priori
    GABRCPT(13) = "CCZ"         : # Table partagée : Interdiction section / section
    GABRCPT(14) = "CNZ"         : # Table partagée : Interdiction nature / section
    GABRCPT(15) = "JOU"         : # Table partagée : Journal comptable
    GABRCPT(16) = "ITM"         : # Table partagée : Article
    GABRCPT(17) = "GDE"         : # Table partagée : Transactions de saisie comptable - Gbn 08/06
    GABRCPT(18) = "GTE"         : # Table partagée : Transactions de saisie comptable - Gbn 08/06
    GNBTABCPT   = 18
  # Schémas standards de saisie  # Gbn 08/06
    GSCHSTD(1)="STD"
    GSCHSTD(2)="STDA"
    GSCHSTD(3)="STDL"
  Else
   #GCOMPTA = 3                : # Validation comptable dans une table d'interface locale (pas de X3)
    Raz GTABCPT                : # Pour être sûr de ne pas être embêté qd GABRCPT n'est pas testé
  Endif
  #=============================================================
  # Constantes sur les traces
 #123456789012
  GTRC_LGLIGTR   = 115      : # Lg max d'une ligne dans la trace
  GTRC_OPTION    = 1        : # Options
  GTRC_CRITERE   = 3        : # Critères
  GTRC_PARAM     = 5        : # Paramètres
  GTRC_CRACTIO   = 10       : # Compte-rendu des mises à jour (principal)
  GTRC_CRACT1    = 11       : # Compte-rendu des mises à jour (Partie supplémentaire 1)
  GTRC_CRACT2    = 12       : # Compte-rendu des mises à jour (Partie supplémentaire 2)
  GTRC_CRLST1    = 13       : # Compte-rendu liste diverse 1
  GTRC_CRLST2    = 14       : # Compte-rendu liste diverse 2
  GTRC_CRERREU   = 15       : # Compte-rendu des erreurs
  GTRC_STAT      = 95       : # Statistiques
  GTRC_TRTERRE   = 99       : # Erreur technique - Arrêt du traitement
  GTRC_CCALCUL   = 88       : # Calcul
  GTRC_DBFINTR   = 95
  #=============================================================
  #Gbn-100605-Bug n°30696
  # Variables globales nécessaires à la gestion des événements
  GEVE_VAL1      = 1        : # Valeur 1 d'une zone alphanumérique ou menu local dans un événement
  GEVE_VAL2      = 2        : # Valeur 2 d'une zone alphanumérique ou menu local dans un événement
  #=============================================================
  # Constantes pour la gestion des contextes et des plans
  G300MAX=len(mess(0,3100,1)): # Nombre maxi de contextes
  G301MAX=len(mess(0,3101,1)): # Nombre maxi de plans
  #*V5 G301NBPLNFC   = 5    : # Nombre maxi de plans contexte fiscal & comptable
  G301NBPLNFC   = 15        : # Nombre maxi de plans contexte fiscal & comptable
  GMAXDPMPRIO   = 6         : # Nombre maxi de modes amt pour lesquels le code priorité per / exe est paramétrable.
  #=============================================================
  # Constantes sur certaines tables diverses "remarquables"
  GTD_EQUIPE    = 512       : # Numéro de table diverse "Type traitement équipes"
  GTD_PLREINV   = 531       : # Numéro de table diverse "Plafond réintégration véhicule"
  GTD_TAX_VS    = 533       : # Numéro de table diverse "Taxes / véhicules des sociétés"
  GTD_SITE      = 603       : # Numéro de table diverse "Site"
  GTD_BATIMENT  = 604       : # Numéro de table diverse "Batiment"
  GTD_ETAGE     = 605       : # Numéro de table diverse "Etage"
  GTD_PIECE     = 606       : # Numéro de table diverse "Pièce"
  GTD_CLASSE    = 607       : # Numéro de table diverse "Classe"
  GTD_CATEGORI  = 608       : # Numéro de table diverse "Catégorie"
  GTD_FAMILLE   = 609       : # Numéro de table diverse "Famille"
  GTD_ACTIVITE  = 610       : # Numéro de table diverse "Secteur d'activité
  #GTD_FAMCPT    = 611       : # Numéro de table diverse "Famille comptable"
  GTD_INVPLN    = 614       : # Numéro de table diverse "Projet d'investissement"
  GTD_LEACCO    = 625       : # Numéro de table diverse "Imputation cptable contrats"

  #GTD_INVSTA   = 536       : # Numéro de table diverse "Statut du relevé d'inventaire"
  GTD_PHYCAT    = 537       : # Numéro de table diverse "Catégorie physique"
  GTD_INVETATB  = 538       : # Numéro de table diverse "Etat du bien lors de l'inventaire"
  GTD_ASSOC     = 961       : # Numéro de table diverse "Association-rub.déterminées"
  GTD_ASSORUB   = 961       : # Numéro de table diverse "Associations - Rubriques déterminées"
  GTD_EVENT     = 962       : # Numéro de table diverse "Evénements des immobilisations"
  GTD_INVRUB    = 963       : # Numéro de table diverse "Rubriques inventaire"
  GTD_LKINVRUB  = 964       : # Numéro de table diverse "Lien Rub PDT3100-Rub relevé"
  GTD_INVPRB    = 966       : # Numéro de table diverse "Rub non alimentables invent."
  #=============================================================
  # Constantes sur certains menus locaux "remarquables"
  #=============================================================
  # Ne pas dépasser 12 caractères pour le nom des constantes.
  #123456789012
  #=============================================================
  GML_NCONTEXT  = 3100        : # Numéro de menu local "Contexte"
    G300CPFI      = 1         : # COMPTABLE & FISCAL
