####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 31 : FINTAXCLC Final tax calc ( Field Local menu number 11656)
####################################################################

$SET_FINTAXCLC
If [L]_AOLDVAL<>this.FINTAXCLC
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_FINTAXCLC
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.FINTAXCLC
 Gosub PROPAGATE_FINTAXCLC
Endif
Return

$INIT_FINTAXCLC
Gosub DECLARE_VAR From WMC0ESSWRKSA
[L]CURPRO = "FINTAXCLC"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.FINTAXCLC=0 and fmet this.AGETATTRIBUTE("FINTAXCLC","$isMandatory")="true"
 this.FINTAXCLC = 1
Endif
Return
 
$CONTROL_FINTAXCLC
Gosub DECLARE_VAR From WMC0ESSWRKSA
[L]CURPRO = "FINTAXCLC"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_FINTAXCLC             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_FINTAXCLC             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_FINTAXCLC
[L]CURPRO = "FINTAXCLC"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.FINTAXCLC=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_FINTAXCLC
[L]CURPRO = "FINTAXCLC"
If this.FINTAXCLC<0 or this.FINTAXCLC>len(mess(0,11656,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"11656 ->"-num$(this.FINTAXCLC)-mess(99,123,1)):  Return : # Local menu "11656 -> Invalid option
Endif
Return

$_AOTHERS_FINTAXCLC
[L]CURPRO = "FINTAXCLC"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_FINTAXCLC
[L]CURPRO = "FINTAXCLC"
Return

$PROPAGATE_FINTAXCLC
this.isReadonly = 0
[L]CURPRO = "FINTAXCLC"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_FINTAXCLC
Gosub DECLARE_VAR From WMC0ESSWRKSA
[L]CURPRO = "FINTAXCLC"
$_LNKPRO_FINTAXCLC
Return


