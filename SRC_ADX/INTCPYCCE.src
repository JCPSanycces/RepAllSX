Subprog D_CCE20(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 20 : Goto DEFCCE

$DEFCCE
Local Integer NLED, TLED
Local Char LED(10)
For NLED=1 To GNBTYPLED
 [L]LED = GCODLED(NLED)
  Case CCECAS
    When 1
      Call INICCE(VALEUR,GAXE(AXE),[L]LED,evalue("[M:BIC3]ACC"+num$(NLED)+"("+num$(CCENOL)+")"),"BPCINVD") From CPTINI
    When 2
      Call INICCE(VALEUR,GAXE(AXE),[L]LED,evalue("[M:BIS3]ACC"+num$(NLED)+"("+num$(CCENOL)+")"),"BPSINVD") From CPTINI
    When 3
      Call INICCE(VALEUR,GAXE(AXE),[L]LED,evalue("[M:GIC1]ACC"+num$(NLED)+"("+num$(CCENOL)+")"),"") From CPTINI
  Endcase
 If VALEUR<>"" : Break : End : Endif
Next

End

######################################################################################
Subprog AS_CCE1(VALEUR)
Variable Char    VALEUR()
AXE = 1 : Goto SAICCE

Subprog AS_CCE2(VALEUR)
Variable Char    VALEUR()
AXE = 2 : Goto SAICCE

Subprog AS_CCE3(VALEUR)
Variable Char    VALEUR()
AXE = 3 : Goto SAICCE

Subprog AS_CCE4(VALEUR)
Variable Char    VALEUR()
AXE = 4 : Goto SAICCE

Subprog AS_CCE5(VALEUR)
Variable Char    VALEUR()
AXE = 5 : Goto SAICCE

Subprog AS_CCE6(VALEUR)
Variable Char    VALEUR()
AXE = 6 : Goto SAICCE

Subprog AS_CCE7(VALEUR)
Variable Char    VALEUR()
AXE = 7 : Goto SAICCE

Subprog AS_CCE8(VALEUR)
Variable Char    VALEUR()
AXE = 8 : Goto SAICCE

Subprog AS_CCE9(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 9 : Goto SAICCE

Subprog AS_CCE10(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 10 : Goto SAICCE

Subprog AS_CCE11(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 11 : Goto SAICCE

Subprog AS_CCE12(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 12 : Goto SAICCE

Subprog AS_CCE13(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 13 : Goto SAICCE

Subprog AS_CCE14(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 14 : Goto SAICCE

Subprog AS_CCE15(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 15 : Goto SAICCE

Subprog AS_CCE16(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 16 : Goto SAICCE

Subprog AS_CCE17(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 17 : Goto SAICCE

Subprog AS_CCE18(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 18 : Goto SAICCE

Subprog AS_CCE19(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 19 : Goto SAICCE

Subprog AS_CCE20(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 20 : Goto SAICCE

$SAICCE
# We cannot use SUBBICS; AS_CCE because [M]DSP is not available and those checks are in INTCPYLIB
# and LECLED needs to be from here not SUBBICS with correct CPY

If (CCECAS=1 & [M:BIC1]STA=3) or (CCECAS=2 & [M:BIS1]STA=3)  : mkstat=2 : End : Endif

Local Char    COMPTE(GLONGAC)
Local Integer NLED, TLED
Local Integer AXI, IND
mkstat = 1
For NLED=1 To GNBTYPLED
 [L]TLED = GTYPLED(NLED) : Gosub LECLED
 Call INDLED([L]LED,GAXE(AXE),IND,AXI) From CPTDIV
 If AXI
  Case CCECAS
    When 1
      COMPTE = evalue("[M:BIC3]ACC"+num$(NLED)+"("+num$(CCENOL)+")")
    When 2
       COMPTE = evalue("[M:BIS3]ACC"+num$(NLED)+"("+num$(CCENOL)+")")
    When 3
      COMPTE = evalue("[M:GIC1]ACC"+num$(NLED)+"("+num$(CCENOL)+")")
  Endcase
  If COMPTE<>""
   Call LECTURE("GAC",COMPTE,GPLAN(NLED)) From CONTOBJ
   If find(GAXE(AXE),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1)) : Raz mkstat : Break : Endif
  Endif
 Endif
Next
If mkstat : End : Endif
End

$LECLED
# Cannot use SUBBICS routine due to variables not available from here
Local Char LED(GLONLED)
Local Char DEV(GLONCUR)
Call LECLED (CCECPY,[L]TLED,LED,DEV) From CPTDIV
Call LECTURE("LED",[L]LED,"") From CONTOBJ
Return

######################################################################################
Subprog C_CCE1(VALEUR)
Variable Char    VALEUR()
AXE=1 : Goto CONTCCE

Subprog C_CCE2(VALEUR)
Variable Char    VALEUR()
AXE=2 : Goto CONTCCE

Subprog C_CCE3(VALEUR)
Variable Char    VALEUR()
AXE=3 : Goto CONTCCE

Subprog C_CCE4(VALEUR)
