#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
#    Program Name:    INTCPYCCE - Intercompany enhancement  SAM #87307
#
#    Authors:         BeSpr   May 21-31, 2013
#
#    Modifications:   GL Intercompany journal entry         SAM #88747
#                     BeSpr and JBR  July 1-31, 2013
#
# Handles the display and processing of the child Dimension screen and entry
# When the target company has more dimensions than the source company
#
# Action = INTCPYCCE
# Screen = INTCPYCCE (CCE)
# Window = FINTCPYCCE
#
# The routine that calls the Action is in INTCPYLIB
#
######################################################################################
$ACTION

Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "OUVRE_BOITE"   : Gosub OUVRE_BOITE
 When "DEBUT"         : Gosub DEBUT
 When "OK"            : Gosub SAVEIT
 When "END"           : Gosub DONE
 When Default
Endcase

Return

######################################################################################
$OUVRE
Local Mask INTCPYCCE [CCE]
#Local Integer CCENOL               : # Main grid current line number
#Local Integer CCECAS               : # 1:Customer  2:Suppliers   3: GL journal
#Local Char CCECPY, CCEFCY          : # Target Company, Target Site
#Local Date CCEDAT                  : # Accounting date

## Initialization of the variables
CCECAS   = val(PARAM(1))
CCECPY   = PARAM(2)
CCEFCY   = PARAM(3)
CCENOL   = val(PARAM(4))
CCEDAT   = PARAM(5)

# Need to reset the Global variables due to click right opening of window
Call RESET_INTCPYCOA(CCECPY,CCEFCY) From INTCPYLIB

Return

######################################################################################
$OUVRE_BOITE

Call INT_AFFCOL(CCECAS) From INTCPYCCE
Gosub SETCHPAXE From SUBBICS

Affzo [M:CCE]

Return

######################################################################################
$DEBUT

For I = 1 To 20
  Case CCECAS
    When 1
      Assign ("[M:CCE]CCE"+num$(I)+"(0)") With evalue("[M:BIC3]CCE"+num$(I)+"(CCENOL)")
    When 2
      Assign ("[M:CCE]CCE"+num$(I)+"(0)") With evalue("[M:BIS3]CCE"+num$(I)+"(CCENOL)")
    When 3
      Assign ("[M:CCE]CCE"+num$(I)+"(0)") With evalue("[M:GIC1]CCE"+num$(I)+"(CCENOL)")
  Endcase
Next I

Case CCECAS
  When 1
    [M:CCE]CCEFCY = [M:BIC3]FCYLIN(CCENOL)
    [M:CCE]CCECPY = [M:BIC3]CPYLIN(CCENOL)
  When 2
    [M:CCE]CCEFCY = [M:BIS3]FCYLIN(CCENOL)
    [M:CCE]CCECPY = [M:BIS3]CPYLIN(CCENOL)
  When 3
    [M:CCE]CCEFCY = [M:GIC1]FCYLIN(CCENOL)
    [M:CCE]CCECPY = [M:GIC1]CPYLIN(CCENOL)
Endcase

# Set the hidden variables
[M:CCE]CCECAS = CCECAS
[M:CCE]CCENOL = CCENOL
[M:CCE]CCEDAT = CCEDAT

# Set the focus to the first Dimension
zonsui = "[M:CCE]CCE1(0)"

Return

######################################################################################
$SAVEIT

# Need to always check in case some dimensions were defaulted
Gosub CHECK_MANDATORY
If mkstat : FIN = 0 : Endif

For I = 1 To 20
  Case CCECAS
    When 1
      Assign ("[M:BIC3]CCE"+num$(I)+"(CCENOL)") With evalue("[M:CCE]CCE"+num$(I)+"(0)")
    When 2
      Assign ("[M:BIS3]CCE"+num$(I)+"(CCENOL)") With evalue("[M:CCE]CCE"+num$(I)+"(0)")
    When 3
      Assign ("[M:GIC1]CCE"+num$(I)+"(CCENOL)") With evalue("[M:CCE]CCE"+num$(I)+"(0)")
  Endcase
Next I

# Enable the SAVE button on the main screen
If FIN : mkstat=4 : Endif

Return

######################################################################################
$DONE

# Need to always check in case some dimensions were defaulted
Gosub CHECK_MANDATORY
If mkstat
  Gosub DEBUT
  FIN = 0
Endif

Return

######################################################################################
$CHECK_MANDATORY
# If its the first time in the screen then we need to check for any blank mandatory dimensions
Local Integer AXE         : # Looping variable
Local Char TESTCCE        : # Dimension value

Raz mkstat

For AXE=1 To GNBAXE
  TESTCCE = evalue ("[M:CCE]CCE"+num$(AXE)+"(0)")
  If TESTCCE = ""
    Local Char    COMPTE(GLONGAC)
    Local Integer NLED, TLED
    For NLED=1 To GNBTYPLED
      Case CCECAS
        When 1
          COMPTE = evalue("[M:BIC3]ACC"+num$(NLED)+"("+num$(CCENOL)+")")
        When 2
          COMPTE = evalue("[M:BIS3]ACC"+num$(NLED)+"("+num$(CCENOL)+")")
        When 3
          COMPTE = evalue("[M:GIC1]ACC"+num$(NLED)+"("+num$(CCENOL)+")")
      Endcase
      If COMPTE<>""
        [L]TLED = GTYPLED(NLED) : Gosub LECLED
        Call CONTCCE(TESTCCE,[L]LED,GAXE(AXE),CCEFCY,CCEDAT,COMPTE,GAXE,"[M:CCE]CCE#",0) From CPTCNT
        If mkstat : Break : Endif
      Endif
    Next NLED
    If mkstat : zonsui="[M:CCE]CCE"+num$(AXE)+"(0)" : Break : Endif
  Endif
Next AXE

Return

######################################################################################
$INTIT_CCE
Case I
 When 1  : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE1
 When 2  : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE2
 When 3  : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE3
 When 4  : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE4
 When 5  : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE5
 When 6  : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE6
 When 7  : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE7
 When 8  : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE8
 When 9  : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE9
 When 10 : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE10
 When 11 : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE11
 When 12 : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE12
 When 13 : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE13
 When 14 : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE14
 When 15 : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE15
 When 16 : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE16
 When 17 : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE17
 When 18 : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE18
 When 19 : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE19
 When 20 : Titcol [M:CCE]NBLIGCCE [M:CCE]INTDIE(I-1) For CCE20
Endcase
Return

######################################################################################
# This code is from SUBBICS; AFFCOL
Subprog INT_AFFCOL(CCAS)
Value Integer CCAS      : # 1:Customer  2:Suppliers   3: GL journal
Local Char FMT(10)      : # Format
Local Integer I         : # Looping variable
Case CCAS
  When 1 : # Factures clients
    Default Mask [BIC1]
    Default Mask [BIC3]
  When 2 : # Factures fournisseurs
    Default Mask [BIS1]
    Default Mask [BIS3]
  When 3 : # intercompany journal
    Default Mask [GIC1]
Endcase
Default Mask [CCE]

For I=1 To GNBAXE
 Call LECTURE("DIE",evalue("GAXE("+num$(I)+")"),"") From CONTOBJ
 Call LECTEXTRA([M:CCE]INTDIE(I-1),"GDIE","COLHEA",[F:DIE]DIE,"") From ATEXTRA
 Gosub INTIT_CCE
 Call INICCEFMT([F:DIE]DIE) From SETGLBDIE
 # Changed [M]CPY to CCECPY
 Call SAI_AMONT(CCECPY,GNBTYPLED,GTYPLED,evalue("GAXE("+num$(I)+")"),[M:CCE]SAIAXE(I-1)) From CPTDIV
 # This check is not valid for GL intercompany journal
 If [M:CCE]SAIAXE(I-1)=2 or CCAS=3
  FMT = "K:"+GCCEFMT
 Else
  FMT = "-K:"+GCCEFMT
 Endif
 Assign "[M:CCE]FMTDIE("+num$(I-1)+")" With FMT
Next

For I=GNBAXE+1 To dim([M:CCE]FMTDIE)
 FMT = "-K:10X"
 Assign "[M:CCE]FMTDIE("+num$(I-1)+")" With FMT
Next I

End

######################################################################################
######################################################################################
## Section automatically added (screen INTCPYCCE) 05/23/2013 17:46:53 (BESPR)
######################################################################################
Subprog IB_NBLIGCCE
Affzo [M:CCE]CCEFCY, CCECPY
Grizo [M:CCE]CCEFCY, CCECPY
Affzo [M:CCE]CCE1(0),CCE2(0),CCE3(0),CCE4(0),CCE5(0),CCE6(0),CCE7(0),CCE8(0),CCE9(0),CCE10(0)
Affzo [M:CCE]CCE11(0),CCE12(0),CCE13(0),CCE14(0),CCE15(0),CCE16(0),CCE17(0),CCE18(0),CCE19(0),CCE20(0)
End

Subprog C_NBLIGCCE
# Code from SUBBIS2; C_NBLIG
If find(status,65,68,83,73,67) # removed 82 (summary)
 mkstat = 2
Endif
End

######################################################################################
$SETNOL
Local Integer NOL
NOL = nolign-1
Return

######################################################################################
