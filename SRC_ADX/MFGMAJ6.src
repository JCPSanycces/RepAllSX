#<AdxTL>@(#)3.0.0.0 $Revision$
####################################################################################################
#  MFGMAJ6 : Mises û  jour û  effectuer lors du passage de la version 140 (release 6)                #
####################################################################################################
#
#    GPAO :
#    Dans opûˋration de gammes (ROUOPE)
#        - remplacement date de remplacement, par date dûˋbut/ date fin de l'OP (RPLDAT, VALSTRDAT, VALENDDAT)
#    Dans poste de charge (WORKSTATIO)
#        - rûˋcupûˋration du paramû´tre poste de remplacement (RPLWST) pour alimenter la table des postes
#          de remplacement
#
####################################################################################################
#--------------------------------------------------------------------------------------------------#
#    Moulinette Aprû´s mise û  jour concernant le module GPAO
#--------------------------------------------------------------------------------------------------#
Local Shortint COMPTEUR, STOP
Local Char     CLE1(20),CLE3(20),CRITERE(250)
Local Integer  CLE2, CLE4, CLE5

Local File ADOSSIER [ADS]

If filinfo (filpath ("FIL", "ROUOPE", "fde",[F:ADS]DOSSIER ) ,0) < 0: End : Endif
If filinfo (filpath ("FIL", "WORKSTATIO", "fde",[F:ADS]DOSSIER ) ,0) < 0: End : Endif
If filinfo (filpath ("FIL", "RPLWST", "fde",[F:ADS]DOSSIER ) ,0) < 0: End : Endif

#Goto MWS
#$ROO
#----------------------------------------------#
#  remplacement date de remplacement, ROUOPE   #
#----------------------------------------------#
Local File ROUOPE [ROO]
Local File ROUOPE [ROOW]    # table de travail

Call TEMPON ("Operation Process") From GESECRAN

Raz CLE1, CLE2 , CLE4, CLE5 , STOP
$BOUCLE_ROO
If STOP=1
   STOP=2 : CRITERE='ITMREF="'+CLE1+'"'+'& ROUALT='+ num$(CLE2)+' & OPENUM='+ num$(CLE4)+' & RPLIND>'+ num$(CLE5)
Elsif STOP=2
   STOP=3 : CRITERE='ITMREF="'+CLE1+'"'+'& ROUALT='+ num$(CLE2)+' & OPENUM>'+ num$(CLE4)   
Elsif STOP=3
   STOP=4 : CRITERE='ITMREF="'+CLE1+'"'+'& ROUALT>'+ num$(CLE2)       
Elsif STOP=4
   STOP =0 :CRITERE='ITMREF>"'+CLE1+'"'
Else
   CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [ROO]
 For [ROO] Where evalue (CRITERE)
    Readlock [ROO] Curr
    If fstat
        Call ECR_TRACE("File ROUOPE, Error="-num$(fstat),1) From GESECRAN
    Else
        If [F:ROO]RPLDAT<>[0/0/0]
            [F:ROO]VALENDDAT = [F:ROO]RPLDAT
            Readlock [ROOW]ROO0=[ROO]ITMREF;[ROO]ROUALT;[ROO]OPENUM;[ROO]RPLIND+1
            If fstat =0 
             [F:ROOW]VALSTRDAT =  [F:ROO]RPLDAT+1
             Rewrite [F:ROOW]
            Endif
        Endif
        Rewrite [F:ROO]
    Endif
    COMPTEUR += 1
    If COMPTEUR >499
        CLE1 = [F:ROO]ITMREF
        CLE2 = [F:ROO]ROUALT
        CLE4 = [F:ROO]OPENUM
        CLE5 = [F:ROO]RPLIND
        STOP =1
        Break
    Endif
 Next
Commit

If STOP : Goto BOUCLE_ROO : Endif
Filter [ROO]
Close Local File [ROO]
Close Local File [ROOW]
Call TEMPOFF From GESECRAN

#$MWS
#------------------------------------------------#
#  rûˋcupûˋration du poste de remplacement, RPLWST #
#------------------------------------------------#

Local File WORKSTATIO [MWS]
Local File WORKSTATIO [MWS2] # table de travail
Local File RPLWST [RPW]

Call TEMPON ("Workstations Process") From GESECRAN

Raz CLE1, CLE3, STOP
$BOUCLE_RPW
If STOP=1
    STOP= 2 : CRITERE='WST="'+CLE1+'"'+' & WCRFCY>"'+ CLE3 +'"'
Elsif STOP= 2
    STOP= 0 : CRITERE='WST>"'+CLE1 +'"'
Else
    CRITERE ="1=1"
Endif

Raz COMPTEUR
Trbegin [MWS]
For [MWS]WST0 Where evalue(CRITERE)
    Readlock [MWS] Curr
    If fstat 
        Call ECR_TRACE("File WORKSTATIO, Error="-num$(fstat),1) From GESECRAN
    Else      
        # remplacement
        If [F:MWS]RPLWST<>""
            [F:RPW]WST       =[F:MWS]WST
            [F:RPW]WCRFCY    =[F:MWS]WCRFCY 
            [F:RPW]RPLWST(0) =[F:MWS]RPLWST
            Readlock [MWS2]WST0=[MWS]RPLWST;[MWS]WCRFCY
            If !fstat  
                [F:RPW]RPLWSTDES(0) =[F:MWS2]WSTDES 
                [F:RPW]WCR(0) =[F:MWS2]WCR
                [F:RPW]WSTTYP(0) =[F:MWS2]WSTTYP          
            Endif
        Endif    
        
        # initialisation nouvelles zones RCCP , CONSTRAINT & REGROUPEMENT
        If !find([F:MWS]RCCP,1,2)       : [F:MWS]RCCP = 2       : Endif
        If !find([F:MWS]CONSTRAINT,1,2) : [F:MWS]CONSTRAINT = 2 : Endif
        If !find([F:MWS]GRPFLG,1,2)     : [F:MWS]GRPFLG = 1     : Endif
        Write [F:RPW] 
        Rewrite [F:MWS]
    Endif
    COMPTEUR +=1
    If COMPTEUR>499
        CLE1 = [F:MWS]WST
        CLE3 = [F:MWS]WCRFCY
        STOP = 1
        Break
    Endif
Next
Commit
If STOP : Goto BOUCLE_RPW : Endif
Close Local File [MWS]
Close Local File [MWS2]    
Close Local File [RPW] 
Call TEMPOFF From GESECRAN
