Gosub DECLARE_VAR From WMC0EMPLOJNT
[L]CURPRO = "SJNTTEL"
$_LNKPRO_SJNTTEL
Local Char AFORMAT(50)
[L]ASTATUS =  func ASYRTRTATY.GETFORMATTEL(this,"SJNTTEL",this.SJNTTEL,[L]AFORMAT,"")
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]AFORMAT<>''
[L]AFORMAT='"'+[L]AFORMAT+'"'
[L]ASTATUS = fmet this.ASETATTRIBUTE("SJNTTEL","$x3Format",[L]AFORMAT)
Endif
Return


