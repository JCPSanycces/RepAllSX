#
#*********************************************************************
#
#                    GESTION DES PLANS DE SAISONNALITE
#
#*********************************************************************
#    Création
#    MWA - 03.06.2009
#
#*********************************************************************
#    Modification
#
#*********************************************************************
#
  Raz GPILOBJ
  Call DEFVAR From GLOBIMM
  Call INIVAR From GLOBIMM
  Call OBJET("PSE",GBIDC1,GBIDC2) From GOBJET
End

#*********************************************************************
#
$ACTION
 #Infbox num$(ACTION)
 
  Case ACTION
    When "OUVRE"            : Gosub OUVRE          
    When "RAZCRE"           : Gosub RAZCRE          

    When "LIENS"            : Gosub LIENS

    When "APRES_MODIF"      : Gosub APRES_MODIF 
    When "SETBOUT"          : Gosub SETBOUT

    When "VERIF_CRE"        : Gosub VERIF_CRE
    When "CREATION"         : Gosub CREATION   

    When "AVANT_MOD"        : Gosub AVANT_MOD
    When "VERIF_MOD"        : Gosub VERIF_MOD
    When "MODIF"            : Gosub MODIF   
    
    When "VERF_ANU"         : Gosub VERF_ANU
    When "ABANDON"          : Gosub ABANDON   
     
    When "FERME"            : Gosub FERME   
    When Default
  Endcase
Return

#
#*********************************************************************
#

#
#=====================================================================
#
$OUVRE

Global Integer G_NOLCK
Global Integer G_MODIF

Local Integer STAT                   : # Code retour / call VERFALLCPY
Local Char    L_CPY(GLONCPY)         : # Société pour contrôle habilitation

  # Gestion des fichiers 
  If clalev([F:CNX])  =0     : Local File CONTEXT       [CNX]     : Endif
  If clalev([F:FAS])  =0     : Local File FXDASSETS     [FAS]     : Endif

Return

#=====================================================================
$RAZCRE
  Local Integer IM
  nolign = 1
  For IM = 1 To 12
    [M:PSE1]LIB01 (nolign-1) = month$(IM)
    [M:PSE1]ACTFLG(nolign-1) = G_NON
    nolign += 1
  Next IM
  [M:PSE1]NB_PSE= nolign-1
  Affzo [M:PSE1]    
Return

#=====================================================================
#
$AVANT_MOD

  # Habilitations : Contrôle habilitation / société
  L_CPY=[M:PSE0]CPY
  Gosub AUZ_CPY
Return

#=====================================================================
#
$APRES_MODIF

  # --------------------------
  # Contrôle habilitation / société
  If ( COUZON="CPY" ) Then
    L_CPY = CZ 
    Gosub AUZ_CPY
    If !OK Then
      Return
    Endif
  Endif

Return


#=====================================================================
#
$SETBOUT
 
  # Désactivation des actions   "Changer de clé"
  Call VIREBOUT(CHAINE,"H") From GOBJET

  # Pas de suppression du paramétrage par défaut si pas d'habilitation "tous sites du dossier"
  If ( [M:PSE0]CPY="" ) Then
    If ( GUSRFCY(1) <> "\" and GNBAUZ <> GNBSITE ) Then
      Call VIREBOUT(CHAINE,"A") From GOBJET
    Endif
  Else
    # Pas de suppression du paramétrage d'une société si pas d'habilitation "tous sites de la société"
      Call VERFALLFCY([M:PSE0]CPY,[L]STAT) From SUPCPT
      If ( [L]STAT < 1 ) Then : Call VIREBOUT(CHAINE,"A") From GOBJET : Endif
  Endif

Return


#=====================================================================
#
$LIENS

  Actzo [M:PSE1]1-99 : # FQ73970
  
  # Chargement du masque
  Local Integer IM
  nolign = 1
  For IM = 1 To 12
    [M:PSE1]LIB01 (nolign-1) = month$(IM)
    [M:PSE1]ACTFLG(nolign-1) = [F:PSE]ACTFLG(IM-1)
    [M:PSE1]ACTFLGO(nolign-1) = [F:PSE]ACTFLG(IM-1)
    nolign += 1
  Next IM
  [M:PSE1]NB_PSE= nolign-1
  If G_ACTKRU=G_OUI 
   [M:PSE1]SESTYP  = [F:PSE]SESTYP
   [M:PSE1]SESTYPO = [F:PSE]SESTYP  
  Endif
  Affzo [M:PSE1]    

  # Le plan de production est-il utilisé par au moins un bien.
  If ( func FAS_UTILISE_PSEPLN([M:PSE0]PSEPLN, [M:PSE0]CPY ) ) Then
    [M:PSE0]UTILISE = G_OUI
  Else
    [M:PSE0]UTILISE = G_NON
  Endif

  #--------------------------
  # Selon legislation
  Case GLEGSOC(find([M:PSE0]CPY,GSOC))
  When "RUS"
    # Russie
    Gosub LIENS From SUBPSEKRU
  When "POL"
    # Pologne
    Gosub LIENS From SUBPSEKPL
  Endcase 
  #-------------------------

Return

#-------------------------------------------------------------------------------
$VERIF_CRE
  Gosub VERIF_CRE_MOD 
Return

#-------------------------------------------------------------------------------
$VERF_ANU


Local Char LTBCPY(GLONCPY)(0..100)
Local Integer LNBCPY
Local Integer LUSED
 

  # La suppression d'un plan de saisonnalité est interdite lorsque
  # le mode est utilisé par au moins un bien comptable.
  If ( [M:PSE0]UTILISE = G_OUI  ) Then
    GERR= 1 : GMESSAGE= mess(256,7770,1) :  OK = 0
    zonsui = "[M:PSE0]PSEPLN"
    Return
  Endif

Return


#-------------------------------------------------------------------------------
$VERIF_MOD

  Gosub VERIF_CRE_MOD
 
  #--------------------------
  # Selon legislation
  Case GLEGSOC(find([M:PSE0]CPY,GSOC))
  When "RUS"
    # Russie
    Gosub VERIF_MOD From SUBPSEKRU  
  When "POL"
    # Pologne
    Gosub VERIF_MOD From SUBPSEKPL
  Endcase 
  #-------------------------  
Return

$VERIF_CRE_MOD

Local Integer IM
Local Integer IP
  
  IP = 0  
  For IM = 1 To [M:PSE1]NB_PSE
    If ( [M:PSE1]ACTFLG(IM-1) = G_OUI ) Then : IP = IP+1 :  Endif
  Next IM

  If ( IP = 0 ) Then
    # Au moins un mois doit être actif pour le plan de saisonnalité
    GERR = 1
    GMESSAGE = mess(257,7770,1)
    OK = 0
    Return
  Endif

  If ( IP = 12 ) Then
    # Au moins un mois ne doit pas être actif pour le plan de saisonnalité
    GERR = 1
    GMESSAGE = mess(262,7770,1)
    OK = 0
    Return
  Endif

Return

#-------------------------------------------------------------------------------
$CREATION

Return
#-------------------------------------------------------------------------------
$MODIF
  #--------------------------
  # Selon legislation
  Case GLEGSOC(find([M:PSE0]CPY,GSOC))
  When "RUS"
    # Russie
    Gosub MODIF From SUBPSEKRU  
  When "POL"
    # Pologne
    Gosub MODIF From SUBPSEKPL
  Endcase 
  #------------------------- 
Return


#-------------------------------------------------------------------------------
$ANNULE
Return
#-------------------------------------------------------------------------------
$ABANDON
 
Return
#-------------------------------------------------------------------------------
$FERME
  If dim(G_NOLCK)>0      : Kill G_NOLCK      : Endif
  If dim(G_MODIF)>0      : Kill G_MODIF      : Endif   
Return

######################################################################################
## Ecran PSE0
######################################################################################


#----------------------------------------------
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
 
  If ( find( GLEGSOC(find(VALEUR, GSOC)), "RUS", "POL") = 0 ) Then
     # Legislation de la société invalide
    GERR= 1 : GMESSAGE= mess(263, 7770, 1)
      mkstat = 2 : End
    Endif
  
  If (find( GLEGSOC(find(VALEUR, GSOC)), "RUS", "POL") = 0 ) Then
     # Legislation polonaise
  Endif

  #--------------------------
  # Selon legislation
  Case GLEGSOC(find(VALEUR,GSOC))
  When "RUS"
    # Russie
    Gosub AM_CPY From SUBPSEKRU   
  When "POL"
    # Pologne
    Gosub AM_CPY From SUBPSEKPL
  Endcase 
  #-------------------------  

End
#----------------------------------------------
Subprog AP_PSEPLN(VALEUR)
Variable Char    VALEUR()
End

#----------------------------------------------
Subprog AV_SESTYP(VALEUR)
Variable Integer VALEUR

  #--------------------------
  # Selon legislation
  Case GLEGSOC(find([M:PSE0]CPY,GSOC))
  When "RUS"
    # Russie
    Gosub AV_SESTYP From SUBPSEKRU   
  When "POL"
    # Pologne
    Gosub AV_SESTYP From SUBPSEKPL
  Endcase 
  #-------------------------  
End


######################################################################################
## Sous programme & fonctions
######################################################################################

#=====================================================================
#
$AUZ_CPY
  # Habilitation : Contrôle de l'habilitation / société
  If ( GNBAUZ <> GNBSITE ) Then : # Pas d'habilitation tous sites
    If ( L_CPY <> "" ) Then
      mkstat = 0
      Call CONTALLFCY(L_CPY) From SUPCPT
      If mkstat : OK = 0 : mkstat = 0 : Endif
    Else
      # Vous n'êtes pas habilité pour la modification des paramètrages par défaut
      OK=0 : GMESSAGE=mess(113,7770,1)
    Endif
  Endif

Return

########################################
Funprog PSE_DEFINI(PPLN)
# Reçoit un plan de saisonalité 
#    rend = 0 si le plan n'est pas défini
#           1 si le plan est défini 
# ---------------------------------------

Value Char PPLN
Local Integer RRET

  Filter [PSE] Where PSEPLN = PPLN 
  Read [PSE]PSE0 First 
  Filter [PSE]
  If (fstat) Then
    RRET = 0
  Else
    RRET = 1
  Endif
    
End RRET


########################################
Funprog FAS_UTILISE_PSEPLN(PPLN,PCPY)
# Reçoit un plan de saisonnalité 
# et rend 1 si le plan est utilisé par un bien comptable
# ou rend 0 dans le cas contraire
# --------------------------------------

Value Char  PPLN, PCPY

Local Integer RRET
Local Char CRITERE
  RRET = 0
  CRITERE = 'CPY=PCPY and KPSEPLN=PPLN'
  For [FAS]FAS1 Where evalue(CRITERE)
    RRET=1
    Break
  Next

End RRET



