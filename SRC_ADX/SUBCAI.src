#<AdxTL>@(#)8.0.0.0 $Revision$
Call OBJET("CAI",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "LIENS"           : Gosub LIENS
 When "FILTRE"          : Gosub FILTRE
 When "INICRE","INIMOD" : Gosub INICPT
 When "OUVRE"           : Gosub OUVRE
 When "APRES_MODIF"     : Gosub APRES_MODIF
 When "FIN"             : Gosub FIN
 When "RAZCRE"          : Gosub RAZCRE             # SAM 88426 - 2015-06-22 by LUCUE : Factoring management
 When "VERIF_CRE", "VERIF_MOD"  : Call VERIFPAYTRASEL From SUBBAN
 When Default
Endcase
Return

# SAM 88426
$RAZCRE
#---------------------------------#
# Initialization table axes       #
#---------------------------------#
If dim([M:CAI1]NBSEC)>0
  Call CHARG_DIE(12,"","CAI1","NBSEC") From TRTX3CPT
  Affzo [M:CAI1]
Endif

#Issue 47122 – 2017-09-21  by MADOR - 3.1 - Function GESBAN and GESCAI
If func AFNC.ACTIV("FIFRC")
    Call CHANGE_FIFOCONPRO_STATE([M:CAI1]CPY, [M:CAI1]CUR)
Endif
#Issue end
Return
# End SAm 88426

$OUVRE
If clalev([F:JOU])=0  : Local File GJOURNAL [JOU]  : Endif
If clalev([F:JCO])=0  : Local File GJOUCOA  [JCO]  : Endif
If clalev([F:BAN2])=0 : Local File BANK     [BAN2] : Endif
If dim(GCURLEG)>0     : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

# SAM 88426
If clalev([F:CDI])=0 : Local File CADIEDEF   [CDI] : Endif
Local Integer NUMDIE
NUMDIE = 12 : # Rank in the menu 2230 (Bank)
Read [CDI]CDI0 = NUMDIE
# SAM 88426

Return

$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG  = SAV_GCURLEG : Endif
Return

$FILTRE
FILTSUP = "[F:BAN]BANCSH=2"
Return

$LIENS
[M]JOU    = [F:BAN]JOU(0)
[M]JOUTYP = [F:BAN]JOUTYP(0)
Call LECMAINPLAN(1,[M]CPY,[M]COA) From CPTDIV
Call LEC_CPY([M]CPY) From CPTLEC
GCURLEG = [F:CPY]LEG

# SAM 88426 - 2015-06-22 by LUCUE : comment
## Loading analytical sections
If dim([M:CAI1]DIE)<1 : Return : Endif

Raz [M:CAI1]DIE
Raz [M:CAI1]CCE
[M:CAI1]NBSEC = [F:CDI]NBRDIE
For I=0 To [F:CDI]NBRDIE-1
 [M:CAI1]DIE(I) = [F:CDI]DIE(I)
 For J=0 To dim([F:BAN]DIE)-1
  If [F:BAN]DIE(J)=[F:CDI]DIE(I)
   [M:CAI1]CCE(I) = [F:BAN]CCE(J)
   Break
  Endif
 Next J
Next I
### End SAM 88426

#ISSUE 33455 – 2017-06-09  By MANOW/MRDAB
If func AFNC.ACTIV("REGBC")
  Call REFCASHPAYTRA([M:CAI1]CPY, [M:CAI1]BAN) From SUBBAN
Endif
#ISSUE END
#Issue 47122 – 2017-09-21  by MADOR - 3.1 - Function GESBAN and GESCAI
If func AFNC.ACTIV("FIFRC")
    Call CHANGE_FIFOCONPRO_STATE([M:CAI1]CPY, [M:CAI1]CUR)
Endif
#Issue End
Return

$INICPT
If [F:BAN]BANCSH=2
 Call LEC_CPY([F:BAN]CPY) From CPTLEC
 Call LEC_JOU_LEG([F:CPY]LEG,[F:BAN]JOU(0)) From CPTLEC
 If [F:JOU]TYP=3
  Call LEC_JCO_LEG([F:CPY]LEG,[M]COA,[F:BAN]JOU(0)) From CPTLEC
  If !fstat
   [F:BAN]BANACC = [F:JCO]ACC
  Endif
 Endif
Endif
[F:BAN]JOU(0)    = [M]JOU
[F:BAN]JOUTYP(0) = [M]JOUTYP
[F:BAN]TREACC(0) = [M]BANACC
Return

$APRES_MODIF
If COUZON=CLEPRIM
 Read [F:BAN2]BAN0=CZ
 If fstat=0 & [F:BAN2]BANCSH=1  :# Banque
  GMESSAGE = mess(1,653,1)
  mkstat=2 : [L]OK=0
 Endif
Endif
Return
######################################################################################
Subprog CHANGE_FIFOCONPRO_STATE(COMPANY, BCCUR)
Variable Char COMPANY()
Variable Char BCCUR()

#Issue 47122 – 2017-09-21  by MADOR - 3.1 - Function GESBAN and GESCAI
If func AFNC.PARAM("FIFRC", [L]COMPANY) <> "2"
    Gosub HIDE_FLFFIFCP: End
Endif

If !clalev([F:CPY1])    : Local File COMPANY      [CPY1]    : Endif
If !clalev([F:GCM1])    : Local File GACM         [GCM1]    : Endif

Link [CPY1] With [GCM1]GCM0 = [F:CPY1]ACM As [GCMA]
&           Where [F:CPY1]CPY = [L]COMPANY
Read [GCMA]CPY0 First

If !fstat and [L]BCCUR <> [F:GCM1]CUR(0) and [L]BCCUR <> ""
    Chgfmt [M:CAI1]FLDSDA  With "D:" + GFMDAT
    Chgfmt [M:CAI1]FLDFIFCP  With "K:10X"
    If [M:CAI1]FLDFIFCP = 1 or [M:CAI1]FLDFIFCP = 0
        Raz [M:CAI1]FLDSDA
        Grizo [M:CAI1]FLDSDA
    Else
        Actzo [M:CAI1]FLDSDA
        Affzo [M:CAI1]FLDFIFCP
    Endif
Else
    Gosub HIDE_FLFFIFCP
Endif

LogicClose File  [CPY1]
LogicClose File  [GCM1]
#Issue end
End
######################################################################################
$HIDE_FLFFIFCP
    Raz [M:CAI1]FLDSDA
    Raz [M:CAI1]FLDFIFCP
    Affzo [M:CAI1]FLDSDA
    Affzo [M:CAI1]FLDFIFCP
    Chgfmt [M:CAI1]FLDSDA With "-D:" + GFMDAT
    Chgfmt [M:CAI1]FLDFIFCP  With "-K:10X"
Return

