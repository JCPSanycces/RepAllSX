#<AdxTL>@(#)0.0.0.0 $Revision$
#################################################
# RBA 29/06/2018                                #
# Tool to set default values to FLGSURA         #
# EDICAT table                                  #
#################################################

Subprog PATCH(APPLI)
Value Char    APPLI
  If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
  #child folder
  If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
  # Check Common Data Module
  If [F:ADS]MODULE(8)<>2 : End : Endif
  # Check EDIX3 activity activated
  If func AFNC.ACTIVDOS(DOSSIER,"EDIX3") = 0 : End: Endif

  Local Integer NBTRAIT,NBERR

  Call ECR_TRACE("EDI:"-mess(81,125,1)-tolower(mess(655,197,1)),0) From GESECRAN
  Call ECR_TRACE(string$(90,"-"),0) From GESECRAN
  Call ECR_TIME("DOSSIER : "+DOSSIER) From DOSSUB
  Call ECR_TRACE(string$(90,"-"),0) From GESECRAN

  # Opening the tables to use
  If clalev([F:ECA])  = 0 : Local File =DOSSIER + ".EDICAT"    [ECA]  : Endif

  Raz NBTRAIT, NBERR
  For [ECA]
    Gosub MAJ_CATEGORY
  Next
  Call ECR_TRACE("EDI:"-mess(81,125,1)-tolower(mess(655,197,1)),0) From GESECRAN
  Call ECR_TRACE(mess(93,143,1)-":"-num$(NBTRAIT),0) From GESECRAN
  If NBERR > 0
    Call ECR_TRACE(mess(93,143,1)-"ERR"-":"-num$(NBERR),0) From GESECRAN
  Endif
  Call ECR_TRACE(string$(90,"-"),0) From GESECRAN

  Raz NBTRAIT, NBERR
End

$MAJ_CATEGORY
  Trbegin [ECA]

  Case [ECA]CATTYP
    When 1       : [ECA]FLGSYRA   = [V]CST_ANO  #Purchase invoice
    When 2       : [ECA]FLGSYRA   = [V]CST_ANO  #Sales invoice
    When 3       : [ECA]FLGSYRA   = [V]CST_ANO  #Purchase order
    When 4       : [ECA]FLGSYRA   = [V]CST_ANO  #Sales order
    When 5       : [ECA]FLGSYRA   = [V]CST_ANO  #Sales delivery
    When 6       : [ECA]FLGSYRA   = [V]CST_AYES #Intrasat
    When 7       : [ECA]FLGSYRA   = [V]CST_AYES #Sales delivery notification  : X3-7673 EDI improvements CRUD method for receipt
    When Default : [ECA]FLGSYRA   = [V]CST_ANO
  Endcase

  Case [ECA]CATTYP
    When 1       : [ECA]CATTRGTAB = "PINVOICE"    #Purchase invoice
    When 2       : [ECA]CATTRGTAB = "SINVOICEV"   #Sales invoice
    When 3       : [ECA]CATTRGTAB = "PORDER"      #Purchase order
    When 4       : [ECA]CATTRGTAB = "SORDER"      #Sales order
    When 5       : [ECA]CATTRGTAB = "SDELIVERY"   #Sales delivery
    When 6       : [ECA]CATTRGTAB = "EDIDEB"      #Intrasat
    When 7       : [ECA]CATTRGTAB = "SDELIVERYNO" #Sales delivery notification  : X3-7673 EDI improvements CRUD method for receipt
    When Default : [ECA]CATTRGTAB = ""
  Endcase

  Case [ECA]CATTYP
    When 1       : [ECA]DUPLICATE   = 2 #Purchase invoice
    When 2       : [ECA]DUPLICATE   = 2 #Sales invoice
    When 3       : [ECA]DUPLICATE   = 1 #Purchase order
    When 4       : [ECA]DUPLICATE   = 1 #Sales order
    When 5       : [ECA]DUPLICATE   = 1 #Sales delivery
    When 6       : [ECA]DUPLICATE   = 1 #Intrasat
    When 7       : [ECA]DUPLICATE   = 1 #Sales delivery notification
    When Default : [ECA]DUPLICATE   = 1
  Endcase

  Rewrite [ECA]
  If !fstat
    Commit
    NBTRAIT +=1
    ##
  Else
    NBERR +=1
    ##
    Rollback
  Endif
Return

