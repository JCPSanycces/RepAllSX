#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion objet DLA

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:07:28"
A_USER  = "DOC"
A_STAMP = "20181109230728"
Return

$DEFAUT
Default File [DLA]
Return

$OUVFIC
Local File DECAT [DLA]
Return

$NOMFIC
Local Integer NBLNK , TITLNK(1..20)
Local Char    OBJLNK(GLONAOB)(1..20) , CODLNK(GLONADI)(1..20)
Local Char    DESLNK(20)(1..20) , ABRLNK(GLONABR)(1..20)
Local Integer NUMLNK(1..20) , LIGLNK(1..20)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , ABTAB(GLONABR) , NOMINT(GLONAVA)
Local Integer TYPGES , FLGSTAT , SELORD , TYPOBJ
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA), FLDGRF(GLONAVA), FLDLEG(GLONAVA), FLDGRC(GLONAVA)
Local Char    REPORT1(GLONARP) , REPORT2(GLONARP) , NOMKEY(GLONAVA)
Local Integer DELDEF, FCYREQ
Local Char    SELIND(250) , ADDURL(250)
NOMFIC = "DECAT"
ABFIC  = "DLA"
ABTAB  = "DLA"
NOMINT = ""
TYPGES = 1
SELORD = 2
ZSITE  = "FCY"
ZACC   = ""
FLDGRF = ""
FLDGRC = ""
FLDLEG = "LEG"
FCYREQ = 1
PPAG   = 0
SELIND = "[F:DLA]DAT;[F:DLA]REFNUM;[F:DLA]CTRNUM"
DELDEF = 0
ADDURL = ""
REPORT1 = "DECAT"
NOMKEY = "DLA1"
FLGSTAT = 0
TITOBJ = 45498
NBLNK = 0
Raz NUMLNK , LIGLNK
Return

$OUVRE
If clalev([F:TCY])=0 : Local File TABCOUNTRY   [TCY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY     [FCY] : Endif
If clalev([F:POS])=0 : Local File POSCOD       [POS] : Endif
If clalev([F:ID])=0 : Local File EMPLOID      [ID] : Endif
If clalev([F:ACC])=0 : Local File ACCES        [ACC] : Endif
If clalev([F:ECT])=0 : Local File EMPCTR       [ECT] : Endif
If clalev([F:AFF])=0 : Local File AFCTFCY    [AFF] : Endif
Return

$ESPION
NUMESPION = 1
Return

$TIT
Local Char TIT(60)
Call TEXTE(45498,TIT) From OBJDIV
Return

$SETCLE
Local Char CLEPRIM(GLONAVA) , CLESEC(GLONAVA)(0..1) , CLELIG(GLONAVA)
CLEPRIM = 'REFNUM'
CLESEC(0) = 'DAT'
CLESEC(1) = 'CTRNUM'
Return

$OPTIONS
Local Integer  NBCOND
Local Char     CONDIT(50)(1..20)
Local Char     OPT(1)(1..20) , OPTSEL(20)
Local Char     LIBOPT(30)(1..20), MESSAG(80)(1..20)
NBCOND = 0
OPTSEL = ''
Return

$LIBPAR
Local Char LIBPAR(30)
Call TEXTE(0,LIBPAR) From OBJDIV
Return

$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Date     A_BUF1(0..GNBDERNIER)
Local Char     A_BUF2(30)(0..GNBDERNIER)
Local Char     A_BUF3(15)(0..GNBDERNIER)
Local Char     A_BUF4(20)(0..GNBDERNIER)
Local Char     A_BUF5(20)(0..GNBDERNIER)
If clalev([F:DLA9])>0 : Close Local File [DLA9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Date     A_TAB1,
& Char     A_TAB2(30),
& Char     A_TAB3(15),
& Char     A_TAB4(20),
& Char     A_TAB5(20)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5
& As [DLA9]
Return

$LEC_DERLU
Read [AFF]AFF0 = [F:DLA]FCY;GPROFIL;GUSRFCT
If fstat : Raz [F:AFF] : Endif
Read [ID]ID0=[F:DLA]REFNUM
If fstat : Raz [F:ID] : Endif
Read [ACC]CODACC=GUSER;[F:ID]CODACS
If fstat : Raz [F:ACC] : Endif
Read [ECT]ECT0=[F:DLA]REFNUM;[F:DLA]CTRNUM
If fstat : Raz [F:ECT] : Endif
Return

$CHARGE_DERLU
If clalev([F:DLA9])>0
 Read [DLA9] = [F:DLA9]A_TABI
 [L]CLE = [F:DLA9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:DLA9])>0
 Filter [DLA9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [DLA1] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:DLA9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:DLA]REFNUM+"~"
 A_CLEDERLU += [F:DLA]DAT+"~"
 A_CLEDERLU += [F:DLA]CTRNUM+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:DLA9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:DLA9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 2
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:DLA]DAT"
Call TEXTE(212,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 8
SELFMT(NBSEL) = "DZz:"+GFMDAT4+""
SELFOR(NBSEL) = "DZz:"+GFMDAT4
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:DLA]DAT"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(2)"
SELEXP(NBSEL) = "[F:DLA]NAM-[F:DLA]SRN"
Call TEXTE(47187,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:30X"
SELFOR(NBSEL) = ""
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[F:DLA]REFNUM"
Call TEXTE(10793,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:15X"
SELFOR(NBSEL) = "K:15c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:DLA]REFNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:DLA]CTRNUM"
Call TEXTE(5481,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:DLA]CTRNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:DLA]LEG"
Call TEXTE(26213,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:DLA]LEG"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:DLA_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF] : Endif
If clalev([F:ID])=0 : Local file EMPLOID [ID] : Endif
If clalev([F:ACC])=0 : Local file ACCES [ACC] : Endif
If clalev([F:ECT])=0 : Local file EMPCTR [ECT] : Endif
Link [DLA] With
& [AFF]AFF0~=[F:DLA]FCY;GPROFIL;GUSRFCT,
& [ID]ID0=[F:DLA]REFNUM,
& [ACC]CODACC=GUSER;[F:ID]CODACS,
& [ECT]ECT0=[F:DLA]REFNUM;[F:DLA]CTRNUM
& As [DLA_]
Return

$DEFAUT_LISTE
Default file [DLA_]
Return

$OUVRE_JOIN
Local Char    ORDRE_JOI(250)
ORDRE_JOI = "A_TABJ1;A_TABJ2;A_TABJ3"
Local Date     A_BUFJ1(1..GNBSEL)
Local Char     A_BUFJ2(15)(1..GNBSEL)
Local Char     A_BUFJ3(20)(1..GNBSEL)
Local Char     A_BUFJ4(15)(1..GNBSEL)
Local Char     A_BUFJ5(80)(1..GNBSEL)
Local File(
& Date     A_TABJ1,
& Char     A_TABJ2(15),
& Char     A_TABJ3(20),
& Char     A_TABJ4(15),
& Char     A_TABJ5(80)
& ) From Variable A_BUFJ1, A_BUFJ2, A_BUFJ3, A_BUFJ4, A_BUFJ5
& As [PCEJ]
Return

$TIT_JOIN
Local Char TITJOI(30)(1..5)
Call TEXTE(212,TITJOI(1)) From OBJDIV
Call TEXTE(10793,TITJOI(2)) From OBJDIV
Call TEXTE(5481,TITJOI(3)) From OBJDIV
TITJOI(4) = mess(59,100,1) : # Type
TITJOI(5) = mess(38,100,1) : # Nom
Return

Subprog FORMCLE(FMT,LG,TIT)
Variable Char    FMT()
Variable Integer LG
Variable Char    TIT()
FMT = "Kf:15c"
LG = 0
TIT = ""
End

Subprog FORMCLE2(FMT)
Variable Char    FMT()
FMT = "Df:"+GFMDAT
End

$LIENS
Read [ID]ID0 = [F:DLA]REFNUM
If fstat : Raz [F:ID] : Endif
Read [ACC]CODACC = GUSER;[F:ID]CODACS
If fstat : Raz [F:ACC] : Endif
Read [ECT]ECT0 = [F:DLA]REFNUM;[F:DLA]CTRNUM
If fstat : Raz [F:ECT] : Endif
Return

$LIAISONS
Return

Subprog TITTRN(COD,TIT)
Value Char COD
Variable Char TIT
Local Integer OUV
Local Char    CRITERE(250)
TIT = ""
End

$OUVTAB
Return

$OUVVUE
Return

$DEFAUT_TAB
Return

$TRANS_TAB
Return

$TRANS_FIC
Return

$FERME_TAB
Return

$FERME_FIC
