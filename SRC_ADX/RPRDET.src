#
#*********************************************************************
#
#           DETAIL EXERCICE/PERIODE DU PLAN D'UN BIEN
#
#*********************************************************************
#    Création
#    MWA - 28.05.2009
#
#*********************************************************************
#    Modification
#    MWA - 00.00.2009  FQnnnnn  .................
#    CBO - 12.03.2012  FQ80246  GFMDAT4 au lieu de DD[/]MM[/]YYYY
#
#*********************************************************************
#
# Call OBJET("RPR",GBIDC1,GBIDC2) From GOBJET
# End

$ACTION

Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "END"         : Gosub FIN
 When "SUI"         : Gosub SUIVANT
 When "PRE"         : Gosub PRECEDENT
 When "FIR"         : Gosub PREMIER
 When "LAS"         : Gosub DERNIER
 When "FIN"         : Gosub TERMINE
 When "AP_CHOIX"    : Gosub APRES_CHOIX
Endcase
Return

#
#*********************************************************************
#

#=====================================================================
#
$OUVRE
Local Char     LAASREF(GLONAAS)
Local Shortint LNOL, LIG
Local Date     LFIYENDDAT, LPERENDDAT

Local Integer  FLGRPRCLC
Local Integer  LCONTEXT

Global Integer  BAFFEXE

  # Récupération des paramètres
  LAASREF    = PARAM(1)
  LFIYENDDAT = PARAM(2)
  LPERENDDAT = PARAM(3)
  If ([M:RPR1]NBLIG2 = 0) Then : LPERENDDAT = [0/0/0] : Endif
  LNOL       = val(PARAM(4))

  If ( LPERENDDAT = [0/0/0] ) Then
    BAFFEXE = 1
  Else
    BAFFEXE = 0
  Endif
 
  # Ouverture des fichiers
  If clalev([F:DEPW])=0 : Local File DEPREC      [DEPW] : Endif
  If clalev([F:FASW])=0 : Local File FXDASSETS   [FASW] : Endif

  Read [F:FASW]FAS0= LAASREF
  FLGRPRCLC = [F:FASW]FLGRPRCLC

Return

#=====================================================================
#
$DEBUT

  LIG = LNOL

  #------
  Gosub CHARGE_LIGNE

  Affzo [M:RPRA]    
  Affzo [M:RPRC]    

Return

#=====================================================================
#
$SETBOUT

Return

#=====================================================================
#
$APRES_MODIF

Return


#=====================================================================
#
$FIN
Filter [DEPW]
Return

#=====================================================================
#
$SUIVANT

  # Récupération des informations  du bien.
  LIG = LIG + 1
  If ( BAFFEXE ) Then
    If ( LIG > [M:RPR1]NBLIG1 ) Then 
      LIG = [M:RPR1]NBLIG1 
      GERR= 1: GMESSAGE = mess(27,7773,1) : Return 
    Endif
  Else
    If ( LIG > [M:RPR1]NBLIG2 ) Then 
      LIG = [M:RPR1]NBLIG2 
      GERR= 1: GMESSAGE = mess(27,7773,1) : Return 
    Endif
  Endif

  #------
  Gosub CHARGE_LIGNE

Return

#=====================================================================
#
$PRECEDENT

  # Récupération des informations  du bien.
  LIG = LIG - 1
  If ( LIG <= 0 ) Then
    LIG = LIG + 1
    GERR= 1: GMESSAGE = mess(27,7773,1) : Return 
  Endif
  #------
  Gosub CHARGE_LIGNE

Return
#=====================================================================
#
$PREMIER

# Récupération des informations  du bien.
  LIG = 1
  #------
  Gosub CHARGE_LIGNE

Return
#=====================================================================
#
$DERNIER

# Récupération des informations  du bien.
  If ( BAFFEXE ) Then
    LIG = [M:RPR1]NBLIG1
  Else
    LIG = [M:RPR1]NBLIG2
  Endif
  #------
  Gosub CHARGE_LIGNE

Return
#=====================================================================
#
$TERMINE

Return
#=====================================================================
#
$APRES_CHOIX

Return
#=====================================================================
#

########################################################
# Gestion du masque RPRA
########################################################

Subprog AV_ENDRNWVAL(VALEUR)
Variable Decimal VALEUR

  If ( [M:RPRA]RNWVALFLG = G_OUI) Then
    If ( GBROWS = 0 ) Then
      Chgstl [M:RPRA]ENDRNWVAL With "FORCAGE"
    Else
      Chgstl [M:RPRA]ENDRNWVAL With "TFORCAGE"
    Endif
  Else
   Chgstl [M:RPRA]ENDRNWVAL With ""
  Endif
End


########################################################
# Gestion du masque RPRC
########################################################

Subprog AV_PERSTRDAT(VALEUR)
Variable Date VALEUR


 [M:RPRC]PERSTRDATC = format$("D:" + GFMDAT4, VALEUR)
 If (BAFFEXE) Then
  Chgfmt [M:RPRC]PERSTRDATC With "-K:10X"
  Diszo  [M:RPRC]PERSTRDATC
 Else
  Chgfmt [M:RPRC]PERSTRDATC With "K:10X"
  Diszo  [M:RPRC]PERSTRDATC
 Endif

End

Subprog AV_PERENDDAT(VALEUR)
Variable Date VALEUR

 [M:RPRC]PERENDDATC = format$("D:" + GFMDAT4, VALEUR)
 If (BAFFEXE) Then
  Chgfmt [M:RPRC]PERENDDATC With "-K:10X"
  Diszo  [M:RPRC]PERENDDATC
 Else
  Chgfmt [M:RPRC]PERENDDATC With "K:10X"
  Diszo  [M:RPRC]PERENDDATC
 Endif

End


########################################################
$CHARGE_LIGNE

  Raz [M:RPRA]    
  Raz [M:RPRC]    
    
  # alimentation des champs de l'écran RPRC
  [M:RPRC]CPY       = [M:RPR1]CPY
  [M:RPRC]AASREF    = [M:RPR1]AASREF 
  [M:RPRC]AASDES1   = [M:RPR1]AASDES1
  [M:RPRC]FCY       = [M:RPR1]FCY
  [M:RPRC]CUR       = [M:RPR1]CUR
  If ( FLGRPRCLC = G_OUI ) Then
    [M:RPRC]FLGRPRCLC    = "127"
  Else
    [M:RPRC]FLGRPRCLC    = "128"
  Endif

  #-1 -------------------
  If ( BAFFEXE ) Then

  #-----------
  # EXERCICE
  #-----------

    #----------
    # Entête
    #----------
    [M:RPRC]PERSTRDAT = [0/0/0]
    [M:RPRC]PERENDDAT = [0/0/0]
    [M:RPRC]FIYSTRDAT = [M:RPR1]FIYSTRDAT  (LIG-1)
    [M:RPRC]FIYENDDAT = [M:RPR1]FIYENDDAT  (LIG-1)
    [M:RPRC]FCY       = [M:RPR1]FCY1       (LIG-1)

    #----------
    # Générale
    #----------
    [M:RPRA]STRRNWVAL = [M:RPR1]STRRNWVAL  (LIG-1)
    [M:RPRA]RNWVALCOE = [M:RPR1]RNWVALCOE  (LIG-1)
    [M:RPRA]RNWVALFLG = [M:RPR1]RNWVALFLG  (LIG-1)
    [M:RPRA]ENDRNWVAL = [M:RPR1]ENDRNWVAL  (LIG-1)
    [M:RPRA]E_1ACGRPR = [M:RPR1]E_1ACGRPR  (LIG-1)
    [M:RPRA]EXEACGRPR = [M:RPR1]EXEACGRPR  (LIG-1)
    [M:RPRA]E_1FISRPR = [M:RPR1]E_1FISRPR  (LIG-1)
    [M:RPRA]EXEFISRPR = [M:RPR1]EXEFISRPR  (LIG-1)
    [M:RPRA]E_1RVERPR = [M:RPR1]E_1RVERPR  (LIG-1)
    [M:RPRA]EXERVERPR = [M:RPR1]EXERVERPR  (LIG-1)
    [M:RPRA]E_1SUPCAD = [M:RPR1]E_1SUPCAD  (LIG-1)
    [M:RPRA]EXESUPCAD = [M:RPR1]EXESUPCAD  (LIG-1)
  
   
  Else
  #-1 -------------------

  #-----------
  # PERIODE
  #-----------


    Local Integer   LIGEXE
    LIGEXE = find([M:RPR1]FIYSTRDAT2 (LIG-1), [M:RPR1]FIYSTRDAT)

    #----------
    # Entête
    #----------
    [M:RPRC]FIYSTRDAT = [M:RPR1]FIYSTRDAT2 (LIG-1)
    [M:RPRC]FIYENDDAT = [M:RPR1]FIYENDDAT2 (LIG-1)
    [M:RPRC]PERSTRDAT = [M:RPR1]PERSTRDAT  (LIG-1)
    [M:RPRC]PERENDDAT = [M:RPR1]PERENDDAT  (LIG-1)
    [M:RPRC]FCY       = [M:RPR1]FCY2       (LIG-1)

    #----------
    # Générale
    #----------
    [M:RPRA]STRRNWVAL = [M:RPR1]STRRNWVAL2 (LIG-1)
    [M:RPRA]RNWVALCOE = [M:RPR1]RNWVALCOE2 (LIG-1)
    [M:RPRA]RNWVALFLG = [M:RPR1]RNWVALFLG2 (LIG-1)
    [M:RPRA]ENDRNWVAL = [M:RPR1]ENDRNWVAL2 (LIG-1)
    [M:RPRA]E_1ACGRPR = [M:RPR1]P_1ACGRPR  (LIG-1)
    [M:RPRA]EXEACGRPR = [M:RPR1]PERACGRPR  (LIG-1)
    [M:RPRA]E_1FISRPR = [M:RPR1]P_1FISRPR  (LIG-1)
    [M:RPRA]EXEFISRPR = [M:RPR1]PERFISRPR  (LIG-1)
    [M:RPRA]E_1RVERPR = [M:RPR1]P_1RVERPR  (LIG-1)
    [M:RPRA]EXERVERPR = [M:RPR1]PERRVERPR  (LIG-1)
    [M:RPRA]E_1SUPCAD = [M:RPR1]P_1SUPCAD  (LIG-1)
    [M:RPRA]EXESUPCAD = [M:RPR1]PERSUPCAD  (LIG-1)
    [M:RPRA]ACGRPRDEV = [M:RPR1]ACGRPRDEV  (LIG-1)
    [M:RPRA]PSTACGRPR = [M:RPR1]PSTACGRPR  (LIG-1)
    [M:RPRA]FISRPRDEV = [M:RPR1]FISRPRDEV  (LIG-1)
    [M:RPRA]PSTFISRPR = [M:RPR1]PSTFISRPR  (LIG-1)
 
  Endif
  #-1 -------------------

Return
