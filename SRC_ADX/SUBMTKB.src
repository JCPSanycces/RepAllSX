#<AdxTL>@(#)8.0.0.0 $Revision$
#####################################################################
#subprog et gosub liés au chargement et à la gestion des masques    #
#                  Subprog principaux :                             #
#                  CHARG_OPE : Chargement du masque 1 suivi opé     #
#                  CHARG_ITM : Chargement du masque 2 décl. prod    #
#                  CHARG_MAT : Chargement du masque 3 suivi matière #
#                  CHARGE_STOSOR                                    #
#                  CHARGE_STOSOM                                    #
#                  ALI_ALP                                          #
#                                                   sr Novembre 1998#
#####################################################################
##########################################
Subprog CHARG_OPE(WMFGNUM,WFILTRE)
Value Char    WMFGNUM
Value Integer WFILTRE
Local Char    CRITERE(250)
Local Integer I, WDACMST,M, J, LRET
Local Char    WCCE(15)
Local Decimal WUNTTIM                    # llc 09.02 15971

#Chargement dans l'écran MTK1 des opérations à suivre selon filtre
CRITERE  = "MFGNUM ='"+WMFGNUM+"'"
CRITERE -= "& OPENUM >="+num$([M:MTK1]WOPE1)
CRITERE -= "& OPENUM <="+num$([M:MTK1]WOPE2)
Case WFILTRE
     When 1 : CRITERE -= " & MFOTRKFLG <"+num$(5)
     When 2 : CRITERE -= " & MFOTRKFLG ="+num$(5)
Endcase

I = 0
For [MFO] Where evalue(CRITERE)
#on ne prend pas les opérations exclues
   If [F:MFO]OPESTA <> 6
#S'agit-il d'une opération de sous-traitance
    Read [F:MWS]WST0 = [F:MFO]EXTWST;[F:MFO]MFGFCY
    If !fstat & [F:MWS]WSTTYP <> 3
#L'opération doit-elle être suivie
        Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
        If !fstat & [F:SCH]DACMST > 1
            WDACMST = [F:SCH]DACMST
#Si opération borne il faut charger dans le tableau les opé à suivre en même temps
            If [F:SCH]DACMST = 3 : Gosub CHARG_PREC : Endif
            Default File [F:MFO]
            [M:MTK1]DACMST(I) = WDACMST
            Gosub CHARG_SCREEN
            [M:MTK1]WINDIC(I) = 1
            [M:MTK1]OPETRKLIN(I) = I+1
            I += 1
        Endif
    Endif
  Endif
Next
[M:MTK1]NBOPE = I

## GH 28/02/2014 bug 91718
If [M:MTK1]NBOPE > 0
   [M:MTK0]TIMUOMCOD=[M:MTK1]TIMUOMCOD(0)
Else
   Read [MFO]MFO0(1) = WMFGNUM
   [G:MFO]currlen=0
   If !fstat : [M:MTK0]TIMUOMCOD=[F:MFO]TIMUOMCOD
   Else      : [M:MTK0]TIMUOMCOD=1
   Endif
Endif
##
End

######################################################
$CHARG_PREC
Local File MFGOPE [MFOW]
Local Shortint WOPE
Local Integer WBREAK

#Recherche de la précédente opération à suivre (normale ou borne)
Raz WBREAK,WOPE
Filter [F:MFOW] Where MFGNUM = WMFGNUM & OPENUM < [F:MFO]OPENUM Order By Key MFO0 Desc
For [F:MFOW]
    Read [F:SCH]SCH0 = [F:MFOW]MFGNUM;[F:MFOW]OPENUM;[F:MFOW]OPESPLNUM
    If !fstat & [F:SCH]DACMST >1 : WBREAK = 1 : Break : Endif
Next
If WBREAK = 1 : WOPE = [F:MFOW]OPENUM : Endif

#Traitement des opé entre les deux bornes
Filter [F:MFOW] Where MFGNUM = WMFGNUM & OPENUM > WOPE & OPENUM < [F:MFO]OPENUM
For [MFOW]
    Default File [MFOW]
    If [F:MFOW]OPESTA <> 6
#s'agit-il d'une opération de sous-traitance
        Read [F:MWS]WST0 = [F]EXTWST;[F]MFGFCY
        If !fstat & [F:MWS]WSTTYP <> 3
            [M:MTK1]OPEBORNE(I) = [F:MFO]OPENUM
            [M:MTK1]DACMST(I) = 1
            Gosub CHARG_SCREEN
            [M:MTK1]OPETRKLIN(I) = I+1
            I+=1
        Endif
    Endif
Next
Filter [F:MFOW]
Close Local File [MFOW]
Return

#######################################################
$CHARG_SCREEN

 [M:MTK1]TIMTYP(I)    = 1
 [M:MTK1]ITMREF(I)    = [F:MFG]ROUNUM
 [M:MTK1]ROUALT(I)    = [F:MFG]ROUALT
 [M:MTK1]OPENUM(I)    = [F]OPENUM
 [M:MTK1]ROUOPENUM(I) = [F]OPENUM
 [M:MTK1]OPESPLNUM(I) = [F]OPESPLNUM
 [M:MTK1]MFGNUMOP(I)  = [F]MFGNUM
 [M:MTK1]MKOTEX(I)    = [F]MFOTEX
# lecture poste pour centre de charge et type
 Read [MWS]WST0=[F]EXTWST;[F]MFGFCY
 If !fstat
     [M:MTK1]WSTTYP(I)     = [F:MWS]WSTTYP
     [M:MTK1]XWSTTYP(I)    = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
     # [M:MTK1]WSTSHO(I)     = [F:MWS]WSTSHO : # GH 28/02/2014 bug 95952
     Call LECTEXTRA([M:MTK1]WSTSHO(I),"WORKSTATIO","WSTSHOAXX",[F]EXTWST,[F]MFGFCY) From ATEXTRA
 Endif
 [M:MTK1]CPLWST(I)         = [F]EXTWST
 [M:MTK1]XOPEUOM(I)        = [F]OPEUOM
 [M:MTK1]OPESTUCOE(I)      = [F]OPESTUCOE
#nouvelle gestion des qtés en UO ou US selon transaction
 Case [F:MTS]OPEUOMMOD
    When 1 :  [M:MTK1]OPEUOM(I)          = [F]OPEUOM
              [M:MTK1]OPEWORCOE(I)       = 1
    When 2 :  Case [F:MTS]OPEUOMTYP
                  When 1 : [M:MTK1]OPEUOM(I)    = [F]OPEUOM
                           [M:MTK1]OPEWORCOE(I) = 1
                  When 2 : [M:MTK1]OPEUOM(I)    = [F:MFG]STU
                           [M:MTK1]OPEWORCOE(I) = [F]OPESTUCOE
              Endcase
Endcase
If [M:MTK1]OPEWORCOE(I) = 0 : [M:MTK1]OPEWORCOE(I) = 1 : Endif
[M:MTK1]TECCRD(I)         = [F]TECCRD
#qté prévue = Qté totale prévue - qté déjà réalisée ssi opé non soldée
If     [F]MFOTRKFLG   = 5
       [M:MTK1]EXTQTY(I)  = 0
Else   [M:MTK1]EXTQTY(I)  = ([F]EXTQTY- [F]CPLQTY) / [M:MTK1]OPEWORCOE(I)
       Call QTEARR([M:MTK1]EXTQTY(I),[M:MTK1]OPEUOM(I)) From TRTDIV
Endif
If [M:MTK1]EXTQTY(I) < 0  : [M:MTK1]EXTQTY(I) = 0 : Endif
[M:MTK1]CPLQTY(I)         = [M:MTK1]EXTQTY(I)
Call QTEARR([M:MTK1]CPLQTY(I),[M:MTK1]OPEUOM(I)) From TRTDIV

[M:MTK1]OKQTY(I)          = [M:MTK1]CPLQTY(I)
[M:MTK1]WANCQTY(I)        = [M:MTK1]EXTQTY(I)
[M:MTK1]ROOTIMCOD(I)      = [F]ROOTIMCOD
[M:MTK1]CAD(I)            = [F]CAD    # CCC (2010-04-07) Bug 63699
[M:MTK1]EFF(I)            = [F]EFF    # Issue 88551 - 2013-03-14 by CCC
[M:MTK1]TIMUOMCOD(I)      = [F]TIMUOMCOD
# If [M:MTK0]TIMUOMCOD = 0 : [M:MTK0]TIMUOMCOD = [F]TIMUOMCOD : Endif :  # GH 28/02/2014 bug 91718
# llc  09.02 15971  - FQ 42739 01/2008 sauf si temps forfaitaire
If [F]EXTQTY <> 0 & [F]ROOTIMCOD <> 3
    WUNTTIM = [F]EXTOPETIM / [F]EXTQTY
Endif
#Tps réglage prévu = tps réglage total prévu - tpé réglage déjà réalisé
If [F]MFOTRKFLG = 5
   [M:MTK1]EXTSETTIM(I)   = 0
Else
    [M:MTK1]EXTSETTIM(I)      = [F]EXTSETTIM- [F]CPLSETTIM
    If [M:MTK1]EXTSETTIM(I) < 0 : [M:MTK1]EXTSETTIM(I) = 0 : Endif
Endif
[M:MTK1]CPLSETTIM(I)      = [M:MTK1]EXTSETTIM(I)
# 01.07 demande 39261 - FQ 42739 01/2008 sauf si temps forfaitaire
If GREP = "C" & [F]ROOTIMCOD <> 3
    [M:MTK1]CPLUNTTIM(I)      = WUNTTIM * [M:MTK1]OPEWORCOE(I)                    # llc 09.02 15971
Endif
# 11.06 demande 38402
[M:MTK1]CPLUNTTIM(I) = func TRTX3.ARRTYP("","","TIH",[M:MTK1]CPLUNTTIM(I))
#Tps opé prévu = qté prévue * tps unitaire prévu si ROOTIMCOD <> 3
#sinon tps opé prévue = tpsopé prévu - tps opé déjà réalisé
If [F]MFOTRKFLG = 5
   [M:MTK1]EXTOPETIM(I)   = 0
Else
   # CCC (2010-04-07) Bug 63699 : Dans le cas des cadences, on ne prend pas le temps unitaire car il est arrondi
   Case [M:MTK1]ROOTIMCOD(I)
       When 2 : # Cadence
                # Issue 88551 - 2013-03-14 by CCC : prise en compte de l'efficience
                # Issue 84856 - 2012-10-03 by CCC : arrondi
                # GH 08/10/2014 bug 101352
                #[M:MTK1]EXTOPETIM(I)      = func TRTX3.ARRTYP("", "", "TIH", [M:MTK1]EXTQTY(I) / [M:MTK1]CAD(I) / ([M:MTK1]EFF(I) / 100))
                [M:MTK1]EXTOPETIM(I) = func TRTX3.ARRTYP("", "", "TIH", [M:MTK1]EXTQTY(I) * [M:MTK1]OPEWORCOE(I) / [M:MTK1]CAD(I) / ([M:MTK1]EFF(I) / 100))
       When 3 : # Forfaitaire
                [M:MTK1]EXTOPETIM(I)      = [F]EXTOPETIM - [F]CPLOPETIM
       When Default : [M:MTK1]EXTOPETIM(I)      = [M:MTK1]EXTQTY(I) * [M:MTK1]CPLUNTTIM(I)
   Endcase
   If [M:MTK1]EXTOPETIM(I) < 0 : [M:MTK1]EXTOPETIM(I) = 0 : Endif
Endif
[M:MTK1]CPLOPETIM(I)      = [M:MTK1]EXTOPETIM(I)
If GREP = "C" & [M:MTK0]MFGTRKNUM = ""
   Raz LRET
   Call CONT_SOLDE_OPE([M:MTK0]MFGFCY,[M:MTK1]CPLWST(I),[M:MTK1]CPLQTY(I),[M:MTK1]EXTQTY(I),LRET) From MFGLIBO
   If LRET = 1 : [M:MTK1]CLEFLG(I) = 2
   Else          [M:MTK1]CLEFLG(I) = 1
   Endif
Else
   Case [F:MFO]MFOTRKFLG
        When 3,4     : [M:MTK1]CLEFLG(I) = 1
        When Default : [M:MTK1]CLEFLG(I) = 2
   Endcase
Endif
If [F]MFOTRKFLG < 5  [M:MTK1]WCLEFLG(I) = 1
Else                 [M:MTK1]WCLEFLG(I) = 2
Endif

[M:MTK1]BPSNUM(I)       = [F]BPRNUM
[M:MTK1]POHNUM(I)       = [F]POHNUM
[M:MTK1]POPLIN(I)       = [F]POPLIN
[M:MTK1]POPSEQ(I)       = [F]POPSEQ
[M:MTK1]EXTPRI(I)       = [F]EXTPRI
[M:MTK1]CPLPRI(I)       = [F]CPLPRI
[M:MTK1]CPLCRG(I)       = [F]CPLCRG
[M:MTK1]MFOTRKFLG(I)    = [F]MFOTRKFLG
[M:MTK1]MFOEXTQTY(I)    = [F]EXTQTY
[M:MTK1]MFOCPLQTY(I)    = [F]CPLQTY
[M:MTK1]MFOREJQTY(I)    = [F]REJCPLQTY
[M:MTK1]MFOOKQTY(I)     = [M:MTK1]MFOCPLQTY(I) - [M:MTK1]MFOREJQTY(I)
[M:MTK1]TIMUOMCOD(I)    = [F]TIMUOMCOD
[M:MTK1]MFOESETTIM(I)   = [F]EXTSETTIM
[M:MTK1]MFOCSETTIM(I)   = [F]CPLSETTIM
[M:MTK1]MFOEOPETIM(I)   = [F]EXTOPETIM
[M:MTK1]MFOCOPETIM(I)   = [F]CPLOPETIM
[M:MTK1]CPLLAB(I)       = [F]EXTLAB
[M:MTK1]ROODES(I)       = [F]ROODES
[M:MTK1]SETLABCOE(I)    = [F]SETLABCOE
[M:MTK1]OPELABCOE(I)    = [F]OPELABCOE
# chargement des sections analytiques      (TB  21/03/00)
# reprise des sections de l'OF, si vide : initialisation selon paramétrage
For J = 1 To GNBDIE
      Call INISEC(WCCE,"MKO", J) From TRTX3CPT
      Assign "[M:MTK1]CCE"+num$(J)+"(I)" With WCCE
Next
# lecture poste main d'oeuvre pour section de valo (contenant les CCE)(18/09)
If [F]EXTLAB <> ""
 Read [MWS]WST0=[F]EXTLAB;[F]MFGFCY
 If !fstat
  For J = 1 To GNBDIE
      Call INISEC(WCCE,"MKOLAB",J) From TRTX3CPT
      Assign "[M:MTK1]LABCCE"+num$(J)+"(I)" With WCCE
  Next
 Endif
Endif

# FQ 63719 GA 04/2010 pb si le coeff est calculé entre la Qté article lancé et la qté opé prévue
If [M:MTK1]OPEWORCOE(I)<>1 & [F]EXTQTY <> 0
    # [M:MTK1]CPLQTY(I) contient  ([F]EXTQTY- [F]CPLQTY) / [M:MTK1]OPEWORCOE(I)
    [M:MTK1]COEFFPOND(I) = [M:MTK1]CPLQTY(I)/([F]EXTQTY/[M:MTK1]OPEWORCOE(I))

#Récup du coefficient pondérateur de la qté réalisée
# sr 07.04 demande 23562
Elsif [F]EXTQTY <> 0
    [M:MTK1]COEFFPOND(I) = [M:MTK1]CPLQTY(I)/[F]EXTQTY
    If [M:MTK1]COEFFPOND(I) = 0 : [M:MTK1]COEFFPOND(I) = 1 : Endif
Else
    [M:MTK1]COEFFPOND(I) = 1
Endif

#LECTURE SCHEDULING pour jalonnement, prochaine opé ...
 Read [F:SCH]SCH0 = [F]MFGNUM;[F]OPENUM;[F]OPESPLNUM
 If !fstat
     [M:MTK1]SCDCOD(I)     = [F:SCH]SCDCOD
     [M:MTK1]NEXOPENUM(I)  = [F:SCH]NEXOPENUM
     [M:MTK1]INFCAPSTR(I)  = [F:SCH]OPESTRDAT
     [M:MTK1]INFCAPEND(I)  = [F:SCH]OPEENDDAT
     [M:MTK1]MFGMST(I)     = [F:SCH]MFGMST
     If [M:MTK1]MFGMST(I)  = 2 :[M:MTK0]WOPEPROD   = 2 : Endif
 Endif
Filter [F:SCH] Where MFGNUM = [M:MTK1]MFGNUMOP(I) & NEXOPENUM = [M:MTK1]OPENUM(I)
Read [F:SCH]SCH0 First
If !fstat : [M:MTK1]OPEPREC(I) = [F:SCH]OPENUM : Endif
Filter [F:SCH]
Filter [F:TMA] Where USR = GUSER
Read [F:TMA]TMA1 First                    # 10.02 Performances
If !fstat : [M:MTK1]EMPNUM(I) = [F:TMA]EMPNUM : Endif
Filter [F:TMA]

GPOINT = "LOASUPMFO" : Gosub ENTREE From EXEFNC

Return

###############################################
$INIT_QTY
Local Integer LRET
Local Decimal WCOEFF
WCOEFF = [M:MTK1]WCOEFF
#Appelé en apres_modif de QTESUIVOPE
For I = 1 To [M:MTK1]NBOPE
# 04.02 demande 13793
#   If  [M:MTK1]CPLQTY(I-1) <> 0
       [M:MTK1]CPLQTY(I-1)  = [M:MTK1]MFOEXTQTY(I-1) * [M:MTK1]WCOEFF
       If [M:MTK1]OPEUOM(I-1) <> [M:MTK1]XOPEUOM(I-1)
          [M:MTK1]CPLQTY(I-1) = [M:MTK1]CPLQTY(I-1) / [M:MTK1]OPESTUCOE(I-1)
       Endif
       Call QTEARR([M:MTK1]CPLQTY(I-1),[M:MTK1]OPEUOM(I-1)) From TRTDIV
       [M:MTK1]WANCQTY(I-1) = [M:MTK1]CPLQTY(I-1)
       [M:MTK1]OKQTY(I-1)   = [M:MTK1]CPLQTY(I-1)
       Gosub CALC_TPS
       If [M:MTK1]DACMST(I-1) <> 1
           Raz LRET
           Call CONT_SOLDE_OPE([M:MTK0]MFGFCY,[M:MTK1]CPLWST(I-1),[M:MTK1]CPLQTY(I-1),[M:MTK1]EXTQTY(I-1),LRET) From MFGLIBO
           If LRET = 1 : [M:MTK1]CLEFLG(I-1) = 2
           Else          [M:MTK1]CLEFLG(I-1) = 1
           Endif
       Endif
       If [M:MTK1]DACMST(I-1) = 3
           Gosub REAJUST_CLEFLG
       Endif
#    Endif
Next I
If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2 & [F:MTS]CONSMAT <> 1
   Gosub REAJUST_MAT
Endif
If [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2
   Gosub REAJUST_ITM
Endif

If [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2
   Affzo [M:MTK2]10
Endif
If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2 & [F:MTS]CONSMAT <> 1
   Affzo [M:MTK3]15
Endif
Return

################################################
$REAJUST_CLEFLG
Local Integer J
#Ajustement du flag solde pour les opé suivie automatiquement
For J = 1 To I-1
    If [M:MTK1]OPEBORNE(J-1)   = [M:MTK1]OPENUM(I-1)
       [M:MTK1]CLEFLG(J-1)     = [M:MTK1]CLEFLG(I-1)
    Endif
Next
Return

################################################
$CALC_QTY
#Local Decimal WCOEFF
#Appelé en AM_CPLQTY,AM_REJCPLQTY si opé borne et si MTK1 = tableau
#
For I = 1 To NOL
        If [M:MTK1]OPEBORNE(I-1)   = [M:MTK1]OPENUM(NOL)
           Case WZONE
                When "CPLQTY" :
                     [M:MTK1]CPLQTY(I-1)    = ([M:MTK1]MFOEXTQTY(I-1)* WCOEFF) / [M:MTK1]OPEWORCOE(I-1)
#                     [M:MTK1]CPLQTY(I-1)    = ([M:MTK1]CPLQTY(NOL)*[M:MTK1]OPEWORCOE(NOL
                     Call QTEARR([M:MTK1]CPLQTY(I-1),[M:MTK1]OPEUOM(I-1)) From TRTDIV
                     Gosub CALC_TPS
                     If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2 & [F:MTS]CONSMAT <> 1
                          Gosub REAJUST_OPEMAT
                     Endif
                     If [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2 & [M:MTK1]MFGMST(NOL) = 2
                        Gosub REAJUST_ITM
                     Endif
                     [M:MTK1]CLEFLG(I-1)    = [M:MTK1]CLEFLG(NOL)
# CCC (2009-04-10) Bug 54310 : La quantité de rebut concernen uniquement l'opération en cours de saisie pour éviter de cumuler les qté rejetées
#                When "REJCPLQTY" :
#                     [M:MTK1]REJCPLQTY(I-1) = ([M:MTK1]MFOEXTQTY(I-1)*WCOEFF) / [M:MTK1]OPEWORCOE(I-1)
##                     [M:MTK1]REJCPLQTY(I-1) = ([M:MTK1]REJCPLQTY(NOL)*[M:MTK1]OPEWORCOE(NOL))/[M:MTK1]OPEWORCOE(I-1)
#                     Call QTEARR([M:MTK1]REJCPLQTY(I-1),[M:MTK1]OPEUOM(I-1)) From TRTDIV
           Endcase
        Endif
Next I
#
Affzo [M:MTK1]10
If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2 & [F:MTS]CONSMAT <> 1
    Affzo [M:MTK3]15
Endif
Return

################################################
$CALC_QTYB
Local Integer I,WNOL,J
#Appelé en validation saisie si opé borne et si MTO1= mode fiche
WNOL = find([M:MTO1]OPENUM, [M:MTK1]OPENUM(0..[M:MTK1]NBOPE-1)) - 1
#

For I = 1 To WNOL
        If [M:MTK1]OPEBORNE(I-1)   = [M:MTK1]OPENUM(WNOL)
           [M:MTK1]CPLQTY(I-1)     = ([M:MTK1]MFOEXTQTY(I-1)* WCOEFF)/[M:MTK1]OPEWORCOE(I-1)
#           [M:MTK1]CPLQTY(I-1)     = ([M:MTK1]CPLQTY(WNOL)*[M:MTK1]OPEWORCOE(WNOL))/[M:MTK1]OPEWORCOE(I-1)
           Call QTEARR([M:MTK1]CPLQTY(I-1),[M:MTK1]OPEUOM(I-1)) From TRTDIV
#           WCOEFF = [M:MTK1]CPLQTY(I-1)/([M:MTK1]MFOEXTQTY(I-1) / [M:MTK1]OPEWORCOE(I-1))
# llc 06.04 15812
#           [M:MTK1]CPLUNTTIM(I-1)  = [M:MTK1]CPLUNTTIM(I-1) * WCOEFF
           # FQ 42739 01/2008
           If [M:MTK1]ROOTIMCOD(I-1)<>3
              [M:MTK1]CPLOPETIM(I-1)  = [M:MTK1]CPLQTY(I-1) * [M:MTK1]CPLUNTTIM(I-1)
           Endif
           # 11.06 demande 38402
           [M:MTK1]CPLUNTTIM(I-1) = func TRTX3.ARRTYP("","","TIH",[M:MTK1]CPLUNTTIM(I-1))
           [M:MTK1]CPLOPETIM(I-1) = func TRTX3.ARRTYP("","","TIH",[M:MTK1]CPLOPETIM(I-1))
           Gosub CALC_TPS
           If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2 & [F:MTS]CONSMAT <> 1
               Gosub REAJUST_OPEMAT
           Endif
           If [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2 & [M:MTK1]MFGMST(I-1) = 2
              Gosub REAJUST_ITM
           Endif
           [M:MTK1]CLEFLG(I-1)    = [M:MTK1]CLEFLG(WNOL)

# CCC (2009-07-30) Bug 56869 : La quantité de rebut concerne uniquement l'opération en cours de saisie pour éviter de cumuler les qté rejetées
#           [M:MTK1]REJCPLQTY(I-1) = ([M:MTK1]MFOEXTQTY(I-1)* WCOEFF1)/[M:MTK1]OPEWORCOE(I-1)
##           [M:MTK1]REJCPLQTY(I-1) =([M:MTK1]REJCPLQTY(WNOL)*[M:MTK1]OPEWORCOE(WNOL))/[M:MTK1]OPEWORCOE(I-1)
#           Call QTEARR([M:MTK1]REJCPLQTY(I-1),[M:MTK1]OPEUOM(I-1)) From TRTDIV

           [M:MTK1]EMPNUM(I-1)    = [M:MTK1]EMPNUM(WNOL)
#           [M:MTK1]SCANUM(I-1)    = [M:MTK1]SCANUM(WNOL)
           [M:MTK1]MSGNUM(I-1)    = [M:MTK1]MSGNUM(WNOL)
       Endif
Next I
#
Affzo [M:MTK1]10
If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2 & [F:MTS]CONSMAT <> 1
    Affzo [M:MTK3]15
Endif
Return

################################################
#Appelé en après_modif des qtés à suivre ET
#en après_modif qté opé de prod
$REAJUST_ITM
Local Integer J, WRETOUR
For J = 0 To [M:MTK2]NBITM - 1


# Issue 65390 - 2010-06-16 by CCC : Calcul de la qté en fonction de l'UC qui a pu être saisie
#    [M:MTK2]UOMCPLQTY(J) = [M:MTK2]MFIUOMQTY(J) * WCOEFF
#    Call QTEARR([M:MTK2]UOMCPLQTY(J),[M:MTK2]UOM(J)) From TRTDIV
#    If [M:MTK2]UOMCPLQTY(J) >= [M:MTK2]UOMEXTQTY(J)
#       [M:MTK2]CLEFLG(J) = 2
#    Else
#       [M:MTK2]CLEFLG(J) = 1
#    Endif
#    [M:MTK2]CPLQTY(J)    = [M:MTK2]UOMCPLQTY(J) * [M:MTK2]UOMSTUCOE(J)
#    [M:MTK2]CPLQTY(J)    = [M:MTK2]UOMCPLQTY(J) * [M:MTK2]UOMSTUCOE(J)
#    Call QTEARR([M:MTK2]CPLQTY(J),[M:MTK2]STU(J)) From TRTDIV

    [M:MTK2]CPLQTY(J)    = [M:MTK2]MFIEXTQTY(J) * WCOEFF
    If [M:MTK2]UOMSTUCOE(J)<>0
        [M:MTK2]UOMCPLQTY(J) = [M:MTK2]CPLQTY(J) / [M:MTK2]UOMSTUCOE(J)
    Else
        Raz [M:MTK2]UOMCPLQTY(J)
    Endif
    Call QTEARR([M:MTK2]UOMCPLQTY(J),[M:MTK2]UOM(J)) From TRTDIV

    [M:MTK2]CPLQTY(J)    = [M:MTK2]UOMCPLQTY(J) * [M:MTK2]UOMSTUCOE(J)
    Call QTEARR([M:MTK2]CPLQTY(J),[M:MTK2]STU(J)) From TRTDIV

    If [M:MTK2]CPLQTY(J) >= [M:MTK2]EXTQTY(J)
       [M:MTK2]CLEFLG(J) = 2
    Else
       [M:MTK2]CLEFLG(J) = 1
    Endif

    #Tentative de saisie rapide
     Call DELSTOENTW(J,J,"MTK2",1,1,[M:MTK0]MFGFCY,1,"") From STKENT
     Call STJSTOENTW("MTK2",5,15,[M:MTK0]MFGTRKDAT,J,[M:MTK2]NBITM,"MTS",3,WRETOUR) From STKENT

    # Issue 87766 - 2013-02-21 by CCC
    If [M:MTK2]WSTOSEQ(J)=0 | !find([M:MTK2]WSTOSEQ(J),[M:ENTW]WSTOSEQ)
        Raz [M:MTK2]WLOCSEQ(J)
    Endif

    # CCC (12/03/08) Bug 46178
    Call REAJUSTITMMAT([M:MTK2]MFGLIN(J),WCOEFF)
Next J
Return

################################################
# CCC (12/03/08) Bug 46178
Subprog REAJUSTITMMAT(WMFGLIN,WCOEFF)
Value Integer WMFGLIN
Value Decimal WCOEFF
    Gosub REAJUST_ITMMAT
End

################################################
$REAJUST_OPEMAT
Local Integer J, LRET, WLIG
# 10.01 demande 11203
# 11.06 demande38605
#Local Decimal WTOTUSEQTY, LDIS
Local Decimal LDIS

#Réajustement de la qté consommée de la matière si modif opé et si mat sans no de série et
#pas au forfait
#[F:MTS]CONSMAT     = Mode de consommation matière
#                 1 = Immédiate ( donc on ne change rien)
#                 2 = Progressive selon qté prévu(donc on ne dépasse pas)
#                 3 = Progressive selon qte produite(donc on réajuste toujours)
#On ne réajuste pas si la matière DOIT être suivie manuellement ou qté prévue = 0
#On tient compte du paramètre "stock négatif autorisé"
# 05.03 avertir si une ligne n'a pas été réajustée demande 18344
Local Integer WNO_REAJUST, WNO_AUTO
Raz WNO_REAJUST, WNO_AUTO
For J = 0 To [M:MTK3]NBMAT-1
          If [M:MTK3]OPENUM(J) = [M:MTK1]OPENUM(I-1) & [M:MTK3]SERMGTCOD(J) = 1 &
&                                [M:MTK3]LIKQTYCOD(J) <> 2 & ([M:MTK3]USEQTY(J) <> 0 | [F:MTS]CONSMAT = 3) &
&                                [F:MTS]CONSMAT <> 1
             If [F:MTS]CONSMAT = 2
                If [M:MTK3]MFMEXTQTY(J) * WCOEFF <= [M:MTK3]RETQTY(J)
                   [M:MTK3]USEQTY(J) = [M:MTK3]MFMEXTQTY(J) * WCOEFF
                   Call QTEARR([M:MTK3]USEQTY(J),[M:MTK3]STU(J)) From TRTDIV
                   [M:MTK3]WANCQTY(J) = [M:MTK3]USEQTY(J)
                Endif
             Else
                [M:MTK3]USEQTY(J) = [M:MTK3]MFMEXTQTY(J) * WCOEFF
                Call QTEARR([M:MTK3]USEQTY(J),[M:MTK3]STU(J)) From TRTDIV
                [M:MTK3]WANCQTY(J) = [M:MTK3]USEQTY(J)
             Endif
             Raz LRET
             WLIG = J
             Call DELSTOSORW(J, J,"MTK3",[M:MTK0]MFGFCY,LRET) From STKSOR
             Gosub RAZMULTIVAL
             Gosub TRT_STOCKLIGNE
#             # 10.01 la qté consommée à utiliser est la somme de ce qui a déjà été
#             # consommé et de ce qui va l'être demande 11203
#             WTOTUSEQTY = [M:MTK3]USEQTY(J) + [M:MTK3]MFMUSEQTY(J)
#             Call CONT_SOLDE_MAT([M:MTK0]MFGFCY,[M:MTK3]MATITMREF(J),WTOTUSEQTY,[M:MTK3]MFMEXTQTY(J),LRET) From MFGLIBM
#             If LRET = 0 : [M:MTK3]CLEFLG(J) = 1
#             Else        : [M:MTK3]CLEFLG(J) = 2
#             Endif
          Endif
Next J
# 05.03 avertir si une ligne n'a pas été réajustée demande 18344
If WNO_REAJUST = 1
   Call MESSAGE(mess(234,190,1)) From GESECRAN
Endif
Return

##########################################
$REAJUST_ITMMAT
#Réajustement de la qté consommée de la matière si modif art lancé et si mat sans no de série et
#pas au forfait
#[F:MTS]CONSMAT     = Mode de consommation matière
#                 1 = Immédiate ( donc on ne change rien)
#                 2 = Progressive selon qté prévu(donc on ne dépasse pas)
#                 3 = Progressive selon qte produite(donc on réajuste toujours)
#On ne réajuste pas si la matière DOIT être suivie manuellement
#On tient compte du paramètre "stock négatif autorisé"
#On ne réajuste que les matières liées à l'article lancé  08.01 demande 10269
Local Integer J, LRET, WLIG
# 10.01 demande 11203
# 07.02 Modification du filtre demande 14910
# 11.06 demande38605
#Local Decimal WTOTUSEQTY, LDIS
Local Decimal LDIS

# 05.03 avertir si une ligne n'a pas été réajustée demande 18344
Local Integer WNO_REAJUST, WNO_AUTO
Raz WNO_REAJUST, WNO_AUTO

For J = 0 To [M:MTK3]NBMAT-1
          If [M:MTK3]LIKQTYCOD(J) <> 2  &
&            [M:MTK3]MFGLIN(J) = WMFGLIN & [F:MTS]CONSMAT <> 1
             # Si le suivi opératoire est présent on ne réajuste que les matières sans numéro d'opé
             If [M:MTK0]OPETRKFLG <> 2 | [M:MTK3]OPENUM(J) = 0
                 If [F:MTS]CONSMAT = 2
                    If [M:MTK3]MFMEXTQTY(J) * WCOEFF <= [M:MTK3]RETQTY(J)
                       [M:MTK3]USEQTY(J) = [M:MTK3]MFMEXTQTY(J) * WCOEFF
                       Call QTEARR([M:MTK3]USEQTY(J),[M:MTK3]STU(J)) From TRTDIV
                       [M:MTK3]WANCQTY(J) = [M:MTK3]USEQTY(J)
                    Endif
                 Else
                     [M:MTK3]USEQTY(J) = [M:MTK3]MFMEXTQTY(J) * WCOEFF
                     Call QTEARR([M:MTK3]USEQTY(J),[M:MTK3]STU(J)) From TRTDIV
                    [M:MTK3]WANCQTY(J) = [M:MTK3]USEQTY(J)
                 Endif
                 Raz LRET
                 WLIG = J
                 Call DELSTOSORW(J, J,"MTK3",[M:MTK0]MFGFCY,LRET) From STKSOR
                 Gosub RAZMULTIVAL
                 Gosub TRT_STOCKLIGNE
#                 # 10.01 la qté consommée à utiliser est la somme de ce qui a déjà été
#                 # consommé et de ce qui va l'être demande 11203
#                 WTOTUSEQTY = [M:MTK3]USEQTY(J) + [M:MTK3]MFMUSEQTY(J)
#                 Call CONT_SOLDE_MAT([M:MTK0]MFGFCY,[M:MTK3]MATITMREF(J),WTOTUSEQTY,[M:MTK3]MFMEXTQTY(J),LRET) From MFGLIBM
#                 If LRET = 0 : [M:MTK3]CLEFLG(J) = 1
#                 Else        : [M:MTK3]CLEFLG(J) = 2
#                 Endif
             Endif
          Endif
Next J
# 05.03 avertir si une ligne n'a pas été réajustée demande 18344
If WNO_REAJUST = 1
   Call MESSAGE(mess(234,190,1)) From GESECRAN
Endif
Return

##########################################
$CALC_TPS
If [M:MTK1]ROOTIMCOD(I-1) <> 3    : # FQ 42739 01/2008 sauf temps forfaitaire
   #Ajustement du tps réalisé opé
   [M:MTK1]CPLOPETIM(I-1) = [M:MTK1]CPLQTY(I-1)*[M:MTK1]CPLUNTTIM(I-1)
   # Issue 88551 & 88561 - 2013-03-14 by CCC
   If [M:MTK1]ROOTIMCOD(I-1) = 2
        # GH 08/10/2014 bug 101352
        #[M:MTK1]CPLOPETIM(I-1) = [M:MTK1]CPLQTY(I-1) / [M:MTK1]CAD(I-1) / ([M:MTK1]EFF(I-1) / 100)
        [M:MTK1]CPLOPETIM(I-1) = [M:MTK1]CPLQTY(I-1) * [M:MTK1]OPEWORCOE(I-1) / [M:MTK1]CAD(I-1) / ([M:MTK1]EFF(I-1) / 100)
   Endif
Endif
# 11.06 demande 38402
[M:MTK1]CPLOPETIM(I-1) = func TRTX3.ARRTYP("","","TIH",[M:MTK1]CPLOPETIM(I-1))
Return

##########################################
$SUP_OPE
#Appelé si exclusion d'une opération borne
For I = 1 To NOL
        If [M:MTK1]OPEBORNE(I-1)   = [M:MTK1]OPENUM(NOL)
           [M:MTK1]CPLQTY(I-1)     = 0
           [M:MTK1]MODIFLG(I-1)    = 1
           If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2 & [F:MTS]CONSMAT <> 1
              Gosub SUP_MAT
           Endif
        Endif
Next
Return

#########################################
$REACTIVE_OPE
#Appelé si réactivation d'une opération borne
For I = 1 To NOL
        If [M:MTK1]OPEBORNE(I-1)   = [M:MTK1]OPENUM(NOL)
           [M:MTK1]CPLQTY(I-1)     = [M:MTK1]WANCQTY(NOL)
           [M:MTK1]MODIFLG(I-1)    = 0
           If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2 & [F:MTS]CONSMAT <> 1
               Gosub REACTIV_MAT
           Endif
       Endif
Next
Return

##########################################
$SUP_MAT
Local Integer J, WRET
If GCUMMAT = 3 : Return : Endif
For J = 1 To [M:MTK3]NBMAT
    If [M:MTK3]OPENUM(J-1)= [M:MTK1]OPENUM(I-1)
       [M:MTK3]USEQTY(J-1) = 0
       Call DELSTOSORW(J-1,J-1,"MTK3",[M:MTK0]MFGFCY,WRET) From STKSOR   # Issue 73263 - 2011-04-18 by CCC : Mise à jour de SOW
    Endif
Next J
Return

##########################################
$REACTIV_MAT
Local Integer J
If GCUMMAT = 3 : Return : Endif
For J = 1 To [M:MTK3]NBMAT
    If [M:MTK3]OPENUM(J-1) = [M:MTK1]OPENUM(I-1)
       [M:MTK3]USEQTY(J-1) = [M:MTK3]WANCQTY(J-1)
    Endif
Next J
Gosub REAJUST_OPEMAT From SUBMTKB  # Issue 73263 - 2011-04-18 by CCC : Mise à jour de SOW
Return

###################################################################
Subprog CHARG_ITM(WMFGNUM,WVALEUR,WORI)
Value Char    WMFGNUM :# Numéro OF
Value Decimal WVALEUR :# Qté à suivre renseigné que si on vient de AP_QTESUIVITM(SUBMTK2)
Value Integer WORI    :# Pour savoir si on vient de AP_QTESUIVITM (WORI = 2) ou non
Local Integer N, OK
Local Decimal WRAPPORT
# 10.02 demande 16175
Local Char CRITERE(250)
Raz CRITERE
#Chargement dans l'écran MTK2 des articles lancés
N = 0
If [F:MFG]ITMLINNBR > 1 : [M:MTK2]UL = [F:MFG]STU : Endif

# 10.02 demande 16175
CRITERE =  "1=1"
CRITERE -= "& MFGNUM ='"+WMFGNUM+"'"
# point d'entrée ajout de critères de filtres
GPOINT = "MFIFLT" : Gosub ENTREE From EXEFNC

For [F:MFI] Where evalue(CRITERE)
#on ne prend pas les articles exclus
    If [F:MFI]ITMSTA <> 4
        If [F:ITM]ITMREF <> [F:MFI]ITMREF
            Read [F:ITM]ITM0 = [F:MFI]ITMREF
            If fstat : Raz [F:ITM] : Endif
        Endif
        If [F:ITF]STOFCY <> [M:MTK0]MFGFCY | [F:ITF]ITMREF <> [F:MFI]ITMREF
            Read [F:ITF]ITF0 = [F:MFI]ITMREF;[M:MTK0]MFGFCY
            If fstat : Raz [F:ITF] : Endif
        Endif

    # Issue 65478 - 2010-07-08 by CCC : Contrôle existence fiche article-dépôt
        If clalev([F:ITW])
&        & dim([M:MTK0]WRHE)>0 & [M:MTK0]WRHE<>"" & GWRHOBY=2
&        & ([F:ITW]ITMREF<>[F:ITM]ITMREF | [F:ITW]WRH<>[M:MTK0]WRHE)
            Read [F:ITW]ITW0=[F:ITM]ITMREF;[M:MTK0]WRHE
            If fstat
                Call ERREUR(mess(978,196,1)-":"-[F:ITM]ITMREF+";"+[M:MTK0]WRHE) From GESECRAN
                Raz [F:ITW], [F:ITM], [F:ITF]
            Endif
        Endif

        If [F:ITF]ITMREF<>""
            WRAPPORT = [F:MFI]EXTQTY / [F:MFG]EXTQTY

            Gosub CHARG_MTK2

           #--- Contrôle date entrée par rapport aux dates mouvements en attente
            If [F:ITF]STOMGTCOD>1
                Local Date    LDATRUP
                Local Decimal LQTYRUP
                Call CTLRUP([M:MTK0]MFGFCY,[M:MTK2]ITMREF(N-1),[M:MTK0]MFGTRKDAT,1,
&                           LDATRUP,LQTYRUP) From STKLIB
            Endif
           #---
        Endif
    Endif
Next
[M:MTK2]NBITM = N
End

#####################################""
$CHARG_MTK2
Local Integer J, WRETOUR, WNOL
Local Char    WCCE(15)
If [M:MTK2]UL = "" [M:MTK2]UL = [F:MFI]STU : Endif
[M:MTK2]PRODTYP(N)   = 1
[M:MTK2]MFGNUMIT(N)  = [F:MFI]MFGNUM
[M:MTK2]ITMREF(N)    = [F:MFI]ITMREF
[M:MTK2]ITMTYP(N)    = [F:MFI]ITMTYP                            # llc 05.00 sous-produit
[M:MTK2]ITMLIN(N)    = [F:MFI]ITMLIN                            # llc 05.00 sous-produit
[M:MTK2]LIKQTYCOD(N) = [F:MFI]LIKQTYCOD                         #     03.05 sous-produit
If [M:MTK2]ITMTYP(N) = 0 : [M:MTK2]ITMTYP(N) = 1 : Endif        #     05.00 sous-produit
#[M:MTK2]ITMDES1(N)   = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MTK2]ITMDES1(N), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:MTK2]QUAFLG(N)    = [F:ITF]QUAFLG                            # hcb V6CQ
[M:MTK2]CSTFLG(N)    = [F:MFI]CSTFLG                            # ccc 020209 sous-produit

[M:MTK2]UOM(N)       = [F:MFI]UOM
If [F:MFI]UOMSTUCOE <> 0
   [M:MTK2]UOMEXTQTY(N) = ([F:MFI]RMNEXTQTY / [F:MFI]UOMSTUCOE)
Else
   [M:MTK2]UOMEXTQTY(N) = [F:MFI]RMNEXTQTY
Endif
# 04.02 demande 13793
#If WVALEUR <> 0
If GREP = "C" & [M:MTK0]MFGTRKNUM = ""
    If WORI = 2
        Case [F:MFG]ITMLINNBR
             When 1       : [M:MTK2]UOMCPLQTY(N) = WVALEUR * WRAPPORT
             When Default : [M:MTK2]UOMCPLQTY(N) = (WVALEUR / [F:MFI]UOMSTUCOE) * WRAPPORT
        Endcase
        Call QTEARR([M:MTK2]UOMCPLQTY(N),[M:MTK2]UOM(N)) From TRTDIV
    Else
       [M:MTK2]UOMCPLQTY(N)     = [M:MTK2]UOMEXTQTY(N)
    Endif

    # 04.02 demande 13793
    #Else
    #   [M:MTK2]UOMCPLQTY(N)     = [M:MTK2]UOMEXTQTY(N)
    #Endif
   If [M:MTK2]UOMCPLQTY(N)  >= [M:MTK2]UOMEXTQTY(N) | [F:MFI]MFITRKFLG > 4
                               [M:MTK2]CLEFLG(N)     = 2
   Else
                               [M:MTK2]CLEFLG(N)     = 1
   Endif
Else
   Case [F:MFI]MFITRKFLG
        When 3,4     : [M:MTK2]CLEFLG(N) = 1
        When Default : [M:MTK2]CLEFLG(N) = 2
   Endcase
Endif
[M:MTK2]WANCQTY(N)       = [M:MTK2]UOMCPLQTY(N)
[M:MTK2]UOMSTUCOE(N)     = [F:MFI]UOMSTUCOE
[M:MTK2]STU(N)           = [F:MFI]STU
[M:MTK2]CPLQTY(N)        = [F:MFI]RMNEXTQTY
[M:MTK2]EXTQTY(N)        = [F:MFI]RMNEXTQTY
[M:MTK2]CPLQTY(N)        = [M:MTK2]UOMCPLQTY(N) * [M:MTK2]UOMSTUCOE(N)
Call QTEARR([M:MTK2]CPLQTY(N),[M:MTK2]STU(N)) From TRTDIV
[M:MTK2]MFGLIN(N)        = [F:MFI]MFGLIN
[M:MTK2]PJT(N)           = [F:MFI]PJT
[M:MTK2]FMI(N)           = [F:MFI]FMI
[M:MTK2]MFIEXTQTY(N)     = [F:MFI]EXTQTY
[M:MTK2]MFICPLQTY(N)     = [F:MFI]CPLQTY - [F:MFI]REJCPLQTY - [F:MFI]QUACPLQTY
[M:MTK2]MFIREJQTY(N)     = [F:MFI]REJCPLQTY
[M:MTK2]MFIQUAQTY(N)     = [F:MFI]QUACPLQTY
[M:MTK2]MFITOTQTY(N)     = [F:MFI]CPLQTY
[M:MTK2]MFIRMNQTY(N)     = [F:MFI]RMNEXTQTY
[M:MTK2]MFIUOMQTY(N)     = [F:MFI]UOMEXTQTY
If dim([M:MTK2]LOT) > 0: [M:MTK2]LOT(N) = [F:MFI]LOT  : Endif
[M:MTK2]SERMGTCOD(N)     = [F:ITM]SERMGTCOD
#
# 05.06 demande 36126
#Case [F:ITM]QUAFLG
#     When 1 : [M:MTK2]STA(N) = "A"
#     When 2 : [M:MTK2]STA(N) = "Q"
#     When 3 : [M:MTK2]STA(N) = "Q"
#Endcase

# Issue 107513/8 - 2015-07-13 by JUSYN : ECC - Major and minor version
If dim([M:MTK2]ECCVALMAJ(N)) > 0
    [M:MTK2]ECCVALMAJ(N)       = [F:MFI]ECCVALMAJ
    [M:MTK2]ECCVALMAJORI(N)    = [F:MFI]ECCVALMAJ
    [M:MTK2]ECCVALMIN(N)       = [F:MFI]ECCVALMIN
    [M:MTK2]ECCVALMINORI(N)    = [F:MFI]ECCVALMIN
    [M:MTK2]ECCSAIFLG(N)       = 9 # version number is not modifiable
Endif

# 10.05 point d'entrée pour charger des zones spécifiques demande 32753
GPOINT = "LOASUPMFI" : Gosub ENTREE From EXEFNC
If [M:MTK0]MFGTRKNUM = ""
    Default Mask [MTK2]
    Call INIZONENT([M:MTK2]ITMREF(N),"MTK2",[M:MTK0]MFGFCY,"",0,"U",N,5,[M:MTK0]TRSCOD,[M:MTK2]MFGNUMIT(N),3,1) From STKECR

    # car RAZ dans INIZONENT
    If dim([M:MTK2]LOT) > 0: [M:MTK2]LOT(N) = [F:MFI]LOT  : Endif

    # Issue 113021 - 2015-12-09 by GH : to increment the sub-lot number
    If dim([M:MTK2]SLO)>0 & [M:MTK2]LOT(N)<>""
       Raz [M:MTK2]SLO(N)
       Call STKAMLOT([M:MTK2]LOT(N),"MTK2",N,[M:MTK2]ITMREF(N),"SLO") From STKACT
    Endif

    # Issue 107513/8 - 2015-07-13 by JUSYN : ECC - Major and minor version after RAZ in INIZONENT
    If dim([M:MTK2]ECCVALMAJ(N)) > 0
        [M:MTK2]ECCVALMAJ(N)       = [F:MFI]ECCVALMAJ
        [M:MTK2]ECCVALMIN(N)       = [F:MFI]ECCVALMIN
    Endif

    status=0
    Call STJSTOENTW("MTK2",5,15,[M:MTK0]MFGTRKDAT,N,[M:MTK2]NBITM,"MTS",3,WRETOUR) From STKENT

    # Issue 87766 - 2013-02-21 by CCC
    If [M:MTK2]WSTOSEQ(N)=0 | !find([M:MTK2]WSTOSEQ(N),[M:ENTW]WSTOSEQ)
        Raz [M:MTK2]WLOCSEQ(N)
    Endif
Endif


# chargement des sections analytiques      (TB  21/10/99)
# reprise des sections de l'OF, si vide : initialisation selon paramétrage
#Chargement des section ana
 Call CHARG_ACCCCE(N,"","","[M:MTK2]CCE",
&                    "MFI",0,[F:MFI]MFGNUM,[F:MFI]MFGLIN,0,"") From TRTX3CPT

For J = 1 To GNBDIE    :# (on ne vient pas d'une boucle affectant déjà J)
   If evalue ("[M:MTK2]CCE"+num$(J)+"(N)") =""
      Call INISEC(WCCE,"MKI", J) From TRTX3CPT
      Assign "[M:MTK2]CCE"+num$(J)+"(N)" With WCCE
  Endif
Next

[M:MTK2]ITMTRKLIN(N) = N+1
N+= 1
Return

###################################################################
Subprog CHARG_MAT(WMFGNUM,WFILTRE,WCOEFF,WVALEUR)
Value Char    WMFGNUM :#numéro OF
Value Integer WFILTRE :#filtre non soldé/soldé/toutes
Value Decimal WCOEFF  :#coeff pondérateur renseigné que si on vient de AP_QTESUIVITM(SUBMTK2)
Value Decimal WVALEUR :#qté à suivre renseigné que si on vient de AP_QTESUIVITM(SUBMTK2)
Local Char CRITERE(250)
Local Integer M, WCUNFLG, LRET, WRUP, WLIG
Local Integer CAS

If WCOEFF=-1 & WVALEUR=0 : WCOEFF=0 : CAS=1 : Endif : # GH 16/10/12 bug 81005

# 08.03 avertir si une ligne n'a pas été réajustée demande 19283
Local Integer WNO_REAJUST, WNO_AUTO
Raz WNO_REAJUST, WNO_AUTO

Raz CRITERE
#Chargement dans l'écran MTK3 des matières à suivre selon filtre
CRITERE =  "CPNTYP <> 5"
CRITERE -= "& MFGNUM ='"+WMFGNUM+"'"
Case WFILTRE
     When 1 : CRITERE -= " & MFMTRKFLG <"+num$(5)
     When 2 : CRITERE -= " & MFMTRKFLG >"+num$(4)
Endcase
#On doit pouvoir suivre les matières à sous-traiter. Vu avec LLC 160399
#CRITERE -= "& SCOFLG <>"+ num$(2)
#Endif

# point d'entrée ajout de critères de filtres
GPOINT = "MFMFLT" : Gosub ENTREE From EXEFNC
#
Filter [F:MFM] Where evalue(CRITERE)
M = 0
For [F:MFM]
    Raz WCUNFLG
#on ne prend pas les matières exclues
   If [F:MFM]MATSTA <> 4
        If ([F:MFM]BOMOPE>=[M:MTK3]WOPE1 & [F:MFM]BOMOPE<=[M:MTK3]WOPE2) | [F:MFM]BOMOPE = 0
        # 12.02 demande 16889 tester aussi l'égalité sur l'OF !!!
        If [F:MFO]OPENUM <> [F:MFM]BOMOPE  | [F:MFO]MFGNUM <> [F:MFM]MFGNUM
           Filter [F:MFO] Where MFGNUM = [F:MFM]MFGNUM & OPENUM = [F:MFM]BOMOPE
           Read [F:MFO]MFO0 First
           If fstat : Raz [F:MFO]: Endif
        Endif
        # 12.02 Si pas d'opé sur la ligne matière on vide le buffer MFO
        If [F:MFM]BOMOPE = 0 : Raz [F:MFO] : Endif
         If [F:ITM]ITMREF <> [F:MFM]ITMREF
           Read [F:ITM]ITM0 = [F:MFM]ITMREF
           If fstat : Raz [F:ITM] : Endif
         Endif
        If [F:ITF]STOFCY <> [M:MTK0]MFGFCY | [F:ITF]ITMREF <> [F:MFM]ITMREF
           Read [F:ITF]ITF0 = [F:MFM]ITMREF;[M:MTK0]MFGFCY
           If fstat : Raz [F:ITF] : Endif
        Endif
#Si article en inventaire on regarde si il y a des emplacements libérés
        If [F:ITF]CUNFLG = 2
            If [F:MFM]ALLSTA > 3
               Gosub REC_LOC
            Else
                # 04.02 Problèmes Perf
                Filter [F:STO] Where STOFCY = [F:ITF]STOFCY & ITMREF = [F:ITF]ITMREF & CUNLOKFLG = 1
&                              Order By Key STO3
                Read [F:STO]STO3 First
                If fstat WCUNFLG = 2 : Endif
                Filter [F:STO]
            Endif
        Endif
#On ne prend pas les matières en inventaire ou dont le mode de destokage ne convient pas
#        If [F:ITF]CUNFLG <> 2 &  ([M:MTK3]STOCOD = 3 | [F:ITF]STOCOD = [M:MTK3]STOCOD)
        If  WCUNFLG <> 2
            If ([M:MTK3]STOCOD = 3 | [F:ITF]STOCOD = [M:MTK3]STOCOD)
                Gosub CHARG_MTK3
            Endif
        Else  # CCC (2010-01-15) DM 59082 : Informer sur le fait que l'article est en inventaire
            Call MESSAGE([F:ITF]ITMREF-":"-mess(185,199,1)) From GESECRAN
        Endif
    Endif
   Endif
   Filter [F:MFO]
Next
[M:MTK3]NBMAT = M
Filter [F:MFM]

# Stock 1.4.0. on est obligé de le faire à la fin car si cumul des matières au suivi, la quantité des lignes n'est connue
# qu'à la fin du chargement
If GREP = "C"
    For WLIG = 0 To [M:MTK3]NBMAT-1
        Gosub TRT_STOCKLIGNE
#        WTOTUSEQTY = [M:MTK3]USEQTY(WLIG) + [M:MTK3]MFMUSEQTY(WLIG)
#        Call CONT_SOLDE_MAT([M:MTK0]MFGFCY,[M:MTK3]MATITMREF(WLIG),WTOTUSEQTY,[M:MTK3]MFMEXTQTY(WLIG),LRET) From MFGLIBM
#        If LRET = 0 : [M:MTK3]CLEFLG(WLIG) = 1
#        Else        : [M:MTK3]CLEFLG(WLIG) = 2
#        Endif
    Next
Endif

#----------------------------------------#
# Tri du tableau sur                     #
#                             Article    #
#    ou             Opération/article    #
#    ou   date de réservation/article    #
#----------------------------------------#
# 03.05 demande 29069 point d'entrée tri spécifique
# Positionner GPE à 1 si on ne veut pas du tri standard
GPE = 0
GPOINT = "CUSSRT" : Gosub ENTREE From EXEFNC
If GPE = 0
    # llc 12.01 ajout du tri séquence/article 11591
    Case [F:MTS]SORTITM
        When 1 : Sorta [M:MTK3]NBMAT [M:MTK3]NBMAT Order By [M:MTK3]MATITMREF(indice),
&                                                       [M:MTK3]BOMSEQ(indice)
        When 2 : Sorta [M:MTK3]NBMAT [M:MTK3]NBMAT Order By [M:MTK3]OPENUM(indice),
&                                                       [M:MTK3]MATITMREF(indice)
        When 3 : Sorta [M:MTK3]NBMAT [M:MTK3]NBMAT Order By [M:MTK3]RETDAT(indice),
&                                                       [M:MTK3]MATITMREF(indice)
        When 4 : Sorta [M:MTK3]NBMAT [M:MTK3]NBMAT Order By [M:MTK3]BOMSEQ(indice),
&                                                       [M:MTK3]MATITMREF(indice)
    Endcase
Endif
Filter [F:MFM]

If WNO_REAJUST = 1 : GMESSAGE = mess(234,190,1)
Else               : Raz GMESSAGE
Endif

If WNO_AUTO = 1
    # Retrait manuel strict : La détermination auto n’a pu se faire sur les articles dont le mode de retrait est immédiat
    GMESSAGE = mess(252,190,1)
Endif
End

######################
#chargement d'une matière dans le tableau
#Soit une ligne par enr MFGMAT soit une ligne par matière selon paramètre général
$CHARG_MTK3
Local Integer J,K,L, WFIND, LRET
# 10.01 demande 11203
Local Decimal WUSEQTY,WRETQTY,WTOTUSEQTY, LDIS, WALLQTY, WALLQTYSHT
Local Char    WCCE(15)
#En création :
#Pas de cumul des matières si paramètre à NON ou  cumul au lancement ou
#si gestion des numéros de série ou si mode de retrait de stock
#de la matière = MANUEL et code transaction = MANUEL STRICT
#En visu-modif
#On ne cumule que si le flag CUMMATSUI de MKM est = 1
If GCUMMAT <> 3 | [F:ITM]SERMGTCOD <> 1 |([F:ITF]STOCOD = 1 & [F:MTS]STOCODMAN = 2)
  Gosub CHARG_LIGNE
Else
  If GREP = "C" | [F:MKM]CUMMATSUI = 1
     Raz J,K,WFIND
     While J < M
           K = find ([F:MFM]ITMREF,[M:MTK3]MATITMREF(J..M))
           If K
              Raz WRETQTY,WUSEQTY
              If  [M:MTK3]OPENUM(J+(K-1))  = [F:MFM]BOMOPE
                  If [F:MFM]MFMTRKFLG <> 5
                      WRETQTY = [F:MFM]RETQTY - [F:MFM]USEQTY
                      If WRETQTY < 0 : WRETQTY = 0 : Endif
                      WUSEQTY = WRETQTY
                      If [F:MTS]OPETRKFLG <> 1 & [F:MTS]CONSMAT <> 1
                         L = find([M:MTK3]OPENUM(J+(K-1)),[M:MTK1]OPENUM(0..[M:MTK1]NBOPE-1))
                         If L
                             If [F:MTS]CONSMAT = 2
                                # 06.03 demande 18521
                                If [M:MTK1]CPLQTY <> 0
                                    WUSEQTY  = min([F:MFM]RETQTY * [M:MTK1]COEFFPOND(L-1),WRETQTY)
                                Endif
                            Else
                                 # 06.03 demande 18521
                                If [M:MTK1]CPLQTY(L-1) <> 0
                                    WUSEQTY  = [F:MFM]RETQTY * [M:MTK1]COEFFPOND(L-1)
                                Endif

                            Endif

                         Endif
                      Elsif [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2
                             If WVALEUR <> 0
                               If [F:MTS]CONSMAT = 2
                                    WUSEQTY = min([F:MFM]RETQTY * WCOEFF,WRETQTY)
                                Else
                                    WUSEQTY = [F:MFM]RETQTY * WCOEFF
                                Endif
                                Call QTEARR([M:MTK3]USEQTY(J+(K-1)),[M:MTK3]STU(J+(K-1))) From TRTDIV
                             Endif
                      Endif
                      [M:MTK3]RETQTY(J+(K-1)) += WRETQTY
                      [M:MTK3]USEQTY(J+(K-1)) += WUSEQTY
                  Endif
                  [M:MTK3]WANCQTY(J+(K-1))    = [M:MTK3]USEQTY(J+(K-1))
                  [M:MTK3]MFMEXTQTY(J+(K-1)) += [F:MFM]RETQTY
                  [M:MTK3]MFMUSEQTY(J+(K-1)) += [F:MFM]USEQTY
                  If find([F:MFM]ALLSTA,4,5)
                      [M:MTK3]MFMALLQTY(J+(K-1)) += [F:MFM]ALLQTY
                  Elsif find([F:MFM]ALLSTA,2,3)
                      [M:MTK3]GLOALLQTY(J+(K-1)) += [F:MFM]ALLQTY
                      [M:MTK3]MFMALLQTY(J+(K-1)) += [F:MFM]ALLQTY   # Issue 74190 - 2011-06-06 by CCC
                  Endif
                  [M:MTK3]MFMSHTQTY(J+(K-1)) += [F:MFM]SHTQTY
                  If [M:MTK3]ALLSTA(J+(K-1)) <> [F:MFM]ALLSTA
                     Raz [M:MTK3]ALLSTA(J+(K-1))
                  Endif

                # FQ 63162 GA 04/2010 proposer LOT,LOC,STA si renseignés
                  If [M:MTK3]LOTPREF(J+(K-1))="" & [F:MFM]LOT<>""
                     [M:MTK3]LOTPREF(J+(K-1))  = [F:MFM]LOT
                  Endif
                  If [M:MTK3]LOCPREF(J+(K-1))="" & [F:MFM]LOC<>""
                     [M:MTK3]LOCPREF(J+(K-1))  = [F:MFM]LOC
                     If dim([M:MTK3]LOC) > 0
                        [M:MTK3]LOC(J+(K-1))   = [F:MFM]LOC
                     Endif
                  Endif
                  If [M:MTK3]STAPREF(J+(K-1))="" & [F:MFM]STA<>""
                     [M:MTK3]STAPREF(J+(K-1))  = [F:MFM]STA
                     [M:MTK3]STA(J+(K-1))      = [F:MFM]STA
                  Endif

                  [M:MTK3]WALLMULT(J+(K-1))    = 2
                  [M:MTK3]CUMMATSUI(J+(K-1))   = 1
                  [M:MTK3]MFGLIN(J+(K-1))      = 0
                  J = M : WFIND = 1
              Else J+=K : K= 0
              Endif
           Else J = M  : WFIND = 0
           Endif
      Wend
      If WFIND = 0 : Gosub CHARG_LIGNE : Endif
    Else : Gosub CHARG_LIGNE
    Endif
Endif
Return

#####################
#chargement d'une ligne du tableau et incrémentation de M
$CHARG_LIGNE

[M:MTK3]ADDTRK(M)       = 1
[M:MTK3]MKMTEX(M)       = [F:MFM]MFMTEX
[M:MTK3]MATTYP(M)       = 1
[M:MTK3]CPNTYP(M)       = 1                    : # GH 13/11/13 bug 93232
[M:MTK3]MFGNUMMA(M)     = [F:MFM]MFGNUM
[M:MTK3]MATITMREF(M)    = [F:MFM]ITMREF
[M:MTK3]MFMITMREF(M)    = [F:MFM]ITMREF
[M:MTK3]MFMEXTQTY(M)    = [F:MFM]RETQTY
[M:MTK3]MFMUSEQTY(M)    = [F:MFM]USEQTY
[M:MTK3]MFMALLQTY(M)    = [F:MFM]ALLQTY
# Issue 74190 - 2011-06-06 by CCC : Dans le cas du cumul au suivi, GLOALLQTY est utilisée
If find([F:MFM]ALLSTA,2,3)
    [M:MTK3]GLOALLQTY(M) = [F:MFM]ALLQTY
Endif
[M:MTK3]MFMSHTQTY(M)    = [F:MFM]SHTQTY
[M:MTK3]LOTPREF(M)      = [F:MFM]LOT
[M:MTK3]LOCPREF(M)      = [F:MFM]LOC
[M:MTK3]STAPREF(M)      = [F:MFM]STA
[M:MTK3]MFGLIN(M)       = [F:MFM]MFGLIN
[M:MTK3]MATTRKLIN(M)    = M+1
[M:MTK3]ALLSTA(M)       = [F:MFM]ALLSTA
[M:MTK3]MATSTA(M)       = [F:MFM]MATSTA
[M:MTK3]MFMTRKFLG(M)    = [F:MFM]MFMTRKFLG
[M:MTK3]FICFLG(M)       = 0
[M:MTK3]BOMSEQ(M)       = [F:MFM]BOMSEQ
# Issue 107513/8 - 2015-07-13 by JUSYN : ECC - Major and minor version
If dim([M:MTK3]ECCVALMAJ(M)) > 0
    [M:MTK3]ECCVALMAJ(M)       = [F:MFM]ECCVALMAJ
    [M:MTK3]ECCVALMAJORI(M)    = [F:MFM]ECCVALMAJ
    [M:MTK3]ECCVALMIN(M)       = [F:MFM]ECCVALMIN
    [M:MTK3]ECCVALMINORI(M)    = [F:MFM]ECCVALMIN
    [M:MTK3]ECCSAIFLG(M)       = 9 # version number is not modifiable
Endif

If GREP <> "C"
   Case [F:MFM]MFMTRKFLG
        When 3,4 :    [M:MTK3]CLEFLG(M) = 1
        When Default :[M:MTK3]CLEFLG(M) = 2
   Endcase
Endif

Read [F:ITM]ITM0 = [F:MFM]ITMREF
If !fstat
     #[M:MTK3]ITMDES1(M)   = [F:ITM]ITMDES1
     Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MTK3]ITMDES1(M), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
     [M:MTK3]SERMGTCOD(M) = [F:ITM]SERMGTCOD
#     [M:MTK3]STOMGTCOD(M) = [F:ITM]STOMGTCOD
     [M:MTK3]NEGSTO(M)    = [F:ITM]NEGSTO
     [M:MTK3]TCLCOD(M)    = [F:ITM]TCLCOD
Endif

[M:MTK3]STOMGTCOD(M)    = [F:ITF]STOMGTCOD

[M:MTK3]OPENUM(M)       = [F:MFM]BOMOPE
[M:MTK3]CPLWST(M)       = [F:MFO]EXTWST

If [F:MWS]WST <> [F:MFO]EXTWST
     Read [MWS]WST0=[F:MFO]EXTWST;[F:MFO]MFGFCY
     If fstat : Raz [F:MWS] : Endif
Endif
#[M:MTK3]WSTSHO(M)     = [F:MWS]WSTSHO : # GH 28/02/2014 bug 95952
Call LECTEXTRA([M:MTK3]WSTSHO(M),"WORKSTATIO","WSTSHOAXX",[F:MFO]EXTWST,[F:MFO]MFGFCY) From ATEXTRA
##
[M:MTK3]STU(M)        = [F:MFM]STU
If [F:MFM]MFMTRKFLG   = 5
    [M:MTK3]RETQTY(M) = 0
Else
    [M:MTK3]RETQTY(M)     = [F:MFM]RETQTY-[F:MFM]USEQTY
    # 76038
    If [M:MTK3]RETQTY(M) < 0 : [M:MTK3]RETQTY(M) = 0 : Endif
Endif

# 08.02 demande 15515   -----------------Pavé déplacé-------------------
[M:MTK3]STOCODL(M)    = [F:ITF]STOCOD
# 02.07 Demande 39866
[M:MTK3]LOCMGTCOD(M)  = [F:ITF]LOCMGTCOD
[M:MTK3]LIKQTYCOD(M)  = [F:MFM]LIKQTYCOD
If dim([M:MTK3]LOC) > 0
    [M:MTK3]LOCPREF(M)    = [F:MFM]LOC
    If [F:MTS]EMPFLG = 2 & [M:MTK3]LOC(M) = ""
       [M:MTK3]LOC(M)     = [M:MTK3]LOCSTO
# 02.07 Demande 39866
       [M:MTK3]LOCPREF(M) = [M:MTK3]LOCSTO
    Endif
    If [F:ITF]CUNFLG = 2 & [M:MTK3]LOC(M) <> "" & [M:MTK3]WALLMULT(M) <> 2
        # 04.02 Problèmes Perf
        Filter[F:STO] Where STOFCY = [F:ITF]STOFCY & ITMREF = [F:ITF]ITMREF
&                     & LOC = [M:MTK3]LOC(M) & CUNLOKFLG = 1
&                 Order By Key STO3
        Read [F:STO]STO3 First
        If fstat : [M:MTK3]LOC(M) = "" : Endif
        Filter  [F:STO]
    Endif

    # Si emplacement atelier c'est celui qui se trouve sur la ligne matière
    [M:MTK3]WSTLOC(M)    = [F:MFM]LOC

Endif
#[M:MTK3]STAPREF(M)   = "A"
# 08.02 demande 15515  ------------------Fin Pavé déplacé-----------------
#la qté à suivre reste à 0 si matière soldée
If [F:MFM]MFMTRKFLG<>5
        [M:MTK3]USEQTY(M)     = [M:MTK3]RETQTY(M)
        [M:MTK3]WANCQTY(M)    = [M:MTK3]RETQTY(M)
#si suivi matière consécutif à suivi opé et conso mat progressive et pas forfait
#La qté réalisée est initialisée avec la qté prévue * coeff pondérateur de la qté réa de l'opé
        If [F:MTS]OPETRKFLG = 2 & [M:MTK0]OPETRKFLG = 2 & [F:MTS]CONSMAT <> 1 & [M:MTK3]LIKQTYCOD(M) <> 2
            L = find([M:MTK3]OPENUM(M),[M:MTK1]OPENUM(0..[M:MTK1]NBOPE-1))
            If L
               Case [F:MTS]CONSMAT
                    When 2: If [M:MTK1]CPLQTY(L-1) <> 0
                                If  [F:MFM]RETQTY * [M:MTK1]COEFFPOND(L-1) < [M:MTK3]USEQTY(M)
                                    [M:MTK3]USEQTY(M) = [F:MFM]RETQTY * [M:MTK1]COEFFPOND(L-1)
                                Endif
                            Endif
                    When 3: If [M:MTK1]CPLQTY(L-1) <> 0
                                [M:MTK3]USEQTY(M) = [F:MFM]RETQTY * [M:MTK1]COEFFPOND(L-1)
                            Endif
               Endcase
               # 01.03 arrondir la quantité calculée demande 17030
               Call QTEARR([M:MTK3]USEQTY(M),[M:MTK3]STU(M)) From TRTDIV
               [M:MTK3]WANCQTY(M) = [M:MTK3]USEQTY(M)
            Endif
#si suivi matière consécutif à declaration prod et conso mat progressive et pas forfait
#La qté réalisée est initialisée avec la qté prévue * coeff pondérateur de la qté déclarée
        Elsif [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2 & [F:MTS]CONSMAT <> 1 & [M:MTK3]LIKQTYCOD(M) <> 2
           # GH 16/10/2012 bug 81005
           L=0
           If dim([L]CAS)=1 & [L]CAS=1 & [M:MTK3]MFGLIN(M)<>0
              L=find([M:MTK3]MFGLIN(M),[M:MTK2]MFGLIN(0..[M:MTK2]NBITM-1))
              If L & ([M:MTK2]CPLQTY(L-1)=0 | [M:MTK2]MFIEXTQTY(L-1)=0) : L=0 : Endif
           Endif
           If L : # WCOEFF=0 à recalculer
              WCOEFF = [M:MTK2]CPLQTY(L-1) / [M:MTK2]MFIEXTQTY(L-1)
              If [F:MTS]CONSMAT = 2
                 [M:MTK3]USEQTY(M) = min([M:MTK3]MFMEXTQTY(M) * WCOEFF, [M:MTK3]RETQTY(M))
              Else
                 [M:MTK3]USEQTY(M) = [M:MTK3]MFMEXTQTY(M) * WCOEFF
              Endif
              WCOEFF=0
           Elsif [M:MTK3]MFGLIN(M)<>0 | WCOEFF<>0
              # 06.03 demande 18446 Tenir compte de la valeur de CONSMAT
               Case [F:MTS]CONSMAT
                    When 2: If  [F:MFM]RETQTY * WCOEFF < [M:MTK3]USEQTY(M)
                                [M:MTK3]USEQTY(M) = [F:MFM]RETQTY * WCOEFF
                            Endif
                    When 3: [M:MTK3]USEQTY(M) = [F:MFM]RETQTY * WCOEFF
               Endcase
           Endif
           Call QTEARR([M:MTK3]USEQTY(M),[M:MTK3]STU(M)) From TRTDIV
           [M:MTK3]WANCQTY(M) = [M:MTK3]USEQTY(M)
        Endif
Else Raz [M:MTK3]USEQTY(M) : Raz [M:MTK3]WANCQTY(M)
Endif

If [F:MFM]MFMTRKFLG < 5  [M:MTK3]WCLEFLG(M) = 1
Else                     [M:MTK3]WCLEFLG(M) = 2
Endif
If dim([M:MTK3]TYPQTY(M)) > 0
   If [F:ITF]STOMGTCOD <> 3  : [M:MTK3]TYPQTY(M) = 2
   Else                      : [M:MTK3]TYPQTY(M) = 1
   Endif
Endif
If [F:MFM]RETDAT < [M:MTK3]RETDAT(M) | [M:MTK3]RETDAT(M) = [0/0/0]
   [M:MTK3]RETDAT(M)  = [F:MFM]RETDAT
Endif
If [F:MFM]MFGLIN <> 0
    Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
    If !fstat
        [M:MTK3]BOMNUM(M)  = [F:MFI]ITMREF
        [M:MTK3]BOMALT(M)  = [F:MFI]BOMALT
        # Issue 107513/8 - 2015-08-17 by JUSYN : Versions from components / material of a versioned product isn't allowed to be changed.
        If dim([M:MTK3]ECCVALMAJ(M))>0
            If func ECCLIB.NBRCPN([M:MTK3]BOMNUM(M)) > 0
                # versioned parent product
                Grizo [M:MTK3]ECCVALMAJ(M)
                Grizo [M:MTK3]ECCVALMIN(M)
            Else
                Actzo [M:MTK3]ECCVALMAJ(M)
                Actzo [M:MTK3]ECCVALMIN(M)
            Endif
            Affzo [M:MTK3]ECCVALMAJ(M)
            Affzo [M:MTK3]ECCVALMIN(M)
            # Issue 38510 GH 26/10/2017 - read again the product to set the right analytical dimensions later on
            If [F:ITM]ITMREF<>[F:MFM]ITMREF
               Read [ITM]ITM0 = [F:MFM]ITMREF
            Endif
        Endif
    Endif
Else
    Filter [F:MFI]Where MFGNUM = [F:MFM]MFGNUM
    Read [F:MFI]MFI0 First
    If !fstat
       [M:MTK3]BOMNUM(M)  = [F:MFI]ITMREF
       [M:MTK3]BOMALT(M)  = [F:MFI]BOMALT
    Endif
    Filter [F:MFI]
Endif
If dim([M:MTK3]LOT) > 0 :  [M:MTK3]LOT(M)        = "" : Endif
[M:MTK3]STA(M)        = [F:MFM]STA
If dim([M:MTK3]LOC) > 0
    If [F:ITF]CUNFLG = 2 & [M:MTK3]LOC(M) <> ""
        #  04.02 Problèmes Perf
        Filter[F:STO] Where STOFCY = [F:ITF]STOFCY & ITMREF = [F:ITF]ITMREF
&                     & LOC = [M:MTK3]LOC(M) & CUNLOKFLG = 1
&                  Order By Key STO3
        Read [F:STO]STO3 First
        If fstat : [M:MTK3]LOC(M) = "" : Endif
        Filter  [F:STO]
    Endif
Endif

[M:MTK3]WINDIC(M)  = 1
# 05.05 demande 30321
[M:MTK3]WSTODET(M) = 1

# chargement des sections analytiques      (TB  21/10/99)
# reprise des sections de l'OF, si vide : initialisation selon paramétrage
#Chargement des section ana
Call CHARG_ACCCCE(M,"","","[M:MTK3]CCE",
&                 "MFM",0,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,[F:MFM]ITMREF) From TRTX3CPT

For J = 1 To GNBDIE    :# (on ne vient pas d'une boucle affectant déjà J)
   If evalue ("[M:MTK3]CCE"+num$(J)+"(M)") =""
      Call INISEC(WCCE,"MKM",J) From TRTX3CPT
      Assign "[M:MTK3]CCE"+num$(J)+"(M)" With WCCE
  Endif
Next

[M:MTK3]ALLQTY(M)       = 0
[M:MTK3]ALLQTYSHT(M)    = 0

Default Mask [MTK3]
# Issue 84927 - 2012-10-12 by CCC : ne doit être fait qu'en avant_nblig ou am_itmref
#Call INIZONSOR("MTK3",[M:MTK3]MATITMREF(M),[M:MTK0]MFGFCY,M,6,[M:MTK0]TRSCODS,"") From STKECR

# point d'entrée pour charger des zones spécifiques demande 16176
GPOINT = "LOADSUPP" : Gosub ENTREE From EXEFNC

M+=1
Return

###########################
$REC_LOC
#si allocation détaillée et article en inventaire, on vérifie que les allocations
#portent bien sur des emplacements autorisés
If clalev ([F:STA]) <= 0 : Local File STOALL [STA] : Endif
If clalev ([F:STO]) <= 0 : Local File STOCK  [STO] : Endif
Filter [F:STA] Where VCRTYP = 10 & VCRNUM = [F:MFM]MFGNUM & VCRLIN = [F:MFM]MFGLIN & ITMREF = [F:MFM]ITMREF
&                    & VCRSEQ = [F:MFM]BOMSEQ
For [F:STA]STA2                # 10.02 Performances
    Read [F:STO]STO0 = [F:STA]STOFCY;[F:STA]STOCOU
    If !fstat & [F:STO]CUNLOKFLG = 2 : WCUNFLG = 2 : Break : Endif
Next
Filter [F:STA]
Return

#########################################################
$TRT_STOCKLIGNE     # V6 voir aussi dans TRTPSAISCM !!! #
# Stocks 1.4.0
Local Integer WRET, WRUP, WAUTO
Local Decimal WTOTUSEQTY,WRESTQTY
Local Decimal LQTYALL, LQTYSHT
Raz WRET, [M:ALP]
If [F:ITM]ITMREF <> [M:MTK3]MATITMREF(WLIG)
    Read [ITM]ITM0=[M:MTK3]MATITMREF(WLIG)
    If fstat : Raz [ITM] : Endif
Endif
# 02.07 Demande 39866
If [M:MTK3]USEQTY(WLIG) <> 0
# Si cumul au suivi et stock négatif interdit il faut vérifier ce qui sera réellement consommable et réajuster si besoin
    If [M:MTK3]CUMMATSUI(WLIG) = 1
        If  [M:MTK3]NEGSTO(WLIG) < 2
# Issue 90476 - 2013-07-03 by CCC : Recherche de la quantité allouée sur toutes les lignes d'OF du composant
#        # 02.07 Demande 39866
#           If [M:MTK3]ALLQTY(WLIG) <> 0
#                Call CTLALL([M:MTK0]MFGFCY,10,[M:MTK0]MFGNUM,[M:MTK3]MFGLIN(WLIG),[M:MTK3]BOMSEQ(WLIG),6,[M:MTK0]TRSCODS,
#&                       "",1,[M:MTK3]ALLQTY(WLIG),[M:MTK3]ALLQTYSHT(WLIG),WRET) From STKALL
#                WRESTQTY = [M:MTK3]USEQTY - [M:MTK3]ALLQTY(WLIG)
#           Else
#                WRESTQTY  = [M:MTK3]USEQTY(WLIG)
#           Endif
            Raz [M:MTK3]ALLQTY(WLIG), [M:MTK3]ALLQTYSHT(WLIG)
            For [MFM] Where MFGNUM=[M:MTK0]MFGNUM & ITMREF=[M:MTK3]MATITMREF(WLIG)
                Call CTLALL([M:MTK0]MFGFCY,10,[M:MTK0]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,6,[M:MTK0]TRSCODS,
&                       "",1,LQTYALL,LQTYSHT,WRET) From STKALL
                [M:MTK3]ALLQTY(WLIG) += LQTYALL
                [M:MTK3]ALLQTYSHT(WLIG) += LQTYSHT
            Next
            #WRESTQTY = [M:MTK3]USEQTY - [M:MTK3]ALLQTY(WLIG)
            WRESTQTY = [M:MTK3]USEQTY(WLIG) - [M:MTK3]ALLQTY(WLIG) : # GH 24/11/2014 bug 104189

           If WRESTQTY <> 0
                     WRUP = [F:ITM]NEGSTO - 1
                    [M:ALP]TRSTYP     = 6
                    [M:ALP]TRSCOD     = [M:MTK0]TRSCODS
                    [M:ALP]VCRTYP     = 12
                    [M:ALP]VCRNUM     = ""
                    [M:ALP]VCRLIN     = 0
                    [M:ALP]VCRSEQ     = 0
                    [M:ALP]STOFCY     = [M:MTK0]MFGFCY
                    [M:ALP]ITMREF     = [M:MTK3]MATITMREF(WLIG)
                    [M:ALP]QTY        = WRESTQTY
                    [M:ALP]TYPQTY     = 2
                    [M:ALP]STA        = [M:MTK3]STAPREF(WLIG)
                    [M:ALP]LOT        = [M:MTK3]LOTPREF(WLIG)
                    [M:ALP]LOC        = [M:MTK3]LOCPREF(WLIG)
                    [M:ALP]PCU        = [M:MTK3]STU(WLIG)
                    [M:ALP]PCUSTUCOE  = 1
                    [M:ALP]TYPQTY     = 2
                    [M:ALP]BESDAT     = [M:MTK0]MFGTRKDAT
                    [M:ALP]STOLOC     = [M:MTK3]LOCPREF(WLIG)
                    [M:ALP]VCRTYPORI  = 10
                    [M:ALP]VCRNUMORI  = [M:MTK3]MFGNUMMA(WLIG)
                    [M:ALP]VCRLINORI  = 0
                    [M:ALP]VCRSEQORI  = 0
                    [M:ALP]ALLTYPORI  = 0
                    # 05.05 si allocs globales, on les passe au GENSTOALL pour calculer le stock dispo
                    Raz [M:ALP]ALLQTY
                    [M:ALP]ALLQTY    =  [M:MTK3]GLOALLQTY(WLIG)
                    [M:ALP]PECQLYCTL      = 1
                    # 08.05 demande 29188
                    [M:ALP]PECSCOLOC  = 1
                    If [M:MTK3]CPLWST(WLIG) <> ""
                        If [F:MWS]WST <> [M:MTK3]CPLWST(WLIG) | [F:MWS]WCRFCY <> [M:MTK0]MFGFCY
                           Read [F:MWS]WST0 = [M:MTK3]CPLWST(WLIG);[M:MTK0]MFGFCY
                           If fstat : Raz [F:MWS] : Endif
                        Endif
                        If [F:MWS]WSTTYP = 3
                            [M:ALP]PECSCOLOC  = 2
                        Endif
                    Endif
                    [M:ALP]PECINTLOC  = 2
                    [M:ALP]PECPLFLOC  = 2
                    If dim([M:MTK3]WRH)>0 [M:ALP]WRH=[M:MTK3]WRH(WLIG) Endif
                    Call GENSTOALL("",2,WRUP,1,WRET) From STKALL
                    WRESTQTY = [M:ALP]ALLQTY
            Endif
            [M:MTK3]ALLQTY(WLIG) += WRESTQTY
            # si stock négatif interdit, réajustement de la qté à sortir selon le disponible
            If [M:MTK3]NEGSTO(WLIG) < 2  & [M:MTK3]USEQTY(WLIG) > [M:MTK3]ALLQTY(WLIG)
                [M:MTK3]USEQTY(WLIG) = [M:MTK3]ALLQTY(WLIG)
                WNO_REAJUST = 1
            Endif
        Endif
        # Issue 84135 - 2012-08-24 by CCC : Calcul du flag "Solde"
        Raz WRET
        WTOTUSEQTY = [M:MTK3]USEQTY(WLIG) + [M:MTK3]MFMUSEQTY(WLIG)
        Call CONT_SOLDE_MAT([M:MTK0]MFGFCY,[M:MTK3]MATITMREF(WLIG),WTOTUSEQTY,[M:MTK3]MFMEXTQTY(WLIG),WRET) From MFGLIBM
        If WRET = 0 : [M:MTK3]CLEFLG(WLIG) = 1
        Else        : [M:MTK3]CLEFLG(WLIG) = 2
        Endif

        Return
    Endif

    If find([M:MTK3]ALLSTA(WLIG),4,5) &  [M:MTK3]USEQTY(WLIG) <> 0
    #    If ([F:MTS]STOCODMAN=1|[M:MTK3]STOCODL(WLIG)=2)
            Call CTLALL([M:MTK0]MFGFCY,10,[M:MTK0]MFGNUM,[M:MTK3]MFGLIN(WLIG),[M:MTK3]BOMSEQ(WLIG),6,[M:MTK0]TRSCODS,
&               "",1,[M:MTK3]ALLQTY(WLIG),[M:MTK3]ALLQTYSHT(WLIG),WRET) From STKALL
                [M:ALP]TRSTYP     = 6
                [M:ALP]TRSCOD     = [M:MTK0]TRSCODS
                [M:ALP]VCRTYP     = 10
                [M:ALP]VCRNUM     = [M:MTK3]MFGNUMMA(WLIG)
                [M:ALP]VCRLIN     = [M:MTK3]MFGLIN(WLIG)
                [M:ALP]VCRSEQ     = [M:MTK3]BOMSEQ(WLIG)
                [M:ALP]STOFCY     = [M:MTK0]MFGFCY
                [M:ALP]ITMREF     = [M:MTK3]MATITMREF(WLIG)
                [M:ALP]QTY        = [M:MTK3]USEQTY(WLIG)
                [M:ALP]TYPQTY     = 2
                [M:ALP]STA        = [M:MTK3]STAPREF(WLIG)
    # 10.06 demande 38009
    #        [M:ALP]BESDAT     = [M:MTK3]RETDAT(WLIG)  : # Bug 35084
            [M:ALP]BESDAT     = [M:MTK0]MFGTRKDAT
                # 08.05 demande 29188
                [M:ALP]PECSCOLOC  = 1
                If [M:MTK3]CPLWST(WLIG) <> ""
                   If [F:MWS]WST <> [M:MTK3]CPLWST(WLIG) | [F:MWS]WCRFCY <> [M:MTK0]MFGFCY
                      Read [F:MWS]WST0 = [M:MTK3]CPLWST(WLIG);[M:MTK0]MFGFCY
                      If fstat : Raz [F:MWS] : Endif
                   Endif
                   If [F:MWS]WSTTYP = 3
                      [M:ALP]PECSCOLOC  = 2
                   Endif
                Endif
                If dim([M:MTK3]WRH)>0 [M:ALP]WRH=[M:MTK3]WRH(WLIG) Endif
                Raz WRET
                WRUP = [M:MTK3]NEGSTO(WLIG) - 1
                Call ALLSTOSORW("MTK3",WLIG,[M:MTK3]NBMAT,WRUP,1,0,WRET) From STKSOR
                Call ALI_ALP("MTK3",WLIG) From SUBMTKB
   # 03.07 Demande  40494
   # Si pas assez d'allocation et détermination auto à oui, on va chercher du stock ailleurs
# CCC (13/05/08) Bug 47296 : On laisse faire le OUVSOR
#            If [M:ALP]QTY > [M:ALP]ALLQTY
#&            & [F:MTS]STKFLG = 2 & ([F:MTS]STOCODMAN=1|[M:MTK3]STOCODL(WLIG)=2)
#               [M:ALP]QTY -= [M:ALP]ALLQTY
#               Raz [M:ALP]ALLQTY
#               Call GENSTOSORW("MTK3",WLIG,[M:MTK3]NBMAT,WRUP,"C",WRET)
#&                   From STKSOR
#               [M:MTK3]ALLQTY(WLIG)    += [M:ALP]ALLQTY
#               [M:MTK3]ALLQTYSHT(WLIG) += [M:ALP]ALLQTYSHT
#            Endif

    #    Endif
    Else
            Raz WRET
            WRUP = [M:MTK3]NEGSTO(WLIG) - 1
            Call ALI_ALP("MTK3",WLIG) From SUBMTKB
            If find([M:MTK3]ALLSTA(WLIG),2,3) : # By consistency with FUNBENCHM.$TRT_STOCKLIGNE
               [M:ALP]ALLQTY  = [M:MTK3]MFMALLQTY(WLIG)
            Else
                Raz [M:ALP]ALLQTY
            Endif

    #

# CCC (13/05/08) Bug 47296 : On laisse faire le OUVSOR
#            If [F:MTS]STKFLG = 2 & ([F:MTS]STOCODMAN=1|[M:MTK3]STOCODL(WLIG)=2)
#                 Call GENSTOSORW("MTK3",WLIG,[M:MTK3]NBMAT,WRUP,"C",WRET)
#&                            From STKSOR
#            Endif
            [M:MTK3]ALLQTY(WLIG)    = [M:ALP]ALLQTY
            [M:MTK3]ALLQTYSHT(WLIG) = [M:ALP]ALLQTYSHT

    Endif
Else
    [M:MTK3]ALLQTY(WLIG)    = 0
    [M:MTK3]ALLQTYSHT(WLIG) = 0
Endif

# 02.07 Demande 39866
# If [M:MTK3]USEQTY(WLIG) = 0 : Return : Endif

If [M:MTK3]USEQTY(WLIG)<>0 : # GH 27/01/12 bug 78889 le bouton "Ne pas suivre" sur MTK2 ne mettait pas Solder à Non sur MTK3
 Raz WRET
 If [F:MTS]STKFLG = 1 : WAUTO = 1
 Else
    If [F:MTS]STOCODMAN = 2 & [M:MTK3]STOCODL(WLIG) = 1 & [M:ALP]QTY <> 0
        WAUTO = 1
        # Retrait manuel strict : La détermination auto n’a pu se faire sur les articles dont le mode de retrait est immédiat
        WNO_AUTO = 1
    Else
        WAUTO = 2
    Endif
 Endif
 [M:ALP]PECQLYCTL  =  1
 Call OUVSOR("MTK3",WLIG,[M:MTK3]NBMAT,[M:MTK3]WSTOSEQ(WLIG),WAUTO,WRET) From STKSOR

 # CCC (13/05/08) Bug 47296 : Comparaison de la quantité stockée dans STOSORW et de la quantité demandée après le OUVSOR
 [M:MTK3]ALLQTY(WLIG)=sigma(0,[M:SOW]NBLIG-1,([M:SOW]WQTYSTUACT(indcum)*([M:SOW]WSTOSEQ(indcum)=[M:MTK3]WSTOSEQ(WLIG))))
 # si stock négatif interdit, réajustement de la qté à sortir selon ce qui a été sorti
 If [M:MTK3]NEGSTO(WLIG) < 2  & [M:MTK3]USEQTY(WLIG) > [M:MTK3]ALLQTY(WLIG)
    # GA 05/2009 FQ 54366 défaire la modif 51935 dans SUBMTKB
    # CCC (23/01/09) Bug 51935 : si rien n'a été trouvé, on laisse la quantité préchargée
    #If [M:MTK3]ALLQTY(WLIG)>0
        [M:MTK3]USEQTY(WLIG) = [M:MTK3]ALLQTY(WLIG)
    #Endif
    WNO_REAJUST = 1
 Endif
Endif

# 04.07 Demande 41086
# 11.06 Recalcul du flag solde demande 38605
Raz WRET
WTOTUSEQTY = [M:MTK3]USEQTY(WLIG) + [M:MTK3]MFMUSEQTY(WLIG)
Call CONT_SOLDE_MAT([M:MTK0]MFGFCY,[M:MTK3]MATITMREF(WLIG),WTOTUSEQTY,[M:MTK3]MFMEXTQTY(WLIG),WRET) From MFGLIBM
If WRET = 0 : [M:MTK3]CLEFLG(WLIG) = 1
Else        : [M:MTK3]CLEFLG(WLIG) = 2
Endif
Return

################################################
$REAJUST_MAT
Local Integer J, LRET, WLIG
# 10.01 demande 11203
# 11.06 demande38605
#Local Decimal WTOTUSEQTY, LDIS
Local Decimal LDIS
#Réajustement de la qté consommée de la matière si modif mat seule après_modif qtesuivmat
#Si forfait on ne touche à rien idem si matière soldée ou
#code retrait de stock manuel strict
#[F:MTS]CONSMAT = Mode de consommation matière
#                 1 = Immédiate ( donc on ne change rien)
#                 2 = Progressive selon qté prévu(donc on ne dépasse pas)
#                 3 = Progressive selon qte produite(donc on réajuste toujours)
For J = 0 To [M:MTK3]NBMAT-1
# 04.02 demande 13793
#             If [F:MTS]CONSMAT <> 1 & [M:MTK3]USEQTY(J) <> 0 & [M:MTK3]LIKQTYCOD(J) <> 2

             If [F:MTS]CONSMAT <> 1 & [M:MTK3]LIKQTYCOD(J) <> 2
# CCC (06/08/08) Bug 48207 : Dans le cas de consmat=3, même si la matière est soldée, il faut ajuster la quantité de matière.
#&             & [M:MTK3]MFMTRKFLG(J) <> 5
                 If [F:MTS]CONSMAT = 2
                    If [M:MTK3]MFMEXTQTY(J) * WCOEFF <= [M:MTK3]RETQTY(J)
                       [M:MTK3]USEQTY(J) = [M:MTK3]MFMEXTQTY(J) * WCOEFF
                       Call QTEARR([M:MTK3]USEQTY(J),[M:MTK3]STU(J)) From TRTDIV
                       [M:MTK3]WANCQTY(J) = [M:MTK3]USEQTY(J)
                    Endif
                 Else
                    [M:MTK3]USEQTY(J) = [M:MTK3]MFMEXTQTY(J) * WCOEFF
                     Call QTEARR([M:MTK3]USEQTY(J),[M:MTK3]STU(J)) From TRTDIV
                 Endif
                 Raz LRET
                 WLIG = J
                 Call DELSTOSORW(J, J,"MTK3",[M:MTK0]MFGFCY,LRET) From STKSOR
                 Gosub TRT_STOCKLIGNE
#                 # 10.01 la qté consommée à utiliser est la somme de ce qui a déjà été
#                 # consommé et de ce qui va l'être demande 11203
#                 WTOTUSEQTY = [M:MTK3]USEQTY(J) + [M:MTK3]MFMUSEQTY(J)
#                 Call CONT_SOLDE_MAT([M:MTK0]MFGFCY,[M:MTK3]MATITMREF(J),WTOTUSEQTY,[M:MTK3]MFMEXTQTY(J),LRET) From MFGLIBM
#                 If LRET = 0 : [M:MTK3]CLEFLG(J) = 1
#                 Else        : [M:MTK3]CLEFLG(J) = 2
#                 Endif
            Endif
Next J
Affzo [M:MTK3]15
Return

##################################################
$UPD_EMPL_MAT
# 02.07 Demande 39866
Local Integer J,LRET, WLIG
#Initialisation de l'emplacement de destockage et destockage par défaut
For J = 0 To [M:MTK3]NBMAT-1
           [M:MTK3]LOCPREF(J) = VALEUR
           # 56958
           If dim([M:MTK3]LOC) > 0 : [M:MTK3]LOC(J)= VALEUR : Endif
           Raz LRET
            WLIG = J
            Call DELSTOSORW(J, J,"MTK3",[M:MTK0]MFGFCY,LRET) From STKSOR
            Gosub TRT_STOCKLIGNE
# Fin 02.07 Demande 39866
Next J
Affzo [M:MTK3]15
Return


#########################################################################
$CHARGE_STOSOR
#-----------------------------------------------------------------------#
# Chargement des paramètres dans masque STOSOR pour saisie des sorties  #
# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOSORA       #
#-----------------------------------------------------------------------#

Case LABR
    When "MTK3" :
        [M:SOR]WSTOSEQ   = [M:MTK3]WSTOSEQ(LNOL)
        [M:SOR]TRSTYP    = 6
        [M:SOR]TRSCOD    = [M:MTK0]TRSCODS
        [M:SOR]CCECODS   = [M:MTK0]CCECODS
        [M:SOR]TRFFCY    = ""
        [M:SOR]VCRTYP    = 12
        [M:SOR]VCRNUM    = [M:MTK0]MFGTRKNUM
        [M:SOR]VCRLIN    = [M:MTK3]MATTRKLIN(LNOL)
        [M:SOR]MVTDES    = [M:MTK3]MVTDES(LNOL)
        [M:SOR]STU       = [M:MTK3]STU(LNOL)
        [M:SOR]PCU       = [M:MTK3]STU(LNOL)
        [M:SOR]PCUSTUCOE = 1
        [M:SOR]SORQTY    = [M:MTK3]USEQTY(LNOL)
        [M:SOR]SORQTYACT = [M:MTK3]USEQTY(LNOL)
        [M:SOR]RETDAT    = [M:MTK0]MFGTRKDAT
        [M:SOR]PECINTLOC = 2
        [M:SOR]PECPLFLOC = 2
        # Bug 41947
        [M:SOR]VCRTYPORI = 10
        [M:SOR]VCRNUMORI = [M:MTK3]MFGNUMMA(LNOL)
        [M:SOR]VCRLINORI = [M:MTK3]MFGLIN(LNOL)
        [M:SOR]VCRSEQORI = [M:MTK3]BOMSEQ(LNOL)
        # 08.05 demande 29188
        [M:SOR]PECSCOLOC  = 1
        If [M:MTK3]CPLWST(LNOL) <> ""
           If [F:MWS]WST <> [M:MTK3]CPLWST(LNOL) | [F:MWS]WCRFCY <> [M:MTK0]MFGFCY
               Read [F:MWS]WST0 = [M:MTK3]CPLWST(LNOL);[M:MTK0]MFGFCY
               If fstat : Raz [F:MWS] : Endif
           Endif
           If [F:MWS]WSTTYP = 3
              [M:SOR]PECSCOLOC  = 2
           Endif
        Endif
        If [M:MTK3]WSTLOC(LNOL) <> ""
            [M:SOR]STOLOC    = [M:MTK3]WSTLOC(LNOL)
        Endif
        [M:SOR]XLOT      = [M:MTK3]LOTPREF(LNOL)
        [M:SOR]XLOC      = [M:MTK3]LOCPREF(LNOL)
        [M:SOR]XSTA      = [M:MTK3]STAPREF(LNOL)
        If dim([M:MTK3]WRH)>0 [M:SOR]XWRH=[M:MTK3]WRH(LNOL) Endif
        # Issue 107513/US3 GA 04/2015: ECC for stock issue
        If dim([M:MTK3]ECCVALMAJ) >= 0
          [M:SOR]WECCVALMAJ=[M:MTK3]ECCVALMAJ(LNOL)
        Endif
        [M:SOR]PECQLYCTL = 1
        # 05.05
        If find([M:MTK3]ALLSTA(LNOL),2,3)
             [M:SOR]GLOALLQTY = [M:MTK3]MFMALLQTY(LNOL)
        Else
             Raz [M:SOR]GLOALLQTY
        Endif
    When "MBM" :

        [M:SOR]WSTOSEQ   = [M:MBM]WSTOSEQ(LNOL)
        [M:SOR]TRSTYP    = 6
        [M:SOR]TRSCOD    = [M:MBM]TRSCODS
        [M:SOR]CCECODS   = [M:MBM]CCECODS
        [M:SOR]TRFFCY    = ""
        [M:SOR]VCRTYP    = 12
        [M:SOR]VCRNUM    = ""
        [M:SOR]VCRLIN    = [M:MBM]WLINUM(LNOL)
        [M:SOR]MVTDES    = [M:MBM]MVTDES(LNOL)
        [M:SOR]STU       = [M:MBM]STU(LNOL)
        [M:SOR]PCU       = [M:MBM]STU(LNOL)
        [M:SOR]PCUSTUCOE = 1
        [M:SOR]SORQTY    = [M:MBM]USEQTY(LNOL)
        [M:SOR]SORQTYACT = [M:MBM]USEQTY(LNOL)
        [M:SOR]RETDAT    = [M:MBM]IPTDAT(LNOL)
        [M:SOR]PECPLFLOC = 2
        [M:SOR]PECINTLOC = 2
        # Bug 41947
        [M:SOR]VCRTYPORI = 10
        [M:SOR]VCRNUMORI = [M:MBM]MFGNUM(LNOL)
        [M:SOR]VCRLINORI = [M:MBM]MFGLIN(LNOL)
        [M:SOR]VCRSEQORI = [M:MBM]BOMSEQ(LNOL)
        Raz GBIDI1, GBIDI2
        For GBIDI2=0 To [MBM]NBLIG-1
            If GBIDI2<>nolign-1
&            & [M:MBM]IPTDAT(nolign-1) = [M:MBM]IPTDAT(GBIDI2)
&            & [M:MBM]MATTYP(nolign-1) = [M:MBM]MATTYP(GBIDI2)
&            & [M:MBM]MFGNUM(nolign-1) = [M:MBM]MFGNUM(GBIDI2)
&            & [M:MBM]ITMREF(nolign-1) = [M:MBM]ITMREF(GBIDI2)
&            & [M:MBM]BOMSEQ(nolign-1) = [M:MBM]BOMSEQ(GBIDI2)
&            & [M:MBM]OPENUM(nolign-1) = [M:MBM]OPENUM(GBIDI2)
&            & find([M:MBM]WSTOSEQ(GBIDI2),[M:SOW]WSTOSEQ)>0
                [M:SOR]TWSTOSEQ(GBIDI1) = [M:MBM]WSTOSEQ(GBIDI2)
                GBIDI1+=1
                If GBIDI1>=dim([M:SOR]TWSTOSEQ)
                    Break
                Endif
            Endif
        Next

        # 08.05 demande 29188
        [M:SOR]PECSCOLOC  = 1
        If [M:MBM]CPLWST(LNOL) <> ""
          If [F:MWS]WST <> [M:MBM]CPLWST(LNOL) | [F:MWS]WCRFCY <> [M:MBM]FCY
               Read [F:MWS]WST0 = [M:MBM]CPLWST(LNOL);[M:MBM]FCY
               If fstat : Raz [F:MWS] : Endif
           Endif
           If [F:MWS]WSTTYP = 3
              [M:SOR]PECSCOLOC  = 2
           Endif
        Endif
        If [M:MBM]WSTLOC(LNOL) <> ""
            [M:SOR]STOLOC    = [M:MBM]WSTLOC(LNOL)
        Endif
        [M:SOR]XLOT      = [M:MBM]LOTPREF(LNOL)
        [M:SOR]XLOC      = [M:MBM]LOCPREF(LNOL)
        [M:SOR]XSTA      = [M:MBM]STAPREF(LNOL)
        If dim([M:MBM]WRH)>0 [M:SOR]XWRH=[M:MBM]WRH(LNOL) Endif
        # Issue 107513/US3 GA 04/2015: ECC for stock issue
        If dim([M:MBM]ECCVALMAJ) >= 0
          [M:SOR]WECCVALMAJ=[M:MBM]ECCVALMAJ(LNOL)
        Endif
        [M:SOR]PECQLYCTL  = 1
        If [M:MBM]MATTYP(LNOL) = 1 & find([M:MBM]ALLSTA(LNOL),2,3)
             [M:SOR]GLOALLQTY = [M:MBM]MFMALLQTY(LNOL)
        Else
             Raz [M:SOR]GLOALLQTY
        Endif
Endcase
[M:SOR]CUR = GLOCALDEV
[M:SOR]BPRNUM = ""
Return

#########################################################################
#récupérer la quantité surtout si article titré
#pour un article non titré la quantité passée en paramètre au moteur ne doit pas être modifiée
$APRES_STOSOR
Local Decimal WTOTUSEQTY, WUSEQTY
Local Integer WRET
If WGENR = 0 : Return : Endif
WUSEQTY = [M:SOR]SHTQTY + [M:SOR]PECQTYACT
Case LABR
    When "MTK3" :
            If [M:MTK3]USEQTY(LNOL) <> WUSEQTY
                [M:MTK3]USEQTY(LNOL) = WUSEQTY
                If [M:MTK3]MFMITMREF(LNOL) <> ""
                    WTOTUSEQTY = [M:MTK3]USEQTY(LNOL) + [M:MTK3]MFMUSEQTY(LNOL)
                    Call CONT_SOLDE_MAT([M:MTK0]MFGFCY,[M:MTK3]MATITMREF(LNOL),WTOTUSEQTY,[M:MTK3]MFMEXTQTY(LNOL),WRET) From MFGLIBM
                    If WRET = 0 : [M:MTK3]CLEFLG(LNOL) = 1
                    Else        : [M:MTK3]CLEFLG(LNOL) = 2
                    Endif
                    Affzo [M:MTK3]CLEFLG(LNOL)
                Endif
                Affzo [M:MTK3]USEQTY(LNOL)
            Endif
    When "MBM" :
            If [M:MBM]USEQTY(LNOL) <> WUSEQTY
                [M:MBM]USEQTY(LNOL) = WUSEQTY

                If [M:MBM]MATTYP(LNOL) = 1 & [M:MBM]MFMITMREF(LNOL) <> ""
                    WTOTUSEQTY = [M:MBM]USEQTY(LNOL) + [M:MBM]MFMUSEQTY(LNOL)
                    Call CONT_SOLDE_MAT([M:MBM]FCY,[M:MBM]ITMREF(LNOL),WTOTUSEQTY,[M:MBM]MFMEXTQTY(LNOL),WRET) From MFGLIBM
                    If WRET = 0 : [M:MBM]CLEFLG(LNOL) = 1
                    Else        : [M:MBM]CLEFLG(LNOL) = 2
                    Endif
                    Affzo [M:MBM]CLEFLG(LNOL)
                Endif

                Affzo [M:MBM]USEQTY(LNOL)
            Endif
Endcase
Return


#########################################################################

$CHARGE_STOSOM

#----------------------------------------------------------------------------#
# Chargement des paramètres dans masque STOSOM pour modification/suppression #
# des sorties matières                                                       #
# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOSOMA            #
#----------------------------------------------------------------------------#
Case GREP
    When "A"

        [M:SOM]TRSTYP    = 6
        [M:SOM]TRSCOD    = [F:MTS]TRSCODS
        [M:SOM]TRFFCY    = ""
        Case [F:MKM]MATTYP
            When 1,3 :        [M:SOM]VCRTYPORI = 10
                              [M:SOM]VCRNUMORI = [F:MKM]MFGNUM
                              [M:SOM]VCRLINORI = [F:MKM]MFGLIN
                              [M:SOM]VCRSEQORI = [F:MKM]BOMSEQ
            When 2,4 :        [M:SOM]VCRTYPORI = 0
                              [M:SOM]VCRNUMORI = [F:MKM]BOMNUM
                              [M:SOM]VCRLINORI = [F:MKM]BOMALT
        Endcase
        [M:SOM]VCRTYP    = 12
        [M:SOM]VCRNUM    = [F:MKM]MFGTRKNUM
        [M:SOM]VCRLIN    = [F:MKM]MATTRKLIN
        [M:SOM]STU       = [F:ITM]STU
        [M:SOM]PCU       = [F:ITM]STU
        [M:SOM]PCUSTUCOE = 1
        [M:SOM]SORQTY    = [F:MKM]USEQTY
        [M:SOM]SORQTYACT = [F:MKM]USEQTY
        [M:SOM]DLVDAT    = [F:MKM]IPTDAT
        [M:SOM]PECINTLOC = 2
        [M:SOM]PECPLFLOC = 2
        # 08.05 demande 29188
        [M:SOM]PECSCOLOC = 1
        If [F:MKM]CPLWST <> ""
           If [F:MWS]WST <> [F:MKM]CPLWST | [F:MWS]WCRFCY <> [F:MKM]MFGFCY
               Read [F:MWS]WST0 = [F:MKM]CPLWST;[F:MKM]MFGFCY
               If fstat : Raz [F:MWS] : Endif
           Endif
           If [F:MWS]WSTTYP = 3
              [M:SOM]PECSCOLOC  = 2
           Endif
         Endif
        [M:SOM]PECQLYCTL = 1
        [M:SOM]XLOT      = [F:MKM]LOTPREF
        [M:SOM]XLOC      = [F:MKM]LOCPREF
        [M:SOM]XSTA      = [F:MKM]STAPREF
        If dim([M:MKM]WRH)>0 [M:SOM]XWRH=[M:MKM]WRH Endif
    When Default :

        [M:SOM]TRSTYP    = 6
        [M:SOM]TRSCOD    = [M:MTK0]TRSCODS
        [M:SOM]TRFFCY    = ""
        Case [M:MTK3]MATTYP(LNOL)
            When 1,3 :        [M:SOM]VCRTYPORI = 10
                              [M:SOM]VCRNUMORI = [M:MTK3]MFGNUMMA(LNOL)
                              [M:SOM]VCRLINORI = [M:MTK3]MFGLIN(LNOL)
                              [M:SOM]VCRSEQORI = [M:MTK3]BOMSEQ(LNOL)
            When 2,4 :        [M:SOM]VCRTYPORI = 0
                              [M:SOM]VCRNUMORI = [M:MTK3]BOMNUM(LNOL)
                              [M:SOM]VCRLINORI = [M:MTK3]BOMALT(LNOL)
        Endcase
        [M:SOM]VCRTYP    = 12
        [M:SOM]VCRNUM    = [M:MTK0]MFGTRKNUM
        [M:SOM]VCRLIN    = [M:MTK3]MATTRKLIN(LNOL)
        [M:SOM]STU       = [M:MTK3]STU(LNOL)
        [M:SOM]PCU       = [M:MTK3]STU(LNOL)
        [M:SOM]PCUSTUCOE = 1
        [M:SOM]SORQTY    = [M:MTK3]USEQTY(LNOL)
        [M:SOM]SORQTYACT = [M:MTK3]USEQTY(LNOL)
        [M:SOM]DLVDAT    = [M:MTK0]MFGTRKDAT
        [M:SOM]PECINTLOC = 2
        [M:SOM]PECPLFLOC = 2
        # 08.05 demande 29188
        [M:SOM]PECSCOLOC = 1
        If [M:MTK3]CPLWST(LNOL) <> ""
           If [F:MWS]WST <> [M:MTK3]CPLWST(LNOL) | [F:MWS]WCRFCY <> [M:MTK0]MFGFCY
               Read [F:MWS]WST0 = [M:MTK3]CPLWST(LNOL);[M:MTK0]MFGFCY
               If fstat : Raz [F:MWS] : Endif
           Endif
           If [F:MWS]WSTTYP = 3
              [M:SOM]PECSCOLOC  = 2
           Endif
        Endif
        [M:SOM]PECQLYCTL = 1
        If [M:MTK3]WSTLOC(LNOL) <> ""
           [M:SOM]STOLOC    = [M:MTK3]WSTLOC(LNOL)
        Endif
        [M:SOM]XLOT      = [M:MTK3]LOTPREF(LNOL)
        [M:SOM]XLOC      = [M:MTK3]LOCPREF(LNOL)
        [M:SOM]XSTA      = [M:MTK3]STAPREF(LNOL)
        If dim([M:MTK3]WRH)>0 [M:SOM]XWRH=[M:MTK3]WRH(LNOL) Endif
Endcase

Return

#########################################################################
Subprog ALI_ALP(LABR,LLIG)
Value Char    LABR
Value Integer LLIG
#--- Issue 95983
Raz [M:ALP]
Case LABR
    When "MTK3":
        [M:ALP]TRSTYP     = 6
        [M:ALP]TRSCOD     = [M:MTK0]TRSCODS
        [M:ALP]VCRTYP     = 12
        [M:ALP]STOFCY     = [M:MTK0]MFGFCY
        [M:ALP]ITMREF     = [M:MTK3]MATITMREF(LLIG)
        [M:ALP]QTY        = [M:MTK3]USEQTY(LLIG)
        [M:ALP]TYPQTY     = 2
# Les champs STA, LOC et LOT sont des filtres exclusifs (pas préférentiels)
#        [M:ALP]STA        = [M:MTK3]STA(LLIG)
#        If dim([M:MTK3]LOTPREF) > 0 : [M:ALP]LOT     = [M:MTK3]LOTPREF(LLIG) : Endif
#        If dim([M:MTK3]LOCPREF) > 0 : [M:ALP]LOC     = [M:MTK3]LOCPREF(LLIG) : Endif
        [M:ALP]PCU        = [M:MTK3]STU(LLIG)
        [M:ALP]PCUSTUCOE  = 1
        [M:ALP]TYPQTY     = 2
# 10.06 demande 38009
#       [M:ALP]BESDAT     = [M:MTK3]RETDAT(LLIG)
     [M:ALP]BESDAT     = [M:MTK0]MFGTRKDAT
        [M:ALP]STOLOC     = [M:MTK3]WSTLOC(LLIG)
        If [M:MTK3]MATTYP(LLIG) = 1 # Issue X3-65042 15/03/2018 by GEBIL - FILSTO of STKALL , VCRSEQORI wrong
            [M:ALP]VCRTYPORI  = 10
            [M:ALP]VCRNUMORI  = [M:MTK0]MFGNUM
            [M:ALP]VCRLINORI  = [M:MTK3]MFGLIN(LLIG)
            [M:ALP]VCRSEQORI  = [M:MTK3]BOMSEQ(LLIG)
            [M:ALP]ALLTYPORI  = [M:MTK3]ALLSTA(LLIG)
        Endif
        [M:ALP]PECQLYCTL  =  1
        # 08.05 demande 29188
        [M:ALP]PECSCOLOC  = 1
        If [M:MTK3]CPLWST(LLIG) <> ""
           If [F:MWS]WST <> [M:MTK3]CPLWST(LLIG) | [F:MWS]WCRFCY <> [M:MTK0]MFGFCY
               Read [F:MWS]WST0 = [M:MTK3]CPLWST(LLIG);[M:MTK0]MFGFCY
               If fstat : Raz [F:MWS] : Endif
           Endif
           If [F:MWS]WSTTYP = 3
              [M:ALP]PECSCOLOC  = 2
           Endif
         Endif
        [M:ALP]PECINTLOC  = 2
        [M:ALP]PECPLFLOC  = 2
        If dim([M:MTK3]WRH)>0 [M:ALP]WRH=[M:MTK3]WRH(LLIG) Endif
        # Issue 107513/8 - 2015-07-13 by JUSYN : Major version for stock
        If dim([M:MTK3]ECCVALMAJ)> 0
            [M:ALP]ECCVALMAJ = [M:MTK3]ECCVALMAJ(LLIG)
        Endif
    When "MBM"
        [M:ALP]TRSTYP     = 6
        [M:ALP]TRSCOD     = [M:MBM]TRSCODS
        [M:ALP]VCRTYP     = 12
        [M:ALP]STOFCY     = [M:MBM]FCY
        [M:ALP]ITMREF     = [M:MBM]ITMREF(LLIG)
        [M:ALP]QTY        = [M:MBM]USEQTY(LLIG)
        [M:ALP]TYPQTY     = 2
# Les champs STA, LOC et LOT sont des filtres exclusifs (pas préférentiels)
#        [M:ALP]STA        = [M:MBM]STA(LLIG)
#        If dim([M:MBM]LOTPREF) > 0 : [M:ALP]LOT        = [M:MBM]LOTPREF(LLIG) : Endif
#        If dim([M:MBM]LOCPREF) > 0 : [M:ALP]LOC        = [M:MBM]LOCPREF(LLIG) : Endif
        [M:ALP]PCU        = [M:MBM]STU(LLIG)
        [M:ALP]PCUSTUCOE  = 1
        [M:ALP]BESDAT     = [M:MBM]IPTDAT(LLIG)
        [M:ALP]STOLOC     = [M:MBM]WSTLOC(LLIG)
        If [M:MBM]MATTYP(LLIG) = 1 # & GVTMOD # Issue 48252 GH 26/09/2017 - no more conditionned by GVTMOD
            [M:ALP]VCRTYPORI  = 10
            [M:ALP]VCRNUMORI  = [M:MBM]MFGNUM(LLIG)
            [M:ALP]VCRLINORI  = [M:MBM]MFGLIN(LLIG)
            [M:ALP]VCRSEQORI  = [M:MBM]BOMSEQ(LLIG)
            [M:ALP]ALLTYPORI  = [M:MBM]ALLSTA(LLIG)
        Endif
        [M:ALP]PECQLYCTL  =  1
        # 08.05 demande 29188
        [M:ALP]PECSCOLOC  = 1
        If [M:MBM]CPLWST(LLIG) <> ""
           If [F:MWS]WST <> [M:MBM]CPLWST(LLIG) | [F:MWS]WCRFCY <> [M:MBM]FCY
               Read [F:MWS]WST0 = [M:MBM]CPLWST(LLIG);[M:MBM]FCY
               If fstat : Raz [F:MWS] : Endif
           Endif
           If [F:MWS]WSTTYP = 3
              [M:ALP]PECSCOLOC  = 2
           Endif
        Endif
        [M:ALP]PECINTLOC  = 2
        [M:ALP]PECPLFLOC  = 2
        If dim([M:MBM]WRH)>0 [M:ALP]WRH=[M:MBM]WRH(LLIG) Endif
        # Issue 107513/8 - 2015-07-13 by JUSYN : Major version for stock
        If dim([M:MBM]ECCVALMAJ)> 0
            [M:ALP]ECCVALMAJ = [M:MBM]ECCVALMAJ(LLIG)
        Endif
Endcase
End

$RAZMULTIVAL
# Issue 38672 GH 26/07/17 - reset fields with multiple values ($) with blank
If dim([M:MTK3]LOT)>0 & [M:MTK3]LOT(J)="$" : [M:MTK3]LOT(J)="" : Actzo [MTK3]LOT(J) : Endif
If dim([M:MTK3]SLO)>0 & [M:MTK3]SLO(J)="$" : [M:MTK3]SLO(J)="" : Actzo [MTK3]SLO(J) : Endif
If dim([M:MTK3]LOC)>0 & [M:MTK3]LOC(J)="$" : [M:MTK3]LOC(J)="" : Actzo [MTK3]LOC(J) : Endif
If dim([M:MTK3]STA)>0 & [M:MTK3]STA(J)="$" : [M:MTK3]STA(J)="" : Actzo [MTK3]STA(J) : Endif
If dim([M:MTK3]PALNUM)>0 & [M:MTK3]PALNUM(J)="$" : [M:MTK3]PALNUM(J)="" : Actzo [MTK3]PALNUM(J) : Endif
If dim([M:MTK3]CTRNUM)>0 & [M:MTK3]CTRNUM(J)="$" : [M:MTK3]CTRNUM(J)="" : Actzo [MTK3]CTRNUM(J) : Endif
Return

