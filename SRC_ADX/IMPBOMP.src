#<AdxTL>@(#)6.0.0.0 $Revision$
# Process used to import Production or sub-contracting BOM
# For Sub-contracting BOM, th


$ACTION
Case ACTION
    When "IMP_OUVRE"       :   Gosub OUVRE
    When "EXPORT"          :   Gosub EXPORT
    When "EXP_OUVRE"       :   Gosub EXP_OUVRE
    When "IMPORT"          :   Gosub IMPORT
    When "IMP_TAB"         :   Gosub IMP_ZONE
    When "IMP_ZONE"        :   Gosub IMP_ZONE
    When "AP_IMPORT"       :   Gosub AP_IMPORT
    When "IMP_VERIF_CRE"   :   Gosub IMP_VERIF_CREMOD
    When "IMP_VERIF_MOD"   :   Gosub IMP_VERIF_CREMOD
    When "IMP_RAZCRE"      :   Gosub IMP_RAZCRE
    When "IMP_APRES_CRE"   :   Gosub IMP_APRES_CREMOD
    When "IMP_APRES_MOD"   :   Gosub IMP_APRES_CREMOD
Endcase

Return

$OUVRE
If dim([L]LBOMALTTYP)<0
    Local Integer LBOMALTTYP   # Type of BOM to import (2=Production BOM, 3=Sub-contracting BOM)
Endif
If [L]LBOMALTTYP=0
    LBOMALTTYP = 2
Endif

Local Integer OKCHAMP
Local Integer SUPBOD : # 1=The component must be excluded or removed ; 2=The component must be excluded or revised

Local Integer NEWECC    # 1=import of a new version, 0 otherwise
Local Char LECCVALMAJ(GLONICVVAL)   # Version of the BOM to import
Local Char LECCVALMIN(GLONICVVAL)   # Version of the BOM to import
Local Date LSTRDAT                  # Start date of the version to import
Local Integer LBOMALT               # BOM code to use to create the version "In development"
Local Integer LECCERR               # error code
Local Integer LBOHBOMALT            # BOMALT in file to import
Local Integer LNBLIG                # Used to be sure that reintegration has been done correctly

Local Integer LREW      # flag to rewrite a record

Case LBOMALTTYP
    When 2 : GBOITE = "OBODP"
             # As object BOD is used, then the corresponding window is OBOD in which screens are BOH0 and BOD2 [BOD1]
             # => close BOD2 [BOD1] and open BOD1 [BOD1]
             If clalev([M:BOD1])>0 : Close Mask [BOD1] : Endif # bug 65549
             If clalev([M:BOD1])=0 : Local Mask BOD1 [BOD1] : Endif
             NOMMSK(1) = "BOD1"

    When 3 : GBOITE = "OBOS"
             If clalev([F:BOSI])=0 : Local File BOSIMP [BOSI] : Endif
Endcase

Gosub OUVRE_TEXTE
Return

#---------------------------------------------------------------------
$OUVRE_TEXTE

Gosub DECLARE_TEXTE From TRTX3IMP

Case ACTION
  When "IMP_OUVRE"    : G_IMPORT=1
  When "EXP_OUVRE"    : G_EXPORT=1
Endcase
#   textes BOM : Nomenclature Entête           ( texte *71 à *78 )
TSTCHAMP(1) ="BOH*71" : TSTCHAMP(2) ="BOH*72" : TSTCHAMP(3)="BOH*73" : TSTCHAMP(4) ="BOH*74"
TSTCHAMP(5) ="BOH*75" : TSTCHAMP(6) ="BOH*76" : TSTCHAMP(7)="BOH*77" : TSTCHAMP(8) ="BOH*78"

#   textes BOMD : Liens de nomenclature        ( texte *91 à *98 )
TSTCHAMP(21)="BOD*91" : TSTCHAMP(22)="BOD*92" : TSTCHAMP(23)="BOD*93" : TSTCHAMP(24)="BOD*94"
TSTCHAMP(25)="BOD*95" : TSTCHAMP(26)="BOD*96" : TSTCHAMP(27)="BOD*97" : TSTCHAMP(28)="BOD*98"

Local Char SAV_IMPFIC(10)
Gosub OUVRE_TEXTE From TRTX3IMP
Return

#---------------------------------------------------------------------
$EXP_OUVRE
If dim([L]LBOMALTTYP)<0
    Local Integer LBOMALTTYP : LBOMALTTYP = 2   # Type of BOM to import (2=Production BOM, 3=Sub-contracting BOM)
Endif

Local Char LEXPTRTGEN(GLONADC)
Case [L]LBOMALTTYP
    When 2 : LEXPTRTGEN = adxpno(2) # adxpno(1)=SUBEXPOBJ and adxpno(2)=script generated WWExxx
    When 3 : LEXPTRTGEN = adxpno(3)
             If clalev([BOD2])=0     : Local File BOMD [BOD2] : Endif
Endcase

If clalev ([F:EVL]) <= 0  : Local File ECCVAL [EVL]    : Endif # Issue X3-4337 - 2016-10-27 by ALSHE : BOM Export with version
If clalev ([F:BOH1]) <= 0  : Local File BOM [BOH1]    : Endif # Issue X3-4337 - 2016-10-27 by ALSHE : BOM Export with version
If clalev([F:BOD2])=0 : Local File BOMD [BOD2] : Endif        # Issue 120909 - 2017-01-13 by CCC
Gosub OUVRE_TEXTE
Return

#---------------------------------------------------------------------
$EXPORT
If [F:BOH]BOMALTTYP<>LBOMALTTYP : OK = 0 : Return : Endif

If EXPFIC="BOH" & !func ECCLIB.NBRCPN([BOH]ITMREF) # non versioned BOM
    If G_ENT
        Gosub EXP_RAZ_T1 From TRTX3IMP
        If dim([F:BOH]HEATEX)>0 & [F:BOH]HEATEX<>""
            G_CLE_CLOB=[F:BOH]HEATEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
        Endif
    Endif
# Issue X3-4337 - 2016-10-27 by ALSHE : BOM Export with version
Elsif EXPFIC="BOH" # versioned BOM
    If [BOH]ITMREF=[EVL]ITMREF # check if BOM items are already exported
        OK=0
        Return
    Endif
    If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif # read item for default BOM
    If [F:ITM]ITMREF<>[BOH]ITMREF
        Read [ITM]ITM0 = [BOH]ITMREF
        If fstat : Raz [F:ITM] : Endif
    Endif

    Filter [EVL] Where [EVL]ITMREF=[BOH]ITMREF & [EVL]ECCTYP=[BOH]BOMALTTYP
&                Order By Key EVLX=[EVL]USESTA Desc;[EVL]ITMREF;[EVL]ECCSEQ;[EVL]ECCTYP # new key for right order in export file
    For [EVL]EVLX(1) # read BOH1 only when [EVL]USESTA changes
        Read [BOH1]BOH0=[F:EVL]ITMREF;[F:EVL]BOMALT;[F:EVL]ECCTYP
        [F:BOH]=[F:BOH1]
        For [EVL]EVLX # Loop all versions first for "Available to use" and afterwards "In development"
            If G_ENT
                Gosub EXP_RAZ_T1 From TRTX3IMP
                If dim([F:BOH]HEATEX)>0 & [F:BOH]HEATEX<>""
                    G_CLE_CLOB=[F:BOH]HEATEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
                Endif
            Endif
            GIMP(1)=[F:EVL]ECCVALMAJ # assign header values of the version to export file
            GIMP(2)=[F:EVL]ECCVALMIN
            GIMP(3)=evalue("num$([F:ITM]ECCBOMALT"+num$(LBOMALTTYP)+"(0))")

            [F:BOH]BOHSTRDAT=[F:EVL]STRDAT
            [F:BOH]BOHENDDAT=[F:EVL]ENDDAT
            Gosub EXPORT0 From =LEXPTRTGEN
            NBEXP += 1
            # read detail lines to version
            For [BOD] Where
&               BOMALT=[F:BOH]BOMALT & ITMREF=[F:BOH]ITMREF & BOMALTTYP=[F:BOH]BOMALTTYP
&             & (BOMENDDAT>=[F:EVL]STRDAT | (CPNTYP=1 & BOMENDDAT=[F:EVL]STRDAT-1) | BOMENDDAT = [0/0/0])
&             & (BOMSTRDAT<=[F:EVL]ENDDAT | [F:EVL]ENDDAT=[0/0/0])

                # Issue 120909 - 2017-01-13 by CCC : If the last revision of a group is exclusion
                #                            => we have to set negative sequence (=> SUPBOD=1 instead of 2)
                If [F:BOD]ECCRLEGRP>0 & [F:BOD]BOMENDDAT=[F:EVL]STRDAT-1
                    Filter [BOD2] Where [F:BOD2]BOMALT=[F:BOH]BOMALT & [F:BOD2]ITMREF=[F:BOH]ITMREF & [F:BOD2]BOMALTTYP=[F:BOH]BOMALTTYP
&                                     & [F:BOD2]ECCRLEGRP=[F:BOD]ECCRLEGRP
&                                     & [F:BOD2]BOMSTRDAT>[F:BOD]BOMENDDAT
                    Look [BOD2] First
                    Filter [BOD2]
                    If fstat
                        [F:BOD]BOMSEQ *= -1 # It's the last modification of a group : it's excluded
                    Endif
                Endif

                Gosub EXPORT1 From =LEXPTRTGEN
            Next
            OK=1
            EXPFIC="BOH"
        Next
    Next
    Filter [EVL]
    Raz GIMP(1) : Raz GIMP(2) : Raz GIMP(3)
    OK=0
    EXPFIC="BOH"
# End issue X3-4337
Endif

If EXPFIC="BOD"
   Gosub EXP_RAZ_T3 From TRTX3IMP
   If G_DET
      Gosub EXP_RAZ_T3 From TRTX3IMP
      If dim([F:BOD]BOMTEXNUM)>0 & [F:BOD]BOMTEXNUM<>""
         G_CLE_CLOB=[F:BOD]BOMTEXNUM : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T3 From TRTX3IMP
      Endif
   Endif

    # Issue 115658 - 2016-11-18 by CCC : Use of BOSIMP table for service export in case of sub-contracting BOM
    If [L]LBOMALTTYP=3 & [F:BOD]CPNTYP=7
        Raz [F:BOSI]
        [F:BOSI] = [F:BOD]
        Gosub EXPORT2 From =LEXPTRTGEN
        OK=0
   Endif
Endif

Return

#---------------------------------------------------------------------
$AP_IMPORT
Case IMPFIC
    When "BOH"
      If RUPT
          ## GH 13/10/2011 bug 76972
          Call TST_CHAMP(IMPFIC,"BOMALTTYP",OKCHAMP) From SUBIMPOBJ
          If !OKCHAMP & [F:BOH]BOMALTTYP<>LBOMALTTYP
            [F:BOH]BOMALTTYP=LBOMALTTYP
          Endif

        LECCVALMAJ = GIMP(1)
        LECCVALMIN = GIMP(2)
        LSTRDAT    = [F:BOH]BOHSTRDAT
        LBOMALT    = val(GIMP(3))
        # If import of "in development' status => BOM code in BOMALT is the one to use as "default BOM code for in development status"
        If [F:BOH]USESTA=1 & [F:BOH]BOMALT>0 & [F:BOH]BOMALT<99
            LBOMALT = [F:BOH]BOMALT
        Endif
        LBOHBOMALT = [F:BOH]BOMALT

        NEWECC = 0
        SAV_USESTA = [F:BOH]USESTA

        LECCERR = 0
        Gosub ECCCTL
        If OK & LNBCPN>0
            Readlock [ITM]ITM0=[F:BOH]ITMREF
            If fstat
                OK=0
                Call FSTA("ITM") From GLOCK
            Else
                Raz LREW
                If evalue("[F:ITM]ECCBOMALT"+num$(LBOMALTTYP)+"(0)") <> LBOMALT
                    Assign "[F:ITM]ECCBOMALT"+num$(LBOMALTTYP)+"(0)" With LBOMALT
                    LREW = 1
                Endif
                If [F:BOH]USESTA=2 & evalue("[F:ITM]ECCBOMALT"+num$(LBOMALTTYP)+"(1)")<>[F:BOH]BOMALT
                    Assign "[F:ITM]ECCBOMALT"+num$(LBOMALTTYP)+"(1)" With [F:BOH]BOMALT
                    LREW = 1
                Endif
                If LREW=1
                    Rewrite [ITM]
                Else
                    Unlock [ITM]
                Endif
            Endif
            # Before screens loading, we have to create the revision if needed
            If NEWECC=2
                # Creation of 'In development'
                If clalev([F:EVL2])=0 : Local File ECCVAL [EVL2] : Endif
                Filter [EVL2] Where [EVL2]ITMREF=[F:BOH]ITMREF & [EVL2]ECCTYP=[F:BOH]BOMALTTYP & [EVL2]USESTA=2
                # A version "available to use" exists
                If rowcount([EVL2])>0
                    Filter [EVL2] Where [EVL2]ITMREF=[F:BOH]ITMREF & [EVL2]ECCTYP=[F:BOH]BOMALTTYP & [EVL2]USESTA=1
                    # No version "In development" exists => revision action
                    If rowcount([EVL2])=0
                        If clalev([F:BOH2])=0 : Local File BOM [BOH2] : Endif
                        [F:BOH2] = [F:BOH]
                        # "D" means : don't control if start date is in the past
                        If instr(1,GIMP(4),"D")
                            Call TR_EXEC2([F:BOH]ITMREF, [F:BOH]BOMALTTYP, LSTRDAT, LECCVALMAJ, LECCVALMIN, "CREEVL","D") From CREEVL
                        Else
                            Call TR_EXEC2([F:BOH]ITMREF, [F:BOH]BOMALTTYP, LSTRDAT, LECCVALMAJ, LECCVALMIN, "CREEVL","") From CREEVL
                        Endif
                        [F:BOH] = [F:BOH2]
                        If GERR
                            LECCERR = 100
                            Gosub IMPERR
                        Endif
                    Endif
                Endif
                Filter [EVL2]
            Endif

            If NEWECC & [F:BOH]USESTA=2   # If new version of an available to use, change USESTA to "In development"
                If [F:ITM]ITMREF<>[F:BOH]ITMREF
                    Read [ITM]ITM0=[F:BOH]ITMREF
                Endif

                [F:BOH]USESTA  = 1
                [F:BOH]BOMALT  = LBOMALT
                If [F:BOH]BOMALT=0
                    [F:BOH]BOMALT=evalue("[F:ITM]ECCBOMALT"+num$(LBOMALTTYP)+"(0)")
                Endif
            Endif
        Endif

        ## GH 25/10/2012 bug 79196
        If [F:BOH]BOMALTTYP<>0
            Trbegin [AXX]
                If [F:BOH]BOMALT<>LBOHBOMALT
                    Call SUPTEXLAN("BOM","BOMDESAXX","imp",[F:BOH]ITMREF+"~"+num$([F:BOH]BOMALT),num$(LBOMALTTYP)) From ATEXTRA  # Security if an old one already exists
                Endif
                Read [AXX]AXX0 = "BOM";"BOMDESAXX";"imp";[F:BOH]ITMREF+"~"+num$(LBOHBOMALT);'0'
                If fstat
                    Read [AXX]AXX0 = "BOM";"BOMDESAXX";"imp";[F:BOH]ITMREF+"~"+num$(LBOHBOMALT);num$(LBOMALTTYP)
                Endif
                If !fstat
                    # As BOM status is created "in development" instead of "available to use" as it's written in the file to import
                    # we have to change the key of ATEXTRA from "available to use" BOM code to "in development" BOM code
                    [F:AXX]IDENT1=[F:BOH]ITMREF+"~"+num$([F:BOH]BOMALT)
                    # As temporary record for BOMDESAXX is recorded
                    [F:AXX]IDENT2=num$([F:BOH]BOMALTTYP)
                    Rewrite [AXX]
                Endif
            Commit
        Endif
      Endif

    When "BOD", "BOSI"
      If LBOMALTTYP=3
          # For this type of BOM, CPNTYP is not enterable
          #  - material section : CPNTYP=1  (error managed only if CPNTYP is set to 7 to indicate to change section in the file)
          #  - service section : CPNTYP=7
          If IMPFIC="BOD"
            If [F:BOD]CPNTYP=7
                LECCERR = 11
                Gosub IMPERR
            Else
                [F:BOD]CPNTYP=1
            Endif
          Else
            [F:BOD]CPNTYP=7
          Endif
      Endif

      If OK
        Gosub ECCCTL
        If OK & LNBCPN>0
            If [F:BOD]CPNTYP=1
              If [F:BOD]BOMSTRDAT=[0/0/0]
                  [F:BOD]BOMSTRDAT = LSTRDAT
              Endif
            Endif
        Endif
    Endif
Endcase
Return

#---------------------------------------------------------------------
$IMP_RAZCRE
    Call LOGDBG("IMP_RAZCRE"-[F:BOH]ITMREF-mess([F:BOH]BOMALTTYP,224,1)-num$(LSTRDAT)-"version="+LECCVALMAJ+"/"+LECCVALMIN)
Return

#---------------------------------------------------------------------
$IMPORT
If LECCERR>0 | GREP=""
    OK=0
    Return
Endif

Case IMPFIC
    When "BOH":
# ---------------------------------------------------#
#     Entête de nomenclature                         #
# ---------------------------------------------------#
        # If [F:BOH]BOMALTTYP=0 :[F:BOH]BOMALTTYP=2 : Endif : ## GH 13/10/2011 bug 76972

# Issue 115658 - 2016-10-24 by CCC : Control is done by actions in the screen
#        If [F:TBO]BOMALT <> [F:BOH]BOMALT | [F:TBO]BOMALTTYP <> [F:BOH]BOMALTTYP
#            Read [TBO]TBO0=[F:BOH]BOMALTTYP;[F:BOH]BOMALT
#            If fstat : Raz [F:TBO] : Endif
#        Endif
#        If [F:TBO]BOMALTTYP <> 2
#            Call ECR_TRACE(mess(225,199,1),1) From GESECRAN
#            OK = 0
#        Endif

        If dim([M:BOH0]BOHECCMAJ)>0 & LECCVALMAJ<>""
            [M:BOH0]BOHECCMAJ = LECCVALMAJ
            [M:BOH0]BOHECCMIN = LECCVALMIN
            If NEWECC=1
                [M:BOH0]ECCSEQ=-1
            Endif
        Endif

    When "BOD","BOSI":
# ---------------------------------------------------#
#     Lien de nomenclature                           #
# ---------------------------------------------------#
        Gosub IMP_DECLARE From TRTX3IMP

        # Is it a new line or not ?

        # Default mask to search in the right grid
        Case IMPFIC
            When "BOD" : Default Mask [BOD1]
                         SUPBOD = ([F:BOD]BOMSEQ<0)
                         If SUPBOD : [F:BOD]BOMSEQ*=-1
                         # Issue 120233 - 2017-01-09 by CCC :
                         Elsif LNBCPN>0 & NEWECC=2 & [F:BOD]BOMENDDAT=LSTRDAT-1
                             SUPBOD=2   # Need to exclude OR revise the line
                         Endif
            When "BOSI" : Default Mask [BOS2]
                         SUPBOD = ([F:BOSI]BOMSEQ<0)
                         If SUPBOD : [F:BOSI]BOMSEQ*=-1 : Endif
        Endcase
        If IMPFIC="BOD" & [F:BOD]CPNITMREF<>""
&        | IMPFIC="BOSI"
         ICLEPRIM (0) = "[F:"+IMPFIC+"]BOMSEQ" :  ICLESEC (0) = "[F:"+IMPFIC+"]CPNITMREF"
         TPRIM(0)     = "BOMSEQ"               :  TSEC(0)     = "CPNITMREF"
         NBASTAB = "NBLIG"
         Gosub RECHERCHE_LIGNE From TRTX3IMP
         Call LOGDBG("RECHERCHE_LIGNE --> nolign="+num$(nolign))
        Else : ## GH 13/10/2011 bug 76972 ## Gosub RECHERCHE_LIGNE From TRTX3IMP ne fonctionne pas avec [F:BOD]CPNITMREF=""
         nolign=0
         For I=0 To [M]NBLIG-1
          If [M]CPNITMREF(I)="" & [M]BOMSEQ(I)=[F:BOD]BOMSEQ
           nolign=I+1 : Break
          Endif
         Next
        Endif

        If LNBCPN>0 & nolign=0 & (IMPFIC="BOD" & [F:BOD]CPNTYP=1) & [M:BOH0]USESTA=2 & GREP="M"
            LECCERR=9
            Gosub IMPERR
        Endif

        # Issue 115658 (X3-4335) CCC : Line revision
        #----- REVISION
        If IMPFIC="BOD" & LNBCPN>0 & SUPBOD<>1
            If [F:BOD]ECCRLEGRP>0
                Call LOGDBG("Line revision : [F:BOD]ECCRLEGRP="+num$([F:BOD]ECCRLEGRP)-"nolign="+num$(nolign))
                If nolign>0 & [M:BOD1]ECCGRPIMP(nolign-1)=0
                    # Line to revise
                    If [M:BOH0]USESTA=1 & [M:BOD1]CPNTYP(nolign-1)=1 & [M:BOH0]ECCDAT<>[0/0/0]
&                    & [M:BOD1]BOMSTRDAT(nolign-1)<[M:BOH0]ECCDAT
&                    & [M:BOD1]BOMENDDAT(nolign-1)=[M:BOH0]BOHENDDAT
                        # we have to revise the line
                        Call LOGDBG("Revision of line nolign="+num$(nolign))
                        SUPBOD=0    # Security
                        Call B10_NBLIG From ECCBOM
                        If mkstat>0
                            LECCERR=100
                            Gosub IMPERR
                        Else
                            # nolign is the line number of the line revised (the origin)
                            # store group number in the new line
                            [M:BOD1]ECCGRPIMP(nolign) = [F:BOD]ECCRLEGRP
                        Endif
                    Elsif [M:BOD1]ECCRLEGRP(nolign-1)=0
                        # This line can't be revised
                        Call ECR_TRACE([F:BOD]ITMREF-num$([F:BOD]BOMSEQ)-[F:BOD]CPNITMREF-"This line can't be revised",-1) From GESECRAN
                    Endif
                Else
                    If nolign=0
                        # New line revised
                        nolign = find([F:BOD]ECCRLEGRP,[M:BOD1]ECCGRPIMP)
                    Elsif [F:BOD]ECCRLEGRP<>[M:BOD1]ECCGRPIMP(nolign-1)
                        # The revison can't be applied with this record because the group number is not the same as expected
                        nolign = 0
                    Endif
                    If nolign>0
                        Call LOGDBG("Revised line found --> set [M:BOD1]ECCGRPIMP("+num$(nolign-1)+") to 0")
                        [M:BOD1]ECCGRPIMP(nolign-1) = 0
                    Else
                        # This line can’t be integrated in a group of revision
                        #Call ECR_TRACE([M:BOH0]ITMREF-num$([F:BOD]BOMSEQ)-[F:BOD]CPNITMREF-mess(386,193,1),-1) From GESECRAN
                        # no message because it can be normal : when importing the first version, a component in a later version can have already a group number
                        [F:BOD]ECCRLEGRP=0
                    Endif
                Endif
            Elsif nolign>0 & [M:BOD1]CREFLG(nolign-1)=0
                # Attempt to modify a line which is being created
                LECCERR=12
                Gosub IMPERR
            Endif
        Endif

#      #-----------------------------------------------#
#      # Cas de la suppression de ligne (Sequence < 0) #
#      #-----------------------------------------------#
       If    SUPBOD & nolign=0
         Call ECR_TRACE(evalue("[F:"+IMPFIC+"]CPNITMREF")-evalue("num$(-[F:"+IMPFIC+"]BOMSEQ)")-":"-mess(77,9005,1),1) From GESECRAN
         OK = 0
       Elsif SUPBOD & nolign<>0
         If IMPFIC="BOD" & LNBCPN>0
&         & !(dim([M:BOH0]ECCSEQ)<>1 | [M:BOH0]USESTA=2 | [M:BOD1]CPNTYP(nolign-1)<>1 | [M:BOH0]ECCDAT=[0/0/0])
&         & [M:BOD1]BOMENDDAT(nolign-1)=[M:BOH0]BOHENDDAT & [M:BOD1]BOMSTRDAT(nolign-1)<>[M:BOH0]ECCDAT
             Call EXCLUDE_LINE(nolign-1)
         Else
             status=65
             If IMPFIC="BOD"
                 Call C_NBLIG From SUBBOD   # check if deletion is possible
                 If !mkstat
                     Call AVANT_NBLIG From SUBBOD
                     Call APRES_NBLIG From SUBBOD
                 Endif
             Else
                 Call AVANT_NBLIG From SUBBODB
                 Call APRES_NBLIG From SUBBODB
             Endif

             If mkstat
                LECCERR=100
                GMESSAGE -= [F:BOH]ITMREF-LECCVALMAJ-LECCVALMIN-mess(203,190,1)+"="+evalue("[F:"+IMPFIC+"]CPNITMREF")-"BOMSEQ="-evalue("num$(-[F:"+IMPFIC+"]BOMSEQ)")
                Gosub IMPERR
             Endif
         Endif
       Endif
Endcase
Gosub IMPORT_TEXTE
Return

#---------------------------------------------------------------------
$IMPORT_TEXTE
If IMPFIC="BOH" & G_ENT
   Raz [M:ITC]T_CLE_CLOB(1)
   Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
   [M:ITC]T_CLE_CLOB(1)=G_CLE_CLOB
Endif
If find(IMPFIC,"BOD","BOSI") & G_DET
   Raz [M:ITC]T_CLE_CLOB(3)
   SAV_IMPFIC=IMPFIC
   IMPFIC="BOD"
   Gosub IMP_T3 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
   [M:ITC]T_CLE_CLOB(3)=G_CLE_CLOB
   IMPFIC=SAV_IMPFIC
Endif

Return

######################################################################
$IMP_ZONE
Case IMPFIC
  When "BOH"
       If G_ENT & [M:ITC]T_CLE_CLOB(1)<>""
         [M:BOH0]HEATEX=[M:ITC]T_CLE_CLOB(1)
       Endif
   # As soon as a field is enterable we record the key for text.
   # because we don't know which field are enterable
  When "BOD"
       If G_DET & nolign>0
          [M:BOD1]BOMTEXNUM(nolign-1)=[M:ITC]T_CLE_CLOB(3)
       Endif
  When "BOSI"
       If G_DET & nolign>0
          [M:BOS2]BOMTEXNUM(nolign-1)=[M:ITC]T_CLE_CLOB(3)
       Endif
Endcase
Return

######################################################################
$IMP_VERIF_CREMOD
Call LOGDBG("adxlog="+num$(adxlog)-"NEWECC="+num$(NEWECC)-"LECCERR="+num$(LECCERR))

If LECCERR=0
    # Issue 115658 (X3-4335) CCC : Line revision
    Default Mask [BOD1]
    For nolign=1 To [M:BOD1]NBLIG
        # A revision has been initiated but not finished => reintegrate the origin line
        If [M:BOD1]ECCGRPIMP(nolign-1)>0
            nolign -= 1
            Call LOGDBG("Reintegrate line "+num$(nolign))
            LNBLIG=[M:BOD1]NBLIG
            Call B12_NBLIG From ECCBOM
            If LNBLIG=[M:BOD1]NBLIG
                LECCERR=13
                Gosub IMPERR
                Break
            Endif
        Endif
    Next
Endif

If LECCERR>0
    OK=0
    Return
Endif
Return

######################################################################
$IMP_APRES_CREMOD
Call LOGDBG("IMP_APRES_CREMOD adxlog="+num$(adxlog)-"sav_usesta="+num$(SAV_USESTA)-"[m:boh0]USESTA="+num$([M:BOH0]USESTA))
If SAV_USESTA=2 & [M:BOH0]USESTA=1
    # The new version has to be validated
    #Infbox "Validation version"-[M:BOH0]ITMREF-"type="+mess([M:BOH0]BOMALTTYP,224,1)-num$(adxlog)
    #Dbgaff
    Call LOGDBG("Validation version"-[M:BOH0]ITMREF-"type="+mess([M:BOH0]BOMALTTYP,224,1)-num$(adxlog))
    Call TR_EXEC2([M:BOH0]ITMREF, [M:BOH0]BOMALTTYP) From VALEVL
    If GERR
        LECCERR=100
        Gosub IMPERR
    Endif
Endif
Return

############################################################
# ECCCTL : Controls linked to versioning
############################################################
# Parametres E : PFIL = file to control
#            S : POK : 0 if Error otherwise don't change
############################################################
$ECCCTL

Local Integer LNBCPN            # Number of part in version number
Local Integer STAT              # return code
Local Char LECC(GLONICVVAL)     # temporary variable to get version number

Call LOGDBG("----- Call ECCCTL"-IMPFIC-"default masks="+dbgstr(1)-"------------")

If clalev([F:BOH2])=0 : Local File BOM [BOH2] : Endif
If clalev([F:EVL2])=0 : Local File ECCVAL [EVL2] : Endif

LNBCPN = func ECCLIB.NBRCPN([F:BOH]ITMREF)

Case IMPFIC
    When "BOH" :
        If func DEBUG
            Call FIL2XLS2("BOM","BOH",1,"","","",2) From ZEXTRACTSTJ
        Endif
        # If product managed by version
        If LNBCPN>0
            # If import of "In development", it must already exist or no other "in development" should exist
            If LSTRDAT=[0/0/0]
                LECCERR=6
                Gosub IMPERR
                Return
            Endif
            Read [EVL2]EVL1=[F:BOH]ITMREF;LECCVALMAJ;LECCVALMIN;[F:BOH]BOMALTTYP
            If !fstat
                If [F:BOH]USESTA<>[F:EVL2]USESTA
                    LECCERR=3
                    Gosub IMPERR
                    Return
                Elsif [F:BOH]USESTA=2
                    # It's possible to modify an available to use version only with not normal component
                    # Control done later
                Endif
            Elsif fstat
                # Control new version number
                Filter [EVL2] Where [EVL2]ITMREF=[F:BOH]ITMREF & [EVL2]ECCTYP=[F:BOH]BOMALTTYP
                Read [EVL2]EVL1 Last
                Filter [EVL2]
                # Check if a BOM in development already exists with another version number
                If [F:EVL2]USESTA=1 & [F:BOH]USESTA=1
&                & ( [F:EVL2]ECCVALMAJ<>LECCVALMAJ
&                  | [F:EVL2]ECCVALMIN<>LECCVALMIN)
                    LECCERR=7
                    Gosub IMPERR  # BOH in development already exists with another version number
                    Return
                Elsif !fstat
                    If [F:ITM]ITMREF<>[F:BOH]ITMREF
                        Read [ITM]ITM0=[F:BOH]ITMREF
                    Endif
                    If [F:EVL2]ECCVALMAJ=LECCVALMAJ
                        # same Major version => control new minor version
                        Call CALCUL([F:ITM]ECCMIN, [F:EVL2]ECCVALMIN, LECC, GMESSAGE, STAT) From SUBICV
                        If STAT
                            LECCERR=100
                            Gosub IMPERR
                            Return
                        Elsif LECCVALMIN<>LECC
                            LECCERR=4
                            Gosub IMPERR      # New minor version incorrect
                            Return
                        Endif
                    Else
                        # new major version => control all
                        Call CALCUL([F:ITM]ECCMAJ,[F:EVL2]ECCVALMAJ,LECC,GMESSAGE,STAT) From SUBICV
                        If LECCVALMAJ<>LECC
                            LECCERR=4
                            Gosub IMPERR      # New major version incorrect
                            Return
                        Elsif LNBCPN=2
                            Call CALCUL([F:ITM]ECCMIN,"",LECC,GMESSAGE,STAT) From SUBICV
                            If LECCVALMIN<>LECC
                                LECCERR=4
                                Gosub IMPERR      # New minor version incorrect
                                Return
                            Endif
                        Endif
                    Endif
                    If OK
                        Call LOGDBG("New version is correct : old="+[F:EVL2]ECCVALMAJ-[F:EVL2]ECCVALMIN-"new="+LECCVALMAJ-LECCVALMIN)
                    Endif
                    NEWECC=2
                Else
                    # No version exists => control format
                    Call LOGDBG("No version exists => creation of the first version :"-[F:BOH]ITMREF-LECCVALMAJ-LECCVALMIN)
                    If !func ECCLIB.CTLCPN([F:BOH]ITMREF,1,LECCVALMAJ,LECC)
                        LECCERR=8
                        Gosub IMPERR
                        Return
                    Elsif LNBCPN=2 & !func ECCLIB.CTLCPN([F:BOH]ITMREF,2,LECCVALMIN,LECC)
                        LECCERR=8
                        Gosub IMPERR
                        Return
                    Else
                        NEWECC=1
                    Endif
                Endif
                If OK
                    If (LBOMALT<=0 | LBOMALT>99)
                        If evalue("[F:ITM]ECCBOMALT"+num$(LBOMALTTYP)+"(0)")=0
                            LECCERR=5
                            Gosub IMPERR
                            Return
                        Else
                            LBOMALT=evalue("[F:ITM]ECCBOMALT"+num$(LBOMALTTYP)+"(0)")
                        Endif
                    Endif
                Endif
            Endif
            If OK
                # Control consistency of BOMALT with values in [ITM]
                Filter [BOH2] Where ITMREF=[F:BOH]ITMREF
&                                 & ( BOMALT=[F:BOH]BOMALT & USESTA<>[F:BOH]USESTA
&                                   | BOMALT<>[F:BOH]BOMALT & USESTA=[F:BOH]USESTA)
                If rowcount([BOH2])>0
                    LECCERR=2
                    Gosub IMPERR
                    Return
                Endif
                Filter [BOH2]
            Endif
        Endif

    When "BOD" :
        If func DEBUG
            Call FIL2XLS2("BOMD","BOD",1,"","","",2) From ZEXTRACTSTJ
        Endif
Endcase

Return

##############################################
# Write the error message in the log
$IMPERR
OK=0	# Issue 120837 - 2017-01-11 by CCC : it allows to continue other tests for nothing
Case LECCERR
    When 2 : # Wrong BOM code ($1$). Use $2$ for status $3$
             # Issue 120233 - 2016-12-06 by CCC
             #GMESSAGE = func AFNC.MES3(mess(371,193,1),num$([F:BOH]BOMALT),num$([F:ITM]ECCBOMALT3([F:BOH]USESTA-1)),mess([F:BOH]USESTA,240,1))
             GMESSAGE = func AFNC.MES3(mess(371,193,1),
&                                      num$([F:BOH]BOMALT),
&                                      num$(evalue("[F:ITM]ECCBOMALT"+num$([F:BOH]BOMALTTYP)+"("+num$([F:BOH]USESTA-1)+")")),
&                                      mess([F:BOH]USESTA,240,1))

    When 3 : # This version already exists with another status : $1$
             GMESSAGE = func AFNC.MES1(mess(372,193,1),[F:BOH]ITMREF-LECCVALMAJ-LECCVALMIN)

    When 4 : # Incorrect new version number
             GMESSAGE = mess(373,193,1)-[F:BOH]ITMREF-LECCVALMAJ-LECCVALMIN

    When 5 : # BOM code for 'In development' status has not been defined
             GMESSAGE = mess(374,193,1)

    When 6 : # Start date is mandatory
             GMESSAGE = mess(502,177,1)-[F:BOH]ITMREF-LECCVALMAJ-LECCVALMIN

    When 7 : # A version in development already exists ($1$). Impossible to import this version: $2$
             GMESSAGE = [F:BOH]ITMREF-func AFNC.MES2(mess(375,193,1), [F:EVL2]ECCVALMAJ-[F:EVL2]ECCVALMIN,LECCVALMAJ-LECCVALMIN)

    When 8 : # Incorrect version format
             If LECC=""
                 GMESSAGE = mess(209,187,1)
             Else
                 GMESSAGE = [F:BOH]ITMREF-LECCVALMAJ-LECCVALMIN-mess(209,187,1)-"("+LECC+")"+GMESSAGE
             Endif
    When 9 : # A 'Normal' component can't be added to an existing available to use BOM version
             GMESSAGE = mess(376,193,1)+"\"
&                      -[F:BOH]ITMREF-LECCVALMAJ-LECCVALMIN-mess(203,190,1)+"="+[F:BOD]CPNITMREF-"BOMSEQ="-num$([F:BOD]BOMSEQ)

    When 10: # $1$ Component type ($2$) is not correct
             GMESSAGE = func AFNC.MES2(mess(377,193,1),[F:BOH]ITMREF-LECCVALMAJ-LECCVALMIN-[F:BOD]CPNITMREF, mess([F:BOD]CPNTYP,438,1))

    When 11: # Service $1$ has to use another indicator in the file
             GMESSAGE = func AFNC.MES1(mess(378,193,1), [F:BOD]CPNITMREF)-[F:BOH]ITMREF-LECCVALMAJ-LECCVALMIN

    When 12: # Attempt to modify a line which is being created
             GMESSAGE = [M:BOH0]ITMREF-num$([F:BOD]BOMSEQ)-[F:BOD]CPNITMREF-mess(384,193,1)

    When 13: # Reintegration failed
             GMESSAGE = [M:BOH0]ITMREF-num$([M:BOD1]BOMSEQ(nolign-1))-[M:BOD1]CPNITMREF(nolign-1)-mess(385,193,1)

    When 100 : # GMESSAGE already set
Endcase
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Raz GMESSAGE
Return

Subprog EXCLUDE_LINE(PLIN)
Value Integer PLIN
# Based on SUBBOD.B11_NBLIG

Call LOGDBG("EXCLUDE_LINE line="-num$(nolign-1)-"[M:BOD1]BOMENDDAT(PLIN)="+num$([M:BOD1]BOMENDDAT(PLIN))-"[M:BOH0]ECCDAT="+num$([M:BOH0]ECCDAT))
If !([M:BOD1]BOMENDDAT(PLIN)=[M:BOH0]BOHENDDAT & [M:BOD1]BOMSTRDAT(PLIN)<>[M:BOH0]ECCDAT) : End : Endif

[M:BOD1]UPDFLG(PLIN)=1
[M:BOD1]BOMENDDAT(PLIN)=[M:BOH0]ECCDAT-1
Call LOGDBG("line excluded [M:BOD1]BOMENDDAT(PLIN)="+num$([M:BOD1]BOMENDDAT(PLIN)))
End

Funprog DEBUG
If GTRACE<>"" & GUSER="xCCC"
    End 1
Endif
End 0

Subprog LOGDBG(PMES)
Value Char PMES
If (GSTOTRACE=4 | func DEBUG)
    Call ECR_TRACE(num$(val(timestamp$)/1000) - PMES,0) From GESECRAN
    Call FLUSH_TRACE From GESECRAN
Endif
End

