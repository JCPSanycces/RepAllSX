#############################################################################################
#  Composant de gestion automatisée du parc client            Module CRM       4 Avril 2003 
#  Table des historiques des implantations
#
#
# MAIRULE : Sous-programme d'application des règles de gestion relative aux historiques d'implantation
#
#############################################################################################
#############################################################################################
# Sous-programme d'application des règles de gestion relative aux historiques d'implantation
#############################################################################################
Subprog MAIRULE(IACTION, SZMAC, ICLSNUM, IERRINF)
Value Integer IACTION
Value Char SZMAC
Value Integer ICLSNUM
Variable Integer IERRINF

  #IACTION : Type d'action déclenchant l'intégration.
  # 1 = Restauration de la dernière implantation d'une fiche parc
  # 2 = Autre
  #SZMAC : Première composante de clé de la fiche implantation à traiter
  #ICLSNUM : Deuxième composante de clé de la fiche implantation à traiter
  IERRINF = 0
  # Ouverture des tables nécessaires
  If !clalev([F:MAIR]) : Local File MACITN [MAIR] : Endif
  #Déclaration des variables principales
  #Obtention des caractéristiques principales
  Case IACTION
    When 1
      Gosub DORESTORE
    When 2
      Gosub DOOTHER
    When Default
  Endcase
End

###############################################################
#Restauration de la dernière implantation d'une fiche parc
$DORESTORE
Local Char SZFIELDS(10)(19)

  #Mise à jour de la fiche parc
  Read [MAIR]MAI1=SZMAC;ICLSNUM
  If fstat Then
    #Erreur lors de la restauration de l'implantation.
    IERRINF = 127
    Return
  Endif
  #Charge le masque MACW
  Local Mask MACW [MACW]
  Raz [M:MACW]
  [M:MACW]MACITNTYP = [F:MAIR]ITNTYP
  SZFIELDS(0) = "MACITNTYP"
  If [F:MAIR]BPCTYP = "" Then
    [M:MACW]BPCNUM = ""
    [M:MACW]FCYITN = ""
    [M:MACW]CCNNUM = ""
    [M:MACW]MACCUTBPC = ""
  Else
    If [F:MAIR]BPCTYP = "BPC" Then
      [M:MACW]BPCNUM = [F:MAIR]BPC
      [M:MACW]FCYITN = [F:MAIR]ITNFCY
      [M:MACW]CCNNUM = ""
    Elsif [F:MAIR]BPCTYP = "CCN" Then
      [M:MACW]BPCNUM = ""
      [M:MACW]FCYITN = ""
      [M:MACW]CCNNUM = [F:MAIR]BPC
    Endif
    [M:MACW]MACCUTBPC = [F:MAIR]BPC
  Endif
  SZFIELDS(1) = "BPCNUM"
  SZFIELDS(2) = "FCYITN"
  SZFIELDS(3) = "CCNNUM"
  SZFIELDS(4) = "MACCUTBPC"
  [M:MACW]MACORI = [F:MAIR]ORI
  SZFIELDS(5) = "MACORI"
  [M:MACW]MACORIVCR = [F:MAIR]ORIVCR
  SZFIELDS(6) = "MACORIVCR"
  [M:MACW]MACORIVCRL = [F:MAIR]ORIVCRL
  SZFIELDS(7) = "MACORIVCRL"
  [M:MACW]MACITNDAT = [F:MAIR]ITNDAT
  SZFIELDS(8) = "MACITNDAT"
  [M:MACW]MACITNLND = [F:MAIR]LND
  SZFIELDS(9) = "MACITNLND"
  [M:MACW]MACRSL = [F:MAIR]RSL
  SZFIELDS(10) = "MACRSL"
  [M:MACW]MACSALPRI = [F:MAIR]SALPRI
  SZFIELDS(11) = "MACSALPRI"
  [M:MACW]CUR = [F:MAIR]CUR
  SZFIELDS(12) = "CUR"
  [M:MACW]MACPURDAT = [F:MAIR]PURDAT
  SZFIELDS(13) = "MACPURDAT"
  [M:MACW]MACBPCPRI = [F:MAIR]BPCPRI
  SZFIELDS(14) = "MACBPCPRI"
  [M:MACW]MACBPCDAT = [F:MAIR]BPCDAT
  SZFIELDS(15) = "MACBPCDAT"
  [M:MACW]MACBPCCUR = [F:MAIR]BPCCUR
  SZFIELDS(16) = "MACBPCCUR"
  [M:MACW]PLE = [F:MAIR]PLE
  SZFIELDS(17) = "PLE"
  Call UPDPARC(SZMAC, SZFIELDS, IERRINF) From SUBMACC
  If IERRINF Then
    Close Local Mask [MACW]
    Return
  Endif
  #Suppression de la dernière implantation
  Call DELMAI(SZMAC, ICLSNUM, IERRINF) From SUBMACC
  Close Local Mask [MACW]
Return

###############################################################
#Gestion de l'implantation parc depuis on ne sait pas quoi
$DOOTHER
Return
