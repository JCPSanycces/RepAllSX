###########################################################
# SUPSCS : Supprime un document (limité au transfert)
#          Seules les lignes pouvant être supprimées le sont (demande de confirmation)
###########################################################
Subprog SUPSCS
Local Integer  I
Local Decimal  WSTUDIS, WPCUDIS, WSTUACTDIS
Local Decimal  WDISA, WDISQ, WDISR, WGLOALL
Local Decimal  WSTODISTOT, WSTOCOU
Local Integer  WISTA, WILOC, WOK
Local Decimal  WTOTQTY
Local Integer  LRET
Local Shortint WRET
Local Char     WOWN(GLONBPF)

Raz I

Call DEBTRANS From GLOCK
# Vérification suppression
For I=0 To [M:SCS1]NBLIG-1
    [M:SCS1]WSTOFLG(I) = 1
    #-------- Vérification des entrées négatives ----------#
    WTOTQTY = 0
    Read [ITM]ITM0=[M:SCS1]ITMREF(I)
    Read [ITV]ITV0=[M:SCS1]ITMREF(I);[M:SCS1]FCYDES
    Read [ITG]ITG0=[F:ITM]TCLCOD;[M:SCS1]FCYDES
    If fstat
        Read [ITG]ITG0=[F:ITM]TCLCOD;""
    Endif
    # Si suppression d'une ligne dont on n'est pas propriétaire du stock
    If [M:SCS1]OWNER(I)<>[M:SCS1]FCYDES
       WOWN = [M:SCS1]OWNER(I)
    Else
       WOWN = ""
    Endif
    Call STODISMOD("",1,7,WOWN,WDISA,WDISQ,WDISR,WGLOALL) From STKLIB
    For [STJ]STJ1 Where STOFCY=[M:SCS1]FCYDES
&                     & VCRTYP=[M:SCS1]VCRTYP
&                     & VCRNUM=[M:SCS1]VCRNUM
&                     & VCRLIN=[M:SCS1]VCRLIN(I)
&                     & QTYSTU>0
        WDISA -= [F:STJ]QTYSTU*(left$([F:STJ]STA,1)="A")
        WDISQ -= [F:STJ]QTYSTU*(left$([F:STJ]STA,1)="Q")
        WDISR -= [F:STJ]QTYSTU*(left$([F:STJ]STA,1)="R")

        #--- Issue X3-53322 : Ajout LPN
        Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&                   [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,
&                   [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&                   [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,[L]WSTOCOU) From STKLIB

        If [L]WSTOCOU<>0
            Read [STO] STO0=[F:STJ]STOFCY;[L]WSTOCOU
            Call STODIS("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
            If [F:STJ]QTYSTU > WSTUDIS
                Call ERREUR(mess(216,188,1)-num$(I+1)+chr$(13)+mess(817,196,1)) From GESECRAN
                GOK=0 : Break 2
            Endif
        Else
            Call ERREUR(mess(216,188,1)-num$(I+1)+chr$(13)+mess(817,196,1)) From GESECRAN
            GOK=0 : Break 2
        Endif
        WTOTQTY += [F:STJ]QTYSTU
    Next
    If WDISA*([F:ITG]GLOAAAFLG=2)+WDISQ*([F:ITG]GLOQQQFLG=2)+WDISR*([F:ITG]GLORRRFLG=2)<WGLOALL
        Call ERREUR(mess(216,188,1)-num$(I+1)+chr$(13)+mess(817,196,1)) From GESECRAN
        GOK=0
        Break
    Endif

    #-------- Vérification des sorties négatives ----------#
    If dim([M:SCS1]LOC)>0 & [M:SCS1]WSTOFLG(I) & [M:SCS1]LOC(I)<>""
        Read [SGD]SGD0=[M:SCS1]VCRNUM;[M:SCS1]VCRLIN(I)
        Call STKWLOCSEQ("SCS1",I,LRET) From STKECR
        Call STKCTREMP([M:SCS1]WLOCSEQ(I),
&                      [M:SCS1]TRSTYP,[M:SCS1]TRSCOD,
&                      [M:SCS1]STOFCY,[M:SCS1]ITMREF(I),
&                      [M:SCS1]PCU(I),[M:SCS1]QTYPCU(I),
&                      [M:SCS1]STA(I),
&                      [M:SCS1]LOCTYP(I),
&                      [M:SCS1]LOC(I),
&                      "",1,WRET,GBIDD1,"","","") From STKLOC
        If WRET
            Call ERREUR(mess(216,188,1)-num$(I+1)+chr$(13)+GMESSAGE) From GESECRAN
            GOK=0
            Break
            Raz GMESSAGE
        Endif
    Endif
Next

If !GOK
    Raz [M:SCS1]WSTOFLG,WLOCSEQ
    End
Endif

#------ A partir de là toutes les lignes pouvant être supprimées sont identifiées: WSTOFLG=1 -----#
Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
Trbegin [SGH]
For I=0 To [M:SCS1]NBLIG-1
    If [M:SCS1]WSTOFLG(I)=1
        #-------- Enregistrement de la suppression -------#
        Read [SGD]SGD0=[M:SCS1]VCRNUM;[M:SCS1]VCRLIN(I)
        Call ALISTW (I) From SUBSCSB
        If GOK=0
            Break
        Endif
        Call FUNSTKACC([M:SCS1]FCYDES,[M:SCS1]ITMREF(I),29, [M:SCS1]VCRNUM, [M:SCS1]VCRLIN(I)) From STKLIB
        If GOK < 1
          #--- Issue 98011
          Break
          #Return
          #---
        Endif
        Call FUNSTKACC([M:SCS1]STOFCY,[M:SCS1]ITMREF(I),29, [M:SCS1]VCRNUM, [M:SCS1]VCRLIN(I)) From STKLIB
        If GOK < 1
          #--- Issue 98011
          Break
          #Return
          #---
        Endif
        Delete [SGD] Where VCRNUM=[M:SCS1]VCRNUM
&                        & VCRLIN=[M:SCS1]VCRLIN(I)
        #----- Annulation des sections lignes de composants -----#
        Call ENREG_ACCCCE(0,"","","","SGD",29,[M:SCS1]VCRNUM,[M:SCS1]VCRLIN(I),0,"","A") From TRTX3CPT
        If GOK<1  Break : Endif
    Endif
Next

If GOK
    Look [SGD]SGD0(1)=[M:SCS1]VCRNUM
    [G:SGD]currlen = 0
    If fstat
        Delete [SGH]SGH0=[M:SCS1]VCRNUM
    Endif
Endif

If GOK
    Commit
Else
    Rollback
Endif

Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC

End



###############################                         # Ana   deb
$CHARG_PARAM
#----- Chargement des globales référenciels, comptes et sections de la société -----#
Call GETCPY(GFCY,"SRT",3,GSCSNUM) From TRTX3CPT             # hcb 50197
# en import test il ne faut pas controler les compteurs
If dim([M:IMP2]TEST)>0
   If [M:IMP2]TEST = 2
      Return
   Endif
Endif
Local Integer LRET

# Récupération des codes compteur et effacement fichier de travail
If clalev ([F:TCA])<=0
   Local File TABCOUAFF [TCA]
Endif
# Compteur module stock
Call LECTCA(7,LRET) From SUBTCA
If !LRET
   GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
   GERR=1
   Return
Endif

#85785 * RMA
If func AFNC.ACTIV("TRSNE") > 0
  If !clalev([F:TSG]) : Local File TABSGHTYP [TSG] : Endif
  If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif
  If [F:FCY]FCY <> GFCY : Read [F:FCY]FCY0 = GFCY : Endif
  Call LEC_TSG_LEG([F:FCY]LEG,[M:SCS1]SGHTYP,LRET) From TRTLECLEG
  #If !LRET : Raz [F:TSG] : Endif #110357 * RMA * 2015/08/31
  If LRET<>0 : Raz [F:TSG] : Endif

  #--Counter definition based on document type
  If [F:TSG]SGHTYP<>""
    GSTKCPTMAN(14) = [F:TSG]MANCOU
    GSTKCPT   (14) = [F:TSG]CODNUM
  Else
    GSTKCPTMAN(14) = [F:TCA]MANCOU(14)
    GSTKCPT   (14) = [F:TCA]CODNUM(14)
  Endif
Else
  GSTKCPTMAN(14) = [F:TCA]MANCOU(14)
  GSTKCPT   (14) = [F:TCA]CODNUM(14)
Endif

#Controle compteur
Call CTRCPT(GSTKCPT(14),type([M:SCS1]VCRNUM), LRET) From STKLIB
If LRET<>0
   GMESSAGE = mess(242,199,1)
   GERR = 1
   GOK  = 0
   Return
Endif
GSTKCPTMAN(0) = [F:TCA]MANCOU(0)
GSTKCPT   (0) = [F:TCA]CODNUM(0)
GSTKCPTMAN(2) = [F:TCA]MANCOU(2)
GSTKCPT   (2) = [F:TCA]CODNUM(2)

Return

#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & !GVTMOD & dim([M:SCS1]CCE1)>0 & GSCSNUM <> ""  # hcb 50197
  Local Char BASPAG(10)
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WT03"+GSCSNUM+"1"             # hcb 50197
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:SCS1]NBLIG=0
    [M:SCS1]NBLIG=1 : Affzo [SCS1]30 : Effzo [SCS1]30
  Endif
Endif
Raz GSOC_UPDFLG
Return

#------------------------------------------#
# Actzo ou Grizo des dépôts selon le site  #
#------------------------------------------#
$WRH_ETAT
If GWRHACT<>2 Return Endif
If [M]STOFCY<>[F:FCY]FCY
  Read [FCY]FCY0=[M]STOFCY
Endif

If [F:FCY]WRHGES=2
   Actzo [M:SCS1]WRHSEL
Else
   Raz   [M:SCS1]WRHSEL
   Diszo [M:SCS1]WRHSEL
Endif
If [M]FCYDES<>[M]STOFCY & [M]FCYDES<>[F:FCY]FCY
  Read [FCY]FCY0=[M]FCYDES
Endif
If [F:FCY]WRHGES=2
   Actzo [M:SCS1]WRHDESH
   Actzo [M:SCS1]WRHDES
Else
   Raz   [M:SCS1]WRHDESH
   Diszo [M:SCS1]WRHDESH
   Actzo [M:SCS1]WRHDES
Endif
Return
######################################################################
$AFFMASK
#85785
If !find(GFONC1,"GESSIS","GESSST","GESSTR")
  If dim([M:SCS1]CFMFLG) > 0
    Chgfmt [M:SCS1]CFMFLG With "-LA1:X"
  Endif
Endif
Return
######################################################################

