#<AdxTL>@(#)11.0.0.0 $Revision$

Call OBJET("SCS", GBIDC1, GBIDC2) From GOBJET
End


$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return

#######################################################################
# Les etiquettes suivantes sont définies pour la gestion de l'objet   #
#######################################################################
$DEFTRANS
Local Shortint OUVFICFLG
If !find(GFONC1,"GESSCS","GESSIS","GESSST","GESSTR") Raz GFLAG Endif
If GFLAG<>""
  If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
  Read [F:SRT] SRT0=3;GFLAG
  If fstat | [F:SRT]ENAFLG=1 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  If [F:SRT]ACSCOD<>"" & GPROFIL<>GSUPER
    If clalev ([F:ACC])=0
        Local File ACCES  [ACC]
        OUVFICFLG=1
    Endif
    Read [ACC] CODACC=GUSER;[F:SRT]ACSCOD
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG=1  Close Local File [ACC] : Raz OUVFICFLG : Endif
Return
######################################################################
$VARIANTE
# La transaction lue est elle utilisable ?
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
Read [SRT]SRT0=3;[F:AWI]TRN
If fstat | [F:SRT]ENAFLG<>2
   OK = 0 : Return
Endif
#                                                       Rajout | [F:SRT]CHGACC=2)   # hcb x3-67989
If GFONC1="GESSCS" & ([F:SRT]BETFCYCOD<>1 | [F:SRT]CHGACC=2) |
&  GFONC1="GESSIS" & ([F:SRT]BETFCYCOD<>2 | [F:SRT]CHGACC=2) |
&  GFONC1="GESSST" & ([F:SRT]BETFCYCOD<>4 | [F:SRT]CHGACC=2) |
&  GFONC1="GESSIH" & ([F:SRT]BETFCYCOD<>2 | [F:SRT]CHGACC=2) |
&  GFONC1="GESSTR" & ([F:SRT]BETFCYCOD<>5 | [F:SRT]CHGACC=2)
   OK=0
Endif
Return

######################################################################
$SETTRANS
#Local Shortint WSrTDOCFLG,WSrTSNSFLG
#Local Char     WSrTDOCNAM(10), WSRTSNSNAM(10)
#Local Char     WSrTSTRNUM(3)
Global Integer  GCCECOD    : # Flag saisie des sections analytiques

If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
Read [SRT]SRT0=3;GFLAG

#MAE, le 29/01/08, GRP_SITE
GGRPFCY = [F:SRT]GFY
GSCSNUM = [F:SRT]SRTNUM    # hcb 50197
Return

######################################################################
$OUVRE_BOITE
# Récupération des noms de currbox des tiroirs
Global Char     GBOXSTO(10)
GBOXSTO = "GAU_CHE"+num$(find("ST2",OBJLIS(1..8))+find("STO",OBJLIS(1..8))
&         +find("ST1",OBJLIS(1..8)))

Return
######################################################################
$AVANT_OUVRE
# Redéfinition de GFONCTION  bug : 34446
If find(GFONC1,"GESSCS","GESSIS","GESSST","GESSIH","GESSTR")
   If GFONCTION <> GFONC1
      GFONCTION =  GFONC1
      If GFONCTION = "GESSIH"
         GFONCTION = "GESSIS"
      Endif
      Call AUTORIS From EXEFNC
   Endif
Endif
Return

######################################################################
$OUVRE
Global Char    GTRUCOD(GLONTRU)
Raz GSOC_ACTIVE                                               # Ana

Local Char     WCRIT(200)
Local Char     WCRITPIC(250)   : # Critère pour contrôle ligne stock pickée
Local Char     WCRITSTO3(70)   : # Critère péremption
Local Char     WCRITSTO4(90)   : # Critère statuts
Local Char     WPICKSTO(2)
Local Integer  LRET, I
Local Integer  WA, WQ, WR
#DLU client
Local Char     NBDAY(10)
Raz NBDAY

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB

    If dim(GRAFFRAICHISCS)<0
        Global Libelle GRAFFRAICHISCS
    Endif
    Raz GRAFFRAICHISCS

    If dim(GSCSAUZSST)<=0
        Global Char    GSCSAUZSST(50)  #50 par sécurité
    Endif
    GSCSAUZSST = "A*,Q*,R*"

    # Si interne ou inter-site, déplacement vers un emplacement interne
    # car pas de règle de gestion sur chgt stock --> pb dans plan de rangement
    Global Char GFILLOCENT(250)
    Case [F:SRT]BETFCYCOD
        When 1 : GFILLOCENT = "[TLO]LOCCAT<=1 | [TLO]LOCCAT=3"    # Interne
        When 2 : GFILLOCENT = "[TLO]LOCCAT<=1"    # Inter-sites
                 If !clalev([F:BPR]) : Local File BPARTNER   [BPR] : Endif
                 If !clalev([F:BPA]) : Local File BPADDRESS  [BPA] : Endif
                 If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
                 If !clalev([F:BPD]) : Local File BPDLVCUST  [BPD] : Endif
                 If !clalev([F:ITS]) : Local File ITMSALES   [ITS] : Endif
                 If !clalev([F:SPK]) : Local File SPRICLINK  [SPK] : Endif
        When 4 : GFILLOCENT = "[TLO]LOCCAT=4"     # Transfert sous-traitant
                 If !clalev([F:BPR]) : Local File BPARTNER   [BPR] : Endif
                 If !clalev([F:BPA]) : Local File BPADDRESS  [BPA] : Endif
                 If !clalev([F:BPS]) : Local File BPSUPPLIER [BPS] : Endif
                 If !clalev([F:BPD]) : Local File BPDLVCUST  [BPD] : Endif
#MAE, RET_SSTRT
        When 5 : GFILLOCENT = "[TLO]LOCCAT=1 OR [TLO]LOCCAT=2"     # Retour sous-traitant
                 If !clalev([F:BPR]) : Local File BPARTNER   [BPR] : Endif
                 If !clalev([F:BPA]) : Local File BPADDRESS  [BPA] : Endif
                 If !clalev([F:BPS]) : Local File BPSUPPLIER [BPS] : Endif
                 If !clalev([F:BPD]) : Local File BPDLVCUST  [BPD] : Endif
    Endcase

    #--- PE Pour autoriser des chgts d'emplacements vers des emplacements clients
    #--- If [F:SRT]BETFCYCOD=1 GFILLOCENT="[TLO]LOCCAT<=1|[TLO]LOCCAT=3" Endif
    GPOINT="MOD_FILLOC"
    Gosub ENTREE From EXEFNC

    If !clalev([F:ITFD]) : Local File ITMFACILIT [ITFD] : Endif
    If !clalev([F:SRU1]) : Local File TABSTORUL  [SRU1] : Endif
    If !clalev([F:QLD])  : Local File STOQLYD    [QLD]  : Endif
    If !clalev([F:SGW])  : Local File STOSRGW    [SGW]  : Endif
    If !clalev([F:STO])  : Local File STOCK      [STO]  : Endif
    If !clalev([F:QLA])  : Local File QLYCRDASW  [QLA]  : Endif     # hcb X3-46616

    #DLUBPC
    If clalev([F:ITU])=0   Local File ITMBPC     [ITU]  Endif
# hcb 65886  (solution donnée par MB)
    If TUNNEL
       If clalev([STO1]) : Close Local File [STO1] : Endif   # hcb 74732
       Local File STOCK      [STO1]
    Else
       If !clalev([F:STO1]) : Local File STOCK      [STO1] : Endif
    Endif
# hcb 65886 end
    #--- TS 106217
#   Local File ECCSTA [ECS]                                               # hcb 115060
    If !clalev([F:ECS])  : Local File ECCSTA      [ECS]  : Endif          # hcb 115060

    GSRTNUM = GFLAG
    If [F:SRT]BETFCYCOD=2
        [M:SCS1]TRSTYP = 14      # Transfert inter-site
    Else
        [M:SCS1]TRSTYP = ([F:SRT]CHGEMPCOD=2)*7
    Endif
#                                                             # hcb X3-96610 deb
#[M:SCS1]LOTACT = 1
[M:SCS1]LOTACT = 0
#Read [ACV] CODACT = "LOT"
#If !fstat [M:SCS1]LOTACT =[F:ACV]FLACT Endif
[M:SCS1]LOTACT     = func AFNC.ACTIV("LOT")    # Is LOT activated ?
[M:SCS1]LOTACT   +=1
#                                                             # hcb X3-96610 end

$OUVRE_SUIT                                              # hcb 28638
GFCY=GFCYDEF(7)                                                # Ana
Gosub CHARG_PARAM                                              # Ana
If GMODU(2)=2 : # Si module compta actif                       # Ana
  If !clalev([F:GCM])   Local File GACM       [GCM] : Endif    # Ana
Endif                                                          # Ana
GORITITCOL=1                                                   # Ana


    # Initialisation des tables nécessaires à la gestion d'emplacements
    Gosub STK_INILOC From STKLOC

    #  ecran stockage mvt du document
    If clalev([M:SGW])=0
        Local Mask STOCHGW   [SGW]
    Endif
    Raz [M:SGW]
#    Call DELSTOCHGW("SCS1",[M:SCS1]STOFCY,-1,-1,1,LRET) From SUBSCSB
    #  ecran de travail enreg mvt du document
    If clalev([M:STW])=0
        Local Mask STOWORK   [STW]
    Endif
    Raz [M:STW]
    If clalev([M:VALW])=0
        Local Mask STOVALW   [VALW]
    Endif
    Raz [M:VALW]
    [M:VALW]ZONPRI = "[M:SCS1]PRI"
    [M:VALW]ZONPRIORD = "[M:SCS1]PRI"
    If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif
    If !clalev([M:SVWD]) : Local Mask STOVALWORK [SVWD] : Endif    # Pour la valo de la destination

    # Si module vente présent,
    # alimentation des variables nécessaires à la recherche tarif
    If GMODU(5)=2
       Call TARIFCHGT(5) From TRTPRICE
    Endif

    If !GVTMOD=1 Gosub DECLARE From TABLEAUX Endif
Return

######################################################################
$FILTRE
    Default File [SGH]
    # JL n'a pas ce fichier ouvert dans les factures
    If clalev([F:SRT])<>0
        FILTSUP = "BETFCYCOD="+num$([F:SRT]BETFCYCOD)
    Endif
Return

######################################################################
$LIENS

#FQ 68364
If GFCY<>[F:SGH]STOFCY GFCY=[F:SGH]STOFCY Endif
#----- Affichage entêtes de colonne variables -----#                     # Ana
Gosub CHARG_PARAM
#fin FQ 68364
Gosub AFF_TITCOL                                                         # Ana

# hcb 33564 deb
# globales servant à tester la date d imputation par rapport à la date du jour
If dim(GCTRDATSCS) > 0
   Kill GCTRDATSCS
Endif
# hcb 33564 deb

Local Integer I
Local Integer LRET

    If [M:SCS1]BETCPY=2
      # Réalimentation des champs de la société destinatrice
      Read [FCY]FCY0=[M:SCS1]FCYDES
      # Récupération de la société
      [M:SCS1]CPYDES = [F:FCY]LEGCPY
      If GFCY<>[M:SCS1]FCYDES GFCY=[M:SCS1]FCYDES : Gosub CHARG_PARAM : Endif    # Ana

      # Récupération de la devise
      # Call GETDEV([M:SCS1]FCYDES) From DEVSUB
      [M:SCS1]CURDES = GLOCALDEV
      If GFCY<>[M:SCS1]STOFCY GFCY=[M:SCS1]STOFCY : Gosub CHARG_PARAM : Endif    # Ana

      # Pour repositionner glocaldev
      #Call GETDEV([M:SCS1]STOFCY) From DEVSUB
      # Réalimentation des champs liés au client
      Read [F:BPC]BPC0=[M:SCS1]BPCNUM
      [M:SCS1]VACBPR=[F:BPC]VACBPR
      [M:SCS1]CHGTYP=[F:BPC]CHGTYP
      [M:SCS1]PRITYP=[F:BPC]PRITYP
    Endif

    # Rechargement type emplacement sous-traitant
    If ([M:SCS1]BETFCYCOD=4 | [M:SCS1]BETFCYCOD=5)
       Read [F:STC]STC0=[M:SCS1]STOFCY;[M:SCS1]SCOLOC
       If !fstat
          [M:SCS1]SCOLOCTYP = [F:STC]LOCTYP
       Endif
    Endif

    [M:SCS1]VCRTYP = 29
#                                                             # hcb X3-96610 deb
#[M:SCS1]LOTACT = 1
[M:SCS1]LOTACT  = 0
#Read [ACV] CODACT = "LOT"
#If !fstat [M:SCS1]LOTACT =[F:ACV]FLACT Endif
[M:SCS1]LOTACT     = func AFNC.ACTIV("LOT")    # Is LOT activated ?
[M:SCS1]LOTACT   +=1
#                                                             # hcb X3-96610 end
    Raz [M:SGW]
    [M:SGW]TRSTYP = [M:SCS1]TRSTYP
    [M:SGW]TRSCOD = [M:SCS1]TRSCOD
    [M:SGW]FCYDES = [M:SCS1]FCYDES
#    Call DELSTOCHGW("SCS1",[M:SCS1]STOFCY,-1,-1,1,LRET) From SUBSCSB
    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
    If [F:SRT]SRTTYP<>3 | [F:SRT]SRTNUM<>GSCSNUM                    # hcb 50197
       Read [SRT]SRT0=3;GSCSNUM : If fstat  Raz [F:SRT] : Endif
    Endif
    Read [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0
    If fstat
       Raz [F:DTR]
    Endif
    If dim([M:SCS1]CCECODS)>0
        [M:SCS1]CCECODS = [F:DTR]HEACCECOD
    Endif
    For I=1 To GNBDIE
        [M:SCS1]CCE(I-1) =  [F:SGH]CCE(I-1)
    Next

    Diszo [M:SCS1]5
    Actzo [M:SCS1]VCRNUM    # Car il y a un diszo en RAZCRE (et RAZDUP)
    Diszo [M:SCS1]10
    Diszo [M:SCS1]12

    Gosub LIENS From TABLEAUX

    # Ce qui suit ne fonctionne pas dans LIEN_LIG, càd que rien n'est grisé

    # Force l'affichage afin que les Diszo
    # appelés ensuite fonctionnent
    Affzo [M:SCS1]
    Call STKCTRIPT( [M:SCS1]IPTDAT, [M:SCS1]STOFCY, "1") From STKLIB
    If GERR=1
        Call ERREUR(GMESSAGE) From GESECRAN
        Raz GERR
        Raz GMESSAGE
        Grizo [M:SCS1]5
    Elsif GERR=2
        Call MESSAGE(GMESSAGE) From GESECRAN
        Raz GERR
        Raz GMESSAGE
        Grizo [M:SCS1]5
    Elsif [M:SCS1]SIHNUM<>""
        # On ne peut plus  créer de ligne si le transfert est déjà facturé
        Diszo [M:SCS1]30
    Else
        # Rend insaisissables toutes les colonnes, puis...
        # ( Diszo du tableau empêche la réactivation)
        # ...rend saisissable la dernière ligne (la ligne vide)
        # Car celle-ci peut avoir été rendue inactive
        # par le chargement précédent d'un document (comportant plus de lignes)
        Call STKDISCOL("SCS1",[M]NBLIG) From STKECR
        Diszo [SCS1]ITMREF,ITMDES1
        Actzo [SCS1]ITMREF([M]NBLIG),ITMDES1([M]NBLIG)
        If dim([M:SCS1]QTYPCU)>0
            Diszo [SCS1]QTYPCU
            Actzo [SCS1]QTYPCU([M]NBLIG)
        Endif
        If dim([M:SCS1]PCUDES)>0
            Diszo [SCS1]PCUDES
            Actzo [SCS1]PCUDES([M]NBLIG)
        Endif
        If dim([M:SCS1]QTYPCUDES)>0
            Diszo [SCS1]QTYPCUDES
            Actzo [SCS1]QTYPCUDES([M]NBLIG)
        Endif
        If dim([M:SCS1]COEDES)>0
            Diszo [SCS1]COEDES
            Actzo [SCS1]COEDES([M]NBLIG)
        Endif
        If dim([M:SCS1]STADES)>0
            Diszo [SCS1]STADES
            Actzo [SCS1]STADES([M:SCS1]NBLIG)
        Endif
        If dim([M:SCS1]LOCDES)>0
            Diszo [SCS1]LOCDES
            Actzo [SCS1]LOCDES([M]NBLIG)
        Endif
        If dim([M:SCS1]WRHDES)>0
            Diszo [SCS1]WRHDES
            Actzo [SCS1]WRHDES([M]NBLIG)
        Endif
         If dim([M:SCS1]LOCTYPDES)>0
            Diszo [SCS1]LOCTYPDES
            Actzo [SCS1]LOCTYPDES([M]NBLIG)
        Endif
# hcb 110505 28601 deb
        If dim([M:SCS1]PALNUMDES)>0
            Diszo [SCS1]PALNUMDES
            Actzo [SCS1]PALNUMDES([M]NBLIG)
        Endif
        If dim([M:SCS1]CTRNUMDES)>0
            Diszo [SCS1]CTRNUMDES
            Actzo [SCS1]CTRNUMDES([M]NBLIG)
        Endif
# hcb 110505 28601 fin
        If dim([M:SCS1]MVTDES)>0
            Diszo [SCS1]MVTDES
            Actzo [SCS1]MVTDES([M]NBLIG)
        Endif
    Endif

    #--- TS 106217
    # Pas de filtre version pour les changements stock, car il n'y a pas de règle de gestion
    If dim([M:SCS1]ECSSEL)>0
      #If [M:SCS1]BETFCYCOD=1
      #  Grizo [M:SCS1]ECSSEL
      #Else
        Actzo [M:SCS1]ECSSEL
      #Endif
    Endif
    #---

    # Actzo ou Diszo du dépôt
    Gosub WRH_ETAT

    #85785
    If func PORLEGLIB.DIGSIGN([M:SCS1]STOFCY, "")
      If [M:SCS1]CFMFLG = 2
        Diszo [M:SCS1]1-99
      Endif
    Endif

#BRBAN 16/07/2014 SAM #93745 US2
If func AFNC.ACTIV("TRSNE")
  Local Integer STAT
  Call LEC_TSG_LEG([F:FCY]LEG, [F:SGH]SGHTYP, STAT) From TRTLECLEG
Endif
Return


######################################################################
$DEFLIG
    Default Mask [SCS1]
    Default File [SGD]
    CRIT = 'VCRNUM="'+[M:SCS1]VCRNUM+'"'
    FICLIG="SCHGD"
    ABLIG="SGD"
    ZONLIG="VCRLIN"
Return

######################################################################
$LIENS_LIG

    Gosub SET_NOL
    Call RECSTOSOR (1,"SCS1",NOL,[M:SCS1]FCYDES,[M:SCS1]ITMREF(NOL),
&                   [M:SCS1]VCRTYP,[M:SCS1]VCRNUM,[M:SCS1]VCRLIN(NOL),
&                   "",LRET) From STKECR

###############################                         # Ana   deb
#FQ 68364
Call CHARG_ACCCCE(NOL,"","","[M:SCS1]CCE",
&                "SGD",29,[F:SGD]VCRNUM,[F:SGD]VCRLIN,0,"") From TRTX3CPT
#L'entrée dans la table CPTANALIN est créée avec le type de pièce = 29
#&                "SGD",0,[F:SGD]VCRNUM,[F:SGD]VCRLIN,0,"") From TRTX3CPT
#fin FQ 68364
Return

######################################################################
$RAZCRE

If GFCY<>GFCYDEF(7)                             # Ana
  GFCY=GFCYDEF(7) : Gosub CHARG_PARAM           # Ana
Endif                                           # Ana
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL                                # Ana


    Actzo [M:SCS1]5
    # Issue 87017 - 2013-01-14 by MAE : Erreur dans le numéro du compteur
    #If GSTKCPTMAN(9)<>2
    If GSTKCPTMAN(14)<>2
        Effzo [M:SCS1]VCRNUM
        Diszo [M:SCS1]VCRNUM
    Endif
    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
    If [F:SRT]SRTTYP<>3 | [F:SRT]SRTNUM<>GSCSNUM                    # hcb 50197
       Read [SRT]SRT0=3;GSCSNUM : If fstat  Raz [F:SRT] : Endif
    Endif
    Read [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0
    If fstat
       Raz [F:DTR]
    Endif


    #85785 * RMA
    ## Get stock change type
    If func AFNC.ACTIV("TRSNE")
      Local Char WSGHTYP(GLONTSG)
      Gosub SGHTYP From TRTSTKSGH1
      If WSGHTYP<>"" : [M:SCS1]SGHTYP=WSGHTYP : Affzo [M:SCS1]SGHTYP : Endif
    Endif

    If dim([M:SCS1]CCECODS)>0
        [M:SCS1]CCECODS = [F:DTR]HEACCECOD
    Endif
    [M:SCS1]VCRTYP=29
    [M:SCS1]BETCPY    = 1
    [M:SCS1]BETFCYCOD = [F:SRT]BETFCYCOD
    If [F:SRT]BETFCYCOD=2
        [M:SCS1]TRSTYP = 14      # Transfert inter-site
    Else
        [M:SCS1]TRSTYP = ([F:SRT]CHGEMPCOD=2)*7
    Endif
    [M:SCS1]TRSCOD = [F:SRT]TRSCOD
    [M:SCS1]TRSFAM = [F:SRT]TRSFAMDEF
    Affzo [M:SCS1]TRSFAM
    [M:SCS1]ENTCOD = [F:SRT]ENTCOD
    Actzo [M:SCS1]10
    Diszo [M:SCS1]SIHNUM : Affzo [SCS1]SIHNUM
    If dim([M:SCS1]ALLINC)>0
        [M:SCS1]ALLINC="236"
        [M:SCS1]ALLEXC="235"
        Affzo [M:SCS1]ALLINC, ALLEXC
    Endif
    [M:SCS1]ALLSTO   =2
    [M:SCS1]NOTALLSTO=2

    # Si import, par défaut, mouvement interne avec changement d'emplacement
    If GIMPORT & GSCSNUM=""
       [M:SCS1]BETFCYCOD=1 : [M:SCS1]TRSTYP=7
    Endif
    #--- TS 106217
    # Pas de filtre version pour les changements stock, car il n'y a pas de règle de gestion
    If dim([M:SCS1]ECSSEL)>0
      #If [M:SCS1]BETFCYCOD=1
      #  Grizo [M:SCS1]ECSSEL
      #Else
        Actzo [M:SCS1]ECSSEL
      #Endif
    Endif
    #---
#                                                             # hcb X3-96610 deb
#[M:SCS1]LOTACT = 1
[M:SCS1]LOTACT = 0
#Read [ACV] CODACT = "LOT"
#If !fstat[M:SCS1]LOTACT =[F:ACV]FLACT Endif
[M:SCS1]LOTACT     = func AFNC.ACTIV("LOT")    # Is LOT activated ?
[M:SCS1]LOTACT   +=1
#                                                             # hcb X3-96610 end
    # Actzo ou Diszo du dépôt
    Gosub WRH_ETAT
Return

######################################################################
$RAZDUP
Return

######################################################################
$STATUT
    If BOUT="a" & mkstat=4 & REP=""
        REP="M" : GREP="M"
    Endif
Return

######################################################################
$SETBOUT

    # Autorisation suppression si transfert inter-site
    If [M:SCS1]TRSTYP=14
        GFCY=[M]STOFCY
        GBIDC2="D": Gosub AUTORIS_OPT From CONTX3
        If !GBIDI2 : Call VIREBOUT(CHAINE,"1") From GOBJET : Endif
    Endif

    If [M:SCS1]TRSTYP<>14 | GREP<>""
        Call VIREBOUT(CHAINE,"1") From GOBJET
    Endif
    If [M:SCS1]VCRNUM="" & GREP<>"C"
        Call VIREBOUT(CHAINE,"2") From GOBJET
    Endif
    Call VIREBOUT(CHAINE,"A") From GOBJET
    Call VIREBOUT(CHAINE,"D") From GOBJET
# Menu Options / Visu transaction
    CHMEN += "c"
# Menu Options / Sections analytiques
    If find([M:SCS1]CCECODS,1,2)
        CHMEN += "a"
    Endif

    #85785
    If GREP<>"" | !CLECUR | func AFNC.ACTIV("KPO") < 1
      Call VIREBOUT(CHAINE,"3") From GOBJET
    Endif
    If [M:SCS1]STOFCY <> ""
      If func PORLEGLIB.DIGSIGN([M:SCS1]STOFCY, "") <> 1
        Call VIREBOUT(CHAINE,"3") From GOBJET
      Endif
    Endif
    If dim([M:SCS1]CFMFLG)>0
      If [M:SCS1]CFMFLG = 2
        Call VIREBOUT(CHAINE,"13") From GOBJET
      Endif
    Endif

    If !find([F:SGH]BETFCYCOD, 2, 4, 5)
      Call VIREBOUT(CHAINE,"3") From GOBJET
    Endif

    # BRBAN 26-06-2014 SAM 93745
    If func AFNC.ACTIV('KPO') & func PORLEGLIB.DIGSIGN([M:SCS1]STOFCY,'') & find([F:SGH]BETFCYCOD,2,4,5)
      If GREP<>'C' & GREP<>'D'
        CHMEN+='U'
      Endif
    Endif

#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
Gosub SET_BOUT_SPE From GSAISIE
Return

######################################################################
$VERIF_CRE
    Gosub VERIF_ENR
Return

######################################################################
$VERIF_MOD
    Gosub VERIF_ENR
Return

######################################################################
$VERIF_ENR
    Call CTLSTOCHG( OK ) From SUBSCSB
    If OK
         # Issue 93944 - 2014-11-18 by SR : GBROWS=1 =VT, GBROWS = 2 = Web service
#        If GFONCTION<>"FUNSTOP" & !GIMPORT & GFONCTION<>"FUNSTOLTI" & !GBROWS     # hcb 51026 / 89408
         # Issue X3-106909 - 2018-09-21 by MAE : Ajout du GSTOTRACE
        If GFONCTION<>"FUNSTOP" & !GIMPORT & GFONCTION<>"FUNSTOLTI" & GBROWS <> 2 & GSTOTRACE>1
           Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
        Endif
        If func SUBSCSB.VERALL( "SCS1" ) & !GIMPORT                               # hcb 82350
            OK = 1
            Call AVERTIR(mess(81,184,1),OK) From GESECRAN
            OK -= 1
             # Issue 93944 - 2014-11-18 by SR : GBROWS=1 =VT, GBROWS = 2 = Web service
#            If OK & GFONCTION<>"FUNSTOP" & GFONCTION<>"FUNSTOLTI" & !GBROWS       # hcb 51026 / 89408
             # Issue X3-106909 - 2018-09-21 by MAE : Ajout du GSTOTRACE
            If OK & GFONCTION<>"FUNSTOP" & GFONCTION<>"FUNSTOLTI" & GBROWS <> 2 & GSTOTRACE>1
                Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
                Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
            Endif
        Endif
    Else
        Raz GOK
        #--- Issue 113595
        Return
    Endif

    If func AFNC.ACTIV("KPO")>0
      If func PORLEGLIB.CTLDOCTYP([M:SCS1]SGHTYP,"SGH",GMESSAGE) = 1
        OK = 0 : GERR = 1 : Return
      Endif
    Endif

Return
######################################################################
$INICRE

Local Integer LSTAT, I
Local Char    LNUM
    # Création du numéro de document si nécessaire
    If GSTKCPTMAN(14)<>2 | [M:SCS1]VCRNUM = ""
        Call NUMERO(GSTKCPT(14), [M:SCS1]STOFCY, [M:SCS1]IPTDAT,
&                   "", LNUM, LSTAT) From SUBANM
        If GOK<0 Return Endif
        If LSTAT=0
           [M:SCS1]VCRNUM = LNUM
           [F:SGH]VCRNUM  = LNUM
        Else
            GERR=1:GMESSAGE = mess(60,199,1)
            GOK=0
        Endif
    Endif

    For I=1 To GNBDIE
       [F:SGH]CCE(I-1) =  [M:SCS1]CCE(I-1)
       [F:SGH]DIE(I-1) =  GDIE(I)                 # Ana
    Next

Return

