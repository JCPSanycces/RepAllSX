######################################################################
$APRES_CRE
    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif             # hcb 50197
    If [F:SRT]SRTTYP<>3 | [F:SRT]SRTNUM<>GSCSNUM                    # hcb 50197
       Read [SRT]SRT0=3;GSCSNUM : If fstat  Raz [F:SRT] : Endif
    Endif

    Local Integer LRET
    Call STKDELRES(0,[M:SCS1]FCYDES,"",LRET) From STKLOC

    If [F:SRT]PRNCOD1 > 1 & !GVTMOD       #--- Lot V01
        Local Char WPARAM(GLONVCR)(1..3) , WVALEUR(10)
        WPARAM(1) = [M:SCS1]STOFCY
        If [F:SRT]BETFCYCOD = 2
           WPARAM(1) = [M:SCS1]FCYDES  # hcb 65758
        Endif
        WPARAM(2) = num$([M:SCS1]VCRTYP)
        WPARAM(3) = [M:SCS1]VCRNUM
        Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
    Endif


    #MAE, le 23/07/08, bg 48155,
    If GFONCTION <> "FUNSTOP" & GFONCTION<>"FUNSTOLTI"               # hcb 51026
        #---- Régularisation des mouvements et alloc -----#
        Call REGFROMENT( 0, "SCS1", "[M:SCS1]CREFLG(I)=0", "ITMREF", [M:SCS1]FCYDES ) From TRTSHTCOM

        If !GIMPORT & !GWEBSERV & GTRACE<>""
            If dim(GTRAVT)>0 GTRAVT=mess(39,7750,1)-[F:SGH]VCRNUM Endif
            Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
            If dim(GTRAVT)>0 Raz GTRAVT Endif
        Endif
        If !GIMPORT & !GVTMOD              # hcb 28638
            Gosub RELIT From GOBJSUB
            Gosub TIROIR From SUBSCSP
        Endif                              # hcb 28638
    Endif
Return

