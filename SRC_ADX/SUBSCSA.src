#######################################################################
$AVANTBOUT

Case BOUT
 When "3" : If [M:SCS1]VCRNUM = "" | [M:SCS1]STOFCY = ""           #85785
              OK = 0 : Return
            Else
              If func PORLEGLIB.DIGSIGN([M:SCS1]STOFCY, "") <> 1
                OK = 0 : Return
              Endif
            Endif
Endcase
