Return
######################################################################
#MAE, bg 78442
$APRES_MODIF_ITMREFSEL
Raz WCRIT, WCRITPIC, WCRITSTO3, WCRITSTO4, NBDAY
          # Si transfert inter-site ou tiers
          If [M:SCS1]BETFCYCOD>1
            #DLUBPC
            If !clalev([F:BPR2]) : Local File BPARTNER [BPR2] : Endif
            If !clalev([F:BPC2]) : Local File BPCUSTOMER [BPC2] : Endif
            Filter [BPR2] Where BETFCY=2 & FCY=[M:SCS1]FCYDES & BPCFLG=2
            Read [BPR2]BPR2 First
            If ! fstat
              Read [BPC2]BPC0=[F:BPR2]BPRNUM
              Filter [BPR2]
              #Dlu client
            Endif
            If [F:BPC2]BPCNUM<>""
              #DLU Client
              #lecture ITMBPC  pour recuperer DLUBPC
              Read [ITU]ITU0 = [F:ITM]ITMREF;[F:BPC2]BPCNUM
              If fstat
                Raz [F:ITU]
              Endif
              #DLU Client, calcul du nbre de jours à retrancher à la DLU article
              If [F:ITU]DLUBPC <> 0
                Call CALNBDAYCLI([F:ITM]EXYMGTCOD,[F:ITM]SHL,[F:ITM]SHLUOM,[F:ITF]DLU,[F:ITU]DLUBPC,NBDAY) From STKLIB
              Endif
            Endif
            #Fin DLUBPC

            #-------------------------------
            # Positionnement filtre picking
            #-------------------------------
            # Lot et péremption
            If dim([M:SCS1]LOTSTR)>0
               If [F:SRU1]SHLLOT=2
                  WCRITSTO3 = '([F:STL]DLUDAT=[0/0/0]|'
                  If [M:SCS1]IPTDAT<>[0/0/0]
                     WCRITSTO3 += '[F:STL]DLUDAT'+NBDAY+'>=[M:SCS1]IPTDAT)'   #DLUBPC
                  Else
                     WCRITSTO3 += '[F:STL]DLUDAT'+NBDAY+'>=date$)'            #DLUBPC
                  Endif
                  WCRITPIC  = WCRITSTO3
               Endif
               If [F:SRU1]SHLLOT=1
                  WCRITSTO3 = '([F:STL]SHLDAT=[0/0/0]|'
                  If [M:SCS1]IPTDAT<>[0/0/0]
                     WCRITSTO3 += '[F:STL]SHLDAT>=[M:SCS1]IPTDAT)'
                  Else
                     WCRITSTO3 += '[F:STL]SHLDAT>=date$)'
                  Endif
                  WCRITPIC  = WCRITSTO3
               Endif
            Endif

            Raz WA, WQ, WR
            # Statuts autorisés par les règles de gestion d'E/S
            If find([F:SRU1]AUZSTA,1,3,5,7) WA=1  Endif
            If find([F:SRU1]AUZSTA,2,3,6,7) WQ=1  Endif
            If find([F:SRU1]AUZSTA,4,5,6,7) WR=1  Endif

            # Prise en compte des sous-statuts autorisés
            Call CREE_FORMULE([F:SRU1]FORSTA,"[F:STO]STA",WCRITSTO4) From TRTCATEG

            # Alimentation des zones de la fenêtre critère et du filtre
            # pour contrôle ligne stock pickée (si non administrateur stock)
            [M:SCS1]AUZSST=[F:SRU1]AUZSST
            [M:SCS1]FORSTA=[F:SRU1]FORSTA
            [M:SCS1]SHLLOT=[F:SRU1]SHLLOT

            Raz WCRIT
            If WA=1
              WCRIT+='pat([F:STO]STA,"A*")<>0'
            Endif
            If WQ=1
              If WCRIT<>"" WCRIT+='|' Endif
              WCRIT+='pat([F:STO]STA,"Q*")<>0'
            Endif
            If WR=1
              If WCRIT<>"" WCRIT+='|' Endif
              WCRIT+='pat([F:STO]STA,"R*")<>0'
            Endif

            If WCRITSTO4<>""
              If WCRITPIC<>""
                WCRITPIC+='&('+WCRITSTO4+')'
              Else
                WCRITPIC+=WCRITSTO4
              Endif
            Elsif WCRITPIC<>""
              If WCRIT<>"" WCRITPIC+='&('+WCRIT+')' Endif
            Else
              If WCRIT<>""
                WCRITPIC+=WCRIT
              Else
                WCRITPIC='1=1'
              Endif
            Endif
          Endif

          GPOINT="CRITSTO4"
          Gosub ENTREE From EXEFNC

          Gosub TIROIR From SUBSCSP
Return

