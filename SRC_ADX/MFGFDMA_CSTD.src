#Endcase
Return

#**----------------------------------------------------------------<br/>
#* INITIALIZE : Initialize properties of the instance
#**<br/>----------------------------------------------------------------<br/>
#* @param MFGNUM = Work order number
#* @param MFGLIN = Work order line number (For use with CAL_FDMA)
#* @param MFGFCY = Site code (For use with CAL_FDMA)
#* @param FDMATIM = Site default daily start time (used to add to FDMA to give date time)
#**<br/>----------------------------------------------------------------
#*!
$INITIALIZE
    Local Integer I
    Local Integer J
    Local Integer OK

    Local File FACILITY [FCY]
    Local File MFGMAT [MFM]

    this.MFGNUM = [L]MFGNUM
    this.MFGLIN = [L]MFGLIN
    this.MFGFCY = [L]MFGFCY
    this.FDMATIM = [L]FDMATIM
    # Get the planning weekly structure
    this.TWD = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 3, this.MFGFCY, "PLNTWD")

    # Add all the components from the work order that are 'pending' or 'in process'.
    # Issue X3-65500 - 2017-11-23 by ALSHE : include all released products at once for FDMA calculation
    # For [MFM]MFM0 Where [F:MFM]MFGNUM = [L]MFGNUM & [F:MFM]MFGLIN = [L]MFGLIN & find ([F:MFM]MATSTA, 1, 2) <> 0
    For [MFM]MFM0 Where [F:MFM]MFGNUM = [L]MFGNUM & find ([F:MFM]MATSTA, 1, 2) <> 0
        # Issue X3-65500 - 2017-11-23 by ALSHE : determine MFGLIN depending on MFM record
        [L]MFGLIN = [F:MFM]MFGLIN
        this.MFGLIN = [L]MFGLIN
        [L]ARET_VALUE = fmet this.ADDLINE("COMFDMAS", [V]CST_ALASTPOS)
        If [L]ARET_VALUE <> [V]CST_ANOTDEFINED
            [L]ARET_VALUE = fmet this.COMFDMAS([L]ARET_VALUE).INITIALIZE([F:MFM]ITMREF, [F:MFM]BOMSEQ, [F:MFM]BOMOPE, [F:MFM]RETQTY, [F:MFM]RETQTY - [F:MFM]USEQTY - [F:MFM]ALLQTY)
        Endif
    Next
Return

#**----------------------------------------------------------------<br/>
#* GETFDMA : Retrieve the Fixed material date of first availability
#**<br/>----------------------------------------------------------------<br/>
#* @param OPENUM = Operation number
#* @param DATTIM = FDMA date time returned
#* @param MATFIX = Whether FDMA has been set
#**<br/>----------------------------------------------------------------
#*!
$GETFDMA
    Local Integer I
    Local Date CURDAT

    MATFIX = 0
    DATTIM = null
    CURDAT = [0/0/0]
    ARET_VALUE = 0

    If this.COMFDMAS <> null & maxtab(this.COMFDMAS) > 0
        For [L]I = 1 To maxtab(this.COMFDMAS)
            # Check if the line has been deleted before.
            If find(this.COMFDMAS(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
                If this.COMFDMAS(I).OPENUM = 0 | this.COMFDMAS(I).OPENUM = OPENUM
                    # Find latest date for this operation
                    If this.COMFDMAS(I).FDMA > [L]CURDAT
                        [L]CURDAT = this.COMFDMAS(I).FDMA
                    Endif
                Endif
            Endif
        Next
    Endif

    If CURDAT <> [0/0/0]
        DATTIM = gdatetime$ (right$(num$([L]CURDAT), 7) + "-" + mid$(num$([L]CURDAT), 4, 2) + "-" + left$(num$([L]CURDAT), 2) + "T" + this.FDMATIM + "Z")
        MATFIX = 1
    Endif
Return

