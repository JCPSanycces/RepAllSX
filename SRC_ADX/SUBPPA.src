#<AdxTL>@(#)7.0.0.0 $Revision$ Gestion objet PPA
######################################################################################
## Etiquette ajoutée par le superviseur (Objet PPA) 11/05/2005 08:27:31 (TS)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "FILTRE"    : Gosub FILTRE
 When "LIENS"     : Gosub LIENS
 When "VERIF_CRE" : Gosub VERIF
 When "VERIF_MOD" : Gosub VERIF
 When "INICRE"    : Gosub INICREMOD
 When "INIMOD"    : Gosub INICREMOD
 When default
Endcase
Return

#########################################################################
$OUVRE
Global Integer GACTSTI, GACTSTC
If !clalev([F:PRC1]) Local File TABPRECOD [PRC1] Endif
If !clalev([F:ACV])  Local File ACTIV     [ACV]  Endif
Read [ACV]CODACT="STI"
If !fstat GACTSTI=[F:ACV]DIME Endif 
Read [ACV]CODACT="STC"
If !fstat GACTSTC=[F:ACV]DIME Endif 
Return

#########################################################################
$FILTRE
FILTSUP = "[F:PRC]PRECOD=''"
Return

#########################################################################
$LIENS
[M:PPA]CRIT1=val([F:PRC]FOR1)
[M:PPA]CRIT2=val([F:PRC]FOR2)
[M:PPA]CRIT3=val([F:PRC]FOR3)
[M:PPA]CRIT4=val([F:PRC]FOR4)
[M:PPA]CRIT5=val([F:PRC]FOR5)
Return

#########################################################################
$VERIF
Local Integer OK : OK=1

If [M:PPA]CRIT1>1 
   If find([M:PPA]CRIT1,[M:PPA]CRIT2,[M:PPA]CRIT3,[M:PPA]CRIT4,[M:PPA]CRIT5)
      Call ERREUR (mess(218,184,1)) From GESECRAN
      OK=0 : Return 
   Endif
Else
   Call ERREUR (mess(225,184,1)) From GESECRAN
   OK=0 : Return 
Endif
If [M:PPA]CRIT2>1 
   If find([M:PPA]CRIT2,[M:PPA]CRIT3,[M:PPA]CRIT4,[M:PPA]CRIT5)
      Call ERREUR (mess(218,184,1)) From GESECRAN
      OK=0 : Return 
   Endif
Elsif max([M:PPA]CRIT3,[M:PPA]CRIT4,[M:PPA]CRIT5)>1
   Call ERREUR (mess(225,184,1)) From GESECRAN
   OK=0 : Return 
Endif 
If [M:PPA]CRIT3>1 
   If find([M:PPA]CRIT3,[M:PPA]CRIT4,[M:PPA]CRIT5)
      Call ERREUR (mess(218,184,1)) From GESECRAN
      OK=0 : Return 
   Endif
Elsif max([M:PPA]CRIT4,[M:PPA]CRIT5)>1
   Call ERREUR (mess(225,184,1)) From GESECRAN
   OK=0 : Return 
Endif 
If [M:PPA]CRIT4>1 
   If [M:PPA]CRIT4=[M:PPA]CRIT5
      Call ERREUR (mess(218,184,1)) From GESECRAN
      OK=0 : Return 
   Endif
Elsif [M:PPA]CRIT5>1
   Call ERREUR (mess(225,184,1)) From GESECRAN
   OK=0 : Return 
Endif 
Filter [PRC1] Where STOFCY=[M:PPA]STOFCY & NUMCRIT<>0 & PRECOD<>""
Read [PRC1] First
If !fstat
   Call OUINON (mess(219,184,1),OK) From GESECRAN
   If OK=1 OK=0 Endif   
Endif
Filter [PRC1]
Return

#########################################################################
$INICREMOD
[F:PRC]NUMCRIT = 0
[F:PRC]PRECOD  = ""
[F:PRC]FOR1    = num$([M:PPA]CRIT1)
[F:PRC]FOR2    = num$([M:PPA]CRIT2)
[F:PRC]FOR3    = num$([M:PPA]CRIT3)
[F:PRC]FOR4    = num$([M:PPA]CRIT4)
[F:PRC]FOR5    = num$([M:PPA]CRIT5)
Return

#########################################################################
Subprog AS_CRIT1(VALEUR)
Variable Integer VALEUR
Gosub RAZ_GMEN 
End

Subprog AS_CRIT2(VALEUR)
Variable Integer VALEUR
Gosub RAZ_GMEN 
End

Subprog AS_CRIT3(VALEUR)
Variable Integer VALEUR
Gosub RAZ_GMEN 
End

Subprog AS_CRIT4(VALEUR)
Variable Integer VALEUR
Gosub RAZ_GMEN 
End

Subprog AS_CRIT5(VALEUR)
Variable Integer VALEUR
Gosub RAZ_GMEN 
End

#########################################################################

$RAZ_GMEN
Case GACTSTI
 When 4 : GMENLOC(8)=1
 When 3 : GMENLOC(8)=1 : GMENLOC(7)=1
 When 2 : GMENLOC(8)=1 : GMENLOC(7)=1 : GMENLOC(6)=1
 When 1 : GMENLOC(8)=1 : GMENLOC(7)=1 : GMENLOC(6)=1 : GMENLOC(5)=1
Endcase
Case GACTSTC
 When 4 : GMENLOC(15)=1
 When 3 : GMENLOC(15)=1 : GMENLOC(14)=1
 When 2 : GMENLOC(15)=1 : GMENLOC(14)=1 : GMENLOC(13)=1
 When 1 : GMENLOC(15)=1 : GMENLOC(14)=1 : GMENLOC(13)=1 : GMENLOC(12)=1
Endcase
Return
