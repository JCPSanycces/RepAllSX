#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
    When "INIT"     : Gosub INIT
    When "INIT_DIA" : Gosub INIT_DIA
    When "CONTROLE" : Gosub CONTROLE
    When "EXEC"     : Gosub EXEC
  Endcase
Return

$INIT
  #Declarar coses
  Local File XDOMMAG[XDM]
Return

$INIT_DIA
  [M:DIA]EXPDAT=[14/07/2017]
Return

$CONTROLE
  #Comprobo que realment vull executar i construeixo filtres
  Local Char MIFILTRO(250)
  MIFILTRO="1=1"

  If [M:DIA]STRDOMCOD<>""
    MIFILTRO-="& DOMCOD>='"+[M:DIA]STRDOMCOD+"'"
  Endif

  If [M:DIA]ENDDOMCOD<>""
    MIFILTRO-="& DOMCOD<='"+[M:DIA]ENDDOMCOD+"'"
  Endif

  If [M:DIA]EXPDAT<>[00/00/0000]
    MIFILTRO-="& EXPDAT<=["+num$([M:DIA]EXPDAT)+"]"
  Endif

  If MIFILTRO="1=1"
    Call ECR_TRACE("Debe seleccionar al menos 1 criterio !",1) From GESECRAN
    SAI=1
  Endif
Return

$EXEC
  If GSERVEUR = 0
    Call OUVRE_TRACE("Reset de dominios") From LECFIC
  Endif


  Call DEBTRANS From GLOCK
$TR1
  GOK=1
  Trbegin [XDM]
    Filter [XDM] Where evalue ([L]MIFILTRO)

  If rowcount([F:XDM])=0
    Call ECR_TRACE("Cap registre coincideix",-1) From GESECRAN
  Endif

    For [XDM]
      Call ECR_TRACE(num$(date$)-"Processant domini"-[F:XDM]DOMCOD,0) From GESECRAN
      Readlock [XDM]XDM0=
      If fstat=1
        GOK=-1
        Break
      Elsif fstat
        GOK=0
        Call RSTA ("XDM", [F:XDM]DOMCOD) From GLOCK
        Break
      Endif

    [XDM]XREVNUM=0
    Rewrite[XDM]
    If fstat
      GOK=0
      Call FSTA("XDM") From GLOCK
      Break
    Endif

    Next
    Filter [XDM]

    If GOK=1
      Commit
      Call ECR_TRACE("Tot va bé",0) From GESECRAN
    Elsif GOK=-1
      Call ROLL From GLOCK
      If GROLL
        Rollback
        Call ECR_TRACE("Rollback por error en transacción",1) From GESECRAN
    Else
      Goto TR1
    Endif
  Else
    Rollback
  Endif

  If GSERVEUR = 0
    Call FERME_TRACE() From LECFIC
    Call LEC_TRACE() From LECFIC
  Endif

Return

$EXEC_MINIMALISTA
  #Realment el que s'executarà
  Trbegin [XDM]
  Update [XDM] Where evalue([L]MIFILTRO) With XREVNUM=0
  If fstat
    Rollback
  Else
    Commit
   Endif

Return

