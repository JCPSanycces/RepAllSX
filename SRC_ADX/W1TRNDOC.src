#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TRNDOC 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:52"
A_USER  = "DOC"
A_STAMP = "20181109230652"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask TRNDOC [TRND]
Gosub HORODAT
Local Inpbox "TRNDOC" From GFONCTION At A_STAMP With A_WINDPREV Mask [TRND] As [SIM_]
Grizo [TRND]5
Grizo [TRND]15
Grizo [TRND]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [TRND]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=60 : Y1(0)=1 : Y2(0)=4
X1(1)=1 : X2(1)=60 : Y1(1)=5 : Y2(1)=6
X1(2)=1 : X2(2)=60 : Y1(2)=7 : Y2(2)=9
Return

$ON_DPEDAT
Onevent BEFORE_INPUT Call AS_DPEDAT(zc) From W1TRNDOC
Onevent BEFORE_AREA Gosub AV_DPEDAT From W1TRNDOC
Return

$AV_DPEDAT
Chgfmt [M]DPEDAT(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog AS_DPEDAT(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_DPEDAT(VALEUR) From TRNDOC
If mkstat=2
 [M]DPEDAT(INDIC) = VALEUR
 Affzo DPEDAT(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

$ON_ETD
Onevent CONTROL Call C_ETD(zc) From W1TRNDOC
Onevent AFTER_AREA Call AP_ETD(zc) From W1TRNDOC
Return

Subprog C_ETD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTHM
 Call CONTHM(VALEUR) From OBJDIV
 If mkstat : GERR = 1 : GZONE = "ETD" : GZNUM = 13423 : Endif
Endif
Gosub _AFF
End

Subprog AP_ETD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action INIHM
 Call INIHM(VALEUR) From OBJDIV
 If mkstat : GERR = 1 : GZONE = "ETD" : GZNUM = 13423 : Endif
Endif
Gosub _AFF
End

$ON_ARVDAT
Onevent CONTROL Call C_ARVDAT(zc) From W1TRNDOC
Onevent BEFORE_AREA Gosub AV_ARVDAT From W1TRNDOC
Return

$AV_ARVDAT
Chgfmt [M]ARVDAT(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog C_ARVDAT(VALEUR)
Variable Date    VALEUR
## Action STD
Call C_ARVDAT(VALEUR) From TRNDOC
If mkstat : GERR = 1 : GZONE = "ARVDAT" : GZNUM = 52762 : Endif
Gosub _AFF
End

$ON_ETA
Onevent CONTROL Call C_ETA(zc) From W1TRNDOC
Onevent AFTER_AREA Call AP_ETA(zc) From W1TRNDOC
Return

Subprog C_ETA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTHM
 Call CONTHM(VALEUR) From OBJDIV
 If mkstat : GERR = 1 : GZONE = "ETA" : GZNUM = 13424 : Endif
Endif
If !mkstat
 ## Action STD
 Call C_ETA(VALEUR) From TRNDOC
 If mkstat : GERR = 1 : GZONE = "ETA" : GZNUM = 13424 : Endif
Endif
Gosub _AFF
End

Subprog AP_ETA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action INIHM
 Call INIHM(VALEUR) From OBJDIV
 If mkstat : GERR = 1 : GZONE = "ETA" : GZNUM = 13424 : Endif
Endif
Gosub _AFF
End

$ON_MANDOC
Onevent CONTROL Call C_MANDOC(zc) From W1TRNDOC
Return

Subprog C_MANDOC(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_MANDOC(VALEUR) From TRNDOC
If mkstat : GERR = 1 : GZONE = "MANDOC" : GZNUM = 52733 : Endif
Gosub _AFF
End

$ON_ATCOMICO
Onevent BEFORE_INPUT Call AS_ATCOMICO(zc) From W1TRNDOC
Onevent INIT_AREA Call D_ATCOMICO(zc) From W1TRNDOC
Return

Subprog D_ATCOMICO(VALEUR)
Variable Char    VALEUR()
If varinit([M]ATCOMICO,indice)=0
 VALEUR = 174
Endif
Gosub _AFF
End

Subprog AS_ATCOMICO(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(52696,GBOUTI) From OBJDIV
Onkey 178 Titled GBOUTI Call CL_ATCOMICO(zc) From W1TRNDOC
Gosub _AFF
End

Subprog CL_ATCOMICO(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SNDAT
 Call SENDDTTOAT([M:SCS1]VCRNUM,func PORLEGLIB.DOCTYP(GFONCTION),GBIDI3) From PORLEGLIB1
Endif
If !GWEBSERV
 ## Action STD
 Call CL_ATCOMICO(VALEUR) From TRNDOC
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$CHG_STY
Return


