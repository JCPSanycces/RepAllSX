#<AdxTL>@(#)0.0.0.0 $Revision$ Object management HRSOFO
#ADNGO - 2017-07-11 - X3-12026 - START
#FRLAA - 2015-07-01 - REQUIREMENT 104631 US 3687 - START
$ACTION
Case ACTION
  When "OUVRE"          : Gosub OUVRE
  When "LIENS"          : Gosub LIENS
  When "MODIF"          : Gosub MODIF
  When "CREATION"       : Gosub CREATION
  When "ANNULE"         : Gosub ANNULE
 When Default
Endcase
Return

$OUVRE
If clalev([F:HROFO])=0     : Local File HRSOFOCOD    [HROFO]         : Endif
If clalev([F:HROFOS])=0    : Local File HRSOFOSET    [HROFOS]        : Endif
Return

$LIENS
Filter [F:HROFO] Where SETACOD = [F:HROFOS]SETACOD & OFOVER = [F:HROFOS]OFOVER
nolign = 0
For [HROFO]HROFO0
  nolign += 1
  [M:OFO1] = [F:HROFO]
  If nolign = dim([M:OFO1]OFOCOD) : Break : Endif
Next
Assign "[M:OFO1]NUMOFO" With nolign
Affzo [M:OFO1]
Return

$MODIF
$CREATION
Local Integer ADDCNT

Delete [HROFO] Where SETACOD = [M:OFO0]SETACOD & OFOVER = [M:OFO0]OFOVER
  If fstat=1
    GOK = -1
    GLOCK = "$HRSOFOCOD"-[M:OFO0]SETACOD-[M:OFO0]OFOVER
    Return
  Elsif fstat>5
    GOK = 0
    Call RSTA("HROFOS",[M:OFO0]SETACOD-[M:OFO0]OFOVER) From GLOCK
    Return
  Endif

For [L]ADDCNT=0 To [M:OFO1]NUMOFO-1
  [F:HROFO]SETACOD      =  [M:OFO0]SETACOD
  [F:HROFO]OFOVER       =  [M:OFO0]OFOVER
  [F:HROFO]OFOCOD       =  [M:OFO1]OFOCOD(ADDCNT)
  [F:HROFO]OFOOLDCOD    =  [M:OFO1]OFOOLDCOD(ADDCNT)
  [F:HROFO]OFOTIT       =  [M:OFO1]OFOTIT(ADDCNT)
  Write [HROFO]
Next
Return

$ANNULE
Delete [HROFO] Where SETACOD = [M:OFO0]SETACOD & OFOVER = [M:OFO0]OFOVER
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("HROFO",[M:OFO0]SETACOD-num$([M:OFO0]OFOVER)) From GLOCK : Return
Endif
Return
#FRLAA - 2015-07-03 - REQUIREMENT 104631 US 3687 - END

######################################################################################
#ADNGO - 2017-07-11 - X3-12026 - END

