#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
#    ACTION MODELISATION E-COMMERCE                                     #
#                                                                       #
# GACTION  : TRTAUTALLM  : Action allocation automatique                #
#                                                                       #
#########################################################################
$ACTION
Case ACTION
 When "INIT"          : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "CONTROLE"      : Gosub CONTROLE
 When "EXEC"          : Gosub EXEC
 When "TERMINE"       : Gosub TERMINE
 When Default
Endcase
Return

########################################################################
$INIT

# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif
    
Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub OUVRE
Return

########################################################################
$INIT_DIA

Local    Char    LFCY : LFCY = PARAM(1)
Local    Char    LDAT : LDAT = PARAM(2)
Local    Char    LTYP : LTYP = PARAM(3)
Local    Char    LVCR : LVCR = PARAM(4)
Local    Char    LITM : LITM = PARAM(5)
Local    Integer LRET : LRET = 0

# titre de la boîte 
TIT = mess(36,190,1)
Raz [M:DIA] 

If LFCY <> ""  : [M:DIA]MFGFCY = LFCY  : Else [M:DIA]MFGFCY = GFCY : Endif

If LDAT <> ""    
    If instr(1,LDAT,"/")
        [M:DIA]STRDAT = "["+LDAT+"]"
    Else
        [M:DIA]STRDAT = LDAT
    Endif
Else
   LDAT = date$+ GALLHOR                # llc 08.02 15423 # 15942 11.02 MM 
Endif
Case LTYP
    When "1":     [M:DIA]ALLTYP = 1
    When "3":     [M:DIA]ALLTYP = 2
Endcase
If LVCR <> "" : [M:DIA]MFGNUMDEB = LVCR : [M:DIA]MFGNUMFIN = LVCR : Endif
If LITM <> "" : [M:DIA]ITMREFDEB = LITM : [M:DIA]ITMREFFIN = LITM : Endif

Return

########################################################################
$CONTROLE
TIT=" "
TMP=1
Return

#########################################################################
$EXEC

If !GSERVEUR
    TRA = 1
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
    Call PRTSCR("MAUTALL","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
    Call ECR_TRACE(" ",0) From GESECRAN 
Endif

If [M:DIA]STRDAT = [0/0/0]  : [M:DIA]STRDAT = date$ + GALLHOR : Endif      # llc 08.02 15423 # 15942 11.02 MM

# préparation des critères de filtre
Gosub SEL_MAT

# premier passage pour traiter les ruptures d'abord
If [M:DIA]SHTFLG = 2 : WFLGALL = 1 : Else : WFLGALL = 2 : Endif
Raz NBALL 

# traitement des allocations (premier passage si ruptures prioritaires)
Gosub TRT_MAT

# traitement des allocations (deuxième passage si ruptures prioritaires)
If [M:DIA]SHTFLG = 2 : WFLGALL = 2 : Gosub TRT_MAT : Endif
Return

#########################################################################
$TERMINE
If !GSERVEUR
    # fermeture trace 
    Call FERME_TRACE From LECFIC
    # aucune allocation effectuee ou lecture trace
    If !NBALL 
         GERR = 2 : GMESSAGE = mess(71,193,1)
         PARAM(6) = "9"
    Endif
    # lecture trace
Endif
Return
  
########################################################################
$OUVRE
Local Integer  MODE
Local Integer  OK
Local Integer  NBALL
Local Integer  WFLGALL
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
# sr 09.01 CUSFLT zone de filtres supplémentaires demande 10405
Local Char     CUSFLT(255)
#
Local Char     FORMULE1(255)

# GH 12/09/12 dm 84212
Local Char     FORMULE2(255)
Local Integer  WITF2, WITM2, WMFI
#
Local Char     WMESS(85)
Local Char     WMESS1(85)
Local Char     WMESS2(85)
Local Decimal  WALL
Local Decimal  WSHT
Local Integer  WRET
Local Char     WTRTLIG(1)
Local Char     WTRT(1)
Local Integer  WALLTYP 
Local Char     WITMREF
Local Char     WSTOFCY (GLONFCY)
Local Char     WVCRNUM
Local Integer  WVCRLIN
Local Integer  WVCRSEQ
Local Date     WSTRDAT

Gosub CHARG_PARAM

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev([F:ORD1]) = 0 : Local File ORDERS      [ORD1] : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:ITV])  = 0 : Local File ITMMVT      [ITV]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif
If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO]  : Endif 
If clalev([F:FCY])  = 0 : Local File FACILITY    [FCY]  : Endif         # mm 08.09

If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif

# --- Déclaration classe ecran pour les encours --- #
Local Mask ORDK    [ORDK]

# V6 Affectations
Gosub OPEN_MTO From MTOLINKLIB


Return

########################################################################
# Préparation du filtre sur la table encours (matières)                #
########################################################################
$SEL_MAT

MODE = 0
# critères liés aux articles lancés
CRITERE  = 'STOFCY ="'+[M:DIA]MFGFCY+'"'            # site de production
CRITERE -= '& VCRTYP = 10'                          # ordre de fabrication
CRITERE -= '& WIPSTA = 1'                           # statut ferme

CRITERE -= '& PIO >=' +num$([M:DIA]MFGPIODEB)           # borne début priorité
CRITERE -= '& PIO <=' +num$([M:DIA]MFGPIOFIN)           # borne fin   priorité

If [M:DIA]MFGNUMDEB <> ""                               # borne début OF
   CRITERE -= '& VCRNUM >="'+[M:DIA]MFGNUMDEB+'"'   
Endif
If [M:DIA]MFGNUMFIN <> ""                               # borne fin   OF       
   CRITERE -= '& VCRNUM <="'+[M:DIA]MFGNUMFIN+'"'
Endif

# affaire
If [M:DIA]PJTDEB <> ""
   CRITERE -= '& PJT >="'+[M:DIA]PJTDEB+'"'             # borne début affaire  
Endif
If [M:DIA]PJTFIN <> ""
   CRITERE -= '& PJT <="'+[M:DIA]PJTFIN+'"'             # borne fin   affaire  
Endif

# destinataire
If [M:DIA]BPCNUMDEB <> ""
   CRITERE -= '& BPRNUM >="'+[M:DIA]BPCNUMDEB+'"'       # borne début destin.  
Endif
If [M:DIA]BPCNUMFIN <> ""
   CRITERE -= '& BPRNUM <="'+[M:DIA]BPCNUMFIN+'"'       # borne fin   destin.  
Endif

# no commande
If [M:DIA]VCRNUMDEB <> ""
   CRITERE -= '& VCRNUMORI >="'+[M:DIA]VCRNUMDEB+'"'    # borne début n° commande
Endif
If [M:DIA]VCRNUMFIN <> ""
   CRITERE -= '& VCRNUMORI <="'+[M:DIA]VCRNUMFIN+'"'    # borne fin   n° commande
Endif
If [M:DIA]VCRNUMDEB <> "" | [M:DIA]VCRNUMFIN <> ""
   CRITERE -= '& VCRTYPORI = 2'                         # type pièce =   commande
Endif 

If [M:DIA]ALDEB <> "" | [M:DIA]ALFIN <> ""
    MODE = 1
    CRITERE -= '& WIPTYP = 5'                           # type WO 
    If [M:DIA]ALDEB <> ""
       CRITERE -= '& ITMREF >="'+[M:DIA]ALDEB+'"'       # borne début article lancé
    Endif
    If [M:DIA]ALFIN <> ""
       CRITERE -= '& ITMREF <="'+[M:DIA]ALFIN+'"'       # borne fin   article lancé
    Endif
    CRITERE2 = 'WIPTYP = 6'                             # type MW
    If [M:DIA]ITMREFDEB <> ""
       CRITERE2 -= '& ITMREF >="'+[M:DIA]ITMREFDEB+'"'   # borne début matière
    Endif
    If [M:DIA]ITMREFFIN <> ""
       CRITERE2 -= '& ITMREF <="'+[M:DIA]ITMREFFIN+'"'   # borne fin   matière
    Endif
Else
    CRITERE -= '& WIPTYP = 6'                           # type MW
    If [M:DIA]ITMREFDEB <> ""
       CRITERE -= '& ITMREF >="'+[M:DIA]ITMREFDEB+'"'   # borne début matière
    Endif
    If [M:DIA]ITMREFFIN <> ""
       CRITERE -= '& ITMREF <="'+[M:DIA]ITMREFFIN+'"'   # borne fin   matière
    Endif
Endif

Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

# GH 12/09/12 dm 84212
FORMULE2 = vireblc(FORMULE1,4)
WMFI=0 : WITM2=0 : WITF2=0
If instr(1,FORMULE2,"[ITM2]") | instr(1,FORMULE2,"[F:ITM2]")
   WITM2=1
   If !clalev([F:ITM2]) : Local File ITMMASTER [ITM2] : Endif
Endif

If instr(1,FORMULE2,"[ITF2]") | instr(1,FORMULE2,"[F:ITF2]")
   WITF2=1
   If !clalev([F:ITF2]) : Local File ITMFACILIT [ITF2] : Endif
Endif

If instr(1,FORMULE2,"[MFI]") | instr(1,FORMULE2,"[F:MFI]") | WITM2 | WITF2
    WMFI=1
    If !clalev([F:MFI])  : Local File MFGITM    [MFI] : Endif
Endif

If WMFI | WITF2 | WITM2
& | instr(1,FORMULE2,"[MFM]") | instr(1,FORMULE2,"[F:MFM]")
& | instr(1,FORMULE2,"[MFG]") | instr(1,FORMULE2,"[F:MFG]")
& | instr(1,FORMULE2,"[ITM]") | instr(1,FORMULE2,"[F:ITM]")
& | instr(1,FORMULE2,"[ITF]") | instr(1,FORMULE2,"[F:ITF]")
    FORMULE2 = FORMULE1
    FORMULE1 = "1=1"
Else
    FORMULE2=""
Endif

Return  

##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:DIA]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif      
Else
    Read [F:TFO]TFO0=10;[M:DIA]FORMULE
    If fstat 
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif  
    Else  
        If FORMULE1 = "" 
            FORMULE1  = [F:TFO]FORFOR                 
        Else
            FORMULE1 += "&" 
            FORMULE1 += [F:TFO]FORFOR                 
        Endif
    Endif
Endif

Return

#---------------------------------------------------------------------#
# Traitement des matières                                             #
#---------------------------------------------------------------------#
$TRT_MAT
# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
# sr 09.01 demande 10405
Raz CUSFLT  
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif

# critère pour le traitement des ruptures 
If WFLGALL = 1
   CRITERE1 = "SHTQTY <> 0"
Else
   If [M:DIA]SHTFLG = 2
          CRITERE1 = "SHTQTY = 0"
   Else
       CRITERE1 = "1=1"
   Endif
Endif

# FQ 70409 GA 01/2011 ajout tri VCRTYP,VCRNUM pour regrouper matières même date/priorité d'un OF
# link en tenant compte des critères sur date ou sur code priorité
Case [M:DIA]SORPAR
    When 1: Filter [ORD] Where (evalue(CRITERE) & evalue(CRITERE1) & STRDAT <= [M:DIA]STRDAT) &
&                               evalue(CUSFLT) & evalue(FORMULE1)
&                        Order By STRDAT Asc; PIO Desc; VCRTYP Asc; VCRNUM Asc
    When 2: Filter [ORD] Where (evalue(CRITERE) & evalue(CRITERE1)  & STRDAT <= [M:DIA]STRDAT) &
&                               evalue(CUSFLT) & evalue(FORMULE1)
&                        Order By PIO Desc; STRDAT Asc; VCRTYP Asc; VCRNUM Asc
Endcase
   
# boucle de lecture des matières
For  [ORD] With Nohint                # 10.02 Performances
      # FQ 70409 GA 01/2011 limiter le nb de maj de [F:MFG], on maj l'OF précédent
      If [F:ORD]VCRNUM<>WVCRNUM & WVCRNUM<>""
         Gosub TRTMFG
      Endif
      If MODE = 1
        Filter [ORD1] Where (evalue(CRITERE2) & STRDAT<=[M:DIA]STRDAT & VCRTYP=[F:ORD]VCRTYP & VCRNUM=[F:ORD]VCRNUM) 
&                     Order By STRDAT Asc; PIO Desc       
        For [ORD1] With Nohint        # 10.02 Performances
                WITMREF = [F:ORD1]ITMREF
                WSTOFCY = [F:ORD1]STOFCY
                WVCRNUM = [F:ORD1]VCRNUM
                WVCRLIN = [F:ORD1]VCRLIN
                WVCRSEQ = [F:ORD1]VCRSEQ
                WSTRDAT = [F:ORD1]STRDAT
                Gosub SEL_MATCOMPL            
                If OK = 1 : Goto NXT1 : Endif
                #
                If [F:MFM]ALLQTY = 0 & [F:MFM]SHTQTY = 0 
                    WTRTLIG = "C"
                Else 
                    WTRTLIG = "M" 
                Endif
                Gosub TRTALL
        $NXT1    
        Next
        Filter [ORD1]
        Goto NXT2
      Endif
      WITMREF = [F:ORD]ITMREF
      WSTOFCY = [F:ORD]STOFCY
      WVCRNUM = [F:ORD]VCRNUM
      WVCRLIN = [F:ORD]VCRLIN
      WVCRSEQ = [F:ORD]VCRSEQ
      WSTRDAT = [F:ORD]STRDAT
      Gosub SEL_MATCOMPL            
      If OK = 1 : Goto NXT2 : Endif
      #
      If [F:MFM]ALLQTY = 0 & [F:MFM]SHTQTY = 0 
        WTRTLIG = "C"
      Else 
        WTRTLIG = "M" 
      Endif
      Gosub TRTALL
$NXT2
Next 
Filter [ORD]
# FQ 70409 GA 01/2011 limiter le nb de maj de [F:MFG], traiter le dernier OF
If WVCRNUM<>""
   Gosub TRTMFG
Endif
#
#
Return

#-----------------------------------------------------------------------#
# Sélections complémentaires sur la matière                             #
#-----------------------------------------------------------------------#
$SEL_MATCOMPL

OK=1
# lecture article
If [F:ITM]ITMREF <> WITMREF
    Read [ITM]ITM0=WITMREF
    If fstat : Raz [F:ITM] : Return : Endif
Endif

# lecture article/site
If [F:ITF]ITMREF <> WITMREF | [F:ITF]STOFCY <> WSTOFCY
    Read [ITF]ITF0=WITMREF;WSTOFCY
    If fstat : Raz [F:ITF] : Return : Endif
Endif

# lecture enregistrement entête OF
If [F:MFG]MFGNUM <> WVCRNUM
    Read [MFG]MFG0=WVCRNUM
    If fstat : Raz [F:MFG] : Return : Endif
Endif

# lecture enregistrement matière
Read [MFM]MFM0=WVCRNUM;WVCRLIN;WVCRSEQ;WITMREF
If fstat : Raz [F:MFM] : Return : Endif

#
If !find([F:MFG]MFGMOD,1,2) : Return : Endif
If [F:MFM]MATSTA > 2 : Return : Endif    # si matière soldée ou exclue
Case [M:DIA]ALLTYP
    When 1:    If [F:MFM]ALLSTA >= 4 : Return : Endif # si alloué détail
    When 2:    If [F:MFM]ALLSTA  = 5 : Return : Endif # si alloué détail sans rupture
Endcase

# GH 12/09/12 dm 84212
If FORMULE2<>""
   If WMFI & ([F:MFI]MFGNUM <> WVCRNUM | [F:MFI]MFGLIN <> WVCRLIN)
        # lecture enregistrement ligne OF article lancé
        Read [MFI]MFI0 = WVCRNUM;WVCRLIN
        If fstat : Raz [F:MFI] : Return : Endif
   Endif
   If WITF2 & ([F:ITF2]ITMREF <> [F:MFI]ITMREF | [F:ITF2]STOFCY <> WSTOFCY)
        # lecture enregistrement article/site lancé
        Read [ITF2]ITF0 = [F:MFI]ITMREF;WSTOFCY
        If fstat : Raz [F:ITF2] : Return : Endif
   Endif
   If WITM2 & [F:ITM2]ITMREF <> [F:MFI]ITMREF
        # lecture enregistrement article lancé
        Read [ITM2]ITM0 = [F:MFI]ITMREF
        If fstat : Raz [F:ITM2] : Return : Endif
   Endif
   If !evalue(FORMULE2) : Return : Endif
Endif
#
OK=2

# PE 23570 (llc 07.04)
GPOINT = "CUSSELCOMP" : Gosub ENTREE From EXEFNC
Return

#-----------------------------------------------------------------------#
# Traitement d'une allocation                                           #
#-----------------------------------------------------------------------#
$TRTALL
# FQ 67806 GA 11/2010 PE BEFTRTLIG idem FUNMAUTO
Local Integer GPE : GPE=1
GPOINT = "BEFTRTLIG" : Gosub ENTREE From EXEFNC
If !GPE Return Endif

Gosub VERROU
If !OK : Return : Endif
Call DEBTRANS From GLOCK
GOK = 1
Gosub MAJALL
Gosub DEVERROU
Return

#-----------------------------------------------------------------------#
# Mise à jour des allocations                                           #
#-----------------------------------------------------------------------#
$MAJALL
Local Char    WTRTORD
Local Decimal WCPLQTY
Local Integer MEMSTA : MEMSTA = [F:MFM]ALLSTA # mémo statut

#
WALLTYP = [M:DIA]ALLTYP
WMESS   = mess(156,197,1)+" "+WVCRNUM+" "+mess(157,197,1)+" "+WITMREF+" "+
&         mess(158,197,1)+" "+format$("D:"+GFMDAT,WSTRDAT)                    # 56915 mm 08.09
#
Trbegin [MFG],[MFM]
    # traitement matière
    Readlock [MFM]MFM0 Curr
    If fstat = 1
        GOK = -1 : GLOCK="$MFGITM"+WVCRNUM-num$(WVCRLIN)-num$(WVCRSEQ) 
        Goto ROL_TRTALL
    Elsif fstat
        GOK = 0  : Call RSTA("MFM",WVCRNUM-num$(WVCRLIN)-num$(WVCRSEQ)) From GLOCK
        Goto AB_TRTALL
    Endif
    # si passage de global vers détail, mode "E"
    If (WALLTYP=2 & [F:MFM]ALLSTA > 1 & [F:MFM]ALLSTA < 4) : WTRTLIG = "E" : Endif
    #
    Case WTRTLIG
        When "C","M": If [F:MFM]ALLQTY = 0 & [F:MFM]SHTQTY = 0 
                          WTRT = "C" 
                      Else 
                          WTRT = "M" 
                      Endif      
                      WALL = [F:MFM]RETQTY - [F:MFM]ALLQTY - [F:MFM]SHTQTY - [F:MFM]USEQTY
                      WSHT = [F:MFM]SHTQTY
        When "E":     WTRT = "E"
                      WALL = [F:MFM]ALLQTY
                      WSHT = [F:MFM]SHTQTY
    Endcase
    # appel à la routine de gestion des allocations 
    Call ALLOCATION(WTRT, WALLTYP, WALL, WSHT, WRET) From MFGALL
    If WRET  = 9             # llc 07.01 9308
        Rewrite [MFM]
        WRET = 0
        Goto END_ALL
    Endif
    If WRET <> 0 : Goto AB_TRTALL : Endif

    # mise à jour matière
    Case WTRTLIG
        When "C","M": [F:MFM]ALLQTY    += WALL 
                      [F:MFM]SHTQTY     = WSHT                      
                      Case WALLTYP
                        When 1: [F:MFM]ALLSTA = 3
                        When 2: [F:MFM]ALLSTA = 5
                      Endcase
        When "E":     [F:MFM]ALLQTY     = WALL
                      [F:MFM]SHTQTY     = WSHT
                      [F:MFM]ALLSTA     = 5
    Endcase

    # si rupture, maj statut allocation
    If [F:MFM]SHTQTY <> 0 : [F:MFM]ALLSTA -= 1 : Endif

    # point d'entrée pour modifier spécifiquement les données d'allocation - 09.07 mm 42605
    GPOINT = "MFMMAJ" : Gosub ENTREE From EXEFNC

    # mise à jour matière
    Rewrite [MFM]
    If fstat : GOK=0 : Call FSTA("MFM") From GLOCK : Goto AB_TRTALL : Endif

    # mise à jour encours
    Case MODE
        When 0 : Readlock [ORD] Curr
                 [F:ORD]ALLQTY = [F:MFM]ALLQTY 
                 [F:ORD]SHTQTY = [F:MFM]SHTQTY    
                 Rewrite [ORD]
        When 1 : Readlock [ORD1] Curr
                 [F:ORD1]ALLQTY = [F:MFM]ALLQTY 
                 [F:ORD1]SHTQTY = [F:MFM]SHTQTY    
                 Rewrite [ORD1]
    Endcase
    If fstat : GOK=0 : Call FSTA("ORD") From GLOCK : Goto AB_TRTALL : Endif
 
    # traces
    Call ECR_TRACE(WMESS,0) From GESECRAN
    WMESS1 = "          "+mess(106,197,1)+":"+format$("N:15F", WALL)  
    WMESS2 = "          "+mess(159,197,1)+":"+format$("N:15F", WSHT)  
    Call ECR_TRACE(sum(WMESS1, " ",WMESS2),0) From GESECRAN
    Raz WMESS, WMESS1, WMESS2
    
    # FQ 70409 GA 01/2011 Maj déplacée + tard pour performances
    # mise à jour entête
    ##### Gosub MAJMFG
    
    # v6 affectations
    Gosub MAJ_MTO_MFM From MFGMTOLIB
    
    NBALL += 1
$END_ALL                    # llc 07.01 9308
Commit
Return

# FQ 70409 GA 01/2011 Maj déplacée + tard pour performances
#####-----------------------------------------------------------------------#
##### Mise à jour de l'entete OF                                            #
#####-----------------------------------------------------------------------#
####$MAJMFG
####Local Integer XTOT
####Local Integer I
#####
