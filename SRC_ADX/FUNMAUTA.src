#-----------------------------------------------------------------------#
# Maj globale d'un OF après allocations                                 #
#-----------------------------------------------------------------------#
$TRTMFG                                           # FQ 70409 GA 01/2011 #
Gosub VERROU
If !OK : Return : Endif
Call DEBTRANS From GLOCK
GOK = 1
Gosub MAJMFG
Gosub DEVERROU
Return

#-----------------------------------------------------------------------#
# Mise à jour de l'entete OF                                            #
#-----------------------------------------------------------------------#
$MAJMFG                                           # FQ 70409 GA 01/2011 #
Local Integer XTOT
Local Integer I
#
If WVCRNUM="" Return Endif

Trbegin [MFG]
#
  Readlock [MFG]MFG0=WVCRNUM
  If fstat = 1
     GOK = -1 : GLOCK = "$MFGHEAD"+[F:MFG]MFGNUM 
     Goto ROL_TRTMFG
  Elsif fstat
     GOK = 0  : Call RSTA("MFG",   [F:MFG]MFGNUM) From GLOCK
     Goto AB_TRTMFG
  Endif
#
  Gosub MAJMFGHEAD From MFGLIB
#
  # 82781
  [F:MFG]UPDDAT = date$
  [F:MFG]UPDUSR = GUSER
  [F:MFG]EXPNUM = [C]EXPORT
  Rewrite [MFG]
  If fstat
     GOK = 0 : Call FSTA("MFG") From GLOCK
     Goto AB_TRTMFG
  Endif
#
Commit
#
Return
$ROL_TRTMFG
Rollback
Call ROLL From GLOCK
If GROLL 
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Endif
Return
$AB_TRTMFG
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return


#-----------------------------------------------------------------------#
# Positionnement d'un verrou sur l'entête OF                            #
#-----------------------------------------------------------------------#
$VERROU
SYMBOLE = "MFG"+[F:MFG]MFGNUM
Lock = SYMBOLE With lockwait = 0
OK = 1
If fstat = 1
    Call ECR_TRACE([F:MFG]MFGNUM - mess(10,100,1),1) From GESECRAN 
    OK = 0
Endif 
Return

#-----------------------------------------------------------------------#
# Suppression du verrou sur l'entête OF                                 #
#-----------------------------------------------------------------------#
$DEVERROU
Unlock=SYMBOLE
Return

$ROL_TRTALL
Rollback
Call ROLL From GLOCK
If GROLL 
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Else Goto MAJALL :Endif
Return

$AB_TRTALL
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

######################################################################## 
$CHARG_PARAM 
#----- Variables globales stock 
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA


Return 

