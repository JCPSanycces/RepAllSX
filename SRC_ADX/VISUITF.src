#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE" :     
    Case GACTION
      When "VISUITF" : Gosub OUVRE_VISUITF 
      When "VISUUNI" : Gosub OUVRE_VISUUNI
    Endcase 
  When "SETBOUT" :    
    Case GACTION
      When "VISUITF" : Gosub SETBOUT_VISUITF 
    Endcase
  When "DEBUT" :    
    Case GACTION
      When "VISUITF" : Gosub DEBUT_VISUITF 
      When "VISUUNI" : Gosub DEBUT_VISUUNI
    Endcase 
  When "BOUTON" :
    Case GACTION
      When "VISUITF" : Gosub BOUTON_VISUITF 
    Endcase
Endcase
Return
############################################################
$OUVRE_VISUITF 
If PARAM(2) = ""
  FIN = 1
Else
  If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
  If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
  If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
  If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
Endif
Local Char W_INT(30)(40)
Local Char W_DMY(10) : W_DMY = ""
Call STKDETSTO("[F:ITV]","","[M:VITF]","NBLIG",W_INT,1,0) From STKACT
Return
############################################################
$SETBOUT_VISUITF 
If [M]CFGLIN = ""
  ETABOU(GSPE4) = 0
Else 
  ETABOU(GSPE4) = 1
Endif
If [M]CUNLISNUM = ""
  ETABOU(GSPE5) = 0
Else 
  ETABOU(GSPE5) = 1
Endif
Return
############################################################
$DEBUT_VISUITF 
Raz [M:VITF]
If PARAM(1) = ""
  FIN = 1
  Return
Endif
#
If [F:FCY]FCY <> PARAM(1) 
  Read [FCY]FCY0=PARAM(1)
  If fstat
     Raz [F:FCY]
  Endif
Endif
[M:VITF] = [F:FCY]
#
If [F:ITM]ITMREF <> PARAM(2)
 Read [ITM]ITM0=PARAM(2)
 If fstat
    Raz [F:ITM]
  Endif
Endif
[M:VITF] = [F:ITM]
#
If [F:ITF]STOFCY <> PARAM(1) | [F:ITF]ITMREF <> PARAM(2)
  Read [ITF]ITF0=PARAM(2);PARAM(1)
  If fstat
    Raz [F:ITF]
  Endif
Endif
[M:VITF] = [F:ITF]

[M:VITF]STOMGTCOD     = [F:ITM]STOMGTCOD
[M:VITF]STOMGTCODI    = [F:ITF]STOMGTCOD

If dim([M:VITF]NBLOC)>0
    [M:VITF]NBLOC = 0
    For W_I = 0 To dim([F:ITF]LOCNUM)-1
      If [F:ITF]LOCNUM(W_I) <> 0 | [F:ITF]DEFLOCTYP(W_I) <> "" | [F:ITF]DEFLOC <> ""
        If [M:VITF]NBLOC < dim([M:VITF]LOCNUM)-1
          [M:VITF]NBLOC += 1
        Endif
      Endif
    Next W_I
Endif
#
If [F:ITV]STOFCY <> PARAM(1) | [F:ITV]ITMREF <> PARAM(2)
  Read [ITV]ITV0=PARAM(2);PARAM(1)
  If fstat
    Raz [F:ITV]
  Endif
Endif
[M:VITF] = [F:ITV]
[M:VITF]ITMREF = [F:ITM]ITMREF 
#
Call STKVISUNI([F:ITM]ITMREF,"[M:VITF]","NBUOM",W_DMY)    From STKACT
Call STKDETSTO("[F:ITV]","","[M:VITF]","NBLIG",W_INT,2,0) From STKACT
#
Affzo [M:VITF]
Return
############################################################
$BOUTON_VISUITF 
Return
############################################################
# Action VISUUNI Visualisation des unités article
############################################################
$OUVRE_VISUUNI 
If PARAM(1) = ""
  FIN = 1
Else
  If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
  If clalev([F:TUN]) = 0 : Local File TABUNIT    [TUN] : Endif
  Read [ITM]ITM0=PARAM(1)
  If fstat
    FIN = 1
  Endif
Endif
Return
############################################################
$DEBUT_VISUUNI 
Local Char W_DMY(10) : W_DMY = ""
Raz [M:VUNI]
[M:VUNI] = [F:ITM]
Call STKVISUNI([F:ITM]ITMREF,"[M:VUNI]","NBLIG",W_DMY) From STKACT
#
Affzo [M:VUNI]
Return
############################################################
Subprog AV_INTFLD(VALEUR)
Variable Char    VALEUR()
Case left$(VALEUR,3)
  When "*  "   : pcolor = GCOUL(3)
  When "** "   : pcolor = GCOUL(0)
  When "***"   : pcolor = GCOUL(1)
  When Default : pcolor = GCOUL(0)
Endcase
End

#########################################################################

