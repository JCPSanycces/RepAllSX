#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PRF1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone ACCCOD
mkstat = 0
zoncou = "ACCCOD"
indice = 0
If varinit([M]ACCCOD,indice)=0
 SAVACT = GACTION : GACTION = "INITACCCOD"
 Call INITACCCOD([M]ACCCOD,29) From TRTX3
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]ACCCOD,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "ACCCOD" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTCAC"
  Call CONTCAC([M]ACCCOD,"29") From SUBCAC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("CAC","!",[M]ACCCOD,"29",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone EMPMDL
mkstat = 0
zoncou = "EMPMDL"
indice = 0
If varmode([M]EMPMDL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EMPMDL" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "DROITEMP"
 Call DROIT([M]EMPMDL,"","","") From DIVPAYE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "EMPMDL" : GZNUM = 47669 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("EML","!",[M]EMPMDL,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "EMPMDL" : GZNUM = 47669 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBRCCE
mkstat = 0
zoncou = "NBRCCE"
indice = 0
status = 1
zoncou = "NBRCCE"
If varmode([M]NBRCCE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRCCE" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRCCE
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRCCE = nolign
   status = 75
   Call SAI_NBRCCE(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone PRFCMT
mkstat = 0
zoncou = "PRFCMT"
For indice=0 To 2
 If varmode([M]PRFCMT,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "PRFCMT" : Gosub ACTION From =IMPTRT
  Endif
 Endif
 mkstat = 0
Next indice
If mkstat : End : Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRCCE(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRCCE
mkstat = 0
zoncou = "NBRCCE"

## Zone CCE
mkstat = 0
zoncou = "CCE"
SAVACT = GACTION : GACTION = "INICCEFMT"
Call INICCEFMT(num$([M]DIE(nolign-1))) From SETGLBDIE
GACTION = SAVACT
If mkstat=1 : Raz [M]CCE(indice) : Endif
If !mkstat
 If varmode([M]CCE,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "CCE" : Gosub ACTION From =IMPTRT
  Endif
  Call CONTROLE("CCE","!",[M]CCE(indice),num$([M]DIE(nolign-1)),mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 1688 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CNTCCE"
   Call SECTION([M]CCE(indice),1,"",[0/0/0],[M]DIE(nolign-1)) From SUPCPT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 1688 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NBRCCE
mkstat = 0
zoncou = "NBRCCE"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PRF1"
Return

