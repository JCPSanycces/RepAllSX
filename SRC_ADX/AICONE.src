#<AdxTL>@(#)2.0.0.0 $Revision$

Local Char PARAM(10)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"AICONE","AICONE","") From GSAISIE
End


$ACTION
Case ACTION
  When "DEBUT" : Gosub DEBUT
Endcase
Return


$DEBUT
Local Integer I
 Local Integer I
[M]NBLIG=50
  For I=1 To [M]NBLIG
    [M]C01(I-1)=(I-1)*10+0   : [M]C1(I-1)=num$([M]C01(I-1))
    [M]C02(I-1)=(I-1)*10+1   : [M]C2(I-1)=num$([M]C02(I-1))
    [M]C03(I-1)=(I-1)*10+2   : [M]C3(I-1)=num$([M]C03(I-1))
    [M]C04(I-1)=(I-1)*10+3   : [M]C4(I-1)=num$([M]C04(I-1))
    [M]C05(I-1)=(I-1)*10+4   : [M]C5(I-1)=num$([M]C05(I-1))
    [M]C06(I-1)=(I-1)*10+5   : [M]C6(I-1)=num$([M]C06(I-1))
    [M]C07(I-1)=(I-1)*10+6   : [M]C7(I-1)=num$([M]C07(I-1))
    [M]C08(I-1)=(I-1)*10+7   : [M]C8(I-1)=num$([M]C08(I-1))
    [M]C09(I-1)=(I-1)*10+8   : [M]C9(I-1)=num$([M]C09(I-1))
    [M]C010(I-1)=(I-1)*10+9 : [M]C10(I-1)=num$([M]C010(I-1))
  Next I
Affzo [M]
Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran AICONE)
######################################################################################
Subprog AM_C01(VALEUR)
Variable Decimal VALEUR
If VALEUR>0 and VALEUR<250
  [M]C1(nolign-1)=num$(VALEUR)
  Affzo [M]C1
Endif
End

Subprog AM_C02(VALEUR)
Variable Decimal VALEUR
If VALEUR>0 and VALEUR<250
  [M]C2(nolign-1)=num$(VALEUR) 
  Affzo [M]C2
Endif
End

Subprog AM_C03(VALEUR)
Variable Decimal VALEUR
If VALEUR>0 and VALEUR<250
  [M]C3(nolign-1)=num$(VALEUR)
  Affzo [M]C3
Endif
End


######################################################################################
