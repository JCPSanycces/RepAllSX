#<AdxTL>@(#)1.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("PDM",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : Gosub EFFMASK
 When "RAZCRE"      : Gosub RAZCRE
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "ANNULE"      : Gosub ANNULE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When Default
Endcase
Return

$OUVRE
If clalev([COA]) = 0 : Local File GCOA [COA] : Endif
If !GIMPORT & CLE1=""
 Read [COA]COA0 First
 CLE2 = [F:COA]COA
Endif
GBIDC2 = CLE2
Return

$INICRE
$INIMOD
If dim([F:PDM]DES)>0
 [F:PDM]DES = [M:PDM1]DESTRA
Endif
Return

$RAZCRE
[M]COA = GBIDC2
Return

$EFFMASK
[M:PDM1]COA = GBIDC2
Affzo [M:PDM1]COA
Return

$FILGAUCHE
FILGAUCHE = '[F:PDM]COA="'+GBIDC2+'"'
Return

$FILTRE
If GIMPORT : GBIDC2 = [F:PDM]COA : Endif
If GFONCTION="GESPDM"
 If CRITERE<>"" : CRITERE += " & " : Endif
 CRITERE += '[F:PDM]COA="'+GBIDC2+'"'
Endif
Return

$LIENS
Call LECTEXTRA([M:PDM1]DESTRA,"GAPARDUM","DESTRA",[M:PDM1]COA,[M:PDM1]COD) From ATEXTRA
Call LECTEXTRA([M:PDM1]SHOTRA,"GAPARDUM","SHOTRA",[M:PDM1]COA,[M:PDM1]COD) From ATEXTRA
Return

$SETBOUT
CHAINE += "AH"
If GREP<>""
 Call VIREBOUT(CHAINE,"1") From GOBJET 
Endif
[M:PDM1]COA = GBIDC2 : Affzo [M:PDM1]COA : Grizo [PDM1]COA
Return

$EXEBOUT
Case REP
 When "1"
  If (VALBOUT = "") : Return : Endif
  Gosub DEVERROU From GOBJET
  Effzo
  [M:PDM1]COA = VALBOUT
  Affzo [M:PDM1]COA
  GBIDC2 = [M]COA
  Gosub REMPLIT From GOBJSUB
  Raz CLECUR
  Filter [PDM] Where COA=GBIDC2
  Read [PDM]PDM0 First
  Filter [PDM]
  If !fstat
   CLECUR1 = [F:PDM]COA
   Gosub LECTURE From GOBJSUB
  Endif
Endcase  
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GAPARDUM","DESTRA",CLECUR2,CLECUR1,"GAPARDUM","DESTRA",[M:PDM1]COA,[M:PDM1]COD)  From ATEXTRA
 Call DUPTEXTRA("GAPARDUM","SHOTRA",CLECUR2,CLECUR1,"GAPARDUM","SHOTRA",[M:PDM1]COA,[M:PDM1]COD)  From ATEXTRA
Endif
Call MAJTEXTRA([M:PDM1]DESTRA,"GAPARDUM","DESTRA",[M:PDM1]COA,[M:PDM1]COD) From ATEXTRA
Call MAJTEXTRA([M:PDM1]SHOTRA,"GAPARDUM","SHOTRA",[M:PDM1]COA,[M:PDM1]COD) From ATEXTRA
Return


$AP_CHANGE
Call CHGTEXTRA("GAPARDUM","DESTRA",[M:PDM1]COA,[M:PDM1]COD,[M:PDM1]COA,NCODE) From ATEXTRA
Call CHGTEXTRA("GAPARDUM","SHOTRA",[M:PDM1]COA,[M:PDM1]COD,[M:PDM1]COA,NCODE) From ATEXTRA
Return


$ANNULE
Call SUPTEXTRA("GAPARDUM","DESTRA",[M:PDM1]COA,[M:PDM1]COD) From ATEXTRA
Call SUPTEXTRA("GAPARDUM","SHOTRA",[M:PDM1]COA,[M:PDM1]COD) From ATEXTRA
Return


##########################################################################
# Etiquettes du masque PDM1 [PDM] : Paramétrage déversement compte
##########################################################################
Subprog C_ACCSTR(VALEUR)
Variable Char     VALEUR
Call UNICITE(VALEUR,[M:PDM1]ACCSTR(0..[M:PDM1]NBLIG-1)) From OBJDIV
End

Subprog C_ACCDEB(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
If left$(VALEUR,len([M:PDM1]ACCSTR(NOL)))=[M:PDM1]ACCSTR(NOL)
 # Le compte ne doit pas commencer par [M:PDM1]ACCSTR(NOL)
 GMESSAGE = mess(18,104,1)-[M:PDM1]ACCSTR(NOL)
 mkstat=2 : End
Else
 Call LECTURE("GAC",VALEUR,[M]COA) From CONTOBJ
 If [F:GAC]SAC = 2
  # Compte de type collectif
  GMESSAGE = mess(19,104,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog C_ACCCDT(VALEUR)
Variable Char     VALEUR
Call C_ACCDEB(VALEUR)
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

