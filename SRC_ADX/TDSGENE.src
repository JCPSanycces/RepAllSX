#<AdxTL>@(#)3.0.0.0 $Revision$
#*X3-104535 MWA  Parameters linked to activity code (04.09.2018)

Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TDSGENE","DTDSGENE",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
Endcase
Return

$OUVRE
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:BPA])=0 : Local File BPADDRESS[BPA] : Endif
If clalev([F:DCP])=0 : Local File DADCPY   [DCP] : Endif
If clalev([F:FTD])=0 : Local File FILTDS   [FTD] : Endif
Return

$INIT_DIA
TMP = 1 : TRA = 1
## LS Bug 20765
Raz [M]
Return

$EXEC
Call TDSGENE
Return

############################################################################
Subprog TDSGENE
Local Integer OK
Local Char    TIT(50)
Local Char    SYMBOLE(30)
Gosub OUVRE
TIT = mess(57,122,1) : # Génération fichier TDS

SYMBOLE = "TDS"+num$([M:DIA]YEA)
Lock =SYMBOLE
If fstat
 # Opération en cours sur autre poste
 Call ECR_TRACE(mess(30,100,1),1) From GESECRAN : End
Endif

GOK = 1
If [M]TDSFLG=2
 Call CONTLTDS From TDSCTL
Endif
If !GOK
 If !GSERVEUR
  Call FERME_TRACE From LECFIC
 Endif
 Goto SORTIE
Endif

Call GENEFIC

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif

$SORTIE
Unlock =SYMBOLE
End

############################################################################
Subprog GENEFIC

Gosub OUVRE2
Gosub DECLARE

Gosub RAZ_TDSPRV
If GOK<=0 : End : Endif

################# Point d'entrée FILTRE #################
Raz [L]CRITERE
GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC
If [L]CRITERE="" : [L]CRITERE="1=1" : Endif

Gosub TR1
If GOK<=0 : End : Endif

If [M:DIA]ALLCPY<>2
 Filter [DCP] Where find(CPY,[M:DIA]CPY(0..[M:DIA]NBLIG-1))
Endif

Gosub VERIF_PLANCHER
If !GOK : Filter [DCP] : End : Endif

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxium = GASCII

ORECTYP = -1
If [M]TDSFLG=1
 [L]COD = "DADS-U"
 Read [FTD]FTD0=[M]GRP
Else
 [L]COD = "TDSBI"
 Read [TFT]TFT0 = [L]COD;1;1
Endif

FICHIER2 = [M:DIA]FICHIER
If left$(FICHIER2, 2)="#@"
 FICHIER2 = right$(FICHIER2, 3)
Endif
Call MACHINE(FICHIER2,MACHINE,CHEMIN) From ORDSYS
NOM = date$+"_"+num$(time)
If [M]TEST=2
 NOM +="T" : # Fichier test
Endif

If [M]TDSFLG=2 # TDSB-BI
 FICHIER = filpath(FICHIER2, [F:TFT]FILREF+NOM, "TDB", 0, "", MACHINE)
 EXPFIL = [F:TFT]FILREF+NOM+".TDB"
 If [M]TYPEXP=1 : # Client
  Call SET_FICNAM(FICHIER,FICDON,URL) From ORDSYS
 Else
  FICDON = FICHIER
 Endif
 SOURCE  = filpath(FICHIER2, [F:TFT]FILREF+NOM+"X", "TDB", 0, "", MACHINE)
 If [M]TYPEXP=1 : # Client
  Call SET_FICNAM(SOURCE,FICSRC,URL_S) From ORDSYS
 Else
  FICSRC = SOURCE
 Endif
Else # DADS-U
 FICHIER = filpath(FICHIER2, [F:FTD]FILREF+NOM, "DAD", 0, "", MACHINE)
 EXPFIL = [F:FTD]FILREF+NOM+".DAD"
 If [M]TYPEXP=1 : # Client
  Call SET_FICNAM(FICHIER,FICDON,URL) From ORDSYS
 Else
  FICDON = FICHIER
 Endif
Endif

Local Integer FIN
If [M]TDSFLG=1
 Gosub EXEC From TRTDADSU # génération DADS-U
 Goto SUITE
Endif

If [M]TDSFLG=2 # TDSB-BI
 Openo FICSRC, 0
 adxifs = chr$(9)
 adxirs = chr$(10)
Endif

Openo FICDON,0
adxifs = ""
adxirs = ""
Call DEBTRANS From GLOCK

Trbegin [TPR]
# Drapeau de début(000)
Read [FCY]FCY0=[M:DIA]SENFCY
## LS Bug 20765
# Edition du drapeau si fichier TDS. Si fichier TDS bilatérale, pas de drapeau
If [M]TDSFLG=1
 [L]RECTYP = 1
 Gosub ECR_TDS
Endif

For [DCP]
 SYMBOLE = "HONLIN"+"\"+[F:DCP]CPY
 Lock =SYMBOLE
 Filter [HLN] Where year(DAT)=[M:DIA]YEA & CPY=[F:DCP]CPY & AMTLOC<>0 & evalue(CRITERE)
 Read[HLN]HLN0 First
 If !fstat
  # En-tête entreprise(010)
  Raz TAMTHON,TFCY,THONLIN
  Read [CPY]CPY0=[F:DCP]CPY
  Read [FCY]FCY0=[F:CPY]MAIFCY
  [L]RECTYP = 2
  Gosub ECR_TDS
  # En-tête établissement(020)
  For [HLN]HLN1(1)  : # Par site DAS2
   Read [DFC]DFC0=[F:HLN]DADFCY
   If [F:DFC]NBDAS=1 : SECFCY=1 : Endif : # 1 DADS salaires
   If [F:DFC]NBDAS=2 : SECFCY=2 : Endif : # 2 DADS salaires
   If [F:DFC]TAXWAG=2
    TAXSAL = "I"                        : # Etablissement imposable
   Else
    TAXSAL = "N"                        : # Etablissement non imposable
   Endif
   [L]RECTYP = 3
   Gosub ECR_TDS
   For I=1 To N : Raz TAMTHON(I,1) : Next I : # Raz totaux par site
   TFCY +=1
   # Lignes honoraires(210)
   For [HLN]HLN1(2) : # Par site DAS2 et par prestataire
    Raz AMTHON,NATHON,MODHON,RETHON
    For [HLNA] Where DADFCY=[F:HLN]DADFCY & PRVNUM=[F:HLN]PRVNUM &
&                    year(DAT)=[M:DIA]YEA
     AMTHON([F:HLNA]HON) +=[F:HLNA]AMTLOC
     For I=1 To len([F:HLNA]TYPHON)
      If [F:HLNA]HON=10
       Case mid$([F:HLNA]TYPHON,I,1)
        When "N" : NATHON(1)="N"
        When "L" : NATHON(2)="L"
        When "V" : NATHON(3)="V"
        When "A" : NATHON(4)="A"
       Endcase
      Elsif [F:HLNA]HON=9
       Case mid$([F:HLNA]TYPHON,I,1)
        When "F" : MODHON(1)="F"
        When "R" : MODHON(2)="R"
        When "P" : MODHON(3)="P"
       Endcase
      Elsif [F:HLNA]HON=11
       Case mid$([F:HLNA]TYPHON,I,1)
        When "R" : RETHON(1)="R"
        When "D" : RETHON(2)="D"
       Endcase
      Endif
     Next I
    Next : # HLNA
    OK = 0
    For I=1 To N
     If find(format$("K:"+num$(GLONCPY)+"X",[F:DCP]CPY)+[F:HLN]PRVNUM,OUTPRV1(0..1999)) &
&      find(I,1,2,3,4,5,8,9,10,11)
      AMTHON(I) = 0
      Case I
       When 9  : Raz MODHON
       When 10 : Raz NATHON
       When 11 : Raz RETHON
      Endcase
     Elsif find(format$("K:"+num$(GLONCPY)+"X",[F:DCP]CPY)+[F:HLN]PRVNUM,OUTPRV2(0..1999)) &
&      find(I,6,7)
      AMTHON(I)  = 0
      AMTHON(12) = 0 : # Raz TVA s/droit auteur si plancher Droit pas atteint
     Else
      AMTHON(I) = arr(AMTHON(I),1)
     Endif
     If AMTHON(I)>0
      For J=0 To 1 : TAMTHON(I,J) += AMTHON(I) : Next J
      OK = 1
     Else AMTHON(I) = 0
     Endif
     Gosub MAJ_TPR
     If GOK<=0 : Rollback : Endif
    Next I
    If OK : # au moins un montant honoraires<>0 sur une ligne
     THONLIN +=1
     Read[PRV]PRV0=[F:HLN]PRVNUM
     [L]RECTYP = 4
     Gosub ECR_TDS
    Endif
   Next : # HLN1(2)
   # Total site(300)
   [L]RECTYP = 5
   Gosub ECR_TDS
  Next : # HLN1(1)
  # Total entreprise(312)
  [L]RECTYP = 6
  Gosub ECR_TDS
 Endif
 Filter [HLN]
 Unlock =SYMBOLE
Next
If [M:DIA]ALLCPY=1
 Filter [DCP]
Endif

# Drapeau de fin(990)
## LS Bug 20765
# Edition du drapeau si fichier TDS. Si fichier TDS bilatérale, pas de drapeau
If [M]TDSFLG=1
 [L]RECTYP = 7
 Gosub ECR_TDS
Endif
[L]RECTYP = 0
Gosub STRUCTURE
If [M]TYPEXP=1
 Call COPCLI(FICDON,FICHIER,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  Call ERREUR(mess(164,141,1)) From GESECRAN
  FIN=1 : Rollback : Goto SUITE
 Elsif STAT>1
  # Fichier inexistant
  Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  FIN=1 : Rollback : Goto SUITE
 Endif
 Call COPCLI(FICSRC,SOURCE,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  Call ERREUR(mess(164,141,1)) From GESECRAN
  FIN=1 : Rollback : Goto SUITE
 Elsif STAT>1
  # Fichier inexistant
  Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  FIN=1 : Rollback : Goto SUITE
 Endif
Endif
Commit

$SUITE
If FIN=1 : End : Endif

While(instr(0, FICHIER, "\")<>0)
 POS = instr(0, FICHIER, "\")
 FICHIER = mid$(FICHIER, 1, POS-1)+"/"+mid$(FICHIER, POS+1, len(FICHIER)-POS)
Wend
If [M]TYPEXP=1
 Call ECR_TRACE(mess(178,115,1),0) From GESECRAN
Else
 # Création du fichier
 Call ECR_TRACE(mess(12,125,1)-[M]VOLFIL+"/"+EXPFIL,0) From GESECRAN #<YYFIN_93938_US351>
Endif
If [M]TDSFLG=2 # TDSB-BI
 While(instr(0, SOURCE, "\")<>0)
  POS = instr(0, SOURCE, "\")
  SOURCE = mid$(SOURCE, 1, POS-1)+"/"+mid$(SOURCE, POS+1, len(SOURCE)-POS)
 Wend
 # Création du fichier
 If [M]TYPEXP=1
  Call ECR_TRACE(mess(178,115,1),0) From GESECRAN
 Else
  Call ECR_TRACE(mess(12,125,1)-SOURCE,0) From GESECRAN
 Endif
Endif
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

End


$TR1
Call DEBTRANS From GLOCK
Trbegin [HLN]
 If [M:DIA]ALLCPY=1
  Filter [HLN] Where find(CPY,[M:DIA]CPY(0..[M:DIA]NBLIG-1))
 Endif
 For [HLN]HLN0 Where year(DAT)=[M:DIA]YEA & evalue(CRITERE)
  Read[FCY]FCY0=[F:HLN]FCY
  Readlock [HLN]HLN0 Curr
  GCLE = [F:HLN]FCY-[F:HLN]PRVNUM-[F:HLN]DAT-num$([F:HLN]HON)-num$([F:HLN]LINNUM)
  If fstat=1
   GOK = -1 : GLOCK="$HONLIN"-GCLE : Break
  Elsif fstat
   GOK = 0 : Call RSTA("HLN",GCLE) From GLOCK : Break
  Else
   [F:HLN]DADFCY = [F:FCY]DADFCY
   Rewrite [F:HLN]
   If fstat
    GOK = 0 : Call FSTA("HLN") From GLOCK : Break
   Endif
  Endif
 Next
 If [M:DIA]ALLCPY=1 : Filter [HLN] : Endif
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$AB_TR1
Rollback
Return

$VERIF_PLANCHER
I = 0
J = 0

Local Integer LDAS : # X3-104535
LDAS = func AFNC.ACTIV("DAS")
If LDAS = G_OUI
 Call PARAM([F:DCP]CPY,"AMTDCLDAS",PLANCHERCH) From ADOVAL
Endif : # X3-104535
PLANCHER1 = val(PLANCHERCH) : # Param société tjs exprimé en devise reporting

For [DCP]
 Call LECTURE("CPY",[F:DCP]CPY,"") From CONTOBJ
 Call CONVERT(GSYSCUR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,1,date$,PLANCHER1,PLANCHER,OK) From TRTDEV
 If OK
  Call ERREUR(mess(16,114,1)-GSYSCUR-"=>"-[F:CPY]ACCCUR) From GESECRAN  : # Pas de cours de devise
  GOK = 0
  Break
 Endif
 For [PRV]
  Raz EVALMT1,EVALMT2,OK
  For [HLN] Where CPY=[F:DCP]CPY & year(DAT)=[M:DIA]YEA & PRVNUM=[F:PRV]PRVNUM & evalue(CRITERE)
   Case [F:HLN]HON
    When 1,2,3,4,5,8,9,10,11
     EVALMT1 += [F:HLN]AMTLOC
     OK = 1
    When 6,7
     EVALMT2 += [F:HLN]AMTLOC
     OK = 1
   Endcase
  Next
  If EVALMT1<=PLANCHER & OK
   OUTPRV1(I) = format$("K:"+num$(GLONCPY)+"X",[F:DCP]CPY)+[F:PRV]PRVNUM
   I +=1
  Endif
  If EVALMT2<=PLANCHER & OK
   OUTPRV2(J) = format$("K:"+num$(GLONCPY)+"X",[F:DCP]CPY)+[F:PRV]PRVNUM
   J +=1
  Endif
 Next
Next
If GOK=0 : Return :Endif
Return

$ECR_TDS
For [TFT]TFT0 Where COD=[L]COD & RECTYP=[L]RECTYP
 If [F:TFT]FRM=""
  CHAINE = ""
 Else
  Onerrgo ERR
  CHAINE = num$(evalue([F:TFT]FRM))
  Onerrgo
 Endif
 Case [F:TFT]FLDTYP
  When 1 : Gosub ALPHA
  When 2 : Gosub NUM
 Endcase
Next
Gosub STRUCTURE
Return

$ERR
# Erreur en évaluation de la formule
Call ECR_TRACE(mess(65,106,1)-[F:TFT]FRM,1) From GESECRAN
Resume

$STRUCTURE
If ORECTYP=-1
 NB = 1
 ORECTYP = [L]RECTYP
Elsif [L]RECTYP<>ORECTYP
 Openo FICSRC, -1
 adxifs = chr$(9)
 adxirs = chr$(10)
 Wrseq ORECTYP,NB
 ORECTYP = [L]RECTYP
 NB =1
 Openo FICDON,-1
 adxifs = ""
 adxirs = ""
Else
 NB +=1
Endif
Return

$ALPHA
If ascii(CHAINE)>=32
 ENREG = toupper(ctrans(left$(CHAINE+space$([F:TFT]LNG),[F:TFT]LNG)))
Else
 ENREG = left$(CHAINE+space$([F:TFT]LNG),[F:TFT]LNG)
Endif
Wrseq ENREG,
Return

$NUM
ENREG = right$(string$([F:TFT]LNG,"0")+CHAINE,len(CHAINE)+1)
Wrseq ENREG,
Return

$RAZ_TDSPRV
# Raz de la table des cumuls honoraires/prestataires
Call DEBTRANS From GLOCK
Trbegin [TPR]
 If [M:DIA]ALLCPY<>2
  Delete [TPR] Where find(CPY,[M:DIA]CPY(0..[M:DIA]NBLIG-1))
  If fstat=1 | fstat>5
   GOK = 0
   Call RSTA("TPR","") From GLOCK
   Goto AB_RAZ
  Endif
 Else
  Delete [TPR] Where "1=1"
  If fstat=1 | fstat>5
   GOK = 0
   Call RSTA("TPR","") From GLOCK
   Goto AB_RAZ
  Endif
 Endif
Commit
Return

$AB_RAZ
Rollback
Return

$MAJ_TPR

# Demande 42955 : Le code prestataire n'est pas forcément un tiers et si tiers, le code tiers peut être <> code prestataire.
#  Enregistrement du tiers pour un lien direct sur l'adresse pour l'édition LETTREDAS - Recherche de l'adresse.
#  CAS 1 : Sous la fiche fournisseur : prestataire renseigné => code fournisseur, Adresse Fournisseur
#  CAS 2 : Sous la fiche fournisseur : prestataire vide => Prestataire = Fournisseur, Adress Frouniseur
#  CAS 3 : Sous la fiche fournisseur : prestataire <> fournisseur
#* (a) le code prestataire pointe vers une fiche tiers et on prend l'adresse de la fiche tiers associé au prestataire
#* (b) le code prestataire ne pointe pas vers une fiche tiers

# 65462 : utilisation de l'abréviation BPZ pour la table BPSUPPLIER, car la table BPADDRESS utilise déjà l'abréviation BPS (dans TRTDADSU)

Raz [L]CODBPR
If [F:BPZ]BPSNUM<>[F:HLN]PRVNUM
 Read [F:BPZ]BPS0 = [F:HLN]PRVNUM
 If !fstat
  [L]CODBPR = [F:BPZ]BPSNUM
 Endif
Else
 [L]CODBPR = [F:BPZ]BPSNUM
Endif

If [L]CODBPR=""
 Filter [BPZ] Where PRVNUM=[F:HLN]PRVNUM
 Read [BPZ] First
 Filter [BPZ]
 If !fstat
  [L]CODBPR = [F:BPZ]BPSNUM
 Endif
Endif

Readlock [TPR]TPR0=[F:HLN]PRVNUM;[F:DCP]CPY
If fstat=1
 GOK = -1 : GLOCK = "$TDSPRV"-[F:HLN]PRVNUM-[F:DCP]CPY : Return
Elsif fstat
 Raz [F:TPR]
 [F:TPR]CPY         = [F:DCP]CPY
 [F:TPR]PRVNUM      = [F:HLN]PRVNUM
 [F:TPR]AMTLOC(I-1) = AMTHON(I)
 [F:TPR]HON(I-1)    = I
 [F:TPR]SENFCY      = [M]SENFCY
 [F:TPR]YEA         = [M]YEA
 [F:TPR]BPRNUM      = [L]CODBPR
 Write [TPR]
Else
 [F:TPR]AMTLOC(I-1) +=AMTHON(I)
 [F:TPR]HON(I-1)    = I
 [F:TPR]BPRNUM      = [L]CODBPR
 Rewrite [TPR]
Endif
If fstat
 GOK=0 : Call FSTA("TPR") From GLOCK : Return
Endif
Return

$OUVRE2
Local File TABFILTDS[TFT], HONLIN[HLN], DADCPY[DCP], DADFCY[DFC], TDSPRV[TPR],
&          COMPANY[CPY], FACILITY[FCY], HONLIN[HLNA], HONPRV[PRV], BPARTNER [BPR], BPSUPPLIER [BPZ]
Return

$DECLARE
Local Integer N,I,J,OK,NB
N = len(mess(0,615,1))               : # 615 Types d'honoraires
Local Char    MSG(80)
Local Char    NOM(30)
Local Char    FICHIER(GDIMFIC)       : # Chemin+nom du fichier TDS
Local Char    FICHIER2(GDIMFIC)      : # variable intermédiaire pour le calcul de la valeur de FICHIER
Local Char    EXPFIL(GDIMFIC)        :
Local Char    SOURCE(GDIMFIC)        : # Chemin+nom du fichier récap
Local Char    COD(10)
Local Integer RECTYP,ORECTYP         : # Type d'enregistrement
Local Char    CHDATE(50)
Local Char    CHAINE(200)
Local Char    ENREG(200)             : # Enregistrement à écrire
Local Decimal TAMTHON(1..N,2)        : # Totaux par Entreprise(0) et par Site(1)
Local Integer SECFCY                 : # Section établissement
Local Decimal AMTHON(1..N)           : # Totaux par ligne honaraire
Local Char    NATHON(1)(1..4)        : # Type avantage en nature
Local Char    MODHON(1)(1..3)        : # Type modalité de prise en charge
Local Char    RETHON(1)(1..2)        : # Type de retenue à la source
Local Integer THONLIN                : # Nombre de lignes d'honoraires
Local Integer TFCY                   : # Nombre d'établissement
Local Decimal EVALMT1,EVALMT2        : # Total des sommes à déclarer /an/prestataire
Local Char    OUTPRV1(GLONCPY+GLONPRV)(2000)      : # Tableau Sté/Prestataire n'atteignant pas le plancher
Local Char    OUTPRV2(GLONCPY+GLONPRV)(2000)      : # Tableau Sté/Prestataire n'atteignant pas le plancher
Local Char    PLANCHERCH(4)
Local Decimal PLANCHER1, PLANCHER
Local Char    SYMBOLE(30)
Local Char    TAXSAL(1)              : # Code assujettissement taxe sur salaire
Local Char    CRITERE(250)
Local Char    SAVIFS(5),SAVIRS(5)
Local Integer SAVIUM
# Variables pour Poste Client
Local Char FICDON(GDIMFIC),URL(GDIMFIC)
Local Char FICSRC(GDIMFIC),URL_S(GDIMFIC)
Local Char CHEMIN(GDIMFIC)
Local Char MACHINE(GDIMFIC)
Local Integer STAT
# Code Tiers pour LETTREDAS
Local Char CODBPR(GLONBPR)
Return

Subprog PARAM(DOSSIER,USER,P1,P2,OK)
Value    Char    DOSSIER
Value    Char    USER
Variable Char    P1()(1..)
Variable Char    P2()(1..)
Variable Integer OK
Local Char TIT(30)
TIT = mess(57,122,1) : # Génération fichier TDS
Gosub OUVRE
Raz [M:DIA]
###DBA le 01/08/04 : Passage V140
Local Char WIN (GLONFEN)
WIN="DTDSGENE"
Call PARAM(DOSSIER,USER,P1,P2,OK,TIT,WIN) From CPTTRT
###
End

