  [L]WCHAMP="PERSTR" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:ITH]PERSTR : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="PEREND" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:ITH]PEREND : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="FIYNUM" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:ITH]FIYNUM : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="PERNUM" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:ITH]PERNUM : Gosub TRACE_MAJ_CHAMP
  If [F:ITH]YEARCPQTY<>0
