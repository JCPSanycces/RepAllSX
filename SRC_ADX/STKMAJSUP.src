#<AdxTL>@(#)1.0.0.0 $Revision$
########################################################################
# Traitement STKMAJSUP - Librairie des composants de màj stock    V140 #
#                        Trace détaillée pour contrôle màj champs      #
########################################################################
# Etiquettes appelées par Gosub depuis le  STKMAJ
#
# MAJ_STOSRG          Mise à jour du plan de rangement
# UPD_STOSRG          Suppression ou réécriture enregistrement SRG
# CRE_STOSRG          Création enregistrement SRG
#
# Etiquettes appelées par Gosub depuis les STKMAJ-E-S-C       MBT 2003
#
# TRACE_DEB_LIGNE     Trace début traitement d'une ligne détail
# TRACE_DETAILLEE     Trace détaillée (tables mises à jour)
# TRACE_HYPER_DETAIL  Trace hyper détaillée (champs mis à jour)
#
#-----------------------------------------------------------------------
# Autres étiquettes appelées par Gosub depuis ce traitement :
#
# TRACE_DETAIL_STS    Trace de la table STOSER    (numéros de série)
# TRACE_DETAIL_STP    Trace de la table STOCOST   (couts)
# TRACE_DETAIL_STJ    Trace de la table STOJOU    (mouvements de stock)
# TRACE_DETAIL_STO    Trace de la table STOCK     (lignes de stock)
# TRACE_DETAIL_SRG    Trace de la table STOSRG    (plan de rangement)
# TRACE_DETAIL_QLH    Trace de la table STOQLYH   (entête contrôle qualité)
# TRACE_DETAIL_QLD    Trace de la table STOQLYD   (ligne contrôle qualité)
# TRACE_DETAIL_STA    Trace de la table STOALL    (allocations)
# TRACE_DETAIL_STL    Trace de la table STOLOT    (lots)
# TRACE_DETAIL_SLF    Trace de la table STOLOTFCY (lots/site)
#   DETAIL_STL_ISS      Changement emplacement sortie
#   DETAIL_STL_RCP      Changement emplacement entrée
#   DETAIL_STL_ISSRCP   Changement emplacement sortie+entrée
# TRACE_DETAIL_ITV    Trace de la table ITMMVT    (cumuls article-site)
#   ITV_INTER_SITE      Dans le cas de l'inter-site
# TRACE_DETAIL_ITH    Trace de la table ITMMVTHIS (historique art-site)
# TRACE_DETAIL_REO    Trace de la table STOREO (Reappro zone consommation) (HCB)
#
# TRACE_MAJ_CHAMP     Trace de la mise à jour d'un champ d'une table
#
########################################################################

#----------------------------------------#
# Mise à jour plan de rangement (STOSRG) #
#----------------------------------------#
$MAJ_STOSRG

If [L]WQTEACT=0  Return : Endif
#                                                                    # hcb 110327 deb
# il ni a pas de création de plan de rangement pour les articles gérés en séries globales sur des mvts de:
#                                                               7  Changement stock
#                                                               8  Controle qualité
#                                                               13 Inventaire
#                                                               12 retour sur livraison#
#                                                               18 retour sur livraison pret

If [F:ITM]SERMGTCOD = 4 & find([M:STW]TRSTYP,7,8,13)
   Return
Endif
If [F:ITM]SERMGTCOD = 4 & find([M:STW]TRSTYP,12,18) & [M:STW]VCRNUMORI <> ""
   Return
Endif
#                                                                    # hcb 110327 end
#--- Issue 101561
# La suppression d'une ligne de document de type flux de sortie ne doit pas
# regénérer de STOSRG, car celui-ci ne serait pas exploitable dans le plan de
# rangement (la pièce origine du STOSRG serait une sortie)
#If find([M:STW]TRSTYP,2,4,6,11,17,20,24,29,32) & WMAJCOD="A" : Return : Endif
[L]WFIC="STOSRG"
[L]WCLE=num$([F:STO]STOCOU)-num$([M:STW]VCRTYP)-[M:STW]VCRNUM-num$([M:STW]VCRLIN)
Readlock [SRG] SRG0=[F:STO]STOCOU;[M:STW]VCRTYP;[M:STW]VCRNUM;[M:STW]VCRLIN
If fstat=1
  GLOCK="$STOSRG"-[L]WCLE
  [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
Elsif fstat
  #--- Bug 69358
  # Si quantité négative, on ne fait rien
#  If [L]WQTEACT<0 Return Endif      # hcb 73072
  #---
  [L]WCLE=""
  [L]WQTE=[L]WQTEACT

  #--- Dem 34933 (Pb REM)
  #If !find([M:STW]TRSTYP,1,3,5,12,19) & !(find([M:STW]TRSTYP,7,8,13,14)&[L]WQTEACT>0)
  If !find([M:STW]TRSTYP,1,3,5,12,16,19) & !(find([M:STW]TRSTYP,7,8,13,14,22,34)&[L]WQTEACT>0)
  #---
    For [SRG] SRG0 Where STOCOU=[F:STO]STOCOU
      [L]WCLE=num$([F:SRG]STOCOU)-num$([F:SRG]VCRTYP)-[F:SRG]VCRNUM-num$([F:SRG]VCRLIN)
      Readlock [SRG] Curr
      If fstat=1
        GLOCK="$STOSRG"-[L]WCLE
        [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Break
      Elsif fstat
        Call RSTA("SRG",[L]WCLE) From GLOCK
        [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Break
      Endif
      If [L]WQTE<0 & [F:SRG]QTYSTUACT>0
        [L]WQTEACT=-min([F:SRG]QTYSTUACT,abs([L]WQTE))
      Else
        [L]WQTEACT=[L]WQTE
      Endif
      [L]WQTE-=[L]WQTEACT
      Gosub UPD_STOSRG
      If GOK<1 | [L]WQTE=0  Break : Endif
    Next
    If GOK<1  Return : Endif
  Endif
  If [L]WCLE=""
     If [L]WQTEACT >0    # hcb 73072
        Gosub CRE_STOSRG
        Raz [L]WQTE
        If GOK<1
           Return
        Endif
     Else               # hcb 73072
        Raz [L]WQTE     # hcb 73072
     Endif              # hcb 73072
  Endif
  #----- Prise en compte du reliquat si nécessaire -----#
  If [L]WQTE<>0
    Readlock [SRG] Curr
    If fstat=1
      GLOCK="$STOSRG"-[L]WCLE
      [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
    Elsif fstat
      Call RSTA("SRG",[L]WCLE) From GLOCK
      [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
    Endif
    [L]WQTEACT=[L]WQTE : Raz [L]WQTE
    Gosub UPD_STOSRG : If GOK<1  Return : Endif
  Endif
Else
  Gosub UPD_STOSRG : If GOK<1  Return : Endif
Endif
#----- La quantité en unité active ne doit pas être inférieure à zéro -----#
If [F:SRG]QTYSTUACT<0 & ([L]WMAJCOD<>"A" | !find([F:STO]LOC,[M:STW]LOC(I+1..[M:STW]NBLIG-1)))
  [M:STW]ERRCOD=39 : Gosub TRT_ERR From STKMAJ : Return
Endif
Return

#---------------------------------------------------------------#
# Suppression ou réécriture enregistrement du plan de rangement #
#---------------------------------------------------------------#
$UPD_STOSRG
[F:SRG]QTYSTUACT+=[L]WQTEACT
#----- Plan de rangement désynchronisé ! -----#
If ([F:STO]QTYSTUACT=0 & [F:SRG]QTYSTUACT<>0) | [F:SRG]QTYSTUACT<0
  If [M:STW]TRAFLG>2
    [L]WMESSAGE =num$([F:STO]STOCOU)
    [L]WMESSAGE-=num$([F:SRG]VCRTYP)-[F:SRG]VCRNUM-num$([F:SRG]VCRLIN)
    [L]WMESSAGE-="("+num$([F:SRG]QTYSTUACT)+")"
    [L]WMESSAGE-=mess(487,197,1)
    Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
    If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
    [F:SRG]QTYSTUACT=0
  Endif
Endif
#----- Suppression ligne de rangement -----#
If [F:SRG]QTYSTUACT<=0
  [L]WVCRTYP=[F:SRG]VCRTYP : [L]WVCRNUM=[F:SRG]VCRNUM : [L]WVCRLIN=[F:SRG]VCRLIN
  Delete [SRG] Where STOCOU=[F:STO]STOCOU
&                  & VCRTYP=[L]WVCRTYP
&                  & VCRNUM=[L]WVCRNUM
&                  & VCRLIN=[L]WVCRLIN
  If fstat=1
    GLOCK="$STOSRG"-[L]WCLE
    [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
  Elsif fstat
    Call FSTA("SRG") From GLOCK
    [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
  Endif
  [L]WMESSAGE=mess(175,197,1)
  [F:SRG]QTYSTUACT=0
#----- Réécriture ligne de rangement -----#
Else

  # Si plan de rangement via les terminaux portables,
  # on ne traite pas forcément toute la quantité de la liste à ranger
  If [M:STW]TRSTYP=22 & GVTMOD=1
    Raz [F:SRG]QTYSTU
    For [SGW1]SGW0 Where STOCOU=[F:SRG]STOCOU & VCRTYP=[F:SRG]VCRTYP &
&                        VCRNUM=[F:SRG]VCRNUM & VCRLIN=[F:SRG]VCRLIN
        [F:SRG]QTYSTU+=[F:SGW1]QTYSTU
    Next
    # Toute la quantité de la liste à ranger a été traitéé
    If [F:SRG]QTYSTU=0
      [F:SRG]STAFLG=1
      Raz [F:SRG]SRGPPS, [F:SRG]PCU, [F:SRG]PCUSTUCOE, [F:SRG]QTYPCU
    # Recalcul de la quantité de la liste à ranger restant à traiter
    Else
      If [F:SRG]PCUSTUCOE=0 [F:SRG]PCUSTUCOE=1 Endif
      [F:SRG]QTYPCU = [F:SRG]QTYSTU/[F:SRG]PCUSTUCOE
    Endif
  Else
    [F:SRG]STAFLG=1
    Raz [F:SRG]SRGPPS, [F:SRG]PCU, [F:SRG]PCUSTUCOE, [F:SRG]QTYSTU, [F:SRG]QTYPCU
  Endif

  Call REWSRG From STKLIB
  If fstat
    Call FSTA("SRG") From GLOCK
    [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
  Endif
  [L]WMESSAGE=mess(232,197,1)
Endif
If [M:STW]TRAFLG>2  Gosub TRACE_DETAILLEE From STKMAJSUP : Endif
Return

#-------------------------------------------#
# Création enregistrement plan de rangement #
#-------------------------------------------#
$CRE_STOSRG
Raz [F:SRG]
[F:SRG] = [F:STO]
Raz [F:SRG]PCU, [F:SRG]PCUSTUCOE, [F:SRG]QTYPCU, [F:SRG]QTYSTU
[F:SRG]STAFLG   =1
If [M:STW]TRSTYP=22
  Case [M:STW]VCRTYP
    When 4,5     : [F:SRG]TRSTYP= 4
    When 6       : If [L]WFLUX=1 [F:SRG]TRSTYP= 3 Else [F:SRG]TRSTYP=29 : Endif
    When 8       : [F:SRG]TRSTYP=11
    When 9       : [F:SRG]TRSTYP=13
    When 10      : If [L]WFLUX=1 [F:SRG]TRSTYP= 5 Else [F:SRG]TRSTYP= 6 : Endif
    When 12      : If [L]WFLUX=1 [F:SRG]TRSTYP=19 Else [F:SRG]TRSTYP= 6 : Endif
    When 13      : [F:SRG]TRSTYP=12
    When 15      : [F:SRG]TRSTYP= 5
    When 19      : [F:SRG]TRSTYP= 1
    When 20      : [F:SRG]TRSTYP= 2
    When Default : If [L]WFLUX=1 [F:SRG]TRSTYP=1 Else [F:SRG]TRSTYP=2 : Endif
  Endcase
Else
  [F:SRG]TRSTYP   =[M:STW]TRSTYP
Endif
[F:SRG]VCRTYP   =[M:STW]VCRTYP
[F:SRG]VCRNUM   =[M:STW]VCRNUM
[F:SRG]VCRLIN   =[M:STW]VCRLIN

[F:SRG]QUAFLG   =[M:STW]QUAFLG(I)   # hcb V6CQ
[F:SRG]QUAFRE   =[M:STW]QUAFRE(I)   # hcb V6CQ
[F:SRG]BPRNUM   =[M:STW]BPRNUM      # hcb V6CQ

# Si inventaire [M:STW]VCRLIN est nul --> il faut prendre [M:STW]MVTSEQ(I)
If [M:STW]VCRTYP=9 [F:SRG]VCRLIN=[M:STW]MVTSEQ(I) Endif
[F:SRG]VCRTYPORI=[M:STW]VCRTYPORI
[F:SRG]VCRNUMORI=[M:STW]VCRNUMORI
[F:SRG]VCRLINORI=[M:STW]VCRLINORI
[F:SRG]MVTDES   =[M:STW]MVTDES
[F:SRG]PJT      =[M:STW]PJT
[F:SRG]IPTDAT   =[M:STW]IPTDAT
[F:SRG]QTYSTUACT=[L]WQTEACT
If ([F:STO]QTYSTUACT=0 & [F:SRG]QTYSTUACT<>0) | [F:SRG]QTYSTUACT<0
  If [M:STW]TRAFLG>2
    [L]WMESSAGE =num$([F:STO]STOCOU)
    [L]WMESSAGE-=num$([M:STW]VCRTYP)-[M:STW]VCRNUM-num$([F:SRG]VCRLIN)
    [L]WMESSAGE-="("+num$([F:SRG]QTYSTUACT)+")"
    [L]WMESSAGE-=mess(487,197,1)
    Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
    If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
  Endif
  If [F:SRG]QTYSTUACT<0  Return : Endif
Endif
[L]WCLE=num$([F:SRG]STOCOU)-num$([F:SRG]VCRTYP)-[F:SRG]VCRNUM-num$([F:SRG]VCRLIN)
Call ECRSRG From STKLIB
If fstat
  Call FSTA("SRG") From GLOCK
  [M:STW]ERRCOD=70 : [L]WFIC="STOSRG" : Gosub TRT_ERR From STKMAJ : Return
Endif
[L]WMESSAGE=mess(233,197,1)
If [M:STW]TRAFLG>2  Gosub TRACE_DETAILLEE From STKMAJSUP : Endif
Return

#-------------------------------------------#
# Trace début traitement d'une ligne détail #
#-------------------------------------------#
$TRACE_DEB_LIGNE
[L]WMESSAGE ="-------"-format$("D:"+GFMDAT4,date$)-time$
Case [M:STW]MAJCOD(I)
  When "C"     : [L]WMESSAGE-=mess(51,197,1)
  When "A"     : [L]WMESSAGE-=mess(53,197,1)
  When Default : [L]WMESSAGE-="????????"
Endcase
Case [M:STW]MAJTYP(I)
  When "E"     : [L]WMESSAGE-=mess(1,331,1)
  When "S"     : [L]WMESSAGE-=mess(2,331,1)
  When "C"     : [L]WMESSAGE-=mess(164,190,1)
  When Default : [L]WMESSAGE-="????????"
Endcase
[L]WMESSAGE-=mess(18,197,1)-":"-num$(I+1)
[L]WMESSAGE-="-------"
Call ECR_TRACE ([L]WMESSAGE,0) From GESECRAN
If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
Raz [L]WMESSAGE
Return


#------------------------------------------------#
# Ecriture d'une trace détaillée (mise au point) #
#------------------------------------------------#
$TRACE_DETAILLEE
If [M:STW]TRAFLG>1
  If [M:STW]TRAFLG>3 & [L]WMESSAGE<>mess(478,197,1) & [L]WMESSAGE<>mess(175,197,1)
    Gosub TRACE_HYPER_DETAIL From STKMAJSUP
  Endif
  If [L]WFIC="STOJOU" & [L]WTRSTYP=96
    [L]WMESSAGE-="("+mess(493,197,1)+")"
  Elsif [L]WFIC="STOJOU" & [L]WTRSTYP=97
    [L]WMESSAGE-="("+mess(511,197,1)+")"
  Elsif [L]WFIC="STOJOU" & [L]WTRSTYP=98
    [L]WMESSAGE-="("+mess(510,197,1)+")"
  Elsif [L]WFIC="STOJOU" & [L]WTRSTYP=99
    [L]WMESSAGE-="("+mess(27,701,1)+")"
  Elsif [L]WFIC="STOCK" & [L]WRECOND=1
    [L]WMESSAGE-="("+mess(493,197,1)+")"
  Elsif [L]WFIC="STOCK" & find([L]WPCURUL,1,2)
    [L]WMESSAGE-="("+mess(493,197,1)+")"
  Endif
  Call ECR_TRACE([L]WCLE-mess(87,116,1)-[L]WFIC-[L]WMESSAGE,0) From GESECRAN
  If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
Else
  Call MESSAGE([L]WCLE-mess(87,116,1)-[L]WFIC-[L]WMESSAGE)     From GESECRAN
Endif
Return


#-----------------------#
# Trace hyper détaillée #
#-----------------------#
$TRACE_HYPER_DETAIL
If dim([L]WMESSAG2) <1  Local Char     WMESSAG2(100) : Endif
If dim([L]WCHAMP)   <1  Local Char     WCHAMP(15)    : Endif
If dim([L]WTYPCHAMP)<1  Local Libelle  WTYPCHAMP     : Endif
If dim([L]WVALNUM)  <1  Local Decimal  WVALNUM       : Endif
If dim([L]WVALCHR)  <1  Local Char     WVALCHR(35)   : Endif
If dim([L]WVALDAT)  <1  Local Date     WVALDAT       : Endif
If dim([L]ABRFIC)   <1  Local Char     WABRFIC(7)    : Endif
If dim([L]WSNS)     <1  Local Shortint WSNS          : Endif
Case [L]WFIC
  When "STOSER"    : Gosub TRACE_DETAIL_STS
  When "STOCOST"   : Gosub TRACE_DETAIL_STP
  When "STOJOU"    : Gosub TRACE_DETAIL_STJ
  When "STOCK"     : Gosub TRACE_DETAIL_STO
  When "STOSRG"    : Gosub TRACE_DETAIL_SRG
  When "STOQLYH"   : Gosub TRACE_DETAIL_QLH
  When "STOQLYD"   : Gosub TRACE_DETAIL_QLD
  When "STOALL"    : Gosub TRACE_DETAIL_STA
  When "STOLOT"    : Gosub TRACE_DETAIL_STL
  When "STOLOTFCY" : Gosub TRACE_DETAIL_SLF
  When "ITMMVT"    : Gosub TRACE_DETAIL_ITV
  When "ITMMVTHIS" : Gosub TRACE_DETAIL_ITH
  When "STOREO"    : Gosub TRACE_DETAIL_REO
  When "STOJOUVAL" : Gosub TRACE_DETAIL_SJV
Endcase
Return


#-----------------------------------------------------#
# Trace de la table des numéros de série STOSER [STS] #
#-----------------------------------------------------#
$TRACE_DETAIL_STS
[L]WABRFIC="[F:STS]"
If [L]WMESSAGE=mess(233,197,1)
  [L]WCHAMP="ITMREF"   : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STS]ITMREF   : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="SERNUM"   : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STS]SERNUM   : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="STOFCY"   : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STS]STOFCY   : Gosub TRACE_MAJ_CHAMP
  If [F:STS]VCRTYP<>0
    [L]WCHAMP="VCRTYP"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]VCRTYP
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STS]VCRNUM<>""
    [L]WCHAMP="VCRNUM"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]VCRNUM
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STS]VCRLIN<>0
    [L]WCHAMP="VCRLIN"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]VCRLIN
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STS]RCPDAT<>[0/0/0]
    [L]WCHAMP="RCPDAT"    : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STS]RCPDAT
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STS]RCPFCY<>""
    [L]WCHAMP="RCPFCY"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]RCPFCY
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STS]RCPVCRTYP<>0
    [L]WCHAMP="RCPVCRTYP" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]RCPVCRTYP
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STS]RCPVCRNUM<>""
    [L]WCHAMP="RCPVCRNUM" : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]RCPVCRNUM
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STS]RCPVCRLIN<>0
    [L]WCHAMP="RCPVCRLIN" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]RCPVCRLIN
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STS]BPCNUM<>""
    [L]WCHAMP="BPCNUM"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]BPCNUM
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STS]BPAADD<>""
    [L]WCHAMP="BPAADD"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]BPAADD
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STS]SDHTYP<>0
    [L]WCHAMP="SDHTYP"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]SDHTYP
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STS]SDHNUM<>""
    [L]WCHAMP="SDHNUM"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]SDHNUM
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STS]SDDLIN<>0
    [L]WCHAMP="SDDLIN"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]SDDLIN
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STS]ISSDAT<>[0/0/0]
    [L]WCHAMP="ISSDAT"    : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STS]ISSDAT
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STS]GUAENDDAT<>[0/0/0]
    [L]WCHAMP="GUAENDDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STS]GUAENDDAT
    Gosub TRACE_MAJ_CHAMP
  Endif
Elsif [L]WMESSAGE=mess(232,197,1)
  Case [L]WCODFONC
    When 1
      [L]WCHAMP="STOFCY"      : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]STOFCY
      Gosub TRACE_MAJ_CHAMP
      If [M:STW]QTYSTU(I)*[L]SIGN>0
        [L]WCHAMP="RCPFCY"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]RCPFCY
        Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="RCPDAT"    : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STS]RCPDAT
        Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="RCPVCRTYP" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]RCPVCRTYP
        Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="RCPVCRNUM" : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]RCPVCRNUM
        Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="RCPVCRLIN" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]RCPVCRLIN
        Gosub TRACE_MAJ_CHAMP
      Else
        [L]WCHAMP="SDHTYP"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]SDHTYP
        Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="SDHNUM"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]SDHNUM
        Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="SDDLIN"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]SDDLIN
        Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="ISSDAT"    : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STS]ISSDAT
        Gosub TRACE_MAJ_CHAMP
      Endif
    When 2
      If [L]SENS=-1 & [F:STS]RCPVCRTYP=[M:STW]VCRTYP
&                   & [F:STS]RCPVCRNUM=[M:STW]VCRNUM
&                   & [F:STS]RCPVCRLIN=[M:STW]VCRLIN
        [L]WCHAMP="RCPVCRTYP" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]RCPVCRTYP
        Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="RCPVCRNUM" : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]RCPVCRNUM
        Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="RCPVCRLIN" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]RCPVCRLIN
        Gosub TRACE_MAJ_CHAMP
      Endif
      [L]WCHAMP="BPCNUM"      : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]BPCNUM
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="BPAADD"      : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]BPAADD
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="SDHTYP"      : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]SDHTYP
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="SDHNUM"      : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]SDHNUM
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="SDDLIN"      : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]SDDLIN
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="ISSDAT"      : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STS]ISSDAT
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="GUAENDDAT"   : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STS]GUAENDDAT
      Gosub TRACE_MAJ_CHAMP
    When 3
      Case [L]WFLUX
        When 1
          [L]WCHAMP="STOFCY"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]STOFCY
          Gosub TRACE_MAJ_CHAMP
          [L]WCHAMP="RCPDAT"    : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STS]RCPDAT
          Gosub TRACE_MAJ_CHAMP
          [L]WCHAMP="RCPFCY"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]RCPFCY
          Gosub TRACE_MAJ_CHAMP
          [L]WCHAMP="RCPVCRTYP" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]RCPVCRTYP
          Gosub TRACE_MAJ_CHAMP
          [L]WCHAMP="RCPVCRNUM" : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]RCPVCRNUM
          Gosub TRACE_MAJ_CHAMP
          [L]WCHAMP="RCPVCRLIN" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]RCPVCRLIN
          Gosub TRACE_MAJ_CHAMP
          [L]WCHAMP="BPCNUM"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]BPCNUM
          Gosub TRACE_MAJ_CHAMP
          [L]WCHAMP="BPAADD"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]BPAADD
          Gosub TRACE_MAJ_CHAMP
          [L]WCHAMP="SDHTYP"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]SDHTYP
          Gosub TRACE_MAJ_CHAMP
          [L]WCHAMP="SDHNUM"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]SDHNUM
          Gosub TRACE_MAJ_CHAMP
          [L]WCHAMP="SDDLIN"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]SDDLIN
          Gosub TRACE_MAJ_CHAMP
          [L]WCHAMP="ISSDAT"    : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STS]ISSDAT
          Gosub TRACE_MAJ_CHAMP
          [L]WCHAMP="GUAENDDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STS]GUAENDDAT
          Gosub TRACE_MAJ_CHAMP
        When 2
          If [M:STW]MAJCOD(I)="C"
            [L]WCHAMP="SDHTYP"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[M:STW]VCRTYP
            Gosub TRACE_MAJ_CHAMP
            [L]WCHAMP="SDHNUM"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[M:STW]VCRNUM
            Gosub TRACE_MAJ_CHAMP
            [L]WCHAMP="SDDLIN"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[M:STW]VCRLIN
            Gosub TRACE_MAJ_CHAMP
            [L]WCHAMP="BPCNUM"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[M:STW]BPRNUM
            Gosub TRACE_MAJ_CHAMP
            [L]WCHAMP="BPAADD"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[M:STW]BPAADD
            Gosub TRACE_MAJ_CHAMP
          Else
            [L]WCHAMP="STOFCY"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]STOFCY
            Gosub TRACE_MAJ_CHAMP
            [L]WCHAMP="SDHTYP"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]VCRTYP
            Gosub TRACE_MAJ_CHAMP
            [L]WCHAMP="SDHNUM"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]VCRNUM
            Gosub TRACE_MAJ_CHAMP
            [L]WCHAMP="SDDLIN"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STS]VCRLIN
            Gosub TRACE_MAJ_CHAMP
            [L]WCHAMP="BPCNUM"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]BPCNUM
            Gosub TRACE_MAJ_CHAMP
            [L]WCHAMP="BPAADD"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STS]BPAADD
            Gosub TRACE_MAJ_CHAMP
          Endif
      Endcase
  Endcase
Endif
Return


