    Endif
    If [L]WAMT_RCP<>0
      [L]WCHAMP="MONRCPAMT" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WAMT_RCP
      Gosub TRACE_MAJ_CHAMP
    Endif
    If [L]WQTYACT_RCP<>0
      [L]WCHAMP="YEARCPQTY" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACT_RCP
