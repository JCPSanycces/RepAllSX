      Gosub TRACE_MAJ_CHAMP
    Endif
    If [L]WAMT_ISS<>0
      [L]WCHAMP="YEAISSAMT" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WAMT_ISS
      Gosub TRACE_MAJ_CHAMP
    Endif
    If [L]WCTR_ISS<>0
      [L]WCHAMP="MONISSMVT" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WCTR_ISS
      Gosub TRACE_MAJ_CHAMP
    Endif
    If [L]WCTR_ISS<>0
      [L]WCHAMP="YEAISSMVT" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WCTR_ISS
      Gosub TRACE_MAJ_CHAMP
    Endif
    If find("C",[M:STW]MAJCOD(0..[M:STW]NBLIG-1))
      If [L]WLASDAT_ISS=[F:ITH]LASISSDAT & [F:ITH]LASISSDAT<>[0/0/0]
        [L]WCHAMP="LASISSDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:ITH]LASISSDAT
        Gosub TRACE_MAJ_CHAMP
      Endif
    Endif
  Endif
Elsif [L]WMESSAGE=mess(233,197,1)
