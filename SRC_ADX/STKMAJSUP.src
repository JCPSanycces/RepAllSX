    Gosub TRACE_MAJ_CHAMP

    [L]WCHAMP="DEVSCOCST" : [L]WTYPCHAMP=0
    [L]WVALNUM=[F:SJV]DEVSCOCST
    Gosub TRACE_MAJ_CHAMP
    [L]WCHAMP="DEVOVESCO" : [L]WTYPCHAMP=0
    [L]WVALNUM=[F:SJV]DEVOVESCO
    Gosub TRACE_MAJ_CHAMP

    [L]WCHAMP="DEVINVDTA" : [L]WTYPCHAMP=0
    [L]WVALNUM=[F:SJV]DEVINVDTA
    Gosub TRACE_MAJ_CHAMP

    If GACTVLT2
        Call TRACE_FLD("DEVMATCST2",GACTMAT,2,WABRFIC,WCHAMP, WVALCHR, WMESSAG2)

        [L]WCHAMP="DEVOVEMAT2" : [L]WTYPCHAMP=0
        [L]WVALNUM=[F:SJV]DEVOVEMAT2
        Gosub TRACE_MAJ_CHAMP

        Call TRACE_FLD("DEVMACCST2",GACTMAC,2,WABRFIC,WCHAMP, WVALCHR, WMESSAG2)

        [L]WCHAMP="DEVOVEMAC2" : [L]WTYPCHAMP=0
        [L]WVALNUM=[F:SJV]DEVOVEMAC2
        Gosub TRACE_MAJ_CHAMP

        Call TRACE_FLD("DEVLABCST2",GACTLAB,2,WABRFIC,WCHAMP, WVALCHR, WMESSAG2)

        [L]WCHAMP="DEVOVELAB2" : [L]WTYPCHAMP=0
        [L]WVALNUM=[F:SJV]DEVOVELAB2
        Gosub TRACE_MAJ_CHAMP

        [L]WCHAMP="DEVSCOCST2" : [L]WTYPCHAMP=0
        [L]WVALNUM=[F:SJV]DEVSCOCST2
        Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="DEVOVESCO2" : [L]WTYPCHAMP=0
        [L]WVALNUM=[F:SJV]DEVOVESCO2
        Gosub TRACE_MAJ_CHAMP

        [L]WCHAMP="DEVINVDTA2" : [L]WTYPCHAMP=0
        [L]WVALNUM=[F:SJV]DEVINVDTA2
        Gosub TRACE_MAJ_CHAMP
    Endif
Return

# Trace d'un champ dimensionné
# 3 indices par ligne (variable LNBIND)
Subprog TRACE_FLD(PFLD,PNB,WTYPCHAMP,WABRFIC,WCHAMP,WVALCHR,WMESSAG2)
Value Char PFLD
Value Integer PNB
Value Integer WTYPCHAMP
Value Char WABRFIC
Value Char WCHAMP
Value Char WVALCHR
Value Char WMESSAG2

Local Integer LNBIND : LNBIND=3
Local Integer I, J

For I=0 To int((PNB+LNBIND-1)/LNBIND)-1
    [L]WCHAMP=PFLD+"("+num$(I*LNBIND)+".."
    Raz WVALCHR
    For J=0 To LNBIND-1
        If I*LNBIND+J>=PNB
            Break
        Endif
        [L]WVALCHR+=num$(evalue(WABRFIC+PFLD+"(I*LNBIND+J)"))+"; "
    Next
    [L]WCHAMP+=num$(I*LNBIND+J-1)+")"
    Gosub TRACE_MAJ_CHAMP
Next
End

