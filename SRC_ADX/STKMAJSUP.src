  [L]WCHAMP="QTYPCU"   : [L]WTYPCHAMP=1: [L]WVALNUM=[F:STJ1]QTYPCU  : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="QTYSTU"   : [L]WTYPCHAMP=1: [L]WVALNUM=[F:STJ1]QTYSTU  : Gosub TRACE_MAJ_CHAMP
