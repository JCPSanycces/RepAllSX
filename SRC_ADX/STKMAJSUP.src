#-----------------------------------------#
# Trace de la table des lots STOLOT [STL] #
#-----------------------------------------#
$TRACE_DETAIL_STL
[L]WABRFIC="[F:STL]"
Case [L]WCODFONC
  When 1
    [L]WCHAMP="REFPER" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STL]REFPER
    Gosub TRACE_MAJ_CHAMP
    [L]WCHAMP="SHL"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STL]SHL
    Gosub TRACE_MAJ_CHAMP
    If [F:STL]USRFLD1<>""
      [L]WCHAMP="USRFLD1": [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STL]USRFLD1
      Gosub TRACE_MAJ_CHAMP
    Endif
    If [F:STL]USRFLD2<>""
      [L]WCHAMP="USRFLD2": [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STL]USRFLD2
      Gosub TRACE_MAJ_CHAMP
    Endif
    If [F:STL]USRFLD3<>0
      [L]WCHAMP="USRFLD3": [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STL]USRFLD3
      Gosub TRACE_MAJ_CHAMP
    Endif
    If [F:STL]USRFLD4<>[0/0/0]
      [L]WCHAMP="USRFLD4": [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STL]USRFLD4
      Gosub TRACE_MAJ_CHAMP
    Endif
  When 2
  When 3
Endcase
Return

#--------------------------------------------------#
# Trace de la table des lots/sites STOLOTFCY [SLF] #
#--------------------------------------------------#
$TRACE_DETAIL_SLF
[L]WABRFIC="[F:SLF]"
Case [L]WCODFONC
  When 1
    Case left$([M:STW]STA(I),1)
      When "A" : [L]WCHAMP="AAACUMQTY"
      When "Q" : [L]WCHAMP="QQQCUMQTY"
      When "R" : [L]WCHAMP="RRRCUMQTY"
    Endcase
    [L]WTYPCHAMP=1 : [L]WVALNUM=[M:STW]QTYSTU(I)*[L]SIGN
    Gosub TRACE_MAJ_CHAMP
    If find([M:STW]TRSTYP,1,3,5)
      If [L]SENS=1 & [M:STW]MAJCOD(I)<>"A" & [F:SLF]LASRCPDAT=[M:STW]IPTDAT
        [L]WCHAMP="LASRCPDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:SLF]LASRCPDAT
        Gosub TRACE_MAJ_CHAMP
      Endif
    Elsif find([M:STW]TRSTYP,13)
      If [L]SENS=1 & [M:STW]MAJCOD(I)<>"A" & [F:SLF]LASCUNDAT=[M:STW]IPTDAT
        [L]WCHAMP="LASCUNDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:SLF]LASCUNDAT
        Gosub TRACE_MAJ_CHAMP
      Endif
    Endif
    [L]WCHAMP="AVCBASAMT" : [L]WTYPCHAMP=1
    [L]WVALNUM=arr([M:SVW]AMTORD(I),WRND_RPT)
    Gosub TRACE_MAJ_CHAMP
    [L]WCHAMP="AVC" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:SLF]AVC
    Gosub TRACE_MAJ_CHAMP
  When 2
    Case left$([M:STW]STA(I),1)
      When "A" : [L]WCHAMP="AAACUMQTY"
      When "Q" : [L]WCHAMP="QQQCUMQTY"
      When "R" : [L]WCHAMP="RRRCUMQTY"
    Endcase
    [L]WTYPCHAMP=1 : [L]WVALNUM=[M:STW]QTYSTU(I)*[L]SIGN
    Gosub TRACE_MAJ_CHAMP
    If find([M:STW]TRSTYP,2,4,6,24,29)
      If [L]SENS=1 & [M:STW]MAJCOD(I)<>"A" & [F:SLF]LASISSDAT=[M:STW]IPTDAT
        [L]WCHAMP="LASISSDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:SLF]LASISSDAT
        Gosub TRACE_MAJ_CHAMP
      Endif
    Elsif find([M:STW]TRSTYP,13)
      If [L]SENS=1 & [M:STW]MAJCOD(I)<>"A" & [F:SLF]LASCUNDAT=[M:STW]IPTDAT
        [L]WCHAMP="LASCUNDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:SLF]LASCUNDAT
        Gosub TRACE_MAJ_CHAMP
      Endif
    Endif
    [L]WCHAMP="AVCBASAMT" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:SLF]AVCBASAMT
    Gosub TRACE_MAJ_CHAMP
    [L]WCHAMP="AVC" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:SLF]AVC
    Gosub TRACE_MAJ_CHAMP
  When 3
    Case [L]WFLUX
      When 0
        If [L]WLOT_ISS<>[L]WLOT_RCP | [L]WSLO_ISS<>[L]WSLO_RCP
          [L]WSNS=[L]SIGN
          If [M:STW]MAJCOD(I)<>"A"
            Gosub DETAIL_SLF_RCP
          Else
            Gosub DETAIL_SLF_ISS
          Endif
        Else
          If [M:STW]MAJCOD(I)<>"A" [L]WSNS=-[L]SIGN Else [L]WSNS=[L]SIGN : Endif
          Gosub DETAIL_SLF_ISSRCP
        Endif
      When 1 : [L]WSNS=-[L]SIGN : Gosub DETAIL_SLF_ISS
      When 2 : [L]WSNS=-[L]SIGN : Gosub DETAIL_SLF_RCP
    Endcase
Endcase
Return

#-----------------------------------------------#
# Détail lot pour changement emplacement sortie #
#-----------------------------------------------#
$DETAIL_SLF_ISS
Case left$([L]WSTA_ISS,1)
  When "A" : [L]WCHAMP="AAACUMQTY"
  When "Q" : [L]WCHAMP="QQQCUMQTY"
  When "R" : [L]WCHAMP="RRRCUMQTY"
Endcase
[L]WTYPCHAMP=1 : [L]WVALNUM=[M:STW]QTYSTU(I)*[L]WSNS
Gosub TRACE_MAJ_CHAMP
If [L]WLOT_ISS="" & [L]WLOT_ISS<>[L]WLOT_RCP
  If [M:STW]MAJCOD(I)<>"A" & [L]SENS=1 & [L]WLASDAT_ISS=[M:STW]IPTDAT
    [L]WCHAMP="LASISSDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:SLF]LASISSDAT
    Gosub TRACE_MAJ_CHAMP
  Endif
Endif
If [L]WLOT_ISS<>[L]WLOT_RCP | [L]WSLO_ISS<>[L]WSLO_RCP
  [L]WCHAMP="AVCBASAMT" : [L]WTYPCHAMP=1
  If [M:STW]MAJCOD(I)<>"A"
    [L]WVALNUM=arr([F:SLF]AVC*[M:STW]QTYSTU(I)*[L]WSNS,WRND_RPT)
  Else
    [L]WVALNUM=arr([M:SVW]AMTORD(I)*[M:STW]QTYSTU(I)*[L]WSNS,WRND_RPT)
  Endif
  Gosub TRACE_MAJ_CHAMP
Endif
Return

#-----------------------------------------------#
# Détail lot pour changement emplacement entrée #
#-----------------------------------------------#
$DETAIL_SLF_RCP
Case left$([L]WSTA_RCP,1)
  When "A" : [L]WCHAMP="AAACUMQTY"
  When "Q" : [L]WCHAMP="QQQCUMQTY"
  When "R" : [L]WCHAMP="RRRCUMQTY"
Endcase
[L]WTYPCHAMP=1 : [L]WVALNUM=[M:STW]QTYSTU(I)*[L]WSNS
Gosub TRACE_MAJ_CHAMP
If [L]WLOT_ISS="" & [L]WLOT_ISS<>[L]WLOT_RCP
  If [M:STW]MAJCOD(I)<>"A" & [L]SENS=1 & [L]WLASDAT_RCP=[M:STW]IPTDAT
    [L]WCHAMP="LASRCPDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:SLF]LASRCPDAT
    Gosub TRACE_MAJ_CHAMP
  Endif
Endif
If [L]WLOT_ISS<>[L]WLOT_RCP | [L]WSLO_ISS<>[L]WSLO_RCP
  [L]WCHAMP="AVCBASAMT" : [L]WTYPCHAMP=1
  If [M:STW]MAJCOD(I)<>"A"
    [L]WVALNUM=arr([M:SVW]AMTORD(I)*[M:STW]QTYSTU(I)*[L]WSNS,WRND_RPT)
  Else
    [L]WVALNUM=arr([F:SLF]AVC*[M:STW]QTYSTU(I)*[L]WSNS,WRND_RPT)
  Endif
  Gosub TRACE_MAJ_CHAMP
Endif
Return

#------------------------------------------------------#
# Détail lot pour changement emplacement sortie+entrée #
#------------------------------------------------------#
$DETAIL_SLF_ISSRCP
Case left$([L]WSTA_ISS,1)
  When "A" : [L]WCHAMP="AAACUMQTY"
  When "Q" : [L]WCHAMP="QQQCUMQTY"
  When "R" : [L]WCHAMP="RRRCUMQTY"
Endcase
[L]WTYPCHAMP=1 : [L]WVALNUM=[M:STW]QTYSTU(I)*[L]WSNS
Gosub TRACE_MAJ_CHAMP
Case left$([L]WSTA_RCP,1)
  When "A" : [L]WCHAMP="AAACUMQTY"
  When "Q" : [L]WCHAMP="QQQCUMQTY"
  When "R" : [L]WCHAMP="RRRCUMQTY"
Endcase
[L]WTYPCHAMP=1 : [L]WVALNUM=-[M:STW]QTYSTU(I)*[L]WSNS
Gosub TRACE_MAJ_CHAMP
Return


#--------------------------------------------------------#
# Trace de la table des cumuls article-site ITMMVT [ITV] #
#--------------------------------------------------------#
$TRACE_DETAIL_ITV
[L]WABRFIC="[F:ITV]"
If [M:STW]TRSTYP=14 | ([M:STW]TRFFCY<>"" & [M:STW]TRFFCY<>[M:STW]STOFCY)
  If [F:ITV]STOFCY<>[L]WFCY
    Gosub ITV_INTER_SITE : Return
  Endif
Endif
If [L]WQTYACTINT_A<>0
  [L]WCHAMP="PHYSTO"    : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACTINT_A
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WQTYACTINT_Q<>0
  [L]WCHAMP="CTLSTO"    : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACTINT_Q
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WQTYACTINT_R<>0
  [L]WCHAMP="REJSTO"    : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACTINT_R
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WQTYACTPLF_A<>0
  [L]WCHAMP="PLFPHYSTO" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACTPLF_A
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WQTYACTPLF_Q<>0
  [L]WCHAMP="PLFCTLSTO" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACTPLF_Q
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WQTYACTPLF_R<>0
  [L]WCHAMP="PLFREJSTO" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACTPLF_R
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WQTYACTBPR_A<>0
  [L]WCHAMP="BPRPHYSTO" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACTBPR_A
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WQTYACTBPR_Q<>0
  [L]WCHAMP="BPRCTLSTO" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACTBPR_Q
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WQTYACTBPR_R<>0
  [L]WCHAMP="BPRREJSTO" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACTBPR_R
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WQTYACTSCO_A<>0
  [L]WCHAMP="SCOPHYSTO" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACTSCO_A
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WQTYACTSCO_Q<>0
  [L]WCHAMP="SCOCTLSTO" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACTSCO_Q
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WQTYACTSCO_R<>0
  [L]WCHAMP="SCOREJSTO" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACTSCO_R
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WQTYACTSCC<>0
  [L]WCHAMP="SCCLNDSTO" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACTSCC
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WPHYALL<>0
  [L]WCHAMP="PHYALL"    : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WPHYALL
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WCTLALL<>0
  [L]WCHAMP="CTLALL"    : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WCTLALL
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WREJALL<>0
  [L]WCHAMP="REJALL"    : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WREJALL
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WSCOPHYALL<>0
  [L]WCHAMP="SCOPHYALL" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WSCOPHYALL
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WSCOCTLALL<>0
  [L]WCHAMP="SCOCTLALL" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WSCOCTLALL
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WSCOREJALL<>0
  [L]WCHAMP="SCOREJALL" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WSCOREJALL
  Gosub TRACE_MAJ_CHAMP
Endif

If ([L]WAMTORD_RCP+[L]WAMTORD_ISS)-([L]WAMT_RCP+[L]WAMT_ISS)<>0
  [L]WCHAMP="AMTDEV" : [L]WTYPCHAMP=1
  [L]WVALNUM=([L]WAMTORD_RCP+[L]WAMTORD_ISS)-([L]WAMT_RCP+[L]WAMT_ISS)
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WQTYACT_RCP<>0 | [L]WAMT_RCP<>0 | [L]WCTR_RCP<>0
  If [L]WPMP=0
    [L]WCHAMP="AVCBASQTY" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACT_RCP
    Gosub TRACE_MAJ_CHAMP
    [L]WCHAMP="AVCBASAMT" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WAMTORD_RCP
    Gosub TRACE_MAJ_CHAMP
    If [F:ITV]AVCBASQTY>0
      [L]WCHAMP="AVC" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:ITV]AVC
      Gosub TRACE_MAJ_CHAMP
    Endif
    If GACTDECCST=1
      [L]WCHAMP="AMATCST(0)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]AMATCST(0): Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="AMATCST(1)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]AMATCST(1): Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="AMATCST(2)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]AMATCST(2): Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="AMATCST(3)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]AMATCST(3): Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="AMATCST(4)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]AMATCST(4): Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="AMATCST(5)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]AMATCST(5): Gosub TRACE_MAJ_CHAMP

      [L]WCHAMP="AOVEMATCST": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]AOVEMATCST: Gosub TRACE_MAJ_CHAMP

      [L]WCHAMP="AMACCST(0)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]AMACCST(0): Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="AMACCST(1)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]AMACCST(1): Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="AMACCST(2)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]AMACCST(2): Gosub TRACE_MAJ_CHAMP

      [L]WCHAMP="AOVEMACCST": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]AOVEMACCST: Gosub TRACE_MAJ_CHAMP

      [L]WCHAMP="ALABCST(0)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]ALABCST(0): Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="ALABCST(1)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]ALABCST(1): Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="ALABCST(2)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]ALABCST(2): Gosub TRACE_MAJ_CHAMP

      [L]WCHAMP="AOVELABCST": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]AOVELABCST: Gosub TRACE_MAJ_CHAMP

      [L]WCHAMP="ASCOCST"   : [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]ASCOCST   : Gosub TRACE_MAJ_CHAMP

      [L]WCHAMP="AOVESCOCST": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]AOVESCOCST: Gosub TRACE_MAJ_CHAMP

      [L]WCHAMP="AINVDTACST": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]AINVDTACST: Gosub TRACE_MAJ_CHAMP
    Endif
  Endif
  If [L]WCTR_RCP<>0
    [L]WCHAMP="CUNRCPMVT" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WCTR_RCP
    Gosub TRACE_MAJ_CHAMP
  Endif
  If find("C",[M:STW]MAJCOD(0..[M:STW]NBLIG-1))
    If [M:STW]TRSTYP=3 & [M:STW]PRIPUR<>0
      If [M:STW]IPTDAT=[F:ITV]LASPURDAT
        [L]WCHAMP="LASPURDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:ITV]LASPURDAT
        Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="LASPURPRI" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:ITV]LASPURPRI
        Gosub TRACE_MAJ_CHAMP
      Endif
    Endif
    If [L]WLASDAT_RCP=[F:ITV]LASRCPDAT & [F:ITV]LASRCPDAT<>[0/0/0]
      [L]WCHAMP="LASRCPDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:ITV]LASRCPDAT
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="LASRCPPRI" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:ITV]LASRCPPRI
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="VCRTYP"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:ITV]VCRTYP
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="VCRNUM"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:ITV]VCRNUM
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="VCRLIN"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:ITV]VCRLIN
      Gosub TRACE_MAJ_CHAMP
      If GACTDECCST=1
        [L]WCHAMP="LMATCST(0)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LMATCST(0): Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="LMATCST(1)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LMATCST(1): Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="LMATCST(2)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LMATCST(2): Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="LMATCST(3)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LMATCST(3): Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="LMATCST(4)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LMATCST(4): Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="LMATCST(5)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LMATCST(5): Gosub TRACE_MAJ_CHAMP

        [L]WCHAMP="LOVEMATCST": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LOVEMATCST: Gosub TRACE_MAJ_CHAMP

        [L]WCHAMP="LMACCST(0)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LMACCST(0): Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="LMACCST(1)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LMACCST(1): Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="LMACCST(2)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LMACCST(2): Gosub TRACE_MAJ_CHAMP

        [L]WCHAMP="LOVEMACCST": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LOVEMACCST: Gosub TRACE_MAJ_CHAMP

        [L]WCHAMP="LLABCST(0)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LLABCST(0): Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="LLABCST(1)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LLABCST(1): Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="LLABCST(2)": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LLABCST(2): Gosub TRACE_MAJ_CHAMP

        [L]WCHAMP="LOVELABCST": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LOVELABCST: Gosub TRACE_MAJ_CHAMP

        [L]WCHAMP="LSCOCST"   : [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LSCOCST   : Gosub TRACE_MAJ_CHAMP

        [L]WCHAMP="LOVESCOCST": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LOVESCOCST: Gosub TRACE_MAJ_CHAMP

        [L]WCHAMP="LINVDTACST": [L]WTYPCHAMP=0: [L]WVALNUM=[F:ITV]LINVDTACST: Gosub TRACE_MAJ_CHAMP
      Endif
    Endif
  Endif
Endif
If [L]WQTYWAI_ISS<>0 | [L]WQTYWAI_RCP<>0
  [L]WCHAMP="WAISTO" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYWAI_ISS+[L]WQTYWAI_RCP
  Gosub TRACE_MAJ_CHAMP
Endif
If [L]WQTYACT_ISS<>0 | [L]WAMT_ISS<>0 | [L]WCTR_ISS<>0
  If [L]WPMP=0
    [L]WCHAMP="AVCBASQTY" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACT_ISS
    Gosub TRACE_MAJ_CHAMP
    [L]WCHAMP="AVCBASAMT" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WAMTORD_ISS
    Gosub TRACE_MAJ_CHAMP
    If [F:ITV]AVCBASQTY>0
      [L]WCHAMP="AVC" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:ITV]AVC
      Gosub TRACE_MAJ_CHAMP
    Endif
  Endif
  If [L]WCTR_ISS<>0
    [L]WCHAMP="CUNISSMVT" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WCTR_ISS
    Gosub TRACE_MAJ_CHAMP
  Endif
  If find("C",[M:STW]MAJCOD(0..[M:STW]NBLIG-1))
    If [L]WLASDAT_ISS=[F:ITV]LASISSDAT
      [L]WCHAMP="LASISSDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:ITV]LASISSDAT
      Gosub TRACE_MAJ_CHAMP
    Endif
  Endif
Endif
If [L]WQTYACT_TRF<>0
