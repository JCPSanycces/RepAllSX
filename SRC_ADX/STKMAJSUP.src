      Endif
      If [L]WLASDAT_RCP=[F:ITH]LASRCPDAT & [F:ITH]LASRCPDAT<>[0/0/0]
        [L]WCHAMP="LASRCPDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:ITH]LASRCPDAT
        Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="LASRCPPRI" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:ITH]LASRCPPRI
        Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="VCRTYP"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:ITH]VCRTYP
        Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="VCRNUM"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:ITH]VCRNUM
        Gosub TRACE_MAJ_CHAMP
        [L]WCHAMP="VCRLIN"    : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:ITH]VCRLIN
        Gosub TRACE_MAJ_CHAMP
      Endif
    Endif
  Endif
  If [L]WQTYACT_ISS<>0 | [L]WAMT_ISS<>0 | [L]WCTR_ISS<>0
    If [L]WQTYACT_ISS<>0
      [L]WCHAMP="MONISSQTY" : [L]WTYPCHAMP=1 : [L]WVALNUM=[L]WQTYACT_ISS
      Gosub TRACE_MAJ_CHAMP
    Endif
    If [L]WAMT_ISS<>0
