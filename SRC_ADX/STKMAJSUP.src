  [L]WCHAMP="AMTVAL"   : [L]WTYPCHAMP=1: [L]WVALNUM=[F:STJ1]AMTVAL  : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="VARORD"   : [L]WTYPCHAMP=1: [L]WVALNUM=[F:STJ1]VARORD  : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="VARVAL"   : [L]WTYPCHAMP=1: [L]WVALNUM=[F:STJ1]VARVAL  : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="ACTQTY"   : [L]WTYPCHAMP=1: [L]WVALNUM=[F:STJ1]ACTQTY  : Gosub TRACE_MAJ_CHAMP
Endif
Return


#---------------------------------------------------#
# Trace de la table des lignes de stock STOCK [STO] #
#---------------------------------------------------#
$TRACE_DETAIL_STO
[L]WABRFIC="[F:STO]"
If [L]WMESSAGE=mess(232,197,1)
  If [L]WPCURUL<>0
    If [L]WQTEACT=[L]WQTYSTUACT
      [L]WCHAMP="QTYPCU"    : [L]WTYPCHAMP=1 : [L]WVALNUM=+[L]WQTYPCU
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="QTYSTU"    : [L]WTYPCHAMP=1 : [L]WVALNUM=+[L]WQTYSTU
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="QTYSTUACT" : [L]WTYPCHAMP=1 : [L]WVALNUM=+[L]WQTYSTUACT
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="CUMALLQTY" : [L]WTYPCHAMP=1 : [L]WVALNUM=+[L]WALLQTY
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="CUMALLQTA" : [L]WTYPCHAMP=1 : [L]WVALNUM=+[L]WALLQTA
      Gosub TRACE_MAJ_CHAMP
    Else
      [L]WCHAMP="QTYPCU"    : [L]WTYPCHAMP=1 : [L]WVALNUM=-[L]WQTYPCU
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="QTYSTU"    : [L]WTYPCHAMP=1 : [L]WVALNUM=-[L]WQTYSTU
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="QTYSTUACT" : [L]WTYPCHAMP=1 : [L]WVALNUM=-[L]WQTYSTUACT
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="CUMALLQTY" : [L]WTYPCHAMP=1 : [L]WVALNUM=-[L]WALLQTY
      Gosub TRACE_MAJ_CHAMP
      [L]WCHAMP="CUMALLQTA" : [L]WTYPCHAMP=1 : [L]WVALNUM=-[L]WALLQTA
      Gosub TRACE_MAJ_CHAMP
    Endif
  Elsif [L]WRECOND=1
    [L]WCHAMP="QTYPCU"      : [L]WTYPCHAMP=1 : [L]WVALNUM=-[L]WQTE1
    Gosub TRACE_MAJ_CHAMP
    [L]WCHAMP="QTYSTU"      : [L]WTYPCHAMP=1 : [L]WVALNUM=-[L]WQTE2
    Gosub TRACE_MAJ_CHAMP
    [L]WCHAMP="QTYSTUACT"   : [L]WTYPCHAMP=1 : [L]WVALNUM=-[L]WQTEACT
    Gosub TRACE_MAJ_CHAMP
  Else
    [L]WCHAMP="QTYPCU"    : [L]WTYPCHAMP=1
    [L]WVALNUM=[M:STW]QTYPCU(I)*[M:STW]PCUSTUCOE(I)/[F:STO]PCUSTUCOE*[L]SIGN
    Gosub TRACE_MAJ_CHAMP
    [L]WCHAMP="QTYSTU"    : [L]WTYPCHAMP=1
    [L]WVALNUM=[M:STW]QTYSTU(I)*[L]SIGN
    Gosub TRACE_MAJ_CHAMP
    [L]WCHAMP="QTYSTUACT" : [L]WTYPCHAMP=1
    [L]WVALNUM=[M:STW]QTYSTUACT(I)*[L]SIGN
    Gosub TRACE_MAJ_CHAMP
    If [L]WCODFONC=3
      If [L]WDIFALLQTY<>0
        [L]WCHAMP="CUMALLQTY" : [L]WTYPCHAMP=1
        Case [L]WFLUX
          When 1
            If [M:STW]MAJCOD(I)="A"
              [L]WVALNUM=-[L]WDIFALLQTY
            Else
              [L]WVALNUM= [L]WDIFALLQTY
            Endif
          When 2
            If [M:STW]MAJCOD(I)="A"
              [L]WVALNUM= [L]WDIFALLQTY
            Else
              [L]WVALNUM=-[L]WDIFALLQTY
            Endif
        Endcase
        Gosub TRACE_MAJ_CHAMP
      Endif
      If [L]WDIFALLQTA<>0
        [L]WCHAMP="CUMALLQTA" : [L]WTYPCHAMP=1
        Case [L]WFLUX
          When 1
            If [M:STW]MAJCOD(I)="A"
              [L]WVALNUM=-[L]WDIFALLQTA
            Else
              [L]WVALNUM= [L]WDIFALLQTA
            Endif
          When 2
            If [M:STW]MAJCOD(I)="A"
              [L]WVALNUM= [L]WDIFALLQTA
            Else
              [L]WVALNUM=-[L]WDIFALLQTA
            Endif
        Endcase
        Gosub TRACE_MAJ_CHAMP
      Endif
    Endif
    If find([M:STW]TRSTYP,1,3,5)
      If [L]SENS=1 & [M:STW]MAJCOD(I)<>"A" & [F:STO]LASRCPDAT=[M:STW]IPTDAT
        [L]WCHAMP="LASRCPDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STO]LASRCPDAT
        Gosub TRACE_MAJ_CHAMP
      Endif
    Elsif find([M:STW]TRSTYP,2,4,6,24,29)
      If [L]SENS=1 & [M:STW]MAJCOD(I)<>"A" & [F:STO]LASISSDAT=[M:STW]IPTDAT
        [L]WCHAMP="LASISSDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STO]LASISSDAT
        Gosub TRACE_MAJ_CHAMP
      Endif
    Elsif find([M:STW]TRSTYP,13)
      [L]WCHAMP="CUNLOKFLG" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STO]CUNLOKFLG
      Gosub TRACE_MAJ_CHAMP
      If [L]SENS=1 & [M:STW]MAJCOD(I)<>"A" & [F:STO]LASCUNDAT=[M:STW]IPTDAT
        [L]WCHAMP="LASCUNDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STO]LASCUNDAT
        Gosub TRACE_MAJ_CHAMP
      Endif
    Elsif [L]WCODFONC=3
      If [M:STW]STOFCY<>[M:STW]TRFFCY | ([M:STW]LOCCAT(I)>2 & [M:STW]LOCDESCAT(I)<3)
        If [L]WFLUX=1
          If [F:STO]LASRCPDAT=[M:STW]IPTDAT
            [L]WCHAMP="LASRCPDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STO]LASRCPDAT
            Gosub TRACE_MAJ_CHAMP
          Endif
        Else
          If [F:STO]LASISSDAT=[M:STW]IPTDAT
            [L]WCHAMP="LASISSDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STO]LASISSDAT
            Gosub TRACE_MAJ_CHAMP
          Endif
        Endif
      Endif
    Endif
  Endif
Elsif [L]WMESSAGE=mess(233,197,1)
  [L]WCHAMP="STOFCY"   : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STO]STOFCY   : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="STOCOU"   : [L]WTYPCHAMP=0: [L]WVALNUM=[F:STO]STOCOU   : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="ITMREF"   : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STO]ITMREF   : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="LOT"      : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STO]LOT      : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="SLO"      : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STO]SLO      : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="BPSLOT"   : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STO]BPSLOT   : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="STA"      : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STO]STA      : Gosub TRACE_MAJ_CHAMP
  If GWRHACT=2 & [F:STO]WRH<>""
    [L]WCHAMP="WRH"    : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STO]WRH      : Gosub TRACE_MAJ_CHAMP
  Endif
  [L]WCHAMP="LOC"      : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STO]LOC      : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="LOCTYP"   : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STO]LOCTYP   : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="LOCCAT"   : [L]WTYPCHAMP=0: [L]WVALNUM=[F:STO]LOCCAT   : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="SERNUM"   : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STO]SERNUM   : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="PALNUM"   : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STO]PALNUM   : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="CTRNUM"   : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STO]CTRNUM   : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="LPNNUM"   : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STO]LPNNUM   : Gosub TRACE_MAJ_CHAMP : # Issue X3-53322
  [L]WCHAMP="PCU"      : [L]WTYPCHAMP=2: [L]WVALCHR=[F:STO]PCU      : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="PCUSTUCOE": [L]WTYPCHAMP=0: [L]WVALNUM=[F:STO]PCUSTUCOE: Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="QTYPCU"   : [L]WTYPCHAMP=0: [L]WVALNUM=[F:STO]QTYPCU   : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="QTYSTU"   : [L]WTYPCHAMP=0: [L]WVALNUM=[F:STO]QTYSTU   : Gosub TRACE_MAJ_CHAMP
  [L]WCHAMP="QTYSTUACT": [L]WTYPCHAMP=0: [L]WVALNUM=[F:STO]QTYSTUACT: Gosub TRACE_MAJ_CHAMP
  If [L]WPCURUL<>0
    [L]WCHAMP="PCUORI"    : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STO]PCUORI
    Gosub TRACE_MAJ_CHAMP
    [L]WCHAMP="QTYPCUORI" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STO]QTYPCUORI
    Gosub TRACE_MAJ_CHAMP
    [L]WCHAMP="QTYSTUORI" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STO]QTYSTUORI
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STO]QLYCTLDEM<>""
    [L]WCHAMP="QLYCTLDEM" : [L]WTYPCHAMP=2 : [L]WVALCHR=[F:STO]QLYCTLDEM
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STO]CUMALLQTY<>0
    [L]WCHAMP="CUMALLQTY" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STO]CUMALLQTY
    Gosub TRACE_MAJ_CHAMP
  Endif
  If [F:STO]CUMALLQTA<>0
    [L]WCHAMP="CUMALLQTA" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STO]CUMALLQTA
    Gosub TRACE_MAJ_CHAMP
  Endif
  If find([M:STW]TRSTYP,13)
    [L]WCHAMP="CUNLOKFLG" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STO]CUNLOKFLG
    Gosub TRACE_MAJ_CHAMP
    [L]WCHAMP="LASCUNDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STO]LASCUNDAT
    Gosub TRACE_MAJ_CHAMP
  Elsif [L]WFLUX=1
    [L]WCHAMP="LASRCPDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STO]LASRCPDAT
    Gosub TRACE_MAJ_CHAMP
  Else
    [L]WCHAMP="LASISSDAT" : [L]WTYPCHAMP=3 : [L]WVALDAT=[F:STO]LASISSDAT
    Gosub TRACE_MAJ_CHAMP
  Endif
Elsif [L]WMESSAGE=mess(551,197,1)
  [L]WCHAMP="QTYSTUACT" : [L]WTYPCHAMP=0 : [L]WVALNUM=[F:STO]QTYSTUACT: Gosub TRACE_MAJ_CHAMP
Endif
Return


