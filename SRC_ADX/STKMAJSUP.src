#-------------------------------------#
#    Trace des mises à jour champ     #
#-------------------------------------#
# WTYPCHAMP : 0 = numérique           #
#             1 = variation numérique #
#             2 = alphanumérique      #
#             3 = date                #
# WABRFIC   : Abréviation du fichier  #
#             sous la forme "[F:xxx]" #
# WCHAMP    : Nom du champ            #
# WVALNUM   : Valeur numérique        #
# WVALCHR   : Valeur alpahanumérique  #
# WVALDAT   : Valeur date             #
#-------------------------------------#
$TRACE_MAJ_CHAMP
[L]WMESSAG2="  "+[L]WABRFIC+[L]WCHAMP-":"
Case [L]WTYPCHAMP
  When 0
    [L]WMESSAG2-="="-num$([L]WVALNUM)
  When 1
    If [L]WVALNUM<0  [L]WMESSAG2-="-"  Else  [L]WMESSAG2-="+" : Endif
    [L]WMESSAG2-=num$(abs([L]WVALNUM))
  When 2
    [L]WMESSAG2-="="-[L]WVALCHR
  When 3
    If [L]WVALDAT<>[0/0/0]
      [L]WMESSAG2-="="-format$(GFMD,[L]WVALDAT)
    Else
      [L]WMESSAG2-="="-"0/0/0"
    Endif
Endcase
If ([L]WCHAMP="PCUORI" & [L]WABRFIC="[F:STO]" & [F:STO]PCUORI<>[L]WPCU_ORI)
  [L]WMESSAG2-="("+[L]WPCU_ORI-"<-- STKMAJ)"
Endif
If ([L]WCHAMP="QTYPCUORI" & [L]WABRFIC="[F:STO]" & [F:STO]QTYPCUORI<>[L]WQTYPCU_ORI)
  [L]WMESSAG2-="("+num$([L]WQTYPCU_ORI)-"<-- STKMAJ)"
Endif
If ([L]WCHAMP="QTYSTUORI" & [L]WABRFIC="[F:STO]" & [F:STO]QTYSTUORI<>[L]WQTYSTU_ORI)
  [L]WMESSAG2-="("+num$([L]WQTYSTU_ORI)-"<-- STKMAJ)"
Endif
Call ECR_TRACE([L]WMESSAG2,0) From GESECRAN
Return

