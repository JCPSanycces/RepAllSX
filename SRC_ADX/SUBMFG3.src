########################################
Subprog D_OPEUOM(VALEUR)
Variable Char    VALEUR()
# utilisé depuis l'écran MFO2
# FQ 74274 GA 10/2011 code déplacé dans une fonction pour réutilisation depuis SUBMFG3 et MFGAUTLIB
Call COMPLETE_OPEUOM([M:MFG1]ROUNUM,[M:MFO2]SCOITMREF,[M:MFO2]BPRNUM,[M:MFO1]SCOLTI
&                    ,VALEUR,[M:MFO2]OPESTRCOE,[M:MFO1]SCOPUU) From MFGLIBO
End

########################################
Subprog C_OPEUOM(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog AM_OPEUOM(VALEUR)
Variable Char    VALEUR()
Local    Decimal WCOEFF
Local    Decimal MCOEFF : MCOEFF = [M:MFO1]OPESTUCOE
Local    Integer WRET
Local    Char WWST (GLONWST)
Local    Char WFCY (GLONFCY)
Local    Decimal WCPL
Local    Decimal WEXT

# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif

# recherche coefficient US/UO
Call RECH_COEFF([M:MFG1]MFGSTU, VALEUR, WCOEFF) From MFGLIB
If WCOEFF <> 0
    [M:MFO1]OPESTUCOE = WCOEFF
Else
    [M:MFO1]OPESTUCOE = 1
    # 42973 mm 09.07
    Call MESSAGE (mess(150,190,1)+"."-mess(231,190,1)) From GESECRAN
    VALEUR = [M:MFG1]MFGSTU
Endif
If WCOEFF <> MCOEFF
    Affzo [M:MFO1]OPESTUCOE
    [M:MFO1]OPEUOM = VALEUR                 # 42973 mm 09.07
    Call UPD_OPE_UNI(10, "MFO1", 0, [M:MFO1]OPESTUCOE) From MFGLIBO

    WWST = [M:MFO1]EXTWST
    WCPL = [M:MFO1]CPLQTY
    WFCY = [M:MFG0]MFGFCY
    WEXT = [M:MFO1]EXTQTY
    # vérification seuil solde automatique atteint
    Call CONT_SOLDE_OPE(WFCY, WWST, WCPL , WEXT, WRET) From MFGLIBO
    If WRET = 1
        Call SOLDE_OPE
        If mkstat
            End
        Endif
    Endif
Endif
# FQ 74274 GA 10/2011 code déplacé dans une fonction pour réutilisation depuis SUBMFG3 et MFGAUTLIB
# récupération coeff US(STR)/UO
Call COMPLETE_OPEUOM([M:MFG1]ROUNUM,[M:MFO2]SCOITMREF,[M:MFO2]BPRNUM,[M:MFO1]SCOLTI
&                   ,VALEUR,[M:MFO2]OPESTRCOE,[M:MFO1]SCOPUU) From MFGLIBO
Affzo [M:MFO1]SCOPUU
Affzo [M:MFO2]
#
If [M:MFO1]ROOTIMCOD = 1
    Call MESSAGE (mess(23,193,1)) From GESECRAN : zonsui="EXTOPETIM"
Elsif [M:MFO1]ROOTIMCOD = 2
    Call MESSAGE (mess(23,193,1)) From GESECRAN : zonsui="CAD"
Endif
OMODIF = 1
#
End

########################################
Subprog AS_OPESTUCOE(VALEUR)
Variable Decimal VALEUR
#
If [F:ITM]ITMREF <> [M:MFG1]ROUNUM
    Read [ITM]ITM0=[M:MFG1]ROUNUM
    If fstat : End : Endif
Endif
If [F:ITM]STU = [M:MFO1]OPEUOM
    VALEUR = 1
    mkstat = 2
Endif
#
End

########################################
Subprog AM_OPESTUCOE(VALEUR)
Variable Decimal VALEUR
Local    Char WWST (GLONWST)
Local    Char WFCY (GLONFCY)
Local    Decimal WCPL
Local    Decimal WEXT
Local    Integer WRET

# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif

# mise à jour quantité opération et temps unitaire
If VALEUR <> 0 : Call UPD_OPE_UNI(10, "MFO1", 0, VALEUR) From MFGLIBO : Endif

WWST = [M:MFO1]EXTWST
WCPL = [M:MFO1]CPLQTY
WFCY = [M:MFG0]MFGFCY
WEXT = [M:MFO1]EXTQTY
# vérification seuil solde automatique atteint
Call CONT_SOLDE_OPE(WFCY, WWST, WCPL , WEXT, WRET) From MFGLIBO
If WRET = 1
    Call SOLDE_OPE
    If mkstat
        End
    Endif
Endif

OMODIF = 1
#
End

