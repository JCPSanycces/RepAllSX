#########################################################################
## Saisie des données jalonnements (écran [MFOS])                      ##
#########################################################################
########################################
Subprog C_NEXOPENUM(VALEUR)
Variable Decimal VALEUR
Local Integer     I
Local Integer     OPEOK
#
If VALEUR <> 0 & VALEUR = [M:MFOS]OPENUM(nolign-1)
   mkstat=2 : GMESSAGE=mess(18,193,1)
Endif
If VALEUR <> 0
   OPEOK=0
   For I=0 To [M:MFOS]NBLIG-1
       If VALEUR=[M:MFOS]OPENUM(I) : OPEOK=1 : Break : Endif
   Next I
   If OPEOK<>1 : mkstat=2 : GMESSAGE=mess(19,193,1) : Endif
Endif
#
End

########################################
Subprog AM_SCDCOD(VALEUR)
Variable Integer VALEUR
#
Case VALEUR
     When 1, 5, 6, 7:
          [M:MFOS]SCDTIM(nolign-1)=0
          [M:MFOS]SCDQTY(nolign-1)=0
          [M:MFOS]SCDLOT(nolign-1)=0
          Affzo [M:MFOS]SCDTIM(nolign-1)
          Affzo [M:MFOS]SCDQTY(nolign-1)
          Affzo [M:MFOS]SCDLOT(nolign-1)
     When 2:
          [M:MFOS]SCDTIM(nolign-1)=0
          [M:MFOS]SCDQTY(nolign-1)=0
          If [F:ITF]ITMREF <> [M:MFG1]ROUNUM
              Read [ITF]ITF0=[M:MFG1]ROUNUM;[M:MFG0]MFGFCY
          Endif
          [M:MFOS]LOTQTY(nolign-1)=[F:ITF]MFGLOTQTY
          Affzo [M:MFOS]SCDTIM(nolign-1)
          Affzo [M:MFOS]SCDQTY(nolign-1)
     When 3:
          [M:MFOS]SCDQTY(nolign-1)=0
          [M:MFOS]SCDLOT(nolign-1)=0
          Affzo [M:MFOS]SCDQTY(nolign-1)
          Affzo [M:MFOS]SCDLOT(nolign-1)
     When 4:
          [M:MFOS]SCDTIM(nolign-1)=0
          [M:MFOS]SCDLOT(nolign-1)=0
          Affzo [M:MFOS]SCDTIM(nolign-1)
          Affzo [M:MFOS]SCDLOT(nolign-1)
     When 8:
          mkstat = 2
          End
Endcase
If OJAL = 0 : OJAL = 1 : Endif
#
End

