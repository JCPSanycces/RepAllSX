##########################################################################
Subprog AM_CTIMCOE(VALEUR)
Variable Decimal VALEUR
Local Decimal    WMFGEXTQTY
Local Integer    L
Local Decimal    WTIMCOE
WTIMCOE = 1
GPE = 0
#---------
# PE permettant de modifier l'application du coef multiplicateur des temps de charge
GPOINT = "ROTCHGTIM"
Gosub  ENTREE From EXEFNC
#---------
If !GPE
    [M:MFO1]EXTSETTIM = [M:MFO1]SETTIMTMP * VALEUR    # tmps réglage
    WTIMCOE =  VALEUR    # coef temps
Endif
WMFGEXTQTY    = [M:MFG1]MFGEXTQTY
Call CAL_ROT_TIME("MFO1", WMFGEXTQTY, L, [M:MFG1]NBLIG, [M:MFG1]LTIREDCOE , WTIMCOE ) From MFGLIBO
Affzo [MFO1]
OMODIF = 1
End

##########################################################################
Subprog AS_HCTIMCOE(VALEUR)
