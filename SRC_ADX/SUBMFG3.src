   [M:MFO1]TIMUOM3 = "" :
   [M:MFO1]X = ""
Endif

# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif

Call UPD_OPE_UNI(17, "MFO1", 0, VALEUR) From MFGLIBO
If [M:MFO0]TIMUOMCOD = 1
    [M:MFO1]TIMUOM2   = mess(30,197,1)
Else
    [M:MFO1]TIMUOM2   = mess(32,197,1)
Endif
Affzo [MFO1]TIMUOM2
OMODIF = 1

Affzo [MFO1]X, TIMUOM3

End

