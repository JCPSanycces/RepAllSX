########################################
Subprog AM_EFF(VALEUR)
Variable Decimal VALEUR
Local    Integer L : L = nolign-1
Local    Integer WRET

# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif

If instr(1,dbgstr(1),"MFO1")
    Call UPD_OPE_UNI(14, "MFO1", 0, [M:MFO1]EFF) From MFGLIBO
    Call UPD_OPE_UNI(6,  "MFO1", 0, VALEUR) From MFGLIBO
    OMODIF = 1
Else
    Call UPD_OPE_UNI(14, "MFG3", L, [M:MFG3]EFF(L)) From MFGLIBO
    Call UPD_OPE_UNI(6,  "MFG3", L, VALEUR) From MFGLIBO
Endif

End

########################################
Subprog AM_SHR(VALEUR)
Variable Decimal VALEUR
Local    Integer L : L = nolign-1
Local    Integer WRET
#Local    Char    WWST,WFCY
Local    Char WWST (GLONWST)
Local    Char WFCY (GLONFCY)
Local    Decimal WCPL
Local    Decimal WEXT
Local    Integer WRET
Local    Integer VS

# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif

If instr(1,dbgstr(1),"MFO1")
    Call UPD_OPE_UNI(15, "MFO1", 0, [M:MFO1]SHR) From MFGLIBO
    Call UPD_OPE_UNI(16, "MFO1", 0, VALEUR) From MFGLIBO
    OMODIF = 1
Else
    Call UPD_OPE_UNI(15, "MFG3", L, [M:MFG3]SHR(L)) From MFGLIBO
    Call UPD_OPE_UNI(16, "MFG3", L, VALEUR) From MFGLIBO
Endif

WFCY = [M:MFG0]MFGFCY
WEXT = [M:MFO1]EXTQTY
WWST = [M:MFO1]EXTWST
WCPL = [M:MFO1]CPLQTY

# vérification seuil solde automatique atteint
Call CONT_SOLDE_OPE(WFCY, WWST, WCPL , WEXT, WRET) From MFGLIBO
If WRET = 1
    VS=1
    Call AVERTIR(mess(24,190,1),VS) From GESECRAN
    If VS = 1 : mkstat = 2 : End : Endif
    If instr(1,dbgstr(1),"MFO1")
        [M:MFO0]OPESTA=5
        Affzo [M:MFO0]XOPESTA
        Diszo [M:MFO0]5
        Diszo [M:MFO1]15
        Diszo [M:MFO1]20
        Diszo [M:MFO1]25
        Diszo [M:MFO1]30
        Diszo [M:MFO1]35
        Diszo [M:MFO1]40
        Diszo [M:MFO2]15
        Diszo [M:MFO2]20
        Diszo [M:MFO2]25
        If dim([M:MFG3]OPENUMLEV(I)) > 0
            Diszo [M:MFO3]15
            Diszo [M:MFO3]20
        Endif
        OSOLDE = 1
    Else
        [M:MFG3]OPESTA(nolign-1)=5
        [M:MFG1]DOPECLENBR += 1
        Affzo [M:MFG3]OPESTA(nolign-1)
    Endif
Endif
End

