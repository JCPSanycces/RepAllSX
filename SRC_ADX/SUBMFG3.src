    Endif
    Affzo [MFO1]TIMUOM8
    OMODIF = 1
Else
    Call UPD_OPE_UNI(4, "MFG3", L, VALEUR) From MFGLIBO
Endif

# Issue X3-28791 - if critical field changed, set REVCOD
# Issue X3-55362 - 2017-09-18 by JUSYN : only if activity code "RVM" set; check for routing version
If dim([M:MFG1]ROUECCMAJ) > 0
    If instr(1,dbgstr(1),"MFG3")
      # Issue X3-55431 - display info message once if critical field changed
      If GOPECRICHG=1 & [M:MFG1]ROUECCMAJ<>"" & VALEUR <> [M:MFG3]EXTUNTTIM(L)
        If GMFGREV=2
          [M:MFG3]REVCOD(L) = 2 # = Modify
        Endif
        If !GREVMESSC # No critical message yet
          GREVMESSC = 1
          GERR = 2
          GMESSAGE = mess(411,193,1)
        Endif
      Endif
      # End issue X3-55431
    Endif
Endif
# End issue X3-55362
# End issue X3-28791

End

