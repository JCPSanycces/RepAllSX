########################################
Subprog S_STDOPENUM(VALEUR)
Variable Decimal VALEUR
Local Char WFCY (GLONFCY)
Filter [F:ROT] Where FCY = [M:MFG0]MFGFCY
Call SELECT("ROT","",[M:MFG0]MFGFCY,"") From SELOBJ
Filter [F:ROT]
If status = 7 : End
Else
    VALEUR=[F:ROT]STDOPENUM
Endif
End

########################################
Subprog B1_EXTLAB(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY (GLONFCY)
WFCY = [M:MFG0]MFGFCY
Call OBJET("MWS",WFCY,VALEUR) From GOBJET
If [F:MWS]WST <> "" & [F:MWS]WCRFCY = [M:MFG0]MFGFCY
    VALEUR = [F:MWS]WST
Endif
End

########################################
Subprog C_SHR(VALEUR)
Variable Decimal VALEUR
If VALEUR < -99 : mkstat = 2 : Endif
End

########################################
Subprog AM_EXTLABNBR(VALEUR)
Variable Decimal VALEUR
Local    Integer L : L = nolign-1
Local    Integer WRET
# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif

If instr(1,dbgstr(1),"MFO1") : OMODIF = 1 : Endif

# Issue X3-28791 - if critical field changed, set REVCOD
# Issue X3-55362 - 2017-09-20 by JUSYN : regarding activity code
If dim([M:MFG1]ROUECCMAJ) > 0
    If instr(1,dbgstr(1),"MFG3")
        # Issue X3-55431 - display info message once if critical field changed
        If GOPECRICHG=1 & [M:MFG1]ROUECCMAJ<>"" & VALEUR <> [M:MFG3]EXTLABNBR(L)
          If GMFGREV=2
            [M:MFG3]REVCOD(L) = 2 # = Modify
          Endif
          If !GREVMESSC # No critical message yet
            GREVMESSC = 1
            GERR = 2
            GMESSAGE = mess(411,193,1)
          Endif
        Endif
        # End issue X3-55431
    Endif
Endif
# End issue X3-55362
# End issue X3-28791

End

########################################
Subprog AM_SCOLTI(VALEUR)
Variable Decimal VALEUR
Local    Decimal WTIME
Local    Decimal WLTI : WLTI = VALEUR

If [F:MWS]WST <> [M:MFO1]EXTWST
    Read [MWS]WST0=[M:MFO1]EXTWST;[M:MFG0]MFGFCY
    If fstat : End : Endif
Endif

# 74351
# transformation délai achat en unité de temps opération
#Call CONV_LTI_TIME([M:MFG0]MFGFCY, WLTI, [M:MFO1]TIMUOMCOD, [F:MWS]TWD, [M:MFO1]OPESTR,
#&                  WTIME) From MFGLIBO
#[M:MFO1]EXTOPETIM   = WTIME
#[M:MFO1]EXTUNTTIM   = [M:MFO1]EXTOPETIM / [M:MFO1]EXTQTY
#[M:MFO1]EXTUNTTIM   = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]EXTUNTTIM)
#Affzo [M:MFO1]EXTOPETIM
#Affzo [M:MFO1]EXTUNTTIM
# sr 07.02 pour activer le bouton Enregistrer demande 15035
OMODIF = 1
End

########################################
Subprog AM_OBJDAT(VALEUR)
Variable Date    VALEUR
[M:MFOS]ELFLG  = VALEUR - [M:MFOS]ENDDAT
If OJAL = 0 : OJAL = 1 : Endif
End

##########################################################################
# 12.03 MM : Multi-emplacement, la notion de tiers remplace celle de fournisseur.
Subprog AM_BPRNUM(VALEUR)
Variable Char    VALEUR()
GBPCNUM= VALEUR
[M:MFO2]BPAADD=""

If [M:MFO2]SCOITMREF <> ""       # FQ 63036 GA 04/2010 recup des infos Article-Fournisseur
    # FQ 74274 GA 10/2011
    Call COMPLETE_OPEUOM([M:MFG1]ROUNUM,[M:MFO2]SCOITMREF,[M:MFO2]BPRNUM,[M:MFO1]SCOLTI
&                       ,[M:MFO1]OPEUOM,[M:MFO2]OPESTRCOE,[M:MFO1]SCOPUU) From MFGLIBO
Endif

# FQ 55167 GA 05/2009
# adresse par défaut du fournisseur (utilisé sur les allocations/manquants)
Call FIND_BPAADD(VALEUR, [M:MFO2]BPAADD) From BPRLIB
Affzo [M:MFO2]BPAADD

#pour activer le bouton Enregistrer
OMODIF = 1
End

##########################################################################
# 12.03 MM : Multi-emplacement,la notion de tiers remplace celle de fournisseur.
