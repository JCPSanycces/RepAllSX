##########################################################################
Subprog AM_HCTIMCOE(VALEUR)
Variable Decimal VALEUR
Local Decimal    WMFGEXTQTY
Local Integer    L
Local Decimal    WTIMCOE
WTIMCOE = 1
GPE = 0

#---------
# PE permettant de modifier l'application du coef multiplicateur des temps hors charge
GPOINT = "ROTCHGOFF"
Gosub  ENTREE From EXEFNC
#---------
If !GPE
    [M:MFO1]PRPTIM = [M:MFO1]PRPTIMTMP * VALEUR    # tmps prep
    [M:MFO1]WAITIM = [M:MFO1]WAITIMTMP * VALEUR    # tmps attente
    [M:MFO1]PSPTIM = [M:MFO1]PSPTIMTMP * VALEUR    # tmps post-ope
Endif
WMFGEXTQTY    = [M:MFG1]MFGEXTQTY
Call CAL_ROT_TIME("MFO1", WMFGEXTQTY, L, [M:MFG1]NBLIG, [M:MFG1]LTIREDCOE, WTIMCOE ) From MFGLIBO
Affzo [MFO1]
OMODIF = 1
End

