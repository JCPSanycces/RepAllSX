#
If VALEUR = 2 & [M:MFO1]WSTTYP <> 3
   GMESSAGE = mess(6,193,1)
   mkstat = 2
Endif
#
End

########################################
Subprog AM_SCOCOD(VALEUR)
Variable Integer VALEUR
# llc 01.01 5979
Case VALEUR
    When 1:
        [M:MFO2]SCOITMREF     = ""
        [M:MFO2]SCOWST        = ""
        [M:MFO2]SCOWCR        = ""
        [M:MFO2]SCOWSTTYP     = 0
        [M:MFO2]SCOWSTDES     = ""
        [M:MFO2]XSCOWSTTYP    = ""
        [M:MFO2]BPRNUM        = ""            # llc 02.01 5977 + 12.03 MM : multi-emplacement
        [M:MFO2]BPAADD        = ""            # 12.03 MM : multi-emplacement
        [M:MFO2]REFPRI        = 0             # llc 02.01 5977
        [M:MFO1]SCOLTI = 0
        [M:MFO1]SCOPUU = ""
        Affzo [M:MFO1]SCOLTI
        Affzo [MFO2]SCOITMREF, SCOWST, SCOWCR, XSCOWSTTYP, SCOWSTDES
    When Default:
Endcase
OMODIF = 1
If VALEUR = 1 : Grizo [M:MFO2]30 : Else : Actzo [M:MFO2]30 : Endif
#
End

