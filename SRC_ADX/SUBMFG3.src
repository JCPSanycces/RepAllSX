Subprog AV_OPESTRDAT(VALEUR)
Variable Date    VALEUR
Local Integer I

If [M:MFOS]OPENUM(nolign-1) <> 0
    If [M:MFOS]FRCSTRDAT(nolign-1) <> [0/0/0]
        pcolor = GCOUL(3)
    Else
        pcolor = GCOUL(0)
    Endif
Endif
End

########################################
Subprog C_FRCSTRHOU(VALEUR)
Variable Char    VALEUR()
Local    Integer L        : L = nolign-1
Local Char VALIDTIME(6)
Local Integer I
Local Integer VALID : VALID = 0
If clalev ([DIH]) = 0 : Local File DIAHOU [DIH] : Endif

GMESSAGE = ""

# X3-42664 - STWIL - Validate forced time is a valid working time
If func AFNC.ACTIV("POPS")
    Call OPETIME ([M:MFG0]MFGFCY, [M:MFG3]EXTWST(L), [M:MFG3]FRCSTRDAT(L), 0, [L]VALIDTIME) From JALLIBB
    # If left blank default to start of shift
    If VALEUR = "0000"
        VALEUR = [L]VALIDTIME
    Else
        # We have got the shift start and end times, check that the entered time is between one of the shifts
        For I = 0 To dim([F:DIH]STRHOU) - 1
            If [F:DIH]STRHOU(I) = ""
                Break
            Endif
            If VALEUR >= [F:DIH]STRHOU(I) & VALEUR <= [F:DIH]ENDHOU(I)
                VALID = 1
                Break
            Endif
        Next I
        If VALID = 0
            GMESSAGE = mess(396,193,1)
            mkstat = 2
            End
        Endif
    Endif
Endif

Call CONT_FRCH_MAN(L, [M:MFG3]FRCSTRDAT(nolign-1),VALEUR) From MFGLIBO
If GMESSAGE <> "" : mkstat = 2 : Endif
End

