# 10.05
Subprog AS_SCOITMREF(VALEUR)
Variable Char    VALEUR()
# article sous-traitance non saisissable si code sous-traitance à Non
If instr(1,dbgstr(1),"MFO2")
    If [M:MFO2]SCOCOD  = 1 : mkstat = 2 : End : Endif
Else
    If [M:MFG3]SCOCOD(nolign-1)  = 1 : mkstat = 2 : End : Endif
Endif
#
End

########################################
Subprog AV_SCOWST(VALEUR)
Variable Char    VALEUR()
Local Char WFCY (GLONFCY)
If instr(1,dbgstr(1),"MFO2")
    WFCY = [M:MFO0]MFGFCY
Else
    WFCY = [M:MFG0]MFGFCY
Endif
# affichage des zones liées au poste de sous-traitance
If VALEUR <> ""
    Read [MWS]WST0=VALEUR;WFCY
    If !fstat
        [M:MFO2]SCOWCR     = [F:MWS]WCR
        [M:MFO2]SCOWSTTYP  = [F:MWS]WSTTYP
        # 03.09 mm - libellé traduisible
        Call LECTEXTRA ([M:MFO2]SCOWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY)From ATEXTRA
        [M:MFO2]XSCOWSTTYP = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
        Affzo [MFO2]SCOWCR, XSCOWSTTYP, SCOWSTDES
    Endif
Endif
#
End

#####################################
Subprog AS_SCOWST(VALEUR)
Variable Char     VALEUR

Local Char WFCY (GLONFCY)
If instr(1,dbgstr(1),"MFO2")
    WFCY = [M:MFO0]MFGFCY
Else
    WFCY = [M:MFG0]MFGFCY
Endif
GBOUT2 = ""
If !find([M:MFG1]WORTYP,3,4) : mkstat=2 : Endif
If VALEUR <>""
    Read [RPW]RPW0 = VALEUR;WFCY
    If fstat              : End : Endif
    If [F:RPW]RPLWST(0) = "" : End : Endif
    GBOUT2=mess(436,198,1)  # bouton  remplacement
Endif
End # FQ 69909 Ctrl des sources End manquant

########################################
Subprog C_SCOWST(VALEUR)
Variable Char    VALEUR()
Local Char WFCY (GLONFCY)
If instr(1,dbgstr(1),"MFO2")
    WFCY = [M:MFO0]MFGFCY
Else
    WFCY = [M:MFG0]MFGFCY
Endif
# contrôle existence et type poste sous-traitance
If VALEUR <> ""
   Read [MWS]WST0=VALEUR;WFCY
   If fstat
      GMESSAGE= VALEUR+"\"+mess(23,100,1) : mkstat=2
   Else
      If [F:MWS]WSTTYP <> 3 : GMESSAGE=VALEUR - mess(3,193,1) : mkstat=2 : End : Endif
      If [F:MWS]WCRFCY <> WFCY
               GMESSAGE = mess(116,193,1) - WFCY
               mkstat = 1
               End
      Endif
   Endif
Endif
#
End

########################################
Subprog AP_SCOWST(VALEUR)
