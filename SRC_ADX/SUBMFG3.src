########################################
Subprog AM_FRCSTRDAT(VALEUR)
Variable Date    VALEUR
Local    Integer WRET, I, WF
Local    Integer OK
Local    Integer L : L = nolign-1

If VALEUR = [0/0/0]
    [M:MFG3]FRCSTRHOU(nolign-1) = ""
    Affzo [M:MFG3]FRCSTRHOU(nolign-1)
Endif

# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif

If VALEUR = [0/0/0] : End : Endif

If [M:MFG3]SCDFLG = 1 : End : Endif    # si OF non jalonné

If VALEUR > [M:MFG3]OPESTR(L) & L > 0
    # opérations précédentes figées ?
    WF = 0
    For I = 0 To L-1
        If [M:MFG3]FRCSTRDAT(I) = [0/0/0] : WF = 1 : Break : Endif
    Next I
    If WF = 0 : End : Endif
    OK=1
    Call OUINON(mess(99,190,1),OK) From GESECRAN
    If OK=2
        For I = 0 To L-1
            If [M:MFG3]FRCSTRDAT(I) = [0/0/0]
                [M:MFG3]FRCSTRDAT(I) = [M:MFG3]OPESTR(I)
            Endif
        Next I
        [M:MFG3]FRCSTRDAT(L) = VALEUR
        Affzo [M:MFG3]10
    Endif
    End
Endif

If VALEUR < [M:MFG3]OPESTR(L) & L < [M:MFG3]NBLIG-1
    # opérations suivantes figées ?
    WF = 0
    For I = L+1 To [M:MFG3]NBLIG-1
        If [M:MFG3]FRCSTRDAT(I) = [0/0/0] : WF = 1 : Break : Endif
    Next I
    If WF = 0 : End : Endif
    OK=1
    Call OUINON(mess(100,190,1),OK) From GESECRAN
    If OK=2
        For I = L+1 To [M:MFG3]NBLIG-1
            If [M:MFG3]FRCSTRDAT(I) = [0/0/0]
                [M:MFG3]FRCSTRDAT(I) = [M:MFG3]OPESTR(I)
            Endif
        Next I
        [M:MFG3]FRCSTRDAT(L) = VALEUR
        Affzo [M:MFG3]10
    Endif
Endif

End

########################################
Subprog AM_FRCSTRHOU(VALEUR)
Variable Char    VALEUR()
Local Integer WRET
# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif

End

########################################
Subprog AV_FRCSTRDAT(VALEUR)
Variable Date    VALEUR

If [M:MFG3]OPENUM(nolign-1) <> 0
    If [M:MFG3]FRCSTRDAT(nolign-1) <> [0/0/0]
        pcolor = GCOUL(3)
    Else
        pcolor = GCOUL(0)
    Endif
Endif
End

########################################
Subprog C_FRCSTRDAT(VALEUR)
Variable Date    VALEUR
Local    Integer L        : L = nolign-1
Local    Date    WDATE, WDATEF
Local    Decimal WCAP (2)
Local    Integer WRET, WCOR

If VALEUR = [0/0/0] : End : Endif
GMESSAGE = ""
Call CONT_FRC_MAN(L, VALEUR) From MFGLIBO
If GMESSAGE <> "" : mkstat = 2 : End : Endif

If clalev([F:FCY]) = 0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:TUV]) = 0  : Local File TABUNAVAIL [TUV]  : Endif
If clalev([F:CPV]) = 0  : Local File CAPVAR     [CPV]  : Endif
If clalev([F:TWD]) = 0  : Local File TABWEEDIA  [TWD]  : Endif

# lecture site
Call LECTURE ("FCY", [M:MFG0]MFGFCY, "") From CONTOBJ

# lecture indisponibilités
Read [F:TUV]UVY0=[F:FCY]UVYCOD
If fstat : Raz [F:TUV] : Endif

# contrôle capacité non nulle sur poste
If [F:MWS]WST <> [M:MFG3]EXTWST(L)
    Read [MWS]WST0=[M:MFG3]EXTWST(L);[M:MFG0]MFGFCY
    If fstat : Raz [F:MWS] : Endif
Endif
WDATE  = VALEUR
WDATEF = WDATE + 1
#  (llc 08.00 v130) nouvelle gestion des capacités
Call LOACAP (WDATE,WDATEF,WCAP,WRET) From JALLIBB

If WCAP(0) > 0 : End : Endif

mkstat = 2
GMESSAGE = mess(119,193,1)

End

