Local Char WFCY (GLONFCY)
If instr(1,dbgstr(1),"MFO2")
    WFCY = [M:MFO0]MFGFCY
Else
    WFCY = [M:MFG0]MFGFCY
Endif
# affichage du centre choisi en retour de la consultation des postes
If VALEUR <> ""
   Read [MWS]WST0=VALEUR;WFCY
   If !fstat
      [M:MFO2]SCOWCR = [F:MWS]WCR
      Affzo [MFO2]SCOWCR
   Endif
Endif
#
End

########################################
Subprog AM_SCOWST(VALEUR)
Variable Char    VALEUR()
Local Char WFCY (GLONFCY)
If instr(1,dbgstr(1),"MFO2")
    WFCY = [M:MFO0]MFGFCY
Else
    WFCY = [M:MFG0]MFGFCY
Endif
If VALEUR <> ""
    Read [MWS]WST0=VALEUR;WFCY
    If !fstat
        [M:MFO2]SCOWCR       = [F:MWS]WCR
        [M:MFO2]SCOWSTTYP    = [F:MWS]WSTTYP
        # 03.09 mm - libellé traduisible
        Call LECTEXTRA ([M:MFO2]SCOWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY)From ATEXTRA
        [M:MFO2]XSCOWSTTYP   =format$("K:2X",mess([F:MWS]WSTTYP,313,1))
        Affzo [MFO2]SCOWCR, XSCOWSTTYP, SCOWSTDES
    Endif
Else
    [M:MFO2]SCOWCR     = ""
    [M:MFO2]SCOWSTTYP  = 0
    [M:MFO2]SCOWSTDES  = ""
    [M:MFO2]XSCOWSTTYP = ""
    Affzo [MFO2]SCOWCR, XSCOWSTTYP, SCOWSTDES
Endif
OMODIF = 1
#
End

########################################
# 10.05
Subprog AM_SCOITMREF(VALEUR)
Variable Char    VALEUR()
Local    Decimal WCOEFF
Local    Decimal WTIME

#
If VALEUR <> ""
    If instr(1,dbgstr(1),"MFO2")
       # FQ 74274 GA 10/2011 code déplacé dans une fonction pour réutilisation depuis SUBMFG3 et MFGAUTLIB
        Call COMPLETE_OPEUOM([M:MFG1]ROUNUM,VALEUR,[M:MFO2]BPRNUM,[M:MFO1]SCOLTI
&                           ,[M:MFO1]OPEUOM,[M:MFO2]OPESTRCOE,[M:MFO1]SCOPUU) From MFGLIBO

        # Issue 85878 - 2012-11-23 by CCC : calcul de EXTSTRCOE avec la valeur de OPESTRCOE
        [M:MFO1]EXTSTRQTY = [M:MFO1]EXTQTY * [M:MFO2]OPESTRCOE

        If [F:MWS]WST <> [M:MFO1]EXTWST
            Read [MWS]WST0=[M:MFO1]EXTWST;[M:MFG0]MFGFCY
            If fstat : End : Endif
        Endif

# 74351
        # transformation délai achat en unité de temps opération
#        Call CONV_LTI_TIME([M:MFG0]MFGFCY, [M:MFO1]SCOLTI, [M:MFO1]TIMUOMCOD, [F:MWS]TWD, [M:MFO1]OPESTR,
#&                                          WTIME) From MFGLIBO
#        [M:MFO1]EXTOPETIM   = WTIME
#        [M:MFO1]EXTUNTTIM   = [M:MFO1]EXTOPETIM / [M:MFO1]EXTQTY
#        [M:MFO1]EXTUNTTIM   = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]EXTUNTTIM)
#        Affzo [M:MFO1]EXTOPETIM
#        Affzo [M:MFO1]EXTUNTTIM
    Else

         # FQ 74274 GA 10/2011
         Call COMPLETE_OPEUOM([M:MFG1]ROUNUM,VALEUR,[M:MFG3]BPRNUM(nolign-1),[M:MFG3]SCOLTI(nolign-1)
&                            ,[M:MFG3]OPEUOM(nolign-1),[M:MFG3]OPESTRCOE(nolign-1),[M:MFG3]SCOPUU(nolign-1)) From MFGLIBO

        # Issue 85878 - 2012-11-23 by CCC : calcul de EXTSTRCOE avec la valeur de OPESTRCOE
        [M:MFG3]EXTSTRQTY(nolign-1) = [M:MFG3]EXTQTY(nolign-1) * [M:MFG3]OPESTRCOE(nolign-1)

        If [F:MWS]WST <> [M:MFG3]EXTWST(nolign-1)
            Read [MWS]WST0=[M:MFG3]EXTWST(nolign-1);[M:MFG0]MFGFCY
            If fstat : End : Endif
        Endif
# 74351
        # transformation délai achat en unité de temps opération
#        Call CONV_LTI_TIME([M:MFG0]MFGFCY, [M:MFG3]SCOLTI(nolign-1), [M:MFG3]TIMUOMCOD(nolign-1), [F:MWS]TWD, [M:MFG3]OPESTR(nolign-1),
#&                                      WTIME) From MFGLIBO
#        [M:MFG3]EXTOPETIM(nolign-1)   = WTIME
#        [M:MFG3]EXTUNTTIM(nolign-1)   = [M:MFG3]EXTOPETIM(nolign-1) / [M:MFG3]EXTQTY(nolign-1)
#        [M:MFG3]EXTUNTTIM(nolign-1)   = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTUNTTIM(nolign-1))
#        Affzo [M:MFG3]EXTOPETIM(nolign-1)
#        Affzo [M:MFG3]EXTUNTTIM(nolign-1)
    Endif
Else
    If instr(1,dbgstr(1),"MFO2")
        [M:MFO1]SCOLTI = 0
        [M:MFO1]SCOPUU = ""
        [M:MFO2]OPESTRCOE = 1
        [M:MFO1]EXTSTRQTY = [M:MFO1]EXTQTY
        Affzo [M:MFO1]SCOLTI
    Else
        [M:MFG3]SCOLTI(nolign-1) = 0
        [M:MFG3]SCOPUU(nolign-1) = ""
        [M:MFG3]OPESTRCOE(nolign-1) = 1
        [M:MFG3]EXTSTRQTY(nolign-1) = [M:MFG3]EXTQTY(nolign-1)
        Affzo [M:MFG3]SCOLTI(nolign-1)
    Endif
Endif
OMODIF = 1

# Issue X3-28791 - if critical field changed, set REVCOD
# Issue X3-55362 - 2017-09-20 by JUSYN : regarding activity code
If dim([M:MFG1]ROUECCMAJ) > 0
    If instr(1,dbgstr(1),"MFG3")
        # Issue X3-55431 - display info message once if critical field changed
        If GOPECRICHG=1 & [M:MFG1]ROUECCMAJ<>"" & VALEUR <> [M:MFG3]SCOITMREF(nolign-1)
          If GMFGREV=2
            [M:MFG3]REVCOD(nolign-1) = 2 # = Modify
          Endif
          If !GREVMESSC # No critical message yet
              GREVMESSC = 1
              GERR = 2
              GMESSAGE = mess(411,193,1)
          Endif
        Endif
        # End issue X3-55431
    Endif
Endif
# End issue X3-55362
# End issue X3-28791
End

