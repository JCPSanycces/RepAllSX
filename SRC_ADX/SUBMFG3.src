######################################################################################

$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE > GNBDIE : Return : Endif
Call INIT_CCE(VALEUR,AXE,"MFO","",0) From TRTX3CPT
Return

$D_LABCCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE > GNBDIE : Return : Endif
If [M:MFG3]EXTLAB(nolign-1) = "" : Return : Endif
Call INIT_CCE(VALEUR,AXE,"MFO","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$AS_LABCCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
If [M:MFG3]EXTLAB(nolign-1) = "" : mkstat = 2 : Return : Endif
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
# Issue 72051 - 2011-03-04 by CCC : initialisation de la date avec la date du jour au lieu de [0/0/0]
Local Date WDATE : WDATE = date$
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,WDATE) From TRTX3CPT
Return

# Issue X3-28791 - Check revision reason is entered if critical field changed

######################################################################################
## Section automatically added (screen MFG3) 08/30/2017 13:38:43 (BAKHA)
######################################################################################
Subprog C_REVREASON(VALEUR)
Variable Char    VALEUR()
Local    Integer L : L = nolign-1

# Check revision reason is entered
# Issue X3-55362 - 2017-09-18 by JUSYN : only if activity code "RVM" set; check for routing version
If dim([M:MFG1]ROUECCMAJ) > 0
    If instr(1,dbgstr(1),"MFG3")
      If (GMFGREV=2 and VALEUR = "" and [M:MFG3]REVCOD(L) > 0)
          GMESSAGE = mess(403,193,1) # Please enter a revision reason
          GERR=1
          mkstat=2
      Endif
    Endif
Endif
# End issue X3-55362
End

# End issue X3-28791
######################################################################################

