#<AdxTL>@(#)12.0.0.0 $Revision$
#########################################################################
## Programme de traitement de l'onglet opération des O.F               ##
#########################################################################
## écrit en Septembre 1998 par LLC                                     ##
#########################################################################
# Issue X3-28791 - 2017-08-30 by BAKHA : WO opertaions critical changes, reset flag for message
# Issue X3-55431 - 2017-09-15 by BAKHA : display info message once after critical field changes, also
#                                        use same global variable (GREVMESSC) as component changes so that info
#                                        message is displayed only once during all critical changes

$ACTION
Case ACTION
		When "BB6_NBLIG"     : Gosub BB6_NBLIG
Endcase
Return

########################################################################
$OUVRE
Global Integer OMODIF
Global Integer OSOLDE
Global Integer OJAL
# --- Déclaration classe ecran pour encours opérations --- #
Local Mask OPSK   [OPSK]
# --- Déclaration classe ecran pour jalonnement        --- #
Local Mask JALK   [JALK]
# ouverture PARJAL
Local File PARJAL     [PJA]
#
Return

########################################################################
$FERME
Close Local Mask [OPSK]
Close Local Mask [JALK]    # 03.05 29228
Close Local File [PJA]     # 03.05 29228

Return

########################################################################
$APRES_MODIF
OMODIF=1
Call ITMUPDFLG From SUBMFGB
Return

###########################################################################
## Action technique de définition du filtre de lecture
$DEFLIG
FICLIG = "MFGOPE" : ABLIG = "MFO"

Return

###########################################################################
## Lecture des lignes
#########################################################################
$LIENS
Local Integer I : I=0
Local Integer L

#
For [MFO]MFO0 Where MFGNUM=[M:MFG0]MFGNUM
#    llc 03.01 8593
    nolign = I + 1
    [M:MFG3] = [F:MFO]

    [M:MFG3]OPENUM(I)    = [F:MFO]OPENUM
    [M:MFG3]ROUOPENUM(I) = [F:MFO]ROUOPENUM
    [M:MFG3]OPESPLNUM(I) = [F:MFO]OPESPLNUM
    [M:MFG3]RPLIND(I)    = [F:MFO]RPLIND
    [M:MFG3]OPESTA(I)    = [F:MFO]OPESTA
    [M:MFG3]EXTWST(I)    = [F:MFO]EXTWST
    # lecture poste pour centre de charge et type
    Read [MWS]WST0=[F:MFO]EXTWST;[F:MFO]MFGFCY
    If !fstat
        [M:MFG3]WCR(I)        = [F:MWS]WCR
        Call LECTEXTRA([M:MFG3]EXTWSTSHO(I),"WORKSTATIO","WSTSHOAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
        [M:MFG3]WSTTYP(I)     = [F:MWS]WSTTYP
        [M:MFG3]XWSTTYP(I)    = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
        [M:MFG3]WSTEFF(I)     = [F:MWS]EFF
    Endif
    [M:MFG3]OPESTR(I)    = [F:MFO]OPESTR
    [M:MFG3]OPEEND(I)    = [F:MFO]OPEEND
    [M:MFG3]FRCSTRDAT(I) = [F:MFO]FRCSTRDAT
    [M:MFG3]FRCSTRHOU(I) = [F:MFO]FRCSTRHOU
    [M:MFG3]ROODES(I)    = [F:MFO]ROODES
    [M:MFG3]TIMUOMCOD(I) = [F:MFO]TIMUOMCOD
    [M:MFG3]EXTSETTIM(I) = [F:MFO]EXTSETTIM
    [M:MFG3]EXTUNTTIM(I) = [F:MFO]EXTUNTTIM
    [M:MFG3]EXTOPETIM(I) = [F:MFO]EXTOPETIM
    [M:MFG3]EXTQTY(I)    = [F:MFO]EXTQTY
    [M:MFG3]EXTSTUQTY(I) = [F:MFO]EXTSTUQTY
    [M:MFG3]EXTSTRQTY(I) = [F:MFO]EXTSTRQTY
    [M:MFG3]OPEUOM(I)    = [F:MFO]OPEUOM
    [M:MFG3]SCOCOD(I)    = [F:MFO]SCOCOD
    [M:MFG3]SCOWST(I)    = [F:MFO]SCOWST
    # lecture poste pour centre de charge et type
    Read [MWS]WST0=[F:MFO]SCOWST;[F:MFO]MFGFCY
    If !fstat : [M:MFG3]SCOWCR(I)     = [F:MWS]WCR : Endif
    [M:MFG3]SCOITMREF(I) = [F:MFO]SCOITMREF
    [M:MFG3]BPRNUM(I)    = [F:MFO]BPRNUM        # llc 02.01 5977 +12.03 MM
    [M:MFG3]BPAADD(I)    = [F:MFO]BPAADD        # FQ 55167 GA 05/2009
    [M:MFG3]REFPRI(I)    = [F:MFO]REFPRI        # llc 02.01 5977
    [M:MFG3]SCOLTI(I)    = [F:MFO]SCOLTI
    [M:MFG3]SCOPUU(I)    = [F:MFO]SCOPUU
    [M:MFG3]EXTLAB(I)    = [F:MFO]EXTLAB
    # lecture poste pour centre de charge m-o
    Read [MWS]WST0=[F:MFO]EXTLAB;[F:MFO]MFGFCY
    If !fstat
        [M:MFG3]LABWCR(I)    = [F:MWS]WCR
        Call LECTEXTRA([M:MFG3]EXTLABSHO(I),"WORKSTATIO","WSTSHOAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
    Endif
    [M:MFG3]SETLABCOE(I) = [F:MFO]SETLABCOE
    [M:MFG3]OPELABCOE(I) = [F:MFO]OPELABCOE
    [M:MFG3]OPESTUCOE(I) = [F:MFO]OPESTUCOE
    [M:MFG3]OPESTRCOE(I) = [F:MFO]OPESTRCOE
    [M:MFG3]ROOTIMCOD(I) = [F:MFO]ROOTIMCOD
    [M:MFG3]TIMCOD(I)    = [F:MFO]TIMCOD
    [M:MFG3]BASQTY(I)    = [F:MFO]BASQTY
    [M:MFG3]CAD(I)       = [F:MFO]CAD
    [M:MFG3]OPEPLNNUM(I) = [F:MFO]OPEPLNNUM
    [M:MFG3]OPEROUPCT(I) = [F:MFO]OPEROUPCT
    [M:MFG3]MFOTEX(I)    = [F:MFO]MFOTEX
    [M:MFG3]TECCRD(I)    = [F:MFO]TECCRD
    [M:MFG3]EQUNUM(I)    = [F:MFO]EQUNUM
    [M:MFG3]FXGNUM(I)    = [F:MFO]FXGNUM
    [M:MFG3]PRGNUM(I)    = [F:MFO]PRGNUM
    [M:MFG3]EFF(I)       = [F:MFO]EFF
    [M:MFG3]SHR(I)       = [F:MFO]SHR
    [M:MFG3]WAITIM(I)    = [F:MFO]WAITIM
    [M:MFG3]PSPTIM(I)    = [F:MFO]PSPTIM
    [M:MFG3]EXTWSTNBR(I) = [F:MFO]EXTWSTNBR
    [M:MFG3]EXTLABNBR(I) = [F:MFO]EXTLABNBR
    [M:MFG3]PRPTIM(I)    = [F:MFO]PRPTIM
    [M:MFG3]MFOTEX(I)    = [F:MFO]MFOTEX
# données capacité finie
    If dim([M:MFG3]OPENUMLEV(I)) > 0 : [M:MFG3]OPENUMLEV(I) = [F:MFO]OPENUMLEV : Endif
    If dim([M:MFG3]ALTOPECOD(I)) > 0 : [M:MFG3]ALTOPECOD(I) = [F:MFO]ALTOPECOD : Endif
    If dim([M:MFG3]SPLCOD(I))    > 0 : [M:MFG3]SPLCOD(I)    = [F:MFO]SPLCOD    : Endif
    If dim([M:MFG3]SPLMAXNBR(I)) > 0 : [M:MFG3]SPLMAXNBR(I) = [F:MFO]SPLMAXNBR : Endif
    If dim([M:MFG3]RSTMAC(I))    > 0 : [M:MFG3]RSTMAC(I)    = [F:MFO]RSTMAC    : Endif
    If dim([M:MFG3]SCHGRP(I))    > 0 : [M:MFG3]SCHGRP(I)    = [F:MFO]SCHGRP    : Endif
    If dim([M:MFG3]SCHSBB(I))    > 0 : [M:MFG3]SCHSBB(I)    = [F:MFO]SCHSBB    : Endif    # 08.05 distinction des exemplaires
    If dim([M:MFG3]GRPSETTIM(I)) > 0 : [M:MFG3]GRPSETTIM(I) = [F:MFO]GRPSETTIM : Endif
#
    [M:MFG3]MFOTRKFLG(I) = [F:MFO]MFOTRKFLG
    [M:MFG3]OPSNUM(I)    = [F:MFO]OPSNUM
    [M:MFG3]WIPNUM(I)    = [F:MFO]WIPNUM
    [M:MFG3]ITMLINNBR(I) = [M:MFG1]NBLIG
    [M:MFG3]CPLQTY(I)    = [F:MFO]CPLQTY
    [M:MFG3]REJCPLQTY(I) = [F:MFO]REJCPLQTY
    [M:MFG3]QUACPLQTY(I) = [F:MFO]QUACPLQTY
    [M:MFG3]CPLSETTIM(I) = [F:MFO]CPLSETTIM
    [M:MFG3]CPLOPETIM(I) = [F:MFO]CPLOPETIM
    [M:MFG3]POHNUM(I)    = [F:MFO]POHNUM
    [M:MFG3]POPLIN(I)    = [F:MFO]POPLIN
    [M:MFG3]POPSEQ(I)    = [F:MFO]POPSEQ
    If [F:MFO]WIPNUM="" & [F:MFO]SCOITMREF<>"" & [F:MFO]OPESTA<4
       # FQ 77397 GA 12/2011 si WIPNUM perdu la commande de sous-traitance ne sera pas rattachée
       Read [F:ORD]ORD3=[F:MFO]MFGFCY;10;[F:MFO]MFGNUM;0;0
       If !fstat & [F:ORD]ITMREF=[F:MFO]SCOITMREF
          [M:MFG3]WIPNUM(I)=[F:ORD]WIPNUM
       Endif
    Endif
#
    # FQ 60099 GA 11/2009 relire la valeur STDOPENUM sur la gamme
    If dim([M:MFG3]STDOPENUM(I))>0 & [M:MFG3]STDOPENUM(I)=0
       Read [ROO]ROO0=[F:MFG]MFGFCY;[F:MFG]ROUNUM;[F:MFG]ROUALT;[F:MFO]OPENUM;[F:MFO]RPLIND
       If ! fstat [M:MFG3]STDOPENUM(I)=[F:ROO]STDOPENUM Endif
    Endif

    If [M:MFG3]WAITIM(I) > [M:MFG3]PSPTIM(I)
       [M:MFG3]FXDTIM(I) = [M:MFG3]PRPTIM(I) + [M:MFG3]WAITIM(I)
    Else
       [M:MFG3]FXDTIM(I) = [M:MFG3]PRPTIM(I) + [M:MFG3]PSPTIM(I)
    Endif
    [M:MFG3]VARTIM(I)    = [M:MFG3]EXTSETTIM(I) + [M:MFG3]EXTOPETIM(I)
# lecture des données jalonnements
    Read [SCH]SCH0=[M:MFG0]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
    If !fstat
        [M:MFG3]NEXOPENUM(I) = [F:SCH]NEXOPENUM
        [M:MFG3]SCDCOD(I)    = [F:SCH]SCDCOD
        [M:MFG3]SCDTIM(I)    = [F:SCH]SCDTIM
        [M:MFG3]SCDQTY(I)    = [F:SCH]SCDQTY
        [M:MFG3]SCDLOT(I)    = [F:SCH]SCDLOT
        [M:MFG3]LOTQTY(I)    = [F:SCH]LOTQTY       # 10.09
        [M:MFG3]DACMST(I)    = [F:SCH]DACMST
        [M:MFG3]MFGMST(I)    = [F:SCH]MFGMST
    Endif
    #----- Chargement sections analytiques -----#
    Call CHARG_ACCCCE(I,"","","[M:MFG3]CCE","MFO",0,[F:MFO]MFGNUM,[F:MFO]OPENUM,[F:MFO]OPESPLNUM,"EXTWST") From TRTX3CPT
    Call CHARG_ACCCCE(I,"","","[M:MFG3]LABCCE","MFO",0,[F:MFO]MFGNUM,[F:MFO]OPENUM,[F:MFO]OPESPLNUM,"EXTLAB") From TRTX3CPT
    # Issue X3-28791 - 2017-08-31 by JUSYN : Initialise REVCOD
    # Issue X3-55362 - 2017-09-12 by JUSYN : Initialise field regarding activity code
    If dim([M:MFG1]ROUECCMAJ) > 0
        [M:MFG3]REVCOD(I) = 0
    Endif
    # End issue X3-55362
    I+=1
Next
[M:MFG3]NBLIG            = I
[M:MFG3]SCDMOD           = [M:MFG1]SCDMOD
[M:MFG3]SCDFLG           = [F:MFG]SCDFLG
#
Call UPDATE_FDMA()    # X3-3999 Display the first date of availability of each operation

Return

# X3-3999
#**----------------------------------------------------------------<br/>
#* UPDATE_FDMA : Display the first date of availability of each operation
#**<br/>----------------------------------------------------------------<br/>
#*!
Subprog UPDATE_FDMA()
If !(dim([M:MFG3]FDMA)>0 & varmode([M:MFG3]FDMA)<>3) : End : Endif

If clalev([M:MFG2])
  # Issue 60258 GH 16/04/2018 - for performance, not redo calculations already done to set [M:MFG2]FDMA
  If [M:MFG2]NBLIG=0
    Raz [M:MFG3]FDMA
  Else
    Local Integer I, J
    For J=0 To [M:MFG3]NBLIG-1
      [M:MFG3]FDMA(J) = [0/0/0]
      For I=0 To [M:MFG2]NBLIG-1
        If find([M:MFG2]BOMOPE(I),[M:MFG3]OPENUM(J),0)
           [M:MFG3]FDMA(J) = max([M:MFG3]FDMA(J),[M:MFG2]FDMA(I))
        Endif
      Next
    Next
  Endif

Else
  Local Instance FDMA Using C_MFGFDMA      # X3-3999 To test => delete
  Local Integer LLIN, MATFIX, J, K, WRET
  Local Datetime FDMADAT

  # X3-3999 Display the first date of availability
  LLIN=0
  # Issue X3-65500 - 2017-11-23 by ALSHE : Calculate FDMA for all components at once - not for each released product separate
  FDMA = NewInstance C_MFGFDMA AllocGroup null
  WRET = fmet FDMA.INITIALIZE([M:MFG0]MFGNUM,[L]LLIN,[M:MFG0]MFGFCY,"00:00:00")
  If FDMA.COMFDMAS <> null & maxtab(FDMA.COMFDMAS) > 0
      For J=0 To [M:MFG3]NBLIG-1
          # Issue 50884 GH 31/07/2017 - use K instead of L to not disturb the loop above
          #L = fmet FDMA.GETFDMA([M:MFG3]OPENUM(J), [L]FDMADAT, [L]MATFIX)
          K = fmet FDMA.GETFDMA([M:MFG3]OPENUM(J), [L]FDMADAT, [L]MATFIX)
          [M:MFG3]FDMA(J) = left$(num$([L]FDMADAT), 4) + mid$(num$([L]FDMADAT), 6, 2) + mid$(num$([L]FDMADAT), 9, 2)
      Next
  Endif
  FreeGroup FDMA
Endif
End

###########################################################################
## Modification des lignes
#########################################################################
$MODIF
Local Integer I
Local Integer J : J=0
Local Char    OPSMEM(GLONVCR)(GMFOMAX) # FQ 59777 GA 11/2009 avant (15)(GMFOMAX) # 7761 llc 01.01
If GMFMMAX >= GMFOMAX
   Local Char WIPMEM(GLONVCR)(GMFMMAX) # FQ 59777 GA 11/2009 avant (15)(GMFMMAX)
Else
   Local Char WIPMEM(GLONVCR)(GMFOMAX) # FQ 59777 GA 11/2009 avant (15)(GMFOMAX)
Endif
Local Decimal WEXTHOU1, WEXTHOU2
Local Integer L    : # pour sections analytiques
Local Integer WEXISTE
Local Integer WRET
# Issue X3-28791 - 2017-08-31 by JUSYN : Field to set revision code
Local Shortint WREVCOD : WREVCOD = 0
# Issue X3-28791 - 2017-08-31 by JUSYN : END

# llc 11.02 16478 (déjalonnement déplacé dans $INIMOD de SUBMFGA)
Gosub DEFLIG
For I=0 To [M:MFG3]NBLIG-1
    Readlock [MFO]MFO0=[M:MFG0]MFGNUM;[M:MFG3]OPENUM(I);[M:MFG3]OPESPLNUM(I)
    If fstat=1 : GOK=-1 : GLOCK="$"+FICLIG-num$(I) : Break : Endif
    If fstat = 5 : Raz [F:MFO] : Endif :# sr 260100
    WEXISTE = fstat
    If WEXISTE = 0
        #----- Mise à jour statistiques opération -----#
        Call VALSTA("MFO",-1) From SUBPS2 : If GOK<1 : Break : Endif
    Endif
# Issue X3-28791 - 2017-08-31 by JUSYN : Write auditing record for operations
#   WEXISTE 0 = record already exists
#   WEXISTE 5 = new record
    # Issue X3-55362 - 2017-09-11 by JUSYN : regarding activity code
    If dim([M:MFG1]ROUECCMAJ) > 0
        Case WEXISTE
            When 0: WREVCOD = 2 # Modify
            When 2: WREVCOD = 2 # Modify
            When 5: WREVCOD = 1 # Add
        Endcase
        If WREVCOD = 2
            If [M:MFG3]OPESTA(I) = 6 & [F:MFO]OPESTA < 4 :  WREVCOD = 3  : Endif   # 3 # Excluded (Cancelled)
            If [M:MFG3]OPESTA(I) < 4 & [F:MFO]OPESTA = 6 :  WREVCOD = 4  : Endif   # 4 # Reinstate
        Endif

        If GMFGREV=2 & find(WREVCOD,2,3,4) & [M:MFG1]ROUECCMAJ<>"" & [M:MFG3]REVCOD(I) > 0
            # Issue X3-55362 - 2017-09-11 by JUSYN : Set automatic revision reason if Route reload
            If GMFGROPE > 0
                [M:MFG3]REVREASON(I) = mess(410,193,1)   # Route has been reloaded
            Endif
            # End issue X3-55362
            Call HISTO_REVMFG ("MOR", WREVCOD, I, "G") From TRTREVMFG
        Endif
# Issue X3-28791 - 2017-08-31 by JUSYN : End
    Endif
    # End issue X3-55362
#
#    llc 03.01 8593
    nolign = I + 1
    WEXTHOU1            = [F:MFO]EXTOPETIM                # llc 07.02 15327
    If [F:MFO]SCOITMREF <> [M:MFG3]SCOITMREF(I)   : [M:MFG3]WIPNUM(I) = "" : Endif        # 09.04 25237

    # transclasse
    [F:MFO] = [M:MFG3]

    [F:MFO]OPENUM       = [M:MFG3]OPENUM(I)
    [F:MFO]ROUOPENUM    = [M:MFG3]ROUOPENUM(I)
    [F:MFO]OPESPLNUM    = [M:MFG3]OPESPLNUM(I)
    [F:MFO]RPLIND       = [M:MFG3]RPLIND(I)
    [F:MFO]OPESTA       = [M:MFG3]OPESTA(I)
    [F:MFO]EXTWST       = [M:MFG3]EXTWST(I)
    [F:MFO]OPESTR       = [M:MFG3]OPESTR(I)
    [F:MFO]OPEEND       = [M:MFG3]OPEEND(I)
    [F:MFO]FRCSTRDAT    = [M:MFG3]FRCSTRDAT(I)
    [F:MFO]FRCSTRHOU    = [M:MFG3]FRCSTRHOU(I)
    [F:MFO]ROODES       = [M:MFG3]ROODES(I)
    [F:MFO]TIMUOMCOD    = [M:MFG3]TIMUOMCOD(I)
    [F:MFO]EXTSETTIM    = [M:MFG3]EXTSETTIM(I)
    [F:MFO]EXTUNTTIM    = [M:MFG3]EXTUNTTIM(I)
# llc 03.01 multi-exemplaire
#   WEXTHOU1            = [F:MFO]EXTOPETIM * [F:MFO]EXTWSTNBR            # llc 12.00 6966
#   [F:MFO]EXTOPETIM    = [M:MFG3]EXTOPETIM(I) * [M:MFG3]EXTWSTNBR(I)    # llc 12.00 6966
    [F:MFO]EXTOPETIM    = [M:MFG3]EXTOPETIM(I)
    WEXTHOU2            = [F:MFO]EXTOPETIM
    [F:MFO]EXTQTY       = [M:MFG3]EXTQTY(I)
    [F:MFO]EXTSTUQTY    = [M:MFG3]EXTSTUQTY(I)
    [F:MFO]EXTSTRQTY    = [M:MFG3]EXTSTRQTY(I)
    [F:MFO]OPEUOM       = [M:MFG3]OPEUOM(I)
    [F:MFO]SCOCOD       = [M:MFG3]SCOCOD(I)
    [F:MFO]SCOWST       = [M:MFG3]SCOWST(I)
    [F:MFO]SCOITMREF    = [M:MFG3]SCOITMREF(I)
    [F:MFO]BPRNUM       = [M:MFG3]BPRNUM(I)         # llc 02.01 5977 + 12.03 MM
    [F:MFO]BPAADD       = [M:MFG3]BPAADD(I)         # FQ 55167 GA 05/2009
    [F:MFO]REFPRI       = [M:MFG3]REFPRI(I)         # llc 02.01 5977
    [F:MFO]SCOLTI       = [M:MFG3]SCOLTI(I)
    [F:MFO]SCOPUU       = [M:MFG3]SCOPUU(I)
    [F:MFO]EXTLAB       = [M:MFG3]EXTLAB(I)
    [F:MFO]SETLABCOE    = [M:MFG3]SETLABCOE(I)
    [F:MFO]OPELABCOE    = [M:MFG3]OPELABCOE(I)
    [F:MFO]OPESTUCOE    = [M:MFG3]OPESTUCOE(I)
    [F:MFO]OPESTRCOE    = [M:MFG3]OPESTRCOE(I)
    [F:MFO]ROOTIMCOD    = [M:MFG3]ROOTIMCOD(I)
    [F:MFO]TIMCOD       = [M:MFG3]TIMCOD(I)
    [F:MFO]BASQTY       = [M:MFG3]BASQTY(I)
    [F:MFO]CAD          = [M:MFG3]CAD(I)
    [F:MFO]OPEPLNNUM    = [M:MFG3]OPEPLNNUM(I)
    [F:MFO]OPEROUPCT    = [M:MFG3]OPEROUPCT(I)
    [F:MFO]MFOTEX       = [M:MFG3]MFOTEX(I)
    [F:MFO]TECCRD       = [M:MFG3]TECCRD(I)
    [F:MFO]EQUNUM       = [M:MFG3]EQUNUM(I)
    [F:MFO]FXGNUM       = [M:MFG3]FXGNUM(I)
    [F:MFO]PRGNUM       = [M:MFG3]PRGNUM(I)
    [F:MFO]EFF          = [M:MFG3]EFF(I)
    [F:MFO]SHR          = [M:MFG3]SHR(I)
    [F:MFO]WSTEFF       = [M:MFG3]WSTEFF(I)
    [F:MFO]WAITIM       = [M:MFG3]WAITIM(I)
    [F:MFO]PSPTIM       = [M:MFG3]PSPTIM(I)
    [F:MFO]EXTWSTNBR    = [M:MFG3]EXTWSTNBR(I)
    [F:MFO]EXTLABNBR    = [M:MFG3]EXTLABNBR(I)
    [F:MFO]PRPTIM       = [M:MFG3]PRPTIM(I)

    If WEXISTE = 5
        [F:MFO]STDWST       = [M:MFG3]EXTWST(I)
        [F:MFO]STDLAB       = [M:MFG3]EXTLAB(I)
        [F:MFO]STDWSTNBR    = [M:MFG3]EXTWSTNBR(I)
        [F:MFO]STDLABNBR    = [M:MFG3]EXTLABNBR(I)
        [F:MFO]STDUNTTIM    = [M:MFG3]EXTUNTTIM(I)
        [F:MFO]STDSETTIM    = [M:MFG3]EXTSETTIM(I)
        [F:MFO]STDOPETIM    = [M:MFG3]EXTOPETIM(I)
        [F:MFO]STDQTY       = [M:MFG3]STDQTY(I)
    Endif

# données capacité finie
    If dim([M:MFG3]OPENUMLEV(I)) > 0 : [F:MFO]OPENUMLEV = [M:MFG3]OPENUMLEV(I) : Endif
    If dim([M:MFG3]ALTOPECOD(I)) > 0 : [F:MFO]ALTOPECOD = [M:MFG3]ALTOPECOD(I) : Endif
    If dim([M:MFG3]SPLCOD(I))    > 0 : [F:MFO]SPLCOD    = [M:MFG3]SPLCOD(I)    : Endif
    If dim([M:MFG3]SPLMAXNBR(I)) > 0 : [F:MFO]SPLMAXNBR = [M:MFG3]SPLMAXNBR(I) : Endif
    If dim([M:MFG3]RSTMAC(I))    > 0 : [F:MFO]RSTMAC    = [M:MFG3]RSTMAC(I)    : Endif
    If dim([M:MFG3]SCHGRP(I))    > 0 : [F:MFO]SCHGRP    = [M:MFG3]SCHGRP(I)    : Endif
    If dim([M:MFG3]SCHSBB(I))    > 0 : [F:MFO]SCHSBB    = [M:MFG3]SCHSBB(I)    : Endif    # 08.05 distinction des exemplaires
    If dim([M:MFG3]GRPSETTIM(I)) > 0 : [F:MFO]GRPSETTIM = [M:MFG3]GRPSETTIM(I) : Endif
#
    [F:MFO]INFCAPSTR    = [M:MFG3]OPESTR(I)
    [F:MFO]INFCAPEND    = [M:MFG3]OPEEND(I)
#
    [F:MFO]MFOTRKFLG    = [M:MFG3]MFOTRKFLG(I)
    [F:MFO]MFGPIO       = [M:MFG1]MFGPIO
    [F:MFO]MFGFCY        = [M:MFG0]MFGFCY
    [F:MFO]MFGSTA        = [M:MFG0]MFGSTA
#
   # sr 07.02 dans tous les cas (modif ligne existante ou création nouvelle ligne
   # sr demande 15028
   If [M:MFG3]MFOTEX(I) <> ""
      [F:MFO]MFOTEX  = [M:MFG3]MFOTEX(I)
      If left$([F:MFO]MFOTEX,3)="MFO"
         Call CRE_CLOB([F:MFO]MFOTEX,GOK) From TRTX3TEX
      Elsif !find(left$([F:MFO]MFOTEX,3),"ROT","ROO")
         Call DUP_CLOB("MFO",[F:MFO]MFOTEX,GOK) From TRTX3TEX
      Endif
   Endif
   If    WEXISTE = 0
        Call UPDATE_OWX("M",[M:MFG1]PJT(0)) From MFGLIBO
        [F:MFO]UPDDAT = date$
        [F:MFO]UPDUSR = GUSER
        [F:MFO]EXPNUM = [C]EXPORT
        # Issue 91336 GA 09/2014 Rewrite [MFO]
        Gosub REWRITE_MFO From MFGAUTLIB
        OPSMEM(J) = [F:MFO]OPSNUM
        WIPMEM(J) = [F:MFO]WIPNUM            # llc 08.01    10053
        J+=1
   Elsif WEXISTE = 5
        [F:MFO]MFGNUM        = [M:MFG0]MFGNUM
        [F:MFO]PLNFCY        = [M:MFG0]PLNFCY
        Call UPDATE_OWX("C",[M:MFG1]PJT(0)) From MFGLIBO
        [F:MFO]CREDAT = date$
        [F:MFO]CREUSR = GUSER
        [F:MFO]EXPNUM = [C]EXPORT
        # Issue 91336 GA 09/2014 Write [MFO]
        Gosub WRITE_MFO From MFGAUTLIB
        OPSMEM(J) = [F:MFO]OPSNUM
        WIPMEM(J) = [F:MFO]WIPNUM        # llc 08.01    10053
        J+=1
        # Issue X3-28791 - 2017-08-31 by JUSYN : Auditing versioned routing: insert new record.
        # Issue X3-55362 - 2017-09-11 by JUSYN : regarding activity code
        If dim([M:MFG1]ROUECCMAJ) > 0
            If GMFGREV=2 & find(WREVCOD,1) & [M:MFG1]ROUECCMAJ<>"" & [M:MFG3]REVCOD(I) > 0
                # Issue X3-55362 - 2017-09-11 by JUSYN : Set automatic revision reason if Route reload
                If GMFGROPE > 0
                    [M:MFG3]REVREASON(I) = mess(410,193,1)   # Route has been reloaded
                Endif
                # End issue X3-55362
                Call HISTO_REVMFG ("MOR", WREVCOD, I, "G") From TRTREVMFG
            Endif
        Endif
        # End issue X3-55362
   Endif
   #----- Ecriture des sections de la ligne operation -----#
   Call MAJMFO_CPTANALIN(WEXISTE)

# enregistrement données jalonnements
   If [M:MFG3]OPESTA(I) <> 6
       Readlock [SCH]SCH0=[M:MFG0]MFGNUM;[M:MFG3]OPENUM(I);[M:MFG3]OPESPLNUM(I)
       If fstat=1 : GOK=-1 : GLOCK="$"+"SCHEDULING"-num$(I) : Break : Endif
       [F:SCH]ROUNUM       = [M:MFG1]ROUNUM
       [F:SCH]ROUALT       = [M:MFG1]ROUALT
       # Issue 111414 - 2016-01-26 by CCC
       If dim([M:MFG1]ROUECCMAJ)>0
          [F:SCH]ROUECCMAJ = [M:MFG1]ROUECCMAJ
          [F:SCH]ROUECCMIN = [M:MFG1]ROUECCMIN
       Endif
       [F:SCH]NEXOPENUM    = [M:MFG3]NEXOPENUM(I)
       [F:SCH]SCDCOD       = [M:MFG3]SCDCOD(I)
       [F:SCH]SCDTIM       = [M:MFG3]SCDTIM(I)
       [F:SCH]SCDQTY       = [M:MFG3]SCDQTY(I)
       [F:SCH]SCDLOT       = [M:MFG3]SCDLOT(I)
       [F:SCH]LOTQTY       = [M:MFG3]LOTQTY(I)            # 10.09
       [F:SCH]DACMST       = [M:MFG3]DACMST(I)
       [F:SCH]MFGMST       = [M:MFG3]MFGMST(I)
       If    fstat=0
            [F:SCH]UPDDAT=date$
            [F:SCH]UPDUSR=GUSER
            If dim([F:SCH]UPDTIM) > 0 : [F:SCH]UPDTIM = time : Endif            # 01.05 27567
            [F:SCH]EXPNUM=[C]EXPORT
            Rewrite [SCH]
       Elsif fstat=5
            [F:SCH]MFGNUM        = [M:MFG0]MFGNUM
            [F:SCH]PLNFCY        = [M:MFG0]PLNFCY
            [F:SCH]MFGFCY        = [M:MFG0]MFGFCY
            [F:SCH]OPENUM        = [M:MFG3]OPENUM(I)
            [F:SCH]OPESPLNUM     = [M:MFG3]OPESPLNUM(I)    # llc 03.02 13539
            [F:SCH]CREDAT=date$
            [F:SCH]CREUSR=GUSER
            If dim([F:SCH]CRETIM) > 0 : [F:SCH]CRETIM = time : Endif            # 01.05 27567
            [F:SCH]EXPNUM=[C]EXPORT
            Write [SCH]
       Endif
# Maj du fichier WORKSTATIO
       If find([F:MFO]MFGSTA,1,2)
           Readlock [MWS]WST0 = [M:MFG3]EXTWST(I);[M:MFG0]MFGFCY
           If fstat=1 : GOK=-1 : GLOCK="$"+"WORKSTATIO"-[M:MFG3]EXTWST(I) : Break : Endif
           If !fstat
               If [M:MFG3]TIMUOMCOD(I) = 2
                   WEXTHOU1 = WEXTHOU1 / 60
                   WEXTHOU2 = WEXTHOU2 / 60
               Endif
               [F:MWS]EXTHOUTIM -= func TRTX3.ARRTYP("", "", "TIH", WEXTHOU1)
               [F:MWS]EXTHOUTIM += func TRTX3.ARRTYP("", "", "TIH", WEXTHOU2)
               Rewrite [MWS]
           Endif
        Endif
    Endif
    #----- Mise à jour statistiques opération -----#
    Call VALSTA("MFO",1) From SUBPS2 : If GOK<1 : Break : Endif
Next I

# Purge des opérations non prévues et exclues ou remplacées
# 07.06 37187
For [MFO]MFO0 Where MFGNUM=[M:MFG0]MFGNUM
    If !find([F:MFO]OPSNUM,[M:MFG3]OPSNUM(0..[M:MFG3]NBLIG-1)) &
&      !find([F:MFO]OPSNUM,OPSMEM(0..dim(OPSMEM)-1))
        Readlock [F:MFO] Curr
        If !fstat
            Call UPDATE_OWX("A","") From MFGLIBO
            If [F:MFO]MFOTEX <> "" & left$([F:MFO]MFOTEX,3) = "MFO"
               Call SUP_CLOB([F:MFO]MFOTEX,WRET) From TRTX3TEX
            Endif
            # Issue X3-28791 - 2017-08-31 by JUSYN : write critical changes into auditing table - operation deletion
            # Issue X3-55362 - 2017-09-20 by JUSYN : regarding activity code
            If dim([M:MFG1]ROUECCMAJ) > 0
                If GMFGREV=2
                    If [M:MFG1]ROUECCMAJ<>""
                        Call HISTO_REVMFG ("MOR",3 , 0, "E") From TRTREVMFG
                    Endif
                Endif
            Endif
            # End issue X3-55362
            # Issue X3-28791 - 2017-08-31 by JUSYN : END

            Delete [MFO]
            #----- Suppression des sections de la ligne operation  pour les deux postes -----#
#            Delete [CAL] Where ABRFIC="MFO" & VCRNUM=[F:MFO]MFGNUM & VCRLIN=[F:MFO]OPENUM &
#&                VCRSEQ = [F:MFO]OPESPLNUM
            # Issue 119469 GH 04/11/16 - performance enhancement
            Delete [CAL] Where ABRFIC="MFO" & VCRNUM=[F:MFO]MFGNUM & VCRLIN=[F:MFO]OPENUM
&                            & VCRSEQ=[F:MFO]OPESPLNUM & VCRTYP=0
            If fstat=1
               GOK=-1 : GLOCK="$CPTANALIN MFO 0"-[F:MFO]MFGNUM-num$([F:MFO]OPENUM)-num$([F:MFO]OPESPLNUM)
               Break # FQ 69909 Ctrl des sources avant Return
            Endif
            #-----
            Call DEL_JAL
            #----- Mise à jour statistiques opération -----#
            Call VALSTA("MFO",-1) From SUBPS2 : If GOK<1 : Break : Endif
        Endif
    Endif
Next

# 07.06 37187 (purge SCx résiduels)
Filter [ORD] Where WIPTYP = 4 & VCRNUM = [M:MFG0]MFGNUM
For [ORD]ORD3
    If !find([F:ORD]WIPNUM,WIPMEM(0..dim(WIPMEM)-1))
        Readlock [ORD] Curr
        If !fstat
            Delete [ORD]
        Endif
    Endif
Next
Filter [ORD]

If [M:MFG3]NBLIG <> 0 &
& (([F:MTS]MODJAL = 2 & find([M:MFG3]SCDFLG,1,3)) |
&  (GSCDFLG <> [M:MFG3]SCDFLG & find(GSCDFLG,2,4)))
    GJALFLG = 1
#    [M:JALK]CODORI = 1
#    [M:JALK]CODMAJ = 0
#    [M:JALK]CODTRS = 0
#    [M:JALK]MFGFCY = [M:MFG0]MFGFCY
#    [M:JALK]MFGNUM = [M:MFG0]MFGNUM
#    [M:JALK]MFGSTA = [M:MFG0]MFGSTA
#    Call DEJALONNE From JALLIBA
#    If [M:JALK]CODRET <> 0 : Call ERREUR(mess(78,193,1)) From GESECRAN : Return : Endif
    [M:JALK]CODORI = 1
    [M:JALK]CODMAJ = 0
    [M:JALK]CODTRS = 2
    [M:JALK]MFGFCY = [M:MFG0]MFGFCY
    [M:JALK]MFGNUM = [M:MFG0]MFGNUM
    [M:JALK]MFGSTA = [M:MFG0]MFGSTA
    If [F:PJA]MFGFCY <> [M:MFG0]MFGFCY
        Read [PJA]PJA0=[M:MFG0]MFGFCY
        If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
    Endif
    Call JALONNE From JALLIB
    If [M:JALK]CODRET=0 & [M:MFG1]SCDMOD = 1
        Read [MFG]MFG0=[M:MFG0]MFGNUM
        If !fstat & [F:MFG]ENDDAT <> [M:MFG1]ENDDAT
           Call MESSAGE(mess(76,190,1)+"\"+format$(GFMD,[M:MFG1]ENDDAT)-"-->"-format$(GFMD,[F:MFG]ENDDAT)) From GESECRAN
        Endif
   Endif
Endif

# Issue 119845 - 2016-12-12 by CCC : Production scheduler
Gosub UPDATE_OPTIMISATION

# Issue 105341 - 2015-03-06 by JUSYN : Treatment to set operation status concerning preceding operations
For I=0 To [M:MFG3]NBLIG-1
    Readlock [F:MFO]MFO0 = [M:MFG0]MFGNUM;[M:MFG3]OPENUM(I);[M:MFG3]OPESPLNUM(I)
    If !fstat
        Gosub MAJ_SUIVANTE From SUBMTKC
    Endif
    If GOK < 1 : Break : Endif
Next I

# llc 11.02 16478
If GLOADFLG = 1
    Call WORKLOAD([F:MFG]MFGFCY, [F:MFG]MFGNUM, [F:MFG]SCDFLG) From JALLIBB
Endif
# Issue X3-55362 - 2017-09-11 by JUSYN : Reset flag for route reload
If dim([M:MFG1]ROUECCMAJ) > 0 : Raz GMFGROPE : Endif
# End issue X3-55362
Return

###########################################################################
## Création des opérations
#########################################################################
$CREATION
Local Integer I
Local Integer WRET
Local Decimal WEXTHOU
Local Integer L
#
Raz [F:MFO]
For I=0 To [M:MFG3]NBLIG-1
#    llc 03.01 8593
    nolign = I + 1
    [F:MFO] = [M:MFG3]

    [F:MFO]MFGNUM       = [M:MFG0]MFGNUM
    [F:MFO]MFGSTA       = [M:MFG0]MFGSTA
    [F:MFO]PLNFCY       = [M:MFG0]PLNFCY
    [F:MFO]MFGFCY       = [M:MFG0]MFGFCY
    [F:MFO]MFGPIO       = [M:MFG1]MFGPIO
#
    [F:MFO]OPENUM       = [M:MFG3]OPENUM(I)
    [F:MFO]ROUOPENUM    = [M:MFG3]ROUOPENUM(I)
    [F:MFO]OPESPLNUM    = [M:MFG3]OPESPLNUM(I)
    [F:MFO]RPLIND       = [M:MFG3]RPLIND(I)
    [F:MFO]OPESTA       = [M:MFG3]OPESTA(I)
    [F:MFO]EXTWST       = [M:MFG3]EXTWST(I)
    [F:MFO]OPESTR       = [M:MFG3]OPESTR(I)
    [F:MFO]OPEEND       = [M:MFG3]OPEEND(I)
    [F:MFO]FRCSTRDAT    = [M:MFG3]FRCSTRDAT(I)
    [F:MFO]FRCSTRHOU    = [M:MFG3]FRCSTRHOU(I)
    [F:MFO]ROODES       = [M:MFG3]ROODES(I)
    [F:MFO]TIMUOMCOD    = [M:MFG3]TIMUOMCOD(I)
    [F:MFO]EXTSETTIM    = [M:MFG3]EXTSETTIM(I)
    [F:MFO]EXTUNTTIM    = [M:MFG3]EXTUNTTIM(I)
    [F:MFO]EXTOPETIM    = [M:MFG3]EXTOPETIM(I)
    [F:MFO]EXTQTY       = [M:MFG3]EXTQTY(I)
    [F:MFO]EXTSTUQTY    = [M:MFG3]EXTSTUQTY(I)
    [F:MFO]EXTSTRQTY    = [M:MFG3]EXTSTRQTY(I)
    [F:MFO]OPEUOM       = [M:MFG3]OPEUOM(I)
    [F:MFO]SCOCOD       = [M:MFG3]SCOCOD(I)
    [F:MFO]SCOWST       = [M:MFG3]SCOWST(I)
    [F:MFO]SCOITMREF    = [M:MFG3]SCOITMREF(I)
    [F:MFO]BPRNUM       = [M:MFG3]BPRNUM(I)        # llc 02.01 5977 +12.03 MM
    [F:MFO]BPAADD       = [M:MFG3]BPAADD(I)        # FQ 55167 GA 05/2009
    [F:MFO]REFPRI       = [M:MFG3]REFPRI(I)        # llc 02.01 5977
    [F:MFO]SCOLTI       = [M:MFG3]SCOLTI(I)
    [F:MFO]SCOPUU       = [M:MFG3]SCOPUU(I)
    [F:MFO]EXTLAB       = [M:MFG3]EXTLAB(I)
    [F:MFO]SETLABCOE    = [M:MFG3]SETLABCOE(I)
    [F:MFO]OPELABCOE    = [M:MFG3]OPELABCOE(I)
    [F:MFO]OPESTUCOE    = [M:MFG3]OPESTUCOE(I)
    [F:MFO]OPESTRCOE    = [M:MFG3]OPESTRCOE(I)
    [F:MFO]ROOTIMCOD    = [M:MFG3]ROOTIMCOD(I)
    [F:MFO]TIMCOD       = [M:MFG3]TIMCOD(I)
    [F:MFO]BASQTY       = [M:MFG3]BASQTY(I)
    [F:MFO]CAD          = [M:MFG3]CAD(I)
    [F:MFO]OPEPLNNUM    = [M:MFG3]OPEPLNNUM(I)
    [F:MFO]OPEROUPCT    = [M:MFG3]OPEROUPCT(I)
    [F:MFO]MFOTEX       = [M:MFG3]MFOTEX(I)
    [F:MFO]TECCRD       = [M:MFG3]TECCRD(I)
    [F:MFO]EQUNUM       = [M:MFG3]EQUNUM(I)
    [F:MFO]FXGNUM       = [M:MFG3]FXGNUM(I)
    [F:MFO]PRGNUM       = [M:MFG3]PRGNUM(I)
    [F:MFO]EFF          = [M:MFG3]EFF(I)
    [F:MFO]SHR          = [M:MFG3]SHR(I)
    [F:MFO]WSTEFF       = [M:MFG3]WSTEFF(I)
    [F:MFO]WAITIM       = [M:MFG3]WAITIM(I)
    [F:MFO]PSPTIM       = [M:MFG3]PSPTIM(I)
    [F:MFO]EXTWSTNBR    = [M:MFG3]EXTWSTNBR(I)
    [F:MFO]EXTLABNBR    = [M:MFG3]EXTLABNBR(I)
    [F:MFO]PRPTIM       = [M:MFG3]PRPTIM(I)
#
    [F:MFO]STDWST       = [M:MFG3]EXTWST(I)
    [F:MFO]STDLAB       = [M:MFG3]EXTLAB(I)
    [F:MFO]STDWSTNBR    = [M:MFG3]EXTWSTNBR(I)
    [F:MFO]STDLABNBR    = [M:MFG3]EXTLABNBR(I)
    [F:MFO]STDUNTTIM    = [M:MFG3]EXTUNTTIM(I)
    [F:MFO]STDSETTIM    = [M:MFG3]EXTSETTIM(I)
    [F:MFO]STDOPETIM    = [M:MFG3]EXTOPETIM(I)
    [F:MFO]STDQTY       = [M:MFG3]STDQTY(I)
# données capacité finie
    If dim([M:MFG3]OPENUMLEV(I)) > 0 : [F:MFO]OPENUMLEV = [M:MFG3]OPENUMLEV(I) : Endif
    If dim([M:MFG3]ALTOPECOD(I)) > 0 : [F:MFO]ALTOPECOD = [M:MFG3]ALTOPECOD(I) : Endif
    If dim([M:MFG3]SPLCOD(I))    > 0 : [F:MFO]SPLCOD    = [M:MFG3]SPLCOD(I)    : Endif
    If dim([M:MFG3]SPLMAXNBR(I)) > 0 : [F:MFO]SPLMAXNBR = [M:MFG3]SPLMAXNBR(I) : Endif
    If dim([M:MFG3]RSTMAC(I))    > 0 : [F:MFO]RSTMAC    = [M:MFG3]RSTMAC(I)    : Endif
    If dim([M:MFG3]SCHGRP(I))    > 0 : [F:MFO]SCHGRP    = [M:MFG3]SCHGRP(I)    : Endif
    If dim([M:MFG3]SCHSBB(I))    > 0 : [F:MFO]SCHSBB    = [M:MFG3]SCHSBB(I)    : Endif    # 08.05 distinction des exemplaires
    If dim([M:MFG3]GRPSETTIM(I)) > 0 : [F:MFO]GRPSETTIM = [M:MFG3]GRPSETTIM(I) : Endif
#
    [F:MFO]INFCAPSTR    = [M:MFG3]OPESTR(I)
    [F:MFO]INFCAPEND    = [M:MFG3]OPEEND(I)
#
    [F:MFO]MFOTRKFLG    = [M:MFG3]MFOTRKFLG(I)
    [F:MFO]MFGPIO       = [M:MFG1]MFGPIO
    [F:MFO]WIPNUM       = ""
    [F:MFO]OPSNUM       = ""
    Call UPDATE_OWX("C",[M:MFG1]PJT(0)) From MFGLIBO

# llc 11.02 16424
    If [M:MFG3]MFOTEX(I) <> ""
       [F:MFO]MFOTEX  = [M:MFG3]MFOTEX(I)
       If left$([F:MFO]MFOTEX,3)="MFO"
          Call CRE_CLOB([F:MFO]MFOTEX,GOK) From TRTX3TEX
       Elsif !find(left$([F:MFO]MFOTEX,3),"ROT","ROO")
          Call DUP_CLOB("MFO",[F:MFO]MFOTEX,GOK) From TRTX3TEX
       Endif
    Endif

    [F:MFO]CREDAT = date$
    [F:MFO]CREUSR = GUSER
    [F:MFO]EXPNUM = [C]EXPORT
    Write [MFO]
    If fstat : GOK=0 : Call FSTA("MFO") From GLOCK : Break : Endif

    #----- Ecriture des sections de la ligne operation -----#
    Call MAJMFO_CPTANALIN(1)

# génération jalonnements
        Raz [F:SCH]
        [F:SCH]MFGNUM       = [M:MFG0]MFGNUM
        [F:SCH]PLNFCY       = [M:MFG0]PLNFCY
        [F:SCH]MFGFCY       = [M:MFG0]MFGFCY
        [F:SCH]OPENUM       = [M:MFG3]OPENUM(I)
        [F:SCH]OPESPLNUM    = [M:MFG3]OPESPLNUM(I)
        [F:SCH]ROUNUM       = [M:MFG1]ROUNUM
        [F:SCH]ROUALT       = [M:MFG1]ROUALT
        # Issue 111414 - 2016-01-26 by CCC
        If dim([M:MFG1]ROUECCMAJ)>0
           [F:SCH]ROUECCMAJ = [M:MFG1]ROUECCMAJ
           [F:SCH]ROUECCMIN = [M:MFG1]ROUECCMIN
        Endif
        [F:SCH]NEXOPENUM    = [M:MFG3]NEXOPENUM(I)
        [F:SCH]SCDCOD       = [M:MFG3]SCDCOD(I)
        [F:SCH]SCDTIM       = [M:MFG3]SCDTIM(I)
        [F:SCH]SCDQTY       = [M:MFG3]SCDQTY(I)
        [F:SCH]SCDLOT       = [M:MFG3]SCDLOT(I)
        [F:SCH]LOTQTY       = [M:MFG3]LOTQTY(I)            # 10.09
        [F:SCH]DACMST       = [M:MFG3]DACMST(I)
        [F:SCH]MFGMST       = [M:MFG3]MFGMST(I)
#
        [F:SCH]CREDAT=date$
        [F:SCH]CREUSR=GUSER
        If dim([F:SCH]CRETIM) > 0 : [F:SCH]CRETIM = time : Endif            # 01.05 27567
        [F:SCH]EXPNUM=[C]EXPORT
        Write [SCH]
        If fstat : GOK=0 : Call FSTA("SCH") From GLOCK : Break : Endif
# Maj du fichier WORKSTATIO
         If find([F:MFO]MFGSTA,1,2)
            Readlock [MWS]WST0 = [M:MFG3]EXTWST(I);[M:MFG0]MFGFCY
            If fstat=1 : GOK=-1 : GLOCK="$"+"WORKSTATIO"-[M:MFG3]EXTWST(I) : Break : Endif
            If !fstat
# llc 03.01 multi-exemplaire
#               WEXTHOU = [M:MFG3]EXTOPETIM(I) * [M:MFG3]EXTWSTNBR(I)            # llc 1200 6966
                WEXTHOU = [M:MFG3]EXTOPETIM(I)
                If [M:MFG3]TIMUOMCOD(I) = 2 : WEXTHOU = WEXTHOU / 60 : Endif
                [F:MWS]EXTHOUTIM += func TRTX3.ARRTYP("", "", "TIH", WEXTHOU)
                Rewrite [MWS]
            Endif
        Endif
        #----- Mise à jour statistiques opération -----#
        Call VALSTA("MFO",1) From SUBPS2 : If GOK<1 : Break : Endif
#
Next I
#
If [M:MFG3]NBLIG <> 0 & [F:MTS]MODJAL = 2
    GJALFLG = 1
    [M:JALK]CODORI = 1
    [M:JALK]CODMAJ = 0
    [M:JALK]CODTRS = 2
    [M:JALK]MFGFCY = [M:MFG0]MFGFCY
    [M:JALK]MFGNUM = [M:MFG0]MFGNUM
    [M:JALK]MFGSTA = [M:MFG0]MFGSTA
    If [F:PJA]MFGFCY <> [M:MFG0]MFGFCY
        Read [PJA]PJA0=[M:MFG0]MFGFCY
        If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
    Endif
    Call JALONNE From JALLIB
    If [M:JALK]CODRET=0 & [M:MFG1]SCDMOD = 1
        Read [MFG]MFG0=[M:MFG0]MFGNUM
        If !fstat & [F:MFG]ENDDAT <> [M:MFG1]ENDDAT
           Call MESSAGE(mess(76,190,1)+"\"+format$(GFMD,[M:MFG1]ENDDAT)-"-->"-format$(GFMD,[F:MFG]ENDDAT)) From GESECRAN
        Endif
   Endif
Endif

# Issue 119845 - 2016-12-12 by CCC : Production scheduler
Gosub UPDATE_OPTIMISATION
Return

# Issue 119845 - 2016-12-12 by CCC : Production scheduler
# Update Production Scheduler flag
$UPDATE_OPTIMISATION
# Issue X3-30339 - 2017-04-07 by ALSHE : Release WO managed by PS - don't change OPTFLG if WO is already optimized
#    If [F:MTS]MODOPT = 2 & find([F:MFG]SCDFLG,2,4)<>0
    If [F:MTS]MODOPT = 2 & find([F:MFG]SCDFLG,2)<>0
        [F:MFG]OPTFLG = 2
#    Elsif find([F:MFG]SCDFLG,2,4)=0
    Elsif find([F:MFG]SCDFLG,2)=0
        [F:MFG]OPTFLG = 1   # The WO is not scheduled => can't be in PS
    Endif
Return

###########################################################################
## Annulation des lignes
#########################################################################
# purge des opérations
$ANNULE
Local Integer WRETOUR
Local Integer WRET
Local Char WNUMTEX (12)
Local Decimal WEXTHOU

# si OF jalonné, déjalonnement
If [F:MFG]SCDFLG > 1
    [M:JALK]CODORI = 1
    [M:JALK]CODMAJ = 0
    [M:JALK]CODTRS = 0
    [M:JALK]MFGFCY = [M:MFG0]MFGFCY
    [M:JALK]MFGNUM = [M:MFG0]MFGNUM
    [M:JALK]MFGSTA = [M:MFG0]MFGSTA
    Call DEJALONNE From JALLIBA
    If [M:JALK]CODRET <> 0
         Call ERREUR(mess(79,193,1)) From GESECRAN
    Endif
Endif
# annulation opérations
For [MFO]MFO0 Where MFGNUM=[F:MFG]MFGNUM With Lock
    Call UPDATE_OWX("A","") From MFGLIBO
#annulation textes
    If [F:MFO]MFOTEX <> "" & left$([F:MFO]MFOTEX,3) = "MFO"
        Call SUP_CLOB([F:MFO]MFOTEX,WRET) From TRTX3TEX
    Endif
# Maj du fichier WORKSTATIO
    If find([F:MFO]MFGSTA,1,2)
        Readlock [MWS]WST0 = [F:MFO]EXTWST;[F:MFO]MFGFCY
        If fstat=1 : GOK=-1 : GLOCK="$"+"WORKSTATIO"-[F:MFO]EXTWST : Break
        Elsif !fstat
# llc 03.01 multi-exemplaire
#           WEXTHOU = [F:MFO]EXTOPETIM * [F:MFO]EXTWSTNBR        # llc 12.00 6966
            WEXTHOU = [F:MFO]EXTOPETIM
            If [F:MFO]TIMUOMCOD = 2 : WEXTHOU = WEXTHOU / 60 : Endif
            [F:MWS]EXTHOUTIM -= func TRTX3.ARRTYP("", "", "TIH", WEXTHOU)
            Rewrite [MWS]
        Endif
    Endif
    Delete [MFO]
    #----- Suppression des sections de la ligne operation  pour les deux postes -----#
#    Delete [CAL] Where ABRFIC="MFO" & VCRNUM=[F:MFO]MFGNUM & VCRLIN=[F:MFO]OPENUM &
#&                VCRSEQ = [F:MFO]OPESPLNUM
    # Issue 119469 GH 04/11/16 - performance enhancement
    Delete [CAL] Where ABRFIC="MFO" & VCRNUM=[F:MFO]MFGNUM & VCRLIN=[F:MFO]OPENUM
&                    & VCRSEQ=[F:MFO]OPESPLNUM & VCRTYP=0
    If fstat=1
       GOK=-1 : GLOCK="$CPTANALIN MFO 0"-[F:MFO]MFGNUM-num$([F:MFO]OPENUM)-num$([F:MFO]OPESPLNUM)
       Break # FQ 69909 Ctrl des sources avant Return
    Endif
    #----- Mise à jour statistiques opération -----#
    Call VALSTA("MFO",-1) From SUBPS2 : If GOK<1 : Break : Endif
Next
If GOK<1 : Return : Endif

# annulation jalonnements
#For [SCH]SCH0 Where MFGNUM=[F:MFG]MFGNUM With Lock
#    Delete [SCH]
#Next
# Issue 119469 GH 04/11/16 - performance enhancement
Delete [SCH] Where MFGNUM=[F:MFG]MFGNUM
If fstat=1
   GOK=-1 : GLOCK="$SCHEDULING"-[F:MFG]MFGNUM : Return
Endif

Return

###########################################################################
## Annulation des lignes
#########################################################################
# purge des opérations
Subprog DEL_JAL
#
Readlock [SCH]SCH0=[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
If fstat=1 : GOK=-1 : GLOCK="$"+"SCHEDULING"-num$([F:MFO]OPENUM) : Endif
If !fstat : Delete [SCH] : Endif
#
End


#########################################################################
#---------------------------------------------------------#
# Ecriture des sections de la ligne operation             #
#---------------------------------------------------------#
Subprog MAJMFO_CPTANALIN(WEXISTE)
Value Integer WEXISTE
# Issue 104346 GA 02/2015 always check existence sending code "M" to ENREG_ACCCE
###If dim(WLABWST)<1 : Local Integer WLABWST : Endif
###If dim(WEXTWST)<1 : Local Integer WEXTWST : Endif
###
#### FQ 60397 GA 11/2009 pb si pas de ligne dans [F:CAL]
###WEXTWST  = 1
###If WEXISTE =0
###    Read [CAL] CAL0="MFO";0;[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM;"EXTWST";1
###    If !fstat  : WEXTWST= 0 : Endif
###Endif
###If WEXTWST = 0
###    # FQ 60397 GA 11/2009  avant If WEXISTE = 0 et il manquait [F:MFO]OPESPLNUM dans les paramètres
###    Call ENREG_ACCCCE(nolign-1,"","","[M:MFG3]CCE","MFO",0,[F:MFO]MFGNUM,[F:MFO]OPENUM,[F:MFO]OPESPLNUM,"EXTWST","M") From TRTX3CPT
###Else
###    Call ENREG_ACCCCE(nolign-1,"","","[M:MFG3]CCE","MFO",0,[F:MFO]MFGNUM,[F:MFO]OPENUM,[F:MFO]OPESPLNUM,"EXTWST","C") From TRTX3CPT
###Endif
###
####
###If [F:MFO]EXTLAB = "" : End : Endif
###
#### Poste secondaire L'enregistrement peut ne pas exister même en modif (si le poste secondaire a été rajouté)
###WLABWST  = 1
###If WEXISTE =0
###    Read [CAL] CAL0="MFO";0;[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM;"EXTLAB";1
###    If !fstat  : WLABWST= 0 : Endif
###Endif
###
###If WLABWST = 0
###    Call ENREG_ACCCCE(nolign-1,"","","[M:MFG3]LABCCE","MFO",0,[F:MFO]MFGNUM,[F:MFO]OPENUM,[F:MFO]OPESPLNUM,"EXTLAB","M") From TRTX3CPT
###Else
###    Call ENREG_ACCCCE(nolign-1,"","","[M:MFG3]LABCCE","MFO",0,[F:MFO]MFGNUM,[F:MFO]OPENUM,[F:MFO]OPESPLNUM,"EXTLAB","C") From TRTX3CPT
###Endif

# Issue 104346 GA 02/2015 always check existence sending code "M" to ENREG_ACCCE
Call ENREG_ACCCCE(nolign-1,"","","[M:MFG3]CCE","MFO",0,[F:MFO]MFGNUM,[F:MFO]OPENUM,[F:MFO]OPESPLNUM,"EXTWST","M") From TRTX3CPT
If [F:MFO]EXTLAB <> ""
    Call ENREG_ACCCCE(nolign-1,"","","[M:MFG3]LABCCE","MFO",0,[F:MFO]MFGNUM,[F:MFO]OPENUM,[F:MFO]OPESPLNUM,"EXTLAB","M") From TRTX3CPT
Endif
End

###########################################################################
## Etiquettes de l'écran
###########################################################################

Subprog C_NBLIG
Local Integer NOL
# pour bug moteur
If clalev ([M:MFG3])>0
    If [M:MFG3]NBLIG > 0
      If [M:MFG3]OPENUM([M:MFG3]NBLIG-1) = 0
        status=65 : nolign=[M:MFG3]NBLIG
        Dela [M:MFG3]NBLIG-1,1,[M:MFG3]NBLIG-1 [M:MFG3]NBLIG : [M:MFG3]NBLIG-=1
      Endif
    Endif
Endif
GMODIF=2    # pour bug moteur

Case status
    When 75:          NOL=nolign-1                    # Modification
                      Gosub TEST_MOD
    When 82:          NOL=nolign-1                    # Reprise
                      GMODIF = 1 # pour bug moteur
                      mkstat=2
Endcase
End

########################################
$TEST_MOD
If instr(1,dbgstr(1),"MFOS")
    If [M:MFOS]SCDCOD(nolign-1) = 8 : mkstat=2 : Return : Endif
Else
    If [M:MFG3]OPESTA(nolign-1) > 4 : mkstat=2 : Return : Endif # si soldée/exclue
Endif
Return

########################################
Subprog IB_NBLIG
If instr(1,dbgstr(1),"MFOS")
#    If !GBROWS : GBOUT1 = mess(225,198,1) : Else : GBOUT1 = "" : Endif
     GBOUT1 = mess(225,198,1)
Else
    GBOUT1 = ""
    GBOUT2 = ""
    GBOUT3 = ""
    GBOUT4 = ""
    GBOUT5 = ""
    GBOUT6 = ""
    GBOUT7 = ""  # Issue 100671 GA 01/2015  Released product situation
    # Issue X3-55362 - 2017-09-15 by JUSYN : Set revision history button when needed
    GBOUT8 = ""
    If dim([M:MFG1]ROUECCMAJ) > 0
        If GMFGREV = 2 & [M:MFG3]EXTWST(nolign-1) <> "" & [M:MFG1]ROUECCMAJ <> "" & GREP <> "C"
            GBOUT8 = mess(174,195,1) # Revision history
        Endif
    Endif
    # End issue X3-55362
    If dim([M:MFG3]EXTWST) < nolign + 1 : mkstat = 2 : End : Endif
    If [M:MFG0]MFGMOD = 2 : End : Endif
    If [M:MFG3]EXTWST(nolign-1) <> ""
        GBOUT1 = mess(99,195,1)
        If [M:MFG3]OPESTA(nolign-1) <> 6
            If [M:MFG3]OPESTA(nolign-1) < 4
                If find([M:MFG1]WORTYP,3,4) : GBOUT2 = mess(182,198,1) : Endif
            Endif
        Else
            If find([M:MFG1]WORTYP,3,4) : GBOUT2 = mess(185,198,1) : Endif
        Endif
        If [M:MFG0]MFGSTA = 1
            If [M:MFG3]WSTTYP(nolign-1) = 3
                GBOUT3 = ""
                GBOUT4 = mess(242,198,1)
            Else
                GBOUT3 = mess(242,198,1)
                GBOUT4 = ""
            Endif
        Endif
        If GCONSLCT = 1 : GBOUT2 = "" : Endif
        # bouton Texte
        GBOUT5 = mess(38,198,1)
        # subcontract order ?
        If GMODU(6) = 2 & GREP = "" & [M:MFG3]WSTTYP(nolign-1) = 3 & [M:MFG0]MFGSTA = 1
          If[M:MFG3]OPESTA(nolign-1) < 4
            GBOUT6 = mess(363,198,1)                    # commander
            If GBUYFLT = 2
                Read [ITF]ITF0=[M:MFG3]SCOITMREF(nolign-1);[M:MFG0]MFGFCY
                If fstat : Raz [ITF] : Endif
                If [F:ITF]BUY <> GUSER & [F:ITF]BUY <> "" : GBOUT6 = "" : Endif            # 01.05 27441
            Endif
          Elsif GVERSION>="1.8.0"     # Issue 100671 GA 01/2015  Released product situation
            GBOUT7 = mess(256,190,1)
            GBOUT4 = ""
          Endif
        Endif
    Else
        If find([M:MFG1]WORTYP,3,4) : GBOUT1 = mess(244,198,1) : Endif
        If [M:MFG3]OPENUM(nolign-1) <> 0
            GBOUT5 = mess(38,198,1)
        Endif
        If GCONSLCT = 1 : GBOUT1 = "" : Endif
        Case [M:MFG0]MFGSTA
            When 4         : GBOUT1 = ""    # clôs
            When Default   : # rien
        Endcase
        Case [M:MFG1]MFGTRKFLG
            When 2,6         : GBOUT1 = ""    # soldé + prf
            When Default   : # rien
        Endcase
    Endif

    # Issue X3-28791 - 2017-09-04 by JUSYN : Moved to this place.
    # Issue X3-6109 - 2017-01-25 by ALSHE : Block changes on the WO-Routing "versioned"
    If dim([M:MFG1]ROUECCMAJ)>0
        If vireblc([M:MFG1]ROUECCMAJ, 2)<>""
            # Issue X3-28791 - 2017-09-04 by JUSYN : if user can make critical changes, then do not disable button for Operation detail
            # Issue X3-6312 - 2017-09-08 by JUSYN : Keep button2 (Exclude/Reactivate) if still available and user has got permissions for critical changes.
            #                                      Keep button1 (Unexpected Operation) for user with permission
            If GBOUT1 <> ""
                If GREP = "C" # No operation detail nor unexpected operations during creation
                    Raz GBOUT1
                Endif

                If !GOPECRICHG & [M:MFG3]EXTWST(nolign-1) = ""
                    Raz GBOUT1
                Endif
            Endif
            If GBOUT2 <> ""
                If !GOPECRICHG | GREP = "C"
                    Raz GBOUT2
                Endif
            Endif
            # Issue X3-6312 - 2017-09-08 by JUSYN - End
        Endif
    Endif

    # si OF à l'étude, pas de modification
    If [M:MFG1]MFGTRKFLG = 2 : GBOUT2 = "" : Endif

    # ISSUE X3-30339 - 2017-04-07 By ALSHE : Release WO managed by PS - hide button "Additional operation not expected"
    # If WO has already been sent to PS not more changes on operations allowed!
    If func AFNC.ACTIV("POPS") & ([M:MFG1]MFGTRKFLG=2 | [M:MFG1]SCDFLG=4)
        GBOUT1 = ""
        GBOUT2 = ""
    Endif

Endif
End

########################################
Subprog B2_NBLIG
Local Shortint L : L = nolign-1
Local Integer  OK
Local Integer  WRET
Local Integer  I,J

# Issue X3-6312 - 2017-09-11 by JUSYN : For Exclude and Reactivate for versioned routings display info message and ask for revision reason.
# Issue X3-55362 - 2017-09-18 by JUSYN : only if activity code "RVM" set; check for routing version
If dim([M:MFG1]ROUECCMAJ) > 0
    If [M:MFG1]ROUECCMAJ<>""
        # Issue X3-55431 - global variable changed
        If !GREVMESSC & GOPECRICHG # No critical message yet
            GREVMESSC = 1
            GERR = 2
            GMESSAGE = mess(401,193,1) # You are about to make critical changes to a work order for a versioned product
        Endif

        If GMFGREV=2 & GOPECRICHG # Critical changes will be written to audit table
            Local Char PARAM(250)(1..20) , SAVACT(10)
            Local Char VALEUR(20)
            PARAM(1)= ""

            If [M:MFG3]ROUOPENUM(L) > 0 & (([M:MFG3]OPESTA(L) < 4) | ([M:MFG3]OPESTA(L) = 6))
                SAVACT = GACTION : GACTION = "MFGREVREA"
                Call SAISIE_CHAR(VALEUR,PARAM,"OMFGR","SUBMFGR","") From GSAISIE
                GACTION = SAVACT
                If (PARAM(1) <> "")
                    [M:MFG3]REVREASON(L) = PARAM(1)
                    Affzo [M:MFG3]REVREASON(L)
                Else
                    mkstat = 2
                    End
                Endif
            Endif
            # Set revision code for critical change.
            If PARAM(1) <> "" & mkstat = 0
                If [M:MFG3]OPESTA(L) <> 6
                    If [M:MFG3]OPESTA(L) < 4
                        [M:MFG3]REVCOD(L) = 3 # = Exclusion
                    Endif
                Else
                    [M:MFG3]REVCOD(L) = 4 # = Reinstate
                Endif
            Endif
        Endif
    Endif
Endif
# End issue X3-55362
# End issue X3-6312
# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif
# exclusion opération - mise à 0 de la quantité prévue + réactivation
If [M:MFG3]OPESTA(L) = 6
    [M:MFG3]OPESTA(L) = 1
    [M:MFG1]DOPENBR += 1
    Call CAL_JAL_SUG(1, [M:MFG3]OPENUM(L)) From MFGSCD
    Call RESEQ_JAL From MFGSCD
    Call MESSAGE(mess(29,190,1)) From GESECRAN
    Affzo [M:MFG3]OPESTA(L)
Else
    # cas opération non prévue
    If [M:MFG3]ROUOPENUM(L) = 0
        # suppression ligne
        Dela L,1 [M:MFG3]NBLIG
        # mise à jour NBLIG et réaffichage
        [M:MFG3]NBLIG    -= 1
        [M:MFG1]DOPENBR  -= 1
        Affzo [M:MFG3]10
    Else
        [M:MFG1]DOPENBR  -= 1
        [M:MFG3]OPESTA(L) = 6
        Affzo [M:MFG3]OPESTA(L)
    Endif
    Call CAL_JAL_SUG(2, [M:MFG3]OPENUM(L)) From MFGSCD
    Call RESEQ_JAL From MFGSCD
    J = 0
    For I = 0 To [M:MFG3]NBLIG-1
        If [M:MFG3]OPESTA(I) <> 6 : J += 1 : Endif
    Next I
    If J > 0
        Call MESSAGE(mess(29,190,1)) From GESECRAN
    Endif
Endif
# pour réinitialiser texte bouton
mkstat = 4

End

########################################
$BB6_NBLIG
Local Integer L : L = nolign-1
If [M:MFG3]REACT = 2
    Call ANALYSE_OPELOC([M:MFG3]OPENUM(L), L, [M:MFG3]EXTWST(L),[M:MFG0]MFGFCY) From MFGLIBO
    # 09.04 24754
    Read [MFG]MFG0=[M:MFG0]MFGNUM
    If fstat : End : Endif
    [M:MFG1]STRDAT = [F:MFG]STRDAT
    [M:MFG1]ENDDAT = [F:MFG]ENDDAT
    Gosub LIENS From SUBMFG2
    Gosub LIENS From SUBMFG3
    Affzo [M:MFG1]10
    Call HIGHLIGHT("MFG2", -1) From ECCLIB : # Affzo [M:MFG2]1-99 : # Issue 119469 GH 04/11/16 - display lines with their style
    Affzo [M:MFG3]10
    mkstat = 99
    [M:MFG3]REACT = 1
Endif
Return

########################################
Subprog AS_OPENUM(VALEUR)
Variable Decimal VALEUR
#
If GMODOPE = 1 : mkstat=2 : Endif
#
End

#########################################################################
Subprog C_OPENUM(VALEUR)
Variable Decimal VALEUR
Local Integer I
#
For I=0 To [M:MFG3]NBLIG-1
    If [M:MFG3]OPENUM(I)=VALEUR : mkstat=2 : GMESSAGE=mess(70,193,1) : Endif
Next I
#
End

########################################
Subprog C_STDOPENUM(VALEUR)
Variable Decimal VALEUR
Local Char WFCY (GLONFCY)
If instr(1,dbgstr(1),"MFO0")
    WFCY = [M:MFO0]MFGFCY
    WFCY = [M:MFG0]MFGFCY
Endif
If VALEUR = 0 : End : Endif
If clalev([ROT])=0 : Local File ROUOPESTD  [ROT] : Endif
If clalev([MWS])=0 : Local File WORKSTATIO [MWS] : Endif

Read [ROT]ROT0=VALEUR;WFCY
If fstat : GMESSAGE = mess(133,193,1)
           mkstat = 1
           End
Endif
End



########################################
Subprog B2_STDOPENUM(VALEUR)
Variable Decimal VALEUR
#
Gosub TRTB2_STDOPENUM
#
End

#########################################################################
$TRTB2_STDOPENUM
Local Integer     OK
Local Decimal     KHM, VOPESTUCOE, WCOEFF
Local Decimal     WMFGEXTQTY
Local Integer     L
#
If clalev([ROT])=0 : Local File ROUOPESTD [ROT] : Endif
If clalev([TCO])=0 : Local File TABCOEFF  [TCO] : Endif
#
If VALEUR <> 0
 OK=1
 Call OUINON(mess(1,190,1),OK) From GESECRAN
 If OK=2
  Read [ROT]ROT0=VALEUR;[M:MFG0]MFGFCY
  If !fstat
    If [F:ROT]OPEUOM=""
        [F:ROT]OPEUOM = [M:MFG1]MFGSTU
        VOPESTUCOE    = 1
    Else
        Read [TCO]TCO0=[M:MFG1]MFGSTU;[F:ROT]OPEUOM
        If !fstat
            VOPESTUCOE=[F:TCO]COEUOM
        Else
            VOPESTUCOE=1
        Endif
    Endif
    # 8594 llc 03.01
    Gosub CONVERSION
    [M:MFO0]            = [F:ROT]
    [M:MFO1]            = [F:ROT]
    [M:MFO2]            = [F:ROT]
    [M:MFO0]MFOTEX      = [F:ROT]OPETEXNUM
    If dim([M:MFG3]OPENUMLEV(I)) > 0 : [M:MFO3] = [F:ROT] : Endif
    [M:MFO1]TIMUOMCOD   = [M:MFO1]XTIMUOMCOD
    [M:MFO0]TIMUOMCOD   = [M:MFO1]XTIMUOMCOD
    [M:MFO1]ROUOPENUM   = 0
    # FGR 21/09/2009 : X3SUIVI57981
    #[M:MFO0]ROODES      = [F:ROT]STDOPEDES
    # FGR 01/10/2009 : X3SUIVI58277 : il y avait GLANGUE comme paramètre en trop
    Call LECTEXTRA([M:MFO0]ROODES,"ROUOPESTD","STDOPEDESAXX",num$([F:ROT]STDOPENUM),[F:ROT]FCY) From ATEXTRA
    [M:MFO1]EXTWST      = [F:ROT]WST
    # 17809 MM 07.05
    [M:MFO1]SETTIMTMP = [F:ROT]SETTIM
    [M:MFO1]OPETIMTMP = [F:ROT]OPETIM
    [M:MFO1]PRPTIMTMP = [F:ROT]PRPTIM
    [M:MFO1]WAITIMTMP = [F:ROT]WAITIM
    [M:MFO1]PSPTIMTMP = [F:ROT]PSPTIM
    # lecture poste pour centre de charge et type
    Read [MWS]WST0=[F:ROT]WST;[F:ROT]FCY
    If ! fstat
        [M:MFO1]WCR             = [F:MWS]WCR
        [M:MFO1]WSTTYP          = [F:MWS]WSTTYP
        [M:MFO1]XWSTTYP         = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
        [M:MFO1]WSTEFF          = [F:MWS]EFF
        # 03.09 mm - libellé traduisible
        Call LECTEXTRA ([M:MFO1]WSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY)From ATEXTRA
    Endif
    # lecture poste pour centre de charge et type
    If [F:ROT]LABWST <> ""
        Read [MWS]WST0=[F:ROT]LABWST;[F:ROT]FCY
        If ! fstat
            [M:MFO1]LABWCR          = [F:MWS]WCR
            [M:MFO1]LABWSTTYP       = [F:MWS]WSTTYP
            [M:MFO1]XLABWSTTYP      = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
            # 03.09 mm - libellé traduisible
            Call LECTEXTRA ([M:MFO1]LABWSTDES ,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY)From ATEXTRA
        Endif
    Endif
    [M:MFO1]EXTLAB      = [F:ROT]LABWST
    [M:MFO1]EXTSETTIM   = [F:ROT]SETTIM
    [M:MFO1]EXTOPETIM   = [F:ROT]OPETIM
    [M:MFO1]EXTWSTNBR   = [F:ROT]WSTNBR
    [M:MFO1]EXTLABNBR   = [F:ROT]LABNBR
    # si sous-traitance, lecture poste correspondant
    If [F:ROT]SCOCOD <> 1
        Read [MWS]WST0=[F:ROT]SCOWST;[F:ROT]FCY
        If !fstat
            [M:MFO2]SCOWCR          = [F:MWS]WCR
            [M:MFO2]SCOWSTTYP       = [F:MWS]WSTTYP
            [M:MFO2]XSCOWSTTYP      = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
            # 03.09 mm - libellé traduisible
            Call LECTEXTRA ([M:MFO2]SCOWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY)From ATEXTRA
        Endif
    Endif
    [M:MFO1]OPESTUCOE = VOPESTUCOE
    [M:MFO2]SCOITMREF = [F:ROT]SCOITMREF
    # FQ 74274 GA 10/2011
    Call COMPLETE_OPEUOM([M:MFG1]ROUNUM,[M:MFO2]SCOITMREF,[M:MFO2]BPRNUM,[M:MFO1]SCOLTI
&                       ,[M:MFO1]OPEUOM,[M:MFO2]OPESTRCOE,[M:MFO1]SCOPUU) From MFGLIBO

    WMFGEXTQTY    = [M:MFG1]MFGEXTQTY
    Call CAL_ROT_TIME("MFO1", WMFGEXTQTY, L, [M:MFG1]NBLIG, [M:MFG1]LTIREDCOE,1) From MFGLIBO  # 17809 MM 07.05

    # point d'entrée pour intervenir sur les données récupérées
    GPOINT = "STD_OPE_MOD"
    Gosub  ENTREE From EXEFNC

    Affzo [MFO0]1-99
    Affzo [MFO1]1-99
    Affzo [MFO2]1-99
    If dim([M:MFG3]OPENUMLEV(I)) > 0 : Affzo [MFO3]1-99 : Endif
   Endif
   If [M:MFO2]SCOCOD = 1 : Grizo [M:MFO2]30 : Else : Actzo [M:MFO2]30 : Endif
  Endif
Endif
Return

#########################################################################
# 8594 llc 03.01
$CONVERSION
#
If [F:ROT]TIMUOMCOD = [M:MFO1]XTIMUOMCOD : Return : Endif
KHM=1
If [M:MFO1]XTIMUOMCOD = 1 & [F:ROT]TIMUOMCOD = 2
        KHM=1/60
Else
        KHM=60
Endif
[F:ROT]SETTIM = KHM * [F:ROT]SETTIM
Case [F:ROT]ROOTIMCOD
    When 1: [F:ROT]OPETIM = KHM * [F:ROT]OPETIM
            [F:ROT]OPETIM = func TRTX3.ARRTYP("", "", "TIH", [F:ROT]OPETIM)
    When 2: [F:ROT]CAD    = [F:ROT]CAD / KHM
    When 3: [F:ROT]OPETIM = KHM * [F:ROT]OPETIM
            [F:ROT]OPETIM = func TRTX3.ARRTYP("", "", "TIH", [F:ROT]OPETIM)
Endcase
[F:ROT]GRPSETTIM = KHM * [F:ROT]GRPSETTIM

[F:ROT]SETTIM        = func TRTX3.ARRTYP("", "", "TIH", [F:ROT]SETTIM   )            # llc 03.01 8355
[F:ROT]OPETIM        = func TRTX3.ARRTYP("", "", "TIH", [F:ROT]OPETIM   )            # llc 03.01 8355
[F:ROT]CAD           = arr([F:ROT]CAD      , 0.0001)            # llc 03.01 8355
[F:ROT]GRPSETTIM     = func TRTX3.ARRTYP("", "", "TIH", [F:ROT]OPETIM   )            # llc 03.01 8355

Return

########################################
Subprog AS_STDOPENUM(VALEUR)
Variable Decimal VALEUR
#
GBOUT1=mess(247,198,1)
GBOUT2=mess(100,198,1)
GBOUT3=""
#
End

########################################
Subprog AM_STDOPENUM(VALEUR)
Variable Decimal VALEUR
#
Gosub TRTB2_STDOPENUM
OMODIF = 1
#
# 17809 MM 07.05: gestion d'un coef multiplicateur des temps liés à une opération standard
If VALEUR<>0
    [M:MFO1]CTIMCOE = 1 : [M:MFO1]HCTIMCOE = 1
    Affzo [M:MFO1]CTIMCOE,HCTIMCOE
    Actzo [M:MFO1]CTIMCOE,HCTIMCOE
Endif
End

########################################################
Subprog AV_EXTWST(VALEUR)
Variable Char     VALEUR
Local Char WFCY (GLONFCY)
If instr(1,dbgstr(1),"MFO1")
    WFCY = [M:MFO0]MFGFCY
Else
    WFCY = [M:MFG0]MFGFCY
Endif
# affichage des zones liées au poste de charge principal
If VALEUR <> ""
        Read [MWS]WST0=VALEUR;WFCY
        If !fstat
            [M:MFO1]WCR=[F:MWS]WCR
            [M:MFO1]WSTTYP=[F:MWS]WSTTYP
            [M:MFO1]XWSTTYP=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
            # 03.09 mm - libellé traduisible
            Call LECTEXTRA ([M:MFO1]WSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY)From ATEXTRA
            Affzo [MFO1]WCR, XWSTTYP, WSTDES
        Endif
Else
            [M:MFO1]WCR=""
            [M:MFO1]WSTDES=""
            [M:MFO1]XWSTTYP=""
            Affzo [MFO1]WCR, XWSTTYP, WSTDES
Endif
#
End

###########################################
Subprog AS_EXTWST(VALEUR)
Variable Char     VALEUR
Local    Char WFCY (GLONFCY)

# 03.05 29322
If instr(1,dbgstr(1),"MFO1")
    WFCY = [M:MFO0]MFGFCY
Else
    WFCY = [M:MFG0]MFGFCY
Endif
# bouton  remplacement
GBOUT3 = ""
GBOUT2 = ""
If !find([M:MFG1]WORTYP,3,4) : mkstat=2 : End : Endif
If VALEUR <>""
    Read [RPW]RPW0 = VALEUR;WFCY
    If !fstat
        If [F:RPW]RPLWST(0)<>""
             GBOUT3=mess(436,198,1)
        Endif
    Endif
Endif

# bouton sous-traiter
If instr(1,dbgstr(1),"MFO1")
    GBOUT2 = ""
Else
    Case [M:MFG3]SCOCOD(nolign-1)
        When 1,2:    GBOUT2 = ""
        When 3:      If find([M:MFG3]WSTTYP(nolign-1),1,2)
                         GBOUT2 = mess(239,198,1)
                     Else
                         If [M:MFG3]ROUOPENUM(nolign-1) <> 0
                             GBOUT2 = mess(348,198,1)
                         Endif
                     Endif
    Endcase
Endif
End

########################################
Subprog B2_EXTWST(VALEUR)
Variable Char    VALEUR()
Local    Integer L : L = nolign-1
Local    Integer WRET
Local    Char    WWST (GLONWST)
#
# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif
WWST = VALEUR
Case [M:MFG3]WSTTYP(L)
    When 1,2: Call  SUB_CONTRACT("MFG",L, WWST) From MFGLIBO
    When 3:   Call ASUB_CONTRACT("MFG",L, WWST) From MFGLIBO
Endcase
mkstat = 4
VALEUR = WWST

# y a t-il une matière associée à cette opération ?
Call ANALYSE_OPELOC([M:MFG3]OPENUM(L), L, VALEUR,[M:MFG0]MFGFCY) From MFGLIBO
Call ANALYSE_OPESTR("MFG3", [M:MFG3]OPENUM(L), L, VALEUR,[M:MFG0]MFGFCY) From MFGLIBO # llc 07.01 9728

#
End

###########################################
Subprog C_EXTWST(VALEUR)
Variable Char     VALEUR
Local Char WFCY (GLONFCY)

WFCY = [M:MFG0]MFGFCY
# contrôle existence
If VALEUR <> ""
        Read [MWS]WST0=VALEUR;WFCY
        If fstat
           GMESSAGE=VALEUR+"\"+mess(23,100,1) : mkstat=2
        Else
            If [F:MWS]WCRFCY <> WFCY
               GMESSAGE = mess(116,193,1) - WFCY
               mkstat = 1
               End
            Endif
            If instr(1,dbgstr(1),"MFO1")
                If [M:MFO2]SCOCOD = 3 & [M:MFO1]WSTTYP <> 3 & [F:MWS]WSTTYP = 3
                    mkstat = 2
                    GMESSAGE = mess(163,193,1)
                Endif
            Else
                If [M:MFG3]SCOCOD(nolign-1) = 3 & [M:MFG3]WSTTYP(nolign-1) <> 3 & [F:MWS]WSTTYP = 3
                    mkstat = 2
                    GMESSAGE = mess(163,193,1)
                Endif
            Endif

        Endif
Endif
#
End

###########################################################
Subprog AM_EXTWST(VALEUR)
Variable Char     VALEUR
Local Integer I : I = nolign-1
Local Integer WRET
Local Char WFCY (GLONFCY)

If instr(1,dbgstr(1),"MFO1")
    WFCY = [M:MFO0]MFGFCY
Else
    WFCY = [M:MFG0]MFGFCY
Endif
# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif
#
If VALEUR <> ""
        Read [MWS]WST0=VALEUR;WFCY
        If !fstat
            If instr(1,dbgstr(1),"MFO1")
                [M:MFO1]WCR=[F:MWS]WCR
                [M:MFO1]WSTTYP=[F:MWS]WSTTYP
                # 03.09 mm - libellé traduisible
                Call LECTEXTRA ([M:MFO1]WSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY)From ATEXTRA
                [M:MFO1]EXTWSTNBR=[F:MWS]WSTNBR
                [M:MFO1]XWSTTYP=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
                Case GWSTEFFINH
                    When 1:       Call UPD_OPE_UNI(14, "MFO1", 0, [M:MFO1]EFF) From MFGLIBO
                                  [M:MFO1]WSTEFF=[F:MWS]EFF
                                  Call UPD_OPE_UNI(1,  "MFO1", 0, [M:MFO1]WSTEFF) From MFGLIBO
                                  OMODIF = 1
                    When 2:       Call UPD_OPE_UNI(14, "MFO1", 0, [M:MFO1]EFF) From MFGLIBO
                                  [M:MFO1]EFF = [F:MWS]EFF
                                  Call UPD_OPE_UNI(6,  "MFO1", 0, [M:MFO1]EFF) From MFGLIBO
                Endcase
                [M:MFO1]WSTEFF=[F:MWS]EFF
                Affzo [MFO1]WCR, XWSTTYP, WSTDES, EFF, EXTWSTNBR

                # annulation et recalcul avec perte
                Call UPD_OPE_UNI(15, "MFO1", 0, [M:MFO1]SHR) From MFGLIBO
                # 43552 mm 03.08 : Point d'entrée permettant d'ignorer la perte opératoire
                GPE =0
                GPOINT = "WITHSHR" : Gosub ENTREE From EXEFNC
                If !GPE
                    [M:MFO1]SHR=[F:MWS]SHR
                Endif

                Call UPD_OPE_UNI(16,  "MFO1", 0, [M:MFO1]SHR) From MFGLIBO
                Affzo [M:MFO1]SHR
                If [F:MWS]WSTTYP=3
                    If [M:MFO2]SCOCOD = 1
                        [M:MFO2]SCOCOD=2
                    Else
                        [M:MFO2]SCOCOD=3        # llc 01.01 5979
                    Endif
                    [M:MFO2]SCOWST=VALEUR
                    [M:MFO1]LABWCR=""
                    [M:MFO1]EXTLAB=""
                    [M:MFO1]LABWSTTYP=0
                    [M:MFO1]LABWSTDES=""
                    [M:MFO1]EXTLABNBR=0
                    [M:MFO1]XLABWSTTYP=""
                    [M:MFO1]SETLABCOE=0
                    [M:MFO1]OPELABCOE=0
                    Affzo [M:MFO2]25
                    Affzo [M:MFO1]LABWCR, XLABWSTTYP, EXTLAB, LABWSTDES, EXTLABNBR, SETLABCOE, OPELABCOE
                    # Issue 85878 - 2012-11-23 by CCC : récupération de OPESTRCOE
                    Call COMPLETE_OPEUOM([M:MFG1]ROUNUM,[M:MFO2]SCOITMREF,[M:MFO2]BPRNUM,[M:MFO1]SCOLTI
&                                       ,[M:MFO1]OPEUOM,[M:MFO2]OPESTRCOE,[M:MFO1]SCOPUU) From MFGLIBO

                Endif
                If [F:MWS]WSTTYP <> 3 & [M:MFO2]SCOCOD=2 : [M:MFO2]SCOCOD=3 : Endif
            Else
                [M:MFG3]WCR(I)=[F:MWS]WCR
                Call LECTEXTRA([M:MFG3]EXTWSTSHO(I),"WORKSTATIO","WSTSHOAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
                [M:MFG3]WSTTYP(I)=[F:MWS]WSTTYP
                [M:MFG3]EXTWSTNBR(I)=[F:MWS]WSTNBR
                [M:MFG3]XWSTTYP(I)=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
                Case GWSTEFFINH
                    When 1:        Call UPD_OPE_UNI(14, "MFG3", I, [M:MFG3]EFF(I)) From MFGLIBO
                                   [M:MFG3]WSTEFF(I) = [F:MWS]EFF
                                   Call UPD_OPE_UNI(1, "MFG3", I, [M:MFG3]WSTEFF(I)) From MFGLIBO
                    When Default:  Call UPD_OPE_UNI(14, "MFG3", I, [M:MFG3]EFF(I)) From MFGLIBO
                                   [M:MFG3]EFF(I) = [F:MWS]EFF
                                   Call UPD_OPE_UNI(6,  "MFG3", I, [M:MFG3]EFF(I)) From MFGLIBO
                Endcase
                [M:MFG3]WSTEFF(I)=[F:MWS]EFF
                Affzo [MFG3]WCR(I), XWSTTYP(I), EFF(I), EXTWSTNBR(I)
                # annulation et recalcul avec perte
                Call UPD_OPE_UNI(15, "MFG3", I, [M:MFG3]SHR(I)) From MFGLIBO        # llc 04.02 14041
                # 43552 mm 03.08 : Point d'entrée permettant d'ignorer la perte opératoire
                GPE =0
                GPOINT = "WITHSHR" : Gosub ENTREE From EXEFNC
                If !GPE
                    [M:MFG3]SHR(I)=[F:MWS]SHR
                Endif

                Call UPD_OPE_UNI(16, "MFG3", I, [M:MFG3]SHR(I)) From MFGLIBO        # llc 04.02 14041
                If [F:MWS]WSTTYP=3
                    If [M:MFG3]SCOCOD(I) = 1
                        [M:MFG3]SCOCOD(I)=2
                    Else
                        [M:MFG3]SCOCOD(I)=3        # llc 01.01 5979
                    Endif
                    [M:MFG3]SCOWST(I)=VALEUR
                    [M:MFG3]EXTLAB(I)=""
                    [M:MFG3]EXTLABNBR(I)=0
                    [M:MFG3]SETLABCOE(I)=0
                    [M:MFG3]OPELABCOE(I)=0
                    Affzo [M:MFG3]EXTLAB(I)
                    # Issue 85878 - 2012-11-23 by CCC : récupération de OPESTRCOE
                    Call COMPLETE_OPEUOM([M:MFG1]ROUNUM,[M:MFG3]SCOITMREF(I),[M:MFG3]BPRNUM(I),[M:MFG3]SCOLTI(I)
&                                       ,[M:MFG3]OPEUOM(I),[M:MFG3]OPESTRCOE(I),[M:MFG3]SCOPUU(I)) From MFGLIBO

                Endif
                If [F:MWS]WSTTYP <> 3 & [M:MFG3]SCOCOD(I) = 2
                    [M:MFG3]SCOCOD(I) = 3
                Endif
                Call ANALYSE_OPELOC([M:MFG3]OPENUM(I), I, VALEUR,WFCY) From MFGLIBO
                # llc 07.01 9728 (sous-traitance)
                Call ANALYSE_OPESTR("MFG3",[M:MFG3]OPENUM(I), I, VALEUR,WFCY) From MFGLIBO
            Endif
        Endif
        OMODIF = 1
Else
    If instr(1,dbgstr(1),"MFO1")
         [M:MFO1]WCR=""
         [M:MFO1]WSTTYP=0
         [M:MFO1]WSTDES=""
         [M:MFO1]EXTWSTNBR=0
         [M:MFO1]XWSTTYP=""
         Affzo [MFO1]WCR, XWSTTYP, WSTDES, EXTWSTNBR
    Else
        [M:MFG3]WCR(I)=""
        [M:MFG3]EXTWSTSHO(I) = ""
        [M:MFG3]WSTTYP(I)=0
        [M:MFG3]XWSTTYP(I)=""
        [M:MFG3]EXTWSTNBR(I)=0
        Affzo [MFG3]WCR(I), XWSTTYP(I), EXTWSTNBR(I)
    Endif
Endif
If instr(1,dbgstr(1),"MFO1")
    If [M:MFO2]SCOCOD = 1 : Grizo [M:MFO2]30 : Else : Actzo [M:MFO2]30 : Endif
Endif

# Issue X3-28791 - if critical field changed, set
# Issue X3-55362 - 2017-09-18 by JUSYN : only if activity code "RVM" set; check for routing version
If dim([M:MFG1]ROUECCMAJ) > 0
    If instr(1,dbgstr(1),"MFG3")
	    # Issue X3-55431 - display info message once if critical field changed
	    If GOPECRICHG=1 & [M:MFG1]ROUECCMAJ<>"" & VALEUR <> [M:MFG3]EXTWST(I)
	      If GMFGREV=2
	        [M:MFG3]REVCOD(I) = 2 # = Modify
	      Endif
	      If !GREVMESSC # No critical message yet
	        GREVMESSC = 1
	        GERR = 2
	        GMESSAGE = mess(411,193,1)
	      Endif
	    Endif
      # End issue X3-55431
    Endif
Endif
# End issue X3-55362
# End issue X3-28791
End

##############################################
Subprog AP_EXTWST(VALEUR)
Variable Char     VALEUR
Local Char WFCY (GLONFCY)
If instr(1,dbgstr(1),"MFO1")
    WFCY = [M:MFO0]MFGFCY
    WFCY = [M:MFG0]MFGFCY
Endif
# affichage du centre choisi en retour de la consultation des postes
If VALEUR <> ""
   Read [MWS]WST0=VALEUR;WFCY
   If !fstat
       If instr(1,dbgstr(1),"MFO1")
           [M:MFO1]WCR=[F:MWS]WCR
           Affzo [MFO1]WCR
       Else
           [M:MFG3]WCR(nolign-1)=[F:MWS]WCR
           Affzo [MFG3]WCR(nolign-1)
       Endif
   Endif
Endif
End

#########################################################################
Subprog AV_EXTLAB(VALEUR)
Variable Char     VALEUR
Local    Integer  L : L = nolign-1
Local Char WFCY (GLONFCY)
If instr(1,dbgstr(1),"MFO1")
    WFCY = [M:MFO0]MFGFCY
Else
    WFCY = [M:MFG0]MFGFCY
Endif
If instr(1,dbgstr(1),"MFO1")
    If [M:MFO1]WSTTYP=3
        VALEUR = ""
        [M:MFO1]LABWCR     = ""
        [M:MFO1]LABWSTTYP  = 0
        [M:MFO1]LABWSTDES  = ""
        [M:MFO1]XLABWSTTYP = ""
        Affzo [MFO1]LABWCR, XLABWSTTYP, LABWSTDES
    Endif
    If VALEUR <> ""
        Read [MWS]WST0=VALEUR;WFCY
        If !fstat
            [M:MFO1]LABWCR     = [F:MWS]WCR
            [M:MFO1]LABWSTTYP  = [F:MWS]WSTTYP
            # 03.09 mm - libellé traduisible
            Call LECTEXTRA ([M:MFO1]LABWSTDES ,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY)From ATEXTRA
            [M:MFO1]XLABWSTTYP = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
            Affzo [MFO1]LABWCR, XLABWSTTYP, LABWSTDES
        Endif
    Else
       [M:MFO1]LABWCR     = ""
       [M:MFO1]LABWSTDES  = ""
       [M:MFO1]XLABWSTTYP = ""
       [M:MFO1]EXTLABNBR  = 0
       Affzo [MFO1]LABWCR, XLABWSTTYP, LABWSTDES, EXTLABNBR
    Endif
Endif
End

#####################################
Subprog AS_EXTLAB(VALEUR)
Variable Char     VALEUR

Local Char WFCY (GLONFCY)
If instr(1,dbgstr(1),"MFO1")
    WFCY = [M:MFO0]MFGFCY
Else
    WFCY = [M:MFG0]MFGFCY
Endif
GBOUT2 = ""
If !find([M:MFG1]WORTYP,3,4) : mkstat=2 : Endif
If VALEUR <>""
    Read [RPW]RPW0 = VALEUR;WFCY
    If fstat              : End : Endif
    If [F:RPW]RPLWST(0) = "" : End : Endif
    GBOUT2=mess(436,198,1)  # bouton  remplacement
Endif

End

##########################################
Subprog C_EXTLAB(VALEUR)
Variable Char     VALEUR
Local    Char     LWST(GLONWST)
#
Local Char WFCY (GLONFCY)
If instr(1,dbgstr(1),"MFO1")
    WFCY = [M:MFO0]MFGFCY
Else
    WFCY = [M:MFG0]MFGFCY
Endif
If instr(1,dbgstr(1),"MFO1")
    LWST = [M:MFO1]EXTWST
Else
    LWST = [M:MFG3]EXTWST(nolign-1)
Endif

# contrôle existence et poste de type main-d'oeuvre
If VALEUR <> ""
   If VALEUR = LWST : GMESSAGE=mess(26,193,1) : mkstat=2 : End : Endif
   Read [MWS]WST0=VALEUR;WFCY
   If fstat
      GMESSAGE= VALEUR+"\"+mess(23,100,1)
      mkstat=2
      End
   Else
      If [F:MWS]WSTTYP <> 2
         GMESSAGE=VALEUR - mess(4,193,1) : mkstat=2 : End
      Endif
      If [F:MWS]WCRFCY <> WFCY
         GMESSAGE = mess(116,193,1) - WFCY
         mkstat = 1
         End
      Endif
   Endif
Endif
#
End

#########################################################################
Subprog AM_EXTLAB(VALEUR)
Variable Char     VALEUR
Local    Integer  L : L = nolign-1
Local    Integer  WRET
#
Local Char WFCY (GLONFCY)
If instr(1,dbgstr(1),"MFO1")
    WFCY = [M:MFO0]MFGFCY
Else
    WFCY = [M:MFG0]MFGFCY
Endif
# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif

If instr(1,dbgstr(1),"MFO1")
    If VALEUR <> ""
        Read [MWS]WST0=VALEUR;WFCY
        If !fstat
            [M:MFO1]LABWCR     = [F:MWS]WCR
            [M:MFO1]LABWSTTYP  = [F:MWS]WSTTYP
            # 03.09 mm - libellé traduisible
            Call LECTEXTRA ([M:MFO1]LABWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY)From ATEXTRA
            [M:MFO1]EXTLABNBR  = [F:MWS]WSTNBR
            [M:MFO1]XLABWSTTYP = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
            Affzo [MFO1]LABWCR, XLABWSTTYP, LABWSTDES, EXTLABNBR
        Endif
        If [M:MFO1]SETLABCOE = 0 : [M:MFO1]SETLABCOE = 1 : Endif
        If [M:MFO1]OPELABCOE = 0 : [M:MFO1]OPELABCOE = 1 : Endif
        OMODIF = 1
    Else
        [M:MFO1]LABWCR=""
        [M:MFO1]LABWSTTYP=0
        [M:MFO1]LABWSTDES=""
        [M:MFO1]XLABWSTTYP=""
        [M:MFO1]EXTLABNBR=0
        Affzo [MFO1]LABWCR, XLABWSTTYP, LABWSTDES, EXTLABNBR
        OMODIF = 1
    Endif
    # Issue 94895 - 2014-11-13 by CCC
    Call UPDCOE([M:MFO0]MFGFCY,[M:MFO1]EXTLAB, VALEUR, [M:MFO1]SETLABCOE, [M:MFO1]OPELABCOE) From MFGLIBO
    Affzo [M:MFO1]SETLABCOE, OPELABCOE
Else
    If VALEUR <> ""
        Read [MWS]WST0=VALEUR;WFCY
        If !fstat
            [M:MFG3]LABWCR(L)     = [F:MWS]WCR
            Call LECTEXTRA([M:MFG3]EXTLABSHO(L),"WORKSTATIO","WSTSHOAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
            [M:MFG3]EXTLABNBR(L)  = [F:MWS]WSTNBR
            Affzo [MFG3]LABWCR(L), EXTLABSHO(L), EXTLABNBR(L)
        Endif
        If [M:MFG3]SETLABCOE(L) = 0 : [M:MFG3]SETLABCOE(L) = 1 : Endif
        If [M:MFG3]OPELABCOE(L) = 0 : [M:MFG3]OPELABCOE(L) = 1 : Endif
        OMODIF = 1
    Else
        [M:MFG3]LABWCR(L)=""
        [M:MFG3]EXTLABSHO(L)=""
        [M:MFG3]EXTLABNBR(L)=0
        Affzo [MFG3]LABWCR(L), EXTLABSHO(L), EXTLABNBR(L)
        OMODIF = 1
    Endif
    # Issue 94895 - 2014-11-13 by CCC
    Call UPDCOE([M:MFG0]MFGFCY,[M:MFG3]EXTLAB(L), VALEUR, [M:MFG3]SETLABCOE(L), [M:MFG3]OPELABCOE(L)) From MFGLIBO
    Affzo [M:MFG3]SETLABCOE(L), OPELABCOE(L)
Endif

# Issue X3-28791 - if critical field changed, set REVCOD
# Issue X3-55362 - 2017-09-18 by JUSYN : only if activity code "RVM" set; check for routing version
If dim([M:MFG1]ROUECCMAJ) > 0
    If instr(1,dbgstr(1),"MFG3")
      # Issue X3-55431 - display info message once if critical field changed
      If GOPECRICHG=1 & [M:MFG1]ROUECCMAJ<>"" & VALEUR <> [M:MFG3]EXTLAB(L)
        If GMFGREV=2
          [M:MFG3]REVCOD(L) = 2 # = Modify
        Endif
        If !GREVMESSC # No critical message yet
          GREVMESSC = 1
          GERR = 2
          GMESSAGE = mess(411,193,1)
        Endif
      Endif
    # End issue X3-55431
    Endif
Endif
# End issue X3-55362
# End issue X3-28791

End

###################################
Subprog AP_EXTLAB(VALEUR)
Variable Char     VALEUR
Local    Integer  L : L = nolign-1
Local Char WFCY (GLONFCY)
If instr(1,dbgstr(1),"MFO1")
    WFCY = [M:MFO0]MFGFCY
Else
    WFCY = [M:MFG0]MFGFCY
Endif
# affichage du centre choisi en retour de la consultation des postes
If instr(1,dbgstr(1),"MFO1")
    If VALEUR <> ""
        Read [MWS]WST0=VALEUR;WFCY
        If !fstat
            [M:MFO1]LABWCR = [F:MWS]WCR
            Affzo [MFO1]LABWCR
        Endif
    Else
        [M:MFO1]SETLABCOE = 0
        [M:MFO1]OPELABCOE = 0
        Affzo [MFO1]SETLABCOE, OPELABCOE
    Endif
Else
    If VALEUR <> ""
        Read [MWS]WST0=VALEUR;WFCY
        If !fstat
            [M:MFG3]LABWCR(L) = [F:MWS]WCR
            Affzo [MFG3]LABWCR(L)
        Endif
    Else
       [M:MFG3]SETLABCOE(L) = 0
       [M:MFG3]OPELABCOE(L) = 0
    Endif
Endif

End

########################################
Subprog AV_ROOTIMCOD(VALEUR)
Variable Integer VALEUR

If VALEUR <> 0
   If VALEUR = 2
      Affzo [MFO1]EXTOPETIM, TIMUOM2
   Else
      [M:MFO1]CAD      = 0
      [M:MFO1]X        = ""
      [M:MFO1]TIMUOM3  = ""
      Affzo [MFO1]CAD, X, TIMUOM3
   Endif
   If VALEUR <> 1
       [M:MFO1]TIMCOD=0
       [M:MFO1]BASQTY=0
       Affzo [MFO1]TIMCOD, BASQTY
   Endif
Endif
#
End

########################################
Subprog AM_ROOTIMCOD(VALEUR)
Variable Integer VALEUR
#
If VALEUR <> 0
   If VALEUR = 2
      [M:MFO1]EXTOPETIM=0
      Affzo [MFO1]EXTOPETIM, TIMUOM2
   Else
      [M:MFO1]CAD=0 : [M:MFO1]X="" : [M:MFO1]TIMUOM3=""
      Affzo [MFO1]CAD, X, TIMUOM3
   Endif
   If VALEUR<>1 : [M:MFO1]TIMCOD=0 : [M:MFO1]BASQTY=0 : Affzo [MFO1]TIMCOD, BASQTY : Endif
   If VALEUR=1  : [M:MFO1]TIMCOD=1 : [M:MFO1]BASQTY=1 : Affzo [MFO1]TIMCOD, BASQTY : Endif
   OMODIF = 1
Endif
#
End

#########################################################################
Subprog AS_EXTSETTIM(VALEUR)
Variable Decimal VALEUR
#
If [M:MFO0]TIMUOMCOD = 1
    [M:MFO1]TIMUOM1   = mess(30,197,1)
Else
    [M:MFO1]TIMUOM1   = mess(32,197,1)
Endif
Affzo [MFO1]TIMUOM1
#
End

#########################################################################
Subprog AM_EXTSETTIM(VALEUR)
Variable Decimal VALEUR
Local    Integer L : L = nolign-1
Local    Integer WRET

# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif

If instr(1,dbgstr(1),"MFO1")
    Call UPD_OPE_UNI(3, "MFO1", 0, VALEUR) From MFGLIBO
    If [M:MFO0]TIMUOMCOD = 1
        [M:MFO1]TIMUOM1   = mess(30,197,1)
    Else
        [M:MFO1]TIMUOM1   = mess(32,197,1)
    Endif
    Affzo [MFO1]TIMUOM1
    OMODIF = 1
Else
    Call UPD_OPE_UNI(3, "MFG3", L, VALEUR) From MFGLIBO
Endif

# Issue X3-28791 - if critical field changed, set REVCOD
# Issue X3-55362 - 2017-09-18 by JUSYN : only if activity code "RVM" set; check for routing version
If dim([M:MFG1]ROUECCMAJ) > 0
    If instr(1,dbgstr(1),"MFG3")
      # Issue X3-55431 - display info message once if critical field changed
      If GOPECRICHG=1 & [M:MFG1]ROUECCMAJ<>"" & VALEUR <> [M:MFG3]EXTSETTIM(L)
        If GMFGREV=2
          [M:MFG3]REVCOD(L) = 2 # = Modify
        Endif
        If !GREVMESSC # No critical message yet
          GREVMESSC = 1
          GERR = 2
          GMESSAGE = mess(411,193,1)
        Endif
      Endif
      # End issue X3-55431
    Endif
Endif
# End issue X3-55362
# End issue X3-28791

End

########################################
Subprog AV_TIMUOM1(VALEUR)
Variable Char    VALEUR()
#
If [M:MFO0]TIMUOMCOD = 1
   VALEUR = mess(30,197,1)
Else
   VALEUR = mess(32,197,1)
Endif
#
End


########################################
Subprog AS_TIMCOD(VALEUR)
Variable Integer VALEUR
#
Case VALEUR
    When 1 : [M:MFO1]BASQTY = 1
    When 2 : [M:MFO1]BASQTY = 100
    When 3 : [M:MFO1]BASQTY = 1000
    When 4 : # 98901 mm 06.2014
             If ![M:MFO1]BASQTY
               Read [TRO]TRO0=[M:MFG1]ROUALT : # 45042 mm 01.08
               If !fstat & [F:TRO]FCY <> ""
                   Read [ITF]ITF0=[M:MFG1]ROUNUM;[F:TRO]FCY
                   If !fstat
                       [M:MFO1]BASQTY = [F:ITF]MFGLOTQTY
                   Endif
               Else
                   [M:MFO1]BASQTY=0
               Endif
             Endif
    When Default : [M:MFO1]BASQTY=0
Endcase
Affzo [MFO1]BASQTY
#
End

########################################
Subprog AM_TIMCOD(VALEUR)
Variable Integer VALEUR
#
If VALEUR <> 0 : Call MESSAGE(mess(23,193,1)) From GESECRAN : Endif
Case VALEUR
   When 1 : [M:MFO1]BASQTY = 1
   When 2 : [M:MFO1]BASQTY = 100
   When 3 : [M:MFO1]BASQTY = 1000
   When 4 : Read [TRO]TRO0=[M:MFG1]ROUALT
            If !fstat & [F:TRO]FCY <> ""
                Read [ITF]ITF0=[M:MFG1]ROUNUM;[F:TRO]FCY
                If !fstat
                    [M:MFO1]BASQTY = [F:ITF]MFGLOTQTY
                Endif
            Else
                [M:MFO1]BASQTY=0
            Endif
   When Default : [M:MFO1]BASQTY=0
Endcase
Affzo [MFO1]BASQTY
OMODIF = 1
#
End

########################################
Subprog D_BASQTY(VALEUR)
Variable Decimal VALEUR
#
Case [M:MFO1]TIMCOD
    When 1 : VALEUR = 1
    When 2 : VALEUR = 100
    When 3 : VALEUR = 1000
    When 4 : Read [TRO]TRO0=[M:MFG1]ROUALT
             If !fstat & [F:TRO]FCY <> ""
                 Read [ITF]ITF0=[M:MFG1]ROUNUM;[F:TRO]FCY
                 If !fstat : VALEUR=[F:ITF]MFGLOTQTY : Endif
              Endif
    When Default : VALEUR=0
Endcase
#
End

########################################
Subprog C_EXTQTY(VALEUR)
Variable Decimal VALEUR
Local    Decimal WCPL
# la quantité de l'opération ne peut être inférieure à la quantité déjà suivie
If instr(1,dbgstr(1),"MFO1")
    WCPL = [M:MFO1]CPLQTY
Else
    WCPL = [M:MFG3]CPLQTY(nolign-1)
Endif
If VALEUR < WCPL
    mkstat=2
    Call MESSAGE(mess(68,193,1)) From GESECRAN
    End
Endif
If instr(1,dbgstr(1),"MFO1")
    [M:MFO1]EXTSTUQTY           = VALEUR / [M:MFO1]OPESTUCOE
    Call QTEARR([M:MFO1]EXTSTUQTY,[M:MFG1]MFGSTU) From TRTDIV
    [M:MFO1]EXTSTRQTY           = VALEUR * [M:MFO2]OPESTRCOE
Else
    [M:MFG3]EXTSTUQTY(nolign-1) = VALEUR / [M:MFG3]OPESTUCOE(nolign-1)
    Call QTEARR([M:MFG3]EXTSTUQTY(nolign-1),[M:MFG1]MFGSTU) From TRTDIV
    [M:MFG3]EXTSTRQTY(nolign-1) = VALEUR * [M:MFG3]OPESTRCOE(nolign-1)
Endif

End

########################################
Subprog AM_EXTQTY(VALEUR)
Variable Decimal VALEUR
#Local    Char    WWST,WFCY
Local    Char WWST (GLONWST)
Local    Char WFCY (GLONFCY)
Local    Decimal WCPL
Local    Decimal WEXT
Local    Integer WRET
Local    Integer L : L = nolign-1

# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif

If instr(1,dbgstr(1),"MFO1")
    WWST = [M:MFO1]EXTWST
    WCPL = [M:MFO1]CPLQTY
    Call UPD_OPE_UNI(2, "MFO1", 0, VALEUR) From MFGLIBO
Else
    WWST = [M:MFG3]EXTWST(nolign-1)
    WCPL = [M:MFG3]CPLQTY(nolign-1)
    Call UPD_OPE_UNI(2, "MFG3", L, VALEUR) From MFGLIBO
Endif
WFCY = [M:MFG0]MFGFCY
WEXT = VALEUR
# vérification seuil solde automatique atteint
Call CONT_SOLDE_OPE(WFCY, WWST, WCPL , WEXT, WRET) From MFGLIBO
If WRET = 1
    Call SOLDE_OPE
    If mkstat
        End
    Endif
Endif
OMODIF = 1

# Issue X3-28791 - if critical field changed, set REVCOD
# Issue X3-55362 - 2017-09-18 by JUSYN : only if activity code "RVM" set; check for routing version
If dim([M:MFG1]ROUECCMAJ) > 0
    If instr(1,dbgstr(1),"MFG3")
      # Issue X3-55431 - display info message once if critical field changed
      If GOPECRICHG=1 & [M:MFG1]ROUECCMAJ<>"" & VALEUR <> [M:MFG3]EXTQTY(L)
        If GMFGREV=2
          [M:MFG3]REVCOD(L) = 2 # = Modify
        Endif
        If !GREVMESSC # No critical message yet
          GREVMESSC = 1
          GERR = 2
          GMESSAGE = mess(411,193,1)
        Endif
      Endif
      # End issue X3-55431
    Endif
Endif
# End issue X3-55362
# End issue X3-28791

End

##########################################################
# SOLDE_OPE : Demande confirmation du solde de l'opération
##########################################################
Subprog SOLDE_OPE
Local    Integer VS
    VS=1
    Call AVERTIR(mess(24,190,1),VS) From GESECRAN
    If VS = 1 : mkstat = 2 : End : Endif
    If instr(1,dbgstr(1),"MFO1")
        [M:MFO0]OPESTA=5
        Affzo [M:MFO0]XOPESTA
        Diszo [M:MFO0]5
        Diszo [M:MFO1]15
        Diszo [M:MFO1]20
        Diszo [M:MFO1]25
        Diszo [M:MFO1]30
        Diszo [M:MFO1]35
        Diszo [M:MFO1]40
        Diszo [M:MFO2]15
        Diszo [M:MFO2]20
        Diszo [M:MFO2]25
        If dim([M:MFG3]OPENUMLEV(I)) > 0
            Diszo [M:MFO3]15
            Diszo [M:MFO3]20
        Endif
        OSOLDE = 1
    Else
        [M:MFG3]OPESTA(nolign-1)=5
        [M:MFG1]DOPECLENBR += 1
        Affzo [M:MFG3]OPESTA(nolign-1)
    Endif
End

