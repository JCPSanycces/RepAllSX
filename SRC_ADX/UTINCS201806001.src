#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTINCS201806001   Deletion of CCMNCSDOC table                                 #
##########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call MAI_DEL_CCMNCSDOC(APPLI)
End

##########################################################################
Subprog MAI_DEL_CCMNCSDOC(DOSSIER)
Value Char     DOSSIER
Local Integer NB
Local Char CODE(GLONID1) , VSUPP(GLONID2)
Local Char APPLI(GLONADS)

Call ECR_TRACE("UTINCS201806001: Process Start on : "+DOSSIER,0) From GESECRAN

If clalev([F:ATB])=0   : Local File =DOSSIER+".ATABLE"       [ATB]  : Endif
If clalev([F:ATZ])=0   : Local File =DOSSIER+".ATABZON"      [ATZ] : Endif
If clalev([F:ATI])=0   : Local File =DOSSIER+".ATABIND"      [ATI] : Endif
If clalev([F:ATY])=0   : Local File =DOSSIER+".ATYPE"        [ATY] : Endif
If clalev([F:ACV])=0   : Local File =DOSSIER+".ACTIV"        [ACV] : Endif
If clalev([F:AML])=0   : Local File =DOSSIER+".AMENLOC"      [AML] : Endif
If clalev([F:ANX])=0   : Local File =DOSSIER+".AINDEX"       [ANX] : Endif
If clalev([F:ACT])=0   : Local File =DOSSIER+".ACTION"       [ACT] : Endif
If clalev([F:AMP])=0   : Local File =DOSSIER+".AMSKPAR"      [AMP] : Endif
If clalev([F:ATR])=0   : Local File =DOSSIER+".ACTPAR"       [ATR] : Endif
If clalev([F:AOB])=0   : Local File =DOSSIER+".AOBJET"       [AOB] : Endif
If clalev([F:AOT])=0   : Local File =DOSSIER+".AOBJTAB"      [AOT] : Endif
If clalev([F:ADW])=0   : Local File =DOSSIER+".ADOVAL"       [ADW] : Endif
If clalev([F:AWI])=0   : Local File =DOSSIER+".AWINDOW"      [AWI] : Endif
If clalev([F:AWB])=0   : Local File =DOSSIER+".AWINBRO"      [AWB] : Endif
If clalev([F:AVW])=0   : Local File =DOSSIER+".AVIEW"        [AVW] : Endif
If clalev([F:ACL])=0   : Local File =DOSSIER+".ACTL"         [ACL] : Endif
If clalev([F:ADS])=0   : Local File =DOSSIER+".ADOSSIER"     [ADS] : Endif
If clalev([F:AAR])=0   : Local File =DOSSIER+".ACTCODPAR"    [AAR] : Endif

# Check first if old table still exists
Read [ATB] CODFIC='CCMNCSDOC'
If fstat
    Raz [F:ATB]
Else
    Call ECR_TRACE("UTINCS201806001: Delete old table CCMNCSDOC.",0) From GESECRAN

    # Remove the table from the dictionary
    CODE = "CCMNCSDOC"
    Raz VSUPP
    Call ANNULATION(DOSSIER,"-ATB",CODE,VSUPP) From ANUCOD

    # Remove the table from the database
    APPLI = DOSSIER
    Gosub ANNULE From SUBATB

    Call ECR_TRACE("UTINCS201806001: CCMNCSDOC deleted.",0) From GESECRAN

Endif
# Issue X3-94198 - 2018-07-06 by STWIL : Purchase receipt, customer return and production tracking entry transactions
Call ECR_TRACE("UTINCS201806001: Update purchase receipt, customer return and production tracking transactions.",0) From GESECRAN
# Purchase receipt
If [F:ADS]MODULE(5) = 2
  Call PATCH(DOSSIER) From SUBPTR
Endif
# Customer return
If [F:ADS]MODULE(4) = 2
  Call PATCH(DOSSIER) From SUBSLR
Endif
# Production tracking
If [F:ADS]MODULE(7) = 2
  Call PATCH(DOSSIER) From SUBMTL
Endif
Call ECR_TRACE("UTINCS201806001: Entry transactions updated.",0) From GESECRAN
Call ECR_TRACE("UTINCS201806001: Process end",0) From GESECRAN
End

########################################################################

