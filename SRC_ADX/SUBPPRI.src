#<AdxTL>@(#)8.0.0.0 $Revision$
########################################################################
# SUBPPRI : Saisie détail tarif achat ligne de cde        MBT 12/02/98 #
# -------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par le s/p         #
# de saisie remises-frais tarif ligne  "REMFRS_LIG" et ne sert qu'à    #
# gérer le masque écran "PURPRICE [PPRI]".                             #
########################################################################


Subprog IB_GROPRI
#--------------------------------------------#
# Initialisation boutons sur champ prix brut #
#--------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4
GBOUT1=mess(42,198,1) : # Tarifs
GBOUT2=mess(51,198,1) : # Derniers prix
GBOUT3=mess(52,198,1) : # Réinit.Prix
End

Subprog B3_GROPRI(VALEUR)
#------------------------#
# Bouton : "Réinit.Prix" #
#------------------------#
Variable Decimal  VALEUR
Local    Shortint NOL       : NOL=nolign-1
Local    Date     OLDRCPDAT : OLDRCPDAT=[M:PPRI]RETRCPDAT
Local    Integer  STAT
Local    Date     WDAT      : # Date du document
Local    Char     WFCY(GLONFCY)   : # Site
Local    Shortint WCHGTYP, I

If mid$([M:PPRI]ABREVM,1,3)="PSH"
  WDAT=[M:PSH0]PRQDAT
  WFCY=[M:PSH1]PRHFCY(NOL)
Endif
WCHGTYP =evalue("[M:"+[M:PPRI]ABREVM+"]CHGTYP(NOL)")
If GPSHVLT=2 | mid$([M:PPRI]ABREVM,1,3)<>"PSH"
  Call RECH_TARIF (mid$([M:PPRI]ABREVM,1,3),NOL) From TRTACHTAR1
  [M:PPRI]GROPRI =evalue("[M:"+[M:PPRI]ABREVM+"]GROPRI(NOL)")
  [M:PPRI]PRIREN =evalue("[M:"+[M:PPRI]ABREVM+"]PRIREN(NOL)")
  [M:PPRI]NETPRI =evalue("[M:"+[M:PPRI]ABREVM+"]NETPRI(NOL)")
  If evalue("dim([M:"+[M:PPRI]ABREVM+"]RETRCPDAT(NOL))")>0
    [M:PPRI]RETRCPDAT=evalue("[M:"+[M:PPRI]ABREVM+"]RETRCPDAT(NOL)") : Endif
  For I=1 To 9
    If evalue("dim([M:"+[M:PPRI]ABREVM+"]DISCRGREN"+num$(I)+"(NOL))")>0
      Assign "[M:PPRI]DISCRGREN"+num$(I) With
&             evalue("[M:"+[M:PPRI]ABREVM+"]DISCRGREN"+num$(I)+"(NOL)")
      Assign "[M:PPRI]DISCRGVAL"+num$(I) With
&             evalue("[M:"+[M:PPRI]ABREVM+"]DISCRGVAL"+num$(I)+"(NOL)")
    Endif
  Next I
  If OLDRCPDAT<>[M:PPRI]RETRCPDAT [M:PPRI]EXTRCPDAT=[M:PPRI]RETRCPDAT : Endif
Else
  Raz [M:PPRI]GROPRI, [M:PPRI]PRIREN, [M:PPRI]NETPRI
  For I=1 To 9
    If evalue("dim([M:PPRI]DISCRGREN"+num$(I)+")")>0
      Assign "[M:PPRI]DISCRGREN"+num$(I) With 0
      Assign "[M:PPRI]DISCRGVAL"+num$(I) With 0
    Endif
  Next I
Endif
#--- Si pas de tarif, on prend le coût standard article en fonction de GPURPRICE ---#
If mid$([M:PPRI]ABREVM,1,3)="PSH"
  If [M:PPRI]NETPRI=0 & [M:PPRI]GROPRI=0 & GPURPRICE=2
    If clalev([F:ITC])=0  Local File ITMCOST [F:ITC] : Endif
    Call GETPRI([M:PPRI]ITMREF,"","",WFCY,WDAT,1,"","",1,GBIDD3,STAT) From STKVAL
    If !STAT
      GBIDD3=[F:ITC]VLTTOT
      #----- Conversion si nécessaire à cause de la devise -----#
      If GCUR<>[M:PPRI]CUR
        Call CONVERT2(GCUR,[M:PPRI]CUR,GCUR,WCHGTYP,GHIDATE,
&                     [F:ITC]VLTTOT,GBIDD3,STAT) From TRTDEV
      Endif
      #------ Conversion si nécessaire à cause de l'unité ------#
      If [M:PPRI]PUU<>evalue("[M:"+[M:PPRI]ABREVM+"]STU(NOL)")
        Local Char WSTU(GLONUOM)
        WSTU =evalue("[M:"+[M:PPRI]ABREVM+"]STU(NOL)")
        #----- Appel du S/P pour chargement du coefficient avec précision maxi -----#
        Call PCAL_QTY([M:PPRI]QTYPUU,[M:PPRI]PUU,GBIDD1,WSTU,
&                     [M:PPRI]ITMREF,[M:PPRI]BPSNUM,1,GBIDD2) From TRTACHQTE1
        If GBIDD2=0 GBIDD2=1 : Endif
        GBIDD3=GBIDD3*GBIDD2
      Endif
      #----- Prix brut et prix net -----#
      [M:PPRI]NETPRI = arr(GBIDD3,10^-GDECPRI)
      [M:PPRI]GROPRI = [M:PPRI]NETPRI
      #----- Motif prix brut -----#
      [M:PPRI]PRIREN = GUPDPRIPUR
    Endif
  Endif
Endif
#----- Restauration valeurs masque ligne modifiées par la recherche tarif -----#
Assign "[M:"+[M:PPRI]ABREVM+"]GROPRI(NOL)" With [M:PPR2]GROPRI
Assign "[M:"+[M:PPRI]ABREVM+"]PRIREN(NOL)" With [M:PPR2]PRIREN
Assign "[M:"+[M:PPRI]ABREVM+"]NETPRI(NOL)" With [M:PPR2]NETPRI
If evalue("dim([M:"+[M:PPRI]ABREVM+"]RETRCPDAT(NOL))")>0
  Assign "[M:"+[M:PPRI]ABREVM+"]RETRCPDAT(NOL)" With [M:PPR2]RETRCPDAT
Endif
For I=1 To 9
  If evalue("dim([M:"+[M:PPRI]ABREVM+"]DISCRGREN"+num$(I)+"(NOL))")>0
    Assign "[M:"+[M:PPRI]ABREVM+"]DISCRGREN"+num$(I)+"(NOL)" With
&           evalue("[M:PPR2]DISCRGREN"+num$(I))
    Assign "[M:"+[M:PPRI]ABREVM+"]DISCRGVAL"+num$(I)+"(NOL)" With
&           evalue("[M:PPR2]DISCRGVAL"+num$(I))
  Endif
Next I
#-----
Affzo [PPRI]1-99
VALEUR=GROPRI
End

Subprog AM_GROPRI(VALEUR)
#--------------------------------------------#
# Après modif du prix brut : Affichage motif #
#--------------------------------------------#
Variable Decimal VALEUR
Affzo [PPRI]PRIREN, GROPRIDES
End

Subprog AP_GROPRI(VALEUR)
#----------------------------------------------#
# Après saisie du prix brut : Test si prix nul #
#----------------------------------------------#
Variable Decimal VALEUR
Local Integer OK
If VALEUR=0
  OK=2 : Call AVERTIR(mess(62,194,1),OK) From GESECRAN
  If OK=1 mkstat=1 : Endif
Endif
End

