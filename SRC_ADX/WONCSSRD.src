#<AdxTL>@(#)0.0.0.0 $Revision$
# Supervisor
# Object management NCSSRD

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [19/10/2018]
A_HEURE = "08:15:37"
A_USER  = "ADMIN"
A_STAMP = "20181019081537"
Return

$DEFAUT
Default File [SRD]
Return

$OUVFIC
Local File SRETURND [SRD]
Return

$NOMFIC
Local Integer NBLNK , TITLNK(1..20)
Local Char    OBJLNK(GLONAOB)(1..20) , CODLNK(GLONADI)(1..20)
Local Char    DESLNK(20)(1..20) , ABRLNK(GLONABR)(1..20)
Local Integer NUMLNK(1..20) , LIGLNK(1..20)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , ABTAB(GLONABR) , NOMINT(GLONAVA)
Local Integer TYPGES , FLGSTAT , SELORD , TYPOBJ
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA), FLDGRF(GLONAVA), FLDLEG(GLONAVA), FLDGRC(GLONAVA)
Local Char    REPORT1(GLONARP) , REPORT2(GLONARP) , NOMKEY(GLONAVA)
Local Integer DELDEF, FCYREQ
Local Char    SELIND(250) , ADDURL(250)
NOMFIC = "SRETURND"
ABFIC  = "SRD"
ABTAB  = "SRD"
NOMINT = ""
TYPGES = 1
SELORD = 2
ZSITE  = "STOFCY"
ZACC   = ""
FLDGRF = ""
FLDGRC = ""
FLDLEG = ""
FCYREQ = 1
PPAG   = 0
SELIND = "[F:SRD]SRHNUM;[F:SRD]SRDLIN"
DELDEF = 0
ADDURL = ""
REPORT1 = "BONRETLIV"
REPORT2 = "SRETURNE"
NOMKEY = "SRD0"
FLGSTAT = 0
TITOBJ = 8586
NBLNK = 0
Raz NUMLNK , LIGLNK
Return

$OUVRE
If clalev([F:SRH])=0 : Local File SRETURN      [SRH] : Endif
If clalev([F:AFF])=0 : Local File AFCTFCY    [AFF] : Endif
Return

$ESPION
NUMESPION = 1
Return

$TIT
Local Char TIT(60)
Call TEXTE(8586,TIT) From OBJDIV
Return

$SETCLE
Local Char CLEPRIM(GLONAVA) , CLESEC(GLONAVA)(0..0) , CLELIG(GLONAVA)
CLEPRIM = 'SRDLIN'
CLESEC(0) = 'SRHNUM'
Return

$OPTIONS
Local Integer  NBCOND
Local Char     CONDIT(50)(1..20)
Local Char     OPT(1)(1..20) , OPTSEL(20)
Local Char     LIBOPT(30)(1..20), MESSAG(80)(1..20)
NBCOND = 0
NBCOND += 1
OPT(NBCOND)    = 'P'
CONDIT(NBCOND) = "[F:SRD]ITMREF=[M]PRODUCT"
Call TEXTE(3651,LIBOPT(NBCOND)) From OBJDIV
Call TEXTE(0,MESSAG(NBCOND)) From OBJDIV
OPTSEL = ''
Return

$LIBPAR
Local Char LIBPAR(30)
Call TEXTE(0,LIBPAR) From OBJDIV
Return

$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(20)(0..GNBDERNIER)
Local Integer  A_BUF2(0..GNBDERNIER)
Local Char     A_BUF3(20)(0..GNBDERNIER)
Local Decimal  A_BUF4(0..GNBDERNIER)
Local Char     A_BUF5(20)(0..GNBDERNIER)
Local Char     A_BUF6(40)(0..GNBDERNIER)
If clalev([F:SRD9])>0 : Close Local File [SRD9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(20),
& Integer  A_TAB2,
& Char     A_TAB3(20),
& Decimal  A_TAB4,
& Char     A_TAB5(20),
& Char     A_TAB6(40)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5,A_BUF6
& As [SRD9]
Return

$LEC_DERLU
Read [AFF]AFF0 = [F:SRD]STOFCY;GPROFIL;GUSRFCT
If fstat : Raz [F:AFF] : Endif
Return

$CHARGE_DERLU
If clalev([F:SRD9])>0
 Read [SRD9] = [F:SRD9]A_TABI
 [L]CLE = [F:SRD9]A_TABC
Endif
Return

$REMP_DERLU
Return

$CLE_DERLU
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 2
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:SRD]SRHNUM"
Call TEXTE(2789,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:SRD]SRHNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:SRD]SRDLIN"
Call TEXTE(641,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 3
SELFMT(NBSEL) = "N:8F"
SELFOR(NBSEL) = "N:8#"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:SRD]SRDLIN"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:SRD]ITMREF"
Call TEXTE(3651,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:SRD]ITMREF"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:SRD]QTYSTU"
Call TEXTE(4657,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 4
SELFMT(NBSEL) = "N:15F"
SELFOR(NBSEL) = "Nz:15F"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:SRD]QTYSTU"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:SRD]SDHNUM"
Call TEXTE(2199,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:SRD]SDHNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:SRD]PJT"
Call TEXTE(1886,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:40X"
SELFOR(NBSEL) = "K:40X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:SRD]PJT"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:SRD_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF] : Endif
If clalev([F:SRH])=0 : Local file SRETURN [SRH] : Endif
Link [SRD] With
& [AFF]AFF0~=[F:SRD]STOFCY;GPROFIL;GUSRFCT,
& [SRH]SRH0=[F:SRD]SRHNUM
& As [SRD_]
Return

$DEFAUT_LISTE
Default file [SRD_]
Return

$OUVRE_JOIN
Local Char    ORDRE_JOI(250)
ORDRE_JOI = "A_TABJ1;A_TABJ2"
Local Char     A_BUFJ1(20)(1..GNBSEL)
Local Integer  A_BUFJ2(1..GNBSEL)
Local Char     A_BUFJ3(15)(1..GNBSEL)
Local Char     A_BUFJ4(80)(1..GNBSEL)
Local File(
& Char     A_TABJ1(20),
& Integer  A_TABJ2,
& Char     A_TABJ3(15),
& Char     A_TABJ4(80)
& ) From Variable A_BUFJ1, A_BUFJ2, A_BUFJ3, A_BUFJ4
& As [PCEJ]
Return

$TIT_JOIN
Local Char TITJOI(30)(1..4)
Call TEXTE(2789,TITJOI(1)) From OBJDIV
Call TEXTE(641,TITJOI(2)) From OBJDIV
TITJOI(3) = mess(59,100,1) : # Type
TITJOI(4) = mess(38,100,1) : # Nom
Return

Subprog FORMCLE(FMT,LG,TIT)
Variable Char    FMT()
Variable Integer LG
Variable Char    TIT()
FMT = "Nf:8#"
LG = 0
TIT = ""
End

Subprog FORMCLE2(FMT)
Variable Char    FMT()
FMT = "Kf:20X"
End

$LIENS
Read [SRH]SRH0 = [F:SRD]SRHNUM
If fstat : Raz [F:SRH] : Endif
Return

$LIAISONS
Return

Subprog TITTRN(COD,TIT)
Value Char COD
Variable Char TIT
Local Integer OUV
Local Char    CRITERE(250)
TIT = ""
End

$OUVTAB
Return

$OUVVUE
Return

