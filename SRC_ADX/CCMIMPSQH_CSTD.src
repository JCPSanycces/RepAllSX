#<AdxTL>@(#)0.0.0.0 $Revision$
# Class CCMIMPSQH - Sales Quotes Impact Analysis 'header'
# Issue 109096/2 - 2015-11-24 by BAKHA : For non-conformance, send email to actioners

$METHODS
  Case CURPTH
    When ""
      Case ACTION
        When "AINIT"                         : Gosub INITIALISE
        When "CREATE_SALES_QUOTES_BATCH"     : Gosub CREATE_SALES_QUOTES_BATCH
        When "CREATE_SALES_QUOTES"           : Gosub CREATE_SALES_QUOTES
        When "CREATE_SALES_QUOTES_LINES"     : Gosub CREATE_SALES_QUOTES_LINES
        When "VALIDATE_IMPLEMENT"            : Gosub VALIDATE_IMPLEMENT
        When "UPDATE_STATUS"                 : Gosub UPDATE_STATUS
        When "AUPDATE_AFTER"                 : Gosub NOTIFY_ACTIONER
      Endcase
  Endcase
Return

# --------------------------------------------------
# Initialise 'header' properties ...
$INITIALISE

  Local Integer LINES

  this.HOLD        = 1
  this.IMPLEMENT   = 1
  this.SQHCUST     = 0
  this.SQHQUOTES   = 0
  this.SQHQTY      = 0
  this.SQHAMT      = 0
  this.SQHAMTEX    = 0
  this.TOTALLINES  = 0
  this.SQHPLASTA   = 4

  this.IMPACTANAL  = 0

  # Folder currency ...
  this.FOLDCUR = fmet this.ACTX.APARAM.AGETVALCHAR(CST_ALEVFOLD, this.ACTX.AFOLDER, "RTZCUR")

Return

# ------------------------------------------------------
# Operation: CREATE_SALES_QUOTES_BATCH
#
# Called from Impact Analysis summary links.
# Instantiate Batch Server process, Task: CCMIMPBATT.
#
$CREATE_SALES_QUOTES_BATCH

  Local Integer LOCAL_STATUS
  Local Instance IMPSQH Using C_CCMIMPSQH
  IMPSQH = NewInstance C_CCMIMPSQH AllocGroup null

  Local Char    AFOLDER(30)
  Local Char    USER(30)
  Local Char    TASKNAME(30)
  Local Date    DAT
  Local Char    TIM(5)
  Local Char    TBPAR(30)(1..10)
  Local Char    TBVAL(250)(1..10)
  Local Integer NBPAR
  Local Integer TASKID
  Local Char    TASKMESSAGE(250)

  Local Integer LTIME
  Local Char    CTIME(4)

  # Read impact header
  LOCAL_STATUS = fmet IMPSQH.AREAD(CRID)

  ASTATUS = CST_AOK

  If (IMPSQH.IMPACTANAL <> 1)

    LTIME = time : CTIME = format$("N00:2", int(LTIME/3600)) +format$("N00:2", int((LTIME -(int(LTIME/3600) *3600)) /60))

    USER       = IMPSQH.ACTX.USER
    TASKNAME  = "CCMIMPBATT"
    DAT       = date$
    TIM       = CTIME
    NBPAR = 1  : TBPAR(NBPAR) = "CRID"        : TBVAL(NBPAR) = CRID
    NBPAR += 1 : TBPAR(NBPAR) = "TRANSACTION" : TBVAL(NBPAR) = "8"

    # Impact Analysis 'Created' flag = "No" ...
    IMPSQH.IMPACTANAL = 1
    LOCAL_STATUS = fmet IMPSQH.AUPDATE()

    ASTATUS = func ASYRMNGTREQ.CRERQT(IMPSQH.ACTX,
&                              IMPSQH.ACTX.AFOLDER,
&                              USER,
&                              TASKNAME,
&                              DAT,
&                              TIM,
&                              TBPAR,
&                              TBVAL,
&                              NBPAR,
&                              TASKID,
&                              TASKMESSAGE)

  Endif

  FreeGroup IMPSQH
  ARET_VALUE = ASTATUS

Return

# -------------------------------------------------------------------------------
# Custom Operation ...
#
# Called from (a) Change Request - change of status to "In review", and
#             (b) Impact Analysis Sales Quotes - refresh.
#
$CREATE_SALES_QUOTES

  Local Integer LOCSTATUS
  Local File CCMIMPSQD [CCMISQD]
  Local Instance SELCHGREQ Using C_CCMCHGREQ
  Local Instance SELIMPSQH Using C_CCMIMPSQH

  # Begin a Database Transaction ...
  Local Integer TRANSACTION_PENDING
  TRANSACTION_PENDING = adxlog
  If (adxlog = 0)
    Trbegin [CCMISQD]
  Endif

  # Read Change Request ...
  SELCHGREQ = NewInstance C_CCMCHGREQ AllocGroup null
  LOCSTATUS = fmet SELCHGREQ.AREAD(CRID)

  # Read Impact Analysis 'header' ...
  SELIMPSQH = NewInstance C_CCMIMPSQH AllocGroup null
  LOCSTATUS = fmet SELIMPSQH.AREAD(CRID)

  # Is refresh possible? ...
  If (LOCSTATUS = [V]CST_AOK and
&     SELCHGREQ.CRSTATUS = 2 and
&     SELIMPSQH.HOLD <> 2)

    # Clear lines ...
    Delete [CCMISQD] Where CRID = SELIMPSQH.CRID

    # Initialise 'header' properties ...
    SELIMPSQH.HOLD        = 1
    SELIMPSQH.IMPLEMENT   = 1
    SELIMPSQH.SQHCUST     = 0
    SELIMPSQH.SQHQUOTES   = 0
    SELIMPSQH.SQHQTY      = 0
    SELIMPSQH.SQHAMT      = 0
    SELIMPSQH.SQHAMTEX    = 0

    # Folder currency ...
    SELIMPSQH.FOLDCUR = fmet this.ACTX.APARAM.AGETVALCHAR(CST_ALEVFOLD, this.ACTX.AFOLDER, "RTZCUR")

    LOCSTATUS = fmet SELIMPSQH.CREATE_SALES_QUOTES_LINES (SELIMPSQH.CRID, SELCHGREQ.PRODUCT, SELCHGREQ.ECCVALMAJ, SELCHGREQ.ECCVALMIN)

  Endif

  # If lines (i.e. unique quotes) then set status to 5 (No actions) else set to 4 (None) ...
  If (SELIMPSQH.SQHQUOTES >= 1)
    SELIMPSQH.SQHPLASTA = 1
  Else
    SELIMPSQH.SQHPLASTA = 4
    # If Plan Status is 4 (None) then Implement flag is always ticked ...
    SELIMPSQH.IMPLEMENT = 2
  Endif

  SELIMPSQH.IMPACTANAL = 2

  LOCSTATUS= fmet SELIMPSQH.AUPDATE()

  # Commit or Rollback the Database Transaction ...
  If (TRANSACTION_PENDING = 0)
    If (ASTATUS <= [V]CST_AINFO)
      Commit
    Else
      Rollback
    Endif
  Endif

  FreeGroup SELIMPSQH
  FreeGroup SELCHGREQ

  LogicClose File [CCMISQD]

Return

# -------------------------------------------------------------------------------
# Custom Method ...
#
# Called from $CREATE_SALES_QUOTES (above).
#
$CREATE_SALES_QUOTES_LINES
  Local Instance SELCHGREQ Using C_CCMCHGREQ
  SELCHGREQ = NewInstance C_CCMCHGREQ AllocGroup null
  Local Char CRITERIA(250)
  Local Integer I, LOCSTATUS, WRET, OK, BLANK_VERSION

  #MGG X3-38337_Product_Code_length_GLONITM_function
  Local Char LAST_ITMREF(GLONITM)    : LAST_ITMREF = ""
  #END MGG X3-38337_Product_Code_length_GLONITM_function

  Local Date    WDATREF         : WDATREF     = AVOID.ADATE
  Local Integer WLSTTYP         : WLSTTYP     = 3     # 1=first level, 2=last level, 3= multi-level
  Local Integer WALTTYPSTR      : WALTTYPSTR  = 1     # 1=Sales (kit), 2=WO (Manufacturing), 3=EO (subcontracting BOM)
  Local Integer WALTTYPEND      : WALTTYPEND  = 3     # 1=Sales (kit), 2=WO (Manufacturing), 3=EO (subcontracting BOM)
  Local Integer WALTSTR         : WALTSTR     = 0     # From alt number : 0=all alternatives
  Local Integer WALTEND         : WALTEND     = 0     # From alt number : 0=all alternatives
  Local Char    MYCRIT(250)     : MYCRIT      = "1=1" # No particular Where criteria
  Local Char    MYFOR (GLONFOR) : MYFOR       = ""    # Reference of a formula in table TABFOR [F:TFO] with FORTYP=31
  Local File ITMMASTER [ITM]
  Local File ITMCATEG [ITG]
  Local Integer LINE_NUMBER     : LINE_NUMBER = 0
  Local Char MYBPCNUM (GLONBPC)(0..)
  Local Integer NO_CUST   : NO_CUST = 0
  Local Char MYSQHNUM (GLONSQH)(0..)
  Local Integer NO_QUOTES : NO_QUOTES = 0
  #CATUA X3-38562.sn Set Product Code length to GLONITM
  Local Char SUB_LINES_PRODUCT(GLONITM)
  #CATUA X3-38562.en

  Local Char SUB_ECCVALMAJ(10)
  Local Char SUB_ECCVALMIN(10)

  # Create lines for Change Request Product ...
  BLANK_VERSION = CST_ATRUE
  SUB_LINES_PRODUCT = PRODUCT
  SUB_ECCVALMAJ = MAJOR_VERSION
  SUB_ECCVALMIN = MINOR_VERSION
  Gosub CREATE_SALES_QUOTES_SUB_LINES

  # Check for semi-finished goods ...
  Read [ITM]ITM0 = PRODUCT
  If (fstat = 0)

    Read [ITG]ITG1 = [F:ITM]TCLCOD; ""
    If (fstat = 0 and
&       [F:ITG]SALFLG = 2)

      # CCM ...
      Local File BOMWUS [BOW]
      Call CALCULATE_WHERE_USED_ECC(this.ACTX,
&                               PRODUCT,
&                               MAJOR_VERSION,
&                               MINOR_VERSION,
&                               WDATREF,
&                               WLSTTYP,
&                               WALTTYPSTR,
&                               WALTTYPEND,
&                               WALTSTR,
&                               WALTEND,
&                               MYCRIT,
&                               MYFOR,
&                               WRET) From SUBBOW_SYRA
      Filter [BOW] Where CREUSR = this.ACTX.USER and
&                        BOWUID = adxuid(1)
&                  Order By ITMREF
      For [BOW]
        If ([F:BOW]ITMREF <> LAST_ITMREF)
          SUB_LINES_PRODUCT = [F:BOW]ITMREF

          # if version managed

          If (fmet SELCHGREQ.IS_PRODUCT_VERSION_MANAGED(SUB_LINES_PRODUCT) > 1)
            Local File ECCVAL [EVL]
            # for each version, create lines
            CRITERIA = " 1=1 "
            If [F:BOW]BOMSTRDAT<>[0/0/0]
              CRITERIA+=" & STRDAT>=["+format$(GFMD,[F:BOW]BOMSTRDAT)+"]"
            Endif
            If [F:BOW]BOMENDDAT<>[0/0/0]
              CRITERIA+=" & STRDAT<=["+format$(GFMD,[F:BOW]BOMENDDAT)+"]"
            Endif

            BLANK_VERSION = CST_ATRUE
            For [EVL] Where ITMREF=[F:BOW]ITMREF & ECCTYP=[F:BOW]BOMALTTYP & BOMALT=[F:BOW]BOMALT  & evalue(CRITERIA)
              SUB_ECCVALMAJ = [F:EVL]ECCVALMAJ
              SUB_ECCVALMIN = [F:EVL]ECCVALMIN
              Gosub CREATE_SALES_QUOTES_SUB_LINES
              If (BLANK_VERSION = CST_ATRUE)
                BLANK_VERSION = CST_AFALSE
              Endif
            Next
            Close Local File [EVL]
          Else
            BLANK_VERSION = CST_AFALSE
            SUB_ECCVALMAJ = ""
            SUB_ECCVALMIN = ""
            Gosub CREATE_SALES_QUOTES_SUB_LINES
          Endif
        Endif
        LAST_ITMREF = [F:BOW]ITMREF
      Next
      # CCM ...
      Delete [BOW] Where CREUSR = this.ACTX.USER and BOWUID = adxuid(1)

      Close Local File [BOW]

    Endif
  Endif

  # Update summary totals ...
  this.SQHCUST = NO_CUST
  this.SQHQUOTES = NO_QUOTES

  this.TOTALLINES = LINE_NUMBER

  Close Local File [ITM]
  Close Local File [ITG]
  FreeGroup SELCHGREQ
Return


# -------------------------------------------------------------------------------
$CREATE_SALES_QUOTES_SUB_LINES

  Local Integer LOCSTATUS, STAT, FOUND, COUNT
  Local Decimal WMNTCALC, AMNTCALC
  Local File SQUOTE [SQH]
  Local File SQUOTED [SQD]
  Local Char CRITERIA(250)

  Local Instance CCMIMPSQD Using C_CCMIMPSQD
  CCMIMPSQD = NewInstance C_CCMIMPSQD AllocGroup null

  CRITERIA = " 1=1 "
  If (SUB_ECCVALMAJ <> "")
    If (BLANK_VERSION = CST_ATRUE)
      CRITERIA += " and [F:SQD]ECCVALMAJ = '' or [F:SQD]ECCVALMAJ = SUB_ECCVALMAJ"
    Else
      CRITERIA += " and [F:SQD]ECCVALMAJ = SUB_ECCVALMAJ"
    Endif

    If (SUB_ECCVALMIN <>  "")
      If (BLANK_VERSION = CST_ATRUE)
        CRITERIA += " and [F:SQD]ECCVALMIN = '' or [F:SQD]ECCVALMIN = SUB_ECCVALMIN"
      Else
        CRITERIA += " and [F:SQD]ECCVALMIN = SUB_ECCVALMIN"
      Endif
    Endif
  Endif

  Filter [SQD] Where [F:SQD]ITMREF = SUB_LINES_PRODUCT and
&                    [F:SQH]QUOSTA <> 3 and
&         evalue(CRITERIA)
  For [SQD]SQD0

    # Select lines when quote not fully ordered and order quantity < quote quantity and not expired ...
    Read [SQH]SQH0 = [F:SQD]SQHNUM
    If (fstat = 0 and
&       [F:SQH]QUOSTA <> 3 and
&       [F:SQD]ORDQTY < [F:SQD]QTY and
&      ([F:SQH]VLYDAT = [00/00/00] or [F:SQH]VLYDAT >= date$))

      LOCSTATUS = fmet CCMIMPSQD.AINIT()

      LINE_NUMBER += 1

      CCMIMPSQD.CRID         = CRID
      CCMIMPSQD.LINENO       = LINE_NUMBER
      CCMIMPSQD.SORTSEQ      = LINE_NUMBER
      CCMIMPSQD.SQHNUM       = [F:SQD]SQHNUM
      CCMIMPSQD.SQDLIN       = [F:SQD]SQDLIN
      CCMIMPSQD.ITMREF       = SUB_LINES_PRODUCT
      CCMIMPSQD.ECCVALMAJ    = [F:SQD]ECCVALMAJ
      CCMIMPSQD.ECCVALMIN    = [F:SQD]ECCVALMIN
      CCMIMPSQD.BPCORD       = [F:SQD]BPCORD
      CCMIMPSQD.SALFCY       = [F:SQD]SALFCY
      CCMIMPSQD.VLYDAT       = [F:SQH]VLYDAT
      CCMIMPSQD.QTY          = [F:SQD]QTY - [F:SQD]ORDQTY
      CCMIMPSQD.TRANTYPE     = 8
      CCMIMPSQD.LINESTATUS   = 1
      CCMIMPSQD.STARTDATE    = AVOID.ADATE
      CCMIMPSQD.ENDDATE      = AVOID.ADATE
      CCMIMPSQD.COMPLETEDATE = AVOID.ADATE
      CCMIMPSQD.ACTIONID     = ""
      CCMIMPSQD.ACTIONER     = ""
      CCMIMPSQD.COMMENT      = ""

      # Calculate: [amount + tax] ...
      WMNTCALC = 0.00
      WMNTCALC = [F:SQD]QTY * [F:SQD]NETPRIATI
      If ([F:SQH]CUR <> "")
        Call ARRDEV (WMNTCALC,  [F:SQH]CUR) From TRTDIV
      Endif

      # Calculate: [amount - tax] ...
      AMNTCALC = 0.00
      AMNTCALC = [F:SQD]QTY * [F:SQD]NETPRINOT
      If ([F:SQH]CUR <> "")
          Call ARRDEV (AMNTCALC,  [F:SQH]CUR) From TRTDIV
      Endif

      CCMIMPSQD.NETPRIATI = WMNTCALC
      CCMIMPSQD.NETPRINOT = AMNTCALC
      CCMIMPSQD.SQHCUR    = [F:SQH]CUR
      CCMIMPSQD.FOLDCUR   = this.FOLDCUR

      # Convert [amount - tax] to folder currency ...
      If CCMIMPSQD.SQHCUR <> CCMIMPSQD.FOLDCUR
        Call CONVERT (this.ACTX,
&                     CCMIMPSQD.SQHCUR,
&                     CCMIMPSQD.FOLDCUR,
&                     CCMIMPSQD.FOLDCUR,
&                     [F:SQH]CHGTYP,
&                     [F:SQH]ORDDAT,
&                     CCMIMPSQD.NETPRINOT,
&                     CCMIMPSQD.CONAMNT,
&                     STAT) From TRTDEV_SYRA
      Else
        CCMIMPSQD.CONAMNT = CCMIMPSQD.NETPRINOT
      Endif

      LOCSTATUS = fmet CCMIMPSQD.AINSERT()

      # Maintain unique customer and order arrays / totals:
      #
      # Customer ...
      FOUND = CST_AFALSE
      For COUNT = 0 To NO_CUST
        If (CCMIMPSQD.BPCORD = MYBPCNUM(COUNT))
          FOUND = CST_ATRUE
          Break
        Endif
      Next
      If (FOUND = CST_AFALSE)
        MYBPCNUM(NO_CUST) = CCMIMPSQD.BPCORD
        NO_CUST = NO_CUST +1
      Endif

      # Order ...
      FOUND = CST_AFALSE
      For COUNT = 0 To NO_QUOTES
        If (CCMIMPSQD.SQHNUM = MYSQHNUM(COUNT))
          FOUND = CST_ATRUE
          Break
        Endif
      Next
      If (FOUND = CST_AFALSE)
        MYSQHNUM(NO_QUOTES) = CCMIMPSQD.SQHNUM
        NO_QUOTES = NO_QUOTES +1
      Endif

      # Increment summary totals ...
      this.SQHQTY += CCMIMPSQD.QTY
      this.SQHAMTEX += CCMIMPSQD.CONAMNT

    Endif

  Next

  FreeGroup CCMIMPSQD
  LogicClose File [SQH]
  LogicClose File [SQD]

Return

# -------------------------------------------------------------------------------
# Update Sales Oreder Detail Plan 'header' status.
#
# Set status to:
#
# 4 'Not applicable'  ... if (No sales order lines) or (No actionable sales order lines and Planning complete),
# 3 'Complete'        ... if (All actionable sales order lines are complete),
# 2 'Implement'       ... if (Actionable sales order lines and Planning complete),
# 1 'Plan'            ... if (Planning is not complete).

$UPDATE_STATUS

  Local Integer STAT, ACTIONLINES, LINESCOMP

  # Count number of action lines ...
  Local File CCMIMPSQD [CCMSQD]
  Filter [CCMSQD] Where CRID = this.CRID and ACTIONID <> ""
  ACTIONLINES = rowcount([CCMSQD])

  # Count number of action lines completed ...
  Filter [CCMSQD] Where CRID = this.CRID and LINESTATUS = 3
  LINESCOMP = rowcount([CCMSQD])

  Filter [CCMSQD]
  LogicClose File [CCMSQD]

  If (this.SQHQUOTES = 0) or
&    (ACTIONLINES = 0 and this.IMPLEMENT = 2)
    this.SQHPLASTA = 4
  Elsif (ACTIONLINES <> 0 and ACTIONLINES = LINESCOMP)
    this.SQHPLASTA = 3
  Elsif (this.IMPLEMENT = 2)
    this.SQHPLASTA = 2
  Else
    this.SQHPLASTA = 1
  Endif

  ARET_VALUE = CST_ATRUE

Return

# -------------------------------------------------------------------------------
# "Planning complete" flag validation ...
$VALIDATE_IMPLEMENT
  Local Integer ACTIONLINES, LOCSTATUS

  # count number of action lines
  Local File CCMIMPSQD [CCMSQD]
  Filter [CCMSQD] Where CRID = this.CRID and ACTIONID <> ""
  ACTIONLINES = rowcount([CCMSQD])
  LogicClose File [CCMSQD]

  ASTATUS = CST_AOK

  If (this.snapshot.IMPLEMENT = 1 and this.IMPLEMENT = 2)
    If (this.TOTALLINES > ACTIONLINES)
#      LOCSTATUS = fmet this.ASETERROR ("IMPLEMENT", mess(62,2038,1), CST_AINFO)
      LOCSTATUS = fmet this.ASETERROR ("", mess(62,2038,1), CST_AINFO)

    Endif
  Endif

 ARET_VALUE = ASTATUS

Return

#
# --------------------------------------------------
# FUNCTION NAME:        NOTIFY_ACTIONER
# FUNCTION DESCRIPTION: Notify Actioner
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
#
$NOTIFY_ACTIONER

  Local Instance CHANGE_REQUEST Using C_CCMCHGREQ
  CHANGE_REQUEST = NewInstance C_CCMCHGREQ AllocGroup null
  Local File CCMIMPSQD [SQD]
  Local Char LAST_ACTIONER(5)
  Local Integer STAT
  Local Integer EMAIL_TYPE
  Local Char SUBJECT(250)
  Local Clbfile BODY(0), OTHER_BODY(0)
  Local Integer AC_EMAIL : AC_EMAIL = CST_AFALSE
# Issue 109096/2 - send e-mails to actioners
  Local Integer SENDEMAIL : SENDEMAIL = CST_AFALSE
  STAT = fmet CHANGE_REQUEST.AREAD(this.CRID)

  If (CHANGE_REQUEST.NCSREC = 2)
    # Issue X3-76268 - 2018-02-13 by JUSYN : Remove/deactivate email notification NCS
#    If (fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "NCSEMAILAC") <> 1 and
#&     this.snapshot.IMPLEMENT = 1 and this.IMPLEMENT = 2)
#
#      SENDEMAIL = CST_ATRUE
#      EMAIL_TYPE = 3713  # Actioner
#      BODY(0) = AVOID.ACLOB
#      OTHER_BODY(0) = AVOID.ACLOB
#      Append OTHER_BODY, mess(8,2039,1) +chr$(10)
#      STAT = fmet CHANGE_REQUEST.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, OTHER_BODY, "NCSPLASQH")
#    Endif
    # End issue X3-76268
  Else
# End issue 109096/2

    If (fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMEMAILAC") <> 1 and
&     this.snapshot.IMPLEMENT = 1 and this.IMPLEMENT = 2)

      SENDEMAIL = CST_ATRUE
      EMAIL_TYPE = 2066  # Actioner
      BODY(0) = AVOID.ACLOB
      OTHER_BODY(0) = AVOID.ACLOB
      Append OTHER_BODY, mess(8,2039,1) +chr$(10)
      STAT = fmet CHANGE_REQUEST.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, OTHER_BODY, "CCMPLASQH")
    Endif
# Issue 109096/2
  Endif

  If (SENDEMAIL = CST_ATRUE)
# End issue 109096/2

    Filter [SQD] Where CRID = this.CRID and ACTIONER <> "" Order By ACTIONER
    For [SQD]
      If ([F:SQD]ACTIONER <> LAST_ACTIONER and
&         [F:SQD]ACTIONER <> this.ACTX.USER)

        STAT = fmet CHANGE_REQUEST.SEND_EMAIL(this.ACTX.USER, [F:SQD]ACTIONER, "", SUBJECT, BODY)

        If (STAT = CST_AOK)
          AC_EMAIL = CST_ATRUE
        Endif

        LAST_ACTIONER = [F:SQD]ACTIONER

      Endif
    Next

    If (AC_EMAIL = CST_ATRUE)
      ASTATUS = fmet this.ASETERROR("", mess(60,2038,1), CST_AINFO)
    Endif

  Endif

  LogicClose File [SQD]
  FreeGroup CHANGE_REQUEST

Return

$PROPERTIES
  Case CURPRO
  Endcase
Return


