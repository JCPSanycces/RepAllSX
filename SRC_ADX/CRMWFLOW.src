  Call WFLUSE(SZCODEWF, IASK)
  If IASK = 0 Then
    End
  Endif
  Read [BPC2]BPC0=[F:CON]CONBPC
  If fstat Then
    End
  Endif
  If dim([F:BPC2]REP) <= 0 Then
    End
  Endif
  If [F:BPC2]REP(0) = "" Then
    End
  Endif
  Read [REP2]REP0=[F:BPC2]REP(0)
  If fstat Then
    End
  Endif
  If [F:REP2]AUSNUM = "" Then
    End
  Endif
  Read [AUS]CODUSR=[F:REP2]AUSNUM
  If fstat Then
    End
  Endif
  If [F:AUS]ADDEML = "" Then
    End
  Endif
  If GNAVIG(GPILNAV) = "GESBPC" Then
    #Call WORKFLOW("TO1","","") From SUBAMSC
    Call WORKFLOW(1, "TO1", "", "") From AWRK  # FGR 23/03/2010 : X3SUIVI63397
