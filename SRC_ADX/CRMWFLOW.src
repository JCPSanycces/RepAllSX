    End
  Endif
  IASK = 0
  ISOK = 1
  SZCODEWF = "CRMSRE1"
  # FGR 23/03/2010 : X3SUIVI63397 Pas d'accord avec une création de règle automatique (début)
  #                  Donc tester l'existence ne sert à rien
  #Call WFLEXIST(SZCODEWF, IASK)
  #If IASK = 0 Then
  #  #Destinataire
  #  SZDESTIN = "[M:SRE2]SRECOVCTL"
  #  #Sujet du message
  #  SZSUJET = "mess(505,196,1)"   #Une demande de service a été couverte commercialement.
  #  #Contenu du message
  #  SZCONTENT(0) = "mess(506,196,1) - [M:SRE0]SRENUM - mess(507,196,1) - [M:SRE2]SRECOVAUS - [M:SRE2]COVAUSCLA"
  #  SZCONTENT(1) = "mess(508,196,1) - num$(day([M:SRE2]SRERESDAT)) + '/' + num$(month([M:SRE2]SRERESDAT)) + '/' + num$(year([M:SRE2]SRERESDAT))"
  #  SZCONTENT(2) = "mess(510,196,1)"
  #  SZCONTENT(3) = "[M:SRE1]SRETTR"
  #  Call CREWFLRULE(SZCODEWF, "GESSRE", "[M:SRE0]SRENUM", SZDESTIN, "COV", SZSUJET, SZCONTENT, ISOK)
  #  If !ISOK Then
  #    End
  #  Endif
  #Endif
  # FGR 23/03/2010 : X3SUIVI63397 Pas d'accord avec une création de règle automatique (fin)
  Call WFLUSE(SZCODEWF, IASK)
