  #  SZCONTENT(1) = "mess(607,182,1) - ':' - [F:BPC2]BPCNAM + ' (' + [F:BPC2]BPCNUM + ').'"
  #  SZCONTENT(2) = "mess(608,182,1) - ':' - num$([F:CON]PITCDT) + '.'"
