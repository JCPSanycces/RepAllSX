#################################################
# Vérifie si le workflow CRMSRE1 doit être exécuté.
#################################################
Subprog CHKCRMSRE1(SZCONTEXT, IDOCRMSRE1)
Value Char SZCONTEXT
Variable Integer IDOCRMSRE1

Local Integer ITER
Local Integer ICOVCHG
Local Integer ICPNFOUND
Local Integer ISTOP

  IDOCRMSRE1 = 0
  [M:SRE2]SRECOVAUS = ""
  [M:SRE2]COVAUSCLA = ""
  [M:SRE2]SRECOVCTL = ""
  ICOVCHG = 0
  ICPNFOUND = 0
  ISTOP = 0
  If SZCONTEXT = "C" Then
    #Création
    #Contrôle couverture globale
    If [M:SRE2]OVRCOV = 6 Then
      Gosub SETCRMSRE1
      End
    Elsif [M:SRE2]OVRCOV = 4 or [M:SRE2]OVRCOV = 5 Then
      If [M:SRE2]SRECOVNUM = "" Then
        Gosub SETCRMSRE1
        End
      Endif
    Endif
    #Contrôle couverture parc
    For ITER = 0 To [M:SRE7]NBMAC-1
      If [M:SRE7]COVFLG(ITER) = 1 Then
        If [M:SRE7]COVSPT(ITER) = 3 Then
          Gosub SETCRMSRE1
          ISTOP = 1
          Break
        Elsif [M:SRE7]COVSPT(ITER) = 1 or [M:SRE7]COVSPT(ITER) = 2 Then
          If [M:SRE7]COVVCR(ITER) = "" Then
            Gosub SETCRMSRE1
            ISTOP = 1
            Break
          Endif
        Endif
      Endif
    Next
    If ISTOP Then
      End
    Endif
    #Contrôle couverture composant
    If [M:SRE7]NBMAC > 0 Then
      Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
      For [SRN]
        If [F:SRN]CPNCOVFLG = 1 Then
          If [F:SRN]CPNCOVSPT = 3 Then
            Gosub SETCRMSRE1
            ISTOP = 1
            Break
          Elsif [F:SRN]CPNCOVSPT = 1 or [F:SRN]CPNCOVSPT = 2 Then
            If [F:SRN]CPNCOVVCR = "" Then
              Gosub SETCRMSRE1
              ISTOP = 1
              Break
            Endif
          Endif
        Endif
      Next
      Filter [SRN]
      If ISTOP Then
        End
      Endif
    Endif
  Elsif SZCONTEXT = "M" Then
    #Modification
    #La couverture globale a-t-elle changé ?
    If [M:SRE2]OVRCOV <> [M:SRE2]PREOVRCOV Then
      ICOVCHG = 1
    Endif    
    #If [M:SRE2]PRECOVNUM <> [M:SRE2]PRECOVNUM Then
    If [M:SRE2]SRECOVNUM <> [M:SRE2]PRECOVNUM Then  # FGR 23/03/2010 : X3SUIVI63397 : mauvais test
      ICOVCHG = 1
    Endif    
    If ICOVCHG Then
      #Contrôle couverture globale
      If [M:SRE2]OVRCOV = 6 Then
        Gosub SETCRMSRE1
        End
      Elsif [M:SRE2]OVRCOV = 4 or [M:SRE2]OVRCOV = 5 Then
        If [M:SRE2]SRECOVNUM = "" Then
          Gosub SETCRMSRE1
          End
        Endif
      Endif
    Endif
    #La couverture parc a-t-elle changé ?
    For ITER = 0 To [M:SRE7]NBMAC-1
      ICOVCHG = 0
      If [M:SRE7]PRECOVFLG(ITER) <> [M:SRE7]COVFLG(ITER) Then
        ICOVCHG = 1
      Endif
      If [M:SRE7]PRECOVSPT(ITER) <> [M:SRE7]COVSPT(ITER) Then
        ICOVCHG = 1
      Endif
      If [M:SRE7]PRECOVVCR(ITER) <> [M:SRE7]COVVCR(ITER) Then
        ICOVCHG = 1
      Endif
      If ICOVCHG Then
        If [M:SRE7]COVFLG(ITER) = 1 Then
          If [M:SRE7]COVSPT(ITER) = 3 Then
            Gosub SETCRMSRE1
            ISTOP = 1
            Break
          Elsif [M:SRE7]COVSPT(ITER) = 1 or [M:SRE7]COVSPT(ITER) = 2 Then
            If [M:SRE7]COVVCR(ITER) = "" Then
              Gosub SETCRMSRE1
              ISTOP = 1
              Break
            Endif
          Endif
        Endif
      Endif
    Next
    If ISTOP Then
      End
    Endif
    #Contrôle couverture composant
    If [M:SRE7]NBMAC > 0 Then
      #La couverture composant a-t-elle changé ?
      Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0
      For [SRN]
        ICOVCHG = 0
        ICPNFOUND = 0
        Filter [SRN2]Where [F:SRN2]SRENUM = [M:SRE0]SRENUM and [F:SRN2]TPYFLG = 0 and [F:SRN2]FGVCAH = 1 and [F:SRN2]MACNUM = [F:SRN]MACNUM and [F:SRN2]CPNITM = [F:SRN]CPNITM
        For [SRN2]
          If [F:SRN]CPNCOVFLG <> [F:SRN2]CPNCOVFLG Then
            ICOVCHG = 1
          Endif
          If [F:SRN]CPNCOVSPT <> [F:SRN2]CPNCOVSPT Then
            ICOVCHG = 1
          Endif
          If [F:SRN]CPNCOVVCR <> [F:SRN2]CPNCOVVCR Then
            ICOVCHG = 1
          Endif
          ICPNFOUND = 1
        Next
        Filter [SRN2]
        If !ICPNFOUND Then
          ICOVCHG = 1
        Endif
        If ICOVCHG Then
          If [F:SRN]CPNCOVFLG = 1 Then
            If [F:SRN]CPNCOVSPT = 3 Then
              Gosub SETCRMSRE1
              ISTOP = 1
              Break
            Elsif [F:SRN]CPNCOVSPT = 1 or [F:SRN]CPNCOVSPT = 2 Then
              If [F:SRN]CPNCOVVCR = "" Then
                Gosub SETCRMSRE1
                ISTOP = 1
                Break
              Endif
            Endif
          Endif
        Endif
      Next
      Filter [SRN]
      If ISTOP Then
        End
      Endif
    Endif
  Endif
End

################################################################
$SETCRMSRE1
Local Char SZFNC
Local Integer IFNC
Local Char SZMNA
Local Integer IMNA

  Call PARAMUTIL("AUSCRMA", SZFNC, GUSER, "") From SUBAUS
  If SZFNC = "" Then
    IFNC = 1
  Else
    IFNC = val(SZFNC)
  Endif
  Call PARAMUTIL("AUSCRME", SZMNA, GUSER, "") From SUBAUS
  If SZMNA = "" Then
    IMNA = 1
  Else
    IMNA = val(SZMNA)
  Endif
  Read [AUS]CODUSR=GUSER
  If !fstat Then
    If IFNC <> 4 Then
      If IMNA > 0 Then
        If [F:AUS]CHEF(IMNA-1) = "" Then
          If [F:AUS]CHEF(0) <> "" Then
            [M:SRE2]SRECOVAUS = GUSER
            [M:SRE2]COVAUSCLA = [F:AUS]NOMUSR
            [M:SRE2]SRECOVCTL = [F:AUS]CHEF(0)
            IDOCRMSRE1 = 1
          Endif
        Else
          [M:SRE2]SRECOVAUS = GUSER
          [M:SRE2]COVAUSCLA = [F:AUS]NOMUSR
          [M:SRE2]SRECOVCTL = [F:AUS]CHEF(IMNA-1)
          IDOCRMSRE1 = 1
        Endif
      Else
        If [F:AUS]CHEF(0) <> "" Then
          [M:SRE2]SRECOVAUS = GUSER
          [M:SRE2]COVAUSCLA = [F:AUS]NOMUSR
          [M:SRE2]SRECOVCTL = [F:AUS]CHEF(0)
          IDOCRMSRE1 = 1
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################
#Workflow envoyé lors d'une couverture commerciale de demande de service.  
