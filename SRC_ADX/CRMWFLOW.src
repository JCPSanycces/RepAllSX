#<AdxTL>@(#)10.0.0.0 $Revision$
#####################################################################################################################
#     Ensemble de sous-programmes utilitaires CRM pour la création automatique de règles Workflow                   #
#                                                                                                                   #
#  WFLEXIST       : Détermine si une règle de workflow est définie dans l'application                               #
#  WFLUSE         : Détermine si une règle de workflow doit être utilisée                                           #
#  CPTEVTKEY      : Calcul un code d'évenement divers dans la table diverse 908                                     #
#  GETEVTADICOD   : Renvoie le code de table diverse 908 correspondant à un évènement CRM                           #
#  ADDSTRFOR      : Inclus une chaine dans une formule string$                                                      #
#  CREWFLRULE     : Crée une nouvelle règle de workflow.                                                            #
#####################################################################################################################
#     Liste des sous-programmes de génération des workflow CRM standards                                            #
#                                                                                                                   #
#  DOCRMSRE1      : Workflow envoyé lors d'une couverture commerciale de demande de service.                        #
#  CHKCRMSRE1     : Vérifie si le workflow CRMSRE1 doit être exécuté.                                               #
#  DOCRMPIT1      : Workflow envoyé lors d'une création de contrat de service par crédit de points.                 #
#####################################################################################################################
##############################################################################
# Détermine si une règle de workflow est définie dans l'application.         #
##############################################################################
#CHECK UNUSED_BEGIN
Subprog WFLEXIST(CODEWFL, IEXIST)
Value Char CODEWFL
Variable Integer IEXIST

  If !clalev([F:AMS]) : Local File AMESSAGE [AMS] : Endif
  Read [AMS]AMS0=CODEWFL
  If fstat Then
    IEXIST = 0
  Else
    IEXIST = 1
  Endif
End
#CHECK UNUSED_END
##############################################################################
# Détermine si une règle de workflow doit être utilisée                      #
##############################################################################
Subprog WFLUSE(CODEWFL, IUSE)
Value Char CODEWFL
Variable Integer IUSE

  # FGR 23/03/2010 : X3SUIVI63397 : utilisation da AWRKPAR, plus AMESSAGE
  If !clalev([F:AWA]) : Local File AWRKPAR [AWA] : Endif
  Read [AWA]AWA0=CODEWFL
  If fstat Then
    IUSE = 0
  Else
    If [F:AWA]ENAFLG = 2 Then
      IUSE = 1
    Else
      IUSE = 0
    Endif
  Endif
End

##############################################################################
# Inclus une chaine dans une formule string$                                 #
##############################################################################
#CHECK UNUSED_BEGIN
Subprog ADDSTRFOR(ISVAR, SZTEXTE)
Value Integer ISVAR
Variable Char SZTEXTE()

  If ISVAR Then
    SZTEXTE = "string$(1, " + SZTEXTE + ")"
  Else
    SZTEXTE = "string$(1, " + '"' + SZTEXTE + '"' + ")"
  Endif
End

##############################################################################
# Crée une nouvelle règle de workflow.                                       #
##############################################################################
Subprog CREWFLRULE(CODEWFL, SZBAKFCT, SZBAKLNK, SZDESTIN, SZCODEVT, SZSUJET, SZCONTENT, ISOK)
Value Char CODEWFL
Value Char SZBAKFCT          #Fonction de retour
Value Char SZBAKLNK          #Clé de lien
Value Char SZDESTIN          #Destinataire
Value Char SZCODEVT          #Code Evènement
Value Char SZEVENT           #Evènement
Value Char SZSUJET()         #Sujet du message
Value Char SZCONTENT()(0..)  #Contenu du message
Variable Integer ISOK        #Statut d'erreur

Local Integer IQ

  ISOK = 1
  If SZCODEVT = "" Then
    GMESSAGE = mess(504,196,1) - CODEWFL   #Erreur lors de la création de la règle workflow : 
    GERR = 1
    ISOK = 0
    End
  Endif
  If !clalev([F:AMS]) : Local File AMESSAGE [AMS] : Endif
  If !clalev([F:AMD]) : Local File AMESSAGED [AMD] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  Call DEBTRANS From GLOCK
  Trbegin [AMS], [AMD]
  #Création de la règle workflow
  #Infos fixes
  [F:AMS]BAKMEN = 1                      #Retour menu
  Filter [ADI] Where [F:ADI]NUMTAB = 51 and [F:ADI]DEFVAL = 2 Order By [F:ADI]CODE Asc
  For [ADI]
    [F:AMS]CATEGORIE = [F:ADI]CODE     #Catégorie
    Break
  Next
  Filter [ADI]
  [F:AMS]CONDITION(0) = "1=1"            #Condition
  [F:AMS]COPIE(0) = 1                    #Option de copie
  [F:AMS]CREDAT = date$                  #Date de création
  [F:AMS]CRETIM = time                   #Heure de création
  [F:AMS]CREUSR = GUSER                  #Créé par
  [F:AMS]DEBUG = 1                       #Mise au point
  [F:AMS]DESIG = CODEWFL                 #Intitulé
  [F:AMS]ENAFLG = 2                      #Actif
  [F:AMS]ENALOG = 1                      #Log actif
  [F:AMS]ENAMES = 2                      #Message actif
  [F:AMS]INTERV = 1                      #Message modifiable
  [F:AMS]NBBAS = 0                       #Nombre de pas de page
  [F:AMS]NBCOND = 1                      #Nombre de conditions
  [F:AMS]NBDEST = 1                      #Nombre de destinataires
  [F:AMS]NBNAT = 0                       #Nombre de natures
  [F:AMS]RETOUR = 2                      #Icône de retour
  [F:AMS]TYPDES(0) = 1                   #Type de destinataire
  [F:AMS]TYPEVT = 1                      #Type d'évènement (Divers)
  [F:AMS]OPERATION = ""                  #Code opération
  #Infos paramétrés
  [F:AMS]CODE = CODEWFL                  #Code de la règle de workflow
  [F:AMS]BAKFCT = SZBAKFCT               #Fonction de retour
  [F:AMS]BAKLNK = SZBAKLNK               #Clé de lien
  [F:AMS]DESTIN(0) = SZDESTIN            #Destinataire
  [F:AMS]CODEVT = SZCODEVT               #Code évènement
  [F:AMS]EVENEMENT = SZCODEVT            #Evènement
  [F:AMS]SUJET = SZSUJET                 #Sujet du message
  Write [AMS]
  If fstat Then
    GMESSAGE = mess(504,196,1) - CODEWFL   #Erreur lors de la création de la règle workflow : 
    GERR = 1
    Rollback
    ISOK = 0
  Endif
  #Si il y a un problème, pas la peine de continuer
  If !ISOK Then
    End
  Endif
  #Définition du contenu du message
  For IQ = 0 To dim(SZCONTENT)-1
    #Lorsqu'il n'y a plus de lignes on sort.
    If SZCONTENT(IQ) = "" Then
      Break
    Endif
    [F:AMD]CODE = CODEWFL
    [F:AMD]LIG = IQ + 1
    [F:AMD]SAUTLG = 2
    [F:AMD]TEXTE = SZCONTENT(IQ)
    Write [AMD]
    If fstat Then
      GMESSAGE = mess(504,196,1) - CODEWFL   #Erreur lors de la création de la règle workflow : 
      GERR = 1
      Rollback
      ISOK = 0
    Endif
    If !ISOK Then
      Break
    Endif
  Next
  #Si il y a un problème, pas la peine de continuer
  If !ISOK Then
    End
  Endif
  Commit
End

##################################################
$MNGDVAADI
  Filter [DVA] Where [F:DVA]OBC = "FLW" and [F:DVA]PARAM = SZCODEVT
  For [DVA]
    If [F:DVA]ALHX(0) <> "" Then
      Delete [ADI] Where [F:ADI]NUMTAB = 908 and [F:ADI]CODE = [F:DVA]ALHX(0)
      If fstat Then
        GMESSAGE = mess(504,196,1) - CODEWFL   #Erreur lors de la création de la règle workflow : 
        GERR = 1
        Rollback
        ISOK = 0
        Break
      Endif
    Endif
  Next
  Filter [DVA]
  If ISOK = 0 Then
    Return
  Endif
  Delete [DVA] Where [F:DVA]OBC = "FLW" and [F:DVA]PARAM = SZCODEVT
  If fstat Then
    GMESSAGE = mess(504,196,1) - CODEWFL   #Erreur lors de la création de la règle workflow : 
    GERR = 1
    Rollback
    ISOK = 0
    Return
  Endif
  #Il faut obtenir un code événement qui garantie un fonctionnement correct
  Call CPTEVTKEY(SZDVACODEVT)
  If SZDVACODEVT = "" Then
    GMESSAGE = mess(504,196,1) - CODEWFL   #Erreur lors de la création de la règle workflow : 
    GERR = 1
    Rollback
    ISOK = 0
    Return
  Endif
  Raz [F:ADI]
  [F:ADI]NUMTAB = 908
  [F:ADI]CODE = SZDVACODEVT
  [F:ADI]CREDAT = date$
  [F:ADI]CREUSR = GUSER
  Write [ADI]    
  If fstat Then
    GMESSAGE = mess(504,196,1) - CODEWFL   #Erreur lors de la création de la règle workflow : 
    GERR = 1
    Rollback
    ISOK = 0
    Return
  Endif
  Raz [F:DVA]
  [F:DVA]OBC = "FLW"
  [F:DVA]PARAM = SZCODEVT
  [F:DVA]ALHX(0) = SZDVACODEVT
  Write [DVA]    
  If fstat Then
    GMESSAGE = mess(504,196,1) - CODEWFL   #Erreur lors de la création de la règle workflow : 
    GERR = 1
    Rollback
    ISOK = 0
    Return
  Endif
Return

##########################################################################################
# Calcul un code d'évenement divers dans la table diverse 908
##########################################################################################
Subprog CPTEVTKEY(SZFREECODE)
Variable Char SZFREECODE

Local Integer ICOUNT

  SZFREECODE = "1"
  ICOUNT = 1
  While 1
    Read [ADI]CODE=908;SZFREECODE
    If fstat Then
      Break
    Else
      ICOUNT += 1
      SZFREECODE = num$(ICOUNT)
    Endif
  Wend
End

##########################################################################################
# Renvoie le code de table diverse 908 correspondant à un évènement CRM
##########################################################################################
Subprog GETEVTADICOD(SZEVT, SZADICOD)
Value Char SZEVT
Variable Char SZADICOD

  SZADICOD = ""
  If SZEVT = "" Then
    End
  Endif
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  Read [DVA]DVA0="FLW";SZEVT
  If !fstat Then
    SZADICOD = [F:DVA]ALHX(0)
  Endif
End
#CHECK UNUSED_END
##########################################################################################
#Workflow envoyé lors d'une couverture commerciale de demande de service.  
##########################################################################################
Subprog DOCRMSRE1(IDOCRMSRE1)
Value Integer IDOCRMSRE1

Local Integer IASK
Local Integer ISOK
Local Char SZCODEWF(GLONAWA)
# FGR 23/03/2010 : X3SUIVI63397 Pas d'accord avec une création de règle automatique (début)
#Local Char SZDESTIN(250)
#Local Char SZSUJET(250)
#Local Char SZCONTENT(250)(4)
# FGR 23/03/2010 : X3SUIVI63397 Pas d'accord avec une création de règle automatique (fin)

  If !IDOCRMSRE1 Then
    End
  Endif
