#<AdxTL>@(#)0.0.0.0 $Revision$ 
Local Char PARAM(20)(1) , VALEUR(20)
End

$ACTION
  Case [L]ACTION
    When "INIT"       : Gosub INIT
    When "DEBUT"      : Gosub DEBUT
    When "CONTROLE"   : Gosub CONTROLE
    When "EXEC"       : Gosub EXEC
    When "OK"         : Gosub OK
    When "END"        : FIN = 1
  Endcase

Return

$INIT
#open file
  If clalev([F:HREDM])=0 : Local File EMPLODIRNUM [HREDM] : Endif

#open screen
  Local Mask MATDIRNUM [MDN] : Raz [MDN]

Return

$DEBUT
#populate screens on startup
  Raz [M:MDN]
  [M:MDN]REFNUM = PARAM(1)

#populate detail
  nolign = 0
  For [F:HREDM]EDM0 Where [F:HREDM]REFNUM=[M:MDN]REFNUM
    nolign += 1
    [M:MDN]=[F:HREDM]
  Next
  [M:MDN]NBRMDN=nolign

#refresh screens
  Affzo [M:MDN]

Return

$CONTROLE
  If GSTATUT<>GSTAOK
   FIN = 1
  Else
   TMP = 1
   TRA = 1
  Endif

Return

$OK
  FIN = 1 : GOK = 1

Return

$EXEC
  OK=1

  Trbegin [F:HREDM]

  Delete [F:HREDM] Where [F:HREDM]REFNUM=[M:MDN]REFNUM
  If fstat=1 | fstat>5
    GOK=0 : OK=0
    Call RSTA("HREDM",[M:MDN]REFNUM) From GLOCK : Return
  Endif

  If OK
    For nolign=1 To [M:MDN]NBRMDN
      Raz [F:HREDM]
      [F:HREDM] = [M:MDN]
      Write [F:HREDM]
      If fstat
        GOK=0 : OK=0
        Call FSTA("HREDM") From GLOCK : Break
      Endif
    Next nolign
  Endif

  If !OK
    Rollback
    Return
  Endif

  Commit

Return




