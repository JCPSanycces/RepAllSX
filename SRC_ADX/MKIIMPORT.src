#<AdxTL>@(#)3.0.0.0 $Revision$
Call IMPORTATION("MKI") From GIMPOBJ
End

###################################################################################
$ACTION
Case ACTION
    When "EXPORT" :        Gosub EXPORT
    When "EXP_ZONE"      : Gosub EXP_ZONE
    When "IMP_ZONE"      : Gosub IMP_ZONE
    When "IMP_FERME"     : Gosub IMP_FERME
Endcase
Return

###################################################################################
$EXPORT
Raz GIMP(1), GIMP(2), GIMP(3), GIMP(4) # FQ 54982 GA 06/2009
If clalev ([F:MTK]) = 0 : Local File MFGHEADTRK  [MTK] : Endif
Read [F:MTK]MTK0 = [F:MKI]MFGTRKNUM
# 57336 Modification du nombre de paramètres de SETDATE
If !fstat : Call SETDATE([F:MTK]MFGTRKDAT,GIMP(1),[F:AOE]OPTDAT) From SUBEXPOBJ : Endif
Return

#######################################################################
$EXP_ZONE
# 57336 Modification du nombre de paramètres de SETDATE
Case EXPZON
  When "GIMP(1)"    : Read [F:MTK]MTK0 = [F:MKI]MFGTRKNUM
                      If !fstat : Call SETDATE([F:MTK]MFGTRKDAT,GIMP(1),[F:AOE]OPTDAT) From SUBEXPOBJ : Endif
  When "GIMP(2)"    : If dim(GMKITRSNUM)>0 GIMP(2)=GMKITRSNUM Endif     # FQ 54982 GA 06/2009
  When "GIMP(3)"    :
  When "GIMP(4)"    :
  When Default

Endcase

Return
######################################################
# Ouvertures
########################################################
# GIMP :                                               #
#     GIMP(1) : Date du suivi                          #
#     GIMP(2) : Transaction de decl prod    à utiliser #
#     GIMP(3) : Indicateur de solde                    #
#     GIMP(4) : Qté rejetée                            #
########################################################
$OUVRE
Local   Char    WMESSAGE(250)
Global  Char    GMILNUM(GLONTRS)
Global  Integer G_DATOK, G_TRSOK,  G_CLEFLGOK,G_IMPQTYREJ
Global  Integer G_LIN,   G_WNBITM, G_WNBMAT
Global  Integer G_WITMCLENBR,      G_WMATCLENBR
Global  Decimal G_WCPLQTY, G_WREJCPLQTY, G_WQUACPLQTY
Global  Decimal G_WWREJQTY              # Issue GA 07/2013

Global  Date    G_DATE
# Issue 86522 - 2013-03-06 by CCC : sauvegarde du site précédent
Global  Char    G_FCY(GLONFCY)
Global  Char    G_MFGNUM(GLONVCR),G_WMFGNUM(GLONVCR),G_MFGTRKNUM(GLONVCR)
Global Integer  GMFILIN: GMFILIN = 1


Local Integer DEBENR_SVG, LCOMMIT
Local Integer WMKIFLG : WMKIFLG=1
Local Integer WADXSEK, NBENR_SVG, WERR
#
#Pour savoir si date de suivi,transaction à utiliser et indicateur de solde sont paramétrées
Call TST_CHAMP("MKI","*1",G_DATOK)     From SUBIMPOBJ    : # date du suivi
Call TST_CHAMP("MKI","*2",G_TRSOK)     From SUBIMPOBJ    : # Transaction de suivi des temps
Call TST_CHAMP("MKI","*3",G_CLEFLGOK)  From SUBIMPOBJ    : # Indicateur de solde
Call TST_CHAMP("MKI","*4",G_IMPQTYREJ) From SUBIMPOBJ   :  # quantité rejetée
#Call TST_CHAMP("MKI","*5",G_SLOOK)     From SUBIMPOBJ   :  # Sous-lot
#Call TST_CHAMP("MKI","*6",G_LOCOK)     From SUBIMPOBJ   :  # Emplacement
#Call TST_CHAMP("MKI","*7",G_PALNUMOK)  From SUBIMPOBJ   :  # Palnum
#Call TST_CHAMP("MKI","*8",G_CTRNUMOK)  From SUBIMPOBJ   :  # Ctrnum
#
If clalev([M:ORDK])=0 : Local Mask ORDK      [ORDK] : Endif  # pour générer encours
If clalev([M:STW])=0  : Local Mask STOWORK   [STW]  : Endif  # masque STOCK
If clalev([M:ENTW])=0 : Local Mask STOENTW   [ENTW] : Endif  # masque de travail entrée
If clalev([M:SOW])=0  : Local Mask STOSORW   [SOW]  : Endif  # masque de travail sorties
If clalev([M:ALP])=0  : Local Mask ALLPAR    [ALP]  : Endif  # masque de travail sorties
If clalev([M:MBI])=0  : Local Mask MTKBENCHI [MBI]  : Endif  # masque plan de production
If clalev([M:MTIK])=0 : Local Mask MTIK      [MTIK] : Endif  # masque buffer decl prod
If clalev([M:MTMK])=0 : Local Mask MTMK      [MTMK] : Endif  # masque buffer suivi matière
If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif
If !clalev([M:VALW]) Local Mask STOVALW [VALW] : Endif
#
If clalev([F:BOH])<=0 : Local File BOM        [BOH] : Endif
If clalev([F:BOD])<=0 : Local File BOMD       [BOD] : Endif
If clalev([F:ITM])<=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF])<=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITV])<=0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITG])<=0 : Local File ITMCATEG   [ITG] : Endif
If clalev([F:MFG])<=0 : Local File MFGHEAD    [MFG] : Endif
If clalev([F:MFI])<=0 : Local File MFGITM     [MFI] : Endif
If clalev([F:MFM])<=0 : Local File MFGMAT     [MFM] : Endif
If clalev([F:MFO])<=0 : Local File MFGOPE     [MFO] : Endif
If clalev([F:MTK])<=0 : Local File MFGHEADTRK [MTK] : Endif
If clalev([F:MKI])<=0 : Local File MFGITMTRK  [MKI] : Endif
If clalev([F:MKM])<=0 : Local File MFGMATTRK  [MKM] : Endif
If clalev([F:TCA])<=0 : Local File TABCOUAFF  [TCA] : Endif
If clalev([F:TBO])<=0 : Local File TABBOMALT  [TBO] : Endif
If clalev([F:STO])<=0 : Local File STOCK      [STO] : Endif
If clalev([F:STC])<=0 : Local File STOLOC     [STC] : Endif
If clalev([F:STJ])<=0 : Local File STOJOU     [STJ] : Endif
If clalev([F:STL])<=0 : Local File STOLOT     [STL] : Endif
If clalev([F:STS])<=0 : Local File STOSER     [STS] : Endif
If clalev([F:ORD])<=0 : Local File ORDERS     [ORD] : Endif
If clalev([F:FCY])<=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:BTS])<=0 : Local File BENCHTRS   [BTS] : Endif
If clalev([F:DTR])<=0 : Local File DIETRS     [DTR] : Endif
If clalev([F:ADP])<=0 : Local File ADOPAR     [ADP] : Endif
If clalev([F:ADW])<=0 : Local File ADOVAL     [ADW] : Endif
If clalev([F:SRU])<=0 : Local File TABSTORUL  [SRU] : Endif
If clalev([F:CAL])<=0 : Local File CPTANALIN  [CAL] : Endif

If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif

# Issue 86725 GA 07/2014 see CHARG_PARAM
#Récupération du compteur
#Local Integer WOK
#Call LECTCA(8,WOK) From SUBTCA
#If WOK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
#GCODNUM    = [F:TCA]CODNUM(2)   # compteur suivi
#GMANCOU    = [F:TCA]MANCOU(2)
#GOPS       = [F:TCA]CODNUM(4)   # compteur encours opérations
Raz G_LIN, G_DATE, G_FCY

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub CHARG_PARAM
#----- Globales à definir pour import stock -----#
Global Char     GSTK_ACTION(20)                               : # Nom de l'action
Global Char     GSTK_BASTAB(20) : GSTK_BASTAB="[M:MBI]NBLIG"  : # Nom variable bas tableau
Global Libelle  GSTK_TRSTYP     : GSTK_TRSTYP=5               : # Type mouvement (M.704)
Global Libelle  GSTK_VCRTYP     : GSTK_VCRTYP=15              : # Type pièce (M.701)
Global Libelle  GSTK_TRACE      : GSTK_TRACE =1               : # Trace détaillée si =2

#-----
If GSTOTRACE>2  GSTK_TRACE=2 : Endif
#-----
If GSTK_TRACE=2
  Call ECR_TRACE(mess(27,115,1)-"OUVRE"+space$(17)+"From IMPSMRS",0) From GESECRAN
Endif
# Issue GA 07/2013 déjà fait dans CHARG_PARAM
#If G_TRSOK            : Read [F:BTS]BTS0 = 62;GIMP(2)
#                        If fstat
#                           Read [F:BTS]BTS0 = 62;GMKITRSNUM
#                           If fstat : OK = 0 : Return : Endif
#                        Endif
#Else
#                        Read [F:BTS]BTS0 = 62;GMKITRSNUM
#                        If fstat : OK = 0 : Return : Endif
#Endif
Gosub FLD_MODELE From TRTX3IMP
GSTK_ACTION="OUVRE" : Gosub ACTION From STKIMP
[L]WSTK_ABRTTR="BTS" : # Abréviation table transaction de saisie
Raz [M:ENTW]
[M:ENTW]WZONPCU = "UOM"
[M:ENTW]WZONQUC = "UOMCPLQTY"
[M:ENTW]WZONCCS = "UOMSTUCOE"
[M:ENTW]WZONSTU = "STU"
[M:ENTW]WZONQUS = "CPLQTY"
[M:ENTW]WZONSTOUPD = ""

GFONC1 = "FUNBENCHI"
Gosub STK_INILOC From STKLOC
Gosub DECL_SVG

Return

####################################################
$CHARG_PARAM
Local Char     MKIPARAM(10)
Global Char    GMKITRSNUM(GLONTRS)
Global Libelle GMTKALLMGT
Gosub CHARG_PARAM From FUNBENCHI

# Issue 81181 - 2012-03-29 by CCC : Récupération de la transaction par défaut
If G_TRSOK            : Read [F:BTS]BTS0 = 62;GIMP(2)
                        If fstat
                           Read [F:BTS]BTS0 = 62;GMKITRSNUM
                           If fstat
                               OK = 0 : GOK = 0
                           Else
                               GMILNUM=GMKITRSNUM
                           Endif
                        Else
                               GMILNUM=GIMP(2)
                        Endif
Else
                        Read [F:BTS]BTS0 = 62;GMKITRSNUM
                        If fstat
                            OK = 0 : GOK = 0
                        Else
                            GMILNUM=GMKITRSNUM
                        Endif
Endif
If GOK = 0
        WMESSAGE = mess(6,199,1)+"BTSNUM" - [F:MKI]ITMREF
        Call ECR_TRACE(WMESSAGE,1) From GESECRAN
Endif
Call GETCPY(GFCY,"BTS",62,GMILNUM) From TRTX3CPT

#Call PARAM(GFCY,"MKITRSNUM",MKIPARAM) From ADOVAL
#GMKITRSNUM = MKIPARAM

# Allocation à l'OF obligatoire
#Call PARAM(GFCY,"MTKALLMGT",MKIPARAM) From ADOVAL
#GMTKALLMGT = val(MKIPARAM)

# Issue 86725 GA 07/2014 idem 72699/SUBMTKA Change counter when change current site
#Récupération du compteur
Local Integer WOK
Call LECTCA(8,WOK) From SUBTCA
If WOK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
GCODNUM    = [F:TCA]CODNUM(2)   # compteur suivi
GMANCOU    = [F:TCA]MANCOU(2)
GOPS       = [F:TCA]CODNUM(4)   # compteur encours opérations

Return

######################################################
# Réinitialisation après création (début de lecture)
$RAZCRE
Raz [M:MTIK]
If GSTK_TRACE=2
  GSTK_ACT="RAZCRE" : GSTK_PGM="MKIIMPORT" : Gosub TRACE_DETAILLEE From STKIMP
Endif

GSTK_ACTION="RAZCRE" : Gosub ACTION From STKIMP
# 11.06 demande 38391
GREP="C"
Return

######################################################
$SAIMSK
#------------------------------------------------------------------------------------#
# Chargement masques écrans, appelé directement depuis le traitement généré WWIxxxxx #
#------------------------------------------------------------------------------------#
Local Integer WERR,WRET

If IMPFIC<>"MKI" : WMKIFLG=0 :Endif # Permet de savoir si on importe autre chose que seulement le suivi

Case IMPFIC
  When "MKI"
      # 11.06 demande 38391
      WDEBENR_B = adxseek("IMP")
      # 03.07 Demande 40150 Raz à la place de effzo
      Raz [M:MBI]
      Raz [M:ENT]
      Call DELSTOENTW(-1,-1,"MBI",1,1,[M:MBI]FCY,0,"") From STKENT
      nolign = 1
      indice = 0
      # Issue 85182 - 2012-10-25 by CCC
      Raz [F:CAL]
      [M:MBI] = [F:MKI]
      [M:MBI]FCY = [F:MKI]MFGFCY
      # Report Issue 93631 GA 03/2014 suite Issue 91583 GA 09/2013 valeurs par défaut
      # Issue 101146 - 2015-12-11 by BEEBE : check only existance of field and set min value depending from product
      #If dim([M:MBI]SLO)>0 & [M:MBI]SLO(indice)<>"" & [M:MBI]NBSLO(indice)=0
      #    M:MBI]NBSLO(indice)=1
      #Endif
      # Issue 98435 GA 03/2014 statut par défaut après lecture SRU
      #If [M:MBI]STA(indice)="" [M:MBI]STA(indice)="A" Endif

      # Issue 81181 - 2012-03-29 by CCC : Récupération de la transaction par défaut
      #Call GETCPY([M:MBI]FCY,"BTS",62,GMKITRSNUM) From TRTX3CPT    # alimentation de GSOCIETE et GTYPGEN
      If [M:MBI]FCY <> GFCY
           GFCY = [M:MBI]FCY
           Gosub CHARG_PARAM
      Elsif GIMP(2)<>"" & GIMP(2)<>[F:BTS]BTSNUM
          # Issue 81873 - 2012-07-03 by CCC : Utiliser les valeurs GIMP(x) avant VALID
          If G_TRSOK            : Read [F:BTS]BTS0 = 62;GIMP(2)
                                  If fstat
                                     Read [F:BTS]BTS0 = 62;GMKITRSNUM
                                  Endif
          Else
                                  Read [F:BTS]BTS0 = 62;GMKITRSNUM
          Endif
          If fstat
                  WMESSAGE = mess(6,199,1)+"BTSNUM" - [F:MKI]ITMREF
                  Call ECR_TRACE(WMESSAGE,1) From GESECRAN
                  OK = 0
                  GOK = 0
          Endif
      Endif
      [M:MBI]TRSCOD = [F:BTS]TRSCOD
      If [M:MBI]MFGNUM(nolign-1)  <> ""
         Read [F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MKI]MFGLIN
         If !fstat : [M:MBI]BOMALT(nolign-1) = [F:MFI]BOMALT : Endif
         [M:MBI]PRODTYP(nolign-1) = 1
      Else
           [M:MBI]PRODTYP(nolign-1) = 2
      Endif
      If [F:MFI]LOT <> "" : [M:MBI]LOT(nolign-1) = [F:MFI]LOT : Endif
      If G_DATOK
          Call SETDATE([M:MBI]IPTDAT(nolign-1),GIMP(1),[M:AOE1]OPTDAT,WERR) From SUBIMPOBJ
          If WERR : WMESSAGE = mess(6,199,1)+"IPTDAT" - [M:MBI]ITMREF
               Call ECR_TRACE(WMESSAGE,1) From GESECRAN
               OK = 0
               GOK = 0
          Endif
      Else
          [M:MBI]IPTDAT(nolign-1) = date$
      Endif

      If [F:ITM]ITMREF<>[F:MKI]ITMREF
        Read [ITM] ITM0=[F:MKI]ITMREF
        If fstat  Raz [F:ITM] : Endif
      Endif
      If [F:ITF]ITMREF<>[F:MKI]ITMREF | [F:ITF]STOFCY <> [F:MKI]MFGFCY
        Read [ITF] ITF0=[F:MKI]ITMREF;[F:MKI]MFGFCY
        If fstat  Raz [F:ITF] : Endif
      Endif

      # Issue 101146 - 2015-12-22 by BEEBE : check only existance of field and set min value, when product
      #                                      is managed by lot / sublot
      If dim([M:MBI]SLO)>0 & [M:MBI]NBSLO(indice)=0 & [F:ITM]LOTMGTCOD=4
         [M:MBI]NBSLO(indice)=1
      Endif

      If G_IMPQTYREJ      # Issue GA 07/2013 à faire dans SAIMSK
         G_WWREJQTY = val(GIMP(4))
      Endif
      # Issue 93975 GA 11/2013
      Call LECSRU([F:MKI]MFGFCY,[F:ITM]TCLCOD,5,[M:MBI]TRSCOD,"",WRET) From STKLIB
      If [M:MBI]UOM(nolign-1) = "" : [M:MBI]UOM(nolign-1) =   [F:ITM]STU : Endif
      # Issue 98435 GA 03/2014 statut par défaut après lecture ITM et SRU
      If [M:MBI]STA(indice)=""
          Local Char    WSTADEF(GLONSTA)
          Call STKINISTA(WSTADEF,"",[F:ITF]QUAFLG) From STKACT
          [M:MBI]STA(indice)=WSTADEF
      Endif
      [M:MBI]NBLIG = 1
      Default File [MKI]  : # Voir si utile ?
      If GSTK_TRACE=2
         GSTK_ACT="SAI_NBLIG" : GSTK_PGM="W0MTKBENCHI" : Gosub TRACE_DETAILLEE From STKIMP
      Endif
      Default Mask [MBI]
      Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
      #11.06 suite aux tests pour demande 38391
      status = 82
      Call SAI_NBLIG("MKI","IMP_ZONE","SUBIMPOBJ") From W0MTKBENCHI
      Setmode

      # Issue 81873 - 2012-08-03 by CCC : la zone est initialisée dans SAI_NBLIG il faut donc l'alimenter après
      If G_CLEFLGOK : [M:MBI]CLEFLG(nolign-1) = val(GIMP(3))
      Else          : [M:MBI]CLEFLG(nolign-1) = 3
      Endif

      If mkstat
          GREP="" : REP="" : mkstat=0 : GOK=0
      Else
          Gosub AAPRES_NBLIG From FUNBENCHI
      Endif
  When "CAL"
    #---------------------------------------------------------------------#
    # Traitement des sections analytiques des lignes de production        #
    #---------------------------------------------------------------------#
    [F:CAL]ABRFIC="MKI"
    [F:CAL]VCRTYP=0
    Call IMPORT_ACCCCE(0,"","","[M:MBI]CCE") From TRTX3CPT
    nolign=1 : status=75 : # Modif élément
    #-----
    If GSTK_TRACE=2
      GSTK_ACT="SAI_NBLIG" : GSTK_PGM="W0MTKBENCHI" : Gosub TRACE_DETAILLEE From STKIMP
    Endif
    Default Mask [MBI]
    indice=nolign-1 : mkstat=0
    GNBAFF=0
    Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
    Call SAI_NBLIG("CAL","IMP_ZONE","SUBIMPOBJ") From W0MTKBENCHI
    If mkstat  NBERR+=1 : Call TRACE2(2,GMESSIMP,-10) From SUBIMPOBJ : Endif
    Setmode
    If mkstat  GREP="" : REP="" : mkstat=0 : GOK=0 :  Endif
    #-----
  When "STJ"
    # 11.06 demande 38391
    WDEBENR_B = adxseek("IMP")
    GSTK_ACTION="SAIMSK" : Gosub ACTION From STKIMP
    If mkstat  GREP="" : REP="" : mkstat=0 : GOK=0 :  Endif
    #-----
Endcase
If GOK<1
  GOK=1
  LCOMMIT=1
  Gosub FIN_DOC
  LCOMMIT=0
  GOK=0
Endif
Return

######################################################
$IMP_ZONE
If dim([L]WTST_CHAMP)<1  Local Libelle  WTST_CHAMP : Endif

Case IMPFIC
  When "MKI"
    #----- Pas de contrôle si les sections sont importées avec "CAL" -----#
    Case IMPZON
      When "CCE1", "CCE2", "CCE3", "CCE4", "CCE5", "CCE6", "CCE7", "CCE8", "CCE9", "CCE10",
&          "CCE11","CCE12","CCE13","CCE14","CCE15","CCE16","CCE17","CCE18","CCE19","CCE20"
          If find("CPTANALIN",[M:AOE1]FLGFIL(0..[M:AOE1]NBRFLG))
             OK=0 : mkstat=1
          Endif
        #-----
      When Default :
          IMPMOD=1
    Endcase
  When "CAL"
    #----- La zone présente dans le modèle a déjà été chargée par IMPORT_ACCCCE du $SAIMSK
    If find("[F:CAL]"+IMPZON+"(0)",[M:AOE2]ZONMSK1)
      If GSTK_TRACE=2
        GSTK_ACT="IMP_ZONE("+IMPZON+")" : GSTK_PGM="MKIIMPORT"
        Gosub TRACE_DETAILLEE From STKIMP
      Endif
      IMPMOD=1
    Endif
    OK=0
    #-----
  When "STJ"
      GSTK_ACTION="IMP_ZONE" : Gosub ACTION From STKIMP
Endcase
Return

######################################################
# Contrôles et mises à jour
$VALID
If GOK<=0
    Goto FIN_VALID
Endif
If GREP=""
    Raz GSTK_NBLIG
    OK=0
    Goto FIN_VALID
Endif

If [M:MBI]UOMCPLQTY(0) = 0
    WMESSAGE = mess(28,190,1) - [M:MBI]MFGNUM(0)-[M:MBI]ITMREF(0)
    Call ECR_TRACE(WMESSAGE,1) From GESECRAN
    OK = 0
    GOK = 0
    LCOMMIT=1
    # Issue 78484 & 78521 - 2011-12-12 by CCC : il faut continuer pour fermer la transaction
    #Return
    Goto FIN_VALID
Endif

GSTK_ACTION="VALID" : Gosub ACTION From STKIMP
If ![L]OK
   If GMESSAGE<>""  Call ECR_TRACE(GMESSAGE,1) From GESECRAN : Raz GMESSAGE : Endif
   GOK=0
    # Issue 78484 & 78521 - 2011-12-12 by CCC : il faut continuer pour fermer la transaction
    #Return
    Goto FIN_VALID
Endif
# Chargement [MTIK]
Raz [M:MTIK]
[M:MTIK]             = [M:MBI]
[M:MTIK]MFGFCY       = [M:MBI]FCY
Raz [M:MTIK]MFGTRKNUM
# Issue 81181 - 2012-03-29 by CCC : Transaction lue dans SAIMSK
#If G_TRSOK            : Read [F:BTS]BTS0 = 62;GIMP(2)
#                        If fstat
#                           Read [F:BTS]BTS0 = 62;GMKITRSNUM
#                           If fstat : OK = 0 : GOK = 0 : Endif
#                        Endif
#Else
#                        Read [F:BTS]BTS0 = 62;GMKITRSNUM
#                        If fstat : OK = 0 : GOK = 0 : Endif
#Endif
#If GOK = 0
#        WMESSAGE = mess(6,199,1)+"BTSNUM" - [M:MTIK]ITMREF
#        Call ECR_TRACE(WMESSAGE,1) From GESECRAN
#        # Issue 78484 & 78521 - 2011-12-12 by CCC : il faut continuer pour fermer la transaction
#        #Return
#        LCOMMIT=1
#        Goto FIN_VALID
#Endif
[M:MTIK]MATFLG       = [F:BTS]MATFLG
[M:MTIK]MATFLTFLG    = [F:BTS]MATFLTFLG # Issue 79586 - 2012-02-09 by CCC
[M:MTIK]WMATOK       = 1
[M:MTIK]CONSMAT      = [F:BTS]CONSMAT
[M:MTIK]STOCODMAN    = [F:BTS]STOCODMAN
[M:MTIK]ENTCOD       = [F:BTS]ENTCOD
[M:MTIK]TRSFAM       = [F:BTS]TRSFAM
[M:MTIK]TRSCOD       = [F:BTS]TRSCOD
[M:MTIK]ENTCODS      = [F:BTS]ENTCODS
[M:MTIK]TRSFAMS      = [F:BTS]TRSFAMS
[M:MTIK]TRSCODS      = [F:BTS]TRSCODS

If [M:MTIK]MFGNUM <> ""
   [M:MTIK]TYPTRT = 3
   # Issue 81873 - 2012-07-03 by CCC : Utiliser les valeurs GIMP(x) avant VALID
#   If G_CLEFLGOK : [M:MTIK]CLEFLG = val(GIMP(3))
#   Else          : [M:MTIK]CLEFLG = 3
#   Endif
   If [M:MTIK]CLEFLG = 0 : [M:MTIK]CLEFLG = 3 : Endif
Elsif [M:MTIK]ITMREF <> "" & [M:MTIK]BOMALT <> 0
      [M:MTIK]TYPTRT = 7
Else
  # GA 05/2009: on n'a pas les données pour créer un suivi
  # Aucun suivi effectué
   WMESSAGE = mess(28,190,1)-[M:MTIK]ITMREF-num$([M:MTIK]BOMALT)
   Call ECR_TRACE(WMESSAGE,1) From GESECRAN
   GOK=0
   LCOMMIT=1
   Goto FIN_VALID
Endif
#
Gosub CONTROLE_IMP
If !OK
    Call ECR_TRACE(WMESSAGE,1) From GESECRAN
    Call DELSTOENTW(-1,-1,"MBI",1,1,[M:MBI]FCY,1,"") From STKENT
    GOK = 0
    LCOMMIT=1
Else  # CCC (2009-11-13) Bug 57648 : En cas d'erreur on continue pour fermer la transaction mais on ne crée pas la ligne de suivi
    [M:MTIK]STU = [F:ITM]STU
    If GSTK_TRACE=2
      GSTK_ACT='VALID(GREP="'+GREP+'")' : GSTK_PGM="MKIIMPORT" : Gosub TRACE_DETAILLEE From STKIMP
    Endif
    [L]OK=1 : Raz GERREUR
    #-----


    GSTK_ACTION="VALID" : Gosub ACTION From STKIMP
    If ![L]OK
        GOK=0
        LCOMMIT=1
        Goto FIN_VALID
    Endif
    #-----
    If GSTK_TRACE=2
      GSTK_ACT="VERIF_CRE" : GSTK_PGM="GOBJSUB" : Gosub TRACE_DETAILLEE From STKIMP
    Endif


    # Issue 78118 - 2012-01-05 by CCC
    Raz WMESSAGE
    Gosub CRE_SUIVI
    If GOK < 1
        If WMESSAGE<>""
            Call ECR_TRACE(WMESSAGE,1) From GESECRAN
        Endif
         WMESSAGE = mess(254,193,1)
         Call ECR_TRACE(WMESSAGE,1) From GESECRAN
         WMESSAGE = mess(255,193,1)
         Call ECR_TRACE(WMESSAGE,1) From GESECRAN
         Gosub COP_SVG
    Endif
Endif

$FIN_VALID
If LCOMMIT & GOK=0
    GOK=1
    Gosub FIN_DOC
    GOK=0
Else
    Gosub FIN_DOC
Endif
LCOMMIT=0
Return

$FIN_DOC
If IMPFIN | GOK<=0 | LCOMMIT
    If G_WMFGNUM <> "" : Gosub MAJ_ENTOF  : Endif
    If G_WNBITM <> 0    # FQ 54431 il manque le commit ou rollback final
        Gosub CRE_ENTETE
        If GOK < 1
           WMESSAGE = mess(254,193,1)
           Call ECR_TRACE(WMESSAGE,1) From GESECRAN
           WMESSAGE = mess(255,193,1)
           Call ECR_TRACE(WMESSAGE,1) From GESECRAN
           Gosub COP_SVG
        Endif
    Else
        If adxlog <> 0 : Rollback : Endif
    Endif
    OK  = 0
    TRA = 0
Endif
Return

######################################################
# Contrôles
$CONTROLE_IMP
Local Date    WDAT
Local Char    WFCY(GLONFCY)
Local Char    WITM(GLONITM)
Local Integer WALT, WALTTYP, WBOD_OK
Local Integer TABTBO(3)
#Contrôle OF

# Issue 81181 - 2012-03-29 by CCC : déjà fait dans SAIMSK
#Call GETCPY([M:MTMK]MFGFCY,"BTS",62,GMKITRSNUM) From TRTX3CPT    # alimentation de GSOCIETE et GTYPGEN

If [M:MTIK]TYPTRT = 3
    Read [F:MFI]MFI0 = [M:MTIK]MFGNUM;[M:MTIK]MFGLIN
    If fstat : WMESSAGE = mess(174,193,1)+[M:MTIK]ITMREF - [M:MTIK]MFGNUM
               OK = 0
               Return
    Endif
    # sr 01.03 gestion des sous_produits
    [M:MTIK]ITMTYP       = [F:MFI]ITMTYP
    [M:MTIK]CSTFLG       = [F:MFI]CSTFLG
    # si une quantité en "R" a été importée
    If G_IMPQTYREJ
       # Issue GA 07/2013 à faire dans SAIMSK
       #[M:MTIK]WCOEFF2   = (val(GIMP(4)) / [F:MFI]EXTQTY)
       [M:MTIK]WCOEFF2 = G_WWREJQTY / [F:MFI]EXTQTY
       G_WWREJQTY=0
       # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
       # Ce sont les quantités qui sont arrondies
       #[M:MTIK]WCOEFF2   = arr([M:MTIK]WCOEFF2,0.00000001)
    Endif

    If [M:MTIK]MFGFCY = "" : [M:MTIK]MFGFCY = [F:MFI]MFGFCY : Endif
    Read [MFG]MFG0 = [M:MTIK]MFGNUM
    If fstat
       WMESSAGE = mess(151,193,1) - [M:MTIK]MFGNUM
       OK = 0
       Return
    Endif
    #L'OF doit être complet
    If [F:MFG]TYPMOD = 1    : WMESSAGE = mess(51,190,1) - [M:MTIK]MFGNUM : OK = 0 : Return : Endif
    #L'OF doit être ferme et alloué complètement
    If [F:MFG]MFGSTA <> 1   : WMESSAGE = mess(19,190,1) - [M:MTIK]MFGNUM: OK = 0 : Return : Endif
    #Selon paramètre général l'OF doit être alloué complètement
    If   GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0
         WMESSAGE = mess(18,190,1) - [M:MTIK]MFGNUM
         OK = 0
         Return
    Endif
    #Selon paramètre général, l'OF doit être édité
    If  [F:MFG]MFGTRKFLG < 3 &  GDOSFAB = 2
        WMESSAGE = mess(20,190,1) - [M:MTIK]MFGNUM
        OK = 0
        Return
    Endif
    # boucle d'analyse des matières bloquantes si rupture
    # 10.02 Performances
    For [MFM]MFM0 Where MFGNUM = [F:MFG]MFGNUM
        If [F:MFM]SHTQTY <> 0
           Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
           If !fstat & [F:ITF]MFGSHTCOD = 1
              WMESSAGE = mess(105,193,1) - [M:MTIK]MFGNUM +" ("+[F:MFM]ITMREF+")"
              OK = 0
              Break
           Endif
        Endif
    Next
    If OK = 0 : Return : Endif
Elsif [M:MTIK]TYPTRT = 7
    #Contrôle nomenclature
    WITM=[M:MTIK]ITMREF
    WDAT=[M:MTIK]IPTDAT
    WFCY=[M:MTIK]MFGFCY
    WALT=[M:MTIK]BOMALT
    WALTTYP=2
    #    Lecture BOM
    Read [TBO]TBO0=WALTTYP;WALT
    If fstat : WMESSAGE = mess(154,193,1)- [M:MTIK]ITMREF+"/"+num$([M:MTIK]BOMALT) : OK = 0 : Return : Endif
    Read [BOH]BOH0=WITM;WALT;WALTTYP
    If fstat
        WMESSAGE = mess(95,193,1) - [M:MTIK]ITMREF+"/"+num$([M:MTIK]BOMALT)
        OK = 0
        Return
    Endif
    Call CONTMFGNOM(WFCY,WALT,WDAT,1) From MFGLIB
    If WALT=0 : OK = 0 : Return : Endif
Endif
# controle site
Call LECTURE("FCY",[M:MTIK]MFGFCY,"") From CONTOBJ
If fstat | [F:FCY]MFGFLG <> 2
    WMESSAGE = mess(1,193,1) - [M:MTIK]MFGFCY
    OK = 0
    Return
Endif
If [M:MTIK]MFGFCY <> GFCY
   GFCY = [M:MTIK]MFGFCY
   Gosub CHARG_PARAM
Endif
# controle article
If [F:ITM]ITMREF <> [M:MTIK]ITMREF
   Read [ITM]ITM0 = [M:MTIK]ITMREF
   If fstat
      WMESSAGE = mess(134,100,1) - [M:MTIK]ITMREF
      OK = 0
      Return
   Endif
Endif
#
# controle article-site
If [F:ITF]ITMREF <> [M:MTIK]ITMREF | [F:ITF]STOFCY <> [M:MTIK]MFGFCY
    Read [ITF]ITF0 = [M:MTIK]ITMREF;[M:MTIK]MFGFCY
    If fstat
        WMESSAGE = mess(2,196,1)+" : "+ [M:MTIK]ITMREF - [M:MTIK]MFGFCY
        OK = 0
        Return
    Endif
Endif
#
#VPO 14/05/09 ajout pour interface MES
If [M:MTIK]STA = "" & GACTION="MESINT" & dim([M:DIA]DEFSTA)>0 : #interface MES
[M:MTIK]STA = [M:DIA]DEFSTA
Endif

# sr 01.04 si statut non importé et contrôle qualité, on force "Q"
#          de même si controle non modifiable et statut importé = "A"
If (find([F:ITF]QUAFLG,2,3) & [M:MTIK]STA = "") | ([F:ITF]QUAFLG =2 & left$([M:MTIK]STA,1) = "A")
       [M:MTIK]STA = "Q"
Endif

#Controle de la date
GMESSAGE = ""
Call STKCTRIPT([M:MTIK]IPTDAT, [M:MTIK]MFGFCY, "1") From STKLIB
If GMESSAGE <> "": WMESSAGE = GMESSAGE : GMESSAGE="" : OK = 0 : Return : Endif
Return

######################################################
$CRE_SUIVI
Local Integer STAT
If G_LIN = 0
   G_DATE = [M:MTIK]IPTDAT
   G_FCY = [M:MTIK]MFGFCY
   If [M:MTIK]TYPTRT = 3 : G_MFGNUM  = [M:MTIK]MFGNUM
                           G_WMFGNUM = [M:MTIK]MFGNUM
   Endif
   GOK = 1
   Call DEBTRANS From GLOCK
   Trbegin [MKI]
   Call NUMERO(GCODNUM,[M:MTIK]MFGFCY,G_DATE,"",G_MFGTRKNUM,STAT) From SUBANM
   If STAT
     WMESSAGE = mess(60,199,1)-GCODNUM-num$([L]STAT)
     GOK = 0
     Gosub TR_ROLL
     Return
   Endif
Else
   If [M:MTIK]IPTDAT <> G_DATE | [M:MTIK]MFGFCY <> G_FCY
      If G_WMFGNUM <> ""
         Gosub MAJ_ENTOF
         Raz   G_WMFGNUM
      Endif
      Gosub CRE_ENTETE
      GOK = 1
      Call DEBTRANS From GLOCK
      Trbegin [MKI]
      G_DATE = [M:MTIK]IPTDAT
      G_FCY = [M:MTIK]MFGFCY
      If [M:MTIK]TYPTRT = 3 G_MFGNUM  = [M:MTIK]MFGNUM
                            G_WMFGNUM = [M:MTIK]MFGNUM
      Endif
      Call NUMERO(GCODNUM,[M:MTIK]MFGFCY,G_DATE,"",G_MFGTRKNUM,STAT) From SUBANM
      If STAT
         WMESSAGE = mess(60,199,1)-GCODNUM-num$([L]STAT)
         GOK = 0
         Gosub TR_ROLL
         Return
      Endif
   Else
      If [M:MTIK]MFGNUM <> G_WMFGNUM
         Raz G_MFGNUM
      Endif
      If [M:MTIK]MFGNUM <> G_WMFGNUM & G_WMFGNUM <> ""
         Gosub MAJ_ENTOF
         Raz G_WMFGNUM
         If [M:MTIK]TYPTRT = 3 : G_WMFGNUM = [M:MTIK]MFGNUM : Endif
      Endif
   Endif
Endif
[M:MTIK]ITMTRKLIN    = G_LIN + 1
[M:MTIK]MFGTRKNUM    = G_MFGTRKNUM
[M:MTIK]WNBMAT       = G_WNBMAT
[M:MTIK]WLINUM       = 1
# sr 07.02
[M:MTIK]WITMCLENBR    = G_WITMCLENBR
[M:MTIK]WMATCLENBR    = G_WMATCLENBR

#Appel du moteur de création des déclarations de production
#On a en ligne soit la ligne article lancé soit l'entête de nomenclature
Case [M:MTIK]TYPTRT
    When 3 : If !find([M:MTIK]UOMSTUCOE,0,1)
                 [M:MTIK]CPLQTY = [M:MTIK]UOMCPLQTY * [M:MTIK]UOMSTUCOE
                 Call QTEARR([M:MTIK]CPLQTY,[F:ITM]STU) From TRTDIV
             Else
                 [M:MTIK]CPLQTY = [M:MTIK]UOMCPLQTY
             Endif
             If [M:MTIK]STA = "" : [M:MTIK]STA = "A" : Endif
             [M:MTIK]FMI  = [F:MFI]FMI
             Call CRE_MKI From MTKAUTLIB
             If GOK < 1 : Gosub TR_ROLL : Return
             Else Gosub TRACE_SVG
             Endif
             G_LIN         = [M:MTIK]ITMTRKLIN
             G_WMATCLENBR  = [M:MTIK]WMATCLENBR
             G_WITMCLENBR  = [M:MTIK]WITMCLENBR
             G_WNBITM     += 1
             G_WNBMAT      = [M:MTIK]WNBMAT
             # sr 01.03 gestion des sous-produits
             If [M:MTIK]ITMTYP = 1
                 G_WCPLQTY    += [M:MTIK]WCPLQTY
                 G_WREJCPLQTY += [M:MTIK]WREJCPLQTY
                 G_WQUACPLQTY += [M:MTIK]WQUACPLQTY
             Endif
    When 7 : If [M:MTIK]UOM = ""
                 [M:MTIK]UOM   = [M:MTIK]STU
                 [M:MTIK]UOMCPLQTY = [M:MTIK]CPLQTY
                 [M:MTIK]UOMSTUCOE = 1
             Endif
             If [M:MTIK]STA = "" : [M:MTIK]STA = "A" : Endif
             Call CRE_MKI From MTKAUTLIB
             If GOK < 1 : Gosub TR_ROLL : Return
             Else Gosub TRACE_SVG
             Endif
             G_LIN         = [M:MTIK]ITMTRKLIN
             G_WNBITM     += 1
             G_WNBMAT      = [M:MTIK]WNBMAT
             [M:MTIK]CPLQTY    = [F:MKI]CPLQTY
             [M:MTIK]UOMCPLQTY = [F:MKI]UOMCPLQTY
             Raz [M:MTIK]LOT
             # sr 04.02 gestion des sous-produits  demande 9469
             Call RECHERCHE_SOUS_PRODUIT([M:MTIK]ITMREF)

    When Default :
Endcase
#

Return

$TR_ROLL
#Rollback
#Raz G_MFGNUM, G_WMFGNUM, G_MFGTRKNUM, G_WNBITM, G_WNBMAT, G_LIN
Return

#######################################
$MAJ_ENTOF
#Maj entête d'OF
Readlock [F:MFG]MFG0 = G_WMFGNUM
If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-num$(G_WMFGNUM) : Return
Elsif fstat GOK=0  : Call RSTA("MFG",num$(G_WMFGNUM)) From GLOCK
      Return
Endif
[F:MFG]ITMCLENBR += G_WITMCLENBR
[F:MFG]MATCLENBR += G_WMATCLENBR
If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&  [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&  [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
   [F:MFG]MFGTRKFLG = 5
   # CCC (10/01/08) DM 44021
#   [F:MFG]TRKLAST   = G_DATE
Else
   [F:MFG]MFGTRKFLG = 4
   # CCC (10/01/08) DM 44021
#   Raz [F:MFG]TRKLAST
Endif

# CCC (10/01/08) DM 44021
If [F:MFG]TRKLAST<G_DATE
   [F:MFG]TRKLAST   = G_DATE
Endif
If [F:MFG]TRKLASTC<date$
   [F:MFG]TRKLASTC  = date$
Endif
If [F:MFG]TRKFIRST>G_DATE | [F:MFG]TRKFIRST = "00/00/00"
    [F:MFG]TRKFIRST = G_DATE
Endif
If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
    [F:MFG]TRKFIRSTC = date$
Endif
[F:MFG]CPLQTY    += G_WCPLQTY
[F:MFG]REJCPLQTY += G_WREJCPLQTY
[F:MFG]QUACPLQTY += G_WQUACPLQTY
If [F:MFG]ITMLINNBR = [F:MFG]ITMCLENBR
   [F:MFG]RMNEXTQTY = 0
Else
   [F:MFG]RMNEXTQTY =  [F:MFG]EXTQTY - [F:MFG]CPLQTY
Endif
Call QTEARR([F:MFG]RMNEXTQTY,[F:MFG]STU) From TRTDIV
If [F:MFG]RMNEXTQTY < 0 : [F:MFG]RMNEXTQTY = 0 : Endif
If [F:MFG]CPLQTY >= [F:MFG]EXTQTY : Raz [F:MFG]RMNEXTQTY : Endif
If [F:MFG]RMNEXTQTY > [F:MFG]EXTQTY : [F:MFG]RMNEXTQTY = [F:MFG]EXTQTY : Endif
[F:MFG]UPDDAT    = date$  : # FQ 42680
[F:MFG]UPDUSR    = GUSER  : # FQ 42680
Rewrite [F:MFG]
If fstat
   GOK = 0 : Call FSTA("MFG") From GLOCK : Return
Endif
#----- MISE à jour statistiques entête d'OF -----#
Call VALSTA("MFG",1) From SUBPS2
If GOK < 1 : Return : Endif
Raz G_WMATCLENBR, G_WITMCLENBR
Raz G_WCPLQTY,    G_WREJCPLQTY, G_WQUACPLQTY
Return

#######################################
$CRE_ENTETE
# 04.07 Demande 40752
Local Char WFILTRE(80)
If GOK = 1 & G_WNBITM+G_WNBMAT >0   # FQ 54431
    Raz [F:MTK]
    If G_MFGNUM <> ""
       Read [F:MFG] = G_MFGNUM
       If !fstat : [F:MTK] = [F:MFG] : Endif
    Endif
    [F:MTK]MFGFCY    = G_FCY                # Issue 90461 GA 07/2013 avant GFCY
    [F:MTK]TRSCOD    = [M:MTIK]TRSCOD
    [F:MTK]TRSCODS   = [M:MTIK]TRSCODS
    [F:MTK]MFGTRKNUM = G_MFGTRKNUM
    [F:MTK]MFGTRKDAT = G_DATE
    [F:MTK]OPETRKFLG = 1
    [F:MTK]ITMTRKFLG = 2
    [F:MTK]MATTRKFLG = 1
    [F:MTK]NBRITM    = G_WNBITM
    [F:MTK]NBRMAT    = G_WNBMAT
    If [F:MTK]NBRMAT <> 0 : [F:MTK]MATTRKFLG = 2 : Endif
    [F:MTK]CREDAT    = date$
    [F:MTK]CREUSR    = GUSER
    [F:MTK]EXPNUM    = [C]EXPORT
    Raz [F:MTK]UPDUSR
    Raz [F:MTK]UPDDAT
    Write [F:MTK]
    If fstat : GOK = 0 : Call FSTA("MTK") From GLOCK
    Else
      # GA 05/2009 message déplacé ssi on crée l'entete
        WMSGSUI = [F:MTK]MFGFCY-mess(79,190,1)-[F:MTK]MFGTRKNUM
        TRA = 1
        Call ECR_TRACE(WMSGSUI,0) From GESECRAN
    Endif
Endif
If GOK < 1 : Rollback
    # Enregistrement dans SAS si nécessaire
    If WMKIFLG & [L]AOWSTA=2
        DEBENR_TMP = DEBENR
        WDEBENR_TMP = WDEBENR
        DEBENR = DEBENR_SVG
        WADXSEK = adxseek("IMP")
        OLDIRS = adxirs
        OLDIFS = adxifs
        OLDIUM = adxium
        adxirs = IMPIRS
        adxifs = IMPIFS
        adxium = IMPIUM
        GOK=1
        GNUMAOW=NBENR_SVG+1
        For I=1 To NBENR-NBENR_SVG-2
            Gosub IMPORT_SAS From =NOMTRT
            GNUMAOW+=1

            Seek First + DEBENR Using [IMP]
            Call RD_SEQ(VALIMP,BLBIMP,CLBIMP,IMPFIC,SEPNUMS,IMPFINS,WDEBENR) From SUBIMPOBJ
            DEBENR=adxseek("IMP")
        Next
        IMPSTA=0
        NUMFLD=0
        LIG=0
        Raz [F:AOV], [F:AOW]
        DEBENR = DEBENR_TMP
        WDEBENR = WDEBENR_TMP
        Seek First + WADXSEK Using [IMP]
        GOK=0
        adxirs = OLDIRS
        adxifs = OLDIFS
        adxium = OLDIUM
    Endif
Else       : Commit
             # 04.07 Demande 40752 # CCC (17/11/08) Bug 50329
                WFILTRE="[F:MKI]MFGTRKNUM=[F:MTK]MFGTRKNUM"
                Call REGFROMENT(1,"MKI",WFILTRE,"ITMREF",[F:MTK]MFGFCY) From TRTSHTCOM
             Gosub CLEAR_SVG
             DEBENR_SVG=DEBENR
             Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

NBENR_SVG = G_WNBITM

Raz G_MFGNUM, G_WMFGNUM, G_MFGTRKNUM, G_WNBITM, G_WNBMAT, G_LIN
Return


####################################################################
# sr 04.02 gestion des sous-produits demande 9469
Subprog RECHERCHE_SOUS_PRODUIT(LITM)
Value Char LITM

Local    Integer WTYPMVT
Local    Decimal WDIS
Local    Integer NOL2
Local    Integer LRET

Local File BOMD [BOD] Where ITMREF = LITM & BOMALT = [M:MTIK]BOMALT & BOMALTTYP = 2 &
&                   (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= [M:MTIK]IPTDAT)) &
&                   (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= [M:MTIK]IPTDAT)) &
&                    !find(CPNTYP,5,6)
# lecture premier enregistrement
# 10.02 Performances
Read [BOD]BOD0 First

# tant qu'y en a !
While !fstat
   If [F:ITM]ITMREF <> [F:BOD]CPNITMREF
      Read [F:ITM]ITM0 = [F:BOD]CPNITMREF
      If fstat : Goto NEXTBOD : Endif
   Endif
 # article avec statut non actif
   If [F:ITM]ITMSTA > 1
       Goto NEXTBOD
   Endif
 # lecture article site
   If [F:ITF]ITMREF <> [F:BOD]CPNITMREF | [F:ITF]STOFCY <> [M:MTIK]MFGFCY
      Read [ITF]ITF0=[F:BOD]CPNITMREF;[M:MTIK]MFGFCY
      If fstat : Goto NEXTBOD : Endif
   Endif
# lecture cumuls stocks
    Call LECITV2([M:MTIK]MFGFCY,[F:BOD]CPNITMREF,LRET) From MFGLIB
    # Issue 72149 - 2011-03-08 by CCC : test du code retour de LECITV2
    If LRET : Goto NEXTBOD : Endif
    Call LECSRU([M:MTIK]MFGFCY,[F:ITM]TCLCOD,6,[F:BTS]TRSCOD,"",LRET) From STKLIB
    If LRET = 1 : WDIS = 0
    Else
      Call STODISTOT("",0,[F:SRU]AUZSTA,"",WDIS) From STKLIB
    Endif
 # si article fantôme descente par récursivité
   If ([F:ITM]PHAFLG = 2) & WDIS = 0
          Call RECHERCHE_SOUS_PRODUIT([F:ITM]ITMREF)
   Else
      If [F:BOD]CPNTYP       = 4
          [M:MTIK]ITMTYP     = 2
          [M:MTIK]CSTFLG     = [F:BOD]CSTFLG
          [M:MTIK]ITMREF     = [F:BOD]CPNITMREF
          [M:MTIK]ITMTRKLIN    = G_LIN + 1
          [M:MTIK]MFGTRKNUM    = G_MFGTRKNUM
          [M:MTIK]WNBMAT       = G_WNBMAT
          [M:MTIK]WLINUM       = 1
          Call CRE_MKI From MTKAUTLIB
          If GOK < 1 : Break
         # FQ 58387 on ne doit pas sauvegarder cette ligne dans le fichier erreur
         # Else Gosub TRACE_SVG
          Endif
          G_LIN              = [M:MTIK]ITMTRKLIN
          G_WNBITM          += 1
          G_WNBMAT           = [M:MTIK]WNBMAT
      Endif
    Endif
$NEXTBOD
   Read [BOD]BOD0 Next         # 10.02 Performances
Wend
End

#------------#
# Fin import #
#------------#
$IMP_FERME
# CCC (12/02/09) Bug 52524 : Le commit doit être fait dans le Valid pas dans IMP_FERME qui n'est d'ailleurs plus appelé
#If G_WMFGNUM <> "" : Gosub MAJ_ENTOF  : Endif
