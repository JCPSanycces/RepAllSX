#OK  = 0
#TRA = 0
GREP=""
If GSTK_TRACE=2
  GSTK_ACT="FERME" : GSTK_PGM="GOBJSUB" : Gosub TRACE_DETAILLEE From STKIMP
Endif
GSTK_ACTION="IMP_FERME" : Gosub ACTION From STKIMP
Kill GSTK_ACTION, GSTK_BASTAB, GSTK_TRSTYP, GSTK_VCRTYP, GSTK_TRACE
Return

#####################################################
# Déclaration du fichier sauvegarde
$DECL_SVG
# 11.06 demande 38391
Local Integer WDEBENR_B
MKISVG = filpath("tmp",tolower(GFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"mkisvg")
adxifs = ";"
adxirs = chr$(10)
Gosub CLEAR_SVG
Return

#####################################################
# sauvegarde de l'enregistrement en cours de traitement
$TRACE_SVG
Local Char    OLDIRS(5), OLDIFS(5)
Local Integer OLDIUM, FINENR, NBCAR , NBCAR2
OLDIRS = adxirs
OLDIFS = adxifs
OLDIUM = adxium
adxirs = IMPIRS
adxifs = IMPIFS
adxium = IMPIUM
FINENR = adxseek("IMP")
# 11.06 demande 38391
NBCAR  = WDEBENR-DEBENR
Seek First + DEBENR Using [IMP]
Openo MKISVG , -1 Using [SVG]
While NBCAR>0
 NBCAR2 = min(NBCAR,32000)
 Local Schar CAR(1)(1..NBCAR2)
 Getseq NBCAR2 , CAR Using [IMP]
 Putseq NBCAR2 , CAR Using [SVG]
 NBCAR -= NBCAR2
Wend
Openo Using [SVG]
Seek First + FINENR Using [IMP]
adxirs = OLDIRS
adxifs = OLDIFS
adxium = OLDIUM
Return

#####################################################
# Copie du fichier des sauvegardes dans le fichier erreur du superviseur
$COP_SVG
Local Char    OLDIRS(5), OLDIFS(5)
Local Integer OLDIUM, FINENR, NBCAR , NBCAR2
OLDIRS = adxirs
OLDIFS = adxifs
OLDIUM = adxium
adxirs = IMPIRS
adxifs = IMPIFS
adxium = IMPIUM
Openi MKISVG Using [SVG]
Seek Last Using [SVG]
NBCAR  = adxseek("SVG")
Seek First Using [SVG]
Openo FICERR , -1 Using [ERR]
While NBCAR>0
 NBCAR2 = min(NBCAR,32000)
 Local Schar CAR(1)(1..NBCAR2)
 Getseq NBCAR2 , CAR Using [SVG]
 Putseq NBCAR2 , CAR Using [ERR]
 NBCAR -= NBCAR2
Wend
Openo Using [ERR]
Openi Using [SVG]
Gosub CLEAR_SVG
adxirs = OLDIRS
adxifs = OLDIFS
adxium = OLDIUM
Return

#####################################################
# réinitialisation du fichier des sauvegardes
$CLEAR_SVG
Openo MKISVG , 0 Using [SVG]
Openo MKISVG Using [SVG]
Return

