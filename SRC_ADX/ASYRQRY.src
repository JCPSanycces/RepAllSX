#<AdxTL>@(#)1.0.0.0 $Revision$
Call TEST From ZTEST_ASYRQRY
End

#**
#* Funprog HANDLER_GET()
#*!
Funprog HANDLER_GET(ACTX,ASWK,ARCV,PSYR,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND

Local Integer ERROR : ERROR=[V]CST_AOK

ERROR  = func QRY(ACTX,PSYR,ARCV,ASND,PSYR.CODCLA,PSYR.CODREP,PSYR.CODFAC)
End ERROR

#------------------------------------------------------------------#
Funprog QRY(ACTX,PSYR,ARCV,ASND,CLASSE,REPRES,TYPREP)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance PSYR Using C_ASYR
Variable Instance ARCV Using C_ASYRRCV
Variable Instance ASND Using C_ASYRSND
Value    Char     CLASSE, REPRES , TYPREP

Local Integer ERROR : ERROR=[V]CST_AOK

Local Char    REPNAM(20) , GRPINS(30)
Local Integer I , J , NUMLIN
Local Char    PRGREP(30),PRGPRO(30)
Local Uuident UIDINS

#----------------------------------------------------------------#
# Open file(s) & representation
#----------------------------------------------------------------#

Local Integer NBREP
Local Char    NAMQRY(30)               : # Name query class
Local Char    PRGQRY(30)               : # Program contains subprog base access
Local Char    TBPRO(30)(1..)           : # Name of properties of representation used in where critera
Local Char    TBFIL(30)(1..)            : # Name of properties (Abbreviation & name) of files
Local Integer TBTYP(1..)                : # Types
Local Char    TBPTH(30)(1..)           : # path

Local Char    KEYQRY(250)               : # First key for the read
Local Char    TBORDER_PRO(250)(0..)
Local Char    TBORDER_ASCDES(250)(0..)
Local Integer OASCEND                   : # index order

Local Char    INDEXES(250)(1..2 )       : # For indexes
Local Integer FIRSTPAG                  : # First page of query
Local Char    QKEYS(250)(0..3)          : # Keys

Local Char ACTION(30)        : # Action in query for interface
Local Char CURPTH(250)     :  # For hierarchy
Local Char QFILTER(250)    : #For registered filters
Local Char _AFCRIGHT(GLONAFC) : # for managmeent of right

Local Integer FIRSTPAGE,LASTPAGE
Local Integer ASTATUS

# Init presentation / query
PRGQRY = func SUBASW.PREFIX_QRYTRT+REPRES : # WMQRY
NAMQRY = func SUBASW.PREFIX_REP+REPRES    : # R_
PRGREP = func SUBASW.PREFIX_TRT+REPRES    : # WMREP
PRGPRO = func APREFIXTRT.GET_PREFIX_JSO+REPRES

 Call EXISTE_ADX("","",PRGREP,ASTATUS) From ASYRSYS
 If ASTATUS <> 1 : End 9006 : Endif


Local Instance PQRY     Using C_AQUERY   : # Instance containing parameters of query (From, Order; ..)
Local Instance QRY(1..) Using =NAMQRY    : # Instance containing datas query representation
Local Instance RQRY     Using C_AREPENT  : # Representation containing metadatas (infos about representation & properties)

# Load parameter representation
REPNAM = "QRY"
GRPINS = REPNAM

PRGREP = func SUBASW.PREFIX_TRT+REPRES : # WMREP
Call DESCRIPTION_REPRESENTATION(RQRY,REPNAM) From =PRGREP
If  TYPREP = "$query" & (dim(RQRY.AENAFAC)>0 & RQRY.AENAFAC(3)<>2) or TYPREP="$lookup" & (dim(RQRY.AENAFAC)>0 & RQRY.AENAFAC(4)<>2 )
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_CONFLICT,func ASYRFNC.MES2(mess(14,149,1),PSYR.CODFAC,PSYR.CODREP))
 Goto ERR_DETAIL
Endif

RQRY.FCT = TYPREP
[L]_AFCRIGHT = RQRY.AFCRIGHT

# Init Instance
PQRY = NewInstance C_AQUERY AllocGroup null

#Local Instance WQRY Using ="C_"+RQRY.CLA
Onerrgo ERR_LOAD_CLASS
Local Instance WQRY Using ="C_"+CLASSE
Onerrgo
If ERROR : Goto ERR_DETAIL : Endif

#----------------------------------------------------------------#
# Decode parameters
#----------------------------------------------------------------#
Raz TBPRO,TBFIL,TBTYP,TBPTH

PQRY.QWHERE = func ASYRMAIN.PARVAL(ARCV,"Where")
PQRY.QORDER = func ASYRMAIN.PARVAL(ARCV,"OrderBy")
# Lines per page
PQRY.QCOUNT = val(func ASYRMAIN.PARVAL(ARCV,"Count"))
If PQRY.QCOUNT=0  : PQRY.QCOUNT = 20       : Endif

Gosub AQUERY_DECODE_CRITERIA From =PRGQRY

Call DECODE_QORDER(PRGQRY,PQRY,TBPRO,TBFIL,TBORDER_PRO,TBORDER_ASCDES,INDEXES)


# Start key of list
KEYQRY = func ASYRMAIN.PARVAL(ARCV,"key")
FIRSTPAGE=1
LASTPAGE=0
If len(KEYQRY) > 0 : FIRSTPAGE=0 :Endif
Call DECODE_KEY(PRGQRY,PQRY,KEYQRY,TBORDER_PRO,TBORDER_ASCDES,TBPRO,TBTYP,LASTPAGE)

#----------------------------------------------------------------#
# Open table : Local File XXX
#----------------------------------------------------------------#
Gosub AQUERY_OPEN From =PRGQRY

#----------------------------------------------------------------#
#  Criteria of class
#----------------------------------------------------------------#
# Call action "SELECT" to complete the criteria
Gosub AQUERY_CRITERIA From =PRGQRY

#----------------------------------------------------------------#
# Open link
#----------------------------------------------------------------#
If TYPREP= "$query"
 Gosub AQUERY_JOIN From =PRGQRY
Elsif TYPREP="$lookup"
 Gosub AQUERY_JOIN_LOOKUP From =PRGQRY
Endif

If !clalev([LNK_]) : Goto ERR_DETAIL : Endif

PQRY.QFILTER = func ASYRMAIN.PARVAL(ARCV,"filter")
QFILTER = PQRY.QFILTER

#Default filter
#94873 no default filter on lookup
If len(QFILTER)=0 & TYPREP<>"$lookup"
 Gosub AQUERY_FILTER_DEF From =PRGQRY
Endif
If len(QFILTER) & QFILTER<>"null"
 If PQRY.QWHERE=""
  QFILTER = func =PRGPRO+".GET_X3FILTER" With (QFILTER)
  Filter [LNK_] Where evalue(QFILTER) Order With INDEXES(PQRY.QASCEND)
 Else
  PQRY.QWHERE += " and " +  func =PRGPRO+".GET_SDATAFILTER" With (QFILTER)
 Filter [LNK_] Where evalueSData(PQRY.QWHERE,TBPRO,TBFIL) Order With INDEXES(PQRY.QASCEND)
 Endif
Else
 If PQRY.QWHERE="" : PQRY.QWHERE = "1 eq 1" : Endif
 Filter [LNK_] Where evalueSData(PQRY.QWHERE,TBPRO,TBFIL)  Order With INDEXES(PQRY.QASCEND)
Endif

#----------------------------------------------------------------#
# Read data
#----------------------------------------------------------------#
Raz NBREP
Raz QKEYS

Local Integer LFREEHEAP1,LFREEHEAP2,QCOUNT
Raz QCOUNT


# The loop is borken by the condition NBREP > PQRY.QCOUNT
For [LNK_]
 NBREP += 1
 If LFREEHEAP1 =0
  LFREEHEAP1 = freeheap
 Endif
 Gosub AQUERY_TRANS From =PRGQRY
 If  [L]ASTATUS <> [V]CST_AERROR
  If LFREEHEAP2 =0 & NBREP=100
   #100 instances of the entity has to be loaded in memory in order to be able
   #to assess the limit :
   LFREEHEAP2 = freeheap
   #Call LOG_LINE("QCOUNT freemem:"-num$(freemem)+" freeheap:"-num$(freeheap)) From AXUNIT
   If LFREEHEAP1 > LFREEHEAP2
    QCOUNT = int(50*LFREEHEAP1/(LFREEHEAP1-LFREEHEAP2)) :#50% for instances / 50% for the request to send
    QCOUNT      = max(QCOUNT,NBREP)
    PQRY.QCOUNT = min(PQRY.QCOUNT,QCOUNT)
   Endif
  Endif
  If NBREP=1
   #computes the index of the first item:
   QKEYS(0) = func COMPUTE_KEY(NAMQRY,QRY(NBREP),PQRY.QASCEND,1,TBORDER_PRO,TBORDER_ASCDES,TBPRO,TBFIL,TBTYP,TBPTH)
   If !FIRSTPAGE and !LASTPAGE
    QKEYS(1) = QKEYS(0)
   Endif
  Elsif NBREP=PQRY.QCOUNT
   #computes the index of the last item:
   QKEYS(2) = func COMPUTE_KEY(NAMQRY,QRY(NBREP),PQRY.QASCEND,2,TBORDER_PRO,TBORDER_ASCDES,TBPRO,TBFIL,TBTYP,TBPTH)
  Elsif NBREP>PQRY.QCOUNT
   #QKEYS(2) isn't the last item:
   QKEYS(3) = QKEYS(2)
   Break
  Endif
 Else
  FreeInstance QRY(NBREP)
  NBREP -= 1
 Endif
Next LNK_
Filter [LNK_]


#96897
#PQRY.QCOUNT    = min(NBREP,PQRY.QCOUNT)
PQRY.QTOTAL  = min(NBREP,PQRY.QCOUNT)

PQRY.QFIRSTK    = ""                                                       :# First page
PQRY.QPREVIOUSK = QKEYS(1+2*(mod(PQRY.QASCEND  ,2)))        + PQRY.QFIRSTK :# Previous page
PQRY.QNEXTK     = QKEYS(1+2*(mod(PQRY.QASCEND+1,2)))        + PQRY.QFIRSTK :# Next page
PQRY.QLASTK     = left$(QKEYS(2*(mod(PQRY.QASCEND  ,2))),2) + PQRY.QFIRSTK :# Last page
#Reset PQRY.QWHERE before serializing data
PQRY.QWHERE   = escJson(func ASYRMAIN.PARVAL(ARCV,"Where"))
#----------------------------------------------------------------#
# JSON generation
#----------------------------------------------------------------#
Local Char TOTO(10) : TOTO=""
#Call LOG_LINE("QUERY_JSON freeheap:"-num$(freeheap)) From AXUNIT
Call QUERY_JSON(RQRY,QRY,PQRY,PSYR,ASND.DATA) From ASYRDATQRY

#----------------------------------------------------------------#
# Prepare response (OK)
#----------------------------------------------------------------#

##If 1=1 & adxmac(-2)="pc018948.sagefr.adinternal.com" & 0
# Local Char DMPFILE(250)
# DMPFILE = HEAPDMP()
##Endif

#Call LOG_LINE("ASND.STAT freeheap:"-num$(freeheap)) From AXUNIT

ASND.STAT     = 200
ASND.URL      = PSYR.PREFIX+'/'+RQRY.CLA
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+REPRES+"."+TYPREP

#--------------------------------------------------#
# Close files & representation classes
#--------------------------------------------------#

Gosub AQUERY_CLOSE From =PRGQRY

FreeGroup PQRY
FreeGroup RQRY
End 0

#----------------------------------------------------------------#
# Error response
#----------------------------------------------------------------#

$ERR_DETAIL
If PQRY<>null : FreeGroup PQRY : Endif
If RQRY<>null : FreeGroup RQRY : Endif
End ERROR

$ERR_LOAD_CLASS
ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(15,149,1),PSYR.CODREP))
Resume



#**
#* DECODE_QORDER
#*
#* @param QORDER
#* @param TBORDER_PRO
#* @param TBORDER_ASCDES
#*
#*!
Funprog DECODE_QORDER(PRGQRY,PQRY,TBPRO,TBFIL,TBORDER_PRO,TBORDER_ASCDES,INDEXES)
Value Char        PRGQRY
Variable Instance PQRY     Using C_AQUERY
Value Char        TBPRO()(1..)
Value Char        TBFIL()(1..)
Variable Char     TBORDER_PRO()(0..)
Variable Char     TBORDER_ASCDES()(0..)
Variable Char     INDEXES()(1..)

Local Char    QORDER(250)
Local Char    ORDER_PARTS(250)(0..)     : #
Local Char    ORDER_PARTITEMS(250)(0..) : #
Local Integer I,J,K
Local Integer NBPARTS,NBITEMS
Local Char    TBORDER_FIL(250)(0..)
Local Char    ORDER_PRO(250)
Local Char    ORDER_FIL(250)
Local Char    ORDER_ASCDES_FIRST(250)
Local Char    CURPTH(250),ACTION(250)

Raz TBORDER_PRO,TBORDER_ASCDES
Raz INDEXES

#Get the primary key
Gosub AQUERY_PRIMARYKEYS From =PRGQRY

#mix syracuse and X3 key:
QORDER = PQRY.QORDER + "," + ASTDKEY

NBPARTS = func ASYRSUB.SPLIT(ORDER_PARTS,QORDER,",;")
If NBPARTS  > 0
 QORDER = ""
 For I=0 To (NBPARTS-1)

  NBITEMS = func ASYRSUB.SPLIT(ORDER_PARTITEMS,ORDER_PARTS(I)," ")
  J = find(ORDER_PARTITEMS(0),TBFIL)
  If J > 0
   ORDER_PRO = TBPRO(J)
   ORDER_FIL = ORDER_PARTITEMS(0)
  Else
   ORDER_PRO = ORDER_PARTITEMS(0)
   J = find(ORDER_PARTITEMS(0),TBPRO)
   If J > 0
    ORDER_FIL = TBFIL(J)
   Endif
  Endif

  J = find(ORDER_PRO,TBORDER_PRO)
  If J=0
   #ORDER_PRO isn't defined in the array:
   TBORDER_PRO(K)    = ORDER_PRO
   TBORDER_FIL(K)    = ORDER_FIL
   If len(QORDER) > 0
    QORDER     += ","
    INDEXES(1) += ";"
    INDEXES(2) += ";"
   Endif


   If NBITEMS > 1
    TBORDER_ASCDES(K) =  ORDER_PARTITEMS(1)
    If K=0 : ORDER_ASCDES_FIRST=TBORDER_ASCDES(K): Endif
    QORDER     += TBORDER_PRO(K) + " " + TBORDER_ASCDES(K)
   Else
    If len(ORDER_ASCDES_FIRST)
     TBORDER_ASCDES(K) =  ORDER_ASCDES_FIRST
     QORDER    += TBORDER_PRO(K) + " " + ORDER_ASCDES_FIRST
    Else
     TBORDER_ASCDES(K) =  "asc"
     QORDER    += TBORDER_PRO(K)
    Endif
   Endif

   INDEXES(2) += TBORDER_FIL(K) + " " + TBORDER_ASCDES(K)
   If TBORDER_ASCDES(K) = "desc"
    INDEXES(1) += TBORDER_FIL(K) + " asc"
   Else
    INDEXES(1) += TBORDER_FIL(K) + " desc"
   Endif
   K +=1
  Endif
 Next I
Endif

PQRY.QORDER = QORDER
End


#**
#* COMPUTE_KEY
#*!
Funprog COMPUTE_KEY(NAMQRY,RECORD,ASCEND,KEYNUM,TBORDER_PRO,TBORDER_ASCDES,TBPRO,TBFIL,TBTYP,TBPTH)
Value Char NAMQRY
Variable Instance RECORD   Using =NAMQRY
Value Integer ASCEND
Value Integer KEYNUM
Variable Char    TBORDER_PRO()(0..)
Variable Char    TBORDER_ASCDES()(0..)
Value Char       TBPRO()(1..),TBFIL()(1..)
Value Integer    TBTYP(1..)
Value Char       TBPTH()(1..)

Local Char       VRB(250),VRC(250)

Local Integer OASCEND
Local Char CMP(3)(0..2)
CMP(0)="gt."
CMP(1)="lt."

Local Integer I,J,TYP
Local Char QKEY(250)

QKEY=""
For I=0 To maxtab(TBORDER_PRO)
 If I = 0
  If TBORDER_ASCDES(I)="desc" : OASCEND=1: Else OASCEND=2:Endif
  QKEY += CMP(mod(ASCEND+KEYNUM+OASCEND,2))
 Else
  QKEY += "~"
 Endif
 VRC = TBORDER_PRO(I)
 J = find(VRC,TBPRO)
 If J
  TYP = TBTYP(J)
  VRB = "RECORD."+TBPTH(J)
  Onerrgo ERROR_VALUE
  Case TYP
   When CST_ATYPTINYINT : WVALUE = num$(evalue(VRB))
   When CST_ATYPSHORTINT : WVALUE = num$(evalue(VRB))
   When CST_ATYPINTEGER  : WVALUE = num$(evalue(VRB))
   When CST_ATYPDECIMAL  : WVALUE = num$(evalue(VRB))
   When CST_ATYPFLOAT    : WVALUE = num$(evalue(VRB))
   When CST_ATYPDOUBLE   : WVALUE = num$(evalue(VRB))
   When CST_ATYPCHAR,26     : WVALUE = func ASYRSUB.STRING_TO_SYR(num$(evalue(VRB)))
   When CST_ATYPDATE     : WVALUE = func ASYRSUB.DATE_TO_SYR(evalue(VRB))
   When CST_ATYPBLOB     : WVALUE = ""
   When CST_ATYPCLOB     : WVALUE = ""
   When CST_ATYPUUID     : WVALUE = func ASYRSUB.STRING_TO_SYR(num$(evalue(VRB)))
   When CST_ATYPDATETIME : WVALUE = func ASYRSUB.DATETIME_TO_SYR(evalue(VRB))
   When CST_ATYPINSTANCE : WVALUE = ""
  Endcase
  If WVALUE='"'+func ASYRSUB.SYR_NULL+'"'
   WVALUE = func ASYRSUB.SYR_NULL
  Endif
  Onerrgo
  QKEY += WVALUE
 Endif
Next I
End QKEY

#---------------------------#
$ERROR_VALUE
WVALUE = VRB + 'error:' -errmes$(errn)
Resume

#**
#* DECODE_KEY(PRGQRY,PQRY,KEYQRY,TBORDER_PRO,TBORDER_ASCDES,TBPRO,TBTYP,LASTPAGE)
#*
#* @param PRGQRY
#* @param PQRY
#* @param KEYQRY
#* @param TBORDER_PRO
#* @param TBORDER_ASCDES
#* @param LASTPAGE
#*!
Subprog DECODE_KEY(PRGQRY,PQRY,KEYQRY,TBORDER_PRO,TBORDER_ASCDES,TBPRO,TBTYP,LASTPAGE)
Value Char        PRGQRY
Variable Instance PQRY     Using C_AQUERY
Value Char        KEYQRY
Variable Char     TBORDER_PRO()(0..)
Variable Char     TBORDER_ASCDES()(0..)
Value   Char TBPRO()(1..)
Value   Integer TBTYP(1..)
Variable Integer LASTPAGE

Local Char    KEY_A1(250)(0..)
Local Char    KEY_A2(250)(0..)
Local Integer SIZE,I,J,K,MAXJ,P1,P2,P3
Local Char    CMP(2)(0..2)

Local Char    MOASCDES(4)(0..2)
Local Char    MKASCDES(2)(1..2)
Local Char    PAR(1)(0..2)

Local Clbfile QWHERE

PAR(0)=""
PAR(1)="("
PAR(2)=")"

MOASCDES(0)=""
MOASCDES(1)="desc"
MOASCDES(2)="asc"

MKASCDES(1)="lt"
MKASCDES(2)="gt"

CMP(0) = "eq"

#compute PQRY.QASCEND: data order in the user interface
PQRY.QASCEND = 2 : # forward

Raz QWHERE
SIZE = 0
I = instr(1,KEYQRY,".")
If I
 KEY_A1(0) = left$(KEYQRY,I-1)
 KEY_A1(1) = right$(KEYQRY,I+1)
 If find(KEY_A1(0),"gt","gte","lt","lte")
  SIZE = 2
 Endif
Elsif KEYQRY="gt" or KEYQRY="gte" or KEYQRY="lt" or KEYQRY="lte"
 KEY_A1(0) = KEYQRY
 SIZE = 1
Endif


If SIZE > 0
 CMP(1) = KEY_A1(0)
 CMP(2) = MKASCDES(1+ mod(find(CMP(1),MKASCDES),2))

 # find returns the position in the array and not the index in the array!
 PQRY.QASCEND = 1+mod(find(TBORDER_ASCDES(0),MOASCDES)+find(CMP(1),MKASCDES),2)

 If SIZE > 1
  SIZE = func ASYRSUB.SPLIT(KEY_A2,KEY_A1(1),"~")
  If SIZE > 0
   If SIZE > 1 : P1=1 : Else P1=0: Endif
   MAXJ = SIZE
   For I=0 To SIZE-1
    If I : QWHERE += " or " : Endif
    QWHERE += PAR(P1)

    If MAXJ > 1 : P2=1 : Else P2=0: Endif
    For J=0 To MAXJ-1
     If J : QWHERE += " and ": Endif
     QWHERE += PAR(P2)
     P3 = 1+mod(find(TBORDER_ASCDES(0),MOASCDES)+find(TBORDER_ASCDES(J),MOASCDES),2)
     QWHERE += TBORDER_PRO(J) + " " + CMP(int((J+1)/MAXJ)*P3)

     K = find(TBORDER_PRO(J),TBPRO)
     If K
      Case TBTYP(K)
      When CST_ATYPCHAR,CST_ATYPUUID  : QWHERE += " '" + KEY_A2(J) + "'"
      When CST_ATYPDATETIME,CST_ATYPDATE                    : QWHERE += " @" + KEY_A2(J) + "@"
      When Default : QWHERE += " "  + KEY_A2(J)
      Endcase
     Endif
     QWHERE += PAR(2*P2)
    Next J
    MAXJ -= 1
    QWHERE += PAR(2*P1)
   Next I
  Endif
 Else
  LASTPAGE=1
 Endif
Endif

If len(QWHERE)
 If len(PQRY.QWHERE)
  PQRY.QWHERE += " and (" + QWHERE + ")"
 Else
  PQRY.QWHERE = QWHERE
 Endif
Endif
End


#**
#* SPLIT_QWHERE
#* Split a QWHERE expression, contained in a URL, in an array of tokens
#* @param QWHERE
#* @param AQWHERE
#*!
Subprog SPLIT_QWHERE(QWHERE,AQWHERE)
Value Char        QWHERE
Variable Char     AQWHERE()(1..)

Local Integer   I,J
Local Char      CHR(1)


For I=1 To len(QWHERE)
 CHR = xgetchar( QWHERE,I)
 If find(CHR,"(",")"," ")
  J += 1
  AQWHERE(J) += CHR
  J += 1
 Else
  J = max(1,J)
  AQWHERE(J) += CHR
 Endif
Next I
End


#**
#* QWHERE_2_EVALUE
#*
#* @param AQWHERE
#* @param TCIN
#* @param TCOUT
#*!
Funprog QWHERE_2_EVALUE(AQWHERE,TCIN,TCOUT)
Variable Char     AQWHERE()(0..)
Variable Char     TCIN()(1..)
Variable Char     TCOUT()(1..)

Local Char    EVAL(250): EVAL=""
Local Integer I:I=0
Local Integer J

While AQWHERE(I) <> ""
If I > 1: EVAL += " " : Endif
 Case AQWHERE(I)
  When "lt"        : [L]EVAL += "<"
  When "lte"       : [L]EVAL += "<="
  When "gt"        : [L]EVAL += ">"
  When "gte"       : [L]EVAL += ">="
  When Default :
   J = find(AQWHERE(I),TCIN)
   If J
    [L]EVAL += TCOUT(J)
   Else
    [L]EVAL += AQWHERE(I)
   Endif
 Endcase
 I += 1
Wend
End EVAL

