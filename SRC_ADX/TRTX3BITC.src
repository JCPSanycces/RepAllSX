###########################################################################################
# TRTX3BITC  Fonctions pour la Business Intelligence    Module Tronc commun               #
# --------------------------------------------------------------------------------------- #
# GETLEG_EECNAT  : Détermination de la législation retenue pour une nature transaction DEB#
# GETLEG_EECSCH  : Détermination de la législation retenue pour un régime statistique     #
# GETLEG_VACBPR  : Détermination de la législation retenue pour un régime de taxe         #
# GETLEG_VAT     : Détermination de la législation retenue pour une taxe                  #
# GETLEG_PTE     : Détermination de la législation retenue pour une condition de paiement #
# GETLEG_PTEBPR  : Détermination de la législation retenue pour un  client ou fournisseur #
# --------------------------------------------------------------------------------------- #
###########################################################################################
#--------------------------------------------------------------------------------------------------
# FGR 16/06/2014 : X3SUIVI98503 : OPTIMISATION RECHERCHE LEGISLATION (début)
#--------------------------------------------------------------------------------------------------
#####################################################################
Funprog GET_CPY_LEG(SDOSSIER, STABLE, SCPYLEG, SCLE, SLEG)
Value Char SDOSSIER
Value Char STABLE
Value Char SCPYLEG
Value Char SCLE
Variable Char SLEG

Local Integer ISEARCHTODO
Local Integer ILINE

  Raz SLEG
  ISEARCHTODO = [V]CST_ANO
  If GLEGACT <> [V]CST_AYES Then
    SLEG = GDOSLEG
  Else
    If dim(GDBIGLOBALDATE) >= 0 Then
      If GDBIGLOBALDATE < date$ Then
        # Pour réinitialiser les globales si elles datent de plus d'un jour
        Call KILL_GLOBAL_BI
      Endif
    Endif
    If dim(GINBBICPYLEG) < 0 Then
      # Les globales de recherche n'existent pas
      # Il faut les créer, et par conséquent la recherche en base doit être faite
      ISEARCHTODO = [V]CST_AYES

      Global Integer GINBBICPYLEG
      Global Char GSBICPYLEGKEY(250)(1..)
      Global Char GSBICPYLEGLEG(GLONADI)(1..)
      Global Date GDBIGLOBALDATE

      GDBIGLOBALDATE = date$
      GINBBICPYLEG = 0
    Else
      ILINE = find(func GET_CPY_LEG_KEY(SDOSSIER, STABLE, SCPYLEG, SCLE), GSBICPYLEGKEY(1..GINBBICPYLEG))
      If ILINE < 1 Then
        # On ne l'a pas déjà eu, il faut la chercher
        ISEARCHTODO = [V]CST_AYES
      Else
        SLEG = GSBICPYLEGLEG(ILINE)
      Endif
    Endif
  Endif
End ISEARCHTODO

#####################################################################
Subprog ADD_CPY_LEG(SDOSSIER, STABLE, SCPYLEG, SCLE, SLEG)
Value Char SDOSSIER
Value Char STABLE
Value Char SCPYLEG
Value Char SCLE
Value Char SLEG

  GINBBICPYLEG += 1
  GSBICPYLEGKEY(GINBBICPYLEG) = func GET_CPY_LEG_KEY(SDOSSIER, STABLE, SCPYLEG, SCLE)
  GSBICPYLEGLEG(GINBBICPYLEG) = SLEG
End

#####################################################################
Subprog KILL_GLOBAL_BI()

  If dim(GINBBICPYLEG) >= 0 Then
    Kill GINBBICPYLEG
  Endif
  If dim(GSBICPYLEGKEY) >= 0 Then
    Kill GSBICPYLEGKEY
  Endif
  If dim(GSBICPYLEGLEG) >= 0 Then
    Kill GSBICPYLEGLEG
  Endif
  If dim(GDBIGLOBALDATE) >= 0 Then
    Kill GDBIGLOBALDATE
  Endif
End

#####################################################################
Funprog GET_CPY_LEG_KEY(SDOSSIER, STABLE, SCPYLEG, SCLE)
Value Char SDOSSIER
Value Char STABLE
Value Char SCPYLEG
Value Char SCLE

Local Char SARENDRE(250)

  SARENDRE = SDOSSIER + "~" + STABLE + "~" + SCPYLEG + "~" + SCLE
End SARENDRE
#--------------------------------------------------------------------------------------------------
# FGR 16/06/2014 : X3SUIVI98503 : OPTIMISATION RECHERCHE LEGISLATION (fin)
#--------------------------------------------------------------------------------------------------

#--------------------------------------------------------------------------------------------------
$INIT_WLEG
  # FGR 16/06/2014 : X3SUIVI98503 : une fois ça suffit
  #--Si dossier mono-lég, on retourne la
  #--CPO 92324 V7.1: BI modification for data by legislation
  #If func AFNC.ACTIV("LEG")=0
  If GLEGACT<>[V]CST_AYES
    WLEG = GDOSLEG
  Elsif PLEG<>""
    WLEG=PLEG
  Elsif WLEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
    WLEG = GCURLEG
  Endif
Return

#--------------------------------------------------------------------------------------------------
Funprog GETLEG_EECNAT(PEECNAT,PLEG)
Value Char PEECNAT
Value Char PLEG

Local Char WLEG(GLONADI)

  Raz WLEG
  If PEECNAT<>"" Then
    If clalev([TEC]) <= 0 Then                             #--CPO 92324 V7.1: BI modification for data by legislation
      If GDOSSIER <> "" Then
  	    Local File =GDOSSIER+".TABEECNAT" [TEC]
      Else
        Local File TABEECNAT [TEC]
      Endif
    Endif
    Gosub INIT_WLEG  # FGR 16/06/2014 : X3SUIVI98503
    fstat = 0 #--CPO 92324 V7.1: BI modification for data by legislation
    If func GET_CPY_LEG(GDOSSIER, "TABEECNAT", PLEG, PEECNAT, WLEG) = [V]CST_AYES Then
      If WLEG <> "" Then
        If [F:TEC]EECNAT<>PEECNAT and [F:TEC]LEG<>WLEG Then  #--CPO 92324 V7.1: BI modification for data by legislation
          Read [TEC]TEC0=PEECNAT;WLEG
          If fstat Then
            Read [TEC]TEC0=PEECNAT;""
          Endif
        Endif
      Else
        If [F:TEC]EECNAT<>PEECNAT Then                       #--CPO 92324 V7.1: BI modification for data by legislation
          Read [TEC]TEC0(1)=PEECNAT
        Endif
      Endif
      If !fstat Then
        WLEG = [F:TEC]LEG
      Else
        Raz WLEG
      Endif
      Call ADD_CPY_LEG(GDOSSIER, "TABEECNAT", PLEG, PEECNAT, WLEG)
    Endif
  Endif
End WLEG

#--------------------------------------------------------------------------------------------------
