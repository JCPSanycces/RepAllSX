#--------------------------------------------------------------------------------------------------
Funprog GETLEG_PTE(PPTE,PLEG)
Value Char PPTE
Value Char PLEG

Local Char WLEG(GLONADI)

  Raz WLEG
  If PPTE<>""
    If clalev([TPT])<=0 :#--CPO 92324 V7.1: BI modification for data by legislation
      If GDOSSIER<>""
        Local File =GDOSSIER+".TABPAYTERM" [TPT]
      Else
        Local File TABPAYTERM [TPT]
      Endif
    Endif
    Gosub INIT_WLEG  # FGR 16/06/2014 : X3SUIVI98503
    fstat = 0 #--CPO 92324 V7.1: BI modification for data by legislation
    If func GET_CPY_LEG(GDOSSIER, "TABPAYTERM", PLEG, PPTE, WLEG) = [V]CST_AYES Then
      If WLEG<>""
        If [F:TPT]PTE<>PPTE and [F:TPT]LEG<>WLEG #--CPO 92324 V7.1: BI modification for data by legislation
          Read [TPT]TPT0=PPTE;WLEG;1
          If fstat
            Read [TPT]TPT0=PPTE;"";1
          Endif
        Endif
      Else
        If [F:TPT]PTE<>PPTE                      #--CPO 92324 V7.1: BI modification for data by legislation
          Read [TPT]TPT2(1)=PPTE
        Endif
      Endif
      If !fstat
        WLEG = [F:TPT]LEG
      Else
        Raz WLEG
      Endif
      Call ADD_CPY_LEG(GDOSSIER, "TABPAYTERM", PLEG, PPTE, WLEG)
    Endif
  Endif
End WLEG

#--------------------------------------------------------------------------------------------------
#--Dans le contexte du client, on recherche d'abord l'entrée toutes légs et si cette dernière
#--n'existe pas, on prend la première entrée ayant une législation
Funprog GETLEG_PTEBPR(PPTEBPR,PLEG)
Value Char PPTEBPR
Value Char PLEG

Local Char WLEG(GLONADI)

  Raz WLEG
  If PPTEBPR<>"" Then
    If clalev([TPT])<=0 :#--CPO 92324 V7.1: BI modification for data by legislation
      If GDOSSIER<>""
        Local File =GDOSSIER+".TABPAYTERM" [TPT]
      Else
        Local File TABPAYTERM [TPT]
      Endif
    Endif
    Gosub INIT_WLEG  # FGR 16/06/2014 : X3SUIVI98503
    fstat = 0 #--CPO 92324 V7.1: BI modification for data by legislation
    If func GET_CPY_LEG(GDOSSIER, "TABPAYTERMBPR", PLEG, PPTEBPR, WLEG) = [V]CST_AYES Then
      If WLEG<>"" :#--Possible si mono-lég
        If [F:TPT]PTE<>PPTEBPR and [F:TPT]LEG<>WLEG #--CPO 92324 V7.1: BI modification for data by legislation
          Read [TPT]TPT0=PPTEBPR;WLEG;1
          If fstat
            Read [TPT]TPT0=PPTEBPR;"";1
          Endif
        Endif
      Else
        If [F:TPT]PTE<>PPTEBPR                      #--CPO 92324 V7.1: BI modification for data by legislation
          Read [TPT]TPT0=PPTEBPR;"";1
          If fstat
            Read [TPT]TPT2(1)=PPTEBPR
          Endif
        Endif
      Endif
      If !fstat
        WLEG = [F:TPT]LEG
      Else
        Raz WLEG
      Endif
      Call ADD_CPY_LEG(GDOSSIER, "TABPAYTERMBPR", PLEG, PPTEBPR, WLEG)
    Endif
  Endif
End WLEG
