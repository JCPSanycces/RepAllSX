#<AdxTL>@(#)3.0.0.0 $Revision$
#<gen>
# STK_CHG_VAL :  Crée un mouvement de changement de valeur + màj de ITH
#             ou Crée un enreg SMI pour création ultérieure du mouvement
#</gen>

############################################################
# LOADITC :  Recherche le coût standard (budget) pour un exercice donné
############################################################
Funprog LOADITC(PFCY, PITM, PTYP, PEXE, PECCMAJ, PECCMIN)
Value Char PFCY
Value Char PITM
Value Integer PTYP
Value Integer PEXE
Value Char PECCMAJ
Value Char PECCMIN

Local Integer LOK, I
Local Char LCRIT(250)

LOK = 0
If PFCY<>"" & PITM<>"" & PTYP<>0 & PEXE<>0
    I = func ECCLIB.NBRCPNCST(PITM)
    If I=0
&    | I>0 & PECCMAJ<>""
&    | I=2 & PECCMIN=""
        LCRIT = string$(I=0,"1=1")
&              +string$(I>0,"ECCVALMAJ='"+PECCMAJ+"'")
&              +string$(I=2,"&ECCVALMIN='"+PECCMIN+"'")

        For [ITC]ITC0 Where STOFCY= PFCY
&                         & ITMREF= PITM
&                         & CSTTYP= PTYP
&                         & UID   = 0
&                         & FIYNUM= PEXE
&                         & evalue(LCRIT)
            [M]ITCSEQ = [F:ITC]ITCSEQ
            LOK = 1
            Break
        Next
    Endif
Endif
End LOK

############################################################
# ICLD2ICD : charge les masques ICD1 et ICD2 avec les valeurs de ICLD
############################################################
Subprog ICLD2ICD
Local Integer I

#---  ICLD --> ICD2 ----#
For I=0 To GACTMAT-1
    [M:ICD2]MATLEVCST(I) = [M:ICLD]MATCST(I)
Next
[M:ICD2]OVEMATLEV = [M:ICLD]OVEMATCST

For I=0 To GACTMAC-1
    [M:ICD2]MACLEVCST(I) = [M:ICLD]MACCST(I)
Next
[M:ICD2]OVEMACLEV = [M:ICLD]OVEMACCST

For I=0 To GACTLAB-1
    [M:ICD2]LABLEVCST(I) = [M:ICLD]LABCST(I)
Next
[M:ICD2]OVELABLEV = [M:ICLD]OVELABCST

[M:ICD2]SCOLEVCST = [M:ICLD]SCOTOT
[M:ICD2]OVESCOLEV = [M:ICLD]OVESCOCST

[M:ICD2]MATTOTLEV = sum([M:ICD2]MATLEVCST)
[M:ICD2]MACTOTLEV = sum([M:ICD2]MACLEVCST)
[M:ICD2]LABTOTLEV = sum([M:ICD2]LABLEVCST)
[M:ICD2]SCOTOTLEV = sum([M:ICD2]SCOLEVCST)
[M:ICD2]OVETOTLEV = sum([M:ICD2]OVEMATLEV,[M:ICD2]OVEMACLEV,[M:ICD2]OVELABLEV,[M:ICD2]OVESCOLEV)
[M:ICD2]OVELEVCST = [M:ICD2]OVETOTLEV

[M:ICD2]VLTTOT = [M:ICD2]MATTOTLEV + [M:ICD2]MACTOTLEV + [M:ICD2]LABTOTLEV + [M:ICD2]SCOTOTLEV + [M:ICD2]OVETOTLEV

Raz [M:ICD2]FXDMATLEV,[M:ICD2]FXDMACLEV,[M:ICD2]FXDLABLEV,[M:ICD2]FXDSCOLEV,[M:ICD2]FXDOVELEV
Raz [M:ICD2]FXDOVEMATL,[M:ICD2]FXDOVEMACL,[M:ICD2]FXDOVELABL,[M:ICD2]FXDOVESCOL

#---  ICLD --> ICD1 ----#
[M:ICD1] = [M:ICLD]

[M:ICD1]MATTOT = sum([M:ICD1]MATCST)
[M:ICD1]MACTOT = sum([M:ICD1]MACCST)
[M:ICD1]LABTOT = sum([M:ICD1]LABCST)
[M:ICD1]OVETOT = sum([M:ICD1]OVEMATCST,[M:ICD1]OVEMACCST,[M:ICD1]OVELABCST,[M:ICD1]OVESCOCST)

# CCC (2009-08-04) Bug 56348 : CSTTOT n'était pas calculé
[M:ICD1]CSTTOT = [M:ICD1]MATTOT + [M:ICD1]MACTOT + [M:ICD1]LABTOT + [M:ICD1]SCOTOT
[M:ICD1]VLTTOT = [M:ICD1]CSTTOT + [M:ICD1]OVETOT

Raz [M:ICD1]FXDMATCST,[M:ICD1]FXDMACCST,[M:ICD1]FXDLABCST,[M:ICD1]FXDSCOCST
Raz [M:ICD1]FXDOVEMAT,[M:ICD1]FXDOVEMAC,[M:ICD1]FXDOVELAB,[M:ICD1]FXDOVESCO


End

############################################################
# STK_CHG_VAL :  Crée un mouvement de changement de valeur + màj de ITH
#             ou Crée un enreg SMI pour création ultérieure du mouvement
############################################################
# Paramètres E : LNUMVLT = 1ère ou 2ème méthode de valo (1 ou 2)
#                LCCE = liste des sections analytique
#
# La classe [F:ITC] doit être chargée avec le nouveau coût standard mais pas écrit
# sauf dans le cas de la fonction FUNSMI
# Le champ [F:ITC]OLDCST est mis à jour en cas de la création du mouvement
#
# Si la date de début de validité est supérieure à la date du jour alors créer un nouvel enreg dans [SMI]
# sinon créer tout de suite le mouvement en valeur
# Suppression de tous les enregistrements dans STKMVTITC [SMI] correspondant au coût passé en paramètre
# (même date de début de validité, n° séquence inférieur)
############################################################
Subprog STK_CHG_VAL(LNUMVLT,LCCE)
Value Integer LNUMVLT
Value Char    LCCE()

If  !find(LNUMVLT,1,2)
    End
Endif
# Issue 83536 - 2012-08-10 by CCC
If LNUMVLT=2 & !GACTVLT2
    End
Endif

LNUMVLT -=1

# CCC (13/08/07) Bug 42564
If GMODU(7)<>2
    GOK=1
    End
Endif

Local Char    LITM(GLONITM) : LITM = [F:ITC]ITMREF
Local Char    LFCY(GLONFCY) : LFCY = [F:ITC]STOFCY
Local Integer LTYP : LTYP = [F:ITC]CSTTYP
Local Integer LSEQ : LSEQ = [F:ITC]ITCSEQ
Local Char    LECCMAJ(GLONICVVAL) : LECCMAJ = [F:ITC]ECCVALMAJ
Local Char    LECCMIN(GLONICVVAL) : LECCMIN = [F:ITC]ECCVALMIN

If dim(GRNDVAL)<=0 : Global Decimal GRNDVAL : Endif
Call INIRNDVAL("STOJOU","AMTORD") From STKVALECR  # Issue 80993 - 2012-05-10 by CCC

If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
If !clalev([F:ITH]) : Local File ITMMVTHIS  [ITH] : Endif
If !clalev([F:SMI]) : Local File STKMVTITC  [SMI] : Endif
If !clalev([F:STJ]) : Local File STOJOU     [STJ] : Endif
If !clalev([F:STJ1]): Local File STOJOU     [STJ1]: Endif
If !clalev([F:SJV]) : Local File STOJOUVAL  [SJV] : Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([F:PER]) : Local File PERIOD     [PER] : Endif
If !clalev([F:STP]) : Local File STOCOST    [STP] : Endif

If !clalev([M:SDP]) : Local Mask SAIDECPRI  [SDP] : Endif
If !clalev([M:SDP2]): Local Mask SAIDECPRI  [SDP2]: Endif
If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif

# Récupération des codes compteur et effacement fichier de travail
If !clalev([F:TCA]) : Local File TABCOUAFF [TCA]  : Endif
# Compteur module stock
Local Integer WOK
Call LECTCA(7,WOK) From SUBTCA
If !WOK
  GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
  GERR=1
  # FGR 09/02/2010 : X3SUIVI60986 End pas Return
  End
Endif
GSTKCPTMAN(21)=[F:TCA]MANCOU(21) # Cpt des changements de valeur
GSTKCPT(21)   =[F:TCA]CODNUM(21)

Local Integer LTR : Raz LTR
Local Decimal LQTY, LPRI
Local Integer LRET, I
Local Char    LSEC(GLONCCE)
Local Decimal LEXE, LPER
Local Decimal WQTE1, WQTE2
Local Date    WREODAT

If dim(GRNDVAL)<=0 : Global Decimal GRNDVAL : Endif

If adxlog=0
    Call DEBTRANS From GLOCK
    Trbegin [SMI]
    LTR=1
Endif

If [F:ITC]ITCSTRDAT<=date$
    Call STOECCVAL(LITM,LFCY,LECCMAJ,LECCMIN,LQTY) From STKLIB
    If LQTY=0    # Pas de stock => pas de mouvement à faire
        Goto FIN_STJVAL
    Endif
    Delete [SMI] Where ITMREF = LITM
&                    & STOFCY = LFCY
&                    & CSTTYP = LTYP
&                    & ITCSTRDAT = [F:ITC]ITCSTRDAT
    If [F:FCY]FCY<>LFCY
        Read [FCY]FCY0=LFCY
    Endif

    If [F:ITM]ITMREF<>LITM
        Read [ITM]ITM0=LITM
    Endif
    Call GETSOC(LFCY) From DEVSUB    # --> renseigne GTYPGEN
    Call GETPER(LFCY,GTYPGEN,date$,LEXE,LPER) From CPTSUB

    Raz [M:SDP]
    If GACTDECCST
        Call LOADSDPX("SDP"+string$(dim(LNUMVLT)>0&LNUMVLT=1,"2"),"[F:ITC]","",1) From STKVAL
        If LNUMVLT=1
            # Issue X3-25084 - 2017-02-22 by ERMIL : Transmask performance improvements
            #[M:SDP2] = [M:SDP]
            Raz [M:SDP2]
            Transmask [M:SDP] To [M:SDP2]
            Raz [M:SDP]    # Seul SDP2 nous intéresse maintenant
        Endif
    Endif

    Call INIRNDVAL("","") From STKVALECR
    If LNUMVLT=1
        [M:SDP2]PRI = [F:ITC]VLTTOT
        [M:SVW]AMTVAL2(0) = arr(LQTY * [M:SDP2]PRI,GRNDVAL)     # Issue 92701 - 2013-10-23 by CCC
    Else
        [M:SDP]PRI = [F:ITC]VLTTOT
        [M:SVW]AMTVAL(0) = arr(LQTY * [M:SDP]PRI,GRNDVAL)       # Issue 92701 - 2013-10-23 by CCC
    Endif
    Call COPSDP2SVWVALA(0,LQTY,GRNDVAL) From STKVALECR
    # Lorsque le mvt en valeur doit être créé à partir d'un SMI, c'est que le coût passé en paramètre existe déjà
    # et donc il faut rechercher le prix de la veille
    # Sinon c'est avec le prix du jour qu'il faut faire la différence.
    If GFONCTION="FUNSMI"
        LDAT = date$ - 1
    Else
        LDAT = date$
    Endif

    #--- Pour éviter d'écraser la classe en cours on ouvre une nouvelle instance de la table ITC
    #--- juste le temps de récupérer le coût précédent
    Local File ITMCOST [ITC]
      Raz [M:SDP], [M:SDP2], [F:ITC]
      Call GETPRISTD(LITM,LECCMAJ,LECCMIN,LFCY,LDAT,0,LTYP,GBIDD1,LRET) From STKVAL    # ---> Utilise [F:ITC] (!!ne pas mettre [m:sdp]pri à la place de lpri)

      If [M:SDP]PRI<>0    # Un coût a été trouvé
          [F:ITC]OLDCST = [M:SDP]PRI
          [F:ITC]OLDDAT = [F:ITC]ITCDAT
          [F:ITC]PHYSTO = LQTY
      Endif
    Close Local File [ITC]

    If GACTDECCST
        If LNUMVLT=1
            # Issue X3-25084 - 2017-02-22 by ERMIL : Transmask performance improvements
            #[M:SDP2] = [M:SDP]
            Raz [M:SDP2]
            Transmask [M:SDP] To [M:SDP2]
            Raz [M:SDP]
        Endif
    Endif
    # Issue 96176 - 2014-01-27 by CCC : set AMTVAL before COPSDP2SVWVAL
    If LNUMVLT=0
        [M:SVW]AMTVAL(1) = arr(LQTY * [M:SDP]PRI,GRNDVAL)
    Else
        [M:SVW]AMTVAL2(1) = arr(LQTY * [M:SDP2]PRI,GRNDVAL)
    Endif
    Call COPSDP2SVWVALA(1,LQTY,GRNDVAL) From STKVALECR
    # copie de l'indice 1 vers l'indice 0, en multipliant l'indice 1 par -1
    # et l'ajouter à l'indice 0 mais uniquement sur les valeurs de valo(2)
    Call COPSVW(1,0,-1,1,2) From STKVALECR    # !! écrase [m:svw]prival(ind_des)

    If LNUMVLT=0
        [M:SVW]PRIVAL(0) = [F:ITC]VLTTOT - [M:SVW]PRIVAL(1)
        # Issue 83077 - 2012-07-02 by CCC
        If GACTDECCST
&        & (sigma(0,GACTMAT-1,abs([M:SVW]VMATCST(indcum)))
&         +abs([M:SVW]VOVEMATTOT(0))
&         +sigma(0,GACTMAC-1,abs([M:SVW]VMACCST(indcum)))
&         +abs([M:SVW]VOVEMACTOT(0))
&         +sigma(0,GACTLAB-1,abs([M:SVW]VLABCST(indcum)))
&         +abs([M:SVW]VOVELABTOT(0))
&         +abs([M:SVW]VSCOTOT(0))
&         +abs([M:SVW]VOVESCOTOT(0)) = 0)
&         | !GACTDECCST & [M:SVW]PRIVAL(0)=0
            # Pas de différence de prix => pas de mouvement
            Goto FIN_STJVAL
        Endif
    Else
        [M:SVW]PRIVAL2(0) = [F:ITC]VLTTOT - [M:SVW]PRIVAL2(1)
        # Issue 83077 - 2012-07-02 by CCC
        If GACTDECCST
&        & (sigma(0,GACTMAT-1,abs([M:SVW]V2MATCST(indcum)))
&         +abs([M:SVW]V2OVEMAT(0))
&         +sigma(0,GACTMAC-1,abs([M:SVW]V2MACCST(indcum)))
&         +abs([M:SVW]V2OVEMAC(0))
&         +sigma(0,GACTLAB-1,abs([M:SVW]V2LABCST(indcum)))
&         +abs([M:SVW]V2OVELAB(0))
&         +abs([M:SVW]V2SCOTOT(0))
&         +abs([M:SVW]V2OVESCO(0))
&         +abs([M:SVW]V2INVDTA(0)) = 0)
&         | !GACTDECCST & [M:SVW]PRIVAL2(0)=0
            # Pas de différence de prix => pas de mouvement
            Goto FIN_STJVAL
        Endif
    Endif
    #------ Ecriture du mouvement dans STOJOU -----------#
    Raz [F:STJ]
    [F:STJ]ITMREF = LITM
    [F:STJ]STOFCY = LFCY
    [F:STJ]OWNER  = LFCY
    [F:STJ]FINRSPFCY = [F:FCY]FINRSPFCY
    [F:STJ]UPDCOD = 2
    [F:STJ]IPTDAT = date$

    [F:STJ]PRINAT = LTYP+1 # 2= std ; 3= actualisé
    [F:STJ]TRSTYP = 23
    [F:STJ]VCRTYP = 30
    Call NUMERO(GSTKCPT(21),LFCY,date$,"",[F:STJ]VCRNUM,LRET) From SUBANM
    [F:STJ]VCRLIN = 1000
    [F:STJ]LOT    = ""
    [F:STJ]SLO    = ""
    [F:STJ]ECCVALMAJ = LECCMAJ
    [F:STJ]ECCVALMIN = LECCMIN
    # Ne pas mettre de quantité dans un changement de valeur (pb cumuls dans BO)
    #[F:STJ]QTYSTU = LQTY
    [F:STJ]QTYSTU = 0
    [F:STJ]STU    = [F:ITM]STU
    If GACTVLT2 & [M:SVW]PRIVAL2(0)<>0
        [F:STJ]PRINAT2 = LTYP+1 # 2= std ; 3= actualisé
        # Issue 92701 - 2013-10-23 by CCC
        #[F:STJ]AMTVAL2 = LQTY * [M:SVW]PRIVAL2(0)
        [F:STJ]AMTVAL2 = [M:SVW]AMTVAL2(0)
        [F:STJ]VARVAL2 = [F:STJ]AMTVAL2
        [F:STJ]PRIVAL2 = [M:SVW]PRIVAL2(0)
        [F:STJ]AMTDEV2 = -[F:STJ]AMTVAL2
    Else
        [F:STJ]PRINAT = LTYP+1 # 2= std ; 3= actualisé
        # Issue 92701 - 2013-10-23 by CCC
        #[F:STJ]AMTVAL = LQTY * [M:SVW]PRIVAL(0)
        [F:STJ]AMTVAL = [M:SVW]AMTVAL(0)
        [F:STJ]VARVAL = [F:STJ]AMTVAL
        [F:STJ]PRIVAL = [M:SVW]PRIVAL(0)
        [F:STJ]AMTDEV = -[F:STJ]AMTVAL
    Endif
  # FQ 62309 GA 02/2010 global variable GACCCSTENT undefined without Manufacturing module
    If dim(GACCCSTENT)>0  [F:STJ]ENTCOD = GACCCSTENT Endif # param général >> en adaptant la pièce

    For I=1 To max(GNBDIE,GOPTCANA)
        [F:STJ]CCE(I-1) = LCCE(I-1)
        [F:STJ]DIE(I-1) = GDIE(I)
    Next

    Call ECRSTJ(0,LRET) From STKLIB
    Call ECRTRACE (" Create STOJOU",0) From STKVAL
    Call ECRTRACE (" ITMREF="+[F:STJ]ITMREF-"STOFCY="+[F:STJ]STOFCY-"IPTDAT="+num$([F:STJ]IPTDAT)-"MVTSEQ="+num$([F:STJ]MVTSEQ),0) From STKVAL
    Call ECRTRACE (" TRSTYP="+num$([F:STJ]TRSTYP),0) From STKVAL
    Call ECRTRACE (" AMTVAL=VARVAL=AMTORD=VARORD="+num$([F:STJ]AMTVAL),0) From STKVAL
    Call ECRTRACE (" AMTVAL2=VARVAL2="+num$([F:STJ]AMTVAL2),0) From STKVAL
    GOK = !LRET   # faire une trace pour les cas 1,2,3
    If GOK<1  End  Endif

    If GACTDECCST
        [F:SJV] = [F:STJ]    # Récupération de la clé
# Issue 81304 - 2012-06-06 by CCC : le signe est déjà correct dans SVW
#        Call SVW2SJV(0,sgn(LQTY),1) From STKVALECR
        Call SVW2SJV(0,1) From STKVALECR
        [F:SJV]CREDAT = date$
        [F:SJV]CREUSR = GUSER
        Write [SJV]
        If fstat
            GOK=0
            Goto FIN_STJVAL
        Endif
    Endif
    # mettre aussi la différence dans AMTDEV de ITMMVTHIS
    Readlock [ITH]ITH0=LITM;LFCY;[F:PER]PERSTR # période contenant la date d'imputation
    If fstat = 1
      Call FSTA("ITH") From GLOCK
      GOK = -1
    Elsif fstat = 5
    # CCC (2009-09-15) Bug 57799 : Récup cumuls annuels de la période précédente
    Filter [ITH] Where ITMREF=LITM
&                    & STOFCY=LFCY
&                    & FIYNUM=[F:PER]FIYNUM
&                    & PERSTR<[F:PER]PERSTR
    Read [ITH] ITH0 Last
    Filter [ITH]
    If fstat  Raz [F:ITH] : Endif
    [L]WQTE1=[F:ITH]YEARCPQTY
    [L]WQTE2=[F:ITH]YEAISSQTY
    GBIDD1  =[F:ITH]YEARCPAMT
    GBIDD2  =[F:ITH]YEAISSAMT
    GBIDI1  =[F:ITH]YEARCPMVT
    GBIDI2  =[F:ITH]YEAISSMVT
    GBIDA1  =[F:ITH]LASISSDAT
    GBIDA2  =[F:ITH]LASRCPDAT
    GBIDA3  =[F:ITH]LASPURDAT
    GBIDD3  =[F:ITH]LASPURPRI
    WREODAT =[F:ITH]LASREODAT
   #---
    # créer l'enregistrement ITH
    Raz [F:ITH]
    [F:ITH]ITMREF = LITM
    [F:ITH]STOFCY = LFCY
    [F:ITH]PERSTR = [F:PER]PERSTR
    [F:ITH]PEREND = [F:PER]PEREND
    [F:ITH]FIYNUM = [F:PER]FIYNUM
    [F:ITH]PERNUM = [F:PER]PERNUM
    [F:ITH]AMTDEV = [F:STJ]AMTDEV

    #----- Chargement cumuls annuels -----#
    [F:ITH]YEARCPQTY=[L]WQTE1
    [F:ITH]YEAISSQTY=[L]WQTE2
    [F:ITH]YEARCPAMT=GBIDD1
    [F:ITH]YEAISSAMT=GBIDD2
    [F:ITH]YEARCPMVT=GBIDI1
    [F:ITH]YEAISSMVT=GBIDI2
    [F:ITH]LASISSDAT = GBIDA1
    [F:ITH]LASRCPDAT = GBIDA2
    [F:ITH]LASPURDAT = GBIDA3
    [F:ITH]LASPURPRI = GBIDD3
    [F:ITH]LASREODAT = WREODAT
      Call ECRITH From STKLIB
      If fstat
        GOK = 0
        Goto FIN_STJVAL
      Endif
    Else
      # pour que l'on ait toujours        val réelle = val valoris. + écart
      # la valeur du coût s'approche + de la réalité donc l'écart diminue
      [F:ITH]AMTDEV += [F:STJ]AMTDEV
      Call REWITH From STKLIB
      If fstat
        GOK = 0
        Goto FIN_STJVAL
      Endif
    Endif
Else
    # On supprime les SMI correspondant au coût que l'on vient de recalculer
    Delete [SMI] Where ITMREF = LITM
&                    & STOFCY = LFCY
&                    & CSTTYP = LTYP
&                    & ITCSTRDAT = [F:ITC]ITCSTRDAT

    Raz [F:SMI]
    [F:SMI]ITMREF    = LITM
    [F:SMI]STOFCY    = LFCY
    [F:SMI]ITCSTRDAT = [F:ITC]ITCSTRDAT
    [F:SMI]CSTTYP    = LTYP
    [F:SMI]ITCSEQ    = LSEQ
    Write [SMI]
    If fstat
        GOK=0
        Goto FIN_STJVAL
    Endif
Endif

$FIN_STJVAL

If LTR
    If GOK
        Commit
    Else
        Rollback
    Endif
Endif

End

