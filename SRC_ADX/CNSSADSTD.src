#<AdxTL>@(#)0.0.0.0 $Revision$ Allocations détaillées
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz [M:CSAD]:Transmask [M:SAD1] To [M:CSAD] # Issue 25606 [M:CSAD] = [M:SAD1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:ITM])=0  : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:STO2])=0 : Local File STOCK      [STO2] : Endif
If clalev([F:STA])=0  : Local File STOALL     [STA]  : Endif
If clalev([F:SRU])=0  : Local File TABSTORUL  [SRU]  : Endif
If GMODU(5)=2
  If clalev([F:SOH])=0  : Local File SORDER     [SOH]  : Endif
Endif
#
Local Char    WFIL(250)
Local Char    WFILS(250)
Local Char    WFILSPE(250)
Local Char    WCRITSTO(240)
Local Integer WFSTAT, WREA, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I, LRET
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSAD"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SAD1] = [M:CSAD]
[M:SAD1]FLG = 0
Return
############################################################
$AP_MAGNETO
[M:SAD1]FLG = 0
Return
############################################################
$FERME
If clalev([F:STA]) <> 0 : Filter [STA] : Endif
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SAD1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SAD1] = [F:ITM]
        Endif
      Endif
    When 4 :
      If PARAM(I) <> ""
        [M:SAD1]STOCOUSEL = val(PARAM(I))
      Endif
    When 5 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I
If clalev([M:CSAD]) <> 0 & [M:CSAD]MEMO = "STD"       # hcb 61281
  [M:SAD1] = [M:CSAD]
Endif

[M:SAD1]AGGFLG    = 2
Return
############################################################
$LECTURE
If [M:SAD1]ITMREF = "" | [M:SAD1]FCY = ""
  NBLU = 0
  Return
Endif

# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [STA]
      If nolign <= MAXLIG
        Gosub LOA_LIGNE
        NBLU    = 2
        nolign += 1
        NOL    += 1
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [STA]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:SAD2]
    WLIG = 0
    For [STA]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [STA]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    -= 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [STA]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Return
############################################################
$TRT_FILTER
If [M:SAD1]FLG = 0
  [M:SAD1]FLG = 1
  Raz [M:SAD2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
      ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  Filter [STA] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILSPE)
&              Order By Key STA0
  Raz [F:STA]
Endif
Return
############################################################
$LOAD_FILTER
WFIL  = "[F:STA]STOFCY=[M:SAD1]FCY"
WFIL += "&[F:STA]ITMREF=[M:SAD1]ITMREF"
WFIL += "&[F:STA]ALLTYP=2"
If [M:SAD1]VCRTYP <> 1
  WFIL += "&[F:STA]VCRTYP=[M:SAD1]VCRTYP-1"
Endif
If [M:SAD1]VCRNUM <> ""
  WFIL += "&pat([F:STA]VCRNUM,[M:SAD1]VCRNUM)"
Endif
If [M:SAD1]STOCOUSEL <> 0
  WFIL += "&[F:STA]STOCOU=[M:SAD1]STOCOUSEL"
Endif
Return
############################################################
$LOA_LIGNE
WAGR = 0
Read [STO2]STO0=[F:STA]STOFCY;[F:STA]STOCOU
If fstat
  Raz [F:STO2]
Endif

# Nouvelle ligne écran
[M:SAD2] = [F:STO2]
[M:SAD2]VCRTYP(nolign-1)    = [F:STA]VCRTYP
[M:SAD2]VCRNUM(nolign-1)    = [F:STA]VCRNUM
[M:SAD2]STU(nolign-1)       = [F:ITM]STU
[M:SAD2]QTYSTU(nolign-1)    = [F:STA]QTYSTU
If dim([M:SAD2]QTYSTUACT(nolign-1)) > 0
  [M:SAD2]QTYSTUACT(nolign-1) = [F:STA]QTYSTUACT
Endif
# Issue 110327 US 70
[M:SAD2]SERNUM(nolign-1) = [F:STA]SERNUM

#----------------------------------------------------------
# V150 : vérification que l'on peut consommer l'allocation
#----------------------------------------------------------
# Si allocation de commande ou OF ou EO
If find([M:SAD2]VCRTYP(nolign-1),2,10,36)
  If [M:SAD2]VCRTYP(nolign-1)=2
    Read [SOH]SOH0=[F:STA]VCRNUM
    If !fstat & [F:SOH]SOHCAT=2
      [M:SAD2]TRSTYP(nolign-1)=17                        # hcb 120137
    Else
      [M:SAD2]TRSTYP(nolign-1)=4
    Endif
  Else
    [M:SAD2]TRSTYP(nolign-1)=6
  Endif
  # Si rupture type de mouvement
  If nolign=1 | [M:SAD2]TRSTYP(nolign-1)<>[M:SAD2]TRSTYP(nolign-2)
    Call LECSRU([M:SAD1]FCY,[F:ITM]TCLCOD,[M:SAD2]TRSTYP(nolign-1),"","",LRET) From STKLIB
    If LRET=1
      Raz [F:SRU]
      WCRITSTO = "1=1"
    Else
      # Stockage dans WCRITSTO des statuts/sous-statuts autorisés
      Call CTRL_STATUT("[F:STO2]","",WCRITSTO) From STKALL
    Endif
  Endif

  Raz [M:SAD2]FLGERR(nolign-1)
  # Si inventaire en cours ou demande d'analyse ou statut interdit
  If [F:STO2]CUNLOKFLG=2   [M:SAD2]FLGERR(nolign-1)+=1  Endif
  If [F:STO2]QLYCTLDEM<>"" [M:SAD2]FLGERR(nolign-1)+=2  Endif
  If !evalue(WCRITSTO)     [M:SAD2]FLGERR(nolign-1)+=4  Endif
  # La ligne de stock en attente de rangement est-elle complète?
  If [F:STO2]LOCCAT=2
    Raz LRET
    Call CTLPLFLOC([F:ITM]ITMREF,"[F:STO2]",LRET) From STKSOR
    If LRET<>0  [M:SAD2]FLGERR(nolign-1)+=8  Endif
  Endif
Endif


# Point d'entrée pour permettre à l'utilisateur de charger des zones specifiques
# Hcb demande 33817
GPOINT = "CUSLOASAD" : Gosub ENTREE From EXEFNC

Return
############################################################
$SETBOUT
Return
############################################################
$EXEBOUT
Return
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:SAD1]FLG = 0
End
############################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SAD1] = [F:ITM]
End
############################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SAD1]FLG = 0
End
############################################################
Subprog AV_VCRTYP(VALEUR)
Variable Integer VALEUR
If [M:SAD2]FLGERR(nolign-1)=0
   pcolor=GCOUL(0)
Else
   pcolor=GCOUL(1)
Endif
End
############################################################
Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AS_VCRTYP(VALEUR)
Variable Integer VALEUR
#CCC (13/09/10) tout est désactivé par défaut
For I=1 To len(mess(0,725,1))
    If !find(I,1,3,4,5,6,9,11,35,37)
        GMENLOC(I) = 1
    Endif
Next
#--- Dem 63001
#GMENLOC(04) = 1
End

############################################################
Subprog AM_VCRTYP(VALEUR)
Variable Integer VALEUR
[M:SAD1]FLG = 0
End
############################################################
Subprog AM_VCRNUM(VALEUR)
Variable Char    VALEUR()
[M:SAD1]FLG = 0
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSSAD2) 18/01/2005 10:03:58 (TS)
######################################################################################
Subprog IB_NBLIG
If [M:SAD2]FLGERR(nolign-1)=0
   Raz GBOUT3
Endif
# Issue 110327 US 70
If [M:SAD2]SERNUM = "" | [F:ITM]SERMGTCOD <> 4
  Raz GBOUT1
Endif
End

Subprog B3_NBLIG
Raz GMESSAGE
If [M:SAD2]FLGERR(nolign-1)>=8
   GMESSAGE+=mess(378,199,1)-":"-mess(208,184,1)+"\"
   [M:SAD2]FLGERR(nolign-1)-=8
Endif
If [M:SAD2]FLGERR(nolign-1)>=4
   GMESSAGE+=mess(4,196,1)-":"-mess([M:SAD2]TRSTYP(nolign-1),704)+"\"
   [M:SAD2]FLGERR(nolign-1)-=4
Endif
If [M:SAD2]FLGERR(nolign-1)>=2
   GMESSAGE+=mess(460,199,1)+"\"
   [M:SAD2]FLGERR(nolign-1)-=2
Endif
If [M:SAD2]FLGERR(nolign-1)>=1
   GMESSAGE+=mess(126,184,1)
   [M:SAD2]FLGERR(nolign-1)-=1
Endif
Call MESSAGE(GMESSAGE) From GESECRAN
Raz GMESSAGE
End

