#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(30)(1..4) , VALEUR(10)
PARAM(1) = ""
PARAM(2) = "00000000"
Call SAISIE_CHAR(VALEUR,PARAM,"MAJCUM","MAJCUMS","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"          : Gosub OUVRE
 When "DEBUT"          : Gosub DEBUT
 When "APRES_MODIF"    : Gosub APRES_MODIF
 When "ENR"            : Gosub ENREGISTRE
 When "ABA"            : Gosub ABANDON
 When "END"            : Gosub FIN
 When "SETBOUT"        : Gosub SETBOUT
 When "SUI"            : Gosub SUI
 When "PRE"            : Gosub PRE
 When "FIR"            : Gosub FIR
 When "LAS"            : Gosub LAS
Endcase
Return

$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GREPORT1 = "FICHECUMUL"
Return

$DEBUT
Local Char SYMBOLE(50)
If clalev([F:HSP])=0 : Local File HISTOPAYE [HSP] : Endif
If clalev([F:CUM])=0 : Local File CUMUL     [CUM] : Endif
If clalev([F:VEP])=0 : Local File VALEMP    [VEP] : Endif
If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif

Gosub OUVRE From WPDEFTABLE
GREP = ""
Raz [M]
If PARAM(1)<>""
 [M]REFNUM = PARAM(1)
 Call LECTURE ("EML",[M]REFNUM,"") From CONTOBJ
 [M]NAM = [F:ID]NAM-[F:ID]SRN
Endif
If PARAM(2)<>[0/0/0]
 [M]PYRDAT = gdat$(PARAM(2))
Endif
If PARAM(3)<>""
 [M]BUL = PARAM(3)
Else
 Filter [VEP] Where EMP=[M]REFNUM & PYRDAT=[M]PYRDAT
 Read [VEP]VEP0 Last
 Filter [VEP]
 If fstat<=2
  [M]BUL    = [F:VEP]BUL
 Endif
Endif
If dim([M]LEG)>0
 If PARAM(4)<>""
  [M]LEG = PARAM(4)
 Elsif GLEGFIL<>""
  [M]LEG = GLEGFIL
 Endif
Endif
If [M]REFNUM<>"" & [M]PYRDAT<>[0/0/0] & [M]BUL<>""
 Gosub CHARGE
Endif
Return

$APRES_MODIF
 If COUZON="NBRLIG"
  If GREP=""
   If instr(1,GUSRAUZ(1),"M")
    Gosub VERROU
    If OK
     GREP = "M"
     Gosub GRISE
    Else
     GMESSAGE = mess(10,100,1) : # Modif en cours...
     GERR = 1
    Endif
   Else
    mkstat = 2
   Endif
  Endif
 Endif
Return

$GRISE
Grizo PYRDAT,REFNUM
If dim([M]LEG)>0
 Grizo LEG
Endif
Return

$DEGRISE
Actzo PYRDAT,REFNUM
If dim([M]LEG)>0
 Actzo LEG
Endif
Return

$VERROU
SYMBOLE = "VEP"+format$("D:"+GFMDAT,[M]PYRDAT)+"\"+[M]CTRNUM+format$("D:"+GFMDAT,[M]CTRDAT)
Lock =SYMBOLE
If fstat
 OK = 0
Else
 OK = 1
Endif
Return

$DEVERROU
If SYMBOLE<>""
 Unlock =SYMBOLE
 SYMBOLE = ""
Endif
Return

$CHARGE
Effzo 20
nolign = 0
For [CUM]CUM0 Where CUMTMP<>2 and LEG=GCURLEG
#MIPEA - 2016-07-28 - REQ 114309 US274 - START
  If dim([M]CODCUM)<nolign+1
  #If IM([M]CODCUM)<nolign+1
#MIPEA - 2016-07-28 - REQ 114309 US274 - END
  # Tableau plein
  Call ERREUR(mess(26,100,1)) From GESECRAN
  Break
 Endif
 nolign += 1
 [M]CODCUM(nolign-1) = [F:CUM]CUMCOD
 Call LECTEXTRA([M]DES(nolign-1),"CUMUL","CUMDES",[F:CUM]LEG,[F:CUM]CUMCOD) From ATEXTRA
 [M]CUMPER(nolign-1) = [F:CUM]CUMPER
Next
[M]NBRLIG = nolign
For [HSP]HSP0 Where BUL=[M]BUL & TYP=6
 K = find([F:HSP]RUB,[M]CODCUM(0..[M]NBRLIG-1))
 If K
  [M]AMTPAY(K-1)  = [F:HSP]AMT-[F:HSP]BAS
  [M]AMTCUM(K-1)  = [F:HSP]AMT
  [M]OAMTPAY(K-1) = [M]AMTPAY(K-1)
  [M]OAMTCUM(K-1) = [M]AMTCUM(K-1)
 Endif
Next
Read [VEP]VEP5 = [M]BUL
If !fstat
 [M]CTRNUM = [F:VEP]CTRNUM
 ##**82073
 [M]CTRDAT = [F:VEP]CTRDAT
 Call LECTURE("FCY",[F:VEP]FCY,"") From CONTOBJ
 [M]CPY = [F:FCY]LEGCPY
Endif
Affzo
Return

$ENREGISTRE
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 Gosub DEVERROU
 Gosub DEGRISE
 GREP = ""
Endif
Return

$TR1
GOK = 1
Trbegin [HSP]
 For nolign=1 To [M]NBRLIG
  If [M]AMTPAY(nolign-1)<>[M]OAMTPAY(nolign-1) or [M]AMTCUM(nolign-1)<>[M]OAMTCUM(nolign-1)
   Readlock [HSP]HSP3 = [M]BUL;[M]CODCUM(nolign-1);6
   If fstat=1
    GOK = -1 : GLOCK = "$HISTOPAYE"-[M]REFNUM-[M]CODCUM(nolign-1) : Break
   Elsif fstat
    Raz [F:HSP]
    [F:HSP]BUL = [M]BUL
    [F:HSP]EMP = [M]REFNUM
    [F:HSP]CTRNUM = [M]CTRNUM
    [F:HSP]DAT = [M]PYRDAT
    [F:HSP]RUB = [M]CODCUM(nolign-1)
    Read [CUM]CUM0 = GCURLEG;[M]CODCUM(nolign-1)
    [F:HSP]ROW = [F:CUM]CUMROW
    [F:HSP]TYP = 6
    [F:HSP]AMT = [M]AMTCUM(nolign-1)
    [F:HSP]BAS = [M]AMTCUM(nolign-1)-[M]AMTPAY(nolign-1)
    [F:HSP]LEG= GCURLEG
    Write [HSP]
   Else
    [F:HSP]AMT = [M]AMTCUM(nolign-1)
    [F:HSP]BAS = [M]AMTCUM(nolign-1)-[M]AMTPAY(nolign-1)
    Rewrite [HSP]
   Endif
   If fstat
    GOK = 0 : Call FSTA("HSP") From GLOCK : Break
   Endif
  Endif
 Next nolign
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$ABANDON
Gosub CHARGE
GREP = ""
Gosub DEGRISE
Gosub DEVERROU
Return

$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Gosub DEVERROU
Return

$SETBOUT
CHMEN = ""
CHBOU = ""
If GREP="M"
 CHBOU = "EA"
 STADEF = GSTAENR
Else
 If [M]REFNUM<>""
  CHBOU = "<>09I"
 Endif
Endif
Gosub SET_BOUT_STD From GSAISIE
Gosub SET_BOUT_SPE From GSAISIE
Return

$SUI
##**82073
#Read [VEP]VEP0 > [M]REFNUM;[M]PYRDAT;[M]BUL
Filter [VEP] Where EMP=[M]REFNUM
Read [VEP]VEP0 Next
Filter [VEP]
Goto SUIVPREC

$PRE
##**82073
#Read [VEP]VEP0 < [M]REFNUM;[M]PYRDAT;[M]BUL
Filter [VEP] Where EMP=[M]REFNUM
Read [VEP]VEP0 Prev
Filter [VEP]
Goto SUIVPREC

$FIR
Filter [VEP] Where EMP=[M]REFNUM
Read [VEP]VEP0 First
Filter [VEP]
Goto SUIVPREC

$LAS
Filter [VEP] Where EMP=[M]REFNUM
Read [VEP]VEP0 Last
Filter [VEP]
Goto SUIVPREC

$SUIVPREC
If fstat<=2
 [M]PYRDAT = [F:VEP]PYRDAT
 [M]BUL    = [F:VEP]BUL
 Gosub CHARGE
Else
 Call MESSAGE(mess(11,100,1)) From GESECRAN
Endif
Return

########################################
## Ecran MAJCUM
########################################
Subprog AS_PYRDAT(VALEUR)
Variable Date    VALEUR
Raz [M]SELBUL
End

Subprog C_PYRDAT(VALEUR)
Variable Date    VALEUR
Read [VEP]VEP0(2) = [M]REFNUM;VALEUR
If fstat
 GMESSAGE = mess(56,10702,1) : # Paye inexistante
 mkstat = 2 : End
Endif
If [M]SELBUL<>""
 [M]BUL = [M]SELBUL
 Raz [M]SELBUL
Else
 Call SELBUL([M]REFNUM,VALEUR,"",[0/0/0],[M]BUL) From DIVPAYE  :##**72216
 If [M]BUL=""
  mkstat = 2 : End
 Elsif [M]REFNUM<>""
  Gosub CHARGE
  If dim([M]LEG)>0
   Grizo [M]LEG
  Endif
 Endif
Endif
Affzo BUL
End

Subprog AM_PYRDAT(VALEUR)
Variable Date    VALEUR
## Zone CPY utile pour charger les paramètres d'impression de l'état FICHECUMUL
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Call LECTURE("FCY",[F:VEP]FCY,"") From CONTOBJ
[M]CPY = [F:FCY]LEGCPY
If [M]REFNUM<>"" & [M]BUL<>""
 Gosub CHARGE
Endif

End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Call LECTURE ("EML",VALEUR,"") From CONTOBJ
[M]NAM = [F:ID]NAM-[F:ID]SRN
If [M]PYRDAT<>[0/0/0] & [M]BUL<>""
 Gosub CHARGE
Endif
End

#Subprog AM_LEG(VALEUR)
#Variable Char    VALEUR()
##GCURLEG=VALEUR
#End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG=VALEUR
End

