#<AdxTL>@(#)4.0.0.0 $Revision$
##################################################################################
# UU66229                                                                        #
# Suppression du traitement TRTFASCNLRPR dans les dossiers applicatifs qui ne    #
# sont pas des dossiers de test.                                                 #
# Moulinette exécutée EXCLUSIVEMENT sur le dossier racine                        #
# Fq66229                                                                        #
##################################################################################
 Call OUVRE_TRACE("Test moulinette UU66229") From LECFIC
 Call PATCH(nomap)
 Call LEC_TRACE From LECFIC
End
#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(PAPPLI)
Value Char    PAPPLI
 If nomap<>GDOSX3 : End : Endif
 If filinfo(filpath("FIL","ADOSSIER","fde",GDOSX3),0)<=0
  End
 Else
  Call EXE_UU66229(PAPPLI)
 Endif
End
##################################################################################
Subprog PATCH(APPLI)
Value Char APPLI
 If nomap<>GDOSX3 : End : Endif
 Local Char FICHIER(250)
 FICHIER=filpath("FIL","ADOSSIER","fde",GDOSX3)
 If filinfo(FICHIER,0) < 0
  End
 Endif 
  Call EXE_UU66229(APPLI)
 End
End
 
#------ Suppression du traitement ------#
Subprog EXE_UU66229(LDOSSIER)
Value Char LDOSSIER

 #----- Variables locales -----#

 Local Char     WMSG(80)
 Local Integer OK

 GOK =1

 #-----
 Call ECR_TRACE("UU66229: Remove the TRTFASCNLRPR (other folder than root folder and non test folder) "+LDOSSIER,0) From GESECRAN

 #----- Ouverture des fichiers -----#
 If clalev([F:ZADS]) =0 : Local File =GDOSX3+".ADOSSIER"     [ZADS] : Endif
 If clalev([F:RADC]) =0 : Local File =GDOSX3+".ADICTRT"      [RADC] : Endif
 ##FQ-66732If clalev([F:WADC]) =0 : Local File =LDOSSIER+".ADICTRT"    [WADC] : Endif     

 #----- Boucle sur les dossiers ----#

 Onerrgo ERRTRT
 Read [F:RADC]ADC0="TRTFASCNLRPR"
 For [F:ZADS] Where DOSSIER<>GDOSX3 & TSTFLG<>G_OUI
  GOK=1
  Call ECR_TRACE("    "+"Folder"-[F:ZADS]DOSSIER,0) From GESECRAN
  Call DELTRT("TRTFASCNLRPR",[F:ZADS]DOSSIER) From SUBADC
  If GOK
   If filinfo(filpath("FIL","ADICTRT","fde",LDOSSIER),0)<=0 :  Goto NEXT_DOSS    : Endif     #FQ-66732
   If clalev([F:WADC]) =0 : Local File =LDOSSIER+".ADICTRT"    [WADC] : Endif                #FQ-66732
   Read [F:WADC]ADC0="TRTFASCNLRPR"
   If fstat=5
    [F:WADC]=[F:RADC]
    Write [F:WADC]
    If fstat
     Call ECR_TRACE("    "+"Write [F:WADC] fstat="+num$(fstat),0) From GESECRAN       
    Endif
   Endif
  Endif 
  $NEXT_DOSS
 Next
 Onerrgo

$FIN
 
$FIN2
#----- Fin du traitement -----#
WMSG ="UU66229: end of process"
Call ECR_TRACE(WMSG,0) From GESECRAN

End

$ERRTRT 
 If errn=20
  Call ECR_TRACE("       "+"==> "-errmes$(errn),0) From GESECRAN
 Else
  Call ECR_TRACE("       "+"==> Error"-num$(errn)-errmes$(errn),1) From GESECRAN
 Endif
 GOK=0  
 Resume
Return


