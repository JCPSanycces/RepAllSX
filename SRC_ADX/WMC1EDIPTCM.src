# Supervisor
## ACLA-CLASSE ## EDIPTCM
# 2018-11-06 07:05:00 784


####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : PTCCOD Protocol ( Field PTC 20)
####################################################################

$SET_PTCCOD
If [L]_AOLDVAL<>this.PTCCOD
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_PTCCOD
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.PTCCOD
 Gosub PROPAGATE_PTCCOD
Endif
Return

$INIT_PTCCOD
Gosub DECLARE_VAR From WMC0EDIPTCM
[L]CURPRO = "PTCCOD"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_PTCCOD
Gosub DECLARE_VAR From WMC0EDIPTCM
[L]CURPRO = "PTCCOD"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_PTCCOD                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_PTCCOD                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_PTCCOD
[L]CURPRO = "PTCCOD"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.PTCCOD,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_PTCCOD
[L]CURPRO = "PTCCOD"
If vireblc(this.PTCCOD,2)<>vireblc(format$("K:20c",this.PTCCOD),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_PTCCOD
[L]CURPRO = "PTCCOD"
If vireblc(this.PTCCOD,2)<>""
 If fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent")=""
  [L]ASTATUS =  func WMTYPPTC.ACTRLREF(this,"PTCCOD",this.PTCCOD,this.PTCCOD,"")
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Else
  If this.PTCCOD<>evalue("this.APARENT."+fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent"))
   [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(83,123,1)) :  Return : # Invalid value
  Endif
 Endif
Endif
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_PTCCOD
[L]CURPRO = "PTCCOD"
Return

$PROPAGATE_PTCCOD
this.isReadonly = 0
[L]CURPRO = "PTCCOD"
Gosub _LNKPRO_PTCCOD
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_PTCCOD
Gosub DECLARE_VAR From WMC0EDIPTCM
[L]CURPRO = "PTCCOD"
$_LNKPRO_PTCCOD
If vireblc(this.PTCCOD,2)<>""
 # Link EDIPTC
 Local File EDIPTC [WEPT]
 Read [F:WEPT]EPT0 = this.PTCCOD
 If !fstat
  [L]ASTATUS = fmet this.ASETATTRIBUTE("PTCCOD","$title",[F:WEPT]PTCDES)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("PTCCOD","$description",[F:WEPT]PTCDES)
 Endif
 LogicClose File [WEPT]
Endif
Return

$_ALOADATTRIBUTE_PTCCOD
[L]ASTATUS = fmet this.ASETATTRIBUTE("PTCCOD","$isMandatory","true")
Return


