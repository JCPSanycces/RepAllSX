#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################################################
#  Composant de gestion automatisée du parc client            Module CRM       1 Avril 2003
#
# MACRULE : Sous-programme d'application des règles de gestion automatisée du parc client.
#
##########################################################################################################
##########################################################################################################
# Sous-programme d'application des règles de gestion automatisée du parc client.
##########################################################
Subprog MACRULE(IACTION, SZBPC, IERRINF)
Value Integer IACTION
Value Char SZBPC
Variable Integer IERRINF

Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IBPCTYPE
Local Integer IBDEBTRANSFLG             # FGR 04/01/2011 : X3SUIVI70100

  ICHAPTER = 0
  IBRETOUR = 1
  IERRINF = 0
  #
  #IACTION : Type d'action déclenchant l'intégration.
  # 1 = Enregistrement d'une demande de garantie
  # 2 = Expédition d'un parc vendu
  # 3 = Retour d'un parc vendu
  # 4 = Expédition d'un parc en prêt
  # 5 = Facturation d'un parc en prêt
  # 6 = Retour d'un parc en prêt
  # 7 = Autre
  #SZBPC : Tiers client
  #Contraintes d'utilisation : Le masque [MACW] doit être ouvert.
  # FGR 04/01/2011 : X3SUIVI70100 (début)
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  # FGR 04/01/2011 : X3SUIVI70100 (fin)
  #Contrôle de la présence du masque
  If !clalev([M:MACW]) Then
    #Le masque MACW n'est pas ouvert. Mise à jour du parc abandonnée.
    IERRINF = 91
    End
  Endif
  #
  If [M:MACW]MACPDTCOD = "" Then
    #Aucune référence article n'est précisée.
    IERRINF = 437
    End
  Endif
  #
  #Première vérification de base : L'article est-il géré en création de parc ?
  #
  # Issue X3-68002 - 2018-02-22 by FGR : BEGIN : It's better to have our own local files
  #If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  Local File ITMMASTER [ITM]
  # Issue X3-68002 - 2018-02-22 by FGR : END
  Read [ITM]ITM0=[M:MACW]MACPDTCOD
  If fstat Then
    #Erreur lors de l'analyse des propriétés de l'article traité.
    IERRINF = 92
    End
  Endif
  #
  #Pour les demandes de garantie, on intègre dans tous les cas.
  If IACTION <> 1 Then
    If [F:ITM]CREMAC <> 2 Then
      End
    Endif
  Endif
  # Ouverture des tables nécessaires
  # Issue X3-68002 - 2018-02-22 by FGR : BEGIN : It's better to have our own local files
  #If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  #If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  #If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  #If !clalev([F:COT]) : Local File CONTTEMPL [COT] : Endif
  #If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
  #If !clalev([F:CCV]) : Local File CONTCOV [CCV] : Endif
  #If !clalev([F:CCV8]) : Local File CONTCOV [CCV8] : Endif
  #If !clalev([F:MWR]) : Local File MACWARREQ [MWR] : Endif
  #If !clalev([F:MACR]) : Local File MACHINES [MACR] : Endif
  #If !clalev([F:MACV]) : Local File MACHINES [MACV] : Endif  # FGR 04/01/2011 : X3SUIVI70100 : Comme je dois faire le Trbegin ici, il faut au moins cette table ouverte
  #If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif    # FGR 28/10/2015 : X3SUIVI112034
  #If !clalev([F:CCV9]) : Local File CONTCOV [CCV9] : Endif   # FGR 28/10/2015 : X3SUIVI112034
  #If !clalev([F:TCA]) : Local File TABCOUAFF [TCA] : Endif   # FGR 28/10/2015 : X3SUIVI112034
  #If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif   # FGR 28/10/2015 : X3SUIVI112034
  #If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif  # FGR 28/10/2015 : X3SUIVI112034
  #If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif      # FGR 28/10/2015 : X3SUIVI112034
  #If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif     # FGR 28/10/2015 : X3SUIVI112034
  #If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif    # FGR 28/10/2015 : X3SUIVI112034
  #If !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif    # FGR 28/10/2015 : X3SUIVI112034
  Local File BPCUSTOMER [BPC]
  Local File BPARTNER [BPR]
  Local File BPADDRESS [BPA]
  Local File CONTTEMPL [COT]
  Local File CONTSERV [CON]
  Local File CONTCOV [CCV]
  Local File CONTCOV [CCV8]
  Local File MACWARREQ [MWR]
  Local File MACHINES [MACR]
  Local File MACHINES [MACV]
  Local File MACHINES [MAC]
  Local File CONTCOV [CCV9]
  Local File TABCOUAFF [TCA]
  Local File CONTACTCRM [AIN]
  Local File TABCUR [TCU]
  Local File ATABDIV [ADI]
  Local File FACILITY [FCY]
  Local File COMPANY  [CPY]
  # Issue X3-68002 - 2018-02-22 by FGR : END
  #---------------------------------------------------
  Gosub CHARGE_PARAM_FLYER  # FGR 03/12/2014 : X3SUIVI104350
  #---------------------------------------------------
  #Déclaration des variables principales
  #Catégorie client
  # 1 : Client direct
  # 2 : Revendeur
  # 3 : Grossiste
  # 4 : Utilisateur final
  # 5 : Autre
  #---------------------------------------------------#
  # On détermine le type du client
  #---------------------------------------------------#
  Read [BPC]BPC0=SZBPC
  If fstat Then
    #Erreur lors de la détermination de la catégorie du client.
    IERRINF = 436
    End
  Endif
  Call GETCATCLI([F:BPC]TSCCOD(GCATCLI-1), IBPCTYPE) From CRMUTIL140
  If IBPCTYPE < 0 Then
    #Erreur lors de la détermination de la catégorie du client.
    IERRINF = 436
    End
  Elsif IBPCTYPE > 5 Then
    #Erreur lors de la détermination de la catégorie du client.
    IERRINF = 436
    End
  Elsif IBPCTYPE = 0 Then
    IBPCTYPE = 1
  Elsif IBPCTYPE = 5 Then
    End
  Endif
  # FGR 26/11/2009 : X3SUIVI60333 (début)
  Local Integer IMACAUTOYES

  Gosub PE_MACAUTOYES From TRTCRMPE
  If IMACAUTOYES = 0 Then
    End
  Endif
  # FGR 26/11/2009 : X3SUIVI60333 (fin)

Global Char GSZWARMACRULE(GLONVCR)
Global Char GSZWARNAMRULE(100)
Global Char GSZMACNUMRULE(GLONVCR)
Local Integer IWARRANTYFLG
Local Integer IMUSTFLYER
Local Integer ISERIALFLG
Local Char SZWARNUM(GLONVCR)
Local Integer IERRWAR
Local Integer INBMACDUP
Local Integer ICLSNUM
Local Char SZMACNOTTODEL(GLONVCR)
Local Char SZFLYCAT(GLONADI)
Local Char SZCRECONCXT(GLONADC)
Local Integer IRULEORI
Local Char SZRULEVCRORI(GLONVCR)
Local Date DRULEDAT
Local Integer ICOMPLIANTCON
Local Integer ICOTCAT
Local Integer ICOTPITCDT
Global Integer GSZCOTPITCDT    # FGR 29/04/2008 : X3SUIVI46864

  SZFLYCAT = ""
  INBMACDUP = 0
  SZMACNOTTODEL = ""
  ICLSNUM = 0
  SZWARNUM = ""
  IWARRANTYFLG = 0
  IMUSTFLYER = 0
  ISERIALFLG = 0
  GSZWARMACRULE = ""
  GSZWARNAMRULE = ""
  GSZMACNUMRULE = ""
  ICOTCAT = 0
  ICOTPITCDT = 0
  GSZCOTPITCDT = 0        # FGR 29/04/2008 : X3SUIVI46864
  #
  #Masque pour création d'historique d'implantation
  Local Mask MAC7 [MAC7]
  #
  If [F:ITM]STOMGTCOD = 1 Then
    #Article non géré en stock
    ISERIALFLG = 0
  Else
    #Article géré en stock
    If [F:ITM]SERMGTCOD = 1 Then
      #Article non géré en numéro de série
      ISERIALFLG = 0
    Else
      #Article géré en numéro de série
      ISERIALFLG = 1
      If [M:MACW]MACSERNUM = "" Then
        #Numéro de série manquant.
        IERRINF = 93
        End
      Endif
    Endif
  Endif
  #
  #Contrôle sur les quantités
  If ISERIALFLG Then
    [M:MACW]MACQTY = 1
  Else
    If [M:MACW]MACQTY < 1 Then
      [M:MACW]MACQTY = 1
    Endif
    [M:MACW]MACSERNUM = ""
  Endif
  #
  If [F:ITM]TPLCONGUA <> "" Then
    # FGR 15/09/2008 : X3SUIVI49208 : Si le contrat a déjà un contrat modèle indiqué, on le conserve
    If dim(SZTPLCONGUA) < 0 Then
      Global Char SZTPLCONGUA(GLONVCR)
    Endif
    #
    SZTPLCONGUA = [F:ITM]TPLCONGUA
    # création CONtrat de SERvice AUTo
    Gosub PE_CONSERAUT From TRTCRMPE
    #
    Read [COT]COT0=SZTPLCONGUA
    If !fstat Then
      #Article avec garantie
      IWARRANTYFLG = 1
      GSZWARMACRULE = [F:COT]CONNUM
      GSZWARNAMRULE = [F:COT]TPLNAM
      ICOTCAT = [F:COT]CONCAT
      ICOTPITCDT = [F:COT]PITCDT
      GSZCOTPITCDT = [F:COT]PITCDT    # FGR 29/04/2008 : X3SUIVI46864
    Endif
    If dim(SZTPLCONGUA) > 0 Then
      Kill SZTPLCONGUA
    Endif
  Endif
  SZFLYCAT = [F:ITM]FLYCAT
  # ---------------------------------------------------------------------
  # FGR 04/01/2011 : X3SUIVI70100 (début)
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [MACV]
  Endif
  # FGR 04/01/2011 : X3SUIVI70100 (fin)
  # C'est là que ça fait le boulot
  # Catégorie de coupon
  Case IACTION
    When 1
      # 1 = Enregistrement d'une demande de garantie
      Gosub DORQW
    When 2, 8  # FGR 31/01/2012 : X3SUIVI78319 : traiter ici aussi le cas de la facturation
      # 2 = Expédition d'un parc vendu
      Gosub DOSDH
    When 3
      # 3 = Retour d'un parc vendu
      Gosub DOSRH
    When 4
      # 4 = Expédition d'un parc en prêt
      Gosub DOSDHLND
    When 5
      # 5 = Facturation d'un parc en prêt
      Gosub DOINVLND
    When 6
      # 6 = Retour d'un parc en prêt
      Gosub DOSRL
    When 7
      # 7 = Autre
      Gosub DOOTHER
    When Default
  Endcase
  If IERRINF Then                       # FGR 04/01/2011 : X3SUIVI70100
    If IBDEBTRANSFLG = 0 Then
      Rollback
    Endif
  Else
    If IBDEBTRANSFLG = 0 Then
      Commit
    Endif
  Endif
  # ---------------------------------------------------------------------
  Close Local Mask [MAC7]
  Kill GSZWARMACRULE
  Kill GSZWARNAMRULE
  Kill GSZMACNUMRULE
  Kill GSZCOTPITCDT   # FGR 29/04/2008 : X3SUIVI46864
End

##########################################################################################################
$CHARGE_PARAM_FLYER
Local Char PARAM2(GLONDES)

  # FGR 03/12/2014 : X3SUIVI104350
  # -----------------------------------------------
  Call PARAML([MACW]SALFCY, "WARFLYCRE", PARAM2) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  GWARFLYCRE = val(PARAM2)
  If GWARFLYCRE < 1 or GWARFLYCRE > 10 Then
    GWARFLYCRE = 1  # Par défaut "1:Aucun"
  Endif
  # -----------------------------------------------
  Call PARAML([MACW]SALFCY, "WARFLYDOC", PARAM2) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  GWARFLYDOC = val(PARAM2)
  If GWARFLYDOC < 1 or GWARFLYDOC > 2 Then
    GWARFLYDOC = 1  # Par défaut "1:Non"
  Endif
  # -----------------------------------------------
  Call PARAML([MACW]SALFCY, "WARFLYFCX", PARAM2) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  GWARFLYFCX = val(PARAM2)
  If GWARFLYFCX < 1 or GWARFLYFCX > 5 Then
    GWARFLYFCX = 1  # Par défaut "3:Site"
  Endif
  # -----------------------------------------------
  Call PARAML([MACW]SALFCY, "WARFLYFCY", PARAM2) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  GWARFLYFCY = PARAM2
  # -----------------------------------------------
  Call PARAML([MACW]SALFCY, "WARFLYFCZ", PARAM2) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  GWARFLYFCZ = PARAM2
  # -----------------------------------------------
  Call PARAML([MACW]SALFCY, "WARFLYLTI", PARAM2) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  GWARFLYLTI = val(PARAM2)
  If GWARFLYLTI < 1 or GWARFLYLTI > 5 Then
    GWARFLYLTI = 1  # Par défaut "3:Site"
  Endif
  # -----------------------------------------------
  Call PARAML([MACW]SALFCY, "WARFLYRPT", PARAM2) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  GWARFLYRPT = PARAM2
  # -----------------------------------------------
  Call PARAML([MACW]SALFCY, "WARFLYRSL", PARAM2) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  GWARFLYRSL = val(PARAM2)
  If GWARFLYRSL < 1 or GWARFLYRSL > 2 Then
    GWARFLYRSL = 1  # Par défaut "1:Non"
  Endif
Return

##########################################################################################################
#Gestion du parc depuis une demande de garantie
$DORQW
  #---------------------------------------------------#
  # Etape 1
  # Rédéfinition des informations forcées par le composant
  #---------------------------------------------------#
  #Informations obligatoires
  [M:MACW]MACITNTYP = 1
  [M:MACW]MACORI = 5
  [M:MACW]PREORI = [M:MACW]MACORI
  [M:MACW]PREORIVCR = [M:MACW]MACORIVCR
  [M:MACW]PREORIVCRL = [M:MACW]MACORIVCRL
  #Informations facultatives
  [M:MACW]MACITNLND = 1
  #---------------------------------------------------#
  # Etape 2
  # Gestion du parc client
  #---------------------------------------------------#
  IBPCTYPE = 1
  Gosub MNGMAC
  If IERRINF Then
    Return
  Endif
  [M:RQW0]LASCREMAC = GSZMACNUMRULE
  #---------------------------------------------------#
  # Etape 3
  # Gestion de la garantie
  #---------------------------------------------------#
  IRULEORI = 5
  SZRULEVCRORI = [M:RQW0]RQWNUM
  DRULEDAT = [M:MACW]MACITNDAT
  SZCRECONCXT = "TRTMACRUL1"
  Gosub MNGWAR
  If IERRINF Then
    Return
  Endif
  #---------------------------------------------------#
  # Etape 5
  # Gestion de l'historique des demande de garantie
  #---------------------------------------------------#
  #Trbegin [MWR]                        # FGR 04/01/2011 : X3SUIVI70100
  [F:MWR]MACNUM = GSZMACNUMRULE
  [F:MWR]WRENUM = [M:MACW]MACORIVCR
  [F:MWR]CREDAT = date$
  [F:MWR]CONNUM = SZWARNUM
  Write [MWR]
  If fstat
    #Erreur lors de l'enregistrement de l'historique des demandes de garantie.
    IERRINF = 97
    Return
  Endif
Return

##########################################################################################################
#Gestion du parc depuis une livraison
$DOSDH
  #---------------------------------------------------#
  # Etape 1
  # On détermine le type du client
  #---------------------------------------------------#
  If IBPCTYPE < 0 Then
    #Erreur lors de la détermination de la catégorie du client.
    IERRINF = 436
    Return
  Elsif IBPCTYPE > 5 Then
    #Erreur lors de la détermination de la catégorie du client.
    IERRINF = 436
    Return
  Elsif IBPCTYPE = 0 Then
    IBPCTYPE = 1
  Endif
  #---------------------------------------------------#
  # Etape 2
  # Rédéfinition des informations forcées par le composant
  #---------------------------------------------------#
  Case IBPCTYPE
    When 1,4
      [M:MACW]MACITNTYP = 1
      [M:MACW]MACRSL = ""
      If [M:MACW]BPCNUM = ""
        [M:MACW]BPCNUM = SZBPC
      Endif
      [M:MACW]MACBPCPRI = [M:MACW]MACSALPRI
      [M:MACW]MACBPCCUR = [M:MACW]CUR
      [M:MACW]MACBPCDAT = [M:MACW]MACPURDAT
    When 2
      [M:MACW]MACITNTYP = 2
      [M:MACW]BPCNUM = ""
      [M:MACW]MACRSL = SZBPC
      [M:MACW]MACBPCPRI = 0
      [M:MACW]MACBPCCUR = ""
      [M:MACW]MACBPCDAT = [00/00/00]
    When 3
      [M:MACW]MACITNTYP = 3
      [M:MACW]BPCNUM = ""
      [M:MACW]MACRSL = SZBPC
      [M:MACW]MACBPCPRI = 0
      [M:MACW]MACBPCCUR = ""
      [M:MACW]MACBPCDAT = [00/00/00]
  Endcase
  # -------------------------------------
  # FGR 31/01/2012 : X3SUIVI78319 (début) : traitement du cas de la validation de facture
  Case IACTION
    When 2
      [M:MACW]MACORI = 3      #Validation de livraison
    When 8
      [M:MACW]MACORI = 4      #Validation de facture
  Endcase
  # FGR 31/01/2012 : X3SUIVI78319 (fin)
  # -------------------------------------
  [M:MACW]CCNNUM = ""
  [M:MACW]PREORI = [M:MACW]MACORI
  [M:MACW]PREORIVCR = [M:MACW]MACORIVCR
  [M:MACW]PREORIVCRL = [M:MACW]MACORIVCRL
  # Parc en prêt
  [M:MACW]MACITNLND = 1
  # Site d'installation
  If [M:MACW]FCYITN = "" Then
    Read [BPR]BPR0=SZBPC
    If fstat Then
      #Erreur lors de l'affectation du site d'installation par défaut.
      IERRINF = 438
      Return
    Else
      [M:MACW]FCYITN = [F:BPR]BPAADD
    Endif
  Endif
  #---------------------------------------------------#
  # Etape 3
  # Gestion du parc client
  #---------------------------------------------------#
  Gosub MNGMAC
  If IERRINF Then
    Return
  Endif
  #---------------------------------------------------#
  # Etape 4
  # Gestion de la garantie
  #---------------------------------------------------#
  IRULEORI = 3
  If IBPCTYPE = 1 or IBPCTYPE = 4 Then
    SZRULEVCRORI = [M:MACW]MACORIVCR
    DRULEDAT = [M:MACW]MACPURDAT
    SZCRECONCXT = "TRTMACRUL2"
    Gosub MNGWAR
    If IERRINF Then
      Return
    Endif
  Endif
  #---------------------------------------------------#
  # Etape 5
  # Impression des coupons de garantie
  #---------------------------------------------------#
  If IBPCTYPE = 2 or IBPCTYPE = 3 Then
    Gosub MUSTFLYER
    If IMUSTFLYER Then
      Gosub MNGFLYER
      If IERRINF Then
        Return
      Endif
    Endif
  Endif
Return

##########################################################################################################
#Gestion du parc depuis un retour de vente
$DOSRH
  #On ne traite que les fiches parc gérées en numéro de série.
  If !ISERIALFLG Then
    Return
  Endif
  #---------------------------------------------------#
  # Etape 1
  # Vérification des informations obligatoires
  #---------------------------------------------------#
  If [M:MACW]MACITNDAT = [00/00/00] Then
    #La date du retour n'a pas été communiquée.
    IERRINF = 485
    Return
  Endif
  If [M:MACW]MACORIVCR = "" Then
    #Le numéro de pièce du retour n'a pas été communiqué.
    IERRINF = 486
    Return
  Endif
  #---------------------------------------------------#
  # Etape 2
  # Rédéfinition des informations forcées par le composant
  #---------------------------------------------------#
  #Nouvelle implantation
  Case [M:MACW]MACSTA
    When "A", "a"
      [M:MACW]MACITNTYP = 4
    When "Q", "q"
      [M:MACW]MACITNTYP = 5
    When "R", "r"
      [M:MACW]MACITNTYP = 5
    When Default
      [M:MACW]MACITNTYP = 5
  Endcase
  [M:MACW]MACORI = 7
  [M:MACW]BPCNUM = ""
  [M:MACW]FCYITN = ""
  [M:MACW]CCNNUM = ""
  [M:MACW]MACITNLND = 1
  [M:MACW]MACRSL = ""
  [M:MACW]MACBPCPRI = 0
  [M:MACW]MACBPCCUR = ""
  [M:MACW]MACBPCDAT = [00/00/00]
  [M:MACW]MACSALPRI = 0
  [M:MACW]CUR = ""
  [M:MACW]MACPURDAT = [00/00/00]
  [M:MACW]PLE = ""
  #---------------------------------------------------#
  # Etape 3
  # Ajout d'un historique d'implantation et définition de la mise au rebut.
  #---------------------------------------------------#
  Gosub MNGMAI
  If IERRINF Then
    Return
  Endif
  If !IWARRANTYFLG Then
    Return
  Endif
  #---------------------------------------------------#
  # Etape 4
  # Gestion de la couverture
  #---------------------------------------------------#
  Gosub MNGCOV
Return

##########################################################################################################
#Gestion du parc depuis une livraison de prêt
$DOSDHLND
  #---------------------------------------------------#
  # Etape 1
  # Vérification des informations obligatoires
  #---------------------------------------------------#
  If [M:MACW]MACITNDAT = [00/00/00] Then
    #La date de la livraison de prêt n'est pas communiquée.
    IERRINF = 492
    Return
  Endif
  If [M:MACW]MACORIVCR = "" Then
    #Le numéro de pièce de la livraison de prêt n'est pas communiqué.
    IERRINF = 493
    Return
  Endif
  #---------------------------------------------------#
  # Etape 2
  # On détermine le type du client
  #---------------------------------------------------#
  If IBPCTYPE < 0 Then
    #Erreur lors de la détermination de la catégorie du client.
    IERRINF = 436
    Return
  Elsif IBPCTYPE > 5 Then
    #Erreur lors de la détermination de la catégorie du client.
    IERRINF = 436
    Return
  Elsif IBPCTYPE = 0 Then
    IBPCTYPE = 1
  Endif
  #---------------------------------------------------#
  # Etape 3
  # Rédéfinition des informations forcées par le composant
  #---------------------------------------------------#
  # 1 : Client direct
  # 2 : Revendeur
  # 3 : Grossiste
  # 4 : Utilisateur final
  Case IBPCTYPE
    When 1,4
      [M:MACW]MACITNTYP = 1
      [M:MACW]MACRSL = ""
      [M:MACW]BPCNUM = SZBPC
    When 2
      [M:MACW]MACITNTYP = 2
      [M:MACW]MACRSL = SZBPC
      [M:MACW]BPCNUM = SZBPC
    When 3
      [M:MACW]MACITNTYP = 3
      [M:MACW]MACRSL = SZBPC
      [M:MACW]BPCNUM = SZBPC
    When Default
      [M:MACW]MACITNTYP = 1
      [M:MACW]MACRSL = ""
      [M:MACW]BPCNUM = SZBPC
  Endcase
  [M:MACW]MACITNLND = 2
  [M:MACW]CCNNUM = ""
  [M:MACW]MACORI = 3      #Validation de livraison
  [M:MACW]MACSALPRI = 0
  [M:MACW]CUR = ""
  [M:MACW]MACPURDAT = [00/00/00]
  [M:MACW]MACBPCPRI = 0
  [M:MACW]MACBPCCUR = ""
  [M:MACW]MACBPCDAT = [00/00/00]
  [M:MACW]PREORI = [M:MACW]MACORI
  [M:MACW]PREORIVCR = [M:MACW]MACORIVCR
  [M:MACW]PREORIVCRL = [M:MACW]MACORIVCRL
  #Site d'installation
  If [M:MACW]FCYITN = "" Then
    Read [BPR]BPR0=SZBPC
    If fstat Then
      #Erreur lors de l'affectation du site d'installation par défaut.
      IERRINF = 438
      Return
    Else
      [M:MACW]FCYITN = [F:BPR]BPAADD
    Endif
  Endif
  #---------------------------------------------------#
  # Etape 4
  # Gestion du parc client
  #---------------------------------------------------#
  IBPCTYPE = 1
  Gosub MNGMAC
  If IERRINF Then
    Return
  Endif
Return

##########################################################################################################
#Gestion du parc depuis une facturation de prêt
$DOINVLND
  #---------------------------------------------------#
  # Etape 1
  # Vérification des informations obligatoires
  #---------------------------------------------------#
  If [M:MACW]MACORIVCR = "" Then
    #Le numéro de pièce n'est pas communiqué.
    IERRINF = 493
    Return
  Endif
  #---------------------------------------------------#
  # Etape 2
  # On détermine le type du client
  #---------------------------------------------------#
  If IBPCTYPE < 0 Then
    #Erreur lors de la détermination de la catégorie du client.
    IERRINF = 436
    Return
  Elsif IBPCTYPE > 5 Then
    #Erreur lors de la détermination de la catégorie du client.
    IERRINF = 436
    Return
  Elsif IBPCTYPE = 0 Then
    IBPCTYPE = 1
  Endif
  #---------------------------------------------------#
  # Etape 3
  # Rédéfinition des informations forcées par le composant
  #---------------------------------------------------#
  # 1 : Client direct
  # 2 : Revendeur
  # 3 : Grossiste
  # 4 : Utilisateur final
  Case IBPCTYPE
    When 1,4
      [M:MACW]MACITNTYP = 1
      [M:MACW]MACRSL = ""
      [M:MACW]BPCNUM = SZBPC
      [M:MACW]MACBPCPRI = [M:MACW]MACSALPRI
      [M:MACW]MACBPCCUR = [M:MACW]CUR
      [M:MACW]MACBPCDAT = [M:MACW]MACPURDAT
    When 2
      [M:MACW]MACITNTYP = 2
      [M:MACW]MACRSL = SZBPC
      [M:MACW]BPCNUM = ""
    When 3
      [M:MACW]MACITNTYP = 3
      [M:MACW]MACRSL = SZBPC
      [M:MACW]BPCNUM = ""
    When Default
      [M:MACW]MACITNTYP = 1
      [M:MACW]MACRSL = ""
      [M:MACW]BPCNUM = SZBPC
      [M:MACW]MACBPCPRI = [M:MACW]MACSALPRI
      [M:MACW]MACBPCCUR = [M:MACW]CUR
      [M:MACW]MACBPCDAT = [M:MACW]MACPURDAT
  Endcase
  [M:MACW]MACITNLND = 1
  [M:MACW]CCNNUM = ""
  [M:MACW]MACORI = 4      #Validation de facture
  #Site d'installation
  If [M:MACW]FCYITN = "" Then
    Read [BPR]BPR0=SZBPC
    If fstat Then
      #Erreur lors de l'affectation du site d'installation par défaut.
      IERRINF = 438
      Return
    Else
      [M:MACW]FCYITN = [F:BPR]BPAADD
    Endif
  Endif
  #---------------------------------------------------#
  # Etape 4
  # Ajout d'un historique d'implantation ou suppression du parc
  #---------------------------------------------------#
  If ISERIALFLG Then
    Gosub MNGMAI
  Else
    If [M:MACW]PREORIVCR <> "" Then
      If IBPCTYPE = 1 or IBPCTYPE = 4 Then
        Gosub MAI_NOSER_ID
      Elsif IBPCTYPE = 2 or IBPCTYPE = 3 Then
        Gosub MAI_NOSER_DEL
      Endif
    Endif
  Endif
  If IERRINF Then
    Return
  Endif
  #---------------------------------------------------#
  # Etape 5
  # Gestion de la garantie
  #---------------------------------------------------#
  IRULEORI = 4
  If IBPCTYPE = 1 or IBPCTYPE = 4 Then
    SZRULEVCRORI = [M:MACW]MACORIVCR
    DRULEDAT = [M:MACW]MACPURDAT
    SZCRECONCXT = "TRTMACRUL5"
    Gosub MNGWAR
    If IERRINF Then
      Return
    Endif
  Endif
  #---------------------------------------------------#
  # Etape 6
  # Impression des coupons de garantie
  #---------------------------------------------------#
  If IBPCTYPE = 2 or IBPCTYPE = 3 Then
    Gosub MUSTFLYER
    If IMUSTFLYER Then
      Gosub MNGFLYER
      If IERRINF Then
        Return
      Endif
    Endif
  Endif
Return

##########################################################################################################
#Gestion du parc depuis un retour de prêt
$DOSRL
  #---------------------------------------------------#
  # Etape 1
  # Vérification des informations obligatoires
  #---------------------------------------------------#
  If [M:MACW]MACITNDAT = [00/00/00] Then
    #La date du retour n'a pas été communiquée.
    IERRINF = 485
    Return
  Endif
  If [M:MACW]MACORIVCR = "" Then
    #Le numéro de pièce du retour n'a pas été communiqué.
    IERRINF = 486
    Return
  Endif
  #---------------------------------------------------#
  # Etape 2
  # Rédéfinition des informations forcées par le composant
  #---------------------------------------------------#
  #Nouvelle implantation
  Case [M:MACW]MACSTA
    When "A", "a"
      [M:MACW]MACITNTYP = 4
    When "Q", "q"
      [M:MACW]MACITNTYP = 5
    When "R", "r"
      [M:MACW]MACITNTYP = 5
    When Default
      [M:MACW]MACITNTYP = 4
  Endcase
  [M:MACW]MACORI = 8
  [M:MACW]BPCNUM = ""
  [M:MACW]FCYITN = ""
  [M:MACW]CCNNUM = ""
  [M:MACW]MACITNLND = 1
  [M:MACW]MACRSL = ""
  [M:MACW]MACBPCPRI = 0
  [M:MACW]MACBPCCUR = ""
  [M:MACW]MACBPCDAT = [00/00/00]
  [M:MACW]MACSALPRI = 0
  [M:MACW]CUR = ""
  [M:MACW]MACPURDAT = [00/00/00]
  [M:MACW]PLE = ""
  #---------------------------------------------------#
  # Etape 3
  # Ajout d'un historique d'implantation ou suppression du parc
  #---------------------------------------------------#
  If ISERIALFLG Then
    Gosub MNGMAI
  Else
    If [M:MACW]PREORIVCR <> "" Then
      Gosub MAI_NOSER_DEL
    Endif
  Endif
  If IERRINF Then
    Return
  Endif
Return

##########################################################################################################
#Gestion du parc depuis on ne sait pas quoi
$DOOTHER
  Gosub PE_CUSRUL From TRTCRMPE
Return

##########################################################################################################
Subprog CREMINCOV(SZCONNUM, SZMACNUM, SZBPC, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZCONNUM
Value Char SZMACNUM
Value Char SZBPC
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IRECNUM
Local Char SZRECNUM(GLONVCR)
Local Integer ITER
Local Integer ICOVFOUND
Local Char SZPDTCOD(GLONITM)
Local Char SZFAMCIA(GLONADI)
Local Integer IBDEBTRANSFLG
Local Char REQSQL(250)(5)

  # FGR 28/10/2015 : X3SUIVI112034 : version SQL
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  IRECNUM = 0
  ITER = 0
  #ICOVFOUND = 0             # Issue X3-90641 - 2018-06-01 by FGR
  # Issue X3-68002 - 2018-02-22 by FGR : BEGIN : It's better to have our own local files
  #If !clalev([F:CCV]) : Local File CONTCOV [CCV] : Endif
  #If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
  #If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  #If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif
  Local File CONTCOV [CCV]
  Local File CONTSERV [CON]
  Local File ITMMASTER [ITM]
  Local File MACHINES [MAC]
  # Issue X3-68002 - 2018-02-22 by FGR : END
  # ------------------------------------
  If [F:CON]CONNUM <> SZCONNUM Then     # FGR 28/10/2015 : X3SUIVI112034
    Read [CON]CON0=SZCONNUM
    If fstat Then
      #Erreur lors la lecture de la mention Couverture croisée sur le contrat de service.
      IERRINF = 443
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      End
    Endif
  Endif
  # ------------------------------------
  # FGR 28/10/2015 : X3SUIVI112034 (début)
  #  Read [MAC]MAC0=SZMACNUM
  #  If fstat Then
  #    #Erreur lors du contrôle de l'attribution de la couverture minimum de la fiche parc.
  #    IERRINF = 423
  #    ICHAPTER = 182
  #    IBRETOUR = 0
  #    GOK = 0
  #    End
  #  Else
  #    If [F:MAC]MACPDTCOD = "" Then
  #      #Erreur lors du contrôle de l'attribution de la couverture minimum de la fiche parc.
  #      IERRINF = 423
  #      ICHAPTER = 182
  #      IBRETOUR = 0
  #      GOK = 0
  #      End
  #    Else
  #      SZPDTCOD = [F:MAC]MACPDTCOD
  #    Endif
  #  Endif
  #  Read [ITM]ITM0=SZPDTCOD
  #  If fstat Then
  #    #Erreur lors du contrôle de l'attribution de la couverture minimum de la fiche parc.
  #    IERRINF = 423
  #    ICHAPTER = 182
  #    IBRETOUR = 0
  #    GOK = 0
  #    End
  #  Else
  #    SZFAMCIA = [F:ITM]TSICOD(GFAMCIA-1)
  #  Endif
  If [F:MAC]MACNUM <> SZMACNUM Then
    Read [MAC]MAC0=SZMACNUM
    If fstat Then
      #Erreur lors du contrôle de l'attribution de la couverture minimum de la fiche parc.
      IERRINF = 423
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      End
    Endif
  Endif
  If [F:MAC]MACPDTCOD = "" Then
    #Erreur lors du contrôle de l'attribution de la couverture minimum de la fiche parc.
    IERRINF = 423
    ICHAPTER = 182
    IBRETOUR = 0
    GOK = 0
    End
  Else
    SZPDTCOD = [F:MAC]MACPDTCOD
  Endif
  If [F:ITM]ITMREF <> SZPDTCOD Then
    Read [ITM]ITM0=SZPDTCOD
    If fstat Then
      #Erreur lors du contrôle de l'attribution de la couverture minimum de la fiche parc.
      IERRINF = 423
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      End
    Endif
  Endif
  SZFAMCIA = [F:ITM]TSICOD(GFAMCIA-1)
  # FGR 28/10/2015 : X3SUIVI112034 (fin)
  # ------------------------------------
  #Recherche d'une couverture principale applicable au parc créé.
  #ITER = 0 : Couverture simple
  #ITER = 1 : Couverture croisée
  For ITER = 0 To 1
    #Couverture de niveau parc
    If ITER = 0 Then
      #Filter [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "MAC" and [F:CCV]CMT = SZMACNUM and [F:CCV]PAEKEY(0) = ""
      # Issue X3-90641 - 2018-06-01 by FGR : BEGIN
      #REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND SBBRECTYP_0='MAC' AND CMT_0='" + SZMACNUM + "' AND PAEKEY_0=''"
      REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND SBBRECTYP_0='MAC' AND CMT_0='" + SZMACNUM + "' AND PAEKEY_0=' '"
      # Issue X3-90641 - 2018-06-01 by FGR : END
    Else
      #Filter [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "MAC" and [F:CCV]CMT = SZMACNUM and [F:CCV]PAEKEY(0) <> ""
      # Issue X3-90641 - 2018-06-01 by FGR : BEGIN
      #REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND SBBRECTYP_0='MAC' AND CMT_0='" + SZMACNUM + "' AND PAEKEY_0<>''"
      REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND SBBRECTYP_0='MAC' AND CMT_0='" + SZMACNUM + "' AND PAEKEY_0<>' '"
      # Issue X3-90641 - 2018-06-01 by FGR : END
    Endif
    For (Integer ICOVFOUND) From num$(GTYPDBA*2+1) Sql REQSQL(0..0) As [BZZ]
      [L]ICOVFOUND = [F:BZZ]ICOVFOUND     # Issue X3-90641 - 2018-06-01 by FGR
      Break
    Next
    If [L]ICOVFOUND Then
      Break
    Endif
    #Couverture de niveau référence article
    If ITER = 0 Then
      #Filter [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "ITM" and [F:CCV]CMT = SZPDTCOD and [F:CCV]PAEKEY(0) = ""
      # Issue X3-90641 - 2018-06-01 by FGR : BEGIN
      #REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND SBBRECTYP_0='ITM' AND CMT_0='" + SZPDTCOD + "' AND PAEKEY_0=''"
      REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND SBBRECTYP_0='ITM' AND CMT_0='" + SZPDTCOD + "' AND PAEKEY_0=' '"
      # Issue X3-90641 - 2018-06-01 by FGR : END
    Else
      #Filter [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "ITM" and [F:CCV]CMT = SZPDTCOD and [F:CCV]PAEKEY(0) <> ""
      # Issue X3-90641 - 2018-06-01 by FGR : BEGIN
      #REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND SBBRECTYP_0='ITM' AND CMT_0='" + SZPDTCOD + "' AND PAEKEY_0<>''"
      REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND SBBRECTYP_0='ITM' AND CMT_0='" + SZPDTCOD + "' AND PAEKEY_0<>' '"
      # Issue X3-90641 - 2018-06-01 by FGR : END
    Endif
    For (Integer ICOVFOUND) From num$(GTYPDBA*2+1) Sql REQSQL(0..0) As [BZZ]
      [L]ICOVFOUND = [F:BZZ]ICOVFOUND     # Issue X3-90641 - 2018-06-01 by FGR
      Break
    Next
    If [L]ICOVFOUND Then
      Break
    Endif
    #Couverture de niveau famille commerciale de produit
    If SZFAMCIA <> "" Then
      If ITER = 0 Then
        #Filter [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "CIA" and [F:CCV]CMT = SZFAMCIA and [F:CCV]PAEKEY(0) = ""
        # Issue X3-90641 - 2018-06-01 by FGR : BEGIN
        #REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND SBBRECTYP_0='CIA' AND CMT_0='" + SZFAMCIA + "' AND PAEKEY_0=''"
        REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND SBBRECTYP_0='CIA' AND CMT_0='" + SZFAMCIA + "' AND PAEKEY_0=' '"
        # Issue X3-90641 - 2018-06-01 by FGR : END
      Else
        #Filter [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "CIA" and [F:CCV]CMT = SZFAMCIA and [F:CCV]PAEKEY(0) <> ""
        # Issue X3-90641 - 2018-06-01 by FGR : BEGIN
        #REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND SBBRECTYP_0='CIA' AND CMT_0='" + SZFAMCIA + "' AND PAEKEY_0<>''"
        REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND SBBRECTYP_0='CIA' AND CMT_0='" + SZFAMCIA + "' AND PAEKEY_0<>' '"
        # Issue X3-90641 - 2018-06-01 by FGR : END
      Endif
      For (Integer ICOVFOUND) From num$(GTYPDBA*2+1) Sql REQSQL(0..0) As [BZZ]
        [L]ICOVFOUND = [F:BZZ]ICOVFOUND   # Issue X3-90641 - 2018-06-01 by FGR
        Break
      Next
      Filter [CCV]
      If [L]ICOVFOUND Then
        Break
      Endif
    Endif
  Next
  If [L]ICOVFOUND Then
    End
  Endif
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [CCV]
  Endif
  #Calcul le dernier RECNUM couverture simple
  IRECNUM = 0
  Call CPTCOVNUM(SZCONNUM, 0, "", SZRECNUM, IRECNUM) From SUBMACB
  #Création de la couverture minimum simple
  [F:CCV]CONNUM = SZCONNUM
  [F:CCV]TPL = 1
  [F:CCV]BPC = SZBPC
  [F:CCV]RECTYP = "MAC"
  [F:CCV]SBBRECTYP = "MAC"
  [F:CCV]RECNUM = num$(IRECNUM)
  [F:CCV]CMT = SZMACNUM
  [F:CCV]CPNSRT = "CMACMAC"
  Write [CCV]
  If fstat Then
    #Erreur lors de l'attribution de la couverture minimum à la fiche parc.
    IERRINF = 422
    ICHAPTER = 182
    IBRETOUR = 0
    GOK = 0
  Endif
  If GOK < 1 Then
    If IBDEBTRANSFLG = 0 Then
      Rollback
    Endif
    End
  Endif
  #Création de la couverture minimum croisée
  If [F:CON]CRSCOVSAM = 2 Then
    # FGR 29/04/2008 : X3SUIVI46864 je ne sais pas pourquoi cette table n'est plus ouverte !
    #Local File CONTCOV [CCV9]
    #Local File CONTCOV [CCV9]                                 # FGR 28/10/2015 : X3SUIVI112034
    If !clalev([F:CCV9]) : Local File CONTCOV [CCV9] : Endif   # FGR 28/10/2015 : X3SUIVI112034
    Filter [CCV9] Where [F:CCV9]CONNUM = SZCONNUM and [F:CCV9]TPL <> 2 and [F:CCV9]RECTYP = "PBL"
    For [CCV9]
      IRECNUM = 0
      Call CPTCOVNUM(SZCONNUM, 1, [F:CCV9]RECNUM, SZRECNUM, IRECNUM) From SUBMACB
      Raz [F:CCV]
      [F:CCV]CONNUM = SZCONNUM
      [F:CCV]TPL = 1
      [F:CCV]BPC = SZBPC
      [F:CCV]RECTYP = "MAC"
      [F:CCV]SBBRECTYP = "MAC"
      [F:CCV]RECNUM = num$(IRECNUM)
      [F:CCV]CMT = SZMACNUM
      [F:CCV]CPNSRT = "CMACMAC"
      [F:CCV]PAEKEY(0) = [F:CCV9]RECNUM
      Write [CCV]
      If fstat Then
        #Erreur lors de l'attribution de la couverture minimum à la fiche parc.
        IERRINF = 422
        ICHAPTER = 182
        IBRETOUR = 0
        GOK = 0
        Break
      Endif
      IRECNUM += 1
    Next
    Filter [CCV9]
    #Close Local File [CCV9]                                   # FGR 28/10/2015 : X3SUIVI112034
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End
#Subprog CREMINCOV(SZCONNUM, SZMACNUM, SZBPC, IERRINF,ICHAPTER,IBRETOUR)
#Value Char SZCONNUM
#Value Char SZMACNUM
#Value Char SZBPC
#Variable Integer IERRINF
#Variable Integer ICHAPTER
#Variable Integer IBRETOUR
#
#Local Integer IRECNUM
#Local Char SZRECNUM(GLONDES)
#Local Integer ITER
#Local Integer ICOVFOUND
#Local Char SZPDTCOD(GLONITM)
#Local Char SZFAMCIA(GLONADI)
#Local Integer IBDEBTRANSFLG
#
