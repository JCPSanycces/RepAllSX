##########################################################################################################
# Gestion du parc client
########################################################
$MNGMAC
Local Integer INBMACORI      # FGR 04/01/2011 : X3SUIVI70100
Local Integer IMACECLAT      # FGR 06/10/2015 : X3SUIVI111393
Local Integer IMACQTY        # FGR 06/10/2015 : X3SUIVI111393
Local Decimal ORI_MACSALPRI  # FGR 06/10/2015 : X3SUIVI111393
Local Decimal ORI_MACBPCPRI  # FGR 06/10/2015 : X3SUIVI111393
Local Decimal ECA_MACSALPRI  # FGR 06/10/2015 : X3SUIVI111393
Local Decimal ECA_MACBPCPRI  # FGR 06/10/2015 : X3SUIVI111393

  If ISERIALFLG Then
    #Recherche de la fiche qui normalement existe dans tous les cas
    Read [MACR]MAC5=[M:MACW]MACPDTCOD;[M:MACW]MACSERNUM
    If fstat Then
      #Création de la fiche parc
      Call CREPARC(GSZMACNUMRULE, IERRINF) From SUBMACC
      If IERRINF
        Return
      Endif
    Else
      #Mise à jour de la fiche parc
      # FGR 22/03/2011 : X3SUIVI71721 (début)
      If [M:MACW]MACBRA = "" and [F:MACR]MACBRA <> "" Then
        [M:MACW]MACBRA = [F:MACR]MACBRA
      Endif
      # FGR 22/03/2011 : X3SUIVI71721 (fin)
      Gosub MNGMAI
      If IERRINF Then
        Return
      Endif
    Endif
  Else
    If IBPCTYPE = 1 or IBPCTYPE = 4 Then
      # FGR 04/01/2011 : X3SUIVI70100 (début) on regarde si la fiche existe
      INBMACORI = 0
      Filter [MACR] Where [F:MACR]MACORI = [M:MACW]MACORI and [F:MACR]MACORIVCR = [M:MACW]MACORIVCR and [F:MACR]MACORIVCRL = [M:MACW]MACORIVCRL
      For [MACR]
        INBMACORI += 1
        Break
      Next
      Filter [MACR]
      If INBMACORI > 0 Then
        # Si la fiche existe on ne la crée pas on part c'est tout. Mais ça n'est pas une erreur
        Return
      Endif
      # FGR 04/01/2011 : X3SUIVI70100 (fin) on regarde si la fiche existe
      # --------------------------------------
      # FGR 06/10/2015 : X3SUIVI111393 (début)
      #Call CREPARC(GSZMACNUMRULE, IERRINF) From SUBMACC
      #If IERRINF
      #  Return
      #Endif
      If IMACAUTOYES = 2 and [M:MACW]MACQTY > 1 Then
        # Création de autant de fiche parcs qu'il y a de quantité (une fiche = quantité=1)
        # -----------------------------------
        IMACQTY = [M:MACW]MACQTY
        [M:MACW]MACQTY = 1
        # Repris de SUBMACB.ECLATE_MAC
        ORI_MACSALPRI = [M:MACW]MACSALPRI
        ORI_MACBPCPRI = [M:MACW]MACBPCPRI
        ECA_MACSALPRI = 0
        ECA_MACBPCPRI = 0
        If [M:MACW]MACSALPRI > 0 Then
          [M:MACW]MACSALPRI = [M:MACW]MACSALPRI / IMACQTY
          Call ARRDEV ([M:MACW]MACSALPRI, [M:MACW]CUR) From TRTDIV
          ECA_MACSALPRI = ORI_MACSALPRI - ([M:MACW]MACSALPRI * IMACQTY)
        Endif
        If [M:MACW]MACBPCPRI > 0 Then
          [M:MACW]MACBPCPRI = [M:MACW]MACBPCPRI / IMACQTY
          Call ARRDEV ([M:MACW]MACBPCPRI, [M:MACW]MACBPCCUR) From TRTDIV
          ECA_MACBPCPRI = ORI_MACBPCPRI - ([M:MACW]MACBPCPRI * IMACQTY)
        Endif
        # -----------------------------------
        For IMACECLAT = 1 To IMACQTY
          If IMACECLAT = IMACQTY Then
            # Sur le dernier on ajoute les écarts
            [M:MACW]MACSALPRI = [M:MACW]MACSALPRI + ECA_MACSALPRI
            [M:MACW]MACBPCPRI = [M:MACW]MACBPCPRI + ECA_MACBPCPRI
          Endif
          Call CREPARC(GSZMACNUMRULE, IERRINF) From SUBMACC
          If IERRINF Then
            Break
          Endif
        Next IMACECLAT
        If IERRINF Then
          Return
        Endif
      Else
        # Création standard : une fiche parc quelle que soit la quantité
        Call CREPARC(GSZMACNUMRULE, IERRINF) From SUBMACC
        If IERRINF Then
          Return
        Endif
      Endif
      # FGR 06/10/2015 : X3SUIVI111393 (fin)
      # --------------------------------------
    Endif
  Endif
Return

##########################################################################################################
#  Enregistrement d'un historique d'implantation
########################################################
$MNGMAI
Local Char SZUPDFIELD(10)(19)

  #Recherche de la fiche parc à traiter
  If ISERIALFLG Then
    #Identification par numéro de série
    Gosub MAI_SER_ID
  Endif
  If IERRINF Then
    Return
  Endif
  If GSZMACNUMRULE = "" Then
    #Erreur lors de l'enregistrement d'un nouvel historique d'implantation.
    IERRINF = 136
    Return
  Endif
  #Enregistrement d'un historique d'implantation
  Read [MACR]MAC0=GSZMACNUMRULE
  If fstat Then
    #Erreur lors de l'enregistrement d'un nouvel historique d'implantation.
    IERRINF = 136
    Return
  Endif
  Call RAZ_MAC7 From SUBMACB
  [M:MAC7]MACNUM = GSZMACNUMRULE
  [M:MAC7]ITNTYP = [F:MACR]MACITNTYP
  [M:MAC7]BPCNUM = [F:MACR]BPCNUM
  [M:MAC7]ITNFCY = [F:MACR]FCYITN
  [M:MAC7]PLE = [F:MACR]PLE
  [M:MAC7]CCNNUM = [F:MACR]CCNNUM
  [M:MAC7]RSL = [F:MACR]MACRSL
  [M:MAC7]LND = [F:MACR]MACITNLND
  [M:MAC7]ITNDAT = [F:MACR]MACITNDAT
  [M:MAC7]ORI = [F:MACR]MACORI
  [M:MAC7]ORIVCR = [F:MACR]MACORIVCR
  [M:MAC7]ORIVCRL = [F:MACR]MACORIVCRL
  [M:MAC7]PURDAT = [F:MACR]MACPURDAT
  [M:MAC7]SALPRI = [F:MACR]MACSALPRI
  [M:MAC7]CUR = [F:MACR]CUR
  [M:MAC7]BPCDAT = [F:MACR]MACBPCDAT
  #Infos obtenues depuis la demande de garantie
  [M:MAC7]BPCPRI = [M:MACW]MACBPCPRI
  [M:MAC7]BPCCUR = [M:MACW]MACBPCCUR
  # FGR 24/01/2008 : X3Suivi 45266 En cas de retour ENDITN reçoit la date de retour
  #                  Sinon pas de changement, ENDITN reçoit toujours MACBPCDAT
  If [M:MACW]MACORI = 7 Then
    # Retour sur livraison
    [M:MAC7]ENDITN = [M:MACW]MACITNDAT
  Else
    [M:MAC7]ENDITN = [M:MACW]MACBPCDAT
  Endif
  [M:MAC7]SECPRI = 0
  [M:MAC7]SECCUR = ""
  If [M:MACW]MACMAITRT = "A" Then
    Call GESMAI(ICLSNUM, IERRINF) From SUBMACC
  Else
    Call CREMAI(ICLSNUM, IERRINF) From SUBMACC
  Endif
  If IERRINF Then
    Return
  Endif
  #Mise à jour de l'unique fiche parc restante
  Raz SZUPDFIELD
  SZUPDFIELD(0) = "MACITNTYP"
  SZUPDFIELD(1) = "MACORI"
  SZUPDFIELD(2) = "MACORIVCR"
  SZUPDFIELD(3) = "MACORIVCRL"
  SZUPDFIELD(4) = "BPCNUM"
  SZUPDFIELD(5) = "FCYITN"
  SZUPDFIELD(6) = "CCNNUM"
  SZUPDFIELD(7) = "MACITNDAT"
  SZUPDFIELD(8) = "MACITNLND"
  SZUPDFIELD(9) = "MACRSL"
  SZUPDFIELD(10) = "MACBPCPRI"
  SZUPDFIELD(11) = "MACBPCCUR"
  SZUPDFIELD(12) = "MACBPCDAT"
  SZUPDFIELD(13) = "MACBRA"
  SZUPDFIELD(14) = "PLE"
  SZUPDFIELD(15) = "MACSALPRI"
  SZUPDFIELD(16) = "CUR"
  SZUPDFIELD(17) = "MACPURDAT"
  Call UPDPARC(GSZMACNUMRULE, SZUPDFIELD, IERRINF) From SUBMACC
  If IERRINF Then
    Return
  Endif
Return

##########################################################################################################
# Identification d'une fiche parc par numéro de série
#########################################
$MAI_SER_ID
  #On vérifie qu'il n'y en a qu'une avec ce numéro de série.
  Filter [MACR] Where [F:MACR]MACPDTCOD = [M:MACW]MACPDTCOD and [F:MACR]MACSERNUM = [M:MACW]MACSERNUM Order By [F:MACR]MACNUM Asc
  INBMACDUP = 0
  For [MACR]Hint Key MAC5
    If INBMACDUP = 0 Then
      SZMACNOTTODEL = [F:MACR]MACNUM
    Endif
    INBMACDUP += 1
  Next
  Filter [MACR]
  If INBMACDUP = 0 Then
    #La fiche parc à traiter n'est plus définie dans la base du parc client.
    IERRINF = 494
    Return
  Endif
  If INBMACDUP > 1 Then
    #On supprime les doublons
    Delete [MACR] Where [F:MACR]MACPDTCOD = [M:MACW]MACPDTCOD and [F:MACR]MACSERNUM = [M:MACW]MACSERNUM and [F:MACR]MACNUM <> SZMACNOTTODEL
    If fstat Then
      IERRINF = 1013                    # FGR 04/01/2011 : X3SUIVI70100
      Return                            # FGR 04/01/2011 : X3SUIVI70100
    Endif
  Endif
  GSZMACNUMRULE = SZMACNOTTODEL
Return

##########################################################################################################
# Identification d'une ou de plusieurs fiches parc selon caractéristiques essentielles.
#########################################
$MAI_NOSER_ID
Local Integer IDELTAQTY
Local Integer INBMACINV
Local Integer ITESTSPLIT
Local Char SZMACSPLIT(GLONVCR)

  INBMACINV = 0
  IDELTAQTY = 0
  ITESTSPLIT = 0
  SZMACSPLIT = ""
  Local File MACHINES [MACT]
  #On vérifie qu'il n'y en a qu'une avec ce numéro de série.
  Filter [MACT] Where [F:MACT]MACPDTCOD = [M:MACW]MACPDTCOD and [F:MACT]PREORI = [M:MACW]PREORI and [F:MACT]PREORIVCR = [M:MACW]PREORIVCR and [F:MACT]PREORIVCRL = [M:MACW]PREORIVCRL
&            Order By [F:MACT]MACQTY Desc
  For [MACT] Hint Key MAC5
    If INBMACINV >= [M:MACW]MACQTY Then
      Break
    Endif
    If [M:MACW]MACQTY >= [F:MACT]MACQTY Then
      ITESTSPLIT = [F:MACT]MACQTY + INBMACINV
      If ITESTSPLIT > [M:MACW]MACQTY Then
        IDELTAQTY = ITESTSPLIT - [M:MACW]MACQTY
        GSZMACNUMRULE = [F:MACT]MACNUM
        Gosub SPLITMAC
      Else
        GSZMACNUMRULE = [F:MACT]MACNUM
      Endif
    Else
      IDELTAQTY = [F:MACT]MACQTY - [M:MACW]MACQTY
      GSZMACNUMRULE = [F:MACT]MACNUM
      Gosub SPLITMAC
    Endif
    If IERRINF Then
      Break
    Endif
    INBMACINV += [F:MACT]MACQTY
    Gosub MNGMAI
    If IERRINF Then
      Break
    Endif
  Next
  Filter [MACT]
  Close Local File [MACT]
  If IERRINF Then
    Return
  Endif
  If GSZMACNUMRULE = "" Then
    #Erreur lors de l'identification des fiches parc non gérées en numéro de série.
    IERRINF = 498
  Endif
Return

##########################################################################################################
# Eclatement d'une fiche parc en deux avec répartition des quantités
#########################################################
$SPLITMAC
Local Integer INEWMACQTY
Local Char SZMESSAGE(type(GMESSAGE)-10)
Local Integer INOERROR

  IERRINF = 0
  INEWMACQTY = [F:MACT]MACQTY - IDELTAQTY
  #On split la fiche parc
  Call DUPLIPARC([F:MACT]MACNUM, SZMACSPLIT, SZMESSAGE, INOERROR) From SUBMACC
  If INOERROR = 0 Then
    #Erreur lors de l'enregistrement d'un nouvel historique d'implantation.
    IERRINF = 136
    Return
  Else
    #On remet à niveau les quantités
    Read [MACR]MAC0=[F:MACT]MACNUM
    If !fstat Then
      [F:MACT]MACQTY = INEWMACQTY
      Rewrite [MACT]
      If fstat Then
        #Erreur lors de l'enregistrement d'un nouvel historique d'implantation.
        IERRINF = 136
        Return
      Else
        #On remet à niveau les quantités
        Read [MACT]MAC0=SZMACSPLIT
        If !fstat Then
          [F:MACT]MACQTY = IDELTAQTY
          Rewrite [MACT]
          If fstat Then
            #Erreur lors de l'enregistrement d'un nouvel historique d'implantation.
            IERRINF = 136
            Return
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Suppression d'une ou de plusieurs fiches parc selon caractéristiques essentielles. (Retour de prêt)
#########################################
$MAI_NOSER_DEL
Local Integer IDELTAQTY
Local Integer INBMACINV
Local Integer ITESTSPLIT
Local Char SZMACSPLIT(GLONVCR)

  INBMACINV = 0
  IDELTAQTY = 0
  ITESTSPLIT = 0
  SZMACSPLIT = ""
  Local File MACHINES [MACT]
  #On vérifie qu'il n'y en a qu'une avec ce numéro de série.
  Filter [MACT] Where [F:MACT]MACPDTCOD = [M:MACW]MACPDTCOD and [F:MACT]PREORI = [M:MACW]PREORI and [F:MACT]PREORIVCR = [M:MACW]PREORIVCR and [F:MACT]PREORIVCRL = [M:MACW]PREORIVCRL
&            Order By [F:MACT]MACQTY Desc
  For [MACT] Hint Key MAC5
    If INBMACINV >= [M:MACW]MACQTY Then
      Break
    Endif
    If [M:MACW]MACQTY >= [F:MACT]MACQTY Then
      ITESTSPLIT = [F:MACT]MACQTY + INBMACINV
      If ITESTSPLIT > [M:MACW]MACQTY Then
        IDELTAQTY = ITESTSPLIT - [M:MACW]MACQTY
        [F:MACT]MACQTY = IDELTAQTY
        Rewrite [MACT]
        If fstat Then
          #Erreur lors de la suppression des fiches parc non gérées en numéro de série.
          IERRINF = 499
        Else
          INBMACINV += IDELTAQTY
        Endif
      Else
        INBMACINV += [F:MACT]MACQTY
        Delete [MACR] Where [F:MACR]MACNUM = [F:MACT]MACNUM
        If fstat Then
          #Erreur lors de la suppression des fiches parc non gérées en numéro de série.
          IERRINF = 499
        Endif
      Endif
    Else
      IDELTAQTY = [F:MACT]MACQTY - [M:MACW]MACQTY
      #Trbegin [MACT]                   # FGR 04/01/2011 : X3SUIVI70100
      [F:MACT]MACQTY = IDELTAQTY
      Rewrite [MACT]
      If fstat Then
        #Erreur lors de la suppression des fiches parc non gérées en numéro de série.
        IERRINF = 499
      Else
        INBMACINV += [M:MACW]MACQTY
      Endif
    Endif
    If IERRINF Then
      Break
    Endif
  Next
  Filter [MACT]
  Close Local File [MACT]
  If IERRINF Then
    Return
  Endif
Return

##########################################################################################################
# Gestion de la garantie
#########################################
$MNGWAR
  If !IWARRANTYFLG Then
    Return
  Endif
  ICOMPLIANTCON = 0
  #On recherche d'abord un contrat sur lequel on peut se contenter d'ajouter de la couverture.
  Filter [CON] Where [F:CON]CONORI = IRULEORI and [F:CON]CONORIVCR = SZRULEVCRORI and [F:CON]CONBPC = SZBPC and [F:CON]CONCOT = GSZWARMACRULE and [F:CON]SIUDAT = DRULEDAT
  For [CON]CON2 Hint Key CON5
    Call LOADFROMRULES([F:CON]CONNUM, [F:CON]CONBPC, [F:CON]CONCOT, IERRINF, ICHAPTER, IBRETOUR) From TRTCON9
    If IBRETOUR = 0 Then
      Break
    Endif
    #Si contrat à point, on ajoute de nouveaux points sur le contrat existant
    If ICOTCAT = 4 Then
      [F:CON]PITCDT += ICOTPITCDT
      Rewrite [CON]
      If fstat Then
        #Erreur lors de l'attribution des points sur le contrat de service.
        IERRINF = 555
        Break
      Endif
   Endif
   SZWARNUM = [F:CON]CONNUM
   ICOMPLIANTCON += 1
   Break
  Next
  Filter [CON]
  If IERRINF Then
    Return
  Endif
  If !ICOMPLIANTCON Then
    IERRWAR = 0
    Call CRECON(SZCRECONCXT, 0, 0, SZWARNUM, IERRWAR) From SUBCONC
    If IERRWAR Then
      # Erreur lors de la génération du contrat de service associé à l'article.
      IERRINF = 419
      Return
    Endif
  Endif
  #On vérifie si la fiche parc créée bénéficie d'une couverture minimale au titre de la garantie
  Call CREMINCOV(SZWARNUM, GSZMACNUMRULE, SZBPC, IERRINF, ICHAPTER, IBRETOUR)
Return

##########################################################################################################
# Gestion des coupons de garantie
#########################################
$MNGFLYER
Local Char SZFLYNUM(GLONVCR)
Local Integer ITERFLY

  #--- ouverture de la fenêtre contrat
  If clalev([M:FLY0])=0 : Local Mask FLY0 [FLY0] : Endif
  If clalev([M:FLY1])=0 : Local Mask FLY1 [FLY1] : Endif
  If clalev([M:FLY2])=0 : Local Mask FLY2 [FLY2] : Endif
  If clalev([M:FLY3])=0 : Local Mask FLY3 [FLY3] : Endif
  [M:FLY0]FCY = [MACW]SALFCY
  [M:FLY0]FLYCAT = SZFLYCAT
  [M:FLY0]ITMREF = [M:MACW]MACPDTCOD
  If ISERIALFLG Then
    [M:FLY0]SERNUM = [M:MACW]MACSERNUM
  Else
    [M:FLY0]SERNUM = ""
  Endif
  [M:FLY0]PRNFLG = 1
  Case IRULEORI
    When 3
      [M:FLY0]FLYORI = 2  #Livraison de vente.
    When 4
      [M:FLY0]FLYORI = 3  #Facture de vente.
  Endcase
  [M:FLY0]FLYORIVCR = [M:MACW]MACORIVCR
  [M:FLY0]FLYORIVCRL = [M:MACW]MACORIVCRL
  #Qualification du site de traitement.
  If GWARFLYFCY = "" Then
    #Erreur lors de la génération du coupon de garantie. Site de traitement non communiqué.
    IERRINF = 454
    Return
  Else
    If GWARFLYFCZ = "" Then
      #Erreur lors de la génération du coupon de garantie. Adresse de traitement non communiqué.
      IERRINF = 455
      Return
    Else
      If GWARFLYFCX < 1 Then
        #Erreur lors de la génération du coupon de garantie. Type d'entité de traitement non communiqué.
        IERRINF = 463
        Return
      Else
        Read [BPA]BPA0=GWARFLYFCX;GWARFLYFCY;GWARFLYFCZ
        If fstat Then
          #Erreur lors de la lecture du site de traitement du coupon de garantie.
          IERRINF = 456
          Return
        Endif
        [M:FLY1]BPATYP = GWARFLYFCX
        [M:FLY1]BPANUM = GWARFLYFCY
        [M:FLY1]BPAADD = GWARFLYFCZ
      Endif
    Endif
  Endif
  #Qualification du revendeur.
  If IBPCTYPE = 2 Then
    If GWARFLYRSL = 2 Then
      Read [BPA]BPA0=1;SZBPC;[MACW]FCYITN
      If fstat Then
        #Erreur lors de la lecture de l'adresse du revendeur.
        IERRINF = 457
        Return
      Endif
      [M:FLY2]RSLBPATYP = 1
      [M:FLY2]RSLBPANUM = SZBPC
      [M:FLY2]RSLBPAADD = [MACW]FCYITN
    Endif
  Endif
  #Qualification du destinataire.
  Read [BPA]BPA0=1;SZBPC;[MACW]FCYITN
  If fstat Then
    #Erreur lors de la lecture de l'adresse du destinataire du coupon.
    IERRINF = 458
    Return
  Endif
  [M:FLY3]WHOBPATYP = 1
  [M:FLY3]WHOBPANUM = SZBPC
  [M:FLY3]WHOBPAADD = [MACW]FCYITN
  #Création du coupon
  If ISERIALFLG Then
    Call CREFLY(SZFLYNUM, IERRINF) From SUBFLYC
  Else
    For ITERFLY = 0 To [M:MACW]MACQTY-1
      SZFLYNUM = ""
      Call CREFLY(SZFLYNUM, IERRINF) From SUBFLYC
      If IERRINF Then
        Break
      Endif
    Next
  Endif
  If IERRINF Then
    Return
  Endif
Return

##########################################################################################################
# Impression des coupons de garantie
########################################################################
Subprog PRINTFLYER(IACTION, SZSTRORIVCR, SZENDORIVCR, IERRINF)
Value Integer IACTION
Value Char SZSTRORIVCR
Value Char SZENDORIVCR
Variable Integer IERRINF

Local Integer NBPAR
Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
Local Integer ICATFOUND
Local Char SZCATRPT(type(GMESSAGE)-10)
Local Integer IFLYORI

  If GWARFLYDOC <> 2 Then
    End
  Endif
  #IACTION : Type d'action déclenchant l'intégration.
  # 1 = Enregistrement d'une demande de garantie
  # 2 = Expédition d'un parc vendu
  # 3 = Retour d'un parc vendu
  # 4 = Expédition d'un parc en prêt
  # 5 = Facturation d'un parc en prêt
  # 6 = Retour d'un parc en prêt
  # 7 = Autre
  # Issue X3-68002 - 2018-02-22 by FGR : BEGIN : It's better to have our own local files
  #If !clalev([F:FLY]) : Local File WARFLYER [FLY] : Endif
  #If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  #If !clalev([F:ARP]) : Local File AREPORT [ARP] : Endif
  Local File WARFLYER [FLY]
  Local File ATABDIV [ADI]
  Local File AREPORT [ARP]
  # Issue X3-68002 - 2018-02-22 by FGR : END
  ICATFOUND = 0
  SZCATRPT = ""
  If SZENDORIVCR = "" Then
    SZENDORIVCR = SZSTRORIVCR
  Endif
  If IACTION = 2 Then
    IFLYORI = 2
  Endif
  If IACTION = 5 Then
    IFLYORI = 3
  Endif
  #On vérifie s'il y a des coupons sans catégorie
  ICATFOUND = 0
  Filter [FLY] Where [F:FLY]FLYORI = IFLYORI and [F:FLY]FLYORIVCR >= SZSTRORIVCR and [F:FLY]FLYORIVCR <= SZENDORIVCR and [F:FLY]FLYCAT = ""
  For [FLY]FLY1
    ICATFOUND += 1
    Break
  Next
  Filter [FLY]
  #Impression des coupons sans catégorie
  If ICATFOUND Then
    Raz TBPAR
    Raz TBVAL
    NBPAR = 0
    NBPAR += 1 : TBPAR(NBPAR) = "ori"       : TBVAL(NBPAR) = num$(IFLYORI)
    NBPAR += 1 : TBPAR(NBPAR) = "orivcrdeb" : TBVAL(NBPAR) = SZSTRORIVCR
    NBPAR += 1 : TBPAR(NBPAR) = "orivcrfin" : TBVAL(NBPAR) = SZENDORIVCR
    Call OUVRE_TRACE("") From LECFIC
    Call ETAT(GWARFLYRPT,"PREVISU","",0,"",TBPAR,TBVAL) From AIMP3
    Call FERME_TRACE From LECFIC
  Endif
  #Une impression par catégorie différente
  Filter [ADI] Where [F:ADI]NUMTAB = 450
  For [ADI]
    ICATFOUND = 0
    If [F:ADI]A1 = "" Then
      SZCATRPT = ""
    Else
      #Vérifie que le texte saisi correspond bien à un état Crystal Report.
      Read [ARP]ARP0=[F:ADI]A1
      If fstat Then
        SZCATRPT = ""
      Else
        SZCATRPT = [F:ADI]A1
      Endif
    Endif
    Filter [FLY] Where [F:FLY]FLYORI = IFLYORI and [F:FLY]FLYORIVCR >= SZSTRORIVCR and [F:FLY]FLYORIVCR <= SZENDORIVCR and [F:FLY]FLYCAT = [F:ADI]CODE
    For [FLY]FLY1
      ICATFOUND += 1
      Break
    Next
    Filter [FLY]
    #Impression des coupons avec catégorie
    If ICATFOUND Then
      Raz TBPAR
      Raz TBVAL
      NBPAR = 0
      NBPAR += 1 : TBPAR(NBPAR) = "ori"       : TBVAL(NBPAR) = num$(IFLYORI)
      NBPAR += 1 : TBPAR(NBPAR) = "orivcrdeb" : TBVAL(NBPAR) = SZSTRORIVCR
      NBPAR += 1 : TBPAR(NBPAR) = "orivcrfin" : TBVAL(NBPAR) = SZENDORIVCR
      NBPAR += 1 : TBPAR(NBPAR) = "cat"       : TBVAL(NBPAR) = [F:ADI]CODE
      Call OUVRE_TRACE("") From LECFIC
      If SZCATRPT = "" Then
        Call ETAT(GWARFLYRPT,"PREVISU","",0,"",TBPAR,TBVAL) From AIMP3
      Else
        Call ETAT(SZCATRPT,"PREVISU","",0,"",TBPAR,TBVAL) From AIMP3
      Endif
      Call FERME_TRACE From LECFIC
    Endif
  Next
  Filter [ADI]
End

##########################################################################################################
# Gestion de la couverture
###########################################################
$MNGCOV
Local Integer IOTHERCOV
Local Integer IMACTODEL

  IOTHERCOV = 0
  IMACTODEL = 0
  Local File CONTCOV [CCV2]
  #On cherche les contrats de service à supprimer
  Filter [CCV8] Where [F:CCV8]TPL <> 2 and [F:CCV8]RECTYP = "MAC" and [F:CCV8]SBBRECTYP = "MAC" and [F:CCV8]CMT = GSZMACNUMRULE and [F:CCV8]PAEKEY(0) = ""
  For [CCV8]
    IOTHERCOV = 0
    Filter [CCV2] Where [F:CCV2]CONNUM = [F:CCV8]CONNUM and [F:CCV2]TPL <> 2 and [F:CCV2]RECTYP = "MAC"
    For [CCV2]
      IMACTODEL = 0
      If [F:CCV2]RECTYP = "MAC" Then
        If [F:CCV2]SBBRECTYP = "MAC" Then
          If [F:CCV2]CMT = GSZMACNUMRULE Then
            IMACTODEL = 1
          Endif
        Endif
      Endif
      If !IMACTODEL Then
        IOTHERCOV += 1
      Endif
    Next
    Filter [CCV2]
    If IOTHERCOV Then
      #On Supprime seulement la couverture de niveau parc relative à la fiche parc retournée.
      #Suppression des couvertures de niveau composant relatives à la fiche parc retournée
      Delete [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]CONNUM = [F:CCV8]CONNUM and [F:CCV]RECTYP = "CPN" and [F:CCV]CMT = GSZMACNUMRULE and [F:CCV]PAEKEYTYP(1) = "MAC"
      If fstat Then
        #Erreur lors la suppression de la couverture de niveau composant relative à la fiche parc retournée.
        IERRINF = 487
        Break
      Endif
      #Suppression des couvertures financières de niveau parc.
      Delete [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]CONNUM = [F:CCV8]CONNUM and [F:CCV]RECTYP = "AAA" and [F:CCV]CMT = GSZMACNUMRULE and [F:CCV]PAEKEYTYP(1) = "MAC"
      If fstat Then
        #Erreur lors la suppression de la couverture financière relative à la fiche parc retournée.
        IERRINF = 490
        Break
      Endif
      #Suppression de la couvertures de niveau parc relative à la fiche parc retournée.
      Delete [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]CONNUM = [F:CCV8]CONNUM and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "MAC" and [F:CCV]CMT = GSZMACNUMRULE
      If fstat Then
        #Erreur lors la suppression de la couverture de niveau parc à la fiche parc retournée.
        IERRINF = 491
        Break
      Endif
    Else
      #On supprime le contrat de service.
      Call DELCON([F:CCV8]CONNUM, IERRINF) From SUBCONC
      If IERRINF Then
        Break
      Endif
    Endif
  Next
  Filter [CCV8]
  If IERRINF Then
    Close Local File [CCV2]
    Return
  Endif
  Close Local File [CCV2]
Return

##########################################################################################################
#Détermine si une impression de coupon doit être effectuée
##########################################################################
$MUSTFLYER
  IMUSTFLYER = 0
  If GWARFLYCRE < 2 Then
    Return
  Endif
  Case GWARFLYCRE
    When 2
      IMUSTFLYER = 1
    When 3
      If ISERIALFLG Then
        IMUSTFLYER = 1
      Endif
    When 4
      If ISERIALFLG Then
        IMUSTFLYER = 0
      Else
        IMUSTFLYER = 1
      Endif
    When 5
      If IWARRANTYFLG Then
        If ISERIALFLG Then
          IMUSTFLYER = 1
        Endif
      Endif
    When 6
      If IWARRANTYFLG Then
        If ISERIALFLG Then
          IMUSTFLYER = 0
        Else
          IMUSTFLYER = 1
        Endif
      Endif
    When 7
      If ISERIALFLG Then
        If IWARRANTYFLG Then
          IMUSTFLYER = 0
        Else
          IMUSTFLYER = 1
        Endif
      Endif
    When 8
      If ISERIALFLG Then
        IMUSTFLYER = 0
      Else
        If IWARRANTYFLG Then
          IMUSTFLYER = 0
        Else
          IMUSTFLYER = 1
        Endif
      Endif
    When 9
      If IWARRANTYFLG Then
        IMUSTFLYER = 1
      Endif
    When 10
      If IWARRANTYFLG Then
        IMUSTFLYER = 0
      Else
        IMUSTFLYER = 1
      Endif
  Endcase
Return

