#    End
#  Else
#    If [F:MAC]MACPDTCOD = "" Then
#      #Erreur lors du contrôle de l'attribution de la couverture minimum de la fiche parc.
#      IERRINF = 423
#      ICHAPTER = 182
#      IBRETOUR = 0
#      GOK = 0
#      End
#    Else
#      SZPDTCOD = [F:MAC]MACPDTCOD
#    Endif
#  Endif
#  Read [ITM]ITM0=SZPDTCOD
#  If fstat Then
#    #Erreur lors du contrôle de l'attribution de la couverture minimum de la fiche parc.
#    IERRINF = 423
#    ICHAPTER = 182
#    IBRETOUR = 0
#    GOK = 0
#    End
#  Else
#    SZFAMCIA = [F:ITM]TSICOD(GFAMCIA-1)
#  Endif
#  #Recherche d'une couverture principale applicable au parc créé.
#  #ITER = 0 : Couverture simple
#  #ITER = 1 : Couverture croisée
#  For ITER = 0 To 1
#    #Couverture de niveau parc
#    If ITER = 0 Then
#      Filter [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "MAC" and [F:CCV]CMT = SZMACNUM and [F:CCV]PAEKEY(0) = ""
#    Else
#      Filter [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "MAC" and [F:CCV]CMT = SZMACNUM and [F:CCV]PAEKEY(0) <> ""
