#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UTIACH28 : Utilitaire de rectification des EO           Module Achats  #
##########################################################################
#            FQ 73060 BOMSTUCOE et BOMQTY à 0 si génération automatique  # 
#            FQ 72413 LINAMT,*PRI         à 0 si génération automatique  # 
# GA 07/2011 FQ 74682 Ajout de CHGTYP,CHGCOD,LINAMTL mt converti dev loc #
##########################################################################

Call MAJ_UTIACH28
End

##################################
Subprog MAJ_UTIACH28
Local Char DOSSIER(30) : DOSSIER=nomap
#Call SAIDOS(DOSSIER,"") From SAIDOS
If [L]DOSSIER<>""
   If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
   Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

   Call EXE_UTIACH28([L]DOSSIER)
Endif
End

##################################
Subprog EXE_UTIACH28(DOSSIER)
Value Char DOSSIER

Local Integer I, J, PURALL, LRET

Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIACH28 : Rectification des EO avec données manquantes") From LECFIC  
Call ECR_TRACE("UTIACH28 : Début traitement du dossier "+DOSSIER,0) From GESECRAN

# Traitement des EO
If GMODU(6)=2 : # Module Achat actif 
  Gosub TRT_EO
Endif


$FIN_UTIACH28
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC

End


##################################
$TRT_EO

If clalev([F:SCO])=0  Local File =DOSSIER+".SCOHEAD"    [SCO]  Endif
If clalev([F:SCI])=0  Local File =DOSSIER+".SCOITM"     [SCI]  Endif
If clalev([F:SCM])=0  Local File =DOSSIER+".SCOMAT"     [SCM]  Endif
If clalev([F:SCS])=0  Local File =DOSSIER+".SCOSRV"     [SCS]  Endif
If clalev([F:BOD])=0  Local File =DOSSIER+".BOMD"       [BOD]  Endif
If clalev([F:ITF])=0  Local File =DOSSIER+".ITMFACILIT" [ITF]  Endif
If clalev([F:ITM])=0  Local File =DOSSIER+".ITMMASTER"  [ITM]  Endif
If clalev([F:ITP])=0  Local File =DOSSIER+".ITMBPS"     [ITP]  Endif
If clalev([F:BPR])=0  Local File =DOSSIER+".BPARTNER"   [BPR]  Endif
If clalev([F:BPS])=0  Local File =DOSSIER+".BPSUPPLIER" [BPS]  Endif
Local Char     WSCONUM(GLONVCR),WBPRNUM(GLONBPR)
Local Integer  I,J,K, WBOMALTTYP : WBOMALTTYP=3
Local Shortint STAT, WCHGTYP : STAT=0

Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE("Rectification des matières d'EO",0) From GESECRAN 
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
Call ECR_TRACE(" ",0) From GESECRAN 

# 1er contrôle: BOMSTUCOE,BOMQTY
# ------------------------------
Trbegin [SCM]
Raz I
For [F:SCM]SCM0 Where [F:SCM]BOMSTUCOE=0 
&                   & [F:SCM]SCMTRKFLG<5
    Read [BOD]BOD0=[F:SCM]ITMREF;[F:SCM]BOMALT;[F:SCM]BOMSEQ;[F:SCM]CPNITMREF;WBOMALTTYP
    If !fstat
      [F:SCM]BOMUOM    = [F:BOD]BOMUOM
      [F:SCM]BOMSTUCOE = [F:BOD]BOMSTUCOE 
      [F:SCM]BOMQTY    = [F:BOD]BOMQTY 
    Endif
    If [F:SCM]BOMUOM = "" | [F:SCM]BOMSTUCOE=0
       [F:SCM]BOMUOM   = [F:SCM]STU
       [F:SCM]BOMSTUCOE= 1 
       [F:SCM]BOMQTY   = [F:SCM]LIKQTY 
    Endif
    # mise à jour matière
    Gosub REWRITE_SCM From SCOLIB
    I+=1
Next
If I=0
   Call ECR_TRACE("SCOMAT Aucune anomalie trouvée: BOMSTUCOE,BOMQTY",0) From GESECRAN
Else
   Call ECR_TRACE(num$(I)-"Lignes SCOMAT corrigées: BOMSTUCOE,BOMQTY",0)  From GESECRAN
Endif
Commit

Trbegin [SCM]
# 2eme contrôle: LINAMT,*PRI, matières fournies par le sous-traitant
# ------------------------------------------------------------------
Raz I
For [F:SCM]SCM0 Where [F:SCM]SCOFLG=3 & LINAMT=0 
&                   & [F:SCM]SCMTRKFLG<5
    If [F:SCI]SCONUM<>[F:SCM]SCONUM
       Read [SCO]SCO0=[F:SCM]SCONUM
       If fstat Raz [F:SCO] Endif
       
       Read [SCI]SCI0=[F:SCM]SCONUM;[F:SCM]SCILIN
       If fstat Raz [F:SCI] Endif
    Endif
    Read [ITF]ITF0=[F:SCM]CPNITMREF;[F:SCM]STOFCY
    If fstat Raz [F:ITF] Endif

    If [F:SCM]NETPRI=0
        If I=0 Gosub INIT_TARIF From SCOAUTLIB Endif
        Call UPD_MAT_PRI(-1) From SCOLIB
    Endif
    # mise à jour matière
    Gosub REWRITE_SCM From SCOLIB
    I+=1
Next
If I=0
   Call ECR_TRACE("SCOMAT Aucune anomalie trouvée: LINAMT,*PRI",0) From GESECRAN
Else
   Call ECR_TRACE(num$(I)-"Lignes SCOMAT corrigées: LINAMT,*PRI",0)  From GESECRAN
Endif
Commit

Trbegin [SCS]
# 3eme contrôle: LINAMT,*PRI, tarif du service
# ------------------------------------------------------------------
Raz I
For [F:SCS]SCS0 Where LINAMT=0 
    If [F:SCI]SCONUM<>[F:SCS]SCONUM
       Read [SCO]SCO0=[F:SCS]SCONUM
       If fstat Raz [F:SCO] Endif
       
       Read [SCI]SCI0=[F:SCS]SCONUM;[F:SCS]SCILIN
       If fstat Raz [F:SCI] Endif
    Endif
    Read [ITF]ITF0=[F:SCS]SRVITMREF;[F:SCO]POHFCY
    If fstat Raz [F:ITF] Endif

    If [F:SCS]NETPRI=0
        If I=0 Gosub INIT_TARIF From SCOAUTLIB Endif
        Call UPD_SRV_PRI(-1) From SCOLIB
    Endif
    # mise à jour service
    Gosub REWRITE_SCS From SCOLIB
    I+=1
Next
If I=0
   Call ECR_TRACE("SCOSRV Aucune anomalie trouvée: LINAMT,*PRI",0) From GESECRAN
Else
   Call ECR_TRACE(num$(I)-"Lignes SCOSRV corrigées: LINAMT,*PRI",0)  From GESECRAN
Endif
Commit

# GA 07/2011 FQ 74682 Ajout de CHGTYP,CHGCOD dans SCOHEAD, LINAMTL dans SCOMAT et SCOSRV
Trbegin [SCO]
# 4eme contrôle: Devise , type de cours, cours du document
# ------------------------------------------------------------------
If !clalev([F:PTR]) : Local File =DOSSIER+".PURTRS"      [PTR] : Endif
If GSCOPTRNUM<>""
   Read  [PTR]PTR0=9;GSCOPTRNUM : If fstat : Raz [F:PTR] : Endif
Endif
Raz I,J,K
#Filter [F:SCO] Where CUR="" | CHGTYP=0 | CHGCOE=0 Order By POHFCY;BPRNUM;SCONUM
Filter [F:SCO] Order By POHFCY;BPRNUM;SCONUM
For [F:SCO] 
    If GFCY<>[F:SCO]POHFCY
       GFCY=[F:SCO]POHFCY
       Gosub CHARG_PARAM # pour GSOCIETE, GLOCALDEV
    Endif
    
    If [F:SCO]CUR<>GLOCALDEV
        # FQ 77488 GA 10/2011 taux de conversion à la date LOPESTR: => fait dans UPD_SRV_DAT
        #Call FIND_CUR ([F:SCO]BPRNUM,[F:SCO]ORDDAT,[F:SCO]CUR,WCHGTYP,[F:SCO]CHGCOE) From SCOLIB
        #[F:SCO]CHGTYP=WCHGTYP
        
        Gosub TRT_SCS_LINAMTL
        Gosub TRT_SCM_LINAMTL
    
        # mise à jour entete EO
        Gosub REWRITE_SCO From SCOLIB
        
        # Mise à jour du cout prévisionnel
        Gosub CALC_PREV
        I+=1
     Endif
Next
If I=0
   Call ECR_TRACE("SCOHEAD Aucune anomalie trouvée: CUR,CGHTYP,CHGCOE",0) From GESECRAN
Else
   Call ECR_TRACE(num$(I)-"Entêtes SCOHEAD corrigées: CUR,CGHTYP,CHGCOE",0)  From GESECRAN
   Call ECR_TRACE(num$(J)-"Lignes  SCOSRV  corrigées: LINAMTL",0)  From GESECRAN
   Call ECR_TRACE(num$(K)-"Lignes  SCOMAT  corrigées: LINAMTL",0)  From GESECRAN
Endif
Filter [F:SCO]
Commit

$FIN_UTIACH28_EO
Close Local File [SCO]
Close Local File [SCI]
Close Local File [SCM]
Close Local File [SCS]
Close Local File [BOD]
Close Local File [ITM]
Close Local File [ITF]
Close Local File [ITP]
Return

#----------------------------------------------------------------------#
# Chargement des paramètres avec GFCY = Site de la commande            #
# -------------------------------------------------------------------- #
# Chargement GSOCIETE   : Société juridique                            #
#            GLOCALDEV  : Devise société juridique                     #
#----------------------------------------------------------------------#
$CHARG_PARAM
Local  Char     PARAM2(10)
If [F:ADS]MODULE(1) = 2  # Dossier avec module comptabilité
  Call GLOBVAR(GFCY)  From WWGLOBCPT
  #----- Chargement des globales référentiels, comptes et sections de la société -----#
  Call GETCPY(GFCY,"PTR",9,GSCOPTRNUM) From TRTX3CPT
Endif
Call GLOBVAR(GFCY)    From WWGLOBACH
Raz GMESSAGE
Return

$TRT_SCS_LINAMTL
# FQ 77488 GA 10/2011 ajout | [F:SCO]ORDDAT<>OPESTR pour rectifier le taux de change
For [SCS] Where SCONUM=[F:SCO]SCONUM & (LINAMT*LINAMTL=0 | NETPRI*NETPRIL=0 | [F:SCO]ORDDAT<>OPESTR )

    If J=0
       # FQ 77488 GA 10/2011 taux de conversion à la date LOPESTR
       Call FIND_CUR ([F:SCO]BPRNUM,[F:SCS]OPESTR,[F:SCO]CUR,WCHGTYP,[F:SCO]CHGCOE) From SCOLIB
       [F:SCO]CHGTYP=WCHGTYP
    Endif

    Gosub CALC_LINAMT_SCS From SCOLIB     
    # mise à jour service
    Gosub REWRITE_SCS From SCOLIB
    J+=1
Next
Return

$TRT_SCM_LINAMTL
For [SCM] Where SCONUM=[F:SCO]SCONUM & SCOFLG=3  & ( LINAMT*LINAMTL=0 | NETPRI*NETPRIL=0 )

    Gosub CALC_LINAMT_SCM From SCOLIB     
    # mise à jour composant
    Gosub REWRITE_SCM From SCOLIB
    K+=1
Next
For [SCM] Where SCONUM=[F:SCO]SCONUM & SCOFLG<>3 & LINAMT<>0
   Call ECR_TRACE("Attention SCOMAT  prix renseignés à tors: SCONUM/SCMLIN/CPNITMREF"
&                - [F:SCM]SCONUM+"/"+num$([F:SCM]SCMLIN)+"/"+[F:SCM]CPNITMREF
&   ,1)  From GESECRAN
Next

Return
#----------------------------------------------------------------------#
$CALC_PREV
    Local Char PARAM_CLC(50)(1..14) , VAL_CLC(10)
    PARAM_CLC(1) = [F:SCO]POHFCY
    PARAM_CLC(2) = [F:SCO]SCONUM
    PARAM_CLC(4) = "1"
    PARAM_CLC(5) = "4"
    Case [F:PTR]MCCIMPMOD 
         When 0, 1  : PARAM_CLC(12) = "2"
                      PARAM_CLC(13) = "2"
         When 2     : PARAM_CLC(13) = "2"
         When 3     : PARAM_CLC(12) = "2"
    Endcase
    PARAM_CLC(14) = "36"   : # VCRTYP 36 pour EO
    Call TRAITE_CHAR(VAL_CLC,PARAM_CLC,"","SUBSCC","",3,"") From GTRAITE
Return

########################################################################
Subprog RAZ_CHGTYP(DOSSIER)
Value Char DOSSIER

If clalev([F:SCO])=0  Local File =DOSSIER+".SCOHEAD"    [SCO]  Endif
Trbegin [SCO]

Commit
Close Local File [SCO]
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
############## uniquement si nécessaire de maj les données
############## Call EXE_UTIACH28(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
############## uniquement si nécessaire de maj les données
############## Call EXE_UTIACH28(APPLI)
End

#######################################################################

