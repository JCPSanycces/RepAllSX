#* Function to add records to UKBACRDM which is used for FPS
#* @param DESSRTCOD Local Char, Destination Sort Code
#* @param ORGSRTCOD, Local Char, Origin Sort Code
#* @param EMPID, Local Char, Employee ID
#* @param AMOUNT Local Decimal, Amount paid
#* @return BACS hash (starts with / and random characters from ABCDEFGHIJKLMNOPQRSTUVWXYZ-./0987654321)
#*!
Funprog BACS_RANDOM(DESSRTCOD, ORGSRTCOD, EMPID, AMOUNT)
Value Char DESSRTCOD, ORGSRTCOD, EMPID
Value Decimal AMOUNT
Local Integer RDM, COUNT : COUNT = 0
Local Char DATASET(39), RTN(4)

#AMOUNT = func UK_FUNCTIONS.BACS_NETPAY(EMPID)

RTN = "/"
DATASET = "ABCDEFGHIJKLMNOPQRSTUVWXYZ-./0987654321"
While COUNT < 3
  RDM = rnd(39)
  If RDM > 0
    RTN+=seg$(DATASET,RDM,RDM)
    COUNT+=1
  Endif
Wend
If clalev([BACRDM])=0 : Local File UKBACRDM [BACRDM]  : Endif
## store the hash values in a new tbl
Trbegin [F:BACRDM]
#CHSUL - 2017-12-15 X3-60399 START
  [BACRDM]BNKSRTCOD = func UK_FUNCTIONS.BACS_STRCODSTRIP(DESSRTCOD)
  [BACRDM]SRTCOD = func UK_FUNCTIONS.BACS_STRCODSTRIP(ORGSRTCOD)
#CHSUL - 2017-12-15 X3-60399 END
  [BACRDM]REFNUM = EMPID
  [BACRDM]AMT = AMOUNT
  [BACRDM]RDMSER = RTN
Write [BACRDM]
Commit
End RTN

#CHSUL - 2017-11-10 X3-60399 START
#* Function to return BACS hash based on TOP (latest by date) record from UKBACRDM
#* @param EMPID, Local Char, Employee ID
#* @return BACS hash consisting of Random number plus sort code plus amount empty string if not found
#*!
Funprog GET_BACS_HASH(EMPID)
Value Char EMPID
Local Char RTN(27)

If clalev([BACRDM])=0 : Local File UKBACRDM [BACRDM]  : Endif

Filter [BACRDM] Where REFNUM = [L]EMPID Order By CREDATTIM
Read [BACRDM] Last
If !fstat
  ##serial found
  RTN += [BACRDM]RDMSER
  RTN += [BACRDM]SRTCOD
  RTN += [BACRDM]BNKSRTCOD
  RTN += format$("N0:11", [BACRDM]AMT * 100)
Endif
Filter [BACRDM]
End RTN
#CHSUL - 2017-11-10 X3-60399 END

Funprog BACS_SERIAL(INCPY)
Value Char INCPY
Local Integer FOUND : FOUND = 0
Local Char SERIAL(6)

If clalev([BACSER])=0 : Local File UKBACSER [BACSER]  : Endif

While FOUND = 0
  SERIAL = func UK_FUNCTIONS.GEN_BACS_SERIAL()
  Filter [BACSER] Where SER = SERIAL and CPY = INCPY
  Read [BACSER] First
  If fstat
    # save the serial and the company each serail should be unique per company
    Trbegin [F:BACSER]
      [BACSER]CPY = INCPY
      [BACSER]SER = SERIAL
    Write [BACSER]
    Commit
    FOUND = 1
  Endif
  Filter [BACSER]
Wend

End SERIAL

Funprog GEN_BACS_SERIAL()
Local Integer RDM, COUNT : COUNT = 0
Local Char DATASET(36), RTN(6)

DATASET = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0987654321"
While COUNT < 6
  RDM = rnd(36)
  If RDM > 0
    RTN+=seg$(DATASET,RDM,RDM)
    COUNT+=1
  Endif
Wend
End RTN

Funprog BACS_GETSERIAL(INCPY)
Value Char INCPY
Local Char RTN(6)

# do a read last on the table and filter by company
If clalev([BACSER])=0 : Local File UKBACSER [BACSER]  : Endif

Filter [BACSER] Where CPY = INCPY Order By CREDATTIM Desc
Read [BACSER] First
If !fstat
  RTN = [BACSER]SER
Endif
Filter [BACSER]
End RTN

Funprog BACS_RANDOM_NUM()
Local Integer RDM, COUNT : COUNT = 0
Local Char DATASET(10), RTN(3)

DATASET = "0987654321"
While COUNT < 4
  RDM = rnd(10)
  If RDM > 0
    RTN+=seg$(DATASET,RDM,RDM)
    COUNT+=1
  Endif
Wend
End RTN

Funprog BACS_HEADER(PAYMETHOD, ACCOUNT, DUEDATE, BANKID)
Value Char PAYMETHOD, ACCOUNT, BANKID
Value Date DUEDATE

If clalev([PYH]) = 0  : Local File PAYMENTH [PYH] : Endif

Filter [PYH] Where PAM = PAYMETHOD  and ACC = ACCOUNT and DUDDAT = DUEDATE and BID = BANKID
Read [PYH] First
  If !fstat
    TEST = [PYH]BID
  Endif
Filter [PYH]
End TEST

Funprog BACS_EXPDATE(INCPY, SLIPNO, SLIDAT, SITE)
Value Char INCPY, SLIPNO, SITE
Value Date SLIDAT
Local Date EXPDAT
Local Char RTN
Local Integer BANPRO

If clalev([HRFRMPAY])=0 : Local File HRFRMPAY [HRFRMPAY]  : Endif

Filter [HRFRMPAY] Where CPY = INCPY and NUMFRM = SLIPNO and DAT = SLIDAT and FCYFRM = SITE
Read [HRFRMPAY] Last
If !fstat
  EXPDAT = [HRFRMPAY]EXPDAT
  If EXPDAT <> [0/0/0]
    RTN = func UK_FUNCTIONS.BACS_DATE(EXPDAT)
  Endif
Endif
Filter [HRFRMPAY]
End RTN

