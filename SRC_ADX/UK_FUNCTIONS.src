#**
#* Function to determine the pay frequency for a given pay period code. E.g. weekly, monthly etc..
#*
#* @param PERIOD_CODE
#* @return Pay frequency associated with the pay period code, or 0 if the pay period code is invalid
#*!
Funprog GET_PAY_FREQUENCY (PERIOD_CODE)
  Value Char PERIOD_CODE
  Local Integer RETVAL

  If clalev([HRPEOH1])    = 0  : Local File HRPEOHEA [HRPEOH1]    :  Endif

  Read [HRPEOH1]HRPEOH2 = PERIOD_CODE

  If !fstat
    [L]RETVAL = [HRPEOH1]PAYFRQ
  Endif
End [L]RETVAL

#ANCOA 13/04/2018 X3-79956 - Start
#**
#* Rounds up part pennies to the next whole penny, only caters for pater pennies upto 6 decimal places, any part penny beyond that is ignored
#* X3-91058: Change the accuracy of the rounding up to only consider up to 6 decimal places
#* @param VALEUR Value to round up to whole penny
#* @return Returns the value rounded up to nearest whole penny, e.g. 0.11 returns 0.11; 0.11001 returns 0.12; 92.050001 returns 92.05
#*!
Funprog ROUND_UP_PENNY (VALEUR)
  Value Decimal VALEUR
  Local Decimal RETVAL
  VALEUR = fix(VALEUR * 1000000) / 1000000
  If VALEUR >= 0.00
    If VALEUR > ar2(VALEUR)
      RETVAL = ar2(VALEUR) + 0.01
    Else
      RETVAL = ar2(VALEUR)
    Endif
  Else
    If VALEUR < ar2(VALEUR)
      RETVAL = ar2(VALEUR) - 0.01
    Else
      RETVAL = ar2(VALEUR)
    Endif
  Endif
End RETVAL
#ANCOA 13/04/2018 X3-79956 - End

#CHSUL - 2018-05-09 X3-76094 - START
#**
#* Function to return next pay date
#* @param FREQUENCY Local Char, Payment frequency
#* @param REFDATE Local Date, Reference date
#*!
Funprog GETNEXTPAYDATE(FREQUENCY, REFDATE)
Value Char FREQUENCY
Value Date REFDATE
Local File HRPEODET [HRPEOD]
Local Date RTN

RTN = REFDATE
Filter [HRPEOD] Where [HRPEOD]PERCOD = [L]FREQUENCY and [HRPEOD]PYRDAT >= [L]REFDATE
#Filter [HRPEOD] Where PERCOD = [L]FREQUENCY and PERSTR <= [L]REFDATE and PEREND >= [L]REFDATE
Read [HRPEOD] First
If !fstat Then
  RTN = [HRPEOD]PYRDAT
Endif
Filter [HRPEOD]
End RTN
#CHSUL - 2018-05-09 X3-76094 - END

#**
#* Determines the tax year start for a given pay day
#*
#* @param PAY_DATE Pay date
#* @return Tax year start date related to the PAY_DATE
#*!
Funprog GET_TAX_YEAR_START(PAY_DATE)
  Value Date PAY_DATE
  Local Date RETVAL
  RETVAL = PAY_DATE

  RETVAL = gdat$(06,04,year(PAY_DATE))

  If month(PAY_DATE) >= 1 and month(PAY_DATE) <= 4 and !(month(PAY_DATE) = 4 and day(PAY_DATE)>5)
    RETVAL = gdat$(06,04,year(PAY_DATE) - 1)
  Endif
End [L]RETVAL

#**
#* Determines the number of weeks a director has been a director
#*
#* @param DIRECTOR_START Date the director started being a director
#* @param TAX_YEAR_START Start of current tax year
#* @return A number of weeks between 1 and 52
#*!
Funprog GET_DIR_NUM_WEEKS(DIRECTOR_START, TAX_YEAR_START)
  Value Date DIRECTOR_START, TAX_YEAR_START
  Local Integer RETVAL

  # 52 minus the week number the director became a director,
    # if director started last year then assume they started at the beginning of the tax year
  [L]RETVAL = 52 - fix((max(TAX_YEAR_START,DIRECTOR_START) - TAX_YEAR_START) / 7)

  # must be between 1 and 52
  [L]RETVAL = max(min([L]RETVAL,52),1)

End [L]RETVAL

