 For [F:VEP1] Where PERYEA=VPERYEA and PERNUM=VPERNUM and FCY = [F:FCY]FCY
    For [F:HSP] Where BUL = [F:VEP1]BUL & TYP = 6 & RUB = VHEADING
      NIVAL += [F:HSP]AMT
    Next
  Next
Next
Filter [FCY]
End NIVAL
#DEHEN - 2017-04-24 - END


#MASHI - 2017-12-22 - X3-69492 START
#**
#* Function to lookup payslips according to values using pay date
#* @param VCPY Local Char, Company
#* @param VSTRDAT Local date, Start date
#* @param VENDDAT Local date, end date
#* @param VHEADING Local Char, Heading
#* @return NIVAL Local Decimal
#*!
Funprog GET_PAYSLIP_VALUES_DATES(VCPY,VSTRDAT, VENDDAT, VHEADING)
Value Char VCPY, VHEADING
Value Date VSTRDAT, VENDDAT

Local Decimal HEADING_VALUE

Local File HISTOPAYE [HSP]
Local File VALEMP    [VEP1]
Local File VALEMP    [VEP2]
Local File FACILITY  [FCY]

HEADING_VALUE = 0
Filter [F:FCY] Where LEGCPY = VCPY
For [F:FCY]
  For [F:VEP1] Where PYRDAT>=[L]VSTRDAT and PYRDAT<=[L]VENDDAT and FCY=[F:FCY]FCY
    Filter [F:VEP2] Where EMP = [F:VEP1]EMP and PERYEA = [F:VEP1]PERYEA and PERNUM = [F:VEP1]PERNUM and CTRNUM = [F:VEP1]CTRNUM Order By PERYEA;PERNUM;EMP;CTRDAT
    Read [F:VEP2] Last
    If [F:VEP1]BUL = [F:VEP2]BUL Then
      For [F:HSP] Where BUL = [F:VEP1]BUL & TYP = 6 & RUB = VHEADING
        HEADING_VALUE += [F:HSP]AMT
      Next
    Endif
    Filter [F:VEP2]
  Next
Next
Filter [FCY]

End HEADING_VALUE
#MASHI - 2017-12-22 - X3-69492 END

#ALHAR - 2018-19-02 - X3-77235 START
#**
#* Function to lookup payslips according to values using pay date
#* @param VCPY Local Char, Company
#* @param VMONTH Local Integer Month
##* @param VYEAR Local Integer Year
#* @param VHEADING Local Char, Heading
#*!
Funprog GET_PAYSLIP_VALUES_MONYEA(VCPY,VMONTH,VYEAR,VHEADING)
Value Char VCPY,VHEADING
Value Integer VMONTH, VYEAR
Local Decimal NIVAL
Local File HISTOPAYE [HSP]
Local File VALEMP    [VEP1]
Local File FACILITY  [FCY]
Filter [F:FCY] Where LEGCPY = VCPY
For [F:FCY]
 For [F:VEP1] Where VMONTH=month(PYRMON) and VYEAR=year(PYRMON) and FCY = [F:FCY]FCY
    For [F:HSP] Where BUL = [F:VEP1]BUL & TYP = 2 & RUB = VHEADING
      NIVAL += [F:HSP]AMT
    Next
  Next
Next
Filter [FCY]
End NIVAL
#ALHAR - 2018-19-02 - X3-77235 END

Funprog TRUNC2DEC(VALEUR)
Value Decimal VALEUR
Local Integer ROUNDLEN, FOUND_DEC,DECVAL, X
Local Char BUILDROUND(30)
Local Decimal RETVAL
Local Decimal ROUNDEDVALEUR
#Truncate to 2nd decimal
ROUNDLEN = len(num$(VALEUR))

For X = 1 To ROUNDLEN
  #Build the new value
  If mid$(num$(VALEUR),X,1) = "."
    FOUND_DEC = 1
  Elsif FOUND_DEC > 0
    #Already found add
    FOUND_DEC+=1
  Endif
  If FOUND_DEC > 1 and FOUND_DEC = 3 Then
    BUILDROUND += mid$(num$(VALEUR),X,1)
    Break
  Endif
  BUILDROUND += mid$(num$(VALEUR),X,1)

Next X

RETVAL = val(BUILDROUND)

End RETVAL

Funprog TRUNC4DEC(VALEUR)
Value Decimal VALEUR
Local Integer ROUNDLEN, FOUND_DEC,DECVAL, X
Local Char BUILDROUND(30)
Local Decimal RETVAL
Local Decimal ROUNDEDVALEUR
#Truncate to 2nd decimal
ROUNDLEN = len(num$(VALEUR))

For X = 1 To ROUNDLEN
  #Build the new value
  If mid$(num$(VALEUR),X,1) = "."
    FOUND_DEC = 1
  Elsif FOUND_DEC > 0
    #Already found add
    FOUND_DEC+=1
  Endif
  If FOUND_DEC > 1 and FOUND_DEC = 5 Then
    BUILDROUND += mid$(num$(VALEUR),X,1)
    Break
  Endif
  BUILDROUND += mid$(num$(VALEUR),X,1)

Next X

RETVAL = val(BUILDROUND)

End RETVAL

Funprog ROUNDUP(VALEUR)
Value Decimal VALEUR
Local Integer FIXVAL
Local Decimal RETVAL

FIXVAL = fix(VALEUR)
#MASHI - 2018-01-16 - X3-71627 START
#If VALEUR > FIXVAL
If VALEUR > FIXVAL and num$(VALEUR)<>num$(FIXVAL)
#MASHI - 2018-01-16 - X3-71627 END
  RETVAL = FIXVAL+1
Else
  RETVAL = FIXVAL
Endif

End RETVAL


Funprog AMOUNT_TO_PENCE(AMOUNT)
Value Decimal AMOUNT
Local Char RTN(11), PREFIX(11)
RTN = num$(AMOUNT*100)
For I = 1 To 11-len(RTN)
  PREFIX += '0'
Next I
RTN = PREFIX + RTN
End RTN

Funprog AMOUNT_TO_PENCE_EXT(AMOUNT)
Value Decimal AMOUNT
Local Char RTN(13), PREFIX(13)
RTN = num$(AMOUNT*100)
For I = 1 To 13-len(RTN)
  PREFIX += '0'
Next I
RTN = PREFIX + RTN
End RTN

Funprog BACS_NETPAY_PENCE(EMPID)
Value Char EMPID
Local Decimal AMOUNT
Local Char RTN(11), PREFIX(11)

If clalev([HSP])=0 : Local File HISTOPAYE [HSP]  : Endif

Filter [HSP] Where EMP = EMPID and RUB = 'NETT_PAY' and TYP = 6
Read [HSP] First
If !fstat
  AMOUNT = [HSP]AMT
Endif
Filter [HSP]

RTN = func AMOUNT_TO_PENCE(AMOUNT)
End RTN

Funprog TOTALPAY(SLIPNO)
Value Char SLIPNO
Local Decimal AMOUNT
Local Char RTN(13)

If clalev([HRST1])=0 : Local File STLPAY [HRST1]  : Endif

For [HRST1]STL0 Where NUMFRM = SLIPNO
  AMOUNT += [HRST1]AMT
Next

RTN = func AMOUNT_TO_PENCE_EXT(AMOUNT)
End RTN

Funprog TOTALPAY_COUNT(SLIPNO)
Value Char SLIPNO
Local Integer SUBRTN
Local Char RTN(7), PREFIX(7)

If clalev([HRST1])=0 : Local File STLPAY [HRST1]  : Endif

Filter [HRST1] Where NUMFRM = SLIPNO
Read [HRST1] First
If !fstat
SUBRTN = rowcount([HRST1])
Endif
Filter [HRST1]

For I = 1 To 7-len(num$(SUBRTN))
  PREFIX += '0'
Next I
RTN = PREFIX + num$(SUBRTN)
End RTN

