#<AdxTL>@(#)0.0.0.0 $Revision$ 
#**
#*
#* Determines the quotient and remainder for a given tax code amount.
#* Quotient is the number of multiple of 500.
#* <br></br>
#* Note: if the amount is exactly divisible by 500 then then quotient is reduced by 1, and 500 added to the remainder
#*
#* @param VALEUR Tax code amount to check the quotient/remainder for
#* @param FACTOR Always 500, legacy that this parameter even exists
#* @param RETNEED Pass in 1 if the quotient is required, and 2 if the remainder is required.
#* @return The quotient or remainder as requested.
#*!
Funprog TAX_MOD_FULL(TAX_CODE_AMOUNT,FACTOR_500,QUOTIENT_OR_REMAINDER)
Value Integer TAX_CODE_AMOUNT,FACTOR_500,QUOTIENT_OR_REMAINDER
Local Integer RETVAL,QUOTIENT,REMAINDER

FACTOR_500 = 500

REMAINDER = mod(TAX_CODE_AMOUNT,FACTOR_500)
QUOTIENT = (TAX_CODE_AMOUNT/FACTOR_500)

If REMAINDER = 0 and TAX_CODE_AMOUNT <> 0
  QUOTIENT = QUOTIENT - 1
  REMAINDER = REMAINDER + 500
Endif

If QUOTIENT_OR_REMAINDER = 2
  RETVAL = REMAINDER
Else
  RETVAL = QUOTIENT
Endif

End RETVAL

Funprog INSURANCE_ROUNDING(VALEUR)
Value Decimal VALEUR
Local Integer DECVAL, X, ROUNDLEN
Local Char BUILDROUND(30)
Local Decimal RETVAL
ROUNDLEN = len(num$(VALEUR))
For X = 0 To ROUNDLEN
  If mid$(num$(VALEUR),X,1) = "."
    BUILDROUND += num$(mid$(num$(VALEUR),X,1))
    BUILDROUND += num$(mid$(num$(VALEUR),X+1,1))
    DECVAL = val(mid$(num$(VALEUR),X+3,1))
    If DECVAL > 5
      DECVAL = val(mid$(num$(VALEUR),X+2,1))
      BUILDROUND += num$(DECVAL)
      RETVAL = val(BUILDROUND)
      RETVAL = RETVAL + 0.01
      End RETVAL
    Endif
    BUILDROUND += num$(mid$(num$(VALEUR),X+2,1))
    RETVAL = val(BUILDROUND)
    End RETVAL
  Else
    BUILDROUND += num$(mid$(num$(VALEUR),X,1))
    RETVAL = val(BUILDROUND)
  Endif
Next X
End RETVAL


Funprog ROUND_UP_2DEC(VALEUR)
Value Decimal VALEUR
Local Integer ROUNDLEN, FOUND_DEC,DECVAL, X
Local Char BUILDROUND(30)
Local Decimal RETVAL
Local Decimal ROUNDEDVALEUR
#Round to the 3rd decimal
ROUNDEDVALEUR = arr(VALEUR,0.001)
ROUNDLEN = len(num$(ROUNDEDVALEUR))

For X = 1 To ROUNDLEN
  #Build the new value
  If mid$(num$(ROUNDEDVALEUR),X,1) = "."
    FOUND_DEC = 1
  Elsif FOUND_DEC > 0
    #Already found add
    FOUND_DEC+=1
  Endif
  If FOUND_DEC > 1 and FOUND_DEC = 3 Then
    If X = ROUNDLEN-1
      #Round value +1
      DECVAL = val(mid$(num$(ROUNDEDVALEUR),X,1))
      DECVAL+=1
      BUILDROUND += num$(DECVAL)
      RETVAL = val(BUILDROUND)
      End RETVAL
    Endif
  Endif
  BUILDROUND += mid$(num$(ROUNDEDVALEUR),X,1)

Next X

RETVAL = val(BUILDROUND)
End RETVAL

#**
#* Determine the number of weeks that a director has been a director for the tax year
#*
#* @param EMPLOYEE_ID Employee refnum
#* @param CONTRACT_NO Contract number
#* @param CONTRACT_DATE Contract date
#* @param PAY_DATE Current pay date - used to determine tax year start
#* @return Number of weeks between 1-52
#*!
Funprog DIRECTORCALC(EMPLOYEE_ID, CONTRACT_NO, CONTRACT_DATE, PAY_DATE)
  Local Integer RETVAL
  Local Date TAX_YEAR_START
  If clalev([CTRUKDIR])= 0  : Local File EMPLOCTRUKI[CTRUKDIR] : Endif

  Filter [CTRUKDIR] Where REFNUM = EMPLOYEE_ID  and CTRNUM = CONTRACT_NO and CTRDAT = CONTRACT_DATE
  Read [CTRUKDIR] First
  Filter [CTRUKDIR]

  If !fstat and ([CTRUKDIR]DIRSTA = 2 or [CTRUKDIR]DIRSTA = 3)
    TAX_YEAR_START = func GET_TAX_YEAR_START(PAY_DATE)
    [L]RETVAL = func GET_DIR_NUM_WEEKS([CTRUKDIR]DIRSTASTR, TAX_YEAR_START)
  Endif
End [L]RETVAL

Funprog DIRECTORCALC_OLD(EMPLOYEE_ID, CONTRACT_NO, CONTRACT_DATE)
Value Char EMPLOYEE_ID, CONTRACT_NO
Value Date CONTRACT_DATE
Local Integer RETURNVAL, ROUNDLEN, X
Local Date CYCLESTART, CYCLEEND, EMPSTARTDATE, XITDAT, EMPENDDATE, DIRECTORSTARTDATE, CURRENTDATE
Local Decimal SUBRTN

CURRENTDATE = gdat$(datetime$)

If clalev([HRCTR8]) = 0  : Local File EMPLOCTR   [HRCTR8]  : Endif
If clalev([CTRUKI8])= 0  : Local File EMPLOCTRUKI[CTRUKI8] : Endif
If clalev([HRPEOH])= 0  : Local File HRPEOHEA   [HRPEOH] : Endif

Filter [CTRUKI8] Where REFNUM = EMPLOYEE_ID  and CTRNUM = CONTRACT_NO and CTRDAT = CONTRACT_DATE
Read [CTRUKI8] First
Filter [CTRUKI8]
If !fstat
  If [CTRUKI8]DIRSTA = 2 or [CTRUKI8]DIRSTA = 3
    DIRECTORSTARTDATE = [CTRUKI8]DIRSTASTR
    Filter [HRCTR8] Where REFNUM = EMPLOYEE_ID  and CTRNUM = CONTRACT_NO and CTRDAT = CONTRACT_DATE
    Read [HRCTR8] First
    If !fstat
      Filter [HRPEOH] Where PERCOD = [HRCTR8]PERCOD and FLGENA = 2
      XITDAT = [HRCTR8]XITDAT
      Read [HRPEOH] First
      If !fstat
        CYCLESTART = [HRPEOH]CYCSTRDAT
        CYCLEEND = [HRPEOH]CYCENDDAT

#        If CYCLESTART > CURRENTDATE
#          CYCLESTART = gdat$(day(CYCLESTART),month(CYCLESTART), year(CYCLESTART)-1)
#          CYCLEEND = gdat$(day(CYCLEEND),month(CYCLEEND), year(CYCLEEND)-1)
#        Endif

        If DIRECTORSTARTDATE < CYCLESTART
          EMPSTARTDATE = CYCLESTART
        Else
          EMPSTARTDATE = DIRECTORSTARTDATE
        Endif

        EMPENDDATE = CYCLEEND
#        If XITDAT <> [0/0/0]
#          If XITDAT >= CYCLESTART and XITDAT <= CYCLEEND
#            EMPENDDATE = XITDAT
#          Else
#            EMPENDDATE = CYCLEEND
#          Endif
#        Else
#          EMPENDDATE = CYCLEEND
#        Endif

        SUBRTN = (EMPENDDATE-EMPSTARTDATE)/7
        RETURNVAL = int(SUBRTN)
        ROUNDLEN = len(num$(SUBRTN))
        For X = 0 To ROUNDLEN
          If mid$(num$(SUBRTN),X,1) = "."
            RETURNVAL=RETURNVAL+1
            Break
          Endif
        Next X
      Endif
  Endif
  Endif
Endif
If RETURNVAL = 0 : RETURNVAL = 1 : Endif
End RETURNVAL


