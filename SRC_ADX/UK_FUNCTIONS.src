Filter [HRPEOD] Where PERCOD = VTHISPERCOD and PERSTR = VPAYDATSTR and PEREND = VPAYDATEND
If !fstat Then
  If [HRPEOD]PERMON = [HRPEOD]PERMON2 : RTN = 1 : Endif
Endif
Filter [HRPEOD]
End RTN

#DEHEN - 2017-04-24 - START
#**
#* Function to lookup payslips according to values
#* @param VCPY Local Char, Company
#* @param VPERYEA Local Integer, Period Year
#* @param VPERNUM Local Integer, Period Number
#* @param VHEADING Local Char, Headning
#* @param PERCODE Local Char, Period Code
#* @return NIVAL Local Decimal
#*!
Funprog GET_PAYSLIP_VALUES_WPC(VCPY,VPERYEA, VPERNUM, VHEADING,PERCODE)
Value Char VCPY,VHEADING, PERCODE
Value Integer VPERYEA, VPERNUM

Local Decimal NIVAL
Local File HISTOPAYE [HSP]
Local File VALEMP    [VEP1]
Local File FACILITY  [FCY]

Filter [F:FCY] Where LEGCPY = VCPY
For [F:FCY]
 #For [F:VEP1] Where STRDAT>=PERSTR and ENDDAT <=PEREND and FCY = [F:FCY]FCY
 For [F:VEP1] Where PERYEA=VPERYEA and PERNUM=VPERNUM and FCY = [F:FCY]FCY and PERCOD = PERCODE
    For [F:HSP] Where BUL = [F:VEP1]BUL & TYP = 6 & RUB = VHEADING
      NIVAL += [F:HSP]AMT
    Next
  Next
Next
Filter [FCY]
End NIVAL

#**
