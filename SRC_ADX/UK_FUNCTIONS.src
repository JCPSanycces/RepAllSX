#HEGES and FRLAA - 2017/04/10
Funprog DIRXIT(VPAYDATSTR,VPAYDATEND,VTHISPERCOD,VTHISPERYEA,VTHISPERNUM,VREFNUM,VCTRNUM,VCTRDAT)
Value Date VPAYDATSTR,VPAYDATEND,VCTRDAT
Value Char VTHISPERCOD,VREFNUM,VCTRNUM
Value Integer VTHISPERYEA,VTHISPERNUM
Local Integer RETVAL,DIRSTATUS, CTRXITFNL
Local Date CTRXITDAT
Local File EMPLOCTRUKI  [CTRUKI2]
Local File EMPLOCTR     [CTR2]


Read [CTR2]CTR0 = VREFNUM;VCTRNUM;VCTRDAT
If !fstat Then

  CTRXITDAT = [F:CTR2]XITDAT
  CTRXITFNL = [F:CTR2]XITFNL
  Read [CTRUKI2]CTRUKI0 = VREFNUM;VCTRNUM;VCTRDAT
  If !fstat Then
    DIRSTATUS = [F:CTRUKI2]DIRSTA
    #Check the conditions on termination date
    If CTRXITFNL = 2 and CTRXITDAT >= VPAYDATSTR and CTRXITDAT <= VPAYDATEND Then
      If DIRSTATUS = 3
        RETVAL = 1
      Endif
    Endif
    #Check conditions on the pay period in the tax year
    If func DIVPAYE.TAXMON(VTHISPERCOD,VTHISPERYEA,VTHISPERNUM) = 12 and DIRSTATUS = 3
    #the checkifpermon should only work for weekly emp's
      If func CHECKIFLASTPERIOD(VPAYDATSTR,VPAYDATEND,VTHISPERCOD) = 0
        If VTHISPERNUM = 52 : RETVAL = 1 : Endif
      Else
        If VTHISPERNUM = 53
          RETVAL = 0
        Else
          If VTHISPERNUM = 52
            RETVAL = 1
          Endif
          If VTHISPERNUM = 12 : RETVAL = 1 : Endif
        Endif
      Endif
    Endif
  Endif
Endif
End RETVAL

#HEGES - X3-46930 - 2017/07/03
Funprog CHECKIFLASTPERIOD(VPAYDATSTR,VPAYDATEND,VTHISPERCOD)
