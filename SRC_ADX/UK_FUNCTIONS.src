End RTN

Funprog BACS_FASTPRO(INCPY, SLIPNO, SLIDAT, SITE)
Value Char INCPY, SLIPNO, SITE
Value Date SLIDAT
Local Char RTN(9)

If clalev([HRFRMPAY])=0 : Local File HRFRMPAY [HRFRMPAY]  : Endif

Filter [HRFRMPAY] Where CPY = INCPY and NUMFRM = SLIPNO and DAT = SLIDAT and FCYFRM = SITE
Read [HRFRMPAY] Last
If !fstat
  BANPRO = [HRFRMPAY]BANPRO
  If BANPRO = 1
    RTN = '1 DAILY  '
  Endif
  If BANPRO = 2
    RTN = '4 MULTI  '
  Endif
  If [HRFRMPAY]FASPRO = 2
    RTN = '2 FPS    '
  Endif
Endif
Filter [HRFRMPAY]
End RTN

Funprog BACS_DATE(INDATE)
Value Date INDATE
Local Char RTN(6)
Local Char NEWDAYNUM(3) : NEWDAYNUM = num$(func UK_FUNCTIONS.DAYOFYEAR(INDATE))

If len(NEWDAYNUM) = 1
  NEWDAYNUM = "00" + NEWDAYNUM
Else
  If len(NEWDAYNUM) = 2
    NEWDAYNUM = "0" + NEWDAYNUM
  Endif
Endif

RTN = " " + num$(seg$(num$(year(INDATE)),3,4)) + NEWDAYNUM

End RTN

Funprog DAYOFYEAR(INDATE)
Value Date INDATE
Local Integer RTN, DAYSINEND, DAYSINSTR
Local Date ENDDATE : ENDDATE = gdat$(31,12,year(INDATE))

DAYSINEND = nday(ENDDATE)
DAYSINSTR = nday(INDATE)
RTN = 365 - (DAYSINEND - DAYSINSTR)

End RTN

Funprog SAGEBB(VALEUR)
Value Char VALEUR
Local Char RTN(6)
If VALEUR = ''
  RTN = 'SAGEbb'
Else
  RTN  = '      '
Endif
End RTN

Funprog OWNERID(VALEUR)
Value Char VALEUR
Local Char RTN(6)
If VALEUR <> ''
  RTN = VALEUR
Else
  RTN  = '      '
Endif
End RTN

#* Function to remove dashed from bank sort code
#* @param SRTCOD, Local Char, Sort Code
#* @return stripped sort code, e.g. 12-34-56 returns 123456
#*!
Funprog BACS_STRCODSTRIP(SRTCOD)
Value Char SRTCOD
Local Char RTN

For X = 0 To len(num$(SRTCOD))
  If mid$(num$(SRTCOD),X,1) <> "-"
    RTN+= mid$(num$(SRTCOD),X,1)
  Endif
 Next X
End RTN

#JOJAC - 2017-08-07 - X3-33811 - START
Funprog WRKDAYS(STRDAT,ENDDAT,REFNUM,CTRNUM,CODE)
Value    Date    STRDAT
Value    Date    ENDDAT
Value    Char    REFNUM ()
Value    Char    CODE ()
Value    Char    CTRNUM()
Local Decimal RETVAL
Local Decimal NBDAYS
Local Decimal NBHOURS
Local Char SITE
Local Decimal RETVAL

If clalev([HRCTR])<> 0 : Local File EMPLOCTR [HRCTR] : Endif
Filter [HRCTR] Where REFNUM = [L]REFNUM and CTRNUM = [L]CTRNUM
Read [HRCTR] Last
Filter [HRCTR]

#Get site and refnum from HRCTR
SITE      = [HRCTR]ETRFCY
REFNUM    = [HRCTR]REFNUM

#Determine working days
Call VALORIS(STRDAT,ENDDAT,REFNUM,CODE,NBDAYS,NBHOURS,SITE,CTRNUM) From SUBPLN
RETVAL=NBDAYS

End RETVAL
#JOJAC - 2017-08-07 - X3-33811 -END

#**
#* For SSP rounds up part pennies to the next whole penny, calls the function ROUND_UP_PENNY()
#*
#* @param VALEUR The value that should be rounded
#* @return Returns the value rounded up to nearest whole penny, e.g. 0.11 returns 0.11; 0.11001 returns 0.12
#*!
Funprog RNDSSP(VALEUR)
  Value Decimal VALEUR
  Local Decimal RETVAL
  #ANCOA 23/04/2018 X3-88028 - Remove the old logic and just re-use the function that deals with rounding up part pennies
  [L]RETVAL = func ROUND_UP_PENNY(VALEUR)
End RETVAL

