# Gestion du masque MBENCHD1

##########################################################################
## Etiquette ajoutée par le superviseur 24/06/2003 09:20:46 (LLC)
##########################################################################
########################################
Subprog AS_EXTQTY2(VALEUR)
Variable Decimal VALEUR
GBOUT1 = mess(151,198,1)  
GBOUT2 = mess(150,198,1)  
GBOUT3 = mess(282,198,1)
GBOUT4 = mess(423,198,1)
End

########################################
Subprog AM_EXTQTY2(VALEUR)
Variable Decimal VALEUR
Local    Integer OK
Local    Date    WORIDAT   
Local    Char    WORIFCY 
Local    Integer WLTI 
Local    Char    WART   
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD  
Local    Decimal WQTY
Local    Integer WALT         
Local    Integer I : WMODWOX      # 20846 mm 11.05 


# 20846 mm 11.05
WMODWOX = 0
For I=0 To 20
    If maskabr(I)="MBW1"
        WMODWOX = 1 : Break 
    Endif
Next I
If  WMODWOX <>1 : End : Endif

# llc 05.03 18397
If find([F:ORD1]WIPSTA,1,2)
    WQTY = [F:MFG]EXTQTY - [M:MBW1]EXTQTY1 + VALEUR
Else
    WQTY = VALEUR
Endif


If [M:MBW1]ROUNUM <> "" & [M:MBW1]ROUALT <> 0 & [M:MBD1]STRDAT2 <> [0/0/0]
    Raz GMESSAGE
    If clalev([F:TRO]) = 0 : Local File TABROUALT [TRO] : Endif
    If clalev([F:ROH]) = 0 : Local File ROUTING   [ROH] : Endif
    #    Lecture ROUTING   
    Read [TRO]TRO0=[M:MBW1]ROUALT
    If fstat 
        GMESSAGE = mess(152,193,1)
    Else   
        Read [ROH]ROH1=[M:MBW1]STOFCY;[M:MBW1]ROUNUM;[M:MBW1]ROUALT
        If fstat 
            GMESSAGE = mess(152,193,1)   
        Else
            Call CONTMFGGAM([M:MBW1]STOFCY,WALT,[M:MBD1]STRDAT2,WQTY, [M:MBW1]STU2, 1) From MFGLIB   
        Endif
    Endif
    If GMESSAGE <> "" | WALT = 0 : mkstat = 2 : Endif
Endif

If [M:MBW1]WIPTYP=5 & [M:MBW1]FMI=5
    OK=1
    Call OUINON(mess(88,190,1),OK) From GESECRAN
    If OK <> 2 : mkstat=2 : End : Endif  
Endif

If find([F:ORD1]WIPSTA,1,2)
    If [F:MFG]MFGTRKFLG > 3
        OK=1
        Call OUINON(mess(52,190,1),OK) From GESECRAN
        If OK <> 2 : VALEUR = [M:MBW1]EXTQTY2 : mkstat = 2 : End : Endif    
    Endif

    If VALEUR < [F:MFI]CPLQTY
        GMESSAGE = mess(68,193,1)
        mkstat = 2 
        End 
    Endif
Endif


WORIFCY=[M:MBW1]STOFCY 
 
WLTI=0   

# lecture ITF 
If [F:ITF]ITMREF<>[M:MBW1]ITMREF
    Read [ITF]ITF0=[M:MBW1]ITMREF;[M:MBW1]STOFCY
    If fstat : End : Endif  
Endif   

Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI) 
WRMD    = XLTI - ILTI 
If WRMD <> 0 : ILTI += 1 : Endif   
WLTI=ILTI 

# calcul date  
WORIDAT=[M:MBD1]ENDDAT2  
WMEMDAT=[M:MBD1]STRDAT2

Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MBD1]STRDAT2) From MFGLIB   

Affzo [M:MBD1]STRDAT2   
Call CHECK_PAST([M:MBD1]STRDAT2, 2) From MFGLIB  

End

########################################
Subprog B1_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:MBD1]ITMREF    # 20846 mm 11.05
    Read [ITF]ITF0=[M:MBD1]ITMREF;[M:MBD1]STOFCY    # 20846 mm 11.05
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]MFGLOTQTY
End

########################################
Subprog B2_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:MBD1]ITMREF    # 20846 mm 11.05
    Read [ITF]ITF0=[M:MBD1]ITMREF;[M:MBD1]STOFCY     # 20846 mm 11.05
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]REOMINQTY
End

########################################
Subprog AS_STRDAT2(VALEUR)
Variable Date    VALEUR
# jalonnement amont, si nouvel ordre on saisit la date de fin 
# llc 03.02 12520
If [F:MTS]SCDMODSAI = 1 & [M:MBD1]ENDDAT2=[0/0/0] : mkstat=2 : End : Endif  
If find([F:ORD1]WIPSTA,1,2) & [F:MFG]MFGTRKFLG > 3 : mkstat = 2 : Endif
End

########################################
Subprog AM_STRDAT2(VALEUR)
Variable Date    VALEUR
Local    Integer WRET
Local    Date    WORIDAT   
Local    Char    WORIFCY 
Local    Integer WLTI 
Local    Char    WART   
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD  
Local    Decimal WQTY
Local    Integer OK

If [F:MTS]SCDMODSAI = 1 & VALEUR > [M:MBD1]ENDDAT2 : mkstat=2 : End : Endif
 
# révision calendriers (llc 06.00)
Call CONTROL_DATE_PLN(VALEUR, [M:MBW1]STOFCY) From MFGLIB    

If mkstat = 2 : End : Endif

# OF jalonné ?
Call TEST_JAL(WRET) From MFGAUTLIB
If WRET = 1 : mkstat = 2 : End : Endif 

If [M:MBW1]WIPTYP=5 & [M:MBW1]FMI=5
    OK=1
    Call OUINON(mess(88,190,1),OK) From GESECRAN
    If OK <> 2 : mkstat=2 : End : Endif  
Endif

# antériorité par rapport à la date du jour ?
Call CHECK_PAST(VALEUR, 2)  From MFGLIB 

# llc 03.02 12520
If [F:MTS]SCDMODSAI = 1 : End : Endif

WORIDAT=VALEUR  
WORIFCY=[M:MBW1]STOFCY  
WLTI=0 

# lecture article site
Read [ITF]ITF0=[M:MBW1]ITMREF;[M:MBW1]STOFCY 
If fstat : End : Endif 
If find([F:ORD1]WIPSTA,1,2)
    WQTY = [F:MFG]EXTQTY - [M:MBD1]EXTQTY1 + [M:MBD1]EXTQTY2
Else
    WQTY = [M:MBD1]EXTQTY2
Endif
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI) 
WRMD    = XLTI - ILTI 
If WRMD <> 0 : ILTI += 1 : Endif   
WLTI=ILTI 

# calcul date  
WMEMDAT = [M:MBD1]ENDDAT2 

# révision calendriers (llc 06.00)   
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:MBD1]ENDDAT2) From MFGLIB   

Affzo [M:MBD1]ENDDAT2 
#
End

########################################
Subprog AS_ENDDAT2(VALEUR)
Variable Date    VALEUR
Local    Integer I, WMODWOX

# 20846 mm 11.05
WMODWOX = 0
For I=0 To 20
    If maskabr(I)="MBW1"
        WMODWOX = 1 : Break 
    Endif
Next I
If  WMODWOX <>1 : End : Endif

# Si jalonnement aval et date début non renseignée, pas de saisie 
If ([F:MTS]SCDMODSAI=2 & [M:MBD1]STRDAT2=[0/0/0]) : mkstat=2 : End : Endif 
End


########################################
Subprog AM_ENDDAT2(VALEUR)
Variable Date    VALEUR
Local    Date    WORIDAT   
Local    Char    WORIFCY 
Local    Integer WLTI 
Local    Char    WART   
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD  
Local    Decimal WQTY
Local    Integer OK
Local    Integer I, WMODWOX


# 20846 mm 11.05
WMODWOX = 0
For I=0 To 20
    If maskabr(I)="MBW1"
        WMODWOX = 1 : Break 
    Endif
Next I
If  WMODWOX <>1 : End : Endif

If VALEUR=[0/0/0] : mkstat=2 : End : Endif   

If [F:MTS]SCDMODSAI = 2 & VALEUR < [M:MBD1]STRDAT2 : mkstat = 2 : End : Endif

# révision calendriers (llc 06.00)
Call CONTROL_DATE_PLN(VALEUR, [M:MBW1]STOFCY) From MFGLIB    
If mkstat = 2 : End : Endif 

# OF jalonné ?
Call TEST_JAL(WRET) From MFGAUTLIB
If WRET = 1 : mkstat = 2 : End : Endif 

If [M:MBW1]WIPTYP=5 & [M:MBW1]FMI=5
    OK=1
    Call OUINON(mess(88,190,1),OK) From GESECRAN
    If OK <> 2 : mkstat=2 : End : Endif  
Endif

Call CHECK_PAST(VALEUR, 2) From MFGLIB 

# llc 03.02 12520
If [F:MTS]SCDMODSAI = 2 : End : Endif
If find([F:ORD1]WIPSTA,1,2) & [F:MFG]MFGTRKFLG > 3 : End : Endif

WORIDAT=VALEUR  
WORIFCY=[M:MBW1]STOFCY  
WLTI=0 

# lecture article site
Read [ITF]ITF0=[M:MBW1]ITMREF;[M:MBW1]STOFCY 
If fstat : End : Endif 
If find([F:ORD1]WIPSTA,1,2)
    WQTY = [F:MFG]EXTQTY - [M:MBD1]EXTQTY1 + [M:MBD1]EXTQTY2
Else
    WQTY = [M:MBD1]EXTQTY2
Endif
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI) 
WRMD    = XLTI - ILTI 
If WRMD <> 0 : ILTI += 1 : Endif   
WLTI=ILTI 

# calcul date  
WMEMDAT = [M:MBD1]STRDAT2
  
# révision calendriers (llc 06.00)   
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MBD1]STRDAT2) From MFGLIB 
   
Affzo [M:MBD1]STRDAT2 
Call CHECK_PAST([M:MBD1]STRDAT2, 2) From MFGLIB   
#
zonsui="STRDAT2" 
#
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran MBENCHD1) 05/12/2005 10:54:40 (MM)
######################################################################################
Subprog AV_STRDAT2(VALEUR)
Variable Date    VALEUR
Local Integer I, WMODWOX
# 20846 mm 11.05
WMODWOX = 0
For I=0 To 20
    If maskabr(I)="MBW1"
        WMODWOX = 1 : Break 
    Endif
Next I
If  WMODWOX <>1 : Grizo [M:MBD1]STRDAT2 : Endif

End

######################################################################################
Subprog AP_ENDDAT2(VALEUR)
Variable Date    VALEUR
Local Integer I, WMODPOX
# 20846 mm 11.05
WMODPOX = 0
For I=0 To 20
    If maskabr(I)="PBW1" | maskabr(I)="PBW5"
        WMODPOX = 1 : Break 
    Endif
Next I

If WMODPOX = 1 
    If VALEUR <> [0/0/0]
        Call CHECK_PAST(VALEUR, 2) From MFGLIB 
        [M:MBD1]STRDAT2 = VALEUR :  Affzo [M:MBD1]STRDAT2  
    Else
        mkstat=2 
    Endif
Endif


End


