Subprog AV_STRDAT1(VALEUR)
Variable Date    VALEUR
# 20846 mm 11.05
# pour éviter ds le cas des POP que la date début soit chargée alors que la date de fin ne l'est pas
If [M:MBD1]ENDDAT1 = [0/0/0] : [M:MBD1]STRDAT1 =  [0/0/0] : Endif
End


