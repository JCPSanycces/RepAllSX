#<AdxTL>@(#)5.0.0.0 $Revision$
######################################################################################
Subprog FLGDEP(CPY,DEP,FLGDEP)
Value    Char    CPY()      : # Company
Value    Char    DEP()      : # Early Discount Code
Variable Integer FLGDEP     : # Flag

If clalev([F:TDA])=0 : Local File TABDEPAGIO [TDA] : Endif : # Early discount/late charge table
If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif
If clalev([F:PIH])=0 : Local File PINVOICE   [PIH] : Endif

Local Char    INVNUM(GLONVCR)

## The value of the PFINUM & SFINUM Fields has to be verified only for the invoices of the Sales & Purchasing module
[L]INVNUM = [F:DUD]NUM
Case [F:DUD]BPRTYP
 When 1
  Gosub READ_SIH
  If fstat | ([F:SIH]ORIMOD<>5 and func AFNC.PARAM("DEPMGTMOD",[F:DUD]CPY)<>"5")
   FLGDEP = 1 : End
  Endif
 When 2
  Gosub READ_PIH
  If fstat | ([F:PIH]ORIMOD<>6 and func AFNC.PARAM("DEPMGTMOD",[F:DUD]CPY)<>"5")
   FLGDEP = 1 : End
  Endif
Endcase

Call SETMAINREF([F:DUD]CPY,GTYPGEN,GTYPANA) From CPTDIV
# If this is a discount/charge (if [TDA]PFINUM or[TDA] SFINUM is equal to 0),
# calculate the amount of the discount on the net invoice amount.
Call LEC_TDA(GCURLEG,[F:DUD]DEP) From CPTLEC
If ([F:DUD]BPRTYP=1 & [F:TDA]SFINUM<>0) | ([F:DUD]BPRTYP=2 & [F:TDA]PFINUM<>0)
 FLGDEP = 1
Endif
End

$READ_SIH
fstat = 0
If [F:SIH]NUM<>[L]INVNUM
 Read [SIH]SIH0 = [L]INVNUM
Endif
Return

$READ_PIH
fstat = 0
If [F:PIH]NUM<>[L]INVNUM
 Read [PIH]PIH0 = [L]INVNUM
Endif
Return

######################################################################################
Subprog CALBASDEP(BASE)
Variable Decimal BASE

If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif : # Accounting Document Lines Table
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif  : # Accounts
If !clalev([F:TCU])  : Local File TABCUR     [TCU]  : Endif  : # Currencies

Local Decimal MTHT, MTTTC, ARD
Local Decimal AMTPAY

AMTPAY = BASE

Raz MTHT, MTTTC
Call LEC_TCU([F:DUD]CUR) From CPTLEC
ARD=[F:TCU]CURRND

For [DAE]DAE0 Where TYP=[F:DUD]TYP & NUM=[F:DUD]NUM & LEDTYP=GTYPGEN
 If [F:DAE]ACCNUM<>[F:DUD]ACCNUM
  Call LEC_GAC([F:DAE]ACC,[F:DAE]COA) From CPTLEC
  If find([F:GAC]FLGVAT,1,2)
   MTHT += [F:DAE]AMTCUR*[F:DAE]SNS
  Endif
 Elsif [F:DAE]ACCNUM=[F:DUD]ACCNUM
  MTTTC = [F:DAE]AMTCUR
 Endif
Next
If MTTTC
 BASE = arr(abs(MTHT)*(AMTPAY/MTTTC),ARD) : # Correction bug 78652
Endif
End


#SAM 97414 angre 14.07.14

#** #############################################################################################
#* Read GACCENTRY
#*
#*! #############################################################################################
$READ_HAE
fstat = 0
 Read [HAE]HAE0 = [F:DUD]TYP ;[L]INVNUM
Return

#** #############################################################################################
#* Provides the "payment term" and the "original document" for an invoice.
#*
#*! #############################################################################################
Subprog PTEORIDOC(PTE, ORINUM)
Variable Char PTE
Variable Char ORINUM
Local Char    INVNUM(GLONVCR)

If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif
If clalev([F:PIH])=0 : Local File PINVOICE   [PIH] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif

[L]INVNUM = [F:DUD]NUM
# Business partner type: 1 -> Customer; 2 -> Supplier
Gosub READ_HAE
If !fstat
  ORINUM = [F:HAE]BPRVCR
Endif
Case [F:DUD]BPRTYP
 When 1
  Gosub READ_SIH
  If !fstat
   PTE = [F:SIH]PTE
   #ORINUM = [F:SIH]BPRVCR
   End
  Endif
 When 2
  Gosub READ_PIH
  If !fstat
   PTE = [F:PIH]PTE
   #ORINUM = [F:PIH]BPRVCR
   End
  Endif
Endcase
End
#SAM 97414 angre end
