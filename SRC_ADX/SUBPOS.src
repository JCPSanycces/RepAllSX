#<AdxTL>@(#)11.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("POS",GBIDC1,GBIDC2) From GOBJET
End

#####################################################
# SUBPOS -  Gestion de l'objet Codes postaux
#####################################################
$ACTION
Case ACTION
 When "SETBOUT"    : Gosub SETBOUT
 When "VERF_ANU"   : Gosub VERF_ANU     # (TB 06/10/00)
 When "RAZCRE"     : Gosub RAZCRE       # FGR 14/03/2012 : X3SUIVI79830
 When "INICRE"     : Gosub INICRE       # FGR 02/03/2012 : X3SUIVI79830
 When "INIMOD"     : Gosub INIMOD       # FGR 02/03/2012 : X3SUIVI79830
 When "LIENS"      : Gosub LIENS        # FGR 02/03/2012 : X3SUIVI79830

 When "SEL_TABLE"  : Gosub SEL_TABLE
 When "VERF_TABLE" : Gosub VERF_TABLE
 When "CHX_TABLE"  : Gosub CHX_TABLE
 When "FIN_TABLE"  : Gosub FIN_TABLE

 When "TRT_DIV"    : Gosub TRTDIV
 When "AVANT_CHOI" : Gosub AVANT_CHOI
 When "APRES_CHOI" : Gosub APRES_CHOI
Endcase

Return

################################################################################
$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET
#--- Objet à 4 éléments de clé : ajout du btn suppression après que GOBJET l'ait viré !
If CLECUR & REP="" & VERROU : CHAINE += "A" : Endif
Return

################################################################################
$LIENS
  # FGR 02/03/2012 : X3SUIVI79830
  Case [M:POS1]CRY
    When "FR"
      If dim([M:POS1]BURDIS) >= 0 Then
        Call FMTCTYPAY([M:POS1]CRY) From TRTDIV
        Chgfmt [M:POS1]BURDIS With "K:" + GFMT
      Endif
      # -------------------------
      If dim([M:POS1]GEOCOD) >= 0 Then
        Chgfmt [M:POS1]GEOCOD With "-K:1X"
      Endif
    When "US"
      If dim([M:POS1]GEOCOD) >= 0 Then
        Chgfmt [M:POS1]GEOCOD With "K:" + num$(GLONGEO) + "X"
      Endif
      # -------------------------
      If dim([M:POS1]BURDIS) >= 0 Then
        Chgfmt [M:POS1]BURDIS With "-K:1X"
      Endif
    When Default
      If dim([M:POS1]GEOCOD) >= 0 Then
        Chgfmt [M:POS1]GEOCOD With "-K:1X"
      Endif
      If dim([M:POS1]BURDIS) >= 0 Then
        Chgfmt [M:POS1]BURDIS With "-K:1X"
      Endif
  Endcase
  # --------------------------
  Gosub AV_SATCOD From W1POS1
Return

################################################################################
$RAZCRE
  # FGR 14/03/2012 : X3SUIVI79830
  [M]CRY = GPAYS
  #
  If dim([M]GEOCOD) >= 0 Then
    Raz [M]GEOCOD
  Endif
  If dim([M]BURDIS) >= 0 Then
    Raz [M]BURDIS
  Endif
Return

################################################################################
$VERF_ANU
# (Annulation du code postal sans controle de liens)
Trbegin [POS]
 Delete [POS] Where CRY=[M:POS1]CRY & POSCOD=[M:POS1]POSCOD
&                 & POSCTY=[M:POS1]POSCTY & POSCTYCOD=[M:POS1]POSCTYCOD
 If fstat = 1  : # enreg locké
   GLOCK = "$POSCOD" : Goto ROLL_ANN
 Elsif fstat
   Goto AB_ANN
 Endif
Commit
Effzo
OK = 0 :# pour ne pas passer dans la suppression standard (TB 06/10/00)
Return

$ROLL_ANN
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto VERF_ANU : Endif

$AB_ANN
# >>  rajouter un message
Rollback
Return

#################################################################################
$INICRE
$INIMOD

  # FGR 02/03/2012 : X3SUIVI79830
  If dim([M:POS1]POSCTYSEA) >=0 Then
    [M:POS1]POSCTYSEA = toupper(ctrans([M:POS1]POSCTY))
    [F:POS]POSCTYSEA = [M:POS1]POSCTYSEA
  Endif
Return

#################################################################################
# Rajout code état
#################################################################################

$TRTDIV
Case TRAIT
 When "ATUNPOS"   : Gosub TUN_POS
 When "CPCONT"    : Gosub CP_CONT
 When "VILCONT"   : Gosub VIL_CONT
 When "INIVIL"    : Gosub INI_VIL
 When "VILCNTOBL" : Gosub VILCNTOBL
 When "POSCNTOBL" : Gosub POSCNTOBL
Endcase
Return

######################################################
$TUN_POS
Local Char    CP(GLONPOS) , PAYS(GLONCRY) , VILLE(GLONCTY) , ETAT(GLONSAT) , COMMUNE(10)
CP      = VALEUR
PAYS    = PARAM(1)
VILLE   = PARAM(2)
ETAT    = PARAM(3)
COMMUNE = PARAM(4)
If clalev([F:POS])=0 : Local File POSCOD [POS] : Endif
If COMMUNE=""
 Read [POS]POS0(3)=PAYS;CP;VILLE
 If !fstat
  COMMUNE = [F:POS]POSCTYCOD
 Endif
Endif
Call OBJET_CHAR(CP,"POS",PAYS+"~"+VILLE+"~"+COMMUNE) From GOBJET
VALEUR   = [F:POS]POSCOD
PARAM(1) = [F:POS]CRY
PARAM(2) = [F:POS]POSCTY
PARAM(3) = [F:POS]SATCOD
PARAM(4) = [F:POS]POSCTYCOD
GMEDIASAI = 1
mkstat = 99
Return

#####################################################
$CP_CONT
Local Char    CP(GLONPOS) , PAYS(GLONCRY) , VILLE(GLONCTY) , ETAT(GLONSAT)
Local Integer NBVILLE , OK
Local Integer IMINZIP                                                 # FGR 29/02/2012 : X3SUIVI79830
Local Char    SMINCP(GLONPOS)                                         # FGR 29/02/2012 : X3SUIVI79830

  CP    = VALEUR
  PAYS  = PARAM(1)
  VILLE = PARAM(2)
  ETAT  = PARAM(3)
  If PAYS="" or CP="" or (PAYS<>GPAYS & GMEDIAPAYS<>2)
    GOK = 9
    Return
  Endif
  # -----------------------------------
  If clalev([F:POS_])=0 : Local File POSCOD     [POS_] : Endif
  If clalev([F:TCY])=0  : Local File TABCOUNTRY [TCY]  : Endif
  # -----------------------------------
  If PAYS<>[F:TCY]CRY
    Read [TCY]TCY0 = PAYS
  Endif
  # -----------------------------------
  # FGR 29/02/2012 : X3SUIVI79830 (début)
  IMINZIP = 0
  SMINCP = CP
  If dim([F:TCY]MINZIP) >= 0 Then
    IMINZIP = [F:TCY]MINZIP
  Endif
  # -----------------------------------
  Repeat
    NBVILLE = 0
    For [POS_]POS0(3) Where CRY = PAYS & POSCOD = SMINCP
      NBVILLE += 1
      If NBVILLE>1 : Break : Endif
    Next
    If NBVILLE >= 1 Then
      Break
    Endif
    # ---------------------------------
    If IMINZIP > 0 Then
      If SMINCP = left$(CP,IMINZIP) Then
        # c'est qu'on l'a déjà fait ou qu'on a reçu cette valeur : donc on sort, il n'y a pas de réponse
        Break
      Endif
      SMINCP = left$(CP,IMINZIP)
    Endif
    # ---------------------------------
  Until IMINZIP = 0
  # FGR 29/02/2012 : X3SUIVI79830 (fin)
  # -----------------------------------
  If NBVILLE=1
    VILLE = [F:POS_]POSCTY
    ETAT  = [F:POS_]SATCOD
    If !GIMPORT : GMEDIASAI = 1 : Endif
    GOK = 9  # pour ne pas faire l'action suite
  Elsif [F:TCY]POSCODCTL<>2
    GOK = 9 : End
  Elsif NBVILLE=0
    If GMEDIACP=2
      # Code postal inexistant
      OK = 1
      If GWEBSERV=1 or GIMPORT : OK=2 : Endif
      GMESSAGE =  CP-":"-mess(188,100,1) : # Code postal inexistant
      Call AVERTIR(GMESSAGE,OK) From GESECRAN
      Raz GMESSAGE
      If OK=1 : mkstat = 2 : Endif
    Endif
    GOK = 9  # pour ne pas faire l'action suite
  Endif
  If GWEBSERV=1 : GOK=9 : Endif
  # -----------------------------------
  VALEUR = CP
  PARAM(2) = VILLE
  PARAM(3) = ETAT
Return

#####################################################
$OLD_CP_CONT
Local Char    CP(GLONPOS) , PAYS(GLONCRY) , VILLE(GLONCTY) , ETAT(GLONSAT)
Local Integer NBVILLE , OK

CP    = VALEUR
PAYS  = PARAM(1)
VILLE = PARAM(2)
ETAT  = PARAM(3)

If PAYS="" or CP="" or (PAYS<>GPAYS & GMEDIAPAYS<>2)
 GOK = 9 : Return
Endif

If clalev([F:POS_])=0 : Local File POSCOD     [POS_] : Endif
If clalev([F:TCY])=0  : Local File TABCOUNTRY [TCY]  : Endif

If PAYS<>[F:TCY]CRY
 Read [TCY]TCY0 = PAYS
Endif

NBVILLE = 0
For [POS_]POS0(3) Where CRY=PAYS & POSCOD=CP
 NBVILLE += 1
 If NBVILLE>1 : Break : Endif
Next
If NBVILLE=1
 VILLE = [F:POS_]POSCTY
 ETAT  = [F:POS_]SATCOD
 If !GIMPORT : GMEDIASAI = 1 : Endif
 GOK = 9  # pour ne pas faire l'action suite
Elsif [F:TCY]POSCODCTL<>2
 GOK = 9 : End
Elsif NBVILLE=0
 If GMEDIACP=2
  # Code postal inexistant
  OK = 1
  If GWEBSERV=1 or GIMPORT : OK=2 : Endif
  GMESSAGE =  CP-":"-mess(188,100,1) : # Code postal inexistant
  Call AVERTIR(GMESSAGE,OK) From GESECRAN
  Raz GMESSAGE
  If OK=1 : mkstat = 2 : Endif
 Endif
 GOK = 9  # pour ne pas faire l'action suite
Endif
If GWEBSERV=1 : GOK=9 : Endif

VALEUR = CP
PARAM(2) = VILLE
PARAM(3) = ETAT
Return

######################################################
$VIL_CONT
Local Char    CP(GLONPOS) , PAYS(GLONCRY) , VILLE(GLONCTY) , ETAT(GLONSAT)
Local Integer NBCODPOS, OK
Local Char    SVVILLE(GLONCTY)          # FGR 01/03/2012 : X3SUIVI79830
Local Integer OKTRT                     # FGR 07/03/2012 : X3SUIVI79830
Local Integer STAT                      # FGR 07/03/2012 : X3SUIVI79830

  # FGR 11/03/2014 : X3SUIVI97584 (début) : à faire en premier
  SVVILLE = VALEUR                      # FGR 01/03/2012 : X3SUIVI79830
  VILLE = VALEUR
  PAYS  = PARAM(1)
  CP    = PARAM(2)
  ETAT  = PARAM(3)
  # FGR 11/03/2014 : X3SUIVI97584 (fin)
  # FGR 01/03/2012 : X3SUIVI79830 (début)
  # FGR 11/03/2014 : X3SUIVI97584 (début) ouvrir en local
  #If clalev([F:POS])=0 : Local File POSCOD [POS] : Endif
  #If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
  Local File POSCOD [POS]
  Local File TABCOUNTRY [TCY]
  # FGR 11/03/2014 : X3SUIVI97584 (fin)
  If PAYS <> "" Then  # FGR 11/03/2014 : X3SUIVI97584 pas la peine si le pays est vide
    If PAYS<>[F:TCY]CRY
      Read [TCY]TCY0 = PAYS
    Endif
    #
    If dim([F:TCY]CTLPRG) > 0 and [F:TCY]CTLPRG <> "" Then
      Call EXISTE_ADX("", "", [F:TCY]CTLPRG, OKTRT) From ORDSYS
      If OKTRT > 0 Then
        Onerrgo RIEN
        STAT = 0
        Call FMTCTY(VALEUR, GMESSAGE, STAT) From =[F:TCY]CTLPRG
        Onerrgo
        If STAT Then
          If GMESSAGE <> "" Then
            Call AVERTIR(GMESSAGE, OK) From GESECRAN
            Raz GMESSAGE
          Endif
          GOK = 9
          Return
        Endif
      Endif
    Endif
  Endif
  # FGR 01/03/2012 : X3SUIVI79830 (fin)
  # FGR 11/03/2014 : X3SUIVI97584 (début) : à faire en premier
  #  SVVILLE = VALEUR                      # FGR 01/03/2012 : X3SUIVI79830
  #  VILLE = VALEUR
  #  PAYS  = PARAM(1)
  #  CP    = PARAM(2)
  #  ETAT  = PARAM(3)
  # FGR 11/03/2014 : X3SUIVI97584 (fin)
  # -----------------------------------
  If PAYS="" or VILLE="" or (PAYS<>GPAYS & GMEDIAPAYS<>2)
    GOK = 9 : Return
  Endif
  # -----------------------------------
  If [F:TCY]POSCODCTL<>2
    # FGR 11/03/2014 : X3SUIVI97584 (début) tenir compte de la ville en majuscules
    If [F:TCY]CTYUPP = 2 Then
      VALEUR = toupper(ctrans(VALEUR))
    Endif
    # FGR 11/03/2014 : X3SUIVI97584 (fin)
    GOK = 9 : Return
  Endif
  VILLE = toupper(ctrans(VILLE))
  NBCODPOS = 0
  For [POS]POS1(3) Where CRY=PAYS & POSCTYSEA=[L]VILLE
    NBCODPOS += 1
    If NBCODPOS>1 : Break : Endif
  Next
  If NBCODPOS=1
    CP     = [F:POS]POSCOD
    ETAT   = [F:POS]SATCOD
    # FGR 01/03/2012 : X3SUIVI79830 (début)
    If [F:TCY]CTYUPP = 2 Then
      VALEUR = toupper(ctrans([F:POS]POSCTY))
    Else
      VALEUR = [F:POS]POSCTY
    Endif
    # FGR 01/03/2012 : X3SUIVI79830 (fin)
    ## GMEDIASAI=1
    GOK = 9  # pour ne pas faire l'action suite (SELPOS2)
  Elsif NBCODPOS=0
    If GMEDIAVIL=2
      # Ville inexistante
      OK = 1
      If GWEBSERV=1 or GIMPORT : OK=2 : Endif
      GMESSAGE = VILLE-":"-mess(189,100,1) : # Ville inexistante
      Call AVERTIR(GMESSAGE,OK) From GESECRAN
      Raz GMESSAGE
      If OK=1 : mkstat = 2 : Endif
    Endif
    GOK = 9  # pour ne pas faire l'action suite
  Endif
  If GWEBSERV=1 : GOK=9 : Endif
  # -----------------------------------
  # FGR 01/03/2012 : X3SUIVI79830 (début)
  If NBCODPOS <> 1 Then
    If [F:TCY]CTYUPP = 2 Then
      VALEUR = toupper(ctrans(VILLE))
    Endif
  Endif
  # FGR 01/03/2012 : X3SUIVI79830 (fin)
  PARAM(2)  = CP
  PARAM(3)  = ETAT
  # -----------------------------------
Return

#----------------------------#
$RIEN
Resume

######################################################
$OLD_VIL_CONT
Local Char    CP(GLONPOS) , PAYS(GLONCRY) , VILLE(GLONCTY) , ETAT(GLONSAT)
Local Integer NBCODPOS , OK

VILLE = VALEUR
PAYS  = PARAM(1)
CP    = PARAM(2)
ETAT  = PARAM(3)

If PAYS="" or VILLE="" or (PAYS<>GPAYS & GMEDIAPAYS<>2)
 GOK = 9 : Return
Endif

If clalev([F:POS])=0 : Local File POSCOD [POS] : Endif
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif

If PAYS<>[F:TCY]CRY
 Read [TCY]TCY0 = PAYS
Endif
If [F:TCY]POSCODCTL<>2
 GOK = 9 : Return
Endif

VILLE = toupper(ctrans(VILLE))
NBCODPOS = 0
For [POS]POS1(3) Where CRY=PAYS & POSCTY=[L]VILLE # sinon y'en a toujours qu'1! (TB)
    NBCODPOS += 1
    If NBCODPOS>1 : Break : Endif
Next
If NBCODPOS=1
    CP   = [F:POS]POSCOD
    ETAT = [F:POS]SATCOD
    ## GMEDIASAI=1
    GOK = 9  # pour ne pas faire l'action suite (SELPOS2)
Elsif NBCODPOS=0
  If GMEDIAVIL=2
    # Ville inexistante
    OK = 1
    If GWEBSERV=1 or GIMPORT : OK=2 : Endif
    GMESSAGE = VILLE-":"-mess(189,100,1) : # Ville inexistante
    Call AVERTIR(GMESSAGE,OK) From GESECRAN
    Raz GMESSAGE
    If OK=1 : mkstat = 2 : Endif
  Endif
  GOK = 9  # pour ne pas faire l'action suite
Endif
If GWEBSERV=1 : GOK=9 : Endif

VALEUR    = VILLE
PARAM(2)  = CP
PARAM(3)  = ETAT
Return

##################################################################
$INI_VIL
If GMEDIASAI
 GMEDIASAI = 0 : mkstat = 2
Endif
Return

######################################################
$VILCNTOBL
Local Char    PAYS(GLONCRY) , VILLE(GLONCTY)
Local Integer CTL

VILLE = VALEUR
PAYS  = PARAM(1)
CTL   = val(PARAM(2))

If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif

If PAYS<>[F:TCY]CRY
 Read [TCY]TCY0 = PAYS
Endif

If dim([F:TCY]POSOBL)>0 & [F:TCY]POSOBL=2 & CTL>0
 If VILLE=""
  GMESSAGE = mess(118,127,1) : # Ville obligatoire
  mkstat = 2 : Return
 Endif
Endif

Return

#####################################################
$POSCNTOBL
Local Char    CP(GLONPOS) , PAYS(GLONCRY)
Local Integer CTL

CP    = VALEUR
PAYS  = PARAM(1)
CTL   = val(PARAM(2))

If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif

If PAYS<>[F:TCY]CRY
 Read [TCY]TCY0 = PAYS
Endif

If dim([F:TCY]POSOBL)>0 & [F:TCY]POSOBL=2 & CTL>0
 If CP=""
  GMESSAGE = mess(117,127,1) : # Code postal obligatoire
  mkstat = 2 : Return
 Endif
Endif

Return

##################################################################
# Modélisation des actions  (Octobre 2001)
# 2 actions pour les sélections ville à cause de l'ordre des param
##################################################################

$SEL_TABLE
Case TABLE
 When "SELPOS"   : Gosub SELPOS    : # Action SELPOS sur le type de donnée POS
 When "SELCTY2"  : Gosub SELCTY2   : # Action suite de l'action CPCONT (type de donnée POS)
 When "SELCTY"   : Gosub SELCTY    : # Action SELCTY sur le type de donnée CTY
 When "SELPOS2"  : Gosub SELPOS2   : # Action suite de l'action VILCONT (type de donnée CTY)
 When "SELCOM"   : Gosub SELCOM    : # Action SELCOM sélection des communes
Endcase
Return

$VERF_TABLE
Case TABLE
 When "SELPOS"   : Gosub VERFPOS
 When "SELCTY2"  : Gosub VERFCTY2
 When "SELCTY"   : Gosub VERFCTY
 When "SELPOS2"  : Gosub VERFPOS2
 When "SELCOM"   : Gosub VERFCOM
Endcase
Return

$CHX_TABLE
Case TABLE
 When "SELCTY"   : Gosub CHXCTY
 When "SELPOS2"  : Gosub CHXPOS2
Endcase
Return

$FIN_TABLE
Case TABLE
 When "SELPOS"    : Gosub FINPOS
 When "SELCTY2"   : Gosub FINPOS        #MAE, bg86759
 When "SELCTY"    : Gosub FINCTY
Endcase
Return

#######################################################
$SELPOS
  # FGR 29/02/2012 : X3SUIVI79830 (début)
  # -------------------------------------
  OBJET = "POS"
  # -------------------------------------
  If PARAM(1)<>""
    CRITERE = '[F:POS]CRY="'+PARAM(1)+'"'
    EXPSTART = '[F:POS]CRY="'+PARAM(1)+'"'
  Endif
  If EXPSTART<>"" : EXPSTART += ' & ' : Endif
  EXPSTART += '[F:POS]POSCOD="'+VALEUR+'"'
  If PARAM(2)<>""
    EXPSTART += ' & [F:POS]POSCTY="'+PARAM(2)+'"'
  Endif
  If CRITERE<>"" : CRITERE += ' & ' : Endif
  # -------------------------------------
  CRITERE += '('
  CRITERE += '[F:POS]POSCOD>="'+VALEUR+'"'
  #
  If dim([F:TCY]MINZIP) >= 0 Then
    CRITERE += '|([F:TCY]MINZIP>0 & [F:POS]POSCOD = left$("' + VALEUR + '",[F:TCY]MINZIP))'
  Endif
  #
  CRITERE += ')'
  # -------------------------------------
  ORDRE   = "[F:POS]CRY;[F:POS]POSCOD;[F:POS]POSCTY;[F:POS]POSCTYCOD"
  # FGR 29/02/2012 : X3SUIVI79830 (fin)
Return

#######################################################
$OLD_SELPOS
OBJET = "POS"
If PARAM(1)<>""
 CRITERE = 'CRY="'+PARAM(1)+'"'
 EXPSTART = 'CRY="'+PARAM(1)+'"'
Endif
If EXPSTART<>"" : EXPSTART += ' & ' : Endif
EXPSTART += 'POSCOD="'+VALEUR+'"'
If PARAM(2)<>""
 EXPSTART += ' & POSCTY="'+PARAM(2)+'"'
Endif
If CRITERE<>"" : CRITERE += ' & ' : Endif
CRITERE += 'POSCOD>="'+VALEUR+'"'
ORDRE   = "CRY;POSCOD;POSCTY;POSCTYCOD"
Return

#######################################################
$FINPOS
PARAM(2) = [F:POS]POSCTY
PARAM(3) = [F:POS]SATCOD
PARAM(4) = [F:POS]POSCTYCOD
Return

#######################################################
$SELCTY2
  # FGR 29/02/2012 : X3SUIVI79830 (début)
  If GOK=9 or GMEDIASAI=1
    OBJET = ""
    OK = 0
  Else
    # -------------------------------------
    OBJET = "POS"
    # -------------------------------------
    If PARAM(1)<>""
      CRITERE = '[F:POS]CRY="'+PARAM(1)+'"'
    Endif
    If CRITERE<>"" : CRITERE += ' & ' : Endif
    # -------------------------------------
    CRITERE += '('
    CRITERE += '[F:POS]POSCOD="'+VALEUR+'"'
    #
    If dim([F:TCY]MINZIP) >= 0 Then
      CRITERE += '|([F:TCY]MINZIP>0 & [F:POS]POSCOD = left$("' + VALEUR + '",[F:TCY]MINZIP))'
    Endif
    #
    CRITERE += ')'
    # -------------------------------------
    ORDRE = "[F:POS]CRY;[F:POS]POSCTY;[F:POS]POSCOD"
  Endif
  GOK = 1
  # FGR 29/02/2012 : X3SUIVI79830 (fin)
Return

#######################################################
$OLD_SELCTY2
If GOK=9 or GMEDIASAI=1
 OBJET = ""
 OK = 0
Else
 OBJET = "POS"
 If PARAM(1)<>""
  CRITERE = 'CRY="'+PARAM(1)+'"'
 Endif
 If CRITERE<>"" : CRITERE += ' & ' : Endif
 CRITERE += 'POSCOD="'+VALEUR+'"'
 ORDRE = "CRY;POSCTY;POSCOD"
Endif
GOK = 1
Return

#######################################################
$SELCTY
  # FGR 29/02/2012 : X3SUIVI79830 (début)
  OBJET = "POS"
  # -------------------------------------
  If PARAM(1)<>""
    CRITERE  = 'CRY="'+PARAM(1)+'"'
    EXPSTART = 'CRY="'+PARAM(1)+'"'
  Endif
  If EXPSTART<>"" : EXPSTART += ' & ' : Endif
  EXPSTART += 'POSCTY="'+VALEUR+'"'
  If PARAM(2)<>""
    EXPSTART += ' & POSCOD>="'+PARAM(2)+'"'
  Endif
  # -------------------------------------
  START = "POSCTY"  # sinon le CP (2è partie de clé) est ramené dans ville !
  OPTIONS = "|"
  # -------------------------------------
  ORDRE = "CRY;POSCTY;POSCOD"
  # FGR 29/02/2012 : X3SUIVI79830 (fin)
Return

#######################################################
$OLD_SELCTY
OBJET = "POS"
If PARAM(1)<>""
 CRITERE  = 'CRY="'+PARAM(1)+'"'
 EXPSTART = 'CRY="'+PARAM(1)+'"'
Endif
If EXPSTART<>"" : EXPSTART += ' & ' : Endif
EXPSTART += 'POSCTY="'+VALEUR+'"'
If PARAM(2)<>""
 EXPSTART += ' & POSCOD>="'+PARAM(2)+'"'
Endif
START = "POSCTY"  # sinon le CP (2è partie de clé) est ramené dans ville !
OPTIONS = "|"
ORDRE = "CRY;POSCTY;POSCOD"
Return

#######################################################
$CHXCTY
If CRITCAR<>"" & SELCAR>0
 CRITCAR = 'left$(POSCTY,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif
Return

#######################################################
$FINCTY
PARAM(2) = [F:POS]POSCOD
PARAM(3) = [F:POS]SATCOD
PARAM(4) = [F:POS]POSCTYCOD
Return

#######################################################
$SELPOS2
  # FGR 29/02/2012 : X3SUIVI79830 (début)
  If GOK=9 or GMEDIASAI=1
    OBJET = ""
    OK = 0
  Else
    OBJET = "POS"
    If PARAM(1)<>""
      CRITERE = 'CRY="'+PARAM(1)+'"'
    Endif
    If CRITERE<>"" : CRITERE += ' & ' : Endif
    #CRITERE += 'POSCTY="'+VALEUR+'"'
    CRITERE += 'POSCTYSEA="' + toupper(ctrans(VALEUR)) + '"'
    ORDRE   = "CRY;POSCOD;POSCTY;POSCTYCOD"
    START = "POSCTY"
  Endif
  GOK = 1
  # FGR 29/02/2012 : X3SUIVI79830 (fin)
Return

#######################################################
$OLD_SELPOS2
If GOK=9 or GMEDIASAI=1
 OBJET = ""
 OK = 0
Else
 OBJET = "POS"
 If PARAM(1)<>""
  CRITERE = 'CRY="'+PARAM(1)+'"'
 Endif
 If CRITERE<>"" : CRITERE += ' & ' : Endif
 CRITERE += 'POSCTY="'+VALEUR+'"'
 ORDRE   = "CRY;POSCOD;POSCTY;POSCTYCOD"
 START = "POSCTY"
Endif
GOK = 1
Return

#######################################################
$CHXPOS2
CRITCAR = '1=1'
Return

#######################################################
$SELCOM
OBJET = "POS"
If PARAM(1)<>""
 CRITERE = 'CRY="'+PARAM(1)+'"'
Endif
If PARAM(2)<>""
 If CRITERE<>"" : CRITERE += ' & ' : Endif
 CRITERE +='POSCOD="'+PARAM(2)+'"'
Endif
If PARAM(3)<>""
 If CRITERE<>"" : CRITERE += ' & ' : Endif
 CRITERE += 'POSCTY="'+PARAM(3)+'"'
Endif
START = "POSCTYCOD"
OPTIONS = "|"
ORDRE = "CRY;POSCOD;POSCTY;POSCTYCOD"
Return

#######################################################
$VERFPOS
VALEUR   = [F:POS]POSCOD
If PARAM(2)<>[F:POS]POSCTY
 PARAM(2) = [F:POS]POSCTY
 mkstat = 4
Endif
GMEDIASAI = 1
Return

#######################################################
$VERFCTY2
PARAM(2) = [F:POS]POSCTY
GMEDIASAI = 1
Return

#######################################################
$VERFCTY
VALEUR   = [F:POS]POSCTY
If PARAM(2)<>[F:POS]POSCOD
 PARAM(2) = [F:POS]POSCOD
 mkstat = 4
Endif
GMEDIASAI = 1
Return

#######################################################
$VERFPOS2
PARAM(2) = [F:POS]POSCOD
PARAM(3) = [F:POS]SATCOD     # FGR 16/06/2015 : X3SUIVI82911
Return

#######################################################
$VERFCOM
Return

#######################################################
$AVANT_CHOI
If SUIZON<>"GAU_CHE"                # SAM 122202 - left list selection - do not set SUIZON when selecting from left list
  SUIZON="CRY"
Endif
Return

$APRES_CHOI                         # SAM 122202 - left list selection - copy selection to mask
If GREP=""
  [M:POS1]=[F:POS]
  Affzo [M:POS1]1-99
Endif
Return

#########################################################
# Etiquettes du masque POS1 : Gestion des codes postaux.#
#########################################################
#########################################################
Subprog AP_CRY(VALEUR)
Variable Char    VALEUR()

  # FGR 14/03/2012 : X3SUIVI79830
  Case VALEUR
    When "FR"
      If dim([M]BURDIS) >= 0 Then
        Call FMTCTYPAY(VALEUR) From TRTDIV
        Chgfmt [M]BURDIS With "K:" + GFMT
      Endif
      # -------------------------
      If dim([M]GEOCOD) >= 0 Then
        Chgfmt [M]GEOCOD With "-K:1X"
      Endif
    When "US"
      If dim([M]GEOCOD) >= 0 Then
        Chgfmt [M]GEOCOD With "K:" + num$(GLONGEO) + "X"
      Endif
      # -------------------------
      If dim([M]BURDIS) >= 0 Then
        Chgfmt [M]BURDIS With "-K:1X"
      Endif
    When Default
      If dim([M]GEOCOD) >= 0 Then
        Chgfmt [M]GEOCOD With "-K:1X"
      Endif
      If dim([M]BURDIS) >= 0 Then
        Chgfmt [M]BURDIS With "-K:1X"
      Endif
  Endcase
  # --------------------------
  [M]CRY = VALEUR
  Gosub AV_SATCOD From W1POS1
End

#########################################################
Subprog AV_POSCOD(VALEUR)
Variable Char    VALEUR()

  # FGR 11/04/2012 : X3SUIVI79830
  If GFMT <> "" and left$(GFMT,2) <> "K:" Then
    GFMT = "K:" + GFMT
  Endif
  GFMT = ctrans(GFMT,"[]","")   #X3-58318 23/07/2018
End

#########################################################
Subprog C_POSCOD(VALEUR)
Variable Char     VALEUR

  If GREP = "C" | GREP = "D"
    If VALEUR = "" : mkstat = 2 : Endif
  Endif
End

#########################################################
Subprog AV_POSCTY(VALEUR)
Variable Char    VALEUR()

  # FGR 11/04/2012 : X3SUIVI79830
  If GFMT <> "" and left$(GFMT,2) <> "K:" Then
    GFMT = "K:" + GFMT
  Endif
End

#########################################################
Subprog C_POSCTY(VALEUR)
Variable Char     VALEUR

  If GREP = "C" | GREP = "D"
    If VALEUR = "" : mkstat = 2 : Endif
  Endif
End

#########################################################
Subprog AM_POSCTY(VALEUR)
Variable Char    VALEUR()

Local Integer NBPOSCTY

  # FGR 14/03/2012 : X3SUIVI79830
  If !GWEBSERV
    Local File POSCOD [POS1]
    Filter [POS1] Where CRY = [M]CRY and POSCTYSEA = toupper(ctrans(VALEUR))
    NBPOSCTY = rowcount([F:POS1])
    Filter [POS1]
  Endif
  # ------------------
  If NBPOSCTY > 0 Then
    If !GWEBSERV
      ## Action SELPOS2
      Local Char    PARMSK(250)(1..20) , SAVACT(20)

      SAVACT = GACTION : GACTION = "SELPOS2"
      PARMSK(1) = [M]CRY
      PARMSK(2) = [M]POSCOD
      Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOS2","SUBPOS","") From GACTION
      [M]POSCOD = PARMSK(2)
      GACTION = SAVACT
      mkstat = 0  # FGR : Pour ne pas bloquer si on a rien choisi dans la liste
    Endif
    Gosub AFF From GSAISIE
  Endif
End

#########################################################
Subprog C_POSCTYCOD(VALEUR)
Variable Char VALEUR()

  If GREP = "C" | GREP = "D"
    If VALEUR = "" : mkstat = 2 : Endif
  Endif
End

#########################################################
Subprog C_BURDIS(VALEUR)
Variable Char    VALEUR()

  # FGR 14/03/2012 : X3SUIVI79830
  If [F:TCY]CTYUPP = 2 Then
    VALEUR = toupper(ctrans(VALEUR))
  Endif
End

#########################################################
Subprog AV_BURDIS(VALEUR)
Variable Char    VALEUR()

  # FGR 11/04/2012 : X3SUIVI79830
  If [M:POS1]CRY <> "FR" Then
    GFMT = ""
  Endif
  If GFMT <> "" and left$(GFMT,2) <> "K:" Then
    GFMT = "K:" + GFMT
  Endif
End

#########################################################
Subprog AV_GEOCOD(VALEUR)
Variable Char    VALEUR()

  # FGR 11/04/2012 : X3SUIVI79830
  If [M:POS1]CRY <> "US" Then
    GFMT = ""
  Endif
End

