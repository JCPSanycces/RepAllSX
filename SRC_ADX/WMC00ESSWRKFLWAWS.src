# Supervisor
## CRUD-CLASSE ## ESSWRKFLWAWS
# 2018-10-23 06:53:13 859

Gosub TEST From WMCR_ESSWRKFLWAWS : End

############################################################################################
## R : Subprog AREAD(INSTANCE,UID,CLA,REFNUM,MAIREC,FLDNAM)
############################################################################################
# ESSWRKFLWAWS : ESSWRKFLWDET
# ESSWRKEMP : ESSWRKFLWDET ESSWRKEMP
# ESSWRKSA : ESSWRKFLWDET ESSWRKSA
# ESSWRKCHD : ESSWRKFLWDET ESSWRKCHD
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet ESSWRKFLWAWS._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1,A_N2,A_S2,A_N3,A_S3,A_N4,A_S4
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = ESSWRKFLWAWS.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(ESSWRKFLWAWS.ACTX.AFOLDER,nomap,"")>0
 Local File ESSWRKFLWDET [ESWD]
 Local File ESSWRKEMP [EWIS]
 Local File ESSWRKSA [EWSA]
 Local File ESSWRKCHD [EWCD]
Else
 Local File =ESSWRKFLWAWS.ACTX.AFOLDER+".ESSWRKFLWDET" [ESWD]
 Local File =ESSWRKFLWAWS.ACTX.AFOLDER+".ESSWRKEMP" [EWIS]
 Local File =ESSWRKFLWAWS.ACTX.AFOLDER+".ESSWRKSA" [EWSA]
 Local File =ESSWRKFLWAWS.ACTX.AFOLDER+".ESSWRKCHD" [EWCD]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKFLWAWS.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [ESWD] With
& [EWIS]EWID0 = [F:ESWD]UID,
& [EWSA]EWSA0 = [F:ESWD]UID,
& [EWCD]EWCHD0 = [F:ESWD]UID
& As [LNK_]
Return



