#<AdxTL>@(#)3.0.0.0 $Revision$
##########################
# Structure PPRICCONF
##########################

$ACTION
Case CURPRO
    When ""         : Gosub METHODS    : # If CURPRO is empty, we are on class methods
    When Default    : Gosub PROPERTIES : # Otherwise it is an event called on properties
Endcase
Return

#######################################################################################
$METHODS
  Case CURPTH
    When ""
      Case ACTION
        When "AREAD_AFTER"              : Gosub AREAD_AFTER
        When Default
      Endcase
    When Default
  Endcase
Return

#######################################################################################
$PROPERTIES
  Case CURPRO
    When "BPCBPS"         : Gosub BPCBPS
    When Default
  Endcase
Return

#######################################################################################
#######################################################################################
#######################################################################################
# METHODS                                                                             #
#######################################################################################
#######################################################################################
#######################################################################################
$AREAD_AFTER

this.BPCBPS=2

# The following was added by Beth S
Local File ATABLE [ATB]
Local File ATEXTE [ATX]
Local File ATEXTRA [AXX]

Local Integer TEMPNEW, TEMPAI
Local Char TEMPC

# Need to get correct Description for the Charges grid based upon the dimension # Added by Beth S
TEMPNEW = 0
For TEMPAI=0 To 5
 If ([F:PPC]DISCRGPRO(TEMPAI)<>0)
  TEMPNEW += 1
  For [AXX] Where CODFIC="PRICSTRUCT" & ZONE="DESAXX("+num$((TEMPAI))+")" & IDENT1="2" & IDENT2=[F:PPC]PLISTC
   Call ASETTEXTRA(this.C_DISCRG(TEMPNEW).AXX,this.C_DISCRG(TEMPNEW).ALLOCGRP(),"DISCRGTTL",[F:AXX]TEXTE,[F:AXX]LANGUE) From ASYRSUB
   this.C_DISCRG(TEMPNEW).AXX(maxtab(this.C_DISCRG(TEMPNEW).AXX)).FLG = 0
  Next AXX
 Endif
Next

# Need to get the Table Title from ATX from ATB from [F:PPC]FIL within the dimension # Added by Beth S
TEMPNEW = 0
For TEMPAI=0 To 4
 If ([F:PPC]FIL(TEMPAI))<>""
  TEMPNEW += 1
  Read [ATB]CODFIC = [F:PPC]FIL(TEMPAI)
  For [ATX] Where NUMERO=[F:ATB]INTITFIC
   Call ASETTEXT(this.C_FIL(TEMPNEW).ATX,this.C_FIL(TEMPNEW).ALLOCGRP,"INTITFIC",[F:ATX]TEXTE,[F:ATX]LAN,[F:ATX]NUMERO) From ASYRSUB
#   TEMPC=this.C_FIL(TEMPNEW).ATX.TEX
  Next ATX
 Endif
Next

Close File [ATB],[ATX],[AXX]

Return

#######################################################################################
#######################################################################################
#######################################################################################
# PROPERTIES                                                                          #
#######################################################################################
#######################################################################################
#######################################################################################
$BPCBPS
#When "INIT"  : Gosub INIT_BPCBPS
#When "GET"  : Gosub GET_BPCBPS
#When "SET"    : Gosub SET_BPCBPS
#When "CONTROL"   : Gosub CONTROL_BPCBPS
#When "PROPAGATE" : Gosub BPCBPS
Case ACTION
When "GET"  : Gosub GET_BPCBPS
When Default
Endcase

Return

$GET_BPCBPS

this.BPCBPS=2

Return

