#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
# Sélection d'un script d'appel                                     Module CRM           23 avril 2002   #
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "FIR"          : Gosub PREMIER
    When "PRE"          : Gosub PRECEDENT
    When "SUI"          : Gosub SUIVANT
    When "LAS"          : Gosub DERNIER
    When "RAF"          : Gosub PREMIER
    When "SUP"          : Gosub SUPPRESSION
    When Default
  Endcase
Return

##########################################################################################################
$PREMIER
  Call LOADSCP(1, 0)
Return

##########################################################################################################
$PRECEDENT
  Call LOADSCP(2, 0)
Return

##########################################################################################################
$SUIVANT
  Call LOADSCP(3, 0)
Return

##########################################################################################################
$DERNIER
  Call LOADSCP(4, 0)
Return

##########################################################################################################
$OUVRE
  If clalev ([F:AUS])<=0 Local File AUTILIS [AUS] : Endif
  If clalev ([F:SCP])<=0 Local File SCRIPT [SCP] : Endif
  If clalev ([F:SCQ])<=0 Local File SCPQST [SCQ] : Endif
  If clalev ([F:SQC])<=0 Local File SCPQSTCND [SQC] : Endif
  If clalev ([F:SCA])<=0 Local File SCPASW [SCA] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  ETABOU(GRAFF) = 1
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  Call LOADSCP(1, 0)
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
AP_CHOIX
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:PHZ6]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$SUPPRESSION
  Call DELSCRIPT([M:PHZ6]SCPNUMY(nolign - 1))
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
Subprog LOADSCP(IWHATTODO, IACTFLT)
Value Integer IWHATTODO
Value Integer IACTFLT

Local Integer IMAXREC
Local Integer IG

  # FGR 03/09/2008 : Structure LOADSCP revue en traitant X3SUIVI43507. L'original est en V5 (en cas de PB)
  IG = 0
  IMAXREC = 0
  #1 : Premier
  #2 : Précédent
  #3 : Suivant
  #4 : Dernier
  Case IWHATTODO
    When 1
      If IACTFLT Then
        Filter [SCP] Where [F:SCP]SCPFLG <> 2 Order By [F:SCP]SCPNUM Asc
      Else
        Filter [SCP] Where [F:SCP]SCPNUM <> "" Order By [F:SCP]SCPNUM Asc
      Endif
      Gosub LIT_ASCENDANT
      Filter [SCP]
    When 2
      If [M:PHZ6]NBSCP > 0 Then
        If [M:PHZ6]SCPNUMY(0) <> "" Then
          If IACTFLT Then
            Filter [SCP] Where [F:SCP]SCPNUM < [M:PHZ6]SCPNUMY(0) and [F:SCP]SCPFLG <> 2 Order By [F:SCP]SCPNUM Desc
          Else
            Filter [SCP] Where [F:SCP]SCPNUM < [M:PHZ6]SCPNUMY(0) Order By [F:SCP]SCPNUM Desc
          Endif
          Gosub LIT_DESCENDANT
          #
          If IG = 0 Then
            If IACTFLT Then
              Filter [SCP] Where [F:SCP]SCPFLG <> 2 Order By [F:SCP]SCPNUM Asc
            Else
              Filter [SCP] Where [F:SCP]SCPNUM <> "" Order By [F:SCP]SCPNUM Asc
            Endif
            Gosub LIT_ASCENDANT
            Filter [SCP]
          Endif
        Endif
      Endif
    When 3
      If [M:PHZ6]NBSCP > 0 Then
        If [M:PHZ6]SCPNUMY([M:PHZ6]NBSCP - 1) <> "" Then
          If IACTFLT Then
            Filter [SCP] Where [F:SCP]SCPNUM > [M:PHZ6]SCPNUMY([M:PHZ6]NBSCP-1) and [F:SCP]SCPFLG <> 2 Order By [F:SCP]SCPNUM Asc
          Else
            Filter [SCP] Where [F:SCP]SCPNUM > [M:PHZ6]SCPNUMY([M:PHZ6]NBSCP-1) Order By [F:SCP]SCPNUM Asc
          Endif
          Gosub LIT_ASCENDANT
          Filter [SCP]
          #
          If IG = 0 Then
            Gosub LIT_LA_FIN
          Endif
        Endif
      Endif
    When 4
      Gosub LIT_LA_FIN
  Endcase
  [M:PHZ6]NBSCP = IG
  Affzo [M:PHZ6]
End

####################################################
$LIT_LA_FIN
  If IACTFLT Then
    Filter [SCP] Where [F:SCP]SCPFLG <> 2 Order By [F:SCP]SCPNUM Desc
  Else
    Filter [SCP] Where [F:SCP]SCPNUM <> "" Order By [F:SCP]SCPNUM Desc
  Endif
  Gosub LIT_DESCENDANT
  Filter [SCP]
Return

####################################################
$LIT_DESCENDANT
  IMAXREC = rowcount([SCP]) - 1
  If IMAXREC >= dim([M:PHZ6]SCPNUMY) Then
    IMAXREC = dim([M:PHZ6]SCPNUMY) - 1
  Endif
  For [SCP] 
    If IMAXREC < 0 Then
      Break
    Endif
    Call CHARGE_UNE_LIGNE (IMAXREC)
    IMAXREC -= 1
    IG += 1
  Next
Return

####################################################
$LIT_ASCENDANT
  For [SCP]
    If IG >= dim([M:PHZ6]SCPNUMY) Then
      Break
    Endif
    Call CHARGE_UNE_LIGNE (IG)
    IG += 1
  Next
Return

##########################################################################################################
Subprog CHARGE_UNE_LIGNE (ILINE)
Value Integer ILINE

Local Integer ISCQ

  [M:PHZ6]SCPNUMY(ILINE) = [F:SCP]SCPNUM
  [M:PHZ6]SCPNAMY(ILINE) = [F:SCP]SCPNAM
  [M:PHZ6]SALFCYY(ILINE) = [F:SCP]SALFCY # FGR 03/09/2008 : X3SUIVI43507
  [M:PHZ6]CREUSRY(ILINE) = [F:SCP]CREUSR
  [M:PHZ6]CREDATY(ILINE) = [F:SCP]CREDAT
  If [F:SCP]SCPFLG = 2 Then
    [M:PHZ6]SCPFLG(ILINE) = 1
  Else
    [M:PHZ6]SCPFLG(ILINE) = 2
  Endif
  If [F:SCP]CREUSR = "" Then
    [M:PHZ6]CREUSRCLA(ILINE) = ""
  Else
    Read [AUS]CODUSR=[F:SCP]CREUSR
    If fstat
      [M:PHZ6]CREUSRCLA(ILINE) = ""
    Else
      [M:PHZ6]CREUSRCLA(ILINE) = [F:AUS]NOMUSR
    Endif
  Endif
  Filter [SCQ] Where [F:SCQ]SCPNUM=[M:PHZ6]SCPNUMY(ILINE)
  ISCQ = 0
  For [SCQ]
    ISCQ += 1
  Next
  [M:PHZ6]NBQQST(ILINE) = ISCQ
  Filter [SCQ]
End

##########################################################################################################
Subprog DELSCRIPT(SZSCPTODEL)
Value Char SZSCPTODEL

Local Char SZMESS(250)
Local Integer IOKREP

  SZMESS = mess(644,196,1) + ' ' + mess(645,196,1) + ' ' + mess(646,196,1)
  IOKREP = 0
  If SZSCPTODEL = "" Then
    End
  Endif
  #La suppression d'un script d'appel élimine également toutes les réponses enregistrée dans le questionnaire associé.
  #Il ne sera alors plus possible de réaliser des analyses marketing ultérieures sur ces réponses.
  #Confirmez-vous cette suppression ?
  Call OUINON(SZMESS, IOKREP) From GESECRAN
  If IOKREP <> 2 Then
    End
  Endif
  #
  If !clalev([F:SCP]) : Local File SCRIPT [SCP] : Endif
  If !clalev([F:SCQ]) : Local File SCPQST [SCQ] : Endif
  If !clalev([F:SQC]) : Local File SCPQSTCND [SQC] : Endif
  If !clalev([F:SCA]) : Local File SCPASW [SCA] : Endif
  #
  Call DEBTRANS From GLOCK
  Trbegin [SCP], [SCQ], [SQC], [SCA]
  Delete [SCP] Where [F:SCP]SCPNUM=SZSCPTODEL
  If fstat Then
    #Erreur lors de la suppression du script
    GMESSAGE = mess(647,196,1)
    GERR = 1
    Rollback
    End
  Endif
  #
  Delete [SCQ] Where [F:SCQ]SCPNUM=SZSCPTODEL
  If fstat Then
    #Erreur lors de la suppression des questions du script
    GMESSAGE = mess(648,196,1)
    GERR = 1
    Rollback
    End
  Endif
  #
  Delete [SQC] Where [F:SQC]SCPNUM=SZSCPTODEL
  If fstat Then
    #Erreur lors de la suppression des cheminements du script
    GMESSAGE = mess(649,196,1)
    GERR = 1
    Rollback
    End
  Endif
  #
  Delete [SCA] Where [F:SCA]SCP=SZSCPTODEL
  If fstat Then
    #Erreur lors de la suppression des réponses au script
    GMESSAGE = mess(650,196,1)
    GERR = 1
    Rollback
    End
  Endif
  Commit
End
