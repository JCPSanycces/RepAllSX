#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion objet ACG
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ACG",GBIDC1,GBIDC2) From GOBJET
End

#------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "SETBOUT"   : Gosub SETBOUT
 When "LIENS"     : Gosub LIENS
 When "INICRE"    : Gosub INICRE
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "ANNULE"    : Gosub ANNULE
 When "CHANGE"    : Gosub CHANGE
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "VERIF_MOD" : Gosub VERIF_MOD
Endcase
Return

$OUVRE
Local Integer NOL
Return

$SETBOUT
CHMEN += "3" : # Exécution
Return

$LIENS
NOL = nolign-1
[M]VAL1(NOL) = [M]CLE1(NOL)
[M]NEW1(NOL) = [M]NEWCOD(NOL)
Call DES([M]DES(NOL),[M]OBJ(NOL),[M]CLE1(NOL),[M]CLE2(NOL))
Call SETFMT([M]OBJ(NOL),[M]TYP1(NOL),[M]LIB1(NOL),[M]LNG1(NOL),[M]OPT1(NOL))
Call CHARGE([M]VAL1(NOL),[M]TYP1(NOL),[M]LIB1(NOL),[M]LNG1(NOL),[M]CLE1(NOL)) From FMTVAR
Call CHARGE([M]NEW1(NOL),[M]TYP1(NOL),[M]LIB1(NOL),[M]LNG1(NOL),[M]NEWCOD(NOL)) From FMTVAR
Return

Subprog SETFMT(OBJ,CODTYP,NOLIB,LONG,OPTION)
Value    Char    OBJ
Variable Char    CODTYP
Variable Decimal NOLIB , LONG
Variable Char    OPTION
Local Char PROGOBJ(GLONADC)
PROGOBJ = "WO"+OBJ
Gosub NOMFIC From =PROGOBJ
Gosub SETCLE From =PROGOBJ
Read [ATZ]CODZONE=NOMFIC;CLEPRIM
Read [ATY]CODTYP=[F:ATZ]CODTYP
[L]CODTYP = [F:ATY]CODTYP
[L]NOLIB  = [F:ATY]NOLIB
[L]LONG   = [F:ATY]LNGTYP
[L]OPTION = [F:ATY]OPTION
End

$INICRE
[F:ACG]LIG = nolign
Return

$CREATION
$MODIF
Call MAJTEXTRA([M]INTIT,"ACHANGE","INTIT",[M]COD,"") From ATEXTRA
Return

$ANNULE
Delete [AXX] Where CODFIC="ACHANGE" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

$CHANGE
Update [AXX] Where CODFIC="ACHANGE" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA ACHANGE"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

$VERIF_CRE
$VERIF_MOD
For I=1 To [M]NBLIG
 If [M]NEWCOD(I-1)=""
  # ligne no/Zone obligatoire
  Call ERREUR(mess(61,100,1)-num$(I)-":"-mess(10,123,1)) From GESECRAN
  OK = 0 : Break
 Endif
Next I
Return

#----------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap 
 Local File ACHANGE [ACG1] 
 Local File ATEXTRA [AXX1] 
Else 
 Local File =[M]DOSORG+".ACHANGE" [ACG1]
 Local File =[M]DOSORG+".ATEXTRA" [AXX1] 
Endif 
If [M]DOSDES=nomap 
 Local File ACHANGE [ACG2] 
 Local File ATEXTRA [AXX2] 
Else 
 Local File =[M]DOSDES+".ACHANGE" [ACG2]
 Local File =[M]DOSDES+".ATEXTRA" [AXX2]
Endif 
Gosub OUVDOS From ATEXTRA
OK = 1
If GTRACE=""
 Read [ACG2]ACG0 = TABLE 
 If !fstat
  Call AVERTIR(mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [ACG1], [ACG2], [AXX1] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [ACG2]
 Delete [ACG2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACHANGE" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACG2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ACG1]ACG0 Where COD=TABLE
  [F:ACG2] = [F:ACG1]
  Call COPTEXTRA("ACHANGE","INTIT",[F:ACG2]COD,"") From ATEXTRA
  If dim([F:ACG2]UPDUSR)>0 : [F:ACG2]UPDUSR = GUSER : Endif
  If dim([F:ACG2]UPDDAT)>0 : [F:ACG2]UPDDAT = date$ : Endif
  Write [ACG2]
  If fstat
   GOK=0 : Call FSTA("ACG2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
ROLLBACK
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#-----------------------------------------------------------#
# Ecran ACG1
#-----------------------------------------------------------#

Subprog IB_NBLIG
End

Subprog B1_NBLIG
Local Char    OBJET(GLONAOB) , PROGOBJ(GLONADC) , VALSUP(GLONID1)(1..16)
Local Char    CHAINE(250) , SUPP(250) , COD(250) , FMTC(30) , TEXTE(GLONDES)
Local Char    CRITERE(250)
Local Integer I , ER , NBSUP , LG
OK = 0
If func GLOCK.LOKBYI("ACG"+[M]COD) or find(GREP,"C","D")
 OK = 1
Elsif !func GLOCK.LOKBYU("ACG"+[M]COD)
 Call ERREUR(mess(11,139,1)) From GESECRAN : # Pour modifier la fiche, cliquez sur l'îcone de verrouillage
Else
 Call ERREUR(mess(60,100,1)) From GESECRAN : # Enregistrement verrouillé
Endif
If !OK : End : Endif
OBJET   = [M]OBJ(nolign-1)
CRITERE = [M]CLE2(nolign-1)
Call SETOBJ(OBJET,CRITERE)
If CRITERE="" : CRITERE = "1=1" : Endif
If OBJET="" : End : Endif
PROGOBJ = "WO"+OBJET
Gosub NOMFIC From =PROGOBJ
Gosub SETCLE From =PROGOBJ
Gosub OUVFIC From =PROGOBJ
Gosub DEFAUT From =PROGOBJ
For [F] Where evalue(CRITERE)
 SUPP = ""
 K = 1
 For I=0 To dim(CLESEC)-1
  If CLESEC(I)<>"" & CLESEC(I)<>CLELIG 
   Onerrgo ER
   CHAINE = num$(evalue("[F]"+CLESEC(I)))
   Onerrgo
   If ER : K = 0 : Break : Endif
   If I>0 : SUPP += "~" : Endif
   SUPP += CHAINE
  Endif
 Next I
 If K
  ER = 0
  Onerrgo ER
  COD = num$(evalue("[F]"+CLEPRIM))
  Onerrgo
  If ER : K = 0 : Endif
 Endif
 If K
  For J=1 To [M]NBLIG
   If [M]CLE1(J-1)=COD & [M]CLE2(J-1)=SUPP
    K = 0 : Break
   Endif
  Next J
 Endif
 If K
  [M]OBJ([M]NBLIG)    = OBJET
  [M]CLE2([M]NBLIG)   = SUPP
  [M]CLE1([M]NBLIG)   = COD
  [M]VAL1([M]NBLIG)   = COD
  [M]NEWCOD([M]NBLIG) = ""
  [M]NEW1([M]NBLIG)   = ""
  Call DES([M]DES([M]NBLIG),[M]OBJ([M]NBLIG),[M]CLE1([M]NBLIG),[M]CLE2([M]NBLIG))
  Call SETFMT([M]OBJ([M]NBLIG),[M]TYP1([M]NBLIG),[M]LIB1([M]NBLIG),[M]LNG1([M]NBLIG),[M]OPT1([M]NBLIG))
  Call CHARGE([M]VAL1([M]NBLIG),[M]TYP1([M]NBLIG),[M]LIB1([M]NBLIG),[M]LNG1([M]NBLIG),[M]CLE1([M]NBLIG)) From FMTVAR
  Call CHARGE([M]NEW1([M]NBLIG),[M]TYP1([M]NBLIG),[M]LIB1([M]NBLIG),[M]LNG1([M]NBLIG),[M]NEWCOD([M]NBLIG)) From FMTVAR
  [M]NBLIG += 1
 Endif
Next
Affzo
End

Subprog SETOBJ(OBJET,CRITERE)
Variable Char OBJET , CRITERE
Local Integer I , ER , OK , NBSUP
Local Char    CHAINE(250) , PROGOBJ(GLONADC) , VALSUP(GLONID1)(1..16)
Local Date    DAT
Local Mask ACG9 [ACG9]
[M:ACG9]OBJET = OBJET
If OBJET<>"" & CRITERE<>""
 CHAINE = CRITERE
 While CHAINE<>""
  NBSUP += 1
  I = instr(1,CHAINE,"~")
  If I
   VALSUP(NBSUP) = left$(CHAINE,I-1)
   CHAINE = right$(CHAINE,I+1)
  Else
   VALSUP(NBSUP) = CHAINE
   CHAINE = ""
  Endif
 Wend
 PROGOBJ = "WO"+OBJET
 Gosub NOMFIC From =PROGOBJ
 Gosub SETCLE From =PROGOBJ
 Gosub OUVFIC From =PROGOBJ
 Gosub DEFAUT From =PROGOBJ
 CRITERE = ""
 For I=1 To NBSUP
  If CLESEC(I-1)<>""
   If CRITERE<>""
    CRITERE += " & "
   Endif
   Case evalue("type([F]"+CLESEC(I-1)+")")
    When 1,2,4,5,6,7,8 : CRITERE += CLESEC(I-1)+'='+VALSUP(I)
    When 3             : Onerrgo ER
                         DAT = VALSUP(I)
                         Onerrgo
                         If !ER
                          CRITERE += CLESEC(I-1)+'=['+format$("D:YY[/]MM[/]DD",DAT)+']'
                         Else
                          CRITERE += "1=1"
                         Endif
    When Default       : CRITERE += CLESEC(I-1)+'="'+VALSUP(I)+'"'
   Endcase
  Endif
 Next I
Endif
[M:ACG9]CRITERE = CRITERE
Call DIALWIN(OK,"","ACG9") From GESECRAN
If OK=2
 [L] = [M]
Endif
Close Local Mask [ACG9]
End

Subprog C_OBJ(VALEUR)
Variable Char    VALEUR()
Local Char    PROGOBJ(GLONADC) , TEXTE(GLONDES)
Local Integer LG 
Call CONTOBJ(VALEUR)
If mkstat : End : Endif
PROGOBJ = "WO"+VALEUR
Call SETFMT(VALEUR,[M]TYP1(nolign-1),[M]LIB1(nolign-1),[M]LNG1(nolign-1),[M]OPT1(nolign-1))
End

Subprog CONTOBJ(VALEUR)
Value Char VALEUR
Local Char    OBJET(GLONAOB) , PROGOBJ(GLONADC)
Local Char    FENETRE(GLONFEN) , TEXTE(GLONDES)
Local Integer LG , OKTRT
PROGOBJ = "WO"+VALEUR
Call EXISTE_ADX("","",PROGOBJ,OKTRT) From ORDSYS
Read [AOB]ABREV=VALEUR
If fstat or [F:AOB]TYPGES=4 or !OKTRT
 GMESSAGE = mess(42,115,1) : # Type d'objet incorrect
 mkstat = 2 : End
Endif
Gosub SETCLE From =PROGOBJ
If dim(CLESEC)>1 & CLESEC(1)<>"" & CLESEC(1)<>CLELIG
 GMESSAGE = mess(236,115,1) : # Changement de clé impossible à réaliser sur cet objet
 mkstat = 2 : End
Endif
Call CONT_FEN(VALEUR,FENETRE) From GOBJET
If FENETRE<>""
 Read [AWI]AWI0=FENETRE
 If fstat
  GMESSAGE = FENETRE-":"-mess(6,126,1) : # Fenêtre inexistante
  mkstat = 2 : End
 Endif
 If [F:AWI]BSTD(11)<>2
  # Le bouton $1$ est désactivé dans la fenêtre $2$
  # Changement clé
  GMESSAGE = func AFNC.MES2(mess(218,115,1),'"'+mess(135,124,1)+'"',FENETRE)
  mkstat = 2 : End
 Endif
Endif
If [F:AOB]NOMFIC<>""
 Read [ATB]CODFIC=[F:AOB]NOMFIC
 If !fstat & [F:ATB]TYPFIC=3 : # Système
  GMESSAGE = [F:AOB]NOMFIC-":"-mess(237,115,1) : # Table système
  mkstat = 2 : End
 Endif
Endif
If find("VALEUR","ACV")
 GMESSAGE = VALEUR-":"-mess(238,115,1) : # Changement de clé interdit sur cet objet
 mkstat = 2 : End
Endif
End

Subprog AS_CLE2(VALEUR)
Variable Char VALEUR
Local Char    OBJET(GLONAOB) , PROGOBJ(GLONADC)
Local Integer I , MULTI
OBJET = [M]OBJ(nolign-1)
PROGOBJ = "WO"+OBJET
Gosub NOMFIC From =PROGOBJ
Gosub SETCLE From =PROGOBJ
For I=0 To dim(CLESEC)-1
 If CLESEC(I)<>"" & CLESEC(I)<>CLELIG
  MULTI = 1 : Break
 Endif
Next I
If !MULTI
 mkstat = 1 : End
Endif
End

Subprog C_CLE2(VALEUR)
Variable Char VALEUR
Local Char    OBJET(GLONAOB) , PROGOBJ(GLONADC)
Local Integer I , OK
End

Subprog IB_VAL1
If GBOUTS<>"" : GBOUT2 = "" : Endif
End

Subprog B2_VAL1(VALEUR)
Variable Char    VALEUR()
Local Char    OBJET(GLONAOB) , PROGOBJ(GLONADC) , SUPP(250)
Local Integer I , ER
OBJET = [M]OBJ(nolign-1)
PROGOBJ = "WO"+OBJET
Gosub NOMFIC From =PROGOBJ
Gosub SETCLE From =PROGOBJ
Gosub OUVFIC From =PROGOBJ
SUPP = [M]CLE2(nolign-1)
Call SELECT(OBJET,"",VALEUR,SUPP) From SELOBJ
If GSTATUT=GSTAESC or CLESEC="" : End : Endif
Onerrgo ER
[M]CLE2(nolign-1) = ""
For I=0 To dim(CLESEC)-1
 If CLESEC(I)<>"" & CLESEC(I)<>CLELIG
  If I>0
   [M]CLE2(nolign-1) += "~"
  Endif
  [M]CLE2(nolign-1) += num$(evalue("[F:"+ABFIC+"]"+CLESEC(I)))
 Endif
Next I
Onerrgo
End

Subprog C_VAL1(VALEUR)
Variable Char VALEUR
Local Char    OBJET(GLONAOB) , SUPP(250) , PROGOBJ(GLONADC)
Local Integer I , MULTI , OK
Local Char    VALNEW(GLONID1) , VALINT(GLONID1)
VALNEW = VALEUR
VALINT = VALEUR
Call CHARGE(VALNEW,[M]TYP1(nolign-1),[M]LIB1(nolign-1),[M]LNG1(nolign-1),VALINT) From FMTVAR
OBJET = [M]OBJ(nolign-1)
PROGOBJ = "WO"+OBJET
Gosub NOMFIC From =PROGOBJ
Gosub SETCLE From =PROGOBJ
For I=0 To [M]NBLIG-1
 If I<>nolign-1 & [M]OBJ(I)=[M]OBJ(nolign-1) & [M]CLE2(I)=[M]CLE2(nolign-1) & [M]CLE1(I)=VALINT
  GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
  mkstat = 2 : Break
 Endif
Next I
If mkstat : End : Endif
If [M]OBJ(nolign-1)="ADI"
 Read [ADV]CODE=val([M]CLE2(nolign-1))
 If [F:ADV]LNG>0 & len(VALINT)>[F:ADV]LNG
  # Longueur trop longue (maximum #)
  Call ERREUR(func AFNC.MES(mess(235,115,1),num$([F:ADV]LNG))) From GESECRAN
  mkstat = 1 : End
 Endif
Endif
Call CONTROLE(OBJET,"",VALINT,[M]CLE2(nolign-1),mkstat) From CONTOBJ
If mkstat
 # Fiche inexistante\Voulez-vous continuer ?
 Call AVERTIR(VALINT-":"-mess(23,100,1)+"\"+mess(205,100,1),OK) From GESECRAN
 If OK<>2 : mkstat = 2 : End : Endif
 mkstat = 0
Endif
Call DES([M]DES(nolign-1),[M]OBJ(nolign-1),VALINT,[M]CLE2(nolign-1))
End

Subprog DES(DES,OBJET,CLE1,CLE2)
Variable Char    DES
Value    Char    OBJET , CLE1 , CLE2
Local Integer I , ER
Local Char    CLE(GLONID1)(1..4) , PAR(GLONAAR)
Local Char    PROGOBJ(GLONADC)
PROGOBJ = "WO"+OBJET
Gosub NOMFIC From =PROGOBJ
Gosub OUVFIC From =PROGOBJ
Call LECTURE(OBJET,CLE1,CLE2) From CONTOBJ
Read [ATZ]CODZONE=NOMFIC;NOMINT
Gosub DEFAUT From =PROGOBJ
Onerrgo ER
Case [F:ATZ]CODTYP
 When "AXX","AX1","AX2","AX3"
  I = 0
  For PAR="TABLE1","ZONE","CLECUR1","CLECUR2"
   I += 1
   Read [AMP]CODPAR=2;NOMFIC;NOMINT;PAR
   If !fstat
    CLE(I) = num$(evalue([F:AMP]VALPAR))
   Endif
  Next PAR
  Call LECTEXTRA([L]DES,CLE(1),CLE(2),CLE(3),CLE(4)) From ATEXTRA
 When "ATX"
  Call TEXTE(evalue("[F:"+ABFIC+"]"+NOMINT),[L]DES) From OBJDIV
 When Default
  [L]DES = evalue("[F:"+ABFIC+"]"+NOMINT)
Endcase
Onerrgo
End

$ER
ER = errn
Resume

Subprog C_NEW1(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Local Char    VALNEW(GLONID1) , VALINT(GLONID1)
VALNEW = VALEUR
VALINT = VALEUR
Call CHARGE(VALNEW,[M]TYP1(nolign-1),[M]LIB1(nolign-1),[M]LNG1(nolign-1),VALINT) From FMTVAR
If [M]CLE1(nolign-1)=VALINT
 # Fiche déjà existante
 Call ERREUR(VALINT-":"-mess(22,100,1)) From GESECRAN
 mkstat = 1 : End
Endif
For I=0 To [M]NBLIG-1
 If I<>nolign-1 & [M]OBJ(I)=[M]OBJ(nolign-1) & [M]CLE2(I)=[M]CLE2(nolign-1) & [M]NEW1(I)=VALINT
  GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
  mkstat = 2 : Break
 Endif
Next I
If mkstat : End : Endif
If [M]OBJ(nolign-1)="ADI"
 Read [ADV]CODE=val([M]CLE2(nolign-1))
 If [F:ADV]LNG>0 & len(VALINT)>[F:ADV]LNG
  # Longueur trop longue (maximum #)
  Call ERREUR(func AFNC.MES(mess(235,115,1),num$([F:ADV]LNG))) From GESECRAN
  mkstat = 1 : End
 Endif
Endif
Call CONTROLE([M]OBJ(nolign-1),"",VALINT,[M]CLE2(nolign-1),mkstat) From CONTOBJ
If !mkstat
 # Fiche déjà existante\Voulez-vous continuer ?
 Call AVERTIR(VALINT-":"-mess(22,100,1)+"\"+mess(205,100,1),OK) From GESECRAN
 If OK<>2 : mkstat = 2 : End : Endif
Else
 mkstat = 0
Endif
End

#-----------------------------------------------------------#
# Ecran ACG9
#-----------------------------------------------------------#

Subprog C_OBJET(VALEUR)
Variable Char    VALEUR()
Call CONTOBJ(VALEUR)
If mkstat : End : Endif
Local File AOBJET [AOB]
Read [AOB]ABREV=VALEUR
[M]CODFIC = [F:AOB]NOMFIC
End

Subprog AM_OBJET(VALEUR)
Variable Char    VALEUR()
[M]CRITERE = ""
Affzo CRITERE
End

