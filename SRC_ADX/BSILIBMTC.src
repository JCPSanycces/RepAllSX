######################################################################################################

Local Char TESTSTMCOD(30), TESTMSG(250)
Local Integer TESTLIN, TESTSTA
TESTSTMCOD = "00001827"
TESTLIN    = 3
TESTSTA    = 0
TESTMSG    = ""
Call BSI_MATCHING(TESTSTMCOD,TESTLIN,TESTSTA,TESTMSG,1)
End

#**
#* Purpose: Matching of one transaction within a bank file import statement
#*
#* @param PSTMCOD      primary key for reading record in table BSIIMP.
#* @param PLIN         second part of primary key for reading record in table BSIIMPD (PSTMCOD+PLIN).
#* @param PSTA         status of matching 0 : OK, 1 : already matched, 2 : import/statement not found, 3 : various.
#* @param PMSG         Message corresponding to status.
#* @param PLOG         Write detailed log? 1 = yes, 0 = no
#*!
Subprog BSI_MATCHING(PSTMCOD,PLIN,PSTA,PMSG,PLOG)
Value Char PSTMCOD     # file number of statement, part of key to table BSIIMP/BSIIMPD
Value Integer PLIN     # line number of statement, part of key to table BSIIMPD
Variable Integer PSTA  # status of matching 0 : OK, 1 : already matched, 2 : import/statement not found, 3 : various
Variable Clbfile PMSG  # Message corresponding to status
Value Integer PLOG     # Write detailed log? 1 = yes, 0 = no

PSTA = 0
Gosub INIT

If PLOG
    If FLGTRACE : Call OUVRE_TRACE(mess(192,7703,1)) From LECFIC : Endif           # Open trace file.
    Call ECR_TRACE (func AFNC.MES1(mess(85,7703,1),PSTMCOD)+"/"+num$(PLIN),0) From GESECRAN
Endif

Read [F:BSIIMP]BSIIMP0 = PSTMCOD  # read statement (import header)
If !fstat
  Read [F:BSIIMPD]BSIIMPD0 = PSTMCOD;PLIN # read transaction PLIN of statement
  If !fstat
    If [F:BSIIMPD]FLGCRE>=2 | left$([F:BSIIMPD]LET,1) ="A"
      PSTA = 1
      PMSG = PSTMCOD - mess(9,7703,1) # "Statement already matched or payment created"
    Else
      Read [F:BSIIP]BSIIP0 = [F:BSIIMP]CODIMPPAR
      If !fstat
        If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(86,7703,1),[F:BSIIMP]CODIMPPAR),0) From GESECRAN Endif
        # ...
        If [F:BSIIMPD]SNS="RD" or [F:BSIIMPD]SNS="RC"
          Gosub RESET_BSIIMPD

          [F:BSIIMPD]LET = "C"

          If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(87,7703,1),[F:BSIIMPD]SNS),-1) From GESECRAN : Endif

          # update record in table BSIIMPD
          Rewrite [F:BSIIMPD]
        Else # ...
          Filter [F:BSIIMPS] Where STMCOD = PSTMCOD and TRSLIN = PLIN     # check if subdetails exist
          NUMIMPS = rowcount([F:BSIIMPS])
          If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(197,7703,1),num$(NUMIMPS)),0) From GESECRAN Endif

          If [F:BSIIMPD]SNS="C"
             SIGN = 1
             If PLOG : Call ECR_TRACE (mess(88,7703,1),0) From GESECRAN : Endif
          Else #  D
             SIGN = -1
             If PLOG : Call ECR_TRACE (mess(89,7703,1),0) From GESECRAN : Endif
          Endif

          Raz INVNUM, VBPRPAY, VBANKID, VACCNO, VBIDNUM, S, S1, BPY00, BPY01, BPY02, BPY03, INV00, INV01, INV02, INV03

          Call LEC_CPY( [F:BSIIMPD]CPY ) From CPTLEC # read company of import

          If [F:BSIIP]MRGDESFLD = 2 or [F:BSIIP]MRGDESFLD = 3   # merge description field "always" or "second pass"
            Gosub BUILD_ALLREFLIN                               # create concatenated string of reference lines
            If [F:BSIIP]MRGDESFLD = 2
                If PLOG : Call ECR_TRACE (mess(90,7703,1),0) From GESECRAN : Endif
            Else
                If PLOG : Call ECR_TRACE (mess(91,7703,1),0) From GESECRAN : Endif
            Endif
          Else
            If PLOG : Call ECR_TRACE (mess(92,7703,1),0) From GESECRAN : Endif
          Endif

          # initial step: matching by search term list if parameter "Use search term list" is set to "First pass"
          If PLOG
              Call ECR_TRACE ("#########################################################################################",0) From GESECRAN
              Call ECR_TRACE (mess(93,7703,1),0) From GESECRAN
          Endif
          If [F:BSIIP]USESEALIS = 2 Then  # parameter "Use search term list" set to "First pass"?
              If PLOG : Call ECR_TRACE (mess(94,7703,1),0) From GESECRAN : Endif
              Gosub MATCH_SEARCH_TERM_LIST From BSILIBMTCSEA
              If SEALIS_FOUND : Goto ENDMATCHING : Endif           # if search term list hit > end
          Else
              If PLOG : Call ECR_TRACE (mess(96,7703,1),0) From GESECRAN : Endif
          Endif
# 2016-11-11 Bader X3-1501 search term list implementation end

          # first step: matching by ISR reference number
          If PLOG
              Call ECR_TRACE ("#########################################################################################",0) From GESECRAN
              Call ECR_TRACE (mess(211,7703,1),0) From GESECRAN
          Endif
          Gosub MATCH_ISR_QR_REFNUM

          # second step: matching by bank ID
          If PLOG
              Call ECR_TRACE ("#########################################################################################",0) From GESECRAN
              Call ECR_TRACE (mess(97,7703,1),0) From GESECRAN
          Endif
          Gosub MATCH_BID

          # third step: matching by BP name
          If PLOG
              Call ECR_TRACE ("#########################################################################################",0) From GESECRAN
              Call ECR_TRACE (mess(98,7703,1),0) From GESECRAN
          Endif
          Gosub MATCH_BP_NAME

          # fourth step: matching by invoice number
          If PLOG
              Call ECR_TRACE ("#########################################################################################",0) From GESECRAN
              Call ECR_TRACE (mess(99,7703,1),0) From GESECRAN
          Endif
          Gosub MATCH_INV_NUMBER

          # fifth step: matching by BP number
          If PLOG
              Call ECR_TRACE ("#########################################################################################",0) From GESECRAN
              Call ECR_TRACE (mess(100,7703,1),0) From GESECRAN
          Endif
          Gosub MATCH_BP_NUMBER

          # sixth step: matching by original document
          If PLOG
              Call ECR_TRACE ("#########################################################################################",0) From GESECRAN
              Call ECR_TRACE (mess(101,7703,1),0) From GESECRAN
          Endif
          Gosub MATCH_ORIG_DOC

          # seventh step: matching by order number
          If PLOG
              Call ECR_TRACE ("#########################################################################################",0) From GESECRAN
              Call ECR_TRACE (mess(102,7703,1),0) From GESECRAN
          Endif
          Gosub MATCH_ORDER_NUMBER

          # eightth step: find open items and write them into table BSIDUD
          If PLOG
              Call ECR_TRACE ("#########################################################################################",0) From GESECRAN
              Call ECR_TRACE (mess(103,7703,1),0) From GESECRAN
          Endif
          [L]LCURLEG = [V]GCURLEG                # remember value of global LEG variable
          [V]GCURLEG = [F:BSIIP]LEG
          Gosub FIND_OPEN_ITEMS
          [V]GCURLEG = [L]LCURLEG                # restore value of global LEG variable
        Endif
      Else
         PSTA = 2
         PMSG = [F:BSIIMP]CODIMPPAR - mess(6,7703,1) # "Import settings not found"
      Endif
    Endif
  Else
     PSTA = 2
     PMSG = PSTMCOD + "~" + num$(PLIN) - mess(7,7703,1) # 'Transaction does not exist'
  Endif
Else
   PSTA = 2
   PMSG = PSTMCOD - mess(1,7703,1) # 'Statement does not exist'
Endif

$ENDMATCHING
If PLOG
    If PSTA : Call ECR_TRACE (PMSG,1) From GESECRAN : Endif
    # Close and show trace file.
    If !FLGTRACE
        Call ECR_TRACE ("#########################################################################################",0) From GESECRAN
        Call ECR_TRACE ("#########################################################################################",0) From GESECRAN
    Else
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
Endif
End


############################################################################################
$INIT
If !clalev ([F:BSIIMP])   : Local File BSIIMP      [BSIIMP]  : Endif # header import
If !clalev ([F:BSIIMPD])  : Local File BSIIMPD     [BSIIMPD] : Endif # details import
If !clalev ([F:BSIIMPS])  : Local File BSIIMPDS    [BSIIMPS] : Endif # subdetails import
If !clalev ([F:BSIIP])    : Local File BSIIMPPAR   [BSIIP]   : Endif # import parameters
If !clalev ([F:BSISEA])   : Local File BSISEAEXD   [BSISEA]  : Endif # excluded search terms
If !clalev ([F:BSIIND])   : Local File BSIINVDIO   [BSIIND]  : Endif # header invoice number definition
If !clalev ([F:BSIINDD])  : Local File BSIINVDIOD  [BSIINDD] : Endif # details invoice number definition
If !clalev ([F:BSIDUD])   : Local File BSIDUD      [BSIDUD]  : Endif # Open items for one transaction
If !clalev ([F:BSIBPN])   : Local File BSIBPRNUM   [BSIBPN]  : Endif # BP number definition
If !clalev ([F:BSIBPND])  : Local File BSIBPRNUMD  [BSIBPND] : Endif # BP number definition details
If !clalev ([F:TCY])      : Local File TABCOUNTRY  [TCY]     : Endif # country table
If !clalev ([F:TPY])      : Local File TABPAYTYP   [TPY]     : Endif
If !clalev ([F:CPY])      : Local File COMPANY     [CPY]     : Endif
If !clalev ([F:HAE])      : Local File GACCENTRY   [HAE]     : Endif
If !clalev ([F:DUD])      : Local File GACCDUDATE  [DUD]     : Endif
If !clalev ([F:SIH])      : Local File SINVOICE    [SIH]     : Endif
If !clalev ([F:PIH])      : Local File PINVOICE    [PIH]     : Endif
If GACTX.AFOLD.AMODULE(5) = [V]CST_AYES # 2017-12-21 DNE X3-68766 BEGIN
    If !clalev ([F:SOH])      : Local File SORDER      [SOH]     : Endif
Endif
If GACTX.AFOLD.AMODULE(6) = [V]CST_AYES
    If !clalev ([F:POH])      : Local File PORDER      [POH]     : Endif
Endif # 2017-12-21 DNE X3-68766 END
If !clalev ([F:TCU])      : Local File TABCUR      [TCU]     : Endif
If !clalev ([F:BID])      : Local File BID         [BID]     : Endif
If !clalev ([F:BPR])      : Local File BPARTNER    [BPR]     : Endif
If !clalev ([F:BPC])      : Local File BPCUSTOMER  [BPC]     : Endif
If !clalev ([F:BPS])      : Local File BPSUPPLIER  [BPS]     : Endif
If !clalev ([F:BAN])      : Local File BANK        [BAN]     : Endif

# 2018-07-20 X3-96233 Bader begin
If !clalev ([F:SWIQRC])   : Local File SWIQRC      [SWIQRC]  : Endif
# 2018-07-20 X3-96233 Bader end

Local Char LCURLEG(GLONADI)
Local Integer MAXBPY : MAXBPY = 200
Local Integer MAXINV : MAXINV = 200
Local Char VACCNO(GLONBID), VBANKID(GLONBID), VBIDNUM(GLONBID)
Local Integer OKAMT, OKREAD
Local Char BPY00(30)(MAXBPY)    # array of business partners for payment
Local Char BPY01(1) (MAXBPY)    # array of flags "BID found"
Local Char BPY02(1) (MAXBPY)    # array of flags "BP name found"
Local Char BPY03(1) (MAXBPY)    # array of flags "invoice number found"
Local Char BPY04(1) (MAXBPY)    # array of flags "BP number found"
Local Char INV00(50) (MAXINV)   # array of invoice numbers
Local Char INV01(50) (MAXINV)   # array of business partners for payment
Local Char INV02(4) (MAXINV)    # Flag: char 1: invoice, char 2: orig. doc., char 3: order, char 4: ISR ref.
Local Decimal INV03 (MAXINV)    # array of amounts corresponding to invoice numbers
Local Char VBPRPAY(GLONBPR)     # business partner
Local Integer FLGBPY            # which array BPY0* to handle
Local Char CRITERE(250), CRITERE2(250), CRITERE3(250), CRIT_BPC(250), CRIT_BPS(250), CRIT_BPR(250)
Local Integer S, S1, S_OLD, S1_OLD         # count of found BPs / invoices
Local Clbfile ALLREFLIN(5), ALLREFLIN1(5)  # all concatenated reference lines
Local Char INVNUM(40)
Local Char PREFIX(10), SEARCHSTR(15), SEARCHSTR2(20)
Local Integer FLGNUM            # Flag indicates whether we are in search of 1=invoice, 2=original document, 3=order number
Local Integer FBPR, FINVNUM, FBIDNUM, FBPRNAM, FSOHNUM, FSRCDOC, FBVRREF, FAMT, FREFLST  # Flags indicate if corresponding type was found
Local Decimal LDEPAMTCUR        # discount in OI currency
Local Decimal LDEPAMTTRS        # discount in transaction currency
Local Decimal SUMDEPAMTTRS      # discount in transaction currency for total transaction amount
Local Integer SIGN              # debit (-1) or credit (1)
Local Char CURTRS(GLONCUR)      # Transaction currency
Local Char CURCPY(GLONCUR)      # Company currency.
Local Integer RATTYP            # Rate type (local menu 202)
Local Date DATRAT               # Value date for payment generation/posting
Local Integer ERRCUR            # Error status from currency conversion
Local Integer CHECK_CUR         # 1: Statement currency differs from OI currency, 0: OI and statement in same currency
# 2016-11-11 Bader X3-1501 search term list implementation
Local Integer SEALIS_FOUND      # indicates that we have a search term list hit
# 2016-11-11 Bader X3-1501 search term list implementation end
Local Integer FLGTRACE : If GTRACE = "" : FLGTRACE = 1 : Else : FLGTRACE = 0 : Endif # Check for an existing log file (FLGTRACE = 1, 0 otherwise).
Local Integer NUMIMPS           # counts the number of subdetails found
Local Char TMPSTR(255)
Local Integer IS_CUR            # indicates wheather an open item in currency different from transaction currency was found
Return


############################################################################################
$BUILD_ALLREFLIN
Raz ALLREFLIN

Gosub BUILD_ALLREFLIN1
ALLREFLIN = ALLREFLIN1

For I=0 To dim([F:BSIIMPD]BPRREF)-1
   If [F:BSIIMPD]BPRREF(I)<>""
      ALLREFLIN = ALLREFLIN + vireblc([F:BSIIMPD]BPRREF(I),2)
   Endif
Next
ALLREFLIN = toupper(ALLREFLIN)
Return


############################################################################################
$BUILD_ALLREFLIN1
Raz ALLREFLIN1

For I=0 To dim([F:BSIIMPD]FREREF)-1
   If [F:BSIIMPD]FREREF(I)<>""
      ALLREFLIN1 = ALLREFLIN1+vireblc([F:BSIIMPD]FREREF(I),4)
   Endif
Next
ALLREFLIN1 = toupper(ALLREFLIN1)
Return


############################################################################################
$GET_BIDNUM
Raz VBIDNUM, VACCNO, VBANKID
VBANKID = vireblc([F:BSIIMPD]BPRREF(0),2)  # [F:BSIIMPD]BPRREF(0) holds either BankID or BIC
VACCNO  = vireblc([F:BSIIMPD]BPRREF(1),2)  # [F:BSIIMPD]BPRREF(1) holds either AccountNo or IBAN
Return


############################################################################################
$READ_TCY
Local Char LCRY(GLONCRY)
Local Integer TCYFOUND
Raz VBIDNUM
LCRY = left$(VACCNO,2)                    # get first 2 chars > country code
Filter [F:TCY] Where ISO = LCRY           # try to read country, LEC_TCY cannot be used because it reads by PAYS instead of ISO
Read [F:TCY] First
TCYFOUND = !fstat
Return


############################################################################################
$EXTRACT_VBIDNUM
If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(108,7703,1),VACCNO),0) From GESECRAN : Endif
If [F:TCY]FLIBAN = 2                   # IBAN management?
  VBIDNUM = right$(VACCNO,5)
Else
  If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(109,7703,1),LCRY),-1) From GESECRAN : Endif
Endif
Return


############################################################################################
$SEARCH_IN_BID
  If VBIDNUM <> ""                         # VBIDNUM could be created
    # loop over all records in BID with VBIDNUM and store BP in array
    Filter [F:BID] Where BPATYP = 1 and BIDNUM = VBIDNUM
    For [F:BID]
      [L]VBPRPAY = [F:BID]BPANUM
      FLGBPY = 1
      Gosub SETFLAG_IN_BPY
    Next
    Filter [F:BID]
  Endif
Return

############################################################################################
$FIND_ALL_BID
If len(VACCNO) > 2                         # VACCNO might hold an IBAN if length > 2
  Gosub READ_TCY                           # try to read country
  If !TCYFOUND                             # not found > not an IBAN
    Filter [F:TCY]
    LCRY = mid$(VBANKID,5,2)               # check if VBANKID is a BIC with CRY at position 5 and 6
    Filter [F:TCY] Where ISO = LCRY        # try to read country
    Read [F:TCY] First
    If !fstat                              # found > VBANKID = BIC > VACCNO holds BIDNUM
      If PLOG : Call ECR_TRACE (func AFNC.MES2(mess(104,7703,1),VBANKID,VACCNO),0) From GESECRAN : Endif
      VBIDNUM = VACCNO
    Else                                   # not found > not a BIC > create VBIDNUM from VBANKID and VACCNO if country of company = DE/AT
      If !fstat and ([F:CPY]CRY = "DE" or [F:CPY]CRY = "AT") # company found and country = "DE" or "AT"
        If PLOG : Call ECR_TRACE (mess(105,7703,1)-"("+VBANKID+"/"+VACCNO+")",0) From GESECRAN : Endif
        Local Integer TEMP
        TEMP=val(VBANKID)                  # transform string to number
        If [F:CPY]CRY = "DE"
          VBANKID = format$("N0:8#",TEMP)  # add leading zeros
        Elsif [F:CPY]CRY = "AT"
          VBANKID = format$("N0:5#",TEMP)  # add leading zeros
        Endif
        TEMP=val(VACCNO)                   # transform string to number
        If [F:CPY]CRY = "DE"
          VACCNO  = format$("N0:10#",TEMP) # add leading zeros
        Elsif [F:CPY]CRY = "AT"
          VACCNO  = format$("N0:11#",TEMP) # add leading zeros
        Endif
        VBIDNUM = VBANKID+VACCNO
      Else
        If PLOG
            Call ECR_TRACE (mess(106,7703,1),0) From GESECRAN
            Call ECR_TRACE (mess(107,7703,1),0) From GESECRAN
        Endif
      Endif
    Endif
  Else                                     # country found > extract VBIDNUM from VACCNO (=IBAN)
    Gosub EXTRACT_VBIDNUM
  Endif
  Filter [F:TCY]

  Gosub SEARCH_IN_BID
Endif
Return


############################################################################################
$FIND_ALL_BID_IMPS
Local Integer INDEX
For [F:BSIIMPS]                             # loop over all subdetail records
  For INDEX = 0 To dim([F:BSIIMPS]ACCREF)-1 # loop over all 3 IBAN fields
    VACCNO = [F:BSIIMPS]ACCREF(INDEX)       # get IBAN
    If len(VACCNO) > 2                      # VACCNO might hold an IBAN if length > 2
        Gosub READ_TCY                      # try to read country
        If TCYFOUND                         # found > might be an IBAN
          Gosub EXTRACT_VBIDNUM
          Gosub SEARCH_IN_BID
        Endif
        Filter [F:TCY]
    Endif
  Next
Next
Return


############################################################################################
$SETFLAG_IN_BPY
Local Integer FLGFIND, L
FLGFIND = 0

For L=0 To S-1                    # try to find business partner in BPY00 array and set flag corresponding to FLGBPY
   If BPY00(L) = VBPRPAY
      FLGFIND = 1
      Case FLGBPY
         When 1 # BIDNUM
            If  BPY01(L)<>"1" : BPY01(L) ="1" : Endif
         When 2 # BPR name
            If  BPY02(L)<>"1" : BPY02(L) ="1" : Endif
         When 3 # invoice number
            If  BPY03(L)<>"1" : BPY03(L) ="1" : Endif
         When 4 # BP number
            If  BPY04(L)<>"1" : BPY04(L) ="1" : Endif
      Endcase
      Break
   Endif
Next
If FLGFIND = 0                       # business partner not found > create new entry in array
   If S = [L]MAXBPY-1                # max. numer of array entries reached > Return
      If PLOG
          Call ECR_TRACE (func AFNC.MES1(mess(110,7703,1),num$([L]MAXBPY)),-1) From GESECRAN
          Call ECR_TRACE (func AFNC.MES1(mess(111,7703,1),VBPRPAY),-1) From GESECRAN
      Endif
      Return
   Endif  # max. numer of array entries reached > Return
   BPY00(S) = VBPRPAY
   If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(112,7703,1),VBPRPAY),0) From GESECRAN : Endif
   Case FLGBPY
      When 1 # BIDNUM
        BPY01(S) ="1"
      When 2 # BPR name
        BPY02(S) ="1"
      When 3 # invoice number
        BPY03(S) ="1"
      When 4 # BP number
        BPY04(S) ="1"
   Endcase
   S +=1
Endif
Return



############################################################################################
$BUILD_BP_CRITERIA
CRIT_BPC = "1=1" : CRIT_BPS= "1=1" : CRIT_BPR= "1=1"
If [F:BSIIP]ALLTYP = 1                # "all types of business partners" = "no"
   Case [F:BSIIP]BPRTYP
      When 1 # customers
         If [F:BSIIP]ALLCAT = 1       # "all categories" = "no"
            If [F:BSIIP]CATBPC <> ""
               CRIT_BPC -= "& BCGCOD=[F:BSIIP]CATBPC "
            Endif
         Endif
         If [F:BSIIP]ALLBPR = 1       # "all BPs" = "no"
            If [F:BSIIP]BPRSTR <> "" and [F:BSIIP]BPREND <> ""
               CRIT_BPC -= "& BPCNUM >= [F:BSIIP]BPRSTR and BPCNUM <= [F:BSIIP]BPREND"
            Elsif [F:BSIIP]BPRSTR = "" and [F:BSIIP]BPREND <> ""
               CRIT_BPC -= "& BPCNUM <= [F:BSIIP]BPREND "
            Elsif [F:BSIIP]BPRSTR <> "" and [F:BSIIP]BPREND = ""
               CRIT_BPC -= "& BPCNUM >= [F:BSIIP]BPRSTR "
            Endif
         Endif
      When 2 # suppliers
         If [F:BSIIP]ALLCAT = 1       # "all categories" = "no"
            If [F:BSIIP]CATBPS <> ""
               CRIT_BPS -= "& BSGCOD=[F:BSIIP]CATBPS "
            Endif
         Endif
         If [F:BSIIP]ALLBPR = 1       # "all BPs" = "no"
            If [F:BSIIP]BPRSTR<>"" and [F:BSIIP]BPREND<>""
               CRIT_BPS -= "& BPSNUM >= [F:BSIIP]BPRSTR and BPSNUM <= [F:BSIIP]BPREND"
            Elsif [F:BSIIP]BPRSTR="" and [F:BSIIP]BPREND<>""
               CRIT_BPS -= "& BPSNUM <= [F:BSIIP]BPREND "
            Elsif [F:BSIIP]BPRSTR<>"" and [F:BSIIP]BPREND=""
               CRIT_BPS -= "& BPSNUM >= [F:BSIIP]BPRSTR "
            Endif
         Endif
    Endcase
Else                                  # "all types of business partners" = "yes"
    If [F:BSIIP]ALLBPR = 1            # "all BPs" = "no"
       If [F:BSIIP]BPRSTR<>"" and [F:BSIIP]BPREND<>""
          CRIT_BPR -= "& BPRNUM >= [F:BSIIP]BPRSTR and BPCNUM <= [F:BSIIP]BPREND"
       Elsif [F:BSIIP]BPRSTR="" and [F:BSIIP]BPREND<>""
          CRIT_BPR -= "& BPRNUM <= [F:BSIIP]BPREND "
       Elsif [F:BSIIP]BPRSTR<>"" and [F:BSIIP]BPREND=""
          CRIT_BPR -= "& BPRNUM >= [F:BSIIP]BPRSTR "
       Endif
    Endif
Endif                                 # "all types of business partners"
Return


#########################################################################
Subprog CNT_BPRNAME(PBPRREF, PBPRNAM01, PCNT)
Value Char PBPRREF          # BP name from import file ?32
Value Char PBPRNAM01        # BP name1 and name 2 of business partner table
Variable Integer PCNT       # returns the number of hits of PBPRREF substrings in PBPRNAM01

Local Integer POS, B
Local Char    SSTRING(250)
Raz PCNT
POS = 1

B = instr(POS,PBPRREF,chr$(32))                # find first blank
While B > 0
  SSTRING = vireblc(mid$(PBPRREF,POS,B-POS),4) # remove all blanks
  If SSTRING = " "
     Goto TONEXT
  Endif

  If len(SSTRING) < [F:BSIIP]SEAEXDLEN         # check if length of substring is smaller than configured
     Goto TONEXT                               # if yes, ignore substring for search
  Endif

  If [F:BSIIP]SEAEXD = 2                       # check parameter "use excluded search term list"
    Read [F:BSISEA]BSISEA0 = SSTRING           # check if substring is in list of strings to ignore
    If !fstat
       Goto TONEXT                             # if yes, ignore substring for search
    Endif
  Endif

  If pat(PBPRNAM01,"*" + SSTRING + "*")        # check if substring is contained in BP.name1 or BP.name2
     PCNT += 1                                 # if yes, increase counter
  Endif

  $TONEXT
  POS = B+1
  B = instr(POS,PBPRREF,chr$(32))
Wend
End


############################################################################################
$HANDLE_ONE_BPRNAM
Raz CNT
Read [F:BPR]BPR0 = LBPRNUM
LBPRNAME01 = toupper([F:BPR]BPRNAM(0) + [F:BPR]BPRNAM(1))
If pat(LBPRNAME01,LBPRREF1)
    CNT = 10
Else
    Call CNT_BPRNAME(LBPRREF, LBPRNAME01, CNT) # count number of substring hits for business partner
Endif
If CNT <> 0
    LBPR(NUMBPRCNT) = LBPRNUM                  # add business partner to array LBPR
    LCNTBPR(NUMBPRCNT) = CNT                   # add CNT of business partner to array LCNTBPR
    NUMBPRCNT += 1                             # increase counter of business partners
Endif
Return


############################################################################################
$HANDLE_BPRNAM
If [F:BSIIMPD]BPRREF(2)="" & [F:BSIIMPD]BPRREF(3)="" : Return : Endif     # BP name1 and BP name2 empty

Gosub BUILD_BP_CRITERIA
If [F:BSIIMPD]BPRREF(2) <> ""                                             # BP name1 in file
   LBPRREF = vireblc(toupper([F:BSIIMPD]BPRREF(2)),2)
   If [F:BSIIMPD]BPRREF(3) <> ""                                          # BP name2 in file
      LBPRREF = LBPRREF+" "+ vireblc(toupper([F:BSIIMPD]BPRREF(3)),2)+" " # concatenation of name1 and name2, separated by a blank
   Else
      LBPRREF = LBPRREF+" "
   Endif
Endif
If LBPRREF = "" : Return  : Endif

Gosub SEARCH_BP
Gosub GET_BEST_FITTING_BPS  # sort arrays LCNTBPR, LBPR in descending order and find out the 3 BPs with the biggest values for CNT
Return



############################################################################################
$GET_BEST_FITTING_BPS
# sort arrays LCNTBPR, LBPR in descending order and find out the 3 BPs with the biggest values for CNT
If NUMBPRCNT > 0
    Sorta LCNTBPR, LBPR Desc    # sort both arrays in descending order
    If NUMBPRCNT < 3
       ZZ = NUMBPRCNT
    Else
       ZZ = 3
    Endif

    For P=0 To ZZ-1             # add 3 BPs with biggest counts to BPY-array
       VBPRPAY = LBPR(P)
       FLGBPY = 2
       Gosub SETFLAG_IN_BPY
    Next
Endif
Return


############################################################################################
$SEARCH_BP
For I=1 To len(LBPRREF)                  # create LBPRREF1 by replacing blanks in LBPRREF with "*"
  LCHR =mid$(LBPRREF,I,1)
  If LCHR=chr$(32)
     LCHR = "*"
  Endif
  LBPRREF1 = LBPRREF1+LCHR
Next
LBPRREF1 = "*"+toupper(LBPRREF1)+"*"

If CRIT_BPC <> "1=1"                     # Customer?
  Filter [F:BPC] Where evalue(CRIT_BPC)
  For [F:BPC]
    LBPRNUM = [F:BPC]BPCNUM
    Gosub HANDLE_ONE_BPRNAM
    If NUMBPRCNT >= 5000 Break Endif
  Next
Elsif CRIT_BPS <> "1=1"                  # Supplier?
  Filter [F:BPS] Where evalue(CRIT_BPS)
  For [F:BPS]
    LBPRNUM = [F:BPS]BPSNUM
    Gosub HANDLE_ONE_BPRNAM
    If NUMBPRCNT >= 5000 Break Endif
  Next
Else
  Filter [F:BPR] Where evalue(CRIT_BPR)
  For [F:BPR]
    LBPRNUM = [F:BPR]BPRNUM
    Gosub HANDLE_ONE_BPRNAM
    If NUMBPRCNT >= 5000 Break Endif
  Next
Endif
Return



############################################################################################
$HANDLE_BPRNAM_IMPS
Gosub BUILD_BP_CRITERIA

For [F:BSIIMPS]                            # loop over all subdetail records
    If [F:BSIIMPS]BPRREFS(0)="" & [F:BSIIMPS]BPRREFS(1)="" & [F:BSIIMPS]BPRREFS(2)="" & [F:BSIIMPS]BPRREFS(3)="" &
&    [F:BSIIMPS]BPRREFS(4)=""               # All BP names empty?
        Goto NEXT_IMPS                     # yes > nothing to do for this subdetail
    Endif

    For ZZ = 0 To dim([F:BSIIMPS]BPRREFS)-1 # Loop over all 5 BPRREF fields
        Raz LBPRREF, LBPRREF1
        If [F:BSIIMPS]BPRREFS(ZZ) <> ""     # BPRREF(ZZ) has a value
           LBPRREF = vireblc(toupper([F:BSIIMPS]BPRREFS(ZZ)),2)
           Gosub SEARCH_BP
        Endif
    Next
$NEXT_IMPS
Next

Gosub GET_BEST_FITTING_BPS  # sort arrays LCNTBPR, LBPR in descending order and find out the 3 BPs with the biggest values for CNT
Return



############################################################################################
$SET_INV02
Case FLGNUM
   When 1                                # invoice number
      INV02(INV02POS) = "1"+right$( INV02(INV02POS),2)
   When 2                                # original document
      INV02(INV02POS) = left$(INV02(INV02POS),1)+"1"+mid$(INV02(INV02POS),3,2)
   When 3                                # order number
      INV02(INV02POS) = left$(INV02(INV02POS),2)+"1"+mid$(INV02(INV02POS),4,1)
   When 4                                # order number
      INV02(INV02POS) = left$(INV02(INV02POS),3)+"1"
   When Default
Endcase
Return


############################################################################################
$SET_INV_ARR
If PLOG
    If NUMIMPS = 0                  # MT940, CSV
        Call ECR_TRACE (func AFNC.MES1(mess(113,7703,1),[F:DUD]NUM),0) From GESECRAN
    Else                            # CAMT
        Call ECR_TRACE (func AFNC.MES1(mess(113,7703,1),[F:DUD]NUM+"("+num$([F:BSIIMPS]AMTCURS)+")"),0) From GESECRAN
    Endif
Endif
INV00(S1) = [F:DUD]NUM
INV01(S1) = [F:DUD]BPRPAY
If NUMIMPS > 0                      # CAMT > store amount for later check in INV03 array
    INV03(S1) = [F:BSIIMPS]AMTCURS
Endif
INV02POS = S1
Gosub SET_INV02
S1 +=1
Return


############################################################################################
$SETFLAG_IN_INVARR
Local Integer FLGFIND, INV02POS
FLGFIND = 0

If [F:BSIINDD]PFXTYP=2                    # source document number
   For [F:HAE] Where BPRVCR = [L]INVNUM   # TODO: check if index needed
      [L]INVNUM = [HAE]NUM
      Break
   Next
Endif
For L=0 To S1-1
   If INV00(L)= [L]INVNUM
      FLGFIND = 1
      INV02POS = L
      Gosub SET_INV02
      Break
   Endif
Next
If FLGFIND = 0                            # not found > search for num in GACCDUDATE
   For [F:DUD] Where NUM = [L]INVNUM and DUDSTA = 2
     If ([F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR) <> 0
        If S1 = MAXINV-1              # no more free space in INVARR
           Break
           If PLOG
               Call ECR_TRACE (func AFNC.MES1(mess(114,7703,1),num$([L]MAXINV)),-1) From GESECRAN
               Call ECR_TRACE (func AFNC.MES1(mess(115,7703,1),[L]INVNUM),-1) From GESECRAN
           Endif
        Endif  # max. numer of array entries reached > Return
        Gosub SET_INV_ARR
        If ([DUD]AMTCUR-[DUD]PAYCUR-[DUD]TMPCUR) <> [F:BSIIMPD]AMTCUR
           VBPRPAY = [F:DUD]BPRPAY
           FLGBPY = 3
           Gosub SETFLAG_IN_BPY
        Endif
        Break
     Endif
   Next
Endif
Return


############################################################################################
$HANDLE_NUMERIC_INV
Local Integer TMPCHAR, J
Raz [L]INVNUM

For J=1 To len (ALLREFTMP)                          # loop over all characters of concatenated reference line and check all numerical sequences
   TMPCHAR = ascii(mid$( ALLREFTMP,J,1))
   If TMPCHAR>=48 and TMPCHAR<=57 Then              # check if character is numeric (0-9)
      [L]INVNUM = [L]INVNUM + mid$( ALLREFTMP,J,1)  # if yes > take it
   Else                                             # no more numerical character found
      If len([L]INVNUM)>= [F:BSIINDD]LENINVSTR & len([L]INVNUM)<= [F:BSIINDD]LENINVEND  # check if len in length range for invoice number
         Gosub SETFLAG_IN_INVARR                    # if yes, check if invoice number exists
         Raz [L]INVNUM
      Else
        Raz [L]INVNUM
      Endif
   Endif
Next
Return


############################################################################################
$GET_MINMAX_LEN
If [F:BSIINDD]LENINVSTR < len(PREFIX)
   LEN_MIN=len(PREFIX)
Else
   LEN_MIN=[F:BSIINDD]LENINVSTR
Endif
If [F:BSIINDD]LENINVEND=0
   LEN_MAX=len(ALLREFTMP)
Else
   LEN_MAX=[F:BSIINDD]LENINVEND
Endif
INVNUM = mid$(ALLREFTMP,IND,LEN_MAX)
Return



############################################################################################
$FIND_ONE_INVOICE
If SIGN = 1
   Read [SIH]SIH0 = [L]INVNUM
   [L]MYCPY = [F:SIH]CPY
   VBPRPAY = [F:SIH]BPRPAY
Else
   Read [PIH]PIH0 = [L]INVNUM
   [L]MYCPY = [F:PIH]CPY
   VBPRPAY = [F:PIH]BPRPAY
Endif
If fstat                                     # no invoice found
   If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(117,7703,1),[L]INVNUM),0) From GESECRAN : Endif
   Return
Endif
If [F:BSIIMP]CPY = [L]MYCPY
   FLGBPY = 3
   Gosub SETFLAG_IN_INVARR
   OKREAD   = 1
Else
   If PLOG : Call ECR_TRACE (func AFNC.MES2(mess(116,7703,1),[L]INVNUM,[L]MYCPY),0) From GESECRAN : Endif
Endif
Return



############################################################################################
$FIND_ONE_ORG_INVOICE
If SIGN = 1
   For [F:SIH] Where BPRVCR = [L]INVNUM
      [L]MYCPY = [F:SIH]CPY
      Break
   Next
Else
   For [F:PIH] Where BPRVCR = [L]INVNUM
      [L]MYCPY = [F:PIH]CPY
      Break
   Next
Endif
If !fstat & [F:BSIIMP]CPY = [L]MYCPY
   FLGBPY = 3
   Gosub SETFLAG_IN_INVARR
   OKREAD   = 1
Else
   If PLOG
      If SIGN = 1
          Call ECR_TRACE (func AFNC.MES2(mess(116,7703,1),[L]INVNUM,[L]MYCPY),0) From GESECRAN
      Else
          Call ECR_TRACE (func AFNC.MES2(mess(117,7703,1),[L]INVNUM,[L]MYCPY),0) From GESECRAN
      Endif
   Endif
Endif
Return



############################################################################################
$FIND_INVOICE
Local Integer N, IND, LEN_MIN, LEN_MAX
Local Char MYCPY(GLONCPY)

# get length of an invoice number
OKREAD = 0
N = 1 : IND = 1
PREFIX = toupper(PREFIX)
While IND > 0
  OKREAD = 0
  IND = instr(N,ALLREFTMP,PREFIX)
  If IND <> 0
     Gosub GET_MINMAX_LEN
     If [F:BSIINDD]PFXTYP = 1         # document number > search for invoice number
       Gosub FIND_ONE_INVOICE
       If OKREAD = 0 # if not found > decrement length step by step and try again until found or min. length reached
           For M=LEN_MAX - 1 To [L]LEN_MIN Step -1
              If OKREAD = 1 Break Endif
              [L]INVNUM = mid$(ALLREFTMP,IND,M)
              Gosub FIND_ONE_INVOICE
           Next
       Endif
     Else                             # source document number > search for original number
       Raz VBPRPAY
       Gosub FIND_ONE_ORG_INVOICE
       If OKREAD = 0 # if not found > decrement length step by step and try again until found or min. length reached
           Raz VBPRPAY
           For M=LEN_MAX To [L]LEN_MIN Step -1
              If OKREAD = 1 Break Endif
              [L]INVNUM = mid$(ALLREFTMP,IND,M)
              Gosub FIND_ONE_ORG_INVOICE
           Next
       Endif
     Endif

     If OKREAD = 1
        N = IND + len(INVNUM)
     Else
        N = IND + len(PREFIX)
     Endif
  Endif
Wend
Return


############################################################################################
$SEARCH_SINV
Local Char SUBNUM(GLONVCR+2)
If [F:BSIINDD]OPT=2                           # n last characters
    Filter [F:SIH] Where pat([F:SIH]NUM,SEARCHSTR)>0
    For [F:SIH]
       SUBNUM = right$([F:SIH]NUM,len([F:SIH]NUM)-[F:BSIINDD]LNG+1)
       SUBNUM="*"+SUBNUM+"*"
       If pat(ALLREFTMP,SUBNUM)
          [L]INVNUM  = [F:SIH]NUM
          [L]VBPRPAY = [F:SIH]BPRPAY
          FLGBPY = 3
          Gosub SETFLAG_IN_INVARR
       Endif
    Next
    Filter [F:SIH]
Endif
Return


############################################################################################
$HANDLE_INVOICE_COMMON
Raz INVNUM
Case [F:BSIINDD]DIR                # search direction
  When 1                          # Sage X3
    If [L]PREFIX = "" & [F:BSIIND]INVALLNUM =2   # invoice number always numeric?
       If PLOG : Call ECR_TRACE (mess(118,7703,1),0) From GESECRAN : Endif
       Gosub HANDLE_NUMERIC_INV
    Elsif [L]PREFIX <> ""
      TMPSTR = ALLREFTMP          # otherwise the Clob ALLREFTMP is truncated in LOG
      If pat(ALLREFTMP,SEARCHSTR) # check if prefix found
         If PLOG : Call ECR_TRACE (func AFNC.MES2(mess(119,7703,1),PREFIX,TMPSTR),0) From GESECRAN : Endif
         Gosub FIND_INVOICE       # if yes, try to find invoice in database
      Else
         If PLOG : Call ECR_TRACE (func AFNC.MES2(mess(120,7703,1),PREFIX,TMPSTR),0) From GESECRAN : Endif
      Endif
    Else
        If PLOG : Call ECR_TRACE (mess(121,7703,1),0) From GESECRAN : Endif
    Endif
  When 2                          # File
     Gosub SEARCH_SINV            # go through SINVOICE and check for each invoice number if equal to invoice number in file
  Endcase
Return


############################################################################################
$HANDLE_INVNUM
Local Integer I, K, BSIIND_FOUND
Local Clbfile ALLREFTMP(5)
Raz PREFIX, SEARCHSTR, BSIIND_FOUND

Gosub READ_INVDIO   # read invoice number definition
If BSIIND_FOUND
    If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(122,7703,1),[F:BSIIND]CPY-[F:BSIIND]FCY-[F:BSIIND]FILFMT),0) From GESECRAN : Endif
    For [F:BSIINDD] Where CPY = [F:BSIIND]CPY and FCY = [F:BSIIND]FCY and FILFMT = [F:BSIIND]FILFMT # loop over invoice number definition details
        [L]PREFIX = [F:BSIINDD]PFXINV
        [L]SEARCHSTR = "*"+[F:BSIINDD]PFXINV+"*"
        If PLOG
            Call ECR_TRACE ("-----------------------------------------------------------------------------------------",0) From GESECRAN
            If [F:BSIINDD]DIR = 1
                Call ECR_TRACE (func AFNC.MES1(mess(123,7703,1),PREFIX),0) From GESECRAN
            Else
                Call ECR_TRACE (func AFNC.MES1(mess(124,7703,1),PREFIX),0) From GESECRAN
            Endif
        Endif
        If NUMIMPS = 0                                    # MT940 or CSV
            Case [F:BSIIP]MRGDESFLD
                  When 2                                  # always concatenate reference lines
                     ALLREFTMP = ALLREFLIN1               # make a copy of concatenated reference lines
                     Gosub HANDLE_INVOICE_COMMON
                  When 1                                  # handle reference lines one by one
                      For I=0 To dim([F:BSIIMPD]FREREF)-1
                         If [F:BSIIMPD]FREREF(I)<>""
                            ALLREFTMP = [F:BSIIMPD]FREREF(I)
                            Gosub HANDLE_INVOICE_COMMON
                         Endif
                      Next
                  When 3 # handle reference lines in 2 steps: one by one and if not found concatenated
                      For I=0 To dim([F:BSIIMPD]FREREF)-1 # one by one
                         If [F:BSIIMPD]FREREF(I)<>""
                            ALLREFTMP = [F:BSIIMPD]FREREF(I)
                            Gosub HANDLE_INVOICE_COMMON
                         Endif
                      Next
                      If S1=S1_OLD                        # nothing found so far > search in concatenated lines
                         ALLREFTMP = ALLREFLIN1           # make a copy of concatenated reference lines
                         Gosub HANDLE_INVOICE_COMMON
                      Endif
            Endcase
        Else                                              # CAMT
            For [F:BSIIMPS]                               # loop over all subdetail records
                For I = 0 To dim([F:BSIIMPS]RMTREF)-1     # Loop over all 10 RMTREF fields
                    If [F:BSIIMPS]RMTREF(I) <> ""
                        ALLREFTMP = [F:BSIIMPS]RMTREF(I)
                        Gosub HANDLE_INVOICE_COMMON
                    Endif
                Next
            Next
        Endif
    Next
Else
    If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(125,7703,1),[F:BSIIMP]CPY-[F:BSIIMP]FCY-[F:BSIIMP]FILFMT),-1) From GESECRAN : Endif
Endif
Return



############################################################################################
$HANDLE_QRREFNUM
If dim(GSWIPAYQR) > 0 and GSWIPAYQR = 2
    For [F:BSIIMPS]                               # loop over all subdetail records
        If [F:BSIIMPS]BVRREF <> ""
            Read [F:SWIQRC]SWIQRC1 = [F:BSIIMPS]BVRREF;5
            If !fstat
                Read [F:SIH]SIH0 = [F:SWIQRC]NUM
                Gosub CHECK_SINVOICE
            Endif
        Endif
    Next
Endif
Return


############################################################################################
$CHECK_SINVOICE
If !fstat
    If [F:BSIIMP]CPY = [F:SIH]CPY
       VBPRPAY = [F:SIH]BPRPAY
       FLGBPY = 3
       Raz [F:BSIINDD]                       # no invoice number definition for ISR/QR necessary
       [L]INVNUM = [F:SIH]NUM
       Gosub SETFLAG_IN_INVARR
    Else
       If PLOG : Call ECR_TRACE (func AFNC.MES3(mess(210,7703,1),[F:SIH]NUM,[F:BSIIMPS]BVRREF,[F:SIH]CPY),0) From GESECRAN : Endif
    Endif
Endif
Return


############################################################################################
$HANDLE_BVRREFNUM
If dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2
    For [F:BSIIMPS]                               # loop over all subdetail records
        If [F:BSIIMPS]BVRREF <> ""
            Read [SIH]SIH9 = [F:BSIIMPS]BVRREF
            Gosub CHECK_SINVOICE
        Endif
    Next
Endif
Return


############################################################################################
$READ_INVDIO
# read header of invoice number definition
Read [F:BSIIND]BSIIND0 = [F:BSIIMP]CPY; [F:BSIIMP]FCY; [F:BSIIMP]FILFMT # first try: all 3 segments of index (only CPY mandatory in [BSIIND])
If !fstat BSIIND_FOUND = 1 Endif                                        # found
If BSIIND_FOUND=0 and [F:BSIIMP]FCY <> ""                               # not yet found?
    Read [F:BSIIND]BSIIND0 = [F:BSIIMP]CPY; ""; [F:BSIIMP]FILFMT        # second try: only CPY + FILFMT (FCY empty)
    If !fstat BSIIND_FOUND = 1 Endif                                    # found
Endif
If BSIIND_FOUND=0 and [F:BSIIMP]FCY <> "" and [F:BSIIMP]FILFMT <> ""    # not yet found?
    Read [F:BSIIND]BSIIND0 = [F:BSIIMP]CPY; [F:BSIIMP]FCY; ""           # third try: only CPY + FCY (FILFMT empty)
    If !fstat BSIIND_FOUND = 1 Endif                                    # found
Endif
If BSIIND_FOUND=0                                                       # not yet found?
    Read [F:BSIIND]BSIIND0 = [F:BSIIMP]CPY; ""; ""                      # fourth try: only CPY (FCY + FILFMT empty)
    If !fstat BSIIND_FOUND = 1 Endif                                    # found
Endif
Return


############################################################################################
$GET_MINMAX_LEN_BPR
If [F:BSIBPND]LENINVSTR < len(PREFIX)
   LEN_MIN=len(PREFIX)
Else
   LEN_MIN=[F:BSIBPND]LENINVSTR
Endif
If [F:BSIBPND]LENINVEND=0
   LEN_MAX=len(ALLREFTMP)
Else
   LEN_MAX=[F:BSIBPND]LENINVEND
Endif
BPRNUM = mid$(ALLREFTMP,IND,LEN_MAX)
Return



$FIND_BPRNUM
Local Integer N, IND, LEN_MIN, LEN_MAX
Local Char MYCPY(GLONCPY)

# get length of a BP number
OKREAD = 0
N = 1 : IND = 1
PREFIX = toupper(PREFIX)
While IND > 0
  OKREAD = 0
  IND = instr(N,ALLREFTMP,PREFIX)
  If IND <> 0
     Gosub GET_MINMAX_LEN_BPR
     Raz VBPRPAY
     Read [BPR]BPR0 = [L]BPRNUM
     If !fstat
         OKREAD = 1
         FLGBPY = 4
         VBPRPAY = [BPR]BPRNUM
         Gosub SETFLAG_IN_BPY
     Else              # if not found > decrement length step by step and try again until found or min. length reached
         Raz VBPRPAY
         For M=LEN_MAX - 1 To [L]LEN_MIN Step -1
            [L]BPRNUM = mid$(ALLREFTMP,IND,M)
            Read [BPR]BPR0 = [L]BPRNUM
            If !fstat
               OKREAD   = 1
               FLGBPY  = 4
               VBPRPAY = [BPR]BPRNUM
               Gosub SETFLAG_IN_BPY
               Break
            Endif
         Next
     Endif
     N = IND + len(PREFIX)
  Endif
Wend
Return


############################################################################################
$SEARCH_BPRNUM
Local Char SUBNUM(GLONVCR+2)
If [F:BSIBPND]OPT=2                           # n last characters
    Filter [F:BPR] Where pat([F:BPR]BPRNUM,SEARCHSTR)>0
    For [BPR]
       SUBNUM = right$([BPR]BPRNUM,len([BPR]BPRNUM)-[F:BSIBPND]LNG+1)
       SUBNUM="*"+SUBNUM+"*"
       If pat(ALLREFTMP,SUBNUM)
          [L]BPRNUM  = [F:BPR]BPRNUM
          [L]VBPRPAY = [F:BPR]BPRNUM
          FLGBPY = 4
          Gosub SETFLAG_IN_BPY
       Endif
    Next
    Filter [BPR]
Endif
Return



############################################################################################
$HANDLE_BPRNUM_COMMON
Local Char BPRNUM(255)
Raz BPRNUM
Case [F:BSIBPND]DIR                 # search direction
  When 1                            # Sage X3
    If [L]PREFIX <> ""
        TMPSTR = ALLREFTMP          # otherwise the Clob ALLREFTMP is truncated in LOG
        If pat(ALLREFTMP,SEARCHSTR) # check if prefix found
           If PLOG : Call ECR_TRACE (func AFNC.MES2(mess(119,7703,1),PREFIX,TMPSTR),0) From GESECRAN : Endif
           Gosub FIND_BPRNUM        # if yes, try to find BP number in database
        Else
           If PLOG : Call ECR_TRACE (func AFNC.MES2(mess(120,7703,1),PREFIX,TMPSTR),0) From GESECRAN : Endif
        Endif
    Else
        If PLOG : Call ECR_TRACE (mess(126,7703,1),0) From GESECRAN : Endif
    Endif
  When 2                            # File
     Gosub SEARCH_BPRNUM            # go through BPARTNER and check for each BP number if equal to BP number in file
Endcase
Return


############################################################################################
$HANDLE_BPRNUM
Local Integer I, K, BSIBPN_FOUND
Local Clbfile ALLREFTMP(5)
Raz PREFIX, SEARCHSTR, BSIBPN_FOUND

Gosub READ_BPRNUM   # read BP number definition
If BSIBPN_FOUND
    If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(127,7703,1),[F:BSIBPN]CPY-[F:BSIBPN]FCY-[F:BSIBPN]FILFMT),0) From GESECRAN : Endif
    For [F:BSIBPND] Where CPY = [F:BSIBPN]CPY and FCY = [F:BSIBPN]FCY and FILFMT = [F:BSIBPN]FILFMT # loop over BP number definition details
        [L]PREFIX = [F:BSIBPND]PFX
        [L]SEARCHSTR = "*"+[F:BSIBPND]PFX+"*"
        If PLOG
            Call ECR_TRACE ("-----------------------------------------------------------------------------------------",0) From GESECRAN
            If [F:BSIBPND]DIR = 1
                Call ECR_TRACE (func AFNC.MES1(mess(123,7703,1),PREFIX),0) From GESECRAN
            Else
                Call ECR_TRACE (func AFNC.MES1(mess(124,7703,1),PREFIX),0) From GESECRAN
            Endif
        Endif

        If NUMIMPS = 0                        # MT940 or CSV
            Case [F:BSIIP]MRGDESFLD
              When 2                          # always concatenate reference lines
                 ALLREFTMP = ALLREFLIN1       # make a copy of concatenated reference lines
                 Gosub HANDLE_BPRNUM_COMMON
              When 1                          # handle reference lines one by one
                  For I=0 To dim([F:BSIIMPD]FREREF)-1
                     If [F:BSIIMPD]FREREF(I)<>""
                        ALLREFTMP = [F:BSIIMPD]FREREF(I)
                        Gosub HANDLE_BPRNUM_COMMON
                     Endif
                  Next
              When 3 # handle reference lines in 2 steps: one by one and if not found concatenated
                  For I=0 To dim([F:BSIIMPD]FREREF)-1  # one by one
                     If [F:BSIIMPD]FREREF(I)<>""
                        ALLREFTMP = [F:BSIIMPD]FREREF(I)
                        Gosub HANDLE_BPRNUM_COMMON
                     Endif
                  Next
                  If S=S_OLD                           # nothing found so far > search in concatenated lines
                     ALLREFTMP = ALLREFLIN1            # make a copy of concatenated reference lines
                     Gosub HANDLE_BPRNUM_COMMON
                  Endif
            Endcase
        Else                                           # CAMT
            For [F:BSIIMPS]                            # loop over all subdetail records
                For I = 0 To dim([F:BSIIMPS]RMTREF)-1  # Loop over all 10 RMTREF fields
                    If [F:BSIIMPS]RMTREF(I) <> ""
                        ALLREFTMP = [F:BSIIMPS]RMTREF(I)
                        Gosub HANDLE_BPRNUM_COMMON
                    Endif
                Next
            Next
        Endif
    Next
Else
    If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(128,7703,1),[F:BSIIMP]CPY-[F:BSIIMP]FCY-[F:BSIIMP]FILFMT),-1) From GESECRAN : Endif
Endif
Return


############################################################################################
$READ_BPRNUM
# read header of BP number definition
Read [F:BSIBPN]BSIBPN0 = [F:BSIIMP]CPY; [F:BSIIMP]FCY; [F:BSIIMP]FILFMT # first try: all 3 segments of index (only CPY mandatory in [BSIIND])
If !fstat BSIBPN_FOUND = 1 Endif                                        # found
If BSIBPN_FOUND=0 and [F:BSIIMP]FCY <> ""                               # not yet found?
    Read [F:BSIBPN]BSIBPN0 = [F:BSIIMP]CPY; ""; [F:BSIIMP]FILFMT        # second try: only CPY + FILFMT (FCY empty)
    If !fstat BSIBPN_FOUND = 1 Endif                                    # found
Endif
If BSIBPN_FOUND=0 and [F:BSIIMP]FCY <> "" and [F:BSIIMP]FILFMT <> ""    # not yet found?
    Read [F:BSIBPN]BSIBPN0 = [F:BSIIMP]CPY; [F:BSIIMP]FCY; ""           # third try: only CPY + FCY (FILFMT empty)
    If !fstat BSIBPN_FOUND = 1 Endif                                    # found
Endif
If BSIBPN_FOUND=0                                                       # not yet found?
    Read [F:BSIBPN]BSIBPN0 = [F:BSIIMP]CPY; ""; ""                      # fourth try: only CPY (FCY + FILFMT empty)
    If !fstat BSIBPN_FOUND = 1 Endif                                    # found
Endif
Return


############################################################################################
$CHECK_SRCDOC
Local Integer LPOS, B
Local Char SSTRING(250)
Raz B
LPOS = 1
Raz [L]LFOUND

B = instr(LPOS,LSRCDOC,chr$(32))
While B > 0                                                       # search for next blank
  SSTRING = mid$(LSRCDOC,LPOS,B-LPOS)

  If len(SSTRING) < [F:BSIIP]SEAEXDLEN                            # check if length of substring is smaller than configured
     Goto TONEXT1                                                 # if yes, ignore substring for search
  Endif

  If [F:BSIIP]SEAEXD = 2                                          # check parameter "use excluded search term list"
    Read [F:BSISEA]BSISEA0 = SSTRING                              # check if substring is in list of strings to ignore
    If !fstat
       Goto TONEXT1                                               # if yes, ignore substring for search
    Endif
  Endif

  If instr(1,ALLREFTMP,SSTRING) >0
     LFOUND = 1 : Break : Return
  Endif

  $TONEXT1
  LPOS = B+1
  B = instr(LPOS,LSRCDOC,chr$(32))
Wend

If B=0
   SSTRING = LSRCDOC
Else
   SSTRING = mid$(LSRCDOC,LPOS,(len(LSRCDOC)+1)-LPOS)
Endif

If len(SSTRING) < [F:BSIIP]SEAEXDLEN                            # check if length of substring is smaller than configured
   Return                                                       # if yes, ignore substring for search
Endif

If [F:BSIIP]SEAEXD = 2                                          # check parameter "use excluded search term list"
  Read [F:BSISEA]BSISEA0 = SSTRING                              # check if substring is in list of strings to ignore
  If !fstat
     Return                                                     # if yes, ignore substring for search
  Endif
Endif

If instr(1,ALLREFTMP,SSTRING) > 0
   LFOUND = 1
Endif
Return


############################################################################################
$HANDLE_SRCDOC
Local Integer LFOUND, OVERFLOW, I
Local Char LSRCDOC (250)
Local Clbfile ALLREFTMP(5)
Raz [L]LFOUND, LSRCDOC, OVERFLOW

If NUMIMPS = 0                       # MT940 or CSV
   ALLREFTMP = ALLREFLIN1            # use concatenated description field
Endif

Filter [F:DUD] Where DUDSTA = 2 & TYPDUD = 2 and FLGCLE = 1  # DUDSTA 2: invoice posted, TYPDUD 2: invoice, FLGCLE 1: not closed
For [F:DUD]
    Gosub READ_INV_BY_SRCDOC
    If [L]LFOUND                     # Invoice found
      If NUMIMPS = 0                 # MT940 or CSV
          If [F:BSIIP]MRGDESFLD = 2 or [F:BSIIP]MRGDESFLD = 3   # merge description field "always" or "second pass" (only then ALLREFTMP has a value)
              Gosub CHECK_SRCDOC
              Gosub CHECK_INVNUM
              If OVERFLOW : Break : Endif
          Else                                      # If "Merge description fields" = "No" ALLREFTMP is empty and we have to loop
              For I=0 To dim([F:BSIIMPD]FREREF)-1   # Loop over all FREREF fields until found
                 If [F:BSIIMPD]FREREF(I)<>""
                    ALLREFTMP = [F:BSIIMPD]FREREF(I)
                    Gosub CHECK_SRCDOC
                    If [L]LFOUND
                        Gosub CHECK_INVNUM
                        If OVERFLOW : Break : Endif
                        Break
                    Endif
                 Endif
              Next
          Endif
      Else                           # CAMT
          For [F:BSIIMPS]            # loop over all subdetail records
              For I = 0 To dim([F:BSIIMPS]RMTREF)-1  # Loop over all 10 RMTREF fields
                  If [F:BSIIMPS]RMTREF(I) <> ""
                      ALLREFTMP = [F:BSIIMPS]RMTREF(I)
                      Gosub CHECK_SRCDOC
                      If [L]LFOUND
                          Gosub CHECK_INVNUM
                          If OVERFLOW : Break : Endif
                          Break
                      Endif
                  Endif
              Next
          Next
      Endif
    Endif
Next
Filter [F:DUD]
Return


############################################################################################
$READ_INV_BY_SRCDOC
Raz [L]INVNUM, [L]LFOUND, FLGFIND, VBPRPAY
If [F:DUD]BPRTYP = 2
   Read [F:PIH]PIH0 = [F:DUD]NUM
   If !fstat
      If [F:PIH]BPRVCR <> ""
         [L]LSRCDOC = [F:PIH]BPRVCR
         [L]LFOUND = 1
      Endif
   Endif
Elsif [F:DUD]BPRTYP = 1
   Read [F:SIH]SIH0 = [F:DUD]NUM
   If !fstat
      If [F:SIH]BPRVCR <> ""
         [L]LSRCDOC = [F:SIH]BPRVCR
         [L]LFOUND = 1
      Endif
   Endif
Endif
Return



############################################################################################
$CHECK_INVNUM
   If [L]LFOUND = 1
     VBPRPAY =  [DUD]BPRPAY
     [L]INVNUM = [DUD]NUM
     For L=0 To S1-1
         If INV00(L)= [L]INVNUM
            FLGFIND = 1
         Endif
     Next

     If FLGFIND = 0                                   # not found in INVARR
        If S1 = MAXINV-1                              # no more free space in INVARR
           OVERFLOW = 1                               # max. numer of array entries reached > Return
           If PLOG
               Call ECR_TRACE (func AFNC.MES1(mess(114,7703,1),num$([L]MAXINV)),-1) From GESECRAN
               Call ECR_TRACE (func AFNC.MES1(mess(115,7703,1),[L]INVNUM),-1) From GESECRAN
           Endif
        Else
           Gosub SET_INV_ARR                          # add to INVARR
        Endif
     Endif
   Endif
Return


############################################################################################
$HANDLE_SOHNUM
Local Clbfile ALLREFTMP(5)
Local Integer LFOUND, I, OVERFLOW

If NUMIMPS = 0                    # MT940 or CSV
   ALLREFTMP = ALLREFLIN1
Endif

Filter [F:DUD] Where (TYP = "*SO" |TYP = "*PO") & TYPDUD = 1 and FLGCLE = 1
For [F:DUD]
   If NUMIMPS = 0                 # MT940 or CSV
      Gosub READ_INV_BY_SOH
      Gosub CHECK_INVNUM
      If OVERFLOW : Break : Endif
   Else                           # CAMT
      For [F:BSIIMPS]             # loop over all subdetail records
          For I = 0 To dim([F:BSIIMPS]RMTREF)-1  # Loop over all 10 RMTREF fields
              If [F:BSIIMPS]RMTREF(I) <> ""
                  ALLREFTMP = [F:BSIIMPS]RMTREF(I)
                  Gosub READ_INV_BY_SOH
                  Gosub CHECK_INVNUM
                  If OVERFLOW : Break : Endif
              Endif
          Next
      Next
   Endif
Next
Filter [F:DUD]
Return



############################################################################################
$READ_INV_BY_SOH
Raz [L]LFOUND , [L]FLGFIND, [L]INVNUM
If GACTX.AFOLD.AMODULE(5) = [V]CST_AYES and [F:DUD]TYP = "*SO" # 2017-12-21 DNE X3-68766
   Read [F:SOH]SOH0 = [F:DUD]NUM
   If !fstat
      # check if SSTRING is found in one of the FREREF fields
      If [F:BSIIP]MRGDESFLD = 2 or [F:BSIIP]MRGDESFLD = 3   # merge description field "always" or "second pass" (only then ALLREFTMP has a value)
          If instr(1,[L]ALLREFTMP,[F:SOH]SOHNUM) > 0        # in concatenated FREREF fields?
             [L]INVNUM = [F:SOH]SOHNUM
             [L]LFOUND = 1
          Endif
      Else                                                  # If "Merge description fields" = "No" ALLREFTMP is empty and we have to loop
          For I=0 To dim([F:BSIIMPD]FREREF)-1               # Loop over all FREREF fields until found
             If [F:BSIIMPD]FREREF(I)<>""
                If instr(1,[F:BSIIMPD]FREREF(I),[F:SOH]SOHNUM) > 0
                   [L]INVNUM = [F:SOH]SOHNUM
                   [L]LFOUND = 1
                   Break
                Endif
             Endif
          Next
      Endif
   Endif
Elsif GACTX.AFOLD.AMODULE(6) = [V]CST_AYES and [F:DUD]TYP = "*PO" # 2017-12-21 DNE X3-68766
   Read [F:POH]POH0 = [F:DUD]NUM
   If !fstat
      # check if SSTRING is found in one of the FREREF fields
      If [F:BSIIP]MRGDESFLD = 2 or [F:BSIIP]MRGDESFLD = 3   # merge description field "always" or "second pass" (only then ALLREFTMP has a value)
          If instr(1,[L]ALLREFTMP,[F:POH]POHNUM) > 0        # in concatenated FREREF fields?
             [L]INVNUM = [F:POH]POHNUM
             [L]LFOUND = 1
          Endif
      Else                                                  # If "Merge description fields" = "No" ALLREFTMP is empty and we have to loop
          For I=0 To dim([F:BSIIMPD]FREREF)-1               # Loop over all FREREF fields until found
             If [F:BSIIMPD]FREREF(I)<>""
                If instr(1,[F:BSIIMPD]FREREF(I),[F:POH]POHNUM) > 0
                   [L]INVNUM = [F:POH]POHNUM
                   [L]LFOUND = 1
                   Break
                Endif
             Endif
          Next
      Endif
   Endif
Endif
Return


############################################################################################
$MATCH_ISR_QR_REFNUM
If (dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2) or (dim(GSWIPAYQR) > 0 and GSWIPAYQR = 2) Then # parameter "Swiss ISR/QR checks in payments" = yes?
    If PLOG : Call ECR_TRACE (mess(212,7703,1),0) From GESECRAN : Endif
    If NUMIMPS = 0               # MT940 or CSV > nothing to do (ISR/QR reference number not supported)
        If PLOG : Call ECR_TRACE (mess(207,7703,1),0) From GESECRAN : Endif
    Else                         # CAMT
        FLGNUM = 4               # index 4 in INV02: ISR/QR reference number
        S1_OLD = S1
        If SIGN = 1                                      # Revenue
            # first step: try to match by ISR reference number
            Gosub HANDLE_BVRREFNUM
            # second step: try to match by QR reference number if no ISR match
            If S1 = S1_OLD           # nothing found so far
                Gosub HANDLE_QRREFNUM
            Endif
        Else                                              # Expense > not possible
            If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(208,7703,1),[L]INVNUM),0) From GESECRAN : Endif
        Endif
        If PLOG : Call ECR_TRACE ("-----------------------------------------------------------------------------------------",0) From GESECRAN : Endif
        If S1 > S1_OLD
          If PLOG : Call ECR_TRACE (mess(205,7703,1),0) From GESECRAN : Endif
          FBVRREF = 2             # set flag "BVRREFNUM found"
        Else
          If PLOG : Call ECR_TRACE (mess(206,7703,1),0) From GESECRAN : Endif
        Endif
    Endif
Else
   If PLOG : Call ECR_TRACE (mess(213,7703,1),0) From GESECRAN : Endif
Endif
Return

############################################################################################
$MATCH_BID
If [F:BSIIP]BPRBANID = 2 Then       # parameter "BP bank ID" set?
   If PLOG : Call ECR_TRACE (mess(129,7703,1),0) From GESECRAN : Endif
   If NUMIMPS = 0                   # MT940 or CSV
      Gosub GET_BIDNUM              # get values for either BIC and IBAN or BankID and AccountNo
   Else                             # CAMT
      VACCNO = "CAMT"               # dummy entry to proceed: there are 3 IBAN fields in table BSIIMPDS
   Endif
   If VACCNO <> "" or VBANKID <> "" # if found > find all fitting BID records
      S_OLD = S
      If NUMIMPS = 0                # MT940 or CSV or no subdetails found
        Gosub FIND_ALL_BID
      Else                          # CAMT
        Gosub FIND_ALL_BID_IMPS
      Endif
      If PLOG : Call ECR_TRACE ("-----------------------------------------------------------------------------------------",0) From GESECRAN : Endif
      If S>S_OLD
        If PLOG : Call ECR_TRACE (mess(131,7703,1),0) From GESECRAN : Endif
        FBIDNUM = 2            # set flag "BIDNUM found"
      Else
        If PLOG : Call ECR_TRACE (mess(132,7703,1),0) From GESECRAN: Endif
      Endif
   Endif
Else
   If PLOG : Call ECR_TRACE (mess(130,7703,1),0) From GESECRAN : Endif
Endif
Return

############################################################################################
$MATCH_BP_NAME
If [F:BSIIP]BPRNAM = 2 Then         # parameter "BP name" set?
    If PLOG : Call ECR_TRACE (mess(133,7703,1),0) From GESECRAN : Endif
    S_OLD = S

    Local Char    LBPRREF (250), LBPRREF1(250)
    Local Char    LCHR(1)
    Local Char    LBPRNAME01 (250)
    Local Char    LBPRNUM(GLONBPR)
    Local Char    LBPR (30)(5000)
    Local Integer LCNTBPR(5000), CNT, NUMBPRCNT, ZZ

    Raz LBPR, CNT, LCNTBPR, NUMBPRCNT, ZZ, LBPRREF

    If NUMIMPS = 0                  # MT940 or CSV
      Gosub HANDLE_BPRNAM
    Else                            # CAMT
      Gosub HANDLE_BPRNAM_IMPS
    Endif
    If PLOG : Call ECR_TRACE ("-----------------------------------------------------------------------------------------",0) From GESECRAN : Endif
    If S>S_OLD
      If PLOG : Call ECR_TRACE (mess(135,7703,1),0) From GESECRAN : Endif
      FBPRNAM = 2                   # set flag "BPRNAM found"
    Else
      If PLOG : Call ECR_TRACE (mess(136,7703,1),0) From GESECRAN: Endif
    Endif
Else
   If PLOG : Call ECR_TRACE (mess(134,7703,1),0) From GESECRAN : Endif
Endif
Return

############################################################################################
$MATCH_INV_NUMBER
If [F:BSIIP]INVNUM = 2 Then   # parameter "Invoice number" set?
    If PLOG : Call ECR_TRACE (mess(137,7703,1),0) From GESECRAN : Endif
    FLGNUM = 1                # index 1 in INV02: invoice number
    S1_OLD = S1
    Gosub HANDLE_INVNUM
    If PLOG : Call ECR_TRACE ("-----------------------------------------------------------------------------------------",0) From GESECRAN : Endif
    If S1>S1_OLD
      If PLOG : Call ECR_TRACE (mess(139,7703,1),0) From GESECRAN : Endif
      FINVNUM = 2             # set flag "INVNUM found"
    Else
      If PLOG : Call ECR_TRACE (mess(140,7703,1),0) From GESECRAN : Endif
    Endif
Else
   If PLOG : Call ECR_TRACE (mess(138,7703,1),0) From GESECRAN : Endif
Endif
Return

############################################################################################
$MATCH_BP_NUMBER
If [F:BSIIP]BPRNUM = 2 Then  # parameter "BP number" set?
    If PLOG : Call ECR_TRACE (mess(141,7703,1),0) From GESECRAN : Endif
    S_OLD = S
    Gosub HANDLE_BPRNUM
    If S>S_OLD
      If PLOG : Call ECR_TRACE (mess(143,7703,1),0) From GESECRAN : Endif
      FBPR = 2               # set flag "BPR found"
    Else
      If PLOG : Call ECR_TRACE (mess(144,7703,1),0) From GESECRAN : Endif
    Endif
Else
   If PLOG : Call ECR_TRACE (mess(142,7703,1),0) From GESECRAN : Endif
Endif
Return

############################################################################################
$MATCH_ORIG_DOC
If [F:BSIIP]SRCDOC = 2 Then   # parameter "source document" set?
    If PLOG : Call ECR_TRACE (mess(145,7703,1),0) From GESECRAN : Endif
    FLGNUM = 2                # index 2 in INV02: source document
    Local Integer FLGFIND
    Raz FLGFIND, VBPRPAY
    S1_OLD = S1
    Gosub HANDLE_SRCDOC
    If PLOG : Call ECR_TRACE ("-----------------------------------------------------------------------------------------",0) From GESECRAN : Endif
    If S1>S1_OLD or FLGFIND = 1
       If PLOG : Call ECR_TRACE (mess(147,7703,1),0) From GESECRAN : Endif
       FSRCDOC = 2            # set flag "source document found"
       FLGBPY = 3
       Gosub SETFLAG_IN_INVARR
    Else
       If PLOG : Call ECR_TRACE (mess(148,7703,1),0) From GESECRAN : Endif
    Endif
Else
    If PLOG : Call ECR_TRACE (mess(146,7703,1),0) From GESECRAN : Endif
Endif
Return


############################################################################################
$MATCH_ORDER_NUMBER
If [F:BSIIP]ORDERNUM = 2 Then  # parameter "order number" set?
   If PLOG : Call ECR_TRACE (mess(149,7703,1),0) From GESECRAN : Endif
   FLGNUM = 3                  # index 3 in INV02: order number
   Local Integer FLGFIND
   Raz FLGFIND, VBPRPAY
   S1_OLD = S1
   Gosub HANDLE_SOHNUM
   If PLOG : Call ECR_TRACE ("-----------------------------------------------------------------------------------------",0) From GESECRAN : Endif
   If S1>S1_OLD or FLGFIND = 1
      If PLOG : Call ECR_TRACE (mess(151,7703,1),0) From GESECRAN : Endif
      FSOHNUM = 2              # set flag "order number found"
      FLGBPY = 3
      Gosub SETFLAG_IN_INVARR
   Else
      If PLOG : Call ECR_TRACE (mess(152,7703,1),0) From GESECRAN : Endif
   Endif
Else
   If PLOG : Call ECR_TRACE (mess(150,7703,1),0) From GESECRAN : Endif
Endif
Return


############################################################################################
# check if amount in DUD equals amount in transaction
############################################################################################
$CHECK_AMOUNT
Local Decimal AMTVARLIMTRS   # Absolute limit ([F:BSIIP]AMTVARLIM in company currency) in transaction currency.
Raz LDEPAMT, LDIFF, LOPENAMT, AMTVARLIMTRS

# X3-42422 Bader 2017-07-10
Gosub CALC_ALL_DISCOUNTS
If [F:DUD]CUR = [F:BSIIMPD]CUR         # no currency conversion necessary for comparison
    LOPENAMT = OPENAMTCUR
    LDEPAMT = [L]LDEPAMTCUR
Else
    LOPENAMT = OPENAMTTRS
    LDEPAMT = [L]LDEPAMTTRS
Endif
# X3-42422 Bader 2017-07-10 end

If PLOG : Call ECR_TRACE (func AFNC.MES2(mess(153,7703,1),[F:DUD]NUM,num$(LDEPAMTCUR)-[F:DUD]CUR),0) From GESECRAN : Endif

# Read country and payment transaction for we need the company currency and the rate type.
Call LEC_TPY_LEG( [F:BSIIP]LEG, [F:BSIIP]PAYTYP ) From CPTLEC # read payment entry type

[L]CURTRS        = [F:BSIIMPD]CUR      # Transaction currency
[L]CURCPY        = [F:CPY]ACCCUR       # Company currency.
[L]RATTYP        = [F:TPY]RATTYP       # Rate type (local menu 202)
[L]DATRAT        = [F:BSIIMPD]VALDAT   # Value date for payment generation/posting
Raz [L]ERRCUR                          # Error status from currency conversion (0: OK).

If [L]LOPENAMT - [L]LDEPAMT = [F:BSIIMPD]AMTCUR
    [L]OKAMT = 2
    If PLOG : Call ECR_TRACE (func AFNC.MES2(mess(154,7703,1),num$([L]LOPENAMT-[L]LDEPAMT),[F:DUD]NUM),0) From GESECRAN : Endif
Else
    If [F:DUD]CUR = [F:BSIIMPD]CUR         # X3-42422 Bader 2017-07-10 use standard variance if OI currency = transaction currency
       If [F:BSIIP]AMTVAR <> 0  Then                      # check amount variance (percentage)
          [L]LDIFF = [L]LOPENAMT - [F:BSIIMPD]AMTCUR
          If abs([L]LDIFF)*100/[L]LOPENAMT <= [F:BSIIP]AMTVAR Then
            If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(155,7703,1),[F:DUD]NUM),0) From GESECRAN : Endif
            [L]OKAMT = 1                                  # inside tolerance range
            If [F:BSIIP]AMTVARLIM <> 0                    # > check absolute amount variance limit
              # Convert variance from company currency to transaction currency (for setup is company based!).
              Call CONVERT( GACTX, CURCPY, CURTRS, CURCPY, RATTYP, DATRAT, [F:BSIIP]AMTVARLIM, [L]AMTVARLIMTRS, ERRCUR ) From TRTDEV_SYRA
              If ERRCUR : PSTA = 3 : PMSG = PSTMCOD + "~" + num$(PLIN) - mess(1017,196,1) : Return : Endif  # 'Currency conversion problem'
              If abs([L]LDIFF) > [L]AMTVARLIMTRS Then     # outside absolute limit?
                If PLOG : Call ECR_TRACE (func AFNC.MES2(mess(156,7703,1),[F:DUD]NUM,num$([L]AMTVARLIMTRS)),0) From GESECRAN : Endif
                [L]OKAMT = 0
              Endif
            Endif
          Endif
       Endif
    Else         # X3-42422 Bader 2017-07-10 use currency variance if OI currency <> transaction currency
       If [F:BSIIP]AMTVARCUR <> 0  Then                   # check currency amount variance (percentage)
          [L]LDIFF = [L]LOPENAMT - [F:BSIIMPD]AMTCUR
          If abs([L]LDIFF)*100/[L]LOPENAMT <= [F:BSIIP]AMTVARCUR Then
            If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(228,7703,1),[F:DUD]NUM),0) From GESECRAN : Endif
            [L]OKAMT = 1                                  # inside tolerance range
          Endif
       Endif
    Endif
Endif

If [L]OKAMT <> 1               # not inside tolerance range
    Raz [L]LDIFF               # > no LDIFF
# Bader: 2016-10-28 X3-6249
Else                           # inside tolerance range > adapt discount if necessary
    If [F:DUD]CUR = [F:BSIIMPD]CUR         # X3-42422 Bader 2017-07-10 overpayment only if OI currency = transaction currency
        If [L]LDIFF >= 0 and [L]LDIFF <=[L]LDEPAMT      # discount not totally taken
          [L]LDEPAMT = [L]LDIFF
          If PLOG : Call ECR_TRACE (func AFNC.MES2(mess(157,7703,1),[F:DUD]NUM,num$([L]LDIFF)),0) From GESECRAN : Endif
        Elsif [L]LDIFF < 0
          [L]LDEPAMT = 0                                # overpayment > no discount
          If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(158,7703,1),[F:DUD]NUM),0) From GESECRAN : Endif
        Endif
    Else
        Raz [L]LDIFF               # no overpayment with currency variance > no LDIFF
    Endif
# Bader: 2016-10-28 X3-6249 end
Endif

[L]FAMT = [L]OKAMT
Return


# X3-42422 Bader 2017-07-10
# Calculates the discount of an open item in OI and transaction currency
$CALC_ALL_DISCOUNTS
Local Char LCUR(GLONCUR)
Local Decimal LDEPAMT

# first: calculate discount in OI currency
LOPENAMT = OPENAMTCUR
LCUR = [F:DUD]CUR
Gosub CALC_DISCOUNT
[L]LDEPAMTCUR = [L]LDEPAMT

# second: calculate discount in transaction currency (if not equal to OI currency)
If [F:DUD]CUR <> [F:BSIIMPD]CUR
    LOPENAMT = OPENAMTTRS
    LCUR = [F:BSIIMPD]CUR              # transaction currency = bank currency
    Gosub CALC_DISCOUNT
Endif
[L]LDEPAMTTRS = [L]LDEPAMT
Return


# X3-42422 Bader 2017-08-11
# Calculates the discount based on the total transaction amount in transaction currency
# needed for the pro rata calculation of the "Paid discount" field in transaction currency
$CALC_TRS_DISCOUNT
Local Char LCUR(GLONCUR)
Local Decimal LDEPAMT
If IS_CUR
    LOPENAMT = [F:BSIIMPD]AMTCUR       # total transaction amount
    LCUR = [F:BSIIMPD]CUR              # transaction currency = bank currency
    Gosub CALC_DISCOUNT
    [L]SUMDEPAMTTRS = [L]LDEPAMT
Endif
Return


# X3-42422 Bader 2017-07-10
# Calculates the discount of an open item
$CALC_DISCOUNT
If [F:DUD]DEP<>""
   # calculate discount
   Raz [L]LDEPAMT
   Call ESC_AGIO([F:DUD]DEP,[F:BSIIMPD]VALDAT-[F:BSIIP]DEPTOL,[F:DUD]DUDDAT,0,LOPENAMT,LCUR,LDEPAMT,[F:DUD]ACCNUM,[F:DUD]DUDLIG) From MODECHE
   If LDEPAMT<>0                                      # TODO: check if not already correctly rounded!!
      Call LECTURE("TCU",LCUR,"") From CONTOBJ        # read currency table
      LDEPAMT = arr(LDEPAMT,[F:TCU]CURRND)            # rounding
   Endif
   If LDEPAMT < 0
     LDEPAMT = 0
   Endif
Endif
Return



$SET_FOUND_FLAGS
Local Integer LPOS
Raz LPOS
If [F:DUD]TYP <> "*SO" & [F:DUD]TYP <> "*PO"
 LPOS = find([DUD]NUM,INV00)
 If LPOS >0
    If left$(INV02(LPOS-1),1) ="1"
       FINVNUM = 2                                  # invoice number found
    Endif
 Endif
Endif

LPOS = find([DUD]BPRPAY, BPY00)
If LPOS>0
   If  BPY01(LPOS-1)="1" : FBIDNUM = 2 : Endif      # BIDNUM found
   If  BPY02(LPOS-1)="1" : FBPRNAM = 2 : Endif      # business partner name found
Endif
Return


############################################################################################
$SET_BSIIMPD
    [F:BSIIMPD]FLGAMT    = min(1, FAMT) + 1
    [F:BSIIMPD]FLGBIDNUM = FBIDNUM
    [F:BSIIMPD]FLGBPR    = FBPR
    [F:BSIIMPD]FLGBPRNAM = FBPRNAM
    [F:BSIIMPD]FLGBPRVCR = FSRCDOC
    [F:BSIIMPD]FLGINVNUM = FINVNUM
    [F:BSIIMPD]FLGBVRREFNUM = FBVRREF
    [F:BSIIMPD]FLGREFLIS = FREFLST # Note (DNE): Further version.
    [F:BSIIMPD]FLGSOHNUM = FSOHNUM
    [F:BSIIMPD]BPRINV = [F:DUD]BPR
    [F:BSIIMPD]DUDDAT = [F:DUD]DUDDAT
    [F:BSIIMPD]DUDNUM = [F:DUD]ACCNUM
    [F:BSIIMPD]DUDLIG = [F:DUD]DUDLIG
    [F:BSIIMPD]FCYLIN = [F:DUD]FCY
    [F:BSIIMPD]DEP    = [L]LDEPAMT
    [F:BSIIMPD]SAC    = [F:DUD]SAC

    If [F:BSIIMPD]BPRPAY = ""
       [F:BSIIMPD]BPRPAY = [F:DUD]BPRPAY
    Endif
# 2016-09-19 DNE INSERT BEGIN
    Raz [F:BSIIMPD]OVERPAY
    If [L]LDIFF < 0 # Overpayment.
        [F:BSIIMPD]OVERPAY = -[L]LDIFF
    Endif
# 2016-09-19 DNE INSERT END
Return


##############################################################################
$RESET_BSIIMPD
    Raz [F:BSIIMPD]LET
    [F:BSIIMPD]FLGAMT    = [V]CST_ANO
    [F:BSIIMPD]FLGBIDNUM = [V]CST_ANO
    [F:BSIIMPD]FLGBPR    = [V]CST_ANO
    [F:BSIIMPD]FLGBPRNAM = [V]CST_ANO
    [F:BSIIMPD]FLGBPRVCR = [V]CST_ANO
    [F:BSIIMPD]FLGCRE    = [V]CST_ANO
    [F:BSIIMPD]FLGINVNUM = [V]CST_ANO
    [F:BSIIMPD]FLGREFLIS = [V]CST_ANO
    [F:BSIIMPD]FLGSOHNUM = [V]CST_ANO
    Raz [F:BSIIMPD]BPRINV
    Raz [F:BSIIMPD]DUDDAT
    Raz [F:BSIIMPD]DUDNUM
    Raz [F:BSIIMPD]DUDLIG
    Raz [F:BSIIMPD]FCYLIN
    Raz [F:BSIIMPD]DEP
    Raz [F:BSIIMPD]SAC
    Raz [F:BSIIMPD]BPRPAY
# 2016-09-19 DNE INSERT BEGIN
    Raz [F:BSIIMPD]OVERPAY
# 2016-09-19 DNE INSERT END
Return


##############################################################################
$BUILD_CRITERIA
Local Integer LCRIT
Raz LCRIT

CRITERE = "CPY = '"+[F:BSIIMP]CPY+"'"

Call LEC_BAN([F:BSIIMP]BAN) From CPTLEC
If fstat = 0 and [F:BAN]FCY <> "" Then
    [L]CRITERE -= "& FCY='" + [F:BAN]FCY + "'"
Endif

If [F:BSIIP]ORDERNUM = 2 Then  # parameter "order number" set?
   CRITERE -= "& (TYPDUD=2 & DUDSTA=2 | find(TYP,'*SO','*PO'))"
Else
   CRITERE -= "& TYPDUD=2 & DUDSTA=2"   # X3-95416: 2018-06-11 Bader prevent from adding unposted invoices
Endif

CRITERE -= "& FLGCLE=1"

# 2016-08-02 Bader add criterion to suppress OI with currency different from statement currency
# 2017-07-06 Bader X3-42422 suppress OI with currency different from statement currency only if stmt. currency <> company currency
If [F:CPY]ACCCUR <> [F:BSIIMPD]CUR
    CRITERE -= "& CUR='" + [F:BSIIMPD]CUR + "'"
Endif

# 2016-11-08 Bader X3-6891 add criterion to suppress factoring OI
CRITERE -= "& BPRFCT=''"

# business partner criteria
CRITERE2 = "1=1"
If S > 0
   CRITERE2 -= "& find([DUD]BPRPAY, BPY00)"
Endif

# invoice number criteria
CRITERE3 = "1=1"
If S1 > 0
 CRITERE3 -= "& find([DUD]NUM,INV00)"
Endif

# invoice number, order number or source document criteria for business partner (stored in INV00 array)
If CRITERE3 <> "1=1" and CRITERE2 <> "1=1"
   For I = 0 To S-1
      If find(BPY00(I),INV01) = 0
         LCRIT = 1 : Break
      Endif
   Next
   If LCRIT = 1
      CRITERE3 = "1=1"
      CRITERE2 = "(find([DUD]NUM,INV00) or find([DUD]BPRPAY, BPY00))"
   Else
      CRITERE2 = "1=1"
   Endif
Endif
If PLOG
    Call ECR_TRACE (func AFNC.MES1(mess(159,7703,1),CRITERE),0) From GESECRAN
    Call ECR_TRACE (func AFNC.MES1(mess(160,7703,1),CRITERE2),0) From GESECRAN
    Call ECR_TRACE (func AFNC.MES1(mess(161,7703,1),CRITERE3),0) From GESECRAN
Endif
Return


############################################################################################
$UPDATE_BSIDUD
Local Char OI_CUR(GLONCUR)                                # X3-42422 Bader 2017-07-18
Local Integer IN_RANGE
If PAID = 1 : Return  : Endif
Raz IMPS_OK, IN_RANGE
Raz SUMPAYMT, SUMPAY, SUMDUD, SUMDEP, OI_CUR
If ROWCNT > 1
   For [F:BSIDUD]BSIDUD0 Where STMCOD=[F:BSIIMPD]STMCOD & LIN=[F:BSIIMPD]LIN
      If find([F:BSIDUD]NUM,INV00)
         If OI_CUR = ""                                   # X3-42422 Bader 2017-07-18
            OI_CUR = [F:BSIDUD]CUR
         Elsif OI_CUR <> [F:BSIDUD]CUR                    # all open items need to be of the same currency
            If PLOG
              Call ECR_TRACE (func AFNC.MES3(mess(234,7703,1),[F:BSIDUD]CUR,[F:BSIDUD]NUM,OI_CUR),0) From GESECRAN
            Endif
            Break
         Endif
         [L]SUMPAYMT += [F:BSIDUD]BSIBAL*[F:BSIDUD]SNS    # X3-42422 Bader 2017-07-13 BSIBAL holds either amount in OI currency or in transaction currency
         OPENAMTTRS = [F:BSIDUD]AMTLOC-[F:BSIDUD]TMPLOC-[F:BSIDUD]PAYLOC
         [L]SUMPAY += OPENAMTTRS                          # SUMPAY holds open amount before subtracting discount, SUMPAYMT after subtracting discount
         [F:DUD] = [F:BSIDUD]                             # [F:DUD] is used in CALC_ALL_DISCOUNTS and needs to hold the correct record
         Gosub CALC_ALL_DISCOUNTS                         # calculate discount in OI and transaction currency
         [L]SUMDEP += [L]LDEPAMTTRS                       # SUMDEP and SUMPAY needed for pro rata calculation of "Paid" in transaction currency
      Endif
   Next
   If [F:BSIIMPD]AMTCUR*SIGN = [L]SUMPAYMT
     If PLOG
       Call ECR_TRACE (func AFNC.MES2(mess(215,7703,1),num$([L]SUMPAYMT),num$([F:BSIIMPD]AMTCUR*SIGN)),0) From GESECRAN
     Endif
     Gosub WRITE_ALL_BSIDUD
   Else                                   # X3-42422 Bader 2017-07-18 if not equal > check currency variance
     If IS_CUR and [F:BSIIP]AMTVARCUR <> 0  Then                   # check currency amount variance (percentage)
        [L]LDIFF = [L]SUMPAYMT - [F:BSIIMPD]AMTCUR*SIGN
# 2017-08-22 DNE MODIF BEGIN (Prevention of "Division by 0")
        If abs([L]LDIFF) * 100 <= [F:BSIIP]AMTVARCUR * [L]SUMPAYMT Then
# 2017-08-22 DNE MODIF ORIG
#        If abs([L]LDIFF)*100/[L]SUMPAYMT <= [F:BSIIP]AMTVARCUR Then
# 2017-08-22 DNE MODIF END
          If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(235,7703,1),num$([L]SUMPAYMT)),0) From GESECRAN : Endif
          IN_RANGE = 1
          Gosub CALC_TRS_DISCOUNT                     # calculate discount for transcation amount (needed for pro rata calculation of "Paid discount"
          Gosub WRITE_ALL_BSIDUD
        Endif
        Raz [L]LDIFF                      # no overpayment
     Endif
   Endif

   If IMPS_OK                           # X3-42422 Bader 2017-07-11 add "AC"
      If !IS_CUR
          [F:BSIIMPD]LET = "A"
      Else
          [F:BSIIMPD]LET = "AC"
      Endif
   Endif
Endif
Return


############################################################################################
# X3-42422 bader 2017-07-18
$WRITE_ALL_BSIDUD
Raz SUMPAYRND, SUMDEPRND            # 2017-09-27 Bader avoid rounding issues
IMPS_OK = 1
For [F:BSIDUD]BSIDUD0 Where STMCOD=[F:BSIIMPD]STMCOD & LIN=[F:BSIIMPD]LIN & find([F:BSIDUD]NUM,INV00)
  If NUMIMPS = 0                    # MT940, CSV
      Gosub WRITE_BSIDUD
  Else                              # CAMT
      POSINV00 = find([F:BSIDUD]NUM, INV00)
      If NUMIMPS = 1 or INV03(POSINV00-1) = 0   # exactly one subdetail or no amount in subdetail
        Gosub WRITE_BSIDUD
      Else                                      # check if amount fits or within tolerance range
          If IN_RANGE or INV03(POSINV00-1) = [F:BSIDUD]BSIBAL*[F:BSIDUD]SNS
            Gosub WRITE_BSIDUD
          Else
            IMPS_OK = 0
            If PLOG
              Call ECR_TRACE (func AFNC.MES3(mess(214,7703,1),num$([F:BSIDUD]BSIBAL*[F:BSIDUD]SNS),[F:BSIDUD]NUM,num$(INV03(POSINV00-1))),0) From GESECRAN
            Endif
          Endif
      Endif
  Endif
Next
# 2017-09-27 Bader avoid rounding issues start
If ([L]SUMPAYRND <> [F:BSIIMPD]AMTCUR) or ([L]SUMDEPRND <> [L]SUMDEPAMTTRS) # rounding issue
    If [L]SUMPAYRND <> [F:BSIIMPD]AMTCUR      # rounding issue in transaction amount
        [F:BSIDUD]BSIPAYSTM = [F:BSIDUD]BSIPAYSTM + [F:BSIIMPD]AMTCUR - [L]SUMPAYRND # add rounding difference to last open item in BSIDUD
    Endif
    If [L]SUMDEPRND <> [L]SUMDEPAMTTRS      # rounding issue in total discount amount
        [F:BSIDUD]BSIDEPSTM += ([L]SUMDEPAMTTRS - [L]SUMDEPRND) # add rounding difference to last open item in BSIDUD
    Endif
    Rewrite [F:BSIDUD]                                        # ... and save it again
Endif
# 2017-09-27 Bader avoid rounding issues end
Return




############################################################################################
$WRITE_BSIDUD
[F:BSIDUD]DUDSEL    = [V]CST_AYES
# X3-42422 Bader 2017-07-13
OPENAMTCUR = [F:BSIDUD]AMTCUR-[F:BSIDUD]TMPCUR-[F:BSIDUD]PAYCUR
OPENAMTTRS = [F:BSIDUD]AMTLOC-[F:BSIDUD]TMPLOC-[F:BSIDUD]PAYLOC
Gosub CALC_ALL_DISCOUNTS                    # calculate discount in OI and transaction currency
[F:BSIDUD]BSIDEPCUR = [L]LDEPAMTCUR
[F:BSIDUD]BSIPAYCUR = [L]OPENAMTCUR - [L]LDEPAMTCUR # set "Paid" in OI currency to remaining amount of OI in currency (we assume it is fully paid)
If !IN_RANGE # no currency variance
    [F:BSIDUD]BSIPAYSTM = [L]OPENAMTTRS - [L]LDEPAMTTRS
    [F:BSIDUD]BSIDEPSTM = [L]LDEPAMTTRS
Else # currency variance
    # set "Paid" in transaction currency on a pro rata basis of the open item total amount in transaction currency
    Call LECTURE("TCU",[F:BSIDUD]CUR,"") From CONTOBJ        # read currency table
    If [L]SUMDEP = 0 or [L]SUMDEPAMTTRS = 0         # 2017-09-27 Bader avoid division by zero
        [F:BSIDUD]BSIDEPSTM = 0
    Else
        [F:BSIDUD]BSIDEPSTM = arr([L]LDEPAMTTRS/[L]SUMDEP*[L]SUMDEPAMTTRS,[F:TCU]CURRND) # rounding
    Endif
    If [L]SUMPAY = 0 or [F:BSIIMPD]AMTCUR = 0         # 2017-09-27 Bader avoid division by zero
        [F:BSIDUD]BSIPAYSTM = 0
    Else
        [F:BSIDUD]BSIPAYSTM = arr([L]OPENAMTTRS/[L]SUMPAY*[F:BSIIMPD]AMTCUR,[F:TCU]CURRND) # rounding
    Endif
Endif
Raz [F:BSIDUD]BSIPAYLOC                     # payment amount in ledger currency always 0 as not used and not displayed
Raz [F:BSIDUD]BSIDEPLOC                     # discount amount in ledger currency always 0 as not used and not displayed
If [F:BSIDUD]CUR = [F:BSIIMPD]CUR
    [F:BSIDUD]BSIBAL = [F:BSIDUD]BALDUD - [F:BSIDUD]BSIPAYCUR - [F:BSIDUD]BSIDEPCUR    # X3-42422 Bader 2017-07-13 BSIBAL holds either amount in OI currency or in transaction currency
Else
    [F:BSIDUD]BSIBAL = [F:BSIDUD]BALDUD - [F:BSIDUD]BSIPAYSTM - [F:BSIDUD]BSIDEPSTM
Endif
# X3-42422 Bader 2017-07-13 end
SUMDUD += 1
[L]SUMPAYRND += [F:BSIDUD]BSIPAYSTM         # 2017-09-27 Bader avoid rounding issues
[L]SUMDEPRND += [F:BSIDUD]BSIDEPSTM         # 2017-09-27 Bader avoid rounding issues
Rewrite [F:BSIDUD]
Return



############################################################################################
$SET_MATCHING_FLAG
If  [F:BSIIMPD]LET = "A" or [F:BSIIMPD]LET = "AC"  # already matched with "A"/"AC"    X3-42422 Bader 2017-07-11 add "AC"
   If  [F:BSIIMPD]DUDNUM <> 0             # open item assigned?  # TODO: why only for 1:1 hits, not for more than 1 open items???
       Return                             # yes > finished
   Endif
Endif

If [L]ROWCNT > 0  and [L]SUMDUD >=1    # open items found and more than 1 summarized > "A"/"AC" or "B"/"BC"
   If IMPS_OK                          # if all subdetail amounts fit the open item amounts (always true if no subdetails exist)
       If !IS_CUR                      # X3-42422 Bader 2017-07-11 add "AC"
          [F:BSIIMPD]LET = "A"
          If PLOG : Call ECR_TRACE (mess(163,7703,1),0) From GESECRAN : Endif
       Else
          [F:BSIIMPD]LET = "AC"
          If PLOG : Call ECR_TRACE (mess(233,7703,1),0) From GESECRAN : Endif
       Endif
   Else
       If !IS_CUR                      # X3-42422 Bader 2017-07-11 add "BC"
          [F:BSIIMPD]LET = "B"
          If PLOG : Call ECR_TRACE (mess(164,7703,1),0) From GESECRAN : Endif
       Else
          [F:BSIIMPD]LET = "BC"
          If PLOG : Call ECR_TRACE (mess(232,7703,1),0) From GESECRAN : Endif
       Endif
   Endif
Elsif [L]ROWCNT > 0  and [L]SUMDUD =0     # open items found but no matching > "B"/"BC"
   If !IS_CUR                      # X3-42422 Bader 2017-07-11 add "BC"
      [F:BSIIMPD]LET = "B"
      If PLOG : Call ECR_TRACE (mess(164,7703,1),0) From GESECRAN : Endif
   Else
      [F:BSIIMPD]LET = "BC"
      If PLOG : Call ECR_TRACE (mess(232,7703,1),0) From GESECRAN : Endif
   Endif
Else                                      # even no open items found > "C"
   If left$([F:BSIIMPD]LET,1) <> "A" and left$([F:BSIIMPD]LET,1) <> "B"  # don't change already existing match
      [F:BSIIMPD]LET = "C"
      If PLOG : Call ECR_TRACE (mess(165,7703,1),0) From GESECRAN : Endif
   Endif
Endif
If [BSIIMPD]LET = "B" or [BSIIMPD]LET = "BC" or [F:BSIIMPD]LET = "C" : Raz [F:DUD] : Endif    # prevent writing of DUD fields to BSIIMPD for B and C hits
Gosub SET_BSIIMPD
Return


############################################################################################
$FIND_OPEN_ITEMS
Local Integer N, ROWCNT, MAXROW
Local Integer SUMDUD, POSINV00, PAID, POSBPY00, IMPS_OK
Local Decimal SUMPAYMT, OPENAMTCUR, OPENAMTTRS, LDEPAMT, LOPENAMT, SUMDEP, SUMPAY, SUMPAYRND, SUMDEPRND
Local Decimal LDIFF    # difference between open item amount and transaction amount > calculated in CHECK_AMOUNT for amount variance

Raz N, ROWCNT, MAXROW, OKAMT, LDEPAMT, PAID, IS_CUR
MAXROW = func AFNC.ACTIV("BSINB")                 # Maximum number of open items, controlled by sizing activity code BSINB

If FBIDNUM<>2 & FBPRNAM<>2 & FINVNUM<>2 & FBVRREF<>2 & FSRCDOC<>2 & FSOHNUM<>2 & FAMT<>2 & FBPR<>2  # nothing found > no loop over GACCDUDATE
   If PLOG : Call ECR_TRACE (mess(166,7703,1),-1) From GESECRAN : Endif
   Goto SET_MATCHING
Endif

If PLOG
    If (S > 0 and S <= 10)            # not more than 10 BPs found > log them
        Raz TMPSTR : TMPSTR = BPY00(0)
        For L=1 To S-1
            TMPSTR -= ","-BPY00(L)
        Next
        Call ECR_TRACE (func AFNC.MES1(mess(167,7703,1),TMPSTR)-"(BPY00)",0) From GESECRAN
    Elsif S > 10
        Call ECR_TRACE (mess(168,7703,1)-"(BPY00)",0) From GESECRAN
    Endif
    If (S1 > 0 and S1 <= 10)           # not more than 10 invoice numbers found > log them
        Raz TMPSTR : TMPSTR = INV00(0)
        For L=1 To S1-1
            TMPSTR -= ","-INV00(L)
        Next
        Call ECR_TRACE (func AFNC.MES1(mess(169,7703,1),TMPSTR)-"(INV00)",0) From GESECRAN
    Elsif S1 > 10
        Call ECR_TRACE (mess(170,7703,1)-"(INV00)",0) From GESECRAN
    Endif
Endif

Gosub BUILD_CRITERIA
If (CRITERE2 ="1=1" & CRITERE3 ="1=1" and [F:BSIIP]AMT <> 2)  # neither business partner nor invoice number or order number or source document found
  Goto SET_MATCHING                                           # > no loop over GACCDUDATE
Endif

# loop over GACCDUDATE
# 2016-09-21 DNE MODIF BEGIN (x3-3936)
# Note: At the moment we do not support prepayment open items so we have to remove
#       open items with TYP "*SO" and "*PO".
For [F:DUD] Where evalue(CRITERE) & evalue(CRITERE2) & evalue(CRITERE3) & !find(TYP,'*SO','*PO')
# 2016-09-21 DNE MODIF END
   IS_CUR = [F:DUD]CUR <> [F:BSIIMPD]CUR
   Raz[F:BSIDUD]
   Raz OKAMT, POSINV00, POSBPY00
   OPENAMTCUR = [F:DUD]AMTCUR-[F:DUD]TMPCUR-[F:DUD]PAYCUR
   OPENAMTTRS = [F:DUD]AMTLOC-[F:DUD]TMPLOC-[F:DUD]PAYLOC

   Filter [F:BSIDUD] Where NUMDUD = [F:DUD]NUMDUD and [F:BSIDUD]DUDSEL = [V]CST_AYES  # check if open item already matched to a transaction and selected
   Read [F:BSIDUD] First
   If !fstat     # is yes > skip it
      If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(171,7703,1),[F:DUD]NUM),-1) From GESECRAN : Endif
      Goto BEGINLOOP
   Endif
   Filter [F:BSIDUD]

   Gosub CHECK_AMOUNT

   ROWCNT += 1
   If ROWCNT > MAXROW                             # more than MAXROW open items not allowed, see sizing activity code BSINB
      PMSG = PSTMCOD + "~" + num$(PLIN) - func AFNC.MES1( mess(38,7703,1), num$( MAXROW ) ) # 'More than $1$ matching open items found'
      If PLOG : Call ECR_TRACE (PMSG,0) From GESECRAN : Endif
      Break
   Endif

   N += 1
   [F:BSIDUD]       = [F:DUD]
   [F:BSIDUD]CPY    = [F:BSIIMPD]CPY
   [F:BSIDUD]BAN    = [F:BSIIMPD]BAN
   [F:BSIDUD]STMCOD = PSTMCOD
   [F:BSIDUD]LIN    = PLIN
   [F:BSIDUD]LIN1   = N
   If [F:DUD]CUR = [F:BSIIMPD]CUR           # same currency > use OI currency
       [F:BSIDUD]DEPAMT = [L]LDEPAMTCUR
       [F:BSIDUD]BALDUD = abs([F:DUD]AMTCUR-[F:DUD]TMPCUR-[F:DUD]PAYCUR)
   Else
       [F:BSIDUD]DEPAMT = [L]LDEPAMTTRS
       [F:BSIDUD]BALDUD = abs([F:DUD]AMTLOC-[F:DUD]TMPLOC-[F:DUD]PAYLOC)
   Endif

# Bader: 2016-10-28 X3-6249
   If [F:BSIIMPD]SNS = "C" or [F:BSIIMPD]SNS = "RD" : [F:BSIDUD]BSISNS = [F:DUD]SNS : Endif
   If [F:BSIIMPD]SNS = "D" or [F:BSIIMPD]SNS = "RC" : [F:BSIDUD]BSISNS = -[F:DUD]SNS : Endif
# Bader: 2016-10-28 X3-6249 end

   Gosub SET_FOUND_FLAGS
   [F:BSIDUD]BSIBAL = abs([F:BSIDUD]BALDUD - [F:BSIDUD]DEPAMT)

   If [F:BSIIMPD]LET <> "A" & [F:BSIIMPD]LET <> "AC" & [L]OKAMT > 0    # X3-42422 Bader 2017-07-11 add "AC"
     POSINV00 = find([F:DUD]NUM, INV00)
     POSBPY00 = find([F:DUD]BPR, BPY00)
     If POSINV00>0 | POSBPY00 >0
       If POSBPY00>0 | INV02(POSINV00-1) <> "0000"        # 2017-06-21 Bader
         [F:BSIDUD]BSIDEPCUR = [L]LDEPAMTCUR
         [F:BSIDUD]BSIDEPSTM = [L]LDEPAMTTRS
         Raz [F:BSIDUD]BSIDEPLOC                      # "Discount" in ledger currency always 0, as not displayed and not used
         Raz [F:BSIDUD]BSIPAYLOC                      # "Paid" in ledger currency always 0, as not displayed and not used
         If [L]OKAMT = 2                              # amount fitting exactly
            [F:BSIDUD]BSIPAYCUR = abs([F:DUD]AMTCUR-[F:DUD]TMPCUR-[F:DUD]PAYCUR-[L]LDEPAMTCUR)
            If [F:DUD]CUR <> [F:BSIIMPD]CUR           # case B: transaction currency = company currency
                [F:BSIDUD]BSIPAYSTM = abs([F:DUD]AMTLOC-[F:DUD]TMPLOC-[F:DUD]PAYLOC-[L]LDEPAMTTRS)
            Else                                      # case A/C: transaction currency = OI currency
                [F:BSIDUD]BSIPAYSTM = [F:BSIDUD]BSIPAYCUR   # identical values for BSIPAYSTM
            Endif
         Else                                         # amount within defined tolerances
            If [F:BSIDUD]CUR = [F:BSIIMPD]CUR         # case A/C: transaction currency = OI currency
                If [L]LDIFF < 0                       # overpayment
                   [F:BSIDUD]BSIPAYCUR = [L]OPENAMTCUR
                   [F:BSIDUD]BSIPAYSTM = [L]OPENAMTTRS
                Else
                   [F:BSIDUD]BSIPAYCUR = [L]OPENAMTCUR - [L]LDIFF
                   [F:BSIDUD]BSIPAYSTM = [L]OPENAMTTRS - [L]LDIFF
                Endif
            Else                                      # case B: transaction currency = company currency
                # currency variance
                [F:BSIDUD]BSIPAYCUR = [L]OPENAMTCUR - [L]LDEPAMTCUR  # set "Paid" in OI currency to remaining amount of OI in currency (we assume it is fully paid)
                [F:BSIDUD]BSIPAYSTM = [F:BSIIMPD]AMTCUR              # set "Paid" in transaction currency to transaction amount (we assume it is fully paid)
            Endif
         Endif

         PAID = 1
         If [F:DUD]CUR = [F:BSIIMPD]CUR           # X3-42422 case A/C: transaction currency = OI currency # case B: transaction currency = company currency
             [F:BSIIMPD]LET = "A"
             If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(173,7703,1),[F:DUD]NUM),-1) From GESECRAN : Endif
         Else                                     # case B: transaction currency = company currency
             [F:BSIIMPD]LET = "AC"
             If PLOG : Call ECR_TRACE (func AFNC.MES1(mess(231,7703,1),[F:DUD]NUM),-1) From GESECRAN : Endif
         Endif
         [F:BSIDUD]DUDSEL    = [V]CST_AYES
         Gosub SET_BSIIMPD
       Endif
     Endif
   Endif

   If [F:DUD]TYP<>"*SO" & [F:DUD]TYP<>"*PO" & [F:DUD]TYP<>""
     Read [F:HAE]HAE0 = [F:DUD]TYP;[F:DUD]NUM
     If !fstat
        [F:BSIDUD]BPRVCR = [F:HAE]BPRVCR
     Endif
   Endif

   Write [F:BSIDUD]

   $BEGINLOOP
Next

$SET_MATCHING
Gosub UPDATE_BSIDUD
Gosub SET_MATCHING_FLAG

# ensure all selected open items belong to the same site
Gosub ENSURE_SAME_SITE

# 2016-11-11 Bader X3-1501 search term list implementation
# For "C" hits: matching by search term list if parameter "Use search term list" is set to "Last pass"
If [F:BSIIMPD]LET = "C" and [F:BSIIP]USESEALIS = 3 Then  # parameter "Use search term list" set to "Last pass"?
    If PLOG
        Call ECR_TRACE ("#########################################################################################",0) From GESECRAN
        Call ECR_TRACE (mess(95,7703,1),0) From GESECRAN
    Endif
    Gosub MATCH_SEARCH_TERM_LIST From BSILIBMTCSEA
    If SEALIS_FOUND : Return : Endif           # if search term list hit > end
Endif
# 2016-11-11 Bader X3-1501 search term list implementation end

# update record in table BSIIMPD
Rewrite [F:BSIIMPD]
Return

########################################################################################################################

$ENSURE_SAME_SITE
If [F:BSIIMPD]LET = "A" or [F:BSIIMPD]LET = "AC" Then       # X3-42422 Bader 2017-07-11 add "AC"
    Local Char LFCY(GLONFCY)
    Filter [F:BSIDUD] Where [F:BSIDUD]STMCOD = PSTMCOD and [F:BSIDUD]LIN = PLIN and [F:BSIDUD]DUDSEL = [V]CST_AYES
    Read [F:BSIDUD] First
    If fstat = 0 Then
        [L]LFCY = [F:BSIDUD]FCY
    Endif
    # loop over BSIDUD
    For [F:BSIDUD]
        If [F:BSIDUD]FCY <> [L]LFCY Then
            If !IS_CUR                                      # X3-42422 Bader 2017-07-11 add "BC"
                [F:BSIIMPD]LET = "B"
            Else
                [F:BSIIMPD]LET = "BC"
            Endif
            If PLOG : Call ECR_TRACE (mess(174,7703,1),-1) From GESECRAN : Endif
            Break
        Endif
    Next
    Filter [F:BSIDUD]

    If [F:BSIIMPD]LET = "B" or [F:BSIIMPD]LET = "BC" Then   # X3-42422 Bader 2017-07-11 add "BC"
        # reset the flag
        Update [F:BSIDUD] Where [F:BSIDUD]STMCOD = PSTMCOD and [F:BSIDUD]LIN = PLIN and [F:BSIDUD]DUDSEL = [V]CST_AYES With [F:BSIDUD]DUDSEL = [V]CST_ANO
    Endif
Endif
Return

######################################################################################################

#**
#* Purpose: Unmatch a transaction.
#*
#* @param PSTMCOD      primary key for reading record in table BSIIMP.
#* @param PLIN         second part of primary key for reading record in table BSIIMPD (PSTMCOD+PLIN).
#* @param PSTA         status of matching 0 : OK, 1 : already matched, 2 : import/statement not found, 3 : various.
#* @param PMSG         Message corresponding to status.
#*!
Subprog BSI_UNMATCH(PSTMCOD,PLIN,PSTA,PMSG)
Value Char PSTMCOD     # File statement, part of key to table BSIIMP/BSIIMPD
Value Integer PLIN     # Line number of statement, part of key to table BSIIMPD
Variable Integer PSTA  # Status of matching 0 : OK, 1 : import/statement not found, 2 : already validated, 3 : database problems
Variable Char PMSG     # Message corresponding to the status

    PSTA = 0 : Raz PMSG

    If !clalev ([F:BSIIMPD]) :  Local File BSIIMPD     [BSIIMPD] : Endif # Details import
    If !clalev ([F:BSIDUD])  :  Local File BSIDUD      [BSIDUD]  : Endif # Open items for one transaction
    If !clalev ([F:BSIMAN])  :  Local File BSIMANENT   [BSIMAN]  : Endif # Manually created matchings.

    Read [F:BSIIMPD]BSIIMPD0 = PSTMCOD; PLIN  # Read transaction
    If fstat # Not found?
        PSTA = 1
        PMSG = [F:BSIIMPD]STMCOD + "~" + num$( [F:BSIIMPD]LIN ) - mess(23,100,1) # 'Record does not exist'
    Elsif [F:BSIIMPD]FLGCRE >= 2 # Already validated, partially validated or manually closed?
        PSTA = 2
        PMSG = [F:BSIIMPD]STMCOD + "~" + num$( [F:BSIIMPD]LIN ) - mess(64,119,1) # 'Entry matched, cannot delete'
    Else
        # Reset manually created matchings.
        Delete [F:BSIMAN]  Where STMCOD = PSTMCOD and LIN = PLIN
        If fstat
            PSTA = 3
            PMSG = [F:BSIIMPD]STMCOD + "~" + num$( [F:BSIIMPD]LIN ) - mess(4,7703,1) # "Transaction cannot be deleted"
        Else
            # Reset open item information.
            Delete [F:BSIDUD]  Where STMCOD = PSTMCOD and LIN = PLIN
            If fstat
                PSTA = 3
                PMSG = [F:BSIIMPD]STMCOD + "~" + num$( [F:BSIIMPD]LIN ) - mess(4,7703,1) # "Transaction cannot be deleted"
            Else
                Gosub RESET_BSIIMPD
                Rewrite [F:BSIIMPD]
                If fstat
                    PSTA = 3
                    PMSG = [F:BSIIMPD]STMCOD + "~" + num$( [F:BSIIMPD]LIN ) - mess(5,7703,1) # "Transaction cannot be updated"
                Endif
            Endif
        Endif
    Endif
End

######################################################################################################

#**
#* Purpose: Match a whole statement.
#*
#* @param PSTMCOD      primary key for reading record in table BSIIMP.
#* @param PSTA         status of matching 0 : OK, 1 : already matched, 2 : import/statement not found, 3 : various, 4 : Symbol locked
#* @param PMSG         Message corresponding to status.
#* @param PMSG         Write detailed log? 1 = yes, 0 = no
#* #*!
Subprog BSI_MATCH_STATEMENT( PSTMCOD, PSTA, PMSG, PLOG )
Value Char PSTMCOD     # File statement, part of key to table BSIIMP/BSIIMPD
Variable Integer PSTA  # Status of matching 0 : OK, 1 : import/statement not found, 2 : already validated, 3 : various, 4 : Symbol locked
Variable Clbfile PMSG  # Message corresponding to the status
Value Integer PLOG     # Write detailed log? 1 = yes, 0 = no
Local Clbfile MSG
Local Integer FLGTRACE : If GTRACE = "" : FLGTRACE = 1 : Else : FLGTRACE = 0 : Endif # Check for an existing log file (FLGTRACE = 1, 0 otherwise).

    If PLOG
        If FLGTRACE : Call OUVRE_TRACE( mess(40,7703,1) ) From LECFIC : Endif           # Open trace file.
        Call ECR_TRACE (func AFNC.MES1(mess(193,7703,1),PSTMCOD),0) From GESECRAN
    Endif

    If !clalev ([F:BSIIMP])    Local File BSIIMP      [BSIIMP]  Endif # Header import
    If !clalev ([F:BSIIMPD])   Local File BSIIMPD     [BSIIMPD] Endif # Details import

    Local Char SYMBOL(255)     # Contains the symbol to lock while updates are in progress.

    # Initialize variables
    Raz PMSG, PSTA

    # Do some pre-checkings on the header (statement) before looping over all
    # its transactions.
    Read [F:BSIIMP]BSIIMP0 = PSTMCOD  # Read statement (import header)
    If fstat # Not found?
        PMSG =  PSTMCOD - mess(1,7703,1) # 'Statement does not exist'
        PSTA = 2
    Elsif [F:BSIIMP]FLGMTC >= 3 # Already validated?
        PMSG = PSTMCOD - mess(2,7703,1) # 'Statement already validated'
        PSTA = 1
    Else
        # Loop over set of transactions.
        For [F:BSIIMPD]BSIIMPD0 Where [F:BSIIMPD]STMCOD = PSTMCOD
            # Try to lock the current MDT object.
            SYMBOL = "BSIIMPD~" + num$([F:BSIIMPD]LIN) +"\" + [F:BSIIMPD]STMCOD
            Lock =SYMBOL With lockwait = 0
            If fstat
                # Locking was not possible.
                PSTA = 4
                PMSG = SYMBOL - mess(124,187,1)
            Else
                Raz MSG
                Call BSI_MATCHING( [F:BSIIMPD]STMCOD, [F:BSIIMPD]LIN, PSTA, MSG, PLOG )
                Unlock =SYMBOL
                If PSTA >= 2
                    Break
                Endif
                If MSG <> ""
                    If PMSG <> ""
                      Append PMSG, chr$(13) + chr$(10) + MSG
                    Else
                      Append PMSG, MSG
                    Endif
                Endif
                Raz PSTA
            Endif
        Next
    Endif

    # Note: We correct the statement status even in the case of errors for there migth be minor
    #       errors we ignored while running the loop.
    Call BSI_UPDATE_STATEMENT_STATE( PSTMCOD )

    If PLOG
        If PSTA : Call ECR_TRACE (PMSG,1) From GESECRAN : Endif
        # Close and show trace file.
        If FLGTRACE
            Call FERME_TRACE From LECFIC
            Call LEC_TRACE From LECFIC
        Endif
    Endif
End


######################################################################################################

#**
#* Purpose: Update status of a whole statement.
#*
#* @param PSTMCOD      primary key for reading record in table BSIIMP.
#*!
Subprog BSI_UPDATE_STATEMENT_STATE( PSTMCOD )
Value Char PSTMCOD     # File statement, part of key to table BSIIMP/BSIIMPD

    If !clalev ([F:BSIIMP])    Local File BSIIMP      [BSIIMP]  Endif # Header import
    If !clalev ([F:BSIIMPD])   Local File BSIIMPD     [BSIIMPD] Endif # Details import
# 2017-09-21 DNE INSERT BEGIN (X3-55850)
    If !clalev([F:BSIIP])      Local File BSIIMPPAR   [BSIIP]   Endif # Import settings
# 2017-09-21 DNE INSERT END

    # Start database transaction
    Local Integer SAVADXLOG : SAVADXLOG = adxlog

    If !SAVADXLOG
        Trbegin [F:BSIIMP], [F:BSIIMPD]
    Endif

    # If there is no unvalidated transaction set statement to "Validated".
    Filter [F:BSIIMPD] Where STMCOD = PSTMCOD and (FLGCRE = 1 or FLGCRE = 3)  # not validated or partially validated
    Read [F:BSIIMPD]BSIIMPD0 First
    Filter [F:BSIIMPD]
    If fstat
# 2017-09-21 DNE MODIF BEGIN (X3-55850)
        # Check if 'Validated' or 'Reconcile' is the correct status.
        #
        # Read import settings
        Read [F:BSIIP]BSIIP0 = [F:BSIIMP]CODIMPPAR
        If !fstat and [F:BSIIP]FLOTYP = 2
            Update [F:BSIIMP] Where STMCOD = PSTMCOD With FLGMTC = 4 # Reconcile
        Else
            Update [F:BSIIMP] Where STMCOD = PSTMCOD With FLGMTC = 3 # Validated
        Endif
# 2017-09-21 DNE MODIF ORIG
#        Update [F:BSIIMP] Where STMCOD = PSTMCOD With FLGMTC = 3 # Validated
# 2017-09-21 DNE MODIF END
        Goto LEAVE
    Endif

    # We have unvalidated transactions so if there is no unmatched transaction
    # set statement to "Matched".
    Filter [F:BSIIMPD] Where STMCOD = PSTMCOD and LET = ""
    Read [F:BSIIMPD]BSIIMPD0 First
    Filter [F:BSIIMPD]
    If fstat
        Update [F:BSIIMP] Where STMCOD = PSTMCOD With FLGMTC = 2 # Matched
        Goto LEAVE
    Endif

    # In any other case set statement to "Unmatched".
    Update [F:BSIIMP] Where STMCOD = PSTMCOD With FLGMTC = 1     # Else: Unmatched

$LEAVE
    If !SAVADXLOG
        Commit
    Endif
End

