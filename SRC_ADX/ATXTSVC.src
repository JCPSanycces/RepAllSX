#<AdxTL>@(#)0.0.0.0 $Revision$
# Interface with Texts server

# Recherche d’un numéro par rapport à un texte et une langue
# Liste des numéro/texte/commentaire se rapprochant

#######################################################
### ATEXTE functions
#######################################################

#**
#* Deletes  a text (ATEXTE) for a given product, number and language
#* the TEXT is kept in the database!
#* @param PRODUCT
#* @param NUM
#* @param LAN
#* @param MESSAGE: A message in case of error
#*!
Funprog DELETE_TEXT(PRODUCT, NUM, MESSAGE)
  Value Integer PRODUCT
  Value Integer NUM
  Variable Char MESSAGE
End func HELPER_DELETE_TEXT(PRODUCT, NUM, MESSAGE,"true")

#**
#* !! INTERNAL ONLY !!
#* Deletes  a text (ATEXTE) for a given product, number and language
#*
#* @param PRODUCT
#* @param NUM
#* @param LAN
#* @param MESSAGE: A message in case of error
#*!
Funprog _QLF_DELETE_TEXT(PRODUCT, NUM, MESSAGE)
  Value Integer PRODUCT
  Value Integer NUM
  Variable Char MESSAGE
End func HELPER_DELETE_TEXT(PRODUCT, NUM, MESSAGE,"false")

Funprog HELPER_DELETE_TEXT(PRODUCT, NUM, MESSAGE, KEEP)
 Value Integer PRODUCT
 Value Integer NUM
 Variable Char MESSAGE
 Value Char KEEP

  Local Clbfile RESHEAD, RESBODY
  Local Clbfile ARGUMENTS(0)
  Raz ARGUMENTS

  Local Integer ASTATUS:ASTATUS =[V]CST_AERROR
  Local Integer HTTP_STATUS

  ARGUMENTS =   '"' + func ADD_PRODUCT(PRODUCT) + '",' + num$(NUM) + ',' + KEEP
 HTTP_STATUS =  func TEXT_HELPER('deleteText', ARGUMENTS, RESHEAD, RESBODY)
  If find(HTTP_STATUS, [V]CST_AHTTP_OK, [V]CST_AHTTP_CREATED)
   ASTATUS =[V]CST_AOK
 Else
  MESSAGE = RESBODY
 Endif
End ASTATUS

#**
#* Returns a text (ATEXTE) for a given product, number and language
#*
#* @param PRODUCT
#* @param NUM
#* @param LAN
#* @param TEXT: the text to be found
#* @param MESSAGE: A message in case of error
#*!
Funprog GET_TEXT(PRODUCT, NUM, LAN, TEXT,MESSAGE)
  Value Integer PRODUCT
  Value Integer NUM
  Value Char LAN
  Variable Clbfile TEXT
  Variable Char MESSAGE

  Local Clbfile RESHEAD, RESBODY
  Local Clbfile ARGUMENTS(0)
  Local Integer ASTATUS:ASTATUS =[V]CST_AERROR
  Local Integer HTTP_STATUS

  Raz ARGUMENTS

  If NUM<=0 | LAN=""
   MESSAGE=mess(67,103,1)+"("+LAN-num$(NUM)+")"
   ASTATUS=[V]CST_AERROR
   End ASTATUS
  Endif

  ARGUMENTS = '"' + func ADD_PRODUCT(PRODUCT) + '",' + num$(NUM) + ',"' + LAN + '"'
  HTTP_STATUS = func TEXT_HELPER('getText', ARGUMENTS, RESHEAD, RESBODY)
  If find(HTTP_STATUS, [V]CST_AHTTP_OK, [V]CST_AHTTP_CREATED)
   ASTATUS =[V]CST_AOK
   TEXT =  RESBODY :# if ok the body contains the text
  Else
   MESSAGE = RESBODY:# if nok the body contains a message
  Endif
End ASTATUS

#**
#* Returns the LANORI  for a given product, number and language
#*
#* @param PRODUCT
#* @param NUM
#* @param LAN
#* @param LANORI
#* @param MESSAGE: A message in case of error
#*!
Funprog GET_LANORI(PRODUCT, NUM, LAN, LANORI,MESSAGE)
  Value Integer PRODUCT
  Value Integer NUM
  Value Char LAN
  Variable Char LANORI
  Variable Char MESSAGE

  Local Clbfile RESHEAD, RESBODY
  Local Clbfile ARGUMENTS(0)
  Local Integer ASTATUS:ASTATUS =[V]CST_AERROR
  Local Integer HTTP_STATUS

  Raz ARGUMENTS, LANORI

  ARGUMENTS = '"' + func ADD_PRODUCT(PRODUCT) + '",' + num$(NUM) + ',"' + LAN + '"'
  HTTP_STATUS = func TEXT_HELPER('getTextOriginalLanguage', ARGUMENTS, RESHEAD, RESBODY)
  If find(HTTP_STATUS, [V]CST_AHTTP_OK, [V]CST_AHTTP_CREATED)
   ASTATUS =[V]CST_AOK
   LANORI =  RESBODY :# if ok the body contains the original language
  Else
   MESSAGE = RESBODY:# if nok the body contains a message
  Endif
End ASTATUS

#**
#* Returns a set of information  for a given product and number
#*
#* @param PRODUCT
#* @param NUM
#* @param COUNT: number of texts
#* @param MESSAGE: A message in case of error
#*!
Funprog GET_TEXTINFO(PRODUCT, NUM, COUNT, TBLAN, TBTEXT, TBCOM, TBLANORI, MESSAGE)
  Value Integer PRODUCT
  Value Integer NUM
  Variable Integer COUNT
  Variable Char TBLAN()(1..)
  Variable Char TBTEXT()(1..)
  Variable Char TBCOM()(1..)
  Variable Char TBLANORI()(1..)
  Variable Char MESSAGE

  Local Clbfile RESHEAD, RESBODY
  Local Clbfile ARGUMENTS(0)
  Local Integer ASTATUS:ASTATUS =[V]CST_AERROR
  Local Integer HTTP_STATUS
  Local Char TBETAG(30)(1..)
  Local Integer TBNUM(1..)

  Raz ARGUMENTS,COUNT
  If NUM<=0
   MESSAGE=mess(67,103,1)+"("+LAN-num$(NUM)+")"
   ASTATUS=[V]CST_AERROR
   End ASTATUS
  Endif

  ARGUMENTS = '"' + func ADD_PRODUCT(PRODUCT) + '",' + num$(NUM)
  HTTP_STATUS = func TEXT_HELPER('getTextInfo', ARGUMENTS, RESHEAD, RESBODY)
  If HTTP_STATUS =[V]CST_AHTTP_OK
  Gosub PARSE_TEXTS
  Else
   MESSAGE = RESBODY:# if nok the body contains a message
  Endif
End ASTATUS

#**
#* Returns last modified texts
#*
#* @param PRODUCT
#* @param NUM
#* @param COUNT: number of texts
#* @param MESSAGE: A message in case of error
#*!
Funprog GET_LASTMODIFIED(PRODUCT, ATXTETAG, LIMIT,COUNT, TBNUM, TBLAN, TBTEXT, TBCOM, TBLANORI, MESSAGE)
  Value Integer PRODUCT
  Variable Char ATXTETAG
  Value Integer LIMIT
  Variable Integer COUNT
  Variable Integer TBNUM(1..)
  Variable Char TBLAN()(1..)
  Variable Char TBTEXT()(1..)
  Variable Char TBCOM()(1..)
  Variable Char TBLANORI()(1..)
  Variable Char MESSAGE

  Local Clbfile RESHEAD, RESBODY
  Local Clbfile ARGUMENTS(0)
  Local Integer ASTATUS:ASTATUS =[V]CST_AERROR
  Local Integer HTTP_STATUS

  Raz ARGUMENTS

  #COUNTASK=1000 is hard-coding in ATXTSRVSYNC
  ARGUMENTS = '"' + func ADD_PRODUCT(PRODUCT) + '","' + ATXTETAG + '",'+num$(LIMIT)+','+num$(COUNT)
  #ARGUMENTS = '"' + func ADD_PRODUCT(PRODUCT) + '","' + ATXTETAG + '"'
  HTTP_STATUS = func TEXT_HELPER('getLastModifiedTexts', ARGUMENTS, RESHEAD, RESBODY)
  Raz COUNT
  If HTTP_STATUS =[V]CST_AHTTP_OK
   Gosub PARSE_TEXTS
   If ASTATUS = [V]CST_AOK and COUNT > 1
    ATXTETAG = TBETAG(COUNT-1)
   Endif
  Else
   MESSAGE = RESBODY:# if nok the body contains a message
  Endif
End ASTATUS

$PARSE_TEXTS
  Local Instance  NODES(1..) Using C_ASYRJSO
  Local Instance  NODE         Using C_ASYRJSO
  Local Instance  NODEPRO  Using C_ASYRJSO
  Local Char TBETAG(30)(1..)
  Local Char CNT(250)

  ASTATUS = func ASYRJSONPARSE.PARSEJSON(GACTX,RESBODY,NODES,NODE)
  While NODE <> null
   COUNT += 1
   NODEPRO = NODE.SUB
   While NODEPRO <> null
    CNT = seg$(fmet NODEPRO.AGETCNT,2,len(fmet NODEPRO.AGETCNT)-1)
    Case NODEPRO.PRO
     When "LAN" : TBLAN(COUNT) = CNT
     When "TEXTE" : TBTEXT(COUNT) = CNT
     When "COMMENT" : TBCOM(COUNT) = CNT
     When "LANORI" : TBLANORI(COUNT) = CNT
     When "NUMERO": TBNUM(COUNT) = val(fmet NODEPRO.AGETCNT)
     When "lastModified" : TBETAG(COUNT) = CNT
    Endcase
    NODEPRO = NODEPRO.NEX
   Wend
   NODE = NODE.NEX
  Wend
  FreeGroup  NODES(1)
Return


Funprog HELPER_CREATE_TEXT(LPRODUCT, LANORI, LANGS, TEXT, COMMENT, NUM, MESSAGE, LEGACY)
  Value Integer LPRODUCT
  Value Char LANORI
  Variable Char LANGS()(0..)
  Const Clbfile TEXT
  Const Clbfile COMMENT
  Variable Integer NUM
  Variable Char MESSAGE
  Value Char LEGACY

  Local Clbfile RESHEAD,RESBODY
  Local Clbfile ARGUMENTS(0)
  Local Char PLANGS(250)
  Local Char SEP(1)
  Local Integer AI
  Raz ARGUMENTS
  Raz MESSAGE

  For AI=0 To dim(LANGS)
   Break LANGS(AI) = ""
   PLANGS += SEP + LANGS(AI)
   SEP=','
  Next AI

  Local Integer ASTATUS:ASTATUS =[V]CST_AERROR
  Local Integer HTTP_STATUS
  Local Clbfile WTEXT: WTEXT = TEXT : WTEXT = escJson(WTEXT)
  Local Clbfile WCOMMENT: WCOMMENT = COMMENT : WCOMMENT = escJson(WCOMMENT)

  ARGUMENTS = '"' + func ADD_PRODUCT(LPRODUCT) + '","'  + LANORI +  '","'  + PLANGS + '","' + WTEXT + '","' + WCOMMENT + '",' + LEGACY
  HTTP_STATUS = func TEXT_HELPER('createText', ARGUMENTS, RESHEAD, RESBODY)
  If find(HTTP_STATUS, [V]CST_AHTTP_OK, [V]CST_AHTTP_CREATED)
   ASTATUS =[V]CST_AOK
   NUM =  val(RESBODY) :# if ok the body contains the required number
   If NUM<=0
    MESSAGE=mess(327,123,1)
    ASTATUS=[V]CST_AERROR
   Endif
  Else
   MESSAGE = RESBODY:# if nok the body contains a message
  Endif
End ASTATUS

#**
#* Create a text (ATEXTE)
#*
# CREATE and ATEXTE:
# - The TEXT isn't created if it exists in the database : in this case the function
#   returns the identifier of the existing text.
# - new TEXTS are not assigned to any product
# - new texts number have to be greater than 1000000

# CREATE_TEXT returns [V]CST_AOK if the creation if OK
#*
#* @param LPRODUCT:
#  -1 = "SU"
#   0 = "X3"
#   1 = "GX"
#   2 = "PA"
#   3 = "AB"
#* @param LANORI : original language
#* @param LANGS: set of languages in which the text has to be created
#* @param TEXT : the text to create
#* @param COMMENT : The comment to associate to the text
#* @param NUM: The number generated by the texts server for the text
#* @param MESSAGE: A message in case of error
#*!
Funprog CREATE_TEXT(LPRODUCT, LANORI, LANGS, TEXT, COMMENT, NUM, MESSAGE)
  Value Integer LPRODUCT
  Value Char LANORI
  Variable Char LANGS()(0..)
  Const Clbfile TEXT
  Const Clbfile COMMENT
  Variable Integer NUM
  Variable Char MESSAGE
End func HELPER_CREATE_TEXT(LPRODUCT, LANORI, LANGS, TEXT, COMMENT, NUM, MESSAGE, "false")

Funprog CREATE_TEXT_CHAR(LPRODUCT, LANORI, LANGS, TEXT, COMMENT, NUM, MESSAGE)
  Value Integer LPRODUCT
  Value Char LANORI
  Variable Char LANGS()(0..)
  Value Char TEXT()
  Value Char COMMENT()
  Variable Integer NUM
  Variable Char MESSAGE
End func CREATE_TEXT(LPRODUCT, LANORI, LANGS, TEXT, COMMENT, NUM, MESSAGE)

#**
#* Create a text (ATEXTE)
#*
# CREATE and ATEXTE:
# - The TEXT isn't created if it exists in the database : in this case the function
#   returns the identifier of the existing text.
# - new TEXTS are assigned to a product
# - new texts number have to be lesser than 100000

# CREATE_TEXT_LEGACY returns [V]CST_AOK if the creation if OK
#*
#* @param LPRODUCT:
#  -1 = "SU"
#   0 = "X3"
#   1 = "GX"
#   2 = "PA"
#   3 = "AB"
#* @param LANORI : original language
#* @param LANGS: set of languages in which the text has to be created
#* @param TEXT : the text to create
#* @param COMMENT : The comment to associate to the text
#* @param NUM: The number generated by the texts server for the text
#* @param MESSAGE: A message in case of error
#*!
Funprog CREATE_TEXT_LEGACY(LPRODUCT, LANORI, LANGS, TEXT, COMMENT, NUM, MESSAGE)
  Value Integer LPRODUCT
  Value Char LANORI
  Variable Char LANGS()(0..)
  Const Clbfile TEXT
  Const Clbfile COMMENT
  Variable Integer NUM
  Variable Char MESSAGE
End func HELPER_CREATE_TEXT(LPRODUCT, LANORI, LANGS, TEXT, COMMENT, NUM, MESSAGE, "true")
Funprog CREATE_TEXT_LEGACY_CHAR(LPRODUCT, LANORI, LANGS, TEXT, COMMENT, NUM, MESSAGE)
  Value Integer LPRODUCT
  Value Char LANORI
  Variable Char LANGS()(0..)
  Value Char TEXT()
  Value Char COMMENT()
  Variable Integer NUM
  Variable Char MESSAGE
End func CREATE_TEXT_LEGACY(LPRODUCT, LANORI, LANGS, TEXT, COMMENT, NUM, MESSAGE)

#**
#* Update a text (ATEXTE) for a given number and a set of languages
#*
# UPDATE_TEXT returns [V]CST_AOK if the creation if OK
#*
#* @param LPRODUCT
#* @param NUM
#* @param LANORI
#* @param LANGS
#* @param TEXT
#* @param COMMENT
#* @param MESSAGE: A message in case of error
#*!
Funprog UPDATE_TEXT(LPRODUCT, NUM, LANORI, LANGS, TEXT, COMMENT, MESSAGE)
  Value Integer LPRODUCT
  Value Integer NUM
  Value Char LANORI
  Variable Char LANGS()(0..)
  Const Clbfile TEXT
  Const Clbfile COMMENT
  Variable Char MESSAGE

  Local  Char MESSAGE(250)

  Local Clbfile RESHEAD,RESBODY
  Local Clbfile ARGUMENTS(0)
   Local Char PLANGS(250)
  Local Char SEP(1)
  Local Integer AI

  For AI=0 To dim(LANGS)-1              # change dim statement
   Break LANGS(AI) = ""
   PLANGS += SEP + LANGS(AI)
  SEP=','
  Next AI
  Raz ARGUMENTS
  Raz MESSAGE

  Local Integer ASTATUS:ASTATUS =[V]CST_AERROR
  Local Integer HTTP_STATUS
  Local Clbfile WTEXT: WTEXT = TEXT : WTEXT = escJson(WTEXT)
  Local Clbfile WCOMMENT: WCOMMENT = COMMENT : WCOMMENT = escJson(WCOMMENT)

  ARGUMENTS =   '"' + func ADD_PRODUCT(LPRODUCT) + '",' + num$(NUM) + ',"' + LANORI + '","' + PLANGS + '","' + WTEXT + '","' + WCOMMENT + '"'
  HTTP_STATUS = func TEXT_HELPER('updateText', ARGUMENTS, RESHEAD, RESBODY)
  If find(HTTP_STATUS, [V]CST_AHTTP_OK, [V]CST_AHTTP_CREATED)
    ASTATUS =[V]CST_AOK
   Else
    MESSAGE=RESBODY
  Endif
End ASTATUS

Funprog UPDATE_TEXT_CHAR(LPRODUCT, NUM, LANORI, LANGS, TEXT, COMMENT, MESSAGE)
  Value Integer LPRODUCT
  Value Integer NUM
  Value Char LANORI
  Variable Char LANGS()(0..)
  Value Char TEXT()
  Value Char COMMENT()
  Variable Char MESSAGE
End func UPDATE_TEXT(LPRODUCT, NUM, LANORI, LANGS, TEXT, COMMENT, MESSAGE)


Funprog UPDATE_RESOURCE(LPRODUCT, NUM, LANG, TEXT, COMMENT, LANORI, MESSAGE)
Value Integer LPRODUCT
Value Integer NUM
Value Char LANG
Const Clbfile TEXT
Const Clbfile COMMENT
Value Char LANORI
Variable Char MESSAGE

Local  Char MESSAGE(250)
Local Clbfile RESHEAD,RESBODY
Local Clbfile ARGUMENTS(0)

Raz ARGUMENTS
Raz MESSAGE

Local Integer ASTATUS:ASTATUS =[V]CST_AERROR
Local Integer HTTP_STATUS
Local Clbfile WTEXT: WTEXT = TEXT : WTEXT = escJson(WTEXT)
Local Clbfile WCOMMENT: WCOMMENT = COMMENT : WCOMMENT = escJson(WCOMMENT)

ARGUMENTS =   '"' + func ADD_PRODUCT(LPRODUCT) + '",' + num$(NUM) + ',"' + LANG  + '","' + WTEXT + '","' + WCOMMENT + '","' + LANORI + '"'
HTTP_STATUS = func TEXT_HELPER('updateResource', ARGUMENTS, RESHEAD, RESBODY)
If find(HTTP_STATUS, [V]CST_AHTTP_OK, [V]CST_AHTTP_CREATED)
  ASTATUS =[V]CST_AOK
Else
  If RESBODY<>AVOID.ACHAR         # pull message from RESBODY or RESHEAD
    MESSAGE=RESBODY
  Else
    MESSAGE=func AJSONLIB.GET_PROP(RESHEAD,"message")
  Endif
Endif
End ASTATUS

#**
#* Updates a resource (ATEXTE) for a given number and language
#*
# UPDATE_ONETEXT returns [V]CST_AOK if the creation if OK
#*
#* @param LPRODUCT
#* @param NUM
#* @param LAN
#* @param TEXT
#* @param COMMENT
#* @param LANORI
#* @param MESSAGE: A message in case of error
#*!
Funprog UPDATE_ONETEXT(LPRODUCT, NUM, LAN, TEXT, COMMENT, LANORI, MESSAGE)
Value Integer LPRODUCT
Value Integer NUM
Value Char LAN
Const Clbfile TEXT
Const Clbfile COMMENT
Value Char LANORI
Variable Char MESSAGE
End func UPDATE_RESOURCE(LPRODUCT, NUM, LAN, TEXT, COMMENT, LANORI, MESSAGE)
Funprog UPDATE_ONETEXT_CHAR(LPRODUCT, NUM, LAN, TEXT, COMMENT, LANORI, MESSAGE)
Value Integer LPRODUCT
Value Integer NUM
Value Char LAN
Value Char TEXT
Value Char COMMENT
Value Char LANORI
Variable Char MESSAGE
End func UPDATE_ONETEXT(LPRODUCT, NUM, LAN, TEXT, COMMENT, LANORI, MESSAGE)

#**
#* Translates a resource (ATEXTE) for a given number and language
#*
# TRANSLATE_ONETEXT returns [V]CST_AOK if the creation if OK
#*
#* @param LPRODUCT
#* @param NUM
#* @param LAN
#* @param TEXT
#* @param COMMENT
#* @param LANORI
#* @param MESSAGE: A message in case of error
#*!
Funprog TRANSLATE_ONETEXT(LPRODUCT, NUM, LAN, TEXT, COMMENT,  MESSAGE)
Value Integer LPRODUCT
Value Integer NUM
Value Char LAN
Const Clbfile TEXT
Const Clbfile COMMENT
Variable Char MESSAGE
End func UPDATE_RESOURCE(LPRODUCT, NUM, LAN, TEXT, COMMENT, "", MESSAGE)
Funprog TRANSLATE_ONETEXT_CHAR(LPRODUCT, NUM, LAN, TEXT, COMMENT,  MESSAGE)
Value Integer LPRODUCT
Value Integer NUM
Value Char LAN
Value Char TEXT
Value Char COMMENT
Variable Char MESSAGE
End func TRANSLATE_ONETEXT(LPRODUCT, NUM, LAN, TEXT, COMMENT,  MESSAGE)

#######################################################
### APLSTD functions
#######################################################
#**
#*Delete messages (APLSTD) for a given product and chapter
#*
#* @param LPRODUCT:
#  -2 = ""  for shared menus
#  -1 = "SU"
#   0 = "X3"
#   1 = "GX"
#   2 = "PA"
#   3 = "AB"
#* @param CHAPTER
#* @param MESSAGE: A message in case of error
#*!
Funprog DELETE_MESSAGES_CHAPTER(PRODUCT, CHAPTER, MESSAGE)
Value Integer PRODUCT
Value Integer CHAPTER
Variable Char MESSAGE

Local Clbfile RESHEAD, RESBODY
Local Clbfile ARGUMENTS(0)
Raz ARGUMENTS
Local Integer HTTP_STATUS
Local Integer ASTATUS:ASTATUS =[V]CST_AERROR

ARGUMENTS =   '"' + func ADD_PRODUCT(PRODUCT) + '",' + num$(CHAPTER)
HTTP_STATUS =  func TEXT_HELPER('deleteChapter', ARGUMENTS, RESHEAD, RESBODY)
 If find(HTTP_STATUS, [V]CST_AHTTP_OK, [V]CST_AHTTP_CREATED)
  ASTATUS =[V]CST_AOK
Else
 MESSAGE = RESBODY
Endif
End ASTATUS

#**
#*Delete a message (APLSTD) for a given product, chapter and number
#*
#* @param LPRODUCT:
#  -2 = ""  for shared menus
#  -1 = "SU"
#   0 = "X3"
#   1 = "GX"
#   2 = "PA"
#   3 = "AB"
#* @param CHAPTER
#* @param MESSAGE: A message in case of error
#*!
Funprog DELETE_MESSAGE(PRODUCT, CHAPTER, LANNUM, MESSAGE)
Value Integer PRODUCT
Value Integer CHAPTER
Value Integer LANNUM
Variable Char MESSAGE

Local Clbfile RESHEAD, RESBODY
Local Clbfile ARGUMENTS(0)
Raz ARGUMENTS
Local Integer HTTP_STATUS
Local Integer ASTATUS:ASTATUS =[V]CST_AERROR

ARGUMENTS =   '"' + func ADD_PRODUCT(PRODUCT) + '",' + num$(CHAPTER) + ',' + num$(LANNUM)
HTTP_STATUS =  func TEXT_HELPER('deleteMessage', ARGUMENTS, RESHEAD, RESBODY)
 If find(HTTP_STATUS, [V]CST_AHTTP_OK, [V]CST_AHTTP_CREATED)
  ASTATUS =[V]CST_AOK
Else
 MESSAGE = RESBODY
Endif
End ASTATUS
#**
#* Returns a local message (APLSTD) for a given product, chapter, number and language
#*
# GET_MESSAGE returns [V]CST_AOK if the creation if OK
#
#* @param LPRODUCT:
#  -2 = ""  for shared menus
#  -1 = "SU"
#   0 = "X3"
#   1 = "GX"
#   2 = "PA"
#   3 = "AB"
#* @param CHP
#* @param NUM
#* @param LAN
#* @param MESSAGE: The expected message
#* @param ERRMSG: A message in case of error
#*!
Funprog GET_MESSAGE(LPRODUCT, CHP, NUM, LAN,CODE,MESSAGE,LANORI,ERRMSG)
Value Integer LPRODUCT
Value Integer CHP
Value Integer NUM
Value Char LAN
Variable Char CODE
Variable Char MESSAGE
Variable Char LANORI
Variable Char ERRMSG

Local Clbfile RESHEAD, RESBODY
Local Clbfile ARGUMENTS(0) : Raz ARGUMENTS
Local Integer STATUSCODE
Local Integer ASTATUS:ASTATUS =[V]CST_AERROR
Local Integer HTTP_STATUS


Local Integer COUNT
Local Integer TBNUM(1..)
Local Char TBLCODE(1)(1..)
Local Char TBLANMES(130)(1..)
Local Integer TBCHP(1..)
Local Char TBLAN(GLONLAN)(1..)
Local Char TBLANORI(GLONLAN)(1..)


If CHP<0 | NUM<0 #| LAN="" # No control on LAN as it's possible to query for any language
  ERRMSG=mess(67,103,1)+"("+LAN-num$(CHP)-num$(NUM)+")"
  ASTATUS=[V]CST_AERROR
  End ASTATUS
 Endif

ARGUMENTS = '"' +  func ADD_PRODUCT(LPRODUCT) + '",' + num$(CHP) +  ',' + num$(NUM) + ',"' + LAN + '"'
HTTP_STATUS = func TEXT_HELPER('getMessage', ARGUMENTS, RESHEAD, RESBODY)
If find(HTTP_STATUS, [V]CST_AHTTP_OK, [V]CST_AHTTP_CREATED)
 ASTATUS =[V]CST_AOK
 Gosub PARSE_MESSAGES
 MESSAGE =  TBLANMES(1)
 CODE = TBLCODE(1)
 LANORI = TBLANORI(1)
Else
 ERRMSG = RESBODY:# if nok the body contains a message
Endif
End ASTATUS

#**
#* Returns a set of message (APLSTD) for a given product, chapter and language
#*
# GET_MESSAGES returns [V]CST_AOK if the creation if OK
#
#* @param LPRODUCT:
#  -2 = ""  for shared menus
#  -1 = "SU"
#   0 = "X3"
#   1 = "GX"
#   2 = "PA"
#   3 = "AB"
#* @param CHP
#* @param NUM
#* @param LAN
#* @param FROMNUM
#* @param TONUM
#* @param MESSAGE: The expected message
#* @param ERRMSG: A message in case of error
#*!
Funprog GET_MESSAGES(LPRODUCT, CHP, LAN,FROMNUM, TONUM,COUNT, TBNUM, TBLCODE,TBLANMES, TBLANORI , ERRMSG)
Value Integer LPRODUCT
Value Integer CHP
Value Char LAN
Value Integer FROMNUM
Value Integer TONUM
Variable Integer COUNT
Variable Integer TBNUM(1..)
Variable Char TBLCODE()(1..)
Variable Char TBLANMES()(1..)
Variable Char TBLANORI()(1..)
Variable Char ERRMSG

Local Clbfile RESHEAD, RESBODY
Local Clbfile ARGUMENTS(0) : Raz ARGUMENTS
Local Integer STATUSCODE
Local Integer ASTATUS:ASTATUS =[V]CST_AERROR
Local Integer HTTP_STATUS

Local Integer TBCHP(1..)
Local Char TBLAN(1)(1..)

If CHP<=0 | FROMNUM<0 | TONUM<FROMNUM #| LAN="" # No control on LAN as it's possible to query for any language
  MESSAGE=mess(67,103,1)+"("+LAN-num$(CHP)-num$(FROMNUM)-num$(TONUM)+")"
  ASTATUS=[V]CST_AERROR
  End ASTATUS
Endif

ARGUMENTS = '"' +  func ADD_PRODUCT(LPRODUCT) + '",' + num$(CHP) + ',"' + LAN + '"' +  ',' + num$(FROMNUM) +  ',' + num$(TONUM)
HTTP_STATUS = func TEXT_HELPER('getMessages', ARGUMENTS, RESHEAD, RESBODY)
If find(HTTP_STATUS, [V]CST_AHTTP_OK, [V]CST_AHTTP_CREATED)
 ASTATUS =[V]CST_AOK
 Gosub PARSE_MESSAGES
Else
 ERRMSG = RESBODY:# if nok the body contains a message
Endif
End ASTATUS

#**
#* Create a message (ATEXTE) for a given product, chapter and language
#*
# CREATE_MESSAGE returns [V]CST_AOK if the creation if OK
#
#* @param LPRODUCT:
#  -2 = ""  for shared menus
#  -1 = "SU"
#   0 = "X3"
#   1 = "GX"
#   2 = "PA"
#   3 = "AB"
#* @param LANORI : original language
#* @param LANGS: set of languages in which the text has to be created
#* @param CHP: The chapter the menu belongs to
#* @param TEXT : the text to create
#* @param NUM: The number generated by the texts server for the text
#* @param MESSAGE: A message in case of error
Funprog CREATE_MESSAGE(LPRODUCT, LANORI, LANGS, CHP, CODE, TEXT,NUM, MESSAGE)
Value Integer LPRODUCT
Value Char LANORI
Variable Char LANGS()(0..)
Value Integer CHP
Value Char CODE
Value Char TEXT
Variable Integer NUM
Variable Char MESSAGE

Local Clbfile RESHEAD, RESBODY
Local Clbfile ARGUMENTS(0) : Raz ARGUMENTS
Local Integer ASTATUS:ASTATUS =[V]CST_AERROR
Local Integer HTTP_STATUS
Local Clbfile WTEXT: WTEXT = TEXT : WTEXT = escJson(WTEXT)
Local Char SEP(1)
Local Char PLANGS(250)

For AI=0 To dim(LANGS)
 Break LANGS(AI) = ""
 PLANGS += SEP + LANGS(AI)
 SEP=','
Next AI

ARGUMENTS = '"' + func ADD_PRODUCT(LPRODUCT) + '","'  + LANORI +  '","'  + PLANGS + '","' + num$(CHP) + '","' + WTEXT + '","' + escJson(CODE) + '"'

HTTP_STATUS = func TEXT_HELPER('createMessage', ARGUMENTS, RESHEAD, RESBODY)
If find(HTTP_STATUS, [V]CST_AHTTP_OK, [V]CST_AHTTP_CREATED)
 ASTATUS =[V]CST_AOK
 NUM =  val(RESBODY) :# if ok the body contains the required number
 If NUM<=0
  MESSAGE=mess(327,123,1)
  ASTATUS=[V]CST_AERROR
 Endif
Else
 MESSAGE = RESBODY:# if nok the body contains a message
Endif
End ASTATUS


#**
#* Update a message (ATEXTE) for a given product, chapter, number  and language
#*
# TRANSLATE_MESSAGE returns [V]CST_AOK if the creation if OK
#
#* @param LPRODUCT:
#  -2 = ""  for shared menus
#  -1 = "SU"
#   0 = "X3"
#   1 = "GX"
#   2 = "PA"
#   3 = "AB"
#* @param NUM: the message's number
#* @param LANG: language
#* @param CHP: The chapter the menu belongs to
#* @param MESSAGE : the expected message
#* @param ERRMSG: A message in case of error
#*!
Funprog TRANSLATE_MESSAGE(LPRODUCT, CHP, NUM, LAN, MESSAGE,ERRMSG)
Value Integer LPRODUCT
Value Integer CHP
Value Char  LAN
Value Integer  NUM
Value Char  MESSAGE
Value Char  ERRMSG
Local Char SYRACUSE_FONCTION(20): SYRACUSE_FONCTION="translateMessage"

Local Clbfile RESHEAD, RESBODY
Local Integer ASTATUS:ASTATUS =[V]CST_AERROR
Local Clbfile ARGUMENTS(0) : Raz ARGUMENTS
Local Integer HTTP_STATUS

ARGUMENTS = '"' + func ADD_PRODUCT(LPRODUCT) + '",' + num$(CHP) +  ',' + num$(NUM) + ',"' + LAN + '","' + escJson(MESSAGE) + '"'
 HTTP_STATUS = func TEXT_HELPER(SYRACUSE_FONCTION, ARGUMENTS, RESHEAD, RESBODY)
If find(HTTP_STATUS, [V]CST_AHTTP_OK, [V]CST_AHTTP_CREATED)
  ASTATUS=[V]CST_AOK
Else
  ERRMSG= RESBODY
Endif
End ASTATUS

#**
#* Update a message (ATEXTE) for a given product, chapter, number  and language
#*
# UPDATE_MESSAGE returns [V]CST_AOK if the creation if OK
#
#* @param LPRODUCT:
#  -2 = ""  for shared menus
#  -1 = "SU"
#   0 = "X3"
#   1 = "GX"
#   2 = "PA"
#   3 = "AB"
#* @param NUM: the message's number
#* @param LANG: language
#* @param CHP: The chapter the menu belongs to
#* @param MESSAGE : the expected message
#* @param ERRMSG: A message in case of error
Funprog UPDATE_MESSAGE(LPRODUCT, CHP, NUM, LANORI, LAN, CODE, MESSAGE,ERRMSG)
#*!
Value Integer LPRODUCT
Value Integer CHP
Value Char LANORI
Value Char  LAN
Value Integer  NUM
Value Char CODE
Value Char  MESSAGE
Value Char  ERRMSG
Local Char SYRACUSE_FONCTION(20): SYRACUSE_FONCTION="updateMessage"

Local Clbfile RESHEAD, RESBODY
Local Integer ASTATUS:ASTATUS =[V]CST_AERROR
Local Clbfile ARGUMENTS(0) : Raz ARGUMENTS
Local Integer HTTP_STATUS

ARGUMENTS = '"' + func ADD_PRODUCT(LPRODUCT) + '",' + num$(CHP) +  ',' + num$(NUM) + ',"' + LANORI +'","' + LAN + '","' + escJson(MESSAGE) + '","' +escJson(CODE)+ '"'
 HTTP_STATUS = func TEXT_HELPER(SYRACUSE_FONCTION, ARGUMENTS, RESHEAD, RESBODY)
If find(HTTP_STATUS, [V]CST_AHTTP_OK, [V]CST_AHTTP_CREATED)
  ASTATUS=[V]CST_AOK
Else
  ERRMSG= RESBODY
Endif
End ASTATUS

#**
#* Returns last modified messages
#*
#* @param LPRODUCT:
#  -2 = ""  for shared menus
#  -1 = "SU"
#   0 = "X3"
#   1 = "GX"
#   2 = "PA"
#   3 = "AB"
#  @param AMESETAG: tag of the last message stored in the local database
#* @param LIMIT: maximum items to get
#* @param COUNT: receives the position of the first element ot read and returns the position of the last element
#* @param MESSAGE: A message in case of error
#* @param TBCHP: table of chapters
#* @param TBNUM table of numbers
#* @param  TBLAN table of languages
#* @param  TBLANMES table of messages
#* @param TBLANORI table of original languages
#* @param  A message in case of error
#*!
Funprog GET_LASTMODIFIED_MESSAGES(PRODUCT, AMESETAG, LIMIT,COUNT, TBCHP, TBNUM, TBLAN, TBLCODE,TBLANMES, TBLANORI, MESSAGE)
  Value Integer PRODUCT
  Variable Char AMESETAG
  Value Integer LIMIT
  Variable Integer COUNT
  Variable Integer TBCHP(1..)
  Variable Integer TBNUM(1..)
  Variable Char TBLAN()(1..)
  Variable Char TBLCODE()(1..)
  Variable Char TBLANMES()(1..)
  Variable Char TBLANORI()(1..)
  Variable Char MESSAGE

  Local Clbfile RESHEAD, RESBODY
  Local Clbfile ARGUMENTS(0)
  Local Integer ASTATUS:ASTATUS =[V]CST_AERROR
  Local Integer HTTP_STATUS

  Raz ARGUMENTS

  ARGUMENTS = '"' + func ADD_PRODUCT(PRODUCT) + '","' + AMESETAG + '",'+num$(LIMIT)+','+num$(COUNT)
  HTTP_STATUS = func TEXT_HELPER('getLastModifiedMessages', ARGUMENTS, RESHEAD, RESBODY)
  Raz COUNT
  If HTTP_STATUS =[V]CST_AHTTP_OK
   Gosub PARSE_MESSAGES
   If ASTATUS = [V]CST_AOK and COUNT > 1
    AMESETAG = TBETAG(COUNT-1)
   Endif
  Else
   MESSAGE = RESBODY:# if nok the body contains a message
  Endif
End ASTATUS

$PARSE_MESSAGES
  Local Instance  NODES(1..) Using C_ASYRJSO
  Local Instance  NODE         Using C_ASYRJSO
  Local Instance  NODEPRO  Using C_ASYRJSO
  Local Char TBETAG(30)(1..)
  Local Char CNT(250)

  Raz COUNT, TBCHP, TBNUM, TBLAN, TBLANMES, TBLANORI

  ASTATUS = func ASYRJSONPARSE.PARSEJSON(GACTX,RESBODY,NODES,NODE)
  While NODE <> null
   COUNT += 1
   NODEPRO = NODE.SUB
   While NODEPRO <> null
    CNT = seg$(fmet NODEPRO.AGETCNT,2,len(fmet NODEPRO.AGETCNT)-1)
    Case NODEPRO.PRO
     When "LAN" : TBLAN(COUNT) = CNT
     When "LANMES" : TBLANMES(COUNT) = CNT
     When "LANORI" : TBLANORI(COUNT) = CNT
     When "LANCHP": TBCHP(COUNT) = val(fmet NODEPRO.AGETCNT)
     When "LANNUM": TBNUM(COUNT) = val(fmet NODEPRO.AGETCNT)
     When "CODE": TBLCODE(COUNT) = CNT

     When "lastModified" : TBETAG(COUNT) = CNT
    Endcase
    NODEPRO = NODEPRO.NEX
   Wend
   NODE = NODE.NEX
  Wend
  FreeGroup  NODES(1)
Return

Funprog SEARCH_SIMILAR(COLLEC, LAN, TEXT,RESBODY)
  Value Char COLLEC, LAN, TEXT
  Variable Clbfile RESBODY
  Local Clbfile RESHEAD
  Local Clbfile ARGUMENTS(0)
  Raz ARGUMENTS
  Local Integer STATUSCODE
  Local Clbfile WTEXT: WTEXT = TEXT : WTEXT = escJson(WTEXT)

  ARGUMENTS = '"' + func ADD_PRODUCT(GPRODUIT) + '","' + COLLEC + '","' + LAN + '","' + WTEXT + '"'
  STATUSCODE = func TEXT_HELPER('searchSimilar', ARGUMENTS, RESHEAD, RESBODY)
End STATUSCODE


#**
#* Text helper function
#*
#* @param FUNCTION
#* @param ARGUMENTS
#* @param RESHEAD
#* @param RESBODY
#*!
Funprog TEXT_HELPER(FUNCTION, ARGUMENTS, RESHEAD, RESBODY)
  Value Char FUNCTION
  Variable Clbfile ARGUMENTS, RESHEAD, RESBODY
End func SYRA_WAIT_CALL('syracuse-translation/lib/pub/textsClient', FUNCTION, ARGUMENTS, RESHEAD, RESBODY)

Funprog SYRA_WAIT_CALL(MODULE, FUNCTION, ARGUMENTS, RESHEAD,RESBODY)
  Value Char MODULE, FUNCTION
  Variable Clbfile ARGUMENTS, RESHEAD, RESBODY

  Local Integer STATUSCODE
  STATUSCODE = 500
  Onerrgo ERR_SYRA_CALL
  STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FUNCTION, 'wait', ARGUMENTS, '', 0, '', '0', RESHEAD, RESBODY)
  Onerrgo
End STATUSCODE

$ERR_SYRA_CALL
Resume

Funprog ADD_PRODUCT(IPRODUCT)
Value Integer IPRODUCT

Local Char PRODUCT(5)
Case IPRODUCT
 When -2 : PRODUCT = "" :#Shared components (for menus)
 When -1 : PRODUCT = "SU" :#Superviseur
 When  0 : PRODUCT = "X3" :#X3
 When  1 : PRODUCT = "GX":#Géode
 When  2 : # Issue X3-50814 - 2017-07-28 by CCC : Even if GPRODUIT=2, the product to consider is "X3" in texts server
           #PRODUCT = "PA":#Paye
           PRODUCT = "X3"
 When  3 : PRODUCT = "AB":#Biens
Endcase
End PRODUCT

