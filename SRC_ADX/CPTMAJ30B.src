#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################################################
## GJOURNAL     : MAJ tables GJOURNAL, GAJOUCOA, GAJOUSTA
## GRPSAC       : MAJ table GRPSAC
## FISCALYEAR   : MAJ table FISCALYEAR
## PERIOD       : MAJ table PERIOD
## GDIE         : MAJ table GDIE (Axes analytiques)
## CACCE        : MAJ table CACCE (Sections analytiques)
## CADSP        : MAJ table CADSP (Répartitions analytiques)
## GAUTACE      : Copie des pièces autos à partir du dossier de réf V6
## GRPAUTACE    : Copie des groupes de pièces autos à partir du dossier de réf V6
## VARAUTACE    : Copie des variables de pièces autos à partir du dossier de réf V6
## BATCH_CPT    : Suppression des données de la table BATCH (de manière à ce que les tâches du dossier de
##                réf soient recopiées
## BATCH_LET    : Initialisation du code plan pour définir la LETTRE au niveau du lettrage
##########################################################################################################

##-------------------------------------------------------------------------------------------------------#
# Mise à jour GJOURNAL, GAJOUCOA, GAJOUSTA
##-------------------------------------------------------------------------------------------------------#
$GJOURNAL
Local File =[F:ADS]DOSSIER+".GJOURNAL"   [JOU]
Local File =[F:ADS]DOSSIER+".GJOUCOA"    [JCO]
Local File =[F:ADS]DOSSIER+".GAJOUSTA"   [JST]
Local File =[F:ADS]DOSSIER+".GCOA"       [COA]
Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]

Call ECR_TIME(mess(81,125,1)-": GJOURNAL") From DOSSUB : # maj table

# Suppresion de la table GAJOUSTA => Plus d'appel, RAZFIC sous CPTMAJ30
#Trbegin [JST]
#Delete [JST] Where 1=1
#If fstat
# GOK = 0 : Call ERREUR("GAJOUSTA",3) From DOSDIC
#Endif
#Commit

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_JOU
Raz NB
If STOP
 Raz STOP
 CRITERE = "[F:JOU]JOU>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [JOU], [JCO], [JST]

 GOK = 1

 For [JOU]JOU0 Where evalue(CRITERE)

  [F:JOU]UPDUSR = GUSER
  [F:JOU]UPDDAT = date$

  NB+=1
  Rewrite [JOU]
  If fstat
   Call ERREUR("GJOURNAL"-[F:JOU]JOU,1) From DOSDIC
  Endif

  # Gestion des intitulés (V6 : Libellé traduisible)
  If dim([F:JOU]DES)>0
   Call MAJTEXTRA([F:JOU]DES,"GJOURNAL","DESTRA",[F:JOU]JOU,"") From CPTMAJ30
  Endif
  If dim([F:JOU]DESSHO)>0
   Call MAJTEXTRA([F:JOU]DESSHO,"GJOURNAL","SHOTRA",[F:JOU]JOU,"") From CPTMAJ30
  Endif

  ##  Tous les codes plans sont tous CREER quelque soit le "type" de journal. (ML613)
  ## Mise à jour table GJOUCOA
  #Case [F:JOU]TYP
  # When 8, 9, 10
  #  ## Création sur le plan de compte analytique
  #  Raz [F:JCO]
  #  [F:JCO]    = [F:JOU]
  #  [F:JCO]COA = PLANA
  #  [F:JCO]ACC = ""
  #  NB += 1
  #  Write [JCO]
  #  If fstat
  #   Call ERREUR("GJOUCOA"-[F:JCO]COA-[F:JCO]JOU,1) From DOSDIC
  #  Endif
  # When Default
  #  ## Création sur le plan de compte social et IAS
  #  Raz [F:JCO]
  #  [F:JCO]    = [F:JOU]
  #  [F:JCO]COA = PLGEN
  #  If [F:JOU]TYP = 3 : # Journal de Trésorerie
  #   [F:JCO]ACC = [F:JOU]ACC
  #  Else
  #   [F:JCO]ACC = ""
  #  Endif
  #  NB += 1
  #  Write [JCO]
  #  If fstat
  #   Call ERREUR("GJOUCOA"-[F:JCO]COA-[F:JCO]JOU,1) From DOSDIC
  #  Endif
  #  If PLIAS<>""
  #   Raz [F:JCO]
  #   [F:JCO]    = [F:JOU]
  #   [F:JCO]COA = PLIAS
  #   If [F:JOU]TYP = 3 : # Journal de Trésorerie
  #    [F:JCO]ACC = [F:JOU]ACC
  #   Else
  #    [F:JCO]ACC = ""
  #   Endif
  #   NB += 1
  #   Write [JCO]
  #   If fstat
  #    Call ERREUR("GJOUCOA"-[F:JCO]COA-[F:JCO]JOU,1) From DOSDIC
  #   Endif
  #  Endif
  #Endcase

  For [COA]COA0
   Raz [F:JCO]
   [F:JCO]COA = [F:COA]COA
   [F:JCO]JOU = [F:JOU]JOU
   If [F:JCO]COA<>PLANA
    If [F:JOU]TYP = 3 : # Journal de Trésorerie
     [F:JCO]ACC = [F:JOU]ACC
    Endif
    [F:JCO]FBDNBR = [F:JOU]FBDNBR
    For I=0 To [F:JCO]FBDNBR-1
     [F:JCO]FBDACC(I) = [F:JOU]FBDACC(I)
    Next
    [F:JCO]FRQNBR = [F:JOU]FRQNBR
    For I=0 To [F:JCO]FRQNBR -1
     [F:JCO]FRQACC(I) = [F:JOU]FRQACC(I)
     [F:JCO]FRQCOD(I) = [F:JOU]FRQCOD(I)
    Next
   Endif
   [F:JCO]CREDAT = [F:JOU]CREDAT
   [F:JCO]CREUSR = [F:JOU]CREUSR
   [F:JCO]UPDUSR = GUSER
   [F:JCO]UPDDAT = date$
   NB += 1
   Write [JCO]
   If fstat
     Call ERREUR("GJOUCOA"-[F:JCO]COA-[F:JCO]JOU,1) From DOSDIC
   Endif
  Next

  For [CPY]CPY0  Where [F:CPY]CPYLEGFLG=2
   Raz [F:JST]
   [F:JST]CPY = [F:CPY]CPY
   [F:JST]JOU = [F:JOU]JOU
   [F:JST]OPGSTRDAT = [0/0/0]
   [F:JST]OPGENDDAT = [0/0/0]
   [F:JST]CREDAT = [F:JOU]CREDAT
   [F:JST]CREUSR = [F:JOU]CREUSR
   [F:JST]UPDUSR = GUSER
   [F:JST]UPDDAT = date$
   If dim([F:JST]LEG)>0 : # Pour la migration V5->V7
    [F:JST]LEG = [F:CPY]LEG
   Endif
   NB += 1
   Write [JST]
   If fstat
    Call ERREUR("GAJOUSTA"-[F:JST]CPY-[F:JST]JOU,1) From DOSDIC
   Endif
  Next

  If NB>GMAXUPDTRS
   ACLE1 = [F:JOU]JOU
   STOP=1
   Break
  Endif

 Next
Commit

If STOP
 Goto LOOP_JOU
Endif

Close Local File [JOU], [JCO], [JST], [CPY], [COA]
Gosub UNSET_FIRST From TRTFIRST

Return


##-------------------------------------------------------------------------------------------------------#
# Mise à jour GRPSAC (Groupes de collectifs)
##-------------------------------------------------------------------------------------------------------#
$GRPSAC

Local File =[F:ADS]DOSSIER+".GRPSAC"   [GSC]
Local File =[F:ADS]DOSSIER+".GRPSAC"   [GSC2]

Call ECR_TIME(mess(81,125,1)-": GRPSAC") From DOSSUB : # maj table


Local Integer INDSAC, NBRSAC

Gosub SET_FIRST From TRTFIRST
Raz STOP

$LOOP_GSC
Raz NB
If GTYPDBA=2 #SQL
 Filter [F:GSC2] Where GRU=""
Endif
If STOP
 Raz STOP
 CRITERE = "[F:GSC2]GRP>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [GSC], [GSC2]

 GOK = 1
 For [GSC2]GSC0 Where evalue(CRITERE)

  ## NB : Modif faite par Marc pour la V6 le 04/02/08 : à ce niveau, on a dans la table le champ qui
  ## a la plus grande dimension. Ici on a le champ SAC de dimension 30 (Version 5) avec les valeurs
  ## A tester pour voir si cela marche....
  NBRSAC = 0
  For INDSAC=0 To dim([F:GSC2]SAC)-1
   If [F:GSC2]SAC(INDSAC)<>""
    NBRSAC += 1
    # Transclass
    [F:GSC]    = [F:GSC2]

    [F:GSC]GRU = [F:GSC2]GRP
    [F:GSC]SAC = [F:GSC2]SAC(INDSAC)

    # Nx champs
    [F:GSC]COA    = PLGEN
    [F:GSC]NUMLIN = NBRSAC

    [F:GSC]UPDUSR = GUSER
    [F:GSC]UPDDAT = date$

    NB+=1
    Write [GSC]
    If fstat
     Call ERREUR("GRPSAC"-[F:GSC]COA-[F:GSC]GRU-num$([F:GSC]NUMLIN),1) From DOSDIC
    Endif
   Endif
  Next

  # Gestion des intitulés (V6 : Libellé traduisible)
  # Groupe de collectif... en V5 = Groupe. Pour les libellé en V6... COA+Code du groupe
  If dim([F:GSC2]DES)>0
   Call MAJTEXTRA([F:GSC2]DES,"GRPSAC","DESTRA",[F:GSC]COA,[F:GSC]GRU) From CPTMAJ30
  Endif
  If dim([F:GSC2]DESSHO)> 0
   Call MAJTEXTRA([F:GSC2]DESSHO,"GRPSAC","SHOTRA",[F:GSC]COA,[F:GSC]GRU) From CPTMAJ30
  Endif

  If NB>GMAXUPDTRS
   ACLE1 = [F:GSC2]GRP
   STOP=1
   Break
  Endif
 Next

Commit

If STOP
 Goto LOOP_GSC
Endif

# Fin de la mise à jour de la table GRPSAC.
Trbegin [GSC]
Delete [GSC] Where [GSC]GRU=""
If fstat
 GOK = 0 : Call ERREUR("GRPSAC",3) From DOSDIC
Endif
Commit

Close Local File [GSC], [GSC2]
Gosub UNSET_FIRST From TRTFIRST

Return



##-------------------------------------------------------------------------------------------------------#
# Mise à jour FISCALYEAR (Exercices)
##-------------------------------------------------------------------------------------------------------#
$FISCALYEAR

Local File =[F:ADS]DOSSIER+".FISCALYEAR"   [FIY]
Local File =[F:ADS]DOSSIER+".FISCALYEAR"   [FIY2]
Local File =[F:ADS]DOSSIER+".COMPANY"      [CPY]
Local File =[F:ADS]DOSSIER+".GACM"         [GCM]

Call ECR_TIME(mess(81,125,1)-": FISCALYEAR") From DOSSUB : # maj table


Local Integer TYPREF

Gosub SET_FIRST From TRTFIRST
Raz STOP

$LOOP_FIY
Raz NB
If GTYPDBA=2 #SQL
 Filter [F:FIY2] Where LEDTYP<1
Endif
If STOP = 1
 STOP = 2
 CRITERE = "[F:FIY2]CPY='"+ACLE1+"' & [F:FIY2]FIYNUM>"+num$(ICLE1)
Elsif STOP = 2
 Raz STOP
 CRITERE = "[F:FIY2]CPY>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [FIY]

 GOK = 1
 For [FIY2]FIY0 Where evalue(CRITERE)

  If [F:CPY]CPY<>[F:FIY2]CPY
   Read [F:CPY]CPY0 = [F:FIY2]CPY
  Endif

  If [F:GCM]GCM<>[F:CPY]ACM
   Read [F:GCM]GCM0 = [F:CPY]ACM
  Endif

  ## Création exercice sur les référentiels non automatiques : social, analytique, IAS
  For TYPREF = 1 To 3
   If [F:GCM]LED(TYPREF-1)<>""
    Raz [FIY]
    [F:FIY] = [F:FIY2]
    [F:FIY]DES    = [F:FIY2]FIYDES
    [F:FIY]DESSHO = [F:FIY2]FIYSHO
    [F:FIY]LEDTYP = TYPREF
    If TYPREF = 3 # IAS
     If [F:FIY]FIYIASSTA<>0 : [F:FIY]FIYSTA = [F:FIY]FIYIASSTA : Endif
    Endif
    If [F:FIY]FIYSTA>3 : [F:FIY]FIYSTA = 3 : Endif
    Write [FIY]
    If fstat
     Call ERREUR("FISCALYEAR"-[F:FIY]CPY-num$([F:FIY]LEDTYP)-num$([F:FIY]FIYNUM),1) From DOSDIC
    Endif
   Endif
  Next

  ## Création exercice sur les référentiels automatiques
  For TYPREF = 4 To dim([F:GCM]LED)
   If [F:GCM]LED(TYPREF-1)<>""
    Raz [FIY]
    [F:FIY] = [F:FIY2]
    [F:FIY]DES    = [F:FIY2]FIYDES
    [F:FIY]DESSHO = [F:FIY2]FIYSHO
    [F:FIY]LEDTYP = TYPREF
    If TYPREF = 3 # IAS
     If [F:FIY]FIYIASSTA<>0 : [F:FIY]FIYSTA = [F:FIY]FIYIASSTA : Endif
    Endif
    If [F:FIY]FIYSTA>3 : [F:FIY]FIYSTA = 3 : Endif
    [F:FIY]LEDTYPAUT = 2
    Write [FIY]
    If fstat
     Call ERREUR("FISCALYEAR"-[F:FIY]CPY-num$([F:FIY]LEDTYP)-num$([F:FIY]FIYNUM),1) From DOSDIC
    Endif
   Endif
  Next

  NB+=1
  If NB>GMAXUPDTRS
   ACLE1 = [F:FIY2]CPY
   ICLE1 = [F:FIY2]FIYNUM
   STOP=1
   Break
  Endif
 Next

Commit

If STOP
 Goto LOOP_FIY
Endif

# Fin de la mise à jour de la table FISCALYEAR
Trbegin [FIY]
Delete [FIY] Where [FIY]LEDTYP<1
If fstat
 GOK = 0 : Call ERREUR("FISCALYEAR",3) From DOSDIC
Endif
Commit

For [FIY]FIY0(1)
 Read [CPY]CPY0=[F:FIY]CPY
 If !fstat & [F:CPY]LEG="FRA"
  Filter [FIY2] Where CPY=[F:FIY]CPY & LEDTYP=1 & FIYSTA=2 : # Social
  If rowcount([FIY2])>2
   # pas plus d'un exercice ouvert antérieur ou postérieur à l'exercice en cours
   Call ECR_TRACE([F:CPY]CPY-mess(64,101,1),-1) From GESECRAN
  Else
   Filter [FIY2] Where CPY=[F:FIY]CPY & LEDTYP=3 & FIYSTA=2 : # IAS
   If rowcount([FIY2])>2
    # pas plus d'un exercice ouvert antérieur ou postérieur à l'exercice en cours
    Call ECR_TRACE([F:CPY]CPY-mess(64,101,1),-1) From GESECRAN
   Endif
  Endif
  Filter [FIY2]
 Endif
Next

Close Local File [FIY], [FIY2], [CPY], [GCM]
Gosub UNSET_FIRST From TRTFIRST

Return


##-------------------------------------------------------------------------------------------------------#
# Mise à jour PERIOD (Périodes)
##-------------------------------------------------------------------------------------------------------#
$PERIOD

Local File =[F:ADS]DOSSIER+".PERIOD"   [PER]
Local File =[F:ADS]DOSSIER+".PERIOD"   [PER2]
Local File =[F:ADS]DOSSIER+".COMPANY"  [CPY]
Local File =[F:ADS]DOSSIER+".GACM"     [GCM]

Call ECR_TIME(mess(81,125,1)-": PERIOD") From DOSSUB : # maj table

Local Integer TYPREF

Gosub SET_FIRST From TRTFIRST
Raz STOP

$LOOP_PER
Raz NB
If GTYPDBA=2 #SQL
 Filter [F:PER2] Where LEDTYP<1
Endif
If STOP = 1
 STOP = 2
 CRITERE = "[F:PER2]CPY='"+ACLE1+"' & [F:PER2]FIYNUM="+num$(ICLE1)+" & [F:PER2]PERNUM>"+num$(ICLE2)
Elsif STOP = 2
 STOP = 3
 CRITERE = "[F:PER2]CPY='"+ACLE1+"' & [F:PER2]FIYNUM>"+num$(ICLE1)
Elsif STOP = 3
 Raz STOP
 CRITERE = "[F:PER2]CPY>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [PER]

 GOK = 1
 For [PER2]PER0 Where evalue(CRITERE)

  If [F:CPY]CPY<>[F:PER2]CPY
   Read [F:CPY]CPY0 = [F:PER2]CPY
  Endif

  If [F:GCM]GCM<>[F:CPY]ACM
   Read [F:GCM]GCM0 = [F:CPY]ACM
  Endif

  ## Création périodes sur les référentiels non automatiques : social, analytique, IAS
  For TYPREF = 1 To 3
   If [F:GCM]LED(TYPREF-1)<>""
    Raz [PER]
    [F:PER] = [F:PER2]
    [F:PER]LEDTYP = TYPREF
    If TYPREF = 2 # Analytique
     [F:PER]PERSTA = [F:PER]PERANASTA
    Endif
    Write [PER]
    If fstat
     Call ERREUR("PERIOD"-[F:PER]CPY-num$([F:PER]LEDTYP)-num$([F:PER]FIYNUM)-num$([F:PER]PERNUM),1) From DOSDIC
    Endif
   Endif
  Next

  ## Création périodes sur les référentiels automatiques
  For TYPREF = 4 To dim([F:GCM]LED)
   If [F:GCM]LED(TYPREF-1)<>""
    Raz [PER]
    [F:PER] = [F:PER2]
    [F:PER]LEDTYP = TYPREF
    If TYPREF = 2 # Analytique
     [F:PER]PERSTA = [F:PER]PERANASTA
    Endif
    [F:PER]LEDTYPAUT = 2
    Write [PER]
    If fstat
     Call ERREUR("PERIOD"-[F:PER]CPY-num$([F:PER]LEDTYP)-num$([F:PER]FIYNUM)-num$([F:PER]PERNUM),1) From DOSDIC
    Endif
   Endif
  Next

  NB+=1
  If NB>GMAXUPDTRS
   ACLE1 = [F:PER2]CPY
   ICLE1 = [F:PER2]FIYNUM
   ICLE2 = [F:PER2]PERNUM
   STOP=1
   Break
  Endif
 Next

Commit

If STOP
 Goto LOOP_PER
Endif

# Fin de la mise à jour de la table PERIOD
Trbegin [PER]
Delete [PER] Where [PER]LEDTYP<1
If fstat
 GOK = 0 : Call ERREUR("PERIOD",3) From DOSDIC
Endif
Commit

Close Local File [PER], [PER2], [CPY], [GCM]
Gosub UNSET_FIRST From TRTFIRST

Return


##-------------------------------------------------------------------------------------------------------#
## Création table GDIE (Périodes)
##
##  Axes analytiques :
##  - Les axes analytiques sont créés avec le code "AX"+numéro de l'axe
##  - Le format de l'axe est initialisé à partir des paramètres FMTCCEx de la version V5
##  - Les intitulés courts et longs sont initialisés par rapport aux intitulés du menu local 601
##  - Le flag 'Création automatique' est initialisé en fonction de la valeur du paramètre V5 CRECCE
##  - Le flag 'Gestion de projet' est initialisé à "Oui" s'il y a au moins une section de l'axe qui est
##    flaguée 'Report A-nouveau'
##
##  Axes IAS (si code activité IAS actif) : Secteurs 'Activité' et 'Géographie'
##  - Les axes "IAS" sont créés à partir des axes du code référentiel IAS du dossier de référence.
##  NB : Comme par ailleurs on récupéra les secteurs d'activité (défini en V5 dans la table diverse 360)
##  et les secteurs 'géographie' (défini en V5 dans la table diverse 361), il faudra définir dans le dossier
##  de référence :
##        1/ L'axe 'Secteur d'activité' comme le 1er axe du référentiel IAS
##        2/ L'axe 'Secteur Géographie' comme le 2ième axe du référentiel IAS
##-------------------------------------------------------------------------------------------------------#
$GDIE

Local File =[F:ADS]DOSSIER+".GDIE"    [DIE]
Local File =[F:ADS]DOSSIER+".GLED"    [LED]
Local File =[F:ADS]DOSSIER+".APLSTD"  [STD2]
Local File =[F:ADS]DOSSIER+".CACCE"   [CCE]
Local File =[F:ADS]DOSSIER+".ADOVAL"  [ADW2]

Local File =[F:ADS]DOSCOP+".GDIE"   [RDIE]

Call ECR_TIME(mess(81,125,1)-": GDIE") From DOSSUB : # maj table


Local Char    FMTAXE(10)
Local Char    CRESEC(10)
Local Char    SAICCE(10)
Local Char    TABDIE(3)(1..9)
Local Integer AXE

Read [ADW2]ADW0 = "";"";"CRECCE"
CRESEC = [F:ADW2]VALEUR

Filter [STD2] Where LANCHP = 601 & LAN = MIGGLANMAJ

Trbegin [DIE]

 GOK = 1

 For [STD2]LAN Where LANNUM>0
  AXE += 1
  Raz [F:DIE]
  [F:DIE]DIE  = "AX"+num$([F:STD2]LANNUM) : # A voir... après, libres aux gens de faire un changement de clé.....
  TABDIE(AXE) = [F:DIE]DIE
  [F:DIE]DES    = [F:STD2]LANMES
  [F:DIE]DESSHO = [F:STD2]LANMES
  FMTAXE = "20c"

  Read [ADW2]ADW0 = "";"";"FMTCCE"+num$([F:STD2]LANNUM)
  If !fstat
   FMTAXE = [F:ADW2]VALEUR
  Endif
  [F:DIE]CCEFMT = FMTAXE

  If [L]CRESEC<>"2"
   [F:DIE]CREAUT = 1
  Else
   [F:DIE]CREAUT = 2
  Endif

  Read [ADW2]ADW0 = "";"";"RNDCCE"+num$([F:STD2]LANNUM)
  If !fstat
   [F:DIE]CCEMIS(0) = [F:ADW2]VALEUR
  Endif

  Filter [CCE] Where AXI=[F:STD2]LANNUM & FIYEND<>2
  Read [CCE] First
  Filter [CCE]
  If fstat
   [F:DIE]PRJMGT = 2
  Endif

  [F:DIE]CREUSR = GUSER
  [F:DIE]CREDAT = date$
  [F:DIE]UPDUSR = GUSER
  [F:DIE]UPDDAT = date$
  Write [DIE]
  If fstat
   Call ERREUR("GDIE"-[F:DIE]DIE,1) From DOSDIC
  Endif

  # Gestion des intitulés (V6 : Libellé traduisible)
  If dim([F:DIE]DES) >0
   Call MAJTEXTRA([F:DIE]DES,"GDIE","DESTRA",[F:DIE]DIE,"") From CPTMAJ30
   Call MAJTEXTRA([F:DIE]DES,"GDIE","SHOTRA",[F:DIE]DIE,"") From CPTMAJ30
   Call MAJTEXTRA([F:DIE]DES,"GDIE","COLHEA",[F:DIE]DIE,"") From CPTMAJ30
  Endif
 Next

 ## Mise à jour des champs axes dans le référentiel ana
 For I=0 To NBLEDANA-1
  Read [LED]LED0 = WLEDANA(I)
  If !fstat : # Normalement le référentiel ana a été créé dans $GLED...
   [F:LED]DIENBR = [L]MIGGOPTCANA
   For AXE = 1 To [L]MIGGOPTCANA
    [F:LED]DIE(AXE-1) = "AX"+num$(AXE)
   Next
   Rewrite [LED]
   If fstat
    Call ERREUR("GLED"-[F:LED]LED,1) From DOSDIC
   Endif
  Else
   ## au cas où il n'aurait pas été créé (théoriquement non...), on le créé à partir du
   ## référentiel analytique du dossier de référence
   Read [RLED]LED0 = WLEDANA(I)
   If !fstat
    [F:LED] = [F:RLED]
    [F:LED]DIENBR = [L]MIGGOPTCANA
    For AXE = 1 To [L]MIGGOPTCANA
     [F:LED]DIE(AXE-1) = "AX"+num$(AXE)
    Next
    Write [LED]
    If fstat
     Call ERREUR("GLED"-[F:LED]LED,1) From DOSDIC
    Endif
   Endif
  Endif
 Next

 ## Si on a l'IAS, on crée les axes 'Secteur d'activité' et 'Secteur géographique' => Ces axes sont théoriquement
 ## définis dans le référentiel IAS du dossier de référence.
 ## Prérequis : il faudra que dans le dossier de référence, on ait pour le référentiel IAS :
 ##         1er axe = secteur d'activité     2ième axe = secteur géographie
 ##  de manière à pouvoir récupérer les secteurs d'activité (à partir de la table diverse 360) et les secteurs
 ##  géographiques (à partir de la table diverse 361)
 If PLIAS<>""
  Read [RLED]LED0 = LEDIAS
  If !fstat
   For AXE = 1 To [F:RLED]DIENBR
    Read [RDIE]DIE0 = [F:RLED]DIE(AXE-1)
    If !fstat
     Raz [DIE]
     [F:DIE] = [F:RDIE]
     Write [DIE]
     If fstat
      Call ERREUR("GDIE"-[F:DIE]DIE,1) From DOSDIC
     Endif
     # Gestion des intitulés (V6 : Libellé traduisible)
     If dim([F:DIE]DES) >0
      Call MAJTEXTRA([F:DIE]DES,"GDIE","DESTRA",[F:DIE]DIE,"") From CPTMAJ30
     Endif
     If dim([F:DIE]DESSHO) >0
      Call MAJTEXTRA([F:DIE]DESSHO,"GDIE","SHOTRA",[F:DIE]DIE,"") From CPTMAJ30
      Call MAJTEXTRA([F:DIE]DESSHO,"GDIE","COLHEA",[F:DIE]DIE,"") From CPTMAJ30
     Endif
    Endif
   Next
  Endif
  [L]AXEIAS1 = [F:RLED]DIE(0)
  [L]AXEIAS2 = [F:RLED]DIE(1)
 Endif

Commit

Filter [STD2]
Close Local File [DIE], [LED], [STD2], [CCE], [RDIE], [ADW2]

Return


##-------------------------------------------------------------------------------------------------------#
## Mise à jour table CACCE (Sections analytiques)
##
##  Sections analytiques :
##  - Les sections analytiques sont créées en initialisant le code d'axe par 'AX'+numéro de l'axe V5
##  - Intitulés traduisibles (champs DESTRA et SHOTRA) créés uniquement pour GLANGUE et à partir des champs
##    DES et DESSHO de la table CACCE
##
##  Secteurs "Activité" et "Géographie" (Si code activité IAS actif)
##  - Les secteurs 'Activité' et 'Géographie' (qui seront des sections en V6) sont créés à partir
##    des tables diverses 360 et 361
##  - Intitulés traduisibles (champs DESTRA et SHOTRA) repris de ATEXTRA
##-------------------------------------------------------------------------------------------------------#
$CACCE
Local Integer NBAXE : NBAXE = 0
Call ECR_TIME(mess(81,125,1)-": CACCE") From DOSSUB : # maj table

Gosub CACCE1  : # Sections analytiques
Gosub CACCE2  : # Secteurs 'Activité' et 'Géographie'

#Gosub INTTRAD : # Récupération intitulés traduisibles des secteurs IAS
Return

$CACCE1
Local File =[F:ADS]DOSSIER+".CACCE"   [CCE]
Local File =[F:ADS]DOSSIER+".CACCE"   [CCE2]

Gosub SET_FIRST From TRTFIRST
Raz STOP

$LOOP_CCE
Raz NB
If GTYPDBA=2 #SQL
 Filter [F:CCE2] Where DIE=""
Endif

If STOP = 1
 STOP = 2
 CRITERE = "[F:CCE2]AXI="+num$(ICLE1)+" & [F:CCE2]CCE>'"+ACLE1+"'"
Elsif STOP = 2
 Raz STOP
 CRITERE = "[F:CCE2]AXI>"+num$(ICLE1)
Else
 CRITERE = "1=1"
Endif

Trbegin [CCE]

 GOK = 1
 For [CCE2]CCE0 Where evalue(CRITERE)
  Raz [F:CCE]
  [F:CCE]    = [F:CCE2]
  [F:CCE]DIE = "AX"+num$([F:CCE2]AXI)
  [F:CCE]ENAFLG = 2
  [F:CCE]BUDTRK = [F:CCE2]BUD
  [F:CCE]FRW    = [F:CCE2]FIYEND
  [F:CCE]UOMNBR = [F:CCE2]NBRUOM
  [F:CCE]UPDUSR = GUSER
  [F:CCE]UPDDAT = date$

  NB+=1
  Write [CCE]
  If fstat
   Call ERREUR("CACCE"-[F:CCE]DIE-[F:CCE]CCE,1) From DOSDIC
  Endif

  # Gestion des intitulés (V6 : Libellé traduisible)
  If dim([F:CCE]DES)>0
   Call MAJTEXTRA([F:CCE]DES,"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From CPTMAJ30
  Endif
  If dim([F:CCE]DESSHO)>0
   Call MAJTEXTRA([F:CCE]DESSHO,"CACCE","SHOTRA",[F:CCE]DIE,[F:CCE]CCE) From CPTMAJ30
  Endif

  If NB>GMAXUPDTRS
   ICLE1 = [F:CCE2]AXI
   ACLE1 = [F:CCE2]CCE
   STOP=1
   Break
  Endif

  NBAXE = max([F:CCE2]AXI,NBAXE)

 Next
Commit

If STOP
 Goto LOOP_CCE
Endif

# Fin de la mise à jour de la table CACCE
Trbegin [CCE]
Delete [CCE] Where [CCE]DIE=""
If fstat
 GOK = 0 : Call ERREUR("CACCE",3) From DOSDIC
Endif
Commit

Close Local File [CCE], [CCE2]
Gosub UNSET_FIRST From TRTFIRST

Return


$CACCE2
Local File =[F:ADS]DOSSIER+".CACCE"   [CCE]
Local File =[F:ADS]DOSSIER+".ATABDIV" [ADI2]
Local File =[F:ADS]DOSSIER+".ATEXTRA" [AXX2]

Trbegin [CCE]

 GOK = 1

 ## Axes IAS 'Activité' (NTAB=360) et 'Géographie' (NTAB=361)
 For NTAB = 360 To 361
  NBAXE += 1
  For [ADI2]CODE Where NUMTAB=NTAB
   Raz [F:CCE]
   [F:CCE]CCE = [F:ADI2]CODE
   If NTAB = 360
    [F:CCE]DIE = [L]AXEIAS1
   Else
    [F:CCE]DIE = [L]AXEIAS2
   Endif
   Read [AXX2] = "ATABDIV";"LNGDES";MIGGLANMAJ;num$([F:ADI2]NUMTAB);[F:ADI2]CODE
   If !fstat
    [F:CCE]DES = [F:AXX2]TEXTE
   Endif

   If dim([F:CCE]DESSHO)>0
    Read [AXX2] = "ATABDIV";"SHODES";MIGGLANMAJ;num$([F:ADI2]NUMTAB);[F:ADI2]CODE
    If !fstat
     [F:CCE]DESSHO = [F:AXX2]TEXTE
    Endif
   Endif

   [F:CCE]ENAFLG = 2
   [F:CCE]BUDTRK = 1
   [F:CCE]FRW    = 2
   [F:CCE]CREUSR = GUSER
   [F:CCE]CREDAT = date$
   [F:CCE]UPDUSR = GUSER
   [F:CCE]UPDDAT = date$

   Write [CCE]
   If fstat
    Call ERREUR("CACCE"-[F:CCE]DIE-[F:CCE]CCE,1) From DOSDIC
   Endif

   # Gestion des intitulés (V6 : Libellé traduisible)
   If dim([F:CCE]DES)>0
    Call MAJTEXTRA([F:CCE]DES,"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From CPTMAJ30
   Endif
   If dim([F:CCE]DESSHO)>0
    Call MAJTEXTRA([F:CCE]DESSHO,"CACCE","SHOTRA",[F:CCE]DIE,[F:CCE]CCE) From CPTMAJ30
   Endif

  Next
 Next

Commit

Close Local File [CCE], [ADI2], [AXX2]

Return


$INTTRAD
######################################################################################
## Intitulés traduisibles des secteurs IAS (qui deviennent des sections analytiques)
######################################################################################
Local File =[F:ADS]DOSSIER+".ATEXTRA" [AXX]
Local File =[F:ADS]DOSSIER+".ATEXTRA" [AXX2]

## 12/ Intitulés traduisibles des secteurs "Activité" (ancienne ADI 360) et secteurs "Géographie" (ADI 361)
For [AXX2] Where CODFIC="ATABDIV" & ZONE="LNGDES" & IDENT1="360"
 Read [AXX]AXX0 = "CACCE";"DESTRA";GLANGUE;"AX"+num$([L]NBAXE-1);[F:AXX2]IDENT2
 If fstat
  Gosub MAJ_TEXTRA
 Endif
Next
For [AXX2] Where CODFIC="ATABDIV" & ZONE="SHODES" & IDENT1="360"
 Read [AXX]AXX0 = "CACCE";"SHOTRA";GLANGUE;"AX"+num$([L]NBAXE-1);[F:AXX2]IDENT2
 If fstat
  Gosub MAJ_TEXTRA
 Endif
Next
For [AXX2] Where CODFIC="ATABDIV" & ZONE="LNGDES" & IDENT1="361"
 Read [AXX]AXX0 = "CACCE";"DESTRA";GLANGUE;"AX"+num$([L]NBAXE);[F:AXX2]IDENT2
 If fstat
  Gosub MAJ_TEXTRA
 Endif
Next
For [AXX2] Where CODFIC="ATABDIV" & ZONE="SHODES" & IDENT1="361"
 Read [AXX]AXX0 = "CACCE";"SHOTRA";GLANGUE;"AX"+num$([L]NBAXE);[F:AXX2]IDENT2
 If fstat
  Gosub MAJ_TEXTRA
 Endif
Next
Close Local File [AXX], [AXX2]
Return

$MAJ_TEXTRA
Raz [F:AXX]
[F:AXX] = [F:AXX2]
[F:AXX]CODFIC = "CACCE"
If [F:AXX2]IDENT1="360"
 [F:AXX]IDENT1 = "AX"+num$([L]NBAXE-1)
Elsif [F:AXX2]IDENT1="361"
 [F:AXX]IDENT1 = "AX"+num$([L]NBAXE)
Endif
If [F:AXX2]ZONE = "LNGDES"
 [F:AXX]ZONE = "DESTRA"
Else
 [F:AXX]ZONE = "SHOTRA"
Endif
Write [AXX]
If fstat
 Call ERREUR("ATEXTRA"-[F:AXX]CODFIC-[F:AXX]ZONE-[F:AXX]LANGUE-[F:AXX]IDENT1-[F:AXX]IDENT2,1) From DOSDIC
Endif
Delete [AXX2] Curr
Return


##-------------------------------------------------------------------------------------------------------#
# Mise à jour CADSP (Répartitions analytiques)
##-------------------------------------------------------------------------------------------------------#
$CADSP

Local File =[F:ADS]DOSSIER+".CADSP" [DSP]
Local File =[F:ADS]DOSSIER+".GLED"  [LED]

Call ECR_TIME(mess(81,125,1)-": CADSP") From DOSSUB : # maj table


Read [LED]LED0 = WLEDANA(0)

Trbegin [DSP]

 GOK = 1

 For [DSP]DSP0
  [F:DSP]NBRDSP = [F:DSP]DSPLIG
  For AXE=1 To [F:LED]DIENBR
   [F:DSP]DIE(AXE-1) = [F:LED]DIE(AXE-1)
  Next
  [F:DSP]NBRDIE = [F:LED]DIENBR
  [F:DSP]UPDUSR = GUSER
  [F:DSP]UPDDAT = date$
  Rewrite [DSP]
  If fstat
   Call ERREUR("CADSP"-[F:DSP]DSP-num$([F:DSP]NBRDSP),1) From DOSDIC
  Endif

  # Gestion des intitulés (V6 : Libellé traduisible)
  If dim([F:DSP]DES)>0
   Call MAJTEXTRA([F:DSP]DES,"CADSP","DESTRA",[F:DSP]DSP,"") From CPTMAJ30
  Endif
  If dim([F:DSP]DESSHO)> 0
   Call MAJTEXTRA([F:DSP]DESSHO,"CADSP","SHOTRA",[F:DSP]DSP,"") From CPTMAJ30
  Endif

 Next

Commit

Close Local File [DSP], [LED]
Return


##-------------------------------------------------------------------------------------------------------#
# Recopie pièces autos V6
##-------------------------------------------------------------------------------------------------------#
$GAUTACE
## Copie de toutes les pièces automatiques du dossier de référence V6 dans le dossier migré
Local File =[F:ADS]DOSCOP+".GAUTACE"    [GAU0]
Local File =[F:ADS]DOSCOP+".GAUTACE"    [GAU1]
Local File =[F:ADS]DOSCOP+".GAUTACED"   [GAD1]
Local File =[F:ADS]DOSCOP+".GAUTACEF"   [GAG1]
Local File =[F:ADS]DOSCOP+".GVARPARVAL" [GVV1]

Local File =[F:ADS]DOSSIER+".GAUTACE"    [GAU2]
Local File =[F:ADS]DOSSIER+".GAUTACED"   [GAD2]
Local File =[F:ADS]DOSSIER+".GAUTACEF"   [GAG2]
Local File =[F:ADS]DOSSIER+".GVARPARVAL" [GVV2]

Call ECR_TIME(mess(81,125,1)-": GAUTACE") From DOSSUB : # maj table

Local Char TABLE(20)
For [GAU0]GAU0
 Read [GAU2]GAU0 = [F:GAU0]COD
 TABLE = [F:GAU0]COD
 Gosub TR_COP
Next
Close Local File [GAU0], [GAU1], [GAD1], [GAG1], [GVV1], [GAU2], [GAD2], [GAG2], [GVV2]
Return

$TR_COP
Local Char DESIG1(GLONDES) , DESIG2(GLONSHO)
GOK = 1
Trbegin [GAU2], [GAD2], [GAG2], [GVV2]
 Delete [GAG2] Where COD=TABLE
 If fstat
  GOK = 0 : Call ERREUR("GAUTACEF",3) From DOSDIC
 Endif
 Delete [GVV2] Where COD=TABLE
 If fstat
  GOK = 0 : Call ERREUR("GVARPARVAL",3) From DOSDIC
 Endif
 For [GAD2] Where COD=TABLE
  Read [GAD1]GAD0 = [F:GAD2]COD;[F:GAD2]LINNUM
  If fstat
   Delete [GAD2]
   If fstat
    GOK = 0 : Call ERREUR("GAUTACED",3) From DOSDIC
   Endif
  Endif
 Next
 For [GAD1] Where COD=TABLE
  Read [GAD2]GAD0 = [F:GAD1]COD;[F:GAD1]LINNUM
  If fstat
   [F:GAD2] = [F:GAD1]
   # Gestion des intitulés (V6 : Libellé traduisible)
   Call LECTEXTRA(DESIG1,"GAUTACED","DESTRA",[F:GAD2]COD,num$([F:GAD2]LINNUM)) From CPTMAJ30
   If dim([F:GAD2]DES)>0
    [F:GAD2]DES = DESIG1
   Endif
   Write [GAD2]
  Else
   DESIG1 = [F:GAD2]DES
   [F:GAD2] = [F:GAD1]
   [F:GAD2]DES = DESIG1
   Rewrite [GAD2]
  Endif
  If fstat
   Call ERREUR("GAUTACED"-[F:GAD1]COD-num$([F:GAD1]LINNUM),1) From DOSDIC
  Endif
  # Gestion des intitulés (V6 : Libellé traduisible)
  If dim([F:GAD2]DES)>0
   Call MAJTEXTRA([F:GAD2]DES,"GAUTACED","DESTRA",[F:GAD2]COD,num$([F:GAD2]LINNUM)) From CPTMAJ30
  Endif
 Next
 For [GAG1] Where COD=TABLE
  [F:GAG2] = [F:GAG1]
  Write [GAG2]
  If fstat
   Call ERREUR("GAUTACEF"-[F:GAG1]COD-num$([F:GAG1]LINNUM)-[F:GAG1]FLD,1) From DOSDIC
  Endif
 Next
 For [GVV1] Where COD=TABLE
  [F:GVV2] = [F:GVV1]
  Write [GVV2]
  If fstat
   Call ERREUR("GVARPARVAL"-[F:GVV1]COD-num$([F:GVV1]LINNUM)-[F:GVV1]FLD-[F:GVV1]CODVAR-[F:GVV1]CODPAR,1) From DOSDIC
  Endif
 Next
 Read [GAU1]GAU0 = TABLE
 Read [GAU2]GAU0 = TABLE
 If fstat
  [F:GAU2] = [F:GAU1]
  If dim([F:GAU2]CREUSR)>0 : [F:GAU2]CREUSR = GUSER   : Endif
  If dim([F:GAU2]CREDAT)>0 : [F:GAU2]CREDAT = date$   : Endif
  If dim([F:GAU2]UPDUSR)>0 : [F:GAU2]UPDUSR = ""      : Endif
  If dim([F:GAU2]UPDDAT)>0 : [F:GAU2]UPDDAT = [0/0/0] : Endif
  # Gestion des intitulés (V6 : Libellé traduisible)
  Call LECTEXTRA(DESIG1,"GAUTACED","DESTRA",[F:GAU2]COD,"") From CPTMAJ30
  If dim([F:GAD2]DES)>0
   [F:GAD2]DES = DESIG1
  Endif
  Call LECTEXTRA(DESIG1,"GAUTACED","SHOTRA",[F:GAU2]COD,"") From CPTMAJ30
  If dim([F:GAU2]DESSHO)>0
   [F:GAU2]DESSHO = DESIG1
  Endif
  Write [GAU2]
 Else
  DESIG1 = [F:GAU2]DES
  DESIG2 = [F:GAU2]DESSHO
  [F:GAU2] = [F:GAU1]
  If dim([F:GAU2]UPDUSR)>0 : [F:GAU2]UPDUSR = GUSER   : Endif
  If dim([F:GAU2]UPDDAT)>0 : [F:GAU2]UPDDAT = date$   : Endif
  [F:GAU2]DES    = DESIG1
  [F:GAU2]DESSHO = DESIG2
  Rewrite [GAU2]
 Endif
 If fstat
  Call ERREUR("GAUTACE"-[F:GAU1]COD,1) From DOSDIC
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
 If dim([F:GAU2]DES)>0
  Call MAJTEXTRA([F:GAU2]DES,"GAUTACE","DESTRA",[F:GAU2]COD,"") From CPTMAJ30
 Endif
 If dim([F:GAU2]DESSHO)> 0
  Call MAJTEXTRA([F:GAU2]DESSHO,"GAUTACE","SHOTRA",[F:GAU2]COD,"") From CPTMAJ30
 Endif

Commit
Return



##-------------------------------------------------------------------------------------------------------#
# Recopie groupes pièces autos V6
##-------------------------------------------------------------------------------------------------------#
$GRPAUTACE
## Copie de tous les groupes de pièces automatiques du dossier de référence V6 dans le dossier migré

Local File =[F:ADS]DOSCOP+".GRPAUTACE"    [GRA0]
Local File =[F:ADS]DOSCOP+".GRPAUTACE"    [GRA1]
Local File =[F:ADS]DOSCOP+".GRPACEMTC"    [GRM1]

Local File =[F:ADS]DOSSIER+".GRPAUTACE"   [GRA2]
Local File =[F:ADS]DOSSIER+".GRPACEMTC"   [GRM2]

Call ECR_TIME(mess(81,125,1)-": GRPAUTACE") From DOSSUB : # maj table

Local Char TABLE(10)
Local Char DESIG1(GLONDES) , DESIG2(GLONSHO)

For [GRA0]GRA0
 Read [GRA2]GRA0 = [F:GRA0]COD
 If !fstat
  DESIG1 = [F:GRA2]DES
  DESIG2 = [F:GRA2]DESSHO
 Else
  Raz DESIG1,DESIG2
 Endif
 TABLE = [F:GRA0]COD
 Gosub TR_COP_GRA
Next
Close Local File [GRA0], [GRA1], [GRM1], [GRA2], [GRM2]
Return

$TR_COP_GRA

GOK = 1
Trbegin [GRA2] , [GRM2]
 Delete [GRA2] Where COD=TABLE
 If fstat
  GOK = 0 : Call ERREUR("GRPAUTACE",3) From DOSDIC
 Endif
 Delete [GRM2] Where COD=TABLE
 If fstat
  GOK = 0 : Call ERREUR("GRPACEMTC",3) From DOSDIC
 Endif
 For [GRA1] Where COD=TABLE
  [F:GRA2] = [F:GRA1]
  If DESIG1<>"" : [F:GRA2]DES    = DESIG1 : Endif
  If DESIG2<>"" : [F:GRA2]DESSHO = DESIG2 : Endif
  If dim([F:GRA2]UPDUSR)>0 : [F:GRA2]UPDUSR = GUSER : Endif
  If dim([F:GRA2]UPDDAT)>0 : [F:GRA2]UPDDAT = date$ : Endif
  Write [GRA2]
  If fstat
   Call ERREUR("GRPAUTACE"-[F:GRA1]COD,1) From DOSDIC
  Endif
  # Gestion des intitulés (V6 : Libellé traduisible)
  If dim([F:GRA2]DES)>0
   Call MAJTEXTRA([F:GRA2]DES,"GRPAUTACE","DESTRA",[F:GRA2]COD,"") From CPTMAJ30
  Endif
  If dim([F:GRA2]DESSHO)> 0
   Call MAJTEXTRA([F:GRA2]DESSHO,"GRPAUTACE","SHOTRA",[F:GRA2]COD,"") From CPTMAJ30
  Endif
 Next
 For [GRM1] Where COD=TABLE
  [F:GRM2] = [F:GRM1]
  Write [GRM2]
  If fstat
   Call ERREUR("GRPACEMTC"-[F:GRM1]COD,1) From DOSDIC
  Endif
 Next
Commit
Return


##-------------------------------------------------------------------------------------------------------#
# Recopie variables pièces autos V6
##-------------------------------------------------------------------------------------------------------#
$VARAUTACE
## Copie de tous les variables de pièces automatiques du dossier de référence V6 dans le dossier migré

Local File =[F:ADS]DOSCOP+".GVARGAU"    [GVG0]
Local File =[F:ADS]DOSCOP+".GVARGAU"    [GVG1]
Local File =[F:ADS]DOSCOP+".GVARPARGAU" [GVP1]
Local File =[F:ADS]DOSCOP+".GVARCODPAR" [GVA1]
Local File =[F:ADS]DOSCOP+".ATEXTE"     [ATX1]

Local File =[F:ADS]DOSSIER+".GVARGAU"    [GVG2]
Local File =[F:ADS]DOSSIER+".GVARPARGAU" [GVP2]
Local File =[F:ADS]DOSSIER+".GVARCODPAR" [GVA2]
Local File =[F:ADS]DOSSIER+".ATEXTE"     [ATX2]

Call ECR_TIME(mess(81,125,1)-": GVARGAU") From DOSSUB : # maj table

Local Char TABLE(10)
For [GVG0]GVG0
 Read [GVG2]GVG0 = [F:GVG0]CODVAR
 TABLE = [F:GVG0]CODVAR
 Gosub TR_COP_GVG
Next
Close Local File [GVG0], [GVG1], [GVP1], [GVA1], [ATX1], [GVG2], [GVP2], [GVA2], [ATX2]
Return

$TR_COP_GVG
GOK = 1
Trbegin [GVG2] , [GVP2] , [GVA2], [ATX2]
 Delete [GVG2] Where CODVAR=TABLE
 If fstat
  GOK = 0 : Call ERREUR("GVARGAU",3) From DOSDIC
 Endif
 Delete [GVP2] Where CODVAR=TABLE
 If fstat
  GOK = 0 : Call ERREUR("GVARPARGAU",3) From DOSDIC
 Endif
 For [GVG1] Where CODVAR=TABLE
  [F:GVG2] = [F:GVG1]
  If dim([F:GVG2]UPDUSR)>0 : [F:GVG2]UPDUSR = GUSER : Endif
  If dim([F:GVG2]UPDDAT)>0 : [F:GVG2]UPDDAT = date$ : Endif
  Call COPTEXTE([F:GVG1]INTITA,[F:GVG2]INTITA) From OBJDIV
  For I=0 To dim([F:GVG]INFO)-1
   Call COPTEXTE([F:GVG1]INFO(I),[F:GVG2]INFO(I)) From OBJDIV
  Next I
  Write [GVG2]
  If fstat
   Call ERREUR("GVARGAU"-[F:GVG1]CODVAR,1) From DOSDIC
  Endif
  # Gestion des intitulés (V6 : Libellé traduisible)
  If dim([F:GVG1]INTITA)>0
   Read [ATX1]NUMERO = MIGGLANMAJ;[F:GVG1]INTITA
   If !fstat
    Call MAJTEXTRA([F:ATX1]TEXTE,"GVARGAU","DESTRA",[F:GVG2]CODVAR,"") From CPTMAJ30
   Endif
  Endif
 Next
 For [GVP1] Where CODVAR=TABLE
  [F:GVP2] = [F:GVP1]
  Call COPTEXTE([F:GVP1]INTITPAR,[F:GVP2]INTITPAR) From OBJDIV
  Write [GVP2]
  If fstat
   Call ERREUR("GVARPARGAU"-[F:GVP1]CODVAR,1) From DOSDIC
  Endif
  # Gestion des intitulés (V6 : Libellé traduisible)
  # GVARPARGAU stocke l'intitulé du paramètre... table GVARCODPAR (fait ci dessous)
  # Initulé sous GVARPARGAU n'a plus son utilité
  Read [GVA1]GVA0 = [F:GVP1]CODPAR
  If !fstat
   Read [GVA2]GVA0 = [F:GVA1]CODPAR
   If !fstat
    [F:GVA2] = [F:GVA1]
    Call COPTEXTE([F:GVA1]INTITPAR,[F:GVA2]INTITPAR) From OBJDIV
    Rewrite [GVA2]
   Else
    [F:GVA2] = [F:GVA1]
    Call COPTEXTE([F:GVA1]INTITPAR,[F:GVA2]INTITPAR) From OBJDIV
    Write [GVA2]
   Endif
   If fstat
    Call ERREUR("GVARCODPAR"-[F:GVA1]CODPAR,1) From DOSDIC
   Endif
   # Gestion des intitulés (V6 : Libellé traduisible)
   If dim([F:GVA1]INTITPAR)>0
    Read [ATX1]NUMERO = MIGGLANMAJ;[F:GVA1]INTITPAR
    If !fstat
     Call MAJTEXTRA([F:ATX1]TEXTE,"GVARCODPAR","DESTRA",[F:GVA2]CODPAR,"") From CPTMAJ30
    Endif
   Endif
  Endif
 Next
Commit
Return

##-------------------------------------------------------------------------------------------------------#
# Recopie formules de pièces autos V6
##-------------------------------------------------------------------------------------------------------#
$TABFOR
## Copie les formules de pièces automatiques du dossier de référence V6 dans le dossier migré SI inexistante !

Local File =[F:ADS]DOSCOP+".TABFOR"     [TFO1]
Local File =[F:ADS]DOSSIER+".TABFOR"    [TFO2]

Call ECR_TIME(mess(81,125,1)-": TABFOR") From DOSSUB : # maj table

Local Char TABLE(10)
Local Char DESIG1(GLONDES) , DESIG2(GLONSHO)

Filter [TFO1] Where FORTYP=21
For [TFO1]TFO0
 Read [TFO2]TFO0 = 21;[F:TFO1]FORCOD
 If fstat
  TABLE = [F:TFO1]FORCOD
  Gosub TR_COP_TFO
 Endif
Next
Filter [TFO1]
Close Local File [TFO1], [TFO2]
Return

$TR_COP_TFO
GOK = 1
Trbegin [TFO2]

  Raz [TFO2]

  [F:TFO2]FORTYP = [F:TFO1]FORTYP
  [F:TFO2]FORCOD = [F:TFO1]FORCOD
  [F:TFO2]FORNUM = num$([F:TFO2]FORTYP)

  For I=0 To [F:ADS]NBLEG-1
   [F:TFO2]LEG(I) = [F:ADS]DOSLEG(I)
  Next I
  [F:TFO2]FORFOR = [F:TFO1]FORFOR  # Uniquement sur la 1ère législation (identique à SUPMAJ30)

  # Gestion des intitulés (V6 : Libellé traduisible)
  Call LECTEXTRA(DESIG1,"TABFOR","DES",[F:TFO1]FORNUM,[F:TFO1]FORCOD) From CPTMAJ30
  Call LECTEXTRA(DESIG2,"TABFOR","DESSHO",[F:TFO1]FORNUM,[F:TFO1]FORCOD) From CPTMAJ30
  Call MAJTEXTRA(DESIG1,"TABFOR","DES",[F:TFO2]FORNUM,[F:TFO2]FORCOD) From CPTMAJ30
  Call MAJTEXTRA(DESIG2,"TABFOR","DESSHO",[F:TFO2]FORNUM,[F:TFO2]FORCOD) From CPTMAJ30

  [F:TFO2]CREUSR = GUSER
  [F:TFO2]CREDAT = date$
  [F:TFO2]UPDUSR = GUSER
  [F:TFO2]UPDDAT = date$
  Write [TFO2]
  If fstat
   Call ERREUR("TABFOR"-[F:TFO2]FORNUM-[F:TFO2]FORCOD,2) From DOSDIC
  Endif

Commit
Return

##-------------------------------------------------------------------------------------------------------#
# Suppression données table BATCH (tâche compta). La tâche compta sera recopiée à partir du dossier
# de réf
##-------------------------------------------------------------------------------------------------------#
# Plus d'appel => RAZFIC sous CPTMAJ30
$BATCH_CPT
Return

Call ECR_TIME(mess(81,125,1)-": BATCH") From DOSSUB : # maj table

Local File =[F:ADS]DOSSIER+".BATCH" [BTC]
Trbegin [BTC]
 Delete [BTC] Where 1=1
 If fstat
  GOK = 0 : Call ERREUR("BATCH",3) From DOSDIC
 Endif
Commit
Close Local File [BTC]
Return

##-------------------------------------------------------------------------------------------------------#
# Initialisation COA... pour le lettrage.
##-------------------------------------------------------------------------------------------------------#
$BATCH_LET

Call ECR_TIME(mess(81,125,1)-": MATCHCODE") From DOSSUB : # maj table


Local File =[F:ADS]DOSSIER+".MATCHCODE" [MTC]

Trbegin [MTC]
For [MTC] Where COA=""
 [F:MTC]COA = PLGEN
 Write [MTC]
 If fstat
   Call ERREUR("MATCHCODE"-[F:MTC]ACC-[F:MTC]BPR,1) From DOSDIC
 Endif
Next
Commit

Trbegin [MTC]
Delete [MTC] Where COA=""
If fstat
 GOK = 0 : Call ERREUR("MATCHCODE",3) From DOSDIC
Endif
Commit
Close Local File [MTC]
Return


##-------------------------------------------------------------------------------------------------------#
# Initialisation COA... pour les tables temporaires DCLVAT
##-------------------------------------------------------------------------------------------------------#
$DCLVAT
Local File =[F:ADS]DOSSIER+".DCLVAT"    [DLV]
Local File =[F:ADS]DOSSIER+".DCLVATPAY" [DVP]

Local File =[F:ADS]DOSSIER+".GACM"      [GCM]         # Modèles comptables
Local File =[F:ADS]DOSSIER+".COMPANY"   [CPY]         # Sociétés

Local Char    LEDGEN(3)

Call ECR_TIME(mess(81,125,1)-": DCLVAT") From DOSSUB : # maj table
Trbegin [DLV]
For [DLV]DLV0(1)
 Read [CPY]CPY0 = [F:DLV]CPY
 If [F:CPY]ACM <> [F:GCM]GCM
  Read [F:GCM]GCM0 = [F:CPY]ACM
 Endif
 LEDGEN     = [F:GCM]LED(0)

 For [DLV]DLV0
  [F:DLV]COA = LEDGEN
  Rewrite [DLV]
  If fstat
   Call ERREUR("DCLVAT"-[F:DLV]CPY-[F:DLV]ACC,1) From DOSDIC
  Endif
 Next
Next
Commit

Call ECR_TIME(mess(81,125,1)-": DCLVATPAY") From DOSSUB : # maj table
Trbegin [DVP]
For [DVP]DVP0(1)
 Read [CPY]CPY0 = [F:DVP]CPY
 If [F:CPY]ACM <> [F:GCM]GCM
  Read [F:GCM]GCM0 = [F:CPY]ACM
 Endif
 LEDGEN     = [F:GCM]LED(0)

 For [DVP]DVP0
  [F:DVP]COA = LEDGEN
  Rewrite [DVP]
  If fstat
   Call ERREUR("DCLVATPAY"-[F:DVP]CPY-[F:DVP]ACC,1) From DOSDIC
  Endif
 Next
Next
Commit

Close Local File [DLV],[DVP],[GCM],[CPY]
Return

##-------------------------------------------------------------------------------------------------------#
# Initialisation COA... pour la ritenzione
##-------------------------------------------------------------------------------------------------------#
$RITENZIONE
If filinfo(filpath("FIL","RITENZIONE","fde",[F:ADS]DOSSIER),0)>0

 Call ECR_TIME(mess(81,125,1)-": RITENZIONE") From DOSSUB : # maj table

 Local File =[F:ADS]DOSSIER+".RITENZIONE" [RTZ]

 Trbegin [RTZ]
 For [RTZ]
  [F:RTZ]COA = PLGEN
  Rewrite [RTZ]
  If fstat
   Call ERREUR("RITENZIONE"-[F:RTZ]RITCOD,1) From DOSDIC
  Endif
 Next
 Commit

 Close Local File [RTZ]
Endif
Return


##-------------------------------------------------------------------------------------------------------#
# Mise à jour CSFRES : Résultat d'extraction
##-------------------------------------------------------------------------------------------------------#
$CSFRES
Local File =[F:ADS]DOSSIER+".CSFRES" [CWR]

Call ECR_TIME(mess(81,125,1)-": CSFRES") From DOSSUB : # maj table

Trbegin [CWR]

 GOK = 1

 For [CWR]CWR0
  [F:CWR]CURLED = [F:CWR]DEVCPY
  [F:CWR]AMTLED = [F:CWR]AMTLOC
  Rewrite [CWR]
  If fstat
   Call ERREUR("CSFRES"-num$([F:CWR]NUMRPT),1) From DOSDIC
  Endif
 Next

Commit

Close Local File [CWR]

Return
