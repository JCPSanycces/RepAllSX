#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","COPRPT","ACOPRPT",3,"XYCOPRPT") From GTRAITE
End
######################################################################################

######################################
$ACTION
Case ACTION
 When "INIT"      : Gosub INIT
 When "EXEC"      : Gosub EXEC

Endcase
Return

$INIT
TMP = 1

Return

$EXEC
Local Integer STAT

Local Char    APPLI(GDIMFIC),MACHINE(GDIMFIC)
Call MACHINE([M]DOSDES,MACHINE,APPLI) From ORDSYS

Local Char    APPLI2(GDIMFIC),MACHINE2(GDIMFIC)
Call MACHINE([M]DOSORG,MACHINE2,APPLI2) From ORDSYS

Call COPIE(filpath("REPORT/"+[M]LAN,[M]RPT,"rpt",APPLI2,"",MACHINE2)
&         ,filpath("REPORT/"+[M]LAN,[M]RPT,"rpt",APPLI,"",MACHINE)
&         ,STAT) From ORDSYS
If STAT=0
  #LSE SAM 110554
  #LSE SAM 110879 => Use [M]DOSDES instead of APPLI
  Call TRACE_COR_DOSS([M]DOSDES,"ETA",[M]RPT,[M]LAN,"C") From ACOPIE
  If  !GSERVEUR
    Call MESSAGE (mess ( 29, 9003, 1 )) From GESECRAN
  Endif

Endif

zonsui = "RPT"
SAI = 1
Return

#####################################################################################
Subprog D_DOSORG(VALEUR)
Variable Char    VALEUR()
VALEUR = nomap
GMODIF = 0
End

Subprog AS_DOSORG(VALEUR)
Variable Char    VALEUR()
If !GMODIF : mkstat = 2 : Endif
GMODIF = 1
End

Subprog AS_DOSDES(VALEUR)
Variable Char    VALEUR()
If GDOSPATH="" : End : Endif
Call C_DOSSIER(GDOSPATH) From DOSCONT
If mkstat
 mkstat = 0
Else
 VALEUR = GDOSPATH
Endif
End

Subprog C_DOSORG(VALEUR)
Variable Char    VALEUR()
Call CTL_DROIT_DOSSIER(VALEUR,"E") From DOSCONT
If mkstat : End : Endif
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Call C_DOSDES(VALEUR) From ACOPIE
If mkstat : End : Endif
GDOSPATH = VALEUR
End

Subprog C_RPT(VALEUR)
Variable Char    VALEUR()
#LSE SAM 110554
If [M]LANFILTER<>""
  [M]LAN=[M]LANFILTER
  Raz [M]LANFILTER
Endif
If [M]LAN = "" : End : Endif
Local Char    APPLI2(GDIMFIC),MACHINE2(GDIMFIC)
Call MACHINE([M]DOSORG,MACHINE2,APPLI2) From ORDSYS
If filinfo(filpath("REPORT/"+[M]LAN,VALEUR,"rpt",APPLI2,"",MACHINE2),7) <=0
 GMESSAGE = mess(163,123,1) : # Etat inexistant
 mkstat = 2 : End
Endif
End

Subprog C_LAN(VALEUR)
Variable Char    VALEUR()
Local Char    APPLI2(GDIMFIC),MACHINE2(GDIMFIC)
Call MACHINE([M]DOSORG,MACHINE2,APPLI2) From ORDSYS
If filinfo(filpath("REPORT/"+VALEUR,[M]RPT,"rpt",APPLI2,"",MACHINE2),7) <=0
 GMESSAGE = mess(163,123,1) : # Etat inexistant
 mkstat = 2 : End
Endif
End

