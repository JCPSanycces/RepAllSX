    Errbox(mess(48,11706,1))
    mkstat=2
  Endif
#DEHEN - 2016-09-02 - Check for valid length on Social security number - END


#------<Début> Z.Meryame 05/03/2014
# Variables pour Poste Client
Local Char FICDON(GDIMFIC),FICHIER(GDIMFIC),NOMFIC(GDIMFIC),URL(GDIMFIC)
Local Char FILBAL(250) , NAM(250) , FICHIER(GDIMFIC) , CHEMIN(GDIMFIC) , MACHINE(GDIMFIC) , CRITSPE(250)
Local Char EXT(5)
Local Char POINT(1)
Local Integer STAT

NAM    = "DS_"+num$(val(SOC))+"_"+num$(LPERIODE) # Nom du fichier
EXT    = "txt"                                   # Extension du fichier

If left$([M:HRSGE0]DATFIL,1)="#"
  [M:HRSGE0]EMPLOC =1
  Call SET_NAMCLI([M:HRSGE0]DATFIL) From ORDSYS
Else
  [M:HRSGE0]EMPLOC =2
    If [M:HRSGE0]DATFIL="" : [M:HRSGE0]DATFIL= filpath("tmp","","",nomap,"","") : Endif
Endif

FICHIER = [M:HRSGE0]DATFIL
Call MACHINE(FICHIER,MACHINE,CHEMIN) From ORDSYS

NOMFIC  = NAM

If [M:HRSGE0]EMPLOC = 1 : # Client
 FICHIER = filpath(CHEMIN,NOMFIC,EXT)
 Call SET_FICNAM(FICHIER,FICDON,URL) From ORDSYS
Else
 FICDON = filpath(CHEMIN,NOMFIC,EXT,"","",MACHINE)
Endif

Call GENERER(val(SOC),LPERIODE,FICDON)

If [M:HRSGE0]EMPLOC = 1
 Call COPCLI(FICDON,FICHIER,STAT) From ORDSYS
 If STAT=1
  # Fichier non copiÃ© sur le poste client
   Return
 Elsif STAT>1
  # Fichier inexistant
    Return
 Endif
Endif

#Infbox ("Génération Fichier : DS_"+num$(val(SOC))+"_"+num$([L]LPERIODE)+".TXT ok")
Infbox ("File Generated : DS_"+num$(val(SOC))+"_"+num$([L]LPERIODE)+".TXT ok")
#------<Fin> Z.Meryame 05/03/2014
Return

