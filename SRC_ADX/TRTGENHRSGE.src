#Période

LPERIODE=val(format$("N0:6X",format$("D:YYYYMM", [M:HRSGE0]ENDDAT)))

#N0 CNSS Société
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If clalev([F:CPYAFR])=0 : Local File HRCOMPANYAFR [CPYAFR] : Endif #DEHEN - Added AFR company table to get Company Soc Sec Num

#Read[CPY]CPY0 =[HRSGE0]CPY
Read[CPYAFR]CPYAFR0 =[HRSGE0]CPY #DEHEN - Changed to AFR table
