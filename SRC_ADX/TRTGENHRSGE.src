Subprog AM_EMPLOC(VALEUR)
Variable Integer VALEUR

  Raz  [M:HRSGE0]DATFIL
  If VALEUR=1
   Call SET_NAMCLI([M:HRSGE0]DATFIL) From ORDSYS
   Grizo [M:HRSGE0]DATFIL
  Else
   [M:HRSGE0]DATFIL = filpath("tmp","","",nomap,"","")
   Actzo [M:HRSGE0]DATFIL
  Endif
  Affzo [M:HRSGE0]DATFIL
End


