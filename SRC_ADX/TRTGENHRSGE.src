Subprog GENERER(LNUMAFFIL,LPERIODE,LFICH)

Value Integer LNUMAFFIL
Value Integer LPERIODE
Value Char LFICH
Local Integer A,B,C,D,E,OK4,OK5
Local Char LIGNE1 (250)
Local Char LIGNE2 (250)
Local Char XCRITE (250)
Local Char XCRITE1(250)

Gosub OPEN_FILE

OK=0
######################EXPORT DU FICHIER SORTIE###############
XCRITE="1=1"
If [M:HRSGE0]CPY<>""
   XCRITE +="& [HRSSC2]CPY=[M:HRSGE0]CPY"
Endif

If [M:HRSGE0]FCY<>""
   XCRITE +="& [HRSSC2]FCY=[M:HRSGE0]FCY"
Endif

If [M:HRSGE0]CRI <> "" Then
  XCRITE1 = [M:HRSGE0]CRI
Else
  XCRITE1 ="1=1"
Endif

Local Char XSALREEL,XSALPLAF, XTSALREEL,XTSALPLAF

#Openo "#@C:\DEC_CNSS\CNSS_ENVOI\DS_"+num$(LNUMAFFIL)+"_"+num$(LPERIODE)+".TXT"
Openo LFICH, 0 Using[XXX]  #Z.Meryame 05/03/2014
adxirs = chr$(13)+chr$(10)

For[HRSDM0] Where PER=[L]LPERIODE and CPYAFFNUM=[L]LNUMAFFIL
  Wrseq [HRSDM0]RECTYP,[HRSDM0]LBLTRF,[HRSDM0]CAT,space$(241) Using[XXX]
Next

For[HRSSA1]  Where PER=[L]LPERIODE and CPYAFFNUM=[L]LNUMAFFIL

#JASMI - 2017-03-15 - START
#  Wrseq[HRSSA1]RGTTYP,format$("N0:7X",[HRSSA1]CPYAFFNUM), format$("N0:6X",[HRSSA1]PER),
#&     format$("K:40X",[HRSSA1]CPYNAM),format$("K:40X",[HRSSA1]ACT),format$("K:120X",[HRSSA1]ADD),
#&     format$("K:20X",[HRSSA1]CTY),format$("K:6X",[HRSSA1]POSCOD), format$("K:2X",[HRSSA1]SSCFDS),format$("K:8X",format$("DDMMYYYY",[HRSSA1]DATISS)),format$("K:8X",format$("DDMMYYYY",[HRSSA1]
#& DATRET)) Using
#& [XXX]
  Wrseq[HRSSA1]RGTTYP,format$("N0:7X",[HRSSA1]CPYAFFNUM), format$("N0:6X",[HRSSA1]PER),
&     format$("K:40X",[HRSSA1]CPYNAM),format$("K:40X",[HRSSA1]ACT),format$("K:120X",[HRSSA1]ADD),
&     format$("K:20X",[HRSSA1]CTY),format$("K:6X",[HRSSA1]POSCOD), format$("K:2X",[HRSSA1]SSCFDS),format$("K:8X",format$("YYYYMMDD",[HRSSA1]DATISS)),format$("K:8X",format$("YYYYMMDD",[HRSSA1]
& DATRET)) Using
& [XXX]
#JASMI - 2017-03-15 - START


 Next

For[HRSSC2]  Where PER=[L]LPERIODE and CPYAFFNUM=[L]LNUMAFFIL and evalue(XCRITE) and evalue(XCRITE1)
#--------------------
Raz XSALREEL,XSALPLAF
XSALREEL=num$([HRSSC2]ACTSAL)
XSALPLAF=num$([HRSSC2]SALCLG)
Call XCALC_SAL(XSALREEL)
Call XCALC_SAL(XSALPLAF)

#JASMI - 2016-10-11 - JIRA 2598 - START
#Wrseq [HRSSC2]RGTTYP,format$("N0:7X",[HRSSC2]CPYAFFNUM),format$("N0:6X",[HRSSC2]PER),format$("N0:9X",[HRSSC2]SSCNUM),format$("K:60X",[HRSSC2]NAM),
#&    format$("N0:2X",[HRSSC2]NUMCHD),format$("N0:6X",[HRSSC2]ALF),format$("N0:6X",[HRSSC2]ALFDED),format$("N0:6X",[HRSSC2]NETPAY),
#&    format$("N0:6X",[HRSSC2]REVSER),format$("N0:2X",[HRSSC2]NUMDAY),format$("N0:13X",XSALREEL)
#&    ,format$("N0:9X",XSALPLAF),format$("K:2X",[HRSSC2]STA),format$("N0:19X", [HRSSC2]CTLFLD),space$(104) Using[XXX]
Wrseq [HRSSC2]RGTTYP,format$("N0:7X",[HRSSC2]CPYAFFNUM),format$("N0:6X",[HRSSC2]PER),format$("N0:9X",[HRSSC2]SSCNUM),format$("K:60X",toupper([HRSSC2]NAM)),
&    format$("N0:2X",[HRSSC2]NUMCHD),format$("N0:6X",[HRSSC2]ALF),format$("N0:6X",[HRSSC2]ALFDED),format$("N0:6X",[HRSSC2]NETPAY),
&    format$("N0:6X",[HRSSC2]REVSER),format$("N0:2X",[HRSSC2]NUMDAY),format$("N0:13X",XSALREEL)
