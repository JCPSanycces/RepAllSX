#&      format$("N0:6X",[HRSSB3]TOTCHD),format$("N0:12X",[HRSSB3]TOTINC),format$("N0:12X",[HRSSB3]TOTDED),format$("N0:12X",[HRSSB3]TOTNET)
#&      ,format$("N0:15X",[HRSSB3]NUMMAT),format$("N0:12X",[HRSSB3]TOTSALCLG),format$("N0:6X",[HRSSB3]TOTDAY),format$("N0:15X",XTSALREEL)
#&      ,format$("N0:13X",XTSALPLAF),format$("N0:19X", [HRSSB3]CTLFLD) ,space$(116) Using[XXX]
 Wrseq [HRSSB3]RGTTYP, format$("N0:7X",[HRSSB3]CPYAFFNUM),format$("N0:6X",[HRSSB3]PER),format$("N0:6X",[HRSSB3]NUMEMP),
&      format$("N0:6X",0),format$("N0:12X",0),format$("N0:12X",0),format$("N0:12X",0)
&      ,format$("N0:15X",[HRSSB3]NUMMAT),format$("N0:12X",0),format$("N0:6X",[HRSSB3]TOTDAY),format$("N0:15X",XTSALREEL)
&      ,format$("N0:13X",XTSALPLAF),format$("N0:19X", [HRSSB3]CTLFLD) ,space$(116) Using[XXX]
#JASMI - 2017-06-20 - END
Next


For[HRSIB4]  Where PER=[L]LPERIODE and CPYAFFNUM=[L]LNUMAFFIL
    Raz XSALREEL,XSALPLAF
    XSALREEL=num$([HRSIB4]SAL)
    XSALPLAF=num$([HRSIB4]SALCLG)
    Call XCALC_SAL(XSALREEL)
    Call XCALC_SAL(XSALPLAF)

#JASMI - 2016-10-11 - JIRA 2598 - START
#     Wrseq "B04", format$("N0:7X",LNUMAFFIL),format$("N0:6X",LPERIODE),format$("N0:9X",[HRSIB4]SSCNUM),format$("K:60X",[HRSIB4]NAM)
#&         ,format$("K:8X",[HRSIB4]TPYSOCNUM),format$("N0:2X",[HRSIB4]NUMDAY),format$("N0:13X",XSALREEL),format$("N0:9X",XSALPLAF)
#&         ,format$("N0:19X",[HRSIB4]CTLFLD) ,space$(124) Using[XXX]
     Wrseq "B04", format$("N0:7X",LNUMAFFIL),format$("N0:6X",LPERIODE),format$("N0:9X",[HRSIB4]SSCNUM),format$("K:60X",toupper([HRSIB4]NAM))
&         ,format$("K:8X",[HRSIB4]TPYSOCNUM),format$("N0:2X",[HRSIB4]NUMDAY),format$("N0:13X",XSALREEL),format$("N0:9X",XSALPLAF)
&         ,format$("N0:19X",[HRSIB4]CTLFLD) ,space$(124) Using[XXX]
#JASMI - 2016-10-11 - JIRA 2598 - END
  OK4=1
Next

If OK4=0
  Wrseq "B04",format$("N0:7X",LNUMAFFIL),format$("N0:6X",LPERIODE),space$(9),space$(60),space$(8),format$("N0:2X",0)
&       ,format$("N0:13X",0),format$("N0:9X",0),format$("N0:19X",0) ,space$(124) Using[XXX]
Endif

OK5=0
For[HRSIA5]  Where PER=[L]LPERIODE and CPYAFFNUM=[L]LNUMAFFIL
   Raz XTSALREEL,XTSALPLAF
    XTSALREEL=num$([HRSIA5]TOTWAG)
    XTSALPLAF=num$([HRSIA5]TOTSALCLG)
    Call XCALC_SAL(XTSALREEL)
    Call XCALC_SAL(XTSALPLAF)
  Wrseq "B05",  format$("N0:7X",LNUMAFFIL),format$("N0:6X",LPERIODE),format$("N0:6X",[HRSIA5]NUMEMP),format$("N0:15X",[HRSIA5]NUMMAT)
&      ,format$("N0:6X",[HRSIA5]TOTDAY),format$("N0:15X",XTSALREEL),
&    format$("N0:13X",XTSALPLAF),format$("N0:19X",[HRSIA5]CTLFLD),space$(170) Using[XXX]
OK5=1
Next

If OK5=0  Then
 Wrseq "B05",  format$("N0:7X",LNUMAFFIL),format$("N0:6X",LPERIODE),format$("N0:6X",0),format$("N0:15X",0)
&      ,format$("N0:6X",0),format$("N0:15X",0),
&    format$("N0:13X",0),format$("N0:19X",0),space$(170) Using[XXX]
Endif

For[HRSSS6]  Where PER=[L]LPERIODE and CPYAFFNUM=[L]LNUMAFFIL
   Raz XTSALREEL,XTSALPLAF
    XTSALREEL=num$([HRSSS6]TOTWAG)
    XTSALPLAF=num$([HRSSS6]TOTSALCLG)
    Call XCALC_SAL(XTSALREEL)
    Call XCALC_SAL(XTSALPLAF)

  Wrseq "B06",  format$("N0:7X",LNUMAFFIL),format$("N0:6X",LPERIODE),format$("N0:6X",[HRSSS6]NUMEMP),format$("N0:15X",[HRSSS6]NUMMAT)
&       ,format$("N0:6X",[HRSSS6]TOTDAY),
&    format$("N0:15X",XTSALREEL),format$("N0:13X",XTSALPLAF),format$("N0:19X",[HRSSS6]CTLFLD),space$(170) Using[XXX]
