Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR
  If VALEUR=2
   Raz [M:HRSGE0]FCY
   Grizo [M:HRSGE0]FCY
  Else
   Actzo [M:HRSGE0]FCY
  Endif
End


