#<AdxTL>@(#)7.0.0.0 $Revision$ Gestion du fichier ABATGRP
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ABG",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "AVANT_OUVRE"  : Gosub AVANT_OUVRE
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "FILGAUCHE"    : Gosub FILGAUCHE
 When "GAUCHE"       : Gosub GAUCHE
 When "LIENS"        : Gosub LIENS
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "MODIF"        : Gosub MODIF
 When "APRES_MOD"    : Gosub APRES_MOD
Endcase
Return

#-------------------------------------------------------------------------------------------------------#
# Les tables ABATGRP et ABATTAC étant de type X3 communes à plusieurs dossiers et l'intitulé
# des tâches et groupes étant du type ATX, il est nécessaire d'ouvrir la table ATEXTE dans le dossier X3
#-------------------------------------------------------------------------------------------------------#

$SETBOUT
If CLECUR=0 or REP="M" or !VERROU or nomap<>GDOSX3
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
Return

$AVANT_OUVRE
Local Char DOSX3(GLONADS)
If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
Read [ADW]ADW0 = "";"";"SUPDOS"
DOSX3 = [F:ADW]VALEUR
If DOSX3="" : DOSX3 = "X3" : Endif
Local File =DOSX3+".ATEXTE" [ATX]
Return

$LIENS
Call TEXTE([M]DES,[M]ZDES) From OBJDIV
Return

$AVANT_MODFIC
Local Integer MODIF_GRP
Local Char    MESSAGE(250)
MODIF_GRP = 0
MESSAGE = ""

Sorta [M:ABG1]NBTAC [M:ABG1]NBTAC Order By [M:ABG1]SEQ(indice)
Affzo [M:ABG1]

For I=1 To [F:ABG]NBTAC
 If [F:ABG]CODTAC(I-1)<>""
& & ([M]SEQ(I-1)<>[F:ABG]SEQ(I-1) | [M]CODTAC(I-1)<>[F:ABG]CODTAC(I-1))
  MODIF_GRP = 1 : Break
 Endif
Next I
Return

$MODIF
If MODIF_GRP
 For [ABA] Where GRP=[M]CODGRP
  Look [ABD]ABD0(1)=[F:ABA]CODABT
  If !fstat
   Delete [ABD] Where CODABT=[F:ABA]CODABT
   If fstat=1
    GOK=-1 : Call FSTA("ABD") From GLOCK : Break
   Endif
   [F:ABA]ENAFLG = 1
   Rewrite [ABA]
   If fstat
    GOK=-1 : Call FSTA("ABA") From GLOCK : Break
   Endif
   MESSAGE -= [F:ABA]CODABT
  Endif
 Next ABA
Endif
Return

$APRES_MOD
If MESSAGE<>""
 # Suppression des paramètres et désactivation des abonnements
 Call ECR_TRACE(mess(98,134,1)+"\"+MESSAGE,0) From GESECRAN
Endif
Return

$OUVRE_BOITE
Local Integer BROWABT
Local Char    BOXABT(10)
BROWABT = find("ABT",OBJLIS(1..8)) : BOXABT = "GAU_CHE"+num$(BROWABT)
Return

$FILGAUCHE
Raz FILGAUSUP
FILGAUSUP = "[F]ENAFLG=2"
Return

$GAUCHE
Case currbox
 When BOXABT
  If [M]NBTAC<dim([M]CODTAC)
   OK = 0
   Case REP
    When "C","M","D"
     OK = 1
    When ""
     If CLECUR & VERROU & ACTMOD & !GCONSULT
      OK = 1
     Endif
   Endcase
   If OK
    mkstat = 0
    nolign = [M]NBTAC+1
    Read [ABT]CODTAC = [F:ABT]CODTAC
    If mkstat
     Call ERREUR(GMESSAGE) From GESECRAN
     OK = 0
    Endif
   Endif
   If OK
    [M:ABG1]CODTAC([M]NBTAC) = [F:ABT]CODTAC
    [M:ABG1]SEQ([M]NBTAC) = func CAL_SEQ([M:ABG1]SEQ, [M:ABG1]NBTAC+1)
    [M:ABG1]NBTAC += 1
    Affzo [M:ABG1]CODTAC([M:ABG1]NBTAC-1),SEQ([M:ABG1]NBTAC-1)
    If dim([M:ABG1]ZCODTAC)>0
        Affzo [M:ABG1]ZCODTAC([M:ABG1]NBTAC-1)
    Endif
    If REP=""
     Gosub ENTRE_MODIF From GOBJSUB
    Endif
   Endif
  Endif
Endcase
Return

#----------------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File ABATGRP [ABG1]
 Local File ATEXTE  [ATX1]
Elsif func DOSCONT.DOSX3([M]DOSORG)<>"" : # On a trouvé le dossier racine
 Local File =func DOSCONT.DOSX3([M]DOSORG)+".ABATGRP" [ABG1]
 Local File =func DOSCONT.DOSX3([M]DOSORG)+".ATEXTE"  [ATX1]
Else
 Call ECR_TRACE(func DOSCONT.DOSX3([M]DOSORG)-":"-mess(106,125,1),1) From GESECRAN : # Dossier inaccessible
 Return
Endif
If [M]DOSDES=nomap
 Local File ABATGRP [ABG2]
 Local File ATEXTE  [ATX2]
Elsif func DOSCONT.DOSX3([M]DOSDES)<>"" : # On a trouvé le dossier racine
 Local File =func DOSCONT.DOSX3([M]DOSDES)+".ABATGRP" [ABG2]
 Local File =func DOSCONT.DOSX3([M]DOSDES)+".ATEXTE"  [ATX2]
Else
 Call ECR_TRACE(func DOSCONT.DOSX3([M]DOSDES)-":"-mess(106,125,1),1) From GESECRAN : # Dossier inaccessible
 Return
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ABG1] , [ATX1] , [ABG2] , [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [ABG2]
 Delete [ABG2] Where CODGRP=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ABATGRP" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ABG2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ABG1]ABG0 Where CODGRP=TABLE
  [F:ABG2] = [F:ABG1]
  Write [ABG2]
  If GOK<1 : Break : Endif
  Call COPTEXTE([F:ABG1]DES,[F:ABG2]DES) From OBJDIV
  If GOK<1 : Break : Endif
 Next ABG1
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

#----------------------------------------------------#
Subprog C_CODTAC(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ABT",VALEUR,"") From CONTOBJ
If [F:ABT]FONCTION="" : End : Endif
Read [AFC]CODINT = [F:ABT]FONCTION
If [F:AFC]ACTION="" : Goto ERR_CODTAC : Endif
Read [ACT]ACTION = [F:AFC]ACTION
If [F:ACT]TYP<>3 : Goto ERR_CODTAC : Endif
End

$ERR_CODTAC
GMESSAGE = mess(141,126,1) : # Code tâche incorrect
mkstat = 2
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ABG1) 25/05/2018 14:06:37 (CCC)
######################################################################################
Subprog AS_SEQ(VALEUR)
Variable Decimal VALEUR

If VALEUR=0
    VALEUR = func CAL_SEQ([M:ABG1]SEQ,nolign)
Endif
End


######################################################################################
Funprog CAL_SEQ(PTABSEQ, PLIG)
Value Integer PTABSEQ(1..)
Value Integer PLIG
Local Integer LSEQ

    If PLIG=1
        If PTABSEQ(PLIG+1)>0
            LSEQ = max(1,PTABSEQ(PLIG+1)-10)
        Else
            LSEQ = 10
        Endif
    Else
        If PLIG<dim(PTABSEQ)
&        & PTABSEQ(PLIG+1)>0
&        & (PTABSEQ(PLIG+1)-PTABSEQ(PLIG-1))<=10
            LSEQ=PTABSEQ(PLIG-1)+int(abs(PTABSEQ(PLIG+1)-PTABSEQ(PLIG-1))/2)
        Else
            LSEQ=PTABSEQ(PLIG-1)+10
        Endif
    Endif

End LSEQ

#**
#* Initialize sequence number of tasks
#*
#* @param PTABSEQ : array of sequence number ([F:ABG]SEQ)
#* @param PNBSEQ  : number of sequence in PTABSEQ
#*!
Subprog INISEQ(PTABSEQ, PNBSEQ)
Variable Integer PTABSEQ()
Value Integer PNBSEQ

If PNBSEQ>0 & find(0,PTABSEQ(0..PNBSEQ-1))>0
    # If all SEQ values are not initialized, init from 10 and 10 by 10
    If sum(PTABSEQ)=0
        PTABSEQ(0)=10
        For I=1 To PNBSEQ-1
            PTABSEQ(I)=PTABSEQ(I-1)+10
        Next
    Else
        # else use dedicated function to init remaining 0
        For I=1 To PNBSEQ
            If PTABSEQ(I-1)=0
                PTABSEQ(I-1) = func SUBABG.CAL_SEQ(PTABSEQ, I)
            Endif
        Next
    Endif
Endif

End

