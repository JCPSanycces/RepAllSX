#<AdxTL>@(#)7.0.0.0 $Revision$
########################################
Subprog C_WFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
   Call CONTROLE("FCY","",VALEUR,"",mkstat) From CONTOBJ 
   If mkstat : GMESSAGE = mess(23,100,1)
     End
   Endif
Endif
End

########################################
Subprog S_WFCY(VALEUR)
Variable Char    VALEUR()
Call SELECT("FCY","",VALEUR,"") From SELOBJ
End

########################################
Subprog C_WNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" & right$(VALEUR,len(VALEUR)) <> "*"
   Read [F:MFG]MFG0 = VALEUR
    If fstat GMESSAGE = mess(23,100,1)
        End
    Endif
#Selon paramètre général, l'OF doit être édité
    If  [F:MFG]MFGTRKFLG < 3 & GDOSFAB = 2 : GMESSAGE = mess(20,190,1) : mkstat = 1 :  End : Endif
    mkstat = 0
 # boucle d'analyse des matières bloquantes si rupture
    For [MFM] Where MFGNUM = [F:MFG]MFGNUM
        If [F:MFM]SHTQTY <> 0
           Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
           If !fstat & [F:ITF]MFGSHTCOD = 1 
                 GMESSAGE = mess(105,193,1)+" ("+[F:MFM]ITMREF+")"
                 mkstat = 1
                 Break
           Endif
        Endif
    Next
    If mkstat = 1 : End : Endif
Endif
End

########################################
Subprog S_WNUM(VALEUR)
Variable Char    VALEUR()
Case GMFGCLOSE
    When "1":  # situation OF
        Filter [F:MFG] Where MFGFCY = WFCY 
    When "2":  # suivi de fabrication/clôture OF  
        If [M]WFCY <> "" 
            If GDOSFAB = 2
               If GMTKALLMGT = 2
                   Filter [F:MFG] Where MFGFCY = WFCY & [F:MFG]MFGTRKFLG>2 & 
&                                     ([F:MFG]ALLSTA=3 | [F:MFG]ALLSTA=5)  & 
&                                      [F:MFG]TYPMOD=2
               Else
                  Filter [F:MFG] Where MFGFCY = WFCY & [F:MFG]MFGTRKFLG>2 & 
&                                      [F:MFG]TYPMOD=2
               Endif

            Else
               If GMTKALLMGT = 2
                   Filter [F:MFG] Where MFGFCY = WFCY & 
&                                      ([F:MFG]ALLSTA=3 | [F:MFG]ALLSTA=5) & 
&                                       [F:MFG]TYPMOD=2
               Else
                   Filter [F:MFG] Where MFGFCY = WFCY & 
&                                       [F:MFG]TYPMOD=2
               Endif 
 
            Endif
        Else
            If GDOSFAB = 2
               If GMTKALLMGT = 2 
                   Filter [F:MFG] Where [F:MFG]MFGTRKFLG > 2 & 
&                                       ([F:MFG]ALLSTA=3 | [F:MFG]ALLSTA=5) & 
&                                       [F:MFG]TYPMOD = 2
               Else
                   Filter [F:MFG] Where [F:MFG]MFGTRKFLG > 2 & 
&                                       [F:MFG]TYPMOD = 2
               Endif
            Else
                If GMTKALLMGT = 2
                   Filter [F:MFG] Where ([F:MFG]ALLSTA=3 | [F:MFG]ALLSTA=5)  & 
&                                       [F:MFG]TYPMOD = 2
                Else
                    Filter [F:MFG] Where [F:MFG]TYPMOD = 2
                Endif
            Endif
        Endif
    When "3":  # suivis par OF
        Filter [F:MFG] Where MFGFCY = WFCY & [F:MFG]MFGTRKFLG > 3
    When "4":  # réactivation OF
        Filter [F:MFG] Where MFGFCY = WFCY & [F:MFG]MFGSTA = 4 & MFGTRKFLG < 6
Endcase
Call SELECT("MFG","",VALEUR,"") From SELOBJ
Filter [F:MFG]
End

########################################
Subprog C_WITM(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
If VALEUR <> "" & right$(VALEUR,len(VALEUR)) <> "*"
    Call CONTROLE("ITM","",VALEUR,"",mkstat) From CONTOBJ
    If mkstat : GMESSAGE = mess(23,100,1)
        End
    Endif
    #[M:MK0S]WITMDES = [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MK0S]WITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
Endif
End

########################################
Subprog S_WITM(VALEUR)
Variable Char    VALEUR()
Call SELECT("ITM","",VALEUR,"") From SELOBJ
End

########################################
Subprog AS_WDATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR = [0/0/0] : VALEUR = [M:MK0S]WDATDEB : Endif
End

########################################
Subprog C_WDATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]WDATDEB : GMESSAGE = mess(044,199,1): mkstat = 1 : End : Endif
End

########################################
Subprog AP_WCDE(VALEUR)
Variable Char VALEUR
Local Integer WOK,WERR
#Filtre sur fichier articles lancés selon critères saisis
#Le fichier maître est le fichier MFGITM 
$VAL_CRIT
Local    Char     CRITERE(250), CRITSUP(250)
Local    Decimal  WQTYUS, WQTYUA
Local    Integer  REPONSE, ETABOU(1..GNBBOU)
Raz CRITERE, CRITSUP
Case GMFGCLOSE : 
     When "1"     :  CRITERE = "1=1"
     When "4"     :  CRITERE = "MFGSTA = 4"
     When Default :  CRITERE = "MFGSTA = 1"
Endcase
CRITERE -= ' & MFGFCY = "' +[M]WFCY+'"'
If [M]WNUM <> ""
   Case right$([M]WNUM,len([M]WNUM)) :
    When  "*"    : CRITERE -= ' & left$(MFGNUM,len(WNUM)-1) = "'+ left$([M]WNUM,len(WNUM)-1)+'"'
    When Default : CRITERE -= ' & MFGNUM = "' +[M]WNUM+'"'
   Endcase 
Endif
If [M]WDATDEB <> [0/0/0]
   CRITERE -= ' & STRDAT >= [' +format$(GFMD,[M]WDATDEB)+']'
Endif
If [M]WDATFIN <> [0/0/0]
   CRITERE -= ' & ENDDAT <= [' +format$(GFMD,[M]WDATFIN)+']'  
Endif
If [M]WITM <> ""
    Case right$([M]WITM,len([M]WITM)) :
     When  "*"    : CRITERE -= ' & left$(ITMREF,len(WITM)-1) >= "'+ left$([M]WITM,len(WITM)-1)+'"'
     When Default : CRITERE -= ' & ITMREF = "' +[M]WITM+'"'
    Endcase
Endif
If [M]WPJT <> ""
   Case right$([M]WPJT,len([M]WPJT)) :
     When  "*"    : CRITERE -= ' & left$(PJT,len(WPJT)-1) >= "'+ left$([M]WPJT,len(WPJT)-1)+'"'
     When Default : CRITERE -= ' & PJT ="'+[M]WPJT+'"' 
   Endcase
Endif
CRITSUP = "1=1"
If VALEUR <> ""
   [M]WCDE = VALEUR 
   CRITSUP -= ' & VCRTYPORI = 2'
   Case right$([M]WCDE,len([M]WCDE)) :
     When  "*"    : CRITSUP -= ' & left$(VCRNUMORI,len([M]WCDE)-1) = "'+ left$([M]WCDE,len([M]WCDE)-1)+'"'
     When Default : CRITSUP -= ' & VCRNUMORI = "' +VALEUR+'"'
   Endcase 
Endif
If [M]WITMDES <> "" 
   Case right$([M]WITMDES,len([M]WITMDES)) :
     When  "*"    : Filter [F:ITM] Where left$(ITMDES1,len(WITMDES)-1) >=left$([M]WITMDES,len(WITMDES)-1)
     When Default : Filter [F:ITM] Where ITMDES1 = [M]WITMDES 
   Endcase 
Endif
Filter [F:MFI] Where evalue(CRITERE) & evalue(CRITSUP)
Link [F:MFI] With [F:ITM]ITM0 = [F:MFI]ITMREF ,[F:MFG]MFG0 = [F:MFI]MFGNUM As [XFG]
nolign = 0
WERR=0    # FQ 69909 Ctrl des sources
For [XFG]
    Case GMFGCLOSE
        When "1": # rien de spécial, on prend tout
        When "2": # plein de filtres
            If  ((GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0) | 
&                [F:MFG]TYPMOD <> 2 | ([F:MFG]MFGTRKFLG <= 2 & GDOSFAB = 2))
                Goto SUIV
            Endif
            If [F:MFG]MFGTRKFLG <= 2 & GDOSFAB <> 2
                 WOK = 0
# boucle d'analyse des matières bloquantes si rupture
                 For [MFM] Where MFGNUM = [F:MFG]MFGNUM
                       If [F:MFM]SHTQTY <> 0
                          Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
                          If fstat : WERR=1 : Goto SUIV : Endif   # FQ 69909 Ctrl des sources avant End
                          If [F:ITF]MFGSHTCOD = 1 
                             WOK = 1
                             Break 
                          Endif
                       Endif
                 Next
                 If WOK = 1 : Goto SUIV : Endif
            Endif
        When "3": # statut >= encours
            If [F:MFG]MFGTRKFLG < 4 : Goto SUIV : Endif
        When "4": # statut <> Prix de revient calculé
            If [F:MFG]MFGTRKFLG = 6 : Goto SUIV : Endif
        When Default: # ben rien
    Endcase
    Look [F:ITM]ITM0 = [F:ITM]ITMREF
    If !fstat
        nolign += 1
        If nolign =500 : Break : Endif
        [M]MFGFCY(nolign-1)  = [F:MFI]MFGFCY
        [M]MFGNUM(nolign-1)  = [F:MFI]MFGNUM
        [M]STRDAT(nolign-1)  = [F:MFI]STRDAT
        [M]ENDDAT(nolign-1)  = [F:MFI]ENDDAT
        [M]ITMREF(nolign-1)  = [F:MFI]ITMREF
        #[M]ITMDES1(nolign-1) = [F:ITM]ITMDES1
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
        [M]PJT(nolign-1)     = [F:MFI]PJT
        [M]VCRNUM(nolign-1)  = [F:MFI]VCRNUMORI
        [M]VCRLIN(nolign-1)  = [F:MFI]VCRLINORI
    Endif
$SUIV
    If WERR<>0 Break Endif # FQ 69909 Ctrl des sources (ligne ajoutée)
Next
Filter [F:MFI]
Filter [F:ITM]
If WERR<>0 End Endif     # FQ 69909 Ctrl des sources (ligne ajoutée)
[M]NBOF = nolign
If [M]NBOF = 0
   Call ERREUR (mess(99,100,1)) From GESECRAN
   mkstat = 1  
   End
Endif
ETABOU(GVALI)=1 : ETABOU(GABAN)=1 : # OK ET ABANDON
Call SETBOUT(ETABOU) From GESECRAN
Affzo [M]15
End
