#------------------------------------------------------------#
# Validation on demand
#------------------------------------------------------------#
Funprog VALID_ONDEMAND(CODCLA)
Value Char CODCLA
Local Integer TYPAGE,OK
Local Integer SILENCE : [L]SILENCE=1
Local Char    FICHIER(GDIMFIC),MES(80)

Local Integer WLOCKSTC
#----- Contrôle lock logique -----#
Call JELOCKE("AVALSUPSTC",WLOCKSTC) From OBJDIV
If WLOCKSTC=0
 WLOCKSTC=1
 Lock ="AVALSUPSTC" With lockwait=-1
Else
 WLOCKSTC=0
Endif

Case left$([L]CODCLA,2)
 When "C_"
  If pat([L]CODCLA,[V]CST_C_NAME_CLASS_CONTEXT+'*')>0
& or pat([L]CODCLA,"C_"+func ACTXVAL.GET_NAME_CACHE()+'*')>0
& or pat([L]CODCLA,"C_"+func ACTXVAL.GET_PREFIX_CACHE()+'*')>0
   If filinfo(filpath("STC",[L]CODCLA,"stc",nomap,"",""),0)<0
&   | filinfo(filpath("STC",[L]CODCLA,"adx",nomap,"",""),0)<0
   #Call EXISTE_STC("",nomap,[L]CODCLA,[L]OK) From ASYRSYS
   #If ![L]OK
    Call VALIDATION_TECH(nomap,"",[L]SILENCE) From ACTXVAL
   Endif
   Local Instance AERR(1..)   Using C_AERROR
   Call VALID("STC",[L]CODCLA,2,nomap,1,[L]TYPAGE,[L]OK,AERR) From ACLAVALSUB
  Else
   Local File ACLASSE  [ACL__]
   Read [ACL__]ACLA0 = right$([L]CODCLA,3)
   If !fstat
    If [F:ACL__]TYPCLA<>4
     Call VALIDATION(0,right$([L]CODCLA,3),nomap,[L]SILENCE,1,1,[L]TYPAGE,[L]OK) From ACLAVAL
    Else
     Call VALIDATION(0,right$([L]CODCLA,3),nomap,[L]SILENCE,1,[L]TYPAGE,[L]OK) From ACLAVALTECH
    Endif
   Else
    Call VALID_TECH("STC",[L]CODCLA,0,nomap,1,[L]TYPAGE,[L]OK,[L]MES) From ACLAVALSUB
   Endif
   Close Local File [ACL__]
  Endif
 When "R_"
  Local File ASHW  [ASW__]
  Read [ASW__]ASW0 = right$([L]CODCLA,3)
  If !fstat
   Call VALIDATION(0,right$([L]CODCLA,3),nomap,[L]SILENCE,1,1,[L]TYPAGE,[L]OK) From ASHWVAL
  Else
   Call VALID_TECH("STC",[L]CODCLA,0,nomap,1,[L]TYPAGE,[L]OK,[L]MES) From ACLAVALSUB
  Endif
  Close Local File [ASW__]
Endcase
If WLOCKSTC
 Unlock "AVALSUPSTC"
Endif
End [L]TYPAGE

#------------------------------------------------------------#
# Génération de la structure WMSxxx
#------------------------------------------------------------#

Subprog VALIDATION(TEST,CODCLA,DOSSIER,SILENCE,TYPGEN,VALP,TYPAGE,OK)
Value    Integer    TEST
Value    Char        CODCLA
Value    Char        DOSSIER
Value    Integer    SILENCE
Value    Integer    TYPGEN
Value    Integer    VALP
Variable Integer    TYPAGE
Variable Integer    OK

Local Char    MACHINE(GDIMFIC) , APPLI(GLONADS)
Local Integer STA,I

OK = 1

If CODCLA="OBJECT" : End : Endif

#If toupper(adxusr)="CCL" and CODCLA="ACTIV"
 #TITITOT =TKTJT
#Endif

If TEST>0 & GTRACE=""
 # Validation de la classe
 Call OUVRE_TRACE(mess(1,140,1)-CODCLA) From LECFIC
Endif

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

If !SILENCE
 Call TEMPON(mess(1,140,1)-CODCLA) From GESECRAN
Endif

If GTRACE<>"" & !VALP
 Call ECR_TRACE(mess(1,140,1)-CODCLA,0) From GESECRAN
Endif

Local Integer WLOCKSTC
#----- Contrôle lock logique -----#
Call JELOCKEDOS([L]DOSSIER,"AVALSUPSTC",WLOCKSTC) From OBJDIV
If WLOCKSTC=0
 WLOCKSTC=1
 Lock ="AVALSUPSTC" From =[L]DOSSIER With lockwait=-1
Else
 WLOCKSTC=0
Endif

Local Instance ACLA   Using C_ACLA
Local Instance AERR(1..)   Using C_AERROR

Call VERIF_VALID_CLA(DOSSIER,CODCLA,OK,AERR) From ACLACONTROL
#91436 warning sur classe/rep inactive
#If  func ACLACONTROL.HAS_AERR(AERR)>0
If  OK<>1 | func ACLACONTROL.HAS_AERR(AERR)>0
 Goto PERDU
Endif

# Chargement classe

ACLA  = NewInstance  C_ACLA AllocGroup null
#If func ASYRFNC.IS_UPDATE_MONGO>0
# Clbfile RESHEAD, RESBODY
# OK = func ASY RMETA.EXTRACT_METADATA(func ASYRMETA.GETCOLLECTION("ACLA"),func ASYRMETA.GETMAJMONGO("ACLA"), CODCLA, RESHEAD, RESBODY)
# #SCM??? Goto  FIN
#Endif

Call INI_ACLAVARDEF(CODCLA,DOSSIER,ACLA,AERR) From ACLAVALLEC

If TYPGEN=0
 Call LOAD_CLASSE(TEST,DOSSIER,CODCLA,0,"",ACLA,AERR) From ACLAVALLEC
 If func ACLACONTROL.HAS_AERR(AERR)>0
  Goto PERDU
 Endif
Else
 Call LOAD_CLASSE_COL(TEST,DOSSIER,CODCLA,ACLA,AERR) From ACLAVALLEC
 If func ACLACONTROL.HAS_AERR(AERR)>0
  Goto PERDU
 Endif
 For I=1 To maxtab(ACLA.ACLACOL)
  If ACLA.ACLACOL(I)<>null
   Call SAVE_STC(DOSSIER,ACLA.ACLACOL(I).CODCLA) From ACLAVALSUB :  # Save in stcol and srcold
  Endif
 Next
 Call SAVE_STC(DOSSIER,ACLA.CODCLA) From ACLAVALSUB :  # Save in stcol and srcold
 Call DELETE_ALLSTC(DOSSIER,ACLA.CODCLA) From ACLAVALSUB
Endif

# Génération du traitement WMCLAxxxx
For I=1 To maxtab(ACLA.ACLACOL)
 If ACLA.ACLACOL(I)<>null
  Call VALSTR_CLASSE(DOSSIER,ACLA.ACLACOL(I).CODCLA,TYPGEN,0,TYPAGE,ACLA.ACLACOL(I),AERR) From ACLAVALTRT
  If func ACLACONTROL.HAS_AERR(AERR)>0 : Break : Endif
 Endif
Next
If func ACLACONTROL.HAS_AERR(AERR)>0
 Goto PERDU
Endif

Call VALSTR_CLASSE(DOSSIER,CODCLA,TYPGEN,VALP,TYPAGE,ACLA,AERR) From ACLAVALTRT
If func ACLACONTROL.HAS_AERR(AERR)>0
 Goto PERDU
Endif

If find(ACLA.TYPCLA,2,5)>0 : # PERSISTANTE OR INTERFACE
 Call CRUD_CLASSE(DOSSIER,CODCLA,ACLA,AERR) From ACLAVALCRUD
 If func ACLACONTROL.HAS_AERR(AERR)>0
  Goto PERDU
 Endif
Endif

If ACLA.FLGSEARCH = 2 & ACLA.TYPCLA=2 : # The classe is 'searchable'
 Call VALTRT_SRH(TEST,DOSSIER,CODCLA,ACLA,AERR) From ACLAVALSRH
  If func ACLACONTROL.HAS_AERR(AERR)>0
  Goto PERDU
 Endif
Endif

#A faire en dernier car freeinstance de [ACLA]
If find(ACLA.TYPCLA,2,5)>0 : # PERSISTANTE OR INTERFACE
 Call CTRLREF(DOSSIER,CODCLA,TEST,SILENCE)
Endif

Call DELETE_STCOLD(DOSSIER,CODCLA) From ACLAVALSUB

Goto FIN

#----------------------------------------------#
$FIN
#pour afficher les erreurs et warning
Call TRACE_AERR(AERR) From ACLACONTROL
If !SILENCE
 Call TEMPOFF From GESECRAN
Endif
If TEST
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
If ACLA<>null : FreeGroup ACLA : Endif
If maxtab(AERR)>0
 FreeGroup AERR
Endif
If WLOCKSTC
 Unlock ="AVALSUPSTC" From =[L]DOSSIER
Endif
End

#----------------------------------------------#
$PERDU
If [L]TEST<1
 Call RESTORE_STC(DOSSIER,[L]CODCLA) From ACLAVALSUB
Endif
OK=0
Goto FIN

#----------------------------------------------#
$ERREUR
Call ECR_TRACE(errp-mess(93,100,1)-num$(errl)+"\"+errmes$(errn)-"("+num$(errn)+")|"-errm,1) From GESECRAN
Resume

#----------------------------------------------#
Subprog CTRLREF(DOSSIER,CODCLA,TEST,SILENCE)
Value Char DOSSIER
Value Char CODCLA
Value    Integer    TEST
Value    Integer    SILENCE
Local File =DOSSIER+".ATYPE"      [ATY]
Local Integer OK

For [ATY]CODTYP Where CODCLA=[L]CODCLA & TYPSELSYR=2
 Call VALCTRLREF([F:ATY]CODTYP,DOSSIER,TEST,SILENCE,OK) From AVALACTLREF
Next

Close Local File [ATY]

End

#----------------------------------------#
Funprog _CHECK_ACLA(ACTX,CODCLA,CODFAC)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char CODCLA,CODFAC

Local Integer ERROR : ERROR=[V]CST_AOK

If ACTX.AFOLDER=nomap
 Local File ACLASSE    [ACLA]
 Local File ACLAMETSTD    [ACLAT]
Else
 Local File =ACTX.AFOLDER+".ACLASSE"   [ACLA]
 Local File =ACTX.AFOLDER+".ACLAMETSTD"   [ACLAT]
Endif
Read [ACLA]ACLA0 = [L]CODCLA
If fstat
 #This class doesn't exist
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,ERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(10,149,1),[L]CODCLA))
 Goto FIN_CHECK_ACLA
Endif
If !func ASYRFNC.ACTIVDOS(ACTX.AFOLDER,[F:ACLA]CODACT)
 #Classe inactive
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,ERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(31,140,1)-[L]CODCLA-"("+[F:ACLA]CODACT+")")
 Goto FIN_CHECK_ACLA
Endif
Case [L]CODFAC
 When "$search"  :
  If [F:ACLA]FLGSEARCH<>2
   #Recherche non disponible pour la classe $1$
   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,ERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,func ASYRFNC.MES1(mess(25,149,1),[L]CODCLA))
   Goto FIN_CHECK_ACLA
  Endif
  Filter [ACLAT] Where CODCLA=[L]CODCLA & ENAMETSTD=2 & CODMETSTD="R"
  Read [ACLAT]ACLAT0 First
  Filter [ACLAT]
  If fstat | !func ASYRFNC.ACTIVDOS(ACTX.AFOLDER,[F:ACLAT]ACTMETSTD)
   #La méthode "$1$" n'est pas disponible pour la classe $2$
   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,ERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,func ASYRFNC.MES2(mess(31,149,1),mess(7,7983,1),[L]CODCLA))
   Goto FIN_CHECK_ACLA
  Endif
 When "$bulk","$query","$lookup","$details","$summary" :
  Filter [ACLAT] Where CODCLA=[L]CODCLA & ENAMETSTD=2 & CODMETSTD="R"
  Read [ACLAT]ACLAT0 First
  Filter [ACLAT]
  If fstat | !func ASYRFNC.ACTIVDOS(ACTX.AFOLDER,[F:ACLAT]ACTMETSTD)
   #La méthode "$1$" n'est pas disponible pour la classe $2$
   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,ERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,func ASYRFNC.MES2(mess(31,149,1),mess(7,7983,1),[L]CODCLA))
   Goto FIN_CHECK_ACLA
  Endif
 When "$edit" :
  Filter [ACLAT] Where CODCLA=[L]CODCLA & ENAMETSTD=2 & CODMETSTD="R"
  Read [ACLAT]ACLAT0 First
  Filter [ACLAT]
  If fstat | !func ASYRFNC.ACTIVDOS(ACTX.AFOLDER,[F:ACLAT]ACTMETSTD)
   #La méthode "$1$" n'est pas disponible pour la classe $2$
   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,ERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,func ASYRFNC.MES2(mess(31,149,1),mess(7,7983,1),[L]CODCLA))
   Goto FIN_CHECK_ACLA
  Endif
  Filter [ACLAT] Where CODCLA=[L]CODCLA & ENAMETSTD=2 & CODMETSTD="U"
  Read [ACLAT]ACLAT0 First
  Filter [ACLAT]
  If fstat | !func ASYRFNC.ACTIVDOS(ACTX.AFOLDER,[F:ACLAT]ACTMETSTD)
   Filter [ACLAT] Where CODCLA=[L]CODCLA & ENAMETSTD=2 & CODMETSTD="C"
   Read [ACLAT]ACLAT0 First
   Filter [ACLAT]
   If fstat | !func ASYRFNC.ACTIVDOS(ACTX.AFOLDER,[F:ACLAT]ACTMETSTD)
    #Les méthodes "$1$" et "$2$" ne sont pas disponibles pour la classes $3$
    ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,ERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,func ASYRFNC.MES3(mess(32,149,1),mess(1,7983,1),mess(10,7983,1),[L]CODCLA))
    Goto FIN_CHECK_ACLA
   Endif
  Endif
Endcase
ERROR =  func ASHWVAL._DEFERRED_VALIDATION(ACTX,"C_"+[L]CODCLA)
If ERROR : Goto FIN_CHECK_ACLA : Endif

$FIN_CHECK_ACLA
LogicClose File
End ERROR

