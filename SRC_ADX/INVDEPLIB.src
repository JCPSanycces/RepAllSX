#<AdxTL>@(#)4.0.0.0 $Revision$
# Issue X3-63507 - 2017-11-29 by FHA : Fix to avoid DEP field defaulting issue in BIS import
#############################################################################################################
# This subprogramm allows to manage the display of the fields linked to the Early Discount Management
# in the invoices coming from AP & AR Modules
#############################################################################################################
Subprog DISPLAY_DSCFLD(DSC,FLDNAM)
Value Char DSC()    : # Early Discount Code
Value Char FLDNAM() : # Field Name

Local Char ABR(GLONABR)

Case GFONCTION
 When "GESBIC" : ABR = "SIH"
 When "GESBIS" : ABR = "PIH"
Endcase

Local Integer SHOW : SHOW=1
Local Integer DSCFLG
If [L]DSC = "" | GDEPMGTMOD=4 | !find([M]INVTYP,1,3)
 SHOW = 0
Elsif !find(GREP,"C","D")
&   & (GDEPMGTMOD=1 | GDEPMGTMOD=2)
&   & dim(GLASINTNUM)>0 & GLASINTNUM>0 & evalue(num$("[F:"+ABR+"]ACCNUM"))<=GLASINTNUM
 SHOW = 0
Else
 If clalev([F:TDA])=0 : Local File TABDEPAGIO [TDA] : Endif
 Call LEC_TDA(GCURLEG,DSC) From CPTLEC
 If !fstat
  Call DEPTYP(DSC,DSCFLG) From PAYDEPLIB3
  If !DSCFLG : SHOW=0 : Endif
 Endif
Endif

Case FLDNAM
 When ""       : Gosub SHOWHIDE_DSCFLD
 When "FLGDEP" : Gosub SHOWHIDE_FLGDEP
 When "BASDEP" : Gosub SHOWHIDE_BASDEP
Endcase
End

$SHOWHIDE_DSCFLD
Gosub SHOWHIDE_FLGDEP
Gosub SHOWHIDE_BASDEP
Return

$SHOWHIDE_FLGDEP
If SHOW
 Chgfmt [M]FLGDEP With "K:10X"
Else
 Chgfmt [M]FLGDEP With "-K:10X"
 Raz [M]FLGDEP(indice), [M]BASDEPLIN(indice)
Endif
Return

$SHOWHIDE_BASDEP
If SHOW
 [M]FMTBASDEP = "NPz3:"+GDEVFM1(1)
 Chgfmt [M]CUR3 With "K:10X"
Else
 [M]FMTBASDEP = "-NPz3:"+GDEVFM1(1)
 Chgfmt [M]CUR3 With "-K:10X"
Endif
Return


#############################################################################################################
# This subprogram allows to initialize the FLGDEP Fields if it has to be displayed
# The FLGDEP Fiel has to be initialized by 'Yes' if the Legal Account is 'not subject' or 'Subject' to tax
#############################################################################################################
Subprog INIT_FLGDEP(COA,ACC,NOL,FLGDSC)
Value    Char    COA()  : # Chart of account
Value    Char    ACC()  : # Account
Value    Integer NOL    : # Current line
Variable Integer FLGDSC : # Flag 'Subjected to discount'

If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
Call LEC_GAC(ACC,COA) From CPTLEC
If !fstat & find([F:GAC]FLGVAT,1,2)
 FLGDSC = 2
Else
 FLGDSC = 1
Endif
End

#############################################################################################################
# This subprogram allows to initiliaze the FLGDEP Fields if it has to be displayed
# The FLGDEP Fiel has to be initialized by 'Yes' if the Legal Account is 'not subject' or 'Subject' to tax
#############################################################################################################
Subprog CAL_BASDEPLIN(DSC,FLGDSC,NOL)
Value Char    DSC()  : # Early Discount Code
Value Integer FLGDSC : # Flag 'Subjected to discount'
Value Integer NOL    : # Current line

If [L]DSC = "" | GDEPMGTMOD=4 | FLGDSC<>2
 [M]BASDEPLIN(NOL-1) = 0 : End
Endif

## If "Rebate on VAT", the scope (Ex tax / Tax incl.) associated the Early Discount Code is not taken into account.
## It is always "Ex tax"
If GDEPMGTMOD = 1
 [M]BASDEPLIN(NOL-1) = [M]AMTNOTLIN(NOL-1)
 End
Endif

If clalev([F:TDA])=0 : Local File TABDEPAGIO [TDA] : Endif
Call LEC_TDA(GCURLEG,DSC) From CPTLEC
If !fstat
 ## If "Rebate on Exempt VAT", the scope (Ex tax / Tax incl.) associated the Early Discount Code is not taken into account.
 ## It is always "Ex tax"
 If GDEPMGTMOD = 5
  Case GFONCTION
   When "GESBIC" :
    If [F:TDA]SFINUM>0 : [M]BASDEPLIN(NOL-1) = [M]AMTNOTLIN(NOL-1) : End : Endif
   When "GESBIS" :
    If [F:TDA]PFINUM>0 : [M]BASDEPLIN(NOL-1) = [M]AMTNOTLIN(NOL-1) : End : Endif
   When Default
    #Recurring invoice creation, called from TRTRILIB
    Case GABREV
     When "BIC" :
      If [F:TDA]SFINUM>0 : [M]BASDEPLIN(NOL-1) = [M]AMTNOTLIN(NOL-1) : End : Endif
     When "BIS"
      If [F:TDA]PFINUM>0 : [M]BASDEPLIN(NOL-1) = [M]AMTNOTLIN(NOL-1) : End : Endif
    Endcase
  Endcase
 Endif

 Case [F:TDA]DEPTYP
  When 1
   [M]BASDEPLIN(NOL-1) = [M]AMTNOTLIN(NOL-1)
  When 2
   [M]BASDEPLIN(NOL-1) = [M]AMTATILIN(NOL-1)
 Endcase
Endif
End


###################################################################################################################
## 'After change' Action called in the DEP Field (Early Discount / Late Charge Code) associated to
## the AP/AR Invoice Header (BIC1 or BIS1 Screen)
###################################################################################################################
Subprog AM_DEP(DSC)
Value Char    DSC()  : # Early Discount Code
Gosub REINIT
End

###################################################################################################################
## Subprogramm called in the SIVTYP/PIVTYP Fields (Invoice type) associated to
## the AP/AR Invoice Header (BIC1 or BIS1 Screen)
###################################################################################################################
Subprog CHANGE_INVTYP(DSC)
Value Char    DSC()  : # Early Discount Code
Gosub REINIT
End


$REINIT
Local Integer NOLI
Case GFONCTION
 When "GESBIC" : Default Mask [BIC3]
 When "GESBIS" : Default Mask [BIS3]
Endcase

Call DISPLAY_DSCFLD(DSC,"") From INVDEPLIB
Local Integer I
# Issue X3-63507 - 2017-11-29 by FHA :
#       DEP shld be moved only if discount code, otherwise the field
#       is considered as intiated even empty, causing
#       the field's defaulting issue in BIS import
If DSC <> ""        # Issue X3-63507
[M]DEP = DSC
Endif               # Issue X3-63507

NOLI = nolign
For I=1 To [M]NBLIG
 Call INIT_FLGDEP(GPLAN(1),[M]ACC1(I-1),I,[M]FLGDEP(I-1)) From INVDEPLIB
 Call CAL_BASDEPLIN(DSC,[M]FLGDEP(I-1),I) From INVDEPLIB
 If GDEPMGTMOD = 1 | GDEPMGTMOD = 5
  nolign = I
  Case GFONCTION
   When "GESBIC"
    Gosub CALTVA From SUBBIC2
   When "GESBIS"
    Gosub CALTVA From SUBBIS2
  Endcase
  [M]AMTATILIN(I-1) = [M]AMTNOTLIN(I-1)+[M]AMTTAX1(I-1)+[M]AMTTAX2(I-1)+[M]AMTVAT(I-1)
 Endif
Next
nolign = NOLI

[M]BASDEP = sum([M]BASDEPLIN(0..max(nolign,[M]NBLIG)-1))
If !GIMPORT
 Affzo FLGDEP, BASDEP, CUR3
 If GDEPMGTMOD = 1 | GDEPMGTMOD = 5
  [M]TOTATI = sum([M]AMTATILIN(0..max(nolign,[M]NBLIG)-1))
  Affzo AMTATILIN, TOTATI
 Endif
Endif
Case GFONCTION
 When "GESBIC" : Default Mask [BIC1]
 When "GESBIS" : Default Mask [BIS1]
Endcase
Return


######################################################################################
# Settlements Discounts - Rebate on VAT Management (GDEPMGTMOD = 1)
#
# This sub-program returns the higher discount rate
######################################################################################
Subprog DSCRAT(DSC,RAT)
Value    Char    DSC
Variable Decimal RAT

If DSC="" : End : Endif
If clalev([F:TDA])=0 : Local File TABDEPAGIO [TDA] : Endif

Call LEC_TDA(GCURLEG,DSC) From CPTLEC

RAT=abs(min([F:TDA]DEPRAT))
End

Funprog DSCSFI(DSC)
Value    Char    DSC
If DSC="" : End 0 : Endif
If clalev([F:TDA])=0 : Local File TABDEPAGIO [TDA] : Endif
Call LEC_TDA(GCURLEG,DSC) From CPTLEC
Case GFONCTION
 When "GESBIC" #, "BPCVAL" :
  End [F:TDA]SFINUM
 When "GESBIS" #, "BPSVAL" :
  End [F:TDA]PFINUM
Endcase
#Recurring invoice creation, called from BPRICRE
Case GABREV
 When "BIC" :
  End [F:TDA]SFINUM
 When "BIS"
  End [F:TDA]PFINUM
Endcase
End 0

##############################################################################################################
Subprog AMTDEP(AMTDEP,STAT)
Variable Decimal AMTDEP
Variable Integer STAT

Local Decimal DSCRAT

Raz AMTDEP
If [F:TB1]FLGDEP<>2 | [F:TB0]DEP="" :End : Endif

Call DSCRAT([F:TB0]DEP,DSCRAT) From INVDEPLIB
If [L]DSCRAT<>0 #& func INVDEPLIB.DSCSFI([F:TB0]DEP)
 Call LEC_TCU([F:TB0]CUR) From CPTLEC
 [L]AMTDEP = arr([F:TB1]AMTNOTLIN*[L]DSCRAT/100,[F:TCU]CURRND)
Endif
End

