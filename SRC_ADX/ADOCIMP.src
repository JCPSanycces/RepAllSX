#<AdxTL>@(#)7.0.0.0 $Revision$
Local Char PARAM(10)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ADOCIMP","ADOCIMP",3,"") From GTRAITE
End

################################################################
$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "SORTIE"     : Gosub FERME
 When "EXEC"       : TRA = 1  : Gosub EXEC
Endcase
Return

$INIT
Local Char COD_LAN(GLONLAN)

Local Mask ADOCIMP [DIA]
[M:DIA]HLPFLD  = 2
[M:DIA]HLPFIL  = 2
[M:DIA]NEWFLG  = 1

[M:DIA]LAN     = PARAM(1)
[M:DIA]REPERT  = PARAM(2)
Call INIT_REPERT_LAN([M:DIA]REPERT, "xml") From AGENLIBA

Local Char    WLANREF(250)
Call PARAMUTIL("LANREF",WLANREF,"","") From SUBAUS
If WLANREF="" : WLANREF=GLANDEF : Endif

Local Char    WLANTRA(250)
Call PARAMUTIL("LANTRA",WLANTRA,"","") From SUBAUS
If [M:DIA]LAN="" : [M:DIA]LAN = WLANTRA: Endif
If [M:DIA]LAN="" : [M:DIA]LAN = GLANGUE: Endif
If [M:DIA]LAN=WLANREF : [M:DIA]LAN="ENG" : Endif

# JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Call INIT_ALLCREGRP("[M:DIA]ALLCREGRP") From AGENLIBA
Return


###################################################################
$FERME
# cg mai  2013
# il faut killer les var globales crée via prog
Gosub FERME_KILL From AGENLIBA
Return

################################################
$EXEC
Local Integer MAXCH : MAXCH=2500
#VPO 22/04/08 bug47064
#Local Char V_TXT (120) (1..MAXCH)
Local Char V_TXT (150) (1..MAXCH)
Local Char MYVAL (100)
### on autorise import de doc et pas seulement mise à jour
### sauf pour les fichiers liés.
#### mettre INSERT_OK=1
Local Integer INSERT_OKADH : INSERT_OKADH=1
Local Integer INSERT_OK : INSERT_OK=0
If [M:DIA]NEWFLG=2 : INSERT_OK=1 : Endif
###################################
Local Char    REPFIC(GDIMFIC) ,REPIMP(GDIMFIC)
Local Char    REPDOC(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(10),SLASH(1)
Local Integer NBFICDOC,NBFICFLD,NBFICFIL
Raz NBFICDOC,NBFICFLD,NBFICFIL
Local Integer OKNBFICDOC,OKNBFICFLD,OKNBFICFIL
Raz OKNBFICDOC,OKNBFICFLD,OKNBFICFIL
Local Integer KONBFICDOC,KONBFICFLD,KONBFICFIL
Raz KONBFICDOC,KONBFICFLD,KONBFICFIL
Local Integer ERR : ERR=0

SLASH=string$(instr(1,[M:DIA]REPERT,"\")=0,"/")+string$(instr(1,[M:DIA]REPERT,"\")<>0,"\")

#Import de documentations
Call OUVRE_TRACE(mess(34,176,1)) From LECFIC
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(mess(35,176,1)-":"-[DIA]LAN,0) From GESECRAN
Call ECR_TRACE(mess(36,176,1)-":"-mess([DIA]HLPFLD,1,1),0) From GESECRAN
Call ECR_TRACE(mess(37,176,1)-":"-mess([DIA]HLPFIL,1,1),0) From GESECRAN
##Call ECR_TRACE(mess(38,176,1)-":"-mess([DIA]FLGCFM,1,1),0) From GESECRAN
Call ECR_TRACE(mess(52,176,1)-":"-mess([DIA]NEWFLG,1,1),0) From GESECRAN
Call ECR_TRACE("|"+mess(37,139,1)-mess(34,176,1)-":"-[M:DIA]REPERT,0)  From GESECRAN

REPIMP = [M:DIA]REPERT
# JPGA-EXI-85524-28 02/04/2014 : Pour la V7 et +, Implémentation de l'utilisation de VOLUME dans les nom de répertoires.
REPIMP=func AGENLIBA.REMPLACE_VOLUME (REPIMP)

Call MACHINE(REPIMP,MACHINE,REPFIC) From ORDSYS
REPIMP = REPFIC
Call GET_OS(MACHINE,OS) From ORDSYS

DOSSUP=func AFNC.PARAM('SUPDOS','')
Local File ADOCUMENT            [ADO]
Local File =DOSSUP+".ADOCUMENT" [ADOI]
Local File ADOCCLB              [ADH]
Local File =DOSSUP+".ADOCCLB"   [ADH2]

#
Gosub TRAIT_DOC
If ERR : Goto FIN_EXEC : Endif
If [DIA]HLPFLD=2
    Gosub TRAIT_DOC_FLD
    If ERR : Goto FIN_EXEC : Endif
Endif
If [DIA]HLPFIL=2
    Gosub TRAIT_DOC_FIL
    If ERR : Goto FIN_EXEC : Endif
Endif

$FIN_EXEC
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(string$(80,"*"),0) From GESECRAN
Call ECR_TRACE(mess(40,176,1),0) From GESECRAN
Call ECR_TRACE_F("","", " "+mess(44,176,1)+string$(max(9-len(mess(44,176,1)),0),"-"),
&                       " "+mess(45,176,1)+string$(max(9-len(mess(45,176,1)),0),"-"),
&                       " "+mess(46,176,1)+string$(max(9-len(mess(46,176,1)),0),"-"),40,3,10,10,10,0) From GESECRAN
Call ECR_TRACE_F(string$(20," ")+mess(41,176,1),":",format$("N:8",NBFICDOC),format$("N:8",OKNBFICDOC),format$("N:8",KONBFICDOC),40,3,10,10,10,0) From GESECRAN
Call ECR_TRACE_F(string$(20," ")+mess(42,176,1),":",format$("N:8",NBFICFLD),format$("N:8",OKNBFICFLD),format$("N:8",KONBFICFLD),40,3,10,10,10,0) From GESECRAN
Call ECR_TRACE_F(string$(20," ")+mess(43,176,1),":",format$("N:8",NBFICFIL),format$("N:8",OKNBFICFIL),format$("N:8",KONBFICFIL),40,3,10,10,10,0) From GESECRAN
Call FERME_TRACE From LECFIC
Return

######################################################################################
######################################################################################
$TRAIT_DOC
Local Clbfile TXTCLOB(10)
Local Clbfile MYCLOB(10)
Local Integer ER : ER=0
Local Char LISTE_XML(100)(1..10000)
Local Integer NBXML,NOXML
Raz LISTE_XML,NBXML
NOXML=1
Local Char FICRECH(100), WABREV(GLONABR), WCLE(100)
##
Local Integer MAXBAL: MAXBAL=11 : #nombre max de balises
####Local Integer MINBAL: MINBAL=5 : #nombre min de balises trouvees dans un fichier de doc
Local Char V_BALDOC (15) (1..MAXBAL)
V_BALDOC(1)="<?xml "
V_BALDOC(2)="<DOC "
V_BALDOC(3)="<PAR "
V_BALDOC(4)="<TIT>"
V_BALDOC(5)="????"
V_BALDOC(6)="</TIT>"
V_BALDOC(7)="<HTML>"
V_BALDOC(8)="????"
V_BALDOC(9)="</HTML>"
V_BALDOC(10)="</PAR>"
V_BALDOC(11)="</DOC>"

##
REPDOC=[DIA]REPERT
REPFIC=REPIMP
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(string$(80,"*"),0) From GESECRAN
Call ECR_TRACE(mess(34,176,1),0) From GESECRAN
Call ECR_TRACE(string$(len(mess(34,176,1)),'-'),0) From GESECRAN
Call ECR_TRACE("|"+mess(39,176,1)-":"-REPDOC,0) From GESECRAN
Call EXISTE(REPDOC,ER) From ORDSYS
If ER<>2
 Call ECR_TRACE(mess(09,141,1),0) From GESECRAN : # Repertoire inexistant
 ERR=1
 Return
Endif
Call SYSTEME2(MACHINE,'lsadx "'+REPFIC+'" "xml"',"",NBXML,LISTE_XML) From ORDSYS
While (NOXML<=NBXML)
    FICRECH = LISTE_XML(NOXML)
    J=instr(1,FICRECH,".xml")
    If J<=0
        FICRECH=FICRECH+".xml"
    Endif
    Gosub IMP_DOC
$TRAIT_DOC_SUITE
    NBFICDOC+=1
    NOXML += 1
Wend
Return

######################################################################################
#{X3-37853
$TRACE_COR_CHECK
TRACE_COR_KEY2 = TRACE_COR_OBJET(TRACE_COR_COUNT)
TRACE_COR_KEY2 += "~"+TRACE_COR_CLE1(TRACE_COR_COUNT)
TRACE_COR_KEY2 += "~"+TRACE_COR_CLE2(TRACE_COR_COUNT,0)
TRACE_COR_KEY2 += "~"+TRACE_COR_CLE2(TRACE_COR_COUNT,1)
TRACE_COR_KEY2 += "~"+TRACE_COR_TRA(TRACE_COR_COUNT)

If !find(TRACE_COR_KEY2,TRACE_COR_KEY)
 #add the key to the list
TRACE_COR_KEY(TRACE_COR_COUNT) =TRACE_COR_KEY2
Else
 #remove the last element
 TRACE_COR_OBJET(TRACE_COR_COUNT)=""
 TRACE_COR_CLE1(TRACE_COR_COUNT)=""
 TRACE_COR_CLE2(TRACE_COR_COUNT,0)=""
 TRACE_COR_CLE2(TRACE_COR_COUNT,1)=""
 TRACE_COR_TRA(TRACE_COR_COUNT)=""
 TRACE_COR_COUNT -= 1
Endif
Return
#X3-37853}

######################################################################################
$IMP_DOC
Local Integer ER : ER=0

Local Integer HTML,TIT,ID_LIG,LIG,TT_PAR
TIT=0 : HTML=0 : LIG=0 : ID_LIG=1 : TT_PAR=0
Local Char COD_LAN(GLONLAN)
Local Char COD_TYP(GLONADI)
Local Char PAR_DOC(GLONADI)
Local Char MSK_DOC(20)
Local Date VLDDAT_DOC
Local Char CODE_DOC(30)
Local Char DOC_CODACT(10)
Local Char DOC_TIT(80)
Local Integer LEV,SUBLEV : # Niveau et sous-niveau
Local Integer CODE_MODULE
Local Integer DOC_STY,VLDFLG_DOC

Local Clbfile MYNEWCLOB(10)
Local Char V_NEWCLOB (255) (1..MAXCH)
Local Integer NONEWCLOB
Raz V_NEWCLOB : NONEWCLOB=1

Gosub TRACE_COR_DEFVAR: #{X3-37853

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
#adxifs = chr$(0) : adxirs = chr$(13)+chr$(10) : adxium = GADXHTENT
adxifs = chr$(0) : adxirs = chr$(13)+chr$(10) : adxium = GUTF8

Openi REPDOC+SLASH+FICRECH,0 Using [FIC1]

Trbegin [ADO]

Rdseq MYCLOB Using [FIC1]
If fstat<>0
    ER=3
Endif

NEW_ADO=0 : NEW_ADH=0
While (fstat=0 and ER=0)
    LIG+=1
    Gosub LIRECLOBDOC
    If ER : Break : Endif
    Rdseq MYCLOB Using [FIC1]
    #JPGA EXI-82999-14 : Bug d'import s'il n'y a pas de CR après </DOC> en fin de fichier importé : La balise n'est pas traitée
    If fstat=1 & len(MYCLOB)>0                 : # fstat=1 : Fin de fichier  & le CLOB lu est non vide
      LIG+=1  :  Gosub LIRECLOBDOC  :  fstat=1 : # on repositionne la fin de fichier après traitement du contenu
    Endif
Wend

###If (ID_LIG<>MAXBAL+1 or LIG<MINBAL) and ER=0
If (ID_LIG<>MAXBAL+1 or LIG<2) and ER=0
    ER=3
Endif

Openi Using [FIC1]
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM

If ER
    Rollback
    Case ER
      When 7       : Goto TRAIT_DOC_KO7  :  #Groupe du User différent de celui de la DOC à importer
      When 6       : Goto TRAIT_DOC_KO6  :  #Mise à jour (Contenu LAN = Contenu LANREF)
      When 5       : Goto TRAIT_DOC_KO5  :  #Mise à jour (Clé inexistante)
      When 4       : Goto TRAIT_DOC_KO4  :  #langue
      When 3       : Goto TRAIT_DOC_KO3  :  #contenu
      When 2       : Goto TRAIT_DOC_KO2  :  #nom du fichier
      When Default : Goto TRAIT_DOC_KO1  :  #mise à jour
    Endcase
Else
    If ER=0 : Call MAJ_ENVINDUS_DOC (COD_LAN,COD_TYP,CODE_DOC,1) From AGENREM : Endif : # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
    Commit

   #{X3-37853: JSON elements have to be generated after the commit
   For TRACE_COR_I=1 To TRACE_COR_COUNT
    Call TRACE_COR(TRACE_COR_OBJET(TRACE_COR_I), TRACE_COR_CLE1(TRACE_COR_I),TRACE_COR_CLE2(TRACE_COR_I),TRACE_COR_TRA(TRACE_COR_I)) From GOBJET
   Next TRACE_COR_I
   #X3-37853}

Endif
Call ECR_TRACE("  "-FICRECH-":"-mess(49,176,1),0) From GESECRAN
OKNBFICDOC+=1
Return

$TRAIT_DOC_KO1 : #mise à jour
    Call ECR_TRACE("!"-FICRECH-"("+mess(93,100,1)-num$(LIG)+"):"-mess(50,176,1),-1) From GESECRAN
    Goto TRAIT_DOC_KO
$TRAIT_DOC_KO2 : # nom du fichier
    Call ECR_TRACE("!"-FICRECH-"("+mess(93,100,1)-num$(LIG)+"):"-mess(47,176,1),1) From GESECRAN
    Goto TRAIT_DOC_KO
$TRAIT_DOC_KO3 : #contenu
    Call ECR_TRACE("!"-FICRECH-"("+mess(93,100,1)-num$(LIG)+"):"-mess(48,176,1),1) From GESECRAN
    Goto TRAIT_DOC_KO
$TRAIT_DOC_KO4 : #la lanque ne correspond pas
    Call ECR_TRACE("!"-FICRECH-"("+mess(93,100,1)-num$(LIG)+"):"-mess(51,176,1),1) From GESECRAN
    Goto TRAIT_DOC_KO
$TRAIT_DOC_KO5 : #Mise à jour (Clé inexistante)
    Call ECR_TRACE("!"-FICRECH-"("+mess(93,100,1)-num$(LIG)+"):"-mess(50,176,1)-"-"-mess(6,114,1),1) From GESECRAN
    Goto TRAIT_DOC_KO
$TRAIT_DOC_KO6 : #Mise à jour (Contenu LAN = Contenu LANREF)
    # Le message d'erreur a déjà été affiché dans le FUNPROG. On n'en réaffiche plus d'autre !
    Goto TRAIT_DOC_KO
$TRAIT_DOC_KO7 : #Documentation non traitée : Groupe ($1$) différent de celui de l'utilisateur ($2$)
    # Le message d'erreur a déjà été affiché dans le FUNPROG. On n'en réaffiche plus d'autre !
    Call ECR_TRACE("!"-FICRECH-"("-mess(6,123,1)-"07"+")",-1) From GESECRAN
    Goto TRAIT_DOC_KO
$TRAIT_DOC_KO
    KONBFICDOC+=1
Return

######################################################################"
# Renseignement des champs par défaut du document
$SET_ADO
  [ADO]TYP=COD_TYP
  [ADO]COD=CODE_DOC
  [ADO]LEV=LEV
  [ADO]SUBLEV=SUBLEV
  [ADO]PAR=PAR_DOC
  [ADO]LAN=COD_LAN
  If dim([ADO]CREUSR)>0    : [ADO]CREUSR    = GUSER                                  : Endif
  If dim([ADO]CREDATTIM)>0 : [ADO]CREDATTIM = datetime$
    If dim([ADO]CREDAT)>0  : [ADO]CREDAT=func SUBADC.DAT_DATETIME([ADO]CREDATTIM)   : Endif
  Else
    If dim([ADO]CREDAT)>0  : [ADO]CREDAT    = date$                                  : Endif
    If dim([ADO]CRETIM)>0  : [ADO]CRETIM    = time                                   : Endif
  Endif
  [ADO]MODULE=CODE_MODULE
  [ADO]STY=DOC_STY
  [ADO]CODACT=DOC_CODACT
  [ADO]MSK=MSK_DOC
  [ADO]VLDDAT=VLDDAT_DOC
  [ADO]VLDFLG=VLDFLG_DOC
  ##VPO 30/10/06 Raz [ADO]UPDDAT,[ADO]UPDUSR,[ADH]TEXTE,[ADO]MSK,[ADO]TIT
  Raz [ADH]TEXTE,[ADO]TIT
  If dim([ADO]UPDDAT)>0    : Raz [ADO]UPDDAT     : Endif
  If dim([ADO]UPDUSR)>0    : Raz [ADO]UPDUSR     : Endif
  If dim([ADO]UPDTIM)>0    : Raz [ADO]UPDTIM     : Endif
  If dim([ADO]UPDDATTIM)>0 : Raz [ADO]UPDDATTIM  : Endif
  [ADH]=[ADO]
Return

######################################################################
$LIRECLOBDOC
Local Integer NOCH : NOCH=1
Local Char V_TEXTE (255)

Setlob V_TXT With MYCLOB
V_TEXTE=vireblc(V_TXT(NOCH),0)

Gosub DOCTRTLIG

ID_LIG +=1
Return

######################################################################
$DOCTRTLIG

Gosub DOCTRTTAG
#JPGA 28/09/2010 BUG-67738:Import KO sur fin de parcours du Buffer V_TEXTE alors que la clé n'est pas complète. Réalimentation à chaque Recherche de Texte
Gosub REALIMENTATION_VTEXTE

If find(ID_LIG,1,5,7,8,9,11)=0 and V_TEXTE<>"" and V_TEXTE<>">"
    IDX=ID_LIG+1
    If ID_LIG=10 : IDX=3 : Endif
    While IDX <= 11 and V_TEXTE<>"" and V_TEXTE<>">"
        RECH=V_BALDOC(IDX)
        J=instr(1,V_TEXTE,RECH)
        I=instr(1,V_TEXTE,V_BALDOC(10))
        If J>0 and ( I=0 or J<=I)
            ID_LIG=IDX
            If ID_LIG=6 and TIT=1
                DOC_TIT=left$(V_TEXTE,J-1)
                [ADO]TIT=DOC_TIT
                Gosub CORRIGETIT : #VPO 25/10/07 BUG43744
                TIT=0
            Endif
            V_TEXTE=right$(V_TEXTE,J)
            Gosub DOCTRTLIG
            Break
        Endif
        IDX+=1
    Wend
Endif
Return

$REALIMENTATION_VTEXTE
    #VPO 22/04/08 bug47064
    #If len(V_TEXTE)<135 and V_TXT(NOCH+1)<>"" Then
    If len(V_TEXTE)<106 and V_TXT(NOCH+1)<>"" Then
        NOCH+=1
        V_TEXTE += V_TXT(NOCH)
    Endif
Return

######################################################################
$RECHTEXTE
    #JPGA 28/09/2010 BUG-67738:Import KO sur fin de parcours du Buffer V_TEXTE alors que la clé n'est pas complète. Réalimentation à chaque Recherche de Texte
    Gosub REALIMENTATION_VTEXTE

    J=instr(1,V_TEXTE,RECH)
    If J=0 : ER=3 : Return : Endif
    V_TEXTE=right$(V_TEXTE,J+len(RECH)+1)
    J=instr(1,V_TEXTE,'"')
    If J=0 : ER=3 : Return : Endif
    MYVAL=left$(V_TEXTE,J-1)
    V_TEXTE=right$(V_TEXTE,J+1)
Return
######################################################################
$DOCTRTTAG

NOHTML=0
If ID_LIG=4 and left$(V_TEXTE,len(V_BALDOC(7)))=V_BALDOC(7)
# on n'a pas <TIT mais <HTML>
    TIT=0
    ID_LIG=7
Elsif ID_LIG=4 and left$(V_TEXTE,len(V_BALDOC(10)))=V_BALDOC(10)
# on n'a pas <TIT mais </PAR>
    TIT=0
    HTML=0
    ID_LIG=10
Elsif ID_LIG=5 and left$(V_TEXTE,len(V_BALDOC(6)))=V_BALDOC(6)
# on n'a pas le texte du titre mais </TIT>
    ID_LIG=6
Elsif ID_LIG=7 and left$(V_TEXTE,len(V_BALDOC(10)))=V_BALDOC(10)
# on n'a pas <HTML mais </PAR>
    HTML=0
    ID_LIG=10
Elsif ID_LIG=5
# on a du texte (TIT)
Elsif ID_LIG=8
# on a du texte (HTML)
    If HTML=1
        If NONEWCLOB>1
            V_NEWCLOB(NONEWCLOB)=chr$(13)+chr$(10)
            NONEWCLOB +=1
        Endif
        NOTXTTMP=1
        While NOTXTTMP<MAXCH and vireblc(V_TXT(NOTXTTMP),2)<>""
            V_NEWCLOB(NONEWCLOB)=V_TXT(NOTXTTMP)
            NOTXTTMP+=1
            NONEWCLOB +=1
        Wend
    Endif
Elsif ID_LIG=9 and HTML=1 and left$(V_TEXTE,len(V_BALDOC(ID_LIG)))<>V_BALDOC(ID_LIG)
# on est encore sur du texte HTML
    If HTML=1
        If NONEWCLOB>1
            V_NEWCLOB(NONEWCLOB)=chr$(13)+chr$(10)
            NONEWCLOB +=1
        Endif
        NOTXTTMP=1
        While NOTXTTMP<MAXCH and vireblc(V_TXT(NOTXTTMP),2)<>""
            V_NEWCLOB(NONEWCLOB)=V_TXT(NOTXTTMP)
            NOTXTTMP+=1
            NONEWCLOB +=1
        Wend
    Endif
    ID_LIG=8
Elsif ID_LIG=11 and left$(V_TEXTE,len(V_BALDOC(3)))=V_BALDOC(3)
# on n'a pas </DOC> mais <PAR>
    ID_LIG=3
#VPO 26/08/08 47325 import de doc si fichier contient trop de lignes
Elsif ID_LIG>11 : # on ne doit plus avoir de texte car doc entierement traitee
    ER=3
    Return
Elsif left$(V_TEXTE,len(V_BALDOC(ID_LIG)))<>V_BALDOC(ID_LIG) : # on doit avoir le texte correspondant
    ER=3
    Return
Endif

Case ID_LIG
When 2: #doc
    RECH="TYPE="
    Gosub RECHTEXTE
    If ER : Return : Endif
    COD_TYP=MYVAL

    RECH="NAME="
    Gosub RECHTEXTE
    If ER : Return : Endif
    CODE_DOC=MYVAL

When 3: #par
    Raz V_NEWCLOB : NONEWCLOB=1
    HTML=0 : TIT=0
    If TT_PAR=1
        ER=3 : Return
    Endif
    TT_PAR=1
    Raz [ADO],[ADH],[ADH2]
    NEW_ADO=0 : NEW_ADH=0

    RECH="LAN="
    Gosub RECHTEXTE
    If ER : Return : Endif
    COD_LAN=MYVAL
    If COD_LAN<>[DIA]LAN
        ER=4
        Return
    Endif

    RECH="LEV="
    Gosub RECHTEXTE
    If ER : Return : Endif
    LEV=val(MYVAL)

    RECH="SUBLEV="
    Gosub RECHTEXTE
    If ER : Return : Endif
    SUBLEV=val(MYVAL)

    RECH="PAR="
    Gosub RECHTEXTE
    If ER : Return : Endif
    PAR_DOC=MYVAL

    #VPO 20/12/06 ajout MSK
    RECH="MSK="
    Gosub RECHTEXTE
    If ER : Return : Endif
    MSK_DOC=MYVAL

    RECH="STY="
    Gosub RECHTEXTE
    If ER : Return : Endif
    DOC_STY=val(MYVAL)

    #VPO 20/12/06 ajout VLDDAT et VLDFLG
    RECH="VLDDAT="
    Gosub RECHTEXTE
    If ER : Return : Endif
    VLDDAT_DOC=MYVAL

    RECH="VLDFLG="
    Gosub RECHTEXTE
    If ER : Return : Endif
    VLDFLG_DOC=val(MYVAL)

    RECH="ACT="
    Gosub RECHTEXTE
    If ER : Return : Endif
    DOC_CODACT=MYVAL

    RECH="MOD="
    Gosub RECHTEXTE
    If ER : Return : Endif
    CODE_MODULE=val(MYVAL)

    Readlock [ADO]ADO0=COD_LAN;COD_TYP;CODE_DOC;LEV;SUBLEV
    If [S]fstat=0
        #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
        If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : ER=7 : Return : Endif
        NEW_ADO=0
$SUITE_ADO
        [ADO]VLDDAT=VLDDAT_DOC
        [ADO]VLDFLG=VLDFLG_DOC
        If dim([ADO]UPDUSR)>0    : [ADO]UPDUSR    = GUSER                                      : Endif
        If dim([ADO]UPDDATTIM)>0 : [ADO]UPDDATTIM = datetime$
          If dim([ADO]UPDDAT)>0  : [ADO]UPDDAT    = func SUBADC.DAT_DATETIME([ADO]UPDDATTIM)   : Endif
        Else
          If dim([ADO]UPDDAT)>0  : [ADO]UPDDAT    = date$                                      : Endif
          If dim([ADO]UPDTIM)>0  : [ADO]UPDTIM    = time                                       : Endif
        Endif
        Readlock [ADH]ADH0=COD_LAN;COD_TYP;CODE_DOC;LEV;SUBLEV
        If [S]fstat=0
            NEW_ADH=0
            Raz [ADH]TEXTE
            [ADH]=[ADO]
        Elsif [S]fstat=5
            Readlock [ADH2]ADH0=COD_LAN;COD_TYP;CODE_DOC;LEV;SUBLEV
            If [S]fstat=0
                NEW_ADH=2
                Raz [ADH2]TEXTE
                [ADH2]=[ADO]
            Elsif [S]fstat=5
                NEW_ADH=1
                If INSERT_OKADH=0
                    ER=5
                    Return
                Else
                    Raz [ADH]TEXTE
                    [ADH]=[ADO]
                Endif
            Else
                WABREV="ADH2"  :  WCLE=COD_LAN-COD_TYP-CODE_DOC-num$(LEV)-num$(SUBLEV)  :  Gosub READ_TEST_FSTAT
                Return
            Endif
        Else
            WABREV="ADH"   :  WCLE=COD_LAN-COD_TYP-CODE_DOC-num$(LEV)-num$(SUBLEV)  :  Gosub READ_TEST_FSTAT
            Return
        Endif
    Elsif [S]fstat=5
        NEW_ADO=1
        If INSERT_OK=0
            ER=5  :  Return
        Else
           Gosub SET_ADO
           Goto  SUITE_ADO
        Endif
    Else
        WABREV="ADO"   :  WCLE=COD_LAN-COD_TYP-CODE_DOC-num$(LEV)-num$(SUBLEV)  :  Gosub READ_TEST_FSTAT  :  Return
    Endif
When 4: #titre
        RECH=V_BALDOC(4)
        J=instr(1,V_TEXTE,RECH)
        If J=0 : ER=3 : Return : Endif
        V_TEXTE=right$(V_TEXTE,J+len(RECH))
        TIT=1
When 5: #texte titre
        #-- HN SI011 82999-1
        If len(V_TEXTE)>80  : # Le texte importé du Titre était trop long : le titre de la documentation a été tronqué !
           Call ECR_TRACE("!"-FICRECH-"("-mess(121,176,1)+")",-1) From GESECRAN
        Endif
        #-- HN SI011 82999-1
        DOC_TIT=V_TEXTE
        [ADO]TIT=DOC_TIT
        Gosub CORRIGETIT : #VPO 25/10/07 BUG43744
        TIT=0
When 6: #fin titre
        TIT=0
        RECH=V_BALDOC(6)
        J=instr(1,V_TEXTE,RECH)
        If J=0 : ER=3 : Return : Endif
        V_TEXTE=right$(V_TEXTE,J+len(RECH))
When 7: #html
        HTML=1
When 8: #texte html
When 9: #fin html
        If NOHTML=0
            Setlob MYNEWCLOB With V_NEWCLOB
            #VPO 25/10/07 BUG43744
            TXTCLOB=MYNEWCLOB
            Gosub CORRIGEXML
            MYNEWCLOB=TXTCLOB

            If NEW_ADH=2
                [ADH2]TEXTE=MYNEWCLOB
            Elsif  NEW_ADH=0
                [ADH]TEXTE=MYNEWCLOB
            Elsif NEW_ADH=1 and INSERT_OKADH=1
                [ADH]TEXTE=MYNEWCLOB
            Endif
        Endif
        HTML=0
When 10: #fin par
        If TT_PAR=0
            ER=3 : Return
        Endif
        TT_PAR=0
        If NEW_ADH=0
            ER = func DOC_CONTENU_EGAL_LANREF("ADH",FICRECH,LIG,[ADH]LAN, [ADH]TYP, [ADH]COD, [ADH]LEV, [ADH]SUBLEV, [ADH]TEXTE, [ADO]PAR) : If ER : Gosub FIN_ADO_PAR : Return : Endif
            Rewrite [ADH]
            [L]WABREV="ADH"   :  Gosub WRITE_TEST_FSTAT
        Elsif NEW_ADH=2
            ER = func DOC_CONTENU_EGAL_LANREF("ADH",FICRECH,LIG,[ADH2]LAN,[ADH2]TYP,[ADH2]COD,[ADH2]LEV,[ADH2]SUBLEV,[ADH2]TEXTE,[ADO]PAR) : If ER : Gosub FIN_ADO_PAR : Return : Endif
            Rewrite [ADH2]
            [L]WABREV="ADH2"  :  Gosub WRITE_TEST_FSTAT
        Elsif NEW_ADH=1 and INSERT_OKADH=1
            ER = func DOC_CONTENU_EGAL_LANREF("ADH",FICRECH,LIG,[ADH]LAN, [ADH]TYP, [ADH]COD, [ADH]LEV, [ADH]SUBLEV, [ADH]TEXTE, [ADO]PAR) : If ER : Gosub FIN_ADO_PAR : Return : Endif
            Write [ADH]
            [L]WABREV="ADH"   :  Gosub WRITE_TEST_FSTAT
        Endif

        If NEW_ADO=0
            Rewrite [ADO]
            [L]WABREV="ADO"   :  Gosub WRITE_TEST_FSTAT
            #{SAM122297
            If ![S]fstat
             #{X3-37853
             TRACE_COR_COUNT += 1
             TRACE_COR_OBJET(TRACE_COR_COUNT)  = "ADO"
             TRACE_COR_CLE1(TRACE_COR_COUNT)     =  [F:ADO]TYP
             TRACE_COR_CLE2(TRACE_COR_COUNT,0) = [F:ADO]LAN
             TRACE_COR_CLE2(TRACE_COR_COUNT,1) = [F:ADO]COD
             TRACE_COR_TRA(TRACE_COR_COUNT)       = "M"
             Gosub TRACE_COR_CHECK
             #X3-37853}
            Endif
            #SAM122297}
        Elsif NEW_ADO=1 and INSERT_OK=1
            Write [ADO]
            [L]WABREV="ADO"   :  Gosub WRITE_TEST_FSTAT
            #{SAM122297
            If ![S]fstat
             #{X3-37853
             TRACE_COR_COUNT += 1
             TRACE_COR_OBJET(TRACE_COR_COUNT)  = "ADO"
             TRACE_COR_CLE1(TRACE_COR_COUNT)     =  [F:ADO]TYP
             TRACE_COR_CLE2(TRACE_COR_COUNT,0) = [F:ADO]LAN
             TRACE_COR_CLE2(TRACE_COR_COUNT,1) = [F:ADO]COD
             TRACE_COR_TRA(TRACE_COR_COUNT)       = "C"
             Gosub TRACE_COR_CHECK

             #X3-37853}
            Endif
            #SAM122297}
        Endif
        #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Marquage Réalisé pour les Ecritures de la Génération ADOCUMENT (On ne le fait que sur TIT en CREATION)
        # Le besoin réside de tracer les DOCS traduites comme l'ENG par exemple pour pouvoir les pousser vers le REPOSITORY
        If PAR_DOC="TIT"
          Call TRACE_GROUPE("ADO", COD_LAN, COD_TYP, CODE_DOC, "C") From AGENLIBA
        Endif
        Gosub FIN_ADO_PAR
Endcase
Return

$FIN_ADO_PAR
   HTML=0
   TIT=0
   RECH=V_BALDOC(10)
   J=instr(1,V_TEXTE,RECH)
   If J=0 : ER=3 : Return : Endif
   V_TEXTE=right$(V_TEXTE,J+len(RECH))
Return

######################################################################################
# Fonction DOC_CONTENU_EGAL_LANREF : Recherche si le contenu de DOC est egal à celui de la langue de Référence)
######################################################################################
Funprog DOC_CONTENU_EGAL_LANREF(DOC_TABLE, FICRECH, LIG, DOC_LAN, DOC_TYP, DOC_COD, DOC_LEV, DOC_SUBLEV, DOC_TEXTE, DOC_PAR)
Value Char    DOC_TABLE()  # Abréviation table : ADH ou ADZ
Value Char    FICRECH()    # Fichier import courant
Value Integer LIG          # Ligne courante dans le ficheir Import
Value Char    DOC_LAN()    # CLE Langue d'importation : [ADH]LAN ou [ADH2]LAN ou [ADZ]LAN
Value Char    DOC_TYP()    # CLE Langue type de paragraphe : [ADH]TYP ou [ADH2]TYP ou ""
Value Char    DOC_COD()    # CLE Code DOC ou Mot clé d'aide : [ADH]COD ou [ADH2]COD ou [ADZ]MOTCLE
Value Integer DOC_LEV      # CLE Niveau : [ADH]LEV ou [ADH2]LEV ou 0
Value Integer DOC_SUBLEV   # CLE Sous-Niveau : [ADH]SUBLEV ou [ADH2]SUBLEV ou 0
Value Clbfile DOC_TEXTE    # Contenu du texte à tester : [ADH]TEXTE ou [ADH2]TEXTE ou [ADZ]TEXTE
Value Char    DOC_PAR()    # Type de paragraphe de doc : [ADO]PAR ou ""

Local Char    LAN_RECH(GLONLAN)
Local Char    LAN_FRA(GLONLAN): [L]LAN_FRA='FRA'
Local Char    LAN_ENG(GLONLAN): [L]LAN_ENG='ENG'
Local Char    LAN_BRI(GLONLAN): [L]LAN_BRI='BRI'
Local Char    TRACE_CLE (50)
Local Integer LAN_ERREUR0     : [L]LAN_ERREUR0=0
Local Integer LAN_ERREUR6     : [L]LAN_ERREUR6=6
# ATTENTION : Si cette fonction sort en ERREUR : Toujours utiliser un code Erreur 6 en RETOUR!!!

# TCH SI010 79707-32 : bloquage import de doc FRA/ENG dans les dossiers indus/ref
If func AGENLIBA.IS_DEVLANG_IMPORT(DOC_LAN)
   # On ne permet pas l'import de fichier en langue de dev
   Call ECR_TRACE("!"-FICRECH-"("+mess(93,100,1)-num$(LIG)+"):"-mess(94,176,1)-":"-DOC_LAN-"("+mess(6,123,1)-"61"+")",1) From GESECRAN
   End [L]LAN_ERREUR6
Endif
#JPGA 27/01/2012 BUG-79693: Import possible en FRA pour la Traduction CO-DEV
   If DOC_TEXTE = ""                                     # OK : Les contenus vides sont forcéments bon
      End [L]LAN_ERREUR0
   Else
      If DOC_LAN=[L]LAN_FRA
        [L]LAN_RECH=[L]LAN_ENG
      Else
        [L]LAN_RECH=[L]LAN_FRA
      Endif
      Case DOC_TABLE
        When "ADH"
          If find(DOC_PAR,'INC','LNK','ATB','AT2','MOT') # OK : Ne pas tester certains paragraphes : le contenu est = à la langue REF
             End [L]LAN_ERREUR0
          Else
             # Ouverture des tables pour recherche dans la langue de référence(on ne la connait pas mais on teste FRA ou ENG)
             DOSSUP=func AFNC.PARAM('SUPDOS','')
             If !clalev([ADHR]) : Local File           ADOCCLB  [ADHR] : Endif
             If !clalev([ADHS]) : Local File =DOSSUP+".ADOCCLB" [ADHS] : Endif
             TRACE_CLE=DOC_LAN+"~"+DOC_TYP+"~"+DOC_COD+"~"+num$(DOC_LEV)+"~"+num$(DOC_SUBLEV)+"~"+DOC_PAR

             #JPGA 12/04/2011 BUG-73174: Le BRI est maintenant traduit indépendemment de l'ENG sur la PAYE
             If !find(DOC_LAN,[L]LAN_FRA,[L]LAN_ENG,[L]LAN_BRI)  # Si DOC autre que FRA ENG BRI: on recherche en ENG puis le cas échéant en FRA
                Read [ADHR]ADH0=[L]LAN_ENG;DOC_TYP;DOC_COD;DOC_LEV;DOC_SUBLEV    # en ENG: Recherche ADH dans Dossier courant
                If [S]fstat
                   Read [ADHS]ADH0=[L]LAN_ENG;DOC_TYP;DOC_COD;DOC_LEV;DOC_SUBLEV # en ENG: Si inexistant, Recherche ADH dans Dossier mère
                   If [S]fstat
                      Raz [ADHR]
                   Else
                      [ADHR]=[ADHS]
                   Endif
                Endif
                If vireblc([ADHR]TEXTE,1)<>"" & vireblc(DOC_TEXTE,1)=vireblc([ADHR]TEXTE,1) # en ENG: Si non trouvé on continue, si = on sort en erreur
                   If DOC_PAR='TIT' : # Pour les paragraphes Titre : On avertit seulement en mettant un Warning dans la trace
                     Call ECR_TRACE("!"-FICRECH-"("+TRACE_CLE+")"-func AFNC.MES2 (mess(126,176,1), DOC_LAN, [L]LAN_ENG),-1) From GESECRAN
                   Else
                     Call ECR_TRACE("!"-FICRECH-"("+mess(93,100,1)-num$(LIG)-TRACE_CLE+"):"-func AFNC.MES2 (mess(97,176,1), DOC_LAN, [L]LAN_ENG)-"("+mess(6,123,1)-"62"+")",1) From GESECRAN
                     End [L]LAN_ERREUR6
                   Endif
                Endif
             Endif

             Read [ADHR]ADH0=[L]LAN_RECH;DOC_TYP;DOC_COD;DOC_LEV;DOC_SUBLEV       # en FRA: Recherche ADH dans Dossier courant
             If [S]fstat
                Read [ADHS]ADH0=[L]LAN_RECH;DOC_TYP;DOC_COD;DOC_LEV;DOC_SUBLEV    # en FRA: Si inexistant, Recherche ADH dans Dossier mère
                If [S]fstat
                   Raz [ADHR]
                Else
                   [ADHR]=[ADHS]
                Endif
             Endif
             If vireblc([ADHR]TEXTE,1)<>"" & vireblc(DOC_TEXTE,1)=vireblc([ADHR]TEXTE,1) # en FRA: Si non trouvé on continue, si = on sort en erreur
                If DOC_PAR='TIT' : # Pour les paragraphes Titre : On avertit seulement en mettant un Warning dans la trace
                  Call ECR_TRACE("!"-FICRECH-"("+TRACE_CLE+")"-func AFNC.MES2 (mess(126,176,1), DOC_LAN, [L]LAN_RECH),-1) From GESECRAN
                Else
                  Call ECR_TRACE("!"-FICRECH-"("+mess(93,100,1)-num$(LIG)-TRACE_CLE+"):"-func AFNC.MES2 (mess(97,176,1), DOC_LAN, [L]LAN_RECH)-"("+mess(6,123,1)-"63"+")",1) From GESECRAN
                  End [L]LAN_ERREUR6
                Endif
             Endif
          Endif
        When "ADZ"
          # Ouverture des tables pour recherche dans la langue de référence(on ne la connait pas mais on teste FRA ou ENG)
          If !clalev([ADZR])  : Local File ADOCFLD  [ADZR] : Endif
          TRACE_CLE=DOC_LAN+"~"+DOC_COD

          #JPGA 12/04/2011 BUG-73174: Le BRI est maintenant traduit indépendemment de l'ENG sur la PAYE
          If !find(DOC_LAN,[L]LAN_FRA,[L]LAN_ENG,[L]LAN_BRI)  # Si Aide autre que FRA ENG BRI: on recherche en ENG puis le cas échéant en FRA
             Read [ADZR]ADZ0=[L]LAN_ENG;DOC_COD               # en ENG: Recherche ADZ dans Dossier courant
             If [S]fstat
                Raz [ADZR]
             Endif
             If vireblc([ADZR]TEXTE,1)<>"" & vireblc(DOC_TEXTE,1)=vireblc([ADZR]TEXTE,1) # en ENG: Si non trouvé on continue, si = on sort en erreur
                Call ECR_TRACE("!"-FICRECH-"("+mess(93,100,1)-num$(LIG)-TRACE_CLE+"):"-func AFNC.MES2 (mess(97,176,1), DOC_LAN, [L]LAN_ENG)-"("+mess(6,123,1)-"64"+")",1) From GESECRAN
                End [L]LAN_ERREUR6
             Endif
          Endif

          Read [ADZR]ADZ0=[L]LAN_RECH;DOC_COD             # en FRA: Recherche ADZ dans Dossier courant
          If [S]fstat
             Raz [ADZR]
          Endif
          If vireblc([ADZR]TEXTE,1)<>"" & vireblc(DOC_TEXTE,1)=vireblc([ADZR]TEXTE,1) # en FRA: Si non trouvé on continue, si = on sort en erreur
             Call ECR_TRACE("!"-FICRECH-"("+mess(93,100,1)-num$(LIG)-TRACE_CLE+"):"-func AFNC.MES2 (mess(97,176,1), DOC_LAN, [L]LAN_RECH)-"("+mess(6,123,1)-"65"+")",1) From GESECRAN
             End [L]LAN_ERREUR6
          Endif
      Endcase
   Endif
End [L]LAN_ERREUR0


######################################################################################
######################################################################################
$TRAIT_DOC_FLD
Local Integer ER : ER=0
Local Char LISTE_XML(100)(1..10000)
Local Integer NBXML,NOXML
Raz LISTE_XML,NBXML
NOXML=1
Local Char FICRECH(100), WABREV(GLONABR), WCLE(100)
##
Local Integer MAXBAL: MAXBAL=6 : #nombre max de balises
###Local Integer MINBAL: MINBAL=5 : #nombre min de balises trouvees dans un fichier de doc
Local Char V_BALDOC (15) (1..MAXBAL)
V_BALDOC(1)="<?xml "
V_BALDOC(2)="<FLD "
V_BALDOC(3)="<HTML>"
V_BALDOC(4)="????"
V_BALDOC(5)="</HTML>"
V_BALDOC(6)="</FLD>"

Local File ADOCFLD [ADZ]
##
REPDOC=[DIA]REPERT+SLASH+"FLD"
REPFIC=REPIMP+SLASH+"FLD"
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(string$(80,"*"),0) From GESECRAN
Call ECR_TRACE(mess(36,176,1),0) From GESECRAN
Call ECR_TRACE(string$(len(mess(36,176,1)),'-'),0) From GESECRAN
Call ECR_TRACE("|"+mess(39,176,1)-":"-REPDOC,0) From GESECRAN
Call EXISTE(REPDOC,ER) From ORDSYS
If ER<>2
 Call ECR_TRACE(mess(09,141,1),0) From GESECRAN : # Repertoire inexistant
 Return
Endif

Call SYSTEME2(MACHINE,'lsadx "'+REPFIC+'" "xml"',"",NBXML,LISTE_XML) From ORDSYS
While (NOXML<=NBXML)
    FICRECH = LISTE_XML(NOXML)
    J=instr(1,FICRECH,".xml")
    If J<=0
        FICRECH=FICRECH+".xml"
    Endif
    Gosub IMP_FLD
$TRAIT_DOC_FLD_SUITE
    NBFICFLD+=1
    NOXML += 1
Wend
Return

######################################################################################
$IMP_FLD
Local Integer ER : ER=0
Local Clbfile TXTCLOB(10)
Local Clbfile MYCLOB(10)

Local Integer HTML,ID_LIG,LIG
HTML=0 : LIG=0 : ID_LIG=1
Local Char COD_LAN(GLONLAN)
Local Char CODE_FLD(GLONAVA)
Local Char CODE_DOC(GLONAVA)
Local Integer CODE_MODULE
Local Integer CODE_GEN

Local Char V_TXTTMP (255) (1..MAXCH)
Local Integer NOTXTTMP
Local Char V_NEWCLOB (255) (1..MAXCH) : Raz V_NEWCLOB
Local Integer NONEWCLOB : NONEWCLOB=1

Gosub TRACE_COR_DEFVAR: #{X3-37853



SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
#adxifs = chr$(0) : adxirs = chr$(13)+chr$(10) : adxium = GADXHTENT
adxifs = chr$(0) : adxirs = chr$(13)+chr$(10) : adxium = GUTF8

CODE_DOC=left$(FICRECH,instr(1,FICRECH,".xml")-1)

Openi REPDOC+SLASH+FICRECH,0 Using [FIC1]

Trbegin [ADZ]

Rdseq MYCLOB Using [FIC1]
If fstat<>0
    ER=3
Endif

NEW_ADZ=0
TROUVE=0
While (fstat=0 and ER=0)
    LIG+=1
    Gosub TRTCLOBFLD
    If ER : Break : Endif
    Rdseq MYCLOB Using [FIC1]
    #JPGA EXI-82999-14 : Bug d'import s'il n'y a pas de CR après </FLD> en fin de fichier importé : La balise n'est pas traitée
    If fstat=1 & len(MYCLOB)>0                 : # fstat=1 : Fin de fichier  & le CLOB lu est non vide
      LIG+=1  :  Gosub TRTCLOBFLD   :  fstat=1 : # on repositionne la fin de fichier après traitement du contenu
    Endif
Wend

# 1- on a enlevé la balise "  <HTML>"
# 2- on doit enlever la balise "  </HTML>"
# 3- on doit enlever la balise "</FLD>"
# puis on aura donc le texte
If NONEWCLOB>1 and ER=0
    TROUVE=0
    NOTXTTMP=NONEWCLOB
    While NOTXTTMP>1 and TROUVE=0
        RECH=V_BALDOC(6)
        J=instr(1,V_NEWCLOB(NOTXTTMP),RECH)
        If J>0
            TROUVE=1
            V_NEWCLOB(NOTXTTMP)=left$(V_NEWCLOB(NOTXTTMP),J-1)
            If vireblc(V_NEWCLOB(NOTXTTMP-1),2)=chr$(13)+chr$(10)
                V_NEWCLOB(NOTXTTMP-1)=""
            Endif
        Endif
        NOTXTTMP-=1
    Wend
    If TROUVE=0 : ER=3 : Endif
Endif
If NONEWCLOB>1 and ER=0
    TROUVE=0
    NOTXTTMP=NONEWCLOB
    While NOTXTTMP>1 and TROUVE=0
        RECH=V_BALDOC(5)
        J=instr(1,V_NEWCLOB(NOTXTTMP),RECH)
        If J>0
            TROUVE=1
            V_NEWCLOB(NOTXTTMP)=left$(V_NEWCLOB(NOTXTTMP),J-1)
            If vireblc(V_NEWCLOB(NOTXTTMP-1),2)=chr$(13)+chr$(10)
                V_NEWCLOB(NOTXTTMP-1)=""
            Endif
        Endif
        NOTXTTMP-=1
    Wend
    Setlob MYCLOB With V_NEWCLOB
    #VPO 25/10/07 BUG43744
    TXTCLOB=MYCLOB
    Gosub CORRIGEXML
    MYCLOB=TXTCLOB

    [ADZ]TEXTE=MYCLOB
    ID_LIG=6
    HTML=0
    Setlob MYCLOB With V_BALDOC(6)
    Gosub LIRECLOBFLD
Endif

###If (ID_LIG<>MAXBAL+1 or LIG<MINBAL) and ER=0
If (ID_LIG<>MAXBAL+1 or LIG<2) and ER=0
    ER=3
Endif

Openi Using [FIC1]
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM

If ER
    Rollback
    Case ER
      When 7       : Goto TRAIT_DOC_FLD_KO7  :  #Groupe du User différent de celui de la DOC à importer
      When 6       : Goto TRAIT_DOC_FLD_KO6  :  #Mise à jour (Contenu LAN = Contenu LANREF)
      When 5       : Goto TRAIT_DOC_FLD_KO5  :  #Mise à jour (Clé inexistante)
      When 4       : Goto TRAIT_DOC_FLD_KO4  :  #langue
      When 3       : Goto TRAIT_DOC_FLD_KO3  :  #contenu
      When 2       : Goto TRAIT_DOC_FLD_KO2  :  #nom du fichier
      When Default : Goto TRAIT_DOC_FLD_KO1  :  #mise à jour
    Endcase
Else
    Commit
Endif
Call ECR_TRACE("  "-FICRECH-":"-mess(49,176,1),0) From GESECRAN
OKNBFICFLD+=1
Return

$TRAIT_DOC_FLD_KO1 : #mise à jour
    Call ECR_TRACE("!"-FICRECH-"("+mess(93,100,1)-num$(LIG)+"):"-mess(50,176,1),-1) From GESECRAN
    Goto TRAIT_DOC_FLD_KO
$TRAIT_DOC_FLD_KO2 : # nom du fichier
    Call ECR_TRACE("!"-FICRECH-"("+mess(93,100,1)-num$(LIG)+"):"-mess(47,176,1),1) From GESECRAN
    Goto TRAIT_DOC_FLD_KO
$TRAIT_DOC_FLD_KO3 : #contenu
    Call ECR_TRACE("!"-FICRECH-"("+mess(93,100,1)-num$(LIG)+"):"-mess(48,176,1),1) From GESECRAN
    Goto TRAIT_DOC_FLD_KO
$TRAIT_DOC_FLD_KO4 : #la lanque ne correspond pas
    Call ECR_TRACE("!"-FICRECH-"("+mess(93,100,1)-num$(LIG)+"):"-mess(51,176,1),1) From GESECRAN
    Goto TRAIT_DOC_FLD_KO
$TRAIT_DOC_FLD_KO5 : #Mise à jour (Clé inexistante)
    Call ECR_TRACE("!"-FICRECH-"("+mess(93,100,1)-num$(LIG)+"):"-mess(50,176,1)-"-"-mess(6,114,1),1) From GESECRAN
    Goto TRAIT_DOC_FLD_KO
$TRAIT_DOC_FLD_KO6 : #Mise à jour (Contenu LAN = Contenu LANREF)
    # Le message d'erreur a déjà été affiché dans le FUNPROG. On n'en réaffiche plus d'autre !
    Goto TRAIT_DOC_FLD_KO
$TRAIT_DOC_FLD_KO7 : #Documentation non traitée : Groupe ($1$) différent de celui de l'utilisateur ($2$)
    # Le message d'erreur a déjà été affiché dans le FUNPROG. On n'en réaffiche plus d'autre !
    Call ECR_TRACE("!"-FICRECH-"("-mess(6,123,1)-"07"+")",-1) From GESECRAN
    Goto TRAIT_DOC_FLD_KO
$TRAIT_DOC_FLD_KO
    KONBFICFLD+=1
Return

$TRTCLOBFLD
    ##VPO 27/02/07
    If ID_LIG<3
       Gosub LIRECLOBFLD
    Else
       If NONEWCLOB>1 and TROUVE=0
          V_NEWCLOB(NONEWCLOB)=chr$(13)+chr$(10)
          NONEWCLOB +=1
       Endif
       TROUVE=0
       NOTXTTMP=1
       Setlob V_TXTTMP With MYCLOB
       While NOTXTTMP<MAXCH and vireblc(V_TXTTMP(NOTXTTMP),2)<>""

            RECH=V_BALDOC(3)
            J=instr(1,V_TXTTMP(NOTXTTMP),RECH)
            If J>0
                TROUVE=1
                V_NEWCLOB(NONEWCLOB)=right$(V_TXTTMP(NOTXTTMP),J+len(RECH))
            Else
                V_NEWCLOB(NONEWCLOB)=V_TXTTMP(NOTXTTMP)
            Endif
            NOTXTTMP+=1
            NONEWCLOB +=1
       Wend
    Endif
Return


#####################################################################"
# Renseignement des champs par défaut du document
$SET_ADZ
  [ADZ]MOTCLE=CODE_FLD
  [ADZ]LAN=COD_LAN
  If dim([ADZ]CREUSR)>0    : [ADZ]CREUSR    = GUSER                                      : Endif
  If dim([ADZ]CREDATTIM)>0 : [ADZ]CREDATTIM = gdatetime$(func SUBADC.CNVSYR(func SUBADC.CNVSTP(FLD_CREDAT, 0)))
    If dim([ADZ]CREDAT)>0  : [ADZ]CREDAT=FLD_CREDAT                                      : Endif
  Else
    If dim([ADZ]CRETIM)>0  : Raz [ADZ]CRETIM                                             : Endif
    If dim([ADZ]CREDAT)>0  : [ADZ]CREDAT=FLD_CREDAT                                      : Endif
  Endif
  If dim([ADZ]UPDUSR)>0    : [ADZ]UPDUSR    = GUSER                                      : Endif
  If dim([ADZ]UPDDATTIM)>0 : [ADZ]UPDDATTIM = datetime$
    If dim([ADZ]UPDDAT)>0  : [ADZ]UPDDAT    = func SUBADC.DAT_DATETIME([ADZ]UPDDATTIM)   : Endif
  Else
    If dim([ADZ]UPDDAT)>0  : [ADZ]UPDDAT    = date$                                      : Endif
    If dim([ADZ]UPDTIM)>0  : [ADZ]UPDTIM    = time                                       : Endif
  Endif
  [ADZ]MODULE=CODE_MODULE
  [ADZ]GEN=CODE_GEN
  [ADZ]LNKHLP=COD_LNKHLP
  [ADZ]LNKORD=COD_LNKORD
  Raz [ADZ]TEXTE
Return

######################################################################
$LIRECLOBFLD
Local Integer NOCH : NOCH=1
Local Char V_TEXTE (255)
Setlob V_TXT With MYCLOB
V_TEXTE=vireblc(V_TXT(NOCH),0)

Gosub FLDTRTLIG

ID_LIG +=1
Return

######################################################################
$FLDTRTLIG
Local Char V_TXTTMP (255) (1..MAXCH)
Local Integer NOTXTTMP
Local Char V_TMP (255)
Local Integer NOTMP
Gosub FLDTRTTAG
Return


######################################################################
$FLDTRTTAG
NOHTML=0
If ID_LIG=4
# on a du texte
Elsif ID_LIG=5 & V_TEXTE=""
    NOHTML=1
    ID_LIG=4
Elsif left$(V_TEXTE,len(V_BALDOC(ID_LIG)))<>V_BALDOC(ID_LIG) : # on doit avoir le texte correspondant
    ER=3
    Return
Endif

Case ID_LIG
When 2: #FLD
    Raz [ADZ]
    NEW_ADZ=0
    HTML=0

    RECH="NAME="
    Gosub RECHTEXTE
    If ER : Return : Endif
    CODE_FLD=MYVAL
    If CODE_FLD<>CODE_DOC
        ER=2
        Return
    Endif


    RECH="LAN="
    Gosub RECHTEXTE
    If ER : Return : Endif
    COD_LAN=MYVAL
    If COD_LAN<>[DIA]LAN
        ER=4
        Return
    Endif

    RECH="MOD="
    Gosub RECHTEXTE
    If ER : Return : Endif
    CODE_MODULE=val(MYVAL)

    RECH="GEN="
    Gosub RECHTEXTE
    If ER : Return : Endif
    # JPGA - 29/01/2009 - Bug:52080 - Si flag importé à 0 on l'initialise à 1 (Non)
    If val(MYVAL) = 0
       CODE_GEN = 1
    Else
       CODE_GEN = val(MYVAL)
    Endif

    RECH="LNKHLP="
    Gosub RECHTEXTE
    If ER : Return : Endif
    COD_LNKHLP=MYVAL

    RECH="LNKORD="
    Gosub RECHTEXTE
    If ER : Return : Endif
    COD_LNKORD=val(MYVAL)

    RECH="CREDAT="
    Gosub RECHTEXTE
    If ER : Return : Endif
    FLD_CREDAT=MYVAL

    RECH="UPDDAT="
    Gosub RECHTEXTE
    If ER : Return : Endif
    FLD_UPDDAT=MYVAL
    If FLD_UPDDAT<>[0/0/0] : FLD_CREDAT=FLD_UPDDAT : Endif

    Readlock [ADZ]ADZ0=COD_LAN;CODE_FLD
    If [S]fstat=0
        #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
        If ! func AGENLIBA.TEST_GROUPE_OK("ADZ", COD_LAN, "", CODE_FLD, "[M:DIA]ALLCREGRP") : ER=7 : Return : Endif

        If dim([ADZ]CREUSR)>0    : [ADZ]CREUSR    = GUSER                                      : Endif
        If dim([ADZ]CREDATTIM)>0 : [ADZ]CREDATTIM = gdatetime$(func SUBADC.CNVSYR(func SUBADC.CNVSTP(FLD_CREDAT, 0)))
          If dim([ADZ]CREDAT)>0  : [ADZ]CREDAT    = FLD_CREDAT                                 : Endif
        Else
          If dim([ADZ]CRETIM)>0  : Raz [ADZ]CRETIM                                             : Endif
          If dim([ADZ]CREDAT)>0  : [ADZ]CREDAT    = FLD_CREDAT                                 : Endif
        Endif
        If dim([ADZ]UPDUSR)>0    : [ADZ]UPDUSR    = GUSER                                      : Endif
        If dim([ADZ]UPDDATTIM)>0 : [ADZ]UPDDATTIM = datetime$
          If dim([ADZ]UPDDAT)>0  : [ADZ]UPDDAT    = func SUBADC.DAT_DATETIME([ADZ]UPDDATTIM)   : Endif
        Else
          If dim([ADZ]UPDDAT)>0  : [ADZ]UPDDAT    = date$                                      : Endif
          If dim([ADZ]UPDTIM)>0  : [ADZ]UPDTIM    = time                                       : Endif
        Endif
        [ADZ]MODULE=CODE_MODULE
        [ADZ]GEN=CODE_GEN
        [ADZ]LNKHLP=COD_LNKHLP
        [ADZ]LNKORD=COD_LNKORD
    Elsif [S]fstat=5
        NEW_ADZ=1
        If INSERT_OK=0
            ER=5  :  Return
        Else
            Gosub SET_ADZ
        Endif
    Else
        WABREV="ADZ"   :  WCLE=COD_LAN-CODE_FLD  :  Gosub READ_TEST_FSTAT  :  Return
    Endif
When 3: #html
        RECH=V_BALDOC(3)
        J=instr(1,V_TEXTE,RECH)
        If J=0 : ER=3 : Return : Endif
        V_TEXTE=right$(V_TEXTE,J+len(RECH))
        HTML=1
When 4: #texte html
        If NOHTML=0
            #VPO 25/10/07 BUG43744
            TXTCLOB=MYCLOB
            Gosub CORRIGEXML
            MYCLOB=TXTCLOB

            [ADZ]TEXTE=MYCLOB
        Endif
When 5: #fin html
        HTML=0
        RECH=V_BALDOC(5)
        J=instr(1,V_TEXTE,RECH)
        If J=0 : ER=3 : Return : Endif
        V_TEXTE=right$(V_TEXTE,J+len(RECH))
When 6: #fin FLD
        If NEW_ADZ=0
            ER = func DOC_CONTENU_EGAL_LANREF("ADZ",FICRECH,LIG,[ADZ]LAN,"",[ADZ]MOTCLE,J,J, [ADZ]TEXTE, "") : If ER : Gosub FIN_FLD : Return : Endif
            Rewrite [ADZ]
            [L]WABREV="ADZ"   :  Gosub WRITE_TEST_FSTAT
            #{SAM122297
            If ![S]fstat
               #{X3-37853
               TRACE_COR_COUNT += 1
               TRACE_COR_OBJET(TRACE_COR_COUNT)  = "ADZ"
               TRACE_COR_CLE1(TRACE_COR_COUNT)     =  [F:ADZ]MOTCLE
               TRACE_COR_CLE2(TRACE_COR_COUNT,0) = [F:ADZ]LAN
               TRACE_COR_TRA(TRACE_COR_COUNT)       = "M"
               Gosub TRACE_COR_CHECK
               #X3-37853}
            Endif
            #{SAM122297
            If ER=0 : Call MAJ_ENVINDUS_FLD (COD_LAN,CODE_FLD) From AGENREM : Endif : # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
        Elsif NEW_ADZ=1 and INSERT_OK=1
            ER = func DOC_CONTENU_EGAL_LANREF("ADZ",FICRECH,LIG,[ADZ]LAN,"",[ADZ]MOTCLE,J,J, [ADZ]TEXTE, "") : If ER : Gosub FIN_FLD : Return : Endif
            Write [ADZ]
            [L]WABREV="ADZ"   :  Gosub WRITE_TEST_FSTAT
            #SAM122297}
            If ![S]fstat
               #{X3-37853
               TRACE_COR_COUNT += 1
               TRACE_COR_OBJET(TRACE_COR_COUNT)  = "ADZ"
               TRACE_COR_CLE1(TRACE_COR_COUNT)     =  [F:ADZ]MOTCLE
               TRACE_COR_CLE2(TRACE_COR_COUNT,0) = [F:ADZ]LAN
               TRACE_COR_TRA(TRACE_COR_COUNT)       = "C"
               Gosub TRACE_COR_CHECK
               #X3-37853}
            Endif
            #SAM122297}
            If ER=0 : Call MAJ_ENVINDUS_FLD (COD_LAN,CODE_FLD) From AGENREM : Endif : # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
        Endif
        #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Marquage Réalisé pour les Ecritures de la Génération ADOCUMENT (On ne le fait que sur TIT en CREATION)
        # Le besoin réside de tracer les DOCS traduites comme l'ENG par exemple pour pouvoir les pousser vers le REPOSITORY
        Call TRACE_GROUPE("ADZ", COD_LAN, "", CODE_FLD, "C") From AGENLIBA
        Gosub FIN_FLD
Endcase
Return

$FIN_FLD
   HTML=0
Return

$CORRIGEXML
Local Char ARECH(250),AREMP(250)
    #VPO 25/10/07 BUG43744
    ARECH='&apos;'
    AREMP="'"
    Gosub ONSUPP
Return

$ONSUPP
POSRECH=instr(1,TXTCLOB,ARECH)
While POSRECH>0
    MYCLOB=left$(TXTCLOB,POSRECH-1)+AREMP+right$(TXTCLOB,POSRECH+len(ARECH))
    TXTCLOB=MYCLOB
    POSRECH=instr(1,TXTCLOB,ARECH)
Wend
Return

$CORRIGETIT
Local Char ARECH(250),AREMP(250),MYTIT(250)
    #VPO 25/10/07 BUG43744
    ARECH='&apos;'
    AREMP="'"
    Gosub ONSUPPTIT
Return

$ONSUPPTIT
POSRECH=instr(1,[ADO]TIT,ARECH)
While POSRECH>0
    MYTIT=left$([ADO]TIT,POSRECH-1)+AREMP+right$([ADO]TIT,POSRECH+len(ARECH))
    [ADO]TIT=MYTIT
    POSRECH=instr(1,[ADO]TIT,ARECH)
Wend
Return

#JPGA 08/04/2011 BUG-69853 : Prise en compte des statuts d'écriture et MAJ de UPDTIM et CRETIM
$READ_TEST_FSTAT
    Call RSTA(WABREV, WCLE) From GLOCK
    ER=1
Return

#JPGA 08/04/2011 BUG-69853 : Prise en compte des statuts d'écriture et MAJ de UPDTIM et CRETIM
$WRITE_TEST_FSTAT
    If [S]fstat
       Call FSTA(WABREV) From GLOCK
       ER=1
    Endif
Return

######################################################################################
######################################################################################
$TRAIT_DOC_FIL
Local Integer ER : ER=0
Local Char LISTE_FIC(100)(1..10000)
Local Integer NBFIC,NOXML
Raz LISTE_FIC,NBFIC
NOXML=1
Local Char FICRECH(100), WABREV(GLONABR), WCLE(100)
Local Char DEBFIC(100)
Local Char FINFIC(100)
##
If clalev ([F:ADB]) = 0
    Local File ADOCBLB
Endif

Local Char CODE_DOC(30)
Local Char CLEFIC(250),NAMFIC(250)
##
REPDOC=[DIA]REPERT+SLASH+"FILE"
REPFIC=REPIMP+SLASH+"FILE"
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(string$(80,"*"),0) From GESECRAN
Call ECR_TRACE(mess(37,176,1),0) From GESECRAN
Call ECR_TRACE(string$(len(mess(37,176,1)),'-'),0) From GESECRAN
Call ECR_TRACE("|"+mess(39,176,1)-":"-REPDOC,0) From GESECRAN
Call EXISTE(REPDOC,ER) From ORDSYS
If ER<>2
 Call ECR_TRACE(mess(09,141,1),0) From GESECRAN : # Repertoire inexistant
 Return
Endif
# on ajoute pour pb de mémoire
SVFREE=freemem
If SVFREE<(10*1024*1024)
maxmem=int((maxmem+((10*1024*1024)-SVFREE))/1024)
Endif
#JPGA 11/05/2010 BUG-64060 : Passage Stockage fichiers joints : BLOB de 9 à 10(En V6). Utilisation Nouveau type : ABD
Local Blbfile MYBLOB(GLONABD)
Call SYSTEME2(MACHINE,'lsadx "'+REPFIC+'" "*'+[DIA]LAN+'*"',"",NBFIC,LISTE_FIC) From ORDSYS
While (NOXML<=NBFIC)
    Raz [ADB]
    ER=0
    FICRECH = LISTE_FIC(NOXML)
    Call COUPEFIC(".",FICRECH,DEBFIC,FINFIC)
    Call COUPEFIC("_",DEBFIC,CLEFIC,FINFIC)

    If FINFIC="" : Goto TRAIT_DOC_FIL_KO2 : Endif
    LG=val(right$(FINFIC,2))
    If LG<=0 : Goto TRAIT_DOC_FIL_KO2 : Endif
    CLEFIC=mid$(FICRECH,1,LG)
    #CLEFIC=[ADB]COD+"_"+[ADB]LAN+"_"+[ADB]TYP+"_"+num$([ADB]LEV)+"_"+num$([ADB]SUBLEV)+"_"+num$([ADB]LIG)

    Call COUPEFIC("_",CLEFIC,DEBFIC,FINFIC)
    If FINFIC="" : Goto TRAIT_DOC_FIL_KO2 : Endif
    LIG=val(right$(FINFIC,2))
    CLEFIC=DEBFIC
    #
    Call COUPEFIC("_",CLEFIC,DEBFIC,FINFIC)
    If FINFIC="" : Goto TRAIT_DOC_FIL_KO2 : Endif
    SUBLEV=val(right$(FINFIC,2))
    CLEFIC=DEBFIC
    #
    Call COUPEFIC("_",CLEFIC,DEBFIC,FINFIC)
    If FINFIC="" : Goto TRAIT_DOC_FIL_KO2 : Endif
    LEV=val(right$(FINFIC,2))
    CLEFIC=DEBFIC
    #
    Call COUPEFIC("_",CLEFIC,DEBFIC,FINFIC)
    If FINFIC="" : Goto TRAIT_DOC_FIL_KO2 : Endif
    TYP=right$(FINFIC,2)
    CLEFIC=DEBFIC
    #
    Call COUPEFIC("_",CLEFIC,DEBFIC,FINFIC)
    If FINFIC="" : Goto TRAIT_DOC_FIL_KO2 : Endif
    LAN=right$(FINFIC,2)
    CLEFIC=DEBFIC
    #
    CODE_DOC=CLEFIC

    Read [ADO]ADO0=LAN;TYP;CODE_DOC;LEV;SUBLEV
    If [S]fstat
        Goto TRAIT_DOC_FIL_KO5
    Else
        #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
        If ! func AGENLIBA.TEST_GROUPE_OK("ADB", LAN, TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Goto TRAIT_DOC_FIL_KO7 : Endif
    Endif

    Openi REPDOC+SLASH+FICRECH,0 Using [BLO]
    Getseq 1,MYBLOB Using [BLO]
    If fstat<>0
        Goto TRAIT_DOC_FIL_KO3
    Endif
    Openi Using [BLO]

    Read [ADB]ADB0=LAN;TYP;CODE_DOC;LEV;SUBLEV;LIG
    If [S]fstat=0
       #JPGA 02/04/2012 BUG-530 Test pour savoir si le nom du fichier correspond au nom de la pièce jointe dans ADOCBLB
       If ! func ADOCIMP.TEST_NAME_OK(FICRECH, [ADB]NAM, LG)
          Goto TRAIT_DOC_FIL_KO4
       Endif
    Endif

    Trbegin [ADB]
    Readlock [ADB]ADB0=LAN;TYP;CODE_DOC;LEV;SUBLEV;LIG
    If [S]fstat=0
        [ADB]PICTUR=MYBLOB
        Rewrite [ADB]
        [L]WABREV="ADB"   :  Gosub WRITE_TEST_FSTAT
        If ER=0 : Call MAJ_ENVINDUS_FIL (LAN,TYP,CODE_DOC,LEV,SUBLEV,LIG) From AGENREM : Endif : # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
        ##VPO 13/12/07 BUG44457 special trad type=AD,AM,FI
        If ER=0 & find(TYP,"AD","FI","AM")<>0
            Read [ADO]ADO0="FRA";[ADB]TYP;[ADB]COD;[ADB]LEV;[ADB]SUBLEV
            If fstat
                Read [ADOI]ADO0="FRA";[ADB]TYP;[ADB]COD;[ADB]LEV;[ADB]SUBLEV
                If fstat
                    Raz [ADOI]
                Endif
            Else
                [ADOI]=[ADO]
            Endif
            Readlock [ADO]ADO0=[ADB]LAN;[ADB]TYP;[ADB]COD;[ADB]LEV;[ADB]SUBLEV
            If [S]fstat<>0 :
                WABREV="ADO"   :  WCLE=[ADB]LAN-[ADB]TYP-[ADB]COD-num$([ADB]LEV)-num$([ADB]SUBLEV)  :  Gosub READ_TEST_FSTAT
            Elsif [ADOI]VLDFLG=2
                [ADO]VLDFLG=[ADOI]VLDFLG
                [ADO]VLDDAT=[ADOI]VLDDAT
                Rewrite [ADO]
                [L]WABREV="ADO"   :  Gosub WRITE_TEST_FSTAT
                If ER=0 : Call MAJ_ENVINDUS_DOC (LAN,TYP,CODE_DOC,2) From AGENREM : Endif : # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
            Endif
        Endif
    Else
        # on ne peut pas creer les fichiers liés, il manque des infos
        WABREV="ADB"   :  WCLE=LAN-TYP-CODE_DOC-num$(LEV)-num$(SUBLEV)-num$(LIG)  :  Gosub READ_TEST_FSTAT
    Endif
    If ER
        Rollback
        Goto TRAIT_DOC_FIL_KO1
    Else
        Commit
        #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
        # Le besoin réside de tracer les DOCS traduites comme l'ENG par exemple pour pouvoir les pousser vers le REPOSITORY
        Call TRACE_GROUPE("ADO", LAN, TYP, CODE_DOC, "C") From AGENLIBA
    Endif
    Call ECR_TRACE("  "-FICRECH-":"-mess(49,176,1),0) From GESECRAN
    OKNBFICFIL+=1
    Goto TRAIT_DOC_FIL_SUITE

$TRAIT_DOC_FIL_KO1 : #mise à jour
    Call ECR_TRACE("!"-FICRECH-":"-mess(50,176,1)-"("+mess(6,123,1)-"01"+")",1) From GESECRAN
    Goto TRAIT_DOC_FIL_KO
$TRAIT_DOC_FIL_KO2 : # nom du fichier
    Call ECR_TRACE("!"-FICRECH-":"-mess(47,176,1)-"("+mess(6,123,1)-"02"+")",1) From GESECRAN
    Goto TRAIT_DOC_FIL_KO
$TRAIT_DOC_FIL_KO3 : #contenu
    Call ECR_TRACE("!"-FICRECH-":"-mess(47,176,1)-"("+mess(6,123,1)-"03"+")",1) From GESECRAN
    Goto TRAIT_DOC_FIL_KO
$TRAIT_DOC_FIL_KO4 : #contenu
    Call ECR_TRACE("!"-FICRECH-":"-func AFNC.MES2 (mess(105,176,1), FICRECH, [ADB]NAM)-"("+mess(6,123,1)-"04"+")",1) From GESECRAN
    Goto TRAIT_DOC_FIL_KO
$TRAIT_DOC_FIL_KO5 : #Enregistrement ADO inexistant !
    Call ECR_TRACE("!"-FICRECH-":"-mess(262,139,1)-"ADOCUMENT ("+mess(6,123,1)-"05"+")",1) From GESECRAN
    Goto TRAIT_DOC_FIL_KO
$TRAIT_DOC_FIL_KO7 : #Documentation non traitée : Groupe ($1$) différent de celui de l'utilisateur ($2$)
    # Le message d'erreur a déjà été affiché dans le FUNPROG. On n'en réaffiche plus d'autre !
    Call ECR_TRACE("!"-FICRECH-"("-mess(6,123,1)-"07"+")",-1) From GESECRAN
    Goto TRAIT_DOC_FIL_KO
$TRAIT_DOC_FIL_KO
    KONBFICFIL+=1
$TRAIT_DOC_FIL_SUITE
    NBFICFIL+=1
    NOXML += 1
Wend
Return

######################################################################################
Funprog TEST_NAME_OK(FICRECH, ADB_NAM, LG_CLE)
Value    Char  FICRECH()
Value    Char  ADB_NAM()
Value Integer  LG_CLE

Local Char DEBFIC(100), CLEFIC(100), FINFIC(100), EXTENSION(100), PIECE_JOINTE(100)
Local Integer RETCOD_ER    : [L]RETCOD_ER=0
Local Integer RETCOD_OK    : [L]RETCOD_OK=1

    Call COUPEFIC(".",FICRECH  , [L]DEBFIC, [L]FINFIC)  From ADOCIMP
    [L]CLEFIC      =[L]DEBFIC
    [L]EXTENSION   =[L]FINFIC
    Call COUPEFIC("_",[L]CLEFIC, [L]DEBFIC ,[L]FINFIC)  From ADOCIMP
    [L]PIECE_JOINTE=right$([L]DEBFIC, LG_CLE + 2)+[L]EXTENSION

   # Test pour savoir si le nom du fichier correspond au nom de la pièce jointe dans ADOCBLB
   If ADB_NAM <> [L]PIECE_JOINTE
      End [L]RETCOD_ER
   Endif
End [L]RETCOD_OK

######################################################################################
Subprog COUPEFIC(CAR,FICHIER,DEBFIC,FINFIC)
Value    Char    CAR()
Value    Char    FICHIER()
Variable Char    DEBFIC()
Variable Char    FINFIC()

Raz DEBFIC,FINFIC
If FICHIER="" : End : Endif

Local Integer J
Local Char    CHAINE(250)

J=len(FICHIER)
While J>0
 CHAINE = mid$(FICHIER,J,1)
 If CHAINE=CAR
    DEBFIC=left$(FICHIER,J-1)
    FINFIC=right$(FICHIER,J)
    Break
 Endif
 J-=1
Wend
If J=0 : DEBFIC=FICHIER : Endif
End


######################################################################################
# Gestion du masque ADOCIMP
######################################################################################

Subprog C_REPERT(VALEUR)
Variable Char VALEUR()
Local Integer ER : ER=0
Local Char    REPFIC(GDIMFIC) , FICHIER(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(10)
Local Integer MODE_REP

If VALEUR=""
 GMESSAGE = mess(09,141,1) : # Repertoire inexistant
 mkstat = 1 : End
Elsif left$(VALEUR,1)="#" & (GBROWS | GSERVEUR )
 GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
 mkstat = 2 : End
Endif

FICHIER = VALEUR

II=instr(1,FICHIER ,"%")
If II
 FICHIER =left$(FICHIER ,II-1)+[M:DIA]LAN+right$(FICHIER ,II+1)
Endif

# JPGA-EXI-85524-28 02/04/2014 : Pour la V7 et +, Implémentation de l'utilisation de VOLUME dans les nom de répertoires.
FICHIER=func AGENLIBA.REMPLACE_VOLUME (FICHIER)

Call MACHINE(FICHIER,MACHINE,REPFIC) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS=""
 GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
 mkstat = 2 : End
Endif

Call EXISTE(FICHIER,ER) From ORDSYS
If ER=0
 GMESSAGE = "|"+REPFIC-":"-mess(09,141,1) : # Repertoire inexistant
 mkstat = 2 : End
Elsif ER=1
 GMESSAGE = "|"+REPFIC-":"-mess(09,141,1) : # Repertoire inexistant
 mkstat = 2 : End
Endif
VALEUR = FICHIER

End

######################################################################################
