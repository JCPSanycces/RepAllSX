#<AdxTL>@(#)0.0.0.0 $Revision$
# Cancel
Local Integer OKCAN : OKCAN = 1

# Open trace file with title
Call OUVRE_TRACE("My First trace file.") From LECFIC

# Information message
Call ECR_TRACE("Information: My first text message.", 0) From GESECRAN
Call AVERTIR("Information: My first text message.", OKCAN) From GESECRAN

# Error message
Call ECR_TRACE("Error: My first error message.", 0) From GESECRAN
Call AVERTIR("Error: My first error message.", OKCAN) From GESECRAN

# Warning message
Call ECR_TRACE("Warning: My first warning message.", 0) From GESECRAN
Call AVERTIR("Warning: My first warning message.", OKCAN) From GESECRAN

# Close trace file
Call FERME_TRACE From LECFIC

# Trace view screen opens. User has several choices
Call LEC_TRACE From LECFIC

