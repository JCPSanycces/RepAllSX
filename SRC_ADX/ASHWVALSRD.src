#<AdxTL>@(#)0.0.0.0 $Revision$
$TEST
Call ALL_VALIDATION(0,nomap,1,GBIDI1)
End

#################################################

Subprog ALL_VALIDATION(TEST,DOSSIER,SILENCE,OK)
Value    Integer TEST
Value    Char     DOSSIER
Value    Integer  SILENCE
Variable Integer OK
Local Integer I

Local Instance AERR(1..)  Using C_AERROR
Local Char CODREP(GLONASW)

If TEST
 # Validation représentation - Dossier XXX
 Call OUVRE_TRACE(mess(48,140,1)-"-"-mess(3,23,1)-[L]DOSSIER) From LECFIC
Endif

If !SILENCE
 Call TEMPON(mess(48,140,1)-"-"-mess(3,23,1)-[L]DOSSIER) From GESECRAN
Endif
If GTRACE<>""
 Call ECR_TIME(mess(48,140,1)-"-"-mess(3,23,1)-[L]DOSSIER) From DOSSUB
Endif

Gosub DEFVAR

Gosub OPEN_FILE

For [F:ASW_]
 [L]CODREP = [F:ASW_]CODREP
 Gosub GENTRT
 If maxtab(AERR)>0 : Break : Endif
Next

Close Local File

If maxtab(AERR)>0
 Goto PERDU
Endif


Goto FIN

#----------------------------------------------#
$FIN
If !SILENCE
 Call TEMPOFF From GESECRAN
Endif
If TEST
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

#--------------#
$PERDU
OK=0
Goto FIN

#--------------#
$ERREUR
Call ECR_TRACE(errp-mess(93,100,1)-num$(errl)+"\"+errmes$(errn)-"("+num$(errn)+")|"-errm,1) From GESECRAN
Resume

#--------------#

$OPEN_FILE
If [L]DOSSIER<>""
 Local File =[L]DOSSIER+".ACLAFLD"      [ACLAF]
 Local File =[L]DOSSIER+".ASHW"           [ASW]
 Local File =[L]DOSSIER+".ASHW"           [ASW_]
 Local File =[L]DOSSIER+".ACLASSE"       [ACLA]
 Local File =[L]DOSSIER+".ACLACOL"       [ACLAC]
 Local File =[L]DOSSIER+".ASHWEXPPRO"  [ASWR]
 Local File =[L]DOSSIER+".ACLALNK"    [ACLAK]
 Local File =[L]DOSSIER+".ASHWFLD"     [ASWF]
 Local File =[L]DOSSIER+".AFONCTION"     [AFC]
 Local File =[L]DOSSIER+".AROLE"     [ARL]
 Local File =[L]DOSSIER+".AOBJET"     [AOB]
Else
 Local File ACLAFLD         [ACLAF]
 Local File ASHW            [ASW]
 Local File ASHW            [ASW_]
 Local File ACLASSE         [ACLA]
 Local File ACLACOL         [ACLAC]
 Local File ASHWEXPPRO  [ASWR]
 Local File ACLALNK    [ACLAK]
 Local File ASHWFLD     [ASWF]
 Local File AFONCTION     [AFC]
 Local File AROLE     [ARL]
 Local File AOBJET     [AOB]
Endif

If [L]DOSSIER<>""
 Local File =[L]DOSSIER+".ACONTEXT"     [ACTX2]
Else
 Local File ACONTEXT       [ACTX2]
Endif

If filinfo(filpath("FIL","AVIEWTAB","fde",DOSSIER),0)<0
& or filinfo(filpath("FIL","AVIEWFLD","fde",DOSSIER),0)<0
& or filinfo(filpath("FIL","AVIEWIND","fde",DOSSIER),0)<0
 Local File =DOSSIER+".ATABLE" [ATB]
 Local File =DOSSIER+".ATABZON" [ATZ]
 Local File =DOSSIER+".ATABIND" [ATI]
Else
 Local File =DOSSIER+".AVIEWTAB" [ATB]
 Local File =DOSSIER+".AVIEWFLD" [ATZ]
 Local File =DOSSIER+".AVIEWIND" [ATI]
Endif

Return

$DEFVAR
Local Char    TABCLA(80)(1..50),TABPTR(80)(1..50),PRO(50),CLA(80),WCODPRO(GLONAVC),CLAREF(GLONACLA),ABRREF(GLONABR)
Local Integer NBCLA,ISACTX

Local Char    TAB_ALIAS(GLONAVB)(1..),TAB_ABR(GLONAVB)(1..),TAB_PRO(GLONAVB)(1..)
Local Integer TAB_NB

Local Char    MACHINE(GDIMFIC) , APPLI(GLONADS),LIGNE(250)

Local Char    NOMTRTSRD(250),MAGIC(80),IDENTTRT(250),IDENTSRD(250),TITETA(250)
Local Clbfile    CLOB(9)
Local Integer   DIF,OK

Local Char    TAB_ROLFLD(GLONAVB)(1..)
Local Integer NB_ROLFLD

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS
Return

#--------------#

Subprog TRT_WMSRD(TEST,DOSSIER,CODREP,AERR)
Value Integer TEST
Value Char DOSSIER,CODREP
Variable  Instance  AERR(1..) Using C_AERROR

Gosub DEFVAR

Gosub OPEN_FILE

Gosub GENTRT

Close Local File

End

#-------------------------------------------------------#
$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

#-------------------------------------------------------#
$GENTRT
If TEST
 Call ECR_TRACE(mess(14,140,1)-CODREP,0) From GESECRAN
Endif
Read [F:ASW]ASW0 = CODREP
If fstat : Return : Endif

Read [F:ACLA]ACLA0 = [F:ASW]CODCLA
If fstat : Return : Endif
If [F:ACLA]TYPCLA<>2 : Return : Endif

Read [ATB]CODFIC = [F:ACLA]TABREF
If fstat : Return : Endif

CLAREF = [F:ACLA]CODCLA
ABRREF = [F:ATB]ABRFIC

Raz CLOB,DIF,LIGNE,TAB_NB,NB_ROLFLD

If [F:ASW]AFCRIGHT<>""
 Read [AFC]CODINT=[F:ASW]AFCRIGHT
 If !fstat &  [AFC]ACTION="GOBJET"
  Read [AOB]ABREV = vireblc(ctrans([AFC]VALPAR(0),'"'+"'","  "),3)
  If !fstat
   For [ARL]ARL0 Where OBJ = [F:AOB]ABREV
    NB_ROLFLD += 1
    TAB_ROLFLD(NB_ROLFLD) = [F:ARL]FLD
   Next
  Endif
 Endif
Endif

For [ASWR]ASWR0 Where CODREP=[L]CODREP
 WCODPRO=[F:ASWR]CODPRO
 Call DECODE_PRO(WCODPRO,0,"PRO",[L]DOSSIER,[F:ASWR]CODREP,[F:ASW]ABRCLA,[F:ASW]CODCLA,TABPTR,TABCLA,PRO,ISACTX,NBCLA) From SUBASW
 If NBCLA>0
  CLA=TABCLA(NBCLA)
  Read  [F:ACLA]ACLA0 = CLA
  If !fstat & [F:ACLA]FLGSEARCH=2
   Read [F:ACLAF]ACLAF0 = CLA;PRO
   If !fstat & ([F:ACLAF]FLDSEARCH=2 or find([F:ACLAF]FLDCLA,TAB_ROLFLD)>0)
    If TABPTR(NBCLA)<>""
     Read [F:ACLAK]ACLAK0 = CLAREF;TABPTR(NBCLA)
     If !fstat
      TAB_NB += 1
      TAB_ALIAS(TAB_NB) = [ASWR]ALIAS
      TAB_PRO(TAB_NB)    = PRO
      TAB_ABR(TAB_NB)    = [F:ACLAK]ABRLNK
     Endif
    Else
     TAB_NB += 1
     TAB_ALIAS(TAB_NB) = [ASWR]ALIAS
     TAB_PRO(TAB_NB)    = PRO
     TAB_ABR(TAB_NB)    = ABRREF
    Endif
   Endif
  Endif
 Endif
Next

Raz CLOB,DIF,LIGNE

LIGNE = "$SEARCH_DECODE_CRITERIA" : Gosub ADDCLB
LIGNE = "Local Integer NBPRO : NBPRO=0" : Gosub ADDCLB
LIGNE = "Local Char T0(30)(1..)" : Gosub ADDCLB
LIGNE = "Local Char T1(30)(1..)" : Gosub ADDCLB

For I=1 To TAB_NB
 LIGNE = 'NBPRO += 1 : T1(NBPRO) = "'+TAB_ALIAS(I)+'" : T0(NBPRO) = "[F:'+TAB_ABR(I)+']'+TAB_PRO(I)+'"'
 If TEST
  Call ECR_TRACE("  "+LIGNE,0) From GESECRAN
 Endif
 Gosub ADDCLB
Next

LIGNE = 'NBPRO += 1  : T1(NBPRO) = "false" : T0(NBPRO) = "[V]CST_ANO"'  :  Gosub ADDCLB
LIGNE = 'NBPRO += 1  : T1(NBPRO) = "true" : T0(NBPRO) = "[V]CST_AYES" '  : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB

NOMTRTSRD   = func APREFIXTRT.GET_PREFIX_SRD+ CODREP
MAGIC           = mess(77,133,1) : # Superviseur Adonix
IDENTTRT      = "#"+NOMTRTSRD
IDENTSRD      = "##"-"?IDENTQRY?"-"SEARCH ##"
TITETA          = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"

Call STC_DEB([L]APPLI,[L]MACHINE,[L]NOMTRTSRD,[L]IDENTTRT,[L]CODREP,IDENTSRD,[L]MAGIC,[L]TITETA,"TRT") From ACLASUB
Call TRT_FIN([L]CLOB,[L]NOMTRTSRD,0,[L]DOSSIER,"TRT",OK,AERR) From ACLASUB

Return
