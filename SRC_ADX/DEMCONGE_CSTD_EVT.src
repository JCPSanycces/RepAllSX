#FRLAA - 2018-03-01 - X3-80678 - START
Funprog SETTCHCPY(VSITE)
Value Char VSITE
Local Char RETCPY(GLONCPY)
Local File FACILITY [FCY6]
Read [FCY6]FCY0=VSITE
If fstat = [V]CST_AOK
  RETCPY = [F:FCY6]LEGCPY
Endif
End RETCPY
