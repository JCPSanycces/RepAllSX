$AINSERT_CONTROL_AFTER
#FRLAA - 2018-03-01 - X3-80678 - START
Local Char SERRMESSAGE(250)
Local Char SEQCODE(GLONVCR)
Local Char COMPTEUR(GLONANM)
Local Integer SEQ_ISMANUAL

If func AFNC.ACTIV("GLM")
  If this.LVESEQ = AVOID.ACHAR
    If func TCA_TOOL.LECTCA(this.ACTX, 15, this.TCH_CPY, this.TCH_LEG, 26, COMPTEUR, SEQ_ISMANUAL, SERRMESSAGE)=[V]CST_ATRUE
      If COMPTEUR = AVOID.ACHAR
        ASTATUS=fmet this.ASETERROR("",mess(4,10702,1)-COMPTEUR,[V]CST_AERROR)
      Else
        If func ANM_TOOL.NUMERO(this.ACTX,COMPTEUR,this.TCH_FCY,datesyst,"",SEQCODE,SERRMESSAGE) = [V]CST_AERROR
          ASTATUS=fmet this.ASETERROR("",mess(4,10702,1)-COMPTEUR,[V]CST_AERROR)
        Else
          this.LVESEQ = SEQCODE
        Endif
      Endif
    Else
      ASTATUS=fmet this.ASETERROR("",mess(4,10702,1)-COMPTEUR,[V]CST_AERROR)
    Endif
  Endif
Endif
#FRLAA - 2018-03-01 - X3-80678 - END


Return


