#############################################################################################################
$ATTACHMENTS
Local Integer STAT
Local Integer I : I = 1

If this.ESSATT <> null

  Local Integer WRITESTAT, READSTAT, COLIND, I
  Local Integer INITSTAT
  Local Char CNTTYP(GLONATYP)
  Local Char FNAM(250) : FNAM = "DCG~"+this.REFNUM+"~"+num$(this.DEM)

  #Set default values for variables
  WRITESTAT = [V]CST_AOK
  READSTAT  = [V]CST_AOK

  #Loop through ESSATT collection
  #Check for existing record
  For COLIND = 1 To maxtab(this.ESSATT)
    If find(this.ESSATT(COLIND).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0

      Gosub CHECK_ATTACHMENT_SETUP

      #Instantiate the class
      Local Instance I_HRESSATT Using C_HRESSATT
      If (I_HRESSATT <> null) : FreeGroup I_HRESSATT : Endif
      I_HRESSATT = NewInstance C_HRESSATT AllocGroup null

      INITSTAT = fmet I_HRESSATT.AINIT()

      this.ESSATT(COLIND).ABREV = "EML"
      this.ESSATT(COLIND).NAM = FNAM + "_" +  format$("N0:3",COLIND)
      this.ESSATT(COLIND).IDENT1 = FNAM
      this.ESSATT(COLIND).IDENT2 = num$(this.UID)
      this.ESSATT(COLIND).IDENT3 = format$("N0:3",COLIND)

      READSTAT = fmet I_HRESSATT.AREAD(this.ESSATT(COLIND).ABREV,this.ESSATT(COLIND).IDENT1,this.ESSATT(COLIND).IDENT2,this.ESSATT(COLIND).IDENT3)
      #Load values = READSTAT will only be used to determine the method to invoke    If READSTAT = [V]CST_AOK
      #Load the fields and save the class/record
      I_HRESSATT.ABREV = this.ESSATT(COLIND).ABREV
      I_HRESSATT.IDENT1 = this.ESSATT(COLIND).IDENT1
      I_HRESSATT.IDENT2 = this.ESSATT(COLIND).IDENT2
      I_HRESSATT.IDENT3 = this.ESSATT(COLIND).IDENT3
      I_HRESSATT.TCH_ATT = this.ESSATT(COLIND).TCH_ATT
      I_HRESSATT.NAM = this.ESSATT(COLIND).NAM

      If READSTAT = [V]CST_AOK
        #Existing record
        #Invoke the update method
        WRITESTAT = fmet I_HRESSATT.AUPDATE
      Else
        #Invoke the insert method
        WRITESTAT = fmet I_HRESSATT.AINSERT
      Endif

      Local File ABLOB [ABB1]
      Read [ABB1]ABB0 =this.ESSATT(COLIND).ABREV;this.ESSATT(COLIND).IDENT1;this.ESSATT(COLIND).IDENT2;this.ESSATT(COLIND).IDENT3
      If fstat = [V]CST_AOK
        CNTTYP = [F:ABB1]CNTTYP
      Endif
      LogicClose File [ABB1]

      Local Char VID1(250)
      Local Char VID2(250)
      Local Char VID3(250)

      VID1 = this.ESSATT(COLIND).IDENT1
      VID2 = this.ESSATT(COLIND).IDENT2
      VID3 = this.ESSATT(COLIND).IDENT3

      Call SETPORATT("DCG", "EML", VID1, this.ESSATT(COLIND).TCH_ATT, VID1, VID2, VID3, CNTTYP, STAT) From PRHPORATT_SOA

      FreeGroup I_HRESSATT

    Endif

    #Call code to get CNTTYP

  Next I

Endif

#$GET_CNTTYP
#
#  #Success - Get the content type
#  Local File ABLOB [ABB1]
#  Read [ABB1]ABB0 =this.ESSATT(COLIND).ABREV;this.ESSATT(COLIND).IDENT1;this.ESSATT(COLIND).IDENT2;this.ESSATT(COLIND).IDENT3
#  If fstat = [V]CST_AOK
#    CNTTYP = [F:ABB1]CNTTYP
#  Endif
#  LogicClose File [ABB1]
#Return

Return
#############################################################################################################
Subprog SYNCATT(ABREV, NAM, TCH_ATT, IDENT1, IDENT2, IDENT3)

If ABREV <> AVOID.ACHAR
  Local Integer WRITESTAT, READSTAT, ASTATUS
  Local Integer INITSTAT

  #Set default values for variables
  WRITESTAT = [V]CST_AOK
  READSTAT  = [V]CST_AOK

  #Instantiate the class
  Local Instance I_HRESSATT Using C_HRESSATT
  If (I_HRESSATT <> null) : FreeGroup I_HRESSATT : Endif
  I_HRESSATT = NewInstance C_HRESSATT AllocGroup null

  INITSTAT = fmet I_HRESSATT.AINIT()

  READSTAT = fmet I_HRESSATT.AREAD(ABREV, IDENT1, IDENT2, IDENT3)
  #Load values = READSTAT will only be used to determine the method to invoke    If READSTAT = [V]CST_AOK
  #Load the fields and save the class/record
  I_HRESSATT.ABREV = ABREV
  I_HRESSATT.IDENT1 =  IDENT1
  I_HRESSATT.IDENT2 =  IDENT2
  I_HRESSATT.IDENT3 =  IDENT3
  I_HRESSATT.TCH_ATT =  TCH_ATT
  I_HRESSATT.NAM =  NAM

  If READSTAT = [V]CST_AOK
    #Existing record
    #Invoke the update method
    WRITESTAT = fmet I_HRESSATT.AUPDATE
  Else
    #Invoke the insert method
    WRITESTAT = fmet I_HRESSATT.AINSERT
  Endif

Endif

End
