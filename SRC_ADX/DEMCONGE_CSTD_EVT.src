  #Folder level parameter PORATTDCG for leave attachment not setup (Chapter: TC > Group: INT)
  ASTATUS = fmet this.ASETERROR("",mess(183,10720,1),[V]CST_AERROR)
Endif

Return


$WORKFLOW_SIGN_GLM
Gosub WORKFLOW_UPDATE_STAT_GLM
Gosub EXEC_WORKFLOW_GLM
Return

$WORKFLOW_UPDATE_STAT_GLM
Local Integer TYPEVT,STAT
Local Char    CODE(20)
Local Char    MESSAGE(250),FILTRE(250)
Local Integer REQUEST

#Check the parameter to determine the workflow code
CODE = "UPDGLMWRK"
FILTRE = "[F:DCG]REFNUM = '"+num$(this.REFNUM)+"' and [F:DCG]UID = " + num$(this.UID)
SIMUL = 1
Return

$EXEC_WORKFLOW_GLM

STAT =  func ASYRWRKCLASSIC.WORKMANUAL(this.ACTX,CODE,FILTRE,SIMUL,REQUEST,MESSAGE)
If STAT = [V]CST_AOK
  #ASTATUS=fmet this.ASETERROR("",MESSAGE,[V]CST_AINFO)
Else
  ASTATUS=fmet this.ASETERROR("",MESSAGE,[V]CST_AERROR)
Endif

Return



