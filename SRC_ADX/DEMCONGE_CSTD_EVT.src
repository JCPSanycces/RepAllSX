$REFRESHLVESUBNNR
If this.SUBTYP = null : Return : Endif

Local Integer LP,M,DR
Local Integer PRAT,NBRATETYP
Local File HRLVESUBHEA [HRLSTH]
Local File DEMCONGE [DCG1]
Local File ATEXTRA [AXX1]

Read [DCG1]DCG2 = this.UID

For LP=1 To maxtab(this.SUBTYP)
  Filter [HRLSTH] Where COD=this.SUBTYP(LP).LVESUBTYP and LEG = this.TCH_LEG
  Read [HRLSTH] First
  Filter [HRLSTH]
  If this.SUBTYP(LP).LVESUBTYP <> AVOID.ACHAR
    #Call LECTEXTRA([M:DCG1]DES(LINENUM),"HRLVESUBHEA","DES",GCURLEG,[DCG]LVESUBTYP(LP-1)) From ATEXTRA
    this.SUBTYP(LP).TCH_SUBTYP = this.SUBTYP(LP).LVESUBTYP
    this.SUBTYP(LP).TCH_SUBBAL = this.SUBTYP(LP).LVESUBBAL
    If [F:DCG1]NBRDAY > 0
      If this.SUBTYP(LP).LVESUBBAL <> 0
        this.SUBTYP(LP).TCH_NBRHOU  = (this.SUBTYP(LP).LVESUBBAL/[F:DCG1]NBRDAY)*[F:DCG1]NBRHOU
      Endif
    Endif
    For RT = 0 To dim([F:HRLSTH]LVEPAYDES)-1
      If [F:HRLSTH]LVEPAYDES(RT)=AVOID.ACHAR : Break : Endif
        NBRATETYP+=1
     Next
    If this.SUBTYP(LP).TCH_SUBBAL > 0
      If this.SUBTYP(LP).LVESUBRAT > 0 and this.SUBTYP(LP).LVESUBRAT <> 99
        this.SUBTYP(LP).LVERATDES = [F:HRLSTH]LVEPAYDES(this.SUBTYP(LP).LVESUBRAT-1)
      Endif
    Endif
    Read [AXX1]AXX0 = "HRLVESUBHEA";"DES";this.ACTX.LAN;this.TCH_LEG;this.SUBTYP(LP).LVESUBTYP
    If fstat = [V]CST_AOK

      this.SUBTYP(LP).TCH_TYPDES = [F:AXX1]TEXTE
    Endif
Else
  Endif
Next

LogicClose File [HRLSTH]
LogicClose File [DCG1]
LogicClose File [AXX1]
Return

$POPULATE_MSG
#Check if the local menu fields have been populated before updating
If this.MSGAML and this.MSGAMLNUM <>0
  #Set the message
  this.SYSMSG = func SUBDCGGLM.POP_DCGGLM_INFOMSG(this.MSGAML, this.MSGAMLNUM, this.STRDAT, this.ENDDAT)
Endif
Return


############################################################################################################
$LOAD_ATTACHMENTS

  Local File HRESSATT [ATT]
  Local File AOBJTXT [ATTOBJ]
  Local File ABLOB [ABLB]
  Local File ACLOB [ACLB]

  Local Integer INDX
  Local Blbfile ATTACHMENT(GLONABB)

  Filter [F:ATT] Where IDENT2 = num$(this.LNK)

  For [ATT]
    Filter [F:ATTOBJ] Where IDENT1 = [ATT]IDENT1 and IDENT2 = [ATT]IDENT2 and IDENT3 = [ATT]IDENT3
    Read [ATTOBJ] First

    If fstat > 0
      Delete [ATT]
    Endif
  Next

  Filter [F:ATTOBJ] Where IDENT2 = num$(this.LNK)
  INDX = 1

  For [ATTOBJ]
    L = fmet this.ADDLINE("ESSATT",INDX)

    this.ESSATT(L).ABREV = [ATTOBJ]ABREV
    this.ESSATT(L).IDENT2 = [ATTOBJ]IDENT2
    this.ESSATT(L).IDENT3 = [ATTOBJ]IDENT3

    Filter [F:ATT] Where IDENT1 = [ATTOBJ]IDENT1 and IDENT2 = [ATTOBJ]IDENT2 and IDENT3 = [ATTOBJ]IDENT3
    Read [ATT] First

    If fstat > 0

      If [ATTOBJ]TYPDOC = "DOC"
        Local Char VPATH(255)
        Local Integer DASHPOS : DASHPOS = instr(1,[ATTOBJ]NAM,"/")
        Local Integer EXTPOS  : EXTPOS  = instr(1,[ATTOBJ]NAM,".")
        Local Char FIC_EXT(30)

        If DASHPOS
          VPATH = right$([ATTOBJ]NAM,DASHPOS+1)
          If EXTPOS
            VPATH = left$(VPATH,instr(1,VPATH,".")-1)
          Endif
        Else
          VPATH = [ATTOBJ]NAM
        Endif

        If EXTPOS
          FIC_EXT = right$([ATTOBJ]NAM,EXTPOS+1)
        Endif

        Openi filpath("ATT",VPATH,FIC_EXT) Using [SOA]

        Getseq GLONABB, ATTACHMENT Using [SOA]

        Openi Using [SOA]

        If ATTACHMENT <> AVOID.ABLOB
          this.ESSATT(L).NAM = VPATH
          this.ESSATT(L).IDENT1 = [ATTOBJ]IDENT1

          Call SYNCATT([ATTOBJ]ABREV, VPATH, ATTACHMENT, [ATTOBJ]IDENT1, [ATTOBJ]IDENT2, [ATTOBJ]IDENT3) From DEMCONGE_CSTD_EVT
        Else
          this.ESSATT(L).NAM = [ATTOBJ]NAM
          this.ESSATT(L).IDENT1 = [ATTOBJ]IDENT1
        Endif
      Elsif [ATTOBJ]TYPDOC = "RTF"
        Filter [F:ACLB] Where IDENT1 = [ATTOBJ]IDENT1 and IDENT2 = [ATTOBJ]IDENT2 and IDENT3 = [ATTOBJ]IDENT3
        Read [ACLB] First

        If fstat = 0
          Local Char FILENAM(255) : FILENAM = [ATTOBJ]IDENT1 + "_" + [ATTOBJ]IDENT2 + "_" + [ATTOBJ]IDENT3
          Local Char NEWVOLUME(255) : NEWVOLUME = "ATT"
          Local Char DIRVOLA(250)
          Local Char TEXT (250)(1..)

          Setlob TEXT With [ACLB]CLOB

          DIRVOLA = func AVOLUME_CSTD._GETFULLPATH(num$(NEWVOLUME),"")

          Openo DIRVOLA + FILENAM,0 Using [FDATA]
          Wrseq TEXT Using [FDATA]
          Openo Using [FDATA]

          Openi filpath("ATT",FILENAM,"") Using [SOA]
          Getseq GLONABB, ATTACHMENT Using [SOA]
          Openi Using [SOA]

          If ATTACHMENT <> AVOID.ABLOB
            this.ESSATT(L).NAM = [ATTOBJ]NAM
            this.ESSATT(L).IDENT1 = [ATTOBJ]IDENT1
            Call SYNCATT([ATTOBJ]ABREV, [ATTOBJ]NAM, ATTACHMENT, [ATTOBJ]IDENT1, [ATTOBJ]IDENT2, [ATTOBJ]IDENT3) From DEMCONGE_CSTD_EVT
          Else
            this.ESSATT(L).NAM = [ATTOBJ]NAM
            this.ESSATT(L).IDENT1 = [ATTOBJ]IDENT1
          Endif
        Else
          this.ESSATT(L).NAM = [ATTOBJ]NAM
          this.ESSATT(L).IDENT1 = [ATTOBJ]IDENT1
        Endif
      Else
        Filter [F:ABLB] Where IDENT1 = [ATTOBJ]IDENT1 and IDENT2 = [ATTOBJ]IDENT2 and IDENT3 = [ATTOBJ]IDENT3
        Read [ABLB] First

        If fstat = 0
          this.ESSATT(L).NAM = [ATTOBJ]NAM
          this.ESSATT(L).IDENT1 = [ATTOBJ]IDENT1
          Call SYNCATT([ATTOBJ]ABREV, [ATTOBJ]NAM, [ABLB]BLOB, [ATTOBJ]IDENT1, [ATTOBJ]IDENT2, [ATTOBJ]IDENT3) From DEMCONGE_CSTD_EVT
        Else
          this.ESSATT(L).NAM = [ATTOBJ]NAM
          this.ESSATT(L).IDENT1 = [ATTOBJ]IDENT1
        Endif
      Endif

    Else
      this.ESSATT(L).NAM = [ATTOBJ]NAM
      this.ESSATT(L).IDENT1 = [ATTOBJ]IDENT1
    Endif

    INDX = INDX + 1

    Filter [F:ATT]
  Next

  Filter [F:ATTOBJ]

  LogicClose File [ACLB]
  LogicClose File [ABLB]
  LogicClose File [ATTOBJ]
  LogicClose File [ATT]

Return

