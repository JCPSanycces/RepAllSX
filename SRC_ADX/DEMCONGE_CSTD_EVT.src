$MODIF

Local Libelle DEFILE, CHODAT   # we are not use these in the SOA code (has to do with buttons/menus)

#If clalev([M:DCG1])> 0     : # 62623
 #Local Integer UPD2(dim([M:DCG1]UPDNUM)), UID2(dim([M:DCG1]UID))
#Endif
# We are only dealing with one line at a time
Local Integer UPD2, UID2
Local Integer NODEM, CHRONO, ITER, R1, R2
Local Char    SYMBOLE2(50), CRITERE2(250)(2), FILTRE2(250), LESITE(GLONFCY)
Local Date    DATDEB, DATFIN
Local Date    OLDDATDEMI
Local Integer OLDYEA
Local Char    OLDFCY(GLONFCY)

# For SOA - SOA_GWEBSERV will always return 0
Local Integer SOA_GWEBSERV  : Call GWEBSERV(SOA_GWEBSERV) From ESSGLOB_SOA
Local Integer SOA_GTPS      : Call GTPS(SOA_GTPS) From ESSGLOB_SOA
Local Integer SOA_GOK       : SOA_GOK = 1
Local Char SOA_GMESSAGE(250)
Local Char SOA_GUSER(GLONAUS) : SOA_GUSER = this.ACTX.USER

If SOA_GTPS=1
  Local File TIMREGUL [TIG]
  R1 = 2 : R2 = 0 : # R1=Indice de PERIOD et R2=Nb jours d횄짤calage
  Local File TIMREGUL [TIG1]
Else
  Local File TIMEMP   [TIG]
  R1 = 0 : R2 = 20 : # R1=Indice de PERIOD et R2=Nb jours d횄짤calage
Endif
Local File TIMCOD  [TIM2]
Local File TIMEMP  [TIP1]
Local File PERIOD  [PEO1]
Local File PERIOD  [PEO2]

Local File DEMCONGE[DCG]
