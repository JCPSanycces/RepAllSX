$GLOCK_RSTA

SOA_GOK=0
Local Integer BLOQ
Local Char ERRMES(250)
BLOQ = 1  # this is an error - transaction stopped - check ASYRREQ_CSTD for example
Call RSTA("DCG",this.REFNUM-'WRK=""',BLOQ,ERRMES) From GLOCK_SYRA   #could just display own error - leave for now
#Rollback  # do we need to rollback?
ASTATUS=fmet this.ASETERROR("",ERRMES,[V]CST_AERROR)

Return
#------------------------------
$GLOCK_FSTA

SOA_GOK=0
Local Integer BLOQ
Local Char  ERRMES(250)
BLOQ = 1 # this is an error - transaction stopped
Call FSTA(SOA_ABR,BLOQ,ERRMES) From GLOCK_SYRA         #could just display own error - leave for now
ASTATUS=fmet this.ASETERROR("",ERRMES,[V]CST_AERROR)

Return
