Return

#FRLAA 2018-02-20 X3-74480 - START
$UPDATE_GLM

#Check activity code GLM
If func AFNC.ACTIV("GLM")=0 : Return : Endif

#Delete future accruals
#PEVAN - 2018-07-30 - X3-90320 - START
#Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]STRDAT, [F:DCG]TIM, IS_SOA, SOALEG) From SUBDCGGLM
Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]CTRDAT, [F:DCG]STRDAT, [F:DCG]TIM, IS_SOA, SOALEG) From SUBDCGGLM
#PEVAN - 2018-07-30 - X3-90320 - END

#Split the current transaction - This filter will only be used for requested records - STA=2
#Assign the split filter(s)
Gosub ASSIGN_SPLITFILTER_SPLIT_THIS_TRANSACTION From SUBDCGGLM

If [F:DCG]UID<>99999999
  Call RESET_FUTURE_SPLITS_PROG(SOA_GOK,SOALEG,4,UIDS_TO_INCLUDE,UIDS_COUNT) From SUBDCGGLM
   If SOA_GOK = 1
    #Handle error - stop transaction
    SOA_ERRMESSAGE = mess(00034,11691,1)
    Gosub SET_RETURN_MSG
    Return #Don't allow additional processing
   Endif
Endif

Call SPLIT_TRANSACTIONS_PROG(SOA_GOK,SOALEG,IS_SOA,CLASS_REFNUM,SPLITFILTER1,SPLITFILTER2,SOA_ERRMESSAGE,[0/0/0]) From SUBDCGGLM
#Gosub SPLIT_TRANSACTIONS
If SOA_GOK <> 0
  Gosub SET_RETURN_MSG
  If SOA_GOK = 1
    #stop processing
    Return
  Endif
Endif

#Resplit any possible future transactions - transaction already cleared
Call RESPLIT_TRANSACTIONS_PROG(SOA_GOK,SOALEG,IS_SOA,this.REFNUM,SOA_ERRMESSAGE,[0/0/0]) From SUBDCGGLM
If SOA_GOK <> 0
  Gosub SET_RETURN_MSG
    If SOA_GOK = 1
      #stop processing
      Return
    Endif
Endif

If SOA_GOK = 0
  #Set new UID to the class
  #Update [F:DCG] Where UID = this.UID With MSGAML      = L_AML
  #Update [F:DCG] Where UID = this.UID With MSGAMLNUM   = L_AMLMSG
  #Fstat will not be tested, messages only - not critical enough to rollback
Endif
Return

$SET_RETURN_MSG
If SOA_GOK = 1
  #Handle error - stop transaction
  ASTATUS = fmet this.ASETERROR("",SOA_ERRMESSAGE,[V]CST_AERROR)
Else
  If SOA_GOK <> 0
   #Test the SOA_GOK number and set the local menu variables
   L_AML = 11691 # Local menu used for all GLM messages - This can be extended in the future to pass the LM back from the function
   L_AMLMSG = SOA_GOK # Local menu number to be saved as standard for all transactions #Request validated
   #Reset SOA_GOK to 0
   SOA_GOK = 0
  Endif
Endif
Return


$DECLARE_SOA_GLM_VARIABLES
Local Integer IS_SOA
Local Integer SOA_GOK
Local Char SOALEG (GLONADI)
Local Integer VGOK # Variable set for GOK that will be used for both V6 and SOA code
Local Char CLASS_REFNUM(GLONEML)
Local Char SOA_ERRMESSAGE(250)
Local Integer UIDS_TO_INCLUDE(20)(1..)
Local Integer UIDS_COUNT : UIDS_COUNT=1
Local Char VSYSMSG(250)
Local Integer ORG_UID, L_AMLMSG, L_AML

L_AML = 11691 # Local menu used for all GLM messages
L_AMLMSG = 32 # Local menu number to be saved as standard for all transactions #Request validated

IS_SOA = [V]CST_AYES
CLASS_REFNUM  = [F:DCG]REFNUM
ORG_UID       = [F:DCG]UID
Local File EMPLOCTR [HRCTR]

#Get legislation from contract
Local File EMPLOCTR [HRCTR3]

Filter [F:HRCTR3] Where REFNUM = [F:DCG]REFNUM and CTRNUM = [F:DCG]CTRNUM #GESDCG does not save CTRDAT yet, only need LEG here
Read [F:HRCTR3] First
Filter [F:HRCTR3]
If fstat = [V]CST_AOK
  SOALEG = func DIVPAYE_SOA.GET_LEG_CTR([F:HRCTR3]REFNUM,[F:HRCTR3]CTRNUM,[F:HRCTR3]CTRDAT,1)
Else
  #AERROR
  #TODO:
Endif
Return
#FRLAA 2018-02-20 X3-74480 - END


