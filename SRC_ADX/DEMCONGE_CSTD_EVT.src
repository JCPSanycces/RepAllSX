Call INISEC_DSP_EMPTY(ABREVT) From TPSSUB_SOA      #Done - what if SOA_GTPS < 1?

Return
#-------------------------------------------------------------------------------
$WRT_TIP
If ITER=0
 [F:TIP]DCGUID=[F:DCG]UID
 [F:TIP]LIG   =uniqid([TIP])
 # FQ82073 - 18/12/12 - Initialisation de TIP.CTRDAT selon r횄짢gle m횄짤tier
 If [F:TIP]CTRDAT=[0/0/0] & [F:TIP]ENDDAT<>[0/0/0] Then
  [F:TIP]CTRDAT=func TPSSTD_SOA.CALC_CTRDATDEF([F:TIP]REFNUM,[F:TIP]CTRNUM,[F:TIP]ENDDAT,[F:TIP]DATPYR,[F:TIP]ENDDAT,1) #done-see above
  # FQ81491 - 13/12/13 - R횄짤cup site et service du contrat trouv횄짤
  #If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
  Read [F:HRCTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
  If !fstat Then
    If [F:HRCTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:HRCTR3]ETRFCY : Endif
    If [F:HRCTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:HRCTR3]ETRSRV : Endif
  Endif
 Endif
 #114937 - Entry point for update specific field [F:TIP]
 #For future development - wait for entry point code from Sage #????
 #GPOINT = "MAJTIPSPE" : Gosub ENTREE From EXEFNC
 #If SOA_GOK<1 : Return : Endif
 #114937
 Write [TIP]
 If fstat
  SOA_ABR = "TIP"
  Gosub GLOCK_FSTA
  Return
 Endif
Else
 [F:TIG]DCGUID=[F:DCG]UID
 [F:TIG]LIG   =uniqid([TIP])
 # FQ105844 - 24/02/15 - Le FLGBUL ne sert plus, le champ DATPYR est suffisant
# [F:TIG]FLGBUL = 2
 # FQ82073 - 18/12/12 - Initialisation de TIP.CTRDAT selon r횄짢gle m횄짤tier
 If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
  [F:TIG]CTRDAT=func TPSSTD_SOA.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1) #done-see above
  # FQ81491 - 13/12/13 - R횄짤cup site et service du contrat trouv횄짤
  #If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
  Read [F:HRCTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
  If !fstat Then
    If [F:HRCTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:HRCTR3]ETRFCY : Endif
    If [F:HRCTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:HRCTR3]ETRSRV : Endif
  Endif
 Endif
 Write [TIG]
 If fstat
  SOA_ABR = "TIG"
  Gosub GLOCK_FSTA
  Return
 Endif
Endif

# 26/11/12 - Test sur PDEB sinon erreur d'appel de ADD_CPPRIS
If [F:TIM]CATTIM=3 & [L]PDEB>0 & I>0
 If ITER<>0 : Raz [F:TIP] : [F:TIP] = [F:TIG] : Endif
 SOA_GOK = 1
 Raz SOA_ERRMSG
 Call ADD_CPPRIS(this.LEG,[L]JOUR([L]PDEB..I), SOA_GOK, SOA_ERRMSG) From TPSSTD1_SOA         #done
 If SOA_GOK<1
   ASTATUS = fmet this.ASETERROR("",SOA_ERRMSG,[V]CST_AERROR)
   Return
 Endif
Endif

If SOA_GTPS
 Case [F:DCG]WRK
  When "C" : [L]WRK=mess(75,709,1) : # Ajout
  When "M" : [L]WRK=mess(77,709,1) : # Modif (apr횄짢s)
 Endcase
 Gosub WORKFLOW From TPSSTD_SOA                               #done-see above
Endif

Return
