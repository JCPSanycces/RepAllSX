Local Integer OPENED_AWS : Local File AWRKHISSUI [AWS]  : OPENED_AWS = [V]CST_AYES
Local Integer OPENED_ID  : Local File EMPLOID[ID]       : OPENED_ID  = [V]CST_AYES
Local Integer OPENED_TIP : Local File TIMEMP [TIP]      : OPENED_TIP = [V]CST_AYES

