#If SOA_GWEBSERV : [L]NODEM=[L]DEM : Else : [L]NODEM=0 : Endif # where is [L]DEM initialized
[L]NODEM = 0  # SOA - just set this to 0

# Reset the WRK field on all DEMCONGE records for this employee with ""
Update [DCG] Where REFNUM=this.REFNUM & WRK>"" With WRK=""
If fstat
 Gosub GLOCK_RSTA
 Return
Endif
#
Raz [L]UPD2, [L]UID2
[L]FILTRE2 = "1=1"    #the filter is determined by the FILTER crieria on classic screen - does not apply here
#If !SOA_GWEBSERV
#  Filter [DCG] Where evalue([L]FILTRE2)
#Endif

# SOA changes to SUBDCG:
# On modification always select the UID that we are modifying and set NOLIGN_SOA=1

Local Integer NOLIGN_SOA
#For [DCG]DCG0 Where REFNUM=this.REFNUM & UID>0 With Stability  : # 62113 Ne pas relire les enreg. cr횄짤횄짤s dans cette boucle
For [DCG]DCG0 Where REFNUM=this.REFNUM & UID=this.UID With Stability
 #NOLIGN_SOA=find([F:DCG]UID,this.UID)
 If [F:DCG]UID = this.UID    # added this for SOA
   NOLIGN_SOA = 1
 Else
   NOLIGN_SOA = 0
 Endif
 If NOLIGN_SOA
  I=(this.UPDNUM=[F:DCG]UPDNUM)
  DBUG_MSG += "10,"
 Else
  DBUG_MSG += "10b,"
  #NOLIGN_SOA=find([F:DCG]UID,this.DELUID)  #do not think this is applicable as there is no mask
  NOLIGN_SOA = 0
  If    NOLIGN_SOA   : I=2*(this.DELUPDNUM=[F:DCG]UPDNUM)
  Elsif SOA_GWEBSERV : I=3
  Else                 I=0
  Endif
 Endif
 If !I
  SOA_GMESSAGE=mess(73,701,1)
  #           La table a 횄짤t횄짤 modifi횄짤e par un autre utilisateur depuis la derni횄짢re lecture
  SOA_GOK     =0
  ASTATUS = fmet this.ASETERROR("",SOA_GMESSAGE,[V]CST_AERROR)
  Break
 Elsif SOA_GWEBSERV & I<2
  [L]NODEM=[F:DCG]DEM
 Endif

 If I=2 : # La ligne d'une demande existante a 횄짤t횄짤 supprim횄짤e
  If [F:DCG]STA<2
   # delete attachment here
   W_UID(0)=num$([F:DCG]UID)
   #Call DELETE_AOX_ATTACH("DCG",[F:DCG]REFNUM,num$([F:DCG]DEM),W_UID,1)From PRHPORATT #???? come back to this
   Delete [DCG] Curr
  Else
   If [F:DCG]STA = 2 | [F:DCG]STA = 5
    Call MAJ_HISSUI(0,SOA_GUSER) : # 62113 ici on ne vient pas du circuit de signature=>maj du suivi workflow
   Endif
   [F:DCG]UID*=-1 : # On va supprimer cette ligne dans TIMEMP
   Case [F:DCG]STA
    When 2   : [F:DCG]WRK="S" : [F:DCG]CHRONO =num$(-adxuid(2)) : # Demande
    When 5   : [F:DCG]WRK="S" : [F:DCG]CHRONO2=num$(-adxuid(2)) : # Demande d'annulation
    When 3,7 : [F:DCG]WRK="S"
   Endcase
   [F:DCG]UPDDAT =date$
   [F:DCG]UPDUSR =SOA_GUSER
   [F:DCG]UPDNUM+=1
   Rewrite [DCG] Curr
  Endif
  If fstat
   SOA_ABR = "DCG"
   Gosub GLOCK_FSTA
   Break
  Endif
# in SOA it is likely that I will contain a 1 and therefore follow the code below
 Elsif I=1 : # La ligne d'une demande existante a 횄짤t횄짤 modifi횄짤e (the row of an existing request has been changed)
  #For J=0 To [G:DCG]nbzon-1
  # code example below
  #  If I_EMPLOID.ObjectVar(K) = VFIELD
  #   Assign "I_EMPLOID."+I_EMPLOID.ObjectVar(K) With evalue("(I_ESSWRKEMP."+I_EMPLOID.ObjectVar(K)+")")
  #   Break
  #  Endif
  #Next K
  #
  #SBA 92896-2040 correctif  sur chp updtick ~W
  #-----------------------------------------------------------------------------------------------------------------------------
  #   If left$([G:DCG]adxfname(J),1)<>"~" & [G:DCG]adxfname(J)<>"UPDNUM" & evalue("dim([M:DCG1]"+[G:DCG]adxfname(J)+")")>1
  #&   & evalue("[F:DCG]"+[G:DCG]adxfname(J)+"<>[M:DCG1]"+[G:DCG]adxfname(J)+"(nolign-1)")
  #-----------------------------------------------------------------------------------------------------------------------------
  #Note: SOA
  #At this point the routine gets and "oboslete" record error
  #Need to manage the delete of the original record being changed in AUPDATE_AFTER either directly or via workflow
  #The code below would need to be changed to handle the deletion of the record being amended
  For J= 1 To this.ObjectNbs
   If !find(this.ObjectVar(J),"AATTRIBUTES","ACTX","AERROR","AINF","AKEYS","AORDER","APARENT","ASTALIN")
&   & left$(this.ObjectVar(J),1)<>"~" & this.ObjectVar(J)<>"UPDNUM"
&   & evalue("[F:DCG]"+this.ObjectVar(J)+"<>this."+this.ObjectVar(J))
    DBUG_MSG += "11,"
    # >un des champs du tableau a 횄짤t횄짤 modifi횄짤 pour l'enreg F:DCG courant
    If [F:DCG]STA = 2 | [F:DCG]STA = 5
     Call MAJ_HISSUI(this.STA,SOA_GUSER) : # 62113 ici on ne vient pas du circuit de signature=>maj du suivi workflow
    Endif
    If [F:DCG]STA>1
     [F:DCG]WRK ="M"
     [F:DCG]UID*=-1 : # On va supprimer cette ligne dans TIMEMP
     Case [F:DCG]STA
      When 2 : [F:DCG]CHRONO =num$(-adxuid(2)) : # Demande
      When 5 : [F:DCG]CHRONO2=num$(-adxuid(2)) : # Demande d'annulation
     Endcase
     # we need to update the field TCH_STA0 READ_AFTER - see LIENS in SUBDCG
     If !SOA_GWEBSERV & this.TCH_STA0=this.STA : # pour forcer MAJTIP
      Case this.STA
       When 2 : this.TCH_STA0=1
       When 3 : this.TCH_STA0=2
       ## When 4 : [M:DCG1]STA0(nolign-1)=2
       When 5 : this.TCH_STA0=3
       ## When 6 : [M:DCG1]STA0(nolign-1)=5
       When 7 : this.TCH_STA0=5
      Endcase
     Endif
    Else
     #[F:DCG]       =[M:DCG1]             #may need to do class transfer
     SetInstance [F:DCG] With this
     [F:DCG]UPDDAT =date$
     [F:DCG]UPDUSR =SOA_GUSER
     If this.STA=2 : [F:DCG]WRK="C" : Else [F:DCG]WRK="" : Endif
    Endif
    [F:DCG]UPDNUM+=1
    DBUG_MSG += "12,"
    Rewrite [DCG] Curr
    If fstat
     SOA_ABR = "DCG"
     Gosub GLOCK_FSTA
     Break 2
    Endif

    If [F:DCG]WRK="M"
     #[F:DCG]       =[M:DCG1]     # class transfer
     SetInstance [F:DCG] With this
     [F:DCG]UPDDAT =date$
     [F:DCG]UPDUSR =SOA_GUSER
     [F:DCG]UID    =uniqid([TIP])
     [F:DCG]UPDNUM+=2
     Case [F:DCG]STA
      When 2 : [F:DCG]CHRONO =num$(-adxuid(2)) : # Demande
      When 5 : [F:DCG]CHRONO2=num$(-adxuid(2)) : # Demande d'annulation
     Endcase
     DBUG_MSG += "12a,"
     Write [DCG]
     If fstat
      SOA_ABR = "DCG"
      Gosub GLOCK_FSTA
      Break 2
     Endif
    Endif
    Break
   Endif
  Next
 Endif
 If I=1 : [L]UPD2=[F:DCG]UPDNUM : [L]UID2=[F:DCG]UID : Endif
Next
Filter [DCG]
If SOA_GOK<1 : Return : Endif
#------------------------------
# Lignes cr횄짤횄짤es dans le tableau
#For nolign=1 To 1 #[M:DCG1]NBLIG
 If this.UID<=0
  Raz [F:DCG]
  SetInstance [F:DCG] With this
  [F:DCG]CREUSR=SOA_GUSER
  [F:DCG]CREDAT=date$
  #[F:DCG]      =[M:DCG1]  # see SetInstance above
  [F:DCG]UID   =uniqid([TIP])
  [F:DCG]LNK   =[F:DCG]UID
  If [F:DCG]STA=2 : [F:DCG]WRK="C" : [F:DCG]CHRONO=num$(-adxuid(2)) : Endif
  If ![L]NODEM : [L]NODEM=uniqid([DCG]) : Endif
  [F:DCG]DEM=[L]NODEM
  DBUG_MSG += "12b,"
  Write [DCG]
  If fstat
   SOA_ABR = "DCG"
   Gosub GLOCK_FSTA
   #Break
  Else
    [L]UPD2=[F:DCG]UPDNUM
    [L]UID2=[F:DCG]UID
  Endif
Endif
#Next
If SOA_GOK<1 : Return : Endif
#------------------------------
#If find(0,[L]UID2(0..[M:DCG1]NBLIG-1))
If [L]UID2 = 0
 #           La table a 횄짤t횄짤 modifi횄짤e par un autre utilisateur depuis la derni횄짢re lecture
 SOA_GMESSAGE=mess(73,701,1)
 SOA_GOK     =0
 ASTATUS = fmet this.ASETERROR("",SOA_GMESSAGE,[V]CST_AERROR)
 Return
Endif
DBUG_MSG += "13,"
#[L]CRITERE2(0) ="REFNUM=[M:DCG1]REFNUM & find(UID,[L]UID2(0..[M:DCG1]NBLIG-1))" : # Nouvelle demande ou statut de la demande a chang횄짤
#[L]CRITERE2(1)="[M:DCG1]STA0(find([F:DCG]UID,[L]UID2(0..[M:DCG1]NBLIG-1))-1)<>[F:DCG]STA"
[L]CRITERE2(0) ="REFNUM=this.REFNUM & find(UID,[L]UID2)"
[L]CRITERE2(1)="this.TCH_STA0(find([F:DCG]UID,[L]UID2)-1)<>[F:DCG]STA"
Read [F:ID]ID0 = this.REFNUM
If fstat
 SOA_GMESSAGE = mess(70,122,1)-"[F:ID]" : # erreur de lecture
 SOA_GOK = 0
 ASTATUS = fmet this.ASETERROR("",SOA_GMESSAGE,[V]CST_AERROR)
 Return
Endif

#------------------------------
Gosub MAJTIP
If SOA_GOK<1 : Return : Endif
#------------------------------

Return
#############################################################################################################
Subprog MAJ_HISSUI(STA,SOA_GUSER)
Value Integer STA
Value Char SOA_GUSER
#62113 - suppression du suivi d'une demande (moniteur workflow)
#ici [F:DCG]STA = 2 ou 5 , [L]STA = valeur saisie

Local Integer SOA_GWEBSERV  : Call GWEBSERV(SOA_GWEBSERV) From ESSGLOB_SOA
If SOA_GWEBSERV : End : Endif

Call MAJ_HISSUIPOR(STA,SOA_GUSER)

End
#------------------------------
#SBA & DEHEN - 2016-10-27 - Leave cancellations for workflow - START
Subprog MAJ_HISSUIPOR(STA,SOA_GUSER)
Value Integer STA
Value Char SOA_GUSER

Local Char REP (GLONADI)
Local File AWRKHISSUI [AWS]

Case [L]STA
 When [F:DCG]STA - 1 : REP = "CMP"
 When [F:DCG]STA + 1 : REP = "VIS"
 When [F:DCG]STA + 2 : REP = "REF"
 When Default        : REP = "ANN"
Endcase

# AWS-file opened in OUVRE_SOA
Update [F:AWS] Where VALCTX1 = [F:DCG]REFNUM
&                  & VALCTX3 = "15"
&                  & VALCTX4 = num$([F:DCG]UID)
&                  & FLGSIG  = 3
&              With [F:AWS]FLGSIG = 5
&                 , [F:AWS]ACTSIG = REP
&                 , [F:AWS]USRSIG = SOA_GUSER
&                 , [F:AWS]DATSIG = date$
#DBUG_MSG += "9,"  # did get here but variable needs to be passed in parameters
End
#SBA & DEHEN - 2016-10-27 - Leave cancellations for workflow - END
################################################################################
$MAJTIP
Local Decimal JOUR(1..400), HEURE(1..400), JOUR1(1..400)
Local Shortint PDEB, PFIN, CDEB, CFIN, DFIN
Gosub DEFVARWRK From TPSSTD_SOA
#Gosub OUVRE From WODCG_SOA
Gosub OUVRE_SOA      # see OUVRE From WODCG
#===================================================================================================
# WG : notes sur les variables de travail. nombres toujours entiers.
# DFIN : Nombre de jour(s) pos횄짤(s) du jour d횄짤but au jour fin demand횄짤
#
# CDEB : Nombre de jour(s) d횄짤calage pour jour d횄짤but
#        depuis date d횄짤but demand횄짤e et en int횄짤grant date de d횄짤but contrat
#        1=> jour d횄짤but = 1er jour demand횄짤 , 2=> jour d횄짤but = lendemain du 1er jour demand횄짤 , etc.
#
# CFIN : Nombre de jour(s) d횄짤calage pour jour fin
#        depuis date d횄짤but demand횄짤e et en int횄짤grant date de fin contrat
#        1=> jour fin = 1er jour demand횄짤 , 2=> jour fin = lendemain du 1er jour demand횄짤 , etc.
#
# PDEB : Nombre de jour(s) d횄짤calage pour jour d횄짤but
#        depuis date d횄짤but demand횄짤e , en int횄짤grant date de d횄짤but contrat
#        et date d횄짤but de p횄짤riode d'extraction
#        m횄짧me principe que CDEB
#
# PFIN : Nombre de jour(s) d횄짤calage pour jour fin
#        depuis date d횄짤but demand횄짤e , en int횄짤grant date fin de contrat
#        et date fin p횄짤riode d'extraction
#        m횄짧me principe que CFIN
#
# []STRDAY(n) = 2 : []ENDDAY(n) = 1 : # Absent le matin      le dernier jour
# []STRDAY(n) = 1 : []ENDDAY(n) = 2 : # Absent l' apr횄짢s-midi le premier jour
# []STRDAY(n) = 1 : []ENDDAY(n) = 1 : # Absent la journ횄짤e    du premier au dernier jour
#===================================================================================================
DBUG_MSG += "14,"
Local Char SOA_ABR(3)

Local Integer  SOA_GPAYE      : Call GPAYE(SOA_GPAYE) From ESSGLOB_SOA       : # Pr횄짤sence du module paye
Local Integer  SOA_GWEBSERV   : Call GWEBSERV(SOA_GWEBSERV) From ESSGLOB_SOA : # Environnement WEB (Adapi)
Local Integer  SOA_GTPS       : Call GTPS(SOA_GTPS) From ESSGLOB_SOA         : # Pr횄짤sence du module temps
#Local Char     SOA_GFMD(30)   : Call GFMD(SOA_GFMD) From ESSGLOB_SOA

# UID < 0 : Lignes annul횄짤es (les lignes modifi횄짤es g횄짤n횄짢rent 1 ligne annul횄짤e et une ligne cr횄짤횄짤e)
# UID <0: Lines canceled (the modified lines generate 1 row canceled and a row created)
For [DCG] Where UID<0 & WRK>"" & REFNUM=[F:ID]REFNUM     : # 62798
  If SOA_GTPS=1
   # Suppression d'une demande qui a g횄짤n횄짤r횄짤 dans TIMREGUL des temps
#   For [TIG1] Where DCGUID=-[F:DCG]UID
   For [TIG1] Where DCGUID=-[F:DCG]UID With Stability  : # 68494
    #If [V]GTPS
    If SOA_GTPS   # why is this here and a few lines above - check SUBDCG
     Case [F:DCG]WRK
      When "S" : [L]WRK=mess(74,709,1) : # Suppression
      When "M" : [L]WRK=mess(76,709,1) : # Modif (avant)
     Endcase
     # this routine TPSSTD_SOA expects [F:TIP] (TIMEMP) to be present as it uses data from this to read other records
     # new for SOA - begin
     #Local File TIMREGUL [TIG1]
     Read [F:TIP]TIP0 = [F:TIG1]LIG        #[F:TIG1] is TIMREGUL
     If fstat : Raz [F:TIP] : Endif
     # new for SOA - end
     Gosub WORKFLOW From TPSSTD_SOA                                                  #Done
    Endif
    # G횄짤n횄짤ration r횄짤gul pour annuler TIMREGUL + pour mettre W
    Raz [F:TIG]
    [F:TIG]       = [F:TIG1]
    [F:TIG]LIG    = uniqid([TIP])
    [F:TIG]NBRDAY = (-1)*[F:TIG1]NBRDAY
    [F:TIG]NBRHOU = (-1)*[F:TIG1]NBRHOU
    # FQ105844 - 24/02/15 - Le FLGBUL ne sert plus, le champ DATPYR est suffisant
#    [F:TIG]FLGBUL = 2
    LESITE = [F:TIG1]FCY
    Call PERIO(LESITE,[F:TIG]REFNUM) From SUBPEO_SOA   # calls an entry point - waiting for Sage to SOA
    Filter [PEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:TIG]STRDAT & PEREND(R1)>=[F:TIG]ENDDAT
    Read [PEO1]PEO0 First
    If fstat
     Filter [PEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:TIG]STRDAT & PEREND(R1)>=[F:TIG]ENDDAT
     Read [PEO1]PEO0 First
    Endif
    Filter [PEO1]
    If !fstat
     [F:TIG]DATPYR = [F:PEO1]PYRDAT
     # FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon r횄짢gle m횄짤tier
     If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
      # Comment out entry point at end of TPSSTD (CALC_CTRDATDEF)
      # - waiting for Sage to SOA - needs to be added back in the future
      # - see GPOINT = "CTRDATREF" : Gosub ENTREE From EXEFNC in code
      [F:TIG]CTRDAT=func TPSSTD_SOA.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1) # see entry point note above
      # FQ81491 - 13/12/13 - R횄짤cup site et service du contrat trouv횄짤
      #If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
      Read [F:HRCTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
      If !fstat Then
        If [F:HRCTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:HRCTR3]ETRFCY : Endif
        If [F:HRCTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:HRCTR3]ETRSRV : Endif
      Endif
     Endif
     Write[TIG]
     If fstat
      SOA_ABR = "TIG"
      Gosub GLOCK_FSTA
      Break 2
     Endif
     Raz [L]JOUR
     Read [TIM]TIM0=[F:TIG]TIM
     Local Char SOA_ERRMSG(250)
     Gosub MAJCP1 From TPSSTDR_SOA      #Done
     If SOA_GOK<1
      ASTATUS = fmet this.ASETERROR("",SOA_ERRMSG,[V]CST_AERROR)
      Break 2
     Endif
    Endif
   Next
  Endif

  # Suppression d'une demande qui a g횄짤n횄짤r횄짤 dans TIMEMP des temps
  For [TIP] Where DCGUID=-[F:DCG]UID
   If SOA_GTPS
    Case [F:DCG]WRK
     When "S" : [L]WRK=mess(74,10709,1) : # Suppression
     When "M" : [L]WRK=mess(76,10709,1) : # Modif (avant)
    Endcase
    Gosub WORKFLOW From TPSSTD_SOA    # done-see above
   Endif
# 28/03/01 - Bug 72654
# - Pouvoir saisir quand on n'a pas GPAYE et GTPS
#   Filter [VEP] Where EMP=[F:DCG]REFNUM & CTRNUM=[F:CTR]CTRNUM & PYRDAT=[F:TIP]DATPYR
#   Read [VEP]VEP0 Last
#   Filter [VEP]
#   If fstat | ([F:VEP]PST=1 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2)
   If SOA_GPAYE
    # 21/10/11 77113 - on ne prend pas le bon contrat
    Filter [VEP] Where EMP=[F:DCG]REFNUM & CTRNUM=[F:TIP]CTRNUM & PYRDAT=[F:TIP]DATPYR
    Read [VEP]VEP0 Last
    Filter [VEP]
   Endif
   If !SOA_GPAYE | fstat | ([F:VEP]PST=1 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2)
    # Paie non g횄짤n횄짤r횄짤e ou Paie non comptabilis횄짤e avec arr횄짧t횄짤 des temps non fait
    # pass in SOA_GOK, SOA_ERRMSG
    SOA_GOK = 1
    Raz SOA_ERRMSG
    Call SUPP_CPPRIS(this.TCH_LEG,SOA_GOK,SOA_ERRMSG) From TPSSTD1_SOA     #done
    If SOA_GOK<1
      ASTATUS = fmet this.ASETERROR("",SOA_ERRMSG,[V]CST_AERROR)
      Break 2
    Endif
    Delete [TIP] Curr
    If fstat
     SOA_ABR = "TIP"
     Gosub GLOCK_FSTA
     Break 2
    Endif
   Else
    # G횄짤n횄짤ration r횄짤gul pour annuler TIMEMP
    Raz [F:TIG]
    [F:TIG]       = [F:TIP]
    [F:TIG]LIG    = uniqid([TIP])
    [F:TIG]NBRDAY = (-1)*[F:TIP]NBRDAY
    [F:TIG]NBRHOU = (-1)*[F:TIP]NBRHOU
    # FQ105844 - 24/02/15 - Le FLGBUL ne sert plus, le champ DATPYR est suffisant
#    [F:TIG]FLGBUL = 2
    LESITE = [F:TIP]FCY
    Call PERIO(LESITE,[F:TIP]REFNUM) From SUBPEO_SOA    # done-see above
    Filter [PEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:TIP]STRDAT & PEREND(R1)>=[F:TIP]ENDDAT
    Read [PEO1]PEO0 First
    If fstat
     Filter [PEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:TIP]STRDAT & PEREND(R1)>=[F:TIP]ENDDAT
     Read [PEO1]PEO0 First
    Endif
    Filter [PEO1]
    If !fstat
     [F:TIG]DATPYR = [F:PEO1]PYRDAT
     # FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon r횄짢gle m횄짤tier
     If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
      [F:TIG]CTRDAT=func TPSSTD_SOA.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1) # done - see above
      # FQ81491 - 13/12/13 - R횄짤cup site et service du contrat trouv횄짤
      Read [F:HRCTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
      If !fstat Then
        If [F:HRCTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:HRCTR3]ETRFCY : Endif
        If [F:HRCTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:HRCTR3]ETRSRV : Endif
      Endif
     Endif
     Write[TIG]
     If fstat
      SOA_ABR = "TIG"
      Gosub GLOCK_FSTA
      Break 2
     Endif
     Raz [L]JOUR
     Read [TIM]TIM0=[F:TIG]TIM
     Gosub MAJCP1 From TPSSTDR_SOA            # see above
     If SOA_GOK<1 : Break 2 : Endif
     # G횄짤n횄짤ration r횄짤gul pour mettre W
     [F:TIG]LIG = uniqid([TIP])
     [F:TIG]TIM = GTPSW
     # FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon r횄짢gle m횄짤tier
     If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
      [F:TIG]CTRDAT=func TPSSTD_SOA.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1) # done-see above
      # FQ81491 - 13/12/13 - R횄짤cup site et service du contrat trouv횄짤
      Read [F:HRCTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
      If !fstat Then
        If [F:HRCTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:HRCTR3]ETRFCY : Endif
        If [F:HRCTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:HRCTR3]ETRSRV : Endif
      Endif
     Endif
     Call VALORIS([F:TIG]STRDAT,[F:TIG]ENDDAT,[F:TIG]REFNUM,[F:TIG]TIM,[F:TIG]NBRDAY,[F:TIG]NBRHOU,[F:TIG]FCY,[F:TIG]CTRNUM) From SUBPLN_SOA   #done
     Write[TIG]
     If fstat
      SOA_ABR = "TIG"
      Gosub GLOCK_FSTA
      Break 2
     Endif
    Endif
   Endif
  Next

 Next
 If SOA_GOK<1 : Return : Endif

#62798 - For [DCG] Where UID>0 & evalue([L]CRITERE2(0)) & STA=6-[V]GWEBSERV
# STA = 6 : Annulation accept횄짤e
For [DCG] Where UID>0 & evalue([L]CRITERE2(0)) & STA=6

 If evalue([L]CRITERE2(1))
  For [TIP]TIP1 Where REFNUM=[F:DCG]REFNUM & find([F:DCG]CTRNUM,"",CTRNUM)
&                   & STRDAT>=[F:DCG]STRDAT & ENDDAT<=[F:DCG]ENDDAT & TIM=[F:DCG]TIM

#  Si Temps et Absence se chevauchent on supprimme les temps
# 27/10/11 FQ 77350 si on a
# 1/2 journ횄짤e le matin dans TIP et 1/2 le matin dans DCG
# ou 1/2 journ횄짤e le l'apr횄짤s midi dans TIP et 1/2 le apr횄짤s midi dans DCG
# Il y a chevauchement et donc il faut supprimer TIMEMP
   If ( [F:TIP]STRDAT<[F:DCG]ENDDAT
&     | ([F:TIP]STRDAT=[F:DCG]ENDDAT & ([F:TIP]STRDAY<2 | [F:DCG]ENDDAY<2))
&     )
&   & ( [F:TIP]ENDDAT>[F:DCG]STRDAT
&     | ([F:TIP]ENDDAT=[F:DCG]STRDAT & ([F:TIP]ENDDAY<2 | [F:DCG]STRDAY<2))
&     )
    If SOA_GTPS
     [L]WRK=mess(74,709,1) : # Suppression
     Gosub WORKFLOW From TPSSTD_SOA                   #done-see above
    Endif
    SOA_GOK = 1
    Raz SOA_ERRMSG
    Call SUPP_CPPRIS(this.TCH_LEG,SOA_GOK,SOA_ERRMSG) From TPSSTD1_SOA          #done-see above
    If SOA_GOK<1
      ASTATUS = fmet this.ASETERROR("",SOA_ERRMSG,[V]CST_AERROR)
      Break 2
    Endif
    Delete [TIP] Curr
    If fstat
     SOA_ABR = "TIP"
     Gosub GLOCK_FSTA
     Break 2
    Endif
   Endif
  Next
 Endif
Next
If SOA_GOK<1 : Return : Endif
# FQ85820 - 12/11/12 - On doit aussi tester la date de r횄짤troactivit횄짤 au lieu de la date du contrat
# FQ??? - 14/03/14 - Pas de test sur la date de r횄짤tro, sinon on comptabilise plusieurs fois la m횄짧me absence avec le Link
Link [DCG] With [HRCTR2]CTR0(1)=REFNUM
&             , [TIM]TIM0    =TIM
&             , [FCY]FCY0    =[HRCTR2]ETRFCY
&             , [CPY]CPY0    =[FCY]LEGCPY
&            As [LNK]
&         Where ([HRCTR2]CTRDAT<=ENDDAT & ([HRCTR2]XITDAT=[0/0/0] | [HRCTR2]XITDAT>=STRDAT))
&             & find(CTRNUM,"",[F:HRCTR2]CTRNUM)<>0
&  Order By Key CLE=UID

# Le statut Accept횄짤, demande annulation et annulation accept횄짤e cr횄짤e un enreg dans TIMEMP.
# Si demande annulation, suppression de l'enreg TIMEMP associ횄짤 횄혻 la demande accept횄짤e et re-cr횄짤ation
# Si annulation accept횄짤e, suppression de l'enreg TIMEMP associ횄짤 횄혻 la demande annulation

Filter [LNK] Where find(STA,3,5,7)<>0  : # 62798

# Demandes accept횄짤es en heures
For [LNK]CLE Where UID>0 & evalue([L]CRITERE2(0)) & [TIM]DAYDAC<2
 Raz ITER
 If evalue([L]CRITERE2(1))

  LESITE = [F:HRCTR2]ETRFCY
  Call PERIO(LESITE,[F:HRCTR2]REFNUM) From SUBPEO_SOA    # done-see above
  For [TIP1]TIP1 Where REFNUM=[F:DCG]REFNUM & STRDAT<=[F:DCG]ENDDAT & ENDDAT>=[F:DCG]STRDAT
   # FQ105844 - 24/02/15 - Si 1/2 journ횄짤e, on v횄짤rifie qu'on n'est pas sur la m횄짧me 1/2 journ횄짤e
   If [F:DCG]STRDAT=[F:DCG]ENDDAT & [F:DCG]STRDAY<>[F:DCG]ENDDAY & ([F:DCG]STRDAY<>[F:TIP1]STRDAY | [F:DCG]ENDDAY<>[F:TIP1]ENDDAY) Then
   Else
     # La demande concerne des jours d횄짤j횄혻 saisis dans TIMEMP : que la paie soit arr횄짧t횄짤e ou pas, on passe r횄짤gul
     If [F:DCG]CTRNUM=[F:TIP1]CTRNUM | ([F:DCG]CTRNUM="" & [F:TIP1]CTRNUM=[F:HRCTR2]CTRNUM)
      For ITER=1 To 4
       Gosub REGUL
       If SOA_GOK<1 : Break 3 : Endif
      Next
     Endif
   Endif
  Next

# 19/03/13 - FQ88381
# - Si d횄짤j횄혻 en paye on passe directement en r횄짤gul
  If ITER=0 & SOA_GPAYE
    Local Date WPERSTR, WPEREND, WPYRDAT
    Raz WPERSTR, WPEREND, WPYRDAT
    J=([F:TIM]MONDAC=2)
    Filter [PEO] Where find(FCY,"",LESITE)<>0
&                     & eomonth(PYRDAT)=eomonth([F:DCG]STRDAT)
&         Order By Key CLE=FCY Desc;PYRDAT
    For [PEO]CLE(1)
     For [PEO]CLE
       WPERSTR=[F:PEO]PERSTR(J)
       WPEREND=[F:PEO]PEREND(J)
       If [F:PEO]PYRDAT>=[F:DCG]ENDDAT : Break 2 : Endif
     Next
     Break
    Next
    If WPERSTR <> [0/0/0] & WPEREND <> [0/0/0] & WPYRDAT <> [0/0/0]
#     & !([F:PEO]PERSTR(J)<=[F:DCG]STRDAT & [F:PEO]PEREND(J)>=[F:DCG]ENDDAT)
      Filter [VEP] Where [F:VEP]EMP=[F:DCG]REFNUM & ([F:DCG]CTRNUM="" | [F:VEP]CTRNUM=[F:DCG]CTRNUM) & [F:VEP]STRDAT<=[F:DCG]STRDAT & [F:VEP]ENDDAT>=[F:DCG]ENDDAT
&     & [F:VEP]PYRDAT=[F:PEO]PYRDAT
      Read [VEP]VEP0 Last
      Filter [VEP]
      # FQ??? - 14/03/14 - Il faut v횄짤rifier quand m횄짧me que la date de l'absence est bien <= 횄혻 la date du dernier temps comptabilis횄짤
      # sur cette paie, sinon on risque d'oublier des temps. D'o횄쨔 le test sur DATTPS.
      If !fstat & !([F:VEP]PST=1 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2 & [F:VEP]STA<>3)
&               & [F:VEP]DATTPS>=[F:DCG]STRDAT
      # Paie g횄짤n횄짤r횄짤e ou Paie comptabilis횄짤e
        ITER=1
        Gosub REGUL
        If SOA_GOK<1 : Break 1 : Endif
      Endif
    Endif
  Endif
  If ITER=0
   Raz [F:TIP]
   [F:TIP]      =[F:DCG]
   [F:TIP]CTRNUM=[F:HRCTR2]CTRNUM
   [F:TIP]FCY   =[F:HRCTR2]ETRFCY
   [F:TIP]SRV   =[F:HRCTR2]ETRSRV

   J=([F:TIM]MONDAC=2)
   Filter [PEO] Where find(FCY,"",LESITE)<>0
&                     & eomonth(PYRDAT)=eomonth([F:DCG]STRDAT)
&         Order By Key CLE=FCY Desc;PYRDAT
   For [PEO]CLE(1)
     For [PEO]CLE
       [F:TIP]DATPYR=[F:PEO]PYRDAT
       If [F:PEO]PYRDAT>=[F:DCG]ENDDAT : Break 2 : Endif
     Next
     Break
   Next

   [F:TIP]AUTFLG =2
   [F:TIP]STAFLG =SOA_GUSER
   [F:TIP]STA    =0 : # 횄혻 quoi 횄짠a sert ?
   [F:TIP]ANAFLG=0
   [F:TIP]DSP   =""
   # FQ82073 - 18/12/12 - Initialisation de TIP.CTRDAT selon r횄짢gle m횄짤tier
   If [F:TIP]CTRDAT=[0/0/0] & [F:TIP]ENDDAT<>[0/0/0] Then
    [F:TIP]CTRDAT=func TPSSTD_SOA.CALC_CTRDATDEF([F:TIP]REFNUM,[F:TIP]CTRNUM,[F:TIP]ENDDAT,[F:TIP]DATPYR,[F:TIP]ENDDAT,1) #done-see above
    # FQ81491 - 13/12/13 - R횄짤cup site et service du contrat trouv횄짤
    Read [F:HRCTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
    If !fstat Then
      If [F:HRCTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:HRCTR3]ETRFCY : Endif
      If [F:HRCTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:HRCTR3]ETRSRV : Endif
    Endif
   Endif
   # FQ92876 - 26/06/14 - Ajout [F:TIP]CPY utilis횄짤 dans INISEC_DSP_EMPTY
   [F:TIP]CPY= func DIVPAYE_SOA.GETSOC([F:TIP]FCY)        #done
   Gosub INICCE  #done
   If dim([F:TIP]CREUSR)>0 : [F:TIP]CREUSR=SOA_GUSER  : Endif
   If dim([F:TIP]CREDAT)>0 : [F:TIP]CREDAT=date$     : Endif
   If dim([F:TIP]CRETIM)>0 : [F:TIP]CRETIM=time      : Endif
   If dim([F:TIP]EXPNUM)>0 : [F:TIP]EXPNUM=[C]EXPORT : Endif     #leave as is for now

   Gosub WRT_TIP
   If SOA_GOK<1 : Break : Endif
  Endif
 Endif
Next
Filter [PEO]
If SOA_GOK<1 : Filter [LNK] : Return : Endif

# Demandes accept횄짤es en jour
Local Date DATDEBCTR
For [LNK]CLE(1) Where UID>0 & evalue([L]CRITERE2(0)) & [TIM]DAYDAC=2
 If evalue([L]CRITERE2(1))
  [L]DFIN=[F:DCG]ENDDAT-[F:DCG]STRDAT+1
  For [LNK]CLE
   # FQ85820 - 12/11/12 - On doit aussi tester la date de r횄짤troactivit횄짤 au lieu de la date du contrat
   DATDEBCTR=[F:HRCTR2]CTRDAT
   If [F:HRCTR2]FLGRET=2 & [F:HRCTR2]RETDATEFF<>[0/0/0] Then
     DATDEBCTR=[F:HRCTR2]RETDATEFF
   Endif
   [L]CDEB=max([F:DCG]STRDAT,DATDEBCTR)-[F:DCG]STRDAT+1
   If [F:HRCTR2]XITDAT=[0/0/0] : [L]CFIN=[L]DFIN
   Else                        [L]CFIN=min([F:DCG]ENDDAT,[F:HRCTR2]XITDAT)-[F:DCG]STRDAT+1
   Endif
   Raz [L]JOUR
   If [F:HRCTR2]PLNTYP=""
    For I=[L]CDEB To [L]CFIN : [L]JOUR(I)=1 : Next
   Else
    #CHECK IGNORE_BEGIN
    #done-see above
    Call VALORDET( [F:DCG]STRDAT+[L]CDEB-1,[F:DCG]STRDAT+[L]CFIN-1,[F:DCG]REFNUM
&                , [F:DCG]TIM,[L]JOUR([L]CDEB..[L]CFIN),[L]HEURE([L]CDEB..[L]CFIN)
&                , [F:HRCTR2]ETRFCY,[F:HRCTR2]CTRNUM
&                ) From SUBPLN_SOA
    #CHECK IGNORE_END
   Endif
#  73242   If [F:DCG]STRDAY=2 & [L]CDEB=1
   If [F:DCG]ENDDAY=2 & [L]CDEB=1
    If [L]JOUR(1)<=0.5 : Raz [L]HEURE(1), [L]JOUR(1)
    Else                 [L]HEURE(1)*=([L]JOUR(1)-0.5)/[L]JOUR(1) : [L]JOUR(1)-=0.5
    Endif
   Endif
#  73242   If [F:DCG]ENDDAY=2 & [L]CFIN=[L]DFIN
   If [F:DCG]STRDAY=2 & [L]CFIN=[L]DFIN
    If [L]JOUR([L]DFIN)<=0.5
     Raz [L]HEURE([L]DFIN), [L]JOUR([L]DFIN)
    Else
     [L]HEURE([L]DFIN)*=([L]JOUR([L]DFIN)-0.5)/[L]JOUR([L]DFIN)
     [L]JOUR ([L]DFIN)-=0.5
    Endif
   Endif

   J=([F:TIM]MONDAC=2)
   LESITE = [F:HRCTR2]ETRFCY
   Call PERIO(LESITE,[F:HRCTR2]REFNUM) From SUBPEO_SOA   # done-see above

   # Pb si PERIOD a 1 enreg avec un site et une date de paie au 28/01/2009 et 1 enreg avec site="" et une date de paie au 31/01/2009
   # On passe 2 fois la r횄짤gul
   #Filter [PEO] Where find(FCY,"",LESITE)<>0 & PEREND(J)>=[F:DCG]STRDAT+[L]CDEB-1
   #&& PERSTR(J)<=[F:DCG]STRDAT+[L]CFIN-1
   #&Order By Key CLE=PYRDAT;FCY Desc
   #For [PEO]CLE(1)
   Raz OLDYEA,OLDFCY
   # FQ94174 - 23/12/13 - si d횄짤calage de paie, on est forc횄짤ment dans ce cas. On ne veut pas pour autant faire le filtre sur toutes les p횄짤riodes

   #If val(func AFNC.PARAM("JPAY",LESITE))>0 Then
   If val(func ADP_TOOL.GET_PARAM(GACTX.AFOLDER,3,LESITE,"JPAY")) > 0 Then
     Local Date PYRDATPEO
     PYRDATPEO=[F:PEO]PYRDAT
     Filter [PEO] Where FCY=LESITE & PYRDAT=PYRDATPEO
&        Order By Key CLE=YEA;FCY Desc;PYRDAT
   Else
     Filter [PEO] Where find(FCY,"",LESITE)<>0 & PEREND(J)>=[F:DCG]STRDAT+[L]CDEB-1
&                     & PERSTR(J)<=[F:DCG]STRDAT+[L]CFIN-1
&          Order By Key CLE=FCY Desc;YEA;PYRDAT : #113959 la priorit횄짤 est au site avant l'ann횄짤e, sinon au aura en 1er la p횄짤riode sans site
#&          Order By Key CLE=YEA;FCY Desc;PYRDAT
   Endif
   For [PEO]CLE(2)
    If OLDYEA<>[F:PEO]YEA
     OLDYEA = [F:PEO]YEA
     OLDFCY = [F:PEO]FCY
    Endif
    If [F:PEO]FCY = OLDFCY
     For [PEO]CLE(3)

#
# -- On 횄짤clate la demande pour isoler les 1/2 journ횄짤es dans les temps
#
      # FQ85820 - 12/11/12 - On doit aussi tester la date de r횄짤troactivit횄짤 au lieu de la date du contrat
      DATDEBCTR=[F:HRCTR2]CTRDAT
      If [F:HRCTR2]FLGRET=2 & [F:HRCTR2]RETDATEFF<>[0/0/0] Then
        DATDEBCTR=[F:HRCTR2]RETDATEFF
      Endif
      [L]PDEB=max([F:DCG]STRDAT,DATDEBCTR,[F:PEO]PERSTR(J))-[F:DCG]STRDAT+1
      If [F:CTR2]XITDAT=[0/0/0]
       [L]PFIN=min([F:DCG]ENDDAT,[F:PEO]PEREND(J))-[F:DCG]STRDAT+1
      Else
       [L]PFIN=min([F:DCG]ENDDAT,[F:HRCTR2]XITDAT,[F:PEO]PEREND(J))-[F:DCG]STRDAT+1
      Endif

      If sum([L]JOUR([L]PDEB..[L]PFIN))

       Gosub INIT_TIP0 : # 73469
       If !SOA_GOK : Break 4 : Endif :#JIRA2198
#D횄짤but une 1/2 journ횄짤e et plus de 1 jour demand횄짤 (cmt WG d'apr횄짢s ligne de code avant modif 73242)
# > on cr횄짤e une ligne dans les temps pour cette 1/2 journ횄짤e de d횄짤but
#      73242  If [L]PDEB=1 & [F:DCG]STRDAY=2 & [L]PFIN>1 & [L]JOUR(1)
       If [L]PDEB=1 & [F:DCG]ENDDAY=2 & [L]PFIN>1 & [L]JOUR(1)
        Gosub INIT_TIP1 : # 73469
        I            =1
        Raz ITER
        For [TIP1]TIP1 Where REFNUM=[F:DCG]REFNUM & STRDAT<=[F:DCG]STRDAT & ENDDAT>=[F:DCG]STRDAT
         # FQ105844 - 24/02/15 - Si 1/2 journ횄짤e, on v횄짤rifie qu'on n'est pas sur la m횄짧me 1/2 journ횄짤e
         If [F:DCG]STRDAT=[F:DCG]ENDDAT & [F:DCG]STRDAY<>[F:DCG]ENDDAY & ([F:DCG]STRDAY<>[F:TIP1]STRDAY | [F:DCG]ENDDAY<>[F:TIP1]ENDDAY) Then
         Else
           # La demande concerne des jours d횄짤j횄혻 saisis dans TIMEMP : que la paie soit arr횄짧t횄짤e ou pas, on passe r횄짤gul
           If [F:DCG]CTRNUM=[F:TIP1]CTRNUM | ([F:DCG]CTRNUM="" & [F:TIP1]CTRNUM=[F:HRCTR2]CTRNUM)
            For ITER=2 To 4
             Gosub REGUL
             If SOA_GOK<1 : Break 4 : Endif
            Next
           Endif
         Endif
        Next
    # 19/03/13 - FQ88381
    # - Si d횄짤j횄혻 en paye on passe directement en r횄짤gul
        If ITER=0 & SOA_GPAYE
##        & !([F:PEO]PERSTR(J)<=[F:DCG]STRDAT & [F:PEO]PEREND(J)>=[F:DCG]ENDDAT)
          Filter [VEP] Where [F:VEP]EMP=[F:DCG]REFNUM & ([F:DCG]CTRNUM="" | [F:VEP]CTRNUM=[F:DCG]CTRNUM)
&                          & [F:VEP]STRDAT<=[F:DCG]STRDAT & [F:VEP]ENDDAT>=[F:DCG]ENDDAT
&                          & [F:VEP]PYRDAT=[F:PEO]PYRDAT
          Read [VEP]VEP0 Last
          Filter [VEP]
          # FQ??? - 14/03/14 - Il faut v횄짤rifier quand m횄짧me que la date de l'absence est bien <= 횄혻 la date du dernier temps comptabilis횄짤
          # sur cette paie, sinon on risque d'oublier des temps. D'o횄쨔 le test sur DATTPS
          If !fstat & !([F:VEP]PST=1 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2 & [F:VEP]STA<>3)
&                   & [F:VEP]DATTPS>=[F:DCG]STRDAT
          # Paie g횄짤n횄짤r횄짤e ou Paie comptabilis횄짤e
            ITER=1
            Gosub REGUL
            If SOA_GOK<1 : Break 1 : Endif
          Endif
        Endif

        If ITER =0         : # On a pas fait de r횄짤gul de TIP
         Gosub WRT_TIP
         If SOA_GOK<1 : Break 3 : Endif
        Else
         If ITER <>1   # 19/03/13 - FQ88381
           # / 73469
           Gosub INIT_TIP0
           If !SOA_GOK : Break 4 : Endif :#JIRA2198
           Gosub INIT_TIP1
           #  73469 /
           Raz [F:TIG]
           [F:TIG] = [F:TIP]
           Filter [PEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:DCG]STRDAT & PEREND(R1)>=[F:DCG]STRDAT
           Read [PEO1]PEO1 First
           If fstat
            Filter [PEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:DCG]STRDAT & PEREND(R1)>=[F:DCG]STRDAT
            Read [PEO1]PEO1 First
           Endif
           [F:TIG]DATPYR = [F:PEO1]PYRDAT
           # FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon r횄짢gle m횄짤tier
           If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
            [F:TIG]CTRDAT=func TPSSTD_SOA.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1) #done-see above
            # FQ81491 - 13/12/13 - R횄짤cup site et service du contrat trouv횄짤
            Read [F:HRCTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
            If !fstat Then
              If [F:HRCTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:HRCTR3]ETRFCY : Endif
              If [F:HRCTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:HRCTR3]ETRSRV : Endif
            Endif
           Endif
           Gosub WRT_TIP
           If SOA_GOK<1 : Break 3 : Endif
         Endif
        Endif
        [L]PDEB=2
       Endif


#Fin une 1/2 journ횄짤e et plus de 1 jour demand횄짤 (cmt WG d'apr횄짢s ligne de code avant modif 73242)
# > on cr횄짤e une ligne dans les temps pour les jours entiers d'avant la 1/2 journ횄짤e de fin
#      73242 If [L]PFIN=[L]DFIN & [F:DCG]ENDDAY=2 & [L]PDEB<[L]PFIN
       If [L]PFIN=[L]DFIN & [F:DCG]STRDAY=2 & [L]PDEB<[L]PFIN
&       & sum([L]JOUR([L]PDEB..[L]PFIN-1))
        Gosub INIT_TIP2 : # 73469
        I            =[L]PFIN-1
        Raz ITER
        For [TIP1]TIP1 Where REFNUM=[F:DCG]REFNUM & STRDAT<=[F:DCG]STRDAT+[L]PFIN-2 & ENDDAT>=[F:DCG]STRDAT+[L]PDEB-1
         # FQ105844 - 24/02/15 - Si 1/2 journ횄짤e, on v횄짤rifie qu'on n'est pas sur la m횄짧me 1/2 journ횄짤e
         If [F:DCG]STRDAT=[F:DCG]ENDDAT & [F:DCG]STRDAY<>[F:DCG]ENDDAY & ([F:DCG]STRDAY<>[F:TIP1]STRDAY | [F:DCG]ENDDAY<>[F:TIP1]ENDDAY) Then
         Else
           # La demande concerne des jours d횄짤j횄혻 saisis dans TIMEMP : que la paie soit arr횄짧t횄짤e ou pas, on passe r횄짤gul
           If [F:DCG]CTRNUM=[F:TIP1]CTRNUM | ([F:DCG]CTRNUM="" & [F:TIP1]CTRNUM=[F:CTR2]CTRNUM)
            For ITER=2 To 4
             Gosub REGUL
             If SOA_GOK<1 : Break 4 : Endif
            Next
           Endif
         Endif
        Next
    # 19/03/13 - FQ88381
    # - Si d횄짤j횄혻 en paye on passe directement en r횄짤gul
        If ITER=0 & SOA_GPAYE
#        & !([F:PEO]PERSTR(J)<=[F:DCG]STRDAT+[L]PFIN-2  & [F:PEO]PEREND(J)>=[F:DCG]ENDDAT+[L]PDEB-1)
          Filter [VEP] Where [F:VEP]EMP=[F:DCG]REFNUM & ([F:DCG]CTRNUM="" | [F:VEP]CTRNUM=[F:DCG]CTRNUM)
&                          & [F:VEP]STRDAT<=[F:DCG]STRDAT+[L]PFIN-2 & [F:VEP]ENDDAT>=[F:DCG]ENDDAT+[L]PDEB-1
&                          & [F:VEP]PYRDAT=[F:PEO]PYRDAT
          Read [VEP]VEP0 Last
          Filter [VEP]
          # FQ??? - 14/03/14 - Il faut v횄짤rifier quand m횄짧me que la date de l'absence est bien <= 횄혻 la date du dernier temps comptabilis횄짤
          # sur cette paie, sinon on risque d'oublier des temps. D'o횄쨔 le test sur DATTPS
          If !fstat & !([F:VEP]PST=1 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2 & [F:VEP]STA<>3)
&                   & [F:VEP]DATTPS>=[F:DCG]STRDAT
          # Paie g횄짤n횄짤r횄짤e ou Paie comptabilis횄짤e
            ITER=1
            Gosub REGUL
            If SOA_GOK<1 : Break 1 : Endif
          Endif
        Endif

        If ITER =0
         Gosub WRT_TIP
         If SOA_GOK<1 : Break 3 : Endif
        Else
         If ITER <>1   # 19/03/13 - FQ88381
           # / 73469
           Gosub INIT_TIP0
           If !SOA_GOK : Break 4 : Endif :#JIRA2198
           Gosub INIT_TIP2
           #  73469 /
           Raz [F:TIG]
           [F:TIG] = [F:TIP]
           Filter [PEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:DCG]STRDAT+[L]PFIN-2 & PEREND(R1)>=[F:DCG]STRDAT+[L]PDEB-1
           Read [PEO1]PEO1 First
           If fstat
            Filter [PEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:DCG]STRDAT+[L]PFIN-2 & PEREND(R1)>=[F:DCG]STRDAT+[L]PDEB-1
            Read [PEO1]PEO1 First
           Endif
           [F:TIG]DATPYR = [F:PEO1]PYRDAT
           # FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon r횄짢gle m횄짤tier
           If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
            [F:TIG]CTRDAT=func TPSSTD_SOA.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1) #done-see above
            # FQ81491 - 13/12/13 - R횄짤cup site et service du contrat trouv횄짤
            Read [F:HRCTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
            If !fstat Then
              If [F:HRCTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:HRCTR3]ETRFCY : Endif
              If [F:HRCTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:HRCTR3]ETRSRV : Endif
            Endif
           Endif
           Gosub WRT_TIP
           If SOA_GOK<1 : Break 3 : Endif
         Endif
        Endif
        [L]PDEB=[L]PFIN
       Endif

    # > on cr횄짤e le reliquat de jour dans les temps (n jours entiers ou 1/2 journ횄짤e de fin)
       If sum([L]JOUR([L]PDEB..[L]PFIN))
        Gosub INIT_TIP3  : # 73469
        I            =[L]PFIN
        Raz ITER
        For [TIP1]TIP1 Where REFNUM=[F:DCG]REFNUM & STRDAT<=[F:DCG]STRDAT+[L]PFIN-1 & ENDDAT>=[F:DCG]STRDAT+[L]PDEB-1
         # Si 1/2 journ횄짤e, on v횄짤rifie qu'on n'est pas sur la m횄짧me 1/2 journ횄짤e
         If [F:DCG]STRDAT=[F:DCG]ENDDAT & [F:DCG]STRDAY<>[F:DCG]ENDDAY & ([F:DCG]STRDAY<>[F:TIP1]STRDAY | [F:DCG]ENDDAY<>[F:TIP1]ENDDAY) Then
         Else
           # La demande concerne des jours d횄짤j횄혻 saisis dans TIMEMP : que la paie soit arr횄짧t횄짤e ou pas, on passe r횄짤gul
           If [F:DCG]CTRNUM=[F:TIP1]CTRNUM | ([F:DCG]CTRNUM="" & [F:TIP1]CTRNUM=[F:HRCTR2]CTRNUM)
            For ITER=2 To 4
             Gosub REGUL
             If SOA_GOK<1 : Break 4 : Endif
            Next
           Endif
         Endif
        Next
    # 19/03/13 - FQ88381
    # - Si d횄짤j횄혻 en paye on passe directement en r횄짤gul
        If ITER=0 & SOA_GPAYE
#        & !([F:PEO]PERSTR(J)<=[F:DCG]STRDAT+[L]PFIN-1 & [F:PEO]PEREND(J)>=[F:DCG]ENDDAT+[L]PDEB-1)
          Filter [VEP] Where [F:VEP]EMP=[F:DCG]REFNUM & ([F:DCG]CTRNUM="" | [F:VEP]CTRNUM=[F:DCG]CTRNUM)
&                          & [F:VEP]STRDAT<=[F:DCG]STRDAT+[L]PFIN-1 & [F:VEP]ENDDAT>=[F:DCG]ENDDAT+[L]PDEB-1
&                          & [F:VEP]PYRDAT=[F:PEO]PYRDAT
          Read [VEP]VEP0 Last
          Filter [VEP]
          # FQ??? - 14/03/14 - Il faut v횄짤rifier quand m횄짧me que la date de l'absence est bien <= 횄혻 la date du dernier temps comptabilis횄짤
          # sur cette paie, sinon on risque d'oublier des temps. D'o횄쨔 le test sur DATTPS
          If !fstat & !([F:VEP]PST=1 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2 & [F:VEP]STA<>3 )
&                   & [F:VEP]DATTPS>=[F:DCG]STRDAT
          # Paie g횄짤n횄짤r횄짤e ou Paie comptabilis횄짤e
            ITER=1
            Gosub REGUL
            If SOA_GOK<1 : Break 1 : Endif
          Endif
        Endif

        If ITER =0
         Gosub WRT_TIP
         If SOA_GOK<1 : Break 3 : Endif
        Else
         If ITER <>1   # 19/03/13 - FQ88381
           # / 73469
           Gosub INIT_TIP0
           If !SOA_GOK : Break 4 : Endif :#JIRA2198
           Gosub INIT_TIP3
           #  73469 /
           Raz [F:TIG]
           [F:TIG] = [F:TIP]
           Filter [PEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:DCG]STRDAT+[L]PFIN-1 & PEREND(R1)>=[F:DCG]STRDAT+[L]PDEB-1
           Read [PEO1]PEO1 First
           If fstat
            Filter [PEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:DCG]STRDAT+[L]PFIN-1 & PEREND(R1)>=[F:DCG]STRDAT+[L]PDEB-1
            Read [PEO1]PEO1 First
           Endif
           [F:TIG]DATPYR = [F:PEO1]PYRDAT
           # FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon r횄짢gle m횄짤tier
           If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
            [F:TIG]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1)
            # FQ81491 - 13/12/13 - R횄짤cup site et service du contrat trouv횄짤
            Read [F:HRCTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
            If !fstat Then
              If [F:HRCTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:HRCTR3]ETRFCY : Endif
              If [F:HRCTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:HRCTR3]ETRSRV : Endif
            Endif
           Endif
           Gosub WRT_TIP
           If SOA_GOK<1 : Break 3 : Endif
         Endif
        Endif
       Endif
      Endif
     Next
    Endif
   Next
  Next
 Endif
Next
Filter [PEO]
Filter [LNK]
If SOA_GOK<1 : Return : Endif
Return
#-------------------------------------------------------------------------------
# / 73469
$INIT_TIP0
# Partie commune d'enregistrement destin횄짤e aux temps
Raz [F:TIP]
[F:TIP]REFNUM=[F:HRCTR2]REFNUM
[F:TIP]CTRNUM=[F:HRCTR2]CTRNUM
[F:TIP]FCY   =[F:HRCTR2]ETRFCY
[F:TIP]SRV   =[F:HRCTR2]ETRSRV
#JIRA2198
#It's not the best solution, but I have no time to rewrite all this awfull program
If SOA_GPAYE and SOA_GTPS
 Filter [F:VEP] Where EMP=[F:TIP]REFNUM & [F:VEP]CTRNUM=[F:TIP]CTRNUM & PYRDAT=[F:PEO]PYRDAT
 Read [VEP]VEP0 Last
 Filter [VEP]
 If !fstat  & [F:VEP]STA>1
  Filter [F:PEO2] Where FCY=[F:PEO]FCY & PYRDAT>[F:PEO]PYRDAT
  Read [F:PEO2]PEO0 First
  Filter [F:PEO2]
  If !fstat
    [F:TIP]DATPYR=[F:PEO2]PYRDAT
  Else
    # Op횄짤ration impossible :  Paye d횄짤j횄혻 calcul횄짤e
    SOA_GMESSAGE = mess(157,123,1)-":"-num$([F:PEO]PYRDAT)-mess(15,709,1)
    SOA_GOK=0 : Raz [F:TIP]
    ASTATUS = fmet this.ASETERROR("",SOA_GMESSAGE,[V]CST_AERROR)
    Return
  Endif
 Else
  [F:TIP]DATPYR=[F:PEO]PYRDAT
 Endif
Else
  [F:TIP]DATPYR=[F:PEO]PYRDAT
Endif
#End JIRA2198
[F:TIP]TIM   =[F:DCG]TIM
[F:TIP]TYPPGN=[F:DCG]TYPPGN
[F:TIP]AUTFLG =2
[F:TIP]STAFLG =SOA_GUSER
[F:TIP]STA    =0 : # 횄혻 quoi 횄짠a sert ?
[F:TIP]ANAFLG=0
[F:TIP]DSP   =""
# FQ82073 - 18/12/12 - Initialisation de TIP.CTRDAT selon r횄짢gle m횄짤tier
If [F:TIP]CTRDAT=[0/0/0] & [F:TIP]ENDDAT<>[0/0/0] Then
  [F:TIP]CTRDAT=func TPSSTD_SOA.CALC_CTRDATDEF([F:TIP]REFNUM,[F:TIP]CTRNUM,[F:TIP]ENDDAT,[F:TIP]DATPYR,[F:TIP]ENDDAT,1)  #done-see above
  #If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
  Read [F:HRCTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
  If !fstat Then
    If [F:HRCTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:HRCTR3]ETRFCY : Endif
    If [F:HRCTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:HRCTR3]ETRSRV : Endif
  Endif
Endif
# FQ92876 - 26/06/14 - Ajout [F:TIP]CPY utilis횄짤 dans INISEC_DSP_EMPTY
[F:TIP]CPY= func DIVPAYE_SOA.GETSOC([F:TIP]FCY)
Gosub INICCE
If dim([F:TIP]CREUSR)>0 : [F:TIP]CREUSR=SOA_GUSER  : Endif
If dim([F:TIP]CREDAT)>0 : [F:TIP]CREDAT=date$     : Endif
If dim([F:TIP]CRETIM)>0 : [F:TIP]CRETIM=time      : Endif
If dim([F:TIP]EXPNUM)>0 : [F:TIP]EXPNUM=[C]EXPORT : Endif     #leave as is
Return
#-------------------------------------------------------------------------------
$INIT_TIP1
# Demi-journ횄짤e de d횄짤but d'absence
[F:TIP]STRDAT=[F:DCG]STRDAT
[F:TIP]ENDDAT=[F:DCG]STRDAT
#73242  [F:TIP]STRDAY=2
#73242  [F:TIP]ENDDAY=1
[F:TIP]STRDAY=1
[F:TIP]ENDDAY=2
[F:TIP]NBRDAY=[L]JOUR(1)
[F:TIP]NBRHOU=[L]HEURE(1)
# FQ82073 - 18/12/12 - Initialisation de TIP.CTRDAT selon r횄짢gle m횄짤tier
If [F:TIP]CTRDAT=[0/0/0] & [F:TIP]ENDDAT<>[0/0/0] Then
  [F:TIP]CTRDAT=func TPSSTD_SOA.CALC_CTRDATDEF([F:TIP]REFNUM,[F:TIP]CTRNUM,[F:TIP]ENDDAT,[F:TIP]DATPYR,[F:TIP]ENDDAT,1) # done - see above
  # FQ81491 - 13/12/13 - R횄짤cup site et service du contrat trouv횄짤
  #If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
  Read [F:HRCTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
  If !fstat Then
    If [F:HRCTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:HRCTR3]ETRFCY : Endif
    If [F:HRCTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:HRCTR3]ETRSRV : Endif
  Endif
Endif
Return
#-------------------------------------------------------------------------------
$INIT_TIP2
# Demi-journ횄짤e de fin d'absence
[F:TIP]STRDAT=[F:DCG]STRDAT+[L]PDEB-1
[F:TIP]ENDDAT=[F:DCG]STRDAT+[L]PFIN-2
[F:TIP]STRDAY=1
[F:TIP]ENDDAY=1
[F:TIP]NBRDAY=sum([L]JOUR([L]PDEB..[L]PFIN-1))
[F:TIP]NBRHOU=sum([L]HEURE([L]PDEB..[L]PFIN-1))
# FQ82073 - 18/12/12 - Initialisation de TIP.CTRDAT selon r횄짢gle m횄짤tier
If [F:TIP]CTRDAT=[0/0/0] & [F:TIP]ENDDAT<>[0/0/0] Then
  [F:TIP]CTRDAT=func TPSSTD_SOA.CALC_CTRDATDEF([F:TIP]REFNUM,[F:TIP]CTRNUM,[F:TIP]ENDDAT,[F:TIP]DATPYR,[F:TIP]ENDDAT,1) # done - see above
  # FQ81491 - 13/12/13 - R횄짤cup site et service du contrat trouv횄짤
  #If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
  Read [F:HRCTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
  If !fstat Then
    If [F:HRCTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:HRCTR3]ETRFCY : Endif
    If [F:HRCTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:HRCTR3]ETRSRV : Endif
  Endif
Endif
Return
#-------------------------------------------------------------------------------
$INIT_TIP3
# Reliquat des jours
[F:TIP]STRDAT = [F:DCG]STRDAT+[L]PDEB-1
[F:TIP]ENDDAT = [F:DCG]STRDAT+[L]PFIN-1
#  74073 (suite de 73242) [F:TIP]STRDAY = 1+([L]PDEB=1 & [F:DCG]STRDAY=2)
#  74073 (suite de 73242) [F:TIP]ENDDAY = 1+([L]PFIN=[L]DFIN & [F:DCG]ENDDAY=2)
[F:TIP]STRDAY = 1+([L]PFIN=[L]DFIN & [F:DCG]STRDAY=2)
[F:TIP]ENDDAY = 1+([L]PDEB=1 & [F:DCG]ENDDAY=2)
[F:TIP]NBRDAY = sum([L]JOUR([L]PDEB..[L]PFIN))
[F:TIP]NBRHOU = sum([L]HEURE([L]PDEB..[L]PFIN))
# FQ82073 - 18/12/12 - Initialisation de TIP.CTRDAT selon r횄짢gle m횄짤tier
If [F:TIP]CTRDAT=[0/0/0] & [F:TIP]ENDDAT<>[0/0/0] Then
  [F:TIP]CTRDAT=func TPSSTD_SOA.CALC_CTRDATDEF([F:TIP]REFNUM,[F:TIP]CTRNUM,[F:TIP]ENDDAT,[F:TIP]DATPYR,[F:TIP]ENDDAT,1) # done-see above
  # FQ81491 - 13/12/13 - R횄짤cup site et service du contrat trouv횄짤
  #If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
  Read [F:HRCTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
  If !fstat Then
    If [F:HRCTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:HRCTR3]ETRFCY : Endif
    If [F:HRCTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:HRCTR3]ETRSRV : Endif
  Endif
Endif
Return
#   73469 /
#-------------------------------------------------------------------------------
$REGUL
# ITER=1 : On passe la demande en r횄짤gul dans [TIG] car p횄짤riode pass횄짤e ([TIG]=TIMREGUL si GTPS=1 sinon TIMEMP)
# ITER=2 : On passe une r횄짤gul dans [TIG], pour annuler les temps d횄짤j횄혻 saisis dans TIMEMP sur p횄짤riode pass횄짤e
# On passe une r횄짤gul pour cr횄짤er les temps d횄짤j횄혻 saisis dans TIMEMP qui ne se chevauchent pas avec la demande
# ITER=3 : R횄짤gul de [F:TIP1]STRDAT 횄혻 [F:DCG]STRDAT-1
# ITER=4 : R횄짤gul de [F:DCG]ENDDAT+1 횄혻 [F:TIP1]ENDDAT

Raz [F:TIG]
Case ITER
 When 1
  [F:TIG] = [F:DCG]
  [F:TIG]CTRNUM=[F:HRCTR2]CTRNUM
  [F:TIG]FCY   =[F:HRCTR2]ETRFCY
  [F:TIG]SRV   =[F:HRCTR2]ETRSRV
  Filter [PEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:DCG]STRDAT & PEREND(R1)>=[F:DCG]ENDDAT
  Read [PEO1]PEO1 First
  If fstat
   Filter [PEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:DCG]STRDAT & PEREND(R1)>=[F:DCG]ENDDAT
   Read [PEO1]PEO1 First
  Endif
 When 2
  [F:TIG] = [F:TIP1]
  [F:TIG]NBRHOU = -1*[F:TIP1]NBRHOU
  [F:TIG]NBRDAY = -1*[F:TIP1]NBRDAY
  # FQ92876 - 13/10/14 - Ajout test sur [F:TIM] car selon l횄혻 d'o횄쨔 est appel횄짤e l'횄짤tiquette REGUL, la classe [F:TIM] peut ne pas 횄짧tre valoris횄짤e
  If [F:TIP]TIM<>"" Then
    # Cas d'une demande de 0.5CP alors qu'on a dans TIMEMP 0.5CP et 0.5W ou 1RTT
    If [F:TIP]NBRDAY<1
     If [F:TIP1]NBRDAY=[F:TIP]NBRDAY
      If [F:TIP1]STRDAY<>[F:TIP]STRDAY | [F:TIP1]ENDDAY<>[F:TIP]ENDDAY
       If OLDDATDEMI <> [F:TIP1]STRDAT
        OLDDATDEMI = [F:TIP1]STRDAT
        Raz [TIG] : # pour ne pas passer de r횄짤gul
       Else
        [F:TIG]TIM = GTPSW
        [F:TIG]STRDAY = 0
        [F:TIG]ENDDAY = 0
        Raz OLDDATDEMI
       Endif
      Else
       Raz OLDDATDEMI
      Endif
     Elsif [F:TIP]NBRDAY<[F:TIP1]NBRDAY
      [F:TIG]NBRHOU = -1*[F:TIP]NBRHOU
      [F:TIG]NBRDAY = -1*[F:TIP]NBRDAY
      Read [TIM2]TIM0=[F:TIP1]TIM
      If !fstat & [F:TIM2]CATTIM<>1
       [F:TIG]STRDAY = [F:TIP]STRDAY
       [F:TIG]ENDDAY = [F:TIP]NBRDAY
      Endif
     Endif
    Else
     Raz OLDDATDEMI
    Endif
  Endif
  Filter [PEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:TIP1]STRDAT & PEREND(R1)>=[F:TIP1]ENDDAT
  Read [PEO1]PEO1 First
  If fstat
   Filter [PEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:TIP1]STRDAT & PEREND(R1)>=[F:TIP1]ENDDAT
   Read [PEO1]PEO1 First
  Endif
 When 3 :# Saisie d'un nombre positif de cong횄짤
  If [F:TIP1]STRDAT<[F:DCG]STRDAT
   [F:TIG] = [F:TIP1]
   [F:TIG]ENDDAT = [F:DCG]STRDAT-1
   Call VALORIS([F:TIG]STRDAT,[F:TIG]ENDDAT,[F:TIG]REFNUM,[F:TIG]TIM,[F:TIG]NBRDAY,[F:TIG]NBRHOU,[F:TIG]FCY,[F:TIG]CTRNUM) From SUBPLN_SOA #done-see above
   Filter [PEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:TIG]STRDAT & PEREND(R1)>=[F:TIG]ENDDAT
   Read [PEO1]PEO1 First
   If fstat
    Filter [PEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:TIG]STRDAT & PEREND(R1)>=[F:TIG]ENDDAT
    Read [PEO1]PEO1 First
   Endif
  Endif
 When 4
  If [F:DCG]ENDDAT<[F:TIP1]ENDDAT
   [F:TIG] = [F:TIP1]
   [F:TIG]STRDAT = [F:DCG]ENDDAT+1
   Call VALORIS([F:TIG]STRDAT,[F:TIG]ENDDAT,[F:TIG]REFNUM,[F:TIG]TIM,[F:TIG]NBRDAY,[F:TIG]NBRHOU,[F:TIG]FCY,[F:TIG]CTRNUM) From SUBPLN_SOA #done-see above
   Filter [PEO1] Where FCY=LESITE & (PERSTR(R1)-R2)<=[F:TIG]STRDAT & PEREND(R1)>=[F:TIG]ENDDAT
   Read [PEO1]PEO1 First
   If fstat
    Filter [PEO1] Where FCY="" & (PERSTR(R1)-R2)<=[F:TIG]STRDAT & PEREND(R1)>=[F:TIG]ENDDAT
    Read [PEO1]PEO1 First
   Endif
  Endif
Endcase

If [F:TIG]STRDAT=[0/0/0] : Return : Endif : # on est pas pass횄짤 par le Case

If !fstat
 [F:TIG]DATPYR=[F:PEO1]PYRDAT
Endif
#62192
##[F:TIG]CTRNUM=[F:CTR2]CTRNUM
##[F:TIG]FCY   =[F:CTR2]ETRFCY
##[F:TIG]SRV   =[F:CTR2]ETRSRV
[F:TIG]DCGUID=[F:DCG]UID
[F:TIG]AUTFLG =2
[F:TIG]STAFLG =SOA_GUSER
[F:TIG]STA    =0 : # 횄혻 quoi 횄짠a sert ?
[F:TIG]ANAFLG=0
[F:TIG]DSP   =""
# FQ105844 - 24/02/15 - Le FLGBUL ne sert plus, le champ DATPYR est suffisant
##[F:TIG]FLGBUL = 2
If dim([F:TIG]CREUSR)>0 : [F:TIG]CREUSR=SOA_GUSER  : Endif
If dim([F:TIG]CREDAT)>0 : [F:TIG]CREDAT=date$     : Endif
If dim([F:TIG]CRETIM)>0 : [F:TIG]CRETIM=time      : Endif
If dim([F:TIG]EXPNUM)>0 : [F:TIG]EXPNUM=[C]EXPORT : Endif   #leave as is

Gosub INICCE

[F:TIG]LIG   =uniqid([TIP])
# FQ82073 - 18/12/12 - Initialisation de TIG.CTRDAT selon r횄짢gle m횄짤tier
If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0]  Then
  [F:TIG]CTRDAT=func TPSSTD_SOA.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1) # done-see above
  # FQ81491 - 13/12/13 - R횄짤cup site et service du contrat trouv횄짤
  #If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
  Read [F:HRCTR3]CTR0=[F:TIG]REFNUM;[F:TIG]CTRNUM;[F:TIG]CTRDAT
  If !fstat Then
    If [F:HRCTR3]ETRFCY<>"" Then [F:TIG]FCY=[F:HRCTR3]ETRFCY : Endif
    If [F:HRCTR3]ETRSRV<>"" Then [F:TIG]SRV=[F:HRCTR3]ETRSRV : Endif
  Endif
Endif
Write [F:TIG]
If fstat
 SOA_ABR = "TIG"
 Gosub GLOCK_FSTA
 Return
Endif

If ITER=1
 If SOA_GTPS
  Case [F:DCG]WRK
   When "C" : [L]WRK=mess(75,709,1) : # Ajout
   When "M" : [L]WRK=mess(77,709,1) : # Modif (apr횄짢s)
  Endcase
  Gosub WORKFLOW From TPSSTD_SOA  # done
 Endif
Else
 Raz [L]JOUR1
 Read [TIM2]TIM0=[F:TIG]TIM
 If [F:TIM2]CATTIM=3
  If ITER=2
   # Nombre n횄짤gatif de cong횄짤
   If [F:TIG]STRDAT<>[F:TIG]ENDDAT
    Call VALORDET([F:TIG]STRDAT,[F:TIG]ENDDAT,[F:TIG]REFNUM,[F:TIG]TIM,[L]JOUR1,[L]HEURE,[F:TIG]FCY,[F:TIG]CTRNUM) From SUBPLN_SOA #done-see above
   Else
    [L]JOUR1(1) = [F:TIG]NBRDAY
   Endif
   SOA_GOK = 1
   Raz SOA_ERRMSG
   Call ADD_CPREG([L]JOUR1,SOA_GOK,SOA_ERRMSG) From TPSSTDR1_SOA    #done
   If SOA_GOK<1
     ASTATUS = fmet this.ASETERROR("",SOA_ERRMSG,[V]CST_AERROR)
     Return
   Endif
  Else
   # Nombre positif de cong횄짤
   Call VALORDET([F:TIG]STRDAT,[F:TIG]ENDDAT,[F:TIG]REFNUM,[F:TIG]TIM,[L]JOUR1,[L]HEURE,[F:TIG]FCY,[F:TIG]CTRNUM) From SUBPLN_SOA #done-see above
   Raz [F:TIP]
   [F:TIP] = [F:TIG]
   SOA_GOK = 1
   Raz SOA_ERRMSG
   Call ADD_CPPRIS(this.LEG,[L]JOUR1,SOA_GOK,SOA_ERRMSG) From TPSSTD1_SOA    #done
   If SOA_GOK<1
     ASTATUS = fmet this.ASETERROR("",SOA_ERRMSG,[V]CST_AERROR)
     Return
   Endif
  Endif
 Endif
Endif

Return
#-------------------------------------------------------------------------------
$INICCE
[F:HRCTR]=[F:HRCTR2]
# FQ92876 - 23/06/14 - Ajout axe dans les temps
Local Char ABREVT(3) #, NAT(GLONNAT)
If SOA_GTPS
 If ITER=0
  ABREVT="TIP"
 Else
  ABREVT="TIG"
 Endif
# NAT=evalue("[F:"+ABREVT+"]NATCOD")
