# Gestion du masque CFGINPS

##########################################################################
## Etiquette ajoutée par le superviseur 03/12/2003 14:02:37 (JPJ1)
##########################################################################
Subprog AM_SELNUM(VALEUR)        # Code sélection
Variable Char    VALEUR()
If VALEUR <> ""
  Read [CSE]CSE0=VALEUR
  If fstat
    mkstat = 2
  Else
    [M:CFGI]SELNUMTXT = [F:CSE]SELDES
    Affzo [M:CFGI]SELNUMTXT
  Endif
Else
  [M:CFGI]SELNUMTXT = ""
  Affzo [M:CFGI]SELNUMTXT
Endif
End

##########################################################################
