########################################################################################
########################################################################################
$AVANT_MOD
  # FGR 29/08/2014 : X3SUIVI95632
  If find("GESAIN", GNAVIG(1..GPILNAV-1)) <> 0 Then
    If [M:BPR1]BETFCY = 2 Then
      mkstat = 2
      GMESSAGE = mess(1152,196,1)
      Return
    Endif
  Endif
Return

########################################################################
##############   ACTIONS STANDARDS #####################################
########################################################################
$OUVRE
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#----- Chargement du GSOCIETE en fonction du site par défaut "Tronc commun" -----#
GCUR=GLOCALDEV
GFCYDEF(0)=GFCYDEF(9)
If GFONC1="GESBPR"
  If GFCYDEF(0)<>""
    Call GETDEV(GFCYDEF(0)) From DEVSUB : GCUR=GLOCALDEV
  Else
    Raz GSOCIETE : GLOCALDEV=GSYSCUR : GCUR=GSYSCUR
  Endif

  # Si multi-législation, ne pas charger de société et législation par défaut
  If GNBLEG>1
     Raz GSOCIETE, GCURLEG
  Endif

  Raz GCURFCY  # FGR 05/02/2010 : X3SUIVI62225
Endif
#-----

Global Integer GIOBPR_MODIF
GIOBPR_MODIF=0

#JPGA : Déclinaisons Société / BPEXCEPT : Ouverture tables pour [M:BPE]
Gosub OUVRE_BPE From BPEXCEPT

Local Integer WBPATYP : WBPATYP = 1

#Local Char OBJET(GLONAOB)
#OBJET = "BPC" : Gosub SETNUM From WWCPY : Gosub OUVRE From WWCPY
#OBJET = "BPS" : Gosub SETNUM From WWCPY : Gosub OUVRE From WWCPY

#---- Initialisation du code comptable par défaut
#MAE, le 06/01/09, SUP_GACCCOD
#Call INITACCCOD(GACCCOD,17) From TRTX3

#Initialisation CRM
Gosub OUVRE_CRM From TRTBPCRM
GSZCRMOBJET="BPR"

Local Integer VII
VII=func AFNC.ACTIV("VII")

Local Char HSGRUGPY(1)
If !func AFNC.ACTIV("CSL") & !func AFNC.ACTIV("PBDCL")
  HSGRUGPY = "-"
Endif

Return

########################################################################
$SETBOUT
#----------------------------------------------------#
# suppression bouton changment de code               #
#----------------------------------------------------#
Call VIREBOUT(CHAINE,"H") From GOBJET
If GREP <> ""
   Call VIREBOUT (CHAINE,"12345") From GOBJET
Elsif GACTFTC<>2
   Call VIREBOUT (CHAINE,"345") From GOBJET
Endif
# Si tiers client, suppression bouton prospect
If CLECUR & [M]BPCFLG=2 Call VIREBOUT (CHAINE,"5") From GOBJET : Endif
# Si tiers prospect, suppression bouton client
If CLECUR & dim([M]PPTFLG)>0 & [M]PPTFLG=2 Call VIREBOUT (CHAINE,"1") From GOBJET : Endif
# ----------------------------------------------------------------------------------------- #
# Activation/Désactivation des menus                                                        #
# ----------------------------------------------------------------------------------------- #
# D : Consultations cpts  : Actif si tiers en ligne                                         #
# X : Consultations parc  : Actif si rien en cours,module support client                    #
# ù : Consultations parc par adresse : Actif si rien en cours,module support client         #
# ç : Consultations parc agrégé : Actif si rien en cours,module support client              #
# S : Infos prestataires  : Actif si rien en cours,module support client,tiers prestataire  #
# U : Infos donneur ordre : Actif si rien en cours,module support client,tiers donneur ordre#
# P : Historique          : Actif si rien en cours,module support client                    #
# B : Secteurs de marché  : Actif si rien en cours et tiers prospect ou client module action commerciale  #
# ----------------------------------------------------------------------------------------- #
If CLECUR   CHMEN += "D"  Endif

If REP="" & GMODU(12)=2 & GACTFTC=2
#LSE 30/09/2005 FQ 32310
#    CHMEN += "X%ùç"
    If [M:BPR1]BPCFLG=2
        CHMEN += "X%ùç"
    Else
        CHMEN += "Xùç"
    Endif
Endif
If REP="" & GMODU(12)=2 & GACTFTC=2 & [M:BPR1]PRVFLG=2 CHMEN += "S"     Endif
If REP="" & GMODU(12)=2 & GACTFTC=2 & [M:BPR1]DOOFLG=2 CHMEN += "U"     Endif
If REP=""
    If GMODU(13)=2 & GACTFTC=2
        If [M:BPR1]BPCFLG = 2 | [M:BPR1]PPTFLG = 2
            CHMEN += "B"
        Endif
    Endif
Endif

# FGR 16/10/2009 : DEBRAYE POUR LA V6. SERA DANS LA V7
#Historique
# FGR 10/08/2009 : X3SUIVI56700 : Toujours actif qq soit le module mais uniquement pour client et prospects
##If REP="" & (GMODU(12)=2 | GMODU(13)=2) & GACTFTC=2
#If REP = "" and ([M:BPR1]PPTFLG = 2 or [M:BPR1]BPCFLG = 2) Then
#    CHMEN += "P"
#Endif

#Menu Actions   Module Action Co
# } : Enregistrer un rendez-vous
# { : Enregistrer un appel
# ~ : Enregistrer une tâche
# ! : Enregistrer une affaire

# ) : Planifier un rendez-vous
# ( : Planifier un appel
# £ : Planifier une tâche

If REP="" & GMODU(13)=2 & GACTFTC=2
    CHMEN += "}{~!)(£"
Endif

Gosub SET_BOUT_SPE From GSAISIE

Return

########################################################################
$EXEBOUT
Local Char SGBOITE

SGBOITE=GBOITE
GBOITE =""

#-----------------------------------------#
# execution  des boutons supplémentaires  #
#-----------------------------------------#
Case REP
     When "1","2","3","4","5"
#       ---------------------------------------#
#       il faut réafficher BPR1 correctement   #
#       ---------------------------------------#
        Gosub $RELIT From GOBJSUB
Endcase

GBOITE=SGBOITE
Return


###########################################################################################
#    Après execution des menus;;                                                          #
###########################################################################################
$STATUT

#Case BOUT
#    When "B"
#        #LSE 13/03/2007 rechargement si modif apres action SAIMST9
#        If GIOBPR_MODIF=1
#            If !GIMPORT Gosub RELIT From GOBJSUB : Endif
#        Endif
#
#
#Endcase

Return

########################################################################
$AVANTBOUT
[M:BPR0]NVGCOD = BOUT

# FGR 02/04/2015 : X3SUIVI109045 (début)
If BOUT = "5" Then
  Local Integer IERR
  Local Char SMESSAGE(type(GMESSAGE)-10)

  Call CTRL_TRSF_BPR_BPEXCEPT([M:BPR0]BPRNUM, IERR, SMESSAGE) From TRTVENSDD
  If IERR <> 0 Then
    GERR = 1
    GMESSAGE = SMESSAGE
    Return
  Endif
Endif
# FGR 02/04/2015 : X3SUIVI109045 (fin)

If GMODU(13)=2
    Case BOUT
        When ")"
            #Planifier Rendez-vous
            GBCRMFLGNEW=1
        When "("
            #Planifier Appel
            GBCRMFLGNEW=1
        When "£"
            #Planifier tache
            GBCRMFLGNEW=1

        When "}"
            #Enregistrer Rendez-vous
            GBCRMFLGNEW=1
        When "{"
            #Enregistrer Appel
            GBCRMFLGNEW=1
        When "~"
            #Enregistrer tache
            GBCRMFLGNEW=1
        When "!"
            #Enregistrer une affaire
            GBCRMFLGNEW=1


    Endcase
Endif

Return

########################################################################
$LIENS
  #----------------------------------#
  # A chaque lecture enregistrement  #
  #----------------------------------#
  [M:BPR0] = [F:BPR]
  [M:BPR0]BPRNAM1 = [F:BPR]BPRNAM   # FGR 28/07/2010 : X3SUIVI66285 bizarre mais fonctionne si on change le nom du champ !

  #If [M]SOC="" & GSOCIETE=""
  #  Call GETDEV(GFCYDEF(0)) From DEVSUB
  #Endif
  #[M]SOC = GSOCIETE

  #If dim([M:BPR0]SOC)>0
  #  GSOCIETE = [M:BPR0]SOC
  #Endif

  #---------------------------------------#
  #        A SUPPRIMER                    #
  #---------------------------------------#
  # on initialise les masques RAZ         #
  #   on remplit les  écrans concernés    #
  #---------------------------------------#
  #   ecran adresse BPA                   #
  #   ecran RIB BID                       #
  #   ecran contact CNT                   #
  #---------------------------------------#
  # paramètre numéro entité = tiers       #
  #           type entité   = 1           #
  #---------------------------------------#
  #Call CHARG_BPA (GABREV,[M:BPR0]BPRNUM,1,[F:BPR]BPAADD) From TRTADR
  #Call CHARG_RIB (GABREV,[M:BPR0]BPRNUM,1,"~") From TRTADR
  #Call CHARG_CNT (GABREV,[M:BPR0]BPRNUM,1,[F:BPR]CNTNAM) From TRTADR
  #---------------------------------------#

  Default Mask [BPAB]
  Call CHARG_BPA(WBPATYP,[M:BPR0]BPRNUM,[F:BPR]BPAADD) From TRTBPA
  Default Mask [BIDB]
  Call CHARG_RIB(WBPATYP,[M:BPR0]BPRNUM,"~") From TRTBPA
  Default Mask [CNTB]
  Call CHARG_CNT(WBPATYP,[M:BPR0]BPRNUM,[F:BPR]CNTNAM) From TRTBPA

  #JPGA : Déclinaisons Société / BPEXCEPT : chargement du masque [M:BPE]
  Call CHARG_EXC ([M:BPR0]BPRNUM) From BPEXCEPT

  #Lecture de la catégorie
  If [F:BPR]BRGCOD<>""
    If [F:BPR]BRGOBJ = "BPC"
      If !clalev([F:BCG]) : Local File BPCCATEG [BCG] : Endif
      Read [BCG]BCG0=[F:BPR]BRGCOD
      [M:BPR0]REFCOU=[F:BCG]REFCOU
      Call GET_ATEXTRA("BPCCATEG", "DESAXX", GLANGUE, [M:BPR0]BRGDES) From TRTX3TEX
    Else
      If !clalev([F:BSG]) : Local File BPSCATEG [BSG] : Endif
      Read [BSG]BSG0=[F:BPR]BRGCOD
      [M:BPR0]REFCOU=[F:BSG]REFCOU
       Call GET_ATEXTRA("BPSCATEG", "DESAXX", GLANGUE, [M:BPR0]BRGDES) From TRTX3TEX
     Endif
  Endif
  Affzo [M:BPR0]BRGDES
  #
  Gosub DEFAUT
  #LSE 02/03/2007
  #---------------------------------------------------#
  ##Modif CRM 6/02/2002
  #If GMODU(13) = 2
  #    Call SETPREREP("BPR") From TRTMST4
  #Endif
  ##---------------------------------------------------#
  #Initialisation CRM
  Gosub LIENS_CRM From TRTBPCRM
  Gosub GRIZE_LIENS
  #MAE, lecture du tiers pour les workflows, ne pas écraser, bg 67131
If !GIMPORT
  If !clalev([F:BPRW]) : Local File BPARTNER [BPRW] : Endif
  If [M:BPR0]BPRNUM <> ""
    Read [BPRW]BPR0 = [M:BPR0]BPRNUM
    If fstat Raz [F:BPRW] Endif
  Endif
Endif

For nolign=1 To [M:BIDB]NBRIB
 [M:BIDB]OBIDBPAADD(nolign-1) = [M:BIDB]BIDBPAADD(nolign-1)
 [M:BIDB]OBIDNUM(nolign-1) = [M:BIDB]BIDNUM(nolign-1)
 If [L]VII : [M:BIDB]OBICCOD(nolign-1) = [M:BIDB]BICCOD(nolign-1) : Endif
Next
Return

####################################################################
$DEFAUT
  For MA=0 To NBMASK
    If AMA(MA)
      Gosub SETMASK From="WGO"+GABREV
    Endif
  Next MA
Return

####################################################################
$GRIZE_LIENS
#------------------------------------------------------------#
# Activation/Desactivation des zones en fonction du contexte #
#------------------------------------------------------------#

If dim([M:BPR1]BETFCY)>0
   If [M:BPR1]BETFCY = 2
      Actzo [M:BPR1]FCY
   Else
      Grizo [M:BPR1]FCY
   Endif
Endif
If [M:BPR1]BPRACC=2
    Actzo [M:BPR2]ACCCOD
    Actzo [M:BPR2]BPRGTETYP
Else
    Diszo [M:BPR2]ACCCOD
    Diszo [M:BPR2]BPRGTETYP
Endif

# Issue 119282 - 2016-10-21 by RMA : GRUGPY without activity code
Chgfmt [M:BPR2]GRUGPY With [L]HSGRUGPY+"K:5c"

# saisie de la consolidation si tiers appartient à un périmètre de consolidation  #
If dim([M:BPR2]GRUCOD) > 0
    If [M:BPR2]GRUGPY=""
        Raz   [M:BPR2]GRUCOD
        Grizo [M:BPR2]GRUCOD
    Else
        Actzo [M:BPR2]GRUCOD
    Endif
Endif

# 2015-04-23 DNE INSERT BEGIN (SAM #85794-3 / SAM #115533)
If dim( [M:BPR2]CPYREL ) > 0
    If [M:BPR2]GRUGPY = ""
        [M]CPYREL = 1
        Grizo [M:BPR2]CPYREL
    Else
        Actzo [M:BPR2]CPYREL
    Endif
Endif
# 2015-04-23 DNE INSERT END
Return

######################################################################
$RAZCRE
[M:BPR0]ENAFLG = 2

#If dim([M:BPR0]SOC)>0
#    GSOCIETE = [M:BPR0]SOC
#Endif

[M:BPR1]CRY = GPAYS
If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
If [F:TCY]CRY <> GPAYS
    Read [TCY]TCY0 = GPAYS
    If fstat Raz [F:TCY] Endif
Endif
[M:BPR1]LAN = [F:TCY]LAN
[M:BPR1]CUR = [F:TCY]CUR


#-----------------------------------------------#
# il faut initialiser le type entite de adresse #
# sinon on ne recupère pas le pays              #
#-----------------------------------------------#
[F:BPA]BPATYP = WBPATYP

#[M:BPR2]ACCCOD = GACCCOD

#Affzo [M:BPR1]CRY, LAN, CUR
#Affzo [M:BPR2]ACCCOD

#------------------------------------------------------------#
# Activation/Desactivation des zones en fonction du contexte #
#------------------------------------------------------------#
If dim([M:BPR1]BETFCY)>0 Grizo [M:BPR1]FCY Endif

If [M:BPR1]BPRACC=2
    Actzo [M:BPR2]ACCCOD
Else
    Diszo [M:BPR2]ACCCOD
Endif
# saisie de la consolidation si tiers appartient à un périmètre de consolidation  #
If dim([M:BPR2]GRUCOD) > 0
    Raz   [M:BPR2]GRUCOD
    Grizo [M:BPR2]GRUCOD
Endif

# 2015-04-23 DNE INSERT BEGIN (SAM #85794-3)
If dim( [M:BPR2]CPYREL ) > 0
    [M:BPR2]CPYREL = 1
    Grizo [M:BPR2]CPYREL
Endif
# 2015-04-23 DNE INSERT END


#CRM
Gosub RAZCRE_CRM From TRTBPCRM
#LSE 06/02/2007
Affzo [M:BPR0]1-99
Affzo [M:BPR1]1-99
Affzo [M:BPAB]1-99
Affzo [M:BPR2]1-99
Affzo [M:BIDB]1-99
Affzo [M:CNTB]1-99

Return

######################################################################
$RAZDUP

#---------------------------------------------------#
#Modif CRM 6/12/2002
#---------------------------------------------------#
#Voulez-vous partager les interlocuteurs de la société XXXX ?
Local Integer IASKBPR
Local Char SZMESS(250)
IASKBPR = 0

If [M:CNTB]NBCNT > 0
    SZMESS = mess(834, 196, 2) + ' ' + [M:BPR0]BPRNUM
    Call OUINON(SZMESS, IASKBPR) From GESECRAN
    If IASKBPR <> 2
        Raz [M:CNTB]
        Raz [M:CNTB]NBCNT
        Affzo [M:CNTB]1-99
    Endif
Endif

#En duplication TIERS : On ne duplique pas les informations RIB ! #JPGA:12/06/2006 - BUG140:38475
# Raz + Affzo + Non validation du Mask
Effzo [M:BIDB]

#----------------------------------------------------#
# il faut remettre à zéro certaines zones du fichier #
#----------------------------------------------------#
[M:BPR1]BPCFLG=1
[M:BPR1]BPSFLG=1
If dim([M:BPR1]BPTFLG)>0 [M:BPR1]BPTFLG=1 Endif
If dim([M:BPR1]PPTFLG)>0 [M:BPR1]PPTFLG=1 Endif
If dim([M:BPR1]REPFLG)>0 [M:BPR1]REPFLG=1 Endif
[M:BPR1]FCTFLG=1

Affzo [M:BPR1]1-99

#CRM
Gosub RAZDUP_CRM From TRTBPCRM

#MAE, le 07/11/08, tiers actif même si on duplique un tiers inactif
[M:BPR0]ENAFLG = 2

Return

###################################################################
$VERIFCRE_MOD

[M:BPR0]BPRNUM= vireblc ([M:BPR0]BPRNUM,2)
#Test MAE
#If [M:BPR0]BPRNUM = ""
#   GERR=1:GMESSAGE = mess(6,199,1): OK = 0 : Return
#Endif

#-------------------------------------#
# avant la creation ou modif du tiers #
# on verifie qu'une adresse existe    #
#-------------------------------------#
If [M]NBADR = 0
   GERR=1: GMESSAGE = mess(31,199,1) : OK = 0 : Return
Endif
#---------------------------------------------------#
# on verifie qu une adresse est désignée par défaut #
#---------------------------------------------------#
If find (2,[M]BPAADDFLG (0..[M]NBADR -1)) = 0
   GERR=1:GMESSAGE = mess(110,199,1) : OK = 0 : Return
Endif
#    Si le tiers est un site
#    --> on va réécrire les adresses les RIB et les contacts du site
If dim([M:BPR1]BETFCY)>0 & [M:BPR1]FCY<>""
   If GIMPORT                                                                                      # hcb X3-63008
# Ce tiers est un site : Les Adresses, données bancaires, contacts du site ont été réécrits        # hcb X3-63008
      Call ECR_TRACE([M:BPR1]FCY-" : "-mess(1199,196,1),-1) From GESECRAN                            # hcb X3-63008
   Else                                                                                            # hcb X3-63008
      GERR=3 : GMESSAGE = mess(178,196,1)  # Ce tiers est un site : \Les Adresses, R.I.B., Contacts du site vont être réécrits
   Endif                                                                                           # hcb X3-63008
Endif

# Issue - MGO - X3-81238 BEGIN
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif

For I=0 To [M]NBADR-1
  If [M]BPACRY(I) <> ""
    Read [TCY]TCY0 = [M]BPACRY(I)
    If dim([F:TCY]POSOBL)>0 & [F:TCY]POSOBL=2
      If [M]POSCOD(I) = ""
        GMESSAGE = mess(117,127,1)-"("+num$([M]CODADR(I))+")" : # Code postal obligatoire
        mkstat = 2 : Return
      Endif
    Endif
  Endif
Next I
# Issue - MGO - X3-81238 END

Return

######################################################################
$INICRE_MOD
#----------------------------------------------#
# il faut récuperer le code adresse par defaut #
# si on ne trouve pas on recupere la premiere  #
#----------------------------------------------#
Local Shortint I
I = find (2,[M]BPAADDFLG (0..[M]NBADR -1))
If I = 0
      [F:BPR]BPAADD = [M]CODADR (0)
Else  [F:BPR]BPAADD = [M]CODADR (I-1)
Endif

# MABON - FQ65459 - 29/06/10 - Le champ ACCNONREI a changé de table
# FQ61382 - MABON 08/01/10 - Récupération du Compte non résident en duplication de tiers
#For I=0 To dim([F:BPR]ACCNONREI)-1
#  # FQ62928 - MABON 12/03/10
##  If [M]ACCNONREIM(I)=G_OUI or (I=0 and [M]XACCNONREIM=G_OUI) Then
#  If [M]ACCNONREIM(I)=G_OUI Then
#    [F:BPR]ACCNONREI(I) = [M]CODADR (I)
#  Endif
#Next

#----------------------------------------------------#
# il faut récuperer le code contact par defaut       #
# si on ne trouve pas alors On prend le premier
#----------------------------------------------------#
#LSE 17/06/2006 FQ36999
#I = ([M]NBCNT>0)*max(1,find (2,[M]CNTFLG (0..[M]NBCNT -1)))
#If I <> 0
#   [F:BPR]CNTNAM = [M]CCNCRM (I-1)
#Else
#   [F:BPR]CNTNAM  = ""
#Endif
If [M]NBCNT >0
    I = find (2,[M]CNTFLG (0..[M]NBCNT -1))
    If I <> 0
        [F:BPR]CNTNAM = [M]CCNCRM (I-1)
    Else
        [F:BPR]CNTNAM  =[M]CCNCRM (0)
    Endif
Else
    [F:BPR]CNTNAM  =""
Endif

Local Integer STAT, WRET, WNUMOK
Local Char    NUMERO(GLONBPC)

#MAE, bg 101554
# Si le numéro client est déterminée par un compteur
#If [F:BPR]BPRNUM = ""
If [M:BPR0]REFCOU <> "" & (GREP="C" | GREP="D")
 WNUMOK=0
 While WNUMOK=0
  Call NUMCLE ([M:BPR0]REFCOU,GFCYDEF(9),datesyst,"","BPR",NUMERO,STAT) From SUBANM
  #---
  If STAT = 0
     [F:BPR]BPRNUM =NUMERO
     [M:BPR0]BPRNUM=NUMERO
     WNUMOK=1
  Else
    GOK=0 : WNUMOK=1
    # FGR 20/07/2011 : X3SUIVI75166
    Local Char MESSA(80)
    GMESSAGE = mess(104,117,1) - "(" + [M:BPR0]REFCOU + ") : "
    Gosub MESSAGE From SUBANMARG
    GMESSAGE -= MESSA
  Endif
 Wend
 If GOK=0 Return Endif
Endif

If func AFNC.ACTIV("SDD") : Call DELBID([M]BPRNUM) From SUBMDT : Endif
Return

######################################################################
$CREATION
#------------------------------------#
# en creation du tiers               #
# il faut creer les adresses les RIB #
# et les contacts                    #
#------------------------------------#
Gosub CREBPA
If GOK < 1 : Return : Endif
Gosub CRERIB
