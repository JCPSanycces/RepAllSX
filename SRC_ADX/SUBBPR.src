#Elsif clalev([M:BPRS]) <> 0
#    Affzo [M:BPRS]5
#Endif
#Return
#########################################################################
#------------------------------------------------------------------#
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

If [F:FCY]FCY<>VALEUR
    Read [FCY]FCY0 = VALEUR
    If fstat End : Endif
Endif
If GREP = "C" # Création du tiers : On demande si on veut récupérer l'identité du site
    Local Integer OK : OK=2
    Call OUINON(mess(160,196,1),OK) From GESECRAN
    If OK=2
        # --------------------------------- #
        # Récupération de l'onglet identité #
        # --------------------------------- #
        [M]BPRSHO = [F:FCY]FCYSHO
        [M]BPRNAM = [F:FCY]FCYNAM
        [M]CRY    = [F:FCY]CRY
        [M]CRN    = [F:FCY]CRN
        If dim([M]NAF) > 0 [M]NAF = [F:FCY]NAF Endif
        # On récupère la devise liée à la société juridique du site
        If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
        Read [CPY]CPY0 = [F:FCY]LEGCPY
        If !fstat
            If [M]CUR <> [F:CPY]ACCCUR
                #   ----- La devise est modifiée ----
                If GACTFTC=2
                      If   clalev([M:BPC0]) <> 0
                      #   ---- chargement devise client sur ligne montant
                         For  nolign = 0 To [M:BPC1]NBFAC-1
                            If [M:BPC1]AMTCOD(nolign) = 2
                                [M:BPC1]WWCUR(nolign) = [F:CPY]ACCCUR
                            Endif
                         Next
                         Call INVDTAAMT ([F:CPY]ACCCUR,[M:BPC2]CHGTYP,"BPC") From SUBBPR
                         [M]CUR = [F:CPY]ACCCUR
                         Affzo [M:BPC1]30
                      Elsif clalev([M:BPS0]) <> 0
                         Call INVDTAAMT ([F:CPY]ACCCUR,[M:BPS4]CHGTYP,"BPS") From SUBBPR
                         [M]CUR = [F:CPY]ACCCUR
                         Affzo [M:BPS1]30
                      Endif
                Else
                    [M]CUR = [F:CPY]ACCCUR
                Endif
            Endif
        Endif
        If clalev([M:BPR1]) <> 0
            Affzo [M:BPR1]5
        Elsif clalev([M:BPRC]) <> 0
            Affzo [M:BPRC]5
        Elsif clalev([M:BPRS]) <> 0
            Affzo [M:BPRS]5
        Endif
    Endif
Endif
#----------------------------------------------#
# Récupération des adresses, rib, et contacts  #
#----------------------------------------------#
#Call CHARG_BPA (GABREV,VALEUR ,3,[F:FCY]BPAADD) From TRTADR
#Call CHARG_CNT (GABREV,VALEUR ,3,"") From TRTADR
#Call CHARG_RIB (GABREV,VALEUR ,3,"") From TRTADR
Case GABREV
    When "BPR" : Default Mask [BPAB]
    When "BPC" : Default Mask [BPAC]
    When "BPS" : Default Mask [BPAS]
Endcase
#MAE,  bg 79523
#Call CHARG_BPA(3,VALEUR,[F:FCY]BPAADD) From TRTBPA
Call CHARG_BPA_INTERSITE(3,VALEUR,[F:FCY]BPAADD) From TRTBPA
Case GABREV
    When "BPR" : Default Mask [BIDB]
    When "BPC" : Default Mask [BIDC]
    When "BPS" : Default Mask [BIDS]
Endcase
Call CHARG_RIB(3,VALEUR,"~") From TRTBPA
Case GABREV
    When "BPR" : Default Mask [CNTB]
    When "BPC" : Default Mask [CNTC]
    When "BPS" : Default Mask [CNTS]
Endcase
Call CHARG_CNT(3,VALEUR,[F:FCY]CNTNAM) From TRTBPA
Case GABREV
    When "BPR" : Default Mask [BPR0]
    When "BPC" : Default Mask [BPC0]
    When "BPS" : Default Mask [BPS0]
Endcase
# Il faut tester clalev([M:BPC0]) en 1er
# --> Car si bouton Client depuis les tiers clalev([M:BPR0]) est aussi positionné
If clalev([M:BPC0]) <> 0
    Local Char WFCY(GLONFCY) : WFCY=VALEUR                                     # FGR 11/04/2012 : X3SUIVI81394
    Local Char WBPCNUM(GLONBPR) : WBPCNUM=[M:BPC0]BPCNUM                       # FGR 11/04/2012 : X3SUIVI81394
    Local Char WBPAADD(GLONADR) : WBPAADD=[F:FCY]BPAADD                        # FGR 11/04/2012 : X3SUIVI81394
    Gosub ALI_BETFCY From SUBBPC
    Affzo [M:BPAC]1-99
    Affzo [M:BIDC]1-99
    Affzo [M:CNTC]1-99
    Affzo [M:BPC3]1-99
    # On peut alimenter l'adresse du 1er client livré avec l'adresse par défaut du tiers
    If GACTFTC=2 & GREP="C"
        Local Char WFCY(GLONFCY) : WFCY=VALEUR                                 # FGR 11/04/2012 : X3SUIVI81394
        [M:BPC4]BPAADD(0)=[F:FCY]BPAADD
        [M:BPC4]FLMOD(0) = 1                                                   # FGR 28/07/2014 : X3SUIVI100229

        Local Char WBPAADD(GLONADR) : WBPAADD=[M:BPC4]BPAADD(0)                # FGR 11/04/2012 : X3SUIVI81394
        [M:BPC4]NBDLV=1
        nolign = 1
        Gosub CHARGE_BPAADD From SUBBPC
        Affzo [M:BPC4]5, 10
    Endif
Elsif clalev([M:BPS0]) <> 0
    Local Char WFCY(GLONFCY) : WFCY=VALEUR                                     # FGR 11/04/2012 : X3SUIVI81394
    Local Char WBPSNUM(GLONBPR) : WBPSNUM=[M:BPS0]BPSNUM                       # FGR 11/04/2012 : X3SUIVI81394
    Local Char WBPAADD(GLONADR) : WBPAADD=[F:FCY]BPAADD  #MAE, bg 79523        # FGR 11/04/2012 : X3SUIVI81394
    Gosub ALI_BETFCY From SUBBPS
    If mkstat GERR=1 : End : Endif
    Affzo [M:BPAS]1-99
    Affzo [M:BIDS]1-99
    Affzo [M:CNTS]1-99
    Affzo [M:BPS2]1-99
Elsif clalev([M:BPR0]) <> 0
    Affzo [M:BPAB]1-99
    Affzo [M:BIDB]1-99
    Affzo [M:CNTB]1-99
Endif

End

