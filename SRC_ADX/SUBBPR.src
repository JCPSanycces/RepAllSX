Call PARAM("","SFCRM", SFCRM) From ADOVAL
If val(SFCRM)=[V]CST_AYES
  Gosub SF_UPDATE From CRMSFLIB
  If GOK < 1 : Return : Endif
Endif
#111269

Return

######################################################################
$AV_VERF_ANU

# Réécriture enreg client si clients identiques pour ne pas rencontrer de lien bloquant
# Idem fournisseur
Trbegin [BPC]
If [M:BPR1]BPCFLG=2
   Readlock [BPC]BPC0=[M:BPR0]BPRNUM
   If !fstat
      If [F:BPC]BPCINV=[M:BPR0]BPRNUM Raz [F:BPC]BPCINV Endif
      If [F:BPC]BPCPYR=[M:BPR0]BPRNUM Raz [F:BPC]BPCPYR Endif
      If [F:BPC]BPCGRU=[M:BPR0]BPRNUM Raz [F:BPC]BPCGRU Endif
      If [F:BPC]BPCRSK=[M:BPR0]BPRNUM Raz [F:BPC]BPCRSK Endif
      Rewrite [BPC]
   Endif
Endif
If [M:BPR1]BPSFLG=2
   Readlock [BPS]BPS0=[M:BPR0]BPRNUM
   If !fstat
      If [F:BPS]BPSINV=[M:BPR0]BPRNUM Raz [F:BPS]BPSINV Endif
      If [F:BPS]BPRPAY=[M:BPR0]BPRNUM Raz [F:BPS]BPRPAY Endif
      If [F:BPS]BPSGRU=[M:BPR0]BPRNUM Raz [F:BPS]BPSGRU Endif
      If [F:BPS]BPSRSK=[M:BPR0]BPRNUM Raz [F:BPS]BPSRSK Endif
      Rewrite [BPS]
   Endif
Endif
Commit

Return

######################################################################
$AP_VERF_ANU

# Retitution des données initiales
Trbegin [BPC]
If [M:BPR1]BPCFLG=2
   Readlock [BPC]BPC0=[M:BPR0]BPRNUM
   If !fstat
      If [F:BPC]BPCINV="" [F:BPC]BPCINV=[M:BPR0]BPRNUM Endif
      If [F:BPC]BPCPYR="" [F:BPC]BPCPYR=[M:BPR0]BPRNUM Endif
      If [F:BPC]BPCGRU="" [F:BPC]BPCGRU=[M:BPR0]BPRNUM Endif
      #MAE, bg 78852
      If [F:BPC]BPCRSK="" [F:BPC]BPCRSK=[M:BPR0]BPRNUM Endif
      Rewrite [BPC]
   Endif
Endif
If [M:BPR1]BPSFLG=2
   Readlock [BPS]BPS0=[M:BPR0]BPRNUM
   If !fstat
      If [F:BPS]BPSINV="" [F:BPS]BPSINV=[M:BPR0]BPRNUM Endif
      If [F:BPS]BPRPAY="" [F:BPS]BPRPAY=[M:BPR0]BPRNUM Endif
      If [F:BPS]BPSGRU="" [F:BPS]BPSGRU=[M:BPR0]BPRNUM Endif
      #MAE, bg 78852
      If [F:BPS]BPSRSK="" [F:BPS]BPSRSK=[M:BPR0]BPRNUM Endif
      Rewrite [BPS]
   Endif
Endif
Commit

Return

######################################################################
$ANNULE
Local Integer WBPATYP : WBPATYP=1
#------------------------------------#
#    A SUPPRIMER                     #
#------------------------------------#
# Suppression des adresses RIB et    #
# contacts    liées à une entité     #
#------------------------------------#
#     Call ANNBPA_CPYFCY ([M:BPR0]BPRNUM,1) From TRTADR
#-------------------------------------------------------------#
# GOK = 1  Transaction OK                                     #
# GOK = -1 Enregistrement verrouillé on recommence trois fois)#
# GOK = 0  Transaction abandonnée                             #
#-------------------------------------------------------------#
#     If GOK < 1 : Return : Endif
#     Call ANNBID_CPYFCY ([M:BPR0]BPRNUM,1) From TRTADR
#     If GOK < 1 : Return : Endif
#     Call ANNCNT_CPYFCY ([M:BPR0]BPRNUM,1) From TRTADR
#     If GOK < 1 : Return : Endif
#------------------------------------#
# FGR 20/04/2010 : X3SUIVI64106 : Utiliser la classe [F:BPR]BPRNUM plutôt que [M:BPR0]BPRNUM en cas de suppression depuis GESAUS

Call ANNBPA(WBPATYP,[F:BPR]BPRNUM) From TRTBPA
Call ANNRIB(WBPATYP,[F:BPR]BPRNUM) From TRTBPA
Call ANNCNT(WBPATYP,[F:BPR]BPRNUM) From TRTBPA   # FGR 26/04/2010 : X3SUIVI64326

#JPGA : Déclinaisons Société / BPEXCEPT : Suppression en annulation [M:BPE]
Gosub OUVRE_BPE From BPEXCEPT  # FGR 20/04/2010 : X3SUIVI64106
Call ANN_EXC ([F:BPR]BPRNUM) From BPEXCEPT
If GOK < 1 : Return : Endif


#Modif CRM      24 août 2001
#Supprime la mention client interne.

If !clalev([F:DBI]) : Local File DOOBPCINT [DBI] : Endif
Read [DBI]DBI0=[F:BPR]BPRNUM
If !fstat
    Delete [DBI]Curr
    If fstat
        GOK = 0
        Return
    Endif
Endif

#LSE 05/07/2005
If GMODU(12) = 2
    #Supprime les associations de donneurs d'ordre.
    If !clalev([F:DBL]) : Local File DOOBPCLNK [DBL] : Endif

    Delete [DBL] Where [F:DBL]BPCNUM = [F:BPR]BPRNUM
    If fstat
        GOK = 0
        Return
    Endif
Endif

Return

