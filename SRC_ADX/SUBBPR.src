Subprog C_CPYREL(VALEUR)
Variable Integer VALEUR
    If [M]GRUGPY = ""
        If VALEUR <> 1
            Call MESSAGE( mess(83,123,1) ) From GESECRAN
            mkstat = 2
        Endif
    Else
        If VALEUR < 2
            Call MESSAGE( mess(83,123,1) ) From GESECRAN
            mkstat = 2
        Endif
    Endif
End

