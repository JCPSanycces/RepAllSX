#<AdxTL>@(#)0.0.0.0 $Revision$ Tiers
########################################################################
#    GESTION DES TIERS                                                 #
#----------------------------------------------------------------------#
#                                                    cg septembre 1997 #
# le 29/01/98 ajout code adresse par defaut                            #
# attention utilisation de GFONC1 de façon particuliere lors tunnel    #
########################################################################
$ACTION
# Pour gestion multi-société
#Gosub ACTION From GSOCIETE
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "EXEBOUT"      : Gosub EXEBOUT
 When "STATUT"       : Gosub STATUT
 When "AVANTBOUT"    : Gosub AVANTBOUT
 When "LIENS"        : Gosub LIENS
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "VERIF_CRE"    : Gosub VERIFCRE_MOD
 When "INICRE"       : Gosub INICRE_MOD
 When "CREATION"     : Gosub CREATION
 When "AVANT_MOD"    : Gosub AVANT_MOD    # FGR 29/08/2014 : X3SUIVI95632
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "VERIF_MOD"    : Gosub VERIFCRE_MOD
 When "INIMOD"       : Gosub INICRE_MOD
 When "MODIF"        : Gosub MODIF
 When "AV_VERF_ANU"  : Gosub AV_VERF_ANU
 When "AP_VERF_ANU"  : Gosub AP_VERF_ANU
 When "ANNULE"       : Gosub ANNULE
 When "FERME"        : Gosub FERME
 When "APRES_CRE"    : Gosub APRES_CRE
 When "APRES_MOD"    : Gosub APRES_MOD
 When "AP_ANNULE"    : Gosub AP_ANNULE
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BB3_BRGCOD"   : If VALEUR <> "" :[M:BPR0]BRGOBJ = "BPC" : Call AM_BRGCOD(VALEUR) : Endif
 When "BB4_BRGCOD"   : If VALEUR <> "" :[M:BPR0]BRGOBJ = "BPS" : Call AM_BRGCOD(VALEUR) : Endif
 When Default
Endcase
Return

