Subprog C_LEGETT(VALEUR)
Variable Integer VALEUR

#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
If [M]CRY = 'PT' & func AFNC.ACTIV("KPO")
  If VALEUR = 2
    If instr(1, [M]EECNUM, "PT5") > 0
      Call MESSAGE (mess(141,7711,1)) From GESECRAN
      mkstat = 2 : End
    Endif
  Endif
Endif
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END

End


######################################################################################
######################################################################################
## Section automatically added (screen BPRBPC) 11/25/2014 16:01:32 (RICAR)
######################################################################################
Subprog AM_EECNUM(VALEUR)
Variable Char    VALEUR()

#97101 RICAR 2014/07/03 - 50001 Law decret - BEGIN + 85803
If [M]CRY = 'PT' & func AFNC.ACTIV("KPO") & dim([M]LEGETT) > 0
  If !find(mid$(VALEUR,3,1),"5","6") #(VALEUR = '' | VALEUR = 'PT123456789' | VALEUR = 'PT999999990' | !find(mid$(VALEUR,3,1),"5","6"))
    [M]LEGETT = 2
  Else
    [M]LEGETT = 1
  Endif
  Affzo [M]LEGETT
Endif
#97101 RICAR 2014/07/03 - 50001 Law decret - END

End


