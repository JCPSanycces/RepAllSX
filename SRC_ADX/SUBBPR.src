########################################################################
$CREBPA


#-------------------------#
#    A SUPPRIMER          #
#-------------------------#
# creation des adresses   #
#-------------------------#
#     Call CREBPA_CPYFCY (GABREV,[M:BPR0]BPRNUM,1) From TRTADR
#-------------------------------------------------------------#
# GOK = 1  Transaction OK                                     #
# GOK = -1 Enregistrement verrouillé on recommence trois fois)#
# GOK = 0  Transaction abandonnée                             #
#-------------------------------------------------------------#
#     If GOK < 1 : Return : Endif
#-------------------------#

Default Mask [BPAB]
Call CREBPA(WBPATYP,[M:BPR0]BPRNUM) From TRTBPA
If GOK < 1 : Return : Endif

Return


########################################################################
$CRERIB

#-------------------------#
#    A SUPPRIMER          #
#--------------------#
# creation des RIB   #
#--------------------#
#     Call CRERIB_CPYFCY ([M:BPR0]BPRNUM,1) From TRTADR
#-------------------------------------------------------------#
# GOK = 1  Transaction OK                                     #
# GOK = -1 Enregistrement verrouillé on recommence trois fois)#
# GOK = 0  Transaction abandonnée                             #
#-------------------------------------------------------------#
#     If GOK < 1 : Return : Endif
#-------------------------#

Default Mask [BIDB]
Call CRERIB(WBPATYP,[M:BPR0]BPRNUM) From TRTBPA
If GOK < 1 : Return : Endif

# FGR 23/11/2009 : X3SUIVI60210 : là c'est mieux (début)
Read [BPR]BPR0=[F:BPR]BPRNUM       # FGR 30/11/2009 : X3SUIVI60473
Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
If !fstat
   [F:BPR]BIDNUM=[F:BPA]BPABID
   Read [BID]BID0=1;[F:BPR]BPRNUM;[F:BPR]BIDNUM;[F:BPR]BPAADD
   If !fstat
      [F:BPR]BIDCRY=[F:BID]CRY
   Else
      # FGR 23/11/2009 : S'il n'y a pas/plus de RIB on l'efface aussi sur l'adresse par défaut
      [F:BPR]BIDNUM=""
      [F:BPR]BIDCRY=""
      [F:BPA]BPABID = ""
      Rewrite [BPA]
      If fstat Then
        GOK = 0
        Call FSTA("BPA") From GLOCK
        Return
      Endif
   Endif
Else
   [F:BPR]BIDNUM=""
   [F:BPR]BIDCRY=""
Endif
#... Mais il faut réécrire [F:BPR] (en création comme en modification c'est REWRITE)
Rewrite [BPR]
If fstat Then
  GOK = 0
  Call FSTA("BPR") From GLOCK
  Return
Endif
# FGR 23/11/2009 : X3SUIVI60210 : là c'est mieux (fin)
Return

########################################################################
$CRECNT

#-------------------------#
#    A SUPPRIMER          #
#-------------------------#
# creation des contacts   #
#-------------------------#
#      Call CRECNT_CPYFCY (GABREV,[M:BPR0]BPRNUM,1) From TRTADR
#-------------------------------------------------------------#
# GOK = 1  Transaction OK                                     #
# GOK = -1 Enregistrement verrouillé on recommence trois fois)#
# GOK = 0  Transaction abandonnée                             #
#-------------------------------------------------------------#
#      If GOK < 1 : Return : Endif
#-------------------------#
Default Mask [CNTB]
Call CRECNT(WBPATYP,[M:BPR0]BPRNUM) From TRTBPA
If GOK < 1 : Return : Endif
  Call MAJ_CNTNAM("[F:BPR]")  # FGR 10/01/2013 X3SUIVI83886

# X3-107151 (LCC 07/09/18) CNTNAM is not ok in the bpartner's table
Local Shortint K: K=0
# We check the default contact in Customers Table
###
If [F:BPR]BPCFLG=2 or [F:BPR]PPTFLG=2
  If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
  Readlock [F:BPC]BPC0=[F:BPR]BPRNUM
  If !fstat
    If [M:CNTB]NBCNT>0
      K = find ([F:BPC]CNTNAM,[M:CNTB]CCNCRM (0..[M:CNTB]NBCNT-1))
    Endif
    ## If the CNTNAM field is an existing contact there is nothing to do
    If K=0
      [F:BPC]CNTNAM    = [F:BPR]CNTNAM
      Rewrite [F:BPC]
      If fstat GOK=0 : Call FSTA("BPC") From GLOCK : Endif
    Endif
  Endif
Endif
###
# We check the default contact in Carriers Table
###
If [F:BPR]BPTFLG=2
  If clalev([F:BPT])=0 : Local File BPCARRIERS[BPT] : Endif
  Readlock [F:BPT]BPT0=[F:BPR]BPRNUM
  If !fstat
    K=0
    If [M:CNTB]NBCNT>0
      K = find ([F:BPT]CNTNAM,[M:CNTB]CCNCRM (0..[M:CNTB]NBCNT-1))
    Endif
    ## If the CNTNAM field is an existing contact there is nothing to do
    If K=0
      [F:BPT]CNTNAM    = [F:BPR]CNTNAM
      Rewrite [F:BPT]
      If fstat GOK=0 : Call FSTA("BPT") From GLOCK : Endif
    Endif
  Endif
Endif
###
# We check the default contact in Suppliers Table
###
If [F:BPR]BPSFLG=2
  If clalev([F:BPS])=0 : Local File BPSUPPLIER[BPS] : Endif
  Readlock [F:BPS]BPS0=[F:BPR]BPRNUM
  If !fstat
    K=0
    If [M:CNTB]NBCNT>0
      K = find ([F:BPS]CNTNAM,[M:CNTB]CCNCRM (0..[M:CNTB]NBCNT-1))
    Endif
    ## If the CNTNAM field is an existing contact there is nothing to do
    If K=0
      [F:BPS]CNTNAM    = [F:BPR]CNTNAM
      Rewrite [F:BPS]
      If fstat GOK=0 : Call FSTA("BPS") From GLOCK : Endif
    Endif
  Endif
Endif
# END X3-107151 (LCC 07/09/18) CNTNAM is not ok in the bpartner's table



Return

########################################################################
$CREEXC
#JPGA : Déclinaisons Société / BPEXCEPT : création depuis [M:BPE]
Call CRE_EXC ([M:BPR0]BPRNUM) From BPEXCEPT
If GOK < 1 : Return : Endif
Return


########################################################################
$MAJFCY

#-------------------------------------------------------------#
# Le tiers est un site :                                      #
# --> Il faut que le site soit l'image du tiers               #
# --> Création des adresses rib et contacts                   #
#-------------------------------------------------------------#

#-------------------------#
# A SUPPRIMER             #
#-------------------------#
# creation des adresses   #
#-------------------------#
#Call CREBPA_CPYFCY(GABREV,[M:BPR1]FCY,3) From TRTADR
#-------------------------------------------------------------#
# GOK = 1  Transaction OK                                     #
# GOK = -1 Enregistrement verrouillé on recommence trois fois)#
# GOK = 0  Transaction abandonnée                             #
#-------------------------------------------------------------#
#If   GOK < 1 : Return : Endif
#--------------------#
# creation des RIB   #
#--------------------#
#Call CRERIB_CPYFCY([M:BPR1]FCY,3) From TRTADR
#If   GOK < 1 : Return : Endif
#-------------------------#
# creation des contacts   #
#-------------------------#
#Call CRECNT_CPYFCY(GABREV,[M:BPR1]FCY,3) From TRTADR
#If   GOK < 1 : Return : Endif
#-------------------------#



#-------------------------#
# creation des adresses   #
#-------------------------#
Case GFONCTION
    When "GESBPR" : Default Mask [BPAB]
    When "GESBPC" : Default Mask [BPAC]
    When "GESBPS" : Default Mask [BPAS]
Endcase
For I=0 To [M]NBADR-1
    [M]FLMOD(I)=1
Next
Call CREBPA(3,[F:BPR]FCY) From TRTBPA
If GOK < 1 : Return : Endif
#--------------------#
# creation des RIB   #
#--------------------#
Case GFONCTION
    When "GESBPR" : Default Mask [BIDB]
    When "GESBPC" : Default Mask [BIDC]
    When "GESBPS" : Default Mask [BIDS]
Endcase
For I=0 To [M]NBRIB-1
    [M]FLMOD(I)=1
Next
Call CRERIB(3,[F:BPR]FCY) From TRTBPA
If GOK < 1 : Return : Endif
#-------------------------#
# creation des contacts   #
#-------------------------#
Case GFONCTION
    When "GESBPR" : Default Mask [CNTB]
    When "GESBPC" : Default Mask [CNTC]
    When "GESBPS" : Default Mask [CNTS]
Endcase
For I=0 To [M]NBCNT-1
    [M]FLMOD(I)=1
Next
Call CRECNT(3,[F:BPR]FCY) From TRTBPA
If GOK < 1 : Return : Endif
Gosub DEFAUT

#---------------------------------------------------------#
# Site et tiers doivent avoir la même adresse par défault #
#---------------------------------------------------------#
Readlock [FCY]FCY0 = [F:BPR]FCY
If fstat = 1
    GOK = -1 : GLOCK = "$FACILITY"-[F:BPR]FCY : Return
Endif
[F:FCY]BPAADD = [F:BPR]BPAADD
[F:FCY]UPDDAT = date$
[F:FCY]UPDUSR = GUSER
Rewrite [FCY]
If fstat <> 0 GOK=0 : Call FSTA("FCY") From GLOCK : Endif

Return

######################################################################
$BPT_APPEL
#-------------------------#
# appel objet transporteur#
#-------------------------#
Call OBJET("BPT",[M:BPR0]BPRNUM,"") From GOBJET
Gosub $RELIT From GOBJSUB
Return

#####################################################################
Subprog INVDTAAMT (WCUR,WCHGTYP,WTYP)
Value Char     WCUR
Value Integer  WCHGTYP
Value Char     WTYP

Local Integer  I, SPSTAT, IJ0
Local Integer  WNB

Case WTYP
 When "BPS","BSG" : WNB=[M]NBELEMENT
 When "BPC","BCG" : WNB=[M]NBFAC
Endcase

If WNB=0 End Endif

Local Decimal WMONTORG (0..WNB-1)
Local Decimal WMONTDES (0..WNB-1)

For I=0 To WNB-1
   If [M]AMTCOD(I)=2
      [M]FORMAT(I)="NZ:"+[F:TCU]CURFMT1
      WMONTORG (I)=[M]INVDTAAMT(I)
   Else
      WMONTORG (I)=0
   Endif
Next I

For IJ0=0 To dim(WMONTORG)-1
   If WMONTORG(IJ0)<>0
      Call CONVERT([M]CUR,WCUR,GCUR,WCHGTYP,datesyst,WMONTORG(IJ0),WMONTDES(IJ0),SPSTAT) From TRTDEV
      If SPSTAT : Break : Endif
   Endif
Next IJ0

If SPSTAT=0
   For I=0 To WNB-1
      If [M]AMTCOD(I)=2
         [M]INVDTAAMT(I)=WMONTDES(I)
         [M]WWCUR(I)    =WCUR
      Endif
   Next I
Endif

End

