##Call DEL_HC("BPRZIP", [M:BPR0]BPRNUM, HCBPRNAM) From TRTHCODE
##Call DEL_HC("BPRCTY", [M:BPR0]BPRNUM, HCBPRNAM) From TRTHCODE
#
#Call DEL_HC(nomap,"BPRNAM", [M:BPR0]BPRNUM, HCBPRNAM,SZMESSAGE, IBRETOUR) From TRTHCODE
#If IBRETOUR=0
#    GERR=1
#    GMESSAGE=SZMESSAGE
#Endif
#Call DEL_HC(nomap,"BPRZIP", [M:BPR0]BPRNUM, HCBPRNAM,SZMESSAGE, IBRETOUR) From TRTHCODE
#If IBRETOUR=0
#    GERR=1
#    GMESSAGE=SZMESSAGE
#Endif
#Call DEL_HC(nomap,"BPRCTY", [M:BPR0]BPRNUM, HCBPRNAM,SZMESSAGE, IBRETOUR) From TRTHCODE
#If IBRETOUR=0
#    GERR=1
#    GMESSAGE=SZMESSAGE
#Endif
#
