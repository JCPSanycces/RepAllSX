    # Pas de gestion par société sur les champs BPCNAM et BPCSHO
    Update [BPC] Where [F:BPC]BPCNUM = [M:BPR0]BPRNUM With BPCNAM=[M:BPR1]BPRNAM, BPCSHO=[M:BPR1]BPRSHO
    If fstat GOK=0 : Call FSTA("BPC") From GLOCK : Endif
Endif
If [M:BPR1]BPSFLG = 2
    # %CCC%
    # Pas de gestion par société sur les champs BPRNAM et BPRSHO
    Update [BPS] Where [F:BPS]BPSNUM = [M:BPR0]BPRNUM With BPSNAM=[M:BPR1]BPRNAM, BPSSHO=[M:BPR1]BPRSHO
    If fstat GOK=0 : Call FSTA("BPS") From GLOCK : Endif
Endif
If dim([M:BPR1]REPFLG)>0 & [M:BPR1]REPFLG = 2
    If clalev([F:REP])=0 : Local File SALESREP [REP] : Endif
    Update [REP] Where [F:REP]REPNUM = [M:BPR0]BPRNUM With REPNAM=[M:BPR1]BPRNAM
    If fstat GOK=0 : Call FSTA("REP") From GLOCK : Endif
Endif
If dim([M:BPR1]BPTFLG)>0 & [M:BPR1]BPTFLG=2
    Update [BPT] Where [F:BPT]BPTNUM = [M:BPR0]BPRNUM With BPTNAM=[M:BPR1]BPRNAM, BPTSHO=[M:BPR1]BPRSHO
    If fstat GOK=0 : Call FSTA("BPT") From GLOCK : Endif
Endif

#CRM
Gosub MODIF_CRM From TRTBPCRM
If GOK < 1 : Return : Endif

#111269 RBU - Salesforce integration
