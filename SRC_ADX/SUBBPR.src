#                                        Ecran BPR1
#--------------------------------------------------------------------------------

#----------------------- CRN --------------------------------------#
#------------------------------------------------------------------#
#------------------------------------------------------------------#
Subprog C_CRN(VALEUR)
Variable Char    VALEUR()

# V6.2 : Certification
# Si personne morale Numero SIRET obligatoire
#If [M]LEGETT=2 & VALEUR="" GMESSAGE=mess(10,123,1) : mkstat=2 : Endif
#MAE, 17/09/10, siret obligatoire si controle obligatoire dans le pays
#--- Issue 110590 & 110597
#If !GIMPORT
#    #MAE, bg77256 If [M]LEGETT=1 & VALEUR="" & [F:TCY]CRTOBL=2 & [M]CRY<>"" GMESSAGE=mess(10,123,1) : mkstat=2 : Endif
#    If [M]LEGETT<>2 & VALEUR="" & [F:TCY]CRTOBL=2 & [M]CRY<>"" GMESSAGE=mess(10,123,1) : mkstat=2 : Endif
#Endif
# --------------------------------------
# FGR 18/08/2016 : X3SUIVI116593 (début)
#If dim([M]LEGETT)>0 & [M]LEGETT<>2 & VALEUR ="" & [F:TCY]CRNOBL=2 & [M]CRY<>""
#  GMESSAGE=mess(10,123,1) : mkstat=2
#Endif
If dim([M]LEGETT)>0 & [M]LEGETT<>2 & VALEUR ="" & [F:TCY]CRTOBL=2 & [M]CRY<>""
  GMESSAGE=mess(10,123,1) : mkstat=2
Endif
# FGR 18/08/2016 : X3SUIVI116593 (fin)
# --------------------------------------
#---
End

#----------------------- EECNUM -----------------------------------#
#------------------------------------------------------------------#
#------------------------------------------------------------------#
Subprog C_EECNUM(VALEUR)
Variable Char    VALEUR()
# V6.2 : Certification
# Si personne morale Numero TVA intracommunautaire obligatoire
#MAE, 17/09/10, siret obligatoire si controle obligatoire dans le pays
#If [M]LEGETT=2 & VALEUR="" GMESSAGE=mess(10,123,1) : mkstat=2 : Endif
#If !GIMPORT
#--- Issue 110597
#If !GIMPORT & dim([M]LEGETT) > 0  # FGR 09/12/2014 : X3SUIVI104578
#    #MAE, bg77256If [M]LEGETT=1 & VALEUR="" & [F:TCY]CRTOBL=2 & [M]CRY<>"" GMESSAGE=mess(10,123,1) : mkstat=2 : Endif
#    If [M]LEGETT<>2 & VALEUR="" & [F:TCY]CRTOBL=2 & [M]CRY<>"" GMESSAGE=mess(10,123,1) : mkstat=2 : Endif
#Endif
# --------------------------------------
# FGR 18/08/2016 : X3SUIVI116593 (début)
#If dim([M]LEGETT)>0 & [M]LEGETT<>2 & VALEUR="" & [F:TCY]CRTOBL=2 & [M]CRY<>""
#  GMESSAGE=mess(10,123,1) : mkstat=2
#Endif
If dim([M]LEGETT)>0 & [M]LEGETT<>2 & VALEUR="" & [F:TCY]CRNOBL=2 & [M]CRY<>""
  GMESSAGE=mess(10,123,1) : mkstat=2
Endif
# FGR 18/08/2016 : X3SUIVI116593 (fin)
# --------------------------------------
#---

#97101 RICAR 2014/07/03 - 50001 Law decret - BEGIN
# Issue X3-74615 - 2018-02-22 by VAVIL : should allow the field EECNUM to change from PT999999990
If (VALEUR = '') & [M]CRY = 'PT' & func AFNC.ACTIV("KPO")
  GMESSAGE=mess(94,7711,1)
  mkstat = 2 : End
Endif

Local Shortint BPRSTAT : BPRSTAT = 0
If !find(GREP,"C","D")
  Case GFONCTION
    When "GESBPR" :
      If [M:BPR1]BPCFLG = 2 & VALEUR <> [F:BPR]EECNUM & [F:BPR]EECNUM <>"PT999999990"
        Call IS_BPR_USED([M:BPR0]BPRNUM,[L]BPRSTAT) From PORLEGLIB
        If [L]BPRSTAT = 1 : GMESSAGE = mess(123,7711,1) : mkstat = 2 : Endif
      Endif
    When "GESBPC" :
      If [F:BPR]BPRNUM <> [M:BPC0]BPCNUM : Read [F:BPR]BPR0 = [M:BPC0]BPCNUM : If fstat Raz [F:BPR] Endif : Endif
      If !fstat
        If [M:BPRC]BPCFLG = 2 & VALEUR <> [F:BPR]EECNUM & [F:BPR]EECNUM <>"PT999999990"
          Call IS_BPR_USED([M:BPC0]BPCNUM,[L]BPRSTAT) From PORLEGLIB
          If [L]BPRSTAT = 1 : GMESSAGE = mess(123,7711,1) : mkstat = 2 : Endif
        Endif
      Endif
    When "GESREP" :
      If [F:BPR]BPRNUM <> [M:REP0]REPNUM : Read [F:BPR]BPR0 = [M:REP0]REPNUM : If fstat Raz [F:BPR] Endif : Endif
      If !fstat
        If [M:BPRR]BPCFLG = 2 & VALEUR <> [F:BPR]EECNUM & [F:BPR]EECNUM <>"PT999999990"
          Call IS_BPR_USED([M:REP0]REPNUM,[L]BPRSTAT) From PORLEGLIB
          If [L]BPRSTAT = 1 : GMESSAGE = mess(123,7711,1) : mkstat = 2 : Endif
        Endif
      Endif
    When "GESBPS" :
      If [F:BPR]BPRNUM <> [M:BPS0]BPSNUM : Read [F:BPR]BPR0 = [M:BPS0]BPSNUM : If fstat Raz [F:BPR] Endif : Endif
      If !fstat
        If [M:BPRS]BPCFLG = 2 & VALEUR <> [F:BPR]EECNUM & [F:BPR]EECNUM <>"PT999999990"
          Call IS_BPR_USED([M:BPS0]BPSNUM,[L]BPRSTAT) From PORLEGLIB
          If [L]BPRSTAT = 1 : GMESSAGE = mess(123,7711,1) : mkstat = 2 : Endif
        Endif
      Endif
    When "GESBPT" :
        If [F:BPR]BPRNUM <> [M:BPT0]BPTNUM : Read [F:BPR]BPR0 = [M:BPT0]BPTNUM : If fstat Raz [F:BPR] Endif : Endif
        If !fstat
          If [M:BPRT]BPCFLG = 2 & VALEUR <> [F:BPR]EECNUM & [F:BPR]EECNUM <>"PT999999990"
            Call IS_BPR_USED([M:BPT0]BPTNUM,[L]BPRSTAT) From PORLEGLIB
            If [L]BPRSTAT = 1 : GMESSAGE = mess(123,7711,1) : mkstat = 2 : Endif
          Endif
        Endif
  Endcase
Endif
#97101 RICAR 2014/07/03 - 50001 Law decret - BEGIN

End

#----------------------- CUR --------------------------------------#
#------------------------------------------------------------------#
#------------------------------------------------------------------#
Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()
Local Integer NBPOSTE

Local Char SZOLDCUR
Local Char SZNEWCUR
SZNEWCUR = VALEUR
If GABREV = "BPR"
    SZOLDCUR = [M:BPR1]CUR
Endif
If GABREV = "BPP"
    SZOLDCUR = [M:BPRP]CUR
Endif
If GABREV = "BPC"
    SZOLDCUR = [M:BPRC]CUR
Endif
If GABREV = "BPS"
    SZOLDCUR = [M:BPRS]CUR
Endif
If GABREV = "REP"
    SZOLDCUR = [M:BPRR]CUR
Endif
If GABREV = "BPT"
    SZOLDCUR = [M:BPRT]CUR
Endif

#---------------------------------------------------------------#
# pour le fournisseur ou client                                 #
# Convertion des montants si changement de devise               #
#---------------------------------------------------------------#
If GACTFTC=2
   If clalev([M:BPS0]) <> 0
        Call INVDTAAMT (VALEUR,[M:BPS4]CHGTYP,"BPS") From SUBBPR
        Affzo [M:BPS1]30
   Elsif clalev([M:BPC0]) <> 0
        Call INVDTAAMT (VALEUR,[M:BPC2]CHGTYP,"BPC") From SUBBPR
        #-- particularite client car valeur defaut dans ecran la classe M
#       [M:BPR1]CUR = VALEUR
        [M]CUR = VALEUR
        Affzo [M:BPC1]30
   Endif
Endif
If clalev([M:BPT1]) <> 0
        [M:BPT1]X1CUR=VALEUR : Affzo [M:BPT1]X1CUR
        [M:BPT1]X2CUR=VALEUR : Affzo [M:BPT1]X2CUR
        [M:BPT1]X3CUR=VALEUR : Affzo [M:BPT1]X3CUR
#       message : changement de devise : verifier les données tarifaires
        GERR=3 : GMESSAGE = mess(336,199,1)
Endif
If clalev([M:BPT3]) <> 0
        [M:BPT3]X4CUR=VALEUR : Affzo [M:BPT3]X4CUR
Endif

##############################
# FGR 26/04/2010 : X3SUIVI64293 : A partir de la V6 chaque type de tiers peut avoir une devise différente.
#                  Pour les donneurs d'ordre c'est un changement de devise au niveau de BPR qui doit déclencher
#                  un conversion des informations financières.
#Modif CRM 04/10/2001
# Si le tiers est un donneur d'ordres, convertir ses informations financières dans la nouvelle devise.
Local Integer STAT_OK
Local Integer IDIM
Local Char CODEDEVSOC(GLONCUR)
Local Decimal MNTBEFORE
Local Decimal MNTAFTER
Local Integer ITYPCUR
Local Char VALPAR

  If GABREV = "BPR" Then
    CODEDEVSOC = ""
    STAT_OK = 1
    IDIM = 0
    MNTBEFORE = 0
    MNTAFTER = 0
    #Obtention du type de devise
    Call PARAML("","CHGTYP",VALPAR) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
    ITYPCUR = val(VALPAR)
    If ITYPCUR = 0 Then
      ITYPCUR = 1
    Endif
    If !clalev([F:BPM]) : Local File BPMISC [BPM] : Endif
    Read [BPM]BPM0="DOO";[M:BPR0]BPRNUM
    If !fstat Then
      STAT_OK = 1
      CODEDEVSOC = ""
      Call GETDEVCPY(GDEFSOC, "", CODEDEVSOC, STAT_OK) From CRM_UTIL
      If !STAT_OK Then
        #Erreur
        GMESSAGE = mess(465,196,1)                         #Erreur lors de la recherche de la devise société.
        GERR = 1
      Endif
      # Devise d'origine
      # Devise destination
      # Devise de la société
      # Type de cours
      # Date du cours
      # Montant origine
      # Montant destination
      # Status de retour (0 = OK)
      If !GERR Then
        For IDIM = 0 To dim([F:BPM]DCBX)-1
          STAT_OK = 0
          MNTBEFORE = 0
          MNTAFTER = 0
          MNTBEFORE = [F:BPM]DCBX(IDIM)
          Call CONVERT(SZOLDCUR, SZNEWCUR, CODEDEVSOC, ITYPCUR, date$, MNTBEFORE, MNTAFTER, STAT_OK) From TRTDEV
          If STAT_OK Then
            #Erreur
            GERR = 1
            GMESSAGE = mess(468,196,1) - "DCBX" - "(a)"    #Erreur lors de la conversion du champs : DCBX
            Break                                          # FGR 26/04/2010 : X3SUIVI64293
          Else
            #Calcul OK
            [F:BPM]DCBX(IDIM) = MNTAFTER
          Endif
        Next
        If !GERR Then
          Call DEBTRANS From GLOCK
          Trbegin [BPM]
          Rewrite [BPM]
          If fstat Then
            Rollback
            GERR = 1
            GMESSAGE = mess(468,196,1) - "DCBX" - "(b)"    #Erreur lors de la conversion du champs : DCBX
          Else
            Commit
          Endif
        Endif
      Endif
    Endif
  Endif
End

#----------------------- BETFCY -----------------------------------#
#------------------------------------------------------------------#
#------------------------------------------------------------------#
Subprog AM_BETFCY(VALEUR)
Variable Integer VALEUR

Local Integer NI  # FGR 28/07/2014 : X3SUIVI100229
Local Integer NE  # FGR 28/07/2014 : X3SUIVI100229

  If VALEUR = 1 Then
    Raz [M]FCY
    Grizo [M]FCY
    #---- Traitement pour CLIENT seulement #
    If clalev([M:BPC4]) Then
      Raz [M:BPC4]XRCPFCY
      Raz [M:BPC4]RCPFCY #MAE, bg 51980
      Grizo [M:BPC4]XRCPFCY
      Affzo [M:BPC4]XRCPFCY
      # FGR 28/07/2014 : X3SUIVI100229 (début) : ça ne traite que les lignes nécessaires
      If find(0, [M:BPC4]FLMOD(0..[M:BPC4]NBDLV-1)) <> 0 Then
        NI = find(0, [M:BPC4]FLMOD(0..[M:BPC4]NBDLV-1))
        Repeat
          [M:BPC4]FLMOD(NI) = 1
          NE = NI
          NI = find(0, [M:BPC4]FLMOD(NE..[M:BPC4]NBDLV-1))
          If NI > 0 Then
            NI = NI + NE
          Endif
        Until NI <= 0
      Endif
      # FGR 28/07/2014 : X3SUIVI100229 (fin)
      End
    Endif
  Else
    Actzo [M]FCY
    #---- Traitement pour CLIENT seulement #
    If clalev([M:BPC4]) Then
      Raz [M:BPC4]XRCPFCY
      Actzo [M:BPC4]XRCPFCY
      Affzo [M:BPC4]XRCPFCY
      End
    Endif
  Endif
  Affzo [M]FCY
End

#----------------------- FCY --------------------------------------#
#------------------------------------------------------------------#
#------------------------------------------------------------------#
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

Local Char WBPRNUM

If VALEUR = "" & [M]BETFCY=2
    GMESSAGE=mess(10,123,1) : mkstat=2 : End
Elsif VALEUR = ""
    End
Endif
#-- Le site ne doit pas être référencé dans un autre tiers
If clalev([M:BPR0]) <> 0
    WBPRNUM = [M:BPR0]BPRNUM
Elsif clalev([M:BPS0]) <> 0
    WBPRNUM = [M:BPS0]BPSNUM
Elsif clalev([M:BPC0]) <> 0
    WBPRNUM = [M:BPC0]BPCNUM
Endif

# Pour gestion multi-société
#Local Char SOCIETE(GLONCPY)
#Gosub SETSOC From WWCPY

Read [BPR]BPR2(2)=2;VALEUR
If !fstat & [BPR]BPRNUM <> WBPRNUM
    GMESSAGE = mess(259,199,1) : mkstat=2 : End
Endif
[G:BPR]currind=1 : [G:BPR]currlen=0 : # Réinitialisation clé par défaut

Local Integer WOK:WOK=2
#-- Si tiers client
If ([M]BPCFLG=2 & GFONCTION="GESBPR") | GFONCTION="GESBPC"
#   Le site doit être un site d'achat ou un site financier
    If [F:FCY]PURFLG<>2 & [F:FCY]FINFLG<>2 mkstat=2 : GMESSAGE=mess(402,199,1) : End : Endif
#   Avertissement si le site n'est pas site d'achat
    If [F:FCY]PURFLG<>2 & [M]FCY<>VALEUR
        Call AVERTIR(mess(865,196,1),WOK) From GESECRAN : If WOK=1 mkstat=2 : End : Endif
    Endif
#   Les sites de réceptions ne sont pas sur la même société juridique
#    If [M:BPC3]LEGCPY<>[F:FCY]LEGCPY & sum([M]RCPFCY) <> "" mkstat = 2 : GMESSAGE=mess(416,199,1): End : Endif
Endif
#-- Si tiers fournisseur, le site doit être un site de vente ou un site financier
If ([M]BPSFLG=2 & GFONCTION="GESBPR") | GFONCTION="GESBPS"
#   Le site doit être un site de vente ou un site financier
    If [F:FCY]SALFLG<>2 & [F:FCY]FINFLG<>2 mkstat=2 : GMESSAGE=mess(407,199,1) : End : Endif
#   Avertissement si le site n'est pas site de vente
    If [F:FCY]SALFLG<>2 & [M]FCY<>VALEUR
        Call AVERTIR(mess(864,196,1),WOK) From GESECRAN : If WOK=1 mkstat=2 : End : Endif
    Endif
Endif
End
# ------------------------------------ FCY -----------------------------
#########################################################################
#    AM_FCY : Traité en 2 actions                                       #
#       BPRFCY1 : Traitement standard                                   #
#       AM_     : Web                                                   #
#########################################################################
