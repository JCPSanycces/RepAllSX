#----------------------- BPRACC --------------------------------------#
Subprog AM_BPRACC(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
    Actzo [M:BPR2]ACCCOD
    Call INITACCCOD([M:BPR2]ACCCOD,17) From TRTX3
Else
    Diszo [M:BPR2]ACCCOD
    Raz [M:BPR2]ACCCOD
Endif
Affzo [M:BPR2]ACCCOD
End
#--------------------------------------------------------------------------------
#                                        Ecran BPR2
#--------------------------------------------------------------------------------
#----------------------- GRUGPY --------------------------------------#
Subprog AM_GRUGPY(VALEUR)
Variable Char    VALEUR()
#---------------------------------------------------------------------------------#
# saisie de la consolidation si tiers appartient à un périmètre de consolidation  #
#---------------------------------------------------------------------------------#
If dim([M]GRUCOD)>0
    If VALEUR=""
        Raz   [M:BPR2]GRUCOD
        Grizo [M]GRUCOD
    Else
        Actzo [M]GRUCOD
    Endif
Endif

# 2015-04-23 DNE INSERT BEGIN (SAM #85794-3)
    If dim( [M]CPYREL ) > 0
        If VALEUR=""
            [M]CPYREL = 1
            Affzo [M]CPYREL
            Grizo [M]CPYREL
        Else
            Actzo [M]CPYREL
        Endif
    Endif
# 2015-04-23 DNE INSERT END
End

######################################################################################
Subprog AM_CRY(VALEUR)
Variable Char    VALEUR()
Local Char SZMESSAGE (250)
Local Integer IBRETOUR, I
IBRETOUR=1
If VALEUR<>""
    Call GETCRYDATA(VALEUR, [M]LAN, [M]CUR, SZMESSAGE, IBRETOUR) From TRTX3FNC
    If IBRETOUR= 1
        Affzo [M]1-99
        Case GABREV
         When "BPS" : If [M:BPS1]NBELEMENT<>0
                         For I=0 To [M:BPS1]NBELEMENT-1
                            If [M:BPS1]AMTCOD(I)=2 [M:BPS1]WWCUR(I)=[M]CUR Endif
                         Next I
                         Affzo [M:BPS1]30
                      Endif
##  X3-26017: Support for REX identification ("Registered Export System) for export out of EU/SAL_X3-29158 (LUCUE 12/19/17)
                      If dim([M:BPRS]REXNUM)>0
                        If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
                        Read [TCY]TCY0 = VALEUR
                        If fstat Raz [F:TCY] Endif
                        If [F:TCY]CRY="" or ([F:TCY]EECFLG<>2 & [F:TCY]GSPFLG<>2)
                          If [M:BPRS]REXNUM<>""
                            Raz [M:BPRS]REXNUM
                            Affzo [M:BPRS]REXNUM
                          Endif
                          Grizo [M:BPRS]REXNUM
                        Else
                          Actzo [M:BPRS]REXNUM
                        Endif
                      Endif
## End X3-26017: Support for REX identification ("Registered Export System) for export out of EU/SAL_X3-29158 (LUCUE 12/19/17)
         When "BPC" : If [M:BPC1]NBFAC<>0
                         For I=0 To [M:BPC1]NBFAC-1
                            If [M:BPC1]AMTCOD(I)=2 [M:BPC1]WWCUR(I)=[M]CUR Endif
                         Next I
                         Affzo [M:BPC1]30
                      Endif
                      #94635 RICAR 2014/04/21 - CASH VAT - BEGIN
                      Call VALIDATE_CSHVATRGM_CRY(VALEUR) From PORLEGLIB
                      #94635 RICAR 2014/04/21 - CASH VAT - END
                      If dim([M:BPC3]BELVATSUB)>0 & find(GREP,"C","D")
                       If VALEUR="BE" : [M:BPC3]BELVATSUB=2 Else [M:BPC3]BELVATSUB=1 : Endif
                       Affzo [M:BPC3]BELVATSUB
                      Endif
        Endcase
    Endif
Endif
End

######################################################################################
Subprog AV_BPRSHO(VALEUR)
Variable Char    VALEUR()

If GREP="D" & !GIMPORT
   If clalev([M:BPRC])<>0
      If [M:BPC0]REFCOU<>"" & [F:BPC]BPCNUM<>[M:BPC0]BPCNUM
         Effzo [M:BPC0]BPCNUM
      Endif
   Elsif clalev([M:BPRS]) <> 0
      If [M:BPS0]REFCOU<>"" & [F:BPS]BPSNUM<>[M:BPS0]BPSNUM
         Effzo [M:BPS0]BPSNUM
      Endif
   Endif
Endif

End

######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran BPR0) 06/06/2013 17:02:07 (MAE)
######################################################################################
Subprog IB_BRGCOD
If [M:BPR0]BRGOBJ = ""
    Raz GBOUT2
    Raz GBOUT1
Else If [M:BPR0]BRGOBJ="BPC" : Raz GBOUT2
  Else : Raz GBOUT1
  Endif
Endif
End

Subprog C_BRGCOD(VALEUR)
Variable Char    VALEUR()
Local Integer J

If clalev([F:BCG])  = 0 : Local File BPCCATEG [BCG] : Endif
If clalev([F:BSG])  = 0 : Local File BPSCATEG [BSG] : Endif

If VALEUR <> "" & [M:BPR0]BRGOBJ = ""
    #recherche si la catégorie est une catégorie client
    Read [BCG]BCG0=VALEUR
    If !fstat : [M:BPR0]BRGOBJ = "BPC" : Endif
  #recherche si la catégorie est une catégorie fournisseur
  Read [BSG]BSG0=VALEUR
    If !fstat
      If [M:BPR0]BRGOBJ <> ""
  #      La catégorie choisie existe en client et fournisseur, laquelle prendre ?
       Selbox mess(78,117,1),mess(17,7,1) Titled mess(124,7900,1) Using J : # Choix catégorie
        Case J
          When 1 : [M:BPR0]BRGOBJ ="BPC"
          When 2 : [M:BPR0]BRGOBJ ="BPS"
          When Default : [M:BPR0]BRGOBJ = ""
        Endcase
      Else
        [M:BPR0]BRGOBJ = "BPS"
      Endif
   Endif
   If [M:BPR0]BRGOBJ = "BPC"
    Call GET_ATEXTRA("BPCCATEG", "DESAXX", GLANGUE, [M:BPR0]BRGDES) From TRTX3TEX
    [M:BPR0]=[F:BCG]
    [M:BPR1]=[F:BCG]
    [M:BPR2]=[F:BCG]
   Else
    If [M:BPR0]BRGOBJ = "BPS"
      Call GET_ATEXTRA("BPSCATEG", "DESAXX", GLANGUE, [M:BPR0]BRGDES) From TRTX3TEX
      [M:BPR0]=[F:BSG]
      [M:BPR1]=[F:BSG]
      [M:BPR2]=[F:BSG]
    Else
      [M:BPR0]BRGOBJ = ""
      [M:BPR0]BRGCOD = ""
    Endif
   Endif
Affzo [M:BPR0]1-99
Affzo [M:BPR1]1-99
Affzo [M:BPR2]1-99
Endif

End

Subprog AM_BRGCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR="" Raz[M:BPR0]BRGDES : Affzo[M:BPR0]BRGDES: End Endif
#MAE, bg 101554
If GREP ="C" | GREP=""
  If [M:BPR0]BRGOBJ = "BPC"
    If clalev([F:BCG])  = 0 : Local File BPCCATEG [BCG] : Endif
    Read [BCG]BCG0=VALEUR
    If fstat
    # Issue 109039 - 2015-06-22 by MAE : message si catégorie non existante
        Call MESSAGE (mess(640,199,1)) From GESECRAN
        mkstat = 2
        End
    Endif
    Call GET_ATEXTRA("BPCCATEG", "DESAXX", GLANGUE, [M:BPR0]BRGDES) From TRTX3TEX
    [M:BPR0]=[F:BCG]
    [M:BPR1]=[F:BCG]
    [M:BPR2]=[F:BCG]
  Elsif [M:BPR0]BRGOBJ = "BPS"
    If clalev([F:BSG])  = 0 : Local File BPSCATEG [BSG] : Endif
    Read [BSG]BSG0=VALEUR
    If fstat
    # Issue 109039 - 2015-06-22 by MAE : message si catégorie non existante
        Call MESSAGE (mess(640,199,1)) From GESECRAN
        mkstat = 2
        End
    Endif
    Call GET_ATEXTRA("BPSCATEG", "DESAXX", GLANGUE, [M:BPR0]BRGDES) From TRTX3TEX
    [M:BPR0]=[F:BSG]
    [M:BPR1]=[F:BSG]
    [M:BPR2]=[F:BSG]
 #ISSUE 109039 - 2015-06-22 By MAE : #si catégorie non précisé, on controle uniquement qu'elle existe
  Elsif [M:BPR0]BRGOBJ = ""
    If clalev([F:BSG])  = 0 : Local File BPSCATEG [BSG] : Endif
    If clalev([F:BCG])  = 0 : Local File BPCCATEG [BCG] : Endif
    Read [BSG]BSG0=VALEUR
    If fstat
      Read [BCG]BCG0=VALEUR
      If fstat
        # Issue 109039 - 2015-06-22 by MAE : comment
        Call MESSAGE (mess(640,199,1)) From GESECRAN
        mkstat = 2
        End
      Endif
    Endif
   Endif
  Affzo [M:BPR0]1-99
  Affzo [M:BPR1]1-99
  Affzo [M:BPR2]1-99
Endif

End

Subprog AS_BPRNUM(VALEUR)
Variable Char    VALEUR()
If [M:BPR0]REFCOU<>"" & find(GREP,"C","D")
   mkstat = 2
Endif

End

Subprog C_BPRNUM(VALEUR)
Variable Char    VALEUR()
If [M:BPR0]REFCOU="" & VALEUR=""
   mkstat=2
Endif
End

######################################################################################
Subprog AM_SCAC(VALEUR)
Variable Char    VALEUR()
Local    Integer VALLEN

# 101090.sn
# - Fill in the length with "-" to get to 4 characters long per VICS standards.
If VALEUR<>""
  VALEUR = toupper(ctrans(VALEUR))
  VALLEN = len(VALEUR)
  If VALLEN<4
    VALEUR = VALEUR+string$(4-VALLEN,"-")
  Endif
Endif
# 101090.en

End


