###################################################################
Subprog MAJ_CNTNAM(SCLASSEF)
Value Char SCLASSEF

Local Integer WI
Local Char SCNTNAM(GLONAIN)
Local Integer INBCNT

  # FGR 06/08/2012 X3SUIVI83886
  Raz SCNTNAM
  WI = 0
  # ----------------------------
  Case SCLASSEF
    When "[F:BPR]"
      INBCNT = [M:CNTB]NBCNT
      If INBCNT > 0 Then
        WI = find (2,[M:CNTB]CNTFLG (0..[M:CNTB]NBCNT-1))
        If WI = 0 Then
          WI = 1
        Endif
        SCNTNAM = [M:CNTB]CCNCRM(WI-1)
      Endif
    When "[F:BPP]"
      INBCNT = [M:CNTP]NBCNT
      If INBCNT > 0 Then
        WI = find (2,[M:CNTP]CNTFLG (0..[M:CNTP]NBCNT-1))
        If WI = 0 Then
          WI = 1
        Endif
        SCNTNAM = [M:CNTP]CCNCRM(WI-1)
      Endif
    When "[F:BPC]"
      INBCNT = [M:CNTC]NBCNT
      If INBCNT > 0 Then
        WI = find (2,[M:CNTC]CNTFLG (0..[M:CNTC]NBCNT-1))
        If WI = 0 Then
          WI = 1
        Endif
        SCNTNAM = [M:CNTC]CCNCRM(WI-1)
      Endif
    When "[F:BPS]"
      INBCNT = [M:CNTS]NBCNT
      If INBCNT > 0 Then
        WI = find (2,[M:CNTS]CNTFLG (0..[M:CNTS]NBCNT-1))
        If WI = 0 Then
          WI = 1
        Endif
        SCNTNAM = [M:CNTS]CCNCRM(WI-1)
      Endif
    When "[F:BPT]"
      INBCNT = [M:CNTT]NBCNT
      If INBCNT > 0 Then
        WI = find (2,[M:CNTT]CNTFLG (0..[M:CNTT]NBCNT-1))
        If WI = 0 Then
          WI = 1
        Endif
        SCNTNAM = [M:CNTT]CCNCRM(WI-1)
      Endif
    When Default
      Raz SCNTNAM
  Endcase
  # ----------------------------
  If SCNTNAM <> "" Then
    If [F:BPR]CNTNAM = "" or SCLASSEF = "[F:BPR]" Then
      Read [F:BPR]=
      [F:BPR]CNTNAM = SCNTNAM
      Rewrite [F:BPR]
    Endif
    # --------------------------
    Case SCLASSEF
      When "[F:BPC]", "[F:BPP]"
        If [F:BPC]CNTNAM = "" Then
          Read [F:BPC]=
          [F:BPC]CNTNAM = SCNTNAM
          Rewrite [F:BPC]
        Endif
      When "[F:BPS]"
        If [F:BPS]CNTNAM = "" Then
          Read [F:BPS]=
          [F:BPS]CNTNAM = SCNTNAM
          Rewrite [F:BPS]
        Endif
      When "[F:BPT]"
        If [F:BPT]CNTNAM = "" Then
          Read [F:BPT]=
          [F:BPT]CNTNAM = SCNTNAM
          Rewrite [F:BPT]
        Endif
    Endcase
  Else
    If INBCNT <= 0 Then
      If [F:BPR]CNTNAM <> "" Then
        Read [F:BPR]=
        [F:BPR]CNTNAM = SCNTNAM
        Rewrite [F:BPR]
      Endif
      # --------------------------
      Case SCLASSEF
        When "[F:BPC]", "[F:BPP]"
          If [F:BPC]CNTNAM <> "" Then
            Read [F:BPC]=
            [F:BPC]CNTNAM = SCNTNAM
            Rewrite [F:BPC]
          Endif
        When "[F:BPS]"
          If [F:BPS]CNTNAM <> "" Then
            Read [F:BPS]=
            [F:BPS]CNTNAM = SCNTNAM
            Rewrite [F:BPS]
          Endif
        When "[F:BPT]"
          If [F:BPT]CNTNAM <> "" Then
            Read [F:BPT]=
            [F:BPT]CNTNAM = SCNTNAM
            Rewrite [F:BPT]
          Endif
      Endcase
    Endif
  Endif
End

