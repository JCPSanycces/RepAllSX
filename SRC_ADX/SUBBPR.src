# Issue X3-49093 - 2017-09-26 by SINGC : START
######################################################################################
Subprog C_VATNO(VALEUR)
Variable Char    VALEUR()

Local Char REGEX(10)

  REGEX = VALEUR
  If VALEUR <> AVOID.ACHAR and REGEX <> format$("K:10#", VALEUR) Then
    GMESSAGE = mess(149,100,1)
    mkstat = 2
    GERR = 1
  Endif
End

######################################################################################
Subprog C_REGNUM(VALEUR)
Variable Char    VALEUR()

Local Char REGEX(15)

  REGEX = VALEUR
  If VALEUR <> AVOID.ACHAR and REGEX <> format$("K:4#X6#X2#", VALEUR) and REGEX <> format$("K:13#", VALEUR) and REGEX <> format$("K:2A4#X4#", VALEUR) and REGEX <> format$("K:3#X3#", VALEUR) Then
    GMESSAGE = mess(149,100,1)
    mkstat = 2
    GERR = 1
  Endif
End
# Issue X3-49093 - 2017-09-26 by SINGC : END

######################################################################################
## Section automatically added (screen BPR1) 02/21/2018 17:39:32 (VAVIL)
######################################################################################
Subprog C_BPRNAM(VALEUR)
Variable Char    VALEUR()

# Issue X3-74615 - 2018-02-22 by VAVIL : should allow the field EECNUM to change from PT999999990
Local Shortint BPRSTAT : BPRSTAT = 0
If func AFNC.ACTIV("KPO") & !find(GREP,"C","D")
  Case GFONCTION
    When "GESBPR"
      If [M:BPR1]BPCFLG = 2 & (VALEUR <> [M:BPR1]BPRNAM) & (VALEUR <> "" & [M:BPR1]EECNUM = "PT999999990")
        Call IS_BPR_USED([M:BPR0]BPRNUM,[L]BPRSTAT) From PORLEGLIB
        If [L]BPRSTAT = 1 : GMESSAGE = mess(240,7711,1) : mkstat = 2 : Endif
      Endif
    When "GESBPC" :
      If [M:BPRC]BPCFLG = 2 & (VALEUR <> [M:BPRC]BPRNAM) & (VALEUR <> "" & [M:BPRC]EECNUM = "PT999999990")
        Call IS_BPR_USED([M:BPC0]BPCNUM,[L]BPRSTAT) From PORLEGLIB
        If [L]BPRSTAT = 1 : GMESSAGE = mess(240,7711,1) : mkstat = 2 : Endif
      Endif
    When "GESREP" :
      If [M:BPRR]BPCFLG = 2 & (VALEUR <> [M:BPRR]BPRNAM) & (VALEUR <> "" & [M:BPRR]EECNUM = "PT999999990")
        Call IS_BPR_USED([M:REP0]REPNUM,[L]BPRSTAT) From PORLEGLIB
        If [L]BPRSTAT = 1 : GMESSAGE = mess(240,7711,1) : mkstat = 2 : Endif
      Endif
    When "GESBPS" :
      If [M:BPRS]BPCFLG = 2 & (VALEUR <> [M:BPRS]BPRNAM) & (VALEUR <> "" & [M:BPRS]EECNUM = "PT999999990")
        Call IS_BPR_USED([M:BPS0]BPSNUM,[L]BPRSTAT) From PORLEGLIB
        If [L]BPRSTAT = 1 : GMESSAGE = mess(240,7711,1) : mkstat = 2 : Endif
      Endif
    When "GESBPT" :
      If [M:BPRT]BPCFLG = 2 & (VALEUR <> [M:BPRT]BPRNAM) & (VALEUR <> "" & [M:BPRT]EECNUM = "PT999999990")
        Call IS_BPR_USED([M:BPT0]BPTNUM,[L]BPRSTAT) From PORLEGLIB
        If [L]BPRSTAT = 1 : GMESSAGE = mess(240,7711,1) : mkstat = 2 : Endif
      Endif
  Endcase
Endif
# End issue X3-74615

End
