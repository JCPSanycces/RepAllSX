#<AdxTL>@(#)3.0.0.0 $Revision$
################################################################################################
# UTIIND02   Moulinette                                                                        #
# - Validation dictionnaire limitée aux types de données touchés dans les lots patchés dans P3 #
# - Validation dictionnaire limitée aux actions touchées dans les lots patchés dans P3         #
# - Mise à jour forcée de l'onglet sélection des objets touchés dans les lots patchés dans P3  #
# - Validation des objets et fenêtres correspondant                                            #
# - Validation dictionnaire des éventuels types de données correspondant à ces objets          #
################################################################################################
  Local Integer OK
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Moulinette UTIIND02") From LECFIC
  If nomap<>GDOSX3
    Call MAJ_UTIIND02(nomap)
  Else
    Call OUINON("Exécuter cette moulinette sur l'ensemble des dossiers de la solution",OK) From GESECRAN
    If OK<>2 : End : Endif
    If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
    For [ADS]
      If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
        Call MAJ_UTIIND02([F:ADS]DOSSIER)
      Endif
    Next
  Endif
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
End

Subprog MAJ_UTIIND02(DOSSIER)
Value Char DOSSIER

  Local Char WOBJET(GLONAOB), WTYP(GLONATY), WACTION(GLONACT)
  Local Integer COMPTEUR, I
  Local Integer VALMOD(20)
  
  If DOSSIER=GDOSX3 : End : Endif
  
  Call ECR_TRACE("UTIIND02 : Process Start on : "+DOSSIER,0) From GESECRAN

  Local File ATYPE [XATY]

  For I=0 To dim(VALMOD)-1
    VALMOD(I) = 2
  Next I

# Types de données
  For WTYP = "AYH","AGC","DEP","TEM","TLO","WRH"
    Call ECR_TRACE("",0) From GESECRAN
    Call ECR_TRACE("UTIIND02 : Processing Data type"-WTYP,0) From GESECRAN
    Call VALID_TRT(DOSSIER,0,WTYP,"","","","","Z","","Z","","","","Z","","","","Z",VALMOD) From VALDICO
    COMPTEUR += 1
  Next WTYP
  
  Call ECR_TRACE("UTIIND02 : "+num$(COMPTEUR)+" data types processed",0) From GESECRAN

# Actions
  Raz COMPTEUR
  For WACTION = "AYIWSRGEN","VISUAYS","CNSAWWTUN1","CNSAWWTUN2","CNSAWWTUN3","CNSAWWTUN4","CNSAWWTUN5"
&              ,"CNSAWWTUN6","CNSAWWTUN7","CNSAWWTUN8","CONSAWW","AEXPSCHEMA","SELFLDTAB5","SELINTTAB3"
&              ,"CONSALO","CONSAUD","CONSAUH","AFRCONT","GESCWRH","WRHCTL","WRHSEL","ITWSCC","SELJOUGTE"
&              ,"SAIITNH","SAISRE5"
    Call ECR_TRACE("",0) From GESECRAN
    Call ECR_TRACE("UTIIND02 : Processing Action"-WACTION,0) From GESECRAN
    Call VALID_TRT(DOSSIER,0,"","",WACTION,"","","","","Z","","","","Z","","","","",VALMOD) From VALDICO
    COMPTEUR += 1
  Next WACTION
  
  Call ECR_TRACE("UTIIND02 : "+num$(COMPTEUR)+" actions processed",0) From GESECRAN

# Objets
  Raz COMPTEUR
# on ne traite pas les types FCY et AGF car c'est coûteux et inutile (pas de modif. de l'onglet sélection)
  For WOBJET = "AS4","AY3","AY4","AYA","AYB","AYC","AYD","AYE","AYF","AYG",
&              "AYI","AYL","AYM","AYS","AYW","APV","AYH","AW3","AW4","ADI",
&              "APR","ENV","BBY","DBY","ITG","ITW","MTK","PNH",
&              "PRH","PRL","SCO","SCS","SDH","SIH","SMO","SMR","SNL","SNX",
&              "SRH","SRL","SRS","STQ","STR","WRH","MFG","SOH","SOQ","BP1",
&              "BP2","DU5","DU6","EX1","GA3","IT1","LI1","LT1","MF1","MF2",
&              "MFK","MKI","MKM","MKO","PA1","PI1","PO1","PO4","PP1","PQ1",
&              "PQ2","PR1","PT1","SC2","CL5","OM2","ON2","OP5","OP6","OP7",
&              "OT2","PH1"
    Call ECR_TRACE("",0) From GESECRAN
    Call ECR_TRACE("UTIIND02 : Processing Object"-WOBJET,0) From GESECRAN
    Call MAJ_SEL(DOSSIER,WOBJET) From PATCHAOB
    Call VALID_TRT(DOSSIER,0,"","","","","","","","",WOBJET,WOBJET,"","","","","","",VALMOD) From VALDICO
    Call VALFEN(DOSSIER,WOBJET) From SUBAOB
# Type de données lié à l'objet (s'il existe)
    Raz WTYP
    For [XATY] Where OBJLIEN=WOBJET
      WTYP = [F:XATY]CODTYP
    Next XATY
    If WTYP<>""
      Call ECR_TRACE("UTIIND02 : Processing linked data type"-WTYP,0) From GESECRAN
      Call VALID_TRT(DOSSIER,0,WTYP,"","","","","Z","","Z","","","","Z","","","","Z",VALMOD) From VALDICO
    Endif
    COMPTEUR += 1
  Next WOBJET
  
  Call ECR_TRACE("UTIIND02 : "+num$(COMPTEUR)+" objects processed",0) From GESECRAN

  Close Local File [XATY]

End

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
  If APPLI=GDOSX3 : End : Endif
  Call MAJ_UTIIND02(APPLI)
End

#######################################################################
# Pour exécution depuis DOSMAJ (validation dossier)
#######################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
  If APPLI=GDOSX3 : End : Endif
  Call MAJ_UTIIND02(APPLI)
End
