#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################################################
#  Sous programmes pour la gestion des rendez-vous                       Module CRM     21 juin 2000     #
##########################################################################################################
#  FILAPPPLC           : Renseigne le lieu du rendez-vous.
#  XCCN_BAP            : Remplit le lieu du rendez-vous pour un interlocuteur
#  LOADPLC             : Charge un autre lieu de rendez-vous
#  CHKREPDISP          : Vérifie la disponibilité des intervenants au rendez-vous.
#  CHKDISIITN          : Contrôle des conflits horaires avec des interventions
#  MNGUPDAPTDAT        : Assure la gestion des réservations de ressources en cas de modif de la date d'un rdv
#  UPDRRSORI           : Met à jour l'origine des réservations de ressources.
#  CLEANRRSORI         : Assure l'exactitude de l'origine des réservations de ressources.
#  UPDRRSBAP           : Met à jour les réservations de ressources sur la base du nouvel horaire du rdv.
#  DISPICON            : Affichage des icônes
#  SAVECLOB            : Enregistrement des CLOBs
#  DELCLOB             : Suppression des CLOBs
#  LOADCLOB            : Chargement du CLOB compte-rendu
#  DELRRS              : Suppression des réservations de ressources
#  DISPCCN             : Affichage de l'interlocuteur
#  SAVEVALINI          : Sauvegarde des valeurs initiales
#  DEFOBJORI           : Définition du type de pièce
#  VERIF_ORGANISATEUR  : Vérifie que l'organisateur appartient à la liste des représentant
#  COMPLETREP          : Complète le tableau des  représentants
#  CRESYDALLREP        : Création des données de synchronisation pour tous les représentants
#  GERESYDALLREP       : Gestion des données de synchronisation pour tous les représentants
#  DELLSYDALLREP       : Suppression des données de synchronisation pour tous les représentants
#  BAPGEREALLAINCOR    : Gestion de toutes les relations interlocuteur /correspondant pour le rendez-vous
#  BAPGEREALLREPCOR    : Gestion de toutes les relations représentants /correspondant pour le rendez-vous
#  FORCEBAP            : créer les données de synchro de forçage pour le représentant
#  GERE_LCM_CREATION   : gere les données  pour la gestion des en cours en creation
#  GERE_LCM_MODIF      : gere les données  pour la gestion des en cours en modification
#  GERE_LCM_ANNULE     : gere les données  pour la gestion des en cours en annulation
#  CHKAPPDISP          : Vérifie la disponibilité des intervenants du rendez-vous.
#  VERIFDATE           : vérifie la cohérence des dates
##########################################################################################################
##########################################################################################################
Subprog AFFICHE_BCK_TIERS(SZBPRNUM)
Value Char SZBPRNUM

Local Char SZTYP(GLONDES)

  # FGR 05/04/2011 : X3SUIVI72615
  Call GETBPRTYP(SZBPRNUM, SZTYP, [M:BAP0]APTCMPAOB) From CRM_UTIL
  Chgtzn [M:BAP0]APTCMP With SZTYP
  [M:BAP0]APTCMPLIB = SZTYP
End

##########################################################################################################
Funprog GET_CONFLIT_BAP(SZCODE)
Value Char SZCODE

Local Integer IARENDRE

  If SZCODE = "" Then
    IARENDRE = 1               : # NON
  Else
    If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
    Read [ADI]CODE=433;SZCODE
    If fstat Then
      IARENDRE = 1             : # NON
    Else
      Case [F:ADI]N2
        When 1,2
          IARENDRE = [F:ADI]N2 : # NON/OUI
        When Default
          IARENDRE = 1         : # NON
      Endcase
    Endif
  Endif
End IARENDRE

##########################################################################################################
#  FILAPPPLC  : Renseigne le lieu du rendez-vous.
##########################################################################################################
Subprog FILAPPPLC(CODPLC, MODIF, SZBPR)
Value Integer CODPLC
Value Integer MODIF
Variable Char SZBPR

Local Char CODADDDEF(GLONADR)

  #Déroute le traitement vers la définition d'un lieu interlocuteur.
  If MODIF = 9 Then
    Call XCCN_BAP(SZBPR, MODIF)
    End
  Endif
  # -------------------------
  Local File BPCUSTOMER [BPC]                                        # FGR 04/11/2015 : X3SUIVI111913
  #Obtient le code adresse par défaut pour la société à visiter
  Case CODPLC
    When 1
      # Site du client
      If SZBPR = "" Then
        If [M:BAP0]APTCMP = "" Then
          If [M:BAP1]APTCCNNUM(0) = "" Then
            End
          Else
            Call XCCN_BAP(SZBPR, MODIF)
            End
          Endif
        Else
          #Read[BPR]BPR0=[M:BAP0]APTCMP                              # FGR 04/11/2015 : X3SUIVI111913
          Read[BPC]BPC0=[M:BAP0]APTCMP                               # FGR 04/11/2015 : X3SUIVI111913
        Endif
      Else
        #Read[BPR]BPR0=SZBPR                                         # FGR 04/11/2015 : X3SUIVI111913
        Read[BPC]BPC0=SZBPR                                          # FGR 04/11/2015 : X3SUIVI111913
      Endif
      #CODADDDEF = [F:BPR]BPAADD                                     # FGR 04/11/2015 : X3SUIVI111913
      CODADDDEF = [F:BPC]BPAADD                                      # FGR 04/11/2015 : X3SUIVI111913
      If SZBPR = "" Then
        Read [BPA]BPA0=1;[M:BAP0]APTCMP;CODADDDEF
      Else
        Read [BPA]BPA0=1;SZBPR;CODADDDEF
      Endif
      [M:BAP3]APTADD(0) = [F:BPA]BPAADDLIG(0)
      [M:BAP3]APTADD(1) = [F:BPA]BPAADDLIG(1)
      [M:BAP3]APTADD(2) = [F:BPA]BPAADDLIG(2)
      [M:BAP3]APTZIP = [F:BPA]POSCOD
      [M:BAP3]APTCTY = [F:BPA]CTY
      [M:BAP3]APTCRY = [F:BPA]CRY
      [M:BAP3]APTSAT = [F:BPA]SAT
      [M:BAP3]APTTEL = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
      [M:BAP3]APTMOB = [F:BPA]TEL(4)   # FGR 27/10/2015 : X3SUIVI111913
      [M:BAP3]APTEML = [F:BPA]WEB(0)   # FGR 27/10/2015 : X3SUIVI111913
      Raz [M:BAP3]APTTYPADD
      Raz [M:BAP3]APTCODADD
      Raz [M:BAP3]APTRECADD
      Affzo [M:BAP3]1-99
    When 2
      # En nos locaux
      # --------------------------------------
      # FGR 04/11/2015 : X3SUIVI111913 (début)
      #Read[BPR]BPR0=[M:BAP2]APTREPNUM(0)
      #CODADDDEF = [F:BPR]BPAADD
      #Read [BPA]BPA0=1;[M:BAP2]APTREPNUM(0);CODADDDEF
      If [M:BAP2]ATPREPMNA <> "" Then
        # S'il y a un organisateur on prend son adresse par défaut
        Local File SALESREP [REP]
        Read [REP]REP0=[M:BAP2]ATPREPMNA
        CODADDDEF = [F:REP]BPAADD
        Read [BPA]BPA0=1;[M:BAP2]ATPREPMNA;CODADDDEF
      Else
        # sinon, on prend l'adresse par défaut du site
        Local File FACILITY [FCY]
        Read [FCY]FCY0=[M:BAP0]SALFCY
        CODADDDEF = [F:FCY]BPAADD
        Read [BPA]BPA0=3;[M:BAP0]SALFCY;CODADDDEF
      Endif
      # FGR 04/11/2015 : X3SUIVI111913 (fin)
      # --------------------------------------
      [M:BAP3]APTADD(0) = [F:BPA]BPAADDLIG(0)
      [M:BAP3]APTADD(1) = [F:BPA]BPAADDLIG(1)
      [M:BAP3]APTADD(2) = [F:BPA]BPAADDLIG(2)
      [M:BAP3]APTZIP = [F:BPA]POSCOD
      [M:BAP3]APTCTY = [F:BPA]CTY
      [M:BAP3]APTCRY = [F:BPA]CRY
      [M:BAP3]APTSAT = [F:BPA]SAT
      [M:BAP3]APTTEL = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
      [M:BAP3]APTMOB = [F:BPA]TEL(4)   # FGR 27/10/2015 : X3SUIVI111913
      [M:BAP3]APTEML = [F:BPA]WEB(0)   # FGR 27/10/2015 : X3SUIVI111913
      Raz [M:BAP3]APTTYPADD
      Raz [M:BAP3]APTCODADD
      Raz [M:BAP3]APTRECADD
      Affzo [M:BAP3]1-99
    When 3
      # Autres
      If MODIF Then
        Raz [M:BAP3]APTADD(0)
        Raz [M:BAP3]APTADD(1)
        Raz [M:BAP3]APTADD(2)
        Raz [M:BAP3]APTZIP
        Raz [M:BAP3]APTCTY
        Raz [M:BAP3]APTCRY
        Raz [M:BAP3]APTSAT
        Raz [M:BAP3]APTTEL
        Raz [M:BAP3]APTMOB             # FGR 27/10/2015 : X3SUIVI111913
        Raz [M:BAP3]APTEML             # FGR 27/10/2015 : X3SUIVI111913
        Raz [M:BAP3]APTTYPADD
        Raz [M:BAP3]APTCODADD
        Raz [M:BAP3]APTRECADD
        Affzo [M:BAP3]1-99
      Endif
    When Default
  Endcase
End

##########################################################################################################
#Remplit le lieu du rendez-vous pour un interlocuteur
Subprog XCCN_BAP(SZBPR, MODIF)
Value Char SZBPR
Value Integer MODIF

  # FGR 12/04/2012 : X3SUIVI81044 : L'interlocuteur peut être un Lead. Dans ce cas, c'est l'adresse par défaut du lead qu'il faut prendre
  If MODIF = 9 Then
    Read [AIN]AIN0=SZBPR
  Else
    Read [AIN]AIN0=[M:BAP1]APTCCNNUM(0)
  Endif
  If fstat Then
    End
  Else
    If [F:AIN]CNTTYP = 2 Then
      # Lead
      Filter [F:BPA] Where [F:BPA]BPATYP = 6 and [F:BPA]BPANUM = [F:AIN]CNTNUM and [F:BPA]BPAADDFLG = G_OUI
      For [F:BPA]
        [M:BAP3]APTADD(0) = [F:BPA]BPAADDLIG(0)
        [M:BAP3]APTADD(1) = [F:BPA]BPAADDLIG(1)
        [M:BAP3]APTADD(2) = [F:BPA]BPAADDLIG(2)
        [M:BAP3]APTZIP = [F:BPA]POSCOD
        [M:BAP3]APTCTY = [F:BPA]CTY
        [M:BAP3]APTCRY = [F:BPA]CRY
        [M:BAP3]APTSAT = [F:BPA]SAT
        [M:BAP3]APTTEL = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
        [M:BAP3]APTMOB = [F:BPA]TEL(4)   # FGR 27/10/2015 : X3SUIVI111913
        [M:BAP3]APTEML = [F:BPA]WEB(0)   # FGR 27/10/2015 : X3SUIVI111913
        Raz [M:BAP3]APTTYPADD
        Raz [M:BAP3]APTCODADD
        Raz [M:BAP3]APTRECADD
        Affzo [M:BAP3]1-99
        Break
      Next
      Filter [F:BPA]
    Else
      # Interlocuteur
      [M:BAP3]APTADD(0) = [F:AIN]ADD(0)
      [M:BAP3]APTADD(1) = [F:AIN]ADD(1)
      [M:BAP3]APTADD(2) = [F:AIN]ADD(2)
      [M:BAP3]APTZIP = [F:AIN]ZIP
      [M:BAP3]APTCTY = [F:AIN]CTY
      [M:BAP3]APTCRY = [F:AIN]CRY
      [M:BAP3]APTSAT = [F:AIN]SAT
      [M:BAP3]APTTEL = [F:AIN]CNTETS
      [M:BAP3]APTMOB = [F:AIN]CNTMOB   # FGR 27/10/2015 : X3SUIVI111913
      [M:BAP3]APTEML = [F:AIN]CNTEMA   # FGR 27/10/2015 : X3SUIVI111913
      Raz [M:BAP3]APTTYPADD
      Raz [M:BAP3]APTCODADD
      Raz [M:BAP3]APTRECADD
      Affzo [M:BAP3]1-99
    Endif
  Endif
End

##########################################################################################################
# Charge un autre lieu de rendez-vous
##############################################################
Subprog LOADPLC
  #Adresse Interlocuteur
  If [M:BAP3]APTTYPADD = 1 Then
    Read [AIN]AIN0=[M:BAP3]APTRECADD
    If fstat Then
      [M:BAP3]APTADD(0) = [F:BAP]APTADD(0)
      [M:BAP3]APTADD(1) = [F:BAP]APTADD(1)
      [M:BAP3]APTADD(2) = [F:BAP]APTADD(2)
      [M:BAP3]APTZIP = [F:BAP]APTZIP
      [M:BAP3]APTCTY = [F:BAP]APTCTY
      [M:BAP3]APTCRY = [F:BAP]APTCRY
      [M:BAP3]APTSAT = [F:BAP]APTSAT
      [M:BAP3]APTTEL = [F:BAP]APTTEL
      [M:BAP3]APTMOB = [F:BAP]APTMOB   # FGR 27/10/2015 : X3SUIVI111913
      [M:BAP3]APTEML = [F:BAP]APTEML   # FGR 27/10/2015 : X3SUIVI111913
    Else
      [M:BAP3]APTADD(0) = [F:AIN]ADD(0)
      [M:BAP3]APTADD(1) = [F:AIN]ADD(1)
      [M:BAP3]APTADD(2) = [F:AIN]ADD(2)
      [M:BAP3]APTZIP = [F:AIN]ZIP
      [M:BAP3]APTCTY = [F:AIN]CTY
      [M:BAP3]APTCRY = [F:AIN]CRY
      [M:BAP3]APTSAT = [F:AIN]SAT
      [M:BAP3]APTTEL = [F:AIN]CNTETS
      [M:BAP3]APTMOB = [F:AIN]CNTMOB   # FGR 27/10/2015 : X3SUIVI111913
      [M:BAP3]APTEML = [F:AIN]CNTEMA   # FGR 27/10/2015 : X3SUIVI111913
    Endif
  Endif
  If [M:BAP3]APTTYPADD > 1 Then
    If [M:BAP3]APTTYPADD = 2 Then
      #Adresse Tiers
      Read [BPA]BPA0=1;[M:BAP3]APTRECADD;[M:BAP3]APTCODADD
    Elsif [M:BAP3]APTTYPADD = 3 Then
      #Adresse Société
      Read [BPA]BPA0=2;[M:BAP3]APTRECADD;[M:BAP3]APTCODADD
    Elsif [M:BAP3]APTTYPADD = 4 Then
      #Adresse Site
      Read [BPA]BPA0=3;[M:BAP3]APTRECADD;[M:BAP3]APTCODADD
    Endif
    If fstat Then
      [M:BAP3]APTADD(0) = [F:BAP]APTADD(0)
      [M:BAP3]APTADD(1) = [F:BAP]APTADD(1)
      [M:BAP3]APTADD(2) = [F:BAP]APTADD(2)
      [M:BAP3]APTZIP = [F:BAP]APTZIP
      [M:BAP3]APTCTY = [F:BAP]APTCTY
      [M:BAP3]APTCRY = [F:BAP]APTCRY
      [M:BAP3]APTSAT = [F:BAP]APTSAT
      [M:BAP3]APTTEL = [F:BAP]APTTEL
      [M:BAP3]APTMOB = [F:BAP]APTMOB   # FGR 27/10/2015 : X3SUIVI111913
      [M:BAP3]APTEML = [F:BAP]APTEML   # FGR 27/10/2015 : X3SUIVI111913
    Else
      [M:BAP3]APTADD(0) = [F:BPA]BPAADDLIG(0)
      [M:BAP3]APTADD(1) = [F:BPA]BPAADDLIG(1)
      [M:BAP3]APTADD(2) = [F:BPA]BPAADDLIG(2)
      [M:BAP3]APTZIP = [F:BPA]POSCOD
      [M:BAP3]APTCTY = [F:BPA]CTY
      [M:BAP3]APTCRY = [F:BPA]CRY
      [M:BAP3]APTSAT = [F:BPA]SAT
      [M:BAP3]APTTEL = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
      [M:BAP3]APTMOB = [F:BPA]TEL(4)   # FGR 27/10/2015 : X3SUIVI111913
      [M:BAP3]APTEML = [F:BPA]WEB(0)   # FGR 27/10/2015 : X3SUIVI111913
    Endif
  Endif
End

##########################################################################################################
#  CHKREPDISP : Vérifie la disponibilité des intervenants au rendez-vous.
########################################################################################
$CHKREPDISP
Local Integer Y
Local Integer Y2
Local Integer SUBY
Local Integer ICONFLICT
Local Integer INBCTL

Local Integer IPTPOS
Local Integer IC1DAYC
Local Decimal IC1HOURC
Local Char SZC1HOURC
Local Decimal IC1MINUTEC
Local Decimal IC1TOTC
Local Integer IC2DAYC
Local Decimal IC2HOURC
Local Char SZC2HOURC
Local Decimal IC2MINUTEC
Local Decimal IC2TOTC

Local Integer IF1DAYC
Local Decimal IF1HOURC
Local Char SZF1HOURC
Local Decimal IF1MINUTEC
Local Decimal IF1TOTC
Local Integer IF2DAYC
Local Decimal IF2HOURC
Local Char SZF2HOURC
Local Decimal IF2MINUTEC
Local Decimal IF2TOTC

  If !clalev([F:BAPW]) : Local File BAPPOINT [BAPW] : Endif
  IPTPOS = 0
  IC1DAYC = nday([M:BAP1]APTDAT)
  IC1MINUTEC = val(mid$([M:BAP1]APTHOU, 3, 2)) / 60
  IC1HOURC = ((100 * val(left$([M:BAP1]APTHOU, 2))) / 24) + IC1MINUTEC
  IPTPOS = instr(1, num$(IC1HOURC), '.')
  If IPTPOS Then
    SZC1HOURC = left$(num$(IC1HOURC), IPTPOS-1) + right$(num$(IC1HOURC), IPTPOS+1)
  Else
    SZC1HOURC = num$(IC1HOURC)
  Endif
  IC1TOTC = val(num$(IC1DAYC) + '.' + SZC1HOURC)
  IPTPOS = 0
  IC2DAYC = nday([M:BAP1]APTDATEND)
  IC2MINUTEC = val(mid$([M:BAP1]APTHOUEND, 3, 2)) / 60
  IC2HOURC = ((100 * val(left$([M:BAP1]APTHOUEND, 2))) / 24) + IC2MINUTEC
  IPTPOS = instr(1, num$(IC2HOURC), '.')
  If IPTPOS Then
    SZC2HOURC = left$(num$(IC2HOURC), IPTPOS-1) + right$(num$(IC2HOURC), IPTPOS+1)
  Else
    SZC2HOURC = num$(IC2HOURC)
  Endif
  IC2TOTC = val(num$(IC2DAYC) + '.' + SZC2HOURC)
  ICONFLICT = 0
  Raz IBUSYREP
  Raz GSZCONFAPP
  INBCTL = 0
  While INBCTL < 3
    If INBCTL = 0 Then
      Filter [BAPW] Where (([F:BAPW]APTDAT >= [M:BAP1]APTDAT and [F:BAPW]APTDAT <= [M:BAP1]APTDATEND)
&                       or ([F:BAPW]APTDATEND >= [M:BAP1]APTDAT and [F:BAPW]APTDATEND <= [M:BAP1]APTDATEND))
&                     and [F:BAPW]APTDAT <> [00/00/00] and [F:BAPW]APTDON <> 2
    Elsif INBCTL = 1 Then
      Filter [BAPW] Where ([F:BAPW]APTDAT < [M:BAP1]APTDAT and [F:BAPW]APTDATEND > [M:BAP1]APTDATEND)
&                     and [F:BAPW]APTDAT <> [00/00/00] and [F:BAPW]APTDON <> 2
    Elsif INBCTL = 2 Then
        Filter [BAPW] Where ([F:BAPW]APTDAT > [M:BAP1]APTDAT and [F:BAPW]APTDATEND < [M:BAP1]APTDATEND)
&                       and [F:BAPW]APTDAT <> [00/00/00] and [F:BAPW]APTDON <> 2
    Endif
    For [BAPW]APP2
      # FGR 24/03/2009 : X3SUIVI53600 : Si on est là, c'est que le conflit n'est pas autorisé sur le RdV courant
      #                                 On regarde s'il l'est dans ceux trouvés dans BAPW
      If [F:BAPW]APTNUM <> [M:BAP0]APTNUM and func GET_CONFLIT_BAP([F:BAPW]APTTYP) = 1 Then
        IPTPOS = 0
        IF1DAYC = nday([F:BAPW]APTDAT)
        IF1MINUTEC = val(mid$([F:BAPW]APTHOU, 3, 2)) / 60
        IF1HOURC = ((100 * val(left$([F:BAPW]APTHOU, 2))) / 24) + IF1MINUTEC
        IPTPOS = instr(1, num$(IF1HOURC), '.')
        If IPTPOS Then
          SZF1HOURC = left$(num$(IF1HOURC), IPTPOS-1) + right$(num$(IF1HOURC), IPTPOS+1)
        Else
          SZF1HOURC = num$(IF1HOURC)
        Endif
        IF1TOTC = val(num$(IF1DAYC) + '.' + SZF1HOURC)
        IPTPOS = 0
        IF2DAYC = nday([F:BAPW]APTDATEND)
        IF2MINUTEC = val(mid$([F:BAPW]APTHOUEND, 3, 2)) / 60
        IF2HOURC = ((100 * val(left$([F:BAPW]APTHOUEND, 2))) / 24) + IF2MINUTEC
        IPTPOS = instr(1, num$(IF2HOURC), '.')
        If IPTPOS Then
          SZF2HOURC = left$(num$(IF2HOURC), IPTPOS-1) + right$(num$(IF2HOURC), IPTPOS+1)
        Else
          SZF2HOURC = num$(IF2HOURC)
        Endif
        IF2TOTC = val(num$(IF2DAYC) + '.' + SZF2HOURC)
        If IC1TOTC >= IF1TOTC and IC1TOTC <= IF2TOTC Then
          If IF2TOTC <> IC1TOTC Then
            ICONFLICT = 1
          Endif
        Endif
        If IC2TOTC >= IF1TOTC and IC2TOTC <= IF2TOTC Then
          If IF1TOTC <> IC2TOTC Then
            ICONFLICT = 1
          Endif
        Endif
        If IC1TOTC <= IF1TOTC and IC2TOTC >= IF2TOTC Then
          ICONFLICT = 1
        Endif
        If ICONFLICT Then
          #Vérifie d'abord la disponibilité de l'intervenant principal.
          If [F:BAPW]APTREPNUM(0) = [M:BAP2]APTREPNUM(0) Then
            SZDSTRDAT = day$([F:BAPW]APTDAT) - num$(day([F:BAPW]APTDAT)) - month$([F:BAPW]APTDAT) - num$(year([F:BAPW]APTDAT))
            SZDSTRHOU = left$([F:BAPW]APTHOU, 2) + ":" + mid$([F:BAPW]APTHOU, 3, 2)
            SZDENDDAT = day$([F:BAPW]APTDATEND) - num$(day([F:BAPW]APTDATEND)) - month$([F:BAPW]APTDATEND) - num$(year([F:BAPW]APTDATEND))
            SZDENDHOU = left$([F:BAPW]APTHOUEND, 2) + ":" + mid$([F:BAPW]APTHOUEND, 3, 2)
            REPISDISP = 1
            Break
          Endif
          #Vérifie ensuite la disponibilité des différents intervenants.
          For  Y = 0 To dim([F:BAPW]APTREPNUM)-1
            For SUBY = 0 To dim([M:BAP2]APTREPNUM)-1
              If [F:BAPW]APTREPNUM(Y) <> "" Then
                If [M:BAP2]APTREPNUM(SUBY) <> "" Then
                  If [F:BAPW]APTREPNUM(Y) = [M:BAP2]APTREPNUM(SUBY) Then
                    IBUSYREP(SUBY) = 1
                    REPISDISP = 2
                    #Mise en mémoire du rdv en conflit.
                    For Y2 = 0 To 9
                      If GSZCONFAPP(SUBY+(10*Y2)) = "" Then
                        GSZCONFAPP(SUBY+(10*Y2)) = [F:BAPW]APTNUM
                        Break
                      Endif
                    Next
                  Endif
                Endif
              Endif
            Next
          Next
          ICONFLICT = 0
        Endif
      Endif
    Next
    Filter [BAPW]
    If REPISDISP Then
      Break
    Endif
    INBCTL += 1
  Wend
Return

##########################################################################################################
#  CHKDISIITN : Contrôle des conflits horaires avec des interventions
########################################################################################
Subprog CHKDISIITN(ISECONLY, SZDDSTR, SZDDEND, SZBUSYREP, ISDISP)
Value Integer ISECONLY
Variable Char SZDDSTR
Variable Char SZDDEND
Variable Char SZBUSYREP
Variable Integer ISDISP

Local Integer Y
Local Integer Y2
Local Integer ICONFLICT
Local Integer INBCTL
Local Char SZCODPLC
Local Char SZCODPLC2
Local Integer IRSFOUND
Local Char SZREPTOCTL(GLONREP)
Local Char SZCFLITNLIS(GLONVCR)(10)
Local Integer IITNINF(10)
Local Integer IFULL

Local Integer IPTPOS
Local Integer IC1DAYC
Local Decimal IC1HOURC
Local Char SZC1HOURC
Local Decimal IC1MINUTEC
Local Decimal IC1TOTC
Local Integer IC2DAYC
Local Decimal IC2HOURC
Local Char SZC2HOURC
Local Decimal IC2MINUTEC
Local Decimal IC2TOTC

Local Integer IF1DAYC
Local Decimal IF1HOURC
Local Char SZF1HOURC
Local Decimal IF1MINUTEC
Local Decimal IF1TOTC
Local Integer IF2DAYC
Local Decimal IF2HOURC
Local Char SZF2HOURC
Local Decimal IF2MINUTEC
Local Decimal IF2TOTC

  If !clalev([F:ITN]) : Local File INTERVEN [ITN] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  Raz SZCFLITNLIS
  Raz IITNINF
  IFULL = 0
  SZREPTOCTL = ""
  IRSFOUND = 0
  ISDISP = 0
  IPTPOS = 0
  IC1DAYC = nday([M:BAP1]APTDAT)
  IC1MINUTEC = val(mid$([M:BAP1]APTHOU, 3, 2)) / 60
  IC1HOURC = ((100 * val(left$([M:BAP1]APTHOU, 2))) / 24) + IC1MINUTEC
  IPTPOS = instr(1, num$(IC1HOURC), '.')
  If IPTPOS Then
    SZC1HOURC = left$(num$(IC1HOURC), IPTPOS-1) + right$(num$(IC1HOURC), IPTPOS+1)
  Else
    SZC1HOURC = num$(IC1HOURC)
  Endif
  IC1TOTC = val(num$(IC1DAYC) + '.' + SZC1HOURC)
  IPTPOS = 0
  IC2DAYC = nday([M:BAP1]APTDATEND)
  IC2MINUTEC = val(mid$([M:BAP1]APTHOUEND, 3, 2)) / 60
  IC2HOURC = ((100 * val(left$([M:BAP1]APTHOUEND, 2))) / 24) + IC2MINUTEC
  IPTPOS = instr(1, num$(IC2HOURC), '.')
  If IPTPOS Then
    SZC2HOURC = left$(num$(IC2HOURC), IPTPOS-1) + right$(num$(IC2HOURC), IPTPOS+1)
  Else
    SZC2HOURC = num$(IC2HOURC)
  Endif
  IC2TOTC = val(num$(IC2DAYC) + '.' + SZC2HOURC)
  #Obtient le code utilisateur du représentant passé en paramètre
  If SZBUSYREP <> "" Then
    Read [REP]REP0=SZBUSYREP
    If !fstat Then
      If [F:REP]AUSNUM <> "" Then
        Read [AUS]CODUSR=[F:REP]AUSNUM
        If !fstat Then
          SZREPTOCTL = [F:AUS]USR
        Endif
      Endif
    Endif
  Endif
  If SZREPTOCTL = "" Then
    ISDISP = 0
    End
  Endif
  INBCTL = 0
  Y2 = 0
  While INBCTL < 3
    If INBCTL = 0 Then
      Filter [ITN] Where (([F:ITN]DAT >= [M:BAP1]APTDAT and [F:ITN]DAT <= [M:BAP1]APTDATEND)
&                      or ([F:ITN]DATEND >= [M:BAP1]APTDAT and [F:ITN]DATEND <= [M:BAP1]APTDATEND))
&                    and [F:ITN]DAT <> [00/00/00] and [F:ITN]DON <> 2 and [F:ITN]REP = SZREPTOCTL
    Elsif INBCTL = 1 Then
      Filter [ITN] Where ([F:ITN]DAT < [M:BAP1]APTDAT and [F:ITN]DATEND > [M:BAP1]APTDATEND)
&                    and [F:ITN]DAT <> [00/00/00] and [F:ITN]DON <> 2 and [F:ITN]REP = SZREPTOCTL
    Elsif INBCTL = 2 Then
      Filter [ITN] Where ([F:ITN]DAT > [M:BAP1]APTDAT and [F:ITN]DATEND < [M:BAP1]APTDATEND)
&                    and [F:ITN]DAT <> [00/00/00] and [F:ITN]DON <> 2 and [F:ITN]REP = SZREPTOCTL
    Endif
    For [ITN]ITN0 Hint Key ITN5
      If [F:ITN]REP <> "" Then
        IPTPOS = 0
        IF1DAYC = nday([F:ITN]DAT)
        IF1MINUTEC = val(mid$([F:ITN]HOU, 3, 2)) / 60
        IF1HOURC = ((100 * val(left$([F:ITN]HOU, 2))) / 24) + IF1MINUTEC
        IPTPOS = instr(1, num$(IF1HOURC), '.')
        If IPTPOS Then
          SZF1HOURC = left$(num$(IF1HOURC), IPTPOS-1) + right$(num$(IF1HOURC), IPTPOS+1)
        Else
          SZF1HOURC = num$(IF1HOURC)
        Endif
        IF1TOTC = val(num$(IF1DAYC) + '.' + SZF1HOURC)
        IPTPOS = 0
        IF2DAYC = nday([F:ITN]DATEND)
        IF2MINUTEC = val(mid$([F:ITN]HOUEND, 3, 2)) / 60
        IF2HOURC = ((100 * val(left$([F:ITN]HOUEND, 2))) / 24) + IF2MINUTEC
        IPTPOS = instr(1, num$(IF2HOURC), '.')
        If IPTPOS Then
          SZF2HOURC = left$(num$(IF2HOURC), IPTPOS-1) + right$(num$(IF2HOURC), IPTPOS+1)
        Else
          SZF2HOURC = num$(IF2HOURC)
        Endif
        IF2TOTC = val(num$(IF2DAYC) + '.' + SZF2HOURC)
        If IC1TOTC >= IF1TOTC and IC1TOTC <= IF2TOTC Then
          ICONFLICT = 1
        Endif
        If IC2TOTC >= IF1TOTC and IC2TOTC <= IF2TOTC Then
          ICONFLICT = 1
        Endif
        If IC1TOTC <= IF1TOTC and IC2TOTC >= IF2TOTC Then
          ICONFLICT = 1
        Endif
        If ICONFLICT Then
          If Y2 >= dim(SZCFLITNLIS) Then
            IFULL = 1
            Break
          Endif
          SZCFLITNLIS(Y2) = [F:ITN]NUM
          #SZCODPLC = func SUBITNB1.GET_LIEU_ITN([F:ITN]TYP, 1)      # FGR 22/02/2010 : X3SUIVI62661
          SZCODPLC = func SUBITNB1.GET_CONFLIT_ITN([F:ITN]TYP, 1)    # FGR 22/02/2010 : X3SUIVI62661
          If SZCODPLC = "OUT" Then
            #Intervention sur site (Conflits interdits)
            IITNINF(Y2) = 1
          Else
            #Autres types d'interventions avec conflits autorisés
            IITNINF(Y2) = 0
          Endif
          Y2 += 1
        Endif
        ICONFLICT = 0
      Endif
    Next
    Filter [ITN]
    If IFULL Then
      Break
    Endif
    INBCTL += 1
  Wend
  If IFULL Then
    #Le nombre maximum d'interventions en conflit pour un collaborateur est atteint.
    #On bloque la saisie.
    ISDISP = 4
    End
  Endif
  ISDISP = 0
  #Il n'y a aucune intervention en conflit. Pas la peine d'aller plus loin.
  If SZCFLITNLIS(0) = "" Then
    End
  Endif
  If ISECONLY Then
    #Conflits autorisés pour les intervenants secondaires
    #Recherche une intervention non encore affichée
    IRSFOUND = 0
    For Y = 0 To dim(SZCFLITNLIS)-1
      IRSFOUND = 0
      For Y2 = 0 To dim(GBAP2CFLRS)-1
        If SZCFLITNLIS(Y) <> "" Then
          If GBAP2CFLRS(Y2) <> "" Then
            If GBAP2CFLRS(Y2) = SZCFLITNLIS(Y) Then
              IRSFOUND = 1
              Break
            Endif
          Endif
        Endif
      Next
      If !IRSFOUND Then
        #Cette intervention doit être affiché
        Read [ITN]ITN0=SZCFLITNLIS(Y)
        If !fstat Then
          SZDDSTR = day$([F:ITN]DAT) - num$(day([F:ITN]DAT)) - month$([F:ITN]DAT) - num$(year([F:ITN]DAT)) - left$([F:ITN]HOU, 2) + ":" + mid$([F:ITN]HOU, 3, 2)
          SZDDEND = day$([F:ITN]DATEND) - num$(day([F:ITN]DATEND)) - month$([F:ITN]DATEND) - num$(year([F:ITN]DATEND)) - left$([F:ITN]HOUEND, 2) + ":" + mid$([F:ITN]HOUEND, 3, 2)
          #SZCODPLC2 = func SUBITNB1.GET_LIEU_ITN([F:ITN]TYP, 1)      # FGR 22/02/2010 : X3SUIVI62661
          SZCODPLC2 = func SUBITNB1.GET_CONFLIT_ITN([F:ITN]TYP, 1)    # FGR 22/02/2010 : X3SUIVI62661
          If SZCODPLC2 = "OUT" Then
            ISDISP = 5
          Else
            ISDISP = 3
          Endif
          #Cherche une case de libre dans GBAP2CFLRS
          For Y2 = 0 To dim(GBAP2CFLRS)-1
            If GBAP2CFLRS(Y2) = "" Then
              GBAP2CFLRS(Y2) = SZCFLITNLIS(Y)
              Break
            Endif
          Next
        Endif
        Break
      Endif
    Next
  Else
    #Recherche s'il y a au moins une intervention bloquante.
    For Y = 0 To dim(IITNINF)-1
      If IITNINF(Y) Then
        Read [ITN]ITN0=SZCFLITNLIS(Y)
        If !fstat Then
          SZDDSTR = day$([F:ITN]DAT) - num$(day([F:ITN]DAT)) - month$([F:ITN]DAT) - num$(year([F:ITN]DAT)) - left$([F:ITN]HOU, 2) + ":" + mid$([F:ITN]HOU, 3, 2)
          SZDDEND = day$([F:ITN]DATEND) - num$(day([F:ITN]DATEND)) - month$([F:ITN]DATEND) - num$(year([F:ITN]DATEND)) - left$([F:ITN]HOUEND, 2) + ":" + mid$([F:ITN]HOUEND, 3, 2)
          ISDISP = 1
        Endif
      Endif
    Next
    If !ISDISP Then
      #Conflits autorisés pour les intervenants secondaires
      #Recherche une intervention non encore affichée
      IRSFOUND = 0
      For Y = 0 To dim(SZCFLITNLIS)-1
        IRSFOUND = 0
        For Y2 = 0 To dim(GBAP2CFLRS)-1
          If SZCFLITNLIS(Y) <> "" Then
            If GBAP2CFLRS(Y2) <> "" Then
              If GBAP2CFLRS(Y2) = SZCFLITNLIS(Y) Then
                IRSFOUND = 1
                Break
              Endif
            Endif
          Endif
        Next
        If !IRSFOUND Then
          #Cette intervention doit être affiché
          Read [ITN]ITN0=SZCFLITNLIS(Y)
          If !fstat Then
            SZDDSTR = day$([F:ITN]DAT) - num$(day([F:ITN]DAT)) - month$([F:ITN]DAT) - num$(year([F:ITN]DAT)) - left$([F:ITN]HOU, 2) + ":" + mid$([F:ITN]HOU, 3, 2)
            SZDDEND = day$([F:ITN]DATEND) - num$(day([F:ITN]DATEND)) - month$([F:ITN]DATEND) - num$(year([F:ITN]DATEND)) - left$([F:ITN]HOUEND, 2) + ":" + mid$([F:ITN]HOUEND, 3, 2)
            ISDISP = 2
            #Cherche une case de libre dans GBAP2CFLRS
            For Y2 = 0 To dim(GBAP2CFLRS)-1
              If GBAP2CFLRS(Y2) = "" Then
                GBAP2CFLRS(Y2) = SZCFLITNLIS(Y)
                Break
              Endif
            Next
          Endif
          Break
        Endif
      Next
    Endif
  Endif
End

##########################################################################################################
# Assure la gestion des réservations de ressources en cas de modif de la date d'un rdv
#######################################################
$MNGUPDAPTDAT
Local Integer IAPTDATUPD
Local Integer IAPTUPDITER
Local Integer ISRRSDISP
Local Integer ISFOG
Local Date DDATFOG
Local Char SZSTRFOG
Local Char SZENDFOG
Local Char SZPROMPT(250)
Local Char SZRRSCFL
Local Integer IPROMPTREP
Local Char SZDES(GLONDCO) # FGR 24/09/2009 : X3SUIVI58059

  DDATFOG = [M:BAP1]APTDATX + 4
  SZSTRFOG = "0900"
  SZENDFOG = "1800"
  IAPTDATUPD = 0
  IAPTUPDITER = 0
  ISRRSDISP = 1
  ISFOG = 0
  SZPROMPT = ""
  IPROMPTREP = 0
  SZRRSCFL = ""
  #On vérifie si une modification de dates à eu lieu
  If [M:BAP1]APTDATXINI <> [M:BAP1]APTDATX Then
    IAPTDATUPD = 1
  Endif
  If [M:BAP1]APTDATENDI <> [M:BAP1]APTDATEND Then
    IAPTDATUPD = 1
  Endif
  If [M:BAP1]APTHOUINI <> [M:BAP1]APTHOU Then
    IAPTDATUPD = 1
  Endif
  If [M:BAP1]APTHOUENDI <> [M:BAP1]APTHOUEND Then
    IAPTDATUPD = 1
  Endif
  If [M:BAP1]APTWEEINI <> [M:BAP1]APTWEE Then
    IAPTDATUPD = 1
  Endif
  If !IAPTDATUPD Then
    Return
  Endif
  #On vérifie si il existe au moins une réservation en conflit horaire
  For IAPTUPDITER = 0 To dim([M:BAP5]APTRER)-1
    If [M:BAP5]APTRER(IAPTUPDITER) = "" Then
      Break
    Else
      Read [RRS]RRS0=[M:BAP5]APTRER(IAPTUPDITER)
      If !fstat Then
        ISRRSDISP = 1
        ISFOG = 0
        If [M:BAP1]APTDAT = [00/00/00]
          Call CHKRRSDISP([F:RRS]RSSNUM, [M:BAP1]APTDATX, DDATFOG, [F:RRS]NUM, SZSTRFOG, SZENDFOG, ISRRSDISP, ISFOG, SZRRSCFL) From SUBRRSB
        Else
          Call CHKRRSDISP([F:RRS]RSSNUM, [M:BAP1]APTDATX, [M:BAP1]APTDATEND, [F:RRS]NUM, [M:BAP1]APTHOU, [M:BAP1]APTHOUEND, ISRRSDISP, ISFOG, SZRRSCFL) From SUBRRSB
        Endif
        If !ISRRSDISP Then
          If ISFOG Then
            Read [RSS]RSS0=[F:RRS]RSSNUM
            If fstat Then
              SZPROMPT = mess(556,196,1) - mess(557,196,1)
              Call OUINON(SZPROMPT, IPROMPTREP) From GESECRAN
              If IPROMPTREP Then
                GIBAP1RRSUPD = 1
              Else
                OK = 0
              Endif
            Else
              # FGR 24/09/2009 : X3SUIVI58059
              #SZPROMPT = mess(551,196,1) + [F:RSS]TTR + mess(176,182,1) - mess(557,196,1)
              Call LECTEXTRA(SZDES,"RESOURCES","RSSDESAXX",[F:RSS]NUM,"") From ATEXTRA
              SZPROMPT = mess(551,196,1) - SZDES - mess(176,182,1) - mess(557,196,1)
              Call OUINON(SZPROMPT, IPROMPTREP) From GESECRAN
              If IPROMPTREP = 2 Then
                GIBAP1RRSUPD = 1
              Else
                OK = 0
              Endif
            Endif
          Else
            Read [RSS]RSS0=[F:RRS]RSSNUM
            If fstat Then
              GMESSAGE = mess(553,196,1)
            Else
              # FGR 24/09/2009 : X3SUIVI58059
              #GMESSAGE = mess(551,196,1) - [F:RSS]TTR - mess(552,196,1)
              Call LECTEXTRA(SZDES,"RESOURCES","RSSDESAXX",[F:RSS]NUM,"") From ATEXTRA
              GMESSAGE = mess(551,196,1) - SZDES - mess(552,196,1)
            Endif
            OK = 0
            GERR = 3
          Endif
          Break
        Endif
      Endif
    Endif
  Next
  If !ISRRSDISP Then
    Return
  Endif
  GIBAP1RRSUPD = 1
Return

##########################################################################################################
# On met à jour les nouvelles origine des réservations de ressources
#################################################################################
Subprog UPDRRSORI
Local Integer ITER

  For ITER = 0 To dim([M:BAP5]APTRER)-1
    If [M:BAP5]APTRER(ITER) = "" Then
      Break
    Else
      Read [RRS]RRS0=[M:BAP5]APTRER(ITER)
      If !fstat Then
        If [F:RRS]RRSORI < 2 Then
          [F:RRS]RRSORI = 2
          [F:RRS]RRSORIVCR = [M:BAP0]APTNUM
          [F:RRS]RRSORIVCRL = 0
        Endif
        Rewrite [RRS]
        If fstat Then
          #Erreur lors la mise à jour de l'origine des réservations de ressources.
          GMESSAGE = mess(172,182,1)
          GERR = 1
          GOK = 0
          Break
        Endif
      Endif
    Endif
  Next
End

##########################################################################################################
# On met à jour les réservations de ressources sur la base du nouvel horaire du rdv.
#################################################################################
Subprog UPDRRSBAP
Local Integer ITER
Local Integer IBAP5LIG

  If !GIBAP1RRSUPD Then
    End
  Endif
  IBAP5LIG = 0
  For ITER = 0 To dim([M:BAP5]APTRER)-1
    If [M:BAP5]APTRER(ITER) = "" Then
      Break
    Else
      Read [RRS]RRS0=[M:BAP5]APTRER(ITER)
      If !fstat Then
        If [M:BAP1]APTDAT = [00/00/00] Then
          [F:RRS]RERDAT = [M:BAP1]APTDATX
          [F:RRS]RERDATEND = [M:BAP1]APTDATX + 4
          [F:RRS]HOUSTR = "0900"
          [F:RRS]HOUEND = "1800"
        Else
          [F:RRS]RERDAT = [M:BAP1]APTDATX
          [F:RRS]RERDATEND = [M:BAP1]APTDATEND
          [F:RRS]HOUSTR = [M:BAP1]APTHOU
          [F:RRS]HOUEND = [M:BAP1]APTHOUEND
        Endif
        Rewrite [RRS]
        If fstat Then
          #Erreur lors la mise à jour du nouvel horaire sur les réservations de ressources.
          GMESSAGE = mess(554,196,1)
          GERR = 1
          GOK = 0
          Break
        Endif
      Endif
    Endif
  Next
  If GERR Then
    GIBAP1RRSUPD = 0
    End
  Else
    GIBAP1RRSUPD = 0
  Endif
  #On recharge le tableau des réservations de ressources sur la base du nouvel horaire
  For ITER = 0 To dim([F:BAPW]APTRER)-1
    If [M:BAP5]APTRER(ITER) = "" Then
      Break
    Else
      Read [RRS]RRS0=[M:BAP5]APTRER(ITER)
      If !fstat Then
        # FGR 30/09/2009 : X3SUIVI57403
        #[M:BAP5]RSS(ITER) = left$([F:RRS]RSSTTR, 30)
        [M:BAP5]RSSNUM(ITER) = [F:RRS]RSSNUM
        [M:BAP5]RERSTRDAT(ITER) = [F:RRS]RERDAT
        [M:BAP5]RERSTRHOU(ITER) = [F:RRS]HOUSTR
        [M:BAP5]RERENDDAT(ITER) = [F:RRS]RERDATEND
        [M:BAP5]RERENDHOU(ITER) = [F:RRS]HOUEND
        Read [REP]REP0=[F:RRS]RERREP
        If fstat Then
          [M:BAP5]RSSREP(ITER) = [F:RRS]RERREP
        Else
          [M:BAP5]RSSREP(ITER) = [F:REP]REPNAM
        Endif
      Endif
    Endif
    IBAP5LIG += 1
  Next
  [M:BAP5]NBRER = IBAP5LIG
  Affzo [M:BAP5]1-99
End

##########################################################################################################
#Affichage des icônes
######################################################
$DISPICON
  Gosub DEFICONNUM From CRMUTIL150
  #Synthèse Compte-rendu
  If len([M:BAP4]FULRPO) > GLONCLE Then
    If [M:BAP4]RPOFLG Then
      [M:BAP4]RPOICO = SZICOSYNDON
    Else
      [M:BAP4]RPOICO = SZICOSYN
    Endif
    Actzo [M:BAP4]RPOICO
  Else
    [M:BAP4]RPOICO = "-1"
    Grizo [M:BAP4]RPOICO
  Endif
  #Synthèse Objet de l'action
  If len([M:BAP1]FULOBJ) > GLONCLE Then
    If [M:BAP1]OBJFLG Then
      [M:BAP1]OBJICO = SZICOSYNDON
    Else
      [M:BAP1]OBJICO = SZICOSYN
    Endif
    Actzo [M:BAP1]OBJICO
  Else
    [M:BAP1]OBJICO = "-1"
    Grizo [M:BAP1]OBJICO
  Endif
Return

##########################################################################################################
#Enregistrement des CLOBs
######################################################
$SAVECLOB
  Gosub DELCLOB
  If GOK < 1 Then
    Return
  Endif
  If [M:BAP4]FULRPO <> "" Then
    Raz [F:HD4]
    [F:HD4]NUM = [M:BAP4]NUMFULRPO
    [F:HD4]TYP = [M:BAP4]TYPFULRPO
    [F:HD4]CLOB = [M:BAP4]FULRPO
    Write [HD4]
    If fstat Then
      #Erreur lors de l'enregistrement du compte-rendu du rendez-vous. Transaction abandonnée.
      GMESSAGE = mess(859,182,1)
      GERR = 1
      Call FSTA("HD4") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
  #Objet de l'action
  If [M:BAP1]FULOBJ <> "" Then
    Raz [F:HD6]
    [F:HD6]NUM = [M:BAP1]NUMFULOBJ
    [F:HD6]TYP = [M:BAP1]TYPFULOBJ
    [F:HD6]CLOB = [M:BAP1]FULOBJ
    Write [HD6]
    If fstat Then
      #Erreur lors de l'enregistrement de l'objectif du rendez-vous. Transaction abandonnée.
      GMESSAGE = mess(860,182,1)
      GERR = 1
      Call FSTA("HD6") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
######################################################
$DELCLOB
  Delete [HD4] Where [F:HD4]NUM = [M:BAP4]NUMFULRPO and [F:HD4]TYP = [M:BAP4]TYPFULRPO
  If fstat Then
    #Erreur lors de la suppression du compte-rendu du rendez-vous. Transaction abandonnée.
    GMESSAGE = mess(861,182,1)
    GERR = 1
    Call FSTA("HD4") From GLOCK
    GOK = 0
    Return
  Endif
  Delete [HD6] Where [F:HD6]NUM = [M:BAP1]NUMFULOBJ and [F:HD6]TYP = [M:BAP1]TYPFULOBJ
  If fstat Then
    #Erreur lors de la suppression de l'objectif du rendez-vous. Transaction abandonnée.
    GMESSAGE = mess(862,182,1)
    GERR = 1
    Call FSTA("HD6") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
# Chargement du CLOB compte-rendu
######################################################
$LOADCLOB
Local Integer ILOOKFORCLOB

  ILOOKFORCLOB = 1
  If [M:BAP4]NUMFULRPO = "" Then
    Raz [M:BAP4]FULRPO
    ILOOKFORCLOB = 0
  Endif
  If [M:BAP4]TYPFULRPO = "" Then
    Raz [M:BAP4]FULRPO
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD4] HD40 = [M:BAP4]NUMFULRPO;[M:BAP4]TYPFULRPO
    If fstat Then
      Raz [M:BAP4]FULRPO
    Else
      [M:BAP4]FULRPO = [F:HD4]CLOB
    Endif
  Endif
  ILOOKFORCLOB = 1
  If [M:BAP1]NUMFULOBJ = "" Then
    Raz [M:BAP1]FULOBJ
    ILOOKFORCLOB = 0
  Endif
  If [M:BAP1]TYPFULOBJ = "" Then
    Raz [M:BAP1]FULOBJ
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD6] HD60 = [M:BAP1]NUMFULOBJ;[M:BAP1]TYPFULOBJ
    If fstat Then
      Raz [M:BAP1]FULOBJ
    Else
      [M:BAP1]FULOBJ = [F:HD6]CLOB
    Endif
  Endif
Return

##########################################################################################################
# Suppression des réservations de ressources
##################################################################
Subprog DELRRS(SZBAPNUM)
Value Char SZBAPNUM

Local Integer ZB

  #Supprime les éventuelles réservations de ressources effectuées
  For ZB = 0 To [M:BAP5]NBRER-1
    If [M:BAP5]APTRER(ZB) <> "" Then
      Delete [RRS] Where [F:RRS]NUM = [M:BAP5]APTRER(ZB)
      If fstat Then
        #Erreur lors de la suppression des réservations de ressources. Suppression interrompue.
        GMESSAGE = mess(476,196,1)
        GERR = 1
        GOK = 0
        Break
      Endif
    Endif
  Next
End

##########################################################################################################
#Affichage de l'interlocuteur
######################################################
$DISPCCN
Local Integer IBFOUND  # FGR 23/03/2011 : X3SUIVI71451

  If [M:BAP1]APTCCNNUM(BAPNOL) = "" Then
    [M:BAP1]APTCCNCLA(BAPNOL) = ""
    [M:BAP1]TYPCCN(BAPNOL) = 1
  Else
    Read [AIN]AIN0=[M:BAP1]APTCCNNUM(BAPNOL)
    If fstat Then
      [M:BAP1]APTCCNCLA(BAPNOL) = ""
      [M:BAP1]TYPCCN(BAPNOL) = 1
    Else
      Call BUILDFULNAM("AIN", [M:BAP1]APTCCNCLA(BAPNOL)) From CRMUTIL140
      [M:BAP1]TYPCCN(BAPNOL)= [F:AIN]CNTTYP
    Endif
  Endif
  If [M:BAP1]TYPCCN(BAPNOL) <> 1 and [M:BAP1]TYPCCN(BAPNOL) <> 2 Then
    [M:BAP1]TYPCCN(BAPNOL) = 1
  Endif
  If [M:BAP1]TYPCCN(BAPNOL) = 1 Then
    [M:BAP1]CCNOBJ(BAPNOL) = "AIN"
  Else
    [M:BAP1]CCNOBJ(BAPNOL) = "LDS"
  Endif
  # FGR 23/03/2011 : X3SUIVI71451 (début)
  If [M:BAP1]APTCOR(BAPNOL) = "" Then
    IBFOUND = 0
    If [M:BAP1]APTCCNNUM(BAPNOL) <> ""  Then
      If [M:BAP0]APTCMP <> "" Then
        For [COR] Where [F:COR]CNTNUM = [M:BAP1]APTCCNNUM(BAPNOL) and [F:COR]BPRNUM = [M:BAP0]APTCMP
          IBFOUND = 1
          Break
        Next
      Endif
      If IBFOUND = 0 Then
        For [COR] Where [F:COR]CNTNUM = [M:BAP1]APTCCNNUM(BAPNOL) and [F:COR]BPRNUM = ""
          IBFOUND = 1
          Break
        Next
      Endif
      If IBFOUND = 1 Then
        [M:BAP1]APTCOR(BAPNOL) = [F:COR]CORNUM
      Endif
    Endif
  Endif
  # FGR 23/03/2011 : X3SUIVI71451 (fin)
Return

##########################################################################################################
#---------------------------------------------------#
# Gestion des valeurs modifiées
#---------------------------------------------------#
$SAVEVALINI
  [M:BAP0]SALFCYINI =[M:BAP0]SALFCY
  [M:BAP0]APTCMPINI=[M:BAP0]APTCMP
  [M:BAP0]APTDONINI=[M:BAP0]APTDON
  #
  [M:BAP1]APTDATXINI = [M:BAP1]APTDATX
  [M:BAP1]APTDATENDI = [M:BAP1]APTDATEND
  [M:BAP1]APTHOUINI  = [M:BAP1]APTHOU
  [M:BAP1]APTHOUENDI = [M:BAP1]APTHOUEND
  [M:BAP1]APTWEEINI = [M:BAP1]APTWEE
Return

##########################################################################################################
#CHECK UNUSED_BEGIN
$DEFOBJORI
  #Définition du type de pièce
  Case [M:BAP1]APTORI
    When 0
      #[M:BAP1]APTORIOBC = ""       # FGR 04/03/2010 : X3SUIVI62924
      [M:BAP1]APTORIAVA = ""        # FGR 12/02/2009 : X3SUIVI52443
    When 1
      #[M:BAP1]APTORIOBC = ""       # FGR 04/03/2010 : X3SUIVI62924
      [M:BAP1]APTORIAVA = ""        # FGR 12/02/2009 : X3SUIVI52443
    When 2
      #[M:BAP1]APTORIOBC = "OMM"       # FGR 04/03/2010 : X3SUIVI62924
      [M:BAP1]APTORIAVA = "OMMNUM"  # FGR 12/02/2009 : X3SUIVI52443
    When 3
      #[M:BAP1]APTORIOBC = "OMP"       # FGR 04/03/2010 : X3SUIVI62924
      [M:BAP1]APTORIAVA = "OMPNUM"  # FGR 12/02/2009 : X3SUIVI52443
    When 4
      #[M:BAP1]APTORIOBC = "OMT"       # FGR 04/03/2010 : X3SUIVI62924
      [M:BAP1]APTORIAVA = "OMTNUM"  # FGR 12/02/2009 : X3SUIVI52443
    When 5
      #[M:BAP1]APTORIOBC = "OMN"       # FGR 04/03/2010 : X3SUIVI62924
      [M:BAP1]APTORIAVA = "OMNNUM"  # FGR 12/02/2009 : X3SUIVI52443
    When 6
      #[M:BAP1]APTORIOBC = "CMG"       # FGR 04/03/2010 : X3SUIVI62924
      [M:BAP1]APTORIAVA = "NUM"     # FGR 12/02/2009 : X3SUIVI52443
    When Default
  Endcase
Return
#CHECK UNUSED_END

##########################################################################################################
#Vérification cohérence entre origine et numéro de pièce
$VERIFORI
  # FGR 11/03/2010 : X3SUIVI62924
  If [M:BAP1]APTORIAOB <> "" and [M:BAP1]APTORIVCR = "" Then
    #Le numéro de pièce / ligne est obligtoire pour la liaison spécifiée.
    GMESSAGE = mess(442,177,1)
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
  Endif
Return

#CHECK UNUSED_BEGIN
$VERIFORIOLD
Local Integer IBOBLOGATOIRE

  IBOBLOGATOIRE = 0
  Case [M:BAP1]APTORI
    When 2
      IBOBLOGATOIRE = 1
    When 3
      IBOBLOGATOIRE = 1
    When 4
      IBOBLOGATOIRE = 1
    When 5
      IBOBLOGATOIRE = 1
    When 6
      IBOBLOGATOIRE = 1
    When Default
  Endcase
  If IBOBLOGATOIRE = 1 Then
    If [M:BAP1]APTORIVCR = "" Then
      #Le numéro de pièce / ligne est obligtoire pour la liaison spécifiée.
      GMESSAGE = mess(442,177,1)
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
    Endif
  Endif
Return
#CHECK UNUSED_END

##########################################################################################################
#Vérifie que l'organisateur appartient à la liste des représentant
$VERIF_ORGANISATEUR
  If [M:BAP2]ATPREPMNA = "" Then
    Return
  Endif

Local Integer ILIGNE
Local Integer IBTROUVE

  ILIGNE = 0
  IBTROUVE = 0
  While ILIGNE<[M:BAP2]NBLIGREP
    If [M:BAP2]APTREPNUM(ILIGNE) = [M:BAP2]ATPREPMNA Then
      IBTROUVE = 1
      Break
    Endif
    ILIGNE = ILIGNE + 1
  Wend
  If IBTROUVE = 0 Then
    GMESSAGE = mess(287,177,1)
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
  Endif
  If OK = 0 Then
    GOK = 0
  Endif
Return

##########################################################################################################
# Complète le tableau des  représentants
$COMPLETREP
Local Integer ITESTNBLIG
Local Integer ILIGNE
Local Char SZFNC
Local Integer IFNC

  SZFNC = ""
  IFNC = 0
  # Calcul de NBLIGREP pour le tableau des représentants
  ITESTNBLIG = 0
  Raz GTBBAPVALREP
  Raz GTBBAPVALUSR
  GIBAPNBREP = 0
  For ILIGNE = 0 To dim([F:BAP]APTREPNUM)-1
    If [M:BAP2]APTREPNUM(ILIGNE) = "" Then
      Break
    Endif
    GTBBAPVALREP(GIBAPNBREP) = [M:BAP2]APTREPNUM(ILIGNE)
    Read [REP]REP0=[M:BAP2]APTREPNUM(ILIGNE)
    If fstat Then
      [M:BAP2]APTREPSRV(ILIGNE) = ""
      GTBBAPVALUSR(GIBAPNBREP) = ""
    Else
      GTBBAPVALUSR(GIBAPNBREP) = [F:REP]AUSNUM
      If [F:REP]AUSNUM = "" Then
        Call TEXTE(2929, [M:BAP2]APTREPSRV(ILIGNE)) From OBJDIV      #Représentant
      Else
        Call PARAMUTIL("AUSCRMA", SZFNC, [F:REP]AUSNUM, "") From SUBAUS
        If SZFNC = "" Then
          IFNC = 1
        Else
          IFNC = val(SZFNC)
        Endif
        If IFNC = 1 Then
          Call TEXTE(2929, [M:BAP2]APTREPSRV(ILIGNE)) From OBJDIV      #Représentant
        Else
          [M:BAP2]APTREPSRV(ILIGNE) = mess(val(SZFNC),3022,1)
        Endif
      Endif
    Endif
    GIBAPNBREP += 1
    ITESTNBLIG += 1
  Next
  [M:BAP2]NBLIGREP = ITESTNBLIG
Return

##########################################################################################################
# Création des données de synchronisation pour tous les représentants
$CRESYDALLREP
  If GOK < 1 Then
    Return
  Endif

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IINDICE

  IINDICE = 0
  While IINDICE < [M:BAP2]NBLIGREP
    #Création des données de synchronisation
    Call SYDBAPCRE ([M:BAP2]APTREPNUM(IINDICE), IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
    If IBRETOUR = 0 Then
      #Erreur lors de la création des données pour la synchronisation
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
      GOK = 0
      Break
    Endif
    IINDICE = IINDICE + 1
  Wend
Return

##########################################################################################################
#Gestion des données de synchronisation pour tous les représentants
$GERESYDALLREP
  If GOK < 1 Then
    Return
  Endif

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IINDICE
Local Integer ILIGNETAB
Local Integer IBTROUVE
Local Integer ITABTROUVE (dim([M:BAP2]APTREPNUM))

  ILIGNE = 0
  ILIGNEOLD = 0
  IBTROUVE = 0
  Raz ITABTROUVE
  While IINDICE< [M:BAP2]NBLIGREP
    If [M:BAP2]APTREPNUM(IINDICE) <> "" Then
      ILIGNETAB = 0
      IBTROUVE = 0
      While ILIGNETAB < GIBAPNBREP
        If GTBBAPVALREP (ILIGNETAB) = [M:BAP2]APTREPNUM(IINDICE) Then
          IBTROUVE = 1
          ITABTROUVE(ILIGNETAB) = 1
          Break
        Endif
        ILIGNETAB = ILIGNETAB + 1
      Wend
      If IBTROUVE = 0 Then
        #Création des données de synchronisation
        Call SYDBAPCRE ([M:BAP2]APTREPNUM(IINDICE), IERRINF,ICHAPTER,IBRETOUR) From SUBSYDB
        If IBRETOUR = 0 Then
          #Erreur lors de la création des données pour la synchronisation
          GMESSAGE = mess(IERRINF,ICHAPTER,1)
          GERR = 1
          GOK = 0
          Break
        Endif
      Else
        #Ce représenant existait, c'est une modif
        #On ne fait que créer les données de synchro
        Call SYDBAPUPD ([M:BAP2]APTREPNUM(IINDICE), IERRINF,ICHAPTER,IBRETOUR) From SUBSYDB
        If IBRETOUR = 0 Then
          #Erreur lors de la création des données pour la synchronisation
          GMESSAGE = mess(IERRINF,ICHAPTER,1)
          GERR = 1
          GOK = 0
          Break
        Endif
      Endif
    Endif
    IINDICE = IINDICE + 1
  Wend
  #On traite le cas des représentants supprimés
  ILIGNETAB = 0
  While ILIGNETAB < GIBAPNBREP
    If ITABTROUVE (ILIGNETAB) = 0 Then
      #On n'a trouvé aucune fois ce représentant
      #Il faut le supprimer pour la synchro
      Call SYDBAPDEL(GTBBAPVALREP (ILIGNETAB), IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
      If IBRETOUR = 0 Then
        #Erreur lors de la création des données pour la synchronisation
        GMESSAGE = mess(210,177,1)
        GERR = 1
        GOK = 0
        Break
      Endif
    Endif
    ILIGNETAB = ILIGNETAB + 1
  Wend
Return

##########################################################################################################
# Suppression des données de synchronisation pour tous les représentants
$DELLSYDALLREP
  If GOK < 1 Then
   Return
  Endif

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer  ILIGNE

  ILIGNE = 0
  While ILIGNE < [M:BAP2]NBLIGREP
    If [M:BAP2]APTREPNUM(ILIGNE ) <> "" Then
      Call SYDBAPDEL ( [M:BAP2]APTREPNUM(ILIGNE), IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
      If IBRETOUR = 0 Then
        #Erreur lors de la suppression des données de synchronisation
        GMESSAGE = mess(211,177,1)
        GERR = 1
        GOK = 0
        Break
      Endif
    Endif
    ILIGNE = ILIGNE + 1
  Wend
Return

##########################################################################################################
# Gestion de toutes les relations interlocuteur /correspondant pour le rendez-vous
$BAPGEREALLAINCOR
Local Integer ILIGNE

  ILIGNE = 0
  OK = 1
  If [M:BAP2]ATPREPMNA <> "" Then
    #On va vérifier que les correspondant existent pour l'organisateur
    While ILIGNE < [M:BAP1]NBLIGCCN
      If [M:BAP1]APTCCNNUM(ILIGNE) <> "" or [M:BAP1]APTCOR(ILIGNE) <> "" Then
        #On regarde si gestion du correspondant
        Call  CORGERE ([M:BAP2]ATPREPMNA, [M:BAP0]APTCMP, [M:BAP1]APTCCNNUM(ILIGNE), [M:BAP1]APTCOR(ILIGNE), IERRINF, ICHAPTER, IBRETOUR) From SUBCORB
        If IBRETOUR = 0 Then
          GMESSAGE = mess(IERRINF,ICHAPTER,1)
          GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
          OK = 0
          Break
        Endif
      Endif
      If GOK < 1 Then
        Break
      Endif
      ILIGNE = ILIGNE + 1
    Wend
  Endif
  Affzo [M:BAP1]APTCOR
  If OK = 0 Then
    GOK = 0
  Endif
Return

##########################################################################################################
# Gestion de toutes les relations représentants /correspondant pour le rendez-vous
$BAPGEREALLREPCOR
Local Integer ILIGNE
Local Char SZREFCOR

  Raz SZREFCOR
  ILIGNE = 0
  OK = 1
  If [M:BAP2]ATPREPMNA <> "" Then
    #On va vérifier que les correspondant existent pour l'organisateur
    While ILIGNE < [M:BAP2]NBLIGREP
      If [M:BAP2]APTREPNUM(ILIGNE ) <> "" Then
        #On regarde si gestion du correspondant
        Raz SZREFCOR
        Call  CORGEREREP ([M:BAP2]ATPREPMNA,[M:BAP2]APTREPNUM(ILIGNE ),SZREFCOR, IERRINF, ICHAPTER, IBRETOUR) From SUBCORB
        If IBRETOUR = 0
          GMESSAGE = mess(IERRINF,ICHAPTER,1)
          GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
          OK = 0
          Break
        Endif
      Endif
      If GOK < 1 Then
        Break
      Endif
      ILIGNE = ILIGNE + 1
    Wend
  Endif
  If OK = 0 Then
    GOK = 0
  Endif
Return

##########################################################################################################
#créer les données de synchro de forçage pour le représentant
$FORCEBAP
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IINDICE
Local Integer IBTROUVE

  IBTROUVE = 0
  IINDICE = 0
  While IINDICE < [M:BAP2]NBLIGREP
    If [M:BAP2]APTREPNUM(IINDICE) = [M:BAP0]FORCAGEREP Then
      IBTROUVE = 1
      Break
    Endif
    IINDICE = IINDICE + 1
  Wend
  If IBTROUVE = 0 Then
    GERR = 1
    #Erreur : le représentant de forçage n'est pas dans la liste des représentants
    GMESSAGE = mess(416,177,1)
    GOK = 0
    Return
  Endif
  #On laisse la fonction de forçage géré l'écriture des données
Return

##########################################################################################################
# gere les données  pour la gestion des en cours en creation
$GERE_LCM_CREATION
  # FGR 12/08/2009 : X3SUIVI57005 : Revu toute cette partie pour laisser faire S/P qui vont bien
  Raz [BPR]
  If [M:BAP0]APTCMP <> "" Then
    Read [BPR]BPR0=[M:BAP0]APTCMP
    If fstat <> 0 Then
      #Erreur lors de la lecture du tiers + " : " +[M:BAP0]APTCMP
      GMESSAGE = mess(445,177,1) - [M:BAP0]APTCMP
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      GOK = 0
      Return
    Endif
    If [F:BPR]BPCFLG <> 2 and [F:BPR]PPTFLG <> 2 Then
      Return
    Endif
    # FGR 12/08/2009 : X3SUIVI57005 : Ce sont les S/P fais pour qui gèrent, on ne le fait pas directement par LCM_MAJINFO
    #                                 En plus directement ça ne tient pas compte de la priorité Appel/Tâche/RdV
    If [M:BAP0]APTDON = 2 Then
      # Gestion premier contact
      Call LCM_BPRFIRSTCNT ([M:BAP0]APTCMP, GSOCIETE, [M:BAP0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      # Gestion dernier contact
      Call LCM_BPRLASTCNT ([M:BAP0]APTCMP, GSOCIETE, [M:BAP0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Else
      # Gestion prochain contact
      Call LCM_BPRNEXTCNT ([M:BAP0]APTCMP, GSOCIETE, [M:BAP0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Endif
  Endif
Return

##########################################################################################################
# gere les données  pour la gestion des en cours en modification
$GERE_LCM_MODIF
Local Integer IBTRAITBPR
Local Integer IBTRAITBPRINI
Local Char SZSOCINI(GLONCPY)
Local Integer IBCHANGE_LCMKEY

  # FGR 12/08/2009 : X3SUIVI57005 : Revu toute cette partie pour laisser faire S/P qui vont bien
  IBTRAITBPR = 0
  IBTRAITBPRINI = 0
  Raz SZSOCINI
  IBCHANGE_LCMKEY = 0
  Raz [BPR]
  If [M:BAP0]SALFCYINI = [M:BAP0]SALFCY and [M:BAP0]APTCMPINI = [M:BAP0]APTCMP and
&    [M:BAP0]APTDONINI = [M:BAP0]APTDON and [M:BAP1]APTDATXINI = [M:BAP1]APTDATX and
&    [M:BAP1]APTHOUINI = [M:BAP1]APTHOU and [M:BAP1]APTDATENDI = [M:BAP1]APTDATEND
& Then
    #Rien n'a été changé sur les données encours, on sort
    Return
  Endif
  If [M:BAP0]APTCMP <> "" Then
    Read [BPR]BPR0=[M:BAP0]APTCMP
    If fstat <> 0 Then
      #Erreur lors de la lecture du tiers + " : " +[M:BAP0]APTCMP
      GMESSAGE = mess(445,177,1) - ":" - [M:BAP0]APTCMP
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      GOK = 0
      Return
    Endif
    If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
      IBTRAITBPR = 1
    Endif
  Endif
  If [M:BAP0]SALFCYINI <> [M:BAP0]SALFCY Then
    #On recherche la société initiale
    If [M:BAP0]SALFCYINI <> "" Then
      If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
      Read [FCY]FCY0=[M:BAP0]SALFCYINI
      If fstat = 0 Then
        SZSOCINI = [F:FCY]LEGCPY
      Else
        #Erreur lors de la lecture de la table des sites
        GMESSAGE = mess(444,177,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Else
      SZSOCINI = ""
    Endif
    If SZSOCINI <> GSOCIETE Then
      IBCHANGE_LCMKEY = 1
    Endif
  Else
    SZSOCINI = GSOCIETE
  Endif
  If [M:BAP0]APTCMPINI <> [M:BAP0]APTCMP Then
    If [M:BAP0]APTCMPINI <> "" Then
      IBCHANGE_LCMKEY = 1
      Read [BPR]BPR0=[M:BAP0]APTCMPINI
      If fstat <> 0 Then
        #Erreur lors de la lecture du tiers + " : " +[M:BAP0]APTCMP
        GMESSAGE = mess(445,177,1) - ":" - [M:BAP0]APTCMPINI
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
        IBTRAITBPRINI = 1
      Endif
    Endif
  Else
    IBTRAITBPRINI = IBTRAITBPR
  Endif
  If IBCHANGE_LCMKEY = 1 and IBTRAITBPRINI = 1 Then
    # On a changé de société. On remet à jour les infos pour l'ancienne société
    If [M:BAP0]APTDONINI = 2 Then
      Call LCM_BPRFIRSTCNT ([M:BAP0]APTCMPINI, SZSOCINI, [M:BAP0]SALFCYINI, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      Call LCM_BPRLASTCNT ([M:BAP0]APTCMPINI, SZSOCINI, [M:BAP0]SALFCYINI, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Else
      Call LCM_BPRNEXTCNT ([M:BAP0]APTCMPINI, SZSOCINI, [M:BAP0]SALFCYINI, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Endif
  Endif
  #
  If IBTRAITBPR = 1 Then
    # C'est un client ou un prospect
    If [M:BAP0]APTDONINI = [M:BAP0]APTDON Then
      # Le statut n'a pas changé : GERE_LCM_CREATION fait tout ce qu'il faut.
      Gosub GERE_LCM_CREATION
    Else
      # Le statut n'a pas changé : il faut refaire les trois étapes
      # Gestion premier contact
      Call LCM_BPRFIRSTCNT ([M:BAP0]APTCMP, GSOCIETE, [M:BAP0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      # Gestion dernier contact
      Call LCM_BPRLASTCNT ([M:BAP0]APTCMP, GSOCIETE, [M:BAP0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      # Gestion prochain contact
      Call LCM_BPRNEXTCNT ([M:BAP0]APTCMP, GSOCIETE, [M:BAP0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Endif
  Endif
Return

##########################################################################################################
# gere les données  pour la gestion des en cours en annulation
$GERE_LCM_ANNULE
Local Integer IBSUPR

  # FGR 12/08/2009 : X3SUIVI57005 : Revu toute cette partie pour laisser faire S/P qui vont bien
  If [M:BAP0]APTCMP = "" Then
    Return
  Endif
  Raz [BPR]
  Read [BPR]BPR0=[M:BAP0]APTCMP
  If fstat <> 0 Then
    #Erreur lors de la lecture du tiers + " : " +[M:BAP0]APTCMP
    GMESSAGE = mess(445,177,1) - ":" - [M:BAP0]APTCMP
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
    GOK = 0
    Return
  Endif
  If [F:BPR]BPCFLG <> 2 and [F:BPR]PPTFLG <> 2 Then
    Return
  Endif
  IBSUPR = 0
  #If faut supprimer les éventuelles anciennes données
  Call LCM_DELKEY(15, [M:BAP0]APTNUM, IBSUPR, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
    GOK = 0
    Return
  Endif
  If IBSUPR = 1 Then
    # on a supprimé quelque chose : donc on refait la recherche
    If [M:BAP0]APTDONINI = 2 Then
      Call LCM_BPRFIRSTCNT ([M:BAP0]APTCMP, GSOCIETE, [M:BAP0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      Call LCM_BPRLASTCNT ([M:BAP0]APTCMP, GSOCIETE, [M:BAP0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Else
      Call LCM_BPRNEXTCNT ([M:BAP0]APTCMP, GSOCIETE, [M:BAP0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Vérifie la disponibilité des intervenants du rendez-vous.
$CHKAPPDISP
Local Integer REPISDISP
Local Integer IONREP
Local Integer ITNITER
Local Char SZREPMESS(250)
Local Char SZDSTRDAT(100)
Local Char SZDSTRHOU(100)
Local Char SZDENDDAT(100)
Local Char SZDENDHOU(100)
Local Char SZDSTR(100)
Local Char SZDEND(100)
Local Integer ICONFLIT  # FGR 24/03/2009 : X3SUIVI53600

  SZREPMESS = ""
  REPISDISP = 0
  IONREP = 0
  ICONFLIT = func GET_CONFLIT_BAP([M:BAP1]APTTYP)
  Raz GBAP2CFLRS
  If ICONFLIT = 1 Then
    # FGR 24/03/2009 : X3SUIVI53600 : * Si par rapport à la catégorie de RdV, le conflit est autorisé,
    #                                   On ne regarde pas pour les autres RdV.
    #                                 * Si par rapport à la catégorie de RdV, le conflit n'est pas autorisé,
    #                                   On regardera si elle est autorisée pour les autres RdV en conflit.
    # Première étape
    # Contrôle de conflits horaires avec d'autres rendez-vous
    If [M:BAP0]APTDON <> 2 Then
      If [M:BAP1]APTDAT <> [00/00/00] Then
        Gosub CHKREPDISP From SUBBAPB
        #Case 1 : L'intervenant principal est déjà en rendez-vous aux horaires suivants :
        #Case 2 : Certains intervenants ne sont pas disponibles pour la date souhaitée
        Case REPISDISP
          When 1
            GMESSAGE = mess(559,196,1) - SZDSTRDAT - SZDSTRHOU - mess(560,196,1) - SZDENDDAT - SZDENDHOU + '.' - mess(627,196,1)
            GERR = 3
            OK = 0
            GOK = 0
            Affzo [M:BAP1]1-99
          When 2
            GMESSAGE = mess(222,196,1)
            GERR = 3
            OK = 0
            GOK = 0
            Affzo [M:BAP1]1-99
            Affzo [M:BAP2]1-99
          When Default
        Endcase
      Endif
    Endif
  Endif
  # Deuxième étape
  # Contrôle de conflits horaires avec les réservations de ressources
  If OK > 0 Then
    # FGR 24/03/2009 : Note pour ne pas oublier. Il ne peut y avoir de conflit de réservation de ressource. On vérifie donc toujours.
    Gosub MNGUPDAPTDAT From SUBBAPB
  Endif
  # Troisième étape
  # Contrôle de conflits horaires avec les interventions SAV
  If [M:BAP0]APTDON <> 2 and ICONFLIT = 1 and OK > 0 Then
    # FGR 24/03/2009 : X3SUIVI53600 : * Si par rapport à la catégorie de RdV, le conflit est autorisé (ICONFLIT = 2),
    #                                   On ne regarde pas pour les interventions.
    #                                 * Si par rapport à la catégorie de RdV, le conflit n'est pas autorisé (ICONFLIT = 1),
    #                                   On regardera dans les intervention. C'est le "OUT" qui pilote (pas de changement).
    For ITNITER = 0 To [M:BAP2]NBLIGREP-1
      If [M:BAP2]APTREPNUM(ITNITER) <> "" Then
        Raz GBAP2CFLRS
        Call CHKDISIITN(ITNITER, SZDSTR, SZDEND, [M:BAP2]APTREPNUM(ITNITER), REPISDISP) From SUBBAPB
        While REPISDISP > 0
          #Case 1 : L'intervenant principal est déjà en intervention SAV sur site aux horaires suivants :
          #         Saisie refusée.
          #Case 2 : L'intervenant principal est déjà en intervention SAV aux horaires suivants :
          #         Confirmez-vous la saisie ?
          #Case 3 : L'intervenant secondaire XXX est déjà en intervention SAV. Confirmez-vous la saisie ?
          #Case 4 : Le nombre de conflits détectés est trop important.
          #         Il est déconseillé de surcharger de façon concurrente l'agenda du collaborateur : XXXX
          #         Par conséquent, la saisie du rendez-vous est refusée.
          #Case 5 : L'intervenant secondaire XXX est déjà en intervention SAV sur site. Confirmez-vous la saisie ?
          Case REPISDISP
            When 1
              GMESSAGE = mess(621,196,1) - SZDSTR - mess(560,196,1) - SZDEND + '.' - mess(627,196,1)
              GERR = 3
              OK = 0
              GOK = 0
            When 2
              SZREPMESS = mess(622,196,1) - SZDSTR - mess(560,196,1) - SZDEND + '.' - mess(623,196,1)
              Call OUINON(SZREPMESS, IONREP) From GESECRAN
              If IONREP <> 2 Then
                OK = 0
              Endif
            When 3
              SZREPMESS = mess(625,196,1) - [M:BAP2]APTREPNUM(ITNITER) - mess(626,196,1) - SZDSTR - mess(560,196,1) - SZDEND + '.' - mess(623,196,1)
              Call OUINON(SZREPMESS, IONREP) From GESECRAN
              If IONREP <> 2 Then
                OK = 0
              Endif
            When 4
              GMESSAGE = mess(628,196,1) - mess(629,196,1) - [M:BAP2]APTREPNUM(ITNITER) + '.' - mess(630,196,1)
              GERR = 3
              OK = 0
            When 5
              SZREPMESS = mess(625,196,1) - [M:BAP2]APTREPNUM(ITNITER) - mess(634,196,1) - SZDSTR - mess(560,196,1) - SZDEND + '.' - mess(623,196,1)
              Call OUINON(SZREPMESS, IONREP) From GESECRAN
              If IONREP <> 2 Then
                OK = 0
              Endif
            When Default
          Endcase
          If OK = 0 Then
            Break
          Endif
          Call CHKDISIITN(ITNITER, SZDSTR, SZDEND, [M:BAP2]APTREPNUM(ITNITER), REPISDISP) From SUBBAPB
        Wend
      Endif
      If OK = 0 Then
        Break
      Endif
    Next
  Endif
  If OK = 0 Then
    GOK = 0
  Endif
Return

##########################################################################################################
$VERIFDATE
Local Integer IBRETOUR
Local Char SZMESSAGE(250)

  If [M:BAP0]APTDON = 2 Then
    If [M:BAP1]APTDAT = [00/00/00] or  [M:BAP1]APTDATEND = [00/00/00] or [M:BAP1]APTHOU = "" or [M:BAP1]APTHOUEND = "" Then
      #Les dates de début et de fin sont obligatoires pour un rendez vous effectué..
      GMESSAGE = mess(214,177,1)
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      Return
    Endif
  Endif
  #Si date flou
  If [M:BAP1]APTDAT = [00/00/00] and [M:BAP1]APTDATEND = [00/00/00] Then
    If [M:BAP1]APTHOU > [M:BAP1]APTHOUEND Then
      #En date flou, l'heure de fin doit être supérieure à l'heure de début.
      GMESSAGE = mess(512,177,1)
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      Return
    Endif
  Endif
  If [M:BAP1]APTDAT <> [00/00/00] or [M:BAP1]APTDATEND<>[00/00/00] Then
    #On n'est pas en date flou
    If [M:BAP1]APTDAT = [00/00/00] Then
      #La date de début n'a pas été précisée.
      GMESSAGE = mess(98,177,1)
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      Return
    Endif
    If [M:BAP1]APTDATEND = [00/00/00] Then
      #La date de fin n'a pas été précisée.
      GMESSAGE = mess(98,177,1)
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      Return
    Endif
    If [M:BAP1]APTDATEND < [M:BAP1]APTDAT Then
      #La date de fin ne doit pas être inférieure à la date de début.
      GMESSAGE = mess(99,177,1)
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      Return
    Endif
    #On vérifie la ciohérence date/heure début et date/heure/fin
    Call VERDATEDEBFIN ( [M:BAP1]APTDAT, [M:BAP1]APTHOU, [M:BAP1]APTDATEND, [M:BAP1]APTHOUEND, SZMESSAGE, IBRETOUR) From CRMUTIL150
    If IBRETOUR = 0 Then
      GMESSAGE = SZMESSAGE
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      Return
    Endif
  Endif
Return

