######################################################################################
## Etiquettes ajoutée par le superviseur (écran ASYRVOLFIL)
######################################################################################
#**
#* AM_VOLUME : sélection d'un espace de stockage
#*
Subprog AM_VOLUME(VOLUME)
Variable Char VOLUME
Raz [M:ASFI]NBFILES,[M:ASFI]FULLNAME,[M:ASFI]LEVEL,[M:ASFI]NAME,[M:ASFI]OPEN,[M:ASFI]SELECTED,[M:ASFI]FULLNAMETMP
#Affzo
Call FOPEN(VOLUME,"",0,0)
pcolor = GCOUL(0)
Affzo
End

#**
#* C_NBFILES : clic sur tableau de "fichiers"
#*
Subprog C_NBFILES
#action prise en compte si et seulement  si
#1. clic sur tableau
#2. action = "modification ligne"
Local Integer LSELECTED
If adxgtb | status<>75 :  End : Endif

LSELECTED = nolign-1
[M:ASFI]SELECTED = [M:ASFI]FULLNAME(LSELECTED)
Call B1_NBFILES

pcolor = GCOUL(0)
Affzo
pcolor = GCOUL(2)
Affzo [M:ASFI]NAME(LSELECTED)

mkstat = 2
End

#**
#* B1_NBFILES : Open/Close
#*
Subprog B1_NBFILES
Local Integer I,POS
POS = nolign-1
If [M:ASFI]OPEN(POS) = 0
 For I=1 To [M:ASFI]NBFILES
  [M:ASFI]OPEN(I-1) = 1
 Next I
Elsif [M:ASFI]OPEN(POS) = 1
 Call FOPEN([M:ASFI]VOLUME,[M:ASFI]FULLNAME(POS),[M:ASFI]LEVEL(POS)+1,POS+1)
 [M:ASFI]OPEN(POS) = 2
Elsif [M:ASFI]OPEN(POS) = 2
 Call FCLOSE(POS)
 [M:ASFI]OPEN(POS) = 1
Endif
Affzo [M:ASFI]NBFILES
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran ASYRVOLFIL) 11/03/2014 09:48:26 (CCL)
######################################################################################
Subprog AS_NBFILES
Local Integer K
K = find([M]FULLNAMETMP,[M]FULLNAME)
If K
 Chgstl [M]NAME(K-1) With ""
Endif
Gosub SETNOL
Gosub SETZON
Chgstl [M]NAME(nolign-1) With "AMKCUR"
End

$SETNOL
Local Integer NOL
NOL = max(0,nolign-1)
Return

$SETZON
[M]FULLNAMETMP = [M]FULLNAME(NOL)
[M:ASFI]SELECTED = [M:ASFI]FULLNAME(NOL)
Affzo [M]SELECTED
Return

Subprog IB_NAME
If nolign & [M]NAME(nolign-1)=""
 GBOUTS = ""
Endif
End

