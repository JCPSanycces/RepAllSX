#<AdxTL>@(#)8.0.0.0 $Revision$
Call TRAITE_CHAR(VALEUR,PARAM,"","PATCH","PATCH",3,"") From GTRAITE
End
#**
#* $ACTION
#*!
$ACTION
Case ACTION
 When "OK"          : Gosub OK
 When "DEBUT"       : Gosub DEBUT
Endcase
Return

#**
#* OK
#*!
$OK
VALEUR  = '['+ [M:ASFI]VOLUME + "]/" + ctrans([M:ASFI]SELECTED,"\","/")
Return

#**
#*
#*!
$DEBUT
Local Integer I,LEVEL,POS
Local File    AVOLUME    [AVL]
Local Char    SELECTED(250),SELECTED2(250)
Raz [M:ASFI]

#recherche du volume :
If len([L]VALEUR) > 0
 For [AVL]
  If left$(toupper([L]VALEUR),len([AVL]ROOT)+2) = "["+toupper([AVL]ROOT) + "]"
   [M:ASFI]VOLUME = [AVL]VOLUME
   [M:ASFI]ROOT   = [AVL]ROOT
   [M:ASFI]SELECTED = right$([L]VALEUR,len([AVL]ROOT)+3)
   If left$([M:ASFI]SELECTED,1) ="/" or left$([M:ASFI]SELECTED,1) ="\\"
    [M:ASFI]SELECTED = right$([M:ASFI]SELECTED,2)
   Endif
   [M:ASFI]SELECTED = ctrans([M:ASFI]SELECTED,"/","\\")
   If [M:ASFI]SELECTED="" : [M:ASFI]SELECTED="["+toupper([AVL]ROOT) + "]" : Endif
   Break
  Endif
 Next AVL
Endif


#chargement des fichiers stockés dans le volume "par défaut"
Raz [M:ASFI]NBFILES,[M:ASFI]FULLNAME,[M:ASFI]LEVEL,[M:ASFI]NAME,[M:ASFI]OPEN
Affzo

If len([M:ASFI]VOLUME) > 0
 [L]SELECTED = ""
 [L]LEVEL = 0
 [L]POS = 0
 While len([L]SELECTED) < len([M:ASFI]SELECTED)
  Call FOPEN([M:ASFI]VOLUME,[L]SELECTED,[L]LEVEL,[L]POS)
  If [L]POS > 0
   [M:ASFI]OPEN(POS-1) = 2
  Endif
  [L]SELECTED2 = ""
  For I=1 To [M:ASFI]NBFILES-1
   [M:ASFI]OPEN(I) = max([M:ASFI]OPEN(I),1)
   If left$(toupper( [M:ASFI]SELECTED),len([M:ASFI]FULLNAME(I))) = toupper([M:ASFI]FULLNAME(I))
&    & len([M:ASFI]FULLNAME(I)) > len([L]SELECTED)
    [L]SELECTED2 =  [M:ASFI]FULLNAME(I)
    [L]POS = I+1
   Endif
  Next I
  If len([L]SELECTED2) = 0 : Break : Endif
  [L]LEVEL += 1
  SELECTED = SELECTED2
 Wend
 #réafficher la liste
 pcolor = GCOUL(0)
 Affzo

 If POS > 1
  #mettre en valeur la ligne
  #pcolor = GCOUL(2)
  #Affzo [M:ASFI]NAME(POS-1)
  [M]FULLNAMETMP = [M]FULLNAME(POS-1)
  Chgstl [M]NAME(POS-1) With "AMKCUR"
  Affzo
 Endif
Endif
Return

#**
#* S_VOLUME
#*
#* @param VALEUR
#*!
Subprog S_VOLUME(VALEUR)
Variable Char    VALEUR()
Call SEL_VOLUME(VALEUR)
End

#**
#* SEL_VOLUME
#*
#* @param VALEUR
#*!
Subprog SEL_VOLUME(VALEUR)
Variable Char    VALEUR()

Local File    AVOLUME    [AVL]
Local Integer NBVOL
Local Integer CHOICE: CHOICE=0
Local Char    TEX(GLONAVL)(1..500,1..2),TIT(GLONDES)(0..2)

For [AVL]
 #If [AVL]VOLTYP = 1
  NBVOL += 1
  TEX(NBVOL,1) = [AVL]VOLUME
  TEX(NBVOL,2) = [AVL]TITLE
 #Endif
Next AVL

TIT(0) = mess(  8, 31,1)  :#"Sélection"
TIT(1) = mess(  3,230,1)  :#"Volume"
TIT(2) = mess(173,125,1)  :#"Description"

If NBVOL > 0
 Call SAITEX_COL_MAX(NBVOL,TEX,CHOICE,TIT,240,60) From GESECRAN
 If status<>7 & CHOICE<>0
  VALEUR = TEX(CHOICE,1)
 Endif
Endif
End


#**
#* FOPEN
#*
#* @param VOLUME
#* @param PATH
#* @param LEVEL
#* @param POS
#*!
Subprog FOPEN(VOLUME,PATH, LEVEL, POS)
Variable Char VOLUME
Value Char PATH
Value Integer LEVEL
Value Integer POS


Local Instance  IVOLUME Using C_AVOLUME
Local Integer   I,NBFILES,MAXFILES
Local Integer   OPEN: OPEN=1
Local Char      FILES(255)(1..)
Local Integer   ASTATUS

IVOLUME = NewInstance C_AVOLUME AllocGroup null
ASTATUS = fmet IVOLUME.AREAD(VOLUME)
If ASTATUS : FreeGroup IVOLUME : End : Endif
[M:ASFI]ROOT = IVOLUME.ROOT
ASTATUS = fmet IVOLUME.LS([L]PATH,"","","",NBFILES,FILES)

##TODO
#NBFILES = min(NBFILES,5)

If [M:ASFI]NBFILES=0 : OPEN=0 : Endif

If NBFILES  > 0
 MAXFILES = 2000
 #NBFILES = min(MAXFILES,POS+NBFILES)
 NBFILES = min(MAXFILES,NBFILES)
 Insa POS,NBFILES [M:ASFI]FULLNAME,[M:ASFI]NAME,[M:ASFI]LEVEL,[M:ASFI]OPEN
 For I=1 To NBFILES
  If [M:ASFI]NBFILES < MAXFILES-1 : # 108151 CCL
   [M:ASFI]FULLNAME(POS+I-1) = FILES(I)
   [M:ASFI]NAME(POS+I-1)     = space$(LEVEL)+ [M:ASFI]FULLNAME(POS+I-1)
   [M:ASFI]LEVEL(POS+I-1)    = LEVEL
   [M:ASFI]OPEN(POS+I-1)     = OPEN
   [M:ASFI]NBFILES += 1
  Endif
 Next I
Endif
FreeGroup IVOLUME

End

#**
#* FCLOSE
#*
#* @param POS
#*!
Subprog FCLOSE(POS)
Value Integer POS

Local Integer I
I = 0
While [M]LEVEL(POS+I+1)>[M]LEVEL(POS)
 I += 1
Wend
If I>0
 Dela POS+1,I [M:ASFI]FULLNAME,[M:ASFI]NAME,[M:ASFI]LEVEL,[M:ASFI]OPEN
 [M]NBFILES -= I
Endif
End


