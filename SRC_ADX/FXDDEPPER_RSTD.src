#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation FXDDEPPER

# Classe FXDDEPPER_CGAS


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
        When "AQUERY_TRANS_AFTER" : Gosub AQUERY_TRANS_AFTER
        When "AREAD_AFTER"        : Gosub AREAD_AFTER
    Endcase
Endcase
Return

$AQUERY_TRANS_AFTER
  Local File CONTEXT   [CNX]

  # CONTEXT
  Read [CNX]CNX0=this.DEP.CPY;this.DEP.CNX
  this.CUR = [F:CNX]CUR

  # DEPREC
  this.DPRVAL     = this.DEP.DPRBAS - this.DEP.RSDVAL
  this.GLOCLOCUM  = this.DEP.DPRCUM + this.DEP.PERCLOCUM

Return

$AREAD_AFTER
  Local File FXDASSETS [FAS]
  Local File CONTEXT   [CNX]
  Local File LNKCPTABD [LCD]

  Read [FAS]FAS0=this.DEP.AASREF
  Read [CNX]CNX0=this.DEP.CPY;this.DEP.CNX

  this.AASDES1    = [F:FAS]AASDES1
  this.CUR        = [F:CNX]CUR

  # Calculation state...
  # ... for the whole asset
  If ( [F:FAS]FLGCLC = [V]CST_AYES ) Then
    this.FLGCLC     = [V]CST_ANO
  Else
    this.FLGCLC     = [V]CST_AYES
  Endif

  # ... for the context
  If ( [F:FAS]FLGCNXCLC(this.DEP.CNX) = 2 ) Then
    this.FLGCNXCLC = [V]CST_ANO
  Elsif ( [F:FAS]FLGCNXCLC(this.DEP.CNX) = 3 ) Then
    this.FLGCNXCLC = [V]CST_ANO
  Else
    this.FLGCNXCLC = [V]CST_AYES
  Endif

  # ... for the plan
  If ( this.DEP.DEPSTA = 2 ) Then
    this.DEPSTA    = [V]CST_AYES
  Else
    this.DEPSTA    = [V]CST_ANO
  Endif

  # Flows state, hidden if the context doesn't manage flows
  If val(mid$([F:FAS]FLGCNXFLX,this.DEP.CNX,1)) = 1 Then
    If this.FLGCNXCLC = [V]CST_AYES and this.DEPSTA = [V]CST_AYES
      this.FLGCNXFLX = [V]CST_AYES
    Else
      this.FLGCNXFLX = [V]CST_ANO
    Endif
    ASTATUS = fmet this.ASETATTRIBUTE("FLGCNXFLX", "$isHidden", "false")
  Elsif val(mid$([F:FAS]FLGCNXFLX,this.DEP.CNX,1)) = 2
    this.FLGCNXFLX = [V]CST_ANO
    ASTATUS = fmet this.ASETATTRIBUTE("FLGCNXFLX", "$isHidden", "false")
  Endif

  # Values
  this.DPRVAL    = this.DEP.DPRBAS - this.DEP.RSDVAL
  this.IMLRVEISS = [F:FAS]IMLRVEISS (this.DEP.DPRPLN-1)
  this.DERRVEISS = [F:FAS]DERRVEISS

  this.RSDVALI   = this.DEP.RSDVAL
  this.BSEVALI   = this.DEP.BSEVAL
  this.DPRVALI   = this.DEP.BSEVAL - this.DEP.RSDVAL
  this.DPRCUMI   = this.DEP.EXECLOCUMI

  this.RSDVALT   = this.DEP.RSDVAL
  this.BSEVALT   = this.DEP.DPRBAS
  this.DPRVALT   = this.DEP.DPRBAS - this.DEP.RSDVAL
  this.DPRCUMT   = this.DEP.EXECLOCUMT

  this.DPMR      = this.DEP.DPM
  this.RSDVALR   = this.DEP.RSDVAL
  this.DPRVALR   = this.DEP.DPRBAS - this.DEP.RSDVAL
  this.DPRBASR   = this.DEP.DPRBAS
  this.DPRCUMR   = this.DEP.DPRCUM
  this.PERENDDPER= this.DEP.PERENDDPE
  this.ENDDPER   = this.DEP.ENDDPE
  this.EXCDPRR   = this.DEP.PEREXCDPR
  this.NBVR      = this.DEP.NBV

  Local Integer LNB
  For [F:LCD] Where REF=this.DEP.AASREF & DPRPLN=this.DEP.DPRPLN & FIYENDDAT=this.DEP.FIYENDDAT &
&                   (PERENDDAT>this.DEP.PERSTRDAT & PERENDDAT<=this.DEP.PERENDDAT)
    LNB = fmet this.ADDLINE("CGAS",-1)
    this.CGAS(LNB).TYP=[F:LCD]TYP
    this.CGAS(LNB).NUM=[F:LCD]NUM
  Next
Return



#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

