#<AdxTL>@(#)8.0.0.0 $Revision$
#Call OBJET ("SCO", GBIDC1, GBIDC2) From GOBJET
#End

$ACTION
#---------------------------------#
# Actions de l'objet SCO (GOBJET) #
#---------------------------------#
Case ACTION
 When "DEFTRANS"     : Gosub DEFTRANS     From SUBSCOA
 When "VARIANTE"     : Gosub VARIANTE     From SUBSCOA
 When "SETTRANS"     : Gosub SETTRANS     From SUBSCOA
 When "AV_IMPRIME"   : Gosub AV_IMPRIME   From SUBSCOA
 When "AP_IMPRIME"   : Gosub AP_IMPRIME   From SUBSCOA
 When "OUVRE"        : Gosub OUVRE        From SUBSCOA
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE  From SUBSCOA
 When "FILTRE"       : Gosub FILTRE       From SUBSCOA
 When "SETBOUT"      : Gosub SETBOUT      From SUBSCOA
 When "AVANTBOUT"    : Gosub AVANTBOUT    From SUBSCOA
 When "EXEBOUT"      : Gosub EXEBOUT      From SUBSCOA
 When "HINT"         : Gosub HINTCLE      From SUBSCOA
 When "FILGAUCHE"    : Gosub FILGAUCHE    From SUBSCOA
 When "AP_FILGAUCHE" : Gosub AP_FILGAUCHE From SUBSCOA
#When "TIROIR"       : Gosub TIROIR       From SUBSCOA
 When "DEB_PICK"     : Gosub DEB_PICK     From SUBSCOA
 When "PICKE"        : Gosub PICKE        From SUBSCOA
 When "DEPICK"       : Gosub DEPICK       From SUBSCOA
 When "FIN_PICK"     : Gosub FIN_PICK     From SUBSCOA
 When "STATUT"       : Gosub STATUT       From SUBSCOA
 When "DEFLIG"       : Gosub DEFLIG       From SUBSCOA
 When "LIENS_LIG"    : Gosub LIENS_LIG    From SUBSCOA
 When "INICRE_LIG"   : Gosub INICRE_LIG   From SUBSCOA
 When "INIMOD_LIG"   : Gosub INIMOD_LIG   From SUBSCOA
 When "VALLIG"       : Gosub VALLIG       From SUBSCOA
 When "RAZCRE"       : Gosub RAZCRE       From SUBSCOA
 When "RAZDUP"       : Gosub RAZDUP       From SUBSCOA
 When "LIENS"        : Gosub LIENS        From SUBSCOA
 When "VERIF_CRE"    : Gosub VERIF_CRE    From SUBSCOA
 When "INICRE"       : Gosub INICRE       From SUBSCOA
 When "CREATION"     : Gosub CREATION     From SUBSCOA
 When "APRES_CRE"    : Gosub APRES_CRE    From SUBSCOA
 When "AB_CREATION"  : Gosub AB_CREATION  From SUBSCOA
 When "AVANT_MOD"    : Gosub AVANT_MOD    From SUBSCOA
 When "VERIF_MOD"    : Gosub VERIF_MOD    From SUBSCOA
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC From SUBSCOA
 When "INIMOD"       : Gosub INIMOD       From SUBSCOA
 When "MODIF"        : Gosub MODIF        From SUBSCOA
 When "APRES_MOD"    : Gosub APRES_MOD    From SUBSCOA
 When "AB_MODIF"     : Gosub AB_MODIF     From SUBSCOA
 When "ABANDON"      : Gosub ABANDON      From SUBSCOA
 When "VERF_ANU"     : Gosub VERF_ANU     From SUBSCOA
 When "AV_ANNULE"    : Gosub AV_ANNULE    From SUBSCOA
 When "ANNULE"       : Gosub ANNULE       From SUBSCOA
 When "FERME"        : Gosub FERME        From SUBSCOA
 When "APRES_MODIF"  : Gosub APRES_MODIF  From SUBSCOA

 When "AB2_BPRNUM"   : Gosub AB2_BPRNUM  : # Action GOBJECTC0A sur ITP
 When "AB3_ITMREF"   : Gosub AB3_ITMREF  : # Action GOBJECTC0A sur ITF
 When "AB6_ITMREF"   : Gosub AB6_ITMREF  : # Action GOBJECTC0A sur POH
 When "BB6_ITMREF"   : Gosub BB6_ITMREF  : # Action GOBJECTC0A sur POH

 ## GH 08/08/13 dm 91762 ajout du tunnel vers le plan d'affectation
 When "AB7_ITMREF"   : Gosub MEM_VCR
 When "BB7_ITMREF"   : VALEUR=PARMSK(4) : mkstat=2

Endcase
Return

######################################################################################
# SCO0 => Entête: Site/Fournisseur/NomencArticleSousTraitance
######################################################################################


Subprog D_POHFCY(VALEUR)
Variable Char     VALEUR
  VALEUR = GFCY
End

Subprog AS_POHFCY(VALEUR)
Variable Char    VALEUR()
#---------------------------------------------------#
#      Initialisation du site de commande           #
# ------------------------------------------------- #
If VALEUR=""
   VALEUR = GFCY
Endif
End


Subprog AM_POHFCY(VALEUR)
#---------------------------------------------------#
#      Après modification du site de commande       #
# ------------------------------------------------- #
# Rechargement GSOCIETE : Société juridique         #
#              GLOCALDEV: Devise sté juridique      #
#              GFINRSP  : Site financier            #
#              GFCY     : Site commande             #
#              GRCPFCY  : Site réception par défaut #
# Récupération des paramètres achats et budget      #
# Rechargement code acheteur                        #
#---------------------------------------------------#
Variable Char     VALEUR
# (re)Chargement GSOCIETE courante pour le multi-soc
If GFCY<>VALEUR
   GFCY=VALEUR : Gosub CHARG_PARAM From SUBSCOA
Else
   Call ACTUALIS_FMTDIE(VALEUR,"PTR",9,GSCOPTRNUM)From TRTX3CPT
Endif
If GMESSAGE<>""
  GERR=1 : mkstat=1 : Goto RAZ_POHFCY
Endif
# Société courante
[M:SCO0]CPY = GSOCIETE
#----- Contrôle et chargement des zones inter-sites -----#
If [M:SCO0]BPRNUM<>""
  Call CTRL_INTERSITE (VALEUR,[M:SCO0]BPRNUM) From SUBSCOA
Endif

# Issue 86437 GA 12/2012
If [M:SCO1]PRHFCY<>"" & [M:SCO1]PRHFCY<>VALEUR
  If clalev([F:FCY2]) = 0 : Local File FACILITY   [FCY2] : Endif
  Read [FCY2]FCY0=[M:SCO1]PRHFCY : If fstat : Raz [F:FCY2] : Endif
  If [F:FCY2]LEGCPY<>GSOCIETE
     # Le site n'est pas sur la même société juridique
     GMESSAGE=[F:FCY2]FCY-"/"-VALEUR-mess(2,194,1)-[F:FCY2]LEGCPY-"/"-GSOCIETE
     # Issue 86768 GA 12/2012
     #mkstat=2 : End
     Local Integer  WOK : WOK=2
     # Issue X3-95319 - 2018-06-20 by MUARN : message d'erreur non avertissement
     #WOK=2 : Call AVERTIR(GMESSAGE,WOK) From GESECRAN
     #Raz GMESSAGE : If WOK=1 : mkstat=2 : End : Endif
     Call ERREUR(GMESSAGE) From GESECRAN
     Raz GMESSAGE : mkstat=1 : End
  Endif
Endif

#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL From SUBSCOA
[M:SCO0]CPY=GSOCIETE
[M:SCO1]INVFCY=GFINRSP      : # maj par CHARG_PARAM (appel de GETDEV)

$RAZ_POHFCY
If mkstat
  Local Char WMESS(80) : WMESS=GMESSAGE
  GFCY=[M:SCO0]POHFCY : Gosub CHARG_PARAM From SUBSCOA
  GMESSAGE=WMESS
  GERR=1 : mkstat=1 : End
Endif

End

######################################################################################
########################################
# Boutons/Menus contextuels BPRNUM
########################################

Subprog IB_BPRNUM
#---------------------------------------#
# Initialisation bouton sur fournisseur #
#---------------------------------------#
Raz [M:SCO0]WTRAIT
  Call IB_NOTECHECK([M:SCO0]BPRNUM,"BPS",4)  From TRTNTSCTL # Supplier notes
End

$AB2_BPRNUM
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1 (GLONVCR)
Local Char     WCLE2 (GLONVCR)
  # Article-Fournisseur
  WOBJET="ITP"
  WCLE1 =[M:SCO0]ITMREF
  WCLE2 =[M:SCO0]BPRNUM
Return

######################################################################################
Subprog AM_BPRNUM(VALEUR)
#---------------------------------------------------#
#      Après modification du fournisseur            #
#---------------------------------------------------#
Variable Char    VALEUR
Local    Integer WOK,WBOMALT      : WBOMALT=[M:SCO0]BOMALT # Issue 107513/US2 GA 04/2015
Local    Char    WBPRNUM(GLONBPR) : WBPRNUM=VALEUR

# Issue X3-55891 - 2018-09-20 by MUARN : exploitation table article/site/fournisseur GMESSAGE peut être positionné à tord
Raz GMESSAGE

# FQ 63277 GA 03/2010 # FQ 63394 GA 03/2010
If !find(GREP,"C","D")
# Modification article ou nomenclature, veuillez supprimer puis recréer votre ordre de sous-traitance.
  GMESSAGE=mess(362,194,1)
  VALEUR = [M:SCO0]BPRNUM: Affzo [M:SCO0]BPRNUM
  mkstat = 2 : End
Elsif WBOMALT=0  # Issue 107513/US2 GA 04/2015 only when no BOMALT
  Call FIND_BOMALT([M:SCO0]ITMREF,WBPRNUM,WBOMALT ) From SCOLIB
  [M:SCO0]BOMALT=WBOMALT : Affzo [M:SCO0]BOMALT
Endif
If [M:SCO0]ITMREF<>"" & WBOMALT>0
   # Issue 116684 - 2016-05-23 by MUARN : alimentation fournisseur
   [M:SCO0]BPRNUM = VALEUR
   # FQ 74423 GA 06/2011 maj de mkstat en cas d'erreur
   # FQ 63394 GA 03/2010 + 2 paramètres [M:SCO0]BOMALT,1(=Raz)
   Call RECH_SCO1_ITMREF ([M:SCO0]ITMREF,WBPRNUM,WBOMALT,1,mkstat )
   # Issue X3-95319 - 2018-07-03 by MUARN : pas d'Affzo si mkstat, sinon il est perdu
   #[M:SCO0]BOMALT=WBOMALT : Affzo [M:SCO0]BOMALT    # Issue 85534 - 2012-11-06 by CCC
   [M:SCO0]BOMALT=WBOMALT
   If mkstat<>0 End Endif
   Affzo [M:SCO0]BOMALT
   # End issue X3-95319
   # Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
   Affzo [M:SCO1]1-99 : Affzo [M:SCO2]1-99 : Affzo [M:SCO3]1-99
Endif
End

######################################################################################
Subprog C_BPRNUM(VALEUR)
#---------------------------------------------------#
#      Infos complémentaires du fournisseur         #
#---------------------------------------------------#
Variable Char    VALEUR
Local    Integer WOK
Local    Char    WSTOFCY (GLONFCY)
Local    Char    WRCPFCY (GLONFCY)
Local    Char    WBPRNUM (GLONBPR)

#----- Lecture BPARTNER si nécessaire pour chargement CUR, LAN -----#
WBPRNUM = VALEUR
Gosub READ_BPR From BPRLIB

WOK = func BPRLIB.IS_BPS_ACTIVE(WBPRNUM)
If WOK = 1 : mkstat=1 : Endif

WOK = func BPRLIB.CTL_BPS_DOUFLG(WBPRNUM)
If WOK = 1 : Endif : # mkstat déjà positionné si nécessaire

#-------------------------------------------
# Quel emplacement de sous-traitance ?
# Site de réception du client livré
#      => Site de production [M:SCO1]MFGFCY
# Site d'expédition du client livré (sur lequel se trouve l'emplacement sous-traitance)
#      => Site de stockage des matières
#      => Site de réception du produit sous-traité [M:SCO1]PRHFCY
#-------------------------------------------

# Issue 85539 - 2012-11-02 by CCC : Ne pas effacer l'adresse qui a pu être saisie si le fournisseur n'a pas changé
#Raz [M:SCO1]MFGFCY,[M:SCO1]BPAADD,[M:SCO1]LOC
If WBPRNUM<>[M:SCO0]BPRNUM
    Raz [M:SCO1]MFGFCY,[M:SCO1]BPAADD,[M:SCO1]LOC
Endif

# Issue 86439 GA 12/2012 ne pas initialiser le site de réception avant saisie alternative de nomenclature
###Call FIND_SCOLOC ( VALEUR, [M:SCO1]BPAADD, [M:SCO1]LOC,WRCPFCY,WSTOFCY) From BPRLIB
####cf CTRL_INTERSITE
####If [M:SCO1]MFGFCY="" : [M:SCO1]MFGFCY=WRCPFCY : Affzo [M:SCO1]MFGFCY : Endif
###If [M:SCO1]PRHFCY="" : [M:SCO1]PRHFCY=WSTOFCY : Affzo [M:SCO1]PRHFCY : Endif
#

# Issue X3-95319 - 2018-06-21 by MUARN : avant modification du fournisseur contrôle qu'il soit différent du site de réception
If [F:BPR]BETFCY=2 & [F:BPR]FCY= [M:SCO1]PRHFCY
  GMESSAGE = mess(588,194,1)
  mkstat = 2 : End
Endif
# End issue X3-95319

# Issue 116304 - 2016-04-29 by MUARN : devise fournisseur, non tiers
#If [F:BPR]BPRNUM=WBPRNUM
#   [M:SCO1]CUR    = [F:BPR]CUR # FQ 79340 GA 01/2011  Raz correction # FQ 74682
#   [M:SCO1]LAN    = [F:BPR]LAN
If [F:BPS]BPSNUM=WBPRNUM
   [M:SCO1]CUR    = [F:BPS]CUR
   [M:SCO1]LAN    = [F:BPR]LAN
Else
   [M:SCO1]CUR    = GLOCALDEV  # FQ 79340 GA 01/2011  Raz correction # FQ 74682
   [M:SCO1]LAN    = GLANGUE
Endif
[M:SCO3]CUR = [M:SCO1]CUR : Affzo [M:SCO3]CUR  # FQ 54650
GCUR = [M:SCO1]CUR                             # FQ 74682
Affzo [M:SCO3]CUR

#--------------------------------------------------#
# Type de donnée MC1 = devise commande (GCUR)      #
#                MC2 = devise société  (GLOCALDEV) #
#                MC3 = devise dossier  (GSYSCUR)   #
#--------------------------------------------------#
GDEV1(1)=GCUR : GDEV1(2)=GLOCALDEV : GDEV1(3)=GSYSCUR
For I=1 To 3
  GDEVFM1(I)=GDEVFMT1(max(find(GDEV1(I),GDEVISE(1..GNBDEV)),1))
Next I
#----- Chargement zones provenant du BPSUPPLIER -----#
If dim([M:SCO0]TSSCOD)>0
  For I=0 To dim([M:SCO0]TSSCOD)-1
    [M:SCO0]TSSCOD(I)=[F:BPS]TSSCOD(I)
  Next I
Endif
#----- Chargement libellés et formats colonnes tarif -----#
If GPLISTC<>[F:BPS]PLISTC
  GPLISTC=[F:BPS]PLISTC
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
  Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
  Call TARIFCHGT(6)                From TRTPRICE
Endif

# Issue 86864 GA 01/2013 appel en création, sinon c'est fait par $LIENS
# Issue 86439 GA 12/2012 ne pas initialiser le site de réception avant saisie alternative de nomenclature
#If !find(GREP,"C","D") & [M:SCO0]BOMALT>0
If find(GREP,"C","D")
  #----- Contrôle et chargement des zones inter-sites -----#
  Call CTRL_INTERSITE ([M:SCO0]POHFCY,WBPRNUM) From SUBSCOA
  If mkstat
    Local Char WMESS(80) : WMESS=GMESSAGE
    GFCY=[M:SCO0]POHFCY : Gosub CHARG_PARAM From SUBSCOA
    GMESSAGE=WMESS
    GERR=1 : mkstat=1 : End
  Endif
  # Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
  Affzo [M:SCO0]1-99
Endif
###
#### Récup Adresse Client livré et Emplacement de sous-traitance
###If [M:SCO1]BPAADD="" & [M:SCO0]BPRNUM<>""
###   # FQ 54554 Adresse du client livré (avant FIND_BPAADD)
###   Call FIND_BPDADD ([M:SCO0]BPRNUM,[M:SCO1]BPAADD) From  BPRLIB
###   If [M:SCO1]BPAADD<>""
###      Call AM_BPAADD([M:SCO1]BPAADD) From SUBSCO1
###   Endif
###   Affzo [M:SCO1]BPAADD
###Endif
###
###If [M:SCO1]BPAADD="" & [M:SCO1]MFGFCY<>""
###   Call FIND_FCYADD([M:SCO1]MFGFCY,[M:SCO1]BPAADD) From BPRLIB
###Endif
###If [M:SCO1]PRHADD="" & [M:SCO1]PRHFCY<>""
###   Call FIND_FCYADD([M:SCO1]PRHFCY,[M:SCO1]PRHADD) From BPRLIB
###Endif
###
End

######################################################################################
Subprog AS_BPRNUM(VALEUR)
Variable Char    VALEUR()
#---------------------------------------------------#
#      Avant saisie du fournisseur                  #
#---------------------------------------------------#
Local Char       WBPR(GLONBPR)
Local Char       WITMREF(GLONITM) : WITMREF = [M:SCO0]ITMREF
Local Integer    WBOMALT : WBOMALT = [M:SCO0]BOMALT
# Issue X3-55891 - 2018-09-11 by MUARN : exploitation table article/fournisseur/site
Local Char       WFCY(GLONFCY)
If VALEUR = ""
   Raz WBPR
   # Issue X3-55891 - 2018-09-11 by MUARN : exploitation table article/fournisseur/site
   If [M:SCO1]PRHFCY=""
     WFCY = GRCPFCY
   Else
     WFCY = [M:SCO1]PRHFCY
   Endif
   Call FIND_BPRNUM (WITMREF,WBOMALT,[M:SCO0]POHFCY,WFCY,WBPR) From SCOLIB
   VALEUR         = WBPR
   [M:SCO0]BPRNUM = WBPR
   Affzo [M:SCO0]BPRNUM
Endif
End

######################################################################################

Subprog AS_SCONUM(VALEUR)
#----------------------------------#
# Avant saisie du numéro de retour #
#----------------------------------#
Variable Char    VALEUR()
If (GREP="C" | GREP="D") & GMANCOU<>2  mkstat=2 : Endif
End

Subprog C_SCONUM(VALEUR)
Variable Char     VALEUR
#----- Vérif si un enregistrement existe
Look [SCO]SCO0=VALEUR
#----- Si on n'avait rien d'affiché on veut afficher un ordre existant ----#
If [M:SCO0]SCONUM="" & GREP<>"C" & GREP<>"D"
  If fstat GMESSAGE=mess(178,199,1) : mkstat=1 : End : Endif
Endif
# en création ou duplication et compteur manuel, contrôle si no existe déja
If (GREP <> "C" & GREP <> "D") | GMANCOU <> 2  : End : Endif
VALEUR = vireblc(VALEUR,2)
Look [SCO]SCO0=VALEUR
If !fstat GMESSAGE=mess(22,100,1) : mkstat=1 : End : Endif
End

Subprog AM_SCONUM(VALEUR)
Variable Char    VALEUR()
End

######################################################################################

Subprog AS_ITMREF(VALEUR)
Variable Char VALEUR
# Cas d'une modification: pas de maj
####If [M:SCO0]ITMREF<> "" & GREP="" : mkstat = 2 : End : Endif
#### les boutons ne fonctionnent plus si on ne peut plus accéder à cette donnée
# Issue X3-95319 - 2018-06-29 by MUARN : relecture paramète si besoin
If GFCY<>[M:SCO0]POHFCY
   GFCY=[M:SCO0]POHFCY : Gosub CHARG_PARAM From SUBSCOA
Endif
End

######################################################################################

Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
# Issue 112879 - 2015-12-07 by SR : Receipt Product only
If [F:ITM]ITMREF <> VALEUR
  Read [F:ITM]ITM0 = VALEUR
  If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITM]RCPFLG <> 2 : GMESSAGE = mess(472,194,1) : mkstat = 1 : End : Endif

# Ctrl Article sous-traité pris en charge par le tunnel

#Call CONTROLE("ITF","",[M:SCO0]POHFCY,VALEUR,mkstat) From CONTOBJ
# Issue 85534 GA 11/2012 ctrl à (re)faire sur site de rcp
#Local Integer WOK
#WOK = func ITMLIB.IS_ITF_OK(VALEUR,[M:SCO0]POHFCY)
#If WOK<2 : mkstat=2 : End : Endif

End

######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

If [M:SCO0]ITMREF=VALEUR :  End : Endif : # GH 28/02/2013 bug 88285 on sort du tunnel vers la cde achat
If !find(GREP,"C","D") & [M:SCO0]ITMREF<>""
# Modification article ou nomenclature, veuillez supprimer puis recréer votre ordre de sous-traitance.
  GMESSAGE=mess(362,194,1)
  VALEUR = [M:SCO0]ITMREF : Affzo [M:SCO0]ITMREF
  mkstat = 2 : End
Endif

If [F:FCY]FCY<>[M:SCO0]POHFCY
    Read [FCY]FCY0=[M:SCO0]POHFCY
    If fstat Raz [F:FCY] Endif
Endif
If [F:FCY]WRHFLG=2 # Issue 89946 GA 05/2013 article-site doit toujours exister sauf si le site dest uniquement un site d'achat
    Call READ_ITM_ITF (VALEUR,[M:SCO0]POHFCY) From ITMLIB
    If GOK<1 : mkstat = 2 : End : Endif
Endif

# Issue 107513/US10 GA 06/2015
Call AM_ITMREF(VALEUR) From SCOECCLIB

# Issue 86439 GA 12/2012 ne pas initialiser le site de réception avant saisie alternative de nomenclature
#If [M:SCO0]ITMREF<>"" & [M:SCO0]BOMALT>0
If VALEUR<>"" & [M:SCO0]BOMALT>0
    # FQ 74423 GA 06/2011 maj de mkstat en cas d'erreur
    # FQ 63394 GA 03/2010 + 2 paramètres [M:SCO0]BOMALT,1(=Raz)
    # Issue 85534 - 2012-11-06 by CCC
    #Call RECH_SCO1_ITMREF (VALEUR,[M:SCO0]BPRNUM,[M:SCO0]BOMALT,1, mkstat)
    Local Integer WBOMALT
    WBOMALT = [M:SCO0]BOMALT
    Call RECH_SCO1_ITMREF (VALEUR,[M:SCO0]BPRNUM,WBOMALT,1, mkstat)
    [M:SCO0]BOMALT = WBOMALT
Endif
If mkstat<>0 End Endif

# Issue 107513/US2 GA 04/2015 : ECC
If func AFNC.ACTIV("ECC") & dim([M:SCO0]ECCVALMAJ)>0
  If [F:ITM]ECCFLG=2  # Only one available BOMALT
     If [M:SCO0]ECCVALMAJ=""
       Local Char WITMREF(GLONITM) : WITMREF=VALEUR
       Local Char WLOT(GLONLOT)    : WLOT=""
       For [BOH] Where ITMREF=WITMREF & USESTA=2
           [M:SCO0]BOMALT = [F:BOH]BOMALT
           Call BOMFINDECC(WITMREF,[M:SCO0]ECCVALMAJ,[M:SCO0]ECCVALMIN,WLOT,[M:SCO0]BOMALT,3,[M:SCO1]ORDDAT) From TRTBOM
           If !GIMPORT : Affzo [M:SCO0]BOMALT : Affzo [M:SCO0]ECCVALMAJ : Affzo [M:SCO0]ECCVALMIN : Endif
           Break
       Next
     Endif
  Endif
Endif

#------------------------------------------------------------------------------#
# Appel S/P picking des besoins article sous-traité sauf si import             #
#------------------------------------------------------------------------------#
[M:SCO0]TRTPIC=1
If !GIMPORT
  If [F:ITM]SCPFLG=2                               : # Sous-traité (produit fini ou composé)
     [M:SCO0]TRTPIC=1
     If [M:SCO0]BETFCY=2 & [M:SCO0]BETCPY<>2       : # Inter-sites/intra-société
        [M:SCO0]TRTPIC=2
     Endif
  Else
     [M:SCO0]TRTPIC=0
  Endif
Endif
# V6 Règle affectation
[M:SCO1]PTOCOD = func ITMLIB.GET_PTOCOD(VALEUR,[M:SCO1]MFGFCY)
#mkstat=0
End
#----- Retour à la saisie de la référence article -----#
$RETOURITMREF
mkstat=1 : [M:SCO0]ITMREF=""
End

######################################################################################
# GH 08/08/13 dm 91762 pour la navigation vers le plan d'affectation
$MEM_VCR
If find(GREP,"C","D")
    If dim(GVCR)=1
        Raz GVCR, GLIN, GSEQ
    Endif
    Return
Endif
If dim(GVCR) < 0
    Global Char    GVCR(GLONVCR)
    Global Integer GLIN
    Global Integer GSEQ
Endif

GVCR = [M:SCO0]SCONUM
GLIN = [M:SCO1]SCILIN
GSEQ = 0
Return

######################################################################################

Subprog AS_BOMALT(VALEUR)
Variable Decimal VALEUR
Local    Integer WBOMALT : WBOMALT = VALEUR
# Cas d'une modification: pas de maj
####If [M:SCO0]BOMALT <> 0 & GREP="" : mkstat = 2 : End : Endif
#### les boutons ne fonctionnent plus si on ne peut plus accéder à cette donnée
#If [M:SCO0]ITMREF <> "" and WBOMALT = 0
#----- Formats et entêtes de colonne variables (comptes, sections) -----#
#  Gosub CHARG_PARAM From SUBSCOA
#  Gosub AFF_TITCOL  From SUBSCOA
# on cherche à proposer une alt de nomenc lorsque c'est possible
# Issue 85534 - 2012-11-06 by CCC
#   Call FIND_BOMALT([M:SCO0]ITMREF,[M:SCO0]BPRNUM,WBOMALT ) From SCOLIB
#  VALEUR = WBOMALT
#Endif
End

Subprog C_BOMALT(VALEUR)
Variable Decimal VALEUR
Local Integer WBOMALT : WBOMALT=VALEUR
Local Date    WDAT

# Issue 83440 GA 11/2012 en création uniquement
If !find(GREP,"C","D") End Endif

# Issue 90090 GA 06/2013 Choix alternative de nomenclature Obligatoire
If WBOMALT=0
  GMESSAGE=mess(26,195,1)
  mkstat = 2 : End
Endif

# Issue 86439 GA 12/2012 Site de l'alternative => site de réception
If [F:TBO]BOMALT<>WBOMALT
   Read [TBO]TBO0=3;WBOMALT
   If fstat Raz [F:TBO] Endif
Endif
If [F:TBO]FCY<>"" & [F:TBO]FCY<>[M:SCO1]PRHFCY
   # Issue X3-95319 - 2018-06-21 by MUARN : avant modification site de réception contrôle qu'il soit différent du site du fournisseur
   If [F:BPR]BPRNUM<>[M:SCO0]BPRNUM
     Read [BPR] BPR0=[M:SCO0]BPRNUM
     If fstat Raz [F:BPR] : Endif
   Endif
   If [F:BPR]BETFCY=2 & [F:BPR]FCY= [F:TBO]FCY
     GMESSAGE = mess(588,194,1)
     mkstat = 2 : End
   Endif
   # End issue X3-95319
   [M:SCO1]PRHFCY=[F:TBO]FCY : Affzo [M:SCO1]PRHFCY
   #Call AM_PRHFCY([M:SCO1]PRHFCY) From SUBSCO1 # à faire après avoir chargé la nouvelle nomenclature !
Endif

#
# Issue 85534 GA 11/2012
Local Char    WFCY(GLONFCY)
If [M:SCO1]PRHFCY <> "" & [M:SCO1]PRHFCY <> [M:SCO0]POHFCY
    WFCY = [M:SCO1]PRHFCY
Else
    WFCY = [M:SCO0]POHFCY
Endif
# Issue 90090 GA 06/2013 ctrl renforcés si site d'achat non stock
# Ctrl Nomenc de sous-traitance
Raz GMESSAGE
Call CONTSCONOM(WFCY,WBOMALT,WDAT,1)
If GMESSAGE<>"" mkstat=2 : End : Endif
#
End

Subprog AM_BOMALT(VALEUR)
Variable Decimal VALEUR
Local    Integer WBOMALT  : WBOMALT = VALEUR
Local    Integer WOK : WOK=2

If !find(GREP,"C","D") & [M:SCO0]BOMALT>0
# Modification article ou nomenclature, veuillez supprimer puis recréer votre ordre de sous-traitance.
  GMESSAGE=mess(362,194,1)
  VALEUR = [M:SCO0]BOMALT: Affzo [M:SCO0]BOMALT
  mkstat = 2 : End
Endif

# Issue 86439 GA 12/2012 après picking des besoins on a perdu GREP (?)
# Issue 83440 GA 11/2012 en création uniquement
#If find(GREP,"C","D") & WBOMALT > 0 & [M:SCO0]ITMREF<>""
If WBOMALT > 0 & [M:SCO0]ITMREF<>""

  # FQ 74682 ajout param BPRNUM car pb dans certains cas
   Call CHARGE_BOMALT ([M:SCO0]ITMREF,[M:SCO0]BPRNUM,WBOMALT, WOK) From SUBSCOA
   If WOK<>2 : mkstat=2 : Endif

   If [M:SCO1]PRHFCY <> [M:SCO0]POHFCY   # Issue 86439 GA 12/2012 Site de l'alternative => site de réception
     [M:SCO0]BOMALT=VALEUR
     Call AM_PRHFCY([M:SCO1]PRHFCY) From SUBSCO1
   Endif
Endif
End

Subprog B2_BOMALT(VALEUR)
Variable Decimal VALEUR
Local Char    WALT(3)
Local Integer WTYP
Local Char    WITM(GLONITM),WFCY(GLONFCY)
Local Integer NBTBO

WITM=[M:SCO0]ITMREF
WTYP=3

# Issue 83440 GA 11/2012
# toutes les alt. de nomenclature de sous-traitance compatibles avec site réception (s'il est connu)
If     [M:SCO1]PRHFCY<>"" WFCY=[M:SCO1]PRHFCY
Elsif  [M:SCO1]MFGFCY<>"" WFCY=[M:SCO1]MFGFCY
Else                      WFCY=[M:SCO0]POHFCY
Endif

# GH 10/03/2014 bug 97604 les alt.nomenclature SST sont avec MFGUSE<>2
#Filter [TBO] Where ([F:TBO]FCY=WFCY | [F:TBO]FCY="") & [F:TBO]MFGUSE=2 & [F:TBO]BOMALTTYP=WTYP
For [TBO]TBO0 Where  find([F:TBO]FCY,WFCY,"")<>0 & [F:TBO]BOMALTTYP=WTYP
    GBOMALT (NBTBO) = [F:TBO]BOMALT
    NBTBO += 1
Next
#Filter [TBO]
# filtre sur article parent
Local File BOM [BOH] Where find(BOMALT, GBOMALT) & ITMREF=WITM & BOMALTTYP=WTYP

GFONBOD="BOMS"
If [M:SCO1]ORDDAT=[0/0/0]
    GDATEREF=date$
Else
    GDATEREF=[M:SCO1]ORDDAT
Endif

# GH 17/08/11 bug 74528
#Local Char    WSUPP
#If WALT > 0 : WSUPP = num$(WALT) + "~" + num$(WTYP) : Endif
#Call OBJET("BOD", WITM, WSUPP) From GOBJET
Local Char WSUPP(GLONITM)(2)
WSUPP(0)=WITM : WSUPP(1)=num$(WTYP)
WALT=num$(VALEUR)

Call OBJET("BOD",WALT,WSUPP) From GOBJET

# relecture article
If [F:BOH]ITMREF=""
    mkstat=2
    End
Else
    VALEUR=[F:BOH]BOMALT
Endif
Raz GBOMALT
End


######################################################################################

Subprog RECH_SCO1_ITMREF(LITMREF,LBPRNUM,LBOMALT,LRAZ,LMKSTAT)
Value Char    LITMREF()
Value Char    LBPRNUM()
Variable Integer LBOMALT    # Ajout FQ 63394 GA 03/2010
Value Integer LRAZ          # Ajout FQ 63394 GA 03/2010
Variable Shortint LMKSTAT   # FQ 74423 GA 06/2011

Local Integer    WBOMALT : WBOMALT = LBOMALT    # Issue 107513/US2 GA 04/2015 before [M:SCO0]BOMALT
Local Decimal    WCOEFF
Local Integer    WOK  : WOK  = 2

#---------------------------------------------------#
#  Lecture ITM et ITF
#---------------------------------------------------#
Local Char WITMREF(GLONITM) : WITMREF=LITMREF
Local Char WFCY   (GLONFCY)
If [M:SCO1]PRHFCY <> "" and [M:SCO1]PRHFCY <> [M:SCO0]POHFCY
   WFCY = [M:SCO1]PRHFCY
Else
   WFCY = [M:SCO0]POHFCY
Endif
GOK=1
Gosub READ_ITM From ITMLIB

# Issue 83440 GA 11/2012 pour les ctrl [F:ITF]
If [F:FCY]FCY<>WFCY
   Read [FCY]FCY0=WFCY
   If fstat Raz [F:FCY] Endif
Endif
If [F:FCY]WRHFLG=2 # Issue 83440 GA 11/2012 ssi site de stockage
  Gosub READ_ITF From ITMLIB
  #If GOK<>1 : WOK=1 : Goto ERR_SCO1 : Endif # Issue 85534 GA 11/2012 ctrl à (re)faire sur site de rcp
  If GOK<>1 : Raz GMESSAGE : GOK=1 : Endif
Endif

#----- Contrôle si article actif ? -----#
WOK = func ITMLIB.IS_ACTIVE ( LITMREF )
If WOK=1  Goto ERR_SCO1 : Endif

#----- Article référencé chez le fournisseur ? -----#
# Issue X3-55891 - 2018-09-12 by MUARN : exploitation table article/fournisseur/site
#WOK = func ITMLIB.IS_ITP_OK ( LITMREF, LBPRNUM )
If [M:SCO0]BETFCY=2 & [M:SCO0]BETCPY=1
  WOK = func ITMLIB.IS_ITP_OK ( LITMREF, LBPRNUM, [M:SCO1]PRHFCY,2)
Else
  WOK = func ITMLIB.IS_ITP_OK ( LITMREF, LBPRNUM, [M:SCO1]PRHFCY,1)
Endif
If WOK=1  Goto ERR_SCO1 : Endif
[M:SCO1]PURMINQTY = [F:ITP]PURMINQTY : # GA pour SUBSCO1 ctrl Qté

# Est-ce que cet article est vendu ? sinon pb génération de la commande de vente intersite
If [M:SCO0]BETCPY = 2 | [M:SCO0]BETFCY = 2
   WOK = func ITMLIB.IS_SOLD ( LITMREF )
   If WOK=1 : Goto ERR_SCO1 : Endif
Endif

# FQ 63394 GA 03/2010
#If LITMREF <> "" and LITMREF <> [M:SCO0]ITMREF & [M:SCO0]BOMALT<>0
If LRAZ=1
# Changement d'article, de fournisseur ou d'alternative, on efface raz l'écran
  Raz [M:SCO1] : Raz [M:SCO2] : Raz [M:SCO3]
  Gosub CHARG_PARAM From SUBSCOA    # FQ 76637 GA 11/2011 le Raz vide les [M]FMTDIE
  Gosub RAZCRE From SUBSCO1
  Gosub RAZCRE From SUBSCO2
  Gosub RAZCRE From SUBSCO3
  # Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
  Affzo [M:SCO1]1-99
  Affzo [M:SCO2]1-99
  Affzo [M:SCO3]1-99
Endif
#

[M:SCO1]STU=[F:ITM]STU
If [F:PTR]UOMSAIFLG1 = 1
 # Saisie des qtés en UA non autorisée
   [M:SCO1]PUU       = [M:SCO1]STU
Else
   If [F:ITP]PUU<>"" : [M:SCO1]PUU=[F:ITP]PUU : Else [M:SCO1]PUU=[F:ITM]PUU : Endif
Endif

#----------------------------------
# Préparation des données Quantité
#----------------------------------
If [M:SCO1]PUU=[M:SCO1]STU
   [M:SCO1]PUUSTUCOE = 1
   [M:SCO1]EXTQTY = [M:SCO1]QTYPUU
Elsif [F:ITM]PUU<>[M:SCO1]PUU
   Call PCAL_QTY([M:SCO1]QTYPUU,[M:SCO1]PUU,[M:SCO1]EXTQTY,[M:SCO1]STU,
&                 LITMREF,[M:SCO0]BPRNUM,1,[M:SCO1]PUUSTUCOE)  From TRTACHQTE1
Else
   Call PCAL_QTY([M:SCO1]QTYPUU,[M:SCO1]PUU,[M:SCO1]EXTQTY,[M:SCO1]STU,
&                 LITMREF,[M:SCO0]BPRNUM,1,GBIDD1)  From TRTACHQTE1
Endif

# Issue 107513/US2 GA 04/2015 : ECC
If func AFNC.ACTIV("ECC") & dim([M:SCO0]ECCVALMAJ)>0
  If [F:ITM]ECCFLG=2  # Only one available BOMALT
     If [M:SCO0]ECCVALMAJ=""
       Local Char WLOT(GLONLOT) : WLOT=""
       For [BOH] Where ITMREF=WITMREF & USESTA=2
           If [F:BOH]BOMALT<>LBOMALT
             [M:SCO0]BOMALT = [F:BOH]BOMALT
             WBOMALT = [F:BOH]BOMALT
           Endif
           Call BOMFINDECC(WITMREF,[M:SCO0]ECCVALMAJ,[M:SCO0]ECCVALMIN,WLOT,[M:SCO0]BOMALT,3,[M:SCO1]ORDDAT) From TRTBOM
           If !GIMPORT : Affzo [M:SCO0]BOMALT : Affzo [M:SCO0]ECCVALMAJ : Affzo [M:SCO0]ECCVALMIN : Endif
           Break
       Next
     Endif
  Endif
Endif
If LITMREF <> "" & WBOMALT <> 0 & [M:SCO2]NBLIG=0
  # FQ 74682 ajout param BPRNUM car pb dans certains cas
  Call CHARGE_BOMALT (LITMREF,LBPRNUM,WBOMALT,WOK) From SUBSCOA
  If WOK=1  : LBOMALT = 0 : Endif
#
# on repositione ITM sur le composé
  If [F:ITM]ITMREF<>LITMREF
    WITMREF=LITMREF
    Gosub READ_ITM From ITMLIB
    If [F:FCY]WRHFLG=2 # Issue 83440 GA 11/2012 ssi site de stockage
      Gosub READ_ITF From ITMLIB
      #If GOK<>1 : WOK=1 : Goto ERR_SCO1 : Endif # Issue 85534 GA 11/2012 ctrl à (re)faire sur site de rcp
      If GOK<>1 : Raz GMESSAGE : GOK=1 : Endif
    Endif
  Endif
Endif

# Issue 116483 - 2016-06-24 by MUARN : il ne faut pas récuper l'adresse fournisseur dans ce contexte
#If [M:SCO1]BPAADD="" & [F:FCY]WRHFLG=2 # Issue 83440 GA 11/2012 ssi site de stockage
#   If [M:SCO0]BPRNUM<>LBPRNUM [M:SCO0]BPRNUM=LBPRNUM Endif # FQ 64108 GA 04/2010 nécessaire pour AM_BPAADD
## Issue 85539 - 2012-11-05 by CCC : alim adresse du site
##   # FQ 54554 Adresse du client livré (avant FIND_BPAADD)
##   Call FIND_BPDADD ([M:SCO0]BPRNUM,[M:SCO1]BPAADD) From  BPRLIB
#    Local Char WRCPFCY(GLONFCY)
#    Call FIND_SCOLOC ( LBPRNUM, [M:SCO1]BPAADD, [M:SCO1]LOC,WRCPFCY,[M:SCO1]PRHFCY) From BPRLIB
#   If [M:SCO1]BPAADD<>""
#      Call AM_BPAADD([M:SCO1]BPAADD) From SUBSCO1
#   Endif
#   Affzo [M:SCO1]BPAADD
#Endif

# Issue 119621 - 2016-11-08 by MUARN : ne pas faire si site réception non chargé
# Issue 116483 - 2016-06-27 by MUARN : avertissement si changement site réception
If [M:SCO1]PRHFCY <> [M:SCO0]POHFCY & [M:SCO1]PRHFCY <> ""
  Call AM_PRHFCY([M:SCO1]PRHFCY) From SUBSCO1
  # Issue X3-95319 - 2018-07-03 by MUARN : si erreur, fin
  If mkstat : End : Endif
Endif

# Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
Affzo [SCO1]1-99

$ERR_SCO1
If GMESSAGE<>""     # FQ 74423 GA 06/2011 remplacement des Goto RETOURITMREF
   Call ERREUR(GMESSAGE) From GESECRAN
   Raz GMESSAGE :  GOK=1
Endif
If WOK=1 LMKSTAT=2 Endif

End

######################################################################################

########################################
# Boutons/Menus contextuels ITMREF
########################################
Subprog IB_ITMREF
Local Integer I, NBITM
# boutons
If [M:SCO0]ITMREF <> ""
#
  If find(GREP,"C","D")
     GBOUT2  = mess(358,200,1)  : # Sélection des besoins
  Else
     Raz GBOUT2
  Endif
  GBOUT3  = mess(4,198,1)    : # Article-Site
#
  If [M:SCO1]WIPNUM<> ""
    GBOUT5 = mess(238,198,1) : # Encours
  Else
    Raz GBOUT5
  Endif
# s'il y a une réf de commande
  If [M:SCO1]POHNUM<>""
    GBOUT6 = mess(10,159,1)-[M:SCO1]POHNUM  : # Commande
  Else
    Raz GBOUT6
  Endif
#
  GBOUT9  = mess(2,776,1) : # Coût article

# GH 08/08/13 dm 91762
  If [M:SCO1]SCOSTA=1 & [M:SCO1]ORDQTY<[M:SCO1]EXTQTY & [M:SCO1]ITMSTA<5
     GBOUT7 = mess(467,198,1) : # Affectation(s)
  Else Raz GBOUT7
  Endif
Endif

Call IB_NOTECHECK([M:SCO0]ITMREF,"ITMREF",10)  From TRTNTSCTL # product notes

End

$AB3_ITMREF
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1 (GLONVCR)
Local Char     WCLE2 (GLONVCR)
  # Article-Site
  WOBJET="ITF"
  WCLE1 =[M:SCO0]POHFCY
  WCLE2 =[M:SCO0]ITMREF
Return

$AB6_ITMREF
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1 (GLONVCR)
Local Char     WCLE2 (GLONVCR)
Local Integer  SAVCONSULT
SAVCONSULT =GCONSULT
If GREP="M" : # GH 28/02/2013 bug 88285 : # si l'EO est déjà en cours de modif, le tunnel vers la cde achat est consultatif
  GCONSULT = 1
Endif
# commande standard
  WOBJET="POH"
  WCLE1 =[M:SCO1]POHNUM
  WCLE2 =""
Return

$BB6_ITMREF : # GH 28/02/2013 bug 88285
GCONSULT = SAVCONSULT
If GREP<>"M" : mkstat=4 : Endif
Return

#########################################################################
# Contrôle de validité d'une alternative
Subprog CONTSCONOM(LFCY, LALT, LDAT, LMSG)
Variable Char     LFCY
Variable Integer  LALT
Variable Date     LDAT
Value    Integer  LMSG

Local Date WDAT

# Issue 97606 GA 04/2014 table should have been closed if tunnel used before creating
If !clalev([F:BOH])   Local File BOM          [BOH] : Endif
If !clalev([F:BOD])   Local File BOMD         [BOD] : Endif

If [M:SCO0]ITMREF <> [F:BOH]ITMREF | LALT <> [F:BOH]BOMALT | [F:BOH]BOMALTTYP <> 3
   Read [BOH]BOH0=[M:SCO0]ITMREF;LALT;3
   If fstat            # Nomenclature inexistante !
      GMESSAGE=mess(95,193,1) : mkstat=2 : End
   Endif
Endif

If [F:TBO]BOMALT<>LALT | [F:TBO]BOMALTTYP <> 3
   Read [TBO]TBO0=3;LALT
   If fstat : mkstat=1 : End : Endif
Endif

# Issue 90090 GA 06/2013 Cette nomenclature est en cours d'élaboration (exploitation non autorisée) !
If [F:BOH]USESTA<>2
    GMESSAGE=mess(51,193,1) : End
Endif
# Opérateur autorisé ?
If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC=GUSER;[F:TBO]ACSCOD
If (!fstat & [F:ACC]EXEC = 1)
    GMESSAGE=mess(46,193,1) : End
Endif

# Issue 90090 GA 06/2013 ctrl déplacé
# Issue 83440 GA 11/2012
If [F:FCY]FCY<>LFCY
    Read [FCY]FCY0=LFCY
    If fstat Raz [F:FCY] Endif
Endif
If [F:FCY]WRHFLG=2
    If LDAT=[0/0/0]    WDAT=date$
    Else               WDAT=LDAT
    Endif

    Call CONTSCONOM(LFCY, LALT, WDAT, LMSG) From SCOLIB
Endif
End

######################################################################################
# Issue 107513/US2/US10 GA 06/2015
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
    If func ECCLIB.NBRCPN([M:SCO0]ITMREF)<1
        mkstat=2
    Elsif [M:SCO1]SCOTRKFLG > 3
        # No modification of version number if EO is at least in progress
        mkstat=2
    Endif
End

Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
    If func ECCLIB.NBRCPN([M:SCO0]ITMREF)<2
        mkstat=2
    Elsif [M:SCO1]SCOTRKFLG > 3
        # No modification of version number if EO is at least in progress
        mkstat=2
    Endif
End

######################################################################################
# Issue 107513/US2/US10 GA 06/2015
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local Integer LRET
Local Char LMSG(250)

Call CTRECC([M:SCO0]ITMREF,"SCO0","ECCVALMAJ",VALEUR,[M:SCO0]ECCVALMIN,
&           [M:SCO1]ORDDAT,LRET,LMSG) From ECCLIB

# Issue 111417 - 2015-09-30 by CCC : don't change errcod if managed with minor version, wait for control on ECCVALMIN
If func ECCLIB.NBRCPN([M:SCO0]ITMREF)=1
    [M:SCO0]ECCERRCOD = LRET
    [M:SCO0]ECCERRMSG = LMSG
Endif

If find(LRET,1,4)
    GMESSAGE=LMSG
    mkstat=2
Endif
End

######################################################################################
# Issue 107513/US2/US10 GA 06/2015
Subprog C_ECCVALMIN(VALEUR)
Variable Char    VALEUR()

# Issue 111235 - 2016-03-10 by JUSYN : rework control
Call CTRECC([M:SCO0]ITMREF,"SCO0","ECCVALMIN",[M:SCO0]ECCVALMAJ,VALEUR,
&           [M:SCO1]ORDDAT,GERR,GMESSAGE) From ECCLIB

[M:SCO0]ECCERRCOD = GERR
[M:SCO0]ECCERRMSG = GMESSAGE

If find(GERR,1,4)
    mkstat=2
    GERR = 1
Endif

End

######################################################################################
# Issue 107513/US2/US10 GA 04/2015
Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local Integer LRET # Issue 111235
Local Char LMESSAGE(250)

Local Char WECCVAL(GLONECS) : WECCVAL=[M:SCO0]ECCVALMAJ
  If [M:SCO0]ITMREF<>[F:ITM]ITMREF
     Read [ITM]ITM0=[M:SCO0]ITMREF : If fstat Raz [F:ITM] Endif
  Endif
  # Issue 111235 - 2016-03-07 by JUSYN : Enhance treatment when minor version is wrong.
  [M:SCO0]ECCVALMAJ=VALEUR : #Affzo [M:SCO0]ECCVALMAJ

#  Call CTRECCVER([M:SCO0]ITMREF,"SCO0", VALEUR, [M:SCO0]ECCVALMIN,
#&           LRET,[M:SCO0]ECCERRMSG) From ECCLIB
LRET = 0
If func ECCLIB.NBRCPN([M:SCO0]ITMREF) = 2
  Call CTRECC([M:SCO0]ITMREF,"SCO0","ECCVALMIN",[M:SCO0]ECCVALMAJ,[M:SCO0]ECCVALMIN,
&             [M:SCO1]ORDDAT,LRET,LMESSAGE) From ECCLIB
Endif

  If !find(LRET, 1, 4)
      Gosub ECC_CHECK_BOM
#  Else
#      GMESSAGE=[M:SCO0]ECCERRMSG
#      mkstat = 2
#      End
  Endif

  If mkstat=2
     [M:SCO0]ECCVALMAJ=WECCVAL : : #Affzo [M:SCO0]ECCVALMAJ
     End
  Endif
End
######################################################################################
# Issue 107513/US2/US10 GA 06/2015
Subprog AM_ECCVALMIN(VALEUR)
Variable Char    VALEUR()

Local Char WECCVAL(GLONECS) : WECCVAL=[M:SCO0]ECCVALMIN

  # Issue 111235 - 2016-03-07 by JUSYN : Deactivate affzo because messages from ECC_CHECK_BOM don't appear.
  [M:SCO0]ECCVALMIN=VALEUR : #Affzo [M:SCO0]ECCVALMIN
  Gosub ECC_CHECK_BOM
  If mkstat=2
     [M:SCO0]ECCVALMIN=WECCVAL : : #Affzo [M:SCO0]ECCVALMIN
     End
  Endif
End
# --------------------------------------------------------
# Issue 107513/US2 GA 04/2015:
# - Case ORDDAT impacts ECC version
# - Case ECC version changed
# --------------------------------------------------------
$ECC_CHECK_BOM
If func AFNC.ACTIV("ECC") & dim([M:SCO0]ECCVALMAJ)>0 & [M:SCO0]ECCVALMAJ<>""
   Local Char WLOT(GLONLOT) : WLOT=""
   Local Char WECCVALMAJ(GLONECS) : WECCVALMAJ=[M:SCO0]ECCVALMAJ
   Local Char WECCVALMIN(GLONECS) : WECCVALMIN=[M:SCO0]ECCVALMIN
   Raz GMESSAGE
# Issue 111235 - 2016-03-08 by CCC : In AM_ECCVALxxx action, we need to reload => don't need to do another control
#   Call BOMCTRECC([M:SCO0]ITMREF,[M:SCO0]ECCVALMAJ,[M:SCO0]ECCVALMIN,"",0,[M:SCO0]BOMALT,3,[M:SCO1]ORDDAT) From TRTBOM
#   If GMESSAGE<>"" & [M:SCO3]OPESTA<3   # Version is not valid at this date ?
      Local Char SAV_MSG(250) : SAV_MSG=GMESSAGE
# Issue 111235 - 2016-03-10 by JUSYN : of no use!
#      If !find(zoncou,"ECCVALMAJ","ECCVALMIN") # except when checking from ECCVALMxx
#        Raz GMESSAGE : Raz mkstat
#        Call BOMFINDECC([M:SCO0]ITMREF,WECCVALMAJ,WECCVALMIN,WLOT,[M:SCO0]BOMALT,3,[M:SCO1]ORDDAT) From TRTBOM
#        If GMESSAGE<>"" | WECCVALMAJ="" : mkstat=2 : End : Endif
#      Endif
      # Issue 107513/US2 GA 05/2015: BOM will be reloaded
      # Issue 111235 - 2016-03-10 by JUSYN : not to ask question if new version is available
      Local    Integer  WRET : WRET = 1
      If !clalev([F:EVL]) : Local File ECCVAL   [EVL]  : Endif
      Filter [EVL] Where ITMREF=[M:SCO0]ITMREF
&                      & ECCVALMAJ=WECCVALMAJ
&                      & ECCVALMIN=WECCVALMIN
&                      & ECCTYP=3
&                      & STRDAT<=[M:SCO1]ORDDAT
&                      & (ENDDAT=[0/0/0]
&                        |ENDDAT>=[M:SCO1]ORDDAT
&                        |EXNFLG=2 & (EXNDAT=[0/0/0]
&                                    |EXNDAT>=[M:SCO1]ORDDAT))
      Look [EVL] First
      Filter [EVL]
      If GIMPORT | !fstat : WRET=2
      Else
        # Issue 111235 - 2016-03-10 by JUSYN : precise message
        Call OUINON(func AFNC.MES1(mess(220,187,1), format$("D:"+GFMDAT,[M:SCO1]ORDDAT))  -[M:SCO0]ITMREF-WECCVALMAJ-WECCVALMIN-"?",WRET) From GESECRAN
      Endif
      If WRET=2
        [M:SCO0]ECCVALMAJ = WECCVALMAJ
        [M:SCO0]ECCVALMIN = WECCVALMIN
        If !GIMPORT : Affzo [M:SCO0]ECCVALMAJ : Affzo [M:SCO0]ECCVALMIN : Endif
        # Suppress previous Service/Materials
         Call SUPSRV() From SUBSCO1
         Call SUPMAT() From SUBSCO1
        #
        # Reload valid Service/Materials
         Call GENSRV() From SUBSCO1
         Call GENMAT() From SUBSCO1
      Else
       #  Cette nomenclature n'est pas valide à la date indiquée
        mkstat=2 : GMESSAGE=mess(54,199,1)-":"-SAV_MSG
        zonsui="RETDAT"
      Endif
#   Elsif GMESSAGE<>"" : mkstat=2
#   Endif
Endif
Return

