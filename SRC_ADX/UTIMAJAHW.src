#<AdxTL>@(#)6.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Creation table ADOVALHIS dans dossier historisé
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Creating table ADOVALHIS on historical folder") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJAHW
End

#-------------------#
$MAJAHW
If [L]DOSSIER=GDOSX3
 Return
Endif
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER=[L]DOSSIER
If fstat
 Goto FINMAJAHW
Endif
If [F:ADS]DOSHIS=""
 Goto FINMAJAHW
Endif
Local Char REPERT(GDIMFIC)
REPERT = filpath("","","",[F:ADS]DOSHIS,[F:ADS]VOLUME,adxmac(0))
If filinfo(REPERT,0)<0
 Goto FINMAJAHW
Endif
If filinfo(filpath("FIL","ADOVALHIS","fde",[F:ADS]DOSSIER),0)<0
 Goto FINMAJAHW
Endif
If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSHIS),0)<0
 Goto FINMAJAHW
Endif
If filinfo(filpath("FIL","ADOVALHIS","fde",[F:ADS]DOSHIS),0)<0 |
&  filinfo(filpath("FIL","ADOVALHIS","viw",[F:ADS]DOSHIS),0)>=0
  Call CRETABLE([F:ADS]DOSSIER,[F:ADS]DOSHIS,[F:ADS]TYPDBA,"ADOVALHIS",1.0,0) From CREHISTO
  Call ECR_TRACE(mess(41,125,1)-[F:ADS]DOSHIS+"."+"ADOVALHIS",0) From GESECRAN
  Onerrgo ERRMAJ
   Call MAJPARHIS([F:ADS]DOSHIS,"RELEASE",func DOSSUB.RELEASE([F:ADS]DOSREF)) From SUBADS
   Call MAJPARHIS([F:ADS]DOSHIS,"MONO","0") From SUBADS
  Onerrgo
Elsif filinfo(filpath("FIL","ADOVALHIS","fde",[F:ADS]DOSHIS),0)>=0
  Onerrgo ERRMAJ
   Call MAJPARHIS([F:ADS]DOSHIS,"RELEASE",func DOSSUB.RELEASE([F:ADS]DOSREF)) From SUBADS
   Call MAJPARHIS([F:ADS]DOSHIS,"MONO","0") From SUBADS
  Onerrgo
Endif
$FINMAJAHW
Close Local File [ADS]
Return


$ERRMAJ
Resume

