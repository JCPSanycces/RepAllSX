#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGPRESAL02   Pre-migration commandes                     Module Ventes #
#                                                                          #
# Migration en V6 :                                                        #
# ---------------                                                          #
# Entête commande : SORDER                                                 #
# ------------------------                                                 #
# Gestion des adresses                                                     #
# Gestion des infos douanières                                             #
#                                                                          #
# Migration en V11 :            : # Issue X3-90233                         #
# ---------------                                                          #
# Détail commande : SORDERQ                                                #
# -------------------------                                                #
# Alim. PJT à partir du champ PJT de l'entête commande                     #
#                                                                          #
# Pour toutes les versions                                                 #
# ------------------------                                                 #
# Détail commande : SORDERQ                                                #
# -------------------------                                                #
# Alim. SALFCY à partir de l'entête si différence                          #
# Alim. SOHCAT à partir de l'entête si différence                          #
# Détail commande : SORDERP                                                #
# -------------------------                                                #
# Alim. SALFCY à partir de l'entête si différence                          #
# Alim. SOHCAT à partir de l'entête si différence                          #
############################################################################
# Issue X3-90233 - 20180807 by LD : Error in processes UUMGPRESALxx

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPRESAL02") From LECFIC
  Endif

  Call MAJ_UUMGPRESAL02(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End
###################################################################################
Subprog MAJ_UUMGPRESAL02(DOSSIER)
Value Char DOSSIER

Local Integer ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif
# Issue 106947 - 20150811 by LD

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N= no module
  End
Endif

#----- Récupération du n° de version
# Issue X3-90233
#Local Char VERSION
#Call VERSION (DOSSIER,VERSION) From DOSSUB
#If val(VERSION)=0
#  # N° de version incorrecte
#  Call MIGSTKENDFLG (DOSSIER,"UUMGPRESAL02",7,ERR) From TRTMIG : #7=Erreur
#  End
#Endif
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGPRESAL02",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif
# End issue X3-90233

Call ECR_TIME("UUMGPRESAL02 Sales Order Process : Update SORDER") From DOSSUB
Call ECR_TRACE("UUMGPRESAL02 : Process Start on : "+DOSSIER,0) From GESECRAN

Gosub MIG_OUVRE From TRTMIG

Local Integer EXE_SQL
#EXE_SQL = 1

# Passage en V6
If VERSION<GMIGX3VER60
  # ----------------------------------------
  # 1- ajouter les colonnes dans la table S0H
  # ----------------------------------------
  Gosub ADDCOL60
  If ERR : Goto FIN_SOP : Endif
Endif

# Issue X3-90233
# Source folder version before V11 (before CHALLENGER)
If VERSION<GMIGX3VER110
  # ----------------------------------------
  # 1- ajouter les colonnes dans la table SOQ
  # ----------------------------------------
  Gosub ADDCOL110
  If ERR : Goto FIN_SOP : Endif
Endif
# End issue X3-90233

If EXE_SQL
  # Mise à jour des champs directement par requête SQL
  Gosub TRT_SQL1
Else
  # Mise à jour des champs par boucle de lecture de la table et maj
  Gosub TRT_X3
Endif

# Passage en V6
If VERSION<GMIGX3VER60
  #--------------- Suppression index ----------#
  Call MIGINDDEL (DOSSIER,"SORDER",ERR) From TRTMIG
  If ERR : Goto FIN_SOP : Endif
Endif

# Mise à jour des champs directement par une requête SQL
Gosub TRT_SQL2

$FIN_SOP
Call ECR_TIME("UUMGPRESAL02 Sales Order Process END.") From DOSSUB
End

##########################################################################
# ----------------------------------------
# Champs à alimenter à partir de la V6
# ----------------------------------------
# 1- ajouter les colonnes dans la table SOH
# 2- ajouter un index unique
# ----------------------------------------
$ADDCOL60

# 1- ajouter les colonnes dans la table SOH
# ----------------------------------------
# Ajout du champ BPAORD : Adresse client commande
Call MIGADDCOL (DOSSIER,"SORDER","BPAORD","A",5,1,ERR) From TRTMIG
If ERR : Return : Endif

# Ajout du champ BPAINV : Adresse client facture
Call MIGADDCOL (DOSSIER,"SORDER","BPAINV","A",5,1,ERR) From TRTMIG
If ERR : Return : Endif

# Ajout du champ BPAPYR : Adresse client payeur
Call MIGADDCOL (DOSSIER,"SORDER","BPAPYR","A",5,1,ERR) From TRTMIG
If ERR : Return : Endif

If GACTDEB=2
  Call MIGADDCOL (DOSSIER,"SORDER","EECLOC","C",2,1,ERR) From TRTMIG
  If ERR : Return : Endif
Endif

# Ajout du champ EECICT : Incoterm
Call MIGADDCOL (DOSSIER,"SORDER","EECICT","A",20,1,ERR) From TRTMIG
If ERR : Return : Endif

#2- ajouter un index unique
#--------------- INDEX ADDITION  ----------#
Call MIGINDCRE (DOSSIER,"SORDER","BPCORD+BPAADD+SOHNUM","","",0,ERR) From TRTMIG
If ERR : Return : Endif

Return

########################################################################
# ----------------------------------------
# Champs à alimenter à partir de la V11       : # Issue X3-90233
# ----------------------------------------
# 1- ajouter les colonnes dans la table SOQ
# ----------------------------------------
$ADDCOL110                                    : # Issue X3-90233

# 1- ajouter les colonnes dans la table SOQ
# ----------------------------------------
# Ajout du champ PJT : Code affaire
Call MIGADDCOL (DOSSIER,"SORDERQ","PJT","A",40,1,ERR) From TRTMIG

Return

########################################################################
$TRT_X3

# Passage en V6
If VERSION<GMIGX3VER60
  # Champs à alimenter à partir de la V6
  Gosub TRT_X3_60
Endif

Return

############################################################################
# Migration en V6 :                                                        #
# ---------------                                                          #
# Entête commande  : SORDER                                                #
# ---------------------                                                    #
# Gestion des adresses                                                     #
# Gestion des infos douanières                                             #
############################################################################
$TRT_X3_60

# 2- alimenter les nouvelles colonnes si vide
# -------------------------------------------

#----- Ouverture des fichiers -----#
If clalev([F:SOH]) : Close File [SOH] : Endif
If clalev([F:SOH])  = 0 : Local File =DOSSIER+".SORDER"      [SOH]  : Endif
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif
If clalev([F:BPC])  = 0 : Local File =DOSSIER+".BPCUSTOMER"  [BPC]  : Endif
If clalev([F:BPD])  = 0 : Local File =DOSSIER+".BPDLVCUST"   [BPD]  : Endif
# Issue 79827
If [F:ADS]MODULE(5)=2
    If clalev([F:POH])  = 0 : Local File =DOSSIER+".PORDER"  [POH]  : Endif
Endif
If clalev([F:BPS])  = 0 : Local File =DOSSIER+".BPSUPPLIER"  [BPS]  : Endif
# Issue 79827

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer COMPTEUR
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1, ACLE2, ACLE3
Raz COMPTEUR, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_SOP
Raz NB
If STOP=1
 STOP = 2
 CRITERE  = "[F:SOH]BPCORD=ACLE1 & [F:SOH]BPAADD=ACLE2 & [F:SOH]SOHNUM>ACLE3"
Elsif STOP=2
 STOP = 3
 CRITERE  = "[F:SOH]BPCORD=ACLE1 & [F:SOH]BPAADD>ACLE2"
Elsif STOP=3
 STOP = 0
 CRITERE  = "[F:SOH]BPCORD>ACLE1"
Else
 CRITERE  = "1=1"
Endif

Trbegin [SOH]
GOK = 1

For [SOH]MIG Where evalue(CRITERE)

  If [F:SOH]BPAORD<>'' & [F:SOH]BPAPYR<>'' & [F:SOH]BPAINV<>'' & [F:SOH]EECICT<>'' & (dim([F:SOH]EECLOC)<0 | [F:SOH]EECLOC<>0)
      Goto SUITE_LOOP_SOP
  Endif

  # --- alimentation des champs
  Gosub RECUP_BPR
  # --- alimentation des champs
  If [F:SOH]SOHCAT<>4
    Gosub  RECUP_BPD_SOH
  Endif
  # Issue 79827 : Si cde inter-site, alimentation des champs à partir de la cde d'achat
  If [F:ADS]MODULE(5)=2 & [F:SOH]BETFCY=2 & [F:SOH]ORIFCY<>"" & [F:SOH]ORIFCY<>[F:SOH]SALFCY
    Gosub RECUP_POH_SOH
  Endif

  Rewrite [F:SOH]
  If fstat
    Call ECR_TRACE("File SORDER(SOHNUM)"-[F:SOH]SOHNUM+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break
  Endif

  COMPTEUR += 1
  NB+=1
  If NB>GMAXUPDTRS
    ACLE1 = [F:SOH]BPCORD
    ACLE2 = [F:SOH]BPAADD
    ACLE3 = [F:SOH]SOHNUM
    STOP=1
    Break
  Endif

$SUITE_LOOP_SOP
Next

If GOK<1
  Rollback
Else
  Commit
  If STOP
    Goto LOOP_SOP
  Endif
Endif

$FIN_X3_SOH
Gosub UNSET_FIRST From TRTFIRST

Close Local File [SOH], [BPR], [BPC], [BPD], [BPS]    : # Bug 79827
If [F:ADS]MODULE(5)=2                                 : # Bug 79827
  Close Local File [POH]                              : # Bug 79827
Endif                                                 : # Bug 79827


Call ECR_TIME("UUMGPRESAL02 : "+num$(COMPTEUR)+" records processed.")  From DOSSUB

Return

########################################################################
$RECUP_BPR

    If [F:SOH]BPAORD="" | [F:SOH]BPAPYR="" | [F:SOH]BPAINV=""
      If [F:BPC]BPCNUM<>[F:SOH]BPCORD
        Read [BPC]BPC0=[F:SOH]BPCORD
        If fstat Raz [F:BPC] Endif
      Endif
    Endif

    If [F:SOH]BPAORD=""
      If dim([F:BPC]BPAADD)>0 & [F:BPC]BPAADD<>""
          [F:SOH]BPAORD=[F:BPC]BPAADD
      Else
          If [F:BPR]BPRNUM<>[F:BPC]BPCNUM
              Read [BPR]BPR0=[F:BPC]BPCNUM : If fstat Raz [F:BPR] Endif
          Endif
          [F:SOH]BPAORD=[F:BPR]BPAADD
      Endif
    Endif

    If [F:SOH]BPAPYR=""
      If [F:SOH]BPCPYR=[F:BPC]BPCPYR
          If dim([F:BPC]BPAPYR)>0 & [F:BPC]BPAPYR<>""
              [F:SOH]BPAPYR=[F:BPC]BPAPYR
          Else
              If [F:BPC]BPCPYR<>""
                  If [F:BPR]BPRNUM<>[F:BPC]BPCPYR
                      Read [BPR]BPR0=[F:BPC]BPCPYR : If fstat Raz [F:BPR] Endif
                  Endif
                  [F:SOH]BPAPYR=[F:BPR]BPAADD
              Endif
          Endif
      Else
          If [F:BPC]BPCPYR<>""
              If [F:BPR]BPRNUM<>[F:SOH]BPCPYR
                  Read [BPR]BPR0=[F:SOH]BPCPYR : If fstat Raz [F:BPR] Endif
              Endif
              [F:SOH]BPAPYR=[F:BPR]BPAADD
          Endif
      Endif
    Endif

    If [F:SOH]BPAINV=""
      If [F:SOH]BPCINV=[F:BPC]BPCINV
          [F:SOH]BPAINV=[F:BPC]BPAINV
      Else
          If [F:BPR]BPRNUM<>[F:SOH]BPCINV
              Read [BPR]BPR0=[F:SOH]BPCINV
              If fstat Raz [F:BPR] Endif
          Endif
          [F:SOH]BPAINV=[F:BPR]BPAADD
      Endif
    Endif

Return

########################################################################
$RECUP_BPD_SOH

#   Alimentation incoterm si cde non inter-site                 : # Issue 79827
#   Alimentation lieu de transport CEE dans tous les cas        : # Issue 79827
#   If ([F:SOH]EECICT="" | (GACTDEB=2 & [F:SOH]EECLOC=0))
    If (([F:SOH]EECICT="" & ([F:ADS]MODULE(5)<>2 | [F:SOH]BETFCY<>2 | [F:SOH]ORIFCY="" | [F:SOH]ORIFCY=[F:SOH]SALFCY))
&       | (GACTDEB=2 & [F:SOH]EECLOC=0))                        : # Issue 79827
         If [F:BPD]BPCNUM<>[F:SOH]BPCORD | [F:BPD]BPAADD<>[F:SOH]BPAADD
             Read [F:BPD]BPD0 = [F:SOH]BPCORD;[F:SOH]BPAADD : If fstat Raz [BPD] Endif
         Endif
         # Issue 79827
         #If [F:SOH]EECICT="" [F:SOH]EECICT=[F:BPD]EECICT Endif
         If [F:SOH]EECICT="" & ([F:ADS]MODULE(5)<>2 | [F:SOH]BETFCY<>2 | [F:SOH]ORIFCY="" | [F:SOH]ORIFCY=[F:SOH]SALFCY)
         # Issue 79827
            [F:SOH]EECICT=[F:BPD]EECICT
         Endif
         If GACTDEB=2 & [F:SOH]EECLOC=0 [F:SOH]EECLOC=[F:BPD]EECLOC Endif
     Endif

Return

# Issue 79827
##################################################################################
# Si commande inter-site alimentation des champs à partir de la commande d'achat #
##################################################################################
$RECUP_POH_SOH

     If [F:SOH]EECICT=""
         # Alimentation incoterm à partir de la commande d'achat
         If [F:POH]POHNUM<>[F:SOH]CUSORDREF
            Read [F:POH]POH0 = [F:SOH]CUSORDREF : If fstat Raz [POH] Endif
         Endif
         [F:SOH]EECICT=[F:POH]EECICT
         If [F:SOH]EECICT=""
             # Alimentation incoterm à partir du fournisseur
             If [F:BPS]BPSNUM<>[F:POH]BPSNUM
                Read [F:BPS]BPS0 = [F:POH]BPSNUM : If fstat Raz [BPS] Endif
             Endif
             [F:SOH]EECICT=[F:BPS]EECICT
         Endif
     Endif

Return
# Issue 79827

########################################################################
$TRT_SQL1

#2- alimenter la nouvelle colonne si vide
#----- Ouverture des fichiers -----#
If clalev([F:SOH]) : Close File [SOH] : Endif
If clalev([F:SOH])  = 0 : Local File =DOSSIER+".SORDER"      [SOH]  : Endif
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif
If clalev([F:BPC])  = 0 : Local File =DOSSIER+".BPCUSTOMER"  [BPC]  : Endif
If clalev([F:BPD])  = 0 : Local File =DOSSIER+".BPDLVCUST"   [BPD]  : Endif

#-----  Déclaration des variables -----#

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [SOH]
GOK = 1

# Passage en V6
If VERSION<GMIGX3VER60
  Gosub TRT_SQL1_60
Endif

If GOK<1
  Rollback
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [SOH]
Return
########################################################################
$TRT_SQL1_60
Return
########################################################################
$TRT_SQL2

#----- Ouverture des fichiers -----#
If clalev([F:SQH]) : Close File [SOH] : Endif
If clalev([F:SOP]) : Close File [SOP] : Endif
If clalev([F:SOH])  = 0 : Local File =DOSSIER+".SORDER"      [SOH]  : Endif
If clalev([F:SOP])  = 0 : Local File =DOSSIER+".SORDERP"     [SOP]  : Endif
If clalev([F:SOQ])  = 0 : Local File =DOSSIER+".SORDERQ"     [SOQ]  : Endif

#-----  Déclaration des variables -----#

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [SOP]
GOK = 1

# Suppression des incohérences entre tables avant migration
# A faire pour toutes les versions
## Passage en V6
#If val(VERSION)<30
  Gosub TRT_SQL2_30
#Endif


# Issue X3-90233
# Passage en V11
If VERSION<GMIGX3VER110
  # Champs à alimenter à partir de la V11
  Gosub TRT_SQL2_110
Endif
# End issue X3-90233

If GOK<1
  Rollback
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [SOH],[SOP],[SOQ]
Return

############################################################################
# Migration en V6 :                                                        #
# ---------------                                                          #
# Détail commande  : SORDERP                                               #
# --------------------------                                               #
# Alim. SALFCY à partir de l'entête si différence                          #
# Alim. SOHCAT à partir de l'entête si différence                          #
# Détail commande  : SORDERQ                                               #
# --------------------------                                               #
# Alim. SALFCY à partir de l'entête si différence                          #
# Alim. SOHCAT à partir de l'entête si différence                          #
############################################################################
$TRT_SQL2_30

Gosub TRT_SQL2_30_1 : # Mise à jour SALFCY SORDERP à partir de SALFCY SORDER
Gosub TRT_SQL2_30_2 : # Mise à jour SOHCAT SORDERP à partir de SOHCAT SORDER
Gosub TRT_SQL2_30_3 : # Mise à jour SALFCY SORDERQ à partir de SALFCY SORDER
Gosub TRT_SQL2_30_4 : # Mise à jour SOHCAT SORDERQ à partir de SOHCAT SORDER

Return
########################################################################
# Mise à jour SALFCY SORDERP à partir de SALFCY SORDER
########################################################################
$TRT_SQL2_30_1
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".SORDERP SET SALFCY_0="
REQSQL(1)="(SELECT SOH.SALFCY_0 FROM"-DOSSIER+".SORDER SOH WHERE SOH.SOHNUM_0=SORDERP.SOHNUM_0)"
REQSQL(2)=" WHERE SORDERP.SALFCY_0<>(SELECT SOH.SALFCY_0 FROM"-DOSSIER+".SORDER SOH WHERE SOH.SOHNUM_0=SORDERP.SOHNUM_0) "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return
###################################################################################################
# Mise à jour SOHCAT SORDERP à partir de SOHCAT SORDER
###################################################################################################
$TRT_SQL2_30_2
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".SORDERP SET SOHCAT_0="
REQSQL(1)="(SELECT SOH.SOHCAT_0 FROM"-DOSSIER+".SORDER SOH WHERE SOH.SOHNUM_0=SORDERP.SOHNUM_0)"
REQSQL(2)=" WHERE SORDERP.SOHCAT_0<>(SELECT SOH.SOHCAT_0 FROM"-DOSSIER+".SORDER SOH WHERE SOH.SOHNUM_0=SORDERP.SOHNUM_0) "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return
########################################################################
# Mise à jour SALFCY SORDERQ à partir de SALFCY SORDER
########################################################################
$TRT_SQL2_30_3
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".SORDERQ SET SALFCY_0="
REQSQL(1)="(SELECT SOH.SALFCY_0 FROM"-DOSSIER+".SORDER SOH WHERE SOH.SOHNUM_0=SORDERQ.SOHNUM_0)"
REQSQL(2)=" WHERE SORDERQ.SALFCY_0<>(SELECT SOH.SALFCY_0 FROM"-DOSSIER+".SORDER SOH WHERE SOH.SOHNUM_0=SORDERQ.SOHNUM_0) "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return
###################################################################################################
# Mise à jour SOHCAT SORDERQ à partir de SOHCAT SORDER
###################################################################################################
$TRT_SQL2_30_4
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".SORDERQ SET SOHCAT_0="
REQSQL(1)="(SELECT SOH.SOHCAT_0 FROM"-DOSSIER+".SORDER SOH WHERE SOH.SOHNUM_0=SORDERQ.SOHNUM_0)"
REQSQL(2)=" WHERE SORDERQ.SOHCAT_0<>(SELECT SOH.SOHCAT_0 FROM"-DOSSIER+".SORDER SOH WHERE SOH.SOHNUM_0=SORDERQ.SOHNUM_0) "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return

############################################################################
# Migration en V11 :                     : # Issue X3-90233                #
# ---------------                                                          #
# Détail commande : SORDERQ                                                #
# -------------------------                                                #
# Alim. PJT à partir de l'entête                                           #
############################################################################
$TRT_SQL2_110                            : # Issue X3-90233

Gosub TRT_SQL2_110_1 : # Mise à jour PJT SORDERQ à partir de PJT SORDER  : # Issue X3-90233

Return

############################################################################
# Migration en V11 :                     : # Issue X3-90233                #
# ---------------                                                          #
# Détail commande : SORDERQ                                                #
# ----------------------                                                   #
# Alim. PJT à partir du champ PJT de l'entête commande                     #
############################################################################
$TRT_SQL2_110_1                          : # Issue X3-90233

Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".SORDERQ SET PJT_0="
REQSQL(1)="(SELECT SOH.PJT_0 FROM"-DOSSIER+".SORDER SOH WHERE SOH.SOHNUM_0=SORDERQ.SOHNUM_0)"
REQSQL(2)=" WHERE SORDERQ.PJT_0=' '"

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return

###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
GOK=0
Resume

