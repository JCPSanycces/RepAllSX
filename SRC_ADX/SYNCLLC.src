#<AdxTL>@(#)6.0.0.0 $Revision$
#########################################################
# RESYNCHRO DES CODES DE PLUS BAS NIVEAU                #
# Traitement SYNCLLC (Direct ou batch)                  #
#########################################################
$ACTION
Case ACTION
    When "INIT":       Gosub INIT
    When "CONTROLE":   Gosub CONTROLE
    When "EXEC":       Gosub EXEC
    When "TERMINE":    If !GSERVEUR
                           Call FERME_TRACE From LECFIC
                           TRA = 1
                           If OK & [M:DIA]TOUTES <> 2
                               SAI=1
                           Else
                               Raz [M:DIA]
                           Endif
                    Endif
Endcase
Return

#########################################################
$INIT

Local Integer CTL_OK, OK
Local Integer BOM_OK
Local Char    TIT_ECR(50)
Local Char    SYMBOLE(10)

Local File BOM         [BOH]
Local File BOMD        [BOD]
Local File BOMD        [BOD2]
Local File TABBOMALT   [TBO]
Local File ITMBOM      [ITB]
Local File ITMBOM      [ITB2]    # Pour LLCLIB.CALCLLC

# Resynchronisation codes de plus bas niveau
TIT_ECR = mess(142,195,1)

Return

#########################################################
$CONTROLE
Return

#########################################################
$EXEC
Local Char    ERR_TRA(132)
Local Char    FILITB(250), FILBOH(250), FILBOD(250)
Local Integer MAJ_OK
Local Integer NB_OLD, NB_NEW
Local Integer WLLCTYP
Local Integer WLLCTYPS
Local Integer WBOMALTS

Global   Integer GNIV, GBOHLLC   # pour le sous-pro de màj des LLC

Local Char    LCPN(GLONITM)
Local Integer COMPTEUR, STOP, LNB, LNBTOT, LMAX
Local Integer T0,T1,T2, H,M,S, JT,HT,MT,ST, LRET, LREW
Local Decimal T
Local Char    REQ(250)(4)
Local Char    LCREDAT(50),LDATNUL(50)
Local Char    FLTITB_0(50), FLTBOM_0(50), FLTBOMD_0(50)
Local Char    FLTITB(50), FLTBOM(50)
Local Integer IREQ

If !GSERVEUR
   Call OUVRE_TRACE(mess(142,195,1)) From LECFIC
Endif

#########################################################
$LCK_SYM
# Contrôler qu'il n'y a pas une autre resynchro
# "Resynchronisation codes de plus bas niveau en cours"

CTL_OK = 0 : # Issue 118021 GH 07/09/2016 - CTL_OK indicates what is locked

SYMBOLE = "SYNCLLC"
Lock =SYMBOLE With lockwait = 0
If fstat
    If GSERVEUR
      ERR_TRA = mess(137,196,1)
      Call ECR_TRACE(ERR_TRA,1) From GESECRAN
    Else
      Call ERREUR(mess(137,196,1)) From GESECRAN
    Endif
    Goto FIN
Endif
CTL_OK = 1

# locker les tables BOM BOMD ITMBOM
Lock [BOH]
If fstat
    ERR_TRA = mess(20,100,1) - ":"-mess(190,197,1)-"(BOM)"
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
    Goto FIN
Endif
CTL_OK = 2

Lock [BOD]
If fstat
    ERR_TRA = mess(20,100,1) - ":"- mess(191,197,1) - "(BOMD)"
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
    Goto FIN
Endif
CTL_OK = 3

Lock [ITB]
If fstat
    ERR_TRA = mess(20,100,1) - ":"- mess(192,197,1)- "(ITMBOM)"
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
    Goto FIN
Endif
CTL_OK = 4

If [M]TOUTES = 2
   FILITB = "1=1"
Else
   Case [M]LLCTYP
       When 1:  FILITB = "BOMALTTYP = 1"
       When 2:  FILITB = "find(BOMALTTYP,2,3)<>0"
   Endcase
   If [M]BOMALT <> 0 : FILITB += " & BOMALT = [M]BOMALT" : Endif
Endif

## Traitement séparé par type d'alternative
WLLCTYPS = 0
WBOMTYPS = 0

# Issue 118021 GH 07/09/2016 - consider key TBO2 to optimize the process
#For [TBO]TBO0 Where evalue(FILITB)
#    WLLCTYP = func LLCLIB.LLCTYP([F:TBO]BOMALTTYP)
#
#    # un seul passage pour production/sous-traitance
#    If WLLCTYP = WLLCTYPS & WBOMALTS = [F:TBO]BOMALT : Goto NXT_TBO : Endif
#
#    Gosub MAJ_ITB
#
#$NXT_TBO
#    # mémorisation traitement précedent pour ne traiter qu'une fois BOMALTTYP = 2 et 3 (LLCTYP=2)
#    If WLLCTYPS = 0 | WLLCTYPS <> WLLCTYP
#        WLLCTYPS = WLLCTYP
#    Endif
#    If WBOMALTS = 0 | WBOMALTS <> [F:TBO]BOMALT
#        WBOMALTS = [F:TBO]BOMALT
#    Endif
#Next

For [TBO]TBO2 Where evalue(FILITB)
    WLLCTYP = func LLCLIB.LLCTYP([F:TBO]BOMALTTYP)

    # un seul passage pour production/sous-traitance
    If !(WLLCTYP = WLLCTYPS & WBOMALTS = [F:TBO]BOMALT)
        Gosub MAJ_ITB
        WLLCTYPS = WLLCTYP
        WBOMALTS = [F:TBO]BOMALT
    Endif
Next

# Issue 118021 GH 07/09/2016 - unlock tables IN $FIN
#Unlock [BOH]
#Unlock [BOD]
#Unlock [ITB]

Goto FIN

#########################################################
$MAJ_ITB
MAJ_OK = 1
T0=time

Case WLLCTYP
    When 1 : FLTBOM_0 =  " AND BOM.BOMALTTYP_0=1"
             FLTBOM =  "BOMALTTYP=1"
             FLTBOMD_0 =  " AND BOMD.BOMALTTYP_0=1"
    When 2 : FLTBOM_0 =  " AND BOM.BOMALTTYP_0>="+num$(WLLCTYP)
             FLTBOM =  "BOMALTTYP>="+num$(WLLCTYP)
             FLTBOMD_0 = " AND BOMD.BOMALTTYP_0>="+num$(WLLCTYP)

Endcase
FLTITB_0 = " AND ITMBOM.LLCTYP_0="+num$(WLLCTYP)
FLTITB =  "LLCTYP="+num$(WLLCTYP)

Call DEBTRANS From GLOCK : # une transaction par alternative
Trbegin [ITB]
# Effacement des enreg pour cette alternative
#--- Met le niveau à -1 des enregistrements qui ne sont pas des composés
Raz REQ
REQ(0) =" UPDATE ITMBOM"
&      +" SET LLC_0=-1"
&      +" WHERE ITMBOM.BOMALT_0="+num$([F:TBO]BOMALT)
&      +    FLTITB_0
&      +"   and not EXISTS( SELECT 1"
&              +        " FROM BOM"
&              +        " WHERE ITMBOM.ITMREF_0 = BOM.ITMREF_0"
&              +          " AND BOM.BOMALT_0="+num$([F:TBO]BOMALT)
&              +          FLTBOM_0
&              +         ")"

Call ECRTIME("Set LLC=-1")
Execsql From num$(GTYPDBA*2+1) Sql REQ
Call ECRTIME("Set LLC=-1 OK")
Commit

Trbegin [ITB]
#--- Met le niveau à 0 des enregistrements qui sont des composés
Raz REQ
REQ(0) =" UPDATE ITMBOM"
&      +" SET LLC_0=0, BOMEXIFLG_0=2, BOHITM_0=' ', WUSEXIFLG_0=0"
&      +" WHERE ITMBOM.BOMALT_0="+num$([F:TBO]BOMALT)
&  +            FLTITB_0
REQ(1) =  " and EXISTS( SELECT 1"
&            +        " FROM BOM"
&            +        " WHERE ITMBOM.ITMREF_0 = BOM.ITMREF_0"
&            +          FLTBOM_0
&            +          " AND BOM.BOMALT_0="+num$([F:TBO]BOMALT)+")"

Call ECRTIME("Set LLC=0")
Execsql From num$(GTYPDBA*2+1) Sql REQ
Call ECRTIME("Set LLC=0 OK")
Commit

#--- Création des enreg ITB manquants des composés
Raz REQ
REQ(0) =" SELECT COUNT(*)"
REQ(0)+=" From BOM"
REQ(0)+=" LEFT OUTER JOIN ITMBOM"
REQ(0)+=  " ON BOM.ITMREF_0 = ITMBOM.ITMREF_0"
REQ(0)+= " AND BOM.BOMALT_0 = ITMBOM.BOMALT_0"
REQ(0)+= FLTITB_0
REQ(1) =" WHERE ITMBOM.ITMREF_0 IS NULL"
REQ(1)+=  " AND BOM.BOMALT_0="+num$([F:TBO]BOMALT)
REQ(1)+= FLTBOM_0

Call ECRTIME("count missing ITB")
For (Integer NB) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
    LMAX=[F:SQLX]NB
Next
Call ECRTIME(num$(LMAX)-"missing ITB")

Raz COMPTEUR, LNB, STOP

# Issue 105823 - 2015-04-02 by CCC : SQL instruction for Insert is not possible because of technical fields (CREDATTIM, UPDDATTIM and UPDTICK)
## FQ 56581 GA 07/2009 pb avec zones spécifiques Kardol: l'insert ne fonctionne pas
#GPE=0 : GPOINT = "ITBCRE" : Gosub ENTREE From EXEFNC
#If !GPE
#    Call ECRTIME("create missing ITB (Execsql)")
#    T0=time
#
#    # Premier passage à partir des entêtes de nomenclatures
#    Raz REQ
#    Case GTYPDBA
#        When 1 : LCREDAT="to_date( '"+format$("D:DD[/]MM[/]YYYY",date$)+"', 'dd/mm/yyyy')"
#                 LDATNUL="to_date( '31/12/1599', 'dd/mm/yyyy')"
#        When 2 : LCREDAT="CONVERT(DATETIME, '"+format$("D:DD[/]MM[/]YYYY",date$)+"', 103)"
#                 LDATNUL="CONVERT(DATETIME, '01/01/1753', 103)"
#    Endcase
#
#    REQ(0) = "INSERT INTO ITMBOM (ITMREF_0,BOMALT_0,LLCTYP_0,BOMEXIFLG_0,LLC_0,WUSEXIFLG_0,BOHITM_0,CREDAT_0,CREUSR_0,UPDDAT_0,UPDUSR_0,EXPNUM_0)"
#    REQ(1) =" Select BOM.ITMREF_0,"+num$([F:TBO]BOMALT)+","+num$(WLLCTYP)+",2,0,0,' ',"+LCREDAT+",'"+GUSER+"',"+LDATNUL+",' ',"+num$([C]EXPORT)
#    REQ(1)+=" From BOM"
#    REQ(2) =" LEFT OUTER JOIN ITMBOM"
#    REQ(2)+=  " ON BOM.ITMREF_0 = ITMBOM.ITMREF_0"
#    REQ(2)+= " AND BOM.BOMALT_0 = ITMBOM.BOMALT_0"
#    REQ(2)+=   FLTITB_0
#    REQ(3) =" Where ITMBOM.ITMREF_0 IS NULL"
#    REQ(3)+=  " and BOM.BOMALT_0="+num$([F:TBO]BOMALT)
#    REQ(3)+=    FLTBOM_0
#
#    Trbegin [ITB]
#
#    Execsql From num$(GTYPDBA*2+1) Sql REQ
#
#    Commit
#    Call ECRTIME("create missing ITB OK (Execsql)")
#Else
    Call ECRTIME("create missing ITB (Write)")
    T0=time
    Trbegin [ITB]


# Issue 105823 - 2015-04-02 by CCC
#   # FQ 78986 GA 01/2012 lignes manquantes
#   # Premier passage à partir des entêtes de nomenclatures
#   For [BOH]BOH0 Where BOMALT = [F:TBO]BOMALT & [F:BOH]ITMREF<>""
#&                    & evalue(FLTBOM)
#        Read [ITB]ITB0 = [F:BOH]ITMREF;[F:BOH]BOMALT;WLLCTYP
#        If fstat = 5
    Raz REQ, IREQ
    Call ADDCRIT(REQ,IREQ,"","Select BOM.ITMREF_0"," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"","From BOM"," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"","LEFT OUTER JOIN ITMBOM"," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"",  "ON BOM.ITMREF_0 = ITMBOM.ITMREF_0"," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"", "AND BOM.BOMALT_0 = ITMBOM.BOMALT_0"," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"",   FLTITB_0," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"","Where ITMBOM.ITMREF_0 IS NULL"," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"",  "and BOM.BOMALT_0="+num$([F:TBO]BOMALT)," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"",  FLTBOM_0," ") From GOBJSUB
    For (Char ITMREF) From num$(GTYPDBA*2+1) Sql REQ As [SBOH]
        Raz [F:ITB]
        [F:ITB]ITMREF    = [F:SBOH]ITMREF
        [F:ITB]BOMALT    = [F:TBO]BOMALT
        [F:ITB]BOMEXIFLG = 2  : # Issue 118021 GH 07/09/2016 - it is a compound not a component : # [F:ITB]WUSEXIFLG = 2
        [F:ITB]LLCTYP    = WLLCTYP
        [F:ITB]CREDAT    = date$
        [F:ITB]CREUSR    = GUSER
        [F:ITB]EXPNUM    = [C]EXPORT
        Write [ITB]
        If fstat
            GOK = 0
            Break
        Endif
    Next
    Commit

#--- Création des enreg ITB manquants des composants

    Trbegin [ITB]

# Issue 105823 - 2015-04-02 by CCC
#    For [BOD]BOD0 Where BOMALT = [F:TBO]BOMALT
#&                    & evalue(FLTBOM)
#        Read [ITB]ITB0 = [F:BOD]CPNITMREF;[F:BOD]BOMALT;WLLCTYP
#        If fstat = 5
    Raz REQ, IREQ
    Call ADDCRIT(REQ,IREQ,"","Select min(BOMD.ITMREF_0), BOMD.CPNITMREF_0, min(BOMD.CPNTYP_0), max(BOMD.CPNTYP_0)"," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"","From BOMD"," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"","LEFT OUTER JOIN ITMBOM"," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"",  "ON BOMD.CPNITMREF_0 = ITMBOM.ITMREF_0"," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"", "AND BOMD.BOMALT_0 = ITMBOM.BOMALT_0"," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"",   FLTITB_0," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"","Where ITMBOM.ITMREF_0 IS NULL"," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"",  "and BOMD.BOMALT_0="+num$([F:TBO]BOMALT)," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"",  FLTBOMD_0," ") From GOBJSUB
    Call ADDCRIT(REQ,IREQ,"","Group By BOMD.CPNITMREF_0"," ") From GOBJSUB
    For (Char ITMREF, Char CPNITMREF, Integer CPNTYPMIN, Integer CPNTYPMAX) From num$(GTYPDBA*2+1) Sql REQ As [SBOD]
      If [F:SBOD]CPNITMREF<>"" : # Issue 118298 GH 05/09/2016 - don't generate ITMBOM records with no ITMREF
        Raz [F:ITB]
        [F:ITB]ITMREF    = [F:SBOD]CPNITMREF
        [F:ITB]BOMALT    = [F:TBO]BOMALT
        [F:ITB]WUSEXIFLG = 2
        [F:ITB]LLCTYP    = WLLCTYP
        # Issue 104223 - 2015-04-02 by CCC : LLC=0 for by-products
        If ([F:SBOD]CPNTYPMIN=4 & [F:SBOD]CPNTYPMAX=4)
            [F:ITB]LLC       = 0
        Else
            [F:ITB]LLC       = 1
        Endif
        [F:ITB]BOHITM    = [F:SBOD]ITMREF
        [F:ITB]CREDAT    = date$
        [F:ITB]CREUSR    = GUSER
        [F:ITB]EXPNUM    = [C]EXPORT
        Write [ITB]
        If fstat
            GOK = 0
            Break
        Endif
      Endif
    Next

    Commit

    Call ECRTIME("create missing ITB OK (Write)")
#Endif

#-----------------------------------------

Raz REQ
REQ(0) ="Select count(DISTINCT CPNITMREF_0) From BOMD"
REQ(1) =" Where BOMALT_0="+num$([F:TBO]BOMALT)
REQ(1)+=             FLTBOMD_0
# FQ 64407 GA 04/2010 traiter aussi les sous-produits CPNTYP=4
#REQ(1)+=       " AND BOMD.CPNTYP_0<>4 AND BOMD.CPNTYP_0<>5 AND BOMD.CPNTYP_0<>7"

Call ECRTIME("Count first level components")
For (Integer NB) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
    LMAX=[F:SQLX]NB
Next
Call ECRTIME(num$(LMAX)-"first level components (max)")

# FQ 48487 GA 07/2008
# Call OUVRE_BOITE("Components level updating",LMAX) From GESECRAN

Raz COMPTEUR, LNB, LNBTOT

#--- On parcourt les composant de 1er niveau uniquement, les autres seront traités dans LLCLIB.CALCLLC
Raz REQ
# Issue 118021 GH 07/09/2016 - normal component at level 1 for a BOM was not considered
#                              if it was also a by-product component for another BOM
#REQ(0) =" SELECT BOMD.CPNITMREF_0 "
#REQ(0)+=" FROM BOMD"
#REQ(0)+=" LEFT OUTER JOIN BOMD B2"
#REQ(1) =  " ON  BOMD.ITMREF_0=B2.CPNITMREF_0"
#REQ(1)+= " AND BOMD.BOMALT_0=B2.BOMALT_0"
#REQ(1)+= " AND BOMD.BOMALTTYP_0=B2.BOMALTTYP_0"
## Issue 104223 - 2015-03-31 by CCC : If a BOM is only a by-product elsewhere, its components have LLC=1 and we have to go down in their BOM
### FQ 64407 GA 04/2010 traiter aussi les sous-produits CPNTYP=4: suppression de "& !find(CPNTYP,4,5)"
###REQ(1)+= " AND B2.CPNTYP_0<>4 AND B2.CPNTYP_0<>5 AND B2.CPNTYP_0<>7"
#REQ(1)+= " AND B2.CPNTYP_0<>4"
#REQ(2)= " WHERE BOMD.BOMALT_0="+num$([F:TBO]BOMALT)
#REQ(2)+=      FLTBOMD_0
## FQ 64407 GA 04/2010 traiter aussi les sous-produits CPNTYP=4: suppression de "& !find(CPNTYP,4,5)"
##REQ(2)+=  " AND BOMD.CPNTYP_0<>4 AND BOMD.CPNTYP_0<>5 AND BOMD.CPNTYP_0<>7"
#REQ(2)+= " GROUP BY BOMD.CPNITMREF_0"
#REQ(2)+=    " HAVING MAX(B2.ITMREF_0) IS NULL"

# components only used at  the first level in BOM trees => LLC=1
REQ(0) =" SELECT BOMD.CPNITMREF_0 CPN, 1 LLC"
REQ(0)+=" FROM BOMD"
REQ(0)+=" LEFT OUTER JOIN BOMD B2"
REQ(0)+="   ON BOMD.ITMREF_0=B2.CPNITMREF_0"
REQ(0)+="  AND BOMD.BOMALT_0=B2.BOMALT_0"
#REQ(0)+="  AND BOMD.BOMALTTYP_0=B2.BOMALTTYP_0" : # not correct if production & subcontracting BOM trees are mixed together
If WLLCTYP=1
   REQ(0)+="  AND B2.BOMALTTYP_0=1"
Else
   REQ(0)+="  AND B2.BOMALTTYP_0>1"
Endif
REQ(0)+="  AND B2.CPNTYP_0<>4"
REQ(1) =" WHERE BOMD.BOMALT_0="+num$([F:TBO]BOMALT)
REQ(1)+=    FLTBOMD_0
REQ(1)+="   AND BOMD.CPNTYP_0<>4"
REQ(1)+=" GROUP BY BOMD.CPNITMREF_0"
REQ(1)+=" HAVING max(B2.ITMREF_0) IS NULL"
# components only used as by-product in BOMs => LLC=0
REQ(1)+=" UNION"
REQ(2) =" SELECT CPNITMREF_0 CPN, 0 LLC"
REQ(2)+="  FROM BOMD"
REQ(2)+=" WHERE BOMD.BOMALT_0="+num$([F:TBO]BOMALT)
REQ(2)+=    FLTBOMD_0
REQ(2)+=" GROUP BY CPNITMREF_0"
REQ(2)+=" HAVING MAX(CPNTYP_0)=4"
REQ(2)+="    AND MIN(CPNTYP_0)=4"

For (Char CPNITMREF, Integer LLC) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
  If [F:SQLX]CPNITMREF<>"" : # Issue 118298 GH 05/09/2016 - don't generate ITMBOM records with no ITMREF
    If COMPTEUR=0
        Trbegin [ITB]
        If LNB=0
            T0=time
            Call ECRTIME("Start loop llc=1")
        Endif
    Endif

    If mod(LNB,int(LMAX/100))=0 & LNB>0
        T1=time
        T=T1-T0
        H=int(T/3600)
        M=int((T-H*3600)/60)
        S=int(T-H*3600-M*60)
        T=LMAX*(T1-T0)/LNB
        JT=int(T/86400)
        HT=int((T-JT*86400)/3600)
        MT=int((T-JT*86400-HT*3600)/60)
        ST=int(T-JT*86400-HT*3600-MT*60)
      # FQ 48487 GA 07/2008
      # Call AFF_BOITE(num$(LNB)-num$(H)+":"+num$(M)+":"+num$(S)+";"+num$(JT)+"j"+num$(HT)+"h"+num$(MT)+"m"+num$(ST)+"s",LNB,STOP) from gesecran
        Call TEMPON([F:SQLX]CPNITMREF,num$(LNB)-num$(H)+":"+num$(M)+":"+num$(S)+";"+num$(JT)+"j"+num$(HT)+"h"+num$(MT)+"m"+num$(ST)+"s")
    Endif

    If LNB>0 & time-T2>=60
        T2=time
        T1=time
        T=T1-T0
        H=int(T/3600)
        M=int((T-H*3600)/60)
        S=int(T-H*3600-M*60)
        T=LMAX*(T1-T0)/LNB
        JT=int(T/86400)
        HT=int((T-JT*86400)/3600)
        MT=int((T-JT*86400-HT*3600)/60)
        ST=int(T-JT*86400-HT*3600-MT*60)
        Call ECRTIME([F:SQLX]CPNITMREF-"lnb="+num$(LNB)-num$(H)+":"+num$(M)+":"+num$(S)+";"+num$(JT)+"j"+num$(HT)+"h"+num$(MT)+"m"+num$(ST)+"s"-"freemem="+num$(freemem))
    Endif

  # FQ 64407 GA 04/2010 traiter aussi les sous-produits CPNTYP=4: suppression de "& !find(CPNTYP,4,5)"
  # Filter [BOD] Where !find(CPNTYP,4,5,7)
  #  Read [BOD]BOD3(2)=[F:TBO]BOMALT;[F:SQLX]CPNITMREF;WLLCTYP
  #  If fstat & WLLCTYP=2
  #      Read [BOD]BOD3(2)=[F:TBO]BOMALT;[F:SQLX]CPNITMREF;3
  #  Endif
# bug 66927 01/09/10 Modification de l'index BOD3
    Read [BOD]BOD3(3)=[F:TBO]BOMALT;[F:SQLX]CPNITMREF;WLLCTYP
    If fstat & WLLCTYP=2
        Read [BOD]BOD3(3)=[F:TBO]BOMALT;[F:SQLX]CPNITMREF;3
    Endif
    Filter [BOD] # Restore [G:BOD]currlen and [G:BOD]currind

    Read [ITB]ITB0 = [F:SQLX]CPNITMREF;[F:TBO]BOMALT;WLLCTYP
    If fstat = 5
        Raz [F:ITB]
        [F:ITB]ITMREF    = [F:SQLX]CPNITMREF
        [F:ITB]BOMALT    = [F:TBO]BOMALT
        [F:ITB]LLCTYP    = WLLCTYP
        REW = 1
    Else
        GCLE=num$([F:ITB]LLC)-num$([F:ITB]BOMEXIFLG)-num$([F:ITB]WUSEXIFLG)-[F:ITB]BOHITM
        REW = 2
    Endif

    [F:ITB]WUSEXIFLG = 2

  # FQ 64407 GA 04/2010 traiter aussi les sous-produits CPNTYP=4: suppression de "& !find(CPNTYP,4,5)"
    Filter [BOD2] Where BOMALT=[F:TBO]BOMALT
&                     & CPNITMREF=[F:SQLX]CPNITMREF
&                     & ITMREF<>[F:BOD]ITMREF
&                     & evalue(FLTBOM)
# Issue 118021 GH 07/09/2016 - consider all types of component to set BOHITM
#&                     & CPNTYP<>4   # Issue 104223 - 2015-03-26 by CCC : Don't take into account by-product
    If rowcount([BOD2])>0
       [F:ITB]BOHITM    = ""
    Else
       [F:ITB]BOHITM    = [F:BOD]ITMREF
    Endif
    Filter [BOD2]

# Issue 118021 GH 07/09/2016 - setting of LLC should depend of current record [BOD] only if it is the only one
#   # Issue 104223 - 2015-03-30 by CCC : LLC=0 for by-products
#   If [F:BOD]CPNTYP=4
#      [F:ITB]LLC       = 0
#   Else
#      [F:ITB]LLC       = 1
#   Endif
    [F:ITB]LLC = [F:SQLX]LLC

    Filter [BOH] Where BOMALT=[F:TBO]BOMALT
&                    & ITMREF=[F:SQLX]CPNITMREF
&                    & evalue (FLTBOM)
    If rowcount([BOH])>0
       [F:ITB]BOMEXIFLG = 2
    Else
       [F:ITB]BOMEXIFLG = 0
    Endif
    Filter [BOH]

    If REW=1
       [F:ITB]CREDAT    = date$
       [F:ITB]CREUSR    = GUSER
       [F:ITB]EXPNUM    = [C]EXPORT
       Write [ITB]
    Elsif GCLE<>num$([F:ITB]LLC)-num$([F:ITB]BOMEXIFLG)-num$([F:ITB]WUSEXIFLG)-[F:ITB]BOHITM
       Rewrite [ITB]
    Else
       fstat=0 : # nothing to do
    Endif
    If fstat
       GOK = 0 : Call RSTA("ITB",[F:SQLX]CPNITMREF-num$([F:TBO]BOMALT)-num$(WLLCTYP)) From GLOCK : Break
    Endif

    # here, LLC = 0 if the component is only used as byproduct, =1 else
    If [F:ITB]LLC = 1
        GBOHLLC = 1
        GNIV    = 0
        Call CALCLLC([F:SQLX]CPNITMREF,[F:TBO]BOMALT,[F:BOD]BOMALTTYP,"+") From LLCLIB
        If GOK = 0
            Break
        Endif
    Endif

    COMPTEUR += 1
    LNB += 1
    If COMPTEUR > GMAXUPDTRS
        Raz COMPTEUR
        Commit
    Endif
  Endif

Next
If LNB>0
    T1=time
    T=T1-T0
    H=int(T/3600)
    M=int((T-H*3600)/60)
    S=int(T-H*3600-M*60)
    T=LMAX*(T1-T0)/LNB
    JT=int(T/86400)
    HT=int((T-JT*86400)/3600)
    MT=int((T-JT*86400-HT*3600)/60)
    ST=int(T-JT*86400-HT*3600-MT*60)
    Call ECRTIME("lnb="+num$(LNB)-num$(H)+":"+num$(M)+":"+num$(S)+";"+num$(JT)+"j"+num$(HT)+"h"+num$(MT)+"m"+num$(ST)+"s")
Endif
If COMPTEUR>0
    Commit
Endif
If GOK<=0
    # Si c'est le 1er enreg qui a planté, compteur=0 il faut donc faire Rollback
    If adxlog=1 : Rollback : Endif
    Goto FIN_MAJ
Endif

Trbegin [ITB]
Delete [ITB] Where LLC=-1
Commit

# FQ 48487 GA 07/2008 déplacé en étiquette FIN
# Call FERME_BOITE From GESECRAN

#########################################################
$FIN_MAJ
If GOK = 0 | MAJ_OK = 0
    # tracer le problème sur ITB à partir des liens
    ERR_TRA = mess(13,100,1) - mess(192,197,1)-" (ITMBOM)"
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
    # alternative ... Transaction interronpue
    #ERR_TRA = mess(68,198,1) - num$([F:TBO]BOMALT) - mess(WLLCTYP,2224,1) + ":" - mess(14,100,1)
    ERR_TRA = mess(68,198,1) - num$([F:BOD]BOMALT) - mess([F:BOD]BOMALTTYP,224,1) + ":" - mess(14,100,1)
    Call ECR_TRACE(ERR_TRA,0) From GESECRAN
    Call TEMPON(ERR_TRA,"")
Else
    # alternative ... resynchronisation codes plus bas niveau
    ERR_TRA = mess(68,198,1) - num$([F:TBO]BOMALT) - mess(WLLCTYP,2224,1) + ":" - mess(142,195,1)
    Call ECR_TRACE(ERR_TRA,0) From GESECRAN
    Call TEMPON(ERR_TRA,"")
Endif

Return

#########################################################
$FIN
# débloquer
#If CTL_OK = 1
#    SYMBOLE = "SYNCLLC"
#    Unlock  =SYMBOLE
#Endif

# Issue 118201 GH 07/09/2016 - unlock tables if needed
If CTL_OK > 0
    SYMBOLE = "SYNCLLC"
    Unlock  =SYMBOLE
Endif
If CTL_OK > 1
    Unlock [BOH]
Endif
If CTL_OK > 2
    Unlock [BOD]
Endif
If CTL_OK > 3
    Unlock [ITB]
Endif
CTL_OK=0

# FQ 48487 GA 07/2008
Call TEMPOFF
Return

####################################################################
# sous-prog de resynchro appelable (pour 1 alternative) 25/01/01
Subprog SYNCLLC(ALT)
Value Integer ALT

Local Mask SYNCLLC0 [M:SYNC]
If ALT = 0 : [M]TOUTES = 2 : Else : [M]BOMALT = ALT : Endif
Gosub INIT
Gosub EXEC  # si la trace est déjà ouverte il faut faire autrement !
            # transaction !!
End

########################################
Subprog AM_TOUTES(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
    Grizo [M]LLCTYP
    Grizo [M]BOMALT
Else
    Actzo [M]LLCTYP
    Actzo [M]BOMALT
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran SYNCLLC0) 31/03/2006 10:36:37 (LLCX)
######################################################################################
Subprog C_BOMALT(VALEUR)
Variable Decimal VALEUR
Local Integer OK
If [M]TOUTES <> 2 & VALEUR = 0
    OK=2
    Call OUINON(mess(922,196,1)-mess([M]LLCTYP,2224,1),OK) From GESECRAN
    If OK <> 2 : mkstat = 2 : End : Endif
Endif
End


########################################
Subprog ECRTIME(PMES)
Value Char PMES
If dim(GTRACEDET)>0 & GTRACEDET=2
    # FQ 48487 GA 07/2008 Call ECRTIME(PMES)
    Call TEMPON([F:SQLX]CPNITMREF,PMES)
Endif
End

############################################################
Subprog TEMPON(LMSG1,LMSG2)
Value Char    LMSG1()
Value Char    LMSG2()

# FQ 48487 GA 07/2008 l'affichage de la fenetre clignote en V5
# Ouverture de la fenêtre au 1er passage
If clalev([M:VLC])<=0 # | GTEMPON <> 1
   Call OUVRE_VLC(mess(142,195,1),"","") From GESECRAN
   GTEMPON=1
Endif

Call AFF_VLC(LMSG1,LMSG2) From GESECRAN
End

############################################################
Subprog TEMPOFF

# FQ 48487 GA 07/2008 l'affichage de la fenetre clignote en V5
Call FERME_VLC From GESECRAN

End
