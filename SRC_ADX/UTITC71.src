#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTITC71   Delete wrong records in TABBOMALT                  Module TC #
#           (BOMALT=0 & BOMALTTYP=0)                                     #
##########################################################################
# Issue 116422 - 2016-05-20 by CCC : Wrong record delivered in SEED folder
##########################################################################
Local Char DOSSIER(30)

  [L]DOSSIER = nomap
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Deletion of wrong TABBOMALT record") From LECFIC
    Call MAJ_UTITC71([L]DOSSIER)
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC71(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR

  If func DOSVUE.ISVIEW(DOSSIER,"TABBOMALT") : End : Endif
  If filinfo(filpath("FIL","TABBOMALT","fde",DOSSIER),0)<=0 : End : Endif

  Call ECR_TRACE("UTITC71: Process Start on :" - DOSSIER,0) From GESECRAN

  Local File =DOSSIER + ".TABBOMALT" [TBO]
  # -----------------------------------------------------
  Trbegin [TBO]
  Delete [TBO] Where [F:TBO]BOMALT=0 | [F:TBO]BOMALTTYP=0
  COMPTEUR = adxdlrec
  Commit
  # -----------------------------------------------------
  Close Local File [TBO]
  Call ECR_TRACE("UTITC71 :" - num$(COMPTEUR) - "records deleted",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  Call MAJ_UTITC71(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  Call MAJ_UTITC71(APPLI)
End

