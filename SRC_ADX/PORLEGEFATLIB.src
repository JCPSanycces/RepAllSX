Gosub GET_INVSTA From SAFTGENPORSIH
Gosub GET_HASH_INFO From SAFTGENPORSIH

[L]EFAT_DATA_CREATED = SDSYSENTDA
[L]EFAT_DATA_ID = SDINVNUM
[L]EFAT_DATA_STATUS = SDINVSTA

Return
######################################################################################
Funprog REPLACE(TOREP, FINDSTR, REPLACETO)
Value Char TOREP
Value Char FINDSTR
Value Char REPLACETO

Local Char REPA(255)
Local Integer I

I = 0

For I=0 To len(TOREP)
   If FINDSTR = mid$(TOREP, I, len(FINDSTR)) Then
        TOREP = left$(TOREP, I-1) + REPLACETO + right$(TOREP, len(FINDSTR)+I)
        I = len(left$(TOREP, I-1))+len(REPLACETO)
   Endif
Next I
REPA = TOREP

End REPA
######################################################################################
Funprog USER_HASH(USER)
Value Char USER

Local Char HASH(GLONAUS) : HASH = USER

Call CRYPT(HASH) From GESUSER

End HASH
######################################################################################
Funprog CHECK_PORDKS(P_FCY)
Value Char P_FCY

Local Char RET(1)

RET = func AFNC.PARAM("PORDKS",P_FCY)

End RET
######################################################################################
Funprog CHECK_ACT_EFAT
Local Integer RET

RET = func AFNC.ACTIV("EFAT")

End RET
######################################################################################
$CHECK_EFAT_BPEI_ATEI

If !clalev([F:BPC]) : Local File BPCUSTOMER     [BPC] : Endif
If !clalev([F:CPY]) : Local File COMPANY        [CPY] : Endif

Local Integer EFAT_LINE

If [F:BPC]BPCNUM <> [F:SIH]BPR
  Read [F:BPC]BPC0 = [F:SIH]BPR
Endif
If fstat = 0
  If [F:BPC]ELECTINV = 2 & [F:SIH]ACCDAT >= [F:BPC]STRDATEFAT
    EFAT_BPEI_ACTIVE = 2
  Endif
Endif

If [F:CPY]CPY <> [F:SIH]CPY
  Read [F:CPY]CPY0 = [F:SIH]CPY
Endif
If fstat = 0
  For [L]EFAT_LINE = 0 To dim([F:CPY]COMMTYPE)-1
    If ([F:CPY]STRDAT([L]EFAT_LINE) <= [F:SIH]ACCDAT & [F:SIH]ACCDAT <= [F:CPY]ENDDAT([L]EFAT_LINE)) |
&      ([F:CPY]STRDAT([L]EFAT_LINE) <= [F:SIH]ACCDAT & [F:CPY]STRDAT([L]EFAT_LINE) <> [0/0/0] & [F:CPY]ENDDAT([L]EFAT_LINE) = [0/0/0])
      If [F:CPY]COMMTYPE([L]EFAT_LINE) = 2
        EFAT_ATEI_ACTIVE = 2 : Break
      Endif
    Endif
  Next
Endif

Return
###########################################################
# Impression de tous les documents créés (action TERMINE) #
# ------------------------------------------------------- #
# Paramètres E                                            #
#    IDOC        = Indice du document à traiter (1 à 9)   #
#    WARP_NUMREQ = Numéros des requêtes                   #
#    DESTINATION = Destination (nom de l'imprimante)      #
###########################################################
Subprog PRINT_ETAT(IDOC,WARP_NUMREQ,DESTINATION)
Value    Integer IDOC
Value    Integer WARP_NUMREQ(1..)
Value    Char    DESTINATION
#----- Déclaration des variables locales -----#
Local    Integer REQUETE : REQUETE=WARP_NUMREQ(max(IDOC,1))
Local    Char    TBPAR(15)(1..50)
Local    Char    TBVAL(30)(1..50)
Local    Char    WMSG(100)
#----- Déclaration variables globales -----#
Global   Integer GWNUMREQ
Global   Integer GWSEQREQ
Global   Libelle GWTRTAUTO
#----- Transmission du numéro de la requête suite au Call ETAT -----#
[V]GWNUMREQ =REQUETE
[V]GWTRTAUTO=1
#----- Impression par code document -----#
Filter [ARM] Where NUMREQ=REQUETE & USR=GUSER
Read [ARM] ARM2(4) First
#For [ARM] ARM2(4) Where NUMREQ=REQUETE & USR=GUSER
  [V]GWSEQREQ=[F:ARM]SEQREQ
  Call ETAT([F:ARM]RPTCOD,DESTINATION,"",1,"",TBPAR,TBVAL) From AIMP3
  #----- Impression dans la trace du no requête, séquence, opérateur et code état -----#
  If GTRACE<>""
    WMSG =mess(18,134,1)-"="-num$([V]GWNUMREQ)
    WMSG+=","-mess(215,188,1)-"="-num$([V]GWSEQREQ)
    WMSG+=","-mess(2,72,1)-"="-GUSER
    WMSG+=","-mess(36,135,1)-"="-[F:ARM]RPTCOD
    Call ECR_TRACE(WMSG,0) From GESECRAN
  Endif
#Next
#-----
Kill GWNUMREQ, GWSEQREQ, GWTRTAUTO
End

