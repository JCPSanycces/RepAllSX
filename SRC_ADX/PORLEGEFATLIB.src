## Comment section
##
## Issue 110700 - 2016-07-15 by RICAR : Electronic invoices: connect with Sage component
##
######################################################################################

######################################################################################
# Function that sends the document to EFAT. It sends everything that is necessary
# for the document
######################################################################################
Subprog SEND_INV_TO_EFAT(DOCNUM, IGNORE_BP, IGNORE_AT, STAT)
Value    Char    DOCNUM
Value    Integer IGNORE_AT
Value    Integer IGNORE_BP
Variable Integer STAT

STAT = 0

#-- Variables declaration
Gosub DECL_VARS
If dim(EFAT_DATA)<1      : Local Clbfile EFAT_DATA(8)      : Endif
If dim(EFAT_ARGUMENTS)<1 : Local Clbfile EFAT_ARGUMENTS(8) : Endif

#-- Tables declaration
Gosub OPEN_TABLES

#-- Opens trace
If GTRACE = ""
  Call OUVRE_TRACE(func AFNC.MES1(mess(216,7711,1), DOCNUM)) From LECFIC
  [L]PRIVTRACE = 1
Else
  Call ECR_TRACE(func AFNC.MES1(mess(216,7711,1), DOCNUM),0) From GESECRAN
Endif

#-- Sets values to all variables (includes the pdf and body generation)
Gosub SET_POST_VARS
If !OK : STAT = 1 : Gosub TRACE : End : Endif

#-- Validations before sending
Gosub CTR_VALS
If !OK : STAT = 1 : Gosub TRACE : End : Endif

#-- Sends to EFAT and updates the status in DKSDATA
Gosub SEND_TO_EFAT
If !OK : STAT = 1 : Gosub TRACE : End : Endif

Gosub TRACE

End
######################################################################################
# Function that updates the status of a document
######################################################################################
Subprog GET_INV_FROM_EFAT(DOCNUM, STAT)
Value    Char    DOCNUM
Variable Integer STAT

STAT = 0

#-- Variables declaration
Gosub DECL_VARS
If dim(EFAT_DATA)<1      : Local Clbfile EFAT_DATA(8)      : Endif
If dim(EFAT_ARGUMENTS)<1 : Local Clbfile EFAT_ARGUMENTS(8) : Endif

#-- Tables declaration
Gosub OPEN_TABLES

#-- Opens trace
If GTRACE = ""
  Call OUVRE_TRACE(func AFNC.MES1(mess(228,7711,1), DOCNUM)) From LECFIC
  [L]PRIVTRACE = 1
Else
  Call ECR_TRACE(func AFNC.MES1(mess(228,7711,1), DOCNUM),0) From GESECRAN
Endif

#-- Sets values to all variables  need to GET
Gosub SET_GET_VARS
If !OK : STAT = 1 : Gosub TRACE : End : Endif

#-- Validations before sending
# Get has no need of controls
#Gosub CTR_VALS
#If !OK : STAT = 1 : Gosub TRACE : End : Endif

#-- Updates the status in DKSDATA
Gosub GET_FROM_EFAT
If !OK : STAT = 1 : Gosub TRACE : End : Endif

Gosub TRACE

End
######################################################################################
######################################################################################
$DECL_VARS

#Issue 21158 – 2017-06-07  by VAVIL - Saft V4
Local Tinyint ISSAFTVERCURRENT : ISSAFTVERCURRENT = 1
#Issue end

Gosub COMMON_DECLARE From FUNSAFTEXT
Gosub COMMON_DECLARE From SAFTGENPOR

# Miscellaneous
Local Integer   WI, WI2
Local Shortint  PRIVTRACE
Local Integer   OK : OK = 1
Local Char      PDFFILE_PATH(255)
Local Integer   FILEDIM
Local Char      MESSAGE(255)
Local Char      CPY(GLONCPY)

#Line arrays for invoice lines
Local Integer   ARRAYDIM
ARRAYDIM = func AFNC.ACTIV("SIH")
Local Integer   INV_LINES                             #Invoice line counter
Local Integer   SUMMARY_LINES                         #Invoice summary counter

#Line information
Local Decimal   LDEBITAMOUNT(ARRAYDIM+50)               #+50 por causa das eventuais linhas adicionadas com elementos de faturação
Local Decimal   LCREDITAMOUNT(ARRAYDIM+50)              #+50 por causa das eventuais linhas adicionadas com elementos de faturação
Local Char      LTAXTYPE(10)(ARRAYDIM+50)               #+50 por causa das eventuais linhas adicionadas com elementos de faturação
Local Char      LTAXCOUNTRYREGION(GLONCRY)(ARRAYDIM+50) #+50 por causa das eventuais linhas adicionadas com elementos de faturação
Local Decimal   LTAXPERCENTAGE(ARRAYDIM+50)             #+50 por causa das eventuais linhas adicionadas com elementos de faturação
Local Char      LTAXEXEMPTIONREASON(255)(ARRAYDIM+50)   #+50 por causa das eventuais linhas adicionadas com elementos de faturação

#Previous, for the grouping
Local Char      PTAXTYPE(10)
Local Char      PTAXCOUNTRYREGION(GLONCRY)
Local Decimal   PTAXPERCENTAGE
Local Char      PTAXEXEMPTIONREASON(255)

###-----------   EFAT (begin)  -----------###
##--- type
Local Char    EFAT_TYPE(50)

##--- Data variables
#Local Clbfile EFAT_DATA(8) #TODO rever o tamanho se for para gerar pdf
Local Char    EFAT_DATA_FROM(GLONEEC)
Local Char    EFAT_DATA_ID(60)
Local Char    EFAT_DATA_DATE(30)
Local Char    EFAT_DATA_STATUS_DATE(50)
Local Char    EFAT_DATA_CREATED(30)
Local Char    EFAT_DATA_TO_CUSTOMER(GLONEEC)
Local Char    EFAT_DATA_CUSTOMER_IS_INTERNATIONAL(5)
Local Char    EFAT_DATA_COMPANY_NAME(150)
Local Char    EFAT_DATA_TYPE(30)
Local Char    EFAT_DATA_STATUS(5)
Local Char    EFAT_DATA_AMOUNT(30)
Local Char    EFAT_DATA_TAX_AMOUNT(30)
Local Char    EFAT_DATA_GROSS_AMOUNT(30)
Local Char    EFAT_DATA_EMAIL_TO(255)
#Array of 30 since this is the line values grouped by tax
Local Decimal EFAT_DATA_SUM_DEBITAMOUNT(30)
Local Decimal EFAT_DATA_SUM_CREDITAMOUNT(30)
Local Decimal EFAT_DATA_SUM_AMOUNT(30)
Local Char    EFAT_DATA_SUM_TX_COUNTRY(GLONCRY)(30)
Local Char    EFAT_DATA_SUM_TX_CODE(10)(30)
Local Decimal EFAT_DATA_SUM_TX_TAX(30)
Local Char    EFAT_DATA_SUM_TX_TAX_E(255)(30)

##--- Context variables
Local Clbfile EFAT_CTX(0)
Local Char    EFAT_CTX_APP(30)
Local Char    EFAT_CTX_APPVERSION(10)
Local Char    EFAT_CTX_LICENSE(30)
Local Char    EFAT_CTX_USER(30)
Local Char    EFAT_CTX_WSUSER(20)
Local Char    EFAT_CTX_WSPASS(20)
Local Char    EFAT_CTX_WSTEST(5)
Local Integer EFAT_CTX_WSDELAY #: EFAT_CTX_WSDELAY = 5 #TODO retirar
Local Char    EFAT_CTX_EMAIL_FROM(100)
Local Char    EFAT_CTX_ATSERVICE(5)
Local Char    EFAT_CTX_SIGNSERVICE(5)
Local Char    EFAT_CTX_MAILSERVICE(5)

##--- Option variables
Local Clbfile EFAT_OPT(0)
Local Char    EFAT_OPT_EFATCLBACK(5)
Local Char    EFAT_OPT_DEBUGMODE(5)
Local Integer EFAT_OPT_EXPECT_CB
Local Char    EFAT_OPT_CALLBACK_URL(255)

##--- EFAT response
Local Char EFAT_RESP_STATUS(2)
Local Char EFAT_RESP_CREATED(50)
Local Char EFAT_RESP_CODE(10)
Local Char EFAT_RESP_MESSAGE(255)
Local Char EFAT_RESP_SOURCE(50)
Local Char EFAT_RESP_PRIVATE_URL(255)
Local Char EFAT_RESP_SENT(50)
Local Char EFAT_RESP_EXPIRES(50)
Local Char EFAT_RESP_ACCESS(50)
Local Char EFAT_RESP_ACCESS_IP(100)

#bundle-sage-pt-efat
Local Integer EFAT_STATUSCODE
Local Char    EFAT_MODULE(100)  : EFAT_MODULE = 'bundle-sage-pt-efat/efatCommunication'
Local Char    EFAT_FONCTION(30) : EFAT_FONCTION = 'send'
Local Char    EFAT_MODE(10)     : EFAT_MODE = 'wait'
#Local Clbfile EFAT_ARGUMENTS(8) #TODO verificar tamanho na impressão
Local Char    EFAT_RETURNS(255)
Local Clbfile EFAT_RESHEAD(0)
Local Clbfile EFAT_RESBODY(0)
Local Char    EFAT_URLTAXID(GLONEEC)
Local Clbfile EFAT_PAR(0)

#EFAT DKSDATA Status
Local Shortint EFAT_AT_STAT
Local Shortint EFAT_BPC_STAT
###-----------   EFAT (end)  -----------###

# SAF-T * Invoice variables
Gosub DECLARE_VARS_INVOICE From SAFTGENPOR

Return
######################################################################################
######################################################################################
$OPEN_TABLES

If !clalev([F:AUS]) : Local File AUTILIS    [AUS] : Endif
If !clalev([F:BPA]) : Local File BPADDRESS  [BPA] : Endif
If !clalev([F:BPR]) : Local File BPARTNER   [BPR] : Endif
If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
#If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
If !clalev([F:CNT]) : Local File CONTACT    [CNT] : Endif
If !clalev([F:GCM]) : Local File GACM       [GCM] : Endif  #Modelos contabilisticos
If !clalev([F:LED]) : Local File GLED       [LED] : Endif  #LEDGERS
If !clalev([F:SIH]) : Local File SINVOICE   [SIH] : Endif  #Para a impressão
If !clalev([F:SIV]) : Local File SINVOICEV  [SIV] : Endif  #Para a impressão
If !clalev([F:TPM]) : Local File TABPRTMOD  [TPM] : Endif
If !clalev([F:TVT]) : Local File TABVAT     [TVT] : Endif

# SAF-T * Invoice Tables
Gosub DECLARE_TABS_INVOICE From SAFTGENPOR

Return
######################################################################################
$SET_POST_VARS

Gosub VARS_COMMON

#---- EFAT_OPT ----#
Call PARAM([F:CPY]CPY, "EFATCLBACK", [L]EFAT_OPT_EFATCLBACK) From ADOVAL
If EFAT_OPT_EFATCLBACK = "2"
  EFAT_OPT_EFATCLBACK ="1"
Else
  EFAT_OPT_EFATCLBACK = "0"
Endif

Call PARAM([F:CPY]CPY, "EFATCLBURL", [L]EFAT_OPT_CALLBACK_URL) From ADOVAL

#---- EFAT_CTX ----#
#APP
EFAT_CTX_APP = "SAGE X3"

#Version
EFAT_CTX_APPVERSION = GVERSION
If left$(EFAT_CTX_APPVERSION,2) = "1."
  EFAT_CTX_APPVERSION = right$(EFAT_CTX_APPVERSION,3)
Endif

# License
EFAT_CTX_LICENSE = fmet GACTX.AGETLIC_SERIAL("1")

# User (encripted)
EFAT_CTX_USER    = func USER_HASH(GUSER)

# Test mode sent (AT)
Call PARAM([F:CPY]CPY, "EFATTSTMOD", [L]EFAT_CTX_WSTEST) From ADOVAL
If [L]EFAT_CTX_WSTEST = "2" : EFAT_CTX_WSTEST = "true" : Else : EFAT_CTX_WSTEST = "false" : Endif

# Company's E-mail
Filter [F:BPA] Where [F:BPA]BPATYP = 2 & [F:BPA]BPANUM = [F:CPY]CPY & [F:BPA]BPAADDFLG =2
Read [F:BPA] First
If !fstat
  If [F:BPA]WEB <> "" : EFAT_CTX_EMAIL_FROM = [F:BPA]WEB : Else : EFAT_CTX_EMAIL_FROM =[F:BPA]WEB(1) : Endif
Endif
If EFAT_CTX_EMAIL_FROM = "" : OK = 0 : Call ECR_TRACE(func AFNC.MES1(mess(217,7711,1),[F:CPY]CPY), 1) From GESECRAN : Return : Endif
Filter [F:BPA]

# Send to AT (Yes/No)
EFAT_CTX_ATSERVICE = "false"

If IGNORE_AT <> 1
  For [L]WI = 0 To dim([F:CPY]COMMTYPE)-1
    If ([F:CPY]STRDAT([L]WI) <= [F:SIH]ACCDAT & [F:SIH]ACCDAT <= [F:CPY]ENDDAT([L]WI)) |
&      ([F:CPY]STRDAT([L]WI) <= [F:SIH]ACCDAT & [F:CPY]STRDAT([L]WI) <> [0/0/0] & [F:CPY]ENDDAT([L]WI) = [0/0/0])
      If [F:CPY]COMMTYPE([L]WI) = 2
        EFAT_CTX_ATSERVICE = "true" : Break
      Endif
    Endif
  Next
Endif

If EFAT_CTX_ATSERVICE = "true"
  Call PARAM([F:CPY]CPY, "EFATINVUSR", EFAT_CTX_WSUSER) From ADOVAL
  If EFAT_CTX_WSUSER = ""
    OK = 0 : Call ECR_TRACE(mess(111,7711,1), 1) From GESECRAN : Return
  Endif

  Read [F:AUS]CODUSR = EFAT_CTX_WSUSER
  If fstat : Raz [F:AUS] : Endif

  Call GETSEC([F:AUS]NEWPAS, [L]EFAT_CTX_WSPASS) From PORLEGLIB1

  [L]EFAT_CTX_WSUSER    = [L]EFAT_URLTAXID + "/" + [L]EFAT_CTX_WSUSER
Endif

# Uses Electronic Invoice service (Yes/No)
EFAT_CTX_MAILSERVICE  = "false"
If IGNORE_BP <> 1
  If [F:BPC]BPCNUM <> [F:SIH]BPR
    Read[F:BPC]BPC0 = [F:SIH]BPR
  Endif
  If [F:BPC]ELECTINV = 2 & [F:SIH]ACCDAT >= [F:BPC]STRDATEFAT
    EFAT_CTX_MAILSERVICE  = "true"
  Endif
Endif

# If it uses the Electronic Invoice service, definitely uses digital signature PDF
EFAT_CTX_SIGNSERVICE  =  EFAT_CTX_MAILSERVICE

# If it uses the Electronic Invoice service, check the send e-mail
If EFAT_CTX_MAILSERVICE = 'true'
  Read [F:CNT]CNT0 = 1;[F:SIH]BPR;[F:BPC]CNTEFAT
  If !fstat
    EFAT_DATA_EMAIL_TO = [F:CNT]WEB
  Endif
  If EFAT_DATA_EMAIL_TO  = ""  : OK = 0  : Call ECR_TRACE(mess(230,7711,1), 1) From GESECRAN :  Return : Endif
Endif
GPOINT ="TOEMAIL" : Gosub ENTREE From EXEFNC

#----------------------------------------------------#
# SAF-T variables - Begin
#----------------------------------------------------#
[L]SAFTWAY   = 0
[L]INV_LINES = 0
[L]LEDT      = 0

[L]SOC       = [L]CPY
[L]COMMENT   = ""
[L]STRDATE   = [F:SIH]ACCDAT
[L]ENDDATE   = [F:SIH]ACCDAT
[L]FILEPATH  = ""
[L]SAFTTYPE  = 0
[L]FILDESTYP = 0
[L]LEG       = [F:CPY]LEG
[L]EVRDOCTYP = 0
[L]DOCTYP    = 0
[L]PIHBPS    = ""
[L]FICHIER   = ""
[L]EFATACTIV = 2

Gosub COMMON_DECLARE             From SAFTGENPOR
Gosub COMMON_VALUES_AND_CONTROLS From SAFTGENPOR
Gosub LOAD_COMMON_VALUES         From SAFTGENPOR

Gosub FEED_VARS From SAFTGENPORSIH

#---- EFAT_DATA ----#
[L]EFAT_DATA_COMPANY_NAME = vireblc([F:SIH]BPRNAM(0) + [F:SIH]BPRNAM(1), 2)
If vireblc([L]EFAT_DATA_COMPANY_NAME,2)=""
  [L]EFAT_DATA_COMPANY_NAME = [F:BPC]BPCNAM
Endif

# International customer
If [F:BPR]BPRNUM <> [F:BPC]BPCNUM
  Read [F:BPR]BPR0 = [F:BPC]BPCNUM
Endif
EFAT_DATA_CUSTOMER_IS_INTERNATIONAL = "false"
If [F:BPR]CRY <> "PT"
  EFAT_DATA_CUSTOMER_IS_INTERNATIONAL = "true"
Endif

EFAT_DATA_TO_CUSTOMER = [F:BPR]EECNUM
If left$(EFAT_DATA_TO_CUSTOMER,2) = "PT" & EFAT_DATA_CUSTOMER_IS_INTERNATIONAL <> "true"
  EFAT_DATA_TO_CUSTOMER = right$([F:BPR]EECNUM,3)
Endif

EFAT_DATA_FROM = EFAT_URLTAXID
EFAT_DATA_ID = SDINVNUM
EFAT_DATA_DATE = SDINVDAT
EFAT_DATA_STATUS_DATE = SDSYSENTDA
EFAT_DATA_CREATED = SDSYSENTDA
EFAT_DATA_TYPE = [L]SDINVTYP
EFAT_DATA_STATUS = [L]SDINVSTA
EFAT_DATA_AMOUNT = ctrans(vireblc(format$("N20.2",[L]SDNETTOTA),4),",",".")
EFAT_DATA_TAX_AMOUNT = ctrans(vireblc(format$("N20.2",[L]SDTAXPAYA),4),",",".")
EFAT_DATA_GROSS_AMOUNT = ctrans(vireblc(format$("N20.2",[L]SDGROTOTA),4),",",".")

#----------------------------------------------------#
# SAF-T variables - End
#----------------------------------------------------#

#-- Group the Invoice line amount by VAT Tax
Gosub SET_INVOICE_SUMMARIES

#----------------------------------------------------#
# If necessary, generate PDF and read it
#----------------------------------------------------#
If EFAT_CTX_MAILSERVICE = 'true'
  Gosub GENERATE_PDF
  If !OK : STAT = 1 : Gosub TRACE : End : Endif
Endif
#If not declared on pdf generation (with the right dimension) declare here
If dim(EFAT_DATA)<1      : Local Clbfile EFAT_DATA(8)      : Endif
If dim(EFAT_ARGUMENTS)<1 : Local Clbfile EFAT_ARGUMENTS(8) : Endif

Return
######################################################################################
######################################################################################
$FEED_VAR_WS

#-- alimenta as variáveis referentes a uma linha de fatura. Chamado pelo tratamento do SAF-T
[L]INV_LINES += 1

If [L]SDLDEBAMO<>0 | ([L]SDVATDOC=1 & find([F:SIH]INVTYP,2,4))
  LDEBITAMOUNT(INV_LINES-1)  = SDLDEBAMO
Elsif [L]SDLCREAMO<>0 | ([L]SDVATDOC=1 & find([F:SIH]INVTYP,1,3))
  LCREDITAMOUNT(INV_LINES-1) = SDLCREAMO
Endif

LTAXTYPE(INV_LINES-1)            = SDLTAXTYP
LTAXCOUNTRYREGION(INV_LINES-1)   = SDLTACORE
LTAXPERCENTAGE(INV_LINES-1)      = SDLTAXPER

If SDLTAEXRE <> ""
  Call LEC_TVT_LEG('POR',[L]SDLLINTAX,WI) From TRTLECLEG
  LTAXEXEMPTIONREASON(INV_LINES-1) = [F:TVT]POREXEMOT
Endif

Return
######################################################################################
######################################################################################
$SET_INVOICE_SUMMARIES

#-- Group values by tax
Sorta LTAXTYPE, LTAXCOUNTRYREGION, LTAXPERCENTAGE, LTAXEXEMPTIONREASON, LDEBITAMOUNT, LCREDITAMOUNT
& Order By LTAXTYPE, LTAXCOUNTRYREGION, LTAXPERCENTAGE, LTAXEXEMPTIONREASON

WI  = 1
SUMMARY_LINES = 0

While WI <= INV_LINES

  EFAT_DATA_SUM_DEBITAMOUNT(SUMMARY_LINES)  += LDEBITAMOUNT(WI-1)
  EFAT_DATA_SUM_CREDITAMOUNT(SUMMARY_LINES) += LCREDITAMOUNT(WI-1)

  If ((LTAXTYPE(WI-1) <> PTAXTYPE | LTAXCOUNTRYREGION(WI-1) <> PTAXCOUNTRYREGION
&  | LTAXPERCENTAGE(WI-1) <> PTAXPERCENTAGE) | LTAXEXEMPTIONREASON(WI-1) <> PTAXEXEMPTIONREASON) & PTAXTYPE <> ""

    Gosub SET_INVOICE_SUMMARY_LINE

  Endif

  PTAXTYPE = LTAXTYPE(WI-1)
  PTAXCOUNTRYREGION = LTAXCOUNTRYREGION(WI-1)
  PTAXPERCENTAGE = LTAXPERCENTAGE(WI-1)
  PTAXEXEMPTIONREASON = LTAXEXEMPTIONREASON(WI-1)


  WI += 1
Wend

Gosub SET_INVOICE_SUMMARY_LINE

Return
######################################################################################
######################################################################################
$SET_INVOICE_SUMMARY_LINE

If PTAXTYPE <> "" | PTAXCOUNTRYREGION <> "" | PTAXPERCENTAGE <> 0 | PTAXEXEMPTIONREASON <> ""

  If EFAT_DATA_SUM_DEBITAMOUNT > EFAT_DATA_SUM_CREDITAMOUNT
    EFAT_DATA_SUM_AMOUNT(SUMMARY_LINES) = EFAT_DATA_SUM_DEBITAMOUNT - EFAT_DATA_SUM_CREDITAMOUNT
  Else
    EFAT_DATA_SUM_AMOUNT(SUMMARY_LINES) = EFAT_DATA_SUM_CREDITAMOUNT - EFAT_DATA_SUM_DEBITAMOUNT
  Endif
  EFAT_DATA_SUM_TX_TAX(SUMMARY_LINES) = PTAXPERCENTAGE
  EFAT_DATA_SUM_TX_COUNTRY(SUMMARY_LINES) = PTAXCOUNTRYREGION
  EFAT_DATA_SUM_TX_CODE(SUMMARY_LINES) = PTAXTYPE
  EFAT_DATA_SUM_TX_TAX_E(SUMMARY_LINES) = PTAXEXEMPTIONREASON

  SUMMARY_LINES += 1

Endif

EFAT_DATA_SUM_PDEBITAMOUNT = 0
EFAT_DATA_SUM_PCREDITAMOUNT = 0

Return
######################################################################################
$GENERATE_PDF

Gosub INIT_ETAT From TRTX3ETA

WARP_RPTCOD = ""
Raz [F:TPM]
If [F:TPM]TPMCOD <> [F:BPC]TPMCOD
  Read [F:TPM]TPM0 = [F:BPC]TPMCOD
Endif
Case [F:SIH]ORIMOD
  When 5
    Case [F:SIH]INVTYP
      When 2, 4
        WARP_RPTCOD = [F:TPM]SALCRE
      When 1, 3
        WARP_RPTCOD = [F:TPM]SALINV
    Endcase
  When 3
    Case [F:SIH]INVTYP
      When 2, 4
        WARP_RPTCOD = [F:TPM]TRSNCEFAT
      When 1, 3
        WARP_RPTCOD = [F:TPM]TRSEFAT
    Endcase
Endcase

If WARP_RPTCOD = ""
  OK = 0
  Case [F:SIH]ORIMOD
    When 5 # Vendas
      Case [F:SIH]INVTYP
        When 2, 4 #Nota de crédito
          Call ECR_TRACE(func AFNC.MES1(mess(213,7711,1),""),0) From GESECRAN
        When 1, 3 #Factura e Nota de débito
          Call ECR_TRACE(func AFNC.MES1(mess(210,7711,1),""),0) From GESECRAN
      Endcase
    When 3 #Terceiros
      Case [F:SIH]INVTYP
        When 2, 4 # N/Credito e Credito Memo
          Call ECR_TRACE(func AFNC.MES1(mess(211,7711,1),""),0) From GESECRAN
        When 1, 3 #Factura e Nota de débito
          Call ECR_TRACE(func AFNC.MES1(mess(212,7711,1),""),0) From GESECRAN
      Endcase
  Endcase
  Return
Endif

#Printing destination
Call PARAM([F:CPY]CPY, "EFATPRT", [L]WARP_PRT) From ADOVAL
If WARP_PRT = ""
  OK = 0
  Call ECR_TRACE(mess(223,7711,1), 0) From GESECRAN
  Return
Endif

Global Char EFAT_FILE(255)

Call ALIM_ETAT(1,WARP_NBRCPY,WARP_RPTCOD,WARP_NUMREQ,WARP_NUMLIG,WARP_SEQREQ) From TRTX3ETA

Call PRINT_ETAT (1,WARP_NUMREQ,WARP_PRT) #From TRTX3ETA

PDFFILE_PATH = EFAT_FILE
Kill EFAT_FILE

WI  = 0
WI2 = 10
# Verificar se o ficheiro existe
While filinfo(PDFFILE_PATH,7) <= 0
    # Esperar 1 segundo antes da próxima verificação
    Sleep 1
    # Incrementar contador de verificação
    WI + = 1
    # Ficheiro inexistente
    If WI >= WI2
        # Fim de ciclo
        Break
    Endif
Wend

[L]FILEDIM  = filinfo(PDFFILE_PATH,7)

If [L]FILEDIM <= 0
  OK = 0
  Call ECR_TRACE(mess(215,7711,1), 1) From GESECRAN
  Return
Endif

#----------------------------------------------------#
# Read the report file into a blob
#----------------------------------------------------#
WI2 = 0
While [L]FILEDIM > 1024*(2^[L]WI2)-4
  [L]WI2+= 1
Wend
Local Blbfile PDFFIL([L]WI2)
Openi  [L]PDFFILE_PATH       Using [CFIL]
Getseq [L]FILEDIM, [L]PDFFIL Using [CFIL]
Openi                        Using [CFIL]

#----------------------------------------------------#
# Convert to base64
#----------------------------------------------------#
[L]WI  = arr([L]FILEDIM*(4/3),4)
If [L]WI < [L]FILEDIM*(4/3) : [L]WI += 4 : Endif
WI2 = 0
While [L]WI > 512*(2^[L]WI2)-2
  [L]WI2+= 1
Wend
Local Clbfile PDFFIL64([L]WI2)
[L]WI  = b64Encode(PDFFIL,PDFFIL64)

Local Clbfile EFAT_DATA([L]WI2+2)
Local Clbfile EFAT_ARGUMENTS([L]WI2+2)

Call EFFACE(PDFFILE_PATH,WI) From ORDSYS

Return
######################################################################################
######################################################################################
$SET_EFAT_POST_CTX_OBJ

# Format context to JSON object
Local Char PROP01(255) : PROP01 = "Y39+FggdHwxJNyBhHBw+DSknFThXKyoaZwY9DUIgOF5Y"
#Local Char PROP01(255) : PROP01 = "Ynl+FggdHwxJNCEdeR0BJyk7OyxQKwQJERkDCUc=" #PREPROD
PROP01 = num$(len(PROP01))+"-"+PROP01
Local Char PROP01_DATA(255) : PROP01_DATA = EFAT_DATA_ID+EFAT_DATA_CREATED
PROP01 = func DKSLIB.BYTOP(PROP01,PROP01_DATA, 0)

Local Char PROP02(255) : PROP02 = EFAT_CTX_WSPASS
PROP02 = num$(len(PROP02))+"-"+PROP02
Local Char PROP02_DATA(255) : PROP02_DATA = EFAT_DATA_CREATED+EFAT_DATA_ID
PROP02 = func DKSLIB.BYTOP(PROP02,PROP02_DATA, 0)
PROP02 = num$(len(PROP02))+"-"+PROP02
PROP02 = func DKSLIB.BYTOP(PROP02,PROP01, 0)

EFAT_CTX = '{'
Append EFAT_CTX, '"App": "'         + EFAT_CTX_APP + '",'
Append EFAT_CTX, '"AppVersion": "'  + EFAT_CTX_APPVERSION + '",'
Append EFAT_CTX, '"License": "'     + EFAT_CTX_LICENSE + '",'
Append EFAT_CTX, '"User": "'        + EFAT_CTX_USER + '",'
Append EFAT_CTX, '"WSUser": "'      + EFAT_CTX_WSUSER + '",'
Append EFAT_CTX, '"WSTest": "'      + EFAT_CTX_WSTEST + '",'
Append EFAT_CTX, '"WSDelay": "'     + num$(EFAT_CTX_WSDELAY) + '",'
Append EFAT_CTX, '"EMail": "'       + EFAT_CTX_EMAIL_FROM + '",'
Append EFAT_CTX, '"ATService": "'   + EFAT_CTX_ATSERVICE + '",'
Append EFAT_CTX, '"SIGNService": "' + EFAT_CTX_SIGNSERVICE + '",'
Append EFAT_CTX, '"MAILService": "' + EFAT_CTX_MAILSERVICE + '",'
Append EFAT_CTX, '"prop01" : "'     + PROP01 + '",'
Append EFAT_CTX, '"prop02" : "'     + PROP02 + '"'
Append EFAT_CTX, '}'

Return
######################################################################################
######################################################################################
$SET_EFAT_GET_CTX_OBJ

# Format context to JSON object
Local Char PROP01(255) : PROP01 = "dHV5Kw8FBgpDMRpAJioYHQAULjhaOBU8VzcLEkEqI0R6"
#Local Char PROP01(255) : PROP01 = "dXN5Kw8FBgpDMhs8QysnNwAIACxdODsvISg1FkQ=" #PREPROD
PROP01 = num$(len(PROP01))+"-"+PROP01
Local Char PROP01_DATA(255) : PROP01_DATA = EFAT_DATA_ID+EFAT_DATA_CREATED
PROP01 = func DKSLIB.BYTOP(PROP01,PROP01_DATA, 0)

# Format CONTEXT to JSON object
EFAT_CTX = '{'
Append EFAT_CTX, '"prop01" : "' + PROP01 + '"'
Append EFAT_CTX, '}'

Return
######################################################################################
######################################################################################
$SET_EFAT_DATA_OBJ

EFAT_DATA = '{'
Append EFAT_DATA, '"From": "'        + [L]EFAT_DATA_FROM    + '",'
Append EFAT_DATA, '"Id": "'          + [L]EFAT_DATA_ID          + '",'
Append EFAT_DATA, '"Date": "'        + [L]EFAT_DATA_DATE + '",'
Append EFAT_DATA, '"StatusDate": "'  + [L]EFAT_DATA_STATUS_DATE          + '",'
Append EFAT_DATA, '"Created": "'     + [L]EFAT_DATA_CREATED          + '",'
Append EFAT_DATA, '"ToCustomer": "'  + [L]EFAT_DATA_TO_CUSTOMER          + '",'
Append EFAT_DATA, '"CustomerIsInternational": "' + [L]EFAT_DATA_CUSTOMER_IS_INTERNATIONAL + '",'
Append EFAT_DATA, '"CompanyName": "' + [L]EFAT_DATA_COMPANY_NAME          + '",'
Append EFAT_DATA, '"Type": "'        + [L]EFAT_DATA_TYPE          + '",'
Append EFAT_DATA, '"Status": "'      + [L]EFAT_DATA_STATUS          + '",'
Append EFAT_DATA, '"Amount": "'      + EFAT_DATA_AMOUNT +'",'
Append EFAT_DATA, '"TaxAmount": "'   + EFAT_DATA_TAX_AMOUNT +'",'
Append EFAT_DATA, '"GrossAmount": "' + EFAT_DATA_GROSS_AMOUNT +'",'
Append EFAT_DATA, '"Summaries": {'
Append EFAT_DATA, '"InvoiceSummary": ['
SEP  = ''
For WI = 0 To SUMMARY_LINES - 1
  Append EFAT_DATA, SEP+'{'
  Append EFAT_DATA, '"Amount": "'  + num$(EFAT_DATA_SUM_AMOUNT(WI))        +'",'
  Append EFAT_DATA, '"TaxCode": {'
  Append EFAT_DATA, '"Country": "' + EFAT_DATA_SUM_TX_COUNTRY(WI)        +'",'
  Append EFAT_DATA, '"Code": "' + EFAT_DATA_SUM_TX_CODE(WI)        +'",'
  Append EFAT_DATA, '"Tax": "' + num$(EFAT_DATA_SUM_TX_TAX(WI))        +'"'
  If EFAT_DATA_SUM_TX_TAX_E(WI) <> ""
    Append EFAT_DATA, '"TaxE": "' + EFAT_DATA_SUM_TX_TAX_E(WI)        +'"'
  Endif
  Append EFAT_DATA, '}'
  Append EFAT_DATA, '}'
  SEP = ','
Next I
Append EFAT_DATA, ']'
Append EFAT_DATA, '}'

#Pdf
If EFAT_CTX_MAILSERVICE = 'true'
  Append EFAT_DATA, ","
  Append EFAT_DATA, '"UserDocument": {'
  Append EFAT_DATA, '"Data": "'+ PDFFIL64 +'",'
  Append EFAT_DATA, '"ToEMail": "'+EFAT_DATA_EMAIL_TO+'"'
  Append EFAT_DATA, '  }'
Endif

Append   EFAT_DATA, '}'

Return
######################################################################################
######################################################################################
$SET_EFAT_OPT_OBJ

EFAT_OPT_DEBUG="true"
If EFAT_OPT_EFATCLBACK = "" : EFAT_OPT_EFATCLBACK = "0" : Endif

EFAT_OPT = '{'
Append EFAT_OPT, '"debugMode": "' + EFAT_OPT_DEBUG + '",'
Append EFAT_OPT, '"expectCallback": ' + EFAT_OPT_EFATCLBACK

If vireblc(EFAT_OPT_CALLBACK_URL, 4) <> ""
  Append EFAT_OPT, ', "callBackURL": "' + EFAT_OPT_CALLBACK_URL + '"'
Endif
Append EFAT_OPT, '}'

Return
######################################################################################
######################################################################################
$SET_EFAT_PAR_OBJ

EFAT_PAR = '{'
Append EFAT_PAR, '"created": "'+[L]EFAT_DATA_CREATED+'",'
Append EFAT_PAR, '"id":"'+func REPLACE([L]EFAT_DATA_ID, " ", "%20")+'",'
Append EFAT_PAR, '"status":"'+[L]EFAT_DATA_STATUS+'"'
Append EFAT_PAR, '}'

Return
######################################################################################
######################################################################################
$CTR_VALS

#o documentos tem de estar validado
If [F:SIH]STA <> 3 :  OK = 0 : Call ECR_TRACE(func AFNC.MES1(mess(227,7711,1), DOCNUM),1) From GESECRAN  :  Return : Endif
#TODO Só envia os com erro ou não enviados (status >0 e < 5)
If EFAT_CTX_MAILSERVICE = 'false' & EFAT_CTX_ATSERVICE = 'false'
  OK = 0 : Call ECR_TRACE(mess(219,7711,1),0) From GESECRAN  :  Return
Endif

Return
######################################################################################
$SEND_TO_EFAT

# request type
EFAT_TYPE = "invoice"

Gosub SET_EFAT_POST_CTX_OBJ
Gosub SET_EFAT_DATA_OBJ
Gosub SET_EFAT_OPT_OBJ

EFAT_ARGUMENTS = '"Sage-EFAT", "POST", "Invoice/'+EFAT_URLTAXID+'/Invoice",{},{},' + EFAT_CTX + ',' + EFAT_DATA + ', "'+EFAT_TYPE+'",' + EFAT_OPT
#EFAT_ARGUMENTS = '"Sage-EFAT-PREPROD", "POST", "Invoice/'+EFAT_URLTAXID+'/Invoice",{},{},' + EFAT_CTX + ',' + EFAT_DATA + ', "'+EFAT_TYPE+'",' + EFAT_OPT #PRE

# Call 'send' function
EFAT_STATUSCODE   = func ASYRWEBSER.EXEC_JS(EFAT_MODULE, EFAT_FONCTION, EFAT_MODE, EFAT_ARGUMENTS, '', 0, EFAT_RETURNS, '0', EFAT_RESHEAD, EFAT_RESBODY)

If (200 <= EFAT_STATUSCODE & EFAT_STATUSCODE <= 299)
  If EFAT_STATUSCODE = 201 #Only ATService. We have no body just the header
    EFAT_RESP_CODE        = num$(EFAT_STATUSCODE)
    EFAT_RESP_MESSAGE     = func AJSONLIB.GET_PROP(EFAT_RESHEAD,"message")
  Else
    EFAT_RESP_STATUS      = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Status")
    EFAT_RESP_CREATED     = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Created")
    EFAT_RESP_CODE        = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Code")
    EFAT_RESP_MESSAGE     = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Message")
    EFAT_RESP_SOURCE      = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Source")
    EFAT_RESP_URL         = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Url")
    EFAT_RESP_PRIVATE_URL = func AJSONLIB.GET_PROP(EFAT_RESBODY,"PrivateUrl")
    EFAT_RESP_SENT        = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Sent")
    EFAT_RESP_EXPIRES     = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Expires")
    EFAT_RESP_ACCESS      = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Access")
    EFAT_RESP_ACCESS_IP   = func AJSONLIB.GET_PROP(EFAT_RESBODY,"AccessIP")
  Endif

  Gosub SET_EFAT_GET_CTX_OBJ
  Gosub SET_EFAT_PAR_OBJ
  Gosub REST_GET_EFAT_CALL

Elsif EFAT_STATUSCODE >= 300
  EFAT_RESP_CODE        = num$(EFAT_STATUSCODE)
  EFAT_RESP_MESSAGE     = func AJSONLIB.GET_PROP(EFAT_RESHEAD,"message")
Else
  EFAT_RESP_CODE        = num$(EFAT_STATUSCODE)
  EFAT_RESP_MESSAGE     = EFAT_RESHEAD
Endif

Call SET_INV_STA(EFAT_AT_STAT,EFAT_BPC_STAT,EFAT_STATUSCODE,EFAT_RESP_CODE,EFAT_RESP_MESSAGE,EFAT_RESP_SOURCE,EFAT_RESP_SENT,EFAT_RESP_ACCESS)

Call UPDATE_DKSDATA([F:SIH]NUM,[F:SIH]SIVTYP,EFAT_AT_STAT,EFAT_BPC_STAT,EFAT_RESP_CODE,EFAT_RESP_MESSAGE,EFAT_RESP_EXPIRES,EFAT_RESP_PRIVATE_URL,EFAT_RESP_SENT,EFAT_RESP_ACCESS,EFAT_RESP_ACCESS_IP)

Return
######################################################################################
######################################################################################
Subprog SET_INV_STA(EFAT_AT_STAT,EFAT_BPC_STAT,EFAT_STATUSCODE,EFAT_RESP_CODE,EFAT_RESP_MESSAGE,EFAT_RESP_SOURCE,EFAT_RESP_SENT,EFAT_RESP_ACCESS)
Variable Shortint EFAT_AT_STAT
Variable Shortint EFAT_BPC_STAT
Value    Integer  EFAT_STATUSCODE
Value    Char     EFAT_RESP_CODE
Value    Char     EFAT_RESP_MESSAGE
Value    Char     EFAT_RESP_SOURCE
Value    Char     EFAT_RESP_SENT
Value    Char     EFAT_RESP_ACCESS

EFAT_AT_STAT  = 0
EFAT_BPC_STAT = 0

#Todo, falta o sign service (normalmente quando é feito o post, retorna o sign e mess = em processamento central)
#O ATService responde com processado mesmo que não o tenhamos pedido (1000)
If (200 <= EFAT_STATUSCODE & EFAT_STATUSCODE <= 299)
  #--- ATINVSTAT
  If EFAT_RESP_SOURCE = "ATService"
    If EFAT_RESP_CODE = "0"
      EFAT_AT_STAT = 5 #Resposta ok
    Elsif EFAT_RESP_CODE <> ""
      EFAT_AT_STAT = 2 #Resposta nok
    Else
      EFAT_AT_STAT = 3 #Ainda não tivemos resposta
    Endif
  Elsif EFAT_RESP_SOURCE = "EFAT" | EFAT_RESP_SOURCE = "" # (EFAT_RESP_SOURCE = "" & EFAT_STATUSCODE = 201)
    #Está no EFAT, consideramos que estamos a aguardar resposta
    EFAT_AT_STAT = 3 #Ainda não tivemos resposta
  Endif

  #--- ATINVSTAT
  If len(EFAT_RESP_SENT) > 2
    EFAT_BPC_STAT = 4 # EFAT já enviou
  Else
    EFAT_BPC_STAT = 4 # EFAT ainda não enviou
  Endif
  If len(EFAT_RESP_ACCESS) > 2
    EFAT_BPC_STAT = 5 # O cliente já abriu
  Endif
Else
  EFAT_AT_STAT = 2
  EFAT_BPC_STAT = 2
Endif

End
######################################################################################
######################################################################################
Subprog UPDATE_DKSDATA(DOCNUM,INVTYP,EFAT_AT_STAT,EFAT_BPC_STAT,EFAT_RESP_CODE,EFAT_RESP_MESSAGE,EFAT_RESP_EXPIRES,EFAT_RESP_PRIVATE_URL,EFAT_RESP_SENT,EFAT_RESP_ACCESS,EFAT_RESP_ACCESS_IP)
Value Char     DOCNUM
Value Char     INVTYP
Value Shortint EFAT_AT_STAT
Value Shortint EFAT_BPC_STAT
Value Char     EFAT_RESP_CODE
Value Char     EFAT_RESP_MESSAGE
Value Char     EFAT_RESP_EXPIRES
Value Char     EFAT_RESP_PRIVATE_URL
Value Char     EFAT_RESP_SENT
Value Char     EFAT_RESP_ACCESS
Value Char     EFAT_RESP_ACCESS_IP

If !clalev([F:DKD]) : Local File DKSDATA [DKD] : Endif

Local Date     EXPIRDATE
Local Date     ACCESSDATE
Local Char     ACCESSTIME(10)

If len(EFAT_RESP_EXPIRES)>=10
  EXPIRDATE = left$(EFAT_RESP_EXPIRES,4) + mid$(EFAT_RESP_EXPIRES,6,2) + mid$(EFAT_RESP_EXPIRES,9,2)
Endif

If len(EFAT_RESP_ACCESS)>=10
  [L]ACCESSDATE = left$(EFAT_RESP_ACCESS,4) + mid$(EFAT_RESP_ACCESS,6,2) + mid$(EFAT_RESP_ACCESS,9,2)
  [L]ACCESSTIME = left$(right$(EFAT_RESP_ACCESS,instr(0,EFAT_RESP_ACCESS,"T")+1),8)
Endif

Read [DKD]DKD0="SAFT-PT";INVTYP;DOCNUM
If !fstat
    If [F:DKD]BPEI > 0 & [F:DKD]BPEI < 5 & EFAT_BPC_STAT <> 0 : [F:DKD]BPEI= EFAT_BPC_STAT : Endif
    If [F:DKD]ATEI > 0 & [F:DKD]ATEI < 5 & EFAT_AT_STAT <> 0  : [F:DKD]ATEI= EFAT_AT_STAT  : Endif
    [F:DKD]EFATMESS = EFAT_RESP_CODE + " - " + EFAT_RESP_MESSAGE
    If EXPIRDATE<> [0/0/0]
        [F:DKD]EXPDATE= EXPIRDATE
    Endif
    If len(EFAT_RESP_PRIVATE_URL) > 5
       [F:DKD]DOCLINK = EFAT_RESP_PRIVATE_URL
    Endif
    If len(EFAT_RESP_SENT) > 5
       [F:DKD]EFATSENT = EFAT_RESP_SENT
    Endif
    If ACCESSDATE <> [0/0/0]
        [F:DKD]ACCESSDATE = ACCESSDATE
    Endif
    If ACCESSTIME <> ""
        [F:DKD]ACCESSTIME = ACCESSTIME
    Endif

    Rewrite [F:DKD]
Endif

End
######################################################################################
######################################################################################
$TRACE

If MESSAGE <> ""
   Call ECR_TRACE(MESSAGE, STAT) From GESECRAN
Endif

If [L]PRIVTRACE = 1
  Call LEC_TRACE   From LECFIC
  Call FERME_TRACE From LECFIC
Endif

Return
######################################################################################
######################################################################################
$GET_FROM_EFAT

Gosub SET_EFAT_GET_CTX_OBJ
Gosub SET_EFAT_OPT_OBJ
Gosub SET_EFAT_PAR_OBJ

Gosub REST_GET_EFAT_CALL

#WHTTPRETCODE= Funciu = WHTTPREPLY +":getStatusCode" Using [DKSB] With ( )
#
#If WHTTPRETCODE < 200 or WHTTPRETCODE >= 300 #dar erro 3 - O X3 tentou comunicar com o EFAT, mas não conseguiu.
#    Call ECR_TRACE(func AFNC.MES1(mess(224,7711,1), num$(WHTTPRETCODE)),1) From GESECRAN
#    MESSAGE  = mess(224,7711,1) + num$(WHTTPRETCODE)
#    #MESSAGE = "Erro a comunicar com o EFAT. Erro: " + num$(WHTTPRETCODE)
#    If EFAT_CTX_ATSERVICE   = 'true' : ATINVSTAT  = 1 : Else ATINVSTAT  = 0 : Endif
#    If EFAT_CTX_MAILSERVICE = 'true' : BPCINVSTAT = 1 : Else BPCINVSTAT = 0 : Endif
#    Call UPDATE_DKSDATA([F:SIH]NUM,[F:SIH]INVTYP,ATINVSTAT,BPCINVSTAT,"",MESSAGE,"","","","")
#Else # 4 - O X3 já comunicou com sucesso para o EFAT, mas aguarda-se ainda a resposta do EFAT.
#    Call ECR_TRACE(mess(225,7711,1), 0) From GESECRAN
#    #Gosub UPDATE_INVOICE_STATUS
#Endif
#
##Gosub DISPOSE     From XPCOMJBLIB
#Gosub CLOSEJBSCON From COMJBLIB

Call SET_INV_STA(EFAT_AT_STAT,EFAT_BPC_STAT,EFAT_STATUSCODE,EFAT_RESP_CODE,EFAT_RESP_MESSAGE,EFAT_RESP_SOURCE,EFAT_RESP_SENT,EFAT_RESP_ACCESS)

Call UPDATE_DKSDATA([F:SIH]NUM,[F:SIH]SIVTYP,EFAT_AT_STAT,EFAT_BPC_STAT,EFAT_RESP_CODE,EFAT_RESP_MESSAGE,EFAT_RESP_EXPIRES,EFAT_RESP_PRIVATE_URL,EFAT_RESP_SENT,EFAT_RESP_ACCESS,EFAT_RESP_ACCESS_IP)

Return
######################################################################################
######################################################################################
$REST_GET_EFAT_CALL

EFAT_TYPE = "invoice_query"
EFAT_ARGUMENTS = '"Sage-EFAT", "GET", "Invoice/'+EFAT_URLTAXID+'",' + EFAT_PAR + ',{},' + EFAT_CTX + ',{}, "'+EFAT_TYPE+'",' + EFAT_OPT
#EFAT_ARGUMENTS = '"Sage-EFAT-PREPROD", "GET", "Invoice/'+EFAT_URLTAXID+'",' + EFAT_PAR + ',{},' + EFAT_CTX + ',{}, "'+EFAT_TYPE+'",' + EFAT_OPT #PRE

# Call 'send' function
EFAT_STATUSCODE   = func ASYRWEBSER.EXEC_JS(EFAT_MODULE, EFAT_FONCTION, EFAT_MODE, EFAT_ARGUMENTS, '', 0, EFAT_RETURNS, '0', EFAT_RESHEAD, EFAT_RESBODY)
If EFAT_STATUSCODE = 200
  EFAT_RESP_STATUS      = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Status")
  EFAT_RESP_CREATED     = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Created")
  EFAT_RESP_CODE        = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Code")
  EFAT_RESP_MESSAGE     = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Message")
  EFAT_RESP_SOURCE      = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Source")
  EFAT_RESP_URL         = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Url")
  EFAT_RESP_PRIVATE_URL = func AJSONLIB.GET_PROP(EFAT_RESBODY,"PrivateUrl")
  EFAT_RESP_SENT        = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Sent")
  EFAT_RESP_EXPIRES     = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Expires")
  EFAT_RESP_ACCESS      = func AJSONLIB.GET_PROP(EFAT_RESBODY,"Access")
  EFAT_RESP_ACCESS_IP   = func AJSONLIB.GET_PROP(EFAT_RESBODY,"AccessIP")
Elsif EFAT_STATUSCODE > 200
  EFAT_RESP_CODE        = num$(EFAT_STATUSCODE)
  EFAT_RESP_MESSAGE     = func AJSONLIB.GET_PROP(EFAT_RESHEAD,"message")
Else
  EFAT_RESP_CODE        = num$(EFAT_STATUSCODE)
  EFAT_RESP_MESSAGE     = EFAT_RESHEAD
Endif

Return
