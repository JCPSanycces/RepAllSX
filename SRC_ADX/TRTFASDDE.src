#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################################
#    DETACHER DEPENSES A BIEN COMPTABLE
#    FGR
#    Création     le : 26/03/2003
#    Modifications :
#
#  -  MWA  12.05.2016 (FQ116251) : Détachement de dépenses modernisées, ne diminuer que les bases des plans modernisés
#  -  CBO  28.11.2014 (FQ104360) : Undo a linked expense when balance sht val is changed
#  -  GLE  09.10.2014 (FQ 98116) : Deductible VAT recalculated when capitalizing Expense
#  -  MDJ  18.12.2013 (FQ 94340) : Mise à jour du plan de renouvellement quand détachement de dépense
#  -  GLE  09.07.2013 (FQ 91042) : Erreur sur les montants IAS si devise IAS <> devise PCG et LOFIASAMT à Oui
#                                  Le montant IAS doit rester modifiable après sélection de la ligne si LOFIASAMT est à Oui
#  -  MWA  20.02.2013 ( 67615_8) : Ventilation analytiques biens POOL & LVA
#  -  GLE  04/10/2012 (FQ 84794) : Gestion d'un montant IAS pour éviter une double conversion si devise IAS = devise pièce
#  -  GLE  26/04/2012 (FQ 81867) : Valorisation modifiable pour l'IAS
#  -  GLE  20/09/2011 (FQ 62883) : Désactivation du contrôle sur le détachement
#  -  GBO  04/03/2011 (FQ 67577) : Pologne - Modernisation
#  -  MWA  05/10/2010 (FQ 67939) : Affectation des indicateurs de calcul
#  -  GBO  04/05/2010 (FQ 64552) : Suppression de bien et détachement de  bien : pas d'événement
#                                  d'annulation de changement de compte
#  -  GBO  04/03/2010 (FQ 63049) : Gestion des dépenses en suppression de bien
#  -  GBO  28/01/2010 (FQ 61936) : Date d'effet des événements de chgt de compte date$ --> EVTDAT de l'événement d'origine
#  -  GBO  26/10/2009 (FQ 59231) : Pas d'événement d'annulation en cas de détachement de dépenses
#  -  GLE  25/04/2006 (FQ 35964) : prise en compte du fait qu'il n'y a peut-être pas de valorisation IAS
#  -  MDJ  22/07/2005 (FQ 26105) : - On présente l'ensemble des dépenses rattachées au bien, même si
#                                    les dépenses n'ont plus le même site et/ou la même société que le bien
#                                    (cas d'un transfert du bien sur un autre site par ex.)
#                                  - Lors de l'annulation des événements des dépenses supprimées on
#                                    n'interrompt plus le traitement de suppression du bien si un événement
#                                    est déjà annulé (si CDRET=91)
#  -  MDJ  27/04/2005 (FQ 27996) : décrémentation des montants des zones libres en fonction
#                                  du paramétrage du transit dépense-bien
#
###############################################################################################
Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("FAS",GBIDC1,GBIDC2) From GOBJET
End

################################################################################
$ACTION
  #Infbox "ACTION="-num$(ACTION)-"/ GREP"-GREP
  Case ACTION
    When "OUVRE"          : Gosub OUVRE
    When "DEBUT"          : Gosub DEBUT
    When "SETBOUT"        : Gosub SETBOUT            : # Enable/Disable des boutons
    When "APRES_MODIF"    : Gosub APRES_MODIF        : # c'est là qu'on dit qu'on est en modif
    When "AVANT_MODFIC"   : Gosub AVANT_MODFIC
    When "AVANT_OK"       : Gosub AVANT_OK           : # Controle bouton OK
    When "OK"             : Gosub OK                 : # Exécution bouton
    When "ABA"            : Gosub ABA
    When "FIN"            : Gosub FIN                : # Abandon
  Endcase
Return

################################################################################
#-------------------------------------------------------------------------------
$OUVRE
Local Integer LERROR
  #--------------------------
  If clalev([F:LOF])=0  : Local File LAYOUTFAS    [LOF]  : Endif : # Dépense
  If clalev([F:TZL])=0  : Local File PARTRZL      [TZL]  : Endif : # Paramétrage transite zones
  If clalev([F:TZD])=0  : Local File PARTRZLDET   [TZD]  : Endif : # Paramétrage transit zones détail
  #--------------------------
  Gosub ACTION From TRTOBJACT
  #--------------------------
Return

#-------------------------------------------------------------------------------
$DEBUT
  #------------------------------ FQ81867
  Global Integer GLOFIASAMT         : # Paramètre autorisant le forçage du montant HT IAS
  Local Char LPARM(10)
  Call PARAM("","LOFIASAMT",LPARM) From ADOVAL
  GLOFIASAMT = val(LPARM)
  #------------------------------
  [M:DDE1]CPY     = [M:FAS0]CPY
  [M:DDE1]FCY     = [M:FAS0]FCY
  #------------------------------
  #Fq67577-Pologne
  If G_ACTKPL=G_OUI
   Gosub DEBUT_TRTFASDDE From TRTFASMDR
  Endif
  #------------------------------
  Gosub REMPLI_TABLEAU
  #------------------------------
  If GREP = "A" Then
    GDDABOK = G_NON : # on abandonne, donc il ne faudra pas supprimer le bien
  Endif
  #------------------------------
  Gosub ACTION From TRTOBJACT
  Setmok [M:DDE1] With 0
  #------------------------------
Return

#-------------------------------------------------------------------------------
$SETBOUT
  # FGR18062004 : Obligé de restaurer GREP, il est réinitialisé dans GSAISIE. Ca n'était pas le cas avant !
  GREP = SAVGREP
Return

#-------------------------------------------------------------------------------
$ABA
  If GREP = "A" Then
    GDDABOK = G_NON : # on abandonne, donc il ne faudra pas supprimer le bien
  Else
    Gosub DEBUT : # Clic sur abandon, on recharge toutes les valeurs d'origine
    REP = ""    : # On repasse en mode consultation
  Endif
Return

#-------------------------------------------------------------------------------
$FIN
  Gosub DELOCK_TBL_DEST
  #--------------------------
  Gosub ACTION From TRTOBJACT
  #--------------------------
Return

#-------------------------------------------------------------------------------
$REMPLI_TABLEAU
Local Char    LCRITKPL #Fq67577-Pologne
Local Char    LLOCK(200)
Local Integer LDELPOSSIBLE

  Call TEMPON('L') From GESECRAN
  [M:DDE1]NBDEST = 0
  Call ACTION_BLOCK (ACB_EFFZO, "FASDDE1", "FLGULI") From GLOBIENS
  nolign = 1
  LDELPOSSIBLE = G_OUI
  #------------------------------
  #Fq67577-Pologne
  If G_ACTKPL=G_OUI & [M:OAC0]CCLMDRFLG=G_OUI
   Gosub REMPLI_TABLEAU From TRTFASMDR
   If [M:DDE1]NBDEST
    Return
   Else
    Actzo [M:DDE1] : [M:OAC0]CCLMDRFLG=G_NON : Grizo [M:OAC0]CCLMDRFLG
    Call TEMPON('L') From GESECRAN
   Endif
  Endif
  #Fq67577-Fin
  #------------------------------
 # FQ 26105
 # For [LOF] Where [F:LOF]CPY=[M:DDE1]CPY &[F:LOF]FCY=[M:DDE1]FCY &AASREF=[M:FAS0]AASREF &[F:LOF]FLGLIKAAS=G_OUI &FLGLOFMAI=G_OUI
  For [LOF] Where AASREF=[M:FAS0]AASREF &[F:LOF]FLGLIKAAS=G_OUI &FLGLOFMAI=G_OUI
    #------------------------------
    Gosub ALIMENTE_LIGNES
    #------------------------------
    If GREP = "A" Then
      # Lors de la suppression du bien, toutes les dépenses doivent être déliées
      If [M:DDE1]LOCKED(nolign-2) = G_NON Then
        [M:DDE1]FLGULI(nolign-2) = G_OUI
      Else
        [M:DDE1]FLGULI(nolign-2) = G_NON
        LDELPOSSIBLE             = G_NON
      Endif
      Grizo [M:DDE1]FLGULI(nolign-2)
    Endif
    #------------------------------
    # Suite de la boucle
  Next
  #------------------------------
 # FQ 26105
 # For [LOF] Where [F:LOF]CPY=[M:DDE1]CPY &[F:LOF]FCY=[M:DDE1]FCY &AASREF=[M:FAS0]AASREF &[F:LOF]FLGLIKAAS=G_OUI &FLGLOFMAI=G_NON
  #Fq67577-Pologne
  If G_ACTKPL=G_OUI
   LCRITKPL="KMDRFLG<>G_OUI"
  Else
   LCRITKPL="1=1"
  Endif
  For [LOF] Where AASREF=[M:FAS0]AASREF & [F:LOF]FLGLIKAAS=G_OUI & FLGLOFMAI=G_NON & evalue(LCRITKPL)
    #------------------------------
    Gosub ALIMENTE_LIGNES
    #------------------------------
    If GREP = "A" Then
      # Lors de la suppression du bien, toutes les dépenses doivent être déliées
      If [M:DDE1]LOCKED(nolign-2) = G_NON Then
        [M:DDE1]FLGULI(nolign-2) = G_OUI
      Else
        [M:DDE1]FLGULI(nolign-2) = G_NON
        LDELPOSSIBLE             = G_NON
      Endif
      Grizo [M:DDE1]FLGULI(nolign-2)
    Endif
    #------------------------------
    If nolign > 998 Then
      Break
    Endif
    #------------------------------
    # Suite de la boucle
  Next
  [M:DDE1]NBDEST = nolign-1
  #------------------------------
  Call ACTION_BLOCK (ACB_AFFZO, "FASDDE1", "FLGULI") From GLOBIENS
  Call TEMPOFF() From GESECRAN
  #------------------------------ FQ81867
  # Modification du montant IAS
  For nolign = 1 To [M:DDE1]NBDEST
    If (GCNXPROIAS = G_OUI) and (GLOFIASAMT = G_OUI)
      Actzo [M:DDE1]AMTNOTIAS(nolign-1)
    Else
      Diszo [M:DDE1]AMTNOTIAS(nolign-1)
    Endif
  Next

Return
  #------------------------------

#-------------------------------------------------------------------------------
$ALIMENTE_LIGNES
Local Char    LLOCK(200)

  [M:DDE1] = [LOF]

  [M:DDE1]CURCPY(nolign-1) = GCNXCURCPF : # FQ84794
  [M:DDE1]CURIAS(nolign-1) = GCNXCURIAS : # FQ84794

  # FQ91042 : on conserve à présent le montant IAS sur la dépense, il faut faire une conversion depuis le PCG
  #           uniquement si le PCG est valorisé et pas l'IAS (cas des dépenses créées avant la FQ84794)
  #------------------------------ FQ81867
  #If (GCNXPROIAS = G_OUI) and (GLOFIASAMT = G_OUI) Then : # FQ91042
  If (GCNXPROIAS = G_OUI) and ([M:DDE1]AMTNOTCPY(nolign-1) <> 0) and ([M:DDE1]AMTNOTIAS(nolign-1) = 0) Then
    # Attention aux conversions si devise différente !!!
    If GCNXCURIAS <> GCNXCURCPF Then
      Local Integer LSTAT
      Local Decimal LMNTCONV
      If [M:FAS1]IASRATCUR = 0 Then
        Call CDVCAL( [M:FAS1]IASRATCUR, GCNXCURCPF, GCNXCURIAS, GCOUSOC, [M:FAS1]IASCURTYP, [M:DDE1]DATVCR(nolign-1)) From TRTDIV
      Endif
      Call CONVERT3( GCNXCURCPF, GCNXCURIAS, GCOUDEV, [M:FAS1]IASCURTYP, [M:DDE1]DATVCR(nolign-1),
&                    [M:DDE1]AMTNOTCPY(nolign-1), LMNTCONV, [M:FAS1]IASRATCUR,
&                    LSTAT) From CPTSUB
      [M:DDE1]AMTNOTIAS(nolign-1) = LMNTCONV
    # FQ91042
    #Else
    #  [M:DDE1]AMTNOTIAS(nolign-1) = [M:DDE1]AMTNOTCPY(nolign-1)
    Endif
  Endif
  #------------------------------
  LLOCK = func GLOBIENS.GET_KEY_LAYOUTFAS ([F:LOF]CODLOF, [F:LOF]LINLOF)
  If func GLOBIENS.LOCK_SYMBOLE ("LOF", [M:DDE1]CPY, LLOCK, 0) = 0 Then
    # l'enregistrement est locké ailleurs : on ne peut pas le choisir
    [M:DDE1]LOCKED(nolign-1) = G_OUI
  Else
    [M:DDE1]LOCKED(nolign-1) = G_NON
  Endif
  #------------------------------
  nolign += 1
Return

#-------------------------------------------------------------------------------
$DELOCK_TBL_DEST
Local Integer N_I
Local Char    LLOCK(200)

  For N_I = 1 To [M:DDE1]NBDEST
    LLOCK = func GLOBIENS.GET_KEY_LAYOUTFAS ([M:DDE1]CODLOF(N_I-1), [M:DDE1]LINLOF(N_I-1))
    Call UNLOCK_SYMBOLE ("LOF", [M:DDE1]CPY, LLOCK) From GLOBIENS
    #------------------------------
    # Suite de la boucle
  Next N_I
Return

#-------------------------------------------------------------------------------
$APRES_MODIF
  If GREP <> "A" Then
    REP = "M"
  Endif
Return

#-------------------------------------------------------------------------------
$AVANT_OK
  Gosub CTRL_DDAB
Return

#-------------------------------------------------------------------------------
$OK
  If GREP <> "A" Then  # SUBFAS
    G_ACT_MOD = 1 : # Pour mettre l'écran du bien en modif... voir s'il faut bien le faire là
    Gosub RECTIFIE_BCO
    #--------------------------
    Gosub ACTION From TRTOBJACT
    #--------------------------
  Else
    Gosub APPLIQUER_DDAB
    FIN = 1 : # pour quitter la fenêtre de déliaison
  Endif
Return

#-------------------------------------------------------------------------------
$AVANT_MODFIC
  #--------------------------
  Gosub APPLIQUER_DDAB
  #--------------------------
Return

################################################################################
#
################################################################################
#-------------------------------------------------------------------------------
$CTRL_DDAB

  If GREP = "A" Then
    If LDELPOSSIBLE = G_NON Then
      GERR     = 1
      GMESSAGE = mess(36,7772,1) : # Une ou plusieurs dépenses regroupées sont verrouillée par un autre processus. Suppression du bien impossible !
      FIN      = 0 : # pour ne pas quitter la fenêtre de déliaison
    Endif
  Else
    If func TRTFASDDE.GET_NB_LOF_AVIRER () = 0 Then
      # pour enregistrer, faut au moins qu'une dépense ait été déliée
      GERR     = 1
      GMESSAGE = mess(31,7772,1) : # Au moins une dépense doit être proposées à la déliaison
      FIN      = 0 : # pour ne pas quitter la fenêtre de déliaison
    Endif
  Endif
Return

#-------------------------------------------------------------------------------
$APPLIQUER_DDAB
Local  Integer N_I #, CDRET, LEVTCREE
Global Integer G_SV_ACN
#FQ63049
Local  Char    LCODLOF
Local  Integer LLINLOF

  #Fq67577-Pologne
  If G_ACTKPL=G_OUI
   Gosub APPLIQUER_DDAB From TRTFASMDR
  Endif
  #Fq67577-Fin

  Call TEMPON('E') From GESECRAN
  For N_I = 1 To [M:DDE1]NBDEST
    If [M:DDE1]FLGULI(N_I-1) = G_OUI Then
      LCODLOF=[M:DDE1]CODLOF(N_I-1)
      LLINLOF=[M:DDE1]LINLOF(N_I-1)
      Gosub DDAB_LOF
    Endif
    #------------------------------
    # Suite de la boucle
  Next N_I
  #------------------------------
  Gosub DELOCK_TBL_DEST
  #------------------------------
  Kill G_SV_ACN
  If GREP = "A" Then
    GDDABOK = G_OUI
  Endif
  Call TEMPOFF() From GESECRAN
  #------------------------------
Return

#fq63049
#-------------------------------------------------------------------------------
$DDAB_LOF
      Local Integer CDRET, LEVTCREE
      # Traitement de la dépense à délier
      Raz [LOF]
     #Read [LOF]LOF0=[M:DDE1]CODLOF(N_I-1);[M:DDE1]LINLOF(N_I-1)
      Read [LOF]LOF0=LCODLOF;LLINLOF
      #------------------------------
      If fstat Then
        GMESSAGE  = mess(28,7772,1)-num$(fstat) : # Erreur en lecture de la dépense
       #GMESSAGE += ' '-num$([M:DDE1]CODLOF(N_I-1))-num$([M:DDE1]LINLOF(N_I-1))
        GMESSAGE += ' '-LCODLOF-num$(LLINLOF)
        GOK       = 0
        Call FSTA("LOF") From GLOCK
        Return
      Endif
        # ------------------------------
        # Rétablissement des valeurs sur les dépenses
        [F:LOF]AASREF    = ""
        [F:LOF]FLGLIKAAS = G_NON
        [F:LOF]FLGLOFMAI = G_NON
        [F:LOF]FLGDETEXP = G_OUI # FQ104360 Par défaut les dépenses sont détachables

        G_SV_ACN         = func GLOBIENS.GET_GACACN_FROM_GAC ([F:LOF]GACORI, GFASLEDSOC)
        If G_SV_ACN <> [F:LOF]GACACN or [F:LOF]GAC <> [F:LOF]GACORI Then
         #Call ANNULE_EVE(GVML_OMDEPEN,[F:LOF]CPY,"",[F:LOF]CODLOF,[F:LOF]LINLOF,"LOFCHGPCG",date$,LEVTCREE,CDRET) From GENEVE
         #Call ANNULE_EVE(GVML_OMDEPEN,[F:LOF]CPY,"",[F:LOF]CODLOF,[F:LOF]LINLOF,"LOFCIM1",date$,LEVTCREE,CDRET) From GENEVE #@FQ59231
          If clalev([F:EVT0]) : Close Local File [F:EVT0] : Endif #Fq64552
          If clalev([F:EVT1]) : Close Local File [F:EVT1] : Endif #Fq64552
          Call ANNULE_EVE(GVML_OMDEPEN,[F:LOF]CPY,"",[F:LOF]CODLOF,[F:LOF]LINLOF,"LOFCIM1",[0/0/0],LEVTCREE,CDRET) From GENEVE #FQ61936
          #*** FQ 26105 : on ne s'arrête pas en cas de CDRET = 91 car il s'agit alors d'un événement déjà annulé par ailleurs
          #*** FQ 26105 If CDRET > 20
          If CDRET > 20 & CDRET <> 91 Then
            GMESSAGE  = mess(40,7772,1)-num$(CDRET) : # Erreur lors de la génération de l'événement PCG
           #GMESSAGE += ' '-num$([M:LOF6]CODLOF(N_I-1))-num$([M:LOF6]LINLOF(N_I-1))
            GMESSAGE += ' '-num$(LCODLOF)-num$(LLINLOF)
            GOK       = 0
            Call FSTA("LOF") From GLOCK
            Kill G_SV_ACN
            Return
          Endif
        Endif
        [F:LOF]GAC       = [F:LOF]GACORI
        [F:LOF]GACACN    = G_SV_ACN
        #------------------------------
        If GCNXPROIAS = G_OUI Then
          # Si le contexte IAS est géré on restaure l'imputation IAS d'origine
          G_SV_ACN       = func GLOBIENS.GET_GACACN_FROM_GAC ([F:LOF]IASACCORI,GFASLEDIAS )
          If G_SV_ACN <> [F:LOF]IASACN or [F:LOF]IASACC <> [F:LOF]IASACCORI Then
           #Call ANNULE_EVE(GVML_OMDEPEN,[F:LOF]CPY,"",[F:LOF]CODLOF,[F:LOF]LINLOF,"LOFCHGIAS",date$,LEVTCREE,CDRET) From GENEVE
           #Call ANNULE_EVE(GVML_OMDEPEN,[F:LOF]CPY,"",[F:LOF]CODLOF,[F:LOF]LINLOF,"LOFCIM6",date$,LEVTCREE,CDRET) From GENEVE #@FQ59231
            If clalev([F:EVT0]) : Close Local File [F:EVT0] : Endif #Fq64552
            If clalev([F:EVT1]) : Close Local File [F:EVT1] : Endif #Fq64552
            Call ANNULE_EVE(GVML_OMDEPEN,[F:LOF]CPY,"",[F:LOF]CODLOF,[F:LOF]LINLOF,"LOFCIM6",[0/0/0],LEVTCREE,CDRET) From GENEVE #FQ61936
           #*** FQ 26105 : on ne s'arrête pas en cas de CDRET = 91 car il s'agit alors d'un événement déjà annulé par ailleurs
           #*** FQ 26105 If CDRET > 20
           If CDRET > 20 & CDRET <> 91 Then
              GMESSAGE  = mess(41,7772,1)-num$(CDRET) : # Erreur lors de la génération de l'événement IAS
             #GMESSAGE += ' '-num$([M:LOF6]CODLOF(N_I-1))-num$([M:LOF6]LINLOF(N_I-1))
              GMESSAGE += ' '-num$(LCODLOF)-num$(LLINLOF)
              GOK       = 0
              Call FSTA("LOF") From GLOCK
              Kill G_SV_ACN
              Return
            Endif
          Endif

          # FQ84794 : remise à zéro des montants cachés IAS si la dépense a été créée en direct
          # FQ98116 : ou dans un flux
          #If [F:LOF]CPMCREORI = 0 : # FQ98116
            [F:LOF]AMTNOTIAS  = 0
            [F:LOF]AMTVATIAS  = 0
            [F:LOF]AMTVATRIAS = 0
          #Endif

          [F:LOF]IASACC = [F:LOF]IASACCORI
          [F:LOF]IASACN = G_SV_ACN
        Endif
        #------------------------------
        If G_ACTKPL=G_OUI
         Gosub DDAB_LOF From TRTFASMDR
        Endif
        #------------------------------

        # FQ67615_8
        # Ventilation analytique des biens POOL ou LVA
        If ( find ([F:FAS]CMPSTA, GVML_SBPOOL, GVML_SBLVA) > 0 ) Then
          Local Integer I_S
          Local Char    RAASDSP
          Local Char PDIE (3)  (0..19)
          Local Char PCCE (15) (0..19)
          For I_S = 1 To 20
            PDIE(I_S-1) = [F:LOF]DIE(I_S-1)
            PCCE(I_S-1) = [F:LOF]CCE(I_S-1)
          Next
          Local Char RERRMES(250)
          Call LVA_MAJ_ANALYTIQUE ( "-", [F:FAS]AASREF, [F:FAS]DSP, [F:FAS]CPY, [F:FAS]FCY, [F:LOF]DSP,
&              [M:FPC]NBDIE, PDIE, PCCE, [F:LOF]AMTNOTCUR, [F:LOF]CUR, RAASDSP, RERRMES )  From TRTFAS2
          If (RERRMES <> "") Then
            GMESSAGE = RERRMES
            GOK = 0
            Return
          Endif
          If (RAASDSP <> "" and func TRTFAS2.IS_DSP_EMPTY(RAASDSP)) Then
            [M:FAS2]DSP = ""
          Endif
        Endif


        # Mise à jour de la dépense
        Rewrite [LOF]
        If fstat Then
          GMESSAGE  = mess(27,7772,1)-num$(STAT) : # Erreur réécriture dépense
         #GMESSAGE += ' '-num$([M:DDE1]CODLOF(N_I-1))-num$([M:DDE1]LINLOF(N_I-1))
          GMESSAGE += ' '-num$(LCODLOF)-num$(LLINLOF)
          GOK       = 0
          Call FSTA("LOF") From GLOCK
          Kill G_SV_ACN
          Return
        Endif

Return

#-------------------------------------------------------------------------------
$RECTIFIE_BCO
Local Integer N_I, LSTAT
Local Decimal LMNTCONV

  Call TEMPON('C') From GESECRAN
  If GREP <> "A" Then
    For N_I = 1 To [M:DDE1]NBDEST
      If [M:DDE1]FLGULI(N_I-1) = G_OUI Then
        # Correction des valeurs sur le bien comptable
        # 1°) On décrémente les montants PCG si la nature est "En cours" ou "en service"
        If [M:DDE1]GACACN(N_I-1) = GVML_NIENSER or [M:DDE1]GACACN(N_I-1) = GVML_NIENCOU Then
          [M:FAS1]ACGETRNOT  -= [M:DDE1]AMTNOTCPY(N_I-1)
          [M:FAS1]IVCVATAMT  -= [M:DDE1]AMTVATCPY(N_I-1)
          If ([M:FAS1]DEDVATFLG=G_OUI) : # FQ98116
            # Le montant est forcé, on lui retranche celui de la dépense
            [M:FAS1]DEDVATAMT  -= [M:DDE1]AMTVATRCPY(N_I-1)
          Else
            # Le montant n'est pas forcé, on le recalcule à partir du montant de TVA facturé et du taux de TVA récupéré
            [M:FAS1]DEDVATAMT = [M:FAS1]IVCVATAMT * ([M:FAS1]DEDVATRAT / 100 )
            Call GET_MNT_ARRONDI ([M:FAS1]DEDVATAMT, [M:FAS1]ACGCUR, [M:FAS1]DEDVATAMT ) From GLOBIENS
          Endif
        Endif
        #------------------------------
        #Fq67577-Pologne
        If [M:FPC]LEG<>"POL" | ([M:FPC]LEG="POL"&[M:OAC0]CCLMDRFLG<>G_OUI)
         # 2°) On décrémente les montants IAS si la nature est "En cours" ou "en service"
         If GCNXPROIAS = G_OUI Then : # FQ35964
           If [M:DDE1]IASACN(N_I-1) = GVML_NIENSER or [M:DDE1]IASACN(N_I-1) = GVML_NIENCOU Then
             #------------------------------ FQ81867
# FQ84794
             If (GLOFIASAMT <> G_OUI)
#                # Attention aux conversions si devise différente !!!
#                If GCNXCURIAS <> GCNXCURCPF Then
#                  If [M:FAS1]IASRATCUR = 0 Then
#                     Call CDVCAL( [M:FAS1]IASRATCUR, GCNXCURCPF, GCNXCURIAS, GCOUSOC, [M:FAS1]IASCURTYP, [M:DDE1]DATVCR(N_I-1)) From TRTDIV
#                  Endif
#                  Call CONVERT3( GCNXCURCPF, GCNXCURIAS, GCOUDEV, [M:FAS1]IASCURTYP, [M:DDE1]DATVCR(N_I-1),
#&                             [M:DDE1]AMTNOTCPY(N_I-1), LMNTCONV, [M:FAS1]IASRATCUR,
#&                             LSTAT) From CPTSUB
#                  [M:FAS1]IASETRNOT  -= LMNTCONV
#               #
#                  Call CONVERT3( GCNXCURCPF, GCNXCURIAS, GCOUDEV, [M:FAS1]IASCURTYP, [M:DDE1]DATVCR(N_I-1),
#&                             [M:DDE1]AMTVATCPY(N_I-1), LMNTCONV, [M:FAS1]IASRATCUR,
#&                             LSTAT) From CPTSUB
#                  [M:FAS1]IVCVATAMTI -= LMNTCONV
#               #
#                  Call CONVERT3( GCNXCURCPF, GCNXCURIAS, GCOUDEV, [M:FAS1]IASCURTYP, [M:DDE1]DATVCR(N_I-1),
#&                             [M:DDE1]AMTVATRCPY(N_I-1), LMNTCONV, [M:FAS1]IASRATCUR,
#&                             LSTAT) From CPTSUB
#                  [M:FAS1]DEDVATAMTI -= LMNTCONV
#                Else
#                  [M:FAS1]IASETRNOT  -= [M:DDE1]AMTNOTCPY(N_I-1)
#                  [M:FAS1]IVCVATAMTI -= [M:DDE1]AMTVATCPY(N_I-1)
#                  [M:FAS1]DEDVATAMTI -= [M:DDE1]AMTVATRCPY(N_I-1)
#                Endif
               [M:FAS1]IASETRNOT  -= [M:DDE1]AMTNOTIAS(N_I-1)
               [M:FAS1]IVCVATAMTI -= [M:DDE1]AMTVATIAS(N_I-1)
               If ([M:FAS1]DEDVATFLGI = G_OUI ) : # FQ98116
                 # Le montant est forcé, on lui retranche celui de la dépense
                 [M:FAS1]DEDVATAMTI -= [M:DDE1]AMTVATRIAS(N_I-1)
               Else
                 # Le montant n'est pas forcé, on le recalcule à partir du montant de TVA facturé et du taux de TVA récupéré
                 [M:FAS1]DEDVATAMTI = [M:FAS1]IVCVATAMTI * ([M:FAS1]DEDVATRATI / 100 )
                 Call GET_MNT_ARRONDI ([M:FAS1]DEDVATAMTI, [M:FAS1]IASCUR, [M:FAS1]DEDVATAMTI) From GLOBIENS
               Endif
             Else
               [M:FAS1]IASETRNOT  -= [M:DDE1]AMTNOTIAS(N_I-1)
               Gosub TVA_FAC_IAS From SUBFAS
               Gosub TVA_REC_IAS From SUBFAS
             Endif
             #------------------------------ FQ81867
           Endif
         Endif
         # FQ 27996 :
         # 3°) On décrémente les montants des zones libres en fonction du paramétrage de l'alimentation
         # de ces zones libres (montants cumulés ou non)
         Gosub CHERCHE_PARAM_TRANSIT
        Endif
        #Fq67577-Fin
      Endif
      #------------------------------
      # Suite de la boucle
    Next N_I
    #------------------------------
    # Ne pas faire dans le cas de la suppression du bien comptable
    Affzo [M:FAS1]ACGETRNOT
    Affzo [M:FAS1]IVCVATAMT
    Affzo [M:FAS1]DEDVATAMT
    #
    Affzo [M:FAS1]IASETRNOT
    Affzo [M:FAS1]IVCVATAMTI
    Affzo [M:FAS1]DEDVATAMTI
    #------------------------------
    #Call CALCUL_MONTANTS_TVA() From SUBFAS
    Gosub CALCUL_VALEUR_BILAN From TRTFAS
    #------------------------------
    Local Integer I_PLN
    For I_PLN=1 To [M:FAS3]NBLIG1
     #Fq67577-Pologne
     If G_ACTKPL=G_OUI
      # FQ116251
      If ( dim([M:OAC0]CCLMDRFLG)>0 and [M:OAC0]CCLMDRFLG=G_OUI )
        If ([M:FAS3]KMDRDEV(I_PLN-1) = 0) Then
          [M:FAS3]DPRBAS(I_PLN-1) = [M:FAS3]DPRBASORI(I_PLN-1)
          [M:FAS3]BSEVAL(I_PLN-1) = [M:FAS3]BSEVALORI(I_PLN-1)
          Affzo [M:FAS3]DPRBAS(I_PLN-1)
          Affzo [M:FAS3]BSEVAL(I_PLN-1)
          [M:FAS3]DPRVAL(I_PLN-1) = [M:FAS3]DPRBAS(I_PLN-1) -[M:FAS3]RSDVAL(I_PLN-1)
          Affzo [M:FAS3]DPRVAL(I_PLN-1)
        Endif
      Endif
      Gosub RECTIFIE_BCO From TRTFASMDR
     Endif
     #Fq67577-Fin
       #------------------------------
       #FQ94340 Updating the plan for provision for renewal
       If ( G_ACTCCN = G_OUI )
         If [M:FAS3]DPRPLN(I_PLN-1) = G301CPT
            If clalev([F:RPR]) =0     : Local File CCNRPR        [RPR]    : Endif
            Local Integer WNBYEAR
             Read[RPR]RPR0 =[M:FAS0]AASREF;[M:FAS3]FIYENDDAT(I_PLN-1);[M:FAS3]PERENDDAT(I_PLN-1)
             If fstat=0
                # * Initial DPRBAS     =  ACGBSESAV
                # * Updated DPRBAS     =  [M:FAS3]DPRBAS
                If [M:FAS1]PURDAT > [M:FAS3]FIYSTRDAT(I_PLN-1)
                   If [F:RPR]RNWVALFLG <> G_OUI
                      # Replacement amount start of exercise  = Updated DPRBAS
                      [F:RPR]STRRNWVAL = [M:FAS3]DPRBAS
                   Endif
                Else
                   If [F:RPR]RNWVALFLG <> G_OUI and ACGBSESAV <> 0
                      # Replacement amount start of exercise = DPRBAS updated*New value coeff
                      L_GLOCOE =   arr([F:RPR]STRRNWVAL/ACGBSESAV , 0.000001)
                      [F:RPR]STRRNWVAL = [M:FAS3]DPRBAS*L_GLOCOE
                   Endif
                Endif
                Rewrite [RPR]
                If fstat
                   GMESSAGE  = mess(104,GML_MSGFAS,1)-"CCNRPR Fstat="-num$(fstat)+" "-[F:RPR]AASREF
                   Call FSTA("RPR") From GLOCK
                   Break
                Endif
              Endif
           Endif
        Endif #FQ94340 END
        #------------------------------
     [M:FAS3]DEPSTA(I_PLN-1) = GVML_SCNOCAL
     # FQ67939
     [M:FAS0]FLGCLC                            = G_OUI
     [M:FAS0]FLGCNXCLC([M:FAS3]CNX(I_PLN-1)-1) = G_OUI
    Next I_PLN
    #------------------------------
  Endif
  Call TEMPOFF() From GESECRAN
Return
#-------------------------------------------------------------------------------
$RECTIFIE_BCO_OLD
Local Integer N_I, LSTAT
Local Decimal LMNTCONV

  Call TEMPON('C') From GESECRAN
  If GREP <> "A" Then
    For N_I = 1 To [M:DDE1]NBDEST
      If [M:DDE1]FLGULI(N_I-1) = G_OUI Then
        # Correction des valeurs sur le bien comptable
        # 1°) On décrémente les montants PCG si la nature est "En cours" ou "en service"
        If [M:DDE1]GACACN(N_I-1) = GVML_NIENSER or [M:DDE1]GACACN(N_I-1) = GVML_NIENCOU Then
          [M:FAS1]ACGETRNOT  -= [M:DDE1]AMTNOTCPY(N_I-1)
          [M:FAS1]IVCVATAMT  -= [M:DDE1]AMTVATCPY(N_I-1)
          [M:FAS1]DEDVATAMT  -= [M:DDE1]AMTVATRCPY(N_I-1)
        Endif
        #------------------------------
        #Fq67577-Pologne
        If [M:FPC]LEG<>"POL" | ([M:FPC]LEG="POL"&[M:OAC0]CCLMDRFLG<>G_OUI)
         # 2°) On décrémente les montants IAS si la nature est "En cours" ou "en service"
         If GCNXPROIAS = G_OUI Then : # FQ35964
           If [M:DDE1]IASACN(N_I-1) = GVML_NIENSER or [M:DDE1]IASACN(N_I-1) = GVML_NIENCOU Then
             # FQ81867
#             # Attention aux conversions si devise différente !!!
#             If GCNXCURIAS <> GCNXCURCPF Then
#               If [M:FAS1]IASRATCUR = 0 Then
#                 Call CDVCAL( [M:FAS1]IASRATCUR, GCNXCURCPF, GCNXCURIAS, GCOUSOC, [M:FAS1]IASCURTYP, [M:DDE1]DATVCR(N_I-1)) From TRTDIV
#               Endif
#               Call CONVERT3( GCNXCURCPF, GCNXCURIAS, GCOUDEV, [M:FAS1]IASCURTYP, [M:DDE1]DATVCR(N_I-1),
#&                             [M:DDE1]AMTNOTCPY(N_I-1), LMNTCONV, [M:FAS1]IASRATCUR,
#&                             LSTAT) From CPTSUB
#               [M:FAS1]IASETRNOT  -= LMNTCONV
#               #
#               Call CONVERT3( GCNXCURCPF, GCNXCURIAS, GCOUDEV, [M:FAS1]IASCURTYP, [M:DDE1]DATVCR(N_I-1),
#&                             [M:DDE1]AMTVATCPY(N_I-1), LMNTCONV, [M:FAS1]IASRATCUR,
#&                             LSTAT) From CPTSUB
#               [M:FAS1]IVCVATAMTI -= LMNTCONV
#               #
#               Call CONVERT3( GCNXCURCPF, GCNXCURIAS, GCOUDEV, [M:FAS1]IASCURTYP, [M:DDE1]DATVCR(N_I-1),
#&                             [M:DDE1]AMTVATRCPY(N_I-1), LMNTCONV, [M:FAS1]IASRATCUR,
#&                             LSTAT) From CPTSUB
#               [M:FAS1]DEDVATAMTI -= LMNTCONV
#             Else
                # FQ81867
                #[M:FAS1]IASETRNOT  -= [M:DDE1]AMTNOTCPY(N_I-1)
                #[M:FAS1]IVCVATAMTI -= [M:DDE1]AMTVATCPY(N_I-1)
                #[M:FAS1]DEDVATAMTI -= [M:DDE1]AMTVATRCPY(N_I-1)
                [M:FAS1]IASETRNOT  -= [M:DDE1]AMTNOTIAS(N_I-1)
#             Endif
             Gosub TVA_FAC_IAS From SUBFAS
             Gosub TVA_REC_IAS From SUBFAS
           Endif
         Endif
         # FQ 27996 :
         # 3°) On décrémente les montants des zones libres en fonction du paramétrage de l'alimentation
         # de ces zones libres (montants cumulés ou non)
         Gosub CHERCHE_PARAM_TRANSIT
       Endif
       #Fq67577-Fin
      Endif
      #------------------------------
      # Suite de la boucle
    Next N_I
    #------------------------------
    # Ne pas faire dans le cas de la suppression du bien comptable
    Affzo [M:FAS1]ACGETRNOT
    Affzo [M:FAS1]IVCVATAMT
    Affzo [M:FAS1]DEDVATAMT
    #
    Affzo [M:FAS1]IASETRNOT
    Affzo [M:FAS1]IVCVATAMTI
    Affzo [M:FAS1]DEDVATAMTI
    #------------------------------
    #Call CALCUL_MONTANTS_TVA() From SUBFAS
    Gosub CALCUL_VALEUR_BILAN From TRTFAS
    #------------------------------
    Local Integer I_PLN
    For I_PLN=1 To [M:FAS3]NBLIG1
     #Fq67577-Pologne
     If G_ACTKPL=G_OUI
      Gosub RECTIFIE_BCO From TRTFASMDR
     Endif
     #Fq67577-Fin
     [M:FAS3]DEPSTA(I_PLN-1) = GVML_SCNOCAL
     # FQ67939
     [M:FAS0]FLGCLC                            = G_OUI
     [M:FAS0]FLGCNXCLC([M:FAS3]CNX(I_PLN-1)-1) = G_OUI
    Next I_PLN
    #------------------------------
  Endif
  Call TEMPOFF() From GESECRAN
Return

##############################################################################
$CHERCHE_PARAM_TRANSIT
Local Char LIDENT
Local Char LNOMVAR
Local Char CHAMP
Local Char CHAMPDDE

# <<<<<< FQ 27996> :
  If !clalev([M:FRZ9])   Default Mask [FAS9]
  Else                   Default Mask [FRZ9]   Endif

  Call GET_IDENT_TZL ([M:FAS0]CPY, GVML_OMDEPEN, GVML_OMBIEN, LIDENT) From SUBTZL
  Read [TZL]TZL0=LIDENT
  If fstat
    # Si un paramétrage TZL n'existe pas sur la société, on le recherche par défaut
    Call GET_IDENT_TZL ("", GVML_OMDEPEN, GVML_OMBIEN, LIDENT) From SUBTZL
    Read [TZL]TZL0=LIDENT
    If fstat :   Return :  Endif
  Endif
  #------------------------------
  For [TZD] Where KEYTZL=LIDENT and CUM=G_OUI
    LNOMVAR  = [F:TZD]CODZONDES
    CHAMP    =  "[M]"+[F:TZD]CODZONDES
    CHAMPDDE    =  "[M:DDE1]"+[F:TZD]CODZONDES+"("+num$(N_I-1)+")"
    Assign CHAMP With (evalue(CHAMP)- evalue(CHAMPDDE))
    #----------------------------
    # Suite de la boucle
  Next
  #------------------------------

# </FQ 27996>>>>>

Return
##############################################################################
#-------------------------------------------------------------------------------
$ACTMET
  Case ACTMET
    When "CRITMEN"      : Gosub CRITMEN       # Critère d'activation du menu.
    When "LCK_OBJ_LNK"  : Gosub LCK_OBJ_LNK   # Lock manuel des objets liés.
    When "ULK_OBJ_LNK"  : Gosub ULK_OBJ_LNK   # Unlock manuel des objet liés
    When "FILL_HEA"     : Gosub FILL_HEA      # Alimentation zones spé à l'action de l'en-tête [OAC0]
    When "INIT_OBJ_DIV" : Gosub INIT_OBJ_DIV  # Ouvertures tables à mettre à jour dans MAJ_LNK
    When "MAJ_LNK"      : Gosub MAJ_LNK       # Mise à jour et alimentation des objets liés
    When Default
  Endcase
Return

#-------------------------------------------------------------------------------
$CRITMEN
# Permet d'alimenter la variable CRITMEN, avec le critère permettant d'activer
# le menu associé à l'action métier dans l'étiquette CRITMEN

Local Integer AUTORISE
Local Char    LLOCK(200)
Local Integer NBLOFONFAS


  AUTORISE = G_OUI
  If (GREP = "" and [M:FAS0]AASREF <> "") Then
    NBLOFONFAS = func GLOBIENS.GET_NB_LOF_ON_FAS([M:FAS0]AASREF)
    If NBLOFONFAS = 0 Then
      # On ne peut détacher des dépenses d'un bien qu'en mode visu : c'est l'action qui nous mettra en modif
      AUTORISE = G_NON
    Else
     # DEBUT FQ62883 : mise en commentaire
     # Raf-Evaluer par comparaison entre horodatage BCO / dépense
     # On ne peut plus délier de dépenses si le bien à déjà été amortie dans un exercice antérieur
     #Fq67577-Pologne
     #If [M:FPC]LEG<>"POL" | ([M:FPC]LEG="POL" & func TRTFASMDR.IS_MDR_PENDING([F:FAS]CPY,[F:FAS]AASREF,0,G301AUC)=0)
     # If [M:FAS1]PURDAT < GDEBEXECPF or [M:FAS1]ITSDAT < GDEBEXECPF or [M:FAS1]AASIPTDAT < GDEBEXECPF Then
     #  AUTORISE = G_NON
     # Endif
     #Endif  #Fq67577-Fin
     If ([M:FPC]LEG="POL" & func TRTFASMDR.IS_MDR_PENDING([F:FAS]CPY,[F:FAS]AASREF,0,G301AUC)=0)
      If [M:FAS1]PURDAT < GDEBEXECPF or [M:FAS1]ITSDAT < GDEBEXECPF or [M:FAS1]AASIPTDAT < GDEBEXECPF Then
       AUTORISE = G_NON
      Endif
    Endif #Fq67577-Fin
     # FIN FQ62883
    Endif
  Else
    # Action disponible uniquement en mode VISU
    AUTORISE = G_NON
  Endif

  If [M:FAS0]AASREF <> "" and AUTORISE = G_OUI Then
    # Pour désactiver les actions lorsque le bien est locké ailleurs
    LLOCK = func GLOBIENS.GET_KEY_FXDASSETS ([M:FAS0]AASREF)
    If func GLOBIENS.IS_SYMBOLE_LOCKED ("FAS", [M:FAS0]CPY, LLOCK) = 0 Then
      # Il est verrouillé ailleurs : on ne peut pas le calculer, délier et immobiliser
      AUTORISE = G_NON
    Endif
  Endif

  If AUTORISE = G_NON Then
    CRITMEN = 'REP=""' : # Si non autorisé, le CRITMEN doit être vrai pour que le VIREBOUT se fasse
                         # C'est l'inverse quand il s'agit d'un menu (et pas d'un bouton)
  Else
    CRITMEN = "1=0"    : # Si autorisé, le CRITMEN doit être faux pour que le VIREBOUT ne se fasse pas
                         # C'est l'inverse quand il s'agit d'un menu (et pas d'un bouton)
  Endif
#---------------------------
Return

#-------------------------------------------------------------------------------
$LCK_OBJ_LNK
# Ecrire les instructions de lock des objets liés dans cette étiquette
# si les objets liés ne sont pas des objets métiers.
Return

#-------------------------------------------------------------------------------
$ULK_OBJ_LNK
# Ecrire les instructions d'unlock des objets liés dans cette étiquette
# si les objets liés ne sont pas des objets métiers.
Return

#-------------------------------------------------------------------------------
$FILL_HEA
# Permet d'alimenter d'autre élément de l'en-tête en dehors de l'identifiant
# et de la désignation
Return

#-------------------------------------------------------------------------------
$INIT_OBJ_DIV
# Ouvrir les tables à mettre à jour
Return

#-------------------------------------------------------------------------------
$MAJ_LNK
# Ecrire le traitement de maj des tables des objets liés.
Return

#-------------------------------------------------------------------------------
$EVT_LNK
# C'est quoi ?
Return

################################################################################
Funprog GET_NB_LOF_AVIRER ()
# Rend le nombre de dépense liées à délier du bien
# ------------------------------------------------------------------------------
Local Integer LNOMBRE
Local Integer N_I

  LNOMBRE = 0
  For N_I = 1 To [M:DDE1]NBDEST
    If [M:DDE1]FLGULI(N_I-1) = G_OUI Then
      LNOMBRE += 1
    Endif
    #------------------------------
    # Suite de la boucle
  Next N_I
End LNOMBRE

################################################################################ FQ84794
Subprog CALCUL_TVA_TVAR_IAS(PLIG, PAMTNOTIAS, PRATVAT, PRATVATREC)
Value Integer PLIG
Value Decimal PAMTNOTIAS
Value Decimal PRATVAT
Value Decimal PRATVATREC

    MNTDES = PAMTNOTIAS * (PRATVAT / 100 )
    Call GET_MNT_ARRONDI (MNTDES, GCNXCURIAS, [M:DDE1]AMTVATIAS(PLIG-1)) From GLOBIENS

    MNTDES = [M:DDE1]AMTVATIAS(PLIG-1)* ([F:WLOF]RATVATREC / 100 )
    Call GET_MNT_ARRONDI (MNTDES, GCNXCURIAS, [M:DDE1]AMTVATRIAS(PLIG-1)) From GLOBIENS
End

################################################################################
# ECRAN : FASDDE0
################################################################################

#Fq67577-Pologne
########################################
Subprog AM_CCLMDRFLG(VALEUR)
Variable Integer VALEUR
 Call AM_CCLMDRFLG(VALEUR) From TRTFASMDR
End
#Fq67577-Fin

################################################################################
# ECRAN : FASDDE1
################################################################################
########################################
Subprog AV_FLGULI(VALEUR)
Variable Integer VALEUR

  #*Fq-82871
  #* - on garde les pcolor pour l'appli. C/S
  #* - on ajoute un chgstl pour Convergence
  If [M:DDE1]FLGLOFMAI(nolign-1) = G_OUI Then
    Chgstl NBDEST(nolign-1)  With "AWARNLOW"
    pcolor = GCOUL(3) : # Bleu
  Elsif [M:DDE1]LOCKED(nolign-1) = G_OUI Then
    Chgstl NBDEST(nolign-1)  With "AWARNHIGH"
    pcolor = GCOUL(1) : # Rouge
  Else
    Chgstl NBDEST(nolign-1)  With ""
    pcolor = GCOUL(0) : # Normal
  Endif
End

########################################
Subprog AS_FLGULI(VALEUR)
Variable Integer VALEUR

Local Char LLOCK(200)

  If [M:DDE1]FLGLOFMAI(nolign-1) = G_OUI Then
    # On ne peut pas retirer la dépense principale
    GMESSAGE = mess(32,7772,1) : # Impossible de retirer la dépense principale
    GERR     = 1
    mkstat   = 2
    End
  Endif

  # FQ104360
    # we can't unlink an expense if :
    # - it has been linked during the fixed asset's creation and (one of) the balance sheet values of fixed asset has been changed
  If [M:DDE1]FLGDETEXP(nolign-1) = G_NON
    GMESSAGE = mess(105, 7772, 1) : # Impossible de détacher cette dépense.
    GERR     = 1
    mkstat   = 2
    End
  Endif

  # Gestion des dépenses verrouillées
  If [M:DDE1]LOCKED(nolign-1) = G_OUI Then
    # Si l'enregistrement était verrouillé ailleurs, on regarde s'il l'est toujours
    LLOCK = func GLOBIENS.GET_KEY_LAYOUTFAS ([M:DDE1]CODLOF(nolign-1), [M:DDE1]LINLOF(nolign-1))
    If func GLOBIENS.IS_SYMBOLE_LOCKED ("LOF", [M:DDE1]CPY, LLOCK) = 1 Then
      # Maintenant il est libre on se le prend
      If func GLOBIENS.LOCK_SYMBOLE ("LOF", [M:DDE1]CPY, LLOCK, 0) = 0 Then
        # et non quelqu'un l'a repris ! On peut pas le détacher
        GMESSAGE = mess(34,7772,1)-[M:DDE1]CODLOF(nolign-1)-num$([M:DDE1]LINLOF(nolign-1)) : # Enregistrement verrouillé par un autre processus. Il ne peut être utilisé.
        GERR     = 1
        mkstat   = 2
        End
      Else
        [M:DDE1]LOCKED(nolign-1) = G_NON
      Endif
    Else
      # il est toujours verrouillé on peut rien faire sur lui ! On peut pas le détacher
      GMESSAGE = mess(34,7772,1)-[M:DDE1]CODLOF(nolign-1)-num$([M:DDE1]LINLOF(nolign-1)) : # Enregistrement verrouillé par un autre processus. Il ne peut être utilisé.
      GERR     = 1
      mkstat   = 2
      End
    Endif
  Endif
End

######################################################################################
Subprog AM_FLGULI(VALEUR)
Variable Integer VALEUR

  # FQ84794
  If GCNXPROIAS = G_OUI
    If VALEUR = G_OUI and [M:DDE1]AMTNOTIAS(nolign-1) = 0
      Local Integer STAT
      Infbox(mess(100,GML_MSGLOF,1))

      Local File    LAYOUTFAS [WLOF]
      Local Decimal MNTDES

      # Lecture de la dépense
      Read [F:WLOF]LOF0=[M:DDE1]CODLOF(nolign-1);[M:DDE1]LINLOF(nolign-1)

      Call CONVERT3([F:WLOF]CUR,
&                  GCNXCURIAS,
&                   GCNXCURCPF,
&                   [F:WLOF]CURTYP,
&                   [F:WLOF]DATVCR,
&                   [F:WLOF]AMTNOTCUR,
&                   MNTDES,
&                   0,
&                   STAT) From CPTSUB
      If !STAT
        Call GET_MNT_ARRONDI (MNTDES, GCNXCURIAS, [M:DDE1]AMTNOTIAS(nolign-1)) From GLOBIENS

        Call CALCUL_TVA_TVAR_IAS(nolign, [M:DDE1]AMTNOTIAS(nolign-1), [F:WLOF]RATVAT, [F:WLOF]RATVATREC)

        Actzo [M:DDE1]AMTNOTIAS(nolign-1)
        Affzo [M:DDE1]AMTNOTIAS(nolign-1)
      Endif
    Else
      If  GLOFIASAMT <> G_OUI : # FQ91042
        Diszo [M:DDE1]AMTNOTIAS(nolign-1)
        Affzo [M:DDE1]AMTNOTIAS(nolign-1)
      Endif
    Endif
  Endif
End


###################################################################################### FQ84794
Subprog AV_NBDEST
  If GCNXPROIAS <> G_OUI
    # Masquage des champs IAS dans les tableaux
    Chgfmt [M:DDE1]IASACC     With "-K:1X"
    Chgfmt [M:DDE1]AMTNOTIAS  With "-Nz3F:11.2"
    Chgfmt [M:DDE1]CURIAS     With "-KC:3"
  Endif
End


###################################################################################### FQ84794
Subprog AM_AMTNOTIAS(VALEUR)
Variable Decimal VALEUR

  Local File    LAYOUTFAS [WLOF]
  Local Decimal MNTDES

  # Lecture de la dépense
  Read [F:WLOF]LOF0=[M:DDE1]CODLOF(nolign-1);[M:DDE1]LINLOF(nolign-1)

  Call CALCUL_TVA_TVAR_IAS(nolign, VALEUR, [F:WLOF]RATVAT, [F:WLOF]RATVATREC)
End

