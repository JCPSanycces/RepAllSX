#<AdxTL>@(#)5.0.0.0 $Revision$
####################################################################################
# Program Name: CUSSEAQ
# Description : Quick Customer Search
# Author      : GRNA
####################################################################################
# Issue 113343 - 20160205 by LD : Devis avec utilisation de Recherche client rapide et prospec


$ACTION

Case ACTION
    When "OUVRE"         : Gosub OUVRE
    When "DEBUT"         : Gosub DEBUT
    When "APRES_MODIF"   : Gosub APRES_MODIF
    When "SETBOUT"       : Gosub SETBOUT  # 103933.n
    When "OK"            : Gosub OK
Endcase

Return


####################################################################################
$OUVRE

Gosub OUVRE From CUSSEA

# Ship-to address required
Local Integer ADDR : ADDR = val(PARAM(1))

Return


####################################################################################
$DEBUT

Default Mask [CSEQ]

Gosub CLEAR From CUSSEA

Gosub SETBOUT # 103933.n  To Disable OK

Return


####################################################################################
$APRES_MODIF

Case COUZON
  When "NBLIG"
    Call SELECT(nolign-1) From CUSSEA

  When Default
    Assign "[M]" + COUZON With zc
    Gosub SEARCH
Endcase

Return

# 103933.sn
####################################################################################
$SETBOUT

# Buttons
If [M]SELECT=""    # Nothing selected, disable all object buttons
  Disable 1029 : ETABOU(GVALI)=0 : Return
Else
  Enable 1029 : ETABOU(GVALI)=1
Endif

Return
####################################################################################
#103933.en
$OK

# Require ship-to when Address is being passed back
# Issue 113343
# Address required only for customer not for prospect
#If ADDR & [M]SSHIPTO<>2
If ADDR & [M]SSHIPTO<>2 & [M]SBPCUST=2
# End issue 113343
    GMESSAGE = mess(300,192,1)
    GERR=1 : FIN=0  : Return
Endif

# Exit if no customer selected
If [M]SELECT="" : Return : Endif

VALEUR = [M]SELECT

# Put Address in a global variable to be read in after change of base process
If ADDR & [M]SBPAADD<>""
    Global Char GCUSSEAADD : GCUSSEAADD = [M]SBPAADD
Endif

Return


####################################################################################
$SEARCH

Effzo [M]10-15

# Exit if no search fields were entered
If func SEACAT="" : Return : Endif

Gosub SELECT_SEARCH From CUSSEA
#MAE, 77716, verification source error
#SQL_CLOB -= func SET_REQ([M]NAM   ,2)  # Name
#SQL_CLOB -= func SET_REQ([M]TEL   ,3)  # Phone
#SQL_CLOB -= func SET_REQ([M]WEB   ,4)  # Email
#SQL_CLOB -= func SET_REQ([M]ADDLIG,5)  # Address
#SQL_CLOB -= func SET_REQ([M]CTY   ,6)  # City
#SQL_CLOB -= func SET_REQ([M]SAT   ,7)  # State
#SQL_CLOB -= func SET_REQ([M]POSCOD,8)  # Zip
Append SQL_CLOB,func SET_REQ([M]NAM   ,2)  # Name
Append SQL_CLOB,func SET_REQ([M]TEL   ,3)  # Phone
Append SQL_CLOB,func SET_REQ([M]WEB   ,4)  # Email
Append SQL_CLOB,func SET_REQ([M]ADDLIG,5)  # Address
Append SQL_CLOB,func SET_REQ([M]CTY   ,6)  # City
Append SQL_CLOB,func SET_REQ([M]SAT   ,7)  # State
Append SQL_CLOB,func SET_REQ([M]POSCOD,8)  # Zip

Gosub FUZZY_SEARCH From CUSSEA

Return


####################################################################################
# FLDVAL = input value
# FLDTYP = enumerated field type
#   1 - BPR
#   2 - Name
#   3 - Phone
#   4 - Email
#   5 - Address
#   6 - City
#   7 - State
#   8 - Zip
######################################################################################
Funprog SET_REQ(FLDVAL,FLDTYP)
Value    Char    FLDVAL
Value    Integer FLDTYP

If FLDVAL="" : End "" : Endif

Local Clbfile OREQ : OREQ = "and ("

Case FLDTYP
  When 1  : Append OREQ,func CUSSEA.SET_NUM(FLDVAL)
  When 2  : Append OREQ,func CUSSEA.SET_NAME(FLDVAL)
&          - "or" - func CUSSEA.SET_CNT_NAME(FLDVAL)
  When 3  : Append OREQ,func CUSSEA.SET_PHONE(FLDVAL)
&          - "or" - func CUSSEA.SET_CNT_PHONE(FLDVAL)
&          - "or" - func CUSSEA.SET_CNT_CELL(FLDVAL)
  When 4  : Append OREQ,func CUSSEA.SET_EMAIL(FLDVAL)
&          - "or" - func CUSSEA.SET_CNT_EMAIL(FLDVAL)
  When 5  : Append OREQ,func CUSSEA.SET_ADDR(FLDVAL)
  When 6  : Append OREQ,func CUSSEA.SET_CITY(FLDVAL)
  When 7  : Append OREQ,func CUSSEA.SET_STATE(FLDVAL)
  When 8  : Append OREQ,func CUSSEA.SET_ZIP(FLDVAL)
Endcase

Append OREQ,")"

End OREQ


####################################################################################
# Concatenate search fields
####################################################################################
Funprog SEACAT

Local Char CAT

CAT += [M]NAM
CAT += [M]TEL
CAT += [M]WEB
CAT += [M]ADDLIG
CAT += [M]CTY
CAT += [M]SAT
CAT += [M]POSCOD

# Entry Point in case fields were added to the screen
GPOINT="SEACAT" : Gosub ENTREE From EXEFNC

End CAT

