# Superviseur
## CRUD-CLASSE ## CCMCRORIGE
# 2018-10-19 07:50:20 985


############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(CCMCRORIGE,ASTATUS)
Variable Instance CCMCRORIGE Using C_CCMCRORIGE
Variable Integer ASTATUS

If CCMCRORIGE = null : End : Endif

Gosub _AVARIABLES From WMC00CCMCRORIGE

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CCMCRORIGE

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(CCMCRORIGE,ASTATUS)
Variable Instance CCMCRORIGE Using C_CCMCRORIGE
Variable Integer ASTATUS

If CCMCRORIGE = null : End : Endif

Gosub AVARIABLES From WMC00CCMCRORIGE
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_CCMCRORIGE
Else
 Gosub AINSERT_CCMCRORIGE
Endif

Gosub _AINSERT_AFTER
[L]A_I = CCMCRORIGE.freeSnapshot
CCMCRORIGE.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGE._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGE._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGE._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If CCMCRORIGE.ASTALIN = [V]CST_ANEWDEL : Return : Endif
CCMCRORIGE.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_CCMCRORIGE
Trbegin [F:CCMCROE]
 Gosub AINSERT_CCMCRORIGE
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_CCMCRORIGE
Raz [F:CCMCROE]
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00CCMCRORIGE._MAJSQL_CCMCRORIGE(CCMCRORIGE))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If CCMCRORIGE.snapshotEnabled=1
 [L]A_RETIK = CCMCRORIGE.revertUpdTick
Endif
[L]ASTATUS = max(fmet CCMCRORIGE.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(CCMCRORIGE.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 CCMCRORIGE.ASTALIN = [V]CST_ALL
Endif
Return



