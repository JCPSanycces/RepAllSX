#<AdxTL>@(#)1.0.0.0 $Revision$
Raz GBIDC1
Call OBJET("FCT",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "LIENS"      : Gosub LIENS
 When "SEL_LISTE"  : Gosub SEL_LISTE
Endcase
Return

$OUVRE
If clalev([F:TFB])=0 : Local File TABFILBAN [TFB] : Endif
If clalev([F:CAC])=0 : Local File GACCCODE [CAC]  : Endif
Return

$LIENS
For MA=0 To NBMASK
 Gosub SETMASK From =WINPROG
Next MA
Return

################################################
## Etiquettes des masques FCT1 et FTC2
################################################
Subprog AS_POSCOD(VALEUR)
Variable Char    VALEUR()
If [M]CRY="" : [M]CRY = GPAYS : Endif
End

Subprog C_FILEXT(VALEUR)
Variable Char    VALEUR()
If [M]FILNAM=""
 VALEUR=""
Elsif VALEUR = ""
 GMESSAGE = mess(92,121,1)    # Extension obligatoire
 mkstat=2
Endif
End

$SEL_LISTE
Case COUZON
  When "FILNAM"  : Gosub S_FILNAM
Endcase
Return

$S_FILNAM
Raz NBTEX
TIT = mess(122,124,1) : # Sélection Fichier
CRITERE  = "RECTYP=1 & ORDNUM=0 & NUM=1"
For [TFB]TFB0 Where evalue (CRITERE)
 If NBTEX+1>dim(TEX)-1 : Break : Endif
 If !find([F:TFB]COD,TEX(1..NBTEX))
  NBTEX +=1
  TEX(NBTEX) = [F:TFB]COD
  TEXTE(NBTEX) = format$("K:10X",[F:TFB]COD)-[F:TFB]DES
 Endif
Next
Return

Subprog C_FILNAM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Look [TFB]TFB0(1) = VALEUR
If fstat
 GMESSAGE = mess(101,100,1) : # Fichier inexistant
 mkstat = 2
Endif
End
######################################################################################
## Section automatically added (screen FCT2) 06/22/2015 12:02:02 (LUCUE)
## SAM 88426 - 2015-06-22 by LUCUE : Factoring Management
######################################################################################
Subprog AM_FCTTYP(VALEUR)
Variable Integer VALEUR
If VALEUR<2
   Raz [M]FCTBAN, [M]BANACC, [M]BANCPY, [M]BANFCY, [M]BANBPR, [M]BANCUR
   Affzo [M]FCTBAN
   Affzo [M]BANACC
   Affzo [M]BANCPY
   Affzo [M]BANFCY
   Affzo [M]BANBPR
   Affzo [M]BANCUR
Endif
If VALEUR<3
   Raz [M]FCTRES
   Affzo [M]FCTRES
Endif
End

Subprog AM_FCTBAN(VALEUR)
Variable Char    VALEUR()
If !clalev ([F:BAN]): Local File BANK: Endif
Read [BAN]BAN0=VALEUR
If !fstat
   [M:FCT2]BANACC=[F:BAN]BANACC
   [M:FCT2]BANBPR=[F:BAN]BANBPR
   [M:FCT2]BANCPY=[F:BAN]CPY
   [M:FCT2]BANFCY=[F:BAN]FCY
   [M:FCT2]BANCUR=[F:BAN]CUR
   [M:FCT2]TYPRAT=[F:BAN]CHGTYP
   If [M:FCT2]TYPRAT=0: [M:FCT2]TYPRAT=1: Endif
   Call LECMAINPLAN(1,[M:FCT2]BANCPY,[M:FCT2]COA) From CPTDIV
   Affzo [M:FCT2]BANACC
   Affzo [M:FCT2]BANCPY
   Affzo [M:FCT2]BANFCY
   Affzo [M:FCT2]BANBPR
   Affzo [M:FCT2]BANCUR
Endif

End

Subprog C_FCTRES(VALEUR)
Variable Decimal VALEUR
If VALEUR > 100
  GMESSAGE = mess(279,182,1) : # 'Incorrect numeric value'
  mkstat = 2
Endif
End
# End SAM 88426
