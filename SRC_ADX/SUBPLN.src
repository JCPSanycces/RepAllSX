    ORDRE = "COD"
#JASMI - 2016-11-03 - END
  Endcase

Return

#####################################
Subprog SETWEEK(ANNEE)
Value Integer ANNEE
Local Integer I
#JOJAC - 2017-07-20 - X3-46065 - START
#Local Integer D
#Local Date VDAT
#JOJAC - 2017-07-20 - X3-46065 - END
[M]NBRWEK = 52
If aweek(52,ANNEE)+6<gdat$(28,12,ANNEE)
 [M]NBRWEK += 1
Endif
For I=1 To [M]NBRWEK
 Call SEMAINE(ANNEE,I,[M]DAT1(I-1),[M]DAT2(I-1))

Next I
#MIPEA - 2017-11-20- US X3-63170- START
Affzo [M:PLN1]20
#MIPEA - 2017-11-20- US X3-63170- END
End

#####################################
$INICRE
$INIMOD
Local Char SEMTYP(GLONSTY)
SEMTYP = [F]WEKTYP(0)
For I=0 To [M]NBRWEK-1
 If [F]WEKTYP(I)=""
  [F]WEKTYP(I) = SEMTYP
 Else
  SEMTYP = [F]WEKTYP(I)
 Endif
Next I

