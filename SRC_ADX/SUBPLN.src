Subprog CONTPLN(COD)
Variable Char COD()

  If GFONCTION = "GESPLN" | COD="" : End : Endif

  If clalev([F:PLN])=0 : Local File PLANTYP [PLN] : Endif

  If COD <> ""
    Filter [F:PLN] Where COD=[L]COD
    Read [F:PLN] First
    Filter [F:PLN]
    If fstat
        GMESSAGE = COD-":"-mess(23,100,1)
        mkstat = 2 : End
    Else
        Filter [F:PLN]
        Filter [F:PLN] Where COD=[L]COD & LEG=GCURLEG
        If fstat
          Filter [F:PLN] Where COD=[L]COD
          Read [F:PLN] First
          GMESSAGE = COD-":"-mess(62,127,1)-":"-[F:PLN]LEG
          mkstat = 2 : End
        Endif
    Endif
  Endif
  Filter [F:PLN]

End

Subprog TUNPLN(COD)
Variable Char COD()

  Local Integer TOKILL
  TOKILL = 0
  If dim(VCOD)<1
   Global Char VCOD(GLONPLN)
   TOKILL = 1
  Endif

  If clalev([F:PLN])=0 : Local File PLANTYP [PLN] : Endif

  # To update the PRF code after the tunnel order
  VCOD = COD

  If VCOD="" & GLECOBJ=2
    Filter [PLN] Where LEG=GCURLEG
    Read [F:PLN] First
    Filter [PLN]
    If !fstat : VCOD=[F:PLN]COD : Endif
  Else
    #Read [PRF]PRF0 = GCURLEG;VCOD
    Filter [PLN] Where COD=VCOD&LEG=GCURLEG
    Read [F:PLN] First
    Filter [PLN]
    If !fstat : VCOD=[F:PLN]COD : Endif
  Endif

  Call OBJET("PLN",VCOD,GCURLEG) From GOBJET

  COD = VCOD

  If TOKILL : Kill VCOD : Endif

End
#JASMI - 2016-11-03 - END

