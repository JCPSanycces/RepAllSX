##############################################################################
Subprog C_WEKTYP(VALEUR)
Variable Char VALEUR()
If nolign=1 & VALEUR=""
 mkstat = 1 : End
Endif
#ADNGO - 2016-11-17 - START
If !clalev([F:WTY]) : Local File TYPWEEK [WTY] : Endif
Filter [WTY] Where COD=VALEUR & LEG=GCURLEG
Read [F:WTY] First
Filter [F:WTY]
If fstat
  #If  [WTY]LEG <> "" & GCURLEG <> [F:WTY]LEG  Then
  If VALEUR <>""
    mkstat=2
    GMESSAGE=VALEUR-mess(62,127,1)-'"'+[F:WTY]LEG-'"':
  Endif
#ADNGO - 2017-07-13 - X3-33756 - START
Else
  If VALEUR <> ""
    [M:PLN1]WEKTYPDES(nolign-1) = [F:WTY]DES : Affzo WEKTYPDES(nolign-1)
  Endif
#ADNGO - 2017-07-13 - X3-33756 - END
#JASMI - 2017-12-06 - X3-67453 - START
  If [M:PLN1]FIRDAY <> [F:WTY]FIRDAY & VALEUR <> ""
    GMESSAGE = mess(258,10702,1)
    mkstat   = 2
  Endif
#JASMI - 2017-12-06 - X3-67453 - END
Endif
#ADNGO - 2016-11-17 - END

#JASMI - 2017-12-06 - X3-67453 - START
##MIPEA - 2017-11-29- US X3-63170- START
#If [F:PLN]FIRDAY <> [F:WTY]FIRDAY & VALEUR <> ""
##MIPEA - 2017-12-05- US X3-63170- START
#  GMESSAGE = mess(258,10702,1)
##  GMESSAGE = ESS(258,10702,1)
##MIPEA - 2017-12-05- US X3-63170- END
#  mkstat   = 2
#Endif
##MIPEA - 2017-11-29- US X3-63170- END
#JASMI - 2017-12-06 - X3-67453 - END

End

Subprog AM_YEA(VALEUR)
Variable Decimal VALEUR
Call SETWEEK(VALEUR)
Affzo 20
End

Subprog C_YEA(VALEUR)
Variable Decimal VALEUR
If VALEUR<1600 : mkstat = 1 : End : Endif
End

Subprog B2_WEKTYP(VALEUR)
Variable Char    VALEUR()
Local Integer I
#ADNGO - 2017-07-13 - X3-33756 - START
If !clalev([F:WTY]) : Local File TYPWEEK [F:WTY] : Endif
Filter [F:WTY] Where  COD=[M:PLN1]WEKTYP(nolign-1) & LEG=GCURLEG
Read [F:WTY] First
If !fstat
#ADNGO - 2017-07-13 - X3-33756 - END
For I=nolign-1 To [M]NBRWEK-1
 [M]WEKTYP(I) = VALEUR : [M]WEKTYPDES(I) = [F:WTY]DES #ADNGO - 2017-07-14
Next I
#ADNGO - 2017-07-13 - X3-33756 - START
#Affzo WEKTYP,ZWEKTYP
Affzo WEKTYP,WEKTYPDES
Endif
#ADNGO - 2017-07-13 - X3-33756 - END
End

######################################################################
## Date de début et de fin d'une semaine
######################################################################
Subprog SEMAINE(ANNEE,SEMAINE,DEBUT,FIN)
Value    Integer ANNEE
Value    Integer SEMAINE
Variable Date    DEBUT
Variable Date    FIN
Gosub DECAL
DEBUT = DECAL+aweek(SEMAINE,ANNEE)
FIN   = DECAL+aweek(SEMAINE,ANNEE)+6

End

######################################################################
## Année et semaine d'une date
######################################################################
Subprog DAT(DAT,ANNEE,SEMAINE)
Value    Date    DAT
Variable Integer ANNEE
Variable Integer SEMAINE
Local Integer NBSEM
Gosub DECAL
SEMAINE = week(DAT-DECAL)
ANNEE   = year(DAT-DECAL)
NBSEM = 52
If aweek(52,ANNEE)+6<gdat$(28,12,ANNEE)
 NBSEM += 1
Endif
If SEMAINE=0 & ANNEE>0 : # si DAT=[00/00/00]
 ANNEE  -= 1
 SEMAINE = week(gdat$(31,12,ANNEE))
Elsif SEMAINE>NBSEM
 ANNEE += 1
 SEMAINE = 1
Endif
End

#####################################
$DECAL
Local Integer DECAL
If GFIRDAY<5
 DECAL = GFIRDAY-1
Else
 DECAL = GFIRDAY-8
Endif

Return

# FQ103486
########################################################################
##
########################################################################
#**
#* For employee (contract isn't mandatory), return is there a reference planning
#*
#* @param DAT
#* @param DATFIN
#* @param MATRI
#* @param CODE
#* @param SITE
#* @param CTR
#*!
Funprog ISPLANNING(DAT,DATFIN,MATRI,CODE,SITE,CTR)
Value    Date    DAT
Value    Date    DATFIN
Value    Char    MATRI ()
Value    Char    CODE ()
Value    Char    SITE ()
Value    Char    CTR()
Local Integer WOK
If GTPS
  If clalev([F:PLE])=0 : Local File PLANEMP   [PLE] : Endif
#MIPEA - 2017-11-20- US X3-63170- START
  If clalev([F:HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif
  Filter [F:HRCTR8] Where [F:HRCTR8]REFNUM = MATRI & [F:HRCTR8]CTRNUM = CTR
  Read [F:HRCTR8]CTR0(2) = MATRI;CTR
  Filter [F:HRCTR8]
  Call SET_GFIRDAY([F:HRCTR8]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-20- US X3-63170- END
Endif
WOK=1
If GTPS
   Read [PLE]PLE0=MATRI;DAT;CTR
   If fstat & func SUBPLN.GETSEMTYP(DAT,DATFIN,MATRI,CODE,SITE,CTR) = ""
      WOK=0
   Endif
Else
   If func SUBPLN.GETSEMTYP(DAT,DATFIN,MATRI,CODE,SITE,CTR) = ""
      WOK=0
   Endif
Endif
End WOK

# FQ103486
########################################################################
## Reference week for employee(MATRI,ANNEE,SEMAINE) => SEMTYP
########################################################################
#**
#* For employee (contract isn't mandatory), return reference week
#*
#* @param DATDEB Date début
#* @param DATFIN Date fin
#* @param MATRI
#* @param CODE
#* @param SITE
#* @param CTR
#* return Code of SEMTYP
#*!
Funprog GETSEMTYP(DAT,DATFIN,MATRI,CODE,SITE,CTR)
Value    Date    DAT
Value    Date    DATFIN
Value    Char    MATRI ()
Value    Char    CODE ()
Value    Char    SITE ()
Value    Char    CTR()
Local Date    FINCTR
Local Char    PLNCUR(GLONPLN)
Local Date    DEBUT , FIN
Local Char    SEMTYP(GLONSTY)
Local Integer ANNEE , SEMAINE
Local Date    DEBCTR , FINCTR
If clalev([F:PLN])=0 : Local File PLANTYP   [PLN] : Endif
If clalev([F:WTY])=0 : Local File TYPWEEK   [WTY] : Endif
If clalev([F:HLY])=0 : Local File HLYDAY    [HLY] : Endif
If clalev([F:AD]) =0 : Local File EMPLOAD   [AD]  : Endif
If clalev([F:CTR])=0 : Local File EMPLOCTR  [CTR] : Endif
Call DAT(DAT,ANNEE,SEMAINE)
Gosub SETSEM
End [L]SEMTYP

######################################################################
## Horaire théorique d'une journée
######################################################################
# FQ92876 - La table PLNEMP contient maintenant les axes, il faut donc les récupérer
Subprog JOUR_AXE(MATRI,DAT,TYP,JOUR,HEURE,JNUIT,SITE,CTR,NUMPLG,HREDEB,HREFIN,TPSBRK,NATACT,CCE,INITSEC,DIECOMP)
Value    Char    MATRI ()
Value    Date    DAT
Value    Integer NUMPLG
Value    Char    SITE ()
Value    Char    CTR()
Variable Integer TYP
Variable Decimal JOUR(1..)
Variable Decimal HEURE(1..)
Variable Integer JNUIT
Variable Char    HREDEB ()
Variable Char    HREFIN ()
Variable Decimal TPSBRK
Variable Char    NATACT ()
Variable Char    CCE()(1..)
Variable Integer INITSEC
Variable Char    DIECOMP()(1..)
#MIPEA - 2017-11-20- US X3-63170- START
  If clalev([F:HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif
  Filter [F:HRCTR8] Where [F:HRCTR8]REFNUM = MATRI & [F:HRCTR8]CTRNUM = CTR
  Read [F:HRCTR8]CTR0(2) = MATRI;CTR
  Filter [F:HRCTR8]
  Call SET_GFIRDAY([F:HRCTR8]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-20- US X3-63170- END
Goto CALC_JOUR

Subprog JOUR(MATRI,DAT,TYP,JOUR,HEURE,JNUIT,SITE,CTR,NUMPLG,HREDEB,HREFIN,TPSBRK,NATACT,CCE,INITSEC)
Value    Char    MATRI ()
Value    Date    DAT
Value    Integer NUMPLG
Value    Char    SITE ()
Value    Char    CTR()
Variable Integer TYP
Variable Decimal JOUR(1..)
Variable Decimal HEURE(1..)
Variable Integer JNUIT
Variable Char    HREDEB ()
Variable Char    HREFIN ()
Variable Decimal TPSBRK
Variable Char    NATACT ()
Variable Char    CCE()(1..)
Variable Integer INITSEC

$CALC_JOUR
Local Integer ANNEE , SEMAINE , K , L
Local Char    SEMTYP(GLONSTY)
Local Date    DEBUT , FIN
Local Date    DEBCTR , FINCTR
Local Char    PLNCUR(GLONPLN)
Local Decimal LNBRHOU,LNBRDAY

If clalev([F:PLN])=0 : Local File PLANTYP   [PLN] : Endif
If clalev([F:PLE])=0 : Local File PLANEMP   [PLE] : Endif
If clalev([F:WTY])=0 : Local File TYPWEEK   [WTY] : Endif
If clalev([F:HLY])=0 : Local File HLYDAY    [HLY] : Endif
If clalev([F:AD]) =0 : Local File EMPLOAD   [AD]  : Endif
#ADNGO - 2016-01-26 - START
#If clalev([F:CTR])=0 : Local File EMPLOCTR  [CTR] : Endif
#If clalev([F:CTR2]) =0 : Local File EMPLOCTR [CTR2] : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR  [HRCTR] : Endif
If clalev([F:HRCTR2]) =0 : Local File EMPLOCTR [HRCTR2] : Endif
#ADNGO - 2016-01-26 - END
Raz TYP,JOUR,HEURE,JNUIT, HREDEB, HREFIN, TPSBRK, NATACT, CCE, INITSEC

Call DAT(DAT,ANNEE,SEMAINE)
If [F:HLY]YEA<>ANNEE
 #ADNGO - 2016-01-26 - START
 #Read [HLY]HLY0 = ANNEE;SITE
 Read [HLY]HLY0 = ANNEE;SITE;GCURLEG
 #ADNGO - 2016-01-26 - END
 If fstat
 #ADNGO - 2016-01-26 - START
  #Read [HLY]HLY0 = ANNEE;""
  Read [HLY]HLY0 = ANNEE;"";GCURLEG
 #ADNGO - 2016-01-26 - END
 Endif
Else
 fstat = 0
Endif
If year(DAT)<>ANNEE
#ADNGO - 2016-01-26 - START
 #Read [HLY]HLY0 = year(DAT);SITE
 Read [HLY]HLY0 = year(DAT);SITE;GCURLEG
#ADNGO - 2016-01-26 - END
 If fstat
 #ADNGO - 2016-01-26 - START
  #Read [HLY]HLY0 = year(DAT);""
  Read [HLY]HLY0 = year(DAT);"";GCURLEG
 #ADNGO - 2016-01-26 - END
 Endif
Endif
If !fstat
 If find(DAT,[F:HLY]HLYDAY(0..[F:HLY]NBRDAY-1))
  TYP = 3
  # On ne fait pas End car le planning salarié peut mentioner que le salarié travaille ce jour férié
 Endif
Endif

Read [PLE]PLE0=MATRI;DAT;CTR
If !fstat
 TYP     = [F:PLE]TYPDAY
 LNBRDAY = [F:PLE]NBRDAY
 LNBRHOU = [F:PLE]NBRHOU
 # Même si pas de plage horaire, possibilité d'avoir une nature d'activité par jour de la semaine
 If NUMPLG=0
  NATACT = [F:PLE]NATCOD(0)
  For AXE=1 To min(GOPTCANA,9) : # On a max 9 axes dans le planning opérationnel
   CCE(AXE) = evalue("[F:PLE]CCE"+num$(AXE)+"(0)")
   # FQ92876 - Récupération des axes
   If dim(DIECOMP)>0 Then
    DIECOMP(AXE) = [F:PLE]DIE(AXE-1)
   Endif
  Next
 Elsif NUMPLG<=GNBHOR
  HREDEB = [F:PLE]STRTIM(NUMPLG-1)
  HREFIN = [F:PLE]ENDTIM(NUMPLG-1)
  TPSBRK = [F:PLE]BRKTIM(NUMPLG-1)
  NATACT = [F:PLE]NATCOD(NUMPLG-1)
  For AXE=1 To min(GOPTCANA,9) : # On a max 9 axes dans le planning opérationnel
   CCE(AXE) = evalue("[F:PLE]CCE"+num$(AXE)+"("+num$(NUMPLG-1)+")")
   # FQ92876 - Récupération des axes
   If dim(DIECOMP)>0 Then
    DIECOMP(AXE) = [F:PLE]DIE(AXE-1)
   Endif
  Next
 Endif
 INITSEC = 1
Else
 If TYP=3 : End : Endif : # Jour chômé
 Gosub SETSEM
 If SEMTYP="" :  TYP = 0 : End : Endif
 K       = DAT-DEBUT
 TYP     = [F:WTY]TYPDAY(K)
 LNBRDAY = [F:WTY]NBRDAY1(K)
 LNBRHOU = [F:WTY]NBRHRS1(K)
 # Même si pas de plage horaire, possibilité d'avoir une nature d'activité par jour de la semaine
 NATACT = [F:WTY]NATCOD0(K)
 Case NUMPLG
  When 1
   HREDEB = [F:WTY]STRTIM0(K)
   HREFIN = [F:WTY]ENDTIM0(K)
   TPSBRK = [F:WTY]BRKTIM0(K)
  When 2
   HREDEB = [F:WTY]STRTIM1(K)
   HREFIN = [F:WTY]ENDTIM1(K)
   TPSBRK = [F:WTY]BRKTIM1(K)
   NATACT = [F:WTY]NATCOD1(K)
  When 3
   HREDEB = [F:WTY]STRTIM2(K)
   HREFIN = [F:WTY]ENDTIM2(K)
   TPSBRK = [F:WTY]BRKTIM2(K)
   NATACT = [F:WTY]NATCOD2(K)
 Endcase
Endif

Case TYP
 When 1 : # Ouvrable
  JOUR(1) = LNBRDAY
  JOUR(2) = 0
 When 2 : # Ouvré
  JOUR(1) = LNBRDAY
  JOUR(2) = LNBRDAY
 When 3 : # Chômé
  JOUR(1) = 0
  JOUR(2) = 0
Endcase

HEURE(1) = LNBRHOU
HEURE(2) = LNBRHOU

If NATACT<>""
 If clalev([F:NAT])=0  : Local File NATACTIV  [NAT]  : Endif
 #ADNGO - X3PEOP-2655 - 26-10-2016 - START
 #Call LECTURE("NAT",NATACT,"") From CONTOBJ
 Call LECTURE("NAT",NATACT,GCURLEG) From CONTOBJ
 #ADNGO - X3PEOP-2655 - 26-10-2016 - END
 JNUIT = [F:NAT]DAYNGT
Endif
End

###########################################################################################
## Calcul nb de jours/heures entre 2 dates en f(calendrier)
###########################################################################################
Subprog VALORIS(DATDEB,DATFIN,MATRI,CODE,JOUR,HEURE,SITE,CTR)
Value    Date    DATDEB
Value    Date    DATFIN
Value    Char    MATRI ()
Value    Char    CODE ()
Variable Decimal JOUR
Variable Decimal HEURE
Value    Char    SITE ()
Value    Char    CTR()
Goto VALOR

#FRLAA  - 2015/05/29 - REQUIREMENT 108197 - US 3564 - START
Subprog VALORDETWKD(DATDEB,DATFIN,MATRI,CODE,DJOUR,DHEURE,SITE,CTR,VPHI)
Value    Date    DATDEB
Value    Date    DATFIN
Value Integer VPHI
Value    Char    MATRI()
Value    Char    CODE ()
Variable Decimal DJOUR(1..)
Variable Decimal DHEURE(1..)
Value    Char    SITE ()
Value    Char    CTR()
Local Decimal JOUR , HEURE
Goto VALOR
#FRLAA  - 2015/05/29 - REQUIREMENT 108197 - US 3564 - END

Subprog VALORDET(DATDEB,DATFIN,MATRI,CODE,DJOUR,DHEURE,SITE,CTR)
Value    Date    DATDEB
Value    Date    DATFIN
Value    Char    MATRI()
Value    Char    CODE ()
Variable Decimal DJOUR(1..)
Variable Decimal DHEURE(1..)
Value    Char    SITE ()
Value    Char    CTR()
Local Decimal JOUR , HEURE
Goto VALOR

Subprog VALORDETAM(DATDEB,DATFIN,MATRI,CODE,DJOUR,DHEURE,SITE,CTR,AM)
Value    Date    DATDEB
Value    Date    DATFIN
Value    Char    MATRI()
Value    Char    CODE ()
Variable Decimal DJOUR(1..)
Variable Decimal DHEURE(1..)
Value    Char    SITE ()
Value    Char    CTR()
Value    Integer AM
Local Decimal JOUR , HEURE
Goto VALOR

Subprog VALORTYP(DATDEB,DATFIN,MATRI,CODE,JOUR,HEURE,SITE,CTR,PTYPDAY)
Value    Date    DATDEB
Value    Date    DATFIN
Value    Char    MATRI ()
Value    Char    CODE ()
Variable Decimal JOUR
Variable Decimal HEURE
Value    Char    SITE ()
Value    Char    CTR()
Value    Integer PTYPDAY
#76055
If dim(GTABCLE)>0                                                            # vérifie l'existence de la table */
   If GMATRI=MATRI                                                           # si nous avons déjà stocké des appels  à VALORTYP*/
       Local Char CLETABLE(80)
       Local Integer WI
       If dim(GFERIE)<0
        CLETABLE = num$(DATDEB)+num$(DATFIN)+CODE+SITE+CTR+num$(PTYPDAY)      # génération de la clé de recherche */
       Else
        CLETABLE = num$(DATDEB)+num$(DATFIN)+CODE+SITE+CTR+num$(PTYPDAY)+num$(GFERIE)      # génération de la clé de recherche */
       Endif
       If GTABIND
        WI=find(CLETABLE,GTABCLE(1..GTABIND-1))                                #               RECHERCHE                         */
        If WI<>0                                                              # SI TROUVÉ ALORS RENVOYER LES VALEURS ATTENDUES */
          JOUR=GTABJOUR(WI)
          HEURE=GTABHEURE(WI)
          End                                                                 # et sortie de VALORTYP */
        Endif
       Endif
    Endif
Endif
#END 76055
Goto VALOR

Subprog VALORISAM(DATDEB,DATFIN,MATRI,CODE,JOUR,HEURE,SITE,CTR,AM)
Value    Date    DATDEB
Value    Date    DATFIN
Value    Char    MATRI ()
Value    Char    CODE ()
Variable Decimal JOUR
Variable Decimal HEURE
Value    Char    SITE ()
Value    Char    CTR()
Value    Integer AM
Goto VALOR

################################
$VALOR
#76055

If dim(GOUVTABW)<0 or (dim(GOUVTABW)>0 and GOUVTABW=0)                                                          # vérifie l'existence de la table */
 If dim(GOUVTABW)>0
    GOUVTABW=1
 Endif
 If GTPS
  If clalev([F:PLE])=0 : Local File PLANEMP   [PLE] : Endif
 Endif
 If clalev([F:PLN])=0 : Local File PLANTYP   [PLN] : Endif
 If clalev([F:WTY])=0 : Local File TYPWEEK   [WTY] : Endif
 If clalev([F:HLY])=0 : Local File HLYDAY    [HLY] : Endif
 If clalev([F:TIM])=0 : Local File TIMCOD    [TIM] : Endif
 If clalev([F:ADW])=0 : Local File ADOVAL    [ADW] : Endif
 If clalev([F:AD])=0  : Local File EMPLOAD   [AD]  : Endif
 If clalev([F:HRCTR])=0 : Local File EMPLOCTR  [HRCTR] : Endif
 If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
 If clalev([F:HRCTR2]) =0 : Local File EMPLOCTR [HRCTR2] : Endif
Endif
#END 76055

Local Integer ANNEE , SEMAINE , ANNCUR , SEMCUR
Local Char    SEMTYP(GLONSTY)
Local Date    DAT , DEBUT , FIN
Local Date    DEBCTR , FINCTR
Local Char    PLNCUR(GLONPLN)
Local Integer K , I, LTYPDAY, J
Local Decimal WJOUR , WHEURE, LNBRHOU, LNBRDAY
Local Decimal LNBRHOUFULL    ##101660
Local Char    CPE(GLONTPS) , CPA(GLONTPS) , PARAM(10)
Local Integer TPS_COMPLET , DIFF_COMPL , FERIE
Local Integer OK
#Local Char    SAUFCY(GLONFCY) : SAUFCY=[F:FCY]FCY
Local Integer WOKPLE #104478
#80141+78461
Local Integer VKILL
VKILL=0
If dim(GFERIE)<1
 Global Integer GFERIE     :#0=non compté 1= compté
 GFERIE=0 : VKILL=1
Endif

If dim(DJOUR)>0  : Raz DJOUR  : Endif
If dim(DHEURE)>0 : Raz DHEURE : Endif

If CODE=""
#JASMI - START
# Read [TIM]TIM0 = GTPSW
 Read [TIM]TIM0 = GCURLEG; GTPSW
#JASMI - END
Elsif [F:TIM]COD<>CODE
#JASMI - START
# Read [TIM]TIM0 = [L]CODE
 Read [TIM]TIM0 = GCURLEG; [L]CODE
#JASMI - END
Endif

Local Integer VTYPDAY
If dim(PTYPDAY)>0
 VTYPDAY=PTYPDAY
Else
 VTYPDAY=[F:TIM]DAYTYP
Endif

If dim(GTPSCREAGLOB) > 0
  PARAM=GTPSPARINITCP
  CPA=GTPSPARCPA
  CPE=GTPSPARCPE
Else
  Call PARAM("","INITCP",PARAM) From ADOVAL
  Call PARAM("","CPA",CPA) From ADOVAL
  Call PARAM("","CPE",CPE) From ADOVAL
Endif

DIFF_COMPL = (val(PARAM)=2)
Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATFIN
Read [HRCTR]CTR1 Last
Filter [HRCTR]
If fstat<=2
 # FQ85820 - On cherche si on a une fiche de rétroactivité relative aux champs ETRFCY et ETRSRV
 If dim([M]PYRDAT)>0 Then
#JASMI - START
#  TPS_COMPLET = (val(func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,[M]PYRDAT,"TYPJOB","CTR"))=1)
  TPS_COMPLET = (val(func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,[M]PYRDAT,"TYPJOB","HRCTR"))=1)
#JASMI - END
 Else
 # Fin FQ85820
  TPS_COMPLET = ([F:HRCTR]TYPJOB=1)
 Endif
Else
 TPS_COMPLET = 1
Endif
# FQ85820 - On cherche si on a une fiche de rétroactivité relative aux champs ETRFCY et ETRSRV
If dim([M]PYRDAT)>0 Then
#JASMI - START
# Call LECTURE("FCY",func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,[M]PYRDAT,"ETRFCY","CTR"),"") From CONTOBJ
 Call LECTURE("FCY",func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","HRCTR"),"") From CONTOBJ
#JASMI - END
Else
 # Fin FQ85820
 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
Endif
If [F:AD]REFNUM<>MATRI
 Read [AD]AD0 = MATRI
Endif

DAT = DATDEB
#MIPEA - 2017-11-20- US X3-63170- START
If clalev([F:HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif
Filter [F:HRCTR8] Where [F:HRCTR8]REFNUM = MATRI & [F:HRCTR8]CTRNUM = CTR
Read [F:HRCTR8]CTR0(2) = MATRI;CTR
Filter [F:HRCTR8]
Call SET_GFIRDAY([F:HRCTR8]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-20- US X3-63170- END
Call DAT(DATDEB,ANNEE,SEMAINE)
If GTPS
 Read [PLE]PLE0=MATRI;DATDEB;CTR
 If fstat
  Gosub SETSEM
  # FQ96100 - Réinitialiser [F:FCY] en sortie
  If SEMTYP="" : End : Endif
  #If SEMTYP=""
  # Call LECTURE("FCY",SAUFCY,"") From CONTOBJ
  # End
  #Endif
  # Fin FQ96100
 Endif
Else
 Gosub SETSEM
 # FQ96100 - Réinitialiser [F:FCY] en sortie
 If SEMTYP="" : End : Endif
 #If SEMTYP=""
 #  Call LECTURE("FCY",SAUFCY,"") From CONTOBJ
 #  End
 #Endif
 # Fin FQ96100
Endif
ANNCUR = ANNEE
SEMCUR = SEMAINE
#JASMI - START
#Read [HLY]HLY0 = ANNEE;SITE
Read [HLY]HLY0 = ANNEE;SITE;GCURLEG
#JASMI - END
If fstat
#JASMI - START
# Read [HLY]HLY0 = ANNEE;""
 Read [HLY]HLY0 = ANNEE;"";GCURLEG
#JASMI - END
Endif
If year(DATDEB)<>ANNEE
#JASMI - START
# Read [HLY]HLY0 = year(DATDEB);SITE
 Read [HLY]HLY0 = year(DATDEB);SITE;GCURLEG
#JASMI - END
 If fstat
#JASMI - START
#  Read [HLY]HLY0 = year(DATDEB);""
  Read [HLY]HLY0 = year(DATDEB);"";GCURLEG
#JASMI - END
 Endif
Endif
#Point d'entrée AV_VALOR
GPOINT = "AV_VALOR" : Gosub ENTREE From EXEFNC
# FQ96100 - Réinitialiser [F:FCY] en sortie
If OK : End : Endif
#If OK
#  Call LECTURE("FCY",SAUFCY,"") From CONTOBJ
#  End
#Endif
# Fin FQ96100

Raz JOUR,HEURE
For I=1 To (DATFIN-DATDEB)+1
 Raz LNBRHOU, LNBRDAY
 Raz LNBRHOUFULL    ##101660
#MIPEA - 2017-11-20- US X3-63170- START
 If clalev([F:HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif
 Filter [F:HRCTR8] Where [F:HRCTR8]REFNUM = MATRI & [F:HRCTR8]CTRNUM = CTR
 Read [F:HRCTR8]CTR0(2) = MATRI;CTR
 Filter [F:HRCTR8]
 Call SET_GFIRDAY([F:HRCTR8]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-20- US X3-63170- END
 Call DAT(DAT,ANNEE,SEMAINE)
 If GTPS
  Read [PLE]PLE0 = MATRI;DAT;CTR
 Endif
 Raz WOKPLE #104478
 If GTPS & !fstat
  LNBRHOU = [F:PLE]NBRHOU
  LNBRDAY = [F:PLE]NBRDAY
  LTYPDAY = [F:PLE]TYPDAY
  WOKPLE=1 #104478
 Else
  If SEMAINE<>SEMCUR or ANNEE<>ANNCUR or DAT>FINCTR
   Gosub SETSEM
   If SEMTYP="" : Break : Endif
   ANNCUR = ANNEE
   SEMCUR = SEMAINE
  Endif

  K = DAT-DEBUT
  LNBRHOU = [F:WTY]NBRHRS1(K)
  LNBRDAY = [F:WTY]NBRDAY1(K)
  LTYPDAY = [F:WTY]TYPDAY(K)
 Endif
 LNBRHOUFULL=LNBRHOU     ##101660
 If dim([L]AM)>0 & [L]AM=1
  LNBRDAY = LNBRDAY/2
  LNBRHOU = LNBRHOU/2    ##101660
 Endif
 If ANNEE<>[F:HLY]YEA
#JASMI - START
#  Read [HLY]HLY0 = ANNEE;SITE
  Read [HLY]HLY0 = ANNEE;SITE;GCURLEG
#JASMI - END
  If fstat
#JASMI - START
#   Read [HLY]HLY0 = ANNEE;""
   Read [HLY]HLY0 = ANNEE;"";GCURLEG
#JASMI - END
  Endif
 Endif
 If year(DAT)<>ANNEE
#JASMI - START
#  Read [HLY]HLY0 = year(DAT);SITE
  Read [HLY]HLY0 = year(DAT);SITE;GCURLEG
#JASMI - END
  If fstat
#JASMI - START
#   Read [HLY]HLY0 = year(DAT);""
   Read [HLY]HLY0 = year(DAT);"";GCURLEG
#JASMI - END
  Endif
 Endif

FERIE = find(DAT,[F:HLY]HLYDAY(0..[F:HLY]NBRDAY-1))
Raz WJOUR,WHEURE

#FRLAA  - 2015/05/29 - REQUIREMENT 108197 - US 3564 - START
If dim(VPHI) > 0
  If VPHI = 1
    FERIE = find(DAT,[F:HLY]HLYDAY(0..[F:HLY]NBRDAY-1))
    Else
      Raz FERIE
  Endif
Endif
#FRLAA  - 2015/05/29 - REQUIREMENT 108197 - US 3564 - END

 Case [F:TIM]COD
  When CPE
   If !FERIE & LTYPDAY=2
    If !TPS_COMPLET or DIFF_COMPL=1
     WJOUR  = 1
     WHEURE = LNBRHOUFULL   ##101660
     If (dim([L]AM)>0 & [L]AM=1) & DIFF_COMPL=1
      WJOUR  = LNBRDAY
      WHEURE = LNBRHOU      ##101660
     Endif
     #WHEURE = LNBRHOU      ##101660
    Else
     If LTYPDAY=2 : # ouvré
      WJOUR  = LNBRDAY
      WHEURE = LNBRHOU
     Endif
    Endif
   Endif
  When CPA
   If !FERIE & LTYPDAY<=2 : # ouvrable ou ouvré
    If !TPS_COMPLET or DIFF_COMPL=1
     WJOUR  = 1
     WHEURE = LNBRHOUFULL    ##101660
     If (dim([L]AM)>0 & [L]AM=1) & DIFF_COMPL=1
      WJOUR  = LNBRDAY
      WHEURE = LNBRHOU       ##101660
     Endif
     #WHEURE = LNBRHOU       ##101660
    Else
     WJOUR  = LNBRDAY
     WHEURE = LNBRHOU
    Endif
   Endif
  When Default
   Case VTYPDAY
    When 1 : # Jours ouvrables
     If (!FERIE | GFERIE) or CODE=""
&       or WOKPLE #104478
      If LTYPDAY<=2 : # Ouvrable ou ouvrés
       WJOUR  = LNBRDAY
       WHEURE = LNBRHOU
      Endif
     Endif
    When 2 : # Jours ouvrés
     If (!FERIE | GFERIE) or CODE=""
&       or WOKPLE #104478
      If LTYPDAY=2 : # Ouvrés
       WJOUR  = LNBRDAY
       WHEURE = LNBRHOU
      Endif
     Endif
    When 3 : # Calendaires
     WJOUR = 1
     If (!FERIE | GFERIE) or CODE=""
&       or WOKPLE #104478
      If LTYPDAY<=2 : # Pour les evts en jours calendaires, on prend les heures ouvrées & ouvrables !
       WHEURE = LNBRHOU
      Endif
     Endif
   Endcase
 Endcase
 If dim(DJOUR)>0  : DJOUR(I)  = WJOUR  : Endif
 If dim(DHEURE)>0 : DHEURE(I) = WHEURE : Endif
 JOUR  += WJOUR
 HEURE += WHEURE
 DAT += 1
Next I
#Point d'entrée AP_VALOR
GPOINT = "AP_VALOR" : Gosub ENTREE From EXEFNC

#76055
If dim(PTYPDAY)>0
 If dim(GTABCLE)>0     # vérifie l'existence de la table */
    If [V]GMATRI<>MATRI          # SI MATRICULE DIFFÉRENT */
       [V]GMATRI=MATRI           # RÉINITIALISER LE CACHE TABLEAU */
       [V]GTABIND=1
       Raz [V]GTABCLE,[V]GTABJOUR,[V]GTABHEURE
    Endif
    If [V]GMATRI=MATRI # si matricule courant */
       Local Char CLETABLE(50)
       If dim(GFERIE)<0
        CLETABLE= num$(DATDEB)+num$(DATFIN)+CODE+SITE+CTR+num$(PTYPDAY)  # calcul cle */
       Else
        CLETABLE= num$(DATDEB)+num$(DATFIN)+CODE+SITE+CTR+num$(PTYPDAY)+num$(GFERIE)  # calcul cle */
       Endif
       [V]GTABCLE([V]GTABIND)=CLETABLE  # stocker la cle */
       [V]GTABJOUR([V]GTABIND)=JOUR     # stocker la valeur JOUR */
       [V]GTABHEURE([V]GTABIND)=HEURE   # stocker la valeur HEURE */
       [V]GTABIND+=1
    Endif
 Endif
Endif
#END 76055

#80141+78461
If dim(GFERIE)>=0 & VKILL
 Kill GFERIE
Endif

# FQ96100 - Réinitialiser [F:FCY] en sortie
#Call LECTURE("FCY",SAUFCY,"") From CONTOBJ
End

########################################################################
## Semaine type d'un matricule (MATRI,ANNEE,SEMAINE) => SEMTYP
########################################################################
$SETSEM
If clalev([F:HRCTR2])=0 : Local File EMPLOCTR         [HRCTR2] : Endif
# FQ82073 - Si CTR2 est déjà utilisé et renseigné dans un autre traitement, il faut le sauvegarder
If [F:HRCTR2]CTRNUM<>"" Then
  Local Char SCTRNUM : SCTRNUM=[F:HRCTR2]CTRNUM
  Local Char SREFNUM : SREFNUM=[F:HRCTR2]REFNUM
  Local Date SCTRDAT : SCTRDAT=[F:HRCTR2]CTRDAT
Endif
# Fin FQ82073
SEMTYP = ""

# 76055 - Performances arrêté des temps
If dim(GTPSMAT) > 0
  If [F:HRCTR]REFNUM=[V]GTPSMAT & [L]CTR=[V]GTPSCTR & [F:HRCTR]CTRDAT=[V]GTPSCTRDAT & [L]DAT=[V]GTPSDAT
&  &  [L]ANNEE=[V]GTPSANNCUR & [L]SEMAINE=[V]GTPSSEMCUR & [F:WTY]COD=[V]GTPSSEMTYP
    [L]FINCTR = [V]GTPSFINCTR
    [L]PLNCUR = [V]GTPSPLNCUR
    [L]DEBUT  = [V]GTPSDEBUT
    [L]FIN    = [V]GTPSFIN
    [L]SEMTYP = [V]GTPSSEMTYP
    Return
  Endif
Endif
#END 76055

# Recherche dans planning type du salarié
If PLNCUR="" or [F:HRCTR]REFNUM<>MATRI or DEBCTR<>[F:HRCTR]CTRDAT or DAT>FINCTR
 # FQ85820 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
 # Filter [CTR2] Where REFNUM=[L]MATRI & CTRNUM=[L]CTR & CTRDAT<=[L]DAT
 Filter [HRCTR2] Where REFNUM=[L]MATRI & CTRNUM=[L]CTR & (CTRDAT<=[L]DAT | (FLGRET=2 & RETDATEFF<=[L]DAT))
 # Fin FQ85820
 Read [HRCTR2]CTR1 Last
 Filter [HRCTR2]
 # FQ85820 - On cherche si on a une fiche de rétroactivité relative aux champs ETRFCY et ETRSRV
 If dim([M]PYRDAT)>0 Then
  PLNCUR = func SUBCTRRET.FIND_RETRO_FLD([L]MATRI,[L]CTR,[F:HRCTR2]CTRDAT,[M]PYRDAT,"PLNTYP","HRCTR2")
 Else
  # Fin FQ85820
  PLNCUR = [F:HRCTR2]PLNTYP
 Endif
 DEBCTR = [F:HRCTR2]CTRDAT
 # FQ85820 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
 # Filter [CTR2] Where REFNUM=[L]MATRI & CTRNUM=CTR & CTRDAT>DEBCTR
 Filter [HRCTR2] Where REFNUM=[L]MATRI & CTRNUM=CTR & (CTRDAT>DEBCTR | (FLGRET=2 & RETDATEFF>DEBCTR))
 # Fin FQ85820
 Read [HRCTR2]CTR1 First
 Filter [HRCTR2]
 If fstat>2
  FINCTR = [31/12/2999]
 Else
  FINCTR = [F:HRCTR2]CTRDAT-1
 Endif
Endif

# Pas de planning type
If PLNCUR="" : PLNCUR = GPLANNING : Endif
If PLNCUR="" : Return : Endif
If [F:PLN]COD<>PLNCUR or [F:PLN]YEA<>ANNEE
#ADNGO - X3PEOP-2655 - 13-10-2016 - START
 Read [PLN]PLN0 = ANNEE;PLNCUR;GCURLEG
 #ADNGO - X3PEOP-2655 - 13-10-2016 - END
Else
 fstat = 0
Endif
If !fstat
 SEMTYP = [F:PLN]WEKTYP(SEMAINE-1)
Endif

If SEMTYP="" : Return : Endif

If [F:WTY]COD<>SEMTYP
#JASMI - START
# Read [WTY]WTY0 = SEMTYP
 Read [WTY]WTY0 = GCURLEG;SEMTYP
#JASMI - END
Endif
Call SEMAINE(ANNEE,SEMAINE,DEBUT,FIN)

# 76055 - Performances arrêté des temps)
If dim(GTPSMAT) > 0
  [V]GTPSMAT    =[F:HRCTR]REFNUM
  [V]GTPSCTR    =[L]CTR
  [V]GTPSCTRDAT =[L]DEBCTR
  [V]GTPSFINCTR =[L]FINCTR
  [V]GTPSDAT    =[L]DAT
  [V]GTPSANNCUR =[L]ANNEE
  [V]GTPSSEMCUR =[L]SEMAINE
  [V]GTPSSEMTYP =[F:WTY]COD
  [V]GTPSPLNCUR =[L]PLNCUR
  [V]GTPSDEBUT  =[L]DEBUT
  [V]GTPSFIN    =[L]FIN
Endif
#END 76055

# FQ82073 - Si CTR2 est déjà utilisé et renseigné dans un autre traitement, il faut le sauvegarder
If dim(SCTRNUM)>0 Then
  Read [F:HRCTR2]CTR0=SREFNUM;SCTRNUM;SCTRDAT
Endif
Return

