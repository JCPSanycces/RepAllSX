#<AdxTL>@(#)0.0.0.0 $Revision$
# < DEBUG> ###############################################################################################
Call OUVRE_TRACE("") From LECFIC
Local File ADOSSIER [F:ADS]
Read [F:ADS]DOSSIER = "GX3APP"
If !fstat
    Call AMAJ
    Call MAJ
Endif
Call SUPP_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End
# </DEBUG> ###############################################################################################



##########################################################################################################
# ... MAJ70 : Update to do for the release 70 = Version V10 = AVENGER
#
# Subprog ATRCMAJ
# Subprog AMAJ
# Subprog MAJ
#
##########################################################################################################
#
##########################################################################################################
## Part  Financials  -  Common Data Module : Before validation
##########################################################################################################
##-------------------------------------------------------------------------------------------------------#
Subprog ATRCMAJ
##-------------------------------------------------------------------------------------------------------#
#** Appelé depuis DOSMAJ70
#*!

End
##########################################################################################################
## Part Financials - Accounting Module : Before validation
##########################################################################################################
##-------------------------------------------------------------------------------------------------------#
Subprog AMAJ
##-------------------------------------------------------------------------------------------------------#
#** Appelé depuis DOSMAJ70
#*!
Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT71 #YYFIN_104036_US4
Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT72 #YYFIN_110215_US8

#
If [F:ADS]DOSHIS<>""
 Call ECR_TRACE("UTICPT72 : Start of process on : "+[F:ADS]DOSHIS,0) From GESECRAN
 # Step 0 : Update abreviation (add U9)
 If filinfo(filpath("FIL","DCLVATBEL","fde",[F:ADS]DOSHIS),0)>0
  If clalev([F:ZZZ])<>0  : Close Local File [ZZZ] : Endif
  Local File =[F:ADS]DOSHIS+".ATABLE" [ZZZ]
  GOK = 1
  Trbegin [ZZZ]
  Update [ZZZ] Where CODFIC="DCLVATBEL" With ABRFIC="DLVBU9"
  If !fstat
   Call ECR_TRACE("UTICPT72 : File ATABLE,  Code DCLVATBEL, update abbreviation",0) From GESECRAN
  Else
   Call ECR_TRACE("UTICPT72 : File ATABLE, ERROR while update ="-num$(fstat),1) From GESECRAN : GOK=0
  Endif
  If GOK<1
   Rollback
  Else
   Commit
  Endif
  Close Local File [ZZZ]
 Endif
 If filinfo(filpath("FIL","DCLVATBELD","fde",[F:ADS]DOSHIS),0)>0
  If clalev([F:ZZZ])<>0  : Close Local File [ZZZ] : Endif
  Local File =[F:ADS]DOSHIS+".ATABLE" [ZZZ]
  GOK = 1
  Trbegin [ZZZ]
  Update [ZZZ] Where CODFIC="DCLVATBELD" With ABRFIC="DLVBDU9"
  If !fstat
   Call ECR_TRACE("UTICPT72 : File ATABLE,  Code DCLVATBELD, update abbreviation",0) From GESECRAN
  Else
   Call ECR_TRACE("UTICPT72 : File ATABLE, ERROR while update ="-num$(fstat),1) From GESECRAN : GOK=0
  Endif
  If GOK<1
   Rollback
  Else
   Commit
  Endif
  Close Local File [ZZZ]
 Endif
 Call ECR_TRACE("UTICPT72 : End of process on : "+[F:ADS]DOSHIS,0) From GESECRAN
Endif
End

##########################################################################################################
## Part Financials - Accounting Module : After validation
##########################################################################################################
##-------------------------------------------------------------------------------------------------------#
Subprog MAJ
#** Appelé depuis DOSMAJ70
#*!
#-- MAJ sequence number value
Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT73 #YYFIN_110215_US12
End

