#Return


###############################################################################
$LOADRESULTSDI
###############################################################################
#--Paramétres de sortie
#   - PHYSTO : stock actuel
#   - FIRAVADAT : date de 1ere dispo
#   - ORDSTO : stock en réappro
#   - C_STODIPSO : collection de 12 colonnes et 3 lignes
#         - 1ere ligne : date
#         - 2éme ligne : stock disponible à la vente
#         - 3éme ligne : total ressources
#   les colonnes sont les dates selon la date de référence et la périodicité
###############################################################################
Local Char       WNUMCOL(40)

If W_CNSSDI = null
    [L]ASTATUS = fmet this.ASETERROR ("", "Data Class : Method call LOADRESULTSDI no W_CNSSDI instance", [V]CST_AERROR)
Endif
this.PHYSTO    = W_CNSSDI.PHYSTO
this.FIRAVADAT = W_CNSSDI.FIRAVADAT
this.ORDSTO    = W_CNSSDI.ORDSTO
For WLINE=1 To 12
      If this.C_STODISPO(WLINE)=null
        WRET = fmet this.ADDLINE("C_STODISPO",WLINE)
        If WRET = [V]CST_ANOTDEFINED
          #--The insertion was not possible
          [L]ASTATUS = fmet this.ASETERROR ("", "Data Class STKCNSSDI : Method call LOADRESULTSDI result error for this.ADDLINE:", [V]CST_AERROR)
          Return
        Endif
      Endif
    If WLINE <=10 : WNUMCOL ="0"+num$(WLINE-1) Else WNUMCOL = num$(WLINE-1) Endif
    Assign ("this.C_STODISPO(WLINE).COL00") With evalue ("W_CNSSDI.C_STODISPO(1).COL"+num$(WNUMCOL))
    Assign ("this.C_STODISPO(WLINE).COL01") With evalue ("W_CNSSDI.C_STODISPO(2).COL"+num$(WNUMCOL))
    Assign ("this.C_STODISPO(WLINE).COL02") With evalue ("W_CNSSDI.C_STODISPO(3).COL"+num$(WNUMCOL))
Next WLINE
Return

