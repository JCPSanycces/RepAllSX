#<AdxTL>@(#)0.0.0.0 $Revision$
#
#                         T R T E N G 0
#########################################################################################################

#########################################################################################################
# Fonction engagement           pesée           GPAO                                                    #
# Paramètre général engagement qui permet 3 valeurs : "1: Par OF"; "2: Par Phase"; "3: Par Pesée"       #
#                                                                                                       #
# LFCY  = Site de production: "" = tous sites                                                           #
#########################################################################################################
#CHECK UNUSED_BEGIN
Local Char PARAM(50)(1..20) , SAVACT(10)
Local Char VALEUR


PARAM(1) = ""
SAVACT = GACTION : GACTION = "SAIENG0"
Call SAISIE_CHAR(VALEUR,PARAM,"FENG0","TRTENG0") From GSAISIE
End

#CHECK UNUSED_END


$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When Default
Endcase
Return


#########################################################
$OUVRE

Global Integer GHCBWCPT
Global Integer GHCBWCPTART
Global Char    GHCBIVALEUR (GLONVCR)
Global Char    GHCBLMFGNUM (GLONVCR)
Global Char    GHCBLITMREF (GLONITM)  # mm 05.08
Global Integer GHCBLBOMOPE
Global Integer GHCBLMFGLIN
Global Integer GHCBLBOMSEQ
Global Date    GHCBLCBTDAT
Global Integer GHCBLMVTSEQ
Global Integer GHCBWBOUT
Global Integer GHCBWCPTENR
Global Integer GHCBLWGGSTA
Global Integer GHCBLRECONCIL
# Issue 82935 - 2012-06-15 by SR
Global Integer GHCBMAX


# lreconcil = 0 pas de reconciliation de faite
# lwggsta = ancien code wggsta
GHCBLWGGSTA = 0
GHCBLRECONCIL = 0
GHCBLMFGNUM = ""
GHCBWBOUT = 5
GHCBWCPT = 0
GHCBWCPTENR = 0
# Issue 82935 - 2012-06-15 by SR
GHCBMAX = 0

# Ouverture des fichiers utilisés
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:WGG])  = 0 : Local File WEIGHING    [WGG]  : Endif
If clalev([F:WGG1]) = 0 : Local File WEIGHING    [WGG1] : Endif   :#DT


Return


#########################################################
$SETBOUT

If GHCBWBOUT = 1
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 0
    ETABOU(GSPE3) = 1
    ETABOU(GSPE4) = 1
Endif
If GHCBWBOUT = 7
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 1
    # 98801 mm 08.2014
    If GENGAGE= 3
      ETABOU(GSPE3) = 0
    Else
      ETABOU(GSPE3) = 1
    Endif
    ETABOU(GSPE4) = 1
Endif
If GHCBWBOUT = 8
    ETABOU(GSPE1) = 1
    ETABOU(GSPE2) = 1
     # 98801 mm 08.2014
    If GENGAGE= 3
      ETABOU(GSPE3) = 0
    Else
      ETABOU(GSPE3) = 1
    Endif
    ETABOU(GSPE4) = 1
Endif
If GHCBWBOUT = 9
    ETABOU(GSPE1) = 1
    ETABOU(GSPE2) = 0
    # 98801 mm 08.2014
    If GENGAGE= 3
      ETABOU(GSPE3) = 0
    Else
      ETABOU(GSPE3) = 1
    Endif
    ETABOU(GSPE4) = 1
Endif

Return

#########################################################
$OUVRE_BOITE
Return

#########################################################
$DEBUT
# Issue 82935 - 2012-06-15 by SR
GHCBMAX = dim([M:ENG0]ITMREF)     # mémorisation nombre de ligne maxi
Gosub TRT_ORDRE
Return

#########################################################
$AV_CHOIX
Return

#########################################################
AP_CHOIX
Return

#########################################################
$AVANT_BOUTON
Case BOUT
     When "a"
      # Issue 98801 - 2014-08-01 by MM
      # Issue 82948 - 2012-06-15 by SR
      If GENGAGE <>3 : Gosub CALCUL : Endif
      If [M:ENG0]NBLIG <> GHCBWCPTENR
        GMESSAGE  = mess(53,2324,1)+num$(GHCBWCPTENR-[M:ENG0]NBLIG)
        GERR = 1
        Return
      Endif
Endcase
Return

#########################################################
$FINSAI
Kill GHCBWCPT
Kill GHCBWCPTART
Kill GHCBIVALEUR
Kill GHCBLMFGNUM
Kill GHCBLITMREF
Kill GHCBLBOMOPE
Kill GHCBLMFGLIN
Kill GHCBLBOMSEQ
Kill GHCBLCBTDAT
Kill GHCBLMVTSEQ
Kill GHCBWBOUT
Kill GHCBWCPTENR
Kill GHCBLWGGSTA
Kill GHCBLRECONCIL
# Issue 82935 - 2012-06-15 by SR
Kill GHCBMAX


GBIDC1 = ""

#Nettoie l'écran avant de partir.
Raz [M:ENG0]

Return

#########################################################
$FIN
Gosub TRT_FIN :#DT
Return

#########################################################
$ABANDON
Return

#########################################################
$APRES_MODIF
Return

#########################################################
$BOUTON
Case BOUT

     When "a" Gosub TRT_ENREGISTREMENT
     When "b" Gosub TRT_SUPPRIMER
     When "c" Gosub TRT_ABANDON
     When Default
Endcase
Return

#########################################################
$ONMENU
Return


#########################################################
# Sous-programmes bouton
#########################################################
$TRT_FIN
If GHCBLRECONCIL <> 0
    If GENGAGE<>3
        Call ERREUR(mess(48,2324,1)) From GESECRAN
        # suppression engagement
        Gosub TRT_SUPPRIME
    Endif
Endif

GHCBIVALEUR = ""
Gosub MAJ_MFGHEAD

Return
#########################################################
$TRT_ABANDON
If GHCBLRECONCIL <> 0
    OK=1
    # 98801 mm 08.2014
    If GENGAGE <>3
      Call OUINON(mess(48,2324,1),OK) From GESECRAN
    Else
      Call OUINON(mess(76,2324,1),OK) From GESECRAN
    Endif
    If OK <> 2 : mkstat=2 : Return : Endif
Endif
# suppression engagement
# 98801 mm 08.2014
If GENGAGE <>3
  Gosub TRT_SUPPRIME
Else
  Gosub TRT_SUPPRIME_ENGAGEMENT_PESEE
Endif
# retour saisie ordre
GHCBIVALEUR = ""
Gosub MAJ_MFGHEAD
Gosub TRT_ORDRE

GHCBWCPT = 0
ACTION = "ABANDON" : Gosub ACTION
Return
##########################################################
$TRT_SUPPRIMER
# Confirmation de la suppression
OK=1
Call OUINON(mess(49,2324,1),OK) From GESECRAN
If OK <> 2 : mkstat=2 : Return : Endif
# suppression engagement
Gosub TRT_SUPPRIME
# retour saisie ordre
Gosub TRT_ORDRE
Return

#########################################################
$TRT_ENREGISTREMENT
Local Integer J
#  lecture historique

 If [M:ENG0]NBLIG <> 0

    #DT-21/06/2010
    For J=0 To [M:ENG0]NBLIG-1

        GHCBLMFGLIN = [M:ENG0]MFGLIN([L]J)
        GHCBLBOMSEQ = [M:ENG0]BOMSEQ([L]J)
        GHCBLCBTDAT = [M:ENG0]CBTDAT([L]J)
        GHCBLMVTSEQ = [M:ENG0]MVTSEQ([L]J)

        Call DEBTRANS From GLOCK
        Trbegin [WGG]

        Readlock [WGG]WGG0 = [M:ENG0]MFGNUM;[M:ENG0]BOMOPE([L]J);[M:ENG0]ITMREF([L]J);GHCBLMFGLIN;GHCBLBOMSEQ;GHCBLCBTDAT;GHCBLMVTSEQ
        If fstat=1     GOK=-1 : GLOCK="$WEIGHING"-GHCBLMFGNUM : Gosub TRT_ROLL : Return
        Elsif fstat GOK=0  : Call RSTA("WGG",GHCBLMFGNUM) From GLOCK :  Gosub TRT_ROLL : Return
        Endif

        [F:WGG]ENGCOD = 2        :# DT
        [F:WGG]ENGDAT = date$    :# DT
        # Issue number 82926- 2012-06-14 by SR
        [F:WGG]ENGUSR = GUSER
        [F:WGG]ENGTIM = mid$(time$,1,2)+mid$(time$,4,2)
        GHCBLRECONCIL = 1
        Rewrite [F:WGG]
        If fstat
           GOK = 0 : Call FSTA("WGG") From GLOCK : Return
        Endif
        Commit

        #DT-22/06/2010 -> If GENGAGE =1
        Gosub CALCUL

        If GHCBWCPTENR = 0
            OK=1
            If GENGAGE<>3
              Call OUINON(mess(50,2324,1),OK) From GESECRAN
              If OK <> 2  Gosub TRT_SUPPRIME
              Else
                          Gosub TRT_VALIDATION
                          # Issue 82948 - 2012-06-18 by SR
                          If WOK = 6
                             If GRECONCIL <> 2
                               GHCBIVALEUR = ""
                               Gosub TRT_ORDRE
                             Else
                               GHCBLRECONCIL = 0
                                Effzo [M:ENG0]15
                                Raz [M:ENG0]NBLIG
                                Raz [M:ENG0]BOMOPE0,WCPTENR
                                Actzo [M:ENG0]BOMOPE0
                                Affzo [M:ENG0]BOMOPE0,WCPTENR
                                zonsui = "[M:ENG0]BOMOPE0"
                              Endif
                          Endif
              Endif
           Else
            # Issue 98801- 2014-08-01 by MM - cas de l'engagement par pesée
              Call OUINON(mess(75,2324,1),OK) From GESECRAN
              If OK <> 2
                 Gosub TRT_SUPPRIME_ENGAGEMENT_PESEE
                 Effzo [M:ENG0]15
                 Raz [M:ENG0]NBLIG
                 Raz[M:ENG0]BOMOPE0
                 Grizo[M:ENG0]BOMOPE0
              Else
                 Gosub TRT_VALIDATION
                 If WOK = 6
                    Gosub TRT_ORDRE
                 Else
                    GHCBLRECONCIL = 0
                    GHCBWBOUT = 1
                    Effzo [M:ENG0]15
                    Raz [M:ENG0]NBLIG
                    Raz [M:ENG0]BOMOPE0,WCPTENR
                    Grizo[M:ENG0]BOMOPE0
                 Endif
              Endif
           Endif
        Else
             GHCBWBOUT = 1
             If [M:ENG0]WEU([L]J) <> ""
                    If GHCBLRECONCIL = 1 GHCBWBOUT = 8
                    Else
                                         GHCBWBOUT = 9
                    Endif
             Else
                    If GHCBLRECONCIL = 1 GHCBWBOUT = 7
                    Endif
             Endif
            ACTION = "SETBOUT" : Gosub ACTION

            If  J=[M:ENG0]NBLIG-1
                Call MESSAGE (mess(53,2324,1)+num$(GHCBWCPTENR)) From GESECRAN
            Endif

        Endif
    Next J   :# DT-21/06/2010
Endif  :# DT-21/06/2010
Return

########################################################################
# sous programme :
########################################################################

$TRT_VALIDATION
# verification que l'engagement soit fait sur toutes les matieres pesées
# sont exclus de l'engagement les phases de rectification et les QSP
#            code à servir 8 9 10 (michel clement mail du 23 11 01)
# sr 03.02 ainsi que les mouvements de type "fin de contenant"
# sr 01.03 ainsi que les mouvements de type "Inventaire"
# sr 09.03 ainsi que les matières pesée en fabrication (code à servir 3,5,7)
#          En fait on garde les PCK : 2,4,6

For [MFM]MFM0 Where MFGFCY = [M:ENG0]MFGFCY         &
&                   MFGNUM = [M:ENG0]MFGNUM         &
&                   MATSTA <> 4                     &
&                   (WGGSTA = 3 |WGGSTA = 5 )       &
&                   find([F:MFM]PKC,2,4,6)          &
&    ([V]GENGAGE<>2  | BOMOPE = [M:ENG0]BOMOPE0)
         WOK = 0
         For [WGG]WGG0 Where MFGNUM = [M:ENG0]MFGNUM     &
&                            MFGLIN = [F:MFM]MFGLIN      &
&                            ITMREF = [F:MFM]ITMREF      &
&                            BOMSEQ = [F:MFM]BOMSEQ      &
&                            BOMOPE = [F:MFM]BOMOPE      &
&                            WEIWEI <> 0                 &
&                            WEIFLG <> 4                 &
&                            WEIFLG <> 5                 &
&                           ([V]GRECONOBLI<>2| [WGG]RCLCOD=2)


         If [F:WGG]ENGCOD <> 2 WOK = 9 : Break : Endif             # 04.02
         If [F:WGG]ENGCOD =  2 WOK = 1 : Endif                     # 04.02
         Next

         If WOK = 1
                  Call DEBTRANS From GLOCK
                  Trbegin [MFM]

                  Readlock [F:MFM] Curr
                  If fstat=1     GOK=-1 : GLOCK="$MFM"-GHCBLMFGNUM : Gosub  TRT_ROLL :  Break  # mm 05.11 - Ctrl des sources avant Return
                  Elsif fstat GOK=0  : Call RSTA("MFM",GHCBLMFGNUM) From GLOCK : Gosub TRT_ROLL : Break  #  mm 05.11 -Ctrl des sources avant Return
                  Endif

                  [F:MFM]WGGSTA = 7

                  Rewrite [F:MFM]
                  If fstat       GOK = 0 : Call FSTA("MFM") From GLOCK : Gosub TRT_ROLL : Break :  Endif  #  mm 05.11 - Ctrl des sources avant Return
                  Commit

         Endif
Next
If GOK<= 0 Return Endif #  mm 05.11 -  Ctrl des sources Ligne ajoutée

# verification que toutes les matieres soient réconciliées (wggsta = 5)
# sont exclu de l'engagement les phases de rectification et les QSP
#            code à servir 8 9 10 (michel clement mail du 23 11 01)
# sr 09.03 on ne traite que les PKC = 2,4,6

    WOK = 6
# mm 05.11 - l'ensemble des matières doivent être engagées pour modifier le statut de l'entête.

For [MFM]MFM0 Where  MFGFCY = [M:ENG0]MFGFCY     &
&                    MFGNUM = [M:ENG0]MFGNUM     &
&                    MATSTA <> 4                 &
&                    find([F:MFM]PKC,2,4,6)
                                                    # &   ([V]GENGAGE<>2  | BOMOPE = [M:ENG0]BOMOPE0)
    WOK = 6
    If [F:MFM]WGGSTA <> 7 : WOK = 9 : Break : Endif
Next

# X3-85050.sn JOBRO 05/06/2018
# We have to check if there are unweighed material lines
# of type (8,9) before we can update header
If WOK<>9
For [F:MFM]MFM0 Where MFGFCY = [M:ENG0]MFGFCY     &
&                    MFGNUM = [M:ENG0]MFGNUM     &
&                    MATSTA <> 4                 &
&                    find([F:MFM]PKC,8,9)        &
&                    WGGSTA = 1
    WOK=9
    Break
Next
Endif
#X3-85050.en

# si engagement par phase/pesée : pas de mise à jour [MFG] si l'ensemble des matières
# ne sont pas engagées
If WOK =9
  If GENGAGE = 2
     Call MESSAGE (mess(47,2324,1)) From GESECRAN
     WOK = 6
  Elsif GENGAGE = 3
     Call MESSAGE (mess(74,2324,1)) From GESECRAN
  Endif
  Return
Endif

If WOK = 6
     GHCBLWGGSTA     = 8
     [M:ENG0]WGGSTA  = 8
     Call MAJ_FICHIERS ("MFG",7,GHCBLWGGSTA,[M:ENG0]MFGNUM,"",0,0) From SCALEXCHAN
     Call MESSAGE (mess(47,2324,1)) From GESECRAN

# sr 10.03
# si il reste des matières pesées en fabrication non encore pesées,
# on remet l'OF dans le plan de pesée et statut "fin de pesée en box"

    For [F:MFM]MFM0 Where MFGFCY = [M:ENG0]MFGFCY          &
&                         MFGNUM = [M:ENG0]MFGNUM          &
&                         MATSTA <> 4                      &
&                         find([F:MFM]PKC,3,5,7)
      If [F:MFM]WGGSTA < 3
         Call MAJ_FICHIERS ("MFG",3,3,[M:ENG0]MFGNUM,"",0,0) From SCALEXCHAN  # plan de pesée / fin de pesée box
         GHCBLWGGSTA    = 3
         [M:ENG0]WGGSTA = 3
         Break
      Endif
    Next
Endif

Return
#########################################################
$TRT_ROLL
Rollback
Return

#########################################################
$TRT_SUPPRIME
For [WGG]WGG0 Where MFGNUM = [M:ENG0]MFGNUM         &
&                   WEIWEI <> 0                     &
&                   CCLDAT = [0/0/0]                &
&                   ENGCOD =  2                     &
&                   WEIFLG <> 4                     &
&                   WEIFLG <> 5                     &
&   ([V]GENGAGE<>2 | BOMOPE = [M:ENG0]BOMOPE0)

        Call DEBTRANS From GLOCK
        Trbegin [WGG]

        Readlock Curr
        If fstat=1     GOK=-1 : GLOCK="$WEIGHING"-GHCBLMFGNUM : Gosub TRT_ROLL : Break   # mm 06.11 74630 contrôle des sources
        Elsif fstat GOK=0  : Call RSTA("WGG",GHCBLMFGNUM) From GLOCK : Gosub TRT_ROLL : Break   # mm 06.11 74630 contrôle des sources
        Endif

        [F:WGG]ENGCOD = 1
        [F:WGG]ENGDAT = [0/0/0]
        # Issue number 82926- 2012-06-14 by SR
        [F:WGG]ENGUSR = ""
        Raz [F:WGG]ENGTIM
        Rewrite [F:WGG]
        If fstat       GOK = 0 : Call FSTA("WGG") From GLOCK : Gosub TRT_ROLL : Break  # mm 06.11 74630 contrôle des sources
        Endif
        Commit
Next
Return

#########################################################
$TRT_SUPPRIME_ENGAGEMENT_PESEE
For [WGG]WGG0 Where MFGNUM = [M:ENG0]MFGNUM         &
&                   BOMOPE = [M:ENG0]BOMOPE(0)      &
&                   ITMREF = [M:ENG0]ITMREF(0)      &
&                   MFGLIN = [M:ENG0]MFGLIN(0)      &
&                   BOMSEQ = [M:ENG0]BOMSEQ(0)      &
&                   CBTDAT = [M:ENG0]CBTDAT(0)      &
&                   MVTSEQ = [M:ENG0]MVTSEQ(0)

        Call DEBTRANS From GLOCK
        Trbegin [WGG]

        Readlock First
        If fstat=1     GOK=-1 : GLOCK="$WEIGHING"-GHCBLMFGNUM : Gosub TRT_ROLL : Break   # mm 06.11 74630 contrôle des sources
        Elsif fstat GOK=0  : Call RSTA("WGG",GHCBLMFGNUM) From GLOCK : Gosub TRT_ROLL : Break   # mm 06.11 74630 contrôle des sources
        Endif
        [F:WGG]ENGCOD = 1
        [F:WGG]ENGDAT = [0/0/0]
        [F:WGG]ENGUSR = ""
        Raz [F:WGG]ENGTIM
        Rewrite [F:WGG]

        If fstat       GOK = 0 : Call FSTA("WGG") From GLOCK : Gosub TRT_ROLL :  Break  # mm 06.11 74630 contrôle des sources
        Endif
        Commit

        Break
Next
Return

#########################################################
$MAJ_MFM

Call DEBTRANS From GLOCK
Trbegin [MFM]

# MAJ [MFM]
For [MFM]MFM0 Where MFGFCY = [M:ENG0]MFGFCY     &
&                   MFGNUM = [M:ENG0]MFGNUM     &
&                   MATSTA <> 4                 &
&                   WGGSTA = 7                  &
&                   find([F:MFM]PKC,2,4,6)      &
&    ([V]GENGAGE<>2 | BOMOPE = [M:ENG0]BOMOPE0)

      Readlock [F:MFM] Curr
      If fstat=1     GOK=-1 : GLOCK="$MFM"- [M:ENG0]MFGNUM : Gosub  TRT_ROLL : Break            # FQ 69909 Ctrl des sources avant Return
      Elsif fstat GOK=0  : Call RSTA("MFM", [M:ENG0]MFGNUM) From GLOCK : Gosub TRT_ROLL : Break # FQ 69909 Ctrl des sources avant Return
      Endif
      WOK = 0
      For [WGG]WGG0 Where MFGNUM = [M:ENG0]MFGNUM     &
&                         MFGLIN = [F:MFM]MFGLIN      &
&                         ITMREF = [F:MFM]ITMREF      &
&                         BOMSEQ = [F:MFM]BOMSEQ      &
&                         BOMOPE = [F:MFM]BOMOPE      &
&                         WEIWEI <> 0                 &
&                         WEIFLG <> 4                 &
&                         WEIFLG <> 5

         If [F:WGG]RCLCOD =  2 &  [F:WGG]RCLDAT <> [0/0/0] : WOK = 1 : Break : Endif                     # 04.02
      Next

      If WOK = 1
          [F:MFM]WGGSTA = 5     # réconciliée
      Else
          [F:MFM]WGGSTA = 3     # pesée
      Endif
      Rewrite [F:MFM]
      If fstat       GOK = 0 : Call FSTA("MFM") From GLOCK : Gosub TRT_ROLL : Break         # FQ 69909 Ctrl des sources avant Return
      Endif
Next

Commit
Gosub MAJ_ENTETE

Return

#########################################################
$MAJ_ENTETE

Call DEBTRANS From GLOCK
Trbegin [MFG]

WOK =0
# l'ensemble des matières doit pesée ou réconciliée
# sinon situation de pesée de l'entête  =  non pesée
For [MFM]MFM0 Where  MFGFCY = [M:ENG0]MFGFCY     &
&                    MFGNUM = [M:ENG0]MFGNUM     &
&                    MATSTA <> 4                 &
&                    find([F:MFM]PKC,2,4,6)

    WOK = 0
    If !find ( [F:MFM]WGGSTA ,3,5) : WOK = 9 : Break : Endif
Next

# situation de pesée de l'entête = non pesé
If WOK = 9
   Call MAJ_FICHIERS ("MFG",0,1,[M:ENG0]MFGNUM,"",0,0) From SCALEXCHAN
Else
# situation de pesée de l'entête = fin de pesée totale
  Call MAJ_FICHIERS ("MFG",0,8,[M:ENG0]MFGNUM,"",0,0) From SCALEXCHAN
Endif

If GOK < 1  Gosub  TRT_ROLL
Else Commit
      Call MESSAGE (mess(78,2324,1)) From GESECRAN
Endif

Return

#########################################################
$TRT_ORDRE

Actzo  [M:ENG0]MFGFCY
Actzo  [M:ENG0]MFGNUM
#Actzo  [M:ENG0]BOMOPE0
Raz [M:ENG0]
Affzo [M:ENG0]

GHCBLRECONCIL = 0
GHCBWBOUT     = 1
GHCBWCPT      = 0

#DT-22/06/2010
If [M:ENG0]MFGFCY<>""
    Gosub CHARGE_PARAM

    If  [V]GENGAGE=2
        Actzo[M:ENG0]BOMOPE0
    Else
        Raz[M:ENG0]BOMOPE0
#RDH18022011
#        Diszo[M:ENG0]BOMOPE0
        Grizo[M:ENG0]BOMOPE0
    Endif

Endif
Return


#########################################################
$TRT_ITMREF
Actzo  [M:ENG0]ITMREF(nolign-1)
Gosub TRT_RAZITMREF

GHCBLRECONCIL = 0
GHCBWBOUT     = 1

Return


#########################################################
$TRT_RAZITMREF

[M:ENG0]BOMOPE(nolign-1)  = 0
[M:ENG0]LOT(nolign-1)     = ""
[M:ENG0]WEU(nolign-1)     = ""
[M:ENG0]WEIWEI(nolign-1)  = 0

Affzo [M:ENG0]ITMREF(nolign-1)
Affzo [M:ENG0]LOT(nolign-1)
Affzo [M:ENG0]WEIWEI(nolign-1)
Affzo [M:ENG0]WEU(nolign-1)
Affzo [M:ENG0]BOMOPE(nolign-1)
Return

#########################################################
$TRT_RAZORDRE
[M:ENG0]MFGNUM  = ""
[M:ENG0]WCPTENR = 0
Affzo [M:ENG0]MFGNUM
Affzo [M:ENG0]WCPTENR
Return


########################################################################
# calcul nombre de pesée à engager pour un of
########################################################################
$CALCUL
Local Char CRIT_WGG(250),CRIT_WGG1(250),CRIT_WGG2(250)

#GHCBWCPTENR = 0

If [V]GENGAGE<=0 | [V]GRECONOBLI<=0
    Gosub CHARGE_PARAM
Endif

If GENGAGE<>3
  GHCBWCPTENR = 0  # 98801 mm 07.2014 - ligne déplacée
  Gosub SEL_WGG

  Filter [WGG] Where evalue([L]CRIT_WGG) & evalue([L]CRIT_WGG1)
   For [WGG]WGG0
      GHCBWCPTENR += 1
   Next
  Filter [WGG]
  [M:ENG0]WCPTENR = GHCBWCPTENR
Else

  [M:ENG0]WCPTENR -=1
  GHCBWCPTENR =  [M:ENG0]WCPTENR
Endif

Affzo  [M:ENG0]WCPTENR

Return

########################################################################
$SEL_WGG

Raz[L]CRIT_WGG,CRIT_WGG1

[L]CRIT_WGG   = "[WGG]MFGNUM=[M:ENG0]MFGNUM & [WGG]WEIWEI<>0 &[WGG]ENGDAT=[0/0/0] & [WGG]ENGCOD<>2"
[L]CRIT_WGG  -= "&[WGG]CCLDAT=[0/0/0]&[WGG]WEIFLG<>4 & [WGG]WEIFLG<>5 & find([F:WGG]PKC,2,4,6)"

[L]CRIT_WGG1  = " ([V]GRECONOBLI<>2|([WGG]RCLDAT<>[0/0/0] & [WGG]RCLCOD=2))"
[L]CRIT_WGG1 -= "&([V]GENGAGE<>2 |([WGG]BOMOPE=[M:ENG0]BOMOPE0 & [M:ENG0]BOMOPE0<>0)|[M:ENG0]BOMOPE0=0)"
#[L]CRIT_WGG2  = " ([V]GENGAGE<>3 |([M:ENG0]NBLIG<>0 & [WGG]BOMOPE=[M:ENG0]BOMOPE(nolign-1))|[M:ENG0]NBLIG=0)"

Return
########################################################################
# recherche element article à engager
########################################################################
$CRTHISTART
GHCBWCPTART = 0

For [WGG]WGG0 Where MFGNUM = [M:ENG0]MFGNUM     &
&                   BOMOPE = GHCBLBOMOPE        &
&                   ITMREF = GHCBLITMREF        &
&                   WEIWEI <> 0                 &
&                   CCLDAT = [0/0/0]            &
&                   ENGCOD <> 2                 &
&                   WEIFLG <> 4                 &
&                   WEIFLG <> 5                 &
&                   find([F:WGG]PKC,2,4,6)      &
&                   ([V]GRECONOBLI<>2 | [WGG]RCLCOD=2)

    GHCBWCPTART += 1
    Break
Next

Return

########################################################################
# recherche element à réconcilier N° pesée
########################################################################
$CRTHIST_PESEE
GHCBWCPT = 0
#  mm 05.11 - RCLDAT peut être =2 si pesée annulée  ENGCOD    <> 2
For [WGG]WGG0 Where  MFGNUM    = [M:ENG0]MFGNUM                          &
&                    MFGTRKNUM = VALEUR                                  &
&                    WEIWEI    <> 0                                      &
&                    CCLDAT    = [0/0/0]                                 &
&                    ENGDAT    = [0/0/0]                                 &
&                    WEIFLG    <> 4                                      &
&                    WEIFLG    <> 5                                      &
&                    find([F:WGG]PKC,2,4,6)                              &
&                    ([V]GRECONOBLI<>2 | [WGG]RCLCOD=2)                  &
&                    ([V]GENGAGE<>2 | BOMOPE = [M:ENG0]BOMOPE0)

            GHCBWCPT += 1
            If GHCBWCPT > 1 Break : Endif
Next
Return

########################################################################
# recherche element à réconcilier lot
########################################################################
$CRTHISTLOT
GHCBWCPT = 0

#DT-21/06/2010
Raz[M:ENG0]MFGLIN(nolign-1),BOMSEQ(nolign-1),CBTDAT(nolign-1),MVTSEQ(nolign-1)

For [WGG]WGG0 Where MFGNUM = [M:ENG0]MFGNUM               &
&                   BOMOPE = [M:ENG0]BOMOPE(nolign-1)     &
&                   WEIWEI <> 0                           &
&                   ITMREF = [M:ENG0]ITMREF(nolign-1)     &
&                   LOT    = VALEUR                       &
&                   CCLDAT = [0/0/0]                      &
&                   ENGCOD <> 2                           &
&                   WEIFLG <> 4                           &
&                   WEIFLG <> 5                           &
&                 ([V]GRECONOBLI<>2 | [WGG]RCLCOD=2)      &
&                 ([M:ENG0]MFGTRKNUM(nolign-1)="" | [WGG]MFGTRKNUM= [M:ENG0]MFGTRKNUM(nolign-1))


    GHCBWCPT += 1
    If GHCBWCPT > 1 Break : Endif
Next

If GHCBWCPT = 1 GHCBLMFGLIN = [F:WGG]MFGLIN
                GHCBLBOMSEQ = [F:WGG]BOMSEQ
                GHCBLCBTDAT = [F:WGG]CBTDAT
                GHCBLMVTSEQ = [F:WGG]MVTSEQ
                #DT-21/06/2010
                [M:ENG0]MFGLIN(nolign-1)     = [F:WGG]MFGLIN
                [M:ENG0]BOMSEQ(nolign-1)     = [F:WGG]BOMSEQ
                [M:ENG0]CBTDAT(nolign-1)     = [F:WGG]CBTDAT
                [M:ENG0]MVTSEQ(nolign-1)     = [F:WGG]MVTSEQ
                [M:ENG0]MFGTRKNUM1(nolign-1) = [F:WGG]MFGTRKNUM

Endif
Return

########################################################################
# recherche element à réconcilier lot + montant
########################################################################
$CRTHISTWEI
Local Integer CTR_PS
#DT-21/06/2010
Raz[M:ENG0]MFGLIN(nolign-1),BOMSEQ(nolign-1),CBTDAT(nolign-1),MVTSEQ(nolign-1)

GHCBWCPT = 0

For [WGG]WGG0 Where MFGNUM = [M:ENG0]MFGNUM               &
&                   BOMOPE = [M:ENG0]BOMOPE(nolign-1)     &
&                   WEIWEI <> 0                           &
&                   ITMREF = [M:ENG0]ITMREF(nolign-1)     &
&                   LOT    = [M:ENG0]LOT(nolign-1)        &
&                   WEIWEI = VALEUR                       &
&                   CCLDAT = [0/0/0]                      &
&                   ENGCOD <> 2                           &
&                   WEIFLG <> 4                           &
&                   WEIFLG <> 5                           &
&                  ([V]GRECONOBLI<>2 | [WGG]RCLCOD=2)     &
&                  ([M:ENG0]MFGTRKNUM(nolign-1)="" | [WGG]MFGTRKNUM= [M:ENG0]MFGTRKNUM(nolign-1))

    GHCBWCPT += 1


    GHCBLMFGLIN = [F:WGG]MFGLIN
    GHCBLBOMSEQ = [F:WGG]BOMSEQ
    GHCBLCBTDAT = [F:WGG]CBTDAT
    GHCBLMVTSEQ = [F:WGG]MVTSEQ

    [M:ENG0]MFGLIN(nolign-1)     = [F:WGG]MFGLIN
    [M:ENG0]BOMSEQ(nolign-1)     = [F:WGG]BOMSEQ
    [M:ENG0]CBTDAT(nolign-1)     = [F:WGG]CBTDAT
    [M:ENG0]MVTSEQ(nolign-1)     = [F:WGG]MVTSEQ
    [M:ENG0]MFGTRKNUM1(nolign-1) = [F:WGG]MFGTRKNUM

    Raz[L]CTR_PS
    Gosub CTR_PESEE
    If [L]CTR_PS =0
        Break
    Endif
Next

If [L]CTR_PS<>0
    GMESSAGE = mess(43,2324,1)+num$([L]CTR_PS) : GERR =2 : mkstat = 2
Elsif GHCBWCPT<>0
    GHCBWCPT =1
Endif

Return

########################################################################
# mise à jour MFGHEAD
########################################################################
$MAJ_MFGHEAD
If GHCBLMFGNUM <> ""
   Call MAJ_FICHIERS ("MFG",0,GHCBLWGGSTA,GHCBLMFGNUM,"",0,0) From SCALEXCHAN
Endif
If GHCBIVALEUR <> ""
    GHCBLMFGNUM = GHCBIVALEUR
    Call MAJ_FICHIERS ("MFG",0,11,GHCBIVALEUR,"",0,0) From SCALEXCHAN   :#ordre bloquee en engagement
    GHCBLWGGSTA = [M:ENG0]WGGSTA
Endif

Return

#########################################################################
#       sous prog ETIQUETTES
#########################################################################
$CHARGE_PARAM

Local Char VALPAR(20)
Call PARAM([M:ENG0]MFGFCY,"ENGAGE",[L]VALPAR) From ADOVAL
[V]GENGAGE = val([L]VALPAR)
Call PARAM([M:ENG0]MFGFCY,"RECONOBLI",[L]VALPAR) From ADOVAL
[V]GRECONOBLI = val([L]VALPAR)
# Issue 82948 - 2012-06-15 by SR : comment
Call PARAM([M:ENG0]MFGFCY,"SELWGG",[L]VALPAR) From ADOVAL
[V]GSELWGG = val([L]VALPAR)

Return
########################################################################
$ETI_MFGNUM

# Lecture MFGHEAD
# sr 01.03 faire un readlock ici (pour être sûr de pouvoir aller jusqu'à la fin sans qu'une
# autre session ne nous prenne l'entête ???

Read [MFG]MFG0 = VALEUR
If fstat :                             GMESSAGE = mess(16,2324,1) : GERR =2  : mkstat = 2 : Return : Endif
If [F:MFG]WGGFLG < 3                   GMESSAGE = mess(44,2324,1) : GERR =2  : mkstat = 2 : Return : Endif
If GENGAGE = 1
  If [F:MFG]WGGFLG < 6 &[V]GRECONOBLI=2
   GMESSAGE = mess(54,2324,1) : GERR =2  : mkstat = 2 : Return
  Endif
Endif
If [F:MFG]WGGSTA = 9                   GMESSAGE = mess(15,2324,1) : GERR =2  : mkstat = 2 : Return : Endif
If [F:MFG]WGGSTA = 11                  GMESSAGE = mess(51,2324,1) : GERR =2  : mkstat = 2 : Return : Endif

If [F:MFG]WGGFLG =  7
    GMESSAGE = mess(45,2324,1) : GERR =2 : mkstat = 2 : Return   :#DT
Endif

# sr 05.03
If [F:MFG]MFGSTA =  4  GMESSAGE = mess(114,193,1) : GERR =2 : mkstat = 2 : Return : Endif

# verification que toutes les matieres soient pesées (wggsta = 3)
# sont exclu de l'engagement les phases de rectification et les QSP
#            code à servir 8 9 10 (michel clement mail du 23 11 01)

WOK = 0
For [MFM]MFM0 Where MFGFCY = [M:ENG0]MFGFCY     &
&                   MFGNUM = VALEUR             &
&                   MATSTA <> 4                 &
&                   find([F:MFM]PKC,2,4,6)
    WOK = 1

    If [F:MFM]WGGSTA =  7 & [V]GENGAGE =1 WOK = 8 : Break : Endif  :#DT-3006
    # mm 05.11- si engagement par phase/pesée => toutes les phases de l'OF n'ont pas besoin d'être pesées
    # seulement les matières de la phase/pesée
    If GENGAGE = 1
     If [F:MFM]WGGSTA  < 3  WOK = 9 : Break : Endif
    Endif
Next

If WOK = 0  GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If WOK = 9  GMESSAGE = mess(17,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If WOK = 8  GMESSAGE = mess(46,2324,1) : GERR =2 : mkstat = 2 : Return : Endif  :#DT

# mm 05.11 : calcul du nombre total de pesée à engager pour un of
If WOK = 1 & GENGAGE = 1

     [M:ENG0]MFGNUM = VALEUR
     Gosub CALCUL
     If GHCBWCPTENR = 0  GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Raz [M:ENG0]MFGNUM
     # Issue 82935 - 2012-06-15 by SR
     Elsif GHCBWCPTENR > GHCBMAX
           GMESSAGE =  mess(60,2324,1)-"\" - mess(61,2324,1): GERR =2 : mkstat = 2 : Raz [M:ENG0]MFGNUM
     Else
#RDH18022011
#         Diszo  [M:ENG0]MFGFCY
#         Diszo  [M:ENG0]MFGNUM
         Grizo  [M:ENG0]MFGFCY
         Grizo  [M:ENG0]MFGNUM

     Endif
Endif
If GENGAGE <> 1
    Grizo  [M:ENG0]MFGFCY
    Grizo  [M:ENG0]MFGNUM
Endif

Return

#########################################################
$ETI_BOMOPE
#DT-22/06/2010
# Lecture MFGMAT
Local Shortint W_BOMOPE
Local Shortint W_WGGSTA
Raz W_BOMOPE
Raz W_WGGSTA

If [V]GENGAGE=2
    # Engagement par phase
    WOK = 0
    For [MFM]MFM0 Where MFGFCY = [M:ENG0]MFGFCY     &
&                       MFGNUM = [M:ENG0]MFGNUM     &
&                       BOMOPE = VALEUR             &
&                       MATSTA <> 4                 &
&                       find([F:MFM]PKC,2,4,6)

      If ([V]GRECONOBLI<>2)
        WOK = 1
        If [F:MFM]WGGSTA = 7   WOK = 8 : Break : Endif
        If [F:MFM]WGGSTA  < 3  WOK = 9 : Break : Endif
       Else
      # mm 06.11 - Si Réconciliation obligatoire de la phase avant l'engagement
         If W_BOMOPE = 0
            W_BOMOPE = [F:MFM]BOMOPE
            W_WGGSTA = [F:MFM]WGGSTA
         Endif
         If W_BOMOPE = [F:MFM]BOMOPE
           If [F:MFM]WGGSTA <  W_WGGSTA  : W_WGGSTA = [F:MFM]WGGSTA : Endif
         Endif

         WOK=1
         If W_WGGSTA = 7   WOK = 8 : Break : Endif
         If W_WGGSTA = 3   WOK = 10 : Break : Endif
         If W_WGGSTA < 3   WOK = 9 : Break : Endif
      Endif
    Next

    If WOK = 0  GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
    If WOK = 9  GMESSAGE = mess(17,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
    If WOK = 8  GMESSAGE = mess(46,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
    If WOK = 10 GMESSAGE = mess(58,2324,1) : GERR =2 : mkstat = 2 : Return : Endif

    If WOK = 1
         [M:ENG0]BOMOPE0 = VALEUR
         Gosub CALCUL
         If GHCBWCPTENR = 0  GMESSAGE = mess(47,2324,1) : GERR =2 : mkstat = 2 : Raz [M:ENG0]BOMOPE0
         # Issue 82935 - 2012-06-15 by SR
         Elsif GHCBWCPTENR > GHCBMAX
               GMESSAGE =  mess(60,2324,1)-"\" - mess(61,2324,1): GERR =2 : mkstat = 2 : Raz [M:ENG0]BOMOPE0
         Endif
    Endif
    Actzo[M:ENG0]BOMOPE0
Else
    Raz [M:ENG0]BOMOPE0
#RDH18022011
#    Diszo[M:ENG0]BOMOPE0
    Grizo[M:ENG0]BOMOPE0

Endif
Return
#########################################################
$ETI_MFGTRKNUM
Local Integer NOL   : [L]NOL=nolign-1

Local Char    ITM
Local Char    LOT
Local Char    WEU
Local Decimal OPE
Local Decimal WEI

Gosub CRTHIST_PESEE

If GHCBWCPT <>0

    Filter[F:WGG1] Where MFGNUM=[M:ENG0]MFGNUM & FCY=[M:ENG0]MFGFCY & MFGTRKNUM=VALEUR & ([V]GENGAGE<>2|BOMOPE=[M:ENG0]BOMOPE0)
    Read[F:WGG1]WGG0 First
    If !fstat

        [L]ITM = [F:WGG1]ITMREF
        [L]OPE = [F:WGG1]BOMOPE
        [L]LOT = [F:WGG1]LOT
        [L]WEI = [F:WGG1]WEIWEI
        [L]WEU = [F:WGG1]WEU


        [M:ENG0]ITMREF(NOL) = [F:WGG1]ITMREF
        [M:ENG0]BOMOPE(NOL) = [F:WGG1]BOMOPE
        [M:ENG0]LOT(NOL)    = [F:WGG1]LOT
        [M:ENG0]WEIWEI(NOL) = [F:WGG1]WEIWEI
        [M:ENG0]WEU(NOL)    = [F:WGG1]WEU


        Affzo[M:ENG0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)

        If mkstat = 0  Call C_ITMREF([L]ITM)     Endif
        If mkstat = 0  Call C_BOMOPE([L]OPE)     Endif
        If mkstat = 0  Call AM_BOMOPE([L]OPE)    Endif
        If mkstat = 0  Call C_LOT([L]LOT)        Endif
        If mkstat = 0  Call AM_LOT([L]LOT)       Endif
        If mkstat = 0  Call C_WEIWEI([L]WEI)     Endif
        If mkstat = 0  Call AM_WEIWEI([L]WEI)    Endif

        If mkstat=0
            [M:ENG0]WEU(NOL)=[L]WEU
            [M:ENG0]WEIWEI(NOL) = [F:WGG1]WEIWEI
#RDH18022011
#            Diszo[M:ENG0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)
            Grizo[M:ENG0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)

        Else
            zonsui = "MFGTRKNUM(" + num$(NOL) + ")"
            GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
        Endif
    Else
        VALEUR =""
    Endif
    Filter[F:WGG1]
Else
    GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
Endif
Return
#########################################################


#########################################################
$ETI_LOT
Gosub CRTHISTLOT
[M:ENG0]WEIWEI(nolign-1) = 0
[M:ENG0]WEU(nolign-1)    = ""

# sr 09.03 mis en commentaire suite à demande de Céline Charron : ils doivent aussi confirmer la quantité même si une seule pesée
#If GHCBWCPT > 1 Actzo [M:ENG0]WEIWEI
#Else Grizo [M:ENG0]WEIWEI
#Endif

If GHCBWCPT = 1 [M:ENG0]WEU(nolign-1)    = [F:WGG]WEU
Elsif GHCBWCPT = 0 : GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
Endif
Return

#########################################################
$ETI_WEIWEI
#DT-21/06/2010
Gosub CRTHISTWEI
[M:ENG0]WEU(nolign-1)    = ""
If GHCBWCPT = 1  [M:ENG0]WEU(nolign-1)    = [F:WGG]WEU
Elsif GHCBWCPT = 0 GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
Endif
Return

#########################################################
$ETI_ITMREF
Gosub CRTHISTART
If GHCBWCPTART = 0 GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Endif
Return
#########################################################################
$CTR_PESEE
Local Integer K
Local Integer NOL1: NOL1=nolign-1

If [M:ENG0]NBLIG<>0
  For K=0 To [M:ENG0]NBLIG-1
     If K<>[L]NOL1 & ([M:ENG0]BOMOPE(K)=[M:ENG0]BOMOPE(NOL1) & [M:ENG0]MFGLIN(K)=[M:ENG0]MFGLIN(NOL1))
        If  [M:ENG0]ITMREF(K)=[M:ENG0]ITMREF(NOL1) & [M:ENG0]BOMSEQ(K)=[M:ENG0]BOMSEQ(NOL1)
          If [M:ENG0]CBTDAT(K)=[M:ENG0]CBTDAT(NOL1) & [M:ENG0]MVTSEQ(K)=[M:ENG0]MVTSEQ(NOL1)
              If [M:ENG0]MFGTRKNUM1(K)=[M:ENG0]MFGTRKNUM1(NOL1)
                 [L]CTR_PS=K+1
                 Break
              Endif
          Endif
       Endif
     Endif
  Next K
Endif
Return

#########################################################################

#########################################################################
#                     ETIQUETTES                                        #
#########################################################################
########################################
Subprog C_MFGNUM(VALEUR)
Variable Char    VALEUR()
Local Integer WOK
# 115017 mm 03.2016
Read [MFG]MFG0 = VALEUR
If !fstat
  If [F:MFG]WGGSTA = 11
    Call OUINON( mess(11,2321,1)-":"- mess(438,198,1)-"?", WOK)From GESECRAN
    If WOK <> 2
       mkstat=2 : End
    Else
      [M:ENG0]MFGNUM = VALEUR
      Gosub ETI_REACTIVATION : Raz VALEUR : Raz [M:ENG0]MFGNUM : End
    Endif
  Endif
Endif

# Issue 82948 - 2012-06-15 by SR
If VALEUR = [M:ENG0]MFGNUM : End : Endif
Gosub ETI_MFGNUM
End

########################################
Subprog AM_MFGNUM(VALEUR)
Variable Char    VALEUR()
Local Integer WOK
# sr 01.03 y-a-t-il des matières exclues
# Si oui on propose d'anabndonner l'engagement
# Issue 82948 - 2012-06-15 by SR : comment
Raz [M:ENG0]BOMOPE0,WCPTENR
Raz [M:ENG0]NBLIG

Filter [F:MFM] Where MFGNUM = VALEUR & MATSTA = 4
Look [F:MFM]MFM0 First
If !fstat
    Filter [F:MFM]
    WOK=1
    Call OUINON(mess(39,2324,1),WOK) From GESECRAN
    If WOK <> 2 : mkstat=2 : End : Endif
Endif
Filter [F:MFM]

GHCBIVALEUR = VALEUR
[M:ENG0]WGGSTA = [F:MFG]WGGSTA
# Issue 82948 - 2012-06-15 by SR : comment
Affzo [M:ENG0]WGGSTA,BOMOPE0,WCPTENR
Affzo [M:ENG0]15
Gosub MAJ_MFGHEAD

End

########################################
Subprog S_MFGNUM(VALEUR)
Variable Char    VALEUR()
########################################
#                              WGGFLG >2  > une peser doit etre faite
#                              WGGSTA <>7 > en reconciliation
#                              WGGSTA <>9 > bloqué en peser
#                              WGGFLG <>6 > reconcilié

Filter [F:MFG] Where MFGFCY = [M:ENG0]MFGFCY &  WGGFLG > 2 & WGGFLG < 7 & WGGSTA <> 9
Call SELECT("MFG","",VALEUR,"") From SELOBJ
Filter [F:MFG]

End

########################################
Subprog C_BOMOPE(VALEUR)
Variable Decimal VALEUR

#DT-21/06/2010
If [V]GENGAGE=2 & VALEUR <> [M:ENG0]BOMOPE0
    GMESSAGE = mess(6,2324,1)  : GERR =2 : mkstat = 2
Else
    GHCBLBOMOPE = VALEUR
    Gosub ETI_ITMREF
Endif

End

########################################
Subprog AM_BOMOPE(VALEUR)
Variable Decimal VALEUR
GHCBLBOMOPE = VALEUR
End

########################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()

Gosub ETI_LOT

GHCBWBOUT = 1

If [M:ENG0]WEU(nolign-1) <> ""
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7
     Endif
Endif
End

########################################
Subprog AM_LOT(VALEUR)
Variable Char    VALEUR()
LLOT = VALEUR
#Gosub ETI_LOT

Affzo  [M:ENG0]WEIWEI(nolign-1)
Affzo  [M:ENG0]WEU(nolign-1)

GHCBWBOUT = 1

If [M:ENG0]WEU(nolign-1) <> ""
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7
     Endif
Endif
End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
GHCBLITMREF = VALEUR
End
########################################
Subprog C_WEIWEI(VALEUR)
Variable Decimal VALEUR

Gosub ETI_WEIWEI
GHCBWBOUT = 1
#DT-21/06/2010
If [M:ENG0]WEU(nolign-1) <> ""
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7
     Endif
Endif

End

########################################
Subprog AM_WEIWEI(VALEUR)
Variable Decimal VALEUR

Affzo  [M:ENG0]WEU(nolign-1)
GHCBWBOUT = 1
#DT-21/06/2010
If [M:ENG0]WEU(nolign-1) <> ""
     If GHCBLRECONCIL = 1 GHCBWBOUT = 8
        Else
                          GHCBWBOUT = 9
     Endif
Else
     If GHCBLRECONCIL = 1 GHCBWBOUT = 7
     Endif
Endif
End
########################################
Subprog C_BOMOPE0(VALEUR)
Variable Decimal  VALEUR
#DT-18/06/2010
If [V]GENGAGE=2 & VALEUR=0
    GMESSAGE = mess(10,123,1) : GERR =2 : mkstat = 2
    End
Endif
Gosub ETI_BOMOPE
End
#########################################
Subprog AS_BOMOPE0(VALEUR)
Variable Decimal  VALEUR
If [M:ENG0]NBLIG>0
#RDH18022008
#    Diszo[M:ENG0]BOMOPE0
    Grizo[M:ENG0]BOMOPE0

Else
    Actzo[M:ENG0]BOMOPE0
Endif
End
########################################
Subprog AM_MFGFCY(VALEUR)
Variable Char     VALEUR
#DT-18/06/2010

[M:ENG0]MFGFCY=VALEUR
Gosub CHARGE_PARAM

If  [V]GENGAGE=2
    Actzo[M:ENG0]BOMOPE0
Else
    Raz[M:ENG0]BOMOPE0
#RDH18022011
#    Diszo[M:ENG0]BOMOPE0
    Grizo[M:ENG0]BOMOPE0

Endif
End
########################################
Subprog AM_SAISIE(VALEUR)
Variable Integer  VALEUR
Local Integer NOL   : [L]NOL=nolign-1
#DT-18/06/2010
If VALEUR=1
    Raz[M:ENG0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)
    #Diszo[M:ENG0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)
    Actzo[M:ENG0]MFGTRKNUM(NOL)
    zonsui = "MFGTRKNUM(" + num$(NOL) + ")"
Else
    Raz[M:ENG0]MFGTRKNUM(NOL)
#    Diszo[M:ENG0]MFGTRKNUM(NOL)
    Grizo[M:ENG0]MFGTRKNUM(NOL)

    Actzo[M:ENG0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)
    zonsui = "ITMREF(" + num$(NOL) + ")"
Endif

End
########################################
Subprog C_MFGTRKNUM(VALEUR)
Variable Char     VALEUR
Local Integer K
Local Integer NOL : [L]NOL=nolign-1

#DT-18/06/2010
If [M:ENG0]SAISIE(NOL)=1 & VALEUR=""
    GMESSAGE = mess(10,123,1) : GERR =2 : mkstat = 2
Else
    If [M:ENG0]NBLIG<>0 & VALEUR<>""
        For K=0 To [M:ENG0]NBLIG-1
            If K<>[L]NOL & [M:ENG0]MFGTRKNUM(K)=VALEUR
                GMESSAGE = mess(43,2324,1)+num$([L]K+1) : GERR =2 : mkstat = 2 : Break
            Endif
        Next K
    Endif
Endif

End
########################################
Subprog AM_MFGTRKNUM(VALEUR)
Variable Char VALEUR
Gosub ETI_MFGTRKNUM
End
########################################
Subprog AS_BOMOPE(VALEUR)
Variable Decimal  VALEUR
If [M:ENG0]BOMOPE0 <>0
    VALEUR=[M:ENG0]BOMOPE0
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran ENG0) 24/05/2011 13:30:26 (MM)
######################################################################################
Subprog AM_NBLIG

If GENGAGE= 3
  GHCBWCPTENR = NBLIG
  [M:ENG0]WCPTENR = GHCBWCPTENR
  Affzo  [M:ENG0]WCPTENR

  # 98801 mm 08.2014
  If GHCBWCPTENR = 1
     # engagement par pesée : traitement d'une seule pesée à la fois
     Call MESSAGE (mess(77,2324,1)) From GESECRAN
     mkstat = 2
  Endif
Endif
End


