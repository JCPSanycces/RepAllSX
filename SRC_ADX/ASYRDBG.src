#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog TOGGLE_DEBUG
 Local Integer ERR
 ##ERR = fmet GACTX.APARAM.CLEAN()
 Call TRACE("TOGGLE_DEBUG 1: dbgmode=[" + num$(dbgmode(0)) + "," + num$(dbgmode(1)) + "," + num$(dbgmode(2)) + "]") From ASYRCOM
 Local Char AECLIMAC(250)
 AECLIMAC = vireblc(fmet GACTX.APARAM.AGETUSERVALCHAR("AECLIMAC"), 2)
 Call TRACE("TOGGLE_DEBUG 1.1: AECLIMAC=" + AECLIMAC) From ASYRCOM
 If len(AECLIMAC) > 0
  If dbgmode(1) = 0
   # comment this 2 lines if you want to stop here without having set a breakpoint before
   If dim(GDBGRDV) < 0 : Global Integer GDBGRDV : Endif
   GDBGRDV = 1
   dbgmode(1) = 1
  Elsif dbgmode(1) <> 0
   dbgmode(1) = 0
  Endif
 Endif
 Call TRACE("TOGGLE_DEBUG 2: dbgmode=[" + num$(dbgmode(0)) + "," + num$(dbgmode(1)) + "," + num$(dbgmode(2)) + "]") From ASYRCOM
End

#
# Sends the JSON prototype
#
Subprog PROTO_JSON(ACTX,PSYR,WCLOB,TIME_UPD)
Variable Instance  ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance  PSYR     Using C_ASYR
Variable Clbfile   WCLOB
Variable Decimal   TIME_UPD

# The timestamp value corresponds to the generation time
  TIME_UPD=1352363528580

  Append WCLOB, '{'
#  Append WCLOB,'"$baseUrl":"'+PSYR.PREFIX+'","$url":"'+"{$baseUrl}/DEBUG('ECLIPSE')?representation=DEBUG~ECLIPSE.$details"+'"'
  Append WCLOB, '"$baseUrl":"/sdata/x3/erp/' + nomap + '"'
  Append WCLOB, ',"$baseType":"application/json;vnd.sage=syracuse;vnd.sage.syracuse.representation=x3.erp.SUPERV"'
  Append WCLOB, ',"$url":"'+"{$baseUrl}/DEBUG?representation=DEBUG.$details"+'"'
  Append WCLOB, ',"$title":"Debugger"'
  Append WCLOB, ',"$type":"{$baseType}.DEBUG.$details"'
  Append WCLOB, ',"$properties":{'
#  Append WCLOB,'"enabled": {"$title":"Enabled","$type":"application/x-boolean","$constraints":{},"$capabilities":"sort,filter"}'
  Append WCLOB, '"message": {"$title":"Message","$type":"application/x-string"}'
  Append WCLOB, ',"state": {"$title":"State","$type":"application/x-choice","$value":{'
    Append WCLOB, '"$type": "application/x-string",'
    Append WCLOB, '"$enum": [{"$value": "E", "$title": "Enabled"}, {"$value": "D", "$title": "Disabled"}]'
  Append WCLOB, '},"$capabilities":"sort,filter,alphaTab"}'
  Append WCLOB, ',"modes": {"$title":"Modes","$type":"application/x-string"}'
#  Append WCLOB,',"modes": {"$title":"Modes","$type":"application/x-array",'
#  Append WCLOB,'"$item":{"$type": "application/json","$":{'
#    Append WCLOB,'"index": {"$title": "Index","$type": "application/x-string"}'
#    Append WCLOB,',"value":{"$title": "Value","$type": "application/x-string"}'
#    Append WCLOB,'}' # $.modes.$item.$
#  Append WCLOB,'}' # $.modes.$items
#  Append WCLOB,'}' # $.modes
  Append WCLOB, ',"AECLIDBG": {"$title":"Eclipse Debugger (AECLIDBG)","$type":"application/x-boolean"}'
  Append WCLOB, ',"AECLIDBGTR": {"$title":"Eclipse Debugger (AECLIDBGTR)","$type":"application/x-boolean"}'
  Append WCLOB, ',"AECLIMAC": {"$title":"Eclipse Debugger Machine (AECLIMAC)","$type":"application/x-string"}'
  Append WCLOB, ',"AECLIPRT": {"$title":"Eclipse Debugger Port (AECLIPRT)","$type":"application/x-string"}'
  Append WCLOB, '}' # $properties
  Append WCLOB, '}'
End

#**
#* Funprog HANDLER_GET()
#*!
Funprog HANDLER_GET(ACTX,ASWK,ARCV,PSYR,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Local Integer ERROR
Local Clbfile WCLOB
Gosub GET
ASND.DATA = WCLOB
End ERROR

$GET
$POST
  Call TOGGLE_DEBUG

  Local Char AECLIMAC(250)
  AECLIMAC = vireblc(fmet GACTX.APARAM.AGETUSERVALCHAR("AECLIMAC"), 2)

  Raz WCLOB
  Append WCLOB, "{"
  Append WCLOB, '"message":"'
  If len(AECLIMAC) = 0
   Append WCLOB, 'AECLIMAC (Eclipse Debugger Machine) cannot be empty! It must be set with the name of the machine that hosts the Eclipse debugger.'
  Endif
  Append WCLOB, '",'
  Append WCLOB, '"state":'
  If dbgmode(1) = 1
    Append WCLOB, '"E"'
  Else
    Append WCLOB, '"D"'
  Endif
  Append WCLOB, ',"modes":"[' + num$(dbgmode(0)) + ',' + num$(dbgmode(1)) + ',' + num$(dbgmode(2)) + ']"'
#  Append WCLOB,',"modes":['
#  Append WCLOB,'{"index":"0","value":"' + num$(dbgmode(0)) + '"}'
#  Append WCLOB,',{"index":"1","value":"' + num$(dbgmode(1)) + '"}'
#  Append WCLOB,',{"index":"2","value":"' + num$(dbgmode(2)) + '"}'
#  Append WCLOB, ']'
  If fmet GACTX.APARAM.AGETUSERVALNUM("AECLIPSE") = 2
   Append WCLOB, ',"AECLIDBG":true'
  Else
   Append WCLOB, ',"AECLIDBG":false'
  Endif
  If fmet GACTX.APARAM.AGETUSERVALNUM("AECLIDBGTR") = 2
   Append WCLOB, ',"AECLIDBGTR":true'
  Else
   Append WCLOB, ',"AECLIDBGTR":false'
  Endif
  Append WCLOB, ',"AECLIMAC":"' + fmet GACTX.APARAM.AGETUSERVALCHAR("AECLIMAC") + '"'
  Append WCLOB, ',"AECLIPRT":"' + fmet GACTX.APARAM.AGETUSERVALCHAR("AECLIPRT") + '"'
  Append WCLOB,'}'

  ASND.STAT     = 200
  ASND.URL      = PSYR.PREFIX+'/'+PSYR.CODREP
  ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+PSYR.CODREP+"."+PSYR.CODFAC
  ASND.DATA     = WCLOB

Return
