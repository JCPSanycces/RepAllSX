#--- Sage ltr 2013 for Test
#================================================
Funprog GETLNKCLASS(PNAME,PDATA)
Value    Char     PNAME  : #-- name class
Variable Char     PDATA()()
#------------------------------------------------
  Local Integer K : K=0
  Local Integer WRET : WRET=0

  Local File ACLALNK [CLLNK] :
  Filter [CLLNK] Where CODCLA=PNAME
  For [CLLNK]
    PDATA(K)=[F:CLLNK]REFLNK+"|"+[F:CLLNK]CLALNK+"|"+[F:CLLNK]TABLNK+"|"+[F:CLLNK]TABORI
    K+=1
  Next
  Filter[CLLNK]
  WRET=K
  Close Local File [CLLNK] :
End WRET
#=========================================================
#**
#*
#* Collection get Flags Insert,Delete, Rajout
#* @return Number of elems
#* @param PNAME
#* @param PCOLL
#* @param PDATA
#*!
Funprog GETCOLLECTNAME(PNAME,PDATA)
Value    Char     PNAME  : #-- name class
Variable Char     PDATA()()
#------------------------------------------------
  Local Integer K : K=0
  Local File    ACLACOL [CLCOL] :
  Filter [CLCOL] Where CODCLA=PNAME
  For [CLCOL]
    PDATA(K) = [F:CLCOL]CODCOL   : #-- code collect
    K+=1
  Next
  Filter [CLCOL]
  Close Local File [CLCOL] :
End K
#=========================================================
Funprog GETFIELDNAME(PNAME,PDATA)
Value    Char     PNAME  : #-- name class
Variable Char     PDATA()()
#------------------------------------------------
  Local Integer K : K=0
  Local File    ACLAFLD [CLFLD] :

  Filter [CLFLD] Where CODCLA=PNAME
  For [CLFLD]
    PDATA(K)=[F:CLFLD]FLDCLA+"|"+[F:CLFLD]CODTYP+"|"+[F:CLFLD]LNKCLA  : #-- codefield type
    K+=1
  Next
  Filter [CLFLD]
  Close Local File [CLFLD] :
End K
#+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

