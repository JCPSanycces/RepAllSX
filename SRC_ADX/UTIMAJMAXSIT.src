#<AdxTL>@(#)5.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour DIMMAX du code activité SIT
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update max activity code SIT") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub DIMMAX
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub DIMMAX
End

#-------------------#
$DIMMAX

Local File =DOSSIER+".ACTIV" [A__] 

# Mise à jour de la table ACTIV
Call ECR_TRACE(mess(81,125,1)-"ACTIV:"-time$,0) From GESECRAN
Trbegin [A__]
 Update [A__] Where CODACT="SIT" With DIMMAX=0
Commit

Close Local File [A__]

Return
