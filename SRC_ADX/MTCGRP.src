#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Call EXEC(NBPAR,PARAMETRE)
End

#####################
## Report MTCGRP
## In AREPORTM, the field CLEA1 contains the Site (FCY)
## In AREPORTM, the field CLEA2 contains the Company (LEGCPY)
## In AREPORTM, the field CLEN1 contains the  Main General Ledger of the company (LEDTYP)


Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Local Char    FCYSTR(GLONFCY) :# Site start
Local Char    FCYEND(GLONFCY) :# Site end
Local Char    SCPY(GLONCPY)
Local Char    REPNAM(GLONARP) :# Name of the report
Local Tinyint LEDTYP
Local Tinyint LEDTYPANA
Local Tinyint LEDTYPIAS
Local Char    MESSA
Local Char    PARAM(30)       :# Number of the request in an alpha type
Local Integer NUMREQ          :# Number of the request in a numeric type
Local Integer I               :# Numbers each record in the table AREPORTM

If clalev([F:ARM])=0 : Local File AREPORTM  [ARM] : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif

Call GETPARAM("sitedeb",NBPAR,PARAMETRE,[L]FCYSTR) From ETAT
Call GETPARAM("sitefin",NBPAR,PARAMETRE,[L]FCYEND)  From ETAT
Call GETPARAM("X3ETA",NBPAR,PARAMETRE,[L]REPNAM) From ETAT
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,[L]PARAM) From ETAT
[L]NUMREQ = val(PARAM)
PARAM = num$([L]NUMREQ)

Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT
 Call DEBTRANS From GLOCK
 Gosub TR0
Gosub TR1
End
####################################################
## Effacement table temporaire
####################################################
$TR0
 GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]REPNAM & USR=GUSER & CREDAT<date$
 If fstat=1 | fstat>5
  GOK=-1 : GLOCK="$AREPORTM" : Goto ROLL_TR1
  Else
    Commit
 Endif

Return
####################################################
## Mise à jour table temporaire
####################################################
$TR1
 GOK = 1
 Trbegin [ARM]
 I = 0

 Filter [FCY] Where FCY>= [L]FCYSTR and FCY<= [L]FCYEND
 For [FCY]FCY1
  If SCPY<> [F:FCY]LEGCPY
    SCPY=[F:FCY]LEGCPY
  Else
   Goto NEXT_FCY
  Endif
  # To find the Ledger Type which corresponds to the main General Ledger (LEDTYPGEN) for the company
  ASTATUS = func FINACM_SYRA.GET_MAINLEDTYP(GACTX, SCPY,  [L]LEDTYP, [L]LEDTYPANA, [L]LEDTYPIAS, MESSA)
  If ASTATUS<>[V]CST_AOK : GMESSAGE = MESSA : End : Endif
  Raz [ARM]
  I +=1
  [F:ARM]RPTCOD = [L]REPNAM
  [F:ARM]USR    = GUSER
  [F:ARM]NUMREQ = [L]NUMREQ
  [F:ARM]NUMLIG = I
  [F:ARM]CLEA1  = [F:FCY]FCY    # Site
  [F:ARM]CLEA2  = [F:FCY]LEGCPY # Company
  [F:ARM]CLEN1  = [L]LEDTYP     # Main General Ledger
  [F:ARM]CREDAT = date$
  Write [ARM]
  If fstat
   GOK = 0 : Call FSTA("ARM") From GLOCK : Break
  Endif
  $NEXT_FCY
 Next
 Filter [FCY]
 If GOK=0 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Call FSTA("ARM") From GLOCK
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return





