#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Raz GBIDC1, GBIDC2
Call OBJET("HRMDT",GBIDC1,GBIDC2) From GOBJET
End

########################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "FERME"       : Gosub FERME
 When "LIENS"       : Gosub LIENS
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "ANNULE"      : Gosub ANNULE
 When "CHGCOD"      : Gosub CHGCOD
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "AS_COD"      : Raz GCURLEG        :#Used in SELOBJETL action to disable the filter under the current legislation
Endcase
Return

########################################
$OUVRE
If clalev ([F:HRMDT])=0 : Local File HRMEDTYP   [HRMDT] : Endif
If clalev ([F:HRMDT2])=0 : Local File HRMEDTYP   [HRMDT2] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

#LIPET - 2017-08-22 - START
If dim([M:HRMDT1]LEG)=0:If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif:Endif
#LIPET - 2017-08-22 - END
Return

########################################
$LIENS

GCURLEG = [F:HRMDT]LEG
#LIPET - 2017-08-22 - START
#If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If dim([M:HRMDT1]LEG)=0:If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif:Endif
#LIPET - 2017-08-22 - END

# To manage translated texts (data type AX3 & AX1)
Call LECTEXTRA([M]DESAXX,"HRMEDTYP","DESAXX",[M]COD,GCURLEG) From ATEXTRA
Call LECTEXTRA([M]SHOAXX,"HRMEDTYP","SHOAXX",[M]COD,GCURLEG) From ATEXTRA
# To display or to hide fields based on legilation code
Gosub DISPLAY_HIDE
Return

########################################
$CREATION
$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

########################################
# To manage translated texts (data type AX3 & AX1) in cretion and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("HRMEDTYP","DESAXX",CLECUR1,"","HRMEDTYP","DESAXX",[F:HRMDT]COD,GCURLEG)  From ATEXTRA
 Call DUPTEXTRA("HRMEDTYP","SHOAXX",CLECUR1,"","HRMEDTYP","SHOAXX",[F:HRMDT]COD,GCURLEG)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESAXX,"HRMEDTYP","DESAXX",[F:HRMDT]COD,GCURLEG) From ATEXTRA
Call MAJTEXTRA([M]SHOAXX,"HRMEDTYP","SHOAXX",[F:HRMDT]COD,GCURLEG) From ATEXTRA
Return

########################################
$VERIF_CRE
$VERIF_MOD
If [M]DEFVAL=2
 Filter [F:HRMDT2] Where COD<>[M]COD & LEG=GCURLEG & DEFVAL=2
 Read [F:HRMDT2]HRMDT0 First
 Filter [F:HRMDT2]
 If !fstat
  # A default value already exist for this legislation : XXX
  GMESSAGE = mess(1,10712,1)-":'"-[F:HRMDT2]COD+"'"
  OK = 0 : Return
 Endif
Endif
Return

########################################
$DISPLAY_HIDE
#FRLAA - 2016-03-17 - REQUIREMENT 114309 US 25 - START
#Case GCURLEG
# When "FRA",""
#   Chgfmt [M]NBRMON  With "N0:2"
# When Default
#   Chgfmt [M]NBRMON  With "-N0:2"
#Endcase
#FRLAA - 2016-03-17 - REQUIREMENT 114309 US 25 - END
Return

########################################
#To change the main code
$CHGCOD
Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return

########################################
# To change translated texts (data type AX3 & AX1) when you change the main code
$AP_CHANGE
Call CHGTEXTRA("HRMEDTYP","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("HRMEDTYP","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
Call SUPTEXTRA("HRMEDTYP","DESAXX",SUPP,[L]CODE) From ATEXTRA
Call SUPTEXTRA("HRMEDTYP","SHOAXX",SUPP,[L]CODE) From ATEXTRA
Return

########################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif

# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONHRMDT) : Endif
VCOD = CLE2
Return

###############################################################################
##  Button 'Copy'
###############################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File HRMEDTYP  [HRMDT1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".HRMEDTYP"  [HRMDT1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File HRMEDTYP [HRMDT2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".HRMEDTYP"  [HRMDT2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [HRMDT1], [HRMDT2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [HRMDT2]
 Delete [HRMDT2] Where TYP=TABLE & LEG=TABLE2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".HRMEDTYP" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("HRMDT2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [HRMDT1] Where TYP=TABLE & LEG=TABLE2
  [F:HRMDT2] = [F:HRMDT1]
  Call COPTEXTRA("HRMEDTYP","DESAXX",TABLE,TABLE2) From ATEXTRA
  Call COPTEXTRA("HRMEDTYP","SHOAXX",TABLE,TABLE2) From ATEXTRA
  If dim([F:HRMDT2]UPDUSR)>0 : [F:HRMDT2]UPDUSR = GUSER : Endif
  If dim([F:HRMDT2]UPDDAT)>0 : [F:HRMDT2]UPDDAT = date$ : Endif
  Write [HRMDT2]
  If fstat
   GOK = 0 : Call FSTA("HRMDT2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

############################################################################################
## Subprog of screen HRMDT0
############################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
Gosub DISPLAY_HIDE
End


############################################################################################
## Action on the datatype
############################################################################################

#Selection
########################################
$SEL_TABLE
Case TABLE
 When "SELHRMDT"
  If clalev ([F:HRMDT])=0 : Local File HRMEDTYP   [HRMDT] : Endif
  OBJET="HRMDT"
  START   = "[F:HRMDT]COD"
  #Filter based on code legislation
  If PARAM(1)<>""
   Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRMDT]LEG="'+PARAM(1)+'" | [F:HRMDT]LEG="")',"&") From GOBJSUB
  Endif
  #Filter based on group of company
  If PARAM(2)<>""
    #SBA - pb sel
    #OBJET=""
    DEFPAG = 1    :# To have page up and page down
    TIT=mess(13,10712,1) #'Type de visite'
    Gosub NOMFIC From ="WOHRMDT"
    Call  TRANSCOL("HRMDT",NBCOL,COL,TIT,FMTCOL) From OBJDIV
    If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
    If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
    If clalev([F:ACC])=0 : Local File ACCES   [ACC] : Endif
    If GUSRACS=2
     Link [HRMDT] With
&    [AGC]AGC0=[F:HRMDT]GRP,
&    [AXX]AXX0="HRMEDTYP";"DESAXX";GLANGUE;[F:HRMDT]COD;[F:HRMDT]LEG
&    As [LNK]
     Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AGC]CPY="'+PARAM(2)+'" | [F:HRMDT]GRP="")',"&") From GOBJSUB
    Else
     Link [HRMDT] With
&    [AGC]AGC0=[F:HRMDT]GRP,
&    [AXX]AXX0="HRMEDTYP";"DESAXX";GLANGUE;[F:HRMDT]COD;[F:HRMDT]LEG,
&    [ACC]CODACC=GUSER;[F:HRMDT]CODACS
&    As [LNK]
     Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AGC]CPY="'+PARAM(2)+'" | [F:HRMDT]GRP="") & ([F:HRMDT]CODACS="" | [F:ACC]CONSUL=2)',"&") From GOBJSUB
    Endif

    Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:HRMDT]ENAFLG=2',"&") From GOBJSUB

    NBCOL += 1 : COL(NBCOL) = "[F:HRMDT]GRP"    : COLTYP(NBCOL) =  type([F:HRMDT]GRP)    : TIT(NBCOL) =mess(237,133,1)
    Default File [LNK]
   Endif
Endcase
Return

# To do a generic Call CONTSEL... from
##################################################
Subprog CONTSEL(COD,LEG,SOC)
Value    Char    COD
Value    Char    LEG()
Value    Char    SOC()
Call CONTHRMDT(COD,LEG,SOC)
End


# Controls
##################################################
Subprog CONTHRMDT(COD,LEG,SOC)
Value    Char    COD
Value    Char    LEG()
Value    Char    SOC()
Local Integer    CAS

If GFONCTION = "GESHRMDT" | COD="" : End : Endif

If clalev([F:HRMDT])=0 : Local File HRMEDTYP [HRMDT] : Endif

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

# CAS=1 => Record without Legislation (LEG = "")
# CAS=2 => Record with    Legislation (LEG <>"")

CAS = 1 : # Legislation is empty

If LEG<>""
 Read [HRMDT]HRMDT0=COD;LEG
 If fstat
  Read [HRMDT]HRMDT0=COD;""
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Read [HRMDT]HRMDT0(1)=COD
 If !fstat
  LEG = [F:HRMDT]LEG
  CAS = 2
 Endif
Endif
If fstat
 Filter [HRMDT] Where COD=COD
 Look [HRMDT]HRMDT0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  GMESSAGE = [L]COD-":"-mess(14,10712,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  GMESSAGE = [L]COD-":"-mess(23,100,1)
 Endif
 Filter [HRMDT]
 mkstat = 2 : End
Endif
If CAS=2
 Call CONTROLE("HRMDT","",LEG,COD,mkstat) From CONTOBJ
Else
 Call CONTROLE("HRMDT","","",COD,mkstat) From CONTOBJ
Endif

If [F:HRMDT]GRP<>"" & SOC<>""
  If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
  Look [AGC]AGC0 = [F:HRMDT]GRP;SOC
  If fstat
   GMESSAGE = [L]COD-":"-mess(63,127,1)-":"-[F:HRMDT]GRP : # Réservé au groupe de société
   mkstat = 2 : End
  Endif
 Endif

If GUSRACS<>2
 If [F:HRMDT]CODACS <> ""
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  Read [F:ACC]CODACC = GUSER;[F:HRMDT]CODACS
  If fstat or [F:ACC]CONSUL <> 2
   GMESSAGE = [F:HRMDT]COD-":"-mess(3,104,1) :#Access denied
   mkstat = 2 : End
  Endif
 Endif
Endif

End

#Zoom
##################################################
Subprog TUNHRMDT(COD,LEG,SOC)
Variable Char    COD()
Value    Char    LEG
Value    Char    SOC

Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONHRMDT)
 TOKILL = 1
Endif

If clalev([F:HRMDT])=0 : Local File HRMEDTYP [HRMDT] : Endif

# To update the HRMDT code after the tunnel order
VCOD = COD

If GNBLEG = 1
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Elsif LEG=""              : # If LEG="" then firstly we search a HRMDT record with LEG="" secondly a HRMDT record with LEG<>""
 Read [HRMDT]HRMDT0 = VCOD;LEG
 If fstat
  Read [HRMDT]HRMDT0(1)=VCOD
  If !fstat
   LEG = [F:HRMDT]LEG
  Endif
 Endif
Endif

Read [HRMDT]HRMDT0 = VCOD;LEG
If fstat : LEG = "" : Endif

Call OBJET("HRMDT",LEG,VCOD) From GOBJET
COD = VCOD

If TOKILL : Kill VCOD : Endif
End


#Return the default value
##################################################
Subprog DEFHRMDT(COD,LEG,SOC)
Variable Char    COD()
Value    Char    LEG
Value    Char    SOC

If GFONCTION = "GESHRMDT" | COD<>"" : End : Endif

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

If clalev([F:HRMDT])=0  : Local File HRMEDTYP [HRMDT]  : Endif
If LEG<>""
 Filter [F:HRMDT] Where LEG=[L]LEG & DEFVAL=2
 Read[F:HRMDT]HRMDT0 First
 Filter [F:HRMDT]
 If !fstat
  COD=[F:HRMDT]COD
  End
 Endif
Endif

Filter [F:HRMDT] Where LEG="" & DEFVAL=2
Read[F:HRMDT]HRMDT0 First
Filter [F:HRMDT]
If !fstat
 COD=[F:HRMDT]COD
 End
Endif
End

