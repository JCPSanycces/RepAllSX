#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIGPA48   Deletion of POPSWOS table                                   #
##########################################################################


Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Delete old table POPSWOS") From LECFIC

  Call MAJ_UTIGPA48(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

##########################################################################
Subprog MAJ_UTIGPA48(DOSSIER)
Value Char     DOSSIER

# Only when module inventory and manufacturing
If [F:ADS]MODULE(7)<>2 : End : Endif

Local Integer NB
Local Char CODE(GLONID1) , VSUPP(GLONID2)
Local Char APPLI(GLONADS)


Call ECR_TRACE("UTIGPA48: Process Start on : "+DOSSIER,0) From GESECRAN

#----- Open file used by deletion -----#
If  filinfo(filpath("FIL","POPSWOS","fde",DOSSIER),0) >= 0
& & filinfo(filpath("FIL","POPSOBJ","fde",DOSSIER),0) >= 0

    If clalev([F:PSWOS])=0 : Local File =DOSSIER+".POPSWOS"     [PSWOS]  : Endif
    If clalev([F:PSOBJ])=0 : Local File =DOSSIER+".POPSOBJ"      [PSOBJ]  : Endif
    Trbegin [PSOBJ]
    For [PSWOS]
        [F:PSOBJ]FCY = [PSWOS]FCY
        [F:PSOBJ]TYP = "WOS"
        [F:PSOBJ]IDENT1 = [PSWOS]WIPNUM
        [F:PSOBJ]IDENT2 = [PSWOS]ITMREF
        Write [PSOBJ]
        NB+=1
    Next
    Commit

    Call ECR_TRACE(num$(NB)-"records transfered from POPSWOS to POPSOBJ",0) From GESECRAN
Endif

If clalev([F:ATB])=0   : Local File =DOSSIER+".ATABLE"       [ATB]  : Endif
If clalev([F:ATZ])=0   : Local File =DOSSIER+".ATABZON"      [ATZ] : Endif
If clalev([F:ATI])=0   : Local File =DOSSIER+".ATABIND"      [ATI] : Endif
If clalev([F:ATY])=0   : Local File =DOSSIER+".ATYPE"        [ATY] : Endif
If clalev([F:ACV])=0   : Local File =DOSSIER+".ACTIV"        [ACV] : Endif
If clalev([F:AML])=0   : Local File =DOSSIER+".AMENLOC"      [AML] : Endif
If clalev([F:ANX])=0   : Local File =DOSSIER+".AINDEX"       [ANX] : Endif
If clalev([F:ACT])=0   : Local File =DOSSIER+".ACTION"       [ACT] : Endif
If clalev([F:AMP])=0   : Local File =DOSSIER+".AMSKPAR"      [AMP] : Endif
If clalev([F:ATR])=0   : Local File =DOSSIER+".ACTPAR"       [ATR] : Endif
If clalev([F:AOB])=0   : Local File =DOSSIER+".AOBJET"       [AOB] : Endif
If clalev([F:AOT])=0   : Local File =DOSSIER+".AOBJTAB"      [AOT] : Endif
If clalev([F:ADW])=0   : Local File =DOSSIER+".ADOVAL"       [ADW] : Endif
If clalev([F:AWI])=0   : Local File =DOSSIER+".AWINDOW"      [AWI] : Endif
If clalev([F:AWB])=0   : Local File =DOSSIER+".AWINBRO"      [AWB] : Endif
If clalev([F:AVW])=0   : Local File =DOSSIER+".AVIEW"        [AVW] : Endif
If clalev([F:ACL])=0   : Local File =DOSSIER+".ACTL"         [ACL] : Endif
If clalev([F:ADS])=0   : Local File =DOSSIER+".ADOSSIER"     [ADS] : Endif
If clalev([F:AAR])=0   : Local File =DOSSIER+".ACTCODPAR"    [AAR] : Endif


# Remove the table from the dictionnary
CODE = "POPSWOS"
Raz VSUPP
Call ANNULATION(DOSSIER,"-ATB",CODE,VSUPP) From ANUCOD

# Remove the table from the database
APPLI = DOSSIER
Gosub ANNULE From SUBATB

Call ECR_TRACE("UTIGPA48: Process End",0) From GESECRAN
End

########################################################################
# for automatic start at patch-management                            #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call MAJ_UTIGPA48(APPLI)
End

#######################################################################
# for start in dosmaj (validation folder)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
Call MAJ_UTIGPA48(APPLI)
End

