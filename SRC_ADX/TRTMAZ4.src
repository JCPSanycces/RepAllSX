#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
# Etape 6 de la définition d'un mailing                             Module CRM          5 décembre 2000  #
##########################################################################################################
# Expédition du mailing
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "SETBOUT"      : Gosub SETBOUT
    When "DEBUT"        : Gosub DEBUT
    When "FINSAI"       : Gosub FINSAI
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
  If !clalev([F:OMP]) : Local File PHONING [OMP] : Endif
Return

##########################################################################################################
$SETBOUT
  ETABOU(GVALI) = 1
Return

##########################################################################################################
$DEBUT
Local Integer IERRINF

  IERRINF = 0
  If GINTRA Then
    [M:MAZ4]TYP = 4
    Grizo [M:MAZ4]TYP
  Else
    [M:MAZ4]TYP = 3
  Endif
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESOMM" Then
      If [M:OMM0]OMMNUM = "" Then
        #Aucun chrono d'opération marketing n'a été communiqué. Accès refusé.
        GMESSAGE = mess(695,182,1)
        GERR = 1
        FIN = 1
        Return
      Endif
      Read [OMM]OMM0=[M:OMM0]OMMNUM
      If fstat Then
        #Erreur en lecture de l'opération marketing indiquée. Accès refusé.
        GMESSAGE = mess(696,182,1)
        GERR = 1
        FIN = 1
        Return
      Else
        [M:MAZ4]NUM = [F:OMM]OMMNUM
        [M:MAZ4]DEFADD = [F:OMM]DEFADD
        [M:MAZ4]HIEBPR = [F:OMM]HIEBPR
        [M:MAZ4]TYPSEA = [F:OMM]TYPSEA
        [M:MAZ4]CNTTTR = [F:OMM]CNTTTR
      Endif
    Elsif GNAVIG(GPILNAV-1) = "GESOMP" Then
      If [M:OMP0]OMPNUM = "" Then
        #Aucun chrono d'opération marketing n'a été communiqué. Accès refusé.
        GMESSAGE = mess(695,182,1)
        GERR = 1
        FIN = 1
        Return
      Endif
      Read [OMP]OMP0=[M:OMP0]OMPNUM
      If fstat Then
        #Erreur en lecture de l'opération marketing indiquée. Accès refusé.
        GMESSAGE = mess(696,182,1)
        GERR = 1
        FIN = 1
        Return
      Else
        [M:MAZ4]NUM = [F:OMP]OMPNUM
        [M:MAZ4]DEFADD = [F:OMP]DEFADD
        [M:MAZ4]HIEBPR = [F:OMP]HIEBPR
        [M:MAZ4]TYPSEA = [F:OMP]TYPSEA
        [M:MAZ4]CNTTTR = [F:OMP]CNTTTR
      Endif
    Endif
  Endif
  If [M:MAZ4]TYPSEA = "CCN" Then
    [M:MAZ4]MXL = "MAILCCN"
    Call AM_MXL([M:MAZ4]MXL) From SUBMAZ4
    #Crée MAILCCN si il n'existe pas
    Call CREMAILCCN(IERRINF) From SUBMXLB
    If IERRINF Then
      GMESSAGE = mess(IERRINF,182,1)
      GERR = 1
    Endif
  Else
    [M:MAZ4]MXL = "MAILBPR"
    Call AM_MXL([M:MAZ4]MXL) From SUBMAZ4
    #Crée MAILBPR si il n'existe pas
    Call CREMAILBPR(IERRINF) From SUBMXLB
    If IERRINF Then
      GMESSAGE = mess(IERRINF,182,1)
      GERR = 1
    Endif
  Endif
  Affzo [M:MAZ4]1-99
Return

##########################################################################################################
$FINSAI
  Raz [M:MAZ4]
Return

##########################################################################################################
$ONOK
  Call MAIL_XML
Return

##########################################################################################################
Subprog MAIL_XML
Local Integer IOK
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Char SFICCLI(250)

Local Char SZMXL(type([M:MAZ4]MXL)-10)
Local Char SFILEXML(type([M:MAZ4]TPLDIRFIL)-10)
Local Char SZTYPSEA(type([M:MAZ4]TYPSEA)-10)
Local Char SZOPGNUM(type([M:MAZ4]NUM)-10)
Local Integer IDEFADD
Local Integer IHIEBPR
Local Char SZCNTTTR(type([M:MAZ4]CNTTTR)-10)

  # --------------------------------
  SZMXL = [M:MAZ4]MXL
  SFILEXML = [M:MAZ4]TPLDIRFIL
  SZTYPSEA = [M:MAZ4]TYPSEA
  SZOPGNUM = [M:MAZ4]NUM
  IDEFADD = [M:MAZ4]DEFADD
  IHIEBPR = [M:MAZ4]HIEBPR
  SZCNTTTR = [M:MAZ4]CNTTTR
  # --------------------------------
  IOK = func TRTMAILXML.GENMAILXML(SZMXL, SFILEXML, SZTYPSEA, SZOPGNUM, IDEFADD, IHIEBPR, SZCNTTTR, SMESSAGE)
  If IOK <> [V]CST_ASUCCESS Then
    GMESSAGE = SMESSAGE
    GERR = 1
  Else
    If [M:MAZ4]TYP = 3 Then
      # XML sur client
      # On recopie le fichier sur le poste client
      Call COPCLI([M:MAZ4]TPLDIRFIL, SFICCLI, IOK) From ORDSYS
      If IOK <> 0 Then
        GMESSAGE = mess(19,139,1) - ":" - mess(7,21,1)
        GERR = 1
        End
      Endif
    Endif
  Endif
  # --------------------------------
End
