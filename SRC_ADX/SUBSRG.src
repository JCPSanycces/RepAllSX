#<AdxTL>@(#)12.0.0.0 $Revision$ 

#######################################################################
# SUBSRG : Transactions plan de rangement                             #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:SRT]STKTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                                                                     #
# Génération de 1 écrans de saisie à partir des écrans de base SSL1   #
#                                                                     #
# Nom des écrans générés : WTxyyyz                                    #
#                            x = 5 pour plan de rangement             #
#                                                                     #
#                          yyy = nom de la transaction (STRNUM)       #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                1 pour plan de rangement             #
#                                S pour saisie entrée plan rangement  #
#######################################################################
Call OBJET("SRG",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="SRT"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=5
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M:SRG0]SRTTYP = 5
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub TRT_DIETRS From SUBDST : Gosub LIENS
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Delete [AXX] Where CODFIC="STKTRS" & IDENT1=num$([F:SRT]SRTTYP) & IDENT2=[F:SRT]SRTNUM
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="SRT"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "SEL_TABLE"   : Gosub SEL_TABLE  From SUBETR : # Sélection sur code pièce auto
 When "FERME"       : Call IMPSCR        From ATRTX3
 When Default
Endcase
Return


$PE_STKTRS
[F:SRT]SRGWAIFLG = 1   # entrées à quai non autorisées
Gosub PE_STKTRS From SUBSKX
Return

#-------------------------------------#
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto stock

Local Char APPLI    : APPLI=nomap
Local Char     WMODU(3) : WMODU="T"
Local Char     WNOMOBJ(GLONAOB)
Local Char     WNOMTRS(GLONTRS)
Local Char     WACSCOD(GLONACS)
Local Char     WLIBEL(30)
Local Shortint WNUM
Local Shortint WENAFLG
Local Char     WABR(5)
Return

#---------------------------------------------------#
# traiter les transactions de type plan de rangement#
#---------------------------------------------------#
$FILTRE
FILTSUP="SRTTYP=5"
Return

#----------------------------------------------#
# Désactivation bouton "Validation" et "Copie" #
#----------------------------------------------#
$SETBOUT
If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Return

#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT
Case REP
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

$LIENS
#-- Positionnement des valeurs si non renseignées
#** Onglet entete
If [M:SRG0]ENAFLG    =0  [M:SRG0]ENAFLG   =2   : Endif
#** Onglet parametres
If [M:SRG2]ORIFLG    =0  [M:SRG2]ORIFLG   =1   : Endif : # origine
If [M:SRG2]ALLSTKFLG =0  [M:SRG2]ALLSTKFLG=1   : Endif : # Inclure stock alloué
If [M:SRG2]CRIT1     =0  [M:SRG2]CRIT1    =2   : Endif : # critere 1
If [M:SRG2]CRIT2     =0  [M:SRG2]CRIT2    =1   : Endif : # critere 2
#** Onglet origine
If [M:SRG2]VCRTYPCOD=0   [M:SRG2]VCRTYPCOD=1   : Endif :
If [M:SRG2]VCRTYPSCR=0   [M:SRG2]VCRTYPSCR=1   : Endif :
If [M:SRG2]VCRNUMCOD=0   [M:SRG2]VCRNUMCOD=1   : Endif :
If [M:SRG2]VCRNUMSCR=0   [M:SRG2]VCRNUMSCR=1   : Endif :
If [M:SRG2]VCRLINCOD=0   [M:SRG2]VCRLINCOD=1   : Endif :
If [M:SRG2]VCRLINSCR=0   [M:SRG2]VCRLINSCR=1   : Endif :
If [M:SRG2]IPTDATCOD=0   [M:SRG2]IPTDATCOD=1   : Endif :
If [M:SRG2]IPTDATSCR=0   [M:SRG2]IPTDATSCR=1   : Endif :
If [M:SRG2]SRGPPSCOD=0   [M:SRG2]SRGPPSCOD=1   : Endif :
If [M:SRG2]SRGPPSSCR=0   [M:SRG2]SRGPPSSCR=1   : Endif :
If [M:SRG2]STUCOD   =0   [M:SRG2]STUCOD   =1   : Endif :
If [M:SRG2]STUSCR   =0   [M:SRG2]STUSCR   =1   : Endif :
If [M:SRG2]PCUSTUOCOD=0   [M:SRG2]PCUSTUOCOD=1   : Endif :
If [M:SRG2]PCUSTUOSCR=0   [M:SRG2]PCUSTUOSCR=1   : Endif :
If [M:SRG2]QTYSTUOCOD=0   [M:SRG2]QTYSTUOCOD=1   : Endif :
If [M:SRG2]QTYSTUOSCR=0   [M:SRG2]QTYSTUOSCR=1   : Endif :

If [M:SRG2]STAORICOD=0   [M:SRG2]STAORICOD=1   : Endif :
If [M:SRG2]STAORISCR=0   [M:SRG2]STAORISCR=1   : Endif :
If [M:SRG2]LOCORICOD=0   [M:SRG2]LOCORICOD=1   : Endif :
If [M:SRG2]LOCORISCR=0   [M:SRG2]LOCORISCR=1   : Endif :
If dim([M:SRG2]WRHORICOD) > 0
   If [M:SRG2]WRHORICOD=0   [M:SRG2]WRHORICOD=1   : Endif :
   If [M:SRG2]WRHORISCR=0   [M:SRG2]WRHORISCR=1   : Endif :
Endif
#**
If [M:SRG2]PCUCOD   =0   [M:SRG2]PCUCOD   =1   : Endif :
If [M:SRG2]PCUSCR   =0   [M:SRG2]PCUSCR   =1   : Endif :
If [M:SRG2]QTYPCUCOD=0   [M:SRG2]QTYPCUCOD=1   : Endif :
If [M:SRG2]QTYPCUSCR=0   [M:SRG2]QTYPCUSCR=1   : Endif :
If [M:SRG2]PCUSTUCOD=0   [M:SRG2]PCUSTUCOD=1   : Endif :
If [M:SRG2]PCUSTUSCR=0   [M:SRG2]PCUSTUSCR=1   : Endif :
If [M:SRG2]QTYSTUCOD=0   [M:SRG2]QTYSTUCOD=1   : Endif :
If [M:SRG2]QTYSTUSCR=0   [M:SRG2]QTYSTUSCR=1   : Endif :
If [M:SRG2]PJTCOD   =0   [M:SRG2]PJTCOD   =1   : Endif :
If [M:SRG2]PJTSCR   =0   [M:SRG2]PJTSCR   =1   : Endif :


#-- Grisage des zones si besoin
#** Onglet origine
If [M:SRG2]VCRTYPCOD =3  Grizo [SRG2]VCRTYPSCR    Else Actzo [SRG2]VCRTYPSCR  : Endif
If [M:SRG2]VCRNUMCOD =3  Grizo [SRG2]VCRNUMSCR    Else Actzo [SRG2]VCRNUMSCR  : Endif
If [M:SRG2]VCRLINCOD =3  Grizo [SRG2]VCRLINSCR    Else Actzo [SRG2]VCRLINSCR  : Endif
If [M:SRG2]SRGPPSCOD =3  Grizo [SRG2]SRGPPSSCR    Else Actzo [SRG2]SRGPPSSCR  : Endif
If [M:SRG2]IPTDATCOD =2  Grizo [SRG2]IPTDATSCR    Else Actzo [SRG2]IPTDATSCR  : Endif
If [M:SRG2]STUCOD    =2  Grizo [SRG2]STUSCR       Else Actzo [SRG2]STUSCR     : Endif
If [M:SRG2]PCUSTUOCOD=2  Grizo [SRG2]PCUSTUOSCR   Else Actzo [SRG2]PCUSTUOSCR : Endif
If [M:SRG2]QTYSTUOCOD=2  Grizo [SRG2]QTYSTUOSCR   Else Actzo [SRG2]QTYSTUOSCR : Endif
If [M:SRG2]STAORICOD =2  Grizo [SRG2]STAORISCR    Else Actzo [SRG2]STAORISCR  : Endif
If [M:SRG2]LOCORICOD =3  Grizo [SRG2]LOCORISCR    Else Actzo [SRG2]LOCORISCR  : Endif
If dim([M:SRG2]WRHORICOD) > 0
   If  [M:SRG2]WRHORICOD=3 Grizo [SRG2]WRHORISCR  Else Actzo [SRG2]WRHORISCR  : Endif
Endif
#**
If [M:SRG2]PCUCOD   =3  Grizo [SRG2]PCUSCR     Else Actzo [SRG2]PCUSCR    : Endif
If [M:SRG2]QTYPCUCOD=3  Grizo [SRG2]QTYPCUSCR  Else Actzo [SRG2]QTYPCUSCR : Endif
If [M:SRG2]PCUSTUCOD=3  Grizo [SRG2]PCUSTUSCR  Else Actzo [SRG2]PCUSTUSCR : Endif
If [M:SRG2]QTYSTUCOD=2  Grizo [SRG2]QTYSTUSCR  Else Actzo [SRG2]QTYSTUSCR : Endif
If [M:SRG2]PJTCOD   =2  Grizo [SRG2]PJTSCR     Else Actzo [SRG2]PJTSCR    : Endif

If dim([M:SRG2]WRHCOD) >0
    If [M:SRG2]WRHCOD=0  [M:SRG2]WRHCOD=3  : Endif : # Dépôt
Endif

#-- Grisage des zones si besoin
#** Onglet Général
If dim([M:SRG2]WRHCOD) >0
  If [M:SRG2]WRHOBY = 2
    Grizo [M:SRG2]WRHCOD
  Else
    Actzo [M:SRG2]WRHCOD
  Endif
Endif

WMODU +=format$("N0:2",[M:SRG0]SRTTYP)

Gosub LIENS From SUBETR
Gosub PE_STKTRS
Return

#---------------------------------------#
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
#** Onglet entete
[M:SRG0]SRTTYP=5
[M:SRG0]ENAFLG=2
#** Onglet paramatre
[M:SRG2]ORIFLG=1
[M:SRG2]ALLSTKFLG=1
[M:SRG2]CRIT1=2
[M:SRG2]CRIT2=1
#** Onglet origine
[M:SRG2]VCRTYPCOD=1
[M:SRG2]VCRTYPSCR=1
[M:SRG2]VCRNUMCOD=1
[M:SRG2]VCRNUMSCR=1
[M:SRG2]VCRLINCOD=1
[M:SRG2]VCRLINSCR=1
[M:SRG2]IPTDATCOD=2
[M:SRG2]IPTDATSCR=1
[M:SRG2]SRGPPSCOD=2
[M:SRG2]SRGPPSSCR=1
[M:SRG2]STUCOD   =2
[M:SRG2]STUSCR   =1
[M:SRG2]PCUSTUOCOD=2
[M:SRG2]PCUSTUOSCR=1
[M:SRG2]QTYSTUOCOD=2
[M:SRG2]QTYSTUOSCR=1

[M:SRG2]STAORICOD=2
[M:SRG2]STAORISCR=1
[M:SRG2]LOCORICOD=1
[M:SRG2]LOCORISCR=1

[M:SRG2]PCUCOD   =3
[M:SRG2]PCUSCR   =1
[M:SRG2]QTYPCUCOD=3
[M:SRG2]QTYPCUSCR=1
[M:SRG2]PCUSTUCOD=3
[M:SRG2]PCUSTUSCR=1
[M:SRG2]QTYSTUCOD=2
[M:SRG2]QTYSTUSCR=1
[M:SRG2]PJTCOD   =2
[M:SRG2]PJTSCR   =1
If dim([M:SRG2]WRHCOD) >0
       [M:SRG2]WRHCOD=3     # Dépôt
       [M:SRG2]WRHORICOD=1
       [M:SRG2]WRHORISCR=1
Endif
Actzo [SRG0]
Actzo [SRG2]

#-- Grisage des zones si besoin
#** Onglet origine
If [M:SRG2]VCRTYPCOD =3  Grizo [SRG2]VCRTYPSCR  Else Actzo [SRG2]VCRTYPSCR  : Endif
If [M:SRG2]VCRNUMCOD =3  Grizo [SRG2]VCRNUMSCR  Else Actzo [SRG2]VCRNUMSCR  : Endif
If [M:SRG2]VCRLINCOD =3  Grizo [SRG2]VCRLINSCR  Else Actzo [SRG2]VCRLINSCR  : Endif
If [M:SRG2]SRGPPSCOD =3  Grizo [SRG2]SRGPPSSCR  Else Actzo [SRG2]SRGPPSSCR  : Endif
If [M:SRG2]STUCOD    =2  Grizo [SRG2]STUSCR     Else Actzo [SRG2]STUSCR     : Endif
If [M:SRG2]PCUSTUOCOD=2  Grizo [SRG2]PCUSTUOSCR Else Actzo [SRG2]PCUSTUOSCR : Endif
If [M:SRG2]QTYSTUOCOD=2  Grizo [SRG2]QTYSTUOSCR Else Actzo [SRG2]QTYSTUOSCR : Endif

If [M:SRG2]IPTDATCOD =2  Grizo [SRG2]IPTDATSCR  Else Actzo [SRG2]IPTDATSCR  : Endif
If [M:SRG2]STAORICOD =2  Grizo [SRG2]STAORISCR  Else Actzo [SRG2]STAORISCR  : Endif
If [M:SRG2]LOCORICOD =2  Grizo [SRG2]LOCORISCR  Else Actzo [SRG2]LOCORISCR  : Endif
If dim([M:SRG2]WRHORICOD) > 0
   If  [M:SRG2]WRHORICOD=2  Grizo [SRG2]WRHORISCR  Else Actzo [SRG2]WRHORISCR : Endif
Endif
#**
If [M:SRG2]PCUCOD   =3  Grizo [SRG2]PCUSCR     Else Actzo [SRG2]PCUSCR    : Endif
If [M:SRG2]QTYPCUCOD=3  Grizo [SRG2]QTYPCUSCR  Else Actzo [SRG2]QTYPCUSCR : Endif
If [M:SRG2]PCUSTUCOD=3  Grizo [SRG2]PCUSTUSCR  Else Actzo [SRG2]PCUSTUSCR : Endif
If [M:SRG2]QTYSTUCOD=2  Grizo [SRG2]QTYSTUSCR  Else Actzo [SRG2]QTYSTUSCR : Endif
If [M:SRG2]PJTCOD   =2  Grizo [SRG2]PJTSCR     Else Actzo [SRG2]PJTSCR    : Endif

If dim([M:SRG2]WRHCOD) >0
  If [M:SRG2]WRHOBY = 2
    Grizo [M:SRG2]WRHCOD
  Else
    Actzo [M:SRG2]WRHCOD
  Endif
Endif

WMODU +=format$("N0:2",[M:SRG0]SRTTYP)
Gosub RAZCRE From SUBETR

Gosub PE_STKTRS
Affzo [SRG0]1-99
#ffzo [SRG1]1-99
Affzo [SRG2]1-99
Return

#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
Case COUZON
  When "VCRTYPCOD"
       If val(CZ)=3
         [M:SRG2]VCRTYPSCR=1
         If !GIMPORT Affzo [SRG2]VCRTYPSCR : Grizo [SRG2]VCRTYPSCR     : Endif
       Elsif !GIMPORT
         Actzo [SRG2]VCRTYPSCR
       Endif
When "VCRNUMCOD"
       If val(CZ)=3
         [M:SRG2]VCRNUMSCR=1
         If !GIMPORT Affzo [SRG2]VCRNUMSCR : Grizo [SRG2]VCRNUMSCR     : Endif
       Elsif !GIMPORT
         Actzo [SRG2]VCRNUMSCR
       Endif
When "VCRLINCOD"
       If val(CZ)=3
         [M:SRG2]VCRLINSCR=1
         If !GIMPORT Affzo [SRG2]VCRLINSCR : Grizo [SRG2]VCRLINSCR     : Endif
       Elsif !GIMPORT
         Actzo [SRG2]VCRLINSCR
       Endif
When "IPTDATCOD"
       If val(CZ)=2
         [M:SRG2]IPTDATSCR=1
         If !GIMPORT Affzo [SRG2]IPTDATSCR : Grizo [SRG2]IPTDATSCR     : Endif
       Elsif !GIMPORT
         Actzo [SRG2]IPTDATSCR
       Endif
When "SRGPPSCOD"
       If val(CZ)=3
         [M:SRG2]SRGPPSSCR=1
         If !GIMPORT Affzo [SRG2]SRGPPSSCR : Grizo [SRG2]SRGPPSSCR     : Endif
       Elsif !GIMPORT
         Actzo [SRG2]SRGPPSSCR
       Endif
When "STUCOD"
       If val(CZ)=2
         [M:SRG2]STUSCR=1
         If !GIMPORT Affzo [SRG2]STUSCR : Grizo [SRG2]STUSCR     : Endif
       Elsif !GIMPORT
         Actzo [SRG2]STUSCR
       Endif
When "PCUSTUOCOD"
       If val(CZ)=2
         [M:SRG2]PCUSTUOSCR=1
         If !GIMPORT Affzo [SRG2]PCUSTUOSCR : Grizo [SRG2]PCUSTUOSCR     : Endif
       Elsif !GIMPORT
         Actzo [SRG2]PCUSTUOSCR
       Endif
When "QTYSTUOCOD"
       If val(CZ)=2
         [M:SRG2]QTYSTUOSCR=1
         If !GIMPORT Affzo [SRG2]QTYSTUOSCR : Grizo [SRG2]QTYSTUOSCR     : Endif
       Elsif !GIMPORT
         Actzo [SRG2]QTYSTUOSCR
       Endif

When "STAORICOD"
       If val(CZ)=2
         [M:SRG2]STAORISCR=1
         If !GIMPORT Affzo [SRG2]STAORISCR : Grizo [SRG2]STAORISCR     : Endif
       Elsif !GIMPORT
         Actzo [SRG2]STAORISCR
       Endif
When "LOCORICOD"
       If val(CZ)=3
         [M:SRG2]LOCORISCR=1
         If !GIMPORT Affzo [SRG2]LOCORISCR : Grizo [SRG2]LOCORISCR     : Endif
       Elsif !GIMPORT
         Actzo [SRG2]LOCORISCR
       Endif
When "WRHORICOD"
       If val(CZ)=3
         [M:SRG2]WRHORISCR=1
         If !GIMPORT Affzo [SRG2]WRHORISCR : Grizo [SRG2]WRHORISCR     : Endif
       Elsif !GIMPORT
         Actzo [SRG2]WRHORISCR
       Endif

When "PCUCOD"
       If val(CZ)=3
         [M:SRG2]PCUSCR=1
         If !GIMPORT Affzo [SRG2]PCUSCR : Grizo [SRG2]PCUSCR     : Endif
       Elsif !GIMPORT
         Actzo [SRG2]PCUSCR
       Endif
When "QTYPCUCOD"
       If val(CZ)=3
         [M:SRG2]QTYPCUSCR=1
         If !GIMPORT Affzo [SRG2]QTYPCUSCR : Grizo [SRG2]QTYPCUSCR     : Endif
       Elsif !GIMPORT
         Actzo [SRG2]QTYPCUSCR
       Endif
When "PCUSTUCOD"
       If val(CZ)=3
         [M:SRG2]PCUSTUSCR=1
         If !GIMPORT Affzo [SRG2]PCUSTUSCR : Grizo [SRG2]PCUSTUSCR     : Endif
       Elsif !GIMPORT
         Actzo [SRG2]PCUSTUSCR
       Endif
When "QTYSTUCOD"
       If val(CZ)=2
         [M:SRG2]QTYSTUSCR=1
         If !GIMPORT Affzo [SRG2]QTYSTUSCR : Grizo [SRG2]QTYSTUSCR     : Endif
       Elsif !GIMPORT
         Actzo [SRG2]QTYSTUSCR
       Endif
When "PJTCOD"
       If val(CZ)=2
         [M:SRG2]PJTSCR=1
         If !GIMPORT Affzo [SRG2]PJTSCR : Grizo [SRG2]PJTSCR     : Endif
       Elsif !GIMPORT
         Actzo [SRG2]PJTSCR
       Endif

  When Default
       Gosub APRES_MODIF From SUBETR
       Gosub PE_STKTRS
Endcase
Return

#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
WABR = "SRG0"
Gosub CHARGE_ATEXTRA From SUBETR
Gosub PE_STKTRS
Return

#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
$INIMOD
WABR = "SRG0"
Gosub CHARGE_ATEXTRA From SUBETR
Gosub PE_STKTRS
Return

#------------------------------------------------#
# Génération ou suppression des écrans de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(APPLI)<0 Local Char APPLI : Endif
If dim(WMODU)<0 Local Char WMODU(3) : Endif
If dim(OK)<0  : Local Integer OK : Endif
If APPLI=""    APPLI=nomap       : Endif
If WMODU=""    WMODU = "T"+format$("N0:2",[M:SRG0]SRTTYP) : Endif
Local Char     MFROM(GLONAMK)
Local Char     MTO(GLONAMK), MTOB(GLONAMK)
Local Integer  TBLOC(15)
Local Char     TZONE(GLONAVA)(200)
Local Integer  TMOD(200)
Local Char     TINT(1)(200)
Local Char     TTAB(1)(1)
Local Char     TFLD(1)(1)
Local Integer  OPT1, OPT2, OPT3, RETOUR
Local Integer  IZON, I, FLAG
Local Char     BOUTONS(10)(4)
Local Char     TEXTE(40), LISTE(3), REPONS(1)
Local Char     WNOMMSK(GLONAMK)
Local Shortint WFLGMSK





#---------------- Noms fenêtres et traitement pla de rangement---#
Local Char     WINREF1(GLONFEN) : WINREF1="ISSL"
Local Char     NOMWIN1(GLONFEN) : NOMWIN1="WQSSL"+[M:SRG0]SRTNUM+"1"
#-------------------------- 1er écran ---------------------------#
MFROM="SSL1"
MTO="W"+WMODU+[M:SRG0]SRTNUM+"1"
#MTO="WT"+num$([M:SRG0]SRTTYP)+[M:SRG0]SRTNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
    If [M:SRG2]VCRTYPCOD>1    TZONE(IZON)="VCRTYP"
                              TMOD(IZON) =[M:SRG2]VCRTYPCOD
                              IZON+=1
    Endif
    If [M:SRG2]VCRTYPSCR>1    TZONE(IZON)="VCRTYP"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRG2]VCRTYPSCR)
                              IZON+=1
    Endif
    If [M:SRG2]VCRNUMCOD>1    TZONE(IZON)="VCRNUM"
                              TMOD(IZON) =[M:SRG2]VCRNUMCOD
                              IZON+=1
    Endif
    If [M:SRG2]VCRNUMSCR>1    TZONE(IZON)="VCRNUM"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRG2]VCRNUMSCR)
                              IZON+=1
    Endif
    If [M:SRG2]VCRLINCOD>1    TZONE(IZON)="VCRLIN"
                              TMOD(IZON) =[M:SRG2]VCRLINCOD
                              IZON+=1
    Endif
    If [M:SRG2]VCRLINSCR>1    TZONE(IZON)="VCRLIN"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRG2]VCRLINSCR)
                              IZON+=1
    Endif
    If [M:SRG2]IPTDATCOD>1    TZONE(IZON)="IPTDAT"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SRG2]IPTDATSCR>1    TZONE(IZON)="IPTDAT"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRG2]IPTDATSCR)
                              IZON+=1
    Endif
    If [M:SRG2]SRGPPSCOD>1    TZONE(IZON)="SRGPPS"
                              TMOD(IZON) =[M:SRG2]SRGPPSCOD
                              IZON+=1
    Endif
    If [M:SRG2]SRGPPSSCR>1    TZONE(IZON)="SRGPPS"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRG2]SRGPPSSCR)
                              IZON+=1
    Endif
   If [M:SRG2]STUCOD   >1     TZONE(IZON)="STU"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
   If [M:SRG2]PCUSTUOCOD>1    TZONE(IZON)="PCUSTUCOEO"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
   If [M:SRG2]QTYSTUOCOD>1    TZONE(IZON)="QTYSTUORI"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SRG2]STAORICOD>1    TZONE(IZON)="STAORI"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SRG2]STAORISCR>1    TZONE(IZON)="STAORI"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRG2]STAORISCR)
                              IZON+=1
    Endif
    If [M:SRG2]LOCORICOD>1    TZONE(IZON)="LOCORI"
                              TMOD(IZON) =[M:SRG2]LOCORICOD
                              IZON+=1
    Endif
    If [M:SRG2]LOCORISCR>1    TZONE(IZON)="LOCORI"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRG2]LOCORISCR)
                              IZON+=1
    Endif

    If [M:SRG2]PCUCOD>1       TZONE(IZON)="PCU"
                              TMOD(IZON) =[M:SRG2]PCUCOD
                              IZON+=1
    Endif
    If [M:SRG2]PCUSCR>1       TZONE(IZON)="PCU"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRG2]PCUSCR)
                              IZON+=1
    Endif
    If [M:SRG2]QTYPCUCOD>1    TZONE(IZON)="QTYPCU"
                              TMOD(IZON) =[M:SRG2]QTYPCUCOD
                              IZON+=1
    Endif
    If [M:SRG2]QTYPCUSCR>1    TZONE(IZON)="QTYPCU"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRG2]QTYPCUSCR)
                              IZON+=1
    Endif
    If [M:SRG2]PCUSTUCOD>1    TZONE(IZON)="PCUSTUCOE"
                              TMOD(IZON) =[M:SRG2]PCUSTUCOD
                              IZON+=1
    Endif
    If [M:SRG2]PCUSTUSCR>1    TZONE(IZON)="PCUSTUCOE"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRG2]PCUSTUSCR)
                              IZON+=1
    Endif
    If [M:SRG2]QTYSTUCOD>1    TZONE(IZON)="QTYSTU"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SRG2]QTYSTUSCR>1    TZONE(IZON)="QTYSTU"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRG2]QTYSTUSCR)
                              IZON+=1
    Endif
    If [M:SRG2]PJTCOD   >1    TZONE(IZON)="PJT"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SRG2]PJTSCR   >1    TZONE(IZON)="PJT"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SRG2]PJTSCR)
                              IZON+=1
    Endif
    If dim([M:SRG2]WRHCOD) >0
       If [M:SRG2]WRHCOD>1   TZONE(IZON)="WRHE"               : # Dépôt
                             TMOD(IZON) =[M:SRG2]WRHCOD
                             IZON+=1
       Endif
    Endif
    If dim([M:SRG2]WRHORICOD) >0
       If [M:SRG2]WRHORICOD>1    TZONE(IZON)="WRHORI"
                                 TMOD(IZON) =[M:SRG2]WRHORICOD
                                 IZON+=1
       Endif
       If [M:SRG2]WRHORISCR>1    TZONE(IZON)="WRHORI"
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SRG2]WRHORISCR)
                                 IZON+=1
       Endif
   Endif

   Gosub TRT_CHAMP_DOC From SUBETR
   OPT1=2
   Gosub PE_STKTRS
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif
If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif
#--- Génération des écrans et fenêtres de stock
WNOMOBJ="SSL"
WNOMTRS=[M:SRG0]SRTNUM
WACSCOD=[M:SRG0]ACSCOD
WLIBEL =[M:SRG0]DESAXX
WENAFLG=[M:SRG0]ENAFLG
WNUM   =2
Gosub TRT_ECRAN_STO From SUBETR
Return

#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
#----- Suppression ----#
Call DELWIN(NOMWIN1,APPLI) From MSKDIV

Return

#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW" [AWI] : Endif : # Si appel par le FUNPURTRS
If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR" [AWP] : Endif : # Si appel par le FUNPURTRS
If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par le FUNSTKTRS
#----- Suppression fenêtre -------------#
Gosub TRT_SUP_FEN
If [M:SRG0]ENAFLG=1 : Return : Endif
#----- Génération fenêtre  si transaction active -----#
Read [AWI] AWI0=WINREF1
If !fstat
  [F:AWI]WIN       = NOMWIN1
  WNOMMSK=MTO : Gosub ONGLET_INVISIBLE
  I=find("SSL1",[F:AWI]NOMMSK(0..7))-1 : If I<0 I=0 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  [F:AWI]ACS       = [M:SRG0]ACSCOD
  [F:AWI]LIBEL     = [M:SRG0]DESAXX
  [F:AWI]ENAFLG    = 2
  [F:AWI]TRN       = [M:SRG0]SRTNUM
  Write [AWI]
  If fstat GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
  For [AWP] AWP0 Where WIN=WINREF1
    [F:AWP]WIN = NOMWIN1
    Write [AWP]
    If fstat GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
  Next
  For [AWB] AWB0 Where WIN=WINREF1
    [F:AWB]WIN = NOMWIN1
    Write [AWB]
    If fstat GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
  Next
  For [AWT] AWT0 Where WIN=WINREF1
    [F:AWT]WIN = NOMWIN1
    Write [AWT]
    If fstat GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
Endif
# Pour v140
Call VALID(NOMWIN1,APPLI,1,OK) From VALWIN

Return

#-----------------------------------------------------------------#
# Modification des écrans de base si sections d'entête invisibles #
#-----------------------------------------------------------------#
$MODIF_ECRAN
Return


#---------------------------------------#
# Restauration de l'écran de base SSL1  #
#---------------------------------------#
$RESTAUR_ECRAN
Return

#-------------------------------------------#
# Recherche si l'onglet doit être invisible #
# WNOMMSK = Nom de l'onglet (écran)         #
# WFLGMSK = 1 au retour si onglet invisible #
#-------------------------------------------#
$ONGLET_INVISIBLE
If clalev([F:AMK])<=0 Local File =APPLI+".AMSK"    [AMK] : Endif
If clalev([F:AMZ])<=0 Local File =APPLI+".AMSKZON" [AMZ] : Endif
Read [AMK] CODMSK=WNOMMSK
If fstat  Raz [F:AMK]  : WFLGMSK=2 : Return : Endif
WFLGMSK=1
For I=0 To [F:AMK]NBBLOC-1
  If [F:AMK]TYPBLOC(I)=1
    Read [AMZ] CODE=WNOMMSK;[F:AMK]BASPAG(I) : If fstat  Raz [F:AMZ] : Endif
    If [F:AMZ]SAIAFF<>3  WFLGMSK=2 : Break : Endif
  Elsif [F:AMK]TYPBLOC(I)<>5
    WFLGMSK=2 : Break
  Endif
Next I
Return


#########################################################################
#                   Actions sur champs écran [M:SRG0]                   #
#########################################################################
Subprog AS_SRTNUM(VALEUR)
#-----------------------#
# Avant saisie document #
#-----------------------#
Variable Char    VALEUR()
[M:SRG0]SRTTYP=5
End

########################################
Subprog AV_ENAFLG(VALEUR)
Variable Integer VALEUR
End

##########################################################################
## Etiquette ajoutée par le superviseur 12/04/2003 15:17:01 (MB)
##########################################################################
Subprog AS_SRTTYP(VALEUR)
Variable Integer VALEUR
End


##########################################################################

#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call GENPATCH(5,APPLI) From FUNSTKTRS

End
###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

Call GENDOS(5,APPLI) From FUNSTKTRS

End



#################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File STKTRS [SRT1]
Else
 Local File =[M]DOSORG+".STKTRS" [SRT1]
Endif
If [M]DOSDES=nomap
 Local File STKTRS [SRT2]
Else
 Local File =[M]DOSDES+".STKTRS" [SRT2]
Endif
OK = 1

If GTRACE=""
 Read [SRT2]SRT0 = 5;TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [SRT1], [SRT2]
Return

$TR_COP
GOK = 1
Trbegin [SRT2]
 Delete [SRT2] Where SRTTYP = 5 &
&                    SRTNUM = TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".STKTRS" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SRT2","") From GLOCK : Goto AB_TR_COP
 Endif
 Read [SRT1]SRT0=5;TABLE
 If !fstat
  [F:SRT2] = [F:SRT1]
  If dim([F:SRT2]UPDUSR)>0 : [F:SRT2]UPDUSR = GUSER : Endif
  If dim([F:SRT2]UPDDAT)>0 : [F:SRT2]UPDDAT = date$ : Endif
  If dim([F:SRT2]UPDTIM)>0 : [F:SRT2]UPDTIM = time  : Endif
  Write [SRT2]
  If fstat
   GOK=0 : Call FSTA("SRT2") From GLOCK
  Endif
 Endif
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif


Subprog AM_WRHOBY(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
    [M:SRG2]WRHCOD = 1
    Grizo [M:SRG2]WRHCOD
Else
    Actzo [M:SRG2]WRHCOD
Endif
Affzo [M:SRG2]WRHCOD

End


