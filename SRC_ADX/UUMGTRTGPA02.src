#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UUMGTRTGPA02   Migration des prix de revient               Module GPA  #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOS(DOSSIER,"") From SAIDOS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTGPA02") From LECFIC
  Endif

#  Call RAZ_UUMGTRTGPA02(DOSSIER)
  Call MAJ_UUMGTRTGPA02(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

Subprog MAJ_UUMGTRTGPA02(DOSSIER)
Value Char DOSSIER

Local Integer ERR

If [F:ADS]MODULE(7)<>2 : : # 7=GPAO
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTGPA02",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

Local Char WNAMMFCM,WNAMMCNM
Call MIGTABNAME (DOSSIER,"MFGCOST",WNAMMFCM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"MFCNAT",WNAMMCNM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTGPA02",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMMFCM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTGPA02",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMMCNM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTGPA02",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTGPA02",2,ERR) From TRTMIG : #2=En cours

Call ECR_TIME("UUMGTRTGPA02 tables MFC Process : Update MFC") From DOSSUB
Call ECR_TRACE("UUMGTRTGPA02 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"MFGCOST",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"MFCNAT",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:MFC])  = 0 : Local File =DOSSIER+".MFGCOST"    [MFC]  : Endif   # Fichier X3 "Vide"
If clalev([F:MCN])  = 0 : Local File =DOSSIER+".MFCNAT"    [MCN]  : Endif   # Fichier X3 "Vide"

If clalev([F:MFCM]) = 0 : Local File =DOSSIER+"."+WNAMMFCM   [MFCM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:MCNM]) = 0 : Local File =DOSSIER+"."+WNAMMCNM   [MCNM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBCOMMIT, NBLUS
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=6
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz STOP, CRITERE, NBCOMMIT, NBLUS

# Déclaration des variables communes de travail
Local Integer I, J
Local Char LFCY(GLONFCY),LITM(GLONITM), LNUM(50)
Local Integer LLIN

# pour les WriteB des tables détails
Local Char WTAB_MFC (100) (adxwrb)
Local Char WTAB_MCN (100) (adxwrb)
Local Shortint WCPT_MFC,WCPT_MCN

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTGPA02",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(4))

#-----  Lien des tables entête & lignes -----#
Link [MFCM] With [MCNM]MCN0=[F:MFCM]STOFCY;[F:MFCM]ITMREF;[F:MFCM]YEA;[F:MFCM]MFGNUM;[F:MFCM]MFGLIN
&    As [LNK]
&    Order By Key CLE = [F:MFCM]STOFCY;[F:MFCM]ITMREF;[F:MFCM]MFGNUM;[F:MFCM]MFGLIN;[F:MFCM]YEA Desc

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTGPA02" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Gosub INIT_TBO From UUMGTRTSTO00

LFCY=TABMIGKEY(1)
LITM=TABMIGKEY(2)
LNUM=TABMIGKEY(3)
LLIN=val(TABMIGKEY(4))

$LOOP_GPA02
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:MFCM]STOFCY=TABMIGKEY(1) & [F:MFCM]ITMREF=TABMIGKEY(2) & [F:MFCM]MFGNUM=TABMIGKEY(3) & [F:MFCM]MFGLIN="+TABMIGKEY(4)+"& [F:MFCM]YEA<"+TABMIGKEY(5)
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:MFCM]STOFCY=TABMIGKEY(1) & [F:MFCM]ITMREF=TABMIGKEY(2) & [F:MFCM]MFGNUM=TABMIGKEY(3) & [F:MFCM]MFGLIN>"+TABMIGKEY(4)
Elsif STOP=3
 STOP = 4
 CRITERE = "[F:MFCM]STOFCY=TABMIGKEY(1) & [F:MFCM]ITMREF=TABMIGKEY(2) & [F:MFCM]MFGNUM>TABMIGKEY(3)"
Elsif STOP=4
 STOP = 5
 CRITERE = "[F:MFCM]STOFCY=TABMIGKEY(1) & [F:MFCM]ITMREF>TABMIGKEY(2)"
Elsif STOP=5
 STOP = 0
 CRITERE = "[F:MFCM]STOFCY>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [MFC],[MCN]
GOK = 1

For [LNK]CLE(5) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTGPA02" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  # S'il existe un enreg avec MFGLIN=x+4 on vérifie qu'il n'en n'existe pas déjà un avec MFGLIN=x
  # Si c'est le cas, ce n'est pas normal => on ne le récupère pas
  If LFCY=[F:MFCM]STOFCY & LITM=[F:MFCM]ITMREF & LNUM=[F:MFCM]MFGNUM & [F:MFCM]MFCTYP=4
      Look [MFC]MFC0=[F:MFCM]STOFCY;[F:MFCM]ITMREF;10;[F:MFCM]MFGNUM;[F:MFCM]MFGLIN-4;4;0
      If !fstat
          Goto SUITE_BOUCLE
      Endif
  Endif
  If LFCY=[F:MFCM]STOFCY & LITM=[F:MFCM]ITMREF & LNUM=[F:MFCM]MFGNUM & LLIN=[F:MFCM]MFGLIN
      # On supprime les MFGCOST en doublon (seule l'année diffère)
      Goto SUITE_BOUCLE
  Else
      LFCY=[F:MFCM]STOFCY
      LITM=[F:MFCM]ITMREF
      LNUM=[F:MFCM]MFGNUM
      LLIN=[F:MFCM]MFGLIN
  Endif

  Raz [F:MFC]       # Issue 91893 - 2013-08-20 by CCC
  [F:MFC] = [F:MFCM]

  #Appel proc de migration sur entete
  Gosub MAJ30_MFC
  If GOK<1 : Break : Endif

  ############################
  #-- Boucle sur les lignes
  ############################
  For [LNK]CLE
    If [F:MCNM]OVENAT=""
        Break
    Endif

    Raz [F:MCN]     # Issue 91893 - 2013-08-20 by CCC
    [F:MCN] = [F:MCNM]

    #Appel proc de migration sur detail
    Gosub MAJ30_MCN
    If GOK<1 : Break : Endif

    Gosub MCN_STK : # pour stocker ref
    WriteB [MCN]
    If fstat
        Call ECR_TRACE("File MFCNAT, Error ="-num$(fstat),1) From GESECRAN
        Gosub MCN_ERRTRA : # pour afficher les ref
        GOK=0 : Break
    Endif
  Next

  If GOK<1 : Break : Endif

  # --- alimentation des champs et écriture enreg
   # --- alimentation des champs et écriture enreg
  Gosub MFC_STK : # pour stocker ref
  WriteB [F:MFC]
  If fstat
      Call ECR_TRACE("File MFGCOST, Error ="-num$(fstat),1) From GESECRAN
      Gosub MFC_ERRTRA : # pour afficher les ref
      GOK=0 : Break
  Endif

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:MFCM]STOFCY
    TABMIGKEY(2) = [F:MFCM]ITMREF
    TABMIGKEY(3) = [F:MFCM]MFGNUM
    TABMIGKEY(4) = num$([F:MFCM]MFGLIN)
    TABMIGKEY(5) = num$([F:MFCM]YEA)
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTGPA02",7,ERR) From TRTMIG : #7=Erreur
Else
    Flush [F:MFC]
    If fstat
        Call ECR_TRACE("File MFGCOST, Error ="-num$(fstat),1) From GESECRAN
        Gosub MFC_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:MCN]
    If fstat
        Call ECR_TRACE("File MFCNAT, Error ="-num$(fstat),1) From GESECRAN
        Gosub MCN_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
    If STOP
      TABMIGKEY(6)=num$(STOP)
    Else
      Raz TABMIGKEY
    Endif
    Call MIGSTKKEY (DOSSIER,"UUMGTRTGPA02",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
    If ERR
     GOK=-1 : Goto FIN_BOUCLE
    Endif
    NBCOMMIT+=NB
    Commit
    Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTGPA02",STOP,ERR) From TRTMIG
    If STOP
      Goto LOOP_GPA02
    Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [MFC], [MCN]
Close Local File [MFCM], [MCNM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"MFGCOST",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"MFCNAT",ERR) From TRTMIG
Call MIGTRTEND (DOSSIER,"UUMGTRTGPA02") From TRTMIG
Call ECR_TIME("UUMGTRTGPA02 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed") From DOSSUB
End

################################################
$MAJ30_MFC
    [F:MFC]VCRTYP=10
    [F:MFC]VCRNUM=[F:MFCM]MFGNUM
    If MFCTYP=4
        [F:MFC]QTYSTU = [F:MFCM]CPLQTY
        [F:MFC]VCRLIN = [F:MFCM]MFGLIN
    Else
        [F:MFC]QTYSTU = [F:MFCM]EXTQTY
        [F:MFC]VCRLIN = [F:MFCM]MFGLIN-[F:MFCM]MFCTYP
    Endif
    If [F:MFC]BOMALT>0
        [F:MFC]BOMALTTYP = WBOMALTTYP([F:MFCM]BOMALT)
    Else
        [F:MFC]BOMALTTYP = 0
    Endif
Return

################################################
$MAJ30_MCN
    [F:MCN]VCRNUM=[F:MFC]VCRNUM
    [F:MCN]VCRLIN=[F:MFC]VCRLIN
    [F:MCN]VCRTYP=[F:MFC]VCRTYP
    [F:MCN]MFCTYP=[F:MFC]MFCTYP
Return

################################################
$MFC_STK
Call STK (WTAB_MFC,WCPT_MFC,[F:MCN]STOFCY-'/'-[F:MCN]ITMREF-'/'-[F:MCN]VCRNUM-'/'-num$([F:MCN]VCRLIN)-'/'-num$([F:MCN]MFCTYP)-'/'-[F:MCN]OVENAT) From TRTMIG
Return
$MCN_STK
Call STK (WTAB_MCN,WCPT_MCN,[F:MCN]STOFCY-'/'-[F:MCN]ITMREF-'/'-[F:MCN]VCRNUM-'/'-num$([F:MCN]VCRLIN)-'/'-num$([F:MCN]MFCTYP)-'/'-[F:MCN]OVENAT) From TRTMIG
Return
##############################################################################################
$MFC_ERRTRA
Call ERRTRA (WTAB_MFC,WCPT_MFC,"File MFGCOST(STOFCY/ITMREF/VCRNUM/VCRLIN/MFCTYP)=") From TRTMIG
Return
$MCN_ERRTRA
Call ERRTRA (WTAB_MCN,WCPT_MCN,"File MFCNAT(STOFCY/ITMREF/VCRNUM/VCRLIN/MFCTYP/OVENAT)=") From TRTMIG
Return

##########################################################################
Subprog RAZ_UUMGTRTGPA02(DOSSIER)
Value Char DOSSIER

Local Integer ERR
Local Char WNAMMFCM,WNAMMCNM
Call MIGTABNAME (DOSSIER,"MFGCOST",WNAMMFCM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"MFCNAT",WNAMMCNM,ERR) From TRTMIG

If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMMFCM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif
If filinfo(filpath("FIL",WNAMMCNM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif

Call MIGTABRAZ (DOSSIER,"MFGCOST",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"MFCNAT",ERR) From TRTMIG

Call MIGRAZKEY (DOSSIER,"UUMGTRTGPA02",ERR) From TRTMIG

End
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call MAJ_UUMGTRTGPA02(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif

Call MAJ_UUMGTRTGPA02(APPLI)
End

