#<AdxTL>@(#)5.0.0.0 $Revision$
Call OUVRE_TRACE("") From LECFIC
Local File ADOSSIER [ADS]
GTRACE =''
Read [ADS]DOSSIER = "X3DEVV7"
Call ACHMAJ40

End

#####################################################################################
# ACHMAJ40 : Mises à jour à effectuer lors du passage à la version 7 Module achats  #
# --------------------------------------------------------------------------------- #
# Avant mise à jour AACHMAJ40                                                       #
#                                                                                   #
#####################################################################################
# --------------------------------------------------------------------------------- #
# Après mise à jour ACHMAJ40                                                        #
#    - Table PURTRS [PTR]                 : Transactions achats                     #
#                                                                                   #
#####################################################################################
#################################################################################
# Moulinettes avec anciens et nouveaux champs màj concernant le module achats   #
#################################################################################
Subprog AACHMAJ40

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ40 : Process for common data") From LECFIC
    WOUV_TRACE=1
Endif

Gosub SET_FIRST   From TRTFIRST

# Migration process here

Gosub UNSET_FIRST   From TRTFIRST

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End

##################################################################################
# Moulinettes avec champs version V7 uniquement màj concernant le module achats  #
##################################################################################
Subprog ACHMAJ40

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ40 : Process for common data") From LECFIC
    WOUV_TRACE=1
Endif

Gosub SET_FIRST   From TRTFIRST

Call ECR_TIME("DOSMAJ40 Purchase Transactions Process : Update PURTRS") From DOSSUB
Call UPDPTR([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif

Gosub UNSET_FIRST   From TRTFIRST

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End

#################################################################################
# Met à jour la table PURTRS
#################################################################################
# PICRETFLG : initialisé à 2 pour les transactions de commande
#################################################################################
Subprog UPDPTR(PDOS)
Value Char    PDOS
# Issue 95957 - 2014-01-20 by SR
Local Integer WNBENR, FLAG

If filinfo(filpath("FIL","PURTRS","fde",PDOS),0)<=0  : End : Endif

Local File =PDOS+".PURTRS"    [PTR]

Call DEBTRANS From GLOCK
Trbegin [PTR]
# Issue 95957 - 2014-01-20 by SR
For [PTR] PTR0  Where PTRTYP = 3
  Raz FLAG
  If [F:PTR]PICRETFLG = 0 : [F:PTR]PICRETFLG = 2 : FLAG = 1 : Endif
  If FLAG
     Rewrite [PTR]
     If fstat
       Call ECR_TRACE("File PURTRS 3"-[F:PTR]PTRNUM+", Error ="-num$(fstat),1) From GESECRAN
     Endif
  Endif
  WNBENR+=1
Next
#Update [PTR] Where PTRTYP = 3 & PICRETFLG = 0 With PICRETFLG = 2
#If fstat
#   Call FSTA("PTR") From GLOCK
#Else
#    WNBENR+=adxuprec
#Endif
Commit
Call ECR_TIME("ACHMAJ40 Puchase Transactions Process :"-num$(WNBENR)-"record updated") From DOSSUB
Close Local File [PTR]
End
