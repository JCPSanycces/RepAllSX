# Gestion du masque SMBENCHW2 selon MBENCHW2
# Traitement de la fenêtre dans BENCHLIBS 
# - Action FDISPNEO , fenetre IDISPNEO  (selon FDISPNOW)
# - Action FDISPNEON, fenetre IDISPNEON (selon FDISPNOWN)
#   disponibilité matière à date

########################################
Subprog AS_NBLIG
GBOUT1 = mess(157,198,1)
End

########################################
Subprog B1_NBLIG
Local Integer  L : L = nolign - 1
Call OBJET("ITF",[M:SMW2]MFGFCY,[M:SMW2]ITMREF(L)) From GOBJET  
End

########################################
Subprog AV_DIFFSTO(VALEUR)
Variable Decimal VALEUR
Local Integer L : L = nolign-1
If VALEUR < 0
  pcolor = GCOUL(1)
Else 
  pcolor = GCOUL(0)
Endif
End


