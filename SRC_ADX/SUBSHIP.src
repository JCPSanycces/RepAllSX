# Issue 111257 US 42
######################################################################################
## Etiquette ajoutée par le superviseur (écran SHIPTRACK) 16/06/2016 14:37:18 (MAE)
######################################################################################
Subprog IB_NBLIGNE
If GPILNAV>1
  # Issue 121685 - 2017-03-13 by MAE : Ajout de GFONC1
  If (GNAVIG(GPILNAV-1) = "GESPPTS") | (GFONC1="GESPPTS")
    Raz GBOUT1
    Raz GBOUT2
    End
  Endif
Endif
Case [M:SHIPT]TRKLIGSTAT(nolign-1)
  When 1
    Raz GBOUT1
    GBOUT2 = mess(3,2250,1)
  When 2
    GBOUT1 = mess(3,21,1)
    Raz GBOUT2
  When 3
    GBOUT1 = mess(50,9139,1)
    Raz GBOUT2
Endcase
End
######################################################################################
Subprog C_NBLIGNE
Local Integer IRET
Local Integer INDEX
  # ---------------------------------------------------------------------------------
If GPILNAV>1
  If GNAVIG(GPILNAV-1) = "GESSHIP"
    If (status = 82 or status = 73)
      If nolign > [M:SHIPT]NBLIGNE Then
        # Add a new line at the end
        If WSHIPMENT <> null
          INDEX = fmet WSHIPMENT.ADDLINE("SHIPT", [V]CST_ALASTPOS)
          If INDEX <> [V]CST_ANOTDEFINED Then
            Call SHOW_TRACK_LINE(INDEX) From SUBSHIPA
            Affzo [M:SHIPT]1-99
          Else
            Dela nolign-1,1 [M:SHIPT]NBLIGNE
            [M:SHIPT]NBLIGNE-=1
            GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WSHIPMENT)
            GERR = 4
            mkstat = 2
            GOK = 1
            End
          Endif
        Endif
      Endif
    Elsif status = 65 Then
      # Delete a line
      IRET = fmet WSHIPMENT.ADELLINE("SHIPT", WSHIPMENT.SHIPT([M:SHIPT]COLLIN(nolign-1)).AORDER)
      If IRET = [V]CST_ANOTDEFINED Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WSHIPMENT)
        GOK = 0
        GERR = 1
        mkstat = 2
      Endif
      Call SHOW_TRACK_LINE([M:SHIPT]COLLIN(nolign-1)) From SUBSHIPA
      Affzo [M:SHIPT]1-99
    Endif
  Endif
Endif
End

######################################################################################
Subprog AV_TRKCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDEX

If GPILNAV>1
  If GNAVIG(GPILNAV-1) = "GESSHIP"
    If [M:SHIPT]STLIN(nolign-1) = 0 Then
      If WSHIPMENT <> null
        INDEX = fmet WSHIPMENT.ADDLINE("SHIPT", nolign)
        If INDEX <> [V]CST_ANOTDEFINED Then
          Call SHOW_TRACK_LINE(INDEX) From SUBSHIPA
          Affzo [M:SHIPT]1-99
        Else
          # Afficher le message d'erreur
          Dela nolign-1,1 [M:SHIPT]NBLIGNE
          [M:SHIPT]NBLIGNE-=1
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WSHIPMENT)
          GERR = 4
          mkstat = 2
          GOK = 1
          End
        Endif
      Endif
    Endif
  Endif
Endif
End
######################################################################################
Subprog AM_TRKDEPCOD(VALEUR)
Variable Char    VALEUR()
Local Integer WPOS
# Issue 53814 - 2017-09-04 by MAE
#If VALEUR <> AVOID.ACHAR
# End issue 53814
  WPOS = find(toUuid([M:SHIPT]AUUID(nolign-1)), WSHIPMENT.SHIPT(1..maxtab(WSHIPMENT.SHIPT)).AUUID)
  If WPOS = 0
    GMESSAGE = "Position not found"
    GOK=0 : GERR=1
    End
  Else
    WSHIPMENT.SHIPT(WPOS).TRKDEPCOD = VALEUR
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WSHIPMENT)
      If GMESSAGE <> AVOID.ACHAR
        GOK = 0:GERR = 1:mkstat = 2
        #la classe a renvoyé une erreur mais l'erreur sur le propagate n'empêche pas l'enregistrement
        VALEUR = AVOID.ACHAR
        End
      Endif
  Endif
  VALEUR = WSHIPMENT.SHIPT(WPOS).TRKDEPCOD
# Issue 53814 - 2017-09-04 by MAE
#Endif
# End issue 53814
End
######################################################################################
# End issue 111257 US 42

######################################################################################
## Etiquette ajoutée par le superviseur (écran SHIPTRACK) 23/05/2016 14:34:24 (MAE)
######################################################################################
Subprog AM_TRKENDDAT(VALEUR)
Variable Date    VALEUR
#si ligne dépendante, la ligne mére doit être terminée
If [M:SHIPT]TRKDEPLIN(nolign-1) <> AVOID.ADEC
    #recherche de la ligne mére
    WIND = find([M:SHIPT]TRKDEPLIN(nolign-1), WSHIPMENT.SHIPT(1..maxtab(WSHIPMENT.SHIPT)).STLIN)
    If WIND <> 0
      If WSHIPMENT.SHIPT(WIND).TRKENDDAT = AVOID.ADATE & VALEUR <> AVOID.ADATE
        GMESSAGE = mess(560,194,1)
        GERR=1
        OK = 0
        mkstat = 2
        End
      Endif
    Endif
  Endif
  # Issue 122200 - 2017-03-30 by MAE
  #If [M:SHIPT]TRKLIGSTAT(nolign-1) <> 3
  If VALEUR <> AVOID.ADATE
    [M:SHIPT]TRKENDDAT(nolign-1) = VALEUR
    [M:SHIPT]TRKUSR(nolign-1) = WSHIPMENT.ACTX.USER
    [M:SHIPT]TRKLIGSTAT(nolign-1) = 3
  Else
    [M:SHIPT]TRKENDDAT(nolign-1) = AVOID.ADATE
    [M:SHIPT]TRKUSR(nolign-1) = AVOID.ACHAR
    [M:SHIPT]TRKLIGSTAT(nolign-1) = 1
  Endif
  Affzo[M:SHIPT]
End


