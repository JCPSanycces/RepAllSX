######################################################################################
Subprog AV_TRKNUM(VALEUR)
Variable Char    VALEUR()
If [M:SHIPT]NBLIGNE >0
  Diszo [M:SHIPT]TRKNUM
Else
  Actzo [M:SHIPT]TRKNUM
Endif
End

