######################################################################################
Subprog AM_SDFILNAM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  Actzo [M:SHIPD]SDDOC(nolign-1)
  [M:SHIPD]SDDOC(nolign-1) = "175"
Else
  Grizo [M:SHIPD]SDDOC(nolign-1)
  [M:SHIPD]SDDOC(nolign-1) = "191"
  Raz GBOUT2
Endif
Affzo [M:SHIPD]SDDOC(nolign-1)
End


