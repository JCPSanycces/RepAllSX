Subprog AM_LOCTYPSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR <> AVOID.ACHAR and [M:LPR]LOCTYPEND = AVOID.ACHAR
  [M:LPR]LOCTYPEND = VALEUR
Endif
End

Subprog AM_LOCSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR <> AVOID.ACHAR and [M:LPR]LOCEND = AVOID.ACHAR
  [M:LPR]LOCEND = VALEUR
Endif
End


