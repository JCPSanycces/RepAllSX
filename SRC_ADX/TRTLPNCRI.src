#<AdxTL>@(#)0.0.0.0 $Revision$
#CHECK UNUSED_BEGIN
Local Char PARAM(250)(1..20) , SAVACT(10)
PARAM(1) = "ALL"
Local Decimal VALEUR
#SAVACT = GACTION : GACTION = "SAILPNCRI"
Call SAISIE_NUM(VALEUR,PARAM,"ILPNCRI","TRTLPNCRI") From GSAISIE
#GACTION = SAVACT
End
#CHECK UNUSED_END

###################################################################################################
# TRTLPNCRI    Saisie des filtres pour la liste de picking des affectations de contenant interne  #
###################################################################################################

$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "ENR"         : Gosub ENR
 When "ABA"         : Gosub ABA
Endcase
Return

#########################################################################
$OUVRE_BOITE

Gosub FORMAT_INV From STKLIB

Return

#########################################################################
$DEBUT

Local Integer I,J

Raz[M:LPR] : Transmask [M:LPNA] To [M:LPR]  # Issue 25606_Transmask [M:LPR] = [M:SCS1]
If [M:LPNA]STOFCY=""
    Call ERREUR(mess(215,193,1)) From GESECRAN
    FIN=1
    Return
Endif


Affzo [M:LPR]

Return

#########################################################################
$SETBOUT

ETABOU(GENRE)=1
ETABOU(GABAN)=1

Return
#########################################################################
$ENR

[M:LPNA] = [M:LPR]

If [M:LPR]LOTSTR = [M:LPR]LOTEND
  [M:LPNA]LOTSEL = [M:LPR]LOTSTR
Else
  [M:LPNA]LOTSEL = ""
Endif
If [M:LPR]LOCSTR = [M:LPR]LOCEND
  [M:LPNA]LOCSEL = [M:LPR]LOCSTR
Else
  [M:LPNA]LOCSEL = AVOID.ACHAR
Endif

Affzo [M:LPNA]LOTSEL
Affzo [M:LPNA]LOCSEL
Affzo [M:LPNA]ITMREFSEL

FIN = 1

Return

#########################################################################
$ABA

# Réalimentation avec les valeurs initiales
Gosub DEBUT

Return


Subprog AM_ITMREFSEL(VALEUR)
Variable Char    VALEUR()
    Read [ITF]ITF0 = VALEUR;[M:LPNA]STOFCY
    If fstat
        mkstat = 2
    Endif
    If !mkstat
        If dim([M:LPR]SERNUMSTR)>0
            If [F:ITM]SERMGTCOD>1
                Actzo [M:LPR]SERNUMSTR,SERNUMEND
            Else
                Effzo [M:LPR]SERNUMSTR,SERNUMEND
                Diszo [M:LPR]SERNUMSTR,SERNUMEND
            Endif
        Endif

        If [F:ITM]LOTMGTCOD<=1
            If dim([M:LPR]LOTSTR)>0
                Effzo [M:LPR]LOTSTR,LOTEND
                Diszo [M:LPR]LOTSTR,LOTEND
            Endif
            If dim([M:LPR]SLOSTR)>0
                Effzo [M:LPR]SLOSTR,SLOEND
                Diszo [M:LPR]SLOSTR,SLOEND
            Endif
        Elsif [F:ITM]LOTMGTCOD=4
            If dim([M:LPR]LOTSTR)>0
                Actzo [M:LPR]LOTSTR,LOTEND
            Endif
            If dim([M:LPR]SLOSTR)>0
                Actzo [M:LPR]SLOSTR,SLOEND
            Endif
        Else
            If dim([M:LPR]LOTSTR)>0
                Actzo [M:LPR]LOTSTR,LOTEND
            Endif
            If dim([M:LPR]SLOSTR)>0
                Effzo [M:LPR]SLOSTR,SLOEND
                Diszo [M:LPR]SLOSTR,SLOEND
            Endif
        Endif

        If dim([M:LPR]LOCSTR)>0
            If [F:ITF]LOCMGTCOD=2
                Actzo [M:LPR]LOCSTR,LOCEND
            Else
                Effzo [M:LPR]LOCSTR,LOCEND
                Diszo [M:LPR]LOCSTR,LOCEND
            Endif
        Endif
        Affzo [M:LPR]20
    Endif
End


##########################################################################
## Etiquette ajoutée par le superviseur 11/09/2003 08:27:05 (CCC)
##########################################################################
Subprog AM_LOTSTR(VALEUR)
Variable Char    VALEUR()
    If [M:LPR]LOTEND=[M:LPR]LOTSTR | [M:LPR]LOTEND<VALEUR
        [M:LPR]LOTEND = VALEUR
        Affzo [M:LPR]LOTEND
    Endif
End

Subprog C_LOTEND(VALEUR)
Variable Char    VALEUR()
    If [M:LPR]LOTSTR>VALEUR
        GMESSAGE = mess(44,199,1)
        mkstat=2
    Endif
    If VALEUR = ""
        VALEUR = [M:LPR]LOTSTR
    Endif
    If dim([M:LPR]SLOSTR)>0
        If VALEUR=[M:LPR]LOTSTR
            Actzo [M:LPR]SLOSTR,SLOEND
        Else
            Effzo [M:LPR]SLOSTR,SLOEND
            Diszo [M:LPR]SLOSTR,SLOEND
        Endif
    Endif
End

Subprog AM_SLOSTR(VALEUR)
Variable Char    VALEUR()
    If [M:LPR]SLOEND=[M:LPR]SLOSTR | [M:LPR]SLOEND<VALEUR
        [M:LPR]SLOEND = VALEUR
        Affzo [M:LPR]SLOEND
    Endif
End

