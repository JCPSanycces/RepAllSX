######################################################################################
## Etiquette ajoutée par le superviseur (écran SCLPRI) 12/10/2004 17:42:24 (TS)
######################################################################################

##########################################################################
Subprog C_AUZSST(VALEUR)
Variable Char    VALEUR()

Local Integer I,J
Local Char    WWSTA(30)
Local Char    WSTA(3)(20)

If VALEUR="" Raz [M:LPR]FORSTA : End Endif

VALEUR=toupper(VALEUR)
WWSTA=VALEUR
J=instr(J,WWSTA,",")
While J<>0
   WSTA(I)=left$ (WWSTA,J-1)
   WWSTA  =right$(WWSTA,J+1)
   J=instr(J,WWSTA,",")
   I+=1
Wend
J=I
WSTA(I)=WWSTA
For I=0 To J
   If !find(left$(WSTA(I),1),"A","Q","R")
      mkstat=2 : GMESSAGE=mess(21,199,1)
      Break
   Elsif len(WSTA(I))>GLONSTA
      mkstat=2 : GMESSAGE=mess(456,199,1)-num$(GLONSTA)
      Break
   Endif
Next I

# Construction de la formule :
Call DECODE_STAT(VALEUR,[M:LPR]FORSTA) From TRTCATEG

End

##########################################################################
Subprog B1_AUZSST(VALEUR)
Variable Char    VALEUR()

If find([M:SCS1]BETFCYCOD,2,4)
   VALEUR = [F:SRU]AUZSST
Else
   Raz VALEUR
Endif

End

