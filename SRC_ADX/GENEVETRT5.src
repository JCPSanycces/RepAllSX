#<AdxTL>@(#)2.0.0.0 $Revision$
 Call VALIDATION("LOFCIM","LOFCIM1",nomap) From GENEVETRT5
End

################################################################################
#    Sous-programme de génération des traitement d'alimentation des événements
#    à partir du contenu des tables PAREVT et PAREVTD.
#    GBN
#    Création le : 09/08/2007
#    Modification le : xx/xx/xxxx
#    Version X3
#
# Issue  X3-64332 - 2017-12-21 by CBO : tester par if dim() les affectations directes autour des DIE CCE
# CBO   25.09.2017 X3-41592    : Dossier d'indus correspondant au dossier de ref
################################################################################
#**
#*
#*
#* @param PEVT
#* @param PEVTINT
#* @param APPLI_PARAM     appli ou se trouve le paramétrage (TABLES PAREVT et PAREVTD)
#* @param APPLI_TRT       appli ou se trouvent les sources et traitements générés
#*!
Subprog VALIDATION(PEVT, PEVTINT, APPLI_PARAM, APPLI_TRT)
Value Char    PEVT()
Value Char    PEVTINT()
Value Char    APPLI_PARAM()
Value Char    APPLI_TRT()

Local Char    NOMTRT(30)
Local Char    FICSRC(250)
Local Char    CODOBJ(30)
Local Integer OK, I_EVTINT, I_CHEVT, REFOBJ, T_NBFLDPRORAT
Local Char    EVTINT(10)(1..100)
Local Char    EVTNAM(30)
Local Char    EVTTAB(30)
Local Integer I_CODACT
Local Integer LCODACT
Local Char    LGLOACT(30)

Local Char    PRFX_COM(30)  : PRFX_COM="G"
Local Char    PRFX_INT(30)  : PRFX_INT=PRFX_COM+"V"

  If !clalev([F:ADI])  : Local File =APPLI_PARAM+".ATABDIV" [ADI] : Endif
  If !clalev([F:GVTR]) : Local File =APPLI_PARAM+".PAREVT"  [PVT] : Endif
  If !clalev([F:GVDA]) : Local File =APPLI_PARAM+".PAREVTD" [PVD] : Endif


  #> Ouverture du fichier source à générer : GV+pevtint.src
  #  ------------------------------------------------------

  NOMTRT = PRFX_INT+PEVTINT
  FICSRC = filpath("TRT", NOMTRT, "src", APPLI_TRT)
  Openo FICSRC,0
  adxifs = ""
  adxirs = chr$(10)

  #> Lecture de la table diverse
  #  ---------------------------

  Read [F:ADI]CODE=962;PEVT
  EVTTAB=[F:ADI]A2
  REFOBJ=[F:ADI]N2


  #> Lecture de la table de paramétrage
  #  ----------------------------------

  Read [F:PVT]PVT1=PEVT;PEVTINT

  #> En-tête
  #  -------

  Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
  Wrseq '# MODIFIE PAR :'-GUSER
  Wrseq '# LE          :'-format$("DD4",date$)
  Wrseq ''

  #> Ouverture des tables
  #  --------------------

  Wrseq '$OUVRE_TABLE'
  Wrseq ' If dim(APPLI)<0 : Local Char APPLI(30) : APPLI=nomap : Endif'
  Wrseq ' If !clalev([F:EVT0]) : Local File =APPLI+".'+EVTTAB+'" [EVT0] : Endif'
  Wrseq ' If !clalev([F:EVT1]) : Local File =APPLI+".'+EVTTAB+'" [EVT1] : Endif'
  Wrseq 'Return'
  Wrseq ''

  #> Condition pour la recherche d'existence d'un événement
  #  ------------------------------------------------------

  Wrseq '$CONDITION_EVE'
  Case REFOBJ
    When GVML_OMDEPEN
      Wrseq ' LCNDREQEVT="CPY=PCPY & REF=PREF & LIN=PLIN & DPRPLN=LPLN &EVTINT=CODEVTINT & SNSEVE=PSNSEVE"'
    When GVML_OMBIEN
      Wrseq ' LCNDREQEVT="CPY=PCPY & REF=PREF & DPRPLN=LPLN & EVTINT=CODEVTINT & SNSEVE=PSNSEVE"'
    When GVML_OMSUBV
      Wrseq ' LCNDREQEVT="CPY=PCPY & REF=PREF & DPRPLN=LPLN & EVTINT=CODEVTINT & SNSEVE=PSNSEVE"'
    When GVML_OMLOCFI
      Wrseq ' LCNDREQEVT="CPY=PCPY & REF=PREF & DPRPLN=LPLN & EVTINT=CODEVTINT & SNSEVE=PSNSEVE"'
    When Default
      Wrseq ' LCNDREQEVT=""'
  Endcase
  Wrseq 'Return'
  Wrseq ''

  #> Raz de l'enregistrement [EVT0] et [EVT1]
  #  ----------------------------------------

  Wrseq '$RAZ_F_EVT0_1'
  Wrseq ' Raz [F:EVT0]'
  Wrseq ' Raz [F:EVT1]'
  Wrseq 'Return'
  Wrseq ''


  #> Bloc principal
  #  --------------

  Wrseq '$AIGUILLAGE'
  Wrseq ' Gosub OUVRE_TABLE'
  Wrseq ' Gosub RAZ_F_EVT0_1'
  Wrseq ' Gosub '+PEVTINT
  Wrseq ' [F:EVT0]CPY       = PCPY'
  Wrseq ' [F:EVT0]FCY       = PFCY'
  Wrseq ' [F:EVT0]REF       = PREF'
  Wrseq ' [F:EVT0]CURPERSTR = LCURPERSTR'  : # FQ101826
  If REFOBJ=GVML_OMDEPEN
   Wrseq' [F:EVT0]LIN       = PLIN'
  Endif
  Wrseq ' [F:EVT0]CREUSR    = GUSER'
  Wrseq ' [F:EVT0]CREDAT    = date$'
  Wrseq ' [F:EVT0]CRETIM    = time'
  Wrseq ' [F:EVT0]UPDUSR    = ""'
  Wrseq ' [F:EVT0]UPDDAT    = [0/0/0]'
  Wrseq ' [F:EVT0]DPRPLN    = LPLN'
  Wrseq ' [F:EVT0]EVTINT    = CODEVTINT'
  Wrseq ' [F:EVT0]EVTDAT    = PDAT'
  Wrseq ' [F:EVT0]CPTFLG    = 1'
  Wrseq ' [F:EVT0]SNSEVE    = '-num$(GVML_TEACT)
  Wrseq ' [F:EVT0]CREUSRO   = ""'
  Wrseq ' [F:EVT0]TIMSTPO   = ""'
# Wrseq ' [F:EVT0]CPTDATINTO = [0/0/0]'
  Wrseq ' If PACCDAT<>[0/0/0]'
  Wrseq '  [F:EVT0]CPTDATINT = PACCDAT'
  Wrseq ' Else'
  Wrseq '  [F:EVT0]CPTDATINT = PDAT'
  Wrseq ' Endif'
  Wrseq ' Gosub CALCUL_TIMSTP'
  Wrseq ' Gosub ALIM_CUR'
  Wrseq 'Return'
  Wrseq ' '

  #> Calcul du TIMSTP
  #  ----------------

  Wrseq '$CALCUL_TIMSTP'
  Wrseq ' [F:EVT0]TIMSTP = func GENEVE.BUILD_TIMSTP([F:EVT0]CREDAT, [F:EVT0]CRETIM)'
  Wrseq 'Return'
  Wrseq ''

  #> Alimentation de la devise
  #  -------------------------

  Wrseq '$ALIM_CUR'
  Wrseq ' [F:EVT0]CUR=Func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY,[F:EVT0]DPRPLN)'
  Wrseq 'Return'
  Wrseq ''

  #> Annule un événement
  #  ------------------

  Wrseq '$ANNULE_EVE'
  Wrseq ' [F:EVT0]SNSEVE = '-num$(GVML_TEAACT)
  Wrseq ' [F:EVT0]CREUSRO = [F:EVT0]CREUSR'
  Wrseq ' [F:EVT0]TIMSTPO = [F:EVT0]TIMSTP'
  Wrseq ' [F:EVT0]CPTDATINTO = [F:EVT0]CPTDATINT'
  Wrseq ' [F:EVT0]CREUSR = GUSER'
  Wrseq ' [F:EVT0]CREDAT = date$'
  Wrseq ' [F:EVT0]CRETIM = time'
  Wrseq ' [F:EVT0]UPDUSR = ""'
  Wrseq ' [F:EVT0]UPDDAT = [0/0/0]'
  Wrseq ' [F:EVT0]CPTFLG = 1'
  Wrseq ' [F:EVT0]EVTDAT = PDAT'
  Wrseq ' Gosub CALCUL_TIMSTP'
  Wrseq 'Return'
  Wrseq ''

  #> Alimentation des champs spécifiques au type événement
  #  -----------------------------------------------------

  Wrseq'$'+PEVTINT
  Filter [PVD] Where (EVTINT=PEVTINT & FLDNAM="DES") # Zone désignation
  Wrseq' #'+string$(2,'-')+'> Désignation'
  For [PVD]
   If [F:PVD]FLDFIL<>""
    Wrseq' [F:EVT0]DES'+space$(18-len("[F:EVT0]DES"))+' = '+[F:PVD]FLDFIL
   Endif
  Next

  #> Menus locaux

  Filter [PVD] Where (EVTINT=PEVTINT & (FLDTYP=1 | FLDTYP=2))
  Raz I_CHEVT
  Wrseq' #'+string$(2,'-')+'> Menus locaux'
  For [PVD]PVD2
    If [F:PVD]FLDFIL<>""
     Raz LCODACT, LGLOACT : If [F:PVD]FLDACT<>"" : Gosub TRT_COD_ACT : Endif
     If LCODACT
      Wrseq' If '+LGLOACT+'=G_OUI'
      Wrseq'  [F:EVT0]'+[F:PVD]FLDNAM+space$(10-len([F:PVD]FLDNAM))+' = '+[F:PVD]FLDFIL
      Wrseq' Endif'
     Else
      Wrseq' [F:EVT0]'+[F:PVD]FLDNAM+space$(10-len([F:PVD]FLDNAM))+' = '+[F:PVD]FLDFIL
     Endif
     I_CHEVT+=1
    Endif
  Next

  #> Numériques

  Filter [PVD] Where (EVTINT=PEVTINT & FLDTYP=4)
  Raz I_CHEVT
  Wrseq' #'+string$(2,'-')+'> Zones numériques'
  For [PVD]PVD2
    If [F:PVD]FLDFIL<>""
      Raz LCODACT, LGLOACT : If [F:PVD]FLDACT<>"" : Gosub TRT_COD_ACT : Endif
      If LCODACT
       Wrseq' If '+LGLOACT+'=G_OUI'
       Wrseq'  [F:EVT0]'+[F:PVD]FLDNAM+space$(10-len([F:PVD]FLDNAM))+' = '+[F:PVD]FLDFIL
       Wrseq' Endif'
      Else
       Wrseq' [F:EVT0]'+[F:PVD]FLDNAM+space$(10-len([F:PVD]FLDNAM))+' = '+[F:PVD]FLDFIL
      Endif
      I_CHEVT+=1
      If [F:PVD]FLDPRORAT = G_OUI
        T_NBFLDPRORAT += 1
      Endif
    Endif
  Next

  #> Alphanumériques
# Issue X3-64332
  Filter [PVD] Where (EVTINT = PEVTINT and FLDTYP = 7 and FLDNAM <> "DES")
  Raz I_CHEVT
  Wrseq ' #' + string$(2, '-') + '> Zones alphanumériques'
  For [PVD]PVD2
    If [F:PVD]FLDFIL <> ""
      Raz LCODACT, LGLOACT
      If [F:PVD]FLDACT <> ""
        Gosub TRT_COD_ACT
      Endif
      If LCODACT
        Wrseq ' If ' + LGLOACT + '=G_OUI'
        If (left$([F:PVD]FLDNAM, 3) = "DIE" or left$([F:PVD]FLDNAM, 3) = "CCE") and left$([F:PVD]FLDFIL, 3) = "[M:"
          Gosub AFF_CCEDIE
        Else
          Wrseq '  [F:EVT0]' + [F:PVD]FLDNAM + space$(10 - len([F:PVD]FLDNAM)) + ' = ' + [F:PVD]FLDFIL
        Endif
        Wrseq ' Endif'
      Else
        If (left$([F:PVD]FLDNAM, 3) = "DIE" or left$([F:PVD]FLDNAM, 3) = "CCE") and left$([F:PVD]FLDFIL, 3) = "[M:"
          Gosub AFF_CCEDIE
        Else
          Wrseq ' [F:EVT0]' + [F:PVD]FLDNAM + space$(10 - len([F:PVD]FLDNAM)) + ' = ' + [F:PVD]FLDFIL
        Endif
      Endif
      I_CHEVT += 1
    Endif
  Next
# End issue X3-64332
  #> Dates

  Filter [PVD] Where (EVTINT=PEVTINT & FLDTYP=8)
  Raz I_CHEVT
  Wrseq' #'+string$(2,'-')+'> Dates'
  For [PVD]PVD2
    If [F:PVD]FLDFIL<>""
      Raz LCODACT, LGLOACT : If [F:PVD]FLDACT<>"" : Gosub TRT_COD_ACT : Endif
      If LCODACT
       Wrseq' If '+LGLOACT+'=G_OUI'
       Wrseq'  [F:EVT0]'+[F:PVD]FLDNAM+space$(10-len([F:PVD]FLDNAM))+' = '+[F:PVD]FLDFIL
       Wrseq' Endif'
      Else
       Wrseq' [F:EVT0]'+[F:PVD]FLDNAM+space$(10-len([F:PVD]FLDNAM))+' = '+[F:PVD]FLDFIL
      Endif
      I_CHEVT+=1
    Endif
  Next
  Filter [PVD]
  Wrseq'Return'
  Wrseq''

  #> Liste des champs numériques à éclater
  #  -------------------------------------

  Local Integer NBUSRFLD : NBUSRFLD = 6
  Wrseq '$ECLATE_NBFLD'
  Wrseq ' LNBFLD='+num$(T_NBFLDPRORAT-NBUSRFLD)
  Wrseq 'Return'
  Wrseq''

  Wrseq '$ECLATE_STATUS'
  Local Integer I_ZON
  Filter [PVD] Where (EVTINT=PEVTINT & FLDTYP=4 & FLDPRORAT=G_OUI) & left$(FLDNAM,6)<>"USRFLD"
  For [PVD]
   Wrseq '  T_INTNOMZON('+num$(I_ZON)+') '+space$(4-len(num$(I_ZON)))+'= '+'"'+[F:PVD]FLDNAM+'"'
   I_ZON+=1
  Next
  Filter [PVD]
  Wrseq 'Return'
  Wrseq ''

  #> Infos diverses sur l'événement
  #  ------------------------------

  Wrseq '$INFO_EVTINT'
  Wrseq ' EVT = "'+PEVT+'"'
  Wrseq ' LPLN= '+num$([F:PVT]PLN)
  Wrseq 'Return'
  Wrseq ''

  #> Fin de la génération du fichier source
  #  --------------------------------------

  Openo

  # Compilation du traitement associé au code interne
  #  ------------------------------------------------

  Call VALID("TRT", NOMTRT, APPLI_TRT, OK) From VALMSKSUB
  If OK = 0
    Local Char MESSAGE_ERR(100)
    MESSAGE_ERR="Erreur de compilation du traitement"-NOMTRT- APPLI_TRT
    If GTRACE<>""
      Call ECR_TRACE (MESSAGE_ERR,1) From GESECRAN
    Else
      Infbox MESSAGE_ERR
    Endif
    End
  Else
   Call MAJ_TRT_DICO(NOMTRT, APPLI_TRT, PEVTINT,OK)
   # Marquage correction.
   Local Integer B_ADCOPN : B_ADCOPN = 0
   If !clalev([F:ADC])  : Local File ADICTRT [ADC] : B_ADCOPN = 1  : Endif
   Call MAJ(NOMTRT, "", 14, "") From SUBADC
   If (B_ADCOPN) Then : Close File [F:ADC] : Endif

  Endif

#=====================
#$FIN_SP
End

#=====================
$TRT_COD_ACT

  I_CODACT = find([F:PVD]FLDACT,GCODACTABX3)
  If I_CODACT
    LCODACT = G_OUI
    LGLOACT = GGLOACTABX3(I_CODACT)
  Endif
Return

# issue X3-64332
$AFF_CCEDIE

  Wrseq ' If dim(' + [F:PVD]FLDFIL + ') > 0'
  Wrseq '  [F:EVT0]' + [F:PVD]FLDNAM + space$(10 - len([F:PVD]FLDNAM)) + ' = ' + [F:PVD]FLDFIL
  Wrseq ' Endif'

Return
# End issue X3-64332

################################################################################
#    Sous-programme de mise à jour du dictionnaire de traitement
#    GBN
#    Création le : 09/08/2007
#    Modification le : xx/xx/xxxx
#
################################################################################
Subprog MAJ_TRT_DICO(PNOMTRT, PAPPLI, PEVTNAM, POK)
Value    Char PNOMTRT()
Value    Char PAPPLI()
#Value    Char PTYP
Value    Char PEVTNAM()
Variable Integer POK

If !clalev([F:ADC]) : Local File =PAPPLI+".ADICTRT" [ADC] : Endif

GOK=1

Trbegin [ADC]

Delete [ADC] Where CODTRT=PNOMTRT

Raz [F:ADC]
[F:ADC]CODTRT = PNOMTRT
[F:ADC]DES    = "Génération des événements"
[F:ADC]MODULE = 14
#[F:ADC]COM(0) = "Traitement de génération des événements"
#[F:ADC]COM(1) = "Code interne"-PEVTNAM
#[F:ADC]COM(2) = ""
#[F:ADC]TEXTE   = "Traitement de génération des événements"-"Code interne"-PEVTNAM
[F:ADC]CODACT = ""
[F:ADC]SRC    = G_NON
[F:ADC]CREDAT = date$
[F:ADC]CREUSR = GUSER
[F:ADC]UPDDAT = date$
[F:ADC]UPDUSR = GUSER
Write [F:ADC]
If fstat
 GOK=0
Endif

If GOK=1
 Commit
Else
 Rollback
Endif

End

