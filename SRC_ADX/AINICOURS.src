#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char VALEUR(20) , PARAM(50)(1..10)

PARAM(1) = "FRF"
PARAM(2) = "TL"
PARAM(3) = "ADX"
PARAM(4) = "1"
PARAM(5) = date$
PARAM(6) = "1"
PARAM(7) = ""
Gosub TRT_DIV
Infbox VALEUR-num$(STAT)
End

#################################################################
# Action  : AINICOURS (Bouton du type de données RCU)
#################################################################
$ACTION
Case ACTION
 When "TRT_DIV" : Gosub TRT_DIV
Endcase
Return

$TRT_DIV
Local Char    DEVORG(GLONCUR) , DEVDES(GLONCUR) , SOCIETE(GLONCPY)
Local Char    REVCOURS(30)
Local Integer TYPCOURS , MULDIV
Local Date    DATCOURS
Local Decimal COURMUL , COURDIV
DEVORG   = PARAM(1)
DEVDES   = PARAM(2)
SOCIETE  = PARAM(3)
TYPCOURS = val(PARAM(4))
DATCOURS = PARAM(5)
MULDIV   = val(PARAM(6))
REVCOURS = PARAM(7)
If MULDIV<>1 & MULDIV<>2 : MULDIV = 1 : Endif

Call INI_COURS(DEVORG,DEVDES,TYPCOURS,DATCOURS,COURMUL,COURDIV)

Case MULDIV
 When 1
  If REVCOURS<>""
   If evalue("varmode("+REVCOURS+")")=0
    VALEUR = num$(COURMUL)
    Assign REVCOURS With COURDIV
   Else
    COURS  = arr(COURMUL/COURDIV,10^-GDECRCU)
    VALEUR = num$(COURS)
    Assign REVCOURS With 1
   Endif
   Affzo =REVCOURS
  Else
   COURS  = arr(COURMUL/COURDIV,10^-GDECRCU)
   VALEUR = num$(COURS)
  Endif
 When 2
  If REVCOURS<>""
   If evalue("varmode("+REVCOURS+")")=0
    VALEUR = num$(COURDIV)
    Assign REVCOURS With COURMUL
   Else
    COURS  = arr(COURDIV/COURMUL,10^-GDECRCU)
    VALEUR = num$(COURS)
    Assign REVCOURS With 1
   Endif
   Affzo =REVCOURS
  Else
   COURS  = arr(COURDIV/COURMUL,10^-GDECRCU)
   VALEUR = num$(COURS)
  Endif
Endcase
Return

Subprog INI_COURS(DEVORG,DEVDES,TYPCOURS,DATCOURS,COURMUL,COURDIV)
Value    Char    DEVORG
Value    Char    DEVDES
Value    Integer TYPCOURS
Value    Date    DATCOURS
Variable Decimal COURMUL
Variable Decimal COURDIV
If clalev([F:TCU])=0 : Local File TABCUR    [TCU] : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE [TCH] : Endif
Local Integer INORG , INDES , STAT
Local Decimal EURORG , EURDES
#Call LECTURE("TCU",DEVORG,"") From CONTOBJ
Call LEC_TCU(DEVORG)
INORG  = [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
EURORG = [F:TCU]EURRAT
#Call LECTURE("TCU",DEVDES,"") From CONTOBJ
Call LEC_TCU(DEVDES)
INDES  = [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
EURDES = [F:TCU]EURRAT
If DEVORG=DEVDES    : # Cas trivial
 COURMUL = 1
 COURDIV = 1
Elsif DEVORG=GEURO
 If INDES           : # In => Euro
  COURMUL = 1
  COURDIV = EURDES
 Else               : # xx => Euro
  Call COURS(GEURO,DEVDES,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT)
 Endif
Elsif DEVDES=GEURO
 If INORG           : # Euro => In
  COURMUL = EURORG
  COURDIV = 1
 Else               : # Euro => yy
  Call COURS(DEVORG,GEURO,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT)
 Endif
Elsif INDES & INORG : # In => In
 COURMUL = EURORG
 COURDIV = EURDES
Elsif INORG         : # In => Out
 Call COURS(GEURO,DEVDES,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT)
 COURMUL /= EURORG
Elsif INDES         : # Out => In
 Call COURS(DEVORG,GEURO,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT)
 COURMUL *= EURDES
Else                : # xx => yy
 Call COURS(DEVORG,DEVDES,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT)
Endif
If STAT
 COURMUL = 1
 COURDIV = 1
Endif
End

Subprog LEC_TCU(DEVISE)
Value Char DEVISE
fstat = 0
If [F:TCU]CUR<>DEVISE
 Read [TCU]TCU0 = DEVISE
Endif
End

Subprog COURS(DEVORG,DEVDES,TYPCOURS,DATCOURS,COURMUL,COURDIV,STAT)
Value    Char    DEVORG
Value    Char    DEVDES
Value    Integer TYPCOURS
Value    Date    DATCOURS
Variable Decimal COURMUL
Variable Decimal COURDIV
Variable Integer STAT
Filter [TCH] Where CHGTYP=TYPCOURS & CURDEN=DEVDES & CUR=DEVORG & CHGSTRDAT<=DATCOURS
Read [TCH]TCH0 Last
Filter [TCH]
If fstat<=2
 COURMUL = [F:TCH]REVCOURS
 COURDIV = [F:TCH]CHGDIV
 STAT    = 0
Else
 STAT = 1
Endif
GPOINT = "RECHTCH" : Gosub ENTREE From EXEFNC
End

#################################################################
# Action  : ARCUINI (avant_saisie du type de données RCU)
#################################################################
Subprog RCUINI(COURS,DEVORG,DEVDES)
Variable Decimal COURS  : # Cours devise
Value    Char    DEVORG : # Devise de saisie
Value    Char    DEVDES : # Devise de destination
If DEVORG=DEVDES : COURS = 1 : mkstat = 2 : End : Endif
If GFONCTION="COURDEV"
 GBOUT2 = ""
Else
 GBOUT2 = mess(85,105,1) : # Init cours
Endif
End

