#<AdxTL>@(#)2.0.0.0 $Revision$
# -------------------------------------------------------------------
# Outil : RECHAMZ    Recherche d'un champ dans les écrans/tables X3
# Auteur: G.Ambrosiani (Oct 2008)
# -------------------------------------------------------------------


Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECHAMZ","RECHAMZ",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
Endcase
Return

$INIT
Local Integer I , J , K , INTE , OK
Local Char    WCODZON(GLONAVA) , TEXTE(80)
Local Char    FIC(10) , TIT(30) , COD(10) , NAM(10)
If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
Local Mask RECHAMZ [DIA]
Raz [M:DIA]
TRA = 1
Return

$EXEC
WCODZON = toupper([M:DIA]AMZ)
If WCODZON<>""
 Call OUVRE_BOITE(mess(13,75,1)+mess(1,89,1),100) From GESECRAN : # Recherche : Champ
 Call OUVRE_TRACE(mess(13,75,1)+mess(1,89,1)-WCODZON) From LECFIC   : # Recherche : Champ XXX
 If [M:DIA]AMK=2 : Gosub ECRANS : Endif
 If [M:DIA]ATB=2 : Gosub TABLES : Endif
 If [M:DIA]ACLA=2 : Gosub CLASSES : Endif
 If [M:DIA]ASW=2 : Gosub REPRESENTATIONS : Endif
 Call FERME_TRACE From LECFIC
 Call FERME_BOITE From GESECRAN
 Call LEC_TRACE From LECFIC
Endif
Return

## Ecrans
$ECRANS
Local File AMSK [AMK] , AMSKZON [AMZ]
Call SET_BOITE(mess(2,42,1),nbrecord([AMK])) From GESECRAN : # Ecrans
Call ECR_TRACE(mess(2,42,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [AMK]CODMSK
 K += 1
 Call AFF_BOITE(" ",K,INTE) From GESECRAN
 For [AMZ] Where CODMSK=[F:AMK]CODMSK & pat(CODZON,WCODZON)=1 & find([M:DIA]TYP,"",CODTYP)
   Call TEXTE([F:AMZ]INTIT,TEXTE) From OBJDIV
   Call ECR_TRACE([F:AMZ]CODMSK-mess(17,115,1)-[F:AMZ]CODZON-TEXTE-[F:AMZ]CODTYP-num$([F:AMZ]NOLIB),0) From GESECRAN
 Next
Next
Close Local File [AMK] , [AMZ]
Call ECR_TRACE("",0) From GESECRAN
Return

## Tables
$TABLES
Local File ATABLE [ATB] , ATABZON [ATZ]
Call SET_BOITE(mess(1,42,1),nbrecord([ATB])) From GESECRAN : # Tables
Call ECR_TRACE(mess(1,42,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [ATB]
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 For [ATZ] Where CODFIC=[F:ATB]CODFIC & pat(CODZONE,WCODZON)=1 & find([M:DIA]TYP,"",CODTYP)
   Call TEXTE([F:ATZ]NOCOURT,TEXTE) From OBJDIV
   Call ECR_TRACE([F:ATZ]CODFIC-mess(17,115,1)-[F:ATZ]CODZONE-TEXTE-[F:ATZ]CODTYP-num$([F:ATZ]NOLIB),0) From GESECRAN
 Next
Next
Close Local File [ATB] , [ATZ]
Call ECR_TRACE("",0) From GESECRAN
Return

$CLASSES
Local File ACLASSE [ACLA] , ACLAFLD [ACLAF]
Call SET_BOITE(mess(3,140,1),nbrecord([ACLA])) From GESECRAN : # Tables
Call ECR_TRACE(mess(3,140,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [ACLA]
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 For [ACLAF] Where CODCLA=[F:ACLA]CODCLA & pat(FLDCLA,WCODZON)=1 & find([M:DIA]TYP,"",CODTYP)
   Call TEXTE([F:ACLAF]INTFLD ,TEXTE) From OBJDIV
   Call ECR_TRACE([F:ACLAF]CODCLA-mess(17,115,1)-[F:ACLAF]FLDCLA-TEXTE-[F:ACLAF]CODTYP-num$([F:ACLAF]INTFLD),0) From GESECRAN
 Next
Next
Close Local File [ACLA] , [ACLAF]
Call ECR_TRACE("",0) From GESECRAN
Return


$REPRESENTATIONS
Local File ASHW [ASW] , ASHWFLD [ASWF]
Call SET_BOITE(mess(23,140,1),nbrecord([ASW])) From GESECRAN : # Tables
Call ECR_TRACE(mess(23,140,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [ASW]
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 For [ASWF] Where CODREP=[F:ASW]CODREP & pat(CODFLD,WCODZON)=1 & find([M:DIA]TYP,"",CODTYP)
   Call TEXTE([F:ASWF]INTFLD ,TEXTE) From OBJDIV
   Call ECR_TRACE([F:ASWF]CODREP-mess(17,115,1)-[F:ASWF]CODFLD-TEXTE-[F:ASWF]CODTYP-num$([F:ASWF]INTFLD),0) From GESECRAN
 Next
Next
Close Local File [ASW] , [ASWF]
Call ECR_TRACE("",0) From GESECRAN
Return

