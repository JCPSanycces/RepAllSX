#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
# Gestion de l'action ayoselpool
#
# On passe le champ ou on restitue l'info dans PARAM
# Une gestion est faite dans subayo pour se positionner correctement et éviter 
# la modification de l'affichage de l'icône
######################################################################################

$ACTION
Case ACTION
 When "SEL_TABLE"       : Goto SEL_TABLE
 When "VERF_TABLE"       : Goto VERF_TABLE
 When default
Endcase
Return


$SEL_TABLE
# déclaration de l'objet
OBJET="APW"
Return

# On retourne le résultat dans param 
$VERF_TABLE
PARAM(1)= [F:APW]CLE  # Retour POOLX3
Return
