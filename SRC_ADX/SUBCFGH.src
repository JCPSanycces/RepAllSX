#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion du masque CFGHIS
$SET_NOL
Local Integer NOL : NOL = nolign-1
Return
############################################################
Subprog AS_QSTVAL(VALEUR)
Variable Char VALEUR()
Gosub SET_NOL
If [M]QSTCND(NOL) = 1
  mkstat = 2
Else
  Read [CQU]CQU0=[M]QSTNUM(NOL)
  If fstat 
    mkstat = 2
  Endif
Endif
End
############################################################
Subprog C_QSTVAL(VALEUR)
Variable Char VALEUR()
Gosub SET_NOL
Local Integer W_BOO
Call SAI_VARIABLE(VALEUR,[F:CQU]ASWTYP,[F:CQU]ASWCHA,[M]QSTVALALP(NOL),[M]QSTVALNUM(NOL),
&    [M]QSTVALDAT(NOL),mkstat)  From CFGLIBD
If mkstat = 0 & [M]QSTCND(NOL) = 2
  Case [F:CQU]ASWTYP
    When 1 : 
      Call CFGCTRALP([M]QSTVALALP(NOL),[F:CQU]QSTNUM) From CFGLIB
    When 2 :
      Call CFGCTRNUM([M]QSTVALNUM(NOL),[F:CQU]QSTNUM) From CFGLIB
    When 3 :
      Call CFGCTRDAT([M]QSTVALDAT(NOL),[F:CQU]QSTNUM) From CFGLIB
    When 4 :
      W_BOO = [M]QSTVALNUM(NOL)+1 
      Call CFGCTRCAS(W_BOO,[F:CQU]QSTNUM) From CFGLIB
  Endcase
Endif
End
############################################################
Subprog AS_VARVAL(VALEUR)
Variable Char VALEUR()
Gosub SET_NOL
If [M]VARCND(NOL) = 1
  mkstat = 2
Else
  Read [CQU]CQU0=[M]VARNUM(NOL)
  If fstat 
    mkstat = 2
  Endif
Endif
End
############################################################
Subprog C_VARVAL(VALEUR)
Variable Char VALEUR()
Gosub SET_NOL
Call SAI_VARIABLE(VALEUR,[F:CQU]ASWTYP,[F:CQU]ASWCHA,[M]VARVALALP(NOL),[M]VARVALNUM(NOL),
&    [M]VARVALDAT(NOL),mkstat)  From CFGLIBD
If mkstat = 0 & [M]VARCND(NOL) = 2
  Case [F:CQU]ASWTYP
    When 1 : 
      Call CFGCTRALP([M]VARVALALP(NOL),[F:CQU]QSTNUM) From CFGLIB
    When 2 :
      Call CFGCTRNUM([M]VARVALNUM(NOL),[F:CQU]QSTNUM) From CFGLIB
    When 3 :
      Call CFGCTRDAT([M]VARVALDAT(NOL),[F:CQU]QSTNUM) From CFGLIB
    When 4 :
      Call CFGCTRCAS([M]VARVALNUM(NOL),[F:CQU]QSTNUM) From CFGLIB
  Endcase
Endif
End
############################################################
Subprog C_NBLIG1
Gosub SET_NOL
Case status
  When 73, 82 :
    If NOL > 0
      [M]QSTNUM   (NOL) = [M]QSTNUM(NOL-1)
      [M]QSTDES   (NOL) = [M]QSTDES(NOL-1)
      [M]QSTNAT   (NOL) = [M]QSTNAT(NOL-1)
      [M]QSTCND   (NOL) = 1
      [M]QSTVAL   (NOL) = ""
      [M]QSTVALALP(NOL) = ""
      [M]QSTVALNUM(NOL) = 0
      [M]QSTVALDAT(NOL) = [0/0/0]
      Affzo [M]QSTNUM(NOL)
      Affzo [M]QSTDES(NOL)
      Affzo [M]QSTCND(NOL)
      Affzo [M]QSTVAL(NOL)
    Else
        mkstat=2
    Endif
Endcase  
End
############################################################
Subprog C_NBLIG2
Gosub SET_NOL
Case status
  When 73, 82 :
    If 0 & NOL > 0
      [M]VARNUM   (NOL) = [M]VARNUM(NOL-1)
      [M]VARDES   (NOL) = [M]VARDES(NOL-1)
      [M]VARNAT   (NOL) = [M]VARNAT(NOL-1)
      [M]VARCND   (NOL) = 1
      [M]VARVAL   (NOL) = ""
      [M]VARVALALP(NOL) = ""
      [M]VARVALNUM(NOL) = 0
      [M]VARVALDAT(NOL) = [0/0/0]
      Affzo [M]VARNUM(NOL)
      Affzo [M]VARDES(NOL)
      Affzo [M]VARCND(NOL)
      Affzo [M]VARVAL(NOL)
    Else
#        mkstat=2
    Endif
Endcase  
End
############################################################
Subprog AS_QSTCND(VALEUR)
Variable Integer VALEUR
Gosub SET_NOL
If [M]QSTNAT(NOL) <> 1
  GMENLOC(8) = 1
Endif
End
############################################################
Subprog C_QSTCND(VALEUR)
Variable Integer VALEUR
Gosub SET_NOL
If [M]QSTNUM(NOL) = ""
  mkstat = 2
Else
  If VALEUR = 1
    Raz [M]QSTVAL(NOL)
    Raz [M]QSTVALALP(NOL)
    Raz [M]QSTVALNUM(NOL)
    Raz [M]QSTVALDAT(NOL)
  Endif
Endif
End
############################################################
Subprog AS_VARCND(VALEUR)
Variable Integer VALEUR

Gosub SET_NOL
If [M]VARNAT(NOL) <> 1
  GMENLOC(8) = 1
Endif
End
############################################################
Subprog C_VARCND(VALEUR)
Variable Integer VALEUR
Gosub SET_NOL
If [M]VARNUM(NOL) = ""
  mkstat = 2
Else
  If VALEUR = 1
    Raz [M]VARVAL(NOL)
    Raz [M]VARVALALP(NOL)
    Raz [M]VARVALNUM(NOL)
    Raz [M]VARVALDAT(NOL)
  Endif
Endif
End
############################################################
Subprog S_QSTVAL(VALEUR)
Variable Char    VALEUR()
Call SELVAL(VALEUR,[M]QSTNUM(nolign-1))
End
############################################################
Subprog S_VARVAL(VALEUR)
Variable Char    VALEUR()
Call SELVAL(VALEUR,[M]VARNUM(nolign-1))
End
############################################################
Subprog SELVAL(LVAL,LSYM)
Variable Char LVAL
Value    Char LSYM
Read [CQU]CQU0=LSYM
If fstat = 0
  If [F:CQU]TCT <> ""
    Case [F:CQU]ASWTYP
      When 1 : 
        Local Char PARAM(250)(1..20) , SAVACT(10)
        PARAM(1) = [F:CQU]TCT
        SAVACT = GACTION 
        GACTION = "SELTCT"
        Call S_TAB_CHAR(LVAL,PARAM,"SELTCT","CFGLIB","") From GACTION
        GACTION = SAVACT
      When 2 : 
        Local Char    PARAM(250)(1..20) , SAVACT(10)
        Local Decimal WNUM : WNUM = val(LVAL)       
        PARAM(1) = [F:CQU]TCT
        SAVACT = GACTION 
        GACTION = "SELTCT"
        Call S_TAB_NUM(WNUM,PARAM,"SELTCT","CFGLIB","") From GACTION
        GACTION = SAVACT
        LVAL = num$(WNUM)
    Endcase
  Else
    If [F:CQU]SHACAT <> ""
      Local Char PARAM(250)(1..20) , SAVACT(10)
      PARAM(1) = [F:CQU]SHACAT
      SAVACT = GACTION 
      GACTION = "SELTCT"
      Call S_TAB_CHAR(LVAL,PARAM,"SELSHB","CFGLIB","") From GACTION
      GACTION = SAVACT
    Endif
  Endif
Endif
End
############################################################
Subprog AM_BPRNUM(VALEUR)
Variable Char    VALEUR()
S_BPRNUM = VALEUR
End
############################################################
Subprog AM_BPRREF(VALEUR)
Variable Char    VALEUR()
S_BPRREF = VALEUR
End

