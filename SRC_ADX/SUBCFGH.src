Subprog AVANT_NBLIG2
Gosub SET_NOL
Case status
  When 73, 82 :
    If NOL>0
      [M]VARNUM   (NOL) = [M]VARNUM(NOL-1)
      [M]VARDES   (NOL) = [M]VARDES(NOL-1)
      [M]VARNAT   (NOL) = [M]VARNAT(NOL-1)
      [M]VARCND   (NOL) = 1
      [M]VARVAL   (NOL) = ""
      [M]VARVALALP(NOL) = ""
      [M]VARVALNUM(NOL) = 0
      [M]VARVALDAT(NOL) = [0/0/0]
      Affzo [M]VARNUM(NOL)
      Affzo [M]VARDES(NOL)
      Affzo [M]VARCND(NOL)
      Affzo [M]VARVAL(NOL)
    Else
        mkstat=2
    Endif
Endcase
End


######################################################################################
Subprog IB_NBLIG3
If [M]CPNCRE(nolign-1)<>2
    Raz GBOUT3
Else
    If !clalev([F:BOH]) : Local File BOM [BOH] : Endif
    Look [BOH]BOH0=[M]ITMREF(nolign-1);[M]BOMALT(nolign-1);[M]BOMALTTYP(nolign-1)
    If fstat
        Raz GBOUT3
    Else
        GFLAG="BOMP"
        GFONBOD="BOMP"
        GBOMALT=[M]BOMALT(nolign-1)
    Endif
Endif
If [M]ROUCRE(nolign-1)<>2
    Raz GBOUT4
    If !clalev([F:ROH]) : Local File ROUTING [ROH] : Endif
    Look [ROH]ROH0=[M]ITMREF(nolign-1);[M]ROUALT(nolign-1);S_FCY  : # Beryl Site en fin de clé primaire
    If fstat
        Raz GBOUT4
    Endif
Endif
End


