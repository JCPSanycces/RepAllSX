Subprog SETPORATT(VFNC,VREFNUM,VBYTES,VPATH,VDEM,VUID)
Value Char VFNC             #Function
Value Char VREFNUM          #Employee
Value Char VPATH            #Filename
Value Integer VDEM          #Request
Value Integer VUID          #UID of the line
Variable Blbfile  VBYTES()  #BLBFile
#Local declaration
Local Char DOCTYP(3)
Local Char NEWVOLUME
Local Char DIRVOLA(250)
Local Char NEWVPATH(100)

#Renaming the filename
NEWVPATH=num$(VFNC)+"_"+num$(VUID)+"_"+VPATH

Gosub GET_VOLUME

If NEWVOLUME = "" : End : Endif #Error handling
#Actual path of the volume
DIRVOLA = func AVOLUME_CSTD._GETFULLPATH(num$(NEWVOLUME),"")

#Opening and saving actual file for BYTE
Openo DIRVOLA+NEWVPATH,0 Using [BIN1]
If fstat=0
  Putseq 1, VBYTES Using [BIN1]
  Openo Using [BIN1]
Else
  #Can handle error here
  End
Endif
#NEWVOLUME = "["+NEWVOLUME+"]\"
NEWVOLUME = "["+NEWVOLUME+"]/"
#Get the type of the document based on the file extension
Call GETDOCTYP(NEWVPATH,DOCTYP)

#After moving the file - the details must be stored in AOX table
Local Integer STAT
Call STORE_FILE(VFNC,VREFNUM,VDEM,NEWVPATH,VUID,NEWVOLUME,DOCTYP,STAT)
#STAT Manage - Portal message?
 If STAT>0
  #Delete the file from NEWVOLUME

   #If filinfo(NEWVOLUME+NEWVPATH,0)>=0
   If filinfo( DIRVOLA+NEWVPATH,0)>=0
    Call EFFACE(NEWVOLUME+NEWVPATH,STAT) From ORDSYS
     #Dont need to handle STAT - already in error handling procedure
   Endif
  #Goto AB_TR :  Return
 Endif
#Commit

End


$GET_VOLUME
If dim(NEWVOLUME)=-1 : Local Char NEWVOLUME(30) : Endif
If VFNC = "EXS"
  Call PARAM("", "PORATTEXS", NEWVOLUME) From ADOVAL # Folder level PORATTEXS parameter
Elsif VFNC = "DCG"
  Call PARAM("", "PORATTDCG", NEWVOLUME) From ADOVAL # Folder level PORATTDCG parameter
Endif
Return



Subprog GESTPORATT(ACODE,VFNC,VREFNUM,VPATH,VDEM,VUID)
Value Char      ACODE()
Value Char      VFNC()             #Function
Value Char      VREFNUM()          #Employee
Variable Char   VPATH()            #Filename
Value Integer   VDEM          #Request
Value Integer   VUID          #UID of the line

If !([L]ACODE="READ" or [L]ACODE="DEL") End : Endif
If !clalev([F:AOX]) : Local File AOBJTXT  [AOX] : Endif
Local Integer RES
Local Char W_NAME(100)
Local Char W_LOCPATH(255)
Local Char W_DESTPATH(255)
Local Char MESSAGE(250)

Gosub REMAP_VFNC


[L]RES=func FILTER_AOX([L]VFNC,[L]VREFNUM,[L]VDEM,[L]VUID)
If RES
  [L]W_NAME=[F:AOX]NAM
  If [L]W_NAME<>""
    [L]W_NAME=ctrans([L]W_NAME,"\","/")
    [L]RES=func ASYRSTO.CTL_VOLFIL(2,[L]W_NAME,[L]W_LOCPATH,0,[L]MESSAGE)
    If !RES
      # copy to local
      # calculate destinary
      Repeat
        [L]RES=instr(0,[L]W_NAME,"/")
        [L]W_NAME=right$([L]W_NAME,[L]RES+1)
      Until RES=0
      [L]W_DESTPATH=func GETDEFDIR([L]VFNC)+[L]W_NAME
      [L]VPATH=func GET_DESTREP([L]VFNC)+[L]W_NAME
      If [L]ACODE="READ"
        Call COPIE([L]W_LOCPATH,[L]W_DESTPATH,[L]RES)From ORDSYS
      Else
         Call EFFACE([L]W_DESTPATH,[L]RES)From ORDSYS
      Endif
    Else
      Call ADDMESSERR([L]MESSAGE) From WEB
    Endif
  Endif
Endif

End


$REMAP_VFNC

If [L]VFNC="CNG" : [L]VFNC="DCG" : Endif
If [L]VFNC="NDF" : [L]VFNC="EXS" : Endif

Return

Funprog GETDEFDIR(REP)
Value Char REP()

Local Char SEP(1) : SEP=func PRHUTIFILES.DIRSEP()
Local Char ROOT(250)
Local Char PATHREL(50)
Local Char DIRS(50)(0..)
Local Integer WI,ERR
Call STR_EXPLODE(func GET_DESTREP(REP),"/",DIRS) From PRHUTIFCTPRH
ROOT=filpath(nomap,"", "", "X3_PUB")
While(DIRS(WI)<>"")
  ROOT+=SEP+DIRS(WI)
  If filinfo(ROOT,7)<0
    Call CREREP(ROOT,ERR)From DOSAPL
  Endif
WI+=1
Wend
End ROOT+SEP

Funprog GET_DESTREP(REP)
Value Char REP
Local Char RES(250)
RES="TMP/"+REP+"/"
End RES

Subprog GETDOCTYP(VFILEXT,VDOCTYP)
Value Char VFILEXT()
Variable Char VDOCTYP()
#Add logic - have to use ADI 902!! for now DOC
#DOC,INV,PIC,RTF,TXT
VDOCTYP = "PTL"
End

Subprog STORE_FILE(VFNC,VREFNUM,VDEM,VPATH,VUID,VNEWVOLUME,VTYPDOC,STAT)
Value Char VFNC
Value Char VREFNUM
Value Integer VDEM
Value Char VPATH
Value Integer VUID
Value Char VNEWVOLUME
Value Char VTYPDOC
Variable Integer STAT : STAT = 0
Local Char FILT(250)
Local Char IDENT(250)
Local Char IDENT3(3) : IDENT3 = "001"
Local Char ABRV(3) : ABRV = "EML"
Local Integer ATTCAT : ATTCAT = 1  # ??Confidential??

#Opening different instance of AOX
If clalev([F:AOX2])=0 : Local File AOBJTXT [AOX2] : Endif

Gosub SET_VAR_DELETEFILE

Trbegin [AOX2]

#Build where string
FILT="ABREV='"+ABRV+"' and IDENT1='"+VFNC+"~"+VREFNUM+"~"+num$(VDEM)+"' and IDENT2='"+num$(VUID)+"'"

#Read on filter - FILT
Filter [AOX2] Where evalue(FILT)
Read [AOX2]AOX0 First

If !fstat
   W_NAME=[F:AOX2]NAM
  [F:AOX2]NAM=VNEWVOLUME+VPATH
  [F:AOX2]TYPDOC=VTYPDOC
  Rewrite [F:AOX2]
  If W_NAME=[F:AOX2]NAM : W_NAME="" Endif
Else
 # save the name to delete after

 Raz [F:AOX2]
 [F:AOX2]ABREV    = ABRV
 [F:AOX2]IDENT1   = VFNC+"~"+num$(VREFNUM)+"~"+num$(VDEM)
 [F:AOX2]IDENT2   = num$(VUID)
 [F:AOX2]IDENT3   = IDENT3
 [F:AOX2]CAT      = ATTCAT
 [F:AOX2]NAM=VNEWVOLUME+VPATH
 [F:AOX2]TYPDOC=VTYPDOC
 Write [F:AOX2]
Endif
If fstat<>0
 STAT = 1
 W_NAME=""
 Rollback
 End
Endif
Commit
# replace an existing file, we delete the old file
If W_NAME<>""
  Gosub DELETE_FILE
Endif

End


$AB_TR
Rollback
Return
End






#################################################
# DELTYP : 0 : delete all records, 1: delete records in LUID , 2 : delete records not in LUID
#
# without transaction

Subprog DELETE_AOX_ATTACH(FNC,REFNUM,DEM,LUID,DELTYP)
Value Char FNC()
Value Char REFNUM()
Value Char DEM()
Variable Char LUID()()
Value Integer DELTYP

If clalev([F:AOX2])=0 : Local File AOBJTXT [AOX2] : Endif

Local Integer WOK,I
Gosub SET_VAR_DELETEFILE

Gosub SET_FILTER_DELETE
For [AOX2]
  Gosub CALC_VALUE_DELETE
  If WOK
    W_NAME=[F:AOX2]NAM
    Gosub DELETE_FILE
    Delete [F:AOX2] Curr
  Endif
Next

End

$SET_VAR_DELETEFILE
Local Integer STAT
Local Char FILESRV(250),MESSAGE(250),W_NAME(250)

Return

$DELETE_FILE
If W_NAME<>""
  W_NAME=ctrans(W_NAME,"\","/")
  STAT=func ASYRSTO.CTL_VOLFIL(2,W_NAME,[L]FILESRV,0,MESSAGE)
  If !STAT
    Call EFFACE([L]FILESRV,STAT)From ORDSYS
  Endif
Endif

Return



$SET_FILTER_DELETE
Local Char ABRV(10): ABRV = "EML"
Filter [AOX2] Where ABREV = ABRV and IDENT1 = FNC+"~"+REFNUM+"~"+num$(DEM)

Return

$CALC_VALUE_DELETE

If !DELTYP
    WOK=1
  Else
    I=find([F:AOX2]IDENT2,LUID)
    Case DELTYP:
      When  1 :
       WOK =(I<>0)
      When 2  :
       WOK =(I=0)
    Endcase
  Endif

Return


Funprog FILTER_AOX(FNC,REFNUM,DEM,UID)
Value Char FNC
Value Char REFNUM
Value Integer DEM
Value Integer UID
Local Integer WRET : WRET = 0
#SBA error in portal if the table doesn't open.
If !clalev([F:AOX]) : Local File AOBJTXT  [AOX] : Endif
Read [AOX]AOX0(3) = "EML";FNC+"~"+num$(REFNUM)+"~"+num$(DEM);num$(UID)
If !fstat
  WRET = 1
Endif
End WRET



#Generic Delete function for AOBJTXT - should be called from example APRES_MOD ( No transaction mode)
Funprog ATT_AOBJTXT_MANAGE(FNC,REFNUM,DEM,LUID)
Value Char FNC
Value Char REFNUM
Value Char DEM
Value Char LUID()()

Local Integer WRET : WRET = 0
Local Char ABRV: ABRV = "EML"
Local Integer I

WRET=func ATT_AOBJTXT_MANAGETYP(FNC,REFNUM,DEM,LUID,2)
#Close files
End WRET


#################################################
# DELTYP : 0 : delete all records, 1: delete records in LUID , 2 : delete records not in LUID
Funprog ATT_AOBJTXT_MANAGETYP(FNC,REFNUM,DEM,LUID,DELTYP)
Value Char FNC
Value Char REFNUM
Value Char DEM
Value Char LUID()()
Value Integer DELTYP


Local Integer WRET : WRET = 0
Local Char ABRV: ABRV = "EML"
Local Integer I,WOK


If clalev([F:AOX2])=0 : Local File AOBJTXT [AOX2] : Endif
Trbegin AOBJTXT [AOX2]
Filter [AOX2] Where ABREV = ABRV and IDENT1 = FNC+"~"+REFNUM+"~"+num$(DEM)
For [AOX2]
  If !DELTYP
    WOK=1
  Else
    I=find([F:AOX2]IDENT2,LUID)
    Case DELTYP:
      When  1 :
       WOK =(I<>0)
      When 2  :
       WOK =(I=0)
    Endcase
  Endif
  If WOK
    Delete [F:AOX2] Curr
    If fstat=1 | fstat>5
      WRET = 1
      GOK = 0
      Break
    Endif
  Endif
Next

If GOK
 Commit
Else
 Rollback
Endif
End WRET


#MIPEA - 2016-12-02 - X3-11593- END

