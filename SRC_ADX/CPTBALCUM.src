#<AdxTL>@(#)4.0.0.0 $Revision$
End

#####################################################################################################
## Subprog VALPCE(SIGN,TYPPCE,PIECE)        # Post of journal entry
## Subprog BALANCE(SIGN)                    # Update General Balance
## Subprog BALANA(SIGN)                     # Update Analytical Balance
#####################################################################################################

Subprog VALPCE(SIGN,TYPPCE,PIECE)
Value Integer SIGN
Value Char    TYPPCE
Value Char    PIECE

If !clalev([F:CDAE]) : Local File CUMBAL    [CDAE] : Endif
If !clalev([F:CDAA]) : Local File CUMBLA    [CDAA] : Endif

If !clalev([F:GTE]) : Local File GTYPACCENT       [GTE] : Endif
If !clalev([F:HAE]) : Local File GACCENTRY        [HAE] : Endif
If !clalev([F:GAC]) : Local File GACCOUNT         [GAC] : Endif
If !clalev([F:JST]) : Local File GAJOUSTA         [JST] : Endif
If !clalev([F:LED]) : Local File =GTABCPT+"GLED"  [LED] : Endif

Read [HAE]HAE0 = TYPPCE;PIECE
If fstat=0

 Call GETSOC([F:HAE]FCY) From DEVSUB
 Call LEC_GTE_LEG(GCURLEG,TYPPCE) From CPTLEC

 # Update General Balance
 For [CDAE] Where TYP=TYPPCE & NUM=PIECE
  If [F:LED]LED<>[F:CDAE]LED
   Read [LED]LED0 = [F:CDAE]LED
   If fstat  : Raz [LED] :  Endif
  Endif

  If [F:LED]GEN=2
   Call BALANCE(SIGN)
   If GOK<1 : Break : Endif
  Endif
 Next

 # Update Analytical Balance
 For [CDAA] Where TYP=TYPPCE & NUM=PIECE
  If [F:LED]LED<>[F:CDAA]LED
   Read [LED]LED0 = [F:CDAA]LED
   If fstat  : Raz [LED] :  Endif
  Endif

  If [F:LED]ANA=2
   Call BALANA(SIGN)
   If GOK<1 : Break : Endif
  Endif
 Next

 If GOK<1 : End : Endif
Endif
End

########################################################
Subprog BALANCE(SIGN)
Value Integer SIGN

Local Integer BALTYP, BALEXE, BALPER
Local Char    BALSOC(GLONCPY), BALFCY(GLONFCY)
Local Char    BALACC(GLONGAC), BALBPR(GLONBPR)
Local Char    BALCUR(GLONCUR)

Local Integer ISITE , ISOC , ERR
Local Integer BALREP, BALSNS

Local Integer CLAS
Local Char    BALFCY(GLONFCY)

If [F:HAE]CAT<>3 & [F:HAE]CAT<>5
 ISITE = find([F:HAE]FCY,GSITE(1..GNBSITE))
 If !ISITE : End : Endif
 BALSOC = GSOCSITE(ISITE)
 ISOC = find(BALSOC,GSOC(1..GNBSOC))
 If !ISOC : End : Endif
 BALREP = 0
 BALTYP = [F:CDAE]LEDTYP
 BALACC = [F:CDAE]ACC
 BALBPR = [F:CDAE]BPR
 BALCUR = [F:CDAE]CUR
 BALEXE = [F:CDAE]FIY
 BALPER = [F:CDAE]PER
 BALSNS = [F:CDAE]SNS
 Gosub BALCPT : # BALANCE : ACC+BPR
 If GOK<1 : End : Endif
 If [F:CDAE]BPR<>""
  BALBPR = ""
  Gosub BALCPT : # BALANCE : ACC (=collective account)
  If GOK<1 : End : Endif
 Endif

 # Update the carry forward amounts in real time.
 If GRAN=2 & GEXEAN(ISOC,BALTYP)=[F:CDAE]FIY
  BALREP = 1
  BALEXE += 1
  BALPER = 0
  BALACC = [F:CDAE]ACC
  BALBPR = [F:CDAE]BPR
  Gosub RAN_GEN
  If GOK<1 : End : Endif
  If RESULT
   Gosub BALCPT : # Carry-forward ACC+BPR
   If GOK<1 : End : Endif
   If BALBPR<>""
    BALBPR = ""
    Gosub BALCPT : # Carry-forward ACC (=collective account)
    If GOK<1 : End : Endif
   Endif
  Endif
 Endif

 # Update Accounting Balance for main general ledger.
 If [F:CDAE]BPR<>""
  Call SETMAINREF([F:HAE]CPY,GTYPGEN,GTYPANA) From CPTDIV
  If [F:CDAE]LEDTYP=GTYPGEN
   Gosub SOLDE : # Update accounting balance
  Endif
 Endif
Endif
End


#########################################
## General balance forward
#########################################
$RAN_GEN
Local Integer RESULT , IGCM , ILED , EQUILIBRE
Local Char    REFER(GLONLED) , CLAS(GLONCLA)
IGCM  = find(GGCMSOC(ISOC),GGCM(1..GGCMNBR))
REFER = evalue("GLED"+num$(BALTYP)+"("+num$(IGCM)+")")
ILED  = find(REFER,GLED(1..GLEDNBR))
EQUILIBRE = (GLEDEQLRAN(ILED)=2)
RESULT = 0
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
If clalev([F:COA])=0 : Local File GCOA     [COA] : Endif
If clalev([F:CLS])=0 : Local File GACCCLS  [CLS] : Endif
Call LEC_GAC([F:CDAE]ACC,[F:CDAE]COA) From CPTLEC
If !fstat
 CLAS = [F:GAC]CLSCOD
 Call LEC_COA([F:CDAE]COA) From CPTLEC
 Call LEC_CLS([F:COA]LEGCLS,CLAS) From CPTLEC
 If [F:CLS]ERA<>2 : # Account classes =  CFE => Profit and loss accounts
  If EQUILIBRE
   If [F:COA]ACCMIS(10)=""
    GOK = 0 : Call ERREURT(mess(106,106,1)-"("+[F:CDAE]COA+")",ERR) From GESECRAN : Return
   Endif
   BALACC = [F:COA]ACCMIS(10)
   BALBPR = ""
   RESULT = 2
  Else
   RESULT = 0
  Endif
 Else
  RESULT = 1
 Endif
Endif
Return

#############
$BALCPT
# Update company
 BALFCY = ""
 Gosub MAJBAL
 If GOK<1 : Return : Endif
# Update facility
 BALFCY = [F:CDAE]FCYLIN
 Gosub MAJBAL
 If GOK<1 : Return : Endif
Return

#############
$MAJBAL
# Update General Balance
Readlock [BAL]BAL0 = BALTYP;BALSOC;BALFCY;BALEXE;BALACC;BALBPR;BALCUR
If fstat=1
 GOK = -1 : GLOCK = "$BALANCE"-num$(BALTYP)-BALSOC-BALFCY-num$(BALEXE)-BALACC-BALBPR-BALCUR : Return
Elsif fstat
 Raz [F:BAL]
 [F:BAL]LEDTYP = BALTYP
 [F:BAL]CPY    = BALSOC
 [F:BAL]FCY    = BALFCY
 [F:BAL]FIY    = BALEXE
 [F:BAL]ACC    = BALACC
 [F:BAL]BPR    = BALBPR
 [F:BAL]CUR    = BALCUR
 [F:BAL]ACCNUM = uniqid([F:BAL])
 [F:BAL]LED    = [F:CDAE]LED
 [F:BAL]COA    = [F:CDAE]COA
 [F:BAL]CURLED = [F:CDAE]CURLED
 Gosub CALBAL
 Write [BAL]
Else
 Gosub CALBAL
 Rewrite [BAL]
Endif
If fstat
 GOK=0 : Call FSTA("BAL") From GLOCK : Return
Endif
Return

#############
$CALBAL
If BALSNS=1
 [F:BAL]DEB(BALPER)    += SIGN*[F:CDAE]AMTCUR
 [F:BAL]DEBLED(BALPER) += SIGN*[F:CDAE]AMTLED
Else
 [F:BAL]CDT(BALPER)    += SIGN*[F:CDAE]AMTCUR
 [F:BAL]CDTLED(BALPER) += SIGN*[F:CDAE]AMTLED
Endif

If BALREP
 If [F:BAL]DEB(BALPER)>[F:BAL]CDT(BALPER)
  [F:BAL]DEB(BALPER) = [F:BAL]DEB(BALPER) - [F:BAL]CDT(BALPER)
  [F:BAL]CDT(BALPER) = 0
 Else
  [F:BAL]CDT(BALPER) = [F:BAL]CDT(BALPER) - [F:BAL]DEB(BALPER)
  [F:BAL]DEB(BALPER) = 0
 Endif
 If [F:BAL]DEBLED(BALPER)>[F:BAL]CDTLED(BALPER)
  [F:BAL]DEBLED(BALPER) = [F:BAL]DEBLED(BALPER) - [F:BAL]CDTLED(BALPER)
  [F:BAL]CDTLED(BALPER) = 0
 Else
  [F:BAL]CDTLED(BALPER) = [F:BAL]CDTLED(BALPER) - [F:BAL]DEBLED(BALPER)
  [F:BAL]DEBLED(BALPER) = 0
 Endif
Endif
Return


#############
$SOLDE
# Aucune mise à jour des soldes pour les mouvements clients et fournisseurs pour :
#    - pièces d'à-nouveau
#    - pièces de clôtures
If [F:HAE]FLGREP=2 & [F:CDAE]PER=0  : # à-nouveau
 Return
Elsif [F:CDAE]PER<>0   : # clôture
 If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
 Call GETSOC([F:HAE]FCY) From DEVSUB
 Call LEC_GTE_LEG(GCURLEG,[F:HAE]TYP) From CPTLEC
 If [F:GTE]PER=3 : Return : Endif
Endif
#
Call LEC_GAC([F:CDAE]ACC,[F:CDAE]COA) From CPTLEC
If !fstat & [F:GAC]UPDBLC>1
 Local Decimal WBLCAMT  : # Montant en devise de transaction
 Local Decimal WBLCAMT1 : # Montant en devise de référentiel (possibilité d'un montant forcé)
 Local Char WSNS(1)
 Case [F:GAC]UPDBLC
  When 2 : # Solde client
   WBLCAMT  = [F:CDAE]SNS*[F:CDAE]AMTCUR : # Solde positif débiteur ?
   WBLCAMT1 = [F:CDAE]SNS*[F:CDAE]AMTLED
   If SIGN=-1 : WSNS="-" Else WSNS="+" : Endif
   Call MAJMVC([F:CDAE]BPR,[F:HAE]CUR,[F:HAE]TYPRAT,0,[F:HAE]RATDAT,
&              [F:HAE]NUM,[F:CDAE]FCYLIN,WBLCAMT1,WBLCAMT,WSNS,"S","",0) From TRTBPMVT

  When 3 : # Solde fournisseur
   WBLCAMT  = -SIGN*[F:CDAE]SNS*[F:CDAE]AMTCUR : # Solde positif créditeur ?
   WBLCAMT1 = -SIGN*[F:CDAE]SNS*[F:CDAE]AMTLED
   Call MAJENC_BPS([F:CDAE]BPR,0,[F:CDAE]FCYLIN,[F:HAE]CUR,[F:HAE]TYPRAT,[F:HAE]RATDAT,
&                  [F:HAE]NUM,WBLCAMT1,WBLCAMT,[F:CDAE]AMTCUR) From TRTBPMVT
  Endcase
Endif
Return

###################################################
# Update Analytical Balance
###################################################
Subprog BALANA(SIGN)
Value Integer SIGN

Local Integer CC , AXE
Local Integer BALSNS
Local Integer ISITE , ISOC , RANA , ERR
Local Integer I , J , K

Local Integer BALTYP, BALEXE, BALPER, BALREP
Local Char    BALSOC(GLONCPY), BALFCY(GLONFCY)
Local Char    BALCOA(GLONCOA),BALACC(GLONGAC)
Local Char    BALCUR(GLONCUR)
Local Char    BALBPR(GLONBPR)
Local Char    BALAXE(GLONDIE)

Local Char    BALSEC1(GLONCCE) , BALSEC2(GLONCCE) , BALSEC3(GLONCCE)
Local Char    BALSEC4(GLONCCE) , BALSEC5(GLONCCE) , BALSEC6(GLONCCE)
Local Char    BALSEC7(GLONCCE) , BALSEC8(GLONCCE) , BALSEC9(GLONCCE)
Local Char    SECTION(GLONCCE)

Local Char    BUDCOD(GLONBUP)

If !clalev([F:DIE]) : Local File GDIE      [DIE] : Endif

If [F:HAE]CAT<>3 & [F:HAE]CAT<>5
 Call INDLED([F:CDAA]LED,"",I,J) From CPTDIV
 If sigma(0,GLEDDIENBR(I)-1,[F:CDAA]CCE(indcum))<>"" | GLEDDIEIPT(I)=2
  ISITE = find([F:HAE]FCY,GSITE(1..GNBSITE))
  If !ISITE : End : Endif
  BALSOC = GSOCSITE(ISITE)
  ISOC = find(BALSOC,GSOC(1..GNBSOC))
  If !ISOC : End : Endif
  BALTYP = [F:CDAA]LEDTYP
  BALCOA = [F:CDAA]COA
  BALACC = [F:CDAA]ACC
  BALCUR = [F:CDAA]CUR
  BALEXE = [F:CDAE]FIY
  BALREP = 0
  BALPER = [F:CDAE]PER
  BALBPR = [F:CDAA]BPR
  BALSNS = [F:CDAA]SNS
  For I=1 To 9
   Assign "BALSEC"+num$(I) With evalue("[F:CDAA]CCE("+num$(I-1)+")")
  Next
  Gosub BAL_ANA : # BALANA : ACC+BPR
  If GOK<1 : End : Endif
  If [F:CDAA]BPR<>""
   BALBPR = ""
   Gosub BAL_ANA : # BALANA : ACC (=collective account)
   If GOK<1 : End : Endif
  Endif

  # Update the carry forward amounts in real time.
  If GRANA=2 & GEXEAN(ISOC,BALTYP)=[F:CDAE]FIY
   BALACC = [F:CDAA]ACC
   BALBPR = [F:CDAA]BPR
   Gosub RAN_GEN
   If GOK<1 : End : Endif
   If RESULT
    If RESULT=2
     Raz BALSEC1,BALSEC2,BALSEC3,BALSEC4,BALSEC5,BALSEC6,BALSEC7,BALSEC8,BALSEC9
    Else
     Gosub RAN_ANA
    Endif
    If GOK<1 : End : Endif
    BALREP = 1
    BALPER = 0
    BALEXE += 1

    Gosub BAL_ANA : # BALANA : ACC+BPR
    If GOK<1 : End : Endif
    If BALBPR<>""
     BALBPR = ""
     Gosub BAL_ANA : # BALANA : ACC (=collective account)
     If GOK<1 : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif
End


$BAL_ANA
# Update company
BALFCY = ""
Gosub MAJBLA
If GOK<1 : Return : Endif
# Update facility
BALFCY = [F:CDAE]FCYLIN
Gosub MAJBLA
If GOK<1 : Return : Endif
Return


#########################################
## Dimention (CEE)  - Carry forward
#########################################
$RAN_ANA
If clalev([F:CCE])=0 : Local File CACCE [CCE] : Endif
For AXE=1 To 9
 BALAXE  = [F:CDAA]DIE(AXE-1)
 SECTION = [F:CDAA]CCE(AXE-1)
 If BALAXE<>"" & SECTION<>""
  J = find(BALAXE,GDIECOD(1..GDIENBR))
  If GDIEPRJ(J)=2
   SECTION = ""
  Else
   Read [CCE]CCE0 = BALAXE;SECTION
   If [F:CCE]FRW<>2
    SECTION = ""
   Endif
  Endif
 Endif
 Assign "BALSEC"+num$(AXE) With SECTION
Next AXE
Return

$MAJBLA
# Update Analytical Balance
Readlock [BLA]BLA0 = BALTYP;BALSOC;BALFCY;BALEXE;BALACC;BALBPR;BALSEC1;BALSEC2;BALSEC3;BALSEC4;BALSEC5;BALSEC6;BALSEC7;BALSEC8;BALSEC9;BALCUR
If fstat=1
 GOK = -1 : GLOCK = "$BALANA"-num$(BALTYP)-BALACC-BALBPR : Return
Elsif fstat
 Raz [F:BLA]
 [F:BLA]LEDTYP = BALTYP
 [F:BLA]CPY    = BALSOC
 [F:BLA]FCY    = BALFCY
 [F:BLA]FIY    = BALEXE
 [F:BLA]ACC    = BALACC
 [F:BLA]BPR    = BALBPR
 [F:BLA]CCE1   = BALSEC1
 [F:BLA]CCE2   = BALSEC2
 [F:BLA]CCE3   = BALSEC3
 [F:BLA]CCE4   = BALSEC4
 [F:BLA]CCE5   = BALSEC5
 [F:BLA]CCE6   = BALSEC6
 [F:BLA]CCE7   = BALSEC7
 [F:BLA]CCE8   = BALSEC8
 [F:BLA]CCE9   = BALSEC9
 [F:BLA]CUR    = BALCUR
 [F:BLA]ACCNUM = uniqid([F:BLA])
 [F:BLA]LED    = [F:CDAA]LED
 [F:BLA]COA    = [F:CDAA]COA
 [F:BLA]CURLED = [F:CDAE]CURLED
 For I=1 To 9
  Assign "[F:BLA]DIE("+num$(I-1)+")"  With evalue("[F:CDAA]DIE("+num$(I-1)+")")
 Next
 Gosub CALBLA
 Write [BLA]
Else
 Gosub CALBLA
 Rewrite [BLA]
Endif
If fstat
 GOK=0 : Call FSTA("BLA") From GLOCK : Return
Endif
# Update Analytical Quantity Balance
If [F:CDAA]QTY<>0
 Readlock [BLQ]BLQ0 = BALTYP;BALSOC;BALFCY;BALEXE;BALACC;BALBPR;BALSEC1;BALSEC2;BALSEC3;BALSEC4;BALSEC5;BALSEC6;BALSEC7;BALSEC8;BALSEC9;BALCUR
 If fstat=1
  GOK = -1 : GLOCK = "$BLAQTY"-num$(BALTYP)-BALACC-BALBPR : Return
 Elsif fstat
  Raz [F:BLQ]
  [F:BLQ]LEDTYP = BALTYP
  [F:BLQ]CPY    = BALSOC
  [F:BLQ]FCY    = BALFCY
  [F:BLQ]FIY    = BALEXE
  [F:BLQ]ACC    = BALACC
  [F:BLQ]BPR    = BALBPR
  [F:BLQ]CCE1   = BALSEC1
  [F:BLQ]CCE2   = BALSEC2
  [F:BLQ]CCE3   = BALSEC3
  [F:BLQ]CCE4   = BALSEC4
  [F:BLQ]CCE5   = BALSEC5
  [F:BLQ]CCE6   = BALSEC6
  [F:BLQ]CCE7   = BALSEC7
  [F:BLQ]CCE8   = BALSEC8
  [F:BLQ]CCE9   = BALSEC9
  [F:BLQ]CUR    = BALCUR
  [F:BLQ]ACCNUM = uniqid([F:BLQ])
  [F:BLQ]LED    = [F:CDAA]LED
  [F:BLQ]COA    = [F:CDAA]COA
  For I=1 To 9
   Assign "[F:BLQ]DIE("+num$(I-1)+")"  With evalue("[F:CDAA]DIE("+num$(I-1)+")")
  Next
  [F:BLQ]UOM    = [F:CDAA]UOM
  [F:BLQ]QTY(BALPER) += SIGN*BALSNS*[F:CDAA]QTY
  Write [BLQ]
 Else
  [F:BLQ]QTY(BALPER) += SIGN*BALSNS*[F:CDAA]QTY
  Rewrite [BLQ]
 Endif
 If fstat
  GOK=0 : Call FSTA("BLQ") From GLOCK : Return
 Endif
Endif
Return

$CALBLA
If BALSNS=1
 [F:BLA]DEB(BALPER)    += SIGN*[F:CDAA]AMTCUR
 [F:BLA]DEBLED(BALPER) += SIGN*[F:CDAA]AMTLED
Else
 [F:BLA]CDT(BALPER)    += SIGN*[F:CDAA]AMTCUR
 [F:BLA]CDTLED(BALPER) += SIGN*[F:CDAA]AMTLED
Endif
If BALREP
 If [F:BLA]DEB(0)>[F:BLA]CDT(0)
  [F:BLA]DEB(0) = [F:BLA]DEB(0) - [F:BLA]CDT(0)
  [F:BLA]CDT(0) = 0
 Else
  [F:BLA]CDT(0) = [F:BLA]CDT(0) - [F:BLA]DEB(0)
  [F:BLA]DEB(0) = 0
 Endif
 If [F:BLA]DEBLED(0)>[F:BLA]CDTLED(0)
  [F:BLA]DEBLED(0) = [F:BLA]DEBLED(0) - [F:BLA]CDTLED(0)
  [F:BLA]CDTLED(0) = 0
 Else
  [F:BLA]CDTLED(0) = [F:BLA]CDTLED(0) - [F:BLA]DEBLED(0)
  [F:BLA]DEBLED(0) = 0
 Endif
Endif
Return
