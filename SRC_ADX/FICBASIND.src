#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPRIME("FICBASIND","") From ETAT
End

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Call EXEC(NBPAR,PARAMETRE)
End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Gosub OUVFIC
Gosub DECLARATION

#Recup no de requete
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT
[L]NUMREQ = val(PARAM)
[L]ETAT="FICBASIND"

CRITERE="1=1"
For I=0 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "cpydeb" : If [L]VALEUR<>""
                    [L]CRITERE -= '& [F:HRBAI]CPY>="'+[L]VALEUR+'"'
                   Endif
   When "cpyfin" : If [L]VALEUR<>""
                    [L]CRITERE -= '& [F:HRBAI]CPY<="'+[L]VALEUR+'"'
                   Endif
   When "exo" : If [L]VALEUR<>""
                    [L]CRITERE -= '& [F:HRBAI]EXO="'+[L]VALEUR+'"'
                   Endif
   When "matdeb" : If [L]VALEUR<>""
                    [L]CRITERE -= '& [F:HRBAI]REFNUM>="'+[L]VALEUR+'"'
                   Endif
   When "matfin" : If [L]VALEUR<>""
                    [L]CRITERE -= '& [F:HRBAI]REFNUM<="'+[L]VALEUR+'"'
                   Endif

  Endcase
 Endif
Next

# Affectation du no de requête
PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

Call DEBTRANS From GLOCK
GOK = 1
Gosub TR1
End

########################################
$OUVFIC
If clalev([F:ARM])=0   : Local File AREPORTM  [ARM]   : Endif
If clalev([F:HRBAI])=0 : Local File BASIND    [HRBAI] : Endif
If clalev([F:BAS])=0   : Local File BASGEN    [BAS]   : Endif
If clalev([F:ID])=0    : Local File EMPLOID   [ID]    : Endif
If clalev([F:ACC])=0   : Local File ACCES     [ACC]   : Endif
Return

########################################
$DECLARATION
Local Integer NUMREQ
Local Char ETAT (10)
Local Char CRITERE(250)
Local Char PARAM(30)
Local Char VALEUR(30)
Return

########################################
$TR1
GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER & CREDAT<date$
 If fstat=1
  GOK = -1 : GLOCK = "AREPORTM"-GUSER : Goto ROLL_TR1
 Endif
 LIG=0
 For [F:HRBAI]BAI0 Where evalue (CRITERE)
  mkstat = 0
  Call DROIT([F:HRBAI]REFNUM) From DIVPAYE
  If !mkstat
   For I=0 To [F:HRBAI]NBRBAS-1
    LIG += 1
    Raz [F:ARM]
    [F:ARM]USR    = GUSER
    [F:ARM]RPTCOD = [L]ETAT
    [F:ARM]NUMREQ = [L]NUMREQ
    [F:ARM]NUMLIG = LIG
    [F:ARM]CLEA1  = [F:HRBAI]CPY
    [F:ARM]CLEA2  = [F:HRBAI]EXO
    [F:ARM]CLEA3  = [F:HRBAI]REFNUM
    [F:ARM]CLEMD1 = [F:HRBAI]PPN
    [F:ARM]CLED1  = [F:HRBAI]DATSTR
    [F:ARM]CLED2  = [F:HRBAI]DATEND
    [F:ARM]CLEA4  = [F:HRBAI]CODBAS(I)
    Read[F:BAS]BAS0=[F:HRBAI]CODBAS(I)
    If !fstat
     [F:ARM]CLEA5  = [F:BAS]DES
    Endif
    [F:ARM]CLEMD2  = [F:HRBAI]AMTBAS(I)
    [F:ARM]CREDAT = date$
    [F:ARM]CLEA6  = [F:HRBAI]CTRNUM
    Write [ARM]
    If fstat
     GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
    Endif
   Next
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

