Variable Char    VALEUR()
## Action STD
Call AM_WEVAMAT(VALEUR) From SUBECP
If mkstat : GERR = 1 : GZONE = "WEVAMAT" : GZNUM = 1001508 : Endif
Gosub _AFF
End

Subprog S_WEVAMAT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "EML"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_WEVAMAT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "EML"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WEVAMAT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("EML",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_WEVAPOT
Onevent BEFORE_INPUT Call AS_WEVAPOT(zc) From W1ECP4
Onevent CONTROL Call C_WEVAPOT(zc) From W1ECP4
Return

Subprog AS_WEVAPOT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(22321,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_WEVAPOT(zc) From W1ECP4
Onkey   2 Titled GBOUTS Call S_WEVAPOT(zc) From W1ECP4
Onkey 144 Titled GBOUTP Call P_WEVAPOT(zc) From W1ECP4
Onkey 146 Titled GBOUTA Call SA_WEVAPOT(zc) From W1ECP4
Gosub _AFF
End

Subprog C_WEVAPOT(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("POT","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "WEVAPOT" : GZNUM = 22321 : Endif
Gosub _AFF
End

Subprog S_WEVAPOT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPOT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOT"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_WEVAPOT" : PROGSUB = "SUBECP" : PROGSPE = "SPEECP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOT","SUBPOT","") From GACTION
 ACTION = "BS_WEVAPOT" : PROGSUB = "SUBECP" : PROGSPE = "SPEECP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_WEVAPOT(VALEUR)
Variable Char    VALEUR()
Call OBJET("POT",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_WEVAPOT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "POT"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WEVAPOT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("POT",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

