#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ECP4 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:05"
A_USER  = "DOC"
A_STAMP = "20181109230405"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBREVA"
  If [M]NBREVA=0
  Endif
 When "NBREVAD"
  If [M]NBREVAD=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ECP4 [ECP4]
Gosub HORODAT
Local Inpbox "ECP4" From GFONCTION At A_STAMP With A_WINDPREV Mask [ECP4] As [SIM_]
Grizo [ECP4]5
Grizo [ECP4]10
Grizo [ECP4]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ECP4]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=88 : Y1(0)=1 : Y2(0)=9
X1(1)=1 : X2(1)=88 : Y1(1)=10 : Y2(1)=22
X1(2)=1 : X2(2)=0 : Y1(2)=23 : Y2(2)=22
Return

$ON_NBREVA
Onevent BEFORE_INPUT Call AS_NBREVA From W1ECP4
Return

Subprog IB_NBREVA
Local Decimal BASPAG
## Action STD
Call IB_NBREVA From SUBECP
Gosub _AFF
End

Subprog AS_NBREVA
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(50333,GBOUT1) From OBJDIV
Call IB_NBREVA
Onkey 129 Titled GBOUT1 Call B1_NBREVA From W1ECP4
Gosub _AFF
End

Subprog B1_NBREVA
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B1_NBREVA From SUBECP
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_EVATYP
Onevent INIT_AREA Call D_EVATYP(zc) From W1ECP4
Onevent CONTROL Call C_EVATYP(zc) From W1ECP4
Onevent AFTER_CHANGE Gosub AMM_EVATYP From W1ECP4
Onevent BEFORE_INPUT Call AS_EVATYP(zc) From W1ECP4
Return

Subprog D_EVATYP(VALEUR)
Variable Char    VALEUR()
If varinit([M]EVATYP,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10360","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_EVATYP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_EVATYP(zc) From W1ECP4
Onkey 144 Titled GBOUTP Call P_EVATYP(zc) From W1ECP4
Onkey 146 Titled GBOUTA Call SA_EVATYP(zc) From W1ECP4
If VALEUR="" : Call INIADI(VALEUR,"10360") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_EVATYP(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "EVATYP" : GZNUM = 46680 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"10360","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "EVATYP" : GZNUM = 46680 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"10360",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "EVATYP" : GZNUM = 46680 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_EVATYP
Call AM_EVATYP(zc)
If !mkstat & GOBJET
 zoncou = "EVATYP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_EVATYP(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_EVATYP(VALEUR) From SUBECP
If mkstat : GERR = 1 : GZONE = "EVATYP" : GZNUM = 46680 : Endif
Gosub _AFF
End

Subprog S_EVATYP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10360"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_EVATYP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10360"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_EVATYP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10360"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

