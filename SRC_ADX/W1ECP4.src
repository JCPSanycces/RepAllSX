Onevent BEFORE_INPUT Call AS_WEVAMAT(zc) From W1ECP4
Return

Subprog AS_WEVAMAT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_WEVAMAT(zc) From W1ECP4
Onkey 144 Titled GBOUTP Call P_WEVAMAT(zc) From W1ECP4
Onkey 146 Titled GBOUTA Call SA_WEVAMAT(zc) From W1ECP4
Gosub _AFF
End

Subprog C_WEVAMAT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTEMP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTEMP"
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 PARMSK(6) = [M]LEG
 Call S_LIS_CHAR(VALEUR,PARMSK,"","DIVPAYE","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "WEVAMAT" : GZNUM = 1001508 : Endif
Endif
If !mkstat
 ## Action DROITEMP
 Call DROIT(VALEUR,"","","") From DIVPAYE
 If mkstat : GERR = 1 : GZONE = "WEVAMAT" : GZNUM = 1001508 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("EML","!",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "WEVAMAT" : GZNUM = 1001508 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_WEVAMAT
Call AM_WEVAMAT(zc)
If !mkstat & GOBJET
 zoncou = "WEVAMAT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

