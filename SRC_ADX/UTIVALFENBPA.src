#<AdxTL>@(#)7.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Validation des fenêtres avec écran qui utilise le menu local 7872
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("Windows BPA*") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub VALID
End

#-------------------#
$VALID

Local Char    ECRAN(GLONAMK)(1..30) , FEN(GLONFEN)(1..30)
Local Integer NBECR , NBFEN
Local Integer I , VALMOD(20)

If DOSSIER<>GDOSX3
 For I=0 To dim(VALMOD)-1
  VALMOD(I) = 2
 Next I
Else
 VALMOD(0) = 2
 For I=1 To dim(VALMOD)-1
  VALMOD(I) = 1
 Next I
Endif

If DOSSIER=nomap
 Local File AMSKZON [AMKX] , AWINDOW [AWIX]
Else
 Local File =DOSSIER+".AMSKZON" [AMKX] , =DOSSIER+".AWINDOW" [AWIX]
Endif

Raz ECRAN , FEN
For [AMKX]CODTYP Where CODTYP="M" & NOLIB=7872
 If !find([F:AMKX]CODMSK,ECRAN(1..NBECR))
  NBECR += 1
  ECRAN(NBECR) = [F:AMKX]CODMSK
 Endif
Next AMKX

For [AWIX]
 If !find([F:AWIX]WIN,FEN(1..NBFEN))
  If find([F:AWIX]MSKENT,ECRAN(1..NBECR))
   NBFEN += 1
   FEN(NBFEN) = [F:AWIX]WIN
  Else
   For I=1 To NBMSK
    If find([F:AWIX]NOMMSK(I-1),ECRAN(1..NBECR))
     NBFEN += 1
     FEN(NBFEN) = [F:AWIX]WIN
     Break
    Endif
   Next I
  Endif
 Endif
Next AWIX

For I=1 To NBFEN
 Call VALID_TRT(DOSSIER,0,"","","","","","","","","","",FEN(I),FEN(I),"","","","","","","","",VALMOD) From VALDICO
Next I

Close Local File

Return
