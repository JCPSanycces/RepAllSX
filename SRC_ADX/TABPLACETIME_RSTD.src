#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe TABPLACETIME

# Issue 113105 - 2016-01-13 by MAE : Refactoring code
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER" : Gosub AREAD_AFTER
    Endcase
Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "TPCT.DPETPC"     : Gosub TPCT_DPETPC
  When "TPCT.ARVTPC"     : Gosub TPCT_ARVTPC
  When "TPCT.TRNTPC"     : Gosub TPCT_TRNTPC # Issue 111257 US3
Endcase
Return



#$METHODS
#Case [L]CURPTH
#   When ""
#      Case [L]ACTION
#        When "AREAD_AFTER" : Gosub AREAD_AFTER
#      Endcase
#Endcase
#Return

##############################################################################################
$TPCT_DPETPC
Case [L]ARULE
 When "PROPAGATE"   : Gosub TPCT_DPETPC_PROPAGATE
Endcase
Return

$TPCT_DPETPC_PROPAGATE
Local File BPADDRESS [BPA]

#lecture TABPLACE
Local File TABPLACE [TPC]
Read [TPC] TPC0=this.DPETPC
If fstat Raz [F:TPC] : Endif

Filter [F:BPA] Where BPATYP=8 & BPANUM = [F:TPC]TPC
Read [F:BPA] First

this.APARENT.DPECRY = [F:BPA]CRY

Return

##############################################################################################
$TPCT_ARVTPC
Case [L]ARULE
 When "PROPAGATE"   : Gosub TPCT_ARVTPC_PROPAGATE
Endcase
Return

$TPCT_ARVTPC_PROPAGATE
Local File BPADDRESS [BPA]

#lecture TABPLACE
Local File TABPLACE [TPC]
Read [TPC] TPC0=this.ARVTPC
If fstat Raz [F:TPC] : Endif

Filter [F:BPA] Where BPATYP=8 & BPANUM = [F:TPC]TPC
Read [F:BPA] First

this.APARENT.ARVCRY = [F:BPA]CRY

Return
# Start Issue 111257 US3
##############################################################################################
$TPCT_TRNTPC
Case [L]ARULE
 When "INIT"   : Gosub TPCT_TRNTPC_INIT
Endcase
Return
##############################################################################################
$TPCT_TRNTPC_INIT
  this.TRNTPC = 5
Return
# End Issue 111257 US3
##############################################################################################
$AREAD_AFTER
Local File BPADDRESS [BPA]

#lecture TABPLACE
Local File TABPLACE [TPC]
Read [TPC] TPC0=this.TPCT.DPETPC
If fstat Raz [F:TPC] : Endif
Filter [F:BPA] Where BPATYP=8 & BPANUM = [F:TPC]TPC
Read [F:BPA] First
this.DPECRY = [F:BPA]CRY

Read [TPC] TPC0=this.TPCT.ARVTPC
If fstat Raz [F:TPC] : Endif
Filter [F:BPA] Where BPATYP=8 & BPANUM = [F:TPC]TPC
Read [F:BPA] First
this.ARVCRY = [F:BPA]CRY

Return

