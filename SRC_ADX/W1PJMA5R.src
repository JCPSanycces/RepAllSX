#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMA5R 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:41"
A_USER  = "DOC"
A_STAMP = "20181109230541"
Return

$TITRES
Chgtzn [M:PJM5R]PSCFREEC6B With func SUBPJMA.COL_GET_TITLE_20(26)
Chgtzn [M:PJM5R]PSCMARGTOT6 With func SUBPJMA.COL_GET_TITLE_20(29)
Chgtzn [M:PJM5R]PSCPCTMTOT6 With func SUBPJMA.COL_GET_TITLE_20(30)
Chgtzn [M:PJM5R]PSCFREEC7A With func SUBPJMA.COL_GET_TITLE_20(32)
Chgtzn [M:PJM5R]PSCFREEC8B With func SUBPJMA.COL_GET_TITLE_20(34)
Chgtzn [M:PJM5R]PSCFREEC9B With func SUBPJMA.COL_GET_TITLE_20(36)
Chgtzn [M:PJM5R]PSCFREEC10B With func SUBPJMA.COL_GET_TITLE_20(38)
Chgtzn [M:PJM5R]PSCFREEC6A With func SUBPJMA.COL_GET_TITLE_20(25)
Chgtzn [M:PJM5R]PSCMARGBUD6 With func SUBPJMA.COL_GET_TITLE_20(27)
Chgtzn [M:PJM5R]PSCPCTMBUD6 With func SUBPJMA.COL_GET_TITLE_20(28)
Chgtzn [M:PJM5R]PSCFREEC7B With func SUBPJMA.COL_GET_TITLE_20(31)
Chgtzn [M:PJM5R]PSCFREEC8A With func SUBPJMA.COL_GET_TITLE_20(33)
Chgtzn [M:PJM5R]PSCFREEC9A With func SUBPJMA.COL_GET_TITLE_20(35)
Chgtzn [M:PJM5R]PSCFREEC10A With func SUBPJMA.COL_GET_TITLE_20(37)
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMA5R [PJM5R]
Gosub HORODAT
Local Inpbox "PJMA5R" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJM5R] As [SIM_]
Grizo [PJM5R]30
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJM5R]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=188 : Y1(0)=1 : Y2(0)=25
Return

$ON_PSCU
Return

$ON_PSCFREEC6B
Onevent BEFORE_AREA Gosub AV_PSCFREEC6B From W1PJMA5R
Return

$AV_PSCFREEC6B
If func SUBPJMA.COLGETFMT_20(26)<>""
 Chgfmt [M]PSCFREEC6B(indice) With func SUBPJMA.COLGETFMT_20(26)
Else
 Chgfmt [M]PSCFREEC6B(indice) With "-K:1X"
Endif
Gosub _AFF
Return

