#<AdxTL>@(#)0.0.0.0 $Revision$
$CUSTOMERS

Delete [F:SAFTP] Where 1=1

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Local Char CODACTIV(255) : CODACTIV = ""
If func AFNC.ACTIV("INVCA") = 1
  [L]CODACTIV = "& [F:SIH]REVCANSTA<>2"
Endif

[L]FACCRITER = "[F:SIH]INVTYP<5 & [F:SIH]ACCDAT>=["+format$(GFMD,[L]STRDATE)+"] & [F:SIH]ACCDAT<=["+format$(GFMD,[L]ENDDATE)+"] & [F:SIH]STA=3 & [F:SIH]CPY=[L]SOC"-[L]CODACTIV
#105200 RICAR 2015/05/25 - Inv Cancelation - END

[L]FACCRITER += " & ([F:FCY]CRY='' | [F:FCY]CRY='PT')"

Local Char LASBPCNUM(GLONBPC) : [L]LASBPCNUM = ""

Case [L]SAFTTYPE
  When 6 #AT comunication
    Gosub CUST_COMFAC
    Gosub CUST_CFACPYH
  When 8 #Shipping documents
    Gosub CUST_COMDT
    Gosub FEED_BPCCPY
    Gosub CUST_3_ITER
  When Default
    For [F:BPC]BPC0 Where [F:BPC]BPCTYP <> 4
      Gosub CUST_1_ITER
    Next
    Gosub CUST_3_ITER
    Gosub CUST_2_ITER
    Gosub CUST_4_ITER
    If GMODU(7) = 2
      Gosub FEED_BPCCPY
    Endif
Endcase
Return
#######################################################################################
#######################################################################################
$CUST_COMDT
Gosub DECLARE_TABLES  From SAFTGENPORMG
Gosub DEC_COMDT_CRITS From SAFTGENPORMG
Gosub ALIM_CRITER     From SAFTGENPORMG


#All documents
If [M:SAFT]EVRDOCTYP = 2
  For [F:BPC]
    Link [F:PTDK2] With [F:PTSDH]SDH0~=[F:PTDK2]DOCNUM  As [MG1]
&   Where [F:PTSDH]BPCORD= [F:BPC]BPCNUM & [F:PTSDH]CFMFLG=2 & [F:PTSDH]SHIDAT>=[L]STRDATE & [F:PTSDH]SHIDAT<=[L]ENDDATE &
&   [F:PTSDH]CPY=[L]SOC & [F:PTDK2]ATDTCOD='' & evalue([L]CRITSDH)
    Read [F:MG1] First
    If !fstat
      Gosub CUST_1_ITER : Close File [MG1]
      Goto  SEGUINTE
    Endif
    Close File [MG1]

    Link [F:PTDK2] With [F:PTSRH]SRH0~=[F:PTDK2]DOCNUM  As [MG2]
&   Where [F:PTSRH]SRHCFMFLG=2 & [F:PTSRH]RTNDAT>=[L]STRDATE & [F:PTSRH]RTNDAT<=[L]ENDDATE & [F:PTSRH]CPY=[L]SOC &
&   evalue([L]CRITSRH) & [F:PTDK2]ATDTCOD='' & [F:PTSRH]BPCORD=[F:BPC]BPCNUM
    Read [MG2] First
    If !fstat
      Gosub CUST_1_ITER : Close File [MG2]
      Goto  SEGUINTE
    Endif
    Close File [MG2]

    Link [F:PTDK2] With [F:PTTNH]TNH0~=[F:PTDK2]DOCNUM  As [MG3]
&   Where [F:PTTNH]CFMFLG=2 & [F:PTTNH]TRNDAT>=[L]STRDATE & [F:PTTNH]TRNDAT<=[L]ENDDATE & [F:PTTNH]CPY=[L]SOC &
&   evalue([L]CRITTNH) & [F:PTDK2]ATDTCOD='' & [F:PTTNH]BPRNUM=[F:BPC]BPCNUM & [F:PTTNH]BPCBPS=1
    Read [MG3] First
    If !fstat
      If [F:PTTNH]BPCBPS=1
        Gosub CUST_1_ITER : Close File [MG3]
        Goto  SEGUINTE
      Endif
    Endif
    Close File [MG3]

    $SEGUINTE
  Next
Else
  Case [M:SAFT]DOCTYP
    When 2 #Shipments
      Gosub OPEN_LNK_SDH    From SAFTGENPORMG
      For [MGT1]
        [F:BPC]=[F:PTBPC]
        If [L]LASBPCNUM <> [F:BPC]BPCNUM
          Gosub CUST_1_ITER
        Endif
        [L]LASBPCNUM = [F:BPC]BPCNUM
      Next
      Gosub CLOSE_LNK_SDH From SAFTGENPORMG
    When 3,4,5 #Sales Returns
      Gosub OPEN_LNK_SRH    From SAFTGENPORMG
      [F:BPC]=[F:PTBPC]
      For [MGT2]
        If [L]LASBPCNUM <> [F:BPC]BPCNUM
          Gosub CUST_1_ITER
        Endif
        [L]LASBPCNUM = [F:BPC]BPCNUM
      Next
      Gosub CLOSE_LNK_SRH    From SAFTGENPORMG
    When 10
      Gosub OPEN_LNK_TNH    From SAFTGENPORMG
      For [MGT5]
        If [F:PTTNH]BPCBPS=1
          Read [F:BPC]BPC0=[F:PTBPR]BPRNUM
          If !fstat
            If [L]LASBPCNUM <> [F:BPC]BPCNUM
              Gosub CUST_1_ITER
            Endif
            [L]LASBPCNUM = [F:BPC]BPCNUM
          Endif
        Endif
      Next
      Gosub CLOSE_LNK_TNH    From SAFTGENPORMG
  Endcase
Endif
Return
#######################################################################################
#######################################################################################
$CUST_COMFAC
Link [F:SIH] With [F:FCY]FCY0=[F:SIH]FCY, [F:BPC]BPC0~=[F:SIH]BPR As [BCS]
&             Where evalue([L]FACCRITER) Order By [F:BPC]BPCNUM

Local Char LASBPCNUM(GLONBPC) : [L]LASBPCNUM = ""

For [BCS]
  Call LEC_TSV_LEG([L]LEG,[F:SIH]SIVTYP,[L]STAT) From TRTLECLEG
  If [L]STAT : Raz [F:TSV] : Endif

  If [F:TSV]AUTINV = 2
    Goto NEXT_BCS
  Endif

  If [L]LASBPCNUM <> [F:BPC]BPCNUM
    Gosub CUST_1_ITER

    [F:SAFTP]COD    = "SAFTPT"+[L]SOC
    [F:SAFTP]EECNUM = [F:BPC]BPCNUM
    Write [F:SAFTP]

  Endif

  [L]LASBPCNUM = [F:BPC]BPCNUM

  $NEXT_BCS
Next

Close File [BCS]

Gosub CUST_2_ITER
Gosub CUST_4_ITER

Return
#######################################################################################
#######################################################################################
$CUST_CFACPYH
Local Char LASBPCNUM(GLONBPC) : [L]LASBPCNUM = ""

Gosub GET_PAYSTRDAT From SAFTGENPORPYH

Link [F:PYH] With [F:BPC]BPC0~=[F:PYH]BPR As [BPYH]
& Where [F:PYH]SNS=2 & [F:PYH]CPY=[L]SOC & find([F:PYH]STA,3,4,8,9,10,11) &
& ([F:PYH]ACCDAT>=[L]STRDATE & [F:PYH]ACCDAT<=[L]ENDDATE) &
& ([F:PYH]ACCDAT>[L]PAYSTRDAT | [F:PYH]CSHVATRGM=2) Order By [F:BPC]BPCNUM
For [BPYH]
  If [L]LASBPCNUM = [F:BPC]BPCNUM
    Goto NEXT_CUST_PY
  Endif
  Read [F:SAFTP]SAFTP0="SAFTPT"+[L]SOC;[F:BPC]BPCNUM
  If !fstat : Goto NEXT_CUST_PY : Endif

  Gosub CUST_1_ITER

  NEXT_CUST_PY
  [L]LASBPCNUM = [F:BPC]BPCNUM
Next

Close File [BPYH]
Return
#######################################################################################
#######################################################################################
$CUST_1_ITER
#Entry point do exclude the export of a customer
[L]EXCBPC    = 0
GPOINT  = "SAFTPTBPC" : Gosub ENTREE From EXEFNC
If [L]EXCBPC = 1 : Goto NEXTCUS1 : Endif

#BP
Read [F:BPR]BPR0 = [F:BPC]BPCNUM
If fstat : Raz [F:BPR] : Endif

#Country
If [F:TCY]CRY <> [F:BPR]CRY
  Read [F:TCY]TCY0 = [F:BPR]CRY
  If fstat : Raz [F:TCY] : Endif
Endif

#Address
Read [F:ADC]BPA0 = 1;[F:BPC]BPCINV;[F:BPC]BPAINV
If fstat : Raz [F:ADC] : Endif
If [F:ADC]CRY <> "" & [F:BPR]CRY <> [F:ADC]CRY
  Filter [F:ADC] Where [F:ADC]BPATYP = 1 & [F:ADC]BPANUM = [F:BPC]BPCNUM & [F:ADC]BPAADDFLG = 2 & [F:ADC]CRY = [F:BPR]CRY
  Read [F:ADC] First
  If fstat
    Filter [F:ADC]
    Filter [F:ADC] Where [F:ADC]BPATYP = 1 & [F:ADC]BPANUM = [F:BPC]BPCNUM & [F:ADC]CRY = [F:BPR]CRY
    Read [F:ADC] First
    If fstat
      Raz [F:ADC]
    Endif
  Endif
  Filter [F:ADC]
Endif

#Accounting code
Filter [F:CAC] Where ACCCOD = [F:BPC]ACCCOD & TYP = 2 & COA = [L]COA
Read [F:CAC] First
If fstat : Raz [F:CAC] : Endif
Filter [F:CAC]

#Contact
If [F:BPC]CNTNAM <> ""
  Read [F:AIN]AIN0 = [F:BPC]CNTNAM
  If fstat : Raz [F:AIN] : Endif
Else
  Filter [F:CNT] Where BPATYP = 1 & BPANUM = [F:BPC]BPCNUM
  Read [F:CNT] First
  If !fstat
    Read [F:AIN]AIN0 = [F:CNT]CCNCRM
    If fstat : Raz [F:AIN] : Endif
  Else
    Raz [F:AIN]
  Endif
  Filter [F:CNT]
Endif

#cliente diverso
[L]CDIV = 0

Gosub RAZ_CUT From SAFTGENPOR
[L]CUTCUSTOMID = [F:BPC]BPCNUM
#If [F:CAC]ACC(0)="" | find([L]SAFTTYPE, 2, 5)
#  [L]CUTCACCOUID = 'Desconhecido'
#Else
[L]CUTCACCOUID = [F:CAC]ACC(0)
#Endif
If [L]CUTCACCOUID = "" : [L]CUTCACCOUID = "Desconhecido" : Endif

If [F:BPC]BPCTYP = 2
  [L]CUTCUSTAXID  = "999999990"
  [L]CUTCOMPANAM  = "Desconhecido"
  [L]CUTIADDRDET  = "Desconhecido"
  [L]CUTICITY     = "Desconhecido"
  [L]CUTIPOSTCOD  = "0000000"
  [L]CUTIREGION   = "Desconhecido"
  [L]CUTICOUNTRY  = "PT"
  [L]CDIV         = 1
  #Issue X3-90615 – 2018-06-12 by MADOR - 2018.R5 - Final customer in SAF-T file
  If [F:BPR]LEGETT = 2
    [L]CUTIPOSTCOD = "Desconhecido"
    [L]CUTICOUNTRY = "Desconhecido"
    [L]CUTCUSTOMID = "Consumidor final"
    [L]CUTCOMPANAM = "Consumidor final"

    If [L]CUTISNPSYPE = 1 : Return : Endif
    [L]CUTISNPSYPE = 1
  Endif
  #Issue X3-90615 end
Else
  [L]CUTCUSTAXID   = func SAFTGENPORTG.GETEECNUM([F:BPR]EECNUM)#t9
  #If CUTCUSTAXID  = "" : CUTCUSTAXID = "999999990" : Endif
  [L]CUTCOMPANAM   = [F:BPC]BPCNAM
  [L]CUTIADDRDET   = vireblc([F:ADC]BPAADDLIG(0) + " " + [F:ADC]BPAADDLIG(1) + " " + [F:ADC]BPAADDLIG(2), 2)
  [L]CUTICITY      = vireblc([F:ADC]CTY,2)
  [L]CUTIPOSTCOD   = vireblc([F:ADC]POSCOD,2)
  [L]CUTIREGION    = vireblc([F:ADC]SAT,2)
  [L]CUTICOUNTRY   = vireblc([F:ADC]CRY,2)
Endif

If [L]CUTCUSTAXID = "" & [F:TCY]EECFLG <> 2
  [L]CUTCUSTAXID = "999999990"
Endif

#RM - postalcode
If len([L]CUTIPOSTCOD) = 7 # & CUTICOUNTRY = 'PT'
  [L]CUTIPOSTCOD = format$("K:4#[-]3#", [L]CUTIPOSTCOD)
Endif
If [L]CUTICOUNTRY <> "PT" & [L]SAFTTYPE = 8 : Return : Endif #We only communicate when PT

[L]CUTCONTACT   = [F:AIN]CNTFULNAM
[L]CUTIBILNUM   = ""
[L]CUTISTRENAM  = ""
[L]CUTSSTRENAM  = ""
[L]CUTSADDRDET  = ""
[L]CUTSCITY     = ""
[L]CUTSPOSTCOD  = ""
[L]CUTSREGION   = ""
[L]CUTSCOUNTRY  = ""
[L]CUTTELEPHONE = [F:ADC]TEL
[L]CUTFAX       = [F:ADC]FAX
[L]CUTEMAIL     = ""
[L]CUTWEBSITE   = [F:ADC]WEB
[L]CUTSELFBILIN = 0

If [L]CUTIADDRDET   = "" : [L]CUTIADDRDET   = "Desconhecido"  : Endif
If [L]CUTICITY      = "" : [L]CUTICITY      = "Desconhecido"  : Endif
If [L]CUTIPOSTCOD   = "" : [L]CUTIPOSTCOD   = "0000-000"      : Endif
If [L]CUTIREGION    = "" : [L]CUTIREGION    = "Desconhecido"  : Endif
If [L]CUTICOUNTRY   = "" : [L]CUTICOUNTRY   = "PT"            : Endif
#Issue X3-90615 – 2018-06-12 by MADOR - 2018.R5 - Final customer in SAF-T file
If [F:BPC]BPCTYP = 2 and [F:BPR]LEGETT = 2
  [L]CUTCONTACT = ""
  [L]CUTIREGION = ""
  Gosub WRITE_CUSSIH
Else
  Gosub WRITE_CUSBPC
Endif
#Issue X3-90615 end
$NEXTCUS1

Return
#######################################################################################
#######################################################################################
$CUST_2_ITER
If GMODU(5) <> 2 : Return : Endif
#Link [F:SIV] With [F:BPR]BPR0~=[F:SIV]BPCINV, [F:SIH]SIH0~=[F:SIV]NUM, [F:FCY]FCY0~=[F:SIH]FCY, [F:TSV]TSV0~=[F:SIH]SIVTYP;[F:FCY]LEG As [BSI]
#&             Where evalue([L]FACCRITER) & [F:SIV]BPIEECNUM<>[F:BPR]EECNUM & [F:SIV]BPIEECNUM <> ""
#&             Order By toupper([F:SIV]BPIEECNUM)

Link [F:SIV] With [F:BPR]BPR0~=[F:SIV]BPCINV, [F:SIH]SIH0~=[F:SIV]NUM, [F:FCY]FCY0~=[F:SIH]FCY As [BSI]
&             Where evalue([L]FACCRITER) & [F:SIV]BPIEECNUM<>[F:BPR]EECNUM & [F:SIV]BPIEECNUM <> ""
&             Order By toupper([F:SIV]BPIEECNUM)

Local Char EECTTT(50) : [L]EECTTT = ""

For [F:BSI]
  #SAM NUM RICAR 2014/12/05 - SAFT Extraction - BEGIN
  #Triangular operations
  Gosub TRIANG_OPE From SAFTGENPORSIH
  If STAT = 0 # a triangular operation
    Goto NEXT_CUST_SI
  Endif
  #SAM NUM RICAR 2014/12/05 - SAFT Extraction - END

  If toupper([L]EECTTT) = toupper([F:SIV]BPIEECNUM)
    Goto NEXT_CUST_SI
  Endif
#  If [F:TSV]SIVTYP <> [F:SIH]SIVTYP
#    Read [F:TSV]TSV0 = [F:SIH]SIVTYP
#    If fstat : Raz [F:TSV] : Endif
#  Endif
  Call LEC_TSV_LEG([L]LEG,[F:SIH]SIVTYP,[L]STAT) From TRTLECLEG
  If [L]STAT : Raz [F:TSV] : Endif

  If [F:TSV]AUTINV = 2
    Goto NEXT_CUST_SI
  Endif

  Read [F:SAFTP]SAFTP0="SAFTPT"+[L]SOC;"D"+toupper([F:SIV]BPIEECNUM)
  If !fstat : Goto NEXT_CUST_SI : Endif

  Gosub RAZ_CUT From SAFTGENPOR
  [L]CUTCUSTOMID = "D"+toupper([F:SIV]BPIEECNUM)
  [L]CUTCACCOUID = 'Desconhecido'
  [L]CUTCUSTAXID = func SAFTGENPORTG.GETEECNUM([F:SIV]BPIEECNUM)
  [L]CUTCOMPANAM = vireblc([F:SIH]BPRNAM(0) + [F:SIH]BPRNAM(1), 2)
  [L]CUTIADDRDET = vireblc([F:SIH]BPAADDLIG(0) + " " + [F:SIH]BPAADDLIG(1) + " " + [F:SIH]BPAADDLIG(2), 2)
  [L]CUTICITY      = vireblc([F:SIH]CTY,2)
  [L]CUTIPOSTCOD = vireblc([F:SIH]POSCOD,2)
  [L]CUTIREGION    = vireblc([F:SIH]SAT,2)
  [L]CUTICOUNTRY   = vireblc([F:SIH]CRY,2)

  If len([L]CUTSPOSTCOD) = 7 & [L]CUTICOUNTRY = 'PT'
    [L]CUTSPOSTCOD = format$("K:4#[-]3#", [L]CUTSPOSTCOD)
  Endif

  If [L]CUTIADDRDET = "" : [L]CUTIADDRDET = "Desconhecido" : Endif
  If [L]CUTICITY      = "" : [L]CUTICITY      = "Desconhecido" : Endif
  If [L]CUTIPOSTCOD = "" : [L]CUTIPOSTCOD = "0000-000"     : Endif
  If [L]CUTIREGION    = "" : [L]CUTIREGION    = "Desconhecido" : Endif
  If [L]CUTICOUNTRY   = "" : [L]CUTICOUNTRY   = "PT"           : Endif

  Read [F:AIN]AIN0 = [F:SIV]CNINAM
  If !fstat
    [L]CUTCONTACT   = [F:AIN]CNTFULNAM
  Else
    [L]CUTCONTACT   = ""
  Endif
  [L]CUTIBILNUM = ""
  [L]CUTISTRENAM = ""
  [L]CUTIBILNUM = ""
  [L]CUTISTRENAM = ""

  [L]CUTIADDRDET = vireblc([F:SIV]BPDADDLIG(0) + " " + [F:SIV]BPDADDLIG(1) + " " + [F:SIV]BPDADDLIG(2), 2)
  [L]CUTSCITY     = vireblc([F:SIV]BPDCTY,2)
  [L]CUTSPOSTCOD = vireblc([F:SIV]BPDPOSCOD,2)
  [L]CUTSREGION   = vireblc([F:SIV]BPDSAT,2)
  [L]CUTSCOUNTRY  = vireblc([F:SIV]BPDCRY,2)

  If len([L]CUTSPOSTCOD) = 7 & [L]CUTICOUNTRY = 'PT'
    [L]CUTSPOSTCOD = format$("K:4#[-]3#", [L]CUTSPOSTCOD)
  Endif

  If [L]CUTIADDRDET = ""  : [L]CUTIADDRDET = "Desconhecido" : Endif
  If [L]CUTSCITY     = ""  : [L]CUTSCITY     = "Desconhecido" : Endif
  If [L]CUTSPOSTCOD = "" : [L]CUTSPOSTCOD = "0000-000"     : Endif
  If [L]CUTSREGION   = ""  : [L]CUTSREGION   = "Desconhecido" : Endif
  If [L]CUTSCOUNTRY  = ""  : [L]CUTSCOUNTRY  = "PT"           : Endif

  [L]CUTTELEPHONE = ""
  [L]CUTFAX       = ""
  [L]CUTEMAIL     = ""
  [L]CUTWEBSITE   = ""
  [L]CUTSELFBILIN = 0

  Gosub WRITE_CUSSIH

  [L]EECTTT = [F:SIV]BPIEECNUM
  $NEXT_CUST_SI
Next

Return
#######################################################################################
#######################################################################################
$CUST_3_ITER
If GMODU(5) <> 2 : Return : Endif
Gosub DECLARE_TABLES  From SAFTGENPORMG
Gosub DECLARE_VARS  From SAFTGENPORMG
Gosub ALIM_CRITER   From SAFTGENPORMG

Local Char SDHCRITER(255)

[L]SDHCRITER = "[F:PTSDH]CFMFLG=2 & [F:PTSDH]SHIDAT>=["+format$(GFMD,[L]STRDATE)+"] & [F:PTSDH]SHIDAT<=["+format$(GFMD,[L]ENDDATE)+"] & [F:PTSDH]CPY='"+[L]SOC+"'"

Link [F:PTSDH] With [F:BPR]BPR0~=[F:PTSDH]BPCORD As [BSDH]
&             Where [F:PTSDH]BPIEECNUM <> [F:BPR]EECNUM & [F:PTSDH]BPIEECNUM <> ""
&             & evalue([L]SDHCRITER) & evalue([L]CRITSDH) & evalue([L]SPECRITSDH)
&             Order By toupper([F:PTSDH]BPIEECNUM)

Local Char EECTTT : [L]EECTTT = ""

For [F:BSDH]
  If toupper([L]EECTTT) = toupper([F:PTSDH]BPIEECNUM)
    Goto NEXT_CUST_SD
  Endif

  [F:SAFTP]COD    = "SAFTPT"+[L]SOC
  [F:SAFTP]EECNUM = "D"+toupper([F:PTSDH]BPIEECNUM)
  Write [F:SAFTP]

  Gosub RAZ_CUT From SAFTGENPOR
  [L]CUTCUSTOMID   = "D"+toupper([F:PTSDH]BPIEECNUM)
  [L]CUTCACCOUID   = 'Desconhecido'
  [L]CUTCUSTAXID   = func SAFTGENPORTG.GETEECNUM([F:PTSDH]BPIEECNUM)#t9
  [L]CUTCOMPANAM   = vireblc([F:PTSDH]BPINAM(0) + [F:PTSDH]BPINAM(1), 2)
  [L]CUTIADDRDET   = vireblc([F:PTSDH]BPIADDLIG(0) + " " + [F:PTSDH]BPIADDLIG(1) + " " + [F:PTSDH]BPIADDLIG(2), 2)
  [L]CUTICITY      = vireblc([F:PTSDH]BPICTY,2)
  [L]CUTIPOSTCOD   = vireblc([F:PTSDH]BPIPOSCOD,2)
  [L]CUTIREGION    = vireblc([F:PTSDH]BPISAT,2)
  [L]CUTICOUNTRY   = vireblc([F:PTSDH]BPICRY,2)

  If [L]CUTIADDRDET = ""  : [L]CUTIADDRDET  = "Desconhecido" : Endif
  If [L]CUTICITY    = ""  : [L]CUTICITY     = "Desconhecido" : Endif
  If [L]CUTIPOSTCOD = ""  : [L]CUTIPOSTCOD  = "0000-000"     : Endif
  If [L]CUTIREGION  = ""  : [L]CUTIREGION   = "Desconhecido" : Endif
  If [L]CUTICOUNTRY = ""  : [L]CUTICOUNTRY  = "PT"           : Endif

  If len([L]CUTIPOSTCOD) = 7 #& [L]CUTICOUNTRY = 'PT'
    [L]CUTIPOSTCOD = format$("K:4#[-]3#", [L]CUTIPOSTCOD)
  Endif

  Read [F:AIN]AIN0 = [F:PTSDH]CNINAM
  If !fstat
    [L]CUTCONTACT   = [F:AIN]CNTFULNAM
  Else
    [L]CUTCONTACT   = ""
  Endif
  [L]CUTIBILNUM = ""
  [L]CUTISTRENAM = ""
  [L]CUTIBILNUM = ""
  [L]CUTISTRENAM = ""

  [L]CUTSADDRDET   = vireblc([F:PTSDH]BPDADDLIG(0) + " " + [F:PTSDH]BPDADDLIG(1) + " " + [F:PTSDH]BPDADDLIG(2), 2)
  [L]CUTSCITY      = vireblc([F:PTSDH]BPDCTY,2)
  [L]CUTSPOSTCOD   = vireblc([F:PTSDH]BPDPOSCOD,2)
  [L]CUTSREGION    = vireblc([F:PTSDH]BPDSAT,2)
  [L]CUTSCOUNTRY   = vireblc([F:PTSDH]BPDCRY,2)

  If [L]CUTSADDRDET   = ""  : [L]CUTSADDRDET   = "Desconhecido" : Endif
  If [L]CUTSCITY      = ""  : [L]CUTSCITY      = "Desconhecido" : Endif
  If [L]CUTSPOSTCOD   = ""  : [L]CUTSPOSTCOD   = "0000-000"     : Endif
  If [L]CUTSREGION    = ""  : [L]CUTSREGION    = "Desconhecido" : Endif
  If [L]CUTSCOUNTRY   = ""  : [L]CUTSCOUNTRY   = "PT"           : Endif

  If len([L]CUTSPOSTCOD) = 7 #& [L]CUTICOUNTRY = 'PT'
    [L]CUTSPOSTCOD = format$("K:4#[-]3#", [L]CUTSPOSTCOD)
  Endif

  [L]CUTTELEPHONE = ""
  [L]CUTFAX       = ""
  [L]CUTEMAIL     = ""
  [L]CUTWEBSITE   = ""
  [L]CUTSELFBILIN = 0

  Gosub WRITE_CUSSIH

  $NEXT_CUST_SD
  [L]EECTTT = [F:PTSDH]BPIEECNUM
Next

Return
#######################################################################################
#######################################################################################
$CUST_4_ITER

If GMODU(5) <> 2 : Return : Endif

Link [F:SIH] With [F:BPR]BPR0~=[F:SIH]BPR, [F:FCY]FCY0~=[F:SIH]FCY As [BBI]
&             Where evalue([L]FACCRITER) & [F:SIH]DCLEECNUM<>[F:BPR]EECNUM & [F:SIH]DCLEECNUM <> ""
&             Order By toupper([F:SIH]DCLEECNUM)

Local Char EECTTT(50) : [L]EECTTT = ""

For [F:BBI]

  Gosub TRIANG_OPE From SAFTGENPORSIH
  If STAT = 0 # a triangular operation
     Goto NEXT_CUST_BI
  Endif

  If toupper([L]EECTTT) = toupper([F:SIH]DCLEECNUM)
    Goto NEXT_CUST_BI
  Endif

  Call LEC_TSV_LEG([L]LEG,[F:SIH]SIVTYP,[L]STAT) From TRTLECLEG
  If [L]STAT : Raz [F:TSV] : Endif

  If [F:TSV]AUTINV = 2
    Goto NEXT_CUST_BI
  Endif

  Read [F:SAFTP]SAFTP0="SAFTPT"+[L]SOC;"D"+toupper([F:SIH]DCLEECNUM)
  If !fstat : Goto NEXT_CUST_BI : Endif

  Gosub RAZ_CUT From SAFTGENPOR
  [L]CUTCUSTOMID = "D"+toupper([F:SIH]DCLEECNUM)
  [L]CUTCACCOUID = 'Desconhecido'
  [L]CUTCUSTAXID = func SAFTGENPORTG.GETEECNUM([F:SIH]DCLEECNUM)
  [L]CUTCOMPANAM = vireblc([F:SIH]BPRNAM(0) + [F:SIH]BPRNAM(1), 2)
  [L]CUTIADDRDET = vireblc([F:SIH]BPAADDLIG(0) + " " + [F:SIH]BPAADDLIG(1) + " " + [F:SIH]BPAADDLIG(2), 2)
  [L]CUTICITY      = vireblc([F:SIH]CTY,2)
  [L]CUTIPOSTCOD = vireblc([F:SIH]POSCOD,2)
  [L]CUTIREGION    = vireblc([F:SIH]SAT,2)
  [L]CUTICOUNTRY   = vireblc([F:SIH]CRY,2)

  If len([L]CUTSPOSTCOD) = 7 & [L]CUTICOUNTRY = 'PT'
    [L]CUTSPOSTCOD = format$("K:4#[-]3#", [L]CUTSPOSTCOD)
  Endif

  If [L]CUTIADDRDET = "" : [L]CUTIADDRDET = "Desconhecido" : Endif
  If [L]CUTICITY    = "" : [L]CUTICITY    = "Desconhecido" : Endif
  If [L]CUTIPOSTCOD = "" : [L]CUTIPOSTCOD = "0000-000"     : Endif
  If [L]CUTIREGION  = "" : [L]CUTIREGION  = "Desconhecido" : Endif
  If [L]CUTICOUNTRY = "" : [L]CUTICOUNTRY = "PT"           : Endif


  [L]CUTCONTACT  = ""
  [L]CUTIBILNUM  = ""
  [L]CUTISTRENAM = ""
  [L]CUTIBILNUM  = ""
  [L]CUTISTRENAM = ""

  [L]CUTIADDRDET = vireblc([F:SIH]BPAADDLIG(0) + " " + [F:SIH]BPAADDLIG(1) + " " + [F:SIH]BPAADDLIG(2), 2)
  [L]CUTSCITY    = vireblc([F:SIH]BPYCTY,2)
  [L]CUTSPOSTCOD = vireblc([F:SIH]BPYPOSCOD,2)
  [L]CUTSREGION  = vireblc([F:SIH]BPYSAT,2)
  [L]CUTSCOUNTRY = vireblc([F:SIH]BPYCRY,2)

  If len([L]CUTSPOSTCOD) = 7 & [L]CUTICOUNTRY = 'PT'
    [L]CUTSPOSTCOD = format$("K:4#[-]3#", [L]CUTSPOSTCOD)
  Endif

  If [L]CUTIADDRDET = ""  : [L]CUTIADDRDET = "Desconhecido" : Endif
  If [L]CUTSCITY    = ""  : [L]CUTSCITY    = "Desconhecido" : Endif
  If [L]CUTSPOSTCOD = ""  : [L]CUTSPOSTCOD = "0000-000"     : Endif
  If [L]CUTSREGION  = ""  : [L]CUTSREGION  = "Desconhecido" : Endif
  If [L]CUTSCOUNTRY = ""  : [L]CUTSCOUNTRY = "PT"           : Endif

  [L]CUTTELEPHONE = ""
  [L]CUTFAX       = ""
  [L]CUTEMAIL     = ""
  [L]CUTWEBSITE   = ""
  [L]CUTSELFBILIN = 0

  Gosub WRITE_CUSSIH

  [L]EECTTT = [F:SIH]DCLEECNUM
  $NEXT_CUST_BI
Next
Return
#######################################################################################
#######################################################################################
$FEED_BPCCPY
Gosub DECLARE_TABLES  From SAFTGENPORMG
Gosub DEC_COMDT_CRITS From SAFTGENPORMG
Gosub ALIM_CRITER     From SAFTGENPORMG

For [F:PTCP2]
 For [F:PTFC2] Where [F:PTFC2]LEGCPY = [F:PTCP2]CPY
    If [L]SAFTTYPE = 8
      Link [F:PTDK2] With [F:PTSGH]SGH0~=[F:PTDK2]DOCNUM,[F:FCY]FCY0=[F:PTSGH]STOFCY As [MG3]
&     Where [F:PTSGH]CFMFLG=2 & [F:PTSGH]IPTDAT>=[L]STRDATE & [F:PTSGH]IPTDAT<=[L]ENDDATE & [F:FCY]LEGCPY=[L]SOC &
&     [F:PTSGH]BETFCYCOD=2 & [F:PTSGH]FCYDES=[F:PTFC2]FCY & evalue([L]CRITSGH) & evalue([L]SPECRITSGH)
    Else
      Link [F:PTSGH] With [F:FCY]FCY0=[F:PTSGH]STOFCY As [MG3]
&     Where [F:PTSGH]CFMFLG=2 & [F:PTSGH]IPTDAT>=[L]STRDATE & [F:PTSGH]IPTDAT<=[L]ENDDATE & [F:FCY]LEGCPY=[L]SOC &
&     [F:PTSGH]BETFCYCOD=2 & [F:PTSGH]FCYDES=[F:PTFC2]FCY & evalue([L]CRITSGH)& evalue([L]SPECRITSGH)
    Endif
    Read [MG3] First
    If !fstat
      [L]CUTCUSTOMID = [F:PTCP2]CPY
      [L]CUTCACCOUID = 'Desconhecido'
      [L]CUTCUSTAXID = func SAFTGENPORTG.GETEECNUM([F:PTCP2]EECNUM)
      [L]CUTCOMPANAM = [F:PTCP2]CPYNAM
      [L]CUTCONTACT  = ''

      [L]CUTTELEPHONE = ""
      [L]CUTFAX       = ""
      [L]CUTEMAIL     = ""
      [L]CUTSELFBILIN = 0

      If !clalev([F:BPA])  : Local File BPADDRESS   [BPA] : Endif
      Read [F:BPA]BPA0=2;[F:PTCP2]CPY;[F:PTCP2]BPAADD
      If !fstat
        [L]CUTIADDRDET = vireblc([F:BPA]BPAADDLIG(0)-[F:BPA]BPAADDLIG(1)-[F:BPA]BPAADDLIG(2),2)
        [L]CUTICITY      = vireblc([F:BPA]CTY,2)
        [L]CUTIPOSTCOD = vireblc([F:BPA]POSCOD,2)
        [L]CUTIREGION    = "Desconhecido"
        [L]CUTICOUNTRY   = vireblc([F:BPA]CRY,2)
      Else
        [L]CUTIADDRDET = "Desconhecido"
        [L]CUTICITY     = "Desconhecido"
        [L]CUTIPOSTCOD = "0000-000"
        [L]CUTIREGION   =  "Desconhecido"
        [L]CUTICOUNTRY  =  "PT"
      Endif

      #Can't be empty
      If [L]CUTIADDRDET = "" : [L]CUTIADDRDET = "Desconhecido" : Endif
      If [L]CUTICITY     = "" : [L]CUTICITY     = "Desconhecido" : Endif
      If [L]CUTIPOSTCOD = "" : [L]CUTIPOSTCOD = "0000-000"     : Endif
      If [L]CUTIREGION   = ""  : [L]CUTIREGION   = "Desconhecido" : Endif
      If [L]CUTICOUNTRY  = ""  : [L]CUTICOUNTRY  =  "PT"           : Endif

      If len([L]CUTIPOSTCOD) = 7 & [L]CUTICOUNTRY = 'PT'
        [L]CUTIPOSTCOD = format$("K:4#[-]3#", [L]CUTIPOSTCOD)
      Endif

      Gosub WRITE_CUSBPC
      Break
    Endif
  Next
Next
Close File [F:MG3]

Return
#######################################################################################
#######################################################################################
$WRITE_CUSBPC

Wrseq '<Customer>' Using [SAFT]
AUXTAGNAM = 'CustomerID'           : AUXTAGVAL = [L]CUTCUSTOMID : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'AccountID'            : AUXTAGVAL = [L]CUTCACCOUID : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'CustomerTaxID'        : AUXTAGVAL = [L]CUTCUSTAXID : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'CompanyName'          : AUXTAGVAL = [L]CUTCOMPANAM : Gosub WRITETAG From SAFTGENPORTG
If [L]CUTCONTACT <> "" : AUXTAGNAM = 'Contact'              : AUXTAGVAL = [L]CUTCONTACT   : Gosub WRITETAG From SAFTGENPORTG : Endif
Wrseq '<BillingAddress>' Using [SAFT]
AUXTAGNAM = 'AddressDetail'        : AUXTAGVAL = [L]CUTIADDRDET : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'City'                 : AUXTAGVAL = [L]CUTICITY      : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'PostalCode'           : AUXTAGVAL = [L]CUTIPOSTCOD : Gosub WRITETAG From SAFTGENPORTG
If CUTIREGION <> "" : AUXTAGNAM = 'Region'     : AUXTAGVAL = [L]CUTIREGION    : Gosub WRITETAG From SAFTGENPORTG : Endif
AUXTAGNAM = 'Country'              : AUXTAGVAL = [L]CUTICOUNTRY   : Gosub WRITETAG From SAFTGENPORTG
Wrseq '</BillingAddress>' Using [SAFT]
If [L]CUTTELEPHONE<>"" : AUXTAGNAM = 'Telephone' : AUXTAGVAL = [L]CUTTELEPHONE : Gosub WRITETAG From SAFTGENPORTG : Endif
If [L]CUTFAX<>""       : AUXTAGNAM = 'Fax'       : AUXTAGVAL = [L]CUTFAX       : Gosub WRITETAG From SAFTGENPORTG : Endif
If [L]CUTWEBSITE<>""   : AUXTAGNAM = 'Website'   : AUXTAGVAL = [L]CUTWEBSITE   : Gosub WRITETAG From SAFTGENPORTG : Endif
AUXTAGNAM = 'SelfBillingIndicator' : AUXTAGVAL = num$([L]CUTSELFBILIN) : Gosub WRITETAG From SAFTGENPORTG
Wrseq '</Customer>' Using [SAFT]
[L]RECSWRI += 1

Return
#######################################################################################
#######################################################################################
$WRITE_CUSSIH

Wrseq '<Customer>' Using [SAFT]
AUXTAGNAM = 'CustomerID'           : AUXTAGVAL = [L]CUTCUSTOMID : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'AccountID'            : AUXTAGVAL = [L]CUTCACCOUID : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'CustomerTaxID'        : AUXTAGVAL = [L]CUTCUSTAXID : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'CompanyName'          : AUXTAGVAL = [L]CUTCOMPANAM : Gosub WRITETAG From SAFTGENPORTG
If [L]CUTCONTACT <> "" : AUXTAGNAM = 'Contact'  : AUXTAGVAL = [L]CUTCONTACT   : Gosub WRITETAG From SAFTGENPORTG : Endif
Wrseq '<BillingAddress>' Using [SAFT]
AUXTAGNAM = 'AddressDetail'        : AUXTAGVAL = [L]CUTIADDRDET : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'City'                 : AUXTAGVAL = [L]CUTICITY      : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'PostalCode'           : AUXTAGVAL = [L]CUTIPOSTCOD : Gosub WRITETAG From SAFTGENPORTG
If [L]CUTIREGION <> "" : AUXTAGNAM = 'Region'  : AUXTAGVAL = [L]CUTIREGION    : Gosub WRITETAG From SAFTGENPORTG : Endif
AUXTAGNAM = 'Country'              : AUXTAGVAL = [L]CUTICOUNTRY   : Gosub WRITETAG From SAFTGENPORTG
Wrseq '</BillingAddress>' Using [SAFT]
Wrseq '<ShipToAddress>' Using [SAFT]
AUXTAGNAM = 'AddressDetail'        : AUXTAGVAL = [L]CUTIADDRDET : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'City'                 : AUXTAGVAL = [L]CUTICITY      : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'PostalCode'           : AUXTAGVAL = [L]CUTIPOSTCOD : Gosub WRITETAG From SAFTGENPORTG
If [L]CUTIREGION <> "" : AUXTAGNAM = 'Region'   : AUXTAGVAL = [L]CUTIREGION    : Gosub WRITETAG From SAFTGENPORTG : Endif
AUXTAGNAM = 'Country'              : AUXTAGVAL = [L]CUTICOUNTRY   : Gosub WRITETAG From SAFTGENPORTG
Wrseq '</ShipToAddress>' Using [SAFT]
AUXTAGNAM = 'SelfBillingIndicator' : AUXTAGVAL = num$([L]CUTSELFBILIN) : Gosub WRITETAG From SAFTGENPORTG
Wrseq '</Customer>' Using [SAFT]
[L]RECSWRI += 1

Return

