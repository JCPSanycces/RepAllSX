#<AdxTL>@(#)0.0.0.0 $Revision$ 
Subprog DEBUG_TRACE(LEVEL, CODE, MSG)
Value Integer LEVEL
Value Char CODE
Value Char MSG

  Local Integer RETVAL
  Local Char WEBSERNAME (50)
  Local Char HTTPMETHOD (10)
  Local Char SUBURL(255)
  Local Char PCOD(100)(1..10)
  Local Char PVAL(100)(1..10)
  Local Char HCOD(100)(1..10)
  Local Char HVAL(100)(1..10)
  Local Clbfile TXTDATA(0), CSVDATA(0)
  Local Clbfile RESHEAD(0), RESBODY(0)
  Local Integer MAXTEXT, MAXCOUNTER
  Local Char WRES(20),WMES(250),WDOS(30)
  Local Integer WI,I
  Local Integer RET
  MAXTEXT = 250
  Local Char W_MESS(MAXTEXT)
  MAXCOUNTER = MAXTEXT
  Local Char DOSSIER(250) : DOSSIER = nomap
  Local Char USER(250)

  WEBSERNAME = "TraceLogger"
  HTTPMETHOD = "POST"
  SUBURL = "/trace/log"

  HCOD(1)= "Content-Type"
  HVAL(1)= '"application/json"'

  Local Integer TRACE
  Onerrgo ERR
    If clalev([F:AUS])=0 Local File AUTILIS [AUS] : Endif

    Read [AUS]LOGIN = toupper(adxusr)
    If !fstat
      USER = [F:AUS]USR
    Endif

    CSVDATA = '{"server":"'+num$(DOSSIER)+'","user":"'+num$(USER)+'","code":"'+CODE+'","level":'+num$(LEVEL)+',"message":"'+MSG+'"}'

    RETVAL=func ASYRRESTCLI.EXEC_REST_WS(WEBSERNAME, HTTPMETHOD, SUBURL, PCOD,PVAL,HCOD,HVAL, CSVDATA, 0, "", RESHEAD, RESBODY)
    If TRACE = 0
#      Infbox num$([L]RETVAL)-[L]RESBODY-[L]RESHEAD
    Endif
  TRACE = 0

End

$ERR
  TRACE = 1
#  Infbox "Error: " + num$(errn)-errmes$(errn)-errm
Resume







