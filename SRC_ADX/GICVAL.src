#<AdxTL>@(#)8.0.0.0 $Revision$
# Issue X3-107197 - 2018-09-12 by CBO : PARAMETER AND ACTIVITY CODE
#*X3-39795   MDJ  Manage ORIGIN and ORICOD fields in GL Entry
$ACTION
Case GACTION
 When "GICVAL"
  Case ACTION
   When "CONTROLE"    : Gosub CONTROLE
   When "EXEC"        : Gosub EXEC
  Endcase
 When "GASGICZOOM"
  Case ACTION
   When "SEL_LISTE" : Gosub SEL_LISTE
   When "FIN_LISTE" : Gosub FIN_LISTE
 Endcase
Endcase
Return


$CONTROLE
Local Integer OK
MESSA = mess(332,107,1)-[M]NUM
OK=2 : Call OUINON(MESSA,OK) From GESECRAN
If OK=2
 TMP = 1
Else
 FIN=1
Endif
# Issue X3-58865 - 2017-10-18 by VAVIL : Control GESGIC function for POR legislation
# Issue X3-58865
If clalev([F:GID])=0   : Local File GACCINTCPYD  [GID] : Endif
Local Char LASTCPY : [L]LASTCPY = ""
Local Tinyint LTYPGEN, LTYPANA
For [F:GID]GID0 Where [F:GID]NUM = [F:GIC]NUM
  If [L]LASTCPY <> [F:GID]CPYLIN
    If func PORLEGLIB.DIGSIGN("", [F:GID]CPYLIN)
      If !func PORLEGLIB.CREGASOK([F:GID]JOULIN, "", GMESSAGE)
        Call ECR_TRACE(GMESSAGE - "(" + mess(2,45,1) - [F:GID]CPYLIN + ")", 1) From GESECRAN
        FIN = 1 :  Break
      Endif
    Endif
  Endif
  [L]LASTCPY = [F:GID]CPYLIN
  #Issue X3-76846 by MRDAB
  If (func AFNC.ACTIV("FIFRC") & [F:GIC]NUM <> '')
    If (func AFNC.PARAM("FIFRC", [F:GID]FCYLIN) = "2")
      Call SETMAINREF([F:GID]CPYLIN, [L]LTYPGEN, [L]LTYPANA) From CPTDIV
      If (func FIFOCONVAR_CSTD.IS_ACC_ASSIGNED_TO_FIFO_BANK([F:GID]ACC([L]LTYPGEN - 1)) = 0) and
&        (func FIFOCONVAR_CSTD.DOES_FIFO_EXIST_FOR_ACC_CPY_DATE([F:GID]ACC([L]LTYPGEN - 1), [F:GID]CPYLIN, [F:GIC]ACCDAT) = 0)
        If ([F:GID]LEDTYP = [L]LTYPGEN)
          Call ECR_TRACE([F:GID]TYPLIN - [F:GIC]NUM - [F:GID]CPYLIN + ":" - mess(12,7708,1), 1) From GESECRAN
          FIN = 1 :  Break
        Endif
      Endif
    Endif
  Endif
  #Issue end X3-76846
Next
# End issue X3-58865
Return

$EXEC
Call OUVRE_TRACE(mess(332,107,1)-":"-[M]NUM) From LECFIC
Call VALID([M]NUM)
Call FERME_TRACE From LECFIC
If GOK = 1  : TRA=1
Elsif GOK<1 : TRA=1 : FIN = 1
Endif
Return


############################################
## Journals Zoom in GESGIC                ##
############################################
$SEL_LISTE

Onerrgo ERREUR From CONTROLE
If clalev([F:ICF])=0  : Local File INTCOFLO     [ICF]  : Endif
If clalev([F:HAE2])=0 : Local File GACCENTRY   [HAE2]  : Endif
Onerrgo
If GERREUR : GERREUR=0 : OK=0 : Return : Endif

NBTEX = 0
For [ICF]ICF0 Where ABRFIC="GIC" & NUM = PARAM(1) & FCYTGR=""
 Read [HAE2]HAE0 = [F:ICF]TYPVCR;[F:ICF]NUMVCR
 If fstat=0
  NBTEX += 1
  TEX(NBTEX) = [F:HAE2]TYP-[F:HAE2]NUM
 Endif
Next
Return

$AVANT_SUITE

If status = 7 : OK = 0 : Return : Endif
I=instr(1,VALBOUT," ")
If I
 [L]VALC1="GAS" : [L]VALC3=left$(VALBOUT,I-1) : [L]VALC2=right$(VALBOUT,I+1)
 GCONSULT=1
Endif
Return


$FIN_LISTE
Return


#########################################################################################################
# Intercompany GL Posting
#########################################################################################################
Subprog VALID(NUM)
Value Char NUM()

If clalev([F:ICF])=0   : Local File INTCOFLO  [ICF] : Endif
If clalev([F:HAE])=0   : Local File GACCENTRY [HAE] : Endif
If clalev([F:HA2])=0   : Local File GACCENTRY [HA2] : Endif

Local Integer I, OK, STAT
Local Integer NBJOU
Local Char    MESSA(250), IDENT(30), CODGAU(GLONGAU)
#*X3-39795 Local Char    TZONE(10)(1..6)
#*X3-39795 Local Char    TVAL(30)(1..6)
Local Char    TZONE(10)(1..10)     : # Table of the zones to be forced (Ex: ORICOD)   #*X3-39795
Local Char    TVAL(30)(1..10)      : # Table of values for zones to be forced         #*X3-39795
Local Char    TJOUCPY(GLONCPY)(1..99), TJOUNUM(30)(1..99)

IDENT = NUM

If adxtrans
 Gosub TRANSAC
Else
 Call DEBTRANS From GLOCK
 Gosub TR1
Endif
End

$TR1
GOK = 1
Trbegin [GIC]
 Gosub TRANSAC
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$TRANSAC

Readlock [GIC]GIC0 = NUM
If fstat=1
 GOK=-1 : GLOCK="$GACCINTCPY"-NUM : Return
Elsif fstat
 GOK=0 : Call RSTA("GIC",NUM) From GLOCK : Return
Endif

Call GETSOC([F:GIC]FCY) From DEVSUB

## Note : The template journal can be posted
##           - Through the <Post> Button. In that case, the validation will be done in Real Mode, but the template
##             might be posted previously in Simulation Mode through the Mass Validation Function (CPTINTCPY)
##           - Through the Mass Validation Function (CPTINTCPY). In that case, the validation will be done in Real or Simulation Mode,
##             according to the criteria entered by the user

If [F:GIC]FLGPST=2
 Gosub DELSIM
 If GOK<1 : Return : Endif
Endif

## The automatic journal that will be trigerred will be the one defined in the GAUGIC Parameter for the source company
CODGAU = ""
If func AFNC.ACTIV("INTCO")   # Issue X3-107197
Call PARAML(GSOCIETE,"GAUGIC",CODGAU) From ADOVAL
Endif   # Issue X3-107197
If CODGAU="" : CODGAU = "GLCO" : Endif

Raz NBJOU, TJOUNUM, TJOUCPY
For [ICF]ICF0 Where ABRFIC="GIC" & NUM=[F:GIC]NUM & CPYSRC=[F:GIC]CPY & FCYTGR=""
 GSOCIETE = [F:ICF]CPYTGR
 TZONE(1)="TYP"    : TVAL(1)=[F:ICF]TYPVCR
 TZONE(2)="JOU"    : TVAL(2)=[F:ICF]JOUVCR
 TZONE(3)="NUM"    : TVAL(3)=[F:ICF]NUMVCR
 Case GFONCTION
  When "CPTINTCPY"
   If [M:DIA]TYP=1
    TZONE(4) = "REFSIM" : TVAL(4) = ""
   Else
    TZONE(4) = "REFSIM" : TVAL(4) = "GIC"+[F:GIC]NUM
   Endif
   TZONE(5) = "CAT"     : TVAL(5) = num$([M:DIA]TYP)
   TZONE(6) = "STA"     : TVAL(6) = num$([M:DIA]STA)
   If [M:DIA]TYP = 1 & func AFNC.PARAM("FRADGI",GSOCIETE)="2"
    TZONE(6) = "STA" : TVAL(6) = num$(2)
   Elsif [M:DIA]TYP <> 1
    TZONE(6) = "STA" : TVAL(6) = num$(1)
   Endif
  When Default
   TZONE(4) = "REFSIM" : TVAL(4) = ""
   TZONE(5) = "CAT"    : TVAL(5) = num$(1)
   If func AFNC.PARAM("FRADGI",GSOCIETE)="2"
    TZONE(6) = "STA" : TVAL(6) = num$(2)
   Else
    Raz TZONE(6)
    Raz TVAL(6)
   Endif
 Endcase
 TZONE(7) = "ORIGIN" : TVAL(7) = "2"        :#Automatic loading  #*X3-39795
 TZONE(8) = "ORICOD" : TVAL(8) = CODGAU                          #*X3-39795
 Call VALPCE3(CODGAU,IDENT,STAT,MESSA,TZONE,TVAL) From CPTAUTO
 If STAT
  GOK = 0
  If GACESIMTRC=1 | MESSA<>"" : Call ECR_TRACE(MESSA-"("+mess(2,45,1)-GSOCIETE+")",1) From GESECRAN : Endif
  Break
 Else
  [F:ICF]NUMVCR = MESSA
  NBJOU += 1
  TJOUNUM(NBJOU) =  MESSA
  TJOUCPY(NBJOU) =  GSOCIETE
  Rewrite [ICF]
  If fstat
   GOK=0 : Call FSTA("ICF") From GLOCK : Break
  Endif
 Endif
Next
Call GETSOC([F:GIC]FCY) From DEVSUB
If GOK<1 : Return : Endif

If (GFONCTION<>"CPTINTCPY") | (GFONCTION="CPTINTCPY" & [M:DIA]TYP=1)
 [F:GIC]FLGPST = 3
Elsif GFONCTION="CPTINTCPY" & [M:DIA]TYP>1
 [F:GIC]FLGPST = 2
Endif
Rewrite [GIC]
If fstat
 GOK = 0 : Call FSTA("GIC") From GLOCK : Return
Endif

For J=1 To NBJOU
 If GTRACE<>""
  Call ECR_TRACE(mess(40,107,1)-":"-TJOUNUM(J)-"("+TJOUCPY(J)+")",0) From GESECRAN
 Endif
Next
Return


$DELSIM
GOK=1
For [HA2]HAE2 Where REFSIM="GIC"+[F:GIC]NUM
 Call ECR_TRACE(mess(16,107,1)-[F:HA2]TYP-[F:HA2]NUM,0) From GESECRAN
 Call DELPCE([F:HA2]TYP,[F:HA2]NUM) From CPTBATCH
 If GOK<1 : Break : Endif
Next
Return


$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

