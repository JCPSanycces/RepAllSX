#Endcase
Return

$METHODS
  Case [L]CURPTH
    When ""
      Case [L]AMETHOD
      Endcase
  Endcase
Return


$PROPERTIES
  Case [L]CURPRO
    When "PHYELTIVY" : Gosub PHYELTIVY
    When "PHYELTTOT" : Gosub PHYELTTOT
  Endcase
Return


# Physical assets of this location registered
$PHYELTIVY
  Case ARULE
    When "GET"  : Gosub PHYELTIVY_GET
    When Default
  Endcase
Return

$PHYELTIVY_GET
  Local Integer RET
  RET = func PHYELT_C_MPR._GET_BUI_PHY_NBR(this.BUI.BUICOD, this.PHYELTTOT, this.PHYELTIVY)
Return

# Physical assets of this location
$PHYELTTOT
