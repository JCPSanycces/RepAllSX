#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
 When Default
Endcase
Return


$OUVRE
#  If PARAM(1) = "" and PARAM(2) = ""
#    PARAM(1) = "CDE-2015-5015"
#    PARAM(2) = "4"
#  Endif

  If PARAM(1) <> "" and PARAM(2) <> ""
    [M:EDK1]DOCID     = PARAM(1)
    [M:EDK1]CATTYP    = val(PARAM(2))
    [M:EDK1]CATACTFLT = func GET_EDI_CATACT([M:EDK1]DOCID, [M:EDK1]CATTYP)
  Endif
Return

$LECTURE

  #-- critères obligatoires (section facultative)
  If [M:EDK1]DOCID = ""
    NBLU = 0
    Return
  Endif

  Gosub CHANGE_MSK From GCONSULT
  If CHGPAG<0 : NOL = MAXLIG : Endif

  Local Char    WDOCID(100)   : WDOCID        = [M:EDK1]DOCID
  Local Integer WCATTYP       : WCATTYP       = [M:EDK1]CATTYP
  Local Integer WCATACTFILTER : WCATACTFILTER = [M:EDK1]CATACTFLT

  #-- Positionnement des Filtres
  Gosub LOAD_FILTER

  #-- Application des Filtres et tri des enregistrements
  If CHGPAG > 0
     SUITE=1
     If CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
      If WCATACTFILTER = 1 or WCATACTFILTER = 2
        Link [EDK] With [EDR]EDR0 = [EDK]NUM As [LIEN] Where [EDK]DOCID = WDOCID and [EDK]TRKSTA = 3 and [EDK]TESTFLG = 1 and [EDK]CATTYP = WCATTYP and [EDK]CATACT = WCATACTFILTER and evalue(WFIL)
& Order By [EDK]NUMLIN
& Desc #RUNDATE Desc
      Else
        Link [EDK] With [EDR]EDR0 = [EDK]NUM As [LIEN] Where [EDK]DOCID = WDOCID and [EDK]TRKSTA = 3 and [EDK]TESTFLG = 1 and [EDK]CATTYP = WCATTYP and evalue(WFIL) Order By [EDK]NUMLIN Desc #RUNDATE
# Desc
      Endif
  Else
     RETOUR=1
     If CHGPAG = -1 : SUITE = 1 : Else SUITE = 2 : Endif
      If WCATACTFILTER = 1 or WCATACTFILTER = 2
        Link [EDK] With [EDR]EDR0 = [EDK]NUM As [LIEN] Where [EDK]DOCID = WDOCID and [EDK]TRKSTA = 3 and [EDK]TESTFLG = 1 and [EDK]CATTYP = WCATTYP and [EDK]CATACT = WCATACTFILTER and evalue(WFIL)
& Order By [EDK]NUMLIN
& Asc #RUNDATE Asc
      Else
        Link [EDK] With [EDR]EDR0 = [EDK]NUM As [LIEN] Where [EDK]DOCID = WDOCID and [EDK]TRKSTA = 3 and [EDK]TESTFLG = 1 and [EDK]CATTYP = WCATTYP and evalue(WFIL) Order By [EDK]NUMLIN Asc #RUNDATE
# Asc
      Endif
  Endif

  #-- raz du masque si 1ere ou dernière page
  If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:EDK2] : Endif

  Gosub BOUCLE

Return


$BOUCLE
  If WDOCID <> "" and WCATTYP <> 0 and WCATACTFILTER <> 0
    For [LIEN]

      If NBLU = 1
        If CHGPAG=2 | CHGPAG=-2 : Raz [M:EDK2] : Endif
        NBLU = 2
      Endif

      #-- stockage des bornes début et fin d'enregistrement pour l'écran
      If CHGPAG > 0
        If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
        NOL += 1
        If NOL=0
          DEBNUM = [F:EDK]NUMLIN
        Endif
        FINNUM = [F:EDK]NUMLIN
      Else
        If NOL <= 0 : RETOUR=2 : Break : Endif
        NOL -= 1
        If NOL=MAXLIG-1
          FINNUM = [F:EDK]NUMLIN
        Endif
        DEBNUM = [F:EDK]NUMLIN
      Endif

      nolign = NOL+1
      [M:EDK2]BPAADD(nolign-1)    = [EDK]BPAADD
      [M:EDK2]BPRNUM(nolign-1)    = [EDK]BPRNUM
      [M:EDK2]CATACT(nolign-1)    = [EDK]CATACT
      [M:EDK2]CATCOD(nolign-1)    = [EDK]CATCOD
      [M:EDK2]CPY(nolign-1)       = [EDK]CPY
      [M:EDK2]DUPLICATE(nolign-1) = [EDK]DUPLICATE
      [M:EDK2]EXTID(nolign-1)     = [EDK]EXTID
      [M:EDK2]FCY(nolign-1)       = [EDK]FCY
      [M:EDK2]FLOCOD(nolign-1)    = [EDK]FLOCOD
      [M:EDK2]FLOREL(nolign-1)    = [EDK]FLOREL
      [M:EDK2]NUM(nolign-1)       = [EDK]NUM
      [M:EDK2]NUMBATCH(nolign-1)  = [EDK]NUMBATCH
#      [M:EDK2]NUMLIN(nolign-1)    = [EDK]NUMLIN
      [M:EDK2]PTCCOD(nolign-1)    = [EDK]PTCCOD
      [M:EDK2]RUNDATE(nolign-1)   = num$([EDK]RUNDATE)
      [M:EDK2]TRKSTA(nolign-1)    = [EDK]TRKSTA
      [M:EDK2]PARCOD(nolign-1)    = [EDR]PARCOD
    Next
    Filter [EDK]
  Endif

Return


#--- Préparation du filtre #
$LOAD_FILTER
  WFIL = "1=1"
  Case CHGPAG
    When 3 : # rafraichissement
      WFIL += "&[EDK]NUMLIN<=DEBNUM"
    When 2 : # suite
      WFIL += "&[EDK]NUMLIN<FINNUM"
    When -2 : # retour
      WFIL += "&[EDK]NUMLIN>DEBNUM"
  Endcase
Return

# Gestion du masque EDK1

######################################################################################
## Etiquette ajoutée par le superviseur (écran EDK1) 07/10/2015 14:18:29 (RBA)
######################################################################################
Subprog IB_CATACTFLT
  Case func GET_EDI_CATACT([M:EDK1]DOCID, [M:EDK1]CATTYP)
    When 1 : #send only
          Grizo [M]CATACTFLT
    When 2 : #receipt only
          Grizo [M]CATACTFLT
    When 3 : #both
          Actzo [M]CATACTFLT
    When 0 : #none
          Grizo [M]CATACTFLT
  Endcase
End

Subprog AM_CATACTFLT(VALEUR)
Variable Integer VALEUR
  [M:EDK1]CATACTFLT = VALEUR
End


######################################################################################


#---------------------------------------------------------------------------#
#        Get the ACTION type found for the current doc in the               #
#        EDI tracking table                                                 #
#---------------------------------------------------------------------------#
Funprog GET_EDI_CATACT(WDOCID, WCATTYP)
Value Char    WDOCID
Value Integer WCATTYP
  Local Integer WCATACTFLT     : WCATACTFLT     = 0
  Local Integer WFOUND_SEND    : WFOUND_SEND    = 0
  Local Integer WFOUND_RECEIVE : WFOUND_RECEIVE = 0

  Local File EDITRKDOC [EDK]
  Filter [EDK] Where [EDK]DOCID = WDOCID and [EDK]CATTYP = WCATTYP and [EDK]TESTFLG = 1 and [EDK]TRKSTA = 3
  For [EDK]
    If [EDK]CATACT = 1 : WFOUND_SEND    = 1 : Endif
    If [EDK]CATACT = 2 : WFOUND_RECEIVE = 1 : Endif
  Next
  Filter [EDK]
  Close File [EDK]

  If WFOUND_SEND = 1
    If WFOUND_RECEIVE = 1
      WCATACTFLT = 3 #send+receive
    Else
      WCATACTFLT = 1 #send
    Endif
  Else
    If WFOUND_RECEIVE = 1
      WCATACTFLT = 2 #receive
    Else
      WCATACTFLT = 0 #none
    Endif
  Endif
End WCATACTFLT

