Raz GPILOBJ
Raz GBIDC1, GBIDC2
Call OBJET("HRRPL",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
## Etiquette ajoutée par le superviseur (Objet HRRPL) 17/05/2016 17:17:34 (DLEFR)
######################################################################################
$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "FERME"       : Gosub FERME
    When "LIENS"       : Gosub LIENS
    When "VERIF_CRE"   : Gosub VERIF_CRE
    When "VERIF_MOD"   : Gosub VERIF_MOD
    When "CREATION"    : Gosub CREATION
    When "MODIF"       : Gosub MODIF
    When "AP_CHANGE"   : Gosub AP_CHANGE
    When "ANNULE"      : Gosub ANNULE
    When "CHGCOD"      : Gosub CHGCOD
    When "SEL_TABLE"   : Gosub SEL_TABLE
    When "AS_COD"      : Raz GCURLEG
    When "RAZCRE"      : Gosub RAZCRE
   # When "VERF_TABLE"      : Gosub TESTSBA
  Endcase
Return



$TESTSBA

Dbgaff

Return

########################################
$OUVRE
  If clalev ([F:HRRPL])=0 : Local File HRRPLREN [HRRPL] : Endif
  If clalev ([F:HRRPL2])=0 : Local File HRRPLREN [HRRPL2] : Endif
  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

########################################
$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
  # To manage the button Tunnel
  If TUNNEL<>1 : Return : Endif
  If dim(VCOD)<1 : Global Char VCOD(GLONHRRPL) : Endif
  VCOD = CLE2
Return

########################################
$LIENS
  GCURLEG = [F:HRRPL]LEG
  If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

  # To manage translated texts (data type AX3 & AX1)
  Call LECTEXTRA([M]DESAXX,"HRRPLREN","DESAXX",[M]COD,GCURLEG) From ATEXTRA
  Call LECTEXTRA([M]SHOAXX,"HRRPLREN","SHOAXX",[M]COD,GCURLEG) From ATEXTRA

  Gosub DISPLAY_HIDE
Return

########################################
$VERIF_CRE
$VERIF_MOD
  If [M]DEFVAL=2
   Filter [F:HRRPL2] Where COD<>[M]COD & LEG=GCURLEG & DEFVAL=2
   Read [F:HRRPL2]HRRPL0 First
   Filter [F:HRRPL2]
   If !fstat
    # A default value already exist for this legislation : XXX
    GMESSAGE = mess(1,10712,1)-":'"-[F:HRRPL2]COD+"'"
    OK = 0 : Return
   Endif
  Endif
Return

$RAZCRE
If func AFNC.ACTIV("LEG")=0
  [M]LEG=GDOSLEG(1)
  Affzo [M]LEG
Else
  [M]LEG=GLEGFIL
Endif
GCURLEG=[M]LEG
Gosub DISPLAY_HIDE
Return

########################################
$CREATION
$MODIF
  Gosub TEXTRA
  If GOK<1 : Return : Endif
Return

########################################
# To manage translated texts (data type AX3 & AX1) in creation and duplication
$TEXTRA
  If GREP="D"
    ## In duplication mode we want to keep all translated texts
    Call DUPTEXTRA("HRRPLREN","DESAXX",CLECUR1,"","HRRPLREN","DESAXX",[F:HRRPL]COD,GCURLEG)  From ATEXTRA
    Call DUPTEXTRA("HRRPLREN","SHOAXX",CLECUR1,"","HRRPLREN","SHOAXX",[F:HRRPL]COD,GCURLEG)  From ATEXTRA
  Endif
  Call MAJTEXTRA([M]DESAXX,"HRRPLREN","DESAXX",[F:HRRPL]COD,GCURLEG) From ATEXTRA
  Call MAJTEXTRA([M]SHOAXX,"HRRPLREN","SHOAXX",[F:HRRPL]COD,GCURLEG) From ATEXTRA
Return

########################################
# To change translated texts (data type AX3 & AX1) when you change the main code
$AP_CHANGE
  Call CHGTEXTRA("HRRPLREN","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
  Call CHGTEXTRA("HRRPLREN","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
  Call SUPTEXTRA("HRRPLREN","DESAXX",SUPP,[L]CODE) From ATEXTRA
  Call SUPTEXTRA("HRRPLREN","SHOAXX",SUPP,[L]CODE) From ATEXTRA
Return

########################################
#To change the main code
$CHGCOD
  Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return

########################################
$SEL_TABLE
  Case TABLE
    When "SELHRRPL"
      If clalev ([F:HRRPL])=0 : Local File HRRPLREN [HRRPL] : Endif
      OBJET="HRRPL"
      START = "[F:HRRPL]COD"

      #Filter based on code legislation
      If PARAM(1)<>""
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRRPL]LEG="'+PARAM(1)+'" | [F:HRRPL]LEG="")',"&") From GOBJSUB
      Endif
      #Filter based on group of company
      If PARAM(2)<>""
        #OBJET=""
        DEFPAG = 1    :# To have page up and page down
        TIT=mess(17,10712,1)   :#Permis et habilitations
      Gosub NOMFIC From ="WOHRRPL"
      Call  TRANSCOL("HRRPL",NBCOL,COL,TIT,FMTCOL) From OBJDIV
      If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
      If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
      If clalev([F:ACC])=0 : Local File ACCES   [ACC] : Endif
      If GUSRACS=2
        Link [HRRPL] With
&       [AGC]AGC0=[F:HRRPL]GRP,
&       [AXX]AXX0="HRRPLREN";"DESAXX";GLANGUE;[F:HRRPL]COD;[F:HRRPL]LEG
&       As [LNK]
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AGC]CPY="'+PARAM(2)+'" | [F:HRRPL]GRP="")',"&") From GOBJSUB
      Else
        Link [HRRPL] With
&       [AGC]AGC0=[F:HRRPL]GRP,
&       [AXX]AXX0="HRRPLREN";"DESAXX";GLANGUE;[F:HRRPL]COD;[F:HRRPL]LEG,
&       [ACC]CODACC=GUSER;[F:HRRPL]CODACS
&       As [LNK]
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AGC]CPY="'+PARAM(2)+'" | [F:HRRPL]GRP="") & ([F:HRRPL]CODACS="" | [F:ACC]CONSUL=2)',"&") From GOBJSUB
      Endif

      Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:HRRPL]ENAFLG=2',"&") From GOBJSUB

      NBCOL += 1 : COL(NBCOL) = "[F:HRRPL]GRP"    : COLTYP(NBCOL) =  type([F:HRRPL]GRP)    : TIT(NBCOL) =mess(237,133,1)
      Default File [LNK]
     Endif
  Endcase
Return

$DISPLAY_HIDE
Local Char W_SIGN(1)
Case GCURLEG
 When "FRA",""
   W_SIGN=""
 When Default
   W_SIGN="-"
   Raz [M]RENRPL
Endcase
Chgfmt [M]RENRPL With W_SIGN+"K:10X"

Affzo [M]

Return


##################################################
Subprog DEFHRRPL(COD,LEG,SOC)
Variable Char    COD()
Value    Char    LEG
Value    Char    SOC
  If GFONCTION = "GESHRRPL" | COD<>"" : End : Endif

  If func AFNC.ACTIV("LEG")=0
   LEG = GDOSLEG
  Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
   LEG = GCURLEG
  Endif

  If clalev([F:HRRPL])=0  : Local File HRRPLREN [HRRPL]  : Endif

  # Find default code for legislation
  If LEG<>""
   Filter [F:HRRPL] Where [F:HRRPL]LEG=[L]LEG & DEFVAL=2
   Read [F:HRRPL]HRRPL0 First
   Filter [F:HRRPL]
   If !fstat
    COD=[F:HRRPL]COD
    End
   Endif
  Endif

  Filter [F:HRRPL] Where [F:HRRPL]LEG="" & DEFVAL=2
  Read [F:HRRPL]HRRPL0 First
  Filter [F:HRRPL]
  If !fstat
   COD=[F:HRRPL]COD
   End
  Endif
End

##################################################
# To do a generic Call CONTSEL... from
Subprog CONTSEL(COD,LEG,SOC)
Value    Char    COD
Value    Char    LEG()
Value    Char    SOC()
  Call CONTHRRPL(COD,LEG,SOC)
End

##################################################
Subprog CONTHRRPL(COD,LEG,SOC)
Value    Char    COD
Value    Char    LEG()
Value    Char    SOC()

  If GFONCTION = "GESHRRPL" | COD="" : End : Endif

  If clalev([F:HRRPL])=0 : Local File HRRPLREN [HRRPL] : Endif

  If func AFNC.ACTIV("LEG")=0
   LEG = GDOSLEG
  Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
   LEG = GCURLEG
  Endif
  If LEG<>""
   Read [HRRPL]HRRPL0=COD;LEG
   If fstat
    Read [HRRPL]HRRPL0=COD;""
    If !fstat
      LEG=""
    Else
      # Fiche inexistante pour la législation courante
      GMESSAGE = [L]COD-":"-mess(14,10712,1)-"["+[L]LEG+"]"
      mkstat = 2 : End
    Endif
   Endif
  Else
   Read [HRRPL]HRRPL0(1)=COD
   If !fstat
    LEG = [F:HRRPL]LEG
   Else
    # Fiche inexistante
    GMESSAGE = [L]COD-":"-mess(23,100,1)
    mkstat = 2 : End
   Endif
  Endif

  If LEG<>""
   Call CONTROLE("HRRPL","",LEG,COD,mkstat) From CONTOBJ
  Else
   Call CONTROLE("HRRPL","","",COD,mkstat) From CONTOBJ
  Endif

  If [F:HRRPL]GRP<>"" & SOC<>""
   If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
   Look [AGC]AGC0 = [F:HRRPL]GRP;SOC
   If fstat
    GMESSAGE = [L]COD-":"-mess(63,127,1)-":"-[F:HRRPL]GRP : # Réservé au groupe de société
    mkstat = 2 : End
   Endif
  Endif

  If GUSRACS<>2
   If [F:HRRPL]CODACS <> ""
    If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
    Read [F:ACC]CODACC = GUSER;[F:HRRPL]CODACS
    If fstat or [F:ACC]CONSUL <> 2
     GMESSAGE = [F:HRRPL]COD-":"-mess(3,104,1) :#Access denied
     mkstat = 2 : End
    Endif
   Endif
  Endif
End

##################################################
Subprog TUNHRRPL(COD,LEG,SOC)
Variable Char    COD()
Value    Char    LEG
Value    Char    SOC
Local Integer TOKILL

TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONHRRPL)
 TOKILL = 1
Endif

If clalev([F:HRRPL])=0 : Local File HRRPLREN [HRRPL] : Endif

# To update the HRRPL code after the tunnel order
VCOD = COD

If GNBLEG = 1
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

Read [HRRPL]HRRPL0 = VCOD;LEG
If fstat
  If LEG=""
    Read [HRRPL]HRRPL0(1)=VCOD
    If !fstat
      LEG = [F:HRRPL]LEG
    Endif
  Endif
Endif

Read [HRRPL]HRRPL0=VCOD;LEG
If fstat : LEG="" : Endif

Call OBJET("HRRPL",LEG,VCOD) From GOBJET
COD = VCOD
If TOKILL : Kill VCOD : Endif
End

##################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
  GCURLEG = VALEUR
  Gosub DISPLAY_HIDE
End


