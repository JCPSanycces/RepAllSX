######################################################################################
## Etiquette écran EVA0
######################################################################################

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
Read [ID]ID0=VALEUR
#Infbox "Inside AM_REFNUM" - num$(mkstat)
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
#If !fstat & [F:ID]FLGMULCTR<>2 & [M:EVA0]EVADAT<>[0/0/0]
# Call CHERCHE_CTR(VALEUR,[M:EVA0]EVADAT,[M:EVA0]CTRNUM) From DIVPAYE
If !fstat & [F:ID]FLGMULCTR<>2 & [M:EVA0]EVADATEND<>[0/0/0]
    #AM employee must not have multiple contracts
    #AM eva0 evaluation range end date not null
#Infbox "Read OK, not multi ctr and evaluation end date not null" - num$(mkstat)
#Infbox "Checked multi-contract and end date"  - num$(mkstat)
# FQ81085 US830 - SEGAY 03/10/12 -
# Call CHERCHE_CTRPER(VALEUR,[M:EVA0]EVADATEND,[M:EVA0]EVADATEND,[M:EVA0]CTRNUM) From DIVPAYE
 Call CHERCHE_CTR_PER(VALEUR,[M:EVA0]EVADATEND,[M:EVA0]EVADATEND,[M:EVA0]CEV,[M:EVA0]CTRNUM)
#AM Infbox "after call CHERCHE_CTR_PER[M:EVA0]CTRNUM =" - [M:EVA0]CTRNUM
# Infbox "After the CHERCHE_CTR_PER call"  - num$(mkstat)
# FQ81491 - SEGAY 01/10/12 - Contrôle que le salarié a les mêmes caractéristiques que le code campagne
  If ([M:EVA0]CTRNUM<>"" | [F:ID]FLGMULCTR<>2)& [M:EVA0]CEV<>"" Then
    Call CTL_CEV_CTR(VALEUR,[M:EVA0]CTRNUM,[F:HRCTR]CTRDAT,1)
#AM Infbox "after call CTL_CEV_CTR"
#Infbox "After the CTL_CEV_CTR call"  - num$(mkstat)
    If mkstat=2
#Infbox "AFTER mkstat check"  - num$(mkstat)
      Raz [EVA0]CTRNUM
      End
    Endif
  Endif
 # JML 24/09/10
 [M:EVA0]CTRDAT = [F:HRCTR]CTRDAT
 [M:EVA0]REFNUM = VALEUR : # 13/02/14 - EXI 96649 US2420 Mission
#Infbox "Before Gosub AFF_CTR"
Gosub AFF_CTR
#Infbox "After Gosub AFF_CTR"
 Affzo [EVA0]CTRNUM,CTRDAT
Endif

[M]SRN = [F:ID]NAM-[F:ID]SRN : # JML 31/08/10 CG
Call GRISE_CTRNUM([F:ID]FLGMULCTR) From SUBEVA2
Local Integer L_IJ, L_OK
Gosub STG_REA From SUBEVA2

# FQ81491 - MABON 21/08/12 - Contrôle que le salarié a les mêmes caractéristiques que le code campagne
If ([M:EVA0]CTRNUM<>"" | [F:ID]FLGMULCTR<>2)& [M:EVA0]CEV<>"" Then
  Call CTL_CEV_CTR(VALEUR,[M:EVA0]CTRNUM,[M:EVA0]CTRDAT,1)
Endif
End

# FQ81491 - MABON 21/08/12 - Contrôle que le salarié a les mêmes caractéristiques que le code campagne
Subprog CTL_CEV_CTR(PREFNUM,PCTRNUM,PCTRDAT,PFOREML)
Value Char PREFNUM(),PCTRNUM()
Value Date PCTRDAT
Value Integer PFOREML
  Local Char    CRITERE1(250)
  Local Char    LST_ERR(250)
  Local Integer I
  I=0
#Infbox "Inside AM_REFNUM -> CTL_CEV_CTR"
  If clalev([F:HRPOA])=0 : Local File POPULA   [HRPOA] : Endif
  If clalev([F:CEV])=0 : Local File COMPEVAL [CEV] : Endif
  Call LECTURE("CEV", [M:EVA0]CEV, "") From CONTOBJ

  If PCTRNUM<>"" Then
    Read [F:HRCTR]CTR0=PREFNUM;PCTRNUM;PCTRDAT
    If !fstat Then
      If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
      Call LECTURE("FCY", [F:HRCTR]ETRFCY, "") From CONTOBJ
      If !fstat Then
#        If [F:CEV]CPYCEV<>"" & [F:CEV]CPYCEV<>[F:FCY]LEGCPY Then
        If [F:CEV]CPYCEV<>""  Then
          Call CRITGSOC(CRITERE1) From SUBCEV
          If evalue(CRITERE1) < 1
            If I>0 Then LST_ERR += ", " : Endif
            LST_ERR += mess(1,10478,1) : # Société
            I+=1
          Endif
        Endif
        If [F:CEV]FCYCEV<>"" & [F:CEV]FCYCEV<>[F:HRCTR]ETRFCY Then
          If I>0 Then LST_ERR += ", " : Endif
          LST_ERR += mess(2,10478,1) : # Site
          I+=1
        Endif
      Endif
#      If [F:CEV]SRVCEV<>"" & [F:HRCTR]ETRSRV<>"" & [F:CEV]SRVCEV<>[F:HRCTR]ETRSRV Then
      If [F:CEV]SRVCEV<>""  & [F:CEV]SRVCEV<>[F:HRCTR]ETRSRV Then
        If I>0 Then LST_ERR += ", " : Endif
        LST_ERR += mess(8,10508,1)   : # Service
        I+=1
      Endif
#      If [F:CEV]PRFCEV<>"" & [F:HRCTR]PROPRF<>"" & [F:CEV]PRFCEV<>[F:HRCTR]PROPRF Then
      If [F:CEV]PRFCEV<>""  & [F:CEV]PRFCEV<>[F:HRCTR]PROPRF Then
        If I>0 Then LST_ERR += ", " : Endif
        LST_ERR += mess(10,10508,1)  : # Profil
        I+=1
      Endif
#      If [F:CEV]POTCEV<>"" & [F:HRCTR]POT<>"" & [F:CEV]POTCEV<>[F:HRCTR]POT Then
      If [F:CEV]POTCEV<>""  & [F:CEV]POTCEV<>[F:HRCTR]POT Then
        If I>0 Then LST_ERR += ", " : Endif
        LST_ERR += mess(6,10937,1)   : # Poste
        I+=1
      Endif
#      If [F:CEV]JOTCEV<>"" & [F:HRCTR]JOBPOT<>"" & [F:CEV]JOTCEV<>[F:HRCTR]JOBPOT Then
      If [F:CEV]JOTCEV<>""  & [F:CEV]JOTCEV<>[F:HRCTR]JOBPOT Then
        If I>0 Then LST_ERR += ", " : Endif
        LST_ERR += mess(5,10937,1)   : # Emploi type
        I+=1
      Endif
      If [F:CEV]POPCEV<>"" Then
        Read [F:HRPOA]POA0=[F:CEV]POPCEV;PREFNUM
        If fstat Then
          If I>0 Then LST_ERR += ", " : Endif
          LST_ERR += mess(2,10993,1)   : # Population
          I+=1
        Endif
      Endif
    Endif
  Elsif GREP<>"C"
    If I>0 Then LST_ERR += ", " : Endif
    LST_ERR += mess(72,10720,1)   : # Contrat
    I+=1
  Endif

  If I>0 Then
    If PFOREML
      GMESSAGE  = mess(83,10720,1)-":"+chr$(10)+chr$(13) : # Incompatibilité de données avec le salarié
    Else
      GMESSAGE  = mess(98,10720,1)-":"+chr$(10)+chr$(13) : # Incompatibilité de données avec le contrat
    Endif
    GMESSAGE += LST_ERR
#    mkstat=2
    If GREP="C" | GIMPORT Then :#MABOS-25/09/13-FQ89268-US1911-
      mkstat=2
    Else
      Infbox GMESSAGE
    Endif
  Endif
End

#     SEGAY - 08/08/12 - EXI 81491 83397 US606
################################################################################
## Cherche le no de contrat d'un salarié mono contrat en fonction d'une date
################################################################################
Subprog CHERCHE_CTR_PER(MATRI,DATDEB,DATFIN,PCEV,CTR)
Value    Char MATRI
Value    Date DATDEB
Value    Date DATFIN
Value    Char PCEV # FQ81085 US830 - SEGAY 03/10/12 -
Variable Char CTR
#If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
#Filter [HRCTR] Where REFNUM=MATRI & (CTRDAT<=DATFIN | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=DATFIN))
#&                 & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>=DATDEB)
#Read [HRCTR]CTR1 Last
#Filter [HRCTR]
#If !fstat
# CTR = [F:HRCTR]CTRNUM
#Endif
# FQ81085 US830 - SEGAY 03/10/12 -
Gosub RECHCTRCEV
If CTR=""
  GMESSAGE  = mess(98,10720,1) : # Incompatibilité de données avec le contrat
  mkstat=2
Endif
End


# FQ81085 US830 - SEGAY 03/10/12 -
$RECHCTRCEV
Local Char    POT, JOBPOT, TYPEVA, CPY, FCY, PRF, SRV, CRIT1(250), CRITCEV1(250), CRITCEV2(250)
Local Date    CTRDAT, STRDAT, ENDDAT
Local Char    TEX(80)(1..), TEXTE(80)(1..,1..5)
Local Integer ICRITERE
Local Integer NB_CTR
Local Char    CRITERE1(250)
#Infbox "In $RECHCTRCEV mkstat = " - num$(mkstat)
  If clalev([F:FCY])=0   : Local File FACILITY [FCY]   : Endif
  If clalev([F:CEV])=0   : Local File COMPEVAL [CEV]   : Endif
  If clalev([F:ID])=0    : Local File EMPLOID  [ID]    : Endif
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
  If clalev([F:HRPOA])=0   : Local File POPULA   [HRPOA]   : Endif
# SEGAY 10/09/12 FQ81085 US740
  If clalev([F:CPY])=0    : Local File COMPANY  [CPY]   : Endif
  Local Char WLEG(GLONADI)
  Local Char WCPY(GLONCPY)
  WCPY=GSOCIETE
#  If func AFNC.ACTIV("LEG")=0
#    WLEG = GDOSLEG
#  Else  # GCURLEG positionné par programme
#    If GCURLEG = ""
#      WLEG=GLEGFIL
#    Else
#      WLEG=GCURLEG
#    Endif
#  Endif
  Local Char WLEGCEV(GLONADI)
  Local Char WLEGCTR(GLONADI)
  Local Integer TMP
  Raz TMP
  Raz WLEGCEV
  Call GET_LEGHRCEV([M]CEV,TMP,WLEGCEV,0)From TOOLSHRLEG
  WLEG=WLEGCEV
#Infbox "In $RECHCTRCEV, after call GET_LEGHRCEV" - num$(mkstat)
# END SEGAY 10/09/12 FQ81085 US740
  Raz [F:CEV]
  Call LECTURE("CEV", PCEV, "") From CONTOBJ
#Infbox "In $RECHCTRCEV, after call LECTURE" - num$(mkstat)
  CRIT1="1=1"
  CRIT1 -= "& (([F:HRCTR]CTRDAT<=["+format$(GFMD,[M:EVA0]EVADATEND)+"] )"
  CRIT1 -= " | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=["+format$(GFMD,[M:EVA0]EVADATEND)+"]))"
  CRIT1 -= "& ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=["+format$(GFMD,[M:EVA0]EVADATEND)+"])"

  CRITCEV1='1=1'
  CRITCEV2='1=1'
  CRITCEV1 -= '& REFNUM="'+MATRI+'"'
  #checks interview campaign against contract values
  If [F:CEV]COD<>"" Then
    If [F:CEV]CPYCEV<>"" Then # checks if company is null
#      CRITCEV1 -= ' & find([F:FCY]LEGCPY,"'+[F:CEV]CPYCEV+'","")>0'
      Call CRITGSOC(CRITERE1) From SUBCEV
#Infbox "In $RECHCTRCEV, after call CRITGSOC" - num$(mkstat)
      CRITCEV1 -= ' & '+ CRITERE1
    Endif
    If [F:CEV]FCYCEV<>"" Then
      CRITCEV1 -= ' & [F:HRCTR]ETRFCY="'+[F:CEV]FCYCEV+'"' #Interview campaign facility site
    Endif
    If [F:CEV]SRVCEV<>"" Then
      CRITCEV1 -= ' & [F:HRCTR]ETRSRV="'+[F:CEV]SRVCEV+'"' #department
    Endif
    If [F:CEV]PRFCEV<>"" Then
      CRITCEV2 -= ' & [F:HRCTR]PROPRF="'+[F:CEV]PRFCEV+'"' #profile
    Endif
    If [F:CEV]POTCEV<>"" Then
      CRITCEV2 -= ' & [F:HRCTR]POT="'+[F:CEV]POTCEV+'"' #position
    Endif
    If [F:CEV]JOTCEV<>"" Then
      CRITCEV2 -= ' &[F:HRCTR]JOBPOT="'+[F:CEV]JOTCEV+'"' #job standard
    Endif
  Endif
#AM Infbox "In $RECHCTRCEV, null is no population, POPCEV =" - [F:CEV]POPCEV
  If [F:CEV]POPCEV<>"" Then # checks if the interview campaign has a population #
#Infbox "If campaign population exists"
  Link [F:HRCTR] With [F:HRPOA]POA0=[F:CEV]POPCEV;[F:HRCTR]REFNUM,[F:ID]ID0=[F:HRCTR]REFNUM,
&                       [F:FCY]FCY0=[F:HRCTR]ETRFCY,[F:CPY]CPY0=[F:FCY]LEGCPY As [NEW_]
&                 Where [F:HRPOA]COD=[F:CEV]POPCEV
&               & ((WLEG="" or [F:CPY]LEG=WLEG) & (WCPY="" | [F:FCY]LEGCPY = WCPY)) & evalue(CRIT1) & evalue(CRITCEV1) & evalue(CRITCEV2)
&    Order By Key KEY1 = [F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT

  Else
#Infbox "Else because no campaign population"
    Link [F:HRCTR] With [F:ID]ID0=[F:HRCTR]REFNUM,
&                       [F:FCY]FCY0=[F:HRCTR]ETRFCY,   [F:CPY]CPY0=[F:FCY]LEGCPY As [NEW_]
&              Where ((WLEG="" or [F:CPY]LEG=WLEG) & (WCPY="" | [F:FCY]LEGCPY = WCPY))
&              & evalue(CRIT1)
&              & evalue(CRITCEV1)
&              & evalue(CRITCEV2)
&    Order By Key KEY1 = [F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT

#AM Infbox "link[NEW_] rowcount before read = "-num$(rowcount([NEW_]))
Read [NEW_] First #ANMCL add read for the link - Integration of Interviews  X3-29417 ZAF -

#AM
#Infbox "[F:ID]REFNUM = " - [F:ID]REFNUM - "join" - "[F:HRCTR]REFNUM =" - [F:HRCTR]REFNUM
#Infbox "[F:FCY]FCY =" - [F:FCY]FCY - "join" - "[F:HRCTR]ETRFCY =" - [F:HRCTR]ETRFCY
#Infbox "[F:CPY]CPY =" - [F:CPY]CPY - "join" - "[F:FCY]LEGCPY =" - [F:FCY]LEGCPY
#Infbox "WLEG =" - WLEG - "join" - "[F:CPY]LEG =" - [F:CPY]LEG - "and WCPY is null =" - WCPY
#Infbox "CRIT1 = " - num$(evalue(CRIT1)) - "and CRITCEV1 = " - num$(evalue(CRITCEV1)) - "and CRITCEV2 = " - num$(evalue(CRITCEV2))
#Infbox "CRIT1 = " - CRIT1
#Infbox "and CRITCEV1 = " - CRITCEV1
#Infbox "and CRITCEV2 = " - CRITCEV2

  Endif
#Infbox "In $RECHCTRCEV, after if links" - num$(mkstat)
  For [NEW_]
#AM Infbox "In $RECHCTRCEV, before assign contract number" - num$(mkstat)
#If dim(CTR) < 0 #not sure this variable declared
#  Local Char CTR(GLONCTR)
#  Infbox "In $RECHCTRCEV, ctr = " - num$(CTR)
#Endif
#Infbox "F CTR = " - [F:HRCTR]CTRNUM
    CTR = [F:HRCTR]CTRNUM
  Next
Return

Subprog C_EVADAT(VALEUR)
Variable Date    VALEUR
# SEGAY - 25/01/13 - BUG 87490 + BUG 87492
#Filter [HRCTR] Where REFNUM=[M:EVA0]REFNUM & CTRDAT<=VALEUR
#Read [HRCTR]CTR0 First
#Filter [HRCTR]
#If fstat
# # Salarié non présent le ../../..
# GMESSAGE = mess(38,10720,1)-num$(VALEUR)
# mkstat = 2 : End
#Endif
If(VALEUR<>[0/0/0])
  Filter [HRCTR] Where REFNUM=[M:EVA0]REFNUM  & CTRNUM=[M:EVA0]CTRNUM & (CTRDAT<=[L]VALEUR | ([F:HRCTR]RETDATEFF<>[0/0/0] & ([F:HRCTR]RETDATEFF<=[L]VALEUR)))
& & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>=[L]VALEUR)
  Read [HRCTR]CTR0 First
  Filter [HRCTR]
  If fstat
  # Salarié non présent le ../../..
    GMESSAGE = mess(38,10720,1)-num$(VALEUR)
    # MABOS-25/09/13-FQ89268-US1911-
    # Infbox GMESSAGE
    If GIMPORT Then
      mkstat = 2 : End
    Else
      Infbox GMESSAGE
    Endif
    # end MABOS-25/09/13-FQ89268-US1911-
  Endif
Endif
# END SEGAY - 25/01/13 - BUG 87490 + BUG 87492
End



