End


######################################################################################
######################################################################################
## Section automatically added (screen EVA1) 03/28/2017 14:34:52 (TIVAN)
######################################################################################
Subprog C_DETFNLFLG(VALEUR)
Variable Integer VALEUR
#ANMCL - 2017-05-08 -  X3-29417 - START
Local Char REV(GLONEML)
Local Integer MAINOBJ, EMPOBJ
If func AFNC.ACTIV("EVAEN")=0 : End : Endif
If VALEUR <> 2 : End : Endif
#Objectives
#Check to make sure all objectives are accepted
If [M:EVA0]EVAMAIREC = 2 or [M:EVA0]REFNUM = [M:EVA0]EVAMAT
    For nolign=1 To [M:EVA1]NBRCMT
     MAINOBJ +=1
     If [M:EVA1]DETSTA(nolign-1) <> 1
      VALEUR = 1
      mkstat = 1 : GMESSAGE = mess(00008,002455,1)
      Break : End
     Endif
    Next nolign
Endif

#If all objectives are accepted on the current record, check employee and main record
If [M:EVA0]EVAMAIREC = 2 or [M:EVA0]REFNUM = [M:EVA0]EVAMAT
  If clalev([F:EVD3])=0 : Local File EVAEMPDET    [EVD3] : Endif
  If clalev([F:EVE5])=0 : Local File EVAEMP       [EVE5] : Endif

  If [M:EVA0]EVAMAIREC = 2
    Filter [EVD3] Where REFNUM=[M:EVA0]REFNUM & CTRNUM=[M:EVA0]CTRNUM & EVADATSTR=[M:EVA0]EVADATSTR & EVADATEND=[M:EVA0]EVADATEND & TYPOBJ=1
& & EVATYP=[M:EVA0]EVATYP & EVAMAT = [M:EVA0]REFNUM
  Else
    #Get the reviewer for the main record
    Filter [F:EVE5] Where REFNUM = [M]REFNUM & CTRNUM = [M]CTRNUM & EVADATSTR = [M]EVADATSTR & EVADATEND = [M]EVADATEND & EVATYP = [M]EVATYP & EVAMAIREC = 2
    Read [EVE5] First
    If !fstat
      REV = [F:EVE5]EVAMAT
    Else
      #This should never happen, all reviews must have main reviewer - skip checks
      Filter [EVE5]
      End
    Endif

    Filter [EVD3] Where REFNUM=[M:EVA0]REFNUM & CTRNUM=[M:EVA0]CTRNUM &EVADATSTR=[M:EVA0]EVADATSTR & EVADATEND=[M:EVA0]EVADATEND & TYPOBJ=1
& & EVATYP=[M:EVA0]EVATYP & EVAMAT = REV
  Endif

  If rowcount([F:EVD3])>0
    For [EVD3]
      EMPOBJ +=1
      If [F:EVD3]DETSTA <> 1
        Filter [EVD3]
        Filter [EVE5]
        mkstat = 1 : GMESSAGE = mess(00008,002455,1)-mess(00009,002455,1)
        Break : End
      Endif
    Next
  Else
    #There might not be a employee review - reset object varaibles to pass following checks
      EMPOBJ  = 0
      MAINOBJ = 0
  Endif
  #Check if records were deleted that still exists on the other review
  #This should not happen as deletion on other objectives are prohibited
    If MAINOBJ = 0 and EMPOBJ > 0
      mkstat = 1 : GMESSAGE = mess(00008,002455,1)
    Elsif MAINOBJ > 0 and EMPOBJ = 0
      mkstat = 1 : GMESSAGE = mess(00008,002455,1)-mess(00009,002455,1)
    Endif

Endif
Filter [EVD3]
Filter [EVE5]
#ANMCL - 2017-05-08 -  X3-29417 - END
End


