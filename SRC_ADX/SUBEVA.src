$CHANGE_STYLE_EVAEMPSTA
If func AFNC.ACTIV("EVAEN") = 0 : Return : Endif
##Checking the status of the worklow from the employee
##Only the review for the employee can be changed and set
##All records
#Reset

Actzo [M:EVA1]DETSTA
Actzo [M:EVA1]EVAOBJ
Actzo [M:EVA1]EVACRIT
Actzo [M:EVA1]DETFNLFLG
Actzo [M:EVA1]EVACMT
Actzo [M:EVA1]CMTMAT

If [M:EVA0]REFNUM = [M:EVA0]EVAMAT or [M:EVA0]EVAMAIREC = 2
    For nolign = 1 To [M:EVA1]NBRCMT
      If [M:EVA0]EVAMAIREC <> [M:EVA1]MAIREC(nolign-1)
        Diszo [M:EVA1]EVAOBJ(nolign-1)
        Diszo [M:EVA1]EVACRIT(nolign-1)
      Else
        Actzo [M:EVA1]EVAOBJ(nolign-1)
        Actzo [M:EVA1]EVACRIT(nolign-1)
      Endif
    Next
Else
  Diszo [M:EVA1]DETSTA
  Diszo [M:EVA1]EVAOBJ
  Diszo [M:EVA1]EVACRIT
  Diszo [M:EVA1]DETFNLFLG
  If [M:EVA1]DETFNLFLG <> 2
    Diszo [M:EVA1]EVACMT
    Diszo [M:EVA1]CMTMAT
  Else
    Actzo [M:EVA1]EVACMT
    Actzo [M:EVA1]CMTMAT
  Endif
Endif

#If a record is not accepted - The perfomance can not be scored - all records
Actzo [M:EVA1]EVALEVOBJ
If [M:EVA1]DETFNLFLG = 2
  Actzo [M:EVA1]EVALEVOBJ
Else
  Diszo [M:EVA1]EVALEVOBJ
Endif

Affzo [M:EVA1]

