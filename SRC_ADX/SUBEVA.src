& & [F:EVM]EVATYP=[F:EVE]EVATYP & [F:EVM]EVAMAT = [F:EVE]EVAMAT
  Delete [EVIN] Where [F:EVIN]REFNUM=[F:EVE]REFNUM & [F:EVIN]CTRNUM=[F:EVE]CTRNUM
& & [F:EVIN]EVADATSTR=[F:EVE]EVADATSTR & [F:EVIN]EVADATEND=[F:EVE]EVADATEND
& & [F:EVIN]EVATYP=[F:EVE]EVATYP & [F:EVIN]EVAMAT = [F:EVE]EVAMAT
