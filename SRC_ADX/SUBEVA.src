## Etiquette ajoutée par le superviseur (écran EVA0) 08/08/2012 11:26:08 (SEGAY)
######################################################################################
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
Subprog C_EVATYP(VALEUR)
Variable Char    VALEUR()
Local Char EVAEAN
Local Integer OK
If clalev([F:EVE1])=0 : Local File EVAEMP [EVE1] : Endif
Raz EVAEAN
Call PARAM([M:EVA0]CPY,"EVAYEA",[L]EVAEAN) From ADOVAL
If EVAEAN <> "" & VALEUR=EVAEAN
# Filter [EVE1] Where REFNUM=[M]REFNUM & EVADAT>gdat$(day([M]EVADAT),month([M]EVADAT),year([M]EVADAT)-1)
#&& EVADAT<gdat$(day([M]EVADAT),month([M]EVADAT),year([M]EVADAT)+1) & (EVATYP=[L]EVAEAN | FLGYEA=2)
 Filter [EVE1] Where REFNUM=[M]REFNUM & EVADATSTR<[M]EVADATSTR
&& EVADATEND>[M]EVADATSTR & (EVATYP=[L]EVAEAN | FLGYEA=2) & EVATYP=[M]EVATYP
 Read [EVE1]EVE0 First
 If !fstat
  OK = 1
  # Fiche d'entretien annuel déjà existante le
  Call AVERTIR(mess(41,10720,1)-num$([F:EVE1]EVADATSTR),OK) From GESECRAN
  If OK=1
   mkstat = 2
  Endif
 Endif
 Filter [EVE1]
Endif
End
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
Subprog AM_EVATYP(VALEUR)
Variable Char    VALEUR()
Local Char EVAEAN
Call PARAM([M:EVA0]CPY,"EVAYEA" ,EVAEAN) From ADOVAL
If EVAEAN <> "" Then
  If VALEUR=EVAEAN
    [M]FLGYEA=2
  Else
    [M]FLGYEA=1
#ANMCL - 2017-05-08 -  X3-29417 - START
    [M]FLGPRO=func DIVPAYE.GET_VALTYPEVA("PRO",[M:EVA0]CPY,VALEUR)
    # Vérification de l'entretien bilan
    [M]FLGBIL=func DIVPAYE.GET_VALTYPEVA("BIL",[M:EVA0]CPY,VALEUR)
    # Vérification de l'entretien annuel
    [M]FLGYEA=func DIVPAYE.GET_VALTYPEVA("YEA",[M:EVA0]CPY,VALEUR)
    Affzo [M]FLGPRO,FLGBIL,FLGYEA
#ANMCL - 2017-05-08 -  X3-29417 - END
  Endif
  Affzo [M]FLGYEA
Endif
End

