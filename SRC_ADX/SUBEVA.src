  # But if one of them is filled, the other must be in the same legislation
  If dim(GCURLEG2)<0 Then Global Char GCURLEG2 : Endif
  GCURLEG2 = ""
  If clalev([F:JOT])=0 : Local File JOBTYP [JOT] : Endif
  If [M]EVAJOB<>"" Then
    Read [F:JOT]JOT0=[M]EVAJOB
    If !fstat & [F:JOT]LEG<>GCURLEG2 & [F:JOT]LEG<>"" Then GCURLEG2=[F:JOT]LEG : Endif
  Endif
  If GCURLEG2=GCURLEG or GCURLEG2 = "" Then
    If clalev([F:POT])=0 : Local File POSTE [POT] : Endif
    If [M]EVAPOT<>"" Then
      Read [F:POT]POT0=[M]EVAPOT
      If !fstat & [F:POT]LEG<>GCURLEG2 & [F:POT]LEG<>"" Then GCURLEG2=[F:POT]LEG : Endif
    Else
      If [M]EVAJOBGRP<>"" Then
         Call LECTURE("ADI",[M]EVAJOBGRP,"10460") From CONTOBJ
         If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
      Endif
    Endif
  Endif
  # End SEGAY
End

