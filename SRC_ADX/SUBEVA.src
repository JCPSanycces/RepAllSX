# FQ81085 - SEGAY 12/09/12 - US740  To allow a domain, theme or organism in a different legislation than the contract
# we had to change the datatype of these fields. So we have to control the field, without checking the LEG
Subprog AS_EVAPOT(VALEUR)
Variable Char    VALEUR()
  # FQ81085 - SEGAY 12/09/12 - US740 The position & Standard job can be in a different legislation than the contract
  # But if one of them is filled, the other must be in the same legislation
  If dim(GCURLEG2)<0 Then Global Char GCURLEG2 : Endif
  GCURLEG2 = ""
  If clalev([F:POT])=0 : Local File POSTE [POT] : Endif
  If [M]EVAPOT<>"" Then
    Read [F:POT]POT0=[M]EVAPOT
    If !fstat & [F:POT]LEG<>GCURLEG2 & [F:POT]LEG<>"" Then GCURLEG2=[F:POT]LEG : Endif
  Endif
  If GCURLEG2=GCURLEG or GCURLEG2 = "" Then
    If clalev([F:JOT])=0 : Local File JOBTYP [JOT] : Endif
    If [M]EVAJOB<>"" Then
      Read [F:JOT]JOT0=[M]EVAJOB
      If !fstat & [F:JOT]LEG<>GCURLEG2 & [F:JOT]LEG<>"" Then GCURLEG2=[F:JOT]LEG : Endif
    Else
      If [M]EVAJOBGRP<>"" Then
         Call LECTURE("ADI",[M]EVAJOBGRP,"10460") From CONTOBJ
         If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
      Endif
    Endif
  Endif
  # End SEGAY
End

# FQ81085 - SEGAY 12/09/12 - US740  To allow a domain, theme or organism in a different legislation than the contract
# we had to change the datatype of these fields. So we have to control the field, without checking the LEG
Subprog C_EVAPOT(VALEUR)
Variable Char    VALEUR()
  # FQ81085 - SEGAY 12/09/12 - US740 - CONTBOJN action has been added on this field, in order to avoid the checking of the
  # leg. So we have to control the field manually here
Local Char WLEG
  If VALEUR="" Then End : Endif
  WLEG= GCURLEG
  If [M]EVAJOB="" & [M]EVAJOBGRP="" Then
    If clalev([F:POT])=0 : Local File POSTE [POT] : Endif
    Read [F:POT]POT0=VALEUR
    If !fstat & [F:POT]LEG<>GCURLEG2 & [F:POT]LEG<>"" Then GCURLEG2=[F:POT]LEG : Endif
  Endif

  GCURLEG = GCURLEG2
  Call CONTROLE("POT","!",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1  : Endif
  GCURLEG = WLEG
  # End SEGAY
End

# FQ81085 - SEGAY 12/09/12 - US740  To allow a domain, theme or organism in a different legislation than the contract
# we had to change the datatype of these fields. So we have to control the field, without checking the LEG
