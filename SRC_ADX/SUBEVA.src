Funprog GET_NAMEFLUX(NAME)
Value Char NAME
Local Char NAME_FLUX(30)
Local Char RES(30)
 Case NAME
  When "DCG"    : NAME_FLUX="FLXPORDCG"
  When "EXS"    : NAME_FLUX="FLXPOREXS"
  When "DPI"    : NAME_FLUX="FLXPORDPI"
  When "PPH"    : NAME_FLUX="FLXPREPAI"
  When "PLA"    : NAME_FLUX="FLXPORPLA"
  When "TPS"    : NAME_FLUX="FLXPORTPS"
  When "DEM"    : NAME_FLUX="FLXPORDEM"
  When "CAL"    : NAME_FLUX="FLXPORCAL"
  When "CNGANN" : NAME_FLUX="FLXCNGANN"
  When "FOR"    : NAME_FLUX="FLXPORFOR"
  When "EVA"    : NAME_FLUX="FLXPOREVA"
 Endcase
 If(evalue("dim(G"+NAME_FLUX+")")>0)
  Call PARAM("",NAME_FLUX,RES) From ADOVAL
  If !clalev([F:FJH_])  : Local File FLXJOB   [FJH_]  : Endif
   Read [F:FJH_]FJH0 = GCURLEG;RES
    If fstat
        RES  = "DEFAULT"
        Read [F:FJH_]FJH0 = GCURLEG;RES
         If fstat
            RES=""
         Endif
   Endif
 Endif
End RES


$CALC_FLUX
  Local Char FLUX(30)
  Local Integer WNIVMGR(0..30),NIV
  FLUX=func GET_NAMEFLUX("EVA")
  If(FLUX="")
    FLUX="VALENT"
  Endif
  #Récupération du nom du flux
  #Call PARAM("","FLXPOREVA",[L]FLUX) From ADOVAL
  #Récupération du type de manager
  Call GET_TTYPMGR([L]FLUX, [L]WNIVMGR) From DIVPAYE
Return

Funprog GET_CHEFNCTR(CONTRAT,NIVEAU)
Value Char CONTRAT()
Value Integer NIVEAU()
Local Char TMP_MAT(30)
Local Integer WI
Local Integer DIMNIV : DIMNIV=dim(NIVEAU)
While(WI<DIMNIV and NIVEAU(WI)<>0)
  Call GETCHEFNCTR_NCTRL(CONTRAT,NIVEAU(WI),TMP_MAT)From PORMAT
  If(TMP_MAT<>"") : Break : Endif
  WI+=1
Wend
End TMP_MAT

Subprog SET_EVAVAL(CONTRAT)
Value Char CONTRAT()
If[M:EVA6]EVALIB=""
  Gosub CALC_FLUX

  [M:EVA6]EVAMAT=func GET_CHEFNCTR(CONTRAT,WNIVMGR)
  Call AM_EVAMAT([M:EVA6]EVAMAT)
  Affzo [M:EVA6]EVAMAT
  Affzo [M:EVA6]SRN1
Endif
End

