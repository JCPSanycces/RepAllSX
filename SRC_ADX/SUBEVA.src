#####################################################################################################
$CTL_EVAL
# FQ85010 - MABON 09/10/12 - On ne vérifie que si l'évaluation est Validée, donc ça ne peut pas arriver en création
# et ça ne peut pas arriver en modification car si évaluation validée, la modif n'est plus possible
# Donc ce test devient inutile
#If [M:EVA6]EVAMAT="" & [M:EVA6]EVALIB=""
# # Evaluateur non renseigné
# GMESSAGE = mess(31,10720,1) : zonsui="[M:EVA6]EVAMAT"
# OK = 0
#Endif
#ANMCL - 2017-05-08 -  X3-29417 - START
If func AFNC.ACTIV("EVAEN")>0
  Local Decimal TOTREVSCO
  Local Char ERRMESS(50),RETMSG(25)
  Local Integer STAT, K : STAT = 1
  Local Char ERRMESS(50)
  Local Char MISARR(GLONMIS)(0..)
  Local Decimal MISWEIARR(0..)
  Local Char WMISARR(GLONMIS)(0..)
  Local Decimal INDWEIARR(0..)
  Local Integer MISEQ,INDEQ,INDFLG
  MISEQ   = [M:EVA7]MISEQ
  INDFLG  = [M:EVA7]INDFLG
  INDEQ   = [M:EVA7]INDEQ

  #Storing grid values
  For nolign = 1 To [M:EVA7]NBRMIS
    MISARR(K)      = [M:EVA7]CODMIS(nolign-1)
    MISWEIARR(K)   = [M:EVA7]MISWEI(nolign-1)
    WMISARR(K)     = [M:EVA7]WMIS(nolign-1)
    INDWEIARR(K)   = [M:EVA7]INDWEI(nolign-1)
    K+=1
  Next
  #We need to check that the old records ( Before EVAEN ) are not checked
  If [M:EVA7]MISWEIFLG = 2 or [M:EVA7]MISEQ = 2
    Call VALID_MISIND(STAT,MISEQ,MISARR,MISWEIARR,INDFLG,INDEQ,WMISARR,INDWEIARR,RETMSG) From EVAFNC
    If STAT = 0
      OK = 0
      Return
    Else
      #Fill the grid on the screen with calculated values
      K = 0
      For nolign = 1 To [M:EVA7]NBRMIS
        [M:EVA7]MISWEI(nolign-1) = MISWEIARR(K)
        [M:EVA7]INDWEI(nolign-1) = INDWEIARR(K)
        K+=1
      Next
    Endif
  Endif
  Affzo [M:EVA7]
Endif


Gosub VAL_SCORE
#FRLAA - 2016-06-18 - REQUIREMENT 108587 US 1 - END

#ANMCL - 2017-05-08 -  X3-29417 - END
Return
