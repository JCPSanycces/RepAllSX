######################################################################################
Subprog CTLNIVSCA(AZC,CODSCA)
Variable Char    AZC()     : # Niveau
Value    Char    CODSCA()  : # Code échelle

Local Integer I,J
Local Char    VALCHAR (GLONNIV)

If AZC="" : End : Endif

Call LECTURE("HRSCA",[L]CODSCA,"") From CONTOBJ
If !fstat
 #Egalité parfaite
 For I=0 To dim([F:HRSCA]LEV)-1
  If toupper(ctrans([F:HRSCA]LEV(I)))=toupper(ctrans(AZC))
   VALCHAR=[F:HRSCA]LEV(I) : Break
  Endif
 Next
 If VALCHAR=""
  #Débute par...
  For I=len(AZC) To 1 Step -1
   For J=0 To dim([F:HRSCA]LEV)-1
    If [F:HRSCA]LEV(J)="" : Break : Endif
    If left$(toupper(ctrans([F:HRSCA]LEV(J))),I)=toupper(ctrans(AZC))
     VALCHAR=[F:HRSCA]LEV(J)
     Break 2
    Endif
   Next J
  Next I
 Endif
 If VALCHAR=""
  # Niveau inexistant
  GMESSAGE = mess(1,10720,1)
  mkstat = 2 : End
 Else
  AZC = VALCHAR
 Endif
Endif
End
######################################################################################
$SEL_LISTE
NBTEX = 0
Call LECTURE("HRSCA",PARAM(1),"") From CONTOBJ
If !fstat
 For L_IJ=0 To dim([F:HRSCA]LEV)-1
  If [F:HRSCA]LEV(L_IJ)<>""
   NBTEX += 1
   TEX(NBTEX) =[F:HRSCA]LEV(L_IJ)
   If NBTEX>=dim(TEX)-1 : Break : Endif
  Endif
 Next L_IJ
Endif
Return
