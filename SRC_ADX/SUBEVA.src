$RAZ_DUP
# JML 14/09/10 CG On autorise la duplication que sur date d'évaluation
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
#If COUZON<>"EVADAT"
If COUZON<>"EVADATSTR" and COUZON<>"EVADATEND"
# SEGAY 13/07/12 Message not exist
# Call ERREUR(mess(250,126,1)) From GESECRAN
 #### Duplication interdite
 Local Char MESSERR(250)
 MESSERR=mess(79,10720,1) : # On n'autorise la duplication que sur borne d'évaluation
 If COUZON="EVATYP" Then
  MESSERR += chr$(10)+chr$(13)+mess(101,10720,1) : # Pour modifier le type, utilisez la fonction "Changement de type"
 Endif
# Call ERREUR(mess(79,10720,1)) From GESECRAN
 Call ERREUR(MESSERR) From GESECRAN
 REP = "" : mkstat = 2 : Return
Endif
[M:EVA0]EVAVAL = 1  : Affzo [EVA0]EVAVAL
[M:EVA0]CEV    = "" : Affzo [M:EVA0]CEV
# JML 16/08/10 LOT P02
# SEGAY - 08/08/12 - EXI 81491 83397 US606
#Effzo [EVA6]EVADATSTR,EVADATEND
Effzo [EVA6]EVADAT

Gosub STG_REA From SUBEVA2
[M:EVA5]EVACMT1 = [M:EVA5]EVACMTNEW
[M:EVA5]CMTMAT1 = [M:EVA5]CMTMATNEW
Effzo [EVA5]EVACMTNEW, CMTMATNEW
Affzo [EVA5]EVACMT1, CMTMAT1

# JML 14/09/10 CG on copie nouveaux objectifs sur Performance
Effzo [EVA1]
For nolign=1 To [M:EVA4]NBROBJ
 [M:EVA1] = [M:EVA4]
 [M:EVA1]ORIDET(nolign-1)=2 : # Héritage
Next nolign
[M:EVA1]NBRCMT = [M:EVA4]NBROBJ
Effzo [EVA4]
Affzo [EVA1]
# Compétence, on purge
Effzo [EVA4]
# Perspective, uniquement réalisés
Effzo [EVA3]5
# JML 17/09/10 CG On purge tout
Effzo [EVA2]
# SBA on met à jour l'evaluateur
Call SET_EVAVAL([M]CTRNUM)
If([M:EVA6]EVALIB2="")
  [M:EVA6]EVAMAT2=""
   Call AM_EVAMAT2([M:EVA6]EVAMAT2)
  Affzo [M:EVA6]EVAMAT2
  Affzo [M:EVA6]SRN2
Endif
# 13/02/14 - EXI 96649 US2420 Mission On purge tout avant de récupérer Mission de POT et JOT
Effzo [EVA7]
# FQ82920 - MABON 15/06/12 - Le poste et/ou l'emploi-type sont initialisés par la carrière, et si aucune donnée
# exploitable n'est trouvée dans les carrières, on les cherche dans le contrat
Gosub INI_POT_JOBPOT_MIS : # 13/02/14 - EXI 96649 US2420 Mission
#END 96649

#ADNGO - 2011-11-06 - START
Effzo [EVA8]25
#ADNGO - 2011-11-06 - END

Return
