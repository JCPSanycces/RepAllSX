Subprog AM_MISWEIFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  Chgfmt [M:EVA7]MISWEI     With "+Nz:3.2"
Else
  Chgfmt [M:EVA7]MISWEI     With "-Nz:3.2"         #: Raz [M:EVA7]MISWEI
Endif
Affzo [M:EVA7]
End

Subprog AM_INDFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  Chgfmt [M:EVA7]IND          With "+K:10X"
  Chgfmt [M:EVA7]INDLEV       With "+K:30X"
  Chgfmt [M:EVA7]INDSCO       With "+Nz:3.2"
  Chgfmt [M:EVA7]EVALEVMIS    With "-K:30X"           : Raz [M:EVA7]EVALEVMIS
  Chgfmt [M:EVA7]CMTMIS       With "-K:250X"          : Raz [M:EVA7]CMTMIS
  Chgfmt [M:EVA7]CMTIND       With "+K:150X"
  #Raz [M:EVA7]MISSCO
Else
  Chgfmt [M:EVA7]IND          With "-K:10X"         : Raz [M:EVA7]IND
  Chgfmt [M:EVA7]INDLEV       With "-K:30X"         : Raz [M:EVA7]INDLEV
  Chgfmt [M:EVA7]INDSCO       With "-Nz:3.2"        : Raz [M:EVA7]INDSCO
  Chgfmt [M:EVA7]EVALEVMIS    With "+K:30X"
  Chgfmt [M:EVA7]CMTMIS       With "+K:250X"
  Chgfmt [M:EVA7]CMTIND       With "-K:150X"        : Raz [M:EVA7]CMTIND
Endif
Affzo [M:EVA7]
End


Subprog AM_INDWEIFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  Chgfmt [M:EVA7]INDWEI     With "+Nz:3.2"
Else
  Chgfmt [M:EVA7]INDWEI     With "-Nz:3.2"         #: Raz [M:EVA7]INDWEI
Endif
Affzo [M:EVA7]
End
#ANMCL - 2017-05-08 -  X3-29417 - START
Subprog B2_NBRMIS
# Mission On purge tout avant de récupérer Mission de POT et JOT
Effzo [EVA7]10
# - Le poste et/ou l'emploi-type sont initialisés par la carrière, et si aucune donnée
# exploitable n'est trouvée dans les carrières, on les cherche dans le contrat
Gosub INIT_MIS2
If [M:EVA7]NBRMIS
  Affzo [M:EVA7]
  Gosub STYLE
 mkstat = 4            : # Pour dégriser le bouton Enregistrer
Endif
End

Subprog AP_CODMIS(VALEUR)
Variable Char    VALEUR()
#Need to set WMIS even if there were no change
If VALEUR = "" and nolign > 0
  [M:EVA7]WMIS(nolign-1)    = [M:EVA7]WMIS(nolign-2)
  Diszo [M:EVA7]MISWEI(nolign-1)
  Diszo [M:EVA7]CODMIS(nolign-1)
Else
  [M:EVA7]WMIS(nolign-1) = VALEUR
  Actzo [M:EVA7]MISWEI(nolign-1)
Endif
Affzo [M:EVA7]
End

Subprog AM_CODMIS(VALEUR)
Variable Char    VALEUR()
#Adding the value to the hidden field WMIS
If VALEUR = ""
  [M:EVA7]WMIS(nolign-1)    = [M:EVA7]WMIS(nolign-2)
  Diszo [M:EVA7]MISWEI(nolign-1)
  Diszo [M:EVA7]CODMIS(nolign-1)
Else
  [M:EVA7]WMIS(nolign-1) = VALEUR
  Actzo [M:EVA7]MISWEI(nolign-1)
Endif
Affzo [M:EVA7]
End


