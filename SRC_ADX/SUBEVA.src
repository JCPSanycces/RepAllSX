#     SEGAY - 08/08/12 - EXI 81491 83397 US606
Subprog C_EVADATEND(VALEUR)
Variable Date    VALEUR
If [M:EVA0]REFNUM<>"" Then
  Filter [HRCTR] Where REFNUM=[M:EVA0]REFNUM & (CTRDAT<=VALEUR | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=VALEUR))
&                   & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>=VALEUR)
  Read [HRCTR]CTR0 First
  Filter [HRCTR]
  If fstat
   # Salarié non présent le ../../..
   GMESSAGE = mess(38,10720,1)-num$(VALEUR)
   mkstat = 2 : End
#   # MABOS-25/09/13-FQ89268-US1911-comme ci-dessous en V6
#   If GIMPORT Then
#    mkstat = 2 : End
#   Else
#    Infbox GMESSAGE
#   Endif
#  # end MABOS-25/09/13-FQ89268-US1911-

  Endif
Endif
End



Subprog AM_EVADATEND(VALEUR)
Variable Date    VALEUR
If [M:EVA0]REFNUM<>"" Then
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
  Read [ID]ID0=[M:EVA0]REFNUM
  If !fstat & [F:ID]FLGMULCTR<>2
#   Call CHERCHE_CTR_PER([M:EVA0]REFNUM,[M:EVA0]EVADATSTR,VALEUR,[M:EVA0]CTRNUM)
   Call CHERCHE_CTR_PER([M:EVA0]REFNUM,VALEUR,VALEUR,[M:EVA0]CEV,[M:EVA0]CTRNUM)
   # JML 24/09/10
   [M:EVA0]CTRDAT = [F:HRCTR]CTRDAT
   # FQ82920 - MABON 15/06/12 - Le poste et/ou l'emploi-type sont initialisés par la carrière, et si aucune donnée
   # exploitable n'est trouvée dans les carrières, on les cherche dans le contrat
   # Donc, la date pour la recherche du contrat doit être mise à jour
   [M:EVA0]EVADATEND = VALEUR
   # Fin MABON
   Gosub AFF_CTR
   Affzo [EVA0]CTRNUM,CTRDAT
  Endif
Endif
End


Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()

If [M:EVA0]CTRNUM=""
 # JML 09/08/10 LOT P02 Changing Selection by standard Object
# Call SELCTR([M:EVA0]REFNUM,[M:EVA0]EVADAT,[M:EVA0]EVADAT,VALEUR) From DIVPAYE
# FQ81085 US830 - SEGAY 27/09/12 - Replace by Selection TAB SELCTRCEV in SUBCEV
# Call S_CTRNUM(VALEUR) From SUBEVA
# mkstat = 0 : # Just to stay on the right place... (When exiting SELOBJ with Escape)
 If !GWEBSERV
   ## Action SELCTRCEV
   Local Char    PARMSK(250)(1..20) , SAVACT(20)
   SAVACT = GACTION : GACTION = "SELCTRCEV"
   PARMSK(1) = [M]REFNUM
   PARMSK(2) = [M]CEV
   Call S_TAB_CHAR(VALEUR,PARMSK,"SELCTRCEV","SUBCEV","") From GACTION
   GACTION = SAVACT
 Endif
 Gosub AFF From GSAISIE
 mkstat = 0 : # Just to stay on the right place... (When exiting SELOBJ with Escape)

Endif
End

