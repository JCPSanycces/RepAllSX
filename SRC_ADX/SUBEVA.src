#FRLAA - 2016-06-18 - REQUIREMENT 108587 US 1 - START
#ANMCL - 2017-05-08 -  X3-29417 - START
$SEL_TABLE
#AM Infbox"inside $SEL_TABLE"
Case TABLE
 When "SELINDEVA"
 OBJET = "MID"
 #START = "IND"
 #ORDRE = "IND"
 CRITERE = 'MIS=[M]WMIS(nolign-1)'
  # Issue 11472  - 2017-10-04 by BRBAN : Filter STGCOD field
 When "SELSTGCOD"
  OBJET = "STG"
  CRITERE = 'find([M:EVA2]CPCVAL(nolign-1),[F]CPCAFT) & [F]FICTI=1 & (([F:STG]STRVLY<=[M:EVA0]EVADATEND & ([F:STG]ENDVLY=[0/0/0] | [F:STG]ENDVLY>=[M:EVA0]EVADATSTR)))'
  # -
Endcase
Return
#ANMCL - 2017-05-08 -  X3-29417 - END

#ANMCL - 2017-05-08 -  X3-29417 - START
$VAL_SCORE
If func AFNC.ACTIV("EVAEN")=0 : Return : Endif
  Local Integer STAT : STAT = 1
  Local Decimal TOTREVSCO
  Local Char RETMSG(25)
  Local Integer MISEQ,INDEQ,INDFLG
  MISEQ   = [M:EVA7]MISEQ
  INDFLG  = [M:EVA7]INDFLG
  INDEQ   = [M:EVA7]INDEQ
#Calculate final scores before saving
STAT = 0
Default Mask [M:EVA7]
#Calculate the current reviewer score
Call CALC_SCORE(STAT,[M]MISWEIFLG,[M]MISEQ,[M]INDFLG,[M]INDWEIFLG,[M]INDEQ,RETMSG) From EVAFNC
If STAT = 2 : [M:EVA7]MISREVSCO = 0 : Endif
Affzo [M:EVA7]
Return


$VAL_SCORE_EVA
Gosub VAL_SCORE
#If this is the main record, then the scores for all reviewers must be combined
If [M:EVA0]EVAMAIREC = 2
  If  [M:EVA7]MISREVSCO = 0
    [M:EVA7]MISTOTSCO = 0
  Else
    Gosub VAL_SCORE_ALLREV
  Endif
  mkstat = 4
Endif
Affzo [M:EVA7]
Return


$VAL_SCORE_ALLREV

TOTREVSCO = 0

If  [M:EVA0]REVWEI = 100
  TOTREVSCO =([M:EVA7]MISREVSCO*[M:EVA0]REVWEI)/100
  [M:EVA7]MISTOTSCO = arr(TOTREVSCO,0.01)
  Return
Else
  TOTREVSCO = func EVAFNC.GET_REV_SCORE([M:EVA0]CEV,[M:EVA0]REFNUM,[M:EVA0]CTRNUM,[M:EVA0]EVADATSTR,[M:EVA0]EVADATEND,[M:EVA0]EVATYP,1)
Endif

If TOTREVSCO <> 0
  TOTREVSCO +=([M:EVA7]MISREVSCO*[M:EVA0]REVWEI)/100
  [M:EVA7]MISTOTSCO = arr(TOTREVSCO,0.01)
Else
  [M:EVA7]MISTOTSCO = 0
  #TOTREVSCO =([M:EVA7]MISREVSCO*[M:EVA0]REVWEI)/100
  #[M:EVA7]MISTOTSCO = arr(TOTREVSCO,0.01)
Endif
Affzo [M:EVA7]

Return
#ANMCL - 2017-05-08 -  X3-29417 - START
#FRLAA - X3PEOP-2053 - 2016-11-01 - START
$UPDATE_ALL_EVA
#Updating performance objectives
If func AFNC.ACTIV("EVAEN")=0  : Return : Endif
If [M:EVA1]DETFNLFLG = 2 and STA_EVASTA = 2 : Return : Endif #Accepted stage
#This action will only be performed from the main record or where the reviewer is the employee
If [M:EVA0]EVAMAIREC <> 2 and [M:EVA0]EVAMAT <> [M:EVA0]REFNUM
  Return
Endif

If clalev([F:EVE3])=0 : Local File EVAEMP       [EVE3] : Endif
If clalev([F:EVD2])=0 : Local File EVAEMPDET    [EVD2] : Endif


#Check all interview records except current open record
For [F:EVE3] Where REFNUM = [M]REFNUM & CTRNUM = [M]CTRNUM & EVADATSTR = [M]EVADATSTR & EVADATEND = [M]EVADATEND & EVATYP = [M]EVATYP & EVAMAT <> [M:EVA0]EVAMAT
 Delete [EVD2] Where [F:EVD2]REFNUM=[F:EVE3]REFNUM & [F:EVD2]CTRNUM=[F:EVE3]CTRNUM
& & [F:EVD2]EVADATSTR=[F:EVE3]EVADATSTR & [F:EVD2]EVADATEND=[F:EVE3]EVADATEND & [F:EVD2]TYPOBJ=1
& & [F:EVD2]EVATYP=[F:EVE3]EVATYP & [F:EVD2]EVAMAT = [F:EVE3]EVAMAT
  If fstat=1
   GOK = -1 : GLOCK = "$EVAEMPDET"-[F:EVE3]REFNUM-[F:EVE3]CTRNUM-[F:EVE3]EVADAT
   Break
   Return
  Endif

  #Write new records
  For nolign=1 To [M:EVA1]NBRCMT
    Raz [F:EVD2]
    [F:EVD2] = [M:EVA1]
    [F:EVD2]EVAMAT      = [F:EVE3]EVAMAT
    [F:EVD2]REFNUM      = [M]REFNUM
    [F:EVD2]CTRNUM      = [M]CTRNUM
    [F:EVD2]CTRDAT      = [M]CTRDAT
    [F:EVD2]EVALEVOBJ   = ""
    [F:EVD2]EVALEVREF   = 0
    [F:EVD2]EVADATSTR   = [M]EVADATSTR
    [F:EVD2]EVADATEND   = [M]EVADATEND
    [F:EVD2]EVATYP      = [M]EVATYP
    [F:EVD2]EVADAT      = [M]EVADAT
    [F:EVD2]TYPOBJ      = 1          : # ML 427 Performance
    [F:EVD2]NUMLIG = nolign
    If [F:EVD2]ORIDET=0 Then [F:EVD2]ORIDET=1 : Endif : # Manuel
    If [M:EVA1]DETFNLFLG <> 2 and ([M:EVA0]EVAMAIREC = 2 or [M:EVA0]EVAMAT = [M:EVA0]REFNUM)
      If [M:EVA1]MAIREC(nolign-1) = [M:EVA0]EVAMAIREC
        #Set the status to approval request
        If [M:EVA1]DETSTA(nolign-1) = 1 : [F:EVD2]DETSTA = 4 : Endif
      Endif
     Endif
    Write [F:EVD2]
    If fstat
      GOK = 0 : Call FSTA("EVD2") From GLOCK : Break
    Endif
  Next nolign
Next


Return

$UPDATE_STATUS_ALL_EVA
#Changing the review status for all records
If func AFNC.ACTIV("EVAEN")=0  : Return : Endif
If [M:EVA0]EVAMAIREC <> 2 and [M:EVA0]EVAMAT <> [M:EVA0]REFNUM
  Return
Endif

#Change all linked records status - Final tick on performance
  If clalev([F:EVE4])=0 : Local File EVAEMP       [EVE4] : Endif
  Update [EVE4] Where REFNUM = [M]REFNUM & CTRNUM = [M]CTRNUM & EVADATSTR = [M]EVADATSTR & EVADATEND = [M]EVADATEND & EVATYP = [M]EVATYP
&                     & EVAMAT <> [M:EVA0]EVAMAT With DETFNLFLG = [M:EVA1]DETFNLFLG

Return
#FRLAA - X3PEOP-2053 - 2016-11-02 - END

#FRLAA - X3PEOP-2053 - 2016-11-15 - START
#ANMCL - 2017-05-08 -  X3-29417 - END

#ANMCL - 2017-05-08 -  X3-29417 - START
$APRES_MOD
#AM Infbox"inside $APRES_MOD"
Gosub CHANGE_STYLE_EVAEMPSTA
Return
#ANMCL - 2017-05-08 -  X3-29417 - END


#**
