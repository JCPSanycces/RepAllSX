# FQ81491 - MABON 21/08/12 - Ajout code compagne
Subprog AM_CEV(VALEUR)
Variable Char    VALEUR()
Local    Integer L_OK

  If GREP="C" & VALEUR<>"" & VALEUR<>[M:EVA0]CEV Then
    If clalev([F:CEV])=0 : Local File COMPEVAL [CEV] : Endif
    Call LECTURE("CEV", VALEUR, "") From CONTOBJ
    [M:EVA0]EVADATSTR = [F:CEV]STRDAT
    [M:EVA0]EVADATEND = [F:CEV]ENDDAT
    [M:EVA0]EVATYP    = [F:CEV]EVATYP
    Grizo [M:EVA0]EVADATSTR, EVADATEND, EVATYP
    Affzo [M:EVA0]

    If [F:CEV]LEG<>"" Then GCURLEG = [F:CEV]LEG : Endif
  Endif
# FQ81085 US830 - SEGAY 03/10/12 -
  If GREP="C" & VALEUR="" & VALEUR<>[M:EVA0]CEV & [M:EVA0]REFNUM="" Then
     GCURLEG =""
#     EVATYP=""
#     Raz [M:EVA0]EVADATSTR, EVADATEND
#     Affzo [M:EVA0]EVADATSTR, EVADATEND,EVATYP
  Endif
  If VALEUR="" Then
    Actzo [M:EVA0]EVADATSTR, EVADATEND, EVATYP
#    Affzo [M:EVA0]EVADATSTR, EVADATEND,EVATYP
    zonsui = "[M:EVA0]EVADATSTR"
  Endif
End
# Fin MABON

# FQ81491 - MABON 21/08/12 - Contrôle que le code compagne a les mêmes caractéristiques que l'entretien
Subprog C_CEV(VALEUR)
Variable Char    VALEUR()
Local    Char    LST_ERR(250)
Local    Integer I

  If VALEUR<>""
    Gosub SAVE_GCURLEG From TOOLSHRLEG
     If GREP = "C" & [M:EVA0]REFNUM=""
        GCURLEG=""
     Endif
     Call CONTROLE("CEV","!",VALEUR,"",mkstat) From CONTOBJ
     Gosub RESTAURE_GCURLEG From TOOLSHRLEG
     If mkstat
      GERR = 1
      End
     Endif
  Endif
  If VALEUR<>"" & (GREP<>"C" | [M:EVA0]REFNUM<>"") Then
    I=0
    If clalev([F:CEV])=0 : Local File COMPEVAL [CEV] : Endif
    Call LECTURE("CEV", VALEUR, "") From CONTOBJ
    If (GREP="C" & [M:EVA0]EVATYP<>"" & [F:CEV]EVATYP<>[M:EVA0]EVATYP)
&    | (GREP<>"C" & [F:CEV]EVATYP<>[M:EVA0]EVATYP)  Then
      If I>0 Then LST_ERR += ", " : Endif
      LST_ERR += mess(84,10720,1)      : # Type d'évaluation
      I+=1
    Endif
#ANMCL - 2017-05-08 -  X3-29417 - START
    If [M:EVA0]FLGPRO<>2 &  [M:EVA0]FLGBIL<>2
&    &([M:EVA0]EVADATSTR<>[0/0/0] & [F:CEV]STRDAT<>[M:EVA0]EVADATSTR)
&    | ([M:EVA0]EVADATEND<>[0/0/0] & [F:CEV]ENDDAT<>[M:EVA0]EVADATEND) Then
      If I>0 Then LST_ERR += ", " : Endif
      LST_ERR += mess(85,10720,1)      : # Borne évaluation
      I+=1
    Endif

    If [M:EVA0]CTRNUM<>"" Then
      Read [F:HRCTR]CTR0=[M:EVA0]REFNUM;[M:EVA0]CTRNUM;[M:EVA0]CTRDAT
      If !fstat Then
        If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
        Call LECTURE("FCY", [F:HRCTR]ETRFCY, "") From CONTOBJ
        If !fstat Then
          If [F:CEV]CPYCEV<>"" & [F:CEV]CPYCEV<>[F:FCY]LEGCPY Then
            If I>0 Then LST_ERR += ", " : Endif
            LST_ERR += mess(1,10478,1) : # Société
            I+=1
          Endif
          If [F:CEV]FCYCEV<>"" & [F:CEV]FCYCEV<>[F:HRCTR]ETRFCY Then
            If I>0 Then LST_ERR += ", " : Endif
            LST_ERR += mess(2,10478,1) : # Site
            I+=1
          Endif
        Endif
        If [F:CEV]SRVCEV<>"" & [F:CEV]SRVCEV<>[F:HRCTR]ETRSRV Then
          If I>0 Then LST_ERR += ", " : Endif
          LST_ERR += mess(8,10508,1)   : # Service
          I+=1
        Endif
        If [F:CEV]PRFCEV<>"" & [F:CEV]PRFCEV<>[F:HRCTR]PROPRF Then
          If I>0 Then LST_ERR += ", " : Endif
          LST_ERR += mess(10,10508,1)  : # Profil
          I+=1
        Endif
        If [F:CEV]POTCEV<>"" & [F:CEV]POTCEV<>[F:HRCTR]POT Then
          If I>0 Then LST_ERR += ", " : Endif
          LST_ERR += mess(6,10937,1)   : # Poste
          I+=1
        Endif
        If [F:CEV]JOTCEV<>"" & [F:CEV]JOTCEV<>[F:HRCTR]JOBPOT Then
          If I>0 Then LST_ERR += ", " : Endif
          LST_ERR += mess(5,10937,1)   : # Emploi type
          I+=1
        Endif
      Endif
    Endif

    If I>0 Then
      #MABOS-25/09/13-FQ89268-US1911-
#     GMESSAGE  = mess(83,10720,1)-":" +chr$(10)+chr$(13)
      GMESSAGE  = mess(83,10720,1)-": " : # Incompatibilité de données avec le salarié
      If !GIMPORT
        GMESSAGE  += chr$(10)+chr$(13)
      Endif
      #end MABOS-25/09/13-FQ89268-US1911-
      GMESSAGE += LST_ERR
      If GREP="C" | [M:EVA0]CEV="" | GIMPORT Then : #MABOS-25/09/13-FQ89268-US1911-
        mkstat=2
      Else
        Infbox GMESSAGE
      Endif
    Endif
  Endif
End
# Fin MABON

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()

  Filter [HRCTR] Where REFNUM=VALEUR & (CTRDAT<=[M:EVA0]EVADATEND | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=[M:EVA0]EVADATEND))
&                   & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>=[M:EVA0]EVADATEND)
  Read [HRCTR]CTR0 First
  Filter [HRCTR]
  If fstat
   # Salarié non présent le ../../..
   GMESSAGE = mess(38,10720,1)-num$([M:EVA0]EVADATEND)
   mkstat = 2 : End

## MABOS-25/09/13-FQ89268-US1911- dans V6 c'est comme ci-dessous
## Infbox GMESSAGE
#   If GIMPORT Then
#    mkstat = 2 : End
#   Else
#    Infbox GMESSAGE
#   Endif
## end MABOS-25/09/13-FQ89268-US1911-

  Endif
End


