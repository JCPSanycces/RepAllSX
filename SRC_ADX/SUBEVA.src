######################################################################################
## Etiquette ajoutée par le superviseur (écran EVA3) 11/09/2012 12:13:41 (SEGAY)
######################################################################################
# FQ81085 - SEGAY 12/09/12 - US740 The domain, theme or organism can be in a different legislation than the contract
# but if one of them is filled, the others must be in the same legislation
Subprog AS_ARE(VALEUR)
Variable Char    VALEUR()
# FQ81085 - SEGAY 12/09/12 - US740 The domain, theme or organism can be in a different legislation than the contract
# but if one of them is filled, the others must be in the same legislation
If dim(GCURLEG2)<0 Then Global Char GCURLEG2 : Endif
GCURLEG2 = ""
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
# Si aucun des autres champs n'est renseigné, on récupère la leg du champ en cours
If GCURLEG2="" Then
  Read [F:ADI]CODE=10465;VALEUR
  If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
Endif
Call TITADI(GBOUT2,"10465") From TRTDIV
  # End SEGAY
End

# FQ81085 - SEGAY 12/09/12 - US740 The domain, theme or organism can be in a different legislation than the contract
# but if one of them is filled, the others must be in the same legislation
Subprog C_ARE(VALEUR)
Variable Char    VALEUR()
# FQ81085 - SEGAY 12/09/12 - US740  To allow a domain, theme or organism in a different legislation than the contract
# we had to change the datatype of these fields. So we have to control the field, without checking the LEG
  If VALEUR="" Then End : Endif
  # On recalcule GCURLEG2 si les autres champs sont vides
  If dim(GCURLEG2)<0 Then Global Char GCURLEG2 : Endif
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  Read [F:ADI]CODE=10465;VALEUR
  If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif

  Call CONTADI_SANS_LEG(VALEUR,"10465","") From TOOLSHRLEG
  If fstat : GMESSAGE=mess(23,100,1) : mkstat=2 : Endif
End

Subprog AM_ARE(VALEUR)
Variable Char    VALEUR()
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran EVA3) 17/09/2012 12:48:50 (SEGAY)
######################################################################################
Subprog AS_EVAFCY(VALEUR)
Variable Char    VALEUR()
  # FQ81085 - SEGAY 12/09/12 - US740 T
  If dim(GCURLEG2)<0 Then Global Char GCURLEG2 : Endif
  GCURLEG2 = ""
  If clalev([F:FCY3])=0 : Local File FACILITY [FCY3] : Endif
  If [M]EVAFCY<>"" Then
    Read [F:FCY3]FCY0=[M]EVAFCY
    If !fstat & [F:FCY3]LEG<>GCURLEG2 & [F:FCY3]LEG<>"" Then GCURLEG2=[F:FCY3]LEG : Endif
  Endif

End

Subprog C_EVAFCY(VALEUR)
Variable Char    VALEUR()
Local    Char    SAV_GCURLEG
  # FQ81085 - SEGAY 12/09/12 - US740 - CONTBOJN action has been added on this field, in order to avoid the checking of the
  # leg. So we have to control the field manually here
  If VALEUR="" Then End : Endif
  SAV_GCURLEG=GCURLEG
  GCURLEG = ""
  Call CONTROLE("FCY","!",VALEUR,"",mkstat) From CONTOBJ
  GCURLEG=SAV_GCURLEG
  If mkstat : GERR = 1  : Endif
  # End SEGAY

End


