######################################################################################
## Section automatically added (screen EVA1) 03/28/2017 15:06:21 (TIVAN)
######################################################################################
Subprog C_NBRCMT

If func AFNC.ACTIV("EVAEN")>0
  If !nolign : End : Endif
  Local Shortint I, J
  Case status
    When 65,68,83
    If status=65 : J=nolign-1 : Else J=nolign1-1 : Endif
    [M:EVA1]DETFNLFLG = 1
    Diszo [M:EVA1]DETFNLFLG
    For I=nolign-1 To J
      If [M:EVA1]MAIREC(I) <> 0 and [M:EVA0]EVAMAIREC <> [M:EVA1]MAIREC(I) or ([M:EVA0]EVAMAIREC <> 2 and [M:EVA0]REFNUM <> [M:EVA0]EVAMAT)
        GMESSAGE=mess(61,100,1)-num$(I+1)-":"-mess(54,123,1)
        mkstat     =1
        Break
      Endif
    Next
    If mkstat : End : Endif
  When 73
      #Changing the status

      [M:EVA1]DETFNLFLG = 1
      Diszo [M:EVA1]DETFNLFLG
      If [M:EVA0]EVAMAIREC <> 2 and [M:EVA0]REFNUM <> [M:EVA0]EVAMAT
        GMESSAGE=mess(00045,00133,1) : #Insertion not possible
        mkstat     =1
        End
      Endif
  Endcase
  Affzo [M:EVA1]DETFNLFLG
Endif

End

Subprog AM_EVAOBJ(VALEUR)
Variable Char    VALEUR()
#ANMCL - 2017-05-08 -  X3-29417 - START
If func AFNC.ACTIV("EVAEN")=0 : End : Endif
Diszo [M:EVA1]EVALEVOBJ(nolign-1)
[M:EVA1]DETSTA(nolign-1) = 1
Affzo [M:EVA1]DETSTA(nolign-1)
#Setting the reviewer for display only
[M:EVA1]ORIMAT(nolign-1) = [M:EVA0]EVAMAT
Affzo [M:EVA1]ORIMAT(nolign-1)
#Reset the final flg
[M:EVA1]DETFNLFLG = 1
Affzo [M:EVA1]DETFNLFLG
Diszo [M:EVA1]DETFNLFLG
#ANMCL - 2017-05-08 -  X3-29417 - END
End

Subprog AM_EVACRIT(VALEUR)
Variable Char    VALEUR()
#ANMCL - 2017-05-08 -  X3-29417 - START
If func AFNC.ACTIV("EVAEN")=0 : End : Endif
Diszo [M:EVA1]EVALEVOBJ(nolign-1)
[M:EVA1]DETFNLFLG = 1
Affzo [M:EVA1]DETFNLFLG
Diszo [M:EVA1]DETFNLFLG
#ANMCL - 2017-05-08 -  X3-29417 - END
End

Subprog AM_DETSTA(VALEUR)
Variable Integer VALEUR
#[M:EVA1]ORIMAT(nolign-1) = [M:EVA0]EVAMAT
If func AFNC.ACTIV("EVAEN")=0 : End : Endif
If VALEUR = 1 : End : Endif

[M:EVA1]DETFNLFLG = 1
Affzo [M:EVA1]DETFNLFLG
End


