######################################################################################
## Etiquette ajoutée par le superviseur (écran EVA2) 13/09/2010 14:50:04 (JML)
######################################################################################
Subprog AM_CPCVAL(VALEUR)
Variable Char    VALEUR()

Local    Integer I,J
#  SEGAY - 16/01/13 - EXI 87090 US1222
#  Test doublon
For L_IJ=0 To nolign-2
 If [M:EVA2]CPCVAL(L_IJ)=VALEUR
  # Compétence déjà saisie à la même date
  GMESSAGE = mess(20,10720,1)
  mkstat = 2 : Break
 Endif
Next L_IJ
If mkstat=2 : End : Endif

Call LECTURE("CPC",VALEUR,"") From CONTOBJ
If !fstat
 Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
 If !fstat
  I = find("",[F:HRSCA]LEV)
  J = find(min([F:HRSCA]LEVREF(0..I-2)),[F:HRSCA]LEVREF(0..I-2))
  If J
   [M:EVA2]LEVCPCVAL(nolign-1) = [F:HRSCA]LEV(J-1)
   [M:EVA2]LEVREFVAL(nolign-1) = func SUBECP.CPC_LEVREF([F:CPC]COD,[F:HRSCA]LEV(J-1))
   [M:EVA2]LEVREFEVA(nolign-1) = 0
   Affzo [EVA2]LEVCPCVAL(nolign-1),LEVREFVAL(nolign-1),LEVREFEVA(nolign-1)
  Endif
 Endif
Endif
Gosub MOD_VAL
End
$MOD_VAL
[M:EVA2]ORICPCVAL(nolign-1) = len(mess(0,10939,1)) : # ML 2402 Manuelle
[M:EVA2]FLGMODVAL(nolign-1) = 2
Affzo [EVA2]ORICPCVAL(nolign-1),FLGMODVAL(nolign-1)
Return
######################################################################################
Subprog AS_LEVCPCEVA(VALEUR)
Variable Char    VALEUR()
Local    Integer I,J
If VALEUR=""
 Call LECTURE("CPC",[M:EVA2]CPCVAL(nolign-1),"") From CONTOBJ
 If !fstat
  Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
  If !fstat
   I = find("",[F:HRSCA]LEV)
   J = find(min([F:HRSCA]LEVREF(0..I-2)),[F:HRSCA]LEVREF(0..I-2))
   If J : VALEUR = [F:HRSCA]LEV(J-1) : Endif
  Endif
 Endif
Endif
End

Subprog AM_LEVCPCEVA(VALEUR)
Variable Char    VALEUR()
Local Integer L_IJ
# Modif de l'origine d'une compétence non saisie => on passe l'origine à Manuelle
If !find([M:EVA2]ORICPCVAL(nolign-1),1,len(mess(0,10939,1)))
 [M:EVA2]ORICPCVAL(nolign-1) = len(mess(0,10939,1))
Endif
[M:EVA2]LEVREFEVA(nolign-1) = func SUBECP.CPC_LEVREF([M:EVA2]CPCVAL(nolign-1),VALEUR)
Gosub MOD_VAL

# JML 29/09/10 CG MAJ temps réél du graphique
# Now some graphicals, Learned
L_IJ = find([M:EVA2]CPCVAL(nolign-1),[M:EVA2]CPCGRA(0..[M:EVA2]NBRGRA-1))
If L_IJ
 [M:EVA2]ACQUIS(L_IJ-1)   = [M:EVA2]LEVREFEVA(nolign-1)
Else
 # DBA 30/09 : Add the condition to make a test about 'full table'
 # SEGAY 22/01/13 BUG 87090 ACTIV CODE CGI
#If [M:EVA2]NBRGRA<func AFNC.ACTIV("HRCPC")
 If [M:EVA2]NBRGRA<dim([M:EVA2]CPCGRA)
#ANMCL - 2017-05-08 -  X3-29417 - START
  #[M:EVA2]CPCGRA([M:EVA2]NBRGRA)   = [F:EVC]EVACPC
  [M:EVA2]CPCGRA([M:EVA2]NBRGRA)   = [M:EVA2]CPCVAL(nolign-1)
#ANMCL - 2017-05-08 -  X3-29417 - END
  [M:EVA2]ACQUIS([M:EVA2]NBRGRA)   = [M:EVA2]LEVREFEVA(nolign-1)
  [M:EVA2]NBRGRA += 1
 Else
  # Tableau plein
  Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
 Endif
Endif
Affzo [EVA2]20  : # Le tableau graphique...
End

Subprog AS_ORICPCVAL(VALEUR)
Variable Integer VALEUR
# Modification de l'origine de la compétence interdite si
# la compétence antérieure n'est ni initiale ni manuelle
If [M:EVA2]FLGOLDVAL(nolign-1)=2 & !find(VALEUR,1,len(mess(0,10939,1)))
 mkstat=2 : End
Endif
Raz GMENLOC
GMENLOC(1) = 1 : # Initial
GMENLOC(2) = 1 : # Stage
GMENLOC(3) = 0 : # Evaluation Seul choix du ML 2402 autorisé
GMENLOC(4) = 1 : # Poste
GMENLOC(5) = 1 : # Emploi type
GMENLOC(6) = 1 : # Manuel
Gosub MOD_VAL
VALEUR = len(mess(0,10939,1)) : # ML 2402 Manuel
mkstat = 2 : End
End

Subprog AS_EVACPCDATVAL(VALEUR)
Variable Date    VALEUR
# Modification de la date interdite si c'est une compétence antérieure
If [M:EVA2]FLGOLDVAL(nolign-1)=2
 mkstat=2 : End
Endif
If VALEUR=[0/0/0] : VALEUR = datesyst : Endif
End

