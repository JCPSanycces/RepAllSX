######################################################################################
## Etiquette ajoutée par le superviseur (écran EVA2) 12/08/2010 09:43:59 (JML)
######################################################################################
# On charge toutes les compétences non déjà saisies, avec leurs derniers niveaux
Subprog B1_NBRCPC

Local Integer J, L_IJ
# JML 10/09/10 On supprime avant de recharger
Raz GMESSAGE
For nolign=1 To [M:EVA2]NBRCPC
#If [M:EVA2]FLGOLD(nolign-1)=2 & find([M:EVA2]ORICPC(nolign-1),1,4,len(mess(0,10939,1)))
 If [M:EVA2]FLGOLD(L_IJ)=2
  If [M:EVA2]NBRDLT>=dim([M:EVA2]CPCDLT)
   # Veuillez enregistrer les modifications avant de continuer.
   GMESSAGE = mess(558,9900,1)
   Break
  Endif
  [M:EVA2]CPCDLT([M:EVA2]NBRDLT) = [M:EVA2]EVACPC(nolign-1)
  [M:EVA2]DATDLT([M:EVA2]NBRDLT) = [M:EVA2]EVACPCDAT(nolign-1)
  [M:EVA2]NBRDLT +=1
 Endif
Next nolign
If GMESSAGE<>""
#ANMCL - 2017-05-08 -  X3-29417 - START
# Call ERREUR(GMESSAGE) From GESECRAN
  #From GENCEV
  If dim([V]IS_GENCEV)>0 & [V]IS_GENCEV=1 Then
    Call ECR_TRACE(GMESSAGE,0) From GESECRAN
  Else
    Call ERREUR(GMESSAGE) From GESECRAN
 Endif
#ANMCL - 2017-05-08 -  X3-29417 - END
 GMESSAGE = ""
 mkstat = 2 : End
Endif
For L_IJ=[M:EVA2]NBRGRA-1 To 0 Step -1
 If [M:EVA2]ACQUIS(L_IJ)<>0
  [M:EVA2]REQUIS(L_IJ) = 0
 Else
  Dela L_IJ,1 [M:EVA2]NBRGRA
  [M:EVA2]NBRGRA -= 1
 Endif
Next L_IJ
#
# JML 13/09/10 CG Load from POSTE/JOBTYP
#nolign = [M:EVA2]NBRCPC
#Filter [CPE] Where [CPE]REFNUM=[M:EVA0]REFNUM & [CPE]CPCDAT=[0/0/0]
#For [CPE]CPE0
# ### CPE0 * REFNUM+CPCDAT+CPC
# If !find([F:CPE]CPC,[M:EVA2]EVACPC)
#  [M:EVA2]EVACPC(nolign) = [F:CPE]CPC
#  [M:EVA2]EVALEV(nolign) = [F:CPE]LEVCPC
#  nolign += 1
#  [M:EVA2]NBRCPC = nolign
#  Affzo [EVA2]EVACPC(nolign-1),EVALEV(nolign-1)
#  mkstat = 4            : # Pour dégriser le bouton Enregistrer
# Endif
#Next : # [CPE]CPE1
#Filter [CPE]
Effzo [EVA2]5
Call LECTURE("POT",[M:EVA0]POT,"") From CONTOBJ
nolign = 0
If [M:EVA0]POT<>"" & [F:POT]JOBPOT=[M:EVA0]JOBPOT
  For J=0 To dim([F:POT]CPC)-1
   If [F:POT]CPC(J)="" : Break : Endif
  #ANMCL - 2017-05-08 -  X3-29417 - START
  # Issue 12069 - 2017-08-18 by BRBAN : Skip the inanactive skills
  Read [F:CPC]CPC0=[F:POT]CPC(J)
  If !fstat & [F:CPC]ENAFLG=2
  #ANMCL - 2017-05-08 -  X3-29417 - END
   If !find([F:POT]CPC(J),[M:EVA2]EVACPC)
&     &  (dim([M:EVA0]EVALEG)< 0 | (func SUBJOT.CHECKLEG_CPC([F:POT]CPC(J),[M:EVA0]EVALEG))) # SEGAY 25/10/12 US 930 81085

    [M:EVA2]EVACPC(nolign) = [F:POT]CPC(J)
    [M:EVA2]EVALEV(nolign) = [F:POT]NIV(J)
    [M:EVA2]LEVREF(nolign) = func SUBECP.CPC_LEVREF([F:POT]CPC(J),[F:POT]NIV(J))
#    SEGAY 12/05/11 73791
#    If [F:POT]ORI(J)<>4
    If [F:POT]ORI(J)<>4 & [F:POT]ORI(J)<>len(mess(0,10937,1)) # ML 2400 Groupe compétence ou manuelle
     [M:EVA2]ORICPC(nolign) = [F:POT]ORI(J)
    Else
     # Si =4 ML 2400 Groupe de compétence
     [M:EVA2]ORICPC(nolign) = 6 : # ML 2400 Poste
    Endif
    #ANMCL - 2017-05-08 -  X3-29417 - START
    # Issue 12069 - 2017-08-18 by BRBAN : CPC read before
    #Call LECTURE("CPC",[M:EVA2]EVACPC(nolign),"") From CONTOBJ#Call LECTURE("CPC",[M:EVA2]EVACPC(nolign),"") From CONTOBJ
    #ANMCL - 2017-05-08 -  X3-29417 - END
    [M:EVA2]CODSCACPC(nolign) = [F:CPC]CODSCA
    [M:EVA2]FLGMOD(nolign)  = 1
    [M:EVA2]FLGOLD(nolign)  = 1 : # Oui ou Non ? Plutôt non car pas encore enregistré (Attention pour B1 init)
    nolign += 1
    [M:EVA2]NBRCPC = nolign
    mkstat = 4            : # Pour dégriser le bouton Enregistrer
   Endif
  Endif
  Next J
  For J=0 To [M:EVA2]NBRCPC-1
   L_IJ = find([M:EVA2]EVACPC(J),[M:EVA2]CPCGRA(0..[M:EVA2]NBRGRA-1))
   If L_IJ
    [M:EVA2]REQUIS(L_IJ-1)   = [M:EVA2]LEVREF(J)
   Else
    # DBA 30/09 : Add the condition to make a test about 'full table'
     # SEGAY 22/01/13 BUG 87090 ACTIV CODE CGI
#   If [M:EVA2]NBRGRA<func AFNC.ACTIV("HRCPC")
    If [M:EVA2]NBRGRA<dim([M:EVA2]CPCGRA)
     [M:EVA2]CPCGRA([M:EVA2]NBRGRA)   = [M:EVA2]EVACPC(J)
     [M:EVA2]REQUIS([M:EVA2]NBRGRA)   = [M:EVA2]LEVREF(J)
     [M:EVA2]NBRGRA += 1
    Else
     # Tableau plein
      #ANMCL - 2017-05-08 -  X3-29417 - START
      #From GENCEV
      If dim([V]IS_GENCEV)>0 & [V]IS_GENCEV=1 Then
        Call ECR_TRACE("Ecarts : "-mess(26,100,1),0) From GESECRAN
      Else
        Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
     Endif
     #ANMCL - 2017-05-08 -  X3-29417 - END
     Break
    Endif
   Endif
  Next J
Elsif [M:EVA0]JOBPOT<>""
  Call LECTURE("JOT",[M:EVA0]JOBPOT,"") From CONTOBJ
  For J=0 To dim([F:JOT]CPC)-1
   If [F:JOT]CPC(J)="" : Break : Endif
   If !find([F:JOT]CPC(J),[M:EVA2]EVACPC)
&     &  (dim([M:EVA0]EVALEG)< 0 | (func SUBJOT.CHECKLEG_CPC([F:JOT]CPC(J),[M:EVA0]EVALEG))) # SEGAY 25/10/12 US 930 81085

    [M:EVA2]EVACPC(nolign) = [F:JOT]CPC(J)
    [M:EVA2]EVALEV(nolign) = [F:JOT]NIV(J)
    [M:EVA2]LEVREF(nolign) = func SUBECP.CPC_LEVREF([F:JOT]CPC(J),[F:JOT]NIV(J))
#    SEGAY 12/05/11 73791
#    If [F:JOT]ORI(J)<>4
    If [F:JOT]ORI(J)<>4 & [F:JOT]ORI(J)<>len(mess(0,10937,1)) # ML 2400 Groupe compétence ou manuelle
     [M:EVA2]ORICPC(nolign) = [F:JOT]ORI(J)
    Else
     # Si =4 ML 2400 Groupe de compétence
# Segay 10/11/10 lot P02
#     [M:EVA2]ORICPC(nolign) = 6 : # ML 2400 Poste
     [M:EVA2]ORICPC(nolign) = 5 : # ML 2400 Emploi type
    Endif
    Call LECTURE("CPC",[M:EVA2]EVACPC(nolign),"") From CONTOBJ
    [M:EVA2]CODSCACPC(nolign) = [F:CPC]CODSCA
    [M:EVA2]FLGMOD(nolign)  = 1
    [M:EVA2]FLGOLD(nolign)  = 1 : # Oui ou Non ? Plutôt non car pas encore enregistré (Attention pour B1 init)
    nolign += 1
    [M:EVA2]NBRCPC = nolign
    mkstat = 4            : # Pour dégriser le bouton Enregistrer
   Endif
  Next J
  For J=0 To [M:EVA2]NBRCPC-1
   L_IJ = find([M:EVA2]EVACPC(J),[M:EVA2]CPCGRA(0..[M:EVA2]NBRGRA-1))
   If L_IJ
    [M:EVA2]REQUIS(L_IJ-1)   = [M:EVA2]LEVREF(J)
   Else
    # DBA 30/09 : Add the condition to make a test about 'full table'
     # SEGAY 22/01/13 BUG 87090 ACTIV CODE CGI
#   If [M:EVA2]NBRGRA<func AFNC.ACTIV("HRCPC")
    If [M:EVA2]NBRGRA<dim([M:EVA2]CPCGRA)
     [M:EVA2]CPCGRA([M:EVA2]NBRGRA)   = [M:EVA2]EVACPC(J)
     [M:EVA2]REQUIS([M:EVA2]NBRGRA)   = [M:EVA2]LEVREF(J)
     [M:EVA2]NBRGRA += 1
    Else
     # Tableau plein
     #ANMCL - 2017-05-08 -  X3-29417 - START
     #Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
       #From GENCEV
      If dim([V]IS_GENCEV)>0 & [V]IS_GENCEV=1 Then
        Call ECR_TRACE("Ecarts : "-mess(26,100,1),0) From GESECRAN
      Else
        Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
     Endif
     #ANMCL - 2017-05-08 -  X3-29417 - END
     Break
    Endif
   Endif
  Next J
Endif
[M:EVA2]NBRCPC = nolign
If [M:EVA2]NBRCPC>0 Then
  Sorta [M:EVA2]NBRCPC [M:EVA2]NBRCPC Order By [M:EVA2]EVACPC([S]indice)
  Sorta [M:EVA2]NBRGRA [M:EVA2]NBRGRA Order By [M:EVA2]CPCGRA([S]indice)
Endif
Affzo [EVA2]5,20 : # Requis
If [M:EVA2]NBRCPC
 mkstat = 4            : # Pour dégriser le bouton Enregistrer
Endif
End

Subprog C_NBRCPC
Local Integer I
# Le tableau n'a que l'Option K, mais toutes les zones sont affichées...
# Pas moyen de mettre le focus X3 sur le tableau pour avoir les boutons
# Si on ajoute l'option R, Ôh le joli bug, le tableau se remplit de lignes vides
# Vu MB, pas beaucoup d'espoir. Donc je laisse l'option R mais je bloque les status adéquats...
If find(status,82,75)
 mkstat = 2 : End
Endif
# Suppression interdite sur les compétences antérieures héritées (non initiale et non manuelle et non poste)
If status=65 & [M:EVA2]FLGOLD(nolign-1)=2 & !find([M:EVA2]ORICPC(nolign-1),1,4,len(mess(0,10939,1)))
 # Il est interdit de supprimer des compétences mises à jour automatiquement
 GMESSAGE = mess(19,10720,1)
 mkstat = 2 : End
Endif
# On stocke dans le tableau invisible, les compétences supprimées
If status=65 & [M:EVA2]FLGOLD(nolign-1)=2 & find([M:EVA2]ORICPC(nolign-1),1,4,len(mess(0,10939,1)))
 If [M:EVA2]NBRDLT>=dim([M:EVA2]CPCDLT)
  # Veuillez enregistrer les modifications avant de continuer.
  GMESSAGE = mess(558,9900,1)
  mkstat=2 : End
 Endif
 #SEGAY 23/02/11 Bug 71819
# [M:EVA2]CPCDLT([M:EVA2]NBRDLT) = [M:EVA2]CPC(nolign-1)
# [M:EVA2]DATDLT([M:EVA2]NBRDLT) = [M:EVA2]CPCDAT(nolign-1)
 [M:EVA2]CPCDLT([M:EVA2]NBRDLT) = [M:EVA2]EVACPC(nolign-1)
 [M:EVA2]DATDLT([M:EVA2]NBRDLT) = [M:EVA2]EVACPCDAT(nolign-1)
 #END_Bug 71819

 [M:EVA2]NBRDLT +=1
Endif
End

Subprog AS_EVACPC(VALEUR)
Variable Char    VALEUR()
# Modification de la compétence interdite si c'est une compétence antérieure
If [M:EVA2]FLGOLD(nolign-1)=2
 mkstat=2 : End
Endif
End

Subprog AM_EVACPC(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]EVACPC) From OBJDIV
If mkstat : End : Endif

# Afficher le dernier niveau acquis pour cette compétence
Filter [CPE] Where [CPE]REFNUM=[M:EVA0]REFNUM & [CPE]CPC=VALEUR
Read [CPE]CPE1 Last
Filter [CPE]
If !fstat
 [M:EVA2]EVALEV(nolign-1) = [F:CPE]LEVCPC
Else
 Call BASNIVCPC(VALEUR,[M:EVA2]EVALEV(nolign-1)) From SUBCPC
Endif
End

Subprog AS_EVALEV(VALEUR)
Variable Char    VALEUR()
Local    Integer I,J
If VALEUR=""
 Call LECTURE("CPC",[M:EVA2]EVACPC(nolign-1),"") From CONTOBJ
 If !fstat
  Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
  If !fstat
   I = find("",[F:HRSCA]LEV)
   J = find(min([F:HRSCA]LEVREF(0..I-2)),[F:HRSCA]LEVREF(0..I-2))
   If J : VALEUR = [F:HRSCA]LEV(J-1) : Endif
  Endif
 Endif
Endif
End

Subprog AM_EVALEV(VALEUR)
Variable Char    VALEUR()
# Modif de l'origine d'une compétence non saisie => on passe l'origine à Manuelle
If [M:EVA2]ORICPC(nolign-1)<>1 | [M:EVA2]ORICPC(nolign-1)<>len(mess(0,10939,1))
 [M:EVA2]ORICPC(nolign-1) = len(mess(0,10939,1))
Endif
[M:EVA2]LEVREF(nolign-1) = func SUBECP.CPC_LEVREF([M:EVA2]EVACPC(nolign-1),VALEUR)
End

Subprog AS_EVACPCDAT(VALEUR)
Variable Date    VALEUR
# Modification de la date interdite si c'est une compétence antérieure
If [M:EVA2]FLGOLD(nolign-1)=2
 mkstat=2 : End
Endif
If VALEUR=[0/0/0] : VALEUR = datesyst : Endif
End

Subprog AS_ORICPC(VALEUR)
Variable Integer    VALEUR()
# Modification de l'origine de la compétence interdite si
# la compétence antérieure n'est ni initiale ni manuelle
If [M:EVA2]FLGOLD(nolign-1)=2 & VALEUR<>1 & VALEUR<>len(mess(0,10939,1))
 mkstat=2 : End
Endif
Raz GMENLOC
GMENLOC(2) = 1 : # Stage
GMENLOC(3) = 1 : # Evaluation
GMENLOC(4) = 1 : # Poste
GMENLOC(5) = 1 : # Emploi type
End
###############
Subprog C_NBRVAL
Local Integer I
# Suppression interdite sur les compétences antérieures héritées (non initiale et non manuelle et non poste)
If status=65 & [M:EVA2]FLGOLDVAL(nolign-1)=2 & !find([M:EVA2]ORICPCVAL(nolign-1),1,4,len(mess(0,10939,1)))
 # Il est interdit de supprimer des compétences mises à jour automatiquement
 GMESSAGE = mess(19,10720,1)
 mkstat = 2 : End
Endif
# On stocke dans le tableau invisible, les compétences supprimées
If status=65 & [M:EVA2]FLGOLDVAL(nolign-1)=2 & find([M:EVA2]ORICPCVAL(nolign-1),1,4,len(mess(0,10939,1)))
 If [M:EVA2]NBRDLTVAL>=dim([M:EVA2]CPCDLTVAL)
  # Veuillez enregistrer les modifications avant de continuer.
  GMESSAGE = mess(558,9900,1)
  mkstat=2 : End
 Endif
#  SEGAY 05/06/12 - FQ82661
# [M:EVA2]CPCDLTVAL([M:EVA2]NBRDLT) = [M:EVA2]CPCVAL(nolign-1)
# [M:EVA2]DATDLTVAL([M:EVA2]NBRDLT) = [M:EVA2]EVACPCDATVAL(nolign-1)
 [M:EVA2]CPCDLTVAL([M:EVA2]NBRDLTVAL) = [M:EVA2]CPCVAL(nolign-1)
 [M:EVA2]DATDLTVAL([M:EVA2]NBRDLTVAL) = [M:EVA2]EVACPCDATVAL(nolign-1)
 [M:EVA2]NBRDLTVAL +=1
Endif
#ANMCL - 2017-05-08 -  X3-29417 - START
#ISSUE 11472 - 2017-09-20 By BRBAN : CONTROL THE NEW Field STGCOD
If func AFNC.ACTIV("FRT")>0
  If [M:EVA2]LEVCPCEVA(nolign-1)<>''
    Actzo [M:EVA2]STGCOD(nolign-1)
  Else
    Raz [M:EVA2]STGCOD(nolign-1)
    Diszo [M:EVA2]STGCOD(nolign-1)
    Affzo [M:EVA2]STGCOD(nolign-1)
  Endif
Endif
# -
#ANMCL - 2017-05-08 -  X3-29417 - END
End

# segay 24/12/10 LOT P02
# Suppresion du bouton Ini compétences si le cycle d'évaluation > en cours
Subprog IB_NBRVAL
# FQ85052 - MABOS - 08/04/13 - Insertion d'un item dans le menu local 10947 en position 2 ==>
#If [M:EVA0]EVAVAL>1 : # ML 10947 En cours
If [M:EVA0]EVAVAL>2 : # ML 10947 En cours
  Raz GBOUT1
Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran EVA2) 13/09/2010 12:40:34 (JML)
## JML 13/09/10 CG Init like 'Compétences validées dans Carrière'
######################################################################################
Subprog B1_NBRVAL
Local Integer L_IJ

For L_IJ=0 To [M:EVA2]NBRVAL-1
 If [M:EVA2]FLGOLDVAL(L_IJ)=2
  If [M:EVA2]NBRDLTVAL>=dim([M:EVA2]CPCDLTVAL)
   # Veuillez enregistrer les modifications avant de continuer.
   GMESSAGE = mess(558,9900,1)
   mkstat=2 : Break
  Endif
#  SEGAY 05/06/12 -FQ82661
#  [M:EVA2]CPCDLTVAL([M:EVA2]NBRDLT) = [M:EVA2]CPCVAL(L_IJ)
#  [M:EVA2]DATDLTVAL([M:EVA2]NBRDLT) = [M:EVA2]EVACPCDATVAL(L_IJ)
  [M:EVA2]CPCDLTVAL([M:EVA2]NBRDLTVAL) = [M:EVA2]CPCVAL(L_IJ)
  [M:EVA2]DATDLTVAL([M:EVA2]NBRDLTVAL) = [M:EVA2]EVACPCDATVAL(L_IJ)
  [M:EVA2]NBRDLTVAL +=1
 Endif
Next L_IJ
If mkstat
  #ANMCL - 2017-05-08 -  X3-29417 - START
  #Call ERREUR(GMESSAGE) From GESECRAN
  If dim([V]IS_GENCEV)>0 & [V]IS_GENCEV=1 Then
    Call ECR_TRACE("Ecarts : "-mess(26,100,1),0) From GESECRAN
  Else
    Call ERREUR(GMESSAGE) From GESECRAN
  Endif
  #ANMCL - 2017-05-08 -  X3-29417 - END
  GMESSAGE = ""
 End
Endif
Effzo [EVA2]15 : # Validées
For L_IJ=[M:EVA2]NBRGRA-1 To 0 Step -1
 If [M:EVA2]REQUIS(L_IJ)<>0
  [M:EVA2]ACQUIS(L_IJ) = 0
 Else
  Dela L_IJ,1 [M:EVA2]NBRGRA
  [M:EVA2]NBRGRA -= 1
 Endif
Next L_IJ
nolign=0
For [CPE]CPE1(2) Where [F:CPE]REFNUM=[M:EVA0]REFNUM & [F:CPE]CPCDAT<>[0/0/0]
&   & [F:CPE]CPC <> "" #     SEGAY - 25/01/13 - BUG 87490 + BUG 87492
 # CPE1 * REFNUM+CPC+CPCDAT
# FQ81085 - SEGAY 12/09/12 - US740  CPC of CPE in a different legislation than the contract
 Call LECTURE("CPC",[F:CPE]CPC,"") From CONTOBJ
# If [F:CPC]LEG="" | (dim([M:EVA0]EVALEG)> 0 & [F:CPC]LEG<>"" & [F:CPC]LEG=[M:EVA0]EVALEG) Then
 If dim([M:EVA0]EVALEG)< 0 | [F:CPC]LEG="" | (dim([M:EVA0]EVALEG)> 0 & [F:CPC]LEG<>"" & [F:CPC]LEG=[M:EVA0]EVALEG) Then
# If dim([M:EVA0]EVALEG)< 0 | (func SUBJOT.CHECKLEG_CPC([F:CPE]CPC,[M:EVA0]EVALEG)) # SEGAY 25/10/12 US 930 81085
# SEGAY - 24/12/10 - EXI 66105 LOT P02 - V6.1
   If nolign>=dim([M:EVA2]CPCVAL)
     # Trop de compétences à analyser
#ANMCL - 2017-05-08 -  X3-29417 - START
     #Call ERREUR( mess(48,10720,1)-num$(dim([M:EVA2]CPCVAL))) From GESECRAN
      If dim([V]IS_GENCEV)>0 & [V]IS_GENCEV=1 Then
        Call ECR_TRACE(mess(48,10720,1)-num$(dim([M:EVA2]CPCVAL)),0) From GESECRAN
      Else
        Call ERREUR( mess(48,720,1)-num$(dim([M:EVA2]CPCVAL))) From GESECRAN
      Endif
#ANMCL - 2017-05-08 -  X3-29417 - END
     Break
   Endif

   nolign+=1
   For [CPE]CPE1
    # Watchout here, don't make a 'transclass' !
    [M:EVA2]CPCVAL(nolign-1)       = [F:CPE]CPC
    [M:EVA2]LEVCPCVAL(nolign-1)    = [F:CPE]LEVCPC
    [M:EVA2]LEVREFVAL(nolign-1)    = func SUBECP.CPC_LEVREF([F:CPE]CPC,[F:CPE]LEVCPC)
    [M:EVA2]LEVREFEVA(nolign-1)    = 0
    [M:EVA2]EVACPCDATVAL(nolign-1) = [F:CPE]CPCDAT
    [M:EVA2]ORICPCVAL(nolign-1)    = [F:CPE]ORICPC
    [M:EVA2]FLGMODVAL(nolign-1)    = 1
    [M:EVA2]FLGOLDVAL(nolign-1)    = 1 : # Oui ou Non ? Plutôt non car pas encore enregistré (Attention pour B1 init)
    mkstat = 4
    # Now some graphicals, Learned
    L_IJ = find([F:CPE]CPC,[M:EVA2]CPCGRA(0..[M:EVA2]NBRGRA-1))
    If L_IJ
     [M:EVA2]ACQUIS(L_IJ-1)   = [M:EVA2]LEVREFVAL(nolign-1)
    Else
     # DBA 30/09 : Add the condition to make a test about 'full table'
     # SEGAY 22/01/13 BUG 87090 ACTIV CODE CGI
#   If [M:EVA2]NBRGRA<func AFNC.ACTIV("HRCPC")
    If [M:EVA2]NBRGRA<dim([M:EVA2]CPCGRA)
      [M:EVA2]CPCGRA([M:EVA2]NBRGRA)   = [F:CPE]CPC
      [M:EVA2]ACQUIS([M:EVA2]NBRGRA)   = [M:EVA2]LEVREFVAL(nolign-1)
      [M:EVA2]NBRGRA += 1
     Else
      # Tableau plein
      #ANMCL - 2017-05-08 -  X3-29417 - START
      #Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
       #From GENCEV
      If dim([V]IS_GENCEV)>0 & [V]IS_GENCEV=1 Then
        Call ECR_TRACE("Ecarts : "-mess(26,100,1),0) From GESECRAN
      Else
        Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
      Endif
      #ANMCL - 2017-05-08 -  X3-29417 - END
      Break 2
     Endif
    Endif
   Next : # [CPE]CPE1
   # JML 10/09/10 CG Tunnel Echelle
   Call LECTURE("CPC",[F:CPE]CPC,"") From CONTOBJ
   [M:EVA2]CODSCAVAL(nolign-1) = [F:CPC]CODSCA
 Endif
Next : # [CPE]CPE1(2)
[M:EVA2]NBRVAL = nolign
#ANMCL - 2017-05-08 -  X3-29417 - START
#If [M:EVA2]NBRVAL>0 Then
#  Sorta [M:EVA2]NBRVAL [M:EVA2]NBRVAL Order By [M:EVA2]CPCVAL([S]indice)
#  Sorta [M:EVA2]NBRGRA [M:EVA2]NBRGRA Order By [M:EVA2]CPCGRA([S]indice)
#Endif
#FRLAA (X3-11377-X3-12429) 2017-01-19 START - COMMENT
#If [M:EVA2]NBRVAL>0 Then
#  Sorta [M:EVA2]NBRVAL [M:EVA2]NBRVAL Order By [M:EVA2]CPCVAL([S]indice)
#  Sorta [M:EVA2]NBRGRA [M:EVA2]NBRGRA Order By [M:EVA2]CPCGRA([S]indice)
#Endif
#FRLAA (X3-11377-X3-12429) 2017-01-19 END - COMMENT

#FRLAA (X3-11377-X3-12429) 2017-01-19 START
#We need to check if there were any validated skills for this employee
#If there are no validated skills we need to default the grid to all requested skills
#This will make it easier for the user to complete

#First we check if there were any values populated on the grid

#ANMCL - 2017-05-08 -  X3-29417 - START
# Issue X3-46189 - 2017-06-27 by XBRBA : GFONCTION = "GESEVA" was blocking the filling of the table in GENCPC and GENCEV functions
# Issue X3-49143 - 2017-08-24 By BRBAN : If there are any new skills skills in the POSTE it must be load in the evaluated skills for the user to complete
#If [M:EVA2]NBRVAL = 0 #and GFONCTION = "GESEVA"
#ANMCL - 2017-05-08 -  X3-29417 - END
  # Load from POSTE/JOBTYP
  Call LECTURE("POT",[M:EVA0]POT,"") From CONTOBJ
  # Issue X3-49143 - 2017-08-24 By BRBAN : If there are any new skills skills in the POSTE it must be load in the evaluated skills for the user to complete
  #nolign = 0
  If [M:EVA0]POT<>"" & [F:POT]JOBPOT=[M:EVA0]JOBPOT
    For J=0 To dim([F:POT]CPC)-1
     If [F:POT]CPC(J)="" : Break : Endif
     #ANMCL - 2017-05-08 -  X3-29417 - START
     # Issue 12069 - 2017-08-18 by BRBAN : Skip the inanactive skills
     Read [F:CPC]CPC0=[F:POT]CPC(J)
     If !fstat & [F:CPC]ENAFLG=2
     If nolign<dim([M:EVA2]CPCVAL)
     #ANMCL - 2017-05-08 -  X3-29417 - END
     If !find([F:POT]CPC(J),[M:EVA2]CPCVAL)
      [M:EVA2]CPCVAL(nolign)    = [F:POT]CPC(J)
      [M:EVA2]LEVCPCVAL(nolign) = [F:POT]NIV(J)
      [M:EVA2]LEVREFVAL(nolign) = func SUBECP.CPC_LEVREF([F:POT]CPC(J),[F:POT]NIV(J))
      If [F:POT]ORI(J)<>4 & [F:POT]ORI(J)<>len(mess(0,2400,1)) # ML 2400 Groupe compétence ou manuelle
       [M:EVA2]ORICPCVAL(nolign) = [F:POT]ORI(J)
      Else
       # Si =4 ML 2400 Groupe de compétence
       [M:EVA2]ORICPCVAL(nolign) = 6 : # ML 2400 Poste
      Endif
      Call LECTURE("CPC",[M:EVA2]CPCVAL(nolign),"") From CONTOBJ
      [M:EVA2]CODSCAVAL(nolign) = [F:CPC]CODSCA
      [M:EVA2]FLGMODVAL(nolign)  = 1
      [M:EVA2]FLGOLDVAL(nolign)  = 1 : # Oui ou Non ? Plutôt non car pas encore enregistré (Attention pour B1 init)
      nolign += 1
      [M:EVA2]NBRVAL = nolign
      mkstat = 4            : # Pour dégriser le bouton Enregistrer
     Endif
    Endif
    Endif
    Next J
    For J=0 To [M:EVA2]NBRVAL-1
     L_IJ = find([M:EVA2]CPCVAL(J),[M:EVA2]CPCGRA(0..[M:EVA2]NBRGRA-1))
     If L_IJ
      [M:EVA2]REQUIS(L_IJ-1)   = [M:EVA2]LEVREFVAL(J)
     Else
      # Add the condition to make a test about 'full table'
       # ACTIV CODE CGI
      If [M:EVA2]NBRGRA<dim([M:EVA2]CPCGRA)
       [M:EVA2]CPCGRA([M:EVA2]NBRGRA)   = [M:EVA2]CPCVAL(J)
       [M:EVA2]REQUIS([M:EVA2]NBRGRA)   = [M:EVA2]LEVREFVAL(J)
       [M:EVA2]NBRGRA += 1
      Else
       # Tableau plein
         #From GENCEV
        If dim([V]IS_GENCEV)>0 & [V]IS_GENCEV=1 Then
          Call ECR_TRACE("Ecarts : "-mess(26,100,1),0) From GESECRAN
        Else
          Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
       Endif
       Break
      Endif
     Endif
    Next J
  Elsif [M:EVA0]JOBPOT<>""
    Call LECTURE("JOT",[M:EVA0]JOBPOT,"") From CONTOBJ
    For J=0 To dim([F:JOT]CPC)-1
     If [F:JOT]CPC(J)="" : Break : Endif
     #ANMCL - 2017-05-08 -  X3-29417 - START
     # Issue 12069 - 2017-08-18 by BRBAN : Skip the inanactive skills
     Read [F:CPC]CPC0=[F:JOT]CPC(J)
     If !fstat & [F:CPC]ENAFLG=2
     If nolign<dim([M:EVA2]CPCVAL)
     #ANMCL - 2017-05-08 -  X3-29417 - END
     If !find([F:JOT]CPC(J),[M:EVA2]CPCVAL)
      [M:EVA2]CPCVAL(nolign) = [F:JOT]CPC(J)
      [M:EVA2]LEVCPCVAL(nolign) = [F:JOT]NIV(J)
      [M:EVA2]LEVREFVAL(nolign) = func SUBECP.CPC_LEVREF([F:JOT]CPC(J),[F:JOT]NIV(J))
      If [F:JOT]ORI(J)<>4 & [F:JOT]ORI(J)<>len(mess(0,2400,1)) # ML 2400 Groupe compétence ou manuelle
       [M:EVA2]ORICPCVAL(nolign) = [F:JOT]ORI(J)
      Else
       # Si =4 ML 2400 Groupe de compétence
       [M:EVA2]ORICPCVAL(nolign) = 5 : # ML 2400 Emploi type
      Endif
      #ANMCL - 2017-05-08 -  X3-29417 - START
      # Issue 12069 - 2017-08-18 by BRBAN : Allready read at the top
      #Call LECTURE("CPC",[M:EVA2]CPCVAL(nolign),"") From CONTOBJ
      #ANMCL - 2017-05-08 -  X3-29417 - END
      [M:EVA2]CODSCAVAL(nolign) = [F:CPC]CODSCA
      [M:EVA2]FLGMODVAL(nolign)  = 1
      [M:EVA2]FLGOLDVAL(nolign)  = 1 : # Oui ou Non ? Plutôt non car pas encore enregistré (Attention pour B1 init)
      nolign += 1
      [M:EVA2]NBRVAL = nolign
      mkstat = 4            : # Pour dégriser le bouton Enregistrer
     Endif
     Else
     #ANMCL - 2017-05-08 -  X3-29417 - START
     # Tableau plein
       #From GENCEV
       If dim([V]IS_GENCEV)>0 & [V]IS_GENCEV=1 Then
          Call ECR_TRACE("Ecarts : "-mess(26,100,1),0) From GESECRAN
       Else
          Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
       Endif
       Break
     #ANMCL - 2017-05-08 -  X3-29417 - END
     Endif
     Endif
    Next J
    For J=0 To [M:EVA2]NBRVAL-1
     L_IJ = find([M:EVA2]CPCVAL(J),[M:EVA2]CPCGRA(0..[M:EVA2]NBRGRA-1))
     If L_IJ
      [M:EVA2]REQUIS(L_IJ-1)   = [M:EVA2]LEVREFVAL(J)
     Else
      # Add the condition to make a test about 'full table'
       # ACTIV CODE CGI
      If [M:EVA2]NBRGRA<dim([M:EVA2]CPCGRA)
       [M:EVA2]CPCGRA([M:EVA2]NBRGRA)   = [M:EVA2]CPCVAL(J)
       [M:EVA2]REQUIS([M:EVA2]NBRGRA)   = [M:EVA2]LEVREFVAL(J)
       [M:EVA2]NBRGRA += 1
      Else
       # Tableau plein
         #From GENCEV
        If dim([V]IS_GENCEV)>0 & [V]IS_GENCEV=1 Then
          Call ECR_TRACE("Ecarts : "-mess(26,100,1),0) From GESECRAN
        Else
          Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
       Endif
       Break
      Endif
     Endif
    Next J
  Endif
#Endif
#FRLAA (X3-11377-X3-12429) 2017-01-19 END
#ANMCL - 2017-05-08 -  X3-29417 - START
# Issue X3-49143 - 2017-08-24 By BRBAN : If there are any new skills skills in the POSTE it must be load in the evaluated skills for the user to complete
[M:EVA2]NBRVAL = nolign
#-
#ANMCL - 2017-05-08 -  X3-29417 - END
#FRLAA (X3-11377-X3-12429) 2017-01-19 START
If [M:EVA2]NBRVAL>0 Then
  Sorta [M:EVA2]NBRVAL [M:EVA2]NBRVAL Order By [M:EVA2]CPCVAL([S]indice)
  Sorta [M:EVA2]NBRGRA [M:EVA2]NBRGRA Order By [M:EVA2]CPCGRA([S]indice)
Endif
#FRLAA (X3-11377-X3-12429) 2017-01-19 END

#ANMCL - 2017-05-08 -  X3-29417 - END
Affzo [EVA2]15,20 : # Validées
If [M:EVA2]NBRVAL
 mkstat = 4            : # Pour dégriser le bouton Enregistrer
Endif
End
