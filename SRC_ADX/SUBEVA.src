Subprog AM_CTRNUM_OLD(VALEUR)
Variable Char    VALEUR()
  Filter [HRCTR] Where [HRCTR]REFNUM=[M:EVA0]REFNUM and [HRCTR]CTRNUM=VALEUR
&                and [HRCTR]CTRDAT<=[M:EVA0]EVADAT
&                and ([HRCTR]XITDAT=[0/0/0] or [HRCTR]XITDAT>=[M:EVA0]EVADAT)
  Read [HRCTR]CTR0 Last
  If !fstat
    Gosub AFF_CTR
  Endif
  Filter [F:HRCTR]
End

#     SEGAY - 08/08/12 - EXI 81491 83397 US606
Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
  Filter [HRCTR] Where [HRCTR]REFNUM=[M:EVA0]REFNUM and [HRCTR]CTRNUM=VALEUR
&                and ([HRCTR]CTRDAT<=[M:EVA0]EVADATEND | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=[M:EVA0]EVADATEND))
&                and ([HRCTR]XITDAT=[0/0/0] or [HRCTR]XITDAT>=[M:EVA0]EVADATEND)

  Read [HRCTR]CTR0 Last
  If !fstat
# FQ81491 - SEGAY 26/09/12 - Contrôle que le salarié a les mêmes caractéristiques que le code campagne
#    Gosub AFF_CTR
    If [M:EVA0]CEV<>"" Then
      Call CTL_CEV_CTR([M:EVA0]REFNUM,VALEUR,[F:HRCTR]CTRDAT,0)
      If mkstat<>2
         Gosub AFF_CTR
      Endif
    Else
      Gosub AFF_CTR
    Endif
  Else
   If GREP="C" & !GIMPORT Then :#MABOS-25/09/13-FQ89268-US1911-
      # Salarié non présent le ../../..
      GMESSAGE = mess(38,10720,1)-num$([M:EVA0]EVADATEND)
      mkstat=2
   Endif
  Endif
  Filter [F:HRCTR]
End

######################################################################################
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
$AFF_CTR_OLD
[M:EVA0]CTRDAT = [F:HRCTR]CTRDAT
# FQ82920 - MABON 15/06/12 - Le poste et/ou l'emploi-type sont initialisés par la carrière, et si aucune donnée
# exploitable n'est trouvée dans les carrières, on les cherche dans le contrat
Filter [F:EPO] Where [EPO]REFNUM=[F:HRCTR]REFNUM & [EPO]CTRNUM=[F:HRCTR]CTRNUM and [EPO]DATPOT<=[M:EVA0]EVADAT Order By DATPOT
Read [F:EPO] Last
Filter [F:EPO]
If !fstat & ([F:EPO]POT<>"" | [F:EPO]JOBPOT<>"") Then
  [M:EVA0]POT    = [F:EPO]POT
  [M:EVA0]JOBPOT = [F:EPO]JOBPOT
Else
# Fin MABON
  [M:EVA0]POT    = [F:HRCTR]POT
  [M:EVA0]JOBPOT = [F:HRCTR]JOBPOT
Endif
Affzo [EVA0]CTRDAT,POT,ZPOT,JOBPOT,ZJOBPOT
# 71140 - SYMEU - 28/01/2011
Call SET_CPY([F:HRCTR]ETRFCY) From SUBEVA2
# FQ81085 - MABON 16/07/12 - To manage legislation in employee selection
Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
If !fstat Then GCURLEG=[F:FCY]LEG : Endif
#GSOCIETE=[M:EVA0]CPY
# End MABON
Return

#     SEGAY - 08/08/12 - EXI 81491 83397 US606
$AFF_CTR
[M:EVA0]CTRDAT = [F:HRCTR]CTRDAT
# FQ82920 - MABON 15/06/12 - Le poste et/ou l'emploi-type sont initialisés par la carrière, et si aucune donnée
# exploitable n'est trouvée dans les carrières, on les cherche dans le contrat

# 71140 - SYMEU - 28/01/2011
#AM Infbox "BEFORE call SET_CPY"
Call SET_CPY([F:HRCTR]ETRFCY) From SUBEVA2
#AM Infbox "AFTER call SET_CPY"
# FQ81085 - MABON 16/07/12 - To manage legislation in employee selection
Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
If !fstat Then
  GCURLEG     = [F:FCY]LEG
  [M:EVA0]EVALEG = GCURLEG
  Affzo [M:EVA0]EVALEG, ZEVALEG
Endif
Gosub INI_POT_JOBPOT_MIS : # 13/02/14 - EXI 96649 US2420 Mission

Call SET_EVAVAL([F:HRCTR]CTRNUM)
#GSOCIETE=[M:EVA0]CPY
# End MABON
Return

