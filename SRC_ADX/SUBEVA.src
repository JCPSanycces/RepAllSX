Funprog DATEZERO(DATESCR)
Value Date DATESCR
# If EVADAT = [0/0/0] forcer "[0/0/0]" en chaine de caractère
# pour eviter que les dates d'exercice soient mises par defaut
If [L]DATESCR=[0/0/0] Then
  End "[0/0/0]"
  Else
  End [L]DATESCR
Endif
End


# FQ85052 - MABON 21/01/13 - Workflows sur les évaluations
# Re-routage
Subprog WRKRER(KRONO,ADEST)
Value Char    KRONO(), ADEST()

 Update [F:AWS2] Where CHRONO = KRONO & DEST = ADEST
&                With  VALCTX8 = DEST

End

# Visa du collaborateur :
#   - S'il accepte, le statut passe à "A valider N+1", et le visa collaborateur passe à "Accepté"
#   - S'il demande un complément, le statut repasse à "En cours" pour que le manager puisse compléter l'évaluation ; et si le
#     collaborateur a justifié sa demande, le commentaire est stocké
#   - S'il refuse, le statut passe à "A valider N+1", et le visa collaborateur passe à "Refusé"
Subprog WRKSIGC(ACTION,EMP,CTRNUM,DATSTR,DATEND,TYPEVA,CRIT1)
Value Char    ACTION(),EMP(),CTRNUM(),DATSTR(),DATEND(),TYPEVA(),CRIT1()
Local Char    CRITERE(250)
Local Integer NEWEVAVAL, NEWVISCOL
Local Date    DATSTRD,DATENDD

  If !clalev([F:EVE]) : Local File EVAEMP [EVE] : Endif
  DATSTRD=gdat$(val(mid$(DATSTR,1,2)),val(mid$(DATSTR,4,2)),val(mid$(DATSTR,7,4)))
  DATENDD=gdat$(val(mid$(DATEND,1,2)),val(mid$(DATEND,4,2)),val(mid$(DATEND,7,4)))

  Read [F:EVE]EVE0 = [L]EMP;[L]CTRNUM;[L]DATSTRD;[L]DATENDD;[L]TYPEVA
  If !fstat Then
    Lock ="EVE"+[L]EMP+[L]CTRNUM
    If fstat
      [V]GOK  =-1
      [V]GLOCK="%EVE"+[L]EMP+[L]CTRNUM
      End
    Endif

    Case ACTION
      When "VIS"   : NEWEVAVAL=3 : NEWVISCOL=1              : # A valider N+1
      When "CMP"   : NEWEVAVAL=1 : NEWVISCOL=[F:EVE]VISCOL  : # En cours
      When "REF"   : NEWEVAVAL=3 : NEWVISCOL=2              : # A valider N+1
      When Default : End
    Endcase

    If CRIT1="" Then CRIT1="1=1" : Endif
    CRITERE  = "EVAVAL=2 & REFNUM='"+[L]EMP+"' & CTRNUM='"+[L]CTRNUM+"' & EVADATSTR=["+format$(GFMD,[L]DATSTR)+"]"
    CRITERE -= "& EVADATEND=["+format$(GFMD,[L]DATEND)+"] & EVATYP='"+[L]TYPEVA+"'"

    If len(GCOMMENTSIG)>0
      Update [F:EVE] Where evalue([L]CRITERE) & evalue([L]CRIT1) With EVAVAL=NEWEVAVAL, VISCOL=NEWVISCOL, CMTMATNEW=GCOMMENTSIG
    Else
      Update [F:EVE] Where evalue([L]CRITERE) & evalue([L]CRIT1) With EVAVAL=NEWEVAVAL, VISCOL=NEWVISCOL
    Endif
    If fstat
      [V]GOK=0
      Call RSTA("EVE",[L]EMP+[L]CTRNUM) From GLOCK
      End
    Endif
  Endif
End

# Visa du manager :
#   - Il ne peut qu'accepter : le statut passe à "A valider N+1"
Subprog WRKSIGM(ACTION,EMP,CTRNUM,DATSTR,DATEND,TYPEVA,CRIT1)
Value Char    ACTION(),EMP(),CTRNUM(),DATSTR(),DATEND(),TYPEVA(),CRIT1()
Local Char    CRITERE(250),NEWEVAMAT
Local Integer NEWEVAVAL, NEWVISCOL
Local Date    DATSTRD,DATENDD

  If !clalev([F:EVE]) : Local File EVAEMP [EVE] : Endif
  DATSTRD=gdat$(val(mid$(DATSTR,1,2)),val(mid$(DATSTR,4,2)),val(mid$(DATSTR,7,4)))
  DATENDD=gdat$(val(mid$(DATEND,1,2)),val(mid$(DATEND,4,2)),val(mid$(DATEND,7,4)))

  Read [F:EVE]EVE0 = [L]EMP;[L]CTRNUM;[L]DATSTRD;[L]DATENDD;[L]TYPEVA
  If !fstat Then
    Lock ="EVE"+[L]EMP+[L]CTRNUM
    If fstat
      [V]GOK  =-1
      [V]GLOCK="%EVE"+[L]EMP+[L]CTRNUM
      End
    Endif

    Case ACTION
      When "VIS"   : NEWEVAVAL=[F:EVE]EVAVAL+1  : # Validé N+1 ou Validé N+2
      When Default : End
    Endcase
    NEWEVAMAT=""
    If NEWEVAVAL=5 Then
      NEWEVAMAT=GREFNUM
    Endif
# SEGAY - 12/02/13 - FQ85022 US1209 US1326
    If [F:EVE]EVAVAL = 3
       Call VALIDEVA([L]EMP,[L]CTRNUM,[L]DATSTRD,[L]DATENDD,[L]TYPEVA) From POREVA
       If GOK < 1 : End : Endif
    Endif
# END  US1326
    If CRIT1="" Then CRIT1="1=1" : Endif
    CRITERE  = "REFNUM='"+[L]EMP+"' & CTRNUM='"+[L]CTRNUM+"' & EVADATSTR=["+format$(GFMD,[L]DATSTR)+"]"
    CRITERE -= "& EVADATEND=["+format$(GFMD,[L]DATEND)+"] & EVATYP='"+[L]TYPEVA+"'"

    If len(GCOMMENTSIG)>0
      Update [F:EVE] Where evalue([L]CRITERE) & evalue([L]CRIT1) With EVAVAL=NEWEVAVAL, CMTMATNEW=GCOMMENTSIG, EVAMAT2=NEWEVAMAT
    Else
      Update [F:EVE] Where evalue([L]CRITERE) & evalue([L]CRIT1) With EVAVAL=NEWEVAVAL, EVAMAT2=NEWEVAMAT
    Endif
    If fstat
      [V]GOK=0
      Call RSTA("EVE",[L]EMP+[L]CTRNUM) From GLOCK
      End
    Endif
  Endif
End

