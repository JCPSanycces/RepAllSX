Subprog AM_EVAPOT(VALEUR)
Variable Char    VALEUR()
If clalev([F:POT])=0 : Local File POSTE [POT] : Endif
Call LECTURE("POT",VALEUR,"") From CONTOBJ
If [F:POT]JOBPOT<>""
 #ADNGO - 2017-11-06 - START
 #[M:EVA3]EVAJOB = [F:POT]JOBPOT
 [M:EVA8]EVAJOB = [F:POT]JOBPOT
 #ADNGO - 2017-11-06 - END
 If clalev([F:JOT])=0 : Local File JOBTYP [JOT] : Endif
 #ADNGO - 2017-11-06 - START
 #Call LECTURE("JOT",[M:EVA3]EVAJOB,"") From CONTOBJ
 #[M:EVA3]EVAJOBGRP = [F:JOT]JOBGRP
 Call LECTURE("JOT",[M:EVA8]EVAJOB,"") From CONTOBJ
 [M:EVA8]EVAJOBGRP = [F:JOT]JOBGRP
 #ADNGO - 2017-11-06 - END
# FQ81085 - SEGAY 12/09/12 - US740 To allow a domain, theme or organism in a different legislation than the contract
# we had to change the datatype of these fields. So we have to get the title
# Affzo [EVA3]EVAJOB,ZEVAJOB,EVAJOBGRP,ZEVAJOBGRP
 #ADNGO - 2017-11-06 - START
 #Affzo [EVA3]EVAJOB,ZEVAJOB,EVAJOBGRP
 #Call LECTEXTRA([M]WJOBGRPDES,"ATABDIV","LNGDES","10460",[M:EVA3]EVAJOBGRP) From ATEXTRA
 #Affzo [EVA3]WJOBGRPDES
 Affzo [EVA8]EVAJOB,ZEVAJOB,EVAJOBGRP
 Call LECTEXTRA([M]WJOBGRPDES,"ATABDIV","LNGDES","10460",[M:EVA8]EVAJOBGRP) From ATEXTRA
 Affzo [EVA8]WJOBGRPDES
 #ADNGO - 2017-11-06 - END
Endif
End

Subprog AM_EVAJOB(VALEUR)
Variable Char    VALEUR()
If clalev([F:JOT])=0 : Local File JOBTYP [JOT] : Endif
Call LECTURE("JOT",VALEUR,"") From CONTOBJ
If [F:JOT]JOBGRP<>""
 #ADNGO - 2017-11-06 - START
 #[M:EVA3]EVAJOBGRP = [F:JOT]JOBGRP
 [M:EVA8]EVAJOBGRP = [F:JOT]JOBGRP
 #ADNGO - 2017-11-06 - END
# FQ81085 - SEGAY 12/09/12 - US740 To allow a domain, theme or organism in a different legislation than the contract
# we had to change the datatype of these fields. So we have to get the title
# Affzo [EVA3]EVAJOBGRP,ZEVAJOBGRP
 #ADNGO - 2017-11-06 - START
 #Affzo [EVA3]EVAJOBGRP
 #Call LECTEXTRA([M]WJOBGRPDES,"ATABDIV","LNGDES","10460",[M:EVA3]EVAJOBGRP) From ATEXTRA
 #Affzo [EVA3]WJOBGRPDES
 Affzo [EVA8]EVAJOBGRP,ZEVAJOBGRP
 Call LECTEXTRA([M]WJOBGRPDES,"ATABDIV","LNGDES","10460",[M:EVA8]EVAJOBGRP) From ATEXTRA
 Affzo [EVA8]WJOBGRPDES
 #ADNGO - 2017-11-06 - END
Endif
End

# FQ81085 - SEGAY 12/09/12 - US740 The domain, theme or organism can be in a different legislation than the contract
# but if one of them is filled, the others must be in the same legislation
Subprog AS_EVAJOBGRP(VALEUR)
Variable Char    VALEUR()
# FQ81085 - SEGAY 12/09/12 - US740 The domain, theme or organism can be in a different legislation than the contract
# but if one of them is filled, the others must be in the same legislation
If dim(GCURLEG2)<0 Then Global Char GCURLEG2 : Endif
GCURLEG2 = ""
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
If clalev([F:JOT])=0 : Local File JOBTYP [JOT] : Endif
If clalev([F:POT])=0 : Local File POSTE [POT] : Endif
If [M]EVAJOB<>"" Then
  Read [F:JOT]JOT0=[M]EVAJOB
  If !fstat & [F:JOT]LEG<>GCURLEG2 & [F:JOT]LEG<>"" Then GCURLEG2=[F:JOT]LEG : Endif
Endif
If [M]EVAPOT<>"" Then
  Read [F:POT]POT0=[M]EVAPOT
  If !fstat & [F:POT]LEG<>GCURLEG2 & [F:POT]LEG<>"" Then GCURLEG2=[F:POT]LEG : Endif
Endif

# Si aucun des autres champs n'est renseigné, on récupère la leg du champ en cours
If GCURLEG2="" Then
  Read [F:ADI]CODE=10460;VALEUR
  If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
Endif

Call TITADI(GBOUT2,"10460") From TRTDIV
  # End SEGAY
End

# FQ81085 - SEGAY 12/09/12 - US740  To allow a domain, theme or organism in a different legislation than the contract
# we had to change the datatype of these fields. So we have to control the field, without checking the LEG
Subprog C_EVAJOBGRP(VALEUR)
Variable Char    VALEUR()
  If VALEUR="" Then End : Endif
  # On recalcule GCURLEG2 si les autres champs sont vides
  If dim(GCURLEG2)<0 Then Global Char GCURLEG2 : Endif
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  If [M]EVAJOB="" & [M]EVAPOT="" Then
    Read [F:ADI]CODE=10460;VALEUR
    If !fstat & [F:ADI]LEG<>GCURLEG2 & [F:ADI]LEG<>"" Then GCURLEG2=[F:ADI]LEG : Endif
  Endif

  Call CONTADI_SANS_LEG(VALEUR,"10460","") From TOOLSHRLEG
  If fstat : GMESSAGE=mess(23,100,1) : mkstat=2 : Endif
End

# FQ81085 - SEGAY 12/09/12 - US740  To allow a domain, theme or organism in a different legislation than the contract
# we had to change the datatype of these fields. So we have to control the field, without checking the LEG
Subprog AM_EVAJOBGRP(VALEUR)
Variable Char    VALEUR()
# FQ81085 - SEGAY 12/09/12 - US740 To allow a domain, theme or organism in a different legislation than the contract
# we had to change the datatype of these fields. So we have to get the title
Call LECTEXTRA([M]WJOBGRPDES,"ATABDIV","LNGDES","10460",VALEUR) From ATEXTRA
#ADNGO - 2017-11-06 - START
#Affzo [EVA3]WJOBGRPDES
Affzo [EVA8]WJOBGRPDES
#ADNGO - 2017-011-06 - END
End


