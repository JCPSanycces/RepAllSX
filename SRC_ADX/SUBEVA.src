 Return
Endif


If func AFNC.ACTIV("EVAEN")>0 and GFONCTION = "GESEVA"
  Local Integer Y,Z,K
  For nolign = 1 To [M:EVA7]NBRMIS
    If [M:EVA7]WMIS(nolign-1) = "" : Break: Endif
    If [M:EVA7]CODMIS(nolign-1) = [M:EVA7]WMIS(nolign-1)
      Raz [F:EVM]
      Y = nolign
      [F:EVM]CODMIS     = [M:EVA7]CODMIS(nolign-1)
      [F:EVM]EVAMISREF  = [M:EVA7]EVAMISREF(nolign-1)
      [F:EVM]CMTMIS     = [M:EVA7]CMTMIS(nolign-1)
      [F:EVM]MISWEI     = [M:EVA7]MISWEI(nolign-1)
      [F:EVM]EVALEVMIS  = [M:EVA7]EVALEVMIS(nolign-1)
      [F:EVM]MISSCO     = [M:EVA7]MISSCO(nolign-1)
      [F:EVM]EVAMAT     = [F:EVE]EVAMAT
      [F:EVM]REFNUM     = [F:EVE]REFNUM
      [F:EVM]CTRNUM     = [F:EVE]CTRNUM
      [F:EVM]CTRDAT     = [F:EVE]CTRDAT
      [F:EVM]EVADATSTR  = [F:EVE]EVADATSTR
      [F:EVM]EVADATEND  = [F:EVE]EVADATEND
      [F:EVM]EVATYP     = [F:EVE]EVATYP
      [F:EVM]EVADAT     = [F:EVE]EVADAT
      [F:EVM]NUMLIG     = nolign
      Write [EVM]
      If fstat
        GOK=0 : Call FSTA("EVM") From GLOCK : Break
      Endif
    Endif
  Next

  #Indicators
   For nolign = 1 To [M:EVA7]NBRMIS
    If [M:EVA7]WMIS(nolign-1) = "" : Break: Endif
      Raz [F:EVIN]
      [F:EVIN]CODMIS      = [M:EVA7]WMIS(nolign-1)
      [F:EVIN]EVAMAT      = [F:EVE]EVAMAT
      [F:EVIN]REFNUM      = [F:EVE]REFNUM
      [F:EVIN]CTRNUM      = [F:EVE]CTRNUM
      [F:EVIN]CTRDAT      = [F:EVE]CTRDAT
      [F:EVIN]EVADATSTR   = [F:EVE]EVADATSTR
      [F:EVIN]EVADATEND   = [F:EVE]EVADATEND
      [F:EVIN]EVATYP      = [F:EVE]EVATYP
      [F:EVIN]EVADAT      = [F:EVE]EVADAT
      [F:EVIN]IND         = [M:EVA7]IND(nolign-1)
      [F:EVIN]INDWEI      = [M:EVA7]INDWEI(nolign-1)
      [F:EVIN]INDLEV      = [M:EVA7]INDLEV(nolign-1)
      [F:EVIN]INDSCO      = [M:EVA7]INDSCO(nolign-1)
      [F:EVIN]CMTIND      = [M:EVA7]CMTIND(nolign-1)
      Write [EVIN]
      If fstat
        GOK=0 : Call FSTA("EVIN") From GLOCK : Break
      Endif
    Next
Else
  For nolign=1 To [M:EVA7]NBRMIS
   Raz [F:EVM]
   [F:EVM] = [M:EVA7]
   [F:EVM]REFNUM    = [F:EVE]REFNUM
   [F:EVM]CTRNUM    = [F:EVE]CTRNUM
   [F:EVM]CTRDAT    = [F:EVE]CTRDAT
   [F:EVM]EVADATSTR = [F:EVE]EVADATSTR
   [F:EVM]EVADATEND = [F:EVE]EVADATEND
   [F:EVM]EVATYP    = [F:EVE]EVATYP
   [F:EVM]EVADAT = [F:EVE]EVADAT
   [F:EVM]NUMLIG = nolign
   Write [EVM]
   If fstat
    GOK = 0 : Call FSTA("EVM") From GLOCK : Break
   Endif
  Next nolign
Endif

Return
