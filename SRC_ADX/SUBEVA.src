#SEGAY 3/10/12 : comment GCURLEG=""
# get legislation of campagne
#**
#* Get legislation for field campagne(1),refnum(2)
#* SEGAY
#*!
Funprog FGET_LEGSEL(INDFLD)
Value Integer INDFLD
Local Integer OK
Local  Char MLEG,WLEG
#MLEG=GLEGFIL
If func AFNC.ACTIV("LEG")=0
  MLEG = GDOSLEG
Else   # GCURLEG positionné par programme
  If GCURLEG = ""
    MLEG=GLEGFIL
  Else
    MLEG=GCURLEG
  Endif
Endif
If GREP="C"
  Case INDFLD
    When 1 :
      If ([M:EVA0]CTRNUM = "" | [M:EVA0]REFNUM = "") Then
       MLEG=GLEGFIL
      Endif
    When 2 :
     MLEG=GLEGFIL
     If [M:EVA0]CEV<>""
        Raz WLEG
        Call GET_LEGHRCEV([M:EVA0]CEV,OK,WLEG,0)From TOOLSHRLEG
        If WLEG<>""
         MLEG=WLEG
        Endif
      Endif
  Endcase
Endif
End MLEG

#SEGAY 3/10/12 : comment GCURLEG=""
# get legislation of campagne
#**
#* Get legislation for field campagne(1),refnum(2)
#* SEGAY
#*!
Funprog FGET_LEGCTL(INDFLD)
Value Integer INDFLD
Local Integer OK
Local  Char MLEG
Raz MLEG
Case INDFLD
  When 2 :
   If([M:EVA0]CEV<>"")
      Call GET_LEGHRCEV([M:EVA0]CEV,OK,MLEG,0)From TOOLSHRLEG
    Endif
Endcase
End MLEG

#**
#* Defines parameter ALLLEG used in DIVPAYE.DROITEMP on EVA0.REFNUM field
#*!
Funprog FGET_ALLLEG
Local Char LRET(1)

  LRET = num$(GFONCTION="GESEVA" & maskcou ="EVA0" & GREP="C" & func SUBEVA.FGET_LEGCTL(2)="")
End LRET

