# Readlock [EVC]EVC0(5)=[F:EVE]REFNUM;[F:EVE]CTRNUM;[F:EVE]EVADAT;1;[M:EVA2]EVACPC(nolign-1)

#ANMCL - 2017-05-08 -  X3-29417 - START
# Readlock [EVC]EVC0(7)=[F:EVE]REFNUM;[F:EVE]CTRNUM;[F:EVE]EVADATSTR;[F:EVE]EVADATEND;[F:EVE]EVATYP;1;[M:EVA2]EVACPC(nolign-1)
 If func AFNC.ACTIV("EVAEN")>0
 Readlock [EVC]EVC3(8)=[F:EVE]REFNUM;[F:EVE]CTRNUM;[F:EVE]EVADATSTR;[F:EVE]EVADATEND;[F:EVE]EVATYP;1;[F:EVE]EVAMAT;[M:EVA2]EVACPC(nolign-1)
 Else
  Readlock [EVC]EVC0(7)=[F:EVE]REFNUM;[F:EVE]CTRNUM;[F:EVE]EVADATSTR;[F:EVE]EVADATEND;[F:EVE]EVATYP;1;[M:EVA2]EVACPC(nolign-1)
 Endif
#ANMCL - 2017-05-08 -  X3-29417 - END

 #### EVC0 * REFNUM+CTRNUM+EVADAT+EVATYPCPC+EVACPC+NUMLIG
 If fstat
  Raz [F:EVC]
  [F:EVC]REFNUM    = [F:EVE]REFNUM
  [F:EVC]CTRNUM    = [F:EVE]CTRNUM
  [F:EVC]CTRDAT    = [F:EVE]CTRDAT
  [F:EVC]EVADATSTR = [F:EVE]EVADATSTR #     SEGAY - 08/08/12 - EXI 81491 83397 US606
  [F:EVC]EVADATEND = [F:EVE]EVADATEND #     SEGAY - 08/08/12 - EXI 81491 83397 US606
  [F:EVC]EVATYP    = [F:EVE]EVATYP    #     MABON - 20/09/12 - EXI 81491 83397 US606
  [F:EVC]EVADAT    = [F:EVE]EVADAT
  [F:EVC]EVAMAT    = [F:EVE]EVAMAT    #FRLAA - 2016-08-01 - REQUIREMENT 117178 US 3
  [F:EVC]NUMLIG    = nolign
  [F:EVC]EVACPCDAT = [M:EVA2]EVACPCDAT(nolign-1)
  [F:EVC]EVACPC    = [M:EVA2]EVACPC(nolign-1)
  [F:EVC]EVALEV    = [M:EVA2]EVALEV(nolign-1)
  [F:EVC]ORICPC    = [M:EVA2]ORICPC(nolign-1)
  [F:EVC]LEVREFVAL = [M:EVA2]LEVREF(nolign-1)
  #ANMCL - 2017-05-08 -  X3-29417 - START
  If func AFNC.ACTIV("FRT")>0
    [F:EVC]STGCOD    = [M:EVA2]STGCOD(nolign-1)
  Endif
  #ANMCL - 2017-05-08 -  X3-29417 - END
  [F:EVC]EVATYPCPC = 1                          : # ML 2412 Requise
  If dim([F:EVC]CREDAT)>0 : [F:EVC]CREDAT = date$     : Endif
  If dim([F:EVC]CRETIM)>0 : [F:EVC]CRETIM = time      : Endif
  If dim([F:EVC]CREUSR)>0 : [F:EVC]CREUSR = GUSER     : Endif
  If dim([F:EVC]EXPNUM)>0 : [F:EVC]EXPNUM = [C]EXPORT : Endif
  Write [EVC]
  If fstat
   GOK = 0 : Call FSTA("EVC") From GLOCK : Break
  Endif
 Else
  [F:EVC]CTRDAT    = [F:EVE]CTRDAT
  [F:EVC]EVADAT    = [F:EVE]EVADAT #     SEGAY - 08/08/12 - EXI 81491 83397 US606
  [F:EVC]EVALEV    = [M:EVA2]EVALEV(nolign-1)
  [F:EVC]ORICPC    = [M:EVA2]ORICPC(nolign-1)
  [F:EVC]LEVREFVAL = [M:EVA2]LEVREF(nolign-1)
  #ANMCL - 2017-05-08 -  X3-29417 - START
  # Issue 11472 - 2017-09-20 by BRBAN : New field STGCOD to link with training
  If func AFNC.ACTIV("FRT")>0
    [F:EVC]STGCOD    = [M:EVA2]STGCOD(nolign-1)
  Endif
  # -
  #ANMCL - 2017-05-08 -  X3-29417 - END
  [F:EVC]NUMLIG    = nolign
  [F:EVC]EVATYPCPC = 1                          : # ML 2412 Requise
  If dim([F:EVC]UPDDAT)>0 : [F:EVC]UPDDAT = date$     : Endif
  If dim([F:EVC]UPDTIM)>0 : [F:EVC]UPDTIM = time      : Endif
  If dim([F:EVC]UPDUSR)>0 : [F:EVC]UPDUSR = GUSER     : Endif
  If dim([F:EVC]EXPNUM)>0 : [F:EVC]EXPNUM = [C]EXPORT : Endif
  Rewrite[EVC]
  If fstat
   GOK = 0 : Call FSTA("EVC") From GLOCK : Break
  Endif
 Endif
 #     SEGAY - 16/01/13 - EXI 87090 US1222
 #  Segay pour initialiser l'écran comme "enregistrer" ne passe pas dans liens
# [M:EVA2]FLGVAL(nolign-1) = 2
 [M:EVA2]FLGOLD(nolign-1) = 2
 [M:EVA2]EVACPCDAT(nolign-1) = [F:EVC]EVACPCDAT

Next nolign
If GOK<1 : Return : Endif

