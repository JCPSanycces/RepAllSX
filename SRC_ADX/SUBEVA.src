## Etiquette ajoutée par le superviseur (écran EVA0) 10/08/2010 12:18:23 (JML)
######################################################################################
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
Subprog S_CTRNUM_OLD(VALEUR)
Variable Char    VALEUR()

Local    Integer NB_CTR
Local    Char    TB_CTR(GLONVCR)(0..)
Local    Date    TB_DAT(0..)

If !GWEBSERV
 If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif

 Raz NB_CTR, TB_CTR, TB_DAT
 For [HRCTR]CTR0 Where [HRCTR]REFNUM=[M:EVA0]REFNUM & [HRCTR]CTRDAT<=[M:EVA0]EVADAT
&                  & ([HRCTR]XITDAT=[0/0/0] | [HRCTR]XITDAT>=[M:EVA0]EVADAT)
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  Call LECTURE("SRV",[F:HRCTR]ETRSRV,"") From CONTOBJ
  NB_CTR += 1
  TB_CTR(NB_CTR)  = [F:HRCTR]CTRNUM
  TB_DAT(NB_CTR)  = [F:HRCTR]CTRDAT
 Next : # [HRCTR]CTR0
 If !NB_CTR
  GMESSAGE  = mess(158,10702,1) : # Pas de contrat valide sur la période
  VALEUR = ""
  Raz [F:HRCTR] : mkstat = 2 : End
 Elsif NB_CTR=1
  VALEUR = TB_CTR(1)
  Read [HRCTR]CTR0=[M:EVA0]REFNUM;TB_CTR(1);TB_DAT(1)
  If fstat : Raz [F:HRCTR] : mkstat = 2 : End : Endif
 Else
  ## Action SELOBJCRIT
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "SELOBJCRIT"
  PARMSK(1) = "CTR"
  PARMSK(2) = ""
  PARMSK(3) = ""
  PARMSK(4) = "[F:HRCTR]REFNUM=[M:EVA0]REFNUM & [F:HRCTR]CTRDAT<=[M:EVA0]EVADAT"
  PARMSK(5) = "([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=[M:EVA0]EVADAT)"
  Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJCRIT","SELOBJ","") From GACTION
  If mkstat : Raz [F:HRCTR] : mkstat = 2 : End : Endif
  Read [HRCTR]CTR0=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
  If fstat : Raz [F:HRCTR] : mkstat = 2 : End : Endif
  GACTION = SAVACT
  Gosub AFF From GSAISIE
 Endif : # If !NB_CTR
 Gosub AFF_CTR
Endif : # If !GWEBSERV
End

#     SEGAY - 08/08/12 - EXI 81491 83397 US606
# FQ81085 US830 - SEGAY 27/09/12 - Replace by Selection TAB SELCTRCEV in SUBCEV
Subprog S_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer NB_CTR, OKENR
Local    Char    TB_CTR(GLONVCR)(0..)
Local    Date    TB_DAT(0..)
# FQ81085 US740 - SEGAY 10/09/12 - Control LEG CTR
Local    Char    WLEG(GLONADI)
Local    Char    S_GCURLEG(GLONADI)
  If clalev([F:CEV])=0 : Local File COMPEVAL [CEV] : Endif
  Call LECTURE("CEV", [M:EVA0]CEV, "") From CONTOBJ

If !GWEBSERV
 If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif

 Raz NB_CTR, TB_CTR, TB_DAT
#  For [HRCTR]CTR0 Where REFNUM=[M:EVA0]REFNUM & (CTRDAT<=[M:EVA0]EVADATSTR | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=[M:EVA0]EVADATSTR))
#&                 & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>=[M:EVA0]EVADATEND)
  For [HRCTR]CTR0 Where REFNUM=[M:EVA0]REFNUM & (CTRDAT<=[M:EVA0]EVADATEND | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=[M:EVA0]EVADATEND))
&                 & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>=[M:EVA0]EVADATEND)

  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  Call LECTURE("SRV",[F:HRCTR]ETRSRV,"") From CONTOBJ
  OKENR=2
  If GLEGFIL<>"" | GCURLEG<>"" Then
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    If GCURLEG<>"" Then
      If [F:CPY]LEG<>GCURLEG Then OKENR=1 : Endif
    Elsif [F:CPY]LEG<>GLEGFIL Then OKENR=1 : Endif
  Endif
  If OKENR=2 Then
    NB_CTR += 1
    TB_CTR(NB_CTR)  = [F:HRCTR]CTRNUM
    TB_DAT(NB_CTR)  = [F:HRCTR]CTRDAT
  Endif
 Next : # [HRCTR]CTR0
 If !NB_CTR
  GMESSAGE  = mess(158,10702,1) : # Pas de contrat valide sur la période
  VALEUR = ""
  Raz [F:HRCTR] : mkstat = 2 : End
 Elsif NB_CTR=1
#  VALEUR = TB_CTR(1)
#  Read [HRCTR]CTR0=[M:EVA0]REFNUM;TB_CTR(1);TB_DAT(1)
#  If fstat : Raz [F:HRCTR] : mkstat = 2 : End : Endif
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "SELOBJCRIT"
  PARMSK(1) = "CTR"
  PARMSK(2) = ""
  PARMSK(3) = ""
  PARMSK(4) = "[F:HRCTR]REFNUM=[M:EVA0]REFNUM & [F:HRCTR]CTRNUM='"+TB_CTR(1)+"' & [F:HRCTR]CTRDAT=["+format$(GFMD,TB_DAT(1))+"]"
  PARMSK(5) = ""
  Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJCRIT","SELOBJ","") From GACTION
  If mkstat : Raz [F:HRCTR] : mkstat = 2 : End : Endif
  Read [HRCTR]CTR0=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
  If fstat : Raz [F:HRCTR] : mkstat = 2 : End : Endif
  GACTION = SAVACT
  Gosub AFF From GSAISIE
 Else
# FQ81085 US740 - SEGAY 10/09/12 - Control LEG CTR
  MLEG=""
  If GLEGFIL<>"" Then
   MLEG=GLEGFIL
  Endif
  If dim(GCURLEG)>0 Then
    MLEG=GCURLEG
  Endif
  S_GCURLEG=GCURLEG
  GCURLEG=MLEG
# END FQ81085 US740 - SEGAY 10/09/12 - Control LEG CTR
  ## Action SELOBJCRIT
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "SELOBJCRIT"
  PARMSK(1) = "CTR"
  PARMSK(2) = ""
  PARMSK(3) = ""
  PARMSK(4) = "[F:HRCTR]REFNUM=[M:EVA0]REFNUM & ([F:HRCTR]CTRDAT<=[M:EVA0]EVADATEND | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=[M:EVA0]EVADATEND))"
  PARMSK(5) = "([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=[M:EVA0]EVADATEND)"
# FQ81085 US740 - SEGAY 10/09/12 - Control LEG CTR
  If GCURLEG <> ""
     PARMSK(5) ="([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=[M:EVA0]EVADATEND)& [F:CPY]LEG='"+GCURLEG+"'"
  Endif
#  If [F:CEV]COD<>"" Then
#    If [F:CEV]CPYCEV<>"" Then
#      PARMSK(4) +=' & find([F:FCY]LEGCPY,"'+[F:CEV]CPYCEV+'","")>0'
#    Endif
#    If [F:CEV]FCYCEV<>"" Then
#      PARMSK(4) +=' & find([F:HRCTR]ETRFCY,"'+[F:CEV]FCYCEV+'","")>0'
#    Endif
#    If [F:CEV]SRVCEV<>"" Then
#      PARMSK(4) +=' & find([F:HRCTR]ETRSRV,"'+[F:CEV]SRVCEV+'","")>0'
#    Endif
#    If [F:CEV]PRFCEV<>"" Then
#      PARMSK(5) +=' & find([F:HRCTR]PROPRF,"'+[F:CEV]PRFCEV+'","")>0'
#    Endif
#    If [F:CEV]POTCEV<>"" Then
#      PARMSK(5) +=' & find([F:HRCTR]POT,"'+[F:CEV]POTCEV+'","")>0'
#    Endif
#    If [F:CEV]JOTCEV<>"" Then
#      PARMSK(5) +=' & find([F:HRCTR]JOBPOT,"'+[F:CEV]JOTCEV+'","")>0'
#     Endif
#  Endif

  Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJCRIT","SELOBJ","") From GACTION
  GCURLEG=S_GCURLEG
  If mkstat : Raz [F:HRCTR] : mkstat = 2 : End : Endif
  Read [HRCTR]CTR0=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
  If fstat : Raz [F:HRCTR] : mkstat = 2 : End : Endif
  GACTION = SAVACT
  Gosub AFF From GSAISIE
 Endif : # If !NB_CTR
 Gosub AFF_CTR
Endif : # If !GWEBSERV
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran EVA0) 26/09/2012 15:00:18 (SEGAY)
######################################################################################
# FQ81085 US740 - SEGAY 10/09/12 - Control LEG CTR and LEG CEV
Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()

Local Char WLEGCEV(GLONADI)
Local Char WLEGCTR(GLONADI)
Local Integer TMP
If VALEUR="" : End : Endif
Raz TMP
Call GET_LEGHRCEV([M]CEV,TMP,WLEGCEV,0)From TOOLSHRLEG
Raz TMP
Call GET_LEGHRCTR([M]REFNUM,VALEUR,TMP,WLEGCTR,0)From TOOLSHRLEG
If(WLEGCEV<>"" & WLEGCTR<>"" & WLEGCEV<>WLEGCTR)
    GMESSAGE=mess(72,10720,1)-":"-VALEUR+chr$(10)+chr$(13)+mess(62,127,1)-WLEGCTR : # Réservé à la législation
    mkstat = 2 : End
Endif
# FQ81491 - SEGAY 26/09/12 - Contrôle que le salarié a les mêmes caractéristiques que le code campagne
If GREP="C" Then
  # 13/02/14 - EXI 96649 US2420 Mission
  # pour ne pas faire afficher 2 fois le message Tableau des missions plein
  Global Integer IS_CTR_CTRNUM
  [V]IS_CTR_CTRNUM=1
  #END 96649
  Call AM_CTRNUM(VALEUR) From SUBEVA
  Kill [V]IS_CTR_CTRNUM : # 13/02/14 - EXI 96649 US2420 Mission
  If mkstat=2
      End
  Endif
Endif
End


