If [M:EVA2]NBRDLTVAL>0
 For nolign=1 To [M:EVA2]NBRDLTVAL
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
#  Delete [EVC] Where [EVC]REFNUM=[F:EVE]REFNUM & [EVC]CTRNUM=[F:EVE]CTRNUM & [EVC]EVADAT=[F:EVE]EVADAT
#&                  & [EVC]EVACPC=[M:EVA2]CPCDLTVAL(nolign-1) & [EVC]EVACPCDAT=[M:EVA2]DATDLTVAL(nolign-1)

#ANMCL 09/05/2017 start - Integration of Interviews  X3-29417 ZAF -
#  Delete [EVC] Where [EVC]REFNUM=[F:EVE]REFNUM & [EVC]CTRNUM=[F:EVE]CTRNUM
#&                  & [EVC]EVADATSTR=[F:EVE]EVADATSTR & [EVC]EVADATEND=[F:EVE]EVADATEND
#&                  & [EVC]EVACPC=[M:EVA2]CPCDLTVAL(nolign-1) & [EVC]EVACPCDAT=[M:EVA2]DATDLTVAL(nolign-1)
#&                  & [EVC]EVATYP=[F:EVE]EVATYP
#&                  & [EVC]EVATYPCPC=2 : #     SEGAY - 16/01/13 - EXI 87090 US1222
    If func AFNC.ACTIV("EVAEN")>0
      Delete [EVC] Where [EVC]REFNUM=[F:EVE]REFNUM & [EVC]CTRNUM=[F:EVE]CTRNUM
&                  & [EVC]EVADATSTR=[F:EVE]EVADATSTR & [EVC]EVADATEND=[F:EVE]EVADATEND
&                  & [EVC]EVACPC=[M:EVA2]CPCDLTVAL(nolign-1) & [EVC]EVACPCDAT=[M:EVA2]DATDLTVAL(nolign-1)
&                  & [EVC]EVATYP=[F:EVE]EVATYP & [EVC]EVAMAT=[F:EVE]EVAMAT
&                  & [EVC]EVATYPCPC=2
    Else
        Delete [EVC] Where [EVC]REFNUM=[F:EVE]REFNUM & [EVC]CTRNUM=[F:EVE]CTRNUM
&                  & [EVC]EVADATSTR=[F:EVE]EVADATSTR & [EVC]EVADATEND=[F:EVE]EVADATEND
&                  & [EVC]EVACPC=[M:EVA2]CPCDLTVAL(nolign-1) & [EVC]EVACPCDAT=[M:EVA2]DATDLTVAL(nolign-1)
&                  & [EVC]EVATYP=[F:EVE]EVATYP
&                  & [EVC]EVATYPCPC=2
    Endif
#ANMCL - 2017-05-08 -  X3-29417 - END

  If fstat=1
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
#   GOK = -1 : GLOCK = "$CPCEMP"-[F:EVE]REFNUM-[F:EVE]CTRNUM-[F:EVE]EVADAT-[F:EVC]EVACPCDAT-[F:EVC]EVACPC-num$([F:EVC]NUMLIG)
   GOK = -1 : GLOCK = "$CPCEMP"-[F:EVE]REFNUM-[F:EVE]CTRNUM-[F:EVE]EVADATSTR-[F:EVE]EVADATEND-[F:EVC]EVACPCDAT-[F:EVC]EVACPC-num$([F:EVC]NUMLIG)
   Break
  Endif
 Next nolign
Endif
If GOK<=0 : Return : Endif

For nolign=[M:EVA2]NBRVAL To 1 Step -1
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
#### EVC0 * REFNUM+CTRNUM+EVADAT+EVATYPCPC+EVACPC+NUMLIG
# Readlock [EVC]EVC0(5)=[F:EVE]REFNUM;[F:EVE]CTRNUM;[F:EVE]EVADAT;2;[M:EVA2]CPCVAL(nolign-1)
#### EVC0 * REFNUM+CTRNUM+EVADATSTR+EVADATEND+EVATYPCPC+EVACPC+NUMLIG
# Readlock [EVC]EVC0(6)=[F:EVE]REFNUM;[F:EVE]CTRNUM;[F:EVE]EVADATSTR;[F:EVE]EVADATEND;2;[M:EVA2]CPCVAL(nolign-1)

#ANMCL - 2017-05-08 -  X3-29417 - START
#Readlock [EVC]EVC0(7)=[F:EVE]REFNUM;[F:EVE]CTRNUM;[F:EVE]EVADATSTR;[F:EVE]EVADATEND;[F:EVE]EVATYP;2;[M:EVA2]CPCVAL(nolign-1)
If func AFNC.ACTIV("EVAEN")>0
  Readlock [EVC]EVC3(8)=[F:EVE]REFNUM;[F:EVE]CTRNUM;[F:EVE]EVADATSTR;[F:EVE]EVADATEND;[F:EVE]EVATYP;2;[F:EVE]EVAMAT;[M:EVA2]CPCVAL(nolign-1)
 Else
  Readlock [EVC]EVC0(7)=[F:EVE]REFNUM;[F:EVE]CTRNUM;[F:EVE]EVADATSTR;[F:EVE]EVADATEND;[F:EVE]EVATYP;2;[M:EVA2]CPCVAL(nolign-1)
 Endif
#ANMCL 09/05/2017 end
 If fstat
  Raz [F:EVC]
  [F:EVC]REFNUM    = [F:EVE]REFNUM
  [F:EVC]CTRNUM    = [F:EVE]CTRNUM
  [F:EVC]CTRDAT    = [F:EVE]CTRDAT    #ANMCL - 2017-05-08 -  X3-29417
  [F:EVC]EVADATSTR = [F:EVE]EVADATSTR #     SEGAY - 08/08/12 - EXI 81491 83397 US606
  [F:EVC]EVADATEND = [F:EVE]EVADATEND #     SEGAY - 08/08/12 - EXI 81491 83397 US606
  [F:EVC]EVATYP    = [F:EVE]EVATYP    #     MABON - 20/09/12 - EXI 81491 83397 US606
  [F:EVC]EVADAT    = [F:EVE]EVADAT
  [F:EVC]EVAMAT    = [F:EVE]EVAMAT    #FRLAA - 2016-08-01 - REQUIREMENT 117178 US 3
  [F:EVC]NUMLIG    = nolign
  [F:EVC]EVACPCDAT = [M:EVA2]EVACPCDATVAL(nolign-1)
  [F:EVC]EVACPC    = [M:EVA2]CPCVAL(nolign-1)
  [F:EVC]EVALEV    = [M:EVA2]LEVCPCVAL(nolign-1)
  [F:EVC]LEVCPCEVA = [M:EVA2]LEVCPCEVA(nolign-1)
  [F:EVC]ORICPC    = [M:EVA2]ORICPCVAL(nolign-1)
  [F:EVC]ACTDEV    = [M:EVA2]ACTDEV(nolign-1)
  [F:EVC]LEVREFVAL = [M:EVA2]LEVREFVAL(nolign-1)
  [F:EVC]LEVREFEVA = [M:EVA2]LEVREFEVA(nolign-1)
  [F:EVC]EVATYPCPC = 2                          : # ML 2412 Validée
  #ANMCL - 2017-05-08 -  X3-29417 - START
  # Issue 11472 - 2017-09-20 by BRBAN : New field STGCOD to link with training
  If func AFNC.ACTIV("FRT")>0
    [F:EVC]STGCOD    = [M:EVA2]STGCOD(nolign-1)
  Endif
  # -
  #ANMCL - 2017-05-08 -  X3-29417 - END
  If dim([F:EVC]CREDAT)>0 : [F:EVC]CREDAT = date$     : Endif
  If dim([F:EVC]CRETIM)>0 : [F:EVC]CRETIM = time      : Endif
  If dim([F:EVC]CREUSR)>0 : [F:EVC]CREUSR = GUSER     : Endif
  If dim([F:EVC]EXPNUM)>0 : [F:EVC]EXPNUM = [C]EXPORT : Endif
  Write [EVC]
  If fstat
   GOK = 0 : Call FSTA("EVC") From GLOCK : Break
  Endif
 Else
  [F:EVC]CTRDAT    = [F:EVE]CTRDAT #ANMCL - 2017-05-08 -  X3-29417
  [F:EVC]EVADAT    = [F:EVE]EVADAT #     SEGAY - 08/08/12 - EXI 81491 83397 US606
  [F:EVC]EVALEV    = [M:EVA2]LEVCPCVAL(nolign-1)
  [F:EVC]LEVCPCEVA = [M:EVA2]LEVCPCEVA(nolign-1)
  [F:EVC]ORICPC    = [M:EVA2]ORICPCVAL(nolign-1)
  [F:EVC]ACTDEV    = [M:EVA2]ACTDEV(nolign-1)
  [F:EVC]LEVREFVAL = [M:EVA2]LEVREFVAL(nolign-1)
  [F:EVC]LEVREFEVA = [M:EVA2]LEVREFEVA(nolign-1)
  #ANMCL - 2017-05-08 -  X3-29417 - START
  # Issue 11472 - 2017-09-20 by BRBAN : New field STGCOD to link with training
  If func AFNC.ACTIV("FRT")>0
    [F:EVC]STGCOD    = [M:EVA2]STGCOD(nolign-1)
  Endif
  # -
  #ANMCL - 2017-05-08 -  X3-29417 - END
  [F:EVC]NUMLIG    = nolign
  [F:EVC]EVATYPCPC = 2                          : # ML 2412 Validée
  If dim([F:EVC]UPDDAT)>0 : [F:EVC]UPDDAT = date$     : Endif
  If dim([F:EVC]UPDTIM)>0 : [F:EVC]UPDTIM = time      : Endif
  If dim([F:EVC]UPDUSR)>0 : [F:EVC]UPDUSR = GUSER     : Endif
  If dim([F:EVC]EXPNUM)>0 : [F:EVC]EXPNUM = [C]EXPORT : Endif
  Rewrite[EVC]
  If fstat
   GOK = 0 : Call FSTA("EVC") From GLOCK : Break
  Endif
 Endif
 #     SEGAY - 16/01/13 - EXI 87090 US1222
 #  Segay pour initialiser l'écran comme "enregistrer" ne passe pas dans liens
 [M:EVA2]FLGOLDVAL(nolign-1) = 2
 [M:EVA2]EVACPCDATVAL(nolign-1) = [F:EVC]EVACPCDAT

Next nolign
If GOK<1 : Return : Endif
#     SEGAY - 16/01/13 - EXI 87090 US1222
#  Segay pour initialiser l'écran comme "enregistrer" ne passe pas dans liens
If [M:EVA2]NBRDLTVAL > 0
  Dela 0, [M:EVA2]NBRDLTVAL [M:EVA2]NBRDLTVAL
Endif
Raz [M:EVA2]CPCDLTVAL
Raz [M:EVA2]NBRDLTVAL

Return
######################################################################################
$VAL_CPC

#ANMCL - 2017-05-08 -  X3-29417 - START
Local Integer MULREVVAL
If func AFNC.ACTIV("EVAEN")>0
  If [M:EVA0]EVAMAIREC = 2
    MULREVVAL = func EVAFNC.GET_REV_VALIDATE([M:EVA0]CEV,[M:EVA0]REFNUM,[M:EVA0]CTRNUM,[M:EVA0]EVADATSTR,[M:EVA0]EVADATEND,[M:EVA0]EVATYP,1)
    If MULREVVAL = 0
      GMESSAGE=mess(0007,2455,1)
      Return
    Endif
  Endif
Endif
#ANMCL - 2017-05-08 -  X3-29417 - END

If [M:EVA6]EVADAT=[0/0/0] Then
  GMESSAGE=mess(94,10720,1) : # La date d'évaluation est obligatoire pour la validation
  zonsui="[M:EVA6]EVADAT"
  Return
Endif
# FQ85010 - MABON 09/10/12 - Un évaluateur et la date doivent être renseignées pour la validation
If [M:EVA6]EVAMAT="" & [M:EVA6]EVALIB=""
  GMESSAGE=mess(31,10720,1) : # Evaluateur non renseigné
  zonsui="[M:EVA6]EVAMAT"
  Return
Endif
# SEGAY - 25/01/13 - BUG 87490 + BUG 87492
Call C_EVADAT([M:EVA6]EVADAT)
If mkstat=2
  zonsui="[M:EVA6]EVAMAT"
  Return
Endif
# END SEGAY - 25/01/13 - BUG 87490 + BUG 87492

# segay 24/12/10 LOT P02
# segay 24/12/10 LOT P02 pas de validation compétence pour validation+2
L_SV_EVAVAL = [M:EVA0]EVAVAL
L_NBCP = 0
L_NBDEM = 0

# FQ85052 - MABOS - 08/04/13 - Insertion de 2 items dans le menu local 10947 en positions 2 et 3
#     - si Statut="En cours" ==> +3 pour devenir Validé N+1
#     - si Statut="A valider C" ==> +2 pour devenir "Validé N+1"
#     - si Statut="A valider N+1" ou "Validé N+1" ==> +1 pour devenir "Validé N+1" ou "Validé N+2"
#     New EVAVAL in L_NEW_EVAVAL
L_NEW_EVAVAL=L_SV_EVAVAL
If L_NEW_EVAVAL < 1
  L_NEW_EVAVAL += 1
Endif
If find(L_NEW_EVAVAL,2)>0 Then
  L_NEW_EVAVAL += 2
Elsif find(L_NEW_EVAVAL,3,4)>0 Then
  L_NEW_EVAVAL += 1
Else
  L_NEW_EVAVAL += 3
Endif
# END - FQ85022 US1209 US1326

# FQ85052 - MABOS - 08/04/13 - Insertion d'un item dans le menu local 10947 en position 2
#If L_SV_EVAVAL<2
#If L_SV_EVAVAL<3
If L_NEW_EVAVAL=4 & L_SV_EVAVAL < L_NEW_EVAVAL
#If L_SV_EVAVAL<2
  # segay 11/05/11 73346
  L_OK = 1
  Call OUINON(mess(75,10720,1),L_OK) From GESECRAN
  #### Après validation, les données ne seront plus modifiables. Confirmez-vous la validation ?
  If L_OK<>2
     GOK=0
     Return
#ANMCL - 2017-05-08 -  X3-29417 - START
  Else
    #FRLAA - 2016-09-26 - X3PEOP-2267 - START
    #All further checks and updates will only be done for the main reviewer record
    #Multiple reviewer records will only update some records
    If func AFNC.ACTIV("EVAEN")>0
      If [M:EVA0]EVAMAIREC <> 2
        Gosub TRANSAC_EVAEN
        If   GOK<0 : Goto ROLL_TR1
        Elsif !GOK : Goto AB_TR1
        Endif
        Commit
        [M:EVA0]EVAVAL = [F:EVE]EVAVAL
        Affzo [EVA0]EVAVAL
        Return #Exit the process here
      Endif
    Endif
    #FRLAA - 2016-09-26 - X3PEOP-2267 - END

#ANMCL - 2017-05-08 -  X3-29417 - END
  Endif
  # END_73346
  If func AFNC.ACTIV("FRT")
    TIT = mess(69,10720,1) : # Génération des demandes et mise à jour des compétences
  Else
    TIT = mess(66,10720,1) : # Mise à jour des compétences dans la carrière
  Endif
  If !GSERVEUR
   Call OUVRE_TRACE(TIT) From LECFIC
  Endif
  Call ECR_TRACE(TIT,0) From GESECRAN # Mise à jour des compétences et génération des demandes
Endif
GOK = 1
Call DEBTRANS From GLOCK
Trbegin [CPE]
 Gosub TRANSAC
If   GOK<0 : Goto ROLL_TR1
Elsif !GOK : Goto AB_TR1
Endif
Commit
[M:EVA0]EVAVAL = [F:EVE]EVAVAL
Affzo [EVA0]EVAVAL
# FQ88791 - MABON 26/03/13 - Initialisation de l'évaluateur N+2
If [M:EVA0]EVAVAL=5 & [F:EVE]EVAMAT2<>"" Then
  [M:EVA6]EVAMAT2 = [F:EVE]EVAMAT2
  Read [F:ID]ID0=[M:EVA6]EVAMAT2
  If !fstat
   [M:EVA6]SRN2 = [F:ID]NAM-[F:ID]SRN
  Endif
  Affzo [EVA6]EVAMAT2,SRN2
Endif
# Fin MABON
# segay 24/12/10 LOT P02 pas de validation compétence pour validation+2
# FQ85052 - MABON - 21/01/13 - Insertion d'un item dans le menu local 2410 en position 2
#If L_SV_EVAVAL<2
#If L_SV_EVAVAL<3
If L_NEW_EVAVAL=4 & L_SV_EVAVAL < L_NEW_EVAVAL
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  If func AFNC.ACTIV("FRT")
    If L_NBDEM>0 Then
      Call ECR_TRACE(mess(70,10720,1)-":"-num$(L_NBDEM),0) From GESECRAN : # Nombre de demandes mis à jour
    Else
      Call ECR_TRACE(mess(71,10720,1),0) From GESECRAN : # Aucune demande à traiter
    Endif
  Endif
  If L_NBCP>0
   #Nombre de compétences mis à jour :
   Call ECR_TRACE(mess(67,10720,1)-":"-num$(L_NBCP),0) From GESECRAN
  Else
   #Aucun compétence à traiter
   Call ECR_TRACE(mess(68,10720,1),0) From GESECRAN
  Endif

  If !GSERVEUR
   Call FERME_TRACE From LECFIC
   # Affichage de la trace
   Call LEC_TRACE From LECFIC
  Endif
Endif
Return
#######
$TRANSAC
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
#Readlock [EVE]EVE0=[M:EVA0]REFNUM;[M:EVA0]CTRNUM;[M:EVA0]EVADAT
#ANMCL - 2017-05-08 -  X3-29417 - START
If dim(WG_POREVA) < 0
    If func AFNC.ACTIV("EVAEN")>0
      Readlock [EVE]EVE1=[M:EVA0]REFNUM;[M:EVA0]CTRNUM;[M:EVA0]EVADATSTR;[M:EVA0]EVADATEND;[M:EVA0]EVATYP;[M:EVA6]EVAMAT
  Else
    Readlock [EVE]EVE0=[M:EVA0]REFNUM;[M:EVA0]CTRNUM;[M:EVA0]EVADATSTR;[M:EVA0]EVADATEND;[M:EVA0]EVATYP
  Endif
  If fstat=1
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
# GOK=-1 : GLOCK="$EVAEMP"-[F:EVE]REFNUM-[M:EVA0]CTRNUM-num$([F:EVE]EVADAT) : Return
  GOK=-1 : GLOCK="$EVAEMP"-[F:EVE]REFNUM-[M:EVA0]CTRNUM-num$([F:EVE]EVADATSTR)-num$([F:EVE]EVADATEND) : Return
  Elsif fstat
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
# GOK=0 : Call RSTA("EPE",[F:EVE]REFNUM-[M:EVA0]CTRNUM-num$([F:EVE]EVADAT)) From GLOCK : Return
  GOK=0 : Call RSTA("EPE",[F:EVE]REFNUM-[M:EVA0]CTRNUM-num$([F:EVE]EVADATSTR)-num$([F:EVE]EVADATEND)) From GLOCK : Return
  Endif
Endif
#ANMCL - 2017-05-08 -  X3-29417 - END
