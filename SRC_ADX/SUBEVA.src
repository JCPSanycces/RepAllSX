Subprog AM_EVALEVMIS(VALEUR)
Variable Char    VALEUR()
Local Integer L_NOL : L_NOL = nolign-1
Call NIVREF([M:EVA7]EVAMIS,VALEUR, [M:EVA7]EVAMISREF(L_NOL))
Affzo [EVA7]EVAMISREF(L_NOL)

#ANMCL - 2017-05-08 -  X3-29417 - START
#FRLAA - 2016-06-20 - REQUIREMENT 108587 US 1 - START
#Only using the score of the mission level selected if there are no indicators.
#The field should not be active but just a check
