#  Endif
Gosub ACTIV_BYCEV

If func AFNC.ACTIV("EVAEN")>0
  If REP="C" | REP="D" | [M:EVA0]EVAMAIREC <> 2
   Call VIREBOUT(CHAINE,"B") From GOBJET
  Endif
Endif
#ANMCL - 2017-05-08 -  X3-29417 - END

Return

