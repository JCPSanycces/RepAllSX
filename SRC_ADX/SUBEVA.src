######################################################################################
Subprog NIVREF(COD_SCA,COD_NIV, COD_REF)
Value    Char     COD_SCA()
Value    Char     COD_NIV()
Variable Decimal  COD_REF

Local Integer I, J

If clalev([F:HRSCA])=0 : Local File SCALE      [HRSCA] : Endif

COD_REF = 0
Call LECTURE("HRSCA",COD_SCA,"") From CONTOBJ
If !fstat
 J = find("",[F:HRSCA]LEV)
 I = find(COD_NIV,[F:HRSCA]LEV(0..J-2))
 If I>0 Then
  COD_REF = [F:HRSCA]LEVREF(I-1)
 Endif
Endif
End
