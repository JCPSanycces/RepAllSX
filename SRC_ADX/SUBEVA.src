# FQ85052 - MABOs - 08/04/13 - Insertion d'un item dans le menu local 10947 en position 2
#If !fstat & [F:ACV]FLACT=2 & L_SV_EVAVAL<2 # segay 24/12/10 LOT P02 pas de demande pour validation+2
If !fstat & [F:ACV]FLACT=2 & L_NEW_EVAVAL=4 & L_SV_EVAVAL < L_NEW_EVAVAL
 # segay 24/12/10 LOT P02

#ANMCL - 2017-05-08 -  X3-29417 - START
# Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 ##Génération des demandes pour
##     SEGAY - 08/08/12 - EXI 81491 83397 US606
## Call ECR_TRACE(mess(203,10717,1)-":"-[F:EVE]REFNUM-mess(95,100,1)-num$([F:EVE]EVADAT),0) From GESECRAN
# Call ECR_TRACE(mess(203,10717,1)-":"-[F:EVE]REFNUM-mess(95,100,1)-num$([F:EVE]EVADATSTR)-num$([F:EVE]EVADATEND),0) From GESECRAN
 If dim(WG_POREVA) < 0
   Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
   #Génération des demandes pour
   Call ECR_TRACE(mess(203,717,1)-":"-[F:EVE]REFNUM-mess(95,100,1)-num$([F:EVE]EVADATSTR)-num$([F:EVE]EVADATEND),0) From GESECRAN
 Endif

For L_IJ=0 To dim([F:EVE]DEMNUM)-1
  # segay 12/05/11 bug 73794
#  If [F:EVE]EVASTG(L_IJ)="" & [F:EVE]DOM(L_IJ)="" : Break : Endif
#     SEGAY - 12/12/12 BUG 86600 On n'a besoin de tester que Soit le STG , soit le DOM , soit le THM est renseigné
#  If [F:EVE]EVASTG(L_IJ)="" & ([F:EVE]DOM(L_IJ)="" or [F:EVE]THM(L_IJ)="") : Break : Endif
  If [F:EVE]EVASTG(L_IJ)="" & [F:EVE]DOM(L_IJ)="" & [F:EVE]THM(L_IJ)="" : Break : Endif

  If [F:EVE]DEMNUM(L_IJ)=""
   Gosub CRE_DEM
   If GOK<1 : Break : Endif
   [M:EVA3]DEMNUM(L_IJ) = [F:EVE]DEMNUM(L_IJ)
   Affzo [EVA3]DEMNUM(L_IJ)
  Endif
 Next L_IJ
 If GOK<1 : Return : Endif
Endif
# SEGAY - 16/01/13 - EXI 87090 US1222 + 87537
If [F:EVE]EVAVAL < 1
  [F:EVE]EVAVAL += 1
Endif
# END SEGAY - 16/01/13 - EXI 87090 US1222 + 87537
# FQ85052 - MABOS - 08/14//13 - Insertion de 2 items dans le menu local 10947 en positions 2 et 3
#     - si Statut="En cours" ==> +3 pour devenir Validé N+1
#     - si Statut="A valider C" ==> +2 pour devenir "Validé N+1"
#     - si Statut="A valider N+1" ou "Validé N+1" ==> +1 pour devenir "Validé N+1" ou "Validé N+2"
#     New EVAVAL in L_NEW_EVAVAL
#[F:EVE]EVAVAL += 1
#[F:EVE]DATVAL([F:EVE]EVAVAL-2) = date$
#[F:EVE]TIMVAL([F:EVE]EVAVAL-2) = ctrans(time$,":","")
#[F:EVE]USRVAL([F:EVE]EVAVAL-2) = GUSER
#If dim(GW_POREVA) < 0 # SEGAY - 12/02/13 - FQ85022 US1209 US1326
  [F:EVE]EVAVAL=L_NEW_EVAVAL # SEGAY - 12/02/13 - FQ85022 US1209 US1326
#Endif
[F:EVE]DATVAL([F:EVE]EVAVAL-4) = date$
[F:EVE]TIMVAL([F:EVE]EVAVAL-4) = ctrans(time$,":","")
[F:EVE]USRVAL([F:EVE]EVAVAL-4) = GUSER
# Fin MABOS

# FQ88791 - MABON 26/03/13 - Initialisation de l'évaluateur N+2
If [F:EVE]EVAVAL=5 & [F:EVE]EVAMAT2="" & [F:EVE]EVALIB2="" & GREFNUM<>"" Then
  [F:EVE]EVAMAT2  = GREFNUM
Endif
# Fin MABON
Rewrite [EVE]
If fstat
 GOK=0 : Call FSTA("EVE") From GLOCK : Return
Endif
# segay 24/12/10 LOT P02 pas de validation compétence pour validation+2
# FQ85052 - MABOS - 08/04/13 - Insertion d'un item dans le menu local 10947 en position 2 ==>
#If L_SV_EVAVAL>1 : Return : Endif
If L_SV_EVAVAL>3 : Return : Endif
# segay 24/12/10 LOT P02
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
#Mise à jour des compétences dans la carrière
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
#Call ECR_TRACE(mess(66,10720,1)-":"-[F:EVE]REFNUM-mess(95,100,1)-num$([F:EVE]EVADAT),0) From GESECRAN
Call ECR_TRACE(mess(66,10720,1)-":"-[F:EVE]REFNUM-mess(95,100,1)-num$([F:EVE]EVADATSTR)-num$([F:EVE]EVADATEND),0) From GESECRAN
# Test si on n'a pas trop de compétences
L_NBCPC_SAL = func NB_CPC_SAL

# Création de la compétence dans CPCEMP, pour historique
For nolign=1 To [M:EVA2]NBRVAL
 # JML 24/09/10 CG uniquement si le niveau change
 # JML 21/10/10 CG Le bouton Validation n'a pas la notion de modif.
# If [M:EVA2]FLGMODVAL(nolign-1)=2
  # JML 21/10/10 CG mail du 14/10/10
  #& [M:EVA2]LEVCPCEVA(nolign-1)<>""
  #& & [M:EVA2]LEVCPCEVA(nolign-1)<>[M:EVA2]LEVCPCVAL(nolign-1)
#TODO SEGAY - 08/08/12 - EXI 81491 83397 US606 ?
  Readlock [CPE]CPE0=[F:EVE]REFNUM;[F:EVE]EVADAT;[M:EVA2]CPCVAL(nolign-1)
  If fstat=1
   GOK=-1 : GLOCK="$CPCEMP"-[F:EVE]REFNUM-num$([F:EVE]EVADAT)-[M:EVA2]CPCVAL(nolign-1) : Break
#  SEGAY - 25/01/13 - BUG 87490 + BUG 87492
#  Elsif fstat=0 & [M:EVA2]LEVCPCVAL(nolign-1)<>[F:CPE]LEVCPC
  Elsif fstat=0 & [M:EVA2]LEVCPCEVA(nolign-1) <> "" & [M:EVA2]CPCVAL(nolign-1) <> "" & [M:EVA2]LEVCPCVAL(nolign-1)<>[F:CPE]LEVCPC
   [F:CPE]LEVCPC = [M:EVA2]LEVCPCEVA(nolign-1)
   [F:CPE]ORICPC = 3     : # ML 2402 Evaluation
   [F:CPE]UPDDAT = date$
   [F:CPE]UPDUSR = GUSER
   [F:CPE]UPDTIM = time
   Rewrite [CPE]
   If fstat
    GOK=0 : Call FSTA("CPE") From GLOCK : Break
   Endif
# segay 24/12/10 LOT P02
   #Mise à jour du niveau de compétence :
   Call ECR_TRACE(space$(5)+mess(16,10720,1)-":"-[F:CPE]CPC-[F:CPE]LEVCPC-mess([F:CPE]ORICPC,10939,1),0) From GESECRAN
   L_NBCP += 1

#  Elsif fstat
  Elsif fstat & [M:EVA2]LEVCPCEVA(nolign-1) <> "" & [M:EVA2]CPCVAL(nolign-1) <> "" : #  SEGAY - 25/01/13 - BUG 87490 + BUG 87492

   # segay 24/12/10 LOT P02
   # Test si on n'a pas trop de compétences
   Filter [F:CPE] Where [F:CPE]REFNUM=[F:EVE]REFNUM & [F:CPE]CPCDAT <> [0/0/0] & [F:CPE]CPC = [M:EVA2]CPCVAL(nolign-1)
   Read [F:CPE]CPE1(2)=[F:EVE]REFNUM;[M:EVA2]CPCVAL(nolign-1)
   Filter [F:CPE]
   If fstat & L_NBCPC_SAL >= dim([M:EVA2]CPCVAL)
      # Trop de compétences à analyser
#ANMCL - 2017-05-08 -  X3-29417 - START
      If dim(WG_POREVA) < 0 or !GWEBSERV
        Call ERREUR(mess(48,10720,1)-num$(dim([M:EVA2]CPCVAL))) From GESECRAN
      Else
        If dim(WG_POREVA) >= 0
          WMESSAGE=mess(48,720,1)-num$(dim([M:EVA2]CPCVAL))
          Call ADDMESSERR(WMESSAGE)  From AWEB
        Endif
      Endif
#ANMCL - 2017-05-08 -  X3-29417 - END
      GOK=0  : Break
   Endif
   L_NBCPC_SAL += 1

   Raz [F:CPE]
   [F:CPE] = [M:EVA2]
   [F:CPE]REFNUM = [F:EVE]REFNUM
#TODO    SEGAY - 08/08/12 - EXI 81491 83397 US606
   [F:CPE]CPCDAT = [F:EVE]EVADAT             : # Date d'évaluation ou Date d'acquisition ?
   [F:CPE]CPC    = [M:EVA2]CPCVAL(nolign-1)
   [F:CPE]LEVCPC = [M:EVA2]LEVCPCEVA(nolign-1)
   [F:CPE]ORICPC = 3     : # ML 2402 Evaluation
   [F:CPE]CREDAT = date$
   [F:CPE]CREUSR = GUSER
   [F:CPE]CRETIM = time
   Raz [F:CPE]UPDDAT
   Raz [F:CPE]UPDUSR
   Raz [F:CPE]UPDTIM
   Write [CPE]
   If fstat
    GOK=0 : Call FSTA("CPE") From GLOCK : Break
   Endif
# segay 24/12/10 LOT P02
   #Compétence attribuée :
#ANMCL - 2017-05-08 -  X3-29417 - START
   If dim(WG_POREVA) < 0
      Call ECR_TRACE(space$(5)+mess(14,10720,1)-":"-[F:CPE]CPC-[F:CPE]LEVCPC-mess([F:CPE]ORICPC,10939,1),0) From GESECRAN
   Endif
#ANMCL - 2017-05-08 -  X3-29417 - END
   L_NBCP += 1

  Endif
# Endif : #  If [M:EVA2]FLGMODVAL(nolign-1)=2
Next nolign
If GOK<1 : Return : Endif

# Suppression des compétences dans CPCEMP
# JML 14/10/10 CG Onglet Evaluation ligne 47 Not necessary anymore
#Filter [CPE] Where [CPE]REFNUM=[F:EVE]REFNUM & [CPE]CPCDAT=[F:EVE]EVADAT & [CPE]ORICPC=3
#For [CPE]CPE0
# If !find([F:CPE]CPC,[M:EVA2]CPCVAL(0..[M:EVA2]NBRVAL-1))
#  Delete [CPE] Curr
#  If fstat=1 | fstat>5
#   GOK=-1 : GLOCK="$CPCEMP" : Break
#  Endif
# Endif
#Next
#Filter [CPE]
#If GOK<1 : Return : Endif
Return

#ANMCL - 2017-05-08 -  X3-29417 - START
######################################################################################
$TRANSAC_EVAEN
Trbegin [EVE]

Readlock [EVE]EVE1=[M:EVA0]REFNUM;[M:EVA0]CTRNUM;[M:EVA0]EVADATSTR;[M:EVA0]EVADATEND;[M:EVA0]EVATYP;[M:EVA6]EVAMAT

If fstat=1
 GOK=-1 : GLOCK="$EVAEMP"-[F:EVE]REFNUM-[M:EVA0]CTRNUM-num$([F:EVE]EVADATSTR)-num$([F:EVE]EVADATEND) : Return
Elsif fstat
 GOK=0 : Call RSTA("EPE",[F:EVE]REFNUM-[M:EVA0]CTRNUM-num$([F:EVE]EVADATSTR)-num$([F:EVE]EVADATEND)) From GLOCK : Return
Endif

#New EVAVAL in L_NEW_EVAVAL
[F:EVE]EVAVAL=L_NEW_EVAVAL
[F:EVE]DATVAL([F:EVE]EVAVAL-4) = date$
[F:EVE]TIMVAL([F:EVE]EVAVAL-4) = ctrans(time$,":","")
[F:EVE]USRVAL([F:EVE]EVAVAL-4) = GUSER
If [F:EVE]EVAVAL=5 & [F:EVE]EVAMAT2="" & [F:EVE]EVALIB2="" & GREFNUM<>"" Then
  [F:EVE]EVAMAT2  = GREFNUM
Endif

[F:EVE]NEXEVA=func DIVPAYE.DATE_NEXTINTERVIEW([F:EVE]EVATYP,[F:EVE]EVADAT)
Rewrite [EVE]
If fstat
 GOK=0 : Call FSTA("EVE") From GLOCK : Return
Endif

Return
######################################################################################
#ANMCL - 2017-05-08 -  X3-29417 - END

$CRE_DEM
#Read [TCA]TCA0 = 20 : # Module gestion des talents
#L_COMPTEUR = [F:TCA]CODNUM(0)
#If L_COMPTEUR=""
# # Compteur demande non défini
# GMESSAGE = mess(4,10717,1)
# GOK = 0 : Return
#Endif
Local Integer STAT
Local Integer L_STAT
Call LECTCA(20,STAT) From SUBTCA : # Module gestion des talents
If !STAT
  GMESSAGE = mess(4,10717,1) : # Compteur demande non défini
  GOK = 0 : Return
Else
  L_COMPTEUR= [F:TCA]CODNUM(0)
Endif
Raz [F:DEM]
Call NUMERO(L_COMPTEUR,"",datesyst,"",[F:DEM]DEMNUM,L_STAT) From SUBANM
If L_STAT
 # Erreur sur compteur
 GMESSAGE = mess(4,10702,1)-L_COMPTEUR
 GOK = 0 : Return
Endif
[F:EVE]DEMNUM(L_IJ) = [F:DEM]DEMNUM

# FQ80186 - MABON 23/03/12 - Si demande en statut En cours directement, l'origine doit être Hiérarchique pour le workflow
#[F:DEM]REFNUM    = [F:EVE]REFNUM
[F:DEM]REFNUM    = GREFNUM
# Fin MABON
# FQ87322 - MABON 17/01/13 - Si GREFNUM demandeur, on ne peut pas mettre [F:EVE]CTRNUM dans le contrat car sûrement pas en phase avec GREFNUM !!
#[F:DEM]CTR       = [F:EVE]CTRNUM
Filter [F:HRCTR] Where REFNUM=GREFNUM
Read [F:HRCTR] Last
Filter [F:HRCTR]
[F:DEM]CTR       = [F:HRCTR]CTRNUM
# Fin MABON
[F:DEM]STG       = [F:EVE]EVASTG(L_IJ)
[F:DEM]DATDEM    = datesyst
[F:DEM]DATSTR    = [F:EVE]STRVLY(L_IJ)
[F:DEM]DATEND    = [F:EVE]ENDVLY(L_IJ)
[F:DEM]FLGPLF    = 1 : # ML 1
# FQ80186 - MABON 23/03/12 - Si demande en statut En cours directement, l'origine doit être Hiérarchique pour le workflow
#[F:DEM]ORI       = 1 : # ML 456 Individuelle
[F:DEM]ORI       = 2 : # ML 456 Hiérarchique
# Fin MABON
[F:DEM]ORIDEM    = 4 : # ML 472 Entretien
[F:DEM]FLGPRO    = 1 : # ML 1
# FQ72835 - MABON 04/04/11 - Initialisation de la priorité
#[F:DEM]PIO       = 1 : # ML 2953 Normale
[F:DEM]PIO       = [F:EVE]PIO(L_IJ)
# Fin MABON
[F:DEM]DOM       = [F:EVE]DOM(L_IJ)
[F:DEM]THM       = [F:EVE]THM(L_IJ)
#ANMCL - 2017-05-08 -  X3-29417 - START
[F:DEM]DESNATFIS = ""
[F:DEM]DESCATACN = ""
#ANMCL - 2017-05-08 -  X3-29417 - END
If dim([F:DEM]CREDAT)>0 : [F:DEM]CREDAT = date$     : Endif
If dim([F:DEM]CRETIM)>0 : [F:DEM]CRETIM = time      : Endif
If dim([F:DEM]CREUSR)>0 : [F:DEM]CREUSR = GUSER     : Endif
If dim([F:DEM]EXPNUM)>0 : [F:DEM]EXPNUM = [C]EXPORT : Endif
Write [DEM]
If fstat
 GOK=0 : Call FSTA("DEM") From GLOCK : Return
Endif
# Et la ligne .... (honteusement pompé sur SUBDEM...)
Raz [F:DML]
[F:DML]DEMNUM     = [F:DEM]DEMNUM
[F:DML]NUMLIG     = 1
Read [ID]ID0=[F:DEM]REFNUM
If !fstat
 # FQ80186 - MABON 23/03/12 - Statut En cours directement
# [F:DML]STA       = 1 : # ML 454 Saisie
 [F:DML]STA       = 2 : # ML 454 En cours
 # Fin MABON
 [F:DML]FLGINS    = 1 : # ML 464 Saisie
 [F:DML]OLDFLGINS = 1 : # ML 464 Saisie
 [F:DML]NBREMP    = 1
 # FQ80186 - MABON 23/03/12 - Statut En cours directement
# [F:DML]EMP       = [F:DEM]REFNUM
 [F:DML]EMP       = [F:EVE]REFNUM
 # Fin MABON
 [F:DML]CTRNUM    = [F:DEM]CTR
 [F:DML]SEX       = [F:ID]SEX
 Filter [ADI] Where NUMTAB=10454 Order By Key CLE=N1
 For [ADI]CLE
  If fix((date$-[F:ID]DATBRN)/365)<=[F:ADI]N1
   Break
  Endif
 Next
 Filter [ADI]
 [F:DML]AGE      = [F:ADI]CODE
 Filter [HRCTR] Where [HRCTR]REFNUM=[F:DEM]REFNUM & [HRCTR]CTRNUM=[F:DEM]CTR & [HRCTR]CTRDAT<=date$
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
 If !fstat
  [F:DML]FCY     = [F:HRCTR]ETRFCY
  [F:DML]SRV     = [F:HRCTR]ETRSRV
  Read [FCY]FCY0=[F:HRCTR]ETRFCY
  If !fstat
   [F:DML]CPY    = [F:FCY]LEGCPY
  Endif
  # MABON 10/09/10 - Ajout JOBPOT et POT
  [F:DML]JOBPOT  = [F:HRCTR]JOBPOT
  [F:DML]POT     = [F:HRCTR]POT
  Call CAT2483([F:DEM]REFNUM,[F:DEM]CTR,[F:DML]CATFRT) From SUBDEM
 Endif

 If [F:DEM]STG<>""
  Call LECTURE("STG",[F:DEM]STG,"") From CONTOBJ
  # MABON - 19/08/10 - On n'a plus de flag DIF : c'est géré maintenant en dispositif comme un autre, donc dans TYPFRT
  #  If [F:STG]FLGDIF=2
  If [F:STG]TYPFRT=3
   [F:DML]DESTYPFRT = 3 : # ML 455 DIF
  Else
   [F:DML]DESTYPFRT = [F:STG]TYPFRT
  Endif
 Endif
Endif
Write [DML]
If fstat
 GOK=0 : Call FSTA("DML") From GLOCK : Return
Endif
#Demande de formation :
Call ECR_TRACE(space$(5)+mess(202,10717,1)-":"-[F:DEM]DEMNUM-"/"-mess(33,10717,1)-[F:DEM]STG,0) From GESECRAN
# FQ80186 - MABON 23/03/12 - Gestion du workflow
#TODO     SEGAY - 08/08/12 - EXI 81491 83397 US606
SAV_GOK=GOK : Gosub WORKFLOW From GENDEM : GOK=SAV_GOK
# Fin MABON

L_NBDEM += 1
Return
#######################################################
$AB_TR1
Rollback
Call ERREUR(mess (17,107,1)) From GESECRAN :#Rollback suite à une erreur dans la transaction
Return
#######################################################
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto VAL_CPC : Endif
#######################################################
######################################################################################
$ANNULE
#TODO     SEGAY - 08/08/12 - EXI 81491 83397 US606
Delete [CPE] Where [CPE]REFNUM=[F:EVE]REFNUM & [CPE]CPCDAT=[F:EVE]EVADAT & [CPE]ORICPC=3
If fstat=1 | fstat>5
 GOK=-1 : GLOCK="$CPCEMP"
Endif
# JML 13/08/10 LOT P02 (TYPOBJ=1 & 2)
If GOK<1 : Return : Endif
#   SEGAY - 08/08/12 - EXI 81491 83397 US606
#Delete [EVD] Where [EVD]REFNUM=[F:EVE]REFNUM & [EVD]EVADAT=[F:EVE]EVADAT & [EVD]CTRNUM=[F:EVE]CTRNUM

#ANMCL - 2017-05-08 -  X3-29417 - START
If func AFNC.ACTIV("EVAEN")>0
  Delete [EVD] Where [EVD]REFNUM=[F:EVE]REFNUM
&                & [EVD]EVADATSTR=[F:EVE]EVADATSTR & [EVD]EVADATEND=[F:EVE]EVADATEND & [EVD]CTRNUM=[F:EVE]CTRNUM
&                & [F:EVD]EVATYP=[F:EVE]EVATYP & [F:EVD]EVAMAT=[F:EVE]EVAMAT
Else
  Delete [EVD] Where [EVD]REFNUM=[F:EVE]REFNUM
&                & [EVD]EVADATSTR=[F:EVE]EVADATSTR & [EVD]EVADATEND=[F:EVE]EVADATEND & [EVD]CTRNUM=[F:EVE]CTRNUM
&                & [F:EVD]EVATYP=[F:EVE]EVATYP
Endif
#ANMCL - 2017-05-08 -  X3-29417 - END

If fstat=1 | fstat>5
 GOK=-1 : GLOCK="$EVAEMPDET"
Endif
If GOK<1 : Return : Endif
#   SEGAY - 08/08/12 - EXI 81491 83397 US606
#Delete [EVC] Where [EVC]REFNUM=[F:EVE]REFNUM & [EVC]EVADAT=[F:EVE]EVADAT & [EVC]CTRNUM=[F:EVE]CTRNUM
#ANMCL - 2017-05-08 -  X3-29417 - START
If func AFNC.ACTIV("EVAEN")>0
Delete [EVC] Where [EVC]REFNUM=[F:EVE]REFNUM
&                & [EVC]EVADATSTR=[F:EVE]EVADATSTR & [EVC]EVADATEND=[F:EVE]EVADATEND & [EVC]CTRNUM=[F:EVE]CTRNUM
&                & [EVC]EVATYP=[F:EVE]EVATYP & [EVC]EVAMAT=[F:EVE]EVAMAT
Else
  Delete [EVC] Where [EVC]REFNUM=[F:EVE]REFNUM
&                & [EVC]EVADATSTR=[F:EVE]EVADATSTR & [EVC]EVADATEND=[F:EVE]EVADATEND & [EVC]CTRNUM=[F:EVE]CTRNUM
&                & [EVC]EVATYP=[F:EVE]EVATYP
Endif
#Delete [EVC] Where [EVC]REFNUM=[F:EVE]REFNUM
#&                & [EVC]EVADATSTR=[F:EVE]EVADATSTR & [EVC]EVADATEND=[F:EVE]EVADATEND & [EVC]CTRNUM=[F:EVE]CTRNUM
#&                & [EVC]EVATYP=[F:EVE]EVATYP
#ANMCL - 2017-05-08 -  X3-29417 - END
If fstat=1 | fstat>5
 GOK=-1 : GLOCK="$EVAEMPCPC"
Endif
If GOK<1 : Return : Endif
# 13/02/14 - EXI 96649 US2420 Mission
#ANMCL - 2017-05-08 -  X3-29417 - START
#Indicators
If func AFNC.ACTIV("EVAEN")>0
  Delete [EVIN] Where [F:EVIN]REFNUM=[F:EVE]REFNUM & [F:EVIN]CTRNUM=[F:EVE]CTRNUM
& & [F:EVIN]EVADATSTR=[F:EVE]EVADATSTR & [F:EVIN]EVADATEND=[F:EVE]EVADATEND
& & [F:EVIN]EVATYP=[F:EVE]EVATYP & [F:EVIN]EVAMAT = [F:EVE]EVAMAT
Endif
If fstat=1 | fstat>5
 GOK=-1 : GLOCK="$EVAEMPIND"
Endif
If GOK<1 : Return : Endif

If func AFNC.ACTIV("EVAEN")>0
  Delete [EVM] Where [EVM]REFNUM=[F:EVE]REFNUM
&                & [EVM]EVADATSTR=[F:EVE]EVADATSTR & [EVM]EVADATEND=[F:EVE]EVADATEND & [EVM]CTRNUM=[F:EVE]CTRNUM
&                & [F:EVM]EVATYP=[F:EVE]EVATYP & [F:EVM]EVAMAT=[F:EVE]EVAMAT
Else
  Delete [EVM] Where [EVM]REFNUM=[F:EVE]REFNUM
&                & [EVM]EVADATSTR=[F:EVE]EVADATSTR & [EVM]EVADATEND=[F:EVE]EVADATEND & [EVM]CTRNUM=[F:EVE]CTRNUM
&                & [F:EVM]EVATYP=[F:EVE]EVATYP
Endif
#Delete [EVM] Where [EVM]REFNUM=[F:EVE]REFNUM
#&                & [EVM]EVADATSTR=[F:EVE]EVADATSTR & [EVM]EVADATEND=[F:EVE]EVADATEND & [EVM]CTRNUM=[F:EVE]CTRNUM
#&                & [F:EVM]EVATYP=[F:EVE]EVATYP
If fstat=1 | fstat>5
#ANMCL - 2017-05-08 -  X3-29417 - END
 GOK=-1 : GLOCK="$EVAEMPMIS"
Endif
If GOK<1 : Return : Endif
#END 96649
Return

# 13/02/14 - EXI 96649 US2420 Mission
$INI_POT_JOBPOT_MIS
# FQ82920 - MABON 15/06/12 - Le poste et/ou l'emploi-type sont initialisés par la carrière, et si aucune donnée
# exploitable n'est trouvée dans les carrières, on les cherche dans le contrat
Gosub INI_POT_JOBPOT
Affzo [EVA0]CTRDAT,POT,ZPOT,JOBPOT,ZJOBPOT
# 13/02/14 - EXI 96649 US2420 Mission
Gosub INIT_MIS
Return


# 13/02/14 - EXI 96649 US2420 Mission
# FQ82920 - MABON 15/06/12 - Le poste et/ou l'emploi-type sont initialisés par la carrière, et si aucune donnée
# exploitable n'est trouvée dans les carrières, on les cherche dans le contrat
# Utilisé dans GENCEV et IMPORTEVA
$INI_POT_JOBPOT
Filter [F:EPO] Where [EPO]REFNUM=[F:HRCTR]REFNUM & [EPO]CTRNUM=[F:HRCTR]CTRNUM and [EPO]DATPOT<=[M:EVA0]EVADATEND Order By DATPOT
Read [F:EPO] Last
Filter [F:EPO]
If !fstat & ([F:EPO]POT<>"" | [F:EPO]JOBPOT<>"") Then
  [M:EVA0]POT    = [F:EPO]POT
  [M:EVA0]JOBPOT = [F:EPO]JOBPOT
Else
# Fin MABON
  [M:EVA0]POT    = [F:HRCTR]POT
  [M:EVA0]JOBPOT = [F:HRCTR]JOBPOT
Endif
Return

# 13/02/14 - EXI 96649 US2420 Mission
# Utilisé dans GENCEV et IMPORTEVA
$INIT_MIS
Local Integer WJMIS
Effzo [EVA7]10
If !(dim([L]WIS_GENCEV)>0 & [L]WIS_GENCEV=1) or !GIMPORT Then
  Call AS_EVAMIS([M:EVA7]EVAMIS)
  Affzo [M:EVA7]EVAMIS, ZEVAMIS
Endif
nolign = 0
If [M:EVA0]JOBPOT<>""
  Call LECTURE("JOT",[M:EVA0]JOBPOT,"") From CONTOBJ
  For WJMIS=0 To dim([F:JOT]MIS)-1
   If [F:JOT]MIS(WJMIS)="" : Break : Endif
   Call LECTURE("MIS",[F:JOT]MIS(WJMIS),"") From CONTOBJ
   If ([F:MIS]LEG="" | [F:MIS]LEG<>"" & [F:MIS]LEG=GCURLEG) & !find([F:JOT]MIS(WJMIS),[M:EVA7]CODMIS(0..[M:EVA7]NBRMIS-1))
     If [M:EVA7]NBRMIS+1 > dim([M:EVA7]CODMIS)
       # Tableau des missions plein
       Gosub FULL_MIS
       Break
     Else
       [M:EVA7]CODMIS(nolign) = [F:JOT]MIS(WJMIS)
       nolign += 1
       [M:EVA7]NBRMIS = nolign
     Endif
   Endif
  Next WJMIS
Endif
If [M:EVA0]POT<>""
  Call LECTURE("POT",[M:EVA0]POT,"") From CONTOBJ
  For WJMIS=0 To dim([F:POT]MIS)-1
   If [F:POT]MIS(WJMIS)="" : Break : Endif
   Call LECTURE("MIS",[F:POT]MIS(WJMIS),"") From CONTOBJ
   If ([F:MIS]LEG="" | [F:MIS]LEG<>"" & [F:MIS]LEG=GCURLEG) & !find([F:POT]MIS(WJMIS),[M:EVA7]CODMIS(0..[M:EVA7]NBRMIS-1))
     If [M:EVA7]NBRMIS+1 > dim([M:EVA7]CODMIS)
       # Tableau des missions plein
       Gosub FULL_MIS
       Break
     Else
       [M:EVA7]CODMIS(nolign) = [F:POT]MIS(WJMIS)
       nolign += 1
       [M:EVA7]NBRMIS = nolign
     Endif
   Endif
  Next WJMIS
Endif

[M:EVA7]NBRMIS  = nolign
If [M:EVA7]NBRMIS >0 Then
  Sorta [M:EVA7]NBRMIS  [M:EVA7]NBRMIS  Order By [M:EVA7]CODMIS([S]indice)
Endif
Affzo [EVA7]10
Return

#ANMCL - 2017-05-08 -  X3-29417 - END
# Mission
$INIT_MIS2
If func AFNC.ACTIV("EVAEN")> 0 : Gosub INIT_MISENH : Return :Endif #FRLAA - 2016-08-01 - REQUIREMENT 117178 US 3
Local Integer WJMIS
Local Char WMISPOT(1)
nolign = 0
Call PARAM([F:HRCTR]ETRFCY,"EVAMISPOT",[L]WMISPOT) From ADOVAL
If [M:EVA0]JOBPOT<>"" & [L]WMISPOT <> "2"
  Call LECTURE("JOT",[M:EVA0]JOBPOT,"") From CONTOBJ
  For WJMIS=0 To dim([F:JOT]MIS)-1
   If [F:JOT]MIS(WJMIS)="" : Break : Endif
   If !find([F:JOT]MIS(WJMIS),[M:EVA7]CODMIS(0..[M:EVA7]NBRMIS-1))
     If [M:EVA7]NBRMIS+1 > dim([M:EVA7]CODMIS)
       # Tableau des missions plein
       Gosub FULL_MIS
       Break
     Else
       [M:EVA7]CODMIS(nolign) = [F:JOT]MIS(WJMIS)
       nolign += 1
       [M:EVA7]NBRMIS = nolign
     Endif
   Endif
  Next WJMIS
Endif
If [M:EVA0]POT<>""

  Call LECTURE("POT",[M:EVA0]POT,"") From CONTOBJ
  For WJMIS=0 To dim([F:POT]MIS)-1
   If [F:POT]MIS(WJMIS)="" : Break : Endif
   If !find([F:POT]MIS(WJMIS),[M:EVA7]CODMIS(0..[M:EVA7]NBRMIS-1))
     If [M:EVA7]NBRMIS+1 > dim([M:EVA7]CODMIS)
       # Tableau des missions plein
       Gosub FULL_MIS
       Break
     Else
       [M:EVA7]CODMIS(nolign) = [F:POT]MIS(WJMIS)
       nolign += 1
       [M:EVA7]NBRMIS = nolign
     Endif
   Endif
  Next WJMIS
Endif

[M:EVA7]NBRMIS  = nolign

If [M:EVA7]NBRMIS >0 Then
  Sorta [M:EVA7]NBRMIS  [M:EVA7]NBRMIS  Order By [M:EVA7]CODMIS([S]indice)
Endif
Affzo [EVA7]10

Return
#ANMCL - 2017-05-08 -  X3-29417 - START
$INIT_MISENH
Local Integer WJMIS
Local Char EVAMISMASK
Local Char WMISPOT(1)
Local Integer FIRSTMIS, X
If clalev([F:MPI])=0   : Local File MISPOTIND     [MPI]   : Endif
If clalev([F:MJI])=0   : Local File MISJOTIND     [MJI]   : Endif
nolign = 0
EVAMISMASK = [M:EVA7]EVAMIS
Raz [M:EVA7]
[M:EVA7]EVAMIS = EVAMISMASK
Call PARAM([F:HRCTR]ETRFCY,"EVAMISPOT",[L]WMISPOT) From ADOVAL
If [M:EVA0]JOBPOT<>"" & [L]WMISPOT <> "2"
  Call LECTURE("JOT",[M:EVA0]JOBPOT,"") From CONTOBJ
  #FRLAA - 2016-07-27 - REQUIREMENT 117178 US 3 - START
  #We need to handle the additional levels differently and keep the behaviour the same
  #Fixed values - Indicators
  [M:EVA7]INDFLG      = [F:JOT]INDFLG
  [M:EVA7]MISWEIFLG   = [F:JOT]MISWEIFLG
  [M:EVA7]INDEQ       = [F:JOT]INDEQ
  [M:EVA7]INDWEIFLG   = [F:JOT]INDWEIFLG
  [M:EVA7]MISEQ       = [F:JOT]MISEQ

  For [MJI]MJI0 Where [F:MJI]JOT = [F:JOT]COD
    If nolign<=dim([M:EVA7]CODMIS)-1
      FIRSTMIS = 1
      nolign += 1
      [M:EVA7]WMIS(nolign-1)          = [F:MJI]MIS
      [M:EVA7]CODMIS(nolign-1)        = [F:MJI]MIS
      [M:EVA7]MISWEI(nolign-1)        = [F:MJI]MISWEI
      For X = 1 To dim([F:MJI]IND)
        If [F:MJI]IND(X-1) <> ""
          If FIRSTMIS = 1 : FIRSTMIS = 2 : Else nolign += 1  :Endif
          [M:EVA7]WMIS(nolign-1)    = [F:MJI]MIS
          [M:EVA7]IND(nolign-1)     = [F:MJI]IND(X-1)
          [M:EVA7]INDWEI(nolign-1)  = [F:MJI]INDWEI(X-1)
        Else
          Break
        Endif
      Next X
    Else
      Gosub FULL_MIS
    Endif
  Next
Elsif  [M:EVA0]POT<>""
  Call LECTURE("POT",[M:EVA0]POT,"") From CONTOBJ
  #FRLAA - 2016-07-27 - REQUIREMENT 117178 US 3 - START
  #We need to handle the additional levels differently and keep the behaviour the same
  #Fixed values - Indicators
  [M:EVA7]INDFLG      = [F:POT]INDFLG
  [M:EVA7]MISWEIFLG   = [F:POT]MISWEIFLG
  [M:EVA7]INDEQ       = [F:POT]INDEQ
  [M:EVA7]INDWEIFLG   = [F:POT]INDWEIFLG
  [M:EVA7]MISEQ       = [F:POT]MISEQ

  For [MPI]MPI0 Where [F:MPI]POT = [F:POT]COD
    If nolign<=dim([M:EVA7]CODMIS)-1
      FIRSTMIS = 1
      nolign += 1
      [M:EVA7]WMIS(nolign-1)          = [F:MPI]MIS
      [M:EVA7]CODMIS(nolign-1)        = [F:MPI]MIS
      [M:EVA7]MISWEI(nolign-1)        = [F:MPI]MISWEI
      For X = 1 To dim([F:MPI]IND)
        If [F:MPI]IND(X-1) <> ""
          If FIRSTMIS = 1 : FIRSTMIS = 2 : Else nolign += 1  :Endif
          [M:EVA7]WMIS(nolign-1)    = [F:MPI]MIS
          [M:EVA7]IND(nolign-1)     = [F:MPI]IND(X-1)
          [M:EVA7]INDWEI(nolign-1)  = [F:MPI]INDWEI(X-1)
        Else
          Break
        Endif
      Next X
    Else
      Gosub FULL_MIS
    Endif
  Next
Endif
[M:EVA7]NBRMIS  = nolign
Affzo [EVA7]10

Return
#FRLAA - 2016-08-01 - REQUIREMENT 117178 US 3 - END
#ANMCL - 2017-05-08 -  X3-29417 - END

# 13/02/14 - EXI 96649 US2420 Mission
# Utilisé dans GENCEV et IMPORTEVA
# Tableau des missions plein
$FULL_MIS
If !(dim([V]IS_CTR_CTRNUM)>0 & [V]IS_CTR_CTRNUM=1) Then
  If dim([L]WIS_GENCEV)>0 & [L]WIS_GENCEV=1 Then
      Call ECR_TRACE(mess(150,10720,1)-" > "+num$(dim([M:EVA7]CODMIS)) -mess(1,10319,1)-[F:HRCTR]REFNUM-"/"-mess(72,10720,1)-[F:HRCTR]CTRNUM-"/"-format$("D:"+GFMDAT,[F:HRCTR]CTRDAT),0) From GESECRAN
  Else
    If !GIMPORT
       Call ERREUR(mess(150,10720,1)) From GESECRAN
    Else
       Call TRACE(-2,mess(150,10720,1)-" > "+num$(dim([M:EVA7]CODMIS))) From SUBIMPOBJ
    Endif
  Endif
Endif
Return

#ANMCL - 2017-05-08 -  X3-29417 - START
$STYLE
#Infbox"inside $STYLE"
If func AFNC.ACTIV("EVAEN")=0 : Return : Endif
  If [M:EVA7]INDFLG = 2
    Chgfmt [M:EVA7]IND          With "K:10X"
    Chgfmt [M:EVA7]INDWEI       With "Nz:3.2"
    Chgfmt [M:EVA7]INDLEV       With "K:30X"
    Chgfmt [M:EVA7]EVALEVMIS    With "-K:30X"
    Chgfmt [M:EVA7]CMTMIS       With "-K:250X"
    Chgfmt [M:EVA7]CMTIND       With "K:250X"
    Chgfmt [M:EVA7]INDSCO       With "Nz:3.2"
    Actzo [M:EVA7]INDWEIFLG
    Actzo [M:EVA7]INDEQ
  Else
    Chgfmt [M:EVA7]IND          With "-K:10X"           : Raz [M:EVA7]IND
    Chgfmt [M:EVA7]INDWEI       With "-Nz:3.2"          : Raz [M:EVA7]INDWEI
    Chgfmt [M:EVA7]INDLEV       With "-K:30X"
    Chgfmt [M:EVA7]EVALEVMIS    With "K:30X"
    Chgfmt [M:EVA7]CMTMIS       With "K:250X"
    Chgfmt [M:EVA7]CMTIND       With "-K:250X"
    Chgfmt [M:EVA7]INDSCO       With "-Nz:3.2"
    Diszo [M:EVA7]INDWEIFLG
    Diszo [M:EVA7]INDEQ
  Endif

  Chgfmt [M:EVA6]EVALIB         With "-K:30X"
  Chgfmt [M:EVA6]EVAMAT2        With "-K:15X"
  Chgfmt [M:EVA6]SRN2           With "-K:40X"
  Chgfmt [M:EVA6]EVALIB2        With "-K:30X"

  If [M:EVA7]MISWEIFLG = 2
    Chgfmt [M:EVA7]MISWEI     With "Nz:3.2"
    Actzo [M:EVA7]MISEQ
  Else
    Chgfmt [M:EVA7]MISWEI     With "-Nz:3.2"         #: Raz [M:EVA7]MISWEI
    Diszo [M:EVA7]MISEQ
  Endif

  If [M:EVA7]INDWEIFLG= 2
    Chgfmt [M:EVA7]INDWEI     With "Nz:3.2"
    Actzo [M:EVA7]INDEQ
  Else
    Chgfmt [M:EVA7]INDWEI     With "-Nz:3.2"         #: Raz [M:EVA7]INDWEI
    Diszo [M:EVA7]INDEQ
  Endif

Gosub CHANGE_STYLE

Affzo [M:EVA7]

Return

$CHANGE_STYLE
If func AFNC.ACTIV("EVAEN") = 0 : Return : Endif
For nolign = 1 To [M:EVA7]NBRMIS
  If [M:EVA7]WMIS(nolign-1) = "" : Break: Endif
  If [M:EVA7]CODMIS(nolign-1) <> ""
    Chgstl [M:EVA7]CODMIS(nolign-1)   With "AMKACT"
    #Chgstl [M:EVA7]MISWEI(nolign-1)   With "CONTRAT2"
  Else
    Diszo [M:EVA7]CODMIS(nolign-1)
    Diszo [M:EVA7]MISWEI(nolign-1)
    #Diszo [M:EVA7]CMTMIS(nolign-1)
  Endif
Next
If [M:EVA0]EVAMAIREC <> 2
  Chgfmt [M:EVA7]MISTOTSCO        With "-Nz:3.2"     #: Raz [M:EVA7]MISTOTSCO
  Chgfmt [M:EVA7]MISCALSCO        With "-Nz:3.2"     : Raz [M:EVA7]MISCALSCO
Else
    Chgfmt [M:EVA7]MISTOTSCO        With "Nz:3.2"  : Affzo [M:EVA7]MISTOTSCO
    Chgfmt [M:EVA7]MISCALSCO        With "Nz:3.2"  : Affzo [M:EVA7]MISCALSCO
Endif

Chgfmt [M:EVA0]VISCOL  With "-LA:2413"  #FRLAA - X3PEOP-4050 - 2016-11-11


Gosub CHANGE_STYLE_EVAEMPSTA

Return
#FRLAA - 2016-06-16 - REQUIREMENT 108587 US 1 - END

