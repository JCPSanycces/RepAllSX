Subprog C_FLGYEA(VALEUR)
Variable Integer VALEUR
Local Integer OK
If clalev([F:EVE1])=0 : Local File EVAEMP [EVE1] : Endif
If VALEUR=2
 Filter [EVE1] Where REFNUM=[M]REFNUM & EVADAT>gdat$(day([M]EVADAT),month([M]EVADAT),year([M]EVADAT)-1)
&& EVADAT<gdat$(day([M]EVADAT),month([M]EVADAT),year([M]EVADAT)+1) & FLGYEA=2 & EVATYP=[M]EVATYP
 Read [EVE1]EVE0 First
 If !fstat
  OK = 1
  # Fiche d'entretien annuel déjà existante le
  Call AVERTIR(mess(41,10720,1)-num$([F:EVE1]EVADAT),OK) From GESECRAN
  If OK=1
   mkstat = 2
  Endif
 Endif
 Filter [EVE1]
Endif
End

