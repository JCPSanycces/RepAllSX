Raz GPILOBJ
Call OBJET("EVA",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
## Gestion des évaluations
######################################################################################

## Règles de gestion
## Si suppression d'une compétence d'une évaluation on la supprime de CPCEMP si origine=évaluation
## La création d'une compétence dans une évaluation crée une compétence dans CPCEMP.
## si la compétence existe déjà avec un niveau différent, on lui change son niveau
## La modification du niveau d'une compétence est reportée dans CPCEMP

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE     #after tables linked to object is opened
 When "FERME"       : Gosub FERME     #after object has been closed
 When "ABANDON"     : Gosub ABANDON   #abort and or rollback
 When "LIENS"       : Gosub LIENS From SUBEVA2    #after linked tables or record has been read
 When "SETBOUT"     : Gosub SETBOUT   #window or button is drawn or refreshed
 When "VERIF_CRE"   : Gosub CTL_EVAL  #before a database transaction is started
 When "VERIF_MOD"   : Gosub CTL_EVAL  #standard modification mode actions ??? before or after
 When "MODIF"       : Gosub CRE_MOD   #after rewrite statement
 When "CREATION"    : Gosub CRE_MOD   #after [F] class is written
 When "ANNULE"      : Gosub ANNULE    #before delete statement
 When "RAZDUP"      : Gosub RAZ_DUP   #when duplicates are cleared ???
 When "RAZCRE"      : Gosub RAZ_CRE   #when screens are cleared before user entry
 When "EXEBOUT"     : Gosub EXEBOUT   #after button action is executed
 When "SEL_LISTE"   : Gosub SEL_LISTE #before a select window is displayed
 When "SEL_TABLE"   : Gosub SEL_TABLE #also before a select window is displayed #ANMCL - 2017-05-08 -  X3-29417 - END
 When "FILTRE"      : Gosub FILTRE    #before table records are filtered
 When "FILGAUCHE"   : Gosub FILGAUCHE # ???
 When "STYLE"       : Gosub STYLE     #before fields are displayed #ANMCL - 2017-05-08 -  X3-29417
 When "APRES_CHOI"  : Gosub APRES_CHOI #after user has selected window option
 When "FIN_ACTION"  : Gosub FIN_ACTION #end user action, list record selection etc #ANMCL - 2017-05-08 -  X3-29417
 When "APRES_MOD"   : Gosub APRES #after the modification of any field in a window #ANMCL - 2017-05-08 -  X3-29417
 When "INIMOD"      : Gosub INI   # Issue 11472 - 2017-10-02 by BRBAN : Needed to update training sessions in Training tab
 When "INICRE"      : Gosub INI   # Issue 11472 - 2017-10-02 by BRBAN : Needed to update training sessions in Training tab
 When "APRES_CRE"   : Gosub APRES # Issue 11472 - 2017-10-02 by BRBAN : Needed to update training sessions in Training tab
Endcase
Return


#TIVAN - 2017-04-03 - Integration of Interviews  X3-29417 ZAF - Start
$FIN_ACTION
#Infbox"inside $FIN_ACTION"
Case BOUT
  When "B" :
    If mkstat=4 & GREP=""
      Gosub ENTRE_MODIF From GOBJSUB
    Endif
    Affzo [M:EVA7]
Endcase
Return
#TIVAN - 2017-04-03 - Integration of Interviews  X3-29417 ZAF - End

$APRES
# Issue 11472 - 2017-10-02 by BRBAN : Update Training tab with the new values
If func AFNC.ACTIV("FRT")>0
  Raz [M:EVA3]NBRSTG,EVASTG,DOM,THM,STRVLY,ENDVLY,PIO,DEMNUM,CMTSTG
  [L]NOL = 0

  For I=0 To dim([F:EVE]EVASTG)-1
    If [F:EVE]EVASTG(I)<>''
      [M:EVA3]EVASTG([L]NOL) = [F:EVE]EVASTG(I)
      [M:EVA3]DOM([L]NOL)    = [F:EVE]DOM(I)
      [M:EVA3]THM([L]NOL)    = [F:EVE]THM(I)
      [M:EVA3]STRVLY([L]NOL) = [F:EVE]STRVLY(I)
      [M:EVA3]ENDVLY([L]NOL) = [F:EVE]ENDVLY(I)
      [M:EVA3]PIO([L]NOL)    = [F:EVE]PIO(I)
      [M:EVA3]DEMNUM([L]NOL) = [F:EVE]DEMNUM(I)
      [M:EVA3]CMTSTG([L]NOL) = [F:EVE]CMTSTG(I)
      # Descriptions of the fields
      Read [F:STG]STG0=[F:EVE]EVASTG(I)
      If !fstat
        [M:EVA3]ZEVASTG([L]NOL)=[F:STG]DES
      Endif
      Call LECTEXTRA([M:EVA3]ZDOM,"ATABDIV","LNGDES",num$(381),[F:EVE]DOM(I)) From ATEXTRA
      Call LECTEXTRA([M:EVA3]ZTHM,"ATABDIV","LNGDES",num$(457),[F:EVE]THM(I)) From ATEXTRA
      [L]NOL +=1
    Endif
  Next
  [M:EVA3]NBRSTG = [L]NOL
  Affzo [M:EVA3]NBRSTG,EVASTG,DOM,THM,STRVLY,ENDVLY,PIO,DEMNUM,CMTSTG
  Affzo [M:EVA3]ZDOM,ZTHM,ZEVASTG
Endif

If ACTION = "APRES_MOD"
  Gosub APRES_MOD
Endif
# -
Return

$INI
# Issue 11472 - 2017-10-02 by BRBAN : Update the Trainings with new training season associated with the skill in [M:EVA2]STGCOD
If func AFNC.ACTIV("FRT")>0
  For I=0 To  [M:EVA2]NBRVAL-1
    If find([M:EVA2]STGCOD(I),[F:EVE]EVASTG)<=0
      Read [F:STG]STG0=[M:EVA2]STGCOD(I)
      If !fstat
        J = find("",[F:EVE]EVASTG)-1
        If J<dim([F:EVE]EVASTG)
          [F:EVE]EVASTG(J)   = [F:STG]COD
          [F:EVE]DOM(J)      = [F:STG]DOM
          [F:EVE]THM(J)      = [F:STG]THM
          [F:EVE]STRVLY(J)   = [F:STG]STRVLY
          [F:EVE]ENDVLY(J)   = [F:STG]ENDVLY
          [F:EVE]PIO(J)      = 1
        Else
          Call ECR_TRACE(mess(5,14,1)-":"-mess(26,100,1),0) From GESECRAN
          Break
        Endif
      Endif
    Endif
  Next
Endif
# -
Return

$FILTRE
FILTSUP = "[F:ID]FLGNEWSAL<>2"
If GUSRACS<>2
 FILTSUP -= '& ([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILTSUP -= '& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))'
Endif
#78892
Call FILTREROLE("EML",FILTSUP) From SUBEML
#On cumule
Call FILTREROLE("EVA",FILTSUP) From SUBEML

If GFONCTION1="GESCEV" and clalev([M:CEV0])>0 Then
  If(FILTSUP<>"") :FILTSUP-="&" : Endif
  FILTSUP -= "(CEV='"+[M:CEV0]COD+"')"
   Call FROM_CEVSTAT(FILTSUP) :#MABOS-29/03/13-FQ 88316-US 1420-List from Follow-up
Endif

Return

$FILGAUCHE
#ANMCL - 2017-05-08 -  X3-29417 - START -FILGAUSUP = "[F:ID]FLGNEWSAL<>2"
FILGAUSUP = "[F:ID]FLGNEWSAL<>2 & [F:EVE]EVAVAL<10"

If GUSRACS<>2
 FILGAUSUP -= '& ([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILGAUSUP -= '& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))'
Endif
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 FILGAUSUP -= '& find([F:ECT]FCY,GUSRFCY(1..GNBAUZ))'
Endif
#78892
Call FILTREROLE("EML",FILGAUSUP) From SUBEML
# On cumule
Call FILTREROLE("EVA",FILGAUSUP) From SUBEML

# FQ81085 US740 - SEGAY 10/09/12 - Filter left list according LEGFIL
If GLEGFIL<>""
  If(FILGAUCHE<>"") :FILGAUCHE-="&" : Endif
  FILGAUCHE -= "(find([F:FCY]LEG,'"+GLEGFIL+"','')>0)"
  If FILGAUSUP<>"" : FILGAUSUP += " & " : Endif
  FILGAUSUP += "(find([F:FCY]LEG,'"+GLEGFIL+"','')>0)"
Endif
# End SEGAY

If GFONCTION1="GESCEV" and clalev([M:CEV0])>0 Then
  If(FILGAUCHE<>"") :FILGAUCHE-="&" : Endif
  FILGAUCHE -= "(CEV='"+[M:CEV0]COD+"')"
  If FILGAUSUP<>"" : FILGAUSUP += " & " : Endif
  FILGAUSUP += "(CEV='"+[M:CEV0]COD+"')"

  Call FROM_CEVSTAT(FILGAUCHE) :#MABOS-29/03/13-FQ 88316-US 1420-List from Follow-up
  Call FROM_CEVSTAT(FILGAUSUP) :#MABOS-29/03/13-FQ 88316-US 1420-List from Follow-up
Endif

Return

# FQ81085 US740 - SEGAY 10/09/12 - Navigate in the records, taking into account GLEGFIL
$FILEVA
  CRITEVA="1=1"
  If GLEGFIL<>""
    If CRITEVA<>"" Then CRITEVA-="&" : Endif
    CRITEVA -= "(find([F:FCY]LEG,'"+GLEGFIL+"','')>0)"
  Endif
  If CRITEVA<>"" Then CRITEVA-="&" : Endif
  CRITEVA -= "[F:ID]FLGNEWSAL<>2"
  If GUSRACS<>2
    If CRITEVA<>"" Then CRITEVA-="&" : Endif
    CRITEVA -= '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
    CRITEVA -= '& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))>0'
  Endif
  If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
    If CRITEVA<>"" Then CRITEVA-="&" : Endif
    CRITEVA -= 'find([F:ECT]FCY,GUSRFCY(1..GNBAUZ))>0'
  Endif
  Call FILTREROLE("EML",CRITEVA) From SUBEML
  Call FILTREROLE("EVA",CRITEVA) From SUBEML

  #MABOS-08/03/13-Bug 87748-Last/next in left list from GESCEV
  If GFONCTION1="GESCEV" and clalev([M:CEV0])>0 Then
    If(CRITEVA<>"") :CRITEVA-="&" : Endif
    CRITEVA -= "(CEV='"+[M:CEV0]COD+"')"
    Call FROM_CEVSTAT(CRITEVA) :#MABOS-29/03/13-FQ 88316-US 1420-List from Follow-up
   Endif

  Filter [EVE_] Where evalue(CRITEVA)
Return
# End SEGAY


#####################################
$APRES_CHOI
  Case REPONSE
    When GSTASUI, GSTAPRE, GSTAFIR,GSTALAS
      Gosub FILEVA
      If REPONSE=GSTASUI Then Read [EVE_]EVE0 > [M:EVA0]REFNUM;[M:EVA0]CTRNUM;[M:EVA0]EVADATSTR;[M:EVA0]EVADATEND;[M:EVA0]EVATYP : Endif
      If REPONSE=GSTAPRE Then Read [EVE_]EVE0 < [M:EVA0]REFNUM;[M:EVA0]CTRNUM;[M:EVA0]EVADATSTR;[M:EVA0]EVADATEND;[M:EVA0]EVATYP : Endif
      If REPONSE=GSTAFIR Then Read [EVE_]EVE0 First         : Endif
      If REPONSE=GSTALAS Then Read [EVE_]EVE0 Last          : Endif
      Filter [EVE_]
      Gosub SUIVPREC From TOOLSHRLEG
  Endcase
Return
# End MABON
$OUVRE

#ANMCL - 2017-05-08 -  X3-29417 - START
Local Integer STA_EVASTA #FRLAA - X3PEOP-2053 - 2016-11-02
If clalev([F:EVIN])=0    : Local File EVAEMPIND [EVIN]  : Endif #FRLAA - X3-11714-12859 2017-01-09 #ANMCL - 2017-05-08 -  X3-29417 - START
If clalev([F:EVI])=0     : Local File EVAEMPACT [EVI]   : Endif
#Infbox "[EVI] rowcount before read = "-num$(rowcount([EVI]))

If clalev([F:EVE1])=0   : Local File EVAEMP   [EVE1] : Endif
# 80822 - SEGAY - 16/03/12 Ouvrir que si FRT
If func AFNC.ACTIV("FRT")
  If !clalev([F:INS])   : Local File INSCRIPT [INS]  : Endif
Endif
# 71140 - SYMEU - 28/01/2011
If !clalev([F:FCY2])    : Local File FACILITY [FCY2] : Endif
# FQ82920 - MABON 15/06/12
If clalev([F:EPO])=0    : Local File EMPLOPOT [EPO]  : Endif
# Fin MABON
# FQ81085 - MABON 16/07/12
If clalev([F:FCY])=0    : Local File FACILITY [FCY]  : Endif
# Fin MABON
#SEGAY 25/10/12 US 930 81085
If clalev([F:POT])=0  : Local File POSTE     [POT]  : Endif
If clalev([F:JOT])=0  : Local File JOBTYP    [JOT]  : Endif
#END SEGAY 25/10/12 US 930 81085
If clalev([F:MIS])=0  : Local File MISSION   [MIS]  : Endif : #  13/02/14 - FQ 96649 - US2420 - Mission

Local Integer L_IJ
Local Integer L_OK
Local Char    L_COMPTEUR(type([F:EVE]DEMNUM)-10)
Local Integer L_STAT
Local Integer L_NBCPC_SAL : #SEGAY - 24/12/10 - EXI 66105 lot P02 - V6.1
Local Integer L_NBCP  : #SEGAY - 24/12/10 - EXI 66105 lot P02 - V6.1
Local Integer L_NBDEM  : #SEGAY - 24/12/10 - EXI 66105 lot P02 - V6.1
Local Integer L_SV_EVAVAL : #SEGAY - 24/12/10 - EXI 66105 lot P02 - V6.1
Local Integer L_NEW_EVAVAL

If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
Filter [F:ADW] Where PARAM='EVAYEA' & VALEUR<>""
If rowcount([F:ADW])=0 Then
  Infbox mess(95,10720,1) : # Le paramètre EVAYEA contenant le type d'entretien annuel, n'est pas renseigné
Endif
Filter [F:ADW]
# contrat -> pays -> valeur /defaut pour impression fiche
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif

# Issue 11472 - 2017-09-21 by BRBAN : Enviroment to create a record in Training requests
If func AFNC.ACTIV("FRT")>0
  If !clalev([F:STG])   : Local File STAGE      [STG]   : Endif
  Local Integer NOL     : [L]NOL      = 0
Endif

# FQ81085 - MABON 16/07/12 - To manage legislation in employee selection
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Local Char CRITEVA(250)
# End MABON
Return

$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
  If dim(GCURLEG2)>0    : Kill GCURLEG2         : Endif

Return

$ABANDON
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

## suppression du test sur les dates pour FLGPRO et FLGBIL
$ACTIV_BYCEV
If [M:EVA0]CEV<>"" Then
 If GREP="C" & ([M:EVA0]FLGPRO=2 | [M:EVA0]FLGBIL=2 )
   Actzo [M:EVA0]EVADATSTR, EVADATEND
 Else
   Grizo [M:EVA0]EVADATSTR, EVADATEND, EVATYP
 Endif
Else
 Actzo [M:EVA0]EVADATSTR, EVADATEND, EVATYP
Endif
Return

