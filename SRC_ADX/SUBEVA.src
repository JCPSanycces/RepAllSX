#* SEGAY
#*!
Funprog NB_CPC_SAL
Local Integer NB_CPC
NB_CPC = 0
For [CPE]CPE1(2) Where [F:CPE]REFNUM=[M:EVA0]REFNUM & [F:CPE]CPCDAT<>[0/0/0]
 # CPE1 * REFNUM+CPC+CPCDAT
 NB_CPC+=1
