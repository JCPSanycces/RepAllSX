######################################################################################
Subprog C_EVASTG(VALEUR)
Variable Char    VALEUR()
Local Integer L_NOL
L_NOL = nolign-1

# JML 17/09/10 CG It's not a mandatory field anymore
If VALEUR="" : End : Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini
Call CTL_STG_NON_DEF(VALEUR) From DIVFOR
If mkstat Then End Endif

# JML 14/10/10 CG plus de controle unicité (Suite duplication, on conserve anciennes demandes...)
#Call UNICITE(VALEUR,[M]EVASTG) From OBJDIV

Call LECTURE("STG",VALEUR,"") From CONTOBJ
If !mkstat
  ################################################################################
  # JML 14/09/10 Pompé sur SUBDEM : Contrôle que le salarié appartient à la cible
  #     A faire quand le Subprog ne fera plus appel à M:DEM0....
  #Call VERIF_CIBLE([M:EVA0]REFNUM,[M:EVA0]CTRNUM) From SUBDEM
  #If mkstat=2 : End : Endif
  ################################################################################
 [M]DOM(L_NOL)    = [F:STG]DOM
 [M]THM(L_NOL)    = [F:STG]THM
 [M]STRVLY(L_NOL) = [F:STG]STRVLY
 [M]ENDVLY(L_NOL) = [F:STG]ENDVLY
 Affzo DOM(L_NOL),THM(L_NOL),STRVLY(L_NOL),ENDVLY(L_NOL)
Endif
End

