Subprog AS_EVASCA(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Read [HRCTR]CTR0=[M:EVA0]REFNUM;[M:EVA0]CTRNUM;[M:EVA0]CTRDAT
 If fstat : Raz [F:HRCTR] : Endif
 Call PARAM([F:HRCTR]ETRFCY,"EVASCA",VALEUR) From ADOVAL
Endif
