#<AdxTL>@(#)3.0.0.0 $Revision$
########################################################################################################################
#
# CONSULTATION PIECES COMPTABLES : Visualisation des ventilations analytiques
# ==============================
#
# @ver        1.0.0
# @date       xx/xx/xxxx
# @user       GBO
# @modif      xx/xx/xxxx
#
# Liste des sous-programmes :
# -------------------------
#
#
# Liste des fonctions :
# -------------------
#
#
# Liste des routines :
# ------------------
#
# $ACTION
# $OUVRE
# $DEBUT
# $TERMINE
#
########################################################################################################################
# Modifications :
# -------------
#
# - XXX - DD.MM.AAAA - Fq nnnnn - Commentaire
# - GBO - 20.12.2010 - Fq 69824 - Gestion du multi-référentiel
# - GBO - 25.09.2009 - Fq 58081 - Erreur sur ventilations analytiques
#
########################################################################################################################
Local Char PARAM(30)(1..5) , VALEUR(30)
PARAM(1)= "IMRI"
PARAM(2)= "C020203ODG068"
PARAM(3)= ""
PARAM(4)= "1"
PARAM(5)= "3"
Call SAISIE_CHAR(VALEUR,PARAM,"GACAAB","TRTGPCAAB","") From GSAISIE
End

#-------------------------------------------------------------------------------------
$ACTION
 Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "DEBUT"       : Gosub DEBUT
  When "TERMINE"     : Gosub TERMINE
  When Default
 Endcase
Return

#-------------------------------------------------------------------------------------
$OUVRE

 Local Char    LTYP
 Local Char    LNUM
 Local Integer LLIN
 Local Integer I_LIGNE, I_CCE
 Local Char    NOMFLD
 Local Decimal TOTAL
 Local Decimal QTOTAL
 Local Integer LLED     #Fq58081
 Local Integer LLEDTYP  #Fq58081

 LTYP    = PARAM(1)
 LNUM    = PARAM(2)
 LLIN    = val(PARAM(4))
 LLED    = val(PARAM(5)) #Fq58081

Return


#-------------------------------------------------------------------------------------
$DEBUT

 Local Integer LTMPTAB : LTMPTAB=1

 If clalev([F:HAT])  : Close File [F:HAT] : Endif
 If clalev([F:DAT])  : Close File [F:DAT] : Endif
 If !clalev([F:HAT]) : Local File =GTABCPT+"GACCTMP"  [HAT] : Endif
 If !clalev([F:DAT]) : Local File =GTABCPT+"GACCTMPD" [DAT] : Endif

 Read [F:HAT]HAT0=LTYP;LNUM
 If fstat=5
  If clalev([F:HAT])  : Close Local File [F:HAT] : Endif
  If clalev([F:DAT])  : Close Local File [F:DAT] : Endif
  If !clalev([F:HAT]) : Local File =GTABCPT+"GACCENTRY"   [HAT] : Endif
  If !clalev([F:DAT]) : Local File =GTABCPT+"GACCENTRYD"  [DAT] : Endif
  Read [F:HAT]HAE0=LTYP;LNUM
  If !fstat
   #Read [F:DAT]DAE0=LTYP;LNUM;nolign;[M:GC0]LEDTYP : # FQ90566
   Read [F:DAT]DAE0=LTYP;LNUM;LLIN;[M:GC0]LEDTYP
   LTMPTAB=0
  Endif
 Else
  Read [F:DAT]DAT0=LTYP;LNUM;LLIN #CHECK IGNORE_LINE
 Endif

 If !fstat

  If clalev([F:DAA])  : Close Local File [F:DAA] : Endif
  If LTMPTAB
   If !clalev([F:DAA]) : Local File =GTABCPT+"GACCTMPA"    [DAA] : Endif
  Else
   If !clalev([F:DAA]) : Local File =GTABCPT+"GACCENTRYA"  [DAA] : Endif
  Endif

  If [F:DAT]DSP<>""
   If clalev([F:DSP]) : Close Local File [F:DSP] : Endif
   Local File = GTABCPT+"CADSP" [DSP]
  Endif

 If 1=0
  #FQ58081-Détermination du type de référentiel à retenir en fonction du référentiel de la pièce consultée (social ou IAS).
  If !clalev([M:FPC]) : Local Mask FASPARCPY : Endif
  Raz [M:FPC]
  Local Integer ERROR
  Call LOAD_FASPARCPY([F:HAT]CPY,"",G_NON,ERROR) From GLOFCYCPY
  If ERROR
  Endif
  Case LLED
   When 1
    If [M:FPC]ANALEDTYP<>0
     LLEDTYP=[M:FPC]ANALEDTYP
    Else
     Local Integer I_LEDSOC
     I_LEDSOC=find([M:FPC]GENLEDTYP,[M:FPC]LEDTYP)
     If [M:FPC]ANA(I_LEDSOC-1)=G_OUI
      LLEDTYP=1
     Else
      LLEDTYP=0
     Endif
    Endif
   When 3
    Local Integer I_LEDIAS
    I_LEDIAS=find([M:FPC]IASLEDTYP,[M:FPC]LEDTYP)
    If [M:FPC]ANA(I_LEDIAS-1)=G_OUI
     LLEDTYP=3
    Else
     LLEDTYP=0
    Endif
  Endcase
  #FQ58081-Fin
 Endif

  LLEDTYP=[M:GC0]LEDTYP

  Filter [F:DAA] Where TYP=LTYP & NUM=LNUM & LIN=LLIN & LEDTYP=LLEDTYP
  Raz [F:DAA]
  For [F:DAA]
   I_LIGNE+=1
   nolign = I_LIGNE
   If [F:DAT]DSP<>""
    Read [F:DSP]DSP0=[F:DAT]DSP;I_LIGNE
    [M:VTA]PRC(nolign-1)=[F:DSP]COE
   Else
    [M:VTA]PRC(nolign-1)=0
   Endif
   [M:VTA]=[F:DAT]
   [M:VTA]=[F:DAA]
   [M:VTA]AMT(nolign-1)=[F:DAA]AMTCUR
   For I_CCE=1 To GOPTCANA
    Case I_CCE
     When 1 : [M:VTA]CCE1(nolign-1) = [F:DAA]CCE(I_CCE-1)
     When 2 : [M:VTA]CCE2(nolign-1) = [F:DAA]CCE(I_CCE-1)
     When 3 : [M:VTA]CCE3(nolign-1) = [F:DAA]CCE(I_CCE-1)
     When 4 : [M:VTA]CCE4(nolign-1) = [F:DAA]CCE(I_CCE-1)
     When 5 : [M:VTA]CCE5(nolign-1) = [F:DAA]CCE(I_CCE-1)
     When 6 : [M:VTA]CCE6(nolign-1) = [F:DAA]CCE(I_CCE-1)
     When 7 : [M:VTA]CCE7(nolign-1) = [F:DAA]CCE(I_CCE-1)
     When 8 : [M:VTA]CCE8(nolign-1) = [F:DAA]CCE(I_CCE-1)
     When 9 : [M:VTA]CCE9(nolign-1) = [F:DAA]CCE(I_CCE-1)
    Endcase
   Next I_CCE
   QTOTAL += [F:DAA]QTY
   TOTAL  += [F:DAA]AMTCUR
  Next
  [M:VTA]QTOTAL = QTOTAL
  [M:VTA]TOTAL  = TOTAL
  [M:VTA]BAS=I_LIGNE
  Filter [F:DAA]

  Affzo [M:VTA]

 Endif


Return

#-------------------------------------------------------------------------------------
$TERMINE
Return
