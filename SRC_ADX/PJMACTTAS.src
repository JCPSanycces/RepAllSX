#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# PJMACTTAS
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"                       : Gosub OUVRE
    When "DEBUT"                       : Gosub DEBUT
    # Buttons
    When "NEW"                         : Gosub NEW
    When "APRES_MODIF"                 : Gosub APRES_MODIF
    When "ABA"                         : Gosub ABANDON
    When "FIN"                         : Gosub FIN
    When "ENR"                         : Gosub ENR
    When "SUP"                         : Gosub SUP
    When "AVANT_BOUTON"                : Gosub AVANT_BOUTON          # Issue X3-99928 - 2018-07-19 by ALMON
    When "AVANT_MEN"                   : Gosub AVANT_MEN             # Issue X3-99928 - 2018-07-19 by FGR
    When "SETBOUT"                     : Gosub SETBOUT
    When "BOUTON"                      : Gosub BOUTON
    When "MEN"                         : Gosub MENU
    When "AP_CHOIX"                    : Gosub AP_CHOIX
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Local Char SAVFONCTION(type(GFONCTION)-1)        # Issue X3-99928 - 2018-07-19 by FGR

  NAVIG = GACTION
  GOK = 1
  # Issue X3-99928 - 2018-07-19 by FGR : BEGIN : Load autorization for the current function, after saving formers function...
  SAVFONCTION = GFONCTION
  GFONCTION = "PJMACTTAS"
  Call AUTORIS From EXEFNC
  # Issue X3-99928 - 2018-07-19 by FGR : END
Return

##########################################################################################################
$DEBUT
Local Char STUNTAS(GLONTAC)  # Contain the task given by parameter

  # -----------------------------
  If dim(GZINSPJM) <= 0 Then
    GMESSAGE = mess(186,123,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  # -----------------------------
  # Issue X3-99916 - 2018-07-11 by FGR : BEGIN
  #If !clalev ([F:MWS])  : Local File WORKSTATIO [MWS] : Endif
  #If !clalev ([F:ITM])  : Local File ITMMASTER  [ITM] : Endif
  #If !clalev ([F:TLNK]) : Local File PJMTSKLNK  [TLNK]: Endif
  Local File WORKSTATIO [MWS]
  Local File ITMMASTER  [ITM]
  Local File PJMTSKLNK  [TLNK]
  # Issue X3-99916 - 2018-07-11 by FGR : END
  # -----------------------------
  Raz STUNTAS
  If PARAM(2) <> AVOID.ACHAR Then
    STUNTAS = PARAM(2)
  Endif
  # -----------------------------
  Effzo [M:PJTA0]1-99
  Effzo [M:PJTA0A]1-99       # Issue X3-99916 - 2018-07-11 by FGR
  Effzo [M:PJTA0B]1-99       # Issue X3-99916 - 2018-07-11 by FGR
  Effzo [M:PJTA0C]1-99       # Issue X3-99916 - 2018-07-11 by FGR
  Effzo [M:PJTA1]1-99
  Effzo [M:PJTA2]1-99
  Effzo [M:PJTA3]1-99
  # -----------------------------
  Gosub LOAD_PAGE
Return

##########################################################################################################
##########################################################################################################
# Buttons
##########################################################################################################
$NEW
Local Integer NLINE

  NLINE = fmet GZINSPJM.PJM(1).ADDLINE("TAS", [V]CST_ALASTPOS)
  If NLINE <> [V]CST_ANOTDEFINED Then
    [M:PJTA0]LINTAS = NLINE
    Call SHOW_TASK(NLINE)
    # ----------------------
    [M:PJTA0]NBLIG += 1
    [M:PJTA0]LINTASTBL = [M:PJTA0]NBLIG
    Call LOAD_TREE()
    # ----------------------
    REP = "M"
    [M:PJTA0]REP = REP
    # ----------------------
    Actzo [M:PJTA0A]TASCOD   # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
    Gosub SETBOUT
  Else
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(100,141,1)
    Endif
    GOK = 1
    GERR = 1
    REP = [M:PJTA0]REP
  Endif
Return

##########################################################################################################
$SETBOUT
  If REP <> AVOID.ACHAR or [M:PJTA0]LINTAS = 0 Then
    If [M:PJTA0]LINTAS = 0 Then
      Call VIREBOUT(CHMEN,"3") From GOBJET       # Sub-level
    Endif
    Call VIREBOUT(CHMEN,"1") From GOBJET         # Status change
    Call VIREBOUT(CHMEN,"2") From GOBJET         # Saleable products
    Call VIREBOUT(CHMEN,"-") From GOBJET         # Sold product management
    Call VIREBOUT(CHMEN,"D") From GOBJET         # Project financial overview
    Call VIREBOUT(CHMEN,"U") From GOBJET         # Project overview
    Call VIREBOUT(CHMEN,"*") From GOBJET         # Time entry
    Call VIREBOUT(CHMEN,"(") From GOBJET         # Enterprise planning
    Call VIREBOUT(CHMEN,"^") From GOBJET         # Inquiries/Sales/Quotes
    Call VIREBOUT(CHMEN,"£") From GOBJET         # Inquiries/Sales/Order
    Call VIREBOUT(CHMEN,"à") From GOBJET         # Inquiries/Sales/Delivery
    Call VIREBOUT(CHMEN,"|") From GOBJET         # Inquiries/Sales/Invoice
    Call VIREBOUT(CHMEN,"\") From GOBJET         # Inquiries/Sales/Return
    Call VIREBOUT(CHMEN,"è") From GOBJET         # Inquiries/Purchasing/RFQ
    Call VIREBOUT(CHMEN,"{") From GOBJET         # Inquiries/Purchasing/Order
    Call VIREBOUT(CHMEN,"}") From GOBJET         # Inquiries/Purchasing/Receipt
    Call VIREBOUT(CHMEN,"_") From GOBJET         # Inquiries/Purchasing/Invoice
    Call VIREBOUT(CHMEN,"ç") From GOBJET         # Inquiries/Purchasing/Return
    Call VIREBOUT(CHMEN,"$") From GOBJET         # Inquiries/Manufactoring/Production reporting
    Call VIREBOUT(CHMEN,"~") From GOBJET         # Inquiries/Manufactoring/Material consumptions
    Call VIREBOUT(CHMEN,"#") From GOBJET         # Inquiries/Manufactoring/List of WOs
  Endif
  # ----------------------
  If [M:PJTA0]LINTAS = 0 Then
    Call VIREBOUT(CHMEN,"1") From GOBJET         # Status change
    Grizo [M:PJTA1]NBART                         # Grey-out Products Grid
    Grizo [M:PJTA2]NBOPE                         # Grey-out Operations Grid
  Endif
  # ----------------------
  If fmet GZINSPJM.PJM(1).TAS_COUNT() = 0 Then
    Call VIREBOUT(CHBOU,"S") From GOBJET         # To deactive "Delete" button
  Elsif instr(1,CHBOU,"S") <= 0 Then
    CHBOU += "S"                                 # To not deactive "Delete" button
  Endif
  If instr(1,CHBOU,"N") <= 0 Then
    CHBOU += "N"                                 # To not deactive "New" button
  Endif
  # ----------------------
  # Issue X3-99928 - 2018-07-19 by FGR : BEGIN
  If func SUBPJMA.GET_AUTHORIZATION("C") = [V]CST_ANO Then
    # "New" button
    Call VIREBOUT(CHBOU,"N") From GOBJET
  Endif
  If func SUBPJMA.GET_AUTHORIZATION("S") = [V]CST_ANO Then
    # "Delete" button
    Call VIREBOUT(CHBOU,"S") From GOBJET
  Endif
  # Issue X3-99928 - 2018-07-19 by FGR : END
  # ----------------------
  Gosub SET_BOUT_SPE From GSAISIE
  # ----------------------
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "1"
      # Status change
      Gosub RELIT_GZINSPJM From SUBPJMA
      Call SHOW_TASK([M:PJTA0]LINTAS)
      Call LOAD_TREE()
    When "3"
      # Sous-niveau
      Gosub SUB_LEVEL
    When Default
  Endcase
Return

##########################################################################################################
$MENU
  Case BOUT
    When "2"
      # Status change
      Gosub RELIT_GZINSPJM From SUBPJMA
      Call SHOW_TASK([M:PJTA0]LINTAS)
      Call LOAD_TREE()
    When "5"
      # Status change
      Gosub RELIT_GZINSPJM From SUBPJMA
      Call SHOW_TASK([M:PJTA0]LINTAS)
      Call LOAD_TREE()
    When Default
  Endcase
Return

##########################################################################################################
$APRES_MODIF
  # Issue X3-99928 - 2018-07-19 by FGR : BEGIN
  If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).ASTALIN <> [V]CST_ANEW Then
    If func SUBPJMA.GET_AUTHORIZATION("M") = [V]CST_ANO Then
      # "Save" button
      GMESSAGE = mess(1132,2260,1)
      GOK = 1
      GERR = 1
      Return
    Endif
  Endif
  # Issue X3-99928 - 2018-07-19 by FGR : END
  If REP = AVOID.ACHAR Then
    REP = "M"
    [M:PJTA0]REP = REP
  Endif
Return

##########################################################################################################
$ABANDON
  STUNTAS = [M:PJTA0A]TASCOD # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  REP = AVOID.ACHAR
  [M:PJTA0]REP = REP
  Gosub RELIT_GZINSPJM From SUBPJMA
  Gosub LOAD_PAGE
  REP = AVOID.ACHAR
  [M:PJTA0]REP = REP
  #[M:PJTA0]LINTAS = 0     # Note FGR : Absolutly not
Return

##########################################################################################################
$FIN
Local Integer IRET

  If PARAM(2) <> AVOID.ACHAR Then
    PARAM(2) = [M:PJTA0A]TASCOD        # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  Endif
  If [M:PJTA0]LINTAS > 0 and REP <> AVOID.ACHAR Then
    If GNAVIG(GPILNAV-1) <> "GESPJM" Then
      Gosub RELIT_GZINSPJM From SUBPJMA
    Endif
  Endif
  REP = AVOID.ACHAR
  [M:PJTA0]REP = REP
  # -----------------------------------
  If dim(GPJMCURKEY) > 0 Then
    If dim([M:PJM0]OPPNUM) >= 0 Then
      GPJMCURKEY = [M:PJM0]OPPNUM
    Else
      GPJMCURKEY = AVOID.ACHAR
    Endif
  Endif
  # -----------------------------------
  # Issue X3-99928 - 2018-07-19 by FGR : BEGIN : ...to restaure them at the end
  GFONCTION = SAVFONCTION
  Call AUTORIS From EXEFNC
  # Issue X3-99928 - 2018-07-19 by FGR : END
  # -----------------------------------
Return

##########################################################################################################
$ENR
Local Integer MY_STATUS

  Call COPY_SCREEN_TO_CLASS()
  If GERR = 1 Then
    Return
  Endif
  # ----------------------------------
  If func CHECK_FRCDLTALLFLG() = [V]CST_AYES Then                              # Issue X3-101833 - 2018-08-01 by FGR
    [L]MY_STATUS = fmet GZINSPJM.AUPDATE()
    If [L]MY_STATUS <> [V]CST_AOK Then
      Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
      If GMESSAGE = AVOID.ACHAR Then
        GMESSAGE = mess(159,2260,1)
      Endif
      If [L]MY_STATUS <> [V]CST_AWARNING Then
        STUNTAS = [M:PJTA0A]TASCOD                                             # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
        Gosub LOAD_PAGE
        GERR = 1
        REP = "M"
        Return
      Endif
    Endif
    Gosub RELIT_GZINSPJM From SUBPJMA
    [M:PJTA0]LINTAS = fmet GZINSPJM.PJM(1).TAS_GET_INDEX([M:PJTA0A]TASCOD)     # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
    Call SHOW_TASK([M:PJTA0]LINTAS)
    # -----------------------------------
    Call LOAD_TREE()
    REP = AVOID.ACHAR
    [M:PJTA0]REP = REP
  Else
    # Issue X3-101833 - 2018-08-01 by FGR
    GERR = 1
  Endif
Return

##########################################################################################################
$SUP
Local Integer IRET

  IRET = fmet GZINSPJM.PJM(1).ADELLINE("TAS", GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).AORDER)
  If IRET = [V]CST_ANOTDEFINED Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    GOK = 0
    GERR = 1
    Return
  Else
    [M:PJTA0]LINTAS = 0
    Gosub LOAD_PAGE
    REP = "M"
    [M:PJTA0]REP = REP
    Gosub SETBOUT
    zonsui = "[M:PJTA0]NBLIG"          # Issue X3-102520 - 2018-07-27 by FGR
  Endif
Return

##########################################################################################################
$AVANT_BOUTON
  # Issue X3-99928 - 2018-07-19 by FGR
  Case BOUT
    When "1"
      # "Change status"
      If func SUBPJMA.GET_AUTHORIZATION("1") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
    When "3"
      # "Sub Levels"
      If func SUBPJMA.GET_AUTHORIZATION("C") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
  Endcase
Return

##########################################################################################################
$AVANT_MEN
  # Issue X3-99928 - 2018-07-19 by FGR
  Case BOUT
    When "2"
      # "Saleable products"
      If func SUBPJMA.GET_AUTHORIZATION_GESPJM("6") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
    When "D"
      # "Financial overview"
      If func SUBPJMA.GET_AUTHORIZATION_GESPJM("1") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
    When "U"
      # "Project overview"
      If func SUBPJMA.GET_AUTHORIZATION_GESPJM("U") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
  Endcase
Return

##########################################################################################################
$AP_CHOIX
  If REPONSE = GSTAEND Then
    REP = [M:PJTA0]REP
    If [M:PJTA0]REP <> AVOID.ACHAR Then
      GMESSAGE = mess(162,2260,1)
      OK = 1
      Return
    Endif
  Elsif find(REPONSE, GSTANEW) Then
    # To deactivate the question to lost current not updated information
    [M:PJTA0]REP = REP
    Raz REP
  Endif
Return

##########################################################################################################
# Subroutines
##########################################################################################################
$SUB_LEVEL
Local Integer NLINE
Local Char SPARENT(GLONTAC)
Local Integer NLINEPAE

  SPARENT = [M:PJTA0A]TASCOD # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  NLINE = fmet GZINSPJM.PJM(1).ADDLINE("TAS", [V]CST_ALASTPOS)
  If NLINE <> [V]CST_ANOTDEFINED Then
    #[M:PJTA0]LINTAS = NLINE # Issue X3-105216 - 2018-08-17 by FGR : To early. Issue in case of error
    # ----------------------
    NLINEPAE = fmet GZINSPJM.PJM(1).TAS_GET_INDEX(SPARENT)
    GZINSPJM.PJM(1).TAS(NLINE).TCACOD = GZINSPJM.PJM(1).TAS(NLINEPAE).TCACOD
    GZINSPJM.PJM(1).TAS(NLINE).TASFCY  = GZINSPJM.PJM(1).TAS(NLINEPAE).TASFCY
    GZINSPJM.PJM(1).TAS(NLINE).TASPAE = SPARENT
    GZINSPJM.PJM(1).TAS(NLINE).TASSTARTDT = GZINSPJM.PJM(1).TAS(NLINEPAE).TASSTARTDT
    GZINSPJM.PJM(1).TAS(NLINE).TASENDDT = GZINSPJM.PJM(1).TAS(NLINEPAE).TASENDDT
    GZINSPJM.PJM(1).TAS(NLINE).PBUCOD = GZINSPJM.PJM(1).TAS(NLINEPAE).PBUCOD
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    If GERR = 1 Then
      IRET = fmet GZINSPJM.PJM(1).ADELLINE("TAS", GZINSPJM.PJM(1).TAS(NLINE).AORDER)
      Return
    Endif
    [M:PJTA0]LINTAS = NLINE  # Issue X3-105216 - 2018-08-17 by FGR : Better here
    # ----------------------
    Call SHOW_TASK(NLINE)
    # ----------------------
    [M:PJTA0]NBLIG += 1
    [M:PJTA0]LINTASTBL = [M:PJTA0]NBLIG
    Call LOAD_TREE()
    # ----------------------
    REP = "M"
    [M:PJTA0]REP = REP
    # ----------------------
    Actzo [M:PJTA0A]TASCOD             # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
    zonsui = "[M:PJTA0A]TCACOD"        # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  Else
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(100,141,1)
    Endif
    GOK = 1
    GERR = 1
    REP = [M:PJTA0]REP
  Endif
Return

##########################################################################################################
$LOAD_PAGE
Local Integer ISHOWLINE

  ISHOWLINE = [M:PJTA0]LINTAS
  Effzo [M:PJTA0]1-99                                      # Issue X3-102520 - 2018-07-27 by FGR must be ! # Issue X3-99916 - 2018-07-11 by FGR
  Effzo [M:PJTA0A]1-99                                     # Issue X3-99916 - 2018-07-11 by FGR
  Effzo [M:PJTA0B]1-99                                     # Issue X3-99916 - 2018-07-11 by FGR
  Effzo [M:PJTA0C]1-99                                     # Issue X3-99916 - 2018-07-11 by FGR
  [M:PJTA0]LINTAS = ISHOWLINE
  ISHOWLINE = 0
  Effzo [M:PJTA1]1-99
  Effzo [M:PJTA2]1-99
  Effzo [M:PJTA3]1-99
  # -----------------------------------
  [M:PJTA0]OPPNUM = GZINSPJM.OPPNUM
  Call LOAD_TREE()
  If [M:PJTA0]NBLIG > 1 Then
    If STUNTAS <> AVOID.ACHAR Then
      For NI = 0 To [M:PJTA0]NBLIG-1
        If [M:PJTA0]KEYC(NI) = STUNTAS Then
          ISHOWLINE = [M:PJTA0]CLAROW(NI)
          Raz STUNTAS
          Break
        Endif
      Next NI
    Endif
    If ISHOWLINE < 1 Then
      ISHOWLINE = [M:PJTA0]CLAROW([M:PJTA0]FRTLINDSP)      # Issue X3-99916 - 2018-07-10 by FGR : not (1)
    Endif
    Call SHOW_TASK(ISHOWLINE)
    Actzo [M:PJTA3]5
  Else
    #Diszo [M:PJTA0]10-30                                  # Issue X3-99916 - 2018-07-11 by FGR
    Diszo [M:PJTA0A]                                       # Issue X3-99916 - 2018-07-11 by FGR
    Diszo [M:PJTA0B]                                       # Issue X3-99916 - 2018-07-11 by FGR
    Diszo [M:PJTA1]10
    Diszo [M:PJTA2]10
    Diszo [M:PJTA3]5
  Endif
  #Affzo [M:PJTA0]1-99                                     # Issue X3-99916 - 2018-07-11 by FGR
  Affzo [M:PJTA0A]1-99                                     # Issue X3-99916 - 2018-07-11 by FGR
  Affzo [M:PJTA0B]1-99                                     # Issue X3-99916 - 2018-07-11 by FGR
  Affzo [M:PJTA0C]1-99                                     # Issue X3-99916 - 2018-07-11 by FGR
  Affzo [M:PJTA1]1-99
  Affzo [M:PJTA2]1-99
  Affzo [M:PJTA3]1-99
  # -----------------------------------
Return

##########################################################################################################
Subprog MANAGE_TAB_ACCESS()
  Case [M:PJTA0A]TASPIMTYP   # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
    When 5  # MO
      Grizo [M:PJTA1]
      Actzo [M:PJTA2]
      Actzo [M:PJTA3]
    When 6  # Matière
      Actzo [M:PJTA1]
      Diszo [M:PJTA2]
      Actzo [M:PJTA3]
    When 7  # Mixte
      Actzo [M:PJTA1]
      Actzo [M:PJTA2]
      Actzo [M:PJTA3]
    When Default
      Grizo [M:PJTA1]
      Grizo [M:PJTA2]
  Endcase
End

##########################################################################################################
Subprog SHOW_TASK(VNLINE)
Value Integer VNLINE

Local Integer NI
Local Decimal NSUMQTY

  If VNLINE > 0 Then
    If GZINSPJM.PJM(1).TAS(VNLINE) <> null and find(GZINSPJM.PJM(1).TAS(VNLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      # -------------------------------
      #Effzo [M:PJTA0]10-35  # Issue X3-99916 - 2018-07-11 by FGR
      Effzo [M:PJTA0A]       # Issue X3-99916 - 2018-07-11 by FGR
      Effzo [M:PJTA0B]       # Issue X3-99916 - 2018-07-11 by FGR
      Effzo [M:PJTA0C]       # Issue X3-99916 - 2018-07-11 by FGR
      Effzo [M:PJTA1]35
      Effzo [M:PJTA2]30
      Effzo [M:PJTA3]5
      [M:PJTA0]LINTAS = VNLINE
      # -------------------------------
      Call SHOW_TASK_HEADER0(VNLINE)
      Call MANAGE_TAB_ACCESS()
      # ------------------------------------
      nolign = 0
      For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT)
        If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT(NI) <> null and find(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          nolign += 1
          Call SHOW_RITT_LINE(NI)
        Endif
      Next NI
      [M:PJTA1]NBART = nolign
      Affzo [M:PJTA1]35
      For NI = 0 To [M:PJTA1]NBART-1
        Chgstl [M:PJTA1]AVADAT(NI) With
&            func PJMAVADAT.GET_STYLE_REQDATE([M:PJTA1]REQDAT(NI), [M:PJTA1]AVADAT(NI), ([M:PJTA1]AVADATSTA(NI) = [V]CST_AYES or [M:PJTA0C]TASSTATE = 4))
                                                                        # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
        NSUMQTY = func PJMAVADAT.GET_SUM_QTY([M:PJTA0]OPPNUM, [M:PJTA0A]TASCOD, [M:PJTA1]ITMREF(NI), [M:PJTA1]UOM(NI)) # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
        Chgstl [M:PJTA1]ITTQTY(NI) With func PJMAVADAT.GET_STYLE_ITTQTY([M:PJTA1]AVADAT(NI), [M:PJTA1]ITTQTY(NI), NSUMQTY, ([M:PJTA0C]TASSTATE = 4))
        # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
        If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(NI)).TCHPURFLG = [V]CST_ANO Then
          Grizo [M:PJTA1]MANUALBUD(NI)
        Else
          Actzo [M:PJTA1]MANUALBUD(NI)
        Endif
      Next NI
      nolign = 0
      For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO)
        If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO(NI) <> null and find(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          nolign += 1
          Call SHOW_RTKO_LINE(NI)
        Endif
      Next NI
      [M:PJTA2]NBOPE = nolign
      # -------------------------------
      nolign = 0
      For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PTLNK)
        If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PTLNK(NI) <> null and find(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PTLNK(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          nolign += 1
          Call SHOW_PTLNK_LINE(NI)
        Endif
      Next NI
      # -------------------------------
      [M:PJTA3]NBLNK = nolign
      Affzo [M:PJTA3]5
      For NI = 0 To [M:PJTA3]NBLNK-1
        If [M:PJTA3]OPPNUMLNK(NI) <> [M:PJTA0]OPPNUM Then
          Diszo [M:PJTA3]STRDAT(NI)
          Diszo [M:PJTA3]ENDDAT(NI)
        Endif
      Next NI
      Affzo [M:PJTA3]5
      # -------------------------------
      Affzo [M:PJTA2]30
      For NI = 0 To [M:PJTA2]NBOPE-1
        Case [M:PJTA2]OPESTA(NI)
          When 1
            # En attente
            Chgstl [M:PJTA2]OPESTA(NI) With "PJMNEW"
          When 4
            # en cours
            Chgstl [M:PJTA2]OPESTA(NI) With "PJMOPEN"
          When 5
            # solded
            Chgstl [M:PJTA2]OPESTA(NI) With "PJMCLOSE"
          When Default
            Chgstl [M:PJTA2]OPESTA(NI) With AVOID.ACHAR
        Endcase
      Next NI
      #Actzo [M:PJTA0]10-30  # Issue X3-99916 - 2018-07-11 by FGR
      Actzo [M:PJTA0A]       # Issue X3-99916 - 2018-07-11 by FGR
      Actzo [M:PJTA0B]       # Issue X3-99916 - 2018-07-11 by FGR
      # -------------------------------
      #Affzo [M:PJTA0]1-99   # Issue X3-99916 - 2018-07-11 by FGR
      Affzo [M:PJTA0A]1-99   # Issue X3-99916 - 2018-07-11 by FGR
      Affzo [M:PJTA0B]1-99   # Issue X3-99916 - 2018-07-11 by FGR
      Affzo [M:PJTA0C]1-99   # Issue X3-99916 - 2018-07-11 by FGR
      Affzo [M:PJTA1]1-99
      Affzo [M:PJTA2]1-99
      Affzo [M:PJTA3]1-99
    Endif
  Endif
End

##########################################################################################################
Subprog SHOW_TASK_HEADER0(VNLINE)
Value Integer VNLINE

  SetInstance [M:PJTA0] With GZINSPJM.PJM(1).TAS(VNLINE)
  SetInstance [M:PJTA0A] With GZINSPJM.PJM(1).TAS(VNLINE)             # Issue X3-99916 - 2018-07-11 by FGR
  SetInstance [M:PJTA0B] With GZINSPJM.PJM(1).TAS(VNLINE)             # Issue X3-99916 - 2018-07-11 by FGR
  SetInstance [M:PJTA0C] With GZINSPJM.PJM(1).TAS(VNLINE)             # Issue X3-99916 - 2018-07-11 by FGR
  [M:PJTA0A]TASDESAXX = GZINSPJM.PJM(1).TAS(VNLINE).PIMPL.PIMDESAXX   # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  [M:PJTA0A]TASDESAX1 = GZINSPJM.PJM(1).TAS(VNLINE).PIMPL.PIMDESAX1   # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  If GZINSPJM.PJM(1).TAS(VNLINE).PIMPL.PIMTYP >= 5 Then
    [M:PJTA0A]TASPIMTYP = GZINSPJM.PJM(1).TAS(VNLINE).PIMPL.PIMTYP    # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
    Call SHOW_TASPIMTYP_FIELD([V]CST_AYES)
  Else
    Raz [M:PJTA0A]TASPIMTYP                                           # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
    [M:PJTA0A]TASPIMTYP = -1                                          # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
    Call SHOW_TASPIMTYP_FIELD([V]CST_ANO)
  Endif
  If dim(GPJMCURKEY) > 0 Then
    GPJMCURKEY = [M:PJTA0]KEYCONCAT
  Endif
  [M:PJTA0A]PBUDES = fmet GZINSPJM.PJM(1).BUD_GET_PIMDESAXX(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PBUCOD)     # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  Affzo [M:PJTA0A]PBUDES                                                                                     # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  [M:PJTA0A]BTNTAC = func OPPORPJM_CSTD_PROGS.PJMCLOB_GET_ICON(GZINSPJM.ACTX,
&                                                             func PJMTSK_CSTD_PROGS.TASDESTEX_EXIST(GZINSPJM.ACTX, [M:PJTA0]OPPNUM, [M:PJTA0A]TASCOD) = [V]CST_AYES or
&                                                             func PJMTSK_CSTD_PROGS.TASCOMTEX_EXIST(GZINSPJM.ACTX, [M:PJTA0]OPPNUM, [M:PJTA0A]TASCOD) = [V]CST_AYES)
  # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  # -----------------------------------
  # Issue X3-107733 - 2018-10-09 by FGR : BEGIN : Moved from PJTA0B screen
  #If [M:PJTA0B]DUEDAT <> AVOID.ADATE Then                            # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  #  If [M:PJTA0B]DUEDAT < GZINSPJM.PJM(1).TAS(VNLINE).TASENDDT Then  # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  #    Chgstl [M:PJTA0B]DUEDAT With "PJMWARN1"                        # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  #  Else
  #    Chgstl [M:PJTA0B]DUEDAT With "NORMAL"                          # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  #  Endif
  #Else
  #  Chgstl [M:PJTA0B]DUEDAT With "NORMAL"                            # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  #Endif
  If [M:PJTA0A]DUEDAT <> AVOID.ADATE Then
    If [M:PJTA0A]DUEDAT < GZINSPJM.PJM(1).TAS(VNLINE).TASENDDT Then
      Chgstl [M:PJTA0A]DUEDAT With "PJMWARN1"
    Else
      Chgstl [M:PJTA0A]DUEDAT With "NORMAL"
    Endif
  Else
    Chgstl [M:PJTA0A]DUEDAT With "NORMAL"
  Endif
  # Issue X3-107733 - 2018-10-09 by FGR : END
  GFCY = [M:PJTA0A]TASFCY                                            # Issue X3-99928 - 2018-07-19 by FGR
End

##########################################################################################################
Subprog SHOW_TASK_HEADER(VNLINE)
Value Integer VNLINE

  Call SHOW_TASK_HEADER0(VNLINE)
  Call LOAD_TREE()
End

##########################################################################################################
Subprog SHOW_TASPIMTYP_FIELD(ISHOW)
Value Integer ISHOW

  If ISHOW = [V]CST_AYES Then
    Chgfmt [M:PJTA0A]TASPIMTYP With "LA:2254"    # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  Else
    Chgfmt [M:PJTA0A]TASPIMTYP With "-LA:2254"   # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  Endif
End

##########################################################################################################
Subprog SHOW_RITT_LINE(VNLINE)
Value Integer VNLINE

Local Char KEYCONCAT(250)

  SetInstance [M:PJTA1]35 With GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT(VNLINE)
  [M:PJTA1]COLLIN(nolign-1) = VNLINE   # Line index in the collection
  KEYCONCAT = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT(VNLINE).KEYCONCAT
  [M:PJTA1]BTITT(nolign-1) = func OPPORPJM_CSTD_PROGS.PJMCLOB_GET_ICON(GZINSPJM.ACTX,
&                                                                      func PJMTSKITM_CSTD_PROGS.ITTDESTEX_EXIST(GZINSPJM.ACTX, KEYCONCAT) = [V]CST_AYES or
&                                                                      func PJMTSKITM_CSTD_PROGS.ITTCOMTEX_EXIST(GZINSPJM.ACTX, KEYCONCAT) = [V]CST_AYES)
  Call GET_AVADAT([M:PJTA0]OPPNUM, [M:PJTA0A]TASCOD, [M:PJTA1]ITMREF(nolign-1),
&                 0, AVOID.ACHAR, 0, [M:PJTA1]AVADAT(nolign-1),
&                 [M:PJTA1]AVADATSTA(nolign-1)) From PJMAVADAT       # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
End

##########################################################################################################
Subprog SHOW_RTKO_LINE(VNLINE)
Value Integer VNLINE

Local Char KEYCONCAT(250)

  SetInstance [M:PJTA2]30 With GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO(VNLINE)
  [M:PJTA2]COLLIN(nolign-1) = VNLINE   # Line index in the collection
  KEYCONCAT = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO(VNLINE).KEYCONCAT
  [M:PJTA2]BTCLB(nolign-1) = func OPPORPJM_CSTD_PROGS.PJMCLOB_GET_ICON(GZINSPJM.ACTX,
&                                                                      func PJMTSKOPE_CSTD_PROGS.OPEDESTEX_EXIST(GZINSPJM.ACTX, KEYCONCAT) = [V]CST_AYES or
&                                                                      func PJMTSKOPE_CSTD_PROGS.OPECOMTEX_EXIST(GZINSPJM.ACTX, KEYCONCAT) = [V]CST_AYES)
End

##########################################################################################################
Subprog SHOW_PTLNK_LINE(VNLINE)
Value Integer VNLINE

Local Char PROJECT(GLONOPP)
Local Char BUDGET(GLONPBU)
Local Char TASK(GLONTAC)
Local Integer ISEQNUM
Local Integer IRET
Local Integer ILINE
Local Char SMESSAGE(250)

  SetInstance [M:PJTA3]5 With GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PTLNK(VNLINE)
  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GZINSPJM.ACTX, GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PTLNK(VNLINE).PIMOPPTASLNK, PROJECT, BUDGET, TASK)
  [M:PJTA3]OPPNUMLNK(nolign-1) = PROJECT
  [M:PJTA3]TASCODLNK(nolign-1) = TASK
  [M:PJTA3]COLLIN(nolign-1) = VNLINE   # Line index in the collection
  [M:PJTA3]COLLINLNK(nolign-1) = 0
  # -----------------------------------
  [M:PJTA3]TASCODDES(nolign-1) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GZINSPJM.ACTX, GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PTLNK(VNLINE).PIMOPPTASLNK) # Issue X3-69355 - 2017-12-21 by FGR
  # -----------------------------------
  If PROJECT <> AVOID.ACHAR and TASK <> AVOID.ACHAR Then
    If PROJECT = [M:PJTA0]OPPNUM Then
      ILINE = fmet GZINSPJM.PJM(1).TAS_GET_INDEX(TASK)
      [M:PJTA3]COLLINLNK(nolign-1) = ILINE
      [M:PJTA3]STRDAT(nolign-1) = GZINSPJM.PJM(1).TAS([M:PJTA3]COLLINLNK(nolign-1)).TASSTARTDT
      [M:PJTA3]ENDDAT(nolign-1) = GZINSPJM.PJM(1).TAS([M:PJTA3]COLLINLNK(nolign-1)).TASENDDT
      Actzo [M:PJTA3]STRDAT(nolign-1)
      Actzo [M:PJTA3]ENDDAT(nolign-1)
    Else
      [M:PJTA3]STRDAT(nolign-1) = func PJMTSK_CSTD_PROGS.GET_TASSTARTDT(GZINSPJM.ACTX, PROJECT, TASK,  SMESSAGE)
      [M:PJTA3]ENDDAT(nolign-1) = func PJMTSK_CSTD_PROGS.GET_TASENDDT(GZINSPJM.ACTX, PROJECT, TASK,  SMESSAGE)
      Diszo [M:PJTA3]STRDAT(nolign-1)
      Diszo [M:PJTA3]ENDDAT(nolign-1)
    Endif
  Else
    Raz [M:PJTA3]STRDAT(nolign-1)
    Raz [M:PJTA3]ENDDAT(nolign-1)
    Diszo [M:PJTA3]STRDAT(nolign-1)
    Diszo [M:PJTA3]ENDDAT(nolign-1)
  Endif
End

##########################################################################################################
Subprog LOAD_TREE()

Local Integer NI
Local Integer NE
Local Integer NZ
Local Char STBCODE(GLONTAC)(1..)
Local Integer IRET

  Effzo [M:PJTA0]5
  # -----------------------------------
  # Root is mandatory. so, it's the project
  NE = 0
  [M:PJTA0]KEYC(NE) = GZINSPJM.PJM(1).OPPNUM
  [M:PJTA0]EXPFLG(NE) = [V]CST_AYES
  [M:PJTA0]OBJDES(NE) = GZINSPJM.PJM(1).OPPNUM - GZINSPJM.PIMPL.PIMDESAXX
  [M:PJTA0]ICO(NE) = "Folder.gif"
  [M:PJTA0]CMT1(NE) = -1
  [M:PJTA0]CMT2(NE) = [0/0/0]
  [M:PJTA0]CMT3(NE) = [0/0/0]
  [M:PJTA0]CMT4(NE) = AVOID.ACHAR
  [M:PJTA0]CMT5(NE) = AVOID.ACHAR
  [M:PJTA0]CMT6(NE) = -1
  [M:PJTA0]WRKTAS(NE) = AVOID.ACHAR
  # -----------------------------------
  NE += 1
  For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS)
    If GZINSPJM.PJM(1).TAS(NI) <> null and find(GZINSPJM.PJM(1).TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      # Issue X3-70021 - 2018-01-04 by FGR : BEGIN
      If NE >= dim([M:PJTA0]PARKEY) Then
        Call ERREUR(func AFNC.MES1(mess(1019,2260,1), num$(dim([M:PJTA0]PARKEY)))) From GESECRAN
        Break
      Endif
      # Issue X3-70021 - 2018-01-04 by FGR : END
      If GZINSPJM.PJM(1).TAS(NI).TASPAE <> AVOID.ACHAR Then
        [M:PJTA0]PARKEY(NE) = GZINSPJM.PJM(1).TAS(NI).TASPAE
      Else
        [M:PJTA0]PARKEY(NE) = [M:PJTA0]KEYC(0)
      Endif
      [M:PJTA0]KEYC(NE)   = GZINSPJM.PJM(1).TAS(NI).TASCOD
      [M:PJTA0]WRKTAS(NE) = GZINSPJM.PJM(1).TAS(NI).TASCOD
      [M:PJTA0]OBJDES(NE) = GZINSPJM.PJM(1).TAS(NI).TASCOD - GZINSPJM.PJM(1).TAS(NI).PIMPL.PIMDESAXX
      [M:PJTA0]EXPFLG(NE) = [V]CST_AYES
      [M:PJTA0]ICO(NE) = func PJMTSK_CSTD_PROGS.GET_ICON(GZINSPJM.PJM(1).TAS(NI).PIMPL.PIMTYP)
      [M:PJTA0]CLAROW(NE) = NI                             # Numéro de ligne dans la collection
      # Issue X3-99916 - 2018-07-17 by FGR : BEGIN
      [M:PJTA0]GRDLIN(NE) = NE
      If GZINSPJM.PJM(1).TAS(NI).TASPAE = AVOID.ACHAR Then
        [M:PJTA0]GRDSORKEY(NE) = num$(GZINSPJM.PJM(1).TAS(NI).TASSOR) + "~" + GZINSPJM.PJM(1).TAS(NI).TASCOD
        If [M:PJTA0]FRTLINDSP = 0 or ([M:PJTA0]FRTLINDSP > 0 and [M:PJTA0]GRDSORKEY(NE) < [M:PJTA0]GRDSORKEY([M:PJTA0]FRTLINDSP)) Then
          [M:PJTA0]FRTLINDSP = NE
        Endif
      Endif
      # Issue X3-99916 - 2018-07-17 by FGR : END
      #
      [M:PJTA0]CMTSOR(NE) = GZINSPJM.PJM(1).TAS(NI).TASSOR # Issue X3-91329 - 2018-05-31 by FGR
      [M:PJTA0]CMT1(NE) = GZINSPJM.PJM(1).TAS(NI).TASSTATE
      [M:PJTA0]CMT2(NE) = GZINSPJM.PJM(1).TAS(NI).TASSTARTDT
      [M:PJTA0]CMT3(NE) = GZINSPJM.PJM(1).TAS(NI).TASENDDT
      [M:PJTA0]CMT4(NE) = GZINSPJM.PJM(1).TAS(NI).PBUCOD
      [M:PJTA0]CMT5(NE) = GZINSPJM.PJM(1).TAS(NI).TCACOD
      [M:PJTA0]CMT6(NE) = GZINSPJM.PJM(1).TAS(NI).TASTYP
      If GZINSPJM.PJM(1).TAS(NI).ASTALIN <> [V]CST_ANEW Then
        [M:PJTA0]CMT7(NE) = fmet GZINSPJM.PJM(1).TAS_PROGRESS(GZINSPJM.PJM(1).TAS(NI).TASCOD)
      Else
        Raz [M:PJTA0]CMT7(NE)
      Endif
      [M:PJTA0]CMT4(NE) -= fmet GZINSPJM.PJM(1).BUD_GET_PIMDESAXX(GZINSPJM.PJM(1).TAS(NI).PBUCOD)
      [M:PJTA0]CMT8(NE) = GZINSPJM.PJM(1).TAS(NI).PRCCPL
      [M:PJTA0]CMT9(NE) = GZINSPJM.PJM(1).TAS(NI).DUEDAT
      If [M:PJTA0]LINTAS <> NI Then
        [M:PJTA0]EXPFLG(NE) = [V]CST_ANO
      Else
        If GZINSPJM.PJM(1).TAS(NI).TASPAE <> AVOID.ACHAR and GZINSPJM.PJM(1).TAS(NI).TASCOD <> AVOID.ACHAR Then
          IRET = fmet GZINSPJM.PJM(1).TAS_GET_PARENTS(GZINSPJM.PJM(1).TAS(NI).TASCOD, STBCODE)
        Endif
      Endif
      NE += 1
    Endif
  Next NI
  [M:PJTA0]NBLIG = NE
  # -----------------------------------
  Affzo [M:PJTA0]5
  For NI = 0 To [M:PJTA0]NBLIG-1
    If find([M:PJTA0]KEYC(NI), STBCODE(1..maxtab(STBCODE))) > 0 and [M:PJTA0]EXPFLG(NI) = [V]CST_ANO Then
      [M:PJTA0]EXPFLG(NI) = [V]CST_AYES
    Endif
    # ---------------------------------
    If NI > 0 Then
      #NE = find([M:PJTA0]KEYC(NI), [M:PJTA0]PARKEY(1..[M:PJTA0]NBLIG))        # Issue X3-70021 - 2018-01-04 by FGR
      NE = find([M:PJTA0]KEYC(NI), [M:PJTA0]PARKEY(1..[M:PJTA0]NBLIG-1))       # Issue X3-70021 - 2018-01-04 by FGR
      If NE > 0 Then
        [M:PJTA0]ICO(NI) = "Folder.gif"
      Endif
    Endif
    # ---------------------------------
    If NI = 0 Then
      NZ = fmet GZINSPJM.PJM(1).SPLD_EXISTING()
    Else
      NZ = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]CLAROW(NI)).SPLD_EXISTING()
    Endif
    # ---------------------------------
    If NZ = [V]CST_AYES Then
      Chgstl [M:PJTA0]OBJDES(NI) With "PJMSPL"
    Endif
    # ---------------------------------
    If fmet GZINSPJM.PJM(1).TAS_IS_PARENT([M:PJTA0]KEYC(NI)) = [V]CST_AYES Then
      Chgstl [M:PJTA0]CMT2(NI) With "PJMWHITEB"
      Chgstl [M:PJTA0]CMT3(NI) With "PJMWHITEB"
      Chgstl [M:PJTA0]CMT4(NI) With "PJMWHITEB"
      Chgstl [M:PJTA0]CMT5(NI) With "PJMWHITEB"
      Chgstl [M:PJTA0]CMT6(NI) With "PJMWHITEB"
      Chgstl [M:PJTA0]CMT7(NI) With "PJMWHITEB"
      Chgstl [M:PJTA0]CMT8(NI) With "PJMWHITEB"
      Chgstl [M:PJTA0]CMT9(NI) With "PJMWHITEB"
      If [M:PJTA0]CMT9(NI) <> AVOID.ADATE Then
        If GZINSPJM.PJM(1).TAS(NI).DUEDAT < GZINSPJM.PJM(1).TAS(NI).TASENDDT Then
          Chgstl [M:PJTA0]CMT9(NI) With "PJMWARN1B"
        Endif
      Endif
    Else
      If [M:PJTA0]CMT9(NI) <> AVOID.ADATE Then
          If GZINSPJM.PJM(1).TAS(NI).DUEDAT < GZINSPJM.PJM(1).TAS(NI).TASENDDT Then
            Chgstl [M:PJTA0]CMT9(NI) With "PJMWARN1"
          Endif
      Endif
    Endif
    # ---------------------------------
    Case [M:PJTA0]CMT1(NI)
      When 1
        # New
        If [M:PJTA0]CMT6(NI) = 1 Then
          Chgstl [M:PJTA0]CMT1(NI) With "PJMNEWB"
        Else
          Chgstl [M:PJTA0]CMT1(NI) With "PJMNEW"
        Endif
      When 2
        # Launched
        If [M:PJTA0]CMT6(NI) = 1 Then
          Chgstl [M:PJTA0]CMT1(NI) With "PJMOPENB"
        Else
          Chgstl [M:PJTA0]CMT1(NI) With "PJMOPEN"
        Endif
      When 3
        # Started
        If [M:PJTA0]CMT6(NI) = 1 Then
          Chgstl [M:PJTA0]CMT1(NI) With "PJMSTARTB"
        Else
          Chgstl [M:PJTA0]CMT1(NI) With "PJMSTART"
        Endif
      When 4
        # Closed
        If [M:PJTA0]CMT6(NI) = 1 Then
          Chgstl [M:PJTA0]CMT1(NI) With "PJMCLOSEB"
        Else
          Chgstl [M:PJTA0]CMT1(NI) With "PJMCLOSE"
        Endif
      When 5
        # Plan
        If [M:PJTA0]CMT6(NI) = 1 Then
          Chgstl [M:PJTA0]CMT1(NI) With "PJMPLANB"
        Else
          Chgstl [M:PJTA0]CMT1(NI) With "PJMPLAN"
        Endif
      When 9
        # Suspended
        If [M:PJTA0]CMT6(NI) = 1 Then
          Chgstl [M:PJTA0]CMT1(NI) With "PJMHOLDB"
        Else
          Chgstl [M:PJTA0]CMT1(NI) With "PJMHOLD"
        Endif
      When Default
        Chgstl [M:PJTA0]CMT1(NI) With AVOID.ACHAR
    Endcase
  Next NI
  Affzo [M:PJTA0]5
End

##########################################################################################################
Subprog COPY_SCREEN_TO_CLASS()

Local Integer ASTATUS
Local Integer ILINE
Local Integer NI

  If [M:PJTA0]LINTAS > 0 Then
    # Products lines
    # 2°) Celles qui sont nouvelles dans la classe et pas a l'écran : c'est que l'utilisateur à fait ECHAP sur la ligne : on la supprime
    For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT)
      If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT(NI) <> null and find(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
        ILINE = find(num$(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT(NI).AUUID), [M:PJTA1]AUUID(0..[M:PJTA1]NBART-1))
        If ILINE = 0 Then
          ILINE = find(NI, [M:PJTA1]COLLIN(0..[M:PJTA1]NBART-1))
        Endif
        If ILINE = 0 Then
          [L]ASTATUS = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).ADELLINE("RITT", GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT(NI).AORDER)
          If [L]ASTATUS >= [V]CST_AERROR Then
            GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
            GOK = 0
            GERR = 1
            Break
          Endif
        Endif
      Endif
    Next NI
    If GERR = 1 Then
      End
    Endif
    # Lignes Main d'Oeuvre
    # 2°) Celles qui sont nouvelles dans la classe et pas a l'écran : c'est que l'utilisateur à fait ECHAP sur la ligne : on la supprime
    For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO)
      If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO(NI) <> null and find(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
        ILINE = find(num$(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO(NI).AUUID), [M:PJTA2]AUUID(0..[M:PJTA2]NBOPE-1))
        If ILINE = 0 Then
          ILINE = find(NI, [M:PJTA2]COLLIN(0..[M:PJTA2]NBOPE-1))
        Endif
        If ILINE = 0 Then
          [L]ASTATUS = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).ADELLINE("RTKO",GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO(NI).AORDER)
          If [L]ASTATUS >= [V]CST_AERROR Then
            GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
            GOK = 0
            GERR = 1
            Break
          Endif
        Endif
      Endif
    Next NI
    If GERR = 1 Then
      End
    Endif
    # Line for the task dependecies
    # 2°) Celles qui sont nouvelles dans la classe et pas a l'écran : c'est que l'utilisateur à fait ECHAP sur la ligne : on la supprime
    For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PTLNK)
      If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PTLNK(NI) <> null and find(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PTLNK(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
        ILINE = find(num$(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PTLNK(NI).AUUID), [M:PJTA3]AUUID(0..[M:PJTA3]NBLNK-1))
        If ILINE = 0 Then
          ILINE = find(NI, [M:PJTA3]COLLIN(0..[M:PJTA3]NBLNK-1))
        Endif
        If ILINE = 0 Then
          [L]ASTATUS = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).ADELLINE("PTLNK",GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PTLNK(NI).AORDER)
          If [L]ASTATUS >= [V]CST_AERROR Then
            GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
            GOK = 0
            GERR = 1
            Break
          Endif
        Endif
      Endif
    Next NI
    If GERR = 1 Then
      End
    Endif
  Endif
End

##########################################################################################################
Funprog CHECK_FRCDLTALLFLG()

Local Integer IARENDRE

  # Issue X3-101833 - 2018-08-01 by FGR
  IARENDRE = [V]CST_AYES
  # ---------------------------
  Gosub CHECK_BEGIN_MLK
  # ---------------------------
  For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS)
    If GZINSPJM.PJM(1).TAS(NI) <> null and find(GZINSPJM.PJM(1).TAS(NI).ASTALIN,[V]CST_AUPD) <> 0 Then
      For NE = 1 To maxtab(GZINSPJM.PJM(1).TAS(NI).RITT)
        If GZINSPJM.PJM(1).TAS(NI).RITT(NE) <> null and find(GZINSPJM.PJM(1).TAS(NI).RITT(NE).ASTALIN,[V]CST_AUPD) <> 0 Then
          If GZINSPJM.PJM(1).TAS(NI).RITT(NE).FRCDLTALLFLG = [V]CST_AYES and
&            GZINSPJM.PJM(1).TAS(NI).RITT(NE).FRCDLTALLFLG <> GZINSPJM.PJM(1).TAS(NI).RITT(NE).snapshot.FRCDLTALLFLG
&         Then
            Gosub CHECK_CURRENT_MLK_0
          Endif
        Endif
      Next NE
    Endif
  Next NI
  Gosub CHECK_END_MLK
End IARENDRE

##########################################################################################################
$CHECK_BEGIN_MLK
Global Clbfile GSPJMMSG

Local Integer INBLST
Local Char STASCOD(GLONTAC)(1..)
Local Char SITMREF(GLONITM)(1..)
Local Integer IMTOLINK(1..)
Local Integer IORDERS(1..)
Local Integer ISTOCK(1..)
Local Integer NI
Local Integer NE
Local Char CRLF(GLONDES)
Local Integer BFIRST

  # Issue X3-101833 - 2018-08-01 by FGR
  Local File MTOLINK [MLK]
  # ---------------------------
  INBLST = 0
  Raz STASCOD
  Raz SITMREF
  Raz IMTOLINK
  Raz IORDERS
  Raz ISTOCK
  CRLF = chr$(10)
Return

##########################################################################################################
$CHECK_END_MLK
  # Issue X3-101833 - 2018-08-01 by FGR
  # ---------------------------
  If INBLST > 0 Then
    Raz GSPJMMSG
    BFIRST = [V]CST_AYES
    For NI = 1 To INBLST
      If IMTOLINK(NI) = [V]CST_AYES Then
        If BFIRST = [V]CST_AYES Then
          BFIRST = [V]CST_ANO
          GSPJMMSG += mess(1118,2260,1)
        Endif
        GSPJMMSG += CRLF + string$(5," ") + func AFNC.MES2(mess(1119,2260,1), STASCOD(NI), SITMREF(NI))
      Endif
    Next NI
    BFIRST = [V]CST_AYES
    For NI = 1 To INBLST
      If IORDERS(NI) = [V]CST_AYES Then
        If BFIRST = [V]CST_AYES Then
          BFIRST = [V]CST_ANO
          GSPJMMSG += CRLF + CRLF + mess(1120,2260,1)
        Endif
        GSPJMMSG += CRLF + string$(5," ") + func AFNC.MES2("* Task: $1$ Product: $2$", STASCOD(NI), SITMREF(NI))
      Endif
    Next NI
    If dim(ISTKCHK) > 0 and ISTKCHK = [V]CST_AYES Then
      BFIRST = [V]CST_AYES
      For NI = 1 To INBLST
        If ISTOCK(NI) = [V]CST_AYES Then
          If BFIRST = [V]CST_AYES Then
            BFIRST = [V]CST_ANO
            GSPJMMSG += CRLF + CRLF + mess(1123,2260,1)
          Endif
          GSPJMMSG += CRLF + string$(5," ") + func AFNC.MES2("* Task: $1$ Product: $2$", STASCOD(NI), SITMREF(NI))
        Endif
      Next NI
    Endif
    GSPJMMSG += CRLF + CRLF + mess(1121,2260,1)
    # ---------------------------
    IARENDRE = func TRTPJMQUE.ASK_QUESTION_MESSAGE([V]CST_AYES)
  Endif
  # ---------------------------
  Kill GSPJMMSG
Return

##########################################################################################################
$CHECK_CURRENT_MLK_0
  # Issue X3-101833 - 2018-08-01 by FGR
  If GZINSPJM.PJM(1).TAS(NI).RITT(NE).WIPNUM <> AVOID.ACHAR Then
    INBLST += 1
    STASCOD(INBLST) = GZINSPJM.PJM(1).TAS(NI).RITT(NE).TASCOD
    SITMREF(INBLST) = GZINSPJM.PJM(1).TAS(NI).RITT(NE).ITMREF
    IORDERS(INBLST) = [V]CST_AYES
  Endif
  # ---------------------------
  Filter [MLK] Where [F:MLK]STOFCY = GZINSPJM.PJM(1).TAS(NI).RITT(NE).STOFCY
&                and [F:MLK]ITMREF = GZINSPJM.PJM(1).TAS(NI).RITT(NE).ITMREF
&                and [F:MLK]DEMTYP = 40
&                and [F:MLK]DEMNUM = GZINSPJM.PJM(1).TAS(NI).TASNUM
&                and [F:MLK]DEMLIN = GZINSPJM.PJM(1).TAS(NI).RITT(NE).ITTSEQ
&                and [F:MLK]DEMSEQ = 0
  For [MLK]
    If INBLST = 0 or STASCOD(INBLST) <> GZINSPJM.PJM(1).TAS(NI).RITT(NE).TASCOD or SITMREF(INBLST) <> GZINSPJM.PJM(1).TAS(NI).RITT(NE).ITMREF Then
      INBLST += 1
      STASCOD(INBLST) = GZINSPJM.PJM(1).TAS(NI).RITT(NE).TASCOD
      SITMREF(INBLST) = GZINSPJM.PJM(1).TAS(NI).RITT(NE).ITMREF
    Endif
    IMTOLINK(INBLST) = [V]CST_AYES
    Break
  Next
  Filter [MLK]
Return

##########################################################################################################
$CHECK_CURRENT_MLK_1
  # Issue X3-101833 - 2018-08-01 by FGR
  If dim(ISTKCHK) > 0 and ISTKCHK = [V]CST_AYES Then
    If GZINSPJM.PJM(1).TAS(NI).RITT(NE).ALLQTY > 0 or GZINSPJM.PJM(1).TAS(NI).RITT(NE).SHTQTY > 0 Then
      If INBLST = 0 or STASCOD(INBLST) <> GZINSPJM.PJM(1).TAS(NI).RITT(NE).TASCOD or SITMREF(INBLST) <> GZINSPJM.PJM(1).TAS(NI).RITT(NE).ITMREF Then
        INBLST += 1
        STASCOD(INBLST) = GZINSPJM.PJM(1).TAS(NI).RITT(NE).TASCOD
        SITMREF(INBLST) = GZINSPJM.PJM(1).TAS(NI).RITT(NE).ITMREF
      Endif
      ISTOCK(INBLST) = [V]CST_AYES
    Endif
  Endif
Return

###################################################################################################
Funprog GET_PJMACTSPLD_ORI(VNLINE)
Value Integer VNLINE

Local Char SARENDRE(250)

  # Issue X3-108644 - 2018-10-11 by FGR : called from the screen because field size is not enough
  If VNLINE = 0 Then
    SARENDRE = func PJMACTSPLD.CALLER_PROJECT()
  Else
    SARENDRE = func PJMACTSPLD.CALLER_TASK()
  Endif
End SARENDRE

###################################################################################################
Funprog GET_PJMACTSPLD_COD(VNLINE)
Value Integer VNLINE

Local Char SARENDRE(250)

  # Issue X3-108644 - 2018-10-11 by FGR : called from the screen because field size is not enough
  If VNLINE = 0 Then
    SARENDRE = [M:PJTA0]OPPNUM
  Else
    SARENDRE = [M:PJTA0]WRKTAS(VNLINE)
  Endif
End SARENDRE

