#<AdxTL>@(#)7.0.0.0 $Revision$
############################################################################
# TRTACHPOH2    Traitements liés aux commandes standards      Module ACHAT #
# ------------------------------------------------------------------------ #
# Gosub                                                     MBT 23/04/2008 #
#   - MODIF_POH  : Modif/Suppr/Solde commandes d'achat à partir de [M:PMG] #
############################################################################


$ACTION
If GPOH_WERR  mkstat=1 : Return : Endif : # Si déjà une erreur , c'est fini !
Case ACTION
  When "IMP_ZONE"  : Gosub MSK_ENTETE
  When "IMP_TAB"   : Gosub MSK_DETAIL
Endcase
Return


################################################################################
# MODIF_POH : S/P de modification, suppression ou solde des commandes d'achat  #
# ---------------------------------------------------------------------------- #
#   WTRT    : Nom du traitement à exécuter pour le chargement des champs       #
#   WTRA    : Fichier trace (0-1=Non, 2=Oui, 3=Détaillée, 4=Hyper Détaillée)   #
#   WERR    : Code retour (0=Ok,  1-99=Erreur avec GMESSAGE)                   #
################################################################################
$MODIF_POH
#----- Variables locales -----#
Local  Char     WTRT(GLONADC)  : WTRT="TRTACHPOH2"
Local  Integer  WTRA           : WTRA=2 : # Trace simple !
Local  Integer  WERR           : WERR=0
Local  Char     SAV_GABREV(5)  : SAV_GABREV =GABREV
Local  Char     SAV_GPTRNUM(3) : SAV_GPTRNUM=GPTRNUM
Local  Integer  SAV_GIMPORT    : SAV_GIMPORT=GIMPORT
Local  Integer  SAV_I          : SAV_I      =I
Local  Integer  SAV_NOLIGN     : SAV_NOLIGN =nolign
Local  Char     SAV_GREP       : SAV_GREP   =GREP
Local  Integer  SAV_NBLIG
Local  Integer  OK             : OK=1
Local  Char     WZON(GLONAVA)
Local  Char     ACTION(30)
Local  Char     WPGM(GLONADC)
Local  Char     WMESSAGE(100)
Local  Char     WMSG(90)
Local  Char     WGRPDEB(GLONVCR)
Local  Shortint WREVNUM
Local  Libelle  WADXLOG
Local  Char     CLECUR2(1)(2)
#-----
Global Integer  GPOH_WTRA      : GPOH_WTRA=WTRA
Global Integer  GPOH_WERR      : GPOH_WERR=WERR
#-----
If !adxlog  WADXLOG=0  Else  WADXLOG=1 : Endif
#----- Ouverture masques écrans si nécessaire -----#
If !clalev([M:POH0])  Local Mask "POH0"   [POH0] : Endif
If !clalev([M:POH1])  Local Mask "POH1"   [POH1] : Endif
If !clalev([M:POH2])  Local Mask "POH2"   [POH2] : Endif
If !clalev([M:POH3])  Local Mask "POH3"   [POH3] : Endif
#-----
Raz [M:POH0], [M:POH1], [M:POH2], [M:POH3]
#----- Définition des variables de l'objet -----#
Raz GPTRNUM, GMESSAGE, WGRPDEB, WMSG
GIMPORT=1
Local Char ABREV(5)
ABREV ="POH"
GABREV="POH"
ACTION="DEFVAR"  : WPGM="GOBJET"  : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub DEFVAR  From GOBJET
WINPROG="WGOPOH"
# sr 02.12 Demande 80297
# Issue 81372 - 2012-05-04 by SR
Call ISWINDOWOK (nomap,"OPOH") From INTRUTILB
ACTION="OUVRE"   : WPGM="WOPOH"   : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub OUVRE   From WOPOH
OK=1
ACTION="OUVRE"   : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
If !OK  WERR=1 : GOK=0 : Goto FIN_MODIF_POH : Endif
#----- Chargement de la commande à modifier -----#
CLECUR=1
nolign=1
[M:POH0]=[F:POH]
[M:POH1]=[F:POH]
[M:POH2]=[F:POH]
[M:POH3]=[F:POH]
ACTION="SET_CLE" : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub SET_CLE From GOBJSUB
ACTION="LIENS"   : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
If !OK  WERR=1 : GOK=0 : Goto FIN_MODIF_POH : Endif
#-----------------------------------#
# Début modification de la commande #
#-----------------------------------#
Raz WMSG
SAV_NBLIG=[M:POH2]NBLIG
#----- Les contrôles d'avant modification ont déjà été effectués -----#
GREP="M": OK=1 : GREVFLG=0
#WREVNUM=[M:POH0]REVNUM
#ACTION="AVANT_MOD" : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
#Gosub ACTION From GOBJSUB : If !OK  WERR=1 : GOK=0 : Goto FIN_MODIF_POH : Endif
#[M:POH0]REVNUM=WREVNUM
#----- Modification avec avenant ? -----#
If [M:PMG]REVFLG=2
  GREVFLG=2 : [M:POH0]REVNUM+=1
Else
  GREVFLG=1
Endif
#----- Recherche ligne à modifier ou supprimer -----#
If [M:PMG]MAJCOD<>"L"
  nolign=find([M:PMG]VCRLIN(SAV_I),[M:POH2]POPLIN(0..[M:POH2]NBLIG-1))
  #----- XXXXXXXXXXXXXXX 999999 999999 Ligne inexistante -----#
  If nolign=0
    If WTRA>1
      WMSG =[M:PMG]VCRNUM(SAV_I)-num$([M:PMG]VCRLIN(SAV_I))-num$([M:PMG]VCRSEQ(SAV_I))
      WMSG-=mess(139,105,1)
     Call ECR_TRACE(WMSG,1)
    Endif
    Raz WMSG : WERR=1 : GOK=0 : Goto FIN_MODIF_POH
  Endif
Endif
#-----
Case [M:PMG]MAJCOD
  When "M" : Gosub TRT_MODIF_LIGNE
  When "L" : Gosub TRT_AJOUT_LIGNE
  When "A" : Gosub TRT_SUPPR_LIGNE
  When "S" : Gosub TRT_SOLDE_LIGNE
Endcase
#-------------------------------------------#
# Transaction de mise à jour de la commande #
#-------------------------------------------#
If !WERR
  If GREP="M"
    Gosub TRT_MODIF_POH : # Transaction de modification
  Else
    Gosub TRT_SUPPR_POH : # Transaction de suppression
  Endif
Endif
#-------------------#
# Fin du traitement #
#-------------------#
$FIN_MODIF_POH
ACTION="FERME"  : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
GIMPORT=0
#-----
Kill GPOH_WTRA, GPOH_WERR
GABREV =SAV_GABREV
GPTRNUM=SAV_GPTRNUM
GIMPORT=SAV_GIMPORT
GREP   =SAV_GREP
nolign =SAV_NOLIGN
I      =SAV_I
Return


#---------------------------#
# Ecriture du fichier trace #
#---------------------------#
Subprog ECR_TRACE (WMSG,TRAIT)
Value Char    WMSG
Value Integer TRAIT
If GTRACE<>""
  Call ECR_TRACE(WMSG,TRAIT) From GESECRAN
  If GPURTRACE=1  GPURTRACE=2 : Endif
Endif
End


#-----------------#
# Trace détaillée #
#-----------------#
$TRACE_DETAILLEE
If WPGM=""
  If ACTION="Rewrite [POH]"
    WMESSAGE=ACTION
  Else
    WMESSAGE="---"-mess(5,126,1)-ACTION
  Endif
Else
  WMESSAGE=mess(27,115,1)-ACTION+space$(20-len(ACTION))+"From "-WPGM
Endif
Call ECR_TRACE(WMESSAGE,0)
Return


#----------------------------------------------#
# Modification d'une ligne de commande d'achat #
#----------------------------------------------#
$TRT_MODIF_LIGNE
[M:POH2]POHLIN(nolign-1)=SAV_I
Default Mask [POH2]
indice=nolign-1
mkstat=0
status=75
ACTION="IMP_TAB(SAI_NBLIG)"  : WPGM="W0POH2" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
[M:POH2]NBLIG=nolign        : # Est-ce utile ?
Call SAI_NBLIG("POH","IMP_TAB" ,WTRT) From W0POH2
#[M:POH2]UPDFLG(nolign-1)=1 : # Fait par le SAI_NBLIG !
[M:POH2]NBLIG=SAV_NBLIG     : # Est-ce utile ?
If mkstat | GPOH_WERR  WERR=1 : GOK=0 : Return : Endif
Return


#---------------------------------------#
# Ajout d'une ligne de commande d'achat #
#---------------------------------------#
$TRT_AJOUT_LIGNE
L=find([M:PMG]VCRLIN(SAV_I),[M:POH2]POPLIN(0..[M:POH2]NBLIG-1))
If !L
  If WTRA>1
    WMSG =[M:PMG]VCRNUM(SAV_I)-num$([M:PMG]VCRLIN(SAV_I))-num$([M:PMG]VCRSEQ(SAV_I))
    WMSG-=mess(139,105,1)
    Call ECR_TRACE(WMSG,1)
  Endif
  Raz WMSG : WERR=1 : GOK=0 : Return
Endif
nolign=[M:POH2]NBLIG+1
[M:POH2]POHLIN(nolign-1)=SAV_I
Default Mask [POH2]
indice=nolign-1
mkstat=0
status=75
ACTION="IMP_TAB(SAI_NBLIG)"  : WPGM="W0POH2" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
[M:POH2]NBLIG=nolign
Call SAI_NBLIG("POH","IMP_TAB" ,WTRT) From W0POH2
[M:POH2]NBLIG=SAV_NBLIG+1
If mkstat | GPOH_WERR  WERR=1 : GOK=0 : Return : Endif
Return


#---------------------------------------------#
# Suppression d'une ligne de commande d'achat #
#---------------------------------------------#
$TRT_SUPPR_LIGNE
[M:POH2]POHLIN(nolign-1)=SAV_I
Default Mask [POH2]
indice=nolign-1
mkstat=0
status=65
ACTION="C_NBLIG(status=65)"  : WPGM="SUBPOH" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Call C_NBLIG     From SUBPOH
If mkstat
  If WTRA>1
    GMESSAGE=[M:POH0]POHNUM-[M:POH2]ITMREF(nolign-1)-GMESSAGE
    Call ECR_TRACE(GMESSAGE,1)
  Endif
  Raz GMESSAGE, GERR
  WERR=1 : GOK=0 : Return
Endif
#----- Si composé (produit fini), vérif nbre de lignes liées -----#
Local Integer WI, WNBLL
Raz WNBLL
If nolign<[M:POH2]NBLIG & [M:POH2]LINTYP(nolign)>2
  For WI=nolign To [M:POH2]NBLIG-1
    If [M:POH2]LINTYP(WI)>2
      WNBLL+=1
    Else
      Break
    Endif
  Next WI
Endif
#-----
If [M:POH2]NBLIG>1+WNBLL
  #----- Suppression d'une ligne de commande -----#
  ACTION="AVANT_NBLIG(lin="+num$(nolign)+")"  : WPGM="SUBPOH" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
  Call AVANT_NBLIG From SUBPOH
  ACTION="APRES_NBLIG(lin="+num$(nolign)+")"  : WPGM="SUBPOH" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
  Call APRES_NBLIG From SUBPOH
  Dela nolign-1,1,[M:POH2]NBLIG-1 [M:POH2]NBLIG : [M:POH2]NBLIG-=1
Else
  #----- Si suppression commande, contrôle qu'aucun acompte n'a été versé ----#
  If [M:PMG]MAJCOD="A"
    GREP="A"
    Call ACOMPTES(6,3,[F:POH]POHNUM,[F:POH]LINNBR,[F:POH]PTE,[F:POH]ORDDAT,[F:POH]TOTORD,[F:POH]TTVORD,
&                [F:POH]CUR,0,"","","",1,OK) From TRTTPT :
    If OK=0
      If WTRA>1
        GMESSAGE=[M:POH0]POHNUM-GMESSAGE
        Call ECR_TRACE(GMESSAGE,1)
      Endif
      Raz GMESSAGE, GERR
      WERR=1 : GOK=0 : Return
    Endif
  Endif
Endif
#----- Message : Ligne commande XXXXXXXXXXXXXXX 999999 999999 supprimée ! -----#
If WTRA>1
  WMSG =mess(367,197,1)-[M:PMG]VCRNUM(SAV_I)
  WMSG-=num$([M:PMG]VCRLIN(SAV_I))
  WMSG-=num$([M:PMG]VCRSEQ(SAV_I))
  WMSG-=mess(170,197,1)
  Call ECR_TRACE(WMSG,0)
Endif
#-----
Return


#---------------------------------------#
# Solde d'une ligne de commande d'achat #
#---------------------------------------#
$TRT_SOLDE_LIGNE
[M:POH2]POHLIN(nolign-1)=SAV_I
Default Mask [POH2]
indice=nolign-1
#-----
[M:POH2]LINCLEFLG(nolign-1)=2
#----- Solde automatique des composants -----#
If [M:POH2]LINTYP(nolign-1)=2
  I=nolign
  While [M:POH2]LINTYP(I)>2 & I<[M:POH2]NBLIG
    If [M:POH2]LINCLEFLG(I)<>2
      [M:POH2]LINCLEFLG(I)=2 : [M:POH2]UPDFLG(I)=1
    Endif
    I+=1
  Wend
Endif
#-----
If [M:POH1]APPFLG<3
  [M:POH2]WAPPFLG(nolign-1)=2 : # Reprise du circuit de signature !
Endif
#-----
[M:POH2]UPDFLG(nolign-1)=1
#---- Message : Ligne commande XXXXXXXXXXXXXXX 9999999 9999999 soldée ! ----#
If WTRA>1
  WMSG =mess(367,197,1)-[M:PMG]VCRNUM(SAV_I)
  WMSG-=num$([M:PMG]VCRLIN(SAV_I))
  WMSG-=num$([M:PMG]VCRSEQ(SAV_I))
  WMSG-=mess(263,197,1)
  Call ECR_TRACE(WMSG,0)
Endif
#-----
Return


#-----------------------------------------------------#
# Modification de la commande d'achat proprement dite #
#-----------------------------------------------------#
$TRT_MODIF_POH
OK=1
ACTION="VERIF_MOD" : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
If !OK
  If GMESSAGE<>""
    If WTRA>1
      GMESSAGE=GMESSAGE-mess(98,197,1)-[M:POH0]POHNUM-mess(725,197,1)
      Call ECR_TRACE(GMESSAGE,1)
    Endif
    Raz GMESSAGE, GERR
  Endif
  WERR=1 : GOK=0 : Return
Endif
If WADXLOG=0
  Call DEBTRANS From GLOCK
Endif
#-----
$TR_MODIF
GOK=1
If WADXLOG=0
  If WTRA>2
    ACTION="Trbegin [POH], [POQ], [POP]" : WPGM="" : Gosub TRACE_DETAILLEE
  Endif
  Trbegin [POH], [POQ], [POP]
Endif
#----- Lecture avec bloquage physique de l'entête commande -----#
WMSG=mess(12,100,1)-"PORDER"-[M:POH0]POHNUM : # Erreur d'accès sur le fichier
Readlock [POH] POH0=[M:POH0]POHNUM
If fstat=1
  GOK=-1 : GLOCK="$PORDER"-[M:POH0]POHNUM
  Goto ROLL_MODIF_POH
Elsif fstat
  GOK=0  : Call RSTA("POH",[M:POH0]POHNUM) From GLOCK
  Goto AB_MODIF_POH
Endif
Raz WMSG
Default File [POH]
ACTION="AVANT_MODFIC"        : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
If GOK<0  Goto ROLL_MODIF_POH  Elsif !GOK  Goto AB_MODIF_POH : Endif
#----- Mise à jour du suivi workflow signature -----#
Call WRKGLOB(171,[F:POH]POHNUM,"PORDER","") From GOBJACT
Call WORKPLUS(2,"POH","M",[F:POH]POHNUM,"",0,1,1,WGRPDEB) From AWRK
If GOK<0  Goto ROLL_MODIF_POH  Elsif !GOK  Goto AB_MODIF_POH : Endif
#-----
nolign=1
[F:POH]=[M:POH0]
[F:POH]=[M:POH1]
[F:POH]=[M:POH2]
[F:POH]=[M:POH3]
If dim([F:POH]UPDDAT)>0  [F:POH]UPDDAT=date$     : Endif
If dim([F:POH]UPDTIM)>0  [F:POH]UPDTIM=time      : Endif
If dim([F:POH]UPDUSR)>0  [F:POH]UPDUSR=GUSER     : Endif
If dim([F:POH]EXPNUM)>0  [F:POH]EXPNUM=[C]EXPORT : Endif
ACTION="INIMOD"          : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
If GOK<0  Goto ROLL_MODIF_POH  Elsif !GOK  Goto AB_MODIF_POH : Endif
#-----
If WTRA>2
  ACTION="Rewrite [POH]" : WPGM="" : Gosub TRACE_DETAILLEE
Endif
#-----
WMSG=mess(13,100,1)-"PORDER"-[F:POH]POHNUM : # Erreur d'ecriture sur le fichier ...
Rewrite [POH]
If fstat  GOK=0 : Call FSTA("POH")  From GLOCK : Goto AB_MODIF_POH : Endif
Raz WMSG
ACTION="MODIF" : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
If GOK<0  Goto ROLL_MODIF_POH  Elsif !GOK  Goto AB_MODIF_POH : Endif
#----- Mise à jour du suivi workflow signature -----#
Call WORKPLUS(2,"POH","M",[F:POH]POHNUM,"",0,1,2,WGRPDEB) From AWRK
If GOK<0  Goto ROLL_MODIF_POH  Elsif !GOK  Goto AB_MODIF_POH : Endif
#-----
If WADXLOG=0
  If WTRA>2
    ACTION="Commit" : WPGM="" : Gosub TRACE_DETAILLEE
  Endif
  Commit
Endif
#----- Trace : Commande xxxxxxxxxx modifiée ! -----#
If WTRA>1
  WMSG =mess(98,197,1)-[F:POH]POHNUM-mess(223,197,1)
  Call ECR_TRACE(WMSG,0)
Endif
#-----
ACTION="APRES_MOD" : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
#----- Envoi des messages groupe workflow signature -----#
If WGRPDEB<>""  Call ENVOI_GROUPE(WGRPDEB) From AWRK : WGRPDEB="" : Endif
#-----
ACTION="FIN_MOD"   : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
Return
#-----
$ROLL_MODIF_POH
If WADXLOG=0
  If WTRA>2
    ACTION="Rollback" : WPGM="" : Gosub TRACE_DETAILLEE
  Endif
  Rollback
  Call ROLL From GLOCK
  If !GROLL  Goto TR_MODIF : Endif
Endif
Goto ERR_MODIF_POH
#-----
$AB_MODIF_POH
If WADXLOG=0
  If WTRA>2
    ACTION="Rollback" : WPGM="" : Gosub TRACE_DETAILLEE
  Endif
  Rollback
Endif
#-----
$ERR_MODIF_POH
ACTION="AB_MODIF" : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
#----- Suppression des message groupe workflow signature -----#
If WGRPDEB<>""  Call VIRE_GROUPE(WGRPDEB)  From AWRK : WGRPDEB="" : Endif
#-----
WERR=1
Return


#----------------------------------------------------#
# Suppression de la commande d'achat proprement dite #
#----------------------------------------------------#
$TRT_SUPPR_POH
If WADXLOG=0
  Call DEBTRANS From GLOCK
Endif
#-----
$TR_SUPPR
GOK=1
If WADXLOG=0
  If WTRA>2
    ACTION="Trbegin [POH], [POQ], [POP]" : WPGM="" : Gosub TRACE_DETAILLEE
  Endif
  Trbegin [POH], [POQ], [POP]
Endif
#-----
Raz WMSG
Default File [POH]
ACTION="AV_ANNULE" : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
If GOK<0  Goto ROLL_SUPPR_POH  Elsif !GOK  Goto AB_SUPPR_POH : Endif
ACTION="ANNULE"    : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
If GOK<0  Goto ROLL_SUPPR_POH  Elsif !GOK  Goto AB_SUPPR_POH : Endif
#-----
If WTRA>2
  ACTION="Delete [POH]" : WPGM="" : Gosub TRACE_DETAILLEE
Endif
#-----
WMSG=mess(12,100,1)-"PORDER"-[M:POH0]POHNUM : # Erreur d'accès sur le fichier
Delete [POH] Where POHNUM=[M:POH0]POHNUM
If fstat=1
  GOK=-1 : GLOCK="$PORDER"-[M:POH0]POHNUM
  Goto ROLL_SUPPR_POH
Elsif fstat
  GOK=0  : Call RSTA("POH",[M:POH0]POHNUM) From GLOCK
  Goto AB_SUPPR_POH
Endif
Raz WMSG
#-----
If WADXLOG=0
  If WTRA>2
    ACTION="Commit" : WPGM="" : Gosub TRACE_DETAILLEE
  Endif
  Commit
Endif
#----- Trace : Commande xxxxxxxxxx supprimée ! -----#
If WTRA>1
  WMSG=mess(98,197,1)-[M:POH0]POHNUM-mess(170,197,1)
  Call ECR_TRACE(WMSG,0)
Endif
#-----
ACTION="AP_ANNULE" : WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
#----- Mise à jour du suivi workflow -----#
Call WRKGLOB(172,[M:POH0]POHNUM,"PORDER","") From GOBJACT
Call WORKFLOW(2,"POH","A",[M:POH0]POHNUM)    From AWRK
#-----
If WTRA>2  ACTION="ANNULE" : WPGM="GOBJTXT" : Gosub TRACE_DETAILLEE : Endif
Call ANNULE("POH",[M:POH0]POHNUM,CLECUR2) From GOBJTXT
If WTRA>2  ACTION="ANNULE" : WPGM="SUBALI"  : Gosub TRACE_DETAILLEE : Endif
Call ANNULE("POH",[M:POH0]POHNUM,CLECUR2) From SUBALI
Return
#-----
$ROLL_SUPPR_POH
If WADXLOG=0
  If WTRA>2
    ACTION="Rollback" : WPGM="" : Gosub TRACE_DETAILLEE
  Endif
  Rollback
  Call ROLL From GLOCK
  If !GROLL  Goto TR_SUPPR : Endif
Endif
Goto ERR_SUPPR_POH
#-----
$AB_SUPPR_POH
If WADXLOG=0
  If WTRA>2
    ACTION="Rollback" : WPGM="" : Gosub TRACE_DETAILLEE
  Endif
  Rollback
Endif
#-----
$ERR_SUPPR_POH
WERR=1
Return


#---------------------------------------------------------------#
# Chargement des champs écrans POH0, POH1, POH3 entête commande #
#---------------------------------------------------------------#
$MSK_ENTETE
If GPOH_WTRA>3
  If IMPZON="CCE" | IMPZON="INVDTAAMT"
    Call ECR_TRACE("     ."-mess(36,124,1)-IMPZON+"("+num$(nolign-1)+")",0)
  Else
    Call ECR_TRACE("     ."-mess(36,124,1)-IMPZON,0)
  Endif
Endif
Case IMPZON
  When "POHFCY"    : #----- Ecran POH0 -----#
  When "POHNUM"
  When "ORDDAT"
  When "BPSNUM"
  When "BPSINV"    : #----- Ecran POH1 -----#
  When "BPAINV"
  When "BPRPAY"
  When "BPAPAY"
  When "BPSSHI"
  When "BPOADD"
  When "ORDREF"
  When "PTE"
  When "BUY"
  When "CUR"
  When "CHGTYP"
  When "BPTNUM"
  When "MDL"
  When "DAYLTI"
  When "VACBPR"
  When "EXTRCPDAT1"
  When "INVFCY"
  When "STOFCY"
  When "NBAXE"
  When "CCE"
  When "NBFAC"     : #----- Ecran POH3 -----#
  When "INVDTA"
  When "INVDTAAMT"
  When "INVDTAVAT"
  When "ACC1","ACC2","ACC3","ACC4","ACC5","ACC6","ACC7","ACC8","ACC9","ACC10"
  When "DSP"
  When "PFICCE1", "PFICCE2", "PFICCE3", "PFICCE4", "PFICCE5", "PFICCE6", "PFICCE7",
&      "PFICCE8", "PFICCE9", "PFICCE10","PFICCE11","PFICCE12","PFICCE13","PFICCE14",
&      "PFICCE15","PFICCE16","PFICCE17","PFICCE18","PFICCE19","PFICCE20"
  When "OCNDAT"
  When "OCNNUM"
  When "OCNREM"
Endcase
Return


#-----------------------------------------------------#
# Chargement des champs écran POH2 lignes de commande #
#-----------------------------------------------------#
$MSK_DETAIL
NOL=nolign-1 : # La variable NOL est définie par W0POH2
If GPOH_WTRA>3
  If IMPZON="NBLIG"
    Call ECR_TRACE("     ."-mess(36,124,1)-IMPZON,0)
  Else
    Call ECR_TRACE("     ."-mess(36,124,1)-IMPZON+"("+num$(NOL)+")",0)
  Endif
Endif
Case IMPZON
  When "NBLIG"
  When "ITMREF"
    If [M:PMG]MAJCOD="L"
      L=find([M:PMG]VCRLIN([M:POH2]POHLIN(NOL)),[M:POH2]POPLIN(0..[M:POH2]NBLIG-1))
      If L
        L-=1
        J =NOL
        Gosub COPIE_LIG From SUBPOHA
        [M:POH2]LINFLG(J)=3     : # Pour ne pas effectuer de recherche tarif !
        WCHAR=[M:POH2]ITMREF(J) : # Pour ne pas exécuter "AM_ITMREF" !
      Endif
    Endif
  When "ITMDES"
  When "ITMDES1"
  When "PRHFCY"
    If [M:POH2]PRHFCY(NOL)<>[M:PMG]STOFCY([M:POH2]POHLIN(NOL))
      If [F:FCY]FCY<>[M:PMG]STOFCY([M:POH2]POHLIN(NOL))
        Read [FCY] FCY0=[M:PMG]STOFCY([M:POH2]POHLIN(NOL))
        If fstat  Raz [F:FCY] : Endif
      Endif
      [M:POH2]PRHFCY(NOL)=[M:PMG]STOFCY([M:POH2]POHLIN(NOL))
    Else
      Raz [F:FCY]
    Endif
  When "FCYADD"
    If [F:FCY]BPAADD<>""
      [M:POH2]FCYADD(NOL)=[F:FCY]BPAADD
    Endif
  When "USEPLC"
    If [M:PMG]USEPLC<>""
      [M:POH2]USEPLC(NOL)=[M:PMG]USEPLC
    Endif
  When "LINSTOFCY"
  When "SCOADD"
  When "UOM"
  When "QTYUOM"
    If [M:POH2]UOMPUUCOE(NOL)=0  [M:POH2]UOMPUUCOE(NOL)=1 : Endif
    [M:POH2]QTYUOM(NOL)=[M:PMG]EXTPUUQTY([M:POH2]POHLIN(NOL))/[M:POH2]UOMPUUCOE(NOL)
    Call QTEARR([M:POH2]QTYUOM(NOL),[M:POH2]UOM(NOL)) From TRTDIV
  When "UOMPUUCOE"
  When "QTYSTU"
    [M:POH2]QTYPUU(NOL)=[M:PMG]EXTPUUQTY([M:POH2]POHLIN(NOL))
    [M:POH2]QTYSTU(NOL)=[M:PMG]EXTSTUQTY([M:POH2]POHLIN(NOL))
  When "PJT"
    If [M:PMG]PJT([M:POH2]POHLIN(NOL))<>""
      [M:POH2]PJT(NOL)=[M:PMG]PJT([M:POH2]POHLIN(NOL))
    Endif
  When "EXTRCPDAT"
    [M:POH2]EXTRCPDAT(NOL)=[M:PMG]ENDDAT([M:POH2]POHLIN(NOL))
  When "GROPRI"
  # Issue 71276 - 2015-07-10 by MUARN : Versions
  When "ECCVALMAJ"
    [M:POH2]ECCVALMAJ(NOL)=[M:PMG]ECCVALMAJ([M:POH2]POHLIN(NOL))
  When "ECCVALMAJ"
    [M:POH2]ECCVALMIN(NOL)=[M:PMG]ECCVALMIN([M:POH2]POHLIN(NOL))
  # End issue 71276
  When "DISCRGVAL1", "DISCRGVAL2", "DISCRGVAL3", "DISCRGVAL4", "DISCRGVAL5",
&      "DISCRGVAL6", "DISCRGVAL7", "DISCRGVAL8", "DISCRGVAL9"
  When "LINACC1", "LINACC2", "LINACC3", "LINACC4", "LINACC5",
&      "LINACC6", "LINACC7", "LINACC8", "LINACC9", "LINACC10"
  When "LINPURTYP"
  When "CCE1",  "CCE2",  "CCE3",  "CCE4",  "CCE5",  "CCE6",  "CCE7",  "CCE8",  "CCE9",  "CCE10",
&      "CCE11", "CCE12", "CCE13", "CCE14", "CCE15", "CCE16", "CCE17", "CCE18", "CCE19", "CCE20"
  When "QUAFLG"
  When "EECINCRAT"
  When "ORICRY"
  When "VAT1"
  When "VAT2"
  When "VAT3"
    #----- Dernier champ saisissable non soumis à code activité -----#
    Gosub FIN_CHARG_LIGNE
  When "TAXRCP"
  When "TAXISS"
  When "TAXOTH1"
  When "TAXOTH2"
Endcase
Return


#-------------------------------------------------#
# Fin de chargement de la ligne et écriture trace #
#-------------------------------------------------#
$FIN_CHARG_LIGNE
If dim(WMSG)<1  Local Char WMSG (100) : Endif
#----- Message d'avertissement si date réception prévue inférieure à date du jour -----#
If [M:POH2]EXTRCPDAT(NOL)<date$
  If GPOH_WTRA>1
    WMSG=format$("DD2",[M:POH2]EXTRCPDAT(NOL))-mess(203,197,1)
    Call ECR_TRACE(WMSG,0)
  Endif
Endif
#----- Message : Ligne commande XXXXXXXXXXXXXXX 999999 999999 mofifiée ! -----#
If GPOH_WTRA>1
  WMSG =mess(367,197,1)-[M:PMG]VCRNUM([M:POH2]POHLIN(NOL))
  If [M:PMG]MAJCOD="M"
    WMSG-=num$([M:PMG]VCRLIN([M:POH2]POHLIN(NOL)))
    WMSG-=num$([M:PMG]VCRSEQ([M:POH2]POHLIN(NOL)))
    WMSG-=mess(223,197,1)
  Else
    WMSG-=num$([M:PMG]VCRLIN([M:POH2]POHLIN(NOL))+1000)
    WMSG-=num$([M:PMG]VCRSEQ([M:POH2]POHLIN(NOL)))
    WMSG-=mess(224,197,1)
  Endif
  Call ECR_TRACE(WMSG,0)
Endif
#-----
Return

