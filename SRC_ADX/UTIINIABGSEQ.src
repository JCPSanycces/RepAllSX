#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# UTIINIABGSEQ                                                                       #
#                                                                                    #
# Initialize field SEQ in batch groups                                               #
#                                                                                    #
######################################################################################
Call MAJ_UTIINIABGSEQ
End

#-------------------------------------------------------------------------------#
Subprog MAJ_UTIINIABGSEQ
Local Char DOSSIER(30)
Local Integer LRET
Local Integer LFORCE
Local Integer LDELAXX

DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIINIABGSEQ - Init SEQ field in batch groups") From SAIDOS
If DOSSIER <> "" Then
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTIINIABGSEQ - Init SEQ field in batch groups") From LECFIC
    Call EXE_UTIINIABGSEQ(DOSSIER)

    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif
End

#-------------------------------------------------------------------------------#
#**
#* Initialize AUUID field in tables concerned by GDPR
#*
#* @param DOSSIER : Folder namein which ru
#*!
Subprog EXE_UTIINIABGSEQ(DOSSIER)
Value Char    DOSSIER

If filinfo(filpath("FIL","ABATGRP","fde",DOSSIER),0)<=0
   End
Endif
Local File =DOSSIER+".ABATGRP" [ABG]

Call ECR_TIME("UTIINIABGSEQ : Start folder's process"-DOSSIER) From DOSSUB

Call DEBTRANS From GLOCK
Trbegin [ABG]
For [ABG]
    If [F:ABG]NBTAC>0 & find(0,[F:ABG]SEQ(0..[F:ABG]NBTAC-1))>0
        #Call ECR_TIME("Update Batch group"-[F:ABG]CODGRP) From DOSSUB
        Call INISEQ([F:ABG]SEQ, [F:ABG]NBTAC) From SUBABG
        Rewrite [ABG]
        If fstat
            Call FSTA("ABG") From GLOCK
            GOK=0
            Break
        Endif
    Endif
Next
If GOK=0
    Rollback
Else
    Commit
Endif

LogicClose File [ABG]

Call ECR_TIME("UTIINIABGSEQ : End folder's process"-[L]DOSSIER) From DOSSUB
End

#-------------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
      Call EXE_UTIINIABGSEQ(APPLI)
  Endif

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
      Call EXE_UTIINIABGSEQ(APPLI)
  Endif

End

