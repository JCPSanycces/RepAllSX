#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion objet ADLK
######################################################################################
# GESTION DES KITS
# prend modele sur le GESADLV - certains prog et ecrans sont communs
# on utilise les mêmes abreviations écrans que sur les livrables 
######################################################################################
$ACTION
Case ACTION
 When "AVANT_OUVRE"  : Gosub AVANT_OUVRE From SUBADLV
 When "OUVRE"        : Gosub OUVRE       From SUBADLV
 When "FILTRE"       : Gosub FILTRE      From SUBADLV
 When "FERME"        : Gosub FERME       From SUBADLV
 When "LIENS"        : Gosub LIENS       From SUBADLV
 When "CREATION"     : Gosub CREATION    From SUBADLV
 When "ABANDON"      : Gosub ABANDON     From SUBADLV
 When "RAZCRE"       : Gosub RAZCRE      From SUBADLV
 When "MODIF"        : Gosub MODIF       From SUBADLV
 When "ANNULE"       : Gosub ANNULE      From SUBADLV
 When "VERIF_CRE"    : Gosub VERIF       From SUBADLV
 When "VERIF_MOD"    : Gosub VERIF       From SUBADLV
 When "RAZDUP"       : Gosub RAZDUP      From SUBADLV
 When "AB1_NBRTAB"   : Gosub AB1_NBRTAB  From SUBADLV
 When "AB3_NBRTAB"   : Gosub AB3_NBRTAB  From SUBADLV
 When "SETBOUT"      : Gosub SETBOUT     From SUBADLV
 When "AVANTBOUT"    : Gosub AVANTBOUT   From SUBADLV
 When "EXEBOUT"      : Gosub EXEBOUT     From SUBADLV
 When "EFFMASK"      : [M:ADLK0]ADLVTYP=2
 When Default
Endcase
Return

#----------------------#
$ACTIONB
Local Integer PSUBB
Call EXISTE_ADX("","","ASAIPARVALB",PSUBB) From ORDSYS
If PSUBB
    Gosub ACTION From ASAIPARVALB
Endif
Return


