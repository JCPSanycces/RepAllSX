########################################################################################
##                     Etiquette - écran ADLK0
########################################################################################
########################################################################################

Subprog AS_COD(VALEUR)
#-----------------------#
# Avant saisie code     #
#-----------------------#
Variable Char    VALEUR()
[M:ADLK0]ADLVTYP=2
End


Subprog C_COD(VALEUR)
Variable Char    VALEUR()
Call C_COD(VALEUR) From SUBADLV
End


Subprog AS_PDT(VALEUR)
Variable Integer VALEUR
Call AS_PDT(VALEUR) From SUBADLV
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran ADLK2) 02/07/2013 16:52:28
######################################################################################
Subprog AS_NBRACT
Gosub INIT_NBRACT From SUBADLV
End


Subprog B1_NBRACT
# chargement des valeurs par defaut des codes activités fonctionnelles 
# par rapport à la fiche dossier
Call B1_NBRACT From SUBADLV
End

Subprog B2_NBRACT
# là on demande sur quel livrable
# action ASELADLV
Call B2_NBRACT From SUBADLV
End


Subprog AS_FLGACT(VALEUR)
Variable Integer VALEUR
Call AS_FLGACT(VALEUR) From SUBADLV
End

Subprog C_FLGACT(VALEUR)
Variable Integer VALEUR
Call C_FLGACT(VALEUR) From SUBADLV
End

Subprog AM_FLGACT(VALEUR)
Variable Integer VALEUR
Call AM_FLGACT(VALEUR) From SUBADLV
End

