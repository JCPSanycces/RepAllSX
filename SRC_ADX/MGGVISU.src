#<AdxTL>@(#)2.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
End

######################################

$ACTION
Case ACTION
 When "OUVRE"             : Gosub OUVRE
 When "SAISIE"            : Gosub SAISIE
 When "DESTINATION"       : Gosub DESTINATION
 When "EXEC"              : Gosub EXEC
 When "FIN"               : Gosub FIN
 When "IMPRIMANTE"        : Gosub IMPRIMANTE
 When "MESSAGERIE"        : Gosub MESSAGERIE
 When "FICHIER"           : Gosub FICHIER
 When "INIPAR"            : Gosub INIPAR
Endcase
Return

######################################
$OUVRE
Return

######################################
$SAISIE
[M:RPT]IMPRIME = 1
OK = 0
Return

######################################
$DESTINATION
[M:RPT]IMPRIME = 1
OK = 0
Return

######################################
$EXEC
Local Integer ISEP
Local Integer ITERATOR

For ITERATOR = 1 To NBPAR
    ISEP = instr(1,[L]PARAMETRE(ITERATOR),"=")
    If ISEP
        [L]PARAM  = left$([L]PARAMETRE(ITERATOR), ISEP - 1)
        [L]VALEUR = right$([L]PARAMETRE(ITERATOR), ISEP + 1)
        Case [L]PARAM
           When "X3ETA"           : [L]ETAT = [L]VALEUR
           When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
           When "numedt"          : [L]PARAMETRE(ITERATOR) = "numedt=" + num$([L]NUMREQ)
           When "numqur"          : [L]PARAMETRE(ITERATOR) = "numqur=" + [M:MGC1]QURNUMX
           When "target"          : [L]PARAMETRE(ITERATOR) = "target=" + [M:MGC1]TGRPNLCLA
           When "sortfield"       : [L]PARAMETRE(ITERATOR) = "sortfield=" + [M:MGC1]FIESRTX
        Endcase
    Endif
Next

Return

######################################
$FIN
Return

######################################
$IMPRIMANTE
Return

######################################
$MESSAGERIE
Return

######################################
$FICHIER
Return

######################################
$INIPAR
Return

