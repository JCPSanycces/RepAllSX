#<AdxTL>@(#)1.0.0.0 $Revision$
# test 
Local Char     AXPARCOD(30)(0..10)
Local Char     AXPARVAL(30)(0..10)
Local Char     AACTION(20): AACTION="R"
Local Char     REFNUM(10) : REFNUM="7101"
Local Char    BIDCRY(30)(0..10)
Local Char    BIDNUM(30)(0..10)
Local Char    BNF(30)(0..10)
Local Char    CPYBAN(30)(0..10)
Local Char    CUR(30)(0..10)
Local Char    MODSTL(30)(0..10)
Local Char    PAB1(30)(0..10)
Local Char    PAB2(30)(0..10)
Local Char    PAB3(30)(0..10)
Local Char    PAB4(30)(0..10)
Local Integer PAYPCT(0..10)
Local Char    TYPPAY(30)(0..10)



Call OUVRE_TRACE("Test: PRHINFRIB/LECTURE") From LECFIC

AACTION="R"
Call ECR_TRACE("lecture "+REFNUM ,0) From GESECRAN
Call ACTION(AXPARCOD,AXPARVAL,AACTION,REFNUM,BIDCRY,BIDNUM,BNF,CPYBAN,CUR,MODSTL,PAB1,PAB2,PAB3,PAB4,PAYPCT,TYPPAY)


Local Integer I:I=0
For I=0 To 10
If BIDNUM(I)<>"" 
 Call ECR_TRACE("########################################################",0) From GESECRAN
 
  Call ECR_TRACE("BIDCRY(" + num$(I) + ")          =" + num$(BIDCRY(I)) ,0) From GESECRAN
  Call ECR_TRACE("BIDNUM(" + num$(I) + ")          =" + num$(BIDNUM(I)) ,0) From GESECRAN
  Call ECR_TRACE("BNF" + num$(I) + ")          =" + num$(BNF(I)) ,0) From GESECRAN
  Call ECR_TRACE("CPYBAN(" + num$(I) + ")          =" + num$(CPYBAN(I)) ,0) From GESECRAN
  Call ECR_TRACE("CUR(" + num$(I) + ")          =" + num$(CUR(I)) ,0) From GESECRAN
Call ECR_TRACE("MODSTL(" + num$(I) + ")          =" + num$(MODSTL(I)) ,0) From GESECRAN
Call ECR_TRACE("PAB1(" + num$(I) + ")          =" + num$(PAB1(I)) ,0) From GESECRAN
Call ECR_TRACE("PAB2(" + num$(I) + ")          =" + num$(PAB2(I)) ,0) From GESECRAN
Call ECR_TRACE("PAB3(" + num$(I) + ")          =" + num$(PAB3(I)) ,0) From GESECRAN
Call ECR_TRACE("PAB4(" + num$(I) + ")          =" + num$(PAB4(I)) ,0) From GESECRAN
Call ECR_TRACE("PAYPCT(" + num$(I) + ")          =" + num$(PAYPCT(I)) ,0) From GESECRAN
Call ECR_TRACE("TYPPAY(" + num$(I) + ")          =" + num$(TYPPAY(I)) ,0) From GESECRAN
Endif
Next
Call ECR_TRACE("fin lecture "+REFNUM ,0) From GESECRAN


Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End

#fin test




Subprog ACTION(AXPARCOD,AXPARVAL,AACTION,REFNUM
&                ,BIDCRY,BIDNUM,BNF,CPYBAN,CUR,MODSTL,PAB1,PAB2,PAB3,PAB4,PAYPCT
&                ,TYPPAY)
    Value    Char     AXPARCOD()()
    Value    Char     AXPARVAL()()
    Value    Char     AACTION()
    Value    Char     REFNUM()    
    Variable Char    BIDCRY()()
    Variable Char    BIDNUM()()
    Variable Char    BNF()()
    Variable Char    CPYBAN()()
    Variable Char    CUR()()
    Variable Char    MODSTL()()
    Variable Char    PAB1()()
    Variable Char    PAB2()()
    Variable Char    PAB3()()
    Variable Char    PAB4()()
    Variable Integer PAYPCT()
    Variable Char    TYPPAY()()

    
If vireblc(REFNUM,0)="" 
#ON NE FAIT RIEN

Else
    If clalev([F:RIB])=0 : Local File EMPLORIB [RIB] : Endif    

    Case AACTION
        When "R"
             Gosub ACTION_LECTURE 
        When "W"
             Gosub ACTION_ECRITURE   
         When Default
             Gosub ACTION_LECTURE 
    Endcase
    
Endif

End
  
$ACTION_LECTURE   # valeur action R
Filter  [RIB] Where REFNUM=[L]REFNUM
# si non trouvé, on affiche une erreur...
If fstat : Call ADDMESSERR(mess(18,7905,1)) From AWEB : Return: Endif
# Sinon on remplit les valeurs
# on suppose que les champs ont la même dimension..
# on parcoure les enregistrements
Local Integer I: I=0
For [RIB]
    BIDNUM (I)=[F:RIB]BIDNUM
    BIDCRY (I)=[F:RIB]BIDCRY
    BNF (I)=[F:RIB]BNF
    CPYBAN(I)=[F:RIB]CPYBAN
    CUR(I)=[F:RIB]CUR
    MODSTL(I)=[F:RIB]MODSTL
    PAB1(I)=[F:RIB]PAB1
    PAB2(I)=[F:RIB]PAB2
    PAB3(I)=[F:RIB]PAB3
    PAB4(I)=[F:RIB]PAB4
    PAYPCT(I)=[F:RIB]PAYPCT
    TYPPAY(I)=[F:RIB]TYPPAY
    I+=1
Next
Return 

$ACTION_ECRITURE   # valeur action R

# on verouille la fiche utilisateur

# verif à faire :
# valeur = BIDNUM
#ctrl iban Call IBAN(PAYS,VALEUR,[M]IBAN(nolign-1)) From TRTBPA
#ctrl rib CONTROLE_BIDNUM(VALEUR,PAYS) from submat
#ctrl répartition à faire sigma TYPPAY =100
# bidnum obligatoire si virement


If clalev([F:CHD])=0 : Local File EMPLOCHD [CHD] : Endif
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Readlock [ID]ID0 = REFNUM
# si non trouvé, on affiche une erreur...
If fstat : Call ADDMESSERR(mess(18,7905,1)) From AWEB : Return: Endif
# Sinon on remplit les valeurs
# on récupére tous les enfants..
Filter  [CHD] Where REFNUM=[L]REFNUM
If fstat : Call ADDMESSERR(mess(18,7905,1)) From AWEB : Return: Endif
    Delete [CHD] Where REFNUM=[L]REFNUM
Local Integer I:I=0
Trbegin[CHD],[ID]
For I=0 To dim(CHDNAM)
    If CHDNAM(I)="" and CHDSRN(I)="" : Break : Endif     
    [F:CHD]REFNUM=[L]REFNUM
    [F:CHD]CHDNAM=CHDNAM (I)
    [F:CHD]CHDSRN=CHDSRN (I)
    [F:CHD]CHDSEX=CHDSEX(I)
    [F:CHD]DATCHDBRN=DATCHDBRN(I)
    [F:CHD]CMT=CMT(I)
    [F:CHD]NUMLIG=I+1
    [F:CHD]CREDAT=date$
    [F:CHD]CREUSR=GUSER
    [F:CHD]CRETIM=time 
    Write [CHD]   
Next

[F:ID]NBRCHD=I
Rewrite [F:ID]
If  fstat
        Rollback
        Call ADDMESSERR("Problème lors de l'enregistrement")From AWEB
  Else
         Commit    
        # Rollback
       Call ADDMESSINF("Modifications effectuées")From AWEB
    Endif
 End




