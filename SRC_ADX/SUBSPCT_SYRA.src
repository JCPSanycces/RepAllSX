#<AdxTL>@(#)0.0.0.0 $Revision$
#------------------------------------------------------------------------
# SUBSPCT
# --- génération du traitement de recherche de ce tarif WBTxxxxxx
#------------------------------------------------------------------------
# Type de tarif : 1 = Normal / 2 = Groupé / 3 = Interdit / 4 = Composant
#------------------------------------------------------------------------
# Issue 122499 - 20170505 by LD : Grouped price list priority in a modification context

# Nota : TEX(1)=*COEFUNITE  TEX(2)=/COEFPOURN  TEX(3)=*DEVISE
#------------------------------------------------------------------------
$GEN_TRT
#--CPO
#Local Char NOMTRT(10),FICTRT(GDIMFIC),TEX(100)(0..3),INDN
Local Char NOMTRT(GLONPLI+6),FICTRT(GDIMFIC),TEX(100)(0..3),INDN
Local Integer IX, PASSAGE
Local Integer TESTUOM
Local Integer ATYOPEN, AMZOPEN, ACVOPEN, NBRCOLONNE
Local Char    FORMULEPRI (250)
Local Char    AMZ_CODTYP  (5) (0..10)   : # type donnees prix et frais/remises
Local Char    ATY_FORTYP (50) (0..10)   : # format du type de donnee

Local Char    WSPCFIL(GLONAVA) : Raz WSPCFIL :#--CPO


NOMTRT="WBT"+num$([F:SPC]PLI)+"_SY"
FICTRT=filpath("TRT",NOMTRT,"src",APPLI)

If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : ATYOPEN=1 : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : AMZOPEN=1 : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : ACVOPEN=1 : Endif

# Issue 121760 - 2017-03-24 by SR : Retrieving the dimension of SPR data type
Local Shortint WLONSPR
Read [ATY] CODTYP="SPR"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=2 : Endif
WLONSPR=[F:ATY]LNGTYP
# End issue 121760

#--- Recherche du nombre de colonnes actives dans le code activite SPR
Read [ACV]CODACT="SPR"
NBRCOLONNE=[F:ACV]DIME
If fstat : NBRCOLONNE=0 : Endif
If ACVOPEN=1 : Close Local File [ACV] : Endif

#--- Recherche du type de donnee et du format du prix et colonnes frais/remise
#-   type de donnee par defaut MD5
#-   on prend en priorite le format defini dans ecran
For IX=0 To dim(AMZ_CODTYP)-1 : AMZ_CODTYP(IX)="MD5" : Next IX
#-   type de donnee du prix
Read [AMZ]CODE="WB1"+num$([F:SPC]PLI)+"1";"PRI"
If !fstat
   AMZ_CODTYP(0)=[F:AMZ]CODTYP
   If [F:AMZ]LONG>0 : ATY_FORTYP(0)=num$([F:AMZ]LONG) : Endif
Endif
#-   type de donnee frais/remises
For IX=1 To 9
    Read [AMZ]CODE="WB1"+num$([F:SPC]PLI)+"1";"XFRAREM"+num$(IX)
    If !fstat
       AMZ_CODTYP(IX)=[F:AMZ]CODTYP
       If [F:AMZ]LONG>0 : ATY_FORTYP(IX)=num$([F:AMZ]LONG) : Endif
    Endif
Next IX
#-   stockage du format (ou de la variable contenant le format)
For IX=0 To dim(AMZ_CODTYP)-1
    If ATY_FORTYP(IX)=""
       Read [ATY] CODTYP=AMZ_CODTYP(IX)
       If !fstat : ATY_FORTYP(IX)=[F:ATY]FORTYP : Else : ATY_FORTYP(IX)="12.4#" : Endif
       If instr(1,ATY_FORTYP(IX),"GDEVFMT") : ATY_FORTYP(IX)="=[F:TCU]CURFMT1" : Endif
    Endif
Next IX

Openo FICTRT,0
adxifs=""
adxirs=chr$(10)
Wrseq "#<AdxT"+GADOVERS+">@(#)%|%","Gén.traitement tarif "+[F:SPC]PLI
Wrseq "#-----------------------------------------------------------------"
Wrseq "# WBT";[F:SPC]PLI;"_SY                                            ";format$(GFMD,date$)
Wrseq "#-----------------------------------------------------------------"
#Wrseq "Subprog TARIF(TRAIT,DAT,QTY,UOM,CHGTYP,CUR,PRITYP,VAT,"
#Wrseq "&             PIO,PARAM_T,MONTANT,MOTIF,PRIORITE,PLI,PLICRD,PLILIN,"
#Wrseq "&             FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,"
#Wrseq "&             PLISTRDAT,PLIENDDAT,INTERDIT)"
Wrseq "Subprog TARIF(PARAM,PLINEDOC, RESULT, WERR, WMESSAGE)"
Wrseq "Value    Instance PARAM  Using  C_SFINDPRICE   : # instance des paramètres en entrée de recherche tarif"
Wrseq "Value    Integer  PLINEDOC                     : # no ligne courante (C_LINE associé à la ligne courante)"
Wrseq "Variable Instance RESULT Using  C_RESULTPRICE  : # instance des paramètres en sortie de recherche tarif"
Wrseq "Variable Integer  WERR                         : # si erreur => positionné avec [V]CST_Axxx selon erreur"
Wrseq "Variable Char     WMESSAGE()                   : # le contenu du message"

Wrseq ""
Wrseq "If PLINEDOC < 1 : End : Endif : # Pas la peine d'aller plus loin.."
Wrseq ""
Wrseq "If PARAM.C_LINE(PLINEDOC) = null : End : Endif : # Pas la peine d'aller plus loin.."
#--CPO ajout => infos concernant PARAM_T
# PARAM_T(0) => PARAM.C_LINE().SAUSTUCOE
# PARAM_T(1) => PARAM.VACBPR
# PARAM_T(2) => PARAM.MLTDIVCOE
# PARAM_T(3) => PARAM.VATCLCDAT
#--/
Wrseq "Local    Char     CODENTPNT (3)      : # Code point entree"
#--CPO ajout
Wrseq "Local    Integer WLINE"
Wrseq "Local    Integer WBIDI               : # Remplacer l'ancienne GBIDI3"
Wrseq "Local    Decimal WBIDD               : # Remplacer l'ancienne GBIDD3"
Wrseq "Local    Char    WBPAADD(GLONADR)    : # adresse à entête ou ligne"
Wrseq "Local    Char    WSTOFCY(GLONFCY)    : # site    à entête ou ligne"
#--/
Case [F:SPC]PLITYP
  When 1,4
             Wrseq "#--CPO Afin de séparer le prix net des frais/remises et des commisions"
             Wrseq "#Local    Shortint TACHE (0..11)      : # traitements a effectuer ?"
             Wrseq "#--DOTASK_PRICE          => TACHE(0)"
             Wrseq "#--DOTASK_DISCRG   (1..) => TACHE(1-9)"
             Wrseq "#--DOTASK_REPCOE         => TACHE(10)"
             Wrseq "#--DOTASK_FOC            => TACHE(11)"
             Wrseq "Local    Shortint DOTASK_PRICE               : # traitements prix a effectuer ?"
             Wrseq "Local    Shortint DOTASK_DISCRG   (1..)      : # traitements frais/remises a effectuer ?"
             Wrseq "Local    Shortint DOTASK_REPCOE              : # traitements commisions représentants a effectuer ?"
             Wrseq "Local    Shortint DOTASK_FOC                 : # traitements des gratuits a effectuer ?"
Endcase
# Issue 121760 - 2017-03-27 by SR : Dimension XPRIREN according to SPR data type
Case [F:SPC]PLITYP
  When 1,2,4 Wrseq "local    Char     XPRIREN ("+num$(WLONSPR)+")"  : # recup. motif"
             #Wrseq "Local    Char     XPRIREN (2)        : # recup. motif"
             Wrseq "Local    Integer  WPRIREN            : # recup. motif"
             Wrseq "Local    Char     XPRITYP (1)        : # recup. type prix"
             Wrseq "Local    Integer  WPRITYP            : # recup. type prix"
             Wrseq "Local    Integer  WMODULE            : # module"
             Wrseq "Local    Char     WPLI    (10)       : # code tarif"
             Wrseq "Local    Decimal  COEFDEVISE         : # coef.conv. devise"
             Wrseq "Local    Decimal  COEFUNITE (2)      : # coef.conv. unite"
             Wrseq "                                       # (0) coef.utilisé pour recherche tarif"
             Wrseq "                                       # (1) coef. UV --> US saisi"
             Wrseq "Local    Decimal  COEFPOURN          : # coef. si tarif pour n"
             Wrseq "Local    Decimal  WFOCQTYMIN         : # calcul gratuits : tranche qte"
             Wrseq "Local    Decimal  WFOCQTYBKT         : # calcul gratuits : tranche qte"
             Wrseq "Local    Decimal  WFOCAMTMIN         : # calcul gratuits : tranche prix"
             Wrseq "Local    Decimal  WFOCAMTBKT         : # calcul gratuits : tranche prix"
             Wrseq "Local    Integer  WRET               : # Code retour"
             Wrseq "Local    Decimal  CLCAMT1            : # Montant1 pour taxe suivant formule"
             Wrseq "Local    Decimal  CLCAMT2            : # Montant2 pour taxe suivant formule"
             Wrseq "Local    Char     APDC_CUR (5)       : # Arrondi : Code devise"
             Wrseq "Local    Char     APDC_FMT (50)      : # Arrondi : Format sous forme 12.4#"
             Wrseq "Local    Decimal  APDC_RND           : # Arrondi : Code arrondi pour instruction arr"
             Wrseq "Local    Date     DATCONVPRI         : # Bug 84596 : Date utilisée pour le calcul des taxes (prix HT/TTC)"
Endcase
Case [F:SPC]PLITYP
  When 2     Wrseq "Local    Shortint SELGRP (0..maxtab(PARAM.C_LINE)) : # flag sélection de la ligne"
             Wrseq "Local    Shortint UPDGRP (0..maxtab(PARAM.C_LINE)) : # flag maj ligne par ce tarif"
             Wrseq "Local    Shortint NLD                : # = nolign boucle primaire (A)"
             Wrseq "Local    Shortint NLG                : # = nolign boucle secondaire (B)"
             Wrseq "                                       #   (recherche lignes de meme criteres que NLD)"
             Wrseq "Local    Char     FOCUPDTST (50) (1..maxtab(RESULT.C_FOC)) : # pour m.a.j. des gratuits "
             #--CPO => plus besoin car la classe des paramètres contient un tableau de paramètres déjà chargés liés à chaque ligne
             #Wrseq "Local    Integer  SAVNOLIGN          : # sauvegarde de nolign"
             Wrseq "Local    Decimal  CUMQTY             : # cumul qté des lignes"
             Wrseq "Local    Decimal  CONVQTY            : # qté après les coeff"
             Wrseq "Local    Decimal  CUMAMT             : # cumul mt des lignes"
             Wrseq "Local    Decimal  CONVPRI            : # prix après coeff"
             Wrseq "Local    Char     WCRIT (GLONSPX)    : # concaténation critères"
             #Wrseq "Local    Char     WBPAADD            : # adresse à entête ou ligne"
             Wrseq "Local    Integer  UPDNULPRI          : # groupes : flag modif prix nul"
Endcase
If [F:SPC]PLITYP=2
  Wrseq "#If dim(GSPLXGRP)<0 : Global Shortint GSPLXGRP : Endif"
  Wrseq "UPDNULPRI="+num$([F:SPC]UPDNULPRI)
Endif
Case [F:SPC]PLITYP
  When 1,2,4 Wrseq "#           initialisations"
             Wrseq "XPRIREN='"+num$([F:SPC]PRIREN)+"' : WPRIREN=val(XPRIREN)"
             Wrseq "XPRITYP='"+num$([F:SPC]PRITYP)+"' : WPRITYP=val(XPRITYP)"
             Wrseq "WMODULE=5                            : # Module Ventes"
             Wrseq "WPLI='"+[F:SPC]PLI+"'"
             Wrseq "COEFDEVISE=1 : COEFUNITE=1 : COEFPOURN=1"
             #--CPO
             #Wrseq "If PARAM_T(3)<>'' [L]DATCONVPRI=PARAM_T(3) Else [L]DATCONVPRI=PARAM.DOCDAT Endif : # Bug 84596 : Date utilisée pour le calcul des taxes (prix HT/TTC) "
             Wrseq "If PARAM.VATCLCDAT<>[0/0/0] [L]DATCONVPRI=PARAM.VATCLCDAT Else [L]DATCONVPRI=PARAM.DOCDAT Endif : # Bug 84596 : Date utilisée pour le calcul des taxes (prix HT/TTC) "
             #--/
Endcase
Wrseq "RESULT.INTERDIT=0"
Wrseq "# Pour test d'application de la recherche"
#--CPO ajout
Wrseq "Local File ITMMASTER [ITM]"
Wrseq "Local File TABCUR    [TCU]"
Wrseq ""
Wrseq "Read [F:ITM]ITM0=PARAM.C_LINE(PLINEDOC).ITMREF"
Wrseq "If fstat : Raz [F:ITM] : End :Endif"
Wrseq ""
#--/
Wrseq "If dim([F:ITM]SALFLG(0)) < 0 : End : Endif"
If [F:SPC]PLITYP=1
    Wrseq "# Application de la recherche uniquement sur les articles vendus"
    Wrseq "If [F:ITM]SALFLG<>2 : End : Endif"
    Wrseq "# L'application de la recherche ne se fait pas sur les articles sous-traités"
    Wrseq "#If find(PARAM.C_LINE().C_SPKD(1).LINTYP,10) : End : Endif"
    Wrseq "If PARAM.C_LINE(PLINEDOC) <> null and PARAM.C_LINE(PLINEDOC).C_SPKD(1) <> null"
    Wrseq "  If find(PARAM.C_LINE(PLINEDOC).C_SPKD(1).LINTYP,10) : End : Endif"
    Wrseq "Endif"
    Wrseq "#For I = 1 To maxtab(PARAM.C_LINE)"
    Wrseq "#  If PARAM.C_LINE(I)<>null and find(PARAM.C_LINE(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)<1"
    Wrseq "#    If find(10, PARAM.C_LINE(I).C_SPKD(1..maxtab(PARAM.C_LINE(I).C_SPKD)).LINTYP )"
    Wrseq "#     End"
    Wrseq "#   Endif"
    Wrseq "#  Endif"
    Wrseq "#Next I"
Endif
Wrseq "#--Ouverture et chargement systématique de SPRICLINK"
Wrseq "#--Utilisé surtout pour les formules..."
Wrseq "Local File SPRICLINK [SPK]" :#--CPO 98525 Priority in price search (added [SPK] named buffer)
Wrseq "#--Transclasse [F:SPK] with PARAM.C_SPKH(1) et PARAM.C_LINE(NLD).C_SPKD(1)"
Wrseq "If PARAM.C_SPKH(1)<>null"
Wrseq "  WERR = fmet PARAM.C_SPKH(1).LOAD_TO_SPK_FILE()"
Wrseq "  If WERR >= [V]CST_AERROR"
Wrseq "    [L]WERR = fmet PARAM.ASETERROR('', mess(68,123,1)-':'-mess(1,7845,1)-'LOAD_TO_SPK_FILE', WERR)"
Wrseq "  Endif"
Wrseq "Endif"
Wrseq "If PARAM.C_LINE(PLINEDOC).C_SPKD(1)<>null"
Wrseq "  WERR = fmet PARAM.C_LINE(PLINEDOC).C_SPKD(1).LOAD_TO_SPK_FILE()"
Wrseq "  If WERR >= [V]CST_AERROR"
Wrseq "    [L]WERR = fmet PARAM.ASETERROR('', mess(68,123,1)-':'-mess(1,7845,1)-'LOAD_TO_SPK_FILE', WERR)"
Wrseq "  Endif"
Wrseq "Endif"
Wrseq ""
Wrseq "# Les critères existent ?"

If [F:SPC]ABB(0)<>""
  If find([F:SPC]FIL(0),"SPRICLINK","ITMMASTER")<1
    Wrseq "Local File ";[F:SPC]FIL(0);" [";[F:SPC]ABB(0);"]"
  Endif
  WSPCFIL = [F:SPC]FIL(0)
  Gosub READFIL
Endif
For I=1 To 4
  If [F:SPC]ABB(I)<>""
    #--CPO Il faut également ouvrir les autres tables utilisées dans le paramètrage...
    #--Attention à ne pas essayer d'ouvrir 2x la même sir présente sur plusieures lignes du paramètrage
    If !find([F:SPC]FIL(I),[F:SPC]FIL(0..I-1)) and find([F:SPC]FIL(I),"SPRICLINK","ITMMASTER")<1
      Wrseq "Local File ";[F:SPC]FIL(I);" [";[F:SPC]ABB(I);"]"
      WSPCFIL = [F:SPC]FIL(I)
      Gosub READFIL
    Endif
    #--/
    Wrseq "If dim([F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(";[F:SPC]CRIIND(I);")) < 0 : End : Endif"
  Endif
Next I

Wrseq ""
Wrseq "# Application des tarifs Hors groupe / Groupe"
Wrseq "If PARAM.C_LINE(PLINEDOC) <> null and PARAM.C_LINE(PLINEDOC).C_SPKD(1) <> null"
Wrseq "  # Si PARAM.C_LINE().C_SPKH(1).PLIBPRCNR=3 application de tous les tarifs (Hors groupe et Groupe)"
Wrseq "  If dim(PARAM.C_LINE(PLINEDOC).C_SPKH(1).PLIBPRCNR)<=0 | PARAM.C_LINE(PLINEDOC).C_SPKH(1).PLIBPRCNR<>3"
Wrseq "    # Application des tarifs Hors groupe ou Groupe en fonction des flags intersociété et intersite"
Wrseq "    # Tarif concernant les tiers ( ";
Wrseq mess([F:SPC]PLIBPRCNR,2210,1);
Wrseq " )"
Wrseq "    If PARAM.C_SPKH(1) <> null"
If find([F:SPC]PLIBPRCNR,1,2)
   Wrseq "      If dim(PARAM.C_SPKH(1).BETCPY)>0 & dim(PARAM.C_SPKH(1).BETFCY)>0"
   If [F:SPC]PLIBPRCNR=1
      Wrseq "        If PARAM.C_SPKH(1).BETCPY=2 | PARAM.C_SPKH(1).BETFCY=2 : End : Endif"
   Endif
   If [F:SPC]PLIBPRCNR=2
      Wrseq "        If PARAM.C_SPKH(1).BETCPY<>2 & PARAM.C_SPKH(1).BETFCY<>2 : End : Endif"
   Endif
   Wrseq "      Endif"
Endif
Wrseq "    Endif"
Wrseq "  Endif"
Wrseq "Endif"
Wrseq ""
Wrseq "# Faut-il ouvrir le fichier tarif ?"
Wrseq "Local File SPRICLIST [SPL]"

If [F:SPC]PRIPRO=4 | [F:SPC]PRIPRO=5
Wrseq "# Prix par coeff. ou calcul : ouverture autres fichers"
Wrseq "#Local File SPRICLINK [SPK]"
Wrseq "#"
Wrseq "##--Transclasse [F:SPK] with PARAM.C_SPKH(1) et PARAM.C_LINE(PLINEDOC).C_SPKD(1)"
Wrseq "#If PARAM.C_SPKH(1)<>null"
Wrseq "#  SetInstance [F:SPK] With PARAM.C_SPKH(1)"
Wrseq "#Endif"
Wrseq "#If PARAM.C_LINE(PLINEDOC).C_SPKD(1)<>null"
Wrseq "#  SetInstance [F:SPK] With PARAM.C_LINE(PLINEDOC).C_SPKD(1)"
Wrseq "#Endif"
Wrseq ""
Wrseq "Local File ITMMVT [ITV]"
Wrseq "#Local File ITMSALES [ITS]"
Wrseq "Local File ITMCOST [ITC]"
Endif

Wrseq ""
Wrseq "#If PLI(0)='*SIMU*'    : # Pour simulation chgt toutes les lignes utilisable"
Wrseq "If PARAM.PLI(1)<>null and PARAM.PLI(1).PLI ='*SIMU*'    : # Pour simulation chgt toutes les lignes utilisable"
Wrseq "  Gosub CONSULTATION"
Wrseq "  End"
Wrseq "Endif"
Wrseq ""

Case [F:SPC]PLITYP
  When 1 : Gosub TR_NORMAL   : # Tarif normal
  When 2 : Gosub TR_GROUPE   : # Tarif groupe
  When 3 : Gosub TR_INTERDIT : # Tarif interdit
  When 4 : Gosub TR_NORMAL   : # Tarif composant (idem normal)
Endcase
Wrseq "#-----------------------------------------------------------------"

# Génération du traitement à la ligne du tarif groupe
If [F:SPC]PLITYP=2 : Gosub TR_GRPLIG : Endif
# Génération traitement erreur si prix par coefficient
If [F:SPC]PRIPRO=4 | [F:SPC]PRIPRO=5
  Wrseq ""
  Wrseq "$ERR_PRI"
  #Wrseq "GERR=2"
  Wrseq "WERR=[V]CST_AERROR"
  Wrseq "WMESSAGE = mess(15,197,1)+': '+[F:SPL]PLI+'  '+";
  If [F:SPC]PRIPRO=4
    Wrseq "mess(16,197,1)+'\'+";
  Endif
  If [F:SPC]PRIPRO=5
    Wrseq "mess(17,197,1)+'\'+";
  Endif
  Wrseq "mess(65,106,1)"
  If [F:SPC]PRIPRO=4
    Wrseq "[F:SPL]PRI=0"
  Endif
  If [F:SPC]PRIPRO=5
    Wrseq "CONVPRI=0"
  Endif
  Wrseq "Resume"
Endif

Gosub FORMAT_ARRONDI    : # constitution de l'arrondi pour l'instruction arr
Gosub TYPE_CRITERES     : # Saisie des tarif : savoir si type de donnée interne est alpha ou num
Gosub FILTRE_CRITERES   : # consultation tarif : filtre complementaire des lignes d'une fiche
Gosub CONSULTATION      : # consultation tarif
Gosub INI_IMPORT        : # traitement d'init de la classe F lors de l'import

Openo

# Validation du traitement généré
#  Call VALID(NOMTRT,APPLI) From GRVALMSK2
  Call VALID("TRT", NOMTRT,APPLI,OK) From VALMSKSUB
  If OK=0 GOK=0 : Endif

#--- Fermeture
If ATYOPEN=1 : Close Local File [ATY] : Endif
If AMZOPEN=1 : Close Local File [AMZ] : Endif

Return

#------------------------------------------------------------------------
# Génération de l'instruction Filter (suivant critères et conditions)
#------------------------------------------------------------------------
$LE_FILTRE

Wrseq ""
#--CPO Problème des Points d'entrée
Wrseq "#CODENTPNT='T01_SY' : Gosub PE_TARIFS From TRTPRICE_SYRA"
#--/
Wrseq ""

Wrseq "# Lecture des tarifs"
Wrseq "Filter [SPL] Where PLI='"+[F:SPC]PLI+"'"
Wrseq "&  & PLICRI=";
For I=0 To 4
  If I>0 : Wrseq "+"; : Endif
  If [F:SPC]FLD(I)<>""
     If [F:SPC]FLDTYP(I)="CCE"
        Wrseq "num$([F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(max(find('";[F:SPC]CRIDIE(I);"',[F:";[F:SPC]ABB(I);"]DIE)-1,0)))+'~'";
     Elsif [F:SPC]FLDTYP(I)="D"   : # si critere de type date
        Wrseq "num$(val([F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(";[F:SPC]CRIIND(I);")))+'~'";
     Else                     : # autres types
        Wrseq "num$([F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(";[F:SPC]CRIIND(I);"))+'~'";
     Endif
  Else
     Wrseq "'~'";
  Endif
Next
Wrseq
#--CPO ajout [F:SPL] devant PLISTRDAT et PLIENDDAT => afin de ne pas confondre
#--CPO 98525 Priority in price search (no [F:SPL])
#Wrseq "&  & PARAM.DOCDAT>=[F:SPL]PLISTRDAT & PARAM.DOCDAT<=[F:SPL]PLIENDDAT"
Wrseq "&  & PARAM.DOCDAT>=PLISTRDAT & PARAM.DOCDAT<=PLIENDDAT"
#--/
If ([F:SPC]UOMCNVFLG=1 & ZZ(8)=1) | [F:SPC]CRIUOMNUM<>0
  Wrseq "&  & UOM=PARAM.C_LINE(PLINEDOC).SAU"
  If ZZ(9)=1
    Wrseq "&  & PARAM.C_LINE(PLINEDOC).QTY>=MINQTY & PARAM.C_LINE(PLINEDOC).QTY<=MAXQTY"
  Endif
Endif
If [F:SPC]CURCNVFLG=1 & SAISIEDEV=1
  Wrseq "&  & CUR=PARAM.CUR"
Endif
Wrseq "&    Order by Key SPL1"
Return

#------------------------------------------------------------------------
# Tarif normal : génération du traitement (utilisé pour composants)
#------------------------------------------------------------------------
$TR_NORMAL
If [F:SPC]ATICNVFLG=1
  Wrseq "# Si le tarif n'est pas bon (HT/TTC), on s'arrête"
  Wrseq "If PARAM.PRITYP<>WPRITYP : End : Endif"
Endif

Wrseq "# On teste le remplissage effectue"
Wrseq "#Raz TACHE"
Wrseq "Raz DOTASK_PRICE"
Wrseq "Raz DOTASK_DISCRG"
Wrseq "Raz DOTASK_REPCOE"
Wrseq "Raz DOTASK_FOC"
# Prix
If [F:SPC]PRIPRO>1
  Wrseq "DOTASK_PRICE=(RESULT.C_PRICE(1).MOTIF=0 | RESULT.C_PRICE(1).PRIORITE=PARAM.PIO)"
Endif

# Remises
For I=0 To NBRCOLONNE-1
  If find([F:SPC]DISCRGPRO(I),1,3)
    INDN=num$(I+1)
    Wrseq "If RESULT.C_DISCRG("+INDN+")<>null"
    Wrseq "  DOTASK_DISCRG("+INDN+")=(RESULT.C_DISCRG("+INDN+").MOTIF=0 | RESULT.C_DISCRG("+INDN+").PRIORITE=PARAM.PIO)"
    Wrseq "Endif"
  Endif
Next I

# Coeff comm
If [F:SPC]COMPRO=1 | [F:SPC]COMPRO=3
  Wrseq "DOTASK_REPCOE=(RESULT.C_REPCOE(1).MOTIF=0 | RESULT.C_REPCOE(1).PRIORITE=PARAM.PIO)"
Endif

# Gratuits
If [F:SPC]FOCPRO=2 | [F:SPC]FOCPRO=3
#--CPO ajout
Wrseq "If RESULT.C_FOC(1)=null"
Wrseq "  WLINE = fmet RESULT.ADDLINE('C_FOC',1)"
Wrseq "  If WLINE = [V]CST_ANOTDEFINED"
Wrseq "    #--The insertion was not possible"
Wrseq "    [L]WERR = fmet RESULT.ASETERROR('', func ASYRFNC.MES2(mess(266,133,1),'C_FOC','RESULTPRICE'), [V]CST_AERROR)"
Wrseq "    End"
Wrseq "  Endif"
Wrseq "Endif"
#--/
Wrseq "DOTASK_FOC=(RESULT.C_FOC(1).FOCQTY=0)"
Endif

Wrseq "# Toutes les colonnes sont garnies ?"
Wrseq "#If sum(TACHE)=0 : End : Endif"
Wrseq "IF DOTASK_PRICE+sum(DOTASK_DISCRG)+DOTASK_REPCOE+DOTASK_FOC=0 : End : Endif"
# Le filtre
Gosub LE_FILTRE

# La boucle des enregistrements lus
Wrseq "If PARAM.C_LINE(PLINEDOC)=null or PARAM.C_LINE(PLINEDOC).C_SPKD(1)=null : Filter [F:SPL] : End : Endif"
Wrseq "For [SPL]"
Wrseq "  COEFUNITE=1 : COEFPOURN=1 : COEFDEVISE=1"
Wrseq "  If [F:SPL]UOM='*' : [F:SPL]UOM=[F:ITM]SAU : Endif"
Wrseq "  WFOCQTYMIN=[F:SPL]FOCQTYMIN"
Wrseq "  WFOCQTYBKT=[F:SPL]FOCQTYBKT"

# On détermine le conversions (unite/devise/pour n)
Raz TEX
ICONV=0
If [F:SPC]PRIPRO=3
  Wrseq "# Prix pour N articles"
  Wrseq "  If [F:SPL]PRIDIV<>0 : COEFPOURN=[F:SPL]PRIDIV : Endif"
  TEX(2)="/COEFPOURN" : ICONV=1
Endif
If [F:SPC]UOMCNVFLG=2
  Wrseq "# Conversion qte mini maxi (pas d'arrondi)"
  Wrseq "  If [F:SPL]UOM<>PARAM.C_LINE(PLINEDOC).SAU"
  #--CPO
  #Wrseq "    COEFUNITE(1)=val(PARAM_T(0))"
  Wrseq "    COEFUNITE(1) = PARAM.C_LINE(PLINEDOC).SAUSTUCOE"
  Wrseq "    Call SREC_COE ([F:ITM]ITMREF,[F:BPC]BPCNUM,[F:SPL]UOM,PARAM.C_LINE(PLINEDOC).SAU,COEFUNITE) From TRTVENQTE_SYRA"
  Wrseq "    If COEFUNITE=0 : Goto TAR_SUIVANT : Endif"
  Wrseq "    [F:SPL]MINQTY=[F:SPL]MINQTY/COEFUNITE"
  Wrseq "    [F:SPL]MAXQTY=[F:SPL]MAXQTY/COEFUNITE"
  If [F:SPC]FOCPRO>1
    Wrseq "# Tarif normal mini et seuil toujours en qte"
    Wrseq "# Conversion conditions gratuité (pas d'arrondi)"
    Wrseq "    [F:SPL]FOCQTYMIN=[F:SPL]FOCQTYMIN/COEFUNITE"
    Wrseq "    [F:SPL]FOCQTYBKT=[F:SPL]FOCQTYBKT/COEFUNITE"
  Endif
  If [F:SPC]FOCPRO=2
    Wrseq "# Conversion qte gratuite sur le meme article (arrondi)"
    Wrseq "    [F:SPL]FOCQTY=[F:SPL]FOCQTY/COEFUNITE"
    Wrseq "    Call QTEARR ([F:SPL]FOCQTY,PARAM.C_LINE(PLINEDOC).SAU) From TRTDIV_SYRA"
  Endif
  TEX(1)="*COEFUNITE" : ICONV=1
Wrseq "  Endif"
  If ZZ(9)=1
    Wrseq "  If [F:SPL]MINQTY>PARAM.C_LINE(PLINEDOC).QTY | [F:SPL]MAXQTY<PARAM.C_LINE(PLINEDOC).QTY : Goto TAR_SUIVANT : Endif"
  Endif
Endif

If [F:SPC]CURCNVFLG=2
# Bug 60443
  Wrseq "# Conversion devise"
  Wrseq "  If [F:SPL]CUR<>PARAM.CUR"
  #--CPO
  #Wrseq "      If [F:SPL]CUR<>PARAM.CUR & [F:SPL]CUR=GLOCALDEV & val(PARAM_T(2))<>0"
  Wrseq "      If [F:SPL]CUR<>PARAM.CUR & [F:SPL]CUR=PARAM.GLOCALDEV & PARAM.MLTDIVCOE<>0"
  #Wrseq "          COEFDEVISE=val(PARAM_T(2))"
  Wrseq "          COEFDEVISE=PARAM.MLTDIVCOE"
  #--/
  Wrseq "      Else"
  Wrseq "          Call CONVERT(PARAM.ACTX,[F:SPL]CUR,PARAM.CUR,PARAM.GLOCALDEV,PARAM.CHGTYP,PARAM.DOCDAT,1000000000000.00,COEFDEVISE,WBIDI) From TRTDEV_SYRA"
  Wrseq "          If WBIDI=0 & COEFDEVISE<>0 COEFDEVISE=COEFDEVISE/1000000000000.00 Else COEFDEVISE=1 Endif"
  Wrseq "      Endif"
  Wrseq "  Endif"
# Bug 60443
  TEX(3)="*COEFDEVISE" : ICONV=1
Endif

# On traite la colonne prix
If [F:SPC]PRIPRO>1
Wrseq "  If DOTASK_PRICE"
  If [F:SPC]PRIPRO=4 | [F:SPC]PRIPRO=5
Wrseq "# Prix par coeff. ou calcul : lecture ITS et ITV"
Wrseq "#   Articles-Ventes ITMSALES"
Wrseq "If [F:ITS]ITMREF<>[F:ITM]ITMREF"
Wrseq "  Read [ITS]ITS0 = [F:ITM]ITMREF"
Wrseq "  If fstat : Raz [F:ITS] : Endif"
Wrseq "Endif"
Wrseq "#   Cumuls Mouvements Articles-Sites ITMMVT"
Wrseq "If [F:ITV]ITMREF<>[F:ITM]ITMREF | [F:ITV]STOFCY<>PARAM.C_LINE(PLINEDOC).C_SPKD(1).STOFCY"
Wrseq "  Read [ITV]ITV0 = [F:ITM]ITMREF; PARAM.C_LINE(PLINEDOC).C_SPKD(1).STOFCY"
Wrseq "  If fstat : Raz [F:ITV] : Endif"
Wrseq "Endif"
Wrseq "#   Articles-Couts ITMCOST"
Wrseq "#   ( utilisation de GETPRI pour delivrer le bon enregistrement [F:ITC] )"
Wrseq "Local Integer CSTTYP : CSTTYP=1 : # Prix standard par defaut"
Wrseq "If dim(PARAM.C_LINE(PLINEDOC).C_SPKD(1).CSTTYP)>0"
Wrseq "   If find(PARAM.C_LINE(PLINEDOC).C_SPKD(1).CSTTYP,1,2,99) : [L]CSTTYP=PARAM.C_LINE(PLINEDOC).C_SPKD(1).CSTTYP    : Endif"
Wrseq "   If find(PARAM.C_LINE(PLINEDOC).C_SPKD(1).CSTTYP,3,4)    : [L]CSTTYP=PARAM.C_LINE(PLINEDOC).C_SPKD(1).CSTTYP*-1 : Endif"
Wrseq "Endif"
Wrseq "If [L]CSTTYP=99"
Wrseq "   Raz [F:ITC]"
Wrseq " Else"
Wrseq "   If [F:ITC]STOFCY<>PARAM.C_LINE(PLINEDOC).C_SPKD(1).STOFCY | [F:ITC]ITMREF<>[F:ITM]ITMREF |"
# FQ 53431 GA 03/2009 ITCSTRDAT : Variable inexistante
Wrseq "&     [F:ITC]CSTTYP<>[L]CSTTYP| [F:ITC]ITCSTRDAT>PARAM.DOCDAT | PARAM.DOCDAT>[F:ITC]ITCENDDAT"
Wrseq "       Raz [F:ITC]"
# 105605 : CCM - Revision index
#Wrseq "       Call GETPRI([F:ITM]ITMREF,PARAM.C_LINE(PLINEDOC).C_SPKD(1).STOFCY,PARAM.DOCDAT,1,'','',[L]CSTTYP,WBIDD,WRET) From STKVAL_SYRA"
Wrseq "       If dim(PARAM.C_LINE(PLINEDOC).C_SPKD(1).ECCVALMAJ)>0"
Wrseq "           Call GETPRI([F:ITM]ITMREF,PARAM.C_LINE(PLINEDOC).C_SPKD(1).ECCVALMAJ,PARAM.C_LINE(PLINEDOC).C_SPKD(1).ECCVALMIN,PARAM.C_LINE(PLINEDOC).C_SPKD(1).STOFCY,PARAM.DOCDAT,1,'','',[L]CSTTY"
&  + "P,WBIDD,WRET) From STKVAL_SYRA"
Wrseq "       Else"
Wrseq "           Call GETPRI([F:ITM]ITMREF,'','',PARAM.C_LINE(PLINEDOC).C_SPKD(1).STOFCY,PARAM.DOCDAT,1,'','',[L]CSTTYP,WBIDD,WRET) From STKVAL_SYRA"
Wrseq "       Endif"
# 105605
Wrseq "   Endif"
Wrseq "Endif"
  Endif
  If [F:SPC]PRIPRO=4
       FORMULEPRI=format$("KTv1:250X",[F:SPC]PRIFLD)
Wrseq "# Prix par coefficient"
Wrseq "    Onerrgo ERR_PRI"
Wrseq "    [F:SPL]PRI=[F:SPL]PRI*(";FORMULEPRI;")"
Wrseq "    Onerrgo"
  Endif
  If [F:SPC]PRIPRO=5
       FORMULEPRI=format$("KTv1:250X",[F:SPC]PRIFLD)
Wrseq "# Prix par formule"
Wrseq "    Onerrgo ERR_PRI"
Wrseq "    [F:SPL]PRI=(";FORMULEPRI;")"
Wrseq "    Onerrgo"
  Endif
  If ICONV<> 0
Wrseq "    [F:SPL]PRI=[F:SPL]PRI";TEX(1);TEX(2);TEX(3)
  Endif
  If [F:SPC]ATICNVFLG<>1
Wrseq "# Possibilité conversion ht/ttc"
Wrseq "    If PARAM.PRITYP<>WPRITYP"
Wrseq "      Raz CLCAMT1, CLCAMT2"
Wrseq "      If dim(PARAM.C_LINE(PLINEDOC).C_SPKD(1).CLCAMT1)>0 : CLCAMT1=PARAM.C_LINE(PLINEDOC).C_SPKD(1).CLCAMT1 : Endif"
Wrseq "      If dim(PARAM.C_LINE(PLINEDOC).C_SPKD(1).CLCAMT2)>0 : CLCAMT2=PARAM.C_LINE(PLINEDOC).C_SPKD(1).CLCAMT2 : Endif"
Wrseq ""
Wrseq "#      Local Integer ICPO"
Wrseq "#      Local Char WVAT(GLONVAT)(1..), WVAT_LEG(GLONADI)(1..)"
Wrseq "#      For ICPO=1 To maxtab(PARAM.C_LINE(PLINEDOC).C_VAT)"
Wrseq "#        If PARAM.C_LINE(PLINEDOC).C_VAT(ICPO)<>null"
Wrseq "#          WVAT(ICPO)     = PARAM.C_LINE(PLINEDOC).C_VAT(ICPO).VAT"
Wrseq "#          WVAT_LEG(ICPO) = PARAM.C_LINE(PLINEDOC).C_VAT(ICPO).VAT_LEG"
Wrseq "#        Else"
Wrseq "#          WVAT(ICPO)     = ''"
Wrseq "#          WVAT_LEG(ICPO) = ''"
Wrseq "#        Endif"
Wrseq "#      Next ICPO"
Wrseq "#"
Wrseq "#      Call CLCTAXEPRIV (PARAM.ACTX, [F:SPL]PRI,WVAT,WVAT_LEG"
Wrseq "#&             ,WPRITYP,PARAM.CPY,DATCONVPRI,PARAM.C_LINE(PLINEDOC).QTY,PARAM.VACBPR,PARAM.VACBPR_LEG,CLCAMT1,CLCAMT2,[F:SPL]PRI) From TRTX3_SYRA  : # Bug 84596"
Wrseq "#      Call CLCTAXEPRIV (PARAM.ACTX, [F:SPL]PRI,PARAM.C_LINE(PLINEDOC).C_VAT(1..maxtab(PARAM.C_LINE(PLINEDOC).C_VAT)).VAT,PARAM.C_LINE(PLINEDOC).C_VAT(1..maxtab(PARAM.C_LINE(PLINEDOC).C_VAT))."
&  + "VAT_LEG"
Wrseq "#&             ,WPRITYP,PARAM.CPY,DATCONVPRI,PARAM.C_LINE(PLINEDOC).QTY,PARAM.VACBPR,PARAM.VACBPR_LEG,CLCAMT1,CLCAMT2,[F:SPL]PRI) From TRTX3_SYRA  : # Bug 84596"
Wrseq "      Call CLCTAXEPRIV_ADAPTER(PARAM.ACTX, [F:SPL]PRI,PARAM.C_LINE(PLINEDOC).C_VAT(1..maxtab(PARAM.C_LINE(PLINEDOC).C_VAT))"
Wrseq "&             ,WPRITYP,PARAM.CPY,DATCONVPRI,PARAM.C_LINE(PLINEDOC).QTY,PARAM.VACBPR,PARAM.VACBPR_LEG,CLCAMT1,CLCAMT2,[F:SPL]PRI) From TRTX3_SYRA  : # Bug 84596"
Wrseq "    Endif"
  Endif
Wrseq "    If (RESULT.C_PRICE(1).MONTANT=0 & RESULT.C_PRICE(1).MOTIF=0) | RESULT.C_PRICE(1).MONTANT>[F:SPL]PRI"
Wrseq "      RESULT.C_PRICE(1).MONTANT=arr([F:SPL]PRI,10^-PARAM.GDECPRI)"
Wrseq "      RESULT.C_PRICE(1).MOTIF=WPRIREN"
Wrseq "      RESULT.C_PRICE(1).PRIORITE=PARAM.PIO"
Wrseq "      #PLI(0)=[F:SPL]PLI : PLICRD(0)=[F:SPL]PLICRD : PLILIN(0)=[F:SPL]PLILIN"
Wrseq "      RESULT.C_PRICE(1).PLI=[F:SPL]PLI : RESULT.C_PRICE(1).PLICRD=[F:SPL]PLICRD : RESULT.C_PRICE(1).PLILIN=[F:SPL]PLILIN"
Wrseq "    Endif"
Wrseq "  Endif"
Endif

# on traite les 9 colonnes frais/remises

For I=0 To NBRCOLONNE-1
  If find ([F:SPC]DISCRGPRO(I),1,3)
     INDR=num$(I)
     INDN=num$(I+1)
    If [F:SPC]DISCRGPRO(I)=1
      If [F:PRS]VALTYP(I)=1
Wrseq "# frais/rem en montant"
Wrseq "  If DOTASK_DISCRG(";INDN;")"
        If ICONV<>0
Wrseq "    [F:SPL]DCGVAL(";INDR;")=[F:SPL]DCGVAL(";INDR;")";TEX(3);
          If [F:PRS]CLCRUL(I)=1
Wrseq TEX(1);TEX(2);
          Endif
Wrseq

#         arrondi suivant type donnee ecran saisie tarifs si montant par unite
          If [F:PRS]CLCRUL=1
Wrseq "    Raz APDC_RND : APDC_CUR=PARAM.CUR : Gosub LECTCU : ";
            I1=instr(1,ATY_FORTYP(I+1),"=")
            If I1
Wrseq "APDC_FMT=";right$(ATY_FORTYP(I+1),I1+1)
            Else
#Gbn-78037
#Wrseq "APDC_FMT='";ATY_FORTYP(I+1);"'"
Wrseq "If PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);")<>null"
Wrseq "  If pat(PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);").GFMTCOL,'[F:TCU]') : APDC_FMT='' : Else : APDC_FMT=PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);").GFMTCOL : Endif"
Wrseq "Endif"
            Endif
Wrseq "    Gosub ARRFMT : [F:SPL]DCGVAL(";INDR;")=arr([F:SPL]DCGVAL(";INDR;"),APDC_RND)"
          Endif

#         arrondi suivant type donnee ecran saisie tarifs si montant par ligne
          If [F:PRS]CLCRUL=2
Wrseq "    Raz APDC_RND : APDC_CUR=PARAM.CUR : Gosub LECTCU : ";
            I1=instr(1,ATY_FORTYP(I+1),"=")
            If I1
Wrseq "APDC_FMT=";right$(ATY_FORTYP(I+1),I1+1)
            Else
#Gbn-78037
#Wrseq "APDC_FMT='";ATY_FORTYP(I+1);"'"
Wrseq "If PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);")<>null"
Wrseq "  If pat(PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);").GFMTCOL,'[F:TCU]') : APDC_FMT='' : Else : APDC_FMT=PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);").GFMTCOL : Endif"
Wrseq "Endif"
            Endif
Wrseq "    Gosub ARRFMT : [F:SPL]DCGVAL(";INDR;")=arr([F:SPL]DCGVAL(";INDR;"),APDC_RND)"
          Endif
        Endif

        If [F:SPC]ATICNVFLG<>1 & [F:PRS]NPRNOTFLG=2
Wrseq "    If PARAM.PRITYP<>WPRITYP"
Wrseq "      Raz CLCAMT1, CLCAMT2"
Wrseq "      If dim(PARAM.C_LINE(PLINEDOC).C_SPKD(1).CLCAMT1)>0 : CLCAMT1=PARAM.C_LINE(PLINEDOC).C_SPKD(1).CLCAMT1 : Endif"
Wrseq "      If dim(PARAM.C_LINE(PLINEDOC).C_SPKD(1).CLCAMT2)>0 : CLCAMT2=PARAM.C_LINE(PLINEDOC).C_SPKD(1).CLCAMT2 : Endif"
Wrseq ""
Wrseq "#      Local Integer ICPO"
Wrseq "#      Local Char WVAT(GLONVAT)(1..), WVAT_LEG(GLONADI)(1..)"
Wrseq "#      For ICPO=1 To maxtab(PARAM.C_LINE(PLINEDOC).C_VAT)"
Wrseq "#        If PARAM.C_LINE(PLINEDOC).C_VAT(ICPO)<>null"
Wrseq "#          WVAT(ICPO)     = PARAM.C_LINE(PLINEDOC).C_VAT(ICPO).VAT"
Wrseq "#          WVAT_LEG(ICPO) = PARAM.C_LINE(PLINEDOC).C_VAT(ICPO).VAT_LEG"
Wrseq "#        Else"
Wrseq "#          WVAT(ICPO)     = ''"
Wrseq "#          WVAT_LEG(ICPO) = ''"
Wrseq "#        Endif"
Wrseq "#      Next ICPO"
Wrseq "#"
Wrseq "#      Call CLCTAXEPRIV (PARAM.ACTX,[F:SPL]DCGVAL(";INDR;"),WVAT,WVAT_LEG,"
Wrseq "#&  WPRITYP,PARAM.CPY,DATCONVPRI,PARAM.C_LINE(PLINEDOC).QTY,PARAM.VACBPR,PARAM.VACBPR_LEG,CLCAMT1,CLCAMT2,[F:SPL]DCGVAL(";INDR;")) From TRTX3_SYRA : # Bug 84596"
Wrseq "#      Call CLCTAXEPRIV (PARAM.ACTX,[F:SPL]DCGVAL(";INDR;
& "),PARAM.C_LINE(PLINEDOC).C_VAT(1..maxtab(PARAM.C_LINE(PLINEDOC).C_VAT)).VAT,PARAM.C_LINE(PLINEDOC).C_VAT(1..maxtab(PARAM.C_LINE(PLINEDOC).C_VAT)).VAT_LEG,"
Wrseq "#&  WPRITYP,PARAM.CPY,DATCONVPRI,PARAM.C_LINE(PLINEDOC).QTY,PARAM.VACBPR,PARAM.VACBPR_LEG,CLCAMT1,CLCAMT2,[F:SPL]DCGVAL(";INDR;")) From TRTX3_SYRA : # Bug 84596"
Wrseq "      Call CLCTAXEPRIV_ADAPTER(PARAM.ACTX,[F:SPL]DCGVAL(";INDR;"),PARAM.C_LINE(PLINEDOC).C_VAT(1..maxtab(PARAM.C_LINE(PLINEDOC).C_VAT)),"
Wrseq "&  WPRITYP,PARAM.CPY,DATCONVPRI,PARAM.C_LINE(PLINEDOC).QTY,PARAM.VACBPR,PARAM.VACBPR_LEG,CLCAMT1,CLCAMT2,[F:SPL]DCGVAL(";INDR;")) From TRTX3_SYRA : # Bug 84596"
Wrseq "      Raz APDC_RND : APDC_CUR=PARAM.CUR : Gosub LECTCU : ";
             I1=instr(1,ATY_FORTYP(I+1),"=")
             If I1
Wrseq "APDC_FMT=";right$(ATY_FORTYP(I+1),I1+1)
             Else
#Gbn-78037
#Wrseq "APDC_FMT='";ATY_FORTYP(I+1);"'"
Wrseq "If PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);")<>null"
Wrseq "  If pat(PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);").GFMTCOL,'[F:TCU]') : APDC_FMT='' : Else : APDC_FMT=PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);").GFMTCOL : Endif"
Wrseq "Endif"
             Endif
Wrseq "      Gosub ARRFMT : [F:SPL]DCGVAL(";INDR;")=arr([F:SPL]DCGVAL(";INDR;"),APDC_RND)"
Wrseq "    Endif"
        Endif

        Else

Wrseq "# frais/rem en %"
Wrseq "  If DOTASK_DISCRG(";INDN;")"
      Endif
      If [F:PRS]INCDCR(I)=1
#       c'est une majoration
Wrseq "    If (RESULT.C_DISCRG(";INDN;").MONTANT=0 & RESULT.C_DISCRG(";INDN;").MOTIF=0) | RESULT.C_DISCRG(";INDN;").MONTANT>[F:SPL]DCGVAL(";INDR;")"
      Else
#       c'est une minoration
Wrseq "    If (RESULT.C_DISCRG(";INDN;").MONTANT=0 & RESULT.C_DISCRG(";INDN;").MOTIF=0) | RESULT.C_DISCRG(";INDN;").MONTANT<[F:SPL]DCGVAL(";INDR;")"
      Endif
Wrseq "      RESULT.C_DISCRG(";INDN;").MONTANT=[F:SPL]DCGVAL(";INDR;") : RESULT.C_DISCRG(";INDN;").MOTIF=WPRIREN : RESULT.C_DISCRG(";INDN;").PRIORITE=PARAM.PIO"
Wrseq "      RESULT.C_DISCRG(";INDN;").PLI=[F:SPL]PLI : RESULT.C_DISCRG(";INDN;").PLICRD=[F:SPL]PLICRD : RESULT.C_DISCRG(";INDN;").PLILIN=[F:SPL]PLILIN"
Wrseq "    Endif"
Wrseq "  Endif"
    Endif
    If [F:SPC]DISCRGPRO(I)=3
Wrseq "# frais/rem initialisation"
Wrseq "  If DOTASK_DISCRG(";INDN;")"
Wrseq "    RESULT.C_DISCRG(";INDN;").MONTANT=0 : RESULT.C_DISCRG(";INDN;").MOTIF=WPRIREN"
Wrseq "    RESULT.C_DISCRG(";INDN;").PLI=[F:SPL]PLI : RESULT.C_DISCRG(";INDN;").PLICRD=[F:SPL]PLICRD : RESULT.C_DISCRG(";INDN;").PLILIN=[F:SPL]PLILIN"
Wrseq "  Endif"
    Endif
  Endif
Next I

# on traite le coef de commission
If [F:SPC]COMPRO=1
Wrseq "# coef commission"
Wrseq "  If DOTASK_REPCOE"
Wrseq "    RESULT.C_REPCOE(1).MONTANT=[F:SPL]COMCOE : RESULT.C_REPCOE(1).MOTIF=WPRIREN : RESULT.C_REPCOE(1).PRIORITE=PARAM.PIO"
Wrseq "    RESULT.C_REPCOE(1).PLI=[F:SPL]PLI : RESULT.C_REPCOE(1).PLICRD=[F:SPL]PLICRD : RESULT.C_REPCOE(1).PLILIN=[F:SPL]PLILIN"
Wrseq "  Endif"
Endif
If [F:SPC]COMPRO=3
Wrseq "# coef commission initialisation"
Wrseq "  If DOTASK_REPCOE"
Wrseq "    DOTASK_REPCOE=0 : RESULT.C_REPCOE(1).MOTIF=WPRIREN"
Wrseq "    RESULT.C_REPCOE(1).PLI=[F:SPL]PLI : RESULT.C_REPCOE(1).PLICRD=[F:SPL]PLICRD : RESULT.C_REPCOE(1).PLILIN=[F:SPL]PLILIN"
Wrseq "  Endif"
Endif

# on traite les gratuits
If [F:SPC]FOCPRO=2 | [F:SPC]FOCPRO=3
Wrseq "# les gratuits"
Wrseq "  If DOTASK_FOC"
Wrseq "    If [F:SPL]FOCQTYMIN<=PARAM.C_LINE(PLINEDOC).QTY"
#--CPO ajout
Wrseq "      If RESULT.C_FOC(1)=null"
Wrseq "        WLINE = fmet RESULT.ADDLINE('C_FOC',1)"
Wrseq "        If WLINE = [V]CST_ANOTDEFINED"
Wrseq "          #--The insertion was not possible"
Wrseq "          [L]WERR = fmet RESULT.ASETERROR('', func ASYRFNC.MES2(mess(266,133,1),'C_FOC','RESULTPRICE'), [V]CST_AERROR)"
Wrseq "          End"
Wrseq "        Endif"
Wrseq "      Endif"
#--/
#    seuil
  If [F:SPC]FOCTYP=1
Wrseq "      RESULT.C_FOC(1).FOCQTY=[F:SPL]FOCQTY"
Wrseq "      RESULT.C_FOC(1).FOCMOTIF=WPRIREN"
  Endif
#    multiple
  If [F:SPC]FOCTYP=2
Wrseq "      If WFOCQTYBKT=0 WFOCQTYBKT=1 Endif"
Wrseq "      RESULT.C_FOC(1).FOCQTY  = fix (((PARAM.C_LINE(PLINEDOC).QTY*COEFUNITE)-WFOCQTYMIN)/WFOCQTYBKT)*[F:SPL]FOCQTY"
Wrseq "      RESULT.C_FOC(1).FOCMOTIF= WPRIREN"
  Endif
  If [F:SPC]FOCPRO=3
Wrseq "      If RESULT.C_FOC(1).FOCQTY<>0"
Wrseq "        RESULT.C_FOC(1).FOCITMREF= [F:SPL]FOCITMREF"
Wrseq "        RESULT.C_FOC(1).FOCUOM   = [F:SPL]FOCUOM"
Wrseq "      Endif"
  Endif

Wrseq "    Endif"
Wrseq "  Endif"
Endif

Wrseq "  RESULT.PLISTRDAT = [F:SPL]PLISTRDAT"
Wrseq "  RESULT.PLIENDDAT = [F:SPL]PLIENDDAT"
Wrseq "$TAR_SUIVANT"
Wrseq "Next"
Wrseq "Filter [SPL]"
Wrseq "End"
Return

#------------------------------------------------------------------------
# tarif groupe : génération traitement
#------------------------------------------------------------------------
$TR_GROUPE

#--CPO Dépassement du nombre d'instructions possible
Gosub TR_GROUPE From SUBSPCTB_SYRA

Return

$TR_GRP_CI_NLD
Wrseq "#-----------------------------------------------------------------"
Wrseq "#--- Pour chaque ligne de la Boucle (A:NLD) en cours -------------"
Wrseq "#--- Boucle (B:SPL) : lignes tarifs ayant criteres ligne NLD -----"
Wrseq ""
Wrseq "$CRIT_IDEM_NLD"
#--CPO ajout
Wrseq "IGR=1"
Wrseq ""
#--/
Wrseq "For [SPL]SPL1 Where [F:SPL]PLI='"+[F:SPC]PLI+"'"
Wrseq "&  & PLICRI=WCRIT"
Wrseq "&  & PARAM.DOCDAT>=[F:SPL]PLISTRDAT & PARAM.DOCDAT<=[F:SPL]PLIENDDAT"
If [F:SPC]CURCNVFLG=1 & SAISIEDEV=1          : # si tarif sans conversion devise (filtre devise identique)
  Wrseq "&  & [F:SPL]CUR=PARAM.CUR"
Endif
Wrseq "  If !PARAM.GSPLXGRP"
Wrseq "    If sum(PARAM.C_LINE(1..maxtab(PARAM.C_LINE)).GRPFLG)=maxtab(PARAM.C_LINE) : break : Endif"
Wrseq "  Endif"
Wrseq "  Raz CUMQTY, CUMAMT, SELGRP"
Wrseq "  COEFUNITE=1 : COEFPOURN=1 : COEFDEVISE=1"
Raz TEX : ICONV=0
If [F:SPC]CURCNVFLG=2                        : # si tarif avec conversion devise
# Bug 60443
Wrseq "  If [F:SPL]CUR<>PARAM.CUR"
#--CPO
#Wrseq "    If [F:SPL]CUR<>PARAM.CUR & [F:SPL]CUR=GLOCALDEV & val(PARAM_T(2))<>0"
#Wrseq "      COEFDEVISE=val(PARAM_T(2))"
Wrseq "    If [F:SPL]CUR<>PARAM.CUR & [F:SPL]CUR=PARAM.GLOCALDEV & PARAM.MLTDIVCOE<>0"
Wrseq "      COEFDEVISE=PARAM.MLTDIVCOE"
Wrseq "    Else"
Wrseq "      Call CONVERT(PARAM.ACTX,[F:SPL]CUR,PARAM.CUR,PARAM.GLOCALDEV,PARAM.CHGTYP,PARAM.DOCDAT,1000000000000.00,COEFDEVISE,WBIDI) From TRTDEV_SYRA"
Wrseq "      If WBIDI=0 & COEFDEVISE<>0 COEFDEVISE=COEFDEVISE/1000000000000.00 Else COEFDEVISE=1 Endif"
Wrseq "    Endif"
Wrseq "  Endif"
# Bug 60443
  TEX(3)="*COEFDEVISE" : ICONV=1
Endif
Wrseq "#--- Pour chaque ligne tarif de la Boucle (B:SPL) ----------------"
Wrseq "#--- Boucle (C:NLG) : lignes du documents ------------------------"
Wrseq "  For NLG=1 to maxtab(PARAM.C_LINE)"
Wrseq "    If (PARAM.C_LINE(NLG).GRPFLG=0 | PARAM.GSPLXGRP) & UPDGRP(NLG-1)=0"

#--CPO => plus besoin car la classe des paramètres contient un tableau de paramètres déjà chargés liés à chaque ligne
#If ILK                                       : # appel de ALIPLK uniquement si necessaire
#  Wrseq "      SAVNOLIGN=nolign : nolign=NLG"
#  Wrseq "      GALIPLK=TRAIT : Gosub GALIPLK From TRTPRICE"
#  Wrseq "      nolign=SAVNOLIGN"
#Endif

If find("ITM",[F:SPC]ABB)                    : # lecture ITMMASTER si present dans les criteres
  Wrseq "      If [F:ITM]ITMREF<>PARAM.C_LINE(NLG).ITMREF"
  Wrseq "        Read [ITM]ITM0=PARAM.C_LINE(NLG).ITMREF"
  Wrseq "        If fstat : Raz [F:ITM] : Endif"
  Wrseq "      Endif"
Endif

If find("ITS",[F:SPC]ABB)                    : # lecture ITMSALES si present dans les criteres
  Wrseq "      If [F:ITS]ITMREF<>PARAM.C_LINE(NLG).ITMREF"
  Wrseq "        Read [ITS]ITS0=PARAM.C_LINE(NLG).ITMREF"
  Wrseq "        If fstat : Raz [F:ITS] : Endif"
  Wrseq "      Endif"
Endif

If find("BPD",[F:SPC]ABB)                    : # lecture BPDLVCUST si present dans les criteres
  Wrseq "      If    dim(PARAM.C_LINE(NLG).DBPAADD)>0   [L]WBPAADD=PARAM.C_LINE(NLG).DBPAADD"
  Wrseq "      Elsif dim(PARAM.BPAADD)>0           [L]WBPAADD=PARAM.BPAADD"
  Wrseq "      Endif"
  Wrseq "      If [F:BPD]BPCNUM<>[F:BPC]BPCNUM | [F:BPD]BPAADD<>[L]WBPAADD"
  Wrseq "        Read [BPD]BPD0=[F:BPC]BPCNUM;[L]WBPAADD"
  Wrseq "        If fstat : Raz [F:BPD] : Endif"
  Wrseq "      Endif"
Endif

If find("REP",[F:SPC]ABB)                    : # lecture SALESREP si present dans les criteres
  Wrseq "      If [F:REP]REPNUM<>PARAM.C_LINE(NLG).REP1"
  Wrseq "        Read [REP]REP0=PARAM.C_LINE(NLG).REP1"
  Wrseq "        If fstat : Raz [F:REP] : Endif"
  Wrseq "      Endif"
Endif

If find("SPK",[F:SPC]ABB)                    : # lecture SPRICELINK si present dans les criteres
Wrseq "#--Transclasse [F:SPK] with PARAM.C_SPKH(1) et PARAM.C_LINE(NLG).C_SPKD(1)"
Wrseq "If PARAM.C_SPKH(1)<>null"
Wrseq "  WERR = fmet PARAM.C_SPKH(1).LOAD_TO_SPK_FILE()"
Wrseq "  If WERR >= [V]CST_AERROR"
Wrseq "    [L]WERR = fmet PARAM.ASETERROR('', mess(68,123,1)-':'-mess(1,7845,1)-'LOAD_TO_SPK_FILE', WERR)"
Wrseq "  Endif"
Wrseq "Endif"
Wrseq "If PARAM.C_LINE(NLG).C_SPKD(1)<>null"
Wrseq "  WERR = fmet PARAM.C_LINE(NLG).C_SPKD(1).LOAD_TO_SPK_FILE()"
Wrseq "  If WERR >= [V]CST_AERROR"
Wrseq "    [L]WERR = fmet PARAM.ASETERROR('', mess(68,123,1)-':'-mess(1,7845,1)-'LOAD_TO_SPK_FILE', WERR)"
Wrseq "  Endif"
Wrseq "Endif"
Wrseq ""
Endif
Wrseq "      WCRIT=";
For I=0 To 4
  If I>0 : Wrseq "+"; : Endif
  If [F:SPC]FLD(I)<>""
    Case [F:SPC]FLDTYP(I)
    When "CCE"
      Wrseq "[F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(max(find('";[F:SPC]CRIDIE(I);"',[F:";[F:SPC]ABB(I);"]DIE)-1,0))+'~'";
    When "C", "L", "DCB", "M"
      Wrseq "num$([F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(";num$([F:SPC]CRIIND(I));"))+'~'";
    When "D"
      Wrseq "num$(val([F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(";num$([F:SPC]CRIIND(I));")))+'~'";
    When Default
      Wrseq "[F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(";num$([F:SPC]CRIIND(I));")+'~'";
    Endcase
  Else
    Wrseq "'~'";
  Endif
Next I
Wrseq
Wrseq "      If WCRIT=[F:SPL]PLICRI"
Wrseq "        CONVQTY=PARAM.C_LINE(NLG).QTY"
If [F:SPC]PRIQTYFLG=5                        : # si tranches tarifs sur prix nets
Wrseq "        CONVPRI=PARAM.C_LINE(NLG).NETPRI"
  Else                                       : # si tranches tarifs sur prix bruts
Wrseq "        CONVPRI=PARAM.C_LINE(NLG).GROPRI"
Endif
Wrseq "        NONSEL=0"
Wrseq "        COEFUNITE=1 : COEFUNITE(1)=0"

If [F:SPC]PRIQTYFLG=3                        : # si tranches tarifs sur quantites
  If [F:SPC]UOMCNVFLG=2                      : # si tarif avec conversion unites
Wrseq "        If [F:SPL]UOM<>PARAM.C_LINE(NLG).SAU"
#Wrseq "          If dim([M]SAUSTUCOE)>0 : COEFUNITE(1)=[M]SAUSTUCOE(NLG-1) : Endif"  :# bug 34050
Wrseq "          Call SREC_COE (PARAM.C_LINE(NLG).ITMREF,[F:BPC]BPCNUM,PARAM.C_LINE(NLG).SAU,[F:SPL]UOM,COEFUNITE) From TRTVENQTE_SYRA"
Wrseq "          If COEFUNITE=0 : COEFUNITE=1 : Endif"
Wrseq "#         attention on reste dans unité tarif (donc /coefunite)"
Wrseq "          CONVQTY=CONVQTY/COEFUNITE"
Wrseq "        Endif"
  Else                                       : # si tarif sans conversion unites
Wrseq "        If [F:SPL]UOM<>PARAM.C_LINE(NLG).SAU : NONSEL=1 : CONVQTY=0 : Endif"
  Endif
Endif

If [F:SPC]UPDNULPRI=2                        : # si maj des prix nuls
Wrseq "        If PARAM.C_LINE(NLG).C_SPKD(1).FOCITM=2 : NONSEL=1 : Endif"
Endif
#--CPO Problème des Points d'entrée
#Wrseq "        CODENTPNT='S1' : Gosub RECHGROUP1 From TRTVENTAR"
Wrseq "        CODENTPNT='S1_SY' : Gosub RECHGROUP1 From TRTVENTAR_SYRA"
Wrseq "        If NONSEL=0"
Wrseq "          CUMQTY += CONVQTY"
Wrseq "#         attention on reste dans devise tarif (donc /coefdevise)"
Wrseq "          If COEFDEVISE=0 : COEFDEVISE=1 : Endif"
Wrseq "          CUMAMT += (CONVPRI*PARAM.C_LINE(NLG).QTY/COEFDEVISE)"
Wrseq "          SELGRP(NLG-1)=1"
Wrseq "        Endif"
Wrseq "      Endif"
Wrseq "    Endif"
Wrseq "  Next NLG"
Wrseq ""
Wrseq "  Local Integer WARR_CUMQTY : WARR_CUMQTY=1"                             : # 88602
Wrseq "  Local Integer WARR_CUMAMT : WARR_CUMAMT=1"                             : # 91167
Wrseq "  Local Integer IJRAZ"
#--CPO Problème des Points d'entrée
Wrseq "  CODENTPNT='S2_SY' : Gosub RECHGROUP1 From TRTVENTAR_SYRA" #Gbn-fq77541
Wrseq "  If WARR_CUMQTY = 1 Call QTEARR(CUMQTY, [F:SPL]UOM) From TRTDIV_SYRA Endif"  : # 88602
Wrseq "  If WARR_CUMAMT = 1 Call ARRDEV(CUMAMT, PARAM.CUR, PARAM.CPY) From TRTDIV_SYRA Endif"          : # 91167
Wrseq ""
Wrseq "  If sum(SELGRP)>0"
If [F:SPC]PRIQTYFLG=3                        : # si tranches tarifs sur quantites

Wrseq "    If CUMQTY>=[F:SPL]MINQTY & CUMQTY<=[F:SPL]MAXQTY"
Wrseq "      CUMALL=CUMQTY"

Else                                       : # si tranches tarifs sur prix bruts ou nets

Wrseq "    If CUMAMT>=[F:SPL]MINAMT & CUMAMT<=[F:SPL]MAXAMT"
Wrseq "      CUMALL=CUMAMT"

Endif

Wrseq "      COEFUNITE=1 : COEFPOURN=1 "

Wrseq "      LIGMAJ=0 : # pour tester si 1ere ligne en m.a.j."
Wrseq "      #--boucle sur les lignes de document .."
Wrseq "      For NLG=1 to maxtab(PARAM.C_LINE)"
Wrseq "        If SELGRP(NLG-1)<>0"
Wrseq "          UPDGRP(NLG-1)=1"
Wrseq "          LIGMAJ +=1"
#Wrseq "          Raz RESULT.C_PRICE(1..maxtab(RESULT.C_PRICE)).PLI"
#Wrseq "          Raz RESULT.C_PRICE(1..maxtab(RESULT.C_PRICE)).PLICRD"
#Wrseq "          Raz RESULT.C_PRICE(1..maxtab(RESULT.C_PRICE)).PLILIN"
#Wrseq "          Raz RESULT.C_DISCRG(1..maxtab(RESULT.C_DISCRG)).PLI"
#Wrseq "          Raz RESULT.C_DISCRG(1..maxtab(RESULT.C_DISCRG)).PLICRD"
#Wrseq "          Raz RESULT.C_DISCRG(1..maxtab(RESULT.C_DISCRG)).PLILIN"
#Wrseq "          Raz RESULT.C_REPCOE(1..maxtab(RESULT.C_REPCOE)).PLI"
#Wrseq "          Raz RESULT.C_REPCOE(1..maxtab(RESULT.C_REPCOE)).PLICRD"
#Wrseq "          Raz RESULT.C_REPCOE(1..maxtab(RESULT.C_REPCOE)).PLILIN"
Wrseq "          For IJRAZ = 1 to maxtab(RESULT.C_PRICE)"
Wrseq "            If RESULT.C_PRICE(IJRAZ)<>null"
Wrseq "              RESULT.C_PRICE(IJRAZ).PLI      = '' #AVOID.ACHAR"
Wrseq "              RESULT.C_PRICE(IJRAZ).PLICRD   = '' #AVOID.ACHAR"
Wrseq "              RESULT.C_PRICE(IJRAZ).PLILIN   = 0  #AVOID.AINT"
Wrseq "            Endif"
Wrseq "          Next IJRAZ"
Wrseq "          For IJRAZ = 1 to maxtab(RESULT.C_DISCRG)"
Wrseq "            If RESULT.C_DISCRG(IJRAZ)<>null"
Wrseq "              RESULT.C_DISCRG(IJRAZ).PLI    = '' #AVOID.ACHAR"
Wrseq "              RESULT.C_DISCRG(IJRAZ).PLICRD = '' #AVOID.ACHAR"
Wrseq "              RESULT.C_DISCRG(IJRAZ).PLILIN = 0  #AVOID.AINT"
Wrseq "            Endif"
Wrseq "          Next IJRAZ"
Wrseq "          For IJRAZ = 1 to maxtab(RESULT.C_REPCOE)"
Wrseq "            If RESULT.C_REPCOE(IJRAZ)<>null"
Wrseq "              RESULT.C_REPCOE(IJRAZ).PLI    = '' #AVOID.ACHAR"
Wrseq "              RESULT.C_REPCOE(IJRAZ).PLICRD = '' #AVOID.ACHAR"
Wrseq "              RESULT.C_REPCOE(IJRAZ).PLILIN = 0  #AVOID.AINT"
Wrseq "            Endif"
Wrseq "          Next IJRAZ"
Wrseq "          Raz  CODENTPNT"
Wrseq ""
Wrseq "          Gosub TR_GRPLIG                   : # Traitement 1 ligne"
#--CPO Problème des points d'entrée
Wrseq "          If CODENTPNT<>'' : Gosub RECHGROUP1 From TRTVENTAR_SYRA : Endif"
Wrseq ""
Wrseq "          For IJRAZ = 1 to maxtab(RESULT.C_PRICE)"
Wrseq "            If RESULT.C_PRICE(IJRAZ)<>null"
Wrseq "              RESULT.C_PRICE(IJRAZ).PLI      = '' #AVOID.ACHAR"
Wrseq "              RESULT.C_PRICE(IJRAZ).PLICRD   = '' #AVOID.ACHAR"
Wrseq "              RESULT.C_PRICE(IJRAZ).PLILIN   = 0  #AVOID.AINT"
Wrseq "            Endif"
Wrseq "          Next IJRAZ"
Wrseq "          For IJRAZ = 1 to maxtab(RESULT.C_DISCRG)"
Wrseq "            If RESULT.C_DISCRG(IJRAZ)<>null"
Wrseq "              RESULT.C_DISCRG(IJRAZ).PLI    = '' #AVOID.ACHAR"
Wrseq "              RESULT.C_DISCRG(IJRAZ).PLICRD = '' #AVOID.ACHAR"
Wrseq "              RESULT.C_DISCRG(IJRAZ).PLILIN = 0  #AVOID.AINT"
Wrseq "            Endif"
Wrseq "          Next IJRAZ"
Wrseq "          For IJRAZ = 1 to maxtab(RESULT.C_REPCOE)"
Wrseq "            If RESULT.C_REPCOE(IJRAZ)<>null"
Wrseq "              RESULT.C_REPCOE(IJRAZ).PLI    = '' #AVOID.ACHAR"
Wrseq "              RESULT.C_REPCOE(IJRAZ).PLICRD = '' #AVOID.ACHAR"
Wrseq "              RESULT.C_REPCOE(IJRAZ).PLILIN = 0  #AVOID.AINT"
Wrseq "            Endif"
Wrseq "          Next IJRAZ"
Wrseq "          Raz  CODENTPNT"
Wrseq "        Endif"
Wrseq "      Next NLG"

If [F:SPC]FOCPRO=4                           : # attribution art. gratuits sur total document

Wrseq "#           les gratuits"

  If [F:SPC]PRIQTYFLG=3                      : # test sur quantite

Wrseq "      If [F:SPL]FOCITMREF<>'' & [F:SPL]FOCQTYMIN<=CUMQTY"

  Endif

  If find([F:SPC]PRIQTYFLG,4,5)              : # test sur prix brut ou net

Wrseq "      If [F:SPL]FOCITMREF<>'' & [F:SPL]FOCAMTMIN<=CUMALL"

  Endif

Wrseq "        If !find([F:SPL]PLI+'~'+[F:SPL]PLICRD+'~'+num$([F:SPL]PLILIN),FOCUPDTST)"
#--CPO
#Wrseq "          IGR = find('',FOCITMREF(0..dim(FOCITMREF)-1))"
#--/
#Wrseq "          IGR = find('',RESULT.C_FOC(1..maxtab(RESULT.C_FOC)).FOCITMREF)"
#Wrseq "          If IGR<>0"
#--CPO ajout
Wrseq "            If RESULT.C_FOC(IGR) = null"
Wrseq "              IGR = fmet RESULT.ADDLINE('C_FOC',IGR)"
Wrseq "              If IGR = [V]CST_ANOTDEFINED"
Wrseq "                #--The insertion was not possible"
Wrseq "                [L]WERR = fmet RESULT.ASETERROR('', func ASYRFNC.MES2(mess(266,133,1),'C_FOC','RESULTPRICE'), [V]CST_AERROR)"
Wrseq "                Break"
Wrseq "              Endif"
Wrseq "            Endif"
#--/
Wrseq "            For IJRAZ = 1 to maxtab(RESULT.C_PRICE)"
Wrseq "              If RESULT.C_PRICE(IJRAZ)<>null"
Wrseq "                RESULT.C_PRICE(IJRAZ).PLI      = '' #AVOID.ACHAR"
Wrseq "                RESULT.C_PRICE(IJRAZ).PLICRD   = '' #AVOID.ACHAR"
Wrseq "                RESULT.C_PRICE(IJRAZ).PLILIN   = 0  #AVOID.AINT"
Wrseq "              Endif"
Wrseq "            Next IJRAZ"
Wrseq "            For IJRAZ = 1 to maxtab(RESULT.C_DISCRG)"
Wrseq "              If RESULT.C_DISCRG(IJRAZ)<>null"
Wrseq "                RESULT.C_DISCRG(IJRAZ).PLI    = '' #AVOID.ACHAR"
Wrseq "                RESULT.C_DISCRG(IJRAZ).PLICRD = '' #AVOID.ACHAR"
Wrseq "                RESULT.C_DISCRG(IJRAZ).PLILIN = 0  #AVOID.AINT"
Wrseq "              Endif"
Wrseq "            Next IJRAZ"
Wrseq "            For IJRAZ = 1 to maxtab(RESULT.C_REPCOE)"
Wrseq "              If RESULT.C_REPCOE(IJRAZ)<>null"
Wrseq "                RESULT.C_REPCOE(IJRAZ).PLI    = '' #AVOID.ACHAR"
Wrseq "                RESULT.C_REPCOE(IJRAZ).PLICRD = '' #AVOID.ACHAR"
Wrseq "                RESULT.C_REPCOE(IJRAZ).PLILIN = 0  #AVOID.AINT"
Wrseq "              Endif"
Wrseq "            Next IJRAZ"
Wrseq "            Raz  CODENTPNT"

  If [F:SPC]FOCTYP=1                         : # type de gratuite : seuil

Wrseq "            FOCUPDTST(IGR)=[F:SPL]PLI+'~'+[F:SPL]PLICRD+'~'+num$([F:SPL]PLILIN)"
Wrseq "            RESULT.C_FOC(IGR).FOCITMREF=[F:SPL]FOCITMREF"
Wrseq "            RESULT.C_FOC(IGR).FOCQTY   =[F:SPL]FOCQTY"
Wrseq "            RESULT.C_FOC(IGR).FOCUOM   =[F:SPL]FOCUOM"
Wrseq "            RESULT.C_FOC(IGR).FOCMOTIF =WPRIREN"
#--CPO Problème des points d'entrée
Wrseq "            CODENTPNT='G2_SY' : Gosub RECHGROUP1 From TRTVENTAR_SYRA"
#--/
#Wrseq "          Endif"

  Elsif [F:SPC]FOCTYP=2                      : # type de gratuite : multiple

Wrseq "            FOCUPDTST(IGR)=[F:SPL]PLI+'~'+[F:SPL]PLICRD+'~'+num$([F:SPL]PLILIN)"
Wrseq "            RESULT.C_FOC(IGR).FOCITMREF = [F:SPL]FOCITMREF"

    If [F:SPC]PRIQTYFLG=3                      : # test sur quantite
Wrseq "            If [F:SPL]FOCQTYBKT=0 [F:SPL]FOCQTYBKT=1 Endif"
Wrseq "            RESULT.C_FOC(IGR).FOCQTY    = fix ((CUMALL-[F:SPL]FOCQTYMIN)/[F:SPL]FOCQTYBKT)*[F:SPL]FOCQTY"
    Endif

    If find([F:SPC]PRIQTYFLG,4,5)              : # test sur prix brut ou net
Wrseq "            If [F:SPL]FOCAMTBKT=0 [F:SPL]FOCAMTBKT=1 Endif"
Wrseq "            RESULT.C_FOC(IGR).FOCQTY    = fix ((CUMALL-[F:SPL]FOCAMTMIN)/[F:SPL]FOCAMTBKT)*[F:SPL]FOCQTY"
    Endif

Wrseq "            RESULT.C_FOC(IGR).FOCUOM    = [F:SPL]FOCUOM"
Wrseq "            RESULT.C_FOC(IGR).FOCMOTIF  = WPRIREN"
#--CPO Problème des points d'entrée
Wrseq "            CODENTPNT='G2_SY' : Gosub RECHGROUP1 From TRTVENTAR_SYRA"
#--/
#Wrseq "          Endif"

  Else

#Wrseq "          Endif"

  Endif

Wrseq "        Endif"
  If find([F:SPC]PRIQTYFLG,3,4,5)
Wrseq "      Endif"
  Endif
Endif

Wrseq "    Endif"
Wrseq "  Endif"

Wrseq "Next"
Wrseq "Return"
Return


$TR_GRPLIG
# --- Mise a jour une ligne (devis, cde, etc..) suivant tarif groupé
Wrseq ""
Wrseq "$TR_GRPLIG"
Wrseq "COEFUNITE=1 : COEFUNITE(1)=0"
Wrseq "CODENTPNT='G0'"

# On détermine la conversion unité
If [F:SPC]UOMCNVFLG=2                        : # si tarif avec conversion unites
  Raz TESTUOM
  TESTUOM=find(1,[F:PRS]VALTYP(0..NBRCOLONNE-1)) : # si une colonne de tarif est en montant
  If [F:SPC]PRIPRO>1 : TESTUOM=1 : Endif         : # si le tarif gere le prix
  If TESTUOM>0
Wrseq "# Conversion unite"
Wrseq "If [F:SPL]UOM<>PARAM.C_LINE(NLG).SAU"
Wrseq "  If dim(PARAM.C_LINE(NLG).SAUSTUCOE)>0 : COEFUNITE(1)=PARAM.C_LINE(NLG).SAUSTUCOE : Endif"
Wrseq "  Call SREC_COE (PARAM.C_LINE(NLG).ITMREF,[F:BPC]BPCNUM,[F:SPL]UOM,PARAM.C_LINE(NLG).SAU,COEFUNITE) From TRTVENQTE_SYRA"
Wrseq "  If COEFUNITE=0 : COEFUNITE=1 : Endif"
Wrseq "Endif"
    TEX(1)="*COEFUNITE"
    ICONV=1
  Endif
Endif

# On traite la colonne prix
If [F:SPC]PRIPRO>1                           : # si le tarif gere le prix

  If [F:SPC]PRIPRO=2                         : # prix en valeur
Wrseq "# Prix en valeur"
Wrseq "CONVPRI=[F:SPL]PRI"
  Endif
  If [F:SPC]PRIPRO=4 | [F:SPC]PRIPRO=5       : # prix par coefficient ou par calcul (formule)
Wrseq "# Prix par coeff. ou calcul : lecture ITS et ITV"
Wrseq "If [F:ITS]ITMREF<>[F:ITM]ITMREF"
Wrseq "  Read [ITS]ITS0 = [F:ITM]ITMREF"
Wrseq "  If fstat : Raz [F:ITS] : Endif"
Wrseq "Endif"
Wrseq "If [F:ITV]ITMREF<>[F:ITM]ITMREF | [F:ITV]STOFCY<>PARAM.C_LINE(NLG).C_SPKD(1).STOFCY"
Wrseq "  Read [ITV]ITV0 = [F:ITM]ITMREF; PARAM.C_LINE(NLG).C_SPKD(1).STOFCY"
Wrseq "  If fstat : Raz [F:ITV] : Endif"
Wrseq "Endif"
Wrseq "#   Articles-Couts ITMCOST"
Wrseq "#   ( utilisation de GETPRI pour delivrer le bon enregistrement [F:ITC] )"
Wrseq "Local Integer CSTTYP : CSTTYP=1 : # Prix standard par defaut"
Wrseq "If dim(PARAM.C_LINE(NLG).C_SPKD(1).CSTTYP)>0"
Wrseq "   If find(PARAM.C_LINE(NLG).C_SPKD(1).CSTTYP,1,2,99) : [L]CSTTYP=PARAM.C_LINE(NLG).C_SPKD(1).CSTTYP    : Endif"
Wrseq "   If find(PARAM.C_LINE(NLG).C_SPKD(1).CSTTYP,3,4)    : [L]CSTTYP=PARAM.C_LINE(NLG).C_SPKD(1).CSTTYP*-1 : Endif"
Wrseq "Endif"
Wrseq "If [L]CSTTYP=99"
Wrseq "   Raz [F:ITC]"
Wrseq " Else"
Wrseq "   If [F:ITC]STOFCY<>PARAM.C_LINE(NLG).C_SPKD(1).STOFCY | [F:ITC]ITMREF<>[F:ITM]ITMREF |"
# FQ 53431 GA 03/2009 ITCSTRDAT : Variable inexistante
#Wrseq "&     [F:ITC]CSTTYP<>[L]CSTTYP| ITCSTRDAT>DAT | DAT>ITCENDDAT"
Wrseq "&     [F:ITC]CSTTYP<>[L]CSTTYP| [F:ITC]ITCSTRDAT>PARAM.DOCDAT | PARAM.DOCDAT>[F:ITC]ITCENDDAT"
Wrseq "       Raz [F:ITC]"
# 105605 : CCM - Revision index
#Wrseq "       Call GETPRI([F:ITM]ITMREF,'','',PARAM.C_LINE(NLG).C_SPKD(1).STOFCY,PARAM.DOCDAT,1,'','',[L]CSTTYP,WBIDD,WRET) From STKVAL_SYRA"
Wrseq "       If dim(PARAM.C_LINE(NLG).C_SPKD(1).ECCVALMAJ)>0"
Wrseq "           Call GETPRI([F:ITM]ITMREF,PARAM.C_LINE(NLG).C_SPKD(1).ECCVALMAJ,PARAM.C_LINE(NLG).C_SPKD(1).ECCVALMIN,PARAM.C_LINE(NLG).C_SPKD(1).STOFCY,PARAM.DOCDAT,1,'','',[L]CSTTY"
&  + "P,WBIDD,WRET) From STKVAL_SYRA"
Wrseq "       Else"
Wrseq "           Call GETPRI([F:ITM]ITMREF,'','',PARAM.C_LINE(NLG).C_SPKD(1).STOFCY,PARAM.DOCDAT,1,'','',[L]CSTTYP,WBIDD,WRET) From STKVAL_SYRA"
Wrseq "       Endif"
# 105605
Wrseq "   Endif"
Wrseq "Endif"
  Endif
  If [F:SPC]PRIPRO=4                         : # prix par coefficient (formule)
       FORMULEPRI=format$("KTv1:250X",[F:SPC]PRIFLD)
Wrseq "# Prix par coefficient"
Wrseq "Onerrgo ERR_PRI"
Wrseq "CONVPRI=[F:SPL]PRI*(";FORMULEPRI;")"
Wrseq "Onerrgo"
  Endif
  If [F:SPC]PRIPRO=5                         : # prix par calcul (formule)
       FORMULEPRI=format$("KTv1:250X",[F:SPC]PRIFLD)
Wrseq "# Prix par formule"
Wrseq "Onerrgo ERR_PRI"
Wrseq "CONVPRI=(";FORMULEPRI;")"
Wrseq "Onerrgo"
  Endif
  If ICONV<>0
Wrseq "CONVPRI=CONVPRI";TEX(1);TEX(2);TEX(3)
  Endif
  If [F:SPC]ATICNVFLG<>1                     : # si tarif avec conversion de prix HT<-->TTC
Wrseq "#   Possibilité conversion ht/ttc"
Wrseq "If PARAM.PRITYP<>WPRITYP"
#--CPO ajout => pas besoin car existe dans la classe paramètres (il faut par contre s'assurer que le pointeurs <> null
#Wrseq "  Raz VAT"
#Wrseq "  If dim([M]VAT1)>0 : VAT(0)=[M]VAT1(NLG-1) : Endif"
#Wrseq "  If dim([M]VAT2)>0 : VAT(1)=[M]VAT2(NLG-1) : Endif"
#Wrseq "  If dim([M]VAT3)>0 : VAT(2)=[M]VAT3(NLG-1) : Endif"
#Wrseq "  Raz CLCAMT1, CLCAMT2"
#Wrseq "  If dim([F:SPK]CLCAMT1)>0 : CLCAMT1=[F:SPK]CLCAMT1 : Endif"
#Wrseq "  If dim([F:SPK]CLCAMT2)>0 : CLCAMT2=[F:SPK]CLCAMT2 : Endif"
#--/
Wrseq ""
Wrseq "#  Local Integer ICPO"
Wrseq "#  Local Char WVAT(GLONVAT)(1..), WVAT_LEG(GLONADI)(1..)"
Wrseq "#  Raz WVAT,WVAT_LEG"
Wrseq "#  For ICPO=1 To maxtab(PARAM.C_LINE(NLG).C_VAT)"
Wrseq "#    If PARAM.C_LINE(NLG).C_VAT(ICPO)<>null"
Wrseq "#      WVAT(ICPO)     = PARAM.C_LINE(NLG).C_VAT(ICPO).VAT"
Wrseq "#      WVAT_LEG(ICPO) = PARAM.C_LINE(NLG).C_VAT(ICPO).VAT_LEG"
Wrseq "#    Else"
Wrseq "#      WVAT(ICPO)     = ''"
Wrseq "#      WVAT_LEG(ICPO) = ''"
Wrseq "#    Endif"
Wrseq "#  Next ICPO"
Wrseq "#"
Wrseq "#  Call CLCTAXEPRIV (PARAM.ACTX, CONVPRI,WVAT,WVAT_LEG"
Wrseq "#&                  ,WPRITYP,PARAM.CPY,DATCONVPRI,PARAM.C_LINE(NLG).QTY,PARAM.VACBPR,PARAM.VACBPR_LEG,CLCAMT1,CLCAMT2,CONVPRI) From TRTX3_SYRA  : # Bug 84596"
Wrseq "#  Call CLCTAXEPRIV (PARAM.ACTX, CONVPRI,PARAM.C_LINE(NLG).C_VAT(1..maxtab(PARAM.C_LINE(NLG).C_VAT)).VAT,PARAM.C_LINE(NLG).C_VAT(1..maxtab(PARAM.C_LINE(NLG).C_VAT)).VAT_LEG"
Wrseq "#&                  ,WPRITYP,PARAM.CPY,DATCONVPRI,PARAM.C_LINE(NLG).QTY,PARAM.VACBPR,PARAM.VACBPR_LEG,CLCAMT1,CLCAMT2,CONVPRI) From TRTX3_SYRA  : # Bug 84596"
Wrseq "  Call CLCTAXEPRIV_ADAPTER(PARAM.ACTX, CONVPRI,PARAM.C_LINE(NLG).C_VAT(1..maxtab(PARAM.C_LINE(NLG).C_VAT)).VAT"
Wrseq "&                  ,WPRITYP,PARAM.CPY,DATCONVPRI,PARAM.C_LINE(NLG).QTY,PARAM.VACBPR,PARAM.VACBPR_LEG,CLCAMT1,CLCAMT2,CONVPRI) From TRTX3_SYRA  : # Bug 84596"
Wrseq "Endif"
  Endif
Wrseq "If CONVPRI<>0"
# Issue 122499
# En cas de nvelle recherche tarif groupé sans modif du doc, il faut réappliquer le tarif
#Wrseq "   If CONVPRI<PARAM.C_LINE(NLG).GROPRI | PARAM.C_LINE(NLG).PRIREN=0 | (PARAM.C_LINE(NLG).GROPRI=0 & UPDNULPRI=2)"
Wrseq "   If CONVPRI<=PARAM.C_LINE(NLG).GROPRI | PARAM.C_LINE(NLG).PRIREN=0 | (PARAM.C_LINE(NLG).GROPRI=0 & UPDNULPRI=2)"
# End issue 122499
Wrseq "      PARAM.C_LINE(NLG).GROPRI=arr(CONVPRI,10^-PARAM.GDECPRI) : PARAM.C_LINE(NLG).PRIREN=WPRIREN"
Wrseq "      PARAM.C_LINE(NLG).GRPFLG=1"
Wrseq "      CODENTPNT='G1'"
Wrseq "      RESULT.C_PRICE(1).PLI    = [F:SPL]PLI"
Wrseq "      RESULT.C_PRICE(1).PLICRD = [F:SPL]PLICRD"
Wrseq "      RESULT.C_PRICE(1).PLILIN = [F:SPL]PLILIN"
Wrseq "   Endif"
Wrseq "Endif"
Endif

# On traite les 9 colonnes frais/remises
For I=0 To NBRCOLONNE-1
  If find ([F:SPC]DISCRGPRO(I),1,3)          : # si colonne tarif geree ou initialisee
    INDR=num$(I)
    INDN=num$(I+1)
# Génération du libelle
    Wrseq ""
    Wrseq "# ";
    If [F:PRS]INCDCR(I)=1 : Wrseq "Frais-"; : Endif
    If [F:PRS]INCDCR(I)=2 : Wrseq "Remise-"; : Endif
    Wrseq INDN;" ";
    If [F:PRS]VALTYP(I)=1 : Wrseq "en Montant "; : Endif
    If [F:PRS]VALTYP(I)=2 : Wrseq "en %Cumul "; : Endif
    If [F:PRS]VALTYP(I)=3 : Wrseq "en %Cascade "; : Endif
    If [F:PRS]CLCRUL(I)=1 : Wrseq "par Unité "; : Endif
    If [F:PRS]CLCRUL(I)=2 : Wrseq "par Ligne "; : Endif
    If [F:PRS]CLCRUL(I)=3 : Wrseq "par Document "; : Endif
    If [F:SPC]DISCRGPRO(I)=3 : Wrseq "(Initialisation)"; : Endif
    Wrseq

    If [F:SPC]DISCRGPRO(I)=1                 : # si colonne tarif geree

#                Montant à la ligne ou unité

      If [F:PRS]VALTYP(I)=1 & [F:PRS]CLCRUL(I)<>3      : # si colonne montant par unite
Wrseq "CONVPRI=[F:SPL]DCGVAL(";INDR;")";TEX(1);TEX(3)
        If ICONV<>0
Wrseq "If [F:SPL]CUR<>PARAM.CUR | PARAM.C_LINE(NLG).SAU<>[F:SPL]UOM"
Wrseq "  Raz APDC_RND : APDC_CUR=PARAM.CUR : Gosub LECTCU : ";
         I1=instr(1,ATY_FORTYP(I+1),"=")
         If I1
Wrseq "APDC_FMT=";right$(ATY_FORTYP(I+1),I1+1)
         Else
#Gbn-78037
#Wrseq "APDC_FMT='";ATY_FORTYP(I+1);"'"
Wrseq "If PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);")<>null"
Wrseq "  If pat(PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);").GFMTCOL,'[F:TCU]') : APDC_FMT='' : Else : APDC_FMT=PARAM.FMTCOLREM(1).C_FMTCOL(";num$(I+1);").GFMTCOL : Endif"
Wrseq "Endif"
         Endif
Wrseq "  Gosub ARRFMT : CONVPRI=arr(CONVPRI,APDC_RND)"
Wrseq "Endif"
        Endif

        If [F:PRS]INCDCR(I)=1                : # c est une majoration
#--CPO
#Wrseq "If PARAM.C_LINE().C_DISCRG().DISCRGVAL";INDN;"(NLG-1)=0 | ";
Wrseq "If PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL = 0 | ";
# Bug 73486 : En cas de nvelle recherche tarif groupé sans modif du doc, il faut réappliquer le tarif
#Wrseq "[M]DISCRGVAL";INDN;"(NLG-1)>CONVPRI"
Wrseq "PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL>=CONVPRI"
# Bug 73486
       Else                                  : # c est une minoration
# Bug 73486 : En cas de nvelle recherche tarif groupé sans modif du doc, il faut réappliquer le tarif
#Wrseq "If [M]DISCRGVAL";INDN;"(NLG-1)<CONVPRI"
Wrseq "If PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL<=CONVPRI"
# Bug 73486
        Endif
Wrseq "  PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL=CONVPRI"
Wrseq "  PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGREN=WPRIREN"
Wrseq "  PARAM.C_LINE(NLG).GRPFLG=1"
Wrseq "  CODENTPNT='G1'"
Wrseq "  RESULT.C_DISCRG(";INDN;").PLI=[F:SPL]PLI : RESULT.C_DISCRG(";INDN;").PLICRD=[F:SPL]PLICRD : RESULT.C_DISCRG(";INDN;").PLILIN=[F:SPL]PLILIN"
Wrseq "Endif"
      Endif

#                Montant au document (trt sur 1ere ligne)

      If [F:PRS]VALTYP(I)=1 & [F:PRS]CLCRUL(I)=3       : # si colonne montant par document
Wrseq "PARAM.C_LINE(NLG).GRPFLG=1"                 : # 98934 : Grouped Price list that cumulate
Wrseq "If LIGMAJ=1"
Wrseq "  CONVPRI=[F:SPL]DCGVAL(";INDR;")";TEX(3)
        If ICONV<>0
Wrseq "  If [F:SPL]CUR<>PARAM.CUR"
#                   la valeur va dans le pied (arrondi devise obligatoire)
Wrseq "    Call ARRDEV(CONVPRI, PARAM.CUR, PARAM.CPY) From TRTDIV_SYRA"
Wrseq "  Endif"
        Endif
#                   on met la remise montant dans la rubrique d'appel
Wrseq "  RESULT.C_DISCRG(";INDN;").MONTANT= RESULT.C_DISCRG(";INDN;").MONTANT+CONVPRI"
Wrseq "  RESULT.C_DISCRG(";INDN;").MOTIF  = [F:PRS]INVDTA(";INDR;")"
Wrseq "  CODENTPNT='G1'"
Wrseq "  RESULT.C_DISCRG(";INDN;").PLI=[F:SPL]PLI : RESULT.C_DISCRG(";INDN;").PLICRD=[F:SPL]PLICRD : RESULT.C_DISCRG(";INDN;").PLILIN=[F:SPL]PLILIN"
Wrseq "Endif"
      Endif

#                % ligne

      If [F:PRS]VALTYP(I)>1                            : # c est une colonne pourcentage
        If [F:PRS]INCDCR(I)=1                : # c est une majoration
Wrseq "If PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL=0 | ";
# Bug 73486 : En cas de nvelle recherche tarif groupé sans modif du doc, il faut réappliquer le tarif
#Wrseq "[M]DISCRGVAL";INDN;"(NLG-1)>[F:SPL]DCGVAL(";INDR;")"
Wrseq "PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL>=[F:SPL]DCGVAL(";INDR;")"
# Bug 73486
        Else                                 : # c est une minoration
# Bug 73486 : En cas de nvelle recherche tarif groupé sans modif du doc, il faut réappliquer le tarif
#Wrseq "If [M]DISCRGVAL";INDN;"(NLG-1)<[F:SPL]DCGVAL(";INDR;")"
Wrseq "If PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL<=[F:SPL]DCGVAL(";INDR;")"
# Bug 73486
        Endif
Wrseq "  PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL=[F:SPL]DCGVAL(";INDR;")"
Wrseq "  PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGREN=WPRIREN"
Wrseq "  PARAM.C_LINE(NLG).GRPFLG=1"
Wrseq "  CODENTPNT='G1'"
Wrseq "  RESULT.C_DISCRG(";INDN;").PLI=[F:SPL]PLI : RESULT.C_DISCRG(";INDN;").PLICRD=[F:SPL]PLICRD : RESULT.C_DISCRG(";INDN;").PLILIN=[F:SPL]PLILIN"
Wrseq "Endif"
      Endif
    Endif

#                Frais/rem Initialisation

    If [F:SPC]DISCRGPRO(I)=3                 : # colonne tarif a initialiser
      If [F:PRS]CLCRUL(I)=3                  : # colonne par document
Wrseq "RESULT.C_DISCRG(";INDN;").MONTANT=0"
Wrseq "RESULT.C_DISCRG(";INDN;").MOTIF=0"
Wrseq "PARAM.C_LINE(NLG).GRPFLG=1"                 : # 98934 : Grouped Price list that cumulate
Wrseq "CODENTPNT='G1'"
Wrseq "RESULT.C_DISCRG(";INDN;").PLI=[F:SPL]PLI : RESULT.C_DISCRG(";INDN;").PLICRD=[F:SPL]PLICRD : RESULT.C_DISCRG(";INDN;").PLILIN=[F:SPL]PLILIN"
      Else                                   : # colonne par unite ou par ligne
Wrseq "PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGVAL=0"
Wrseq "PARAM.C_LINE(NLG).C_DISCRG(";INDN;").DISCRGREN=0"
Wrseq "PARAM.C_LINE(NLG).GRPFLG=1"
Wrseq "CODENTPNT='G1'"
Wrseq "RESULT.C_DISCRG(";INDN;").PLI=[F:SPL]PLI : RESULT.C_DISCRG(";INDN;").PLICRD=[F:SPL]PLICRD : RESULT.C_DISCRG(";INDN;").PLILIN=[F:SPL]PLILIN"
      Endif

    Endif
  Endif
Next I
Wrseq "Return"

Return

#------------------------------------------------------------------------
# tarif interdit : génération traitement
#------------------------------------------------------------------------
$TR_INTERDIT
Gosub LE_FILTRE
Wrseq "For [SPL]"
Wrseq "RESULT.INTERDIT=1 : Break"
Wrseq "Next"
Wrseq "Filter [SPL]"
Wrseq "End"
Return

#------------------------------------------------------------------------
# Constitution de l'arrondi en fonction d'un format
# (utilise pour les arrondis des colonnes frais/remises
#------------------------------------------------------------------------
$FORMAT_ARRONDI
Wrseq "#------------------------------------------------------------------------"
Wrseq "# Constitution de l'arrondi en fonction d'un format"
Wrseq "#------------------------------------------------------------------------"
Wrseq "# Utilisé notamment dans la recherche tarif pour les colonnes frais/rem"
Wrseq "# Entree : APDC_CUR = Code devise"
Wrseq "# Entrée : APDC_FMT = Format sous la forme 12.4#"
Wrseq "# Sortie : APDC_RND = Arrondi sous la forme 0.0001 (pour instruction arr)"
Wrseq "#------------------------------------------------------------------------"
Wrseq "$LECTCU"
Wrseq "If APDC_CUR='' : APDC_CUR=PARAM.GLOCALDEV : Endif"
#Wrseq "If clalev([F:TCU])<=0 : Local File TABCUR [TCU] : Endif" :#--CPO
Wrseq "If APDC_CUR<>[F:TCU]CUR"
Wrseq "   Read [TCU]TCU0=APDC_CUR"
Wrseq "Endif"
Wrseq "Return"
Wrseq "$ARRFMT"
Wrseq "APDC_RND=min([F:TCU]CURRND,10^-(mod(val(APDC_FMT),1)*10))"
Wrseq "Return"
Wrseq "#------------------------------------------------------------------------"
Return

#------------------------------------------------------------------------
# Filtre sur les critères:
#   pour lecture des lignes de la fiche qui répondent aux critères
#   Utilisé si objet utilisé à partir de la recherche tarif FUNVENSPSI
#------------------------------------------------------------------------
$FILTRE_CRITERES
Wrseq ""
Wrseq "#-----------------------------------------------------------------"
Wrseq "# Pour visualiser uniquement les lignes de la fiche répondant"
Wrseq "# aux critères ( utilisé dans la simulation )"
Wrseq "#-----------------------------------------------------------------"
Wrseq "$FILTRE_CRITERES"
Wrseq "# Les critères existent ?"
For I=0 To 4
 If [F:SPC]ABB(I)<>""
  Wrseq "If dim([F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(";[F:SPC]CRIIND(I);")) < 0 : Return : Endif"
 Endif
Next I
Wrseq 'CRIT += " & PLICRI=';
For I=0 To 4
  If I>0 : Wrseq "+"; : Endif
  If [F:SPC]FLD(I)<>""
     If [F:SPC]FLDTYP(I)="CCE"
        Wrseq "num$([F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(max(find('";[F:SPC]CRIDIE(I);"',[F:";[F:SPC]ABB(I);"]DIE)-1,0)))+'~'";
     Elsif [F:SPC]FLDTYP(I)="D"     : # si critere de type date
        Wrseq "num$(val([F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(";[F:SPC]CRIIND(I);")))+'~'";
     Else                       : # autres types
        Wrseq "num$([F:";[F:SPC]ABB(I);"]";[F:SPC]FLD(I);"(";[F:SPC]CRIIND(I);"))+'~'";
     Endif
  Else
     Wrseq "'~'";
  Endif
Next
Wrseq '"'
Wrseq "Return"

Wrseq "#-----------------------------------------------------------------"
Return

#------------------------------------------------------------------------
# Type de donnée des critères:
#   pour permettre la gestion correcte de tous les types de données
#   ( y compris ceux définis par l'utilisateur )
#------------------------------------------------------------------------
$TYPE_CRITERES
#If clalev([F:ATY])=0 : Local File ATYPE [ATY] : ATYOPEN=1 : Endif
Local Char WFLDTYPINT (3)
Wrseq ""
Wrseq "#-----------------------------------------------------------------"
Wrseq "# Pour connaitre le type de donnée des critères "
Wrseq "# Fournir le type de donnée dans FLDTYPEXT  ( ex : BPC, ADI, ...)"
Wrseq "# Pour récuperer FLDTYPINT ( M, C, L, DCB, A, D )"
Wrseq "#-----------------------------------------------------------------"
Wrseq "$TYPE_CRITERES"
Wrseq "Local char    TFLDTYPEXT (3) (0..5)"
Wrseq "Local char    TFLDTYPINT (3) (0..5)"
Wrseq "Local Integer IJLS"
Wrseq "If dim(FLDTYPEXT)>0 & dim(FLDTYPINT)>0"

For I=0 To 4
 If [F:SPC]ABB(I)<>""
   Read [ATY] CODTYP=[F:SPC]FLDTYP(I)
   If fstat
Wrseq "  TFLDTYPEXT(";num$(I);")='";num$([F:SPC]FLDTYP(I));"' : TFLDTYPINT(";num$(I);")='A'"
   Else
     Case [F:ATY]TYPTYP
       When 1      : WFLDTYPINT="M"    : # Menu local
       When 2      : WFLDTYPINT="C"    : # Entier court
       When 3      : WFLDTYPINT="L"    : # Entier long
       When 4,5,6  : WFLDTYPINT="DCB"  : # Decimal, Flottant, Double
       When 7      : WFLDTYPINT="A"    : # Alpha
       When 8      : WFLDTYPINT="D"    : # Date
     Endcase
Wrseq "  TFLDTYPEXT(";num$(I);")='";num$([F:SPC]FLDTYP(I));"' : TFLDTYPINT(";num$(I);")='";WFLDTYPINT;"'"
   Endif
 Endif
Next I

Wrseq "  IJLS = find (FLDTYPEXT,TFLDTYPEXT)"
Wrseq "  If IJLS : FLDTYPINT=TFLDTYPINT(IJLS-1) : Endif"
Wrseq "Endif"
Wrseq "Return"

Wrseq "#-----------------------------------------------------------------"

#If ATYOPEN=1 : Close Local File [ATY] : Endif

Return

#------------------------------------------------------------------------
# Extraction des lignes de tarif pour la consultation dans FUNVENSPSI
#   stockage dans le masque SPSIMUL0
#------------------------------------------------------------------------
$CONSULTATION

#--CPO Dépassement du nombre d'instructions possible
Gosub CONSULTATION From SUBSPCTB_SYRA

Return
#------------------------------------------------------------------------
# Import de tarif: Raz des zones non accessibles lors du paramétrage mais
#                  qui ont pu être alimentées par le paramétrage du modèle
#                  d'import
#------------------------------------------------------------------------
$INI_IMPORT
Wrseq ""
Wrseq "#-----------------------------------------------------------------"
Wrseq "# Traitment appelé par Gosub dans l'import de tarif"
Wrseq "# init. de la classe F des zones non saisissables pour ce tarif"
Wrseq "#-----------------------------------------------------------------"
Wrseq "$INI_IMPORT"
Wrseq "Raz [F:SPL]PLICRI1, [F:SPL]PLICRI2, [F:SPL]PLICRI3, [F:SPL]PLICRI4, [F:SPL]PLICRI5"
Wrseq "Raz [F:SPL]CPNITMREF"
For I=1 To 5
  If [F:SPC]FLD(I-1)=""
    Wrseq "Raz GIMP("+num$(I)+")          : # Critere "+num$(I)
  Endif
Next
If ZZ(7)=0  : Wrseq "Raz [F:SPL]CUR        : # Devise"               : Endif
If ZZ(8)=0  : Wrseq "Raz [F:SPL]UOM        : # Unite"                : Endif
If ZZ(9)=0  : Wrseq "Raz [F:SPL]MINQTY     : # Qte mini"             : Endif
If ZZ(10)=0 : Wrseq "Raz [F:SPL]MAXQTY     : # Qte maxi"             : Endif
If ZZ(12)=0 : Wrseq "Raz [F:SPL]PRIDIV     : # Diviseur prix"        : Endif
If ZZ(13)=0 : Wrseq "Raz [F:SPL]PRI        : # Prix"                 : Endif
If ZZ(14)=0 : Wrseq "Raz [F:SPL]DCGVAL(0)  : # Frais/remise 1"       : Endif
If ZZ(15)=0 : Wrseq "Raz [F:SPL]DCGVAL(1)  : # Frais/remise 2"       : Endif
If ZZ(16)=0 : Wrseq "Raz [F:SPL]DCGVAL(2)  : # Frais/remise 3"       : Endif
If ZZ(17)=0 : Wrseq "Raz [F:SPL]DCGVAL(3)  : # Frais/remise 4"       : Endif
If ZZ(18)=0 : Wrseq "Raz [F:SPL]DCGVAL(4)  : # Frais/remise 5"       : Endif
If ZZ(19)=0 : Wrseq "Raz [F:SPL]DCGVAL(5)  : # Frais/remise 6"       : Endif
If ZZ(20)=0 : Wrseq "Raz [F:SPL]DCGVAL(6)  : # Frais/remise 7"       : Endif
If ZZ(21)=0 : Wrseq "Raz [F:SPL]DCGVAL(7)  : # Frais/remise 8"       : Endif
If ZZ(22)=0 : Wrseq "Raz [F:SPL]DCGVAL(8)  : # Frais/remise 9"       : Endif
If ZZ(23)=0 : Wrseq "Raz [F:SPL]FOCQTYMIN  : # Qte mini gratuite"    : Endif
#If ZZ(24)=0 : Wrseq "Raz [F:SPL]FOCBKT    : # Seuil gratuite"       : Endif
If ZZ(25)=0 : Wrseq "Raz [F:SPL]FOCITMREF  : # Article gratuit"      : Endif
If ZZ(26)=0 : Wrseq "Raz [F:SPL]FOCUOM     : # Unite du gratuit"     : Endif
If ZZ(27)=0 : Wrseq "Raz [F:SPL]FOCQTY     : # Qte gratuite"         : Endif
If ZZ(28)=0 : Wrseq "[F:SPL]COMCOE=1       : # Coef. commission"     : Endif
If ZZ(29)=0 : Wrseq "Raz [F:SPL]MINAMT     : # Montant mini"         : Endif
If ZZ(30)=0 : Wrseq "Raz [F:SPL]MAXAMT     : # montant maxi"         : Endif
If ZZ(31)=0 : Wrseq "Raz [F:SPL]FOCAMTMIN  : # Prix mini gratuite"   : Endif
If ZZ(32)=0 : Wrseq "Raz [F:SPL]FOCQTYBKT  : # Qte seuil gratuite"   : Endif
If ZZ(33)=0 : Wrseq "Raz [F:SPL]FOCAMTBKT  : # Prix seuil gratuite"  : Endif

Wrseq "Return"

Wrseq "#-----------------------------------------------------------------"

Return
#------------------------------------------------------------------------
$READFIL

Case WSPCFIL

  When "ITMMASTER" :
                    Wrseq "Read [F:ITM]ITM0=PARAM.C_LINE(PLINEDOC).ITMREF"
                    Wrseq "If fstat : Raz [F:ITM] : Endif"
                    Wrseq ""
  When "BPCUSTOMER":
                    Wrseq "Read [F:BPC]BPC0=PARAM.BPCNUM"
                    Wrseq "If fstat : Raz [F:BPC] : Endif"
                    Wrseq ""
  When "ITMSALES"  :
                    Wrseq "Read [ITS]ITS0=PARAM.C_LINE(PLINEDOC).ITMREF"
                    Wrseq "If fstat : Raz [F:ITS] : Endif"
                    Wrseq ""
  When "ITMFACILIT"
                    Wrseq "Raz WSTOFCY"
                    #--CPO 98402
                    #Wrseq "If dim(PARAM.C_LINE(PLINEDOC).STOFCY)>0   [L]WSTOFCY=PARAM.C_LINE(PLINEDOC).STOFCY"
                    Wrseq "If dim(PARAM.C_LINE(PLINEDOC).STOFCY)>0 and PARAM.C_LINE(PLINEDOC).STOFCY<>''"
                    Wrseq "  [L]WSTOFCY=PARAM.C_LINE(PLINEDOC).STOFCY"
                    Wrseq "Elsif dim(PARAM.FCY)>0"
                    Wrseq "  [L]WSTOFCY=PARAM.FCY"
                    Wrseq "Endif"
                    Wrseq ""
                    Wrseq "Read [ITF]ITF0=PARAM.C_LINE(PLINEDOC).ITMREF;[L]WSTOFCY"
                    Wrseq "If fstat : Raz [F:ITF] : Endif"
                    Wrseq ""
  When "BPARTNER"
                    Wrseq "Read [F:BPR]BPR0=PARAM.BPCNUM"
                    Wrseq "If fstat : Raz [F:BPR] : Endif"
                    Wrseq ""
  When "BPCUSTMVT"

  When "BPDLVCUST"
                    Wrseq "Raz WBPAADD"
                    #--CPO 98402
                    #Wrseq "If dim(PARAM.C_LINE(PLINEDOC).BPAADD)>0   [L]WBPAADD=PARAM.C_LINE(PLINEDOC).BPAADD"
                    Wrseq "If dim(PARAM.C_LINE(PLINEDOC).BPAADD)>0 and PARAM.C_LINE(PLINEDOC).BPAADD<>''"
                    Wrseq "  [L]WBPAADD=PARAM.C_LINE(PLINEDOC).BPAADD"
                    Wrseq "Elsif dim(PARAM.BPAADD)>0"
                    Wrseq "  [L]WBPAADD=PARAM.BPAADD"
                    Wrseq "Endif"
                    Wrseq ""
                    Wrseq "Read [BPD]BPD0=PARAM.BPCNUM;[L]WBPAADD"
                    Wrseq "If fstat : Raz [F:BPD] : Endif"
                    Wrseq ""
  When "SALESREP"
                    Wrseq "If PARAM.C_LINE(PLINEDOC).C_REP(1)<>null "
                    Wrseq "  Read [REP]REP0=PARAM.C_LINE(PLINEDOC).C_REP(1).REP"
                    Wrseq "  If fstat : Raz [F:REP] : Endif"
                    Wrseq "Endif"
  When "SPRICLINK" :#--Ne rien mettre ici car lecture systématique plus haut...
  When Default : GOK=0 :
Endcase

Return

