#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIHDK201805001
# Issue X3-90641 - 2018-06-04 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIHDK201805001(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIHDK201805001(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer NCOUNTERROR
Local Char AREQ(250)(0..)
Local Integer IAREQ

  Call ECR_TRACE("UTIHDK201805001: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".CONTCOV" [CCV]
  # -----------------
  Raz COMPTEUR
  # -----------------
  Trbegin [CCV]
  # -----------------
  Raz AREQ
  IAREQ = -1
  IAREQ += 1 : AREQ(IAREQ) -= "SELECT A.CONNUM_0, A.TPL_0, A.RECTYP_0, A.SBBRECTYP_0, A.RECNUM_0"
  IAREQ += 1 : AREQ(IAREQ) -= "FROM "+ DOSSIER + ".CONTCOV A"
  IAREQ += 1 : AREQ(IAREQ) -= "WHERE (SELECT COUNT(*)"
  IAREQ += 1 : AREQ(IAREQ) -= "       FROM "+ DOSSIER + ".CONTCOV B"
  IAREQ += 1 : AREQ(IAREQ) -= "       WHERE B.CMT_0 = A.CMT_0 and B.CONNUM_0 = A.CONNUM_0"
  IAREQ += 1 : AREQ(IAREQ) -= "      ) > 1"
  IAREQ += 1 : AREQ(IAREQ) -= "  and A.CPNSRT_0 = 'CMACMAC'"
  IAREQ += 1 : AREQ(IAREQ) -= "  and A.LNDAUZ_0 = 0 and A.CPNICDFLG_0 = 0 and A.LABICDFLG_0 = 0 and A.EXSICDFLG_0 = 0"
  For (Char CONNUM(GLONCON), Integer TPL, Char RECTYP(3), Char SBBRECTYP(3), Char RECNUM(30))
&           From num$(GTYPDBA*2+1) Sql AREQ As [WWW]
    Filter [CCV] Where [F:CCV]CONNUM = [F:WWW]CONNUM and [F:CCV]TPL = [F:WWW]TPL and [F:CCV]RECTYP = [F:WWW]RECTYP and [F:CCV]SBBRECTYP = [F:WWW]SBBRECTYP and [F:CCV]RECNUM = [F:WWW]RECNUM
    For [CCV]
      If [F:CCV]LNDAUZ = 0 and [F:CCV]CPNICDFLG = 0 and [F:CCV]LABICDFLG = 0 and [F:CCV]EXSICDFLG = 0 Then
        Delete [CCV]Curr
        COMPTEUR += 1
        If fstat Then
          Call ECR_TRACE("File CONTCOV" - num$([F:CCV]CONNUM) -  num$([F:CCV]TPL) -  num$([F:CCV]RECTYP) -  num$([F:CCV]SBBRECTYP) - num$([F:CCV]RECNUM) -  + ", Error =" - num$(fstat), 1)
&              From GESECRAN
          GOK = 1
          IERR = 1
          NCOUNTERROR += 1
        Endif
      Endif
    Next
    Filter [CCV]
  Next
  # -----------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIHDK201805001 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIHDK201805001 : records processed with error(s).", 0) From GESECRAN
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","CONTCOV","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "CONTCOV") : End : Endif
  # -------------------------
  Call MAJ_UTIHDK201805001(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","CONTCOV","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "CONTCOV") : End : Endif
  # -------------------------
  Call MAJ_UTIHDK201805001(APPLI)
End

