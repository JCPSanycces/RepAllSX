#<AdxTL>@(#)0.0.0.0 $Revision$
Call OBJET("IPM",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
## Section automatically added (Object IPM) 01/12/2016 09:11:07 (JUCON)
######################################################################################
$ACTION
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "RAZCRE"       : Gosub RAZCRE
  When "SETBOUT"      : Gosub SETBOUT
  When "CREATION"     : Gosub CREATION
  When "MODIF"        : Gosub MODIF
  When "LIENS"        : Gosub LIENS
  When "ANNULE"       : Gosub ANNULE
  When Default
Endcase
Return


######################################################################################
$OUVRE
If clalev([F:IPM])=0  : Local File IMURANO    [IPM]  : Endif
If clalev([F:IPMD])=0 : Local File IMURANOD   [IPMD] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:GAU])=0  : Local File GAUTACE    [GAU]  : Endif
If clalev([F:CAC])=0  : Local File GACCCODE   [CAC]  : Endif
If clalev([F:CDE])=0  : Local File CACCEDEF   [CDE]  : Endif
If clalev([F:ATX])=0  : Local File ATEXTE     [ATX]  : Endif
If clalev([F:AOR])=0  : Local File AOBJEXTR   [AOR]  : Endif
If clalev([F:DIE])=0  : Local File GDIE       [DIE]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
If clalev([F:COA])=0  : Local File GCOA       [COA]  : Endif
Return

######################################################################################
$CREATION
$MODIF
  Gosub CONTROL_TABS
  If GOK<1 : Return : Endif
  Gosub ANNULE
  If GOK<1 : Return : Endif
  Raz [F:IPM]
  [F:IPM]=[M:IPM0]
  [F:IPM]IDENT1=[M:IPM0]CPY+[M:IPM0]FCY
  [F:IPM]=[M:IPM1]
  Write [IPM]
  If fstat : GOK=0 : Call FSTA("IPM") From GLOCK : Endif

  Raz [F:IPMD]
  For I=0 To [M:IPM2]NBCLIG-1
    [F:IPMD]=[M:IPM0]
    [F:IPMD]LINNUM=I+1
    [F:IPMD]FLGACT =[M:IPM2]FLGACT(I)
    [F:IPMD]CODDES =[M:IPM2]CODDES(I)
    [F:IPMD]INIPOS =[M:IPM2]INIPOS(I)
    [F:IPMD]ENDPOS =[M:IPM2]ENDPOS(I)
    [F:IPMD]LENGHT =[M:IPM2]LENGHT(I)
    [F:IPMD]SENSE  =[M:IPM2]SENSE(I)
    [F:IPMD]ACCCOD =[M:IPM2]ACCCOD(I)
    [F:IPMD]CCEDEFL=[M:IPM2]CCEDEFL(I)
    Write [IPMD]
    If fstat : GOK=0 : Call FSTA("IPMD") From GLOCK : Break : Endif
  Next

Return

#########################################################################################
$SETBOUT
  If GACTX.ALLACS<>2
    GBIDC2="S"
    Gosub AUTORIS_OPT From CONTX3
  Else
    GBIDI2=1
  Endif
  If GBIDI2  : CHAINE="A"+CHAINE:  Endif
Return

#########################################################################################
$LIENS
  Local Integer I
  Filter [IPM] Where CPY=[M:IPM0]CPY and FCY=[M:IPM0]FCY and LEG=[M:IPM0]LEG
  [M:IPM0]=[F:IPM]

  For I=0 To maxtab([M:IPM1]HEAVALNAM)
    If [M:IPM1]HEAVALNAM(I)=0: Break: Endif
    [M:IPM1]=[F:IPM]
    [M:IPM1]NBLIG=I+1
    Affzo [M:IPM1]NBLIG
  Next
  Affzo [M:IPM0]
  Affzo [M:IPM1]
  Filter [IPM]
  I=0
  Filter [IPMD] Where CPY=[M:IPM0]CPY and FCY=[M:IPM0]FCY and LEG=[M:IPM0]LEG
  For [IPMD]
    [M:IPM2]FLGACT(I) =[F:IPMD]FLGACT
    [M:IPM2]CODDES(I) =[F:IPMD]CODDES
    [M:IPM2]INIPOS(I) =[F:IPMD]INIPOS
    [M:IPM2]ENDPOS(I) =[F:IPMD]ENDPOS
    [M:IPM2]LENGHT(I) =[F:IPMD]LENGHT
    [M:IPM2]SENSE(I)  =[F:IPMD]SENSE
    [M:IPM2]ACCCOD(I) =[F:IPMD]ACCCOD
    [M:IPM2]CCEDEFL(I)=[F:IPMD]CCEDEFL
    [M:IPM2]NBCLIG=[F:IPMD]LINNUM
    I+=1
    Affzo [M:IPM2]NBCLIG
  Next
  Affzo [M:IPM2]
  Filter [IPMD]
Return

######################################################################################
$RAZCRE
    Raz   [M:IPM0],[M:IPM1],[M:IPM2]
    Affzo [M:IPM0]
    Affzo [M:IPM1]
    Affzo [M:IPM2]
Return

######################################################################################
$ANNULE
  Delete [IPMD] Where CPY=[M:IPM0]CPY and FCY=[M:IPM0]FCY and LEG=[M:IPM0]LEG
  If fstat=1  : GOK=-1 : Call RSTA("IPMD","") From GLOCK : Return : Endif
  Delete [IPM] Where CPY=[M:IPM0]CPY and FCY=[M:IPM0]FCY and LEG=[M:IPM0]LEG
  If fstat=1  : GOK=-1 : Call RSTA("IPM","") From GLOCK : Return : Endif
Return

######################################################################################
## Section automatically added (screen IPM0) 01/12/2016 09:25:10 (JUCON)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
  Local Char WLEG(5)
  If VALEUR<>""
    Read [F:CPY]CPY0=VALEUR
    If fstat=[V]CST_AOK
      If [F:CPY]CPYLEGFLG=2
        Read [FCY]FCY0=[F:CPY]MAIFCY
        If fstat=[V]CST_AOK: [M]FCY=[F:FCY]FINRSPFCY: Endif
        WLEG=[F:CPY]LEG
        If [M]LEG<>WLEG: Gosub RAZ_MSK: Endif
        Actzo [M]LEG
        [M]LEG=WLEG
        Affzo [M]LEG, FCY
        Diszo [M]LEG  # Legislation to disable
      Else
        GMESSAGE = mess(12,199,1)
        mkstat = 2 : End
      Endif
    Endif
  Endif
  If VALEUR="" and [M]FCY=""
    Actzo [M]LEG
    [M]LEG=""
    Affzo [M]LEG # Legislation to available
  Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
  If [M]CPY="" and [M]LEG="": VALEUR=GFCYDEF(1):  Endif
End

Subprog AM_FCY(VALEUR)
Variable Char   VALEUR()
  Local Char WLEG(5)
  If VALEUR<>""
    Read [F:FCY]FCY0=VALEUR
    If fstat=[V]CST_AOK
      [M]CPY=[F:FCY]LEGCPY
      WLEG=[F:FCY]LEG
      Affzo [M]CPY
    Endif
    If [M]LEG<>WLEG: Gosub RAZ_MSK: Endif
    Actzo [M]LEG
    [M]LEG=[F:FCY]LEG
    Affzo [M]LEG
    Diszo [M]LEG  # Legislation to disable
  Else
    If [M]CPY=""
      Actzo [M]LEG
      [M]LEG=""
      Affzo [M]LEG # Legislation to available
      Gosub RAZ_MSK
    Endif
  Endif

End

Subprog AS_LEG(VALEUR)
Variable Char    VALEUR()
  If [M]CPY="" and [M]FCY=""
    Actzo [M]LEG
    If GLEGFIL<>"": [M]LEG=GLEGFIL: Affzo LEG: Endif
  Else
    Effzo [M]LEG
    Diszo [M]LEG
  Endif
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>[M]LEG
    Gosub RAZ_MSK
  Endif
End

Subprog AV_DES(VALEUR)
Variable Char    VALEUR()
  If [M:IPM0]CPY="" and [M:IPM0]FCY="" and [M:IPM0]LEG=""
    [M:IPM0]DES=""
  Endif
End

Subprog AM_DES(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>[M:IPM0]DES
    [M:IPM0]DES=VALEUR
    Call MAJTEXTRA ([M:IPM0]DES,"IMURANO","DES",[M:IPM0]CPY+[M:IPM0]FCY,[M:IPM0]LEG) From ATEXTRA
  Endif
End

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
  Local Integer I, WLEGOK
  If VALEUR<>""
    Read [GAU]GAU0=VALEUR
    If fstat=[V]CST_AOK
      For I=0 To [F:GAU]NBRLEG-1
        If [F:GAU]ACTLEG(I)=[M]LEG: WLEGOK=1: Break: Endif
      Next
    Endif
  Endif

  If WLEGOK=0
    GMESSAGE = mess(25,188,1)+"."- mess(379,194,1)  #Value not allowed for this legislation
    mkstat = 2
  Endif
End

Subprog C_SEPDEC(VALEUR)
Variable Char    VALEUR()
  Local Integer I

  I=find(VALEUR,"",",",".")
  If I=0
   GMESSAGE= mess(394,9900,1)-mess(189,104,1)+"."
   mkstat=2   #Allowed characters: Blank, comma and dot
  Endif
End

Subprog AM_SEPDEC(VALEUR)
Variable Char    VALEUR()
  Local Integer I, WNL, WVAL
  [M:IPM0]SEPDEC=VALEUR
  For I=0 To [M:IPM2]NBCLIG-1
    WVAL=[M:IPM2]ENDPOS(I)+1
    Gosub INIT_LENGHT
  Next

End

Subprog C_NUMDEC(VALEUR)
Variable Decimal VALEUR
  Local Integer I
  I=find([M:IPM0]SEPDEC,",",".")
  If I<>0 and VALEUR=0
    GMESSAGE=mess(10,123,1) # Mandatory Field
    mkstat=2
  Endif
End

Subprog AM_NUMDEC(VALEUR)
Variable Decimal VALEUR
  Local Integer I, WNL, WVAL
  Local Char WLENG (15)

  [M:IPM0]NUMDEC=VALEUR
  For I=0 To [M:IPM2]NBCLIG-1
    WVAL=[M:IPM2]ENDPOS(I)+1
    Gosub INIT_LENGHT
  Next
End

Subprog AM_CCEDEF(VALEUR)
Variable Char    VALEUR()
  Local Char WCPY(5), WERR(250)
  Local Integer WOKK, WNBR

  If VALEUR<>""
    Gosub CONTROL_CDE
    If WERR<>""
      GMESSAGE=WERR
      mkstat=2
    Endif

  Endif
End

Subprog AS_SEPREC(VALEUR)
Variable Char    VALEUR()
  If [M:IPM0]SEPREC=""
    VALEUR = "\013\010"
  Endif

End

Subprog C_SEPREC(VALEUR)
Variable Char     VALEUR
  Local Integer C
  Local Char  SEP1(10)
  SEP1 = VALEUR
  If left$(SEP1,1)="\"
    C = val(mid$(SEP1,2,3))
    If C=0 | C>255
      GMESSAGE = mess(134,141,1) : # Syntax error
      mkstat = 1 : End
    Else
      SEP1 = right$(VALEUR,5)
    Endif
  Else
    SEP1 = right$(VALEUR,2)
  Endif
  If left$(SEP1,1)="\"
    C = val(right$(SEP1,2))
    If C=0 | C>255
      mkstat = 1 : End
    Elsif len(SEP1)>4
      GMESSAGE = mess(33,126,1) : # Key too long
      mkstat = 1 : End
    Endif
  Elsif len(SEP1)>1
    GMESSAGE = mess(33,126,1) : # Key too long
    mkstat = 1 : End
  Endif
End

Subprog AM_FLGDET(VALEUR)
Variable Integer VALEUR
  Local Char WERR(250)

  If clalev([F:KPH])=0  : Local File KPYIMPHDR  [KPH]  : Endif

  If [M:IPM0]FCY<>""
    Filter [KPH] Where FCY=[M:IPM0]FCY and CPY=[M:IPM0]CPY and STA<>2
    If rowcount([F:KPH])>0: WERR=mess(194,104,1) : Endif  # Modification impossible.. Not posted records found for this setup
    Filter [KPH]
  Endif

  If [M:IPM0]CPY<>"" and [M:IPM0]FCY="" and WERR=""
    Filter [KPH] Where CPY=[M:IPM0]CPY and STA<>2
    If rowcount([F:KPH])>0: WERR=mess(194,104,1) : Endif  # Modification impossible.. Not posted records found for this setup
    Filter [KPH]
  Endif

  If [M:IPM0]CPY="" and [M:IPM0]FCY="" and WERR=""
    For [CPY]  Where LEG=[M:IPM0]LEG
      Filter [KPH] Where CPY=[F:CPY]CPY and STA<>2
      If rowcount([F:KPH])>0: WERR=mess(194,104,1): Break : Endif  # Modification impossible.. Not posted records found for this setup
    Next
    Filter [CPY]
    Filter [KPH]
  Endif

  If WERR<>"": GMESSAGE=WERR: mkstat=2: Endif
End




######################################################################################
## Section automatically added (screen IPM1) 01/12/2016 11:12:25 (JUCON)
######################################################################################
Subprog C_HEAVALNAM(VALEUR)
Variable Integer VALEUR

 Call UNICITE(VALEUR, [M:IPM1]HEAVALNAM(0..[M:IPM1]NBLIG-1)) From OBJDIV   # Code already exists on line

End

Subprog AM_HEAVALNAM(VALEUR)
Variable Integer VALEUR
  Local Integer NOL:  NOL=nolign-1
  Gosub CHANGE_VALUES
End

Subprog AP_HEAVALNAM(VALEUR)
Variable Integer VALEUR
  Local Integer NOL:  NOL=nolign-1
  Gosub CHANGE_VALUES
End

Subprog C_HEAVALINI(VALEUR)
Variable Decimal VALEUR
  Local Integer WKO, WPOS, NOL: NOL=nolign-1
  Local Integer WTAB   #WTAB=1: Field WTAB=2 : Concepts
  WTAB=1

  [M:IPM1]HEAVALINI(NOL)=VALEUR
  Gosub CONTROL_POSITIONS

  If WKO=0 and  VALEUR<>0: [M:IPM1]HEAVALEND(NOL)=VALEUR: Affzo [M:IPM1]HEAVALEND(NOL)
  Elsif WKO=1
    GMESSAGE=func AFNC.MES1(mess(1,10721,1),num$(WPOS))
    mkstat=2
  Elsif WKO=2
    GMESSAGE=mess(63,105,1)-mess(182,104,1)+"."-func AFNC.MES1(mess(1,10721,1),num$(WPOS))
    mkstat=2
  Endif
End

Subprog AM_HEAVALINI(VALEUR)
Variable Decimal VALEUR
  Local Integer NOL: NOL=nolign-1
  If VALEUR<>0: [M:IPM1]HEAVALEND(NOL)=VALEUR: Affzo [M:IPM1]HEAVALEND(NOL):  Endif
  If [M:IPM1]HEAVALNAM(NOL)=5: Diszo [M:IPM1]HEAUSEVAL(NOL): Endif
End

Subprog C_HEAVALEND(VALEUR)
Variable Decimal VALEUR
  Local Integer WKO, NOL:  NOL=nolign-1
  Local Integer WTAB   #WTAB=1: Field WTAB=2 : Concepts
  WTAB=1

  If VALEUR<[M:IPM1]HEAVALINI(NOL): GMESSAGE=mess(757,196,1): mkstat=2: End: Endif #  This value must not be less than the first.

  Gosub CONTROL_POSITIONS

  If WKO=1
    GMESSAGE=func AFNC.MES1(mess(1,10721,1),num$(WPOS))
    mkstat=2
  Elsif WKO=2
    GMESSAGE=mess(63,105,1)-mess(182,104,1)+"."-func AFNC.MES1(mess(1,10721,1),num$(WPOS))
    mkstat=2
  Endif

End


Subprog S_HEAUSEVAL(VALEUR)
Variable Char    VALEUR()
  Local Integer NOL: NOL=nolign-1

  If [M:IPM1]HEAVALNAM(NOL)=5: End: Endif

  Case [M:IPM1]HEAVALNAM(NOL)
    When 3: If clalev([F:AST])=0: Local File APLSTD [AST]: Endif
            Choose [AST] Where LANCHP=2015 and LAN=GLANGUE and LANNUM<>0 Using LANMES Titled "" Sized (112,80) Titled mess(86,100,1)
            Case status
              When 0       : Call MESSAGE(mess(99,100,1)) From GESECRAN
              When 7
              When Default : VALEUR = [AST]LANMES: [M:IPM1]NOLIB(NOL)=[AST]LANNUM
            Endcase
    When 4: Local Char WATB(10)(2)
            WATB(0)="BPARTNER": WATB(1)="BPSUPPLIER"
            Call B3_LNK(VALEUR,2,WATB()) From LNKSUB
            J=instr(1,VALEUR,"=")
            If J<>0:  VALEUR=right$(VALEUR,J+2): Endif
    When Default
            If clalev([F:AOR])=0: Local File AOBJEXTR [AOR]: Endif
            Local File ATEXTRA  [AXXW]
            Local Integer I, NBREC
            NBREC=nbrecord([F:AOR])

            Local Char  WDESC1(80)(NBREC), WNUM(3)(NBREC)
            Local File (Char NUM(3) , Char DESC1(80)) From Variable WNUM , WDESC1 As [AORX] Order By NUM

            For [AOR]
              If !find(num$([F:AOR]NUMTAB),WNUM)
                WNUM(I)=num$([F:AOR]NUMTAB)
                Read [AXXW]AXX0="AOBJEXTR";"INTIT";GLANGUE;WNUM(I);""
                WDESC1(I)=[F:AXXW]TEXTE
                I+=1
              Endif
            Next

            Choose [AORX] Using NUM Titled mess(5,159,1) , DESC1 Titled mess(36,105,1) Sized (112,80) Titled mess(26,127,1)
            Case status
              When 0       : Call MESSAGE(mess(99,100,1)) From GESECRAN
              When 7
              When Default : VALEUR = [AORX]NUM: [M:IPM1]NOLIB(NOL)= val(VALEUR)
            Endcase
         Close File [AXXW]
  Endcase
End

Subprog C_HEAUSEVAL(VALEUR)
Variable Char    VALEUR()
  Local Char WERR(250)
  Local Integer NOL:  NOL=nolign-1

  If [M:IPM1]HEAVALNAM(NOL)=3
    If len(VALEUR)>[M:IPM1]HEAVALEND(NOL)-([M:IPM1]HEAVALINI(NOL)-1)
      WERR=mess(186,104,1)  #Value incompatible with the length of the concept in line
    Else
      [M:IPM1]HEAVALEND(NOL)=([M:IPM1]HEAVALINI(NOL)-1)+len(VALEUR)
      Affzo [M:IPM1]HEAVALEND(NOL)
    Endif
  Endif

  If [M:IPM1]HEAVALNAM(NOL)<3 or [M:IPM1]HEAVALNAM(NOL)>5
    If VALEUR="": VALEUR="0": Endif
    If VALEUR="0": End: Endif
    Read [AOR]AOR0=val(VALEUR);1
    If fstat<>[V]CST_AOK
      WERR=mess(8,9137,1)
    Endif
  Endif

  If [M:IPM1]HEAVALNAM(NOL)=4
    If VALEUR="" and [M:IPM0]FLGDET=2: WERR=mess(532,177,1) : Endif # The field is mandatory
    If VALEUR<>"": Gosub CONTROL_FLD: Endif
  Endif

  If WERR<>""
    If [M:IPM0]FLGDET=2: GMESSAGE=WERR:  mkstat=2
    Else: Infbox(WERR)
    Endif
  Endif
End

Subprog S_HEAUSEVAL2(VALEUR)
Variable Char    VALEUR()
  Local Integer NOL: NOL=nolign-1

  If [M:IPM1]HEAVALNAM(NOL)=6
    If clalev([F:AST])=0: Local File APLSTD [AST]: Endif
    Choose [AST] Where LANCHP=202 and LAN=GLANGUE and LANNUM<>0 Using LANMES Titled "" Sized (112,80) Titled mess(86,100,1)
    Case status
      When 0       : Call MESSAGE(mess(99,100,1)) From GESECRAN
      When 7
      When Default : VALEUR = [AST]LANMES: [M:IPM1]NOLIB1(NOL)=[AST]LANNUM
    Endcase
  Endif

  If [M:IPM1]HEAVALNAM(NOL)>6
    If [M:IPM0]CPY<>""
      Local Integer NBDIE
      If GREP="C": Read [CPY]CPY0=[M:IPM0]CPY: Endif
      NBDIE=find("",[F:CPY]DIE)
      If NBDIE=0: NBDIE=21: Endif
      Local Char WDIE(GLONDIE)(NBDIE), WDES1(80)(NBDIE), TEXTE(80)
      Local File (Char DIE(GLONDIE) , Char DES1(80)) From Variable WDIE , WDES1 As [DIEX] Order By DIE

      For I=0 To NBDIE-2
        If [F:CPY]DIE(I)="": Break: Endif
        WDIE(I)=[F:CPY]DIE(I)
        Read [DIE]DIE0=WDIE(I)
        Call LECTEXTRA(TEXTE,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
        WDES1(I)=TEXTE
      Next

      Choose [DIEX] Using DIE Titled mess(206,111,1) , DES1 Titled mess(36,105,1) Sized (112,80) Titled mess(175,105,1)
      Case status
        When 0       : Call MESSAGE(mess(99,100,1)) From GESECRAN
        When 7
        When Default : VALEUR = [DIEX]DIE
      Endcase
    Else
      If clalev([F:AXX])=0: Local File ATEXTRA [AXX]: Endif
      Link [AXX] With [DIE]DIE0=[AXX]IDENT1 As [DIEX] Where [F:AXX]CODFIC="GDIE" & [F:AXX]ZONE="DESTRA" & [F:AXX]LANGUE=GLANGUE
      Choose [DIEX] Using [F:DIE]DIE Titled mess(206,111,1), [F:AXX]TEXTE Titled mess(36,105,1) Sized (112,80) Titled mess(175,105,1)
      Case status
        When 0       : Call MESSAGE(mess(99,100,1)) From GESECRAN
        When 7
        When Default : VALEUR = [DIEX]IDENT1
      Endcase
    Endif
  Endif
End

Subprog C_HEAUSEVAL2(VALEUR)
Variable Char    VALEUR()
  Local Integer J, NOL:  NOL=nolign-1
  Local Integer NOL: NOL=nolign-1

  If VALEUR<>""
    VALUER=toupper(VALEUR)
    If [M:IPM1]HEAVALNAM(NOL)>6
      Read [DIE]DIE0=VALEUR
      If fstat=[V]CST_AOK
        If GREP="C": Read [CPY]CPY0=[M:IPM0]CPY: Endif
        J=find(VALEUR,[F:CPY]DIE)
        If J=0 and [M:IPM0]CPY<>"": GMESSAGE=mess(94,103,1): mkstat=2 : Endif # Dimension type not compatible with this company
      Else
        GMESSAGE=mess(20,103,1) # Nonexistent dimension type code
        mkstat=2
      Endif
      Call UNICITE(VALEUR, [M:IPM1]HEAUSEVAL2(0..[M:IPM1]NBLIG-1)) From OBJDIV   # Code already exists on line
    Endif
  Else
    GMESSAGE=mess(472,192,1): mkstat=2  # Mandatory value
  Endif

End

Subprog AVANT_NBLIG
  Local Integer I, NOL, WNB: NOL=nolign-1

  If [M:IPM1]HEAVALNAM(NOL)=5: Diszo [M:IPM1]HEAUSEVAL(NOL): Endif

  If NOL>0 and [M:IPM1]HEAVALINI(NOL)=0
    [M:IPM1]HEAVALNAM(NOL)=[M:IPM1]HEAVALNAM(NOL-1)+1
    [M:IPM1]HEAVALINI(NOL)=[M:IPM1]HEAVALEND(NOL-1)+1
  Endif
  If NOL=0 and [M:IPM1]HEAVALINI(NOL)=0: [M:IPM1]HEAVALNAM(NOL)=1: Endif
  If [M:IPM1]HEAVALNAM(NOL)<6
    Diszo [M:IPM1]HEAUSEVAL2(NOL)
    Affzo [M:IPM1]HEAUSEVAL2(NOL)
  Endif
End


######################################################################################
## Section automatically added (screen IPM2) 01/12/2016 15:55:54 (JUCON)
######################################################################################
Subprog C_CODDES(VALEUR)
Variable Char    VALEUR()
  Local Integer NOL: NOL=nolign-1
  Call UNICITE(VALEUR, [M:IPM2]CODDES(0..[M:IPM2]NBCLIG-1)) From OBJDIV
  If NOL=0 : [M:IPM2]INIPOS(NOL)=[M:IPM1]HEAVALEND(NBLIG-1)+1
  Else       [M:IPM2]INIPOS(NOL)=[M:IPM2]ENDPOS(NOL-1)+1
  Endif
  Actzo [M:IPM2]INIPOS(NOL)
End

Subprog C_INIPOS(VALEUR)
Variable Decimal VALEUR
  Local Integer WKO, WPOS, NOL: NOL=nolign-1
  Local Integer WTAB   #WTAB=1: Field WTAB=2 : Concepts
  WTAB=2
  [M:IPM2]INIPOS(NOL)=VALEUR
  Gosub CONTROL_POSITIONS

  If WKO=1
    GMESSAGE=mess(63,105,1)-mess(108,123,1)+"."-func AFNC.MES1(mess(1,10721,1),num$(WPOS))
    mkstat=2
  Elsif WKO=2
    GMESSAGE=func AFNC.MES1(mess(1,10721,1),num$(WPOS))
    mkstat=2
  Endif
End

Subprog AM_INIPOS(VALEUR)
Variable Decimal VALEUR
  Local Integer NOL: NOL=nolign-1

  If VALEUR<>0: [M:IPM2]ENDPOS(NOL)=VALEUR: Endif
End

Subprog C_ENDPOS(VALEUR)
Variable Decimal VALEUR
  Local Integer WKO, NOL:  NOL=nolign-1
  Local Integer WTAB   #WTAB=1: Field WTAB=2 : Concepts
  WTAB=2

  If VALEUR<[M:IPM2]INIPOS(NOL): GMESSAGE=mess(757,196,1): mkstat=2: End: Endif #  This value must not be less than the first.

  Gosub CONTROL_POSITIONS

  If WKO=1
    GMESSAGE=mess(63,105,1)-mess(108,123,1)+"."-func AFNC.MES1(mess(1,10721,1),num$(WPOS))
    mkstat=2
  Elsif WKO=2
    GMESSAGE=func AFNC.MES1(mess(1,10721,1),num$(WPOS))
    mkstat=2
  Endif

  If VALEUR<>0 and WKO=0
    Local Integer WNL, WVAL, I: I=NOL
    Local Char WLENG(15)
    WNL=1
    WVAL=VALEUR+1
    Gosub INIT_LENGHT
  Endif

End

Subprog AM_ACCCOD(VALEUR)
Variable Char    VALEUR()
  Local Char WCOA(3), WERR(250), WCPT(GLONGAC)

  If VALEUR<>""
    VALEUR=toupper(VALEUR)
    If [M:IPM0]CPY<>""
      Read [GCM]GCM0 = [F:CPY]ACM
      Read [LED]LED0 = [F:GCM]LED(0)
      Read [COA]COA0 = [F:LED]COA
      If fstat=[V]CST_AOK
        WCOA=[F:COA]COA
        Read [CAC]CAC0=26;VALEUR;WCOA
        If fstat<>[V]CST_AOK
          WERR=mess(1108,196,1)-mess(33,111,1)+"."-mess(86,105,1)  # Accounting code is not defined
        Else
          WCPT=[F:CAC]ACC
        Endif
      Endif
    Else
      Read [CAC]CAC1=26;VALEUR
      If fstat<>[V]CST_AOK: WERR=mess(2453,200,1)-mess(368,177,1)
      Else:  WCPT=[F:CAC]ACC
      Endif
    Endif
  Endif

  Local File GACCOUNT [GAC]
  Read [GAC]GAC0=WCPT
  If fstat=[V]CST_AOK
    If [M:IPM0]FLGDET=1 and [F:GAC]ACCSHO <>""
      WERR=mess(123,106,1)    # Control account not authorized
    Endif
  Endif
  Close File [GAC]
  If WERR<>""
    Infbox(WERR)
  Endif
End

Subprog AM_CCEDEFL(VALEUR)
Variable Char    VALEUR()
  Local Char WCPY(5), WERR(250)
  Local Integer WOKK, WNBR
  If VALEUR<>""
    Gosub CONTROL_CDE
    If WERR<>""
      GMESSAGE=WERR
      mkstat=2
    Endif
  Endif
End

######################################################################################
$RAZ_MSK
  [M]TYP="": [M]COD="": [M]CCEDEF=""
   Affzo [M]TYP,COD,CCEDEF
Return

######################################################################################
$CHANGE_VALUES
  Raz [M:IPM1]HEAVALUSE(NOL), HEAUSEVAL(NOL), HEAVALUSE2(NOL), HEAUSEVAL2(NOL)
  Actzo [M:IPM1]HEAVALUSE(NOL)
  Diszo [M:IPM1]HEAUSEVAL2(NOL)

  Case VALEUR
    When 3:
      Read [ATX]NUMERO = GLANGUE;1267
      If !fstat
        HEAVALUSE(NOL)=[F:ATX]TEXTE  #Format date
      Endif
    When 4: [M:IPM1]HEAVALUSE(NOL)=mess(341,117,1) #X3 BP field
    When 5: Effzo [M:IPM1]HEAVALUSE(NOL): Diszo [M:IPM1]HEAVALUSE(NOL)
    When Default
      Read [ATX]NUMERO = GLANGUE;7161
      If !fstat
        HEAVALUSE(NOL)=[F:ATX]TEXTE # Transcoding
        HEAUSEVAL(NOL)="0"
      Endif
      If VALEUR>5
        Actzo [M:IPM1]HEAVALUSE2(NOL),HEAUSEVAL2(NOL)
        If VALEUR=6 :
          [M:IPM1]HEAVALUSE2(NOL)= mess(86,100,1)  #Rate type
        Else
        [M:IPM1]HEAVALUSE2(NOL)= mess(2,103,1)    # Dimension type
        Endif
        Diszo [M:IPM1]HEAVALUSE2(NOL)
      Endif
  Endcase

  Diszo [M:IPM1]HEAVALUSE(NOL)

  If NOL=0 : [M:IPM1]HEAVALINI(NOL)=1
  Else       [M:IPM1]HEAVALINI(NOL)=[M:IPM1]HEAVALEND(NOL-1)+1
  Endif
  Actzo [M:IPM1]HEAVALINI(NOL)

Return

######################################################################################
$CONTROL_CDE
  If [M]CPY="" and [M]FCY="": WOKK=1: Endif
  If [M]CPY<>"": WCPY=[M]CPY
  Elsif [M]CPY="" and [M]FCY<>""
    Read [F:FCY]FCY0=[M]FCY
    If fstat=[V]CST_AOK
      WCPY=[F:FCY]CPYLEG
    Endif
  Endif
  If WOKK=0     #Control by company
    Read [CDE]CDE0=VALEUR;WCPY
    If fstat<>[V]CST_AOK
      Read [CDE]CDE0=VALEUR;""
      If fstat<>[V]CST_AOK
        WERR=mess(184,104,1)      # Default dimension is incompatible with this company
      Endif
    Endif
  Else          # Control by legislation
    Filter [CDE] Where COD=VALEUR
    For [CDE]
      Read [CPY]CPY0=[F:CDE]CPY
      If fstat=[V]CST_AOK
        If [M]LEG=[F:CPY]LEG: WNBR=1: Break: Endif
      Endif
    Next
    If WNBR=0: WERR=mess(184,104,1) : Endif       # Default dimension is incompatible with this company
  Endif

Return

######################################################################################
$CONTROL_POSITIONS
  Local Integer I, NBINI
  If WTAB=1
    NBINI=[M:IPM1]HEAVALINI(NOL)
  Else
    NBINI=[M:IPM2]INIPOS(NOL)
  Endif

  For I=0 To [M:IPM1]NBLIG-1
    If WTAB=1
      If I<>NOL and (VALEUR>=[M:IPM1]HEAVALINI(I) and VALEUR<=[M:IPM1]HEAVALEND(I)): WKO=1: WPOS=I+1: Break: Endif
     Else
      If VALEUR>=[M:IPM1]HEAVALINI(I) and VALEUR<=[M:IPM1]HEAVALEND(I): WKO=1: WPOS=I+1: Break: Endif
    Endif
    If [M:IPM1]HEAVALINI(I)>NBINI and [M:IPM1]HEAVALEND(I)<=VALEUR: WKO=1: WPOS=I+1: Break: Endif
  Next
  If WKO=0
    For I=0 To [M:IPM2]NBCLIG-1
      If WTAB=2
        If I<>NOL and (VALEUR>=[M:IPM2]INIPOS(I) and VALEUR<=[M:IPM2]ENDPOS(I)): WKO=2: WPOS=I+1: Break: Endif
      Else
        If VALEUR>=[M:IPM2]INIPOS(I) and VALEUR<=[M:IPM2]ENDPOS(I): WKO=2: WPOS=I+1: Break: Endif
      Endif
      If [M:IPM2]INIPOS(I)>NBINI and [M:IPM2]ENDPOS(I)<=VALEUR: WKO=2: WPOS=I+1: Break: Endif
    Next
  Endif

Return

######################################################################################
$INIT_LENGHT
  Actzo [M:IPM2]LENGHT(I)
  WLENG=num$(WVAL-[M:IPM2]INIPOS(I)-[M:IPM0]NUMDEC)
  If (val(WLENG)<2 and len([M:IPM0]SEPDEC)>0) or(val(WLENG)<1 and len([M:IPM0]SEPDEC)<1)
    If WNL=1: WERR=mess(185,104,1)                #Value incompatible with the number of decimal places indicated
    Else    : WERR=mess(186,104,1)+":"-num$(I+1)  #Value incompatible with the length of the concept in line
    Endif
    GMESSAGE=WERR
    mkstat=2: Return
  Endif

  If len([M:IPM0]SEPDEC)<>0
    WLENG=num$(val(WLENG)-len([M:IPM0]SEPDEC))
    WLENG=WLENG+[M:IPM0]SEPDEC
    WLENG=WLENG+num$([M:IPM0]NUMDEC)
  Else
    WLENG=num$(val(WLENG)+[M:IPM0]NUMDEC)
  Endif
  [M:IPM2]LENGHT(I)=WLENG
  Affzo [M:IPM2]LENGHT(I)
  Diszo [M:IPM2]LENGHT(I)

Return

######################################################################################
$CONTROL_TABS
Local Integer I, WNBCPY, WNBFCY, WDACT, WCACT, WLNB, WDAT, WDEB, WCRE, WEMP
Local Char WERR(250)

  If [M:IPM1]NBLIG =0: WNBCPY=0: WERR=mess(56,108,1) : Endif #: Company or site mandatory: endif
  If [M:IPM2]NBCLIG=0: WERR=mess(183,104,1): Endif  #At least one active concept is mandatory

  If WERR=""
    For I=0 To [M:IPM1]NBLIG-1
      If [M:IPM1]HEAVALNAM(I)<3: WNBCPY=1: Endif   # One company is mandatory
      If [M:IPM1]HEAVALNAM(I)=2: WNBFCY=1: Endif   # One site is mandatory
      If [M:IPM1]HEAVALNAM(I)=3: WDAT=1  : Endif   # Date is mandatory if REPDAT=2
      If [M:IPM1]HEAVALNAM(I)=4: WEMP=1  : Endif   # Employee is mandatory if FLGDET=2
    Next

    If WNBCPY=0  : WERR=mess(56,108,1)  #: Company or site mandatory
    Elsif WNBFCY=0 and [M:IPM0]FCY<>"": WERR=mess(123,123,1)   #Site field must be defined'
    Endif
    If WERR="" and WDAT=0 and [M:IPM0]REPDAT=2: WERR=mess(187,104,1): Endif
    If WERR="" and WEMP=0 and [M:IPM0]FLGDET=2: WERR=mess(188,104,1): Endif
  Endif

  If WERR=""
    For I=0 To [M:IPM2]NBCLIG-1
      If [M:IPM2]SENSE(I)=1 and [M:IPM2]FLGACT(I)=2: WDEB=1: WDACT=1: Endif
      If [M:IPM2]SENSE(I)=2 and [M:IPM2]FLGACT(I)=2: WCRE=1: WCACT=1: Endif
    Next
    If WDACT=0 or WCACT=0 or WDEB=0 or WCRE=0 : WERR= mess(183,104,1)+".": Endif  # At least one active concept is mandatory by sense

  Endif

  If WERR<>"": GOK=0: Call ERREUR(WERR) From GESECRAN: Endif

Return

######################################################################################
$CONTROL_FLD
  Local Integer J, K
  Local Char WFLD(10), WATB(10)

  VALEUR=toupper(VALEUR)
  J=instr(1,toupper(VALEUR),"[F:BPR]")
  K=instr(1,toupper(VALEUR),"[F:BPS]")

  If clalev([F:ATZ])=0  : Local File ATABZON [ATZ]  : Endif
  WFLD=seg$(VALEUR,8,len(VALEUR))
  If J>0: WATB="BPARTNER": Endif
  If K>0: WATB="BPSUPPLIER": Endif
  Read [ATZ]CODZONE=WATB;WFLD
  If fstat<>[V]CST_AOK
    WERR=WFLD-mess(574,196,1)-WATB
  Endif

  If J=0 and K=0
    WERR=mess(149,100,1)+"."-"[F:BPR]"-tolower(mess(2,56,1))-"[F:BPS]"-mess(42,9003,1) # Incorrect format
  Endif

Return

