#<AdxTL>@(#)0.0.0.0 $Revision$


#########################################################################
# TRAITEMENTS LIES AU PICKING DES LIGNES DE STOCK                       #
#########################################################################

#########################################################################
# Actions de la saisie fenêtre (traitement GSAISIE)                     #
#########################################################################

#########################################################################
$FILGAUCHE

Raz FILGAUSUP(1)
Raz FILGAUSUP(2)
Raz FILGAUSUP(3)

If WAFFPICK=0
   # Rien dans la liste de picking
   FILGAUSUP(0)='[F:STO]ITMREF=""&[F:STO]STOFCY=""'
Else
   # Filtre article, site
   FILGAUSUP(0)=WCRITSTO1
   # Filtre lot
   If WCRITSTO2<>""
      FILGAUSUP(0)+='&'+WCRITSTO2
   Endif
   # Filtre péremption
   If [M:SHTR]FLGSHLLOT = 1 & WCRITSTO3<>""  # hcb V6cri
      FILGAUSUP(0)+='&'+WCRITSTO3
   Endif
   If [M:SHTR]FLGDLULOT = 1 & WCRITSTO31<>"" # hcb V6cri
      FILGAUSUP(0)+='&'+WCRITSTO31           # hcb V6cri
   Endif
   #--- Bug 63974
   # Filtre catégorie emplacement
   #If dim([M:SHTR]LOC)>0 & WCRITSTO5<>""
   #   FILGAUSUP(0)+='&'+WCRITSTO5
   #Endif
   #---
   # Filtre propriétaire
   FILGAUSUP(0)+='&'+WCRITSTO6

   # Filtre statuts
   FILGAUSUP(1)+='&('+WCRITSTO4+')'

   #--- TS 106217
   # Filtre version
   If WCRITSTO41<>""
      FILGAUSUP(1)+='&'+WCRITSTO41
   Endif
   #---

   # Filtre lignes de stock indisponibles
   If [M:SHTR]STODISFLG<>2
      FILGAUSUP(1)+='&([F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY>0)'
   Endif

   # Filtres supplémentaires
   If !find([M:SHTR]XPALNUM,"","*")
      FILGAUSUP(1)+='&pat([F:STO]PALNUM,[M:SHTR]XPALNUM)<>0'
   Endif
   If !find([M:SHTR]XCTRNUM,"","*")
      FILGAUSUP(1)+='&pat([F:STO]CTRNUM,[M:SHTR]XCTRNUM)<>0'
   Endif
   If [M:SHTR]XPCUFIL<>""
      FILGAUSUP(1)+='&[F:STO]PCU=[M:SHTR]XPCUFIL'
   Endif

   # Si prise en compte filtre emplacement de la règle d'allocation
   If [M:SHTR]PECTRU=2
      If GSTOLOC<>""
         FILGAUSUP(3)+='&(pat([F:STO]LOC,GSTOLOC)<>0'
      Endif
      If GDEFLOC<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOC,GDEFLOC)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOC,GDEFLOC)<>0'
         Endif
      Elsif GDEFLOCTYP<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOCTYP,GDEFLOCTYP)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOCTYP,GDEFLOCTYP)<>0'
         Endif
      Endif
      If GDEFLOC2<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOC,GDEFLOC2)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOC,GDEFLOC2)<>0'
         Endif
      Elsif GDEFLOCTYP2<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOCTYP,GDEFLOCTYP2)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOCTYP,GDEFLOCTYP2)<>0'
         Endif
      Endif
      If GDEFLOC3<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOC,GDEFLOC3)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOC,GDEFLOC3)<>0'
         Endif
      Elsif GDEFLOCTYP3<>""
         If FILGAUSUP(3)=""
            FILGAUSUP(3)+='&(pat([F:STO]LOCTYP,GDEFLOCTYP3)<>0'
         Else
            FILGAUSUP(3)+='|pat([F:STO]LOCTYP,GDEFLOCTYP3)<>0'
         Endif
      Endif
      If FILGAUSUP(3)<>"" FILGAUSUP(3)+=')' Endif
   Endif
   #--- Bug 63974
   # Filtre catégorie emplacement
   If dim([M:SHTR]LOC)>0 & WCRITSTO5<>""
      FILGAUSUP(3)+='&'+WCRITSTO5
   Endif
   #---
Endif

Return

##########################################################################
$AP_FILGAUCHE

WPICK=2 : Gosub RAFFRAICHI

Return

#########################################################################
$CLE_GAUCHE

SNSLIS = 1       : # Ascendant
LENLIS = 6
Case [M:SHTR]LOTMGT
 When 1 : CLELISTE  = "ITMREF;STOFCY;LOT;SLO;STOCOU"
          LENLIS    = 5
 When 2 : CLELISTE  = "ITMREF;STOFCY;[F:STL]LOTCREDAT;LOT;SLO;STOCOU"
 When 3 : CLELISTE  = "ITMREF;STOFCY;[F:STL]SHLDAT;LOT;SLO;STOCOU"
 When 4 : CLELISTE  = "ITMREF;STOFCY;[F:STL]LOTCREDAT desc;LOT desc;SLO desc;STOCOU desc"
          SNSLIS    = 2  : # Descendant
Endcase

Return

#########################################################################
$HINT_KEY

#Case currbox
# When Default : Return
# When GBOXSQ1 : HINTLIS(val(right$(GBOXSQ1,8)))="SQD1"
#Endcase

Return

##########################################################################
$DEB_PIC
Local Integer I, WRET
Local Char    SYMBOLE2(20)

Return

#########################################################################
$CRE_PIC

Raz WPICKSTO
Read [STO]STO0=[F:STO]STOFCY;[F:STO]STOCOU
If fstat
   Call RSTA ("STO",[F:STO]STOFCY-num$([F:STO]STOCOU)) From GLOCK
   FOK=0 : Return
Endif

#--- Issue 110327 inutile car stock négatif interdit si E/S global (mais on laisse le code)
If [F:ITM]SERMGTCOD=4 & [M:SHTR]SERSAI<>""
   Read [STS]STS0=[M:SHTR]ITMREF;[M:SHTR]SERSAI
   If fstat
      GMESSAGE = [M:SHTR]SERSAI-":"-mess(43,196,1)
      FOK=0 : Return
   Elsif [F:STS]STOCOU<>[F:STO]STOCOU
      GMESSAGE = [M:SHTR]SERSAI-":"-mess(447,184,1)
      FOK=0 : Return
   Elsif [F:STS]ISSDAT<>[0/0/0]
      GMESSAGE = [M:SHTR]SERSAI-":"-mess(37,184,1)
      FOK=0 : Return
   Elsif [F:STS]SDHNUM<>"" & !find([F:STS]SDHNUM,[M:SHTR]VCRNUM,[M:SHTR]VCRNUMORI)
      GMESSAGE = [M:SHTR]SERSAI-":"-mess(443,184,1)
      FOK=0 : Return
   Elsif func STKLIB.REC_STOSERW([M:SHTR]ITMREF,[M:SHTR]SERSAI)<>0
      GMESSAGE = [M:SHTR]SERSAI-":"-mess(449,184,1)
      FOK=0 : Return
   Endif
Endif
#---

Read [STL]STL0=[M:SHTR]ITMREF;[F:STO]LOT;[F:STO]SLO
If fstat
   Call RSTA ("STL",[M:SHTR]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
   FOK=0 : Return
Endif

If [F:STO]LOCCAT=2
   Raz WRET
   # Contrôle que la ligne de stock en attente de rangement est complète
   Call CTLPLFLOC([M:SHTR]ITMREF,"",WRET) From STKSOR
   If WRET<>0
      FOK=0 : GERR=1
      GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
      GMESSAGE+="\"+mess(377,199,1)-":"
      Case LRET
       When 1 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)
       When 2 : GMESSAGE+=mess(453,197,1)
       When 3 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)-","-mess(453,197,1)
      Endcase
      Return
   Endif
Endif


# Ligne de stock faisant l'objet d'une demande d'analyse
If [F:STO]QLYCTLDEM<>""
   FOK=0 : GERR=1
   GMESSAGE =mess(399,198,1)-":"-[F:STO]STA
   If [F:ITM]LOTMGTCOD>1
      GMESSAGE-=mess(43,197,1)-":"-[F:STO]LOT
   Endif
   If [F:ITM]LOTMGTCOD=4
      GMESSAGE-=mess(456,197,1)-":"-[F:STO]SLO
   Endif
   If [F:ITM]SERMGTCOD=3
      GMESSAGE-=mess(453,197,1)-":"-[F:STO]SERNUM
   Endif
   If [F:ITF]LOCMGTCOD=2
      GMESSAGE-=mess(44,197,1)-":"-[F:STO]LOC
   Endif
   GMESSAGE+="\"+mess(460,199,1)
   Return
Endif


# Si non administrateur stock, contrôle ligne pickée par rapport
# à la péremption et à la règle d'allocation
If GSTOADMIN<>2
   WPICKSTO=string$(evalue(WCRITPIC),"OK")
   If WPICKSTO<>"OK"
      FOK=0 : GERR=1
      GMESSAGE =mess(399,198,1)-":"-[F:STO]STA
      If dim([M:SHTR]LOT)>0
         GMESSAGE-=mess(43,197,1)-":"-[F:STO]LOT
      Endif
      GMESSAGE+="\"+mess(366,199,1)
      Return
   Endif
Endif

# Contrôle du disponible pour sortie sur la ligne de stock
Call STODISSOR("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB

# Pas de stock disponible
If WSTUACTDIS<=0
   FOK=0 : GERR=1
   GMESSAGE =mess(367,199,1)
   If GWIPSTOLCK=2 & [F:STO]LOCCAT=2
      # La qté en attente de rangement est peut être dans une liste à ranger
      GMESSAGE += "\"+mess(150,184,1)
   Endif
   Return
Endif

# La quantité est déjà supérieure à la qte à traiter
If [M:SHTR]PECQTYACT>=[M:SHTR]QTYACT
   FOK=0 : GERR=1
   GMESSAGE=mess(393,199,1)
   Return
Endif

# Contrôle de l'insertion
If [M:SHTR]NBLIG+1 >= dim([M:SHTR]STA)-1
   FOK=0 : GERR=1
   GMESSAGE=mess(122,199,1)
   Return
Endif

#--- La sélection est correcte

# Ouverture de la ligne
nolign = [M:SHTR]NBLIG
Insa nolign,1,[M:SHTR]NBLIG [M:SHTR]NBLIG
[M:SHTR]NBLIG += 1
nolign = [M:SHTR]NBLIG
NOL = nolign-1
status = 0


# Quantité US restant à traiter
WQTYSTUACT=[M:SHTR]QTYACT-[M:SHTR]PECQTYACT

If WSTUACTDIS>=WQTYSTUACT
   [M:SHTR]QTYSTUACT(NOL)=WQTYSTUACT
Else
   [M:SHTR]QTYSTUACT(NOL)=WSTUACTDIS
Endif

[M:SHTR]QTYSTU(NOL) = [M:SHTR]QTYSTUACT(NOL)
If dim([M:SHTR]POT)>0
   # Si gestion en titres ou UI, calcul quantité en UA
   Case [F:ITF]STOMGTCOD
    When 3 : If [F:STL]POT<>0
                 [M:SHTR]POT(NOL) = [F:STL]POT
                 [M:SHTR]QTYSTU(NOL) = [M:SHTR]QTYSTUACT(NOL)/([M:SHTR]POT(NOL)/100)
             Else
                 [M:SHTR]POT(NOL) = 1
             Endif
    When 4 : If [F:STL]ACT<>0
                 [M:SHTR]POT(NOL) = [F:STL]ACT
                 [M:SHTR]QTYSTU(NOL) = [M:SHTR]QTYSTUACT(NOL)/[M:SHTR]POT(NOL)
             Else
                 [M:SHTR]POT(NOL) = 1
             Endif
   Endcase
Endif

[M:SHTR]AVAQTYPCU(NOL)  = WPCUDIS
[M:SHTR]AVAQTYSTU(NOL)  = WSTUDIS
[M:SHTR]TOTQTY(NOL)  = [F:STO]QTYSTU

If dim([M:SHTR]PCU)>0       [M:SHTR]PCU(NOL)       = [F:STO]PCU        Endif
If dim([M:SHTR]PCUSTUCOE)>0
    If [M:SHTR]PCUSTUCOE(NOL)=0
        [M:SHTR]PCUSTUCOE(NOL) = 1
    Else
        [M:SHTR]PCUSTUCOE(NOL) = [F:STO]PCUSTUCOE
    Endif
Endif
If dim([M:SHTR]QTYPCU)>0    [M:SHTR]QTYPCU(NOL)    = [M:SHTR]QTYSTU(NOL)/[F:STO]PCUSTUCOE    Endif
If dim([M:SHTR]LOT)>0       [M:SHTR]LOT(NOL)       = [F:STO]LOT        Endif
If dim([M:SHTR]SLO)>0       [M:SHTR]SLO(NOL)       = [F:STO]SLO        Endif
#--- TS 106217
If dim([M:SHTR]ECCVALMAJ)>0 [M:SHTR]ECCVALMAJ(NOL) = [F:STO]ECCVALMAJ  Endif
If dim([M:SHTR]LOC)>0       [M:SHTR]LOC(NOL)       = [F:STO]LOC        Endif
If dim([M:SHTR]SERNUM)>0    [M:SHTR]SERNUM(NOL)    = [F:STO]SERNUM     Endif
[M:SHTR]STA(NOL)        = [F:STO]STA

If dim([M:SHTR]SHLDAT)>0    [M:SHTR]SHLDAT(NOL)    = [F:STL]SHLDAT     Endif

[M:SHTR]STOCOU(NOL)    = [F:STO]STOCOU

If dim([M:SHTR]LOT)>0     Diszo [M:SHTR]LOT(NOL)     Endif
If dim([M:SHTR]SLO)>0     Diszo [M:SHTR]SLO(NOL)     Endif
#--- TS 106217
If dim([M:SHTR]ECCVALMAJ)>0 Diszo [M:SHTR]ECCVALMAJ(NOL) Endif
If dim([M:SHTR]LOC)>0     Diszo [M:SHTR]LOC(NOL)     Endif
If dim([M:SHTR]SHLDAT)>0  Diszo [M:SHTR]SHLDAT(NOL)  Endif
If dim([M:SHTR]POT)>0     Diszo [M:SHTR]POT(NOL)     Endif
Diszo [M:SHTR]STA(NOL)

Call MAJLIGNE(NOL) From TRTSHTRA
Return

#########################################################################
$ANU_PIC

Raz I,J
OK = 0
If [M:SHTR]NBLIG <> 0
   While OK <> 1
      I = find([F:STO]STOCOU,[M:SHTR]STOCOU(J..[M:SHTR]NBLIG-1))
      If !I Break Endif
      NOL = J+I-1
      Dela NOL,1,[M:SHTR]NBLIG-1 [M:SHTR]NBLIG
      [M:SHTR]NBLIG -= 1
      OK = 1
   Wend
   Gosub MAJQTYTOT From TRTSHTRA
Endif

Return

#########################################################################
$FIN_PIC

Gosub MAJQTYTOT From TRTSHTRA
Affzo [M:SHTR]1-99

Return

#########################################################################
# Etiquettes de traitement                                              #
#########################################################################

#########################################################################
$TIROIR
#-----------------------------------------------------------------------#
# Remplissage de la liste de picking                                    #
#-----------------------------------------------------------------------#

ILIS=val(right$(currbox,8))
Gosub REMPLIT From GSAISIE
If WAFFPICK<>0
   WPICK=2
   Gosub RAFFRAICHI
Endif

Return

#########################################################################
$RAFFRAICHI
#-----------------------------------------------------------------------#
# Raffraichissement de la liste picking pour les lignes déjà saisies    #
#-----------------------------------------------------------------------#
If [M:SHTR]NBLIG <> 0
   For I=0 To [M:SHTR]NBLIG-1
      If [M:SHTR]STOCOU(I) <> 0
         Read [STO]STO0=[M:SHTR]STOFCY;[M:SHTR]STOCOU(I)
         Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
         If evalue(FILGAUSUP)
            If    WPICK=1 Gosub DEPICK From GSAISIE
            Elsif WPICK=2 Gosub REPICK From GSAISIE
            Endif
         Endif
      Endif
   Next I
Endif

Return

