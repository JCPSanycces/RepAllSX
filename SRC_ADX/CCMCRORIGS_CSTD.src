#<AdxTL>@(#)0.0.0.0 $Revision$
# Data Class script: CCMCRORIGS_CSTD, Change Request - Originator Supplier Collection

#####################
# METHODS           #
#####################
$METHODS

  Case CURPTH
    When ""
      Case ACTION
        When "ADDLINE_AFTER"
          Gosub INCREMENT_LINE_NUMBER
        When "VALIDATE_SUPPLIER_CONTACT"
          Gosub VALIDATE_SUPPLIER_CONTACT
      Endcase
  Endcase

Return

# --------------------------------------------------
# Increment collection row's line number (ORIGSLN)
# for subsequent database update.
$INCREMENT_LINE_NUMBER

  this.ORIGSLN = 1 + max (this.APARENT.CCMCRORIGS(1..maxtab(this.APARENT.CCMCRORIGS)).ORIGSLN)

Return

#####################
# PROPERTIES        #
#####################
$PROPERTIES

  Local Char PROPERTYACTION(50)
  PROPERTYACTION = CURPRO +"." +ACTION

  Case PROPERTYACTION
    When "SUPPCONTACT.CONTROL" : ASTATUS = fmet this.VALIDATE_SUPPLIER_CONTACT()
  Endcase

Return

# --------------------------------------------------
# The Contact must relate to the Supplier ...
$VALIDATE_SUPPLIER_CONTACT

  Local File CONTACT [CNT]
  Local Char MESSAGE(100)
  Local Char SUPPLIER_NAME(50)
  Local Char CONTACT_NAME(50)
  Local Instance BPSUPPLIER Using C_BPSUPPLIER
  Local Instance CONTACTCRM Using C_CONTACTCRM
  Local Integer LOCASTATUS

  ASTATUS = CST_AOK

  If this.SUPPCONTACT <> ""

    # Read the Supplier Contact ...
    Read [CNT]CNT0 = 1;this.BPSNUM;this.SUPPCONTACT
    If (fstat > 1)  # No record ...

      # Derive the Supplier name ...
      BPSUPPLIER = NewInstance C_BPSUPPLIER AllocGroup null
      SUPPLIER_NAME = ""
      LOCASTATUS = fmet BPSUPPLIER.AREAD(this.BPSNUM)
      If (LOCASTATUS = CST_AOK)
        SUPPLIER_NAME = this.BPSNAM
      Endif

      # Derive the Contact name ...
      CONTACTCRM = NewInstance C_CONTACTCRM AllocGroup null
      CONTACT_NAME = ""
      LOCASTATUS = fmet CONTACTCRM.AREAD(this.SUPPCONTACT)
      If (LOCASTATUS = CST_AOK)
        CONTACT_NAME = mess(CONTACTCRM.CNTTTL,941,1) - CONTACTCRM.CNTFNA - CONTACTCRM.CNTLNA
      Endif

      MESSAGE = func ASYRFNC.MES2(mess(63,2038,1), CONTACT_NAME, SUPPLIER_NAME)
      ASTATUS = fmet this.ASETERROR("SUPPCONTACT", MESSAGE, CST_AERROR)
    Endif

  Endif

  LogicClose File [CNT]

  ARET_VALUE = ASTATUS

Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

