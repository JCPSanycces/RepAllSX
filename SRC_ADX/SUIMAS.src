###############################################################################
$CONTROLE_SRV
# Droits par service
# SEGAY - 01/12/10 - EXI 69466 lot P13, SAM lot 1
# Test pour avoir la même chose que dans l'état accés en consultation
# Car le tableau GAUTSRV est rempli si on seulement droit exécution = "Oui"
If GUSRACS<>2 Then
  Read [SRV]SRV0 = [F:HRCTR]ETRSRV
  If !fstat
    Read [ACC]CODACC = GUSER;[F:SRV]CODACC
    If fstat or [F:ACC]EXEC<>2 or [F:ACC]CONSUL<>2
       OK = 0 : Return
    Endif
  Else
    OK = 0 : Return
  Endif
Endif
Return

$CONTROLE_RUB

  If RUBRIQ <> ""
  #7236 Amélioration contrôles par rapport à la liste + code accès.
    Read [MSR1]MSR0=RUBRIQ
    If fstat
      Read [RUB1]RUB0=GCURLEG;RUBRIQ
      If fstat
        GMESSAGE =  mess(11,10702,1) : # Rubrique inexistante
        Call ERREUR(GMESSAGE) From GESECRAN : # Période incorrecte
        GOK=0 : Return
      Elsif !fstat & [F:RUB1]CODGRP=""
        GMESSAGE =  mess(35,10722,1) : # Code groupe MS non renseigné dans la rubrique
        Call ERREUR(GMESSAGE) From GESECRAN : # Période incorrecte
        GOK=0 : Return
      Else
        LCODACC=[F:RUB1]CODACC
        LCODGRP=[F:RUB1]CODGRP
      Endif
    Elsif !fstat & [F:MSR1]CODGRP=""
      GMESSAGE =  mess(35,10722,1) : # Code groupe MS non renseigné dans la rubrique
      Call ERREUR(GMESSAGE) From GESECRAN : # Période incorrecte
      GOK=0 : Return
    Else
      LCODACC=[F:MSR1]CODACC
      LCODGRP=[F:MSR1]CODGRP
    Endif

    #control droit d'accès de la rubrique
    Call CONTEXE(LCODACC) From CPTSUB
    If mkstat = 1
      Call ERREUR(GMESSAGE) From GESECRAN : # Période incorrecte
      GOK=0 : Return
    Endif

    #Si groupe saisi, controle cohérence
    If SGROUPE<>"" & SGROUPE<>LCODGRP
      GMESSAGE = mess(40,10722,1)-SGROUPE #La rubrique n'appartient pas au groupe
      Call ERREUR(GMESSAGE) From GESECRAN : # Période incorrecte
      GOK=0 : Return
    Endif

    #Si Catégorie controle cohérence groupe rubrique et catégorie
    If CATEGORIE<>""
      Read [ADI]CODE(2) = 10654;LCODGRP
      If !fstat & [ADI]A1 <> CATEGORIE
          GMESSAGE = mess(43,10722,1)-CATEGORIE :#Le groupe de cette rubrique n'appartient pas à la catégorie
          Call ERREUR(GMESSAGE) From GESECRAN : # Période incorrecte
          GOK=0 : Return
      Endif
    Endif

    #Si liste de rubrique, contrôle que la rubrique appartient à la liste
    If LISRUB<>""
      Look [MLR1]MLR1(2)=LISRUB;RUBRIQ
      If fstat
        GMESSAGE = mess(38,10722,1)-":"-LISRUB #La rubrique n'appartient pas à la liste
        Call ERREUR(GMESSAGE) From GESECRAN : # Période incorrecte
        GOK=0 : Return
      Endif
    Endif
  Endif
  #end 7236
Return

######################################################################################
$CREER_FILTRE
#Filtre des données à parcourir selon les critères de sélection
CRITERE ="1=1"
CRITERE0="1=2"  : # parce que c'est un 'or' dans TRI_LNK_FILTRE
CRITERE1="1=1"
CRITERE2="1=1"
CRITERE3="1=1" #70009
CRITERE4="1=1" #70009


#Les scénarii , la paie réelle et Les hypothèses actives par périodes
If ACTMAX(1) < 6   : # Si il y a peu d'hypothèses à sélectionner on a la place dans CRITERE
 CRITERE    =  '(([F:MHS]COD="'+SCENARIO+'" & [F:MHS]SIM=1) |'
 For I = 0 To ACTMAX(1)-1
  If I = 0 or LACTSCE1(I) <> LACTSCE1(I-1)
   CRITERE +=  string$(I>0,')) |')
   CRITERE -=  '([F:MHS]COD="'+LACTSCE1(I)+'"'
   CRITERE -=  '& ('
  Else
   CRITERE -=  '|'
  Endif
  CRITERE  -=  '[F:MHS]LIGHYP='+num$(LACTHYP1(I))
 Next
 CRITERE   +=  ')))'
Else         : # Si il y a trop d'hypothèses à sélectionner on simplifie
# 58935 WGA
# CRITERE   = 'find([F:MHS]COD,[M:MAS1]ACTSCE1)<> 0'
 CRITERE    =  '([F:MHS]COD="'+SCENARIO+'"'
 For I = 0 To ACTMAX(1)-1
  If LACTSCE1(I) <> SCENARIO & LACTSCE1(I) <> LACTSCE1(I-1)
   CRITERE -=  '| ([F:MHS]COD="'+LACTSCE1(I)+'" & [F:MHS]SIM=2)'
  Endif
 Next
 CRITERE   +=  ')'
# fin 58935
Endif


#Les types de montants
CRITERE1  = '[F:MHS]TYP < 6 & [F:MHS]GRP <> ""'

#Les critères de sélection

#57313
If SITEDEB = "" & SITEFIN = "" & SOCIETE<>""
 Read [CPY]CPY0=SOCIETE
 If !fstat & [F:CPY]CPYLEGFLG=2    : # Société juridique
  CRITERE1 -= '& [F:MHS]CPY="'+SOCIETE+'"'
 Elsif !fstat & [F:CPY]CPYLEGFLG=1 : # Société non juridique
  I=1
  Raz FCYGRP()
  For [FGR]FGR0 Where CPY=SOCIETE
   If !find([F:FGR]FCY,FCYGRP(1..I))
    FCYGRP(I) = [F:FGR]FCY
    I +=1
   Endif
  Next
  If I>1
#70018
   CRITERE1 -= '& find([F:MHS]FCY, FCYGRP(1..'+num$(I-1)+'))'
#end 70018
  Endif
 Endif
Endif
# fin 57313


#Les filtres supplémentaires
If CATEGORIE<>""
 CRITERE1 -= '& [F:MHS]CAT="'+CATEGORIE+'"'
Endif
If SGROUPE<>""
 CRITERE1 -= '& [F:MHS]GRP="'+SGROUPE+'"'
Endif
#72636
If RUBRIQ<>""
  CRITERE1 -= '& [F:MHS]RUB="'+RUBRIQ+'"'
Elsif LISRUB<>""
  I=1
  Raz RUBGRP()
  For [MLR]MLR0 Where COD = LISRUB
    If func CNSMASSTD.CTRL_RUB_ACCES([F:MLR]CODRUB) & !find([F:MLR]CODRUB,RUBGRP(1..I))
      RUBGRP(I) = [F:MLR]CODRUB
      I +=1
    Endif
  Next
  If I>1
   CRITERE1 -= '& find([F:MHS]RUB, RUBGRP(1..'+num$(I-1)+'))'
  Endif
Endif
#end 72636
#70009
If EMPLOI<>""
  CRITERE3 = '& [F:MHS]JOBPOT="'+EMPLOI+'"'
Endif
If POSTE<>""
  CRITERE3= '& [F:MHS]POT="'+POSTE+'"'
Endif
#end 70009

## Critère salarié
CRIT1 = '1=1'
If MATDEB<>""
 CRIT1 -= '& [F:ID]REFNUM>="'+MATDEB+'"'
Endif
If MATFIN<>""
 CRIT1 -= '& [F:ID]REFNUM<="'+MATFIN+'"'
Endif

CRITERE3 -= '& [F:MHS]DAT>=['+format$(GFMD,DATEDEB)+']'
CRITERE3 -= '& [F:MHS]DAT<=['+format$(GFMD,DATEFIN)+']'

If MATDEB<>""
 CRITERE4 -= '& (([F:MHS]EMP>="'+MATDEB+'" & [F:MHS]MSEMP="") | [F:MHS]MSEMP>="'+MATDEB+'")'
Endif
If MATFIN<>""
 CRITERE4 -= '& (([F:MHS]EMP<="'+MATFIN+'" & [F:MHS]MSEMP="") | [F:MHS]MSEMP<="'+MATFIN+'")'
Endif
If SCONTRAT<>""
 CRITERE4 -= '& [F:MHS]CTR="'+SCONTRAT+'"'
Endif


If SITEDEB<>""
 CRITERE3 -= '& [F:MHS]FCY>="'+SITEDEB+'"'
Endif
If SITEFIN<>""
 CRITERE3 -= '& [F:MHS]FCY<="'+SITEFIN+'"'
Endif
If PROFIL<>""
 CRITERE3 -= '& [F:MHS]PRF="'+PROFIL+'"'
Endif
If SERVICE<>""
 CRITERE3 -= '& [F:MHS]SRV="'+SERVICE+'"'
Endif

Return

######################################################################################
$TRI_LNK_FILTRE
#Clé de tri des données parcourues en fonction du détail demandé
Case LDETAIL # ML 489
 When 1 # Pas de détail
If POPULATION<>""
 Link [F:MHS] With
&  [F:ID]ID0    = [F:MHS]EMP
&    , [F:HRPOA]POA0 ~= POPULATION;[F:ID]REFNUM
&    , [F:RUB]RUB0  = [F:MHS]RUB
&    , [F:MSR]MSR0  = [F:MHS]RUB
&    , [F:ADI0]CODE = 10655;[F:MHS]CAT
& As [LMHS]
& Where (evalue (CRITERE) | evalue (CRITERE0))
&   & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue (CRITERE4) & evalue(CRIT1)
&   & [F:HRPOA]REFNUM<>""
& Order By Key CLE = [F:ADI0]N1;[F:MHS]GRP;[F:MHS]RUB
Else
 Link [F:MHS] With
& [F:ID]ID0    = [F:MHS]EMP
&    , [F:RUB]RUB0  = [F:MHS]RUB
&    , [F:MSR]MSR0  = [F:MHS]RUB
&    , [F:ADI0]CODE = 10655;[F:MHS]CAT
& As [LMHS]
& Where (evalue (CRITERE) | evalue (CRITERE0))
&    & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue (CRITERE4) & evalue(CRIT1)
& Order By Key CLE = [F:ADI0]N1;[F:MHS]GRP;[F:MHS]RUB
