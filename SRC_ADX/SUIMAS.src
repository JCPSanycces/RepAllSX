&    , [F:RUB]RUB0  = [F:MHS]RUB
&    , [F:MSR]MSR0  = [F:MHS]RUB
&    , [F:ADI0]CODE = 10655;[F:MHS]CAT
& As [LMHS]
& Where (evalue (CRITERE) | evalue (CRITERE0))
&    & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue (CRITERE4) & evalue(CRIT1)
& Order By Key CLE = [F:MHS]JOBPOT;[F:ADI0]N1;[F:MHS]GRP;[F:MHS]RUB
Endif
 When 7 # Détail poste
If POPULATION<>""
 Link [F:MHS] With
&  [F:ID]ID0    = [F:MHS]EMP
&    , [F:HRPOA]POA0 ~= POPULATION;[F:ID]REFNUM
&    , [F:RUB]RUB0  = [F:MHS]RUB
&    , [F:MSR]MSR0  = [F:MHS]RUB
&    , [F:ADI0]CODE = 10655;[F:MHS]CAT
& As [LMHS]
& Where (evalue (CRITERE) | evalue (CRITERE0))
&   & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue (CRITERE4) & evalue(CRIT1)
&   & [F:HRPOA]REFNUM<>""
& Order By Key CLE = [F:MHS]POT;[F:ADI0]N1;[F:MHS]GRP;[F:MHS]RUB
Else
 Link [F:MHS] With
& [F:ID]ID0    = [F:MHS]EMP
&    , [F:RUB]RUB0  = [F:MHS]RUB
&    , [F:MSR]MSR0  = [F:MHS]RUB
&    , [F:ADI0]CODE = 10655;[F:MHS]CAT
& As [LMHS]
& Where (evalue (CRITERE) | evalue (CRITERE0))
&    & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue (CRITERE4) & evalue(CRIT1)
& Order By Key CLE = [F:MHS]POT;[F:ADI0]N1;[F:MHS]GRP;[F:MHS]RUB
Endif
 When 8,9 # Détail salarié & contrat
If POPULATION<>""
 Link [F:MHS] With
&  [F:ID]ID0    = [F:MHS]EMP
&    , [F:HRPOA]POA0 ~= POPULATION;[F:ID]REFNUM
&    , [F:RUB]RUB0  = [F:MHS]RUB
&    , [F:MSR]MSR0  = [F:MHS]RUB
&    , [F:ADI0]CODE = 10655;[F:MHS]CAT
& As [LMHS]
& Where (evalue (CRITERE) | evalue (CRITERE0))
&   & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue (CRITERE4) & evalue(CRIT1)
&   & [F:HRPOA]REFNUM<>""
& Order By Key CLE = [F:MHS]MSEMP;[F:MHS]EMP;[F:MHS]CTR;[F:ADI0]N1;[F:MHS]GRP;[F:MHS]RUB
Else
 Link [F:MHS] With
& [F:ID]ID0    = [F:MHS]EMP
&    , [F:RUB]RUB0  = [F:MHS]RUB
&    , [F:MSR]MSR0  = [F:MHS]RUB
&    , [F:ADI0]CODE = 10655;[F:MHS]CAT
& As [LMHS]
& Where (evalue (CRITERE) | evalue (CRITERE0))
&    & evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) & evalue (CRITERE4) & evalue(CRIT1)
& Order By Key CLE = [F:MHS]MSEMP;[F:MHS]EMP;[F:MHS]CTR;[F:ADI0]N1;[F:MHS]GRP;[F:MHS]RUB
Endif
Endcase
Return
######################################################################################
$ALIM_LIGN
# Alimentation d'une ligne pour le scénario 1 ou pour le scénario 2
# projection : récupération du simulé dans le réel au delà de la date de maj du réel

If IND1 <> 0
 If [F:MHS]SIM = 2             : # Calcul MS
  V1_AMT     += [F:MHS]AMT
  If V_PROJ & ( [F:MHS]DAT > LREADAT(0) | [F:MHS]EMP <> "" )  : # 73294
   V1_REA     += [F:MHS]AMT
  Endif
 Else
  V1_REA     += [F:MHS]REA     : #Paie Réelle
 Endif
 Gosub CALCUL_ECA1

Endif

Return

$CALCUL_ECA1
#calcul de l'écart réalisé - budgété
 If LDISPLAY = 1 & V1_REA <> 0 & V1_AMT <> 0   : # en %
  V1_ECA     = (( V1_REA / V1_AMT ) - 1 ) * 100
 Elsif LDISPLAY = 2                            : # en montant
  V1_ECA     = V1_REA - V1_AMT
 Endif
Return
######################################################################################
$FILT_HYP_ACTIV
#Recherche dans le tableau des hypothèses actives par période
IND1 = 0
#Scénario 1
For I = 0 To ACTMAX(1)
 If [F:MHS]DAT >= LACTDEB1(I) & [F:MHS]DAT <= LACTFIN1(I)
  If [F:MHS]COD = LACTSCE1(I) & [F:MHS]LIGHYP = LACTHYP1(I)
   IND1 = I+1
  Endif
  Break
 Endif
Next
If [F:MHS]COD = SCENARIO & [F:MHS]SIM = 1 : # PAIE réelle
 IND1 = -1
Endif
Return

$LIB_MCH
[F:TMP]MCH  = mess(16,10722,1)-mess(LTYPMCH(0),10486,1)                        : #Scénario type
If LTYPMCH(0) = 1
 [F:TMP]MCH -= "("+LCODHYP(0)+")"
Endif
[F:TMP]MCH -= ",   "+mess(94,100,1)-format$("D:DD[/]MM[/]YYYY",LSTRDAT(0)) : #Du
[F:TMP]MCH -= mess(95,100,1)-format$("D:DD[/]MM[/]YYYY",LENDDAT(0))        : #au
[F:TMP]MCH -= ",   "+mess(21,10722,1)-format$("D:MM[/]YYYY",LMTHREF(0))      : #Mois de référence

Return
###############################################################################
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End
