#<AdxTL>@(#)4.0.0.0 $Revision$
################################################################################
## Etat SUIMAS
# SEGAY - 20/05/11 - EXI 72645
# Suivi de masse salariale
#################################################################################

Call IMPRIME("SUIMAS","") From ETAT
End


####################################################
## Etat livrepaye
####################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

If clalev([F:MHS])=0 : Local File MSHISTOH    [MHS] : Endif

If clalev([F:FGR])=0 : Local File FACGROUP    [FGR] : Endif
If clalev([F:CPY])=0 : Local File COMPANY     [CPY] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE    [RUB] : Endif
If clalev([F:TMP])=0 : Local File TMPSUIMAS   [TMP] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE      [ATX] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA     [AXX] : Endif
If clalev([F:HRPOA])=0 : Local File POPULA      [HRPOA] : Endif
If clalev([F:ACC])=0 : Local File ACCES       [ACC] : Endif
If clalev([F:CUM])=0 : Local File CUMUL       [CUM] : Endif
If clalev([F:ECT])=0 : Local File EMPCTR      [ECT] : Endif
If clalev([F:SRV])=0 : Local File SERVICE     [SRV] : Endif
If clalev([F:ADI0])=0 : Local File ATABDIV    [ADI0]: Endif
If clalev([F:MCH])=0  : Local File MSSCENAH   [MCH] : Endif
If clalev([F:MCH2])=0 : Local File MSSCENAH   [MCH2]: Endif
If clalev([F:MCL])=0  : Local File MSSCENAL   [MCL] : Endif
If clalev([F:MSR])=0  : Local File MSRUB      [MSR] : Endif
If clalev([F:MSR1])=0 : Local File MSRUB      [MSR1]: Endif
If clalev([F:RUB1])=0 : Local File RUBRIQUE   [RUB1]: Endif
If clalev([F:MLR])=0  : Local File MSLRUB     [MLR] : Endif
If clalev([F:MLR1])=0 : Local File MSLRUB     [MLR1]: Endif

Gosub OUVRE From WPDEFTABLE

Local Char    SCENARIO(GLONMCH),SOCIETE(GLONCPY) , SITEDEB(GLONFCY) , SITEFIN(GLONFCY) , MATDEB(GLONEML) , MATFIN(GLONEML)
Local Char    POSTE(GLONPOT),EMPLOI(GLONJOT)
Local Date    DATEDEB , DATEFIN
Local Char    LISRUB(GLONMLR)
Local Char    RUBRIQ(GLONRUB)
Local Char    SGROUPE(20)
Local Char    SCONTRAT(GLONHRCTR)
Local Char    CATEGORIE(20)
Local Char    PARAM(20) , PROFIL(GLONPRF) , SERVICE(GLONSRV)
Local Char    CRIT1(250), CRIT2(250)
Local Char    CRITERE(250)
Local Char    CRITERE0  (250)
Local Char    CRITERE1  (250)
Local Char    CRITERE2  (250)
Local Char    CRITERE3  (250) #70009
Local Char    CRITERE4  (250) #70009

Local Integer I , J , K , IND,  NBMOIS , GROUPE , NUMREQ , LIGTMP , OK
Local Char    MATRI(GLONEML) , POPULATION(GLONPOP), CTR(GLONHRCTR)
Local Date    DATMAT
Local Integer NCOL , ICOL , NGRP , MCOL
Local Integer NBRUB , MAXRUB
Local Integer DETRUB
Local Integer NBSITE
Local Char    TBSITE(GLONFCY)(1..GNBSITE)
Local Integer NBCAT , NBGRP
Local Integer TEST
# SEGAY - 01/12/10 - EXI 69466 lot P13, SAM lot 1
# Sauvegarde GFONCTION
Local Char    SVFONCTION(GLONAFC)
Local Date    LSTRDAT(0..4)
Local Date    LENDDAT(0..4)
Local Date    LREADAT(0..4)
Local Date    LENDDAT(0..4)
Local Date    LMTHREF(0..4)
Local Integer LTYPMCH(0..4)
Local Char    LCODHYP(20)(0..4)
Local Integer LTYPINI
Local Decimal EXEFULL
Local Integer LDISPLAY : # Gestion des écarts ML 488
Local Integer LDETAIL : # Gestion du détail ML 489
Local Integer LNIVEAU : # Gestion du niveau ML 494
Local Integer LNIV : # Gestion de la Key pour TMP
Local Char    LCATEGORIE(25)
Local Char    LGROUPE(20)
Local Char    LRUBRIQUE(GLONRUB)
Local Char    LCPY(GLONCPY)
Local Char    LFCY(GLONFCY)
Local Char    LSRV(GLONSRV)
Local Char    LPRF(GLONPRF)
Local Char    LJOBPOT(GLONJOT)
Local Char    LPOT(GLONPOT)
Local Char    LEMP(GLONEML)
Local Char    LCTR(GLONHRCTR)

Local Integer NBRCAT , MAXCAT
Local Decimal  V1_AMT,V1_REA,V1_ECA,V2_AMT,V2_REA,V2_ECA,V_PROJ
Local  Shortint IND1 , IND2 , IND3 , IND4
Local Integer OKTMP
Local Char    LACTSCE1(GLONMCH)(0..func AFNC.ACTIV("MCH"))
Local Decimal LACTHYP1(0..func AFNC.ACTIV("MCH"))
Local Date    LACTDEB1(0..func AFNC.ACTIV("MCH"))
Local Date    LACTFIN1(0..func AFNC.ACTIV("MCH"))
Local Char    FCYGRP(GLONFCY)(1..999)
Local Char    RUBGRP(GLONRUB)(1..999)
Local Decimal LMOD
Local Decimal CUMBUD
Local Decimal CUMREA
Local Char    LCODACC(GLONACS)
Local Char    LCODGRP(GLONADI)

Global Shortint ACTMAX (1..4)

Raz ACTMAX(1..4)

#Champ pour tester l'impression
Raz TEST
TEST = 0
GOK = 1

NCOL   = 3 : # Nombre de colonne par groupe (3 mois)
NGRP   = 4 : # Nombre de groupe de mois
MAXRUB = nbrecord([F:RUB])+10
Filter [F:ADI0] Where [F:ADI0]NUMTAB=10655 Order By Key CLE = [F:ADI0]NUMTAB;[F:ADI0]N1
MAXCAT = rowcount([F:ADI0])+10
Local Char TBCAT(GLONADI)(1..MAXCAT)
Local Decimal RESBUDCAT(1..MAXCAT,1..NGRP*NCOL)
Local Decimal RESREACAT(1..MAXCAT,1..NGRP*NCOL)
Local Decimal RESECACAT(1..MAXCAT,1..NGRP*NCOL)

For [F:ADI0]CLE
 NBRCAT += 1
 TBCAT(NBRCAT) = num$([F:ADI0]N1)+"~"+[F:ADI0]CODE
Next
Filter [F:ADI0]


Call GETPARAM("scenario",NBPAR,PARAMETRE,SCENARIO)
Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE)
Call GETPARAM("sitedeb",NBPAR,PARAMETRE,SITEDEB)
Call GETPARAM("sitefin",NBPAR,PARAMETRE,SITEFIN)
Call GETPARAM("population",NBPAR,PARAMETRE,POPULATION)
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB)
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN)
Call GETPARAM("datedeb",NBPAR,PARAMETRE,PARAM) : DATEDEB = PARAM
Call GETPARAM("datefin",NBPAR,PARAMETRE,PARAM) : DATEFIN = PARAM
Call GETPARAM("contrat",NBPAR,PARAMETRE,SCONTRAT)
Call GETPARAM("profil",NBPAR,PARAMETRE,PROFIL)
Call GETPARAM("service",NBPAR,PARAMETRE,SERVICE)
Call GETPARAM("emploi",NBPAR,PARAMETRE,EMPLOI)
Call GETPARAM("poste",NBPAR,PARAMETRE,POSTE)
Call GETPARAM("lisrub",NBPAR,PARAMETRE,LISRUB)
Call GETPARAM("categorie",NBPAR,PARAMETRE,CATEGORIE)
Call GETPARAM("groupe",NBPAR,PARAMETRE,SGROUPE)
Call GETPARAM("rubriq",NBPAR,PARAMETRE,RUBRIQ)
Call GETPARAM("ecart",NBPAR,PARAMETRE,PARAM) : LDISPLAY = val(PARAM) : # Gestion des écarts ML 488
Call GETPARAM("niveau",NBPAR,PARAMETRE,PARAM) : LNIVEAU = val(PARAM) : # Gestion des écarts ML 488
Call GETPARAM("detail",NBPAR,PARAMETRE,PARAM) : LDETAIL = val(PARAM) : # Gestion des écarts ML 488
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : [L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

#Read [CPY]CPY0 = SOCIETE
#If fstat
# Call ERREUR(mess(65,10702,1)) From GESECRAN : # Société inexistante
# GOK = 0 : End
#Endif

K = 12*(year(DATEFIN)-year(DATEDEB)) + (month(DATEFIN)-month(DATEDEB)) + 1
If K>NGRP*NCOL
 Call ERREUR(mess(25,10702,1)) From GESECRAN : # Période incorrecte
 GOK = 0 : End
Endif



NGRP = int((K+NCOL-1)/NCOL)

If RUBRIQ <> ""
  Gosub CONTROLE_RUB
  If !GOK
     End
  Endif
Endif

Read [F:MCH]MCH0= SCENARIO
LSTRDAT(0) = [F:MCH]STRDAT
LENDDAT(0) = [F:MCH]ENDDAT
LREADAT(0) = [F:MCH]DATMAJREA
LMTHREF(0) = [F:MCH]MTHREF
LTYPMCH(0) = [F:MCH]TYPMCH
If [F:MCH]TYPMCH = 1
 If LTYPINI = 7
  LCODHYP(0) = [F:MCH]BUD(0)
 Else
  LCODHYP(0) = [F:MCH]BUD(1)
 Endif
Endif

Call ALIM_HYPO_ACTIV(1,SCENARIO,LSTRDAT(0),LENDDAT(0),
&                    LACTSCE1,LACTHYP1,LACTDEB1,LACTFIN1,EXEFULL,7)
& From CNSMASSTD
EXEFULL = 1

Gosub CREER_FILTRE


Call TEMPON("O") From GESECRAN



## Critère population, société + link
Gosub TRI_LNK_FILTRE




# Transaction

If TEST
 Call OUVRE_TRACE("") From LECFIC
Endif
Call DEBTRANS From GLOCK
# SEGAY - 01/12/10 - EXI 69466 lot P13, SAM lot 1
# Sauvegarde GFONCTION
SVFONCTION = GFONCTION
Call GETPARAM("X3FCT",NBPAR,PARAMETRE,GFONCTION) From ETAT
Call AUTORIS From EXEFNC

Gosub TR1

# SEGAY - 01/12/10 - EXI 69466 lot P13, SAM lot 1
# Sauvegarde GFONCTION
GFONCTION = SVFONCTION
Call AUTORIS From EXEFNC

Call TEMPOFF From GESECRAN
If TEST
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End


$TR1
GOK = 1
Raz NBCAT , NBGRP
LIGTMP = 0
GROUPE = 0
Trbegin [TMP]
#Delete [TMP] Where USR=GUSER & DAT<date$
Delete [TMP] Where USR=GUSER

If fstat=1
  GOK = -1 : GLOCK = "TMPSUIMAS"-GUSER : Goto ROLL_TR1
Endif

Raz IND1 , IND2 , IND3 , IND4
IND1=1
OKTMP = 0

Raz RESBUDCAT
Raz RESREACAT
Raz RESECACAT

For [LMHS]CLE(1)  : # Catégorie
  NBCAT += 1
  MCOL  = 0
  For [LMHS]CLE  : # Catégorie + Groupe + Rubrique
    Gosub FILT_HYP_ACTIV
    If (IND1 <> 0 ) &
& (([F:MHS]TYP=2 & [F:RUB]TYPRUB=6) | ([F:MHS]TYP=2 & [F:MSR]TYPRUB=6) | ([F:RUB]TYPRUB<>6 & [F:MSR]TYPRUB<>6))
# interdire la saisi d'un groupe MS dès la modif de la rubrique plutôt que tester ci-avant
     If [F:MHS]DAT >= DATEDEB & [F:MHS]DAT <= DATEFIN

      OK = 1
      NBGRP += 1

      MATRI  = [F:MHS]EMP
      CTR    = [F:MHS]CTR
      If TEST
         Call ECR_TRACE(MATRI-CTR-[F:FGR]CPY-[F:FGR]FCY-"("+[F:MHS]FCY+")",0) From GESECRAN
      Endif

      DATMAT = [F:MHS]DAT
      ICOL   = 12*(year([F:MHS]DAT)-year(DATEDEB)) + (month([F:MHS]DAT)-month(DATEDEB)) + 1
      MCOL   = max(ICOL,MCOL)
      Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
      Read [HRCTR]CTR0 Last
      Filter [HRCTR]
      If !fstat
        Call CONTROLE(MATRI,DATMAT,CTR,"",OK,0) From DIVPAYE
        # Droits par service
        # SEGAY - 01/12/10 - EXI 69466 lot P13, SAM lot 1
        # Test pour avoir la même chose que dans l'état accés en consultation
        # Car le tableau GAUTSRV est rempli si on seulement droit exécution = "Oui"
        If OK
          Gosub CONTROLE_SRV
        Endif
      Else
        OK = 0
      Endif
      If OK & ([F:MHS]AMT<>0 or [F:MHS]REA<>0)
       GROUPE = int((ICOL+NCOL-1)/NCOL)
       Raz V1_AMT, V1_REA, V1_ECA
       IND = mod(ICOL-1,NCOL)
       LCATEGORIE = num$([F:ADI0]N1)+"~"+[F:ADI0]CODE
       LGROUPE = [F:MHS]GRP
       LRUBRIQUE = [F:MHS]RUB
       LCPY = [F:MHS]CPY
       LFCY = [F:MHS]FCY
       LSRV = [F:MHS]SRV
       LPRF = [F:MHS]PRF
       LJOBPOT = [F:MHS]JOBPOT
       LPOT = [F:MHS]POT
       LEMP = [F:MHS]EMP
       LCTR = [F:MHS]CTR
       Gosub FILT_TMP
       Readlock [TMP]TMH0 Last
       Filter [F:TMP]
       If !fstat
           V1_AMT = [F:TMP]AMT(IND)
           V1_REA = [F:TMP]REA(IND)
           V1_ECA = [F:TMP]ECART(IND)
           Gosub ALIM_LIGN
           [F:TMP]AMT(IND) = V1_AMT
           [F:TMP]REA(IND) = V1_REA
           [F:TMP]ECART(IND) = V1_ECA
          Rewrite [F:TMP]
          If fstat
             GOK = 0 : Call FSTA("TMP") From GLOCK : Break 2
          Endif
       Elsif fstat=1
          GOK=-1 : GLOCK="$TMPSUIMAS"-num$([L]NUMREQ)-GUSER
       Else
        Raz [F:TMP]
        Raz V1_AMT, V1_REA, V1_ECA
        LIGTMP +=1
        Gosub ALIM_LIGN
        [F:TMP]AMT(IND) = V1_AMT
        [F:TMP]REA(IND) = V1_REA
        [F:TMP]ECART(IND) = V1_ECA

        [F:TMP]STR = addmonth(DATEDEB,(GROUPE-1)*NCOL)
        [F:TMP]CAT = num$([F:ADI0]N1)+"~"+[F:ADI0]CODE
        [F:TMP]GRP = LGROUPE
        [F:TMP]RUB = LRUBRIQUE
        [F:TMP]CPY = LCPY
        [F:TMP]FCY = LFCY
        [F:TMP]SRV = LSRV
        [F:TMP]PRF = LPRF
        [F:TMP]JOBPOT = LJOBPOT
        [F:TMP]POT = LPOT
        [F:TMP]EMP = LEMP
        [F:TMP]CTR = LCTR
        [F:TMP]USR     = GUSER
        [F:TMP]NUMREQ  = [L]NUMREQ
        [F:TMP]NUMLIG = LIGTMP
        [F:TMP]PER = GROUPE
        [F:TMP]DAT = date$
        Write [F:TMP]
        If fstat
         GOK = 0 : Call FSTA("TMP") From GLOCK : Break 2
        Endif
        OKTMP = 1
        If GROUPE < NGRP
          While GROUPE < NGRP
            GROUPE+=1
            Gosub FILT_TMP
            If rowcount([F:TMP]) = 0
              Filter [F:TMP]
              Raz [F:TMP]
              LIGTMP +=1
              [F:TMP]STR = addmonth(DATEDEB,(GROUPE-1)*NCOL)
              [F:TMP]CAT = num$([F:ADI0]N1)+"~"+[F:ADI0]CODE
              [F:TMP]GRP = LGROUPE
              [F:TMP]RUB = LRUBRIQUE
              [F:TMP]CPY = LCPY
              [F:TMP]FCY = LFCY
              [F:TMP]SRV = LSRV
              [F:TMP]PRF = LPRF
              [F:TMP]JOBPOT = LJOBPOT
              [F:TMP]POT = LPOT
              [F:TMP]EMP = LEMP
              [F:TMP]CTR = LCTR
              [F:TMP]USR     = GUSER
              [F:TMP]NUMREQ  = [L]NUMREQ
              [F:TMP]NUMLIG = LIGTMP
              [F:TMP]PER = GROUPE
              [F:TMP]DAT = date$
              Write [F:TMP]
              If fstat
               GOK = 0 : Call FSTA("TMP") From GLOCK : Break 3
              Endif
            Endif
            Filter [F:TMP]
          Wend
        Endif
       Endif
      Endif
     Endif
    Endif

  Next : # Catégorie Groupe Rubrique

Next : # Catégorie
If GOK=0
  Goto AB_TR1
Elsif GOK=-1
  Goto ROLL_TR1
Endif

If OKTMP & GOK
  Gosub FILT_KEY_TMP

   For [F:TMP]CLE(LNIV)
    Raz [F:TMP]AMT(NCOL),[F:TMP]REA(NCOL),[F:TMP]ECART(NCOL)
    Raz CUMBUD, CUMREA

    For [F:TMP]CLE
      For J=1 To NCOL
       CUMBUD+=[F:TMP]AMT(J-1)
       CUMREA+=[F:TMP]REA(J-1)
       [F:TMP]AMT(NCOL)= CUMBUD
       [F:TMP]REA(NCOL)= CUMREA
       Raz V1_AMT, V1_REA, V1_ECA
       V1_AMT = [F:TMP]AMT(NCOL)
       V1_REA = [F:TMP]REA(NCOL)
       Gosub CALCUL_ECA1
       [F:TMP]ECART(NCOL) = V1_ECA
      Next J
      Rewrite [F:TMP]
      If fstat
        GOK = 0 : Call FSTA("TMP") From GLOCK : Break 2
      Endif
   Next
  Next
  Filter [TMP]
Endif

If GOK=0
  Goto AB_TR1
Elsif GOK=-1
  Goto ROLL_TR1
Endif


Commit
If TEST
 Call ECR_TRACE(num$(NBCAT)-"Catégories",0) From GESECRAN
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$FILT_TMP
Case LDETAIL # ML 489
 When 1 # Pas de détail
 Case LNIVEAU
    When 4,0 # Aucun
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & CAT=LCATEGORIE
    When 3   # Catégorie de groupe
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & CAT=LCATEGORIE
    When 2   # Groupe de rubriques
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & CAT=LCATEGORIE & GRP=LGROUPE
    When 1   # Rubriques
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & CAT=LCATEGORIE & GRP=LGROUPE & RUB=LRUBRIQUE
 Endcase
 When 2 # Détail sociétés
 Case LNIVEAU
    When 4,0 # Aucun
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & CPY=LCPY & CAT=LCATEGORIE
    When 3   # Catégorie de groupe
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & CPY=LCPY & CAT=LCATEGORIE
    When 2   # Groupe de rubriques
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & CPY=LCPY & CAT=LCATEGORIE & GRP=LGROUPE
    When 1   # Rubriques
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & CPY=LCPY & CAT=LCATEGORIE & GRP=LGROUPE & RUB=LRUBRIQUE
  Endcase
 When 3 # Détail sites
 Case LNIVEAU
    When 4,0 # Aucun
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & FCY=LFCY & CAT=LCATEGORIE
    When 3   # Catégorie de groupe
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & FCY=LFCY & CAT=LCATEGORIE
    When 2   # Groupe de rubriques
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & FCY=LFCY & CAT=LCATEGORIE & GRP=LGROUPE
    When 1   # Rubriques
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & FCY=LFCY & CAT=LCATEGORIE & GRP=LGROUPE & RUB=LRUBRIQUE
  Endcase
 When 4 # Détail services
 Case LNIVEAU
    When 4,0 # Aucun
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & SRV=LSRV & CAT=LCATEGORIE
    When 3   # Catégorie de groupe
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & SRV=LSRV & CAT=LCATEGORIE
    When 2   # Groupe de rubriques
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & SRV=LSRV & CAT=LCATEGORIE & GRP=LGROUPE
    When 1   # Rubriques
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & SRV=LSRV & CAT=LCATEGORIE & GRP=LGROUPE & RUB=LRUBRIQUE
  Endcase
 When 5 # Détail profil
 Case LNIVEAU
    When 4,0 # Aucun
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & PRF=LPRF & CAT=LCATEGORIE
    When 3   # Catégorie de groupe
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & PRF=LPRF & CAT=LCATEGORIE
    When 2   # Groupe de rubriques
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & PRF=LPRF & CAT=LCATEGORIE & GRP=LGROUPE
    When 1   # Rubriques
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & PRF=LPRF & CAT=LCATEGORIE & GRP=LGROUPE & RUB=LRUBRIQUE
  Endcase
 When 6 # Détail emploi type
 Case LNIVEAU
    When 4,0 # Aucun
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & JOBPOT=LJOBPOT & CAT=LCATEGORIE
    When 3   # Catégorie de groupe
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & JOBPOT=LJOBPOT & CAT=LCATEGORIE
    When 2   # Groupe de rubriques
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & JOBPOT=LJOBPOT & CAT=LCATEGORIE & GRP=LGROUPE
    When 1   # Rubriques
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & JOBPOT=LJOBPOT & CAT=LCATEGORIE & GRP=LGROUPE & RUB=LRUBRIQUE
  Endcase
 When 7 # Détail poste
 Case LNIVEAU
    When 4,0 # Aucun
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & POT=LPOT & CAT=LCATEGORIE
    When 3   # Catégorie de groupe
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & POT=LPOT & CAT=LCATEGORIE
    When 2   # Groupe de rubriques
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & POT=LPOT & CAT=LCATEGORIE & GRP=LGROUPE
    When 1   # Rubriques
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & POT=LPOT & CAT=LCATEGORIE & GRP=LGROUPE & RUB=LRUBRIQUE
  Endcase
 When 8,9 # Détail salarié Contrat
 Case LNIVEAU
    When 4,0 # Aucun
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & EMP=LEMP & CTR=LCTR & CAT=LCATEGORIE
    When 3   # Catégorie de groupe
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & EMP=LEMP & CTR=LCTR & CAT=LCATEGORIE
    When 2   # Groupe de rubriques
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & EMP=LEMP & CTR=LCTR & CAT=LCATEGORIE & GRP=LGROUPE
    When 1   # Rubriques
      Filter [TMP] Where NUMREQ=[L]NUMREQ & USR=GUSER & PER=GROUPE & EMP=LEMP & CTR=LCTR & CAT=LCATEGORIE & GRP=LGROUPE & RUB=LRUBRIQUE
  Endcase

Endcase


Return

