#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIPJM015 Moulinette d'entretien des listes de gauche des
#           objets
# Issue X3-27075/121759 - 2017-02-28 by FGR
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM015(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM015(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Char WOBJET(GLONAOB)
Local Integer WNBR
Local Integer B_OK

  Call ECR_TRACE("UTIPJM015: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  If clalev([F:AOB]) = 0 : Local File =DOSSIER + ".AOBJET"  [AOB] : Endif
  Raz COMPTEUR
  #
  # Issue X3-19361/121162 - 2017-03-15 by FGR add "PSO2","PSO3"
  For WOBJET="PSO1","PSO2","PSO3","PSO"
    Read [AOB]ABREV=WOBJET
    If !fstat Then
      Call MAJ_SEL(DOSSIER, WOBJET) From PATCHAOB
      #
      If [F:AOB]TYPGES <> 4 Then
        # Pas de fenêtre pour les browsers
        Call VALID("O" + WOBJET, DOSSIER, 1, B_OK) From VALWIN
        If B_OK <> 1 Then
          Call ECR_TRACE("Window validation error O" + WOBJET, 1) From GESECRAN
        Endif
      Endif
      #
      Call VALID (WOBJET, DOSSIER, 1, B_OK) From VALOBJ
      If B_OK <> 1 Then
        Call ECR_TRACE("Object validation error" - WOBJET, 1) From GESECRAN
      Endif
      #
      COMPTEUR += 1
    Endif
  Next WOBJET
  #
  Close Local File [AOB]
  Call ECR_TRACE("UTIPJM015 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"AOBJET") : End : Endif
  Call MAJ_UTIPJM015(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If func DOSVUE.ISVIEW(APPLI,"AOBJET") : End : Endif
  Call MAJ_UTIPJM015(APPLI)
End

