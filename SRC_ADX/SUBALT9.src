#<AdxTL>@(#)1.0.0.0 $Revision$
Close Local File
Raz GPILOBJ , GNBMASKOUV
GCONSULT = 0
Call OBJET("ALT",GBIDC1,GBIDC2) From GOBJET
End

#-------------------------------------------------------#
$ACTION
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub OK
Endcase
Return

#----------------------#
$DEBUT
Local Integer EX
[M]FORMU = VALEUR
For I=1 To 5
 [M]TABLE(I-1) = PARAM(I)
Next I
[M]INTITLIG = PARAM(6)
[M]CODTYP   = PARAM(7)
[M]NOLIB    = val(PARAM(8))
[M]LONG     = val(PARAM(9))
[M]COD      = PARAM(10)
[M]LIG      = val(PARAM(11))
If dim([M]EXPR)>0
 [M]EXPR    = val(PARAM(12))
Endif
[M]BORNE    = val(PARAM(13))
[M]VALDEB   = PARAM(14)
[M]VALFIN   = PARAM(15)
If dim([M]NUMTEX)>0
 [M]NUMTEX = val(PARAM(16)) #Bug 78943
Endif
Affzo
Gosub GRISE_NOLIB
Gosub GRISE_LONG
Gosub GRISE_AUTRE
Gosub GRISE_VALDEB
Return

#----------------------#
$OK
VALEUR    = [M]FORMU 
PARAM(6)  = [M]INTITLIG
PARAM(7)  = [M]CODTYP
PARAM(8)  = num$([M]NOLIB)
PARAM(9)  = num$([M]LONG)
PARAM(14) = [M]VALDEB
PARAM(15) = [M]VALFIN
If dim([M]NUMTEX)
 PARAM(16) = num$([M]NUMTEX) #Bug 78943
Endif
Return

#----------------------#
$GRISE_NOLIB
Call LECTURE("ATY",[M]CODTYP,"") From CONTOBJ
If [F:ATY]TYPTYP<>1 & [M]CODTYP<>"ADI"
 [M]NOLIB = 0
 Affzo NOLIB
 Grizo NOLIB
Else
 Actzo NOLIB
Endif
Return

#----------------------#
$GRISE_LONG
Call LECTURE("ATY",[M]CODTYP,"") From CONTOBJ
If [F:ATY]LNGTYP<>0
 [M]LONG = [F:ATY]LNGTYP
 Affzo LONG
 Grizo LONG
Else
 Actzo LONG
Endif
Return

#----------------------#
$GRISE_AUTRE
If dim([M]EXPR)<0 or [M]EXPR
 Actzo FORMU
Else
 Grizo FORMU
Endif
Return

#----------------------#
$GRISE_VALDEB
If [M]BORNE=2
 Actzo VALDEB , VALFIN
Else
 [M]VALDEB = ""
 [M]VALFIN = ""
 Affzo VALDEB , VALFIN
 Grizo VALDEB , VALFIN
Endif
Return

#-------------------------------------------------------#
Subprog C_FORMU(VALEUR)
Variable Char   VALEUR()
If VALEUR=""
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2 : End
Elsif len(VALEUR)>mod(type([M]FORMU)-10,256)
 GMESSAGE = mess(122,123,1) : # Longueur trop grande
 mkstat = 2 : End
Endif
End

Subprog AM_CODTYP(VALEUR)
Variable Char    VALEUR()
[M]CODTYP = VALEUR
Gosub GRISE_NOLIB
Gosub GRISE_LONG
End

Subprog C_CODTYP(VALEUR)
Variable Char    VALEUR()
Local Integer OTYP
Read [ATY]CODTYP=[M]CODTYP
If !fstat
 OTYP = [F:ATY]TYPTYP
Endif
Read [ATY]CODTYP=VALEUR
If !fstat
 If find([F:ATY]TYPTYP,9,10) : # Clob, Blob
  GMESSAGE = mess(198,139,1) : # Type de champ non géré
  mkstat = 2 : End
 Elsif dim([M]EXPR)>0 & [M]EXPR=0
  If (find(OTYP,1,2,3,4,5,6) & [F:ATY]TYPTYP>6) or (OTYP=7 & [F:ATY]TYPTYP<>7) or (OTYP=8 & [F:ATY]TYPTYP<>8)
   GMESSAGE = mess(269,139,1) : # Ce type de donnée est incohérent avec le champ
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog AS_NOLIB(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]CODTYP,"") From CONTOBJ
If [F:ATY]TYPTYP<>1 & [M]CODTYP <> "ADI"
 Raz VALEUR
 mkstat = 2 : End 
Elsif [F:ATY]NOLIB > 0
 VALEUR = [F:ATY]NOLIB
 mkstat = 3 :  End
Endif
End

Subprog C_NOLIB(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]CODTYP,"") From CONTOBJ
If [F:ATY]TYPTYP=1 
 If VALEUR<1 | (VALEUR>99 & VALEUR<201)
  GMESSAGE = mess(5,176,1) : # No menu local incorrect
  mkstat = 2 : End
 Elsif mess(0,VALEUR,1)=""
  GMESSAGE = mess(98,123,1) : # Menu local non défini
  mkstat = 2 : End
 Endif
Elsif [F:ATY]TYPTYP<>1  & [M]CODTYP = "ADI"
 Call CONTROLE("ADV","",num$(VALEUR),"",mkstat) From CONTOBJ
Endif
End

Subprog AS_LONG(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]CODTYP,"") From CONTOBJ
If [F:ATY]LNGTYP<>0 : VALEUR = [F:ATY]LNGTYP : mkstat = 2 : End : Endif
End

Subprog C_LONG(VALEUR)
Variable Decimal VALEUR
nolign = 1
Call C_LONG(VALEUR) From SUBATB
End

