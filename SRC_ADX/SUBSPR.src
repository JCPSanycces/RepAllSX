#<AdxTL>@(#)70.0.0.0 $Revision$
########################################################################
# SUBSPR : Gestion des motifs de prix VENTES             Créé par JLS  #
#                                                                      #
#----------------------------------------------------------------------#
# Table mise à jour  : [F:SPR]SPREASON                                 #
########################################################################

Call OBJET("SPR",GBIDC1,GBIDC2) From GOBJET
End

#########################################################################
$ACTION
Case ACTION
 When "SETBOUT"    : Gosub SETBOUT   : # Activation/désactivation boutons
 When "FILTRE"     : Gosub FILTRE    : # Ecriture du tableau
 When "LIENS"      : Gosub LIENS     : # Après chargement de chaque ligne
 When "INICRE"     : Gosub INICRE    : # Chargement de la cle
 When "VERIF_MOD"  : Gosub VERIF_MOD : # Vérification avant d'enregistrer
 When "VERF_ANU"   : Gosub VERF_ANU  : # Contrôle de suppression
 When "AVANT_ACT"  : Gosub AVANT_ACT : # Avant exécution d'une action bouton
 When "FERME"      : Gosub FERME     : # pour test valeur des globales
 When "MODIF"      : Gosub MODIF
 When "ANNULE"     : Gosub ANNULE
 When "CHANGE"       : Call CHANGE_AXX ("SPREASON", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When Default
Endcase
Return

#########################################################################

$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET : # Désactivation changement de clé
Return

$FILTRE
FILTSUP=""
Return

$LIENS
If [M:SPR1]DACMAN(nolign-1)=0  [M:SPR1]DACMAN(nolign-1)=1 : Endif
If [M:SPR1]UPDPRI(nolign-1)=0  [M:SPR1]UPDPRI(nolign-1)=1 : Endif
Return

#------------------------------------------------------------------------
$INICRE
[F:SPR]PRIREN=nolign
[M:SPR1]PRIREN(nolign-1)=nolign
[F:SPR]PRIRENCAR=num$([F:SPR]PRIREN)
[F:SPR]DES=[M:SPR1]DESAXX(nolign-1)
[F:SPR]LANDESSHO=GLANGUE+"~"+[F:SPR]DES
Return

#------------------------------------------------------#
# avant exécution d'une action bouton (ex Suppression) #
#------------------------------------------------------#
$AVANT_ACT
If BOUT<>"S" Return : Endif
If [M:SPR1]NBREN<>nolign
   GERR = 1 : GMESSAGE=mess(186,199,1) : OK=0 
Endif  
Return

#------------------------------------------------------------------------
# Contrôle si présence des motifs par défaut
#   - GDACMANPUR : Motif par défaut en saisie manuelle
#   - GUPDPRIPUR : Motif par défaut pour le prix
#------------------------------------------------------------------------
$VERIF_MOD
If GDACMANSAL<>0
  If [M:SPR1]NBREN<GDACMANSAL
    GMESSAGE=mess(8,191,1)+num$(GDACMANSAL) : GERR=1 : OK=0 : Return
  Elsif [M:SPR1]DACMAN(GDACMANSAL-1)<>2 | [M:SPR1]UPDPRI(GDACMANSAL-1)<>2
    GMESSAGE=mess(12,191,1)+num$(GDACMANSAL) : GERR=1 : OK=0 : Return
  Endif
Endif
If GUPDPRISAL<>0
  If [M:SPR1]NBREN<GUPDPRISAL
    GMESSAGE=mess(9,191,1)+num$(GUPDPRISAL) : GERR=1 : OK=0 : Return
  Endif
Endif
Return

#------------------------------------------------------------------------  
# Seule la dernière ligne est supprimable à cause de la numérotation  
#------------------------------------------------------------------------   
$VERF_ANU  
If [M:SPR1]NBREN<>val(CODE)  
   GERR=1
   GMESSAGE=mess(186,199,1)  
Endif   
Return  
  
#------------------------------------------------------------------------
# Controle si présence des motifs par défaut
#   - GDACMANSAL : Motif par défaut en saisie manuelle
#   - GUPDPRISAL : Motif par défaut pour le prix
#------------------------------------------------------------------------
$FERME
If GDACMANSAL<>0
 Read [F:SPR]SPR0=GDACMANSAL
 If fstat
  GERR=2
  GMESSAGE=mess(8,191,1)+num$(GDACMANSAL)
 Else
  If [F:SPR]DACMAN<>2 | [F:SPR]UPDPRI<>2
   GERR=2
   GMESSAGE=mess(12,191,1)+num$(GDACMANSAL)
  Endif
 Endif
Endif
If GUPDPRISAL<>0
 Read [F:SPR]SPR0=GUPDPRISAL
 If fstat
  GERR=2
  GMESSAGE=mess(9,191,1)+num$(GUPDPRISAL)
 Endif
Endif
Return

#------------------------------------------------------------------------
$MODIF
Delete [AXX] Where CODFIC="SPREASON" & LANGUE=GLANGUE
If fstat=1 | fstat>5
   # FGR 12/01/2010 : X3SUIVI60986
   #GOK=0 : Call RSTA([AXX],GLANGUE) From GLOCK : Return
   GOK=0 : Call RSTA("AXX",GLANGUE) From GLOCK : Return
Endif
For nolign=1 To [M]NBREN
    Call MAJTEXTRA([M]DESAXX(nolign-1),"SPREASON","DESAXX",num$([M]PRIREN(nolign-1)),"") From ATEXTRA
    If GOK<1 : Break : Endif
Next nolign
Return

#------------------------------------------------------------------------
$ANNULE
Delete [AXX] Where CODFIC="SPREASON" & IDENT1=[L]CODE
If fstat=1 | fstat>5
   # FGR 12/01/2010 : X3SUIVI60986
   #GOK=0 : Call RSTA([AXX],[L]CODE) From GLOCK : Return
   GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

#########################################################################

Subprog C_NBREN
# interdit sup ligne sauf si dernière
If find(status,68,83) | (status=65 & NBREN<>nolign)  
   GMESSAGE=mess(186,199,1) : mkstat=2  
Endif
End

