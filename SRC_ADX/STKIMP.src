#<AdxTL>@(#)7.0.0.0 $Revision$
###############################################################################
# Traitement STKIMP - Librairie des composants d'import documents stock  V140 #
#                     Entrée - Sortie - Changement d'emplacement     MBT 2003 #
###############################################################################
# Etiquette appelée par Gosub depuis les traitements d'import IMPxxxS :       #
#                                                                             #
# ACTION : Traitement import stock                                            #
#                                                                             #
#   GSTK_TRSTYP   : Type mouvement                      Entrée Sortie Change  #
#                    1 = Entrée diverse                    E                  #
#                    2 = Sortie diverse                           S           #
#                    3 = Réception fournisseur             E                  #
#                    4 = Livraison client                         S           #
#                    5 = Entrée OF                         E                  #
#                    6 = Sortie OF                                S           #
#                    7 = Changement d'emplacement                        C    #
#                    8 = Contrôle qualité                                C    #
#                    9 = Changement de statut                            C    #
#                   11 = Retour réception                         S           #
#                   12 = Retour livraison                  E                  #
#                   14 = Transfert inter-sites                           C    #
#                   17 = Livraison de prêt                               C    #
#                   18 = Retour prêt                                     C    #
#                   19 = Réintégration en stock            E                  #
#                   20 = Livraison sous-traitance                        C    #
#                                                                             #
#   GSTK_VCRTYP   : Type de document        Objet  Table entête  Table détail #
#                    4 = Livraison           SDH    SDELIVERY     SDELIVERYD  #
#                    6 = Réception           PTH    PRECEIPT      PRECEIPTD   #
#                    8 = Retour fournisseur  PNH    PRETURN       PRETURND    #
#                   13 = Retour client       SRH    SRETURN       SRETURND    #
#                   15 = Decl production     MKI    MFGTRKNUM     MFGITMTRK   #
#                   19 = Entrée diverse      SMR    SMVTH         SMVTD       #
#                   20 = Sortie diverse      SMO    SMVTH         SMVTD       # 
# --------------------------------------------------------------------------- #
# Autres étiquettes appelées par Gosub depuis les STKIMP-E-S-C :              #
#                                                                             #
###############################################################################


$ACTION
#----- Définir si nécessaire les variables pour la trace détaillée -----#
If dim(GSTK_MESS)<1
  Global Char GSTK_MESS(100), GSTK_PGM(GLONADC), GSTK_ACT(30)
Endif
#-----
Case GSTK_TRSTYP
  When  1, 3, 5                   : Gosub ENTREES    From STKIMPE
  When 12,19                      : Gosub ENTREES    From STKIMPE
  When  2, 4, 6                   : Gosub SORTIES    From STKIMPS
  When 11                         : Gosub SORTIES    From STKIMPS
  When  7                         : Gosub CHGEMPL    From STKIMPC
Endcase
Return


#---------------------------------#
# Trace détaillée si GSTK_TRACE=2 #
#---------------------------------#
$TRACE_DETAILLEE
If GSTK_TRACE<>2  Return : Endif
If GSTK_PGM=""
  If find(GSTK_ACT,"Trbegin","Commit","Rollback")
    GSTK_MESS="---"-mess(5,126,1)-GSTK_ACT
  Else
    GSTK_MESS=GSTK_ACT
  Endif
Else
  If GSTK_ACT="AP_IMPORT"
      If SEPNUM > 0                    # hcb 96666
         GSTK_ACT+="("+[M:AOE1]FLGFIL([L]SEPNUM-1)+")"
      Endif                            # hcb 96666
  Endif
  GSTK_MESS=mess(27,115,1)-GSTK_ACT+space$(22-len(GSTK_ACT))+"From "-GSTK_PGM
Endif
Call ECR_TRACE(GSTK_MESS,0) From GESECRAN
Return
