#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECUPHDU","UTIRECHDU",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
Endcase
Return

$OUVRE
If !clalev([F:HDU])  : Local File HISTODUD      [HDU] : Endif
If !clalev([F:DUD])  : Local File GACCDUDATE    [DUD] : Endif
If !clalev([F:DAE])  : Local File GACCENTRYD    [DAE] : Endif
If !clalev([F:CPY])  : Local File COMPANY       [CPY] : Endif
If !clalev([F:FCY])  : Local File FACILITY      [FCY] : Endif
If !clalev([F:GSC])  : Local File GRPSAC        [GSC] : Endif
If !clalev ([F:HDUH]): Local File HISTODUD     [HDUH] : Endif
Return

$INIT
Gosub OUVRE
TMP = 1
Return

$EXEC
Call RECUPHDU([M:DIA]CPY,[M:DIA]ALLFCY,[M:DIA]FCY,
&             [M:DIA]ALLTYPBPR,[M:DIA]TYPBPR,[M:DIA]ALLBPR,[M:DIA]BPRSTR,[M:DIA]BPREND,
&             [M:DIA]ALLSAC,[M:DIA]GRPSAC,[M:DIA]SAC,[M:DIA]RECUP,[M:DIA]DEL,[M:DIA]TRC,GSERVEUR)
TRA = 1
Return

Subprog RECUPHDU(CPY,ALLFCY,FCY,ALLTYPBPR,TYPBPR,ALLBPR,BPRSTR,BPREND,ALLSAC,GRPSAC,SAC,RECUP,DEL,TRC,BATCH)
Value Char    CPY
Value Integer ALLFCY
Value Char    FCY
Value Integer ALLTYPBPR
Value Integer TYPBPR
Value Integer ALLBPR
Value Char    BPRSTR
Value Char    BPREND
Value Integer ALLSAC
Value Char    GRPSAC
Value Char    SAC
Value Integer RECUP
Value Integer DEL
Value Integer TRC
Value Integer BATCH

Gosub OUVRE

Local Char    FILTECT(250), MESSA(80), WCOA(GLONCOA)
Local Integer IFILT, OK, RWE, ARRET, ANOM, GRAVE, NBRDUD

# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1(30)

Local Integer CTL_EVTDAT : # Used for the CTLEVTDAT Entry point

RECUP = (RECUP=2)
DEL   = (DEL=2)
TRC   = (TRC=2)

If RECUP
 Call MONOCPY(CPY,OK) From AX3MONO
 If !OK : Goto FIN : Endif
Endif

If !DEL
 # Effacement NON coché => Traitement des incohérences de HISTODUD (Rewrite HISTODUD)
 Gosub RECUP_HDU
Else
 # Effacement coché => Traitement de l'historique (Delete/Write HISTODUD)
 Gosub HISTO_HDU
Endif

$FIN
If RECUP
 Call MULTICPY(CPY) From AX3MONO
Endif
If !BATCH
 Call FERME_TRACE From LECFIC
Endif

End

################################################################################################
$RECUP_HDU
ANOM = 0
GRAVE = 0
If !BATCH
 If RECUP
  Call OUVRE_TRACE(mess(172,116,1)) From LECFIC : # Resynchronisation de l'historique des échéances
 Else
  Call OUVRE_TRACE(mess(173,116,1)) From LECFIC : # Vérification de l'historique des échéances
 Endif
 Call TRACE_MASQUE("RECUPHDU","DIA",nomap) From GTRAITE
Endif

If RECUP
 Call ECR_TRACE(mess(49,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
# Début récup
Else
 Call ECR_TRACE(mess(70,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
# Début vérification
Endif
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Gosub RECUP
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
If RECUP
 Call ECR_TRACE(mess(50,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
# Fin récup
Else
 Call ECR_TRACE(mess(71,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
# Fin Vérification
Endif
If ANOM
 Call ECR_TRACE(num$(ANOM)-mess(7,116,1),0) From GESECRAN : # anomalies
Else
 Call ECR_TRACE(mess(8,116,1),0) From GESECRAN : # Aucune anomalie
Endif
Return

################################################################################################
$HISTO_HDU
ANOM = 0
GRAVE = 0
If !BATCH
 If RECUP
  Call OUVRE_TRACE(mess(174,116,1)) From LECFIC : # Création de l'historique des échéances
 Else
  Call OUVRE_TRACE(mess(175,116,1)) From LECFIC : # Etat de l'historique des échéances
 Endif
 Call TRACE_MASQUE("RECUPHDU","DIA",nomap) From GTRAITE
Endif

If RECUP
 # Début récup
 Call ECR_TRACE(mess(49,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
Else
 # Début vérification
 Call ECR_TRACE(mess(70,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
Endif
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Gosub HISTO
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
If RECUP
 Call ECR_TRACE(mess(50,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
# Fin récup
Else
 Call ECR_TRACE(mess(71,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
# Fin Vérification
Endif
If NBRDUD
 Call ECR_TRACE(num$(NBRDUD)-mess(176,116,1),0) From GESECRAN : # enregistrements crées
Endif
Return

################################################################################################
$FILTRE
Raz FILTECT, IFILT

If !DEL
 Call ADDCRIT(FILTECT,IFILT,"DUDSTA",'DUDSTA=2',"&") From GOBJSUB
Endif

#-- Société & Site
Call ADDCRIT(FILTECT,IFILT,"CPY",'CPY="'+CPY+'"',"&") From GOBJSUB
If ALLFCY<>2
 Call ADDCRIT(FILTECT,IFILT,"FCY",'FCY="'+FCY+'"',"&") From GOBJSUB
Endif

#-- Types de Tiers/Tiers
If ALLTYPBPR<>2
 Call ADDCRIT(FILTECT,IFILT,"BPRTYP",'BPRTYP='+num$(TYPBPR),"&") From GOBJSUB
Endif
If ALLBPR<>2
 If BPRSTR<>""
  Call ADDCRIT(FILTECT,IFILT,"BPR",'BPR>="'+BPRSTR+'"',"&") From GOBJSUB
 Endif
 If BPREND<>""
  Call ADDCRIT(FILTECT,IFILT,"BPR",'BPR<="'+BPREND+'"',"&") From GOBJSUB
 Endif
Endif

#-- Collectif/Groupes de collectif
If ALLSAC<>2
 If GRPSAC<>""
  Call LECMAINPLAN(1,CPY,WCOA) From CPTDIV
  Filter [GSC] Where [F:GSC]COA=WCOA & [F:GSC]GRU=GRPSAC
  SUBCRIT = 'find(SAC'
  For [F:GSC]GSC0
   SUBCRIT += ',"'+[F:GSC]SAC+'"'
  Next
  Filter [GSC]
  SUBCRIT += ")<>0"
  Call ADDCRIT(FILTECT,IFILT,"GSC",SUBCRIT,"&") From GOBJSUB
 Else
  If SAC<>""
   Call ADDCRIT(FILTECT,IFILT,"SAC",'SAC="'+SAC+'"',"&") From GOBJSUB
  Endif
 Endif
Endif
Return


$RECUP

#-- Lancement de la vérification
Gosub FILTRE
For [HDU]HDU0 Where evalue(FILTECT)
 Filter [HDUH] Where [F:HDUH]ACCNUM=[F:HDU]ACCNUM
 Read [HDUH]HDU0 Last
 Filter [HDUH]
 If !fstat & [F:HDUH]FLGCLE<3
  Gosub RECHDU
 Endif
Next
Return

$RECHDU
For [DUD]DUD0 Where TYP=[F:HDU]TYP & NUM=[F:HDU]NUM & LIG=[F:HDU]LIG & DUDLIG=[F:HDU]DUDLIG

 RWE = 0
 If [F:DUD]ACCNUM<>[F:HDU]ACCNUM
  MESSA = mess(102,116,1) : Gosub ERRECH : # Numéro interne incorrect
  If RECUP : [F:HDU]ACCNUM = [F:DUD]ACCNUM : RWE = 1 : Endif
 Endif
 If [F:DUD]CPY<>[F:HDU]CPY
  MESSA = mess(81,116,1) : Gosub ERRECH : # Société incorrecte
  If RECUP : [F:HDU]CPY = [F:DUD]CPY : RWE = 1 : Endif
 Endif
 If [F:DUD]FCY<>[F:HDU]FCY
  MESSA = mess(82,116,1) : Gosub ERRECH : # Site incorrect
  If RECUP : [F:HDU]FCY = [F:DUD]FCY : RWE = 1 : Endif
 Endif
 If [F:DUD]CUR<>[F:HDU]CUR
  MESSA = mess(84,116,1) : Gosub ERRECH : # Devise incorrecte
  If RECUP : [F:HDU]CUR = [F:DUD]CUR : RWE = 1 : Endif
 Endif
 If [F:DUD]SNS<>[F:HDU]SNS
  MESSA = mess(83,116,1) : Gosub ERRECH : # Sens incorrect
  If RECUP : [F:HDU]SNS = [F:DUD]SNS : RWE = 1 : Endif
 Endif
 If [F:DUD]SAC<>[F:HDU]SAC
  MESSA = mess(23,116,1) : Gosub ERRECH : # Collectif incorrect
  If RECUP : [F:HDU]SAC = [F:DUD]SAC : RWE = 1 : Endif
 Endif
 If [F:DUD]BPR<>[F:HDU]BPR
  MESSA = mess(24,116,1) : Gosub ERRECH : # Tiers incorrect
  If RECUP : [F:HDU]BPR = [F:DUD]BPR : RWE = 1 : Endif
 Endif
 If [F:DUD]BPRTYP<>[F:HDU]BPRTYP
  MESSA = mess(24,116,1) : Gosub ERRECH : # Tiers incorrect
  If RECUP : [F:HDU]BPRTYP = [F:DUD]BPRTYP : RWE = 1 : Endif
 Endif
 If [F:DUD]BPRPAY<>[F:HDU]BPRPAY
  MESSA = mess(24,116,1) : Gosub ERRECH : # Tiers incorrect
  If RECUP : [F:HDU]BPRPAY = [F:DUD]BPRPAY : RWE = 1 : Endif
 Endif

 # Champ particulier FLGCLE
 If [F:HDU]FLGCLE<>3
  If [F:HDU]AMTCUR<>0
   If [F:HDU]AMTCUR = [F:HDU]PAYCUR
    [F:HDU]FLGCLE = 2
   Elsif [F:HDU]AMTCUR = [F:HDU]TMPCUR+[F:HDU]PAYCUR
    [F:HDU]FLGCLE = 4
   Else
    [F:HDU]FLGCLE = 1
   Endif
  Else
   If [F:HDU]AMTLOC = [F:HDU]PAYLOC
    [F:HDU]FLGCLE = 2
   Elsif [F:HDU]AMTLOC = [F:HDU]TMPLOC+[F:HDU]PAYLOC
    [F:HDU]FLGCLE = 4
   Else
    [F:HDU]FLGCLE = 1
   Endif
  Endif
 Endif

 # Champ particulier DATEVT
 If [F:HDU]PAYCUR>0
  Read [F:DAE]DAE2 = [F:HDU]ACCNUM
  CTL_EVTDAT = 1
  GPOINT = "BEFRECDUD" : Gosub ENTREE From EXEFNC
  If !fstat & [F:DAE]MTC<>"" & [F:HDU]DATEVT<>[F:DAE]MTCDATMAX & CTL_EVTDAT=1
   # Lettre xxx : Date incorrecte
   MESSA = mess(70,105,1)-[F:DAE]MTC-":"-format$("D:"+GFMDAT,[F:HDU]DATEVT)-":"-mess(1,104,1)-"=>"-format$("D:"+GFMDAT,[F:DAE]MTCDATMAX) : Gosub ERRECH
   If RECUP : [F:HDU]DATEVT=[F:DAE]MTCDATMAX : RWE = 1 : Endif
  Endif
 Elsif [F:HDU]FLGCLE<2
  Read [F:DAE]DAE2 = [F:HDU]ACCNUM
  If !fstat & [F:HDU]DATEVT<>[F:DAE]ACCDAT
   # Date incorrecte
   MESSA = format$("D:"+GFMDAT,[F:HDU]DATEVT)-":"-mess(1,104,1)-"=>"-format$("D:"+GFMDAT,[F:DAE]ACCDAT) : Gosub ERRECH
   If RECUP :  [F:HDU]DATEVT=[F:DAE]ACCDAT : RWE = 1 : Endif
  Endif
 Endif


 If RWE
  Trbegin [HDU]
  Rewrite [HDU]
  If fstat
   GOK = 0 : Call FSTA("HDU") From GLOCK
  Endif
  Commit
 Endif
Next

Return


$ERRECH
Call ECR_TRACE(mess(46,116,1)-[F:HDU]TYP-[F:HDU]NUM-mess(47,116,1)-num$([F:HDU]LIG)
& -"Echéance"-num$([F:HDU]DUDLIG)-"("+num$([F:HDU]NUMHDU)+")",GRAVE) From GESECRAN
# Pièce... Ligne... Echéance
Goto ERREUR

$ERREUR
Call ECR_TRACE("   "+MESSA,0) From GESECRAN
ANOM += 1
GRAVE = 0
Return


################################################################################################
$HISTO
Gosub FILTRE
Raz STOP
Raz NBRDUD

$LOOP_DUD
Raz NB
If STOP
 Raz STOP
 CRITERE = "[F:DUD]NUMDUD>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [DUD]
OK = 1

#-- Lancement de la vérification
For [DUD]DUD8 Where evalue(FILTECT) & evalue(CRITERE)
 Call ECR_TRACE(mess(46,116,1)-[F:DUD]TYP-[F:DUD]NUM-mess(47,116,1)-num$([F:DUD]LIG)
&               -"Echéance"-num$([F:DUD]DUDLIG),GRAVE) From GESECRAN
                # Pièce... Ligne... Echéance
 Gosub HIS_HDU
 NB+=1
 If NB>GMAXUPDTRS
  ACLE1 = [F:DUD]NUMDUD
  STOP=1
  Break
 Endif

Next

If RECUP
 Commit
Else
 Rollback
Endif

If STOP
 Goto LOOP_DUD
Endif

Return

$HIS_HDU
Read [HDU]HDU1 = [F:DUD]ACCNUM;[F:DUD]DUDLIG
If !fstat
 # Enregistrements déjà dans la table
 If TRC
  # Détails de la suppression
  For [HDU]HDU1 Where ACCNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
   Call ECR_TRACE("***"+num$([F:HDU]NUMHDU)-format$("D:"+GFMDAT,[F:HDU]DATEVT),GRAVE) From GESECRAN
  Next
 Endif

 # Supression des enregistrements présents
 If RECUP
  Delete [HDUH] Where ACCNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
  If fstat
   OK = 0 : Call FSTA("HDU") From GLOCK
  Endif
 Endif
Endif

If RECUP
 # Création des enregistrements
 Gosub CRE_HDU
Else
 # SIMULATION
 # Enregistrement dit "Création" => DUDSTA = 0 & DATEVT=DUDDAT
 Call ECR_TRACE(mess(40,107,1)-[F:DUD]TYP-[F:DUD]NUM-mess(47,116,1)-num$([F:DUD]LIG)
&              -"Echéance"-num$([F:DUD]DUDLIG)-format$("D:"+GFMDAT,[F:DUD]DUDDAT),GRAVE) From GESECRAN
  # Création pièce... Ligne... Echéance
 NBRDUD+=1
 Read [DAE]DAE2=[F:DUD]ACCNUM
 If !fstat
  # Enregistrement dit "Validation" => DUDSTA = 2 & DATEVT=ACCDAT
  Call ECR_TRACE(mess(40,107,1)-[F:DUD]TYP-[F:DUD]NUM-mess(47,116,1)-num$([F:DUD]LIG)
&              -"Echéance"-num$([F:DUD]DUDLIG)-format$("D:"+GFMDAT,[F:DAE]ACCDAT),GRAVE) From GESECRAN
  # Création pièce... Ligne... Echéance
  NBRDUD+=1
  If [F:DAE]MTC<>""
   # Enregistrement dit "Réglée" à l'image de DUD => DATEVT=MTCDATMAX
   Call ECR_TRACE(mess(40,107,1)-[F:DUD]TYP-[F:DUD]NUM-mess(47,116,1)-num$([F:DUD]LIG)
&               -"Echéance"-num$([F:DUD]DUDLIG)-format$("D:"+GFMDAT,[F:DAE]MTCDATMAX),GRAVE) From GESECRAN
   # Création pièce... Ligne... Echéance
   NBRDUD+=1
  Endif
 Endif
Endif
Return

$CRE_HDU

Raz [HDUH]
[F:HDUH]=[F:DUD]
[F:HDUH]PAYCUR = 0
[F:HDUH]PAYLOC = 0
[F:HDUH]TMPCUR = 0
[F:HDUH]TMPLOC = 0
[F:HDUH]FLGCLE = 1
[F:HDUH]DUDSTA = 0
[F:HDUH]DATEVT = [F:DUD]DUDDAT
Raz [F:HDUH]PAYDAT
[F:HDUH]NUMHDU = uniqid([HDU])
[F:HDUH]CREDAT = date$
[F:HDUH]CREUSR = GUSER
Write [HDUH]
If fstat
 OK = 0 : Call FSTA("HDU") From GLOCK
Else
 Gosub AFFHDUH
Endif

Read [DAE]DAE2=[F:DUD]ACCNUM
If !fstat
 # Enregistrement dit "Validation" => DUDSTA = 2 & DATEVT=ACCDAT
 [F:HDUH]DUDSTA = 2
 [F:HDUH]DATEVT = [F:DAE]ACCDAT
 [F:HDUH]NUMHDU = uniqid([HDU])
 [F:HDUH]CREDAT = date$
 [F:HDUH]CREUSR = GUSER
 Write [HDUH]
 If fstat
  OK = 0 : Call FSTA("HDU") From GLOCK
 Else
  Gosub AFFHDUH
 Endif
 If [F:DAE]MTC<>""
  # Enregistrement dit "Réglée" à l'image de DUD => DATEVT=MTCDATMAX
  Raz [HDUH]
  [F:HDUH]=[F:DUD]
  [F:HDUH]DATEVT = [F:DAE]MTCDATMAX
  If TYPDUD=3 :
   Raz [F:DUD]PAYDAT
  Endif
  [F:HDUH]NUMHDU = uniqid([HDU])
  [F:HDUH]CREDAT = date$
  [F:HDUH]CREUSR = GUSER
  Write [HDUH]
  If fstat
   OK = 0 : Call FSTA("HDU") From GLOCK
  Else
   Gosub AFFHDUH
  Endif
 Endif
Endif
Return

$AFFHDUH
Call ECR_TRACE(mess(40,107,1)-[F:HDUH]TYP-[F:HDUH]NUM-mess(47,116,1)-num$([F:HDUH]LIG)
& -"Echéance"-num$([F:HDUH]DUDLIG)-"("+num$([F:HDUH]NUMHDU)+")"-format$("D:"+GFMDAT,[F:HDUH]DATEVT),GRAVE) From GESECRAN
# Création pièce... Ligne... Echéance
NBRDUD+=1
Return


######################################################################################
## Etiquette de l'écran RECUPHDU
######################################################################################
Subprog D_INI(VALEUR)
Variable Integer VALEUR
Gosub GRISE
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call LECMAINPLAN(1,VALEUR,[M]COA) From CPTDIV
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
If VALEUR=2
 Effzo FCY : Grizo FCY
Else
 Actzo FCY
Endif
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo FCY : Grizo FCY
Else
 Actzo FCY
Endif
End


Subprog C_ALLTYPBPR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo TYPBPR : Grizo TYPBPR
Else
 Actzo TYPBPR
Endif
End

Subprog C_ALLBPR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo BPRSTR, BPREND : Grizo BPRSTR, BPREND
Else
 Actzo BPRSTR, BPREND
Endif
End

Subprog AS_BPREND(VALEUR)
Variable Char    VALEUR()
If [M]ALLBPR=2 : mkstat=1 : Endif
If VALEUR="" | VALEUR<[M]BPRSTR : VALEUR = [M]BPRSTR : Endif
End

Subprog C_BPREND(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]BPRSTR
 GMESSAGE = mess(44,199,1) :#La borne fin est inferieure a la borne debut
 mkstat = 1
Endif
End

Subprog C_ALLSAC(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo SAC,GRPSAC : Grizo SAC,GRPSAC
Else
 Actzo SAC,GRPSAC
Endif
End

Subprog AS_SAC(VALEUR)
Variable Char    VALEUR()
If [M]GRPSAC<>"" : mkstat=1 : Endif
End

Subprog C_DEL(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Actzo TRC
Else
 Effzo TRC : Grizo TRC
Endif
End

$GRISE
If [M]ALLFCY=2
 Effzo FCY : Grizo FCY
Else
 Actzo FCY
Endif
If [M]ALLTYPBPR=2
 Effzo TYPBPR : Grizo TYPBPR
Else
 Actzo TYPBPR
Endif
If [M]ALLBPR=2
 Effzo BPRSTR, BPREND : Grizo BPRSTR, BPREND
Else
 Actzo BPRSTR, BPREND
Endif
If [M]ALLSAC=2
 Effzo SAC,GRPSAC : Grizo SAC,GRPSAC
Else
 Actzo SAC,GRPSAC
Endif
If [M]DEL=2
 Actzo TRC
Else
 Effzo TRC : Grizo TRC
Endif
Return

