######################################################################

#$ACTION
#Case ACTION
# When "EXEC"        : Gosub EXEC_AUT
#Endcase
#Return

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)
End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Variable Integer NBPAR 
Variable Char    PARAMETRE()()

Local File FXDASSETS [FAS],   KTEMPPOR[KTP] , KCOEF[KCO]
Local Char SOC
Local Date DAT1, DAT2
Local Char    CRITERE(255), CRITSUP(100), PARAM(30) , VALEUR(30) 
Local Integer ANOREAV, ABATIDOS
GOK=1
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "societe"   : [L]SOC=[L]VALEUR
   When "datdeb"    : [L]DAT1=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
   When "datfin"    : [L]DAT2= gdat$(val(right$([L]VALEUR,7)), val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
   When "anoreav"   : [L]ANOREAV=val([L]VALEUR)
   When "abatidos"  : [L]ABATIDOS=val([L]VALEUR)

 Endcase
 Endif
Next
Trbegin [KTP]
Delete [KTP] Where 1=1

If [L]ABATIDOS=1
    Filter [F:FAS] Where CPY=[L]SOC & year(ISSDAT)=year([L]DAT2) 
Else
    Filter [F:FAS] Where CPY=[L]SOC & (year(ISSDAT)>year([L]DAT2) | year(ISSDAT)<1900 )
Endif
Read [F:KCO]KCO0=ANOREAV

  If [F:KCO]REAVAUT>1
    Call ERREUR ("ano de reavaliação com reavaliações aceites fiscalmente. Nada será impresso") From GESECRAN
    Commit
    End
  Endif
 For [F:FAS]
 Raz [F:KTP]
 K=0
 # If [F:FAS]AASREF="S1000078" : Dbgaff : Endif
    For I=0 To 9    
      J=find(ANOREAV,[F:FAS]KANOREAV(I))
      If J<>0 
        K=I
        Break
      Endif
   Next I
   
   If J>0 and [F:FAS]KANOREAV(I+1)=0
         [F:KTP]AASREF=[F:FAS]AASREF
         If K>=1
          [F:KTP]KVREAV_0=[F:FAS]KVREAV(K-1)   
          [F:KTP]KAREAV_0=[F:FAS]KAREAV(K-1) 
         Endif

         [F:KTP]KVREAV_1=[F:FAS]KVREAV(K)   
         [F:KTP]KAREAV_1=[F:FAS]KAREAV(K)   
         [F:KTP]KANOUTIL=[F:FAS]KANOUTIL(K)
         [F:KTP]DECRETO=[F:KCO]DECRETO

       Write [F:KTP]
       If fstat : Call FSTA("KTP") From GLOCK : GOK=0 : Break : Endif
    Endif
 Next
Filter [F:FAS] 

If GOK : Commit : Else : Rollback : Endif
End

###################################################################
