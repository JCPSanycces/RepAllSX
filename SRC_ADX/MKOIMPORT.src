#<AdxTL>@(#)2.0.0.0 $Revision$
Call IMPORTATION("MKO") From GIMPOBJ
End

###################################################################################
$ACTION
Case ACTION
    When "EXPORT" :        Gosub EXPORT
Endcase
Return

###################################################################################
$EXPORT
If clalev ([F:MTK]) = 0 : Local File MFGHEADTRK  [MTK] : Endif
If clalev ([F:MFI]) = 0 : Local File MFGITM      [MFI] : Endif
Read [F:MTK]MTK0 = [F:MKO]MFGTRKNUM
#If !fstat : GIMP(1)= [F:MTK]MFGTRKDAT : Endif
# 57334 Modification du nombre de paramètres de SETDATE
If !fstat : Call SETDATE([F:MTK]MFGTRKDAT,GIMP(1),[F:AOE]OPTDAT) From SUBEXPOBJ : Endif
If [F:MKO]TIMTYP = 1
    Filter [F:MFI] Where MFGNUM = [F:MKO]MFGNUM
    Read [F:MFI]MFI0 First
    If !fstat : GIMP(4) = [F:MFI]ITMREF
                GIMP(5) = num$([F:MFI]BOMALT)
    Endif
    Filter [F:MFI]
Endif
Return

########################################################
# Ouvertures
########################################################
# GIMP :                                               #
#     GIMP(1) : Date du suivi                          #
#     GIMP(2) : Transaction suivi des temps à utiliser #
#     GIMP(3) : Indicateur de solde                    #
#     GIMP(4) : Nomenclature                           #
#     GIMP(5) : Alternative                            #
########################################################
$OUVRE
Local   Char    WMESSAGE(250)
# Issue 65266 - 2010-06-08 by CCC : sauvegarder l'unité de l'opération importée
Local Char LSAVOPEUOM(GLONUOM)

Global  Char    GMOLNUM(GLONTRS)
Global  Integer G_DATOK, G_TRSOK, G_CLEFLGOK, G_BOMNUMOK, G_BOMALTOK, G_CPLOPETIMOK
Global  Integer G_LIN, G_WNBMAT, G_WNBITM, G_WNBOPE
Global  Integer G_WOPECLENBR, G_WMATCLENBR, G_WITMCLENBR
Global  Decimal G_WCPLQTY, G_WREJCPLQTY, G_WQUACPLQTY
Global  Date    G_DATE
# Issue 86522 - 2013-03-06 by CCC : sauvegarde du site précédent
Global  Char    G_FCY(GLONFCY)
Global  Char    G_MFGNUM(GLONVCR),G_WMFGNUM(GLONVCR),G_MFGTRKNUM(GLONVCR)

Local Integer DEBENR_SVG, LCOMMIT
Local Integer WMKOFLG : WMKOFLG=1
Local Integer WADXSEK, NBENR_SVG, WERR
#
#Pour savoir si la date de suivi et la transaction à utiliser sont paramétrées
Call TST_CHAMP("MKO","*1",G_DATOK)    From SUBIMPOBJ    : # date du suivi
Call TST_CHAMP("MKO","*2",G_TRSOK)    From SUBIMPOBJ    : # Transaction de suivi des temps
Call TST_CHAMP("MKO","*3",G_CLEFLGOK) From SUBIMPOBJ    : # Indicateur de solde
Call TST_CHAMP("MKO","*4",G_BOMNUMOK) From SUBIMPOBJ    : # Nomenclature
Call TST_CHAMP("MKO","*5",G_BOMALTOK) From SUBIMPOBJ    : # Alternative de nomenclature
Call TST_CHAMP("MKO","CPLOPETIM",G_CPLOPETIMOK) From SUBIMPOBJ    : # temps passé
#
If clalev([M:MBO])=0  : Local Mask MTKBENCHO [MBO]  : Endif       # masque buffer suivi opé
If clalev([M:OPSK])=0 : Local Mask OPSK      [OPSK] : Endif       # masque encours charge
If clalev([M:MTOK])=0 : Local Mask MTOK      [MTOK] : Endif       # masque buffer suivi opé
If clalev([M:MTMK])=0 : Local Mask MTMK      [MTMK] : Endif       # masque buffer suivi matière
If clalev([M:MTIK])=0 : Local Mask MTIK      [MTIK] : Endif       # masque buffer decl prod
If clalev([F:FCY])<=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ITM])<=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF])<=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:MFG])<=0 : Local File MFGHEAD    [MFG] : Endif
If clalev([F:MFI])<=0 : Local File MFGITM     [MFI] : Endif
If clalev([F:MFM])<=0 : Local File MFGMAT     [MFM] : Endif
If clalev([F:MFO])<=0 : Local File MFGOPE     [MFO] : Endif
If clalev([F:MFO1])<=0: Local File MFGOPE    [MFO1] : Endif
If clalev([F:MTK])<=0 : Local File MFGHEADTRK [MTK] : Endif
If clalev([F:MKI])<=0 : Local File MFGITMTRK  [MKI] : Endif
If clalev([F:MKO])<=0 : Local File MFGOPETRK  [MKO] : Endif
If clalev([F:MWS])<=0 : Local File WORKSTATIO [MWS] : Endif
If clalev([F:ROH])<=0 : Local File ROUTING    [ROH] : Endif
If clalev([F:ROS])<=0 : Local File ROUSCD     [ROS] : Endif
If clalev([F:ROO])<=0 : Local File ROUOPE     [ROO] : Endif
If clalev([F:ROT])<=0 : Local File ROUOPESTD  [ROT] : Endif
If clalev([F:SCH])<=0 : Local File SCHEDULING [SCH] : Endif
If clalev([F:TRO])<=0 : Local File TABROUALT  [TRO] : Endif
If clalev([F:TMA])<=0 : Local File TABMAT     [TMA] : Endif
If clalev([F:TSR])<=0 : Local File TABSCA     [TSR] : Endif
If clalev([F:TMS])<=0 : Local File TABMSG     [TMS] : Endif
If clalev([F:TCA])<=0 : Local File TABCOUAFF  [TCA] : Endif
If clalev([F:TUN])<=0 : Local File TABUNIT    [TUN] : Endif
If clalev([F:BTS])<=0 : Local File BENCHTRS   [BTS] : Endif
If clalev([F:ADP])<=0 : Local File ADOPAR     [ADP] : Endif
If clalev([F:ADW])<=0 : Local File ADOVAL     [ADW] : Endif
If clalev([F:OPS])<=0 : Local File OPERATIONS [OPS] : Endif
If clalev([F:CAL])<=0 : Local File CPTANALIN  [CAL] : Endif
# sr 08.02 1.4.0
If clalev([F:TFO])<=0 : Local File TABFOR     [TFO] : Endif
# sr 08.02 demande 15029
Local Mask JALK   [JALK]                                             # ecran pour jalonnement
If clalev([F:PJA])<=0 : Local File PARJAL     [PJA] : Endif          # Paramètres jalonnement
#

# Issue 86725 GA 07/2014 see CHARG_PARAM
#Récupération du compteur
#Local Integer WOK
#Call LECTCA(8,WOK) From SUBTCA
#If WOK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
#GCODNUM    = [F:TCA]CODNUM(2)   # compteur suivi
#GMANCOU    = [F:TCA]MANCOU(2)
#GOPS       = [F:TCA]CODNUM(4)   # compteur encours opérations

Raz G_LIN, G_DATE, G_FCY
Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub CHARG_PARAM
#Gosub STK_INILOC From STKLOC # cf CHARG_PARAM
Return



###############################################
$CHARG_PARAM
# Issue 90461 GA 09/2013 insuffisant, code remis idem V5
#Gosub CHARG_PARAM From FUNBENCHO

Local Char    MKOPARAM(10)
# Transaction suivi temps import
Global Char    GMKOTRSNUM(GLONTRS)
Call PARAM(GFCY,"MKOTRSNUM",MKOPARAM) From ADOVAL
GMKOTRSNUM = MKOPARAM
#
# Contrôle suivi opération précédente
Global Libelle GCTLOPEPRE
Call PARAM(GFCY,"CTLOPEPRE",MKOPARAM) From ADOVAL
GCTLOPEPRE = val(MKOPARAM)
#
# Contrôle fiche technique
Global Libelle GCTLFICTEC
Call PARAM(GFCY,"CTLFICTEC",MKOPARAM) From ADOVAL
GCTLFICTEC = val(MKOPARAM)
#
# Allocation à l'OF obligatoire
Global Libelle GMTKALLMGT
Call PARAM(GFCY,"MTKALLMGT",MKOPARAM) From ADOVAL
GMTKALLMGT = val(MKOPARAM)
#
##----- Variables société
Call GETDEV(GFCY) From DEVSUB : If GFINRSP="" GFINRSP=GFCY : Endif
Gosub STK_INILOC From STKLOC

# Issue 81181 - 2012-03-29 by CCC : Récupération de la transaction par défaut
If G_TRSOK            : Read [F:BTS]BTS0 = 60;GIMP(2)
                        If fstat
                           Read [F:BTS]BTS0 = 60;GMKOTRSNUM
                           If fstat
                               OK = 0 : GOK = 0
                           Else
                               GMOLNUM=GMKOTRSNUM
                           Endif
                        Else
                               GMOLNUM=GIMP(2)
                        Endif
Else
                        Read [F:BTS]BTS0 = 60;GMKOTRSNUM
                        If fstat
                            OK = 0 : GOK = 0
                        Else
                            GMOLNUM=GMKOTRSNUM
                        Endif
Endif
If GOK = 0
        WMESSAGE = mess(6,199,1)+"BTSNUM" - [M:MTMK]ITMREF
        Call ECR_TRACE(WMESSAGE,1) From GESECRAN
Endif
Call GETCPY(GFCY,"BTS",60,GMOLNUM) From TRTX3CPT

# Issue 86725 GA 07/2014 idem 72699/SUBMTKA Change counter when change current site
Local Integer WOK
Call LECTCA(8,WOK) From SUBTCA
If WOK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
GCODNUM    = [F:TCA]CODNUM(2)   # compteur suivi
GMANCOU    = [F:TCA]MANCOU(2)
GOPS       = [F:TCA]CODNUM(4)   # compteur encours opérations

Return

######################################################
# Réinitialisation après création (début de lecture)
$RAZCRE
Raz [M:MTOK]
GREP="C"
Return

######################################################
$SAIMSK
If IMPFIC<>"MKO" : WMKOFLG=0 :Endif # Permet de savoir si on importe autre chose que seulement le suivi

Case IMPFIC
  When "MKO"
    Raz [M:MBO]
    nolign = 1 : indice = 0 # Issue 89068 GA 07/2013 ajout nolign idem MKMIMPORT et MKIIMPORT
    # Issue 85182 - 2012-10-25 by CCC
    Raz [F:CAL]
    [M:MBO]=[F:MKO]
    [M:MBO]FCY = [F:MKO]MFGFCY
    If [M:MBO]FCY <> GFCY
         GFCY = [M:MBO]FCY
         Gosub CHARG_PARAM
    Endif
    # Issue 89467 GA 07/2013 déplacé depuis VALID
    If G_DATOK            : Call SETDATE([M:MBO]IPTDAT,GIMP(1),[M:AOE1]OPTDAT,WERR) From SUBIMPOBJ
       If WERR : WMESSAGE = mess(6,199,1)+"IPTDAT" - num$([M:MBO]OPENUM)
                 Call ECR_TRACE(WMESSAGE,1) From GESECRAN
                 OK = 0
                 GOK = 0
       Endif
    Else                  : [M:MBO]IPTDAT = date$
    Endif

    # Issue 101783 - 2014-10-06 by CCC : load SCANUM & TABREJQTY
    For I=1 To 15
        Assign "[M:MBO]SCANUM"+num$(I)+"(0)" With [F:MKO]SCANUM(I-1)
        Assign "[M:MBO]TAREJQTY"+num$(I)+"(0)" With [F:MKO]TABREJQTY(I-1)
    Next


    # Issue 87780 - 2013-03-07 by CCC
    If G_CLEFLGOK : [M:MBO]CLEFLG = val(GIMP(3))
    Else          : [M:MBO]CLEFLG = 3
    Endif
    If [M:MBO]CLEFLG = 0 : [M:MBO]CLEFLG = 3 : Endif

    # Issue 89330 GA 06/2013 déplacé dans SAIMSK
    If G_BOMNUMOK : [M:MBO]BOMNUM = GIMP(4)      : Endif
    If G_BOMALTOK : [M:MBO]BOMALT = val(GIMP(5)) : Endif

  When "CAL"  :    # Issue 94225 GA 11/2013 ajout du cas particulier "CAL"
    Default Mask [MBO]
    indice=nolign-1 : mkstat=0

    For I=1 To GNBDIE
#----------------- Contrôle des sections analytiques -----------------#
        Call CTRL_CCE([F:CAL]CCE(I-1),I,"",GFINRSP,[M:MBO]IPTDAT) From TRTX3CPT
        If mkstat
            Call ECR_TRACE(GMESSAGE,1) From GESECRAN
            Raz GMESSAGE
            Raz OK, GOK
            Break
        Endif
        J=find([F:CAL]DIE(I-1),GDIE(1..GNBDIE))
        If J
            Assign "[M:MBO]CCE"+num$(J) With [F:CAL]CCE(I-1)
        Endif
    Next I

Endcase
Return

######################################################
# Contrôles et mises à jour
$VALID
Local Integer I, J
Local Date WDATE
Local Char LSEC(GLONCCE)

If GOK<=0
    Goto FIN_VALID
Endif
If GREP=""
    OK=0
    Goto FIN_VALID
Endif

If [M:MBO]CPLQTY = 0 & [M:MBO]CPLOPETIM = 0 & [M:MBO]CPLSETTIM = 0
    WMESSAGE = mess(28,190,1) - [M:MBO]MFGNUM(0)-num$([M:MBO]OPENUM(0)) # Issue 89068 GA 07/2013 avant num$([F:MKO]OPENUM)
    Call ECR_TRACE(WMESSAGE,1) From GESECRAN
    OK = 0
    GOK = 0
    LCOMMIT=1
    # Issue 78484 & 78521 - 2011-12-12 by CCC : il faut continuer pour fermer la transaction
    #Return
    Goto FIN_VALID
Endif

# Chargement [MTOK]
Raz [M:MTOK]
[M:MTOK]             = [M:MBO]
[M:MTOK]MFGFCY       = [M:MBO]FCY
Raz [M:MTOK]MFGTRKNUM

# Issue 101783 - 2014-10-06 by CCC : load SCANUM & TABREJQTY
For I=1 To 15
    [M:MTOK]SCANUM(I-1) = evalue("[M:MBO]SCANUM"+num$(I)+"(0)")
    [M:MTOK]TABREJQTY(I-1) = evalue("[M:MBO]TAREJQTY"+num$(I)+"(0)")
Next

Call GETSOC([M:MTOK]MFGFCY) From DEVSUB
Call GETCPY([M:MTOK]MFGFCY,"",0,"") From TRTX3CPT

# Issue 86467 - GA 07/2013 déplacé dans SAIMSK
#If G_DATOK            : Call SETDATE([M:MTOK]IPTDAT,GIMP(1),[M:AOE1]OPTDAT,WERR) From SUBIMPOBJ
#   If WERR : WMESSAGE = mess(6,199,1)+"IPTDAT" - num$([M:MTOK]OPENUM)
#             Call ECR_TRACE(WMESSAGE,1) From GESECRAN
#             OK = 0
#             GOK = 0
#             LCOMMIT=1
#             # Issue 78484 & 78521 - 2011-12-12 by CCC : il faut continuer pour fermer la transaction
#             #Return
#             Goto FIN_VALID
#   Endif
##                        [M:MTOK]IPTDAT = GIMP(1)
#Else                  : [M:MTOK]IPTDAT = date$
#Endif

# Issue 81181 - 2012-03-29 by CCC : Déjà fait dans SAIMSK
# Issue 112528 - 2015-12-09 by BEEBE : no, will not be made in SAIMSK when FCY doesn´t change!
If clalev([F:BTS])<=0 : Local File BENCHTRS   [BTS] : Endif
If G_TRSOK            : Read [F:BTS]BTS0 = 60;GIMP(2)
                        If fstat
                           Read [F:BTS]BTS0 = 60;GMKOTRSNUM
                           If fstat : OK = 0 : GOK = 0 : Endif
                        Endif
Else
                        Read [F:BTS]BTS0 = 60;GMKOTRSNUM
                        If fstat : OK = 0 : GOK = 0 : Endif
Endif
If GOK = 0
        WMESSAGE = mess(6,199,1)+"BTSNUM" - num$([M:MTOK]OPENUM)
        Call ECR_TRACE(WMESSAGE,1) From GESECRAN
        # Issue 78484 & 78521 - 2011-12-12 by CCC : il faut continuer pour fermer la transaction
        #Return
        LCOMMIT=1
        Goto FIN_VALID
Endif
# Issue 89330 GA 06/2013 GIMP(*) contient les valeurs suivantes, déplacé dans SAIMSK
#If G_BOMNUMOK : [M:MTOK]BOMNUM = GIMP(4)      : Endif
#If G_BOMALTOK : [M:MTOK]BOMALT = val(GIMP(5)) : Endif
[M:MTOK]MATFLG       = [F:BTS]MATFLG
[M:MTOK]MATFLTFLG    = [F:BTS]MATFLTFLG # Issue 79586 - 2012-02-09 by CCC
[M:MTOK]CONSMAT      = [F:BTS]CONSMAT
[M:MTOK]STOCODMAN    = [F:BTS]STOCODMAN
[M:MTOK]ITMFLG       = [F:BTS]ITMFLG
[M:MTOK]WMATOK       = 1
[M:MTOK]ENTCOD       = [F:BTS]ENTCOD
[M:MTOK]ENTCODS      = [F:BTS]ENTCODS   # Issue 71696 - 2011-02-25 by CCC
[M:MTOK]PRNCOD       = [F:BTS]PRNCOD1
[M:MTOK]PRNNBRFLG    = [F:BTS]PRNNBFLG1
[M:MTOK]TRSCOD       = [F:BTS]TRSCOD
[M:MTOK]TRSCODS      = [F:BTS]TRSCODS
# 02.06 demande 34968 Initialiser à 0
[M:MTOK]WCOEFF       = 0
[M:MTOK]WCOEFF1      = 0

If [M:MTOK]MFGNUM <> ""
   [M:MTOK]TYPTRT = 2
   Read [F:MFG]MFG0 = [M:MTOK]MFGNUM
   If !fstat : [M:MTOK]ITMREF = [F:MFG]ROUNUM
               [M:MTOK]ROUALT = [F:MFG]ROUALT
   Endif
   Read [F:MFO]MFO0 = [M:MTOK]MFGNUM;[M:MTOK]OPENUM;[M:MTOK]OPESPLNUM
   If fstat : [M:MTOK]TYPTRT = 10 : Raz [F:MFO] : Endif
   Filter [F:MFI] Where MFGNUM = [M:MTOK]MFGNUM
   Read [F:MFI]MFI0 First
   Filter [MFI]
   If fstat : Raz [F:MFI] : Endif
   # CCC (14/05/08) Bug 47346 : Renseigner le champ ROUOPENUM
   If [M:MTOK]ROUOPENUM = 0
      # [M:MTOK]ROUOPENUM = [F:MFO]ROUOPENUM
      [M:MTOK]ROUOPENUM = [F:MFO]OPENUM : # Issue 53305 GH 01/12/2017 - to be consistent with SUBMTKB.CHARG_SCREEN
   Endif
   If [M:MTOK]OPEUOM = ""
      If [M:MTOK]TYPTRT = 2
         Case [F:BTS]OPEUOMMOD
              When 1 : [M:MTOK]OPEUOM    = [F:MFO]OPEUOM
              When 2 :
                       Case [F:BTS]OPEUOMTYP
                             When 1 : [M:MTOK]OPEUOM    = [F:MFO]OPEUOM
                             When 2 : [M:MTOK]OPEUOM    = [F:MFI]STU
                       Endcase
         Endcase
         If    [M:MTOK]OPEUOM  = [F:MFO]OPEUOM : [M:MTOK]OPEWORCOE = 1
         Elsif [M:MTOK]OPEUOM  = [F:MFI]STU    : [M:MTOK]OPEWORCOE = [F:MFO]OPESTUCOE
         Endif
      Else
         [M:MTOK]OPEUOM    = [F:MFI]STU
         [M:MTOK]OPEWORCOE = 1
      Endif
   Elsif [M:MTOK]OPEWORCOE=0  # FQ 73833 GA 05/2011
      If [M:MTOK]OPEUOM = [F:MFI]STU
         [M:MTOK]OPEWORCOE = 1
      Else
         # Zone OPEWORCOE Non renseignée
         OK=0 : GMESSAGE="OPEWORCOE"-mess(22,108,1)-"UO="+[M:MTOK]OPEUOM-"<> US="+[F:MFI]STU
      Endif
   Endif

#
   If ([F:BTS]MATFLG > 2 | [F:BTS]ITMFLG > 2 ) & [M:MTOK]BOMNUM = ""
      [M:MTOK]BOMNUM = [F:MFI]ITMREF
      [M:MTOK]BOMALT = [F:MFI]BOMALT
   Endif
# Issue 87780 - 2013-03-07 by CCC : GIMP contient déjà la valeur suivante
#   If G_CLEFLGOK : [M:MTOK]CLEFLG = val(GIMP(3))
#   Else          : [M:MTOK]CLEFLG = 3
#   Endif
#   If [M:MTOK]CLEFLG = 0 : [M:MTOK]CLEFLG = 3 : Endif
Elsif [M:MTOK]ITMREF <> "" & [M:MTOK]ROUALT <> 0
      [M:MTOK]TYPTRT = 6
Else  [M:MTOK]TYPTRT = 9
Endif

# Issue 95578 GA 01/2014 fait dans SAIMSK
#Raz [M:MBO]
#[M:MBO]     = [M:MTOK]
#[M:MBO]FCY  = [M:MTOK]MFGFCY

# Issue 77417 - 2012-02-01 by CCC
#For I=1 To max(GNBDIE,GOPTCANA)
For I=1 To GNBDIE
    J=find([F:CAL]DIE(I-1),GDIE(1..GNBDIE))
    If J
        Assign "[M:MTOK]CCE"+num$(J) With [F:CAL]CCE(I-1)
    Endif
Next

# Issue 77417 - 2012-02-01 by CCC
#For I=1 To max(GNBDIE,GOPTCANA)
For I=1 To GNBDIE
    If evalue("[M:MTOK]CCE"+num$(I))=""
        If [F:MWS]WST <> [M:MTOK]CPLWST | [F:MWS]WCRFCY <> [M:MTOK]MFGFCY
            Read [MWS]WST0=[M:MTOK]CPLWST;[M:MTOK]MFGFCY
            If fstat : Raz [F:MWS] : Endif
        Endif
#        Call INISEC(LSEC,"MKOB",GDIE(I)) From SUBCDE
        Raz LSEC
        Call INIT_CCE(LSEC,I,"MKOB","",0) From TRTX3CPT
        Assign "[M:MTOK]CCE"+num$(I) With LSEC
    Endif
Next I

# Issue 85182 - 2012-10-26 by CCC
# L'import des sections analytiques du 2nd poste n'est pas possible
# Il n'y a donc qu'une init à faire
For I=1 To GNBDIE
    If evalue("[M:MTOK]LABCCE"+num$(I))=""
        If [F:MWS]WST <> [M:MTOK]CPLLAB | [F:MWS]WCRFCY <> [M:MTOK]MFGFCY
            Read [MWS]WST0=[M:MTOK]CPLLAB;[M:MTOK]MFGFCY
            If fstat : Raz [F:MWS] : Endif
        Endif
        Raz LSEC
        Call INIT_CCE(LSEC,I,"MKOLABB","",0) From TRTX3CPT
        Assign "[M:MTOK]LABCCE"+num$(I) With LSEC
    Endif
Next I
#
Gosub CONTROLE_IMP

If !OK
    Call ECR_TRACE(WMESSAGE,1) From GESECRAN
    GOK = 0
    LCOMMIT=1
Else
    # Issue 78118 - 2012-01-05 by CCC
    Raz WMESSAGE
    Gosub CRE_SUIVI
    If GOK < 1
        If WMESSAGE<>""
            Call ECR_TRACE(WMESSAGE,1) From GESECRAN
        Endif
         WMESSAGE = mess(254,193,1)
         Call ECR_TRACE(WMESSAGE,1) From GESECRAN
         WMESSAGE = mess(255,193,1)
         Call ECR_TRACE(WMESSAGE,1) From GESECRAN
         Gosub COP_SVG
    Endif
Endif

$FIN_VALID
If LCOMMIT & GOK=0
    GOK=1
    Gosub FIN_DOC
    GOK=0
Else
    Gosub FIN_DOC
Endif
LCOMMIT=0
Return

$FIN_DOC
If IMPFIN | GOK<=0 | LCOMMIT
    If G_WMFGNUM <> "" : Gosub MAJ_ENTOF  : Endif
    If G_WNBOPE <> 0    # FQ 54431 il manque le commit ou rollback final
        Gosub CRE_ENTETE
        If GOK < 1
           WMESSAGE = mess(254,193,1)
           Call ECR_TRACE(WMESSAGE,1) From GESECRAN
           WMESSAGE = mess(255,193,1)
           Call ECR_TRACE(WMESSAGE,1) From GESECRAN
           Gosub COP_SVG
        Endif
    Else
        If adxlog <> 0 : Rollback : Endif
    Endif
    OK  = 0
    TRA = 0
Endif
Return
######################################################
# Contrôles
$CONTROLE_IMP
Local Date    WDAT
Local Char    WFCY(GLONFCY)
Local Integer WMSG
Local Integer WALT, WBREAK
Local Integer TABTBO(3)

# Issue 81181 - 2012-03-29 by CCC : Déjà fait dans SAIMSK
#Call GETCPY([M:MTOK]MFGFCY,"BTS",60,GMKOTRSNUM) From TRTX3CPT    # alimentation de GSOCIETE et GTYPGEN

#Contrôle OF

If find([M:MTOK]TYPTRT,2,10)
    If  [M:MTOK]TYPTRT = 2
        Read [F:MFO]MFO0 = [M:MTOK]MFGNUM;[M:MTOK]OPENUM;[M:MTOK]OPESPLNUM
        If fstat : WMESSAGE = mess(161,193,1) - [M:MTOK]MFGNUM +"/"+ num$([M:MTOK]OPENUM)
           OK = 0
           Return
        Endif
        #L'opération doit-elle être suivie ?
        Read [F:SCH]SCH0 = [M:MTOK]MFGNUM;[M:MTOK]OPENUM;[M:MTOK]OPESPLNUM
        If !fstat & [F:SCH]DACMST = 1
            WMESSAGE = mess(134,193,1) - [M:MTOK]MFGNUM +"/"+ num$([M:MTOK]OPENUM)
            OK = 0
            Return
        Endif
        #Controle fiche technique
        # Point d'entrée pour influencer le controle demande 36827
        GPE = 0
        GPOINT = "CTLFICTEC" : Gosub ENTREE From EXEFNC
        If [F:MFO]TECCRD <> "" & GCTLFICTEC <> 1 & GPE = 0
            # CTLFICTEC = 4 ou 5 :
            # si on est sur le premier suivi alors blocage
            # Si on est sur le Xieme suivi, alors pas de contrôle si CTLFICTEC = 4 ou 5
            # CTLFICTEC = 2 ou 3 :
            # blocage toujours
            fstat = 1
            If find(GCTLFICTEC,4,5)
                Filter [F:MKO] Where MFGNUM = [M:MTOK]MFGNUM & OPENUM = [M:MTOK]OPENUM
                Look [F:MKO]MKO1(1) First
            Endif
            If fstat
               WMESSAGE = mess(23,190,1) - [M:MTOK]MFGNUM+num$([M:MTOK]OPENUM)
               OK = 0
               Filter [F:MKO]
               Return
            Endif
            Filter [F:MKO]
        Endif
        # sr 07.02 Récupération éventuelle du site et des postes demande 15036 + coeff
        If [M:MTOK]MFGFCY = ""   : [M:MTOK]MFGFCY = [F:MFO]MFGFCY       : Endif
        If [M:MTOK]CPLWST = ""   : [M:MTOK]CPLWST = [F:MFO]EXTWST       : Endif
        If [M:MTOK]CPLLAB = ""   : [M:MTOK]CPLLAB = [F:MFO]EXTLAB       : Endif
        If [M:MTOK]SETLABCOE = 0 : [M:MTOK]SETLABCOE = [F:MFO]SETLABCOE : Endif
        If [M:MTOK]OPELABCOE = 0 : [M:MTOK]OPELABCOE = [F:MFO]OPELABCOE : Endif

       Case [F:BTS]OPEUOMMOD
            When 1 :
                 If [M:MTOK]OPEUOM <> [F:MFO]OPEUOM
                    WMESSAGE = mess(173,193,1) -  [M:MTOK]MFGNUM +"/"+num$([M:MTOK]OPENUM)
                    OK = 0
                    Return
                 Endif
            When 2 :
                 Case [F:BTS]OPEUOMTYP
                      When 1 :
                            If [M:MTOK]OPEUOM <> [F:MFO]OPEUOM
                                WMESSAGE = mess(173,193,1)-[M:MTOK]MFGNUM +"/"+num$([M:MTOK]OPENUM)
                                OK = 0
                                Return
                            Endif
                      When 2 :
                           If [M:MTOK]OPEUOM <> [F:MFI]STU
                               WMESSAGE = mess(172,193,1)-[M:MTOK]MFGNUM +"/"+num$([M:MTOK]OPENUM)
                               OK = 0
                               Return
                           Endif
                 Endcase
        Endcase

       # sr 10.03 Si le temps opératoire n'est pas importé, le calculer automatiquement ssi il n'est pas dans le modèle
        If [M:MTOK]CPLOPETIM = 0 & [M:MTOK]CPLQTY <> 0 & !G_CPLOPETIMOK
            # Issue 88561 & 88611 - 2013-03-13 by CCC
            #[M:MTOK]CPLOPETIM = ([F:MFO]EXTUNTTIM * [M:MTOK]OPEWORCOE) * [M:MTOK]CPLQTY
            Case [F:MFO]ROOTIMCOD
                When 1 : [M:MTOK]CPLOPETIM = [F:MFO]EXTUNTTIM * [M:MTOK]CPLQTY
                When 2 : If [F:MFO]CAD <> 0
                             If [F:MFO]EFF=0
                                [M:MTOK]CPLOPETIM = [M:MTOK]CPLQTY / [F:MFO]CAD
                             Else
                                [M:MTOK]CPLOPETIM = [M:MTOK]CPLQTY / [F:MFO]CAD / ([F:MFO]EFF / 100)
                             Endif
                         Endif
                When 3 : [M:MTOK]CPLOPETIM = [F:MFO]EXTOPETIM
            Endcase
            [M:MTOK]CPLOPETIM = func TRTX3.ARRTYP("","","TIH",[M:MTOK]CPLOPETIM)
        Endif

        #Selon paramètre général, l'opération précédente doit être suivie sauf si non suivie
        # sr 06.02 contrôle que si opé precedente pas exclue demande demande 14752
        # Point d'entrée pour influencer le controle demande 36827
        GPE = 0
        GPOINT = "CTLOPEPRE" : Gosub ENTREE From EXEFNC
        If GCTLOPEPRE <> 1 & GPE = 0
            Filter [F:SCH] Where MFGNUM = [F:MFO]MFGNUM & NEXOPENUM = [F:MFO]OPENUM
                Read [F:SCH]SCH0 First
                If !fstat & [F:SCH]DACMST <> 1
                   Read [F:MFO1]MFO0 =  [F:SCH]MFGNUM;[F:SCH]OPENUM;[F:SCH]OPESPLNUM
                   If fstat : Raz [F:MFO1] : Endif
                   If [F:MFO1]TRKFIRST = [0/0/0] & [F:MFO1]OPESTA <> 6
                       WMESSAGE = mess(22,190,1)-num$([F:MFO]OPENUM)
                       OK = 0
                       Filter [F:SCH]
                       Return
                   Endif
                Endif
            Filter [F:SCH]
        Endif
        # 02.06 demande 34968
        If [F:MFO]EXTQTY <> 0 & [M:MTOK]OPEWORCOE <> 0
           [M:MTOK]WCOEFF    = [M:MTOK]CPLQTY / ([F:MFO]EXTQTY/ [M:MTOK]OPEWORCOE)
           [M:MTOK]WCOEFF1   = [M:MTOK]REJCPLQTY / ([F:MFO]EXTQTY/ [M:MTOK]OPEWORCOE)
           # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
           # Ce sont les quantités qui sont arrondies
           #[M:MTOK]WCOEFF = arr([M:MTOK]WCOEFF,0.00000001)
           #[M:MTOK]WCOEFF1 = arr([M:MTOK]WCOEFF1,0.00000001)
        Endif
    Endif

    Read [MFG]MFG0 = [M:MTOK]MFGNUM
    If fstat
       WMESSAGE = mess(151,193,1) - [M:MTOK]MFGNUM
       OK = 0
       Return
    Endif
    #L'OF doit être complet
    If [F:MFG]TYPMOD = 1    : WMESSAGE = mess(51,190,1) - [M:MTOK]MFGNUM : OK = 0 : Return : Endif
    #L'OF doit être ferme
    If [F:MFG]MFGSTA <> 1   : WMESSAGE = mess(19,190,1) - [M:MTOK]MFGNUM : OK = 0 : Return : Endif
    #Selon paramètre général l'OF doit être alloué complètement
    If GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0
         WMESSAGE = mess(18,190,1) - [M:MTOK]MFGNUM
         OK = 0
         Return
    Endif
    #Selon paramètre général, l'OF doit être édité
    If  [F:MFG]MFGTRKFLG < 3 &  GDOSFAB = 2
        WMESSAGE = mess(20,190,1) - [M:MTOK]MFGNUM
        OK = 0
        Return
    Endif
    # boucle d'analyse des matières bloquantes si rupture
    For [MFM] Where MFGNUM = [F:MFG]MFGNUM
        If [F:MFM]SHTQTY <> 0
           Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
           If !fstat & [F:ITF]MFGSHTCOD = 1
              WMESSAGE = mess(105,193,1) - [M:MTOK]MFGNUM +" ("+[F:MFM]ITMREF+")"
              OK = 0
              Break
           Endif
        Endif
    Next
    If OK = 0 : Return : Endif
    # Contrôle de la nomenclature  (ce doit être la nomenclature d'un des articles lancés)
    Raz WBREAK
     If ([F:BTS]MATFLG > 2 | [F:BTS]ITMFLG > 2 )
        For [F:MFI] Where MFGNUM = [M:MTOK]MFGNUM
            If [F:MFI]ITMTYP = 1
                If  [F:MFI]ITMREF = [M:MTOK]BOMNUM
                    [F:MFI]BOMALT = [M:MTOK]BOMALT
                    WBREAK = 1
                    Break
                Endif
            Endif
        Next
        If !WBREAK : WMESSAGE = mess(95,193,1) - [M:MTOK]MFGNUM + [M:MTOK]ITMREF+"/"+num$([M:MTOK]BOMALT)
            OK = 0
            Return
        Endif
    Endif

    # Warning ########
    Case [M:MTOK]TYPTRT
        When 2 : # expected operation
            # Issue 110979/2 - 2016-03-25 by CCC : Warning message when changing workstation on operation of versioned routing
            If [F:MFG]ROUECCMAJ <> ""
                If !find([M:MTOK]CPLWST,[F:MFO]EXTWST,[F:MFO]EXTLAB)
                    Call ECR_TRACE([M:MTOK]MFGNUM-num$([M:MTOK]OPENUM)-mess(346,193,1)-[F:MFO]CPLWST-"-->"-[M:MTOK]CPLWST,-1) From GESECRAN
                Endif
                If [M:MTOK]CPLLAB<>"" & [F:MFO]CPLLAB<>[M:MTOK]CPLLAB
                    Call ECR_TRACE([M:MTOK]MFGNUM-num$([M:MTOK]OPENUM)-mess(346,193,1)-[F:MFO]CPLLAB-"-->"-[M:MTOK]CPLLAB,-1) From GESECRAN
                Endif
            Endif
        When 10 : # unexpected operation
            # Issue 110979/2 - 2016-03-25 by CCC : Warning message when unexpected operation on versioned routing
            If [F:MFG]ROUECCMAJ <> ""
                Call ECR_TRACE([M:MTOK]MFGNUM-num$([M:MTOK]OPENUM)-mess(345,193,1),-1) From GESECRAN
            Endif
    Endcase
Elsif [M:MTOK]TYPTRT = 6
    Read [F:ITM]ITM0 = [M:MTOK]ITMREF
    If fstat : WMESSAGE = mess(134,100,1) - [M:MTOK]ITMREF
               OK = 0
               Return
    Endif
#Contrôle gamme
    WALT = 0
    Read [F:TRO]TRO0 = [M:MTOK]ROUALT
    If !fstat & ([F:TRO]FCY = "" | [F:TRO]FCY = [M:MTOK]MFGFCY)
        WDAT= [M:MTOK]IPTDAT
        WMSG=1
        WFCY=[M:MTOK]MFGFCY
        #Lecture ROUTING
        Read [F:ROH]ROH1 = [M:MTOK]MFGFCY;[M:MTOK]ITMREF;[M:MTOK]ROUALT
        If !fstat
           Call CONTMFGGAM(WFCY,WALT,WDAT,WMSG) From FUNBENCHO
        Endif
    Endif
    If WALT = 0
       If GMESSAGE = "" : GMESSAGE = mess(152,193,1) : Endif
       WMESSAGE = GMESSAGE - [M:MTOK]ITMREF+"/"+num$([M:MTOK]ROUALT)
       OK = 0
       Return
    Endif
    Read [F:ROO]ROO0 = [M:MTOK]MFGFCY;[M:MTOK]ITMREF;[M:MTOK]ROUALT;[M:MTOK]OPENUM;[M:MTOK]RPLIND
    If fstat : Raz [F:ROO] : [M:MTOK]TYPTRT = 11 : Endif

    If [M:MTOK]OPEUOM = ""
       If [M:MTMK]TYPTRT = 6
           Case [F:BTS]OPEUOMMOD
                 When 1 : [M:MTOK]OPEUOM    = [F:ROO]OPEUOM
                 When 2 :
                          Case [F:BTS]OPEUOMTYP
                               When 1 : [M:MTOK]OPEUOM    = [F:ROO]OPEUOM
                               When 2 : [M:MTOK]OPEUOM    = [F:ITM]STU
                          Endcase
           Endcase
           If    [M:MTOK]OPEUOM  = [F:ROO]OPEUOM : [M:MTOK]OPEWORCOE = 1
           Elsif [M:MTOK]OPEUOM  = [F:MFI]STU
                    # sr 08.02 1.4.0 récup éventuelle de la formule
                    If [F:ROO]OPESTUFOR <> ""
                       Read [F:TFO]TFO0=2;[F:ROO]OPESTUFOR
                       If !fstat
                       # se repositionner éventuellement sur l'article produit
                           If [F:ITM]ITMREF <> [M:MTOK]ITMREF
                               Read [F:ITM]ITM0 = [M:MTOK]ITMREF
                               If fstat : Raz [F:ITM] : Endif
                           Endif
                           If [F:ITF]ITMREF <> [M:MTOK]ITMREF | [F:ITF]STOFCY <> [M:MTOK]MFGFCY
                               Read [F:ITF]ITF0 = [M:MTOK]ITMREF;[M:MTOK]MFGFCY
                               If fstat : Raz [F:ITF] : Endif
                           Endif
                           If evalue([F:TFO]FORFOR) <> 0
                               [M:MTOK]OPEWORCOE = evalue([F:TFO]FORFOR)
                           Elsif [F:ROO]OPESTUCOE <> 0
                                 [M:MTOK]OPEWORCOE = [F:ROO]OPESTUCOE
                           Else
                               [M:MTOK]OPEWORCOE = 1
                           Endif
                       Else
                           [M:MTOK]OPEWORCOE = [F:ROO]OPESTUCOE
                       Endif
                    Else
                       [M:MTOK]OPEWORCOE = [F:ROO]OPESTUCOE
                    Endif
           Endif
       Else
           [M:MTOK]OPEUOM    = [F:ITM]STU
           [M:MTOK]OPEWORCOE = 1
       Endif
    Else
        [M:MTOK]OPEUOM    = [F:ITM]STU
        [M:MTOK]OPEWORCOE = 1
    Endif
    If [M:MTOK]TYPTRT = 6
        If [F:BTS]OPEUOMMOD = 1 & [M:MTOK]OPEUOM <> [F:ROO]OPEUOM
            WMESSAGE = mess(173,193,1) - [M:MTOK]OPEUOM
            OK = 0
            Return
        Elsif [F:BTS]OPEUOMMOD = 2 & !find([M:MTOK]OPEUOM,[F:ROO]OPEUOM,[F:ITM]STU)
            WMESSAGE = mess(172,193,1) - [M:MTOK]OPEUOM
            OK = 0
            Return
        Endif
        #Controle fiche technique
        # Point d'entrée pour influencer le controle demande 36827
        GPE = 0
        GPOINT = "CTLFICTEC" : Gosub ENTREE From EXEFNC
        If [F:ROO]TECCRD <> "" & GCTLFICTEC <> 1 & GPE = 0
           WMESSAGE = mess(23,190,1) - [M:MTOK]ITMREF+num$([M:MTOK]OPENUM)
           OK = 0
           Return
        Endif
        #sr 07.02 Récupération éventuelle du site et des postes demande 15036 + coeff
        If [M:MTOK]MFGFCY = "" : [M:MTOK]MFGFCY = [F:ROO]FCY : Endif
        If [M:MTOK]CPLWST = "" : [M:MTOK]CPLWST = [F:ROO]WST : Endif
        If [M:MTOK]CPLLAB = "" : [M:MTOK]CPLLAB = [F:ROO]LABWST : Endif
        If [M:MTOK]SETLABCOE = 0 : [M:MTOK]SETLABCOE = [F:ROO]SETLABCOE : Endif
        If [M:MTOK]OPELABCOE = 0 : [M:MTOK]OPELABCOE = [F:ROO]OPELABCOE : Endif

        # sr 10.03 Si le temps opératoire n'est pas importé, le calculer automatiquement ssi il n'est pas dans le modèle
        If [M:MTOK]CPLOPETIM = 0 & [M:MTOK]CPLQTY <> 0 & !G_CPLOPETIMOK
            Case [F:ROO]ROOTIMCOD
                When 1 : [M:MTOK]CPLOPETIM = [F:ROO]OPETIM * [M:MTOK]CPLQTY
                When 2 : # llc 02.02 13175
                         If [F:ROO]CAD <> 0
                             [M:MTOK]CPLOPETIM = [M:MTOK]CPLQTY / [F:ROO]CAD
                         Endif
                When 3 : [M:MTOK]CPLOPETIM = [F:ROO]OPETIM
            Endcase
            #[F:MKO]CPLOPETIM = arr([F:MKO]CPLOPETIM , 0.0001)
            [M:MTOK]CPLOPETIM = func TRTX3.ARRTYP("","","TIH",[M:MTOK]CPLOPETIM)
        Endif
   Endif


    # Contrôle de cohérence de l'alternative de nomenclature
    TABTBO(0)=[F:TRO]BOMALT1
    TABTBO(1)=[F:TRO]BOMALT2
    TABTBO(2)=[F:TRO]BOMALT3
    If !find([M:MTOK]BOMALT, TABTBO)
        WMESSAGE=mess(53,193,1) - [M:MTOK]ITMREF+"/"+num$([M:MTOK]ROUALT)
        OK = 0
        Return
    Endif
Endif
If find([M:MTOK]TYPTRT,2,6,10,11)
    # controle article
    If [F:ITM]ITMREF <> [M:MTOK]ITMREF
        Read [ITM]ITM0 = [M:MTOK]ITMREF
        If fstat
            WMESSAGE = mess(134,100,1) - [M:MTOK]ITMREF
            OK = 0
            Return
        Endif
    Endif
    [M:MTOK]STU = [F:ITM]STU
    If [F:ITF]ITMREF <> [M:MTOK]ITMREF | [F:ITF]STOFCY <> [M:MTOK]MFGFCY
        Read [ITF]ITF0 = [M:MTOK]ITMREF;[M:MTOK]MFGFCY
        If fstat
            WMESSAGE = mess(2,196,1)+" : "+[M:MTOK]MFGFCY +"/"+ [M:MTOK]ITMREF
            OK = 0
            Return
        Endif
    Endif
Endif
# controle site
Call LECTURE("FCY",[M:MTOK]MFGFCY,"") From CONTOBJ
If fstat | [F:FCY]MFGFLG <> 2
   WMESSAGE = mess(1,193,1) - [M:MTOK]MFGFCY
   OK = 0
   Return
Endif
If [M:MTOK]MFGFCY <> GFCY
   GFCY = [M:MTOK]MFGFCY
   Gosub CHARG_PARAM
Endif
#Controle de la date
GMESSAGE = ""
Call STKCTRIPT([M:MTOK]IPTDAT, [M:MTOK]MFGFCY, "1") From STKLIB
If GMESSAGE <> "": WMESSAGE = GMESSAGE : GMESSAGE="" : OK = 0 : Return : Endif
#Contrôle poste réalisé (existence et pas poste de sous-traitance)
Read [F:MWS]WST0 = [M:MTOK]CPLWST;[M:MTOK]MFGFCY
If fstat | [F:MWS]WSTTYP = 3
   WMESSAGE = mess(133,193,1) - [M:MTOK]MFGFCY + "/" + [M:MTOK]CPLWST
   OK=0
   Return
Endif
#Controle matricule selon [F:BTS]MATRICULE 1=Obligatoire, 2=Facultatif, 3=Interdite
#If [M:MTOK]EMPNUM <> 0  |  [F:BTS]MATRICULE <> 2 : # FQ 42568 GA 09/2007
If [M:MTOK]EMPNUM <> 0                            : # FQ 42568 GA 09/2007
   If [F:BTS]MATRICULE <> 3                       : # FQ 42568 GA 09/2007
     Read [F:TMA]TMA0 = [M:MTOK]EMPNUM
     If fstat : WMESSAGE = mess(153,193,1) - num$([M:MTOK]EMPNUM)
              OK = 0
              Return
     Endif
   Else                                           : # FQ 42568 GA 09/2007
   # Type de champ interdit dans ce traitement
     WMESSAGE=mess(66,196,1)- [M:MTOK]MFGNUM +"/"+ num$([M:MTOK]OPENUM)
&                           - "EMPNUM="+ num$([M:MTOK]EMPNUM)
     OK = 0
     Return
   Endif
Elsif [F:BTS]MATRICULE=1 # Issue 85671 GA 09/2014 1=Mandatory
    WMESSAGE = mess(2103,200,1)-":"-mess([F:BTS]MATRICULE,2303,1)-[M:MTOK]MFGNUM-num$([M:MTOK]OPENUM)
Endif

#----------------- Contrôle des sections analytiques -----------------#
# Issue 77417 - 2012-02-01 by CCC
#For I=1 To max(GNBDIE,GOPTCANA)
For I=1 To GNBDIE
    Default Mask [MTOK]
    LSEC = evalue("[M:MTOK]CCE"+num$(I))
    Call CTRL_CCE(LSEC,I,"",GFINRSP,[M:MTOK]IPTDAT) From TRTX3CPT
    If mkstat
        WMESSAGE = GMESSAGE
        Raz GMESSAGE
        OK=0
        Return
    Endif
Next I
Return

######################################################
$CRE_SUIVI
Local Integer STAT
If G_LIN = 0
   G_DATE = [M:MTOK]IPTDAT
   G_FCY = [M:MTOK]MFGFCY
 # Issue 103194 GA 10/2014 idem MKIIMPORT
   #If [M:MTOK]TYPTRT = 2 : G_WMFGNUM = [M:MTOK]MFGNUM : Endif
   If find([M:MTOK]TYPTRT,2,10) : G_MFGNUM  = [M:MTOK]MFGNUM
                                  G_WMFGNUM = [M:MTOK]MFGNUM : Endif
   Gosub DECL_SVG
   GOK = 1
   Call DEBTRANS From GLOCK
   Trbegin [MKO]
   Call NUMERO(GCODNUM,[M:MTOK]MFGFCY,G_DATE,"",G_MFGTRKNUM,STAT) From SUBANM
   If STAT
     WMESSAGE = mess(60,199,1)-GCODNUM-num$([L]STAT)
     GOK = 0
     Gosub TR_ROLL
     Return
   Endif
Else
   If [M:MTOK]IPTDAT <> G_DATE | [M:MTOK]MFGFCY <> G_FCY
      If G_WMFGNUM <> ""
         Gosub MAJ_ENTOF
         Raz   G_WMFGNUM
      Endif
      Gosub CRE_ENTETE
      GOK = 1
      Call DEBTRANS From GLOCK
      Trbegin [MKO]
      G_DATE = [M:MTOK]IPTDAT
      G_FCY = [M:MTOK]MFGFCY
      # Issue 103194 GA 10/2014 idem MKIIMPORT
      #If [M:MTOK]TYPTRT = 2 : G_WMFGNUM = [M:MTOK]MFGNUM : Endif
      If find([M:MTOK]TYPTRT,2,10) : G_MFGNUM  = [M:MTOK]MFGNUM
                                     G_WMFGNUM = [M:MTOK]MFGNUM : Endif
      Call NUMERO(GCODNUM,[M:MTOK]MFGFCY,G_DATE,"",G_MFGTRKNUM,STAT) From SUBANM
      If STAT
         WMESSAGE = mess(60,199,1)-GCODNUM-num$([L]STAT)
         GOK = 0
         Gosub TR_ROLL
         Return
      Endif
   Else
      If [M:MTOK]MFGNUM <> G_WMFGNUM
         Raz G_MFGNUM
      Endif
      If [M:MTOK]MFGNUM <> G_WMFGNUM & G_WMFGNUM <> ""
         Gosub MAJ_ENTOF
         Raz G_WMFGNUM
         # Issue 103194 GA 10/2014 idem MKIIMPORT
         # Issue 111313 - 2015-11-24 by BEEBE : no " = 2"-comparison with find
         # If find([M:MTOK]TYPTRT,2,10) = 2 : G_WMFGNUM = [M:MTOK]MFGNUM : Endif
         If find([M:MTOK]TYPTRT,2,10) : G_WMFGNUM = [M:MTOK]MFGNUM : Endif
      Endif
   Endif
Endif
[M:MTOK]OPETRKLIN    = G_LIN
[M:MTOK]WNBMAT       = G_WNBMAT
[M:MTOK]WNBITM       = G_WNBITM
[M:MTOK]MFGTRKNUM    = G_MFGTRKNUM
# sr 07.02
[M:MTOK]WOPECLENBR    = G_WOPECLENBR
[M:MTOK]WMATCLENBR    = G_WMATCLENBR
[M:MTOK]WITMCLENBR    = G_WITMCLENBR

LSAVOPEUOM = [M:MTOK]OPEUOM   # Issue 65266 - 2010-06-08 by CCC

#Appel du moteur de création du suivi des temps
Case [M:MTOK]TYPTRT
    When 2 : Read [F:SCH]SCH0 = [M:MTOK]MFGNUM;[M:MTOK]OPENUM;[M:MTOK]OPESPLNUM
             If fstat : Raz [F:SCH] : Endif
             If [F:SCH]DACMST = 3
                Local Shortint WOPE
                Local Integer WBREAK
               #Recherche de la précédente opération à suivre (normale ou borne)
                Raz WBREAK,WOPE
                Filter [F:MFO] Where MFGNUM = [M:MTOK]MFGNUM & OPENUM < [M:MTOK]OPENUM
&               Order By Key MFO0 Desc
                For [F:MFO]
                    Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
                    If !fstat & [F:SCH]DACMST >1 : WBREAK = 1 : Break : Endif
                Next
                If WBREAK = 1 : WOPE = [F:MFO]OPENUM : Endif
                Filter [F:MFO]
           #Traitement des opé entre les deux bornes(borne supérieure comprise)
                Filter [F:MFO] Where MFGNUM = [M:MTOK]MFGNUM &
&                      OPENUM > WOPE & OPENUM <= [M:MTOK]OPENUM
             Else
                Filter [F:MFO] Where MFGNUM    = [M:MTOK]MFGNUM &
&                                    OPENUM    = [M:MTOK]OPENUM &
&                                    OPESPLNUM = [M:MTOK]OPESPLNUM
             Endif
             For [F:MFO]
                 Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
                 If !fstat [M:MTOK]MFGMST = [F:SCH]MFGMST
                           [M:MTOK]DACMST = [F:SCH]DACMST
                 Endif
                 If [F:MFO]OPENUM <> [M:MTOK]OPENUM
                    [M:MTOK]OPEUOM = [F:MFO]OPEUOM
                 Else
                    [M:MTOK]OPEUOM = LSAVOPEUOM   # Issue 65266 - 2010-06-08 by CCC
                 Endif
                 [M:MTOK]TIMUOMCOD = [F:MFO]TIMUOMCOD
                 If [M:MTOK]CPLWST = "" : [M:MTOK]CPLWST = [F:MFO]EXTWST : Endif
                 Call CRE_MKO From MTKAUTLIB
                 If GOK < 1 : Gosub TR_ROLL : Break # FQ 69909 Ctrl des sources avant Return
                 Else Gosub TRACE_SVG
                 Endif
                 G_LIN         = [M:MTOK]OPETRKLIN
                 G_WOPECLENBR  = [M:MTOK]WOPECLENBR
                 G_WMATCLENBR  = [M:MTOK]WMATCLENBR
                 G_WITMCLENBR  = [M:MTOK]WITMCLENBR
                 G_WNBOPE     += 1
                 G_WNBMAT      = [M:MTOK]WNBMAT
                 G_WNBITM      = [M:MTOK]WNBITM
                 G_WCPLQTY    += [M:MTOK]WCPLQTY
                 G_WREJCPLQTY += [M:MTOK]WREJCPLQTY
                 G_WQUACPLQTY += [M:MTOK]WQUACPLQTY
             Next
             Filter [F:MFO]
    When 6 : Read [F:ROS]ROS0 = [M:MTOK]MFGFCY;[M:MTOK]ITMREF;[M:MTOK]ROUALT;[M:MTOK]OPENUM
             If fstat : Raz [F:ROS] : Endif
             If [F:ROS]DACMST = 3
                 Local Shortint WOPE
                 Local Integer WBREAK
                 #Recherche de la précédente opération à suivre (normale ou borne)
                 Raz WBREAK,WOPE
                 Filter [F:ROO] Where FCY    = [M:MTOK]MFGFCY &
&                                     ITMREF = [M:MTOK]ITMREF & ROUALT = [M:MTOK]ROUALT &
&                                     OPENUM < [M:MTOK]OPENUM
&                                     Order By Key ROO0 Desc
                 For [F:ROO]
                     Read [F:ROS]ROS0 = [F:ROO]FCY;[F:ROO]ITMREF;[F:ROO]ROUALT;[F:ROO]OPENUM
                     If !fstat & [F:ROS]DACMST >1 : WBREAK = 1 : Break : Endif
                 Next
                 If WBREAK = 1 : WOPE = [F:ROO]OPENUM : Endif
                 Filter [F:ROO]
               #Traitement des opé entre les deux bornes(borne supérieure comprise)
                 Filter [F:ROO] Where ITMREF = [M:MTOK]ITMREF &
&                                     ROUALT = [M:MTOK]ROUALT &
&                                     OPENUM > WOPE & OPENUM <= [M:MTOK]OPENUM
             Else
                 Filter [F:ROO] Where ITMREF    = [M:MTOK]ITMREF &
&                                     ROUALT    = [M:MTOK]ROUALT &
&                                     OPENUM    = [M:MTOK]OPENUM &
&                                     RPLIND    = [M:MTOK]RPLIND
             Endif
             For [ROO]
                 Read [F:ROS]ROS0 = [M:MTOK]MFGFCY;[M:MTOK]ITMREF;[M:MTOK]ROUALT;[M:MTOK]OPENUM
                 If !fstat [M:MTOK]MFGMST = [F:ROS]MFGMST
                           [M:MTOK]DACMST = [F:ROS]DACMST
                 Endif
                 If [F:ROO]OPENUM  <> [M:MTOK]OPENUM
                    [M:MTOK]OPEUOM =  [F:ROO]OPEUOM
                 Else
                    [M:MTOK]OPEUOM = LSAVOPEUOM   # Issue 65266 - 2010-06-08 by CCC
                 Endif
                 Read [F:ROH]ROH1 = [M:MTOK]MFGFCY;[M:MTOK]ITMREF;[M:MTOK]ROUALT
                 If ! fstat : [M:MTOK]TIMUOMCOD = [F:ROH]TIMUOMCOD : Endif
                 Call CRE_MKO From MTKAUTLIB
                 If GOK < 1 : Gosub TR_ROLL : Break # FQ 69909 Ctrl des sources avant Return
                 Else Gosub TRACE_SVG
                 Endif
                 G_LIN     = [M:MTOK]OPETRKLIN
                 G_WNBOPE += 1
                 G_WNBMAT  = [M:MTOK]WNBMAT
                 G_WNBITM  = [M:MTOK]WNBITM
             Next
             Filter [F:ROO]
    When 10 ,11: Call CRE_MKO From MTKAUTLIB
                 If GOK < 1 : Gosub TR_ROLL : Return
                 Else Gosub TRACE_SVG
                 Endif
                 G_LIN         = [M:MTOK]OPETRKLIN
                 G_WOPECLENBR  = [M:MTOK]WOPECLENBR
                 G_WMATCLENBR  = [M:MTOK]WMATCLENBR
                 G_WITMCLENBR  = [M:MTOK]WITMCLENBR
                 G_WNBOPE     += 1
                 G_WNBMAT      = [M:MTOK]WNBMAT
                 G_WNBITM      = [M:MTOK]WNBITM
                 G_WCPLQTY    += [M:MTOK]WCPLQTY
                 G_WREJCPLQTY += [M:MTOK]WREJCPLQTY
                 G_WQUACPLQTY += [M:MTOK]WQUACPLQTY

    When Default : Read [F:MWS]WST0 = [M:MTOK]CPLWST;[M:MTOK]MFGFCY
                   If !fstat
                      [M:MTOK]TIMUOMCOD = 1
                      Call CRE_MKO From MTKAUTLIB
                      If GOK < 1 : Gosub TR_ROLL : Return
                      Else Gosub TRACE_SVG
                      Endif
                      G_LIN = [M:MTOK]OPETRKLIN
                      G_WNBOPE += 1
                   Endif
Endcase
#
Return

$TR_ROLL
#Rollback
#Raz G_WNBOPE, G_MFGNUM, G_WMFGNUM, G_MFGTRKNUM, G_WNBMAT, G_WNBITM
#Raz G_LIN
Return

#######################################
$MAJ_ENTOF
#Maj entête d'OF
Readlock [F:MFG]MFG0 = G_WMFGNUM
If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-num$(G_WMFGNUM) : Return
Elsif fstat GOK=0  : Call RSTA("MFG",num$(G_WMFGNUM)) From GLOCK
      Return
Endif
[F:MFG]OPECLENBR += G_WOPECLENBR
[F:MFG]MATCLENBR += G_WMATCLENBR
[F:MFG]ITMCLENBR += G_WITMCLENBR
If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&  [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&  [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
   [F:MFG]MFGTRKFLG = 5
   # CCC (10/01/08) DM 44021
#   [F:MFG]TRKLAST   = G_DATE
Else
   [F:MFG]MFGTRKFLG = 4
   # CCC (10/01/08) DM 44021
#   Raz [F:MFG]TRKLAST
Endif

# CCC (10/01/08) DM 44021
If [F:MFG]TRKLAST<G_DATE
   [F:MFG]TRKLAST   = G_DATE
Endif
If [F:MFG]TRKLASTC<date$
   [F:MFG]TRKLASTC  = date$
Endif
If [F:MFG]TRKFIRST>G_DATE | [F:MFG]TRKFIRST = "00/00/00"
    [F:MFG]TRKFIRST = G_DATE
Endif
If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
    [F:MFG]TRKFIRSTC = date$
Endif
[F:MFG]CPLQTY    += G_WCPLQTY
[F:MFG]REJCPLQTY += G_WREJCPLQTY
[F:MFG]QUACPLQTY += G_WQUACPLQTY
If [F:MFG]ITMLINNBR = [F:MFG]ITMCLENBR
   [F:MFG]RMNEXTQTY = 0
Else
   [F:MFG]RMNEXTQTY =  [F:MFG]EXTQTY - [F:MFG]CPLQTY
Endif
Call QTEARR([F:MFG]RMNEXTQTY,[F:MFG]STU) From TRTDIV
If [F:MFG]RMNEXTQTY < 0 : [F:MFG]RMNEXTQTY = 0 : Endif
If [F:MFG]CPLQTY >= [F:MFG]EXTQTY : Raz [F:MFG]RMNEXTQTY : Endif
If [F:MFG]RMNEXTQTY > [F:MFG]EXTQTY : [F:MFG]RMNEXTQTY = [F:MFG]EXTQTY : Endif
[F:MFG]UPDDAT    = date$  : # FQ 42680
[F:MFG]UPDUSR    = GUSER  : # FQ 42680
Rewrite [F:MFG]
If fstat
   GOK = 0 : Call FSTA("MFG") From GLOCK : Return
Endif
#----- MISE à jour statistiques entête d'OF -----#
Call VALSTA("MFG",1) From SUBPS2
If GOK < 1 : Return : Endif
Raz GPE
GPOINT="UPDSCD"
Gosub ENTREE From EXEFNC
If !GPE
    # sr 08.02 si besoin maj de WORKLOAD demande 15029
    If find([F:MFG]SCDFLG,2,4)
            [M:JALK]CODORI = 1
            [M:JALK]CODMAJ = 0
            [M:JALK]CODTRS = 0                # llc 11.02 16716
            [M:JALK]MFGFCY = [F:MFG]MFGFCY
            [M:JALK]MFGNUM = [F:MFG]MFGNUM
            [M:JALK]MFGSTA = [F:MFG]MFGSTA
            # llc 12.02
            If [F:PJA]MFGFCY <> [M:JALK]MFGFCY
                Read [PJA]PJA0=[M:JALK]MFGFCY
                If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
            Endif
            Call DEJALONNE From JALLIBA
            If [M:JALK]CODRET = 0
                Call JALONNE From JALLIB
            Endif
    Endif
Endif
If GOK < 1 : Return : Endif

Raz G_WOPECLENBR, G_WMATCLENBR, G_WITMCLENBR
Raz G_WCPLQTY,    G_WREJCPLQTY, G_WQUACPLQTY
Return

#######################################
$CRE_ENTETE
# 04.07 Demande 40752
Local Char WFILTRE(80)
If GOK = 1
    Raz [F:MTK]
    If G_MFGNUM <> ""
       Read [F:MFG] = G_MFGNUM
       If !fstat : [F:MTK] = [F:MFG] : Endif
    Endif
    [F:MTK]MFGFCY    = G_FCY      # Issue 90461 GA 07/2013 avant GFCY
    [F:MTK]TRSCOD    = [M:MTOK]TRSCOD
    [F:MTK]TRSCODS   = [M:MTOK]TRSCODS
    [F:MTK]MFGTRKNUM = G_MFGTRKNUM
    [F:MTK]MFGTRKDAT = G_DATE
    [F:MTK]OPETRKFLG = 2
    [F:MTK]ITMTRKFLG = 1
    [F:MTK]MATTRKFLG = 1
    [F:MTK]NBROPE    = G_WNBOPE
    [F:MTK]NBRMAT    = G_WNBMAT
    [F:MTK]NBRITM    = G_WNBITM
    If [F:MTK]NBRMAT <> 0 : [F:MTK]MATTRKFLG = 2 : Endif
    If [F:MTK]NBRITM <> 0 : [F:MTK]ITMTRKFLG = 2 : Endif
    [F:MTK]CREDAT    = date$
    [F:MTK]CREUSR    = GUSER
    [F:MTK]EXPNUM    = [C]EXPORT
    Raz [F:MTK]UPDUSR
    Raz [F:MTK]UPDDAT
    Write [F:MTK]
    If fstat : GOK = 0 : Call FSTA("MTK") From GLOCK : Endif
Endif
If GOK < 1 : Rollback
    # Enregistrement dans SAS si nécessaire
    If WMKOFLG & [L]AOWSTA=2
        DEBENR_TMP = DEBENR
        WDEBENR_TMP = WDEBENR
        DEBENR = DEBENR_SVG
        WADXSEK = adxseek("IMP")
        OLDIRS = adxirs
        OLDIFS = adxifs
        OLDIUM = adxium
        adxirs = IMPIRS
        adxifs = IMPIFS
        adxium = IMPIUM
        GOK=1
        GNUMAOW=NBENR_SVG+1
        For I=1 To NBENR-NBENR_SVG-2
            Gosub IMPORT_SAS From =NOMTRT
            GNUMAOW+=1

            Seek First + DEBENR Using [IMP]
            Call RD_SEQ(VALIMP,BLBIMP,CLBIMP,IMPFIC,SEPNUMS,IMPFINS,WDEBENR) From SUBIMPOBJ
            DEBENR=adxseek("IMP")
            DEBENR=adxseek("IMP")
        Next
        IMPSTA=0
        NUMFLD=0
        LIG=0
        Raz [F:AOV], [F:AOW]
        DEBENR = DEBENR_TMP
        WDEBENR = WDEBENR_TMP
        Seek First + WADXSEK Using [IMP]
        GOK=0
        adxirs = OLDIRS
        adxifs = OLDIFS
        adxium = OLDIUM
    Endif
Else       : Commit
             If [F:MTK]ITMTRKFLG = 2
                 # 04.07 Demande 40752
                    WFILTRE="[F:MKI]MFGTRKNUM=[F:MTK]MFGTRKNUM"
                    Call REGFROMENT(1,"MKI",WFILTRE,"ITMREF",[F:MTK]MFGFCY) From TRTSHTCOM
             Endif
             Gosub CLEAR_SVG
             DEBENR_SVG=DEBENR
             WMSGSUI = mess(79,190,1)-[F:MTK]MFGTRKNUM
             TRA = 1
             Call ECR_TRACE(WMSGSUI,0) From GESECRAN
             Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

NBENR_SVG = NBENR

Raz G_WNBOPE, G_MFGNUM, G_WMFGNUM, G_MFGTRKNUM, G_WNBMAT, G_WNBITM
Raz G_LIN
Return

#####################################################
# Déclaration du fichier sauvegarde
$DECL_SVG
MKOSVG = filpath("tmp",tolower(GFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"mkosvg")
adxifs = ";"
adxirs = chr$(10)
Gosub CLEAR_SVG
Return

#####################################################
# sauvegarde de l'enregistrement en cours de traitement
$TRACE_SVG
Local Char    OLDIRS(5), OLDIFS(5)
Local Integer OLDIUM, FINENR, NBCAR , NBCAR2
OLDIRS = adxirs
OLDIFS = adxifs
OLDIUM = adxium
adxirs = IMPIRS
adxifs = IMPIFS
adxium = IMPIUM
FINENR = adxseek("IMP")
NBCAR  = WDEBENR-DEBENR
Seek First + DEBENR Using [IMP]
Openo MKOSVG , -1 Using [SVG]
While NBCAR>0
 NBCAR2 = min(NBCAR,32000)
 Local Schar CAR(1)(1..NBCAR2)
 Getseq NBCAR2 , CAR Using [IMP]
 Putseq NBCAR2 , CAR Using [SVG]
 NBCAR -= NBCAR2
Wend
Openo Using [SVG]
Seek First + FINENR Using [IMP]
adxirs = OLDIRS
adxifs = OLDIFS
adxium = OLDIUM
Return

#####################################################
# Copie du fichier des sauvegardes dans le fichier erreur du superviseur
$COP_SVG
Local Char    OLDIRS(5), OLDIFS(5)
Local Integer OLDIUM, FINENR, NBCAR , NBCAR2
OLDIRS = adxirs
OLDIFS = adxifs
OLDIUM = adxium
adxirs = IMPIRS
adxifs = IMPIFS
adxium = IMPIUM
Openi MKOSVG Using [SVG]
Seek Last Using [SVG]
NBCAR  = adxseek("SVG")
Seek First Using [SVG]
Openo FICERR , -1 Using [ERR]
While NBCAR>0
 NBCAR2 = min(NBCAR,32000)
 Local Schar CAR(1)(1..NBCAR2)
 Getseq NBCAR2 , CAR Using [SVG]
 Putseq NBCAR2 , CAR Using [ERR]
 NBCAR -= NBCAR2
Wend
Openo Using [ERR]
Openi Using [SVG]
Gosub CLEAR_SVG
adxirs = OLDIRS
adxifs = OLDIFS
adxium = OLDIUM
Return

#####################################################
# réinitialisation du fichier des sauvegardes
$CLEAR_SVG
Openo MKOSVG , 0 Using [SVG]
Openo MKOSVG Using [SVG]
Return

