#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# SUBITGB : Gestion des catégorie articles                 TS      2005 #
# --------------------------------------------------------------------- #
# Traitements complémentaires de l'objet "ITG"                          #
# Les traitements sur champ "Call"     se trouvent dans le SUBITG       #
# Les actions "Gosub" de l'objet "ITG" se trouvent dans le SUBITGA      #
# CHARGEMENT du tableau                                                 #
#########################################################################
$CHARG_SRU

# Si import pas de préchargement des tableaux de règles de gestion
If GIMPORT : Return : Endif

Local Integer LSENS
Local Integer NOL, NOL4, NOL8
Local Integer WI
Local Integer WGLOAAAFLG, WGLOQQQFLG, WGLORRRFLG : # pour sauvegarde
WGLOAAAFLG=[M:ITG4]GLOAAAFLG
WGLOQQQFLG=[M:ITG4]GLOQQQFLG
WGLORRRFLG=[M:ITG4]GLORRRFLG
# précharger le tableau de ITG4 à partir des règles générales de stock
Raz [M:ITG4]
Raz [M:ITG8]
[M:ITG4]GLOAAAFLG=WGLOAAAFLG                     : # pour restitution
[M:ITG4]GLOQQQFLG=WGLOQQQFLG
[M:ITG4]GLORRRFLG=WGLORRRFLG
Raz WI
Raz NOL4, NOL8

For [SRU] Where TCLCOD="" & STOFCY=""

    If find([F:SRU]TRSTYP,2,25,27)
       Gosub ALI_ITG4
    Elsif find([F:SRU]TRSTYP,1,8,26,28)
       Gosub ALI_ITG8
    Endif

    # Livrable : Livraison(normale,prêt,sous-traitance),Demande de service,
    #            Retour client(normal,prêt,sous-traitance)
    If [M:ITG1]DLVFLG=2
       If find([F:SRU]TRSTYP,4,17,20,24)
          Gosub ALI_ITG4
       Elsif find([F:SRU]TRSTYP,12,18,33)
          Gosub ALI_ITG8
       Endif
    Endif

    # Acheté : Retour fournisseur(normal,sous-traitance)
    #          Réception(normale,sous-traitance)
    If [M:ITG1]PURFLG = 2
       If find([F:SRU]TRSTYP,11,32,29) &
&         !find([F:SRU]TRSTYP,[M:ITG4]TRSTYPS)
          Gosub ALI_ITG4
       Elsif find([F:SRU]TRSTYP,3,16) &
&         !find([F:SRU]TRSTYP,[M:ITG8]TRSTYPE)
          Gosub ALI_ITG8
       Endif
    Endif

    # Fabriqué, fantôme : Sortie OF, Sortie ordre s-traitance
    #                     Entrée OF, Réintégration stock
    If [M:ITG1]MFGFLG = 2 | [M:ITG1]PHAFLG = 2
       If find([F:SRU]TRSTYP,6,29) &
&         !find([F:SRU]TRSTYP,[M:ITG4]TRSTYPS)
          Gosub ALI_ITG4
       Elsif find([F:SRU]TRSTYP,5,19) &
&         !find([F:SRU]TRSTYP,[M:ITG8]TRSTYPE)
          Gosub ALI_ITG8
       Endif
    Endif

    If [M:ITG1]SCPFLG = 2
    # Sous-traité : Livraison, Retour réception
    #               Réception, Entrée OF, Retour client
       If find([F:SRU]TRSTYP,4,11) &
&         !find([F:SRU]TRSTYP,[M:ITG4]TRSTYPS)
          Gosub ALI_ITG4
       Elsif find([F:SRU]TRSTYP,3,5,12) &
&         !find([F:SRU]TRSTYP,[M:ITG8]TRSTYPE)
          Gosub ALI_ITG8
       Endif
    Endif
    If [M:ITG1]TOOFLG = 2
    # Outillage : Sortie OF, Retour réception
    #             Réception, Réintégration stock
       If find([F:SRU]TRSTYP,6,11) &
&         !find([F:SRU]TRSTYP,[M:ITG4]TRSTYPS)
          Gosub ALI_ITG4
       Elsif find([F:SRU]TRSTYP,3,19) &
&         !find([F:SRU]TRSTYP,[M:ITG8]TRSTYPE)
          Gosub ALI_ITG8
       Endif
    Endif
#  Endcase

  # Si gestion des emplacement
  #MAE, bg 71014, test sur NOL4>0 et NOL8 >0
  #remplacement de NOL4 par (NOL4-1) et NOL8 par (NOL8-1)
  If dim([M:ITG2]LOCMGTCOD)>0 & [M:ITG2]STOMGTCOD>1                            # hcb X3-71908
    If NOL4>0
      If [M:ITG4]LOCNUM(NOL4-1)>1 & !find([M:ITG4]LOCNUM(NOL4-1)-1,[M:ITG2]LOCDES(0..[M:ITG2]NBINT-1))   # hcb X3-71908
        If [M:ITG2]NBINT+1 = GCOD_NDL                                           # hcb X3-71908
          Call MESSAGE(mess(498,199,1)-mess(353,199,1)) From GESECRAN
          Break
        Else
          [M:ITG2]LOCDES(WI)=[M:ITG4]LOCNUM(NOL4-1)-1                 # hcb X3-71908
          WI+=1
          [M:ITG2]NBINT=WI                                            # hcb X3-71908
        Endif
      Endif
      If [M:ITG4]LOCNUM2(NOL4-1)>1 & !find([M:ITG4]LOCNUM2(NOL4-1)-1,[M:ITG2]LOCDES(0..[M:ITG2]NBINT-1))       # hcb X3-71908
        If [M:ITG2]NBINT+1 = GCOD_NDL                                                                          # hcb X3-71908
          Call MESSAGE(mess(498,199,1)-mess(353,199,1)) From GESECRAN
          Break
        Else
          [M:ITG2]LOCDES(WI)=[M:ITG4]LOCNUM2(NOL4-1)-1                                                         # hcb X3-71908
          WI+=1
          [M:ITG2]NBINT=WI                                             # hcb X3-71908
        Endif
      Endif
      If [M:ITG4]LOCNUM3(NOL4-1)>1 & !find([M:ITG4]LOCNUM3(NOL4-1)-1,[M:ITG2]LOCDES(0..[M:ITG2]NBINT-1))       # hcb X3-71908
        If [M:ITG2]NBINT+1 = GCOD_NDL                                                                          # hcb X3-71908
          Call MESSAGE(mess(498,199,1)-mess(353,199,1)) From GESECRAN
          Break
        Else
          [M:ITG2]LOCDES(WI)=[M:ITG4]LOCNUM3(NOL4-1)-1                                                         # hcb X3-71908
          WI+=1
          [M:ITG2]NBINT=WI                                                                                     # hcb X3-71908
        Endif
      Endif
     Endif
    If NOL8>0
      If [M:ITG8]LOCNUME(NOL8-1)>1 & !find([M:ITG8]LOCNUME(NOL8-1)-1,[M:ITG2]LOCDES(0..[M:ITG2]NBINT-1))       # hcb X3-71908
        If [M:ITG2]NBINT+1 = GCOD_NDL
          Call MESSAGE(mess(498,199,1)-mess(353,199,1)) From GESECRAN
          Break
        Else
          [M:ITG2]LOCDES(WI)=[M:ITG8]LOCNUME(NOL8-1)-1                       # hcb X3-71908
          WI+=1
          [M:ITG2]NBINT=WI                                                   # hcb X3-71908
        Endif
      Endif
    Endif
Endif
Next

[M:ITG4]NBLOC = NOL4
[M:ITG8]NBENT = NOL8
If dim([M:ITG2]LOCMGTCOD) > 0 & [M:ITG2]STOMGTCOD>1  # hcb X3-71908
    Gosub TRI
Endif

For NOL=0 To [M:ITG8]NBENT-1
  If dim([M:ITG8]LOCNUME)>0
    Actzo [M:ITG8]LOCNUME(NOL)
  Endif
  # Ctrl qualité, Retour prêt et s-traitance, Chgt stock, Entrée transfert
  If find([M:ITG8]TRSTYPE(NOL),8,18,26,28,33)
    If dim([M:ITG8]DACLOT)>0
      Grizo [M:ITG8]DACLOT(NOL)
      Grizo [M:ITG8]LOTSUPINH(NOL)
      [M:ITG8]DACLOT(NOL)    = 2
      [M:ITG8]LOTSUPINH(NOL) = 1
    Endif
    # Ctrl qualité
    If [M:ITG8]TRSTYPE(NOL)=8
      Grizo [M:ITG8]QLYCTLFLG(NOL)
      [M:ITG8]QLYCTLFLG(NOL) = 1
    Else
      Actzo [M:ITG8]QLYCTLFLG(NOL)
    Endif
    # Chgt stock
    If [M:ITG8]TRSTYPE(NOL)=26
      Grizo [M:ITG8]DEFSTA(NOL)
      Raz [M:ITG8]DEFSTA(NOL)
    Else
      Actzo [M:ITG8]DEFSTA(NOL)
    Endif
  Elsif dim([M:ITG8]DACLOT)>0
    Actzo [M:ITG8]DACLOT(NOL)
    Actzo [M:ITG8]LOTSUPINH(NOL)
  Endif

  #--- Issue X3-53322
  # Ctrl qualité, Chgt stock, Entrée trf, Entrée OF et Réintégration stock (à supprimer quand GP)
  If find([M:ITG8]TRSTYPE(NOL),8,26,28,5,19)
    If dim([M:ITG8]DACCTR)>0
      Grizo [M:ITG8]DACCTR(NOL)
      [M:ITG8]DACCTR(NOL) = 1
    Endif
  Elsif dim([M:ITG8]DACCTR)>0
    Actzo [M:ITG8]DACCTR(NOL)
  Endif
  #---

Next NOL
For NOL=0 To [M:ITG4]NBLOC-1
  If dim([M:ITG4]LOCNUM)>0
    # Sortie transfert
    If [M:ITG4]TRSTYPS(NOL)=27
      Grizo [M:ITG4]LOCNUM(NOL)
      Grizo [M:ITG4]LOCNUM2(NOL)
      Grizo [M:ITG4]LOCNUM3(NOL)
      [M:ITG4]LOCNUM(NOL) =0
      [M:ITG4]LOCNUM2(NOL)=0
      [M:ITG4]LOCNUM3(NOL)=0
    Else
      Actzo [M:ITG4]LOCNUM(NOL)
      Actzo [M:ITG4]LOCNUM2(NOL)
      Actzo [M:ITG4]LOCNUM3(NOL)
    Endif
  Endif
Next NOL

Affzo [M:ITG4]1-99
Affzo [M:ITG8]1-99
#--- Jira X3-50162
Affzo [M:ITG2]LOCMGTCOD                      # hcb X3-71908
Affzo [M:ITG2]75                             # hcb X3-71908
#---

Return

######################################
$TRI
#-- Tri du tableau des emplacement
Sorta [M:ITG2]NBINT [M:ITG2]LOCDES Order By [M:ITG2]LOCDES(indice)           # hcb X3-71908
If [M:ITG2]NBINT > 0                                                         # hcb X3-71908
  [M:ITG2]LOCMGTCOD = 2                                                      # hcb X3-71908
  Actzo [M:ITG2]LOCMGTCOD                                                    # hcb X3-71908
Endif
Return

######################################
$ALI_ITG4
nolign = NOL4 +1
[M:ITG4] = [F:SRU]
[M:ITG4]TRSTYPS(NOL4) = [F:SRU]TRSTYP
[M:ITG4]TRSCODS(NOL4) = [F:SRU]TRSCOD
[M:ITG4]AUZSTAS(NOL4) = [F:SRU]AUZSTA
[M:ITG4]AUZSSTS(NOL4) = [F:SRU]AUZSST
[M:ITG4]FORSTAS(NOL4) = [F:SRU]FORSTA
If GIMPORT & dim(GLOC)>0 & GLOC=1
  Raz [M:ITG4]LOCNUM(NOL4), [M:ITG4]LOCNUM2(NOL4), [M:ITG4]LOCNUM3(NOL4)
Endif
NOL4 += 1
Return

######################################
$ALI_ITG8
nolign = NOL8 +1

[M:ITG8] = [F:SRU]
[M:ITG8]TRSTYPE(NOL8) = [F:SRU]TRSTYP
[M:ITG8]TRSCODE(NOL8) = [F:SRU]TRSCOD
[M:ITG8]AUZSTAE(NOL8) = [F:SRU]AUZSTA
[M:ITG8]AUZSSTE(NOL8) = [F:SRU]AUZSST
[M:ITG8]FORSTAE(NOL8) = [F:SRU]FORSTA
If dim([M:ITG8]LOCNUME)>0
  [M:ITG8]LOCNUME(NOL8)=[F:SRU]LOCNUM
Endif
If GIMPORT & dim(GLOC)>0 & GLOC=1
  Raz [M:ITG8]LOCNUME(NOL8)
Endif
#--- Issue X3-53322
If dim([M:ITG8]DACCTR)>0
  If [M:ITG8]DACCTR(NOL8)=0 [M:ITG8]DACCTR(NOL8)=1 Endif
Endif
#---
NOL8 += 1
Return

