#<AdxTL>@(#)5.0.0.0 $Revision$
##################################################################################################################
# UUTITRS01   Utilitaire de mise à jour de la table TMPFUP0 avec conservation des données           Module Tiers #
#             Traitement exécuté après la maintenance qui livre la nouvelle table TMPFUP01                       #
#             Ce traitement remplit TMPFUP01 avec les données converties de la table TMPFUP0                     #
##################################################################################################################

Local Char APPLI(30) : APPLI = nomap
Call SAIDOS(APPLI,"") From SAIDOS
If APPLI <> ""
 If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
 Read [ADS]DOSSIER=[L]APPLI : If fstat Raz [F:ADS] : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UUTITRS01:"-"TMPFUP0 table data updates") From LECFIC

 Call MAJ_UTITRS01(APPLI) 
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

# conversion puis copie des données de TMPFUP0 dans TMPFUP01
Subprog MAJ_UTITRS01(APPLI)
Value Char APPLI

# test du code activité
If func AFNC.ACTIV("FUP")=0 : End : Endif

# test de présence des tables
If filinfo(filpath("FIL","TMPFUP0","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","TMPFUP01","fde",APPLI),0)<=0 : End : Endif

# table avec ancienne structure (contient peut-être déjà des données)
Local File =APPLI+".TMPFUP0" [TFP]
Local File =APPLI+".TMPFUP0" [TFP2]

# table avec la nouvelle structure
Local File =APPLI+".TMPFUP01" [ZTF]

# si la table est déjà avec la nouvelle structure, pas la peine d'exécuter le traitement
If dim([TFP]QURNUM)>0 : End : Endif

Local Integer DIMFLD, R, OK
Local Char FLD(250)

Call ECR_TRACE("UUTITRS01: Process Start on : "+APPLI,0) From GESECRAN
Trbegin [ZTF]
# boucle sur les numéros de campagnes
For [TFP]TFP0(1)
 # boucle sur chaque champ
 For [TFP2]TFP0 Where [TFP2]NUMREQ=[TFP]NUMREQ
  If evalue("dim([ZTF]"+[TFP2]FLD+")")>=1 # le champ existe dans la nouvelle table
   [L]FLD=[TFP2]FLD
   DIMFLD=0
   OK=1
  Else
   # le champ n'existe pas dans la nouvelle table, c'est peut-être un champ indicé (Syntaxe CHAMP_INDICE)
   # récupérer l'indice
   R=instr(0,[TFP2]FLD,"_")
   If R<>0 # trouvé
    [L]FLD=left$([TFP2]FLD,R-1)
    DIMFLD=val(right$([TFP2]FLD,R+1))
    If evalue("dim([ZTF]"+[L]FLD+")")>=1 # c'est un champ dimensionné
     OK=1
    Else
     OK=0
    Endif
   Else
    OK=0
   Endif
  Endif

  If evalue("dim([ZTF]"+[TFP2]FLD+")")>0
   Case evalue("type([ZTF]"+[TFP2]FLD+")")
    When 1,2,4,5,6,7,8,9 # type numérique
     Assign "[ZTF]"+[TFP2]FLD+"("+num$(DIMFLD)+")" With evalue([TFP2]FLDVAL)
    When 3 # date
     Assign "[ZTF]"+[TFP2]FLD+"("+num$(DIMFLD)+")" With evalue('['+num$([TFP2]FLDVAL)+']')
    When Default
     Assign "[ZTF]"+[TFP2]FLD+"("+num$(DIMFLD)+")" With [TFP2]FLDVAL
   Endcase
  Endif
 Next
 # le champ NUMREQ s'appelle maintenant QURNUM
 [F:ZTF]QURNUM = [F:TFP]NUMREQ #CHECK IGNORE_LINE
 Write [ZTF]
Next
# effacement de tous les enregistrements de la table TMPFUP0
# Cet effacement doit se faire ici et pas au début de UUTITRS02, sinon la validation de la table TMPFUP plante !
# voir le bug 60378 pour plus d'infos
Delete [TFP] Where 1
Commit # ZTF

Call ECR_TRACE("UUTITRS01: Process End on : "+APPLI,0) From GESECRAN
End

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
# pas de modification dans le dossier mère
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

# test de présence du module Tiers
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITRS01(APPLI)
End

########################################################################
# Pour exécution depuis dosmaj (validation dossier)                    #
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char APPLI
# pas de modification dans le dossier mère
If APPLI="X3" End : Endif

# test de présence du module Tiers
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITRS01(APPLI)
End
