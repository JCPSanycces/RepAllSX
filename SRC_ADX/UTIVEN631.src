#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIVEN631    Utilitaire de migration du module ventes     Module VENTE #
#              d'une version 6.2 vers  une version 6.3                   #
#                                                                        #
# Appel UTIVEN11 : (Bug 72056) :                                         #
#   Initialisation champs dans les factures                              #
#     Table SINVOICED   - Lignes factures                                #
#       STRDAT         Date début prestation                             #
#       ENDDAT         Date fin   prestation                             #
#                                                                        #
##########################################################################


Call MAJ_UTIVEN631
End

Subprog MAJ_UTIVEN631
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIVEN631 - Migration ventes Béryl 6.2 vers 6.3") From SAIDOS
If DOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIVEN631 : Utilitaire de migration ventes 6.2 vers 6.3") From LECFIC
  Call EXE_UTIVEN631(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UTIVEN631(DOSSIER)
Value Char    DOSSIER
#-----
Call ECR_TIME("UTIVEN631 : Start folder's process"-DOSSIER) From DOSSUB
Call ECR_TRACE("---------- Update sales module release 6.2 to 6.3 ----------",0) From GESECRAN
#----- Chargement globale GMAXUPDTRS -----#
If dim([V]GMAXUPDTRS)<1  Global Integer GMAXUPDTRS : Endif
Local File =DOSSIER+".ADOVAL" [ADW]
Read [ADW] ADW0="";"";"MAXUPDTRS" : If fstat  Raz [F:ADW] : Endif
If val([F:ADW]VALEUR)>0
  GMAXUPDTRS=val([F:ADW]VALEUR)
Else
  GMAXUPDTRS=1000
Endif
Close Local File [ADW]

#----- Début du traitement -----#

# Traitement des factures
Gosub TRT_SIH From UTIVEN11

# Traitement des transaction
Gosub TRT_SLT From UTIVEN12


#----- Fin du traitement -----#

$FIN_UTIVEN631
Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
Call ECR_TIME("UTIVENV631 : End folder's process"-DOSSIER) From DOSSUB
End



#-------------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(4)<>2 End Endif

Call EXE_UTIVEN631(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(4)<>2 End Endif
Call EXE_UTIVEN631(APPLI)
End


