#<AdxTL>@(#)12.0.0.0 $Revision$ Object Management HRCGD
Raz GPILOBJ
Raz GBIDC1, GBIDC2
Call OBJET("HRCGD",GBIDC1,GBIDC2) From GOBJET
End

########################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "FERME"       : Gosub FERME
 When "LIENS"       : Gosub LIENS
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "ANNULE"      : Gosub ANNULE
 When "CHGCOD"      : Gosub CHGCOD
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "AS_COD"      : Raz GCURLEG
 When "RAZCRE"      : Gosub RAZCRE
 When "ABANDON"     : Gosub ABANDON
Endcase
Return

########################################
$OUVRE
If clalev ([F:HRCGD])=0 : Local File HRCTRGRD   [HRCGD] : Endif
If clalev ([F:HRCGD2])=0 : Local File HRCTRGRD   [HRCGD2] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

#LIPET - 2017-08-22 - START
If dim([M:HRCGD1]LEG)=0:If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif:Endif
#LIPET - 2017-08-22 - END
Return

########################################
$LIENS

GCURLEG = [F:HRCGD]LEG
#LIPET - 2017-08-22 - START
#If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If dim([M:HRCGD1]LEG)=0:If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif:Endif
#LIPET - 2017-08-22 - END

# To manage translated texts (data type AX3 & AX1)
Call LECTEXTRA([M]DESAXX,"HRCTRGRD","DESAXX",[M]COD,GCURLEG) From ATEXTRA
Call LECTEXTRA([M]SHOAXX,"HRCTRGRD","SHOAXX",[M]COD,GCURLEG) From ATEXTRA
# To display or to hide fields based on legislation code
Gosub DISPLAY_HIDE
# SBA-114309
Call GRISE_XIT([M]CTRXITAUT)
Return


########################################
# SBA-114309
$ABANDON
$RAZCRE
If func AFNC.ACTIV("LEG")=0
  GCURLEG=GDOSLEG
Else
  GCURLEG=GLEGFIL
Endif
Gosub DISPLAY_HIDE
Call GRISE_XIT([M]CTRXITAUT)
Return
########################################
$CREATION
$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

########################################
# To manage translated texts (data type AX3 & AX1) in creation and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("HRCTRGRD","DESAXX",CLECUR1,"","HRCTRGRD","DESAXX",[F:HRCGD]COD,GCURLEG)  From ATEXTRA
 Call DUPTEXTRA("HRCTRGRD","SHOAXX",CLECUR1,"","HRCTRGRD","SHOAXX",[F:HRCGD]COD,GCURLEG)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESAXX,"HRCTRGRD","DESAXX",[F:HRCGD]COD,GCURLEG) From ATEXTRA
Call MAJTEXTRA([M]SHOAXX,"HRCTRGRD","SHOAXX",[F:HRCGD]COD,GCURLEG) From ATEXTRA
Return

########################################
$VERIF_CRE
$VERIF_MOD
If [M]DEFVAL=2
 Filter [F:HRCGD2] Where COD<>[M]COD & LEG=GCURLEG & DEFVAL=2
 Read [F:HRCGD2]HRCGD0 First
 Filter [F:HRCGD2]
 If !fstat
  # A default value already exist for this legislation : XXX
  GMESSAGE = mess(1,10712,1)-":'"-[F:HRCGD2]COD+"'"
  OK = 0 : Return
 Endif
Endif
Return

########################################
#03/04/2012 **Delphine be carfull you have to use the good format
#It depends of the datatype of the field to hide or to diplay
#'K:10X' = char of length 10 (look help on-line about format$() )
#'LA<menu local number>' it's for local menu
# GLON<datatype> it's the longer of a datatype
$DISPLAY_HIDE
# SBA-114309
Local Char W_SIGN(1)
W_SIGN=""
If !func DIVPAYE.IS_KFR()
  W_SIGN="-"
  Raz  [M]CODN4H,[M]CODMVT,[M]DETN4H,[M]REGSTR
Endif
Chgfmt [M]CODN4H With W_SIGN+"K:10X"
Chgfmt [M]CODMVT With W_SIGN+"K:10X"
Chgfmt [M]DETN4H With W_SIGN+"K:10X"
Chgfmt [M]REGSTR With W_SIGN+"LA1:10X"


If func AFNC.ACTIV("KFR")
 Chgfmt [M]RENMUT   With W_SIGN+"LA1:20X"
 Chgfmt [M]SSPGRD   With W_SIGN+"K:5B"
 If W_SIGN="-"
   Raz [M]RENMUT,[M]SSPGRD
  Endif
Endif
Affzo [M]

Return

Subprog GRISE_XIT(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo CTRXITGRD
Else
 Effzo CTRXITGRD
 Grizo CTRXITGRD
Endif
Affzo CTRXITGRD
End

########################################
#To change the main code
$CHGCOD
Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return

########################################
# To change translated texts (data type AX3 & AX1) when you change the main code
$AP_CHANGE
Call CHGTEXTRA("HRCTRGRD","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("HRCTRGRD","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
Call SUPTEXTRA("HRCTRGRD","DESAXX",SUPP,[L]CODE) From ATEXTRA
Call SUPTEXTRA("HRCTRGRD","SHOAXX",SUPP,[L]CODE) From ATEXTRA
Return

########################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif

# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONHRCGD) : Endif
VCOD = CLE2
Return

###############################################################################
##  Button 'Copy'
###############################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File HRCTRGRD  [HRCGD1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".HRCTRGRD"  [HRCGD1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File HRCTRGRD [HRCGD2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".HRCTRGRD"  [HRCGD2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [HRCGD1], [HRCGD2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [HRCGD2]
 Delete [HRCGD2] Where TYP=TABLE & LEG=TABLE2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".HRCTRGRD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("HRCGD2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [HRCGD1] Where TYP=TABLE & LEG=TABLE2
  [F:HRCGD2] = [F:HRCGD1]
  Call COPTEXTRA("HRCTRGRD","DESAXX",TABLE,TABLE2) From ATEXTRA
  Call COPTEXTRA("HRCTRGRD","SHOAXX",TABLE,TABLE2) From ATEXTRA
  If dim([F:HRCGD2]UPDUSR)>0 : [F:HRCGD2]UPDUSR = GUSER : Endif
  If dim([F:HRCGD2]UPDDAT)>0 : [F:HRCGD2]UPDDAT = date$ : Endif
  Write [HRCGD2]
  If fstat
   GOK = 0 : Call FSTA("HRCGD2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

######################################################################################
## Subprog of screen HRCGD1
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
Gosub DISPLAY_HIDE
End

############################################################################################
## Action on the datatype
############################################################################################

#Selection
########################################
$SEL_TABLE

Case TABLE
 When "SELHRCGD"
  If clalev ([F:HRCGD])=0 : Local File HRCTRGRD   [HRCGD] : Endif
  OBJET="HRCGD"
  START = "[F:HRCGD]COD"
  #Filter based on code legislation
  If PARAM(1)<>""
   Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRCGD]LEG="'+PARAM(1)+'" | [F:HRCGD]LEG="")',"&") From GOBJSUB
  Endif
  #Filter based on group of company
  If PARAM(2)<>""
    #SBA - pb sel
    #OBJET=""
    DEFPAG = 1
    TIT=mess(3,10712,1)   :#Entry reason
    Gosub NOMFIC From ="WOHRCGD"
    Call  TRANSCOL("HRCGD",NBCOL,COL,TIT,FMTCOL) From OBJDIV
    If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
    If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
    If clalev([F:ACC])=0 : Local File ACCES   [ACC] : Endif
    If GUSRACS = 2
      Link [HRCGD] With
&     [AGC]AGC0=[F:HRCGD]GRP,
&     [AXX]AXX0="HRCTRGRD";"DESAXX";GLANGUE;[F:HRCGD]COD;[F:HRCGD]LEG
&     As [LNK]
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AGC]CPY="'+PARAM(2)+'" | [F:HRCGD]GRP="")',"&") From GOBJSUB
    Else
      Link [HRCGD] With
&     [AGC]AGC0=[F:HRCGD]GRP,
&     [AXX]AXX0="HRCTRGRD";"DESAXX";GLANGUE;[F:HRCGD]COD;[F:HRCGD]LEG,
&     [ACC]CODACC=GUSER;[F:HRCGD]CODACS
&     As [LNK]
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AGC]CPY="'+PARAM(2)+'" | [F:HRCGD]GRP="") & ([F:HRCGD]CODACS="" or [F:ACC]CONSUL=2) ',"&") From GOBJSUB
    Endif

    Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:HRCGD]ENAFLG=2',"&") From GOBJSUB

    NBCOL += 1 : COL(NBCOL) = "[F:HRCGD]GRP"    : COLTYP(NBCOL) =  type([F:HRCGD]GRP)    : TIT(NBCOL) =mess(237,133,1)
    Default File [LNK]
   Endif
Endcase
Return

# To do a generic Call CONTSEL... from
##################################################
Subprog CONTSEL(COD,LEG,SOC)
Value    Char    COD
Value    Char    LEG()
Value    Char    SOC()
Call CONTHRCGD(COD,LEG,SOC)
End

##################################################
Subprog CONTHRCGD(COD,LEG,SOC)
Value    Char    COD
Value    Char    LEG()
Value    Char    SOC()
Local Integer    CAS


If GFONCTION = "GESHRCGD" | COD="" : End : Endif

If clalev([F:HRCGD])=0 : Local File HRCTRGRD [HRCGD] : Endif

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

# CAS=1 => Record without Legislation (LEG = "")
# CAS=2 => Record with    Legislation (LEG <>"")

CAS = 1 : # Legislation is empty

If LEG<>""
 Read [HRCGD]HRCGD0=COD;LEG
 If fstat
  Read [HRCGD]HRCGD0=COD;""
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Read [HRCGD]HRCGD0(1)=COD
 If !fstat
  LEG = [F:HRCGD]LEG
  CAS = 2
 Endif
Endif
If fstat
 Filter [HRCGD] Where COD=COD
 Look [HRCGD]HRCGD0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  GMESSAGE = [L]COD-":"-mess(14,10712,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  GMESSAGE = [L]COD-":"-mess(23,100,1)
 Endif
 Filter [HRCGD]
 mkstat = 2 : End
Endif

If CAS=2
 Call CONTROLE("HRCGD","",LEG,COD,mkstat) From CONTOBJ
Else
 Call CONTROLE("HRCGD","","",COD,mkstat) From CONTOBJ
Endif

If [F:HRCGD]GRP<>"" & SOC<>""
  If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
  Look [AGC]AGC0 = [F:HRCGD]GRP;SOC
  If fstat
   GMESSAGE = [L]COD-":"-mess(63,127,1)-":"-[F:HRCGD]GRP : # Réservé au groupe de société
   mkstat = 2 : End
  Endif
Endif

If GUSRACS<>2
 If [F:HRCGD]CODACS <> ""
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  Read [F:ACC]CODACC = GUSER;[F:HRCGD]CODACS
  If fstat or [F:ACC]CONSUL <> 2
   GMESSAGE = [F:HRCGD]COD-":"-mess(3,104,1) :#Access denied
   mkstat = 2 : End
  Endif
 Endif
Endif

End

#Zoom
##################################################
Subprog TUNHRCGD(COD,LEG,SOC)
Variable Char    COD
Value    Char    LEG
Value    Char    SOC

Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONHRCGD)
 TOKILL = 1
Endif

If clalev([F:HRCGD])=0 : Local File HRCTRGRD [HRCGD] : Endif

# To update the HRCGD code after the tunnel order
VCOD = COD

If GNBLEG = 1
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Elsif LEG=""              : # If LEG="" then firstly we search a HRCGD record with LEG="" secondly a HRCGD record with LEG<>""
 Read [HRCGD]HRCGD0 = VCOD;LEG
 If fstat
  Read [HRCGD]HRCGD0(1)=VCOD
  If !fstat
   LEG = [F:HRCGD]LEG
  Endif
 Endif
Endif


If VCOD="" & GLECOBJ=2
  #If no code is specified, it's better to select one of the curent legislation
  Filter [HRCGD] Where LEG=[L]LEG
  Read [F:HRCGD] First
  Filter [HRCGD]
  If !fstat : VCOD=[F:HRCGD]COD : Endif
Else
  Read [HRCGD]HRCGD0 = VCOD;LEG
Endif

If fstat : LEG = "" : Endif

Call OBJET("HRCGD",LEG,VCOD) From GOBJET
COD = VCOD

If TOKILL : Kill VCOD : Endif
End

######################################################################################
## Section automatically added (screen HRCGD1) 27/03/2012 17:54:03 (OLY)
######################################################################################
Subprog C_CTRXITAUT(VALEUR)
Variable Integer VALEUR
Call GRISE_XIT(VALEUR)
End



Subprog C_CTRXITGRD(VALEUR)
Variable Char    VALEUR()
If [M]CTRXITAUT=2 & VALEUR=""
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2 : End
Endif
End

#Return the default value
##################################################
Subprog DEFHRCGD(COD,LEG,SOC)
Variable Char    COD()
Value    Char    LEG
Value    Char    SOC

If GFONCTION = "GESHRCGD" | COD<>"" : End : Endif

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

If clalev([F:HRCGD])=0  : Local File HRCTRGRD [HRCGD]  : Endif

If LEG<>""
 Filter [F:HRCGD] Where LEG=[L]LEG & DEFVAL=2 : #23/04/12 - DKA - Added [L] to make sure local var LEG is used for comparison
 Read[F:HRCGD]HRCGD0 First
 Filter [F:HRCGD]
 If !fstat
  COD=[F:HRCGD]COD
  End
 Endif
Endif

Filter [F:HRCGD] Where LEG="" & DEFVAL=2
Read[F:HRCGD]HRCGD0 First
Filter [F:HRCGD]
If !fstat
 COD=[F:HRCGD]COD
 End
Endif
End

########################################
Subprog SIMPLEREAD(COD,LEG,ERR)
Value Char COD ()
Value Char LEG ()
Variable Integer ERR         :#return the 'fstat' about the read

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

If clalev([F:HRCGD])=0  : Local File HRCTRGRD [HRCGD]  : Endif

[L]ERR=1

If [L]LEG<>""
 Read[F:HRCGD]HRCGD0=[L]COD;[L]LEG
 [L]ERR=fstat
Endif
If [L]ERR
 Read[F:HRCGD]HRCGD0=[L]COD;""
 [L]ERR=fstat
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran HRCGD1) 23/02/2016 10:09:35 (SBA)
######################################################################################
Subprog C_SSPGRD(VALEUR)
Variable Char    VALEUR()
Local Char WLIBDSN(30)
Local Integer WNUMADI
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
WNUMADI=10344 :#ATABDIV 344
Read [F:ADI]CODE=WNUMADI;VALEUR
If !fstat & [F:ADI]A3=""
 Call LECTEXTRA(WLIBDSN,"ATABTAB","COLALPDES",num$(WNUMADI),"2") From ATEXTRA
 WLIBDSN="'"+WLIBDSN+"'"
 GMESSAGE=mess(139,10761,1) : #Motif suspension non autorisé.
 GMESSAGE+=" "+func AFNC.MES2(mess(140,10761,1), WLIBDSN, num$(WNUMADI)) : #Code $1$ vide dans la table diverse $2$.
 mkstat=2 : End
Endif
End


######################################################################################

Subprog GET_FLGCREBUL_LEG (VALFLG,COD,LEG)
Variable Integer VALFLG
Value Char COD ()
Value Char LEG()

If !GPAYE : End : Endif

#Always checked by default
VALFLG=2
If clalev ([F:HRCGD])=0 : Local File HRCTRGRD   [HRCGD] : Endif
#If clalev([F:MOE])=0  : Local File MOTENT   [MOE]  : Endif
If COD="" | dim([F:HRCGD]FLGCREBUL)<0 : End : Endif

#Else depending of the entry reason
Read [F:HRCGD]HRCGD0=COD;LEG
If fstat
 Read [F:HRCGD]HRCGD0(1)=COD
Endif
If !fstat :  VALFLG=[F:HRCGD]FLGCREBUL : Endif
End


Subprog GET_FLGCREBUL (VALFLG,COD)
Variable Integer VALFLG
Value Char COD ()
Call  GET_FLGCREBUL_LEG (VALFLG,COD,GCURLEG)
End

