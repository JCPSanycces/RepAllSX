#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion du fichier EDIFRM
Raz GBIDC1, GBIDC2, GPILCOD
Call OBJET("EDM",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "SETBOUT"    : Gosub SETBOUT
 When "LIENS"      : Gosub LIENS
 When "FIN_ACTION" : Gosub FIN_ACTION
 When "EXEACT"     : Gosub EXEACT
Endcase
Return

$OUVRE
If !clalev([F:EDM2]) : Local File EDIFRM [EDM2] : Endif
Return

$LIENS
If [M]SEG<>""
 Read [EDS]EDS0 = [F:EDM]SEG;[F:EDM]LIG   :# 140 ?
 If !fstat
  [M]INTIT(nolign-1) = [F:EDS]INTIT
 Endif
Endif
If [M]ORDNUM>1
 Grizo [M]GRPCND
Else
 Actzo [M]GRPCND
Endif
Return

$SETBOUT
If [M]MES="" | find(GREP,"C","D","M")
  Call VIREBOUT(CHAINE,"U") From GOBJET   : # Bouton Duplication
Endif
# bug 37720
CHAINE += "A"   : # Bouton Supprimer
Return

$FIN_ACTION
Case BOUT
 When "U" : Gosub RAFFRAICHIR From GOBJSUB
 When "E" :
   Read [EDM2]EDM0(5) = [M]MES;[M]BAN;[M]GRP;[M]OCC;2
   If !fstat & [M]GRPCND<>[F:EDM2]GRPCND
     Gosub ENREG
   Endif
Endcase
Return

$EXEACT
Case BOUT
  When "S" : OK=0    : # pour ne pas exécuter la suppression standard
Endcase
Return

$ENREG
Trbegin [EDM2]
Update [EDM2] Where MES=[M]MES & BAN=[M]BAN & GRP=[M]GRP & OCC=[M]OCC & ORDNUM>1
&             With GRPCND=toupper([M]GRPCND)
If fstat
 Rollback : Call FSTA("EDM2") From GLOCK
Else
 Commit
Endif
Return


# Copie 1 --> 2
$TRTCOP
If [M]DOSORG=nomap
 Local File EDIFRM [EDM1]
Else
 Local File =[M]DOSORG+".EDIFRM" [EDM1]
Endif
If [M]DOSDES=nomap
 Local File EDIFRM [EDM2]
Else
 Local File =[M]DOSDES+".EDIFRM" [EDM2]
Endif

Call TEMPON("T") From GESECRAN
Call DEBTRANS From GLOCK
Gosub TR_COP
Call TEMPOFF From GESECRAN

Close Local File [EDM1], [EDM2]
Return

$TR_COP
GOK=1
Trbegin [EDM2]
Delete [EDM2] Where MES=[M:EDM1]MES & BAN=[M:EDM1]BAN
If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".EDIFRM" : Goto ROLL_TR_COP
Elsif fstat>5
  GOK = 0 : Call RSTA("EDM2",[M:EDM1]MES-[M:EDM1]BAN) From GLOCK : Goto AB_TR_COP
Endif
For [EDM1]EDM0 Where MES=[M:EDM1]MES & BAN=[M:EDM1]BAN
 [F:EDM2] = [F:EDM1]
 Write [EDM2]
 If fstat
  GOK=0 : Call RSTA("EDM2",[F:EDM1]MES-[F:EDM1]BAN-num$([F:EDM1]GRP)-num$([F:EDM1]OCC)) From GLOCK
  Break
 Endif
Next
If   GOK<0 : Goto ROLL_TR_COP
Elsif !GOK : Goto AB_TR_COP
Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif


########################################
Subprog C_GRP(VALEUR)
Variable Decimal VALEUR
Look [EDP]EDP0(3) = [M]MES;[M]BAN;VALEUR
If fstat
 # Groupe non défini dans le paramétrage
 GMESSAGE=mess(3,136,1) : mkstat=2
Endif
End

Subprog C_OCC(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 GMESSAGE = mess(7,135,1)  : # Valeur incorrecte
 mkstat=2
Endif
End

Subprog C_ORDNUM(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 GMESSAGE = mess(7,135,1)  : # Valeur incorrecte
 mkstat=2
Endif
End

Subprog C_SEG(VALEUR)
Variable Char    VALEUR()
Filter [EDP] Where MES=[M]MES & BAN=[M]BAN & GRP=[M]GRP & SEG=VALEUR
Read [EDP]EDP0 First
Filter [EDP]
# bug 37723
If fstat
 GMESSAGE=mess(2,136,1)  : # Segment non défini dans ce groupe
 mkstat=2
Endif
End

Subprog AM_SEG(VALEUR)
Variable Char    VALEUR()
## Bug 58558 : Le chargement des données associé au segment n'était pas prévu...
If find(GREP,"C","D")
 If !clalev([F:EDS2]) : Local File EDISEG [EDS2] : Endif
 Raz nolign
 [M]NBLIG = 0
 For [EDS2]EDS0 Where SEG=VALEUR
  nolign += 1
  [M] = [F:EDS2]
  [M]NBLIG += 1
 Next
 Affzo 15
Endif 
End

Subprog C_SEGOCC(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 GMESSAGE = mess(7,135,1)  : # Valeur incorrecte
 mkstat=2
Endif
End

Subprog C_FRM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & dim(VALEUR)>0 : VALEUR = toupper(VALEUR) : Endif
If VALEUR="" & find([M]STA(nolign-1),1,2)
 GMESSAGE=mess(10,123,1)   : # Zone obligatoire
 mkstat=2
Endif
End

Subprog AS_FRM(VALEUR)
Variable Char    VALEUR()
If find(left$([M]DATA(nolign-1),1),"C","S")
 mkstat=2
Endif
End

Subprog AS_NBLIG
If nolign>[M]NBLIG
 mkstat=2
Endif
End

Subprog AS_GRPCND(VALEUR)
Variable Char    VALEUR()
If [M]ORDNUM>1
 mkstat=2
Endif
End

Subprog AS_SEGCND(VALEUR)
Variable Char    VALEUR()
End

