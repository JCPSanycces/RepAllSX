#<AdxTL>@(#)1.0.0.0 $Revision$ Prorogation des règlements
#*X3-39795   MDJ  Manage ORIGIN and ORICOD fields in GL Entry
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
Local Char OFONCTION(20)
OFONCTION=GFONCTION
If GFONCTION<>"PROROG"
 GFONCTION="PROROG" : Call AUTORIS From EXEFNC
Endif
GACTION = "PROROG"
PARBOUT="1" : # 1 : client / 2 : fournisseur
Call TRAITE_CHAR(VALBOUT,PARBOUT,"FPROROG","PROROG","",1,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "DEBUT"
  Case PROG
   When "SELOBJAW"  : Gosub DSELPAY
   When Default     : Gosub DEBUT
  Endcase
 When "APRES_MODIF" : REP="M"
 When "ENR"         : Gosub ENR
 When "EXEC"        : Gosub EXEC
 When "FIN"
  Case PROG
   When "SELOBJAW"  : Gosub FSELPAY
  Endcase
Endcase
Return

#####
$INIT
#####
If !find(PARAM(1),"1","2")
 GERR=1 : GMESSAGE="PARAM(1)="+PARAM(1) : FIN=1
Endif
GBIDI1=val(PARAM(1))
Return

######
$DEBUT
######
Onerrgo CHUT From CONTROLE
If !clalev([F:TPY]) : Local File TABPAYTYP  [TPY] : Endif
If !clalev([F:PYH]) : Local File PAYMENTH   [PYH] : Endif
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
Onerrgo
If GERREUR : GERREUR=0 : Endif

Raz [M:SAI1]
Return

#####
$EXEC
#####
If GSTATUT<>GSTAENR : FIN=1 : Return : Endif
TRA=1
Return

####
$ENR
####
If [M:SAI1]NBLIG=0 : FIN=1 : Return : Endif

Onerrgo ERREUR From CONTROLE
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
If !clalev([F:PYH])  : Local File PAYMENTH   [PYH]  : Endif
If !clalev([F:PRO])  : Local File PROROG     [PRO]  : Endif
If !clalev([F:PRP])  : Local File PROROGPCE  [PRP]  : Endif
If !clalev([F:PAN])  : Local File PAYACCNUM  [PAN]  : Endif
If !clalev([F:PAM])  : Local File PAYACCNUM  [PAM]  : Endif
If !clalev([F:DAE])  : Local File GACCENTRYD [DAE]  : Endif
If !clalev([F:DAE2]) : Local File GACCENTRYD [DAE2] : Endif
If !clalev([F:HAE])  : Local File GACCENTRY  [HAE]  : Endif
If !clalev([F:DUD])  : Local File GACCDUDATE [DUD]  : Endif
If !clalev([F:GAG])  : Local File GAUTACEF   [GAG]  : Endif
If !clalev([F:GAD])  : Local File GAUTACED   [GAD]  : Endif
If !clalev([F:GAU])  : Local File GAUTACE    [GAU]  : Endif
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif
If !clalev([F:DAT])  : Local File GACCTMPD   [DAT]  : Endif
Local File PROROGPCE [TB0]
Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

Local Char    SCHAINE(10), MESSA(80), IDENT(20)
Local Char    VSAC(GLONSAC) ,VACC(GLONGAC) ,VBPR(GLONBPR) ,VCNA(GLONCNA) ,COMPTE1(GLONGAC)
Local Integer I, J, K, PRO, STAT, NBDFR
Local Integer IREF, FLGAUT
Local Integer PACCNUM(1..2),DUDLIG(1..2)
Local Decimal PAMTIPT(1..2)
Local Char    PCEAUTO(GLONGAU)
Local Char    PLGEN(GLONCOA)
Local Char    TCOMPTE(GLONGAC)(1..len(mess(0,2644,1))), TPLAN(GLONCOA)(1..len(mess(0,2644,1)))
Local Char    TSAC(GLONSAC)(1..len(mess(0,2644,1)))
Local Char    TIERS(GLONBPR)
Local Integer CHGACC
Local Char    TZONE(10)(1..10)     : # Table of the zones to be forced (Ex: ORICOD)   #*X3-39795
Local Char    TVAL(30)(1..10)      : # Table of values for zones to be forced         #*X3-39795

Call PARAM("","GAUPRORO",[L]PCEAUTO) From ADOVAL
If [L]PCEAUTO="" : [L]PCEAUTO="PRORO" : Endif

Call TEMPON("V") From GESECRAN
Call OUVRE_TRACE(mess(2,121,1)) From LECFIC : # Génération des écritures de prorogation

# Effacement du fichier PROROGPCE
Call DEBTRANS From GLOCK
Gosub TR_ANNUL
If GOK>0
 # Maj fichier PROROGPCE
 Call DEBTRANS From GLOCK
 Gosub TR1
 If GOK>0 # Génération écritures
  If clalev([M:HAE0])=0 : Local Mask GACCENT0   [HAE0] : Endif
  If clalev([M:HAE1])=0 : Local Mask GACCENT1   [HAE1] : Endif
  If clalev([M:HAE2])=0 : Local Mask GACCENT2   [HAE2] : Endif
  If clalev([M:VTL])=0  : Local Mask VENTILE    [VTL]  : Endif
  If clalev([M:VT2])=0  : Local Mask VENTILE2   [VT2]  : Endif
  If clalev([M:HAEF])=0 : Local Mask GACCENTFMT [HAEF] : Endif
  If clalev([M:HAEW])=0 : Local Mask GACCENTW   [HAEW] : Endif
  If clalev([M:SCL])=0  : Local Mask SAICURLED  [SCL]  : Endif

  Default Mask [M:SAI1]
  NBDFR = 0
  For I=0 To [M:SAI1]NBLIG-1
   Call DEBTRANS From GLOCK
   Gosub TR2
  Next I
  Close Local Mask [HAE0], [HAE1], [HAE2], [VTL], [VT2], [HAEF], [HAEW], [SCL]
  If NBDFR>0
   Call ECR_TRACE(" \"+num$(NBDFR)-mess(28,117,1),0) From GESECRAN
   # NBDFR règlement(s) traité(s)
  Endif
 Endif
Endif

Call FERME_TRACE From LECFIC
Call TEMPOFF From GESECRAN

If NBDFR=0
 GERR=2 : GMESSAGE=mess(2,117,1)
 # Aucun règlement traité
Endif
FIN=1
Return

######################## Effacement du fichier PROROGPCE #############################

$TR_ANNUL
GOK=1
Trbegin [PRP]
 Delete [PRP] Where 1=1
 If fstat=1
  GOK = -1 : GLOCK = "PROROGPCE"-""
 Elsif fstat>5
  GOK = 0 : Call RSTA("PRP","") From GLOCK
 Endif
 If   GOK<0 : Goto ROLL_TR_ANNUL
 Elsif !GOK : Goto AB_TR_ANNUL
 Endif
Commit
Return

$AB_TR_ANNUL
Rollback
Return

$ROLL_TR_ANNUL
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANNUL : Endif
Return

######################## Maj fichier PROROGPCE #############################

$TR1
GOK=1 : MESSA=""
Trbegin [PYH], [PRP]
 For I=0 To [M:SAI1]NBLIG-1
  Read [PYH]PYH0=[M:SAI1]NUM(I)
  If [F:PYH]STAFLG(2)=2 : # Etape 3 Mise en portefeuille
   Call SETMAINREF([F:PYH]CPY,GTYPGEN,GTYPANA) From CPTDIV
   GSOCIETE = [F:PYH]CPY
   Gosub MAJ_PROROGPCE
  Endif
 Next I
 If GOK <0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$MAJ_PROROGPCE
# Mise à jour PROROGPCE si changement de compte EAR ou EAP pour la prorogation
# Etape1 : Recherche du compte à solder
# Si l'écriture de mise en portefeuille a déjà été prorogée (PRO=1), c'est la dernière
# écriture de prorogation qu'il faut solder (celle dont le accnum n'existe pas dans un GRP)
# Sinon, c'est l'écriture de Mise en portefeuille qu'il faut solder
PRO = 0
For [PAN]PAN0 Where TYPNUM=3 & NUM=[F:PYH]NUM & ACCSTA=3 & STA=4 & CPTBAN=2 & RVSACCNUM=0
 Filter [PAM] Where TYPNUM=3 & NUM=[F:PYH]NUM & ACCSTA=3 & STA=4 &
&                   GRP="N"+num$([F:PAN]ACCNUM) & RVSACCNUM=0
 Read [PAM]PAN0 First
 If fstat : # C'est la dernière écriture de prorogation
  PRO = 1
  Read [DAE]DAE2=[F:PAN]ACCNUM
  If fstat
   Read [DAT]DAT1=[F:PAN]ACCNUM
   If fstat=0 : # Règlement XXXXX : TYP NUM En cours de validation
    Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":"-[F:DAT]TYP-[F:DAT]NUM-mess(128,117,1),1) From GESECRAN
   Else       : # Règlement XXXXX : Pièce inexistante (ACCNUM)
    Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":"-mess(28,107,1)-"("+num$([F:PAN]ACCNUM)+")",1) From GESECRAN
   Endif
   GOK = 0  : Break
  Endif
  Read [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM
  If fstat : GOK = 0 : Break : Endif
  Gosub ECR_PROROGPCE
  If GOK <1 : Break : Endif
 Endif
Next : # [PAN]
Filter [PAM]
If !PRO
 For [PAN]PAN0 Where TYPNUM=3 & NUM=[F:PYH]NUM & ACCSTA=3 & STA=3 & CPTBAN=2 & RVSACCNUM=0
  Read [DAE]DAE2=[F:PAN]ACCNUM
  If fstat
   Read [DAT]DAT1=[F:PAN]ACCNUM
   If fstat=0 : # Règlement XXXXX : TYP NUM En cours de validation
    Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":"-[F:DAT]TYP-[F:DAT]NUM-mess(128,117,1),1) From GESECRAN
   Else       : # Règlement XXXXX : Pièce inexistante (ACCNUM)
    Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":"-mess(28,107,1)-"("+num$([F:PAN]ACCNUM)+")",1) From GESECRAN
   Endif
   GOK = 0 : Break
  Endif
  Read [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM
  If fstat : GOK = 0 : Break : Endif
  Gosub ECR_PROROGPCE
  If GOK<1 : Break : Endif
 Next : # [PAN]
Endif
Return

$ECR_PROROGPCE
Raz [F:PRP]
[F:PRP]ACCNUM = [F:DAE]ACCNUM
Assign "[F:PRP]TACCNUM("+num$([F:DAE]LEDTYP-1)+")" With [F:DAE]ACCNUM
Assign "[F:PRP]AMTLED("+num$([F:DAE]LEDTYP-1)+")" With[F:DAE]AMTLED
Assign "[F:PRP]AMTCUR("+num$([F:DAE]LEDTYP-1)+")" With [F:DAE]AMTCUR
Assign "[F:PRP]ACC("+num$([F:DAE]LEDTYP-1)+")" With [F:DAE]ACC
Assign "[F:PRP]COA("+num$([F:DAE]LEDTYP-1)+")" With [F:DAE]COA
[F:PRP]AMTLED = [F:DAE]AMTLED
[F:PRP]AMTCUR = [F:DAE]AMTCUR
[F:PRP]JOU    = [F:HAE]JOU
[F:PRP]FCYLIN = [F:DAE]FCYLIN
[F:PRP]DES    = [M:SAI1]DES(I)
[F:PRP]DUDDAT = [M:SAI1]DUDDAT1(I)
[F:PRP]CUR    = [M:SAI1]CUR(I)
[F:PRP]ACCDAT = [M:SAI1]ACCDAT1
[F:PRP]FCY    = [F:HAE]FCY
[F:PRP]NUM    = [F:PYH]NUM
[F:PRP]NUM2   = [F:PYH]NUM
[F:PRP]CLIFOU = GBIDI1
[F:PRP]BPRC   = [F:DAE]BPR
For [DAE2]DAE7(4) Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & IDTLIN=[F:DAE]IDTLIN & LEDTYP<>GTYPGEN
 Call LEDTYPAUT([F:DAE2]CPY,[F:DAE2]LEDTYP,[L]FLGAUT) From CPTDIV
 If [L]FLGAUT<>2
  Assign "[F:PRP]TACCNUM("+num$([F:DAE2]LEDTYP-1)+")" With [F:DAE2]ACCNUM
  Assign "[F:PRP]AMTLED("+num$([F:DAE2]LEDTYP-1)+")" With[F:DAE2]AMTLED
  Assign "[F:PRP]AMTCUR("+num$([F:DAE2]LEDTYP-1)+")" With [F:DAE2]AMTCUR
  Assign "[F:PRP]ACC("+num$([F:DAE2]LEDTYP-1)+")" With [F:DAE2]ACC
  Assign "[F:PRP]COA("+num$([F:DAE2]LEDTYP-1)+")" With [F:DAE2]COA
 Endif
Next
# Etape 2 : Recherche du compte à mouvementer pour la prorogation
# Si le compte EAR à solder est différent du nouveau compte à mouvementer -> maj PROROGPCE
# Recherche du nouveau compte EAR. La pièce auto ne doit avoir qu'une écriture Débit
SCHAINE = num$(GBIDI1)
Read [GAU]GAU0=[L]PCEAUTO
For [GAD]GAD0 Where COD=[F:GAU]COD
 If instr(1,[F:GAD]FORCND,SCHAINE)
  Read [GAG]GAG0=[F:GAU]COD;[F:GAD]LINNUM;"SNS"
  # BY 02/01/01 Pour un fournisseur, on recherche le crédit
  If (GBIDI1=1 & val([F:GAG]FORCLC)=1) or (GBIDI1=2 & val([F:GAG]FORCLC)=-1)
   Read [GAG]GAG0=[F:GAU]COD;[F:GAD]LINNUM;"ACC"+num$(GTYPGEN)
   [F:TB0] = [F:PRP]
   Raz TPLAN, TCOMPTE, TSAC, TIERS
   Call CPTNAT([F:GAD]NBRLED,[F:GAD]LEDTYP,TPLAN,TCOMPTE,TSAC,TIERS,1,[F:PYH]NUM,[M:SAI1]DUDDAT1(I),STAT,MESSA) From TRTPCE
   If STAT
    Gosub MESSAGE From CPTAUTO
    # Règlement XXXXXXX
    Call ECR_TRACE(mess(27,117,1)-[F:PRP]NUM-":"-MESSA,1) From GESECRAN
    GOK = 0 : Break
   Endif
   CHGACC = 0
   For IREF=1 To [F:GAD]NBRLED
    If TCOMPTE(IREF)<>evalue("[F:PRP]ACC("+num$([F:GAD]LEDTYP(IREF-1)-1)+")")
     CHGACC = 1
     Call LECTURE("GAC",TCOMPTE(IREF),TPLAN(IREF)) From CONTOBJ
     If [F:GAC]CUR<>"" & [M:SAI1]CUR(I)<>[F:GAC]CUR
      # Règlement XXX : Devise du compte de trésorerie incompatible
      Call ECR_TRACE(mess(27,117,1)-[F:PRP]NUM-":"-mess(12,121,1),1) From GESECRAN
      GOK = 0 : Break 2
     Endif
     If [F:GAC]SAC=2 : # C'est un collectif
      [F:PRP]BPRD = [F:DAE]BPR
     Endif
    Endif
   Next
   If CHGACC
    Write [PRP]
    If fstat
     GOK = 0 : Call FSTA("PRP") From GLOCK : Break
    Endif
   Endif
  Endif
 Endif
Next : # [GAD]
Return

################################## Génération écritures ###########################

$TR2
# Exemple : Echéance sur Janvier prorogée à Février
# Crédit du compte EAR 41301 par le débit du 41302
# Lettrage du compte 41301
GOK=1
Trbegin [PYH], [HAE], [DUD], [PRO], [PRP], [PAN]
 # Mise à jour de DUDDAT dans PAYMENTH
 Readlock [PYH]PYH0=[M:SAI1]NUM(I)
 If fstat = 1
  GOK = -1 : GLOCK = "$PAYMENTH"-[M:SAI1]NUM(I) : Goto ROLL_TR2
 Elsif fstat
  GOK = 0 : Call RSTA("PYH",[M:SAI1]NUM(I)) From GLOCK : Goto AB_TR2
 Endif
 Call SETMAINREF([F:PYH]CPY,GTYPGEN,GTYPANA) From CPTDIV
 GSOCIETE = [F:PYH]CPY
 [F:PYH]DUDDAT = [M:SAI1]DUDDAT1(I)

 ## CP 07/08/03 Demande 19029
 GPOINT = "MAJ" : Gosub ENTREE From EXEFNC

 Rewrite [PYH]
 If fstat
  GOK = 0 : Call FSTA("PYH") From GLOCK : Goto AB_TR2
 Endif

 If [F:PYH]STAFLG(2)=2 : #Etape 3 Mise en portefeuille
  Gosub MAJ_GACCENTRY
  If GOK <0 : Goto ROLL_TR2 : Elsif !GOK : Goto AB_TR2 : Endif
  Gosub MAJ_GACCDUDAT
  If GOK <0 : Goto ROLL_TR2 : Elsif !GOK : Goto AB_TR2 : Endif
 Endif

 Call LECPLAN(GSOCIETE,GTYPGEN,PLGEN) From CPTDIV

 Gosub MAJ_PROROG
 If GOK <0 : Goto ROLL_TR2 : Elsif !GOK : Goto AB_TR2 : Endif

 For [PRP]PRP1(2) Where NUM=[M:SAI1]NUM(I)
  IDENT = num$([F:PRP]ACCNUM)
  TZONE(5)= "ORIGIN" : TVAL(5)= "2"        :#Automatic loading  #*X3-39795
  TZONE(6)= "ORICOD" : TVAL(6)= [L]PCEAUTO                      #*X3-39795
  #*X3-39795 Call VALPCE([L]PCEAUTO,IDENT,STAT,MESSA) From CPTAUTO
  Call VALPCE3([L]PCEAUTO,IDENT,STAT,MESSA,TZONE,TVAL) From CPTAUTO

  If STAT
   Call ECR_TRACE(mess(27,117,1)-[F:PRP]NUM-":"-MESSA,1) From GESECRAN
   GOK = 0 : Break
  Endif
  ## Lettrage compte EAR...
  J = 0
  For IREF=1 To dim([F:PRP]ACC)
   K = 0
   Call LEDTYPAUT([F:PYH]CPY,IREF,[L]FLGAUT) From CPTDIV
   If FLGAUT <> 2 & [F:PRP]ACC(IREF-1)<>""
    For I=0 To [M:HAEW]NB-1
     If !K & [M:HAEW]LEDTYP(I)=IREF & [F:PRP]ACC(IREF-1)=[M:HAEW]ACC(I)
      K = I+1
     Endif
     If IREF=GTYPGEN & GBIDI1=1 & [M:HAEW]CDT(I)=0 & !J : # Prorogation client => Débit nouveau compte EAR
      J = I+1
     Elsif IREF = GTYPGEN & GBIDI1=2 & [M:HAEW]DEB(I)=0 & !J : # Prorogation fournisseur => Crédit nouveau compre EAP
      J = I+1
     Endif
    Next
    If K=0
     # Problème d'écriture non générée
     Call ECR_TRACE(mess(27,117,1)-[F:PRP]NUM-":"-mess(36,121,1)-"("+mess(IREF,2644,1)+")",1) From GESECRAN
     GOK = 0 : Break 2
    Endif
    ## lettrage du référentiel IREF
    Raz PACCNUM, PAMTIPT, DUDLIG
    PACCNUM(1) = [M:HAEW]ACCNUM(K-1) : # N°Ecriture générée sur le n°compte EAR soldé
    PAMTIPT(1) = [M:HAEW]CDT(K-1)
    PACCNUM(2) = [F:PRP]TACCNUM(IREF-1) : # N°Ecriture EAR qui va être lettrée
    PAMTIPT(2) = [F:PRP]AMTCUR(IREF-1)
    DUDLIG(1)  = 1
    DUDLIG(2)  = 1
    Call LECTURE("GAC",[M:HAEW]ACC(K-1),[M:HAEW]COA(K-1)) From CONTOBJ
    If [F:GAC]MTC = 2 : # Compte lettrable
     Call LETDIF(2,PACCNUM,DUDLIG,PAMTIPT,2) From CPTLET
    Endif
    If IREF=GTYPGEN
     Gosub MAJ_PAYACCNUM
     If GOK<1 : Break 2 : Endif
     Gosub MAJ_PROROG2
     If GOK<1 : Break 2 : Endif
    Endif
   Endif
  Next
  # Réglement xxxxxx : Création pièce TYP NUM
  Call ECR_TRACE(mess(27,117,1)- [F:PRP]NUM-":"-mess(40,107,1)-[M:HAE0]TYP-MESSA,0) From GESECRAN
 Next : # [PRP]
 If GOK=0 : Goto AB_TR2 : Endif
Commit
Call ECR_TRACE(mess(27,117,1)-[M:SAI1]NUM(I)-":"-mess(38,121,1),0) From GESECRAN
NBDFR +=1
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$AB_TR2
Rollback
Return

$MAJ_GACCENTRY
# Mise à jour DUDDAT dans GACCENTRY.
# Recherche des écritures comptables de mise en portefeuille dans PAYACCNUM.
For [PAN]PAN0 Where TYPNUM=3 & NUM=[F:PYH]NUM & ACCSTA=3 & STA=3 & RVSACCNUM=0
 Read [DAE]DAE2=[F:PAN]ACCNUM
 If fstat
  Read [DAT]DAT1=[F:PAN]ACCNUM
  If fstat=0 : # Règlement XXXXX : TYP NUM En cours de validation
   Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":"-[F:DAT]TYP-[F:DAT]NUM-mess(128,117,1),1) From GESECRAN
  Else       : # Règlement XXXXX : Pièce inexistante (ACCNUM)
   Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":"-mess(28,107,1)-"("+num$([F:PAN]ACCNUM)+")",1) From GESECRAN
  Endif
  GOK = 0 : Break
 Endif
 Readlock [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM
 GCLE = [F:DAE]TYP-num$([F:DAE]NUM)
 If fstat = 1
  GOK = -1 : GLOCK = "$GACCENTRY"-GCLE : Break
 Elsif fstat
  GOK = 0 : Call RSTA("HAE",GCLE) From GLOCK : Break
 Endif
 [F:HAE]DUDDAT = [M:SAI1]DUDDAT1(I)
 Rewrite [HAE]
 If fstat
  GOK = 0 : Call FSTA("HAE") From GLOCK : Break
 Endif
Next : # [PAN]
Return

$MAJ_GACCDUDAT
# Mise à jour GACCDUDATE
For [PAN]PAN0 Where TYPNUM=3 & NUM=[F:PYH]NUM & ACCSTA=3 & STA=3
&                 & find(TYPVCR,"A","D") & RVSACCNUM=0
 Read [DAE]DAE2=[F:PAN]ACCNUM
 If fstat
  Read [DAT]DAT1=[F:PAN]ACCNUM
  If fstat=0 : # Règlement XXXXX : TYP NUM En cours de validation
   Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":"-[F:DAT]TYP-[F:DAT]NUM-mess(128,117,1),1) From GESECRAN
  Else       : # Règlement XXXXX : Pièce inexistante (ACCNUM)
   Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":"-mess(28,107,1)-"("+num$([F:PAN]ACCNUM)+")",1) From GESECRAN
  Endif
  GOK = 0 : Break
 Endif
 For [DUD]DUD0 Where TYP=[F:DAE]TYP and NUM=[F:DAE]NUM
  Readlock [DUD]
  GCLE = [F:DUD]TYP-[F:DUD]NUM-num$([F:DUD]LIG)-num$([F:DUD]DUDLIG)
  If fstat = 1
   GOK = -1 : GLOCK = "$GACCDUDATE"-GCLE : Break(2)
  Elsif fstat
   GOK = 0 : Call RSTA("DUD",GCLE) From GLOCK : Break(2)
  Endif
  [F:DUD]DUDDAT = [M:SAI1]DUDDAT1(I)
  Rewrite [DUD]
  If fstat
   GOK = 0 : Call FSTA("DUD") From GLOCK : Break(2)
  Endif
  Call HISTOECH("DUD",1,[F:DAE]ACCDAT)From MODECHE
 Next : # [DUD]
Next : # [PAN]
Return

$MAJ_PROROG
# Mise à jour PROROG
Read [PRO]PRO0=[M:SAI1]NUM(I)
Raz [F:PRO]
If fstat : # OLDDUDDAT est mis à jour pour la première prorogation du règlement
 [F:PRO]OLDDUDDAT = [M:SAI1]DUDDAT0(I)
Endif
[F:PRO]NUM       = [M:SAI1]NUM(I)
[F:PRO]BPR       = [M:SAI1]BPR(I)
[F:PRO]COA       = [L]PLGEN
[F:PRO]ACCDAT    = [M:SAI1]ACCDAT1
[F:PRO]CUR       = [M:SAI1]CUR(I)
[F:PRO]AMTCUR    = [M:SAI1]AMTCUR(I)
[F:PRO]NEWDUDDAT = [M:SAI1]DUDDAT1(I)
[F:PRO]CREDAT    = date$
[F:PRO]CREUSR    = GUSER
[F:PRO]TYP       = GBIDI1
J=0
For [PRP]PRP1 Where NUM=[M:SAI1]NUM(I)
 [F:PRO]ACCNUM(J) = [F:PRP]ACCNUM
 J +=1
Next : # [PRP]
Write [PRO]
If fstat
 GOK = 0 : Call FSTA("PRO") From GLOCK : Return
Endif
Return

$MAJ_PROROG2
# Si la traite est prorogée puis mise en portef puis prorogée, elle a des enreg
# dans prorog où accnum=0, cause de la 1ère prorogation.
# Pour éviter que le readlock first ne les sélectionne, on met accnum(0)<>0
Filter [PRO] Where NUM=[F:PRP]NUM & ACCNUM(0)<>0
Readlock [PRO]PRO0 First
Filter [PRO]
If (fstat<=2 & !find([F:PRP]ACCNUM,[F:PRO]ACCNUM)) | fstat >2
 GOK = 0 : Call FSTA("PRO") From GLOCK : Return
Elsif fstat=0
 K = find([F:PRP]ACCNUM,[F:PRO]ACCNUM(0..9))
 [F:PRO]ACCNUM(K-1) = [M:HAEW]ACCNUM(J-1)
 Rewrite [PRO]
 If fstat
  GOK = 0 : Call FSTA("PRO") From GLOCK : Return
 Endif
Endif
Return

$MAJ_PAYACCNUM
# Création dans PAYACCNUM de l'enreg de prorogation du règlement
Raz [F:PAN]
[F:PAN]TYPNUM    = 3
[F:PAN]NUM       = [F:PRP]NUM
[F:PAN]STA       = 4
[F:PAN]ACCSTA    = 3
[F:PAN]TYPVCR    = "4"
[F:PAN]CPTBAN    = 2
[F:PAN]ACCNUM    = [M:HAEW]ACCNUM(J-1) : # ACCNUM de l'écriture générée sur nouveau compte EAR
[F:PAN]RVSACCNUM = 0
[F:PAN]GRP       = "N"+num$([F:PRP]ACCNUM)
Write [PAN]
If fstat
 GOK = 0 : Call FSTA("PAN") From GLOCK : Return
Endif
Return

##################################
## Etiquettes de l'écran PROROG ##
##################################

Subprog C_NUM(VALEUR)
Variable Char    VALEUR()
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
If !clalev([F:PYH]) : Local File PAYMENTH  [PYH] : Endif
Read [PYH]PYH0 = VALEUR
If fstat
 GMESSAGE = mess(137,117,1) : # Règlement inexistant
 mkstat = 2
 End
Elsif find(VALEUR,[M:SAI1]NUM(0..indice-1),"$$$$$$$$$$$",[M:SAI1]NUM(indice+1..[M:SAI1]NBLIG-1))
 GMESSAGE = mess(107,117,1) : # Numéro de règlement déjà saisi
 mkstat = 2
 End
Elsif [F:PYH]STAFLG(10) = 2
 GMESSAGE = mess(125,117,1) : # Règlement déjà impayé
 mkstat = 2
 End
Elsif [F:PYH]STAFLG(8)=2
 GMESSAGE = mess(5,121,1)   : # Règlement remis en banque
 mkstat = 2
 End
Elsif [F:PYH]STAFLG(7)=2
 GMESSAGE = mess(4,121,1)   : # Règlement remis sur compte intermédiaire
 mkstat = 2
 End
Elsif [F:PYH]STAFLG(6)=2
 GMESSAGE = mess(9,121,1)   : # Règlement domicilié
 mkstat = 2
 End
Elsif [F:PYH]STAFLG(5)=2
 GMESSAGE = mess(10,121,1)   : # Règlement sur fichier
 mkstat = 2
 End
Elsif [F:PYH]STAFLG(4)=2
 GMESSAGE = mess(11,121,1)   : # Règlement sur bordereau de remise
 mkstat = 2
 End
Elsif [F:PYH]BPRTYP<>GBIDI1 & GBIDI1=1
 GMESSAGE = mess(67,117,1) : # Ce n'est pas un client
 mkstat = 2
 End
Elsif [F:PYH]BPRTYP<>GBIDI1 & GBIDI1=2
 GMESSAGE = mess(68,117,1) : # Ce n'est pas un fournisseur
 mkstat = 2
 End
Else
 Call LECTURE("CPY",[F:PYH]CPY,"") From CONTOBJ
 Call LEC_TPY_LEG([F:CPY]LEG,[F:PYH]PAYTYP) From CPTLEC
 If [F:TPY]ENAFLG<>2
  Gosub TIT From WOTPY
  GMESSAGE = TIT-"\"+[F:PYH]PAYTYP-":"-mess(2,126,1) : # Fiche inactive
  mkstat=2
  End
 Elsif dim([F:TPY]ACS)>0
  Call CONTEXE([F:TPY]ACS) From CPTSUB
  If mkstat : End : Endif
 Endif
 If [F:TPY]DACDUDDAT=3
  # Date d'échéance non gérée pour le type de règlement
  GMESSAGE = mess(142,117,1)+" "+[F:PYH]PAYTYP
  mkstat = 2
  End
 Endif
 Call SETMAINREF([F:PYH]CPY,GTYPGEN,GTYPANA) From CPTDIV
 Call CONTPER([M:SAI1]ACCDAT1,GTYPGEN,[F:PYH]FCY) From CPTSUB
 If mkstat = 2 : End : Endif
Endif
If [F:PYH]BPR=""
 [M:SAI1]BPR(nolign-1)    = [F:PYH]ACC
Else
 [M:SAI1]BPR(nolign-1)    = [F:PYH]BPR
Endif
[M:SAI1]ACCDAT0(nolign-1) = [F:PYH]ACCDAT
[M:SAI1]AMTCUR(nolign-1)  = [F:PYH]AMTCUR
[M:SAI1]CUR(nolign-1)     = [F:PYH]CUR
[M:SAI1]DUDDAT0(nolign-1) = [F:PYH]DUDDAT
[M:SAI1]DES(nolign-1)     = [F:PYH]DES
End

########
$DSELPAY
########
[L]MEMO="" : # Pas de mémo

## Préchargement du tableau de sélection avancée
If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif

NBSEL = 0 : NBTRI = 0

# Type de règlement
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]PAYTYP" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]PAYTYP"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Tiers
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]BPR" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]BPR"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Banque
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]BAN" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]BAN"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Site
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]FCY" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]FCY"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Devise
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]CUR" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]CUR"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Montant
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]AMTCUR" : Gosub TEX_PAY
SELTYP(NBSEL) = 4
SELFMT(NBSEL) = "Nf:15F"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]AMTCUR"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Date d'échéance
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]DUDDAT" : Gosub TEX_PAY
SELTYP(NBSEL) = 8
SELFMT(NBSEL) = "Df:"+GFMDAT
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]DUDDAT"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Référence
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]REF" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]REF"
TRILIB(NBTRI) = SELLIB(NBSEL)

# Lot de saisie
NBSEL += 1
SELZON(NBSEL) = "[F:PYH]PAYLOT" : Gosub TEX_PAY
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "Kf:15X"
NBTRI += 1
TRIZON(NBTRI) = "[F:PYH]PAYLOT"
TRILIB(NBTRI) = SELLIB(NBSEL)

If dim([L]SELEXP)>0 : Raz [L]SELEXP : Endif

## Filtre supplémentaire obligatoire sur le fichier PAYMENTH

If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
Local Char FILTPYH(255)(1..4), SUBCRIT(255)
Local Integer IFILT
Raz FILTPYH, IFILT
Call ADDCRIT(FILTPYH, IFILT,"BPRTYP","BPRTYP="+num$(GBIDI1)," & ") From GOBJSUB
Call ADDCRIT(FILTPYH, IFILT,"STAFLG",'!find(2,STAFLG(4..8),STAFLG(10))'," & ") From GOBJSUB
[L]SUBCRIT=""
For [TPY]TPY0 Where DACDUDDAT<>3 & ENAFLG=2
 If dim([F:TPY]ACS)>0
  Call CONTEXE([F:TPY]ACS) From CPTSUB
  If !mkstat : OK=1 : Else OK=0 : GMESSAGE="" : mkstat=0 : Endif
 Else OK=1
 Endif
 If OK=1
  If [L]SUBCRIT="" :
      [L]SUBCRIT="find(PAYTYP"
      Call ADDCRIT(FILTPYH, IFILT,"PAYTYP",SUBCRIT,"&") From GOBJSUB
  Endif
  Call ADDCRIT(FILTPYH, IFILT,"PAYTYP",'"'+[F:TPY]PAYTYP+'"',",") From GOBJSUB
 Endif
Next : # [TPY]
If [L]SUBCRIT<>""
  Call ADDCRIT(FILTPYH, IFILT,"PAYTYP",')',"") From GOBJSUB
Endif
Filter [PYH] Where evalue([L]FILTPYH)
Return

$TEX_PAY
J=instr(1,SELZON(NBSEL),"]")
If !J : SELLIB(NBSEL)=SELZON(NBSEL) : Else SELLIB(NBSEL)=right$(SELZON(NBSEL),J+1) : Endif
For I=0 To 2
 Read [AMZ]CODE="PAY"+num$(I);SELLIB(NBSEL)
 If fstat=0
  Call TEXTE([F:AMZ]INTIT,SELLIB(NBSEL)) From OBJDIV
  Break
 Endif
Next I
Return

########
$FSELPAY
########
Filter [PYH]
Return

