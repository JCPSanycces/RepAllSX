#<AdxTL>@(#)1.0.0.0 $Revision$
Local File ITCNAT [ICN]
Local File ITCMAT [ICC]
Local File ITCWST [ICW]
Trbegin [ICN]
#Delete [ICN] Where ITMREF="CD100" & STOFCY="PAR" & ITCSEQ=6
#Delete [ICC] Where ITMREF="CD100" & STOFCY="PAR" & ITCSEQ=6
#Delete [ICW] Where ITMREF="CD100" & STOFCY="PAR" & ITCSEQ=6
Commit

End

#####################################################
$OUVRE
Local Integer IFLITSUP
Local Integer LFIYNUM
Local Integer SAV_GCSTTYP

If !clalev([F:STJ]) : Local File STOJOU [STJ] : Endif

Local Mask SAIDECPRI [ITCD]
Local Mask SAIDECPRI [ICLD]
If dim(GSAIDECPRI)<=0
    Global Integer GSAIDECPRI    # Passée en paramètre AFFMSK de l'action SAIDECPRI. Détermine ce qui peut être saisi
Endif

If dim(GCSTTYP)<=0
    Global Integer GCSTTYP
Else
    SAV_GCSTTYP = GCSTTYP
Endif
GCSTTYP = find(GFONCTION,"GESICD","GESICA","GESICB","GESICS")

If find(GCSTTYP,2,4)
    Local Date LDATREF
Endif
Return

#####################################################
$FILTRE
Raz IFILTSUP
Default File [ITC]
Call ADDCRIT(FILTSUP,IFILTSUP,"","CSTTYP="+num$(GCSTTYP),"&") From GOBJSUB
Call ADDCRIT(FILTSUP,IFILTSUP,"","UID=0","&") From GOBJSUB
If GFLTITM <> ""
    Call ADDCRIT(FILTSUP,IFILTSUP,"","ITMREF=GFLTITM","&") From GOBJSUB
Endif
If GFLTFCY <> ""
    Call ADDCRIT(FILTSUP,IFILTSUP,"","STOFCY=GFLTFCY","&") From GOBJSUB
Endif
If clalev([M:HIC2]) & dim(GFLTDAT)>0 & GFLTDAT>[0/0/0]
    Call ADDCRIT(FILTSUP,IFILTSUP,"","ITMREF=[M:HIC0]ITMREF","&") From GOBJSUB
    Call ADDCRIT(FILTSUP,IFILTSUP,"","STOFCY=[M:HIC0]STOFCY","&") From GOBJSUB
#    Filter [ITC] Where ITMREF = [M:HIC0]ITMREF
#&                    & STOFCY = [M:HIC0]STOFCY
#&                    & UID    = 0
#&                    & CSTTYP = GCSTTYP
#&                    & ITCSTRDAT<=GFLTDAT
#    Read [ITC] First
#    [M]DATREF = GFLTDAT
#    Filter [ITC]
Endif
Return

# Chargement du 1er coût
$AFFMASK
If GFLTITM <> "" | GFLTFCY<>""
    Raz IFILTSUP
    Call ADDCRIT(FILTSUP,IFILTSUP,"","CSTTYP="+num$(GCSTTYP),"&") From GOBJSUB
    Call ADDCRIT(FILTSUP,IFILTSUP,"","UID=0","&") From GOBJSUB
    If GFLTITM <> ""
        Call ADDCRIT(FILTSUP,IFILTSUP,"","ITMREF=GFLTITM","&") From GOBJSUB
    Endif
    If GFLTFCY <> ""
        Call ADDCRIT(FILTSUP,IFILTSUP,"","STOFCY=GFLTFCY","&") From GOBJSUB
    Endif
    CLE1 = [F:ITC]ITMREF
    CLE2 = [F:ITC]STOFCY
    CLE3 = num$([F:ITC]CSTTYP)
    CLE4 = num$([F:ITC]ITCSEQ)
    CLE5 = "0"

    Filter [ITC] Where evalue(FILTSUP)
&                    & ITCSTRDAT<=date$
&                    & ITCENDDAT>=date$
    Read [ITC]ITC0 First
    Filter [ITC]
    If fstat
        Filter [ITC] Where evalue(FILTSUP)
&                        & ITCSTRDAT<=date$
        Read [ITC]ITC0 First
        Filter [ITC]
    Endif
    If !fstat
        CLE1 = [F:ITC]ITMREF
        CLE2(0) = [F:ITC]STOFCY
        CLE2(1) = num$([F:ITC]CSTTYP)
        CLE2(2) = num$([F:ITC]ITCSEQ)
        CLE2(3) = "0"
    Endif
Endif
Return

#####################################################
$DROIT
    # Issue 84192 - 2012-08-30 by CCC : Les arrondis ne sont pas faits par défaut au moment du calcul
    #                                   => les faire pour l'affichage
    If dim(GRNDVAL)<=0 : Global Decimal GRNDVAL : Endif
    Call INIRNDVAL("ITMCOST","CSTTOT") From STKVALECR
    Call ARRITC(GRNDVAL) From TRTCOST
Return

#####################################################
$LIENS

Read [ITM]ITM0=[F:ITC]ITMREF
Read [ITG]ITG1=[F:ITM]TCLCOD;[F:ITC]STOFCY
If fstat
    Read [ITG]ITG1=[F:ITM]TCLCOD;""
Endif
Read [ITF]ITF0=[F:ITC]ITMREF;[F:ITC]STOFCY
If clalev([M:ICD0]) : Default Mask [ICD0] : Endif
If clalev([M:ICA0]) : Default Mask [ICA0] : Endif
[M] = [F:ITM]
# Issue 80346 - 2012-02-23 by CCC
#[M] = [F:ITF]
Gosub LOAD_ITF

Affzo [M]

Actzo [M] #MIHAL
Actzo [M:ICD1]
Actzo [M:ICD2]
Actzo [M:ICD3]

If dim(LDATREF)>0
    [M]DATREF=LDATREF
Endif
[M]TCLCOD = [F:ITM]TCLCOD : Affzo [M]TCLCOD
[M:ICD1]STU = [F:ITM]STU
[M:ICD2]STU = [F:ITM]STU
[M:ICD2]MATTOTLEV = sum([M:ICD2]MATLEVCST)
[M:ICD2]MACTOTLEV = sum([M:ICD2]MACLEVCST)
[M:ICD2]LABTOTLEV = sum([M:ICD2]LABLEVCST)
[M:ICD2]SCOTOTLEV = sum([M:ICD2]SCOLEVCST)
[M:ICD2]OVETOTLEV = sum([M:ICD2]OVEMATLEV,[M:ICD2]OVEMACLEV,[M:ICD2]OVELABLEV,[M:ICD2]OVESCOLEV)

Gosub CHARGE_GRAPH From SUBICDG

GFCY=[F:ITC]STOFCY
Call GETCPY(GFCY,"",0,"") From TRTX3CPT

Call GETDEV([M]STOFCY) From DEVSUB  # charge GLOCALDEV
[M:ICD1]CUR = GLOCALDEV
[M:ICD2]CUR = GLOCALDEV

Raz [M:ITCD],[M:ICLD]
# Chargement du masque de travail ITCD
[M:ITCD] = [F:ITC] :  # écran détail
[M:ITCD]QTY = [F:ITC]CLCQTY
[M:ITCD]UOM = [F:ITM]STU
[M:ITCD]PRI = [F:ITC]VLTTOT
[M:ITCD]CUR = GLOCALDEV

[M:ICLD] = [F:ITC]
[M:ICLD]QTY = [F:ITC]CLCQTY
[M:ICLD]UOM = [F:ITM]STU
[M:ICLD]PRI = [F:ITC]VLTTOT
[M:ICLD]CUR = GLOCALDEV
Call LEV2MSK("ICLD","ITC")


Link [ICN] With [ONA]ONA0=[F:ICN]OVENAT
&          As [LNK]
&          Where ITMREF = [F:ITC]ITMREF
&              & STOFCY = [F:ITC]STOFCY
&              & CSTTYP = [F:ITC]CSTTYP
&              & ITCSEQ = [F:ITC]ITCSEQ
&              & UID    = [F:ITC]UID
For [LNK]
    For I=1 To dim([F:ICN]NATAMTLEV)-1
        If [F:ICN]NATAMTLEV(I)>0
            [M:ICLD]OVENAT([M:ICLD]NBONA) = [F:ICN]OVENAT
            If find(I,1,6)
                [M:ICLD]ONATYP([M:ICLD]NBONA) = 2
            Else
                [M:ICLD]ONATYP([M:ICLD]NBONA) = I
            Endif
            [M:ICLD]ONAAMT([M:ICLD]NBONA) = [F:ICN]NATAMTLEV(I)
            [M:ICLD]NBONA += 1
        Endif
        If [F:ICN]NATAMTSSE(I)+[F:ICN]NATAMTLEV(I)>0
            [M:ITCD]OVENAT([M:ITCD]NBONA) = [F:ICN]OVENAT
            If find(I,1,6)
                [M:ITCD]ONATYP([M:ITCD]NBONA) = 2   # CCC (2010-01-28) Bug 60369 : l'indice était incorrect
            Else
                [M:ITCD]ONATYP([M:ITCD]NBONA) = I   # CCC (2010-01-28) Bug 60369 : l'indice était incorrect
            Endif
            [M:ITCD]ONAAMT([M:ITCD]NBONA) = [F:ICN]NATAMTSSE(I)+[F:ICN]NATAMTLEV(I)
            [M:ITCD]NBONA += 1
        Endif
        If [M:ITCD]NBONA>=dim([M:ITCD]OVENAT)
            Break
        Endif
    Next
Next

Gosub ACTIVE_ZONES

#--------- Initialisation des sections ana en cas modif ------------#
Call INITCCE

Case GCSTTYP
    When 1,3 : Call ECCAFF([M]ITMREF,"ICD0") From SUBICDECC
    When 2,4 : Call ECCAFF([M]ITMREF,"ICA0") From SUBICDECC
Endcase

  Gosub GREYSCREEN #MJH X3-105463 Sep/4/2018

Return



#####################################################
$INICRE
Local Char LDEF(len(dbgstr(2)))
LDEF = left$(dbgstr(2),instr(1,dbgstr(2),"]"))
If !clalev([F:ITC2]) : Local File ITMCOST [ITC2] : Endif
#---- Récupération du n° de séquence ----#
Filter [ITC2] Where ITMREF = [M]ITMREF
&                 & STOFCY = [M]STOFCY
&                 & CSTTYP = GCSTTYP
Read [ITC2] First
Filter [ITC2]
[M]ITCSEQ = [F:ITC2]ITCSEQ+1
[F:ITC]ITCSEQ = [M]ITCSEQ
[F:ITC]ITCDAT = date$
# Le fichier par défaut est [ITC2] => il faut repositionner correctement
Default File LDEF

Gosub INIMOD
Return

#####################################################
$INIMOD
Local Integer I

Local Char    TABCCE(GLONCCE)(max(GNBDIE,GOPTCANA))
#---- Mise à jour de l'article et l'article/site ----#
Gosub UPD_ITF
If GOK < 1 : Return : Endif

#---- Création du mouvement de stock en valeur ----#
Read [ITF]ITF0=[M]ITMREF;[M]STOFCY  # il n'a pas forcément été lu dans UPD_ITF
Read [ITG]ITG0="";[M]TCLCOD # enreg utile pour la màj stock (chgt valeur)
Call GETTCM([F:ITF]ITMREF,[F:ITF]STOFCY,GBIDC1,GBIDI1) From STKVAL    #GETTCM se positionne sur [F:TCM], nécessaire pour conditionner le mvt chgt valeur

# Mise en phase des natures de frais
# Issue 69578 - 2010-12-01 by CCC : L'enregistrement des natures doit aussi se faire en cas de suppression des natures
#If [M:ICD1]OVETOT> 0
  Gosub ENR_ICN
#Endif
If GOK = 0 : Return : Endif

If find([F:ITC]CSTTYP,[F:TCM]ISSVLTCOD,[F:TCM]ISSVLTCOD(1)) & find([F:ITC]CSTTYP,1,2)
    # Si pas d'axe analytique [m]CCE n'existe pas => il faut passer par un tableau intermédiaire
    For I=0 To max(GNBDIE,GOPTCANA)-1
        TABCCE(I) = [M]CCE(I)
    Next
    Call STK_CHG_VAL(([F:TCM]ISSVLTCOD=[F:ITC]CSTTYP xor [F:TCM]ISSVLTCOD(1)=[F:ITC]CSTTYP)+([F:TCM]ISSVLTCOD(1)=[F:ITC]CSTTYP),TABCCE) From SUBITCB
    If GOK < 1
        # "Erreur à la génération du mouvement de changement de valeur"
        GMESSAGE = mess(200,199,1)
        Return
    Endif
    For I=0 To max(GNBDIE,GOPTCANA)-1
        [M]CCE(I) = TABCCE(I)
    Next
Endif

Return

#####################################################
$MODIF
Return

#####################################################
$RAZCRE
Raz [M:ITCD],[M:ICLD]
[M:ICD1]DETCST = "152"
[M:ICD2]DETCST = "152"
[M:ICD3]CLCSTD = "102"
Affzo [M:ICD1]DETCST
Affzo [M:ICD2]DETCST
Affzo [M:ICD3]CLCSTD
If [V]GFLTITM<>""  : # GH 28/02/2012 bug 80299
    Call LECTURE("ITM",GFLTITM,"") From CONTOBJ
    Gosub ACTIVE_ZONES From SUBITCA
    Case GCSTTYP
        When 1,3 : Call ECCAFF(GFLTITM,"ICD0") From SUBICDECC
        When 2,4 : Call ECCAFF(GFLTITM,"ICA0") From SUBICDECC
    Endcase
Endif
Return

#####################################################
$FILGAUCHE
If !GIMPORT   # FQ 62854 GA 03/2010 pb si en tunnel dans [M:ICD0]
  If clalev([M:ICD0]) # Cout standard
    If GFLTITM <> "" : Call AM_ITMREF(GFLTITM) From SUBICD : Endif
    If GFLTFCY <> "" : Call AM_STOFCY(GFLTFCY) From SUBICD : Endif
    # Issue 70038 - 2011-01-10 by CCC : Lorsqu'on arrive dans la fonction avec l'article ou le site chargé mais pas l'exercice
    #                                   il faut dévalider l'écran, sinon avec la souris le contrôle sur l'exercice ne se fait pas
    If [M:ICD0]FIYNUM=0 & (GFLTITM<>"" | GFLTFCY<>"")
        Setmok [M:ICD0] With 0
    Endif
  Endif

  #MJH 118833.sn
  #We need to make sure we correctly refresh the screen for revised cost like we would for standard cost
  If clalev([M:ICA0])
    If GFLTITM <> "" : Call AM_ITMREF(GFLTITM) From SUBICD : Endif
    If GFLTFCY <> "" : Call AM_STOFCY(GFLTFCY) From SUBICD : Endif
  Endif#MJH 118833.en

Endif
Return

#####################################################
$SETBOUT

    If (clalev([M:ICD0]) & [M:ICD0]ITMREF<>"" & [M:ICD0]STOFCY<>"" & [M:ICD0]CSTTYP=1
&      |clalev([M:ICA0]) & [M:ICA0]ITMREF<>"" & [M:ICA0]STOFCY<>"" & [M:ICA0]CSTTYP=2)
&    & find(GREP,"C","M")
        CHMEN+="S"
    Endif
    [M:ICD3]CLCSTD="102"  # Sur le bouton "Abandon", la valeur est vidée

    Actzo [M:ICD3]CLCSTD
    Affzo [M:ICD3]CLCSTD
    If GREP<>""
        Call VIREBOUT(CHAINE,"23") From GOBJET
        Diszo [M:ICD3]CLCSTD
    Endif
    # Issue 75479 - 2011-09-07 by CCC : Un coût saisi ne peut être calculé

    Case GCSTTYP
        When 1 : If [M]STDCSTUPD=2
                    Call VIREBOUT(CHAINE,"3") From GOBJET
                    Diszo [M:ICD3]CLCSTD
                 Endif
        When 2 : If [M]CUTCSTUPD=2
                    Call VIREBOUT(CHAINE,"3") From GOBJET
                    Diszo [M:ICD3]CLCSTD
                 Endif

        When 3 : If [M]STDCSTUPD=2
                    Call VIREBOUT(CHAINE,"3") From GOBJET
                    Diszo [M:ICD3]CLCSTD
                 Endif

        When 4 : If [M]CUTCSTUPD=2
                    Call VIREBOUT(CHAINE,"3") From GOBJET
                    Diszo [M:ICD3]CLCSTD
                 Endif
    Endcase

  # FQ 62309 GA 02/2010 global variable GACCCSTENT undefined without Manufacturing module
    If dim(GACCCSTENT)>0 & GACCCSTENT = ""
        CHAINE+="A"
    Elsif clalev([F:STJ])    # CCC (01/10/08) DM 49486
        # Si les mouvements de changement de coûts standard sont comptabilisés,
        # aucun mouvement ne doit exister pour avoir le droit de supprimer le coût
        If dim([M]ECCVALMAJ)>0
            Filter [STJ] Where ITMREF=[F:ITC]ITMREF
&                            & STOFCY=[F:ITC]STOFCY
&                            & UPDCOD=2
&                            & IPTDAT>=[F:ITC]ITCSTRDAT
&                            & IPTDAT<=[F:ITC]ITCENDDAT
&                            & ECCVALMAJ = [M]ECCVALMAJ
&                            & ECCVALMIN = [M]ECCVALMIN
        Else
            Filter [STJ] Where ITMREF=[F:ITC]ITMREF
&                            & STOFCY=[F:ITC]STOFCY
&                            & UPDCOD=2
&                            & IPTDAT>=[F:ITC]ITCSTRDAT
&                            & IPTDAT<=[F:ITC]ITCENDDAT
        Endif

        Look [STJ] First
        Filter [STJ]
        If fstat
            CHAINE+="A"
        Endif
    Endif

    #MJH X3-105463. dont allow calculation or deletions if edits are not allowed
    If [M:ICD1]GREYSCREEN = "2" #MJH X3-105463. dont allow calculation if edits are not allowed
      Diszo [M:ICD3]CLCSTD
      Call VIREBOUT(CHAINE,"A") From GOBJET
    Endif

    #MJH X3-109066. Dont display the field when coming from budgeted or simulated costs.
    If find(GCSTTYP,3,4)
      If dim([M:ICD0]ITMREF)> 0
        Chgfmt [M:ICD0]LCKSCRN With "-K:" + num$(type([M:ICD0]LCKSCRN)-10) + "B"   # Hide
      Elsif dim([M:ICA0]ITMREF)>0
        Chgfmt [M:ICA0]LCKSCRN With "-K:" + num$(type([M:ICD0]LCKSCRN)-10) + "B"   # Hide
      Endif
    Endif


Return

#####################################################
$GREYSCREEN #MJH X3-105463 Sep/4/2018 start

  If GREP <> "C" and func ALLOWEDIT = 2
    If dim([M:ICD0]ITMREF)> 0
      Grizo [M:ICD0]
      [M:ICD0]LCKSCRN =  mess(9,123,1) + ":" - tolower(mess(235,187,1))
      Affzo [M:ICD0]
    Elsif dim([M:ICA0]ITMREF)>0
      Grizo [M:ICA0]
      [M:ICA0]LCKSCRN =  mess(9,123,1) + ":" - tolower(mess(235,187,1))
      Affzo [M:ICA0]
    Endif

    Grizo [M:ICD1]
    Grizo [M:ICD2]
    Grizo [M:ICD3]
    Actzo [M:ICD1]DETCST
    Actzo [M:ICD2]DETCST

    [M:ICD1]GREYSCREEN = "2"
  Else
    Raz [M:ICD1]GREYSCREEN

    If dim([M:ICD0]ITMREF)> 0
      Raz [M:ICD0]LCKSCRN
    Elsif dim([M:ICA0]ITMREF)>0
      Raz [M:ICA0]LCKSCRN
    Endif
  Endif
Return


Funprog ALLOWEDIT

  If [F:ITC]ITMREF <> [M]ITMREF or [F:ITC]CREDAT = [0/0/0]
    Read [ITC]ITC0 =  [M]STOFCY;[M]ITMREF;[M]CSTTYP;[M]ITCSEQ;[M]UID
  Endif

  If [F:TCM]ISSVLTCOD = 0
    Call GETTCM([M]ITMREF,[M]STOFCY,GBIDC1,GBIDI1) From STKVAL
  Endif
  #The cost type is not being tracked, allow edits
  If !find([F:ITC]CSTTYP,[F:TCM]ISSVLTCOD) or find([F:ITC]CSTTYP,3,4) End 1 Endif

  #The cost is past its end date
  If date$ > [M]ITCENDDAT End 2 Endif


  #This is not the newest cost (By sequence number) that is valid
  If !clalev([F:ITCX]) : Local File ITMCOST [ITCX] : Endif
  Filter [F:ITCX] Where STOFCY = [M]STOFCY and ITMREF=[M]ITMREF and CSTTYP = [M]CSTTYP and ITCSEQ > [M]ITCSEQ
&                   and date$ >= [M]ITCSTRDAT and date$ <= [M]ITCENDDAT
  Look [F:ITCX] First
  Filter [F:ITCX]
  If !fstat End 2 Endif


  Local Char VERSIONS(100)
  If dim([M]ECCVALMAJ) > 0
    VERSIONS = '[F:STJX]ECCVALMAJ = [M]ECCVALMAJ and [F:STJX]ECCVALMIN = [M]ECCVALMIN'
  Else
    VERSIONS = '1=1'
  Endif

  #There are records in STOJOU that references this cost
  If !clalev([F:STJX]) : Local File STOJOU [STJX] : Endif
  Filter [F:STJX] Where [F:STJX]ITMREF = [M]ITMREF and [F:STJX]STOFCY = [M]STOFCY and evalue(VERSIONS)
&                   and ([F:STJX]PRINAT = [M]CSTTYP + 1 or [F:STJX]PRINAT2 = [M]CSTTYP + 1) and [F:STJX]CREDAT >= [F:ITC]CREDAT
&                   and [F:STJX]IPTDAT >= [M]ITCSTRDAT and [F:STJX]IPTDAT <= [M]ITCENDDAT

  Look [F:STJX] First
  Filter [F:STJX]
  If !fstat End 2 Endif

End 1
#MJH X3-105463 Sep/4/2018 end

#####################################################
$AVANTBOUT
    Case BOUT
        When "2" :    # Copie
            GBIDI1 = [F:ITC]CSTTYP-2*([F:ITC]CSTTYP>2)
            GBIDI2 = [F:ITC]FIYNUM+([F:ITC]CSTTYP=1)
    Endcase
Return

#####################################################
$EXEBOUT
    Case BOUT
        When "3" :    # Calcul
            Gosub RELIT From GOBJSUB
            Gosub REMPLIT From GOBJSUB
    Endcase
Return

#####################################################
$ANNULE
Delete [ICN] Where evalue(CRITERE)
Delete [ICC] Where evalue(CRITERE)
Delete [IWC] Where evalue(CRITERE)
Return

#####################################################
$FERME
Kill GSAIDECPRI
If SAV_GCSTTYP
    Kill GCSTTYP
Else
    GCSTTYP = SAV_GCSTTYP
Endif
Return

##########################################################################





##########################################################################
##########################################################################
##########################################################################
##########################################################################
Subprog INITCCE
Local Integer I
Local Char    LSEC(GLONCCE)

    # Issue 77417 - 2012-02-01 by CCC
    #For I=1 To max(GNBDIE,GOPTCANA)
    For I=1 To GNBDIE
        If dim([M]CCE)>I-1
            Raz LSEC
            # Issue X3-71090 - 2018-01-30 by MJH : STJVALAUT is used to calculate the values, we are entering them on a screen here
            #Call INISEC (LSEC, "STJVALAUT", I) From TRTX3CPT
            Call INISEC (LSEC, "STJVAL", I) From TRTX3CPT
            [M]CCE(I-1) = LSEC
        Else
            Break
        Endif
    Next
End

##################################################################
Subprog LEV2MSK(PABRMSK,PABRFIL)
Value Char PABRMSK
Value Char PABRFIL

Local Integer I

For I=0 To GACTMAT-1
    Assign "[M:"+PABRMSK+"]MATCST(I)" With evalue("[F:"+PABRFIL+"]MATLEVCST(I)")
Next
For I=0 To GACTMAC-1
    Assign "[M:"+PABRMSK+"]MACCST(I)" With evalue("[F:"+PABRFIL+"]MACLEVCST(I)")
Next
For I=0 To GACTLAB-1
    Assign "[M:"+PABRMSK+"]LABCST(I)" With evalue("[F:"+PABRFIL+"]LABLEVCST(I)")
Next
Assign "[M:"+PABRMSK+"]SCOCST" With evalue("[F:"+PABRFIL+"]SCOLEVCST")
Assign "[M:"+PABRMSK+"]SCOTOT" With evalue("[F:"+PABRFIL+"]SCOLEVCST")
Assign "[M:"+PABRMSK+"]OVEMATCST" With evalue("[F:"+PABRFIL+"]OVEMATLEV")
Assign "[M:"+PABRMSK+"]OVEMACCST" With evalue("[F:"+PABRFIL+"]OVEMACLEV")
Assign "[M:"+PABRMSK+"]OVELABCST" With evalue("[F:"+PABRFIL+"]OVELABLEV")
Assign "[M:"+PABRMSK+"]OVESCOCST" With evalue("[F:"+PABRFIL+"]OVESCOLEV")
End

##########################################################################
$UPD_ITF
Read [ITM]ITM0 = [M]ITMREF
If !fstat
 If [F:ITM]BRDCOD <> [M]BRDCOD
  [F:ITM]BRDCOD = [M]BRDCOD
  Rewrite [ITM]
  If fstat=1
     GOK = -1 : GLOCK= "$ITMMASTER" + [ITM]ITMREF : Return
  Endif
 Endif
Endif

Read [ITF]ITF0=[M]ITMREF;[M]STOFCY
[F:ITF]OVECOD = [M]OVECOD

Case GCSTTYP
    When 1 : [F:ITF]STDCSTUPD = [M]STDCSTUPD
    When 2 : [F:ITF]CUTCSTUPD = [M]CUTCSTUPD
    When 3 : [F:ITF]BUDCSTUPD = [M]STDCSTUPD
    When 4 : [F:ITF]SIMCSTUPD = [M]CUTCSTUPD
Endcase
#--- Tableau FG ----#
For GBIDI1=0 To dim([F:ITF]OTRSTYP)-1
    [F:ITF]OTRSTYP(GBIDI1)    = [M]OTRSTYP(GBIDI1)
    [F:ITF]OVECOD(GBIDI1)     = [M]OVECOD(GBIDI1)
    [F:ITF]OVECPNFLG(GBIDI1)  = [M]OVECPNFLG(GBIDI1)
Next

Rewrite [ITF]
If fstat=1
 GOK = -1 : GLOCK= "$ITMFACILIT" + [ITF]ITMREF + [ITF]STOFCY : Return
Endif

Return

#######################################################
$ENR_ICN
Delete [ICN] Where STOFCY=[M]STOFCY & ITMREF=[M]ITMREF & CSTTYP=[F:ITC]CSTTYP
&          & ITCSEQ=[F:ITC]ITCSEQ & UID=[F:ITC]UID
Raz [F:ICN]
[F:ICN]          = [F:ITC]
[F:ICN]CREDAT    = date$
[F:ICN]CREUSR    = GUSER
[F:ICN]EXPNUM    = [C]EXPORT
For I=0 To [M:ITCD]NBONA-1
    Raz [F:ICN]NATAMTLEV, [F:ICN]NATAMTSSE
    [F:ICN]OVENAT    = [M:ITCD]OVENAT(I)
    GBIDI1 = find([M:ITCD]OVENAT(I),[M:ICLD]OVENAT)
    If GBIDI1>0
        [F:ICN]NATAMTLEV(0) = [M:ICLD]ONAAMT(GBIDI1-1)
        [F:ICN]NATAMTLEV([M:ITCD]ONATYP(I)) = [F:ICN]NATAMTLEV(0)
    Endif
    [F:ICN]NATAMTSSE(0) = [M:ITCD]ONAAMT(I)-[F:ICN]NATAMTLEV(0)
    [F:ICN]NATAMTSSE([M:ITCD]ONATYP(I)) =  [M:ITCD]ONAAMT(I)-[F:ICN]NATAMTLEV([M:ITCD]ONATYP(I))
    # les parties fixes et sous-niveau ne sont pas affectées
    Write [ICN]
Next
If fstat
  # erreur d'écriture sur le fichier ITCNAT std... AAAA #### nature de FG : ZZZ
  GMESSAGE = mess(13,100,1)-"ITCNAT"-mess([F:ITC]CSTTYP,219,1)-num$([F:ITC]ITCSEQ)-mess(309,197,1)+":"+[F:ICN]OVENAT
  GOK = 0
Endif

Return

####################################################
$ACTIVE_ZONES

# Art fabriqué : on saisit tout
If [F:ITM]MFGFLG=2
   GSAIDECPRI = 1
   Actzo [M:ICD2]MACTOTLEV
   Actzo [M:ICD2]LABTOTLEV
   Actzo [M:ICD2]SCOTOTLEV
# si article sous-traité on saisit matière + ss-trait + fg
Elsif [F:ITM]SCPFLG=2
&    | [F:ITM]SCSFLG=2  # Issue 86470 - 2012-12-06 by CCC
   GSAIDECPRI = 4+32+64+128    # Matière + sous-traitance + FG + natures
   Grizo [M:ICD2]MACTOTLEV
   Grizo [M:ICD2]LABTOTLEV
   Actzo [M:ICD2]SCOTOTLEV
#sinon seuls le cout matière et les FG sont saisis
Else
   GSAIDECPRI = 4+64+128    # Matière + FG + natures
   Grizo [M:ICD2]MACTOTLEV
   Grizo [M:ICD2]LABTOTLEV
   Grizo [M:ICD2]SCOTOTLEV
Endif
Diszo [M:ICD1]MATTOT,MACTOT,LABTOT,SCOTOT,OVETOT    # Le coût multi-niveaux n'est pas saisissable

Return

$LOAD_ITF
# alimenter les zones reprises de ITF : Saisi ou calculé
If clalev([M:ICD0])
    [M:ICD0] = [F:ITF]
Elsif clalev([M:ICA0])
    [M:ICA0] = [F:ITF]
Endif
[M] = [F:ITF]
Case GCSTTYP
    When 1 : [M]STDCSTUPD = [F:ITF]STDCSTUPD
    When 2 : [M]CUTCSTUPD = [F:ITF]CUTCSTUPD
    When 3 : [M]STDCSTUPD = [F:ITF]BUDCSTUPD
    When 4 : [M]CUTCSTUPD = [F:ITF]SIMCSTUPD
Endcase

#--- Tableau FG ----#
For GBIDI1=0 To dim([F:ITF]OTRSTYP(GBIDI1))-1
    If [F:ITF]OTRSTYP(GBIDI1)=0 : Break : Endif
    [M]OTRSTYP(GBIDI1) = [F:ITF]OTRSTYP(GBIDI1)
    [M]OVECOD(GBIDI1)  = [F:ITF]OVECOD(GBIDI1)
    [M]OVECPNFLG(GBIDI1)  = [F:ITF]OVECPNFLG(GBIDI1)
Next
[M]NBTYP=GBIDI1
Return

