#CHECK MIGRATE_SOURCE
# ----------------------------------------------------------------------------- #
# TRCMAJ99 : M.a.j à effectuer lors du passage à version x  Module Tronc commun #
# ----------------------------------------------------------------------------- #
#################################################################################
# Rectification du dictionnaire : ADICMAJ99                                     #
#                                                                               #
#################################################################################
# Avant mise à jour             : ATRCMAJ99                                     #
#                                                                               #
#   - STKITG   : Init PCKFLG fichier ITMCATEG                                   #
#                                                                               #
#################################################################################
# Après mise à jour             : TRCMAJ99                                      #
#                                                                               #
#                                                                               #
#################################################################################

#################################################################################
# Moulinette : Dico anciennes tables avant ajout des nouvelles tables           #
#################################################################################

Subprog ADICMAJ99
Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ99: Process for common dictionnary") From LECFIC
    WOUV_TRACE=1
Endif

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End


#################################################################################
# Moulinette : Structure tables avec anciens et nouveaux champs                 #
#################################################################################

Subprog ATRCMAJ99
Local Integer NUMPROC
Raz NUMPROC

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ99: Process for common data") From LECFIC
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

#---- Init PCKFLG    fichier ITMCATEG ------#
NUMPROC += 1
Call ECR_TIME("TRCMAJ99 Transactions Process "+num$(NUMPROC)+": Update PCKFLG") From DOSSUB
Call STKITG([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif

#---- Init PCKFLG    fichier ITMFACILIT-----#
NUMPROC += 1
Call ECR_TIME("TRCMAJ99 Transactions Process "+num$(NUMPROC)+": Update PCKFLG") From DOSSUB
Call STKITF([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif

#---- Init PCKFLG    fichier STOPRED ------#
NUMPROC += 1
Call ECR_TIME("TRCMAJ99 Transactions Process "+num$(NUMPROC)+": Update PCKFLG") From DOSSUB
Call STKPRE([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif

#---- Init PCKFLG    fichier SDELIVERYD----#
NUMPROC += 1
Call ECR_TIME("TRCMAJ99 Transactions Process "+num$(NUMPROC)+": Update PCKFLG") From DOSSUB
Call STKSDD([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif


#----- Mise à jour des listes de gauche des objets modifiés -----#
Gosub MAJ_AOBJLST
#-----

Onerrgo

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End


#-------------------------------------------------------#
# STKITG     : MAJ des catégories:                      #
#             -Init PCKFLG  dans ITMCATEG               #
# Paramètres E : LDOS   = Dossier                       #
#-------------------------------------------------------#
Subprog STKITG(LDOS)
Value Char LDOS
Local File =LDOS+".ITMCATEG"   [ITG]
#
Local Integer WRE
Raz WRE

Call ECR_TRACE("Start trace : ITMCATEG / PCKFLG" ,0) From GESECRAN

Trbegin [ITG]
For [ITG]
    [F:ITG]PCKFLG = 2
    If [F:ITG]SALFLG <> 2 &  [F:ITG]DLVFLG <> 2
       [F:ITG]PCKFLG    = 1
       [F:ITG]PCKSTKFLG = 1
       Raz [F:ITG]PCK
       Raz [F:ITG]PCKCAP
    Endif        
    Rewrite [ITG]
    WRE +=1
Next
Commit
 
Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),0) From GESECRAN

End


#-------------------------------------------------------#
# STKITF     : MAJ des catégories:                      #
#             -Init PCKFLG  dans ITMFACILIT             #
# Paramètres E : LDOS   = Dossier                       #
#-------------------------------------------------------#
Subprog STKITF(LDOS)
Value Char LDOS

Local File =LDOS+".ITMMASTER"  [ITM]
Local File =LDOS+".ITMFACILIT" [ITF]
#
Local Integer WRE
Raz WRE
Call ECR_TRACE("Start trace : ITMFACILIT / PCKFLG" ,0) From GESECRAN

Trbegin [ITF]
For [ITM]
    For [ITF]ITF0 Where ITMREF=[F:ITM]ITMREF
        [F:ITF]PCKFLG = 2
        If [F:ITM]SALFLG <> 2 &  [F:ITM]DLVFLG <> 2
           [F:ITF]PCKFLG    = 1
           [F:ITF]PCKSTKFLG = 1
           Raz [F:ITF]PCK
           Raz [F:ITF]PCKCAP
        Endif        
        Rewrite [ITF]
        WRE +=1
    Next
Next
Commit

Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),0) From GESECRAN

End


#################################################################################
# Moulinette : Structure définitive des tables                                  #
#################################################################################
Subprog TRCMAJ99

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ99: Process for common data") From LECFIC
    WOUV_TRACE=1
Endif

Local Integer NUMPROC
Raz NUMPROC

Onerrgo TRT_ERR


If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

Onerrgo

End

#################################################################################
$TRT_ERR
    Call ECR_TRACE( "ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
Resume

#-------------------------------------------------------#
# Mise à jour de l'onglet sélection des objets modifiés #
#-------------------------------------------------------#
$MAJ_AOBJLST
#-----
Local File =[F:ADS]DOSSIER+".AOBJLST" [AOL]
Local File =[F:ADS]DOSREF +".AOBJLST" [AOL2]
#-----
Local Char    WOBJET(GLONAOB)
Local Integer WNBR
#-----
Call ECR_TIME("TRCMAJ99 Object Lists Process : Update AOBJLST") From DOSSUB
#-----
Raz WNBR
Trbegin [AOL]
For WOBJET="SD3","PR2"
    Read [AOL] AOL0=WOBJET
    If !fstat
       Read [AOL2] AOL0=WOBJET
       If !fstat
          [F:AOL]=[F:AOL2]
          Rewrite [AOL]
          If fstat
             Call ECR_TRACE("File AOBJLST"-WOBJET+", Error ="-num$(fstat),1) From GESECRAN
          Else
             WNBR+=1
          Endif
       Endif
    Endif
Next WOBJET
Commit
#-----
Close Local File [AOL], [AOL2]
Call ECR_TIME("TRCMAJ99 Object Lists Process : Ended ("+num$(WNBR)+")") From DOSSUB
Return 



