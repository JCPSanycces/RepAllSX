#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du masque EXTOURNE
Subprog C_RVSDAT(VALEUR)
Variable Date    VALEUR
Local Decimal EXE, PER
If clalev([M:HAE0])>0 : Default Mask [HAE0] : CAS = 1 : Endif
If clalev([M:HAE1])>0 : Default Mask [HAE1] : CAS = 1 : Endif
If VALEUR < [M]ACCDAT
 GMESSAGE = mess(1,104,1)   :# Incorrect Date
 mkstat = 2 : End
Else
 Local Char SVGREP : SVGREP=GREP
 GREP="D"
 Gosub SETMSK From SUBGAS
 Call C_ACCDAT(VALEUR) From SUBGA0
 GREP=SVGREP
 If mkstat=2 : End : Endif

 Read [JST]JST0 = [M]CPY;[F:JOU]JOU
 If fstat | [F:JST]OPGSTRDAT>VALEUR | ([F:JST]OPGENDDAT<>[0/0/0] and [F:JST]OPGENDDAT<VALEUR)
  GMESSAGE = [F:JOU]JOU-mess(92,104,1)-"("+format$("D:"+GFMDAT,VALEUR)+")"
  mkstat = 2 : End :  # Journal no open
 Endif

Endif
End

