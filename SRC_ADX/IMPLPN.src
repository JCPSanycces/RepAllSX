#<AdxTL>@(#)0.0.0.0 $Revision$
#
#*********************************************************************
#
#           SYRCUSE LPN IMPORT PROCESS
#
#*********************************************************************
# Creation
# MAE   01.08.2018
#
#*********************************************************************
# Updates
#
# XXXXX DD.MM.YYYY FQ000000   : XXX
#
#*********************************************************************

$ACTION
  Case ACTION
    When "IMP_OUVRE"     : Gosub IMP_OUVRE
    When "AP_IMPORT"     : Gosub AP_IMPORT
    When Default
  Endcase
Return

####################################################################
# At the beginning of import process
####################################################################
$IMP_OUVRE
  Local Integer RET
  Local Integer NBCREA, NBMODIF
  Local Integer WPOS
  Local Integer NBLIG
  Local Char SAV_CTRNUM(GLONVCR)

  If !clalev([F:LPN]) : Local File LPN [LPN] : Endif
  If !clalev([F:LPN1]) : Local File LPN [LPN1] : Endif
  If !clalev([F:TCR]) : Local File TABCONTAINER [TCR] : Endif

  Local Instance WLPN Using C_LPN

  # Set ANOWRITE to 1 to avoid creation/update by the Supervisor import process
  ANOWRITE = 1
Return

####################################################################
# After each line reading
####################################################################
$AP_IMPORT
# In the TEST mode ther's nothing to do
If ([M:IMP2]TEST=[V]CST_AYES) : Return : Endif

WLPN=NewInstance C_LPN AllocGroup null
[L]RET=fmet WLPN.AINIT()
If [L]RET >= [V]CST_AERROR
  Call WRITE_ERRORS(WLPN)
  FreeGroup WLPN
  Return
Endif
# Must set GREP to have the right numbers of created and updated items in the log
GREP="C"

# The lpn exist, passage in modification
If ([M:AOE1]OPTUPD=G_OUI) and ([F:LPN]LPNNUM<>"")
  Read[LPN1]LPN0=[F:LPN]LPNNUM
  If (fstat=[V]CST_AOK)
    [L]RET=fmet WLPN.AREAD([F:LPN]LPNNUM)
    If [L]RET >= [V]CST_AERROR
      Call WRITE_ERRORS(WLPN)
      FreeGroup WLPN
      Return
    Else
      GREP="M"
    Endif
  Endif
Endif

If GREP="M"
  Gosub SET_PROPERTIES_UPDATE
Elsif GREP="C"
 Gosub SET_PROPERTIES_CREATE
Else
 Call ECR_TRACE("GREP = ''",1) From GESECRAN
 FreeGroup WLPN
 Return
Endif


If WLPN<>null
  If WLPN.LPNNUM<>AVOID.ACHAR
    If GREP ="C"
      Gosub INSERTION
    Elsif GREP="M"
      Gosub MODIFICATION
    Else
      Call ECR_TRACE("GREP = ''",1) From GESECRAN
      FreeGroup WLPN
      Return
    Endif
  #To manage the case of the sequence number (LPNNUM = AVOID.ACHAR)
  Else
    If GREP ="C"
      Gosub INSERTION
    Endif
  Endif
Endif


NBLIG=AVOID.ADEC
FreeGroup WLPN

Return
####################################################################
# Record insertion
####################################################################
$INSERTION
Trbegin [F:LPN]
# Insertion of the previous record
[L]RET=fmet WLPN.AINSERT()

Call WRITE_ERRORS(WLPN)

If [L]RET>=[V]CST_AERROR
  # Must set GOK to zero in case of error. If not a success message is added to the log.
  GOK=0
  Rollback
Else
  Call ECR_TRACE(mess(143,141,1)+" "+mess(59,123,1)+" "+WLPN.LPNNUM,0) From GESECRAN
  NBCREA +=1
  Commit
Endif

Return

####################################################################
# Record update
####################################################################
$MODIFICATION

Trbegin [F:LPN]
# Update of the previous record
[L]RET=fmet WLPN.AUPDATE()

Call WRITE_ERRORS(WLPN)

If [L]RET>=[V]CST_AERROR
  # Must set GOK to zero in case of error. If not a success message is added to the log.
  GOK=0
  Rollback
Else
  Call ECR_TRACE(mess(143,141,1)+" "+mess(3,85,1)+" "+WLPN.LPNNUM,0) From GESECRAN
  NBMODIF +=1
  Commit
Endif

Return

####################################################################
# Assign value to the class property when creating
####################################################################
$SET_PROPERTIES_CREATE

SetInstance WLPN With [F:LPN]
WLPN.MONITMFLG = [F:LPN]MONITMFLG
WLPN.MONLOTFLG = [F:LPN]MONLOTFLG
WLPN.LPNSTAT = 1
Return

####################################################################
# Assign value to the class property from the F class
# according the imported fields list when updating
####################################################################
$SET_PROPERTIES_UPDATE
Local Integer N_I, IS_NULL, WIND
For N_I = 0 To [M:AOE2]NBRLIG-1
    If (left$([M:AOE2]FLD(N_I),1)<>"*") &(left$([M:AOE2]FLD(N_I),1)<>"/")
      If (evalue("dim(WLPN."+[M:AOE2]FLD(N_I)+")>-1")) & (evalue("dim([F:LPN]"+[M:AOE2]FLD(N_I)+")>-1"))
        IS_NULL = 0
        Case evalue("type([F:LPN]"+[M:AOE2]FLD(N_I)+")")
        When 1, 2, 4, 5, 6, 7, 9
         If evalue("[F:LPN]"+[M:AOE2]FLD(N_I)) = 0
           IS_NULL = 1
         Endif
        When 3
          If evalue("[F:LPN]"+[M:AOE2]FLD(N_I)) = [0/0/0]
           IS_NULL = 1
          Endif
        When Default
          If evalue("[F:LPN]"+[M:AOE2]FLD(N_I)) = ""
            IS_NULL = 1
          Endif
        Endcase
        # Filling of the header
        If !IS_NULL
          Assign "WLPN."+[M:AOE2]FLD(N_I) With evalue("[F:LPN]"+[M:AOE2]FLD(N_I))

        Endif
      Endif
     Endif
  Next
Return

#------------------------------------#
#--- Write the errors                #
#------------------------------------#
Subprog WRITE_ERRORS(WLPN)
Variable Instance WLPN Using C_LPN

Local Integer I
Local Char WMESSAGE(250)

WMESSAGE=AVOID.ACHAR

# Head errors
WMESSAGE=func LCCLIB.MAXMSG(WLPN)
If WMESSAGE<>AVOID.ACHAR
  Call WRITE_ERROR_STACK_CLASSIC(WLPN, 0) From LCCLIB
Endif

End

