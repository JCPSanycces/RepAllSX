#<AdxTL>@(#)5.0.0.0 $Revision$
################################################################################################
#                                                                                              #
#      TRAITEMENTS EPURATION dans les VENTES                                                   #
#                                                                                              #
################################################################################################
################################################################################################
# HISTO = 1 => Historisation                                                                   #
#                                                                                              #
#              Les données passent d'APPLI vers HISAPL                                         #
#              Les données historisées sont supprimées d'APPLI                                 #
#              Uniquement des contrôles liés au dossier APPLI                                  #
#                                                                                              #
#                                                                                              #
# OKEPU  = 1 => Epuration                                                                      #
#                                                                                              #
#    Soit Epuration seule (OKEPU=1 et HISTO=0)                                                 #
#              Les données sont supprimées d'APPLI                                             #
#              Uniquement des contrôles liés au dossier APPLI.                                 #
#                                                                                              #
#    Soit Epuration suite à l'historisation (OKEPU=1 et HISTO=1)                               #
#              L'historisation a fait les vérifications nécessaires (cf HISTO=1)               #
#              L'épuration concerne donc le dossier HISAPL mais aucun contrôle sur ce dossier. #
#                                                                                              #
################################################################################################
$ACTION
Case ACTION
    When "OUVRE"       : Gosub OUVRE_EPURE
    When "HISTO"       : Gosub HISTO
    When "EPURE"       : Gosub EPURE
    When "FERME"       : Gosub FERME_EPURE
Endcase
Return
#################################################################################
#    OUVRE_EPURE                                                                #
#################################################################################
$OUVRE_EPURE
Case [F:AHI]COD
    When "SQH"    :    Gosub OUVRE_EPU_SQH
    When "SOH"    :    Gosub OUVRE_EPU_SOH
    When "SOR"    :    Gosub OUVRE_EPU_SOR
    When "SDH"    :    Gosub OUVRE_EPU_SDH
    When "SRH"    :    Gosub OUVRE_EPU_SRH
    When "SRL"    :    Gosub OUVRE_EPU_SRL
    When "SRS"    :    Gosub OUVRE_EPU_SRS
    When "SIH"    :    Gosub OUVRE_EPU_SIH
    When "DEB"    :    Return
    When "SPF"    :    Gosub OUVRE_EPU_SPF
Endcase
Return
#################################################################################
#    HISTO                                                                      #
#################################################################################
$HISTO
Case [F:AHI]COD
    When "SQH"    :    Gosub HIS_EPU_SQH
    When "SOH"    :    Gosub HIS_EPU_SOH
    When "SOR"    :    Gosub HIS_EPU_SOR
    When "SDH"    :    Gosub HIS_EPU_SDH
    When "SRH"    :    Gosub HIS_EPU_SRH
    When "SRL"    :    Gosub HIS_EPU_SRL
    When "SRS"    :    Gosub HIS_EPU_SRS
    When "SIH"    :    Gosub HIS_EPU_SIH
    When "DEB"    :    Return
    When "SPF"    :    Gosub HIS_EPU_SPF
Endcase
Return
#################################################################################
#    EPURE                                                                      #
#################################################################################
$EPURE
Case [F:AHI]COD
    When "SQH"    :    Gosub HIS_EPU_SQH
    When "SOH"    :    Gosub HIS_EPU_SOH
    When "SOR"    :    Gosub HIS_EPU_SOR
    When "SDH"    :    Gosub HIS_EPU_SDH
    When "SRH"    :    Gosub HIS_EPU_SRH
    When "SRL"    :    Gosub HIS_EPU_SRL
    When "SRS"    :    Gosub HIS_EPU_SRS
    When "SIH"    :    Gosub HIS_EPU_SIH
    When "DEB"    :    Return
    When "SPF"    :    Gosub HIS_EPU_SPF
Endcase
Return
#################################################################################
#    FERME_EPURE                                                                #
#################################################################################
$FERME_EPURE
Case [F:AHI]COD
    When "SQH"    :    Gosub FERME_EPU_SQH
    When "SOH"    :    Gosub FERME_EPU_SOH
    When "SOR"    :    Gosub FERME_EPU_SOR
    When "SDH"    :    Gosub FERME_EPU_SDH
    When "SIH"    :    Gosub FERME_EPU_SIH
    When "SRH"    :    Gosub FERME_EPU_SRH
    When "SRL"    :    Gosub FERME_EPU_SRL
    When "SRS"    :    Gosub FERME_EPU_SRS
    When "DEB"    :    Return
    When "SPF"    :    Return
Endcase
Return

#################################################################################
#    Epuration des devis                                                        #
# ------------------------------------------------------------------------------#
#    SQH : Actions liées à l'épuration des devis                                #
# ------------------------------------------------------------------------------#
#    Formule d'épuration :                                                      #
#    (VLYDAT<>[0/0/0] & VLYDAT < date$) | QUOSTA=3                              #
#################################################################################
#-------------------------------------------------------------------------------#
#    Ouvertures des fichiers complémentaires                                    #
#-------------------------------------------------------------------------------#
$OUVRE_EPU_SQH

If HISTO
    If OKEPU=0
      #-- Historisation
      If clalev([F:SQD])=0 : Local File =[L]APPLI+".SQUOTED"   [SQD]   : Endif
      If clalev([F:SVV])=0 : Local File =[L]APPLI+".SVCRVAT"   [SVV]   : Endif
      If clalev([F:SVF])=0 : Local File =[L]APPLI+".SVCRFOOT"  [SVF]   : Endif
      If clalev([F:CAL])=0 : Local File =[L]APPLI+".CPTANALIN" [CAL]   : Endif
      #-----------------------#
      # Fichier historisation #
      #-----------------------#
      TABLE="SVCRVAT"   : Gosub CRETAB_HISTO
      If clalev([F:SVV1])= 0 : Local File =[L]HISAPL+".SVCRVAT"   [SVV1] : Endif
      TABLE="SVCRFOOT"  : Gosub CRETAB_HISTO
      If clalev([F:SVF1])= 0 : Local File =[L]HISAPL+".SVCRFOOT"  [SVF1] : Endif
      TABLE="CPTANALIN" : Gosub CRETAB_HISTO
      If clalev([F:CAL1])= 0 : Local File =[L]HISAPL+".CPTANALIN" [CAL1] : Endif
    Else
      #-- Epuration après historisation (Pour épuration du texte lié)
      If clalev([F:SQD])=0 : Local File =[L]HISAPL+".SQUOTED"   [SQD]   : Endif
      If clalev([F:SVV])=0 : Local File =[L]HISAPL+".SVCRVAT"   [SVV]   : Endif
      If clalev([F:SVF])=0 : Local File =[L]HISAPL+".SVCRFOOT"  [SVF]   : Endif
      If clalev([F:CAL])=0 : Local File =[L]HISAPL+".CPTANALIN" [CAL]   : Endif
    Endif
Else
    #-- Epuration seule (Pour épuration du texte lié)
    If clalev([F:SQD])=0   : Local File =[L]APPLI+".SQUOTED"   [SQD]   : Endif
    If clalev([F:SVV])=0   : Local File =[L]APPLI+".SVCRVAT"   [SVV]   : Endif
    If clalev([F:SVF])=0   : Local File =[L]APPLI+".SVCRFOOT"  [SVF]   : Endif
    If clalev([F:CAL])=0   : Local File =[L]APPLI+".CPTANALIN" [CAL]   : Endif
Endif

Gosub DEFVAR
Return

#-------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'un devis                                  #
#-------------------------------------------------------------------------------#
$HIS_EPU_SQH

WCLE=[F:F1]SQHNUM
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif

WOK=1
WNUMTEX = [F:F1]SQHTEX1
If WNUMTEX <> "" WTYP="SQH1" : Gosub HIS_EPU_TEXTE : Endif
If WOK=0 OKHIS=0 : OKEPU=0 : Return : Endif
WNUMTEX = [F:F1]SQHTEX2
If WNUMTEX <> "" WTYP="SQH2" : Gosub HIS_EPU_TEXTE : Endif
If WOK=0 OKHIS=0 : OKEPU=0 : Return : Endif

# --- Boucle de supression des textes associés aux lignes détail devis
# --- Boucle d'historisation-épuration sections analytiques lignes devis
Raz WVCRTYP, WVCRNUM, WVCRLIN, WVCRSEQ, WCPLCLE
Columns [SQD] (SQHNUM, SQDLIN, SQDTEX)
For [F:SQD] SQD0 Where SQHNUM=[F:F1]SQHNUM
  WNUMTEX = [F:SQD]SQDTEX
  If WNUMTEX <> "" WTYP="SQD1" : Gosub HIS_EPU_TEXTE : Endif
  If WOK=0 Break : Endif
  WVCRNUM = [F:SQD]SQHNUM : WVCRLIN=[F:SQD]SQDLIN : WABRFIC="SQD"
  Gosub HIS_EPU_CAL
  If WOK=0 Break : Endif
Next
Columns [SQD]

If WOK=0 OKHIS=0 : OKEPU=0 : Return : Endif

# --- Historisation-épuration SVCRVAT SVCRFOOT
WVCRTYP=1
Gosub HIS_EPU_SVV : If WOK=0 OKHIS=0 : OKEPU=0 : Return : Endif
Gosub HIS_EPU_SVF : If WOK=0 OKHIS=0 : OKEPU=0 : Return : Endif

Return

#-------------------------------------------------------------------------------#
#    Fermeture des fichiers complémentaires                                     #
#-------------------------------------------------------------------------------#
$FERME_EPU_SQH

If clalev([F:SQD])  : Close Local File [SQD] : Endif
If clalev([F:SVV])  : Close Local File [SVV] : Endif
If clalev([F:SVF])  : Close Local File [SVF] : Endif
If clalev([F:CAL])  : Close Local File [CAL] : Endif
If clalev([F:SVV1]) : Close Local File [SVV1] : Endif
If clalev([F:SVF1]) : Close Local File [SVF1] : Endif
If clalev([F:CAL1]) : Close Local File [CAL1] : Endif
Return

#################################################################################
#    Epuration des commandes                                                    #
# ------------------------------------------------------------------------------#
#    SOH : Actions liées à l'épuration des commandes                            #
# ------------------------------------------------------------------------------#
#    Formule d'épuration :                                                      #
#    SOHCAT<4 & ORDSTA=2 & (ORIFCY="" | ORIFCY=SALFCY))                         #
#################################################################################
#-------------------------------------------------------------------------------#
#    Ouvertures des fichiers complémentaires                                    #
#-------------------------------------------------------------------------------#
$OUVRE_EPU_SOH

If HISTO
    If OKEPU=0
      #-- Historisation
      If clalev([F:SOQ])=0 : Local File =[L]APPLI+".SORDERQ"     [SOQ]   : Endif
      If clalev([F:SOP])=0 : Local File =[L]APPLI+".SORDERP"     [SOP]   : Endif
      If clalev([F:VOP])=0 : Local File =[L]APPLI+".VSORDERP"    [VOP]   : Endif
      If clalev([F:SIV])=0 : Local File =[L]APPLI+".SINVOICEV"   [SIV]   : Endif
      If clalev([F:SID])=0 : Local File =[L]APPLI+".SINVOICED"   [SID]   : Endif
      If clalev([F:SDD])=0 : Local File =[L]APPLI+".SDELIVERYD"  [SDD]   : Endif
      If clalev([F:DUD])=0 : Local File =[L]APPLI+".GACCDUDATE"  [DUD]   : Endif
      If clalev([F:SVV])=0 : Local File =[L]APPLI+".SVCRVAT"     [SVV]   : Endif
      If clalev([F:SVF])=0 : Local File =[L]APPLI+".SVCRFOOT"    [SVF]   : Endif
      If clalev([F:CAL])=0 : Local File =[L]APPLI+".CPTANALIN"   [CAL]   : Endif
      #-----------------------#
      # Fichier historisation #
      #-----------------------#
      TABLE="GACCDUDATE" : Gosub CRETAB_HISTO
      If clalev([F:DUD1])= 0 : Local File =[L]HISAPL+".GACCDUDATE" [DUD1] : Endif
      TABLE="SVCRVAT"    : Gosub CRETAB_HISTO
      If clalev([F:SVV1])= 0 : Local File =[L]HISAPL+".SVCRVAT"    [SVV1] : Endif
      TABLE="SVCRFOOT"   : Gosub CRETAB_HISTO
      If clalev([F:SVF1])= 0 : Local File =[L]HISAPL+".SVCRFOOT"   [SVF1] : Endif
      TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
      If clalev([F:CAL1])= 0 : Local File =[L]HISAPL+".CPTANALIN"  [CAL1] : Endif
    Else
      #-- Epuration après historisation (Pour les vérifs et épuration du texte lié)
      If clalev([F:SOQ])=0 : Local File =[L]HISAPL+".SORDERQ"    [SOQ]   : Endif
      If clalev([F:SOP])=0 : Local File =[L]HISAPL+".SORDERP"    [SOP]   : Endif
      If clalev([F:VOP])=0 : Local File =[L]HISAPL+".VSORDERP"   [VOP]   : Endif
      If clalev([F:SIV])=0 : Local File =[L]HISAPL+".SINVOICEV"  [SIV]   : Endif
      If clalev([F:SID])=0 : Local File =[L]HISAPL+".SINVOICED"  [SID]   : Endif
      If clalev([F:SDD])=0 : Local File =[L]HISAPL+".SDELIVERYD" [SDD]   : Endif
      If clalev([F:DUD])=0 : Local File =[L]HISAPL+".GACCDUDATE" [DUD]   : Endif
      If clalev([F:SVV])=0 : Local File =[L]HISAPL+".SVCRVAT"    [SVV]   : Endif
      If clalev([F:SVF])=0 : Local File =[L]HISAPL+".SVCRFOOT"   [SVF]   : Endif
      If clalev([F:CAL])=0 : Local File =[L]HISAPL+".CPTANALIN"  [CAL]   : Endif
    Endif
Else
    #-- Epuration seule (Pour les vérifs et épuration du texte lié)
    If clalev([F:SOQ])=0   : Local File =[L]APPLI+".SORDERQ"     [SOQ]   : Endif
    If clalev([F:SOP])=0   : Local File =[L]APPLI+".SORDERP"     [SOP]   : Endif
    If clalev([F:VOP])=0   : Local File =[L]APPLI+".VSORDERP"    [VOP]   : Endif
    If clalev([F:SIV])=0   : Local File =[L]APPLI+".SINVOICEV"   [SIV]   : Endif
    If clalev([F:SID])=0   : Local File =[L]APPLI+".SINVOICED"   [SID]   : Endif
    If clalev([F:SDD])=0   : Local File =[L]APPLI+".SDELIVERYD"  [SDD]   : Endif
    If clalev([F:DUD])=0   : Local File =[L]APPLI+".GACCDUDATE"  [DUD]   : Endif
    If clalev([F:SVV])=0   : Local File =[L]APPLI+".SVCRVAT"     [SVV]   : Endif
    If clalev([F:SVF])=0   : Local File =[L]APPLI+".SVCRFOOT"    [SVF]   : Endif
    If clalev([F:CAL])=0   : Local File =[L]APPLI+".CPTANALIN"   [CAL]   : Endif
Endif

Gosub DEFVAR
Local Integer WCTL_VAL_FAC
Local Char    WCRITERE(200)

Return

$CRETAB_HISTO
OK=0
#--- Création des tables non liées
If filinfo(filpath("FIL",TABLE,"fde",HISAPL),0)<0
  OK=1
Else
  Call VUE_OK(TABLE,HISAPL,"FIL",OK) From DOSVUE
Endif
If OK
  Call CRETABLE(APPLI,HISAPL,TYPDBA,TABLE,COEFF,0) From CREHISTO
Endif
OK=1
Return

#-------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'une commande                              #
#    Contrôles à effectuer avant l'épuration d'une commande (WOK=0 pour refuser)#
#-------------------------------------------------------------------------------#
$HIS_EPU_SOH
Raz WCTL_VAL_FAC

WCLE=[F:F1]SOHNUM

If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif
WOK=1

# --- Boucle de lecture des lignes détail commandes
For [F:SOQ] SOQ0 Where SOHNUM=[F:F1]SOHNUM
    # 107888 : Scheduled invoices : (LD:20/05/16)
#    Case [F:F1]SOHCAT
#        When 1 : Gosub VERF_SOH_NOR
#        When 2 : Gosub VERF_SOH_PRE
#        When 3 : Gosub VERF_SOH_FAC
#    Endcase
    Case [F:F1]SOHCAT
        When 1 : # Commande normale
            If [F:SOQ]DLVFLG=2
                # Article livrable      : Vérification des livraisons
                Gosub VERF_SOH_NOR
            Else
                # Article non livrable  : Pas de livraison --> Vérification des factures
                Gosub VERF_SOH_FAC
            Endif
        When 2 : # Commande de prêt
            Gosub VERF_SOH_PRE
        When 3 : # Commande à facturation directe : --> Vérification des factures
            Gosub VERF_SOH_FAC
    Endcase
    # 107888 : Scheduled invoices : (LD:20/05/16)
    If WOK=0 Call ECR_TRACE(WMESSAGE,1) From GESECRAN : Break : Endif
Next
If WOK=0 OKHIS=0 : OKEPU=0 : Return : Endif
Gosub EPURE_SOH : # Epuration des textes
If WOK=0 OKHIS=0 : OKEPU=0 : Return : Endif
Return

#--------------------------------------------------------------------------------------------------#
# Commande normale :                                                                               #
# Commande normale :                                                                               #
#                  Ttes les livraisons doivent être facturées,les factures validées                #
# Commande normale intersociété :                                                                  #
#                  Ttes les livraisons doivent être receptionnées,facturées,les factures validées  #
# Commande normale intrasociété :                                                                  #
#                  Ttes les livraisons doivent être validées,réceptionnées                         #
#--------------------------------------------------------------------------------------------------#
$VERF_SOH_NOR
# Si rien n'a été livré sur la commande on peut la purger
# Vérif de ttes les qtés car des qté en US st à 0 alors que les qté en UV sont à tord !
If sum([F:SOQ]ODLQTYSTU,[F:SOQ]DLVQTYSTU,[F:SOQ]INVQTYSTU,[F:SOQ]ODLQTY,[F:SOQ]DLVQTY,[F:SOQ]INVQTY)= 0
    Return
Endif

# La commande a été livrée
If [F:SOQ]ODLQTYSTU<>0 | [F:SOQ]ODLQTY<>0
    #--- Des livraisons ne sont pas validées  : Stop
    WOK=0 : WMESSAGE=[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-mess(440,197,1)-mess(441,197,1)
Else
    #--- Les livraisons sont validées (ODLQTYSTU=0)
    #--- Commande intersite : Les livraisons doivent être réceptionnées
    If [F:F1]BETFCY=2 Gosub VERF_RCP_LIV : If WOK=0 Return Endif : Endif
    #--- Commande normale ou commande intersociété : Les livraisons doivent être facturées, les factures validées
    If [F:F1]BETFCY=1 | ([F:F1]BETFCY=2 & [F:F1]BETCPY=2)
        If [F:SOQ]DLVQTYSTU>[F:SOQ]INVQTYSTU | [F:SOQ]DLVQTY>[F:SOQ]INVQTY
            #--- Les livraisons sont validées (ODLQTYSTU=0) mais tout n'est pas facturé (DLVQTYSTU>INVQTYSTU) : Stop
            #--- On vérifie si ce qui n'est pas facturé a été retourné                     : # Bug 70672
            #WOK=0 : WMESSAGE=[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-mess(437,197,1)            : # Bug 70672
            Gosub VERF_RET_LIV                                                             : # Bug 70672
            If WOK=0 WMESSAGE=[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-mess(437,197,1) Endif      : # Bug 70672
        Elsif [F:SOQ]DLVQTYSTU<=[F:SOQ]INVQTYSTU | [F:SOQ]DLVQTY<=[F:SOQ]INVQTY
            #--- Tout est facturé : Vérif que les factures sont bien validées
            If WCTL_VAL_FAC=0 : Gosub VERF_SOH_VALFAC : Endif
        Endif
    Endif
Endif
Return

#------------------------------------------------------------------------------#
# Vérification que toutes les livraisons sont bien receptionnées               #
#------------------------------------------------------------------------------#
$VERF_RCP_LIV

Columns [SDD] (SDHNUM, SDDLIN, SOHNUM, SOPLIN, SOQSEQ, RCPFLG)
For [SDD]SDD1 Where SOHNUM=[F:SOQ]SOHNUM & SOPLIN=[F:SOQ]SOPLIN & SOQSEQ=[F:SOQ]SOQSEQ & RCPFLG<>2
    # Ligne livrée : Ligne de livraison intersite non réceptionnée
    WOK=0:WMESSAGE=[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-mess(440,197,1)-mess(462,197,1)
    Break
Next
Columns [SDD]
Return

#---------------------------------------------------------------------------------------#
# Commande de prêt : Toutes les livraisons sont validées, toutes les factures validées  #
#---------------------------------------------------------------------------------------#
$VERF_SOH_PRE

If [F:SOQ]ODLQTYSTU<>0 | [F:SOQ]ODLQTY<>0
    # --- Des livraisons ne sont pas validées : Stop
    WOK=0 : WMESSAGE=[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-mess(440,197,1)-mess(441,197,1)
Elsif [F:SOQ]DLVQTYSTU<>0 | [F:SOQ]DLVQTY<>0
    #--- Les livraisons sont validées : Vérif que les livraisons sont retournées
    Gosub VERF_RET_LIV
    If WOK = 0 Return Endif
    If [F:SOQ]INVQTYSTU<>0 | [F:SOQ]INVQTY<>0
    #--- Il y a eu des factures : Vérif que les factures sont bien validées
        If WCTL_VAL_FAC=0 Gosub VERF_SOH_VALFAC Endif
    Endif
Endif
Return
#----------------------------------------------------------------------------------------#
# Commande facturation directe : Commande normale et Commande intersociété               #
#                                Toutes les factures sont validées                       #
# (Une commande à facturation directe ne peut pas être intrasociété)                     #
#----------------------------------------------------------------------------------------#
$VERF_SOH_FAC
If [F:SOQ]ODLQTYSTU<>0 | [F:SOQ]ODLQTY<>0
   #--- Des factures ne sont pas validées : Stop
   WOK=0 : WMESSAGE=[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-mess(442,197,1)-mess(36,119,1)
Endif
Return

#---------------------------------------------------------------------#
# Verification que toutes les factures de la comande sont validées    #
#---------------------------------------------------------------------#
$VERF_SOH_VALFAC
# Pour ne faire la vérif qu'une seule fois (car la vérif. concerne la commande complète)
WCTL_VAL_FAC=1
For [SID]SID1 Where BPCINV=[F:F1]BPCINV & SALFCY=[F:F1]SALFCY & SOHNUM=[F:SOQ]SOHNUM
    Read [SIV]SIV0 = [F:SID]NUM
    If !fstat
        If [F:SIV]INVSTA <> 3 & [F:SIV]INVTYP <> 5
            WOK=0 : WMESSAGE = [F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-mess(442,197,1)-mess(36,119,1)
            Break
        Endif
    Endif
Next
Return
#------------------------------------------------------------------------------#
# Vérification que toutes les livraisons de prêt sont bien retournées          #
# Si elles ne sont pas retournées, ce qui n'est pas retourné doit être facturé #
#------------------------------------------------------------------------------#
$VERF_RET_LIV
Local Decimal WQTYTOINVSTU

# On recherche ce qui n'a pas été retourné
For [SDD]SDD1 Where SOHNUM=[F:SOQ]SOHNUM & SOPLIN=[F:SOQ]SOPLIN & SOQSEQ=[F:SOQ]SOQSEQ
    If [F:SDD]QTYSTU > [F:SDD]RTNQTYSTU WQTYTOINVSTU += ([F:SDD]QTYSTU - [F:SDD]RTNQTYSTU) Endif
Next

# Ce qui n'a pas été retourné doit être facturé
If WQTYTOINVSTU > [F:SOQ]INVQTYSTU
    WOK=0 : WMESSAGE = [F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-mess(439,197,1)
Endif
Return

#-------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'une commande                              #
#-------------------------------------------------------------------------------#
$EPURE_SOH
# --- Supression des textes associés à la commande
WNUMTEX = [F:F1]SOHTEX1
If WNUMTEX <> "" WTYP="SOH1" : Gosub HIS_EPU_TEXTE : Endif
If WOK=0 Return : Endif
WNUMTEX = [F:F1]SOHTEX2
If WNUMTEX <> "" WTYP="SOH2" : Gosub HIS_EPU_TEXTE : Endif
If WOK=0 Return : Endif
# --- Boucle de supression des textes associés aux détails commande
Columns [SOQ] (SOHNUM, SOPLIN, SOQSEQ, SOQTEX)
For [F:SOQ]SOQ0 Where SOHNUM=[F:F1]SOHNUM
    WNUMTEX = [F:SOQ]SOQTEX
    If WNUMTEX <> "" WTYP="SOQ1" : Gosub HIS_EPU_TEXTE : Endif
    If WOK=0 Break : Endif
Next
Columns [SOQ]
# --- Boucle d'historisation-épuration sections analytiques lignes commande -----#
Raz WVCRTYP, WVCRNUM, WVCRLIN, WVCRSEQ, WCPLCLE
Columns [SOP] (SOHNUM, SOPLIN, SOPSEQ)
For [SOP] SOP0 Where SOHNUM=[F:F1]SOHNUM
    WVCRNUM=[F:SOP]SOHNUM : WVCRLIN=[F:SOP]SOPLIN : WVCRSEQ=[F:SOP]SOPSEQ : WABRFIC="SOP"
    Gosub HIS_EPU_CAL
    If WOK=0 Break : Endif
Next
Columns [SOP]
If WOK=0 Return : Endif

# --- Boucle d'historisation-épuration sections analytiques avenants lignes commande -----#
Raz WVCRTYP, WVCRNUM, WVCRLIN, WVCRSEQ, WCPLCLE
Columns [VOP] (SOHNUM, SOPLIN, SOPSEQ, LINREVNUM)
For [VOP] VOP0 Where SOHNUM=[F:F1]SOHNUM
    WVCRNUM=[F:VOP]SOHNUM : WVCRLIN=[F:VOP]SOPLIN : WVCRSEQ=[F:VOP]SOPSEQ : WCPLCLE=num$([F:VOP]LINREVNUM) : WABRFIC="VOP"
    Gosub HIS_EPU_CAL
    If WOK=0 Break : Endif
Next
Columns [VOP]
If WOK=0 Return : Endif

# --- Historisation-épuration SVCRVAT SVCRFOOT
WVCRTYP=20
Gosub HIS_EPU_SVV : If WOK=0 : Return : Endif
Gosub HIS_EPU_SVF : If WOK=0 : Return : Endif

# --- Historisation-épuration des acomptes
WCRITERE='TYP="*SO" & NUM=WCLE'
# Si le module compta est présent, les échéances doivent être soldées
If GMODU(2)=2 WCRITERE-='& FLGCLE=2' Endif
If OKHIS & OKEPU=0
    For [DUD] Where evalue(WCRITERE)
        [F:DUD1] = [F:DUD]
        If dim([F:DUD1]CREHISDAT)>0 : [F:DUD1]CREHISDAT = date$    : Endif
        If dim([F:DUD1]CREHISUSR)>0 : [F:DUD1]CREHISUSR = [V]GUSER : Endif
        If !SIMUL
            Write [F:DUD1]
            If fstat
                WOK=0 : Call ECR_TRACE("$GACCDUDATE"-WCLE-mess(13,100,1),1) From GESECRAN : Break
            Endif
        Endif
    Next
    If WOK=0 : Return : Endif
Endif
If !SIMUL
  Delete [DUD] Where evalue (WCRITERE)
  If fstat=1
      WOK=0 : Call ECR_TRACE("$GACCDUDATE"-WCLE-mess(10,100,1),1) From GESECRAN
  Endif
  If WOK=0 : Return : Endif
Endif

Return


#-------------------------------------------------------------------------------#
#    Historisation/epuration SVCRVAT                                            #
#-------------------------------------------------------------------------------#
#    Historisation         :  OKHIS=1 et OKEPU=0                                #
#    --> Ecriture    des données d'APPLI vers HISAPL                            #
#    --> Suppression des données d'APPLI                                        #
#    Epuration apres histo :  OKHIS=1 et OKEPU=1                                #
#    --> Suppression des données d'HISAPL                                       #
#    Epuration seule       :  OKHIS=0 et OKEPU=1                                #
#    --> Suppression des données d'APPLI                                        #
#-------------------------------------------------------------------------------#
$HIS_EPU_SVV

WCRITERE='VCRTYP=WVCRTYP & VCRNUM=WCLE'
If OKHIS & OKEPU=0
    For [SVV] Where evalue(WCRITERE)
        [F:SVV1] = [F:SVV]
        If dim([F:SVV1]CREHISDAT)>0 : [F:SVV1]CREHISDAT = date$    : Endif
        If dim([F:SVV1]CREHISUSR)>0 : [F:SVV1]CREHISUSR = [V]GUSER : Endif
        If !SIMUL
            Write [F:SVV1]
            If fstat
                WOK=0 : Call ECR_TRACE("$SVCRVAT"-WCLE-mess(13,100,1),1) From GESECRAN : Break
            Endif
        Endif
    Next
    If WOK=0 : Return : Endif
Endif
If !SIMUL
  Delete [SVV] Where evalue (WCRITERE)
  If fstat=1
      WOK=0 : Call ECR_TRACE("$SVCRVAT"-WCLE-mess(10,100,1),1) From GESECRAN
  Endif
  If WOK=0 : Return : Endif
Endif
If [L]TRACEDET
    Call ECR_TRACE ("-- SVCRVAT"-WCLE,0) From GESECRAN
Endif

Return

#-------------------------------------------------------------------------------#
#    Historisation/epuration SVCRFOOT                                           #
#-------------------------------------------------------------------------------#
#    Historisation         :  OKHIS=1 et OKEPU=0                                #
#    --> Ecriture    des données d'APPLI vers HISAPL                            #
#    --> Suppression des données d'APPLI                                        #
#    Epuration apres histo :  OKHIS=1 et OKEPU=1                                #
#    --> Suppression des données d'HISAPL                                       #
#    Epuration seule       :  OKHIS=0 et OKEPU=1                                #
#    --> Suppression des données d'APPLI                                        #
#-------------------------------------------------------------------------------#
$HIS_EPU_SVF

WCRITERE='VCRTYP=WVCRTYP & VCRNUM=WCLE'
If OKHIS & OKEPU=0
    For [SVF] Where evalue(WCRITERE)
        # 85786 : Les sections analytiques des élts de facturation sur gérés pour devis, commandes, livraisons, factures
        ## Uniquement pour les factures : Historisation-épuration sections analytiques éléments de facturation -----#
        #If [F:SVF]VCRTYP=4
        Raz WVCRTYP, WVCRNUM, WVCRLIN, WVCRSEQ, WCPLCLE
        WVCRTYP=[F:SVF]VCRTYP : WVCRNUM=[F:SVF]VCRNUM : WVCRSEQ=[F:SVF]DTA : WABRFIC="SVF"
        Gosub HIS_EPU_CAL
        If WOK=0 Break : Endif
        #Endif    : # 85786
        [F:SVF1] = [F:SVF]
        If dim([F:SVF1]CREHISDAT)>0 : [F:SVF1]CREHISDAT = date$    : Endif
        If dim([F:SVF1]CREHISUSR)>0 : [F:SVF1]CREHISUSR = [V]GUSER : Endif
        If !SIMUL
            Write [F:SVF1]
            If fstat
                WOK=0 : Call ECR_TRACE("$SVCRFOOT"-WCLE-mess(13,100,1),1) From GESECRAN : Break
            Endif
        Endif
    Next
    If WOK=0 : Return : Endif
Endif
If !SIMUL
  Delete [SVF] Where evalue (WCRITERE)
  If fstat=1
      WOK=0 : Call ECR_TRACE("$SVCRFOOT"-WCLE-mess(10,100,1),1) From GESECRAN
  Endif
  If WOK=0 : Return : Endif
Endif
If [L]TRACEDET
    Call ECR_TRACE ("-- SVCRFOOT"-WCLE,0) From GESECRAN
Endif

Return

#-------------------------------------------------------------------------------------#
#    Historisation / Epuration des sections analytiques associées aux lignes document #
#-------------------------------------------------------------------------------------#
#    Historisation         :  OKHIS=1 et OKEPU=0                                      #
#    --> Ecriture    des données d'APPLI vers HISAPL                                  #
#    --> Suppression des données d'APPLI                                              #
#    Epuration apres histo :  OKHIS=1 et OKEPU=1                                      #
#    --> Suppression des données d'HISAPL                                             #
#    Epuration seule       :  OKHIS=0 et OKEPU=1                                      #
#    --> Suppression des données d'APPLI                                              #
#-------------------------------------------------------------------------------------#
$HIS_EPU_CAL

[L]WCLEFIC=[L]WABRFIC-num$([L]WVCRTYP)-[L]WVCRNUM-num$([L]WVCRLIN)-num$([L]WVCRSEQ)-[L]WCPLCLE
#----- Historisation -----#
If OKHIS & OKEPU=0
  Read [CAL] CAL0=[L]WABRFIC;[L]WVCRTYP;[L]WVCRNUM;[L]WVCRLIN;[L]WVCRSEQ;[L]WCPLCLE;1
  If !fstat & ![L]SIMUL
    [F:CAL1]=[F:CAL]
    If dim([F:CAL1]CREHISDAT)>0  [F:CAL1]CREHISDAT=date$    : Endif
    If dim([F:CAL1]CREHISUSR)>0  [F:CAL1]CREHISUSR=[V]GUSER : Endif
    Write [CAL1]
    If fstat
      Call ECR_TRACE("$CPTANALIN"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
      WOK=0 : Return
    Endif
  Endif
Endif
#----- Epuration -----#
If ![L]SIMUL
  Delete [CAL] Where ABRFIC=[L]WABRFIC
&                  & VCRTYP=[L]WVCRTYP
&                  & VCRNUM=[L]WVCRNUM
&                  & VCRLIN=[L]WVCRLIN
&                  & VCRSEQ=[L]WVCRSEQ
&                  & CPLCLE=[L]WCPLCLE
&                  & ANALIG=1
  If fstat
    Call ECR_TRACE("$CPTANALIN"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
#-----
If [L]TRACEDET
  Call ECR_TRACE("-- CPTANALIN"-[L]WCLEFIC,0) From GESECRAN
Endif
#-----
Return

#-------------------------------------------------------------------------------#
#    Fermeture des fichiers complémentaires                                     #
#-------------------------------------------------------------------------------#
$FERME_EPU_SOH
If clalev([F:SOQ])  : Close Local File [SOQ] : Endif
If clalev([F:SOP])  : Close Local File [SOP] : Endif
If clalev([F:VOP])  : Close Local File [VOP] : Endif
If clalev([F:SIV])  : Close Local File [SIV] : Endif
If clalev([F:SID])  : Close Local File [SID] : Endif
If clalev([F:SDD])  : Close Local File [SDD] : Endif
If clalev([F:DUD])  : Close Local File [DUD] : Endif
If clalev([F:SVV])  : Close Local File [SVV] : Endif
If clalev([F:SVF])  : Close Local File [SVF] : Endif
If clalev([F:CAL])  : Close Local File [CAL] : Endif
If clalev([F:DUD1]) : Close Local File [DUD1] : Endif
If clalev([F:SVV1]) : Close Local File [SVV1] : Endif
If clalev([F:SVF1]) : Close Local File [SVF1] : Endif
If clalev([F:CAL1]) : Close Local File [CAL1] : Endif
Return

#################################################################################
#    Epuration des contrats                                                     #
# ------------------------------------------------------------------------------#
#    SOR : Actions liées à l'épuration des contrats                             #
# ------------------------------------------------------------------------------#
#    Formule d'épuration :                                                      #
#    (SOHCAT=4 & BETFCY<>2)                                                     #
#################################################################################
#-------------------------------------------------------------------------------#
#    Ouvertures des fichiers complémentaires                                    #
#-------------------------------------------------------------------------------#
$OUVRE_EPU_SOR

If HISTO
    If OKEPU=0
      #-- Historisation
      If clalev([F:SOC])=0 : Local File =[L]APPLI+".SORDERC"     [SOC]   : Endif
      If clalev([F:SOQ])=0 : Local File =[L]APPLI+".SORDERQ"     [SOQ]   : Endif
      If clalev([F:SOP])=0 : Local File =[L]APPLI+".SORDERP"     [SOP]   : Endif
      If clalev([F:VOP])=0 : Local File =[L]APPLI+".VSORDERP"    [VOP]   : Endif
      If clalev([F:SDH])=0 : Local File =[L]APPLI+".SDELIVERY"   [SDH]   : Endif
      If clalev([F:SDD])=0 : Local File =[L]APPLI+".SDELIVERYD"  [SDD]   : Endif
      If clalev([F:SIV])=0 : Local File =[L]APPLI+".SINVOICEV"   [SIV]   : Endif
      If clalev([F:CAL])=0 : Local File =[L]APPLI+".CPTANALIN"   [CAL]   : Endif
      #-----------------------#
      # Fichier historisation #
      #-----------------------#
      TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
      If clalev([F:CAL1])= 0 : Local File =[L]HISAPL+".CPTANALIN"  [CAL1] : Endif
    Else
      #-- Epuration après historisation (Pour les vérifs et épuration du texte lié)
      If clalev([F:SOC])=0 : Local File =[L]HISAPL+".SORDERC"    [SOC]   : Endif
      If clalev([F:SOQ])=0 : Local File =[L]HISAPL+".SORDERQ"    [SOQ]   : Endif
      If clalev([F:SOP])=0 : Local File =[L]HISAPL+".SORDERP"    [SOP]   : Endif
      If clalev([F:VOP])=0 : Local File =[L]HISAPL+".VSORDERP"   [VOP]   : Endif
      If clalev([F:SDH])=0 : Local File =[L]HISAPL+".SDELIVERY"  [SDH]   : Endif
      If clalev([F:SDD])=0 : Local File =[L]HISAPL+".SDELIVERYD" [SDD]   : Endif
      If clalev([F:SIV])=0 : Local File =[L]HISAPL+".SINVOICEV"  [SIV]   : Endif
      If clalev([F:CAL])=0 : Local File =[L]HISAPL+".CPTANALIN"  [CAL]   : Endif
    Endif
Else
    #-- Epuration seule (Pour les vérifs et épuration du texte lié)
    If clalev([F:SOC])=0   : Local File =[L]APPLI+".SORDERC"     [SOC]   : Endif
    If clalev([F:SOQ])=0   : Local File =[L]APPLI+".SORDERQ"     [SOQ]   : Endif
    If clalev([F:SOP])=0   : Local File =[L]APPLI+".SORDERP"     [SOP]   : Endif
    If clalev([F:VOP])=0   : Local File =[L]APPLI+".VSORDERP"    [VOP]   : Endif
    If clalev([F:SDH])=0   : Local File =[L]APPLI+".SDELIVERY"   [SDH]   : Endif
    If clalev([F:SDD])=0   : Local File =[L]APPLI+".SDELIVERYD"  [SDD]   : Endif
    If clalev([F:SIV])=0   : Local File =[L]APPLI+".SINVOICEV"   [SIV]   : Endif
    If clalev([F:CAL])=0   : Local File =[L]APPLI+".CPTANALIN"   [CAL]   : Endif
Endif

Gosub DEFVAR
Return

#---------------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'un contrat                                        #
#    Contrôles à effectuer avant l'épuration d'un contrat (WOK=0 pour refuser)          #
#                                                                                       #
# (NB:Les contrats intersite ne sont pas traités car ils sont épurés depuis les achats) #
#---------------------------------------------------------------------------------------#
$HIS_EPU_SOR
WCLE=[F:F1]SOHNUM
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif

WOK=1
# Toutes les DL du contrats doivent être soldées
Columns [SOQ] (SOHNUM,SOQSTA)
For  [SOQ]SOQ0 Where SOHNUM = [F:F1]SOHNUM & SOQSTA<>3
    WOK=0:WMESSAGE = [F:F1]SOHNUM-mess(432,197,1): Call ECR_TRACE (WMESSAGE,1) From GESECRAN
    Break
Next
Columns [SOQ]
If WOK=0 OKHIS=0 : OKEPU=0 : Return : Endif

# Tous les BLS doivent être validés et facturés
Gosub VERF_SDH
If WOK=0 OKHIS=0 : OKEPU=0 : Return : Endif

Gosub EPURE_SOR
If WOK=0 OKHIS=0 : OKEPU=0 : Return : Endif

Return

#---------------------------------------------------------------------------------#
# Vérification que les livraisons sont validées et facturées                      #
#---------------------------------------------------------------------------------#
$VERF_SDH

Columns [SDD] (SOHNUM,SDHNUM)
For  [SDD]SDD1 Where [SDD]SOHNUM = [F:F1]SOHNUM
    Read [SDH]SDH0=[F:SDD]SDHNUM
    If !fstat
        If [F:SDH]BETFCY = 2 and [F:SDH]BETCPY = 1 Then
          # FGR 29/08/2014 : X3SUIVI92847 : Si intersite : pas de facturation : donc on peut supprimer
        Else
          If [F:SDH]INVFLG=1
              #           Livraison non facturée : Stop
              WOK=0:WMESSAGE = [F:F1]SOHNUM-[F:SDH]SDHNUM-mess(437,197,1) : Break
          Else
              #           Livraison facturée     : La facture doit être validée
              Read [SIV]SIV0 = [F:SDH]SIHNUM
              If !fstat
                  If [F:SIV]INVSTA <> 3
                      #                   Facture non validée : Stop
                      WOK=0:WMESSAGE = [F:F1]SOHNUM-[F:SIV]NUM-mess(36,119,1) : Break
                  Endif
              Endif
          Endif
        Endif
    Endif
Next
If WOK=0 Call ECR_TRACE (WMESSAGE,1) From GESECRAN : Endif
Columns [SDD]
Return

#-------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'un contrat                                #
#-------------------------------------------------------------------------------#
$EPURE_SOR
# --- Supression des textes associés au contrat épuré
WNUMTEX = [F:F1]SOHTEX1
If WNUMTEX <> "" WTYP="SOH1" : Gosub HIS_EPU_TEXTE : Endif
If WOK=0 Return : Endif
WNUMTEX = [F:F1]SOHTEX2
If WNUMTEX <> "" WTYP="SOH2" : Gosub HIS_EPU_TEXTE : Endif
If WOK=0 Return : Endif

Columns [SOC] (SOHNUM, SOPLIN, SOCTEX)
For [SOC]SOC0 Where SOHNUM=[F:F1]SOHNUM
#   --- Boucle de supression des textes associés aux demandes de livraisons liées à l'article
    Columns [SOQ] (SOHNUM, SOPLIN, SOQSEQ, SOQTEX)
    For [F:SOQ]SOQ0 Where SOHNUM=[F:SOC]SOHNUM & SOPLIN=[F:SOC]SOPLIN
        WNUMTEX = [F:SOQ]SOQTEX
        If WNUMTEX <> "" WTYP="SOQ1" : Gosub HIS_EPU_TEXTE : Endif
        If WOK=0 Break : Endif
    Next
    Columns [SOQ]
    If WOK=0 Break : Endif

#   --- Supression des textes associés à l'article
    WNUMTEX = [F:SOC]SOCTEX
    If WNUMTEX <> "" WTYP="SOC1" : Gosub HIS_EPU_TEXTE : Endif
    If WOK=0 Break : Endif

#   --- Boucle d'historisation-épuration sections analytiques lignes commande -----#
    Raz WVCRTYP, WVCRNUM, WVCRLIN, WVCRSEQ, WCPLCLE
    Columns [SOP] (SOHNUM, SOPLIN, SOPSEQ)
    For [SOP] SOP0 Where SOHNUM=[F:F1]SOHNUM
        WVCRNUM=[F:SOP]SOHNUM : WVCRLIN=[F:SOP]SOPLIN : WVCRSEQ=[F:SOP]SOPSEQ : WABRFIC="SOP"
        Gosub HIS_EPU_CAL
        If WOK=0 Break : Endif
    Next
    Columns [SOP]
    If WOK=0 Break : Endif

#   --- Boucle d'historisation-épuration sections analytiques avenants lignes commande -----#
    Raz WVCRTYP, WVCRNUM, WVCRLIN, WVCRSEQ, WCPLCLE
    Columns [VOP] (SOHNUM, SOPLIN, SOPSEQ, LINREVNUM)
    For [VOP] VOP0 Where SOHNUM=[F:F1]SOHNUM
        WVCRNUM=[F:VOP]SOHNUM : WVCRLIN=[F:VOP]SOPLIN : WVCRSEQ=[F:VOP]SOPSEQ : WCPLCLE=num$([F:VOP]LINREVNUM) : WABRFIC="VOP"
        Gosub HIS_EPU_CAL
        If WOK=0  Break : Endif
    Next
    Columns [VOP]
    If WOK=0 Break : Endif
Next
Columns [SOC]
If WOK=0 Return : Endif
Return

#-------------------------------------------------------------------------------#
#    Fermeture des fichiers complémentaires                                     #
#-------------------------------------------------------------------------------#
$FERME_EPU_SOR
If clalev([F:SOC])  : Close Local File [SOC]  : Endif
If clalev([F:SOQ])  : Close Local File [SOQ]  : Endif
If clalev([F:SOP])  : Close Local File [SOP]  : Endif
If clalev([F:VOP])  : Close Local File [VOP]  : Endif
If clalev([F:SDH])  : Close Local File [SDH]  : Endif
If clalev([F:SDD])  : Close Local File [SDD]  : Endif
If clalev([F:SIV])  : Close Local File [SIV]  : Endif
If clalev([F:CAL])  : Close Local File [CAL]  : Endif
If clalev([F:CAL1]) : Close Local File [CAL1] : Endif
Return

#################################################################################
#    Epuration des livraisons                                                   #
# ------------------------------------------------------------------------------#
#    SDH : Actions liées à l'épuration des livraisons                           #
# ------------------------------------------------------------------------------#
#    Formule d'épuration :                                                      #
#    (CFMFLG=2)                                                                 #
#################################################################################
#-------------------------------------------------------------------------------#
#    Ouvertures des fichiers complémentaires                                    #
#-------------------------------------------------------------------------------#
$OUVRE_EPU_SDH
If HISTO
    If OKEPU=0
      #-- Historisation
      If clalev([F:SDD])=0 : Local File =[L]APPLI+".SDELIVERYD"  [SDD]   : Endif
      If clalev([F:SIV])=0 : Local File =[L]APPLI+".SINVOICEV"   [SIV]   : Endif
      If clalev([F:SRD])=0 : Local File =[L]APPLI+".SRETURND"    [SRD]   : Endif
      If clalev([F:SVV])=0 : Local File =[L]APPLI+".SVCRVAT"     [SVV]   : Endif
      If clalev([F:SVF])=0 : Local File =[L]APPLI+".SVCRFOOT"    [SVF]   : Endif
      If clalev([F:CAL])=0 : Local File =[L]APPLI+".CPTANALIN"   [CAL]   : Endif
      #-----------------------#
      # Fichier historisation #
      #-----------------------#
      TABLE="SVCRVAT"    : Gosub CRETAB_HISTO
      If clalev([F:SVV1])= 0 : Local File =[L]HISAPL+".SVCRVAT"   [SVV1] : Endif
      TABLE="SVCRFOOT"   : Gosub CRETAB_HISTO
      If clalev([F:SVF1])= 0 : Local File =[L]HISAPL+".SVCRFOOT"  [SVF1] : Endif
      TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
      If clalev([F:CAL1])= 0 : Local File =[L]HISAPL+".CPTANALIN" [CAL1] : Endif
    Else
      #-- Epuration après historisation (Pour les vérifs et épuration du texte lié)
      If clalev([F:SDD])=0 : Local File =[L]HISAPL+".SDELIVERYD" [SDD]   : Endif
      If clalev([F:SIV])=0 : Local File =[L]HISAPL+".SINVOICEV"  [SIV]   : Endif
      If clalev([F:SRD])=0 : Local File =[L]HISAPL+".SRETURND"   [SRD]   : Endif
      If clalev([F:SVV])=0 : Local File =[L]HISAPL+".SVCRVAT"    [SVV]   : Endif
      If clalev([F:SVF])=0 : Local File =[L]HISAPL+".SVCRFOOT"   [SVF]   : Endif
      If clalev([F:CAL])=0 : Local File =[L]HISAPL+".CPTANALIN"  [CAL]   : Endif
    Endif
Else
    #-- Epuration seule (Pour les vérifs et épuration du texte lié)
    If clalev([F:SDD])=0   : Local File =[L]APPLI+".SDELIVERYD"  [SDD]   : Endif
    If clalev([F:SIV])=0   : Local File =[L]APPLI+".SINVOICEV"   [SIV]   : Endif
    If clalev([F:SRD])=0   : Local File =[L]APPLI+".SRETURND"    [SRD]   : Endif
    If clalev([F:SVV])=0   : Local File =[L]APPLI+".SVCRVAT"     [SVV]   : Endif
    If clalev([F:SVF])=0   : Local File =[L]APPLI+".SVCRFOOT"    [SVF]   : Endif
    If clalev([F:CAL])=0   : Local File =[L]APPLI+".CPTANALIN"   [CAL]   : Endif
Endif

Gosub DEFVAR
Return
#----------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'une livraison                                #
#    Contrôles à effectuer avant l'épuration d'une livraison (WOK=0 pour refuser)  #
#----------------------------------------------------------------------------------#
$HIS_EPU_SDH
WCLE=[F:F1]SDHNUM
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif
WOK=1
Raz WMESSAGE
If [F:F1]LND=1
    If [F:F1]BETFCY=2 Gosub VERF_SDH_BETFCY Endif
    If [F:F1]BETFCY=1 | ([F:F1]BETCPY=2 & WOK=1) Gosub VERF_SDH_NOR Endif
Else
    Gosub VERF_SDH_PRE
Endif
If WOK=0 Call ECR_TRACE(WMESSAGE,1) From GESECRAN : OKHIS=0 : OKEPU=0 : Return : Endif

Gosub EPURE_SDH : # Epuration des textes
If WOK=0  OKHIS=0 : OKEPU=0 : Return : Endif
Return
#---------------------------------------------------------------------------------------#
# Livraison normale ou livraison intersite intersociété                                 #
#                     Elle doit être facturée et la facture validée                     #
#                     Si retours avec avoir : Les avoirs doivent être créés et validés  #
#---------------------------------------------------------------------------------------#
$VERF_SDH_NOR
# Pas de contrôle à faire pour les livraisons de sous-traitance
If [F:F1]SCO = 2 Return : Endif

WMESSAGE=[F:F1]SDHNUM
# --- Contrôle concernant la facture
Gosub VERF_SDH_FAC
If WOK=0 : Return : Endif

# --- Contrôle concernant les retours eventuels
Columns [SRD] (SRHNUM, SRDLIN, SDHNUM, RTNCNOFLG, SIHNUM)
Filter [SRD] Where SDHNUM = [F:F1]SDHNUM Order By Key SRD1
For [SRD]
    If [F:SRD]RTNCNOFLG = 2 & [F:SRD]SIHNUM = ""
#       Retour avec avoir et avoir non créé
        WMESSAGE-=mess(444,197,1)-[F:SRD]SRHNUM-mess(438,197,1) : WOK=0 : Break
    # 85786 : Si l'avoir existe, il doit être validé
    Elsif [F:SRD]RTNCNOFLG = 2 & [F:SRD]SIHNUM <> ""
#       Retour avec avoir et avoir créé
        Read [SIV]SIV0=[F:SRD]SIHNUM
        #   L'avoir peut ne plus exister (si la purge facture a déjà été lancée)
        If !fstat Then
          # S'il existe, il doit être validé
          If [F:SIV]INVSTA <> 3 Then
            WMESSAGE -= mess(444,197,1)-[F:SRD]SRHNUM-mess(459,197,1)-[F:SIV]NUM : WOK = 0 : Break
          Endif
        Endif
    # 85786
    Endif
Next
Filter [SRD]
Columns [SRD]
Return

#---------------------------------------------------------------------------------------#
# Livraison inter-site : Les lignes doivent être receptionnées                          #
#---------------------------------------------------------------------------------------#
$VERF_SDH_BETFCY

WMESSAGE=[F:F1]SDHNUM

Columns [SDD] (SDHNUM,SDDLIN,SOHCAT, RCPFLG)
For  [SDD]SDD0 Where SDHNUM = [F:F1]SDHNUM & RCPFLG<>2
    WOK=0:WMESSAGE -= num$([F:SDD]SDDLIN)-mess(462,197,1)
    Break
Next
Columns [SDD]
If WOK=0 Return Endif
Return

#---------------------------------------------------------------------------------------#
# Livraison de prêt : Tout est retourné       : WOK                                      #
#                     Tout n'est pas retourné : La livraison doit être facturée         #
#                                               La facture doit être validée            #
#---------------------------------------------------------------------------------------#
$VERF_SDH_PRE

If [F:F1]RTNSTA = 3 Return : Endif
WMESSAGE=[F:F1]SDHNUM-mess(439,197,1)
# --- Contrôle concernant une livraison partiellement retournée
Gosub VERF_SDH_FAC

Return

#---------------------------------------------------------------------#
# Verification concernant la facture                                  #
#---------------------------------------------------------------------#
$VERF_SDH_FAC
  If [F:F1]INVFLG=2 & [F:F1]SIHNUM <> "" Then
    #   Livraison facturée
    Read [SIV]SIV0=[F:F1]SIHNUM
    #   La facture peut ne plus exister (si la purge facture a déjà été lancée)
    If !fstat Then
      # Si elle existe, elle doit être validée
      If [F:SIV]INVSTA <> 3 Then
        WMESSAGE -= mess(443,197,1) - [F:SIV]NUM - mess(36,119,1)
        WOK = 0
        Return
      Endif
    Endif
  Else
    #   Livraison non facturée
    If [F:F1]BETFCY = 2 and [F:F1]BETCPY = 1 Then
      # FGR 12/08/2014 : X3SUIVI92847 : Ne pas rendre une erreur sur l'intersite réceptionné qui ne sera jamais facturé.
      Columns [SDD] (SDHNUM, SDDLIN, RCPFLG, QTYSTU, RCPQTYSTU)
      For [SDD]SDD0 Where SDHNUM = [F:F1]SDHNUM and (RCPFLG = 0 or RCPFLG = 1 or (RCPFLG = 2 and QTYSTU <> RCPQTYSTU))
        WMESSAGE -= mess(835,197,1)
        WOK = 0
        Break
      Next
      Columns [SDD]
    Else
      #   On peut l'épurer si elle a été entièrement retournée
      Columns [SDD] (SDHNUM, SDDLIN, QTY, RTNQTY)
      For [SDD]SDD0 Where SDHNUM = [F:F1]SDHNUM & QTY>RTNQTY
        #       Cette ligne n'est pas entièrement retournée : La livraison doit être facturée
        WMESSAGE -= mess(437,197,1)
        WOK = 0
        Break
      Next
      Filter [SDD]
      Columns [SDD]
    Endif
  Endif
Return


#---------------------------------------------------------------------------------------------#
# Verification concernant les livraisons non facturées                                        #
# Si la livraison n'a pas été facturée, on peut l'épurer ssi elle a été entièrement retournée #
#---------------------------------------------------------------------------------------------#
$VERF_SDH_RTN

Return

#-------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'une livraison                             #
#-------------------------------------------------------------------------------#
$EPURE_SDH

# --- Supression des textes associés à la livraison
WNUMTEX = [F:F1]PRPTEX1
If WNUMTEX <> "" WTYP="SDH1" : Gosub HIS_EPU_TEXTE : Endif
If WOK=0 Return : Endif
WNUMTEX = [F:F1]PRPTEX2
If WNUMTEX <> "" WTYP="SDH2" : Gosub HIS_EPU_TEXTE : Endif
If WOK=0 Return : Endif
WNUMTEX = [F:F1]SDHTEX1
If WNUMTEX <> "" WTYP="SDH3" : Gosub HIS_EPU_TEXTE : Endif
If WOK=0 Return : Endif
WNUMTEX = [F:F1]SDHTEX2
If WNUMTEX <> "" WTYP="SDH4" : Gosub HIS_EPU_TEXTE : Endif
If WOK=0 Return : Endif

# --- Boucle de supression des textes associés aux détails livraison
# --- Boucle d'historisation-épuration sections analytiques lignes livraison
Raz WVCRTYP, WVCRNUM, WVCRLIN, WVCRSEQ, WCPLCLE
Columns [SDD] (SDHNUM, SDDLIN, PRPTEX, SDDTEX)
For [F:SDD]SDD0 Where SDHNUM=[F:F1]SDHNUM
    WNUMTEX = [F:SDD]PRPTEX
    If WNUMTEX <> "" WTYP="SDD1" : Gosub HIS_EPU_TEXTE : Endif
    If WOK=0 Break : Endif
    WNUMTEX = [F:SDD]SDDTEX
    If WNUMTEX <> "" WTYP="SDD2" : Gosub HIS_EPU_TEXTE : Endif
    If WOK=0 Break : Endif
    WVCRNUM=[F:SDD]SDHNUM : WVCRLIN=[F:SDD]SDDLIN : WABRFIC="SDD"
    Gosub HIS_EPU_CAL
    If WOK=0  Break : Endif
Next
Columns [SDD]
If WOK=0 Return : Endif

# --- Historisation-épuration SVCRVAT SVCRFOOT
WVCRTYP=2
Gosub HIS_EPU_SVV : If WOK=0 Return : Endif
Gosub HIS_EPU_SVF : If WOK=0 Return : Endif
Return

#-------------------------------------------------------------------------------#
#    Fermeture des fichiers complémentaires                                     #
#-------------------------------------------------------------------------------#
$FERME_EPU_SDH
If clalev([F:SDD])  : Close Local File [SDD]  : Endif
If clalev([F:SIV])  : Close Local File [SIV]  : Endif
If clalev([F:SRD])  : Close Local File [SRD]  : Endif
If clalev([F:SVV])  : Close Local File [SVV]  : Endif
If clalev([F:SVF])  : Close Local File [SVF]  : Endif
If clalev([F:CAL])  : Close Local File [CAL]  : Endif
If clalev([F:SVV1]) : Close Local File [SVV1] : Endif
If clalev([F:SVF1]) : Close Local File [SVF1] : Endif
If clalev([F:CAL1]) : Close Local File [CAL1] : Endif
Return

#################################################################################
#    Epuration des retours                                                      #
# ------------------------------------------------------------------------------#
#    SRH : Actions liées à l'épuration des retours                              #
# ------------------------------------------------------------------------------#
#    Formule d'épuration :                                                      #
#    (LNDRTN <> 2 & SCORTN <> 2)                                                #
#################################################################################
#-------------------------------------------------------------------------------#
#    Ouvertures des fichiers complémentaires                                    #
#-------------------------------------------------------------------------------#
$OUVRE_EPU_SRH

If HISTO
    If OKEPU=0
      #-- Historisation
      If clalev([F:SIV])=0   : Local File =[L]APPLI+".SINVOICEV"   [SIV]   : Endif
      If clalev([F:SRD])=0   : Local File =[L]APPLI+".SRETURND"    [SRD]   : Endif
      If clalev([F:CAL])=0   : Local File =[L]APPLI+".CPTANALIN"   [CAL]   : Endif
      TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
      If clalev([F:CAL1])= 0 : Local File =[L]HISAPL+".CPTANALIN"  [CAL1]  : Endif
    Else
      #-- Epuration après historisation (Pour les vérifs et épuration du texte lié)
      If clalev([F:SIV])=0   : Local File =[L]HISAPL+".SINVOICEV"  [SIV]   : Endif
      If clalev([F:SRD])=0   : Local File =[L]HISAPL+".SRETURND"   [SRD]   : Endif
      If clalev([F:CAL])=0   : Local File =[L]HISAPL+".CPTANALIN"  [CAL]   : Endif
      If clalev([F:SVV])=0   : Local File =[L]HISAPL+".SVCRVAT"    [SVV]   : Endif
      If clalev([F:SVF])=0   : Local File =[L]HISAPL+".SVCRFOOT"   [SVF]   : Endif
    Endif
Else
    #-- Epuration seule (Pour les vérifs et épuration du texte lié)
    If clalev([F:SIV])=0   : Local File =[L]APPLI+".SINVOICEV"     [SIV]   : Endif
    If clalev([F:SRD])=0   : Local File =[L]APPLI+".SRETURND"      [SRD]   : Endif
    If clalev([F:CAL])=0   : Local File =[L]APPLI+".CPTANALIN"     [CAL]   : Endif
    If clalev([F:SVV])=0   : Local File =[L]APPLI+".SVCRVAT"       [SVV]   : Endif
    If clalev([F:SVF])=0   : Local File =[L]APPLI+".SVCRFOOT"      [SVF]   : Endif
Endif

Gosub DEFVAR

Return

#-------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'un retour                                 #
#    Contrôles à effectuer avant l'épuration d'un retour (WOK=0 pour refuser)   #
#-------------------------------------------------------------------------------#
$HIS_EPU_SRH

WCLE=[F:F1]SRHNUM
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif

WOK=1
# Si des lignes avec avoir, les avoirs doivent être crées et validés
WMESSAGE=[F:F1]SRHNUM
Columns [SRD] (SRHNUM, SRDLIN, RTNCNOFLG, SIHNUM)
Filter [SRD] Where SRHNUM = [F:F1]SRHNUM & RTNCNOFLG=2 Order By Key SRD2
For [SRD] Hint Key SRD0
    If [F:SRD]SIHNUM = ""
#       Avoir non créé
        WMESSAGE-=num$([F:SRD]SRDLIN)-mess(438,197,1) : WOK=0 : Break
    Else
#       Avoir créé : est-il validé ?
        Gosub VERF_SRH_AVO : If WOK=0 Break : Endif
    Endif
Next
Filter [SRD]
Columns [SRD]
If WOK=0 Call ECR_TRACE(WMESSAGE,1) From GESECRAN : OKHIS=0 : OKEPU=0 : Return : Endif

Gosub EPURE_SRH : # Epuration des textes
If WOK=0 OKHIS=0 : OKEPU=0 : Return : Endif
Return

#---------------------------------------------------------------------#
# Verification concernant l'avoir : Il doit être validé               #
#---------------------------------------------------------------------#
$VERF_SRH_AVO

Read [SIV]SIV0 = [F:SRD]SIHNUM
# L'avoir peut ne plus exister (si la purge facture a déjà été lancée)
If !fstat
    If [F:SIV]INVSTA <> 3 WMESSAGE-=num$([F:SRD]SRDLIN)-[F:SIV]NUM -mess(459,197,1) : WOK=0 : Return : Endif
Endif
Return

#-------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'un retour                                 #
#-------------------------------------------------------------------------------#
$EPURE_SRH
# --- Supression des textes associés au retour
WNUMTEX = [F:F1]SRHTEX1
If WNUMTEX <> "" WTYP="SRH1" : Gosub HIS_EPU_TEXTE : Endif
If WOK=0 Return : Endif
WNUMTEX = [F:F1]SRHTEX2
If WNUMTEX <> "" WTYP="SRH2" : Gosub HIS_EPU_TEXTE : Endif
If WOK=0 Return : Endif
# --- Boucle de supression des textes associés aux détails retours
# --- Boucle d'historisation-épuration sections analytiques lignes retour
Raz WVCRTYP, WVCRNUM, WVCRLIN, WVCRSEQ, WCPLCLE
Columns [SRD] (SRHNUM, SRDLIN, SRDTEX)
For [F:SRD]SRD0 Where SRHNUM=[F:F1]SRHNUM
    WNUMTEX = [F:SRD]SRDTEX
    If WNUMTEX <> "" WTYP="SRD1" : Gosub HIS_EPU_TEXTE : Endif
    If WOK=0 Break : Endif
    WVCRNUM=[F:SRD]SRHNUM : WVCRLIN=[F:SRD]SRDLIN : WABRFIC="SRD"
    Gosub HIS_EPU_CAL
    If WOK=0 Break : Endif
Next
Columns [SRD]
If WOK=0 Return : Endif

Return

#-------------------------------------------------------------------------------#
#    Fermeture des fichiers complémentaires                                     #
#-------------------------------------------------------------------------------#
$FERME_EPU_SRH
If clalev([F:SIV])  : Close Local File [SIV]  : Endif
If clalev([F:SRD])  : Close Local File [SRD]  : Endif
If clalev([F:CAL])  : Close Local File [CAL]  : Endif
If clalev([F:CAL1]) : Close Local File [CAL1] : Endif
Return


#################################################################################
#    Epuration des retours de prêt                                              #
# ------------------------------------------------------------------------------#
#    SRL : Actions liées à l'épuration des retours de prêt                      #
# ------------------------------------------------------------------------------#
#    Formule d'épuration :                                                      #
#    (LNDRTN = 2 & SCORTN<>2)                                                   #
#################################################################################
#-------------------------------------------------------------------------------#
#    Ouvertures des fichiers complémentaires                                    #
#-------------------------------------------------------------------------------#
$OUVRE_EPU_SRL

If HISTO
    If OKEPU=0
      #-- Historisation
      If clalev([F:SRD])=0   : Local File =[L]APPLI+".SRETURND"    [SRD]   : Endif
      If clalev([F:CAL])=0   : Local File =[L]APPLI+".CPTANALIN"   [CAL]   : Endif
      TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
      If clalev([F:CAL1])= 0 : Local File =[L]HISAPL+".CPTANALIN"  [CAL1]  : Endif
    Else
      #-- Epuration après historisation (Pour les vérifs)
      If clalev([F:SRD])=0   : Local File =[L]HISAPL+".SRETURND"   [SRD]   : Endif
      If clalev([F:CAL])=0   : Local File =[L]HISAPL+".CPTANALIN"  [CAL]   : Endif
    Endif
Else
    #-- Epuration seule (Pour les vérifs)
    If clalev([F:SRD])=0     : Local File =[L]APPLI+".SRETURND"    [SRD]   : Endif
    If clalev([F:CAL])=0     : Local File =[L]APPLI+".CPTANALIN"   [CAL]   : Endif
Endif

Gosub DEFVAR
Return

#-------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'un retour                                 #
#    Contrôles à effectuer avant l'épuration d'un retour (WOK=0 pour refuser)   #
#-------------------------------------------------------------------------------#
$HIS_EPU_SRL

WCLE=[F:F1]SRHNUM
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif

WOK=1
# --- Boucle d'historisation-épuration sections analytiques lignes retour
Raz WVCRTYP, WVCRNUM, WVCRLIN, WVCRSEQ, WCPLCLE
Columns [SRD] (SRHNUM, SRDLIN, SRDTEX)
For [F:SRD]SRD0 Where SRHNUM=[F:F1]SRHNUM
    WVCRNUM=[F:SRD]SRHNUM : WVCRLIN=[F:SRD]SRDLIN : WABRFIC="SRD"
    Gosub HIS_EPU_CAL
    If WOK=0 Break : Endif
Next
Columns [SRD]
If WOK=0 OKHIS=0 : OKEPU=0 : Return : Endif

Return

#-------------------------------------------------------------------------------#
#    Fermeture des fichiers complémentaires                                     #
#-------------------------------------------------------------------------------#
$FERME_EPU_SRL
If clalev([F:SRD])  : Close Local File [SRD]  : Endif
If clalev([F:CAL])  : Close Local File [CAL]  : Endif
If clalev([F:CAL1]) : Close Local File [CAL1] : Endif
Return

#################################################################################
#    Epuration des retours de sous-traitance                                    #
# ------------------------------------------------------------------------------#
#    SRS : Actions liées à l'épuration des retours de sous-traitance            #
# ------------------------------------------------------------------------------#
#    Formule d'épuration :                                                      #
#    SCORTN = 2                                                                 #
#################################################################################
#-------------------------------------------------------------------------------#
#    Ouvertures des fichiers complémentaires                                    #
#-------------------------------------------------------------------------------#
$OUVRE_EPU_SRS

If HISTO
    If OKEPU=0
      #-- Historisation
      If clalev([F:SRD])=0   : Local File =[L]APPLI+".SRETURND"    [SRD]   : Endif
      If clalev([F:CAL])=0   : Local File =[L]APPLI+".CPTANALIN"   [CAL]   : Endif
      TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
      If clalev([F:CAL1])= 0 : Local File =[L]HISAPL+".CPTANALIN"  [CAL1]  : Endif
    Else
      #-- Epuration après historisation (Pour les vérifs)
      If clalev([F:SRD])=0   : Local File =[L]HISAPL+".SRETURND"   [SRD]   : Endif
      If clalev([F:CAL])=0   : Local File =[L]HISAPL+".CPTANALIN"  [CAL]   : Endif
    Endif
Else
    #-- Epuration seule (Pour les vérifs)
    If clalev([F:SRD])=0     : Local File =[L]APPLI+".SRETURND"    [SRD]   : Endif
    If clalev([F:CAL])=0     : Local File =[L]APPLI+".CPTANALIN"   [CAL]   : Endif
Endif

Gosub DEFVAR
Return

#-------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'un retour                                 #
#    Contrôles à effectuer avant l'épuration d'un retour (WOK=0 pour refuser)   #
#-------------------------------------------------------------------------------#
$HIS_EPU_SRS
WCLE=[F:F1]SRHNUM
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif

WOK=1
# --- Boucle d'historisation-épuration sections analytiques lignes retour
Raz WVCRTYP, WVCRNUM, WVCRLIN, WVCRSEQ, WCPLCLE
Columns [SRD] (SRHNUM, SRDLIN, SRDTEX)
For [F:SRD]SRD0 Where SRHNUM=[F:F1]SRHNUM
    WVCRNUM=[F:SRD]SRHNUM : WVCRLIN=[F:SRD]SRDLIN : WABRFIC="SRD"
    Gosub HIS_EPU_CAL
    If WOK=0 Break : Endif
Next
Columns [SRD]
If WOK=0 OKHIS=0 : OKEPU=0 : Return : Endif

Return

#-------------------------------------------------------------------------------#
#    Fermeture des fichiers complémentaires                                     #
#-------------------------------------------------------------------------------#
$FERME_EPU_SRS
If clalev([F:SRD])  : Close Local File [SRD]  : Endif
If clalev([F:CAL])  : Close Local File [CAL]  : Endif
If clalev([F:CAL1]) : Close Local File [CAL1] : Endif
Return

#################################################################################
#    Epuration des factures                                                     #
# ------------------------------------------------------------------------------#
#    SIH : Actions liées à l'épuration des factures                             #
# ------------------------------------------------------------------------------#
#    Formule d'épuration :                                                      #
#    INVSTA=3 | (INVSTA<3 & INVTYP=5)                                           #
#################################################################################
#-------------------------------------------------------------------------------#
#    Ouvertures des fichiers complémentaires                                    #
#-------------------------------------------------------------------------------#
$OUVRE_EPU_SIH

If HISTO
    If OKEPU=0
      #-- Historisation
      If clalev([F:SID])=0  : Local File =[L]APPLI+".SINVOICED"   [SID]   : Endif
      If clalev([F:SIH])=0  : Local File =[L]APPLI+".SINVOICE"    [SIH]   : Endif
      If clalev([F:DUD])=0  : Local File =[L]APPLI+".GACCDUDATE"  [DUD]   : Endif
      If clalev([F:SIV1])=0 : Local File =[L]APPLI+".SINVOICEV"   [SIV1]  : Endif
      If clalev([F:SVV])=0  : Local File =[L]APPLI+".SVCRVAT"     [SVV]   : Endif
      If clalev([F:SVF])=0  : Local File =[L]APPLI+".SVCRFOOT"    [SVF]   : Endif
      If clalev([F:CAL])=0  : Local File =[L]APPLI+".CPTANALIN"   [CAL]   : Endif
      #-----------------------#
      # Fichier historisation #
      #-----------------------#
      TABLE="GACCDUDATE" : Gosub CRETAB_HISTO
      If clalev([F:DUD1])= 0 : Local File =[L]HISAPL+".GACCDUDATE" [DUD1] : Endif
      TABLE="SVCRVAT"  : Gosub CRETAB_HISTO
      If clalev([F:SVV1])= 0 : Local File =[L]HISAPL+".SVCRVAT"  [SVV1]   : Endif
      TABLE="SVCRFOOT" : Gosub CRETAB_HISTO
      If clalev([F:SVF1])= 0 : Local File =[L]HISAPL+".SVCRFOOT" [SVF1]   : Endif
      TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
      If clalev([F:CAL1])= 0 : Local File =[L]HISAPL+".CPTANALIN"  [CAL1] : Endif
    Else
      #-- Epuration après historisation (Pour les vérifs et épuration du texte lié)
      If clalev([F:SID])=0  : Local File =[L]HISAPL+".SINVOICED"  [SID]   : Endif
      If clalev([F:SIH])=0  : Local File =[L]HISAPL+".SINVOICE"   [SIH]   : Endif
      If clalev([F:DUD])=0  : Local File =[L]HISAPL+".GACCDUDATE" [DUD]   : Endif
      If clalev([F:SIV1])=0 : Local File =[L]HISAPL+".SINVOICEV"  [SIV1]  : Endif
      If clalev([F:SVV])=0  : Local File =[L]HISAPL+".SVCRVAT"    [SVV]   : Endif
      If clalev([F:SVF])=0  : Local File =[L]HISAPL+".SVCRFOOT"   [SVF]   : Endif
      If clalev([F:CAL])=0  : Local File =[L]HISAPL+".CPTANALIN"  [CAL]   : Endif
    Endif
Else
    #-- Epuration seule (Pour les vérifs et épuration du texte lié)
    If clalev([F:SID])=0    : Local File =[L]APPLI+".SINVOICED"   [SID]   : Endif
    If clalev([F:SIH])=0    : Local File =[L]APPLI+".SINVOICE"    [SIH]   : Endif
    If clalev([F:DUD])=0    : Local File =[L]APPLI+".GACCDUDATE"  [DUD]   : Endif
    If clalev([F:SIV1])=0   : Local File =[L]APPLI+".SINVOICEV"   [SIV1]  : Endif
    If clalev([F:SVV])=0    : Local File =[L]APPLI+".SVCRVAT"     [SVV]   : Endif
    If clalev([F:SVF])=0    : Local File =[L]APPLI+".SVCRFOOT"    [SVF]   : Endif
    If clalev([F:CAL])=0    : Local File =[L]APPLI+".CPTANALIN"   [CAL]   : Endif
Endif

Gosub DEFVAR
Return

#---------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'une facture                                 #
#    Contrôles à effectuer avant l'épuration d'une facture   (WOK=0 pour refuser) #
#    --> Elle doit être réglée                                                    #
#    --> Si elle a fait l'objet d'un avoir, l'avoir doit être validé              #
#---------------------------------------------------------------------------------#
$HIS_EPU_SIH
WCLE=[F:F1]NUM
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif

WOK=1
Raz WMESSAGE
If [F:F1]INVTYP <> 1
    # Avoir ou proforma pas de contrôles à faire
    Gosub EPURE_SIH : If WOK=0 OKHIS=0 : OKEPU=0 : Endif : Return
Endif
# Contrôle pour les factures
WMESSAGE=[F:F1]NUM
Read [SIH] SIH0=[F:F1]NUM
If fstat
    Raz [F:SIH] : Call ECR_TRACE("$SINVOICE"-[F:F1]NUM-mess(12,100,1),1) From GESECRAN
Endif
If GMODU(2)=2
#----- Contrôle du règlement des échéances si le module compta est présent
    Columns [DUD] (ACCNUM, DUDLIG, FLGCLE)
    For [DUD]DUD6 Where FLGCLE<>2 & ACCNUM=[F:SIH]ACCNUM
        #Des montants ne sont pas réglés
        WMESSAGE-=mess(430,197,1) : WOK=0 : Break
    Next
    Columns [DUD]
    If WOK=0 Call ECR_TRACE(WMESSAGE,1) From GESECRAN : OKHIS=0 : OKEPU=0 : Return : Endif
Endif
#----- Contrôle que les avoirs sont validés
Columns [SID] (NUM, SIDLIN, BPCINV, SALFCY, SIHORINUM)
Filter [SID] Where BPCINV=[F:F1]BPCINV & SALFCY=[F:F1]SALFCY & SIHORINUM=[F:F1]NUM
&      Order By Key SID0
For [SID] Hint Key SID1
    Read [SIV1] SIV0 = [F:SID]NUM
#   L'avoir peut ne plus exister (s'il a déjà été purgé)
    If !fstat
        If [F:SIV1]INVSTA <> 3 WMESSAGE-=mess(460,197,1)-[F:SIV1]NUM -mess(459,197,1) : WOK=0 : Break : Endif
    Endif
Next
Filter [SID]
Columns [SID]
If WOK=0 Call ECR_TRACE(WMESSAGE,1) From GESECRAN : OKHIS=0 : OKEPU=0 : Return : Endif

Gosub EPURE_SIH
If WOK=0 OKHIS=0 : OKEPU=0 : Return Endif

Return

#-------------------------------------------------------------------------------#
#    Traitements liés à l'épuration d'une facture                               #
#-------------------------------------------------------------------------------#
$EPURE_SIH
# --- Supression des textes associés à la livraison
WNUMTEX = [F:F1]SIHTEX1
If WNUMTEX <> "" WTYP="SIV1" : Gosub HIS_EPU_TEXTE : Endif
If WOK=0 Return : Endif
WNUMTEX = [F:F1]SIHTEX2
If WNUMTEX <> "" WTYP="SIV2" : Gosub HIS_EPU_TEXTE : Endif
If WOK=0 Return : Endif
# --- Boucle de supression des textes associés aux détails facture
# --- Boucle d'historisation-épuration sections analytiques lignes facture -----#
Raz WVCRTYP, WVCRNUM, WVCRLIN, WVCRSEQ, WCPLCLE
Columns [SID] (NUM, SIDLIN, SIDTEX)
For [F:SID]SID0 Where NUM=[F:F1]NUM
    WNUMTEX = [F:SID]SIDTEX
    If WNUMTEX <> "" WTYP="SID1" : Gosub HIS_EPU_TEXTE : Endif
    If WOK=0 Break : Endif
    WVCRNUM=[F:SID]NUM : WVCRLIN=[F:SID]SIDLIN : WABRFIC="SID"
    Gosub HIS_EPU_CAL
    If WOK=0 Break : Endif
Next
Columns [SID]
If WOK=0 Return : Endif

If GMODU(2)<>2
# --- Si le module compta n'est pas présent, Historisation-épuration des échéances
    If OKHIS & OKEPU=0
        For [DUD]DUD1 Where ACCNUM=[F:SIH]ACCNUM
            [F:DUD1] = [F:DUD]
            If dim([F:DUD1]CREHISDAT)>0 : [F:DUD1]CREHISDAT = date$    : Endif
            If dim([F:DUD1]CREHISUSR)>0 : [F:DUD1]CREHISUSR = [V]GUSER : Endif
            If !SIMUL
                Write [F:DUD1]
                If fstat
                    WOK=0 : Call ECR_TRACE("$GACCDUDATE"-WCLE-mess(13,100,1),1) From GESECRAN : Break
                Endif
            Endif
        Next
        If WOK=0 : Return : Endif
    Endif
    If !SIMUL
      Delete [DUD] Where ACCNUM=[F:SIH]ACCNUM
      If fstat=1
          WOK=0 : Call ECR_TRACE("$GACCDUDATE"-WCLE-mess(10,100,1),1) From GESECRAN
      Endif
      If WOK=0 : Return : Endif
    Endif
    If [L]TRACEDET
        Call ECR_TRACE ("-- GACCDUDATE"-WCLE,0) From GESECRAN
    Endif
Endif

# --- Historisation-épuration SVCRVAT SVCRFOOT
WVCRTYP=4
Gosub HIS_EPU_SVV : If WOK=0 : Return : Endif
Gosub HIS_EPU_SVF : If WOK=0 : Return : Endif
Return

#-------------------------------------------------------------------------------#
#    Fermeture des fichiers complémentaires                                     #
#-------------------------------------------------------------------------------#
$FERME_EPU_SIH
If clalev([F:SID])  : Close Local File [SID]  : Endif
If clalev([F:SIH])  : Close Local File [SIH]  : Endif
If clalev([F:DUD])  : Close Local File [DUD]  : Endif
If clalev([F:SIV1]) : Close Local File [SIV1] : Endif
If clalev([F:SVV])  : Close Local File [SVV]  : Endif
If clalev([F:SVF])  : Close Local File [SVF]  : Endif
If clalev([F:CAL])  : Close Local File [CAL]  : Endif
If clalev([F:DUD1]) : Close Local File [DUD1] : Endif
If clalev([F:SVV1]) : Close Local File [SVV1] : Endif
If clalev([F:SVF1]) : Close Local File [SVF1] : Endif
If clalev([F:CAL1]) : Close Local File [CAL1] : Endif
Return

#################################################################################
#    Epuration des tarifs                                                       #
# ------------------------------------------------------------------------------#
#    SPF : Actions liées à l'épuration des tarifs                               #
#################################################################################
#-------------------------------------------------------------------------------#
#    Ouvertures des fichiers complémentaires                                    #
#-------------------------------------------------------------------------------#
$OUVRE_EPU_SPF

If HISTO
    If OKEPU=0
      #-- Historisation
      If clalev([F:SPL])=0 : Local File =[L]APPLI+".SPRICLIST"    [SPL]   : Endif
    Else
      #-- Epuration après historisation (Pour les vérifs)
      If clalev([F:SPL])=0 : Local File =[L]HISAPL+".SPRICLIST"   [SPL]   : Endif
    Endif
Else
    #-- Epuration seule (Pour les vérifs)
    If clalev([F:SPL])=0   : Local File =[L]APPLI+".SPRICLIST"    [SPL]   : Endif
Endif

Gosub DEFVAR
Return
#-------------------------------------------------------------------------------#
#    Traitements liés à l'épuration des tarifs                                  #
#    Contrôles à effectuer avant l'épuration d'un tarif (WOK=0 pour refuser)    #
#-------------------------------------------------------------------------------#
$HIS_EPU_SPF
Return
#-------------------------------------------------------------------------------#
#    Fermeture des fichiers complémentaires                                     #
#-------------------------------------------------------------------------------#
$FERME_EPU_SPF
If clalev([F:SPL]) : Close Local File [SPL] : Endif
Return
#################################################################################
#    Traitements complémentaires                                                #
#################################################################################
#--------------------------------------------------------------#
#    Routine de suppression d'un texte associé à un document   #
#--------------------------------------------------------------#
$HIS_EPU_TEXTE

If HISTO
    If OKEPU=0
        #-- Historisation : historisation des textes
        If !SIMUL
            # A VOIR
        Endif
        #-- A voir si on supprime les textes ou pas (sur le dossier mère)
        If !SIMUL
            # A VOIR
        Endif
    Else
        # -- Epuration après historisation
        # -- A voir si on supprime les textes ou pas (sur le dossier fille)
    Endif
Else
    #-- Epuration seule
    # -- A voir si on supprime les textes ou pas (sur le dossier mère)

Endif

#If !SIMUL
#    Call TEX(5,WTYP,"","","",WNUMTEX,"A",WRETOUR) From TRTX3TEX
#Endif

Return

$DEFVAR
Local Integer WRETOUR, WOK
Local Char    WNUMTEX (12), WTYP, WMESSAGE(125)
Local Char    WABRFIC(4)
Local Integer WVCRTYP,          WVCRTYP2
Local Char    WVCRNUM(GLONVCR), WVCRNUM2(GLONVCR)
Local Integer WVCRLIN
Local Integer WVCRSEQ
Local Char    WCPLCLE(30)
Local Char    WCLEFIC(50),      WCLEFIC2(50)
Return

