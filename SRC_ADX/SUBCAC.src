#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("CAC",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBCACB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "DEFTRANS"   : Gosub DEFTRANS
 When "TITRE"      : Gosub TIT
 When "AVANT_CHOI" : Gosub AVANT_CHOI
 When "OUVRE"      : Gosub OUVRE
 When "SETBOUT"    : Gosub SETBOUT
 When "AFFMASK"    : Gosub AFFMASK
 When "VERIF_CRE"  : Gosub VERIF_CRE
 When "VERIF_MOD"  : Gosub VERIF_MOD
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "LIENS"      : Gosub LIENS
 When "ANNULE"     : Gosub ANNULE
 When "AP_CHANGE"  : Gosub AP_CHANGE
 When "FIN"        : Gosub FIN
 When "APRES_MODIF": Gosub APRES_MODIF
 When "EXEBOUT"    : Gosub EXEBOUT
 When Default
Endcase
If PSUBB
 Gosub ACTION From SUBCACB
Endif
Return

# 73604
$APRES_MODIF
CLECUR = 1
Return

$OUVRE
If clalev([F:ATY])=0  : Local File ATYPE      [ATY] : Endif
If clalev([F:COA])=0  : Local File GCOA       [COA] : Endif
If clalev([F:CAC2])=0 : Local File GACCCODE  [CAC2] : Endif
Local Char    INTCOL(15)
Local Integer I, NBACC
If !GIMPORT
 If CLE2=""
  GBIDI1 = 1
  CLE2 = "1"
 Else
  GBIDI1 = val(CLE2)
 Endif
Endif
Gosub SETFOR
Local Integer SAV_GNBGAUCHE
SAV_GNBGAUCHE = GNBGAUCHE
GNBGAUCHE = 9999
[L]ANOUPDTICK = 1  #84061
Return

$DEFTRANS
If clalev([F:GCO])=0 : Local File GCACCOA    [GCO] : Endif
Local  Integer  XVARINB  : XVARINB = 0
Local  Integer  XVARIREP : XVARIREP = 0
Local  Char     XVARITEX(40)(200)
Local  Char     XVARITEXTRA(40)
Local  Char     XVARICOD(10)(200)
Global Char     GXFLAG(10)

If GFLAG="" : GXFLAG=GSCHGCO : Endif
If GXFLAG<>""
 XVARIREP = 1
 Call LECTEXTRA(XVARITEXTRA,"GCACCOA","DESTRA",GXFLAG,"") From ATEXTRA
 XVARITEX(XVARIREP) = GXFLAG-XVARITEXTRA
 XVARICOD(XVARIREP) = GXFLAG
 Return
Endif

GOK = 1
For [GCO]GCO0
 XVARINB += 1
 Call LECTEXTRA(XVARITEXTRA,"GCACCOA","DESTRA",[F:GCO]COD,"") From ATEXTRA
 XVARITEX(XVARINB) = [F:GCO]COD-XVARITEXTRA
 XVARICOD(XVARINB) = [F:GCO]COD
Next
If XVARINB=0
 OK=0
Elsif XVARINB=1
 GXFLAG  = [F:GCO]COD
Else
 Call SAITEX(XVARINB,XVARITEX,XVARIREP,mess(3,126,1)) From GESECRAN : # Choix transaction
 If status<>7 & XVARIREP<>0
  GXFLAG  = XVARICOD(XVARIREP)
 Endif
Endif
If GXFLAG="" : OK=0 : Endif
Return

$TIT
If XVARITEX(XVARIREP) <>""
 TIT -=  XVARITEX(XVARIREP)
Endif
Return

$AVANT_CHOI
Gosub AFFMASK
Return

$AFFMASK
[M:CAC1]CODTRS = GXFLAG
Read [GCO]GCO0 = GXFLAG
If !fstat
 [M:CAC1]NBRCOA = [F:GCO]NBRCOA
 For NCOA=0 To [F:GCO]NBRCOA-1
  Read [COA]COA0 = [F:GCO]COA(NCOA)
  [M:CAC1]COA(NCOA) = [F:GCO]COA(NCOA)
  If !fstat
   Gosub AFFCOL
  Endif
 Next
Endif
Return

$LIENS
Call CHARGE([M]TYP) From SUBCAC
[M:CAC1]CODTRS = GXFLAG
Read [GCO]GCO0 = GXFLAG
If !fstat
 For NCOA=0 To [F:GCO]NBRCOA-1
  [M:CAC1]COA(NCOA) = [F:GCO]COA(NCOA)
  For [CAC2]CAC0 Where TYP=[M:CAC1]TYP & ACCCOD=[M:CAC1]ACCCOD & COA=[M:CAC1]COA(NCOA)
   For NOL=0 To [M:CAC1]NBLIG-1
    Assign("[M:CAC1]ACC"+num$(NCOA+1)+"("+num$(NOL)+")") With [F:CAC2]ACC(NOL)
    If [F:CAC2]ACC(NOL)<>""
     CLECUR2(1) = [F:CAC2]COA
    Endif
   Next
  Next
  Read [COA]COA0 = [M:CAC1]COA(NCOA)
  If !fstat
   Gosub AFFCOL
  Endif
 Next
 [M:CAC1]NBRCOA = [F:GCO]NBRCOA
Endif
#Textes Traduisibles
Call LECTEXTRA([M:CAC1]DESTRA,"GACCCODE","DESTRA",num$([M:CAC1]TYP),[M:CAC1]ACCCOD) From ATEXTRA
Call LECTEXTRA([M:CAC1]SHOTRA,"GACCCODE","SHOTRA",num$([M:CAC1]TYP),[M:CAC1]ACCCOD) From ATEXTRA
Return

$AFFCOL
Local Char NOMCOL(10)
NOMCOL = evalue("ACC"+num$(NCOA+1))
Call LECTEXTRA(INTCOL,"GCOA","COLHEA",[F:COA]COA,"") From ATEXTRA
Case NCOA
 When 0
  Titcol [M]NBLIG INTCOL For ACC1
 When 1
  Titcol [M]NBLIG INTCOL For ACC2
 When 2
  Titcol [M]NBLIG INTCOL For ACC3
 When 3
  Titcol [M]NBLIG INTCOL For ACC4
 When 4
  Titcol [M]NBLIG INTCOL For ACC5
 When 5
  Titcol [M]NBLIG INTCOL For ACC6
 When 6
  Titcol [M]NBLIG INTCOL For ACC7
 When 7
  Titcol [M]NBLIG INTCOL For ACC8
 When 8
  Titcol [M]NBLIG INTCOL For ACC9
Endcase
Return

$SETBOUT
CHAINE += "A"
Return

$EXEBOUT
Case REP
 When "B" : GOK = 2 : REPONSE = GSTAEND
Endcase
Return

$FIN
GNBGAUCHE = SAV_GNBGAUCHE

If GOK=2 : # Bouton Transaction
 GFLAG="\"
Else
 Raz GFLAG
Endif
Return

$INICRE
If dim([F:CAC]DES)>0
 [F:CAC]DES = [M:CAC1]DESTRA
Endif
#Initialiser pour objet CAC pour textes traduisibles
[F:CAC]TYPCAR = num$([F:CAC]TYP)
Return

$INIMOD
Gosub INICRE
Return


$VERIF_MOD
# 67090 - on crée l'enregistrement pour éviter l'erreur "Pas d'enregistrement courant" (GOBJET1:214 : Readlock)
Read [CAC]CAC0=[M:CAC1]TYP;[M:CAC1]ACCCOD;[M:CAC1]COA(0)
If fstat
 Trbegin [CAC]
 Raz [F:CAC]
 [F:CAC]TYP     = [M:CAC1]TYP
 [F:CAC]ACCCOD  = [M:CAC1]ACCCOD
 [F:CAC]COA     = [M:CAC1]COA(0)
 If dim([F:CAC]UPDDAT)>0 : [F:CAC]UPDDAT=date$ : Endif
 If dim([F:CAC]UPDUSR)>0 : [F:CAC]UPDUSR=GUSER : Endif
 If dim([F:CAC]UPDTIM)>0 : [F:CAC]UPDTIM=time  : Endif
 Write [F:CAC]
 If fstat
  GOK = 0 : Call FSTA("CAC") From GLOCK
 Else
  Commit
 Endif
Endif
Gosub VERIF_CRE
Return

$VERIF_CRE
# 67090 - ligne de code nécessaire pour éviter l'erreur "Fiche déjà existante" (GOBJET1:259 : Rewrite)
CLECUR2(1) = [M]COA(0)

For NOL=0 To [M:CAC1]NBLIG-1
 ## Le flag 'Compte obligatoire' n'est exploité que pour le compte du premier plan de compte saisissable
 ## (on ne peut pas obliger de mettre un compte analytique alors que le compte général n'a pas de suivi ana...)
 If [M:CAC1]OBL(NOL)=2 & evalue("[M:CAC1]ACC"+num$(1)+"("+num$(NOL)+")") = ""
  # Ligne no ... Compte obligatoire
  GMESSAGE = mess(61,100,1)-num$(NOL+1)-mess(47,133,1)
  [L]OK=0 : Break
 Endif
Next
If ![L]OK : Return : Endif
Return

$CREATION
For NCOA=0 To [M:CAC1]NBRCOA-1
 Read [CAC2]CAC0 = [M:CAC1]TYP ; [M:CAC1]ACCCOD ; [M:CAC1]COA(NCOA)
 If !fstat
  Gosub TEXTRA
  For NOL=0 To [M:CAC1]NBLIG-1
   Assign("[F:CAC2]ACC"+"("+num$(NOL)+")") With evalue("[M:CAC1]ACC"+num$(NCOA+1)+"("+num$(NOL)+")")
  Next
  If dim([F:CAC2]UPDDAT)>0 : [F:CAC2]UPDDAT=date$ : Endif
  If dim([F:CAC2]UPDUSR)>0 : [F:CAC2]UPDUSR=GUSER : Endif
  If dim([F:CAC2]UPDTIM)>0 : [F:CAC2]UPDTIM=time  : Endif
  Rewrite [F:CAC2]
  If fstat
   GOK = 0 : Call FSTA("CAC2") From GLOCK : Break
  Endif
 Else
  [F:CAC2]TYP     = [M:CAC1]TYP
  [F:CAC2]ACCCOD  = [M:CAC1]ACCCOD
  [F:CAC2]COA     = [M:CAC1]COA(NCOA)
  Gosub TEXTRA
  For NOL=0 To [M:CAC1]NBLIG-1
   Assign("[F:CAC2]ACC"+"("+num$(NOL)+")") With evalue("[M:CAC1]ACC"+num$(NCOA+1)+"("+num$(NOL)+")")
  Next
  If dim([F:CAC2]CREDAT)>0 : [F:CAC2]CREDAT=date$ : Endif
  If dim([F:CAC2]CREUSR)>0 : [F:CAC2]CREUSR=GUSER : Endif
  If dim([F:CAC2]CRETIM)>0 : [F:CAC2]CRETIM=time  : Endif
  Write [F:CAC2]
  If fstat
   GOK = 0 : Call FSTA("CAC2") From GLOCK : Break
  Endif
 Endif
Next
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub CREATION
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GACCCODE","DESTRA",CLECUR2,num$(CLECUR1),"GACCCODE","DESTRA",num$([M:CAC1]TYP),[M:CAC1]ACCCOD)  From ATEXTRA
 Call DUPTEXTRA("GACCCODE","SHOTRA",CLECUR2,num$(CLECUR1),"GACCCODE","SHOTRA",num$([M:CAC1]TYP),[M:CAC1]ACCCOD)  From ATEXTRA
Endif
Call MAJTEXTRA([M:CAC1]DESTRA,"GACCCODE","DESTRA",num$([M:CAC1]TYP),[M:CAC1]ACCCOD) From ATEXTRA
Call MAJTEXTRA([M:CAC1]SHOTRA,"GACCCODE","SHOTRA",num$([M:CAC1]TYP),[M:CAC1]ACCCOD) From ATEXTRA
Return

$AP_CHANGE
Call CHGTEXTRA("GACCCODE","DESTRA",num$([M:CAC1]TYP),[M:CAC1]ACCCOD,num$([M:CAC1]TYP),NCODE) From ATEXTRA
Call CHGTEXTRA("GACCCODE","SHOTRA",num$([M:CAC1]TYP),[M:CAC1]ACCCOD,num$([M:CAC1]TYP),NCODE) From ATEXTRA
Return

$ANNULE
Call SUPTEXTRA("GACCCODE","DESTRA",num$([M:CAC1]TYP),[M:CAC1]ACCCOD) From ATEXTRA
Call SUPTEXTRA("GACCCODE","SHOTRA",num$([M:CAC1]TYP),[M:CAC1]ACCCOD) From ATEXTRA
Return


###############################################################################
##  Copie
###############################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File GACCCODE  [CAC1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".GACCCODE"  [CAC1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File GACCCODE [CAC2]
 Local File GCOA [COA2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".GACCCODE"  [CAC2]
 Local File =[M]DOSDES+".GCOA"  [COA2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [CAC1], [CAC2], [COA2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
If clalev([M:CAC1])=0 : Return : Endif
Trbegin [CAC2]
 Delete [CAC2] Where num$(TYP)=TABLE & ACCCOD=TABLE2 & find(COA,[M:CAC1]COA(0..[M:CAC1]NBRCOA))
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".GACCCODE" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("CAC2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [CAC1] Where num$(TYP)=TABLE & ACCCOD=TABLE2 & find(COA,[M:CAC1]COA(0..[M:CAC1]NBRCOA))
  Read [COA2]COA0 = [F:CAC1]COA
  If !fstat
   [F:CAC2]   = [F:CAC1]
   Call COPTEXTRA("GACCCODE","DESTRA",TABLE,TABLE2) From ATEXTRA
   Call COPTEXTRA("GACCCODE","SHOTRA",TABLE,TABLE2) From ATEXTRA
   If dim([F:CAC2]UPDUSR)>0 : [F:CAC2]UPDUSR = GUSER : Endif
   If dim([F:CAC2]UPDDAT)>0 : [F:CAC2]UPDDAT = date$ : Endif
   Write [CAC2]
   If fstat
    GOK = 0 : Call FSTA("CAC2") From GLOCK : Break
   Endif
  Endif
 Next
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

##############################################################################################

Subprog CHARGE(TYPC)
Value Integer TYPC
Local Integer NOL
Filter [CCL] Where TYP=TYPC
For [CCL]CCL0
 NOL = [F:CCL]NUMLIG
 [M:CAC1]CPT(NOL-1)    = [F:CCL]TYPCPT
 [M:CAC1]DESIG(NOL-1)  = [F:CCL]TXT
 If [F:CCL]OTHPPU=2
  [M:CAC1]ADESIG(NOL-1) = mess([F:CCL]TXT,2820,1)
 Else
  [M:CAC1]ADESIG(NOL-1) = mess([F:CCL]TXT,853,1)
 Endif
 [M:CAC1]OBL(NOL-1)    = [F:CCL]OBL
Next
Filter [CCL]
[M:CAC1]NBLIG = NOL
End

$SEL_LISTE
Case LISTE
 When "SELCAC"

  Local Integer MAXCAC
  Filter [CAC] Where TYP=val(PARAM(1))
#MIPEA - 2017-01-31- X3-22757- START
  If rowcount([CAC])=0 : GERR=1 : GMESSAGE = mess(11,114,1) : Return : Endif
#MIPEA - 2017-01-31- X3-22757- END
  MAXCAC = min(32767,max(1,rowcount([F:CAC])))
  Local Char TEXTE(GLONDES)(1..MAXCAC,1..2)
  Local Char TEX(GLONDES)(1..MAXCAC)
  NBTEX = 0
  For [CAC]CAC0(2)
   If NBTEX >= dim(TEX) - 1 : Break : Endif
   NBTEX += 1
   TEX(NBTEX)     = [F:CAC]ACCCOD
   TEXTE(NBTEX,1) = [F:CAC]ACCCOD
   Call LECTEXTRA(TEXTE(NBTEX,2),"GACCCODE","DESTRA",num$([F:CAC]TYP),[F:CAC]ACCCOD) From ATEXTRA
  Next
  Filter [CAC]
  TIT(0) = mess(12,123,1)  # Choix
  Call TITOBJ("CAC","",TIT(1)) From CONTOBJ
  TIT(0) -= TIT(1)
  TIT(2) = mess(82,123,1)  # Intitulé
Endcase
Return

###################################################################################################
## Etiquettes masque CAC1
###################################################################################################
Subprog AM_TYP(VALEUR)
Variable Integer VALEUR
Effzo [M:CAC1]10
Call CHARGE(VALEUR) From SUBCAC
If !GIMPORT : Affzo [M:CAC1] : Endif
End

Subprog AS_TYP(VALEUR)
Variable Integer VALEUR
Local Char ACTION(10)
ACTION = "AS_TYP" : Gosub ACTION
End

Subprog AV_ACC1(VALEUR)
Variable Char    VALEUR()
Local Integer NACC : NACC = 1
Gosub AFFACC
End

Subprog AV_ACC2(VALEUR)
Variable Char    VALEUR()
Local Integer NACC : NACC = 2
Gosub AFFACC
End

Subprog AV_ACC3(VALEUR)
Variable Char    VALEUR()
Local Integer NACC : NACC = 3
Gosub AFFACC
End

Subprog AV_ACC4(VALEUR)
Variable Char    VALEUR()
Local Integer NACC : NACC = 4
Gosub AFFACC
End

Subprog AV_ACC5(VALEUR)
Variable Char    VALEUR()
Local Integer NACC : NACC = 5
Gosub AFFACC
End

Subprog AV_ACC6(VALEUR)
Variable Char    VALEUR()
Local Integer NACC : NACC = 6
Gosub AFFACC
End

Subprog AV_ACC7(VALEUR)
Variable Char    VALEUR()
Local Integer NACC : NACC = 7
Gosub AFFACC
End

Subprog AV_ACC8(VALEUR)
Variable Char    VALEUR()
Local Integer NACC : NACC = 8
Gosub AFFACC
End

Subprog AV_ACC9(VALEUR)
Variable Char    VALEUR()
Local Integer NACC : NACC = 9
Gosub AFFACC
End

$AFFACC
GFMT = "K:15X"
Read [GCO]GCO0 = GXFLAG
If [F:GCO]NBRCOA<NACC
 GFMT = "-K:15X"
Endif
Return

Subprog AS_ACC1(VALEUR)
Variable Char    VALEUR()
Local Integer IND : IND = 1
Goto AS_ACC

Subprog AS_ACC2(VALEUR)
Variable Char    VALEUR()
Local Integer IND : IND = 2
Goto AS_ACC

Subprog AS_ACC3(VALEUR)
Variable Char    VALEUR()
Local Integer IND : IND = 3
Goto AS_ACC

Subprog AS_ACC4(VALEUR)
Variable Char    VALEUR()
Local Integer IND : IND = 4
Goto AS_ACC

Subprog AS_ACC5(VALEUR)
Variable Char    VALEUR()
Local Integer IND : IND = 5
Goto AS_ACC

Subprog AS_ACC6(VALEUR)
Variable Char    VALEUR()
Local Integer IND : IND = 6
Goto AS_ACC


Subprog AS_ACC7(VALEUR)
Variable Char    VALEUR()
Local Integer IND : IND = 7
Goto AS_ACC

Subprog AS_ACC8(VALEUR)
Variable Char    VALEUR()
Local Integer IND : IND = 8
Goto AS_ACC

Subprog AS_ACC9(VALEUR)
Variable Char    VALEUR()
Local Integer IND : IND = 9
Goto AS_ACC

$AS_ACC
If IND>1
 Gosub SETNOL
 Local Char    CRIBLE(20)
 Local Char    ACCORG(GLONGAC), ACCDES(GLONGAC)
 Local Integer IPLAN, INDREF
 For IPLAN=1 To IND
  [L]ACCORG = evalue("[M]ACC"+num$(IPLAN)+"("+num$(NOL)+")")
  If [L]ACCORG<>"" & evalue("[M]COA("+num$(IPLAN-1)+")")<>evalue("[M]COA("+num$(IND-1)+")")
   Call LECTURE("GAC",ACCORG,evalue("[M]COA("+num$(IPLAN-1)+")")) From CONTOBJ
   If find(evalue("[M]COA("+num$(IND-1)+")"),[F:GAC]OTHCOA(0..[F:GAC]COANBR-1))
    Call INIACC(evalue("[M]COA("+num$(IPLAN-1)+")"),[L]ACCORG,evalue("[M]COA("+num$(IND-1)+")"),ACCDES,[L]CRIBLE) From CPTINI
    If [L]ACCDES<>""
     INDREF = IPLAN : Break
    Endif
   Endif
  Endif
 Next
 If ACCDES = ""
  End
 Elsif evalue("[M]COA("+num$(INDREF-1)+")")<>evalue("[M]COA("+num$(IND-1)+")")
  If [L]ACCDES = [L]CRIBLE
   VALEUR = ACCDES
   mkstat=2 : End
  Elsif VALEUR=""
   VALEUR = ACCDES
  Endif
 Endif
Endif
End

Subprog C_ACC1(VALEUR)
Variable Char     VALEUR
Local Integer IND : IND = 1
Goto C_ACC

Subprog C_ACC2(VALEUR)
Variable Char     VALEUR
Local Integer IND : IND = 2
Goto C_ACC

Subprog C_ACC3(VALEUR)
Variable Char     VALEUR
Local Integer IND : IND = 3
Goto C_ACC

Subprog C_ACC4(VALEUR)
Variable Char     VALEUR
Local Integer IND : IND = 4
Goto C_ACC

Subprog C_ACC5(VALEUR)
Variable Char     VALEUR
Local Integer IND : IND = 5
Goto C_ACC

Subprog C_ACC6(VALEUR)
Variable Char     VALEUR
Local Integer IND : IND = 6
Goto C_ACC

Subprog C_ACC7(VALEUR)
Variable Char     VALEUR
Local Integer IND : IND = 7
Goto C_ACC

Subprog C_ACC8(VALEUR)
Variable Char     VALEUR
Local Integer IND : IND = 8
Goto C_ACC

Subprog C_ACC9(VALEUR)
Variable Char     VALEUR
Local Integer IND : IND = 9
Goto C_ACC

$C_ACC
Gosub SETNOL
Gosub SETCAR
Local Integer STAT
Call INIACCFMT(evalue("[M]COA("+num$(IND-1)+")")) From SETGLBCOA
If VALEUR=""
 If IND=1 &  [M]OBL(NOL)=2 : GMESSAGE = mess(10,123,1) : mkstat = 2 : End : Endif
 # Zone obligatoire
Else
 Case [M]CPT(NOL)
  When 1 : # LA 604 Compte
   Call CONTROLE("GAC","G",VALEUR,evalue("[M]COA("+num$(IND-1)+")"),mkstat) From CONTOBJ
  When 2 : # LA 604 Modificateur
   Local Integer I
   Local Char    CHAINE(GLONGAC)
   For I=1 To len(VALEUR)
    If mid$(VALEUR,I,1)=toupper(CAR)
     VALEUR = left$(VALEUR,I-1)+CAR+right$(VALEUR,I+1)
    Endif
   Next I
   CHAINE = VALEUR
   For I=1 To len(CHAINE)
    If mid$(CHAINE,I,1)=CAR
     CHAINE = left$(CHAINE,I-1)+"0"+right$(CHAINE,I+1)
    Endif
   Next I
   If vireblc(format$("K:"+GFMTACC,CHAINE),2)<>CHAINE
    GMESSAGE = mess(149,100,1) : mkstat = 2 : End  : # Format incorrect
   Endif
  When 3 : # LA 604 Collectif
   Read [F:GAC]GAC1 = evalue("[M]COA("+num$(IND-1)+")");VALEUR
   If !fstat : VALEUR = [F:GAC]ACC : Endif
   Call CONTROLE("GAC","C",VALEUR,evalue("[M]COA("+num$(IND-1)+")"),mkstat) From CONTOBJ
 Endcase
Endif
If IND>1
 Assign "[M]ACC"+num$(IND)+"("+num$(NOL)+")" With VALEUR
 Local Char    TPLAN(GLONCOA)(1..[M:CAC1]NBRCOA), TCOMPTE(GLONGAC)(1..[M:CAC1]NBRCOA), MESSA(250)
 Local Integer I, STAT : STAT = 0
 For I=1 To IND
  TPLAN(I)   = [M:CAC1]COA(I-1)
  TCOMPTE(I) = evalue("[M]ACC"+num$(I)+"("+num$(NOL)+")")
 Next

 Call CNTIPTACC(IND,TPLAN,TCOMPTE,MESSA,STAT) From CPTCNT
 If STAT : GMESSAGE = MESSA : mkstat = 2 : End : Endif
Endif
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

$SETFOR
GBIDC1 = "10X"
Return

$SETCAR
Local Char CAR(3)
CAR = "x"
Return


Subprog AVANT_NBLIG
End


##################################################
## Gestion type de données CAC
##################################################
Subprog CONTCAC(COD,CAC)
Variable Char    COD()
Value    Char    CAC
If GFONCTION = "GESCAC" | COD="" : End : Endif
If clalev([F:CAC])=0 : Local File GACCCODE [CAC] : Endif
Read [CAC]CAC0(2) = val(CAC);COD
If fstat
 GMESSAGE = mess(11,114,1) : # Code comptable inexistant
 mkstat = 2 : End
Endif
End

Subprog SELCAC(COD,CAC)
Variable Char    COD()
Value    Char    CAC
Local Char PARMSK(30)(1..10)
If clalev([F:CAC])=0 : Local File GACCCODE [CAC] : Endif
#If PLAN<>""
#PARMSK(1) = "CAC"
# Filter [CAC] Where TYP=val(CAC) & COA=PLAN
# Call S_TAB_CHAR(COD,PARMSK,"SELOBJ","SELOBJ","") From GACTION
# Filter [CAC]
#Else
 PARMSK(1) = num$(CAC)
 Call S_LIS_CHAR(COD,PARMSK,"SELCAC","SUBCAC","") From GACTION
#Endif
End

Subprog TUNCAC(COD,CAC)
Variable Char    COD() : # Code comptable
Value    Char    CAC   : # Type de code comptable
Local Char PLAN(GLONCOA), ACC_COD(GLONCAC)
If clalev([F:CAC])=0 : Local File GACCCODE [CAC] : Endif
If [L]COD = ""
 Filter [CAC] Where TYP=val(CAC) & ACCCOD<>""
Else
 Filter [CAC] Where TYP=val(CAC) & ACCCOD=[L]COD
Endif
Read [CAC]CAC0 First
Filter [CAC]
If !fstat
 [L]PLAN = [F:CAC]COA
 If [L]COD <> ""
  [L]ACC_COD = [L]COD
 Else
  [L]ACC_COD = [F:CAC]ACCCOD
 Endif
Endif
Call OBJET_CHAR(ACC_COD,"CAC",CAC+"~"+PLAN) From GOBJET
[L]COD = [L]ACC_COD
End

