#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du fichier PHONING
Call OBJET ("OMP", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "BOITE"       : Gosub BOITE       # FGR 31/07/2014 : X3SUIVI101463
    When "OUVRE_BOITE" : Gosub OUVRE_BOITE
    When "OUVRE"       : Gosub OUVRE
    When "SETBOUT"     : Gosub SETBOUT
    When "RAZCRE"      : Gosub RAZCRE
    When "LIENS"       : Gosub LIENS
    When "FERME"       : Gosub FERME
    When "INICRE"      : Gosub INICRE
    When "VERIF_CRE"   : Gosub VERIF_CRE
    When "VERIF_MOD"   : Gosub VERIF_MOD
    When "CREATION"    : Gosub CREATION
    When "MODIF"       : Gosub MODIF
    When "APRES_CRE"   : Gosub APRES_CRE
    When "APRES_MOD"   : Gosub APRES_MOD
    When "VERF_ANU"    : Gosub VERF_ANU
    When "AV_ANNULE"   : Gosub AV_ANNULE
    When "ANNULE"      : Gosub ANNULE
    When "AP_ANNULE"   : Gosub AP_ANNULE
    When "FILGAUCHE"   : Gosub FILGAUCHE
    When "AVANTBOUT"   : Gosub AVANTBOUT
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GCOMPCPT(GLONANM)   # Code compteur pour une opération marketing
Global Char GBOXOMP(10)
Global Char GBOXOP2(10)
Global Char GSZDELOPGNUM

Local Char SZSITE(GLONFCY)

  GSZDELOPGNUM = ""
  SZSITE = ""
  Call SITECRMDEF ("ACT", SZSITE) From CRM_UTIL
  GFCY = SZSITE
  Call GETDEV(GFCY) From DEVSUB
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If !clalev([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=13
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(2)
  #  GCOMPCPT = [F:TCA]CODNUM(2)
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
Return

##########################################################################################################
$BOITE
Local Char STRTSUB(GLONADC)

  # FGR 31/07/2014 : X3SUIVI101463
  STRTSUB = "SUBOMP"
  Gosub BOITE_GOBJET From CRMUTIL150
Return

##########################################################################################################
$REDEFINE_LINK
  If !clalev([F:O_MP]) Then
    # FGR 11/02/2015 : X3SUIVI106120 : Si [O_MP] pas ouvert c'est que les browsers ont été redéfinis en SPE/SPV.
    # On part, c'est à ce niveau qu'on doit faire ce travail.
    Return
  Endif
  #---------------------------------------------------#
  # FGR 30/07/2014 : X3SUIVI101463
  Link [OMP] With [O_MP]OMP0=[F:OMP]OMPNUM,
&                 [AFF]AFF0~=[F:OMP]FCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:OMP]FCY
&              As [OM1]
Return

##########################################################################################################
$OUVRE_BOITE
  #---------------------------------------------------#
  #Chargement des noms des cuurbox de chaque tiroir
  If OBJLIS(0) = "OMP" Then
    GBOXOMP= "GAU_CHE"
  Else
    GBOXOMP = "GAU_CHE"+num$(find("OMP",OBJLIS(1..8))) : #Campagnes d'appels actives
  Endif
  If OBJLIS(0) = "OP2" Then
    GBOXOP2= "GAU_CHE"
  Else
    GBOXOP2 = "GAU_CHE"+num$(find("OP2",OBJLIS(1..8))) : #Campagnes d'appels clôturées
  Endif
Return

##########################################################################################################
$FERME
  If type(GSZWIZCOD) > 0 Then
    Gosub FINSAI From TRTWIZ2
  Endif
  #LSE 09/01/2007
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESCMG" Then
      Call LOAD_OPG From SUBCMGB
    Endif
  Endif
  # FGR 15/06/2015 : X3SUIVI108846 (début)
  If dim(GCOMPCPT) > 0 Then
    Kill GCOMPCPT            # Code compteur pour une opération marketing.
  Endif
  # FGR 15/06/2015 : X3SUIVI108846 (fin)
  Kill GSZDELOPGNUM
  #LSE 22/12/2005 FQ 33987
  If dim(GBOXOMP) > 0 Then
    Kill GBOXOMP
    Kill GBOXOP2
  Endif
Return

##########################################################################################################
$SETBOUT
  If REP = "" Then
    If [M:OMP2]SCPNUM = "" Then
      Call VIREBOUT(CHAINE,"P") From GOBJET
    Endif
  Else
    Call VIREBOUT(CHAINE,"INP") From GOBJET
  Endif
  #Retours marketing
  If REP <> "" Then
    Call VIREBOUT(CHAINE,"Q") From GOBJET
  Else
    If [M:OMP0]CMGNUM = "" Then
      Call VIREBOUT(CHAINE,"Q") From GOBJET
    Endif
    If [M:OMP0]OMPNUM = "" Then
      Call VIREBOUT(CHAINE,"Q") From GOBJET
    Endif
  Endif
  Call VIREBOUT(CHAINE,"HC") From GOBJET
Return

##########################################################################################################
$AVANTBOUT
  If BOUT = "I" Then
    Local Char PARAM(30)(2)

    Raz PARAM
    PARAM(1) = "PHONING"
    Gosub OUVRE From TRTWIZ2
    GIFSTEP = 1
    GICSTEP = 5
    GINBSTEP = 8
    GILSTEP = 8
    Gosub SETWIZVAR From TRTWIZ2
    GSZCMGNUM = [M:OMP0]CMGNUM
    Gosub SETVAR From TRTWIZ2
    GSZOPGNUM = [M:OMP0]OMPNUM
    If GSZOPGNUM = "" Then
      #Aucun chrono de campagne d'appel n'a pu être obtenu.
      GMESSAGE = mess(674,182,1)
      GERR = 1
      Gosub FINSAI From TRTWIZ2
      OK = 0
    Endif
  Endif
  If BOUT = "N" Then
    [M:OMP0]SELTLS = ""
  Endif
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  Call READ_COUNTER([M:OMP0]FCY, 13, 2, GSOCIETE, GCURLEG, GCOMPCPT, GMANCOU) From CRM_UTIL        # FGR 20/05/2015 : X3SUIVI107775
  # Récupération du compteur
  If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", [M:OMP0]FCY, GCOMPCPT, date$, "", [M:OMP0]OMPNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      [F:OMP]OMPNUM = [M:OMP0]OMPNUM
      Affzo [M:OMP0]OMPNUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
  [F:OMP]TYPFULOBJ = "OMP"
  [F:OMP]NUMFULOBJ = [M:OMP0]OMPNUM
  [M:OMP1]TYPFULOBJ = "OMP"
  [M:OMP1]NUMFULOBJ = [M:OMP0]OMPNUM
Return

##########################################################################################################
$VERIF_CRE
  Gosub CHECKDATA From SUBOMPB
Return

##########################################################################################################
$VERIF_MOD
  Gosub CHECKDATA From SUBOMPB
Return

##########################################################################################################
$CREATION
Local Integer INUMMES
Local Integer ICHAPTER
Local Integer IBRETOUR

  IBRETOUR = 1
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBOMPB
  If GOK < 1 Then
     Return
  Endif
  #Traitement de la cloture
  If [M:OMP2]CLO = 2 Then
    # FGR 09/10/2012 : X3SUIVI84266 (début)
    #Call CLOOPGCALL ([M:OMP0]OMPNUM, INUMMES,ICHAPTER,IBRETOUR) From SUBCMGB
    #If IBRETOUR = 0 Then
    #  GMESSAGE = mess(INUMMES,ICHAPTER,1) #Erreur lors de la clôture.
    #  GERR = 1
    #  GOK=0
    #  Return
    #Endif
    Call CLOOMPCLL ([M:OMP0]OMPNUM, GMESSAGE, IBRETOUR) From SUBCMGB
    If IBRETOUR = 0 Then
      GERR = 1
      GOK=0
      Return
    Endif
    # FGR 09/10/2012 : X3SUIVI84266 (fin)
  Endif
  # Maj des statistiques
  Call VALSTA("OMP",1) From SUBPS2
Return

##########################################################################################################
$MODIF
Local Integer INUMMES
Local Integer ICHAPTER
Local Integer IBRETOUR

  IBRETOUR = 1
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBOMPB
  If GOK < 1 Then
    Return
  Endif
  #Traitement de la cloture
  If [M:OMP2]CLO = 2 Then
    If [M:OMP0]OMPPRECLO <> 2 Then
      # FGR 09/10/2012 : X3SUIVI84266 (début)
      #Call CLOOPGCALL ([M:OMP0]OMPNUM, INUMMES,ICHAPTER,IBRETOUR) From SUBCMGB
      #If IBRETOUR = 0 Then
      #  GMESSAGE = mess(INUMMES,ICHAPTER,1) #Erreur lors de la clôture.
      #  GERR = 1
      #  GOK = 0
      #  Return
      #Endif
      Call CLOOMPCLL ([M:OMP0]OMPNUM, GMESSAGE, IBRETOUR) From SUBCMGB
      If IBRETOUR = 0 Then
        GERR = 1
        GOK=0
        Return
      Endif
      # FGR 09/10/2012 : X3SUIVI84266 (fin)
    Endif
  Endif
  # Maj des statistiques
  Call VALSTA("OMP",-1) From SUBPS2
  Call VALSTA("OMP",1) From SUBPS2
Return

##########################################################################################################
$APRES_CRE
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBOMPB
  [M:OMP0]PREFULOBJ = [M:OMP1]FULOBJ
  [M:OMP0]PREOBJ = [M:OMP1]OBJ
  [M:OMP0]OMPPRECLO = [M:OMP2]CLO
  Affzo [M:OMP1]1-99
Return

##########################################################################################################
$APRES_MOD
  #Si l'objectif a été modifié, il faut mettre à jour l'objet des appels
  Call MNGUPDCLOB("OMP", [M:OMP0]OMPNUM) From SUBCMGB
  If !GERR Then
    #Si la synthèse a été modifiée, il faut mettre à jour la synthèse sur chaque appel
    Call MNGUPDSYN("OMP", [M:OMP0]OMPNUM) From SUBCMGB
  Endif
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBOMPB
  [M:OMP0]PREOBJ = [M:OMP1]OBJ
  [M:OMP0]PREFULOBJ = [M:OMP1]FULOBJ
  [M:OMP0]OMPPRECLO = [M:OMP2]CLO
  Affzo [M:OMP1]1-99
Return

##########################################################################################################
$VERF_ANU
Local Integer IOMPREP

  IOMPREP = 0
  Gosub CONFIRM_ANU From SUBOMM
  If OK = 0 Then
    Return
  Endif
  #Souhaitez-vous supprimer les appels restant à effectuer pour cette opération ?
  [M:OMP0]CLLDELFLG = 0
  Call OUINON(mess(915,182,1), IOMPREP) From GESECRAN
  If IOMPREP = 2 Then
    [M:OMP0]CLLDELFLG = 1
    GSZDELOPGNUM = [M:OMP0]OMPNUM
  Else
    [M:OMP0]CLLDELFLG = 0
  Endif
Return

##########################################################################################################
$AV_ANNULE
Local Char GSZOPGNUM
Local Integer IDELTODOCALL

  GSZOPGNUM = [M:OMP0]OMPNUM
  IDELTODOCALL = 0
  If [M:OMP0]CLLDELFLG Then
    IDELTODOCALL = 1
  Else
    IDELTODOCALL = 0
  Endif
  #Suppression des appels générés et restant à effectuer
  Gosub ANNULEOMP
Return

##########################################################################################################
$ANNULEOMP
  Gosub CANCELSTEP From TRTMGD1
  If GOK = 0 Then
    Return
  Endif
  Gosub CANCELSTEP From TRTMAI3
  If GOK = 0 Then
    Return
  Endif
  Gosub CLEANHISTO From SUBOMMB
  If GOK = 0 Then
    Return
  Endif
  #Suppression des clobs
  Gosub DELCLOB2 From SUBOMPB
  If GOK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$ANNULE
  # Maj des statistiques
  Call VALSTA("OMP",-1) From SUBPS2
Return

##########################################################################################################
$AP_ANNULE
Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF

  If [M:OMP0]CLLDELFLG Then
    #Suppression des appels générés par la campagne d'appels et restant à effectuer
    SZCLE = ""
    ICUT = 2500
    ICLECOUNT = ICUT
    IPERF = 0
    INTR = 0
    While ICLECOUNT >= ICUT
      ICLECOUNT = 0
      Filter [CLL] Where [F:CLL]CLLOPGNUM = GSZDELOPGNUM
&                    and [F:CLL]CLLDON <> 2
&                    and [F:CLL]CLLCMGFLG > 0
&                    and [F:CLL]CLLNUM > SZCLE
&               Order By [F:CLL]CLLNUM Asc
      For [CLL]
        SZCLE = [F:CLL]CLLNUM
        If IPERF = 0 Then
          Trbegin [HD5], [HD4], [CTT]
          INTR = 1
        Endif
        Delete [HD4] Where [F:HD4]NUM = [F:CLL]CLLNUM and [F:HD4]TYP = "CLLRPO"
        If fstat Then
          #Erreur lors de la suppression des appels restant à effectuer
          GMESSAGE = mess(916,182,1)
          GERR = 1
          Rollback
          INTR = 0
          Break
        Endif
        Delete [HD5] Where [F:HD5]NUM = [F:CLL]CLLNUM and [F:HD5]TYP = "CLLOBJ"
        If fstat Then
          #Erreur lors de la suppression des appels restant à effectuer
          GMESSAGE = mess(916,182,1)
          GERR = 1
          Rollback
          INTR = 0
          Break
        Endif
        Delete [CTT] Where [F:CTT]CLLNUM = [F:CLL]CLLNUM
        If fstat Then
          #Erreur lors de la suppression des appels restant à effectuer
          GMESSAGE = mess(916,182,1)
          GERR = 1
          Rollback
          INTR = 0
          Break
        Endif
        If IPERF >= 478 Then
          Commit
          IPERF = 0
          INTR = 0
        Else
          IPERF += 1
        Endif
        ICLECOUNT += 1
        If ICLECOUNT >= ICUT Then
          Break
        Endif
      Next
      Filter [CLL]
      If GERR Then
        Break
      Endif
    Wend
    If GERR Then
      Return
    Endif
    Delete [CLL] Where [F:CLL]CLLOPGNUM = GSZDELOPGNUM
    If fstat Then
      #Erreur lors de la suppression des appels restant à effectuer.
      GMESSAGE = mess(916,182,1)
      GERR = 1
      Rollback
      Return
    Endif
    If INTR Then
      If !GERR Then
        Commit
      Endif
    Endif
  Endif
Return

##########################################################################################################
$RAZCRE
  #Initialise le site par défaut
  Call SITECRMDEF ("ACT", [M:OMP0]FCY) From CRM_UTIL
  GFCY = [M:OMP0]FCY
  Call GETDEV(GFCY) From DEVSUB
  #Initialise la devise par défaut
  [M:OMP1]CUR = GSYSCUR
  #Initialise le statut de clôture.
  [M:OMP2]CLO = 1
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBOMPB
  [M:OMP0]OMPNUM = ""
  [M:OMP0]PREFULOBJ = [M:OMP1]FULOBJ
  [M:OMP0]PREOBJ = [M:OMP1]OBJ
  [M:OMP0]OMPPRECLO = 1
  Affzo [M:OMP0]1-99
  Affzo [M:OMP1]1-99
  Affzo [M:OMP2]1-99
Return

##########################################################################################################
$FILGAUCHE
  Default File [OMP]
  If currbox = GBOXOMP Then
    #Campagnes d'appels
    Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "CLO <> 2", "&") From GOBJSUB
  Elsif currbox = GBOXOP2 Then
    #Campagne d'appels clôturées
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "CLO = 2", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "OMP") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Endif
Return

##########################################################################################################
$LIENS
  GFCY = [M:OMP0]FCY
  Call GETDEV(GFCY) From DEVSUB
  #---------------------------------------------------#
  #Lecture des clobs
  #---------------------------------------------------#
  Gosub LOADCLOB From SUBOMPB
  #Affiche le nom de la campagne
  If [M:OMP0]CMGNUM <> "" Then
    Read [CMG]CMG0=[M:OMP0]CMGNUM
    If fstat Then
      [M:OMP0]CMGTTR = [M:OMP0]CMGNUM
    Else
      [M:OMP0]CMGTTR = [F:CMG]TTR
    Endif
  Endif
  #Affiche le script d'appel
  If [M:OMP2]SCPNUM = "" Then
    [M:OMP2]SCPNAM = ""
  Else
    Read [SCP]SCP0=[M:OMP2]SCPNUM
    If fstat Then
      [M:OMP2]SCPNAM = ""
    Else
      [M:OMP2]SCPNAM = [F:SCP]SCPNAM
    Endif
  Endif
  #Affiche les téléacteurs participants
  Call LOADTSALES([M:OMP0]OMPNUM) From SUBOMPB
  [M:OMP0]SELTLS = ""
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBOMPB
  [M:OMP0]PREFULOBJ = [M:OMP1]FULOBJ
  [M:OMP0]PREOBJ = [M:OMP1]OBJ
  [M:OMP0]OMPPRECLO = [M:OMP2]CLO
  Affzo [M:OMP1]1-99
  Affzo [M:OMP2]1-99
Return

##########################################################################################################
Subprog AM_CLO(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    If [M:OMP0]OMPPRECLO <> 2 Then
      [M:OMP2]CLODAT = date$
      [M:OMP2]NBRCLLPCDX = 0
    Endif
  Endif
End

##########################################################################################################
Subprog C_OMPEND(VALEUR)
Variable Date    VALEUR

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  If VALEUR <> [00/00/00] Then
    Call CMGCTRLDATEFIN (VALEUR,[M:OMP0]CMGNUM,IERRINF,ICHAPTER,IBRETOUR) From SUBCMGB
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End

##########################################################################################################
Subprog IB_FULOBJ
  Raz GBOUT1
  If [M:OMP1]FULOBJ <> "" Then
    If len([M:OMP1]FULOBJ) > GLONCLE Then
      Call TEXTE(23819, GBOUT1) From OBJDIV      #Synthèse
    Endif
  Endif
End

##########################################################################################################
Subprog AM_FULOBJ (VALEUR)
Variable Clbfile VALEUR

  Call GERE_TEXTE_SYNTHESE([M:OMP1]FULOBJ, VALEUR, [M:OMP1]OBJ) From CRMUTIL150  # FGR 06/08/2014 : X3SUIVI95250
  [M:OMP1]FULOBJ = VALEUR
  Gosub DISPICON From SUBOMPB
  Affzo [M:OMP1]1-99
End

##########################################################################################################
Subprog AS_NBREP

  If nolign < 1 Then
    End
  Endif
  [M:OMP0]SELTLS = [M:OMP2]OMPREP(nolign-1)
End

##########################################################################################################
Subprog C_NBREP

  If nolign < 1 Then
    End
 Endif
  [M:OMP0]SELTLS = [M:OMP2]OMPREP(nolign-1)
End

##########################################################################################################
Subprog IB_NBREP

  Raz GBOUT1
  If [M:OMP2]CLO = 2 Then
    Call TEXTE(15158, GBOUT1) From OBJDIV      #Appels effectués
  Else
    Call TEXTE(25824, GBOUT1) From OBJDIV      #Planifier un appel
  Endif
End

##########################################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  GFCY = VALEUR
  Call GETDEV(GFCY) From DEVSUB
End

##########################################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  If VALEUR <> "" Then
    Call CMGCTRLFCY (VALEUR,[M:OMP0]CMGNUM,IERRINF,ICHAPTER,IBRETOUR) From SUBCMGB
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AV_FCY(VALEUR)
Variable Char    VALEUR()

  # FGR 21/01/2013 : X3SUIVI71937
  If dim(GCOMPCPT) < 0 Then
    Global Char GCOMPCPT(GLONANM)   # Code compteur pour une opération marketing
  Endif
End

##########################################################################################################
Subprog C_OMPSTR(VALEUR)
Variable Date    VALEUR

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  If VALEUR <> [00/00/00] Then
    Call CMGCTRLDATEDEB (VALEUR,[M:OMP0]CMGNUM,IERRINF,ICHAPTER,IBRETOUR) From SUBCMGB
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End

