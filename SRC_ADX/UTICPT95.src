#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTICPT95   UTI process                                    Module CPT   #
#            correction utility
#
# Issue X3-52049 - 2018-01-22 by FHA : ORI ORIC records initiated in GDD if necessary
#
##########################################################################


Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("GDD table Update: Creation of ORI* records") From LECFIC
  Call MAJ_UTICPT95(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTICPT95(DOSSIER)
Value Char DOSSIER

# Issue X3-56195 - 2017-09-15 by GLE : Do not perform on archive folders
If (func DOSSUB.ISHISTFOLD(DOSSIER))
  Call ECR_TRACE("UTICPT95 : Not to perform on archive folder : "+DOSSIER,0) From GESECRAN
  End
Endif

Local Integer WCOMPTEUR
Call ECR_TRACE("UTICPT95 : GDD Update: Creation of ORI* records",0) From GESECRAN
Call ECR_TRACE("UTICPT95 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:GDD])  =0  Local File =DOSSIER+".GDIAENTRYD"   [GDD] : Endif
If clalev([F:GD2])  =0  Local File =DOSSIER+".GDIAENTRYD"   [GD2] : Endif
If clalev([F:GD3])  =0  Local File =DOSSIER+".GDIAENTRYD"   [GD3] : Endif

WCOMPTEUR = 0
Call DEBTRANS From GLOCK

Trbegin [GD3]
For [F:GDD]GDD0(1)
  # ORI record
  Look [GD2]GDD0=[F:GDD]DIA;"ORI"
  If fstat
      Raz [F:GD3]
      [F:GD3]DIA=[F:GDD]DIA
      [F:GD3]FLD="ORI"
      [F:GD3]CRD=1
      [F:GD3]DAC=2
      [F:GD3]CREUSR=GUSER
      Write [F:GD3]
      If !fstat
        WCOMPTEUR+=1
        Call ECR_TRACE("GDD:"-[F:GD3]DIA+"/"+[F:GD3]FLD-"created in"-DOSSIER,0) From GESECRAN
      Else
        Call ECR_TRACE("GDD:"-[F:GDD]DIA+"/ORI"-"creation failed."-DOSSIER,1) From GESECRAN
      Endif
  Else
      Call ECR_TRACE("GDD:"-[F:GDD]DIA+"/ORI"-"record not created because already present."-DOSSIER,0) From GESECRAN
  Endif
  # ORIC record
  Look [GD2]GDD0=[F:GDD]DIA;"ORIC"
  If fstat
      Raz [F:GD3]
      [F:GD3]DIA=[F:GDD]DIA
      [F:GD3]FLD="ORIC"
      [F:GD3]CRD=1
      [F:GD3]DAC=2
      [F:GD3]CREUSR=GUSER
      Write [F:GD3]
      If !fstat
        WCOMPTEUR+=1
        Call ECR_TRACE("GDD:"-[F:GD3]DIA+"/"+[F:GD3]FLD-"created in"-DOSSIER,0) From GESECRAN
      Else
        Call ECR_TRACE("GDD:"-[F:GDD]DIA+"/ORIC"-"creation failed."-DOSSIER,1) From GESECRAN
      Endif
  Else
      Call ECR_TRACE("GDD:"-[F:GDD]DIA+"/ORIC"-"record not created because already present."-DOSSIER,0) From GESECRAN
  Endif
Next
Filter [F:GDD]
Commit

Close Local File [GDD]
Close Local File [GD2]
Close Local File [GD3]

Call ECR_TRACE("UTICPT95 : "+num$(WCOMPTEUR)+" records created",0) From GESECRAN

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif

If [F:ADS]MODULE(1)<>2 : End : Endif                                 : # module compta

Call MAJ_UTICPT95(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(1)<>2 : End : Endif                                 : # module compta

Call MAJ_UTICPT95(APPLI)
End

