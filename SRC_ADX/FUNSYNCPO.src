#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################
# FUNSYNCPO : Resynchronisation des ordres POP,POF          MBT 15/04/04 #
# ---------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais une fonction                     #
#  - Recréation des encours POP manquants pour les demandes d'achat      #
#  - Recréation des encours POP,POF,TRP,TRF manquants pour les cdes & DL #
# ---------------------------------------------------------------------- #
# Ce traitement est appelé depuis le FUNSYNCW                            #
#  - Le masque écran SYNCW [DIA] doit être ouvert et chargé              #
# Ce traitement peut également être lancé manuellement                   #
##########################################################################


Call OUVRE_TRACE("Recréation des encours manquants (module achats)") From LECFIC
#-----
Local Mask    SYNCW [DIA] : Raz [M:DIA]
Local Libelle WFLAG       : WFLAG=1
Local Integer OK
#-----
GCONSDIA=0
Call DIALWIN(OK,mess(188,195,1),"DSYNCW") From GESECRAN
If OK=2 & [M:DIA]POREGEN=2
  Gosub REGEN_PO
  Call ECR_TRACE("Nombre de contrôles effectués     : "+num$(NBANA),0) From GESECRAN
  If [M:DIA]AUTCOR<>2
    Call ECR_TRACE("Nombre de corrections à effectuer : "+num$(NBMAJ),0) From GESECRAN
  Else
    Call ECR_TRACE("Nombre de corrections effectuées  : "+num$(NBMAJ),0) From GESECRAN
  Endif
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
#-----
End


####################################
# Recréation des encours manquants #
####################################
$REGEN_PO
#----- Ouverture des tables si nécessaire -----#
If !clalev([F:ORD])  Local File ORDERS   [ORD]  : Endif
If !clalev([F:PSD])  Local File PREQUISD [PSD]  : Endif
If !clalev([F:POQ])  Local File PORDERQ  [POQ]  : Endif
#----- Ouverture masque écran si nécessaire -----#
If !clalev([M:ORDK]) Local Mask ORDK     [ORDK] : Endif
#----- Variables locales -----#
Local Integer SAV_NBMAJ
If dim(CRITERE)<1  Local Char    CRITERE(60) : Endif
If dim(NBANA)  <1  Local Integer NBANA       : Endif
If dim(WMSG)   <1  Local Char    WMSG(100)   : Endif
If dim(WFLAG)  <1  Local Libelle WFLAG       : Endif
If dim(WNBPSD) <1  Local Integer WNBPSD      : Endif
If dim(WNBPOQ) <1  Local Integer WNBPOQ      : Endif
If dim(NBMAJ)<1
  Local Integer NBMAJ
  Raz SAV_NBMAJ
Else
  SAV_NBMAJ=NBMAJ
Endif
#-----
Raz WMSG, WNBPSD,WNBPOQ
Call DEBTRANS From GLOCK
#----- Traitement des lignes demandes d'achats non soldées et gérées en stock -----#
If [M:DIA]STOFCY<>""
  CRITERE ='PRHFCY="'+[M:DIA]STOFCY+'"'   : # Site de stockage
Else
  CRITERE ="1=1"
Endif
If [M:DIA]ITMREF<>""
  CRITERE-='& ITMREF="'+[M:DIA]ITMREF+'"' : # Référence article
Endif
#----- Trace uniquement si lancement direct -----#
If WFLAG
  WMSG="- "+mess(446,197,1)+" " : WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
#-----
For [PSD] Where LINCLEFLG=1 & WIPNUM<>"" & evalue(CRITERE) With Nohint
  NBANA+=1 : WNBPSD+=1 : Gosub REGEN_PSD : If GOK<1  Break : Endif
Next
#----- Trace uniquement si lancement direct -----#
If WFLAG
  WMSG="- ("+num$(WNBPSD)+") " : WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN : Call ECR_TRACE(" ",0)  From GESECRAN
Endif
#-----
If GOK<1  Return : Endif
#----- Traitement des lignes de commandes ou DL non soldées et gérées en stock -----#
If [M:DIA]STOFCY<>""
  CRITERE ='PRHFCY="'+[M:DIA]STOFCY+'"'   : # Site de stockage
Else
  CRITERE ="1=1"
Endif
If [M:DIA]ITMREF<>""
  CRITERE-='& ITMREF="'+[M:DIA]ITMREF+'"' : # Référence article
Endif
#----- Trace uniquement si lancement direct -----#
If WFLAG
  WMSG="- "+mess(447,197,1)+" " : WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
#-----
For [POQ] POQ2 Where LINCLEFLG=1 & WIPNUM<>"" & evalue(CRITERE)
  NBANA+=1 : WNBPOQ+=1 : Gosub REGEN_POQ : If GOK<1  Break : Endif
Next
#----- Trace uniquement si lancement direct -----#
If WFLAG
  WMSG="- ("+num$(WNBPOQ)+") " : WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN : Call ECR_TRACE(" ",0)  From GESECRAN
Endif
#-----
If [M:DIA]AUTCOR<>2 & dim(NBORD)>0
  NBORD+=NBMAJ
  NBMAJ=SAV_NBMAJ
Endif
#-----
If GOK<1  Return : Endif
Return


#------------------------------#
# Traitement d'une ligne de DA #
#------------------------------#
$REGEN_PSD
# Pas besoin de recréér l'en-cours si qté cde >= qté initiale
If [F:PSD]QTYSTU-[F:PSD]ORDQTYSTU<=0  Return : Endif

If dim([M:DIA]CTLDAT)>0 & [M:DIA]CTLDAT=2   # FQ 69974 GA 12/2010 Ctrl des dates de l'encours
  Read [ORD] ORD0=2;[F:PSD]WIPNUM;[F:PSD]ITMREF
  If !fstat  & (([F:ORD]STRDAT=[F:PSD]EXTORDDAT & [F:ORD]ENDDAT=[F:PSD]EXTRCPDAT ) | [F:ORD]WIPSTA<>2)
    Return
  Endif
  Call ECR_TRACE(mess(53,183,1)-"ORDERS"-mess([F:POQ]WIPTYP,341,1)+mess([F:ORD]WIPSTA,342,1)-
&                  [F:PSD]WIPNUM-[F:PSD]ITMREF
&                  -"\        Date début"-num$([F:ORD]STRDAT)-num$([F:PSD]EXTORDDAT)
&                             -"Date fin"-num$([F:ORD]ENDDAT)-num$([F:PSD]EXTRCPDAT)
&                  ,0) From GESECRAN
  Return            # 76376
Else
  Look [ORD] ORD0=2;[F:PSD]WIPNUM;[F:PSD]ITMREF
  If !fstat  Return : Endif
Endif

#----- Trace uniquement si lancement direct -----#
If WFLAG
  Call ECR_TRACE(mess(51,197,1)-mess(238,198,1)-[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)-
&                "2 2"-[F:PSD]WIPNUM,0) From GESECRAN
Endif
If [M:DIA]AUTCOR<>2  NBMAJ+=1 : Return : Endif
#----- Recréation de l'encours (POP) -----#
Trbegin [ORD]
  Raz [M:ORDK]
  [M:ORDK]MAJCOD    = "C"
  [M:ORDK]WIPTYP    = 2
  [M:ORDK]WIPSTA    = 2
  [M:ORDK]WIPNUM    = [F:PSD]WIPNUM
  [M:ORDK]ITMREF    = [F:PSD]ITMREF

  # Issue 102513 - 2018-07-31 by STLIG : communicate versions to WIP
  [M:ORDK]ECCVALMAJ = [F:PSD]ECCVALMAJ
  [M:ORDK]ECCVALMIN = [F:PSD]ECCVALMIN

  [M:ORDK]STOFCY    = [F:PSD]PRHFCY
  [M:ORDK]PJT       = [F:PSD]PJT
  [M:ORDK]BPRNUM    = [F:PSD]BPSNUM
  [M:ORDK]STRDAT    = [F:PSD]EXTORDDAT
  [M:ORDK]ENDDAT    = [F:PSD]EXTRCPDAT
  [M:ORDK]VCRTYP    = 14
  [M:ORDK]VCRNUM    = [F:PSD]PSHNUM
  [M:ORDK]VCRLIN    = [F:PSD]PSDLIN
  [M:ORDK]VCRSEQ    = 0
  [M:ORDK]EXTQTY    = [F:PSD]QTYSTU
  [M:ORDK]CPLQTY    = [F:PSD]ORDQTYSTU
  [M:ORDK]ALLQTY    = 0
  [M:ORDK]SHTQTY    = 0
  [M:ORDK]FMI       = 1
  [M:ORDK]MRPMES    = 1
  [M:ORDK]ORIFCY    = [F:PSD]PSHFCY
  [M:ORDK]VCRTYPORI = 0
  [M:ORDK]VCRNUMORI = ""
  [M:ORDK]VCRLINORI = 0
  [M:ORDK]VCRSEQORI = 0
  [M:ORDK]BOMALT    = 0
  [M:ORDK]ORI       = 1
  [M:ORDK]ABBFIL    = "PSD"
  Call WIP From TRTWIP
  If GOK<1
    Rollback
    Call ECR_TRACE(mess(13,100,1)-"ORDERS"-"2 2"-[F:PSD]WIPNUM-
&                  [F:PSD]ITMREF,1) From GESECRAN
    Return
  Endif
Commit
NBMAJ+=1
Return


#------------------------------------#
# Traitement d'une ligne de commande #
#------------------------------------#
$REGEN_POQ
# Pas besoin de recréér l'en-cours si qté rcp >= qté initiale
If [F:POQ]QTYSTU-[F:POQ]RCPQTYSTU<=0  Return : Endif

If dim([M:DIA]CTLDAT)>0 & [M:DIA]CTLDAT=2   # FQ 69974 GA 12/2010 Ctrl des dates de l'encours
  Read [ORD] ORD0=[F:POQ]WIPTYP;[F:POQ]WIPNUM;[F:POQ]ITMREF
  If !fstat  & (([F:ORD]STRDAT=[F:POQ]ORDDAT & [F:ORD]ENDDAT=[F:POQ]EXTRCPDAT ) | [F:ORD]WIPSTA>1)
    Return
  Endif
  Call ECR_TRACE(mess(53,183,1)-"ORDERS"-mess([F:POQ]WIPTYP,341,1)+mess([F:ORD]WIPSTA,342,1)-
&                  [F:POQ]WIPNUM-[F:POQ]ITMREF
&                  -"\        Date début"-num$([F:ORD]STRDAT)-num$([F:POQ]ORDDAT)
&                  -"Date fin"-num$([F:ORD]ENDDAT)-num$([F:POQ]EXTRCPDAT)
&                  ,0) From GESECRAN
  Return            # 76376
Else
  Look [ORD] ORD0=[F:POQ]WIPTYP;[F:POQ]WIPNUM;[F:POQ]ITMREF
  If !fstat  Return : Endif
Endif

#----- Trace uniquement si lancement direct -----#
If WFLAG
  Call ECR_TRACE(mess(51,197,1)-mess(238,198,1)-[F:POQ]POHNUM-num$([F:POQ]POPLIN)-
&                num$([F:POQ]POQSEQ)-[F:PSD]WIPNUM,0) From GESECRAN
Endif
If [M:DIA]AUTCOR<>2  NBMAJ+=1 : Return : Endif
#----- Recréation de l'encours (POP, POF, TRP, TRF) -----#
Trbegin [ORD]
  Raz [M:ORDK]
  [M:ORDK]MAJCOD    = "C"
  [M:ORDK]WIPTYP    = [F:POQ]WIPTYP
  [M:ORDK]WIPSTA    = [F:POQ]WIPSTA
  [M:ORDK]WIPNUM    = [F:POQ]WIPNUM
  [M:ORDK]ITMREF    = [F:POQ]ITMREF

  # Issue 102513 - 2018-07-31 by STLIG : communicate versions to WIP
  [M:ORDK]ECCVALMAJ = [F:POQ]ECCVALMAJ
  [M:ORDK]ECCVALMIN = [F:POQ]ECCVALMIN

  [M:ORDK]STOFCY    = [F:POQ]PRHFCY
  [M:ORDK]PJT       = ""
  [M:ORDK]BPRNUM    = [F:POQ]BPSNUM
  [M:ORDK]STRDAT    = [F:POQ]ORDDAT
  [M:ORDK]ENDDAT    = [F:POQ]EXTRCPDAT
  [M:ORDK]VCRTYP    = 14
  [M:ORDK]VCRNUM    = [F:POQ]POHNUM
  [M:ORDK]VCRLIN    = [F:POQ]POPLIN
  [M:ORDK]VCRSEQ    = [F:POQ]POQSEQ
  [M:ORDK]EXTQTY    = [F:POQ]QTYSTU
  [M:ORDK]CPLQTY    = [F:POQ]RCPQTYSTU
  [M:ORDK]ALLQTY    = 0
  [M:ORDK]SHTQTY    = 0
  [M:ORDK]FMI       = 1
  [M:ORDK]MRPMES    = 1
  If [F:POQ]WIPTYP=7
    [M:ORDK]ORIFCY  = [F:POQ]LINSTOFCY
    If [F:POQ]OCNLIN<>0
      [M:ORDK]VCRTYPORI = 2
      [M:ORDK]VCRNUMORI = [F:POQ]LINOCNNUM
      [M:ORDK]VCRLINORI = [F:POQ]OCNLIN
      [M:ORDK]VCRSEQORI = [F:POQ]OCNSEQ
    Else
      [M:ORDK]VCRTYPORI = 0
      [M:ORDK]VCRNUMORI = ""
      [M:ORDK]VCRLINORI = 0
      [M:ORDK]VCRSEQORI = 0
    Endif
  Else
    [M:ORDK]ORIFCY    = [F:POQ]POHFCY
    [M:ORDK]VCRTYPORI = 0
    [M:ORDK]VCRNUMORI = ""
    [M:ORDK]VCRLINORI = 0
    [M:ORDK]VCRSEQORI = 0
  Endif
  [M:ORDK]BOMALT    = 0
  [M:ORDK]ORI       = 1
  [M:ORDK]ABBFIL    = "POQ"
  Call WIP From TRTWIP
  If GOK<1
    Rollback
    Call ECR_TRACE(mess(13,100,1)-"ORDERS"-num$([F:POQ]WIPTYP)-num$([F:POQ]WIPSTA)-
&                  [F:POQ]WIPNUM-[F:POQ]ITMREF,1) From GESECRAN
    Return
  Endif
Commit
NBMAJ+=1
Return

