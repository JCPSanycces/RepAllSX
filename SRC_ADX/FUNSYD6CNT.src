#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'une correspondant. (exemple)
#############################################################################
$COR_SET_HEA_INFO
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  #CHECK FILE_DECLARE CONTACTCRM [AIN6]
  #CHECK FILE_DECLARE BPADDRESS [BPA6]
  #CHECK FILE_DECLARE CONTACT [CNT6]
  #CHECK FILE_DECLARE BPCUSTOMER [BPC6]
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  Case IMPZON
    When "CNTNUM"
      #Code interlocuteur
      If GREP = "C" Then
        [M:COR0]CNTNUM = [F:AIN6]CNTNUM
        [M:COR0]UPDCNTNUM = 0
      Endif
    When "CPYEML"
      #E-mail professionnel
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR2]CPYEML = [F:CNT6]WEB 
      #Endif
    When "HOMEML"
      #E-mail personnel
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR3]HOMEML = [F:AIN6]CNTEMA      
      #Endif
    When "CPYZIP"
      #Code postal professionnel
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR2]CPYZIP = [F:BPA6]POSCOD     
      #Endif
    When "HOMZIP"
      #Code postal personnel
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR3]HOMZIP = [F:AIN6]ZIP      
      #Endif
    When "CPYSAT"
      #Etat professionnel
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR2]CPYSAT = [F:BPA6]SAT
      #Endif
    When "HOMSAT"
      #Etat personnel
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR3]HOMSAT = [F:AIN6]SAT
      #Endif
    When "LNA"
      #Nom
      #If GREP = "C" Then    # FGR 25/03/2010 : X3SUIVI63506       
        [M:COR0]LNA = [F:AIN6]CNTLNA      
      #Endif
      #On affecte le représentant de forcage
      [M:COR0]FORCAGEREP = GSZREPSYNC            
    When "CPYCRY"
      #Pays (prodessionel)
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR2]CPYCRY = [F:BPA6]CRY
      #Endif
    When "CPYCRYNAM"
      #Libellé Pays (prodessionel)
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR2]CPYCRYNAM = [F:BPA6]CRYNAM
      #Endif
    When "HOMCRY"
      #Pays (personnel)
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR3]HOMCRY = [F:AIN6]CRY
      #Endif
    When "HOMCRYNAM"
      #Libellé Pays (personnel)
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR3]HOMCRYNAM = [F:AIN6]CRYNAM
      #Endif
    When "FNA"
      #Prénom
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR0]FNA = [F:AIN6]CNTFNA     
      #Endif
    When "CPYADD"
      #Adresse rue (professionnel)
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        Case indice
          When 0
            [M:COR2]CPYADD(0) = [F:BPA6]BPAADDLIG(0)
          When 1    
            [M:COR2]CPYADD(1) = [F:BPA6]BPAADDLIG(1)
          When 2
            [M:COR2]CPYADD(2) = [F:BPA6]BPAADDLIG(2)
        Endcase
      #Endif
    When "HOMADD"
      #Adresse rue (personnel)
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        Case indice
          When 0
            [M:COR3]HOMADD(0) = [F:AIN6]ADD(0)
          When 1    
            [M:COR3]HOMADD(1) = [F:AIN6]ADD(1)
          When 2
            [M:COR3]HOMADD(2) = [F:AIN6]ADD(2)
        Endcase
      #Endif
    When "BPRNUM"
      #Code tiers
      If GREP = "C" Then
        [M:COR2]BPRNUM = [F:BPC6]BPCNUM
        [M:COR2]UPDBPRNUM = 0
      Endif
    When "BPRLIB"
      #Libellé tiers
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR2]BPRLIB = [F:BPC6]BPCNAM    
      #Endif
    When "CPYFAX"
      #Fax (professionnel)
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR2]CPYFAX=[F:CNT6]FAX
      #Endif
    When "HOMFAX"
      #Fax (personnel)
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR3]HOMFAX = [F:AIN6]CNTFAX
      #Endif
    When "CPYTEL"
      #Téléphone (professionnel)
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR2]CPYTEL = [F:CNT6]TEL      
      #Endif
    When "HOMTEL"
      #Téléphone (personnel)
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR3]HOMTEL = [F:AIN6]CNTETS      
      #Endif
    When "HOMMOB"
      #telephone portable (personnel)
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR3]HOMMOB = [F:AIN6]CNTMOB
      #Endif
    When "FNC"    
      #code fonction
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR2]FNC = [F:CNT6]CNTFNC
      #Endif
    #When "FNCLIB"
    #  # FGR 26/03/2009 : X3SUIVI50275 : changement sur la façon de gérer ça
    #  #Libellé fonction
    #  If GREP = "C" Then
    #    [M:COR2]FNCLIB = mess([F:CNT6]CNTFNC,233,1)
    #  Endif
    When "TTL"
      #Civilité
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR0]TTL = [F:AIN6]CNTTTL
      #Endif
   When "CPYCTY"
      #Ville (professionnel)
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR2]CPYCTY = [F:BPA6]CTY 
      #Endif
   When "HOMCTY"
      #Ville (personnel)
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR3]HOMCTY = [F:AIN6]CTY
      #Endif
    When "CPYBPANUM"
      #code adresse
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR2]CPYBPANUM = [F:BPA6]BPAADD
        [M:COR2]CPYBPATYP = [F:BPA6]BPATYP
      #Endif
    When "CPYBPADES"
      #Inttitulé adresse
      #If GREP = "C" Then   # FGR 25/03/2010 : X3SUIVI63506
        [M:COR2]CPYBPADES = [F:BPA6]BPADES
      #Endif
  Endcase
Return

#############################################################################
#DETAIL
$COR_SET_DET_INFO
  Case IMPZON
    When "COPREP"
      If GREP = "C" Then
        [M:COR4]COPREP(0) = GSZREPSYNC
      Endif
  Endcase
Return
