#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
# Gestion des commandes ouvertes : demandes de livraisons        SUBSOQ #
#-----------------------------------------------------------------------#
# DÃĐcembre 1997                                                      TS #
#########################################################################
# Issue 114112 - 20160302 by LD : Modif ECCVALMAJ ECCVALMIN non rÃĐpercutÃĐe ds ORDERS
# Issue X3-39248 - 20170602 by LD : Delivery requests with empty ORIFCY field in ORDERS table
# Issue X3-66385 - 20180221 by LD : Sales order: Default package by shipment site

#########################################################################
# SECTION CONTENANT LES ACTIONS SUR L'OBJET                             #
#########################################################################
$ACTION
Case ACTION
 When "OUVRE"          : Gosub OUVRE
 When "FILTRE"         : Gosub FILTRE
 When "BOITE"          : Gosub BOITE
 When "DEFLIG"         : Gosub DEFLIG
 When "SETBOUT"        : Gosub SETBOUT
 When "INICRE_LIG"     : Gosub INICRE_LIG
 When "CREATION"       : Gosub CREATION
 When "VERIF_CRE"      : Gosub VERIF_CRE
 When "VERIF_MOD"      : Gosub VERIF_MOD
 When "APRES_CRE"      : Gosub APRES_CRE
 When "LIENS"          : Gosub LIENS
 When "LIENS_LIG"      : Gosub LIENS_LIG
 When "AVANT_MOD"      : Gosub AVANT_MOD
 When "AVANT_MODFIC"   : Gosub AVANT_MODFIC
 When "INIMOD_LIG"     : Gosub INIMOD_LIG
 When "MODIF"          : Gosub MODIF
 When "APRES_MOD"      : Gosub APRES_MOD
 When "ANNULE"         : Gosub ANNULE
 When "VALLIG"         : Gosub VALLIG
 When "FERME"          : Gosub FERME
 When "ABANDON"        : Gosub ABANDON
 When "REMP_DERLU"     : Gosub REMP_DERLU
 When "FILGAUCHE"      : Gosub FILGAUCHE
 When Default
Endcase
#--- Actions liÃĐs au type traitement standard
Case ACTION
 When "AB6_NBLIG"  : Gosub AB6_NBLIG
 When "BB6_NBLIG"  : Gosub BB6_NBLIG
 When Default
Endcase
Return

#########################################################################
$OUVRE

#-----------------------------------#
# Sauvegarde des variables globales #
#-----------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
Global Integer GSOQSEQ
Global Integer GSOQSTA
Global Integer GCDTUNL        : # Flag dÃĐblocage crÃĐdit autorise
Global Integer GALLCOD        : # Flag habilitation allocation
Global Integer GMODCOD        : # Flag habilitation modification
Global Char    GLOCCAT(4)     : # Pour filtrer les catÃĐgories d'emplacements
# Filtre catÃĐgorie emplacement pour le contrÃīle et la sÃĐlection emplacement
GLOCCAT="12"

#Local  Integer WNBGAUCHE
#WNBGAUCHE=GNBGAUCHE

If !clalev([F:TCA])  Local File TABCOUAFF  [TCA] Endif

If !clalev([F:GCM])  Local File GACM       [GCM] Endif

Local Char WPARAM(10)
#--------------------------------------------------------------#
# Chargement param.utilisateur dÃĐblocage crÃĐdit autorisÃĐ       #
#--------------------------------------------------------------#
Call PARAMUTIL("SCDTUNL",WPARAM,"","") From SUBAUS
GCDTUNL=val(WPARAM)
If GCDTUNL=0 GCDTUNL=1 Endif

Raz GWIP
GQSEQ = 0
GSOQSEQ = 0
If GMODU(7)=2 GLOCSEL = "[F:STC]LOCCAT<>3&[F:STC]LOCCAT<>4" Endif
Raz GSOC_ACTIVE
GFCY  = GFCYDEF(5)
#Call GETDEV(GFCY) From DEVSUB
# Chargement globales rÃĐfÃĐrenciels, comptes et sections de la sociÃĐtÃĐ
Gosub CHARG_PARAM : If GERR=1 OK=0 : Return Endif
# RÃĐcupÃĐration des paramÃĻtres vente du site / de la sociÃĐtÃĐ
Call GLOBVAR(GFCY,"VEN") From TRTX3
# --- DÃĐclaration classe ecran pour les encours --- #
Local Mask ORDK   [ORDK]
# --- DÃĐclaration classe ecran pour les allocations --- #
Local Mask STOK   [STOK]
# --- DÃĐclaration classe ecran pour les allocations --- #
Local Mask ALLPAR [ALP]

If GMODU(6)=2 & clalev([F:POQ])=0 : Local File PORDERQ [POQ] : Endif

Gosub DECLARE From TABLEAUX

#----------------------------
# V6 Affectations
Gosub OPEN_MTO From MTOLINKLIB

Return

#########################################################################
$FILTRE
Default File [SOC]
Return

#########################################################################
$BOITE
# Si l'on est pas dans les commandes ouvertes
#If !find(GFONC1,"GESSOR","GESSOI","GESSOQ")
#   GNBGAUCHE=0
#Endif
Return

#########################################################################
$DEFLIG
Default Mask [SOQ1]
# Le fichier des lignes doit ÃŠtre "par dÃĐfaut"
Default File [SOQ]
Filter [SOQ]
# CritÃĻre de lecture (uniquement les quantitÃĐs non soldÃĐes)
#CRIT = 'SOHNUM="'+[M:SOQ1]SOHNUM+'" & SOPLIN='+num$([M:SOQ1]SOPLIN)+' & SOQSTA<>'+num$(3)
CRIT = 'SOHNUM="'+[M:SOQ1]SOHNUM+'" & SOPLIN='+num$([M:SOQ1]SOPLIN)+' & SOQSEQ>=GSOQSEQ'
# Nom et abrÃĐviation du fichier ligne
FICLIG = "SORDERQ" : ABLIG = "SOQ"
# Nom de la zone "numÃĐro de ligne"
ZONLIG = "SOQSEQ"
Return

#########################################################################
$SETBOUT
# Suppression des boutons : annulation,crÃĐation,dupplication,chgt code
Call VIREBOUT(CHAINE,"ACDH") From GOBJET
# Si l'on est pas dans les commandes ouvertes
If !find(GFONC1,"GESSOR","GESSOI","GESSOQ")
   Call VIREBOUT(CHAINE,"R<>SL09") From GOBJET
Endif
# --> Gestion des signatures : Si le contrat n'est pas signÃĐ, pas de saisie de lignes DL possible
If [M:SOQ1]APPFLG<3 Call VIREBOUT(CHAINE,"M") From GOBJET Endif

# Supprimer le bouton contrat si l'on est sur un contrat inter-site
#If CLECUR & [M]BETFCY=2
#   Call VIREBOUT(CHAINE,"1") From GOBJET
#Endif
# ------------------------------------------------------------------------------------- #
# Activation/DÃĐsactivation des menus                                                    #
# ------------------------------------------------------------------------------------- #
#     C : DerniÃĻres liv.     : Actif si contrat en ligne et rien en cours               #
#     N : TraÃ§abilitÃĐ piÃĻces                                          SYMEU 08/12/2008  #
# ------------------------------------------------------------------------------------- #
If GREP="" & CLECUR CHMEN += "CD" : Endif
If !find(GREP,"C","D") and !find("CONSPIV",GNAVIG(1..GPILNAV)) Then CHMEN += "N" Endif # SYMEU 08/12/2008 : branchement traÃ§abilitÃĐ piÃĻces
If find("GESSOR",GNAVIG(1..GPILNAV)) Then Call VIREBOUT(CHAINE,"1") From GOBJET Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

####################################################################
$INICRE_LIG

If dim([F:SOQ]CPY)>0 : [F:SOQ]CPY=GSOCIETE : Endif

[F:SOQ]PJT    = [M]DPJT(nolign-1)   # FGR 15/12/2011 : X3SUIVI71065

# Alimentation des zones dÃĐtails du masque 0
[F:SOQ]SOHNUM = [M:SOQ1]SOHNUM
[F:SOQ]SOPLIN = [M:SOQ1]SOPLIN
[F:SOQ]BPCORD = [M:SOQ1]BPCORD
[F:SOQ]SALFCY = [M:SOQ1]SALFCY
[F:SOQ]ORDDAT = date$
[F:SOQ]INVFLG = 1
[F:SOQ]SOHCAT = 4
[F:SOQ]ORIQTY = [F:SOQ]QTY

[F:SOQ]USEPLC    = [M]DUSEPLC(nolign-1)
[F:SOQ]STOFCY    = [M]DSTOFCY(nolign-1)
[F:SOQ]STOMGTCOD = [M]DSTOMGTCOD(nolign-1)

[F:SOQ]FMI = 1

# RÃĐcupÃĐration du chrono pour les en-cours
If [F:ITM]ITMREF <> [M]ITMREF
   Read [ITM] ITM0=[M]ITMREF
   If fstat Raz [F:ITM] Endif
Endif
If [M]DSTOMGTCOD(nolign-1) <> 1
    Call NUMERO(GWIP,[F:SOQ]STOFCY,[F:SOQ]ORDDAT,"",[F:SOQ]DEMNUM,STAT) From SUBANM
    If GOK<0 Return Endif
    If STAT <> 0
        GERR=2 : GMESSAGE=GWIP-mess(60,199,1) : # ERREUR NON BLOQUANTE
    Endif
Endif

Gosub INITXC
Gosub CHARGESOQ

Return

#########################################################################
$VERIF_CRE
#######################
#Modif CRM 25/09/2003
Raz [F:SOQ]PITFLG
Return

#########################################################################
$VERIF_MOD
#######################
#Modif CRM 25/09/2003
Raz [F:SOQ]PITFLG
Return

#########################################################################
$CREATION

# Issue X3-39248
Read [SOH]SOH0 = [F:SOC]SOHNUM
If fstat Raz [F:SOH] : Call RSTA("SOH",[F:SOC]SOHNUM) From GLOCK : Endif
# End issue X3-39248

# Enregistrement des lignes
Gosub CREATION From TABLEAUX
If GOK < 1 : Return : Endif
Return

#########################################################################
$APRES_CRE

#--------------------------------------------------------------------#
# RÃĐaffichage des demandes de livraisons apres enregistrement        #
# --> Ceci pour rÃĐafficher les qtÃĐs allouÃĐes                         #
#--------------------------------------------------------------------#
Raz [M]EARQTY
Gosub LIENS From TABLEAUX

# v6 affectations
Gosub MAJ_MTO_SOQ_DL From SALMTOLIB

#--------------------------------------------------------------------#
# Gestion des points                                  CRM 25.09.2003 #
#--------------------------------------------------------------------#
Local Integer IERRINF
#LSE 21/03/2005 rajout 2 paramÃĻtres
Local Integer ICHAPTER
Local Integer IBRETOUR
IERRINF = 0
ICHAPTER= 0
IBRETOUR= 1

Call SOHPOINT([M:SOQ1]SOHNUM, IERRINF, ICHAPTER, IBRETOUR) From TRTPOINT
If IERRINF
    GMESSAGE = mess(IERRINF, ICHAPTER, 2)
    GERR = 1
Endif

Affzo [M:SOQ1]1-99
Return

#########################################################################
$LIENS
# Lecture du contrat correspondant
Read [SOH]SOH0 = [F:SOC]SOHNUM
If fstat Raz [F:SOH] : Call RSTA("SOH",[F:SOC]SOHNUM) From GLOCK : Endif

[M:SOQ1]APPFLG    = [F:SOH]APPFLG
[M:SOQ1]XALLTYP   = [F:SOH]ALLTYP
[M:SOQ1]SOHTYP    = [F:SOH]SOHTYP
[M:SOQ1]SALFCY    = [F:SOH]SALFCY
#[M:SOQ1]CUSORDREF = [F:SOH]CUSORDREF
[M:SOQ1]XORDDAT   = [F:SOH]ORDDAT
[M:SOQ1]BETFCY    = [F:SOH]BETFCY
[M:SOQ1]BETCPY    = [F:SOH]BETCPY
[M:SOQ1]ORIFCY    = [F:SOH]ORIFCY

# FGR 14/04/2015 : X3SUIVI105605 (dÃĐbut)
If dim([M:SOQ1]XECCVALMAJ) >= 0 Then
  [M:SOQ1]XECCVALMAJ = [F:SOC]ECCVALMAJ
  [M:SOQ1]XECCVALMIN = [F:SOC]ECCVALMIN
Endif
# FGR 14/04/2015 : X3SUIVI105605 (fin)

# Bug 62888
## Recalcul de l'ÃĐtat crÃĐdit
#Call SDCDTSTA([F:SOH]SOHNUM,[F:SOH]BPCORD,[F:SOH]CHGTYP,0,[F:SOH]CUR,[F:SOH]ORDDAT,[F:SOH]UNL, 1, [M]CDTSTA,GBIDD1,GBIDD2) From TRTVENCDT
# Bug 62888
# Lecture de la table des types de commande
If [F:TSO]SOHTYP<>[F:SOH]SOHTYP
    Read [F:TSO]TSO0 = [F:SOH]SOHTYP
    If fstat Raz [F:TSO] : Call RSTA("TSO", [F:SOH]SOHTYP) From GLOCK : Endif
Endif

#[M:SOQ1]XTSOSOH = [F:TSO]TSOSOH
Call GET_ATEXTRA("TABSOHTYP","SHOAXX",GLANGUE,[M:SOQ1]XTSOSOH) From TRTX3TEX

GBPCNUM = [F:SOC]BPCORD
# Lecture du client commande
Read [BPC]BPC0 = [F:SOC]BPCORD
If fstat Raz [F:BPC] : Call RSTA("BPC",[F:SOC]BPCORD) From GLOCK : Endif
[M:SOQ1]XBPCNAM = [F:BPC]BPCNAM

# Lecture du client livrÃĐ
If [F:BPD]BPCNUM<>[F:SOC]BPCORD | [F:BPD]BPAADD<>[F:SOC]BPAADD
    Read [BPD]BPD0 = [F:SOC]BPCORD;[F:SOC]BPAADD
    If fstat Raz [F:BPD] : Call RSTA("BPD", [F:SOC]BPCORD) From GLOCK : Endif
Endif
[M:SOQ1]XBPDNAM = [F:BPD]BPDNAM
[M:SOQ1]XDAYLTI = [F:BPD]DAYLTI
[M:SOQ1]XDRN    = [F:BPD]DRN
[M:SOQ1]XDLVPIO = [F:BPD]DLVPIO
[M:SOQ1]XMDL    = [F:BPD]MDL
[M:SOQ1]XBPTNUM = [F:BPD]BPTNUM
#[M:SOQ1]XLOC   = [F:BPD]BPCLOC

# Lecture de l'article
If [F:ITM]ITMREF <> [F:SOC]ITMREF
    Read [F:ITM]ITM0 = [F:SOC]ITMREF
    If fstat  Raz [F:ITM] : Call RSTA ("ITM",[F:SOC]ITMREF) From GLOCK : Endif
Endif
[M:SOQ1]XSTOMGTCOD = [F:ITM]STOMGTCOD

If [F:ITM]STOMGTCOD>1
    If [F:ITF]ITMREF<>[F:SOC]ITMREF | [F:ITF]STOFCY<>[F:SOC]STOFCY
        Read [ITF] ITF0=[F:SOC]ITMREF;[F:SOC]STOFCY
        If fstat Raz [F:ITF] : Endif
    Endif
    [M:SOQ1]XSTOMGTCOD = [F:ITF]STOMGTCOD
Endif
# Lecture de l'article vente
If [F:ITS]ITMREF <> [F:SOC]ITMREF
    Read [F:ITS]ITS0 = [F:SOC]ITMREF
    If fstat  Raz [F:ITS] : Call RSTA ("ITS",[F:SOC]ITMREF) From GLOCK : Endif
Endif
# Lecture de l'article client
If [F:ITU]ITMREF<>[F:SOC]ITMREF | [F:ITU]BPCNUM<>[F:SOC]BPCORD
    Read [F:ITU]ITU0 = [F:SOC]ITMREF;[F:SOC]BPCORD
    If fstat  Raz [F:ITU] : Endif
Endif

# Init de l'emballage et de la capacitÃĐ en fonction de l'unitÃĐ de vente
# Issue X3-66385
#If [M:SOQ1]SAU=[F:ITU]SAU
#   [M:SOQ1]XPCK    = [F:ITU]PCK
#   [M:SOQ1]XPCKCAP = [F:ITU]PCKCAP
#Elsif [M:SOQ1]SAU=[F:ITM]SAU
##  [M:SOQ1]XPCK    = [F:ITS]PCK
## [M:SOQ1]XPCKCAP = [F:ITS]PCKCAP
#   Call ALIPCK ([F:SOC]ITMREF, [F:SOC]STOFCY, [M:SOQ1]XPCK, [M:SOQ1]XPCKCAP) From TRTVENDIV
#Endif
# L'emballage est initialisÃĐ en prioritÃĐ avec l'article client
# Il est initialisÃĐ avec l'article (article site ou catÃĐgorie article) uniquement si l'UV de l'article = l'UV de la ligne
# et si l'UV de l'article client = l'UV de la ligne mais il n'y a pas d'emballage pour l'article client
# ou si l'UV de l'article client est diffÃĐrente de l'UV de la ligne
# Package is initialized in priority with product customer
# It is initialized  with product (product site or product category) onky if UV product= UV line
# and if UV product customer = UV line but there is no package for product customer
# or  if UV product customer <> UV line
If [M:SOQ1]SAU=[F:ITU]SAU
   [M:SOQ1]XPCK    = [F:ITU]PCK
   [M:SOQ1]XPCKCAP = [F:ITU]PCKCAP
Endif
If [M]XPCK = ""
    If [M:SOQ1]SAU=[F:ITM]SAU
      Call ALIPCK ([F:SOC]ITMREF, [F:SOC]STOFCY, [M:SOQ1]XPCK, [M:SOQ1]XPCKCAP) From TRTVENDIV
    Endif
Endif
# End issue X3-66385

If [F:SOH]SALFCY <> GFCY
   GFCY = [F:SOH]SALFCY
   #Call GETDEV(GFCY) From DEVSUB
   # Chargement globales rÃĐfÃĐrenciels, comptes et sections de la sociÃĐtÃĐ
   Gosub CHARG_PARAM : Raz GERR : Raz GMESSAGE
#  RÃĐcupÃĐration des paramÃĻtres vente du site / de la sociÃĐtÃĐ
   Call GLOBVAR(GFCY,"VEN") From TRTX3
Endif

# Bug 62888
# Recalcul de l'ÃĐtat crÃĐdit
Call SDCDTSTA([F:SOH]SOHNUM,[F:SOH]BPCORD,[F:SOH]CHGTYP,0,[F:SOH]CUR,[F:SOH]ORDDAT,[F:SOH]UNL, 1, [M]CDTSTA,GBIDD1,GBIDD2) From TRTVENCDT
# Bug 62888

# Lecture du site d'expÃĐdition
If [F:FCY]FCY<>[F:SOC]STOFCY
    Read [FCY]FCY0=[F:SOC]STOFCY
    If fstat  Call RSTA ("FCY",[F:SOC]STOFCY) From GLOCK : Endif
Endif

# Filtre sur toutes les lignes non soldÃĐes de SORDERQ pour initialiser
# une variable permettant de dÃĐterminer la premiÃĐre ligne du tableau
GSOQSEQ=0
Filter [SOQ] Where SOHNUM=[F:SOC]SOHNUM & SOPLIN=[F:SOC]SOPLIN & SOQSTA<>3 Order By Key SOQ0
Read [SOQ]SOQ0 First
If fstat
# Si aucune ligne non soldÃĐe, la 1ÃĻre ligne du tableau est la derniÃĻre ligne soldÃĐe (Bug 40128)
    Filter [SOQ] Where SOHNUM=[F:SOC]SOHNUM & SOPLIN=[F:SOC]SOPLIN & SOQSTA=3 Order By Key SOQ0
    Read [SOQ]SOQ0 Last
    If !fstat GSOQSEQ = [F:SOQ]SOQSEQ Endif
    Filter [SOQ]
Else
# La 1ÃĻre ligne du tableau est la 1ÃĻre ligne non soldÃĐe
    GSOQSEQ = [F:SOQ]SOQSEQ
Endif

[M:SOQ1]XUSEPLC = [F:SOC]USEPLC
[M:SOQ1]XSTOFCY = [F:SOC]STOFCY
[M:SOQ1]ITSTEX  = [F:SOC]SOCTEX

# Recherche autorisation bouton allocation manuelle
#           autorisation ÃĐgalement utilisÃĐe pour la saisie qtÃĐ Ã  allouer et type allocation
GALLCOD=2 : GBIDC2="A": GFCY=[M:SOQ1]SALFCY : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GALLCOD=1 Endif
# Recherche autorisation modification (pb bouton allocation manuelle bug 39344)
GMODCOD=2 : GBIDC2="M": GFCY=[M:SOQ1]SALFCY : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GMODCOD=1 Endif

# Chargement des lignes dans le tableau
Gosub LIENS From TABLEAUX

# Bug 35543 : Pb GQSEQ non chargÃĐ sur bt ÃĐclatement --> Init GQSEQ dÃĐplacÃĐe de AVANT_MOD vers LIENS
# Si utilis. bt ÃĐclatement et aucune modif.rÃĐalisÃĐe : AVANT_MOD n'a pas encore ÃĐtÃĐ exÃĐcutÃĐe
Default File [SOQ]
# lecture de la derniÃĻre ligne soldÃĐe sur SORDERQ pour initialiser
# la variable DEB (GQSEQ) si insertion sur la premiÃĐre ligne du tableau
Filter [SOQ] Where SOHNUM = [M]SOHNUM(0) & SOPLIN = [M]SOPLIN(0)
Read [SOQ]SOQ0 = [M]SOHNUM(0);[M]SOPLIN(0);[M]SOQSEQ(0)
If fstat
   Read [SOQ]SOQ0 Last
   If fstat GQSEQ = 0
   Else     GQSEQ = [F:SOQ]SOQSEQ
   Endif
Else
   Read [SOQ]SOQ0 Prev
   If fstat GQSEQ = 0
   Else     GQSEQ = [F:SOQ]SOQSEQ
   Endif
Endif

Filter [SOQ]       # FGR 30/04/2015 : X3SUIVI107726

# 107890 : Scheduled invoices : (LD:24/03/16)
[M:SOQ1]DLVFLG     = [F:ITM]DLVFLG
# 107890 : Scheduled invoices : (LD:24/03/16)

# --> Gestion des signatures : Si le contrat n'est pas signÃĐ, pas de saisie de lignes DL possible
If [M:SOQ1]APPFLG<3
    Diszo [M:SOQ1]1-99 : Actzo [M:SOQ1]SOHNUM :  Actzo [M:SOQ1]SOPLIN
Else
    Actzo [M:SOQ1]1-99
Endif

Diszo [M]CUSORDREF, BPCORD, BPAADD, ITMREF
# Si un contrat inter-site l'A/R n'est pas gÃĐrÃĐe
If !GIMPORT
   If [M:SOQ1]BETFCY = 2
      Grizo [M:SOQ1]EARQTY, SAU, EARDAT, EARHOU
      Grizo [M:SOQ1]EARQTYCUS, EARDATCUS, EARHOUCUS
   Else
      Actzo [M:SOQ1]EARQTY, SAU, EARDAT, EARHOU
      Actzo [M:SOQ1]EARQTYCUS, EARDATCUS, EARHOUCUS
   Endif
Endif
  Call SHOW_HIDE_VERSION_FIELDS([M:SOQ1]ITMREF)          # FGR 14/04/2015 : X3SUIVI105605
Return

################################################################################
Subprog SHOW_HIDE_VERSION_FIELDS(SITMREF)
Value Char SITMREF

  # FGR 14/04/2015 : X3SUIVI105605
  If dim([M:SOQ1]ECCVALMAJ) >= 0 and !GIMPORT Then
    Local File ITMMASTER [ITM]
    Read [ITM]ITM0=SITMREF
    #
    Case [F:ITM]ECCSTO
      When 1
        # Non
        Chgfmt [M:SOQ1]XECCVALMAJ  With "-K:" + num$(type([M:SOQ1]XECCVALMAJ)-10) + "X"
        Chgfmt [M:SOQ1]XECCVALMIN  With "-K:" + num$(type([M:SOQ1]XECCVALMIN)-10) + "X"
        Chgfmt [M:SOQ1]ECCVALMAJ  With "-K:" + num$(type([M:SOQ1]ECCVALMAJ)-10) + "X"
        Chgfmt [M:SOQ1]ECCVALMIN  With "-K:" + num$(type([M:SOQ1]ECCVALMIN)-10) + "X"
      When 2
        # Majeure
        Chgfmt [M:SOQ1]XECCVALMAJ  With "K:" + num$(type([M:SOQ1]XECCVALMAJ)-10) + "X"
        Chgfmt [M:SOQ1]XECCVALMIN  With "-K:" + num$(type([M:SOQ1]XECCVALMIN)-10) + "X"
        Chgfmt [M:SOQ1]ECCVALMAJ  With "K:" + num$(type([M:SOQ1]ECCVALMAJ)-10) + "X"
        Chgfmt [M:SOQ1]ECCVALMIN  With "-K:" + num$(type([M:SOQ1]ECCVALMIN)-10) + "X"
      When 3
        # Majeure et mineure
        Chgfmt [M:SOQ1]XECCVALMAJ  With "K:" + num$(type([M:SOQ1]XECCVALMAJ)-10) + "X"
        Chgfmt [M:SOQ1]XECCVALMIN  With "K:" + num$(type([M:SOQ1]XECCVALMIN)-10) + "X"
        Chgfmt [M:SOQ1]ECCVALMAJ  With "K:" + num$(type([M:SOQ1]ECCVALMAJ)-10) + "X"
        Chgfmt [M:SOQ1]ECCVALMIN  With "K:" + num$(type([M:SOQ1]ECCVALMIN)-10) + "X"
      When Default
        # Si pas initialisÃĐ alors c'est comme "Non"
        Chgfmt [M:SOQ1]XECCVALMAJ  With "-K:" + num$(type([M:SOQ1]XECCVALMAJ)-10) + "X"
        Chgfmt [M:SOQ1]XECCVALMIN  With "-K:" + num$(type([M:SOQ1]XECCVALMIN)-10) + "X"
        Chgfmt [M:SOQ1]ECCVALMAJ  With "-K:" + num$(type([M:SOQ1]ECCVALMAJ)-10) + "X"
        Chgfmt [M:SOQ1]ECCVALMIN  With "-K:" + num$(type([M:SOQ1]ECCVALMIN)-10) + "X"
    Endcase
  Endif
End

#########################################################################
$LIENS_LIG
Local Integer WWJOUR, WWMOIS, WWAN

[M]DPJT(nolign-1)       = [F:SOQ]PJT  # FGR 15/12/2011 : X3SUIVI71065

[M]DUSEPLC(nolign-1)    = [F:SOQ]USEPLC
[M]DSTOFCY(nolign-1)    = [F:SOQ]STOFCY
[M]DSTOMGTCOD(nolign-1) = [F:SOQ]STOMGTCOD
# QtÃĐ Ã  allouer = QtÃĐ dÃĐjÃ  allouÃĐe
[M]WALLQTY(nolign-1)    = [F:SOQ]ALLQTY + [F:SOQ]SHTQTY
[M]WALLQTYSTU(nolign-1) = [F:SOQ]ALLQTYSTU + [F:SOQ]SHTQTYSTU
# Calcul du total prÃĐparÃĐ/livrÃĐ
[M]WTLVQTYSTU(nolign-1) = [F:SOQ]OPRQTYSTU+[F:SOQ]PREQTYSTU+[F:SOQ]DLVQTYSTU + [F:SOQ]ODLQTYSTU
[M]WTLVQTY(nolign-1)    = [F:SOQ]OPRQTY   +[F:SOQ]PREQTY   +[F:SOQ]DLVQTY    + [F:SOQ]ODLQTY

# Bug 62888
# Calcul du total allouÃĐ
[M]TALLQTYSTU(nolign-1) = [F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU + [F:SOQ]OPRQTYSTU + [F:SOQ]PREQTYSTU
# Bug 62888

# Chargement des zones servant de tests en VALLIG
[M]YQTY(nolign-1)       = [M]QTY(nolign-1)
[M]YALLQTY(nolign-1)    = [M]ALLQTY(nolign-1)
[M]YSHTQTY(nolign-1)    = [M]SHTQTY(nolign-1)
[M]YDEMSTA(nolign-1)    = [M]DEMSTA(nolign-1)
[M]YSOQSTA(nolign-1)    = [M]SOQSTA(nolign-1)
[M]YSTOFCY(nolign-1)    = [M]DSTOFCY(nolign-1)
[M]YSHIDAT(nolign-1)    = [M]SHIDAT(nolign-1)

Raz [M]WIPFLG(nolign-1)  : # Issue 114112

# Maj de l'avance/retard selon la date du jour
# Seulement s'il ne s'agit pas d'un contrat inter-site
If [M]BETFCY = 1 & [F:SOQ]DEMDLVDAT < date$ & [F:SOQ]SOQSTA = 1 & [F:SOQ]DEMSTA = 1
   [M]SOQSTA(nolign-1) = 2
   #  Bug 65979 : Plus de positionnement de UPDFLG Ã  1 pour avoir tjs le bouton allocation manuelle
   ##  Bug 39344 : Si on a pas les droits de modif, on laisse UPDFLG Ã  0 pour avoir le bt allocation manuelle (IB_NBLIG)
   #If GMODCOD=2 [M]UPDFLG(nolign-1) = 1 Endif
   [M]EARQTY += [F:SOQ]QTY
   [M]EARDAT = date$-1
Endif
# Alimentation de la zone ÃĐcran date de livraison demandÃĐe
If [F:SOQ]CAD = 3
   If left$(GFMMOI,2) = "MM"
      If [F:SOQ]MON < 10
         [M]XDLVDAT(nolign-1) = "0"+num$([F:SOQ]MON)+"/"+num$([F:SOQ]YEA)
      Else
         [M]XDLVDAT(nolign-1) = num$([F:SOQ]MON)+"/"+num$([F:SOQ]YEA)
      Endif
   Else
      If [F:SOQ]MON < 10
         [M]XDLVDAT(nolign-1) = num$([F:SOQ]YEA)+"/"+"0"+num$([F:SOQ]MON)
      Else
         [M]XDLVDAT(nolign-1) = num$([F:SOQ]YEA)+"/"+num$([F:SOQ]MON)
      Endif
   Endif
Elsif [F:SOQ]CAD = 2
   If left$(GFMMOI,2) = "MM"
      If [F:SOQ]WEE < 10
         [M]XDLVDAT(nolign-1) = "00"+num$([F:SOQ]WEE)+"-"+num$([F:SOQ]YEA)
      Else
         [M]XDLVDAT(nolign-1) = "0"+num$([F:SOQ]WEE)+"-"+num$([F:SOQ]YEA)
      Endif
   Else
      If [F:SOQ]WEE < 10
         [M]XDLVDAT(nolign-1) = num$([F:SOQ]YEA)+"-"+"00"+num$([F:SOQ]WEE)
      Else
         [M]XDLVDAT(nolign-1) = num$([F:SOQ]YEA)+"-"+"0"+num$([F:SOQ]WEE)
      Endif
   Endif
Elsif [F:SOQ]CAD = 1
#   If len(num$([F:SOQ]DLVDAY)) = 1
#      WWJOUR = "0"+num$([F:SOQ]DLVDAY)
#   Else
#      WWJOUR = num$([F:SOQ]DLVDAY)
#   Endif
#   If len(num$([F:SOQ]MON)) = 1
#      WWMOIS = "0"+num$([F:SOQ]MON)
#   Else
#      WWMOIS = num$([F:SOQ]MON)
#   Endif
#   WWAN = num$([F:SOQ]YEA)

    WWJOUR = [F:SOQ]DLVDAY
    WWMOIS = [F:SOQ]MON
    WWAN   = [F:SOQ]YEA

   [M]XDLVDAT(nolign-1) = format$("D:"+GFMDAT4,gdat$(WWJOUR,WWMOIS,WWAN))

#   If left$(GFMDAT,2) = "DD"
#      [M]XDLVDAT(nolign-1) = format$("D:"+GFMDAT4,gdat$(WWJOUR,WWMOIS,WWAN))
#   Elsif left$(GFMDAT,2) = "YY"
#      [M]XDLVDAT(nolign-1) = format$("D:"+GFMDAT4,gdat$(WWAN,WWMOIS,WWJOUR))
#   Else
##      [M]XDLVDAT(nolign-1) = format$("D:"+GFMDAT4,WWMOIS+WWJOUR+WWAN)
#      [M]XDLVDAT(nolign-1) = format$("D:"+GFMDAT4,gdat$(WWMOIS,WWJOUR,WWAN))
#   Endif
Endif

# Alimentation des zones ÃĐcrans cumuls Ã  livrer et Ã  atteindre
If nolign = 1
   If [M]SOQSTA(nolign-1) = 2
      [M]XCUMLIV(nolign-1) = [F:SOQ]QTY
   Elsif [M]SOQSTA(nolign-1) = 1
      [M]XCUMLIV(nolign-1) = [F:SOQ]QTY
      [M]XCUMATT(nolign-1) = [F:SOQ]QTY
   Endif
Else
   If [M]SOQSTA(nolign-1) = 2
      [M]XCUMLIV(nolign-1) = [M]XCUMLIV(nolign-2) + [F:SOQ]QTY
   Elsif [M]SOQSTA(nolign-1) = 1
      [M]XCUMLIV(nolign-1) = [M]XCUMLIV(nolign-2) + [F:SOQ]QTY
      [M]XCUMATT(nolign-1) = [M]XCUMATT(nolign-2) + [F:SOQ]QTY
   Elsif [M]SOQSTA(nolign-1) = 3
      [M]XCUMLIV(nolign-1) = [M]XCUMLIV(nolign-2)
      [M]XCUMATT(nolign-1) = [M]XCUMATT(nolign-2)
   Endif
Endif

Return

#########################################################################
$AVANT_MOD

# Bug 35543 : Pb GQSEQ non chargÃĐ sur bt ÃĐclatement --> Init GQSEQ dÃĐplacÃĐe de AVANT_MOD vers LIENS
# Si utilis. bt ÃĐclatement et aucune modif.rÃĐalisÃĐe : AVANT_MOD n'a pas encore ÃĐtÃĐ exÃĐcutÃĐe
#Default File [SOQ]
## lecture de la derniÃĻre ligne soldÃĐe sur SORDERQ pour initialiser
## la variable DEB (GQSEQ) si insertion sur la premiÃĐre ligne du tableau
#Filter [SOQ] Where SOHNUM = [M]SOHNUM(0) & SOPLIN = [M]SOPLIN(0)
#Read [SOQ]SOQ0 = [M]SOHNUM(0);[M]SOPLIN(0);[M]SOQSEQ(0)
#If fstat
#   Read [SOQ]SOQ0 Last
#   If fstat GQSEQ = 0
#   Else     GQSEQ = [F:SOQ]SOQSEQ
#   Endif
#Else
#   Read [SOQ]SOQ0 Prev
#   If fstat GQSEQ = 0
#   Else     GQSEQ = [F:SOQ]SOQSEQ
#   Endif
#Endif

# CritÃĻre de lecture (uniquement les quantitÃĐs non soldÃĐes)
#CRIT = 'SOHNUM="'+[M:SOQ1]SOHNUM+'" & SOPLIN='+num$([M:SOQ1]SOPLIN)+' & SOQSTA<>'+num$(3)
CRIT = 'SOHNUM="'+[M:SOQ1]SOHNUM+'" & SOPLIN='+num$([M:SOQ1]SOPLIN)+' & SOQSEQ>=GSOQSEQ'
# Repositionnement du filtre
Filter [SOQ] Where evalue(CRIT)

# Pour se positionner sur le tableau en modification
#zonsui = "NBLIG"
Return
#########################################################################
$AVANT_MODFIC
#------------------------------------------#
# Traitement avant modification            #
#------------------------------------------#

#  Bug 65979 : Positionnement de UPDFLG Ã  1 au dernier moment pour avoir tjs le bouton allocation manuelle
# S'il y a des lignes en retard, il faut forcer leur modification
Local Integer NLIG
If find([M]SOQSTA(0..[M]NBLIG-1), 2)
    For NLIG = 0 To [M]NBLIG-1
        If [M]YSOQSTA(NLIG)=1 & [M]SOQSTA(NLIG)=2 [M]UPDFLG(NLIG) = 1 Endif
    Next NLIG
Endif

Return
#########################################################################
$INIMOD_LIG

[F:SOQ]USEPLC    = [M]DUSEPLC(nolign-1)
[F:SOQ]STOFCY    = [M]DSTOFCY(nolign-1)
[F:SOQ]STOMGTCOD = [M]DSTOMGTCOD(nolign-1)
[F:SOQ]PJT       = [M]DPJT(nolign-1)       # FGR 15/12/2011 : X3SUIVI71065

Gosub INITXC
Gosub CHARGESOQ

Return

#########################################################################
$INITXC

If [M:SOQ1]SOQTEX(nolign-1)<>""
   If left$([M:SOQ1]SOQTEX(nolign-1),3)="SOQ"
      Call CRE_CLOB([M:SOQ1]SOQTEX(nolign-1),GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Elsif !find(left$([M:SOQ1]SOQTEX(nolign-1),3),"ITU","ITS")
      Call DUP_CLOB("SOQ",[M:SOQ1]SOQTEX(nolign-1),GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
   [F:SOQ]SOQTEX = [M:SOQ1]SOQTEX(nolign-1)
Endif

Return
#########################################################################
$CHARGESOQ

# Initialisation du code prÃĐpa
Local Char    WTSCCOD(GLONADI) (0..5)
Local Char    WTSICOD(GLONADI) (0..5)
Local Integer I
If dim([M:SOQ1]TSCCOD) <> -1
    For I = 1 To dim([M:SOQ1]TSCCOD)
        WTSCCOD(I-1) = [M:SOQ1]TSCCOD(I-1)
    Next I
Endif
If dim([M:SOQ1]TSICOD) <> -1
    For I = 1 To dim([M:SOQ1]TSICOD)
        WTSICOD(I-1) = [M:SOQ1]TSICOD(I-1)
    Next I
Endif
If [F:BPC]BPCNUM<>[M:SOQ1]BPCORD
   Read [BPC]BPC0=[M:SOQ1]BPCORD
   If fstat Raz [F:BPC] Endif
Endif

Call REC_PRECOD([M:SOQ1]DSTOFCY(nolign-1),[M:SOQ1]ITMREF,[F:ITM]TCLCOD,WTSICOD(0),
&               WTSICOD(1),WTSICOD(2),WTSICOD(3),WTSICOD(4),[M:SOQ1]BPCORD,
&               [F:BPC]BCGCOD,WTSCCOD(0),WTSCCOD(1),WTSCCOD(2),WTSCCOD(3),
&               WTSCCOD(4),[F:SOQ]PRECOD) From STKLIB

Return
#########################################################################
$MODIF

# Issue X3-39248
Read [SOH]SOH0 = [F:SOC]SOHNUM
If fstat Raz [F:SOH] : Call RSTA("SOH",[F:SOC]SOHNUM) From GLOCK : Endif
# End issue X3-39248

# Modification des lignes (optimisÃĐe)
Gosub MODIF From TABLEAUX    : # Enregistrement des lignes
If GOK<1 : Return : Endif    : # Propagation erreur
# Ici il peut y avoir d'autres traitements
# (en-cours client, maj diverses, ...)
Return

#########################################################################
$APRES_MOD

# v6 affectations
Gosub MAJ_MTO_SOQ_DL From SALMTOLIB

#--------------------------------------------------------------------#
# RÃĐaffichage des demandes de livraisons apres enregistrement        #
# --> Ceci pour rÃĐafficher les qtÃĐs allouÃĐes                         #
#--------------------------------------------------------------------#
Raz [M]EARQTY
If !GIMPORT
    Gosub RELIT From GOBJSUB
Else
    Gosub LIENS From TABLEAUX
Endif

#--------------------------------------------------------------------#
# Gestion des points                                  CRM 25.09.2003 #
#--------------------------------------------------------------------#
Local Integer IERRINF
#LSE 21/03/2005 rajout 2 paramÃĻtres
Local Integer ICHAPTER
Local Integer IBRETOUR
IERRINF = 0
ICHAPTER= 0
IBRETOUR= 1

Call SOHPOINT([M:SOQ1]SOHNUM, IERRINF, ICHAPTER, IBRETOUR) From TRTPOINT
If IERRINF
    GMESSAGE = mess(IERRINF, ICHAPTER, 2)
    GERR = 1
Endif

Return

#########################################################################
$ANNULE

# Traitements particuliers d'annulation
# L'action VALLIG sera appelÃĐe pour chaque ligne avec SIGN=-1
# Ici il peut y avoir d'autres traitements
# (en-cours client, maj diverses, ...)
Gosub ANNULE From TABLEAUX : # Effacement des lignes
If GOK<1 : Return : Endif
Return

#########################################################################
$VALLIG
Local Char    WTRTORD, WSOHNUM
Local Decimal WQTY, WSHT, WCPLQTY
Local Integer WRET, WTYP, NOL
Local Integer WSOPLIN, WSOQSEQ

# Traitements complÃĐmentaires effectuÃĐs Ã  la ligne (mise Ã  jour stock, etc...)
# SIGN vaut +1 ou -1 selon qu'il s'agit d'une crÃĐation ou d'une annulation
# TRTLIG vaut "C","M" ou "A" selon que l'on crÃĐÃĐ, modifie ou annule une ligne

NOL = nolign-1
If TRTLIG = "A"
    If left$([F:SOQ]SOQTEX,3)="SOQ"
        Call SUP_CLOB([F:SOQ]SOQTEX,WRET) From TRTX3TEX
        If WRET=0 GOK=0 : Return Endif
    Endif
Elsif TRTLIG = "M" & SIGN=-1
    # Cas particulier oÃđ on modifie le texte en le supprimant
    If [M:SOQ1]SOQTEX(NOL)="" & left$([F:SOQ]SOQTEX,3)="SOQ"
        Call SUP_CLOB([F:SOQ]SOQTEX,WRET) From TRTX3TEX
    Endif
Endif

Raz WRET
If TRTLIG = "A" | SIGN = +1
    Gosub GENALLORD : If WRET = 1 GOK = 0 Endif
    If GOK < 1 Return : Endif
    # --> Apres passage dans le moteur d'allocation, il faut rÃĐÃĐcrire SOQ
    If SIGN = +1 & find(TRTLIG,"C","M")
        Update [SOQ] Where SOHNUM=[M]SOHNUM & SOPLIN=[M]SOPLIN & SOQSEQ=[M]SOQSEQ(NOL)
&            With ALLQTY=[M]ALLQTY(NOL),ALLQTYSTU=[M]ALLQTYSTU(NOL),
&                 SHTQTY=[M]SHTQTY(NOL),SHTQTYSTU=[M]SHTQTYSTU(NOL)
    Endif
Endif
Gosub MAJITV : If GOK<1 Return : Endif
#---------------------------------------------------------------------#
# Si solde d'une ligne : Suppression des allocations en rupture       #
#---------------------------------------------------------------------#
#Local  Decimal  LQTY, LSHT
#Local  Integer  LRET
#If TRTLIG = "M" & SIGN = -1
#  Maj uniquement si article gÃĐrÃĐ en stock et CF et ligne non soldÃĐe
#   If [M]STOMGTCOD <> 1 & [F:SOQ]DEMSTA = 1 & [F:SOQ]SOQSTA <> 3
#     Maj si solde ligne et quantitÃĐ en rupture <> 0
#      If [M]SOQSTA(NOL) = 3 & [M]SHTQTY(NOL) <> 0
#         LQTY=0:CALL MAJSTOALL("","[M:SOQ1]","A", 2,LQTY,[F:SOQ]SHTQTYSTU, WRET) From TRTVENALL
#         If WRET = 1 GOK = -1 Elsif WRET GOK = 0 :ENDIF
#         [M]SHTQTY(NOL)   = 0
#         [M]SHTQTYSTU(NOL)= 0
#         Update [SOQ] Where SOHNUM=[M]SOHNUM & SOPLIN=[M]SOPLIN & SOQSEQ=[M]SOQSEQ(NOL)
#&            With SHTQTY=0, SHTQTYSTU=0
#      Endif
#   Endif
#ENDIF
Gosub MAJORDERS : If GOK<1 Return : Endif
Return
####################################################################
$GENALLORD
Local Decimal WQTY, WALL, WSHT, WALLSTU, WSHTSTU, WQTYSTU
Local Decimal WSTUDIS
Local Char    WTRTLIG    :    WTRTLIG=TRTLIG
Local Integer WUSERERBPC, WGENSHT, WALLPAR
Local Char    WSHIDAT    : # 85588

If TRTLIG = "A"
#    Suppression d'une ligne
    If [F:SOQ]ALLQTYSTU <> 0 | [F:SOQ]SHTQTYSTU <> 0
        Call GENALLORD("","[F:SOC]","A", 1, 1, 0, [F:SOQ]ALLQTYSTU, [F:SOQ]SHTQTYSTU, WRET) From TRTVENALL
        If WRET <> 0 Return : Endif
    Endif
Else
#    CrÃĐation ou modification d'une ligne
    If [M]WALLQTYSTU (NOL) - ([M]ALLQTYSTU(NOL)+[M]SHTQTYSTU(NOL)) = 0
# 85588
# ----- Il n'y a pas de nouvelle allocation,  ni de modif de la date d'expÃĐdition
        If [M]SHTQTYSTU(NOL)=0 & ([M]SHIDAT(NOL)=[M]YSHIDAT(NOL)) Return Endif
## ----- Il n'y a pas de nouvelle allocation
#        If [M]SHTQTYSTU(NOL) = 0 Return Endif
## --------- Il y avait de la rupture : On essaie de rÃĐallouer la qtÃĐ en rupture
## ------ On essaie de rÃĐallouer la qtÃĐ en rupture
#        WTRTLIG = "M"
#        WALLSTU = 0
#        WSHTSTU = [M]SHTQTYSTU (NOL)
        If [M]SHTQTYSTU(NOL)<>0
  # --------- Il y avait de la rupture : On essaie de rÃĐallouer la qtÃĐ en rupture
  # ------ On essaie de rÃĐallouer la qtÃĐ en rupture
            WTRTLIG = "M"
            WALLSTU = 0
            WSHTSTU = [M]SHTQTYSTU (NOL)
        Elsif [M]SHIDAT(NOL)<>[M]YSHIDAT(NOL)
# --------- La date d'expÃĐdition a ÃĐtÃĐ modifiÃĐe : RÃĐpercution sur les allocations existante
            WSHIDAT=[F:SOQ]SHIDAT
            Call MODZONALL(2,[F:SOQ]SOHNUM,[F:SOQ]SOPLIN,[F:SOQ]SOQSEQ,"BESDAT",WSHIDAT,WRET) From STKALL
        Endif
# 85588
    Elsif [M]WALLQTYSTU (NOL) - ([M]ALLQTYSTU(NOL)+[M]SHTQTYSTU(NOL)) < 0
# ----- C'est une diminution/annulation de l'allocation
        WTRTLIG = "D"
        WQTYSTU = ([M]ALLQTYSTU(NOL)+[M]SHTQTYSTU(NOL)) - [M]WALLQTYSTU(NOL)
# ----------- On traite en prioritÃĐ la quantitÃĐ rupture
        If [M]SHTQTYSTU(NOL) <> 0
# ----------- On dÃĐcrÃĐmente la quantitÃĐ rupture
            If WQTYSTU < [M]SHTQTYSTU (NOL)
                WSHTSTU = WQTYSTU  : WALLSTU = 0
            Else
# ----------- On annule la quantitÃĐ rupture et on dÃĐcrÃĐmente la quantitÃĐ allouÃĐe
                WSHTSTU = [M]SHTQTYSTU (NOL)
                WQTYSTU -= WSHTSTU : WALLSTU = WQTYSTU
            Endif
        Else
# ----------- On traite ensuite la quantitÃĐ allouÃĐe
            If WQTYSTU < ([M]ALLQTYSTU(NOL)+[M]SHTQTYSTU(NOL))
# ---------------- On dÃĐcrÃĐmente la quantitÃĐ rupture
                WSHTSTU = 0 : WALLSTU = WQTYSTU
            Else
# ---------------- On annule la quantitÃĐ allouÃĐe
                WTRTLIG = "A"
                WALLSTU = [M]ALLQTYSTU (NOL)
            Endif
        Endif
    Else
# ----- C'est une augmentation de l'allocation
        If [M]ALLQTYSTU(NOL) = 0 & [M]SHTQTYSTU(NOL) = 0
             WTRTLIG = "C"
        Else
             WTRTLIG = "M"
        Endif
        WSHTSTU = [M]SHTQTYSTU(NOL)
        WALLSTU = [M]WALLQTYSTU(NOL) - ([M]ALLQTYSTU(NOL)+[M]SHTQTYSTU(NOL))
    Endif

    If WALLSTU + WSHTSTU <> 0
#   GÃĐnÃĐration de l'allocation
#   (Les quantitÃĐ allouÃĐes et ruptures sont toujours positives)
        If [M]DSTOMGTCOD(NOL) <> 1
#           Consommation rÃĐservations clients
#           Si valeur "Ã  la dde" rÃĐcup. de la rÃĐponse faite lors de la saisie
            WUSERERBPC=GUSERERBPC
            If WUSERERBPC=3 WUSERERBPC=[M]RERBPCFLG(NOL) Endif
#           GÃĐnÃĐration des ruptures
            # --> RÃĐcupÃĐration du paramÃŠtre stock : GÃĐnÃĐration de ruptures
            Local Char     WPARAM(10)
            Call PARAML([M]DSTOFCY(NOL),"GENSHT",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
            GGENSHT=val(WPARAM)
            WGENSHT=GGENSHT
#           Allocations partielles sf si livraison ligne/cde complÃĻte
#           Un kit et ses composants ne peuvent ÃŠtre allouÃĐs partiellement (sinon dÃĐphasage possible)
            WALLPAR=0
            Call GENALLORD("","[F:SOC]",WTRTLIG, WUSERERBPC, WGENSHT, WALLPAR, WALLSTU, WSHTSTU, WRET) From TRTVENALL
            If WRET=2 & GOK=1 Call MESSAGE([M]ITMREF-":"-mess(504,197,1)-"\"-mess(44,192,1)) From GESECRAN Endif
            If WRET <> 0 Return : Endif
        Endif

        WALL=WALLSTU*(1/[M]SAUSTUCOE)
        Call QTEARR(WALL, [M]SAU) From TRTDIV
        WSHT=WSHTSTU*(1/[M]SAUSTUCOE)
        Call QTEARR(WSHT, [M]SAU) From TRTDIV
#       CrÃĐation et modification : QtÃĐ allouÃĐe en +
#                                  Nouvelle QtÃĐ rupture
#       Annulation et diminution : QtÃĐ allouÃĐe en -
#                                  QtÃĐ rupture en -
        If find(WTRTLIG, "C","M")
            [F:SOQ]ALLQTYSTU += WALLSTU
            [F:SOQ]ALLQTY    += WALL
            [F:SOQ]SHTQTYSTU = WSHTSTU
            [F:SOQ]SHTQTY    = WSHT
        Else
            [F:SOQ]ALLQTYSTU -= WALLSTU
            [F:SOQ]ALLQTY    -= WALL
            [F:SOQ]SHTQTYSTU -= WSHTSTU
            [F:SOQ]SHTQTY    -= WSHT
        Endif
        [M]ALLQTY(NOL)     = [F:SOQ]ALLQTY
        [M]ALLQTYSTU(NOL)  = [F:SOQ]ALLQTYSTU
        [M]SHTQTY(NOL)     = [F:SOQ]SHTQTY
        [M]SHTQTYSTU(NOL)  = [F:SOQ]SHTQTYSTU
     Endif
Endif
Return
####################################################################
$MAJITV
Local Decimal WQTY
Local Char    WSENS
Local Char    WTYP    :    WTYP="S"
Local Integer WRET
#---------------------------------------------------------------------------------#
# Maj des cumuls articles : En-cde client dans ITMMVT                             #
#---------------------------------------------------------------------------------#
Case TRTLIG
    When "C" :    # CrÃĐation
#       Pas de maj si article non gÃĐrÃĐ en stock, ligne soldÃĐe ou ligne non ferme
        If [F:SOQ]STOMGTCOD=1 | [F:SOQ]SOQSTA=3 | [F:SOQ]DEMSTA<>1 Return : Endif
        WSENS="+"
    When "M" :    # Modification
        Case SIGN
            When -1 : # Avant maj
                Local Integer WFLGMOD : Raz WFLGMOD
#               DÃĐcrÃĐmentation de l'En-cde
#               -- Si la ligne devient non gÃĐrÃĐe en stock ou
#               -- Si la ligne est gÃĐrÃĐe en stock et elle devient soldÃĐe ou devient non ferme ou
#               -- Si modification du site ou la qtÃĐ
                If [F:SOQ]STOMGTCOD<>1 & [M]DSTOMGTCOD(NOL)=1 |
&                  [F:SOQ]STOMGTCOD<>1 & ([F:SOQ]SOQSTA<>3 & [M]SOQSTA(NOL)=3 |
&                  [F:SOQ]DEMSTA=1     & [M]DEMSTA(NOL)<>1   | [F:SOQ]STOFCY<>[M]DSTOFCY(NOL) |
&                  [F:SOQ]QTYSTU      <> [M]QTYSTU(NOL))
                    WFLGMOD=1
                    WSENS="-"
#               Si la ligne devient gÃĐrÃĐ en stock ou est dÃĐsoldÃĐe ou devient ferme
#               -- Positionnement flag pour faire l'AprÃĻs maj
                Elsif [F:SOQ]STOMGTCOD=1 & [M]DSTOMGTCOD(NOL)<>1 | [F:SOQ]SOQSTA=3 & [M]SOQSTA(NOL)<>3 |
&                     [F:SOQ]DEMSTA<>1   & [M]DEMSTA(NOL)=1
                    WFLGMOD=1 : Return
                Else
                    Return
                Endif
            When +1 : # AprÃĻs maj
#               Pas de maj si article non gÃĐrÃĐ en stock, ligne soldÃĐe ou ligne non ferme
                If [F:SOQ]STOMGTCOD=1 | [F:SOQ]SOQSTA=3 | [F:SOQ]DEMSTA<>1 Return : Endif
#               IncrÃĐmentation de l'En-cde
#               -- Si modification du site ou la qtÃĐ
                If WFLGMOD=0 Return Endif
                WSENS="+"
        Endcase
    When "A" :    # Suppression
#       Pas de maj si article non gÃĐrÃĐ en stock, ligne soldÃĐe ou ligne non ferme
        If [F:SOQ]STOMGTCOD=1 | [F:SOQ]SOQSTA=3 | [F:SOQ]DEMSTA<>1 Return : Endif
        WSENS="-"
Endcase
WQTY=[F:SOQ]QTYSTU
Call  MAJITVVEN ([F:SOQ]ITMREF, [F:SOQ]STOFCY, WQTY, WSENS, WTYP, WRET) From TRTVENMAJ
If WRET <> 0 Return : Endif
Return
####################################################################
$MAJORDERS
#-------------------------------
# Maj de l'en-cours dans ORDERS
#-------------------------------
#If [M]DSTOMGTCOD(NOL) = 1 Return : Endif

WCPLQTY = [F:SOQ]DLVQTYSTU
# Maj uniquement si ligne non soldÃĐe
If [F:SOQ]SOQSTA <> 3
#  Maj si modif ligne et la quantitÃĐ ou le type en-cours ou l'ÃĐtat
#  de la ligne ou le site d'expÃĐdition ont ÃĐvoluÃĐ
   If TRTLIG = "M"
      If [M]QTY(NOL)     <> [M]YQTY(NOL)
&      | [M]ALLQTY(NOL)  <> [M]YALLQTY(NOL)
&      | [M]SHTQTY(NOL)  <> [M]YSHTQTY(NOL)
&      | [M]DEMSTA(NOL)  <> [M]YDEMSTA(NOL)
&      | [M]SOQSTA(NOL)  <> [M]YSOQSTA(NOL)
&      | [M]DSTOFCY(NOL) <> [M]YSTOFCY(NOL)
&      | [M]SHIDAT(NOL)  <> [M]YSHIDAT(NOL)
&      | [M]WIPFLG(NOL)  = "M"                    : # Issue 114112
          Raz WTRTORD
#         Suppression de l'en-cours Si
#         --> Maj type en-cours
#             ou Solde de ligne et pas d'encours de livraison
#             ou Article non gÃĐrÃĐ en stock
          If (SIGN = -1 & ([M]DEMSTA(NOL) <> [M]YDEMSTA(NOL)
&                        | ([M]SOQSTA(NOL) <> [M]YSOQSTA(NOL) & [M]ODLQTY(NOL) = 0)
&                        | [M]DSTOMGTCOD(NOL)=1))
              WTRTORD = "A" : Gosub APPELWIP From TRTVENMAJ
              If GOK < 1 Return Endif
          Endif
#         Modification de l'en-cours si l'article est gÃĐrÃĐ en stock
          If  SIGN = +1 & [M]DSTOMGTCOD(NOL) <> 1
              WTRTORD = "M" : Gosub APPELWIP From TRTVENMAJ
              If GOK < 1 Return Endif
          Endif
      Endif
#  Maj si l'article est gÃĐrÃĐ en stock et si crÃĐation ou suppression ligne
   Elsif [F:SOQ]STOMGTCOD <> 1
      If SIGN = -1
         WTRTORD = "A" : Gosub APPELWIP From TRTVENMAJ
         If GOK < 1 Return Endif
      Elsif SIGN = +1 & [F:SOQ]DEMNUM <> ""
         WTRTORD = "C" : Gosub APPELWIP From TRTVENMAJ
         If GOK < 1 Return Endif
      Endif
   Endif
Endif
Return
