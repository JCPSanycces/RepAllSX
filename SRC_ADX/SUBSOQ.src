## Etiquette ajoutÃĐe par le superviseur (ÃĐcran SOQ1) 09/06/2010 09:59:49 (LD)
######################################################################################
Subprog C_SOHNUM(VALEUR)
Variable Char    VALEUR()

If [F:SOH]SOHNUM<>VALEUR
    Read [SOH]SOH0 = VALEUR
    If fstat Raz [F:SOH] : Endif
Endif
If [F:SOH]APPFLG<3 mkstat=2 : GMESSAGE=mess(343,192,1) Endif

End
######################################## Obligatoire
Subprog C_SOPLIN(VALEUR)
Variable Decimal VALEUR
# Si l'enregistrement n'existe pas, on ne passe pas
Look [F:SOC]SOC0=[M]SOHNUM;VALEUR
If fstat
   GERR=1 : GMESSAGE=mess(178,199,1) : mkstat=2
Endif
End
######################################################################################
## Etiquette ajoutÃĐe par le superviseur (ÃĐcran SOQ1) 14/09/2004 14:58:35 (LD)
######################################################################################
Subprog IB_CUSORDREF
If [M]CUSORDREF="" | [M]BETFCY<>2 | [M]ORIFCY="" Raz GBOUT1 Endif
End
######################################## Obligatoire
Subprog IB_NBLIG
# 1 = Eclatement de la demande
# 2 = Solde de la ligne
# 3 = Saisie supplÃĐmentaire
# 4 = Textes
# 5 = DÃĐtail allocation
# 6 = Allocation manuelle
# 7 = Stock par site
# 8 = Situation ligne
Local Integer NOL : NOL= nolign-1

If nolign > [M:SOQ1]NBLIG
   Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8
   End
Endif
If [M:SOQ1]BETFCY=2 Raz GBOUT1, GBOUT2 : Endif

If [M:SOQ1]CAD(NOL) = 1
   GBOUT8 = mess(164,198,1) : # Situation ligne
   Raz GBOUT1
   #--> Ligne dÃĐjÃ  soldÃĐe
   If [M:SOQ1]SOQSTA(NOL) = 3
      #--> Ligne Ã  dÃĐsolder sf si totalement livrÃĐe
      If [M]DLVQTY(NOL) + [M]ODLQTY(NOL) >= [M]QTY(NOL)
         Raz GBOUT2
      Endif
   #--> Ligne non soldÃĐe
   Else
      #--> Ligne Ã  solder sf si prÃĐparÃĐe
      If ([M]LPRQTY(NOL) + [M]OPRQTY(NOL) + [M]PREQTY(NOL)) <> 0 Raz GBOUT2 Endif
   Endif
Else
   Raz GBOUT2
Endif
#If [M]STOMGTCOD = 1 | [M]ALLTYP(NOL) = 1 | ([M]ALLQTY(NOL)=0 & [M]SHTQTY(NOL)=0)
If [M]DSTOMGTCOD(NOL) = 1 Raz GBOUT7 Endif
If [M]DSTOMGTCOD(NOL) = 1 | ([M]ALLQTY(NOL)=0 & [M]SHTQTY(NOL)=0)
   Raz GBOUT5
Endif
If [M]UPDFLG(NOL)<>0 | [M]DEMSTA(NOL)<>1 | [M]CDTSTA=2 | [M]DSTOMGTCOD(NOL)=1 | [M]SOQSTA(NOL)=3 |
&   GALLCOD=1
   Raz GBOUT6
Endif
End
######################################## Obligatoire
Subprog C_NBLIG
Local Integer OK
Local Integer NOL : NOL=nolign-1
#----------------------------------------------------------------------------------------------------#
# Tests inter-site                                                                                   #
# Aucune modification n'est autorisÃĐe sf l'accÃĻs Ã  la fenÃŠtre de complÃĐment                          #
#                                     sf la modif. de la qtÃĐ Ã  allouer et le type d'allocation       #
# On fait un diszo de ts les chps : si ajout de nvx champs saisissables penser Ã  ajouter le diszo    #
#----------------------------------------------------------------------------------------------------#
If [M:SOQ1]BETFCY=2
#   If find (status,65,68,83,72,73,75,82) mkstat=2 Endif
   If find (status,65,68,83,72,73,82) GMESSAGE=(mess(491,199,1)-mess(9,123,1)) : mkstat=2 Endif
   If status=75 Diszo [M]XDLVDAT(NOL), SHIDAT(NOL), DEMSTA(NOL), QTY(NOL) Endif
Endif
#------------------------------#
# Test de suppression de ligne #
#------------------------------#
# --> pas de suppression si ligne soldÃĐe ou qte allouÃĐe
#If status = 65 & ([M]ALLQTY(nolign-1) + [M]DLVQTY(nolign-1) + [M]ODLQTY(nolign-1)) <> 0
If status=65
#   --> pas de suppression si ligne prÃĐparÃĐe/livrÃĐe
    If sum([M]WTLVQTY(NOL),[M]LPRQTY(NOL)) <> 0
        GMESSAGE = mess(313, 192,1) : mkstat = 2 : End
#   --> demande confirmation si ligne allouÃĐe
    Elsif sum([M]ALLQTYSTU(NOL), [M]SHTQTYSTU(NOL)) <> 0
        OK=2 : Call AVERTIR(mess(119,191,1)-":"-mess(205,100,1), OK) From GESECRAN
        If OK=1 mkstat=2 : End : Endif
    Endif
Endif

#-------------------------------#
# Test de modification de ligne #
#-------------------------------#
# --> pas de modification si ligne soldee
If status=75 & [M]SOQSTA(nolign-1) = 3
   GMESSAGE = mess(18,192,1) : mkstat = 2 : End
Endif
#-------------------------------#
# Test en insertion de ligne    #
#-------------------------------#
If status=73 | status=82
# --> Ctrl du statut de l'article : Ctrl statut non utilisable
    If [F:ITM]ITMREF <> [M]ITMREF
       Read [ITM] ITM0=[M]ITMREF
       If fstat Raz [F:ITM] Endif
    Endif
    If [F:ITM]ITMSTA = 6 : # Ctrl statut non utilisable
       GMESSAGE = [M]ITMREF-mess(3,196,1)+" ("+mess([F:ITM]ITMSTA,246,1)+")" : mkstat=2 : End
    Endif
    If [F:ITM]ITMSTA>1
        Local Integer WOK : WOK=2
        Call AVERTIR ([M]ITMREF-":"-mess(3,196,1)+" ("+mess([F:ITM]ITMSTA,246,1)+")", WOK) From GESECRAN
        If WOK=1 mkstat=2 : End Endif
    Endif
Endif
End
######################################## Obligatoire
Subprog AVANT_NBLIG
Local Integer I, NOL
NOL = nolign-1

# Si insertion ou crÃĐation
If [M]CREFLG(NOL) = 0
   [M]DSTOFCY(NOL)    = [M]XSTOFCY
   [M]DUSEPLC(NOL)    = [M]XUSEPLC
   [M]DSTOMGTCOD(NOL) = [M]XSTOMGTCOD
   [M]DRN(NOL)        = [M]XDRN
   [M]DLVPIO(NOL)     = [M]XDLVPIO
   [M]BPTNUM(NOL)     = [M]XBPTNUM
   [M]MDL(NOL)        = [M]XMDL
   [M]DAYLTI(NOL)     = [M]XDAYLTI
   [M]PCK(NOL)        = [M]XPCK
   [M]PCKCAP(NOL)     = [M]XPCKCAP
   [M]LOC(NOL)        = [M]XLOC
   [M]ALLTYP(NOL)     = [M]XALLTYP
   # FGR 14/04/2015 : X3SUIVI105605 (dÃĐbut)
   If dim([M:SOQ1]XECCVALMAJ) >= 0 Then
     [M:SOQ1]ECCVALMAJ(NOL) = [M:SOQ1]XECCVALMAJ
     [M:SOQ1]ECCVALMIN(NOL) = [M:SOQ1]XECCVALMIN
   Endif
   # FGR 14/04/2015 : X3SUIVI105605 (fin)
   If find(GSALTEXLIN,1,5) & [M]SOQTEX(NOL)=""
       [M]SOQTEX(NOL) = [M:SOQ1]ITSTEX
   Endif
Endif
# Si annulation ligne
If status = 65
#  Si la ligne annulÃĐe est en retard et de type CF, Maj de l'A/R
   If [M]SOQSTA(NOL) = 2 & [M]DEMSTA(NOL) = 1
      [M]EARQTY -= [M]QTY(NOL)
      [M]EARDAT  = date$-1
       Affzo [M]EARQTY,EARDAT
   Endif
#  Calcul des cumuls Ã  livrer et Ã  atteindre des lignes suivant celle supprimÃĐe
   If nolign <> NBLIG
      For I = nolign+1 To NBLIG
         If [M]SOQSTA(NOL) = 2
            [M]XCUMLIV(I-1) -= [M]QTY(NOL)
         Elsif [M]SOQSTA(NOL) = 1
            [M]XCUMLIV(I-1) -= [M]QTY(NOL)
            [M]XCUMATT(I-1) -= [M]QTY(NOL)
         Endif
         Affzo [M]XCUMLIV(I-1),XCUMATT(I-1)
      Next I
   Endif
Endif
[M]ORDQTYCUM -= [M]QTY(NOL)
End
######################################## Obligatoire
Subprog APRES_NBLIG
Local Integer NOL
NOL = nolign-1
[M]ORDQTYCUM += [M]QTY(NOL)
# QuantitÃĐ totale cde > quantitÃĐ initialement prÃĐvue
If status <> 65 & [M]EXTQTY <> 0 & [M]ORDQTYCUM > [M]EXTQTY
   If !GIMPORT GERR=2 : GMESSAGE=mess(11,191,1) Endif
Endif

# En import : Chargement  manuel de l'ecran de complement
If GIMPORT & status <> 65
# Recalcul date expÃĐdition si dÃĐlai modifiÃĐ
    If [M:CPDL]YDAYLTI <> [M:SOQ1]DAYLTI(NOL) & [M:SOQ1]CAD(nolign-1) = 1
#        If [F:FCY]FCY <> [M:CPDL]YSTOFCY
#            Read [F:FCY]FCY0 = [M:CPDL]YSTOFCY
#            If fstat Raz [F:FCY] Endif
#        Endif
#        [M:SOQ1]SHIDAT(NOL) = [M:SOQ1]DEMDLVDAT(NOL) - [M:CPDL]YDAYLTI
#        Call CTL_JOU([M:SOQ1]SHIDAT(NOL),[F:FCY]UVYDAY,[F:FCY]UVYCOD,1) From CONTX3
        Call CALC_SHIDAT([M:SOQ1]DEMDLVDAT(NOL),[M:CPDL]YDAYLTI,[M:CPDL]YSTOFCY,1,1,[0/0/0],[M:SOQ1]SHIDAT(NOL)) From TRTVENDAT
    Endif
    [M:SOQ1]UPDFLG(NOL) = 1
    [M:SOQ1]DSTOFCY(NOL)= [M:CPDL]YSTOFCY
    [M:SOQ1]DUSEPLC(NOL)= [M:CPDL]YUSEPLC
    [M:SOQ1]BPTNUM(NOL) = [M:CPDL]YBPTNUM
    [M:SOQ1]MDL(NOL)    = [M:CPDL]YMDL
    [M:SOQ1]DAYLTI(NOL) = [M:CPDL]YDAYLTI
    [M:SOQ1]DLVPIO(NOL) = [M:CPDL]YDLVPIO
    [M:SOQ1]PCK(NOL)    = [M:CPDL]YPCK
    [M:SOQ1]PCKCAP(NOL) = [M:CPDL]YPCKCAP
Endif
If GERR <> 2 GERR=4 : GMESSAGE = "             "  Endif

# Calcul de l'avance/retard
#If [M]CREFLG(NOL)=0 & [M]DEMSTA(NOL)=1 & [M]SOQSTA(NOL)=2
#   [M]EARQTY += [M]QTY(nolign-1)
#   [M]EARDAT  = date$-1
#   Affzo [M]EARQTY,EARDAT
#Endif

#--- bug 37811
Raz [M]EARQTY
For IJL=0 To dim([M]QTY)-1
If [M]SHIDAT(IJL)=[0/0/0] & IJL>[M]NBLIG : Break : Endif
If [M]BETFCY = 1 & [M]DEMDLVDAT(IJL) < date$ & [M]SOQSTA(IJL) = 2 & [M]DEMSTA(IJL) = 1
   [M]EARQTY += [M]QTY(IJL)
   [M]EARDAT = date$-1
Endif
Next IJL
Affzo [M]EARQTY,EARDAT
#---

End

########################################
#Subprog B6_NBLIG

#Gosub TR_DESALLOC

#End

######################################## Obligatoire
Subprog AS_XDLVDAT(VALEUR)
Variable Char    VALEUR()

If [M:SOQ1]CREFLG(nolign-1)<>0 mkstat=2 Endif
End

######################################## Obligatoire
Subprog C_XDLVDAT(VALEUR)
Variable Char    VALEUR()

Local Char XVALEUR
Local Integer NOJOUR, I

XVALEUR = ctrans(VALEUR,sigma(I=1,47,chr$(I))+sigma(I=58,255,chr$(I)),"")
VALEUR = XVALEUR

# Pas de controle de date si la ligne existait dÃĐjÃ 
# ou si le contenu de la zone est inchangÃĐ
If [M]CREFLG(nolign-1) <> 0 | ([M]XDLVDAT(nolign-1) = VALEUR & !GIMPORT)
   Goto FINCTR
Endif
#  DÃĐtermination de la date livraison saisie (date,no semaine,no mois)
Case len(VALEUR)
   When 4       : Gosub LENDAT4
   When 5       : Gosub LENDAT5
   When 6       : Gosub LENDAT6
   When 7       : Gosub LENDAT7
   When 8       : Gosub LENDAT8
   When Default : mkstat = 2 : GMESSAGE = mess(14,192,1)
Endcase
If mkstat = 2 End : Endif
# Le cadencement doit ÃŠtre >= Ã  celui de la ligne prÃĐcÃĐdente
If nolign > 1 & [M]CAD(nolign-1) < [M]CAD(nolign-2)
   GMESSAGE = mess(21,192,1) : mkstat = 2 : End
Endif
# Le cadencement doit ÃŠtre <= Ã  celui de la ligne suivante
If nolign < NBLIG & [M]CAD(nolign-1) > [M]CAD(nolign)
   GMESSAGE = mess(21,192,1) : mkstat = 2 : End
Endif
# Alimentation de la date de livraison (jour saisi, 1er jour semaine, 1er jour mois)
If [M]CAD(nolign-1) = 3
   # Format MMYY
   If left$(GFMMOI,2) = "MM"
      [M]MON(nolign-1) = val(left$(VALEUR,2))
      [M]YEA(nolign-1) = val(right$(VALEUR,4))
   # Format YYMM
   Else
      [M]MON(nolign-1) = val(right$(VALEUR,6))
      [M]YEA(nolign-1) = val(left$(VALEUR,4))
   Endif
   [M]DEMDLVDAT(nolign-1) = gdat$(01,[M]MON(nolign-1),[M]YEA(nolign-1))
#  DÃĐtermination du 1er jour du mois
   NOJOUR = dayn([M]DEMDLVDAT(nolign-1))
   If NOJOUR > 4
      [M]DEMDLVDAT(nolign-1) += 8-NOJOUR
   Else
     #[M]DEMDLVDAT(nolign-1) -= NOJOUR-1 #Fq74541-Gbn : si le 1er jour du mois est antÃĐrieur au vendredi, pas d'ajustement
   Endif
Elsif [M]CAD(nolign-1) = 2
   # Format MMYY
   If left$(GFMMOI,2) = "MM"
      [M]WEE(nolign-1) = val(left$(VALEUR,3))
      [M]YEA(nolign-1) = val(right$(VALEUR,5))
   # Format YYMM
   Else
      [M]WEE(nolign-1) = val(right$(VALEUR,6))
      [M]YEA(nolign-1) = val(left$(VALEUR,4))
   Endif
   [M]DEMDLVDAT(nolign-1) = aweek([M]WEE(nolign-1),[M]YEA(nolign-1))
Elsif [M]CAD(nolign-1) = 1
#  Format DD-MM-YYYY
   If left$(GFMDAT,2) = "DD"
      [M]DLVDAY(nolign-1) = val(left$(VALEUR,2))
      [M]MON(nolign-1)    = val(mid$(VALEUR,4,2))
      [M]YEA(nolign-1)    = val(right$(VALEUR,7))
#  Format YYYY-MM-DD
   Elsif left$(GFMDAT,2) = "YY"
      [M]YEA(nolign-1)    = val(left$(VALEUR,4))
      [M]MON(nolign-1)    = val(mid$(VALEUR,6,2))
      [M]DLVDAY(nolign-1) = val(right$(VALEUR,9))
#  Format MM-DD-YYYY
   Else
      [M]MON(nolign-1)    = val(left$(VALEUR,2))
      [M]DLVDAY(nolign-1) = val(mid$(VALEUR,4,2))
      [M]YEA(nolign-1)    = val(right$(VALEUR,7))
   Endif
   [M]DEMDLVDAT(nolign-1) = gdat$([M]DLVDAY(nolign-1),[M]MON(nolign-1),[M]YEA(nolign-1))
   # Bug 46183 : VÃĐrification de la date de livraison demandÃĐe
   WDEMDLVDAT = [M]DEMDLVDAT(nolign-1)
   Call CTLUVYBPD(WDEMDLVDAT, [M:SOQ1]BPAADD, [M:SOQ1]BPCORD, 0) From TRTVENCTL
   If mkstat=2 End Endif
   If WDEMDLVDAT<>[M]DEMDLVDAT(nolign-1)
       [M]DLVDAY(nolign-1)   = day(WDEMDLVDAT)
       [M]MON(nolign-1)      = month(WDEMDLVDAT)
       [M]YEA(nolign-1)      = year(WDEMDLVDAT)
       [M]DEMDLVDAT(nolign-1)= WDEMDLVDAT
       VALEUR=format$("D:"+GFMDAT4,gdat$([M]DLVDAY(nolign-1),[M]MON(nolign-1),[M]YEA(nolign-1)))
   Endif
Endif
# La date doit ÃŠtre > Ã  celle de la ligne prÃĐcÃĐdente
If nolign > 1
   If [M]CAD(nolign-1) = 1 & [M]CAD(nolign-2) = 1
      If [M]DEMDLVDAT(nolign-1) < [M]DEMDLVDAT(nolign-2)
         GMESSAGE = mess(21,192,1) : mkstat = 2 : End
      Endif
   Else
      If [M]DEMDLVDAT(nolign-1) <= [M]DEMDLVDAT(nolign-2)
         GMESSAGE = mess(21,192,1) : mkstat = 2 : End
      Endif
   Endif
Endif
# On vÃĐrifie que la date de commande est bien >= la date de dÃĐbut de vie de l'article
If [F:ITM]ITMREF <> [M]ITMREF
    Read [ITM] ITM0=[M]ITMREF
    If fstat Raz [F:ITM] Endif
Endif
If [F:ITM]LIFSTRDAT<>[0/0/0] & [M]DEMDLVDAT(nolign-1)<[F:ITM]LIFSTRDAT
   mkstat=2 : GMESSAGE=mess(331,199,1)-":"-format$(GFMDAT,[F:ITM]LIFSTRDAT) : End
Endif
# La date doit ÃŠtre <= Ã  la date de fin validitÃĐ de l'article
If [M]DEMDLVDAT(nolign-1) > [M]VLYDATITM
   GMESSAGE = mess(67,194,1) : mkstat = 2 : End
Endif
# La date doit ÃŠtre < Ã  celle de la ligne prÃĐcÃĐdente
If nolign < NBLIG
   If [M]CAD(nolign-1) = 1 & [M]CAD(nolign) = 1
      If [M]DEMDLVDAT(nolign-1) > [M]DEMDLVDAT(nolign)
         GMESSAGE = mess(21,192,1) : mkstat = 2 : End
      Endif
   Else
      If [M]DEMDLVDAT(nolign-1) >= [M]DEMDLVDAT(nolign)
         GMESSAGE = mess(21,192,1) : mkstat = 2 : End
      Endif
   Endif
Endif

GSOQSTA = [M]SOQSTA(nolign-1)
[M]SOQSTA(nolign-1) = 1
# Pas de gestion de l'avance-retard pour les contrats inter-site
If [M]DEMDLVDAT(nolign-1) < date$ & [M]BETFCY=1
   [M]SOQSTA(nolign-1) = 2
Endif

$FINCTR
End
######################################## Obligatoire
Subprog AM_XDLVDAT(VALEUR)
Variable Char    VALEUR()
# ForÃ§age de l'affichage de la zone date livraison (aprÃĻs formattage)
[M]XDLVDAT(nolign-1) = VALEUR
# Calcul date d'expÃĐdition si cadencement jour
If [M]CAD(nolign-1) = 1
   [M]SHIDAT(nolign-1) = [M]DEMDLVDAT(nolign-1) - [M]XDAYLTI
   Call CTL_JOU([M]SHIDAT(nolign-1),[F:FCY]UVYDAY,[F:FCY]UVYCOD,1) From CONTX3
# 88405 : Si cadencement semaine ou mois, la date d'expÃĐdition ne doit pas ÃŠtre renseignÃĐe
Else
  Raz [M]SHIDAT(nolign-1)
# 88405
Endif
# Initialisation du type d'ordre (CF si jour, CP si semaine ou mois)
[M]DEMSTA(nolign-1) = 1
If [M]CAD(nolign-1) <> 1
   [M]DEMSTA(nolign-1) = 2
Endif
Affzo [M]XDLVDAT(nolign-1)
Affzo [M]DEMSTA(nolign-1)
# Si demande semaine ou mois sur l'horizon ferme
If [M]CAD(nolign-1) <> 1 & [M]DEMDLVDAT(nolign-1) - date$ < [M]FIMHOR
   GERR=2 : GMESSAGE=mess(16,191,1)
Endif
# Recalcul de l'avance/retard
If [M]CREFLG(nolign-1) = 0 & [M]DEMSTA(nolign-1) = 1 & [M]QTY(nolign-1) <> 0
   If GSOQSTA = 1 & [M]SOQSTA(nolign-1) = 2
      [M]EARQTY += [M]QTY(nolign-1)
      [M]EARDAT  = date$-1
   Elsif GSOQSTA = 2 & [M]SOQSTA(nolign-1) = 1
      [M]EARQTY -= [M]QTY(nolign-1)
      [M]EARDAT  = date$-1
   Endif
   Affzo [M]EARQTY,EARDAT
Endif
#----- Optimisation du sÃĐquencement si possible -----#
If [M:SOQ1]SOQSEQ(nolign-1)<>0
  Local Integer SAV_STATUS : SAV_STATUS=status
  status=65 : Call C_NBLIG : # La ligne est-elle "supprimable" ?
  If !mkstat
    [M:SOQ1]SOQSEQ(nolign-1)=0
    [M:SOQ1]CREFLG(nolign-1)=0
    [M:SOQ1]UPDFLG(nolign-1)=1
  Else
    Raz mkstat, GMESSAGE
  Endif
  status=SAV_STATUS
Endif
#-----
End

######################################## Facultatif
Subprog AS_SHIDAT(VALEUR)
Variable Date    VALEUR
If [M:SOQ1]CAD(nolign-1)<>1 mkstat=2 Endif
End

######################################## Facultatif
Subprog C_SHIDAT(VALEUR)
Variable Date    VALEUR
# La date d'expÃĐdition doit ÃŠtre <= Ã  la date de livraison

If VALEUR > [M]DEMDLVDAT(nolign-1) mkstat = 2 : GMESSAGE=mess(33,192,1) : Endif
End

######################################## Facultatif
Subprog AS_DEMSTA(VALEUR)
Variable Integer VALEUR
Local    Integer NOL : NOL=nolign-1
#If [M:SOQ1]CAD(nolign-1)<>1 | sum([M:SOQ1]ALLQTY(nolign-1), [M:SOQ1]SHTQTY(nolign-1),[M]WALLQTY(nolign-1)) <> 0
If [M:SOQ1]CAD(NOL)<>1 |
&  sum([M:SOQ1]WTLVQTY(NOL), [M:SOQ1]ALLQTY(NOL), [M:SOQ1]SHTQTY(NOL),[M:SOQ1]LPRQTY(NOL)) <> 0
    mkstat=2
Endif
# On autorise uniquement les F et P dans le menu local 317
For I = 3 To 15
   GMENLOC(I) = 1
Next I
End

######################################## Facultatif
Subprog AP_DEMSTA(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
End

########################################
Subprog C_DEMSTA(VALEUR)
Variable Integer VALEUR
If [M]CAD(nolign-1) = 1
#  Si demande jour CF en dehors de l'horizon ferme
   If VALEUR = 1 & [M]DEMDLVDAT(nolign-1) - date$ > [M]FIMHOR
      GERR=2 : GMESSAGE=mess(15,191,1)
   Endif
Endif
End
######################################## Facultatif
Subprog AM_DEMSTA(VALEUR)
Variable Integer VALEUR

# 94476 : Il ne doit pas y avoir d'allocations sur une ligne planifiÃĐe
Local Integer NOL : NOL=nolign-1
# Il y a des allocations
If [M]WALLQTYSTU(NOL)-[M]ALLQTYSTU(NOL)+[M]SHTQTYSTU(NOL) > 0
    Local Integer OK : OK=2
    Call OUINON (mess(141,191,1)-mess(205,100,1), OK) From GESECRAN
    If OK=1 mkstat=2 : End : Endif
    Raz [M]WALLQTY(NOL), [M]WALLQTYSTU(NOL)
    Affzo [M]WALLQTY(NOL)
Endif
# 94476

If [M]CAD(nolign-1) = 1
#  Si demande jour CF en dehors de l'horizon ferme
#   If VALEUR = 1 & [M]DEMDLVDAT(nolign-1) - date$ > [M]FIMHOR
#      GERR=2 : GMESSAGE=mess(15,191,1)
#   Endif
#  Si demande jour CP sur l'horizon ferme
   If VALEUR = 2 & [M]DEMDLVDAT(nolign-1) - date$ < [M]FIMHOR
      GERR=2 : GMESSAGE=mess(16,191,1)
   Endif
Endif
#  Si la ligne modifiÃĐe est en retard, Maj de l'A/R
If [M]SOQSTA(nolign-1) = 2
#  Passage de CP Ã  CF
   If VALEUR = 1
      [M]EARQTY += [M]QTY(nolign-1)
#  Passage de CF Ã  CP
   Elsif VALEUR = 2
      [M]EARQTY -= [M]QTY(nolign-1)
   Endif
   [M]EARDAT  = date$-1
   Affzo [M]EARQTY,EARDAT
Endif
End

########################################
Subprog IB_QTY
# DÃĐsactivation bouton interro de stock, saisie filtre allocation, stock dispo
If [M]DSTOMGTCOD(nolign-1)=1 Raz GBOUT1, GBOUT2, GBOUT4 : Endif
# DÃĐsactivation bouton dÃĐtail allocation
# --> Si Allocation globale ou aucune allocation
#If [M]ALLTYP(nolign-1) = 1 | ([M]ALLQTY(nolign-1) = 0 & [M]SHTQTY(nolign-1) = 0)
# --> Si aucune allocation
If ([M]ALLQTY(nolign-1) = 0 & [M]SHTQTY(nolign-1) = 0)
    Raz GBOUT3
Endif
End
########################################
Subprog C_QTY(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M]WTLVQTY(nolign-1)+[M]ALLQTY(nolign-1)+[M]SHTQTY(nolign-1)+[M]LPRQTY(nolign-1)
    GMESSAGE=mess(312,192,1) : mkstat=2
Endif
End
########################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR
Local Integer I, NOL
Local Decimal COEF
NOL = nolign-1

# Bug 62888
# Si la qtÃĐ cdÃĐe a ÃĐvoluÃĐ, Init qtÃĐ Ã  allouer selon paramÃĻtre et habilitation :
If GINIALLORD=2 & GALLCOD <> 1
    Local Decimal WSAUSTUCOE : WSAUSTUCOE=[M]SAUSTUCOE
    Gosub INIT_WALLQTYSTU
Endif
# Bug 62888

# Calcul des cumuls Ã  livrer et Ã  atteindre de la ligne courante
If NOL = 0
   If [M]SOQSTA(NOL) = 2
      [M]XCUMLIV(NOL) = VALEUR
   Elsif [M]SOQSTA(NOL) = 1
      [M]XCUMLIV(NOL) = VALEUR
      [M]XCUMATT(NOL) = VALEUR
   Endif
Else
   If [M]SOQSTA(NOL) = 2
      [M]XCUMLIV(NOL) = [M]XCUMLIV(NOL-1) + VALEUR
   Elsif [M]SOQSTA(NOL) = 1
      [M]XCUMLIV(NOL) = [M]XCUMLIV(NOL-1) + VALEUR
      [M]XCUMATT(NOL) = [M]XCUMATT(NOL-1) + VALEUR
   Endif
Endif
Affzo [M]XCUMLIV(NOL),XCUMATT(NOL)
# Calcul des cumuls Ã  livrer et Ã  atteindre des lignes suivantes
If NOL+1 <> NBLIG
   For I = NOL+2 To NBLIG
      If [M]SOQSTA(I-1) = 2
         [M]XCUMLIV(I-1) = [M]XCUMLIV(I-2) + [M]QTY(I-1)
      Elsif [M]SOQSTA(I-1) = 1
         [M]XCUMLIV(I-1) = [M]XCUMLIV(I-2) + [M]QTY(I-1)
         [M]XCUMATT(I-1) = [M]XCUMATT(I-2) + [M]QTY(I-1)
      Elsif [M]SOQSTA(I-1) = 3
         [M]XCUMLIV(I-1) = [M]XCUMLIV(I-2)
         [M]XCUMATT(I-1) = [M]XCUMATT(I-2)
      Endif
      Affzo [M]XCUMLIV(I-1),XCUMATT(I-1)
   Next I
Endif
nolign = NOL+1

# Traitement particulier pour l'import : En AM_ on a plus l'ancienne valeur
If GIMPORT
    If [M]SOQSTA(nolign-1) = 2 & [M]DEMSTA(nolign-1) = 1
       [M]EARQTY -= [M]YQTY(nolign-1)
       [M]EARQTY += VALEUR
       [M]EARDAT  = date$-1
    Endif
    End
Endif
#  Si la ligne modifiÃĐe est en retard et de type CF, Maj de l'A/R
If [M]SOQSTA(nolign-1) = 2 & [M]DEMSTA(nolign-1) = 1
   [M]EARQTY    -= [M]QTY(nolign-1)
   [M]EARQTY    += VALEUR
   [M]EARDAT     = date$-1
   Affzo [M]EARQTY,EARDAT
Endif
End

# Bug 62888
# -------------------------------------------- #
# Initialisation de la qtÃĐ Ã  allouer           #
# -------------------------------------------- #
$INIT_WALLQTYSTU
Local Decimal WCOEF
Local Integer OK
# -- Si Commande non bloquÃĐe, pas en dÃĐpassement d'en-cours avec blocage
#       Ligne ferme
#       Article gÃĐrÃĐ en stock     : # 94476
# ----> Initialisation de la qtÃĐ Ã  allouer
# 94476 : Initialisation de la qtÃĐ Ã  allouer Ã  tord pour les articles non gÃĐrÃĐs en stock
#If  (find([M]CDTSTA,1,4) | ([M]CDTSTA=3 & GCDTUNL=2)) & [M]DEMSTA(NOL)=1
If  (find([M]CDTSTA,1,4) | ([M]CDTSTA=3 & GCDTUNL=2)) & [M]DEMSTA(NOL)=1 & [M]DSTOMGTCOD(NOL)<>1
# 94476
    # (Il faut toujours repartir des qtÃĐ en US pour effectuer les calculs)
    # --- QtÃĐ Ã  allouer = QtÃĐ dÃĐjÃ  allouÃĐe + Reste Ã  allouer
    [M]WALLQTYSTU(NOL) =[M]ALLQTYSTU(NOL)+([M]QTYSTU(NOL)-[M]TALLQTYSTU(NOL))
    COEF=1/WSAUSTUCOE
    Call CNVQTY([M]WALLQTYSTU(NOL),COEF,[M]SAU,[M]WALLQTY(NOL)) From TRTVENQTE
    If [M]WALLQTY(NOL)>0 & GUSERERBPC=3
        # Dde d'utilisation des rÃĐservations clients
        [M]RERBPCFLG(NOL)=1
        Local Char WVCRRER
        Local Decimal WALLCLI
        WVCRRER= vireblc(format$("K:"+num$(GLONBPC)+"X",[M]BPCORD)+format$("K:"+num$(GLONBPD)+"X",[M]BPAADD), 1)
        Call CAL_RERQTY(1,[M]ITMREF,[M]DSTOFCY(NOL),WVCRRER,[M]SHIDAT(NOL),WALLCLI) From STKALL
        If WALLCLI <> 0
            GMESSAGE = mess(131,191,1)-num$(WALLCLI)-[M]STU
            OK=2 : Call OUINON (GMESSAGE-"\"-mess(130,191,1),OK) From GESECRAN
            If OK = 2 [M]RERBPCFLG(NOL)=2 : Endif
        Endif
    Endif
    Affzo [M]WALLQTY(NOL)
Endif
# Bug 62888

Return

# ------------------------------------ WALLQTY ------------------------
########################################
Subprog IB_WALLQTY
# DÃĐsactivation bouton stock site, filtre allocation, stock dispo
# --> Si article non gÃĐrÃĐ en stock
If [M]DSTOMGTCOD(nolign-1) = 1 Raz GBOUT1, GBOUT2, GBOUT4 : Endif
# DÃĐsactivation bouton visu dÃĐtail allocation
# --> Si allocation globale ou aucune allocation
#If [M]ALLTYP(nolign-1) = 1 | ([M]ALLQTY(nolign-1) = 0 & [M]SHTQTY(nolign-1) = 0)
# --> Si aucune allocation
If ([M]ALLQTY(nolign-1) = 0 & [M]SHTQTY(nolign-1) = 0)
    Raz GBOUT3
Endif
End
########################################
Subprog AS_WALLQTY(VALEUR)
Variable Decimal VALEUR

Local    Integer NOL : NOL = nolign-1
Local    Decimal WSTUDIS, WSTUDISSTU
Local    Decimal WRALLQTY, WTALLQTY

# ---------- Pas de saisie de la quantitÃĐ allouÃĐe ------------
# --> Pas d'autorisation d'allocation
If GALLCOD = 1 mkstat = 2 : Endif
# --> La commande est bloquÃĐe
If [M:SOQ1]CDTSTA =  2 mkstat = 2 : End : Endif
# --> Ce n'est pas une ligne ferme
If [M]DEMSTA(NOL) <> 1 mkstat = 2 : End : Endif
# --> Article non gÃĐrÃĐ en stock
If [M]DSTOMGTCOD(NOL)   = 1  mkstat = 2 : End : Endif
# ------------------------------------------------------------------------------- #
#     Affichage de la quantitÃĐ restant Ã  allouer et de la quantitÃĐ disponible     #
# ------------------------------------------------------------------------------- #
If GIMPORT End Endif
# Calcul du total allouÃĐ    : Ã  allouer + prÃĐparÃĐ + livrÃĐ
WTALLQTY = VALEUR+[M]OPRQTY(NOL)+[M]PREQTY(NOL)+[M]ODLQTY(NOL)+[M]DLVQTY(NOL)
# Calcul du reste Ã  allouer : CommandÃĐ - total allouÃĐ
If WTALLQTY < [M]QTY(NOL) WRALLQTY = [M]QTY(NOL)  - WTALLQTY : Endif
# Calcul stock disponible
Local Integer WRET
Local Char    WNUM
If find(GUSERERBPC, 2,3) WNUM=vireblc(format$("K:15X",[M]BPCORD)+format$("K:3X",[M]BPAADD), 1) : Endif
#--- Issue 115110 : Added LECCVAL parameter in 10th position
Call STODISALL([M]DSTOFCY(NOL),[M]ITMREF,2,[M]ALLTYP(NOL),2,2,1,"",WNUM,"",WSTUDISSTU,WRET) From STKALL
If WRET=1 End Endif
GERR=4
If WSTUDISSTU > 0
    WSTUDIS=WSTUDISSTU*(1/[M]SAUSTUCOE)
    GMESSAGE = mess(46,191,1)+num$(WRALLQTY)-"-"-mess(163,197,1)+num$(WSTUDIS)
Else
    GMESSAGE = mess(46,191,1)+num$(WRALLQTY)-"-"-mess(409,197,1)
Endif
End
########################################
Subprog AS_WALLQTYSVG(VALEUR)
Variable Decimal VALEUR

Local    Integer NOL : NOL = nolign-1
Local    Decimal WSTUDIS
Local    Decimal WRALLQTY, WTALLQTY

# ---------- Pas de saisie de la quantitÃĐ allouÃĐe ------------
# --> La commande est bloquÃĐe
If [M:SOQ1]CDTSTA =  2 mkstat = 2 : End : Endif
# --> Ce n'est pas une ligne ferme
If [M]DEMSTA(NOL) <> 1 mkstat = 2 : End : Endif
# --> Article non gÃĐrÃĐ en stock et ce n'est pas un kit
If [M]DSTOMGTCOD(NOL) = 1 mkstat = 2 : End : Endif
# ------------------------------------------------------------------------------- #
#     Affichage de la quantitÃĐ restant Ã  allouer et de la quantitÃĐ disponible     #
# ------------------------------------------------------------------------------- #
# Calcul du total allouÃĐ    : DÃĐjÃ  allouÃĐ + rupture + Ã  allouer + livrÃĐ/facturÃĐ
If GIMPORT End Endif

WTALLQTY = [M]ALLQTY(NOL)+[M]SHTQTY(NOL)+[M]WALLQTY(NOL)+[M]ODLQTY(NOL)+[M]DLVQTY(NOL)
# Calcul du reste Ã  allouer : CommandÃĐ - total allouÃĐ
If WTALLQTY < [M]QTY(NOL)
    WRALLQTY = [M]QTY(NOL)  - WTALLQTY
Endif
# Recherche du stock disponible
#Call STODISALL([M]DSTOFCY(NOL), [M]ITMREF, [M]BPCORD, [M]BPAADD, [M]ALLTYP(NOL),
#&              [M]LOT(NOL), [M]LOC(NOL), [M]STA(NOL), WSTUDIS) From TRTVENALL
GERR=4 : GMESSAGE = mess(46,191,1)+num$(WRALLQTY)+" "+mess(47,191,1)+num$(WSTUDIS)

End
########################################
Subprog AP_WALLQTY(VALEUR)
Variable Decimal VALEUR
If [M]WALLQTY(nolign-1) = VALEUR
    GERR=4 : GMESSAGE = "             "
Endif
End
########################################
Subprog AM_WALLQTY(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL : NOL=nolign-1
Local    Decimal WALLQTY, WALLCLI, WSHT, WSTUDIS
Local    Decimal WTOTDLVQTY, WQTY
Local    Integer OK

  # --> Calcul du total dÃĐjÃ  prÃĐparÃĐ/livrÃĐ
  WTOTDLVQTY = [M]OPRQTY(NOL)+[M]PREQTY(NOL)+[M]DLVQTY(NOL)+[M]ODLQTY(NOL)
  # --> Calcul de la nouvelle qtÃĐ Ã  allouer
  WALLQTY=VALEUR-([M]ALLQTY(NOL)+[M]SHTQTY(NOL))
  Raz GMESSAGE
  If WALLQTY > 0
    # Augmentation de la qtÃĐ Ã  allouer
    # --> Blocage si dÃĐpassement en-cours
    If [M:SOQ1]CDTSTA = 3 & GCDTUNL=1
      # FGR 10/03/2015 : X3SUIVI23273 (dÃĐbut)
      #mkstat=2: GMESSAGE = mess(101,197,1) : End
      If !([M:SOQ1]BETFCY = 2 & [M:SOQ1]BETCPY <> 2) or GCTLBETFCY = 2 Then
        mkstat=2: GMESSAGE = mess(101,197,1) : End
      Endif
      # FGR 10/03/2015 : X3SUIVI23273 (fin)
    Elsif [M:SOQ1]CDTSTA = 3
      # --> Si pas de blocage et dÃĐpassement d'en-cours : Dde de confirmation
      # FGR 10/03/2015 : X3SUIVI23273 (dÃĐbut)
      #GMESSAGE = mess(101,197,1)
      If !([M:SOQ1]BETFCY = 2 & [M:SOQ1]BETCPY <> 2) or GCTLBETFCY = 2 Then
        GMESSAGE = mess(101,197,1)
      Endif
      # FGR 10/03/2015 : X3SUIVI23273 (fin)
    Elsif [M:SOQ1]CDTSTA = 4
      # --> Si Acompte non versÃĐ : Dde de confirmation
      GMESSAGE = mess(102,197,1)
    Endif
  Endif
  # --> QtÃĐ allouÃĐe supÃĐrieure Ã  la qtÃĐe cdÃĐe : Dde de confirmation
  If VALEUR + WTOTDLVQTY > [M]QTY(NOL)
    If GMESSAGE<>"" GMESSAGE+="\" Endif
    GMESSAGE+=mess(213,191,1)
  Endif
  If GMESSAGE <> ""
    GMESSAGE+="\"+mess(205,100,1)
    OK=1: Call AVERTIR(GMESSAGE,OK) From GESECRAN
    Raz GMESSAGE : If OK=1 mkstat=2 : End : Endif
  Endif
  If WALLQTY <=0 End : Endif
  # Dde d'utilisation des rÃĐservations clients
  If GUSERERBPC=3
    [M]RERBPCFLG(NOL)=1
    Local Char WVCRRER
    WVCRRER= vireblc(format$("K:"+num$(GLONBPC)+"X",[M]BPCORD)+format$("K:"+num$(GLONBPD)+"X",[M]BPAADD), 1)
    #--- Bug 65986
    #Call CAL_RERQTY(1,[M]ITMREF(NOL),[M]DSTOFCY(NOL),WVCRRER,WALLCLI) From STKALL            : # Bug 72485
    Call CAL_RERQTY(1,[M]ITMREF,[M]DSTOFCY(NOL),WVCRRER,[M]SHIDAT(NOL),WALLCLI) From STKALL   : # Bug 72485
    #---
    If WALLCLI <> 0
      GMESSAGE = mess(131,191,1)-num$(WALLCLI)-[M]STU
      OK=2 : Call OUINON (GMESSAGE-"\"-mess(130,191,1),OK) From GESECRAN
      If OK = 2 [M]RERBPCFLG(NOL)=2 : Endif
    Endif
  Endif
End
##########################################################################
## Etiquette ajoutÃĐe par le superviseur 25/04/2003 17:28:42 (LD)
##########################################################################
Subprog AS_ALLTYP(VALEUR)
Variable Integer VALEUR
# Pas d'autorisation d'allocation
If GALLCOD = 1 mkstat = 2 : End : Endif
If [M]DSTOMGTCOD(nolign-1)=1 mkstat=2 : End Endif
# le type d'allocation n'est plus modifiable s'il y a des allocations
If sum([M]ALLQTY(nolign-1), [M]SHTQTY(nolign-1)) mkstat=2 : End Endif
End
##########################################################################
#########################################################################
# SECTION CONTENANT LES TRAITEMENTS ANNEXES                             #
#########################################################################

$LENDAT4
# Il s'agit d'une demande mensuelle
If pat(VALEUR,"####")
   [M]CAD(nolign-1) = 3
#  Format MMYY
   If left$(GFMMOI,2) = "MM"
      If val(left$(VALEUR,2)) > 0 & val(left$(VALEUR,2)) < 13
         If val(right$(VALEUR,3)) > 90
            VALEUR = left$(VALEUR,2)+"/19"+right$(VALEUR,3)
         Else
            VALEUR = left$(VALEUR,2)+"/20"+right$(VALEUR,3)
         Endif
      Else
         Gosub ERRD
      Endif
#  Format YYMM
   Else
      If val(right$(VALEUR,3)) > 0 & val(right$(VALEUR,3)) < 13
         If val(left$(VALEUR,2)) > 90
            VALEUR = "19"+left$(VALEUR,2)+"/"+right$(VALEUR,3)
         Else
            VALEUR = "20"+left$(VALEUR,2)+"/"+right$(VALEUR,3)
         Endif
      Else
         Gosub ERRD
      Endif
   Endif
Else
   Gosub ERRD
Endif
Return

$LENDAT5
# Il s'agit d'une demande semaine
If pat(VALEUR,"#####")
   [M]CAD(nolign-1) = 2
#  Format MMYY
   If left$(GFMMOI,2) = "MM"
      If val(left$(VALEUR,3)) > 0 & val(left$(VALEUR,3)) < 54
         If val(right$(VALEUR,4)) > 90
            VALEUR = left$(VALEUR,3)+"-19"+right$(VALEUR,4)
         Else
            VALEUR = left$(VALEUR,3)+"-20"+right$(VALEUR,4)
         Endif
      Else
         Gosub ERRD
      Endif
#     Est ce une annÃĐe Ã  53 semaines
      If left$(VALEUR,3) = "053" Gosub S53 : Endif
#  Format YYMM
   Else
      If val(right$(VALEUR,3)) > 0 & val(right$(VALEUR,3)) < 54
         If val(left$(VALEUR,2)) > 90
            VALEUR = "19"+left$(VALEUR,2)+"-"+right$(VALEUR,3)
         Else
            VALEUR = "20"+left$(VALEUR,2)+"-"+right$(VALEUR,3)
         Endif
      Else
         Gosub ERRD
      Endif
#     Est ce une annÃĐe Ã  53 semaines
      If right$(VALEUR,6) = "053" Gosub S53 : Endif
   Endif
Else
   Gosub ERRD
Endif
Return

$LENDAT6
Local Integer I, WMOIS, WJOUR, WAN, WCHOIX, LNUM
Local Char    LVAL(12)(2)
Local Char    WWJOUR(2) ,WWMOIS(2) ,WWAN(4)
I = 6
WCHOIX = 0
#WCHOIX = 1

If pat(VALEUR,"######")
   If find(val(mid$(VALEUR,3,2)),19,20) & left$(GFMDAT,2)="MM" & left$(GFMMOI,2)="MM"
      If val(left$(VALEUR,2)) > 0 & val(left$(VALEUR,2)) < 13
         WWJOUR = mid$(VALEUR,3,2)
         WWMOIS = left$(VALEUR,2)
         WAN    = val(mid$(VALEUR,5,2))
         If WAN > 80
            WWAN = "19"+num$(WAN)
         Elsif len(num$(WAN)) = 1
            WWAN = "200"+num$(WAN)
         Else
            WWAN = "20"+num$(WAN)
         Endif
#         LVAL(0) = format$("D:"+GFMDAT4,WWMOIS+WWJOUR+WWAN)
#         LVAL(0) = format$("D:"+GFMDAT4,gdat$(val(WWMOIS),val(WWJOUR),val(WWAN)))
         LVAL(0) = format$("D:"+GFMDAT4,gdat$(val(WWJOUR),val(WWMOIS),val(WWAN)))
         LVAL(1) = left$(VALEUR,2)+"/"+right$(VALEUR,3)

         # --- Nouveau ---#
         status = 7
         While status = 7
            Selbox [L]LVAL Titled mess(112,195,1) Using [L]LNUM
         Wend
         WCHOIX = LNUM

      Else
         Gosub ERRD
      Endif

   Elsif find(val(left$(VALEUR,2)),19,20) & left$(GFMDAT,2)="DD" & left$(GFMMOI,2)="YY"
      WWJOUR = left$(VALEUR,2)
      WWMOIS = mid$(VALEUR,3,2)
      WAN    = val(mid$(VALEUR,5,2))
      If WAN > 80
         WWAN = "19"+num$(WAN)
      Elsif len(num$(WAN)) = 1
         WWAN = "200"+num$(WAN)
      Else
         WWAN = "20"+num$(WAN)
      Endif
#      LVAL(0) = format$("D:"+GFMDAT4,WWJOUR+WWMOIS+WWAN)
      LVAL(0) = format$("D:"+GFMDAT4,gdat$(val(WWJOUR),val(WWMOIS),val(WWAN)))
      LVAL(1) = left$(VALEUR,4)+"/"+right$(VALEUR,5)

      status = 7
      While status = 7
         Selbox [L]LVAL Titled mess(112,195,1) Using [L]LNUM
      Wend
      WCHOIX = LNUM

   Endif
#  Il s'agit d'une demande mensuelle
   If WCHOIX <> 1 & ((left$(GFMMOI,2)="MM" & find(val(mid$(VALEUR,3,2)),19,20)) |
&                    (left$(GFMMOI,2)="YY" & find(val(left$(VALEUR,2)),19,20)))
      [M]CAD(nolign-1) = 3
      If left$(GFMMOI,2) = "MM"
         If val(left$(VALEUR,2)) > 0 & val(left$(VALEUR,2)) < 13
            VALEUR = left$(VALEUR,2)+"/"+right$(VALEUR,3)
         Else
            Gosub ERRD
         Endif
      Else
         If val(right$(VALEUR,5)) > 0 & val(right$(VALEUR,5)) < 13
            VALEUR = left$(VALEUR,4)+"/"+right$(VALEUR,5)
         Else
            Gosub ERRD
         Endif
      Endif
#  Il s'agit d'une demande journaliÃĻre
   Else
      [M]CAD(nolign-1) = 1
#     Format DDMMYY
      If left$(GFMDAT,2) = "DD"
         WJOUR = val(left$(VALEUR,2))
         WMOIS = val(mid$(VALEUR,3,2))
         WAN   = val(mid$(VALEUR,5,2))
#     Format YYMMDD
      Elsif left$(GFMDAT,2) = "YY"
         WJOUR = val(mid$(VALEUR,5,2))
         WMOIS = val(mid$(VALEUR,3,2))
         WAN   = val(left$(VALEUR,2))
#     Format MMDDYY
      Else
         WJOUR = val(mid$(VALEUR,3,2))
         WMOIS = val(left$(VALEUR,2))
         WAN   = val(mid$(VALEUR,5,2))
      Endif
      Case WMOIS
         When 1,3,5,7,8,10,12 : Gosub M31
         When 4,6,9,11        : Gosub M30
         When 2               : Gosub M28
         When Default         : Gosub ERRD
      Endcase
   Endif
Else
   Gosub ERRD
Endif
Return

$LENDAT7
# Il s'agit d'une demande semaine
If pat(VALEUR,"#######")
   [M]CAD(nolign-1) =2
#  Format MMYY
   If left$(GFMMOI,2) = "MM"
      If val(left$(VALEUR,3)) > 0 & val(left$(VALEUR,3)) < 54
         VALEUR = left$(VALEUR,3)+"-"+right$(VALEUR,4)
      Else
         Gosub ERRD
      Endif
#     Est ce une annÃĐe Ã  53 semaines
      If left$(VALEUR,3) = "053" Gosub S53 : Endif
#  Format YYMM
   Else
      If val(right$(VALEUR,5)) > 0 & val(right$(VALEUR,5)) < 54
         VALEUR = left$(VALEUR,4)+"-"+right$(VALEUR,5)
      Else
         Gosub ERRD
      Endif
#     Est ce une annÃĐe Ã  53 semaines
      If right$(VALEUR,6) = "053" Gosub S53 : Endif
   Endif
Else
   Gosub ERRD
Endif
Return

$LENDAT8
Local Integer I, WJOUR, WMOIS, WAN
I = 8
# Il s'agit d'une demande journaliÃĻre
If pat(VALEUR,"########")
   [M]CAD(nolign-1) = 1
#  Format DDMMYYYY
   If left$(GFMDAT,2) = "DD"
      WJOUR = val(left$(VALEUR,2))
      WMOIS = val(mid$(VALEUR,3,2))
      WAN   = val(mid$(VALEUR,7,2))
#  Format YYYYMMDD
   Elsif left$(GFMDAT,2) = "YY"
      WJOUR = val(mid$(VALEUR,7,2))
      WMOIS = val(mid$(VALEUR,5,2))
      WAN   = val(mid$(VALEUR,3,2))
#  Format MMDDYYYYY
   Else
      WJOUR = val(mid$(VALEUR,3,2))
      WMOIS = val(left$(VALEUR,2))
      WAN   = val(mid$(VALEUR,7,2))
   Endif
   Case WMOIS
      When 1,3,5,7,8,10,12 : Gosub M31
      When 4,6,9,11        : Gosub M30
      When 2               : Gosub M28
      When Default         : Gosub ERRD
   Endcase
Else
   Gosub ERRD
Endif
Return

$M31
If WJOUR = 0 | WJOUR > 31
   Gosub ERRD
Else
   Gosub DAT8
Endif
Return

$M30
If WJOUR = 0 | WJOUR > 30
   Gosub ERRD
Else
   Gosub DAT8
Endif
Return

$M28
Local Integer WAN4
If WJOUR = 0 | WJOUR > 29
   Gosub ERRD
Else
   If WJOUR = 29
      If WAN > 80
         WAN4 = 1900 + WAN
      Else
         WAN4 = 2000 + WAN
      Endif
      If mod(WAN4,4) <> 0
         Gosub ERRD
      Endif
   Endif
   Gosub DAT8
Endif
Return

$DAT8
Local Char WWJOUR(2) ,WWMOIS(2) ,WWAN(4)
If len(num$(WJOUR)) = 1
   WWJOUR = "0"+num$(WJOUR)
Else
   WWJOUR = num$(WJOUR)
Endif
If len(num$(WMOIS)) = 1
   WWMOIS = "0"+num$(WMOIS)
Else
   WWMOIS = num$(WMOIS)
Endif
If WAN > 80
   WWAN = "19"+num$(WAN)
Elsif len(num$(WAN)) = 1
   WWAN = "200"+num$(WAN)
Else
   WWAN = "20"+num$(WAN)
Endif

VALEUR = format$("D:"+GFMDAT4,gdat$(val(WWJOUR),val(WWMOIS),val(WWAN)))

#If left$(GFMDAT,2) = "DD"
##   VALEUR = format$("D:"+GFMDAT4,WWJOUR+WWMOIS+WWAN)
#    VALEUR = format$("D:"+GFMDAT4,gdat$(val(WWJOUR),val(WWMOIS),val(WWAN)))
#Elsif left$(GFMDAT,2) = "YY"
##   VALEUR = format$("D:"+GFMDAT4,WWAN+WWMOIS+WWJOUR)
#    VALEUR = format$("D:"+GFMDAT4,gdat$(val(WWAN),val(WWMOIS),val(WWJOUR)))
#Else
##   VALEUR = format$("D:"+GFMDAT4,WWMOIS+WWJOUR+WWAN)
#    VALEUR = format$("D:"+GFMDAT4,gdat$(val(WWMOIS),val(WWJOUR),val(WWAN)))
#Endif

Return

$S53
Local Integer I
# L'annÃĐe comporte t-elle 53 semaines ?
# No jour du 31/12 de l'annÃĐe concernÃĐe
If left$(GFMMOI,2) = "MM"
   I = dayn(gdat$(31,12,val(right$(VALEUR,5))))
Else
   I = dayn(gdat$(31,12,val(left$(VALEUR,4))))
Endif
# Il y a 53 semaines si le dernier jour de l'annÃĐe est un jeudi ou
# si c'est un vendredi et le premier jour de l'annÃĐe est un jeudi
If I < 4 | I > 5 Gosub ERRD : Endif
If left$(GFMMOI,2) = "MM"
   If I = 5 & dayn(gdat$(01,01,val(right$(VALEUR,5)))) <> 4 Gosub ERRD : Endif
Else
   If I = 5 & dayn(gdat$(01,01,val(left$(VALEUR,4)))) <> 4 Gosub ERRD : Endif
Endif
Return

$ERRD
GMESSAGE = mess(14,192,1)
mkstat = 2
Return

#########################################################################
# Action SOLDLIV (Trt divers) : Solde d'une demande de livraison        #
#########################################################################
Subprog SOLDLIV
Local Integer I, OK, NOL
NOL = nolign-1
OK = 1
# --> Ctrl autorisation bouton solde (on teste l'autorisation de modification)
GBIDC2="M": GFCY=[M]SALFCY : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GZNUM=0:GERR = 1:GMESSAGE = mess(2,104,1): End : Endif
# Si la ligne est dÃĐjÃ  soldÃĐe, on a possibilitÃĐ de la rÃĐactiver
If [M]SOQSTA(NOL) = 3
   If [M]ODLQTY(NOL) = 0 & [M]DLVQTY(NOL) = 0
      Call OUINON(mess(22,192,1),OK) From GESECRAN
      If OK = 1 End : Endif
   Else
      End
   Endif
Endif
If [M]WALLQTY(NOL) <> 0
# Si la ligne de commande est allouÃĐe, demander confirmation
    OK=1 : Call OUINON(mess(139,191,1)-":"-mess(205,100,1), OK) From GESECRAN
    If OK=1 : End Endif
Endif
# --> Solde impossible, la qtÃĐ allouÃĐe doit ÃŠtre livrÃĐe
#If [M]WALLQTY(NOL) > 0
#   GERR=1 : GMESSAGE=mess(17,192,1)
#   End
#Endif
# Solde impossible, cadencement semaine ou mois
If [M]CAD(NOL) <> 1
   GERR=1 : GMESSAGE=mess(24,192,1)
   End
Endif
status = 75
If [M]SOQSTA(NOL) <> 3
# Solde de la ligne
   For I = NOL+1 To NBLIG
      If [M]SOQSTA(NOL) = 2
         [M]XCUMLIV(I-1) -= [M]QTY(NOL)
      Elsif [M]SOQSTA(NOL) = 1
         [M]XCUMLIV(I-1) -= [M]QTY(NOL)
         [M]XCUMATT(I-1) -= [M]QTY(NOL)
      Endif
      Affzo [M]XCUMLIV(I-1),XCUMATT(I-1)
   Next I
   #  Si la ligne est en retard, et de type CF, on maj l'A/R
   If [M]SOQSTA(NOL) = 2 & [M]DEMSTA(NOL) = 1
      [M]EARQTY  -= [M]QTY(NOL)
      [M]EARDAT   = date$-1
   Endif
   [M]SOQSTA(NOL) = 3
   #  -- Raz de la quantitÃĐ Ã  allouer
   Raz [M]WALLQTY(NOL), WALLQTYSTU(NOL)
   Affzo [M]WALLQTY(NOL)
   Affzo [M]EARQTY,EARDAT
Else
#  RÃĐactivation de la ligne
#  Ligne en retard
   If [M]DEMDLVDAT(NOL) < date$
      [M]SOQSTA(NOL) = 2
#     Ligne de type CF
      If [M]DEMSTA(NOL) = 1
         [M]EARQTY  += [M]QTY(NOL)
         [M]EARDAT   = date$-1
      Endif
      Affzo [M]EARQTY,EARDAT
#  Ligne en attente
   Else
      [M]SOQSTA(NOL) = 1
   Endif
   For I = NOL+1 To NBLIG
      If [M]SOQSTA(NOL) = 2
         [M]XCUMLIV(I-1) += [M]QTY(NOL)
      Elsif [M]SOQSTA(NOL) = 1
         [M]XCUMLIV(I-1) += [M]QTY(NOL)
         [M]XCUMATT(I-1) += [M]QTY(NOL)
      Endif
      Affzo [M]XCUMLIV(I-1),XCUMATT(I-1)
   Next I
Endif
[M]UPDFLG(NOL) = 1
Affzo [M]SOQSTA(NOL)
nolign = NOL+1
mkstat = 4
End


# --------------------------------------------------------------------- #
#     ETIQUETTES UTILISEES PAR ACTION SAISTOALL (ALLOCATIONS MANUELLES) #
#                                                                       #
#                AppelÃĐes depuis TRTSTOALLA                             #
# --------------------------------------------------------------------- #

#---------------------------------------------------------------------- #
# Action avant bouton  : VÃĐrifications au prÃĐalable                     #
# Si GNOTALL=1 Pas d'ouverture de la fenÃŠtre allocations manuelles      #
#---------------------------------------------------------------------- #
$AB6_NBLIG
Local Integer OK, NOL : NOL=nolign-1
Local Char    SYMBOLE(50)

  #--------------------------------------------------#
  # Verrouillage de la commande pour bouton          #
  #--------------------------------------------------#
  SYMBOLE = "SOC"+num$([M:SOQ1]SOPLIN)+"\"+[M:SOQ1]SOHNUM
  Lock = SYMBOLE
  If fstat
    # modification en cours sur un autre poste
    GERR=1 : GNOTALL=1 : GMESSAGE=[M:SOQ1]SOHNUM-num$([M:SOQ1]SOPLIN)-":"-mess(10,100,1) : Return
  Endif
  If [M:SOQ1]CDTSTA = 3
    # -- DÃĐpassement en-cours
    If !([M:SOQ1]BETFCY = 2 & [M:SOQ1]BETCPY <> 2) or GCTLBETFCY = 2 Then      # FGR 10/03/2015 : X3SUIVI23273
      If GCDTUNL=1
        Call ERREUR(mess(101,197,1)) From GESECRAN : GNOTALL=1 : Return
      Else
        OK=1 : Call AVERTIR (mess(17,191,1), OK) From GESECRAN
        If OK=1 GNOTALL=1 : Return : Endif
      Endif
    Endif
  Elsif [M:SOQ1]CDTSTA = 4
    # -- Acomptes non versÃĐs
    OK=1 : Call AVERTIR (mess(18,191,1), OK) From GESECRAN
    If OK=1 GNOTALL=1 : Return : Endif
  Endif
  # -- Ligne allouÃĐe en Global : On demande si on veut l'allouer en dÃĐtaillÃĐ
  If [M:SOQ1]ALLTYP(NOL)=1
    OK=1 : Call OUINON (mess(144,191,1), OK) From GESECRAN
    If OK=1 GNOTALL=1 : Return : Endif
  Endif
Return

#---------------------------------------------------------------------- #
# DÃĐverrou de la commande                                               #
#---------------------------------------------------------------------- #
$BB6_NBLIG

# Si GCONSULT=0, le verrou a ÃĐtÃĐ positionnÃĐ par l'objet SOQ : on ne fait rien
# Si GCONSULT=2, le verrou a ÃĐtÃĐ positionnÃĐ en avant bouton, il faut dÃĐverouiller
# Si GMODCOD =2, le verrou a ÃĐtÃĐ positionnÃĐ en avant bouton, il faut dÃĐverouiller
If GCONSULT=2 | GMODCOD=1 Unlock=SYMBOLE Endif

Return

#---------------------------------------------------------------------- #
# Chargement des paramÃĻtres dans masque STOALL                          #
# Cette ÃĐtiquette est appelÃĐe depuis CHARGE_PARAM From TRTSTOALLA       #
#---------------------------------------------------------------------- #
$CHARGE_STOALL
#Local Char    LWRH(GLONWRH)
#Local Integer LEXC
# Chargement du masque [M:ALL]
Raz [M:ALL]
[M:ALL]VCRTYP=2
[M:ALL]VCRNUM=[M:SOQ1]SOHNUM
[M:ALL]VCRLIN=[M:SOQ1]SOPLIN
[M:ALL]VCRSEQ=[M:SOQ1]SOQSEQ (LNOL)
[M:ALL]PCU=[M:SOQ1]SAU
[M:ALL]STU=[M:SOQ1]STU
[M:ALL]PCUSTUCOE=[M:SOQ1]SAUSTUCOE
[M:ALL]BPCORD=[M:SOQ1]BPCORD
[M:ALL]BPAADD=[M:SOQ1]BPAADD
# QuantitÃĐ besoin = commandÃĐ - dÃĐjÃ  livrÃĐ
[M:ALL]RETQTY = [M:SOQ1]QTYSTU(LNOL) - [M:SOQ1]WTLVQTYSTU(LNOL)
If [M:ALL]RETQTY < 0 [M:ALL]RETQTY = 0 Endif
[M:ALL]OLDALLQTY = [M:SOQ1]ALLQTYSTU(LNOL)
[M:ALL]SHTQTY    = [M:SOQ1]SHTQTYSTU(LNOL)
# Alimentation de la qtÃĐ Ã  allouer
[M:ALL]QTYTOALL  = [M:SOQ1]WALLQTYSTU(LNOL)
# Alimentation de la qtÃĐ dÃĐjÃ  allouÃĐe en global
Raz [M:ALL]GLOALLQTY : If [M:SOQ1]ALLTYP(LNOL)=1 [M:ALL]GLOALLQTY=[M:SOQ1]ALLQTYSTU(LNOL) Endif

[M:ALL]ALLTYP = [M:SOQ1]ALLTYP(LNOL)
[M:ALL]RETDAT = max(date$, [M:SOQ1]SHIDAT(LNOL))
#[M:ALL]DLVDAT = max(date$, [M:SOQ1]EXTDLVDAT(LNOL))
[M:ALL]PECINTLOC = 2    : # Prise en cpte empl interne : Oui
[M:ALL]PECPLFLOC = 2    : # Prise en cpte empl quai    : Oui
[M:ALL]XLOT   = [M:SOQ1]LOT(LNOL)
[M:ALL]XLOC   = [M:SOQ1]LOC(LNOL)
[M:ALL]XSTA   = [M:SOQ1]STA(LNOL)
#Call WRHAUTO([M:SOQ1]DSTOFCY(LNOL),[M:SOQ1]ITMREF(LNOL),2,0,0,LWRH,LEXC) From STKWRH
#If LEXC=1 [M:ALL]XWRH=LWRH Endif
# FGR 04/05/2015 : X3SUIVI105605 (dÃĐbut)
If dim([M:SOQ1]ECCVALMAJ) >= 0 Then
  [M:ALL]WECCVALMAJ = [M:SOQ1]ECCVALMAJ(LNOL)
Endif
# FGR 04/05/2015 : X3SUIVI105605 (fin)
GTYPLIG=0
# RÃĐcupÃĐration du paramÃŠtre stock : GÃĐnÃĐration de ruptures
Local Char     WPARAM(10)
Call PARAML([M:SOQ1]DSTOFCY(LNOL),"GENSHT",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GGENSHT=val(WPARAM)
Return

#---------------------------------------------------------------------- #
# ContrÃīle avant enregistrement                                         #
# Si contrÃīle non OK, mettre OK=0 pour ne pas enregister                #
# Cette ÃĐtiquette est appelÃĐe depuis AVANT_ENR From TRTSTOALLA          #
#---------------------------------------------------------------------- #
$AVANT_STOALL
Return

$APRES_STOALL
Local Integer NL, WRET
Local Decimal WALLSTU
Local Char    WTRTLIG(1)

#[M:ALL]ALLTYP=2
If WCSOQTY<>0
    Local Char WVCRRER
    WVCRRER = format$("K:"+num$(GLONBPC)+"X", [M:ALL]BPCORD)+format$("K:"+num$(GLONBPD)+"X", [M:ALL]BPAADD)
    WVCRRER = vireblc(WVCRRER, 1)
    # Si consommation des rÃĐservations clients : Maj de l'encours correspondant
    Call MAJORDBPC(1,WVCRRER,[M:SOQ1]ITMREF,[M:SOQ1]DSTOFCY(LNOL),WCSOQTY,WRET) From TRTVENALL
    If WRET <> 0 GOK=0 : Return Endif
Endif
#   Mise Ã  jour commande
Call MAJALLORD([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, [M:ALL]ALLTYP, 1, WALLQTY, WSHTQTY, WRET) From TRTVENALL
If WRET <> 0 : GOK = 0 : Return : Endif
#   Si ComposÃĐ de kit, il faut allouer les composants
WALLSTU=WALLQTY+WSHTQTY
WALLSTU=WALLSTU-([M:SOQ1]ALLQTYSTU(LNOL)+[M:SOQ1]SHTQTYSTU(LNOL))
Raz WTRTLIG
#    RÃĐaffichage du masque [M:SOQ1]
If [F:SOQ]SOHNUM<>[M:SOQ1]SOHNUM | [F:SOQ]SOPLIN<>[M:SOQ1]SOPLIN | [F:SOQ]SOQSEQ<>[M:SOQ1]SOQSEQ(LNOL)
    Read [SOQ]SOQ0=[M:SOQ1]SOHNUM;[M:SOQ1]SOPLIN;[M:SOQ1]SOQSEQ(LNOL)
    If fstat : Return : Endif
Endif
[M:SOQ1]ALLQTY(LNOL)       = [F:SOQ]ALLQTY
[M:SOQ1]ALLQTYSTU(LNOL)    = [F:SOQ]ALLQTYSTU
[M:SOQ1]SHTQTY(LNOL)       = [F:SOQ]SHTQTY
[M:SOQ1]SHTQTYSTU(LNOL)    = [F:SOQ]SHTQTYSTU
[M:SOQ1]ALLTYP(LNOL)       = [F:SOQ]ALLTYP
[M:SOQ1]WTLVQTYSTU(LNOL)   = [F:SOQ]OPRQTYSTU+[F:SOQ]PREQTYSTU+[F:SOQ]DLVQTYSTU + [F:SOQ]ODLQTYSTU
[M:SOQ1]WTLVQTY(LNOL)      = [F:SOQ]OPRQTY   +[F:SOQ]PREQTY   +[F:SOQ]DLVQTY    + [F:SOQ]ODLQTY
# --- QtÃĐ Ã  allouer = QtÃĐ dÃĐjÃ  allouÃĐe
[M:SOQ1]WALLQTY(LNOL)      = [F:SOQ]ALLQTY + [F:SOQ]SHTQTY
[M:SOQ1]WALLQTYSTU(LNOL)   = [F:SOQ]ALLQTYSTU + [F:SOQ]SHTQTYSTU
[M:SOQ1]YALLQTY(LNOL)      = [M:SOQ1]ALLQTY(LNOL)
[M:SOQ1]YSHTQTY(LNOL)      = [M:SOQ1]SHTQTY(LNOL)

Affzo [M:SOQ1]ALLQTY(LNOL), SHTQTY(LNOL), WALLQTY(LNOL), ALLTYP(LNOL)

Return
######################################################################################
#--------------------------------------------------------------------------#
# Chargement des paramÃĻtres avec GFCY = Site de la commande                #
# ------------------------------------------------------------------------ #
# Chargement des globales rÃĐfÃĐrenciels, comptes et sections de la sociÃĐtÃĐ  #
# Chargement des paramÃĻtres de localisation                                #
# ------------------------------------------------------------------------ #
$CHARG_PARAM

# --- Chargement des globales rÃĐfÃĐrenciels, comptes et sections de la sociÃĐtÃĐ
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
# --- Si changement sociÃĐtÃĐ
If GSOC_UPDFLG
    If dim(OK)<1  Local Integer OK : Endif
    # --- RÃĐcupÃĐration du compteur des encours article
    Call LECTCA(7,OK) From SUBTCA
    If fstat | !OK
        GERR=1 : GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1) : Return
    Endif
    GWIP=[F:TCA]CODNUM(8)

    # FGR 15/12/2011 : X3SUIVI71065 (dÃĐbut)
    GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC(GFCY)
    Call PJT_MODFCY(GFCY, "[M:SOQ1]DPJT") From TRTPJT
    # FGR 15/12/2011 : X3SUIVI71065 (fin)
Endif
Return

######################################################################################
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

  # FGR 01/04/2015 : X3SUIVI105605
  Gosub ECCVALMAJMIN_ENABLE
End

######################################################################################
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Integer LRET

  # FGR 10/04/2015 : X3SUIVI105605
  Call CTLECCVAL(VALEUR, [M:SOQ1]DSTOFCY(nolign-1), [M:SOQ1]ITMREF, 4, "", [M:SOQ1]SHIDAT(nolign-1), LRET) From STKSOR
  If LRET > 1 Then
    mkstat = 2
  Endif
End

######################################################################################
Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Char WECCVALMAJ(GLONECS)
Local Char WECCVALMIN(GLONICVVAL)
Local Char PITM(GLONITM)

If [M]WIPFLG(nolign-1) = "" [M]WIPFLG(nolign-1) = "M" : Endif : # Issue 114112

  # FGR 10/04/2015 : X3SUIVI105605
  Raz PITM
  # si version majeure trouvÃĐe et si article gere la version mineure : recherche derniere version mineure
  If [F:ITM]ITMREF <> [M:SOQ1]ITMREF Then
    Read [ITM]ITM0=[M:SOQ1]ITMREF
  Endif
  If VALEUR  <> "" and [F:ITM]ECCSTO = 3 Then
    WECCVALMAJ = VALEUR
    PITM = [F:ITM]ITMREF
    Gosub READECCMIN From STKACT
    [M:SOQ1]ECCVALMIN(nolign-1) = WECCVALMIN
    Affzo [M:SOQ1]ECCVALMIN(nolign-1)
  Elsif VALEUR = "" and [M:SOQ1]ECCVALMIN(nolign-1) <> "" Then
    Raz [M:SOQ1]ECCVALMIN(nolign-1)
    Affzo [M:SOQ1]ECCVALMIN(nolign-1)
  Endif
End

######################################################################################
Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()

  # FGR 01/04/2015 : X3SUIVI105605
  Gosub ECCVALMAJMIN_ENABLE
End

######################################################################################
$ECCVALMAJMIN_ENABLE
  # FGR 01/04/2015 : X3SUIVI105605
  # 105605 :La version n'est plus modifiable dÃĻs lors que la ligne est allouÃĐe,prÃĐparÃĐe,livrÃĐe
  If [M:SOQ1]TALLQTYSTU(nolign-1) > 0 Then
    mkstat = 2
  Endif
Return

# Issue 114112
######################################################################################
Subprog AM_ECCVALMIN(VALEUR)
Variable Char    VALEUR()

If [M]WIPFLG(nolign-1) = "" [M]WIPFLG(nolign-1) = "M" : Endif

End
######################################################################################
# End issue 114112


