####################################################################
# OTHERS
####################################################################

$_AOTHERS
Gosub DECLARE_VAR From WMC0EDISEQFILF
Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MSGCOD From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MSGCOD From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MSGREL From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MSGREL From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MSGFILNOR From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MSGFILNOR From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_NUMLIN From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_NUMLIN From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SORT From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SORT From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_FILCOD From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_FILCOD From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_FILNAM From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_FILNAM From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MANDATORY From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MANDATORY From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_DESCRIPTION From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_DESCRIPTION From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MAINFIELD From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MAINFIELD From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_LINKFIELD From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_LINKFIELD From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_PARFILE From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_PARFILE From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_PROTOMAIN From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_PROTOMAIN From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREDATTIM From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREDATTIM From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_PROTOLINK From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_PROTOLINK From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDDATTIM From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDDATTIM From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_AUUID From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_AUUID From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREUSR From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREUSR From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDUSR From WMC1EDISEQFILF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDUSR From WMC1EDISEQFILF : Gosub TESTALLSTAT :  Endif
[L]ASTATUS = fmet this.ACONTROL
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



