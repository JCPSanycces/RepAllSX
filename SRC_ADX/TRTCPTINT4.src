#
# Liste des fonctions :
# -------------------
#
#
# Liste des routines :
# ------------------
#
# $TRC_TMPTABDTA
# $TRC_TMPTABLCK
#
########################################################################################################################
# Modifications :
# -------------
#
# XXX   JJ.MM.AAAA  Fq nnnnn     Commentaire
# MDJ Issue X3-97599 - 2018-09-2018  Reversal document with REFSIM not deleted when TRTCPTINT run in actual
# MDJ   01.01.2016  FQ 113163    Simulated journals not deleted when actual journals created
# MDJ   17.12.2015  FQ 112850    Managing deletion of simulated entries
# MDJ   21.08.2015  FQ 110477    "ORA-08006: specified row no longer exists : Erreur Oracle" [F:WLCA]LNKSRC=9 : Rewrite [F:WLCA]
# MDJ   23.10.2013  FQ 93018     Pièces compta prov sur exercice suivant non supprimées quand Exe(N+1) devient Exe(N)
# GBO   10.12.2010  FQ 69824     Interface comptable multi référentiel
# GBO   09.09.2010  FQ 67087     Pas de décrémentation du solde lors de la suppression des pièces provisoires
# GBO   05.07.2010  FQ 65873     Utilisation des globales GML_MSGxxx
# GBO   06.05.2010  Fq 64544     Gestion de la comptabilisation des écarts entre plans
# GBO   03.09.2009  Fq 56897     Suppression pièce provisoire d'un plan à tort.
########################################################################################################################
#CHECK IGNORE_BEGIN
 Local Integer CDRET
 Local Char    MES(255)
 If !clalev([F:HAE])  : Local File GACCENTRY             [HAE]  : Endif
 If !clalev([F:DAE])  : Local File GACCENTRYD            [DAE]  : Endif
 If !clalev([F:DAA])  : Local File GACCENTRYA            [DAA]  : Endif
 Call DELETE_CPT_PROVISOIRE("TVF", "SVF", GVML_TLIAS, [0/0/0], [0/0/0], 0, 0, G_OUI, G_OUI, CDRET, MES)
 If CDRET
  Infbox MES
 Endif
End
#CHECK IGNORE_END
#=============================================================================
# Sous-programme de suppression des pièces comptables provisoires
#
#=============================================================================
Subprog DELETE_CPT_PROVISOIRE(PCPY, PFCY, PCOMPTA, PDATMIN, PDATMAX, PFIY, PPER, PPROGBAR, PTRC, PACETYP, PDIRECT, RCOD, RMES)
Value    Char    PCPY      # Société
Value    Char    PFCY      # Site
Value    Integer PCOMPTA   # Référentiel à traiter 0 - Tous / 1 - PCG / 2 - IAS
Value    Date    PDATMIN   # Borne de date minimum pour sélection
Value    Date    PDATMAX   # Borne de date maximum pour sélection
Value    Integer PFIY      # Exercice de rattachement : GVML_TECOURA / GVML_TESUIV
Value    Integer PPER      # N° de la période dans l'exercice PFIY
Value    Integer PPROGBAR  # Barre de progression (non par défaut)
Value    Integer PTRC      # Affichage de la liste des pièces supprimées dans une trace (non par défaut)
Value    Char    PACETYP   # Type d'écriture à supprimer
Value    Integer PDIRECT   # Contexte d'appel : comptabilisation directe ? G_OUI / G_NON
Variable Integer RCOD      # Code retour du sous-pro >0 : erreur
Variable Char    RMES()    # Message associé au code erreur

 Local Date  WPDATMIN, WPDATMAX  #112850
 Gosub DEF_CONSTANTES
 Gosub DEF_GLOBALES
 Gosub DEF_VARIABLES
 Gosub OUVRE_TABLES
 L_PARANNUL = G_NON


 # on sélectionne les pièces provisoires stockées sur l'exercice courant ou sur l'exercice suivant car
 # les pièces générées sur un exercice suivant restent "topées" exercice suivant même quand l'exercice en question est devenu courant
 #FQ93018 L_REQ   ="CPY='"+PCPY+"'&FCY='"+PFCY+"'"+"&"+"FIY="+num$(PFIY)+"&PER="+num$(PPER)+"&CAT=2".
 L_REQ   ="CPY='"+PCPY+"'&FCY='"+PFCY+"'"+"&PER="+num$(PPER)+"&CAT=2"
 # issue 113163 L_REQ+="&(FIY=GVML_TECOURA|FIY=GVML_TESUIV)"

 # Sélection du type d'écriture pour ne pas supprimer toutes les pièces provisoires d'un même référentiel
 If PACETYP<>""
  L_REQ+="&(ACETYP='"+PACETYP+"'|ACETYP='')"
 Endif

 # issue 113163 & 112850
#<<<<<<FQ93018 on testera aussi la date de comptabilisation pour ne supprimer que les pièces correspondant à une plage de dates
 #Local Char    WCRITDAT(255)
 #  PDATMIN<>[0/0/0]                 :  WCRITDAT="ACCDAT>=PDATMIN"  : Endif
 #  PDATMAX<>[0/0/0] & WCRITDAT<>""  :  WCRITDAT+="&"               : Endif
 #  PDATMAX<>[0/0/0]                 :  WCRITDAT+="ACCDAT<=PDATMAX" : Endif
 #  WCRITDAT=""                      :  WCRITDAT="1=1"              : Endif
 #FQ93018 >>>>>>>
 WPDATMIN=[F:FSY]DATSTRFIY
 WPDATMAX=[F:FSY]DATENDFIY
Local Char    WCRITDAT(255)
 If  PDATMIN<>[0/0/0]                 :  WCRITDAT="ACCDAT>=WPDATMIN"  : Endif
If  PDATMAX<>[0/0/0] & WCRITDAT<>""  :  WCRITDAT+="&"               : Endif
 If  PDATMAX<>[0/0/0]                 :  WCRITDAT+="ACCDAT<=WPDATMAX" : Endif
If  WCRITDAT=""                      :  WCRITDAT="1=1"              : Endif
 # End issue 113163 & 112850

 If PTRC=G_OUI & GTRACE=""
  Call OUVRE_TRACE("Suppressions des pièces comptables provisoires de dotation") From LECFIC
  Gosub ET_TRC_DEL_PRO_PCE From TRTCPTINT2
  Local Integer LOCALTRC
 Endif
 Gosub DELPCE
$FIN_DELETE_CPT_PROVISOIRE
 If PPROGBAR=G_OUI
  Call FERME_BOITE From GESECRAN
 Endif
 Gosub KILL_CONSTANTES
 Gosub KILL_GLOBALES
 If PTRC=G_OUI & dim(LOCALTRC)>0
  Call LEC_TRACE From LECFIC
 Endif
 #@fq64544
 If PDIRECT=G_OUI & PTRC=G_OUI & dim(LOCALTRC)<0 & !LNBDELPCETOT
  Call FERME_TRACE From LECFIC
 Endif
End

#=============================================================================
$OUVRE_TABLES

 If !clalev([F:WLCA])  : Local File LNKCPTABX3            [WLCA]  : Endif
 If !clalev([F:WLCD])  : Local File LNKCPTABD             [WLCD]  : Endif
 If !clalev([F:WHAT])  : Local File GACCTMP               [WHAT]  : Endif
 If !clalev([F:WDAT])  : Local File GACCTMPD              [WDAT]  : Endif
 If !clalev([F:WDTA])  : Local File GACCTMPA              [WDTA]  : Endif
 If !clalev([F:WHAE])  : Local File GACCENTRY             [WHAE]  : Endif
 If !clalev([F:HAE])   : Local File GACCENTRY             [HAE]   : Endif
 If !clalev([F:WDAE])  : Local File GACCENTRYD            [WDAE]  : Endif
 If !clalev([F:WDAA])  : Local File GACCENTRYA            [WDAA]  : Endif

Return

#=============================================================================
$DEF_CONSTANTES
Return

#=============================================================================
$DEF_GLOBALES
Return

#=============================================================================
$DEF_VARIABLES_OLD
 Local Integer L_PARANNUL
 Local Char    L_REQ(255)
 Local Char    LPCGPCEFCY
 Local Char    LPCGPCEJOU
 Local Char    LPCGPCETYP
 Local Char    LPCGPCENUM
 Local Char    LPCGPCEREF
 Local Char    LPCGPCEDES
 Local Date    LPCGPCEDAT
 Local Char    LIASPCEFCY
 Local Char    LIASPCEJOU
 Local Char    LIASPCETYP
 Local Char    LIASPCENUM
 Local Char    LIASPCEREF
 Local Char    LIASPCEDES
 Local Date    LIASPCEDAT
 Local Integer LNBDELPCETOT #@fq64544
Return

#=============================================================================
$DEF_VARIABLES
 Local Char L_REQ(255)
 Local Char LPERCHAR
 Local Char LACETYP

 Local Char LPCEFCY         # Site de la pièce                          # ?
 Local Char LPCETYP         # Type de la pièce                          # -
 Local Char LPCENUM         # N° de pièce                               # o
 Local Date LPCEACCDAT      # Date comptable de la pièce                # o
 Local Char LPCEREF         # Référence libre de la pièce               # o
 Local Char LPCEDES         # Libellé / Désignation de la pièce         # ? Non utilisé
 Local Char LPCEJOU         # Journal de la pièce                       # ? Non utilisé
 Local Char LPCEREFSIM      # Référence pièce Simu ABL-nnnn-n           #  #*X3-97599

 Local Integer LNBDELPCETOT

Return

#=============================================================================
$DELPCE

 LTRCACETYP     = PACETYP
 LTRCPER        = format$(GFMDAT4,PDATMIN)-"=>"-format$(GFMDAT4,PDATMAX)
 LTRCTYPACT     = "S"

 #FQ93018 Filter [F:WLCA] Where evalue(L_REQ)
 Filter [F:WLCA] Where evalue(L_REQ) &evalue(WCRITDAT)
 Local Integer NBDELPCE
 If PPROGBAR=G_OUI
  Local Integer NBDELPCETOT : NBDELPCETOT=rowcount([F:WLCA])
  Call OUVRE_BOITE("Suppression pièces provisoires du module immobilisation",NBDELPCETOT) From GESECRAN
 Endif

 Trbegin [WHAT], [WHAE]
 For [F:WLCA]
   #> Recherche dans les tables temporaires
   # -------------------------------------
  Read [F:WHAT]HAT0=[F:WLCA]TYP;[F:WLCA]NUM
  If !fstat

   If PDIRECT<>G_OUI
    If dim(LTRCINFOPER)<0
     Gosub TRC_PER From TRTCPTINT2
     Global Integer LTRCINFOPER
    Endif
   Endif

   LPCEFCY     = [F:WHAT]FCY
   LPCETYP     = [F:WHAT]TYP
   LPCENUM     = [F:WHAT]NUM
   LPCEDES     = [F:WHAT]DESVCR
   LPCEJOU     = [F:WHAT]JOU
   LPCEACCDAT  = [F:WHAT]ACCDAT
   LPCEREFSIM  = [F:WHAT]REFSIM  #*X3-97599

   Delete [F:WDAT] Where (TYP=[F:WHAT]TYP & NUM=[F:WHAT]NUM)
   Delete [F:WDTA] Where (TYP=[F:WHAT]TYP & NUM=[F:WHAT]NUM)
   Delete [F:WHAT] Curr
   If fstat
   Endif

   # Delete simulated journals with same value for REFSIM
   Delete [F:WHAT] Where (REFSIM=LPCEREFSIM & CAT>1)    #*X3-97599
   NBDELPCE+=1                                          #*X3-97599
   LNBDELPCETOT+=1                                      #*X3-97599

   [F:WLCA]LNKSRC=9 : Rewrite [F:WLCA]
   NBDELPCE+=1
   LNBDELPCETOT+=1 #@fq64544

   If PPROGBAR=G_OUI
    Call AFF_BOITE(LPCGPCENUM-num$(NBDELPCE)+"/"+num$(NBDELPCETOT),NBDELPCE,GOK) From GESECRAN
   Endif
   If PTRC=G_OUI
    If dim(LENTETE)<0
     Call ECR_TRACE("    "+mess(119,GML_MSGCPT,1),0) From GESECRAN #"PIECES COMPTABLES PROVISOIRES SUPPRIMEES"
     Local Integer LENTETE
    Endif
    Gosub LIST_PCE From TRTCPTINT2
   Endif

   Goto $NEXT_PCE_NEW
  Elsif fstat=5
  Else
   Goto $NEXT_PCE_NEW
  Endif
  #> Recherche dans les tables définitives
  #  -------------------------------------

  Read [F:WHAE]HAE0=[F:WLCA]TYP;[F:WLCA]NUM
  If !fstat

   If PDIRECT<>G_OUI
    If dim(LTRCINFOPER)<0
     Gosub TRC_PER From TRTCPTINT2
     Global Integer LTRCINFOPER
    Endif
   Endif

   LPCEFCY     = [F:WHAE]FCY
   LPCETYP     = [F:WHAE]TYP
   LPCENUM     = [F:WHAE]NUM
   LPCEDES     = [F:WHAE]DESVCR
   LPCEJOU     = [F:WHAE]JOU
   LPCEACCDAT  = [F:WHAE]ACCDAT
   LPCEREFSIM  = [F:WHAE]REFSIM    #*X3-97599

   GTRANS=1
   [F:HAE]=[F:WHAE] #fq67087
   Call DELPCE([F:WHAE]TYP,[F:WHAE]NUM) From CPTBATCH
   NBDELPCE+=1                                              #*X3-97599
   LNBDELPCETOT+=1                                          #*X3-97599

   # Delete simulated journals with same value for REFSIM
   Delete [F:WHAE] Where  (REFSIM=LPCEREFSIM & CAT>1)       #*X3-97599

   #FQ110477  [F:WLCA]LNKSRC=9 :    Rewrite [F:WLCA]
   NBDELPCE+=1
   LNBDELPCETOT+=1 #@fq64544

   If PPROGBAR=G_OUI
    Call AFF_BOITE(LPCGPCENUM-num$(NBDELPCE)+"/"+num$(NBDELPCETOT),NBDELPCE,GOK) From GESECRAN
   Endif
   If PTRC=G_OUI
    If dim(LENTETE)<0
     Call ECR_TRACE("    "+mess(119,GML_MSGCPT,1),0) From GESECRAN #"PIECES COMPTABLES PROVISOIRES SUPPRIMEES"
     Call ECR_TRACE("    "+string$(len(mess(119,GML_MSGCPT,1)),"="),0) From GESECRAN
     Local Integer LENTETE
    Endif
    Gosub LIST_PCE From TRTCPTINT2
   Endif
  Elsif fstat & fstat<>5
   # Erreur
  Endif

  $NEXT_PCE_NEW
 Next

 Filter [F:WLCA] Where evalue(L_REQ)&LNKSRC=9
 For [F:WLCA]
  Delete [WLCD] Where TYP=[F:WLCA]TYP & NUM=[F:WLCA]NUM
  If fstat
   GOK=0
  Endif
 Next
 Filter [F:WLCA]
 Delete [F:WLCA] Where evalue(L_REQ)&LNKSRC=9
 If fstat
  GOK=0
 Endif

 If GOK
  Commit
 Else
  Rollback
 Endif
 Filter [F:WLCA]

Return

#=============================================================================
$KILL_CONSTANTES
Return

#=============================================================================
$KILL_GLOBALES
Return

