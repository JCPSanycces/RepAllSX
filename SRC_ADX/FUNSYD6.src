#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################################################
# Gestion du forçage de synchronistion                   Créé le 22 février 2006
##########################################################################################################
##########################################################################################################
$ACTION
  #--- Actions liées au traitement standard 
  Case ACTION
    When "INIT"        : Gosub INIT
    When "OUVRE_BATCH" : Gosub INIT
    When "INIT_DIA"    : Gosub INIT_DIA
    When "CONTROLE"    : Gosub CONTROLE
    When "EXEC"        : Gosub EXEC
    When "TERMINE"     : Gosub TERMINE
    When Default
  Endcase
Return

##########################################################################################################
$INIT
  If GMODU(12) = 2 Then
    # En batch , il vaut mieux mettre onerrgo
    If GSERVEUR Then
      Onerrgo ERRBATCH
    Endif
    Gosub OUVRE
  Else
    #Le module Action commerciale n'est pas activé. Fonction inaccessible.
    GMESSAGE = mess(243,177,1)
    GERR = 2
    FIN = 1
    Return
  Endif
Return

##########################################################################################################
$INIT_DIA
Local Char SZREP(GLONREP)
Local Char SZSITE(GLONFCY)

  Raz [M:SYD6]
  #Recherche du représentant
  Raz SZREP
  Raz SZSITE
  Call PARAMUTIL("AUSCRMF",SZREP,GUSER,SZSITE) From SUBAUS
  If SZREP <> "" Then
    [M:SYD6]USER = GUSER
    Affzo [M:SYD6]USER
  Endif
  SZSITE = ""
  Call SITECRMDEF ("ACT", SZSITE) From CRM_UTIL
  GFCY = SZSITE
  Call GETDEV(GFCY) From DEVSUB
  [M:SYD6]TRTSOC = GSOCIETE
  Affzo [M:SYD6]TRTSOC
Return

##########################################################################################################
$CONTROLE
Return

##########################################################################################################
$EXEC
Global Char GSZREPSYNC(GLONREP)
Global Integer GITRACELEVEL

Local Char SZSITE(GLONFCY)
Local Integer INBRECORD
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IBSYPOK
Local Integer IBOK
Local Integer ICOUNT 
Local Integer IOK
Local Integer IBERROR
Local Integer IBTRTOK
Local Integer IBEXIST
Local Char SZCODE
Local Integer LERRCOD
Local Integer IINDICE
Local Char SZCOR(GLONCOR)
Local Char SZMESSAGE(250)
Local Integer INBTRTOK
Local Integer INBTRTKO
Local Integer IBOK

  Raz SZCOR
  Raz SZMESSAGE
  If [M:SYD6]FLGTRCDET = 2 Then
    GITRACELEVEL = 2
  Else
    GITRACELEVEL = 1
  Endif
  Raz GSZREPSYNC
  GSZREP = ""
  SZSITE = ""
  INBRECORD = 0
  IBSYPOK = 0
  IBOK = 0
  ICOUNT = 0
  IOK = 0
  IBERROR = 0
  IBEXIST = 0
  LERRCOD = 0
  IINDICE = 0
  If !GSERVEUR Then
    # Ouverture de la trace
    Call OUVRE_TRACE(mess(244,177,1)) From LECFIC 
    Call ECR_TRACE(" ", 0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"), 0) From GESECRAN 
    Call PRTSCR("SYD6", "SYD6", "", 0, 1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"), 0) From GESECRAN 
    Call ECR_TRACE(" ", 0) From GESECRAN 
  Endif
  #Recherche du représentant
  Call PARAMUTIL("AUSCRMF",GSZREPSYNC,[M]USER,SZSITE) From SUBAUS
  If GSZREPSYNC = "" Then
    Return
  Endif
  IBOK = 0
  #Vérification du paramétrage pour l'utilisateur on a un utilisateur On regarde son paramétrage
  Read [SYP]SYP0=[M:SYD6]USER
  If fstat = 0 Then
    IBSYPOK = 1
  Endif
  IBOK = 0
  If [M:SYD6]CORSYNCNT = 2 Then
    #On doit traiter les correspondants
    If [F:SYP]COROTKCRE = 2 or [F:SYP]COROTKUPD = 2 or [F:SYP]COROTKDLT = 2 Then
      IBOK = 1
    Endif
    If IBOK = 1 Then
      #Traitement des contacts
      Gosub TRTCNT
    Else
      #Aucun droit sur la synchronisation des correspondants
      Call ECR_TRACE(mess(385,177,1), 0) From GESECRAN
    Endif
  Endif
  IBOK = 0
  If [M:SYD6]SELCOR = 2 Then
    #On doit traiter les taches
    If [F:SYP]COROTKCRE = 2 or [F:SYP]COROTKUPD = 2 or [F:SYP]COROTKDLT = 2 Then
      IBOK = 1
    Endif
    If IBOK = 1 Then
      #Traitement des contacts
      Gosub TRTCOR
    Else
      #Aucun droit sur la synchronisation des correspondants
      Call ECR_TRACE(mess(385,177,1), 0) From GESECRAN
    Endif
  Endif
  IBOK = 0
  If [M:SYD6]CORSYNREP = 2 Then
    #On doit traiter les taches
    If [F:SYP]COROTKCRE = 2 or [F:SYP]COROTKUPD = 2 or [F:SYP]COROTKDLT = 2 Then
      IBOK = 1
    Endif
    If IBOK = 1 Then
      #Traitement des contacts
      Gosub TRTREP
    Else
      #Aucun droit sur la synchronisation des correspondants
      Call ECR_TRACE(mess(385,177,1), 0) From GESECRAN
    Endif
  Endif
  IBOK = 0
  If [M:SYD6]SELTSK = 2 Then
    #On doit traiter les taches
    If [F:SYP]TSKOTKCRE = 2 or [F:SYP]TSKOTKUPD = 2 or [F:SYP]TSKOTKDLT = 2 Then
      IBOK = 1
    Endif
    If IBOK = 1 Then
      #Traitement des taches
      Gosub TRTTSK
    Else
      #Aucun droit sur la synchronisation des tâches
      Call ECR_TRACE(mess(386,177,1), 0) From GESECRAN
    Endif
  Endif
  IBOK = 0
  If [M:SYD6]SELCLL = 2 Then
    #On doit traiter les appels
    If [F:SYP]CLLOTKCRE = 2 or [F:SYP]CLLOTKUPD = 2 or [F:SYP]CLLOTKDLT = 2 Then
      IBOK = 1
    Endif
    If IBOK = 1 Then
      #Traitement des taches
      Gosub TRTCLL
    Else
      #Aucun droit sur la synchronisation des appels
      Call ECR_TRACE(mess(387,177,1), 0) From GESECRAN
    Endif
  Endif
  IBOK = 0
  If [M:SYD6]SELBAP = 2 Then
    #On doit traiter les rendez-vous
    If [F:SYP]BAPOTKCRE = 2 or [F:SYP]BAPOTKUPD = 2 or [F:SYP]BAPOTKDLT = 2 Then
      IBOK = 1
    Endif
    If IBOK = 1 Then
      #Traitement des rendez-vous
      Gosub TRTBAP
    Else
      #Aucun droit sur la synchronisation des rendez-vous
      Call ECR_TRACE(mess(388,177,1), 0) From GESECRAN
    Endif
  Endif    
Return

##########################################################################################################
$TRTCNT
Local Char SZWHERE(250)
Local Char SZWHERECNT(250)
Local Char SAVBPCNUM(GLONBPR)

  LERRCOD = 0
  INBTRTOK = 0
  INBTRTKO = 0
  Raz SZWHERE
  If !clalev([F:BPC6]) : Local File BPCUSTOMER [BPC6] : Endif
  If !clalev([F:BPD6]) : Local File BPDLVCUST [BPD6] : Endif    # FGR 06/08/2010 : X3SUIVI65524
  If !clalev([F:AIN6]) : Local File CONTACTCRM [AIN6] : Endif
  If !clalev([F:CNT6]) : Local File CONTACT [CNT6] : Endif
  If !clalev([F:COR6]) : Local File CORRESPOND [COR6] : Endif
  If !clalev([F:BPA6]) : Local File BPADDRESS [BPA6] : Endif
  #Traitement de génération à partir des contacts
  Call ECR_TRACE(mess(306,177,1),0) From GESECRAN
  # FGR 06/08/2010 : X3SUIVI66575 : un abrégé ne DOIT plus excéder 4 caractères
  #Link [CNT6] With [BPC6]BPC0=[F:CNT6]BPANUM As [BPCCNT] Where [F:CNT6]BPATYP = 1
  #Link [CNT6] With [BPC6]BPC0=[F:CNT6]BPANUM As [LBPC] Where [F:CNT6]BPATYP = 1
  # FGR 06/08/2010 : X3SUIVI65524
  Link [BPD6] With [BPC6]BPC0=[F:BPD6]BPCNUM As [LBPC]
  #
  SZWHERE = "(find(GSZREPSYNC,[F:BPC6]REP)<>0 or find(GSZREPSYNC,[F:BPD6]REP)<>0)"
  #
  If [M]CORBPRMIN <> "" Then
    SZWHERE = SZWHERE - "and [F:BPC6]BPCNUM>=[M:SYD6]CORBPRMIN"
  Endif
  If [M]CORBPRMAX <> "" Then
    SZWHERE = SZWHERE - "and [F:BPC6]BPCNUM<=[M:SYD6]CORBPRMAX"
  Endif
  If [M]CORCNTFCT <> 0 Then
    SZWHERECNT = "[F:CNT6]CNTFNC=[M:SYD6]CORCNTFCT"
  Else
    SZWHERECNT = "1=1"
  Endif
  #
  Raz SAVBPCNUM
  Filter [LBPC] Where evalue(SZWHERE) Order By [F:BPC6]BPCNUM
  If !GSERVEUR Then
    INBRECORDTRT = rowcount([LBPC])
    #Traitement des contacts
    Call OUVRE_BOITE(mess(310,177,1), INBRECORDTRT) From GESECRAN
    Call ECR_TRACE(num$(INBRECORDTRT) - mess(389,177,1), 0) From GESECRAN
  Endif
  For [LBPC]
    If !GSERVEUR Then
      ICOUNT += 1
      Call AFF_BOITE ([F:BPC6]BPCNUM, ICOUNT, IOK) From GESECRAN
    Endif
    If SAVBPCNUM <> [F:BPC6]BPCNUM Then
      # Un même client peut revenir plusieurs fois à cause de [BPD]. Pas la peine de le traiter plus d'une fois
      SAVBPCNUM = [F:BPC6]BPCNUM
      #------------------------------------------------------------------------------------------------
      Filter [CNT6] Where [F:CNT6]BPANUM = [F:BPC6]BPCNUM and [F:CNT6]BPATYP = 1 and evalue(SZWHERECNT)
      For [CNT6]
        If !GSERVEUR Then
          Call AFF_BOITE ([F:BPC6]BPCNUM + "/" + [F:CNT6]CCNCRM, ICOUNT, IOK) From GESECRAN
        Endif
        #------------------------------------------------------------------------------------------------
        #Traitement du contact +" : "+[F:BPC6]BPCNUM + "/" + [F:CNT6]CCNCRM
        Call ECR_TRACE(mess(311,177,1) - ":" - [F:BPC6]BPCNUM + "/" + [F:CNT6]CCNCRM, 0) From GESECRAN
        IBERROR = 0
        IBTRTOK = 1
        #Recherche si contact déjà créé en correspondant
        SZCODE = ""
        IBEXIST = 1
        Call COREXIST ([F:BPC6]BPCNUM, [F:CNT6]CCNCRM, SZCODE, IERRINF, ICHAPTER, IBRETOUR) From SUBCORB
        If IBRETOUR = 0 Then
          #Problème
          IBERROR = 1
          Call ECR_TRACE(mess(IERRINF,ICHAPTER,1), 1) From GESECRAN
        Endif
        If IBERROR = 0 Then
          If SZCODE <> "" Then
            # On a déjà un enregistrement dans CORRESPOND
            # Il faut voir s'il est répertorié pour ce représentant
            Call CORREPEXIST(SZCODE, GSZREPSYNC, IBEXIST, IERRINF, ICHAPTER, IBRETOUR) From SUBCORB
            If IBRETOUR = 0 Then
              IBERROR = 1
              Call ECR_TRACE(mess(IERRINF,ICHAPTER,1), 1) From GESECRAN
            Endif
            If IBERROR = 0 Then
              If IBEXIST = 0 Then
                #Il faut créer
                Call DEBTRANS From GLOCK
                Trbegin [SYD]
                Call CORREPCRE(SZCODE, GSZREPSYNC, IERRINF, ICHAPTER, IBRETOUR) From SUBCORB
                If IBRETOUR = 0 Then
                  IBERROR = 1
                  Call ECR_TRACE(mess(IERRINF,ICHAPTER,1), 1) From GESECRAN
                Endif
                If IBERROR = 1 Then
                  Rollback
                Else
                  Commit
                Endif 
              Endif
            Endif
            # FGR 25/03/2010 : X3SUIVI63506 (début)
            Read [AIN6]AIN0=[F:CNT6]CCNCRM
            If fstat <> 0 Then
              IBERROR = 1
              #Erreur lors de la lecture de l'interlocuteur +" : " +[F:CNT6]CCNCRM
              Call ECR_TRACE(mess(313,177,1) - ":" - [F:CNT6]CCNCRM, 1) From GESECRAN
            Endif
            If [F:CNT6]BPAADD <> "" Then
              # Si le code adresse est indiqué sur le contact : on le prend
              Read [BPA6]BPA0=[F:CNT6]BPATYP;[F:CNT6]BPANUM;[F:CNT6]BPAADD
              If fstat <> 0 Then
                IBERROR = 1
                #Erreur lors de la lecture de l'adresse - ":" - num$([F:CNT6]BPATYP)+" / " + [F:CNT6]BPANUM + "/ "+[F:CNT6]BPAADD
                Call ECR_TRACE(mess(314,177,1) - ":" - num$([F:CNT6]BPATYP) - "/" - [F:CNT6]BPANUM - "/" - [F:CNT6]BPAADD, 1) From GESECRAN
              Endif
            Else
              # Sinon on prend l'adresse par défaut du tiers
              INBRECORD = 0
              For [BPA6] Where [F:BPA6]BPATYP = [F:CNT6]BPATYP and [F:BPA6]BPANUM = [F:CNT6]BPANUM and [F:BPA6]BPAADDFLG = 2
                INBRECORD += 1
                Break
              Next
              If INBRECORD = 0 Then
                IBERROR = 1
                #Problème avec adresse par défaut
                #Erreur lors de la lecture de l'adresse par défaut  - ":" - num$([F:CNT6]BPATYP) - "/" - [F:CNT6]BPANUM
                Call ECR_TRACE(mess(315,177,1) - ":" - num$([F:CNT6]BPATYP) - "/" - [F:CNT6]BPANUM, 1) From GESECRAN
              Endif
            Endif
            If IBERROR = 0 Then
              #Rq: transaction géré dans la fonction avec commit ou rollback       
              Call UPDCOR("FUNSYD6CNT", 1, 0, SZCODE, LERRCOD) From SUBCORCM
              If LERRCOD <> 0 Then
                #Problème
                IBERROR = 1
                #Erreur lors de la création du correspondant+" BPCNUM=" +[F:CNT6]BPANUM+" / CNTNUM=" + [F:CNT6]CCNCRM
                Call ECR_TRACE(mess(318,177,1) - "(b) BPCNUM=" - [F:CNT6]BPANUM - "/ CNTNUM=" - [F:CNT6]CCNCRM, 1) From GESECRAN
              Endif
            Endif
            # FGR 25/03/2010 : X3SUIVI63506 (fin)
          Else
            # On n'a pas d'enregistrement dans CORRESPOND, il faut le créer
            Read [AIN6]AIN0=[F:CNT6]CCNCRM
            If fstat <> 0 Then
              IBERROR = 1
              #Erreur lors de la lecture de l'interlocuteur +" : " +[F:CNT6]CCNCRM
              Call ECR_TRACE(mess(313,177,1) - ":" - [F:CNT6]CCNCRM, 1) From GESECRAN
            Endif
            If [F:CNT6]BPAADD<> "" Then
              # Si le code adresse est indiqué sur le contact : on le prend
              Read [BPA6]BPA0=[F:CNT6]BPATYP;[F:CNT6]BPANUM;[F:CNT6]BPAADD
              If fstat <> 0 Then
                IBERROR = 1
                #Erreur lors de la lecture de l'adresse - ":" - num$([F:CNT6]BPATYP)+" / " + [F:CNT6]BPANUM + "/ "+[F:CNT6]BPAADD
                Call ECR_TRACE(mess(314,177,1) - ":" - num$([F:CNT6]BPATYP) - "/" - [F:CNT6]BPANUM - "/" - [F:CNT6]BPAADD,1) From GESECRAN
              Endif
            Else
              # Sinon on prend l'adresse par défaut du tiers
              INBRECORD = 0
              For [BPA6] Where [F:BPA6]BPATYP = [F:CNT6]BPATYP and [F:BPA6]BPANUM = [F:CNT6]BPANUM and [F:BPA6]BPAADDFLG = 2
                INBRECORD += 1
                Break
              Next
              If INBRECORD = 0 Then
                IBERROR = 1
                #Problème avec adresse par défaut
                #Erreur lors de la lecture de l'adresse par défaut  - ":" - num$([F:CNT6]BPATYP) - "/" - [F:CNT6]BPANUM
                Call ECR_TRACE(mess(315,177,1) - ":" - num$([F:CNT6]BPATYP) - "/" - [F:CNT6]BPANUM, 1) From GESECRAN
              Endif
            Endif
            If IBERROR = 0 Then
              #Rq: transaction géré dans la fonction avec commit ou rollback       
              Call CRECOR("FUNSYD6CNT", 1, 0, SZCODE, LERRCOD) From SUBCORCC
              If LERRCOD <> 0 Then
                #Problème
                IBERROR = 1
                #Erreur lors de la création du correspondant+" BPCNUM=" +[F:CNT6]BPANUM+" / CNTNUM=" + [F:CNT6]CCNCRM
                Call ECR_TRACE(mess(318,177,1) - "(a) BPCNUM=" - [F:CNT6]BPANUM - "/ CNTNUM=" - [F:CNT6]CCNCRM, 1) From GESECRAN
              Endif
            Endif
          Endif
        Endif
        Call DEBTRANS From GLOCK
        Trbegin [SYD]
        If IBERROR = 0 Then
          INBRECORD = 0
          Filter [SYD] Where [F:SYD]SYDUSR = [M]USER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = SZCODE and [F:SYD]SYDGEN = 0
          For [SYD]SYD1
            INBRECORD += 1
            If [F:SYD]SYDATTTYP <> "A" Then
              Readlock [SYD]Curr
              If fstat = 0 Then
                [F:SYD]SYDATTTYP = "R"
                [F:SYD]SYDOTKSTA = 1
                [F:SYD]SYDUPD = 0
                [F:SYD]SYDDAT = date$
                [F:SYD]SYDHOU = time$
                [F:SYD]UPDUSR= GUSER
                [F:SYD]UPDDAT = date$
                Rewrite [SYD]
                If fstat <> 0 Then
                  IBERROR = 1
                  #Erreur lors de la modification des données de synchronisation pour le correspondant - ":" -  SZCODE
                  Call ECR_TRACE(mess(280,177,1) - ":" - SZCODE, 1) From GESECRAN
                  Break
                Endif
              Else
                IBERROR = 1
                #Impossible de locker les données de synchronisation pour le correspondant - ":" -  SZCODE
                Call ECR_TRACE(mess(281,177,1) - ":" - SZCODE, 1) From GESECRAN
                Break
              Endif
            Endif
          Next
          Filter [SYD]
          If INBRECORD = 0 and IBERROR = 0 Then
            #On n'a pas de données de synchro, il faut créer
            Call SYDWRITE ([M]USER, "", SZCODE,"COR", "R" ,1, 0,0, IERRINF,ICHAPTER,IBRETOUR) From SUBSYDB
            If IBRETOUR = 0 Then
              #Erreur lors de l'écriture des données de synchronisation pour le correspondant - ":" - SZCODE 
              Call ECR_TRACE(mess(282,177,1) - ":" - SZCODE, 1) From GESECRAN
              IBERROR = 1
            Endif
          Endif
        Endif
        If IBERROR = 1 Then
          IBTRTOK = 0
        Endif
        If adxlog Then
          If IBERROR = 1 Then
            Rollback
          Else
            Commit
          Endif
        Endif
        If IBTRTOK = 0 Then
          #Anomalie lors du forçage du contact - ":" - [F:BPC6]BPCNUM + "/" + [F:CNT6]CCNCRM
          Call ECR_TRACE(mess(390,177,1) - ":" - [F:BPC6]BPCNUM + "/" + [F:CNT6]CCNCRM, -1) From GESECRAN
          INBTRTKO += 1
        Else
          #Forçage réussi pour le contact - ":" - [F:BPC6]BPCNUM + "/" + [F:CNT6]CCNCRM
          Call ECR_TRACE(mess(391,177,1) - ":" - [F:BPC6]BPCNUM + "/" + [F:CNT6]CCNCRM, 0) From GESECRAN
          INBTRTOK += 1
        Endif
        #------------------------------------------------------------------------------------------------
      Next           # [FNT6]
      Filter [CNT6]
      #------------------------------------------------------------------------------------------------
    Endif
  Next
  Filter [LBPC]  # FGR 06/08/2010 : X3SUIVI66575 
  Call ECR_TRACE(num$(INBRECORDTRT) - mess(389,177,1), 0) From GESECRAN  #num$(INBRECORDTRT) tâches à traiter
  Call ECR_TRACE(num$(INBTRTOK) - mess(392,177,1), 0) From GESECRAN      #num$(INBTRTOK)+" " + contacts forcés
  Call ECR_TRACE(num$(INBTRTKO) - mess(393,177,1), 0) From GESECRAN      #num$(INBTRTKO)+" " + forçages de contacts en échec
  Call ECR_TRACE(mess(316,177,1), 0) From GESECRAN                       #Fin du traitement des contacts
Return

##########################################################################################################
$OLD_TRTCNT
Local Char SZWHERE(250)

  LERRCOD = 0
  INBTRTOK = 0
  INBTRTKO = 0
  Raz SZWHERE
  If !clalev([F:BPC6]) : Local File BPCUSTOMER [BPC6] : Endif
  If !clalev([F:AIN6]) : Local File CONTACTCRM [AIN6] : Endif
  If !clalev([F:CNT6]) : Local File CONTACT [CNT6] : Endif
  If !clalev([F:COR6]) : Local File CORRESPOND [COR6] : Endif
  If !clalev([F:BPA6]) : Local File BPADDRESS [BPA6] : Endif
  #Traitement de génération à partir des contacts
  Call ECR_TRACE(mess(306,177,1),0) From GESECRAN
  # FGR 06/08/2010 : X3SUIVI66575 : un abrégé ne DOIT plus excéder 4 caractères
  #Link [CNT6] With [BPC6]BPC0=[F:CNT6]BPANUM As [BPCCNT] Where [F:CNT6]BPATYP = 1
  Link [CNT6] With [BPC6]BPC0=[F:CNT6]BPANUM As [LBPC] Where [F:CNT6]BPATYP = 1
  #
  SZWHERE = "find(GSZREPSYNC,[F:BPC6]REP)<>0 "
  #
  If [M]CORBPRMIN <> "" Then
    SZWHERE = SZWHERE - "and [F:BPC6]BPCNUM>=[M:SYD6]CORBPRMIN"
  Endif
  If [M]CORBPRMAX <> "" Then
    SZWHERE = SZWHERE - "and [F:BPC6]BPCNUM<=[M:SYD6]CORBPRMAX"
  Endif
  If [M]CORCNTFCT <> 0 Then
    SZWHERE = SZWHERE - "and [F:CNT6]CNTFNC=[M:SYD6]CORCNTFCT"
  Endif
  #
  Filter [LBPC] Where evalue(SZWHERE)
  If !GSERVEUR Then
    INBRECORDTRT = rowcount([LBPC])
    #Traitement des contacts
    Call OUVRE_BOITE(mess(310,177,1), INBRECORDTRT) From GESECRAN
    Call ECR_TRACE(num$(INBRECORDTRT) - mess(389,177,1), 0) From GESECRAN
  Endif
  For [LBPC]
    If !GSERVEUR Then
      ICOUNT += 1
      Call AFF_BOITE ([F:BPC6]BPCNUM + "/" + [F:CNT6]CCNCRM, ICOUNT, IOK) From GESECRAN
    Endif
    #Traitement du contact +" : "+[F:BPC6]BPCNUM + "/" + [F:CNT6]CCNCRM
    Call ECR_TRACE(mess(311,177,1) - ":" - [F:BPC6]BPCNUM + "/" + [F:CNT6]CCNCRM, 0) From GESECRAN
    IBERROR = 0
    IBTRTOK = 1
    #Recherche si contact déjà créé en correspondant
    SZCODE = ""
    IBEXIST = 1
    Call COREXIST ([F:BPC6]BPCNUM, [F:CNT6]CCNCRM, SZCODE, IERRINF, ICHAPTER, IBRETOUR) From SUBCORB
    If IBRETOUR = 0 Then
      #Problème
      IBERROR = 1
      Call ECR_TRACE(mess(IERRINF,ICHAPTER,1), 1) From GESECRAN
    Endif
    If IBERROR = 0 Then
      If SZCODE <> "" Then
        # On a déjà un enregistrement dans CORRESPOND
        # Il faut voir s'il est répertorié pour ce représentant
        Call CORREPEXIST(SZCODE, GSZREPSYNC, IBEXIST, IERRINF, ICHAPTER, IBRETOUR) From SUBCORB
        If IBRETOUR = 0 Then
          IBERROR = 1
          Call ECR_TRACE(mess(IERRINF,ICHAPTER,1), 1) From GESECRAN
        Endif
        If IBERROR = 0 Then
          If IBEXIST = 0 Then
            #Il faut créer
            Call DEBTRANS From GLOCK
            Trbegin [SYD]
            Call CORREPCRE(SZCODE, GSZREPSYNC, IERRINF, ICHAPTER, IBRETOUR) From SUBCORB
            If IBRETOUR = 0 Then
              IBERROR = 1
              Call ECR_TRACE(mess(IERRINF,ICHAPTER,1), 1) From GESECRAN
            Endif
            If IBERROR = 1 Then
              Rollback
            Else
              Commit
            Endif 
          Endif
        Endif
        # FGR 25/03/2010 : X3SUIVI63506 (début)
        Read [AIN6]AIN0=[F:CNT6]CCNCRM
        If fstat <> 0 Then
          IBERROR = 1
          #Erreur lors de la lecture de l'interlocuteur +" : " +[F:CNT6]CCNCRM
          Call ECR_TRACE(mess(313,177,1) - ":" - [F:CNT6]CCNCRM, 1) From GESECRAN
        Endif
        If [F:CNT6]BPAADD <> "" Then
          # Si le code adresse est indiqué sur le contact : on le prend
          Read [BPA6]BPA0=[F:CNT6]BPATYP;[F:CNT6]BPANUM;[F:CNT6]BPAADD
          If fstat <> 0 Then
            IBERROR = 1
            #Erreur lors de la lecture de l'adresse - ":" - num$([F:CNT6]BPATYP)+" / " + [F:CNT6]BPANUM + "/ "+[F:CNT6]BPAADD
            Call ECR_TRACE(mess(314,177,1) - ":" - num$([F:CNT6]BPATYP) - "/" - [F:CNT6]BPANUM - "/" - [F:CNT6]BPAADD, 1) From GESECRAN
          Endif
        Else
          # Sinon on prend l'adresse par défaut du tiers
          INBRECORD = 0
          For [BPA6] Where [F:BPA6]BPATYP = [F:CNT6]BPATYP and [F:BPA6]BPANUM = [F:CNT6]BPANUM and [F:BPA6]BPAADDFLG = 2
            INBRECORD += 1
            Break
          Next
          If INBRECORD = 0 Then
            IBERROR = 1
            #Problème avec adresse par défaut
            #Erreur lors de la lecture de l'adresse par défaut  - ":" - num$([F:CNT6]BPATYP) - "/" - [F:CNT6]BPANUM
            Call ECR_TRACE(mess(315,177,1) - ":" - num$([F:CNT6]BPATYP) - "/" - [F:CNT6]BPANUM, 1) From GESECRAN
          Endif
        Endif
        If IBERROR = 0 Then
          #Rq: transaction géré dans la fonction avec commit ou rollback       
          Call UPDCOR("FUNSYD6CNT", 1, 0, SZCODE, LERRCOD) From SUBCORCM
          If LERRCOD <> 0 Then
            #Problème
            IBERROR = 1
            #Erreur lors de la création du correspondant+" BPCNUM=" +[F:CNT6]BPANUM+" / CNTNUM=" + [F:CNT6]CCNCRM
            Call ECR_TRACE(mess(318,177,1) - "(b) BPCNUM=" - [F:CNT6]BPANUM - "/ CNTNUM=" - [F:CNT6]CCNCRM, 1) From GESECRAN
          Endif
        Endif
        # FGR 25/03/2010 : X3SUIVI63506 (fin)
      Else
        # On n'a pas d'enregistrement dans CORRESPOND, il faut le créer
        Read [AIN6]AIN0=[F:CNT6]CCNCRM
        If fstat <> 0 Then
          IBERROR = 1
          #Erreur lors de la lecture de l'interlocuteur +" : " +[F:CNT6]CCNCRM
          Call ECR_TRACE(mess(313,177,1) - ":" - [F:CNT6]CCNCRM, 1) From GESECRAN
        Endif
        If [F:CNT6]BPAADD<> "" Then
          # Si le code adresse est indiqué sur le contact : on le prend
          Read [BPA6]BPA0=[F:CNT6]BPATYP;[F:CNT6]BPANUM;[F:CNT6]BPAADD
          If fstat <> 0 Then
            IBERROR = 1
            #Erreur lors de la lecture de l'adresse - ":" - num$([F:CNT6]BPATYP)+" / " + [F:CNT6]BPANUM + "/ "+[F:CNT6]BPAADD
            Call ECR_TRACE(mess(314,177,1) - ":" - num$([F:CNT6]BPATYP) - "/" - [F:CNT6]BPANUM - "/" - [F:CNT6]BPAADD,1) From GESECRAN
          Endif
        Else
          # Sinon on prend l'adresse par défaut du tiers
          INBRECORD = 0
          For [BPA6] Where [F:BPA6]BPATYP = [F:CNT6]BPATYP and [F:BPA6]BPANUM = [F:CNT6]BPANUM and [F:BPA6]BPAADDFLG = 2
            INBRECORD += 1
            Break
          Next
          If INBRECORD = 0 Then
            IBERROR = 1
            #Problème avec adresse par défaut
            #Erreur lors de la lecture de l'adresse par défaut  - ":" - num$([F:CNT6]BPATYP) - "/" - [F:CNT6]BPANUM
            Call ECR_TRACE(mess(315,177,1) - ":" - num$([F:CNT6]BPATYP) - "/" - [F:CNT6]BPANUM, 1) From GESECRAN
          Endif
        Endif
        If IBERROR = 0 Then
          #Rq: transaction géré dans la fonction avec commit ou rollback       
          Call CRECOR("FUNSYD6CNT", 1, 0, SZCODE, LERRCOD) From SUBCORCC
          If LERRCOD <> 0 Then
            #Problème
            IBERROR = 1
            #Erreur lors de la création du correspondant+" BPCNUM=" +[F:CNT6]BPANUM+" / CNTNUM=" + [F:CNT6]CCNCRM
            Call ECR_TRACE(mess(318,177,1) - "(a) BPCNUM=" - [F:CNT6]BPANUM - "/ CNTNUM=" - [F:CNT6]CCNCRM, 1) From GESECRAN
          Endif
        Endif
      Endif
    Endif
    Call DEBTRANS From GLOCK
    Trbegin [SYD]
    If IBERROR = 0 Then
      INBRECORD = 0
      Filter [SYD] Where [F:SYD]SYDUSR = [M]USER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = SZCODE and [F:SYD]SYDGEN = 0
      For [SYD]SYD1
        INBRECORD += 1
        If [F:SYD]SYDATTTYP <> "A" Then
          Readlock [SYD]Curr
          If fstat = 0 Then
            [F:SYD]SYDATTTYP = "R"
            [F:SYD]SYDOTKSTA = 1
            [F:SYD]SYDUPD = 0
            [F:SYD]SYDDAT = date$
            [F:SYD]SYDHOU = time$
            [F:SYD]UPDUSR= GUSER
            [F:SYD]UPDDAT = date$
            Rewrite [SYD]
            If fstat <> 0 Then
              IBERROR = 1
              #Erreur lors de la modification des données de synchronisation pour le correspondant - ":" -  SZCODE
              Call ECR_TRACE(mess(280,177,1) - ":" - SZCODE, 1) From GESECRAN
              Break
            Endif
          Else
            IBERROR = 1
            #Impossible de locker les données de synchronisation pour le correspondant - ":" -  SZCODE
            Call ECR_TRACE(mess(281,177,1) - ":" - SZCODE, 1) From GESECRAN
            Break
          Endif
        Endif
      Next
      Filter [SYD]
      If INBRECORD = 0 and IBERROR = 0 Then
        #On n'a pas de données de synchro, il faut créer
        Call SYDWRITE ([M]USER, "", SZCODE,"COR", "R" ,1, 0,0, IERRINF,ICHAPTER,IBRETOUR) From SUBSYDB
        If IBRETOUR = 0 Then
          #Erreur lors de l'écriture des données de synchronisation pour le correspondant - ":" - SZCODE 
          Call ECR_TRACE(mess(282,177,1) - ":" - SZCODE, 1) From GESECRAN
          IBERROR = 1
        Endif
      Endif
    Endif
    If IBERROR = 1 Then
      IBTRTOK = 0
    Endif
    If adxlog Then
      If IBERROR = 1 Then
        Rollback
      Else
        Commit
      Endif
    Endif
    If IBTRTOK = 0 Then
      #Anomalie lors du forçage du contact - ":" - [F:BPC6]BPCNUM + "/" + [F:CNT6]CCNCRM
      Call ECR_TRACE(mess(390,177,1) - ":" - [F:BPC6]BPCNUM + "/" + [F:CNT6]CCNCRM, -1) From GESECRAN
      INBTRTKO += 1
    Else
      #Forçage réussi pour le contact - ":" - [F:BPC6]BPCNUM + "/" + [F:CNT6]CCNCRM
      Call ECR_TRACE(mess(391,177,1) - ":" - [F:BPC6]BPCNUM + "/" + [F:CNT6]CCNCRM, 0) From GESECRAN
      INBTRTOK += 1
    Endif
  Next
  Filter [LBPC]  # FGR 06/08/2010 : X3SUIVI66575 
  Call ECR_TRACE(num$(INBRECORDTRT) - mess(389,177,1), 0) From GESECRAN  #num$(INBRECORDTRT) tâches à traiter
  Call ECR_TRACE(num$(INBTRTOK) - mess(392,177,1), 0) From GESECRAN      #num$(INBTRTOK)+" " + contacts forcés
  Call ECR_TRACE(num$(INBTRTKO) - mess(393,177,1), 0) From GESECRAN      #num$(INBTRTKO)+" " + forçages de contacts en échec
  Call ECR_TRACE(mess(316,177,1), 0) From GESECRAN                       #Fin du traitement des contacts
Return

##########################################################################################################
$TRTCOR
Local Char SZWHERE(250)

  LERRCOD = 0
  INBTRTOK = 0
  INBTRTKO = 0
  Call ECR_TRACE(mess(307,177,1), 0) From GESECRAN  #Traitement des correspondants
  Raz SZWHERE
  If !clalev([F:COR6]) : Local File CORRESPOND [COR6] : Endif
  If !clalev([F:COP6]) : Local File CORREP[COP6] : Endif
  #
  Link [COP6] With [COR6]COR0 = [F:COP6]COPNUM As [LKCO]
  SZWHERE = "[F:COP6]COPREP = GSZREPSYNC and [F:COR6]CORNUM <> ''"
  If [M]CORMIN <> "" Then
    SZWHERE = SZWHERE - "and [F:COR6]CORNUM >= [M:SYD6]CORMIN"
  Endif
  If [M]CORMAX<> "" Then
    SZWHERE = SZWHERE - "and [F:COR6]CORNUM <= [M:SYD6]CORMAX"
  Endif
  Filter [LKCO] Where evalue (SZWHERE)
  If !GSERVEUR Then
    INBRECORDTRT = rowcount([LKCO])
    Call OUVRE_BOITE(mess(307,177,1), INBRECORDTRT) From GESECRAN           #Traitement des correspondants
    Call ECR_TRACE(num$(INBRECORDTRT) - mess(396,177,1), 0) From GESECRAN    #num$(INBRECORDTRT) correspondants à traiter
  Endif
  For [LKCO]
    If !GSERVEUR Then
      ICOUNT += 1
      Call AFF_BOITE ([F:COR6]CORNUM, ICOUNT, IOK) From GESECRAN
    Endif
    IBERROR = 0
    IBTRTOK = 1
    Gosub FORCEONECOR
    If IBTRTOK = 0 Then
      #Anomalie lors du forçage du correspondant - ":" -  [F:COR6]CORNUM
      Call ECR_TRACE(mess(398,177,1) - ":" - [F:COR6]CORNUM, -1) From GESECRAN
      INBTRTKO += 1
    Else
      #Forçage réussi pour le correspondant - ":" -  [F:COR6]CORNUM
      Call ECR_TRACE(mess(399,177,1) - ":" - [F:COR6]CORNUM, 0) From GESECRAN
      INBTRTOK += 1
    Endif 
  Next
  Call ECR_TRACE(num$(INBRECORDTRT) - mess(396,177,1), 0) From GESECRAN  #num$(INBRECORDTRT) correspondants à traiter
  Call ECR_TRACE(num$(INBTRTOK) - mess(400,177,1),0 ) From GESECRAN      #num$(INBTRTOK)+" " + correspondants forcés
  Call ECR_TRACE(num$(INBTRTKO) - mess(401,177,1), 0) From GESECRAN      #num$(INBTRTKO)+" " + forçages de correspondants en échec
  Call ECR_TRACE(mess(309,177,1), 0) From GESECRAN                       #Fin du traitement des correspondants
Return

##########################################################################################################
$FORCEONECOR
  Call UPDCOR("FUNSYD6", GITRACELEVEL, 0, [F:COR6]CORNUM, LERRCOD) From SUBCORCM
  Call DEBTRANS From GLOCK
  Trbegin [SYD]
  If LERRCOD = 0 Then
    INBRECORD = 0
    Filter [SYD] Where [F:SYD]SYDUSR = [M]USER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = [F:COR6]CORNUM and [F:SYD]SYDGEN = 0
    For [SYD]SYD1
      INBRECORD += 1
      If [F:SYD]SYDATTTYP <> "A" Then
        Readlock [SYD]Curr
        If fstat = 0 Then
          [F:SYD]SYDATTTYP = "R"
          [F:SYD]SYDOTKSTA = 1
          [F:SYD]SYDUPD = 0
          [F:SYD]SYDDAT = date$
          [F:SYD]SYDHOU = time$
          [F:SYD]UPDUSR = GUSER
          [F:SYD]UPDDAT = date$
          Rewrite [SYD]
          If fstat <> 0 Then
            IBERROR = 1
            #Erreur lors de la modification des données de synchronisation pour le correspondant - ":" -  [F:COR6]CORNUM
            Call ECR_TRACE(mess(280,177,1) - ":" - [F:COR6]CORNUM, 1) From GESECRAN
            Break
          Endif
        Else
          IBERROR = 1
          #Impossible de locker les données de synchronisation pour le correspondant - ":" -  [F:COR6]CORNUM
          Call ECR_TRACE(mess(281,177,1) - ":" - [F:COR6]CORNUM, 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    Filter [SYD]
    If INBRECORD = 0 and IBERROR = 0 Then
      #On n'a pas de données de synchro, il faut créer
      Call SYDWRITE([M]USER, "", [F:COR6]CORNUM,"COR", "R" ,1, 0, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
      If IBRETOUR = 0 Then
        #Erreur lors de l'écriture des données de synchronisation pour le correspondant - ":" - [F:COR6]CORNUM
        Call ECR_TRACE(mess(282,177,1) - ":" - [F:COR6]CORNUM, 1) From GESECRAN
        IBERROR = 1
      Endif
    Endif
    If IBERROR = 1 Then
      IBTRTOK = 0
    Endif
  Else
    IBTRTOK = 0
    #Forçage impossible. Le correspondant + [F:COR6]CORNUM + n'est pas valide.
    Call ECR_TRACE(mess(397,177,1) - [F:COR6]CORNUM - mess(368,177,1), 1) From GESECRAN
    Delete [SYD] Where [F:SYD]SYDUSR = [M]USER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = [F:COR6]CORNUM
    If fstat <> 0 Then
      #Erreur lors de la suppression des données de synchronisation pour le correspondant - ":" - [F:COR6]CORNUM
      Call ECR_TRACE(mess(284,177,1) - ":" - [F:COR6]CORNUM, 1) From GESECRAN
      IBERROR = 1
    Endif
  Endif
  If adxlog Then
    If IBERROR = 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
Return

##########################################################################################################
$TRTREP
Local Char SZWHERE(250)
Local Char SZAND(6)

  LERRCOD = 0
  INBTRTOK = 0
  INBTRTKO = 0
  Raz SZWHERE
  Raz SZAND
  If !clalev([F:REP6]) : Local File SALESREP [REP6] : Endif
  If !clalev([F:COR6]) : Local File CORRESPOND [COR6] : Endif
  #Traitement de génération à partir des représentants
  Call ECR_TRACE(mess(335,177,1), 0) From GESECRAN
  If[M]CORREPMIN <> "" Then
    SZWHERE = SZWHERE - SZAND - "[F:REP6]REPNUM>=[M:SYD6]CORREPMIN"
    SZAND = " AND "
  Endif
  If [M]CORREPMAX <> "" Then
    SZWHERE = SZWHERE - SZAND - "[F:REP6]REPNUM<=[M:SYD6]CORREPMAX"
    SZAND = " AND "
  Endif
  If SZWHERE <> "" Then
    Filter [REP6] Where evalue(SZWHERE)
  Else
    Filter [REP6] 
  Endif
  If !GSERVEUR  Then
    INBRECORDTRT = rowcount([REP6])
    #Traitement des représentants
    Call OUVRE_BOITE(mess(336,177,1), INBRECORDTRT) From GESECRAN
    #num$(INBRECORDTRT) représentants à traiter
    Call ECR_TRACE(num$(INBRECORDTRT) - mess(407,177,1), 0) From GESECRAN
  Endif
  For [REP6]
    If !GSERVEUR Then
      ICOUNT += 1
      Call AFF_BOITE ([F:REP6]REPNUM + "/" + [F:REP6]REPNAM, ICOUNT, IOK) From GESECRAN
    Endif
    IBERROR = 0
    IBTRTOK = 1
    #Traitement du représentant  - ":" - [F:REP6]REPNUM
    Call ECR_TRACE(mess(337,177,1) - ":" - [F:REP6]REPNUM, 0) From GESECRAN  
    Gosub FORCEONEREP
    If IBTRTOK = 0 Then
      #Anomalie lors du forçage du représentant - ":" -  [F:REP6]REPNUM
      Call ECR_TRACE(mess(408,177,1) - ":" - [F:REP6]REPNUM, -1) From GESECRAN
      INBTRTKO += 1
    Else
      #Forçage réussi pour le représentant - ":" -  [F:REP6]REPNUM
      Call ECR_TRACE(mess(409,177,1) - ":" - [F:REP6]REPNUM, 0) From GESECRAN
      INBTRTOK += 1
    Endif
  Next
  Call ECR_TRACE(num$(INBRECORDTRT) - mess(407,177,1), 0) From GESECRAN  #num$(INBRECORDTRT) représentants à traiter
  Call ECR_TRACE(num$(INBTRTOK) - mess(410,177,1), 0) From GESECRAN      #num$(INBTRTOK)+" " + représentants forcés
  Call ECR_TRACE(num$(INBTRTKO) - mess(411,177,1), 0) From GESECRAN      #num$(INBTRTKO)+" " + forçages de représentants en échec
  Call ECR_TRACE(mess(338,177,1), 0) From GESECRAN                       #Fin du traitement des représentants
Return

##########################################################################################################
$FORCEONEREP
  #Recherche si contact déjà créé en correspondant
  Raz SZCOR
  Call CORGEREREP (GSZREPSYNC, [F:REP6]REPNUM, SZCOR, IERRINF, ICHAPTER, IBRETOUR) From SUBCORB
  If IBRETOUR = 0 Then
    SZMESSAGE = mess(IERRINF,ICHAPTER,1) - "([F:REP6]REPNUM=" + [F:REP6]REPNUM + ")"
    Call ECR_TRACE(SZMESSAGE, 1) From GESECRAN
    IBTRTOK = 0
    IBERROR = 1
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [SYD]
  If IBERROR = 0 Then
    INBRECORD = 0
    Filter [SYD] Where [F:SYD]SYDUSR = [M]USER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = SZCOR and [F:SYD]SYDGEN = 0
    For [SYD]SYD1
      INBRECORD += 1
      If [F:SYD]SYDATTTYP <> "A" Then
        Readlock [SYD]Curr
        If fstat = 0 Then
          [F:SYD]SYDATTTYP = "R"
          [F:SYD]SYDOTKSTA = 1
          [F:SYD]SYDUPD = 0
          [F:SYD]SYDDAT = date$
          [F:SYD]SYDHOU = time$
          [F:SYD]UPDUSR = GUSER
          [F:SYD]UPDDAT = date$
          Rewrite [SYD]
          If fstat <> 0 Then
            IBERROR = 1
            #Erreur lors de la modification des données de synchronisation pour le correspondant - ":" -  SZCOR
            Call ECR_TRACE(mess(280,177,1) - ":" - SZCOR, 1) From GESECRAN
            Break
          Endif
        Else
          IBERROR = 1
          #Impossible de locker les données de synchronisation pour le correspondant - ":" -  SZCOR
          Call ECR_TRACE(mess(281,177,1) - ":" - SZCOR, 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    Filter [SYD]
    If INBRECORD = 0 and IBERROR = 0 Then
      #On n'a pas de données de synchro, il faut créer
      Call SYDWRITE ([M]USER, "", SZCOR, "COR", "R" , 1, 0, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
      If IBRETOUR = 0 Then
        #Erreur lors de l'écriture des données de synchronisation pour le correspondant - ":" - SZCOR
        Call ECR_TRACE(mess(282,177,1) - ":" - SZCOR, 1) From GESECRAN
        IBERROR = 1
      Endif
    Endif
    If IBERROR = 1 Then
      IBTRTOK = 0
    Endif
  Else
    IBTRTOK = 0
    #Forçage impossible. Le correspondant + SZCOR + n'est pas valide.
    Call ECR_TRACE(mess(397,177,1) - SZCOR - mess(368,177,1), 1) From GESECRAN
    Delete [SYD] Where [F:SYD]SYDUSR = [M]USER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = SZCOR
    If fstat <> 0 Then
      #Erreur lors de la suppression des données de synchronisation pour le correspondant - ":" - [F:COR6]CORNUM
      Call ECR_TRACE(mess(284,177,1) - ":" - SZCOR, 1) From GESECRAN
      IBERROR = 1
    Endif
  Endif
  If adxlog Then
    If IBERROR = 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
Return

##########################################################################################################
$TRTTSK
Local Char SZWHERE(250)

  LERRCOD = 0
  INBTRTOK = 0
  INBTRTKO = 0
  Raz SZWHERE
  If !clalev([F:TSK6]) : Local File TASK [TSK6] : Endif
  If !clalev([F:COR6]) : Local File CORRESPOND [COR6] : Endif
  #Traitement des tâches
  Call ECR_TRACE(mess(245,177,1), 0) From GESECRAN
  SZWHERE = "[F:TSK6]TSKREP = GSZREPSYNC"
  If [M]TSKDATDEB <> [00/00/00] Then
    SZWHERE = SZWHERE - "and [F:TSK6]TSKSTR>=[M:SYD6]TSKDATDEB"
  Endif
  If [M]TSKDATFIN <> [00/00/00] Then
    SZWHERE = SZWHERE - "and [F:TSK6]TSKSTR<=[M:SYD6]TSKDATFIN"
  Endif
  If [M]TSKECHDEB <> [00/00/00] Then
    SZWHERE = SZWHERE - "and [F:TSK6]TSKDAT>=[M:SYD6]TSKECHDEB"
  Endif
  If [M]TSKECHFIN <> [00/00/00] Then
   SZWHERE = SZWHERE - "and [F:TSK6]TSKDAT<=[M:SYD6]TSKECHFIN"
  Endif
  Filter [TSK6] Where evalue(SZWHERE)
  If !GSERVEUR  Then
    INBRECORDTRT = rowcount([TSK6])
    #Traitement des tâches
    Call OUVRE_BOITE(mess(245,177,1), INBRECORDTRT) From GESECRAN
    #num$(INBRECORDTRT) tâches à traiter
    Call ECR_TRACE(num$(INBRECORDTRT) - mess(373,177,1), 0) From GESECRAN
  Endif
  For [TSK6]
    If !GSERVEUR Then
      ICOUNT += 1
      Call AFF_BOITE ([F:TSK6]TSKNUM, ICOUNT, IOK) From GESECRAN
    Endif
    IBERROR = 0
    IBTRTOK = 1
    Call UPDTSK("FUNSYD6", GITRACELEVEL, 0, [F:TSK6]TSKNUM, LERRCOD) From SUBTSKCM
    Call DEBTRANS From GLOCK
    Trbegin [SYD]
    If LERRCOD = 0 Then
      INBRECORD = 0
      Filter [SYD] Where [F:SYD]SYDUSR = [M]USER and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDKEY = [F:TSK6]TSKNUM and [F:SYD]SYDGEN = 0
      For [SYD]SYD1
        INBRECORD += 1
        If [F:SYD]SYDATTTYP <> "A" Then
          Readlock [SYD]Curr
          If fstat = 0 Then
            [F:SYD]SYDATTTYP = "R"
            [F:SYD]SYDOTKSTA = 1
            [F:SYD]SYDUPD = 0
            [F:SYD]SYDDAT = date$
            [F:SYD]SYDHOU = time$
            [F:SYD]UPDUSR= GUSER
            [F:SYD]UPDDAT = date$
            Rewrite [SYD]
            If fstat <> 0 Then
              IBERROR = 1
              #Erreur lors de la modification des données de synchronisation pour la tâche - ":" -  [F:TSK6]TSKNUM
              Call ECR_TRACE(mess(235,177,1) - ":" - [F:TSK6]TSKNUM, 1) From GESECRAN
              Break
            Endif
          Else
            IBERROR = 1
            #Impossible de locké les données de synchronisation pour la tâche - ":" -  [F:TSK6]TSKNUM
            Call ECR_TRACE(mess(236,177,1) - ":" - [F:TSK6]TSKNUM, 1) From GESECRAN
            Break
          Endif
        Endif
      Next
      Filter [SYD]
      If INBRECORD = 0 and IBERROR = 0 Then
        #On n'a pas de données de synchro, il faut créer
        Call SYDWRITE ([M]USER, [F:TSK]SALFCY, [F:TSK6]TSKNUM,"TSK", "R" ,1, 0, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
        If IBRETOUR = 0 Then
          #Erreur lors de l'écriture des données de synchronisation pour la tâche - ":" - [F:TSK6]TSKNUM
          Call ECR_TRACE(mess(237,177,1) - ":" - [F:TSK6]TSKNUM, 1) From GESECRAN
          IBERROR = 1
        Endif
      Endif
      If IBERROR = 1 Then
        IBTRTOK = 0
      Endif
    Else
      IBTRTOK = 0
      #Forçage impossible. La tâche + [F:TSK6]TSKNUM + n'est pas valide.
      Call ECR_TRACE(mess(367,177,1) - [F:TSK6]TSKNUM - mess(368,177,1),1) From GESECRAN
      Delete [SYD] Where [F:SYD]SYDUSR = [M]USER and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDKEY = [F:TSK6]TSKNUM
      If fstat <> 0 Then
        #Erreur lors de la suppression des données de synchronisation pour la tâche
        Call ECR_TRACE(mess(249,177,1) - ":" - [F:TSK6]TSKNUM, 1) From GESECRAN
        IBERROR = 1
      Endif
    Endif
    If adxlog Then
      If IBERROR = 1 Then
        Rollback
      Else
        Commit
      Endif
    Endif 
    If IBTRTOK = 0 Then
      #Anomalie lors du forçage de la tâche - ":" -  [F:TSK6]TSKNUM
      Call ECR_TRACE(mess(372,177,1) - ":" - [F:TSK6]TSKNUM, -1) From GESECRAN
      INBTRTKO += 1
    Else
      #Forçage réussi pour la tâche - ":" -  [F:TSK6]TSKNUM
      Call ECR_TRACE(mess(371,177,1) - ":" - [F:TSK6]TSKNUM, 0) From GESECRAN
      INBTRTOK += 1
    Endif
    If IBERROR = 0 Then
      If [M:SYD6]TSKFORCOR = 2 Then
        #Il faut aussi forcer le correspondant
        If [F:TSK6]TSKCOR <> "" Then
          Read [COR6]COR0=[F:TSK6]TSKCOR
          If fstat = 0 Then
            Gosub FORCEONECOR
            If IBTRTOK = 0 Then
              #Anomalie lors du forçage du correspondant - ":" -  [F:COR6]CORNUM
              Call ECR_TRACE(mess(398,177,1) - ":" - [F:COR6]CORNUM, -1) From GESECRAN
            Else
              #Forçage réussi pour le correspondant - ":" -  [F:COR6]CORNUM
              Call ECR_TRACE(mess(399,177,1) - ":" - [F:COR6]CORNUM, 0) From GESECRAN
            Endif 
          Else
            #Erreur lors de la lecture du correspondant - ":" -  [F:TSK6]TSKCOR
            Call ECR_TRACE(mess(271,177,1) - ":" - [F:TSK6]TSKCOR , 1) From GESECRAN
          Endif
        Endif
      Endif
    Endif
  Next
  Call ECR_TRACE(num$(INBRECORDTRT) - mess(373,177,1), 0) From GESECRAN   #num$(INBRECORDTRT) tâches à traiter
  Call ECR_TRACE(num$(INBTRTOK) - mess(374,177,1), 0) From GESECRAN       #num$(INBTRTOK)+" " + tâches forcées
  Call ECR_TRACE(num$(INBTRTKO) - mess(375,177,1), 0) From GESECRAN       #num$(INBTRTKO)+" " + forçages de tâches en échec
  Call ECR_TRACE(mess(247,177,1), 0) From GESECRAN                        #Fin du traitement des tâches
Return

##########################################################################################################
$TRTCLL
Local Char SZWHERE(250)

  #Traitement des appels
  LERRCOD = 0
  INBTRTOK = 0
  INBTRTKO = 0
  Raz SZWHERE
  If !clalev([F:CLL6]) : Local File PHONECALL [CLL6] : Endif
  If !clalev([F:COR6]) : Local File CORRESPOND [COR6] : Endif
  #Traitement des appels
  Call ECR_TRACE(mess(364,177,1), 0) From GESECRAN
  SZWHERE = "[F:CLL6]CLLREP = GSZREPSYNC"
  If [M]CLLDATDEB <> [00/00/00] Then
    SZWHERE = SZWHERE - "and [F:CLL6]CLLDAT>[M:SYD6]CLLDATDEB"
  Endif
  If [M]CLLDATFIN<>[00/00/00] Then
    SZWHERE = SZWHERE - "and [F:CLL6]CLLDAT<[M:SYD6]CLLDATFIN"
  Endif
  Filter [CLL6] Where evalue(SZWHERE)
  If !GSERVEUR  Then
    INBRECORDTRT = rowcount([CLL6])
    #Traitement des appels
    Call OUVRE_BOITE(mess(364,177,1), INBRECORDTRT) From GESECRAN
    #num$(INBRECORDTRT) appels à traiter
    Call ECR_TRACE(num$(INBRECORDTRT) - mess(379,177,1), 0) From GESECRAN   
  Endif
  For [CLL6]
    If !GSERVEUR Then
      ICOUNT += 1
      Call AFF_BOITE ([F:CLL6]CLLNUM, ICOUNT, IOK) From GESECRAN
    Endif
    IBERROR = 0
    IBTRTOK = 1
    Call UPDCLL("FUNSYD6", GITRACELEVEL, 0, [F:CLL6]CLLNUM, LERRCOD) From SUBCLLCM    
    Call DEBTRANS From GLOCK
    Trbegin [SYD]
    If LERRCOD = 0 Then
      INBRECORD = 0
      Filter [SYD] Where [F:SYD]SYDUSR = [M]USER and [F:SYD]SYDTYP = "CLL" and [F:SYD]SYDKEY = [F:CLL6]CLLNUM and [F:SYD]SYDGEN = 0
      For [SYD]SYD1
        INBRECORD += 1
        If [F:SYD]SYDATTTYP <> "A" Then
          Readlock [SYD]Curr
          If fstat = 0 Then
            [F:SYD]SYDATTTYP = "R"
            [F:SYD]SYDOTKSTA = 1
            [F:SYD]SYDUPD = 0
            [F:SYD]SYDDAT = date$
            [F:SYD]SYDHOU = time$
            [F:SYD]UPDUSR = GUSER
            [F:SYD]UPDDAT = date$
            Rewrite [SYD]
            If fstat <> 0 Then
              IBERROR = 1
              #Erreur lors de la modification des données de synchronisation pour l'appel - ":" -  [F:CLL6]CLLNUM
              Call ECR_TRACE(mess(356,177,1) - ":" - [F:CLL6]CLLNUM, 1) From GESECRAN
              Break
            Endif
          Else
            IBERROR = 1
            #Impossible de locker les données de synchronisation pour l'appel - ":" -  [F:CLL6]CLLNUM
            Call ECR_TRACE(mess(357,177,1) - ":" - [F:CLL6]CLLNUM, 1) From GESECRAN
            Break
          Endif
        Endif
      Next
      Filter [SYD]
      If INBRECORD = 0 and IBERROR = 0 Then
        #On n'a pas de données de synchro, il faut créer
        Call SYDWRITE ([M]USER, [F:CLL6]SALFCY, [F:CLL6]CLLNUM, "CLL", "R" , 1, 0, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
        If IBRETOUR = 0 Then
          #Erreur lors de l'écriture des données de synchronisation pour l'appel - ":" - [F:CLL6]CLLNUM
          Call ECR_TRACE(mess(358,177,1) - ":" - [F:CLL6]CLLNUM, 1) From GESECRAN
          IBERROR = 1
        Endif
      Endif
      If IBERROR = 1 Then
        IBTRTOK = 0
      Endif
    Else
      IBTRTOK = 0
      #Forçage impossible. L'appel + [F:CLL6]CLLNUM + n'est pas valide.
      Call ECR_TRACE(mess(380,177,1) - [F:CLL6]CLLNUM - mess(368,177,1), 1) From GESECRAN
      Delete [SYD] Where [F:SYD]SYDUSR = [M]USER and [F:SYD]SYDTYP = "TSK" and [F:SYD]SYDKEY = [F:CLL6]CLLNUM
      If fstat <> 0 Then
        #Erreur lors de la suppression des données de synchronisation pour l'appel - ":" - [F:CLL6]CLLNUM
        Call ECR_TRACE(mess(360,177,1) - ":" - [F:CLL6]CLLNUM, 1) From GESECRAN
        IBERROR = 1
      Endif
    Endif
    If adxlog Then
      If IBERROR = 1 Then
        Rollback
      Else
        Commit
      Endif
    Endif
    If IBTRTOK = 0 Then
      #Anomalie lors du forçage de l'appel - ":" -  [F:CLL6]CLLNUM
      Call ECR_TRACE(mess(383,177,1) - ":" - [F:CLL6]CLLNUM, -1) From GESECRAN
      INBTRTKO += 1
    Else
      #Forçage réussi pour l'appel - ":" -  [F:CLL6]CLLNUM
      Call ECR_TRACE(mess(384,177,1) - ":" - [F:CLL6]CLLNUM, 0) From GESECRAN
      INBTRTOK += 1
    Endif
    If IBERROR = 0 Then
      If [M:SYD6]CLLFORCOR = 2 Then
        #Il faut aussi forcer le correspondant
        If [F:CLL6]CLLCOR <> "" Then
          Read [COR6]COR0=[F:CLL6]CLLCOR
          If fstat = 0 Then
            Gosub FORCEONECOR
            If IBTRTOK = 0 Then
              #Anomalie lors du forçage du correspondant - ":" -  [F:COR6]CORNUM
              Call ECR_TRACE(mess(398,177,1) - ":" - [F:COR6]CORNUM, -1) From GESECRAN
            Else
              #Forçage réussi pour le correspondant - ":" -  [F:COR6]CORNUM
              Call ECR_TRACE(mess(399,177,1) - ":" - [F:COR6]CORNUM, 0) From GESECRAN
            Endif 
          Else
            #Erreur lors de la lecture du correspondant - ":" -  [F:CLL6]CLLCOR
            Call ECR_TRACE(mess(271,177,1) - ":" - [F:CLL6]CLLCOR, 1) From GESECRAN
          Endif
        Endif
      Endif
    Endif
  Next
  Call ECR_TRACE(num$(INBRECORDTRT) - mess(379,177,1), 0) From GESECRAN    #num$(INBRECORDTRT) appels à traiter
  Call ECR_TRACE(num$(INBTRTOK) - mess(381,177,1), 0) From GESECRAN        #num$(INBTRTOK)+" " + appels forcés
  Call ECR_TRACE(num$(INBTRTKO) - mess(382,177,1), 0) From GESECRAN        #num$(INBTRTKO)+" " + forçages d'appels en échec
  Call ECR_TRACE(mess(366,177,1), 0) From GESECRAN                         #Fin du traitement des appels
Return

##########################################################################################################
$TRTBAP
Local Char SZWHERE(250)

  LERRCOD = 0
  INBTRTOK = 0
  INBTRTKO = 0
  Raz SZWHERE
  If !clalev([F:BAP6]) : Local File BAPPOINT[BAP6] : Endif
  If !clalev([F:REP6]) : Local File SALESREP [REP6] : Endif
  If !clalev([F:COR6]) : Local File CORRESPOND [COR6] : Endif
  Call ECR_TRACE(mess(303,177,1), 0) From GESECRAN
  SZWHERE = "find(GSZREPSYNC,[F:BAP6]APTREPNUM)<> 0"
  If [M]BAPDATDEB <> [00/00/00] Then
    SZWHERE = SZWHERE - "and [F:BAP6]APTDAT>=[M:SYD6]BAPDATDEB"
  Endif
  If [M]BAPDATFIN <> [00/00/00] Then
    SZWHERE = SZWHERE - "and [F:BAP6]APTDATEND<=[M:SYD6]BAPDATFIN"
  Endif
  Filter [BAP6] Where evalue(SZWHERE)
  If !GSERVEUR  Then
    INBRECORDTRT = rowcount([BAP6])
    Call OUVRE_BOITE(mess(303,177,1), INBRECORDTRT) From GESECRAN
    #num$(INBRECORDTRT) rendez-vous à traiter
    Call ECR_TRACE(num$(INBRECORDTRT) - mess(402,177,1), 0) From GESECRAN
  Endif
  For [BAP6]
    If !GSERVEUR Then
      ICOUNT += 1
      Call AFF_BOITE ([F:BAP6]APTNUM, ICOUNT, IOK) From GESECRAN
    Endif
    IBERROR = 0
    IBTRTOK = 1
    Call UPDBAP("FUNSYD6", GITRACELEVEL, 0, [F:BAP6]APTNUM, LERRCOD) From SUBBAPCM
    Call DEBTRANS From GLOCK
    Trbegin [SYD]
    If LERRCOD = 0 Then
      INBRECORD = 0
      Filter [SYD] Where [F:SYD]SYDUSR = [M]USER and [F:SYD]SYDTYP = "BAP" and [F:SYD]SYDKEY = [F:BAP6]APTNUM and [F:SYD]SYDGEN = 0
      For [SYD]SYD1
        INBRECORD += 1
        If [F:SYD]SYDATTTYP <> "A" Then
          Readlock [SYD]Curr
          If fstat = 0 Then
            [F:SYD]SYDATTTYP = "R"
            [F:SYD]SYDOTKSTA = 1
            [F:SYD]SYDUPD = 0
            [F:SYD]SYDDAT = date$
            [F:SYD]SYDHOU = time$
            [F:SYD]UPDUSR= GUSER
            [F:SYD]UPDDAT = date$
            Rewrite [SYD]
            If fstat <> 0 Then
              IBERROR = 1
              #Erreur lors de la modification des données de synchronisation pour le rendez-vous - ":" -  [F:BAP6]APTNUM
              Call ECR_TRACE(mess(294,177,1) - ":" - [F:BAP6]APTNUM, 1) From GESECRAN
              Break
            Endif
          Else    
            IBERROR = 1
            #Impossible de locker les données de synchronisation pour le rendez-vous - ":" -  [F:BAP6]APTNUM
            Call ECR_TRACE(mess(295,177,1) - ":" - [F:BAP6]APTNUM, 1) From GESECRAN
            Break
          Endif
        Endif
      Next
      Filter [SYD]
      If INBRECORD = 0 and IBERROR = 0 Then
        #On n'a pas de données de synchro, il faut créer
        Call SYDWRITE ([M]USER, [F:BAP6]SALFCY, [F:BAP6]APTNUM, "BAP", "R" , 1, 0, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
        If IBRETOUR = 0 Then
          #Erreur lors de l'écriture des données de synchronisation pour le nouveau rendez-vous - ":" - [F:BAP6]APTNUM
          Call ECR_TRACE(mess(291,177,1) - ":" - [F:BAP6]APTNUM, 1) From GESECRAN
          IBERROR = 1
        Endif
      Endif
    Else
      IBTRTOK = 0
      #Forçage impossible. Le rendez-vous + [F:BAP6]APTNUM+ n'est pas valide.
      Call ECR_TRACE(mess(363,177,1) - [F:BAP6]APTNUM - mess(368,177,1), 1) From GESECRAN
      Delete [SYD] Where [F:SYD]SYDUSR = [M]USER and [F:SYD]SYDTYP = "BAP" and [F:SYD]SYDKEY = [F:BAP6]APTNUM
      If fstat <> 0 Then
        #Erreur lors de la suppression des données de synchronisation pour la tâche
        Call ECR_TRACE(mess(249,177,1) - ":" - [F:BAP6]APTNUM, 1) From GESECRAN
        IBERROR = 1
      Endif
      If IBERROR = 1 Then
        IBTRTOK = 0
      Endif
    Endif
    If adxlog Then
      If IBERROR = 1 Then
        Rollback
      Else
        Commit
      Endif
    Endif 
    If IBTRTOK = 0 Then
      #Anomalie lors du forçage du rendez-vous - ":" -  [F:BAP6]APTNUM
      Call ECR_TRACE(mess(403,177,1) - ":" - [F:BAP6]APTNUM, -1) From GESECRAN
      INBTRTKO += 1
    Else
      #Forçage réussi pour le rendez-vous - ":" -  [F:BAP6]APTNUM
      Call ECR_TRACE(mess(404,177,1) - ":" - [F:BAP6]APTNUM, 0) From GESECRAN
      INBTRTOK += 1
    Endif
    If IBERROR = 0 Then
      If [M:SYD6]BAPFORCOR = 2 Then
        IINDICE = 0
        While IINDICE < dim([F:BAP6]APTCOR)
          #Il faut aussi forcer le correspondant
          If [F:BAP6]APTCOR(IINDICE) <> "" Then
            Read [COR6]COR0=[F:BAP6]APTCOR(IINDICE)
            If fstat = 0 Then
              Gosub FORCEONECOR
              If IBTRTOK = 0 Then
                #Anomalie lors du forçage du correspondant - ":" -  [F:COR6]CORNUM
                Call ECR_TRACE(mess(398,177,1) - ":" - [F:COR6]CORNUM, -1) From GESECRAN
              Else
                #Forçage réussi pour le correspondant - ":" -  [F:COR6]CORNUM
                Call ECR_TRACE(mess(399,177,1) - ":" - [F:COR6]CORNUM, 0) From GESECRAN
              Endif 
            Else
              #Erreur lors de la lecture du correspondant - ":" -  [F:BAP6]APTCOR(IINDICE)
              Call ECR_TRACE(mess(271,177,1) - ":" - [F:BAP6]APTCOR(IINDICE), 1) From GESECRAN
            Endif
          Endif
          IINDICE += 1
        Wend
      Endif
    Endif
    If IBERROR = 0 Then
      If [M:SYD6]BAPFORREP = 2 Then
        IINDICE = 0
        While IINDICE < dim([F:BAP6]APTREPNUM)
          #Il faut aussi forcer le représentant
          If [F:BAP6]APTREPNUM(IINDICE) <> "" Then
            Read [REP6]REP0=[F:BAP6]APTREPNUM(IINDICE)
            If fstat = 0 Then
              Gosub FORCEONEREP
              If IBTRTOK = 0 Then
                #Anomalie lors du forçage du représentant - ":" -  [F:REP6]REPNUM
                Call ECR_TRACE(mess(408,177,1) - ":" - [F:REP6]REPNUM, -1) From GESECRAN
              Else
                #Forçage réussi pour le représentant - ":" -  [F:REP6]REPNUM
                Call ECR_TRACE(mess(409,177,1) - ":" - [F:REP6]REPNUM, 0) From GESECRAN
              Endif
            Else
              #Erreur lors de la lecture du représentant - ":" -  [F:BAP6]APTREPNUM(IINDICE)
              Call ECR_TRACE(mess(330,177,1) - ":" - [F:BAP6]APTREPNUM(IINDICE), 1) From GESECRAN
            Endif
          Endif
          IINDICE += 1
        Wend
      Endif
    Endif
  Next
  Call ECR_TRACE(num$(INBRECORDTRT) - mess(402,177,1), 0) From GESECRAN    #num$(INBRECORDTRT) rendez-vous à traiter
  Call ECR_TRACE(num$(INBTRTOK) - mess(405,177,1), 0) From GESECRAN        #num$(INBTRTOK)+" " + rendez-vous forcés
  Call ECR_TRACE(num$(INBTRTKO) - mess(406,177,1), 0) From GESECRAN        #num$(INBTRTKO)+" " + forçages de rendez-vous en échec
  Call ECR_TRACE(mess(305,177,1), 0) From GESECRAN                         #Fin du traitement des rendez-vous
Return

##########################################################################################################
$OUVRE
Local Char    TIT(50)

  TIT = mess(244,177,1) 
  #Ouvre les fichiers utilisés dans l'affichage des données de synchronisation
  If !clalev([F:SYP]) : Local File SYNCPAR [SYP] : Endif
  If !clalev([F:SYD]) : Local File SYNCDATA [SYD] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif  # FGR 19/10/2011 : X3SUIVI77229
Return

##########################################################################################################
$TERMINE
  If !GSERVEUR Then
    Call FERME_BOITE From GESECRAN
  Endif
  If !GSERVEUR Then
    Call FERME_TRACE From LECFIC
    TRA = 1
  Endif
Return

##########################################################################################################
$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl) - errm, 1) From GESECRAN
End

##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'une tâche.
#############################################################################
$TSK_SET_HEA_INFO
  #On ne modifie aucune valeur 
Return

##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'un appel
#############################################################################
$CLL_SET_HEA_INFO
  #On ne modifie aucune valeur 
Return

##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'un correspondant
#############################################################################
$COR_SET_HEA_INFO
  #On ne modifie aucune valeur 
  Case IMPZON
    When "LNA"
      #On affectele représentant de forcage
      [M:COR0]FORCAGEREP = GSZREPSYNC
  Endcase
Return

##########################################################################################################
$COR_SET_DET_INFO
  #On ne modifie aucune valeur 
Return

##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'un rendez-vous
#############################################################################
$BAP_SET_HEA_INFO
  #On ne modifie aucune valeur 
  Case IMPZON
    When "APTDAT"
      #On affectele représentant de forcage
      [M:BAP0]FORCAGEREP = GSZREPSYNC
  Endcase
Return

##########################################################################################################
$BAP_SET_DET_INFO
  #On ne modifie aucune valeur 
Return
