#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque UKAPPLEV1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRAPPLEV
mkstat = 0
zoncou = "NBRAPPLEV"
indice = 0
status = 1
zoncou = "NBRAPPLEV"
If varmode([M]NBRAPPLEV,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRAPPLEV" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRAPPLEV
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRAPPLEV = nolign
   status = 75
   Call SAI_NBRAPPLEV(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBRCURLEV
mkstat = 0
zoncou = "NBRCURLEV"
indice = 0
status = 1
zoncou = "NBRCURLEV"
If varmode([M]NBRCURLEV,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRCURLEV" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRCURLEV
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRCURLEV = nolign
   status = 75
   Call SAI_NBRCURLEV(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBRAPPLEV(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRAPPLEV
mkstat = 0
zoncou = "NBRAPPLEV"

## Zone NBRAPPLEV
mkstat = 0
zoncou = "NBRAPPLEV"

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRCURLEV(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRCURLEV
mkstat = 0
zoncou = "NBRCURLEV"

## Zone NBRCURLEV
mkstat = 0
zoncou = "NBRCURLEV"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "UKAPPLEV1"
Return

