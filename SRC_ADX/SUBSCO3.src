######################################################################################
# Issue 91501 GA 07/2013
Subprog C_NBDIE
If !find(status,1,4,5,20,21,26,92,93) | GIMPORT End : Endif
#----- Contrôle Sections d'entête obligatoires si saisissables -----#
# Issue 118457 - 2016-09-21 by MUARN : GHEADIE inutiles en SST
#If [M:SCO3]NBDIE>0 & GHEADIE=1
If [M:SCO3]NBDIE>0
  # Issue 98444 GA 06/2014
  If [F:ITM]ITMREF<>[M:SCO3]SRVITMREF
     Read [F:ITM]ITM0=[M:SCO3]SRVITMREF
  Endif
  Local Integer I,J
  For I=1 To [M:SCO3]NBDIE
    J=find([M:SCO3]DIE(I-1),GDIE(1..GNBDIE))
    Call CTRL_CCEH([M:SCO3]CCE(I-1),J,GFINRSP,[M:SCO1]RETDAT ) From TRTX3CPT
    If mkstat  Break : Endif
  Next I
Endif
End

Subprog D_CCE(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=find([M:SCO3]DIE(nolign-1),GDIE(1..GNBDIE)) : Gosub D_CCEX
End

Subprog AS_CCE(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=find([M:SCO3]DIE(nolign-1),GDIE(1..GNBDIE)) : Gosub AS_CCEX
End

Subprog C_CCE(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=find([M:SCO3]DIE(nolign-1),GDIE(1..GNBDIE)) : Gosub C_CCEX
End

$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE>GNBDIE Return : Endif
Call INIT_CCE(VALEUR,AXE,"SCS","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
If VALEUR="" Gosub D_CCEX Endif # Issue 91501 GA 07/2013
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,[M:SCO1]RETDAT) From TRTX3CPT
If GIMPORT & mkstat
  GMESSAGE-="-"-mess(18,197,1)-num$(nolign)-mess(80,197,1)-[M:SCO3]SRVITMREF
Endif
Return
