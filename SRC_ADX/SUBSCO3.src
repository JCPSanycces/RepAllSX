#<AdxTL>@(#)7.0.0.0 $Revision$
###########################################################################
## Traitement de l'onglet <Service> des Commandes Ss-traitance SUBSCO3   ##
###########################################################################
## selon SUBMFG3                                                         ##
###########################################################################
# 02/2007 dans SCOSRV CPNITMREF devient SRVITMREF                         #
#         et          LIKQTYCOD         STRQTYCOD                         #
###########################################################################

$ACTION
Case ACTION
 When "SUPLIG"       : Gosub SUPLIG
 When "AB3_SRVITMREF"   : Gosub AB3_SRVITMREF
 When "AB4_SRVITMREF"   : Gosub AB4_SRVITMREF
 When "AB5_SRVITMREF"   : Gosub AB5_SRVITMREF
 When "BB5_SRVITMREF"   : Gosub BB5_SRVITMREF
 When Default
Endcase
Return

########################################################################
$OUVRE
Global Integer OMODIF
Global Integer OSOLDE
Return

########################################################################
$FERME
Return

########################################################################
$APRES_MODIF
OMODIF=1
Call ITMUPDFLG
Return

###########################################################################
## Action technique de définition du filtre de lecture
$DEFLIG
FICLIG = "SCOSRV" : ABLIG = "SCS"
Return

###########################################################################
$RAZCRE
#----------------------------#
# Initialisation de la ligne #
#----------------------------#
# clé: cf INICRE_LIG à la validation
#
# Site de réception = Site de stockage par défaut
  [M:SCO3]PRHFCY = [M:SCO1]PRHFCY
#
# (ré)activation des zones qui ont pu être désactivées
  Gosub SCS_OPESTA_INI From SCOLIB
  Actzo [M:SCO3]OPESTA
#
#----- Chargement comptes et sections analytiques -----#
# Call CHARG_SCS_CPTANALIN(-1) From SCOCPTLIB # Issue 91501 GA 08/2013
#-----
# Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque : sections [M:SCO3]30
  Affzo [M:SCO3]10 : Affzo [M:SCO3]20 : Affzo [M:SCO3]40

# Issue X3-69383 - 2018-05-04 by MUARN : axe affiché
If dim([M:SCO3]FMTDIE)>0
  For I = 0 To dim([M:SCO3]FMTDIE)-1
    If [M:SCO3]FMTDIE(I)<>""
      If instr(1,[M:SCO3]FMTDIE(I),"P") >0
        Diszo [M:SCO3]CCE(I)
      Else
        Actzo [M:SCO3]CCE(I)
      Endif
    Else
      Actzo [M:SCO3]CCE(I)
    Endif
  Next I
Endif

Return

###########################################################################
$RAZDUP
# appelé par RAZDUP de SUBSCOA
[M:SCO3]POHNUM=""
[M:SCO3]POPLIN=0
[M:SCO3]POQSEQ=0
Actzo [M:SCO3]SRVITMREF, OPESTA, EXTSTRQTY, SCOPUU
# Issue X3-38230 - 2017-08-24 by MUARN : gestion des zones modifiables
Actzo [M:SCO3]OPESTUCOE, GROPRI
[M:SCO3]WIPNUM=""
[M:SCO3]WIPTYP=4             : # Encours SCx
[M:SCO3]WIPSTA=[M:SCO1]SCOSTA
[M:SCO3]RMNEXTQTY=[M:SCO3]EXTQTY       # FQ 51325
[M:SCO3]CPLQTY=0                       # FQ 51325
[M:SCO3]REJCPLQTY=0                    # FQ 51325
[M:SCO3]QUACPLQTY=0                    # FQ 51325
[M:SCO3]INVQTY=0                       # FQ 51325
[M:SCO3]STDQTY=0                       # FQ 51325
Raz [M:SCO3]OPESTR,OPEEND
# Issue 92532 GA 10/2013 Cancel price to recalculate only
If !GIMPORT & [M:SCO3]NETPRI<>0
    Local Integer WRET : WRET=1
    # Vous êtes en duplication : \ Désirez-vous recalculer les prix et remises ?
    Call OUINON(mess(50,191,1),WRET) From GESECRAN
    If WRET=2
      Raz [M:SCO3]NETPRI: Affzo [M:SCO3]NETPRI # FQ 73561
      Raz [M:SCO3]GROPRI: Affzo [M:SCO3]GROPRI # FQ 73561
      Raz [M:SCO3]REFPRI: Affzo [M:SCO3]REFPRI # FQ 73561
      Raz [M:SCO3]PRIREN: Affzo [M:SCO3]PRIREN # FQ 73561
      Raz [M:SCO3]LINAMT: Affzo [M:SCO3]LINAMT # FQ 73561
    #
      Raz [M:SCO3]CUR    : Affzo [M:SCO3]CUR      # FQ 74682
      Raz [M:SCO3]NETPRIL: Affzo [M:SCO3]NETPRIL  # FQ 74682
      Raz [M:SCO3]LINAMTL: Affzo [M:SCO3]LINAMTL  # FQ 74682
    #
      Raz [M:SCO3]CPLPRI : Affzo [M:SCO3]CPLPRI   # FQ 75944 raz ancienne valo
      Raz [M:SCO3]CPLCRG : Affzo [M:SCO3]CPLCRG   # FQ 75944 raz ancienne valo
    Endif
Endif
Raz [M:SCO3]UPDDAT,[M:SCO3]UPDUSR      # FQ 51325
Raz [M:SCO3]CREDAT,[M:SCO3]CREUSR      # Maj par WRITE_SCS From SCOLIB
Gosub SCS_OPESTA_INI From SCOLIB
# Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
Affzo [M:SCO3]1-99 #Affzo [M:SCO3]

# Issue X3-69383 - 2018-05-04 by MUARN : axe affiché
If dim([M:SCO3]FMTDIE)>0
  For I = 0 To dim([M:SCO3]FMTDIE)-1
    If [M:SCO3]FMTDIE(I)<>""
      If instr(1,[M:SCO3]FMTDIE(I),"P") >0
        Diszo [M:SCO3]CCE(I)
      Else
        Actzo [M:SCO3]CCE(I)
      Endif
    Else
      Actzo [M:SCO3]CCE(I)
    Endif
  Next I
Endif

Return


###########################################################################
$INICRE_LIG
#----------------------------#
# Avant le Write de la ligne #
#----------------------------#
# Insertion d'une nouvelle ligne: on renseigne toute la clé
  [F:SCS]SCONUM = [M:SCO0]SCONUM
  [F:SCS]SCILIN = [M:SCO1]SCILIN
  Call CALC_SCSLIN([M:SCO3]SCSLIN,0)
  [F:SCS]SCSLIN = [M:SCO3]SCSLIN
  [F:SCS]ITMREF = [M:SCO0]ITMREF
  [F:SCS]BOMALT = [M:SCO0]BOMALT
  [F:SCS]BOMSEQ = [M:SCO3]BOMSEQ
#
  [F:SCS]RMNEXTQTY=[M:SCO3]EXTQTY
#

  # Issue 111449 - 2015-10-29 by MUARN : REFPRI est alimenté par GROPRI en création
  If [F:SCO]CUR=GLOCALDEV
    [F:SCS]REFPRI=[F:SCS]GROPRI
  Else
    Local Integer  WRET
    Call COURMNT([F:SCO]CUR,GLOCALDEV,GLOCALDEV,[F:SCO]CHGTYP,[F:SCS]OPESTR,1,
&                  [F:SCS]GROPRI,[F:SCS]REFPRI,[F:SCO]CHGCOE,WRET) From TRTDEV
  Endif

  If [F:SCS]CPY = ""
     [F:SCS]CPY = GSOCIETE
  Endif
#
Return

###########################################################################
$INIMOD_LIG
#------------------------------#
# Avant le Rewrite de la ligne #
#------------------------------#
# Pb de synchro à cause de la clé sur 3 rubriques ?
  If  [M:SCO3]ITMREF <> [M:SCO0]ITMREF
      [F:SCS]ITMREF= [M:SCO0]ITMREF
  Endif
  If  [M:SCO3]BOMALT <> [M:SCO0]BOMALT
      [F:SCS]BOMALT = [M:SCO0]BOMALT
  Endif
#
# Clé d'unicité => pas de recalcul ...
# Issue 98583 GA 04/2014 Pb Mise à niveau au lancement d'EO
  If [M:SCO3]SCSLIN=0
    Call CALC_SCSLIN([M:SCO3]SCSLIN,0)
    [F:SCS]SCSLIN = [M:SCO3]SCSLIN
  Endif
#
  If [F:SCS]CPY = ""
     [F:SCS]CPY = GSOCIETE
  Endif
#
Return


###########################################################################
# appel en VERIF_CRE et VERIF_MOD sur l'objet SCO
$VERIF

Raz GMESSAGE
# Contrôles communs création/modification
Gosub COMPLETE_LIG

# Issue 85534 GA 11/2012 ctrl à (re)faire sur site de rcp (facultatif)
If [M:SCO3]PRHFCY <> "" & [M:SCO3]SRVITMREF <> ""
   # Issue 113031 - 2016-02-11 by MUARN : lecture ITM
   WFCY   =[M:SCO3]PRHFCY
   WITMREF=[M:SCO3]SRVITMREF
   Gosub READ_ITM From ITMLIB
   # End issue 113031
   # On recontrôle article/site
   Local Char WITMREF(GLONITM) : WITMREF=[M:SCO3]SRVITMREF
   Local Char WFCY   (GLONFCY) : WFCY=[M:SCO3]PRHFCY
   Gosub READ_ITF From ITMLIB
   If !GOK
     mkstat=1 : zonsui="[M:SCO1]PRHFCY"
     GERR=1 : mkstat=1 : Return
   Endif
Endif

If [M:SCO3]SRVITMREF = ""
   GMESSAGE = mess(510,199,1) : # Article de sous-traitance obligatoire
   zonsui="[M:SCO3]SRVITMREF"
   GERR=1 : mkstat=1
Endif
If [M:SCO3]OPESTR > [M:SCO3]OPEEND
   GMESSAGE = mess(106,177,1) : # La date de fin d'opération ne peut pas être inférieure à la date de début.
   zonsui="[M:SCO3]OPEEND"
   GERR=1 : mkstat=1 : Return
Endif
# Issue 85931 GA 11/2012 - revu GA 01/2013 selon nb décimales de SCOPUU
If clalev([F:TUN]) = 0 : Local File TABUNIT [TUN] : Endif
If [M:SCO3]SCOPUU <> "" & [M:SCO3]SCOPUU<>[F:TUN]UOM   # FQ 70409 GA 01/2011 PERFORMANCES ne pas relire si unité déjà lue
 Read [TUN]TUN0 = [M:SCO3]SCOPUU : If fstat Raz [F:TUN] Endif
Endif
Local Decimal WQTYMIN : WQTYMIN=10^-[F:TUN]UOMDEC
If [M:SCO3]EXTSTRQTY < WQTYMIN
   GMESSAGE = mess(436,194,1) : # La quantité de Service commandée ne peut être nulle
   zonsui="[M:SCO3]EXTSTRQTY"
   GERR=1 : mkstat=1
Endif
#
# FQ 67864 GA 10/2010 ne pas faire ce contrôle
#If find(GREP,"C","D") & [M:SCO3]OPESTR < date$
#   GMESSAGE = mess(114,199,1) : # La date ne doit pas être antérieure à la date du jour
#   zonsui="[M:SCO3]OPESTR"
#   GERR=1 : mkstat=1 : Return
#Endif

Return


###########################################################################
$COMPLETE_LIG

# Site de réception
  If [M:SCO3]PRHFCY=""
     [M:SCO3]PRHFCY = [M:SCO1]PRHFCY
     [F:SCS]PRHFCY  = [M:SCO1]PRHFCY
  Endif

  Local    Integer WOFS : WOFS=[M:SCO3]SCOLTI
  Call UPD_SRV_DAT(WOFS,[M:SCO3]OPESTR,[M:SCO3]OPEEND,0) From SCOLIB
  Affzo [M:SCO3]SCOLTI : Affzo [M:SCO3]OPESTR : Affzo [M:SCO3]OPEEND

# FQ 77636 GA 11/2011 buffer [F:SCS] vide, utiliser [M:SCO3]
# FQ 73561 GA 05/2011 maj du prix en création/duplication
  If [M:SCO3]NETPRI=0
     Call UPD_SRV_PRI(0) From SCOLIB
  Endif
  Gosub CALC_LINAMT_SCO3  From SCOLIB

#----- Chargement comptes et sections analytiques -----#
#  Call CHARG_SCS_CPTANALIN(-1) From SCOCPTLIB # Issue 91501 GA 08/2013 Ko écrase les valeurs saisies
 Gosub INIT_CCE_SCO3 From SCOCPTLIB
Return

###########################################################################
## Lecture des lignes
#########################################################################
$LIENS
Local Integer I : I=0
Local Integer L
#
# ----
# déjà fait dans SUBSCOA/LIENS:
# ne pas refaire ici sinon on perd les FMTDIE et FMTCOA
# Raz [M:SCO3]
# ----

  Read [SCS]SCS0=[M:SCO0]SCONUM;[M:SCO1]SCILIN
  [M:SCO3] = [M:SCO0]
  # Issue X3-69383 - 2018-05-04 by MUARN : Seul CUR pose problème sinon on perd FMTDIE
  #[M:SCO3] = [M:SCO1]  # pour CUR par exemple
  [M:SCO3]CUR = [M:SCO1]CUR
  [M:SCO3] = [F:SCS]

  # Issue 106083 - 2016-04-07 by MUARN : ne pas faire
  # Ctrl présence d'une ligne POF
  #Call FIND_POF From SUBSCO3
  # Issue X3-38230 - 2017-08-24 by MUARN : gestion des zones modifiables ou non si EO commandé
  If [M:SCO3]POHNUM=""
    Actzo [M:SCO3]SRVITMREF, OPESTA, EXTSTRQTY, SCOPUU, OPESTUCOE, GROPRI
  Else
    Diszo [M:SCO3]SRVITMREF, OPESTA, EXTSTRQTY, SCOPUU, OPESTUCOE, GROPRI
  Endif


# FQ 75630 GA 09/2011
#  If [M:SCO3]NETPRI=0
#     Call UPD_SRV_PRI(0) From SCOLIB
#  Endif

#
# Pas de saisie possible OPESTA si statut différent de
#     0=
#     1="En attente"
#     4="En-cours"

  If !find([M:SCO3]OPESTA,0,1,4)
    Diszo [M:SCO3]OPESTA
  Else
    Actzo [M:SCO3]OPESTA
  Endif

#----- Chargement comptes et sections analytiques -----#
  Call CHARG_SCS_CPTANALIN(-1) From SCOCPTLIB
#-----
  Affzo [M:SCO3]

  # Issue X3-69383 - 2018-05-04 by MUARN : axe affiché
  If dim([M:SCO3]FMTDIE)>0
    For I = 0 To dim([M:SCO3]FMTDIE)-1
      If [M:SCO3]FMTDIE(I)<>""
        If instr(1,[M:SCO3]FMTDIE(I),"P") >0
          Diszo [M:SCO3]CCE(I)
        Else
          Actzo [M:SCO3]CCE(I)
        Endif
      Else
        Actzo [M:SCO3]CCE(I)
      Endif
    Next I
  Endif

Return

###########################################################################
## Modification des lignes
#########################################################################
$MODIF
Local Integer I
Local Integer J : J=0
Local Integer L    : # pour sections analytiques
Local Integer WEXISTE
Local Integer WRET
#
  Gosub DEFLIG
#
  # GA 21/07/2005 un seul service pour le moment
  Readlock [SCS]SCS0=[M:SCO0]SCONUM;[M:SCO1]SCILIN
  If fstat = 1 : GOK=-1 : GLOCK="$SCOSRV" : Return : Endif
  If fstat = 5 : Raz [F:SCS] : Endif
#
  WEXISTE = fstat
  [F:SCS] = [M:SCO0] : [F:SCS] = [M:SCO1] : [F:SCS] = [M:SCO3]
#
  If    WEXISTE = 0
      # Maj d'une ligne
        Gosub INIMOD_LIG
#
      # Texte
        Call UPDATE_SCSTEX("U")
#
        If [M:SCO3]POHNUM=""
         # Mise à jour de l'encours sous-traitance SCx, sauf si déjà commandé
           Call UPDATE_SCX("M") From SCOLIB
        Endif
#
      #----- Ecriture des comptes et sections de la ligne de document -----#
        Call UPDATE_SCS_CPTANALIN ("M") From SCOCPTLIB : If GOK<1  Return : Endif

        Gosub REWRITE_SCS From SCOLIB
        If GOK<1 : Return : Endif
#
   Elsif WEXISTE = 5
      # Insertion d'une nouvelle ligne
        Gosub INICRE_LIG
#
      # Texte
        Call UPDATE_SCSTEX("C")
#
      # Mise à jour de l'encours sous-traitance
        Call UPDATE_SCX("C") From SCOLIB
#
      #----- Ecriture des comptes et sections de la ligne de document -----#
        Call UPDATE_SCS_CPTANALIN ("C") From SCOCPTLIB : If GOK<1  Return : Endif

        Gosub WRITE_SCS From SCOLIB
        If GOK<1 : Return : Endif
   Endif

   Affzo [SCO3]


Return


###########################################################################
## Création des opérations
#########################################################################
$CREATION
Local Integer I
Local Integer WRET
Local Char    XMSG(105)
Local Integer L
#
    Raz [F:SCS]
# GA 21/07/2005 un seul service pour le moment
    [F:SCS] = [M:SCO0] : [F:SCS] = [M:SCO1] : [F:SCS] = [M:SCO3]
#
  # on s'assure que la Cle soit entièrement renseignée
    Gosub INICRE_LIG
#
  # Texte
    Call UPDATE_SCSTEX("C")
#
  # Mise à jour de l'encours sous-traitance
    Call UPDATE_SCX("C") From SCOLIB
    If GOK<1 : Return : Endif   # Issue 88058 GA 02/2013
#
  #----- Ecriture des comptes et sections de la ligne de document -----#
    Call UPDATE_SCS_CPTANALIN ("C") From SCOCPTLIB : If GOK<1  Return : Endif

    Gosub WRITE_SCS From SCOLIB
    If GOK<1 : Return : Endif   # Issue 88058 GA 02/2013
#
Return

###########################################################################
## Annulation de toutes les lignes
#########################################################################
# purge des opérations
$ANNULE
#GA ici on peut laisser la boucle, même s'il n'y a qu'une opération
# annulation opérations
For [SCS]SCS0 Where SCONUM=[M:SCO0]SCONUM With Lock
#
# Texte
  Call UPDATE_SCSTEX("A")
#
#----- Suppression des comptes et sections de la ligne de document -----#
# ne pas planter en cas d'erreur
  Call UPDATE_SCS_CPTANALIN ("A") From SCOCPTLIB

  Gosub DELETE_SCS From SCOLIB
  If GOK < 1 : Break : Endif
Next
#
Return

$SUPLIG
#-----------------------------------------------------------#
# Avant Delete ou Rewrite de la ligne                       #
#-----------------------------------------------------------#
# not used ????
Return


#------------------------------------------------------------------------#
# Pour forcer le flag update des lignes articles lancés  extrait SUBMFGB #
#------------------------------------------------------------------------#
Subprog ITMUPDFLG
Local Integer I
#
If find(GREP,"C","D") : End : Endif
#
#For  I=0 To [M:SCO1]NBLIG-1
#    [M:SCO1]UPDFLG=1
#Next I
[M:SCO3]UPDFLG = 1
#
End

########################################
Subprog CALC_SCSLIN(LSCSLIN,NOL)
Variable Decimal  LSCSLIN
Value    Shortint NOL
### GA 21/07/2005 un seul service pour le moment
### initialisation selon le paramètre BOMSTE
### If !GIMPORT
###    If NOL> 1
###        LSCSLIN = [M:SCO3]SCSLIN(NOL-2) + GBOMSTE
###    Else
        LSCSLIN = 5 # FQ 54710 GA 23/04/2009 avant GBOMSTE
###    Endif
### Endif
End

########################################
# Boutons/Menus contextuels
########################################
Subprog IB_SRVITMREF
Local Integer I, NBITM
# boutons
If [M:SCO3]SRVITMREF <> ""
#
# Maj du service autorisée ? cf Menu local 2228
  If [M:SCO3]OPESTA<2 & dim(GDEFEORTYP)>0 & find(GDEFEORTYP,3,4)
     GBOUT2  = mess(293,195,1)   :  # Choix d'un service
  Else
    Raz GBOUT2
  Endif
#
  GBOUT3  = mess(4,198,1)   :  # Article-Site
#
  If [M:SCO3]POHNUM<> ""
  # GA: voir SUBPTH / IB_NBLIG et AB1_NBLIG
     If [M:SCO3]POHTYP=2
       GBOUT4 = mess(00244,00197,1) :  # Demande de livraison
     Else
       GBOUT4 = mess(00010,00159,1)-[M:SCO3]POHNUM :  # Commande
     Endif
  Else
    Raz GBOUT4
  Endif
#
  If [M:SCO3]WIPNUM<> ""
    GBOUT5 = mess(00238,00198,1) :  # Encours
  Else
    Raz GBOUT5
  Endif
#
  GBOUT8  = mess(350,194,1) :  # Situation sous-traitance
  GBOUT9  = mess(59,197,1)  :  # Coût sous-traitance
  GBOUT10 = mess(38,198,1)  :  # Texte
Endif
End

$AB3_SRVITMREF
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1 (GLONVCR)
Local Char     WCLE2 (GLONVCR)
  # Article-Site
  WOBJET="ITF"
  WCLE1 =[M:SCO3]PRHFCY
  WCLE2 =[M:SCO3]SRVITMREF
Return

$AB4_SRVITMREF
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1 (GLONVCR)
Local Char     WCLE2 (GLONVCR)
# GA: voir SUBPTH / IB_NBLIG et AB1_NBLIG
If [M:SCO3]POHTYP = 2
# demande de livraison
  WOBJET="POD"
  WCLE1 =num$([M:SCO3]POPLIN)
  WCLE2 =[M:SCO3]POHNUM
Else
# commande d'achat standard
  WOBJET="POH"
  WCLE1 =[M:SCO3]POHNUM
  WCLE2 =""
Endif
Return

$AB5_SRVITMREF
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1 (GLONVCR)
Local Char     WCLE2 (GLONVCR)
  # encours
  WOBJET="WIP" : # sélection des besoins
  WCLE1 =[M:SCO3]WIPNUM
  WCLE2 =""
# Le filtre ci-dessus ne fonctionne pas car 3 rubriques de clé
  GWIPTYP = [M:SCO3]WIPTYP
  GWIPNUM = [M:SCO3]WIPNUM
  GITMREF = [M:SCO3]SRVITMREF
#
Return

$BB5_SRVITMREF
# Après bouton, raz des globales
  Raz GWIPTYP,  GWIPNUM ,  GITMREF
#
Return


Subprog AS_SRVITMREF(VALEUR)
Variable Char    VALEUR()
# Site nécessaire pour filtrer la liste des articles
If [M:SCO3]PRHFCY="" : [M:SCO3]PRHFCY=[M:SCO1]PRHFCY : Endif
End

Subprog C_SRVITMREF(VALEUR)
Variable Char    VALEUR()
# Issue 113089-150 - 2016-09-19 by SR : ne servent pas
#Local Char     WFCY (GLONFCY)
#Local Integer  I

# Issue 113089-150 - 2016-09-15 by MUARN : article réceptionnable
# Pas d'article non réceptionnable
If [F:ITM]RCPFLG <> 2 : GMESSAGE=mess(99,194,1)  : mkstat = 2 : End : Endif
# Pas d'article non livrable en inter-site
If [M:SCO0]BETFCY = 2
  If [F:ITM]DLVFLG <> 2 : GMESSAGE=mess(865,197,1) : mkstat = 2 : End : Endif
Endif
End


Subprog AM_SRVITMREF(VALEUR)
Variable Char    VALEUR()
#
If VALEUR<>[M:SCO3]SRVITMREF & [M:SCO3]SRVITMREF<>""
#  si changt d'article, raz des zones de prix pour relire le tarif
   Raz [M:SCO3]GROPRI,PRIREN,NETPRI,LINAMT,REFPRI
   Affzo [M:SCO3]GROPRI,PRIREN,NETPRI,LINAMT,REFPRI
Endif


  Filter [BOD] Where ITMREF=[M:SCO0]ITMREF
&                and BOMALT=[M:SCO0]BOMALT and BOMALTTYP=3
&                and CPNITMREF=VALEUR and CPNTYP=7
&              Order By Key CLE=BOMSTRDAT Desc ; BOMENDDAT Desc
  Read   [BOD] First
  If fstat : Raz [F:BOD] : Endif
  Filter [BOD]
# ATTENTION: Service invalide à la date de commande
  If ([F:BOD]BOMENDDAT <> [0/0/0] & [F:BOD]BOMENDDAT < [M:SCO1]ORDDAT )
&  | ([F:BOD]BOMSTRDAT <> [0/0/0] & [F:BOD]BOMSTRDAT > [M:SCO1]ORDDAT )
    # "Service invalide à la date de commande !!!"
    GMESSAGE=mess(536,199,1) : Goto RETOURITMREF
  Endif

# charge les infos complémentaires # FQ 74682 GA 07/2011 + BPRNUM
  Call CHARGE_SCO3_FROM_BOS([M:SCO0]ITMREF,[M:SCO0]BPRNUM,[M:SCO0]BOMALT,VALEUR,0) From SUBSCOA
#-----
  # FQ 74682 GA 07/2011 + BPRNUM
  Call RECH_SCO3_SRVITMREF(VALEUR, [M:SCO0]ITMREF,[M:SCO0]BPRNUM)
  If mkstat Goto RETOURITMREF : Endif

  # Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
  #Affzo [SCO3]
End
#----- Retour à la saisie de la référence article -----#
$RETOURITMREF
mkstat=1 : VALEUR=""
End


########################################
Subprog D_SCOPUU(VALEUR)
Variable Char    VALEUR()
#
Read [ITM]ITM0=[M:SCO3]SRVITMREF
If !fstat : VALEUR = [F:ITM]PUU : Endif
#
End

Subprog AM_SCOPUU(VALEUR)
Variable Char    VALEUR()
  # Issue 77611 GA 11/2012
  If VALEUR=[M:SCO3]OPESTU [M:SCO3]OPESTRCOE=1
  Else                 Raz [M:SCO3]OPESTRCOE
  Endif
  # FQ 73561 ne fonctionne pas car  [M:SCO3]SCOPUU ne contient pas encore la bonne valeur
  [M:SCO3]SCOPUU = VALEUR: Affzo [M:SCO3]SCOPUU
  Call UPD_SRV_QTY([M:SCO1]EXTQTY,[M:SCO3]OPESTU,VALEUR,0) From SCOLIB
  Call UPD_SRV_PRI(0) From SCOLIB
End

Subprog D_OPESTU(VALEUR)
Variable Char    VALEUR()
#
Read [ITM]ITM0=[M:SCO3]SRVITMREF
If !fstat : VALEUR = [F:ITM]STU : Endif
#
End


Subprog AM_OPESTU(VALEUR)
Variable Char    VALEUR()
Call UPD_SRV_QTY([M:SCO1]EXTQTY,VALEUR,[M:SCO3]SCOPUU,0) From SCOLIB
End

Subprog D_PRHFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
   VALEUR = [M:SCO1]PRHFCY
Endif
End

Subprog AM_PRHFCY(VALEUR)
Variable Char    VALEUR()
# voir SUBSCO1/AM_PRHFCY
End

Subprog AS_POHTYP(VALEUR)
Variable Integer VALEUR
# Suppression du type de commande=3 "Cde de sous-traitance"
GMENLOC(3)=1
End

Subprog AS_SCOLTI(VALEUR)
Variable Decimal VALEUR
# Issue 82748 GA 06/2012
#If VALEUR=0 & [M:SCO1]LTI>0   VALEUR=[M:SCO1]LTI Endif
If VALEUR=0
  Local Char WSRVITMREF(GLONITM) : WSRVITMREF=[M:SCO3]SRVITMREF
  Call FIND_SCI_LTI([M:SCO0]ITMREF,[M:SCO0]BPRNUM,[M:SCO0]POHFCY,[M:SCO0]BOMALT,WSRVITMREF,VALEUR) From SCOLIB
Endif
End

######################################################################################
Subprog C_SCOLTI(VALEUR)
Variable Decimal VALEUR
# 107513 - control validity of version
Local Date WOPESTR
Local Date WOPEEND
Local Integer WOFS
If VALEUR<>[M:SCO3]SCOLTI
    WOPESTR=[0/0/0]
    WOPEEND=[M:SCO3]OPEEND
    WOFS=VALEUR
    Call CALSTRDAT(WOFS, WOPESTR, WOPEEND) From SCOLIB
Else
    WOPESTR=[M:SCO3]OPESTR
Endif

If dim([M:SCO0]ECCVALMAJ)>0 & [M:SCO0]ECCVALMAJ<>""
    If clalev([F:EVL])=0 : Local File ECCVAL [EVL] : Endif
    Call CTRECC([M:SCO0]ITMREF,"SCO0","ORDDAT",[M:SCO0]ECCVALMAJ,[M:SCO0]ECCVALMIN,
&               WOPESTR,GERR,GMESSAGE) From ECCLIB

    If find(GERR,1,4)
        GERR = 1
        mkstat=2
        End
    Endif
Endif
End

######################################################################################
Subprog AM_SCOLTI(VALEUR)
Variable Decimal VALEUR
Local    Integer WOFS : WOFS=VALEUR
## FQ 77115 GA 12/2011 demande VA toujours le même délai, dès lors qu'on le modifie ici report sur article lancé
## Ctrl du délai article sous-traité
##If WOFS > [M:SCO1]LTI
#   [M:SCO1]LTI = WOFS : Affzo [M:SCO1]LTI
##Endif
Raz [M:SCO3]OPESTR
Call UPD_SRV_DAT(WOFS,[M:SCO3]OPESTR,[M:SCO3]OPEEND,0) From SCOLIB
Affzo [M:SCO3]SCOLTI,OPESTR,OPEEND
[M:SCO1]LTI = WOFS : Affzo [M:SCO1]LTI
End


Subprog AS_OPESTR(VALEUR)
Variable Date     VALEUR
If VALEUR = [0/0/0]
   Local    Integer WOFS : WOFS=[M:SCO3]SCOLTI
   Call UPD_SRV_DAT(WOFS,[M:SCO3]OPESTR,[M:SCO3]OPEEND,0) From SCOLIB
   Affzo [M:SCO3]SCOLTI,OPESTR,OPEEND
Endif
End

Subprog AM_OPESTR(VALEUR)
Variable Date    VALEUR

Local Date     WOPESTR : WOPESTR=VALEUR
# on force le recalcul de la date de fin
Raz [M:SCO3]OPEEND

# FQ 67864 GA 10/2010 ne pas faire ce contrôle
# Message de mise en garde si date dépassée
# Call CHECK_PAST(VALEUR, 2)  From MFGLIB

# Issue 85554 GA 11/2012 contrôle déplacé depuis [M:SCO1]ORDDAT
# FQ 66569 GA 09/2010 idem SUBPOH
#----- Contrôle périodes indisponibilités fournisseur -----#
If [M:SCO0]BPRNUM<>""
  Local Integer OK
  If [F:BPS]BPSNUM<>[M:SCO0]BPRNUM
    Read [BPS] BPS0=[M:SCO0]BPRNUM : If fstat  Raz [F:BPS] : Endif
  Endif
  Call CTL_PER (VALEUR,[F:BPS]UVYCOD) From CONTX3
  If mkstat
    GMESSAGE=mess(73,198,1)-[M:SCO0]BPRNUM+"\"+GMESSAGE
    GMESSAGE=mess(1,503,1)-format$("D:"+GFMDAT,VALEUR)-GMESSAGE
    OK=2 : Call AVERTIR (GMESSAGE,OK) From GESECRAN
    If OK=1 : mkstat=2 : Raz GMESSAGE : End : Endif
    Raz mkstat, GMESSAGE
  Endif
Endif
#
# Issue 107513 by GA 08/2015: check validity for current BOM
If func AFNC.ACTIV("ECC") & dim([M:SCO0]ECCVALMAJ)>0 & [M:SCO0]ECCVALMAJ<>""
   Raz GMESSAGE
   Call BOMCTRECC([M:SCO0]ITMREF,[M:SCO0]ECCVALMAJ,[M:SCO0]ECCVALMIN,"",0,[M:SCO0]BOMALT,3,VALEUR) From TRTBOM
   If GMESSAGE<>""    # Version is not valid at this date ?
      mkstat=2 : End
   Endif
Endif
#
If [M:SCO3]SCOLTI>0 & VALEUR <> [0/0/0]
 # Màj de la date de fin selon debut+delai
   Local    Integer WOFS : WOFS=[M:SCO3]SCOLTI
   # FQ 77115 GA avant [M:SCO3]OPESTR
   Call UPD_SRV_DAT(WOFS,WOPESTR,[M:SCO3]OPEEND,1) From SCOLIB
Endif
Affzo [M:SCO3]SCOLTI,OPESTR,OPEEND

End


########################################
Subprog AS_OPEEND(VALEUR)
Variable Date     VALEUR
   If VALEUR=[0/0/0] : VALEUR=[M:SCO1]RETDAT : Endif
End

Subprog C_OPEEND(VALEUR)
Variable Date    VALEUR
# Issue 115211 - 2016-03-23 by BAKHA/CCC : control if new start date is not in the past
Call CTLRCPDAT(VALEUR,[M:SCO3]SCOLTI) From SUBSCO1
If mkstat=2
    End
Endif
End

Subprog AM_OPEEND(VALEUR)
Variable Date     VALEUR
# Issue 107513 - 2015-06-22 by GA : ECC for EO - use local variables
Local Date WOPESTR : WOPESTR=[M:SCO3]OPESTR
Local Date WOPEEND : WOPEEND=VALEUR
If VALEUR <> [0/0/0]
   Local    Integer WOFS : WOFS=[M:SCO3]SCOLTI
   WOPESTR=[0/0/0]
   Call UPD_SRV_DAT(WOFS,WOPESTR,WOPEEND,0) From SCOLIB
   VALEUR=WOPEEND   # Issue 85554 GA 11/2012: date recalculée
   [M:SCO3]OPESTR=WOPESTR
   [M:SCO3]OPEEND=WOPEEND
   Affzo [M:SCO3]SCOLTI,OPESTR,OPEEND
Endif
End

########################################
Subprog C_EXTQTY(VALEUR)
Variable Decimal VALEUR
Local    Decimal WCPL
# la quantité de l'opération ne peut être inférieure à la quantité déjà suivie
WCPL = [M:SCO3]CPLQTY
If VALEUR < WCPL
    mkstat=2
    Call MESSAGE(mess(68,193,1)) From GESECRAN
    End
Endif
Call QTEARR(VALEUR,[M:SCO3]OPESTU) From TRTDIV
# calcul qté sous-traitance, sauf si on a est "au forfait"
If [M:SCO3]STRQTYCOD <> 2
   [M:SCO3]EXTSTRQTY = VALEUR * [M:SCO3]OPESTRCOE
Endif
End

########################################
Subprog AM_EXTSTRQTY(VALEUR)
Variable Decimal VALEUR

Local    Decimal  WEXTSTRQTY_SCS : WEXTSTRQTY_SCS = [M:SCO3]EXTSTRQTY
Local    Decimal  WEXTQTY_SCS : WEXTQTY_SCS = [M:SCO3]EXTQTY
Local    Integer  WRET : WRET = 2

# Issue 88402 GA 03/2013
If [M:SCO1]EXTQTY=0 | [M:SCO3]EXTSTRQTY=0
  # Article sous-traité: La quantité doit être supérieure à zéro.
  GMESSAGE=mess(1,588,1)-":"-mess(83,182,1)
  mkstat=2 : zonsui="[M:SCO1]EXTQTY"
  End
Endif

Call QTEARR(VALEUR,[M:SCO3]SCOPUU) From TRTDIV
# FQ 52858 pb si on saisit d'abord cette qté avant [M:SCO1]QTYPUU
If [M:SCO3]OPESTRCOE=0 | [M:SCO3]OPESTUCOE=0
   Call UPD_SRV_UOM(0) From SCOLIB
Endif
# calcul qté à produire, sauf si on a est "au forfait"
If [M:SCO3]STRQTYCOD <> 2 & [M:SCO3]OPESTRCOE<>0
   [M:SCO3]EXTQTY = VALEUR / [M:SCO3]OPESTRCOE
   Call QTEARR([M:SCO3]EXTQTY,[M:SCO3]OPESTU) From TRTDIV
Else
   [M:SCO3]EXTQTY = VALEUR
   Call QTEARR([M:SCO3]EXTQTY,[M:SCO3]OPESTU) From TRTDIV
Endif
If [M:SCO3]STRQTYCOD <> 2 & [M:SCO1]EXTQTY<>0
# Issue 83385 GA 07/2012 proposer maj des qtés article lancé et composants
    If !GIMPORT
    # Ajustement de la quantité article lancé et des quantités composants ?
        Call OUINON(mess(428,194,1),WRET) From GESECRAN
    Endif
Endif
If [M:SCO3]STRQTYCOD <> 2 & WRET=2

  # Issue 87021 GA 01/2013 calcul revu
  If [M:SCO3]OPESTU=[M:SCO1]STU  & WEXTQTY_SCS = [M:SCO1]EXTQTY
  # Cas 1: US du Service = US article sous-traité et pas de coeff
     [M:SCO1]EXTQTY = [M:SCO3]EXTQTY
  Else
  # Cas 2: US du Service <> US article sous-traité et/ou coeff connu
  #        estimation selon règle de 3 ?
     [M:SCO1]EXTQTY = [M:SCO1]EXTQTY / [M:SCO3]EXTSTRQTY * VALEUR
     Call QTEARR([M:SCO1]EXTQTY,[M:SCO1]STU) From TRTDIV
  Endif
  Call UPD_ITM_QTY(1,[M:SCO1]STU,[M:SCO1]EXTQTY,[M:SCO1]PUU,[M:SCO1]QTYPUU,GBIDD1,0) From SCOLIB

  #----- Avertissement si qté cdée inférieure à la qté réceptionnée -----#
  If [M:SCO1]EXTQTY<[M:SCO1]CPLQTY
    WOK=2 : Call AVERTIR(mess(170,194,1)-format$("N:15F",[M:SCO1]CPLQTY)
&                      -[M:SCO1]STU,WOK) From GESECRAN
    If WOK=1 mkstat=1 : Goto FINQTYPUU : Endif
  Endif
  If [M:SCO1]EXTQTY > [M:SCO1]CPLQTY
     [M:SCO1]RMNEXTQTY = [M:SCO1]EXTQTY - [M:SCO1]CPLQTY
  Else
     [M:SCO1]RMNEXTQTY = 0
  Endif

  If !find(GREP,"C","D")
      Local    Decimal WFRCQTY
      Call GET_FRCQTY([M:SCO1]PRHFCY, [M:SCO0]ITMREF, 36, [M:SCO0]SCONUM, [M:SCO1]SCILIN, 0, 13, WFRCQTY) From MTOLINKLIB
      If ([M:SCO1]EXTQTY - [M:SCO1]CPLQTY) < WFRCQTY
          # lecture règle si nécessaire
          If [F:PTO]PTOCOD <> [M:SCO1]PTOCOD
              Read [F:PTO]PTO0=[M:SCO1]PTOCOD
              If fstat : Raz [PTO] : Endif
          Endif
          If [F:PTO]FRCPRO <> 2
              OK=1
              Call OUINON(mess(228,190,1), OK) From GESECRAN
              If OK <> 2 : VALEUR = [M:SCO1]QTYPUU : mkstat = 2 : End : Endif
          Endif
      Endif
  Endif
  # Issue 87021 GA 01/2013
  #[M:SCO3]EXTSTUQTY = [M:SCO1]EXTQTY
  [M:SCO3]EXTSTUQTY = [M:SCO3]EXTQTY / [M:SCO3]OPESTUCOE
  Call QTEARR([M:SCO3]EXTSTUQTY,[M:SCO1]STU) From TRTDIV
  #
  # Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
  #Affzo [M:SCO1]
  Affzo [M:SCO1]RMNEXTQTY

  #--------------------------------------
  # Qté/Prix pour les matières
  #--------------------------------------
  Default Mask [SCO2]
  For I=0 To [M:SCO2]NBLIG-1
    nolign=I+1
    Call UPD_MAT_QTY([M:SCO1]EXTQTY, I) From SCOLIB
    Call UPD_MAT_PRI(I) From SCOLIB
  Next
  # Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
  #Affzo [SCO2]

Endif

[M:SCO3]EXTSTRQTY = VALEUR : Affzo [M:SCO3]EXTSTRQTY  # sinon pb de calcul LINAMT
#----- Prix & Montant ligne -----# Issue 87680 GA 05/2013 Poser la question, sauf si ancienne valeur était à 0
If [L]WEXTSTRQTY_SCS<>[M:SCO3]EXTSTRQTY & [M:SCO3]NETPRI<>0
  Local Integer OK
  OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
  If OK=2
    Call UPD_SRV_PRI(0) From SCOLIB
  Else
    Gosub CALC_LINAMT_SCO3 From SCOLIB
  Endif
Elsif [M:SCO3]NETPRI=0 # Issue 92532 GA 10/2013 ssi zéro
  Call UPD_SRV_PRI(0) From SCOLIB
Endif

$FINQTYPUU
End
######################################################################################
Subprog RECH_SCO3_SRVITMREF(LSRVITMREF,LITMREF,LBPRNUM)
Value    Char    LSRVITMREF
Value    Char    LITMREF
Value    Char    LBPRNUM   # FQ 74682 GA 07/2011
#Local Integer    WBOMALT : WBOMALT = [M:SCO0]BOMALT
Local Integer    WOK  : WOK  = 2
Local Char       WFCY   (GLONFCY) : WFCY = [M:SCO1]PRHFCY
Local Char       WITMREF(GLONITM) : WITMREF=LSRVITMREF
#
#If [M:SCO3]PRHFCY <> "" and [M:SCO1]PRHFCY <> [M:SCO3]PRHFCY
#   WFCY = [M:SCO3]PRHFCY
#Endif

#---------------------------------------------------#
#  Lecture ITM et ITF
#---------------------------------------------------#
If LSRVITMREF<>[F:ITM]ITMREF
  Gosub READ_ITM From ITMLIB
  #If GOK=-1 : OK=1 : GMESSAGE=mess(483,199,1)-WITMREF : End : Endif
Endif

If [M:SCO3]PRHFCY=[F:FCY]FCY & [F:FCY]WRHFLG=2
  Gosub READ_ITF From ITMLIB : # Article-site facultatif sur le service ?
  #If GOK=-1 : OK=1 : GMESSAGE=mess(139,197,1)-WITMREF-WFCY : End : Endif
  If GOK=-1 : GOK=1 : Raz GMESSAGE : Endif
Endif

#----- Contrôle si article actif ? -----#
WOK = func ITMLIB.IS_ACTIVE ( LSRVITMREF )
If WOK=1 : Raz [M:SCO3]SRVITMREF : Affzo [M:SCO3]SRVITMREF : mkstat=2 : End : Endif

#----- Article référencé chez le fournisseur ? -----#
# Issue X3-55891 - 2018-09-12 by MUARN : exploitation table article/fournis
#WOK = func ITMLIB.IS_ITP_OK ( LSRVITMREF, LBPRNUM )
If [M:SCO0]BETFCY=2 & [M:SCO0]BETCPY=1
  WOK = func ITMLIB.IS_ITP_OK ( LSRVITMREF, LBPRNUM, WFCY,2)
Else
  WOK = func ITMLIB.IS_ITP_OK ( LSRVITMREF, LBPRNUM, WFCY,1)
Endif
If WOK=1 : Raz [M:SCO3]SRVITMREF : Affzo [M:SCO3]SRVITMREF : mkstat=2 : End : Endif

# Est-ce que cet article est vendu ? sinon pb génération de la commande de vente intersite
If [M:SCO0]BETCPY = 2 | [M:SCO0]BETFCY = 2
   WOK = func ITMLIB.IS_SOLD ( LSRVITMREF )
   If WOK=1 : mkstat=2: End : Endif
Endif

#----- L'article fait-il l'objet d'une commande ouverte ? -----#
Filter [POC] Where ITMREF=LSRVITMREF & STRDAT<=date$ & ENDDAT>=date$
Look [POC] POC2 First
Filter [POC]
If fstat=0 WOK=2 : Call AVERTIR(mess(1,194,1),WOK) From GESECRAN
  If WOK=1 mkstat=1 : End : Endif
  [M:SCO3]POHTYP = 2 : Affzo [M:SCO3]POHTYP
Else
  [M:SCO3]POHTYP = 1 : Affzo [M:SCO3]POHTYP
Endif

# Issue 80045 & 69609 GA 02/2012 nécessaire pour UPD_SRV_UOM, appelé dans UPD_SRV_QTY
If [M:SCO3]SRVITMREF<>LSRVITMREF [M:SCO3]SRVITMREF = LSRVITMREF Endif
#
Call UPD_SRV_QTY([M:SCO1]EXTQTY,[M:SCO3]OPESTU,[M:SCO3]SCOPUU,0) From SCOLIB
Call UPD_SRV_PRI(0) From SCOLIB

# Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
#Affzo [SCO3]

#
#Raz [F:ITM]
#Raz [F:ITF]
End


##############################################################################

Subprog UPDATE_SCSTEX(LCOD)
Value Char LCOD
Local Integer WRET
Case LCOD
  When "C","M","U" :
    #---------------------------------------------#
    # nouvelle gestion des textes                 #
    #---------------------------------------------#
     If [F:SCS]SCSTEX <> ""
        If left$([F:SCS]SCSTEX,3)="SCS"
           Call CRE_CLOB([F:SCS]SCSTEX,GOK) From TRTX3TEX
        Elsif left$([F:SCS]SCSTEX,3) <> "SCS"
           Call DUP_CLOB("SCS",[F:SCS]SCSTEX,GOK) From TRTX3TEX
        Endif
     Endif
   When "A"
     If [F:SCS]SCSTEX <> "" & left$([F:SCS]SCSTEX,3) = "SCS"
        Call SUP_CLOB([F:SCS]SCSTEX,WRET) From TRTX3TEX
     Endif
Endcase
End

#######################################################

Subprog FIND_POF ()
Local Integer W_FOUND : W_FOUND=0
#-------------------------------------------#
# On vérifie si une commande est rattachée  #
# en cherchant un encours POF ou TRF        #
#-------------------------------------------#
If [M:SCO3]POHNUM=""
  Raz [F:ORD]
  If [M:SCO0]BETFCY=2 & [M:SCO0]BETCPY<>2
#   Commande inter-site: encours de type 7 TRF
    Filter [ORD] Where WIPTYP=7 & WIPSTA=1      & ITMREF=[M:SCO3]SRVITMREF
&                    & VCRTYPORI=36             & VCRNUMORI=[M:SCO0]SCONUM
&                    & VCRLINORI=[M:SCO1]SCILIN ###### & VCRSEQORI=[M:SCO3]SCSLIN
    Read   [ORD] ORD0 First
    If fstat : Raz [F:ORD] Else W_FOUND = 1 Endif
  Else
#   Recherche d'un encours article POF
    Filter [ORD] Where WIPTYP=2 & WIPSTA=1      & ITMREF=[M:SCO3]SRVITMREF
&                    & VCRTYPORI=36             & VCRNUMORI=[M:SCO0]SCONUM
&                    & VCRLINORI=[M:SCO1]SCILIN ###### & VCRSEQORI=[M:SCO3]SCSLIN
    Read   [ORD] ORD0 First
    If fstat : Raz [F:ORD] Else W_FOUND = 1 Endif
  Endif
#
  If W_FOUND = 1
  # Référence ligne commande sur [F:SCS]
    [M:SCO3]POHNUM = [F:ORD]VCRNUM
    [M:SCO3]POPLIN = [F:ORD]VCRLIN
    [M:SCO3]POQSEQ = [F:ORD]VCRSEQ
    Gosub SCS_OPESTA_PUR From SCOLIB
    Affzo [M:SCO3]OPESTA
  # Référence de l'encours POF
  # on conserve la réf encours SCF tant qu'il n'est pas consommé
    If [F:ORD]EXTQTY >= [M:SCO3]EXTQTY
       [M:SCO3]WIPTYP = [F:ORD]WIPTYP
       [M:SCO3]WIPSTA = [F:ORD]WIPSTA
       [M:SCO3]WIPNUM = [F:ORD]WIPNUM
    Endif
  Else
#   Recherche d'une ligne de commande
    Filter [POQW] Where  VCRTYPORI=36             & VCRNUMORI=[M:SCO0]SCONUM
&                      & VCRLINORI=[M:SCO1]SCILIN & VCRSEQORI=[M:SCO3]SCSLIN
&                      & ITMREF   =[M:SCO3]SRVITMREF
    Read   [POQW]POQ4 First
    If fstat : Raz [F:POQW] : Goto FIN_FIND_POF : Endif
#
  # Référence ligne commande sur [F:SCS]
    [M:SCO3]POHNUM = [F:POQW]POHNUM
    [M:SCO3]POPLIN = [F:POQW]POPLIN
    [M:SCO3]POQSEQ = [F:POQW]POQSEQ
    Gosub SCS_OPESTA_PUR From SCOLIB
    Affzo [M:SCO3]OPESTA
#
  Endif
#
Else
# TEMPORAIRE: si ligne POQ supprimée => Raz de la référence
  Read [POQW] POQ0=[M:SCO3]POHNUM;[M:SCO3]POPLIN;[M:SCO3]POQSEQ
  If fstat
     Raz [F:POQW]
     Raz [M:SCO3]POHNUM,POPLIN,POQSEQ,OPESTA
     Affzo [M:SCO3]OPESTA
  Elsif find([M:SCO3]OPESTA,0,1,4)
    Gosub SCS_OPESTA_PUR From SCOLIB
  Endif
Endif
$FIN_FIND_POF
Filter [ORD]
If [M:SCO3]POHNUM=""
 # Issue 87115 GA 01/2013 OPESTUCOE saisissble
   Actzo [M:SCO3]SRVITMREF, OPESTA, EXTSTRQTY, SCOPUU, OPESTUCOE
 # Référence de l'encours SCx
   Call FIND_SCX()
Else
 # Issue 93852 GA 01/2014 ajout GROPRI
 # Issue 87115 GA 01/2013 OPESTUCOE n'est pas non plus saisissble
 # une fois le service commandé, il faut utiliser l'écran de maj des commandes pour màj la qté
 # => les zones sont bloquées dans la saisie de SCO
   Diszo [M:SCO3]SRVITMREF, OPESTA, EXTSTRQTY, SCOPUU, OPESTUCOE, GROPRI
Endif
End

#######################################################

Subprog FIND_SCX ()
#-------------------------------------------#
# On cherche la présence d'un encours SCx   #
#-------------------------------------------#
If [M:SCO3]WIPNUM<>"" & [M:SCO3]WIPTYP<>2
   End
Else
   Raz [F:ORD]
   Filter [ORD] Where WIPTYP=4                & ITMREF=[M:SCO3]SRVITMREF
&                  & VCRTYPORI=36             & VCRNUMORI=[M:SCO0]SCONUM
&                  & VCRLINORI=[M:SCO1]SCILIN & VCRSEQORI=[M:SCO3]SCSLIN
  Read   [ORD] ORD0 First
  If fstat : Raz [F:ORD] : Endif
  [M:SCO3]WIPTYP = [F:ORD]WIPTYP
  [M:SCO3]WIPSTA = [F:ORD]WIPSTA
  [M:SCO3]WIPNUM = [F:ORD]WIPNUM
  Filter [ORD]
Endif
End

######################################################################################

Subprog AM_GROPRI(VALEUR)
Variable Decimal VALEUR

Local Decimal  MT1, MT2, DISCRGVAL(0..8)
Local Integer  J, NOL : NOL=nolign-1

  If VALEUR=[M:SCO3]GROPRI End : Endif

  For J=1 To 9
      If evalue("dim([M:SCO3]DISCRGVAL"+num$(J)+")")>0
          If GDISCRGTYP(J-1)=1 & GCLCRUL(J-1)=1
&             MT1=evalue("[M:SCO3]DISCRGVAL"+num$(J)+"*MT2")
              Call ARRDEV(MT1,[M:SCO1]CUR) From TRTDIV
              Assign "[M:SCO3]DISCRGVAL"+num$(J) With MT1
          Endif
          DISCRGVAL(J-1)=evalue("[M:SCO3]DISCRGVAL"+num$(J))
      Endif
  Next J
  If dim(GCALNETLIN)>0  GCALNETLIN=1          : Endif
  If dim(GCALNETABR)>0  GCALNETABR="[M:SCO3]" : Endif
  Call CALNET(2,[F:BPS]PLISTC,VALEUR,DISCRGVAL,[M:SCO3]EXTSTRQTY,
&               [M:SCO3]NETPRI,[M:SCO1]CUR) From TRTPRICE
#
  If dim(GDACMANPUR)<0 | GDACMANPUR=0      # Issue 93852 GA 01/2014
    [M:SCO3]PRIREN=GUPDPRIPUR         # 8=Motif ne venant pas du tarif
  Else
    [M:SCO3]PRIREN=GDACMANPUR         # Motif de saisie manuelle du prix de la DA
  Endif

  # FQ 74682 GA 07/2011 devise Fournisseur versus devise locale
  If dim([M:SCO1]CHGTYP)>0
    [M:SCO3]GROPRI = VALEUR     # Issue 84760 - 2012-10-12 by CCC
    Gosub CALC_LINAMT_SCO3 From SCOLIB
    # Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
    #Affzo [M:SCO3]
    Affzo [M:SCO3]GROPRI,PRIREN,REFPRI,LINAMT,LINAMTL
  Endif

End

Subprog AP_GROPRI(VALEUR)               # Issue 93852 GA 01/2014
Variable Decimal VALEUR
#---------------------------------------------------------------------------------#
# Après saisie du prix brut : Test si prix nul                                    #
#---------------------------------------------------------------------------------#
End

