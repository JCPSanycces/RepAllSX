#<AdxTL>@(#)2.0.0.0 $Revision$
# TRTINT
# -------------------------------------
 Local Char    PARMSK(250)(1..20), SAVACT(20), VALEUR(40)
 SAVACT = GACTION : GACTION = "SINTERNET"
 PARMSK(1) = "www.google.com"
 Call SAISIE_CHAR(VALEUR, PARMSK, "SINTERNET", "TRTINT", "") From GSAISIE
End
##########################################################################################################

##########################################################################################################
$ACTION
Case ACTION
  When "DEBUT" : Gosub DEBUT
  When "FIN"   : Gosub FIN
Endcase
Return


##########################################################################################################
$DEBUT
# ---------------------------------------------------------------------------------------------------------
# PARAM(1) : Adresse internet
# ---------------------------------------------------------------------------------------------------------
Effzo [M]
[M]INTADR = PARAM(1)

Call URL([M]INTADR,[M]ADRESSE) From PRDINFLIB
# Si on n'a pas d'adresse, on ne peut pas y aller... Donc on sort tout de suite
If mkstat=2 : FIN = 1 : Endif

# add single quotes for evalue statement in URL formula
[M]ADRESSE = "'"+[M]ADRESSE+"'"
Return

##########################################################################################################
$FIN
Inftxt "" At 1
Return

