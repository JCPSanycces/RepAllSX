#<AdxTL>@(#)%I%
# Supervisor
# Inquiry BOA

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:10:58"
A_USER  = "ADMIN"
A_STAMP = "20181109081058"
Return

$DEFAUT
Default File [BOA]
Return

$OUVFIC
Local File BUDAPP [BOA]
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(38764,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSBOASTD"
PROGSPE    = "CNSBOASPE"
CBOITE     = "DCNSBOA"
BOITE      = "FCNSBOA"
NOMMSK(0)  = "CONSBOA1"
ABMSK(0)   = "BOA1"
NOMMSK(1)  = "CONSBOA2"
ABMSK(1)   = "BOA2"
CMEMO      = "brv"
CNOMMSK    = "CRITBOA"
CABMSK     = "CBOA"
NOMFIC     = "BUDAPP"
ABFIC      = "BOA"
OBJDERLU   = "BOA"
CODMSKDEF  = "STD"
MAGNETO    = 1
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..0), CLEMSK(10)(0..0)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = "BOA0"
NBCMP = 1
CLECMP(0) = "NUM"
CLEMSK(0) = "SELNUM"
Return

$OUVRE
If clalev([F:BOA])=0 : Local File BUDAPP       [BOA] : Endif
If clalev([F:BOA])=0 : Local File BUDAPP       [BOA] : Endif
If clalev([F:PRJ])=0 : Local File PROJET       [PRJ] : Endif
If clalev([F:ENV])=0 : Local File ENVELOPPE    [ENV] : Endif
If clalev([F:ENF])=0 : Local File ENVFIY       [ENF] : Endif
If clalev([F:BUD])=0 : Local File BUD          [BUD] : Endif
If clalev([F:BUP])=0 : Local File BUDPAR       [BUP] : Endif
Return

$OUVRE_MSK
Case MA
 When -1 : Local Mask =CNOMMSK   [CBOA]
 When  0 : Local Mask =NOMMSK(0) [BOA1]
 When  1 : Local Mask =NOMMSK(1) [BOA2]
Endcase
Return

$GRISE_MSK
Case MA
 When -1 : Grizo [CBOA]
 When  0 : Grizo [BOA1]
 When  1 : Grizo [BOA2]
Endcase
Return

$GRISE_CLE
Case MA
 When -1 : If dim([M:CBOA]SELNUM)>0 : Grizo [CBOA]SELNUM : Endif
 When  0 : If dim([M:BOA1]SELNUM)>0 : Grizo [BOA1]SELNUM : Endif
Endcase
Return

$GRISE_CRIT
If dim([M:CBOA]SELNUM)>0
 Grizo [CBOA]SELNUM
Endif
If dim([M:CBOA]CPY)>0
 Grizo [CBOA]CPY
Endif
If dim([M:CBOA]FCY)>0
 Grizo [CBOA]FCY
Endif
If dim([M:CBOA]DATDEB)>0
 Grizo [CBOA]DATDEB
Endif
If dim([M:CBOA]DATFIN)>0
 Grizo [CBOA]DATFIN
Endif
If dim([M:CBOA]ALLTYP)>0
 Grizo [CBOA]ALLTYP
Endif
If dim([M:CBOA]SELTYP)>0
 Grizo [CBOA]SELTYP
Endif
If dim([M:CBOA]PRJ)>0
 Grizo [CBOA]PRJ
Endif
If dim([M:CBOA]ENTMSTR)>0
 Grizo [CBOA]ENTMSTR
Endif
If dim([M:CBOA]ENTMEND)>0
 Grizo [CBOA]ENTMEND
Endif
If dim([M:CBOA]ENTASTR)>0
 Grizo [CBOA]ENTASTR
Endif
If dim([M:CBOA]ENTAEND)>0
 Grizo [CBOA]ENTAEND
Endif
If dim([M:CBOA]ENVSTR)>0
 Grizo [CBOA]ENVSTR
Endif
If dim([M:CBOA]ENVEND)>0
 Grizo [CBOA]ENVEND
Endif
If dim([M:CBOA]SELACC)>0
 Grizo [CBOA]SELACC
Endif
Return

$FERME_MSK
Case MA
 When -1 : If clalev([M:CBOA])>0 : Close Local Mask [CBOA] : Endif
 When  0 : If clalev([M:BOA1])>0 : Close Local Mask [BOA1] : Endif
 When  1 : If clalev([M:BOA2])>0 : Close Local Mask [BOA2] : Endif
Endcase
Return

$SETMASK
Case MA
 When -1 : Default Mask [CBOA]
 When  0 : Default Mask [BOA1]
 When  1 : Default Mask [BOA2]
Endcase
Return

$RAZMASK
Case MA
 When -1 : Raz [M:CBOA]
 When  0 : Raz [M:BOA1]
 When  1 : Raz [M:BOA2]
Endcase
Return

$CRITENT
If dim([M:CBOA]SELNUM)>0 & dim([M:BOA1]SELNUM)>0
 [M:CBOA]SELNUM = [M:BOA1]SELNUM
Endif
If dim([M:CBOA]CPY)>0 & dim([M:BOA1]CPY)>0
 [M:CBOA]CPY = [M:BOA1]CPY
Endif
If dim([M:CBOA]FCY)>0 & dim([M:BOA1]FCY)>0
 [M:CBOA]FCY = [M:BOA1]FCY
Endif
If dim([M:CBOA]DATDEB)>0 & dim([M:BOA1]DATDEB)>0
 [M:CBOA]DATDEB = [M:BOA1]DATDEB
Endif
If dim([M:CBOA]DATFIN)>0 & dim([M:BOA1]DATFIN)>0
 [M:CBOA]DATFIN = [M:BOA1]DATFIN
Endif
If dim([M:CBOA]ALLTYP)>0 & dim([M:BOA1]ALLTYP)>0
 [M:CBOA]ALLTYP = [M:BOA1]ALLTYP
Endif
If dim([M:CBOA]SELTYP)>0 & dim([M:BOA1]SELTYP)>0
 [M:CBOA]SELTYP = [M:BOA1]SELTYP
Endif
If dim([M:CBOA]PRJ)>0 & dim([M:BOA1]PRJ)>0
 [M:CBOA]PRJ = [M:BOA1]PRJ
Endif
If dim([M:CBOA]ENTMSTR)>0 & dim([M:BOA1]ENTMSTR)>0
 [M:CBOA]ENTMSTR = [M:BOA1]ENTMSTR
Endif
If dim([M:CBOA]ENTMEND)>0 & dim([M:BOA1]ENTMEND)>0
 [M:CBOA]ENTMEND = [M:BOA1]ENTMEND
Endif
If dim([M:CBOA]ENTASTR)>0 & dim([M:BOA1]ENTASTR)>0
 [M:CBOA]ENTASTR = [M:BOA1]ENTASTR
Endif
If dim([M:CBOA]ENTAEND)>0 & dim([M:BOA1]ENTAEND)>0
 [M:CBOA]ENTAEND = [M:BOA1]ENTAEND
Endif
If dim([M:CBOA]ENVSTR)>0 & dim([M:BOA1]ENVSTR)>0
 [M:CBOA]ENVSTR = [M:BOA1]ENVSTR
Endif
If dim([M:CBOA]ENVEND)>0 & dim([M:BOA1]ENVEND)>0
 [M:CBOA]ENVEND = [M:BOA1]ENVEND
Endif
If dim([M:CBOA]SELACC)>0 & dim([M:BOA1]SELACC)>0
 [M:CBOA]SELACC = [M:BOA1]SELACC
Endif
Return

$ENTCRIT
If dim([M:CBOA]SELNUM)>0 & dim([M:BOA1]SELNUM)>0
[M:BOA1]SELNUM = [M:CBOA]SELNUM
Endif
If dim([M:CBOA]CPY)>0 & dim([M:BOA1]CPY)>0
[M:BOA1]CPY = [M:CBOA]CPY
Endif
If dim([M:CBOA]FCY)>0 & dim([M:BOA1]FCY)>0
[M:BOA1]FCY = [M:CBOA]FCY
Endif
If dim([M:CBOA]DATDEB)>0 & dim([M:BOA1]DATDEB)>0
[M:BOA1]DATDEB = [M:CBOA]DATDEB
Endif
If dim([M:CBOA]DATFIN)>0 & dim([M:BOA1]DATFIN)>0
[M:BOA1]DATFIN = [M:CBOA]DATFIN
Endif
If dim([M:CBOA]ALLTYP)>0 & dim([M:BOA1]ALLTYP)>0
[M:BOA1]ALLTYP = [M:CBOA]ALLTYP
Endif
If dim([M:CBOA]SELTYP)>0 & dim([M:BOA1]SELTYP)>0
[M:BOA1]SELTYP = [M:CBOA]SELTYP
Endif
If dim([M:CBOA]PRJ)>0 & dim([M:BOA1]PRJ)>0
[M:BOA1]PRJ = [M:CBOA]PRJ
Endif
If dim([M:CBOA]ENTMSTR)>0 & dim([M:BOA1]ENTMSTR)>0
[M:BOA1]ENTMSTR = [M:CBOA]ENTMSTR
Endif
If dim([M:CBOA]ENTMEND)>0 & dim([M:BOA1]ENTMEND)>0
[M:BOA1]ENTMEND = [M:CBOA]ENTMEND
Endif
If dim([M:CBOA]ENTASTR)>0 & dim([M:BOA1]ENTASTR)>0
[M:BOA1]ENTASTR = [M:CBOA]ENTASTR
Endif
If dim([M:CBOA]ENTAEND)>0 & dim([M:BOA1]ENTAEND)>0
[M:BOA1]ENTAEND = [M:CBOA]ENTAEND
Endif
If dim([M:CBOA]ENVSTR)>0 & dim([M:BOA1]ENVSTR)>0
[M:BOA1]ENVSTR = [M:CBOA]ENVSTR
Endif
If dim([M:CBOA]ENVEND)>0 & dim([M:BOA1]ENVEND)>0
[M:BOA1]ENVEND = [M:CBOA]ENVEND
Endif
If dim([M:CBOA]SELACC)>0 & dim([M:BOA1]SELACC)>0
[M:BOA1]SELACC = [M:CBOA]SELACC
Endif
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..1) , CRITAFF2(10)(1..1)
CRITAFF(1) = "ECRAN" : CRITAFF2(1) = ""
NBCA = 1
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
Call AS_NBLIG From ="W1CONSBOA2"
NBBOUT = 0
If GBOUT2<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT2
 VALBOUT(NBBOUT) = "BOA"
 VALBOUT(NBBOUT) += "~B2"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M]NUM(nolign-1),"~","¨")
 Onerrgo
Endif
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Gosub NOMFIC
For MA=0 to dim(NOMMSK)-1
 Gosub OUVRE_MSK
Next MA
For MA=0 to dim(NOMMSK)-1
 Gosub SETMASK
Next MA
Case BOUT
 When "B2"
  Onerrgo RIEN
  Assign "[M]NUM(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Onerrgo
  Call B2_NBLIG From ="W1CONSBOA2"
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


