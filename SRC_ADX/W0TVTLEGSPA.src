Endif
[M]SPAPURTAG = IMPENT

## Zone SPAIVT303
mkstat = 0
zoncou = "SPAIVT303"
indice = 0
IMPENT = [M]SPAIVT303
If varinit([M]SPAIVT303,indice)=0
 IMPENT = 1
