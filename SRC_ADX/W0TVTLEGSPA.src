Endif
[M]SPAUSEPDT = IMPENT

## Zone SPASPETAX
mkstat = 0
zoncou = "SPASPETAX"
indice = 0
IMPENT = [M]SPASPETAX
If varinit([M]SPASPETAX,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPASPETAX,indice)=0
 [M]SPASPETAX(indice) = IMPENT
