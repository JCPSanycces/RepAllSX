#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TVTLEGSPA 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CURLEG
mkstat = 0
zoncou = "CURLEG"
indice = 0
If varinit([M]CURLEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]CURLEG,"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone SPAVAT
mkstat = 0
zoncou = "SPAVAT"
indice = 0
If varmode([M]SPAVAT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_SPAVAT([M]SPAVAT) From TRTTVTLEGSPA
 GACTION = SAVACT
 If mkstat=1 : Raz [M]SPAVAT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPAVAT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTTVT"
  Call CONTTVT([M]SPAVAT,[M:TVTSPA]CURLEG,"TVTLEGSPA","SPAVAT","","","") From SUBTVT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SPAVAT" : GZNUM = 48710 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_SPAVAT([M]SPAVAT) From TRTTVTLEGSPA
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "SPAVAT" : GZNUM = 48710 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone SPAEXEVAT
mkstat = 0
zoncou = "SPAEXEVAT"
indice = 0
IMPENT = [M]SPAEXEVAT
If varinit([M]SPAEXEVAT,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPAEXEVAT,indice)=0
 [M]SPAEXEVAT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPAEXEVAT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPAEXEVAT(indice)
 Endif
Endif
[M]SPAEXEVAT = IMPENT

## Zone SPAIMPVAT
mkstat = 0
zoncou = "SPAIMPVAT"
indice = 0
IMPENT = [M]SPAIMPVAT
If varinit([M]SPAIMPVAT,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPAIMPVAT,indice)=0
 [M]SPAIMPVAT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPAIMPVAT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPAIMPVAT(indice)
 Endif
Endif
[M]SPAIMPVAT = IMPENT

