  IMPMOD = 0 : IMPZON = "SPASPETAX" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPASPETAX(indice)
 Endif
Endif
[M]SPASPETAX = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone SPANRS
mkstat = 0
zoncou = "SPANRS"
indice = 0
IMPENT = [M]SPANRS
If varinit([M]SPANRS,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPANRS,indice)=0
 [M]SPANRS(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPANRS" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPANRS(indice)
 Endif
Endif
[M]SPANRS = IMPENT

## Zone SPARNT
mkstat = 0
zoncou = "SPARNT"
indice = 0
IMPENT = [M]SPARNT
If varinit([M]SPARNT,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPARNT,indice)=0
 [M]SPARNT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPARNT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPARNT(indice)
