Endif
[M]SPAPRA303 = IMPENT

## Zone SPAAGRVAT
mkstat = 0
zoncou = "SPAAGRVAT"
indice = 0
IMPENT = [M]SPAAGRVAT
If varinit([M]SPAAGRVAT,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPAAGRVAT,indice)=0
 [M]SPAAGRVAT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPAAGRVAT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPAAGRVAT(indice)
 Endif
Endif
[M]SPAAGRVAT = IMPENT

## Zone SPAUSEPDT
mkstat = 0
zoncou = "SPAUSEPDT"
indice = 0
IMPENT = [M]SPAUSEPDT
If varinit([M]SPAUSEPDT,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPAUSEPDT,indice)=0
 [M]SPAUSEPDT(indice) = IMPENT
