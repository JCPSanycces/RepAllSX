#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"LCKSRC","LCKSRC","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "DEBUT"    : Gosub DEBUT
 When "SETBOUT"  : Gosub SETBOUT
 When "RAF"      : Gosub RAF
 When "FINSAI"   : Gosub FINSAI
Endcase
Return

$OUVRE
Local Mask LCKSRC
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
Local Char    ORDRE(250)
Local Integer NBTRT , I 
Gosub DEFVAR
Gosub DEFEXT
Return

$DEFVAR
Local Char    REPERT(10) , APPLI(GLONADS) , FICHIER(GDIMFIC)
APPLI = nomap
Return

$DEFEXT
Local Char EXT(10)
Case REPERT
 When "TRT" : EXT = "LCKsrc"
 When "STC" : EXT = "LCKstc"
Endcase
Return

$DEBUT
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ""
adxirs = chr$(10)
adxium = GASCII
Gosub LIRE
Return

$SETBOUT
CHBOU += "="
Return

$RAF
Gosub LIRE
Return

$FINSAI
adxirs = SAVIRS
adxifs = SAVIFS
adxium = SAVIUM
Return

$LIRE
If clalev([TRT_])>0 : Close Local File [TRT_] : Endif
Raz [M]
I = 0
For REPERT="TRT","STC"
 Gosub DEFEXT
 ORDRE = adxmac(0)+'@lsadx -a '+APPLI-REPERT-EXT : # Pour ne pas être limité par une variable dimensionnée
 Local File (TRT(GLONADC)) From System ORDRE As [TRT_]
 For [TRT_]
  I += 1
  [M]TRT(I-1) = [TRT_]TRT
  If dim([M]REP)>0
   [M]REP(I-1) = REPERT
  Endif
  FICHIER = filpath(REPERT,[TRT_]TRT,EXT,APPLI)
  If filinfo(FICHIER,0)>=0
   Openi FICHIER
   Rdseq [M]MAC(I-1)
   Rdseq [M]USR(I-1)
   Rdseq [M]DAT(I-1)
   Openi
  Endif
 Next TRT_
 Close Local File [TRT_]
Next REPERT
[M]NBLIG = I
Affzo
Return

#--------------------------------------------------#
# Ecran LCKSRC
#--------------------------------------------------#

Subprog B1_NBLIG
Local Integer NOL , STAT
Local Char    REPERT(10) , EXT(10)
NOL = nolign-1
Gosub DEFVAR
If dim([M]REP)>0
 REPERT = [M]REP(NOL)
Else
 REPERT = "TRT"
Endif
Gosub DEFEXT
FICHIER = filpath(REPERT,[M]TRT(NOL),EXT,APPLI)
If filinfo(FICHIER,0)>=0
 Call EFFACE(FICHIER,STAT) From ORDSYS
Endif
If filinfo(FICHIER,0)>=0
 Call MESSAGE(mess(28,125,1)+"\|"+FICHIER+"|") From GESECRAN : # Erreur d'effacement
Endif
Gosub LIRE
End

