#<AdxTL>@(#)188.0.0.0 $Revision$
######################################################
## Subprog ROLL
## Subprog DEBTRANS
## Subprog RSTA(ABR,CLE)
## Subprog FSTA(ABR)
## Subprog GSTA
## Subprog DELOCK(RACINE)
######################################################
#################################
## Transactions                ##
#################################
Subprog ROLL
Local Integer OK
Local Char    TEXTE(250)
GNBROL += 1
If !GSERVEUR
 If mod(GNBROL,GROLLBACK)=0
  If GLOCK<>""
   # Erreur de verrouillage sur
   Case left$(GLOCK,1)
    When "$" : TEXTE = mess(20,100,1)-mess(55,100,1)-right$(GLOCK,2)         : # fichier
    When "%" : TEXTE = mess(20,100,1)-mess(56,100,1)-"|"+right$(GLOCK,2)+"|" : # symbole
    When "@" : TEXTE = mess(20,100,1)-mess(184,100,1)-right$(GLOCK,2)        : # compteur
    When Default : TEXTE = GLOCK
   Endcase
  Endif
  If !GIMPORT and GWEBSERV<>1
   # Les données que vous mettez à jour sont verrouillées par un autre utilisateur, Vouez-vous réessayer ?
   TEXTE = mess(188,124,1)+"\"+mess(189,124,1)+"\("+TEXTE+")\"+mess(190,124,1)
   TEMPS = int(10*rnd(1)+1)
   Sleep TEMPS
   OK = 2 : Call AVERTIRT(TEXTE,OK) From GESECRAN
   If OK<>2 : GROLL = 1 : Endif
  Else
   If GWEBSERV<>1
    Call ECR_TRACE(TEXTE,1) From GESECRAN
   Else
    Call ERREUR(TEXTE) From GESECRAN
   Endif
   GROLL = 1
  Endif
  GLOCK=""
 Endif
Else
 If mod(GNBROL,GROLLBACK)=0
  # Erreur de verrouillage
  Case left$(GLOCK,1)
   When "$"     : GMESSAGE = mess(20,100,1)-mess(55,100,1)-right$(GLOCK,2) : # fichier
   When "%"     : GMESSAGE = mess(20,100,1)-mess(56,100,1)-right$(GLOCK,2) : # symbole
   When "@"     : GMESSAGE = mess(20,100,1)-mess(184,100,1)-right$(GLOCK,2): # compteur
   When ""      : GMESSAGE = mess(60,100,1)                                : # Enregistrement verrouillé
   When Default : GMESSAGE = GLOCK
  Endcase
  If GIMPORT
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   GMESSAGE = ""
  Endif
  GROLL = 1
  GLOCK = ""
 Endif
Endif
fstat = 0 : # Pour éviter un bouclage dû à adonix
End

#######################################################################################################
Subprog TEMPLOK
Local Char    WINPROG(GLONADC) , PROG(GLONADC) , SAVPROG(GLONADC)
Local Char    OPERATION(10)
Call NOMTRTWIN("TEMPLOK",WINPROG) From MSKDIV
OPERATION  = "TEMPLOK"
SAVPROG    = GPROGRAMME
GPROGRAMME = "GSAISIE"
PROG       = "GESECRAN"
Gosub OUVRE_BOITE From =WINPROG
Sleep max(2,int(10*rnd(1)))
Gosub FERME_BOITE From =WINPROG
GPROGRAMME = SAVPROG
End

########################
Subprog DEBTRANS
GLOCK = ""
GROLL = 0
GNBROL = 0
GOK = 1
End

#######################################################################################################
Subprog RSTA(ABR,CLE)
Value Char ABR
Value Char CLE
Local Integer RD
RD = 1
Goto STAT

#######################################################################################################
Subprog FSTA(ABR)
Value Char    ABR
Local Integer RD
Local Char    CLE(250)
RD = 0

$STAT
Local Char    SUBCLE(GLONAVA)
Local Char    SAVIFS(10) , SAVIRS(10)
Local Integer SAVIUM
Local Char    CHEMIN(GDIMFIC) , REPERT(GDIMFIC) , NOMFIC(GLONATB) , EXT(10)
Local Char    MESSAGE(40) , TEXTE(240)
Local Char    VARIA(GLONAVA+GLONABR+10) , APPLI(GLONADS)
Local Integer I , J , SAVFSTAT, ERR
SAVFSTAT = fstat
Local File ATABIND [AZZ_]
Local Char    NOMCLE(type([F:AZZ_]DESCRIPT)-10)

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

CHEMIN = ""
If left$(ABR,1)<>"@"
 For I=1 To adxmto
  If fileabre(I)=ABR
   If evalue("clalev([F:"+ABR+"])")=1
    CHEMIN = filename(I) : Break
   Endif
  Endif
 Next I
 If CHEMIN="" & left$(CLE,1)<>"#"
  If RD
   ERR = 1
   If GSERVEUR : GMESSAGE = "RSTA"-mess(152,115,1)-ABR : Endif : # Argument incorrect
   Call ERREURT("RSTA"-mess(152,115,1)-ABR,ERR) From GESECRAN : # Argument incorrect
  Else
   ERR = 1
   If GSERVEUR : GMESSAGE = "FSTA"-mess(152,115,1)-ABR : Endif : # Argument incorrect
   Call ERREURT("FSTA"-mess(152,115,1)-ABR,ERR) From GESECRAN : # Argument incorrect
  Endif
  End
 Endif

 J = instr(1,CHEMIN,"@")
 If J
  I = instr(1,CHEMIN,".FIL")
  If I
   APPLI = seg$(CHEMIN,J+1,I-1)
   If APPLI = nomap(0) : APPLI="" : Endif
  Endif
 Endif

 J = instr(1,CHEMIN,"/")
 If J
  I = instr(1,CHEMIN,"$")
  If I
   NOMFIC = seg$(CHEMIN,J+1,I-1)
  Else
   NOMFIC = right$(CHEMIN,J+1)
  Endif
 Endif

 If !RD
  CLE=""
  Read [AZZ_]NUMLIG(2) = NOMFIC;1
  If !fstat
   NOMCLE = [F:AZZ_]DESCRIPT
   While NOMCLE<>""
    I = instr(1,NOMCLE,"+")
    J = instr(1,NOMCLE,"-")
    If I & J : I = min(I,J)
    Elsif J & !I : I = J : #  112311 CCL J = I
    Endif
    If I
     SUBCLE = left$(NOMCLE,I-1) : NOMCLE = right$(NOMCLE,I+1)
    Else
     SUBCLE = NOMCLE : NOMCLE = ""
    Endif
    CLE -= num$(evalue("[F:"+ABR+"]"+SUBCLE))
   Wend
  Endif
 Endif
Else
 NOMFIC = "APLLCK"
 CHEMIN = NOMFIC
 CLE = right$(ABR,2)
Endif

# Use a common function
#Case SAVFSTAT
# When 0       : MESSAGE = ""
# When 1       : MESSAGE = mess(60,100,1)  : # Enregistrement verrouillé
# When 2       : MESSAGE = mess(153,115,1) : # Clé suivante lue
# When 3       : MESSAGE = mess(22,100,1)  : # Clé déjà existante
# When 4       : MESSAGE = mess(11,100,1)  : # Début/fin de fichier
# When 5       : MESSAGE = mess(154,115,1) : # Pas d'enregistrement courant
# When 6       : MESSAGE = mess(240,115,1) : # Enregistrement obsolète
# When Default : MESSAGE = mess(6,123,1)   : # Erreur
#Endcase
MESSAGE = func GET_FSTAT_MSG(SAVFSTAT)

If GSERVEUR
 GMESSAGE = num$(SAVFSTAT)
 If NOMFIC<>""
  If APPLI<>"" : GMESSAGE += mess(85,115,1)-":"-APPLI+" " : Endif
  GMESSAGE += mess(55,100,1)-":|"-NOMFIC-"["+ABR+"]"+"| " : # Fichier
 Endif
 If left$(CLE,1)<>"#"
  GMESSAGE += mess(55,123,1)-NOMCLE+":"-CLE : # Clé
 Else
  GMESSAGE += right$(CLE,2)
 Endif
 If GIMPORT
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  GMESSAGE = ""
 Endif
Endif

If NOMFIC<>""
 If APPLI<>"" : TEXTE = mess(85,115,1)-":"-APPLI+"\" : Endif
 TEXTE += mess(55,100,1)-":|"-NOMFIC-"["+ABR+"]"+"|\" : # Fichier
Else
 TEXTE = ""
Endif
If left$(CLE,1)<>"#"
 TEXTE += mess(55,123,1)-NOMCLE+":"-CLE : # Clé
 If MESSAGE<>"" : TEXTE+="\"+MESSAGE : Endif
 # TEXTE += MESSAGE
Else
 TEXTE += right$(CLE,2)
Endif
If GOK=0
 TEXTE += "\\"+mess(14,100,1) : # Transaction interrompue
Endif
ERR = 1
Call ERREURT(TEXTE,ERR) From GESECRAN
If GTRACE<>"" & !GSERVEUR & !GIMPORT
 Call ECR_TRACE(TEXTE,ERR) From GESECRAN : # mb 25.11.9 demande 60259
Endif

adxifs = ""
adxirs = chr$(10)
adxium = GUTF8

FICTRA = filpath("tmp","transac","tra",0)
Lock FICTRA With lockwait=-1
Openo FICTRA , -1
Wrseq format$("D:"+GFMDAT,date$)-time$;
If GOK=0
 Wrseq "  "+mess(6,123,1) : # Erreur
Else
 Wrseq "  "+mess(156,115,1) : # Anomalie non bloquante
Endif
Wrseq "   "+mess(55,100,1)-":"-CHEMIN : # Fichier
If left$(CLE,1)<>"#"
 Wrseq "   "+mess(55,123,1)-":"-CLE : # Clé
 Wrseq "   ";MESSAGE-"(fstat=";num$(SAVFSTAT);")"
Else
 Wrseq right$(CLE,2)
Endif
Wrseq "   ";mess(103,124,1)-":"-GUSER-GTTY : # Code utilisateur
If !RD
 If left$(ABR,1)<>"@"
  For I=1 To evalue("clanbs([F:"+ABR+"],1)")
   VARIA = evalue("clavar([F:"+ABR+"],"+num$(I)+")")
   If left$(VARIA,1)<>"~" & !find(evalue("type([F:"+ABR+"]"+VARIA+")"),522,523) : # Blob, Clob
    For J=1 To evalue("dim([F:"+ABR+"]"+VARIA+")")
     Wrseq "   ";format$("K:10X",VARIA);format$("K:4X","("+num$(J-1)+")");
     Wrseq " = ";evalue("[F:"+ABR+"]"+VARIA+"("+num$(J-1)+")")
    Next J
   Endif
  Next I
 Else
  Wrseq evalue("[C]"+right$(ABR,2))
 Endif
Endif
I = 0
While adxpno(I)<>""
 Wrseq filpath("",adxpno(I),"")
 #If instr(1,adxpno(I),".MEN/") : Break : Endif
 I += 1
Wend
Wrseq string$(70,"-")
Openo

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

fstat = SAVFSTAT
Unlock FICTRA
If GTRACE<>""
 CHEMIN = filpath("TRA",GTRACE,"tra",0)
 Openo CHEMIN , -1
Endif

End

#######################################################################################################
Subprog GSTA
Case fstat
 When 0 : # Rien
 When 1 : Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
 When 2 : fstat = 0
 When 3 : Call ERREUR(mess(22,100,1)) From GESECRAN : # Fiche déjà existante
 When 4 : Call ERREUR(mess(11,100,1)) From GESECRAN : # Début/Fin de fichier
 When 5 : Call ERREUR(mess(23,100,1)) From GESECRAN : # Fiche inexistante
 When Default
  Call ERREUR(mess(12,100,1)+"\(fstat="+num$(fstat)+")") From GESECRAN : # Erreur d'accés sur le fichier
Endcase
End

#####################################
Subprog DELOCK(RACINE)
Value Char    RACINE
Local Decimal PID
Local File APLLCK [LKK]
PID   = adxuid(2) : # JML 27/2/97 avec DS/BY
If !adxlog
 Trbegin [LKK]
 Gosub DELLKK
 Commit
Else
 Gosub DELLKK
Endif
Close Local File [LKK]
End

$DELLKK
# mb 12.1.2010 bug 61490 Blocage sous Sql sur symbole verrouillé dans une transaction
#Delete [LKK] Where LCKPID=PID & left$(LCKSYM,len(RACINE))=RACINE
For [LKK] Where LCKPID=PID & left$(LCKSYM,len(RACINE))=RACINE
 Delete [LKK] Curr
Next LKK
Return

#####################################
Subprog VERROU(DOSSIER,SYMBOLE,LCKWT)
Value Char DOSSIER(), SYMBOLE()
Value Integer LCKWT
If DOSSIER="" | DOSSIER=nomap(0) | DOSSIER=adxmac(0)+"@"+nomap(0)
 Lock =SYMBOLE With lockwait=LCKWT
Else
 Lock =SYMBOLE From =DOSSIER With lockwait=LCKWT
Endif
End

#####################################
Subprog DEVERROU(DOSSIER,SYMBOLE)
Value Char DOSSIER(), SYMBOLE()
If DOSSIER="" | DOSSIER=nomap(0) | DOSSIER=adxmac(0)+"@"+nomap(0)
 Unlock =SYMBOLE
Else
 Unlock =SYMBOLE From =DOSSIER
Endif
End

#######################################################################
# Le symbole est-il verrouillé par moi ?
#######################################################################
Funprog LOKBYI(SYMBOLE)
Value Char SYMBOLE
Local Integer LOK
Local File APLLCK [ALK]
Read [ALK]LCKCLE = SYMBOLE;0
If !fstat & [F:ALK]LCKPID=adxuid(2)
 LOK = 1
Else
 LOK = 0
Endif
Close Local File [ALK]
End LOK

#######################################################################
# Le symbole est-il verrouillé ?
#######################################################################
Funprog LOKBYU(SYMBOLE)
Value Char SYMBOLE
Local Integer LOK
Local File APLLCK [ALK]
Read [ALK]LCKCLE = SYMBOLE;0
If !fstat
 LOK = 1
Else
 LOK = 0
Endif
Close Local File [ALK]
End LOK

########################################################
## Connexion à une fonction
########################################################
Subprog CONNECT(LICPARAM,OK)
Value    Char    LICPARAM
Variable Integer OK
Local Integer MAXUSR , T , I
#87108
Local Char VALMAX(30)
If fmet GACTX.AGETLICPAR(LICPARAM,VALMAX)=[V]CST_ATRUE
 MAXUSR=val(VALMAX)
Else
 OK = 1 : End
Endif

If MAXUSR=0 : OK = 0 : End : Endif
Gosub SETSUP

T = time
OK = 0
For I=1 To MAXUSR
 Lock =LICPARAM+format$("N0:4#",I) From =SUPER
 If !fstat
  GLOCKFCT = LICPARAM+format$("N0:4#",I)
  OK = 1 : Break
 Endif
Next I
End

$SETSUP
Local Char    SUPER(20)
Call PARAM("","SUPDOS",SUPER) From ADOVAL
If SUPER="" or filinfo(filpath("FIL","APLLCK","fde",SUPER),0)<0
 SUPER = "X3"
 If filinfo(filpath("FIL","APLLCK","fde",SUPER),0)<0
  SUPER = nomap
 Endif
Endif
Return

########################################################
## Déconnexion d'une fonction
########################################################
Subprog DECONNECT(LICPARAM)
Value Char LICPARAM
Local Integer MAXUSR
#87108
Local Char VALMAX(30)
If fmet GACTX.AGETLICPAR(LICPARAM,VALMAX)=[V]CST_ATRUE
 MAXUSR=val(VALMAX)
Else
 End
Endif

If MAXUSR=0 : End : Endif
Gosub SETSUP

If GLOCKFCT<>""
 Unlock =GLOCKFCT From =SUPER
Endif

End

#############################################
Subprog ECR_LOCK(OPT)
Value Char OPT()
Local Char    TEXTE(250)
# Erreur de verrouillage sur
Case left$(GLOCK,1)
 When "$" : TEXTE = mess(20,100,1)-mess(55,100,1)-right$(GLOCK,2)         : # fichier
 When "%" : TEXTE = mess(20,100,1)-mess(56,100,1)-"|"+right$(GLOCK,2)+"|" : # symbole
 When "@" : TEXTE = mess(20,100,1)-mess(184,100,1)-right$(GLOCK,2)        : # compteur
 When Default : TEXTE = GLOCK
Endcase
If instr(1,OPT,"T")
 TEXTE += "\"+mess(14,100,1) : # Transaction interrompue
Endif
Call ECR_TRACE(TEXTE,1) From GESECRAN
End

#**
#* Get a standard message corresponding to a fstat value
#*
#* @param FSTA = fstat value
#* @return Message
#*!
Funprog GET_FSTAT_MSG(FSTA)
Value Integer FSTA
Local Char MESSAGE(250)
Case FSTA
 When 0       : MESSAGE = ""
 When 1       : MESSAGE = mess(60,100,1)  : # Enregistrement verrouillé
 When 2       : MESSAGE = mess(153,115,1) : # Clé suivante lue
 When 3       : MESSAGE = mess(22,100,1)  : # Clé déjà existante
 When 4       : MESSAGE = mess(11,100,1)  : # Début/fin de fichier
 When 5       : MESSAGE = mess(154,115,1) : # Pas d'enregistrement courant
 When 6       : MESSAGE = mess(240,115,1) : # Enregistrement obsolète
 When Default : MESSAGE = mess(6,123,1)   : # Erreur
Endcase

End MESSAGE

######################################################################################

#**
#* Write details concerning the context when a DB operation error occurs
#*
#* @param OPE     : operation (1=write, 2=rewrite, 3=delete, 4=read, 5=lock)
#* @param ABREV   : abreviation of table
#* @param CLE     : key elements : cle1~cle2~cle3...
#* @param LOGFIL  : path of the log file in which write the result. Set "" to use GTRACE
#*!
Subprog LOG_ERROR_DETAILS(OPE,ABREV,CLE1,LOGFIL)
Value Integer OPE
Value Char ABREV
Value Char CLE1
Value Char LOGFIL

Local Char CLE(250)(1..)
Local Integer I, INDCLE
Local Integer OPEN_TRACE
Local Char MES(250)
Local Tinyint SAV_FSTAT
SAV_FSTAT = fstat

INDCLE=1
CLE(INDCLE)=CLE1
I = instr(1,CLE(INDCLE),"~")
While I>0
    CLE(INDCLE+1) = right$(CLE(INDCLE),I+1)
    CLE(INDCLE) = left$(CLE(INDCLE),I-1)
    INDCLE +=1
    I = instr(1,CLE(INDCLE),"~")
Wend

If LOGFIL="" & GTRACE=""
    # When log file path is not specified => use classic log
    If !GSERVEUR : Call OUVRE_TRACE("DB operation error") From LECFIC : Endif
Elsif LOGFIL<>"" & filinfo(LOGFIL,0)<0
    # When log file path is specified and file doesn't exist yet => create it
    Openo LOGFIL,0
    Wrseq "#<AdxV"+"L"+">@(#)%I%"-format$("MM[/]DD[/]YY",date$)-time$-"DB operation error"
    Openo
    OPEN_TRACE=[V]CST_ATRUE
Endif

# -- 1 ----- Log the error
Case OPE
    When 1 : MES=mess(26,125,1) # Erreur d'écriture
    When 2 : MES=mess(27,125,1) # Erreur de réécriture
    When 3 : MES=mess(28,125,1) # Erreur d'effacement
    When 4 : MES=mess(49,125,1) # Erreur de lecture
    When 5 : MES=mess(58,134,1) # Erreur de verrouillage
Endcase
MES -= ABREV-"fstat="+num$(fstat)
MES-='Key = '
I=1
Repeat
    MES += string$(I>1,";") + CLE(I)
    I+=1
Until I>maxtab(CLE)
MES -="-"
Case fstat:
    When [V]CST_ALOCK      : MES-="Record is locked"
    When [V]CST_AOUTSEARCH : MES-="Read succeeded, but the key found is not equal to the value"
    When [V]CST_ADUPKEY    : MES-="Duplicate value on unique index"
    When [V]CST_AOUTKEYS   : MES-="Attempt of reading a key value that is smaller or greater than all existing key values"
    When [V]CST_ANOREC     : MES-="Record not read (no current record exists)"
    When [V]CST_ARECTICKUPD: MES-="Update : The line no longer exists with the right updtick value"
    When [V]CST_ARECTICKDEL: MES-="Delete : The line no longer exists with the right updtick value"
Endcase
Call ECRTRACE(format$("D:"+GFMDAT4,date$)-time$-":"-MES,1,LOGFIL)

# -- 2 ----- Log the current status of processes + database information
Call DUMP_USER_PROCESSES(LOGFIL)
Call DUMP_DB_PROCESSES(LOGFIL)

# -- 3 ----- Log some information concerning the record itself (readable, lockable)
# !!!!!!!!!!!!!!!!!!!  Must be done after user & DB dumps !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
Call DUMP_CURRENT_RECORD(ABREV,CLE,LOGFIL)

fstat = SAV_FSTAT


Call ECRTRACE(time$-"End of detailed log for DB operation error",0,LOGFIL)
If dim(GTRACE)>0 & GTRACE<>""
    Call FLUSH_TRACE From GESECRAN
Endif

End

#**
#* Write information concerning a record : readable ? Lockable ? Filter activated ?
#*
#* @param ABREV   : Abreviation of table for the record to analyze
#* @param CLE     : Array of value for primary key
#* @param LOGFIL  : path of log file in which write the result. Set "" to use GTRACE
#*!
Subprog DUMP_CURRENT_RECORD(ABREV,CLE,LOGFIL)
Value Char ABREV
Value Char CLE()(1..)
Value Char LOGFIL

Local Integer I
Local Char DOSSIER(50)
Local Char TABLE(250)   # Table name corresponding to the abreviation
Local Char MES(250)
Local Char CLEFLD(GLONAVA)(1..)

Call ECRTRACE ("***************************************************************",0,LOGFIL)
Call ECRTRACE ("********** Information concerning the current record **********",0,LOGFIL)
Call ECRTRACE ("***************************************************************",0,LOGFIL)

I = find(ABREV,fileabre)-1
If I>0
    # Get table name corresponding to abreviation
    TABLE = filename(I)     # Name of folder is included in the name
    J = instr(1,TABLE,"@")
    If J
      I = instr(1,TABLE,".FIL")
      If I
       DOSSIER = seg$(TABLE,J+1,I-1)
      Endif
    Endif
    If DOSSIER = "" : DOSSIER = nomap(0) : Endif
Endif
Call ECRTRACE(mess(33,9016,1)-":"-TABLE,0,LOGFIL)
Call ECRTRACE(" -->"-mess(128,9713,1)-":"-DOSSIER,0,LOGFIL)
If TABLE="" # Shouldn't happen...
    Call ECRTRACE (mess(1113,144,1),1,LOGFIL)
Else

    Local File =TABLE [ZREC]

    Call ECRTRACE ("[F:"+ABREV+"]"-mess(133,126,1),0,LOGFIL)
    Call LOG_RECORD(ABREV,LOGFIL)

    Call ECRTRACE(mess(1546,9900,1)-"?"-"nbrecord="+evalue("num$(nbrecord(["+ABREV+"]))")-"rowcount="+evalue("num$(rowcount(["+ABREV+"]))"),0,LOGFIL)

    Call GETKEY(DOSSIER,TABLE,CLEFLD)
    If CLEFLD(1)<>""
        I=1
        Call ECRTRACE(mess(38,115,1)-"("-TABLE-"[ZREC])",0,LOGFIL)
        MES = "Read [F:ZREC]"+[G:ZREC]keyname(0)+"="
        Repeat
            Case evalue("type([F:ZREC]"+CLEFLD(I)+")")
                When 1,2,4,5,6,7:
                    Assign "[F:ZREC]"+CLEFLD(I) With val(CLE(I))
                When Default:
                    Assign "[F:ZREC]"+CLEFLD(I) With CLE(I)
            Endcase
            MES += string$(I>1,";") + CLE(I)
            I+=1
        Until CLEFLD(I)=""
        Call ECRTRACE(MES,0,LOGFIL)
        Read [ZREC] =
        Call ECRTRACE(" ---> fstat="+num$(fstat),0,LOGFIL)
        Call LOG_RECORD("ZREC",LOGFIL)
        Readlock [ZREC] = With lockwait=0
        Call ECRTRACE("Readlock -> fstat="+num$(fstat),0,LOGFIL)
        If fstat=[V]CST_AOK & adxlog=0
            Unlock [ZREC]
        Endif
     Endif
Endif


End

#**
#* Return list of fields of the primary key
#*
#* @param DOSSIER : folder name (optional)
#* @param TABLE   : table name
#* @return an array with the list of field names used in the primary key
#*!
Subprog GETKEY(DOSSIER,TABLE,KEYFLD)
Value Char DOSSIER
Value Char TABLE
Variable Char KEYFLD()(1..)

Local Integer NBKEYFLD, I, J
Local Char KEYDESC(250)
If DOSSIER=""
    DOSSIER=nomap
Endif
Local File =DOSSIER+".ATABIND" [ZATI]
TABLE = right$(TABLE,instr(1,TABLE,"/")+1)

Raz KEYFLD, NBKEYFLD
Read [ZATI]NUMLIG(2) = TABLE;1
If fstat
 Raz [F:ZATI]
Else
 KEYDESC = [F:ZATI]DESCRIPT
 While KEYDESC<>""
  I = instr(1,KEYDESC,"+")
  J = instr(1,KEYDESC,"-")
  If I & J
   I = min(I,J)
  Elsif J & !I
   I = J
  Endif
  NBKEYFLD += 1
  If I
   KEYFLD(NBKEYFLD) = left$(KEYDESC,I-1)
   KEYDESC = right$(KEYDESC,I+1)
  Else
   KEYFLD(NBKEYFLD) = KEYDESC
   KEYDESC = ""
  Endif
 Wend
Endif

End

##########
# log values of all fields corresponding to a table
Subprog LOG_RECORD(ABREV,LOGFIL)
Value Char ABREV
Value Char LOGFIL

Local Integer NBFLD
Local Char CODFLD(GLONAVA)

NBFLD = evalue("[G:"+ABREV+"]nbzon")
For I=1 To NBFLD-1
    CODFLD = evalue("[G:"+ABREV+"]adxfname(I)")
    MES = "[F:"+ABREV+"]"+CODFLD+"="+evalue("num$([F:"+ABREV+"]"+CODFLD+")")
    Call ECRTRACE (MES ,0,LOGFIL)
Next

End

#############################################################
Subprog DUMP_USER_PROCESSES(LOGFIL)
Value Char LOGFIL

Local Char MES(250)
Local Char FUNCNAME(250),USER(250)
Local Integer MODULE

Call ECRTRACE ("*******************************************************",0,LOGFIL)
Call ECRTRACE ("*****************"-mess(52,115,1)-"*****************",0,LOGFIL)
Call ECRTRACE ("*******************************************************",0,LOGFIL)
Gosub INIT_RQT From ASESSIONS
WSELECT = "X3SM0.SESSIONID_0,X3SM0.FOLD_0,X3SM0.LAN_0,X3SM0.SOLUTION_0,X3SM0.SESSIONTYPE_0,"
Gosub ADD_SELECT_RQT From ASESSIONS
WSELECT = "X3SM0.REMOTE_0,X3SM0.PEER_0,X3SM0.SYSTEMUSER_0,X3SM0.NATURE_0,X3SM0.ALOGIN_0,"
Gosub ADD_SELECT_RQT From ASESSIONS
WSELECT = "X3SM0.PROCESSADX_0,X3SM0.UPDUSR_0,X3SM0.CREDATTIM_0, X3SM1.DBIDENT1_0, X3SM1.DBIDENT2_0  "
Gosub ADD_SELECT_RQT From ASESSIONS

Call ECRTRACE ("current session ID="+num$(adxuid(1)),0,LOGFIL)
Call ECRTRACE ("",0,LOGFIL)

Call ECRTRACE ("SESSIONID ; Ident1 ; Ident2 ; Client ; Address ; Folder ; LOGIN ; SESSIONTYPE ; SYSTEMUSER ; connexion time ; NATURE; Function ; module ; user",0,LOGFIL)
For (Integer SESSIONID,Char FOLD(GLONADS),Char LAN(GLONLAN),Char SOLUTION(40),Integer SESSIONTYPE,Char REMOTE(40),
&    Char PEER(250),Char SYSTEMUSER(250),Integer NATURE,Char ALOGIN(30),Integer PROCESSADX,Char UPDUSR(GLONAUS),Datetime CREDATTIM,
&    Char DBIDENT1(250), Char DBIDENT2(250))
&    From num$((GTYPDBA*2)+1)  Sql RQT_SESSION As [SYS_]

    Call GET_CURFCT(adxmac(0),[F:SYS_]FOLD,num$([F:SYS_]SESSIONID),[L]FUNCNAME,[L]MODULE,[L]USER) From PSADX

    Raz MES
    MES += num$([F:SYS_]SESSIONID)+string$([F:SYS_]SESSIONID=adxuid(1),"*")         +" ; "
    MES +=      [F:SYS_]DBIDENT1           +" ; "
    MES +=      [F:SYS_]DBIDENT2           +" ; "
    MES +=      [F:SYS_]REMOTE             +" ; "
    MES +=      [F:SYS_]PEER               +" ; "
    MES +=      [F:SYS_]FOLD               +" ; "
    MES +=      [F:SYS_]ALOGIN             +" ; "
    MES += mess([F:SYS_]SESSIONTYPE,924,1) +" ; "
    MES +=      [F:SYS_]SYSTEMUSER         +" ; "
    MES += num$([F:SYS_]CREDATTIM)         +" ; "
    MES += mess([F:SYS_]NATURE,7990,1)     +" ; "
    MES +=      FUNCNAME                   +" ; "
    MES += mess(MODULE,14,1)               +" ; "
    MES +=      USER

    Call ECRTRACE (MES,0,LOGFIL)
Next

End

#############################################################
Subprog DUMP_DB_PROCESSES(LOGFIL)
Value Char LOGFIL

Call ECRTRACE ("*****************************************************",0,LOGFIL)
Call ECRTRACE ("*****************"-mess(503,153,1)-"*****************",0,LOGFIL)
Call ECRTRACE ("*****************************************************",0,LOGFIL)

If LOGFIL<>""
    # As ORAPRO uses GESECRAN.ECR_TRACE => we have to use GTRACE
    Call ECRTRACE (mess(309,107,1),0,LOGFIL)
Else
    Case GTYPDBA
        When 1 : Call DUMP_DB_PROCESSES_ORA(LOGFIL)
        When 2 : Call DUMP_DB_PROCESSES_SQL(LOGFIL)
    Endcase
Endif
End

#############################################################
Subprog DUMP_DB_PROCESSES_ORA(LOGFIL)
Value Char LOGFIL

Local Mask ORAPRO1 [PRO1]
Local Mask ORAPRO2 [PRO2]
Local Mask ORAPRO3 [PRO3]
Local Integer ERR
Local Integer SAV_GSERVEUR
SAV_GSERVEUR = GSERVEUR
GSERVEUR=1
[M:PRO1]TRI=2    # by username
Call CHARGE_PRO1(ERR) From ORAPRO
Call CHARGE_PRO3(ERR) From ORAPRO
GSERVEUR = SAV_GSERVEUR

End

#############################################################
Subprog DUMP_DB_PROCESSES_SQL(LOGFIL)
Value Char LOGFIL

Local Mask SQLPRO1 [PRO1]
Local Mask SQLPRO3 [PRO3]
Local Integer ERR
Local Integer SAV_GSERVEUR
SAV_GSERVEUR = GSERVEUR
GSERVEUR=1
[M:PRO1]TRI=2    # by username
Call CHARGE_PRO1(ERR) From SQLPRO
Call CHARGE_PRO3(ERR) From SQLPRO
GSERVEUR = SAV_GSERVEUR
End

#############################################################
#**
#* Write a message in a log file
#*
#* @param PMES : message
#* @param PERR : error code (-1=Warning, 0=Info, 1=Error)
#* @param PFIL : path of the file. If "" => use GESECRAN.ECR_TRACE
#*!
Subprog ECRTRACE(PMES,PERR,PFIL)
Value Char PMES
Value Integer PERR
Value Char PFIL

If PFIL=""
    Call ECR_TRACE(PMES,PERR) From GESECRAN
Else
    Openo PFIL, -1
    If PERR<>0
        If PERR<0
         Wrseq ">"+right$(num$(10000+mod(abs(PERR),10000)),2)+" ";
        Else
         Wrseq "<"+right$(num$(10000+mod(PERR,10000)),2)+" ";
        Endif
    Endif
    Wrseq PMES
    Openo
Endif

End

