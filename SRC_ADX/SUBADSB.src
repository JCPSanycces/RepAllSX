#If [M]CODACT2(nolign-1)="KPO" and VALEUR = 2 Then
#  VU = find("DKS",[M]CODACT1(0..[M]NBLIG1))
#  If VU and [M]FLACT1(VU-1) = 1 Then
#    [M]FLACT1(VU-1) = 2
#    Affzo [M]FLACT1(VU-1)
#  Endif
#Elsif
If [M]CODACT1(nolign-1)="DKS" and VALEUR = 1 Then
  VU = find("KPO",[M]CODACT2(0..[M]NBLIG2))
  If VU and [M]FLACT2(VU-1) = 2 Then
    GMESSAGE = mess(132,7711,1)
    mkstat = 2 : Return
  Endif
Endif
#97101 RICAR 2014/07/03 - 50001 Law decret - END

#110972 RMA 2015/09/11 - IESFG
If [M]CODACT1(nolign-1)="IESFG" and VALEUR = 2 Then
  VU = find("KPO",[M]CODACT2(0..[M]NBLIG2))
  If VU and [M]FLACT2(VU-1) <> 2 Then
    GMESSAGE = mess(14,115,1)-"KPO"-tolower(mess(1,8,1))
    mkstat = 2 : Return
  Endif
Endif
#110972 RMA 2015/09/11 - IESFG - END

If [M]CODACT1(nolign-1)="DCL" & VALEUR<>2
 VU = find("DCLOT",[M]CODACT1(0..[M]NBLIG1))
 If VU and [M]FLACT1(VU-1)=2
  [M]FLACT1(VU-1) = 1
  Affzo [M]FLACT1(VU-1)
 Endif
Endif

# Issue 104937 - 2015-11-02 by CCC : RVM can be active only if ECC is active
Case [M]CODACT1(nolign-1)
    When "ECC" :
        If VALEUR<>2
            VU = find("RVM",[M]CODACT1(0..[M]NBLIG1))
            If VU and [M]FLACT1(VU-1)=2
                [M]FLACT1(VU-1) = 1
                Affzo [M]FLACT1(VU-1)
            Endif
        Endif
    When "RVM" :
        If VALEUR=2
            VU = find("ECC",[M]CODACT1(0..[M]NBLIG1))
            If VU and [M]FLACT1(VU-1)<>2
                # Activity code $1$ cannot be abled if activity code $2$ is disabled
                Call ERREUR(func AFNC.MES2(mess(258,125,1), "RVM", "ECC")) From GESECRAN
                mkstat=2
            Endif
        Endif
Endcase

# Issue 110700 - 2016-04-14 by RICAR : Electronic invoices: connect with Sage component
# Issue 110700
If [M]CODACT1(nolign-1)="EFAT" and VALEUR = 2 Then
  VU = find("KPO",[M]CODACT2(0..[M]NBLIG2))
  If VU and [M]FLACT2(VU-1) <> 2 Then
    GMESSAGE = mess(14,115,1)-"KPO"-tolower(mess(1,8,1))
    mkstat = 2 : Return
  Endif
Endif
# End issue 110700

 # Issue 105932_2 - 2016-04-14 by MDJ : PRCSL and CSL can't be both equal to "Yes"
 If [M]CODACT1(nolign-1)="CSL" and VALEUR = 2
  VU = find("PRCSL",[M]CODACT1(0..[M]NBLIG1))
  If VU and [M]FLACT1(VU-1)= 2
    GMESSAGE = func AFNC.MES2(mess(658,199,1), "CSL", "PRCSL")
    mkstat = 2 : Return
  Endif
 Endif
 If [M]CODACT1(nolign-1)="PRCSL" and VALEUR = 2
  VU = find("CSL",[M]CODACT1(0..[M]NBLIG1))
  If VU and [M]FLACT1(VU-1)= 2
    GMESSAGE = func AFNC.MES2(mess(658,199,1), "PRCSL", "CSL")
    mkstat = 2 : Return
  Endif
 Endif
 # End issue 105932_2

Return

$C_FLACT2
#97101 RICAR 2014/07/03 - 50001 Law decret - BEGIN
If [M]CODACT2(nolign-1)="KPO" and VALEUR = 2 Then
  VU = find("DKS",[M]CODACT1(0..[M]NBLIG1))
