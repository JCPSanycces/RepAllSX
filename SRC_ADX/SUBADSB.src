###############################################################
$DICO
Local Char STABLE(GLONATB)

  # FGR 16/03/2012 : X3SUIVI80820
  Local File =[F:ADS]DOSSIER+".ATABLE" [DATS]
  Local File ADOSACT [ADAS]
  # ----------
  Read [ADAS]ADA0=[F:ADS]DOSSIER;"GCRM"
  If !fstat Then
    Trbegin [DATS]
    # FGR 24/05/2012 : X3SUIVI 82410 : Ajout de TABUNIT et ITMCATEG
    For STABLE = "BPARTNER", "CONTACT", "CONTACTCRM", "ITMMASTER", "TABUNIT", "ITMCATEG"
      Read [DATS]CODFIC=STABLE
      If [F:ADAS]FLACT = G_OUI and [F:DATS]AUDSDA = G_NON Then
        # Si GCRM actif et flag SDATA non coché : on coche
        [F:DATS]AUDSDA = G_OUI
        [F:DATS]UPDFLG = G_NON
      Elsif [F:ADAS]FLACT = G_NON and [F:DATS]AUDSDA = G_OUI Then
        # Si GCRM inactif et flag SDATA coché : on décoche
        [F:DATS]AUDSDA = G_NON
        [F:DATS]UPDFLG = G_NON
      Endif
      Rewrite [F:DATS]
    Next
    Commit
  Endif
  # ----------
  Close Local File [DATS]
  Close Local File [ADAS]
Return
###############################################################
###############################################################
$OLD_DICO
Local Char STABLE(GLONATB)

  # FGR 25/07/2011 : X3SUIVI75276
  Local File =[F:ADS]DOSSIER+".ATABLE" [DATS]
  Local File ADOSACT [ADAS]
  # ----------
  # FGR 18/08/2011 : X3SUIVI75738 (début) : cas de la création de dossier
  If MODGCRM = -1 Then
    If filinfo(filpath("FIL", "ACTIV", "fde", [F:ADS]DOSSIER),0) > 0 Then
      If clalev([F:DACV])=0 : Local File =[F:ADS]DOSSIER+".ACTIV" [DACV] : Endif
      Read [DACV]CODACT="GCRM"
      If fstat Then
        MODGCRM = 0       # GCRM n'existe pas
      Else
        If [F:DACV]FLACT = G_OUI Then
          MODGCRM = 1     # GCRM Actif
        Else
          MODGCRM = 0     # GCRM Inactif
        Endif
      Endif
    Else
      MODGCRM = 0         # ACTIV n'existe (toujours) pas. on ne traite pas GCRM
    Endif
  Endif
  # FGR 18/08/2011 : X3SUIVI75738 (fin) : cas de la création de dossier
  # ----------
  If MODGCRM Then
    Trbegin [DATS]
    Read [ADAS]ADA0=[F:ADS]DOSSIER;"GCRM"
    For STABLE = "BPARTNER", "CONTACT", "CONTACTCRM", "ITMMASTER"
      Read [DATS]CODFIC=STABLE
      If [F:ADAS]FLACT = G_OUI Then
        [F:DATS]AUDSDA = G_OUI
      Else
        [F:DATS]AUDSDA = G_NON
      Endif
      [F:DATS]UPDFLG = G_NON
      Rewrite [F:DATS]
    Next
    Commit
  Endif
  # ----------
  Close Local File [DATS]
  Close Local File [ADAS]
Return
###############################################################


$AS_LIBMOD
GMENLOC(4) = 1
Return

$AS_FLACT1
If [M]CODACT1(nolign-1)="IAS"
 If fmet GACTX.AGETLICACV("IAS") = [V]CST_AFALSE
  VALEUR = 1 : mkstat = 2
 Endif
Endif

If [M]CODACT1(nolign-1)="DCLOT"
 VU = find("DCL",[M]CODACT1(0..[M]NBLIG1))
 If VU and [M]FLACT1(VU-1)<>2
  mkstat=2 : Return
 Endif
Endif

Return

$C_FLACT1
Local Integer VU
If [M]CODACT1(nolign-1)="ABL" & VALEUR = 2
 VU = find("FAS",[M]CODACT1(0..[M]NBLIG1))
 If VU and [M]FLACT1(VU-1) = 2
  GMESSAGE = mess(14,115,1)-"FAS"-tolower(mess(2,8,1))
  mkstat = 2 : Return
 Endif
Elsif [M]CODACT1(nolign-1)="FAS" & VALEUR = 2
 VU = find("ABL",[M]CODACT1(0..[M]NBLIG1))
 If VU and [M]FLACT1(VU-1) = 2
  GMESSAGE = mess(14,115,1)-"ABL"-tolower(mess(2,8,1))
  mkstat = 2 : Return
 Endif
Endif

If [M]CODACT1(nolign-1)="FAS"
 VALEUR = [M]MODULE(13)
Endif

#JASMI - 2017-03-06 - #121847 - START
#To automatically switch OFF activity codes that belong to modules Payroll or HR when these modules are OFF
#Activity codes include: BTP management, Careers module, Lunch vouchers, Equity module, Training module,
# Paperless payslips, HR module, Payroll module, Work accidents, Casual workers, Sickness/Maternity,
#Total payroll module, Employee/Contract fields, Skills module, Time Management module, Lunch vouchers
#JASMI - 2017-03-14 - #121809 - Added activity code PAI to also deactivate when HR modules are OFF - START
#If find([M]CODACT1(nolign-1),'BTP','CAR','CQH','EQM','FRT','HRDEM','HRHRM','HRPAY'
#&                           ,'HRTAT','INTMT','MAL','MAS','PORMI','SDM','TPS','TRH')>0
#&  & VALEUR=2 & ([M]MODULE(15-1)<>2)
#JASMI - 2018-01-09 - X3-70627 - START
#If find([M]CODACT1(nolign-1),'BTP','CAR','CQH','EQM','FRT','HRDEM','HRHRM','HRPAY'
#&                           ,'HRTAT','INTMT','MAL','MAS','PORMI','SDM','TPS','TRH'
#&                           ,'PAI','AD5','PYS')>0
#&  & VALEUR=2 & ([M]MODULE(15-1)<>2)
If find([M]CODACT1(nolign-1),'DCP','EQM','HREMP','HRESS','HRFRM','HRPAY','INTMT','LOA','MAS','PAI','PORMI','PYS','TPS')>0
&  & VALEUR=2 & ([M]MODULE(15-1)<>2)
#JASMI - 2018-01-09 - X3-70627 - END
#JASMI - 2017-03-14 - #121809 - Added activity code PAI to also deactivate when HR modules are OFF - END
 VALEUR = 1
Endif
#JASMI - 2017-03-06 - #121847 - END

#JASMI - 2018-01-09 - X3-70627 - START
If find([M]CODACT1(nolign-1),'CAR','FRT','HRHRM')>0
&  & VALEUR=2 & ([M]MODULE(20-1)<>2)
 VALEUR = 1
Endif
#JASMI - 2018-01-09 - X3-70627 - END

# Si le module 'comptabilité' est actif, le code activité CPT doit être à oui (par contre l'inverse n'est pas forcément vrai - F61321)
If [M]CODACT1(nolign-1)="CPT" & VALEUR<>2 & [M]MODULE(1)=2
 VALEUR = [M]MODULE(1)
Endif

# Interface trésorerie, une seule interface trésorerie ne peut être cochée.
If GADONIX<>2
 If [M]CODACT1(nolign-1)="SCTE" & VALEUR=2
  VU = find("T1000",[M]CODACT1(0..[M]NBLIG1))
  If VU and [M]FLACT1(VU-1) = 2
   [M]FLACT1(VU-1) = 1
   Affzo [M]FLACT1(VU-1)
  Endif
  VU = find("SFRPT",[M]CODACT1(0..[M]NBLIG1))
  If VU and [M]FLACT1(VU-1) = 2
   [M]FLACT1(VU-1) = 1
   Affzo [M]FLACT1(VU-1)
  Endif
 Endif
 If [M]CODACT1(nolign-1)="T1000" & VALEUR=2
  VU = find("SCTE",[M]CODACT1(0..[M]NBLIG1))
  If VU and [M]FLACT1(VU-1) = 2
   [M]FLACT1(VU-1) = 1
   Affzo [M]FLACT1(VU-1)
  Endif
  VU = find("SFRPT",[M]CODACT1(0..[M]NBLIG1))
  If VU and [M]FLACT1(VU-1) = 2
   [M]FLACT1(VU-1) = 1
   Affzo [M]FLACT1(VU-1)
  Endif
 Endif
 If [M]CODACT1(nolign-1)="SFRPT" & VALEUR=2
  VU = find("T1000",[M]CODACT1(0..[M]NBLIG1))
  If VU and [M]FLACT1(VU-1) = 2
   [M]FLACT1(VU-1) = 1
   Affzo [M]FLACT1(VU-1)
  Endif
  VU = find("SCTE",[M]CODACT1(0..[M]NBLIG1))
  If VU and [M]FLACT1(VU-1) = 2
   [M]FLACT1(VU-1) = 1
   Affzo [M]FLACT1(VU-1)
  Endif
 Endif
Endif

#--- Dem 78067
# Pas d'activation de la gestion de dépôt
#If [M]CODACT1(nolign-1)="WRH" & VALEUR=2
#   GMESSAGE=mess(634,177,1) : mkstat=2
#   VALEUR=1
#Endif

# Si gestion dépôt alors gestion emplacement
If [M]CODACT1(nolign-1)="WRH" & VALEUR = 2
 VU = find("EMP",[M]CODACT1(0..[M]NBLIG1))
 If VU & [M]FLACT1(VU-1) = 1
  [M]FLACT1(VU-1) = 2
  Affzo [M]FLACT1(VU-1)
 Endif
# Si pas gestion emplacement alors pas gestion dépôt
Elsif [M]CODACT1(nolign-1)="EMP" & VALEUR = 1
 VU = find("WRH",[M]CODACT1(0..[M]NBLIG1))
 If VU & [M]FLACT1(VU-1) = 2
  [M]FLACT1(VU-1) = 1
  Affzo [M]FLACT1(VU-1)
 Endif
Endif

# FGR 16/10/2009 : X3SUIVI58869 (début)
# Si gestion du Xtend : si AYT vaut "NON", TCAYT vaut aussi "NON". Si AYT vaut "OUI", TCAYT vaut "OUI" ou "NON"
If [M]CODACT1(nolign-1)="AYT" and VALEUR = 1 Then
  VU = find("TCAYT",[M]CODACT1(0..[M]NBLIG1))
  If VU and [M]FLACT1(VU-1) = 2 Then
    [M]FLACT1(VU-1) = 1
    Affzo [M]FLACT1(VU-1)
   Endif
  # et inversement si TCAYT vaut "OUI", AYT vaut aussi "OUI"
Elsif [M]CODACT1(nolign-1)="TCAYT" and VALEUR = 2 Then
  VU = find("AYT",[M]CODACT1(0..[M]NBLIG1))
  If VU and [M]FLACT1(VU-1) = 1 Then
    [M]FLACT1(VU-1) = 2
    Affzo [M]FLACT1(VU-1)
  Endif
Endif
# FGR 16/10/2009 : X3SUIVI58869 (fin)
# Issue 116137 - 2016-04-21 by MAE : si pas de gestion lot, pas d'ECC
If [M]CODACT1(nolign-1)="LOT" & VALEUR = 1
 VU = find("ECC",[M]CODACT1(0..[M]NBLIG1))
 If VU & [M]FLACT1(VU-1) = 2
  [M]FLACT1(VU-1) = 1
  Affzo [M]FLACT1(VU-1)
 Endif
Endif
If [M]CODACT1(nolign-1)="ECC" & VALEUR = 2
 VU = find("LOT",[M]CODACT1(0..[M]NBLIG1))
 If VU & [M]FLACT1(VU-1) = 1
  Call ERREUR(func AFNC.MES2(mess(258,125,1), "ECC", "LOT")) From GESECRAN
  mkstat=2
 Endif
Endif
# End issue 116137

# Issue X3FEAT-345 - 2017-11-10 by MAE : Gestion du code activité LPN
# Si pas de code activité EMP, pas de LPN
If [M]CODACT1(nolign-1)="EMP" & VALEUR = 1
 VU = find("LPN",[M]CODACT1(0..[M]NBLIG1))
 If VU & [M]FLACT1(VU-1) = 2
  [M]FLACT1(VU-1) = 1
  Affzo [M]FLACT1(VU-1)
 Endif
Endif
If [M]CODACT1(nolign-1)="LPN" & VALEUR = 2
 VU = find("EMP",[M]CODACT1(0..[M]NBLIG1))
 If VU & [M]FLACT1(VU-1) = 1
  Call ERREUR(func AFNC.MES2(mess(258,125,1), "LPN", "EMP")) From GESECRAN
  mkstat=2
 Endif
Endif
# End issue X3FEAT-345


