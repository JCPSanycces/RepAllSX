####################################################################################
# Ce sous-programme est appellé depuis le Subprog CHARGE_ACV From SUBADS
# CHARGE_ACV est callé depuis la gestion des dossiers ou la validation de dossier
# Il n'y a que les écrans ADS2 ADS6 ADS7 qui sont ouverts en validation de dossier
####################################################################################

$SET_ACV

# Vérification de l'autorisation IAS

If ACTCOD="IAS"
 If fmet GACTX.AGETLICACV("IAS") = [V]CST_AFALSE
  [M:ADS6]FLACT1([M:ADS6]NBLIG1) = 1
 Endif
Endif

# Désactivation du code VAT pour un exclusivement dossier américain

If ACTCOD="VAT"
 Local Integer XLEG, DOSUSA
 Read [ADA]ADA0 = [L]DOSSIER;"USA"
 If !fstat & [F:ADA]FLACT=2
  DOSUSA = 1
  For XLEG=0 To [L]NBLEG-1
   If !find([L]DOSLEG(XLEG),"USA","")
    [M:ADS6]FLACT1([M:ADS6]NBLIG1) = 2
    DOSUSA = 0 : Break
   Endif
  Next
  If DOSUSA
   [M:ADS6]FLACT1([M:ADS6]NBLIG1) = 1
  Endif
 Else
  [M:ADS6]FLACT1([M:ADS6]NBLIG1) = 2
 Endif
 fstat = 0
Endif

# Immobilisation

If ACTCOD="FAS"
 [M:ADS6]FLACT1([M:ADS6]NBLIG1) = [L]MODULE(13)
Endif
Return

###############################################################
## Appelée en avant saisie des modules
## Pour imposer ou refuser un module ([M]MODULE)
## ou
###############################################################
$AS_MODULE
[M]MODULE(0)  = 2 : # Superviseur
[M]MODULE(8)  = 2 : # Tronc commun
[M]MODULE(10) = 1 : # Interne X3
[M]MODULE(3)  = 1 : # Immos
Return

###############################################################
## Appelée en contrôle des modules
## Pour gérér les dépendances
###############################################################
$C_MODULE
## 1) Modules obligatoires
If find(nolign,1,9) : # Superviseur et tronc commun
 VALEUR = 2
Else
## 2) Modules qui en implique un autre
 If VALEUR=2
  Local Integer MODU
  MODU = 0
  Case nolign
   When 2 : # Compta => Compta tiers
    MODU = 3
   When 3 : # Compta tiers => compta
    MODU = 2
   When 5,6,8 : # Ventes, achats, GPAO => stocks
    MODU = 7
   When 12,13 : # CRM => ventes => stocks
    MODU = 5 : Gosub SETMOD
    MODU = 7
  Endcase
  Gosub SETMOD
 Endif
 ## 2 bis) Contrôle réciproque
 If VALEUR=1
  Case nolign
   When 5 : # On vire les ventes
    [M]MODULE(11) = 1 : [M]MODULE(12) = 1
    Affzo MODULE(11),MODULE(12)
   When 7 : # On vire les stocks
    [M]MODULE(4) = 1 : [M]MODULE(5) = 1 : [M]MODULE(7) = 1
    Affzo MODULE(4),MODULE(5),MODULE(7)
   When 2,3 : # On vire la compta, compta tiers
    [M]MODULE(1) = 1 : [M]MODULE(2) = 1
    Affzo MODULE(1),MODULE(2)
  Endcase
 Endif
 ## 3) Module interdit
 If nolign=11
  If GADONIX<>2 : VALEUR = 1 : Endif
 Endif
Endif
Return

$SETMOD
If MODU
 If [M]MODULE(MODU-1)<>2
  GMODIF = 1
  [M]MODULE(MODU-1) = 2
  If !GIMPORT : Affzo MODULE(MODU-1) : Endif
 Endif
Endif
Return

###############################################################
## Appelée en contrôle des options d'init
## Pour gérer les dépendances
###############################################################
$C_OPTINI
If VALEUR=2
 Local Integer I, J, K1, K2, K3
 J = nolign
 Raz K1, K2, K3
 Case J
  When 12 : # Paramètres budgets => plan comptable ana
   K1 = 10
  When 14 : # Banques => sociétés/sites + plan comptable géné
   K1 = 6 : K2 = 9
  When 15 : # Paramètres immos => tables diverses
   K1 = 2
  When 16 : # Données immos => sociétés/sites + tables diverses
   K1 = 6 : K2 = 2
  When 17 : # Tableaux de bord => sociétés/sites
   K1 = 6
  When 13 : # Référentiel tiers => tables diverses
   K1 = 2
 Endcase
 For I=K1,K2,K3
  If I & [M]OPTINI(I-1)<>2
   [M]OPTINI(I-1) = 2 : Affzo OPTINI(I-1)
  Endif
 Next I
Endif
Return

###############################################################
## Appelée en validation dossier
## - Copie des Textes Clob liés aux tables BPCUSTOMER
##   BPCUSTOMER / BPDLVCUST / BPSUPPLIER
###############################################################
$DOSCOP
If find("BPCUSTOMER",TBCOP(1..NBCOP))
 Call COPIE("TEXCLOB","CODE","BPC") From TRTX3TEX
Endif
If find("BPDLVCUST",TBCOP(1..NBCOP))
 Call COPIE("TEXCLOB","CODE","BPD") From TRTX3TEX
Endif
If find("BPSUPPLIER",TBCOP(1..NBCOP))
 Call COPIE("TEXCLOB","CODE","BPS") From TRTX3TEX
Endif

Return
###############################################################

$VERIF

  If GPRODUIT = 2
    If [F:ADS]DOSSIER <> GDOSX3
      If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
        If clalev([F:ADWHR])=0 : Local File =LDOSSIER+".ADOVAL" [ADWHR] : Endif
        Read [F:ADWHR]ADW0 = "";"";"RELEASE"
        If [F:ADWHR]VALEUR >= "60" and [F:ADWHR]VALEUR <= "69"
          If clalev([F:ADI]) = 0 : Local File ATABDIV [F:ADI] : Endif
          If clalev([F:AXX]) = 0 : Local File ATEXTRA [F:AXX] : Endif
#          Local Char TITLE(250)
          Local Integer C, CNT, SELECTED_LEG
          Local Char LOCALIZATIONS(250)(0..), LEGISLATIONS(250)(1..), DISPLAY_LEG(250)(1..), LOCALMSG(250), VALMSK(30)

          For C = 1 To [M:ADS6]NBLIG2
            If [M:ADS6]FLACT2(C-1) = 2
              [L]LOCALIZATIONS(CNT) = [M:ADS6]CODACT2(C-1)
              CNT += 1
              LOCALMSG += [M:ADS6]CODACT2(C-1) + ", "
            Endif
          Next
          If len(LOCALMSG) > 0
            LOCALMSG = left$(LOCALMSG,len(LOCALMSG)-1)
          Endif

          CNT = 0
          For [F:ADI] Where [F:ADI]NUMTAB=10302 and find([F:ADI]A1, [L]LOCALIZATIONS) > 0
            CNT += 1
            Read [F:AXX]AXX0 = "ATABDIV";"LNGDES";"ENG";"10302";[F:ADI]CODE
            If !fstat
              DISPLAY_LEG(CNT) = [F:ADI]CODE-"-"-[F:AXX]TEXTE
            Else
              DISPLAY_LEG(CNT) = [F:ADI]CODE
            Endif
            LEGISLATIONS(CNT) = [F:ADI]CODE#-"-"-[F:AXX]TEXTE
          Next

          If [M:ADS4]DOSLEG <> LEGISLATIONS(1)
#            TITLE = mess(265,10702,1)
#            TITLE = ctrans(TITLE,"$1$",LOCALMSG)

#            Call SAITEX(CNT,DISPLAY_LEG,SELECTED_LEG,TITLE) From GESECRAN
            Call SAISIE_CHAR(VALMSK,DISPLAY_LEG,"OLEGSEL","SUBLEGSEL","") From GSAISIE

#            If SELECTED_LEG > 0
            If dim(GGESADSDOSLEG) > 0
#              [M:ADS4]DOSLEG = LEGISLATIONS(SELECTED_LEG)
              [M:ADS4]DOSLEG = LEGISLATIONS(GGESADSDOSLEG)
              Affzo [M:ADS4]20
              Read [F:ADWHR]ADW0 = "";"";"DOSLEG"
              If !fstat
#                [F:ADWHR]VALEUR = LEGISLATIONS(SELECTED_LEG)
                [F:ADWHR]VALEUR = LEGISLATIONS(GGESADSDOSLEG)
                Rewrite [F:ADWHR]
              Endif
              Kill GGESADSDOSLEG
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif

Local Integer IND, IND2

# Interface trésorerie, une seule interface trésorerie ne peut être cochée.
If GADONIX<>2
 IND = find("SCTE",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
 If IND & [M:ADS6]FLACT1(IND-1)=2
  IND2 = find("T1000",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
  If IND2 & [M:ADS6]FLACT1(IND2-1)=2
   GMESSAGE = mess(14,115,1)-"SCTE"-tolower(mess(2,8,1))-"&"-mess(14,115,1)-"T1000"-tolower(mess(2,8,1))
    OK=0 : Return
  Endif
  IND2 = find("SFRPT",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
  If IND2 & [M:ADS6]FLACT1(IND2-1)=2
  GMESSAGE = mess(14,115,1)-"SCTE"-tolower(mess(2,8,1))-"&"-mess(14,115,1)-"SFRPT"-tolower(mess(2,8,1))
   OK=0 : Return
  Endif
 Endif
 IND = find("T1000",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
 If IND & [M:ADS6]FLACT1(IND-1)=2
  IND2 = find("SCTE",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
  If IND2 & [M:ADS6]FLACT1(IND2-1)=2
  GMESSAGE = mess(14,115,1)-"T1000"-tolower(mess(2,8,1))-"&"-mess(14,115,1)-"SCTE"-tolower(mess(2,8,1))
   OK=0 : Return
  Endif
  IND2 = find("SFRPT",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
  If IND2 & [M:ADS6]FLACT1(IND2-1)=2
   GMESSAGE = mess(14,115,1)-"T1000"-tolower(mess(2,8,1))-"&"-mess(14,115,1)-"SFRPT"-tolower(mess(2,8,1))
    OK=0 : Return
  Endif
 Endif
 IND = find("SFRPT",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
 If IND & [M:ADS6]FLACT1(IND-1)=2
  IND2 = find("SCTE",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
  If IND2 & [M:ADS6]FLACT1(IND2-1)=2
  GMESSAGE = mess(14,115,1)-"SFRPT"-tolower(mess(2,8,1))-"&"-mess(14,115,1)-"SCTE"-tolower(mess(2,8,1))
   OK=0 : Return
  Endif
  IND2 = find("T1000",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
  If IND2 & [M:ADS6]FLACT1(IND2-1)=2
  GMESSAGE = mess(14,115,1)-"SFRPT"-tolower(mess(2,8,1))-"&"-mess(14,115,1)-"T1000"-tolower(mess(2,8,1))
   OK=0 : Return
  Endif
 Endif
Endif

# FGR 04/01/2010 : X3SUIVI61177 (début)
# Ca vu avec TS : autant le faire aussi.
# Si pas gestion emplacement alors pas gestion dépôt
IND = find("EMP",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
If IND & [M:ADS6]FLACT1(IND-1) = 1
 IND2 = find("WRH",[M]CODACT1(0..[M]NBLIG1))
 If IND2 & [M]FLACT1(IND2-1) = 2
  [M]FLACT1(IND2-1) = 1
 Endif
Endif
# Si gestion du Xtend : si AYT vaut "NON", TCAYT vaut aussi "NON". Si AYT vaut "OUI", TCAYT vaut "OUI" ou "NON"
IND = find("AYT",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
If IND and [M:ADS6]FLACT1(IND-1) = 1 Then
  IND2 = find("TCAYT",[M]CODACT1(0..[M]NBLIG1))
  If IND2 and [M]FLACT1(IND2-1) = 2 Then
    [M]FLACT1(IND2-1) = 1
   Endif
Endif
# FGR 04/01/2010 : X3SUIVI61177 (fin)
# Issue 116357 - 2016-04-21 by MAE : Si pas de gestion de lot, pas d'ECC
IND = find("LOT",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
If IND & [M:ADS6]FLACT1(IND-1) = 1
 IND2 = find("ECC",[M]CODACT1(0..[M]NBLIG1))
 If IND2 & [M]FLACT1(IND2-1) = 2
  [M]FLACT1(IND2-1) = 1
 Endif
Endif

# Issue X3FEAT-345 - 2017-11-10 by MAE : Pas de gestion des emplacements, pas de gestion des LPPN
IND = find("EMP",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
If IND & [M:ADS6]FLACT1(IND-1) = 1
 IND2 = find("LPN",[M]CODACT1(0..[M]NBLIG1))
 If IND2 & [M]FLACT1(IND2-1) = 2
  [M]FLACT1(IND2-1) = 1
 Endif
Endif
# End issue X3FEAT-345

# Si le module 'comptabilité' est actif, le code activité CPT doit être à oui (par contre l'inverse n'est pas forcément vrai - F61321)
If [M:ADS1]MODULE(1)=2
 IND = find("CPT",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
 If IND & [M:ADS6]FLACT1(IND-1)<>2
  GMESSAGE = mess(14,115,1)-"CPT"-tolower(mess(1,8,1))-"&"-mess(10,144,1)-mess(2,14,1)-tolower(mess(2,8,1))
  OK=0 : Return
 Endif
Endif

# Module Compta & Compta-Tiers doivent avoir le même statut. (F61321)
If [M:ADS1]MODULE(1)<>[M:ADS1]MODULE(2)
 GMESSAGE = mess(10,144,1)-mess(2,14,1)-tolower(mess(2,8,1))-"&"-mess(10,144,1)-mess(3,14,1)-tolower(mess(1,8,1))
 OK=0 : Return
Endif

# Issue 115092
# Si code activité PHY inactif, alors PHN doit être à 0 et inversement
IND = find("PHY",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
If IND
  If [M:ADS6]FLACT1(IND - 1) = [V]CST_AYES
    IND = find("PHN",[M:ADS2]CODACT3(0..[M:ADS2]NBLIG3-1))
    If IND and [M:ADS2]DIME3(IND - 1) < [M:ADS2]DIMIN3(IND - 1)
      [M:ADS2]DIME3(IND - 1) = [M:ADS2]DIMIN3(IND - 1)
    Endif
  Else
    IND = find("PHN",[M:ADS2]CODACT3(0..[M:ADS2]NBLIG3-1))
    If IND
      [M:ADS2]DIME3(IND - 1) = 0
    Endif
  Endif
Endif
# End Issue 115092

# Issue 105932_2 - 2016-04-14 by MDJ : PRCSL and CSL can't be both equal to "Yes"
IND = find("PRCSL",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
If IND & [M:ADS6]FLACT1(IND-1)=[V]CST_AYES
  IND2 = find("CSL",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
  If IND2 & [M:ADS6]FLACT1(IND2-1)=[V]CST_AYES
   GMESSAGE = func AFNC.MES2(mess(658,199,1), "PRCSL", "CSL")
   OK=0 : Return
 Endif
Endif
# End Issue 105932_2

#JASMI - 2018-01-11 - X3-71126 - START
If [M:ADS1]MODULE(15-1)<>2
  Call X3PEOPLE_CONTROL("DCP")
  Call X3PEOPLE_CONTROL("EQM")
  Call X3PEOPLE_CONTROL("HREMP")
  Call X3PEOPLE_CONTROL("HRESS")
  Call X3PEOPLE_CONTROL("HRFRM")
  Call X3PEOPLE_CONTROL("HRPAY")
  Call X3PEOPLE_CONTROL("INTMT")
  Call X3PEOPLE_CONTROL("LOA")
  Call X3PEOPLE_CONTROL("MAS")
  Call X3PEOPLE_CONTROL("PAI")
  Call X3PEOPLE_CONTROL("PORMI")
  Call X3PEOPLE_CONTROL("PYS")
  Call X3PEOPLE_CONTROL("TPS")
Endif
If [M:ADS1]MODULE(20-1)<>2
  Call X3PEOPLE_CONTROL("CAR")
  Call X3PEOPLE_CONTROL("FRT")
  Call X3PEOPLE_CONTROL("HRHRM")
Endif
#JASMI - 2018-01-11 - X3-71126 - END

#JASMI - 2018-01-30 - X3-74808 - START
If GPRODUIT=2 #X3 People
  IND=find("LEG",[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
  If IND & [M:ADS6]FLACT1(IND-1)=1 : [M:ADS6]FLACT1(IND-1)=2 : Endif
Endif
#JASMI - 2018-01-30 - X3-74808 - END

#LIPET - 2018-02-22 - X3-37942 - START
If clalev([F:ADI1])=0 : Local File ATABDIV  [ADI1] : Endif
Filter [F:ADI1] Where [F:ADI1]NUMTAB  = 10302
For nolign=1 To dim([M:ADS6]CODACT2)
  If [M:ADS6]CODACT2(nolign-1) <> "" & [M:ADS6]FLACT2(nolign-1) = 2 Then
    For [ADI1] Where [ADI1]A1=[M:ADS6]CODACT2(nolign-1)
      IND=find([ADI1]CODE,[M:ADS4]DOSLEG(0..[M:ADS4]NBLEG-1))
      If IND=0
         #For activity code XXX, legislation XXX must be added to the folder
         GERR=1: GMESSAGE = func AFNC.MES2(mess(260,10702,1), [M:ADS6]CODACT2(nolign-1),[ADI1]CODE) : Break 2
      Endif
    Next
  Endif
Next
Filter [F:ADI1]
#LIPET - 2018-02-22 - X3-37942 - END

Return

#JASMI - 2018-01-11 - X3-71126 - START
Subprog X3PEOPLE_CONTROL(THISACTIVITYCODE)
Value Char THISACTIVITYCODE
Local Integer IND

  IND=find(THISACTIVITYCODE,[M:ADS6]CODACT1(0..[M:ADS6]NBLIG1-1))
  If IND & [M:ADS6]FLACT1(IND-1)=2 : [M:ADS6]FLACT1(IND-1)=1 : Endif

End
#JASMI - 2018-01-11 - X3-71126 - END

$C_TSTFLG
#If KPO active and the folder is already generated, TSTFLG cannot be changed
Local Integer KPOIDX
KPOIDX = find("KPO",[M:ADS6]CODACT2(0..[M:ADS6]NBLIG2))

If KPOIDX > 0
  If [M:ADS6]FLACT2(KPOIDX-1) = 2
    If filinfo(filpath("FIL","AUTILIS","fde",[M:ADS0]DOSSIER),0) > 0
      mkstat = 2
      GERR = 1 : GMESSAGE = mess(9,123,1)
    Endif
  Endif
Endif

Return


# Issue X3-7276 - 2017-02-07 by CCC : copy JSNX3HEAD & JSNX3DET
# Data of these tables will be copied in all cases of folder validation (direct validation or migration)
# This is necessary to be sure to have good data in these tables even if we create maintenances
$COPY_JSNX3

If  func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)<>0
& | nomap=[F:ADS]DOSSIER
    Return
Endif

Local Integer ERR

Onerrgo ERRCOP
#----- Check existence of files used by Json mapping -----#
If  filinfo(filpath("FIL","JSNX3HEAD","fde",[F:ADS]DOSSIER),0) < 0 : Return : Endif
If  filinfo(filpath("FIL","JSNX3DET","fde",[F:ADS]DOSSIER),0) < 0 : Return : Endif
If  filinfo(filpath("FIL","JSNX3TRAN","fde",[F:ADS]DOSSIER),0) < 0 : Return : Endif
Local File =[F:ADS]DOSSIER+".JSNX3HEAD" [JXH]
Local File =[F:ADS]DOSSIER+".JSNX3DET"  [JXD]
Local File =[F:ADS]DOSSIER+".JSNX3TRAN" [JXT]
Local File JSNX3HEAD  [JXHM]
Local File JSNX3DET   [JXDM]
Local File JSNX3TRAN  [JXTM]
Read [JXHM] First   # Security for rights
Onerrgo
If ERR=1
    Return
Endif

GOK=1
Trbegin [JXD]

Delete [JXD] Where 1=1
Delete [JXH] Where 1=1
Delete [JXT] Where 1=1

For [JXHM]
    [F:JXH] = [F:JXHM]
    Write [JXH]
    If fstat
        Call FSTA("JXH") From GLOCK
        GOK = 0
        Break
    Endif
Next
If GOK
    For [JXDM]
        [F:JXD] = [F:JXDM]
        Write [JXD]
        If fstat
            Call FSTA("JXD") From GLOCK
            GOK = 0
            Break
        Endif
    Next
Endif
If GOK
    For [JXTM]
        [F:JXT] = [F:JXTM]
        Write [JXT]
        If fstat
            Call FSTA("JXT") From GLOCK
            GOK = 0
            Break
        Endif
    Next
Endif

If GOK=1
    Commit
Else
    Rollback
Endif
Close Local File [JXH]
Close Local File [JXD]
Close Local File [JXT]
Close Local File [JXHM]
Close Local File [JXDM]
Close Local File [JXTM]

Return

$ERRCOP
Call ECR_TRACE(num$(errl)-errp-errmes$(errn)-errm,-1) From GESECRAN
ERR=1
Resume

$SHOW_MIGRATION_MSG
  If dim(GSHOWMIGMSG) = 0
    Global Integer GSHOWMIGMSG
  Endif

  If ACTION = "LIENS"
    GSHOWMIGMSG = 1
  Else
    GSHOWMIGMSG = 0
  Endif
Return

##PEVAN - 2018-02-15 - X3-77380 - START
$MIGRATION_CHECK
  If dim(GSHOWMIGMSG) > 0 and GSHOWMIGMSG = 1
    Local Char LDOSSIER(250), LVERSION(250)
    If GPRODUIT <> 2 : Return : Endif
    LDOSSIER = [F:ADS]DOSSIER
    If LDOSSIER <> GDOSX3
      If filinfo(filpath("FIL","ADOVAL","fde",[L]LDOSSIER),0)>0
        If clalev([F:ADWHR])=0 : Local File =LDOSSIER+".ADOVAL" [ADWHR] : Endif
        Read [F:ADWHR]ADW0 = "";"";"RELEASE"
        LVERSION = [F:ADWHR]VALEUR
        If LVERSION >= "60" and LVERSION <= "69"
          Local Integer OKCAN, L
          OKCAN = 1
          Call AVERTIR(mess(167,100,1)+","-LDOSSIER-mess(263,10702,1)+"\"+mess(264,10702,1), OKCAN) From GESECRAN
          If OKCAN = 2
            Call OUVRE_TRACE("Pre VALDOS scripts on "+LDOSSIER+" (Automatic process GESADS)") From LECFIC
            If !clalev([F:WACV]) : Local File ACTIV [F:WACV] : Endif
            For L = 1 To NBRMOD
              If (L=1 | L=9 | L=10 | L=15 | L=20)
                [M:ADS1]MODULE(L-1) = 2
                [M:ADS4]TRVAL(L-1) = 2
              Else
                [M:ADS1]MODULE(L-1) = 1
                [M:ADS4]TRVAL(L-1) = 1
              Endif
            Next
            Call CHARGE_ACV([M:ADS0]DOSSIER,[M:ADS1]DOSREF,[M:ADS4]NBLEG,[M:ADS4]DOSLEG,[M:ADS1]MODULE) From SUBADS
            Affzo [M:ADS1]60
            Affzo [M:ADS4]5
            Call ECR_TRACE("Switched off all modules and switched on 1, 9, 10, 15, 20",0) From GESECRAN

            Local Integer C
            For C = 1 To [M:ADS6]NBLIG1
              If !find([M:ADS6]MODULE1(C-1), 1, 9, 10, 15, 20)
                [M:ADS6]FLACT1(C-1) = 1
              Else
                Read [F:WACV]CODACT = [M:ADS6]CODACT1(C-1)
                If !fstat
                  Call ECR_TRACE("Found ACTIVITY CODE: " + [M:ADS6]CODACT1(C-1) + " on PAIE folder. Setting to " + num$([F:WACV]FLACT),0) From GESECRAN
                  [M:ADS6]FLACT1(C-1) = [F:WACV]FLACT
                Else
                  Call ECR_TRACE("Not Found ACTIVITY CODE: " + [M:ADS6]CODACT1(C-1) + " on PAIE folder. Setting to off (1).",0) From GESECRAN
                  [M:ADS6]FLACT1(C-1) = 1
                Endif
              Endif
              Affzo [M:ADS6]20
            Next
            Affzo [M:ADS6]10
            Call ECR_TRACE("Activated and de-activated activity codes in modules 1, 9, 10, 15, 20",0) From GESECRAN

            If clalev([F:HRACV]) = 0 : Local File =LDOSSIER+".ACTIV" [HRACV] : Endif
            For C = 1 To [M:ADS6]NBLIG1
              If find([M:ADS6]CODACT1(C-1),"HRCIG") > 0
                Read [F:HRACV]CODACT = "CIG"
                If !fstat
                  [M:ADS6]FLACT1(C-1) = [F:HRACV]FLACT
                Endif
              Elsif find([M:ADS6]CODACT1(C-1),"HRCPC") > 0
                Read [F:HRACV]CODACT = "CPC"
                If !fstat
                  [M:ADS6]FLACT1(C-1) = [F:HRACV]FLACT
                Endif
              Elsif find([M:ADS6]CODACT1(C-1),"HRDEM") > 0
                Read [F:HRACV]CODACT = "DEMAT"
                If !fstat
                  [M:ADS6]FLACT1(C-1) = [F:HRACV]FLACT
                Endif
              Elsif find([M:ADS6]CODACT1(C-1),"HREMP") > 0
                Read [F:HRACV]CODACT = "EMP"
                If !fstat
                  [M:ADS6]FLACT1(C-1) = [F:HRACV]FLACT
                Endif
              Elsif find([M:ADS6]CODACT1(C-1),"HRFRM") > 0
                Read [F:HRACV]CODACT = "FRM"
                If !fstat
                  [M:ADS6]FLACT1(C-1) = [F:HRACV]FLACT
                Endif
              Elsif find([M:ADS6]CODACT1(C-1),"HRNOF") > 0
                Read [F:HRACV]CODACT = "NOF"
                If !fstat
                  [M:ADS6]FLACT1(C-1) = [F:HRACV]FLACT
                Endif
              Elsif find([M:ADS6]CODACT1(C-1),"HRPAY") > 0
                Read [F:HRACV]CODACT = "PAY"
                If !fstat
                  [M:ADS6]FLACT1(C-1) = [F:HRACV]FLACT
                Endif
              Else
                Read [F:HRACV]CODACT = [M:ADS6]CODACT1(C-1)
                If !fstat
                  [M:ADS6]FLACT1(C-1) = [F:HRACV]FLACT
                Endif
              Endif
            Next
            Affzo [M:ADS6]10
            Close File [F:HRACV]
            Call ECR_TRACE("Looped through the U9 folder activity codes and assigned the active flag value to the screen",0) From GESECRAN

            For C = 1 To [M:ADS6]NBLIG2
              If [M:ADS6]CODACT2(C-1)="KSCO" | [M:ADS6]CODACT2(C-1)="KSA"
                [M:ADS6]FLACT2(C-1) = 1
              Endif
            Next
            Affzo [M:ADS6]20

            Call ECR_TRACE("Folder placed in modification mode",0) From GESECRAN
            Call ECR_TRACE("Folder ready to be validated",0) From GESECRAN
            REP="M"
#            Call OUVRE_TRACE("Pre VALDOS scripts") From LECFIC
#            Call UTI_MOUL(LDOSSIER) From EMHRMAJ90_FLD
#            Call UTI_MOUL(LDOSSIER) From EMHRMAJ90_TXT
            Call FERME_TRACE From LECFIC
            Local Char MSG(250)(1..)
            MSG(1) = mess(261,10702,1) - LDOSSIER
            Call INFO(MSG, 1, mess(2,585,1)) From GESECRAN
          Endif
        Endif
        Close File [ADWHR]
      Endif
    Endif
  Endif
  If dim(GSHOWMIGMSG) > 0
    Kill GSHOWMIGMSG
  Endif
Return
##PEVAN - 2018-02-15 - X3-77380 - END

