Close Mask
Raz GPILOBJ , GNBMASKOUV
GBIDC1 = ""
Call OBJET("ADS",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "AS_FLACT1"    : Gosub AS_FLACT1
 When "C_FLACT1"     : Gosub C_FLACT1
 When "C_FLACT2"     : Gosub C_FLACT2
 When "SET_ACV"      : Gosub SET_ACV
 When "AS_MODULE"    : Gosub AS_MODULE
 When "C_MODULE"     : Gosub C_MODULE
 When "C_OPTINI"     : Gosub C_OPTINI
 When "AS_LIBMOD"    : Gosub AS_LIBMOD
#---------------------------------------
 When "VERIF"        : Gosub VERIF
 When "VERFDOS"      : Gosub VERFDOS
 When "DICO"         : Gosub DICO         # FGR 25/07/2011 : X3SUIVI75276
 When "DOSCOP"       : Gosub DOSCOP
 When "FINDOS"       : Gosub FINDOS
##PEVAN - 2018-02-15 - X3-77380 - START
 When "SETBOUT"      : Gosub MIGRATION_CHECK
 When "LIENS"        : Gosub SHOW_MIGRATION_MSG
 When "ABANDON"      : Gosub SHOW_MIGRATION_MSG
##PEVAN - 2018-02-15 - X3-77380 - END
Endcase
Return

$FINDOS
# Issue X3-7276 - 2017-02-07 by CCC : copy JSNX3HEAD & JSNX3DET
If !GCRE
    Gosub COPY_JSNX3
Endif

# Validation dictionnaire sur aws-x3-qaintall (solutions QA*) ou aws-x3-indxxxx (solution indus.) suite au transfert des corrections de X3DEV
If !GCRE &
&   (nomap="X3" & (instr(1,tolower(adxmac(-1)),"aws-x3-qaintall") & adxtcp=18018)
&   | nomap="X3INDCHALL" & instr(1,tolower(adxmac(-1)),"aws-x3-indchall") & adxtcp=20100)
&  & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 : #107271
 If filinfo(filpath("TRT","XVALDICO","adx"),0)>0
  Call ECR_TRACE("Open files:"-sigma(0,[S]dbglong(11),string$(filelev(indcum+1)<>0,[S]fileabre(indcum+1)+",")),0) From GESECRAN
  If clalev([F:ATX])<>0 : Close Local File  [ATX] : Endif
  If clalev([F:ACV])<>0 : Close Local File  [ACV] : Endif
  Call VALID([F:ADS]DOSSIER) From XVALDICO
 Endif
Endif
# Validation dictionnaire sur les dossiers filles de la solution de développement suite au transfert des corrections du Superviseur
If !GCRE &
&   (nomap="GX3APP" & (instr(1,tolower(adxmac(-1)),"aws-x3-devx3") & adxtcp=2050)
&   | nomap="X3DEV" & instr(1,tolower(adxmac(-1)),"aws-x3-devx3") & adxtcp=2060)
&  & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 : #107271
 If filinfo(filpath("TRT","XXVALDICO","adx"),0)>0
  Call ECR_TRACE("Open files:"-sigma(0,[S]dbglong(11),string$(filelev(indcum+1)<>0,[S]fileabre(indcum+1)+",")),0) From GESECRAN
  If clalev([F:ATX])<>0 : Close Local File  [ATX] : Endif
  If clalev([F:ACV])<>0 : Close Local File  [ACV] : Endif
  Call VALID([F:ADS]DOSSIER) From XXVALDICO
 Endif
Endif

# Issue X3-113885
# create the recurring task for accounting task

  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER) = 0 # X3-115384
    Call ECR_TRACE("Accounting recurring task migration. BTC/ABA", 0) From GESECRAN
    Call ECR_TRACE("Start of process on : " + [F:ADS]DOSSIER, 0) From GESECRAN
    Call MAJ_UTIFIN001([F:ADS]DOSSIER, [V]CST_ANO, [V]CST_ANO) From UTIFIN001GEN
  Endif
# End Issue X3-113885

Return

$VERFDOS
If !GCRE
 Call VERSION([F:ADS]DOSSIER,DOSVERS) From DOSSUB
 If val(DOSVERS)<14
  If (filinfo(filpath("TRT","VERIFMAJ14","adx"),0)>0)
    Call VERIF(OK) From VERIFMAJ14
  Endif
 Endif
 If val(DOSVERS)<30
  If (filinfo(filpath("TRT","VERIFMAJ30","adx"),0)>0)
   Call VERIF(OK) From VERIFMAJ30
  Endif
 Endif
 If val(DOSVERS)<70
  If (filinfo(filpath("TRT","VERIFMAJ70","adx"),0)>0)
   Call VERIF(OK) From VERIFMAJ70
  Endif
 Endif
Endif
