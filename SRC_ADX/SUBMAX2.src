#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion du masque MAX2
########################################
Subprog AS_NBOPG
Local Char SZTBLTYP
SZTBLTYP = ""
If nolign - 1 >= dim([M:MAX2]OPGNUM) - 1
    End
Endif
If nolign > 0
    If GSZPREOPG <> [M:MAX2]OPGNUM(nolign - 1)
        GSZPREOPG = [M:MAX2]OPGNUM(nolign - 1)
        Call LOADOPGINF([M:MAX2]OPGNUM(nolign - 1), SZTBLTYP) From TRTMAX2
        Call LOADSEL([M:MAX2]OPGNUM(nolign - 1), SZTBLTYP) From TRTMAX2
        Affzo [M:MAX2]
    Endif
Endif
End

########################################
Subprog C_NBOPG
Local Char SZTBLTYP
SZTBLTYP = ""
If nolign - 1 >= dim([M:MAX2]OPGNUM) - 1
    End
Endif
If nolign > 0
    If GSZPREOPG <> [M:MAX2]OPGNUM(nolign - 1)
        GSZPREOPG = [M:MAX2]OPGNUM(nolign - 1)
        Call LOADOPGINF([M:MAX2]OPGNUM(nolign - 1), SZTBLTYP) From TRTMAX2
        Call LOADSEL([M:MAX2]OPGNUM(nolign - 1), SZTBLTYP) From TRTMAX2
        Affzo [M:MAX2]
    Endif
Endif
End

