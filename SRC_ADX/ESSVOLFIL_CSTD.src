#<AdxTL>@(#)0.0.0.0 $Revision$ File
# Classe AVOLFIL

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AINSERT_AFTER"                : Gosub AINSERT
      When "AUPDATE_AFTER"                : Gosub AUPDATE
      When "AREAD_AFTER"                  : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When 'CONTENTS'
    Case [L]ARULE
      When  'PROPAGATE' : Gosub CONTENTS_PROPAGATE
    Endcase
  When 'HRESSATT.BLOB'
    Case [L]ARULE
      When  'PROPAGATE' : Gosub HRESSATT_BLOB_PROPAGATE
    Endcase
 When 'VOLUME'
  Case [L]ARULE
    When  'INIT' : Gosub VOLUME_INIT
  Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#   When "GETFILEINFO"       : Gosub GETFILEINFO
#   When "GETFILEDATETIME"   : Gosub GETFILEDATETIME
#   When "GETFILECOM"        : Gosub GETFILECOM
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return



#**
#* AREAD_AFTER
#*!
$AREAD_AFTER
Gosub VOLUME_INIT
Return

#**
#* AINSERT
#*!
$AINSERT
$AUPDATE


#Loop through the collection and save the blob
Local Integer FILEINFO
Local Integer I,LINNUMBER
If this.HRESSATT <> null
  For I = 1 To maxtab(this.HRESSATT)
    If find(this.HRESSATT(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      If !len(this.HRESSATT(I).BLOB)ST_AERROR
        [L]ASTATUS = fmet this.ASETERROR("BLOB",mess(34,149,1),[V]CST_AERROR)
      Else
        LINNUMBER = this.HRESSATT(I).NUMLIG
        [L]ASTATUS = func ASYRSTO.WRITEBLOB(this.HRESSATT(I).VOLUME,this.HRESSATT(I).FULLNAME,this.HRESSATT(I).BLOB)
        If [L]ASTATUS = [V]CST_AOK
          #Add reference to ABOJTXT
          [L]ASTATUS = func ESSVOLFIL_CSTD.WRITE_AOBJTXT("EML",this.HRESSATT(I).FULLNAME, this.HRESSATT(I).VOLUME, this.HRESSATT(I).IDENT1,  this.HRESSATT(I).IDENT2, format$("N0:3",LINNUMBER))
        Endif
      Endif
    Endif
  Next I
Endif

Return

#**
#* PROPAGATE
#*!

$CONTENTS_PROPAGATE
Local Integer I
If [L]ARULE = 'PROPAGATE'
 If [L]CURPRO = 'CONTENTS'
  this.FULLNAME =fmet this.APARENT.AGETVALPARAMURL("FULLNAME")
#  this.FULLNAME =fmet this.AGETVALPARAMURL("FULLNAME")
  Local Integer _FILINFO,ATTRIBUTE,FILEINFO
  _FILINFO = func ASYRSTO.GETFILEINFO(this.VOLUME,this.FULLNAME,[L]ATTRIBUTE,FILEINFO)
  If _FILINFO  = [V]CST_AOK and FILEINFO>0
   If find(int(mod(FILEINFO/2^12,16)),0,8)=0 : # Répertoire
    this.FULLNAME += string$(this.FULLNAME<>"","/")+fmet this.APARENT.AGETVALPARAMURL("x-file-name")
#  this.FULLNAME += string$(this.FULLNAME<>"","/")+fmet this.AGETVALPARAMURL("x-file-name")
   Else  # Fichier normal
    Local Char PARTFULLNAME(250)(1..)
    Local Integer NBPART
    NBPART =func ASYRSUB.SPLIT(PARTFULLNAME,this.FULLNAME,"/")
    this.FULLNAME = ""
    For I=1 To NBPART-1
     this.FULLNAME += PARTFULLNAME(I)+"/"
    Next
    this.FULLNAME += fmet this.APARENT.AGETVALPARAMURL("x-file-name")
#  this.FULLNAME += fmet this.AGETVALPARAMURL("x-file-name")
   Endif
  Else
   this.FULLNAME = fmet this.APARENT.AGETVALPARAMURL("x-file-name")
#  this.FULLNAME = fmet this.AGETVALPARAMURL("x-file-name")
  Endif
 Elsif  [L]CURPRO = 'FULLNAME'
     [L]ASTATUS = fmet this.ASETERROR("CONTENTS","",[V]CST_AOK )
 Endif
Endif
Return


$HRESSATT_BLOB_PROPAGATE

#Setting the parent blb file to get fileinfo
this.APARENT.CONTENTS = this.BLOB

#Refresh collection information
this.VOLUME     = this.APARENT.VOLUME
this.NUMLIG     = max(maxtab(this.APARENT.HRESSATT))
this.FULLNAME   = this.IDENT1+"_"+num$(this.IDENT2)+"_"+format$("N0:3",this.NUMLIG )+"_"+this.APARENT.FULLNAME

Return

$VOLUME_INIT
#Set the volume
#Check the function saved in the user tracking to determine the parameter value
#PORATTDCG/PORATTEXS

this.VOLUME = func ADP_TOOL.GET_PARAM(this.ACTX.AFOLDER, 1, this.ACTX.AFOLDER, "PORATTDCG")
If this.VOLUME = AVOID.ACHAR
  ASTATUS=fmet this.ASETERROR("","PORATTDCG:"-mess(00124,00134,1),[V]CST_AERROR)#The folder parameter is empty
Endif

Return

#**
#* GETFILEINFO
#*!
$GETFILEINFO
ASTATUS = func ASYRSTO.GETFILEINFO(this.VOLUME,this.FULLNAME,[L]ATTRIBUTE,FILEINFO)
Return

#**
#* GETFILEDATETIME
#*!
$GETFILEDATETIME
ASTATUS = func ASYRSTO.GETFILEDATETIME(this.VOLUME,this.FULLNAME,FDATETIME)
Return

#**
#* GETFILECOM
#*!
$GETFILECOM
ASTATUS = func ASYRSTO.GETFILECOM(this.VOLUME,this.FULLNAME,GETFILECOM)
Return

Funprog WRITE_AOBJTXT(VABR,VFILENAME, VVOLUME, VID1,VID2,VID3)
Value Char VABR,VFILENAME, VVOLUME, VID1,VID2,VID3
Local Integer FUNRESULT
FUNRESULT = [V]CST_AOK
Local Mask AOBJTXT [AOX]

Local File AOBJTXT [AOX1]
Read [F:AOX1]AOX0 = VABR;VID1;VID2;VID3
If !fstat
  #re-write
  Gosub WRITE_AOBJTXT_FIELDS
  Rewrite [F:AOX1]
Else
  Raz [F:AOX1]
  Gosub WRITE_AOBJTXT_FIELDS
  Write [F:AOX1]
Endif


End FUNRESULT

$WRITE_AOBJTXT_FIELDS
[F:AOX1]ABREV = VABR
[F:AOX1]IDENT1 = VID1
[F:AOX1]IDENT2 = VID2
[F:AOX1]IDENT3 = VID3
[F:AOX1]NAM = "["+VVOLUME+"]/"+VFILENAME
[F:AOX1]CAT = 1
#Get the content type
nolign =1
[M:AOX]NAM(nolign-1) = "["+VVOLUME+"]/"+VFILENAME
[F:AOX1]TYPDOC = func ESSVOLFIL_CSTD.GET_DOCTYP(VFILENAME)

Return

Funprog GET_DOCTYP(FFILENAME)
Value Char FFILENAME
Local Char VDOCTYP(GLONADI)
Local Char    NAM(GDIMFIC), SUF(10), MESSA(250)

Local File ATABDIV [F:ADI2]
Call SETNAM(FFILENAME,NAM,SUF) From GOBJTXT

Read [ADI2]CODE = 902;toupper(SUF)
If !fstat & [F:ADI2]A1<>""
  VDOCTYP =  [F:ADI2]A1
Endif
End VDOCTYP

