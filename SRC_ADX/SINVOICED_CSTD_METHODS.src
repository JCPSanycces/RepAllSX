# Classe SINVOICED
#######################################################################################
End

#######################################################################################
$AREAD_AFTER
Local Integer IRET

  IRET = fmet this.INIT_TSICODADI()
Return

#######################################################################################
$AINIT
Local Integer IRET

  IRET = fmet this.INIT_TSICODADI()
Return

#######################################################################################
$INIT_TSICODADI
Local Integer DIM_STI
Local Integer NI

  DIM_STI = func ASYRFNC.ACTIV("STI")
  # -------------------
  For NI = 1 To DIM_STI
    this.C_TSICOD(NI).TSICODADI = NI + 20
  Next NI
  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
Return

