#<AdxTL>@(#)0.0.0.0 $Revision$
# Sert à initialiser le nouveau champ OWNTYP de la table FXDLIFL avec la valeur 1
  Call OUVRE_TRACE("UTIIMM012 - Field OWNTYP of FXDLIFL table initialization") From LECFIC
  Call PATCH(nomap)
  Call LEC_TRACE() From LECFIC
End

Subprog EXE_UTIIMM012(APPLI)
Value Char APPLI

  If clalev([F:WFLU]) : Close Local File [WFLU] : Endif
  Local File =APPLI+".FXDLIFL" [WFLU]

  Call ECR_TRACE("UTIIMM012: Process Start on : "+APPLI,0) From GESECRAN

  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM012

  Call ECR_TRACE("UTIIMM012: Process End on : "+APPLI,0) From GESECRAN

  If clalev([F:WFLU]) : Close Local File [WFLU] : Endif
End


#### Corps de la moulinette - début
$TR_UTIIMM012
  Trbegin [WFLU]
  
  Update [F:WFLU] Where OWNTYP = 0 With OWNTYP = 1
  If fstat 
    Call ECR_TRACE(mess(13,100,1)-"FXDLIFL"-num$(fstat),1) From GESECRAN
  Else
    Call ECR_TRACE(mess(192,124,1)-":"-num$(adxuprec),0) From GESECRAN
  Endif
  
  If !GOK Then
    Goto AB_UTIIMM012
  Else
    Commit
  Endif
Return

$AB_UTIIMM012
  Rollback
Return 
#### Corps de la moulinette - fin 


Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=adxmother(0) : End : Endif

  If filinfo(filpath("FIL","FXDLIFL","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM012(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj7 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Local Integer GPHY

  If APPLI=adxmother(0) : End : Endif

  If filinfo(filpath("FIL","FXDLIFL","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM012(APPLI)
End




