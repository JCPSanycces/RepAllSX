#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################################
# Programme : PREDERO                                                                   #
#                                                                                       #
# Fonction  :                                                                           #
#      1- Maj de la table TMPDERO                                                       #
#      2- Maj des tables CACCE, GACCOUNT, CADSP, TABCUR et TABCHANGE si ABELX3 lié à X3 #
#      3- Préparer le traitement pour l'état DEPSITUCUR (gestion des devises)en créant  #
#         un enregistrement par couple CUR/CURDEN en fonction de la devise de reporting,#
#         du type de cours et de la date du cours passés en paramètre.                  #
#########################################################################################
#    Modification :
# UUUUU jj.mm.aaaa nnnnnn_nn Cccccccccccccccccccccccccccccccccccccccccccccccccccccccc
#
# MDJ   03.02.2016 114161    Intitulés Code comptable absents (en sqlserver)
# MDJ   09/02/2015 FQ100398  Suppression site géographique
# CBO   29/04/2014 FQ-69690  Objet FAM
# MDJ   25/10/2013 FQ-93870  Pb sur biens sortis dans périodes précédentes
# MDJ   15/04/2013 FQ-88643  On n'édite pas les biens sortis dans un exercice antérieur à l'exercice demandé
# MDJ   05/10/2012 FQ-84980  Variable GCOA remplacée par GWCOA
# GLE   30/05/2012 FQ-82485  Corrections IASACCC -> IASACC
# MDJ   24/05/2012 FQ-82080  Récupération des intitulés de champs dans TMPDERO
# MDJ   23/04/2012 FQ-81776  Test profil fonction-site déplacé depuis l'état
# MDJ   18.01.2011 FQ-70822  Etat multi-sociétés
# MDJ   21.12.2010 FQ-70141  Vérification de sources (interne)
# MDJ   03/12/2010 FQ-69632  Prise en compte incorrecte du type de détention
# MDJ   24/03/2010 FQ-63518  Problèmes de locks
# MDJ   19/02/2010 FQ-62744  Corrections s/sélection des biens sortis ou non
# MDJ   18/01/2010 FQ-61601  Pb prise en compte biens sortis
#                            ==> somme prov/repr période <> prov/repr exercice )
# MDJ   14/01/2010 FQ-61602  dotation théorique prise en cpte uniquement si bien a été déprécié
# MDJ   23/03/2009 FQ-53670  Bien sortis sur période antérieure de l'exercice non pris en compte
###############################################################################################
######################################################################################
$ACTION

    Case ACTION
        When "OUVRE" :   Gosub OUVRE
        When "EXEC"  :   Gosub EXEC
        When "FIN"   :   Gosub FIN
    Endcase
Return
######################################################################################
$OUVRE

#=============================================================================
# traitement PREPEDT : maj de tables communes X3/ABELX3
#=============================================================================
If clalev([F:CCE])=0    :    Local File CACCE                 [CCE]  : Endif
If clalev([F:CCEM])=0   :    Local File CACCE                 [CCEM]  : Endif
If clalev([F:GACM])=0   :    Local File GACCOUNT              [GACM]  : Endif
If clalev([F:DSP])=0    :    Local File CADSP                 [DSP]  : Endif
If clalev([F:DSPM])=0   :    Local File CADSP                 [DSPM]  : Endif
If clalev([F:TCUM])=0   :    Local File TABCUR                [TCUM]  : Endif
If clalev([F:TCHM])=0   :    Local File TABCHANGE             [TCHM]  : Endif
If clalev([F:TDE])=0    :    Local File TMPDERO               [TDE]   : Endif
If clalev([F:TDEM])=0   :    Local File TMPDERO               [TDEM]  : Endif

#=============================================================================
# traitement PREDERO : alimentation de la table TMPDERO
#=============================================================================
#If clalev([F:FAS])=0    :    Local File FXDASSETS       [FAS]   : Endif  : # X3-71025
If clalev([F:FAS])=0    :    Local File DEPSITUDERO     [FAS]   : Endif  : # X3-71025

If clalev([F:CCE0])=0   :    Local File CACCE           [CCE0]  : Endif
If clalev([F:CCE1])=0   :    Local File CACCE           [CCE1]  : Endif
If clalev([F:CCE2])=0   :    Local File CACCE           [CCE2]  : Endif
If clalev([F:CCE3])=0   :    Local File CACCE           [CCE3]  : Endif
If clalev([F:CCE4])=0   :    Local File CACCE           [CCE4]  : Endif
If clalev([F:CCE5])=0   :    Local File CACCE           [CCE5]  : Endif
If clalev([F:CCE6])=0   :    Local File CACCE           [CCE6]  : Endif
If clalev([F:CCE7])=0   :    Local File CACCE           [CCE7]  : Endif
If clalev([F:CCE8])=0   :    Local File CACCE           [CCE8]  : Endif

If clalev([F:DSP])=0    :    Local File CADSP           [DSP]   : Endif

If clalev([F:CPY])=0    :    Local File COMPANY         [CPY]   : Endif
If clalev([F:CNX])=0    :    Local File CONTEXT         [CNX]   : Endif
If clalev([F:FIY])=0    :    Local File FISCYEAR        [FIY]   : Endif

If clalev([F:DEPC])=0   :    Local File DEPREC          [DEPC]  : Endif    # DEPREC comptable
If clalev([F:DEPE])=0   :    Local File DEPREC          [DEPE]  : Endif    # DEPREC comptable exercice
If clalev([F:DEPF])=0   :    Local File DEPREC          [DEPF]  : Endif    # DEPREC fiscal
If clalev([F:FCY])=0    :    Local File FACILITY        [FCY]   : Endif    # Sites financiers
If clalev([F:FCYG])=0   :    Local File FACILITY        [FCYG]  : Endif    # Sites géographiques

If clalev([F:CAC])=0    :    Local File GACCCODE        [CAC]   : Endif    # Codes comptables
If clalev([F:GACC])=0   :    Local File GACCOUNT        [GACC]  : Endif    # Comptes généraux PCG
If clalev([F:GACI])=0   :    Local File GACCOUNT        [GACI]  : Endif    # Comptes généraux IAS

If clalev([F:ADI])=0   :    Local File ATABDIV        [ADI]  : Endif       # Tables diverses
If clalev([F:AFF])=0   :    Local File AFCTFCY        [AFF]  : Endif       #*Fq-81776 Profil fonction site


Return
######################################################################################
$FIN

Unlock PREPDERO

Return
######################################################################################
$EXEC

#FQ-63518 SYMBOLE = "PREPDERO"
#FQ-63518 Lock SYMBOLE With lockwait = 3
Lock PREPDERO With lockwait = 3
If fstat
   Return
Endif

Gosub MAJ_TMPDERO


Return
###################################################
$MAJ_TMPDERO
#------------------------------------------------------------------------------------#
#--- Création table temporaire TMPDERO pour les états s/dérogatoire               ---#
#------------------------------------------------------------------------------------#

Gosub OUVRE

    Local Integer I             # Compteur de paramètres
    Local Char LCPYDEB          # Société deb
    Local Char LCPYFIN
    Local Char LFCYDEB          # Site deb
    Local Char LFCYFIN
    Local Char LCCPTDEB         # Code comptable deb
    Local Char LCCPTFIN         # Code comptable fin
    Local Char LACCDEB          # Compte PCG deb
    Local Char LACCFIN          # Compte PCG fin
    Local Char LIASACDEB        # Compte IAS deb
    Local Char LIASACFIN        # Compte IAS fin
    Local Integer LTYPDETDEB    # Type dét deb
    Local Integer LTYPDETFIN    # Type dét  fin
    Local Date LDATDEB
    Local Date LDATFIN          # Type dét  fin
    Local Char LREFDEB          # réf deb
    Local Char LREFFIN          # réf fin
    Local Integer LSITUAT       # Situation
    Local Integer LENCOURS      # Encours ?
    Local Integer LACTIF        # Actif ?
    Local Integer LSELENT       # Sélection entrées
    Local Integer LSELSOR       # Sélection sorties
    Local Date    LDATNULL      : LDATNULL = [01/01/1900]
    Local Integer LBAS0         # base à 0 si sortis ?
    Local Integer LTRI2         # Critère de tri 2
    Local Integer LTRI3         # Critère de tri 3
    Local Integer LDET          # Détail ?
    Local Integer LEDTNUM       # Identifiant session         #*FQ-51494
    Local Char    LCRITERE  (250) # Critère de sélection
    Local Char    LCRITERE2 (250) # Critère de sélection
    Local Char    LCRITERE3 (250) # Critère de sélection  X3-71025
    Local Decimal WTOTLEG
    Local Decimal WENDDPET
    Local Char    SCPY
    Local Integer WFLGPER
    Global Integer GDERO : GDERO=G_NON
    Local Char    SFCY         #*FQ-81776 site financier traité
    Local Char    X3PRF        #*FQ-81776 Code profil user
    Local Char    X3FCT        #*FQ-81776 Fonction
    Global Char   GWCOA         #*FQ-81776 globale sur plan de compte

    If clalev([FAM])=0 : Local File FASFAM [FAM] : Endif

    If clalev([TDE])=0 : Local File TMPDERO [TDE] : Endif
    Trbegin [TDE]
    Delete [TDE] Where CREUSR = GUSER & CREDAT < date$
    If fstat = 1
      # Fq-81429 Rollback
      #  "Problème à l'effacement du fichier temporaire"
      # Fq-81429   Call MESSAGE (mess(155,197,1)) From GESECRAN
    Else
       Commit
    Endif

   Call GETPARAM("cpydeb",NBPAR,PARAMETRE,LCPYDEB)
   Call GETPARAM("cpyfin",NBPAR,PARAMETRE,LCPYFIN)

   Call GETPARAM("fcydeb",NBPAR,PARAMETRE,LFCYDEB)
   Call GETPARAM("fcyfin",NBPAR,PARAMETRE,LFCYFIN)
   Call GETPARAM("ccptdeb",NBPAR,PARAMETRE,LCCPTDEB)
   Call GETPARAM("ccptfin",NBPAR,PARAMETRE,LCCPTFIN)
   Call GETPARAM("accdeb",NBPAR,PARAMETRE,LACCDEB)
   Call GETPARAM("accfin",NBPAR,PARAMETRE,LACCFIN)
   Call GETPARAM("accifrsdeb",NBPAR,PARAMETRE,LIASACDEB)
   Call GETPARAM("accifrsfin",NBPAR,PARAMETRE,LIASACFIN)
   Call GETPARAM("typdetdeb",NBPAR,PARAMETRE,PARAM)    : LTYPDETDEB = val(PARAM)
   Call GETPARAM("typdetfin",NBPAR,PARAMETRE,PARAM)    : LTYPDETFIN = val(PARAM)
   Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM)       : LDATDEB    =  PARAM
   Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM)       : LDATFIN    =  PARAM
   Call GETPARAM("refdeb",NBPAR,PARAMETRE,LREFDEB)
   Call GETPARAM("reffin",NBPAR,PARAMETRE,LREFFIN)
   Call GETPARAM("situation",NBPAR,PARAMETRE,PARAM)    : LSITUAT    = val(PARAM)
   Call GETPARAM("encours",NBPAR,PARAMETRE,PARAM)      : LENCOURS   = val(PARAM)
   Call GETPARAM("actif",NBPAR,PARAMETRE,PARAM)        : LACTIF     = val(PARAM)
   Call GETPARAM("selentree",NBPAR,PARAMETRE,PARAM)    : LSELENT    = val(PARAM)
   Call GETPARAM("selbiensor",NBPAR,PARAMETRE,PARAM)   : LSELSOR    = val(PARAM)
   Call GETPARAM("biensor",NBPAR,PARAMETRE,PARAM)      : LBAS0      = val(PARAM)
   Call GETPARAM("tri2",NBPAR,PARAMETRE,PARAM)         : LTRI2      = val(PARAM)
   Call GETPARAM("tri3",NBPAR,PARAMETRE,PARAM)         : LTRI3      = val(PARAM)
   Call GETPARAM("detail",NBPAR,PARAMETRE,PARAM)       : LDET       = val(PARAM)
   Call GETPARAM("edtnum",NBPAR,PARAMETRE,PARAM)       : LEDTNUM    = val(PARAM)

   Call GETPARAM("X3PRF",NBPAR,PARAMETRE,X3PRF)
   Call GETPARAM("X3FCT",NBPAR,PARAMETRE,X3FCT)

   LCRITERE = "1=1"
   For I=1 To NBPAR
      J=instr(1,[L]PARAMETRE(I),"=")
      If J
         [L]PARAM  = left$([L]PARAMETRE(I),J-1)
         [L]VALEUR = right$([L]PARAMETRE(I),J+1)
         Case [L]PARAM
            When "cpydeb" :
                  If LCPYDEB <> ""
                     LCRITERE =    "CPY>='"+LCPYDEB+"'"
                  Else
                     LCRITERE =    "CPY<='"+LCPYFIN+"'"
                  Endif
            When "cpyfin" :
                  If LCPYDEB <> ""
                     LCRITERE += "& CPY<='"+LCPYFIN+"'"
                  Endif
            When "fcydeb"     :     LCRITERE += "& FCY>='"+LFCYDEB+"'"
            When "fcyfin"     :     LCRITERE += "& FCY<='"+LFCYFIN+"'"
            When "ccptdeb"    :     LCRITERE += "& ACCCOD>='"+LCCPTDEB+"'"
            When "ccptfin"    :     LCRITERE += "& ACCCOD<='"+LCCPTFIN+"'"
            When "accdeb"     :     LCRITERE += "& GAC>='"+LACCDEB+"'"
            When "accfin"     :     LCRITERE += "& GAC<='"+LACCFIN+"'"
            When "accifrsdeb" :     LCRITERE += "& IASACC>='"+LIASACDEB+"'"
            When "accifrsfin" :     LCRITERE += "& IASACC<='"+LIASACFIN+"'"
            When "refdeb"     :     LCRITERE += "& AASREF>='"+LREFDEB+"'"
            When "reffin"     :     LCRITERE += "& AASREF<='"+LREFFIN+"'"
            When "encours"
                  If LENCOURS=1
                     LCRITERE2 =    "GACACN <3"
                  Else
                     LCRITERE2 =    "GACACN<>1"
                  Endif
            When "actif"
                  If LACTIF=1
                     LCRITERE2 +=    "& ENAFAS<>1"
                  Else
                     LCRITERE2 +=    "& ENAFAS=1"
                  Endif
            When "selentree"
                  # X3-71025
#                 Case LSELENT
#                    When 1 :  LCRITERE2 +=  "& (AASIPTDAT<= ["+format$(GFMD,LDATFIN)+"]"
#                              LCRITERE2 +=  "| ITSDAT   <= ["+format$(GFMD,LDATFIN)+"])"
#                    When 2 :  LCRITERE2 +=  "& AASIPTDAT>= ["+format$(GFMD,LDATDEB)+"]"
#                              LCRITERE2 +=  "& AASIPTDAT<= ["+format$(GFMD,LDATFIN)+"]"
#                    When 3 :  LCRITERE2 +=  "& AASIPTDAT<  ["+format$(GFMD,LDATDEB)+"]"
#                 Endcase
                  Case LSELENT
                     When 1 :  LCRITERE2 +=  "& MINSTRDPR<= ["+format$(GFMD,LDATFIN)+"]"
                     When 2 :  LCRITERE2 +=  "& MINSTRDPR>= ["+format$(GFMD,LDATDEB)+"]"
                               LCRITERE2 +=  "& MINSTRDPR<= ["+format$(GFMD,LDATFIN)+"]"
                     When 3 :  LCRITERE2 +=  "& MINSTRDPR<  ["+format$(GFMD,LDATDEB)+"]"
                  Endcase
            When "selbiensor"
                  Case LSELSOR
                     When 1 :  LCRITERE2 +=  "& (ISSDAT  <= ["+format$(GFMD,LDATNULL)+"]"
                               LCRITERE2 +=  "| ISSDAT   >  ["+format$(GFMD,LDATNULL)+"])"
                     When 2 :  LCRITERE2 +=  "& (ISSDAT  <= ["+format$(GFMD,LDATNULL)+"]"
                               LCRITERE2 +=  "| ISSDAT   >  ["+format$(GFMD,LDATFIN)+"])"
                     When 3 :
                        If LSITUAT = 1
                               LCRITERE2 +=  "& ISSDAT   >= ["+format$(GFMD,LDATNULL)+"]"
                               LCRITERE2 +=  "& ISSDAT   <= ["+format$(GFMD,LDATFIN)+"]"
                        Else
                               LCRITERE2 +=  "& ISSDAT   >= ["+format$(GFMD,LDATNULL)+"]"
                        Endif
                  Endcase
         Endcase
      Endif
   Next

   LCRITERE3 = "PERENDDAT = ["+format$(GFMD,LDATFIN)+"]" : # X3-71025
   #FQ-69632   When "typdetdeb"  :     LCRITERE += "& OWNTYP>="+num$(LTYPDETDEB)
   #FQ-69632   When "typdetfin"  :     LCRITERE += "& OWNTYP<="+num$(LTYPDETFIN)
#--------------------------------
   Trbegin [TDE]
   Delete [TDE] Where [F:TDE]CPY <> ""
   If fstat=0
       Commit
   Else
      #*Fq-88643 Infbox ("Erreur de suppression")
      #  "Problème à l'effacement du fichier temporaire"
      Call MESSAGE (mess(155,197,1)) From GESECRAN
      Rollback
   Endif
    #
   Trbegin [TDE]
   SCPY= ""
   SFCY= ""   #*FQ-81776
   GWCOA= ""   #*FQ-81776
   #FQ-69632 Filter [FAS] Where ( evalue(LCRITERE) &  evalue(LCRITERE2) )
   #X3-71025 Filter [FAS] Where ( evalue(LCRITERE) &  evalue(LCRITERE2) ) and (OWNTYP >= LTYPDETDEB ) and (OWNTYP <= LTYPDETFIN )
   Filter [FAS] Where ( evalue(LCRITERE) &  evalue(LCRITERE2) & evalue(LCRITERE3) )  and (OWNTYP >= LTYPDETDEB ) and (OWNTYP <= LTYPDETFIN )
&  Order By CPY; AASREF; PERENDDAT
   For [FAS]
      If  LSELENT = 1 and
&         ([F:FAS]AASIPTDAT <= [F:FAS]ITSDAT)   and  ([F:FAS]AASIPTDAT > LDATFIN) or
&         ([F:FAS]AASIPTDAT > [F:FAS]ITSDAT)    and  ([F:FAS]ITSDAT    > LDATFIN)
          Goto NEXTFAS
      Endif
      ##*Fq-88643  Si le bien est sorti dans un exercice antérieur on ne le prend pas en compte
      If ( [F:FAS]ISSDAT > LDATNULL and  [F:FAS]ISSDAT < LDATDEB ) and ( [F:FAS]EXTISSFLG=G_NON )
         Goto NEXTFAS
      Endif
      If [F:FAS]CPY <> SCPY
         # Lecture contexte FISCAL & COMPTABLE
         Read [CNX] CNX0= [F:FAS]CPY;G300CPFI
         If fstat=0
            #*FQ-81776
            I_COA = find(G301CPT,[F:CNX]PLNCAA(0..[F:CNX]NBPLC-1))
            If I_COA > 0
               GWCOA= [F:CNX]COA(I_COA-1)
            Endif
         Endif
         # Lecture exercice courant FISCAL & COMPTABLE
         Filter [FIY] Where CPY=[F:FAS]CPY and CNX = G300CPFI and DATSTRFIY=LDATDEB & DATENDFIY=LDATFIN
         Read [FIY]First
         If fstat= 0
            WFLGPER = G_OUI
         Endif
         Filter [FIY]
         SCPY= [F:FAS]CPY
      Endif
      #*FQ-81776
      If [F:FAS]FCY <> SFCY
         Read [AFF]AFF0 = [F:FAS]FCY;X3PRF;X3FCT
         If fstat <> 0
            Goto NEXTFAS
         Endif
         SFCY= [F:FAS]FCY
      Endif  #*FQ-81776
      #1------------
      Raz[TDEM]
      [F:TDEM] = [F:FAS]
      [F:TDEM]COA = GWCOA
      #=========================================================
      #Fq-82080 Récupération des intitulés des champs
      #=========================================================
      Read [CPY]CPY0    = [F:FAS]CPY
      If fstat=0 :     [F:TDEM]CPYNAM    = [F:CPY]CPYNAM  : Endif
      Read [FCY]FCY0    = [F:FAS]FCY
      If fstat=0 :     [F:TDEM]FCYNAM    = [F:FCY]FCYNAM : Endif
      [F:TDEM]AASDES1   = [F:FAS]AASDES1
      # Issue 114161  READ[CAC]CAC0="15";[F:FAS]ACCCOD;GWCOA
      Read[CAC]CAC0=15;[F:FAS]ACCCOD;GWCOA
      If fstat=0
         Call LECTEXTRA([F:TDEM]ACCDES,"GACCCODE","DESTRA","15",[F:FAS]ACCCOD) From ATEXTRA
         # Issue 114161 [F:TDEM]ACCDES=[F:CAC]DESTRA
      Endif
      Read[GACC]GAC0=GWCOA;[F:FAS]GAC
      If fstat=0
         Call LECTEXTRA([F:TDEM]GACDES,"GACCOUNT","DESTRA",GWCOA,[F:FAS]GAC) From ATEXTRA
      Endif
      Read[GACI]GAC0=GWCOA;[F:FAS]IASACC : # FQ82485
      If fstat=0
         Call LECTEXTRA([F:TDEM]IASACCDES,"GACCOUNT","DESTRA",GWCOA,[F:FAS]IASACC) From ATEXTRA
      Endif
      Read[DSP]DSP0=[F:FAS]DSP;1
      If fstat=0
       [F:TDEM]DSPDES = [F:DSP]DESTRA
      Endif

      Read [F:FAM]FAM0 = [F:FAS]ACGGRP
#      Read [ADI]CODE = GTD_FAMCPT;[F:FAS]ACGGRP
      If fstat=0
#        Call LECTEXTRA ([F:TDEM]ACGGRPDES, "ATABDIV", "LNGDES", num$(GTD_FAMCPT), [F:ADI]CODE) From ATEXTRA
         Call LECTEXTRA ([F:TDEM]ACGGRPDES, "FASFAM", "FAMDES", [F:FAS]ACGGRP, "") From ATEXTRA
      Endif
      Read [ADI]CODE = 613;[F:FAS]IASCGU
      If fstat=0
         Call LECTEXTRA ([F:TDEM]IASCGUDES, "ATABDIV", "LNGDES", "613", [F:ADI]CODE) From ATEXTRA
      Endif
      #=========================================================
      GDERO=G_NON
      #========================================================
      # Récupération des infos en provenance du plan comptable
      #========================================================
      If LSITUAT = 1
         #----- Exercice -----
         Filter [DEPC] Where ( CPY=[F:FAS]CPY    & AASREF=[F:FAS]AASREF & DPRPLN=G301CPT         &
&                              FIYSTRDAT=LDATDEB & FIYENDDAT=LDATFIN    & STRDPRDAT<=LDATFIN     &
&                              PERENDDAT = LDATFIN )

         Read[DEPC]DEP0 Last
         Filter [DEPC]
         If fstat = 0
            WTOTLEG = 0
            WTOTLEG =  [F:DEPC]LEG
            WTOTLEG += [F:DEPC]LEGRVE
            WTOTLEG += [F:DEPC]LEGCUM
            WTOTLEG += [F:DEPC]LEGRVECUM
            WTOTLEG += [F:DEPC]PERLEGCUM
            WTOTLEG += [F:DEPC]PERLEGRVE
            WTOTLEG += [F:DEPC]LEGRVECUM
            If WTOTLEG <> 0
               GDERO=G_OUI
               Gosub CHARGE_TDEM_EXE_CPT
            Else
               GDERO=G_NON
            Endif
            WENDDPET = 0
            #*pour les biens dépréciés on utilise la dotation théorique (ENDDPETC) et non pas la dotation réelle
            #* pour calculer le dérogatoire. RAF : il faut tester que le bien a été déprécié ou non  (IMLBLC)
            If GDERO=G_OUI
               Filter[DEPE] Where ( CPY=[F:FAS]CPY        & AASREF=[F:FAS]AASREF & DPRPLN=G301CPT &
&                                   PERSTRDAT>= LDATDEB & PERENDDAT <= LDATFIN     & STRDPRDAT<=LDATFIN  &
&                                   IMLBLC <> 0  )
               For[DEPE]
                 WENDDPET += [F:DEPE]DPET
               Next
               Filter[DEPE]
               [F:TDEM]ENDDPETC = WENDDPET
            Endif
         Endif
      Else
         #----- Période -----
# X3-71025
#         Filter[DEPC] Where (CPY=[F:FAS]CPY    & AASREF=[F:FAS]AASREF & DPRPLN=G301CPT &
#&                            PERSTRDAT=LDATDEB & PERENDDAT=LDATFIN    & STRDPRDAT<=LDATFIN  &
#&                              PERENDDAT = LDATFIN )
         Filter[DEPC] Where (CPY=[F:FAS]CPY    & AASREF=[F:FAS]AASREF & DPRPLN=G301CPT &
&                            PERSTRDAT=LDATDEB & PERENDDAT=LDATFIN    &
&                              PERENDDAT = LDATFIN )
         Read[DEPC]DEP0 Last
         Filter[DEPC]
         If fstat
            #*Fq-70822 Read[DEPC]DEP0 Prev
            #*Fq-70822 If fstat
               Goto NEXTFAS
            #*Fq-70822 Endif
         Endif
         If fstat = 0
            #
            # si "Biens sortis et non-sortis" : #Fq-88643 si sortie antérieure à l'exercice traité on n'édite pas le bien
            # si "Biens non sortis" :  si sortie <  début période traitée on n'édite pas le bien
            # si "Biens sortis" :  si non sortis ou sortie postérieure à la période traitée on n'édite pas le bien
            #Case  LSELSOR
            #When 1  :
            #Fq-93870   If ( [F:FAS]ISSDAT > [0/0/0] and [F:FAS]ISSDAT < LDATDEB )
            #      GDERO=G_NON
            #   Else
            #       GDERO=G_OUI
            #   Endif
            Case  LSELSOR
               When 1  :
                  If ( [F:FAS]ISSDAT > [0/0/0] and [F:FAS]ISSDAT < [F:DEPC]FIYSTRDAT )
                     GDERO=G_NON
                  Else
                      GDERO=G_OUI
                  Endif
               When 2
                   If ( [F:FAS]ISSDAT >  [0/0/0] and [F:FAS]ISSDAT < LDATDEB  and [F:FAS]ISSDAT >= [F:DEPC]FIYSTRDAT ) or
&                     ( [F:FAS]ISSDAT > LDATFIN)  or
&                     ( [F:FAS]ISSDAT =  [0/0/0] )
                      GDERO=G_OUI
                   Else
                      GDERO=G_NON
                   Endif
               When 3
                   If  [F:FAS]ISSDAT < [F:DEPC]FIYSTRDAT or [F:FAS]ISSDAT > LDATFIN
                     GDERO=G_NON
                   Else
                     GDERO=G_OUI
                   Endif
               When Default : GDERO=G_OUI
            Endcase
            If GDERO=G_OUI
               WTOTLEG = 0
               WTOTLEG  = [F:DEPC]LEG
               WTOTLEG += [F:DEPC]LEGRVE
               WTOTLEG += [F:DEPC]LEGCUM
               WTOTLEG += [F:DEPC]LEGRVECUM
               WTOTLEG += [F:DEPC]PERLEGCUM
               WTOTLEG += [F:DEPC]PERLEGRVE
               WTOTLEG += [F:DEPC]LEGRVECUM
               If WTOTLEG = 0
                  GDERO=G_NON
               Else
                  GDERO=G_OUI
                  Gosub CHARGE_TDEM_PER_CPT
               Endif
            Endif
         Endif
      Endif
      #========================================================
      # Récupération des infos en provenance du plan fiscal
      #========================================================
      If GDERO=G_OUI
         If ( LSITUAT = 1 )
            #----- Exercice -----
            Filter [DEPF] Where ( CPY=[F:FAS]CPY    & AASREF=[F:FAS]AASREF & DPRPLN=G301FIS &
&                                 FIYSTRDAT=LDATDEB & FIYENDDAT=LDATFIN    & STRDPRDAT<=LDATFIN )
            Read[DEPF]DEP0 Last
            Filter [DEPF]
            If fstat=0
                Gosub CHARGE_TDEM_EXE_FIS
            Endif
            WENDDPET = 0
            #*pour les biens dépréciés on utilise la dotation théorique (DPET) et non pas la dotation réelle
            #* pour calculer le dérogatoire. RAF : il faut tester que le bien a été déprécié ou non  (IMLBLC)
            Filter[DEPE] Where ( CPY=[F:FAS]CPY        & AASREF=[F:FAS]AASREF & DPRPLN=G301CPT &
&                                PERSTRDAT>= LDATDEB   & PERENDDAT <= LDATFIN & STRDPRDAT<=LDATFIN &
&                                   IMLBLC <> 0  )
            For[DEPE]
              WENDDPET += [F:DEPE]DPET
            Next
            Filter[DEPE]
            [F:TDEM]DPETF = WENDDPET
         Else
            #----- Période -----
            Filter [DEPF] Where ( CPY=[F:FAS]CPY    & AASREF=[F:FAS]AASREF & DPRPLN=G301FIS &
&                                 PERSTRDAT=LDATDEB & PERENDDAT=LDATFIN    & STRDPRDAT<=LDATFIN )
            Read[DEPF]DEP0 Last
            Filter [DEPF]
            If fstat=0
               Gosub CHARGE_TDEM_PER_FIS
            Endif
         Endif
      Endif

      If GDERO=G_OUI
         [F:TDE]=[F:TDEM]
         [F:TDE]EDTNUM = LEDTNUM
         [F:TDE]CREUSR = GUSER
         [F:TDE]CREDAT = date$
         Write [F:TDE]
         If fstat <> 0
            GOK=0
            Rollback
            #Infbox("Impossible de lancer l'état. Erreur d'écriture sur le fichier de travail !")
         Else
            Commit
            Unlock[TDE]
         Endif
         #1------------
      Endif
      $NEXTFAS
   Next
   Filter[FAS]


If GDERO=G_NON
   Rollback
Else
Commit
Endif
Unlock PREPDERO
Return
######################################################################################
$CHARGE_TDEM_EXE_CPT

             [F:TDEM]STRDPRDATC   = [F:DEPC]STRDPRDAT
             [F:TDEM]ENDDPRDATC   = [F:DEPC]ENDDPRDAT
             [F:TDEM]FIYSTRDATC   = [F:DEPC]FIYSTRDAT
             [F:TDEM]DPRBASC      = [F:DEPC]DPRBAS
             [F:TDEM]DPRCUMC      = [F:DEPC]DPRCUM
             [F:TDEM]DPMC         = [F:DEPC]DPM
             [F:TDEM]DPRRATC      = [F:DEPC]DPRRAT
             [F:TDEM]DPRDURC      = [F:DEPC]DPRDUR
