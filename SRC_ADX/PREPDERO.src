             [F:TDEM]FLGUPDISSC   = [F:DEPC]FLGUPDISS
             [F:TDEM]DATISSPSTC   = [F:FAS]DATISSPST
             [F:TDEM]NBVC         = [F:DEPC]NBV
             [F:TDEM]LEG          = [F:DEPC]LEG
             [F:TDEM]PERLEGCUM    = [F:DEPC]PERLEGCUM
             [F:TDEM]PERLEGRVE    = [F:DEPC]PERLEGRVE
             [F:TDEM]LEGCUMC      = [F:DEPC]LEGCUM
             [F:TDEM]LEGRVECUMC   = [F:DEPC]LEGRVECUM
             [F:TDEM]SOLDEBEX     = [F:TDEM]LEGCUMC -  [F:TDEM]LEGRVECUMC  #Fq-93870
             [F:TDEM]PROVISION    = [F:DEPC]LEG    + [F:DEPC]PERLEGCUM
             [F:TDEM]REPRISE      = [F:DEPC]LEGRVE + [F:DEPC]PERLEGRVE



Return
