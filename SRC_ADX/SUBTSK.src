#<AdxTL>@(#)4.0.0.0 $Revision$
Call OBJET ("TSK", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "BOITE"        : Gosub BOITE       # FGR 31/07/2014 : X3SUIVI101463
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "OUVRE"        : Gosub OUVRE
    When "FERME"        : Gosub FERME
    When "SETBOUT"      : Gosub SETBOUT
    When "AVANTBOUT"    : Gosub AVANTBOUT
    When "LIENS"        : Gosub LIENS
    When "RAZCRE"       : Gosub RAZCRE
    When "RAZDUP"       : Gosub RAZDUP
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "INICRE"       : Gosub INICRE
    When "CREATION"     : Gosub CREATION
    When "AVANT_MODFIC" : Gosub AVANT_MODFIC
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "INIMOD"       : Gosub INIMOD
    When "MODIF"        : Gosub MODIF
    When "AV_ANNULE"    : Gosub AV_ANNULE
    When "ANNULE"       : Gosub ANNULE
   #When "AP_ANNULE"    : Gosub AP_ANNULE    # FGR 12/08/2009 : X3SUIVI57005
    When "APRES_ANNULE" : Gosub APRES_ANNULE # FGR 22/10/2009 : X3SUIVI57254
    When "APRES_CRE"    : Gosub APRES_CRE
    When "APRES_MOD"    : Gosub APRES_MOD
    When "FILTRE"       : Gosub FILTRE
    When "FILGAUCHE"    : Gosub FILGAUCHE
    When "AVANT_CHOI"   : Gosub AVANT_CHOI
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GCTSKCPT(GLONANM)   # Code compteur
Global Char GBOXTSK(10)
Global Char GBOXTS2(10)
Global Char GBOXTS3(10)
Global Char GBOXTS4(10)
Global Char GTBTSKFIELDSYL(30)(0..)     # FGR 30/11/2012 : X3SUIVI86305 (50)
Global Char GTBTSKVALSYL(250)(0..)      # FGR 30/11/2012 : X3SUIVI86305 (50)
Global Char GTBTSKCHRONOSYL(30)(0..)    # FGR 30/11/2012 : X3SUIVI86305 (50)
Global Integer GITSKNBSYL
Global Integer GTSKTUNNEL

Local Char SZSITE(GLONFCY)

  GTSKTUNNEL = TUNNEL
  If !clalev([F:SYL]) : Local File SYNCLINK [SYL] : Endif
  Raz GTBTSKFIELDSYL
  Raz GTBTSKVALSYL
  Raz GTBTSKCHRONOSYL
  GITSKNBSYL = 0
  GCTSKCPT = ""
  #------------------------------------------------------------#
  # --> Récupération du code compteur Activité commerciale     #
  #------------------------------------------------------------#
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=13
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(0)
  #  GCTSKCPT = [F:TCA]CODNUM(0)
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
  SZSITE = ""
  Call SITECRMDEF ("ACT", SZSITE) From CRM_UTIL
  GFCY = SZSITE
  Call GETDEV(GFCY) From DEVSUB
  #Affichage background TSKCCN
  Gosub DISPBKGCCN From SUBTSKB
Return

##########################################################################################################
$BOITE
Local Char STRTSUB(GLONADC)

  # FGR 31/07/2014 : X3SUIVI101463
  STRTSUB = "SUBTSK"
  Gosub BOITE_GOBJET From CRMUTIL150
Return

##########################################################################################################
$REDEFINE_LINK
  If !clalev([F:T_SK]) Then
    # FGR 11/02/2015 : X3SUIVI106120 : Si [T_SK] pas ouvert c'est que les browsers ont été redéfinis en SPE/SPV.
    # On part, c'est à ce niveau qu'on doit faire ce travail.
    Return
  Endif
  #---------------------------------------------------#
  # FGR 30/07/2014 : X3SUIVI101463
  Link [TSK] With [T_SK]TSK1=[F:TSK]TSKDAT;[F:TSK]TSKNUM,
&                 [AFF]AFF0~=[F:TSK]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:TSK]SALFCY,
&                 [FCY]FCY0=[F:TSK]SALFCY
&              As [TS2]
  Link [TSK] With [T_SK]TSK1=[F:TSK]TSKDAT;[F:TSK]TSKNUM,
&                 [AFF]AFF0~=[F:TSK]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:TSK]SALFCY,
&                 [FCY]FCY0=[F:TSK]SALFCY
&              As [TS3]
  Link [TSK] With [T_SK]TSK1=[F:TSK]TSKDAT;[F:TSK]TSKNUM,
&                 [AFF]AFF0~=[F:TSK]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:TSK]SALFCY,
&                 [FCY]FCY0=[F:TSK]SALFCY
&              As [TS4]
Return

##########################################################################################################
$OUVRE_BOITE
  #---------------------------------------------------#
  #Chargement des noms des cuurbox de chaque tiroir
  If OBJLIS(0) = "TSK" Then
    GBOXTSK= "GAU_CHE"
  Else
    GBOXTSK = "GAU_CHE"+num$(find("TSK",OBJLIS(1..8))) : #Tâches à effectuer
  Endif
  If OBJLIS(0) = "TS2" Then
    GBOXTS2= "GAU_CHE"
  Else
    GBOXTS2 = "GAU_CHE"+num$(find("TS2",OBJLIS(1..8))) : #Tâches effectuées
  Endif
  If OBJLIS(0) = "TS3" Then
    GBOXTS3= "GAU_CHE"
  Else
    GBOXTS3 = "GAU_CHE"+num$(find("TS3",OBJLIS(1..8))) : #Mes tâches à effectuer
  Endif
  If OBJLIS(0) = "TS4" Then
    GBOXTS4= "GAU_CHE"
  Else
    GBOXTS4 = "GAU_CHE"+num$(find("TS4",OBJLIS(1..8))) : #Mes tâches effectuées
  Endif
Return

##########################################################################################################
$FERME
  Kill GCTSKCPT   #Code compteur
  #LSE 22/12/2005 FQ 33987
  If dim(GBOXTSK) > 0 Then
    Kill GBOXTSK
    Kill GBOXTS2
    Kill GBOXTS3
    Kill GBOXTS4
  Endif
  Kill GTBTSKFIELDSYL
  Kill GTBTSKVALSYL
  Kill GTBTSKCHRONOSYL
  Kill GITSKNBSYL
  Kill GTSKTUNNEL
Return

##########################################################################################################
$SETBOUT
  #Menu Actions   Module Action Co
  # } : Enregistrer un rendez-vous
  # { : Enregistrer un appel
  # ! : Enregistrer une affaire
  # % : Enregistrer une demande de service
  # ) : Planifier un rendez-vous
  # ( : Planifier un appel
  # N : Traçabilité des pièces          # FGR 17/10/2012 : X3SUIVI71278
  If REP = "" Then
    CHMEN += "{}!()N"
  Endif
  If REP = "" and GMODU(12) = 2 and [M:TSK0]CCNTYP = 1 Then
    CHMEN += "%"
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$AVANTBOUT
  [M:TSK0]NVGCOD = BOUT
  Case BOUT
    When ")"
      #Planifier Rendez-vous
      GBCRMFLGNEW = 1
    When "("
      #Planifier Appel
      GBCRMFLGNEW = 1
    When "}"
      #Enregistrer Rendez-vous
      GBCRMFLGNEW = 1
    When "{"
      #Enregistrer Appel
      GBCRMFLGNEW = 1
    When "!"
      #Enregistrer Affaire
      GBCRMFLGNEW = 1
    When "%"
      #Enregistrer demande de service
      GBCRMFLGNEW = 1
  Endcase
Return

##########################################################################################################
$AVANT_CHOI
  If GBCRMFLGNEW = 1 Then
    REPONSE = GSTANEW
    Gosub NOUVEAU From GOBJSUB
    Gosub SETBOUT From GOBJSUB
    GBCRMFLGNEW=0
  Endif
Return

##########################################################################################################
$RAZCRE
Local Char SZNVGCOD(GLONNVG)
Local Char SZORINAV

  Raz SZNVGCOD
  Raz SZORINAV
  Raz GTBTSKFIELDSYL
  Raz GTBTSKVALSYL
  Raz GTBTSKCHRONOSYL
  GITSKNBSYL = 0
  # FGR 07/04/2015 : X3SUIVI107457 (début)
  If [M:TSK0]TSKCMP <> "" Then
    Local Char SVALEUR(type([M:TSK0]TSKCMP)-10)

    SVALEUR = [M:TSK0]TSKCMP
    Call AM_TSKCMP(SVALEUR) From W1TSK0
  Endif
  # FGR 07/04/2015 : X3SUIVI107457 (fin)
  #Clob
  [M:TSK1]TYPFULOBJ = "TSKOBJ"
  [M:TSK2]TYPFULRPO = "TSKRPO"

  #LSE 18/12/2006 Initialisation date
  #Initialise les valeurs par défaut de l'enregistrement
  If [M:TSK1]TSKSTR = [00/00/00] Then
    [M:TSK1]TSKSTR = date$
  Endif
  #Affecte une échéance et une date de début par défaut si rien n'a été saisi
  If [M:TSK1]TSKDAT = [00/00/00] Then
    [M:TSK1]TSKDAT = date$ + 1
  Endif

  If [M:TSK1]TSKPIOLEV = "" Then
    Call DEFVALADI(405, [M:TSK1]TSKPIOLEV) From CRMUTIL140
  Endif
  Call DEFVALADI(431, [M:TSK1]TSKTYP) From CRMUTIL140
  Actzo [M:TSK1]TSKDEL
  [M:TSK1]TSKDEL = 2
  [M:TSK1]TSKDELX = mess(2,976,1)

  #LSE V150 09/08/2005
  #On initialise le site
  Call SITECRMDEF("ACT", [M:TSK0]SALFCY) From CRM_UTIL
  #LSE 10/04/2006
  GFCY = [M:TSK0]SALFCY
  Call GETDEV(GFCY) From DEVSUB

  If GCRMREPTSK = 2 Then
    Read [REP]REP1=GUSER
    If !fstat Then
      [M:TSK1]TSKREP = [F:REP]REPNUM
    Endif
  Endif

  #Origine
  [M:TSK1]CREDAT = date$
  [M:TSK1]CREUSR = GUSER
  Read [AUS]CODUSR=GUSER
  If fstat Then
    [M:TSK1]FULNAMUSR = GUSER
  Else
    [M:TSK1]FULNAMUSR = [F:AUS]NOMUSR
  Endif
  # FGR 08/03/2010 : X3SUIVI62924 (début)
  #[M:TSK1]TSKORIOBC = ""
  #[M:TSK1]TSKORI = 1
  #[M:TSK1]TSKORITXT = ""
  #Diszo [M:TSK1]TSKORITXT
  If [M:TSK1]TSKORIADI = "" Then
    Raz [M:TSK1]TSKORIAOB
    [M:TSK1]TSKORIADI = "MAN1"
  Else
    # FGR 17/03/2010 : X3SUIVI62924 : pour faire correctement si on vient en création tunnel.
    [M:TSK1]TSKORIAOB = func CRMUTIL150.GET_AOB_FROM_ORI([M:TSK1]TSKORIADI)
    Call DEFOBJORI([M:TSK1]TSKORIAOB, [M:TSK1]TSKORIAVA) From CRMUTIL150
    Call LIEN_OBJ_DYNAMIC([M:TSK1]TSKORIVCR,[M:TSK1]TSKORIAOB,[M:TSK1]TSKORIAVA,"","","[M:TSK1]TSKORIVCRD") From CRMUTIL140
  Endif
  # FGR 08/03/2010 : X3SUIVI62924 (fin)
  Diszo [M:TSK1]TSKORIVCR
  Diszo [M:TSK1]TSKORIADI
  If !GIMPORT Then
    [M:TSK1]TSKORITYP = 1
  Else
    If GSYNCOUTLOOK = 0 Then
      [M:TSK1]TSKORITYP = 2
    Else
      [M:TSK1]TSKORITYP = 3
    Endif
  Endif
  #[M:TSK1]TSKORILIB = mess([M:TSK1]TSKORITYP,3037,1)  # FGR 08/03/2010 : X3SUIVI62924
  If [M:TSK0]TSKCMP <> "" Then
    #Définit l'interlocuteur par défaut de la tâche
    If [M:TSK0]TSKCCN = "" Then
      Call GETDEFCNT([M:TSK0]TSKCMP, [M:TSK0]TSKCCN) From CRMUTIL140
    Endif
    #Définit le représentant et le site par défaut.
    Read [BPR]BPR0=[M:TSK0]TSKCMP
    If fstat Then
      #Affiche le nom en clair du tiers sélectionné.
      [M:TSK0]TSKCMPCLA = ""
    Else
      #Affiche le nom en clair du tiers sélectionné.
      [M:TSK0]TSKCMPCLA = [F:BPR]BPRNAM
      If [M:TSK1]TSKREP = "" Then
        If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
          Read [BPC]BPC0=[M:TSK0]TSKCMP
          If !fstat Then
            If [F:BPC]REP(0) <> "" Then
              [M:TSK1]TSKREP = [F:BPC]REP(0)
            Else
              If [F:BPC]REP(1) <> "" Then
                [M:TSK1]TSKREP = [F:BPC]REP(1)
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
    #Affiche le type du tiers sélectionné.
    Call AFFICHE_BCK_TIERS([M:TSK0]TSKCMP) From SUBTSKB
  Endif
  If !GIMPORT Then
    If TUNNEL = 0 Then
      #On ne vient de nulle part
      If GDONDEFTSK = 2 Then
        SZNVGCOD = "~"
      Else
        SZNVGCOD = "£"
      Endif
    Elsif GPILNAV > 1 Then
      Case GNAVIG(GPILNAV-1)
        When "GESSRE"
          SZNVGCOD = [M:SRE0]NVGCOD
          Call GETSREOPP([M:SRE0]SRENUM, [M:TSK0]TSKPJT) From SUBSREB2
        When "FUNHDKAGD"
          SZNVGCOD = [M:HDK0]NVGCOD
          Call GETSREOPP([M:HDK0]HDKSRE, [M:TSK0]TSKPJT) From SUBSREB2
        When "GESBPR"
          SZNVGCOD = [M:BPR0]NVGCOD
        When "GESBPP"
          SZNVGCOD = [M:BPP0]NVGCOD
        When "GESBPC"
          SZNVGCOD = [M:BPC0]NVGCOD
        When "FUNCRM9"
          SZNVGCOD = [M:CRM9]NVGCOD
        When "FUNCRMAGD"
          SZNVGCOD = [M:CRM0]NVGCOD
        When "GESTSK"
          SZNVGCOD = [M:TSK0]NVGCOD
        When "GESCLL"
          SZNVGCOD = [M:CLL0]NVGCOD
        When "GESOPP"
          SZNVGCOD = [M:OPP0]NVGCOD
        When "GESLDS"
          # FGR 16/04/2012 : X3SUIVI81045
          SZNVGCOD = [M:LDS0]NVGCOD
        When Default
          If GDONDEFTSK = 2 Then
            SZNVGCOD = "~"
          Else
            SZNVGCOD = "£"
          Endif
      Endcase
    Endif
    If SZNVGCOD = "£" Then
      #Tâche à planifier
      [M:TSK0]TSKDON = 1
    Elsif SZNVGCOD = "~" Then
      #Tâche effectuée
      [M:TSK0]TSKDON = 2
    Endif
  Endif
  If GCRMDEFREP = 2 Then
    If [M:TSK1]TSKREP = "" Then
      Read [REP]REP1=GUSER
      If !fstat Then
        [M:TSK1]TSKREP = [F:REP]REPNUM
      Endif
    Endif
  Endif
  #LSE V150 09/08/2005
  #Utilisation ou non du site du représentant
  Call SITECRMREP("ACT", [M:TSK1]TSKREP, [M:TSK0]SALFCY) From CRM_UTIL
  #LSE 10/04/2006
  GFCY = [M:TSK0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBTSKB

  #Affichage de l'interlocuteur
  Gosub DISPCCN From SUBTSKB
  #Affichage background TSKCCN
  Gosub DISPBKGCCN From SUBTSKB

  [M:TSK2]HOUUOM = mess(1,976,1)   #Heures
  [M:TSK2]MNTUOM = mess(933,182,1) #Minutes
  Affzo [M:TSK0]1-99
  Affzo [M:TSK1]1-99
  Affzo [M:TSK2]1-99
Return

##########################################################################################################
$RAZDUP
  Raz GTBTSKFIELDSYL
  Raz GTBTSKVALSYL
  Raz GTBTSKCHRONOSYL
  GITSKNBSYL = 0

  #Origine
  [M:TSK1]CREDAT = date$
  [M:TSK1]CREUSR = GUSER
  Read [AUS]CODUSR=GUSER
  If fstat Then
    [M:TSK1]FULNAMUSR = GUSER
  Else
    [M:TSK1]FULNAMUSR = [F:AUS]NOMUSR
  Endif
  If !GIMPORT Then
    [M:TSK1]TSKORITYP = 1
  Else
    If GSYNCOUTLOOK = 0 Then
      [M:TSK1]TSKORITYP = 2
    Else
      [M:TSK1]TSKORITYP = 3
    Endif
  Endif
  #[M:TSK1]TSKORILIB = mess([M:TSK1]TSKORITYP,3037,1)  # FGR 08/03/2010 : X3SUIVI62924
  # FGR 08/03/2010 : X3SUIVI62924 (début)
  #[M:TSK1]TSKORIOBC = ""
  #[M:TSK1]TSKORI = 1
  #[M:TSK1]TSKORITXT = ""
  Raz [M:TSK1]TSKORIAOB
  [M:TSK1]TSKORIADI = "MAN1"
  # FGR 08/03/2010 : X3SUIVI62924 (fin)
  Affzo [M:TSK1]1-99
  Diszo [M:TSK1]TSKORIVCR
  #Diszo [M:TSK1]TSKORITXT
  Diszo [M:TSK1]TSKORIADI    # FGR 08/03/2010 : X3SUIVI62924
Return

##########################################################################################################
$VERIF_CRE_MOD
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZMESS(250)
Local Integer IASK

  IBRETOUR = 1
  SZMESS = ""
  IASK = 0
  Gosub VERIFDATE From SUBTSKB
  If OK = 0 Then
    Return
  Endif
  # FGR 06/07/2011 : X3SUIVI74797 : En fait pas si l'origine est "synchronisation" sinon ça devient obligatoire lorsqu'on modifie dans l'écran
  # FGR 09/10/2009 : X3SUIVI58275 : Pas si synchronisation outlook : l'info n'y est pas.
  #If [M:TSK0]TSKCMP = "" and  [M:TSK0]TSKCCN = "" and  [M:TSK0]TSKCOR = "" and GSYNCOUTLOOK = 0 Then
  If [M:TSK0]TSKCMP = "" and  [M:TSK0]TSKCCN = "" and  [M:TSK0]TSKCOR = "" and [M:TSK1]TSKORITYP <> 3 Then
    # FGR 20/08/2009 : X3SUIVI57294 : Au moins un des champs est renseigné
    GMESSAGE = mess(976,196,1) #Aucun représentant n'est mentionné.
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
    Return
  Endif
  #Affecte l'appel à l'utilisateur si rien n'a été saisi ni déduit.
  If [M:TSK1]TSKREP = "" Then
    Read [REP]REP1=GUSER
    If fstat Then
      GMESSAGE = mess(249,196,1) #Aucun représentant n'est mentionné.
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      Return
    Else
      #Aucun représentant n'a été saisi pour cette action. Souhaitez-vous l'affecter à :
      SZMESS = mess(409,182,1) - [F:REP]REPNAM - "(" + [F:REP]REPNUM + ")"
      Call OUINON(SZMESS, IASK) From GESECRAN
      If IASK = 2 Then
        [M:TSK1]TSKREP = [F:REP]REPNUM
        Affzo [M:TSK1]1-99
      Else
        GMESSAGE = mess(249,196,1) #Aucun représentant n'est mentionné.
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        Return
      Endif
    Endif
    #LSE 26/12/2006
    If [M:TSK1]TSKREP <> "" Then
      Call SITECRMREP("ACT", [M:TSK1]TSKREP, [M:TSK0]SALFCY) From CRM_UTIL
      GFCY = [M:TSK0]SALFCY
      Call GETDEV(GFCY) From DEVSUB
      Affzo [M:TSK0]SALFCY
    Endif
  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (début)
  #  #Assure enregistrement description abrégé
  #  If [M:TSK1]FULOBJ = "" Then
  #    [M:TSK1]TSKDES = ""
  #  Else
  #    [M:TSK1]TSKDES = left$([M:TSK1]FULOBJ,250)
  #  Endif
  #  #Assure enregistrement début cpt rendu
  #  If [M:TSK2]FULRPO = "" Then
  #    [M:TSK2]TSKRPO = ""
  #  Else
  #    [M:TSK2]TSKRPO = left$([M:TSK2]FULRPO,250)
  #  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (fin)
  #Assure le bon enregistrement de l'origine de la tâche
  # FGR 08/03/2010 : X3SUIVI62924 (début)
  #If [M:TSK1]TSKORI > 1 Then
  #  [M:TSK1]TSKORITXT = mess([M:TSK1]TSKORI,2992,1)
  #Else
  #  [M:TSK1]TSKORITXT = ""
  #Endif
  # FGR 08/03/2010 : X3SUIVI62924 (début)
  Gosub VERIFORI From SUBTSKB
  If GERR <> 0 Then
    OK = 0
    Return
  Endif
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
  If GERR <> 0 Then
    Return
  Endif
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  If not (GSYNCOUTLOOK = 1 and vireblc([M:TSK0]TSKNUM,2) <> "") Then
    #On n'est pas en restauration de synchro
    Call READ_COUNTER([M:TSK0]SALFCY, 13, 0, GSOCIETE, GCURLEG, GCTSKCPT, GMANCOU) From CRM_UTIL   # FGR 20/05/2015 : X3SUIVI107775
    # Récupération du compteur Activité commerciale
    If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", [M:TSK0]SALFCY, GCTSKCPT, date$, "", [M:TSK0]TSKNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
      If IBRETOUR = 1 Then
        [F:TSK]TSKNUM = [M:TSK0]TSKNUM
        Affzo [M:TSK0]TSKNUM
      Else
        # problème lors de la récupération du compteur
        GERR = 1
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GOK = 0
        Return
      Endif
    Endif
  Endif
  [F:TSK]NUMFULOBJ = [M:TSK0]TSKNUM
  [F:TSK]NUMFULRPO = [M:TSK0]TSKNUM
  [M:TSK1]NUMFULOBJ = [M:TSK0]TSKNUM
  [M:TSK2]NUMFULRPO = [M:TSK0]TSKNUM
  [F:TSK]CREHOU = left$(time$, 2) + mid$(time$, 4, 2)

  #On regarde si gestion du correspondant
  Call CORGERE ([M:TSK1]TSKREP, [M:TSK0]TSKCMP, [M:TSK0]TSKCCN, [M:TSK0]TSKCOR, IERRINF, ICHAPTER, IBRETOUR) From SUBCORB
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    GOK = 0
  Endif
  [F:TSK]TSKCOR = [M:TSK0]TSKCOR
  If [M:TSK0]TSKCOR <> "" Then
    Affzo [M:TSK0]TSKCOR
  Endif
Return

##########################################################################################################
$VERIF_MOD
  Gosub VERIF_CRE_MOD
  If GERR <> 0 Then
    Return
  Endif
Return

##########################################################################################################
$INIMOD
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  IBRETOUR = 1
  #On regarde si gestion du correspondant
  Call CORGERE ([M:TSK1]TSKREP, [M:TSK0]TSKCMP,[M:TSK0]TSKCCN,[M:TSK0]TSKCOR, IERRINF, ICHAPTER, IBRETOUR) From SUBCORB
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    GOK = 0
    Return
  Endif
  [F:TSK]TSKCOR=[M:TSK0]TSKCOR
  If [M:TSK0]TSKCOR <> "" Then
    Affzo [M:TSK0]TSKCOR
  Endif
Return

##########################################################################################################
$CREATION
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  IBRETOUR = 1
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBTSKB
  If GOK < 1 Then
    Return
  Endif
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_CREATION From SUBTSKB
  If GOK < 1 Then
    Return
  Endif
  #Traitement des données de synchro pour la tache
  Call SYDTSKCRE (IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("TSK",1) From SUBPS2
Return

##########################################################################################################
$AVANT_MODFIC
Return

##########################################################################################################
$MODIF
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IINDICE

  IINDICE = 0
  IBRETOUR = 1
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBTSKB
  If GOK < 1 Then
    Return
  Endif
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_MODIF From SUBTSKB
  If GOK < 1 Then
    Return
  Endif
  #Traitement de la synchronisation outlook
  Call SYDTSKUPD (IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
  If GOK < 1 Then
    Return
  Endif
  #traitement des erreurs de transcodification
  If GITSKNBSYL > 0 Then
    While IINDICE < GITSKNBSYL
      If GTBTSKVALSYL(IINDICE) <> evalue ("[M]" + GTBTSKFIELDSYL(IINDICE)) Then
        #On a une modification du champs, on estime transcodif faite
        Read [SYL]SYL0=GTBTSKCHRONOSYL(IINDICE )
        If fstat = 0 Then
          [F:SYL]SYLFLGDPT = 0
          Rewrite [SYL]
        Endif
      Endif
      IINDICE = IINDICE + 1
    Wend
  Endif
  # Maj des statistiques
  Call VALSTA("TSK",-1) From SUBPS2
  Call VALSTA("TSK",1) From SUBPS2
Return

##########################################################################################################
$AV_ANNULE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  IBRETOUR = 1
  #Suppression des clobs
  Gosub DELCLOB From SUBTSKB
  If GOK < 1 Then
    Return
  Endif
  # FGR 12/08/2009 : X3SUIVI57005 : C'est pas là que ça doit être
  #Enregistrement des données pour les encours
  #Gosub GERE_LCM_ANNULE From SUBTSKB
  #If GOK < 1 Then
  #  Return
  #Endif
  Call SYDTSKDEL (IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
  If GOK < 1 Then
    Return
  Endif
  #Suppression donnée transcodif
  Call SYLDELETE("TSK", [M:TSK0]TSKNUM,IERRINF, ICHAPTER, IBRETOUR) From SUBSYLB
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$ANNULE
  # Maj des statistiques
  Call VALSTA("TSK",-1) From SUBPS2
Return

##########################################################################################################
$APRES_ANNULE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  # FGR 12/08/2009 : X3SUIVI57005 : Pour le moment, il n'y a que là qu'on peut le mettre
  #                  Le pb c'est que ça n'est pas dans la transaction, donc si ça échoue,
  #                  L'enregistrement sera détruit, mais les Premier/Dernier/Prochain ne seront pas forcément à jour
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_ANNULE From SUBTSKB
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$APRES_CRE
  #Sauvegarde données courant
  [M:TSK0]SALFCYINI = [M:TSK0]SALFCY
  [M:TSK0]TSKCMPINI = [M:TSK0]TSKCMP
  [M:TSK0]TSKDONINI = [M:TSK0]TSKDON
  [M:TSK1]TSKSTRINI = [M:TSK1]TSKSTR
  [M:TSK1]TSKDATINI = [M:TSK1]TSKDAT
  [M:TSK1]TSKREPINI = [M:TSK1]TSKREP
  [M:TSK1]CREHOU = left$([F:TSK]CREHOU, 2) + mid$([F:TSK]CREHOU, 3, 2)
  Diszo [M:TSK1]TSKORIVCR
  #Diszo [M:TSK1]TSKORITXT
  Diszo [M:TSK1]TSKORIADI   # FGR 08/03/2010 : X3SUIVI62924
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBTSKB
  Affzo [M:TSK1]1-99
  Affzo [M:TSK2]1-99
Return

##########################################################################################################
$APRES_MOD
  #Sauvegarde données courant
  [M:TSK0]SALFCYINI = [M:TSK0]SALFCY
  [M:TSK0]TSKCMPINI = [M:TSK0]TSKCMP
  [M:TSK0]TSKDONINI = [M:TSK0]TSKDON
  [M:TSK1]TSKSTRINI = [M:TSK1]TSKSTR
  [M:TSK1]TSKDATINI = [M:TSK1]TSKDAT
  [M:TSK1]TSKREPINI = [M:TSK1]TSKREP
  Diszo [M:TSK1]TSKORIVCR
  #Diszo [M:TSK1]TSKORITXT
  Diszo [M:TSK1]TSKORIADI   # FGR 08/03/2010 : X3SUIVI62924
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBTSKB
  Affzo [M:TSK1]1-99
  Affzo [M:TSK2]1-99
Return

##########################################################################################################
$FILTRE
  Default File [TSK]
Return

##########################################################################################################
$FILGAUCHE
  Default File [TSK]
  If currbox = GBOXTSK Then
    #Tâches à effectuer
    Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "TSKDON <> 2", "&") From GOBJSUB
  Elsif currbox = GBOXTS2 Then
    #Tâches effectuées
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "TSKDON = 2", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "TSK") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Elsif currbox = GBOXTS3 Then
    #Mes tâches à effectuer
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "TSKDON <> 2 AND TSKREP=GAUSCRMF", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "TSK") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Elsif currbox = GBOXTS4 Then
    #Mes tâches effectuées
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "TSKDON = 2 AND TSKREP=GAUSCRMF", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "TSK") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Endif
Return

##########################################################################################################
$LIENS
  #LSE 10/04/2006
  GFCY = [M:TSK0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  #Sauvegarde données courant
  [M:TSK0]SALFCYINI = [M:TSK0]SALFCY
  [M:TSK0]TSKCMPINI = [M:TSK0]TSKCMP
  [M:TSK0]TSKDONINI = [M:TSK0]TSKDON
  [M:TSK1]TSKSTRINI = [M:TSK1]TSKSTR
  [M:TSK1]TSKDATINI = [M:TSK1]TSKDAT
  [M:TSK1]TSKREPINI = [M:TSK1]TSKREP
  #---------------------------------------------------#
  #Lecture des clobs
  #---------------------------------------------------#
  Gosub LOADCLOB From SUBTSKB
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBTSKB
  #Affiche l'unité "JOUR" du champs Etre informé d'un retard au bout de
  [M:TSK1]TSKDELX = mess(2,976,1)
  Affzo [M:TSK1]TSKDELX
  #---------------------------------------------------#
  #  Origine
  #---------------------------------------------------#
  If [M:TSK1]CREUSR <> "" Then
    Read [AUS]CODUSR=[M:TSK1]CREUSR
    If fstat = 0 Then
      [M:TSK1]FULNAMUSR = [F:AUS]NOMUSR
    Endif
    Affzo [M:TSK1]FULNAMUSR
  Endif
  #[M:TSK1]TSKORILIB = mess([M:TSK1]TSKORITYP,3037,1)  # FGR 08/03/2010 : X3SUIVI62924
  # FGR 08/03/2010 : X3SUIVI62924 (début)
  #If [M:TSK1]TSKORI = 1 Then
  #  [M:TSK1]TSKORITXT = ""
  #Else
  #  [M:TSK1]TSKORITXT = mess([M:TSK1]TSKORI,2992,1)
  #Endif
  # FGR 08/03/2010 : X3SUIVI62924 (début)
  #Définition du type de pièce
  #Gosub DEFOBJORI From SUBTSKB
  Call DEFOBJORI([M:TSK1]TSKORIAOB, [M:TSK1]TSKORIAVA) From CRMUTIL150    # FGR 08/03/2010 : X3SUIVI62924
  Diszo [M:TSK1]TSKORIVCR
  #Diszo [M:TSK1]TSKORITXT
  Diszo [M:TSK1]TSKORIADI   # FGR 08/03/2010 : X3SUIVI62924
  #Call LIEN_OBJ_DYNAMIC([M:TSK1]TSKORIVCR,[M:TSK1]TSKORIOBC,[M:TSK1]TSKORIAVA,"","","[M:TSK1]TSKORIVCRD") From CRMUTIL140 # FGR 12/02/2009 : X3SUIVI52443
  Call LIEN_OBJ_DYNAMIC([M:TSK1]TSKORIVCR,[M:TSK1]TSKORIAOB,[M:TSK1]TSKORIAVA,"","","[M:TSK1]TSKORIVCRD") From CRMUTIL140   # FGR 08/03/2010 : X3SUIVI62924
  #---------------------------------------------------#
  #Affiche le nom en clair du tiers sélectionné.
  #---------------------------------------------------#
  Read [BPR]BPR0=[M:TSK0]TSKCMP
  If fstat = 0 Then
    [M:TSK0]TSKCMPCLA = [F:BPR]BPRNAM
  Else
    [M:TSK0]TSKCMPCLA = ""
  Endif
  #---------------------------------------------------#
  #Affiche le type du tiers sélectionné.
  #---------------------------------------------------#
  Call AFFICHE_BCK_TIERS([M:TSK0]TSKCMP) From SUBTSKB
  #---------------------------------------------------#
  # Interdit la modification du champs Signaler le retard au bout de
  #---------------------------------------------------#
  If [M:TSK1]CREUSR = GUSER Then
    Actzo [M:TSK1]TSKDEL
  Else
    Grizo [M:TSK1]TSKDEL
  Endif
  #Affichage de l'interlocuteur
  Gosub DISPCCN From SUBTSKB
  #Affichage background TSKCCN
  Gosub DISPBKGCCN From SUBTSKB
  #
  [M:TSK2]HOUUOM = mess(1,976,1)   # Heures
  [M:TSK2]MNTUOM = mess(933,182,1) # Minutes
  [M:TSK1]CREHOU = left$([M:TSK1]CREHOU, 2) + mid$([M:TSK1]CREHOU, 3, 2)
  #
  #Gestion de la transcodif
  Raz GTBTSKFIELDSYL
  Raz GTBTSKVALSYL
  Raz GTBTSKCHRONOSYL
  GITSKNBSYL = 0
  # FGR 10/04/2008 : X3SUIVI46720 : cas qui s'est produit à cause d'une erreur de données dans la base
  #                  mais normalement impossible !
  If [M:TSK0]TSKNUM <> "" Then
    For [SYL] Where [F:SYL]SYLTYP = "TSK" and [F:SYL]SYLKEY = [M:TSK0]TSKNUM and [F:SYL]SYLFLGDPT = 1
      GTBTSKFIELDSYL(GITSKNBSYL) = [F:SYL]SYLFIE
      GTBTSKVALSYL(GITSKNBSYL) = evalue("[M]"+[F:SYL]SYLFIE)
      GTBTSKCHRONOSYL(GITSKNBSYL) = [F:SYL]SYLNUM
      GITSKNBSYL = GITSKNBSYL + 1
    Next
  Endif
  #
  Affzo [M:TSK0]1-99
  Affzo [M:TSK1]1-99
  Affzo [M:TSK2]1-99
Return

##########################################################################################################
Subprog IB_TSKCMP

  # FGR 05/04/2011 : X3SUIVI72615
  GBOUT1 = [M:TSK0]TSKCMPLIB
  If [M:TSK0]TSKCMPAOB = "BPR" Then
    Raz GBOUT3
  Endif
  Call IB_NOTECHECK([M:TSK0]TSKCMP,"CRM",4)  From TRTNTSCTL # CRM notes
End

##########################################################################################################
Subprog AM_TSKCMP(VALEUR)
Variable Char    VALEUR()

  #Définit le représentant et le site par défaut.
  Raz [M:TSK0]TSKCCN
  Raz [M:TSK0]TSKCCNCLA
  #On réinitialise le correspondant
  Raz [M:TSK0]TSKCOR
  Read [BPR]BPR0=VALEUR
  If fstat Then
    #Affiche le nom en clair du tiers sélectionné.
    [M:TSK0]TSKCMPCLA = ""
  Else
    #Définit l'interlocuteur par défaut de la tâche
    Call GETDEFCNT(VALEUR, [M:TSK0]TSKCCN) From CRMUTIL140
    #Affiche le nom en clair du tiers sélectionné.
    [M:TSK0]TSKCMPCLA = [F:BPR]BPRNAM
    If [M:TSK1]TSKREP = "" Then
      If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
        Read [BPC]BPC0=VALEUR
        If !fstat Then
          If [F:BPC]REP(0) <> "" Then
            [M:TSK1]TSKREP = [F:BPC]REP(0)
          Else
            If [F:BPC]REP(1) <> "" Then
              [M:TSK1]TSKREP = [F:BPC]REP(1)
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  #Affiche le type du tiers sélectionné.
  Call AFFICHE_BCK_TIERS(VALEUR) From SUBTSKB
  #Utilisation ou non du site du représentant
  Call SITECRMREP("ACT", [M:TSK1]TSKREP, [M:TSK0]SALFCY) From CRM_UTIL
  [M:TSK0]TSKCMP = VALEUR
  Gosub DISPCCN From SUBTSKB
  #Affichage background TSKCCN
  Gosub DISPBKGCCN From SUBTSKB
  Gosub VERIFCCNCOR From SUBTSKB
  Gosub DEFCOR From SUBTSKB
  Affzo [M:TSK0]1-99
  Affzo [M:TSK1]1-99
End

##########################################################################################################
Subprog AM_TSKREP(VALEUR)
Variable Char    VALEUR()

  Call SITECRMREP("ACT", VALEUR, [M:TSK0]SALFCY) From CRM_UTIL
  GFCY = [M:TSK0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  Affzo [M:TSK0]SALFCY
End

##########################################################################################################
Subprog AM_TSKRPO(VALEUR)
Variable Char    VALEUR()
End

##########################################################################################################
Subprog AM_TSKDON(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    If [M:TSK2]TSKSAO = "" Then
      Call DEFVALADI(435, [M:TSK2]TSKSAO) From CRMUTIL140
    Endif
  Endif
  Affzo [M:TSK2]TSKSAO
End

##########################################################################################################
Subprog IB_TSKORIVCR
Local Integer IFUPEXIST

  # FGR 08/03/2010 : X3SUIVI62924
  If [M:TSK1]TSKORIADI = "MAN1" Then
    # Si c'est "MAN1" on ne peut pas indiquer d'objet donc pas de bouton
    Raz GBOUTS
    Raz GBOUT1
    Raz GBOUT2
  Else
    Raz GBOUT1
    If [M:TSK1]TSKORITYP <> 2 Then
      If varmode([M:TSK1]TSKORIVCR, 0) <> 0 Then
        Raz GBOUTS
        GBOUT2 = mess(257,177,1)
      Else
        Raz GBOUT2
      Endif
    Else
      Raz GBOUTS
      Raz GBOUT2
    Endif
    #If [M:TSK1]TSKORIOBC <> "" and [M:TSK1]TSKORIVCR <> "" Then
    If [M:TSK1]TSKORIAOB <> "" and [M:TSK1]TSKORIVCR <> "" Then   # FGR 08/03/2010 : X3SUIVI62924
      #Détail pièce
      GBOUT1 = mess(103,182,1)
    Endif
  Endif
End

##########################################################################################################
Subprog B2_TSKORIVCR(VALEUR)
Variable Char    VALEUR()

  #Actzo [M:TSK1]TSKORITXT
  Actzo [M:TSK1]TSKORIADI   # FGR 08/03/2010 : X3SUIVI62924
  Actzo [M:TSK1]TSKORIVCR
  mkstat = 4
End

##########################################################################################################
Subprog C_TSKORIVCR(VALEUR)
Variable Char    VALEUR()

Local Char SZMESSAGE(250)
Local Integer IBRETOUR

  #If [M:TSK1]TSKORIOBC = "" Then
  If [M:TSK1]TSKORIAOB = "" Then   # FGR 08/03/2010 : X3SUIVI62924
    If VALEUR <> "" Then
      #Vous devez d'abord choisir une origine
      GMESSAGE = mess(526,177,1)
      mkstat = 1
      End
    Endif
  Endif
  #If VALEUR <> "" and [M:TSK1]TSKORIOBC <> "" Then
  If VALEUR <> "" and [M:TSK1]TSKORIAOB <> "" Then   # FGR 08/03/2010 : X3SUIVI62924
    # FGR 21/01/2009 : X3SUIVI33671 : ajout du site
    #Call VERIFOBJCODE([M:TSK1]TSKORIOBC, [M:TSK0]SALFCY, VALEUR, SZMESSAGE, IBRETOUR) From CRMUTIL150
    Call VERIFOBJCODE([M:TSK1]TSKORIAOB, [M:TSK0]SALFCY, VALEUR, SZMESSAGE, IBRETOUR) From CRMUTIL150   # FGR 08/03/2010 : X3SUIVI62924
    If IBRETOUR = 0 Then
      GMESSAGE = SZMESSAGE
      mkstat = 1
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AM_TSKORIVCR(VALEUR)
Variable Char    VALEUR()

Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Char SZCMGNUM(GLONVCR)

  Affzo [M:TSK0]TSKCMP
  If left$([M:TSK1]TSKORIADI, 3) = "MKT" Then          # FGR 08/03/2010 : X3SUIVI62924
    #If VALEUR <> "" and [M:TSK1]TSKORIOBC <> "" Then
    If VALEUR <> "" and [M:TSK1]TSKORIAOB <> "" Then   # FGR 08/03/2010 : X3SUIVI62924
      # FGR 01/12/2008 : X3SUIVI50722
      #Call GETCMG_OBJCODE("", [M:TSK1]TSKORIOBC, VALEUR, SZCMGNUM, SZMESSAGE, IBRETOUR) From CRMUTIL150
      Call GETCMG_OBJCODE("", [M:TSK1]TSKORIAOB, VALEUR, SZCMGNUM, SZMESSAGE, IBRETOUR) From CRMUTIL150
      If IBRETOUR = 0 Then
        GMESSAGE = SZMESSAGE
        mkstat = 1
        End
      Endif
      [M:TSK1]TSKCMGNUM = SZCMGNUM
      #[M:TSK1]TSKOPGTYP = [M:TSK1]TSKORIOBC  # FGR 21/04/2009 : X3SUIVI54457 : ça manquait un peu !
      [M:TSK1]TSKOPGTYP = [M:TSK1]TSKORIAOB   # FGR 08/03/2010 : X3SUIVI62924
      [M:TSK1]TSKOPGNUM = VALEUR              # FGR 21/04/2009 : X3SUIVI54457 : ça manquait un peu !
    Endif
  Else
    Raz [M:TSK1]TSKCMGNUM
    Raz [M:TSK1]TSKOPGTYP
    Raz [M:TSK1]TSKOPGNUM
  Endif
End

##########################################################################################################
Subprog IB_TSKREP

  Raz GBOUT3
  If [M:TSK0]TSKCMP <> "" Then
    Read [BPC]BPC0=[M:TSK0]TSKCMP
    If !fstat Then
      #Représentants secondaires
      Call TEXTE(15800, GBOUT3) From OBJDIV
    Endif
  Endif
End

##########################################################################################################
Subprog IB_FULOBJ

  Raz GBOUT1
  If [M:TSK1]FULOBJ <> "" Then
    If len([M:TSK1]FULOBJ) > GLONCLE Then
      Call TEXTE(23819, GBOUT1) From OBJDIV      #Synthèse
    Endif
  Endif
End

##########################################################################################################
Subprog AM_FULOBJ (VALEUR)
Variable Clbfile VALEUR

  Call GERE_TEXTE_SYNTHESE([M:TSK1]FULOBJ, VALEUR, [M:TSK1]TSKDES) From CRMUTIL150  # FGR 06/08/2014 : X3SUIVI95250
  [M:TSK1]FULOBJ = VALEUR
  Gosub DISPICON From SUBTSKB
  Affzo [M:TSK1]OBJICO
End

##########################################################################################################
Subprog IB_FULRPO

  Raz GBOUT1
  If [M:TSK2]FULRPO <> "" Then
    If len([M:TSK2]FULRPO) > GLONCLE Then
      Call TEXTE(23819, GBOUT1) From OBJDIV      #Synthèse
    Endif
  Endif
End

##########################################################################################################
Subprog AM_FULRPO (VALEUR)
Variable Clbfile VALEUR

  Call GERE_TEXTE_SYNTHESE([M:TSK2]FULRPO, VALEUR, [M:TSK2]TSKRPO) From CRMUTIL150  # FGR 06/08/2014 : X3SUIVI95250
  [M:TSK2]FULRPO = VALEUR
  Gosub DISPICON From SUBTSKB
  Affzo [M:TSK2]RPOICO
End

##########################################################################################################
Subprog AM_TSKCCN(VALEUR)
Variable Char    VALEUR()

  #On réinitialise le correspondant
  [M:TSK0]TSKCOR = ""
  [M:TSK0]CCNTYP = [F:AIN]CNTTYP
  [M:TSK0]TSKCCN = VALEUR
  #Affichage de l'interlocuteur
  Gosub DISPCCN From SUBTSKB
  #Affichage background TSKCCN
  Gosub DISPBKGCCN From SUBTSKB
  Gosub VERIFCCNCOR From SUBTSKB
  Gosub DEFCOR From SUBTSKB
  Affzo [M:TSK0]1-99
End

##########################################################################################################
Subprog C_MNTTIMSPG(VALEUR)
Variable Decimal VALEUR

  If VALEUR > 59 Then
    #Le nombre de minutes ne peut pas être supérieur à 59. Saisie refusée.
    GMESSAGE = mess(248,182,1)
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog IB_TSKORIADI

  # FGR 08/03/2010 : X3SUIVI62924
  If [M:TSK1]TSKORITYP <> 2 Then
    If varmode ([M:TSK1]TSKORIADI, 0) = 0 Then
      Raz GBOUT2
    Else
      GBOUT2 = mess(257,177,1)
    Endif
  Else
    Raz GBOUT2
  Endif
End

##########################################################################################################
Subprog AM_TSKORIADI(VALEUR)
Variable Char    VALEUR()

Local Char SZTSKORIAOB(GLONAOB)

  # FGR 08/03/2010 : X3SUIVI62924
  #Définition du type de pièce
  If VALEUR = "" Then
    VALEUR = "MAN1"
  Endif
  SZTSKORIAOB = [M:TSK1]TSKORIAOB
  [M:TSK1]TSKORIAOB = func CRMUTIL150.GET_AOB_FROM_ORI(VALEUR)
  #Gosub DEFOBJORI From SUBTSKB
  Call DEFOBJORI([M:TSK1]TSKORIAOB, [M:TSK1]TSKORIAVA) From CRMUTIL150
  If SZTSKORIAOB <> [M:TSK1]TSKORIAOB Then
    Raz [M:TSK1]TSKORIVCR
    Raz [M:TSK1]TSKORIVCRL
    Raz [M:TSK1]TSKCMGNUM
    Raz [M:TSK1]TSKOPGTYP
    Raz [M:TSK1]TSKOPGNUM
    Raz [M:TSK1]TSKORIVCRD
    Affzo [M:TSK1]1-99
  Endif
End

##########################################################################################################
Subprog B2_TSKORIADI(VALEUR)
Variable Char    VALEUR()

  # FGR 08/03/2010 : X3SUIVI62924
  Actzo [M:TSK1]TSKORIADI
  Actzo [M:TSK1]TSKORIVCR
  mkstat = 4
End

##########################################################################################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()

  If GREP = "C" Then
    Local Char SZFCY(GLONFCY)
    Local Char SZCRMREP
    Local Integer ICRMREP
    Local Char SZCRMDEF
    Local Integer ICRMDEF
    Local Char SZDONDEF
    Local Integer IDONDEF

    [M:TSK1]TSKREP = ""
    SZFCY = VALEUR
    SZCRMREP = ""
    ICRMREP = 1
    SZCRMDEF = ""
    ICRMDEF = 1
    SZDONDEF = ""
    IDONDEF = 1
    Call PARAMUTIL("CRMREPTSK", SZCRMREP, GUSER, SZFCY) From SUBAUS
    If SZCRMREP = "" Then
      ICRMREP = 1
    Else
      ICRMREP = val(SZCRMREP)
    Endif
    Call PARAMUTIL("CRMDEFREP", SZCRMDEF, GUSER, SZFCY) From SUBAUS
    If SZCRMDEF = "" Then
      ICRMDEF = 1
    Else
      ICRMDEF = val(SZCRMDEF)
    Endif
    Call PARAMUTIL("DONDEFTSK", SZDONDEF, GUSER, SZFCY) From SUBAUS
    If SZDONDEF = "" Then
      IDONDEF = 1
    Else
      IDONDEF = val(SZDONDEF)
    Endif
    If ICRMREP = 2 Then
      Read [REP]REP1=GUSER
      If !fstat Then
        [M:TSK1]TSKREP = [F:REP]REPNUM
      Endif
    Endif
    If [M:TSK0]TSKCMP <> "" Then
      #Définit le représentant et le site par défaut.
      Read [BPR]BPR0=[M:TSK0]TSKCMP
      If !fstat Then
        If [M:TSK1]TSKREP = "" Then
          If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
            Read [BPC]BPC0=[M:TSK0]TSKCMP
            If !fstat Then
              If [F:BPC]REP(0) <> "" Then
                [M:TSK1]TSKREP = [F:BPC]REP(0)
              Else
                If [F:BPC]REP(1) <> "" Then
                  [M:TSK1]TSKREP = [F:BPC]REP(1)
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
    If ICRMDEF = 2 Then
      If [M:TSK1]TSKREP = "" Then
        Read [REP]REP1=GUSER
        If !fstat Then
          [M:TSK1]TSKREP = [F:REP]REPNUM
        Endif
      Endif
    Endif
    If !GIMPORT Then
      If GTSKTUNNEL = 0 Then
        #On ne vient de nulle part
        If IDONDEF = 2 Then
          #Tâche effectuée
          [M:TSK0]TSKDON = 2
        Else
          #Tâche à planifier
          [M:TSK0]TSKDON = 1
        Endif
      Endif
    Endif
  Endif
  GFCY = VALEUR
  Call GETDEV(GFCY) From DEVSUB
  Affzo [M:TSK0]1-99
  Affzo [M:TSK1]1-99
End

##########################################################################################################
Subprog IB_TSKCCN

  Filter [AIN]
  If [M:TSK0]TSKCMP = "" Then
    Raz GBOUT2
  Endif
End

##########################################################################################################
Subprog AM_TSKCOR(VALEUR)
Variable Char    VALEUR()

  #Table COR chargé par le controle
  If [F:COR]CNTNUM <> "" Then
    Call AM_TSKCCN([F:COR]CNTNUM) From SUBTSK
    Affzo [M:TSK0]TSKCCN
  Endif
  If [F:COR]BPRNUM <> "" Then
    If [M:TSK0]TSKCMP = "" Then
      Call AM_TSKCMP([F:COR]BPRNUM) From SUBTSK
      Affzo [M:TSK0]TSKCMP
    Endif
  Endif
End

