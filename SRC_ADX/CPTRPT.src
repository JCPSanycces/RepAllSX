#<AdxTL>@(#)0.0.0.0 $Revision$ Traitement d'init des éditions
Local Char PARAM(10)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AIMP1","AIMP1",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "OUVRE"   : Gosub OUVRE
 When "INIPAR"  : Gosub INIPAR
 When "INIPAR2" : Gosub INIPAR2
 When "CONT1"   : Gosub CONT1
Endcase
Return

$OUVRE
If clalev([F:BUP])=0  : Local File BUDPAR     [BUP]  : Endif
If clalev([F:FGR])=0  : Local File FACGROUP   [FGR]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
If clalev([F:COA])=0  : Local File GCOA       [COA]  : Endif
If clalev([F:DIE])=0  : Local File GDIE       [DIE]  : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX]  : Endif
If clalev([F:GYM])=0  : Local File GACCPYM    [GYM]  : Endif
If clalev([F:ARM])=0  : Local File AREPORTM   [ARM]  : Endif
If clalev([F:GSC])=0  : Local File GRPSAC     [GSC]  : Endif
If clalev([F:JOU])=0  : Local File GJOURNAL   [JOU]  : Endif
If clalev([F:JOU1])=0 : Local File GJOURNAL   [JOU1] : Endif
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif
If clalev([F:TPY])=0  : Local File TABPAYTYP  [TPY]  : Endif
If clalev([F:CDA])=0  : Local File GACCDENCOD [CDA]  : Endif
If clalev([F:TVT])=0  : Local File TABVAT     [TVT]  : Endif
Return

## Called from AIMP1 : Initialize VALEUR
$INIPAR
Local Integer K , AXE
Local Integer REFERENTIEL
Local Char    SOCIETE(GLONCPY)

# If we close with the red cross the lookup on a parameter with GAC data type, the process recalls
# INIPAR From CPTRPT in FMTVARB.But for the GLVATGEN and BUDREV reports there is a specific $INIPAR.
# Verrue si on ferme la fenêtre de sélection d'un compte comme  par la croix rouge
# on repasse par là : appel de FMTVARB. Or pour les états GLVATGEN/BURREV
# le INIPAR est spécifique
If [M:RPT]ETAT = "GLVATGEN"
 Gosub INIPAR From GLVATAUX
Elsif [M:RPT]ETAT ="BUDREV"
 Gosub INIPAR From TRTBUDREV
Elsif [M:RPT]RPTCOD ="BUDGET"
 If [M:RPT]PARCOD(nolign-1)="sitedeb"
  K = find("codbud",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  If K
   Read [BUP]BUP0 = [M:RPT]VALINT1(K-1)
   If !fstat & [F:BUP]LEV<>2 : mkstat=2 : VALEUR=" " :  Return : Endif
  Endif
 Endif
Else
 #INIPAR standard
 Case [M:RPT]PARCOD(nolign-1)
  When "comptedeb","cptdeb","natdeb"
   Gosub SETSOC
   If SOCIETE<>""
    K = find("referentiel",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
    If K
     REFERENTIEL = val([M:RPT]VALINT1(K-1))
     Read [GCM]GCM0 = [F:CPY]ACM
     Read [LED]LED0 = [F:GCM]LED(REFERENTIEL-1)
     Read [COA]COA0 = [F:LED]COA
     Call INIACCFMT([F:LED]COA) From SETGLBCOA
    Endif
   Endif
  When "secdeb","sec1deb","sec2deb","sec3deb"
   AXE = val(right$([M:RPT]PARCOD(nolign-1),4))
   If AXE=0
    PARA = "axe"
   Else
    PARA = "axe"+num$(AXE)
   Endif
   K = find(PARA,[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
   If K
    If [M:RPT]VALEUR1(K-1)<>""
     Read [DIE]DIE0 = [M:RPT]VALEUR1(K-1)
    Endif
   Endif
  When "grpcol","grpacol","grpbcol" : # Groupe de collectifs X3-22084
   Gosub SETSOC
   If SOCIETE<>""
    Read [GCM]GCM0 = [F:CPY]ACM
    K = find("referentiel",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
    If K
     REFERENTIEL = val([M:RPT]VALINT1(K-1))
     Read [LED]LED0 = [F:GCM]LED(REFERENTIEL-1)
    Else
     Read [LED]LED0 = [F:GCM]LED([F:GCM]GENLEDTYP-1)
    Endif
   Endif
  When "coldeb","coladeb","colbdeb" : # Collectifs X3-22084
   Gosub SETSOC
   If SOCIETE<>""
    Read [GCM]GCM0 = [F:CPY]ACM
    K = find("referentiel",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
    If K
     REFERENTIEL = val([M:RPT]VALINT1(K-1))
     Read [LED]LED0 = [F:GCM]LED(REFERENTIEL-1)
    Else
     Read [LED]LED0 = [F:GCM]LED([F:GCM]GENLEDTYP-1)
    Endif
    Filter [GAC] Where COA=[F:LED]COA
   Endif
 Endcase
Endif
Return

## Called from AIMP1 : Initialize VALEUR2
$INIPAR2
Case [M:RPT]PARCOD(nolign-1)
 When "comptedeb","cptdeb","natdeb","coldeb","coladeb","colbdeb" : Gosub INIPAR : # X3-22084
Endcase
If [M:RPT]RPTCOD ="BUDGET"
 If [M:RPT]PARCOD(nolign-1)="sitedeb"
  K = find("codbud",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  If K
   Read [BUP]BUP0 = [M:RPT]VALINT1(K-1)
   If !fstat & [F:BUP]LEV<>2 : mkstat=2 : VALEUR=" " : Return : Endif
  Endif
 Endif
Endif
Return

$SETSOC
SOCIETE = ""
K = find("societe",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
If K
 SOCIETE = [M:RPT]VALINT1(K-1)
 Read [CPY]CPY0 = SOCIETE
 If [F:CPY]CPYLEGFLG<>2
  Read [FGR]FGR0(1) = SOCIETE
  Read [FCY]FCY0 = [F:FGR]FCY
  SOCIETE = [F:FCY]LEGCPY
  Read [CPY]CPY0 = SOCIETE
 Endif
Endif
Return

## Called from AIMP1 : Contol VALEUR1
$CONT1
Case [M:RPT]PARCOD(nolign-1)
 When "codbud"
  Read [BUP]BUP0 = VALEUR
 When "coldeb","coladeb","colbdeb" : # X3-22084
  Filter [GAC]
 When "grpcol","grpacol","grpbcol" : # X3-22084
  Gosub SETSOC
  If SOCIETE<>""
   Read [GCM]GCM0 = [F:CPY]ACM
   K = find("referentiel",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
   If K
    REFERENTIEL = val([M:RPT]VALINT1(K-1))
    Read [LED]LED0 = [F:GCM]LED(REFERENTIEL-1)
   Else
    Read [LED]LED0 = [F:GCM]LED([F:GCM]GENLEDTYP-1)
   Endif
  Endif
 When "pyramide"
  If VALEUR<>""
   Gosub SETSOC
   If SOCIETE<>""
    K = find("referentiel",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
    If K
     REFERENTIEL = val([M:RPT]VALINT1(K-1))
     Read [GCM]GCM0 = [F:CPY]ACM
     Read [LED]LED0 = [F:GCM]LED(REFERENTIEL-1)
     Read [GYM]GYM0=VALEUR
     If fstat | [F:LED]COA<>[F:GYM]COA
      GMESSAGE = mess(93,108,1)-[F:GYM]COA
      mkstat = 2 : Return
     Endif
    Endif
   Endif
  Endif
Endcase

# BODEL X3-35088 .s
# If we're in BALGRP or BALGRPDEV and the parameter we're controlling is "export"
# then clear the dimension and dimension type fields when All dimensions are selected
# and then set the next field
If find([M:RPT]RPTCOD,"BALGRP","BALGRPDEV")
Case [M:RPT]PARCOD(nolign-1)
 When "export"
  Local Integer P3
  P3=nolign
  If VALINT1(nolign-1)="2"
    Raz [M]VALEUR1 (P3), [M]VALEUR1 (P3+1) # To clear dim or dim type when all dimensions selected
    Call CHARGE([M]VALEUR1(P3+1),[M]NOLIB(P3+1), [M]LONG(P3+1), [M]VALINT1(P3+1)) From FMTVAR
    Call CHARGE([M]VALEUR1(P3),[M]PARTYP(P3),[M]NOLIB(P3),[M]LONG(P3),[M]VALINT1(P3)) From FMTVAR
    Grizo [M]VALEUR1 (P3)
    Grizo [M]VALEUR1 (P3+1)
  Else
    Actzo [M]VALEUR1 (P3)
    Actzo [M]VALEUR1 (P3+1) #To set dimension type and dimension fields
    Call CHARGE([M]VALEUR1(P3+1),[M]PARTYP(P3+1),[M]NOLIB(P3+1),[M]VALINT1(P3+1)) From FMTVAR
    Call CHARGE([M]VALEUR1(P3),[M]PARTYP(P3),[M]NOLIB(P3),[M]LONG(P3),[M]VALINT1(P3)) From FMTVAR
    Affzo [M:RPT]PARCOD(P3)
    Affzo [M:RPT]PARCOD(P3+1)
    zonsui = "[M]VALINT1(nolign)"
  Endif
Endcase
Endif

# Issue X3-75715
############################################################################
## Here we recover the Legal company: CPYLEGFLG field.
## If CPYLEGFLG = 2 it means Legal company is checked.
## We only process companies with CPYLEGFLG = 2 otherwise we show a message.
############################################################################
If instr (1,[M:RPT]RPTCOD,"DETNPBP")
  SOCIETE = ""
  If [M:RPT]PARCOD(nolign-1) = "societe"
    SOCIETE = [M:RPT]VALINT1(nolign-1)
    Read [CPY]CPY0 = SOCIETE
    If [F:CPY]CPYLEGFLG <> [V]CST_AYES
      GMESSAGE = mess(130,121,1) : # This company is not a legal company!
      mkstat = 2
      Return
    Endif
  Endif
Endif
# End issue X3-75715

# BODEL X3-35088 .e
Return

##########################################################################################################
##########################################################################################################
##########################################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Char    SOCIETE(GLONCPY) , SOC(GLONCPY) , BUDGET(GLONBUP)
Local Char    ETAT(GLONARP) , TYP_ETAT(GLONARP)
Local Char    RACINE(10) , VALEUR(30) , PARAM(50) , PARAM2(50)
Local Date    DATDEB , DATFIN , DDEB , DFIN , DEBEX , FINEX, DATREF
Local Integer EDEB , EFIN , K , ER , NODATE , STAT , TYP , BAL
Local Decimal EXE , PER , COURS , EXERCICE
Local Integer REFERENTIEL
Local Integer NBSOC , ISOC , JSOC , IPER , JPER
Local Char    PLAN(GLONCOA) , AXE(GLONDIE) , DEVLED(GLONCUR)
Local Integer NUMREQ
Local Char    VDEB(GLONSAC)(1..99) , VFIN(GLONSAC)(1..99)
Local Integer NBRLEG
Local Char    TABLEG(GLONADI)(1..GNBSOC)
# X3-22084
Local Char    GRPACOL(GLONGSC), COLADEB(GLONSAC), COLAFIN(GLONSAC)
Local Char    GRPBCOL(GLONGSC), COLBDEB(GLONSAC), COLBFIN(GLONSAC)
# X3-54644
Local Char    GRPCOL(GLONGSC), COLDEB(GLONSAC), COLFIN(GLONSAC)

Gosub OUVRE

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT) From ETAT
K = instr(1,ETAT,".")
If K
 ETAT = left$(ETAT,K-1)
Endif

## To not test the report name in the code we use TYP_ETAT
Call GETPARAM("typetat",NBPAR,PARAMETRE,TYP_ETAT) From ETAT
If TYP_ETAT="?????"
 TYP_ETAT = ETAT
Endif

#----------------------------------------------------------------------------------------------
## Check the company + fill the legislations of the legal companies in TBSOC
#----------------------------------------------------------------------------------------------
Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE) From ETAT
Read [CPY]CPY0 = SOCIETE
If fstat
 Call ECR_TRACE(mess(81,116,1),1) From GESECRAN
 GOK = 0 : End
Endif
If [F:CPY]CPYLEGFLG<>2
 If TYP_ETAT="BUDGET"
  Call ECR_TRACE(mess(130,121,1),1) From GESECRAN
  GOK=0 : End
 Endif
  NBSOC = 0
 Link [FGR] With [FCY]FCY0=[FGR]FCY,
&                [CPY]CPY0=[FCY]LEGCPY
& As [LNK] Where [FGR]CPY=SOCIETE
& Order By Key CLE1=[CPY]CPY

 For [LNK]CLE1(1)
  NBSOC +=1
 Next
 Local Char    TBSOC(GLONCPY)(1..NBSOC)
 NBSOC = 0
 For [LNK]CLE1(1)
  NBSOC +=1
  TBSOC(NBSOC) = [F:FCY]LEGCPY
 Next
 Read [CPY]CPY0 = TBSOC(1)
Else
 NBSOC = 1
 Local Char    TBSOC(GLONCPY)(1..NBSOC)
 TBSOC(1) = SOCIETE
Endif
Call LEGCPY(TBSOC,NBRLEG,TABLEG) From CPTDIV

#----------------------------------------------------------------------------------------------
## Check the ledger
#----------------------------------------------------------------------------------------------
Call GETPARAM("referentiel",NBPAR,PARAMETRE,VALEUR) From ETAT
If VALEUR<>"?????"
 REFERENTIEL = val(VALEUR)
 For ISOC=1 To NBSOC
  Call LECTURE("CPY",TBSOC(ISOC),"") From CONTOBJ
  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  If [F:GCM]LED(REFERENTIEL-1)=""
   Call ECR_TRACE(mess(REFERENTIEL,2644,1)-":"-mess(105,104,1)-TBSOC(ISOC),1) From GESECRAN
   GOK = 0 : Break
  Endif
 Next ISOC
 If GOK<1 : End : Endif
Endif

#----------------------------------------------------------------------------------------------
## Check and reframe periods
#----------------------------------------------------------------------------------------------
RACINE = "dat" : Gosub PERIODE
If GOK=0 : End : Endif
EXERCICE = EXE

RACINE = "dat2" : Gosub PERIODE
If GOK=0 : End : Endif

#----------------------------------------------------------------------------------------------
## Vérification du Plan, Compte & Devise selon Référentiel ou Référentiel Général Principal
#----------------------------------------------------------------------------------------------
PLAN   = ""
DEVLED = ""
If ETAT = "BALAGEEOY" : # X3-22084
 Call GETPARAM("datref",NBPAR,PARAMETRE,VALEUR) From ETAT
 DATREF=VALEUR
Endif
For ISOC=1 To NBSOC
 Read [CPY]CPY0 = TBSOC(ISOC)
 Call LEC_GCM([F:CPY]ACM) From CPTLEC
 If REFERENTIEL = 0
  Call SETMAINREF(TBSOC(ISOC),GTYPGEN,GTYPANA) From CPTDIV
  REFERENTIEL = GTYPGEN
 Endif
 Call LEC_LED([F:GCM]LED(REFERENTIEL-1)) From CPTLEC
 If PLAN=""
  PLAN = [F:LED]COA
 Elsif PLAN<>[F:LED]COA
  If find(TYP_ETAT,"BALGRP","GLGRP","GLGRPDEV","GLGRPAUX","GLGRPDEVAUX","JOUGRP","BALAGE") or
&    find(ETAT, "BALAGEEOY","UK-PAYPRACTICES") : # X3-22084 + X3-54644
#&    ETAT = "BALAGEEOY" : # X3-22084
   Call ECR_TRACE(mess(57,109,1)-":"-SOCIETE,1) From GESECRAN
   GOK = 0 : Break
  Endif
 Endif
 If DEVLED=""
  DEVLED = [F:GCM]CUR(REFERENTIEL-1)
  If ETAT="JOUGRPDEV"
   Call SETPARAM("devref",NBPAR,PARAMETRE,DEVLED) From ETAT
  Endif
 Elsif DEVLED<>[F:GCM]CUR(REFERENTIEL-1)
  If find(TYP_ETAT,"BALGRP","GLGRP","GLGRPDEV","GLGRPAUX","GLGRPDEVAUX","JOUGRP","BALAGE") # SAM 106699
   Call ECR_TRACE(mess(179,107,1)-":"-SOCIETE,1) From GESECRAN
   GOK = 0 : Break
  Endif
  If ETAT = "BALAGEEOY" : # X3-22084
   Call ECR_TRACE(mess(319,107,1)-":"-SOCIETE,1) From GESECRAN
   GOK = 0 : Break
  Endif
 Endif


 # X3-22084
 If ETAT = "BALAGEEOY"
  Filter [FIY] Where CPY= TBSOC(ISOC) and LEDTYP= REFERENTIEL and FIYEND = DATREF
  Read [FIY]First
  Filter [FIY]
  If (fstat) Then
   Filter [FIY] Where CPY= TBSOC(ISOC) and LEDTYP= REFERENTIEL
   Read [FIY]FIY0 First
   Filter [FIY]
   If ([F:FIY]FIYSTR <= DATREF) Then
    Call ECR_TRACE(num$(DATREF)-mess(1003,2299,1),1) From GESECRAN
    GOK = 0 : Break
   Endif
  Else
   If [F:FIY]FIYSTA=1
    Call ECR_TRACE(num$(DATREF)-mess(1003,2299,1),1) From GESECRAN
    GOK = 0 : Break
   Endif
  Endif
 Endif
Next ISOC
If !GOK : End : Endif


 # X3-54644
 If ETAT = "UK-PAYPRACTICES"
   Call GETPARAM("coldeb",NBPAR,PARAMETRE,VALEUR) From ETAT : COLDEB=VALEUR
   Call GETPARAM("colfin",NBPAR,PARAMETRE,VALEUR) From ETAT : COLFIN=VALEUR
   Call GETPARAM("grpcol",NBPAR,PARAMETRE,VALEUR) From ETAT : GRPCOL=VALEUR
   Local Integer LSAC
   LSAC= len("zzzzzzzzzz")
   If GLONSAC < LSAC
     LSAC = GLONSAC
   Endif
   Local Char WZZ(LSAC)
   WZZ = "zzzzzzzzzz"
   If GRPCOL = "" and COLDEB = " " and COLFIN = WZZ
     Call ECR_TRACE(mess(69,109,1), 1) From GESECRAN
     GOK = 0
     End
   Endif
   If GRPCOL <> "" and (COLDEB <> " " or COLFIN <> WZZ)
     Call ECR_TRACE(mess(69,109,1), 1) From GESECRAN
     GOK = 0
     End
   Endif
 Endif

# X3-22084
If ETAT = "BALAGEEOY"
 Call GETPARAM("coladeb",NBPAR,PARAMETRE,VALEUR) From ETAT : COLADEB=VALEUR
 Call GETPARAM("colafin",NBPAR,PARAMETRE,VALEUR) From ETAT : COLAFIN=VALEUR
 Call GETPARAM("grpacol",NBPAR,PARAMETRE,VALEUR) From ETAT : GRPACOL=VALEUR
 Call GETPARAM("colbdeb",NBPAR,PARAMETRE,VALEUR) From ETAT : COLBDEB=VALEUR
 Call GETPARAM("colbfin",NBPAR,PARAMETRE,VALEUR) From ETAT : COLBFIN=VALEUR
 Call GETPARAM("grpbcol",NBPAR,PARAMETRE,VALEUR) From ETAT : GRPBCOL=VALEUR

 # X3-36073
 # replace "zzzzzzzzzz" by WZZ
 Local Integer LSAC
 LSAC= len("zzzzzzzzzz")
 If GLONSAC < LSAC
   LSAC = GLONSAC
 Endif
 Local Char WZZ(LSAC)
 WZZ = "zzzzzzzzzz"

 If GRPACOL = "" and COLADEB = " " and COLAFIN = WZZ
  Call ECR_TRACE(func ASYRFNC.MES1(mess(68,109,1), "A"), 1) From GESECRAN
  GOK = 0
  End
 Endif

 If GRPACOL <> "" and (COLADEB <> " " or COLAFIN <> WZZ)
  Call ECR_TRACE(func ASYRFNC.MES1(mess(68,109,1), "A"), 1) From GESECRAN
  GOK = 0
  End
 Endif

 If GRPBCOL <> "" and (COLBDEB <> " " or COLBFIN <> WZZ)
  Call ECR_TRACE(func ASYRFNC.MES1(mess(68,109,1), "B"), 1) From GESECRAN
  GOK = 0
  End
 Endif

 # X3-36073 : always load A block if B selection exists
# If (COLAFIN <> WZZ or GRPACOL <> "") and (COLBFIN <> WZZ or GRPBCOL <> "")
 If (COLBDEB <> " " or COLBFIN <> WZZ or GRPBCOL <> "")

  Local Integer NBSAC
  Local Char    TBSAC(GLONSAC)(1..99)
  NBSAC = 0
  Raz TBSAC

#  If COLAFIN <> WZZ or COLADEB <> " " # X3-36073
  If GRPACOL = ""                     # X3-36073
   If clalev([F:GAC])=0  : Local File GACCOUNT     [GAC]  : Endif
   Filter [GAC] Where COA = [F:LED]COA and ACCSHO >= COLADEB and ACCSHO <= COLAFIN
   For [GAC]GAC1
    If NBSAC < 99
     NBSAC +=1
     TBSAC(NBSAC) = [F:GAC]ACCSHO
    Endif
   Next
   Filter [GAC]

  Else

   If clalev([F:GSC])=0  : Local File GRPSAC     [GSC]  : Endif
   Filter [GSC] Where COA = [F:LED]COA and GRU = GRPACOL
   For [GSC]GSC1
    If !find([F:GSC]SAC,TBSAC)
     If NBSAC < 99
      NBSAC +=1
      TBSAC(NBSAC) = [F:GSC]SAC
     Endif
    Endif
   Next
   Filter [GSC]
  Endif

  Local Integer NBCOL  :  NBCOL = 0
  Local Char    LSTCOL(143) : LSTCOL = ""  : # 10X12+20+"..."

  If ( COLBFIN <> WZZ or COLBDEB <> " ") and NBSAC <> 0
   If clalev([F:GAC])=0  : Local File GACCOUNT     [GAC]  : Endif
   Filter [GAC] Where COA = [F:LED]COA and ACCSHO >= COLBDEB  and ACCSHO <= COLBFIN
   For [GAC]GAC1
    If find([F:GAC]ACCSHO, TBSAC)
     If NBCOL = 0
      NBCOL += 1
      LSTCOL = [F:GAC]ACCSHO
     Else
      If NBCOL < 10
       NBCOL  += 1
       LSTCOL += ", "+[F:GAC]ACCSHO
      Else
       NBCOL  += 1
       LSTCOL += ", "+[F:GAC]ACCSHO-"..."
       Break
      Endif
     Endif
    Endif
   Next
   Filter [GAC]
  Endif

  If GRPBCOL<>"" and NBSAC <> 0 and NBCOL < 10
   If clalev([F:GSC])=0  : Local File GRPSAC     [GSC]  : Endif
   Filter [GSC] Where COA= [F:LED]COA and GRU= GRPBCOL
   For [GSC]GSC1
    If find([F:GSC]SAC,TBSAC)
     If NBCOL = 0
      NBCOL += 1
      LSTCOL = [F:GSC]SAC
     Else
      If NBCOL < 10
       NBCOL  += 1
       LSTCOL += ", "+[F:GSC]SAC
      Else
       LSTCOL += ", "+[F:GSC]SAC-"..."
       Break
      Endif
     Endif
    Endif
   Next
   Filter [GSC]
  Endif

  If NBCOL
   Call ECR_TRACE(func ASYRFNC.MES1(mess(66,109,1), LSTCOL) ,1) From GESECRAN
   GOK = 0 : End
  Endif

 Endif
Endif

#----------------------------------------------------------------------------------------------
## Init paramètre PLAN selon groupe de collectif
#----------------------------------------------------------------------------------------------
If (ETAT<>"BALAGEEOY") Then : # X3-22084
 Call GETPARAM("grpcol",NBPAR,PARAMETRE,VALEUR) From ETAT
 If VALEUR<>"?????"
  Call SETPARAM("plan",NBPAR,PARAMETRE,PLAN) From ETAT
 Endif
Endif
##----------------------------------------------------------------------------------------------
### Init parameter prov if some periods between datdeb and datfin are not closed
##----------------------------------------------------------------------------------------
# #*YYFIN_X3-39792 Editions BALGRP & BALGRPAUX & BALGRPDEV & BALGRPDEVAUX
# ## Display 'Provisional' in the header when editing a balance
# ## if the period date range covers one or several periods that are not closed
 If find(TYP_ETAT,"BALGRP","BALGRPDEV","BALGRPAUX","BALGRPDEVAUX")
 For I=1 To NBSOC
  Filter [PER] Where CPY=TBSOC(I) & LEDTYP=REFERENTIEL & PERSTR>=DATDEB & PERSTR<=DATFIN & PERSTA<>3
  Read [PER]First
  Filter [PER]
  If fstat=0
    VALEUR="1"
    Break
  Endif
 Next
 If VALEUR = "1"
   Call SETPARAM("prov",NBPAR,PARAMETRE,VALEUR) From ETAT
 Endif
Endif
# #*YYFIN_X3-39792
##########################################################################################################
#----------------------------------------------------------------------------------------------
## Cas particuliers
#----------------------------------------------------------------------------------------------
##########################################################################################################

## Etats GLGRP/GLGRPAUX, on force détail à nouveaux à oui si écritures lettrées est à non
#----------------------------------------------------------------------------------------------
If find(TYP_ETAT,"GLGRP","GLGRPDEV","GLGRPAUX","GLGRPDEVAUX") # SAM 106699
 Local Integer ECRILET
 Call GETPARAM("ecrilet",NBPAR,PARAMETRE,VALEUR) From ETAT
 ECRILET = val(VALEUR)
 Call GETPARAM("anouveau",NBPAR,PARAMETRE,VALEUR) From ETAT
 ANOUV = val(VALEUR)
 Call GETPARAM("detano",NBPAR,PARAMETRE,VALEUR) From ETAT
 DETANO = val(VALEUR)
 If ECRILET=0 & ANOUV=1 & DETANO=0
  VALEUR = "1"
  Call SETPARAM("detano",NBPAR,PARAMETRE,VALEUR) From ETAT
 Endif
Endif

## Etat BUDGET
#----------------------------------------------------------------------------------------------
If find(TYP_ETAT,"BUDGET")
 If [F:BUP]LEV<>2
  VALEUR=" "
  Call SETPARAM("sitedeb",NBPAR,PARAMETRE,VALEUR) From ETAT
  VALEUR="zzzzzzzzzz"
  Call SETPARAM("sitefin",NBPAR,PARAMETRE,VALEUR) From ETAT
 Endif
Endif

## Etat JOUANA : Nb d'axes et intitulés
#----------------------------------------------------------------------------------------------
If TYP_ETAT="JOUANA"
 Call LEC_CPY(TBSOC(1)) From CPTLEC
 Call LEC_GCM([F:CPY]ACM) From CPTLEC
 Call LEC_LED([F:GCM]LED(REFERENTIEL-1)) From CPTLEC
 For K=1 To min(4,[F:LED]DIENBR)
  Call LECTEXTRA(PARAM,"GDIE","COLHEA",[F:LED]DIE(K-1),"") From ATEXTRA
  If [F:LED]DIENBR>=K+4
   Call LECTEXTRA(PARAM2,"GDIE","COLHEA",[F:LED]DIE(K+3),"") From ATEXTRA
   PARAM += " / "+PARAM2
  Endif
  Call SETPARAM("libana"+num$(K),NBPAR,PARAMETRE,PARAM) From ETAT
 Next K
 PARAM = num$([F:LED]DIENBR)
 Call SETPARAM("nbaxe",NBPAR,PARAMETRE,PARAM) From ETAT
Endif

# EMERAUDE - Feature MULTILEG- Requirement 71216
#----------------------------------------------------------------------------------------------
If TYP_ETAT="JOUANA" | TYP_ETAT="JOUGRP"
 Gosub TRTJOU From RPTLEG
Elsif TYP_ETAT="CONTVAPCE"
 Gosub TRTGTE From RPTLEG
 Gosub TRT_TVB From RPTLEG
 Gosub TRT_TVT From RPTLEG
Endif

## Rate for report ENCOURS & BALAGEGRP + Open Item overrun for BALAGE
#----------------------------------------------------------------------------------------------
## Initialization of the rate
Local Integer TYPCOURS : TYPCOURS = 1
Call GETPARAM("typcur",NBPAR,PARAMETRE,VALEUR) From ETAT
If VALEUR<>"?????"
 [L]TYPCOURS = val(VALEUR)
Endif
Call GETPARAM("datcours",NBPAR,PARAMETRE,VALEUR) From ETAT
If VALEUR<>"?????"
 Local Date DATRPT
 [L]DATRPT = VALEUR
Endif

Call GETPARAM("courrpt",NBPAR,PARAMETRE,VALEUR) From ETAT
If VALEUR<>"?????"
 # The "datcours" could be empty so take the value "date$" by default ( no empty value in Crystal Report)
 If dim([L]DATRPT)<1 or [L]DATRPT  <= [01/01/1800]
  Call CONVERT(GCURSHR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,[L]TYPCOURS,date$,1000000,COURS,STAT) From TRTDEV
  VALEUR = num$(COURS/1000000)
  Call SETPARAM("courrpt",NBPAR,PARAMETRE,VALEUR) From ETAT
 Else
  Call CONVERT(GCURSHR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,[L]TYPCOURS,[L]DATRPT,1000000,COURS,STAT) From TRTDEV
  VALEUR = num$(COURS/1000000)
  Call SETPARAM("courrpt",NBPAR,PARAMETRE,VALEUR) From ETAT
 Endif
Endif

## EN
## Open Item overrun
## If we are looking for only the business partner in open item overrun while
## this one parameter is control at the folder level and not at the facility level
## then we set by default the value of parameter "depasse" with NO.
## FR
## Dépassement d'en cours
## Si on demande uniquement les tiers en dépassement d'en-cours alors
## que ce dépassement est contrôlé au niveau dossier et non au niveau site
## on refuse le critère "que les tiers en dépassement d'en-cours".
If TYP_ETAT="BALAGE"
 Local Integer DEPENCOURS
 Local Char OCTL(1)
 Call GETPARAM("depasse",NBPAR,PARAMETRE,VALEUR) From ETAT
 [L]DEPENCOURS=val(VALEUR)
 Call PARAM(SOCIETE,"OSTCTL",OCTL) From ADOVAL
 GOSTCTL=val(OCTL)
 If [L]DEPENCOURS=1 & GOSTCTL=1
  VALEUR="0"
  Call SETPARAM("depasse",NBPAR,PARAMETRE,VALEUR) From ETAT
 Endif
Endif

## Editions BALxxx & GLxxx : Contrôle du paramètre cloture et forçage à non si nécessaire (Plumettaz 61739)
#----------------------------------------------------------------------------------------------
If find(TYP_ETAT,"BALGRP","GLGRP","GLGRPDEV","GLGRPAUX","GLGRPDEVAUX") # SAM 106699
 Call GETPARAM("cloture",NBPAR,PARAMETRE,VALEUR) From ETAT
 If val(VALEUR)=1
  Read [FIY]FIY0 = SOCIETE;REFERENTIEL;EXERCICE
  Call GETPARAM("datfin",NBPAR,PARAMETRE,VALEUR) From ETAT
  DATFIN = VALEUR
  If VALEUR<>[F:FIY]FIYEND
   VALEUR = "0"
   Call SETPARAM("cloture",NBPAR,PARAMETRE,VALEUR) From ETAT
  Endif
 Endif
Endif

## Editions BALxxx : Initialisation du paramètre datref pour les balances avec groupes de site
#----------------------------------------------------------------------------------------------
If TYP_ETAT="BALGRP"
 Call GETPARAM("datdeb",NBPAR,PARAMETRE,VALEUR) From ETAT
 DATDEB = VALEUR
 Call GETPARAM("datfin",NBPAR,PARAMETRE,VALEUR) From ETAT
 DATFIN = VALEUR
 If find(GDEFSOC,TBSOC(1..NBSOC))
  SOCIETE = GDEFSOC
 Else
  SOCIETE = TBSOC(1)
 Endif
 Filter [FIY] Where CPY=SOCIETE & LEDTYP=REFERENTIEL & [F:FIY]FIYEND>DATDEB & [F:FIY]FIYSTR<=DATDEB
 Read [FIY]FIY0 First
 Filter [FIY]
 DATREF = [F:FIY]FIYSTR
 VALEUR = format$("D:YYYYMMDD",[F:FIY]FIYSTR)
 Call SETPARAM("datref",NBPAR,PARAMETRE,VALEUR) From ETAT
 ##
 ## Vérif de la date de début d'exercice
 ##
 Raz DEBEX , FINEX
 VALEUR = "0"
 For ISOC=1 To NBSOC
  Filter [FIY] Where CPY=TBSOC(ISOC) & LEDTYP=REFERENTIEL & FIYEND>DATDEB & FIYSTR<=DATDEB
  Read [FIY]FIY0 First
  Filter [FIY]
  If fstat<=2
   If DEBEX=[0/0/0]
    DEBEX = [F:FIY]FIYSTR
    FINEX = [F:FIY]FIYEND
   Elsif DEBEX<>[F:FIY]FIYSTR or FINEX<>[F:FIY]FIYEND
    VALEUR = "1"
   Endif
  Else
   VALEUR = "1"
  Endif
 Next
 If VALEUR="1"
  Call MESSAGE(mess(62,109,1)) From GESECRAN
 Endif
 Call SETPARAM("groupe",NBPAR,PARAMETRE,VALEUR) From ETAT
Endif


# Edition CPTNMOUV : Init PLAN
#----------------------------------------------------------------------------------------------
If find(TYP_ETAT,"CPTNMOUV")
 Gosub SETSOC
 If SOCIETE<>""
  K = find("referentiel",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  If K
   REFERENTIEL = val([M:RPT]VALINT1(K-1))
   Read [GCM]GCM0 = [F:CPY]ACM
   Read [LED]LED0 = [F:GCM]LED(REFERENTIEL-1)
   Read [COA]COA0 = [F:LED]COA
   PLAN = [F:LED]COA
   Call SETPARAM("plan",NBPAR,PARAMETRE,PLAN) From ETAT
  Endif
 Endif
Endif


# Etat BALGRPDEVAUX, Collectifs appartenant au groupe de collectifs
#----------------------------------------------------------------------------------------------
If ETAT="BALGRPDEVAUX"
 Call GETPARAM("grpcol",NBPAR,PARAMETRE,VALEUR) From ETAT
 If VALEUR<>"?????"
  K = 0
  Raz VDEB, VFIN
  For [GSC] Where COA=PLAN & GRU=VALEUR
   K +=1
   VDEB(K) = [F:GSC]SAC
   VFIN(K) = [F:GSC]SAC
  Next
  Call SETPARAMPLAG("listcoldugrp",NBPAR,PARAMETRE,VDEB,VFIN,K) From ETAT
 Endif
Endif

# Etats BALGRPDEV, BALGRPDEVAUX
#----------------------------------------------------------------------------------------------
## Balance en devise=> suppression du sous-état "periode_grp" qui alimentait les variables tbsoc tpdeb tpfin et tpref
## car on ne peut pas faire de table croisée sur une formule qui contient une autre formule
# 2016-10-04 DNE MODIF BEGIN
If find(ETAT, "BALGRPDEV", "BALGRPDEVAUX", "DE-BALGRPDEV")
# 2016-10-04 DNE MODIF ORIG
#If find(ETAT,"BALGRPDEV","BALGRPDEVAUX")
# 2016-10-04 DNE MODIF END
 Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT : NUMREQ = val(PARAM)
 PARAM = num$(NUMREQ)
 Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT
 Call DEBTRANS From GLOCK
 Gosub TR0
 Gosub TR1
Endif

End

####################################################
## Effacement table temporaire
####################################################
$TR0
GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=ETAT & USR=GUSER & CREDAT<date$
Commit
Return

####################################################
## Mise à jour table temporaire
####################################################
$TR1
GOK=1
Trbegin [ARM]
 K = 0
 For ISOC=1 To NBSOC
  Raz [F:ARM]
  Filter [PER] Where CPY=TBSOC(ISOC) & LEDTYP=REFERENTIEL & PERSTR>=DDEB & PERSTR<=DFIN
  For [PER]
   If [F:PER]PERSTR=DATREF : [F:ARM]CLEN1 = [F:PER]PERNUM : Endif
   If [F:PER]PERSTR=DDEB   : [F:ARM]CLEN2 = [F:PER]PERNUM : Endif
   If [F:PER]PEREND=DFIN   : [F:ARM]CLEN3 = [F:PER]PERNUM : Endif
   #----------------------------------------------------------------------------------------------
  Next
  Filter [PER]
  K += 1
  [F:ARM]RPTCOD = ETAT
  [F:ARM]USR    = GUSER
  [F:ARM]NUMREQ = NUMREQ
  [F:ARM]NUMLIG = K
  [F:ARM]CLEA1  = TBSOC(ISOC)
  Write [ARM]
  If fstat
   GOK = 0 : Call FSTA("ARM") From GLOCK : Break
  Endif
 Next
 If GOK=0 : Rollback : Return : Endif
Commit
Return


#############################
## Check the periods
#############################

$PERIODE
NODATE = 0
Call GETPARAM(RACINE+"deb",NBPAR,PARAMETRE,VALEUR) From ETAT
If VALEUR<>"?????"
 DATDEB = VALEUR
Else
 NODATE = 1
Endif
Call GETPARAM(RACINE+"fin",NBPAR,PARAMETRE,VALEUR) From ETAT
If VALEUR<>"?????"
 DATFIN = VALEUR
Else
 NODATE = 1
Endif
If TYP_ETAT="CONTVAPCE" : NODATE = 1 : Endif
If NODATE : Return : Endif

If DATDEB=[0/0/0] or DATFIN=[0/0/0]
 Call ECR_TRACE(mess(10,116,1),1) From GESECRAN
 GOK = 0 : Return
Endif

Read [CPY]CPY0 = SOCIETE
If [F:CPY]CPYLEGFLG=2 : # Legal company
 SOC = SOCIETE
 Call GETPERSOC(SOC,REFERENTIEL,DATDEB,EXE,PER) From CPTSUB
 If EXE=0 or PER=0
  Call ECR_TRACE(mess(10,116,1),1) From GESECRAN
  GOK = 0 : Return
 Endif
 DDEB = [F:PER]PERSTR
 EDEB = [F:PER]FIYNUM
 # Journal de report à nouveau : pas de période 0 dans la table PERIOD
 If TYP_ETAT="JOUGRP"
  VALEUR = num$([F:PER]PERNUM)
  Call SETPARAM("pernum",NBPAR,PARAMETRE,VALEUR) From ETAT
 Endif
 Call GETPERSOC(SOC,REFERENTIEL,DATFIN,EXE,PER) From CPTSUB
 If EXE=0 or PER=0
  Call ECR_TRACE(mess(10,116,1),1) From GESECRAN
  GOK = 0 : Return
 Endif
 DFIN = [F:PER]PEREND
 EFIN = [F:PER]FIYNUM

Else : # site/company grouping

 Raz DDEB,EDEB,DFIN,EFIN
 For [FGR]FGR0 Where CPY=SOCIETE
  Read [FCY]FCY0 = [F:FGR]FCY
  If EDEB=0
   Call GETPERSOC([F:FCY]LEGCPY,REFERENTIEL,DATDEB,EXE,PER) From CPTSUB
   If EXE<>0 & PER<>0
    DDEB = [F:PER]PERSTR
    EDEB = [F:PER]FIYNUM
    # Journal de report à nouveau : pas de période 0 dans la table PERIOD
    If TYP_ETAT="JOUGRP"
     VALEUR = num$([F:PER]PERNUM)
     Call SETPARAM("pernum",NBPAR,PARAMETRE,VALEUR) From ETAT
    Endif
   Endif
  Endif
  If EFIN=0
   Call GETPERSOC([F:FCY]LEGCPY,REFERENTIEL,DATFIN,EXE,PER) From CPTSUB
   If EXE<>0 & PER<>0
    DFIN = [F:PER]PEREND
    EFIN = [F:PER]FIYNUM
   Endif
  Endif
  If EDEB<>0 & EFIN<>0 : Break : Endif
 Next
 If EDEB=0 or EFIN=0
  Call ECR_TRACE(SOCIETE-":"-mess(183,107,1),1) From GESECRAN
  GOK = 0 : Return
 Endif

# Check the periods for the site grouping
 If find(TYP_ETAT,"BALGRP","GLGRP","GLGRPDEV","GLGRPAUX","GLGRPDEVAUX") # SAM 106699
  Call CNTCOHPERV6(SOCIETE,REFERENTIEL,DATDEB,DATFIN,STAT,GMESSAGE) From CPTCNT
 Else
  Call CNTCOHPER(SOCIETE,REFERENTIEL,DATDEB,DATFIN,STAT,GMESSAGE) From CPTCNT
 Endif
 If STAT=0
  Call ECR_TRACE(SOCIETE-":"-GMESSAGE,1) From GESECRAN
  GOK = 0 : Return
 Endif
Endif

# Init of the date range
#<SAM 106699>
#If TYP_ETAT<>"GLGRP" & TYP_ETAT<>"CONTVAENC"  : # On ne le fait plus pour les grand-livres...
If !find(TYP_ETAT,"GLGRP","GLGRPDEV","GLGRPAUX","GLGRPDEVAUX","CONTVAENC") : # On ne le fait plus pour les grand-livres...
#</SAM 106699>
 VALEUR = format$("D:YYYYMMDD",DDEB)
 Call SETPARAM(RACINE+"deb",NBPAR,PARAMETRE,VALEUR) From ETAT
 VALEUR = format$("D:YYYYMMDD",DFIN)
 Call SETPARAM(RACINE+"fin",NBPAR,PARAMETRE,VALEUR) From ETAT
Endif

Return

