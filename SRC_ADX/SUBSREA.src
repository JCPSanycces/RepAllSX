  If !clalev([F:SEM]) : Local File SETMAC[SEM] : Endif
  If !clalev([F:SEN]) : Local File SETMACCPN[SEN] : Endif
  If !clalev([F:MQR]) : Local File MKGQUR[MQR] : Endif
  If !clalev([F:QTP]) : Local File QURTMP[QTP] : Endif
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:QUE]) : Local File QUEUE [QUE] : Endif
  If !clalev([F:OPPCRM]) : Local File OPPORCRM [OPPCRM] : Endif      # FGR 26/08/2015 : X3SUIVI108275
  If GMODU(2) = 2 Then
    #si module compta actif
    If !clalev([F:GCM]) : Local File GACM[GCM] : Endif
  Endif
  #LSE temporaire multi soc CRMMULTISOC
  If !clalev([F:BC1]) : Local File BPCUSTOMER [BC1] : Endif
Return

##########################################################################################################
$AVANT_CHOI
  If GBCRMFLGNEW = 1 Then
    REPONSE = GSTANEW
    Gosub NOUVEAU From GOBJSUB
    Gosub SETBOUT From GOBJSUB
    GBCRMFLGNEW = 0
  Endif
Return

##########################################################################################################
$FERME
  If dim(GMANCOU12) > 0 Then   # FGR 13/10/2015 : X3SUIVI111665
    Kill GMANCOU12   # FGR 20/12/2012 : X3SUIVI71937
  Endif
  Kill GSZINVNUM # FGR 07/07/2008 : X3SUIVI48011
  Raz GORITITCOL
  #Termine l'éventuel horodatage en cours.
  If GISRE2TIMFLG Then
    Call MNGHORO([M:SRE0]SRENUM, 0, "") From SUBSREB1
  Endif
  Kill GSZSRE7FOLDTIT
  Kill GSZSRE8FOLDTIT
  Kill GSZSRE9FOLDTIT
  Kill GSREHORAMTFLG
  Kill GTIMPREVALCTL
  Kill GSREUDDHDTFLG
  Kill GSR2CSRECPT
  Kill GSZSRECXT
  Kill GCSRECPT
  Kill GLASOPP
  Kill GLASITN
  Kill GSZSREBPC
  Kill GSZSRECON
  Kill GSZSRENUM
  Kill GIPREASS
  Kill GSZPREASS
  Kill GSZPRESAT
  Kill GIPREMESS
  Kill GISRECOUNT
  Kill GISRE2TIMFLG
  Kill GISRE2STRDAYCTL
  Kill GISRE2STRSODCTL
  Kill GISRE2TIMSRENUM
  Kill GIHAUTSTRDAYCTL
  Kill GIHAUTSTRSODCTL
  Kill GISRE2SELHORMAC

  Kill GFOCITMREF
  Kill GFOCQTY
  Kill GFOCUOM
  Kill GPNTITMREF
  Kill GFOCMOTIF
  Kill GFOCFLG
  Kill GFOCPRIFLG

  Kill GSRE9DIRTYISSISS
  Kill GSRE9HDTISSISS
  Kill GSREHTRNUM
  Kill GSRE0NUMINTIT
  Kill GSRE0PBLINTIT
  Kill GSRE0COVINTIT
  Kill GSRE9PITINTIT
  Kill GSZSREFILGAUFLT
  Kill GSSRENAMESPE

  #LSE 22/12/2005 FQ 33987
  If dim(GBOXSRE) > 0 Then
    Kill GBOXSRE
    Kill GBOXSR2
    Kill GBOXSRESP1
    Kill GBOXSRESP2
    Kill GBOXSRESP3
    Kill GBOXSRESP4
    Kill GBOXSRESP5
    Kill GBOXSRESP6
    Kill GBOXSRESP7
  Endif
  If dim(GHDKTRSSRE) > 0 Then
    Kill GHDKTRSSRE
  Endif

  Kill GISREHTRUSEMAC

  Close Local Mask [SCH0]
  Close Local Mask [SCH2]
  Close Local Mask [SCH7]
  Close Local Mask [SCH9]

  #Remise en ordre des paramètres de déconnexion automatique.
  #LSE 4/01/2006 PB import batch FQ 34106
  If !GIMPORT Then
    Local Char RETOUR
    Local Char SZTIMEHGUP1
    Local Char SZTIMEHGUP2
    Local Integer ITIMEHGUP1
    Local Integer ITIMEHGUP2

    Call PARAMUTIL("TIMEHGUP1", SZTIMEHGUP1, GUSER, "") From SUBAUS
    If SZTIMEHGUP1 = "" Then
      ITIMEHGUP1 = 3600
    Else
      ITIMEHGUP1 = val(SZTIMEHGUP1)
    Endif
    Call PARAMUTIL("TIMEHGUP2", SZTIMEHGUP2, GUSER, "") From SUBAUS
    If SZTIMEHGUP2 = "" Then
      ITIMEHGUP2 = 3600
    Else
      ITIMEHGUP2 = val(SZTIMEHGUP2)
    Endif
    Callui RETOUR="" With "UIAction="+chr$(1)+"Sethangup",
&                         "UITimehangup1="+chr$(1)+num$(ITIMEHGUP1),
&                         "UITimehangup2="+chr$(1)+num$(ITIMEHGUP2)
  Endif
Return

##########################################################################################################
$HINTCLE
  #---------------------------------------------------#
  #Cle pour optimisation du remplissage  des listes gauches
  #---------------------------------------------------#
  Case currbox
    When GBOXSRE
      HINTLIS(val(right$(GBOXSRE,8))) = "SRE0"
    When GBOXSR2
      HINTLIS(val(right$(GBOXSR2,8))) = "SRE0"
  Endcase
Return

##########################################################################################################
$TITRES
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "FUNCXT0" Then
      If GICXT0CXT2SEL Then
        TIT = [M:CXT2]BCXTNAM(GISELNOLCXT)
      Else
        TIT = [M:CXT0]CXTNAM(GISELNOLCXT)
      Endif
    Endif
  Endif
Return

##########################################################################################################
$RAZDUP
Local Integer INOL
Local Integer INOL2
Local Integer IASKDUPLIREP

  IASKDUPLIREP = 0
  [M:SRE0]SRESYM = ""
  [M:SRE0]PREUPDFLG = 0
  [M:SRE0]SREASSDFLG = 0
  [M:SRE2]UPDHORCTL = 0
  #Calcul d'un code séquence temporaire
  # FGR 21/01/2010 : X3SUIVI61755 : adxuid est plus simple et ne provoque pas de bloquage en multi-utilisateurs
  #Call SETSEQNUM([M:SRE0]CRESEQ) From SUBSREB1
  #If GERR Then
  #  If [M:SRE7]NBMAC > 0 Then
  #    INOL = 0
  #    INOL2 = [M:SRE7]NBMAC-1
  #    Gosub DELMACLINES From SUBSREB4
  #    Call RAZMAC From SUBSREB2
  #    Call LOADTOTHDT(1) From SUBSREB1
  #    Call LOADTOTPIT(1) From SUBSREB1
  #  Endif
  #  Grizo [M:SRE7]15
  #Endif
  [M:SRE0]CRESEQ = num$(adxuid(1))
  #
  #Duplication des composants concerné
  Call DUPLICPN(GISRE2TIMSRENUM, [M:SRE0]CRESEQ) From SUBSREB2
  #Enregistrement des horodatages
  If GISRE2TIMFLG Then
    GSREHORAMTFLG = "RAZDUP"
    GSREUDDHDTFLG = "M"
    Call MNGHORO(GISRE2TIMSRENUM, 0, "") From SUBSREB1
  Endif
  GSREUDDHDTFLG = ""
  GISRE2TIMSRENUM = ""
  GSREHORAMTFLG = ""
  [M:SRE2]PRESPGFLG = 0
  #Remise à zéro des champs source d'erreurs et des consommations
  Raz [M:SRE9]
  [M:SRE0]SRENUMBPC = ""
  [M:SRE0]NBRMANUPD = 0
  Raz [M:SRE2]TIMSPGDAY
  Raz [M:SRE2]TIMSPGHOU
  Raz [M:SRE2]TIMSPGMNT
  Raz [M:SRE2]CTIMSPGDAY
  Raz [M:SRE2]CTIMSPGHOU
  Raz [M:SRE2]CTIMSPGMNT
  #Définition du chrono client
  If [M:SRE0]SREBPC <> "" Then
    If GSRENUMAUT = 2 Then
      Gosub SUBB1_SRENUMBPC From SUBSREB3
    Endif
  Endif
  #Origine
  [M:SRE1]CREDAT = date$
  [M:SRE1]CREHOU = left$(time$, 2) + mid$(time$, 4, 2)
  [M:SRE1]CREUSR = GUSER
  Read [AUS]CODUSR=GUSER
  If fstat Then
    [M:SRE1]FULNAMUSR = GUSER
  Else
    [M:SRE1]FULNAMUSR = [F:AUS]NOMUSR
  Endif
  #Facturation
  [M:SRE2]SREINVFLG = 1
  [M:SRE9]DONDATFLG = 0
  Raz [M:SREF] # FGR 07/07/2008 : X3SUIVI48011
  #---------------------------------------------------#
  #Sortie de stock
  Call RAZSTOSORW From STKSOR
  Raz [M:SRE9]CREFLG
  Raz [M:SRE9]UPDFLG
  Raz [M:SRE9]HDTSTOISS    # FGR 05/08/2010 : X3SUIVI66063
  Raz [M:SRE9]SAVSTOISS    # FGR 05/08/2010 : X3SUIVI66063
  Raz [M:SRE9]HDTISSQTY    # FGR 05/08/2010 : X3SUIVI66063
  Raz [M:SRE9]HDTISSISS    # FGR 05/08/2010 : X3SUIVI66063
  Raz GSRE9HDTISSISS
  Raz GSRE9DIRTYISSISS
  #---------------------------------------------------#
  #Réactivation d'une demande clôturée
  If [M:SRE2]SREASS = 5 Then
    #Souhaitez-vous activer la nouvelle demande de service ?
    Call OUINON(mess(152,177,1), IASKDUPLIREP) From GESECRAN
    If IASKDUPLIREP = 2 Then
      Call ASSDUPLISRE From SUBSREB4
    Endif
  Endif
  #Enregistrement des valeurs de couvertures précédentes
  Call PRECRMSRE1("") From SUBSREB3
  #---------------------------------------------------#
  #Dernière escalade
  #---------------------------------------------------#
  Gosub RAZESC From SUBSREB3
  #---------------------------------------------------#
  # Gestion de la création des horodatages en action RAZCRE et LIENS
  #---------------------------------------------------#
  Gosub RESETSCH From SUBSREB3
  #Recalcul de la couverture
  Call COVERM From TRTCOVER
  # Enregistre le moment précis de la création d'une demande pour l'horodatage automatique en création
  Gosub MNGHORCREDUP From SUBSREB4
  Gosub SETMACGRAY From SUBSREB4
  #Modele de demande de service
  Actzo [M:SRE1]SRETPL
  Grizo [M:SRE0]SRENUM
  Diszo [M:SRE2]SREESCNUM
  Actzo [M:SRE0]SALFCY
  Actzo [M:SRE8]SRECUR
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE0]1-99
  Affzo [M:SRE1]1-99
  Affzo [M:SRE2]1-99
  Affzo [M:SRE7]1-99
  Affzo [M:SRE9]1-99
  Affzo [M:SREF]1-99 # FGR 07/07/2008 : X3SUIVI48011
Return

##########################################################################################################
$AVANT_MOD
Local Char SZITNNUM(GLONITN)
Local Integer IERRINF

  #Si on est rentré en modif par la modif
  #1 /  des familles de compétences
  If [M:SRE0]PREUPDFLG Then
    [M:SRE0]PREUPDFLG = 0
    Return
  Endif
  IERRINF = 0
  #Si la demande est lockée, on ne vas pas plus loin
  Gosub AVMCTLLOCKSRE
  If !IUPDSRE Then
    OK = 0
    Return
  Endif
  #Photo des points pour abandon
  Call PITAVANTMOD([M:SRE0]SRENUM, IERRINF) From SUBSREB3
  If IERRINF Then
    GMESSAGE = mess(IERRINF,182,1)
    GERR = 1
    OK = 0
    Return
  Endif
  #Photo des composants pour abandon
  Call CPNAVANTMOD([M:SRE0]SRENUM, IERRINF) From SUBSREB3
  If IERRINF Then
    GMESSAGE = mess(IERRINF,182,1)
    GERR = 1
    OK = 0
    Return
  Endif
  #Enregistrement des valeurs de couvertures précédentes
  Call PRECRMSRE1([M:SRE0]SRENUM) From SUBSREB3
  #Vous modifiez une demande de service clôturée.
  If [M:SRE0]SREASSDFLG = 0 Then
    If !GERR Then
      If [M:SRE2]SREASS = 5 Then
        GMESSAGE = mess(1,177,1)
        GERR = 2
      Endif
    Endif
  Endif
  [M:SRE0]SREASSDFLG = 0
Return

##########################################################################################################
$AVMCTLLOCKSRE
#Contrôle que l'on peut rentrer en modification de la demande.
Local Integer IUPDSRE

  Call LOCKSRE([M:SRE0]SRENUM, IUPDSRE) From SUBITNB1
  If !IUPDSRE Then
    #Modification impossible. Intervention en cours de saisie sur un autre poste.
    GMESSAGE = mess(592,182,1)
    GERR = 2
    Return
  Endif
Return

##########################################################################################################
$RAZCRE
Local Integer IERRRAZCRE
Local Char SZCON
Local Integer ICOV
Local Integer IONREP3
Local Char SZMESS2(250)
Local Char SZSOC(GLONCPY)
Local Char SZSITESTOCK(GLONFCY)
Local Integer ISAVSRE7NOLIGN

  [M:SRE2]UPDHORCTL = 0
  [M:SRE0]SREASSDFLG = 0
  [M:SRE0]SRESYM = ""
  Gosub SETGRAY From SUBSREB3
  IONREP3 = 2
  SZMESS2 = ""
  ICOV = 0
  SZCON = ""
  IERRRAZCRE = 0
  [M:SRE0]PREUPDFLG = 0
  SZSOC = ""
  SZSITESTOCK = ""
  # FGR 07/04/2015 : X3SUIVI107457 (début)
  If [M:SRE0]SREBPC <> "" Then
    Local Char SVALEUR(type([M:SRE0]SREBPC)-10)

    SVALEUR = [M:SRE0]SREBPC
    Call AM_SREBPC(SVALEUR) From W1SRE0
  Endif
  # FGR 07/04/2015 : X3SUIVI107457 (fin)
  #Calcul d'un code séquence temporaire
  # FGR 21/01/2010 : X3SUIVI61755 : adxuid est plus simple et ne provoque pas de bloquage en multi-utilisateurs
  #Call SETSEQNUM([M:SRE0]CRESEQ) From SUBSREB1
  #If GERR Then
  #  Grizo [M:SRE7]15
  #Endif
  [M:SRE0]CRESEQ = num$(adxuid(1))
  #
  #Enregistrement des horodatages
  If GISRE2TIMFLG Then
    GSREUDDHDTFLG = "M"
    GSREHORAMTFLG = "RAZCRE"
    Call MNGHORO(GISRE2TIMSRENUM, 0, "") From SUBSREB1
    GSREUDDHDTFLG = ""
  Endif
  GSREHORAMTFLG = ""
  GISRE2TIMSRENUM = ""
  [M:SRE2]PRESPGFLG = 0
  Affzo [M:SRE2]TITDAY, TITHOU, TITMNT, TITSPG, TITCSPG, TITBLK
  #LSE V150 09/08/2005
  #On initialise le site
  Call SITECRMDEF("HDK", [M:SRE0]SALFCY) From CRM_UTIL
  If GFCY <> [M:SRE0]SALFCY Then
    GFCY = [M:SRE0]SALFCY
    Call INIT_GLOBAL_CPT(GFCY,"HTR",2,GHDKTRSSRE) From TRTX3CPT
  Endif
  Gosub CHARG_PARAM # FGR 26/07/2013 : X3SUIVI87923 (fin)
  # V6.2 : Certification
  # --- Contrôle date documents
  Call LOAD_GCTLDATORI() From CRMUTIL150  # FGR 25/01/2012 : X3SUIVI78765
  #Local  Char     PARAM(GLONADP)
  #Call PARAM(GFCY,"CTLDATORI",PARAM) From ADOVAL
  #GCTLDATORI=val(PARAM)  : If GCTLDATORI=0   GCTLDATORI=2  : Endif
  #---------------------------------------------------#
  #Affectation par défaut de la demande
  #---------------------------------------------------#
  Gosub DEFASSSRE From SUBSREB4
  #---------------------------------------------------#
  #Affecte le donneur d'ordre par défaut pour l'utilisateur en cours.
  #---------------------------------------------------#
  Call SETDEFDOO(GUSER, [M:SRE0]SREDOO) From SUBSREB1
  If [M:SRE0]SREDOO <> "" Then
    Read [BPR]BPR0=[M:SRE0]SREDOO
    If fstat Then
      [M:SRE0]SREDOOX = [M:SRE0]SREDOO
    Else
      [M:SRE0]SREDOOX = [F:BPR]BPRNAM
    Endif
  Endif
  #---------------------------------------------------#
  # Initialise les valeurs par défaut d'une demande de service
  #---------------------------------------------------#
  [M:SRE2]REP = ""
  [M:SRE2]TSKREPCRE = 1
  Call DEFVALADI(422, [M:SRE2]SRESAT) From CRMUTIL140
  Call DEFVALADI(405, [M:SRE2]SREPIOLEV) From CRMUTIL140
  Call DEFVALADI(428, [M:SRE2]SREGRALEV) From CRMUTIL140
  If [M:SRE2]SREGRALEV = "" Then
    Call GET_LIBFC(428, [M:SRE2]SREGRALEV) From CRM_UTIL
  Endif
  [M:SRE2]SREINVFLG = 1
  [M:SRE2]SRELOK = 1
  [M:SRE0]NBRMANUPD = 0
  GSZPRESAT = ""
  GSZPREASS = ""
  GIPREASS = 0
  GSREUDDHDTFLG = ""
  GTIMPREVALCTL(0) = [M:SRE2]TIMSPGDAY
  GTIMPREVALCTL(1) = [M:SRE2]TIMSPGHOU
  GTIMPREVALCTL(2) = [M:SRE2]TIMSPGMNT
  [M:SRE9]HORHDTFLG = 0
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBSREB3
  #Origine
  [M:SRE1]CREDAT = date$
  [M:SRE1]CREHOU = left$(time$, 2) + mid$(time$, 4, 2)
  [M:SRE1]CREUSR = GUSER
  Read [AUS]CODUSR=GUSER
  If fstat Then
    [M:SRE1]FULNAMUSR = GUSER
  Else
    [M:SRE1]FULNAMUSR = [F:AUS]NOMUSR
  Endif
  [M:SRE1]SREORITYP = ""
  [M:SRE1]SREORI = 1
  Diszo [M:SRE1]SREORIVCR
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    Diszo [M:SRE9]TOTPIT
  Endif
  #---------------------------------------------------#
  #Chargement du parc
  #---------------------------------------------------#
  [M:SRE7]TYPMAC = 1
  [M:SRE7]MACFLT = ""
  [M:SRE7]MACFLTINT = 2
  Grizo [M:SRE7]MACFLT
  Grizo [M:SRE7]MACFLTINT
  #Vérifie si le donneur d'ordre par défaut est compatible avec le tiers ou l'interlocuteur initialisé par défaut.
  Gosub CHECKDOO From SUBSREB2
  If [M:SRE0]SREBPC <> "" Then
    #Définit l'interlocuteur par défaut de la demande de service
    If [M:SRE0]SRECCN = "" Then
      Call GETDEFCNT([M:SRE0]SREBPC, [M:SRE0]SRECCN) From CRMUTIL140
    Endif
    Read [BPR]BPR0=[M:SRE0]SREBPC
    If fstat Then
      [M:SRE0]SREBPCCLA = [M:SRE0]SREBPC
    Else
      [M:SRE0]SREBPCCLA = [F:BPR]BPRNAM
    Endif
    If [M:SRE0]SRECCN <> "" Then
      Read [AIN]AIN0=[M:SRE0]SRECCN
      If fstat Then
        [M:SRE0]SRECCNCLA = [M:SRE0]SRECCN
      Else
        Call BUILDFULNAM("AIN", [M:SRE0]SRECCNCLA) From CRMUTIL140
      Endif
    Endif
    #Définition du chrono client
    If GSRENUMAUT = 2 Then
      Gosub SUBB1_SRENUMBPC From SUBSREB3
    Endif
  Endif
  If [M:SRE0]SRECCN <> "" Then
    If [M:SRE0]SREBPC = "" Then
      [M:SRE0]SREDOO = ""
      [M:SRE0]SREDOOX = ""
    Endif
  Endif
  #---------------------------------------------------#
  # Contrôle de la couverture
  #---------------------------------------------------#
  #Remise à zéro des champs de couverture globale.
  Call RAZCOVMEE(0) From TRTCOVER
  If [M:SRE0]SREBPC = "" Then
    [M:SRE2]OVRCOV = 3
    [M:SRE2]OVRCOVTYP = ""
    [M:SRE2]OVRCOVCLA = ""
    [M:SRE2]OVRCOVREN = 0
    [M:SRE2]SRECOVAUT = 1
  Else
    Read [BPC]BPC0=[M:SRE0]SREBPC
    If fstat Then
      Read [BPR]BPR0=[M:SRE0]SREBPC
      If fstat Then
        GMESSAGE = [M:SRE0]SREBPC - mess(106,116,1) #XXXX n'EST pas un client.
        GERR = 2
      Else
        GMESSAGE = [F:BPR]BPRNAM - mess(106,116,1) #XXXX n'EST pas un client.
        GERR = 2
      Endif
    Else
      If [F:BPC]BPCTYP = 4 Then
        GMESSAGE = [F:BPC]BPCNAM - mess(106,116,1) #XXXX n'EST pas un client.
        GERR = 2
      Else
        Call COVERM From TRTCOVER
        #Ajout du parc en cas de création depuis une fiche parc
        #LSE 09/01/2007
        If GPILNAV > 1 Then
          If GNAVIG(GPILNAV-1) = "GESMAC" Then
            If [M:MAC0]MACNUM <> "" Then
              If [M:MAC1]MACITNTYP = 1 Then
                If [M:MAC1]BPCNUM = [M:SRE0]SREBPC Then
                  ISAVSRE7NOLIGN = nolign
                  nolign = 1
                  [M:SRE7]MAC(0) = ""
                  Call AM_MAC([M:MAC0]MACNUM) From SUBSRE
                  nolign = ISAVSRE7NOLIGN
                  [M:SRE7]NBMAC = 1
                  Raz [M:SRE7]NBMACSEL
                  [M:SRE7]NBMACSEL(0) = "->"
                  [M:SRE7]PRESRE7NOL = 0
                  #Ajout d'un composant en cas de création depuis la nomenclature d'une fiche parc
                  If [M:MAC0]CPNFORSRE <> "" Then
                    ISAVSRE7NOLIGN = nolign
                    nolign = 1
                    [M:SRE7]CPNITM(0) = ""
                    Call AM_CPNITM([M:MAC0]CPNFORSRE) From SUBSRE
                    nolign = ISAVSRE7NOLIGN
                    [M:SRE7]NBCPN = 1
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  #Obtient le niveau de réactivité SAV.
  Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
  #---------------------------------------------------#
  #  Affiche les champs labels de l'horodatage
  #---------------------------------------------------#
  [M:SRE2]TITBLK = ""
  [M:SRE2]TITDAY = mess(1,635,1)
  [M:SRE2]TITHOU = mess(1,301,1)
  [M:SRE2]TITMNT = mess(2,301,1)
  [M:SRE2]TITSPG = mess(191,182,1)
  [M:SRE2]TITCSPG = mess(149,182,1)
  Actzo [M:SRE2]TIMSPGDAY
  Actzo [M:SRE2]TIMSPGHOU
  Actzo [M:SRE2]TIMSPGMNT
  #Définition des informations de facturation
  # FGR 16/04/2012 : X3SUIVI81400 (début)
  If [M:SRE0]SREDOO <> "" Then
    Call SETINVINF([M:SRE0]SREDOO) From SUBSREB1
  Elsif [M:SRE0]SREBPC <> "" Then
    Call SETINVINF([M:SRE0]SREBPC) From SUBSREB1
  Endif
  # FGR 16/04/2012 : X3SUIVI81400 (début)
  #---------------------------------------------------#
  # Définit la variable globale pour la création d'une solution
  #---------------------------------------------------#
  GISRECOUNT = 0
  If GINTRA Then
    If GMESSAGE <> "" and SZMESS2 <> "" Then
      GMESSAGE = GMESSAGE - mess(610,196,1) - SZMESS2
    Else
      GMESSAGE = GMESSAGE - SZMESS2
    Endif
  Endif
  #---------------------------------------------------#
  #Gestion des consommations
  #---------------------------------------------------#
  #LSE 01/03/2005 gestion des sites
  If [M:SRE0]SREBPC = "" or [M:SRE0]SALFCY = "" or [M:SRE8]STOFCY = "" Then
    Grizo [M:SRE9]5
  Endif
  [M:SRE9]DONDATFLG = 0
  #---------------------------------------------------#
  #Gestion du parc concerné
  #---------------------------------------------------#
  If [M:SRE0]SREBPC = "" Then
    Grizo [SRE7]10
    Grizo [SRE7]15
  Else
    Actzo [SRE7]10
    Actzo [SRE7]15
  Endif
  Actzo [M:SRE2]SREDET
  If [M:SRE2]SREASS = 2 Then
    Call SITECRMINTREP ("HDK", [M:SRE2]SREDET, [M:SRE0]SALFCY) From CRM_UTIL
  Endif
  #Si aucun site on va prendre celui du client
  Call SETSITECRM("HDK", [M:SRE0]SREBPC, "", [M:SRE0]SALFCY) From CRM_UTIL

  #LSE 04/11/2005 FQ 33022
  If [M:SRE0]SALFCY <> "" Then
    If [M:SRE8]STOFCY<> "" Then
      SZSITESTOCK = [M:SRE8]STOFCY
    Else
      SZSITESTOCK = GFCYDEF(7)
    Endif
    If SZSITESTOCK <> "" and SZSITESTOCK <> [M:SRE0]SALFCY Then
      Read [FCY]FCY0=[M:SRE0]SALFCY
      If fstat Then
        [M:SRE0]SALFCY = ""
      Else
        SZSOC = [F:FCY]LEGCPY
        Read [FCY]FCY0=SZSITESTOCK
        If fstat Then
          SZSITESTOCK = ""
        Else
          If [F:FCY]LEGCPY <> SZSOC Then
            SZSITESTOCK = ""
          Endif
        Endif
      Endif
    Endif
    [M:SRE8]STOFCY = SZSITESTOCK
  Endif
  If GFCY <> [M:SRE0]SALFCY Then
    GFCY = [M:SRE0]SALFCY
    Call INIT_GLOBAL_CPT(GFCY,"HTR",2,GHDKTRSSRE) From TRTX3CPT
  Endif
  #----- Affichage entêtes de colonnes variables -----
  Gosub AFF_TITCOL From SUBSREB1
  #---------------------------------------------------#
  # Sorties de stock
  #---------------------------------------------------#
  [M:SRE0]STKFLG = 1
  [M:SRE0]TRSCOD = [F:HTR]TRSCOD
  [M:SRE0]ENTCOD = [F:HTR]ENTCOD
  [M:SRE0]TRSFAM = [F:HTR]TRSFAM
  #[M:SRE0]CCECODS = 1
  Call RAZSTOSORW From STKSOR
  Raz GSRE9HDTISSISS
  Raz GSRE9DIRTYISSISS
  #Enregistrement des valeurs de couvertures précédentes
  Call PRECRMSRE1("") From SUBSREB3
  #Gestion des statistiques sur compétences
  [M:SRE2]SREPREASS = 0
  [M:SRE2]SREPREDET = ""
  [M:SRE2]SREPREPBL = ""
  #Affichage de l'interlocuteur
  Gosub DISPCCN From SUBSREB3
  #---------------------------------------------------#
  #Dernière escalade
  #---------------------------------------------------#
  Gosub RAZESC From SUBSREB3
  #---------------------------------------------------#
  # Gestion de la création des horodatages en action RAZCRE et LIENS
  #---------------------------------------------------#
  Gosub RESETSCH From SUBSREB3
  # Enregistre le moment précis de la création d'une demande pour l'horodatage automatique en création
  Gosub MNGHORCREDUP From SUBSREB4
  Call SETTZN From SUBSREB4
  Gosub SETMACGRAY From SUBSREB4
  #Modele de demande de service
  Actzo [M:SRE1]SRETPL
  # Issue X3-41593 - 2017-10-13 by FGR : BEGIN
  #Grizo [M:SRE0]SRENUM
  If [M:SRE0]SALFCY <> "" Then
    Call READ_COUNTER([M:SRE0]SALFCY, 12, 1, GSOCIETE, GCURLEG, GCSRECPT, GMANCOU) From CRM_UTIL
    If GMANCOU = [V]CST_ANO Then
      Grizo [M:SRE0]SRENUM
    Endif
  Endif
  # Issue X3-41593 - 2017-10-13 by FGR : END
  Diszo [M:SRE2]SREESCNUM
  Actzo [M:SRE0]SALFCY
  Actzo [M:SRE8]SRECUR
  Raz [M:SREF] # FGR 07/07/2008 : X3SUIVI48011
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE0]1-99
  Affzo [M:SRE1]1-99
  Affzo [M:SRE2]1-99
  Affzo [M:SRE7]1-99
  Affzo [M:SRE8]1-99
  Affzo [M:SRE9]1-99
  Affzo [M:SREF]1-99 # FGR 07/07/2008 : X3SUIVI48011
Return

##########################################################################################################
$FILTRE
Local Char SZAUZDISP
Local Integer IAUZDISP
Local Integer IFILTSUP

  Default File [SRE]
  IFILTSUP = 0
  #Contrôle de l'autorisation dispatching
  Call PARAMUTIL("AUSHDKB", SZAUZDISP, GUSER, "") From SUBAUS
  If SZAUZDISP = "" Then
    IAUZDISP = 1
  Else
    IAUZDISP = val(SZAUZDISP)
  Endif
  If IAUZDISP <> 2 Then
    Call ADDCRIT(FILTSUP, IFILTSUP, "FILTSUP", "SREASS <> 1", "&") From GOBJSUB
  Endif
Return

##########################################################################################################
$FILGAUCHE
Default File [SRE]
Local Char SZAUZDISP
Local Integer IAUZDISP
Local Integer ISREPEFLT
Local Integer IMAINSREPEFLT

  IMAINSREPEFLT = 0
  ISREPEFLT = 0
  #Délégation du filgauche complet à un point d'entrée
  Gosub PE_MAINSREFLT From TRTCRMPE
  If IMAINSREPEFLT Then
    Return
  Endif
  If currbox = GBOXSRE Then
    #Demande de service ouvertes
    #Contrôle de l'autorisation dispatching
    Call PARAMUTIL("AUSHDKB", SZAUZDISP, GUSER, "") From SUBAUS
    If SZAUZDISP = "" Then
      IAUZDISP = 1
    Else
      IAUZDISP = val(SZAUZDISP)
    Endif
    #Gestion des statistiques sur demandes de service.
    If GPILNAV > 1 Then
      If GNAVIG(GPILNAV-1) = "FUNCXT0" Then
        If IAUZDISP <> 2 Then
          Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "SREASS <> 1", "&") From GOBJSUB
        Endif
        If GICXT0CXT2SEL Then
          Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", [M:CXT2]BCXTFLT(GISELNOLCXT), "&") From GOBJSUB
        Else
          Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", [M:CXT0]CXTFLT(GISELNOLCXT), "&") From GOBJSUB
        Endif
      Else
        If IAUZDISP = 2 Then
          Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "SREASS <> 5", "&") From GOBJSUB
        Else
          Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "SREASS <> 5 & SREASS <> 1", "&") From GOBJSUB
        Endif
      Endif
    Else
      If IAUZDISP = 2 Then
        Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "(SREASS <> 5)", "&") From GOBJSUB
      Else
        Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "(SREASS <> 5 and SREASS <> 1)", "&") From GOBJSUB
      Endif
    Endif
  Elsif currbox = GBOXSR2 Then
    #Demandes de services clôturées
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "SREASS = 5", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "SRE") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Elsif currbox = GBOXSRB Then
    #Demandes de services en retard
    # FGR 30/07/2014 : X3SUIVI101463 (début)
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "SREASS <> 5", "&") From GOBJSUB
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "(SRERESDAT<>[0/0/0] & ((SRERESDAT<date$) or (SRERESDAT=date$ and SRERESHOU<left$(time$,2)+mid$(time$,4,2))))", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "SRE") From CRMUTIL150
    # FGR 30/07/2014 : X3SUIVI101463 (fin)
  Elsif currbox = "GAU_CHE9"  Then
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "SRE") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Else
    #Gestion des browsers générés par transaction de saisie
    ISREPEFLT = 0
    #Les filtres sont posés par point d'entrée.
    Gosub PE_SREFLT From TRTCRMPE
    If ISREPEFLT  Then
      Return
    Endif
    Case currbox
      When GBOXSRESP1
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", GSZSREFILGAUFLT(0), "&") From GOBJSUB
        Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "SRE") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
      When GBOXSRESP2
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", GSZSREFILGAUFLT(1), "&") From GOBJSUB
        Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "SRE") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
      When GBOXSRESP3
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", GSZSREFILGAUFLT(2), "&") From GOBJSUB
        Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "SRE") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
      When GBOXSRESP4
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", GSZSREFILGAUFLT(3), "&") From GOBJSUB
        Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "SRE") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
      When GBOXSRESP5
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", GSZSREFILGAUFLT(4), "&") From GOBJSUB
        Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "SRE") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
      When GBOXSRESP6
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", GSZSREFILGAUFLT(5), "&") From GOBJSUB
        Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "SRE") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
      When GBOXSRESP7
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", GSZSREFILGAUFLT(6), "&") From GOBJSUB
        Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "SRE") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
    Endcase
  Endif
Return

##########################################################################################################
$ABANDON
Local Integer ITERABA
Local Integer ISTOERR
Local Integer ILESS
Local Integer IERRINF

  # ------------------------------------------
  # Issue X3-73246 - 2018-04-23 by FGR : BEGIN
  # When user change of line directly, whithout click on "Abort" button, $ABANDON is call twice.
  # First in "$ABANDON" in GOBJSUB, second in "$ABORT" in GOBJSUB.
  # After the first time, data are correct. After, they are corrupted.
  # We are to do something only on the first time
  If ISREABORT = [V]CST_AYES Then
    Return
  Endif
  ISREABORT = [V]CST_AYES
  # Issue X3-73246 - 2018-04-23 by FGR : END
  # ------------------------------------------
  ILESS = 0
  IERRINF = 0
  ISTOERR = 0
  # Sortie de stock
  Raz GSRE9HDTISSISS
  Raz GSRE9DIRTYISSISS
  For ITERABA = 0 To [M:SRE9]NBLIG-1
    Call DELSTOSORW(ITERABA, ITERABA, "SRE9", [M:SRE9]HDTSTOFCY(ITERABA), ISTOERR) From STKSOR
    If ISTOERR Then
      Break
    Endif
  Next
  If ISTOERR Then
    Return
  Endif
  #Clobs temporaires sur consommations
  Call DEBTRANS From GLOCK
  Trbegin [HD7]
  Delete [HD7] Where [F:HD7]PRONUM = adxuid(1)
  If fstat Then
    #Erreur lors de la suppression des textes saisis sur les consommations.
    GMESSAGE = mess(907,182,1)
    GERR = 1
    Rollback
    Return
  Else
    Commit
  Endif
  #On déverrouille la demande
  Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
  #Recalcul de la couverture.
  If [M:SRE0]SRENUM = "" Then
    #Supprime les enregistrements temporaires relatifs aux composants concernés
    Call DEBTRANS From GLOCK
    Trbegin [SRN]
    Delete [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
    If fstat Then
      Rollback
    Else
      Commit
    Endif
    Call DELPITCOV(GREP, 0, 0, IERRINF) From TRTCOVER
    If IERRINF Then
      #Erreur lors de suppression des couvertures par points.
      GMESSAGE = mess(513,182,1)
      GERR = 1
      End
    Endif
  Else
    #Restauration des composants
    Call CPNABANDON([M:SRE0]SRENUM, IERRINF) From SUBSREB3
    If IERRINF Then
      GMESSAGE = mess(IERRINF,182,1)
      GERR = 1
    Else
      #Restauration des points
      Call PITABANDON([M:SRE0]SRENUM, IERRINF) From SUBSREB3
      If IERRINF Then
        GMESSAGE = mess(IERRINF,182,1)
        GERR = 1
      Endif
    Endif
  Endif
  #Suppression du contrôle de session
  Call RAZPRONUM From SUBSREB3

  [M:SRE9]HORHDTFLG = 0

  Actzo [M:SRE0]SRENUM
  Affzo [M:SRE0]SRENUM
Return

##########################################################################################################
$VERF_ANU
Local Integer IANNREP
Local Integer IVALINV
Local Integer IERRINF

  IERRINF = 0
  IANNREP = 0
  IVALINV = 0
  #Vérifie si des factures validées sont associées à la demande à supprimer.
  If !GIMPORT
    Filter [SIV] Where [F:SIV]SIHORI = 8 and [F:SIV]SIHORINUM = [M:SRE0]SRENUM and [F:SIV]INVSTA = 3
    For [SIV]SIV1
      IVALINV += 1
    Next
    Filter [SIV]
    If IVALINV Then
      #Cette demande est associée à au moins une facture validée en comptabilité. Voulez-vous vraiment la supprimer ?
      Call OUINON(mess(935,182,1), IANNREP) From GESECRAN
      If IANNREP <> 2 Then
        OK = 0
      Endif
    Endif
  Endif
  If OK = 0 Then
    Return
  Endif
  #Remise en service des points mobilisés
  Call DELPITCOV(GREP, 0, 0, IERRINF) From TRTCOVER
  If IERRINF Then
    #Erreur lors de suppression des couvertures par points.
    GMESSAGE = mess(513,182,1)
    GERR = 1
    End
  Endif
Return

##########################################################################################################
$AV_ANNULE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  IBRETOUR = 1
  #Vérifie si des sorties de stock ont été réalisées
  Gosub CHECKSREDEL From SUBSREB4
  If GOK < 1 Then
    Return
  Endif
  #Suppression du clob description complète de la demande
  Gosub DELHD1 From SUBSREB3
  If GOK < 1 Then
    Return
  Endif
  #Suppression des clobs sur consommations
  Gosub DELTXC From SUBSREB3
  If GOK < 1 Then
    Return
  Endif
  #Suppression des consommations
  Gosub DELHDT From SUBSREB1
  If GOK < 1 Then
    Return
  Endif
  #Suppression des réservations de ressources des interventions
  Gosub DELITNRRS From SUBSREB3
  If GOK < 1 Then
    Return
  Endif
  #Suppression des interventions
  Gosub DELITN From SUBSREB3
  If GOK < 1 Then
    Return
  Endif
  # FGR 12/08/2009 : X3SUIVI57005 : C'est pas là que ça doit être
  #Enregistrement des données pour les encours
  #Gosub GERE_LCM_ANNULE From SUBSREB4
  #If GOK < 1 Then
  #  Return
  #Endif
Return

##########################################################################################################
$ANNULE
  # Maj des statistiques
  Call VALSTA("SRE",-1) From SUBPS2
Return

##########################################################################################################
$APRES_ANNULE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  # FGR 12/08/2009 : X3SUIVI57005 : Pour le moment, il n'y a que là qu'on peut le mettre
  #                  Le pb c'est que ça n'est pas dans la transaction, donc si ça échoue,
  #                  L'enregistrement sera détruit, mais le Dernier ne sera pas forcément à jour
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_ANNULE From SUBSREB4
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$SETBOUT
#Menu Actions   Module Action Co
# } : Enregistrer un rendez-vous
# { : Enregistrer un appel
# ~ : Enregistrer une tâche
# ! : Enregistrer une affaire
# ) : Planifier un rendez-vous
# ( : Planifier un appel
# £ : Planifier une tâche
# D : Traçabilité des pièces

Local Integer IFUNOPEN

  IFUNOPEN = 0
  If REP = "" & GMODU(13) = 2 Then
    CHMEN += "{}~!()£"
  Endif
  If REP = "" Then
    # FGR 17/10/2012 : X3SUIVI71278
    CHMEN += "D"
    # FGR 03/06/2015 : X3SUIVI108602 (début) Envoie par email
    If func CRMUTIL140.EMAIL_POSSIBLE(GUSER, "SRE", [M:SRE0]SRENUM) = [V]CST_AYES Then
      CHMEN += "-"
    Endif
    # FGR 03/06/2015 : X3SUIVI108602 (fin)
  Endif

  #Menu Actions   Module Support client
  # 2 : Enregistrer une intervention
  # 3 : Enregistrer une demande de service
  # 1 : Planifier une intervention
  If [M:SRE2]SREASS <> 5 Then
    CHMEN += "3"
  Endif
  #Intervention
  If REP = "" Then
    If [M:SRE0]SRENUM <> "" Then
      If [M:SRE0]SREBPC <> ""     Then
        Call ISFUNOPEN("GESITN", IFUNOPEN) From CRMUTIL140
        If !IFUNOPEN Then
          If [M:SRE2]SREASS = 5 Then
            ##LSE 06/10/2005 FQ 32432
            #CHMEN += "2"
          Else
            CHMEN += "12"
          Endif
        Endif
      Endif
    Endif
  Endif
  If REP = "" Then
    #Recherche de solution
    #Historique des états
    CHMEN += "PI"
    #Historique des escalades
    If [M:SRE2]SREESCNUM <> "" Then
      CHMEN += "O"
    Endif
    #Suivi des modifications
    If [M:SRE0]SRENUM <> "" Then
      If GUSRAUZ(1) = "" Then
        CHMEN += "S"
      Else
        If instr(1, GUSRAUZ(1), 'G') Then
          CHMEN += "S"
        Endif
      Endif
    Endif
    #Couverture par défaut
    If [M:SRE2]SREASS < 4 Then
      If [M:SRE2]SREASS > 0 Then
        If GUSRAUZ(1) = "" Then
          CHMEN += "N"
        Else
          If instr(1, GUSRAUZ(1), 'H') Then
            CHMEN += "N"
          Endif
        Endif
      Endif
    Endif
    #L'accès à une solution n'est possible que sur une demande clôturée associée à une solution.
    If [M:SRE2]SREASS = 5 Then
      If [M:SRE0]SOLNUM <> "" Then
        Call ISFUNOPEN("GESSOL", IFUNOPEN) From CRMUTIL140
        If !IFUNOPEN Then
          CHMEN += "Q"
        Endif
      Endif
    Endif
    #L'accès à une facture n'est possible que sur une demande clôturée et facturée.
    If [M:SRE2]SREASS = 5 Then
      If [M:SRE2]SREINVFLG = 3 Then
        Call ISFUNOPEN("GESSIH", IFUNOPEN) From CRMUTIL140
        If !IFUNOPEN Then
          CHMEN += "V"
        Endif
      Endif
    Endif
  Endif
  # FGR 08/07/2008 : X3SUIVI48011 (DEBUT)
  If GREP <> "" Then
    # Si on n'est pas en consultation le bouton "Facture" est grisé
    Call VIREBOUT(CHAINE, "Y") From GOBJET
    Call VIREBOUT(CHAINE, "Z") From GOBJET # FGR 17/06/2009 : X3SUIVI55475
  Elsif not ([M:SRE2]SREASS = 5 and [M:SRE2]SREINVFLG = 2) Then
    # Si la demande de service n'est ni clause, ni facturable le bouton "Facture" est grisé
    Call VIREBOUT(CHAINE, "Y") From GOBJET
  Endif
  # FGR 08/07/2008 : X3SUIVI48011 (FIN)
  # FGR 23/06/2015 : X3SUIVI107642 (début) : Si ni client ni numéro de demande de service, le tunnel vers intervention est interdit.
  If GREP = "" Then
    If [M:SRE0]SREBPC = "" and [M:SRE0]SRENUM = "" Then
    Call VIREBOUT(CHAINE, "Z") From GOBJET
    Endif
  Endif
  # FGR 23/06/2015 : X3SUIVI107642 (fin)
  #Si on est en mode Dispatching. On ne peut pas créer de nouvelles demandes.
  #LSE 09/01/2007
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "FUNHDKAGD" Then
      If [M:HDK0]NVGCOD = "G" Then
        Call VIREBOUT(CHAINE,"C") From GOBJET
      Endif
    Endif
  Endif
  #Option / Transaction de saisie.
  CHMEN += "5"
  # FGR 04/05/2009 : X3SUIVI34174 (début)
  CHMEN += "4"
  # FGR 04/05/2009 : X3SUIVI34174 (fin)
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$AVANTBOUT
Local Integer IERRINF

  IERRINF = 0
  GSZSRECON = ""
  GSZSREBPC = [M:SRE0]SREBPC
  If BOUT = "Z" Then
    # FGR 17/06/2009 : X3SUIVI55475 : Bouton "Planifier intervention" : Z fonctionne comme 1
    [M:SRE0]NVGCOD = "1"
  Else
    [M:SRE0]NVGCOD = BOUT
  Endif
  If BOUT = "B" Then
    #Bouton CONTRAT
    [M:SRE0]SREGREP = GREP
    If [M:SRE0]SREBPC <> "" Then
      If [M:SRE2]SRECOVNUM = "" Then
        [M:SRE2]OVRCOVTYP = "CON"
      Endif
      If [M:SRE2]OVRCOVTYP = "" Then
        [M:SRE2]OVRCOVTYP = "CON"
      Endif
      If [M:SRE2]OVRCOV = 1 Then
        GSZSRECXT = "OVRCOVCON"
        GSZSRECON = [M:SRE2]SRECOVNUM
      Elsif [M:SRE2]OVRCOV = 2 Then
        GSZSRECXT = "OVRCOVCON"
        GSZSRECON = [M:SRE2]SRECOVNUM
      Elsif [M:SRE2]OVRCOV = 4 Then
        GSZSRECXT = "OVRCOVCON"
        GSZSRECON = [M:SRE2]SRECOVNUM
      Endif
    Endif
  Elsif BOUT = "U" Then
    #Bouton COMMANDE
    [M:SRE0]SREGREP = GREP
    If [M:SRE0]SREBPC <> "" Then
      If [M:SRE2]OVRCOV = 5 Then
        GSZSRECXT = "OVRCOVSOH"
        GSZSRECON = [M:SRE2]SRECOVNUM
      Endif
    Endif
  Elsif BOUT = "1" or BOUT = "2" or BOUT = "Z" Then
    # FGR 17/06/2009 : X3SUIVI55475 : Bouton "Planifier intervention" - BOUT = "Z"
    #Menu Intervention
    [M:SRE7]ITNGRUVAL = ""
    #---------------------------------------------------#
    #Définit la clé Intervention pour les tunnels sur interventions.
    #---------------------------------------------------#
    GLASITN = ""
    Filter [ITN] Where [F:ITN]SRVDEMNUM = [M:SRE0]SRENUM and [F:ITN]MACGRU = [M:SRE7]ITNGRUVAL Order By [F:ITN]DATX Desc
    For [ITN]Hint Key ITN1
      GLASITN = [F:ITN]NUM
      Break
    Next
    Filter [ITN]
    Case GAUSHDKC
      When 1
        [M:SRE7]SRENAVTYP = "MAC"
      When 2
        [M:SRE7]SRENAVTYP = "SRE"
      When 3
        [M:SRE7]SRENAVTYP = "BPC"
      When Default
        [M:SRE7]SRENAVTYP = "MAC"
    Endcase
  Elsif BOUT = "N" Then
    #Menu Couverture par défaut
    Call CPTDEFCOV(IERRINF) From SUBSREB3
    If IERRINF Then
      GMESSAGE = mess(IERRINF,182,1)
      GERR = 1
    Endif
  Elsif BOUT = "Y" Then
    # FGR 08/07/2008 : X3SUIVI48011 (DEBUT)
    # Tunnel sur FACTURE à créer
    GCREPARBOU = 2
    GBIDC2 = "F" # Ca on le trouve sur la fonction "GESSRE" dans la liste des options
    Gosub AUTORIS_OPT From CONTX3
    If !GBIDI2 Then
      GERR = 1
      GMESSAGE = mess(2,104,1)
      Return
    Endif
    GINVTYP = 1
    WFONC1 = GFONC1
    GFONC1 = "GESSRE"
    #
    Lock = "SRE" + [M:SRE0]SRENUM
    If fstat Then
      # modification en cours sur un autre poste
      GERR = 1
      GMESSAGE = [M:SRE0]SRENUM - ":" - mess(10,100,1)
    Else
      GCREPARBOU = 1
    Endif
    # FGR 08/07/2008 : X3SUIVI48011 (FIN)
    # V6.2 : Certification
    # Si ctrl date documents : Le contrat doit avoir une date <= datesyst (La facture est générée avec datesyst)
    If GCTLDATORI=2 & [F:SRE]SREDATASS>datesyst
        GMESSAGE=mess(7,413,1)-[F:SRE]SRENUM-format$(GFMDAT,[F:SRE]SREDATASS)-":\"-mess(347,192,1)-":"-format$(GFMDAT,datesyst) :#--CPO 83985 GFMDAT au lieu de GFMDAT
        GERR=1 : Return
    Endif
  Endif
  #
  If GERR = 0 Then
    Case BOUT
      When "1", "Z"  # FGR 17/06/2009 : X3SUIVI55475
        #Planifier Intervention
        GBCRMFLGNEW = 1
      When ")"
        #Planifier Rendez-vous
        GBCRMFLGNEW = 1
      When "("
        #Planifier Appel
        GBCRMFLGNEW = 1
      When "£"
        #Planifier Tache
        GBCRMFLGNEW = 1
      When "2"
        #Enregistrer Intervention
        GBCRMFLGNEW = 1
      When "3"
        #Enregistrer Demande de garantie
        GBCRMFLGNEW = 1
      When "}"
        #Enregistrer Rendez-vous
        GBCRMFLGNEW = 1
      When "{"
        #Enregistrer Appel
        GBCRMFLGNEW = 1
      When "~"
        #Enregistrer Tache
        GBCRMFLGNEW = 1
      When "!"
        #Enregistrer Affaire
        GBCRMFLGNEW = 1
    Endcase
  Endif
  # FGR 11/05/2011 : X3SUIVI73730 (début)
  If BOUT = "V" Then
    Raz GBIDC3
    For [SIV]SIV0 Where [SIV]SIHORI = 8  and [SIV]SIHORINUM = [M:SRE0]SRENUM
      GBIDC3 = [F:SIV]NUM
      Break
    Next
  Endif
  # FGR 11/05/2011 : X3SUIVI73730 (fin)
Return

##########################################################################################################
$EXEBOUT
  # FGR 11/07/2008 : X3SUIVI48011 (DEBUT)
  Case BOUT
    When "Y"
      # Tunnel sur FACTURE à créer
      Gosub RELIT From GOBJSUB
    When "1", "2", "Z"
      # FGR 27/02/2016 : X3SUIVI114807 Le contexte a été modifié dans les interventions. Il faut le restaurer
      Gosub DEFTRANS
    When Default
  Endcase
  # FGR 11/07/2008 : X3SUIVI48011 (FIN)
Return

##########################################################################################################
$LIENS
Local Integer INB

  ISREABORT = [V]CST_ANO     # Issue X3-73246 - 2018-04-23 by FGR
  Gosub CHARG_PARAM # FGR 26/07/2013 : X3SUIVI87923 (fin)
  [M:SRE2]UPDHORCTL = 0
  [M:SRE0]LKP5SEAFLG = 0
  [M:SRE0]SREASSDFLG = 0
  [M:SRE0]SRESYM = SYMBOLE
  If GFCY <> [M:SRE0]SALFCY Then
    GFCY = [M:SRE0]SALFCY
    Call INIT_GLOBAL_CPT([M:SRE0]SALFCY,"HTR",2,GHDKTRSSRE) From TRTX3CPT
  Endif
  # V6.2 : Certification
  # --- Contrôle date documents
  Call LOAD_GCTLDATORI() From CRMUTIL150  # FGR 25/01/2012 : X3SUIVI78765
  #Local  Char     PARAM(GLONADP)
  #Call PARAM(GFCY,"CTLDATORI",PARAM) From ADOVAL
  #GCTLDATORI=val(PARAM)  : If GCTLDATORI=0   GCTLDATORI=2  : Endif
  Call CHARG_CCEH("SRE8","NBAXE","SRE") From TRTX3CPT
  # Issue X3-38449 - 2017-10-09 by FGR : BEGIN was missing here
  Local Char    WPLISTC(250)

  Call ALICOLREM (1,0,"","SRE9", "", 1,WPLISTC) From TRTPRICE
  # Issue X3-38449 - 2017-10-09 by FGR : END
  #----- Affichage entêtes de colonne variables -----#
  Gosub AFF_TITCOL From SUBSREB1
  Gosub SAVEVALINI From SUBSREB1
  #Gosub SETGRAY From SUBSREB3   # FGR 12/04/2011 : X3SUIVI71405 : C'est un peu tôt

  [M:SRE0]DELSRE7FLG = 0
  [M:SRE0]DELSRE9FLG = 0
  [M:SRE0]PREUPDFLG = 0
  GSREUDDHDTFLG = ""
  [M:SRE0]CRMSRE1FLG = 0
  #---------------------------------------------------#
  # Sorties de stock (Modif temporaire cela doit être lu sur la transaction de saisie)
  #---------------------------------------------------#
  Raz GSRE9HDTISSISS
  Raz GSRE9DIRTYISSISS
  [M:SRE0]STKFLG = 1
  Raz [M:SRE0]COVMEE
  Raz [M:SRE0]CURCOVMEE
  [M:SRE0]CRESEQ = ""
  #Lecture du clob description complète
  Gosub LOADHD1 From SUBSREB3
  #---------------------------------------------------#
  #Contrôle de la clôture de la demande
  [M:SRE2]SREPREASS = [M:SRE2]SREASS
  [M:SRE2]SREPREDET = [M:SRE2]SREDET
  [M:SRE2]SREPREPBL = ""
  If [M:SRE7]SREPBLGRP = "" Then
    If [M:SRE0]SREMACPBL <> "" Then
      [M:SRE2]SREPREPBL = [M:SRE0]SREMACPBL
    Endif
  Else
    [M:SRE2]SREPREPBL = [M:SRE7]SREPBLGRP
  Endif
  [M:SRE9]DONDATFLG = 0
  #---------------------------------------------------#
  #  Origine
  #---------------------------------------------------#
  If [M:SRE1]CREUSR <> "" Then
     Read[AUS]CODUSR=[M:SRE1]CREUSR
     [M:SRE1]FULNAMUSR = [F:AUS]NOMUSR
     Affzo [M:SRE1]FULNAMUSR
  Endif
  If [M:SRE1]SREORI = 0 Then
    [M:SRE1]SREORI = 1
  Endif
  #Définition du type de pièce
  Case [M:SRE1]SREORI
    When 1
      [M:SRE1]SREORITYP = ""
    When 2
      [M:SRE1]SREORITYP = ""
    When Default
  Endcase
  Diszo [M:SRE1]SREORIVCR
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    Diszo [M:SRE9]TOTPIT
  Endif
  #---------------------------------------------------#
  #Affichage de la dénomination de la famille de compétence
  #---------------------------------------------------#
  If [M:SRE7]SREPBLGRP = "" Then
    [M:SRE7]SREPBLCLA = ""
  Else
    Read [PBL]PBL0=[M:SRE7]SREPBLGRP
    If fstat Then
      [M:SRE7]SREPBLCLA = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #[M:SRE7]SREPBLCLA = [F:PBL]GRPPBLDES
      Call LECTEXTRA([M:SRE7]SREPBLCLA,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
  Endif
  #---------------------------------------------------#
  #  Affiche les champs labels de l'horodatage
  #---------------------------------------------------#
  [M:SRE2]TITBLK = ""
  [M:SRE2]TITDAY = mess(1,635,1)
  [M:SRE2]TITHOU = mess(1,301,1)
  [M:SRE2]TITMNT = mess(2,301,1)
  [M:SRE2]TITSPG = mess(191,182,1)
  [M:SRE2]TITCSPG = mess(149,182,1)
  #---------------------------------------------------#
  #Enregistrement des horodatages
  #---------------------------------------------------#
  If GISRE2TIMFLG Then
    GSREHORAMTFLG = "LIENS"
    Call MNGHORO(GISRE2TIMSRENUM, 0, "") From SUBSREB1
  Endif
  GSREHORAMTFLG = ""
  GISRE2TIMSRENUM = [M:SRE0]SRENUM
  [M:SRE2]PRESPGFLG = 0
  GTIMPREVALCTL(0) = [M:SRE2]TIMSPGDAY
  GTIMPREVALCTL(1) = [M:SRE2]TIMSPGHOU
  GTIMPREVALCTL(2) = [M:SRE2]TIMSPGMNT
  [M:SRE9]HORHDTFLG = 0
  If [M:SRE9]NBLIG < dim([M:SRE9]HDTCPN)-1 Then
    If [M:SRE2]SREASS = 5 Then
      Grizo [M:SRE2]TIMSPGDAY
      Grizo [M:SRE2]TIMSPGHOU
      Grizo [M:SRE2]TIMSPGMNT
    Else
      Actzo [M:SRE2]TIMSPGDAY
      Actzo [M:SRE2]TIMSPGHOU
      Actzo [M:SRE2]TIMSPGMNT
    Endif
  Else
    Grizo [M:SRE2]TIMSPGDAY
    Grizo [M:SRE2]TIMSPGHOU
    Grizo [M:SRE2]TIMSPGMNT
  Endif
  Affzo [M:SRE2]TITDAY, TITHOU, TITMNT, TITSPG, TITCSPG, TITBLK, TIMSPGDAY, TIMSPGHOU, TIMSPGMNT
  #---------------------------------------------------#
  #Affiche le nom en clair du donneur d'ordre.
  #---------------------------------------------------#
  Read [BPR]BPR0=[M:SRE0]SREDOO
   If !fstat Then
    [M:SRE0]SREDOOX = [F:BPR]BPRNAM
  Endif
  #---------------------------------------------------#
  #Affiche le nom en clair du client avec son site
  #---------------------------------------------------#
  If [M:SRE0]SREBPC <> "" Then
    Read [BPR]BPR0=[M:SRE0]SREBPC
    If fstat Then
      [M:SRE0]SREBPCCLA = [M:SRE0]SREBPC
    Else
      [M:SRE0]SREBPCCLA = [F:BPR]BPRNAM
    Endif
    # FGR 15/02/2010 : X3SUIVI62427
    Read [BPC]BPC0=[M:SRE0]SREBPC
    Call DISPICON_BPC([F:BPC]OSTCTL) From SUBSREB3
    #
    If [M:SRE0]SREBPAADD <> "" Then
      Read [BPA]BPA0=1;[M:SRE0]SREBPC;[M:SRE0]SREBPAADD
      If !fstat Then
        If [F:BPA]BPADES = "" Then
          [M:SRE0]SREBPCCLA = [M:SRE0]SREBPCCLA - '/' - [F:BPA]BPAADD
        Else
          [M:SRE0]SREBPCCLA = [M:SRE0]SREBPCCLA - '/' - [F:BPA]BPADES
        Endif
      Endif
    Endif
  Endif
  #---------------------------------------------------#
  #  Affiche le nom de l'affectation en clair
  #---------------------------------------------------#
  If [M:SRE2]SREDET <> "" Then
    Case SREASS
      When 1
        Read [FCY]FCY0=[M:SRE2]SREDET
        If fstat Then
          [M:SRE2]SREDETCLA = [M:SRE2]SREDET
        Else
          [M:SRE2]SREDETCLA = [F:FCY]FCYNAM
        Endif
      When 2
        Read [AUS]CODUSR=[M:SRE2]SREDET
        If fstat Then
          [M:SRE2]SREDETCLA = [M:SRE2]SREDET
        Else
          [M:SRE2]SREDETCLA = [F:AUS]NOMUSR
        Endif
      When 3
        Read [QUE]QUE0=[M:SRE2]SREDET
        If fstat Then
          [M:SRE2]SREDETCLA = [M:SRE2]SREDET
        Else
          # FGR 23/09/2009 : X3SUIVI58037
          #[M:SRE2]SREDETCLA = [F:QUE]TTR
          Call LECTEXTRA([M:SRE2]SREDETCLA,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
        Endif
      When Default
    Endcase
  Endif
  #---------------------------------------------------#
  #  Grisement des zones
  #---------------------------------------------------#
  #Affectation
  If [M:SRE2]SREASS = 4 or [M:SRE2]SREASS = 5 Then
    Grizo [M:SRE2]SREDET
  Endif
  If [M:SRE2]SREASS = 1 or [M:SRE2]SREASS = 2 or [M:SRE2]SREASS = 3 Then
    Actzo [M:SRE2]SREDET
  Endif
  #---------------------------------------------------#
  # Eléments de facturation
  #---------------------------------------------------#
  #Eléments de facturation
  Gosub SRE_FOOT From SUBSREB1
  #---------------------------------------------------#
  #Définit la clé Affaire pour les tunnels sur affaire.
  #---------------------------------------------------#
  GLASOPP = ""
  Filter [OPPCRM] Where [F:OPPCRM]OPPSRENUM = [M:SRE0]SRENUM         # FGR 26/08/2015 : X3SUIVI108275 [OPPCRM] plus [OPP]
  For [OPPCRM]                                                       # FGR 26/08/2015 : X3SUIVI108275 [OPPCRM] plus [OPP]
    GLASOPP = [F:OPPCRM]OPPNUM                                       # FGR 26/08/2015 : X3SUIVI108275 [OPPCRM] plus [OPP]
    Break
  Next
  Filter [OPPCRM]                                                    # FGR 26/08/2015 : X3SUIVI108275 [OPPCRM] plus [OPP]
  #---------------------------------------------------#
  # Définit la variable globale Demande de service pour le filtre dans les affaires.
  #---------------------------------------------------#
  GSZSREBPC = [M:SRE0]SREBPC
  #---------------------------------------------------#
  # Définit la variable globale Demande de service pour le filtre dans les interventions.
  #---------------------------------------------------#
  GSZSRENUM = [M:SRE0]SRENUM
  #---------------------------------------------------#
  # Définit les variables globales pour la création des historiques d'états
  #---------------------------------------------------#
  GSZPRESAT = [M:SRE2]SRESAT
  GSZPREASS = [M:SRE2]SREDET
  GIPREASS = [M:SRE2]SREASS
  #---------------------------------------------------#
  # Définit la variable globale pour la création d'une solution
  #---------------------------------------------------#
  GISRECOUNT = 0
  #---------------------------------------------------#
  #Chargement du parc
  #---------------------------------------------------#
  If [M:SRE7]TYPMAC = 0 Then
    [M:SRE7]TYPMAC = 1
  Endif
  If [M:SRE7]TYPMAC = 1 Then
    [M:SRE7]MACFLT = ""
    [M:SRE7]MACFLTINT = 2
    Grizo [M:SRE7]MACFLT
    Grizo [M:SRE7]MACFLTINT
  Else
    Actzo [M:SRE7]MACFLT
    Actzo [M:SRE7]MACFLTINT
  Endif
  Gosub SRE7MAC From SUBSREB1
  #---------------------------------------------------#
  #Chargement des consommations
  #---------------------------------------------------#
  Call RAZSTOSORW From STKSOR
  Call LOADHDT([M:SRE0]SRENUM) From SUBSREB1
  If [M:SRE2]SREASS = 5 Then
    Grizo [M:SRE9]5
  Else
    If [M:SRE0]SREBPC = "" or [M:SRE0]SALFCY = "" or [M:SRE8]STOFCY = "" Then
      Grizo [M:SRE9]5
    Else
      Actzo [M:SRE9]5
    Endif
  Endif
  If [M:SRE9]NBLIG > 0 Then
    Diszo [M:SRE8]SRECUR  # FGR 15/02/2010 : X3SUIVI62427 Diszo permet les tunnels. pas Grizo
    Diszo [M:SRE0]SALFCY  # FGR 15/02/2010 : X3SUIVI62427 Diszo permet les tunnels. pas Grizo
    # FGR 27/03/2008 : X3SUIVI46583 : S'il y a des consommation, le client ne peut être modifié
    Diszo [M:SRE0]SREBPC  # FGR 15/02/2010 : X3SUIVI62427 Diszo permet les tunnels. pas Grizo
  Endif
  Gosub SETMACGRAY From SUBSREB4
  Call ETAZONSOR("SRE9") From STKECR
  #---------------------------------------------------#
  # Couverture globale
  #---------------------------------------------------#
  Gosub AFFSRE2MIS From SUBSREB2
  #Contrat support aux contraintes de résolution
  If [M:SRE2]CONSPT = "" Then
    [M:SRE2]CONSPTCLA = ""
  Else
    If [M:SRE2]CONSPTFLG > 0 Then
      #Contrat défini manuellement
      [M:SRE2]CONSPTCLA = mess(302,182,1)
    Else
      #Contrat défini automatiquement
      [M:SRE2]CONSPTCLA = mess(301,182,1)
    Endif
  Endif
  If [M:SRE2]OVRCOVTYP = "" Then
    [M:SRE2]OVRCOVTYP = "CON"
  Endif
  #---------------------------------------------------#
  #Dernière escalade
  #---------------------------------------------------#
  Gosub LOADESC From SUBSREB3
  #---------------------------------------------------#
  # FGR 07/07/2008 : X3SUIVI48011 (DEBUT)
  # Chargement "Factures", "Echéances", "Règlements"
  #---------------------------------------------------#
  # Chargement du tableau des factures
  INB = 0
  Call LOADINV(INB) From SUBSREB1
  If INB > 0 Then
    GSZINVNUM = [M:SREF]INVVCR(0)
    Call LOADECHE([M:SREF]INVVCR(0)) From SUBSREB1
  Else
    GSZINVNUM = ""
  Endif
  #---------------------------------------------------#
  # FGR 07/07/2008 : X3SUIVI48011 (FIN)
  #---------------------------------------------------#
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBSREB3
  Gosub SETGRAY From SUBSREB3   # FGR 12/04/2011 : X3SUIVI71405 : là c'est mieux
  #Affichage de l'interlocuteur
  Gosub DISPCCN From SUBSREB3
  Actzo [M:SRE0]SRENUM
  #Si on est en mode Dispatching. On ne peut pas créer de nouvelles demandes.
  #LSE 09/01/2007
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "FUNHDKAGD" Then
      If [M:HDK0]NVGCOD = "G" Then
        Diszo [M:SRE0]SRENUM
      Endif
    Endif
  Endif
  Diszo [M:SRE2]SREESCNUM

# Call SET_GLOCUSATAX([M:SRE0]SALFCY)  From TRTADRLIB         # LTA.n   # 106867.o
  Gosub GET_CPY_SSTTAXACT From TRTTAXSST   # 106867.n
  Gosub SHOW_HIDE_ENTCOD From TRTADRLIB   # 106867.n

  # 101380 - Show/Hide SST related fields as needed
  Call SETUP_SSTFIELDS

  #---------------------------------------------------#
  # Gestion de la création des horodatages en action RAZCRE et LIENS
  #---------------------------------------------------#
  Gosub RESETSCH From SUBSREB3
  Call SETTZN From SUBSREB4
  #Modele de demande de service
  Grizo [M:SRE1]SRETPL
  Affzo [M:SRE0]SRENUM
  Affzo [M:SRE2]SREESCNUM
  # Issue SAM120376 - 2017-01-09 by FGR : BEGIN
  For ILINDEB = 0 To [M:SRE9]NBLIG-1
    Call SET_HDTAMTINV_ENABLE_DISABLE([M:SRE9]HDTINV(ILINDEB), ILINDEB)
  Next ILINDEB
  # Issue SAM120376 - 2017-01-09 by FGR : END
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer ISUFFIX
Local Integer IERRSUFFIX

  Call READ_COUNTER([M:SRE0]SALFCY, 12, 1, GSOCIETE, GCURLEG, GCSRECPT, GMANCOU) From CRM_UTIL     # FGR 20/04/2015 : X3SUIVI107768 : traite le cas où SALFCY n'est pas saisissable
  # Récupération du compteur de contrat de service.
  If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK", [M:SRE0]SALFCY, GCSRECPT, date$, "", [M:SRE0]SRENUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      [F:SRE]SRENUM = [M:SRE0]SRENUM
      Affzo [M:SRE0]SRENUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
  #Calcul du chrono client numérique
  IERRSUFFIX = 0
  ISUFFIX = 0
  Call GENSRENUMBPC("CCR", [M:SRE0]SREBPC, ISUFFIX, IERRSUFFIX) From SUBSREB4
  If GOK < 1 Then
    Return
  Endif
  [M:SRE0]SREINUMBPC = ISUFFIX
  [F:SRE]SREINUMBPC = ISUFFIX
  #Gestion des clobs
  [F:SRE]TYPFULDES = "SRE"
  [F:SRE]NUMFULDES = [M:SRE0]SRENUM
  [M:SRE1]TYPFULDES = "SRE"
  [M:SRE1]NUMFULDES = [M:SRE0]SRENUM
Return

##########################################################################################################
$VERIF_CRE_MOD
Local Integer ITERFORCOV
Local Integer ISTOERR
Local Integer ITERSTT
Local Integer I
Local Integer ITERPBL
Local Integer IONREP

  # --------------------------------------
  If [M:SRE8]SREPTE <> "" Then
    #-- X3Suivi 71937 : Données par législation pour le Conditions de paiement
    Call CONTTPT([M:SRE8]SREPTE, GCURLEG, '', '', '', '', '') From SUBTPT
    If mkstat Then
      GERR = 1
      OK = 0
      GMESSAGE = mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","SRE8~SREPTE")+'"\'+GMESSAGE
      Return
    Endif
    # FGR 22/07/2013 : X3SUIVI87923 (début)
    Call CTRL_PTE_SEPA_SDD([M:SRE8]SREPTE, GSOCIETE, [M:SRE8]SREBPCPYR) From TRTVENSDD
    If mkstat Then
      GERR = 1
      OK = 0
      GMESSAGE = mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","SRE8~SREPTE")+'"\'+GMESSAGE
      Return
    Endif
    # FGR 22/07/2013 : X3SUIVI87923 (fin)
  Endif
  # --------------------------------------
  ISTOERR = 0
  #Vérification de la qualité de saisie de la couverture parc
  For ITERFORCOV = 0 To [M:SRE7]NBMAC-1
    If [M:SRE7]COVSPT(ITERFORCOV) = 1 or [M:SRE7]COVSPT(ITERFORCOV) = 2 or [M:SRE7]COVSPT(ITERFORCOV) = 5 Then
      If [M:SRE7]COVVCR(ITERFORCOV) = "" Then
        #Certaines couvertures relatives au parc ne comportent de numéro de pièce. Création refusée.
        GMESSAGE = mess(180,177,1)
        GERR = 2
        OK = 0
        Break
      Endif
    Endif
    #Contrôle de la couverture des composants
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]MACNUM = [M:SRE7]MAC(ITERFORCOV) and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
&             Order By [F:SRN]CPNITM Asc
    For [SRN]
      If [F:SRN]CPNCOVSPT = 1 or [F:SRN]CPNCOVSPT = 2 or [F:SRN]CPNCOVSPT = 5 Then
        If [F:SRN]CPNCOVVCR = "" Then
          #Certaines couvertures relatives au parc ne comportent de numéro de pièce. Création refusée.
          If ACTION = "VERIF_CRE" Then
            GMESSAGE = mess(180,177,1)
          Else
            GMESSAGE = mess(181,177,1)
          Endif
          GERR = 2
          OK = 0
          Break
        Endif
      Endif
    Next
    Filter [SRN]
    If OK = 0 Then
      Break
    Endif
  Next
  If OK = 0 Then
    Return
  Endif
  #Vérifie si un site de stokage est bien présent sur une consomation de type pièce
  For I = 0 To [M:SRE9]NBLIG-1
    If [M:SRE9]HDTTYP(I) = 2 Then
      If [M:SRE9]STOMGTCOD(I) > 1 Then
        #consomation de type pièce et géré en stock
        If [M:SRE9]HDTSTOFCY(I) = "" Then
          GMESSAGE = mess(204,177,1) #Il faut obligatoirement saisir un site de stockage.
          GERR = 2
          OK = 0
          Break
        Endif
      Endif
    Endif
  Next
  If OK = 0 Then
    Return
  Endif
  # FGR 30/09/2009 : X3SUIVI57245 : à ne faire que s'il y a des lignes de saisies
  If [M:SRE9]NBLIG > 0 Then
    #Sortie de stock
    Call CTLSTOSOR ("SRE9", "HDTISSQTY", [M:SRE9]NBLIG, ISTOERR) From STKECR
    If ISTOERR Then
      OK = 0
      Return
    Endif
  Endif
  #Un code client est obligatoire
  If [M:SRE0]SREBPC = "" Then
    #Un client doit obligatoirement être mentionné sur la demande de service.
    GMESSAGE = mess(27,177,1)
    GERR = 2
    OK = 0
    Return
  Endif
  #Les familles statistiques sont-elles obligatoires
  If GSRETSIOBY = 2 Then
    For ITERSTT = 0 To dim([M:SRE1]TSDCOD)-1
      If [M:SRE1]TSDCOD(ITERSTT) = "" Then
        #Les familles statistiques de la demande de service sont obligatoires. Elles doivent être renseignées.
        GMESSAGE = mess(417,182,1)
        GERR = 2
        OK = 0
        Break
      Endif
    Next
    If OK = 0 Then
      Return
    Endif
  Endif
  #Interdit la saisie d'une demande affectée à un collaborateur ou une queue de façon non nominative
  If [M:SRE2]SREASS = 2 Then
    If [M:SRE2]SREDET = "" Then
      If ACTION = "VERIF_CRE" Then
        GMESSAGE = mess(478,196,1)   #La demande n'a pas été explicitement affectée. Création refusée.
      Else
        GMESSAGE = mess(479,196,1)   #La demande n'a pas été explicitement affectée. Création refusée.
      Endif
      GERR = 2
      OK = 0
      Return
    Endif
  Elsif [M:SRE2]SREASS = 3 Then
    If [M:SRE2]SREDET = "" Then
      If ACTION = "VERIF_CRE" Then
        GMESSAGE = mess(478,196,1)   #La demande n'a pas été explicitement affectée. Création refusée.
      Else
        GMESSAGE = mess(479,196,1)   #La demande n'a pas été explicitement affectée. Création refusée.
      Endif
      GERR = 2
      OK = 0
      Return
    Endif
  Endif
  #S'assure de la cohérence du champ Parc par défaut avec le tableau du parc concerné
  If [M:SRE7]NBMAC = 0 Then
    [M:SRE0]SREMAC = ""
  Else
    If [M:SRE7]NBMAC = 1 Then
      [M:SRE0]SREMAC = [M:SRE7]MAC(0)
    Endif
  Endif
  #Renseigne la famille de compétence du parc par défaut
  [M:SRE0]SREMACPBL = ""
  If [M:SRE7]SREPBLGRP = "" Then
    If [M:SRE0]SREMAC <> "" Then
      For ITERPL = 0 To [M:SRE7]NBMAC-1
        If [M:SRE7]MAC(ITERPBL) = [M:SRE0]SREMAC Then
          [M:SRE0]SREMACPBL = [M:SRE7]PBL(ITERPBL)
          Break
        Endif
      Next
    Endif
  Endif
  #Caractère facturable de la demande
  Call SETINVFLG From SUBSREB2
Return

##########################################################################################################
$VERIF_CRE
Local Integer I
Local Integer ICRMSRE1FLG

  GOK = 1
  ICRMSRE1FLG = 0
  # FGR 06/08/2014 : X3SUIVI95250 (début)
  #  #Assure enregistrement description abrégé
  #  If [M:SRE1]SREFULDES = "" Then
  #    [M:SRE1]SREDES = ""
  #  Else
  #    [M:SRE1]SREDES = left$([M:SRE1]SREFULDES,250)
  #  Endif
  #  #Assure enregistrement description abrégé
  #  If [M:SRE1]SREFULDES = "" Then
  #    [M:SRE1]SREDES = ""
  #  Else
  #    [M:SRE1]SREDES = left$([M:SRE1]SREFULDES,250)
  #  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (fin)
  #Vérifie si un code article exist, on a un code parc (cas création par modèle)
  For I = 0 To dim ([M:SRE7]MAC)-1
    If [M:SRE7]MAC(I) = "" Then
      If [M:SRE7]ITM(I) <> "" Then
        GMESSAGE = mess(202,177,1) #Il faut obligatoirement saisir une référence parc.
        GERR = 1
        mkstat = 2
        Break
      Endif
    Endif
  Next
  If GERR = 1 Then
    Return
  Endif
  #
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
  #
  #Détermine si le workflow CRMSRE1 doit être exécuté
  Call CHKCRMSRE1("C", ICRMSRE1FLG) From CRMWFLOW
  [M:SRE0]CRMSRE1FLG = ICRMSRE1FLG
  #Détermine si une horodatage automatique en création doit être enregistré
  Gosub MNGAUTHORCRE From SUBSREB4
  GSREUDDHDTFLG = ""
Return

##########################################################################################################
$VERIF_MOD
Local Integer ICRMSRE1FLG

  GOK = 1
  ICRMSRE1FLG = 0
  #
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
  #
  #Détermine si le workflow CRMSRE1 doit être exécuté
  Call CHKCRMSRE1("M", ICRMSRE1FLG) From CRMWFLOW
  [M:SRE0]CRMSRE1FLG = ICRMSRE1FLG
  [M:SRE0]NBRMANUPD += 1
  GSREUDDHDTFLG = ""
Return

##########################################################################################################
$CREATION
Local Char SZPBLSRE
Local Integer IESCFLG
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZMESSAGE (250)

  SZPBLSRE = ""
  IESCFLG = 0
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  Raz SZMESSAGE
  #Enregistrement du CLOB description complète
  Gosub SAVEHD1 From SUBSREB3
  If GOK < 1 Then
    Return
  Endif
  #Ajout d'un historique d'état
  Gosub MNGHISTO From SUBSREB1
  If GOK < 1 Then
    Return
  Endif
  #Enregistrement des consommations
  Call SAVEHDT([M:SRE0]SRENUM) From SUBSREB1
  If GOK < 1 Then
    Return
  Endif
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_CREATION From SUBSREB4
  If GOK < 1 Then
    Return
  Endif
  #Gestion des statistiques sur compétence
  If [M:SRE7]SREPBLGRP = "" Then
    If [M:SRE0]SREMACPBL <> "" Then
      SZPBLSRE = [M:SRE0]SREMACPBL
    Endif
  Else
    SZPBLSRE = [M:SRE7]SREPBLGRP
  Endif
  Call MNGPBLSTAT([M:SRE0]SRENUM, [M:SRE2]SREPREPBL, SZPBLSRE, [M:SRE2]SREPREASS, [M:SRE2]SREASS, [M:SRE2]SREPREDET, [M:SRE2]SREDET, IERRINF, ICHAPTER, IBRETOUR) From TRTFSOL
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  [M:SRE1]CREHOU = [F:SRE]CREHOU
  #Crée la tâche batch CRMESC si elle n'existe pas.
  Call CREABTESC From SUBSREB3
  If GOK < 1 Then
    Return
  Endif
  #Enregistrement du parc concerné
  Call SAVECPN([M:SRE0]CRESEQ, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 0,IERRINF,ICHAPTER,IBRETOUR) From SUBSREB1
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  Call SAVEMAC([M:SRE0]SRENUM,IERRINF,ICHAPTER,IBRETOUR) From SUBSREB1
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  Call SAVECPNWKEY([M:SRE0]CRESEQ, [M:SRE0]SRENUM,IERRINF,ICHAPTER,IBRETOUR) From SUBSREB1
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  #Création d'une tâche si la demande est affectée au service commercial
  Gosub CREREPTSK From SUBSREB1
  If GOK = 0 Then
    Return
  Endif
  #Création de consommations suite à une saisie manuelle d'horodatage
  If [M:SRE2]PRESPGFLG Then
    INOMORE = 0
    If [F:SRE]TIMSPGDAY = 0 Then
      If [F:SRE]TIMSPGHOU = 0 Then
        If [F:SRE]TIMSPGMNT = 0 Then
          INOMORE = 1
        Endif
      Endif
    Endif
    If !INOMORE Then
      Call CREMANHORO([M:SRE0]SRENUM, SZMESSAGE, IBRETOUR) From SUBSREB1
      If IBRETOUR = 0 Then
        GMESSAGE = SZMESSAGE
        GERR = 1
        GOK = 0
        Return
      Endif
    Endif
    [M:SRE2]PRESPGFLG = 0
  Endif
  Call CLOSRE([M:SRE0]SRENUM, "", [M:SRE0]SREBPC, [M:SRE2]SREASS, [M:SRE2]SREPREASS, [M:SRE2]SREINVFLG, [M:SRE9]DONDATFLG, IERRINF, ICHAPTER, IBRETOUR) From SUBSREB2
  If IBRETOUR = 0 Then
    GOK = 0
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1
  Endif
  #Enregistrement des points mobilisés
  Call SAVEHDTWKEY("C", "SRE", SZMESSAGE, IBRETOUR) From SUBSREB2
  If IBRETOUR = 0 Then
    GOK = 0
    GMESSAGE = SZMESSAGE
    GERR = 1
  Endif
  #Enregistrement des points mobilisés
  Call SAVEPITWKEY([M:SRE0]CRESEQ, [M:SRE0]SRENUM, SZMESSAGE, IBRETOUR) From SUBSREB2
  If IBRETOUR = 0 Then
    GOK = 0
    GMESSAGE = SZMESSAGE
    GERR = 1
  Endif
  #---------------------------------------------------#
  #Exécution des escalades
  #---------------------------------------------------#
  Call DOESC([M:SRE0]SRENUM, "", IESCFLG, SZMESSAGE, IBRETOUR) From SUBSREB3
  If IBRETOUR = 0 Then
    GOK = 0
    GMESSAGE = SZMESSAGE
    GERR = 1
  Endif
  # Maj des statistiques
  Call VALSTA("SRE",1) From SUBPS2
Return

##########################################################################################################
$MODIF
Local Char SZPBLSRE(GLONVCR)
Local Integer IESCFLG
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZMESSAGE (250)

  SZPBLSRE = ""
  IESCFLG = 0
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  Raz SZMESSAGE
  #Enregistrement du CLOB description complète
  Gosub SAVEHD1 From SUBSREB3
  If GOK < 1 Then
    [M:SRE0]NBRMANUPD -= 1
    Return
  Endif
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_MODIF From SUBSREB4
  If GOK < 1 Then
    Return
  Endif
  #Suppression des caches abandon
  #Composants
  Call CPNAPRESMOD([M:SRE0]SRENUM, IERRINF) From SUBSREB3
  If IERRINF Then
    GMESSAGE = mess(IERRINF,182,1)
    GERR = 1
    GOK = 0
    [M:SRE0]NBRMANUPD -= 1
    Return
  Endif
  #Points
  Call PITAPRESMOD([M:SRE0]SRENUM, IERRINF) From SUBSREB3
  If IERRINF Then
    GMESSAGE = mess(IERRINF,182,1)
    GERR = 1
    GOK = 0
    [M:SRE0]NBRMANUPD -= 1
    Return
  Endif
  #Dévérouillage de la demande
  Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
  #Ajout d'un historique d'état
  Gosub MNGHISTO From SUBSREB1
  If GOK < 1 Then
    [M:SRE0]NBRMANUPD -= 1
    Return
  Endif
  #Enregistrement des consommations
  Call SAVEHDT([M:SRE0]SRENUM) From SUBSREB1
  If GOK < 1 Then
    [M:SRE0]NBRMANUPD -= 1
    Return
  Endif
  #Gestion des statistiques sur compétence
  If [M:SRE7]SREPBLGRP = "" Then
    If [M:SRE0]SREMACPBL <> "" Then
      SZPBLSRE = [M:SRE0]SREMACPBL
    Endif
  Else
    SZPBLSRE = [M:SRE7]SREPBLGRP
  Endif
  Call MNGPBLSTAT([M:SRE0]SRENUM, [M:SRE2]SREPREPBL, SZPBLSRE, [M:SRE2]SREPREASS, [M:SRE2]SREASS, [M:SRE2]SREPREDET, [M:SRE2]SREDET, IERRINF, ICHAPTER, IBRETOUR) From TRTFSOL
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1
    GOK = 0
    [M:SRE0]NBRMANUPD -= 1
    Return
  Endif
  Call SAVECPN([M:SRE0]SRENUM, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 0,IERRINF,ICHAPTER,IBRETOUR)  From SUBSREB1
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  Call SAVEMAC([M:SRE0]SRENUM,IERRINF,ICHAPTER,IBRETOUR)  From SUBSREB1
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  Gosub SRE7MAC From SUBSREB1
  #Création d'une tâche si la demande est affectée au service commercial
  If [M:SRE2]TSKREPCRE <> 2 Then
    Gosub CREREPTSK From SUBSREB1
    If GOK < 1 Then
      Return
    Endif
  Endif
  #Création de consommations suite à une saisie manuelle d'horodatage
  If [M:SRE2]PRESPGFLG Then
    INOMORE = 0
    If [F:SRE]TIMSPGDAY = 0 Then
      If [F:SRE]TIMSPGHOU = 0 Then
        If [F:SRE]TIMSPGMNT = 0 Then
          INOMORE = 1
        Endif
      Endif
    Endif
    If !INOMORE Then
      SZMTIMSPGCTL = num$([M:SRE2]TIMSPGDAY) + num$([M:SRE2]TIMSPGHOU) + num$([M:SRE2]TIMSPGMNT)
      SZGTIMSPGCTL = num$(GTIMPREVALCTL(0)) + num$(GTIMPREVALCTL(1)) + num$(GTIMPREVALCTL(2))
      If SZMTIMSPGCTL <> SZGTIMSPGCTL Then
        GSREUDDHDTFLG = "M"
        Call CREMANHORO([M:SRE0]SRENUM, SZMESSAGE, IBRETOUR) From SUBSREB1
        If IBRETOUR = 0 Then
          GMESSAGE=SZMESSAGE
          GERR = 1
          GOK = 0
          Return
        Endif
      Endif
    Endif
    [M:SRE2]PRESPGFLG = 0
  Endif
  #============================================================#
  # FGR 01/07/2008 : Il me semble que ca a été oublié (DEBUT)
  Call CLOSRE([M:SRE0]SRENUM, "", [M:SRE0]SREBPC, [M:SRE2]SREASS, [M:SRE2]SREPREASS, [M:SRE2]SREINVFLG, [M:SRE9]DONDATFLG, IERRINF, ICHAPTER, IBRETOUR) From SUBSREB2
  If IBRETOUR = 0 Then
    GOK = 0
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1
  Endif
  # FGR 01/07/2008 : Il me semble que ca a été oublié (FIN)
  #============================================================#
  #Enregistrement des points mobilisés
  Call SAVEHDTWKEY("M", "SRE", SZMESSAGE, IBRETOUR) From SUBSREB2
  If IBRETOUR = 0 Then
    GOK = 0
    GMESSAGE = SZMESSAGE
    GERR = 1
  Endif
  #---------------------------------------------------#
  #Exécution des escalades
  #---------------------------------------------------#
  Call DOESC([M:SRE0]SRENUM, "", IESCFLG, SZMESSAGE, IBRETOUR) From SUBSREB3
  If IBRETOUR = 0 Then
    GMESSAGE = SZMESSAGE
    GERR = 1
    GOK = 0
  Endif
   # Maj des statistiques
  Call VALSTA("SRE",-1) From SUBPS2
  Call VALSTA("SRE",1) From SUBPS2
Return

##########################################################################################################
$APRES_CRE
Local Integer IERRESC
Local Integer IERRFLG
Local Integer INOMORE
Local Integer IESCFLG
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZMESSAGE (250)

  [M:SRE2]UPDHORCTL = 0
  [M:SRE0]LKP5SEAFLG = 0
  [M:SRE0]HORHDTNUM = ""
  [M:SRE0]HORHDTSEQ = ""
  [M:SRE0]SRESYM = ""
  [M:SRE0]SREASSDFLG = 0
  Gosub SETGRAY From SUBSREB3
  IESCFLG = 0
  INOMORE = 0
  IERRFLG = 0
  IERRESC = 0
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  Raz SZMESSAGE
  GISRE2TIMSRENUM = [M:SRE0]SRENUM
  #---------------------------------------------------#
  #Contrôle de la clôture de la demande
  [M:SRE2]SREPREASS = [M:SRE2]SREASS
  [M:SRE2]SREPREDET = [M:SRE2]SREDET
  [M:SRE2]SREPREPBL = ""
  If [M:SRE7]SREPBLGRP = "" Then
    If [M:SRE0]SREMACPBL <> "" Then
      [M:SRE2]SREPREPBL = [M:SRE0]SREMACPBL
    Endif
  Else
    [M:SRE2]SREPREPBL = [M:SRE7]SREPBLGRP
  Endif
  [M:SRE9]DONDATFLG = 0
  Gosub SRE7MAC From SUBSREB1
  Call LOADHDT([M:SRE0]SRENUM) From SUBSREB1
  Call LOADTOT2PIT(1) From SUBSREB1
  If [M:SRE9]NBLIG > 0 Then
    Grizo [M:SRE8]SRECUR
    Grizo [M:SRE0]SALFCY
  Endif
  Gosub SETMACGRAY From SUBSREB4
  #Envoi du workflow CRMSRE1
  Call DOCRMSRE1([M:SRE0]CRMSRE1FLG) From CRMWFLOW
  [M:SRE0]CRESEQ = ""
  #---------------------------------------------------#
  # Affichage de la couverture globale
  #---------------------------------------------------#
  Gosub AFFSRE2MIS From SUBSREB2
  #---------------------------------------------------#
  #Suppression du contrôle de session
  #---------------------------------------------------#
  Call RAZPRONUM From SUBSREB3
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBSREB3
  #---------------------------------------------------#
  #Dernière escalade
  #---------------------------------------------------#
  Gosub LOADESC From SUBSREB3
  GSREHORAMTFLG = ""
  GSREUDDHDTFLG = ""
  GTIMPREVALCTL(0) = [M:SRE2]TIMSPGDAY
  GTIMPREVALCTL(1) = [M:SRE2]TIMSPGHOU
  GTIMPREVALCTL(2) = [M:SRE2]TIMSPGMNT
  [M:SRE9]HORHDTFLG = 0
  Actzo [M:SRE0]SRENUM
  Diszo [M:SRE2]SREESCNUM
  #---------------------------------------------------#
  # Gestion de la création des horodatages en action RAZCRE et LIENS
  #---------------------------------------------------#
  Gosub RESETSCH From SUBSREB3
  #---------------------------------------------------#
  # A exécuter en dernier dans la séquence
  # On averti si à la suite d'un horodatage manuel, on a atteint la nombre maximum de consommations.
  #---------------------------------------------------#
  If !GERR Then
    Gosub WARNMAXHDT From SUBSREB4
  Endif
  Gosub SAVEVALINI From SUBSREB1
  Call SETTZN From SUBSREB4
  #Modele de demande de service
  Grizo [M:SRE1]SRETPL
  [M:SRE0]HORHDTNUM = ""
  [M:SRE0]HORHDTSEQ = ""
  [M:SRE0]PREUPDFLG = 0
  [M:SRE0]DELSRE7FLG = 0
  [M:SRE0]DELSRE9FLG = 0
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE0]1-99
  Affzo [M:SRE1]1-99
  Affzo [M:SRE2]1-99
  Affzo [M:SRE7]1-99
  Affzo [M:SRE8]1-99
  Affzo [M:SRE9]1-99
Return


##########################################################################################################
$APRES_MOD
Local Integer IERRESC
Local Integer INOMORE
Local Integer IERRFLG
Local Integer IESCFLG
Local Char SZMTIMSPGCTL
Local Char SZGTIMSPGCTL
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  [M:SRE2]UPDHORCTL = 0
  [M:SRE0]LKP5SEAFLG = 0
  [M:SRE0]SRESYM = SYMBOLE
  [M:SRE0]SREASSDFLG = 0
  Gosub SETGRAY From SUBSREB3
  IESCFLG = 0
  INOMORE = 0
  IERRFLG = 0
  IERRESC = 0
  SZMTIMSPGCTL = ""
  SZGTIMSPGCTL = ""
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  GISRE2TIMSRENUM = [M:SRE0]SRENUM
  #Enregistrement du parc concerné
  Gosub SRE7MAC From SUBSREB1
  #---------------------------------------------------#
  #Contrôle de la clôture de la demande
  [M:SRE2]SREPREASS = [M:SRE2]SREASS
  [M:SRE2]SREPREDET = [M:SRE2]SREDET
  [M:SRE2]SREPREPBL = ""
  If [M:SRE7]SREPBLGRP = "" Then
    If [M:SRE0]SREMACPBL <> "" Then
      [M:SRE2]SREPREPBL = [M:SRE0]SREMACPBL
    Endif
  Else
    [M:SRE2]SREPREPBL = [M:SRE7]SREPBLGRP
  Endif
  [M:SRE9]DONDATFLG = 0
  Call LOADHDT([M:SRE0]SRENUM) From SUBSREB1
  If [M:SRE9]NBLIG > 0 Then
    Grizo [M:SRE8]SRECUR
    Grizo [M:SRE0]SALFCY
  Endif
  Gosub SETMACGRAY From SUBSREB4
  #Envoi du workflow CRMSRE1
  Call DOCRMSRE1([M:SRE0]CRMSRE1FLG) From CRMWFLOW
  [M:SRE0]CRESEQ = ""
  #---------------------------------------------------#
  #Suppression du contrôle de session
  Call RAZPRONUM From SUBSREB3
  #---------------------------------------------------#
  # Affichage de la couverture globale
  #---------------------------------------------------#
  Gosub AFFSRE2MIS From SUBSREB2
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBSREB3
  #---------------------------------------------------#
  #Dernière escalade
  #---------------------------------------------------#
  Gosub LOADESC From SUBSREB3
  GSREHORAMTFLG = ""
  GSREUDDHDTFLG = ""
  GTIMPREVALCTL(0) = [M:SRE2]TIMSPGDAY
  GTIMPREVALCTL(1) = [M:SRE2]TIMSPGHOU
  GTIMPREVALCTL(2) = [M:SRE2]TIMSPGMNT
  [M:SRE9]HORHDTFLG = 0
  #---------------------------------------------------#
  # Gestion de la création des horodatages en action RAZCRE et LIENS
  #---------------------------------------------------#
  Gosub RESETSCH From SUBSREB3
  #---------------------------------------------------#
  # A exécuter en dernier dans la séquence
  # On averti si à la suite d'un horodatage manuel, on a atteint la nombre maximum de consommations.
  #---------------------------------------------------#
  If !GERR Then
    Gosub WARNMAXHDT From SUBSREB4
  Endif
  Call SETTZN From SUBSREB4
  Gosub SAVEVALINI From SUBSREB1
  [M:SRE0]PREUPDFLG = 0
  [M:SRE0]DELSRE7FLG = 0
  [M:SRE0]DELSRE9FLG = 0
  Diszo [M:SRE2]SREESCNUM
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE0]1-99
  Affzo [M:SRE1]1-99
  Affzo [M:SRE2]1-99
  Affzo [M:SRE7]1-99
  Affzo [M:SRE8]1-99
  Affzo [M:SRE9]1-99
Return

##########################################################################################################
$AB2_NBLIG
  #-- Habilitation Modification mvts stock si on trouve K dans la chaine des boutons autorisés
  # hcb 27842
Local Integer NOL

  NOL = nolign-1
  Raz GBIDI2
  GFCY = [M:SRE9]HDTSTOFCY(NOL)
  GBIDC2 = "K"
  Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2 Then
    GMESSAGE = mess(2,104,1)
    GOUVSOR = 0
    Return
  Else
    GOUVSOR = 1
  Endif
Return

##########################################################################################################
$BB2_NBLIG
Local Integer NOL

  # FGR 13/10/2010 : X3SUIVI68214 : Si annulation sortie de stock décocher aussi
  NOL = nolign-1
  If [M:SRE9]HDTISSISS(NOL) = 0 Then
    [M:SRE9]HDTSTOISS(NOL) = 1
    [M:SRE9]SAVSTOISS(NOL) = 1
    [M:SRE9]HDTISSQTY(NOL) = 0
    Affzo [M:SRE9]HDTSTOISS(NOL)
    Affzo [M:SRE9]HDTISSQTY(NOL)
  Endif
Return

##########################################################################################################
$AAPRES_NBLIG
Local Integer NOL, WRET

  NOL = nolign-1
  Raz WRET
  Raz GOUVSOR
  # Si suppression ligne
  If find(status,65,68,83) Then
    Return
  Endif
  # Si sortie tableau non validante
  If [M:SRE9]HDTTYP(nolign-1) = 2 Then
    If [M:SRE9]HDTDONDAT(nolign-1) <> [00/00/00] Then
      If [M:SRE9]HDTSTOISS(nolign-1) = 2 Then
        If [M:SRE9]HDTISSQTY(nolign-1) > 0 Then
          If [M:SRE9]HDTISSISS(nolign-1) <= 0 Then
            Gosub ALI_ALP From SUBSREB3
            # Détermination du stock à sortir (automatisme, saisie)
            Call OUVSOR("SRE9", NOL, [M:SRE9]NBLIG, [M:SRE9]WSTOSEQ(NOL), [M:SRE0]STKFLG, WRET) From STKSOR
            If WRET = 0 Then
              [M:SRE9]HDTISSISS(nolign-1) = [M:ALP]QTY
              # FGR 05/08/2010 : X3SUIVI66063 (début)
              [M:SRE9]HDTISSQTY(nolign-1) = [M:ALP]QTY
              If [M:SRE9]HDTISSISS(nolign-1) = 0 Then
                [M:SRE9]HDTSTOISS(nolign-1) = 1
                [M:SRE9]SAVSTOISS(nolign-1) = 1
              Endif
              # FGR 05/08/2010 : X3SUIVI66063 (fin)
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Return

#########################################################################
# 101380 - Setup SST Override related fields
#########################################################################
Subprog SETUP_SSTFIELDS
# If GLOCUSATAX & dim([M:SRE8]SFISSTCOD)>0   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 & dim([M:SRE8]SFISSTCOD)>0   # 106867.n
  Chgfmt [M:SRE8]SFISSTCOD  With "K:"   + num$(type([M:SRE8]SFISSTCOD)-10)  + "B"     # Show enterable
Else
  Chgfmt [M:SRE8]SFISSTCOD  With "-K:"  + num$(type([M:SRE8]SFISSTCOD)-10)  + "B"     # Hide
Endif
End

##########################################################################################################
Subprog SET_HDTAMTINV_ENABLE_DISABLE(IHDTINV, ILINE)
Value Integer IHDTINV
Value Integer ILINE

  # Issue SAM120376 - 2017-01-09 by FGR
  If IHDTINV = 2 Then
    Actzo [M:SRE9]HDTAMTINV(ILINE)
  Else
    Diszo [M:SRE9]HDTAMTINV(ILINE)
  Endif
End

