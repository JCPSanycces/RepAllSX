#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################################################
$CHARG_PARAM
Local  Char     PARAM2(10)

  # FGR 26/07/2013 : X3SUIVI87923 (début)
  If func AFNC.ACTIV("SDD") Then
    Call PARAML(GFCY, "SDDMGT", PARAM2) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
    GSDDMGT = val(PARAM2)
    If GSDDMGT <> 1 and GSDDMGT <> 2 Then
      GSDDMGT = 1
    Endif
  Endif
  # FGR 26/07/2013 : X3SUIVI87923 (fin)
Return

##########################################################################################################
#   définitions des actions sources SUBSRE      Module CRM            18 avril 2005
##########################################################################################################
$AVANT_OUVRE
Return

##########################################################################################################
$DEFTRANS
Local Shortint OUVFICFLG

  #--------------------------------------------------------#
  # Avant lecture des transactions de saisie disponibles : #
  # Si GFLAG est renseigné la transaction est déja choisie #
  # par le menu. Vérifier si elle est valide               #
  #--------------------------------------------------------#
  If clalev ([F:HTR])=0 Local File HDKTRS [HTR] : Endif
  If GFLAG <> "" Then
    Read [HTR]HTR0=2;GFLAG
    If fstat or [F:HTR]ENAFLG = 1 Then
      Raz GFLAG
      Goto FIN_DEFTRANS
    Endif
    If [F:HTR]ACSCOD <> "" and GPROFIL <> GSUPER Then
      If clalev ([F:ACC])=0 Local File ACCES [ACC] : OUVFICFLG=1 : Endif
      Read [ACC]CODACC=GUSER;[F:HTR]ACSCOD
      If fstat or [F:ACC]EXEC <> 2 Then
        Raz GFLAG
        Goto FIN_DEFTRANS
      Endif
    Endif
  Endif
  If dim(GSSTENTCOD) < 0 Then          # FGR 27/02/2016 : X3SUIVI114807 pour ne pas l'écraser si elle existe
    Global Integer  GSSTENTCOD         #LTA.n
  Endif
  Goto FIN_DEFTRANS # FGR 10/12/2008 : On y va toujours mais c'est plus propre comme ça
Return

##########################################################################################################
$FIN_DEFTRANS
  If OUVFICFLG = 1 Then
    Close File [ACC]
    Raz OUVFICFLG
  Endif
Return

##########################################################################################################
$VARIANTE
  #---------------------------------------#
  # Après lecture de chaque transaction : #
  # La transaction est-elle valide ?      #
  # VARCOD contient le code transaction.  #
  # Mettre OK à zéro si non valide.       #
  #---------------------------------------#
  If !clalev([F:HTR]) : Local File HDKTRS [HTR] : Endif  # Issue X3-36430/122615 - 2017-05-09 by FGR
  Read [HTR]HTR0=2;VARCOD
  If fstat or [F:HTR]ENAFLG = 1 Then
    OK = 0
  Endif
Return

##########################################################################################################
$SETTRANS
  #-------------------------------------#
  # Après sélection de la transaction : #
  # GFLAG = code transaction choisie    #
  #-------------------------------------#
  If !clalev([F:HTR]) : Local File HDKTRS [HTR] : Endif  # Issue X3-36430/122615 - 2017-05-09 by FGR
  Read [HTR]HTR0=2;GFLAG
  If fstat Then
    Raz [F:HTR]
  Endif
  #MAE, le 31/01/08, GRP_SITE
  GGRPFCY = [F:HTR]GFY
  GSSTENTCOD = [F:HTR]SSTENTCOD         #LTA.n
Return

##########################################################################################################
$BOITE
Local Char STRTSUB(GLONADC)

  # FGR 31/07/2014 : X3SUIVI101463
  STRTSUB = "SUBSREA"
  Gosub BOITE_GOBJET From CRMUTIL150
Return

##########################################################################################################
$REDEFINE_LINK
  If !clalev([F:S_RE]) Then
    # FGR 11/02/2015 : X3SUIVI106120 : Si [S_RE] pas ouvert c'est que les browsers ont été redéfinis en SPE/SPV.
    # On part, c'est à ce niveau qu'on doit faire ce travail.
    Return
  Endif
  # FGR 31/07/2014 : X3SUIVI101463
  Link [SRE] With [S_RE]SRE0=[F:SRE]SRENUM,
&                 [AFF]AFF0~=[F:SRE]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:SRE]SALFCY
&              As [SR2_]
  Link [SRE] With [S_RE]SRE8=[F:SRE]SRERESDAT;[F:SRE]SRERESHOU;[F:SRE]SREASS;[F:SRE]SRENUM,
&                 [AFF]AFF0~=[F:SRE]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:SRE]SALFCY
&              As [SRB_]
Return

##########################################################################################################
$OUVRE_BOITE
  #---------------------------------------------------#
  #Chargement des noms des cuurbox de chaque tiroir
  If OBJLIS(0) = "SRE" Then
    GBOXSRE = "GAU_CHE"
  Else
    GBOXSRE = "GAU_CHE"+num$(find("SRE",OBJLIS(1..8))) : #Demandes de service ouvertes
  Endif
  If OBJLIS(0) = "SR2" Then
    GBOXSR2 = "GAU_CHE"
  Else
    GBOXSR2 = "GAU_CHE"+num$(find("SR2",OBJLIS(1..8))) : #Demandes de service clôturées
  Endif
  # FGR 30/07/2014 : X3SUIVI101463 (début)
  If OBJLIS(0) = "SRB" Then
    GBOXSRB = "GAU_CHE"
  Else
    GBOXSRB = "GAU_CHE"+num$(find("SRB",OBJLIS(1..8))) : #Demandes de service en retard
  Endif
  # FGR 30/07/2014 : X3SUIVI101463 (fin)

  If GSSRENAMESPE(0) <> "" Then
    If OBJLIS(0) = GSSRENAMESPE(0) Then
      GBOXSRESP1 = "GAU_CHE"
    Else
      GBOXSRESP1 = "GAU_CHE"+num$(find(GSSRENAMESPE(0),OBJLIS(1..8))) : #Liste spécifique 1
    Endif
  Endif
  If GSSRENAMESPE(1) <> "" Then
    If OBJLIS(0) = GSSRENAMESPE(1) Then
      GBOXSRESP2 = "GAU_CHE"
    Else
      GBOXSRESP2 = "GAU_CHE"+num$(find(GSSRENAMESPE(1),OBJLIS(1..8))) : #Liste spécifique 2
    Endif
  Endif
  If GSSRENAMESPE(2) <> "" Then
    If OBJLIS(0) = GSSRENAMESPE(2) Then
      GBOXSRESP3 = "GAU_CHE"
    Else
      GBOXSRESP3 = "GAU_CHE"+num$(find(GSSRENAMESPE(2),OBJLIS(1..8))) : #Liste spécifique 3
    Endif
  Endif
  If GSSRENAMESPE(3) <> "" Then
    If OBJLIS(0) = GSSRENAMESPE(3) Then
      GBOXSRESP4 = "GAU_CHE"
    Else
      GBOXSRESP4 = "GAU_CHE"+num$(find(GSSRENAMESPE(3),OBJLIS(1..8))) : #Liste spécifique 4
    Endif
  Endif
  If GSSRENAMESPE(4) <> "" Then
    If OBJLIS(0) = GSBOXNAMESPE(4) Then
      GBOXSRESP5 = "GAU_CHE"
    Else
      GBOXSRESP5 = "GAU_CHE"+num$(find(GSSRENAMESPE(4),OBJLIS(1..8))) : #Liste spécifique 5
    Endif
  Endif
  If GSSRENAMESPE(5) <> "" Then
    If OBJLIS(0) = GSSRENAMESPE(5) Then
      GBOXSRESP6 = "GAU_CHE"
    Else
      GBOXSRESP6 = "GAU_CHE"+num$(find(GSSRENAMESPE(5),OBJLIS(1..8))) : #Liste spécifique 6
    Endif
  Endif
  If GSSRENAMESPE(6) <> "" Then
    If OBJLIS(0) = GSSRENAMESPE(6) Then
      GBOXSRESP7 = "GAU_CHE"
    Else
      GBOXSRESP7 = "GAU_CHE"+num$(find(GSSRENAMESPE(6),OBJLIS(1..8))) : #Liste spécifique 7
    Endif
  Endif
Return

##########################################################################################################
$OUVRE
  #Stockage code transaction
Global Char GHDKTRSSRE

  GHDKTRSSRE = [F:HTR]HTRNUM
  #Contrôle des points
  If !GIMPORT Then
    Local Integer IERRINFPIT
    Local Integer ITSTPRONUM

    ITSTPRONUM = 0
    IERRINFPIT = 0
    Gosub EXECPIT From TRTPITGEN
  Endif
  #Contrôle des clobs temporaires
  If !GIMPORT Then
    Gosub CLEANHD7 From SUBSREB3
  Endif

  # FGR 22/11/2012 : X3SUIVI85908 (début)
  If dim(GSZSECHDT) >= 0 Then
    Kill GSZSECHDT
  Endif
  # FGR 22/11/2012 : X3SUIVI85908 (fin)

Local Integer ISREABORT          # Issue X3-73246 - 2018-04-23 by FGR

ISREABORT = [V]CST_ANO           # Issue X3-73246 - 2018-04-23 by FGR

Global Char GSZINVNUM(GLONVCR)   # FGR 07/07/2008 : X3SUIVI48011
Global Shortint GINVTYP          # FGR 07/07/2008 : X3SUIVI48011 : 1 = facture / 2 = avoir / 5 = proforma
Global Char GSZSRE7FOLDTIT
Global Char GSZSRE8FOLDTIT
Global Char GSZSRE9FOLDTIT
Global Char GCSRECPT(GLONANM)    # Code compteur pour demande de service.
Global Char GSR2CSRECPT(GLONANM) # Code compteur pour numéro de séquence.
Global Char GLASOPP
Global Char GLASITN
Global Char GSZSREBPC(GLONBPC)
Global Char GSZSRECON(GLONVCR)
Global Char GSZSRENUM(GLONVCR)
Global Char GSZSRECXT
Global Integer GIPREASS
Global Char GSZPREASS
Global Char GSZPRESAT
Global Integer GIPREMESS
Global Integer GISRECOUNT
Global Integer GISRE2TIMFLG
Global Integer GISRE2STRDAYCTL
Global Integer GISRE2STRSODCTL
Global Integer GIHAUTSTRDAYCTL
Global Integer GIHAUTSTRSODCTL
Global Char GISRE2TIMSRENUM
Global Char GISRE2SELHORMAC
If dim([M:SRE9]HDTISSQTY) > 1 Then
  Global Decimal GSRE9HDTISSISS(dim([M:SRE9]HDTISSQTY))
  Global Integer GSRE9DIRTYISSISS(dim([M:SRE9]HDTISSQTY))
Else
  Global Decimal GSRE9HDTISSISS
  Global Integer GSRE9DIRTYISSISS
Endif
Global Char GSREHTRNUM
Global Char GSRE0NUMINTIT
Global Char GSRE0PBLINTIT
Global Char GSRE0COVINTIT
Global Char GSRE9PITINTIT

Global Char GSZSREFILGAUFLT(250)(7)
Global Char GSSRENAMESPE(10)(7)
Global Char GBOXSRE(10)
Global Char GBOXSR2(10)
Global Char GBOXSRESP1(10)
Global Char GBOXSRESP2(10)
Global Char GBOXSRESP3(10)
Global Char GBOXSRESP4(10)
Global Char GBOXSRESP5(10)
Global Char GBOXSRESP6(10)
Global Char GBOXSRESP7(10)

Global Integer GISREHTRUSEMAC
Global Char GSREUDDHDTFLG
Global Char GSREHORAMTFLG
Global Integer GTIMPREVALCTL(3)

Local Char SZSITE(GLONFCY)
Local Integer ITERFLT

  GSZINVNUM = ""   # FGR 07/07/2008 : X3SUIVI48011
  GSZSRE7FOLDTIT = ""
  GSZSRE8FOLDTIT = ""
  GSZSRE9FOLDTIT = ""
  GSREHORAMTFLG = ""
  Raz GTIMPREVALCTL
  GSREUDDHDTFLG = ""
  GISREHTRUSEMAC = 0
  Raz GSZSREFILGAUFLT
  Raz GSSRENAMESPE
  GSRE0NUMINTIT = ""
  GSRE0PBLINTIT = ""
  GSRE0COVINTIT = ""
  GSRE9PITINTIT = ""
  GSREHTRNUM = ""
  GLASOPP = ""
  GLASITN = ""
  GSZSREBPC = ""
  GSZSRENUM = ""
  GSZPRESAT = ""
  GSZPREASS = ""
  GSZSRECXT = ""
  GIPREASS = 0
  GIPREMESS = 0
  GISRECOUNT = 0
  GISRE2TIMFLG = 0
  GISRE2STRDAYCTL = 0
  GISRE2STRSODCTL = 0
  GISRE2TIMSRENUM = ""
  GIHAUTSTRDAYCTL = 0
  GIHAUTSTRSODCTL = 0
  Raz GSRE9HDTISSISS
  Raz GSRE9DIRTYISSISS
  #---- Chargement de GCUR
  Call CHARGE_GCUR() From TRTX3
  Gosub OUVRE_TABLES
  Raz GSOC_ACTIVE
  SZSITE = ""
  Call SITECRMDEF ("HDK", SZSITE) From CRM_UTIL
  GFCY = SZSITE
  Call INIT_GLOBAL_CPT(SZSITE,"HTR",2,GHDKTRSSRE) From TRTX3CPT
  #-----
  GORITITCOL = 1
  #Gestion des sorties de stock
  Gosub SETSTORES From SUBSREB3
  #Chargement des tarifs
  Call TARIFCHGT(5) From TRTPRICE

Global Char     GFOCITMREF
Global Decimal  GFOCQTY
Global Char     GFOCUOM
Global Char     GPNTITMREF
Global Shortint GFOCMOTIF
Global Shortint GFOCFLG
Global Shortint GFOCPRIFLG
Global Integer  GMANCOU12   # FGR 20/12/2012 : X3SUIVI71937

  #------------------------------------------------------------#
  # --> Récupération du code compteur demande de service       #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  Read [TCA]TCA0=12
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(1)
  #  GCSRECPT = [F:TCA]CODNUM(1)
  #  GSR2CSRECPT = [F:TCA]CODNUM(11)
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
  #Renouvellement des garanties à tacite reconduction
  Call REWWARRANTY From SUBCONB2
  #Ouverture des écran nécessaires au calcul des montant facturables des consommations
  # en cas de fin d'horodatage par RAZCRE ou LIENS
  Local Mask SRE0 [SCH0]
  Local Mask SRE2 [SCH2]
  Local Mask SRE7 [SCH7]
  Local Mask SRE9 [SCH9]
  If !GIMPORT Then
    If ITSTPRONUM Then
      #Le contrôle de cohérence des points a échoué.
      GMESSAGE = mess(634,182,1)
      GERR = 2
    Endif
    If IERRINFHD7 Then
      #Le contrôle de cohérence des textes sur consommation a échoué.
      GMESSAGE = mess(908,182,1)
      GERR = 2
    Endif
  Endif
  #Transaction de saisie
  GSREHTRNUM = [F:HTR]HTRNUM
  If [F:HTR]NUMBPCCOD > 2 Then
    Call TEXTE(22063, GSRE0NUMINTIT) From OBJDIV      #Chrono interne
  Else
    Call TEXTE(15988, GSRE0NUMINTIT) From OBJDIV      #105537-v7.2 UI Text Review (Request no.)
#    Call TEXTE(22370, GSRE0NUMINTIT) From OBJDIV      #Chrono interne / client
  Endif
  If [F:HTR]TSREMACFLG = 2 Then
    Call TEXTE(22070, GSRE0PBLINTIT) From OBJDIV      #Famille de compétence globale
    Call TEXTE(22074, GSRE0COVINTIT) From OBJDIV      #Couverture globale
  Else
    Call TEXTE(15566, GSRE0PBLINTIT) From OBJDIV      #Famille de compétence
    Call TEXTE(14572, GSRE0COVINTIT) From OBJDIV      #Couverture
  Endif
  If [F:HTR]TSREHDTFLG = 2 Then
    If [F:HTR]HDTAMTCOD > 2 Then
      Call TEXTE(22384, GSRE9PITINTIT) From OBJDIV  #Gestion des points
    Else
      Call TEXTE(11754, GSRE9PITINTIT) From OBJDIV  #Sous-totaux
    Endif
  Else
    Call TEXTE(22384, GSRE9PITINTIT) From OBJDIV      #Gestion des points
  Endif
  If [F:HTR]TSREMACFLG = 2 Then
    GISREHTRUSEMAC = 1
  Endif
  For ITERFLT = 0 To dim(GSSRENAMESPE)-1
    GSSRENAMESPE(ITERFLT) = [F:HTR]OBJLIS(ITERFLT)
    GSZSREFILGAUFLT(ITERFLT) = [F:HTR]FLTLIS(ITERFLT)
  Next
  #Affectation du titre des onglets
  #Parc
  If [F:HTR]TSREMACFLG = 2 Then
    Call TEXTE(16568, GSZSRE7FOLDTIT) From OBJDIV      #Parc
  Else
    Call TEXTE(22067, GSZSRE7FOLDTIT) From OBJDIV      #Compétence
  Endif
  #Sections analytiques
  If [F:HTR]TSREINVFLG = 2 Then
    Call TEXTE(20717, GSZSRE8FOLDTIT) From OBJDIV      #Eléments facturation
  Else
    Call TEXTE(5266, GSZSRE8FOLDTIT) From OBJDIV       #Sections
  Endif
  #Consommations
  If [F:HTR]TSREHDTFLG = 2 Then
    Call TEXTE(17883, GSZSRE9FOLDTIT) From OBJDIV      #Consommations
  Else
    Call TEXTE(20718, GSZSRE9FOLDTIT) From OBJDIV      #Points
  Endif
  Gosub CHARG_PARAM # FGR 26/07/2013 : X3SUIVI87923 (fin)
Return

##########################################################################################################
$OUVRE_TABLES
  If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
  If !clalev([F:ITG]) : Local File ITMCATEG [ITG] : Endif    : # FGR 18/12/2008 : X3SUIVI51076 Table non ouverte
  If !clalev([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
  If !clalev([F:SOH]) : Local File SORDER [SOH] : Endif
  If !clalev([F:PEC]) : Local File PARESC [PEC] : Endif
  If !clalev([F:ECE]) : Local File ESCSRE [ECE] : Endif
  If !clalev([F:TXC]) : Local File TEXCLOB [TXC] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:CCVA]) : Local File CONTCOV [CCVA] : Endif
