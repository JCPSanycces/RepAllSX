#<AdxTL>@(#)11.0.0.0 $Revision$
# Gestion du masque VISUBOMROU - Visualisation graphique nomenclature multi-niveaux
######################################################################################

$ACTION
Case ACTION
 When "AB2_NBLIG" : Gosub AB2_NBLIG # Avant tunnel vers articles
 When "BB2_NBLIG" : # Apres tunnel vers articles
 When "AB3_NBLIG" : Gosub AB3_NBLIG # avant Cas d'emploi
 When "BB3_NBLIG" : # apres Cas d'emploi
 When "AB4_NBLIG" : Gosub AVANT_NOMP    # avant nomenclature de production
 When "AB7_NBLIG" : Gosub AVANT_NOMS    # avant nomenclature de Sous triatance
 When "AB6_NBLIG" : Gosub AVANT_GAMME   # avant gamme
Endcase
Return

######################################################################################
$AB2_NBLIG
Local Char WCLE1
If [M:VBOR]XITMSST <> "" Then
  WCLE1 = [M:VBOR]XITMSST
Else
  WCLE1 = [M:VBOR]XCPNITMREF
Endif
Return

######################################################################################
$AB3_NBLIG
# action VISUBOMWUS se base sur la ligne courante [F:ITF]
Read [ITF]ITF0=[M:VBOR]GRPITMREF(nolign-1);[M:VBOR]STOFCY
If fstat Raz [F:ITF] Endif
GFONCTION = "VISUBOMROU"
Return

######################################################################################

$AVANT_NOMP
Local Char     WCLE1(GLONITM)
Local Char     WCLE2(15)
Local Integer  NBTBO, WOK

  WCLE1=[M:VBOR]GRPITMREF(nolign-1)
  #   sélectionner les alt. de nomenclature compatibles
  # si décliné par société, il faudra filtrer aussi sur le site
  # MABON - FQ58427 - Ouverture table 
  If clalev([F:TBO])=0 : Local File TABBOMALT [TBO] : Endif
  Filter [TBO] Where [F:TBO]MFGUSE=2 & [F:TBO]BOMALTTYP=2
  For [TBO]TBO0
    WOK = 1
    If WOK  GBOMALT (NBTBO) = [F:TBO]BOMALT     
      NBTBO += 1
    Endif
  Next
#
  Filter [TBO]
  If clalev([F:BOH]) > 0 : Close File [BOH] : Endif
  #  FILTRE sur article parent
  Local File BOM [F:BOH] Where find(BOMALT, GBOMALT) & ITMREF=WCLE1  & BOMALTTYP = 2
  Read [F:BOH]BOH0 First
  WCLE2 = num$([M:VBOR]BOMALT)
  GFONBOD="BOMP"
  GDATEREF=date$
  GFONCTION = "GESBODP"

Return
######################################################################################
$AVANT_NOMS

Local Char     WCLE1(GLONITM)
Local Char     WCLE2(15)
Local Integer  NBTBO, WOK       

  WCLE1=[M:VBOR]GRPITMREF(nolign-1)
  #   sélectionner les alt. de nomenclature compatibles 
  # si décliné par société, il faudra filtrer aussi sur le site
  # MABON - FQ58427 - Ouverture table 
  If clalev([F:TBO])=0 : Local File TABBOMALT [TBO] : Endif
  Filter [TBO] Where [F:TBO]BOMALTTYP=3  
  For [TBO]TBO0     
    WOK = 1
    If WOK  GBOMALT (NBTBO) = [F:TBO]BOMALT     
      NBTBO += 1     
    Endif
  Next       
#
  Filter [TBO]    
  If clalev([F:BOH]) > 0 : Close File [BOH] : Endif  
  #  FILTRE sur article parent
  Local File BOM [F:BOH] Where find(BOMALT, GBOMALT) & ITMREF=WCLE1  & BOMALTTYP = 3
  Read [F:BOH]BOH0 First
#  If !fstat : WCLE2 = num$([F:BOH]BOMALT) : Endif    
  WCLE2 = num$([M:VBOR]BOMALT)
  GFONBOD="BOMS"     
  GDATEREF=date$
  GFONCTION = "GESBODS"
Return

######################################################################################
$AVANT_GAMME
Local Char ALTTAP,WGAMME
Local Integer NBTRO

    If clalev([TRO])> 0 Close File [TRO] Endif
    Local File TABROUALT [TRO] Where BOMALT1=[M:VBOR]BOMALT | BOMALT2=[M:VBOR]BOMALT | BOMALT3=[M:VBOR]BOMALT
#   SÉLECTIONNER LES ALT. DE GAMMES QUI ONT POUR ALT.NOMENCL ASSOCIÉE
#   L'alternative passée en paramètre
    For [TRO]TRO0
        GROUALT (NBTRO) = [F:TRO]ROUALT
        NBTRO += 1
    Next

    # si alternative liée à un site, recherche gamme mère
    # WGAMME = [M:VBOG]PARITMREF
    WGAMME = [M:VBOR]GRPITMREF(nolign-1)
    If clalev([F:TBO])=0 : Local File TABBOMALT [TBO] : Endif
    If [F:TBO]BOMALT <> [M:VBOR]BOMALT | [F:TBO]BOMALTTYP <> [M:VBOR]BOMALTTYP
        Read [TBO]TBO0=[M:VBOR]BOMALTTYP;[M:VBOR]BOMALT
        If fstat : Raz [F:TBO] : Endif
    Endif

    If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
    If [F:ITF]ITMREF <> [M:VBOR]GRPITMREF(nolign-1)
        If [F:TBO]FCY <> ""
            Read [ITF]ITF0=[M:VBOR]GRPITMREF(nolign-1);[F:TBO]FCY
            If fstat : Raz [F:ITF] : Endif
        Else
            Filter [ITF] Where ITMREF = [M:VBOR]GRPITMREF(nolign-1)
            Read [ITF] First
            If fstat : Raz [F:ITF] : Endif
            Filter [ITF]
        Endif
    Endif
    ALTTAP = num$([M]BOMALT)
    If [F:ITF]MFGROU <> ""
        WGAMME = [F:ITF]MFGROU
        ALTTAP = num$([F:ITF]MFGROUALT)
    Endif

    # table réouverte systématiquement pour filtre !
    If [F:TBO]FCY <> ""
        Local File ROUTING [ROH] Where find(ROUALT, val(ALTTAP))<> 0 & ITMREF=WGAMME & FCY = [F:TBO]FCY
    Else
        Local File ROUTING [ROH] Where find(ROUALT, val(ALTTAP))<> 0 & ITMREF=WGAMME
    Endif   
Return

######################################################################################
#Subprog AV_MSTOFCY(VALEUR)
#Variable Char    VALEUR()
#If [M:VBOR]STOFCY = "" : Raz VALEUR : Else : VALEUR = "("+[M]STOFCY+")" : Endif
#End

######################################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()

Call DEF_ROUALT([M:VBOR]PARITMREF,VALEUR)
End

######################################################################################
Subprog AM_PARITMREF(VALEUR)
Variable Char    VALEUR()
  # Lecture composé
  Read [F:ITM]ITM0=VALEUR
  If fstat : End : Endif
  
  Look [F:BOH4]BOH0=VALEUR;[M:VBOR]BOMALT;[M:VBOR]BOMALTTYP
  If fstat > 0 Then
    [M:VBOR]BOMALT = 0
    Affzo [M:VBOR]BOMALT
  Endif
  # [M:VBOR]BOMSTU  = [F:ITM1]STU : ## GH 07/03/2013 bug 88514
  Call DEF_ROUALT(VALEUR,[M:VBOR]STOFCY)
End

######################################################################################
Subprog DEF_ROUALT(LITM, LFCY)
Value Char LITM()
Value Char LFCY()

If LITM="" | LFCY="" : End : Endif

If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
Read [ITF]ITF0 = LITM ; LFCY
If !fstat & [F:ITF]MFGROUALT<>0
   [M:VBOR]ROUALT = [F:ITF]MFGROUALT : Affzo [VBOR]ROUALT
Endif
End

######################################################################################
Subprog AS_NBLIG
Local Integer NOL
NOL = nolign-1
Effzo [M:VBOR]27, 30 : # Effzo [M:VBOR]30 : # GH 29/09/11 bug 76687
If NOL>0
   Gosub CHARGE_BOD From VISUBOMROU
Else
   Gosub CHARGE_BOH From VISUBOMROU
Endif
End

######################################################################################
Subprog AS_XCPNITMREF(VALEUR)
Variable Char     VALEUR
mkstat=2
End

######################################################################################
Subprog IB_NBLIG
Local Integer  NBTBO
Local Integer NOBOM
Local Integer OITF,OPNROH

  # MABON - FQ58427 - Ouverture table 
  If clalev([F:TBO])=0 : Local File TABBOMALT [TBO] : Endif
  Filter [TBO] Where [F:TBO]MFGUSE=2 & [F:TBO]BOMALTTYP = [M:VBOR] BOMALTTYP & find ([F:TBO] FCY,"", [M:VBOR] STOFCY) 
    For [TBO] TBO0
      GBOMALT(NBTBO)=[F:TBO]BOMALT
    Next
    NBTBO = rowcount([TBO])
  Filter [TBO]
  If !clalev([BOH2]) Local File BOM [BOH2] Endif
  Read [F:BOH2] BOH0 = [M:VBOR]PARITMREF;[M:VBOR]BOMALT;[M:VBOR]BOMALTTYP
  If !func VISUBOMG.HAS_NOMP([M:VBOR]GRPITMREF(nolign-1),[M:VBOR]BOMALT)or clalev([M:BOD1]) > 0 Then
     NOBOM = 1
  Endif      
  Look [F:BOH2]BOH0 = [M:VBOR]GRPITMREF(nolign-1);[M:VBOR]BOMALT;3
  If fstat > 0 or clalev([M:BOD1]) > 0  Then
    GBOUT7 = ""
  Endif
  #Si on est sur un poste de charge ou si c'est un composant de type Texte
  If [M:VBOR]WST(nolign-1)<> "" Then
    If [M:VBOR]XLIB = mess(245,190,1) Then
      GBOUT3 = ""                  # Cas d'emploi 
      GBOUT4 = ""                  # Nomenclature Prod 
      GBOUT5 = ""                  # Stock par site 
      GBOUT6 = ""                  # Gamme 
      GBOUT7 = ""                  # Nomenclature Sst
    Else
      GBOUT2 = ""                  # Article 
      GBOUT3 = ""                  # Cas d'emploi 
      GBOUT4 = ""                  # Nomenclature Prod 
      GBOUT5 = ""                  # Stock par site 
      GBOUT6 = ""                  # Gamme 
      GBOUT7 = ""                  # Nomenclature Sst
    Endif
  Endif
  #si c'est un composant de type Texte, on enlève tous les boutons
  If  [M:VBOR]XCPNTYP =5 Then
    GBOUT2 = ""                  # Article 
    GBOUT3 = ""                  # Cas d'emploi 
    GBOUT4 = ""                  # Nomenclature Prod 
    GBOUT5 = ""                  # Stock par site 
    GBOUT6 = ""                  # Gamme 
    GBOUT7 = ""                  # Nomenclature Sst   
  Endif
  If [M:VBOR]XCPNTYP = 4 or NOBOM = 1 Then  #si le type de composé est un sous produit, on ne remonte pas sur les nomenclatures
    GBOUT4 = ""
  Endif
  If NOBOM = 0 :  Close File [BOH2] : Endif
  If !clalev([ROH]) Then OPNROH =1 : Local File ROUTING [F:ROH] : Endif
  # on regarde si la gamme existe
  Look [F:ROH]ROH0 = [M:VBOR]GRPITMREF(nolign-1);[M:VBOR]BOMALT;[M:VBOR]STOFCY
  If fstat > 0 Then
    #si elle n'existe pas on cherche la gamme mère
    # FQ60780 - MABON 10/12/09 - Pour chercher la gamme mère, il faut se placer sur l'enregistrement de ITF relatif à la ligne en cours
    Read [ITF]ITF0=[M:VBOR]GRPITMREF(nolign-1);[M:VBOR]STOFCY
    Look [F:ROH]ROH0 = [F:ITF]MFGROU;[F:ITF]MFGROUALT;[M:VBOR]STOFCY
    If fstat > 0 Then
      GBOUT6 = ""
    Endif
  Endif
  If [M:VBOR]OPENUM(nolign-1) <> 0 Then
    GBOUT2 = ""
    GBOUT3 = ""
    GBOUT5 = ""
    GBOUT6 = ""
  Endif
  If find("CASNOMENP", GNAVIG(1..GPILNAV-1)) Then
    GBOUT3=""
  Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUBOMROU) 09/10/2008 11:04:35 (STANT)
######################################################################################
Subprog AS_BOMALTTYP(VALEUR)
Variable Integer VALEUR
  GMENLOC(1)=1
  GMENLOC(3)=1 
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUBOMROU) 09/10/2008 11:55:01 (STANT)
######################################################################################
Subprog AS_PARITMREF(VALEUR)
Variable Char    VALEUR()

  Case BOMALTTYP
    When  2: [M:VBOR]OPTION_ITM = "C" : # Sélection des articles fabriqués
      [M:VBOR]FILTRE     = "MFGFLG=2" : # Article fabriqué
      [M:VBOR]OPTIONA    = "B"
      GFONBOD            = "BOMP" 
    When 3: [M:VBOR]OPTION_ITM = "D" : # Sélection des articles sous-traités
      [M:VBOR]FILTRE     = "SCPFLG=2" : # Article sous-traité
      [M:VBOR]OPTIONA    = "D"
      GFONBOD            = "BOMS"  
  Endcase
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUBOMROU) 09/10/2008 16:50:03 (STANT)
######################################################################################
Subprog AP_BOMALTTYP(VALEUR)
Variable Integer VALEUR

  If VALEUR <> [M:VBOR]BOMALTTYP Then
    Case VALEUR
      When 2 : GFONBOD = "BOMP"
      When 3 : GFONBOD = "BOMS"
    Endcase

    Filter[BOH4] Where BOMALTTYP = VALEUR 
    [M:VBOR]PARITMREF = ""
    [M:VBOR]BOMALT = 0
    Affzo [M:VBOR]PARITMREF,BOMALT
  Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUBOMROU) 13/10/2008 10:03:16 (STANT)
######################################################################################
Subprog C_PARITMREF(VALEUR)
Variable Char    VALEUR()
  Look [F:BOH1]BOH0(1) = VALEUR
  If fstat >=2 Then
     GERR=1
     GMESSAGE=mess(40,7750,1)  # article non conforme
     mkstat=2
  Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUBOMROU) 13/11/2008 17:17:26 (STANT)
######################################################################################
Subprog IB_PARITMREF
# on bloque le tunnel si l'on vient des articles ou des articles site  
  If GPILNAV > 1 Then
    If find(GNAVIG(GPILNAV-1),"GESITM") or find(GNAVIG(GPILNAV),"GESITM") Then
      GBOUT1 = ""
    Endif
  Endif
End


