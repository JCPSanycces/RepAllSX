[L]DCLFLD = "023" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]              # Field 23  - Imp. F.S.P - Imp...Ded. Existencia Taxa Intermédia
[L]DCLFLD = "022" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]              # Field 22  - Imp. F.S.P - Imp...Ded. Existencia Taxa Normal
[L]DCLFLD = "024" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]              # Field 24  - Imp. F.S.P - Imp...Ded. Others Bens e Serviços
[L]DCLFLD = "063" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]              # Field 63  - Imp. F.S.P - Total de Imposto a Favor do Sujeito Passivo
[L]DCLFLD = "002" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]              # Field 2  - Imp. a Favor do Estado - Trans. Bens e Prest. Serviços à Taxa Reduzida
[L]DCLFLD = "006" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]              # Field 6  - Imp. a Favor do Estado - Trans. Bens e Prest. Serviços à Taxa Intermédia
[L]DCLFLD = "004" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]              # Field 4  - Imp. a Favor do Estado - Trans. Bens e Prest. Serviços à Taxa Normal
[L]DCLFLD = "011" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]              # Field 11 - Imp. a Favor do Estado - Aquisições. Intra. Bens e Op. Assimiladas
Wrseq format$("K:11X","")                Using [VATF]              # Filler of 11 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT += 1

#----- Annex detail 12 -----#
Wrseq format$("K:02X","12")                   ; Using [VATF]              # Record type
Wrseq format$("N0:01",[L]ANRLOC)              ; Using [VATF]              # Declaração dos Azores = 2
[L]DCLFLD = "064" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)        ; Using [VATF]              # Field 64 - Total de Imposto a Favor do Estado
If [F:DVPH]AUTBAL = 2
  Wrseq format$("N0:01",1)                    ; Using [VATF]              # Existiram operações no Field 264 se sim =1 se não =0
  Wrseq format$("N0:01",0)                    ; Using [VATF]              # Se não Existiram operações no Field 264 se sim=2 se não =0
Else
  Wrseq format$("N0:01",0)                    ; Using [VATF]              # Existiram operações no Field 264 se sim =1 se não =0
  Wrseq format$("N0:01",2)                    ; Using [VATF]              # Se não Existiram operações no Field 264 se sim=2 se não =0
Endif
Wrseq format$("N0:12",0)                      ; Using [VATF]              # Por defeito esta coluna é nula em caso de existirem valores a considerar deverão ser modificados pelo uilizador manualmente
Wrseq format$("K:105X","")                      Using [VATF]              # Filler of 105 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT += 1

#----- Annex detail 32 -----#
Wrseq format$("K:02X","32")            ; Using [VATF]             # Record type
Wrseq format$("N0:01",[L]ANRLOC)       ; Using [VATF]             # Declaração dos Madeira = 3
[L]DCLFLD = "012" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 12  - B.T. Aquisições Intra bens e op assimil. - Imp. liquidado pelo declarante
[L]DCLFLD = "014" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 14  - B.T. Aquisições Intra bens e op assimil. - abrangidas pelo 15º CIVA / RITI
[L]DCLFLD = "015" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 15  - B.T. Aquisições Intra bens e op assimil. - abrangidas pelo nº 3,4 e 5 do 22º do RITI
[L]DCLFLD = "016" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 16  - B.T. Prestações de serviçoes efectuadas po SP de outras EM cujo imp. foi liquidado pelo declarante
[L]DCLFLD = "013" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 13  - Imp. F.E - Imp.liquidado pelo declarante
[L]DCLFLD = "017" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 17  - Imp. F.E - Prestações de serviços efectuadas por SP de outeros EM cujo Imp.liquidado pelo declarante
Wrseq format$("K:59X","")                Using [VATF]             # Filler of 59 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT += 1

#----- Annex detail 33 -----#
Wrseq format$("K:02X","33")            ; Using [VATF]             # Record type
Wrseq format$("N0:01",[L]ANRLOC)       ; Using [VATF]             # Declaração dos Madeira = 3
[L]DCLFLD = "065" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 65  - A-Efectuadas por entidades residentes em países comunitários (não inclui operações mencionadas no Field 16)
[L]DCLFLD = "066" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 66  - A-Efectuadas por entidades residentes em países ou territórios terceiros
[L]DCLFLD = "067" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 67  - B-Ouro (Decreto-Lei 362/99)
[L]DCLFLD = "068" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 68  - B-Aquisições de imóveis com renúncia à isenção (Decreto-Lei 21/2007)
[L]DCLFLD = "069" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 69  - B-Sucatas [Alínea l) do n.º 1 do art.º 2.º do CIVA]
[L]DCLFLD = "070" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 70  - B-Serviços de construção civil [Alínea j) do n.º 1 do art.º 2.º do CIVA]
[L]DCLFLD = "071" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 71  - C- Se efectuou operações desta natureza, indique o seu valor i 21/2007)
[L]DCLFLD = "072" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 72  - D-Se efectuou operações desta natureza, indique o seu valor
[L]DCLFLD = "073" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 73  - sum
Wrseq format$("K:59X","")                Using [VATF]             # Filler of 23 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT += 1

#----- End of Annex 13 -----#
[L]DCLFLD = "062" : Gosub READ_FLD_VAL
TMPTOTAN = [F:DVPF]AMT
[L]DCLFLD = "063" : Gosub READ_FLD_VAL
TMPTOTAN += [F:DVPF]AMT
[L]DCLFLD = "064" : Gosub READ_FLD_VAL
TMPTOTAN += [F:DVPF]AMT

Wrseq format$("K:02X","13")                 ; Using [VATF]         # Record type
Wrseq format$("N0:01",[L]ANRLOC)            ; Using [VATF]         # Declaração dos Azores = 2
Wrseq format$("N0:03",[L]DETRECCOUNT)       ; Using [VATF]         # Nº of records
Wrseq format$("N0:13",[L]TMPTOTAN)          ; Using [VATF]         # Total of Fields 62+63+64
Wrseq format$("K:115X","")                    Using [VATF]         # Filler of 115 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration

Return
######################################################################################
######################################################################################
$EXPORT_ANNEX_I

#----- Annex I header -----#
Wrseq format$("K:02X","20")                          ; Using [VATF]      # Record type
Wrseq format$("N0:09",ctrans([F:CPY]EECNUM,"PT","")) ; Using [VATF]      # Company EECNUM
Wrseq format$("N0:04",[F:DVPH]DCLYEA)                ; Using [VATF]      # Year (AAAA)
Wrseq format$("K<:3X",[F:DVPH]FPERIOD)               ; Using [VATF]      # Period (month or trim.)
Wrseq format$("K:116X","")                             Using [VATF]      # Filler of 116 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT  = 0

#----- Annex I detail -----#
For [F:DVPL] Where DCLNUM = [F:DVPH]DCLNUM & LINTYP = 11
  If [F:DVPL]AMTBAS>0
    [L]SNSC ="+"
  Else
    [L]SNSC ="-"
  Endif
  Wrseq format$("K:02X","21")                       ; Using [VATF]              # Record type
  Wrseq format$("N0:05",[F:DVPL]LSTLIN)             ; Using [VATF]              # Nº Linha
  If [F:DVPL]CRY = "GR"
    Wrseq format$("K:02X","EL")                     ; Using [VATF]              # Pais do Terceiro
  Else
    Wrseq format$("K:02X",[F:DVPL]CRY)              ; Using [VATF]              # Pais do Terceiro
  Endif
  If [F:DVPL]CRY <> "" & pat([F:DVPL]EECNUM,[F:DVPL]CRY+"*")
    Wrseq format$("K:12X",right$([F:DVPL]EECNUM,len([F:DVPL]CRY)+1))             ; Using [VATF]              # NIF do Terceiro
  Else
    Wrseq format$("K:12X",[F:DVPL]EECNUM)             ; Using [VATF]              # NIF do Terceiro
  Endif
  Wrseq [L]SNSC+format$("N0:12",[F:DVPL]AMTBAS*100) ; Using [VATF]              # Montante da Transacção
  Wrseq format$("N0:1",[F:DVPL]OPETYP)              ; Using [VATF]             # Indicador do tipo de Operação
  Wrseq format$("K:99X","")                           Using [VATF]              # Filler of 99 spaces

  [L]FILRECCOUNT += 1 #Nº of lines on the file
  [L]DCLRECCOUNT += 1 #Nº of lines on the declaration
  [L]DETRECCOUNT += 1
Next

#----- End of Annex I -----#
Wrseq format$("K:02X","22")                         ; Using [VATF]              # Record type
Wrseq format$("N0:05",[L]DETRECCOUNT)               ; Using [VATF]              # Nº of records
[L]DCLFLD = "010" : Gosub READ_FLD_VAL
If [F:DVPF]AMT>=0
  [L]SNSC = "+"
Else
  [L]SNSC = "-"
Endif
Wrseq [L]SNSC+format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Oper. Tipificadas na coluna 5 como sendo 1
[L]DCLFLD = "011" : Gosub READ_FLD_VAL
If [F:DVPF]AMT>=0
  [L]SNSC = "+"
Else
  [L]SNSC = "-"
Endif
Wrseq [L]SNSC+format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Total das Vendas de Meios de Transporte novos a particulares e equiparados de Others estados membros
Wrseq format$("K:101X","")                            Using [VATF]              # Filler of 101 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration

Return
######################################################################################
######################################################################################
$EXPORT_ANNEX_1

#----- Annex 1 header -----#
Wrseq format$("K:02X","40")                          ; Using [VATF]              # Record type
Wrseq format$("N0:04",[F:DVPH]DCLYEA)                ; Using [VATF]              # Year (AAAA)
Wrseq format$("K<:3X",[F:DVPH]FPERIOD)               ; Using [VATF]              # Period (month or trim.)
Wrseq format$("N0:09",ctrans([F:CPY]EECNUM,"PT","")) ; Using [VATF]              # Company EECNUM
Wrseq format$("N0:04",[L]MDCLYEA)                    ; Using [VATF]              # Year (AAAA)
Wrseq format$("K<:3X",[L]MFPERIOD)                   ; Using [VATF]              # Period (month or trim.)
Wrseq format$("K:109X","")                             Using [VATF]              # Filler of 109 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT  = 0

#----- Annex 1 detail -----#
For [F:DVPL] Where [F:DVPL]DCLNUM = [F:DVPH]DCLNUM & [F:DVPL]LINTYP = 1
  Wrseq format$("K:02X","41")                           ; Using [VATF]              # Record type
  Wrseq format$("N0:04",[F:DVPH]DCLYEA)                 ; Using [VATF]              # Year (AAAA)
  Wrseq format$("K<:3X",[F:DVPH]FPERIOD)                ; Using [VATF]              # Period (month or trim.)
  Wrseq format$("N0:05",[F:DVPL]LSTLIN)                 ; Using [VATF]              # Nº Linha
  Wrseq format$("N0:09",ctrans([F:DVPL]EECNUM,"PT","")) ; Using [VATF]              # NIF do Terceiro
  Wrseq format$("N0:12",[F:DVPL]AMTBAS*100)             ; Using [VATF]              # Montante da Transacção
  Wrseq format$("K:99X","")                               Using [VATF]              # Filler of 99 spaces

  [L]FILRECCOUNT += 1 #Nº of lines on the file
  [L]DCLRECCOUNT += 1 #Nº of lines on the declaration
  [L]DETRECCOUNT += 1
Next

For [F:DVPL] Where [F:DVPL]DCLNUM = [F:DVPH]DCLNUM & [F:DVPL]LINTYP = 2
  Wrseq format$("K:02X","42")                 ; Using [VATF]              # Record type
  Wrseq format$("N0:04",[F:DVPH]DCLYEA)       ; Using [VATF]              # Year (AAAA)
  Wrseq format$("K<:3X",[F:DVPH]FPERIOD)      ; Using [VATF]              # Period (month or trim.)
  Wrseq format$("N0:05",[F:DVPL]LSTLIN)       ; Using [VATF]              # Nº Linha
  Wrseq format$("K<:20X",[F:DVPL]VCRNUM)      ; Using [VATF]              # Nº da Declaração de Exportação
  Wrseq format$("N0:12",[F:DVPL]AMTBAS*100)   ; Using [VATF]              # Montante da Transacção
  Wrseq format$("K:88X","")                     Using [VATF]              # Filler of 99 spaces

  [L]FILRECCOUNT += 1 #Nº of lines on the file
  [L]DCLRECCOUNT += 1 #Nº of lines on the declaration
  [L]DETRECCOUNT += 1
Next

#----- End of Annex 1 -----#
Wrseq format$("K:02X","49")                   ; Using [VATF]              # Record type
Wrseq format$("N0:04",[F:DVPH]DCLYEA)         ; Using [VATF]              # Year (AAAA)
Wrseq format$("K<:3X",[F:DVPH]FPERIOD)        ; Using [VATF]              # Period (month or trim.)
Wrseq format$("N0:09",[L]DETRECCOUNT)         ; Using [VATF]              # Nº of records
Wrseq format$("N0:12",[F:DVPH]FLDAN102*100)   ; Using [VATF]              # Oper. Nacionais de montante inferior a 5000
Wrseq format$("N0:12",[F:DVPH]FLDAN104*100)        ; Using [VATF]              # Oper. Efectuadas no Estrangeiro
Wrseq format$("N0:12",[F:DVPH]FLDAN105*100)        ; Using [VATF]              # Outras Operações Isentas
Wrseq format$("N0:14",[F:DVPH]FLDAN106*100)        ; Using [VATF]              # Total
Wrseq format$("K:66X","")                       Using [VATF]              # Filler of 66 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration

Return
######################################################################################
######################################################################################
$EXPORT_ANNEX_2

#----- Annex 2 header -----#
Wrseq format$("K:02X","50")                          ; Using [VATF]              # Record type
Wrseq format$("N0:04",[F:DVPH]DCLYEA)                ; Using [VATF]              # Year (AAAA)
Wrseq format$("K<:3X",[F:DVPH]FPERIOD)               ; Using [VATF]              # Period (month or trim.)
Wrseq format$("N0:09",ctrans([F:CPY]EECNUM,"PT","")) ; Using [VATF]              # Company EECNUM
Wrseq format$("N0:04",[L]MDCLYEA)                    ; Using [VATF]              # Year (AAAA)
Wrseq format$("K<:3X",[L]MFPERIOD)                   ; Using [VATF]              # Period (month or trim.)
Wrseq format$("K:109X","")                             Using [VATF]              # Filler of 109 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT  = 0

#----- Annex 2 detail -----#
For [F:DVPL] Where [F:DVPL]DCLNUM = [F:DVPH]DCLNUM & find([F:DVPL]LINTYP, 3, 4, 5, 6, 7)
  If [F:DVPL]AMTVAT = 0 & [F:DVPL]AMTBAS = 0 : Goto NEXT_ANNEX_2_LINE : Endif
  Wrseq format$("K:02X",num$(48 + [F:DVPL]LINTYP)) ; Using [VATF]              # Record type
  Wrseq format$("N0:04",[F:DVPH]DCLYEA)            ; Using [VATF]              # Year (AAAA)
  Wrseq format$("K<:3X",[F:DVPH]FPERIOD)           ; Using [VATF]              # Period (month or trim.)
  Wrseq format$("N0:05",[F:DVPL]LSTLIN)            ; Using [VATF]              # Nº Linha
  If [F:DVPL]VCRNUM = ""
    If [F:DVPL]CRY = "GR"
      Wrseq format$("K<:2X","EL")                     ; Using [VATF]              # Pais do Terceiro
    Else
      Wrseq format$("K<:2X",[F:DVPL]CRY)              ; Using [VATF]              # Pais do Terceiro
    Endif
    If ([F:DVPL]CRY <> "" & pat([F:DVPL]EECNUM,[F:DVPL]CRY+"*")) | [F:DVPL]CRY = "RC"
      Wrseq format$("K:12X",right$([F:DVPL]EECNUM,len([F:DVPL]CRY)+1))             ; Using [VATF]              # NIF do Terceiro
    Else
      Wrseq format$("K:12X",[F:DVPL]EECNUM)        ; Using [VATF]              # NIF do Terceiro
    Endif
    Wrseq format$("N0:14","")                      ; Using [VATF]              # Nº da Liquidação
  Else
    Wrseq format$("K:12X","")                      ; Using [VATF]
    Wrseq format$("K<:2X","")                      ; Using [VATF]
    Wrseq format$("N0:14",[F:DVPL]VCRNUM)          ; Using [VATF]              # Nº da Liquidação
  Endif
  Wrseq format$("N0:04",[F:DVPL]YEA)               ; Using [VATF]              # Year (AAAA)
  Wrseq format$("N0:02",[F:DVPL]MON)               ; Using [VATF]              # Year (AAAA)
  Wrseq format$("N0:12",[F:DVPL]AMTBAS*100)        ; Using [VATF]              # Montante da Transacção
  Wrseq format$("N0:12",[F:DVPL]AMTVAT*100)        ; Using [VATF]              # Montante IVA da Transacção
  Wrseq format$("K:62X","")                          Using [VATF]              # Filler of 62 spaces

  [L]FILRECCOUNT += 1 #Nº of lines on the file
  [L]DCLRECCOUNT += 1 #Nº of lines on the declaration
  [L]DETRECCOUNT += 1
  $NEXT_ANNEX_2_LINE
Next

#----- End of Annex 2 -----#
Wrseq format$("K:02X","59")                   ; Using [VATF]              # Record type
Wrseq format$("N0:04",[F:DVPH]DCLYEA)         ; Using [VATF]              # Year (AAAA)
Wrseq format$("K<:3X",[F:DVPH]FPERIOD)        ; Using [VATF]              # Period (month or trim.)
Wrseq format$("N0:09",[L]DETRECCOUNT)         ; Using [VATF]              # Nº of records
Wrseq format$("N0:12",[F:DVPH]FLDAN206B*100)  ; Using [VATF]              # Aquisições de montante inferior a 5000 - Valor Aquisição
Wrseq format$("N0:12",[F:DVPH]FLDAN206V*100)  ; Using [VATF]              # Aquisições de montante inferior a 5000 - IVA Deduzido
Wrseq format$("N0:14",[F:DVPH]FLDAN207B*100)  ; Using [VATF]              # Total Valor Aquisições
Wrseq format$("N0:14",[F:DVPH]FLDAN207V*100)  ; Using [VATF]              # Total IVA Deduzido
Wrseq format$("K:64X","")                       Using [VATF]              # Filler of 64 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration

Return
######################################################################################
######################################################################################
$EXPORT_ANNEX_3

#----- Annex 3 header -----#
Wrseq format$("K:02X","70")                           ; Using [VATF]      # Record type
Wrseq format$("N0:04",[F:DVPH]DCLYEA)                 ; Using [VATF]      # Year (AAAA)
Wrseq format$("K<:3X",[F:DVPH]FPERIOD)                ; Using [VATF]      # Period (month or trim.)
Wrseq format$("N0:09",ctrans([F:CPY]EECNUM,"PT",""))  ; Using [VATF]      # Company EECNUM
Wrseq format$("N0:04",[L]MDCLYEA)                     ; Using [VATF]      # Year (AAAA)
Wrseq format$("K<:3X",[L]MFPERIOD)                    ; Using [VATF]      # Period (month or trim.)
Wrseq format$("K:109X","")                              Using [VATF]      # Filler of 109 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT  = 0

#----- Annex 3 detail -----#
For [F:DVPL] Where [F:DVPL]DCLNUM = [F:DVPH]DCLNUM & [F:DVPL]LINTYP = 8
  If [F:DVPL]AMTVAT = 0 & [F:DVPL]AMTBAS = 0 : Goto NEXT_ANNEX_3_LINE : Endif
  Wrseq format$("K:02X","71")                               ; Using [VATF]    # Record type
  Wrseq format$("N0:04",[F:DVPH]DCLYEA)                     ; Using [VATF]    # Year (AAAA)
  Wrseq format$("K<:3X",[F:DVPH]FPERIOD)                    ; Using [VATF]    # Period (month or trim.)
  Wrseq format$("N0:05",[F:DVPL]LSTLIN)                     ; Using [VATF]    # line number
  Wrseq format$("K<:9X",ctrans([F:DVPL]EECNUM,"PT",""))     ; Using [VATF]    # EECNUM
  Wrseq format$("N0:04",[F:DVPL]YEA)                        ; Using [VATF]    # Year (AAAA)
  Wrseq format$("N0:02",[F:DVPL]MON)                        ; Using [VATF]    # Year (AAAA)
  Wrseq format$("N0:12",[F:DVPL]AMTBAS*100)                 ; Using [VATF]    # transaction amount
  Wrseq format$("N0:12",[F:DVPL]AMTVAT*100)                 ; Using [VATF]    # VAT amount
  Wrseq format$("K:81X","")                                   Using [VATF]    # Filler of 81 spaces

  [L]FILRECCOUNT += 1 #Nº of lines on the file
  [L]DCLRECCOUNT += 1 #Nº of lines on the declaration
  [L]DETRECCOUNT += 1
  $NEXT_ANNEX_3_LINE
Next

#----- End of Annex 3 -----#
Wrseq format$("K:02X","79")                  ; Using [VATF]              # Record type
Wrseq format$("N0:04",[F:DVPH]DCLYEA)        ; Using [VATF]              # Year (AAAA)
Wrseq format$("K<:3X",[F:DVPH]FPERIOD)       ; Using [VATF]              # Period (month or trim.)
Wrseq format$("N0:09",[L]DETRECCOUNT)        ; Using [VATF]              # Nº of records
Wrseq format$("N0:12",[F:DVPH]FLDAN302*100)  ; Using [VATF]              # Base - below limit
Wrseq format$("N0:12",[F:DVPH]FLDAN303*100)  ; Using [VATF]              # VAT - below limit
Wrseq format$("N0:12",[F:DVPH]FLDAN304*100)  ; Using [VATF]              # Base - pro-rata - below limit
Wrseq format$("N0:12",[F:DVPH]FLDAN305*100)  ; Using [VATF]              # VAT - pro-rata - below limit
Wrseq format$("N0:12",[F:DVPH]FLDAN306*100)  ; Using [VATF]              # Base - other - below limit
Wrseq format$("N0:12",[F:DVPH]FLDAN307*100)  ; Using [VATF]              # Base - other - below limit
Wrseq format$("N0:14",[F:DVPH]FLDAN308*100)  ; Using [VATF]              # Total - Base
Wrseq format$("N0:14",[F:DVPH]FLDAN309*100)  ; Using [VATF]              # Total - VAT
Wrseq format$("K:16X","")                      Using [VATF]              # Filler of 16 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration

Return
######################################################################################
######################################################################################
$EXPORT_ANNEX_40

#----- Annex 40 header -----#
Wrseq format$("K:02X","60")            ; Using [VATF]              # Record type
Wrseq format$("N0:04",[F:DVPH]DCLYEA)  ; Using [VATF]              # Year (AAAA)
Wrseq format$("K<:3X",[F:DVPH]FPERIOD) ; Using [VATF]              # Period (month or trim.)
Wrseq format$("N0:09",ctrans([F:CPY]EECNUM,"PT",""))  ; Using [VATF]              # Company EECNUM
Wrseq format$("K:116X","")               Using [VATF]              # Filler of 116 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT  = 0

#----- Annex 40 detail -----#
Filter [F:DVPL] Where [F:DVPL]DCLNUM = [F:DVPH]DCLNUM & [F:DVPL]LINTYP = 9 & [F:DVPL]FLD40REN <> "" Order By FLD40REN
For [F:DVPL]
  If [F:DVPL]AMTVAT = 0 & [F:DVPL]AMTBAS = 0 : Goto NEXT_ANNEX_40_LINE : Endif
  [L]QUADRO40 = func GET_Q40([F:DVPL]FLD40REN)
  [L]RECTYP40 = func GET_RECTYP40([L]QUADRO40)
  Wrseq format$("K:02X",[L]RECTYP40)                      ; Using [VATF]         # Record type
  Wrseq format$("N0:05",[F:DVPL]LSTLIN)                   ; Using [VATF]         # line number
  Wrseq format$("K:02X",func GET_COD40([F:DVPL]FLD40REN)) ; Using [VATF]         # Artigo
  If find([L]RECTYP40,"61","62","63","64","65")
    If pat([F:DVPL]EECNUM,"PT*")
      Wrseq format$("K<:9X",right$([F:DVPL]EECNUM,3))     ; Using [VATF]         # EECNUM
    Else
      Wrseq format$("K<:9X",[F:DVPL]EECNUM)               ; Using [VATF]         # EECNUM
    Endif
    Wrseq format$("N0:12",[F:DVPL]AMTBAS*100)             ; Using [VATF]         # transaction amount
    Wrseq format$("N0:12",[F:DVPL]AMTVAT*100)             ; Using [VATF]         # VAT amount
    Wrseq format$("K:92X","")                               Using [VATF]
  Else
    Wrseq format$("K:13X","")                             ; Using [VATF]
    Wrseq format$("N0:12",[F:DVPL]AMTVAT*100)             ; Using [VATF]         # VAT amount
    Wrseq format$("K:100X","")                              Using [VATF]
  Endif

  [L]FILRECCOUNT += 1 #Nº of lines on the file
  [L]DCLRECCOUNT += 1 #Nº of lines on the declaration
  [L]DETRECCOUNT += 1
  Assign "AN40RECCOUNT"+right$([L]RECTYP40,2) With evalue("AN40RECCOUNT"+right$([L]RECTYP40,2))+1
  $NEXT_ANNEX_40_LINE
Next
Filter [F:DVPL]

Wrseq format$("K:02X","68")                      ; Using [VATF]              # Record type
Wrseq format$("N0:12",[F:DVPH]FLDAN4003*100)     ; Using [VATF]              # >750
Wrseq format$("N0:12",[F:DVPH]FLDAN4004*100)     ; Using [VATF]              # >750
Wrseq format$("N0:12",[F:DVPH]FLDAN4003A*100)    ; Using [VATF]              # 23 to 26
Wrseq format$("N0:12",[F:DVPH]FLDAN4004A*100)    ; Using [VATF]              # 23 to 26
Wrseq format$("N0:12",[F:DVPH]FLDAN4003B*100)    ; Using [VATF]              # other regimes
Wrseq format$("N0:12",[F:DVPH]FLDAN4004B*100)    ; Using [VATF]              # other regimes
Wrseq format$("N0:12",[L]TMPAMT40*100)           ; Using [VATF]              # total field 40
Wrseq format$("K:48X","")                          Using [VATF]              # Filler

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT += 1


#----- End of Annex 40 -----#
Wrseq format$("K:02X","69")                       ; Using [VATF]              # Tipo de Registo
Wrseq format$("N0:05",AN40RECCOUNT1)              ; Using [VATF]              # Nº de Registos
Wrseq format$("N0:05",AN40RECCOUNT2)              ; Using [VATF]              # Nº de Registos
Wrseq format$("N0:05",AN40RECCOUNT3)              ; Using [VATF]              # Nº de Registos
Wrseq format$("N0:05",AN40RECCOUNT4)              ; Using [VATF]              # Nº de Registos
Wrseq format$("N0:05",AN40RECCOUNT5)              ; Using [VATF]              # Nº de Registos
Wrseq format$("N0:05",AN40RECCOUNT6)              ; Using [VATF]              # Nº de Registos
Wrseq format$("N0:05",AN40RECCOUNT7)              ; Using [VATF]              # Nº de Registos
Wrseq format$("N0:05",AN40RECCOUNT9)              ; Using [VATF]              # Nº de Registos
Wrseq format$("K:92X","")                           Using [VATF]

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration

Return
######################################################################################
######################################################################################
$EXPORT_ANNEX_41

#----- Annex 41 header -----#
Wrseq format$("K:02X","80")            ; Using [VATF]              # Record type
Wrseq format$("N0:04",[F:DVPH]DCLYEA)  ; Using [VATF]              # Year (AAAA)
Wrseq format$("K<:3X",[F:DVPH]FPERIOD) ; Using [VATF]              # Period (month or trim.)
Wrseq format$("N0:09",ctrans([F:CPY]EECNUM,"PT",""))  ; Using [VATF]              # Company EECNUM
Wrseq format$("K:116X","")               Using [VATF]              # Filler of 116 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT  = 0

#----- Annex 41 detail -----#
Filter [F:DVPL] Where [F:DVPL]DCLNUM = [F:DVPH]DCLNUM & [F:DVPL]LINTYP = 10 & [F:DVPL]FLD41REN <> "" Order By FLD41REN
For [F:DVPL]
  If [F:DVPL]AMTVAT = 0 & [F:DVPL]AMTBAS = 0 : Goto NEXT_ANNEX_41_LINE : Endif
  [L]QUADRO41 = func GET_Q41([F:DVPL]FLD41REN)
  [L]RECTYP41 = func GET_RECTYP41([L]QUADRO41)
  Wrseq format$("K:02X",[L]RECTYP41)                      ; Using [VATF]         # Record type
  Wrseq format$("N0:05",[F:DVPL]LSTLIN)                   ; Using [VATF]         # line number
  Wrseq format$("K:02X",func GET_COD41([F:DVPL]FLD41REN)) ; Using [VATF]         # Artigo
  If find([L]RECTYP41,"81","82","83","84")
    If pat([F:DVPL]EECNUM,"PT*")
      Wrseq format$("K<:9X",right$([F:DVPL]EECNUM,3))     ; Using [VATF]         # EECNUM
    Else
      Wrseq format$("K<:9X",[F:DVPL]EECNUM)               ; Using [VATF]         # EECNUM
    Endif
    Wrseq format$("N0:12",[F:DVPL]AMTBAS*100)             ; Using [VATF]         # transaction amount
    Wrseq format$("N0:12",[F:DVPL]AMTVAT*100)             ; Using [VATF]         # VAT amount
    Wrseq format$("K:92X","")                               Using [VATF]
  Elsif [L]RECTYP41 = "85"
    Wrseq format$("K<:9X",[F:DVPL]EECNUM)                 ; Using [VATF]         # EECNUM
    Wrseq format$("K:13X","")                             ; Using [VATF]         #
    Wrseq format$("N0:12",[F:DVPL]AMTVAT*100)             ; Using [VATF]         # VAT amount
    Wrseq format$("K:91X","")                               Using [VATF]
  Elsif [L]RECTYP41 = "86"
    Wrseq format$("K<:9X",[F:DVPL]EECNUM)                 ; Using [VATF]         # EECNUM
    Wrseq format$("K:13X","")                             ; Using [VATF]
    Wrseq format$("N0:12",[F:DVPL]AMTBAS*100)             ; Using [VATF]         # transaction amount
    Wrseq format$("N0:12",[F:DVPL]AMTVAT*100)             ; Using [VATF]         # VAT amount
    Wrseq format$("K:79X","")                              Using [VATF]
  Endif

  [L]FILRECCOUNT += 1 #Nº of lines on the file
  [L]DCLRECCOUNT += 1 #Nº of lines on the declaration
  [L]DETRECCOUNT += 1
  Assign "AN41RECCOUNT"+right$([L]RECTYP41,2) With evalue("AN41RECCOUNT"+right$([L]RECTYP41,2))+1
  $NEXT_ANNEX_41_LINE
Next
Filter [F:DVPL]

Wrseq format$("K:02X","87")                      ; Using [VATF]              # Record type
Wrseq format$("N0:12",[F:DVPH]FLDAN4103A*100)    ; Using [VATF]              # 23 to 26
Wrseq format$("N0:12",[F:DVPH]FLDAN4104A*100)    ; Using [VATF]              # 23 to 26
Wrseq format$("N0:12",[F:DVPH]FLDAN4103B*100)    ; Using [VATF]              # other regimes
Wrseq format$("N0:12",[F:DVPH]FLDAN4104B*100)    ; Using [VATF]              # other regimes
Wrseq format$("N0:12",[L]TMPAMT41*100)           ; Using [VATF]              # total field 41
Wrseq format$("K:72X","")                          Using [VATF]              # Filler

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT += 1


#----- End of Annex 41 -----#
Wrseq format$("K:02X","89")                       ; Using [VATF]              # Tipo de Registo
Wrseq format$("N0:05",AN41RECCOUNT1)              ; Using [VATF]              # Nº de Registos
Wrseq format$("N0:05",AN41RECCOUNT2)              ; Using [VATF]              # Nº de Registos
Wrseq format$("N0:05",AN41RECCOUNT3)              ; Using [VATF]              # Nº de Registos
Wrseq format$("N0:05",AN41RECCOUNT4)              ; Using [VATF]              # Nº de Registos
Wrseq format$("N0:05",AN41RECCOUNT5)              ; Using [VATF]              # Nº de Registos
Wrseq format$("N0:05",AN41RECCOUNT6)              ; Using [VATF]              # Nº de Registos
Wrseq format$("K:102X","")                          Using [VATF]

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration

Return
######################################################################################
######################################################################################
$DEC_EXP_VARS

If !clalev([F:DVPH1]) : Local File DCLVATPORH [DVPH1] : Endif
If !clalev([F:DVPP])  : Local File DCLVATPORP [DVPP]  : Endif
If !clalev([F:CPY])   : Local File COMPANY    [CPY]   : Endif

Local Integer  DETRECCOUNT
Local Integer  DCLRECCOUNT
Local Integer  FILRECCOUNT
Local Integer  AN40RECCOUNT1
Local Integer  AN40RECCOUNT2
Local Integer  AN40RECCOUNT3
Local Integer  AN40RECCOUNT4
Local Integer  AN40RECCOUNT5
Local Integer  AN40RECCOUNT6
Local Integer  AN40RECCOUNT7
Local Integer  AN40RECCOUNT9
Local Integer  AN41RECCOUNT1
Local Integer  AN41RECCOUNT2
Local Integer  AN41RECCOUNT3
Local Integer  AN41RECCOUNT4
Local Integer  AN41RECCOUNT5
Local Integer  AN41RECCOUNT6
Local Integer  AN41RECCOUNT7
Local Integer  AN41RECCOUNT9

Local Char     ANXPER1NUM(20)
Local Char     ANXPER2NUM(20)
Local Char     ANXPER3NUM(20)
Local Char     ANXINUM(20)
Local Integer  MDCLYEA
Local Char     MFPERIOD(3)

Local Integer  DCLPAG
Local Integer  ANRLOC
Local Char     DCLFLD(3)
Local Char     SNSC(1)

Local Decimal  TMPAMT40
Local Decimal  TMPAMT41
Local Decimal  TMPTOTAN

Local Char     RECTYP40(2)
Local Char     RECTYP41(2)
Local Char     QUADRO40(2)
Local Char     QUADRO41(2)

Local Shortint AN1COUNT
Local Shortint AN2COUNT
Local Shortint AN3COUNT

Local Integer  I

Return
######################################################################################
######################################################################################
Funprog GET_COD40(MOTIV)
Value Char MOTIV

Local Char RET(2)

Case MOTIV
  When "1A1"
    RET = "01"
  When "1A2"
    RET = "02"
  When "1A3"
    RET = "04"
  When "1B1", "1C1"
    RET = "05"
  When "1B2", "1C2"
    RET = "06"
  When "1B3", "1C3"
    RET = "07"
  When "1B4", "1C4"
    RET = "08"
  When "1D1"
    RET = "11"
  When "1D2"
    RET = "09"
  When "1D3"
    RET = "10"
  When "1D4"
    RET = "12"
  When "1E1"
    RET = "15"
  When "1E2"
    RET = "16"
  When "1E3"
    RET = "17"
  When "1E4"
    RET = "18"
  When "1F"
    RET = "14"
  When "1G"
    RET = "19"
Endcase

End RET
#############################################################################################
#############################################################################################
Funprog GET_COD41(MOTIV)
Value Char MOTIV

Local Char RET(2)

Case MOTIV
  When "1A1"
    RET = "02"
  When "1A2"
    RET = "03"
  When "1A3"
    RET = "04"
  When "1B1"
    RET = "05"
  When "1B2"
    RET = "06"
  When "1B3"
    RET = "07"
  When "1B4"
    RET = "08"
  When "1C"
    RET = "11"
  When "1D"
    RET = "13"
  When "1E"
    RET = "20"
  When "1F"
    RET = "21"
Endcase

End RET
#############################################################################################
#############################################################################################
Funprog GET_Q40(MOTIV)
Value Char MOTIV

Local Char RET(2)

Case MOTIV
  When "1A1", "1A2", "1A3"
    RET = "1A"
  When "1B1", "1B2", "1B3", "1B4"
    RET = "1B"
  When "1C1", "1C2", "1C3", "1C4"
    RET = "1C"
  When "1D1", "1D2", "1D3", "1D4"
    RET = "1D"
  When "1E1", "1E2", "1E3", "1E4"
    RET = "1E"
  When "1F"
    RET = "1F"
  When "1G"
    RET = "1G"
  When "2"
    RET = "2"
  When "31", "32"
    RET = "3"
Endcase

End RET

#############################################################################################
#############################################################################################
Funprog GET_Q41(MOTIV)
Value Char MOTIV

Local Char RET(2)

Case MOTIV
  When "1A1", "1A2", "1A3"
    RET = "1A"
  When "1B1", "1B2", "1B3", "1B4"
    RET = "1B"
  When "1C1"
    RET = "1C"
  When "1D1"
    RET = "1D"
  When "1E1"
    RET = "1E"
  When "1F"
    RET = "1F"
  When "21", "22"
    RET = "2"
Endcase

End RET
#############################################################################################
#############################################################################################
#############################################################################################
#############################################################################################
Funprog GET_RECTYP40(QUAD)
Value Char QUAD

Local Char RET(2)

Case QUAD
  When "1A"
    RET = "61"
  When "1B"
    RET = "62"
  When "1C"
    RET = "63"
  When "1D"
    RET = "64"
  When "1E"
    RET = "65"
  When "1F"
    RET = "66"
  When "1G"
    RET = "67"
Endcase

End RET
#############################################################################################
#############################################################################################
Funprog GET_RECTYP41(QUAD)
Value Char QUAD

Local Char RET(2)

Case QUAD
  When "1A"
    RET = "81"
  When "1B"
    RET = "82"
  When "1C"
    RET = "83"
  When "1D"
    RET = "84"
  When "1E"
    RET = "85"
  When "1F"
    RET = "86"
Endcase

End RET
