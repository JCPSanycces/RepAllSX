#<AdxTL>@(#)7.0.0.0 $Revision$
######################################################################################
######################################################################################
$EXPORT

Iomode adxirs chr$(10)          Using [VATF]
Iomode adxifs ''                Using [VATF]
Iomode adxium 50                Using [VATF]

Gosub DEC_EXP_VARS

Read [F:DVPP]DVPP0 = [F:DVPH]CPY;[F:DVPH]DCLYEA
If [F:CPY]CPY <> [F:DVPH]CPY
  Read [F:CPY]CPY0   = [F:DVPH]CPY
Endif

[L]DETRECCOUNT = 0
[L]DCLRECCOUNT = 0
[L]FILRECCOUNT = 0

[L]DCLNUM     = [F:DVPH]DCLNUM
[L]ANXPER1NUM = [F:DVPH]ANXPER1
[L]ANXPER2NUM = [F:DVPH]ANXPER2
[L]ANXPER3NUM = [F:DVPH]ANXPER3
[L]ANXINUM    = [F:DVPH]ANXI
[L]MDCLYEA    = [F:DVPH]DCLYEA
[L]MFPERIOD   = [F:DVPH]FPERIOD
[L]DCLPAG     = 1

[L]AN1COUNT = [F:DVPH]FAN1LINCOUNT>0 & [F:DVPH]BPCFLG = 2
[L]AN2COUNT = [F:DVPH]FAN2LINCOUNT>0 & [F:DVPH]BPSFLG = 2
[L]AN3COUNT = [F:DVPH]FAN3LINCOUNT>0 & [F:DVPH]REGFLG = 2

For [L]I = 1 To 3
  If evalue("[F:DVPH]ANXPER"+num$([L]I)) <> ""
    Read [F:DVPH1]DVPH0 = evalue("[F:DVPH]ANXPER"+num$([L]I))
    If fstat : Raz [F:DVPH1] : Endif
    [L]AN1COUNT += [F:DVPH1]FAN1LINCOUNT>0
    [L]AN2COUNT += [F:DVPH1]FAN2LINCOUNT>0
    [L]AN3COUNT += [F:DVPH1]FAN3LINCOUNT>0
  Endif
Next

Gosub EXPORT_MAIN

# Annex R1 - Other fiscal spaces (Mainland\Azores\Madeira) - current declaration
If [F:DVPH]AN1LOC > 0 & find([F:DVPH]AN1LOC, [F:DVPH]FAN1OPE, [F:DVPH]FAN2OPE, [F:DVPH]FAN3OPE)
  [L]DCLPAG = 2
  [L]ANRLOC = evalue("[F:DVPH]FAN"+num$([F:DVPH]AN1LOC)+"OPE")
  Gosub EXPORT_ANNEX_R
Endif

# Annex R2 - Other fiscal spaces (Mainland\Azores\Madeira) - current declaration
If [F:DVPH]AN2LOC > 0 & find([F:DVPH]AN2LOC, [F:DVPH]FAN1OPE, [F:DVPH]FAN2OPE, [F:DVPH]FAN3OPE)
  [L]DCLPAG = 3
  [L]ANRLOC = evalue("[F:DVPH]FAN"+num$([F:DVPH]AN2LOC)+"OPE")
  Gosub EXPORT_ANNEX_R
Endif

# Annex I - Transactions with other UE countries - European services declaration
If [F:DVPH]ANXI <> ""
  [L]DCLPAG = 1 #we did not separated by fiscal space, so all value is on main dec (dclpag = 1)
  Read [F:DVPH]DVPH0 = [L]ANXINUM
  If fstat
    Gosub EXPORT_ANNEX_I
  Endif
Endif

# Annex 1 - current declaration
If [F:DVPH]FAN1LINCOUNT > 0 & [F:DVPH]BPCFLG = 2
  Read [F:DVPH]DVPH0 = [L]DCLNUM
  Gosub EXPORT_ANNEX_1
Endif

# Annex 1 - declaration of period 1 (n-1)
If [L]ANXPER1NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER1NUM
  If !fstat
    If [F:DVPH]FAN1LINCOUNT > 0
      Gosub EXPORT_ANNEX_1
    Endif
  Endif
Endif

# Annex 1 - declaration of period 2 (n-2)
If [L]ANXPER2NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER2NUM
  If !fstat
    If [F:DVPH]FAN1LINCOUNT > 0
      Gosub EXPORT_ANNEX_1
    Endif
  Endif
Endif

# Annex 1 - declaration of period 3 (n-3)
If [L]ANXPER3NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER3NUM
  If !fstat
    If [F:DVPH]FAN1LINCOUNT > 0
      Gosub EXPORT_ANNEX_1
    Endif
  Endif
Endif

# Annex 2 - current declaration
If [F:DVPH]FAN2LINCOUNT > 0  & [F:DVPH]BPSFLG = 2
  Read [F:DVPH]DVPH0 = [L]DCLNUM
  Gosub EXPORT_ANNEX_2
Endif

# Annex 2 - declaration of period 3 (n-1)
If [L]ANXPER1NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER1NUM
  If !fstat
    If [F:DVPH]FAN2LINCOUNT > 0
      Gosub EXPORT_ANNEX_2
    Endif
  Endif
Endif

# Annex 2 - declaration of period 3 (n-2)
If [L]ANXPER2NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER2NUM
  If !fstat
    If [F:DVPH]FAN2LINCOUNT > 0
      Gosub EXPORT_ANNEX_2
    Endif
  Endif
Endif

# Annex 2 - declaration of period 3 (n-3)
If [L]ANXPER3NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER3NUM
  If !fstat
    If [F:DVPH]FAN2LINCOUNT > 0
      Gosub EXPORT_ANNEX_2
    Endif
  Endif
Endif

# Annex 3 - current declaration
If [F:DVPH]FAN3LINCOUNT > 0 & [F:DVPH]REGFLG = 2
  Read [F:DVPH]DVPH0 = [L]DCLNUM
  Gosub EXPORT_ANNEX_3
Endif

# Annex 3 - declaration of period 1 (n-1)
If [L]ANXPER1NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER1NUM
  If !fstat
    If [F:DVPH]FAN3LINCOUNT > 0
      Gosub EXPORT_ANNEX_3
    Endif
  Endif
Endif

# Annex 3 - declaration of period 2 (n-2)
If [L]ANXPER2NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER2NUM
  If !fstat
    If [F:DVPH]FAN3LINCOUNT > 0
      Gosub EXPORT_ANNEX_3
    Endif
  Endif
Endif

# Annex 3 - declaration of period 2 (n-3)
If [L]ANXPER3NUM <> ""
  Read [F:DVPH]DVPH0 = [L]ANXPER3NUM
  If !fstat
    If [F:DVPH]FAN3LINCOUNT > 0
      Gosub EXPORT_ANNEX_3
    Endif
  Endif
Endif

# Annex 40 - current declaration
If [F:DVPH]FAN40LINCONT > 0 | [F:DVPH]FLDAN4003 > 0 | [F:DVPH]FLDAN4004  > 0 |
&  [F:DVPH]FLDAN4003A  > 0 | [F:DVPH]FLDAN4004A  > 0 | [F:DVPH]FLDAN4003B  > 0 | [F:DVPH]FLDAN4004B > 0
  Read [F:DVPH]DVPH0 = [L]DCLNUM
  Gosub EXPORT_ANNEX_40
Endif

# Annex 41 - current declaration
#Issue 54535 – 2017-09-07 by MRDAB - Law 221/2017 - added fields C & D
If [F:DVPH]FAN41LINCONT > 0 | [F:DVPH]FLDAN4103A > 0 | [F:DVPH]FLDAN4104A  > 0 |
& [F:DVPH]FLDAN4103B  > 0 | [F:DVPH]FLDAN4104B  > 0 | [F:DVPH]FLDAN4103C > 0 |
& [F:DVPH]FLDAN4104C  > 0 | [F:DVPH]FLDAN4103D  > 0 | [F:DVPH]FLDAN4104D  > 0
#Issue end
  Read [F:DVPH]DVPH0 = [L]DCLNUM
  Gosub EXPORT_ANNEX_41
Endif

Gosub EXPORT_MAIN_END

Return
######################################################################################
######################################################################################
$EXPORT_MAIN

#----- File Header -----#
Wrseq format$("K:02X","01")        ; Using [VATF]              # Record type
Wrseq format$("K:05X","ASCII")     ; Using [VATF]              # File type
Wrseq format$("N0:02",4)           ; Using [VATF]              # File version
Wrseq format$("D:YYYYMMDD", date$) ; Using [VATF]              # File date (AAAAMMDD)
Wrseq format$("K:117X","")           Using [VATF]              # Filler 117 spaces

#----- Declaration Header -----#
Wrseq format$("K:02X","02")                          ; Using [VATF]              # Record type
Wrseq format$("K:05X","DPIVA")                       ; Using [VATF]              # Declaration type
Wrseq format$("N0:09",ctrans([F:CPY]EECNUM,"PT","")) ; Using [VATF]              # EECNUM
If [F:DVPH]ONTIMDCL = 2
  Wrseq format$("N0:01",1)                           ; Using [VATF]              # On time (1)/Outdated(2)
Else
  Wrseq format$("N0:01",2)                           ; Using [VATF]              # On time (1)/Outdated(2)
Endif
Wrseq format$("K:117X","")                             Using [VATF]              # Filler 117 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file

#----- Periodic VAT Declaration Header -----#
Wrseq format$("K:02X","03")                ; Using [VATF]             # Record type
Wrseq format$("N0:01",[F:DVPP]HQRLOC)      ; Using [VATF]             # Head-quarters localization (1- Mainland; 2-Azores; 3-Madeira)
Wrseq format$("N0:01",[F:DVPH]FAN1OPE)     ; Using [VATF]             # Other fiscal spaces (0- Non aplicable; 1- Mainland; 2-Azores; 3-Madeira)
Wrseq format$("N0:01",[F:DVPH]FAN2OPE)     ; Using [VATF]             # Other fiscal spaces (0- Non aplicable; 1- Mainland; 2-Azores; 3-Madeira)
Wrseq format$("N0:01",[F:DVPH]FAN3OPE)     ; Using [VATF]             # Other fiscal spaces (0- Non aplicable; 1- Mainland; 2-Azores; 3-Madeira)
Wrseq format$("N0:01",0)                   ; Using [VATF]             # Imob. activities (0- Non aplicable; 4- Aplicable)
Wrseq format$("N0:01",[F:DVPH]FRECAP_UE)   ; Using [VATF]             # Intra-com declaration
Wrseq format$("N0:01",[L]AN1COUNT)         ; Using [VATF]             # Customers recap (0- Non aplicable; 1- Mainland; 2-Azores; 3-Madeira; 4-Others)
Wrseq format$("N0:01",[L]AN2COUNT)         ; Using [VATF]             # Suppliers recap (0- Non aplicable; 1- Mainland; 2-Azores; 3-Madeira; 4-Others)
Wrseq format$("N0:01",[L]AN3COUNT)         ; Using [VATF]             # Adjustments recap (0- Non aplicable; 1- Mainland; 2-Azores; 3-Madeira; 4-Others)
Wrseq format$("N0:01",0)                   ; Using [VATF]             # No operations (0- Non aplicable; 1- Aplicable)
Wrseq format$("N0:04",[F:DVPH]DCLYEA)      ; Using [VATF]             # Year (AAAA)
Wrseq format$("K<:3X",[F:DVPH]FPERIOD)     ; Using [VATF]             # Period (month or Trim.)
Wrseq format$("K:115X","")                   Using [VATF]             # Filler of 115 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1
[L]DETRECCOUNT  = 0

[L]DCLPAG = 1

#----- Periodic VAT declarations fields - 04 -----#
Wrseq format$("K:02X","04")            ; Using [VATF]            # Record type
[L]DCLFLD = "001" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]            # Field 1  - BT. Tax.Red
[L]DCLFLD = "005" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]            # Field 5  - BT. Tax.Int
[L]DCLFLD = "003" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]            # Field 3  - BT. Tax.Normal
[L]DCLFLD = "007" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]            # Field 7  - BT. Intra Bens e Op. Assimiladas
[L]DCLFLD = "008" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]            # Field 8  - BT. Op. Prev. al. B do nº1 art.20 do CIVA
[L]DCLFLD = "009" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]            # Field 9  - BT. Op. não conferem direito de dedução
[L]DCLFLD = "010" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]            # Field 10 - BT. Aquisição Intra. Bens e Op. Assimiladas
[L]DCLFLD = "090" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]            # Field 90 - BT. Aquisição Intra. Bens e Op. Assimiladas
Wrseq format$("K:36X","")                Using [VATF]            # Filler of 36 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT += 1

#----- Periodic VAT declarations fields - 05 -----#
Wrseq format$("K:02X","05")           ; Using [VATF]              # Record type
[L]DCLFLD = "020" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100); Using [VATF]              # Field 20  - Imp. F.S.P - Imp...Ded. Imobilizado
[L]DCLFLD = "021" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100); Using [VATF]              # Field 21  - Imp. F.S.P - Imp...Ded. Existencia Taxa Reduzida
[L]DCLFLD = "023" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100); Using [VATF]              # Field 23  - Imp. F.S.P - Imp...Ded. Existencia Taxa Intermédia
[L]DCLFLD = "022" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100); Using [VATF]              # Field 22  - Imp. F.S.P - Imp...Ded. Existencia Taxa Normal
[L]DCLFLD = "024" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100); Using [VATF]              # Field 24  - Imp. F.S.P - Imp...Ded. Others Bens e Serviços
[L]DCLFLD = "040" : Gosub READ_FLD_VAL
TMPAMT40  = [F:DVPF]AMT
[L]DCLFLD = "081" : Gosub READ_FLD_VAL
TMPAMT40 -= [F:DVPF]AMT
Wrseq format$("N0:12",TMPAMT40*100)   ; Using [VATF]              # Field 40  - Imp. F.S.P - Reg. Mens/Trim e Anuais c/ Exc. indic. Field 81
[L]DCLFLD = "061" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100); Using [VATF]              # Field 61  - Imp. F.S.P - Excesso a Reportar do periodo Anterior
[L]DCLFLD = "065" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100); Using [VATF]              # Field 65  - Imp. F.S.P - Anexo (Valor anexo 1)
[L]DCLFLD = "067" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100); Using [VATF]              # Field 67  - Imp. F.S.P - Anexo (Valor anexo 2)
[L]DCLFLD = "081" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100); Using [VATF]              # Field 81  - Imp. F.S.P - Reg. a Favor Sujeito Passivo Comunicadas P/DSCIVA (Introdução manual pelo utilizador)
[L]DCLFLD = "091" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)  Using [VATF]              # Field 91  - Imp. F.S.P - Total do Imposto do Sujeito passivo corrigido com o valor da 81

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT += 1

#----- Periodic VAT declarations fields - 06 -----#
Wrseq format$("K:02X","06")            ; Using [VATF]             # Record type
[L]DCLFLD = "002" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 2   - Imp. a Favor do Estado - Trans. Bens e Prest. Serviços à taxa Reduzida
[L]DCLFLD = "006" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 6   - Imp. a Favor do Estado - Trans. Bens e Prest. Serviços à taxa Intermédia
[L]DCLFLD = "004" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 4   - Imp. a Favor do Estado - Trans. Bens e Prest. Serviços à taxa Normal
[L]DCLFLD = "011" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 11  - Imp. a Favor do Estado - Aquisições. Intra. Bens e Op. Assimiladas
[L]DCLFLD = "041" : Gosub READ_FLD_VAL
TMPAMT41  = [F:DVPF]AMT
[L]DCLFLD = "081" : Gosub READ_FLD_VAL
TMPAMT41 -= [F:DVPF]AMT
Wrseq format$("N0:12",TMPAMT41*100)    ; Using [VATF]             # Field 41  - Imp. a Favor do Estado - Reg. Mens/Trim. e Anuais c/Exc. das indic. Field 81
[L]DCLFLD = "066" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 66  - Imp. a Favor do Estado - Anexo (Valor anexo 1)
[L]DCLFLD = "068" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 68  - Imp. a Favor do Estado - Anexo (Valor anexo 2)
[L]DCLFLD = "092" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 92  - Imp. a Favor do Estado - Total do Imposto a favor do Estado corrigido com o valor da 81
[L]DCLFLD = "093" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 93  - Imp. a Favor do Estado - Imposto a Entregar ao Estado
[L]DCLFLD = "094" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100) ; Using [VATF]             # Field 94  - Imp. a Favor do Estado - Crédito de Imposto a Recuperar
[L]DCLFLD = "095" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)   Using [VATF]             # Field 95  - Imp. a Favor do Estado - Pedido de Reembolso

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT += 1

#----- Periodic VAT declarations fields - 07 -----#
Wrseq format$("K:02X","07")                 ; Using [VATF]              # Record type
[L]DCLFLD = "096" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Field 96   - Excesso a Reportar
Wrseq format$("N0:12",0)                    ; Using [VATF]              # antigo Field 262  - Opera. Ref. art.41º (Opera. Banc., Financ., Seguros e Resseguros)
Wrseq format$("N0:12",0)                    ; Using [VATF]              # antigo Field 263  - Opera. Ref. art.41º (Locação de Bens Imóveis)
If [F:DVPH]AUTBAL = 2
  Wrseq format$("N0:01",1)                  ; Using [VATF]              # Existiram operações no Field 264 se sim =1 se não =0
  Wrseq format$("N0:01",0)                  ; Using [VATF]              # Se não Existiram operações no Field 264 se sim=2 se não =0
Else
  Wrseq format$("N0:01",0)                  ; Using [VATF]              # Existiram operações no Field 264 se sim =1 se não =0
  Wrseq format$("N0:01",2)                  ; Using [VATF]              # Se não Existiram operações no Field 264 se sim=2 se não =0
Endif
Wrseq format$("N0:12",0)                    ; Using [VATF]              # antigo Field 264  - Opera. Ref. f) e g) do nº3 Art.9 e nas a) e b) do nº2 do Art.4
Wrseq format$("N0:01",0)                    ; Using [VATF]              # antigo em 2009 Primeira declaração neste regime (0 ou 1=Sim; 2=Não)
Wrseq format$("K:08X","00000000")           ; Using [VATF]              # antigo 2009 - Data Primeira declaração neste regime (AAAAMMDD)
Wrseq format$("N0:01",0)                    ; Using [VATF]              # antigo 2009 Cessação de Actividade (0 ou 1=Sim; 2=Não)
Wrseq format$("K:08X","00000000")           ; Using [VATF]              # antigo 2009 Data Cessação de Actividade (AAAAMMDD)
Wrseq format$("K:64X","")                     Using [VATF]              # Filler of 64 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT += 1

#----- Periodic VAT declarations fields - 30 -----#
Wrseq format$("K:02X","30")                 ; Using [VATF]              # Record type
[L]DCLFLD = "012" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Field 12
[L]DCLFLD = "014" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Field 14
[L]DCLFLD = "015" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Field 15
[L]DCLFLD = "016" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Field 16
[L]DCLFLD = "013" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Field 13
[L]DCLFLD = "017" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Field 17
Wrseq format$("K:60X","")                     Using [VATF]              # Filler of 60 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT += 1

#----- Periodic VAT declarations fields - 31 -----#
Wrseq format$("K:02X","31")                 ; Using [VATF]              # Record type
[L]DCLFLD = "097" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Field 97
[L]DCLFLD = "098" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Field 98
[L]DCLFLD = "099" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Field 99
[L]DCLFLD = "100" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Field 100
[L]DCLFLD = "101" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Field 101
[L]DCLFLD = "102" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Field 102
[L]DCLFLD = "103" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Field 103
[L]DCLFLD = "104" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Field 104
[L]DCLFLD = "105" : Gosub READ_FLD_VAL
Wrseq format$("N0:12",[F:DVPF]AMT*100)      ; Using [VATF]              # Field 105
Wrseq format$("K:24X","")                     Using [VATF]              # Filler of 24 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT += 1

#----- end of declaration -----#
[L]DCLFLD = "090" : Gosub READ_FLD_VAL
[L]TMPTOTAN = [F:DVPF]AMT
[L]DCLFLD = "091" : Gosub READ_FLD_VAL
[L]TMPTOTAN += [F:DVPF]AMT
[L]DCLFLD = "092" : Gosub READ_FLD_VAL
[L]TMPTOTAN += [F:DVPF]AMT
[L]DCLFLD = "093" : Gosub READ_FLD_VAL
[L]TMPTOTAN += [F:DVPF]AMT
[L]DCLFLD = "094" : Gosub READ_FLD_VAL
[L]TMPTOTAN += [F:DVPF]AMT
[L]DCLFLD = "095" : Gosub READ_FLD_VAL
[L]TMPTOTAN += [F:DVPF]AMT
[L]DCLFLD = "096" : Gosub READ_FLD_VAL
[L]TMPTOTAN += [F:DVPF]AMT

Wrseq format$("K:02X","08")                    ; Using [VATF]              # Record type
Wrseq format$("N0:03",[L]DETRECCOUNT)          ; Using [VATF]              # Nº of records
Wrseq format$("N0:09",val([F:CPY]PORCTFACN))   ; Using [VATF]              # NIF do TOC
Wrseq format$("N0:13",[L]TMPTOTAN*100)               ; Using [VATF]              # Total
Wrseq format$("K:107X","")                       Using [VATF]              # Filler of 107 spaces

FILRECCOUNT +=1 # Nº Linhas do ficheiro
DCLRECCOUNT +=1 # Nº Total Linhas Declaração

Return
######################################################################################
######################################################################################
$EXPORT_MAIN_END

Wrseq format$("K:02X","98")                  ; Using [VATF]             # Record type
Wrseq format$("N0:09",[L]DCLRECCOUNT)        ; Using [VATF]             # Nº of records
Wrseq format$("K:123X","")                     Using [VATF]             # Filler of 123 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file

Wrseq format$("K:02X","99")                  ; Using [VATF]             # Record type
Wrseq format$("N0:09",[L]FILRECCOUNT)        ; Using [VATF]             # Nº of records
Wrseq format$("K:123X","")                     Using [VATF]             # Filler of 123 spaces

Return
######################################################################################
######################################################################################
$READ_FLD_VAL

Read [F:DVPF]DVPF0 = [F:DVPH]DCLNUM;[L]DCLPAG;[L]DCLFLD
If fstat : Raz [F:DVPF] : Endif

Return
######################################################################################
######################################################################################
$EXPORT_ANNEX_R

#----- Annex header -----#
Wrseq format$("K:02X","09")                          ; Using [VATF]              # Record type
