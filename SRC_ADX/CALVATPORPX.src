Wrseq format$("K<:3X",[F:DVPH]FPERIOD)               ; Using [VATF]              # Period (month or trim.)
Wrseq format$("K:115X","")                             Using [VATF]              # Filler of 115 spaces

[L]FILRECCOUNT += 1 #Nº of lines on the file
[L]DCLRECCOUNT += 1 #Nº of lines on the declaration
[L]DETRECCOUNT  = 0

#----- Annex detail 10 -----#
