#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################################################
#   Débit manuel de points (Débit forfaitaire hors consommations)      Module CRM        9 octobre 2003  #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GIPDB2HBDISP
Global Integer GIPDB2HBLOCK

  GIPDB2HBDISP = 0
  GIPDB2HBLOCK = 0
  If PARAM(1) = "" Then
    #Le code de la demande de service n'a pas été communiqué. Accès impossible.
    GMESSAGE = mess(531,182,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  If PARAM(2) = "" Then
    #Le code client n'a pas été communiqué. Accès impossible.
    GMESSAGE = mess(532,182,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  If PARAM(3) = "" Then
    #Le contrat de service n'a pas été communiqué. Accès impossible.
    GMESSAGE = mess(535,182,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  If GREP = "" Then
    #Vérification du lock superviseur
    Local Integer ISLOCKED
    ISLOCKED = 0
    Call ISAOBLOCKED([M:SRE0]SRESYM, ISLOCKED) From CRMUTIL140
    If ISLOCKED Then
      #Modification en cours sur un autre poste.
      GMESSAGE = mess(10,100,1)
      GERR = 2
      FIN = 1
      Return
    Endif
  Endif
  Gosub AVMCTLLOCKSRE From SUBSREA
  If !IUPDSRE Then
    FIN = 1
    Return
  Endif
  GIPDB2HBLOCK = 1
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If [M:PDB2]DIRTY Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  [M:PDB2]SRENUM = PARAM(1)
  [M:PDB2]SREBPC = PARAM(2)
  [M:PDB2]CONNUM = PARAM(3)
  [M:PDB2]PITSRE = val(PARAM(4))
  [M:PDB2]PIT = [M:PDB2]PITSRE
  GIPDB2HBDISP = 1
  Affzo [M:PDB2]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  If GIPDB2HBDISP Then
    If GIPDB2HBLOCK Then
      Call UNLOCKSRE([M:PDB2]SRENUM) From SUBITNB1
    Endif
    Raz [M:PDB2]
  Endif
  Kill GIPDB2HBDISP
  Kill GIPDB2HBLOCK
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
  [M:PDB2]DIRTY = 1
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONOK
Local Integer IERRINF

  IERRINF = 0
  #Exécution du débit manuel
  Call DEBTRANS From GLOCK
  Trbegin [PCT]
  Delete [PCT] Where [F:PCT]SRENUM = [M:PDB2]SRENUM and [F:PCT]TPYFLG = 0 and [F:PCT]SAT <> 2
  If fstat Then
    If fstat = 4 Then
      Commit
    Else
      #Erreur lors l'enregistrement du débit manuel de points.
      GMESSAGE = mess(533,182,1)
      GERR = 1
      Rollback
      FIN = 0
      Return
    Endif
  Else
    Commit
  Endif
  Call CREPIT([M:PDB2]SRENUM, 0, [M:PDB2]CONNUM, [M:PDB2]SREBPC, "", "", "", "", [M:PDB2]PIT, 1, IERRINF) From SUBSREB2
  If IERRINF Then
    #Erreur lors l'enregistrement du débit manuel de points.
    GMESSAGE = mess(533,182,1)
    GERR = 1
    FIN = 0
    Return
  Endif
  Call LOADTOTPIT(1) From SUBSREB1
Return
