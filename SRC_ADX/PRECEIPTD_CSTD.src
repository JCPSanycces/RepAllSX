#<AdxTL>@(#)0.0.0.0 $Revision$
# Structure PRECEIPTD_C_TSICOD

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When ""
      Case [L]AEVENT
        When "AREAD_AFTER"    : Gosub AREAD_AFTER
        When "AINIT"          : Gosub AINIT          # 108613.n
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "INIT_TSICODADI" : Gosub INIT_TSICODADI # 108613.n
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "VATLEG" :
      Case [L]ARULE
        When "GET"     : Gosub VATLEG_GET
      Endcase
  Endcase
Return

#######################################################################################
$AREAD_AFTER
  Local Integer IRET  # 108613.n

  IRET = fmet this.INIT_TSICODADI   # 108613.n
  Local File PORDERQ [POQ]
  #Split the VAT fields out to 3 sep fields
  this.VAT1 = [F:PTD]VAT(0)
  this.VAT2 = [F:PTD]VAT(1)
  this.VAT3 = [F:PTD]VAT(2)

  Read [POQ] POQ0=this.POHNUM;this.POPLIN;this.POQSEQ
  If !fstat : this.WSOLDE = [F:POQ]LINCLEFLG : Endif

  Close File [POQ]

Return

#######################################################################################
$AINIT  # 108613.n
  Local Integer IRET

  IRET = fmet this.INIT_TSICODADI
Return

################################################################################
$INIT_TSICODADI  # 108613.n
  Local Integer DIM_STI
  Local Integer NI

  DIM_STI = func ASYRFNC.ACTIV("STI")
  # -------------------
  For NI = 1 To DIM_STI
    this.C_TSICOD(NI).TSICODADI = NI + 20
  Next NI
  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
Return

################################################################################
$VATLEG_GET
  Local Instance FACILITY Using C_FACILITY
  FACILITY = NewInstance C_FACILITY AllocGroup null
  [L]ASTATUS = fmet FACILITY.AREAD(this.PRHFCY)
  If [L]ASTATUS=[V]CST_AOK
    Local Instance VATX Using C_TABVAT
    VATX = NewInstance C_TABVAT AllocGroup FACILITY
    [L]ASTATUS = fmet VATX.AREAD(this.VATLEG,FACILITY.LEG)
    If [L]ASTATUS<>[V]CST_AOK
      [L]ASTATUS = fmet VATX.AREAD(this.VATLEG,AVOID.ACHAR)
    Endif
    If [L]ASTATUS=[V]CST_AOK
        this.VATLEG = VATX.LEG
    Endif
    VATX = null
  Endif
  FreeGroup FACILITY
  FACILITY = null
Return

