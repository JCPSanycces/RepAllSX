###nolign=NODETAIL
###Call APRES_NBLIG From =PROGSUB
###If mkstat
###    GREP = "" : REP="" : OK=0
###    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESMVT-GMESSIMP,1) From GESECRAN : # erreur
###Endif
###If !OK : Goto FIN_SMVT_VERROU : Endif
If WVCRTYP=20 :#sortie
    MA=1
    nolign=NODETAIL
    mkstat=0
    WPCU=evalue("[M:"+ABMSK(MA)+"]PCU(nolign-1)")
    Call AM_PCU(WPCU) From =PROGSUB
    If mkstat
    GREP = "" : REP="" : OK=0
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESMVT-GMESSIMP,1) From GESECRAN : # erreur
    Endif
    If !OK : Goto FIN_SMVT_VERROU : Endif

    nolign=NODETAIL
    mkstat=0
    Gosub AAPRES_NBLIG From =PROGSUB
    If mkstat
    GREP = "" : REP="" : OK=0
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESMVT-GMESSIMP,1) From GESECRAN : # erreur
    Endif
    If !OK : Goto FIN_SMVT_VERROU : Endif
Endif

Raz GOUVLOT
If WVCRTYP=19 : #entree
    GOUVLOT=1
Endif

nolign=NODETAIL
For MA=0 To NBMASK
  nolign = 1
  TRTMSK="W0"+NOMMSK(MA)
  ##Infbox num$(MA)-TRTMSK
  If AMA(MA)
    Gosub SETMASK From =WINPROG
    mkstat=0
    GNBAFF=0
    #Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
    If ABMSK(MA)=WOBJ+"1"
        Call SAI_NBLIG("SMD","IMP_TAB","CONNECTSMVT") From =TRTMSK
    Else
        Call SAIMSK("SMH","IMP_ZONE","CONNECTSMVT") From =TRTMSK
    Endif
    If mkstat
        GREP = "" : REP="" : OK=0
        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESMVT-GMESSIMP,1) From GESECRAN : # erreur
    Endif
    Setmode
  Endif
Next MA

If !OK : Goto FIN_SMVT_VERROU : Endif

Gosub VALID
If !OK : Goto FIN_SMVT_VERROU : Endif
Gosub DEVERROU

$FIN_SMVT
Return
$FIN_SMVT_VERROU
Gosub DEVERROU
$FIN_SMVT_ERR
Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
ERR=1
OK=0
Return

#####FIN onerrgo###########
$FIN_ERRGO_VERROU
Onerrgo
#on est en erreur sur la ligne
Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESMVT,1) From GESECRAN : # erreur
If errn
    Call ECR_TRACE(errp+"("+num$(errl)+"):"-errmes$(errn),1) From GESECRAN
Endif
Gosub DEVERROU
$FIN_ERRGO_SMVT
Onerrgo
Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
ERR=1
OK=0
Resume


$VERROU
OK = 1
ACTION = "VERROU"     : Gosub ACTIONG From SUBIMPOBJ
If !OK : Return : Endif
###ACTION = "IMP_VERROU" : Gosub ACTION From SUBIMPOBJ
###If !OK : Return : Endif
OK = 1
SYMBOLE = format$("K:3X",ABFIC)+GCLE
Lock =SYMBOLE With lockwait=0
If fstat
  Call ECR_TRACE(GCLESMVT-mess(61,141,1),1) From GESECRAN : # Fiche en cours de modification
  Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
  OK = 0
Endif
Return

$DEVERROU
ACTION = "DEVERROU"     : Gosub ACTIONG From SUBIMPOBJ
###ACTION = "IMP_DEVERROU" : Gosub ACTION From SUBIMPOBJ
SYMBOLE = format$("K:3X",ABFIC)+GCLE
If SYMBOLE <> ""
    Unlock =SYMBOLE
Endif
SYMBOLE = ""
Return

$SETCLE
CLECUR1 = [F:SMH]VCRNUM
GCLE = num$([F:SMH]VCRTYP)+"\"+[F:SMH]VCRNUM
Return

$VALID
 Gosub DEFAUT From =PROGOBJ
 Raz mkstat
 OK = 1
 Gosub VALIDOBJ
 If !OK
   # ici on sort de subprog VALID avec GMESSAGE=vide, si OK a été razé via $ACTIONG
   # qui a mis le message dans la trace puis l’a razé
   If GMESSAGE="" : GMESSAGE=ACTION : Endif
   Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESMVT-GMESSAGE,1) From GESECRAN : # erreur
   GMESSAGE=""
 Elsif GOK>=1
   If GREP="C"
        GCONSMVT_NEW += 1
        If WVCRTYP=19 : #entree
            GCONSMVTR_NEW += 1
        Else
            GCONSMVTO_NEW += 1
        Endif
        If WGETREF : Gosub ECR_REF : Endif
   Elsif GREP="M"
        GCONSMVT_MAJ += 1
   Endif
 Endif
 Raz GREP
Return

$VALIDOBJ
If GREP="C"
  [L]ACTION="VERIF_CRE"  : Gosub ACTION From GOBJSUB
 ##ACTION = "VERIF_CRE"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 ###ACTION = "IMP_VERIF_CRE" : Gosub ACTION  From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 Gosub TR1
 If GOK<1
   Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESMVT-mess(100,141,1),1) From GESECRAN : # Erreur création
 Else
  Gosub SETCLE : CLECUR = 1
  ##ACTION = "APRES_CRE"     : Gosub ACTIONG From SUBIMPOBJ
  [L]ACTION="APRES_CRE" : Gosub ACTION From GOBJSUB
  ###ACTION = "IMP_APRES_CRE" : Gosub ACTION From SUBIMPOBJ
  ###Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESMVT,-1) From GESECRAN
  Call IDENT3(WOBJ,IDENT,CLECUR1,CLECUR2) From GOBJTXT
  Call WORKFLOW(2,WOBJ,"C",IDENT) From AWRK
 Endif
Elsif GREP="M"
 ACTION = "VERIF_MOD"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 ###ACTION = "IMP_VERIF_MOD" : Gosub ACTION From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 Gosub TR2
 If GOK<1
   Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESMVT-mess(101,141,1),1) From GESECRAN : # Erreur modification
 Else
  Gosub SETCLE
  ACTION = "APRES_MOD"     : Gosub ACTIONG From SUBIMPOBJ
  ###ACTION = "IMP_APRES_MOD" : Gosub ACTION From SUBIMPOBJ
  ###Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESMVT,-1) From GESECRAN
  Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
  Call WORKFLOW(2,ABREV,"M",IDENT) From AWRK
 Endif
Endif
Return

$TR1
GOK = 1
Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 Raz [F]
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Gosub INICRE From GOBJSUB
 ###Gosub INIEXP From SUBIMPOBJ
 ACTION = "INICRE"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ###ACTION = "IMP_INICRE" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Write
 If fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK
  Goto AB_TR1
 Endif
 ACTION = "CREATION"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ###ACTION = "IMP_CREATION" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
ACTION = "AB_CREATION"     : Gosub ACTIONG From SUBIMPOBJ
###ACTION = "IMP_AB_CREATION" : Gosub ACTION  From SUBIMPOBJ
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$TR2
GOK=1
Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Readlock =
 If fstat=1
  GOK=-1 : Call FSTA(ABFIC) From GLOCK : Goto ROLL_TR2
 Elsif fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
 ACTION = "AVANT_MODFIC"    : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ###ACTION = "IMP_AVANT_MODFIC" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Gosub INIMOD From GOBJSUB
 ###Gosub INIEXP From SUBIMPOBJ
 ACTION = "INIMOD"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ###ACTION = "IMP_INIMOD" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Rewrite
 If fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
 ACTION = "MODIF"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ###ACTION = "IMP_MODIF" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
ACTION = "AB_MODIF"     : Gosub ACTIONG From SUBIMPOBJ
###ACTION = "IMP_AB_MODIF" : Gosub ACTION From SUBIMPOBJ
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif


#####################################################
$VALDEFMSK
nolign=1
For MA=0 To NBMASK
    Gosub SETMASK From =WINPROG
    For [MMV]MMV0 Where ID=CONREF & CODFIC=WTABLE
        If evalue("dim([M:"+ABMSK(MA)+"]"+[F:MMV]CODZONE+")")>0
            TYP = evalue("type([M:"+ABMSK(MA)+"]"+[F:MMV]CODZONE+")")
            Case TYP
            When 1, 2, 4, 5, 6, 7, 9
               Assign "[M:"+ABMSK(MA)+"]"+[F:MMV]CODZONE With val([F:MMV]VALDEF)
            When 3
               Assign "[M:"+ABMSK(MA)+"]"+[F:MMV]CODZONE With [F:MMV]VALDEF
            When Default
               Assign "[M:"+ABMSK(MA)+"]"+[F:MMV]CODZONE With [F:MMV]VALDEF
            Endcase
        Endif
        If evalue("dim([M:"+ABMSK(MA)+"]X"+[F:MMV]CODZONE+")")>0
            TYP = evalue("type([M:"+ABMSK(MA)+"]X"+[F:MMV]CODZONE+")")
            Case TYP
            When 1, 2, 4, 5, 6, 7, 9
               Assign "[M:"+ABMSK(MA)+"]X"+[F:MMV]CODZONE With val([F:MMV]VALDEF)
            When 3
               Assign "[M:"+ABMSK(MA)+"]X"+[F:MMV]CODZONE With [F:MMV]VALDEF
            When Default
               Assign "[M:"+ABMSK(MA)+"]X"+[F:MMV]CODZONE With [F:MMV]VALDEF
            Endcase
        Endif
    Next
Next MA
Return

