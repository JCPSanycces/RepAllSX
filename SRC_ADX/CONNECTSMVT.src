#<AdxTL>@(#)7.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBMMSINT","MMSINT",4,"SPEMMSINT") From GTRAITE
End


######################################################################
# CONNECTSMV : MMS Import des mouvements                             #
######################################################################
$ACTION
Case ACTION
 When "IMP_ZONE"      : Gosub IMP_ZONE
 When "IMP_TAB"      : Gosub IMP_TAB
Endcase
Return

######################################################################
$IMP_ZONE
$IMP_TAB
If IMPFIC = "SMH" | IMPFIC = "SMD"
  IMPMOD=1
  If IMPZON="STA"
    Assign ("[M:"+IMPMSK+"]STA") With "A"
  Endif
  # Issue 85698 - 2012-11-06 by RBA
  If IMPZON="NBSLO"
    Assign ("[M:"+IMPMSK+"]NBSLO") With 1
  Endif
  #/ Issue 85698 - 2012-11-06 by RBA
Endif
Return

######################################################################
Subprog TRAITE(ID,OS,FICCSV,FICCLI,CONPIT,CONREF,REJ,FICREJ,REF,FICREF,ERRG,ERRNOFIC)
Value Char ID(),OS(),FICCSV(),FICCLI(),CONPIT(),CONREF()
Value Integer REJ
Value Char FICREJ()
Value Integer REF
Value Char FICREF()
Variable Integer ERRG,ERRNOFIC

Local Integer ERR : ERR=0
Local Integer NOLIG : NOLIG=0
Local Integer OUVFICREJ: OUVFICREJ=0
Local Integer OUVFICREF: OUVFICREF=0

Local Clbfile LIGCLOB(10)
Local Clbfile LIGENTETE(10)
Local Integer ERRFIC : ERRFIC=0

If clalev ([F:SMH]) = 0 : Local File SMVTH [SMH] : Endif
If clalev ([F:SMD]) = 0 : Local File SMVTD [SMD] : Endif

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
adxium = GUTF8
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Gosub INITPIVOT From CONNECTFCT

If clalev ([F:MMV]) = 0 : Local File MMSDEFVAL [MMV] : Endif
If clalev ([F:MMS]) = 0 : Local File MMSPAR [MMS] : Endif
Read [MMS]MMS0=CONREF

GIMPORT=1

 GCONSMVT_NBF+=1
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE("==========================",0) From GESECRAN
 If FICCLI<>""
  GCONSMVT_FIC(GCONSMVT_NBF)=FICCLI
  Call ECR_TRACE(mess(220,139,1)-"|"+FICCLI,0) From GESECRAN : # Traitement du fichier
 Else
  GCONSMVT_FIC(GCONSMVT_NBF)=FICCSV
  Call ECR_TRACE(mess(38,115,1)-"|"+FICCSV,0) From GESECRAN : # Lecture du fichier
 Endif

 Gosub OUVFIC
 Onerrgo FIN_ERRGO
 Gosub LIREFIC
 If ERRFIC
    ERRG+=1 : ERRNOFIC+=1
    Call ECR_TRACE(mess(14,7710,1),1) From GESECRAN : # Lecture du fichier impossible
    Goto FIN
 Endif
 While !ERRFIC
     Gosub CHARGEPIVOT From CONNECTFCT
     If !ERR
         Gosub TRAITE_SMVT
         Onerrgo FIN_ERRGO
     Endif
     If ERR & REJ
        ERRG+=1
        # on doit ecrire dans le fichier des rejets
        Gosub ECR_REJ
     Endif
     ERR=0
     Gosub LIREFIC
 Wend

$FIN
 Onerrgo
 Gosub FERMEFIC
 GIMPORT=0
 adxium = SAVADXIUM
 adxifs = SAVADXIFS
 adxirs = SAVADXIRS
End
############
$FIN_ERRGO
 ERRG+=1 : ERRNOFIC+=1
 Call ECR_TRACE(mess(17,7710,1),1) From GESECRAN : # Erreur sur traitement d'une ligne du fichier
 Goto FIN
############

######################################################################
#Ouverture du fichier CSV
$OUVFIC
 If OS="unix"
    IRS = chr$(10)
 Else
    IRS = chr$(13)+chr$(10)
 Endif

 Openi FICCSV,0 Using [FCSV]
 adxifs=""
 adxirs=IRS
 adxium=GUTF8
 Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
 Iomode adxifs adxifs Using [FCSV]
 Iomode adxirs adxirs Using [FCSV]
 Iomode adxium adxium Using [FCSV]
 If WPIVHEATYP<>1
    Rdseq LIGCLOB Using [FCSV]
    If fstat=0
        LIGENTETE=LIGCLOB
        Call FILE_UTF8_BOM(LIGENTETE) From CONNECTFCT : # FQ 65094 GA 06/2010
    Endif
 Endif
Return

$LIREFIC
Rdseq LIGCLOB Using [FCSV]
If fstat<>0
    ERRFIC=1
Else
    If NOLIG=0  & WPIVHEATYP=1
       Call FILE_UTF8_BOM(LIGCLOB) From CONNECTFCT : # FQ 65094 GA 06/2010
    Endif
    GCONSMVT_ENR+=1
    NOLIG+=1
Endif
Return

$FERMEFIC
 Openi Using [FCSV]
 Openo Using [FREJ]
 Openo Using [FREF]
Return

######################################################################
#Ouverture du fichier REJ
$OUVFICREJ
 If OS="unix"
    IRS = chr$(10)
 Else
    IRS = chr$(13)+chr$(10)
 Endif

 Openo FICREJ,0 Using [FREJ]
 adxifs=""
 adxirs=IRS
 adxium=GUTF8
 Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
 Iomode adxifs adxifs Using [FREJ]
 Iomode adxirs adxirs Using [FREJ]
 Iomode adxium adxium Using [FREJ]
 OUVFICREJ=1
 If WPIVHEATYP<>1
    Wrseq LIGENTETE Using [FREJ]
 Endif
Return

$ECR_REJ
If !OUVFICREJ
    Gosub OUVFICREJ
Endif
Wrseq LIGCLOB Using [FREJ]
GCONSMVT_REJ+=1
Return

######################################################################
#Ouverture du fichier REF
$OUVFICREF
 If OS="unix"
    IRS = chr$(10)
 Else
    IRS = chr$(13)+chr$(10)
 Endif

 Openo FICREF,0 Using [FREF]
 adxifs=""
 adxirs=IRS
 adxium=GUTF8
 Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
 Iomode adxifs adxifs Using [FREF]
 Iomode adxirs adxirs Using [FREF]
 Iomode adxium adxium Using [FREF]
 OUVFICREF=1
 If WPIVHEATYP<>1
    Wrseq "VCRTYP;VCRNUM" Using [FREF]
 Endif
Return

$ECR_REF
If REF
    If !OUVFICREF
        Gosub OUVFICREF
    Endif
    Wrseq [F:SMH]VCRTYP+";"+[F:SMH]VCRNUM Using [FREF]
Endif
Return


######################################################################
$INIVARNB
Global Integer GCONSMVT_NBF : GCONSMVT_NBF = 0 : #nombre de fichier ITM
Global Char    GCONSMVT_FIC(GDIMFIC)(1..1000) : Raz GCONSMVT_FIC
Global Integer GCONSMVT_ENR : GCONSMVT_ENR = 0 : #enreg lus
Global Integer GCONSMVT_NEW : GCONSMVT_NEW = 0 : #enreg importés/nouveaux
Global Integer GCONSMVTR_NEW : GCONSMVTR_NEW = 0 : #nombre d'entrées
Global Integer GCONSMVTO_NEW : GCONSMVTO_NEW = 0 : #nombre de sorties
Global Integer GCONSMVT_MAJ : GCONSMVT_MAJ = 0 : #enreg importés/maj
Global Integer GCONSMVT_REJ : GCONSMVT_REJ = 0 : #enreg rejetés
Return

$SUPVARNB
  # Désallocation des variables globales
  If dim(GCONSMVT_NBF)>0 Then Kill GCONSMVT_NBF Endif
  If dim(GCONSMVT_FIC)>0 Then Kill GCONSMVT_FIC Endif
  If dim(GCONSMVT_ENR)>0 Then Kill GCONSMVT_ENR Endif
  If dim(GCONSMVT_NEW)>0 Then Kill GCONSMVT_NEW Endif
  If dim(GCONSMVTR_NEW)>0 Then Kill GCONSMVTR_NEW Endif
  If dim(GCONSMVTO_NEW)>0 Then Kill GCONSMVTO_NEW Endif
  If dim(GCONSMVT_MAJ)>0 Then Kill GCONSMVT_MAJ Endif
  If dim(GCONSMVT_REJ)>0 Then Kill GCONSMVT_REJ Endif
Return
######################################################################
$OUVRE_IMP_SMO
If !clalev([F:SRT])  Local File STKTRS [SRT] : Endif
GABREV="SMO" : GFLAG=""
#----- Sélection de la transaction d'un bordereau de sortie -----#
#Call PARAM("","SMOTRS",GBIDC3) From ADOVAL : GFLAG=GBIDC3
Read [SRT] SRT0=2;GFLAG
If fstat
  Filter [SRT] Where SRTTYP=2 & ENAFLG=2
  Read [SRT] First
  Filter [SRT]
  If fstat
    If GTRACE<>""
      Call ECR_TRACE(mess(114,192,1),1) From GESECRAN
    Endif
    OK=0 : Return
  Endif
  GFLAG=[F:SRT]SRTNUM
Endif
[F:SRT]STKFLG   =2 : # On force la détermination du stock à sortir à "oui"
[F:SRT]PRNCOD1  =1 : # On force l'impression d'étiquettes à "Non"
[F:SRT]PRNNBFLG1=1 : # On force le nbre d'impression à "Non"
Return
######################################################################

$TRAITE_SMVT
Onerrgo FIN_ERRGO_SMVT
Local Shortint IADIME : IADIME = 30    : # Taille pour le Setmode
Local Integer  INBAFF                  : # Pile/Indice
Local Integer  IAFFCOD(0..IADIME)      : # Code instruction
Local Char     IAFFMASK(GLONABR)(0..IADIME)  : # Abréviation écran
Local Char     IAFFCHP(50)(0..IADIME)        : # Zone écran
Local Integer  IAFFIND(0..IADIME)            : # Indice de la zone
Local Char     IAFFTXT(250)(0..IADIME) : # Texte
Local Integer  IAFFRANG(0..IADIME)     : # Rang
Local Integer  IAFFOPT1(0..IADIME)     : # Option1 Ex: Status, premier rang affzo 10-20
Local Integer  IAFFOPT2(0..IADIME)     : # Option2 Ex: Raccourci clavier, dernier rang affzo 10-20

Local Char    PROGOBJ(GLONADC) , PROGSUB(GLONADC) , PROGSPE(GLONADC) , PROGSPV(GLONADC)
Local Char    PROGIMP(GLONADC) , PROGIMS(GLONADC)
Local Char    OBJLIS(GLONAOB)(1..8)
Local Integer AMA(0..16) , RESTMSK(0..16)
Local Integer CRE, MODI, SUPPR, ISITE
Local Char    ERRMES(50)
Local Integer NRMASK , ILIS , RELIT
Local Integer PSPE, PSUB, PSPV, PSTD
Local Integer PIMP
Local Char    SYMBOLE(35)
Local Char    CLECUR1(GLONID1) , CLECUR2(GLONID2)(0..16), CLE2(GLONID2)(0..16)
Local Char    SCLE2(GLONID2) , COUZON(GLONAVA)
Local Integer TPCLE1 , TPCLE2(0..16)
Local Char    SAVCLE1(GLONID1) , SAVCLE2(GLONID2)
Local Char    FILTRE(240) , FILTSUP(240) , CRITTAB(250)
Local Char    CRITERE(250) , FILROLE(250) , FILSUITE(250)
Local Integer ICRITERE , IFILROLE , IFILSUITE
Local Char    ACTION(20) , CHAINE(20) , REP(1)
Local Char    MESSA(250)
Local Char    IDENT(50), ABREV(GLONAOB), SITCUR(15)
Local Integer MA, CL , CLECUR, AFFICHE, AUTENA, OPTENA, OPTDOC , OKTRT,OK
Local Integer TUNNEL, VERROU
Local Integer NBMEN , NBRMEN , ETAMEN(1..60)
Local Char    CHMEN(30) , BOUT(1)
Local Char GCLESMVT(GLONITM+20)
Local Char WFICSMVTNUM(GLONVCR+20)
Local Char WFICBPSNUM(GLONBPR)
Local Char WFICSTOFCY(GLONFCY)
Local Char WTCLCOD(GLONITG)
Local Char GREPCON : # "C" ou "M"
Local Integer WGETREF
Local Integer WVCRTYP #, WQTYRCP , WQTYISS
# Issue 89328 - 2013-04-22 by RBA
Local Decimal WQTYRCP , WQTYISS
#/ Issue 89328 - 2013-04-22 by RBA

# Issue 89540 - 2013-29-04 by RBA
Local Char WCCE, WVALCCE
#/ Issue 89540 - 2013-29-04 by RBA

OK=1
Raz GCLESMVT
If [F:PIT]TYP=24 : #MMS mouvements
GCLESMVT=func CONNECTFCT.GETVAL("SMVTH","IPTDAT",NBPIVZON,WPIVTABZON,WPIVVAL)+"/"+func CONNECTFCT.GETVAL("SMVTD","ITMREF",NBPIVZON,WPIVTABZON,WPIVVAL)
Endif
If GCLESMVT=""
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-mess(9,7710,1),1) From GESECRAN : # Ligne x Référence non renseignée
    Goto FIN_SMVT_ERR
Endif

WQTYRCP=val(func CONNECTFCT.GETVAL("SMVTD","WQTYRCP",NBPIVZON,WPIVTABZON,WPIVVAL))
WQTYISS=val(func CONNECTFCT.GETVAL("SMVTD","WQTYISS",NBPIVZON,WPIVTABZON,WPIVVAL))
If (WQTYRCP=0 & WQTYISS=0) | (WQTYRCP>0 & WQTYISS>0)
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESMVT-mess(72,7710,1),1) From GESECRAN : # Les quantités d'entrée et de sortie sont incorrectes.
    Goto FIN_SMVT_ERR
Elsif WQTYISS>0 : #sortie
    WVCRTYP=20
    WOBJ="SMO"
Else : # entree
    WVCRTYP=19
    WOBJ="SMR"
Endif

ABREV="SMH"
ABFIC="SMH"

# Issue 89540 - 2013-29-04 by RBA
WCCE=num$(func CONNECTFCT.GETVAL("SMVTD","WCCE",NBPIVZON,WPIVTABZON,WPIVVAL))
If pat(GVERSION,"1.5.*")
  # La table contient le champ CCEi correspondant à l'axe i
  WVALCCE = "CCE"+num$([F:MMS]AXIIMP)
Else
  # Recherche de la valeur dans CADIEDEF
  Local Integer WI, WJ
  If !clalev([F:CDI])  Local File CADIEDEF [CDI] : Endif
  Read [CDI] CDI0=1 #articles
  If !fstat & [MMS]DIEIMP<>""
     WI=find("SMVTD/WCCE",WPIVTABZON(1..NBPIVZON))
     WJ=find([MMS]DIEIMP,[F:CDI]DIE(0..max(GNBDIE-1,8)))
     If WJ : WVALCCE = "CCE"+num$(WJ) : Endif
  Endif
  Close File [F:CDI]
Endif
#/ Issue 89540 - 2013-29-04 by RBA

WINPROG="WGO"+WOBJ
# Issue 80297 - 2012-27-02 by RBA
# Issue 81372 - 2012-05-04 by SR
Call ISWINDOWOK (nomap,"O"+WOBJ) From INTRUTILB
##  "WOSMR SUBSMR SPESMR SPVSMR"
##  "WOSMO SUBSMO SPESMO SPVSMO"
Call SETPROG(WOBJ,PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
Gosub DEFVAR From =WINPROG
Gosub OUVRE_MSK From GOBJET
For MA=0 To NBMASK
    Gosub RAZMASK From =WINPROG
Next MA
Gosub OUVRE From =PROGOBJ

Raz GFLAG
ACTION="DEFTRANS"
Gosub ACTION From =PROGSUB

If WVCRTYP=20 : #sortie
    Gosub OUVRE_IMP_SMO
Endif

ACTION="OUVRE"
Gosub ACTION From =PROGSUB

If !OK : Goto FIN_SMVT_ERR : Endif

If evalue("clalev([F:"+ABFIC+"])")=0 : Gosub OUVFIC From =PROGOBJ : Endif
If !OK : Goto FIN_SMVT_ERR : Endif

Default File [F:SMH]

Raz [F:SMH]
WGETREF=0
Gosub SETCLE : #pour vider les zones
If [F:PIT]TYP=24 : #MMS mouvements
    GREPCON = "C"
Else
    Goto FIN_SMVT_ERR
###    ### A VERIFIER LE JOUR OU ON AURA UN AUTRE CONNECTEUR
###    Read [F:SMH]SMH0=GCLESMVT
###    If fstat
###        GREPCON = "C"
###        WFICSMVTNUM=func CONNECTFCT.GETVAL("PREQUIS","XXXNUM",NBPIVZON,WPIVTABZON,WPIVVAL)
###        If WFICSMVTNUM<>""
###            Read [F:SMH]SMH0=WFICSMVTNUM
###            If !fstat
###                If [F:SMH]XXXNUMMMS<>"" & GCLESMVT<>[F:SMH]XXXNUMMMS
###                    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESMVT-mess(64,7710,1),1) From GESECRAN : # la demande d'achat ne correspond pas
###                    Goto FIN_SMVT_ERR
###                Endif
###                GREPCON = "M"
###            Endif
###        Endif
###    Else
###        GREPCON = "M"
###    Endif
Endif

## AVEC MMS Mouvements on est toujours en insertion
If GREPCON = "C"
 CLECUR = 0
 CHAINE = "C"
 ACTION = "SETBOUT"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : Goto FIN_SMVT_ERR : Endif
 ###ACTION = "IMP_SETBOUT" : Gosub ACTION  From SUBIMPOBJ
 OK=(instr(1,CHAINE,"C")<>0)
 If OK
   GREP = "C" : REP = "C"
   ACTION = "RAZCRE"      : Gosub ACTIONG From SUBIMPOBJ
   ###ACTION = "IMP_RAZCRE"  : Gosub ACTION From SUBIMPOBJ
 Endif
Else
 ### A VERIFIER LE JOUR OU ON AURA UN AUTRE CONNECTEUR
 If [F:PIT]TYP<>24 : #MMS mouvements
###     WFICSMVTNUM=func CONNECTFCT.GETVAL("PREQUIS","XXXNUM",NBPIVZON,WPIVTABZON,WPIVVAL)
###     If WFICSMVTNUM<>"" & WFICSMVTNUM<>[F:SMH]XXXNUM
###        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESMVT-mess(64,7710,1),1) From GESECRAN : # la demande d'achat ne correspond pas
###        Goto FIN_SMVT_ERR
###     Elsif WFICSMVTNUM=""
###        Call SETVAL("PREQUIS","XXXNUM",NBPIVZON,WPIVTABZON,WPIVVAL,WPIVVALFIC,[F:SMH]XXXNUM) From CONNECTFCT
###     Endif
###     Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESMVT-mess(68,7710,1),1) From GESECRAN : # La demande d'achat existe déjà et ne peut pas etre modifiée.
     Goto FIN_SMVT_ERR
 Endif
 Gosub SETCLE
 Gosub VERROU
 If !OK : Goto FIN_SMVT_ERR : Endif
 Onerrgo FIN_ERRGO_VERROU
 nolign = 1
 For IMA=0 To NBMASK
  If AMA(IMA)
   Gosub CHARGEMSK From =WINPROG
  Endif
 Next IMA
 For MA=0 To NBMASK
    Gosub SETMASK From =WINPROG
 Next MA
 ACTION = "LIENS"     : Gosub ACTIONG From SUBIMPOBJ
 ###ACTION = "IMP_LIENS" : Gosub ACTION  From SUBIMPOBJ
 CLECUR = 1
 CHAINE = "M"
 ACTION = "SETBOUT"     : Gosub ACTIONG From SUBIMPOBJ
 ###ACTION = "IMP_SETBOUT" : Gosub ACTION  From SUBIMPOBJ
 If instr(1,CHAINE,"M")
  OK = 1
  ACTION = "AVANT_MOD"     : Gosub ACTIONG From SUBIMPOBJ
  ###ACTION = "IMP_AVANT_MOD" : Gosub ACTION  From SUBIMPOBJ
 Else
  OK = 0
 Endif
 GREP = "M" : REP = "M"
Endif

If !OK | GREP="" : Goto FIN_SMVT_VERROU : Endif
#on affecte les valeurs du mask
If WVCRTYP=19 : #entree
    [M:SMR1]NBLIG+=1
    NODETAIL=[M:SMR1]NBLIG
Else
    [M:SMO1]NBLIG+=1
    NODETAIL=[M:SMO1]NBLIG
Endif

nolign=NODETAIL
If GREP="C"
    WTABLE="SMVTH"
    Gosub VALDEFMSK
Endif
##nolign=1
For MA=0 To NBMASK
        Gosub SETMASK From =WINPROG
        For NOPIV=1 To NBPIVZON
            If pat(WPIVTABZON(NOPIV),"SMVTH/*")
                If evalue("dim([M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
                   Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV),WPIVVAL(NOPIV),OK) From CONNECTFCT
                Endif
            Endif
        Next
Next MA
If !OK : Goto FIN_SMVT_VERROU : Endif

MA=0
TRTMSK="W0"+WOBJ+"0"
Gosub SETMASK From =WINPROG
mkstat=0
GNBAFF=0
Call SAIMSK("SMH","IMP_ZONE","CONNECTSMVT") From =TRTMSK
If mkstat
    GREP = "" : REP="" : OK=0
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESMVT-GMESSIMP,1) From GESECRAN : # erreur
Endif
Setmode
If !OK : Goto FIN_SMVT_VERROU : Endif

MA=1
NOPIV=find("SMVTD"+"/"+"ITMREF",WPIVTABZON(1..NBPIVZON))
nolign=NODETAIL
If NOPIV>0
    Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV),WPIVVAL(NOPIV),OK) From CONNECTFCT

    mkstat=0
    Call AM_ITMREF(WPIVVAL(NOPIV)) From =PROGSUB
    If mkstat
        GREP = "" : REP="" : OK=0
        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLESMVT-GMESSIMP,1) From GESECRAN : # erreur
    Endif
    If !OK : Goto FIN_SMVT_VERROU : Endif

Endif
If GREP="C"
    nolign=NODETAIL
    WTABLE="SMVTD"
    Gosub VALDEFMSK
Endif

nolign=NODETAIL
For MA=0 To NBMASK
        Gosub SETMASK From =WINPROG
        For NOPIV=1 To NBPIVZON
            If pat(WPIVTABZON(NOPIV),"SMVTD/*")
                If evalue("dim([M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
                   Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV),WPIVVAL(NOPIV),OK) From CONNECTFCT
                Endif
            Endif
        Next
Next MA
If !OK : Goto FIN_SMVT_VERROU : Endif

#on affecte les valeurs particulières

MA=1
nolign=NODETAIL
If evalue("dim([M:"+ABMSK(MA)+"]PRI)")>0
    If find("SMVTD"+"/"+"WPRIUNT",WPIVTABZON(1..NBPIVZON))>0
        WPRI=val(func CONNECTFCT.GETVAL("SMVTD","WPRIUNT",NBPIVZON,WPIVTABZON,WPIVVAL))
#Issue 106715 - 2015-03-04 by RBA
#        If WVCRTYP=19 : #entree
#            WPRI=WPRI*WQTYRCP
#        Else
#            WPRI=WPRI*WQTYISS
#        Endif
#/Issue 106715 - 2015-03-04 by RBA
        Assign "[M:"+ABMSK(MA)+"]PRI(nolign-1)" With WPRI
    Endif
Endif

MA=1
nolign=NODETAIL
If WVCRTYP=19 : #entree
    Assign "[M:"+ABMSK(MA)+"]QTYPCU(nolign-1)" With WQTYRCP
Else
    Assign "[M:"+ABMSK(MA)+"]QTYPCU(nolign-1)" With WQTYISS
Endif

MA=1
nolign=NODETAIL
If evalue("dim([M:"+ABMSK(MA)+"]STA)")>0
    Assign "[M:"+ABMSK(MA)+"]STA(nolign-1)" With "A"
Endif

#Issue 89540 - 2013-29-04 by RBA
MA=1
nolign=NODETAIL
#If WJ #: WPIVTABZON(WI) = "SMVTD/"+"CCE"+num$(WJ)+"" : WVALCCE = "CCE"+num$(WJ) : Endif
#Issue 100098 - 2014-16-05 by RBA
If WVALCCE <> "" and WCCE <> "" #Issue 106091 - 2015-02-13 by RBA
#/Issue 100098 - 2014-16-05 by RBA
  If evalue("dim([M:"+ABMSK(MA)+"]"+WVALCCE+")")>0
      Assign "[M:"+ABMSK(MA)+"]"+WVALCCE+"(nolign-1)" With WCCE
  Endif
Endif
