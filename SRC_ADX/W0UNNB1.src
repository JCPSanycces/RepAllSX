#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque UNNB1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone UNNBR
mkstat = 0
zoncou = "UNNBR"
indice = 0
WCHAR = [M]UNNBR
If varmode([M]UNNBR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "UNNBR" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]UNNBR,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "UNNBR" : GZNUM = 1001644 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]UNNBR or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_UNNBR([M]UNNBR) From SUBUNNB
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "UNNBR" : GZNUM = 1001644 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone UNSHOAXX
mkstat = 0
zoncou = "UNSHOAXX"
indice = 0
If varinit([M]UNSHOAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]UNSHOAXX,"TABUNNBR","UNSHOAXX",num$([M:UN1]UNNBR),"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]UNSHOAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "UNSHOAXX" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]UNSHOAXX,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "UNSHOAXX" : GZNUM = 4010 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone UNNBRDES
mkstat = 0
zoncou = "UNNBRDES"
indice = 0
If varmode([M]UNNBRDES,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "UNNBRDES" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "UNNB1"
Return

