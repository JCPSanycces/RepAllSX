#<AdxTL>@(#)0.0.0.0 $Revision$Class XML files
# Supervisor
## CRUD-CLASSE ## EDIXMLFIL
# 2018-11-06 07:05:17 801


############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(EDIXMLFIL,ASTATUS)
Variable Instance EDIXMLFIL Using C_EDIXMLFIL
Variable Integer ASTATUS

If EDIXMLFIL = null : End : Endif

Gosub _AVARIABLES From WMC00EDIXMLFIL

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_EDIXMLFIL

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(EDIXMLFIL,ASTATUS)
Variable Instance EDIXMLFIL Using C_EDIXMLFIL
Variable Integer ASTATUS

If EDIXMLFIL = null : End : Endif

Gosub AVARIABLES From WMC00EDIXMLFIL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_EDIXMLFIL
Else
 Gosub AINSERT_EDIXMLFIL
Endif

Gosub _AINSERT_AFTER
[L]A_I = EDIXMLFIL.freeSnapshot
EDIXMLFIL.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EDIXMLFIL._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EDIXMLFIL._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EDIXMLFIL._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If EDIXMLFIL.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EDIXMLFIL.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(EDIXMLFIL.EXFN)
 If EDIXMLFIL.EXFN([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFN([L]A_I).ACTION("AINSERT_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIXMLFIL.EXFD) : # EDIXMLFILD -- 2
 If EDIXMLFIL.EXFD(A_N2) <> null
& and !find(EDIXMLFIL.EXFD(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ACTION("AINSERT_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIXMLFIL.EXSD) : # EDIXMLFILXSD -- 3
 If EDIXMLFIL.EXSD(A_N2) <> null
& and !find(EDIXMLFIL.EXSD(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ACTION("AINSERT_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIXMLFIL.EXFF) : # EDIXMLFILF -- 4
 If EDIXMLFIL.EXFF(A_N2) <> null
& and !find(EDIXMLFIL.EXFF(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ACTION("AINSERT_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER
For A_N2=1 To maxtab(EDIXMLFIL.EXFD) : # EDIXMLFILD -- 2
 If EDIXMLFIL.EXFD(A_N2) <> null
& and !find(EDIXMLFIL.EXFD(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ACTION("AINSERT_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIXMLFIL.EXSD) : # EDIXMLFILXSD -- 3
 If EDIXMLFIL.EXSD(A_N2) <> null
& and !find(EDIXMLFIL.EXSD(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ACTION("AINSERT_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIXMLFIL.EXFF) : # EDIXMLFILF -- 4
 If EDIXMLFIL.EXFF(A_N2) <> null
& and !find(EDIXMLFIL.EXFF(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ACTION("AINSERT_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

For [L]A_I=1 To maxtab(EDIXMLFIL.EXFN)
 If EDIXMLFIL.EXFN([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFN([L]A_I).ACTION("AINSERT_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_EDIXMLFIL
Trbegin [F:EXF]
 Gosub AINSERT_EDIXMLFIL
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_EDIXMLFIL
Raz [F:EXF]
[L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EDIXMLFIL._MAJSQL_EDIXMLFIL(EDIXMLFIL))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]A_TYPMAJ=[V]CST_ANEW

#-----------------------------------------------------#
For A_N2=1 To maxtab(EDIXMLFIL.EXFD)
 If EDIXMLFIL.EXFD(A_N2) <> null and
& (EDIXMLFIL.EXFD(A_N2).ASTALIN=[L]A_TYPMAJ or
& EDIXMLFIL.EXFD(A_N2).ASTALIN=[V]CST_ALL)
  If EDIXMLFIL.EXFD(A_N2).ASTALIN=[L]A_TYPMAJ
   Raz [F:EXFD]
   [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ACTION("AINSERT_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   [L]ASTATUS = func WMC00EDIXMLFIL._MAJSQL_EDIXMLFILD(EDIXMLFIL.EXFD(A_N2))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ACTION("AINSERT_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
 If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EDIXMLFIL.EXSD)
 If EDIXMLFIL.EXSD(A_N2) <> null and
& (EDIXMLFIL.EXSD(A_N2).ASTALIN=[L]A_TYPMAJ or
& EDIXMLFIL.EXSD(A_N2).ASTALIN=[V]CST_ALL)
  If EDIXMLFIL.EXSD(A_N2).ASTALIN=[L]A_TYPMAJ
   Raz [F:EXSD]
   [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ACTION("AINSERT_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   [L]ASTATUS = func WMC00EDIXMLFIL._MAJSQL_EDIXMLFILXSD(EDIXMLFIL.EXSD(A_N2))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ACTION("AINSERT_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
 If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EDIXMLFIL.EXFF)
 If EDIXMLFIL.EXFF(A_N2) <> null and
& (EDIXMLFIL.EXFF(A_N2).ASTALIN=[L]A_TYPMAJ or
& EDIXMLFIL.EXFF(A_N2).ASTALIN=[V]CST_ALL)
  If EDIXMLFIL.EXFF(A_N2).ASTALIN=[L]A_TYPMAJ
   Raz [F:EXFF]
   [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ACTION("AINSERT_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   [L]ASTATUS = func WMC00EDIXMLFIL._MAJSQL_EDIXMLFILF(EDIXMLFIL.EXFF(A_N2))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ACTION("AINSERT_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
 If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

[L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If EDIXMLFIL.snapshotEnabled=1
 [L]A_RETIK = EDIXMLFIL.revertUpdTick
Endif
[L]ASTATUS = max(fmet EDIXMLFIL.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(EDIXMLFIL.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EDIXMLFIL.ASTALIN = [V]CST_ALL
Endif
For [L]A_I=1 To maxtab(EDIXMLFIL.EXFN)
 If EDIXMLFIL.EXFN([L]A_I)<>null
  If EDIXMLFIL.EXFN([L]A_I).ASTALIN=[V]CST_ADEL or EDIXMLFIL.EXFN([L]A_I).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDIXMLFIL.EXFN([L]A_I)
   EDIXMLFIL.EXFN([L]A_I) = null
  Elsif EDIXMLFIL.EXFN([L]A_I).ASTALIN <> [V]CST_ALL
   EDIXMLFIL.EXFN([L]A_I).ASTALIN = [V]CST_ALL
  Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIXMLFIL.EXFD)
 If EDIXMLFIL.EXFD(A_N2) <> null
  If EDIXMLFIL.EXFD(A_N2).ASTALIN=[V]CST_ADEL or EDIXMLFIL.EXFD(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDIXMLFIL.EXFD(A_N2)
   EDIXMLFIL.EXFD(A_N2) = null
  Elsif EDIXMLFIL.EXFD(A_N2).ASTALIN <> [V]CST_ALL
   EDIXMLFIL.EXFD(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIXMLFIL.EXSD)
 If EDIXMLFIL.EXSD(A_N2) <> null
  If EDIXMLFIL.EXSD(A_N2).ASTALIN=[V]CST_ADEL or EDIXMLFIL.EXSD(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDIXMLFIL.EXSD(A_N2)
   EDIXMLFIL.EXSD(A_N2) = null
  Elsif EDIXMLFIL.EXSD(A_N2).ASTALIN <> [V]CST_ALL
   EDIXMLFIL.EXSD(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIXMLFIL.EXFF)
 If EDIXMLFIL.EXFF(A_N2) <> null
  If EDIXMLFIL.EXFF(A_N2).ASTALIN=[V]CST_ADEL or EDIXMLFIL.EXFF(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDIXMLFIL.EXFF(A_N2)
   EDIXMLFIL.EXFF(A_N2) = null
  Elsif EDIXMLFIL.EXFF(A_N2).ASTALIN <> [V]CST_ALL
   EDIXMLFIL.EXFF(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Return



