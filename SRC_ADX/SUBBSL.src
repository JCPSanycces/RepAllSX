#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion objet BSL
######################################################################################
#    GESTION DES FOURNISSEURS - EXPEDITEURS                                          #
#------------------------------------------------------------------------------------#
# Traitement : SUBBSL                                                                #
# -------------------                                                                #
# Gestion de L'objet BSL lié à la table de liens [F:BSL] : BPSHISUPLN                #
#                                                                                    #
# PARAMETRES provenant de l'action appelante  :                                      #
# Parametre CLE1 : contient le  champs 2 de l'index                                  #
#   CLE1    : Société                                                                #
# Parametre CLE2 : contient les champs 1~3~4 de l'index                              #
#   CLE2(0) : Fournisseur                                                            #
#   CLE2(1) : Expéditeur                                                             #
#   CLE2(2) : Adresse                                                                #
#                                                                                    #
# Détails :                                                                          #
# ---------                                                                          #
# Création/Modification/Suppression de liens correspondant à 1 et 1 seul fournisseur #
# Stockage liens par   : SOCIETE - FOURNISSEUR - EXPEDITEUR - ADDRESSE               #
#                                                                                    #
# Pour chaque lien géré, MAJ des informations relatives à ce fournisseur dans une    #
# table annexe [F:BSS] : BPSHISUPP                                                   #
# Stockage d'infos par : EXPEDITEUR - ADDRESSE                                       #
# 1 couple EXPEDITEUR - ADDRESSE possède les mêmes infos par Société ou Fournisseur  #
#                                                                                    #
# => Utilisation de variables Globales qui utilisent les zones issues du fournisseur #
# courant (Objet BPS) à partir duquel on a appelé la gestion des Expéditeurs         #
# Ces variables sont initialées à l'ouverture du masque et modifiées si on a changé  #
# l'expéditeur par défaut                                                            #
#                                                                                    #
# => La zone Société CPY est rendue invisible si VIDE (en MONO-SOCIETE)              #
######################################################################################
$ACTION
 Case ACTION
  When "OUVRE"              : Gosub OUVRE
  When "AFFMASK"            : Gosub AFFMASK
  When "FILTRE"             : Gosub FILTRE
  When "LIENS"              : Gosub LIENS
  When "RAZCRE"             : Gosub RAZCRE
  When "RAZDUP"             : Gosub RAZDUP
  When "CREATION"           : Gosub CREATION
  When "AVANT_MOD"          : Gosub AVANT_MOD
  When "MODIF"              : Gosub MODIF
  When "FIN_MOD"            : Gosub FIN_MOD
  When "APRES_CRE"          : Gosub APRES_CRE
  When "VERF_ANU"           : Gosub VERF_ANU
  When "ABANDON"            : Gosub ABANDON
  When "ANNULE"             : Gosub ANNULE
  When "SETBOUT"            : Gosub SETBOUT
  When "FERME"              : Gosub FERME
  When "BB2_BPSSHI"         : Gosub BB2_BPSSHI
  When Default
 Endcase
Return

######################################################################################
# ---------------------------------------------------------------------------------- #
#                               ACTIONS OBJET : Objet BSL                            #
# ---------------------------------------------------------------------------------- #
######################################################################################

#########################################################################
$OUVRE
###### A l'entrée
#########################################################################
Global Char    GBPSNUM, GBSGCOD, GBPSCPY, GBPSSHI, GBPSADD
  # Alimentation des variables globales initiales alimentée depuis le masque Fournisseur
  Gosub ALIM_GLOBALES

  If !clalev([F:BSL2])  Local File BPSHISUPLN  [BSL2]  : Endif
  If !clalev([F:BPA2])  Local File BPADDRESS   [BPA2]  : Endif
Return

#########################################################################
$AFFMASK
######## Au chargement du masque avant la lecture de la classe F:BSL
#########################################################################
Return

#########################################################################
$FILTRE
######## Filtrer la liste gauche Principale et Derniers lus et de la Sélection sur Objet
#########################################################################
  # On filtre les couples Expéditeur-Addresse du fournisseur courant et de la Société de ce fournisseur
  FILTSUP += "[F:BSL]BPSNUM = [V]GBPSNUM  &  [F:BSL]CPY = [V]GBPSCPY"
Return

#########################################################################
$BB2_BPSSHI
########### Après l'appel de l'action SELOBJ1 sur le Bouton 2 de la zone [M:BSL0]BPSSHI
#########################################################################
  # On alimente en retour de la sélection les zones : BPSSHI (expéditeur) et BPSADD (addresse) si une saisie a été faite
  If [F:BSL]BPSSHI <> ""
    VALEUR         = [F:BSL]BPSSHI
    [M:BSL0]BPSSHI = [F:BSL]BPSSHI
    [M:BSL0]BPSADD = [F:BSL]BPSADD

    # Couple Expéditeur-Addrese alimenté : => Chargement Complet des masques BSL0, BSL1, BSL2 // Plus a faire si mkstat = 99 ensuite
    # Gosub CHARGE_MASQUES
    # Gosub AFFZO_MASQUES
    # Passage au champs suivant pour une sélection faite sur le bouton n°2
    mkstat = 99
  Endif
Return

#########################################################################
$LIENS
###### Enregistrement trouvé : Après lecture de la classe F:BSL dans les masques BSL0, BSL1, BSL2
#########################################################################
  # Zone Société : mis en invisible si Champs vide dans masque BSL0
  Gosub INIT_BSL0_CPY
  # Chargement Complet des masques BSL0, BSL1, BSL2
  Gosub CHARGE_MASQUES

  # Affichage de tous les masques de la fenêtre
  Gosub AFFZO_MASQUES
Return

#########################################################################
$RAZCRE
####### Avant la saisie en CREATION
#########################################################################
  # Initialisation fournisseur courant : BPSNUM et société : CPY
  Gosub INIT_BSL0
  # Zone Société : mis en invisible si Champs vide
  Gosub INIT_BSL0_CPY
  # Initialisation expéditeur par les informations issues de la catégorie Fournisseur
  Gosub CHARGE_BPSCATEG
  # Initialisation de la zone Transporteur : Grisage
  Gosub GRIZE_BSL1_TRANSPORTEUR
  # Affichage de tous les masques de la fenêtre
  Gosub AFFZO_MASQUES
Return

#########################################################################
$RAZDUP
####### Avant la saisie en DUPLICATION
#########################################################################
  # En duplication, on ne laisse pas l'expéditeur pas défaut s'il l'était pour le précédent
  [M:BSL1]BPAADDFLG = 1
  Affzo [M:BSL1]20
Return

#########################################################################
$CREATION
######### Dans la Transaction de Création, Après Ecriture de l'objet BSL : BPSHISUPLN
#########################################################################
  # Recherche autres Fournisseurs et Création/MAJ BSS et MAJ éventuelle BPS et BPA
  Gosub CREATION_MODIF
  If GOK < 1 
    Return 
  Endif
Return

#########################################################################
$AVANT_MOD
########## Dès qu'un champs est sur le point d'être modifié avant la saisie
#########################################################################
  # Verrouillage de l'adresse BPA pour modification
  Gosub VERROUILLAGE_BPA
  If OK < 1 
    Return 
  Endif
Return

#########################################################################
$MODIF
######### Dans la Transaction de Modification, Après Réécriture de l'objet BSL : BPSHISUPLN
#########################################################################
Local Integer    COUPLE_BSL_TROUVE : [L]COUPLE_BSL_TROUVE = 0

  # Recherche des autres couples Société-Fournisseurs pouvant avoir le même couple Expéditeur-Addresse
  Gosub AVERTIR_EXISTENCE_COUPLES_BSL
  If [L]COUPLE_BSL_TROUVE = 1                                   # Bouton ANNULER de la boite AVERTIR sélectionné
    GOK = 0 : Return 
  Endif
  
  # Recherche autres Fournisseurs et Création/MAJ BSS et MAJ éventuelle BPS et BPA
  Gosub CREATION_MODIF
  If GOK < 1 
    Return 
  Endif
Return

#########################################################################
$FIN_MOD
########## En fin de Modification, le symbole principal est déverrouillé
#########################################################################
  # DéVerrouillage de l'adresse BPA en fin de modification
  Gosub DEVERROUILLAGE_BPA
Return

#########################################################################
$APRES_CRE
######### Après la Transaction de Création, Après écriture de l'objet BSL : BPSHISUPLN
#########################################################################
  # Recherche du nombre de Fournisseurs partageant le même couple Expéditeur-Addresse
  Gosub RECHERCHE_NB_COUPLES_BSL
  Affzo [M:BSL0]15
Return

#########################################################################
$VERF_ANU
######### Avant la transaction de Suppression, Contrôles avant Suppression BSL : BPSHISUPLN
#########################################################################
  # Contrôle : On ne peut pas supprimer un Expéditeur par défaut (Il faut déjà en choisir un autre par Défaut)
  If [M:BSL1]BPAADDFLG = 2
    GERR = 1 : GMESSAGE = mess(377,194,1) : [L]OK = 0 : Return
  Endif
Return

#########################################################################
$ABANDON
######## Abandon en Cr&ation, Duplication, Modification
#########################################################################
  # DéVerrouillage de l'adresse BPA en Abandon
  Gosub DEVERROUILLAGE_BPA
Return

#########################################################################
$ANNULE
######### Pendant la transaction de Suppression, Avant Suppression BSL : BPSHISUPLN
#########################################################################
  # Recherche des autres couples Société-Fournisseurs pouvant avoir le même couple Expéditeur-Addresse
  Gosub RECHERCHE_COUPLES_BSL

  If [L]WBPSNUM = ""                                            # Pas d'autres fournisseurs : On supprime aussi le Couple de BSS
    # Contrôle existence couple Expéditeur-Addrese de BSS dans d'autres fichiers
    Gosub CONTROLE_EXISTENCE_DANS_FICHIERS
    If [L]EXPEDITEUR_TROUVE                                     # Si couple présent : Suppression BSS impossible
      GOK = 0 : Return
    Else    
      Gosub SUPPRESSION_BSS
    Endif
  Endif
Return

#########################################################################
$SETBOUT
######## Au réaffichage de la fenêtre, au changement de clé ou d'enregistrement du brower
#########################################################################
  # Activation Bouton SUPPRIMER qui est grisé sur une gestion OBJET dont la clé est à + de 2 éléments
  CHAINE += "A"
Return

#########################################################################
$FERME
###### A la sortie
#########################################################################
  # Suppression des variables globales en sortie du masque
  Kill [V]GBPSNUM, [V]GBSGCOD, [V]GBPSCPY, [V]GBPSSHI, [V]GBPSADD
Return


######################################################################################
# ---------------------------------------------------------------------------------- #
#                               ACTIONS CHAMPS : Ecran BPSSHI0  (BSL0)               #
# ---------------------------------------------------------------------------------- #
######################################################################################

Subprog C_BPSSHI(VALEUR)
Variable Char    VALEUR()
Local    Char    WBPSNUM
  # Contrôle existence Fournisseur et vérification Fournisseur Actif
  If VALEUR <> "" & VALEUR <> [V]GBPSNUM
    [L]WBPSNUM = VALEUR
    Gosub LECTURE_BPS
    If [F:BPS]BPSNUM = ""                                      # Fournisseur inexistant
      mkstat = 2 : GMESSAGE = mess(373,194,1) - ":" - [L]WBPSNUM : End
    Elsif [F:BPS]ENAFLG <> 2                                   # Fournisseur inactif
      mkstat = 2 : GMESSAGE = mess(140,199,1) - ":" - [L]WBPSNUM : End
    Endif
  Endif
End

Subprog AM_BPSSHI(VALEUR)
Variable Char    VALEUR()
  [M:BSL0]BPSSHI = VALEUR

  # Alimentation de la Raison sociale
  Gosub ALIM_BSL1_BPSNAM

  # Recherche si Lien Société-Fournisseur-Expéditeur-Addresse présent
  Look [BSL2] BSL0 = [M:BSL0]BPSNUM;[M:BSL0]CPY;[M:BSL0]BPSSHI;[M:BSL0]BPSADD
  If fstat                                                      # Lien Fournisseur-Expéditeur non trouvé dans BSL
    Gosub RAZ_BPSADD
  Endif
  Affzo [M:BSL0]10
  Affzo [M:BSL1]20
End

Subprog C_BPSADD(VALEUR)
Variable Char    VALEUR()
  # Contrôle existence Code adresse du Fournisseur
  If VALEUR <> ""
    Look [BPA2] BPA0 = 1;[M:BSL0]BPSSHI;VALEUR
    If fstat
      mkstat = 2 : GMESSAGE = mess(533,199,1) - mess(2,242,1) - ":" - [M:BSL0]BPSSHI : End
    Endif
  Endif
End

Subprog AM_BPSADD(VALEUR)
Variable Char    VALEUR()
Local Integer    COUPLE_BSL_TROUVE : [L]COUPLE_BSL_TROUVE = 0

  [M:BSL0]BPSADD = VALEUR

  # Contrôle couple Expéditeur-Addresse présent pour d'autres fournisseurs
  Look [BSL2] BSL0 = [M:BSL0]BPSNUM;[M:BSL0]CPY;[M:BSL0]BPSSHI;[M:BSL0]BPSADD
  If fstat                                                      # Le lien n'existe pas pour le fournisseur courant
    # Recherche des autres couples Société-Fournisseurs pouvant avoir le même couple Expéditeur-Addresse
    Gosub AVERTIR_EXISTENCE_COUPLES_BSL
  Endif

  Case [L]COUPLE_BSL_TROUVE
    When  1                                                     # Bouton ANNULER de la boite AVERTIR sélectionné
      Gosub RAZ_BPSADD : Raz VALEUR : Affzo [M:BSL0]BPSDES : mkstat = 2 : End
    When  2                                                     # Couple Expéditeur-Addresse trouvé pour d'autres fournisseurs
      # Chargement Complet des masques BSL0, BSL1, BSL2
      Gosub CHARGE_MASQUES
    When Default                                                # Nouveau Couple Expéditeur-Adresse
      # Mise à 0 du compteur de nombre de Fournisseurs partageant le même couple Expéditeur-Addresse
      Raz [M:BSL0]NBSHI
      # Alimentation des informations Adresse et du Pays/Code postal de l'Addresse
      Gosub ALIM_ADRESSE
  Endcase

  # Affichage de tous les masques de la fenêtre
  Gosub AFFZO_MASQUES
End


######################################################################################
# ---------------------------------------------------------------------------------- #
#                               ACTIONS CHAMPS : Ecran BPSSHI1  (BSL1)               #
# ---------------------------------------------------------------------------------- #
######################################################################################

Subprog C_ENAFLG(VALEUR)
Variable Integer VALEUR
Local    Char    WBPSNUM : [L]WBPSNUM = ""
  # Contrôle que le couple Expéditeur-Adresse n'est pas par défaut d'un autre fournisseur
  If VALEUR <> 2
    If [M:BSL1]BPAADDFLG = 2                                    # L'expéditeur par défaut ne doit pas être inactif
      mkstat = 2 : GMESSAGE = mess(376,194,1) : End 
    Endif

    For [BPS] Where BPSSHI = [M:BSL0]BPSSHI and BPSADD = [M:BSL0]BPSADD and BPSNUM <> [M:BSL0]BPSNUM
      If [L]WBPSNUM = ""
        [L]WBPSNUM = [F:BPS]BPSNUM
      Else
        [L]WBPSNUM = WBPSNUM - "-" - [F:BPS]BPSNUM
      Endif
    Next

    If [L]WBPSNUM <> ""                                         # Fournisseur(s) trouvé(s)
      mkstat = 2 : GMESSAGE = mess(375,194,1) - ":" - [L]WBPSNUM : End 
    Endif
  Endif
End

Subprog C_BPAADDFLG(VALEUR)
Variable Integer VALEUR
  # L'expéditeur par défaut ne doit pas être inactif
  If VALEUR = 2  & [M:BSL1]ENAFLG <> 2
    mkstat = 2 : GMESSAGE = mess(376,194,1) : End 
  Endif

  # On ne peut pas désactiver un Expéditeur par défaut : Choisir un autre expéditeur
  If VALEUR <> 2  &  [M:BSL0]BPSSHI = [V]GBPSSHI  &  [M:BSL0]BPSADD = [V]GBPSADD
    VALEUR = 2  : End 
  Endif
End

Subprog AM_FFWNUM(VALEUR)
Variable Char    VALEUR()
Local    Char    WBPSNUM
  If VALEUR <> ""                                               # Transporteur vide : on grise le code adresse
  # Lecture du Partner expéditeur : BPR
    [M:BSL1]FFWNUM = VALEUR
    [L]WBPSNUM = [M:BSL1]FFWNUM
    Gosub LECTURE_BPR
   
    [M:BSL1]FFWADD = [F:BPR]BPAADD 
    Affzo [M:BSL1]FFWADD : Actzo [M:BSL1]FFWADD
    
    # Recherche de l'intitulé du Code addresse du transporteur
    Gosub ALIM_BSL1_FFWADDDES
  Else
    Raz [M:BSL1]FFWADD,[M:BSL1]FFWADDDES : Affzo [M:BSL1]FFWADD : Diszo [M:BSL1]FFWADD : End 
  Endif

  Affzo [M:BSL1]FFWADDDES
End

Subprog C_FFWADD(VALEUR)
Variable Char    VALEUR()
  # Vérification code adresse existe pour le transporteur sélectionné
  Look [BPA2] BPA0 = 1;[M:BSL1]FFWNUM;VALEUR
  If fstat 
    mkstat = 2 : GMESSAGE = mess(16,199,1) : End
  Endif
End

Subprog AM_FFWADD(VALEUR)
Variable Char    VALEUR()
  # Recherche de l'intitulé du Code addresse du transporteur
  [M:BSL1]FFWADD = VALEUR
  Gosub ALIM_BSL1_FFWADDDES
  
  Affzo [M:BSL1]FFWADDDES
End

######################################################################################
# ---------------------------------------------------------------------------------- #
#                               ACTIONS CHAMPS : Ecran BPSSHI2  (BSL2)               #
# ---------------------------------------------------------------------------------- #
######################################################################################

Subprog AM_BPADES(VALEUR)
Variable Char    VALEUR()
  # Si désignation d'adresse modifiée, on MAJ le champs sur le masque BSL1
  # FGR : [M:BSL1]BPADES n'existe pas
  #[M:BSL1]BPADES = VALEUR
  #Affzo [M:BSL1]BPADES
End

Subprog C_CRY(VALEUR)
Variable Char    VALEUR()
Local    Char    WBPSCRY
  # Lecture TABCOUNTRY
  [L]WBPSCRY = VALEUR
  Gosub LECTURE_TCY

  # Grisage/Dégrisage de la Province et du Nom du pays
  If [F:TCY]ETAT <> 2
    Effzo [M:BSL2]SAT
  Endif
  Gosub GRIZE_BSL2_PROVINCE

  [M:BSL2]CRY = VALEUR
  Gosub GRIZE_BSL2_NOMPAYS
End

Subprog AM_CRY(VALEUR)
Variable Char    VALEUR()
  # Si Modification du champs PAYS : MAJ du champs invisible du Masque BSL1
  [M:BSL1]BPSCRY = VALEUR
End

Subprog AM_POSCOD(VALEUR)
Variable Char    VALEUR()
  # Si Modification du champs POSCOD : MAJ du champs invisible du Masque BSL1
  [M:BSL1]BPSPOSCOD = VALEUR
End

Subprog AS_SAT(VALEUR)
Variable Char    VALEUR()
Local    Char    WBPSCRY
  # Lecture TABCOUNTRY
  [L]WBPSCRY = VALEUR
  Gosub LECTURE_TCY

  If [F:TCY]ETAT <> 2
    mkstat = 1
  Endif
End


######################################################################################
# ---------------------------------------------------------------------------------- #
#                               ETIQUETTES APPELEES : Traitement SUBBSL              #
# ---------------------------------------------------------------------------------- #
######################################################################################

$ALIM_GLOBALES
############## Appelé depuis AFFMASK
Local    Char    WBPSNUM
  Raz [V]GBPSNUM, [V]GBSGCOD, [V]GBPSCPY, [V]GBPSSHI, [V]GBPSADD

  # Recherche des valeurs passées en paramètre de l'ACTION : SOCIETE et FOURNISSEUR
  # CLE1 : société
  # CLE2 : Fournisseur~Expéditeur~Adresse (mis par le superviseur dans un tableau CLE2)
  [V]GBPSCPY = CLE1
  [V]GBPSNUM = CLE2(0)
  
  # Recherche des informations du Fournisseur : CATEGORIE , EXPEDITEUR et ADRESSE-EXPEDITEUR
  [L]WBPSNUM = [V]GBPSNUM
  Gosub LECTURE_BPS
  If [F:BPS]BPSNUM <> ""
    [V]GBSGCOD = [F:BPS]BSGCOD
    [V]GBPSSHI = [F:BPS]BPSSHI    #CHECK IGNORE_LINE
    [V]GBPSADD = [F:BPS]BPSADD    #CHECK IGNORE_LINE
  Endif
Return

$INIT_BSL0_CPY
############## Appelé depuis RAZCRE et LIENS
  # Mécanique permettant de rendre Invisible le champs Société s'il est à vide
  # Si on est en Multi-Société, le société n'est pas vide et est affichée en non modifiable
  #   [M:BSL0]CPY dans le masque doit avoir un format évalué (=[M:BSL0]CPYFMT)
  #   [M:BSL0]CPYFMT est invisible et reçoit le format de la zone société [M:BSL0]CPY
  #   [V]GLONCPY contient la longueur de la zone société
  If [M:BSL0]CPY = ""
    [M:BSL0]CPYFMT = "-K:" + num$([V]GLONCPY) + "X"
  Else
    [M:BSL0]CPYFMT = "KP:" + num$([V]GLONCPY) + "X"
  Endif
Return

$INIT_BSL0
########## Appelé depuis RAZCRE
  # Chargement du Fournisseur et de la société du Fournisseur courant
  [M:BSL0]BPSNUM = [V]GBPSNUM
  [M:BSL0]CPY    = [V]GBPSCPY
Return

$CHARGE_BPSCATEG
############## Appelé depuis RAZCRE
Local Char    WBPSCOD

  # Recherche des informations par défaut dans la Catégorie Fournisseur
  [L]WBPSCOD = [V]GBSGCOD
  Gosub LECTURE_BSG

  [M:BSL1]          = [F:BSG]
  [M:BSL1]EECICT    = [F:BSG]EECICT2
  [M:BSL1]UVYCOD    = [F:BSG]UVYCOD2
  # Informations CEE soumis au code Activité : DEB
  If dim([M:BSL1]EECINCRAT)>0
    [M:BSL1]EECINCRAT = [F:BSG]EECINCRAT2
  Endif
  If dim([M:BSL1]EECLOC)>0
    [M:BSL1]EECLOC    = [F:BSG]EECLOC2
  Endif
Return

$CHARGE_MASQUES
############### Appelé depuis LIENS et BB2_BPSSHI et AM_BPSADD
  #-----------------------------------------------------------#
  # A CHAQUE LECTURE ENREGISTREMENT EXPEDITEUR (BPSHISUPP)    #
  # --> il faut lire l'enregistrement addresse (BPADDRESS)    #
  #-----------------------------------------------------------#
  # Alimentation zones Fournisseur et Expéditeurs du masque
  Gosub CHARGE_INFOS_BSS
  # Alimentation zones annexes du masque comme l'expéditeur par défaut
  Gosub ALIM_AUTRES_ZONES
  # Alimentation de la désignation du Transporteur
  Gosub ALIM_BSL1_FFWADDDES
  # Alimentation de la zone Transporteur : Grisage/Dégrisage
  Gosub GRIZE_BSL1_TRANSPORTEUR
Return

$AFFZO_MASQUES
##################### Appelé depuis AM_BPSADD et LIENS et RAZCRE
  # Affichage de tous les masques de la fenêtre
  Affzo [M:BSL0]1-99
  Affzo [M:BSL1]1-99
  Affzo [M:BSL2]1-99
Return

$CHARGE_INFOS_BSS
################# Appelé depuis CHARGE_MASQUES (par LIENS et BB2_BPSSHI et AM_BPSADD)
Local Char    WBPSNUM, WBPSADD

  # Chargement des informations du couple Expéditeur-Addresse de BSS : BPSHISUPP
  [L]WBPSNUM = [M:BSL0]BPSSHI
  [L]WBPSADD = [M:BSL0]BPSADD
  Gosub LECTURE_BSS

  [M:BSL1]         = [F:BSS]
  [M:BSL1]BPSNAM0  = [F:BSS]BPSNAM(0)
  [M:BSL1]BPSNAM1  = [F:BSS]BPSNAM(1)

  If [F:BSS]BPSSHI = ""  |  [F:BSS]BPSADD = ""                  # Si lien BSL existant mais couple BSS Expéditeur-Addresse inexistant
    [M:BSL0]BPSSHI = [L]WBPSNUM
    [M:BSL0]BPSADD = [L]WBPSADD
  Endif

  # recherche du nombre de Fournisseurs partageant le même couple Expéditeur-Addresse
  Gosub RECHERCHE_NB_COUPLES_BSL
Return

$ALIM_AUTRES_ZONES
####################### Appelé depuis CHARGE_MASQUES (par LIENS et BB2_BPSSHI et AM_BPSADD)
  # Alimentation de code Expéditeur par Défaut
  If [M:BSL0]BPSSHI = [V]GBPSSHI  &  [M:BSL0]BPSADD = [V]GBPSADD
    [M:BSL1]BPAADDFLG = 2
  Else
    [M:BSL1]BPAADDFLG = 1
  Endif

  # Alimentation des informations Adresse et du Pays/Code postal de l'Addresse
  Gosub ALIM_ADRESSE
Return

$ALIM_BSL1_BPSNAM
################# appelé depuis AM_BPSSHI
Local Char    WBPSNUM

  # Lecture du Partner expéditeur : BPR
  [L]WBPSNUM = [M:BSL0]BPSSHI
  Gosub LECTURE_BPR

  [M:BSL1]BPSNAM0 = [F:BPR]BPRNAM(0)
  [M:BSL1]BPSNAM1 = [F:BPR]BPRNAM(1)
Return

$ALIM_ADRESSE
############# Appelé depuis AM_BPSADD et ALIM_AUTRES_ZONES (par CHARGE_MASQUES par LIENS et BB2_BPSSHI et AM_BPSADD)
Local Char    WBPSNUM, WBPSADD, WBPSCRY

  # Lecture de l'addresse de l'Expéditeur
  [L]WBPSNUM = [M:BSL0]BPSSHI
  [L]WBPSADD = [M:BSL0]BPSADD
  Gosub LECTURE_BPA

  # Alimentation masque BSL0 : Désignation Adresse
  [M:BSL0]BPSDES      = [F:BPA]BPADES

  # Alimentation masque BSL1 : Pays et Code postal (zones invisibles) pour les types de données :
  #   - CTY de la zone ICTCTY : Ville Incoterm
  #   - EEC de la zone EECNUM : Identification CEE
  [M:BSL1]BPSCRY      = [F:BPA]CRY
  [M:BSL1]BPSPOSCOD   = [F:BPA]POSCOD

  # Alimentation masque BSL2 : Informations Adresse
  [M:BSL2]            = [F:BPA]
  [M:BSL2]ADDLIG1     = [F:BPA]BPAADDLIG(0)
  [M:BSL2]ADDLIG2     = [F:BPA]BPAADDLIG(1)
  [M:BSL2]ADDLIG3     = [F:BPA]BPAADDLIG(2)
  
  # Lecture TABCOUNTRY
  [L]WBPSCRY = [M:BSL2]CRY
  Gosub LECTURE_TCY
  Gosub GRIZE_BSL2_PROVINCE
  Gosub GRIZE_BSL2_NOMPAYS
Return

$ALIM_BSL1_FFWADDDES
#################### Appelé depuis AM_FFWNUM et AM_FFWADD et CHARGE_MASQUES (par LIENS et BB2_BPSSHI et AM_BPSADD)
Local Char    WBPSNUM, WBPSADD

  # Alimentation de l'addresse du transporteur de l'expéditeur
  [L]WBPSNUM = [M:BSL1]FFWNUM
  [L]WBPSADD = [M:BSL1]FFWADD
  Gosub LECTURE_BPA2

  [M:BSL1]FFWADDDES = [F:BPA2]BPADES
Return

$RAZ_BPSADD
########### Appelé depuis AM_BPSSHI et AM_BPSADD
  Raz [M:BSL0]BPSADD, BPSDES
  Raz [M:BSL1]BPSCRY, BPSPOSCOD
Return

$GRIZE_BSL1_TRANSPORTEUR
######################## Appelé depuis RAZCRE et CHARGE_MASQUES (par LIENS et BB2_BPSSHI et AM_BPSADD)
  # Activation/Désactivation du code addresse du transporteur
  If [M:BSL1]FFWNUM = "" 
    Diszo [M:BSL1]FFWADD 
  Else 
    Actzo [M:BSL1]FFWADD 
  Endif
Return

$GRIZE_BSL2_PROVINCE
#################### Appelé depuis ALIM_ADRESSE (par AM_BPSADD et CHARGE_MASQUES par LIENS et BB2_BPSSHI et AM_BPSADD)
  # Activation/Désactivation du code province
  Gosub TITRES From = 'W1' + 'BPSSHI2'

  If [F:TCY]ETAT <> 2
    Grizo [M:BSL2]SAT
  Else
    Actzo [M:BSL2]SAT
  Endif
Return

$GRIZE_BSL2_NOMPAYS
################### Appelé depuis ALIM_ADRESSE (par AM_BPSADD et CHARGE_MASQUES par LIENS et BB2_BPSSHI et AM_BPSADD)
  If [M:BSL2]CRYNAM <> ""
    Diszo [M:BSL2]CRYNAM 
  Else
    Actzo [M:BSL2]CRYNAM
  Endif
Return

$RECHERCHE_NB_COUPLES_BSL
########################## Appelé depuis CHARGE_INFOS_BSS (par LIENS et AM_BPSADD et BB2_BPSSHI) et APRES_CRE
  # Recherche du nombre de fournisseurs pouvant avoir le même couple Expéditeur-Addresse indépendemment de la société CPY
  Filter [BSL2]  Where BPSSHI = [M:BSL0]BPSSHI and BPSADD = [M:BSL0]BPSADD
  [M:BSL0]NBSHI = rowcount([BSL2])
  Filter [BSL2]
Return

$AVERTIR_EXISTENCE_COUPLES_BSL
############################## Appelé depuis MODIF et AM_BPSADD
# Variables devant être préalablement positionnées : COUPLE_BSL_TROUVE
  # Recherche des autres liens possibles dans BSL
  Gosub RECHERCHE_COUPLES_BSL

  # [L]COUPLE_BSL_TROUVE = 2 : Bouton OK      de la boite AVERTIR sélectionné 
  # [L]COUPLE_BSL_TROUVE = 1 : Bouton ANNULER de la boite AVERTIR sélectionné
  # [L]COUPLE_BSL_TROUVE = 0 : Pas de couples BSL partagés par d'autres fournisseurs
  If [L]WBPSNUM = ""                                          # Pas d'autres fournisseurs
    Return
  Else                                                        # D'autres fournisseurs partagent le couple Expéditeur-Addresse
    GMESSAGE = mess(374,194,1) - num$([L]WNBBSL) - mess(457,198,1) - ":" - [L]WBPSNUM
    Call AVERTIR(GMESSAGE,[L]COUPLE_BSL_TROUVE) From GESECRAN
    Raz GMESSAGE : Return
  Endif
Return

$RECHERCHE_COUPLES_BSL
###################### Appelé depuis ANNULE et AVERTIR_EXISTENCE_COUPLE_BSL (par AM_BPSADD et MODIF)
Local Char       WBPSNUM           : [L]WBPSNUM = ""
Local Integer    WNBBSL            : [L]WNBBSL  = 0

  # Recherche des autres fournisseurs pouvant avoir le même couple Expéditeur-Addresse indépendemment de la Société CPY
  For [BSL2]BSL1  Where (BPSNUM <> [M:BSL0]BPSNUM or CPY <> [M:BSL0]CPY) and BPSSHI = [M:BSL0]BPSSHI and BPSADD = [M:BSL0]BPSADD
    If [L]WBPSNUM = ""
      [L]WBPSNUM = [F:BSL2]BPSNUM
    Else
      [L]WBPSNUM = [L]WBPSNUM - "/" - [F:BSL2]BPSNUM
    Endif
    [L]WNBBSL += 1
  Next
Return

$CONTROLE_EXISTENCE_DANS_FICHIERS
################################# Appelé depuis ANNULE
Local Integer    EXPEDITEUR_TROUVE : [L]EXPEDITEUR_TROUVE = 0
Local Integer    WNBBSL            : [L]WNBBSL  = 0

  # Vérification existence couple Expéditeur-Adresse dans : Commandes
  If !clalev([F:POH])  Local File PORDER [POH]  : Endif
  Filter [POH] Where BPSSHI = [M:BSL0]BPSSHI  &  BPOADD = [M:BSL0]BPSADD
  [L]WNBBSL = rowcount([POH])
  Read [POH]POH0 First
  Filter [POH]
  If !fstat 
    [L]EXPEDITEUR_TROUVE = 1 
    GMESSAGE = mess(374,194,1) - num$([L]WNBBSL) - mess(48,198,1) - ":" - POHNUM - "..." : Return 
  Endif

  # A COMPLETER LE CAS ECHEANT : DEBUT #
  # Vérification existence couple Expéditeur-Adresse dans : 
  #
  # A COMPLETER LE CAS ECHEANT : FIN   #
Return

$CREATION_MODIF
########### Appelé depuis CREATION et MODIF
  # Création des informations du couple Expéditeur-Adresse dans BSS : BPSHISUPP
  Gosub CREATION_BSS
  If GOK < 1
    Return 
  Endif

  # Création ou MAJ des Informations Adresse dans BPA : BPADDRESS
  Gosub CREATION_BPA
  If GOK < 1
    Return 
  Endif

  # MAJ de l'expéditeur par défaut s'il a changé !
  Gosub MAJ_BPS
  If GOK < 1 
    Return 
  Endif

Return

$CREATION_BSS
####### Appelé depuis CREATION_MODIF (par CREATION et MODIF)
  # Lecture avec LOCK de l'enregistrement BSS
  Gosub LECTURE_BSS_LOCK
  If GOK < 1 
    Return 
  Endif

  # Remplissage zones du masque
  [F:BSS] = [M:BSL0]
  [F:BSS] = [M:BSL1]

  # Remplissage autres zones du masque
  [F:BSS]BPSNAM(0) = [M:BSL1]BPSNAM0
  [F:BSS]BPSNAM(1) = [M:BSL1]BPSNAM1

  # MAJ des zones systèmes
  If [L]BSS_PRESENT
    [F:BSS]UPDDAT  = date$
    [F:BSS]UPDUSR  = GUSER
    Rewrite [BSS]
  Else
    [F:BSS]CREDAT  = date$
    [F:BSS]CREUSR  = GUSER
    Write [BSS]
  Endif

  If fstat
    GOK = 0 : Call FSTA("BSS") From GLOCK : Return
  Endif
Return

$CREATION_BPA
####### Appelé depuis CREATION_MODIF (par CREATION et MODIF)
  # Lecture avec LOCK de l'enregistrement BPA
  Gosub LECTURE_BPA_LOCK
  If GOK < 1 
    Return 
  Endif

  # Remplissage zones du masque
  [F:BPA] = [M:BSL2]

  # Remplissage autres zones du masque
  [F:BPA]BPATYP       = 1
  [F:BPA]BPANUM       = [M:BSL0]BPSSHI
  [F:BPA]BPAADD       = [M:BSL0]BPSADD
  [F:BPA]BPAADDLIG(0) = [M:BSL2]ADDLIG1
  [F:BPA]BPAADDLIG(1) = [M:BSL2]ADDLIG2
  [F:BPA]BPAADDLIG(2) = [M:BSL2]ADDLIG3

  # MAJ des zones systèmes
  If [L]BPA_PRESENT
    [F:BPA]UPDDAT     = date$
    [F:BPA]UPDTIM     = time  
    [F:BPA]UPDUSR     = GUSER
    Rewrite [BPA]
  Else
    [F:BPA]CREDAT     = date$
    [F:BPA]CRETIM     = time  
    [F:BPA]CREUSR     = GUSER
    Write [BPA]
  Endif

  If fstat
    GOK = 0 : Call FSTA("BPA") From GLOCK : Return
  Endif
Return

$MAJ_BPS
####### Appelé depuis CREATION_MODIF (par CREATION et MODIF)
  # Un nouveau couple Expéditeur-Adresse a été mis par défaut
  # Si L'expéditeur ou l'addresse par défaut ont changé :
  #   On MAJ le fournisseur (Et dans l'objet BPS, on force le réaffichage du masque dans l'étiquette EXEBOUT)
  If [M:BSL1]BPAADDFLG = 2  &  ([M:BSL0]BPSSHI <> [V]GBPSSHI | [M:BSL0]BPSADD <> [V]GBPSADD)
    Update [BPS] Where BPSNUM = [V]GBPSNUM  With BPSSHI = [M:BSL0]BPSSHI, BPSADD = [M:BSL0]BPSADD
    If fstat
      GOK = 0 : Call FSTA("BPS") From GLOCK : Return
    Else
      [V]GBPSSHI = [M:BSL0]BPSSHI
      [V]GBPSADD = [M:BSL0]BPSADD
    Endif
  Endif
Return

$SUPPRESSION_BSS
################ Appelé depuis ANNULE
  # Lecture avec LOCK de l'enregistrement BSS
  Gosub LECTURE_BSS_LOCK
  If GOK < 1 
    Return 
  Endif

  # Si enregistrement Trouvé : Suppression
  If [L]BSS_PRESENT
    Delete [BSS]
    If fstat
      GOK = 0 : Call FSTA("BSS") From GLOCK : Return
    Endif
  Endif
Return

$LECTURE_BSS_LOCK
################# Appelé depuis SUPPRESSION_BSS (par ANNULE) et CREATION_BSS (par CREATION_MODIF : CREATION et MODIF)
Local Integer BSS_PRESENT

  # Lecture avec LOCK des informations Expéditeur-Adresse dans BPSHISUPP
  Readlock [BSS]BSS0 = [M:BSL0]BPSSHI;[M:BSL0]BPSADD
  Case fstat
    When 1                                                      # Enregistrement Trouvé mais vérouillé
      GOK = -1 : GLOCK = "$BPSHISUPP" - [M:BSL0]BPSSHI - [M:BSL0]BPSADD : Return
    When 0                                                      # Enregistrement     Trouvé OK
      [L]BSS_PRESENT = 1
    When 5                                                      # Enregistrement Non Trouvé OK
      [L]BSS_PRESENT = 0
    When Default                                                # Enregistrement en erreur
      GOK = 0 : Call RSTA("BSS",[M:BSL0]BPSSHI-[M:BSL0]BPSADD) From GLOCK : Return
  Endcase
Return

$LECTURE_BPA_LOCK
################# Appelé depuis CREATION_BSS (par CREATION_MODIF : CREATION et MODIF)
Local Integer BPA_PRESENT

  # Lecture avec LOCK des informations Adresse dans BPADDRESS
  Readlock [BPA]BPA0 = 1;[M:BSL0]BPSSHI;[M:BSL0]BPSADD
  Case fstat
    When 1                                                      # Enregistrement Trouvé mais vérouillé
      GOK = -1 : GLOCK = "$BPADDRESS" - [M:BSL0]BPSSHI - [M:BSL0]BPSADD : Return
    When 0                                                      # Enregistrement     Trouvé OK
      [L]BPA_PRESENT = 1
    When 5                                                      # Enregistrement Non Trouvé OK
      [L]BPA_PRESENT = 0
    When Default                                                # Enregistrement en erreur
      GOK = 0 : Call RSTA("BPA",[M:BSL0]BPSSHI-[M:BSL0]BPSADD) From GLOCK : Return
  Endcase
Return

$VERROUILLAGE_BPA
################# Appelé depuis AVANT_MOD
  # verrouillage symbole : BPA
  Gosub VERROU_INIT_SYMBOLE2
  Lock = SYMBOLE2 With lockwait = 0
  
  OK = 1
  If fstat
    GERR=1 : GMESSAGE = mess(10,100,1) : OK = 0
  Endif
Return

$DEVERROUILLAGE_BPA
################### Appelé depuis ABANDON et FIN_MOD
  # Deverrouillage symbole : BPA
  Gosub VERROU_INIT_SYMBOLE2
  Unlock = SYMBOLE2
Return

$VERROU_INIT_SYMBOLE2
##################### Appelé depuis VERROUILLAGE_BPA et DEVERROUILLAGE_BPA
Local Char SYMBOLE2 (20)
  # Initialisation du Symbole pour Lock ou Unlock de : BPA
  SYMBOLE2 ="BPA" + num$(1) + num$([M:BSL0]BPSSHI) + num$([M:BSL0]BPSADD)
Return

$LECTURE_BSS
############ Appelé depuis CHARGE_INFOS_BSS (par LIENS et AM_BPSADD et BB2_BPSSHI)
# Variables devant être préalablement positionnées : WBPSNUM, WBPSADD
  If [L]WBPSNUM <> ""  &  [L]WBPSADD <> "" 
    If [F:BSS]BPSSHI <> [L]WBPSNUM  |  [F:BSS]BPSADD <> [L]WBPSADD
      Read [BSS]BSS0 = [L]WBPSNUM;[L]WBPSADD
      If fstat                                                  # Fournisseur inexistant
        Raz [F:BSS]
      Endif
    Endif
  Else
    Raz [F:BSS]
  Endif
Return

$LECTURE_BSG
############ Appelé depuis CHARGE_BPSCATEG
# Variables devant être préalablement positionnées : WBPSCOD
  If [L]WBPSCOD <> ""
    If [F:BSG]BSGCOD <> [L]WBPSCOD
      Read [BSG]BSG0 = [L]WBPSCOD
      If fstat                                                  # Categorie fournisseur inexistante
        Raz [F:BSG]
      Endif
    Endif
  Else
    Raz [F:BSG]
  Endif
Return

$LECTURE_BPA
############ Appelé depuis ALIM_ADRESSE
# Variables devant être préalablement positionnées : WBPSNUM, WBPSADD
  If [L]WBPSNUM <> "" & [L]WBPSADD <> ""
    If [F:BPA]BPATYP <> 1  |  [F:BPA]BPANUM <> [L]WBPSNUM  |  [F:BPA]BPAADD <> [L]WBPSADD
      Read [BPA] BPA0 = 1;[L]WBPSNUM;[L]WBPSADD
      If fstat                                                  # Addresse Fournisseur inexistante
        Raz [F:BPA]
      Endif
    Endif
  Else
    Raz [F:BPA]
  Endif
Return

$LECTURE_BPA2
############# Appelé depuis ALIM_BSL1_FFWADDDES
# Variables devant être préalablement positionnées : WBPSNUM, WBPSADD
  If [L]WBPSNUM <> "" & [L]WBPSADD <> ""
    If [F:BPA2]BPATYP <> 1  |  [F:BPA2]BPANUM <> [L]WBPSNUM  |  [F:BPA2]BPAADD <> [L]WBPSADD
      Read [BPA2] BPA0 = 1;[L]WBPSNUM;[L]WBPSADD
      If fstat                                                  # Addresse Fournisseur inexistante
        Raz [F:BPA2]
      Endif
    Endif
  Else
    Raz [F:BPA2]
  Endif
Return

$LECTURE_BPS
############# Appelé depuis C_BPSSHI
# Variables devant être préalablement positionnées : WBPSNUM
  If [L]WBPSNUM <> ""
    If [L]WBPSNUM <> [F:BPS]BPSNUM
      Read [BPS]BPS0 = [L]WBPSNUM
      If fstat                                                  # Fournisseur inexistant
        Raz [F:BPS]
      Endif
    Endif
  Else
    Raz [F:BPS]
  Endif
Return

$LECTURE_BPR
############ Appelé depuis ALIM_BSL1_BPSNAM (par AM_BPSSHI)
# Variables devant être préalablement positionnées : WBPSNUM
  If [L]WBPSNUM <> ""
    If [F:BPR]BPRNUM <> [L]WBPSNUM
      Read [BPR]BPR0 = [L]WBPSNUM
      If fstat                                                  # Business Partner inexistant
        Raz [F:BPR]
      Endif
    Endif
  Else
    Raz [F:BPR]
  Endif
Return

$LECTURE_TCY
############ Appelé depuis AM_BPSADD et C_CRY et AS_SAT et AM_et ALIM_ADRESSE (par CHARGE_MASQUES par LIENS et BB2_BPSSHI et AM_BPSADD)
# Variables devant être préalablement positionnées : WBPSCRY
  If [L]WBPSCRY <> ""
    If [F:TCY]CRY <> [L]WBPSCRY
      Read [TCY]TCY0 = [L]WBPSCRY
      If fstat                                                  # Pays inexistant
        Raz [F:TCY]
      Endif
    Endif
  Else
    Raz [F:TCY]
  Endif
Return

