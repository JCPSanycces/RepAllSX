#<AdxTL>@(#)0.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
Local Char PARAM(20) (1..9)
Call GCONSULT("AWM","",PARAM)From GCONSULT
End

#########################################################################
# APPLICATION BUILDER - WORKFLOW MONITOR
# ACTIONS SUR L'OBJET GCONSULT                 
#########################################################################


#--    Exécution boutons
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$EXEBOUT
Case BOUT
When "I"
    If FLAGNBCRIT > 0 : FLAGNBCRIT  -= 1  : Endif
    # décalage des critéres
    For I= 0 To MAXNBCRIT - 1 
        # clés de début 
        CLEDEBM1(I)=CLEDEBM1(I+1) : CLEDEBM2(I)= CLEDEBM2(I+1) : CLEDEBM3(I)= CLEDEBM3(I+1)
        # critére
        NATURE_M(I)=NATURE_M(I+1)
        INFORM_M(I)=INFORM_M(I+1)
        CREUSR_M(I)=CREUSR_M(I+1)
        DATDEB_M(I)=DATDEB_M(I+1)
        DATFIN_M(I)=DATFIN_M(I+1)
        RETOUR_M(I)=RETOUR_M(I+1)
    Next
    # dernier critére saisi 
    [M:AWM1]NATURE=NATURE_M(0)
    [M:AWM1]INFORM=INFORM_M(0)
    [M:AWM1]CREUSR=CREUSR_M(0)
    [M:AWM1]DATDEB=DATDEB_M(0)
    [M:AWM1]DATFIN=DATFIN_M(0)
    CLEDEB1=CLEDEBM1(0) : CLEDEB2=CLEDEBM2(0) : CLEDEB3=CLEDEBM3(0)
    # affichage GCONSULT
    OK=2    : FLAGCRIT = 2
Endcase
Return

#--    Lecture
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$LECTURE
#Infbox "lecture"-num$(CHGPAG)-" nblu" -num$(NBLU)-" max" -num$(MAXLIG)

# Gestion bouton
If CHGPAG>0
    SUITE=1
    If CHGPAG=1 : RETOUR=1: Elsif CHGPAG=2 : RETOUR=2 : Endif
Else
    RETOUR=1
    If CHGPAG=-1 : SUITE=1: Else : SUITE=2 : Endif
Endif
If CHGPAG <> 2 & CHGPAG <>-2 : Raz [AWM2] : Endif

# Hors recherche modification des critères interdites 
If CHGPAG <> 1 
    [M:AWM1]NATURE = NATURE_M(0)
    [M:AWM1]INFORM = INFORM_M(0)
    [M:AWM1]CREUSR = CREUSR_M(0)
    [M:AWM1]DATDEB = DATDEB_M(0)
    [M:AWM1]DATFIN = DATFIN_M(0)
Endif


# Constitution du filtre uniquement en recherche
If CHGPAG = 1
    Raz FILTFIC
    FILTREWRK="1=1"
    Case [M:AWM1]NATURE    
    When ""                              # sans nature
       Case [M:AWM1]CREUSR
       When ""                              # sans emetteur
           Case [M:AWM1]DATDEB
           When "000000"                         # sans date de debut
               Case [M:AWM1]DATFIN
               When "000000"                          # sans date de fin
                    FILTFIC = 0
               When Default                           # avec date de fin
                    FILTFIC = 0
                    WDATE = num$(99999999-val(format$("YYYYMMDD", [M:AWM1]DATFIN)))
                    FILTREWRK ='CPTINV >= "' + WDATE  + '0000"'
               Endcase
           When Default                          # date de debut
               FILTFIC = 0
               WDATE = num$(99999999-val(format$("YYYYMMDD", [M:AWM1]DATDEB)))
               FILTREWRK ='CPTINV <= "' + WDATE  + '9999"'
               Case [M:AWM1]DATFIN
               When "000000" 
               When Default                           # avec date de fin
                    WDATE = num$(99999999-val(format$("YYYYMMDD", [M:AWM1]DATFIN)))
                    FILTREWRK +=' & CPTINV >= "' + WDATE  + '0000"'
               Endcase
           Endcase
       When Default                    # emetteur
           FILTFIC = 1
           FILTREWRK ='CREUSR = "' + [M:AWM1]CREUSR + '"'
           Case [M:AWM1]DATDEB
           When "000000"                         # sans date de debut
               Case [M:AWM1]DATFIN
               When "000000"                          # sans date de fin
               When Default                           # avec date de fin
                    WDATE = num$(99999999-val(format$("YYYYMMDD", [M:AWM1]DATFIN)))
                    FILTREWRK +=' & CPTINV >= "' + WDATE  + '0000"'
               Endcase
           When Default                          # date de debut
               WDATE = num$(99999999-val(format$("YYYYMMDD", [M:AWM1]DATDEB)))
               FILTREWRK +=' & CPTINV <= "' + WDATE  + '9999"'
               Case [M:AWM1]DATFIN
               When "000000" 
               When Default                           # avec date de fin
                    WDATE = num$(99999999-val(format$("YYYYMMDD", [M:AWM1]DATFIN)))
                    FILTREWRK +=' & CPTINV >= "' + WDATE  + '0000"'
               Endcase
           Endcase
       Endcase
    When Default                             # avec nature
       FILTREWRK ='[F:AWN]NATURE = "' + [M:AWM1]NATURE  + '"'
       If [M:AWM1]INFORM = ""
               FILTFIC = 3
       Else
           If (instr(1,[M:AWM1]INFORM,"?") or instr(1,[M:AWM1]INFORM,"*")) 
               FILTFIC = 3
               FILTREWRK +=' & pat([F:AWN]INFORM,"' + [M:AWM1]INFORM + '")'
           Else
               FILTFIC = 2        
               FILTREWRK +=' & [F:AWN]INFORM = "' + [M:AWM1]INFORM + '"'
           Endif
       Endif
       Case [M:AWM1]CREUSR
       When ""                              # sans emetteur
           Case [M:AWM1]DATDEB
           When "000000"                         # sans date de debut
               Case [M:AWM1]DATFIN
               When "000000"                          # sans date de fin
               When Default                           # avec date de fin
                    WDATE = num$(99999999-val(format$("YYYYMMDD", [M:AWM1]DATFIN)))
                    FILTREWRK +=' & [F:AWN]CPTINV >= "' + WDATE  + '0000"'
               Endcase
           When Default                          # date de debut
               WDATE = num$(99999999-val(format$("YYYYMMDD", [M:AWM1]DATDEB)))
               FILTREWRK +=' & [F:AWN]CPTINV <= "' + WDATE  + '9999"'
               Case [M:AWM1]DATFIN
               When "000000" 
               When Default                           # avec date de fin
                    WDATE = num$(99999999-val(format$("YYYYMMDD", [M:AWM1]DATFIN)))
                    FILTREWRK +=' & [F:AWN]CPTINV >= "' + WDATE  + '0000"'
               Endcase
           Endcase
       When Default                         # avec emetteur
           FILTREWRK +=' & [F:AWL]CREUSR = "' + [M:AWM1]CREUSR + '"'
           Case [M:AWM1]DATDEB
           When "000000"                         # sans date de debut
               Case [M:AWM1]DATFIN
               When "000000"                          # sans date de fin
               When Default                           # avec date de fin
                    WDATE = num$(99999999-val(format$("YYYYMMDD", [M:AWM1]DATFIN)))
                    FILTREWRK +=' & [F:AWN]CPTINV >= "' + WDATE  + '0000"'
               Endcase
           When Default                          # date de debut
               WDATE = num$(99999999-val(format$("YYYYMMDD", [M:AWM1]DATDEB)))
               FILTREWRK +=' & [F:AWN]CPTINV <= "' + WDATE  + '9999"'
               Case [M:AWM1]DATFIN
               When "000000" 
               When Default                           # avec date de fin
                    WDATE = num$(99999999-val(format$("YYYYMMDD", [M:AWM1]DATFIN)))
                    FILTREWRK +=' & [F:AWN]CPTINV >= "' + WDATE  + '0000"'
               Endcase
           Endcase
       Endcase
    Endcase
Endif            # fin de constitution du filtre en recherche
#Infbox FILTREWRK

# Critères identiques
If FLAGCRIT <> 2        # Hors cas rappel critères précédents
   FLAGCRIT= 0
   If [M:AWM1]NATURE <> NATURE_M(0) or [M:AWM1]INFORM <> INFORM_M(0)     : FLAGCRIT=1
   Elsif [M:AWM1]CREUSR <> CREUSR_M(0)                                   : FLAGCRIT=1
   Elsif [M:AWM1]DATDEB <> DATDEB_M(0) or [M:AWM1]DATFIN <> DATFIN_M(0)  : FLAGCRIT=1 
   Endif
Endif


# Empilage des critéres si changement
If FLAGCRIT = 1   # Oui
    If FLAGNBCRIT < MAXNBCRIT : FLAGNBCRIT  += 1  : Endif
    # décalage des critéres
    For I= MAXNBCRIT -1 To 0 Step -1
        # clés de début 
        CLEDEBM1(I+1)=CLEDEBM1(I) : CLEDEBM2(I+1)= CLEDEBM2(I) : CLEDEBM3(I+1)= CLEDEBM3(I)
        # critére
        NATURE_M(I+1)=NATURE_M(I)
        INFORM_M(I+1)=INFORM_M(I)
        CREUSR_M(I+1)=CREUSR_M(I)
        DATDEB_M(I+1)=DATDEB_M(I)
        DATFIN_M(I+1)=DATFIN_M(I)
        RETOUR_M(I+1)=RETOUR_M(I)
    Next
    # dernier critére saisi 
    NATURE_M(0)=[M:AWM1]NATURE
    INFORM_M(0)=[M:AWM1]INFORM
    CREUSR_M(0)=[M:AWM1]CREUSR
    DATDEB_M(0)=[M:AWM1]DATDEB
    DATFIN_M(0)=[M:AWM1]DATFIN
Endif        

# Aiguillage suivant la demande
Case FILTFIC
When 0
    Gosub LECTURE_0
When 1
    Gosub LECTURE_1
When 2
    Gosub LECTURE_2
When 3
    Gosub LECTURE_3
Endcase


# Stockage de la derniére clé de début et état retour de la consultation
CLEDEBM1(0)=CLEDEB1 : CLEDEBM2(0)= CLEDEB2 : CLEDEBM3(0)= CLEDEB3 : RETOUR_M(0)=RETOUR
# Gestion critères précédents
Raz FLAGCRIT

Return

#--    Ouverture
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$OUVRE
# Filtres 
#  
 Local Char FILTREWRK (255)           # filtre de travail (sans clé de pagination)
 Local Char FILTREPAG (255)           # filtre de pagination
 Local Integer FILTFIC                # 0 : cle CPTINV sur AWRKLOG
                                      # 1 : cle CREUSR+CPTINV sur AWRKLOG
# Information de pagination
 Local Integer FLAGCRIT                 # 0: Critères identiques à la lecture précédente 
                                        # 1: différents      2: lecture critères précédents
 Local Char CLEDEB1 (20), CLEFIN1 (20)  # Cle de pagination 1 
 Local Char CLEDEB2 (20), CLEFIN2 (20)  # Cle de pagination 2
 Local Char CLEDEB3 (20), CLEFIN3 (20)  # Cle de pagination 3

# memorisation (indice 0: en-cours, 1 à MAXNBCRIT pour remontée des critéres)
 Local Integer MAXNBCRIT              # Nb maxi de critères mémorisés
 MAXNBCRIT = 20
 Local Integer FLAGNBCRIT             # Nombre de critères mémorisés
 Local Char CLEDEBM1 (20) (0..MAXNBCRIT)        # cle de debut mémorisées pagination
 Local Char CLEDEBM2 (20) (0..MAXNBCRIT)
 Local Char CLEDEBM3 (20) (0..MAXNBCRIT)
 Local Integer RETOUR_M (0..MAXNBCRIT)          # Variable RETOUR
 Local Char NATURE_M (3) (0..MAXNBCRIT)         # Nature
 Local Char INFORM_M (20) (0..MAXNBCRIT)        # Informations
 Local Char CREUSR_M (5) (0..MAXNBCRIT)         # Emetteur
 Local Date DATDEB_M (0..MAXNBCRIT)             # Dates début et fin
 Local Date DATFIN_M (0..MAXNBCRIT)            
# Divers
 Local Integer  I, J
 Local Char     WDATE                   # date inverse

# Fichier lien pour recherche sur nature et information
Link [AWN] With [AWL]AWL0=CPTINV As [AWX]

Return


#--    Grisage des boutons
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$SETBOUT
If ! FLAGNBCRIT  : Call VIREBOUT(CHAINE,"I") From GCONSULT : Endif
Return            

#-----------------------------------------------------------------------------------------
#         G O S U B
#-----------------------------------------------------------------------------------------

# Lecture AWL sur clé AWL0 (compteur inversé)
#-----------------------------------------------------------------------------------------
$LECTURE_0
# Mêmes critères
FILTREPAG= "1=1"
If FLAGCRIT = 0     # Critères identiques
    Case CHGPAG
        When 3    # Rafraichissement
             FILTREPAG = 'CPTINV >= "' + CLEDEB1 + '"'
        When 2    # Suite
             FILTREPAG = 'CPTINV > "'  + CLEFIN1 + '"'
        When -2   # Retour
             FILTREPAG = 'CPTINV < "'   + CLEDEB1 + '"'
    Endcase
Elsif FLAGCRIT = 2      # Rappel précédent
    If CLEDEB1 <> "" 
        RETOUR=RETOUR_M(0)
        FILTREPAG = 'CPTINV >= "' + CLEDEB1 + '"' 
    Endif
Endif

# Positionnement du filtre 
If CHGPAG > 0
    Filter [F:AWL] Where evalue(FILTREWRK) and evalue(FILTREPAG) Order By Key AWL0
Else
    Filter [F:AWL] Where evalue(FILTREWRK) and evalue(FILTREPAG) Order By Key AWL0 Desc
Endif

# Initialisation clé debut et fin de pagination
Raz CLEDEB1, CLEDEB2, CLEDEB3, CLEFIN1, CLEFIN2, CLEFIN3

# Boucle de lecture 
For [F:AWL]
   If NBLU=1
       If CHGPAG=2 | CHGPAG=-2 : Raz [M:AWM2] : Endif
       NBLU = 2
   Endif
   If CHGPAG > 0
       If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
       NOL +=1
       If NOL=0 : CLEDEB1=[F:AWL]CPTINV : Endif
       CLEFIN1=[F:AWL]CPTINV
   Else
       If NOL <= 0 : RETOUR=2 : Break : Endif
       NOL -=1
       If NOL=MAXLIG-1 : CLEFIN1=[F:AWL]CPTINV : Endif
       CLEDEB1=[F:AWL]CPTINV
   Endif
   # Chargement écran
   nolign=NOL+1
   [M:AWM2]=[F:AWL] 
   For I = 0 To 4
       Assign "[M:AWM2]NAT" + num$(I+1) +"(NOL)" With [F:AWL]NATURE(I) 
       Assign "[M:AWM2]INF" + num$(I+1) +"(NOL)" With [F:AWL]INFORM(I)
   Next I
Next

Return

# Lecture AWL sur clé AWL1 (emetteur + compteur inversé)
#-----------------------------------------------------------------------------------------
$LECTURE_1
# Mêmes critères
FILTREPAG= "1=1"
If FLAGCRIT = 0     # Critères identiques
    Case CHGPAG
        When 3    # Rafraichissement
             FILTREPAG = 'CPTINV >= "' + CLEDEB1 + '"' 
        When 2    # Suite
             FILTREPAG = 'CPTINV > "' + CLEFIN1 + '"'
        When -2   # Retour
             FILTREPAG = 'CPTINV < "' + CLEDEB1 + '"'
    Endcase
Elsif FLAGCRIT = 2      # Rappel précédent
    If CLEDEB1 <> "" 
        RETOUR=RETOUR_M(0)
        FILTREPAG = 'CPTINV >= "' + CLEDEB1 + '"' 
    Endif
Endif

# Positionnement du filtre 
If CHGPAG > 0
    Filter [F:AWL] Where evalue(FILTREWRK) and evalue(FILTREPAG) Order By Key AWL1
Else
    Filter [F:AWL] Where evalue(FILTREWRK) and evalue(FILTREPAG) Order By Key AWL1 Desc
Endif


# Initialisation clé debut et fin de pagination
Raz CLEDEB1, CLEDEB2, CLEDEB3, CLEFIN1, CLEFIN2, CLEFIN3

# Boucle de lecture 
For [F:AWL]AWL1
   If NBLU=1
       If CHGPAG=2 | CHGPAG=-2 : Raz [M:AWM2] : Endif
       NBLU = 2
   Endif
   If CHGPAG > 0
       If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
       NOL +=1
       If NOL=0 : CLEDEB1=[F:AWL]CPTINV : Endif
       CLEFIN1=[F:AWL]CPTINV
   Else
       If NOL <= 0 : RETOUR=2 : Break : Endif
       NOL -=1
       If NOL=MAXLIG-1 : CLEFIN1=[F:AWL]CPTINV  : Endif
       CLEDEB1=[F:AWL]CPTINV
   Endif
   # Chargement écran
   nolign=NOL+1
   [M:AWM2]=[F:AWL] 
   For I = 0 To 4
       Assign "[M:AWM2]NAT" + num$(I+1) +"(NOL)" With [F:AWL]NATURE(I) 
       Assign "[M:AWM2]INF" + num$(I+1) +"(NOL)" With [F:AWL]INFORM(I)
   Next I
Next

Return

# Lecture AWX sur clé AWN0 (nature , information exacte et compteur inversé) 
#-----------------------------------------------------------------------------------------
$LECTURE_2
# Mêmes critères
FILTREPAG= "1=1"
If FLAGCRIT = 0     # Critères identiques
    Case CHGPAG
        When 3    # Rafraichissement
             FILTREPAG = '[F:AWN]CPTINV >= "' + CLEDEB1 + '"'
        When 2    # Suite
             FILTREPAG = '[F:AWN]CPTINV > "'  + CLEFIN1 + '"'
        When -2   # Retour
             FILTREPAG = '[F:AWN]CPTINV < "'  + CLEDEB1 + '"'
    Endcase
Elsif FLAGCRIT = 2      # Rappel précédent
    If CLEDEB1 <> "" 
        RETOUR=RETOUR_M(0)
        FILTREPAG = '[F:AWN]CPTINV >= "' + CLEDEB1 + '"'
    Endif
Endif

#Infbox FILTREWRK -"and" - FILTREPAG

# Positionnement du filtre 
If CHGPAG > 0
       Filter [F:AWX] Where evalue(FILTREWRK) and evalue(FILTREPAG) Order By Key AWN0
Else
       Filter [F:AWX] Where evalue(FILTREWRK) and evalue(FILTREPAG) Order By Key AWN0 Desc
Endif

# Initialisation clé debut et fin de pagination
Raz CLEDEB1, CLEDEB2, CLEDEB3, CLEFIN1, CLEFIN2, CLEFIN3
# Boucle de lecture 
For [F:AWX]AWN0
   If NBLU=1
       If CHGPAG=2 | CHGPAG=-2 : Raz [M:AWM2] : Endif
       NBLU = 2
   Endif
   If CHGPAG > 0
       If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
       NOL +=1
       If NOL=0 : CLEDEB1=[F:AWN]CPTINV : Endif
       CLEFIN1=[F:AWN]CPTINV
   Else
       If NOL <= 0 : RETOUR=2 : Break : Endif
       NOL -=1
       If NOL=MAXLIG-1 : CLEFIN1=[F:AWN]CPTINV : Endif
       CLEDEB1=[F:AWN]CPTINV
   Endif
   # Chargement écran
   nolign=NOL+1
   [M:AWM2]=[F:AWL] 
   For I = 0 To 4
       Assign "[M:AWM2]NAT" + num$(I+1) +"(NOL)" With [F:AWL]NATURE(I) 
       Assign "[M:AWM2]INF" + num$(I+1) +"(NOL)" With [F:AWL]INFORM(I)
   Next I
Next

Return


# Lecture AWX sur clé AWN0 (nature et compteur inversé)
#-----------------------------------------------------------------------------------------
$LECTURE_3
# Mêmes critères
FILTREPAG= "1=1"
If FLAGCRIT = 0     # Critères identiques
    Case CHGPAG
        When 3    # Rafraichissement
             FILTREPAG = '[F:AWN]CPTINV >= "' + CLEDEB1 + '"'
        When 2    # Suite
             FILTREPAG = '[F:AWN]CPTINV > "'  + CLEFIN1 + '"'
        When -2   # Retour
             FILTREPAG = '[F:AWN]CPTINV < "'  + CLEDEB1 + '"'
    Endcase
Elsif FLAGCRIT = 2      # Rappel précédent
    If CLEDEB1 <> "" 
        RETOUR=RETOUR_M(0)
        FILTREPAG = '[F:AWN]CPTINV >= "' + CLEDEB1 + '"'
    Endif
Endif

#Infbox FILTREWRK -"and" - FILTREPAG

# Positionnement du filtre 
If CHGPAG > 0
       Filter [F:AWX] Where evalue(FILTREWRK) and evalue(FILTREPAG) Order By Key AWN1
Else
       Filter [F:AWX] Where evalue(FILTREWRK) and evalue(FILTREPAG) Order By Key AWN1 Desc
Endif

# Initialisation clé debut et fin de pagination
Raz CLEDEB1, CLEDEB2, CLEDEB3, CLEFIN1, CLEFIN2, CLEFIN3
# Boucle de lecture 
For [F:AWX]AWN1
   If NBLU=1
       If CHGPAG=2 | CHGPAG=-2 : Raz [M:AWM2] : Endif
       NBLU = 2
   Endif
   If CHGPAG > 0
       If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
       NOL +=1
       If NOL=0 : CLEDEB1=[F:AWN]CPTINV : Endif
       CLEFIN1=[F:AWN]CPTINV
   Else
       If NOL <= 0 : RETOUR=2 : Break : Endif
       NOL -=1
       If NOL=MAXLIG-1 : CLEFIN1=[F:AWN]CPTINV : Endif
       CLEDEB1=[F:AWN]CPTINV
   Endif
   # Chargement écran
   nolign=NOL+1
   [M:AWM2]=[F:AWL] 
   For I = 0 To 4
       Assign "[M:AWM2]NAT" + num$(I+1) +"(NOL)" With [F:AWL]NATURE(I) 
       Assign "[M:AWM2]INF" + num$(I+1) +"(NOL)" With [F:AWL]INFORM(I)
   Next I
Next

Return


