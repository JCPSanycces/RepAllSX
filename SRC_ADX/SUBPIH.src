#------------------------------#
Variable Integer VALEUR
If !GLOCITAPRE  mkstat=2 : End : Endif
End

Subprog AV_DIFQTY(VALEUR)
#----------------------------------------------#
# Avant zone indicateur différence de quantité #
#----------------------------------------------#
Variable Integer VALEUR
Local    Shortint NOL : NOL=nolign-1
If ([M:PIH0]PIHTYP<>1 & [M:PIH0]PIHTYP<>4) | [M:PIH3]TYPORI(NOL)=5 End : Endif
If [M:PIH3]PRTFLG(NOL)=1 & [M:PIH3]QTYPUU(NOL)<>[M:PIH3]ORIQTYPUU(NOL)
  VALEUR=2 Else VALEUR=1
Endif
End

Subprog AV_DIFPRI(VALEUR)
#----------------------------------------------#
# Avant zone indicateur différence de quantité #
#----------------------------------------------#
Variable Integer VALEUR
Local    Shortint NOL : NOL=nolign-1
If ([M:PIH0]PIHTYP<>1 & [M:PIH0]PIHTYP<>4) | [M:PIH3]TYPORI(NOL)=5 End : Endif
If [M:PIH3]NETPRI(NOL)<>[M:PIH3]ORINETPRI(NOL)  VALEUR=2 Else VALEUR=1 : Endif
End

Subprog C_NBFAC
#--------------------------------------------------------------#
# Contrôle sur numéro de ligne élément de facturation onglet 4 #
#--------------------------------------------------------------#
Local Shortint NOL : NOL=nolign-1
#----- Interdiction de l'insertion et de la suppression sur facture validée -----#
If find(status,65,73,82) & [M:PIH1]STA=3 GMESSAGE=mess(155,194,1) : mkstat=2 : End : Endif
#----- Test suppression d'un élément non ajouté -----#
If status=65 & [M:PIH1]INVDTAFLG1(NOL)=1 GMESSAGE=mess(136,194,1) : mkstat=2 : End : Endif
#----- Affichage tableau des éléments du 1er onglet en sortie de tableau -----#
# If find(status,1,4,5,20,21,26,92,93) & !GIMPORT : Affzo [PIH1]20-25 : Endif
#----- Grisage ou dégrisage de certains champs -----#
If [M:PIH1]CUR<>GLOCALDEV
  Actzo [PIH1]CURTYP
Else
  Diszo [PIH1]CURTYP
Endif
End

Subprog AVANT_NBFAC
#------------------------------------------#
# Avant ligne élément facturation onglet 4 #
#------------------------------------------#
Local   Shortint NOL : NOL=nolign-1
Local   Integer  AFF
#----- Mise à jour bases taxables et calcul taxes des éléments si nécessaire -----#
If [M:PIH1]NBFAC1>0 & [M:PIH4]NBFAC=0
   [M:PIH4]NBFAC=[M:PIH1]NBFAC1
   For I=0 To [M:PIH1]NBFAC1-1
       # Issue 85145 - 2012-10-16 by MUARN : ajout devise
       [M:PIH4]AMTCODLIB(I)=[M:PIH1]CUR
       Call MAJ_ELEMENT (I,1,+1) From SUBPIHB
   Next I
   If GPIHCALTAX=2 | (dim([M:PIH4]DISVATFLG)>0 & find(2,[M:PIH4]DISVATFLG(0..[M:PIH4]NBFAC-1)))
     For GPIH_INDTAX=1 To [M:PIH4]NBTAX
       Gosub CAL_TAXE_GLOB From SUBPIHB
     Next GPIH_INDTAX
   Endif
   # Issue 71069 - 2016-09-07 by MUARN : PJT
   #If !GIMPORT Affzo [PIH4]5 : Endif
   Gosub MAJ_CCE_PFI From SUBPIHC
Endif
#----- Si suppression ligne : Activation affichage dans MAJ_ELEMENT -----#
If status=65 | status=68 | status=83 AFF=1 : Endif
#----- Décrémentation des bases de taxe sans affichage -----#
Call MAJ_ELEMENT (NOL,AFF,-1) From SUBPIHB
If AFF=1
   If GPIHCALTAX=2 | (dim([M:PIH4]DISVATFLG)>0 & find(2,[M:PIH4]DISVATFLG(0..[M:PIH4]NBFAC-1)))
     For GPIH_INDTAX=1 To [M:PIH4]NBTAX
       Gosub CAL_TAXE_GLOB From SUBPIHB
     Next GPIH_INDTAX
     #Issue 107878 - 2018-10-03 by RBA change due to sequence display
     #If !GIMPORT Affzo [PIH4]10,20,30 : Endif
     If !GIMPORT Affzo [PIH4]10,25,30 : Endif
   Endif
   Gosub MAJ_STATUT From SUBPIH
Endif
End

Subprog APRES_NBFAC
#---------------------------------------------------------------------------#
# Après ligne : Calcul affichage écart, total TTC et écart TTC sur onglet 4 #
#---------------------------------------------------------------------------#
Local    Shortint NOL : NOL=nolign-1
#----- Si suppression ligne : Suppression ligne du 1er tableau onglet 1 -----#
If status=65 | status=68 | status=83
   If [M:PIH1]NBFAC1>0 & [M:PIH1]NBFAC1<max(func AFNC.ACTIV("PFI"),20)
      Dela NOL,1,[M:PIH1]NBFAC1-1 [M:PIH1]NBFAC1
      [M:PIH1]NBFAC1-=1
   Elsif [M:PIH1]NBFAC1=0
      [M:PIH1]NBFAC1=20
      Dela NOL,1 [M:PIH1]NBFAC1
      [M:PIH1]NBFAC1=0
   Else
      Dela NOL,1 [M:PIH1]NBFAC1
      [M:PIH1]NBFAC1-=1
   Endif
   If !GIMPORT
      #Issue 107878 - 2018-10-03 by RBA change due to sequence display
      #Affzo [PIH1]20-25 : Affzo [PIH4]25-30
      Affzo [PIH1]20-25 : Affzo [PIH4]20,30
   Endif
   Gosub MAJ_STATUT From SUBPIH : End
Endif
#-------------------------------------------------#
# Si touche "Echap" ou autre statut "Abandon"     #
# incrémentation bases taxe sans affichage et FIN #
#-------------------------------------------------#
If status=6 | status=7 | status=27 | status=28
   If [M:PIH1]INVDTA1(NOL)=0
     Raz [M:PIH1]INVDTAFLG1(NOL)
   Elsif [M:PIH4]ACC1(NOL)="" & [M:PIH4]ACC2(NOL)="" & [M:PIH4]ACC3(NOL)=""
     Call INIT_COMPTES_INVDTA(NOL) From SUBPIHC
     Gosub AFFICH_ACC
   Endif
   Call MAJ_ELEMENT (NOL,0,+1) From SUBPIHB : End : Endif
#----- Si no élément non renseigné, c'est fini ! -----#
If [M:PIH4]INVDTA(NOL)=0  Raz [M:PIH1]INVDTAFLG1(NOL) : End : Endif
#-------------------------------------------------------#
# Si ajout d'un nouvel élément : Chargement des valeurs #
#         dans le 1er tableau des éléments sur onglet 1 #
#-------------------------------------------------------#
If [M:PIH1]INVDTA1(NOL)=0
   [M:PIH1]INVDTA1(NOL)   =[M:PIH4]INVDTA(NOL)
   [M:PIH1]INVDTALIB1(NOL)=[M:PIH4]INVDTALIB(NOL)
   [M:PIH1]INVDTAAMT1(NOL)=[M:PIH4]INVDTAAMT(NOL)
   [M:PIH1]DEBCDT1(NOL)   =[M:PIH4]DEBCDT(NOL)
   [M:PIH1]INVDTAFLG1(NOL)=2
   [M:PIH1]NBFAC1+=1
   If !GIMPORT
     Affzo [PIH1]INVDTA1(NOL),INVDTALIB1(NOL),INVDTAAMT1(NOL),TOTATIAMT1
   Endif
Endif
#----- Affichage écart de l'élément, total TTC et écart TTC -----#
If !GIMPORT Affzo [PIH4]INVDIFAMT(NOL) : Endif
#----- Incrémentation des bases de taxe avec affichage -----#
Call MAJ_ELEMENT (NOL,2,+1) From SUBPIHB
If GPIHCALTAX=2 | (dim([M:PIH4]DISVATFLG)>0 & find(2,[M:PIH4]DISVATFLG(0..[M:PIH4]NBFAC-1)))
   Local Shortint SAV_NBFAC : SAV_NBFAC=[M:PIH4]NBFAC
   If [M:PIH4]NBFAC<NOL+1  [M:PIH4]NBFAC=NOL+1 : Endif
   For GPIH_INDTAX=1 To [M:PIH4]NBTAX
     Gosub CAL_TAXE_GLOB From SUBPIHB
   Next GPIH_INDTAX
   [M:PIH4]NBFAC=SAV_NBFAC
   #Issue 107878 - 2018-10-03 by RBA change due to sequence display
   #If !GIMPORT Affzo [PIH4]5,10,20,30 : Endif
   If !GIMPORT Affzo [PIH4]5,10,25,30 : Endif
Endif

Gosub MAJ_STATUT From SUBPIH
End

Subprog AS_INVDTA(VALEUR)
#---------------------------------------------#
# Avant saisie du No d'élément de facturation #
#---------------------------------------------#
Variable Decimal VALEUR
If [M:PIH4]INVDTA(nolign-1)<>0 & [M:PIH1]INVDTAFLG1(nolign-1)=0
  [M:PIH1]INVDTAFLG1(nolign-1)=2
Endif
If [M:PIH1]INVDTAFLG1(nolign-1)<>0 mkstat=2 : Endif
End

Subprog C_INVDTA(VALEUR)
#----------------------------------------------------#
# Contrôle No d'élément déja présent dans le tableau #
#----------------------------------------------------#
Variable Decimal VALEUR
#-----
If find(VALEUR,[M:PIH4]INVDTA) & find(VALEUR,[M:PIH4]INVDTA)<>nolign & !GIMPORT
   GMESSAGE=mess(102,194,1) : mkstat=1
Endif
End

Subprog AM_INVDTA(VALEUR)
#------------------------------------------------#
# Après modif No d'élément : chargement libellé, #
#       valeur par défaut et indicateur d'ajout. #
#------------------------------------------------#
Variable Decimal VALEUR
Local    Shortint NOL : NOL=nolign-1
Local    Integer  STAT
#-----
If [F:PFI]DISVATFLG=2
  GMESSAGE=mess(412,194,1) : GERR=1 : mkstat=1 : End
Endif
#-----
Call LECTEXTRA(GBIDC3,"PFOOTINV","SHOAXX",num$([F:PFI]PFINUM),"") From ATEXTRA
[M:PIH4]INVDTALIB(NOL)=GBIDC3
If [F:PFI]AMTCOD=2
# Issue 85145 - 2012-10-15 by MUARN : en tunnel GCUR n a pas la même signification
#   Call CONVERT(GLOCALDEV,GCUR,GLOCALDEV,[M:PIH1]CURTYP,datesyst,
#&               [F:PFI]DEFVAL,GBIDD3,STAT) From TRTDEV
   Call CONVERT(GLOCALDEV,[M:PIH1]CUR,GLOCALDEV,[M:PIH1]CURTYP,datesyst,
&               [F:PFI]DEFVAL,GBIDD3,STAT) From TRTDEV
   If [F:PFI]INCDCR=2 & GBIDD3>0 GBIDD3=-GBIDD3 : Endif
   [M:PIH4]INVDTAAMT(NOL)=GBIDD3
Endif
# Issue 85145 - 2012-10-17 by MUARN : ajout devise
[M:PIH4]AMTCODLIB(NOL)=[M:PIH1]CUR
If [M:PIH0]PIHTYP<3 [M:PIH4]DEBCDT(NOL)=[F:PFI]INCDCR
               Else [M:PIH4]DEBCDT(NOL)=3-[F:PFI]INCDCR : Endif
[M:PIH1]INVDTAFLG1(NOL)=2
Raz [M:PIH4]INVORDAMT(NOL),[M:PIH4]INVLINAMT(NOL),[M:PIH4]INVDIFAMT(NOL),
&   [M:PIH4]INVDTAVAT(NOL),[M:PIH4]DTAAMTTAX(NOL),[M:PIH4]DTADEDTAX(NOL)
If dim([M:PIH4]DTADISBAS)>0  Raz [M:PIH4]DTADISBAS(NOL) : Endif
If [F:PFI]VATRUL=2
   Local Char WVAT(GLONVAT)
   If !clalev([F:TVC])  Local File TABVAC [TVC] : Endif
   Call RECHVATFOOT(2,[M:PIH0]BPR,[F:PFI]PFINUM,"PIH4",WVAT) From TRTX3
   [M:PIH4]INVDTAVAT(NOL)=WVAT
Endif
[M:PIH4]INVLINFLG(NOL)=[F:PFI]DSPLIN
[M:PIH4]INVORDFLG(NOL)=[F:PFI]DACORD
[M:PIH4]CLCORD(NOL)   =[F:PFI]CLCORD
[M:PIH4]CLCBAS(NOL)   =[F:PFI]CLCBAS
[M:PIH4]DSP(NOL)      =[F:PFI]DSP
# Issue 83026 - 2012-06-26 by MUARN : early escompte
[M:PIH4]DEPFLG(NOL)   =[F:PFI]DEPFLG
[M:PIH4]INCDCR(NOL)   =[F:PFI]INCDCR
If dim([M:PIH4]DISVATFLG)>0
  [M:PIH4]DISVATFLG(NOL)=[F:PFI]DISVATFLG
  If [F:PFI]DISVATFLG=2
    [M:PIH4]INVORDAMT(NOL)=[F:PFI]DEFVAL
  Endif
Endif
If !GIMPORT Affzo [PIH4]INVDTALIB(NOL) : Endif
End

Subprog AS_INVDTAAMT(VALEUR)
Variable Decimal  VALEUR
If dim([M:PIH4]DISVATFLG)>0 & [M:PIH4]DISVATFLG(nolign-1)=2  mkstat=2 : Endif
End

Subprog AM_INVDTAAMT(VALEUR)
#-------------------------------------------------------------#
# Après modif d'un montant élément de facturation (Mt saisi): #
# Mise à jour ligne et affichage de l'élément sur onglet 1    #
#-------------------------------------------------------------#
Variable Decimal  VALEUR
Local    Shortint NOL : NOL=nolign-1
If ([M:PIH0]PIHTYP<3 & [M:PIH4]DEBCDT(NOL)=2) |
&  ([M:PIH0]PIHTYP>2 & [M:PIH4]DEBCDT(NOL)=1)
   If VALEUR>0 VALEUR=-VALEUR : Endif
Elsif VALEUR<0 VALEUR=-VALEUR
Endif
Raz [M:PIH4]DTAAMTTAX(NOL), [M:PIH4]DTADEDTAX(NOL)
#----- Mise à jour en après ligne si élément ajouté -----#
If [M:PIH1]INVDTA1(NOL)=0  End : Endif
[M:PIH1]INVDTAAMT1(NOL)=VALEUR
If !GIMPORT
  Affzo [PIH1]INVDTAAMT1(NOL),TOTATIAMT1
Endif
End

Subprog AS_INVORDAMT(VALEUR)
#---------------------------------------------------------------------#
# Avant saisie d'un montant élément de facturation (Mt pied commande) #
#---------------------------------------------------------------------#
Variable Decimal  VALEUR
#If dim([M:PIH4]DISVATFLG)>0 & [M:PIH4]DISVATFLG(nolign-1)=2
#  End : # Permettre la saisie du taux pour la remise sur taxe (cas particulier)
#Elsif [M:PIH4]INVORDFLG(nolign-1)<>2
# Issue 102698 - 2014-12-17 by MUARN : ne pas saisir sur la remise sur tax si DEPMGTMOD=5
If [M:PIH4]INVORDFLG(nolign-1)<>2 | ( GDEPMGTMOD= 5 & [M:PIH4]DISVATFLG(nolign-1)=2 )
  mkstat=2
Endif
End

Subprog AM_INVORDAMT(VALEUR)
#---------------------------------------------------------------------#
# Après modif d'un montant élément de facturation (Mt pied commande): #
#---------------------------------------------------------------------#
Variable Decimal  VALEUR
Local    Shortint NOL : NOL=nolign-1
#----- C'est une remise sur taxe (Settlement discount) -----#
If dim([M:PIH4]DISVATFLG)>0 & [M:PIH4]DISVATFLG(NOL)=2
  Raz [M:PIH4]DTADISBAS(NOL), [M:PIH4]DTAAMTTAX(NOL), [M:PIH4]DTADEDTAX(NOL) : End
Endif
#-----
If ([M:PIH0]PIHTYP<3 & [M:PIH4]DEBCDT(NOL)=2) |
&  ([M:PIH0]PIHTYP>2 & [M:PIH4]DEBCDT(NOL)=1)
   If VALEUR>0 VALEUR=-VALEUR : Endif
Elsif VALEUR<0 VALEUR=-VALEUR
Endif
End

Subprog AV_INVDIFAMT(VALEUR)
#-----------------------------------------------------#
# Avant zone écart : Calcul de l'écart pour affichage #
#-----------------------------------------------------#
Variable Decimal VALEUR
Local    Shortint NOL : NOL=nolign-1
If (INVLINFLG(NOL)<6 & INVORDFLG(NOL)=1) | (dim([M:PIH4]DISVATFLG)>0 & [M:PIH4]DISVATFLG(NOL)=2)
  Raz VALEUR : End
Endif
VALEUR=INVDTAAMT(NOL)-INVORDAMT(NOL)-INVLINAMT(NOL)
End

Subprog AS_INVDTAVAT(VALEUR)
#---------------------------#
# Avant saisie du code taxe #
#---------------------------#
Variable Char    VALEUR()
If VALEUR="" &
& ([M:PIH4]INVLINFLG(nolign-1)>1 | (dim([M:PIH4]DISVATFLG)>0 & [M:PIH4]DISVATFLG(nolign-1)=2))
  mkstat=2 : End
Endif
End

