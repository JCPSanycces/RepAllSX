Subprog AS_EECICT2(VALEUR)
Variable Char    VALEUR()
# Issue 84130 - 2013-02-21 by MUARN : landed cost Incoterm modifiable si aucune ligne en structure de cout
Local    Integer  I,J
If [M:PIH3]NBLIG>0
   J = sigma(I=0,[M:PIH3]NBLIG-1,1*([M:PIH3]STCNUM(I)<>""))
   If J
        Diszo [M:PIH1]EECICT2
   Else
        Actzo [M:PIH1]EECICT2
   Endif
Endif
End
