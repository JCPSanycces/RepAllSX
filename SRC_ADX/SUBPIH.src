# Issue 89349 - 2013-10-25 by SR : Rapprochement
######################################################################################
## Etiquette ajoutée par le superviseur (écran PIH3) 25.10.2013 14:07:51 (SR)
######################################################################################
Subprog AM_CSTMAJLIN(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
   Raz [M:PIH3]FCSCOD(nolign-1)
   Grizo [M:PIH3]FCSCOD(nolign-1)
Else
  # Issue 110325 - 2016-01-11 by SR : FCC sur Exp
  If find([M:PIH3]TYPORI(nolign-1),1,2,6)<>0
      Actzo [M:PIH3]FCSCOD(nolign-1)
  Endif
Endif
Affzo [M:PIH3]FCSCOD(nolign-1)
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran PIH3) 05.11.2013 08:27:51 (SR)
######################################################################################
Subprog AS_FCSCOD(VALEUR)
Variable Char    VALEUR()
#Zone non saisissable si pas facture complémentaire ou nouveau coût ou pas origine commande/Réception
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
If [M:PIH0]PIHTYP <> 2 | [M:PIH3]CSTMAJLIN(nolign-1)<> 1 | find([M:PIH3]TYPORI(nolign-1),1,2,6)=0
    mkstat = 2
    End
Endif
End

