$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE>GNBDIE  Return : Endif
Call INIT_CCE(VALEUR,AXE,"PID","[M:PIH3]LINACC",nolign-1) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
If GMODIF<>2  mkstat=2 : Return : Endif
Call SAIS_CCE(VALEUR,AXE,"[M:PIH3]LINACC","[M:PIH3]LINDSP") From TRTX3CPT
# Issue 76502 - 2011-09-27 by VPO : on refait init pour cas sections précedentes
#car PREP_INIT_CCE déjà fait sur comptes
If !mkstat
   If VALEUR=""
      Call INIT_CCE(VALEUR,AXE,"PID","[M:PIH3]LINACC",nolign-1) From TRTX3CPT
   Endif
Endif
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"[M:PIH3]LINACC",GFINRSP,[M:PIH0]ACCDAT) From TRTX3CPT
If GIMPORT & mkstat
  GMESSAGE-="-"-mess(18,197,1)-num$(nolign)-mess(80,197,1)-[M:PIH3]ITMREF(nolign-1)
  #----- Simple warning si migration Intégrale -----#
  If clalev([F:XEPA]) & clalev([F:XLPA])
    Call ECR_TRACE(GMESSAGE,-1) From GESECRAN : Raz GMESSAGE, mkstat
  Endif
  #-----
Endif
Return

Subprog D_STRDAT(VALEUR)
#--------------------------------------#
# Initialisation date début prestation #
#--------------------------------------#
Variable Date    VALEUR
If dim([M:PIH1]STRDATSVC)>0 & !GLOCITAPRE
  VALEUR=[M:PIH1]STRDATSVC
Else
  VALEUR=[0/0/0]
Endif
End

Subprog AM_STRDAT(VALEUR)
#------------------------------------------------#
# Après modification date début prestation ligne #
#------------------------------------------------#
Variable Date    VALEUR
If VALEUR=[0/0/0]
  [M:PIH3]ENDDAT(nolign-1)=[0/0/0] : Affzo [PIH3]ENDDAT(nolign-1)
Endif
End

Subprog D_ENDDAT(VALEUR)
#------------------------------------------#
# Initialisation date fin prestation ligne #
#------------------------------------------#
Variable Date    VALEUR
If dim([M:PIH1]ENDDATSVC)>0 & !GLOCITAPRE & [M:PIH3]STRDAT(nolign-1)<>[0/0/0]
  VALEUR=[M:PIH1]ENDDATSVC
Else
  VALEUR=[0/0/0]
Endif
End

Subprog AS_ENDDAT(VALEUR)
#---------------------------------------------------------------------#
# Avant saisie Date fin prestation :                                  #
# On saute la zone si la date début prestation n'a pas été renseignée #
#---------------------------------------------------------------------#
Variable Date    VALEUR
If [M:PIH3]STRDAT(nolign-1)=[0/0/0]
  mkstat=2 : End
Endif
End

Subprog C_ENDDAT(VALEUR)
#----------------------------------------------------------------------------------#
# Contrôle Date fin prestation :                                                   #
# La date de fin prestation est rendue obligatoire si la date début est renseignée #
#----------------------------------------------------------------------------------#
Variable Date    VALEUR
If [M:PIH3]STRDAT(nolign-1)<>[0/0/0] & VALEUR=[0/0/0]
  GMESSAGE=mess(123,107,1) : # Date fin de prestation à renseigner
  mkstat=1 : End
Endif
End

