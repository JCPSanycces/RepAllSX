Variable Char    VALEUR()
Local    Integer AXE : AXE=20 : Gosub C_PFICCEX
End

$D_PFICCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE>GNBDIE  Return : Endif
If [M:PIH4]DSP(nolign-1)<>""  VALEUR="" : Return : Endif
Call INIT_CCE(VALEUR,AXE,"PIV","[M:PIH4]ACC",nolign-1) From TRTX3CPT
Return

$AS_PFICCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"[M:PIH4]ACC","[M:PIH4]DSP") From TRTX3CPT
Return

$C_PFICCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
If GIMPORT & [M:PIH4]INVDTAAMT(nolign-1)=0  Return : Endif
Call CTRL_PFICCE(VALEUR,AXE,"[M:PIH4]ACC",GFINRSP,[M:PIH0]ACCDAT) From TRTX3CPT
If GIMPORT & mkstat
  GMESSAGE-="-"-mess(523,197,1)-num$([M:PIH4]INVDTA(nolign-1))-[M:PIH4]INVDTALIB(nolign-1)
  #----- Simple warning si migration Intégrale -----#
  If clalev([F:XEPA]) & clalev([F:XLPA])
    Call ECR_TRACE(GMESSAGE,-1) From GESECRAN : Raz GMESSAGE, mkstat
  Endif
  #-----
Endif
Return

Subprog AS_AMTTAX(VALEUR)
#---------------------------#
# Avant saisie montant taxe #
#---------------------------#
Variable Decimal  VALEUR
If [M:PIH3]NBLIG=0 mkstat=2 : Endif
End

Subprog AM_AMTTAX(VALEUR)
#--------------------------#
# Après modif montant taxe #
#--------------------------#
Variable Decimal  VALEUR
Local    Shortint NOL : NOL=nolign-1
Local  Integer WRET :#--CPO 71937 TVT et multi-lèg
#-----
Gosub RECH_DATE_TAXE From SUBPIHB
#--CPO 71937 TVT et multi-lèg
Call LEC_TVT_LEG(GCURLEG,[M:PIH4]TAX(NOL),WRET) From TRTLECLEG
If WRET : Raz [F:TVT] : Endif
#Filter [TRA] Where CPY=GSOCIETE & VAT=[M:PIH4]TAX(NOL) & STRDAT<=GBIDA1
Filter [TRA] Where CPY=GSOCIETE & VAT=[M:PIH4]TAX(NOL) & STRDAT<=GBIDA1 & LEG=[F:TVT]LEG
Read [TRA]TRA0 Last
If fstat>2
  #Filter [TRA] Where CPY="" & VAT=[M:PIH4]TAX(NOL) & STRDAT<=GBIDA1
  Filter [TRA] Where CPY="" & VAT=[M:PIH4]TAX(NOL) & STRDAT<=GBIDA1 & LEG=[F:TVT]LEG
  Read [TRA]TRA0 Last
  If fstat>2  Raz [F:TRA] : Endif
Endif
#--/CPO
#----- Avertissement : Code taxe exonéré et montant taxe non nul ! -----#
If [F:TRA]VATRAT=0 & VALEUR<>0
  Call MESSAGE ([M:PIH4]TAX(NOL)-[M:PIH4]LIBTAX(NOL)-":"-mess(398,194,1)) From GESECRAN
Endif
#----- Réajustement de la partie déductible -----#
If [M:PIH4]DEDTAXCOE(NOL)=0
  If [M:PIH4]AMTTAX(NOL)<>0
    [M:PIH4]DEDTAXCOE(NOL)=[M:PIH4]DEDTAX(NOL)/[M:PIH4]AMTTAX(NOL)
  Else
    [M:PIH4]DEDTAXCOE(NOL)=[F:TRA]DEDRAT/100
  Endif
Endif
[M:PIH4]DEDTAX(NOL)=VALEUR*[M:PIH4]DEDTAXCOE(NOL)
Call ARRDEV([M:PIH4]DEDTAX(NOL),GCUR) From TRTDIV

#----- Calcul et affichage total des taxes -----#
[M:PIH4]AMTTAX(NOL)=VALEUR
[M:PIH4]TOTTAXCLC=sum([M:PIH4]AMTTAX)
#Issue 107878 - 2018-10-03 by RBA change due to sequence display
#If !GIMPORT Affzo [PIH4]20,30 : Endif
If !GIMPORT Affzo [PIH4]25,30 : Endif
Gosub MAJ_STATUT From SUBPIH
#----- Réajustement des montants de taxe sur éléments et lignes facture -----#
Call MAJ_TAXE (NOL) From SUBPIHB : If !GIMPORT Affzo [PIH4]10 : Endif
End

Subprog AS_TOTTAXAMT(VALEUR)
#---------------------------------------#
# Avant saisie total des taxes onglet 4 #
#---------------------------------------#
Variable Decimal VALEUR
If [M:PIH1]VACTYP=4 mkstat=2 : Endif
End

Subprog AM_TOTTAXAMT(VALEUR)
#--------------------------------------#
# Après modif total des taxes onglet 4 #
#--------------------------------------#
Variable Decimal VALEUR
[M:PIH1]TOTTAXAMT1=VALEUR
[M:PIH4]TOTTAXAMT =VALEUR
If !GIMPORT & !GWEBSERV
  Affzo [PIH1]TOTTAXAMT1,TOTATIAMT1
  #Issue 107878 - 2018-10-03 by RBA change due to sequence display
  #Affzo [PIH4]20,30
  Affzo [PIH4]25,30
Endif
Gosub MAJ_STATUT From SUBPIH
End

Subprog AV_TOTTAXCLC(VALEUR)
#--------------------------------#
# Avant zone total taxes calculé #
#--------------------------------#
Variable Decimal VALEUR
VALEUR=sum([M:PIH4]AMTTAX)
End

Subprog AV_DIFTAXAMT(VALEUR)
#-----------------------#
# Avant zone écart taxe #
#-----------------------#
Variable Decimal VALEUR
If [M:PIH1]VACTYP=4 Raz VALEUR Else VALEUR=[M:PIH4]TOTTAXAMT-sum([M:PIH4]AMTTAX) : Endif
End

Subprog AM_TOTLINAMT(VALEUR)
#--------------------------------------#
# Après modif total HT lignes onglet 4 #
#--------------------------------------#
Variable Decimal VALEUR
[M:PIH1]TOTLINAMT1=VALEUR
[M:PIH4]TOTLINAMT =VALEUR
If !GIMPORT & !GWEBSERV
  Affzo [PIH1]TOTLINAMT1,TOTATIAMT1
  Affzo [PIH4]DIFLINAMT,30
Endif
Gosub MAJ_STATUT From SUBPIH
End

Subprog AV_CLCLINAMT(VALEUR)
#------------------------#
# Avant zone HT calculé  #
#------------------------#
Variable Decimal VALEUR
VALEUR=[M:PIH3]CUMLINAMT1
End

Subprog AV_DIFLINAMT(VALEUR)
#----------------------#
# Avant zone écart TTC #
#----------------------#
Variable Decimal VALEUR
VALEUR=[M:PIH4]TOTLINAMT-[M:PIH4]CLCLINAMT
End

Subprog AV_AMTATI(VALEUR)
#----------------------#
# Avant zone total TTC #
#----------------------#
Variable Decimal VALEUR
VALEUR=sum([M:PIH4]INVDTAAMT)+[M:PIH4]TOTLINAMT+[M:PIH4]TOTTAXAMT
End

Subprog AV_DIFAMTATI(VALEUR)
#----------------------#
# Avant zone écart TTC #
#----------------------#
Variable Decimal VALEUR
Local    Shortint I
VALEUR=sum(INVORDAMT)+sum(INVLINAMT)+CLCLINAMT
If [M:PIH1]VACTYP<>4 VALEUR+=sum(AMTTAX) : Endif
If [M:PIH1]NBFAC1<>0
  For I=0 To [M:PIH1]NBFAC1-1
    If INVORDAMT(I)<>0 INVORDFLG(I)=2 : Endif
    If INVLINFLG(I)<6 & INVORDFLG(I)=1 VALEUR+=INVDTAAMT(I) : Endif
    If dim([M:PIH4]DISVATFLG)>0 & [M:PIH4]DISVATFLG(I)=2
      VALEUR-=[M:PIH4]INVORDAMT(I)
    Endif
  Next I
Endif
VALEUR=[M:PIH4]AMTATI-VALEUR
End

$MAJ_STATUT
#-----------------------------------------------#
# Mise à jour et affichage statut de la facture #
#-----------------------------------------------#
If [M:PIH1]STA=3 Return : Endif : # Si facture validée ne pas modifier le statut !!
If [M:PIH4]DIFTAXAMT<>0 | [M:PIH4]DIFLINAMT<>0 |
&  [M:PIH4]DIFAMTATI<>0 | sum([M:PIH4]INVDIFAMT)<>0 [M:PIH1]STA=1
                                               Else [M:PIH1]STA=2 : Endif
If !GIMPORT Affzo [PIH1]STA : Endif
Return

$AFFICH_LIG
#----------------------------------------#
# Affichage de la ligne après chargement #
#----------------------------------------#
# Issue 112754 - 2016-12-01 by SR : Services
If !varinit([M:PIH3]QTYUOM,NOL)
  Affzo [PIH3]ITMDES(NOL),UOM(NOL),NETPRI(NOL),PJT(NOL),ITMKND(NOL)
Else
  Affzo [PIH3]ITMDES(NOL),UOM(NOL),QTYUOM(NOL),NETPRI(NOL),AMTNOTLIN(NOL),PJT(NOL),ITMKND(NOL)
Endif
Gosub AFFICH_LINACC
Affzo [PIH3]LINPURTYP(NOL)
Gosub AFFICH_CCE
Affzo [PIH3]VAT1(NOL),VAT2(NOL),VAT3(NOL)
# Issue 70985 - 2012-06-12 by MUARN : landed cost
Affzo [PIH3]CPRCOE(NOL), CPRAMT(NOL), CPR(NOL), LINAMTCPR(NOL), NETCUR(NOL), CPRCUR(NOL), STCNUM(NOL), CSTPUR(NOL) ,LINCSTPUR(NOL)
Return

$AFFICH_LINACC
#---------------------------------------------#
# Affichage des comptes de la ligne réception #
#---------------------------------------------#
If dim(I)<1  Local Integer I : Endif
For I=1 To GNBCOA
  Case I
    When  1 : Affzo [PIH3]LINACC1(NOL)
    When  2 : Affzo [PIH3]LINACC2(NOL)
    When  3 : Affzo [PIH3]LINACC3(NOL)
    When  4 : Affzo [PIH3]LINACC4(NOL)
    When  5 : Affzo [PIH3]LINACC5(NOL)
    When  6 : Affzo [PIH3]LINACC6(NOL)
    When  7 : Affzo [PIH3]LINACC7(NOL)
    When  8 : Affzo [PIH3]LINACC8(NOL)
    When  9 : Affzo [PIH3]LINACC9(NOL)
    When 10 : Affzo [PIH3]LINACC10(NOL)
  Endcase
Next I
Return

$AFFICH_CCE
#----------------------------------------------------------#
# Affichage des sections analytiques de la ligne réception #
#----------------------------------------------------------#
If dim(I)<1  Local Integer I : Endif
For I=1 To GNBDIE
  Case I
    When  1 : Affzo [PIH3]CCE1 (NOL)
    When  2 : Affzo [PIH3]CCE2 (NOL)
    When  3 : Affzo [PIH3]CCE3 (NOL)
    When  4 : Affzo [PIH3]CCE4 (NOL)
    When  5 : Affzo [PIH3]CCE5 (NOL)
    When  6 : Affzo [PIH3]CCE6 (NOL)
    When  7 : Affzo [PIH3]CCE7 (NOL)
    When  8 : Affzo [PIH3]CCE8 (NOL)
    When  9 : Affzo [PIH3]CCE9 (NOL)
    When 10 : Affzo [PIH3]CCE10(NOL)
    When 11 : Affzo [PIH3]CCE11(NOL)
    When 12 : Affzo [PIH3]CCE12(NOL)
    When 13 : Affzo [PIH3]CCE13(NOL)
    When 14 : Affzo [PIH3]CCE14(NOL)
    When 15 : Affzo [PIH3]CCE16(NOL)
    When 16 : Affzo [PIH3]CCE17(NOL)
    When 17 : Affzo [PIH3]CCE17(NOL)
    When 18 : Affzo [PIH3]CCE18(NOL)
    When 19 : Affzo [PIH3]CCE19(NOL)
    When 20 : Affzo [PIH3]CCE20(NOL)
  Endcase
Next I
Return

$AFFICH_ACC
#----------------------------------------------------------#
# Affichage des comptes de la ligne élément de facturation #
#----------------------------------------------------------#
If dim(I)<1     Local Integer I    : Endif
If dim(PLAN)<1  Local Integer PLAN : Endif
For I=1 To GNBCOA
  If PLAN<>I : # Ne pas afficher si on se trouve en init sur le champ
    Case I
      When  1 : Affzo [PIH4]ACC1 (NOL)
      When  2 : Affzo [PIH4]ACC2 (NOL)
      When  3 : Affzo [PIH4]ACC3 (NOL)
      When  4 : Affzo [PIH4]ACC4 (NOL)
      When  5 : Affzo [PIH4]ACC5 (NOL)
      When  6 : Affzo [PIH4]ACC6 (NOL)
      When  7 : Affzo [PIH4]ACC7 (NOL)
      When  8 : Affzo [PIH4]ACC8 (NOL)
      When  9 : Affzo [PIH4]ACC9 (NOL)
      When 10 : Affzo [PIH4]ACC10(NOL)
    Endcase
  Endif
Next I
Return

$AFFICH_PFICCE
#-----------------------------------------------------------------#
# Affichage des sections analytiques ligne élément de facturation #
#-----------------------------------------------------------------#
If dim(I)<1  Local Integer I : Endif
For I=1 To GNBDIE
  Case I
    When  1 : Affzo [PIH4]PFICCE1 (NOL)
    When  2 : Affzo [PIH4]PFICCE2 (NOL)
    When  3 : Affzo [PIH4]PFICCE3 (NOL)
    When  4 : Affzo [PIH4]PFICCE4 (NOL)
    When  5 : Affzo [PIH4]PFICCE5 (NOL)
    When  6 : Affzo [PIH4]PFICCE6 (NOL)
    When  7 : Affzo [PIH4]PFICCE7 (NOL)
    When  8 : Affzo [PIH4]PFICCE8 (NOL)
    When  9 : Affzo [PIH4]PFICCE9 (NOL)
    When 10 : Affzo [PIH4]PFICCE10(NOL)
    When 11 : Affzo [PIH4]PFICCE11(NOL)
    When 12 : Affzo [PIH4]PFICCE12(NOL)
    When 13 : Affzo [PIH4]PFICCE13(NOL)
    When 14 : Affzo [PIH4]PFICCE14(NOL)
    When 15 : Affzo [PIH4]PFICCE16(NOL)
    When 16 : Affzo [PIH4]PFICCE17(NOL)
    When 17 : Affzo [PIH4]PFICCE17(NOL)
    When 18 : Affzo [PIH4]PFICCE18(NOL)
    When 19 : Affzo [PIH4]PFICCE19(NOL)
    When 20 : Affzo [PIH4]PFICCE20(NOL)
  Endcase
Next I
Return

#1099.sn
Subprog AM_FRM1099(VALEUR)
#--------------------------------------------------------------------#
# When we have a Form Value allow entry of Box, and
# For Transactions Disable DAS2 if a 1099 since we can only allow one
#--------------------------------------------------------------------#
Variable Integer VALEUR

Call AM_FRM1099(VALEUR, "PIH1") From TEN99LIB  # with screen.#rs.n

End

Subprog AV_AMTSUBJ1099(VALEUR)
#-----------------------------------------------------------------#
# AMTSUBJ1099 is disabled
# but since we need to display/hide it by
# Chgfmt [M:BIS1]AMT1099  With "-K:10X"
# The disabled MD1 field ends up allowing entry when
#  it is re-displayed so it needs an additional
#  screen definition option of "$" (param format=GRMT)
# and the following code to set GFMT = "Nz3:"+GDEVFMT
# and we also need to re-Grizo it.
#-----------------------------------------------------------------#
Variable Decimal VALEUR
Local Char CPYDCLFEES

If  func AFNC.ACTIV("FEE")  # Issue X3-107197
  CPYDCLFEES = func AFNC.PARAM("DCLFEES", GSOCIETE)
Endif  # End Issue X3-107197

#
# If adding other Legislational XXxxxxxx please do it here.
#
# One can have not have both DAS and 1099
Case CPYDCLFEES

    When "3":                  # 1099
        GFMT = "NPz3:"+GDEVFMT
        If GS1099=1 & !GIMPORT
          Grizo [M:PIH1]AMTSUBJ1099 # 1099.sn
          Gosub CURR_CHECK From TEN99LIB
          If CURDIF=1 & [M:PIH1]STA < 3
            GFMT = "Nz3:"+ GDEVFMT
            Actzo [M:PIH1]AMTSUBJ1099
          Endif  #1099.en
        Endif

    When Default:            # None or DAS
        GFMT = "-Nz3:"+GDEVFMT
Endcase

End

Subprog D_FLG1099(VALEUR)
#-----------------------------------------------------------------#
# On a new line
# Default "Yes" only if this is a 1099 invoice
#-----------------------------------------------------------------#
Variable Integer VALEUR

If [M:PIH1]FRM1099 > 1
  VALEUR = 2
Else
  VALEUR = 1
Endif
End

#1099.en


