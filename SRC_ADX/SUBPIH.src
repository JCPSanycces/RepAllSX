Subprog D_DCLEECNUM(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL = nolign-1
If [F:BPR]BPRNUM<>[M:PIH0]BPR
   Read [BPR] BPR0=[M:PIH0]BPR
   If fstat Raz [F:BPR] : Endif
Endif
If NOL = 0
  VALEUR = [F:BPR]EECNUM
Else
  VALEUR = [M:PIH3]DCLEECNUM(NOL-1)
  If VALEUR = ""
     VALEUR = [F:BPR]EECNUM
  Endif
Endif
End


