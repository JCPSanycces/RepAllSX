Local    Integer PLAN : PLAN=10 : Gosub C_ACCX
End

Subprog AM_ACC10(VALEUR)
Variable Char    VALEUR()
Local    Integer PLAN : PLAN=10 : Gosub AM_ACCX
End

$D_ACCX
#---------------------------------------#
# Initialisation commune aux 10 comptes #
#---------------------------------------#
If PLAN>GNBCOA  Return : Endif
Local Shortint NOL : NOL=nolign-1
Call INIT_COMPTES_INVDTA(NOL) From SUBPIHC
Case PLAN
  When  1 : VALEUR=[M:PIH4]ACC1(NOL)
  When  2 : VALEUR=[M:PIH4]ACC2(NOL)
  When  3 : VALEUR=[M:PIH4]ACC3(NOL)
  When  4 : VALEUR=[M:PIH4]ACC4(NOL)
  When  5 : VALEUR=[M:PIH4]ACC5(NOL)
  When  6 : VALEUR=[M:PIH4]ACC6(NOL)
  When  7 : VALEUR=[M:PIH4]ACC7(NOL)
  When  8 : VALEUR=[M:PIH4]ACC8(NOL)
  When  9 : VALEUR=[M:PIH4]ACC9(NOL)
  When 10 : VALEUR=[M:PIH4]ACC10(NOL)
Endcase
Gosub AFFICH_ACC
Return

$AS_ACCX
#-------------------------------------#
# Avant saisie commune aux 10 comptes #
#-------------------------------------#
Call AVSAI_ACC(VALEUR,PLAN,"[M:PIH4]ACC") From TRTX3CPT
Return

$C_ACCX
#--------------------------------#
# Contrôle commun aux 10 comptes #
#--------------------------------#
Local    Shortint NOL : NOL=nolign-1
#-----
Call CTRL_ACC(VALEUR,PLAN,GFINRSP,[M:PIH0]ACCDAT,[M:PIH1]CUR,"[M:PIH4]ACC") From TRTX3CPT
#-----
Return

$AM_ACCX
#------------------------------------#
# Après modif commune aux 10 comptes #
#------------------------------------#
Local    Shortint I
Local    Shortint NOL : NOL=nolign-1
#-----
# Issue 122292 - 2017-03-29 by MUARN : ne pas faire en import
# Issue 106746 - 2015-04-02 by SR :
If find(GREP,"C","D") & !GIMPORT
  For I=PLAN+1 To dim(GCOA)
      If I<=GNBCOA
         Assign "[M:PIH4]ACC"+num$(I)+"(NOL)" With ""
      Else
         Break
      Endif
  Next
Endif
# End issue 106746
Call APMOD_ACC(VALEUR,PLAN,"[M:PIH4]ACC") From TRTX3CPT
#-----
If [F:GAC]COA<>GCOA(PLAN) | [F:GAC]ACC<>VALEUR
   Read [GAC] GAC0=GCOA(PLAN);VALEUR : If fstat Raz [F:GAC] : Endif
Endif
Assign "[M:PIH4]ACC"+num$(PLAN)+"(NOL)" With VALEUR
GBIDI2=1 : Gosub PREP_INIT_PFICCE From SUBPIHB
Return

Subprog AS_DSP(VALEUR)
#---------------------------------------#
# Avant saisie de la clé de répartition #
#---------------------------------------#
Variable Char    VALEUR()
Local Shortint NOL : NOL=nolign-1
Local Char     WACC(GLONGAC)
Call RECH_ACC(2,"[M:PIH4]ACC",NOL,WACC) From TRTX3CPT
If WACC=""  mkstat=2 : End : Endif
End

Subprog AM_DSP(VALEUR)
#---------------------------------------------#
# Après modification de la clé de répartition #
#---------------------------------------------#
Variable Char    VALEUR()
Local Shortint I
Local Shortint NOL : NOL=nolign-1
[M:PIH4]DSP(NOL)=VALEUR
GBIDI2=1 : Gosub PREP_INIT_PFICCE From SUBPIHB
End


