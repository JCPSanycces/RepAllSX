#<AdxTL>@(#)5.0.0.0 $Revision$
#########################################################################
# SUBPIH : Gestion des factures d'achat                    MBT 15/09/98 #
# --------------------------------------------------------------------- #
# Traitements sur champ "Call" de l'objet "PIH"                         #
# Le traitement des actions "Gosub" se trouvent dans le SUBPIHA         #
#                                                                       #
#########################################################################

# Issue X3-107197 - 2018-09-11 by CBO : PARAMETER AND ACTIVITY CODE

$ACTION
#--- Dem 74959
# Entry point reserved for ETO
GPOINT=ACTION
GPE=0
Gosub ENTREE From EXEFNC
If GPE=1 : Return : Endif
#---------------------------------#
# Actions de l'objet PIH (GOBJET) #
#---------------------------------#

Case ACTION
 When "DEFTRANS"      : Gosub DEFTRANS      From SUBPIHA
 When "VARIANTE"      : Gosub VARIANTE      From SUBPIHA
 When "SETTRANS"      : Gosub SETTRANS      From SUBPIHA
 When "FILTRE"        : Gosub FILTRE        From SUBPIHA
 When "AV_IMPRIME"    : Gosub AV_IMPRIME    From SUBPIHA
 When "AP_IMPRIME"    : Gosub RELIT         From GOBJSUB
 When "OUVRE"         : Gosub OUVRE         From SUBPIHA
 When "OUVRE_BOITE"   : Gosub OUVRE_BOITE   From SUBPIHA
 When "SETBOUT"       : Gosub SETBOUT       From SUBPIHA
 When "AVANTBOUT"     : Gosub AVANTBOUT     From SUBPIHA
 When "EXEBOUT"       : Gosub EXEBOUT       From SUBPIHA
 When "STATUT"        : Gosub STATUT        From SUBPIHA
 When "HINT"          : Gosub HINTCLE       From SUBPIHA
 When "CLE_GAUCHE"    : Gosub CLE_GAUCHE    From SUBPIHA
 When "FILGAUCHE"     : Gosub FILGAUCHE     From SUBPIHA
 When "AP_FILGAUCHE"  : Gosub AP_FILGAUCHE  From SUBPIHA
 When "DEB_PICK"      : Gosub DEB_PICK      From SUBPIHA
 When "PICKE"         : Gosub PICKE         From SUBPIHA
 When "DEPICK"        : Gosub DEPICK        From SUBPIHA
 When "FIN_PICK"      : Gosub FIN_PICK      From SUBPIHA
 When "APRES_MODIF"   : Gosub APRES_MODIF   From SUBPIHA
 When "DEFLIG"        : Gosub DEFLIG        From SUBPIHA
 When "LIENS_LIG"     : Gosub LIENS_LIG     From SUBPIHA
 When "INICRE_LIG"    : Gosub INICRE_LIG    From SUBPIHA
 When "INIMOD_LIG"    : Gosub INIMOD_LIG    From SUBPIHA
 When "VALLIG"        : Gosub VALLIG        From SUBPIHA
 When "RAZCRE"        : Gosub RAZCRE        From SUBPIHA
 When "RAZDUP"        : Gosub RAZDUP        From SUBPIHA
 When "LIENS"         : Gosub LIENS         From SUBPIHA
 When "VERIF_CRE"     : Gosub VERIF_CRE     From SUBPIHA
 When "INICRE"        : Gosub INICRE        From SUBPIHA
 When "CREATION"      : Gosub CREATION      From SUBPIHA
 When "APRES_CRE"     : Gosub APRES_CRE     From SUBPIHA
 When "AB_CREATION"   : Gosub AB_CREATION   From SUBPIHA
 When "AVANT_MOD"     : Gosub AVANT_MOD     From SUBPIHA
 When "VERIF_MOD"     : Gosub VERIF_MOD     From SUBPIHA
 When "AVANT_MODFIC"  : Gosub AVANT_MODFIC  From SUBPIHA
 When "AVANT_CHOI"    : Gosub AVANT_CHOI    From SUBPIHA
 When "APRES_CHOI"    : Gosub APRES_CHOI    From SUBPIHA
 When "INIMOD"        : Gosub INIMOD        From SUBPIHA
 When "MODIF"         : Gosub MODIF         From SUBPIHA
 When "APRES_MOD"     : Gosub APRES_MOD     From SUBPIHA
 When "AB_MODIF"      : Gosub AB_MODIF      From SUBPIHA
 When "ABANDON"       : Gosub ABANDON       From SUBPIHA
 When "VERF_ANU"      : Gosub VERF_ANU      From SUBPIHA
 When "ANNULE"        : Gosub ANNULE        From SUBPIHA
 When "AP_ANNULE"     : Gosub AP_ANNULE     From SUBPIHA
 When "FIN_ACTION"    : Gosub FIN_ACTION    From SUBPIHA
 When "FERME"         : Gosub FERME         From SUBPIHA
 #MAE, bg 77405
 When "VERROU"        : Gosub VERROU_HAE    From SUBPIHA
 When "DEVERROU"      : Gosub DEVERROU_HAE  From SUBPIHA
#---------------------------#
# Actions champs modèlisées #
#---------------------------#
 When "AVANT_SUITE"   : Gosub AVANT_SUITE   From SUBPIHA
# Issue 71069 - 2016-01-08 by MUARN : PJT déplacé dans SUBPIHD
 When "AB1_NBLIG"     : Gosub AB1_NBLIG     From SUBPIHD
 When "AB11_NBLIG"    : Gosub AB11_NBLIG    From SUBPIHD
 When "AB1_NUMORI"    : Gosub AB1_NUMORI    From SUBPIHD
 When "AB1_ITMDES"    : Gosub AB1_ITMDES    From SUBPIHD
 When "BB1_ITMDES"    : Gosub BB1_ITMDES    From SUBPIHD
 When "AB1_ITMDES1"   : Gosub AB1_ITMDES    From SUBPIHD
 When "BB1_ITMDES1"   : Gosub BB1_ITMDES    From SUBPIHD
 When Default
Endcase
Return

Subprog AM_FCY(VALEUR)
#---------------------------------------------------#
#     Après modification du site de facturation     #
# ------------------------------------------------- #
# Rechargement GSOCIETE : Société juridique         #
#              GLOCALDEV: Devise sté juridique      #
#              GFINRSP  : Site financier            #
#              GFCY     : Site facturation          #
# Récupération des paramètres achats et budget      #
#---------------------------------------------------#
Variable Char     VALEUR
Local Integer RET
GFCY=VALEUR : Gosub CHARG_PARAM From SUBPIHA

# Issue 71069 - 2013-08-23 by MUARN : PJT
# A faire avant tout le reste
If GPJTSNGDOC = G_NON Then
 Call PJT_MODFCY(VALEUR,"[M:PIH3]PJT") From TRTPJT
Endif

#----- Erreur au chargement des paramètres-----#
If GMESSAGE<>""
  Local Char WMESS(80) : WMESS=GMESSAGE
  GERR=1
  GFCY=[M:PIH0]FCY : Gosub CHARG_PARAM From SUBPIHA
  GMESSAGE=WMESS
  mkstat=1 : End
Endif
# Issue 71253 - 2012-05-10 by SR : Localisation espagnole
If !GIMPORT : Affzo [M:PIH1]5 : Setmok [PIH1] With 0 : Endif
If !GIMPORT : Affzo [M:PIH3]5 : Setmok [PIH3] With 0 : Endif
#----- Effacement tableau des sections entête -----#
If dim([M:PIH1]NBAXE)>0 & [M:PIH1]NBAXE>0
  Effzo [PIH1]25 : [M:PIH0]FCY=VALEUR : Affzo [PIH1]25 : Setmok [PIH1] With 0
Endif
#-----
[M:PIH4]DSPWEU=GSALDSPWEU
[M:PIH4]DSPVOU=GSALDSPVOU
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL From SUBPIHA
#----- Chargement indicateur inter-sociétés et client facture -----#
If GMODU(5)=2 : # Module ventes actif !
  If !clalev([F:BPR2])  Local File BPARTNER  [BPR2] : Endif
  Read [BPR2] BPR2(2)=2;GFCY : If fstat  Raz [F:BPR2] : Endif
  [G:BPR2]currind=1 : [G:BPR2]currlen=0 : # Réinitialisation clé par défaut
  If [F:BPR2]FCY="" | [F:BPR2]BPCFLG<>2
    [M:PIH0]BETCPY=1 : [M:PIH0]BPCINV=""
  Else
    [M:PIH0]BETCPY=2 : [M:PIH0]BPCINV=[F:BPR2]BPRNUM
  Endif
  #----- Le fournisseur est déjà renseigné -----#
  If [M:PIH0]BPR<>""
    If [F:BPR]BPRNUM<>[M:PIH0]BPR
      Read [BPR] BPR0=[M:PIH0]BPR : If fstat  Raz [F:BPR] : Endif
    Endif
    If [F:BPR]FCY<>""
      If [F:FCY]FCY<>[F:BPR]FCY
        Read [FCY] FCY0=[F:BPR]FCY : If fstat  Raz [F:FCY] : Endif
      Endif
      If [F:FCY]LEGCPY<>GSOCIETE
        [M:PIH0]BETCPY=2 : GCPY=[F:FCY]LEGCPY
      Else
        [M:PIH0]BETCPY=1
      Endif
    Else
      [M:PIH0]BETCPY=1
    Endif
  Endif
Else
  [M:PIH0]BETCPY=1 : [M:PIH0]BPCINV=""
Endif
If !GIMPORT  Affzo [PIH0]BETCPY2 : Endif
#----- Traitement du champ "Bon à payer" -----#
If GPIH_FLGPAZ<>2
  [M:PIH0]PAZ=len(mess(0,510,1)) : Diszo [PIH0]PAZ
Elsif [M:PIH0]PIVTYP<>""
  If [F:TPV]PIVTYP<>[M:PIH0]PIVTYP
    #MAE, ajout LEG
    Call LEC_TPV_LEG(GCURLEG,[M:PIH0]PIVTYP,RET) From TRTLECLEG
    #Read [TPV] TPV0=[M:PIH0]PIVTYP :
    If RET Raz [F:TPV] : Endif
  Endif
  If [F:TPV]PIHTYP>2
    [M:PIH0]PAZ=len(mess(0,510,1))
    #----- Si avoir toutes les valeurs sont permises -----#
    Actzo [PIH0]PAZ
  Else
    # Issue 84063 - 2013-01-04 by MUARN : ajout site facturation
    #Call PARAMUTIL("DEFBONPAY",GBIDC3,"","") From SUBAUS
    Call PARAMUTIL("DEFBONPAY",GBIDC3,"",[M:PIH0]FCY) From SUBAUS
    If val(GBIDC3)<1  GBIDC3="1" : Endif
    [M:PIH0]PAZ=val(GBIDC3)
    #----- Si facture, pas de saisie si une seule valeur possible -----#
    # Issue 84063 - 2013-01-04 by MUARN : ajout site facturation
    #Call PARAMUTIL("NIVBONPAYE",GBIDC3,"",GFCY) From SUBAUS
    Call PARAMUTIL("NIVBONPAYE",GBIDC3,"",[M:PIH0]FCY) From SUBAUS
    If val(GBIDC3)<1  GBIDC3="1" : Endif
    If val(GBIDC3)=1  Diszo [PIH0]PAZ Else Actzo [PIH0]PAZ : Endif
  Endif
Else
  [M:PIH0]PAZ=1 : Actzo [PIH0]PAZ
Endif
If !GIMPORT  Affzo [PIH0]PAZ : Endif
#----- Chargement du cours devise et du cours reporting -----#
If [M:PIH1]CUR<>""
  If GPIHCURDAT<>2
    [M:PIH1]RATDAT=[M:PIH0]ACCDAT
  Else
    [M:PIH1]RATDAT=[M:PIH1]BPRDAT
  Endif
  Call INI_COURS("PIH1",GSOCIETE,[M:PIH1]CUR,[M:PIH1]RATDAT,[M:PIH1]CURTYP) From SUBBICS
  If !GIMPORT
    Affzo [PIH1]RAT1, LABEL, RAT2, CURMLT
  Endif
Endif
#----- Si changement de société -----#
If GSOC_UPDFLG
  If [M:PIH0]BPR<>""
    Call INIT_REGIME  ([M:PIH0]BPR,GSOCIETE,"F",[M:PIH1]VAC)  From CPTSUB
    Call INIPTE([F:BPS]BPRPAY,[F:BPS]BPSNUM,"F",[M:PIH1]PTE)  From TRTX3
    Call INIT_ESCOMPTE([M:PIH0]BPR,GSOCIETE,"F",[M:PIH1]DEP)  From CPTSUB
    Call AM_DEP([M:PIH1]DEP) From SUBPIH
    Affzo [PIH1]VAC, PTE, DEP
  Endif
Endif

#Display 1099 fields depending on Site>company                              #1099.sn
# Parameter in CPT Module, DAS Group is defined at Company Level
#  allows supplier payment tracking to be launched for the Fees Declaration.
If func AFNC.ACTIV("FEE") Call AM_FCY(VALEUR, "PIH1") From TEN99LIB : Endif  #1099.en

#Localisation Belge --str
If  func AFNC.ACTIV("KBE")
  Call BEL_VCS([M:PIH0]BPR,[M:PIH0]PIVTYP) From SUBPIH
Endif
#Localisation Belge --end

# Issue 83026 - 2012-08-02 by MUARN : early discount
Call DISPLAY_BASDEP From SUBPIHC

# Issue 71069 - 2013-08-23 by MUARN : PJT
# A faire apres tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY(VALEUR,"[M:PIH3]PJT") From TRTPJT
Endif

If dim([M:PIH0]ORIDOCNUM) > 0
  Call SHOW_HIDE_PORIDOCNUM(VALEUR,[M:PIH0]PIVTYP,"PIH0") From PORLEGLIB
Endif
End

#Localisation Belge --str
Subprog BEL_VCS(IN_BPR,IN_INVTYP)
#--------------------------------------------------------------------#
# Management of VCS field on PIH1 screen                             #
#   - called by AM_FCY, AM_PIVTYP, AM_BPR                            #
#--------------------------------------------------------------------#
Value Char IN_BPR
Value Char IN_INVTYP

Local Integer RET
Local Integer WRAZORHIDE
Local Integer WINVTYP
Local Char WCRY(GLONCRY)

WRAZORHIDE = 1  :#-- default raz field, -1 = hide field
RET=0
Raz WCRY
Raz WINVTYP

If IN_INVTYP<>""
  Call LEC_TPV_LEG(GCURLEG,IN_INVTYP,RET) From TRTLECLEG
  #Read [TPV]TPV0=IN_INVTYP : If fstat : Raz [F:TPV] : RET=1: Endif
  If RET=0 & [F:TPV]INVTYP=5
    WINVTYP=5
    WRAZORHIDE = -1 :#-- hide proforma
    Raz [M:PIH1]BELVCS
    RET=1
  Endif
Endif

If RET=0
  If IN_BPR <> ""
    Call LEC_BPR(IN_BPR) From CPTLEC
    If !fstat : WCRY=[F:BPR]CRY : Endif
  Endif
Endif

If !GIMPORT
  Call DISPLAY_VCS("PIH1",WCRY,0,WRAZORHIDE)  From INVVCSLIB
Else
  If (WINVTYP=5) or (IN_BPR<>"" & WCRY<>"BE")
    Diszo [M:PIH1]BELVCS
  Else
    Actzo [M:PIH1]BELVCS
  Endif
Endif
End
#Localisation Belge --end

Subprog AM_PIVTYP(VALEUR)
#--------------------------------------------------------------------#
# Après modification du type de facture : Récupération code compteur #
#--------------------------------------------------------------------#
Variable Char    VALEUR()
#-- Les compteurs ne sont plus définis au niveau des types de facture utilisateur --#
# GMANCOU=[F:TPV]MANCOU : GCODNUM=[F:TPV]CODNUM
#----------------------------------------------------------------------#
# Prendre par défaut celui de la table des affectations de compteur    #
# au cas ou les compteurs ne seraient pas défini dans le type de pièce #
#----------------------------------------------------------------------#
Local Integer RET
If [F:TCA]MODULE<>6
  Read [TCA] TCA0=6
  If fstat GMESSAGE=mess(64,199,1) : GERR=1 : mkstat=1 : End : Endif
Endif
GMANCOU=[F:TCA]MANCOU([F:TPV]PIHTYP+6) : GCODNUM=[F:TCA]CODNUM([F:TPV]PIHTYP+6)
#----- Chargement du type de pièce et du journal à partir du type de facture -----#
[M:PIH0]GTE=[F:TPV]GTE : [M:PIH0]JOU=[F:TPV]JOU
#----- LECTURE du type de pièce comptable -----#
If [F:GTE]TYP<>[M:PIH0]GTE
  #MAE, ajout LEG
  Call LEC_GTE_LEG(GCURLEG,[M:PIH0]GTE,RET) From TRTLECLEG
  #Read [GTE] GTE0=[M:PIH0]GTE :
  If RET Raz [F:GTE] : Endif
Endif
If [M:PIH0]GTE<>""
  #----- Type de pièce inexistant ! -----#
  If [F:GTE]TYP=""
    GMESSAGE=[M:PIH0]GTE-mess(17,114,1)  : GERR=1 : mkstat=1 : End
  Endif
  #----- Type de pièce inactive ! -----#
  If [F:GTE]ENAFLG<>2
    GMESSAGE=[M:PIH0]GTE-mess(274,199,1) : GERR=1 : mkstat=1 : End
  Endif
  #----- Type de pièce non réel ! -----#
  If [F:GTE]VCRREA<>2
    GMESSAGE=[M:PIH0]GTE-mess(59,119,1)  : GERR=1 : mkstat=1 : End
  Endif
  #----- Vois n'avez pas les droits d'exécution ! -----#
  If [F:GTE]ACS<>""
    Call CONTEXE([F:GTE]ACS) From CPTSUB
    If mkstat GMESSAGE=[F:GTE]ACS-GMESSAGE : GERR=1 : End : Endif
  Endif
Endif
#----- Récupération du compteur et du code manuel à partir du type de pièce -----#
If [F:GTE]COU<>""
  GMANCOU=[F:GTE]MANNUM : GCODNUM=[F:GTE]COU
Endif
#----- Initialisation de la zone bon à payer -----#
If GPIH_FLGPAZ=2
  If [F:TPV]PIHTYP>2
    [M:PIH0]PAZ=len(mess(0,510,1))
  Else
    # Issue 84063 - 2013-01-04 by MUARN : ajout site facturation
    #Call PARAMUTIL("DEFBONPAY",GBIDC3,"","") From SUBAUS
    Call PARAMUTIL("DEFBONPAY",GBIDC3,"",[M:PIH0]FCY) From SUBAUS
    If val(GBIDC3)<1  GBIDC3="1" : Endif
    [M:PIH0]PAZ=val(GBIDC3)
  Endif
Endif
#----- Saisie du champ facture d'origine que si type = avoir -----#
If [F:TPV]PIHTYP=3 Actzo [PIH1]INVNUM Else Grizo [PIH1]INVNUM : Endif
#----- Saisie condition paiement dans tous les cas -----#
Actzo [PIH1]PTE
If dim([M:PIH1]ZPTE)>0 Actzo [PIH1]ZPTE : Endif
If [M:PIH0]BPR<>""
  If [F:BPS]BPSNUM<>[M:PIH0]BPR
    Read [BPS] BPS0=[M:PIH0]BPR : If fstat Raz [F:BPS] : Endif
  Endif
  #----- Condition de paiement du tiers payé -----#
  Call INIPTE ([F:BPS]BPRPAY, [M:PIH0]BPR, "F", [M:PIH1]PTE) From TRTX3
  #-----
  If !GIMPORT
    Affzo [PIH1]PTE
    If dim([M:PIH1]ZPTE)>0  Affzo [PIH1]ZPTE : Endif
  Endif
Endif
#----- Traitement affichage zone bon à payer (PAZ) -----#
If !GIMPORT  Affzo [PIH0]PAZ : Endif
If GPIH_FLGPAZ=2
  If [F:TPV]PIHTYP<3
    #----- Si facture, pas de saisie si une seule valeur possible -----#
    # Issue 84063 - 2013-01-04 by MUARN : ajout site facturation
    #Call PARAMUTIL("NIVBONPAYE",GBIDC3,"",GFCY) From SUBAUS
    Call PARAMUTIL("NIVBONPAYE",GBIDC3,"",[M:PIH0]FCY) From SUBAUS
    If val(GBIDC3)<1  GBIDC3="1" : Endif
    If val(GBIDC3)=1  Diszo [PIH0]PAZ Else Actzo [PIH0]PAZ : Endif
  Else
    #----- Si avoir toutes les valeurs sont permises -----#
    Actzo [PIH0]PAZ
  Endif
Endif
#----- Inversion débit/crédit suivant facture ou avoir -----#
If [M:PIH1]NBFAC1>0
  If ([M:PIH0]PIHTYP<3 & [F:TPV]PIHTYP>2) | ([M:PIH0]PIHTYP>2 & [F:TPV]PIHTYP<3)
     Local Shortint I
     For I=0 To [M:PIH1]NBFAC1-1
         [M:PIH1]DEBCDT1(I)=3-[M:PIH1]DEBCDT1(I)
         [M:PIH4]DEBCDT(I)=[M:PIH1]DEBCDT1(I)
     Next I
     If !GIMPORT  Affzo [PIH1]20 : Affzo [PIH4]5 : Endif
  Endif
Endif
If [F:TPV]PIHTYP <> [M:PIH0]PIHTYP
   [M:PIH0]PIHTYP=[F:TPV]PIHTYP
Endif

#Localisation Belge --str
If  func AFNC.ACTIV("KBE")
  Call BEL_VCS([M:PIH0]BPR,VALEUR) From SUBPIH
Endif
#Localisation Belge --end

If dim([M:PIH0]ORIDOCNUM) > 0
  Call SHOW_HIDE_PORIDOCNUM([M:PIH0]FCY,VALEUR,"PIH0") From PORLEGLIB
Endif

End

Subprog AS_NUM(VALEUR)
#-----------------------------------#
# Avant saisie du numéro de facture #
#-----------------------------------#
Variable Char    VALEUR()
If (GREP="C" | GREP="D") & GMANCOU<>2  mkstat=2 : Endif
End

Subprog C_NUM(VALEUR)
#--------------------------------#
# Contrôle sur numéro de facture #
#--------------------------------#
Variable Char    VALEUR()
#-------- Compteur manuel, numéro obligatoire ! --------#
# If GMANCOU=2 & VALEUR="" GMESSAGE=mess(182,199,1) : mkstat=1 : End : Endif
#----- Rien d'affiché, vérif si un enregistrement existe -----#
If [M:PIH0]NUM="" & GREP<>"C"
   Look [PIH] PIH0=VALEUR
   If fstat GMESSAGE=mess(178,199,1) : mkstat=1 : End : Endif
Endif
#----- En création ou dupli et cteur manuel, contrôle si no existe déja -----#
If (GREP<>"C" & GREP<>"D") | GMANCOU<>2 End : Endif
Look [PIH] PIH0=VALEUR
If fstat
  #----- Vérification si clés existent déjà dans GACCDUDATE, GACCENTRY & GACCTMP -----#
  If [M:PIH0]GTE<>"" & VALEUR<>""
    Call EXISTE_GTE_NUM([M:PIH0]GTE,VALEUR) From SUBPIHA
  Endif
  End
Endif
GMESSAGE=mess(22,100,1) : mkstat=1
End

Subprog C_ACCDAT(VALEUR)
#-------------------------#
# Contrôle date comptable #
#-------------------------#
Variable Date    VALEUR
Local Decimal EXERCICE , PERIODE
Call GETPERSOC(GSOCIETE,GTYPGEN,VALEUR,EXERCICE,PERIODE) From CPTSUB
#------- Date incorrecte ? -------#
If EXERCICE=0 | PERIODE=0 GMESSAGE=mess(1,104,1)  : Goto ERR_ACCDAT : Endif
Read [FIY] FIY0=GSOCIETE;GTYPGEN;EXERCICE : If fstat Raz [F:FIY] : Endif
#----- Exercice non ouvert ? -----#
If [F:FIY]FIYSTA<>2       GMESSAGE=mess(20,101,1) : Goto ERR_ACCDAT : Endif
#----- Période non ouverte ? -----#
If [F:PER]PERSTA<2        GMESSAGE=mess(35,101,1) : Goto ERR_ACCDAT : Endif
#------- Période fermée ? --------#
If [F:PER]PERSTA>2        GMESSAGE=mess(36,101,1) : Goto ERR_ACCDAT : Endif

# 71937 : Multilégislation
#Call LECTURE("GTE",[M:PIH0]GTE,"") From CONTOBJ
Local Integer WRET
Call LEC_GTE_LEG(GCURLEG,[M:PIH0]GTE,WRET) From TRTLECLEG

Call CTLVLYDAT(VALEUR,[F:GTE]VLYSTR,[F:GTE]VLYEND) From CPTSUB
#----- Hors limite des dates de validité ? ------#
If mkstat     GMESSAGE=[F:GTE]TYP-GMESSAGE        : Goto ERR_ACCDAT : Endif
#----- Contrôle date pour certification NF -----#
If find(GREP,"C","D")
  Call CTLDAT_CNF(6,GFCY,[0/0/0],VALEUR,"","") From CONTX3
  If mkstat  End : Endif
Endif
End
#----- Si erreur forcer la saisie de la date -----#
$ERR_ACCDAT
GPIHACCDAT=2 : mkstat=2
End

Subprog AM_ACCDAT(VALEUR)
#----------------------------#
# Après modif date comptable #
#----------------------------#
Variable Date    VALEUR
#-----
If !find(GREP,"C","D")
  #----- Récupération code compteur -----#
  If !clalev([F:ANM])  Local File ACODNUM [ANM] : Endif
  If [F:TCA]MODULE<>6 | [F:TCA]CPY<>GSOCIETE
    Local Integer OK
    Call LECTCA(6,OK) From SUBTCA
    If fstat | !OK  Raz [F:TCA] : Endif
  Endif
  GMANCOU=[F:TCA]MANCOU([M:PIH0]PIHTYP+6) : GCODNUM=[F:TCA]CODNUM([M:PIH0]PIHTYP+6)
  If [F:GTE]TYP<>[M:PIH0]GTE
    #Read [GTE] GTE0=[M:PIH0]GTE
    Local Integer WRET
    Call LEC_GTE_LEG(GCURLEG,[M:PIH0]GTE,WRET) From TRTLECLEG
    If WRET : Raz [F:GTE] : Endif
  Endif
  If [F:GTE]COU<>""
    GMANCOU=[F:GTE]MANNUM : GCODNUM=[F:GTE]COU
  Endif
  #----- Controle date pour certification NF -----#
  Call CTLDAT_CNF(6,GFCY,[M:PIH0]ACCDAT,VALEUR,GCODNUM,[M:PIH0]NUM) From CONTX3
  If mkstat
    Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE : End
  Endif
Endif
#----- Si avoir, contrôle date facture origine pas supérieure à date d'avoir -----#
If [M:PIH0]PIHTYP=3 & [M:PIH1]INVNUM<>""
  If !clalev([PIHB])  Local File PINVOICE [PIHB] : Endif
  Read [PIHB] PIH0=[M:PIH1]INVNUM : If fstat Raz [F:PIHB] : Endif
  If [F:PIHB]ACCDAT>VALEUR
    Call ERREUR([M:PIH1]INVNUM-"("+num$([F:PIHB]ACCDAT)+")\"-mess(407,194,1)) From GESECRAN
    mkstat=1 : End
  Endif
#----- Si des lignes existent, contrôle date des documents d'origine -----#
Elsif GCTLDATORI=2 & [M:PIH3]NBLIG>0
  Call CTLDAT_ORI(VALEUR) From SUBPIHD
  If mkstat
    Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE : End
  Endif
Endif
#----- Initialisation de la date facture fournisseur -----#
If !varinit([M:PIH1]BPRDAT) | [M:PIH1]BPRDAT=[M:PIH0]ACCDAT
  [M:PIH0]ACCDAT=VALEUR
  Call AM_BPRDAT(VALEUR)
  [M:PIH1]BPRDAT=VALEUR
  Affzo [PIH1]BPRDAT
Endif
#-----
If [M:PIH1]CUR<>"" & GPIHCURDAT<>2
  [M:PIH1]RATDAT=VALEUR
  [M:PIH0]ACCDAT=VALEUR
  Call INI_COURS("PIH1",GSOCIETE,[M:PIH1]CUR,[M:PIH1]RATDAT,[M:PIH1]CURTYP) From SUBBICS
  #-----
  If !GIMPORT
    Affzo [PIH1]RAT1, LABEL, RAT2, CURMLT
  Endif
Endif
End

Subprog AM_BPR(VALEUR)
#-----------------------------------#
# Après modif fournisseur facturant #
#-----------------------------------#
Variable Char    VALEUR()
Local    Integer  I
Local    Char     SECTION(GLONCCE)
Local    Char     CODCPT(GLONCAC)
#----- Affichage des observations fournisseur -----#
If len([F:BPS]BPSREM) Call MESSAGE([F:BPS]BPSREM) From GESECRAN : Endif
#----- Lecture BPARTNER si nécessaire pour chargement CUR, LAN -----#
If [F:BPR]BPRNUM<>VALEUR
  Read [BPR] BPR0=VALEUR
  If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
If GACTDEB=2
  If [F:TCY]CRY<>[F:BPR]CRY
    Read [TCY] TCY0=[F:BPR]CRY : If fstat Raz [F:TCY] : Endif
  Endif
  If GPIH_CPYCRY<>[F:BPR]CRY & [F:TCY]EECFLG=2
    GPIH_EECFLG=2
  Else
    GPIH_EECFLG=1
  Endif
Else
  GPIH_EECFLG=0
Endif
GCUR=[F:BPS]CUR
[M:PIH1]CUR=[F:BPS]CUR : [M:PIH3]WCUR=[F:BPS]CUR : [M:PIH4]CUR2=[F:BPS]CUR
[M:PIH0]LAN=[F:BPR]LAN
[M:PIH0]BPR=VALEUR
#----- Chargement zones provenant du BPSUPPLIER -----#
If dim([M:PIH0]TSSCOD)>0
  For I=0 To dim([M:PIH0]TSSCOD)-1
    [M:PIH0]TSSCOD(I)=[F:BPS]TSSCOD(I)
  Next I
Endif
#----- Chargement tiers payé -----#
If [F:BPS]BPRPAY=""
  [M:PIH1]BPRPAY=VALEUR
Else
  [M:PIH1]BPRPAY=[F:BPS]BPRPAY
Endif
#----- Affichage nom du fournisseur facturant -----#
[M:PIH0]BPRNAM1=[F:BPS]BPSNAM
If !GIMPORT  Affzo [PIH0]BPRNAM1 : Endif
#-----
If [F:BPS]DUDCLC=2
  [M:PIH1]STRDUDDAT=[M:PIH0]ACCDAT
  Actzo [PIH1]STRDUDDAT
Else
  Raz [M:PIH1]STRDUDDAT
  Grizo [PIH1]STRDUDDAT
Endif
[M:PIH1]CURTYP = [F:BPS]CHGTYP

# Exigence 82615 : Législation belge --str
If dim([M:PIH1]DAS2)>0
  #[M:PIH1]DAS2 = [F:BPS]DADFLG
  If [F:BPS]DADFLG<>2 and [F:BPS]FLG281<>2
    Effzo [PIH1]DAS2
    Diszo [PIH1]DAS2
  Else
    Actzo [M:PIH1]DAS2
  Endif
  # FQ122815  Ajout d'un suffixe aux variables globales GDCLFEES, GACVDAS, GACVBE281
  Case GDCLFEES_PIH
    When "2" : # DAS2
      If GACVDAS_PIH and [F:BPS]DADFLG=2
        [M:PIH1]DAS2=[F:BPS]DADFLG
        Actzo [M:PIH1]DAS2
      Else
        Effzo [PIH1]DAS2
        Diszo [PIH1]DAS2
      Endif
    When "4" : # 281.5
      If GACVBE281_PIH and [F:BPS]FLG281=2
        [M:PIH1]DAS2=[F:BPS]FLG281
        Actzo [M:PIH1]DAS2
      Else
        Effzo [PIH1]DAS2
        Diszo [PIH1]DAS2
      Endif
  Endcase
Endif
# Exigence 82615 : Législation belge --end
#----- Chargement des escomptes et agios ------#
Call INIT_ESCOMPTE(VALEUR,[M:PIH0]FCY,"F",[M:PIH1]DEP) From CPTSUB
#----- Condition de paiement du tiers payé -----#
Call INIPTE ([M:PIH1]BPRPAY, VALEUR, "F", [M:PIH1]PTE) From TRTX3
#----- Chargement du régime taxe fournisseur ------#
Call INIT_REGIME(VALEUR,[M:PIH0]FCY,"F",[M:PIH1]VAC) From CPTSUB
#----- Chargement du type de régime taxe -----#
# 71937 : Multilégislation
#If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[M:PIH1]VAC
#  Read [ADI] CODE=1;[M:PIH1]VAC : If fstat Raz [F:ADI] : Endif
#Endif
#[M:PIH1]VACTYP=[F:ADI]N1
If !clalev([F:TVB]) Local File TABVACBPR [TVB] Endif
Local Integer GRET
Call LEC_TVB_LEG(GCURLEG,[M:PIH1]VAC,GRET) From TRTLECLEG
If GRET Raz [F:TVB] : Endif
[M:PIH1]VACTYP=[F:TVB]REGVAC
# 71937 : Multilégislation
#----- Chargement des adresses fournisseur facturant et payé -----#
Gosub CHARG_ADR_BPSINV From SUBPIHB
Gosub CHARG_ADR_BPRPAY From SUBPIHB
#----- Chargement des informations douanières -----#
If GACTDEB=2
  If GPIH_EECFLG=2
    [M:PCEZ]EECLOC=[F:BPS]EECLOC : # Lieu de transport CEE
    [M:PCEZ]EECNUM=[F:BPR]EECNUM : # Identification CEE
    Call INICRE_EEC("PIH",GBIDI2,[M:PCEZ]EECNAT,[M:PCEZ]EECSCH,GBIDI3,GBIDC2,GBIDC3) From FUNDEBA
    If !clalev([F:TMD])  Local File TABMODELIV [TMD] : Endif
    Read [TMD] TMD0=[F:BPS]MDL : If fstat Raz [F:TMD] : Endif
    [M:PCEZ]EECTRN=[F:TMD]EECTRN : # Mode de transport CEE
  Else
    Raz [M:PCEZ]
  Endif
Else
  Raz [M:PCEZ]
Endif
[M:PCEZ]EECICT =[F:BPS]EECICT     : # Incoterm
[M:PIH1]EECICT2=[F:BPS]EECICT     : # Incoterm
[M:PCEZ]WPOSCOD=""
[M:PCEZ]WBPSNUM=VALEUR
[M:PCEZ]WBPAADD=[M:AD66]BPAADD
[M:PCEZ]WCRY   =""
#----- Initialisation de la date facture fournisseur si besoin -----#
If !varinit([M:PIH1]BPRDAT) [M:PIH1]BPRDAT=[M:PIH0]ACCDAT : Endif
#----- Chargement zones devises et cours -----#
If GPIHCURDAT<>2
  [M:PIH1]RATDAT=[M:PIH0]ACCDAT
Else
  [M:PIH1]RATDAT=[M:PIH1]BPRDAT
Endif
Call INI_COURS("PIH1",GSOCIETE,[M:PIH1]CUR,[M:PIH1]RATDAT,[M:PIH1]CURTYP) From SUBBICS
If !GIMPORT | dim(GPIH_WCOD)>0 : # GPIH_WCOD existe si créat à partir fac vte (inter-soc)
  #----- Chargement libellés et formats colonnes tarif -----#
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
  Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
  Call FMTREM("PIH3",GCUR)         From TRTPRICE
  If GPLISTC<>[F:BPS]PLISTC
     GPLISTC=[F:BPS]PLISTC : Call TARIFCHGT(6) From TRTPRICE : Endif
  #------ Chargement des éléments de facturation -----#
  Call INIT_ELEMENTS (8,[M:PIH1]CURTYP,[F:BPS]CUR,GCUR) From TRTACHELT1
  Call AM_DEP([M:PIH1]DEP) From SUBPIH
  [M:PIH4]NBFAC=0 : # Pour optimiser !
Endif

#----- Chargement du code collectif fournisseur -----#
Call INIT_COMPTE(VALEUR,GSOCIETE,"F",CODCPT) From CPTSUB
Call LECTURE("CAC",[L]CODCPT,"3~"+GCOA(1)) From CONTOBJ
Call LECTURE("GAC",[F:CAC]ACC(0),GCOA(1))  From CONTOBJ
If !fstat & [F:GAC]SAC=2 [M:PIH0]BPRSAC=[F:GAC]ACCSHO : Endif

#VPO 10/02/11 71471 PE pour affectation BPRSAC
#---------------------------------------------------------#
# Point d'entrée BPRSACFAC                                #
# ------------------------------------------------------- #
# ------------------------------------------------------- #
# Variables utilisables par le point d'entrée :           #
# Les classes [M:PIH0] et [M:PIH1]                        #
# Les classes [F:GAC], [F:CAC]                            #
# ------------------------------------------------------- #
# Variable modifiable par le point d'entrée :             #
# [M:PIH0]BPRSAC contient le collectif fournisseur        #
#---------------------------------------------------------#
GPOINT="BPRSACFAC" : Gosub ENTREE From EXEFNC

#----- Affichage 1er onglet, devises du 3ème et 4ème onglet -----#
If [M:PIH1]CUR<>GLOCALDEV
  Actzo [PIH1]CURTYP
Else
  Diszo [PIH1]CURTYP
Endif
If !GIMPORT
  Affzo [PIH0]BPRSAC,BPRNAM1 : Affzo [PIH1]1-99 : Affzo [PIH3]WCUR
  Affzo [PIH4]5, CUR2
Endif
If [M:PIH1]VACTYP=4
  Raz [M:PIH1]TOTTAXAMT1, [M:PIH4]TOTTAXAMT, [M:PIH4]DIFTAXAMT
  Grizo [PIH1]TOTTAXAMT1 : Grizo [PIH4]TOTTAXAMT, DIFTAXAMT
Else
  Actzo [PIH1]TOTTAXAMT1 : Actzo [PIH4]TOTTAXAMT, DIFTAXAMT
Endif
#----- Vérification contexte inter-sociétés ? -----#
If GMODU(5)=2
  If [F:BPR]FCY<>""
    If [F:FCY]FCY<>[F:BPR]FCY
      Read [FCY] FCY0=[F:BPR]FCY : If fstat  Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY<>GSOCIETE
      [M:PIH0]BETCPY=2 : GCPY=[F:FCY]LEGCPY
    Else
      [M:PIH0]BETCPY=1
    Endif
  Else
    [M:PIH0]BETCPY=1
  Endif
  If !GIMPORT  Affzo [PIH0]BETCPY2 : Endif
Endif
#----- Initialisations pour l'Argentine -----#
If GLOCARGNUM & dim([M:PIH1]TYPVCR)>0 & [M:PIH0]SIHNUM=""
  Local Integer J, STAT
  Local Char    CAI(14)
  Local Date    DATVAL
  If !clalev([F:ADI])  Local File ATABDIV [ADI] : Endif
  Raz J
  For [ADI] CODE Where NUMTAB=362
    I=instr(1,[F:ADI]A1,num$(([M:PIH0]PIHTYP>2)+1))
    If I
      [M:PIH1]TYPVCR   =[F:ADI]CODE
      [M:PIH3]CAI      =[F:BPS]CAI(J)
      [M:PIH3]DATVLYCAI=[F:BPS]DATVLYCAI(J)
      Call TTCSSSS(2,[F:ADI]CODE,1,[M:PIH0]FCY,[0/0/0],[M:PIH1]VAC,[M:PIH1]TYPVCR,
&                  [M:PIH1]CLSVCR,[M:PIH1]SCUVCR,CAI,DATVAL,STAT) From SUBANMARG
      If !clalev([F:NCA])  Local File NUMCAI [NCA] : Endif
      Filter [NCA] Where CAI=[M:PIH3]CAI
&                      & TYP=[M:PIH1]TYPVCR
&                      & CLS=[M:PIH1]CLSVCR
&                      & VLYEND>=[M:PIH0]ACCDAT
&                      & FLGSHL<>2
      Read [NCA] NCA0 First : If fstat  Raz [F:NCA] : Endif
      Filter [NCA]
      [M:PIH1]SCUVCR=[F:NCA]SCU
      If [M:PIH1]SCUVCR<>""
        [M:PIH1]SCUVCR=string$(4-len([M:PIH1]SCUVCR),"0")+[M:PIH1]SCUVCR
      Endif
      [M:PIH1]BPRVCR=[M:PIH1]TYPVCR+[M:PIH1]CLSVCR+[M:PIH1]SCUVCR+[M:PIH1]SEQVCR
      Affzo [PIH1]TYPVCR, CLSVCR, SCUVCR, SEQVCR, BPRVCR
      If [M:PIH1]BPRVCR<>""
        Diszo [PIH1]BPRVCR
      Else
        Actzo [PIH1]BPRVCR
      Endif
      Affzo [PIH3]CAI, DATVLYCAI
      Break
    Endif
    J+=1
  Next
Endif

#Set 1099 fields based on Supplier defaults                                    #1099.sn
If GS1099 Call AM_BPR(VALEUR, "PIH1") From TEN99LIB : Endif #1099.en
If GS1099 = 1 & !GIMPORT
 Gosub CURR_CHECK From TEN99LIB
 If CURDIF=1 & [M:PIH1]STA < 3
  Actzo [M:PIH1]AMTSUBJ1099
  Raz [M:PIH1]AMTSUBJ1099
  Affzo [M:PIH1]AMTSUBJ1099
  Call MESSAGE(mess(83,122,1)) From GESECRAN
 Else
  Grizo [M:PIH1]AMTSUBJ1099 : Affzo [M:PIH1]AMTSUBJ1099
  Gosub CALC_AMTSUBJ1099 From TEN99LIB # re-calc if going back to company currency
 Endif
Endif  #1099.en

#Localisation Belge --str
If  func AFNC.ACTIV("KBE")
 Call BEL_VCS(VALEUR,[M:PIH0]PIVTYP) From SUBPIH
Endif
#Localisation Belge --end

# Issue 117524 - 2016-08-11 by MUARN : législation australienne
Call AUSABNWRN([M:PIH0]BPR,GSOCIETE) From SUBPIHD
If mkstat = 1 : End : Endif

End

Subprog C_BPRSAC(VALEUR)
#----------------------------#
# Contrôle du code collectif #
#----------------------------#
Variable Char    VALEUR()
Filter [GAC]
Read [GAC] GAC1=GCOA(1);VALEUR : If fstat Raz [F:GAC] : Endif
#----- Ce compte n'est pas un collectif (controlé par le type de donnée) -----#
If [F:GAC]SAC<>2       GMESSAGE=mess(6,106,1)  : mkstat=2 : End : Endif
#----- Tiers incompatible avec le collectif ? -----#
If [F:GAC]AUZBPR(1)<>2 GMESSAGE=mess(45,106,1) : mkstat=2 : End : Endif
#-----
Call CONTACC(GTYPGEN,GCOA(1),[F:GAC]ACC,[M:PIH0]FCY,"",[M:PIH0]ACCDAT) From CPTCNT

End

Subprog AS_PAZ(VALEUR)
#----------------------------------#
# Avant saisie du code bon à payer #
#----------------------------------#
Variable Integer VALEUR
#----- Pas de gestion du code bon à payer -----#
If GPIH_FLGPAZ<>2  mkstat=2 : End : Endif
#----- Si avoir toutes les valeurs sont permises -----#
If [M:PIH0]PIHTYP>2           End : Endif
#----- Toutes les valeurs sont permises -----#
Call PARAMUTIL("NIVBONPAYE",GBIDC3,"","") From SUBAUS
If val(GBIDC3)=4              End : Endif
#----- Suppression des options interdites -----#
Local Shortint I
For I=val(GBIDC3)+1 To 4
  GMENLOC(I)=1
Next I
End

Subprog C_PAZ(VALEUR)
#---------------------------#
# Contrôle code bon à payer #
#---------------------------#
Variable Integer VALEUR
#----- Si pas de gestion du code bon à payer ou avoir -----#
If GPIH_FLGPAZ<>2 | [M:PIH0]PIHTYP>2 End : Endif
Call PARAMUTIL("NIVBONPAYE",GBIDC3,"","") From SUBAUS
If val(GBIDC3)<1  GBIDC3="1" : Endif
#----- Vos droits opérateur n'autorise pas cette valeur ! -----#
If VALEUR>val(GBIDC3) GMESSAGE=mess(141,194,1) : mkstat=1 : End : Endif
End

Subprog AV_LIBPAZ(VALEUR)
#--------------------------------------------#
# Avant zone libellé : Chargement du message #
#--------------------------------------------#
Variable Char    VALEUR()
VALEUR=""
If [M:PIH4]QTYLINNBR<>0 & [M:PIH4]PRILINNBR<>0 VALEUR=mess(154,194,1) : End : Endif
If [M:PIH4]QTYLINNBR<>0 VALEUR=mess(152,194,1) : Endif
If [M:PIH4]PRILINNBR<>0 VALEUR=mess(153,194,1) : Endif
End

Subprog IB_BPRVCR
#---------------------------------------------------#
# Initialisation boutons sur No facture fournisseur #
#---------------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4
If [M:PIH0]SIHNUM<>""
  GBOUT1=mess(459,198,1)-[M:PIH0]SIHNUM : # Factures vente
Endif
End

Subprog C_BPRVCR(VALEUR)
#---------------------------------#
# Contrôle no facture fournisseur #
#---------------------------------#
Variable Char    VALEUR()
If [M:PIH1]STA=3 End : Endif : # Pas de contrôle si facture validée !
If [F:PTR]PTRTYP<>8 | [F:PTR]PTRNUM<>GPTRNUM
  Read [PTR] PTR0=8;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
If [F:PTR]BPRVCRCOD<>1  End : Endif
#----- Message d'erreur : Champ obligatoire -----#
If VALEUR=""
  Local File  AMSKZON [AMZ2]
  Read [AMZ2] CODE="PIH1";"BPRVCR"
  If !fstat
    If !clalev([F:ATX])  Local File ATEXTE [ATX] : Endif
    Read [ATX] NUMERO=GLANGUE;[F:AMZ2]INTIT
    If fstat  [F:AMZ2]INTIT=0 : Endif
    If [F:AMZ2]INTIT=0
      GMESSAGE="BPRVCR :"-mess(10,123,1) : GERR=1
    Else
      Call ERRTIT(mess(10,123,1),mess(32,126,1)-'"'+[F:ATX]TEXTE+'"') From GESECRAN
    Endif
  Else
    GMESSAGE="BPRVCR :"-mess(10,123,1) : GERR=1
  Endif
  # Issue X3-80533 - 2018-03-02 by MUARN : alimenté zone courate
  If !GIMPORT & zoncou<>"BPRVCR" : zonsui="BPRVCR" Endif
  mkstat=1
Endif
End

Subprog AM_BPRVCR(VALEUR)
#-----------------------------------------#
# Contrôle unicité No facture fournisseur #
#-----------------------------------------#
Variable Char    VALEUR()
# Issue 76548 - 2011-11-15 by MUARN : valeur par défaut Annuler
Local    Integer OK : OK=1
If [F:PTR]BPRVCRCOD<>1  End : Endif
If VALEUR<>""
  If clalev([PIHB])<=0 Local File PINVOICE [PIHB] : Endif
  Read [PIHB] PIH1=[M:PIH0]BPR;VALEUR
  If !fstat Call AVERTIR(mess(6,119,1)-[F:PIHB]NUM,OK) From GESECRAN
            If OK<>2 mkstat=2 : End : Endif
  Endif
Endif
End

Subprog AM_BPRDAT(VALEUR)
#-----------------------------------#
# Contrôle date facture fournisseur #
#-----------------------------------#
Variable Date    VALEUR
Local    Integer OK : OK=2
If VALEUR>[M:PIH0]ACCDAT
  Call AVERTIR(mess(188,194,1),OK) From GESECRAN
  If OK<>2 mkstat=2 : End : Endif
Endif
#----- Lecture BPSUPPLIER si nécessaire -----#
If [F:BPS]BPSNUM<>[M:PIH0]BPR
  Read [BPS] BPS0=[M:PIH0]BPR
  If fstat Raz [F:BPS] : Endif
Endif
#----- Chargement et affichage date de départ d'échéance-----#
If GREP="C" & [F:BPS]DUDCLC=2 : # Si création et si règle = date facture
  [M:PIH1]STRDUDDAT=VALEUR
  If !GIMPORT Affzo [PIH1]STRDUDDAT : Endif
Endif
#----- Chargement zones devises et cours -----#
If GPIHCURDAT=2
  [M:PIH1]RATDAT=VALEUR
  [M:PIH1]BPRDAT=VALEUR
  Call INI_COURS("PIH1",GSOCIETE,[M:PIH1]CUR,[M:PIH1]RATDAT,[M:PIH1]CURTYP) From SUBBICS
  #-----
  If !GIMPORT
    Affzo [PIH1]RAT1, LABEL, RAT2, CURMLT
  Endif
Endif
End

Subprog AM_TYPVCR(VALEUR)
#----------------------------------------#
# Après modification du type de document #
#----------------------------------------#
Variable Char    VALEUR()
If VALEUR=""
  If [M:PIH1]CLSVCR+[M:PIH1]SCUVCR+[M:PIH1]SEQVCR<>""
    [M:PIH1]BPRVCR=[M:PIH1]CLSVCR+[M:PIH1]SCUVCR+[M:PIH1]SEQVCR
    Affzo [PIH1]BPRVCR
  Else
    Actzo [PIH1]BPRVCR
    Effzo [PIH1]BPRVCR
  Endif
Else
  [M:PIH1]BPRVCR=VALEUR+[M:PIH1]CLSVCR+[M:PIH1]SCUVCR+[M:PIH1]SEQVCR
  Affzo [PIH1]BPRVCR
  Diszo [PIH1]BPRVCR
  Call AM_BPRVCR([M:PIH1]BPRVCR)
Endif
End

Subprog AM_CLSVCR(VALEUR)
#---------------------------------#
# Après modification de la classe #
#---------------------------------#
Variable Char    VALEUR()
If VALEUR=""
  If [M:PIH1]TYPVCR+[M:PIH1]SCUVCR+[M:PIH1]SEQVCR<>""
    [M:PIH1]BPRVCR=[M:PIH1]TYPVCR+[M:PIH1]SCUVCR+[M:PIH1]SEQVCR
    Affzo [PIH1]BPRVCR
  Else
    Actzo [PIH1]BPRVCR
    Effzo [PIH1]BPRVCR
  Endif
Else
  [M:PIH1]BPRVCR=[M:PIH1]TYPVCR+VALEUR+[M:PIH1]SCUVCR+[M:PIH1]SEQVCR
  Affzo [PIH1]BPRVCR
  Diszo [PIH1]BPRVCR
  Call AM_BPRVCR([M:PIH1]BPRVCR)
Endif
End

Subprog AM_SCUVCR(VALEUR)
#-------------------------------------#
# Après modification de la succursale #
#-------------------------------------#
Variable Char    VALEUR()
If VALEUR=""
  If [M:PIH1]TYPVCR+[M:PIH1]CLSVCR+[M:PIH1]SEQVCR<>""
    [M:PIH1]BPRVCR=[M:PIH1]TYPVCR+[M:PIH1]CLSVCR+[M:PIH1]SEQVCR
    Affzo [PIH1]BPRVCR
  Else
    Actzo [PIH1]BPRVCR
    Effzo [PIH1]BPRVCR
  Endif
Else
  VALEUR=string$(4-len(VALEUR),"0")+VALEUR : # Ajout zéros à gauche
  [M:PIH1]BPRVCR=[M:PIH1]TYPVCR+[M:PIH1]CLSVCR+VALEUR+[M:PIH1]SEQVCR
  Affzo [PIH1]BPRVCR
  Diszo [PIH1]BPRVCR
  Call AM_BPRVCR([M:PIH1]BPRVCR)
Endif
End

Subprog AM_SEQVCR(VALEUR)
#-----------------------------------------#
# Après mdification du numéro de séquence #
#-----------------------------------------#
Variable Char    VALEUR()
If VALEUR=""
  If [M:PIH1]TYPVCR+[M:PIH1]SCUVCR+[M:PIH1]CLSVCR<>""
    [M:PIH1]BPRVCR=[M:PIH1]TYPVCR+[M:PIH1]SCUVCR+[M:PIH1]CLSVCR
    Affzo [PIH1]BPRVCR
  Else
    Actzo [PIH1]BPRVCR
    Effzo [PIH1]BPRVCR
  Endif
Else
  VALEUR=string$(8-len(VALEUR),"0")+VALEUR : # Ajout zéros à gauche
  [M:PIH1]BPRVCR=[M:PIH1]TYPVCR+[M:PIH1]CLSVCR+[M:PIH1]SCUVCR+VALEUR
  Affzo [PIH1]BPRVCR
  Diszo [PIH1]BPRVCR
  Call AM_BPRVCR([M:PIH1]BPRVCR)
Endif
End

Subprog AM_BPRPAY(VALEUR)
#----------------------------------------#
# Après modification du fournisseur payé #
#----------------------------------------#
Variable Char    VALEUR()
Read [BPS] BPS0=VALEUR : If fstat  Raz [F:BPS] : Endif
#----- Condition de paiement du tiers payé -----#
If GPAYTERM=1 & [F:BPS]PTE<>""
  Call INIPTE (VALEUR, " ", "F", [M:PIH1]PTE) From TRTX3
  Affzo [PIH1]PTE
Endif
#----- Chargement de l'adresse fournisseur payé -----#
[M:PIH1]BPRPAY=VALEUR : Gosub CHARG_ADR_BPRPAY From SUBPIHB
End

Subprog AM_CUR(VALEUR)
#----------------------------------------------------------------#
# Après modif devise : Chargement cours devise, cours reporting, #
#  formats colonnes tarif et conversion Mts éléments facturation #
#----------------------------------------------------------------#
Variable Char    VALEUR()
Local    Integer I
Local    Char    OLDCUR(GLONCUR)  : OLDCUR=[M:PIH1]CUR
GCUR=VALEUR : [M:PIH3]WCUR=VALEUR : [M:PIH4]CUR2=VALEUR
#----- Conversion Mts éléments de facturation, HT et TVA -----#
Call CONVERT_MONTANT(VALEUR,[M:PIH1]CURTYP) From SUBPIHB
#----- Chargement formats colonnes tarif -----#
Call FMTREM("PIH3",GCUR) From TRTPRICE
#----- Chargement zones devises et cours -----#
If GPIHCURDAT<>2
  [M:PIH1]RATDAT=[M:PIH0]ACCDAT
Else
  [M:PIH1]RATDAT=[M:PIH1]BPRDAT
Endif
[M:PIH1]CUR=VALEUR
Call INI_COURS("PIH1",GSOCIETE,[M:PIH1]CUR,[M:PIH1]RATDAT,[M:PIH1]CURTYP) From SUBBICS
#----- Affichage des éléments de facturation onglet 1, montants et devise -----#
If VALEUR<>GLOCALDEV
  Actzo [PIH1]CURTYP
Else
  Diszo [PIH1]CURTYP
Endif
If !GIMPORT
  Affzo [PIH1]RAT1,LABEL,RAT2,CURMLT,20,25
  Affzo [PIH3]WCUR
Endif
If [M:PIH3]NBLIG>0  Gosub RECALCUL_LIGNES : Endif
If !GIMPORT  Affzo [PIH4]1-99 : Endif
If GS1099 = 1 & !GIMPORT #1099.sn
 Gosub CURR_CHECK From TEN99LIB
 If CURDIF=1 & [M:PIH1]STA < 3
  Actzo [M:PIH1]AMTSUBJ1099
  Raz [M:PIH1]AMTSUBJ1099
  Affzo [M:PIH1]AMTSUBJ1099
  Call MESSAGE(mess(83,122,1)) From GESECRAN
 Else
  Grizo [M:PIH1]AMTSUBJ1099  : Affzo [M:PIH1]AMTSUBJ1099
  Gosub CALC_AMTSUBJ1099 From TEN99LIB # re-calc if going back to company currency
 Endif
Endif # 1099.en
End

$RECALCUL_LIGNES
#-------------------------------------------------------------------------#
# Si des lignes de factures existent, il faut les convertir et recalculer #
#-------------------------------------------------------------------------#
If [M:PIH3]NBLIG>0
  For I=0 To [M:PIH3]NBLIG-1
    Call MAJ_CUMBASTAX_LIG(I,-2) From SUBPIHC
    Call CONVERSION(OLDCUR,I)    From SUBPIHB
    If [M:PIH3]QTYUOM(I)<>0 & [M:PIH3]NETPRI(I)<>0
      [M:PIH3]AMTNOTLIN(I)=[M:PIH3]NETPRI(I)*[M:PIH3]QTYUOM(I)
      Call ARRDEV([M:PIH3]AMTNOTLIN(I),[M:PIH1]CUR) From TRTDIV
      # Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
      [M:PIH3]AMTNOTLINCAL(I)=[M:PIH3]AMTNOTLIN(I)
    Endif
    Call MAJ_CALTAX_LIG(I)       From SUBPIHC
    Call MAJ_CUMBASTAX_LIG(I,+2) From SUBPIHC
    [M:PIH3]UPDFLG(I)=1

    # Issue 70985 - 2012-06-27 by MUARN : landed cost
    [M:PIH3]NETCUR(I) = [M:PIH1]CUR

  Next I
Endif
For I=0 To [M:PIH1]NBFAC1-1
  Call MAJ_ELEMENT (I,0,-1) From SUBPIHB
  Call MAJ_ELEMENT (I,0,+1) From SUBPIHB
Next I
If GPIHCALTAX=2 | (dim([M:PIH4]DISVATFLG)>0 & find(2,[M:PIH4]DISVATFLG(0..[M:PIH4]NBFAC-1)))
  For GPIH_INDTAX=1 To [M:PIH4]NBTAX
    Gosub CAL_TAXE_GLOB From SUBPIHB
  Next GPIH_INDTAX
Endif
If !GIMPORT
  Affzo [PIH1]TOTLINAMT1, TOTTAXAMT1, TOTATIAMT1
  Affzo [PIH3]1-99
Endif
Return

Subprog AM_CURTYP(VALEUR)
#-----------------------------------------------------------------------#
# Après modif type de cours : Chargement cours devise, cours reporting, #
#                             et conversion Mts éléments facturation    #
#-----------------------------------------------------------------------#
Variable Integer VALEUR
Local    Integer I
Local    Char    OLDCUR(GLONCUR)  : OLDCUR=[M:PIH1]CUR
#----- Conversion Mts éléments de facturation, HT et TVA -----#
Call CONVERT_MONTANT(GCUR,VALEUR) From SUBPIHB
#----- Chargement zones devises et cours -----#
[M:PIH1]CURTYP=VALEUR
Call INI_COURS("PIH1",GSOCIETE,[M:PIH1]CUR,[M:PIH1]RATDAT,[M:PIH1]CURTYP) From SUBBICS
#----- Affichage des éléments de facturation onglet 1 et montants -----#
If !GIMPORT
  Affzo [PIH1]RAT1,LABEL,RAT2,CURMLT,20,25
Endif
If [M:PIH3]NBLIG>0  Gosub RECALCUL_LIGNES : Endif
If !GIMPORT  Affzo [PIH4]1-99 : Endif
End

Subprog AS_RAT1(VALEUR)
#--------------------------------#
# Avant saisie du cours diviseur #
#--------------------------------#
Variable Decimal VALEUR
If [M:PIH1]STA=3  mkstat=2 : End : Endif
End

Subprog AM_RAT1(VALEUR)
#-------------------------------#
# Après modif du cours diviseur #
#-------------------------------#
Variable Decimal VALEUR
Local Char WZONE (10) : WZONE ="RAT1"
Local Char WCHAMP(10) : WCHAMP="RATDIV"
Gosub AM_RATX
End

Subprog AS_RAT2(VALEUR)
#--------------------------------------#
# Avant saisie du cours multiplicateur #
#--------------------------------------#
Variable Decimal VALEUR
If [M:PIH1]STA=3  mkstat=2 : End : Endif
End

Subprog AM_RAT2(VALEUR)
#-------------------------------------#
# Après modif du cours multiplicateur #
#-------------------------------------#
Variable Decimal VALEUR
Local Char WZONE (10) : WZONE ="RAT2"
Local Char WCHAMP(10) : WCHAMP="RATMLT"
Gosub AM_RATX
End

#----------------------------------------------#
# Après modif cours diviseur ou multiplicateur #
#----------------------------------------------#
$AM_RATX
#-----
Local Integer INDLED
INDLED=find(GTYPGEN,[M:SCL]LEDTYP(0..[M:SCL]NBRC-1))
If INDLED
  Assign "[M:SCL]" +WCHAMP+"(INDLED-1)" With VALEUR : # Mise à jour de l'écran SAICURLED
  Assign "[M:PIH1]"+WCHAMP+"(INDLED-1)" With VALEUR : # Mise à jour tableau des cours invisibles
Endif
#-----
If [M:PIH1]CURLED(INDLED-1)<>[M:PIH1]CUR
  Local Char    CODLED(GLONLED)
  Local Char    DEVLED(GLONCUR)
  Local Integer I
  If [F:CPY]CPY<>GSOCIETE
    Read [CPY] CPY0=GSOCIETE   : If fstat  Raz [F:CPY] : Endif
  Endif
  If [F:GCM]GCM<>[F:CPY]ACM
    Read [GCM] GCM0=[F:CPY]ACM : If fstat  Raz [F:CPY] : Endif
  Endif
  For I=1 To len(mess(0,2644,1))
    If I<>INDLED
      Call LECLED(GSOCIETE,I,CODLED,DEVLED) From CPTDIV
      If DEVLED=[M:PIH1]CURLED(INDLED-1) & [F:GCM]FLGVCRRAT(I-1)=2
        Assign "[M:SCL]" +WCHAMP+"(I-1)" With VALEUR
        Assign "[M:PIH1]"+WCHAMP+"(I-1)" With VALEUR
      Endif
    Endif
  Next
Endif
#----- Recalcul des prix unitaires de revient sur chaque ligne -----#
If [M:PIH3]NBLIG>0
  Local Shortint I
  Assign "[M:PIH1]"+WZONE With VALEUR
Endif
#-----
Return

Subprog C_PTE(VALEUR)
#---------------------------------------------------------#
# Contrôle condition de paiement : Obligatoire si facture #
#---------------------------------------------------------#
Variable Char    VALEUR()
If [M:PIH0]PIHTYP<3 & VALEUR=""  mkstat=1 : End : Endif

# SAM 101378: Localization Switzerland, 2016-01-19 Bader
If func AFNC.ACTIV("KSW")
  Gosub C_PTE_PIH From SWIBVRLIB4
  If mkstat  End : Endif
# X3-107116 2018-09-25 Bader commented until final release of QR support for Switzerland
#  Call C_PTE(VALEUR) From SWIQRCLIB2    # X3-90417 CH QR bill - Suppl inv - Implement QR bill payment method 2018-06-06 Bader
#  If mkstat  End : Endif
Endif
# SAM 101378 END
End

Subprog AM_DEP(VALEUR)
#----------------------#
# Après modif Escompte #
#----------------------#
Variable Char    VALEUR()

# Issue 83026 - 2012-06-26 by MUARN : early escompte
Local Shortint I
Local Integer SAV_DEPTYP,NEW_DEPTYP

Call ALIDISVAT(VALEUR,"PIH4") From TRTACHELT1

#--CPO 71937 TABDEPAGIO
# Issue 83026 - 2012-06-26 by MUARN : early discount
If clalev([F:TDA])=0 : Local File TABDEPAGIO [TDA] : Endif
#If [F:TDA]DEP<>VALEUR
#  Read [TDA] TDA0=VALEUR : If fstat Raz [F:TDA] : Endif
#Endif
Local Integer WRET
Call LEC_TDA_LEG(GCURLEG,VALEUR,WRET) From TRTLECLEG
If WRET : Raz [F:TDA] : Endif
#--/CPO
SAV_DEPTYP=[M:PIH1]DEPTYP
# GDEPMGTMOD 1-remise sur taxe 2-Ventilation par code TVA 3-Calcul global
# si GDEPMGTMOD = 1 il faut toujours calculer la base escomptable en HT
# le champ [M:PIH1]DEPTYP a été créé pour pour l'early discount
# on peut donc avoir un désaccord entre DEPTYP de la facture et du paramétrage de l'escompte
# MUARN 04/07/2012 selon consigne Jean-Louis TAIX
# Si l'escompte ne comporte pas de jours négatif pas de calcul de base escomptable
# DEPTYP = 0 sur la facture
Local Integer I, LCALBASDEP
For I=1 To dim([F:TDA]DEPDAY)
  If [F:TDA]DEPRAT(I-1)<0 : LCALBASDEP=1 : Break : Endif
Next I

If !LCALBASDEP #escompte sans jour négatif
  NEW_DEPTYP=0
Elsif GDEPMGTMOD = 1 # cas remise sur taxe anciennement BRIDSC
  NEW_DEPTYP=1
# Issue 102698 - 2014-11-25 by MUARN : escompte belge
Elsif GDEPMGTMOD = 5
  If [F:TDA]PFINUM <> 0
    NEW_DEPTYP=1
  Else
    NEW_DEPTYP = [F:TDA]DEPTYP
  Endif
Else
  NEW_DEPTYP = [F:TDA]DEPTYP
Endif

# en modif de facture contrôle si facture créée avant intégration patch early discount
# dans ce cas pas de calcul de la base escomptable
If GREP<>"C" & [M:PIH0]NUM<>""
  If  [F:PIH]NUM <> [M:PIH0]NUM
    Read [PIH] PIH0=[M:PIH0]NUM
  Endif
  If [F:PIH]ACCNUM < GLASINTNUM : NEW_DEPTYP =0 : Endif
Endif

If SAV_DEPTYP<> NEW_DEPTYP

  # Issue 90152 - 2013-05-29 by MUARN : Problème base taxe après modif code escompte
  For I=0 To [M:PIH4]NBFAC-1
    Call MAJ_ELEMENT(I,2,-1) From SUBPIHB
  Next I
  For I=0 To [M:PIH3]NBLIG-1
    Call MAJ_CUMBASTAX_LIG(I,-1) From SUBPIHC
  Next I

  [M:PIH1]DEP = VALEUR
  [M:PIH1]DEPTYP=NEW_DEPTYP
  For I=0 To [M:PIH3]NBLIG-1
    Call MAJ_CUMBASTAX_LIG(I,+1) From SUBPIHC
  Next I
  For I=0 To [M:PIH4]NBFAC-1
    Call MAJ_ELEMENT(I,2,+1) From SUBPIHB
  Next I

  # Issue 102698 - 2014-12-16 by MUARN : escomptes belges
  If GPIHCALTAX=2 | (dim([M:PIH4]DISVATFLG)>0 & find(2,[M:PIH4]DISVATFLG(0..[M:PIH4]NBFAC-1)))
    #Local Shortint SAV_NBFAC : SAV_NBFAC=[M:PIH4]NBFAC
    #If [M:PIH4]NBFAC<NOL+1  [M:PIH4]NBFAC=NOL+1 : Endif
    For GPIH_INDTAX=1 To [M:PIH4]NBTAX
      Gosub CAL_TAXE_GLOB From SUBPIHB
    Next GPIH_INDTAX
    #[M:PIH4]NBFAC=SAV_NBFAC
    #If !GIMPORT Affzo [PIH4]5,10,20,30 : Endif
  Endif
  For I=0 To [M:PIH4]NBTAX-1
    Call MAJ_TAXE(I) From SUBPIHB
  Next I
Endif
Call DISPLAY_BASDEP From SUBPIHC
If !GIMPORT  Affzo [PIH4]5,10,30 Endif
End

Subprog AM_VAC(VALEUR)
#----------------------------------------------------------#
# Après modif régime taxe : Réactualisation des codes taxe #
#----------------------------------------------------------#
Variable Char  VALEUR()
Local Shortint I
Local Libelle  WVACTYP_NEW, WVACTYP_OLD
Local Char     WVAT(GLONVAT)
#----- Chargement du type de régime taxe -----#
# 71937 : Multilégislation
#If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>VALEUR
#  Read [ADI] CODE=1;VALEUR : If fstat Raz [F:ADI] : Endif
#Endif
#WVACTYP_NEW=[F:ADI]N1
If !clalev([F:TVB]) Local File TABVACBPR [TVB] Endif
Local Integer GRET
Call LEC_TVB_LEG(GCURLEG,VALEUR,GRET) From TRTLECLEG
If GRET Raz [F:TVB] : Endif
WVACTYP_NEW=[F:TVB]REGVAC
# 71937 : Multilégislation

WVACTYP_OLD=[M:PIH1]VACTYP
#-----
If [M:PIH3]NBLIG>0
  For I=0 To [M:PIH3]NBLIG-1
    Call MAJ_CUMBASTAX_LIG(I,-1) From SUBPIHC
  Next I
Endif
[M:PIH1]VAC   =VALEUR
[M:PIH1]VACTYP=WVACTYP_NEW
For I=0 To dim([M:PIH3]INVDTAVAT1)-1
  Read [PFI] PFI0=GINVDTALIN(I) : If fstat Raz [F:PFI] : Endif
  If [F:PFI]VATRUL=2
    If !clalev([F:TVC])  Local File TABVAC [TVC] : Endif
    Call RECHVATFOOT(2,[M:PIH0]BPR,[F:PFI]PFINUM,"PIH4",WVAT) From TRTX3
    [M:PIH3]INVDTAVAT1(I)=WVAT
  Endif
Next I
If [M:PIH3]NBLIG>0
  # Issue 103629 - 2014-10-28 by SR
  Local Integer OK
  Local Integer WOK_LOAD
  OK=2 : Call OUINON(mess(340,194,1),OK) From GESECRAN
  WOK_LOAD = OK
  If WOK_LOAD=2
    Local Integer  SAV_LINPURTYP
    Local Char     SAV_LINACC1(GLONGAC)
    Local Char     SAV_LINACC2(GLONGAC)
  Endif
  # End issue 103629
  For I=0 To [M:PIH3]NBLIG-1
    If [F:ITM]ITMREF<>[M:PIH3]ITMREF(I)
      Read [ITM] ITM0=[M:PIH3]ITMREF(I) : If fstat Raz [F:ITM] : Endif
    Endif
    Call ALIVATCOD(2,[M:PIH0]BPR,[M:PIH3]ITMREF(I),"PIH3",I) From TRTX3
    Call MAJ_CALTAX_LIG(I)       From SUBPIHC
    # Issue 84129 - 2012-10-29 by MUARN : landed cost cout achat
    Call MAJ_CSTPUR_LIG("PIH3",I,[M:PIH1]RATDAT,[M:PIH1]CUR, [M:PIH1]CURTYP) From STCCLC
    If !GIMPORT
      Affzo [PIH3]CSTPUR(I) ,LINCSTPUR(I)
    Endif

    Call MAJ_CUMBASTAX_LIG(I,+1) From SUBPIHC
    # Issue 103629 - 2014-10-28 by SR
    If WOK_LOAD = 2
       SAV_LINPURTYP = [M:PIH3]LINPURTYP(I)
       SAV_LINACC1   = [M:PIH3]LINACC1(I)
       SAV_LINACC2   = [M:PIH3]LINACC2(I)
       Call INIT_COMPTES_LIGNE (I) From SUBPIHC
      [M:PIH3]LINPURTYP(I)=SAV_LINPURTYP         : # Modifié par le Call !
      If [M:PIH3]LINACC1(I)<>SAV_LINACC1
        Call AM_LINACC1([M:PIH3]LINACC1(I))
      Endif
      If [M:PIH3]LINACC2(I)<>SAV_LINACC2
        Call AM_LINACC2([M:PIH3]LINACC2(I))
      Endif
    Endif
    # End issue 103629
    [M:PIH3]UPDFLG(I)=1
  Next I
Endif
For I=0 To [M:PIH1]NBFAC1-1
  [M:PIH1]VACTYP=WVACTYP_OLD
  Call MAJ_ELEMENT (I,1,-1) From SUBPIHB
  [M:PIH1]VACTYP=WVACTYP_NEW
  Read [PFI] PFI0=INVDTA1(I) : If fstat Raz [F:PFI] : Endif
  If [F:PFI]VATRUL=2
    If !clalev([F:TVC])  Local File TABVAC [TVC] : Endif
    Call RECHVATFOOT(2,[M:PIH0]BPR,[F:PFI]PFINUM,"PIH4",WVAT) From TRTX3
    [M:PIH4]INVDTAVAT(I)=WVAT
  Endif
  Call MAJ_ELEMENT (I,0,+1) From SUBPIHB
Next I
If GPIHCALTAX=2 | (dim([M:PIH4]DISVATFLG)>0 & find(2,[M:PIH4]DISVATFLG(0..[M:PIH4]NBFAC-1)))
  For GPIH_INDTAX=1 To [M:PIH4]NBTAX
    Gosub CAL_TAXE_GLOB From SUBPIHB
  Next GPIH_INDTAX
Endif
Raz [M:PIH3]CLCFLG
#Issue 107878 - 2018-10-03 by RBA change due to sequence display
#If !GIMPORT Affzo [PIH3]5 : Affzo [PIH4]5, 10, 20, 30 : Endif
If !GIMPORT Affzo [PIH3]5 : Affzo [PIH4]5, 10, 25, 30 : Endif
If [M:PIH1]VACTYP=4
  Raz [M:PIH1]TOTTAXAMT1, [M:PIH4]TOTTAXAMT, [M:PIH4]DIFTAXAMT
  Grizo [PIH1]TOTTAXAMT1 : Grizo [PIH4]TOTTAXAMT, DIFTAXAMT
Else
  Actzo [PIH1]TOTTAXAMT1 : Actzo [PIH4]TOTTAXAMT, DIFTAXAMT
Endif

End

Subprog AP_INVNUM(VALEUR)
#---------------------------------------------------------#
# Après zone Fact.origine : Contrôle existence no facture #
#---------------------------------------------------------#
Variable Char    VALEUR()
If [M:PIH0]PIHTYP=3
  If VALEUR<>""
    If clalev([PIHB])<=0 Local File PINVOICE [PIHB] : Endif
    Read [PIHB] PIH0=VALEUR : If fstat Raz [F:PIHB] : Endif
    If [F:PIHB]NUM=""
      GMESSAGE=mess(23,100,1)  : GERR=1 : mkstat=1 : End
    Elsif [F:PIHB]ORIMOD<>6 | [F:PIHB]PIHTYP>2
      GMESSAGE=mess(227,194,1) : GERR=1 : mkstat=1 : End
    Elsif [F:PIHB]BPR<>[M:PIH0]BPR
      GMESSAGE=mess(150,194,1) : GERR=1 : mkstat=1 : End
    Elsif [F:PIHB]CPY<>GSOCIETE
      GMESSAGE=VALEUR-"("+[F:PIHB]CPY+")"-mess(151,194,1) : GERR=1 : mkstat=1 : End
    Elsif [F:PIHB]STA<>3
      GMESSAGE=VALEUR-mess([F:PIHB]STA,509,1)-":"-mess(335,194,1)  : GERR=1 : mkstat=1 : End
    Elsif GCTLDATORI=2 & [F:PIHB]ACCDAT>[M:PIH0]ACCDAT
      GMESSAGE=VALEUR-"("+num$([F:PIHB]ACCDAT)+")\"-mess(407,194,1) : GERR=1 : mkstat=1 : End
    Else
      #----- Contrôle si facture fait déjà l'objet d'un avoir -----#
      If !clalev([PIDB])  Local File PINVOICED [PIDB] : Endif
      Filter [PIDB] Where TYPORI=4
&                       & NUMORI=VALEUR
&                       & PIHTYP=3
&                       & NUM<>[M:PIH0]NUM
      Look [PIDB] PID1 First
      Filter [PIDB]
      If !fstat
        Local Integer OK
        OK=2 : Call AVERTIR(VALEUR-mess(45,191,1),OK) From GESECRAN
        If OK=1  mkstat=1 : End : Endif
      Endif
    Endif
    #----- Vérification si règlement en attente sur cette facture -----#
    If !clalev([F:DUD])  Local File GACCDUDATE [DUD] : Endif
    For [DUD] DUD1 Where ACCNUM=[F:PIHB]ACCNUM & TMPCUR<>0
      GMESSAGE=mess(74,119,1) : GERR=1 : mkstat=1 : Break
    Next
    If mkstat  End : Endif
    #-----
    If dim([M:PIH1]VATDAT)>0
      # Issue 93187 - 2013-11-15 by MUARN : VATDAT au lieu de ACCDAT de la facture d'origine
      #[M:PIH1]VATDAT=[F:PIHB]ACCDAT : # Date facture pour calcul TVA sur avoir
      [M:PIH1]VATDAT=[F:PIHB]VATDAT : # Date calcul taxe pour calcul TVA sur avoir
    Endif
  Elsif !clalev([F:XEPA])
    Local Integer OK
    OK=2 : Call AVERTIR(mess(9,119,1),OK) From GESECRAN
    If OK=1 mkstat=1 : End : Endif
  Endif
Endif
End

Subprog AM_EECICT2(VALEUR)
#---------------------------#
# Après modif code Incoterm #
#---------------------------#
Variable Char    VALEUR()
[M:PCEZ]EECICT=VALEUR
End

Subprog AM_ICTCTY2(VALEUR)
#----------------------------#
# Après modif ville Incoterm #
#----------------------------#
Variable Char    VALEUR()
[M:PCEZ]ICTCTY=VALEUR
End

Subprog AM_STRDATSVC(VALEUR)
#---------------------------------------------------------------------#
# Après modification Date début prestation : Répercution sur lignes ? #
#---------------------------------------------------------------------#
Variable Date    VALEUR
Local Integer I, OK
Local Libelle TYPDAT : TYPDAT=1
If [M:PIH3]NBLIG>0 & sigma(I=0,[M:PIH3]NBLIG-1,[M:PIH3]STRDAT(I)<>[0/0/0])
  Call OUINON(mess(955,196,1),OK) From GESECRAN
Endif
Gosub REPORT_PERIODE_LIG
If VALEUR=[0/0/0]
  [M:PIH1]ENDDATSVC=[0/0/0] : Affzo [PIH1]ENDDATSVC
  TYPDAT=2 : Gosub REPORT_PERIODE_LIG
Endif
End

Subprog AS_ENDDATSVC(VALEUR)
#---------------------------------------------------------------------#
# Avant saisie Date fin prestation :                                  #
# On saute la zone si la date début prestation n'a pas été renseignée #
#---------------------------------------------------------------------#
Variable Date    VALEUR
If [M:PIH1]STRDATSVC=[0/0/0]
  mkstat=2 : End
Endif
End

Subprog C_ENDDATSVC(VALEUR)
#----------------------------------------------------------------------------------#
# Contrôle Date fin prestation :                                                   #
# La date de fin prestation est rendue obligatoire si la date début est renseignée #
#----------------------------------------------------------------------------------#
Variable Date    VALEUR
If [M:PIH1]STRDATSVC<>[0/0/0] & VALEUR=[0/0/0]
  GMESSAGE=mess(123,107,1) : # Date fin de prestation à renseigner
  mkstat=1 : End
Endif
End

Subprog AM_ENDDATSVC(VALEUR)
#-------------------------------------------------------------------#
# Après modification Date fin prestation : Répercution sur lignes ? #
#-------------------------------------------------------------------#
Variable Date    VALEUR
Local Integer I, OK
Local Libelle TYPDAT : TYPDAT=2
If [M:PIH3]NBLIG>0 & sigma(I=0,[M:PIH3]NBLIG-1,[M:PIH3]ENDDAT(I)<>[0/0/0])
  Call OUINON(mess(955,196,1),OK) From GESECRAN
Endif
Gosub REPORT_PERIODE_LIG
End

$REPORT_PERIODE_LIG
#---------------------------------------#
# TYPDAT : Type de la date à reporter   #
#          1 = Date début               #
#          2 = Date fin                 #
# OK     : Report sur toutes les lignes #
#          2 = Oui                      #
#          autres valeurs = Non         #
#          uniquement si date non nulle #
#---------------------------------------#
If [M:PIH3]NBLIG>0
  For I=0 To [M:PIH3]NBLIG-1
    If OK=2
&   | (TYPDAT=1 & [M:PIH3]STRDAT(I)=[0/0/0])
&   | (TYPDAT=2 & ([M:PIH3]ENDDAT(I)=[0/0/0] | [M:PIH3]ENDDAT(I)<[M:PIH3]STRDAT(I))) : # Bug 62989
      Case TYPDAT
        When 1 : [M:PIH3]STRDAT(I)=VALEUR
                 # Bug 62989 : Si date fin ligne se retrouve < date début ligne, on force la date fin entête si ok
                 If [M:PIH3]ENDDAT(I)<[M:PIH3]STRDAT(I) & [M:PIH1]ENDDATSVC>=[M:PIH3]STRDAT(I)
                   [M:PIH3]ENDDAT(I)=[M:PIH1]ENDDATSVC
                 Endif
        When 2 : [M:PIH3]ENDDAT(I)=VALEUR
                 # Bug 62989 : Si date début ligne se retrouve < date fin ligne, on force la date fin entête si ok
                 If [M:PIH3]STRDAT(I)<[M:PIH3]ENDDAT(I) & [M:PIH1]STRDATSVC<=[M:PIH3]ENDDAT(I)
                   [M:PIH3]STRDAT(I)=[M:PIH1]STRDATSVC
                 Endif
      Endcase
      [M:PIH3]UPDFLG(I)=1
    Endif
  Next I
  Affzo [PIH3]1-99
Endif
Return

Subprog C_NBFAC1
#--------------------------------------------------------------#
# Contrôle sur numéro de ligne élément de facturation onglet 1 #
#--------------------------------------------------------------#
Local Shortint NOL : NOL=nolign-1
#----- Interdiction de l'insertion et de la suppression sur facture validée -----#
If find(status,65,73,82) & [M:PIH1]STA=3 GMESSAGE=mess(155,194,1) : mkstat=2 : End : Endif
#----- Test suppression d'un élément non ajouté -----#
If status=65 & [M:PIH1]INVDTAFLG1(NOL)=1 GMESSAGE=mess(136,194,1) : mkstat=2 : End : Endif
#----- Affichage tableau des éléments du 4ème onglet en sortie de tableau -----#
# If find(status,1,4,5,20,21,26,92,93) & !GIMPORT : Affzo [PIH4]1-99 : Endif
#----- Grisage ou dégrisage de certains champs -----#
If [M:PIH1]CUR<>GLOCALDEV
  Actzo [PIH1]CURTYP
Else
  Diszo [PIH1]CURTYP
Endif
End

Subprog AVANT_NBFAC1
#------------------------------------------#
# Avant ligne élément facturation onglet 1 #
#------------------------------------------#
Local   Shortint NOL : NOL=nolign-1
Local   Integer  AFF
#----- Si suppression ligne : Activation affichage dans MAJ_ELEMENT -----#
If status=65 | status=68 | status=83 AFF=1 : Endif
#----- Décrémentation des bases de taxe -----#
Call MAJ_ELEMENT (NOL,AFF,-1) From SUBPIHB
If AFF=1
  If GPIHCALTAX=2 | (dim([M:PIH4]DISVATFLG)>0 & find(2,[M:PIH4]DISVATFLG(0..[M:PIH4]NBFAC-1)))
    For GPIH_INDTAX=1 To [M:PIH4]NBTAX
      Gosub CAL_TAXE_GLOB From SUBPIHB
    Next GPIH_INDTAX
    #Issue 107878 - 2018-10-03 by RBA change due to sequence display
    #If !GIMPORT Affzo [PIH4]10,20,30 : Endif
    If !GIMPORT Affzo [PIH4]10,25,30 : Endif
  Endif
  Gosub MAJ_STATUT From SUBPIH
Endif
End

Subprog APRES_NBFAC1
#------------------------------------------------------#
# Après ligne tableau éléments de facturation onglet 1 #
#------------------------------------------------------#
Local Shortint NOL : NOL=nolign-1
#----- Si suppression ligne : Suppression ligne du 2ème tableau onglet 4 -----#
If status=65 | status=68 | status=83
   If [M:PIH4]NBFAC>0 & [M:PIH4]NBFAC<max(func AFNC.ACTIV("PFI"),20)
      Dela NOL,1,[M:PIH4]NBFAC-1 [M:PIH4]NBFAC
      [M:PIH4]NBFAC-=1
   Elsif [M:PIH4]NBFAC=0
      [M:PIH4]NBFAC=20
      Dela NOL,1 [M:PIH4]NBFAC
      [M:PIH4]NBFAC=0
   Else
      Dela NOL,1 [M:PIH4]NBFAC
      [M:PIH4]NBFAC-=1
   Endif
   #Issue 107878 - 2018-10-03 by RBA change due to sequence display
#   If !GIMPORT Affzo [PIH1]25 : Affzo [PIH4]5,25-30 : Endif
   If !GIMPORT Affzo [PIH1]25 : Affzo [PIH4]5,20,30 : Endif
   Gosub MAJ_STATUT From SUBPIH : End
Endif
#-------------------------------------------------#
# Si touche "Echap" ou autre statut "Abandon"     #
# incrémentation bases taxe sans affichage et FIN #
#-------------------------------------------------#
If status=6 | status=7 | status=27 | status=28
   Call MAJ_ELEMENT (NOL,0,+1) From SUBPIHB : End : Endif
#----- Si no élément non renseigné, c'est fini ! -----#
If [M:PIH1]INVDTA1(NOL)=0  End : Endif
#----- Calcul, affichage TTC facturé sur onglet 1 -----#
If !GIMPORT
  Affzo [PIH1]TOTATIAMT1
  Affzo [PIH4]30
Endif
#-------------------------------------------------------#
# Si ajout d'un nouvel élément : Chargement des valeurs #
#        dans le 2ème tableau des éléments sur onglet 4 #
#-------------------------------------------------------#
If [M:PIH4]INVDTA(NOL)=0
   [M:PIH4]INVDTA(NOL)   =[M:PIH1]INVDTA1(NOL)
   [M:PIH4]INVDTALIB(NOL)=[M:PIH1]INVDTALIB1(NOL)
   [M:PIH4]INVDTAAMT(NOL)=[M:PIH1]INVDTAAMT1(NOL)
   Raz [M:PIH4]INVORDAMT(NOL),[M:PIH4]INVLINAMT(NOL),[M:PIH4]INVDIFAMT(NOL),
&      [M:PIH4]INVDTAVAT(NOL),[M:PIH4]DTAAMTTAX(NOL),[M:PIH4]DTADEDTAX(NOL)
   If dim([M:PIH4]DTADISBAS)>0  Raz [M:PIH4]DTADISBAS(NOL) : Endif
   If [F:PFI]VATRUL=2
      Local Char WVAT(GLONVAT)
      If !clalev([F:TVC])  Local File TABVAC [TVC] : Endif
      Call RECHVATFOOT(2,[M:PIH0]BPR,[F:PFI]PFINUM,"PIH4",WVAT) From TRTX3
      [M:PIH4]INVDTAVAT(NOL)=WVAT
   Endif
   [M:PIH4]INVLINFLG(NOL)=[F:PFI]DSPLIN
   [M:PIH4]INVORDFLG(NOL)=[F:PFI]DACORD
   [M:PIH4]DEBCDT(NOL)   =[M:PIH1]DEBCDT1(NOL)
   [M:PIH4]CLCORD(NOL)   =[F:PFI]CLCORD
   [M:PIH4]CLCBAS(NOL)   =[F:PFI]CLCBAS
   [M:PIH4]DSP(NOL)      =[F:PFI]DSP
   # Issue 83026 - 2012-06-26 by MUARN : early escompte
   [M:PIH4]DEPFLG(NOL)   =[F:PFI]DEPFLG
   [M:PIH4]INCDCR(NOL)   =[F:PFI]INCDCR
   If dim([M:PIH4]DISVATFLG)>0  [M:PIH4]DISVATFLG(NOL)=[F:PFI]DISVATFLG : Endif
   If [M:PIH4]NBFAC>0  [M:PIH4]NBFAC+=1 : Endif
   If !GIMPORT
      Affzo [PIH4]INVDTA(NOL),INVDTALIB(NOL),INVDTAAMT(NOL),INVORDAMT(NOL),
&           INVDIFAMT(NOL),DEBCDT(NOL),ACC1(NOL),ACC2(NOL),AMTATI,DIFAMTATI
      # Issue 85145 - 2012-10-17 by MUARN : ajout devise dans élément facturation
      Affzo [M:PIH4]AMTCODLIB(NOL)
   Endif
Endif
#----- Incrémentation des bases de taxe avec affichage -----#
Call MAJ_ELEMENT (NOL,1,+1) From SUBPIHB
If GPIHCALTAX=2 | (dim([M:PIH4]DISVATFLG)>0 & find(2,[M:PIH4]DISVATFLG(0..[M:PIH4]NBFAC-1)))
  For GPIH_INDTAX=1 To [M:PIH4]NBTAX
    Gosub CAL_TAXE_GLOB From SUBPIHB
  Next GPIH_INDTAX
  #Issue 107878 - 2018-10-03 by RBA change due to sequence display
  #If !GIMPORT Affzo [PIH4]10,20,30 : Endif
  If !GIMPORT Affzo [PIH4]10,25,30 : Endif
Endif
Gosub MAJ_STATUT From SUBPIH
End

Subprog AS_INVDTA1(VALEUR)
#---------------------------------------------#
# Avant saisie du No d'élément de facturation #
#---------------------------------------------#
Variable Decimal VALEUR
If [M:PIH1]INVDTAFLG1(nolign-1)<>0 mkstat=2 : Endif
End

Subprog C_INVDTA1(VALEUR)
#----------------------------------------------------#
# Contrôle No d'élément déja présent dans le tableau #
#----------------------------------------------------#
Variable Decimal VALEUR
#-----
If find(VALEUR,[M:PIH1]INVDTA1) & find(VALEUR,[M:PIH1]INVDTA1)<>nolign & !GIMPORT
  GMESSAGE=mess(102,194,1) : mkstat=1
Endif
End

Subprog AM_INVDTA1(VALEUR)
#------------------------------------------------#
# Après modif No d'élément : chargement libellé, #
#       valeur par défaut et indicateur d'ajout. #
#------------------------------------------------#
Variable Decimal  VALEUR
Local    Shortint NOL : NOL=nolign-1
Local    Integer  STAT
#-----
If [F:PFI]DISVATFLG=2
  GMESSAGE=mess(412,194,1) : GERR=1 : mkstat=1 : End
Endif
#-----
Call LECTEXTRA(GBIDC3,"PFOOTINV","SHOAXX",num$([F:PFI]PFINUM),"") From ATEXTRA
[M:PIH1]INVDTALIB1(NOL)=GBIDC3
If [F:PFI]AMTCOD=2
# Issue 85145 - 2012-10-16 by MUARN : en tunnel GCUR n a pas la même signification
#   Call CONVERT(GLOCALDEV,GCUR,GLOCALDEV,[M:PIH1]CURTYP,datesyst,
#&               [F:PFI]DEFVAL,GBIDD3,STAT) From TRTDEV
   Call CONVERT(GLOCALDEV,[M:PIH1]CUR,GLOCALDEV,[M:PIH1]CURTYP,datesyst,
&               [F:PFI]DEFVAL,GBIDD3,STAT) From TRTDEV
   If [F:PFI]INCDCR=2 & GBIDD3>0 GBIDD3=-GBIDD3 : Endif
   [M:PIH1]INVDTAAMT1(NOL)=GBIDD3
Endif
If dim([M:PIH4]DISVATFLG)>0
  [M:PIH4]DISVATFLG(NOL)=[F:PFI]DISVATFLG
  If [F:PFI]DISVATFLG=2
    [M:PIH4]INVORDAMT(NOL)=[F:PFI]DEFVAL
  Endif
  # Issue 85145 - 2012-10-16 by MUARN : ajout devise sur élément facturation
  [M:PIH4]AMTCODLIB(NOL)=[M:PIH1]CUR
  If !GIMPORT Affzo [PIH4]INVORDAMT(NOL), AMTCODLIB(NOL), DISVATFLG(NOL) : Endif
Endif
If [M:PIH0]PIHTYP<3 [M:PIH1]DEBCDT1(NOL)=[F:PFI]INCDCR
               Else [M:PIH1]DEBCDT1(NOL)=3-[F:PFI]INCDCR : Endif
[M:PIH1]INVDTAFLG1(NOL)=2
End

Subprog AS_INVDTAAMT1(VALEUR)
Variable Decimal  VALEUR
If dim([M:PIH4]DISVATFLG)>0 & [M:PIH4]DISVATFLG(nolign-1)=2  mkstat=2 : Endif
End

Subprog AM_INVDTAAMT1(VALEUR)
#-------------------------------------------------#
# Après modif d'un montant élément de facturation #
# Mise à jour ligne de l'élément sur onglet 4     #
#-------------------------------------------------#
Variable Decimal  VALEUR
Local    Shortint NOL : NOL=nolign-1
If ([M:PIH0]PIHTYP<3 & [M:PIH1]DEBCDT1(NOL)=2) |
&  ([M:PIH0]PIHTYP>2 & [M:PIH1]DEBCDT1(NOL)=1)
   If VALEUR>0 VALEUR=-VALEUR : Endif
Elsif VALEUR<0 VALEUR=-VALEUR
Endif
Raz [M:PIH4]DTAAMTTAX(NOL), [M:PIH4]DTADEDTAX(NOL)
#----- Mise à jour en après ligne si élément ajouté -----#
If [M:PIH4]INVDTA(NOL)=0 End : Endif
[M:PIH4]INVDTAAMT(NOL)=VALEUR
If !GIMPORT Affzo [PIH4]INVDTAAMT(NOL),INVDIFAMT(NOL),AMTATI,DIFAMTATI : Endif
Gosub MAJ_STATUT From SUBPIH
End

Subprog C_NBAXE
#----------------#
# Contrôle NBAXE #
#----------------#
If !find(status,1,4,5,20,21,26,92,93) | GIMPORT End : Endif
#----- Contrôle sections obligatoires -----#
If [M:PIH1]NBAXE>0 & [M:PIH1]STA<>3 & GHEADIE=1 : # Sections d'entête saisissables
  Local Integer I
  For I=1 To [M:PIH1]NBAXE
    Call CTRL_CCEH([M:PIH1]CCE(I-1),I,GFINRSP,[M:PIH0]ACCDAT) From TRTX3CPT
    If mkstat  Break : Endif
  Next I
Endif
End

Subprog AM_TOTLINAMT1(VALEUR)
#--------------------------------------#
# Après modif total HT lignes onglet 1 #
#--------------------------------------#
Variable Decimal VALEUR
[M:PIH1]TOTLINAMT1=VALEUR
[M:PIH4]TOTLINAMT =VALEUR
If !GIMPORT & !GWEBSERV
  Affzo [PIH1]TOTATIAMT1
  #Issue 107878 - 2018-10-03 by RBA change due to sequence display
  #Affzo [PIH4]25,30
  Affzo [PIH4]20,30
Endif
Gosub MAJ_STATUT From SUBPIH
End

Subprog AM_TOTTAXAMT1(VALEUR)
#-----------------------------#
# Après modif total des taxes #
#-----------------------------#
Variable Decimal VALEUR
[M:PIH1]TOTTAXAMT1=VALEUR
[M:PIH4]TOTTAXAMT =VALEUR
If !GIMPORT & !GWEBSERV
  Affzo [PIH1]TOTATIAMT1
  #Issue 107878 - 2018-10-03 by RBA change due to sequence display
  #Affzo [PIH4]20,30
  Affzo [PIH4]25,30
Endif
Gosub MAJ_STATUT From SUBPIH
End

Subprog AV_TOTATIAMT1(VALEUR)
#------------------------------#
# Avant zone Total TTC facturé #
#------------------------------#
Variable Decimal VALEUR
VALEUR=sum(INVDTAAMT1)+TOTLINAMT1+TOTTAXAMT1
End

Subprog PASLINPIH(NOMZON)
#------------------------------------------------------------------------#
# Avant saisie des champs de la ligne facture (sauf comptes et sections) #
#------------------------------------------------------------------------#
Value Char NOMZON
If GMODIF<>2  mkstat=2 : Endif
Case NOMZON
  When "TYPORI","NUMORI","LINORI","ITMREF"
    If [M:PIH3]LINFLG(nolign-1)<>0  mkstat=2 : Endif
  When "NETPRI","AMTNOTLIN","VAT1","VAT2","VAT3","TAXRCP","TAXISS","TAXOTH1","TAXOTH2"
    If [M:PIH3]LINTYP(nolign-1)=2   mkstat=2 : Endif
Endcase
End

Subprog C_NBLIG
#--------------------------------------#
# Contrôle sur numéro de ligne facture #
#--------------------------------------#
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
If [M:PIH3]NBCRELIG>0
  [M:PIH3]NBLIG+=[M:PIH3]NBCRELIG
  If !GIMPORT Affzo [PIH3]1-99 : Endif
  Raz [M:PIH3]NBCRELIG
Endif
#-----
GMODIF=2
Local Integer NOL
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#If    status=65             : # Annulation simple
If    WSTATUS=65             : # Annulation simple
      NOL=nolign-1 : Gosub TEST_ANU
#Elsif status=68 | status=83 : # Annulation multiple
Elsif WSTATUS=68 | WSTATUS=83 : # Annulation multiple
      For NOL=nolign-1 To nolign1-1
          Gosub TEST_ANU
          If mkstat : Break : Endif
      Next NOL
Endif
#If status=75             NOL=nolign-1      : Gosub TEST_MOD    : Endif
#If status=73 | status=82 NOL=nolign-1      : Gosub TEST_INSERT : Endif
#If find(status,1,4,5,20,21,26,92,93,131,135) Gosub TEST_VALID  : Endif
If WSTATUS=75             NOL=nolign-1      : Gosub TEST_MOD    : Endif
If WSTATUS=73 | WSTATUS=82 NOL=nolign-1      : Gosub TEST_INSERT : Endif
If find(WSTATUS,1,4,5,20,21,26,92,93,131,135) Gosub TEST_VALID  : Endif
# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End

$TEST_MOD
#------------------------------------#
# Test pour modification d'une ligne #
#------------------------------------#
If [M:PIH1]STA=3 & !GIMPORT  GMODIF=1 : Endif
Return

$TEST_ANU
#----------------------------------#
# Test pour annulation de la ligne #
#----------------------------------#
If dim([M:PIH3]ITMREF)<nolign  mkstat=2 : Return : Endif : # Maximum lignes atteint
#----- Facture validée, modification ou suppression interdite !
If [M:PIH1]STA=3
  GMESSAGE=mess(155,194,1) : mkstat=2 : Return
Endif
#----- Si facture et ligne créée antérieurement alors test -----#
If [M:PIH0]PIHTYP=1 & [M:PIH3]CREFLG(NOL)<>0
  Look [PID] PID1(3)=4;[M:PIH0]NUM;[M:PIH3]PIDLIN(NOL)
  [G:PID]currind=1 : [G:PID]currlen=0 : # Réinitialisation clé par défaut
  #-- Des avoirs ou factures complémentaires existent, suppression interdite ! --#
  If !fstat  GMESSAGE=mess(156,194,1) : mkstat=2 : Return : Endif
Endif
#----- Si ligne issue d'une facture vente, pas de suppression -----#
# Issue 84701 - 2012-09-25 by MUARN : si fcc d'une facture issue des ventes on laisse supprimer
#If [M:PIH3]SIDLIN(NOL)<>0
If [M:PIH3]SIDLIN(NOL)<>0 & [M:PIH0]PIHTYP<>2
  GMESSAGE=mess(290,194,1) : mkstat=2 : Return
Endif
#----- Suppression ligne d'un composant (service) interdite -----#
If [M:PIH3]LINTYP(NOL)=3
  GMESSAGE=mess(358,194,1) : mkstat=2 : Return
Endif
Return

$TEST_INSERT
#---------------------------------#
# Test pour insertion d'une ligne #
#---------------------------------#
If [M:PIH1]STA=3 & !GIMPORT  mkstat=2 : Return : Endif
#-----
If dim([M:PIH3]ITMREF)<[M:PIH3]NBLIG+2
  GMESSAGE=mess(122,199,1) : mkstat=2 : Return
Endif
#-----
If [M:PIH3]LINTYP(NOL)>2
  GMESSAGE=mess(97,192,1)  : mkstat=2 : Return
Endif
Return

$TEST_VALID
#------------------------------------------------------------------------#
# Test et traitement à la validation des lignes :                        #
# Mise à jour bases taxables et calcul taxes des éléments de facturation #
#------------------------------------------------------------------------#
#    à cause de l'appel depuis le W0PIH3 pour chaque lignes à remplir    #
#        les lignes sont en cours de chargement et le status=1           #
#    sera appelé à la fin lorsque toutes les lignes seront chargées      #
#        l'exécution de TEST_VALID se fera à ce moment là !              #
#    GPIH_WCOD existe si création à partir fac vte (inter-sociétés)      #
#------------------------------------------------------------------------#
If [M:PIH3]NBLIG>0 & dim(GPIH_WCOD)>0
  If [M:PIH3]VAT1([M:PIH3]NBLIG-1)=""  Return : Endif
Endif
#-----
#Issue 107878 - 2018-10-03 by RBA change due to sequence display
#If !GIMPORT Affzo [PIH4]25 : Endif
If !GIMPORT Affzo [PIH4]20 : Endif
If [M:PIH3]NBLIG>0 & [M:PIH1]NBFAC1>0 & [M:PIH4]NBFAC=0
   [M:PIH4]NBFAC=[M:PIH1]NBFAC1
   For I=0 To [M:PIH1]NBFAC1-1
       Call MAJ_ELEMENT (I,0,+1) From SUBPIHB
   Next I
   If GPIHCALTAX=2 | (dim([M:PIH4]DISVATFLG)>0 & find(2,[M:PIH4]DISVATFLG(0..[M:PIH4]NBFAC-1)))
     For GPIH_INDTAX=1 To [M:PIH4]NBTAX
       Gosub CAL_TAXE_GLOB From SUBPIHB
     Next GPIH_INDTAX
   Endif
   # Issue 71069 - 2016-09-07 by MUARN : PJT
   Gosub MAJ_CCE_PFI From SUBPIHC
   #Issue 107878 - 2018-10-03 by RBA change due to sequence display
   #If !GIMPORT  Affzo [PIH1]20 : Affzo [PIH4]5, 10, 20, 30 : Endif
   If !GIMPORT  Affzo [PIH1]20 : Affzo [PIH4]5, 10, 25, 30 : Endif
Elsif [M:PIH3]CLCFLG=2
   For I=0 To [M:PIH1]NBFAC1-1
       Call MAJ_ELEMENT (I,0,-1) From SUBPIHB
       Call MAJ_ELEMENT (I,0,+1) From SUBPIHB
   Next I
   If GPIHCALTAX=2 | (dim([M:PIH4]DISVATFLG)>0 & find(2,[M:PIH4]DISVATFLG(0..[M:PIH4]NBFAC-1)))
     For GPIH_INDTAX=1 To [M:PIH4]NBTAX
       Gosub CAL_TAXE_GLOB From SUBPIHB
     Next GPIH_INDTAX
   Endif
   #Issue 107878 - 2018-10-03 by RBA change due to sequence display
   #If !GIMPORT Affzo [PIH1]20 : Affzo [PIH4]5, 10, 20, 30 : Endif
   If !GIMPORT Affzo [PIH1]20 : Affzo [PIH4]5, 10, 25, 30 : Endif
Elsif !GIMPORT
   Affzo [PIH1]20 : Affzo [PIH4]10
Endif
If [F:BPS]BPSNUM<>[M:PIH0]BPR
   Read [BPS] BPS0=[M:PIH0]BPR : If fstat Raz [F:BPS] : Endif
Endif
# Issue 99963 - 2014-05-14 by MUARN : ne pas faire en interco
#If [M:PIH3]NBLIG>0 & [F:BPS]DUDCLC=1 & ([M:PIH3]CLCFLG=2 | [M:PIH1]STRDUDDAT=[0/0/0])
If [M:PIH3]NBLIG>0 & [F:BPS]DUDCLC=1 & ([M:PIH3]CLCFLG=2 | [M:PIH1]STRDUDDAT=[0/0/0]) & [M:PIH0]BETCPY = 1
  If [M:PIH1]STRDUDDAT<>min([M:PIH3]RCPDAT(0..[M:PIH3]NBLIG-1)) | [M:PIH1]STRDUDDAT=[0/0/0]
    Raz [M:PIH1]STRDUDDAT
    For I=0 To [M:PIH3]NBLIG-1
      If [M:PIH3]TYPORI(I)=2 &
&       ([M:PIH1]STRDUDDAT=[0/0/0] | [M:PIH1]STRDUDDAT>[M:PIH3]RCPDAT(I))
        [M:PIH1]STRDUDDAT=[M:PIH3]RCPDAT(I)
      Endif
    Next I
    If [M:PIH1]STRDUDDAT=[0/0/0] [M:PIH1]STRDUDDAT=[M:PIH0]ACCDAT : Endif
    Actzo [PIH1]STRDUDDAT
    If !GIMPORT Affzo [PIH1]STRDUDDAT : Endif
  Endif
Elsif [M:PIH3]NBLIG=0 & [F:BPS]DUDCLC=1
  Raz [M:PIH1]STRDUDDAT
  If !GIMPORT Affzo [PIH1]STRDUDDAT : Diszo [PIH1]STRDUDDAT : Endif
Endif
# Issue 100383 - 2014-05-26 by MUARN : inter-soc, facture directe et
# fournisseur paramétré à origine echéance = date réception, et pas de date départ échéance
If [M:PIH1]STRDUDDAT=[0/0/0] & [F:BPS]DUDCLC=1 & [M:PIH0]BETCPY = 2
  [M:PIH1]STRDUDDAT=[M:PIH0]ACCDAT
  If !GIMPORT Affzo [PIH1]STRDUDDAT : Endif
Endif
Raz [M:PIH3]CLCFLG
If !GIMPORT Affzo [PIH0]LIBPAZ : Endif
Gosub MAJ_STATUT From SUBPIH
Gosub GRISAGE    From SUBPIHA
Return

Subprog IB_NBLIG
#------------------------------------------------------------------#
# Init bouton : Activation Tunnels "Commande" "Réception" "Retour" #
#                          Boutons "Préchargement des lignes"      #
#                                  "Montants remises/frais"        #
#                                  "Détail qtés"                   #
#                                  "Texte"                         #
#                                  "Préchargement des lignes"      #
#                                  "Période de prestation"         #
#------------------------------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8, GBOUT10
If dim([M:PIH3]ITMREF)<nolign  End : Endif : # Maximum lignes atteint
GBOUT10 = mess(164,198,1)      : # Situation ligne

If [M:PIH1]STA<3
  If [M:PIH3]NBLIG=0 & [M:PIH3]PCLFLG=2
    [M:PIH3]PCLFLG=1
    #----- Appel du préchargement automatiquement (supprimé !) -----#
    # Call B6_NBLIG            : # Appel préchargement si 1ère fois
  Endif
  #----- Bouton Préchargement si facture complémentaire -----#
  If [M:PIH0]PIHTYP=2
    GBOUT6=mess(186,198,1)
  Endif
  #----- Si modif non autorisée, désactivation du préchargement -----#
  If GREP<>"C"
    GBIDC2="M" : Gosub AUTORIS_OPT From CONTX3
    If !GBIDI2
      Raz GBOUT2, GBOUT6
    Endif
  Endif
Endif
If [M:PIH3]TYPORI(nolign-1)<>0
  # Issue 84129 - 2012-10-10 by MUARN : landed cost
    # Issue 84130 - 2013-03-25 by MUARN : Seulement si pas en cours de création/Modif, etc ...
  If GREP = ""  : GBOUT3=mess(497,198,1) Endif
  GBOUT4=mess(215,198,1)   : # Détail qtés
  If GLOCITAPRE
    GBOUT7=mess(16,119,1)  : # Période de prestation
  Endif
  # If [M:PIH1]STA<3 GBOUT5=mess(38,198,1) : Endif
  GBOUT5=mess(38,198,1)
  # Issue 110325 - 2016-01-15 by SR : FCC sur expé
  Case [M:PIH3]TYPORI(nolign-1)
    When 1 : GBOUT1=mess(191,198,1)-[M:PIH3]NUMORI(nolign-1)
    When 2 : GBOUT1=mess(117,198,1)-[M:PIH3]NUMORI(nolign-1)
    When 3 : GBOUT1=mess(192,198,1)-[M:PIH3]NUMORI(nolign-1)
    When 6 : GBOUT1=mess(500,198,1)-[M:PIH3]NUMORI(nolign-1)
  Endcase
Endif
#----- SYMEU 10/12/2008 : branchement traçabilité pièces
If find(GREP,"C","D") | find("CONSPIA",GNAVIG(1..GPILNAV))  Raz GBOUT9 : Endif
#----- Tunnel sur engagement -----#
If GMODU(2)=2 & GPURCMM=2
&             & [M:PIH3]LINTYP(nolign-1)<>2
&             & [M:PIH3]TYPORI(nolign-1)<5
&             & [M:PIH3]CMMNUM(nolign-1)<>""
  GBOUT11=mess(160,198,1)-[M:PIH3]CMMNUM(nolign-1)
Else
  Raz GBOUT11
Endif
#-----
Call IB_NOTECHECK([M:PIH3]ITMREF(nolign-1),"ITMREF",14)  From TRTNTSCTL # product notes

End


Subprog AVANT_NBLIG
#--------------------------------------------#
# Avant ligne : Soustraction cumuls et bases #
#--------------------------------------------#
Local Shortint NOL : NOL=nolign-1
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
If [M:PIH3]TYPORI(NOL)=0 [M:PIH3]LINFLG(NOL)=0 : Endif
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#If status<>73 Call MAJ_CUMBASTAX_LIG(NOL,-1) From SUBPIHC : Endif
If WSTATUS<>73 Call MAJ_CUMBASTAX_LIG(NOL,-1) From SUBPIHC : Endif
#----- Si suppression d'une ligne nouvelle, déblocage logique et suppress.texte -----#
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#If (status=65 | status=68 | status=83)
If (WSTATUS=65 | WSTATUS=68 | WSTATUS=83)
  If [M:PIH3]CREFLG(NOL)=0
    If [M:PIH3]TYPORI(NOL)<5 Call DEVERROU_LIG(NOL) From SUBPIHC : Endif
    #----- Suppression du texte ligne si nécessaire -----#
    If left$([M:PIH3]LINTEX(NOL),3)="PID"
      Call SUP_CLOB([M:PIH3]LINTEX(NOL),GBIDI1) From TRTX3TEX
    Endif
    #-----
    If !GIMPORT
      Local Shortint WPICK, I
      WPICK=1 : I=NOL : Gosub MARQUAGE_LIGNE From SUBPIHD
    Endif
  Endif
  [M:PIH3]PCLFLG=1
  #----- Raz date pour taux taxe si tableau des lignes vide -----#
  If [M:PIH3]NBLIG=1 & dim([M:PIH1]VATDAT)>0
    If [M:PIH3]TYPORI(NOL)=4 & [M:PIH0]PIHTYP=3 & [M:PIH1]INVNUM=""
      Raz [M:PIH1]VATDAT
  # Issue 93187 - 2013-11-15 by MUARN : ajout ligne divers et sur commande(1 et 5)
    Elsif find([M:PIH3]TYPORI(NOL),1,2,3,5)
      Raz [M:PIH1]VATDAT
    Endif
  Endif
Endif
# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End

Subprog APRES_NBLIG
#----------------------------------------#
# Après ligne : Addition cumuls et bases #
#----------------------------------------#
Local Shortint NOL : NOL=nolign-1
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
#----- Déblocage logique si abandon ligne par escape ou par clic liste gauche -----#
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#If (status=6 | status=7 | status=27 | status=28 | [M:PIH3]TYPORI(NOL)=0) &
If (WSTATUS=6 | WSTATUS=7 | WSTATUS=27 | WSTATUS=28 | [M:PIH3]TYPORI(NOL)=0) &
&  [M:PIH3]CREFLG(NOL)=0 & GPIH_SYMBOL2<>""
  Unlock=GPIH_SYMBOL2
Endif
Raz GPIH_SYMBOL2
#-----
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#If status=6 | status=7 | status=27 | status=28
If WSTATUS=6 | WSTATUS=7 | WSTATUS=27 | WSTATUS=28
  Call MAJ_CUMBASTAX_LIG(NOL,+1) From SUBPIHC : [M:PIH3]PCLFLG=1
  # Issue X3-102918 - 2018-08-07 by SR : Restore status
  status = WSTATUS
  End
Endif
#-----------------------------------------------#
# Si suppression ligne, affichage totaux et fin #
#-----------------------------------------------#
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#If status=65 | status=68 | status=83
If WSTATUS=65 | WSTATUS=68 | WSTATUS=83
  #----- Suppression des lignes liées au composé (produit fini) -----#
  If NOL<[M:PIH3]NBLIG-1 & [M:PIH3]LINTYP(NOL+1)>2
    Local Shortint I : I=NOL+1
    While [M:PIH3]LINTYP(I)>2
      nolign=I+1 : Call AVANT_NBLIG From SUBPIH
      Dela I,1,[M:PIH3]NBLIG-1 [M:PIH3]NBLIG : [M:PIH3]NBLIG-=1
    Wend
    Affzo [PIH3]5
    nolign=NOL+1
  Endif
If GS1099 = 1 & !GIMPORT # 1099.sn
 Gosub CURR_CHECK From TEN99LIB
 If CURDIF=0
  If GS1099 Gosub CALC_AMTSUBJ1099 From TEN99LIB : Endif #1099.n Sum applicable lines into 1099 Amt
 Endif
Endif #1099.en
  #-----
  If !GIMPORT
    Affzo [PIH3]CUMLINAMT1
    nolign=NOL+1 : # Le nolign peut être perdu à cause de l'Affzo !
  Endif
  [M:PIH3]PCLFLG=1 : [M:PIH3]CLCFLG=2
  # Issue X3-102918 - 2018-08-07 by SR : Restore status
  status = WSTATUS
  End
Endif
# Issue 84013 - 2012-08-24 by MUARN : point entrée pour moonnaie de paris date du jour
#---------------------------------------------------------#
# Point d'entrée GETVATDAT                                #
# ------------------------------------------------------- #
# ------------------------------------------------------- #
# Variables utilisables par le point d'entrée :           #
# Les classes [M:PIH0] et [M:PIH1]                        #
# ------------------------------------------------------- #
# Variable modifiable par le point d'entrée :             #
# [M:PIH1]VATDAT contient la date pour le calcul des taxes#
#---------------------------------------------------------#
GPOINT="GETVATDAT" : Gosub ENTREE From EXEFNC

#----- Récupération date pour taux de taxe -----#
If dim([M:PIH1]VATDAT)>0 & [M:PIH1]VATDAT=[0/0/0] & [M:PIH3]CREFLG(NOL)=0
  #----- Récupération date facture d'origine pour calcul TVA sur avoir -----#
  If [M:PIH3]TYPORI(NOL)=4 & [M:PIH0]PIHTYP=3
    If clalev([PIHB])<=0 Local File PINVOICE [PIHB] : Endif
    Read [PIHB] PIH0=[M:PIH3]NUMORI(NOL) : If fstat Raz [F:PIHB] : Endif
    # Issue 93187 - 2013-11-15 by MUARN : VATDAT au lieu de ACCDAT de la facture d'origine
    #If [F:PIHB]ACCDAT<>[0/0/0]  [M:PIH1]VATDAT=[F:PIHB]ACCDAT : Endif
    If [F:PIHB]VATDAT<>[0/0/0]  [M:PIH1]VATDAT=[F:PIHB]VATDAT : Endif
  Endif
  #----- Récupération date de la réception pour calcul taxes -----#
  If [M:PIH3]TYPORI(NOL)=2
    Read [PTH] PTH0=[M:PIH3]NUMORI(NOL)  : If fstat  Raz [F:PTH] : Endif
    If [F:PTH]RCPDAT<>[0/0/0]  [M:PIH1]VATDAT=[F:PTH]RCPDAT : Endif
  Endif
  #----- Récupération date du retour pour calcul taxes -----#
  If [M:PIH3]TYPORI(NOL)=3
    Read [PNH] PNH0=[M:PIH3]NUMORI(NOL)  : If fstat  Raz [F:PNH] : Endif
    If [F:PNH]RTNDAT<>[0/0/0]  [M:PIH1]VATDAT=[F:PNH]RTNDAT : Endif
  Endif
  #-----
  # Issue 93187 - 2013-11-15 by MUARN : VATDAT sur ligne de commande ou divers
  If [M:PIH3]TYPORI(NOL)=1 | [M:PIH3]TYPORI(NOL)=5
    [M:PIH1]VATDAT=[M:PIH1]BPRDAT
  Endif

Endif
#--------------#
# Calcul ligne #
#--------------#
If [F:ITM]ITMREF<>[M:PIH3]ITMREF(NOL)
  Read [ITM] ITM0=[M:PIH3]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
Endif

##----- Chargement unité et quantité en unité de stock ----#
If [F:ITM]STU="" [M:PIH3]STU(NOL)=[M:PIH3]PUU(NOL) Else [M:PIH3]STU(NOL)=[F:ITM]STU : Endif
If [M:PIH3]UOM(NOL)=[M:PIH3]STU(NOL)
  [M:PIH3]QTYSTU(NOL)=[M:PIH3]QTYUOM(NOL)
Else
  Call PCAL_QTY([M:PIH3]QTYPUU(NOL),[M:PIH3]PUU(NOL),[M:PIH3]QTYSTU(NOL),[M:PIH3]STU(NOL),
&               [M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
Endif
# Issue 71069 - 2016-01-07 by MUARN : pjt
#----- Si modif qté du composé, répercution sur les composants ? -----#
If [M:PIH3]LINTYP(NOL)=2 & ( [M:PIH3]PREQTYPUU(NOL)<>[M:PIH3]QTYPUU(NOL)  | [M:PIH3]PJT(NOL+1)<>[M:PIH3]PJT(NOL) )
  #----- Répercussion indicateur partiel -----#
  Local Integer I : I=NOL+1
  While [M:PIH3]LINTYP(I)>2 & I<[M:PIH3]NBLIG
    If [M:PIH3]PRTFLG(I)<>[M:PIH3]PRTFLG(NOL)
      [M:PIH3]PRTFLG(I)=[M:PIH3]PRTFLG(NOL)
      [M:PIH3]UPDFLG(I)=1
    Endif
    I+=1
  Wend
  #----- Recalcul des qtés ? -----#
  Local Integer OK : OK=2
  # Issue 71069 - 2016-01-07 by MUARN : pjt
  Local Integer UPD_PJT : UPD_PJT = 1
  Local Integer UPD_QTY : UPD_QTY = 1
  If [M:PIH3]PJT(NOL+1)<>[M:PIH3]PJT(NOL) : UPD_PJT = 2 : Endif
  If [M:PIH3]PREQTYPUU(NOL)<>[M:PIH3]QTYPUU(NOL)
    Call OUINON(mess(14,191,1),OK) From GESECRAN
    UPD_QTY = OK
  Endif
  # Issue 71069 - 2016-01-07 by MUARN : pjt
  If OK=2  | UPD_PJT = 2
    Local Decimal WQTE
    I=NOL+1
    While [M:PIH3]LINTYP(I)>2 & I<[M:PIH3]NBLIG
      #If [M:PIH3]LIKQTYCOE(I)<>0
        #WQTE=[M:PIH3]QTYPUU(NOL)*[M:PIH3]LIKQTYCOE(I)
        #If [M:PIH3]UOMPUUCOE(I)<>0
        #  WQTE=WQTE/[M:PIH3]UOMPUUCOE(I)
        #Endif
        # Issue 71069 - 2016-01-07 by MUARN : pjt
        If UPD_QTY = 2
          If [M:PIH3]PREQTYPUU(NOL)<>0
            WQTE=[M:PIH3]QTYUOM(I)*[M:PIH3]QTYPUU(NOL)/[M:PIH3]PREQTYPUU(NOL)
          Elsif [M:PIH3]LIKQTYCOE(I)<>0
            WQTE=[M:PIH3]QTYPUU(NOL)*[M:PIH3]LIKQTYCOE(I)
            If [M:PIH3]UOMPUUCOE(I)<>0
              WQTE=WQTE/[M:PIH3]UOMPUUCOE(I)
            Endif
          Else
            WQTE=[M:PIH3]QTYUOM(I)
          Endif
          #-----
          #Call QTEARR(WQTE,[M:PIH3]UOM(I)) From TRTDIV
          If [F:TUN]UOM<>[M:PIH3]UOM(I)
            Read [TUN] TUN0=[M:PIH3]UOM(I)
            If fstat  Raz [F:TCU] : Endif
          Endif
          WQTE=arr(WQTE,10^-max([F:TUN]UOMDEC,1))
          #-----
        Endif
        If UPD_PJT = 2
          [M:PIH3]PJT(I)=[M:PIH3]PJT(NOL)
        Endif
        nolign=I+1
        Call AVANT_NBLIG     From SUBPIH
        # Issue 71069 - 2016-01-07 by MUARN : pjt
        If UPD_QTY = 2
          Call AM_QTYUOM(WQTE) From SUBPIH
          [M:PIH3]QTYUOM(I)=WQTE : Affzo [PIH3]QTYUOM(I)
        Endif
        # Issue 90295 - 2013-06-14 by SR : Pour activer l'appel à MAJ_CALTAX_LIG
        [M:PIH3]LINFLG(I) = 0
        Call APRES_NBLIG     From SUBPIH
        [M:PIH3]UPDFLG(I)=1
      #Endif
      I+=1
    Wend
    Affzo [PIH3]5
    nolign=NOL+1
  Endif
Endif
[M:PIH3]PREQTYPUU(NOL)=[M:PIH3]QTYPUU(NOL)
#-----
If [M:PIH3]LINFLG(NOL)<>1  Call MAJ_CALTAX_LIG (NOL) From SUBPIHC : Endif
Call MAJ_CUMBASTAX_LIG(NOL,+1) From SUBPIHC
If GS1099 = 1 & !GIMPORT # 1099.sn
 Gosub CURR_CHECK From TEN99LIB
 If CURDIF=0
  If GS1099 Gosub CALC_AMTSUBJ1099 From TEN99LIB : Endif #1099.n Sum applicable lines into 1099 Amt
 Endif
Endif #1099.en
[M:PIH3]LINFLG(NOL)=1
#-------------------------------------------#
# Affichage totaux et actualisation picking #
#-------------------------------------------#
If !GIMPORT
  Affzo [PIH3]CUMLINAMT1
  # Issue 83026 - 2012-06-29 by MUARN : early discount
  Affzo [M:PIH4]BASDEP

  nolign=NOL+1 : # Le nolign peut être perdu à cause de l'Affzo !
  If [M:PIH3]PCLFLG=9 & [M:PIH3]CREFLG(NOL)=0
    Local Shortint WPICK, I
    WPICK=2 : I=NOL : Gosub MARQUAGE_LIGNE From SUBPIHD
  Endif
Endif
[M:PIH3]PCLFLG=1

Gosub PIH_APRES_NBLIG From TWMLIB  # Three way matching GRNA

# Issue 71069 - 2013-08-26 by MUARN : PJT
# Si première ligne & pas de code affaire à l'entête on alimente le code affaire à l'entête
If ([M:PIH3]NBLIG <1 | (GPIH_PICK & [M:PIH3]NBLIG=1)) & [M:PIH1]PJTH = "" & GPJTSNGDOC = 2
  [M:PIH1]PJTH = [M:PIH3]PJT(NOL)
  Affzo [PIH1]PJTH
Endif
# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End



Subprog AS_NBLIG
#--------------------#
# Avant saisie NBLIG #
#--------------------#
#----- Effacement tableau des sections entête -----#
# 69630 ajout GHEADIE<>1
If [M:PIH3]NBLIG=0 & dim([M:PIH1]NBAXE)>0 & [M:PIH1]NBAXE>0 & GHEADIE<>1
  Effzo [PIH1]25 : Affzo [PIH1]25 : Setmok [PIH1] With 0
Endif
# Issue 82703 - 2013-02-12 by SR
# Issue 89349 - 2013-10-25 by SR : Rapprochement
If [M:PIH0]PIHTYP = 2
   Actzo [M:PIH3]CSTMAJLIN(nolign-1)
   If [M:PIH3]CSTMAJLIN(nolign-1) = 2
      Grizo [M:PIH3]FCSCOD(nolign-1)
   Else
      Actzo [M:PIH3]FCSCOD(nolign-1)
   Endif
 Else
  Grizo [M:PIH3]CSTMAJLIN(nolign-1)
  Grizo [M:PIH3]FCSCOD(nolign-1)
Endif
# End issue 89349
#-----
End

Subprog AM_NBLIG
#---------------------------------------------#
# A chaque fois que le nombre de ligne change #
#---------------------------------------------#
#----- Test si modif ligne existante par saisie ou click droit -----#
If status<>75 & status<>131
  [M:PIH3]PCLFLG=9 : # Pour actualisation éventuelle des listes de picking
Endif
End

Subprog AS_TYPORI(VALEUR)
#-----------------------------------------------------------------#
# Avant saisie type d'origine : Interdiction de certaines valeurs #
#                               en fonction du type de facture    #
#-----------------------------------------------------------------#
Variable Integer VALEUR
# Issue 110325 - 2016-01-05 by SR : Interdire GMENLOC(6) = Expéditions sauf pour FCC
GMENLOC(6) = 1
If [M:PIH0]PIHTYP=2 : GMENLOC(6)=0                : Endif : # Fac compl
# End issue 110325
If [M:PIH0]PIHTYP=1 GMENLOC(3)=1 : GMENLOC(4)=1 :GMENLOC(6) = 1               : Endif : # Facture
# Issue 82703 - 2012-10-05 by SR : autoriser GMENLOC(1) = commandes
If [M:PIH0]PIHTYP=2 : GMENLOC(3)=1                : Endif : # Fac compl
If [M:PIH0]PIHTYP=3 GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=1 : Endif : # Avoir
If [M:PIH0]PIHTYP=3 & [M:PIH1]INVNUM=""           GMENLOC(4)=0 : Endif : # Avoir sans fac
If [M:PIH0]PIHTYP=4 GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(4)=1 : Endif : # Avoir/Ret
#----- Si facture issue d'une facture vente, seule la ligne diverse est autorisée -----#
If [M:PIH0]SIHNUM<>""
  GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=1 : GMENLOC(4)=1
Endif
End

Subprog IB_NUMORI
#--------------------------------------------#
# Initialisation bouton sur numéro d'origine #
#--------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
Case [M:PIH3]TYPORI(nolign-1)
  When 1 : GBOUT1=mess(191,198,1)
  When 2 : GBOUT1=mess(117,198,1)
  When 3 : GBOUT1=mess(192,198,1)
  When 6 : GBOUT1=mess(500,198,1)
Endcase
End

Subprog AS_NUMORI(VALEUR)
#-------------------------------#
# Avant saisie numéro d'origine #
#-------------------------------#
Variable Char    VALEUR()
# Issue 115504 - 2016-03-24 by SR : Razer les buffers si Divers
#If [M:PIH3]TYPORI(nolign-1)=5    VALEUR=""    : mkstat=2 : End : Endif
If [M:PIH3]TYPORI(nolign-1)=5
   VALEUR=""
   Raz [F:POH], [F:POQ], [F:POP], [F:PTH], [F:PTD]
   mkstat=2
   End
Endif
# End issue 115504
If [M:PIH0]PIHTYP=3
  If [M:PIH1]INVNUM<>"" VALEUR=[M:PIH1]INVNUM : mkstat=2 : End : Endif
Endif
End

Subprog C_NUMORI(VALEUR)
#---------------------------------------------------------#
# Contrôle numéro d'origine (cde, récept, retour ou fact) #
#---------------------------------------------------------#
Variable Char     VALEUR()
Local    Shortint NOL : NOL=nolign-1
Local    Char     FOUFAC(GLONBPS)
Local    Libelle  INTERSITE, INTERSOC
If [M:PIH3]TYPORI<5 & !GIMPORT
  If VALEUR=""  | VALEUR<>[M:PIH3]NUMORI(NOL)
    Raz [M:PIH3]LINORI(NOL), [M:PIH3]ITMREF(NOL)
  Endif
Endif
If VALEUR="" End : Endif
#-- Contrôle d'existence, appartenance à la même société et fournisseur facturant --#
If clalev([F:FCY])<=0 Local File FACILITY [FCY] : Endif
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
Case [M:PIH3]TYPORI(NOL)
  When 1 : Read [POH] POH0=VALEUR  : If fstat Raz [F:POH]  : Goto ERR_NUMORI : Endif
           If [F:POH]APPFLG<3   GMESSAGE=mess(146,194,1)   : mkstat=1  : End : Endif
           #----- Date document d'origine pas supérieure à date document en cours -----#
           If GCTLDATORI=2 & [F:POH]ORDDAT>[M:PIH0]ACCDAT
             GMESSAGE=mess(98,197,1)-VALEUR-"("+format$(GFMD,[F:POH]ORDDAT)+")\"-mess(409,194,1)
             GERR=1 : mkstat=1 : End
           Endif
           #-----
           FOUFAC=[F:POH]BPSINV : INTERSITE=[F:POH]BETFCY  : INTERSOC=[F:POH]BETCPY
           # Issue 120453 - 2016-12-16 by SR : Inter soc
           If INTERSOC = 2 & [F:POH]SALFCY <> "" & [M:PIH0]SIHNUM = ""
            GMESSAGE = mess(582,194,1)
            GERR = 1 : mkstat = 1 : End
           Endif
           Read [FCY] FCY0=[F:POH]POHFCY : If fstat Raz [F:FCY] : Endif
  When 2 : Read [PTH] PTH0=VALEUR  : If fstat Raz [F:PTH]  : Goto ERR_NUMORI : Endif
           #----- Date document d'origine pas supérieure à date document en cours -----#
           #VPO 21/04/11 73382 ajout ctl DATORI aussi avec date BL
           If GCTLDATORI=2
             If [F:PTH]NDEDAT=[0/0/0]
               If [F:PTH]RCPDAT>[M:PIH0]ACCDAT
                 GMESSAGE=mess(117,198,1)-VALEUR-"("+format$(GFMD,[F:PTH]RCPDAT)+")\"-mess(410,194,1)
                 GERR=1 : mkstat=1 : End
               Endif
             Else
               If min([F:PTH]NDEDAT,[F:PTH]RCPDAT)>[M:PIH0]ACCDAT
                 GMESSAGE=mess(117,198,1)-VALEUR-"("+format$(GFMD,min([F:PTH]NDEDAT,[F:PTH]RCPDAT))+")\"-mess(420,194,1)
                 GERR=1 : mkstat=1 : End
               Endif
             Endif
           Endif
           #-----
           FOUFAC=[F:PTH]BPSINV : INTERSITE=[F:PTH]BETFCY  : INTERSOC=[F:PTH]BETCPY
           If [M:PIH0]PIHTYP=2  FOUFAC=[M:PIH0]BPR : Endif
           Read [FCY] FCY0=[F:PTH]PRHFCY : If fstat Raz [F:FCY] : Endif
  When 3 : Read [PNH] PNH0=VALEUR  : If fstat Raz [F:PNH]  : Goto ERR_NUMORI : Endif
           If [F:PNH]CFMFLG<2   GMESSAGE=mess(144,194,1)   : mkstat=1  : End : Endif
           #----- Date document d'origine pas supérieure à date document en cours -----#
           If GCTLDATORI=2 & [F:PNH]RTNDAT>[M:PIH0]ACCDAT
             GMESSAGE=mess(192,198,1)-VALEUR-"("+format$(GFMD,[F:PNH]RTNDAT)+")\"-mess(411,194,1)
             GERR=1 : mkstat=1 : End
           Endif
           #-----
           FOUFAC=[F:PNH]BPSINV : INTERSITE=[F:PNH]BETFCY  : INTERSOC=[F:PNH]BETCPY
           Read [FCY] FCY0=[F:PNH]PNHFCY : If fstat Raz [F:FCY] : Endif
  When 4 : Local File PINVOICE [PIHB]
           Read [PIHB] PIH0=VALEUR : If fstat Raz [F:PIHB] : Goto ERR_NUMORI : Endif
           #----- Vérification si facture ou facture complémentaire d'achat -----#
           If [F:PIHB]ORIMOD<>6 | [F:PIHB]PIHTYP>2
             GMESSAGE=VALEUR-mess(227,194,1) : GERR=1 : mkstat=1 : End
           Endif
           #----- Date document d'origine pas supérieure à date document en cours -----#
           If GCTLDATORI=2 & [F:PIHB]ACCDAT>[M:PIH0]ACCDAT
             If [M:PIH0]PIHTYP=2
               GMESSAGE=mess(55,198,1)-VALEUR-"("+format$(GFMD,[F:PIHB]ACCDAT)+")\"-mess(408,194,1)
             Else
               GMESSAGE=mess(55,198,1)-VALEUR-"("+format$(GFMD,[F:PIHB]ACCDAT)+")\"-mess(407,194,1)
             Endif
             GERR=1 : mkstat=1 : End
           Endif
           #-----
           # Issue 102744 - 2014-09-26 by SR : Avoir ET FCC
           If find([M:PIH0]PIHTYP,2,3)
             If [F:PIHB]STA<>3
               GMESSAGE=VALEUR-mess([F:PIHB]STA,509,1)-":"-mess(335,194,1)
               GERR=1 : mkstat=1 : End
             Endif
             #----- Vérification si règlement en attente sur cette facture -----#
             If !clalev([F:DUD])  Local File GACCDUDATE [DUD] : Endif
             For [DUD] DUD1 Where ACCNUM=[F:PIHB]ACCNUM & TMPCUR<>0
               GMESSAGE=mess(74,119,1) : GERR=1 : mkstat=1 : Break
             Next
             If mkstat  End : Endif
             #-----
             FOUFAC=[F:PIHB]BPR
           Else
             #----- Vérification si facture d'achat -----#
             If [F:PIHB]PIHTYP<>1
               GMESSAGE=VALEUR-mess(227,194,1) : GERR=1 : mkstat=1 : End
             Endif
             #-----
             FOUFAC=[M:PIH0]BPR
           Endif
           Read [FCY] FCY0=[F:PIHB]FCY   : If fstat Raz [F:FCY] : Endif
 When 6 :
           Read [SHH] SHH0=VALEUR  : If fstat Raz [F:SHH]  : Goto ERR_NUMORI : Endif
           # Pas de pré reception de commande
           If [F:SHH]SHIPTYP <> 1
             GMESSAGE = mess(504,198,1) -":"-mess([F:SHH]SHIPTYP,2510,1)
             GERR=1 : mkstat=1 : End
           Endif
            #----- Date document d'origine pas supérieure à date document en cours -----#
           If GCTLDATORI=2 & [F:SHH]SHIPDAT>[M:PIH0]ACCDAT
             GMESSAGE=mess(500,198,1)-VALEUR-"("+format$(GFMD,[F:SHH]SHIPDAT)+")\"-mess(543,194,1)
             GERR=1 : mkstat=1 : End
           Endif
           #-----
           FOUFAC=[M:PIH0]BPR
           If [F:SHH]FCY <> "" : Read [FCY] FCY0=[F:SHH]FCY : If fstat Raz [F:FCY] : Endif : Endif
Endcase
#----- N'appartient pas à la même société ! -----#
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
If [M:PIH3]TYPORI(NOL) <> 6
  If [F:FCY]LEGCPY<>GSOCIETE   GMESSAGE=mess(151,194,1) : mkstat=1 : End : Endif
Else
  If [F:SHH]LEGCPY <> "" & [F:SHH]LEGCPY<>GSOCIETE   GMESSAGE=mess(151,194,1) : mkstat=1 : End : Endif
Endif
# End issue 110325
# Issue 82703 - 2012-10-05 by SR Pas de contrôle si facture complémentaire
If [M:PIH0]PIHTYP <> 2
    #----- Fournisseur facturant différent ! -----#
    If INTERSITE<>2 & FOUFAC<>[M:PIH0]BPR  GMESSAGE=mess(150,194,1) : mkstat=1 : End : Endif
    #----- Pas de facturation pour l'inter-site -----#
    If INTERSITE=2 & INTERSOC<>2 GMESSAGE=mess(239,194,1) : mkstat=1 : End : Endif
Endif
End
#------ L'enregistrement n'existe pas ------#
$ERR_NUMORI
If GIMPORT : # En import on force le type ligne divers et on efface les numéros
  Raz VALEUR, [F:PID]NUMORI, [F:PID]LINORI, [F:PID]SEQORI
  [F:PID]TYPORI=5 : [M:PIH3]TYPORI(NOL)=5
  End
Endif
GMESSAGE=mess(23,100,1) : mkstat=1 : End
#-------------------------------------------#

Subprog AS_LINORI(VALEUR)
#------------------------------#
# Avant saisie ligne d'origine #
#------------------------------#
Variable Decimal  VALEUR
Local    Shortint NOL : NOL=nolign-1
If [M:PIH3]TYPORI(NOL)=5 | [M:PIH3]NUMORI(NOL)="" VALEUR=0 : mkstat=2 : End : Endif
End

Subprog C_LINORI(VALEUR)
#------------------------------#
# Contrôle sur ligne d'origine #
#------------------------------#
Variable Decimal VALEUR
Local Char WMSG(250) # Issue 71069 - 2016-04-01 by SR : PJT
Local    Shortint NOL : NOL=nolign-1
If VALEUR=0 & [M:PIH3]NUMORI(NOL)<>"" mkstat=1 : End : Endif
If VALEUR=0 End : Endif
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
#----- Contrôle d'existence et test flag facturé et soldé -----#
Case [M:PIH3]TYPORI(NOL)
  When 1 : If [M:PIH3]SEQORI(NOL)<2
             Read [POQ] POQ0=[M:PIH3]NUMORI(NOL);VALEUR;1
           Else
             Read [POQ] POQ0=[M:PIH3]NUMORI(NOL);VALEUR;[M:PIH3]SEQORI(NOL)
           Endif
           If fstat Raz [F:POQ]  : Goto ERR1_LINORI : Endif
           # Issue 101413 - 2014-07-15 by SR : ligne activée si PIHTYP <> 2
#           If [F:POQ]LINTYP>2 & !GIMPORT & !GPIH_PICK  Goto ERR2_LINORI : Endif
#          # Issue 82703 - 2012-10-04 by SR : dissocier facture complémentaire
            If [M:PIH0]PIHTYP <> 2
              # Issue 101413 - 2014-07-15 by SR : Interdire seulement les composants
              If [F:POQ]LINTYP>2 & !GIMPORT & !GPIH_PICK  Goto ERR2_LINORI : Endif
              If [F:POQ]WIPSTA>1 | [F:POQ]LININVFLG>1 |
&               ([F:POQ]LINCLEFLG>1 & [F:POQ]RCPQTYPUU<=[F:POQ]INVQTYPUU)
                WMSG=mess(98,197,1)-[F:POQ]POHNUM-num$([F:POQ]POPLIN)
                Goto ERR3_LINORI
              Endif
              # Issue 71069 - 2016-04-01 by SR : PJT
              If [M:PIH3]NBLIG >0
                Read [F:POP] POP0 = [M:PIH3]NUMORI(NOL);VALEUR;1
                If fstat : Raz [F:POP] : Endif
                  If func TRTPJT.IS_PJT_AVAILABLE([F:POP]PJT, "[M:PIH3]PJT", WMSG) = G_NON Then
                    Goto ERR6_LINORI
                  Endif
              Endif
              # End issue 71069
           # Issue 101413 - 2014-07-15 by SR : Interdire les commandes de sous-traitance
           Else
             If find([F:POQ]VCRTYPORI,10,36) : Goto ERR4_LINORI : Endif
           Endif
  When 2 : Read [PTD] PTD0=[M:PIH3]NUMORI(NOL);VALEUR
           If fstat Raz [F:PTD]  : Goto ERR1_LINORI : Endif
           If [F:PTD]LINTYP>2 & !GIMPORT & !GPIH_PICK  Goto ERR2_LINORI : Endif
#          # Issue 90484 - 2012-10-04 by SR : dissocier facture complémentaire
           If [M:PIH0]PIHTYP <> 2
              If [F:PTD]LININVFLG>1
                WMSG=mess(117,198,1)-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
                Goto ERR3_LINORI
              Endif
              # Issue 71069 - 2016-04-01 by SR : PJT
              If [M:PIH3]NBLIG >0
                If func TRTPJT.IS_PJT_AVAILABLE([F:PTD]PJT, "[M:PIH3]PJT", WMSG) = G_NON Then
                    Goto ERR6_LINORI
               Endif
              Endif
              # End issue 71069
              # Issue 120453 - 2016-12-16 by SR : Inter soc
              If [F:PTH]BETCPY = 2 & [F:PTD]VERFLG = 1 & [F:PTD]SDHNUM <> "" &  [M:PIH3]SIDLIN(nolign-1) = 0
               GMESSAGE = mess(582,194,1)
               GERR = 1 : mkstat = 1 : End
              Endif
           Endif
  When 3 : Read [PND] PND0=[M:PIH3]NUMORI(NOL);VALEUR
           If fstat Raz [F:PND]  : Goto ERR1_LINORI : Endif
           If [F:PND]LININVFLG>1 & [F:PND]INVQTYPUU<>0
             WMSG=mess(192,198,1)-[F:PND]PNHNUM-num$([F:PND]PNDLIN)
             Goto ERR3_LINORI
           Endif
           # Issue 71069 - 2016-04-01 by SR : PJT
           If [M:PIH3]NBLIG >0
              If func TRTPJT.IS_PJT_AVAILABLE([F:PND]PJT, "[M:PIH3]PJT", WMSG) = G_NON Then
                  Goto ERR6_LINORI
              Endif
           Endif
           # End issue 71069
  When 4 : Local File PINVOICED [PIDB]
           Read [PIDB] PID0=[M:PIH3]NUMORI(NOL);VALEUR
           If fstat Raz [F:PIDB] : Goto ERR1_LINORI : Endif
           # Issue 87184 - 2013-01-15 by MUARN : pas les lignes service et matière fournies
           If [F:PIDB]LINTYP>2 & !GIMPORT & !GPIH_PICK  Goto ERR2_LINORI : Endif
           [M:PIH3]ITMREF(NOL)=[F:PIDB]ITMREF
           GBIDC3=[F:PIDB]VAT(0)
           # Issue 71069 - 2016-04-01 by SR : PJT
           If [M:PIH3]NBLIG >0
              If func TRTPJT.IS_PJT_AVAILABLE([F:PIDB]PJT, "[M:PIH3]PJT", WMSG) = G_NON Then
                  Goto ERR6_LINORI
              Endif
           Endif
           # End issue 71069
 When 6 : Read [SHD] SHD0=[M:PIH3]NUMORI(NOL);VALEUR
           If fstat Raz [F:SHD]  : Goto ERR1_LINORI : Endif
           If [F:SHD]LEGCPY <> GSOCIETE
             WMSG=mess(151,194,1)-[F:SHD]SHIPNUM-num$([F:SHD]SHIPLIN)
             Goto ERR5_LINORI
           Endif
  When Default
Endcase
End
#----- L'enregistrement n'existe pas -----#
$ERR1_LINORI
If GIMPORT : # En import on force le type ligne divers et on efface les numéros
  Raz [M:PIH3]NUMORI(NOL), VALEUR, [F:PID]NUMORI, [F:PID]LINORI, [F:PID]SEQORI
  [F:PID]TYPORI=5 : [M:PIH3]TYPORI(NOL)=5
  End
Endif
GMESSAGE=mess(23,100,1)  : mkstat=1 : End
#----- Ligne composant interdite, saisissez le composé ! -----#
$ERR2_LINORI
GMESSAGE=mess(385,194,1) : mkstat=1 : End
#----- Ligne déja facturée ou soldée ! -----#
$ERR3_LINORI
GMESSAGE=WMSG-mess(142,194,1) : mkstat=1 : End
# Issue 101413 - 2014-07-15 by SR : Sous-traitance interdite
$ERR4_LINORI
GMESSAGE=mess(30,190,1) : mkstat=1 : End
# Issue 110325 - 2016-01-11 by SR : N'appartient pas à la même société juridique
$ERR5_LINORI
GMESSAGE = WMSG : mkstat=1 : End
# Issue 71069 - 2016-04-01 by SR :Mono affaire et affiare différente de l'entête
$ERR6_LINORI
GMESSAGE = WMSG : mkstat=1 : End

#-----

Subprog AM_LINORI(VALEUR)
#-----------------------------#
# Après modif ligne d'origine #
#-----------------------------#
Variable Decimal  VALEUR
Local    Shortint NOL : NOL=nolign-1
Local    Char     FICH(3), NOM(GLONATB), SYMBOL2(30)
If VALEUR=0 End : Endif
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
#----- Chargement référence article -----#
Case [M:PIH3]TYPORI(NOL)
  When 1 : [M:PIH3]SEQORI(NOL)=[F:POQ]POQSEQ : [M:PIH3]ITMREF(NOL)=[F:POQ]ITMREF
           FICH="POH" : NOM="$PORDER"
  When 2 : [M:PIH3]SEQORI(NOL)=0             : [M:PIH3]ITMREF(NOL)=[F:PTD]ITMREF
           FICH="PTH" : NOM="$PRECEIPT"
  When 3 : [M:PIH3]SEQORI(NOL)=0             : [M:PIH3]ITMREF(NOL)=[F:PND]ITMREF
           FICH="PNH" : NOM="$PRETURN"
  When 4 : [M:PIH3]SEQORI(NOL)=0
           FICH="PIH" : NOM="$PINVOICE"
  When 5 : [M:PIH3]SEQORI(NOL)=0
  When 6 : [M:PIH3]SEQORI(NOL)=0             : [M:PIH3]ITMREF(NOL)=[F:SHD]ITMREF
           FICH="SHH" : NOM="$SHIPMENT"
Endcase
#----- Blocage logique et chargement des autres champs de la ligne -----#
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
#If [M:PIH3]TYPORI(NOL)<5
If [M:PIH3]TYPORI(NOL)<>5
  #----- Contrôle si avoir ou facture non validé sur document d'origine -----#
  # Issue 102744 - 2014-10-03 by SR : A faire aussi si FCC sur facture
 # Issue 110325 - 2016-01-11 by SR : FCC sur expé : rien à faire
  If [M:PIH3]TYPORI(NOL)<4 | ([M:PIH0]PIHTYP = 2 & [M:PIH3]TYPORI(NOL) <> 6)
   #If [M:PIH3]TYPORI(NOL)<4
    Local Integer SAV_LINORI
    SAV_LINORI=[M:PIH3]LINORI(NOL)
    [M:PIH3]LINORI(NOL)=VALEUR
    Gosub CTRL_DATFAR From SUBPIHD
    If !mkstat  Gosub CTRL_VALID From SUBPIHD : Endif
    [M:PIH3]LINORI(NOL)=SAV_LINORI
    Gosub PIH_TWMCHK From TWMLIB
    If mkstat  Raz [M:PIH3]ITMREF(NOL) : End : Endif
  Endif
  #----- Contrôle si ligne facture fait déjà l'objet d'un avoir -----#
  If [M:PIH0]PIHTYP=3 & [M:PIH3]TYPORI(NOL)=4
    Filter [PIDB] Where TYPORI=4
&                     & NUMORI=[M:PIH3]NUMORI(NOL)
&                     & LINORI=VALEUR
&                     & PIHTYP=3
&                     & NUM<>[M:PIH0]NUM
    Look [PIDB] PID1 First
    Filter [PIDB]
    If !fstat
      Local Integer OK
      OK=2 : Call AVERTIR([M:PIH3]NUMORI(NOL)-num$(VALEUR)-mess(45,191,1),OK) From GESECRAN
      If OK=1  Raz [M:PIH3]ITMREF(NOL) : mkstat=1 : End : Endif
    Endif
  Endif
  #----- Si avoir, contrôle date facture d'origine donne le même taux de taxe -----#
  If [M:PIH0]PIHTYP=3 & [M:PIH3]TYPORI(NOL)=4 & dim([M:PIH1]VATDAT)>0
    If clalev([PIHB])<=0 Local File PINVOICE [PIHB] : Endif
    Read [PIHB] PIH0=[M:PIH3]NUMORI(NOL) : If fstat Raz [F:PIHB] : Endif
    # Issue 93187 - 2013-11-15 by MUARN : VATDAT non ACCDAT
    #GBIDA1=[F:PIHB]ACCDAT
    GBIDA1=[F:PIHB]VATDAT
    Gosub CTRL_DATE_TAXE From SUBPIHB
    If mkstat  Raz [M:PIH3]ITMREF(NOL) : End : Endif
  Endif
  #-----
  SYMBOL2=FICH+[M:PIH3]NUMORI(NOL) : Lock=SYMBOL2
  If fstat
    GMESSAGE=NOM-[M:PIH3]NUMORI(NOL)-mess(10,100,1) : GERR=1
    Raz [M:PIH3]ITMREF(NOL) : mkstat=1 : End
  Endif
  #----- Vérif si commande bloquée logiquement -----#
  If [M:PIH3]TYPORI(NOL)=2 & [F:PTD]POHNUM<>""
    Lock="POH"+[F:PTD]POHNUM
    If fstat
      GMESSAGE="$PORDER"-[F:PTD]POHNUM-mess(10,100,1) : GERR=1
      Raz [M:PIH3]ITMREF(NOL) : mkstat=1 : End
    Endif
    Unlock="POH"+[F:PTD]POHNUM
  Endif
  #-----
  GPIH_SYMBOL2=SYMBOL2
  [M:PIH3]LINORI(NOL)=VALEUR : Call CHARG_LIG (NOL,[M:PIH3]NBLIG) From SUBPIHB
   If !GIMPORT
    Affzo [PIH3]ITMREF(NOL) : Gosub AFFICH_LIG
  Endif
Endif
End

Subprog AS_ITMREF(VALEUR)
#--------------------------------#
# Avant saisie référence article #
#--------------------------------#
Variable Char     VALEUR()
Local    Shortint NOL : NOL=nolign-1
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
#If [M:PIH3]TYPORI(NOL)<5  & [M:PIH3]NUMORI(NOL)<>"" & !GIMPORT mkstat=2 : End : Endif
If [M:PIH3]TYPORI(NOL)<>5  & [M:PIH3]NUMORI(NOL)<>"" & !GIMPORT mkstat=2 : End : Endif
# If [M:PIH3]CREFLG(NOL)<>0 mkstat=2 : End : Endif
End

Subprog IB_ITMREF
#----------------------------------------------#
# Initialisation boutons sur référence article #
#----------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5
GBOUT1=mess(22,198,1)   : # Articles : Tunnel sur les articles
# Issue X3-86112 - 2018-06-15 by SR : Change of the message number
If GITMFLG=1
  #GBOUT2=mess(31,198,1) : # Art/Fourn: Sélection par référence interne
  GBOUT2=mess(23,198,1) : # Article-fournisseur: Sélection par référence interne
Else
  #GBOUT3=mess(31,198,1) : # Art/Fourn: Sélection par référence fournisseur
  GBOUT3=mess(23,198,1) : # Article-fournisseur: Sélection par référence fournisseur
Endif
End

Subprog C_ITMREF(VALEUR)
#--------------------------------#
# Contrôle sur référence article #
#--------------------------------#
Variable Char    VALEUR()
Local    Shortint NOL : NOL=nolign-1
#----- Ligne type divers, accepter une référence vide -----#
If [M:PIH3]TYPORI(NOL)=5 & VALEUR=""
  Raz [F:ITM]
  Raz [M:PIH3]ITMDES(NOL), [M:PIH3]ITMDES1(NOL), [M:PIH3]UOM(NOL)
  #----- Chargement des autres champs de la ligne -----#
  If [M:PIH3]LINFLG(NOL)=0
    [M:PIH3]ITMREF(NOL)=VALEUR : Call CHARG_LIG (NOL,[M:PIH3]NBLIG) From SUBPIHB
    [M:PIH3]LINFLG(NOL)=0
    If !GIMPORT
      Affzo [PIH3]NUMORI(NOL),LINORI(NOL) : Gosub AFFICH_LIG
    Endif
  Endif
  #-----
  End
Endif
#-----
If VALEUR=""  GMESSAGE=mess(107,194,1) : mkstat=1 : End : Endif
Local    Char    WITMREF(GLONITM) : WITMREF=VALEUR
If GITMFLG<>2
  VALEUR=toupper(VALEUR)
  If !GIMPORT   : # Bug 75300 : Action interactive à ne pas executer en import
    Call CONTSEL("ITM","B",VALEUR,"",mkstat) From CONTOBJ
  Endif
  If !mkstat
    Call CONTROLE("ITM","B",VALEUR,"",mkstat) From CONTOBJ
  Endif
  If mkstat  VALEUR=WITMREF : Endif
  End
Endif
Read [ITP] ITP2=[M:PIH0]BPR;VALEUR
If !fstat
  VALEUR=[F:ITP]ITMREF
  If [F:ITM]ITMREF<>[F:ITP]ITMREF
    Read [ITM] ITM0=[F:ITP]ITMREF
    If fstat  mkstat=1 : GMESSAGE=mess(5,194,1) : End : Endif
  Endif
  Call CONTROLE("ITM","B",VALEUR,"",mkstat) From CONTOBJ
  If mkstat  VALEUR=WITMREF : End : Endif
  End
Endif
VALEUR=toupper(VALEUR)
Call CONTSEL("ITM","B",VALEUR,"",mkstat) From CONTOBJ
If !mkstat
  Call CONTROLE("ITM","B",VALEUR,"",mkstat) From CONTOBJ
Endif
If mkstat VALEUR=WITMREF : End : Endif
End

Subprog AM_ITMREF(VALEUR)
#--------------------------------------------#
# Contrôle sur référence article après modif #
#--------------------------------------------#
Variable Char     VALEUR()
Local    Shortint NOL : NOL=nolign-1
Local    Integer  OK
# Issue 100578 - 2018-08-16 by SR : Message d'avertissement selon statut de l'article
Local    Char     WMESS(80)
If [M:PIH3]TYPORI(NOL)<>5 | VALEUR<>""
   If [F:ITM]ITMREF<>VALEUR
     Read [ITM] ITM0=VALEUR : If fstat Raz [F:ITM] : Endif
   Endif
   # Issue X3-100578 - 2018-08-16 by SR : Statut de l'article
   If [F:ITM]ITMSTA<>1 & [F:ITM]ITMSTA<>3
      WMESS = (mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")")
      OK = 2
      Call  AVERTIR(WMESS,OK) From GESECRAN
      If OK=1   Goto RETOURITMREF : Endif
   Endif
   #----- Article référencé chez le fournisseur ? -----#
   Read [ITP] ITP0=VALEUR;[M:PIH0]BPR
   If fstat
      Raz [F:ITP]
      # Issue 77999 - 2011-11-18 by VPO : référencement inutile si fournisseur de type Divers
      If [F:BPS]BPSNUM<>[M:PIH0]BPR
        Read [BPS] BPS0=[M:PIH0]BPR : If fstat Raz [F:BPS] : Endif
      Endif
      #----- Si fournisseur <> Divers -----#
      If [F:BPS]BPSTYP<>3
        #----- Si article non générique -----#
        If [F:ITM]GENFLG<>2
          If GITMBPS=1 GMESSAGE=mess(8,194,1) : GERR=1
                       Goto RETOURITMREF : Endif
          If GITMBPS=2 OK=2 : Call AVERTIR(mess(8,194,1),OK) From GESECRAN
             If OK=1   Goto RETOURITMREF : Endif
          Endif
        Endif
      Endif
   Endif
   #----- Article douteux pour ce fournisseur ? -----#
   If [F:ITP]DOUFLG=2 OK=2 : Call AVERTIR(mess(9,194,1),OK) From GESECRAN
      If OK=1 Goto RETOURITMREF : Endif
   Endif
   If [F:ITP]DOUFLG=3 GMESSAGE=mess(9,194,1) : GERR=1
                      Goto RETOURITMREF : Endif
 Endif

# Issue 70985 - 2012-06-27 by MUARN : landed cost
[M:PIH3]NETCUR(NOL) = [M:PIH1]CUR
[M:PIH3]CPRCUR(NOL) = GLOCALDEV

#----- Pas de sélection de la ligne cde, réception, retour ou facture à facturer -----#
# Issue 110325 - 2016-01-11 by SR : comment
#If [M:PIH3]TYPORI(NOL)>4 | GIMPORT
If [M:PIH3]TYPORI(NOL)= 5 | GIMPORT
   #----- Chargement des autres champs de la ligne -----#
   [M:PIH3]ITMREF(NOL)=VALEUR : Call CHARG_LIG (NOL,[M:PIH3]NBLIG) From SUBPIHB
   If !GIMPORT
     Affzo [PIH3]NUMORI(NOL),LINORI(NOL) : Gosub AFFICH_LIG
   Endif
Endif
End
#----- Retour à la saisie de la référence article -----#
$RETOURITMREF
mkstat=1 : [M:PIH3]ITMREF(NOL)="" : If !GIMPORT VALEUR="" : Endif
End

Subprog IB_ITMDES
#--------------------------------------------------------------#
# Champ désignation article : Initialisation bouton "Articles" #
#--------------------------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
#----- Test si référence article renseignée -----#
If [M:PIH3]ITMREF(nolign-1)<>"" GBOUT1=mess(22,198,1) : Endif
End

Subprog IB_ITMDES1
#------------------------------------------------------------------#
# Champ désignation std article : Initialisation bouton "Articles" #
#------------------------------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
#----- Test si référence article renseignée -----#
If [M:PIH3]ITMREF(nolign-1)<>"" GBOUT1=mess(22,198,1) : Endif
End

Subprog AS_UOM(VALEUR)
#---------------------------------------------------------------------------#
# Avant saisie de l'unité : Pas de saisie pour les factures complémentaires #
#                                et les avoirs sur factures complémentaires #
#---------------------------------------------------------------------------#
Variable Char     VALEUR()
Local Shortint NOL : NOL=nolign-1
# Issue 82703 - 2012-10-05 by SR
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
If [M:PIH0]PIHTYP=2 & find([M:PIH3]TYPORI(NOL),1,2,4,6)
  mkstat=2 : End
Endif
If [M:PIH0]PIHTYP=3 & [M:PIH3]TYPORI(NOL)=4 & [M:PIH3]QTYUOM(NOL)=0 & [M:PIH3]NETPRI(NOL)=0
  mkstat=2 : End
Endif
End

Subprog AM_UOM(VALEUR)
#---------------------------------------#
# Après modif de l'unité de facturation #
#---------------------------------------#
Variable Char     VALEUR()
Local    Shortint NOL : NOL=nolign-1
GCOEUOM=0
If [M:PIH3]TYPORI(NOL)=1 : # Commande
  If [F:POQ]POHNUM<>[M:PIH3]NUMORI(NOL) |
&    [F:POQ]POPLIN<>[M:PIH3]LINORI(NOL) |
&    [F:POQ]POQSEQ =[M:PIH3]SEQORI(NOL)
    Read [POQ] POQ0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL);[M:PIH3]SEQORI(NOL)
    If fstat  Raz [F:POQ] : Endif
  Endif
  If VALEUR=[F:POQ]UOM  GCOEUOM=[F:POQ]UOMPUUCOE : Endif
Endif
If [M:PIH3]TYPORI(NOL)=2 : # Réception
  If [F:PTD]PTHNUM<>[M:PIH3]NUMORI(NOL) | [F:PTD]PTDLIN<>[M:PIH3]LINORI(NOL)
    Read [PTD] PTD0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
    If fstat  Raz [F:PTD] : Endif
  Endif
  If VALEUR=[F:PTD]UOM  GCOEUOM=[F:PTD]UOMPUUCOE : Endif
Endif
If [M:PIH3]TYPORI(NOL)=3 : # Retour
  If [F:PND]PNHNUM<>[M:PIH3]NUMORI(NOL) | [F:PND]PNDLIN<>[M:PIH3]LINORI(NOL)
    Read [PND] PND0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
    If fstat  Raz [F:PND] : Endif
  Endif
  If VALEUR=[F:PND]UOM  GCOEUOM=[F:PND]UOMPUUCOE : Endif
Endif
If [M:PIH3]TYPORI(NOL)=4 & [M:PIH0]PIHTYP=3       : # Facture dans le cas d'un avoir
  Local File PINVOICED [PIDB]
  Read [PIDB] PID0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
  If fstat  Raz [F:PIDB] : Endif
  If VALEUR=[F:PIDB]UOM  GCOEUOM=[F:PIDB]UOMPUUCOE : Endif
Endif
If [M:PIH3]TYPORI(NOL)=5 & [M:PIH3]ITMREF(NOL)="" : # Divers sans référence article
  [M:PIH3]PUU(NOL)=VALEUR : GCOEUOM=1
Endif
If VALEUR=[M:PIH3]PUU(NOL)  GCOEUOM=1 : Endif
If GCOEUOM<>0
  If varinit([M:PIH3]QTYUOM,NOL)
    [M:PIH3]QTYUOM(NOL)=[M:PIH3]QTYPUU(NOL)/GCOEUOM
    Call QTEARR([M:PIH3]QTYUOM(NOL),VALEUR) From TRTDIV
  Endif
Else
  If varinit([M:PIH3]QTYUOM,NOL)
    Call PCAL_QTY([M:PIH3]QTYPUU(NOL),[M:PIH3]PUU(NOL),[M:PIH3]QTYUOM(NOL),VALEUR,
&                 [M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),1,GBIDD1)  From TRTACHQTE1
  Endif
  #---- Récupération coefficient -----#
  Call PCAL_QTY([M:PIH3]QTYUOM(NOL),VALEUR,GBIDD1,[M:PIH3]PUU(NOL),
&               [M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),1,GCOEUOM) From TRTACHQTE1
Endif
[M:PIH3]UOMPUUCOE(NOL)=GCOEUOM
Call PCAL_QTY([M:PIH3]QTYUOM(NOL),[M:PIH3]UOM(NOL),GBIDD1,VALEUR,
&       [M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),1,GBIDD2)  From TRTACHQTE1 : # Récup coef
[M:PIH3]GROPRI(NOL)   =arr([M:PIH3]GROPRI(NOL)/GBIDD2,10^-GDECPRI)
[M:PIH3]NETPRI(NOL)   =arr([M:PIH3]NETPRI(NOL)/GBIDD2,10^-GDECPRI)
[M:PIH3]ORINETPRI(NOL)=arr([M:PIH3]ORINETPRI(NOL)/GBIDD2,10^-GDECPRI)
If varinit([M:PIH3]QTYUOM,NOL)
  [M:PIH3]AMTNOTLIN(NOL)=[M:PIH3]NETPRI(NOL)*[M:PIH3]QTYUOM(NOL)
  Call ARRDEV([M:PIH3]AMTNOTLIN(NOL),[M:PIH1]CUR) From TRTDIV
  # Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
  [M:PIH3]AMTNOTLINCAL(NOL)=[M:PIH3]AMTNOTLIN(NOL)
  [M:PIH3]UOM(NOL)=VALEUR
  If !GIMPORT Affzo [PIH3]QTYUOM(NOL),NETPRI(NOL),AMTNOTLIN(NOL) : Endif
Endif
nolign=NOL+1
End

Subprog IB_QTYUOM
#----------------------------------------------------------#
# Champ qté facturée : Initialisation bouton "Détail qtés" #
#----------------------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5
#----- Si facture complémentaire pas de saisie de quantité -----#
GBOUT1=mess(215,198,1)
End

Subprog AS_QTYUOM(VALEUR)
#---------------------------#
# Avant saisie qté facturée #
#---------------------------#
Variable Decimal  VALEUR
Local Shortint NOL : NOL=nolign-1
# Issue 82703 - 2012-10-05 by SR Si commande et Fact complentaire pas de saisie
If [M:PIH3]TYPORI(NOL)=1 & [M:PIH0]PIHTYP=2
   mkstat=2 : End
Endif
If [M:PIH3]TYPORI(NOL)=4 | [M:PIH3]TYPORI(NOL)=2
  #----- Si facture complémentaire pas de saisie de quantité -----#
  If [M:PIH0]PIHTYP=2
    mkstat=2 : End
  Endif
  #----- Si avoir sur fact complémentaire pas de saisie de qté -----#
  If [M:PIH0]PIHTYP=3 & [M:PIH3]UOM(NOL)="" & [M:PIH3]NETPRI(NOL)=0
    mkstat=2 : End
  Endif
Endif
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
If [M:PIH3]TYPORI(NOL)=6
   mkstat=2 : End
Endif
End

Subprog C_QTYUOM(VALEUR)
#-----------------------#
# Contrôle qté facturée #
#-----------------------#
Variable Decimal  VALEUR
Local    Shortint NOL  : NOL=nolign-1
#----- Si ligne de type DIVERS pas de contrôle -----#
If TYPORI(NOL)=5 End : Endif
# Issue 102677 - 2014-10-02 by SR : Si déjà fait en CHARG_LIG, pas la peine de le refaire
If GIMPORT & dim(GPIH_QTEMAX)> 0 & GPIH_QTEMAX <> 0 : End : Endif
# End issue 102677
#----- Recalcul qté maxi pour contrôle si dépassement (fait en AM_QTYUOM) -----#
Local    Decimal  WQTE : WQTE=[M:PIH3]ORIQTYPUU(NOL)
Call CAL_QTEMAX(NOL,[M:PIH3]NBLIG,WQTE) From SUBPIHB
End

Subprog AM_QTYUOM(VALEUR)
#--------------------------------#
# Après modif de la qté facturée #
#--------------------------------#
Variable Decimal  VALEUR
Local    Shortint NOL : NOL=nolign-1
Local    Integer  OK  : OK=1
Local    Decimal  QTE
Local    Decimal  SAV_QTYPUU : SAV_QTYPUU=[M:PIH3]QTYPUU(NOL)
[M:PIH3]QTYPUU(NOL)=VALEUR*[M:PIH3]UOMPUUCOE(NOL)
Call QTEARR([M:PIH3]QTYPUU(NOL),[M:PIH3]PUU(NOL)) From TRTDIV
QTE=GPIH_QTEMAX/[M:PIH3]UOMPUUCOE(NOL)
Call QTEARR(QTE,[M:PIH3]UOM(NOL)) From TRTDIV
If [M:PIH3]LINTYP(NOL)<3
  [M:PIH3]PRTFLG(NOL)=1
Else
  [M:PIH3]PRTFLG(NOL)=[M:PIH3]PRTFLG(NOL-1)
Endif
If [M:PIH3]TYPORI(NOL)<>5
  #----- Qté inférieure, facturation partielle ? -----#
  If [M:PIH3]QTYPUU(NOL)<GPIH_QTEMAX & [M:PIH3]LINTYP(NOL)<3
    #----- Si avoir pas de question, c'est du partiel -----#
    If [M:PIH0]PIHTYP=3
      [M:PIH3]PRTFLG(NOL)=2
    #----- Autre, poser la question -----#
    Elsif [M:PIH3]LINTYP(NOL)<3
      # Issue 98750 - 2014-04-01 by MUARN : ne poser la question que
      # si quantité facturée + quantité non facturable sur réception+ quantité saisie sur facture
      # est inférieur à la quantité réceptionée et facture considérée non partielle
      #If ( ( [F:POQ]INVQTYPUU + WQTE_NONFAC + VALEUR ) < [F:POQ]RCPQTYPUU ) | [F:POQ]RCPQTYPUU = 0
        OK=2 : Call OUINON(mess(372,194,1),OK) From GESECRAN
        If OK=2  [M:PIH3]PRTFLG(NOL)=2  Else  [M:PIH3]PRTFLG(NOL)=1 : Endif
      #Else
      #  [M:PIH3]PRTFLG(NOL)=1
      #Endif
    Endif
  Endif
  #----- Si ligne de type non DIVERS, contrôle dépassement qté maxi -----#
  If [M:PIH3]QTYPUU(NOL)>GPIH_QTEMAX & !GIMPORT
    GMESSAGE=mess(147,194,1)-format$("N:15F",QTE)-[M:PIH3]UOM(NOL)
    Call AVERTIR(GMESSAGE,OK) From GESECRAN : Raz GMESSAGE
    If OK=1 mkstat=1 : [M:PIH3]QTYPUU(NOL)=SAV_QTYPUU : End : Endif
  Endif
Else
  Raz GPIH_QTEMAX
Endif
[M:PIH3]AMTNOTLIN(NOL)=[M:PIH3]NETPRI(NOL)*VALEUR
Call ARRDEV([M:PIH3]AMTNOTLIN(NOL),[M:PIH1]CUR) From TRTDIV
# Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
[M:PIH3]AMTNOTLINCAL(NOL)=[M:PIH3]AMTNOTLIN(NOL)
If !GIMPORT Affzo [PIH3]AMTNOTLIN(NOL) : Endif
nolign=NOL+1
End

Subprog AS_NETPRI(VALEUR)
#---------------------------------------------------------------------------------#
# Avant saisie du prix unitaire : Pas de saisie pour les factures complémentaires #
#                                      et les avoirs sur factures complémentaires #
#---------------------------------------------------------------------------------#
Variable Decimal VALEUR
Local    Shortint NOL : NOL=nolign-1
If [M:PIH3]TYPORI(NOL)=4
  If [M:PIH0]PIHTYP=2
    mkstat=2 : End
  Endif
  If [M:PIH0]PIHTYP=3 & [M:PIH3]UOM(NOL)="" & [M:PIH3]QTYUOM(NOL)=0
    mkstat=2 : End
  Endif
# Issue 82703 - 2012-10-05 by SR
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
Elsif find([M:PIH3]TYPORI(NOL),1,2,6) & [M:PIH0]PIHTYP=2
  mkstat=2 : End
Endif
End

Subprog AM_NETPRI(VALEUR)
#------------------------------#
# Après modif du prix unitaire #
#------------------------------#
Variable Decimal VALEUR
Local    Shortint NOL : NOL=nolign-1
AMTNOTLIN(NOL)=VALEUR*QTYUOM(NOL)
Call ARRDEV(AMTNOTLIN(NOL),[M:PIH1]CUR) From TRTDIV
# Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
AMTNOTLINCAL(NOL)=AMTNOTLIN(NOL)
If !GIMPORT Affzo [PIH3]AMTNOTLIN(NOL) : Endif
nolign=NOL+1
End

Subprog AM_AMTNOTLIN(VALEUR)
#------------------------------#
# Après modif du montant ligne #
#------------------------------#
Variable Decimal VALEUR
Local    Shortint NOL : NOL=nolign-1
If QTYUOM(NOL)<>0
  NETPRI(NOL)=arr(VALEUR/QTYUOM(NOL),10^-GDECPRI)
  If !GIMPORT Affzo [PIH3]NETPRI(NOL) : Endif
  nolign=NOL+1
Endif
End

