Subprog AM_LINACC10(VALEUR)
Variable Char    VALEUR()
Local    Integer PLAN : PLAN=10 : Gosub AM_LINACCX
End

$AS_LINACCX
#-------------------------------------#
# Avant saisie commune aux 10 comptes #
#-------------------------------------#
If GMODIF<>2  mkstat=2 : Return : Endif
#-----
Local    Shortint NOL : NOL=nolign-1
#----- Si ligne diverse sans article et compte non renseigné -----#
If [M:PIH3]TYPORI(NOL)=5 & [M:PIH3]ITMREF(NOL)="" & VALEUR=""
  #----- Initialiation compte général -----#
  If GTYPLED(PLAN)=GTYPGEN
    Local Char WCOMPTE(GLONGAC)
    Local Char WCODCPT(GLONCAC)
    If [F:BPS]BPSNUM<>[M:PIH0]BPR
      Read [BPS] BPS0=[M:PIH0]BPR : If fstat  Raz [F:BPS] : Endif
    Endif
    Call INIT_COMPTE([M:PIH0]BPR,GSOCIETE,"F",WCODCPT) From CPTSUB
    Read [CAC] CAC0=3;WCODCPT;GCOA(PLAN)
    If !fstat & [F:CAC]ACC(16)<>""
      WCOMPTE=vireblc(ctrans([F:CAC]ACC(16),"xX","00"),2)
      Read [GAC] GAC0=GCOA(PLAN);WCOMPTE
      If !fstat  VALEUR=WCOMPTE : Endif
    Endif
  #----- Initialisation autres comptes -----#
  Else
    Local Char    WCRIBLE(20)
    Local Char    WACCORG(GLONGAC)
    Local Char    WACCDES(GLONGAC)
    Local Integer I, J
    #-----
    For I=1 To PLAN-1
      WACCORG=evalue("[M:PIH3]LINACC"+num$(I)+"(NOL)")
      If WACCORG<>""
        Read [GAC] GAC0=GCOA(I);WACCORG : If fstat  Raz [F:GAC] : Endif
        J=find(GCOA(PLAN),[F:GAC]OTHCOA(0..[F:GAC]COANBR-1))
        If J
          WACCDES=[F:GAC]DEFACC(J-1)
          WCRIBLE=[F:GAC]SCRACC(J-1)
          If WACCDES<>""  Break : Endif
        Endif
      Endif
    Next I
    #-----
    If WACCDES<>""
      Read [GAC] GAC0=GCOA(PLAN);WACCDES
      If !fstat
        VALEUR=WACCDES
        If WACCDES=WCRIBLE  mkstat=2 : Endif
      Endif
    Endif
  Endif
  #-----
Endif
Return

$C_LINACCX
#--------------------------------#
# Contrôle commun aux 10 comptes #
#--------------------------------#
Local    Shortint NOL : NOL=nolign-1
#----- Contrôle compte si ligne type divers et article non renseigné -----#
If [M:PIH3]TYPORI(NOL)=5 & [M:PIH3]ITMREF(NOL)="" & VALEUR=""
  Local Integer WI
  Call RECH_INDACC(1,WI) From TRTX3CPT
  #----- Valeur obligatoire uniquement pour le compte du référentiel général -----#
  If WI=PLAN
    GMESSAGE=mess(10,123,1) : mkstat=1 : Return : # Zone obligatoire !
  Endif
  #-----
Endif
#-----
Call CTRL_ACC(VALEUR,PLAN,GFINRSP,[M:PIH0]ACCDAT,[M:PIH1]CUR,"[M:PIH3]LINACC") From TRTX3CPT
#-----
Return

$AM_LINACCX
#------------------------------------#
# Après modif commune aux 10 comptes #
#------------------------------------#
Local    Shortint I
Local    Shortint NOL : NOL=nolign-1
#-----
# Issue 122292 - 2017-03-29 by MUARN : ne pas faire en import
# Issue 106746 - 2015-04-02 by SR :
If GREP = "C" & !GIMPORT
  For I=PLAN+1 To dim(GCOA)
      If I<=GNBCOA
         Assign "[M:PIH3]LINACC"+num$(I)+"(NOL)" With ""
      Else
         Break
      Endif
  Next
Endif
# End issue 106746
Call APMOD_ACC(VALEUR,PLAN,"[M:PIH3]LINACC") From TRTX3CPT
#-----
If [F:GAC]COA<>GCOA(PLAN) | [F:GAC]ACC<>VALEUR
   Read [GAC] GAC0=GCOA(PLAN);VALEUR : If fstat Raz [F:GAC] : Endif
Endif
If PLAN=1
  [M:PIH3]LINACC1(NOL)=VALEUR
  # Issue 84806 - 2012-10-01 by MUARN : réinitialisation du type après saisie d'un compte
  #If !varinit([M:PIH3]LINPURTYP,NOL)
    Call D_LINPURTYP ([M:PIH3]LINPURTYP(NOL)) From SUBPIH  : # Chargement type d'achat
    Affzo [M:PIH3]LINPURTYP(NOL)
  #Endif
Endif
Assign "[M:PIH3]LINACC"+num$(PLAN)+"(NOL)" With VALEUR
GBIDI2=1 : Gosub PREP_INIT_CCE From SUBPIHB
Return

Subprog D_LINPURTYP(VALEUR)
#----------------------------------------------------------#
# Initialisation du type d'achat en fonction du 1er compte #
#----------------------------------------------------------#
Variable Integer VALEUR
If [F:GAC]COA<>GCOA(1) | [F:GAC]ACC<>[M:PIH3]LINACC1(nolign-1)
   Read [GAC] GAC0=GCOA(1);[M:PIH3]LINACC1(nolign-1) : If fstat Raz [F:GAC] : Endif
Endif
If [F:GAC]VATIPT=5 VALEUR=3 Elsif [F:GAC]VATIPT=4 VALEUR=2 Else VALEUR=1 : Endif
End

Subprog AM_LINPURTYP(VALEUR)
#------------------------------------#
# Après modification du type d'achat #
#------------------------------------#
Variable Integer VALEUR
Local Integer OK
OK=2 : Call OUINON(mess(340,194,1),OK) From GESECRAN
If OK=2
  Local Integer  I
  Local Shortint NOL                  : NOL=nolign-1
  Local Char     SAV_LINACC1(GLONGAC) : SAV_LINACC1=[M:PIH3]LINACC1(NOL)
  Local Char     SAV_LINACC2(GLONGAC) : SAV_LINACC2=[M:PIH3]LINACC2(NOL)
  [M:PIH3]LINPURTYP(NOL)=VALEUR
  Call INIT_COMPTES_LIGNE (NOL) From SUBPIHC
  [M:PIH3]LINPURTYP(NOL)=VALEUR : # Modifié par le Call !
  # Issue 42104 - 2017-06-22 by MUARN : ne pas faire sinon on perd les données de la pièce auto (INIT_COMPTES_LIGNE)
  #If [M:PIH3]LINACC1(NOL)<>SAV_LINACC1
  #  Call AM_LINACC1([M:PIH3]LINACC1(NOL))
  #Endif
  #If [M:PIH3]LINACC2(NOL)<>SAV_LINACC2
  #  Call AM_LINACC2([M:PIH3]LINACC2(NOL))
  #Endif
  # Issue 100635 - 2014-06-05 by SR : Recharger LINPURTYP et afficher
  [M:PIH3]LINPURTYP(NOL)=VALEUR
  If !GIMPORT  Affzo [M:PIH3]LINPURTYP(NOL) : Gosub AFFICH_LINACC : Endif
Endif
End

Subprog AS_LINDSP(VALEUR)
#---------------------------------------#
# Avant saisie de la clé de répartition #
#---------------------------------------#
Variable Char    VALEUR()
If GMODIF<>2  mkstat=2 : End : Endif
Local Shortint NOL : NOL=nolign-1
Local Char     WACC(GLONGAC)
Call RECH_ACC(2,"[M:PIH3]LINACC",NOL,WACC) From TRTX3CPT
If WACC=""    mkstat=2 : End : Endif
End

Subprog AM_LINDSP(VALEUR)
#---------------------------------------------#
# Après modification de la clé de répartition #
#---------------------------------------------#
Variable Char    VALEUR()
Local Shortint I
Local Shortint NOL : NOL=nolign-1
[M:PIH3]LINDSP(NOL)=VALEUR
GBIDI2=1 : Gosub PREP_INIT_CCE From SUBPIHB
End

