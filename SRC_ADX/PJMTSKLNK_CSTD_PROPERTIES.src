#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe PJMTSKLNK
# Issue X3-26991/X3-43920 - 2017-06-30 by FGR/TEJAC
#######################################################################################
$TASLNKTYP
  Case [L]ARULE
    When "INIT"      : Gosub TASLNKTYP_INIT
  Endcase
Return

$TASLNKTYP_INIT
  this.TASLNKTYP = 1
Return

#######################################################################################
$TASLNKCSTR
  Case [L]ARULE
    When "INIT"      : Gosub TASLNKCSTR_INIT
  Endcase
Return

$TASLNKCSTR_INIT
  this.TASLNKCSTR = 1
Return

#######################################################################################
$PIMOPPTASLNK
  # Issue X3-26991/X3-43920 - 2017-06-30 by FGR/TEJAC
  Case [L]ARULE
    When "CONTROL"   : Gosub PIMOPPTASLNK_CONTROL
  Endcase
Return

$PIMOPPTASLNK_CONTROL
Local Char PROJECT(GLONOPP)
Local Char BUDGET(GLONPBU)
Local Char TASK(GLONTAC)
Local Integer IRET
Local Integer ILINE

  # Issue X3-26991/X3-43920 - 2017-06-30 by FGR/TEJAC
  If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and this.PIMOPPTASLNK <> this.snapshot.PIMOPPTASLNK) Then
    # To do only for a new line or a line where PIMOPPTASLNK has been updated
    IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(this.ACTX, this.PIMOPPTASLNK, PROJECT, BUDGET, TASK)
    If IRET >= [V]CST_AERROR Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMOPPTASLNK", mess(83,123,1) - this.PIMOPPTASLNK, [V]CST_AERROR))
    Else
      If TASK = AVOID.ACHAR Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMOPPTASLNK", mess(83,123,1) - this.PIMOPPTASLNK, [V]CST_AERROR))
      Else
        If this.OPPNUM = PROJECT and this.TASCOD = TASK Then
          # this is an error only if the link is on the current project
          [L]ASTATUS = fmet this.SETERROR("PIMOPPTASLNK", func AFNC.MES1(mess(583,2260,1), TASK), [V]CST_AERROR)
        Endif
      Endif
    Endif
  Endif
Return

