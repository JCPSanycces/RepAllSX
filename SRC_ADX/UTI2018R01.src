#<AdxTL>@(#)0.0.0.0 $Revision$ 
##########################################################################
# UTI2018R01 UTI process for 2017R7 of X3 (exception - ARDET 05-01-2018 -  Jira X3-70734)
# ---------------------------------------------------------------------- #
#      moulinettes à passer en fin du patch de la 2018R1 - passage de 2017R6 vers 2018R01 via 2017R7
#
#      correction utility to be done at the end of the patch - move from 2017R6 to 2018R01 via 2017R7
#
##########################################################################
# to be able to execute on scm vm (internal)
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTI2018R01 Processing") From LECFIC
  Call PATCH(nomap)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
# -----------------------------------------------------------------    #
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#-------------------------------------------------------------#
# le test du dossier mère doit etre fait dans chaque uti.. pas ici
# Test of the mother folder must be done in each utixxx.. not HERE
#-------------------------------------------------------------#
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTI2018R01 (APPLI)

End

###################################################
Subprog EXE_UTI2018R01(LDOSSIER)
Value Char LDOSSIER

Call ECR_TRACE("START : UTI2018R01-Phase for folder "+LDOSSIER,0) From GESECRAN

#-------------------------------------------------------------#
# implementer ici l'appel de chaque uti necessaire
# le test du dossier mère doit etre fait dans chaque uti..
#
# implement here the call of each necessary uti
# Test of the mother folder must be done in each utixxx..
#-------------------------------------------------------------#
#Call PATCH(LDOSSIER) From xxxxxx

###### Jira X3-70734 beginning R7   ########

# Issue 59761 - 2017-10-25 by MAE : Validation of CONSSLO inquiry
If [F:ADS]MODULE(6) = 2 Then
  Call PATCH(LDOSSIER) From CNSSLOSTD
Endif

# Issue X3-63292 - 2017-11-23 by SR : Purchase Order Transactions
If [F:ADS]MODULE(5) = 2
  Call PATCH(LDOSSIER) From SUBPTC
Endif

  If [F:ADS]MODULE(8) = 2 Then
    Call PATCH(LDOSSIER) From UTICRM17001        # Issue X3-57419 - 2017-10-26 by FGR
    Call PATCH(LDOSSIER) From UTIPJM023          # Issue X3-63434 - 2017-11-09 by FGR
  Endif

# X3-59904 Validation CONSCSD and CONSSCF inquiries  (JUCON 20/11/2017)
If [F:ADS]MODULE(4) = 2 Then
  Call PATCH(LDOSSIER) From CNSCSDSTD
  Call PATCH(LDOSSIER) From CNSCSFSTD
Endif

Call PATCH(LDOSSIER) From UTIVEN59635        #X3-59635 initializing the metcorcod field in sales invoice transactions
# Call PATCH(LDOSSIER) From SUBSLI             # Issue X3-59635 - 2017-10-26 by ADMIN : Need to revalidate the transactions X3.TRT/SUBSIHA1$adx (1844) Error 6 : Variable Non-existent METCOR
# Call PATCH(LDOSSIER) From SUBSLA             # Issue X3-59635 - 2017-10-26 by ADMIN : Need to revalidate the transactions X3.TRT/SUBSIHA1$adx (1844) Error 6 : Variable Non-existent METCOR
Call PATCH(LDOSSIER) From UTIMAJGSPFLG      :#X3-58867 Set the new field [TCY]GSPFLG to 1



# Issue X3-59287 - 2017-11-08 by FHA : ST1 ST2 ST3 records replicated in GDD as STT1 STT2 STT3
If [F:ADS]MODULE(1) = 2 Then
  Call PATCH(LDOSSIER) From UTICPT94
  Call PATCH(LDOSSIER) From SUBGDE    # Journal Entry Transaction validation
Endif

Call PATCHR7(LDOSSIER) From UTIPIT             #X3-64010 Modify point in time valuation to use ACCDAT instead of IPTDAT

######### end R7 #####

Call PATCH(LDOSSIER) From ACHGCOL   # Issue X3-61074 - 2017-12-06 by CCC : Change color of visual processes

# Issue X3-63491 - 20171214 by LD : Wrong amount in sales invoice elements in amounts with a different currency
# Invoices/Credit notes Transactions validation
If [F:ADS]MODULE(4) = 2
    Call PATCH(LDOSSIER) From SUBSLI
    Call PATCH(LDOSSIER) From SUBSLA
Endif
# End issue X3-63491

  If [F:ADS]MODULE(8) = 2 Then
    Call PATCH(LDOSSIER) From UTIPJM017              # Issue X3-26714 - 2017-04-07 by ALMON/FGR
    Call PATCH(LDOSSIER) From UTIPJM022              # Issue X3-26714 - 2017-07-05 by FGR
    Call PATCH(LDOSSIER) From UTIPJM201801001        # Issue X3-55055 - 2017-12-11 by FGR
    Call PATCH(LDOSSIER) From UTICRM201801001        # Issue X3-67352 - 2017-12-11 by FGR
  Endif

# Issue X3-50816 - 2017-22-12 by RBA : Notification inquiries validation
If [F:ADS]MODULE(4)=2
  Call PATCH(LDOSSIER) From CNSEDNSTD
Endif

# Issue X3-50816 - 2017-22-12 by RBA : Deliveries transaction validation
If [F:ADS]MODULE(4)=2
  Call PATCH(LDOSSIER) From SUBSLD
Endif

#JASMI - 2018-01-09 - X3-68587 - START
If [F:ADS]MODULE(14)<>2
  Call PATCH(LDOSSIER) From UTIHRM003
Endif
#JASMI - 2018-01-09 - X3-68587 - END

#FRLAA - 2018-01-10 - X3-69420 - START
#If [F:ADS]MODULE(14)=2 # X3 and X3 People
  Call PATCH(LDOSSIER) From UTIHRM004
#Endif
#FRLAA - 2018-01-10 - X3-69420 - END

Call ECR_TRACE("END : UTI2018R01-Phase for folder "+LDOSSIER,0) From GESECRAN
#----- Fin du traitement -----#
$FIN_UTI2018R01
End

