#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation script: CCMCHGREQ_RSTD, Change Request - Header
###############################################################################
# Issue 110210/8 - 2015-12-14 by JUSYN : New labels for supervisor update
# Issue 109094/20 - 2016-01-13 by BAKHA : Enable/disable new field NCSCATEGORY
# Issue 114035/3/4 - 2016-02-11 by BAKHA : Enable/disable new fields NCSROOCAU and NCSPROCAU

$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"            : Gosub ACTIVATE_FIELDS
        When "AQUERY_TRANS_AFTER"     : Gosub HIDE_CLOSEDSTATE
      Endcase
    When "NCSREC"
      Case [L]AEVENT
        When "AINIT"        : Gosub ACTIVATE_MAJOR_VERSION : Gosub ACTIVATE_MINOR_VERSION
        When "AREAD_AFTER"
          Gosub ACTIVATE_MAJOR_VERSION
          Gosub ACTIVATE_MINOR_VERSION
          Gosub DEACTIVATE_CRID
      Endcase
  Endcase
Return

$METHODS
  Case [L]AMETHOD
    When "IS_USER_PLANNER"        : Gosub IS_USER_PLANNER
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
    When "NCSREC.CRID"
      Case [L]ARULE
        When "INIT"
          Gosub DEACTIVATE_CRID
      Endcase
    When "NCSREC.CRSTATUS"
      Case [L]ARULE
        When "INIT"
          Gosub ACTIVATE_CHANGE_STATUS
        When "PROPAGATE"
          Gosub ACTIVATE_REJECTION
          Gosub ACTIVATE_PLANNER
          Gosub ACTIVATE_PRODUCT
      Endcase
    When "NCSREC.NCSMANAGER"
      Case [L]ARULE
        When "INIT"
          Gosub ACTIVATE_CHANGE_MANAGER
          Gosub ACTIVATE_APPROVER
      Endcase
    When "NCSREC.NCSPLANNER"
      Case [L]ARULE
        When "INIT"
          Gosub ACTIVATE_PLANNER
      Endcase
    When "NCSREC.PRODUCT"
      Case [L]ARULE
        When "PROPAGATE"
          Gosub RESET_VERSION
          Gosub ACTIVATE_UNKNOWN_PRODUCT
          Gosub ACTIVATE_MAJOR_VERSION
          Gosub VALIDATE_ECCVALMAJ
          Gosub VALIDATE_ECCVALMIN
      Endcase
    When "NCSREC.REJECTCOD"
      Case [L]ARULE
        When "INIT"
          Gosub ACTIVATE_REJECTION
      Endcase
    When "NCSREC.ECCVALMAJ"
      Case [L]ARULE
        When "PROPAGATE"
          Gosub VALIDATE_ECCVALMAJ
          Gosub ACTIVATE_MINOR_VERSION
      Endcase
    When "NCSREC.ECCVALMIN"
      Case [L]ARULE
        When "PROPAGATE"
          Gosub VALIDATE_ECCVALMIN
      Endcase
  Endcase
Return
###############################################################################

# --------------------------------------------------
# Custom Method
#
# Is the logged-in user a NCS PLANNER ?
# Return true or false.

$IS_USER_PLANNER
  Local Char NCSPLANNER(30)

  Call PARAMUTIL("NCSPLANNER", NCSPLANNER, this.ACTX.USER, "") From SUBAUS
  If (NCSPLANNER = "2")
    ARET_VALUE = CST_ATRUE
  Else
    ARET_VALUE = CST_AFALSE
  Endif

Return


#--------------------------------------------------
#To hide the default value '-Select-' in the query facet.
$HIDE_CLOSEDSTATE

If this.NCSREC.CRSTATUS <> 7
   this.NCSREC.CLOSEDST = AVOID.ALIB
Endif

Return

# --------------------------------------------------
# Enable / disable fields at a class level.
$ACTIVATE_FIELDS
  Local Integer I
  Local Integer LOCSTATUS

  LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("CRID", "$isDisabled", "true")

  # Change manager (NCSMANAGER)
  If ((this.NCSREC.CRSTATUS <> 7) and (this.NCSREC.NCSMANAGER = this.ACTX.USER or fmet this.IS_ADMIN_USER()))
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("NCSMANAGER", "$isDisabled", "false")
  Else
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("NCSMANAGER", "$isDisabled", "true")
  Endif

  # disable or enable fields depending on who can amend

  If (this.NCSREC.CRSTATUS = 7 or (this.ACTX.USER <> this.NCSREC.NCSMANAGER and this.ACTX.USER <> this.NCSREC.CREUSR))
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("TITLE",    "$isDisabled", "true")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("CRDESC",   "$isDisabled", "true")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("SEVERITY", "$isDisabled", "true")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("IMPACT",   "$isDisabled", "true")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("NCSREASON",   "$isDisabled", "true")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("NCSCATEGORY",   "$isDisabled", "true")   # Issue 109094/20
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("NCSROOCAU",   "$isDisabled", "true")   # Issue 114035/3/4
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("NCSPROCAU",   "$isDisabled", "true")   # Issue 114035/3/4
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("DATEREQ",  "$isDisabled", "true")
  Else
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("TITLE",    "$isDisabled", "false")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("CRDESC",   "$isDisabled", "false")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("SEVERITY", "$isDisabled", "false")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("IMPACT",   "$isDisabled", "false")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("NCSREASON",   "$isDisabled", "false")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("NCSCATEGORY",   "$isDisabled", "false") # Issue 109094/20
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("NCSROOCAU",   "$isDisabled", "false")   # Issue 114035/3/4
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("NCSPROCAU",   "$isDisabled", "false")   # Issue 114035/3/4
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("DATEREQ",  "$isDisabled", "false")
  Endif

  # Unknown product (PRODDESC)
  If (this.NCSREC.PRODUCT = "")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("PRODDESC", "$isDisabled", "false")
  Else
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("PRODDESC", "$isDisabled", "true")
  Endif

  # Reason for rejection (REJECTCOD)
  # Further information (REJDESC)
  If this.NCSREC.CRSTATUS = 3  # 3 = Rejected
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("REJECTCOD", "$isDisabled", "false")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("REJECTCOD", "$isMandatory", "true")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("REJDESC", "$isDisabled", "false")
  Else
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("REJECTCOD", "$isDisabled", "true")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("REJECTCOD", "$isMandatory", "false")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("REJDESC", "$isDisabled", "true")
  Endif

  # Change status (CRSTATUS)
  If (this.NCSREC.NCSMANAGER <> this.ACTX.USER)
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("CRSTATUS", "$isDisabled", "true")
  Else
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("CRSTATUS", "$isDisabled", "false")
  Endif

  # Product (PRODUCT)

  #If the status is in [new] then the product is enabled or otherwise it is disabled.
  If (this.NCSREC.CRSTATUS = 1 and (this.ACTX.USER = this.NCSREC.NCSMANAGER or this.ACTX.USER = this.NCSREC.CREUSR))
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("PRODUCT", "$isDisabled", "false")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("SITE",     "$isDisabled", "false")
  Else
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("PRODUCT", "$isDisabled", "true")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("SITE",     "$isDisabled", "true")
  Endif

  # CLOSEDSTATE flag (CLOSEDSTATE)
  If this.NCSREC.CRSTATUS = 7  # 7 = Closed
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("CLOSEDST", "$isHidden", "false")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("CLOSEDATE","$isHidden", "false")
  Else
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("CLOSEDST", "$isHidden", "true")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("CLOSEDATE","$isHidden", "true")
  Endif

  # Planner (NCSPLANNER)
  If ((this.NCSREC.CRSTATUS = 1 or this.NCSREC.CRSTATUS = 2) and (this.NCSREC.NCSMANAGER = this.ACTX.USER or fmet this.IS_USER_PLANNER()))
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("NCSPLANNER", "$isMandatory", "false")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("NCSPLANNER", "$isDisabled", "false")
  Elsif ((this.NCSREC.CRSTATUS = 4 or this.NCSREC.CRSTATUS = 5) and (this.NCSREC.NCSMANAGER = this.ACTX.USER or fmet this.IS_USER_PLANNER()))
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("NCSPLANNER", "$isMandatory", "true")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("NCSPLANNER", "$isDisabled", "false")
  Else
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("NCSPLANNER", "$isMandatory", "false")
    LOCSTATUS = fmet this.NCSREC.ASETATTRIBUTE("NCSPLANNER", "$isDisabled", "true")
  Endif

  # if change request New, disable impact analysis link
  If (this.NCSREC.CRSTATUS = 1 or this.NCSREC.IMPACTANAL <> 2)
    LOCSTATUS = fmet this.ASETLINKDISABLE("CCMIMPACT",[V]CST_AFFLNKREC)
  Endif

  # if change request New or In-review, disable Plan link
  If (this.NCSREC.CRSTATUS < 3 or this.NCSREC.IMPACTANAL <> 2)
    LOCSTATUS = fmet this.ASETLINKDISABLE("CCMPLAN",[V]CST_AFFLNKREC)
  Else
    # check Plan exists, if not then disable link
    Local Instance PLAN_HEADER Using C_CCMPLANH
    PLAN_HEADER = NewInstance C_CCMPLANH AllocGroup null
    LOCSTATUS = fmet PLAN_HEADER.AREAD(this.NCSREC.CRID)
    If (LOCSTATUS <> CST_AOK) # if the Plan does not exist then create the Plan ...
      LOCSTATUS = fmet this.ASETLINKDISABLE("CCMPLAN",[V]CST_AFFLNKREC)
    Endif
    FreeGroup PLAN_HEADER
  Endif

  # if Change request Closed, then disable edit link
  If (this.NCSREC.CRSTATUS = 7)
    LOCSTATUS = fmet this.ASETLINKDISABLE("AEDIT",[V]CST_AFFLNKREC)
  Endif

  If (this.NCSREC.CRSTATUS = 2 and this.NCSREC.IMPACTANAL = 1)
    LOCSTATUS = fmet this.NCSREC.ASETERROR("", mess(68,2038,1), CST_AWARNING)
  Endif

# Issue 109093/3 - 2015-12-02 by JUSYN : Word link only available for QA manager when status >= 4 (4 = plan) and not already closed (7 = closed).
  If ((this.NCSREC.NCSMANAGER = this.ACTX.USER) and (this.NCSREC.CRSTATUS > 3 ) and (this.NCSREC.CRSTATUS < 7 ))
    LOCSTATUS = fmet this.ASETLINKENABLE("NCSWORD",[V]CST_AFFLNKREC)
  Else
    LOCSTATUS = fmet this.ASETLINKDISABLE("NCSWORD",[V]CST_AFFLNKREC)
  Endif

# Issue 109095/3 - 2015-12-03 by JUSYN : NCS-CCM integration. Create a change request from NCS, but only the QA-Manager and only from status plan to implement
#                                                             Only one creation for a NCS is allowed
  If ((this.NCSREC.NCSMANAGER = this.ACTX.USER) and (this.NCSREC.CRSTATUS > 3 ) and (this.NCSREC.CRSTATUS < 7 ) and (this.NCSREC.NCSCCMID = "" or this.NCSREC.NCSCCMID = " "))
    LOCSTATUS = fmet this.ASETLINKENABLE("CREATECR",[V]CST_AFFLNKREC)
  Else
    LOCSTATUS = fmet this.ASETLINKDISABLE("CREATECR",[V]CST_AFFLNKREC)
  Endif

Return

# --------------------------------------------------
#
$VALIDATE_ECCVALMAJ

  Local Integer R_V

  Local Char AVALUE(30) : AVALUE = ""

  If (fmet this.IS_PRODUCT_VERSION_MANAGED(this.PRODUCT) > 1  and this.ECCVALMAJ <> "")
    ASTATUS = func WMTYPCCMECS.ACTRLREF(this, "ECCVALMAJ", AVALUE, this.PRODUCT, this.ECCVALMAJ, "")
  Endif

Return

# --------------------------------------------------
#
$VALIDATE_ECCVALMIN

  Local Integer R_V

  Local Char AVALUE(30) : AVALUE = ""

  If (fmet this.IS_PRODUCT_VERSION_MANAGED(this.PRODUCT) = 3  and this.ECCVALMAJ <> "" and this.ECCVALMIN <> "")
    ASTATUS = func WMTYPCCMEVL.ACTRLREF(this, "ECCVALMIN", AVALUE, this.PRODUCT, this.ECCVALMAJ, this.ECCVALMIN, 4, "")
  Endif

Return

# ------------------------------------------------------------
# Subroutine: RESET_VERSION
#
# If the Product property value changes and then blank the Major/Minor Version.
$RESET_VERSION

    this.ECCVALMAJ = ""
    this.ECCVALMIN = ""

Return


# --------------------------------------------------
# Disable Request ID (CRID).
$DEACTIVATE_CRID

  Local Integer LOCSTATUS
  LOCSTATUS = fmet this.ASETATTRIBUTE("CRID", "$isDisabled", "true")
Return

# --------------------------------------------------
# Enable / disable change status (CRSTATUS).
$ACTIVATE_CHANGE_STATUS
  Local Integer LOCSTATUS

  If (this.NCSMANAGER <> this.ACTX.USER)
      LOCSTATUS = fmet this.ASETATTRIBUTE("CRSTATUS", "$isDisabled", "true")
    Else
      LOCSTATUS = fmet this.ASETATTRIBUTE("CRSTATUS", "$isDisabled", "false")
    Endif

Return

# --------------------------------------------------
# Enable / disable change manager (NCSMANAGER).
$ACTIVATE_CHANGE_MANAGER
  Local Integer LOCSTATUS

  If (this.NCSMANAGER = this.ACTX.USER or fmet this.APARENT.IS_ADMIN_USER())
    LOCSTATUS = fmet this.ASETATTRIBUTE("NCSMANAGER", "$isDisabled", "false")
  Else
    LOCSTATUS = fmet this.ASETATTRIBUTE("NCSMANAGER", "$isDisabled", "true")
  Endif

Return

# --------------------------------------------------
# Enable / disable unknown product (PRODDESC).
$ACTIVATE_UNKNOWN_PRODUCT
  Local Integer LOCSTATUS

  If (this.PRODUCT = "")
    LOCSTATUS = fmet this.ASETATTRIBUTE("PRODDESC", "$isDisabled", "false")
  Else
    LOCSTATUS = fmet this.ASETATTRIBUTE("PRODDESC", "$isDisabled", "true")
  Endif

Return

# --------------------------------------------------
# Enable / disable reason for rejection (REJECTCOD) and
# further information (REJDESC).
$ACTIVATE_REJECTION
  Local Integer LOCSTATUS

  If (this.CRSTATUS = 3)  # 3 = Rejected
    LOCSTATUS = fmet this.ASETATTRIBUTE("REJECTCOD", "$isDisabled", "false")
    LOCSTATUS = fmet this.ASETATTRIBUTE("REJECTCOD", "$isMandatory", "true")
    LOCSTATUS = fmet this.ASETATTRIBUTE("REJDESC", "$isDisabled", "false")
    this.REJECTCOD = this.snapshot.REJECTCOD
  Else
    LOCSTATUS = fmet this.ASETATTRIBUTE("REJECTCOD", "$isDisabled", "true")
    LOCSTATUS = fmet this.ASETATTRIBUTE("REJECTCOD", "$isMandatory", "false")
    LOCSTATUS = fmet this.ASETATTRIBUTE("REJDESC", "$isDisabled", "true")
  Endif

Return

#--------------------------------------------------------
# Enable / disable Approver code (NCSAPPUSR),
# Approver name(USERNAM),
# Approver status (APPRSTAT) and
# Approver reason(APPRREASON)
$ACTIVATE_APPROVER
  Local Integer LOCSTATUS
  Local Integer I

    If (this.NCSMANAGER = this.ACTX.USER)
      For I = 1 To maxtab(this.NCSAPPROVER)
        LOCSTATUS = fmet this.NCSAPPROVER(I).ASETATTRIBUTE("NCSAPPUSR", "$isDisabled", "false")
        LOCSTATUS = fmet this.NCSAPPROVER(I).ASETATTRIBUTE("NCSAPPUSR", "$isMandatory", "true")
        LOCSTATUS = fmet this.NCSAPPROVER(I).ASETATTRIBUTE("USERNAM", "$isDisabled", "false")
        LOCSTATUS = fmet this.NCSAPPROVER(I).ASETATTRIBUTE("APPRSTAT", "$isDisabled", "false")
        LOCSTATUS = fmet this.NCSAPPROVER(I).ASETATTRIBUTE("APPRREASON", "$isDisabled", "false")
      Next I
    Else
      For I = 1 To maxtab(this.NCSAPPROVER)
        LOCSTATUS = fmet this.NCSAPPROVER(I).ASETATTRIBUTE("NCSAPPUSR", "$isDisabled", "true")
        LOCSTATUS = fmet this.NCSAPPROVER(I).ASETATTRIBUTE("NCSAPPUSR", "$isMandatory", "false")
        LOCSTATUS = fmet this.NCSAPPROVER(I).ASETATTRIBUTE("USERNAM", "$isDisabled", "true")

        # Enable the status and reason for logged-in approvers
        If(this.ACTX.USER <> this.NCSAPPROVER(I).NCSAPPUSR)
          LOCSTATUS = fmet this.NCSAPPROVER(I).ASETATTRIBUTE("APPRSTAT", "$isDisabled", "true")
          LOCSTATUS = fmet this.NCSAPPROVER(I).ASETATTRIBUTE("APPRREASON", "$isDisabled", "true")
        Endif
      Next I
    Endif

Return

#--------------------------------------------------------
# Enable / disable Planner (NCSPLANNER).
$ACTIVATE_PLANNER
  Local Integer LOCSTATUS

  If ((this.CRSTATUS = 1 or this.CRSTATUS = 2) and (this.NCSMANAGER = this.ACTX.USER or fmet this.APARENT.IS_USER_PLANNER()))
    LOCSTATUS = fmet this.ASETATTRIBUTE("NCSPLANNER", "$isMandatory", "false")
    LOCSTATUS = fmet this.ASETATTRIBUTE("NCSPLANNER", "$isDisabled", "false")
  Elsif ((this.CRSTATUS = 4 or this.CRSTATUS = 5) and (this.NCSMANAGER = this.ACTX.USER or fmet this.APARENT.IS_USER_PLANNER()))
    LOCSTATUS = fmet this.ASETATTRIBUTE("NCSPLANNER", "$isMandatory", "true")
    LOCSTATUS = fmet this.ASETATTRIBUTE("NCSPLANNER", "$isDisabled", "false")
  Else
    LOCSTATUS = fmet this.ASETATTRIBUTE("NCSPLANNER", "$isMandatory", "false")
    LOCSTATUS = fmet this.ASETATTRIBUTE("NCSPLANNER", "$isDisabled", "true")
  Endif

Return

#-----------------------------------------------------------
# Activate the product field based on CR status
$ACTIVATE_PRODUCT
  Local Integer LOCSTATUS

  If this.CRSTATUS = 1
     LOCSTATUS = fmet this.ASETATTRIBUTE("PRODUCT", "$isDisabled", "false")
  Elsif this.CRSTATUS = 2 and this.NCSMANAGER = this.ACTX.USER and this.PRODUCT = ""
     LOCSTATUS = fmet this.ASETATTRIBUTE("PRODUCT", "$isDisabled", "false")
  Else
     LOCSTATUS = fmet this.ASETATTRIBUTE("PRODUCT", "$isDisabled", "true")
  Endif
Return

#-----------------------------------------------------------
# Activate Major Version (ECCVALMAJ) dependant on Product (PRODUCT) ...
$ACTIVATE_MAJOR_VERSION

  Local Integer LOCSTATUS

  LOCSTATUS = fmet this.ASETATTRIBUTE("ECCVALMAJ", "$isDisabled", "true")
  LOCSTATUS = fmet this.ASETATTRIBUTE("ECCVALMAJ", "$isMandatory", "false")
  If (this.CRSTATUS = 1 and
&     fmet this.IS_PRODUCT_VERSION_MANAGED(this.PRODUCT) > 1)
    LOCSTATUS = fmet this.ASETATTRIBUTE("ECCVALMAJ", "$isDisabled", "false")
  Endif

Return

#-----------------------------------------------------------
# Activate Minor Version (ECCVALMIN) dependant on Product (PRODUCT) ...
$ACTIVATE_MINOR_VERSION

  Local Integer LOCSTATUS

  LOCSTATUS = fmet this.ASETATTRIBUTE("ECCVALMIN", "$isDisabled", "true")
  LOCSTATUS = fmet this.ASETATTRIBUTE("ECCVALMIN", "$isMandatory", "false")
  If (this.CRSTATUS = 1 and
&     fmet this.IS_PRODUCT_VERSION_MANAGED(this.PRODUCT) = 3)
    LOCSTATUS = fmet this.ASETATTRIBUTE("ECCVALMIN", "$isDisabled", "false")
  Endif

Return

