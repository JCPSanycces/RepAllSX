#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque GFP1
Raz GPILOBJ
Call OBJET("GFP",GBIDC1,GBIDC2) From GOBJET
End

# Issue X3-70924 - 2018-01-15 - MDJ : Replace the call to VALID from VALMSK by a call to VALIDFULL from VALMSK

$ACTION
Case ACTION
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When "OUVRE"      : Gosub OUVRE
 When "LIENS"      : Gosub LIENS
 When "RAZCRE"     : Gosub INIT_CHAMP
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "APRES_CRE"  : Gosub VALID
 When "APRES_MOD"  : Gosub VALID
 When "ANNULE"     : Gosub ANNULE
 When "AP_CHANGE"  : Gosub CHANGE
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
Endcase
Return

$OUVRE
Local Char LIBEL(30) , MASKREF(10), CONSCOD(10)
Local Integer ER
Return

$INICRE
$INIMOD
If dim([F:GFP]DES)>0
 [F:GFP]DES = [M]DESTRA
Endif
Return

$SETBOUT
If !CLECUR or REP<>"" or !VERROU
 Call VIREBOUT(CHAINE,"VUO") From GOBJET
Endif
If GBROWS
  Call VIREBOUT(CHAINE,"OB") From GOBJET : # Visu, Visu Web
Endif
If CLECUR1="STD"
 Call VIREBOUT(CHAINE,"A#") From GOBJET
Endif
Return

$EXEBOUT
Case REP
 When "V" : # Validation
  Gosub VALID
 When "O" : # Visualisation
  Call VISUM("WMDFUP"+[M]COD) From SUBAMK
 When "B"
  Call VISUMWEB("WMDFUP"+[M]COD) From SUBAMK
Endcase
Return

$LIENS
[M]NBRFLD = 0
Call LECTEXTRA([M]DESTRA,"GFUPSCR","DESTRA",[M]COD,"") From ATEXTRA
Gosub CHARGE_CHAMP
For NOL=0 To [F:GFP]NBRFLD-1
 K = find([F:GFP]FLD(NOL),[M]FLD(0..[M]NBRFLD-1))
 If K
  [M]DAC(K-1) = [F:GFP]DAC(NOL)
  [M]SAI(K-1) = [F:GFP]SAI(NOL)
 Endif
Next NOL
Gosub TRI
Return

$TRI
For NOL=0 To [M]NBRFLD-1
 If [M]DAC(NOL)=0 : [M]DAC(NOL) = 9999 : Endif
Next NOL
Sorta [M]NBRFLD [M]NBRFLD Order By [M]DAC(indice)
For NOL=0 To [M]NBRFLD-1
 If [M]DAC(NOL)=9999 : [M]DAC(NOL) = 0 : Endif
Next NOL
Return

$LIBEL
If [F:AMZ]INTEVAL<>""
 Onerrgo ERRLIB
 ER = 0
 [M]INTIT(NOL) = evalue([F:AMZ]INTEVAL)
 If ER
  [M]INTIT(NOL) = [F:AMZ]INTEVAL
 Endif
 Onerrgo
Else
 Call TEXTE([F:AMZ]INTIT,LIBEL) From OBJDIV
 [M]INTIT(NOL) = LIBEL
Endif
Return

$ERRLIB
ER = errn
Resume

$CHARGE_CHAMP
Gosub MASKREF
For [AMZ]CODZON Where CODMSK=MASKREF & NUMBLOC=2 & CODZON<>"SEL"
 OK = 1
 If [F:AMZ]CODTYP="ABS" or [F:AMZ]SAIAFF=3 or [F:AMZ]SAIAFF=4
  OK = 0
 Endif
 If [F:AMZ]CODACT<>""
  Read [ACV]CODACT = [F:AMZ]CODACT
  If fstat | [F:ACV]FLACT<>2 : OK = 0 : Endif
 Endif
 If OK & !find([F:AMZ]CODZON,[M]FLD(0..[M]NBRFLD-1))
  NOL = [M]NBRFLD
  [M]FLD(NOL)    = [F:AMZ]CODZON
  [M]SAIREF(NOL) = [F:AMZ]SAIAFF
  Gosub LIBEL
  [M]NBRFLD += 1
 Endif
Next
Return

$MASKREF
Local Char MASKREF(10) , WINREF(10)
MASKREF = "DETFUP"
WINREF  = "DETFUP"
Return

$INIT_CHAMP
Gosub CHARGE_CHAMP
For NOL=0 To [M]NBRFLD-1
 [M]SAI(NOL) = 1
Next
Gosub TRI
Affzo NBRFLD,FLD,INTIT,DAC,SAI
OK = 1
Return

$ANNULE
#Annulation des textes traduisibles
Call SUPTEXTRA("GFUPSCR","DESTRA",[M]COD,"") From ATEXTRA
# Annulation des écrans
Local Char MASQUE1(10) , NOMWIN(10)
MASQUE1 = "WMDFUP"+CODE
NOMWIN  = "WDFUP"+CODE
Call DELMSK(MASQUE1,nomap) From MSKDIV
If GOK<1 : Return : Endif
Call DELWIN(NOMWIN,nomap) From MSKDIV
If GOK<1 : Return : Endif
Return

$CHANGE
# Annulation ancien écran
Local Char MASQUE1(10) , NOMWIN(10)
MASQUE1 = "WMDFUP"+OCODE
Call TR_DELMSK(MASQUE1,nomap) From MSKDIV
NOMWIN  = "WDFUP"+OCODE
Call TR_DELWIN(NOMWIN,nomap) From MSKDIV
# Validation du nouveau
Read [GFP]GFP0 = NCODE
Call VALIDATION(NCODE,nomap)
Return

$AP_CHANGE
Call CHGTEXTRA("GFUPSCR","DESTRA",[M]COD,"",NCODE,"") From ATEXTRA
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GFUPSCR","DESTRA",CLECUR1,"","GFUPSCR","DESTRA",[M]COD,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESTRA,"GFUPSCR","DESTRA",[M]COD,"") From ATEXTRA
Return


$VALID
If !GIMPORT
 Call VALIDATION([F:GFP]COD,nomap)
Endif
Return

######################################################
Subprog PATCH(APPLI)
Value Char APPLI()

If APPLI="X3" : End : Endif

If filinfo(filpath("FIL","FUP","fde",APPLI),0)<0 : End : Endif

Onerrgo CHUT From CONTROLE
Local File =APPLI+".ADOVAL" [ADW]
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Read [ADW]ADW0 = "";"";"MODULE1"
If fstat=0 & ([F:ADW]VALEUR="" | mid$([F:ADW]VALEUR,3,1)="2") : # si module Tiers
 Call GENDOS(APPLI)
Endif
End

Subprog GENDOS(APPLI)
Value Char APPLI()

Local File =APPLI+".AMSK"    [AMK] , =APPLI+".AMSK"    [AMK2]
Local File =APPLI+".AMSKZON" [AMZ] , =APPLI+".AMSKZON" [AMZ2]
Local File =APPLI+".AMSKACT" [AMA] , =APPLI+".AMSKACT" [AMA2]
Local File =APPLI+".AMSKPAR" [AMP] , =APPLI+".AMSKPAR" [AMP2]
Local File =APPLI+".GFUPSCR" [GFP]
Local File =APPLI+".AWINDOW" [AWI] , =APPLI+".AWINDOW" [AWI2]
Local File =APPLI+".AWINPAR" [AWP] , =APPLI+".AWINPAR" [AWP2]
Local File =APPLI+".AWINBRO" [AWB] , =APPLI+".AWINBRO" [AWB2]
Local File =APPLI+".AWINBOUT"[AWT] , =APPLI+".AWINBOUT" [AWT2]
Local File =APPLI+".AOBJET"  [AOB] , =APPLI+".AOBJTAB" [AOT] , =APPLI+".AOBJLST" [AOL]

For [GFP] Where ENAFLG=2
 If GTRACE<>"" : Call ECR_TRACE([F:GFP]COD,0) From GESECRAN : Endif
 Call VALIDATION([F:GFP]COD,APPLI)
Next
End

Subprog VALIDATION(COD,APPLI)
Value Char COD
Value Char APPLI
Local Char    MASKDES(10) , MASKREF(10) , NOMWIN(10) , SAVLAN(3)
Local Integer OK , NOL , RANG, NCOL , LANCUR

Local Integer  O_X1
Local Integer  O_Y1
Local Integer  O_X2
Local Integer  O_Y2_0
Local Integer  O_Y2_1
Local Integer  O_TITBLOC
Local Integer  O_TYPBLOC
Local Integer  O_RANG
Local Integer  O_LNGLIB
Local Char     O_ACTBLOC(5)
Local Integer  O_NBLIGT
Local Char     O_OPTION(20)
Local Char     O_BASPAG(20)
Local Integer  O_DETBLC

If clalev([F:AMK])=0  : Local File AMSK    [AMK]  : Endif
If clalev([F:AMZ])=0  : Local File AMSKZON [AMZ]  : Endif
If clalev([F:AMA])=0  : Local File AMSKACT [AMA]  : Endif
If clalev([F:AMP])=0  : Local File AMSKPAR [AMP]  : Endif
If clalev([F:AWI])=0  : Local File AWINDOW [AWI]  : Endif
If clalev([F:AWP])=0  : Local File AWINPAR [AWP]  : Endif
If clalev([F:AWB])=0  : Local File AWINBRO [AWB]  : Endif
If clalev([F:AWT])=0  : Local File AWINBOUT[AWT]  : Endif
If clalev([F:AMK2])=0 : Local File AMSK    [AMK2] : Endif
If clalev([F:AMZ2])=0 : Local File AMSKZON [AMZ2] : Endif
If clalev([F:AMA2])=0 : Local File AMSKACT [AMA2] : Endif
If clalev([F:AMP2])=0 : Local File AMSKPAR [AMP2] : Endif
If clalev([F:AWI2])=0 : Local File AWINDOW [AWI2] : Endif
If clalev([F:AWP2])=0 : Local File AWINPAR [AWP2] : Endif
If clalev([F:AWB2])=0 : Local File AWINBRO [AWB2] : Endif
If clalev([F:AWT2])=0 : Local File AWINBOUT[AWT2] : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If clalev([F:ACV])=0  : Local File ACTIV    [ACV] : Endif

Call DEBTRANS From GLOCK
Gosub MASKREF
NOMWIN  = "WDFUP"+COD
MASKDES = "WMDFUP"+COD
Gosub TR1
If GOK=1
  Read [ADS]DOSSIER = APPLI
  If [F:GFP]ENAFLG=2
    SAVLAN = GLANGUE
    NOL = find("AMTDEP",[F:GFP]FLD(0..[F:GFP]NBRFLD-1))
    If GOK=1
      #*X3-70924 Call VALID(MASKDES,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
      Call VALIDFULL(MASKDES,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
    Endif
    If GOK=1
      Call VALID(NOMWIN,APPLI,1,OK) From VALWIN
    Endif
  Endif
Endif
End

$TR1
GOK=1
Trbegin [AMK2] , [AMZ2] , [AMA2] , [AMP2] , [AWI2] , [AWP2]
 Call DELMSK(MASKDES,APPLI) From MSKDIV
 Call DELWIN(NOMWIN,APPLI) From MSKDIV

 # champs obligatoires (blocs 1, 3, 4 et 5 + champs invisibles et techniques + type ABS du bloc 2 + champ SEL du bloc 2)
 Filter [AMZ] Order By NOZONE
  For [AMZ] Where CODMSK=MASKREF & (NUMBLOC<>2 or (NUMBLOC=2 and (CODTYP="ABS" or SAIAFF=3 or SAIAFF=4 or CODZON="SEL")))
   [F:AMZ2] = [F:AMZ]
   [F:AMZ2]CODMSK = MASKDES
   Write [AMZ2]
  Next
 Filter [AMZ]

 If [F:GFP]ENAFLG=2
  Read [AMK]CODMSK = MASKREF
  [F:AMK2] = [F:AMK]
  [F:AMK2]CODMSK = MASKDES
  [F:AMK2]MDL    = 1
#  [F:AMK2]TITBLOC(0) = [F:GFP]DES
  For J=1 To 9
   K = instr(1,[F:AMK2]OPTION(1),num$(J))
   If K
    [F:AMK2]OPTION(1) = left$([F:AMK2]OPTION(1),K-1)+right$([F:AMK2]OPTION(1),K+1)
   Endif
  Next J
  [F:AMK2]OPTION(1) += num$([F:GFP]NBRCOL)
  [F:AMK2]NBLIGT(1)  = [F:GFP]NBRLIG
  [F:AMK2]ACTBLOC(1) = ""
  Write [AMK2]
  If fstat
   GOK=0 : Call FSTA("AMK2") From GLOCK : Goto AB_TR1
  Endif

  For [AMZ]CODZON Where CODMSK=MASKREF & NUMBLOC=2 & CODTYP<>"ABS" & SAIAFF<>3 & SAIAFF<>4 & CODZON<>"SEL"
   NOL = find([F:AMZ]CODZON,[F:GFP]FLD(0..[F:GFP]NBRFLD-1))
   If NOL=0 # champ non trouvé dans la table GFUPSCR
    [F:GFP]FLD([F:GFP]NBRFLD) = [F:AMZ]CODZON
    If [F:AMZ]SAIAFF = 1 # champ saisi
     [F:GFP]SAI([F:GFP]NBRFLD) = 2
    Else # champ affiché
     [F:GFP]SAI([F:GFP]NBRFLD) = 1
    Endif
    [F:GFP]DAC([F:GFP]NBRFLD) = max([F:GFP]DAC)+1
    [F:GFP]NBRFLD += 1
    Rewrite [F:GFP]

    # initialisation de NOL pour éviter un plantage plus bas
    NOL = find([F:AMZ]CODZON,[F:GFP]FLD(0..[F:GFP]NBRFLD-1))
   Endif

   [F:AMZ2] = [F:AMZ]
   [F:AMZ2]CODMSK = MASKDES
   [F:AMZ2]NOZONE = [F:GFP]DAC(NOL-1)+2
#   If [F:GFP]SAI(NOL-1)<>2 # ne pas afficher le champ
   If [F:GFP]DAC(NOL-1)=0 # ne pas afficher le champ
    [F:AMZ2]SAIAFF = 3 # invisible
   Else
#    RANG = max(3,[F:GFP]DAC(NOL-1))
#    [F:AMZ2]NOZONE = RANG
    If [F:GFP]SAI(NOL-1)=2
     [F:AMZ2]SAIAFF = 1
    Else
     [F:AMZ2]SAIAFF = 2
    Endif
   Endif
   Write [AMZ2]
   If fstat
    GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
   Endif
  Next
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
  For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=MASKREF
   [F:AMA2] = [F:AMA]
   [F:AMA2]CODAFF = MASKDES
   Write [AMA2]
   If fstat
    GOK=0 : Call FSTA("AMA2") From GLOCK : Break
   Endif
  Next
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
  For [AMP]CODPAR Where TYPAFF=1 & CODAFF=MASKREF
   [F:AMP2] = [F:AMP]
   [F:AMP2]CODAFF = MASKDES
   Write [AMP2]
   If fstat
    GOK=0 : Call FSTA("AMP2") From GLOCK : Break
   Endif
  Next
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
  Read [AWI]AWI0 = WINREF
  [F:AWI2] = [F:AWI]
  [F:AWI2]NOMMSK(0) = MASKDES
  [F:AWI2]FLGMSK(0) = 2
  [F:AWI2]WIN       = NOMWIN
  [F:AWI2]MDL    = 1
  Write [AWI2]
  If fstat
   GOK = 0 : Call FSTA("AWI2") From GLOCK : Goto AB_TR1
  Endif
  For [AWP]AWP0 Where WIN=WINREF
   [F:AWP2] = [F:AWP]
   [F:AWP2]WIN = NOMWIN
   Write [AWP2]
   If fstat
    GOK = 0 : Call FSTA("AWP2") From GLOCK : Break
   Endif
  Next I
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

  For [AWT] Where WIN=WINREF
   [F:AWT2]=[F:AWT]
   [F:AWT2]WIN = NOMWIN
   Write [AWT2]
   If fstat
    GOK = 0 : Call FSTA("AWT2") From GLOCK : Break
   Endif
  Next
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

  Read [F:AWB]AWB0 = WINREF
  If !fstat
   [F:AWB2]= [F:AWB]
   [F:AWB2]WIN = NOMWIN
   Write [AWB2]
   If fstat
    GOK = 0 : Call FSTA("AWB2") From GLOCK : Goto AB_TR1
   Endif
  Endif

 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#########################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File GFUPSCR [GFP1]
 Local File ATEXTRA [AXX1]
Else
 Local File =[M]DOSORG+".GFUPSCR" [GFP1]
 Local File =[M]DOSORG+".ATEXTRA" [AXX1]
Endif
If [M]DOSDES=nomap
 Local File GFUPSCR [GFP2]
 Local File ATEXTRA [AXX2]
Else
 Local File =[M]DOSDES+".GFUPSCR" [GFP2]
 Local File =[M]DOSDES+".ATEXTRA" [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
OK = 1
If GTRACE=""
 Read [GFP2]GFP0 = TABLE
 If !fstat
  # Fiche déjà existante
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [GFP1], [GFP2], [AXX1], [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [GFP2]
 Delete [GFP2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".GFUPSCR" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("GFP2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [GFP1] Where COD=TABLE
  [F:GFP2] = [F:GFP1]
  Call COPTEXTRA("GFUPSCR","DESTRA",TABLE,"") From ATEXTRA
  If dim([F:GFP2]UPDUSR)>0 : [F:GFP2]UPDUSR = GUSER : Endif
  If dim([F:GFP2]UPDDAT)>0 : [F:GFP2]UPDDAT = date$ : Endif
  Write [GFP2]
  If fstat
   GOK = 0 : Call FSTA("GFP2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

########################################
Subprog AS_NBRLIG(VALEUR)
Variable Decimal VALEUR
If VALEUR<=0
 Local Integer NCOL
 Local Char    MASKREF(10)
 Gosub MASKREF
 Call LECTURE("AMK",MASKREF,"") From CONTOBJ
 NCOL   = find(1,[F:AMK]TYPBLOC(0..dim([F:AMK]TYPBLOC)-1))
 VALEUR = [F:AMK]NBLIGT(NCOL-1)
Endif
End

########################################
Subprog AS_SAI(VALEUR)
Variable Integer VALEUR
If [M]DAC(nolign-1)=0 or [M]SAIREF(nolign-1)<>1
 VALEUR = 1 : mkstat = 2
Endif
End

########################################
Subprog C_DAC(VALEUR)
Variable Decimal VALEUR
Local Integer NOL1, NOL2
# Contrôle sur le champs AMTDEP, celui ci ne peut être affiché sans le champs DEP

If [M]FLD(nolign-1)="DEP" & VALEUR=0
 NOL1 = find("AMTDEP",[M]FLD(0..[M]NBRFLD-1))
 If NOL1 : [M]DAC(NOL1-1)=0 : Affzo [M]DAC(NOL1-1) : Endif
Elsif [M]FLD(nolign-1)="AMTDEP" & VALEUR<>0
 NOL1 = find("DEP",[M]FLD(0..[M]NBRFLD-1))
 If !NOL1 | [M]DAC(NOL1-1)=0
  # Liée avec zone
  GMESSAGE=mess(2,773,1)-mess(17,115,1)-num$(NOL1)-":"-"'"-[M]INTIT(NOL1-1)-"'"
  mkstat = 2
 Endif
Endif
End

