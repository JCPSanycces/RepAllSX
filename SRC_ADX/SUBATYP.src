#<AdxTL>@(#)2.0.0.0 $Revision$
# Gestion du masque ATYP1
#
#Local File ATYPEPRO [ATYP]
#Local Char T(1)(0..10)
#For [ATYP] Where [ATYP]STDFLG=2
#  Call TRACE_COR("ATYP",[ATYP]COD,T,"M") From SUBXCB
#Next

End
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "SETBOUT"     : Gosub SETBOUT
 When "LIENS"       : Gosub LIENS
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When Default
Endcase
Return
######################################################################################
$LIENS
Call TEXTE([M:ATYP0]INTIT,[M:ATYP0]INTITTYP) From OBJDIV
Gosub GRISE_FLG
Gosub GERESTD
Return

#----------------------------------------------------------------------------#

$GRISE_FLG
If [M]STDFLG=2
 Actzo [M:ATYP1]PREFLG
 Actzo [M:ATYP1]LISFLG
Else
 Grizo [M:ATYP1]PREFLG
 Grizo [M:ATYP1]LISFLG
Endif
Return

#----------------------------------------------------------------------------#
$GERESTD
If !(GSOPHIA & GPRODUIT=-1)
    If [M:ATYP0]STDFLG=2
        Grizo [M:ATYP0]INTITTYP
        Grizo [M:ATYP0]5
        Grizo [M:ATYP1]10
        Grizo [M:ATYP1]15
    Else
        Actzo [M:ATYP0]INTITTYP
        Actzo [M:ATYP0]5
        Actzo [M:ATYP1]10
        Actzo [M:ATYP1]15
    Endif
    Grizo [M:ATYP0]STDFLG
Endif
Return

#----------------------------------------------------------------------------#
$SETBOUT
If !(GSOPHIA & GPRODUIT=-1)
    If [M:ATYP0]STDFLG=2
        Call VIREBOUT(CHAINE,"A") From GOBJET
    Endif
Endif
Return

#----------------------------------------------------------#
$OUVRE
Local File ATYPE [ATY]
Return
#----------------------------------------------------------#
$OUVRE_BOITE
Local Char    ATYPPBOX1(10)
ATYPPBOX1 = "GAU_CHE"+num$(find("ATYPP",OBJLIS(1..dim(OBJLIS)-1)))
Return
#######################################################
$FILGAUCHE
Case currbox
 When ATYPPBOX1
  FILGAUSUP = 'STDFLG=2'
 When "GAU_CHE"
  FILGAUCHE = "STDFLG=1"
 When Default
  FILGAUCHE = "1=1"
  FILGAUSUP = '1=1'
Endcase
Return

######################################################################################
########################################
# Bouton COPIE
########################################
#-------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File ATYPEPRO [ATYP]
Else
 Local File =[M]DOSORG+".ATYPEPRO" [ATYP]
Endif
If [M]DOSDES=nomap
 Local File ATYPEPRO [ATYP2]
Else
 Local File =[M]DOSDES+".ATYPEPRO" [ATYP2]
Endif
OK = 1
If GTRACE=""
 Read [ATYP2]ATYP0=TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [ATYP], [ATYP2]
Return

$TR_COP
GOK = 1
Trbegin [ATYP2]
 Delete [ATYP2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATYPEPRO" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ATYP2","") From GLOCK : Goto AB_TR_COP
 Endif
 Read [ATYP]ATYP0=TABLE
 [F:ATYP2] = [F:ATYP]
 Write [ATYP2]
 If fstat
   GOK=0 : Call FSTA("ATYP2") From GLOCK : Goto AB_TR_COP
 Endif
 If GOK<1 : Goto AB_TR_COP : Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#----------------------------------------------------------------------------#
$VERIF_CRE
$VERIF_MOD
Return


######################################################################################
Subprog AS_TYPTYP(VALEUR)
Variable Integer VALEUR
If !(GSOPHIA & GPRODUIT=-1 & [M:ATYP0]STDFLG=2)
  GMENLOC(1)=1
  GMENLOC(2)=1
  GMENLOC(3)=1
  GMENLOC(4)=1
  GMENLOC(5)=1
  GMENLOC(6)=1
  GMENLOC(7)=1
  GMENLOC(8)=1
  #GMENLOC(9)=1
  #GMENLOC(10)=1
  GMENLOC(11)=1
  GMENLOC(12)=1
Endif
End

######################################################################################
Subprog C_TYPTYP(VALEUR)
Variable Integer VALEUR
If VALEUR<>[M]TYPTYP
  For [ATY] Where TYPPROSYR=[M]COD
    GMESSAGE=func AFNC.MES1(mess(248,143,1),[F:ATY]CODTYP)
    GERR=1 : mkstat=2
    Break
  Next
  If mkstat : End : Endif
Endif
End

######################################################################################
Subprog AM_STDFLG(VALEUR)
Variable Integer VALEUR
[M]STDFLG = VALEUR
Gosub GRISE_FLG
End


######################################################################################

