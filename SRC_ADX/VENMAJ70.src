#####################################################################################
# VENMAJ70 : Mises à jour à effectuer lors du passage à la version 10 (Release 70)  #
#                                                                     Module ventes #
# --------------------------------------------------------------------------------- #
# Avant mise à jour AMAJ                                                            #
#                                                                                   #
#                                                                                   #
#####################################################################################
# --------------------------------------------------------------------------------- #
# Après mise à jour MAJ                                                             #
#                                                                                   #
#####################################################################################
#################################################################################
# Moulinettes avec anciens et nouveaux champs màj concernant le module ventes   #
#################################################################################
Subprog AMAJ
Local Integer WOUV_TRACE

  If GTRACE = "" Then
    Call OUVRE_TRACE("VENMAJ70 : Process for sales data") From LECFIC
    WOUV_TRACE=1
  Endif
  #--------------------------------
# 2016-03-16 DNE INSERT BEGIN (SAM #99458)
  Gosub SET_FIRST   From TRTFIRST
  #--------------------------------
  # Initialize new fields in SALTRS table
  Call INIT_SALTRS
  #--------------------------------
  Gosub UNSET_FIRST   From TRTFIRST
# 2016-03-16 DNE INSERT END
  #--------------------------------
  If WOUV_TRACE = 1 Then
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
End


##################################################################################
# Moulinettes avec champs version V10 uniquement màj concernant le module ventes #
##################################################################################
Subprog MAJ

Local Integer WOUV_TRACE

  If GTRACE = "" Then
    Call OUVRE_TRACE("VENMAJ70 : Process for sales data") From LECFIC
    WOUV_TRACE = 1
  Endif
  #--------------------------------
  #--------------------------------
  If WOUV_TRACE = 1 Then
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
End


# 2016-03-16 DNE INSERT BEGIN (SAM #99458)
#################################################################################
#    ---> Sales transactions: Initialization of SALTRS table                    #
#################################################################################
Subprog INIT_SALTRS
  Local Integer FLGERR
  Local Integer DIM_BVRREFNUMCOD, DIM_PAYBANCOD
  Local Integer DO_UPDATE

  If filinfo(filpath("FIL","SALTRS","fde",[F:ADS]DOSSIER),0) <= 0 Then
    End
  Endif
  #--------------------------------
  Local File =[F:ADS]DOSSIER+".SALTRS"    [SLT]
  #--------------------------------
  #-------------------------------------------------------------------------------#
  # Initialisation of new fields in sales transactions                            #
  #-------------------------------------------------------------------------------#
  Call ECR_TIME("VENMAJ70 Sales transactions process: Update SALTRS") From DOSSUB
  Call ECR_TIME("VENMAJ70 Sales transactions process: --- Step 1: Sales invoices") From DOSSUB
  Gosub TXNSIH  # Transactions for sales invoices (GESSIH etc., Type 5)
#--------------------------------
End

#-------------------------------------------------------------------------------#
# Transactions for sales invoices (GESSIH etc., Type 5)                         #
#-------------------------------------------------------------------------------#
$TXNSIH
    DIM_BVRREFNUMCOD = dim([F:SLT]BVRREFNUMCOD)
    DIM_PAYBANCOD    = dim([F:SLT]PAYBANCOD)

    Raz FLGERR
    Trbegin [F:SLT]
    For [F:SLT] Where STRTYP = 5
        Raz DO_UPDATE
        If DIM_BVRREFNUMCOD > 0 and [F:SLT]BVRREFNUMCOD = 0
            [F:SLT]BVRREFNUMCOD = 1 # AML 1: 'No'
            DO_UPDATE = 1
        Endif
        If DIM_PAYBANCOD > 0    and [F:SLT]PAYBANCOD = 0
            [F:SLT]PAYBANCOD    = 3 # AML 35: 'Hidden'
            DO_UPDATE = 1
        Endif
        If DO_UPDATE = 1 Then
            Rewrite [SLT]
            If fstat Then
                Call ECR_TRACE("Table SALTRS, Error ="-num$(fstat),1) From GESECRAN
                FLGERR = 1
                Break
            Endif
        Endif
    Next
    If FLGERR = 1
        Rollback
    Else
        Commit
    Endif
Return
# 2016-03-16 DNE INSERT END





