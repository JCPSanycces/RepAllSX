#<AdxTL>@(#)7.0.0.0 $Revision$ Gestion du masque CONSSPE1
Local Char PARAM(20)(1..5)
PARAM(1) = "0"
PARAM(2) = ""
PARAM(3) = ""
PARAM(4) = date$
PARAM(5) = ""
Call GCONSULT("SDA","",PARAM) From GCONSULT
End
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITV1])= 0 : Local File ITMMVT     [ITV1]: Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:STL]) = 0 : Local File STOLOT     [STL] : Endif
If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:STJ]) = 0 : Local File STOJOU     [STJ] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif

#
Local Char    WFIL(250)
Local Char    WFILS(250)
Local Char    WFILSPE(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Char    WINT(30)(40)
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I, J, K, L
#
Local Decimal WCOE, WPOT, WACT, WPHY, WCTL, WREJ
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSDA"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SDA1]FLG = 0
Return
############################################################
$AP_MAGNETO
[M:SDA1]FLG = 0
Return
############################################################
$FERME
If clalev([F:STO]) <> 0 : Filter [STO] : Endif
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I  
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SDA1]FCY = PARAM(I) 
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat 
          [M:SDA1]ITMREF = [F:ITM]ITMREF
        Endif
      Endif
    When 4 :
      If PARAM(I) <> "" 
        [M:SDA1]REFPER = PARAM(I)
      Else
        [M:SDA1]REFPER = date$ 
      Endif
    When 5 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif  
  Endcase
Next I       
Return
############################################################
$LECTURE
# MHB 13/03/09 : accès depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM")
        Diszo [M:SDA1]ITMREF
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
        Diszo [M:SDA1]ITMREF
        Diszo [M:SDA1]FCY
    Endif
Endif

SUITE  = 1
RETOUR = 1
NBLU   = 2
#
If [M:SDA1]ITMREF = ""
  NBLU = 0
  Return
Endif
#
Raz [M:SDA2]
nolign = 0
Read [ITM]ITM0=[M:SDA1]ITMREF
 If fstat
   Raz [F:ITM]
   Return
Endif 
[M:SDA2]STU       = [F:ITM]STU
#
WFILSPE="1=1"
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif
If [M:SDA1]FCY <> ""
  Filter [ITV] Where ITMREF = [M:SDA1]ITMREF &
&                    STOFCY = [M:SDA1]FCY    &
&                    evalue(WFILS)           &
&                    evalue(WFILSPE)
&               Order By Key ITV0
Else
  Filter [ITV] Where ITMREF = [M:SDA1]ITMREF &
&                    evalue(WFILS)           &
&                    evalue(WFILSPE)
&               Order By Key ITV0
Endif
#
Raz WPHY, WCTL, WREJ
Raz [F:ITV1]
For [ITV]
  Call STKDETSTO("[F:ITV]","[F:ITV1]","","",WINT,3,0) From STKACT
Next
Filter [ITV]
#
Call STKDETSTO("[F:ITV1]","","[M:SDA2]","NBLIG0",WINT,0,0) From STKACT
#
[M:SDA2]PHYSTO1    = [F:ITV1]PHYSTO
[M:SDA2]CTLSTO1    = [F:ITV1]CTLSTO
[M:SDA2]REJSTO1    = [F:ITV1]REJSTO
[M:SDA2]INTSTO1    = [F:ITV1]PHYSTO    + [F:ITV1]CTLSTO    + [F:ITV1]REJSTO
[M:SDA2]PLFSTO1    = [F:ITV1]PLFPHYSTO + [F:ITV1]PLFCTLSTO + [F:ITV1]PLFREJSTO
[M:SDA2]BPRSTO1    = [F:ITV1]BPRPHYSTO + [F:ITV1]BPRCTLSTO + [F:ITV1]BPRREJSTO
[M:SDA2]SCOSTO1    = [F:ITV1]SCOPHYSTO + [F:ITV1]SCOCTLSTO + [F:ITV1]SCOREJSTO
# hcb
[M:SDA2]TOTSTO1    += [F:ITV1]PHYSTO    + [F:ITV1]CTLSTO    + [F:ITV1]REJSTO
[M:SDA2]TOTSTO1    += [F:ITV1]PLFPHYSTO + [F:ITV1]PLFCTLSTO + [F:ITV1]PLFREJSTO
[M:SDA2]TOTSTO1    += [F:ITV1]BPRPHYSTO + [F:ITV1]BPRCTLSTO + [F:ITV1]BPRREJSTO
[M:SDA2]TOTSTO1    += [F:ITV1]SCOPHYSTO + [F:ITV1]SCOCTLSTO + [F:ITV1]SCOREJSTO
[M:SDA2]ALLSTO1    += [F:ITV1]PHYALL    + [F:ITV1]CTLALL    + [F:ITV1]REJALL    
[M:SDA2]ALLSTO1    += [F:ITV1]SCOPHYALL + [F:ITV1]SCOCTLALL + [F:ITV1]SCOREJALL  
# hcb
[M:SDA2]SCCLNDSTO  += [F:ITV]SCCLNDSTO 


  
WPHY = ([F:ITV1]PHYSTO+[F:ITV1]PLFPHYSTO+[F:ITV1]BPRPHYSTO+[F:ITV1]SCOPHYSTO)
WCTL = ([F:ITV1]CTLSTO+[F:ITV1]PLFCTLSTO+[F:ITV1]BPRCTLSTO+[F:ITV1]SCOCTLSTO)
WREJ = ([F:ITV1]REJSTO+[F:ITV1]PLFREJSTO+[F:ITV1]BPRREJSTO+[F:ITV1]SCOREJSTO)



#
WRUP = [0/0/0]
#
If [M:SDA1]FCY <> ""
  Filter [STJ] Where UPDCOD = 2              &
&                    ITMREF = [F:ITM]ITMREF  &
&                    STOFCY = [M:SDA1]FCY    &
&                    REGFLG <> 2              
&              Order By Key STJ2
Else
  Filter [STJ] Where UPDCOD = 2             & 
&                    ITMREF = [F:ITM]ITMREF &
&                    REGFLG <> 2              
&              Order By Key STJ2
Endif
#
For [STJ]
#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
    If [F:ITF]STOFCY <> [F:STJ]STOFCY | [F:ITF]ITMREF <> [F:STJ]ITMREF 
       Read [ITF]ITF0 = [F:STJ]ITMREF;[F:STJ]STOFCY
       If fstat 
          Raz [F:ITF]
       Endif
    Endif

  If [F:STJ]IPTDAT > [M:SDA1]REFPER
    Gosub TRT_CUMUL
  Else
    If WRUP <> [F:STJ]IPTDAT
      Gosub GEN_LIGNE
    Endif
    Gosub TRT_CUMUL
    WRUP = [F:STJ]IPTDAT
  Endif
Next
If WRUP <> [0/0/0]
  [F:STJ]IPTDAT -= 1
Endif
Gosub GEN_LIGNE
Filter [STJ]
Return
###########################################################
#Correction des quantités par titre STOJOU
$TRT_CUMUL


WCOE = 1
If find([F:ITF]STOMGTCOD,3,4)
  WPOT = [F:STJ]POT
  WACT = [F:STJ]ACT
  If WPOT = 0 : WPOT = 100 : Endif
  If WACT = 0 : WACT = 1   : Endif
  Case [F:ITF]STOMGTCOD
    When 3 : WCOE = (WPOT/100)
    When 4 : WCOE = WACT
  Endcase
Endif
Case mid$([F:STJ]STA,1,1)
  When "A" : WPHY -= ([F:STJ]QTYSTU*WCOE)
  When "Q" : WCTL -= ([F:STJ]QTYSTU*WCOE)
  When "R" : WREJ -= ([F:STJ]QTYSTU*WCOE)
Endcase
Return
###########################################################
$GEN_LIGNE
If nolign < dim([M:SDA2]PHYSTO)
  nolign += 1
  NOL    += 1
  If WRUP = [0/0/0]
    [M:SDA2]DATREF(nolign-1) = [M:SDA1]REFPER
  Else
    [M:SDA2]DATREF(nolign-1) = [F:STJ]IPTDAT
  Endif
  [M:SDA2]STU1(nolign-1)   = [F:ITM]STU
  [M:SDA2]TOTSTO(nolign-1) = (WPHY+WCTL+WREJ)
  [M:SDA2]PHYSTO(nolign-1) = WPHY
  [M:SDA2]CTLSTO(nolign-1) = WCTL
  [M:SDA2]REJSTO(nolign-1) = WREJ
Endif 
Return
############################################################
$SETBOUT
Return
############################################################
$EXEBOUT
Return
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:SDA1]FLG = 0
End
############################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SDA1]FLG = 0
End
Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AV_INTFLD(VALEUR)
Variable Char    VALEUR()
Call AV_INTFLD(VALEUR) From VISUITF
End

#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SDA") From SUBGTC

End



