#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################
# Sous-pro pour pivot de type : affaires
#                             cf AML 2240 : 31
###################################################
# FQ 64773 GA 05/2010 préfixe des noms de variables PJTWPIV devient WK
######################################################################
$OUVTAB_PJT
If !clalev([F:AXX]) Local File ATEXTRA [AXX] Endif
If !clalev([F:OPP]) Local File OPPOR [OPP] Endif
Return

######################################################################
Subprog TRT_PJT(ID,CLETRT,PITPJT,P_CRITERE,OK)
Value Char ID()
Value Char CLETRT () 
Value Char PITPJT () 
Value Char P_CRITERE() 
Variable Integer OK

If PITPJT ="" : Return : Endif

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
adxium = GUTF8
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Gosub OUVTAB_PJT
Gosub OUVREPIVOT From CONNECTFCT


Local Integer WPREPJT : Raz WPREPJT
Local Integer WNBPJT : Raz WNBPJT 
Local Char    OPTPJT(GDIMFIC)
OPTPJT = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitpjt")
Local Integer WKNBZON        : Raz WKNBZON
Local Char    WKNORECMES (50): Raz WKNORECMES 
Local Integer WKHEATYP       : Raz WKHEATYP 
Local Char    WKHEADMES (250): Raz WKHEADMES 

Call READPIT(PITPJT,WKNBZON,WKNORECMES,WKHEATYP ,WKHEADMES ) From CONNECTFCT
Local Char    WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
Local Char    WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
Local Char    WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
Local Char    WKFRM(150)(1..WKNBZON) : Raz WKFRM
Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
Local Char    WKVAL(255)(1..WKNBZON) : Raz WKVAL
Local Char    WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC
Call LOADPIVZON(PITPJT,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
Call WRPIVOT_HEAD(PITPJT,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPREPJT,OPTPJT) From CONNECTFCT

#######
For [OPP] Where evalue(P_CRITERE)
    Gosub WR_PJT
Next
#######

Call WRPIVOT_END(PITPJT ,WNBPJT ,WKNORECMES ,WPREPJT ,OPTPJT) From CONNECTFCT
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End

######################################################################
$WR_PJT
    ################################
    # fichiers PJT
    ################################
    #     Ouverture du fichier OPTPJT en écriture
    If WPREPJT = 0
      Openo OPTPJT,0 Using [FPIV]
      WPREPJT = 1
    Else
      Openo OPTPJT Using [FPIV]
    Endif
    
    WNBPJT += 1
    Call RAZVALPIVOT(PITPJT,WKNBZON,WKVAL,WKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITPJT,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    Call WRPIVOT(WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Return

######################################################################

