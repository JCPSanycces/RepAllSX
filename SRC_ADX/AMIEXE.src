#<AdxTL>@(#)6.0.0.0 $Revision$
Call EXECUTE(GBIDC1)
End

#---------------------------------------#
Subprog EXECUTE(CODE)
Value Char CODE
Local Char PARAM(10)(1..1) , VALEUR(10)
PARAM(1) = CODE
Call TRAITE_CHAR(VALEUR,PARAM,"","AMIEXE","AMIEXE",3,"") From GTRAITE
End

#---------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "INIT_DIA"    : Gosub INIT_DIA
Endcase
Return

#----------------------#
$INIT
Gosub OUVRE
Gosub VERIF
Return

#----------------------#
$INIT_DIA
[M]MOTIF = MOTIF
[M]CODE = CODE
Return

#----------------------#
$OUVRE_BATCH
Gosub OUVRE
Gosub VERIF
Return

$VERIF
CODE = PARAM(1)
If CODE<>""
 mkstat = 0
 Call CONTACC(CODE)
 If mkstat
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  FIN = 1 : Return
 Endif
Endif
Return

$OUVRE
Local File    AMAINT [AMI] , ATYPE [ATY] , ATABZON [ATZ]
Local Integer OK, I , TEST
Local Char    CODE(10) , MOTIF(GLONADI)
If !GSERVEUR & func AFNC.PARAMUTIL("ASIGMNT","","")="2"
 Local Char VALSIG(10) , PARSIG(30)(1..3)
 PARSIG(1) = nomap
 PARSIG(3) = GUSER
 Call SAISIE_CHAR(VALSIG,PARSIG,"APASSWDMNT","APASSWDMNT","") From GSAISIE
 If mkstat : FIN = 1 : Return : Endif
 MOTIF  = PARSIG(2)
Endif
Return

#----------------------#
$CONTROLE
If [M]COD=""
 Call ECR_TRACE(mess(40,114,1),1) From GESECRAN : # Code transaction inexistant
 SAI = 1 : Return
Endif
OK = 2
For nolign=1 To [M]NBLIG
 mkstat = 0
 Call CONTROLE(nolign,[M]VALEUR(nolign-1)) From ="WMAMI"+[M]COD
 If mkstat : OK = 0 : Break : Endif
Next I
If !OK
 Call ERREUR([M]VARDES(nolign-1)-":"-GMESSAGE) From GESECRAN
 SAI = 1 : Return
Endif
TMP = 1
Return

#----------------------#
$EXEC
Read [AMI]AMI0 = [M]COD
If !GSERVEUR
 Call OUVRE_TRACE([M]COD-func AFNC.TEXTE([F:AMI]INTIT)) From LECFIC
Endif
TEST = ([M]TEST=2)
GERREUR = 0
Onerrgo ER
Call TRANSAC(TEST,[M]NOMBRE) From ="WMAMI"+[M]COD
Onerrgo
If GERREUR
 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
 Raz GMESSAGE
Endif
# Espionnage des transactions systèmes
If !TEST
 # Transaction système
 Call TRACE_ORDRE(MOTIF,mess(190,123,1)-":"-[M]COD) From ESPION
Endif
#
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

#----#
$ER
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-string$(GERREUR>0,errmes$(GERREUR))-errm
Resume

#----------------------#
$TERMINE
If TEST
 SAI = 1
Endif
TRA = 1
Return

#---------------------------------------#
Subprog AS_COD(VALEUR)
Variable Char    VALEUR()
If [M]CODE<>""
 VALEUR = [M]CODE
 Gosub CHARGE
 mkstat = 2
Endif
End

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE
End

#----------------------#
$CHARGE
Local Integer I , LNGFMT
Local Char    TYPFMT(5) , OPTFMT(10) , CHFMT(20) , NUMFMT(10)
# ----------- mb 3.8.11 bug 75549 ----------------#
If clalev([F:AMI])=0 : Local File AMAINT [AMI] : Endif
If clalev([F:ATY])=0 : Local File ATYPE  [ATY] : Endif
If VALEUR<>[F:AMI]COD
 Read [AMI]AMI0 = VALEUR
 If fstat : End : Endif
Endif
# ----------- mb 3.8.11 bug 75549 ----------------#
Call CONTACC(VALEUR)
If mkstat : End : Endif
[M]DES   = func AFNC.TEXTE([F:AMI]INTIT)
[M]NBLIG = [F:AMI]NBRVAR
For I=0 To [M]NBLIG-1
 [M]VARPAR(I) = [F:AMI]VARPAR(I)
 [M]VARDES(I) = func AFNC.TEXTE([F:AMI]VARINTIT(I))
 Read [ATY]CODTYP = [F:AMI]VARTYP(I)
 [M]VARTYP(I) = [F:AMI]VARTYP(I)
 Case [F:ATY]TYPTYP
  When 1
   If [F:ATY]NOLIB<>0
    [M]NOLIB(I) = [F:ATY]NOLIB
   Else
    [M]NOLIB(I) = [F:ATZ]NOLIB
   Endif
  When 8
  When Default
   If [F:ATY]OBJLIEN="ADI" & [F:AMI]VARPAR(I)<>""
    Onerrgo RIEN
    [M]NOLIB(I) = val(num$(evalue([F:AMI]VARPAR(I))))
    Onerrgo
   Endif
   If [F:ATY]TYPTYP=7
    If [F:ATY]LNGTYP<>0
     [M]LONG(I)  = [F:ATY]LNGTYP
    Else
     [M]LONG(I)  = [F:ATZ]LONG
    Endif
   Endif
 Endcase
 If [F:AMI]VARDEF(I)<>""
  Onerrgo RIEN
  [M]VALEUR(I) = num$(evalue([F:AMI]VARDEF(I)))
  Onerrgo
 Endif
 Call CHARGE([M]VALEUR(I),[M]VARTYP(I),[M]NOLIB(I),[M]LONG(I),[M]VALINT(I)) From FMTVAR
Next I
Affzo DES, NBLIG, VARDES, VALEUR
Return

$RIEN
Resume

Subprog AS_NOMBRE(VALEUR)
Variable Decimal  VALEUR
If [M]TEST=2
 If VALEUR=0 : VALEUR = 10 : Endif
Else
 mkstat = 1
Endif
End

Subprog CONTACC(VALEUR)
Value Char VALEUR
Call CONTROLE("AMI","",VALEUR,"",mkstat) From CONTOBJ
If mkstat : End : Endif
If [F:AMI]ACS<>"" & GUSRACS<>2
 If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
 Read [ACC]CODACC = GUSER;[F:AMI]ACS
 If fstat
  GMESSAGE = mess(3,104,1) : mkstat = 2 : End
 # Vous n'avez pas accès à ce code
 Elsif [F:ACC]EXEC<>2
  GMESSAGE = mess(4,104,1) : mkstat = 2 : End
 # Vous n'avez pas les droits pour ce code
 Endif
Endif
End

