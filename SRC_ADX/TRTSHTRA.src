#<AdxTL>@(#)1.0.0.0 $Revision$
###############################################################################
# Sous-programmes liés à l'écran STKSHTREG [SHTR]
###############################################################################

###############################################################################
# ALIM_SHTR : Alimentation de l'en-tête du masque STKSHTREG[SHTR]
#             Positionnement sur les fichiers ITM,ITG,ITF,ITV et ITW
###############################################################################
# Paramètres E : PNOL = indice de la ligne de SHTS concerné
#                Masque STKSHTSEL [SHTS]
#                Masque ALLPAR    [ALP] (alimenté)
#            S : Masque STKSHTREG [SHTR]
#                PRET = Code retour (0=ok,1=erreur)
###############################################################################
Subprog ALIM_SHTR( PNOL, PRET )
Value    Integer PNOL
Variable Integer PRET
Local    Char    WWRH(GLONWRH)

    Raz [M:SHTR]

    [M:SHTR]STOFCY    = [M:SHTS]STOFCY
    [M:SHTR]ITMREF    = [M:SHTS]ITMREF(PNOL)
    [M:SHTR]IPTDAT    = [M:SHTS]BESDAT(PNOL)
    [M:SHTR]VCRTYP    = [M:SHTS]VCRTYP(PNOL)
    [M:SHTR]VCRNUM    = [M:SHTS]VCRNUM(PNOL)
    [M:SHTR]VCRLIN    = [M:SHTS]VCRLIN(PNOL)
    [M:SHTR]VCRTYPORI = [M:SHTS]VCRTYPORI(PNOL)
    [M:SHTR]VCRNUMORI = [M:SHTS]VCRNUMORI(PNOL)
    [M:SHTR]VCRLINORI = [M:SHTS]VCRLINORI(PNOL)
    [M:SHTR]VCRSEQORI = [M:SHTS]VCRSEQORI(PNOL)
    [M:SHTR]VCRSEQ    = [M:SHTS]VCRSEQ(PNOL)
    [M:SHTR]SEQ       = [M:SHTS]SEQ(PNOL)
    [M:SHTR]ALLTYP    = [M:SHTS]ALLTYP(PNOL)
    [M:SHTR]TYPREG    = [M:SHTS]TYPREG(PNOL)
    #--- 63305
    [M:SHTR]BPRNUM    = [M:SHTS]BPRNUM (PNOL)  # hcb 71761


# Par défaut, pas d'affichage des lignes de stock indisponibles
    [M:SHTR]STODISFLG =1


    If dim([M:SHTS]LOT) > 0
       [M:SHTR]LOTSAI    = [M:SHTS]LOT(PNOL)
    Endif
    If dim([M:SHTS]SLO) > 0
       [M:SHTR]SLOSAI    = [M:SHTS]SLO(PNOL)
    Endif
    If dim([M:SHTS]LOC) > 0
       [M:SHTR]LOCSAI    = [M:SHTS]LOC(PNOL)
    Endif
    [M:SHTR]STASAI    = [M:SHTS]STA(PNOL)
    If dim([M:SHTS]SERNUM) > 0
       [M:SHTR]SERSAI    = [M:SHTS]SERNUM(PNOL)
       [M:SHTR]SERFSAI   = [M:SHTS]SERNUMF(PNOL)
    Endif
    If dim([M:SHTS]WRH) > 0
       [M:SHTR]WRHSAI    = [M:SHTS]WRH(PNOL)
       WWRH              = [M:SHTS]WRH(PNOL)
    Endif
    #--- TS 106217
    If dim([M:SHTS]ECCVALMAJ) > 0
       [M:SHTR]ECCSAI    = [M:SHTS]ECCVALMAJ(PNOL)
    Endif
    #---
    [M:SHTR]COESAI    = [M:ALP]PCUSTUCOE
    [M:SHTR]PCUSAI    = [M:ALP]PCU
    [M:SHTR]QTYACT    = [M:SHTS]QTYSTUACT(PNOL)
    [M:SHTR]QTYPHY    = [M:SHTS]QTYSTU(PNOL)
    [M:SHTR]STU       = [M:SHTS]STU(PNOL)

    [M:SHTR]TRSTYP    = [M:SHTS]TRSTYP(PNOL)
    [M:SHTR]TRSCOD    = [M:SHTS]TRSCOD(PNOL)
    [M:SHTR]MVTDES    = [M:SHTS]MVTDES(PNOL)
    [M:SHTR]ENTCOD    = [M:SHTS]ENTCOD(PNOL)
    [M:SHTR]PJT       = [M:SHTS]PJT(PNOL)
    [M:SHTR]TRSFAM    = [M:SHTS]TRSFAM(PNOL)

    Call LECITM2([M:SHTR]STOFCY,[M:SHTR]ITMREF,WWRH,PRET) From STKLIB

End


###############################################################################
# MAJLIGNE : Met à jour l'affichage d'une ligne
#            A appeler après "Proposition" et Picking
###############################################################################
# Paramètres E : PNOL = indice de ligne à mettre à jour
###############################################################################
Subprog MAJLIGNE( PNOL )
Value Integer PNOL

    If [M:SHTR]SERNUM(PNOL)<>""
        Diszo [M:SHTR]QTYSTU(PNOL)
    Else
        Actzo [M:SHTR]QTYSTU(PNOL)
    Endif

End

###############################################################################
$MAJQTYTOT
    [M:SHTR]PECQTYPHY = sum([M:SHTR]QTYSTU)
    [M:SHTR]PECQTYACT = sum([M:SHTR]QTYSTUACT)
    Affzo [M:SHTR]PECQTYPHY,PECQTYACT
Return

###############################################################################
$DEBUT_PICKING
Local Integer DP_RET
#------------------------------------------------------
# Chargement du filtre lignes de stock pour le picking
#------------------------------------------------------
# Récupération de la règle d'allocation
Case [M:SHTR]VCRTYP
 When 3,4,5,8        : # Livraison sous-traitance
                       If [M:ALP]TRSTYP=20
                          WTRUCOD = [F:ITG]ALLRULSCO
                       # Préparation, Livraison, Facture, Retour fou
                       Else
                          WTRUCOD = [F:ITG]ALLRULSHI
                       Endif
 When 12             : # Suivi matière (opération de sous-traitance)
                       If [M:ALP]PECSCOLOC=2
                          WTRUCOD = [F:ITG]ALLRULSCC
                       # Suivi matière (interne)
                       Else
                          WTRUCOD = [F:ITG]ALLRULMFG
                       Endif
 When 20,29,31,32,33 : WTRUCOD = [F:ITG]ALLRULTRF
 When 6              : # Réception (conso matières sous-traitance)
                       WTRUCOD = [F:ITG]ALLRULSCC
 When Default
Endcase

Raz [F:TRU]
# Lecture règle d'allocation
If WTRUCOD<>""
   Read [TRU]TRU0=WTRUCOD
   If fstat Raz WTRUCOD Endif
Endif

# Stockage ordre des lots (FIFO par défaut) pour picking lignes de stock
If WTRUCOD<>""
   [M:SHTR]LOTMGT=[F:TRU]LOTMGT
Else
   [M:SHTR]LOTMGT=2
Endif

# Lecture de la règle de gestion à utiliser
Call LECSRU([M:SHTR]STOFCY,[F:ITM]TCLCOD,[M:SHTR]TRSTYP,[M:SHTR]TRSCOD,"",DP_RET)
&           From STKLIB
If DP_RET<>0
   FIN=1 : Return
Endif

If WTRUCOD<>""
   # Chargement des (types) emplacements de l'article-site paramétrés
   # dans la règle d'allocation/sortie pour filtrer le picking stock
   Call RECH_DEFLOCTYP("ALP") From STKALL
Endif

#-------------------------------
# Positionnement filtre picking
#-------------------------------
Raz WCRIT, WCRITSTO, WCRITPIC
Raz WCRITSTO1, WCRITSTO2, WCRITSTO3, WCRITSTO31, WCRITSTO4, WCRITSTO5, WCRITSTO6

# Article et site
WCRITSTO1 = '[F:STO]ITMREF=[M:SHTR]ITMREF&[F:STO]STOFCY=[M:SHTR]STOFCY'


# Lot et péremption
If dim([M:SHTR]XLOT)>0
   If [F:SRU]SHLLOT=1               # hcb V6dlu nouvelle gestion
       WCRITSTO3 = '([F:STL]SHLDAT=[0/0/0]|[F:STL]SHLDAT>=[M:SHTR]IPTDAT)'
       GCRITPIC  = WCRITSTO3
   Endif
# hcb v6percri deb
   If [F:SRU]SHLLOT=2
      WCRITSTO31 = '([F:STL]DLUDAT=[0/0/0]|[F:STL]DLUDAT>=[M:SHTR]IPTDAT)'
      GCRITPIC   = WCRITSTO31

      WCRITSTO3 = '([F:STL]SHLDAT=[0/0/0]|[F:STL]SHLDAT>=[M:SHTR]IPTDAT)'
   Endif
# hcb v6percri fin
   If !find([M:SHTR]XLOT,"","*")
      WCRITSTO2 = 'pat([F:STO]LOT,[M:SHTR]XLOT)<>0'
   Endif
Endif
#--- TS 106217
If dim([M:SHTR]WECCVALMAJ)>0 & [M:SHTR]WECCVALMAJ<>""
   WCRITSTO41 = '[F:STO]ECCVALMAJ=[M:SHTR]WECCVALMAJ'
Endif
#---

# Catégorie emplacement
If [M:ALP]PECINTLOC=2
   If [M:ALP]PECPLFLOC=2
      #--- Bug 70588
      #WCRITSTO5 = 'find([F:STO]LOCCAT,1,2)<>0'
      WCRITSTO5 = '(find([F:STO]LOCCAT,1,2)<>0'
      #---
      #--- Issue 48800
      If !find([M:SHTR]XLOC,"","*") WCRITSTO5 += '&pat([F:STO]LOC,[M:SHTR]XLOC)<>0' Endif
      If [M:SHTR]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SHTR]XWRH)<>0' Endif
   Else
      #--- Bug 70588
      #WCRITSTO5 = '[F:STO]LOCCAT=1'
      WCRITSTO5 = '([F:STO]LOCCAT=1'
      #---
      #--- Issue 48800
      If !find([M:SHTR]XLOC,"","*") WCRITSTO5 += '&pat([F:STO]LOC,[M:SHTR]XLOC)<>0' Endif
      If [M:SHTR]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SHTR]XWRH)<>0' Endif
   Endif
Elsif [M:SHTR]PECPLFLOC=2
   #--- Bug 70588
   #WCRITSTO5 = '[F:STO]LOCCAT=2'
   WCRITSTO5 = '([F:STO]LOCCAT=2'
   #---
   #--- Issue 48800
   If !find([M:SHTR]XLOC,"","*") WCRITSTO5 += '&pat([F:STO]LOC,[M:SHTR]XLOC)<>0' Endif
   If [M:SHTR]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SHTR]XWRH)<>0' Endif
Endif
If [M:SHTR]PECSCOLOC=2
   If WCRITSTO5=""
      WCRITSTO5  = '[F:STO]LOCCAT=4'
      #--- Issue 48800
      If !find([M:SHTR]XLOC,"","*") WCRITSTO5 += '&pat([F:STO]LOC,[M:SHTR]XLOC)<>0' Endif
   Else
      #--- Bug 70588
      #WCRITSTO5 += '|[F:STO]LOCCAT=4'
      WCRITSTO5 += '|[F:STO]LOCCAT=4)'
      #---
   Endif
Elsif WCRITSTO5=""
   # Pour ne rien avoir (paramétrage incohérent)
   WCRITSTO5 = '[F:STO]LOCCAT=9'
#--- Bug 70588
Else
   WCRITSTO5 += ')'
#---
Endif

# Propriétaire
If [M:SHTR]PECOWNER=""
   [M:SHTR]OWNFLG=2 : [M:SHTR]NOTOWNFLG=1
   WCRITSTO6 = '[F:STO]OWNER=[F:STO]STOFCY'
Else
   [M:SHTR]OWNFLG=2 : [M:SHTR]NOTOWNFLG=2
   WCRITSTO6 = 'find([F:STO]OWNER,[F:STO]STOFCY,[M:SHTR]PECOWNER)'
Endif

Raz WA, WQ, WR
# Statuts autorisés par les règles de gestion d'E/S
If find([F:SRU]AUZSTA,1,3,5,7) WA=1  Endif
If find([F:SRU]AUZSTA,2,3,6,7) WQ=1  Endif
If find([F:SRU]AUZSTA,4,5,6,7) WR=1  Endif

[M:SHTR]XSTA=vireblc([M:SHTR]XSTA,4)

# Si statuts renseignés dans filtre allocation
If !find([M:SHTR]XSTA,"","*")
   # Décodage de la liste de statuts --> transformation en
   # une formule contenant des 'pat(%,statut)'
   Call DECODE_STAT([M:SHTR]XSTA,WCRIT) From TRTCATEG
   # Remplacement des '%' par la variable à tester
   Call CREE_FORMULE(WCRIT,"[F:STO]STA",WCRITSTO4) From TRTCATEG
# Sinon prise en compte des sous-statuts autorisés
Elsif !find([F:SRU]AUZSST,"","*")
   Call CREE_FORMULE([F:SRU]FORSTA,"[F:STO]STA",WCRITSTO4) From TRTCATEG
Endif

WCRITSTOA = 'pat([F:STO]STA,"A*")'
WCRITSTOQ = 'pat([F:STO]STA,"Q*")'
WCRITSTOR = 'pat([F:STO]STA,"R*")'

# Alimentation des zones de la fenêtre critère et du filtre
# pour contrôle ligne stock pickée (si non administrateur stock)
[M:SHTR]AAASTA = 1
[M:SHTR]QQQSTA = 1
[M:SHTR]RRRSTA = 1
# hcb V6percri deb
[M:SHTR]FLGSHLLOT = 2
[M:SHTR]FLGDLULOT = 2
If [F:SRU]SHLLOT = 2
   [M:SHTR]FLGSHLLOT = 1
   [M:SHTR]FLGDLULOT = 1
Endif
If [F:SRU]SHLLOT = 1
   [M:SHTR]FLGSHLLOT = 1
   [M:SHTR]FLGDLULOT = 2
Endif
# hcb V6percri fin
[M:SHTR]AUZSST = [F:SRU]AUZSST
[M:SHTR]FORSTA = [F:SRU]FORSTA

Raz WCRIT
If WA=1
   WCRIT+='pat([F:STO]STA,"A*")'
   [M:SHTR]AAASTA=2
Endif
If WQ=1
   If WCRIT<>"" WCRIT+='|' Endif
   WCRIT+='pat([F:STO]STA,"Q*")'
   [M:SHTR]QQQSTA=2
Endif
If WR=1
   If WCRIT<>"" WCRIT+='|' Endif
   WCRIT+='pat([F:STO]STA,"R*")'
   [M:SHTR]RRRSTA=2
Endif

If WCRITPIC<>""
   If WCRIT<>""
      WCRITPIC+='&('+WCRIT+')'
   Endif
Else
   If WCRIT<>""
      WCRITPIC+=WCRIT
   Else
      WCRITPIC='1=1'
   Endif
Endif

Raz WAFFPICK
If [M:SHTR]NBLIG=0 WAFFPICK=1 Endif
Gosub TIROIR From TRTSHTRP

Return

