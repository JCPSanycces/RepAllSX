#-----------------------------------------------------------------------------
# A partir de l'identifiant, renvoit si il s'agit d'un contexte contremarque
Funprog IS_DIRECT_ORDER(LFCY, LTYP, LNUM, LLIN, LSEQ)
Value    Char    LFCY
Value    Integer LTYP
Value    Char    LNUM
Value    Integer LLIN
Value    Integer LSEQ
Local Integer LDIRECT

If clalev ([F:ORD]) = 0 : Local File ORDERS   [ORD] : Endif

# FQ 70303 GA 02/2011 ne pas tenir compte des affectations si contremarque et statut <> Ferme

LDIRECT = 0
For [ORD]ORD3 Where STOFCY = LFCY
&                 & VCRTYP = LTYP
&                 & VCRNUM = LNUM
&                 & VCRLIN = LLIN
&                 & VCRSEQ = LSEQ
&                 & FMI>1 & WIPSTA=1
  LDIRECT = 1 : Break
Next

End LDIRECT

#-----------------------------------------------------------------------------
# A partir de l'identifiant, renvoit l'identifiant de sa contremarque
Subprog GET_DIRECT_ORDER(LFCY, LITM, LTYP, LNUM, LLIN, LSEQ, LWTYP, LTYP2, LNUM2, LLIN2, LSEQ2)
Value    Char    LFCY
Value    Char    LITM
Value    Integer LTYP
Value    Char    LNUM
Value    Integer LLIN
Value    Integer LSEQ
Value    Integer LWTYP
Variable Integer LTYP2
Variable Char    LNUM2
Variable Integer LLIN2
Variable Integer LSEQ2

Raz LTYP2, LNUM2, LLIN2, LSEQ2

If clalev ([F:MLK]) = 0 : Local File MTOLINK    [MLK] : Endif

If func CBNLIB.ISDEM(LWTYP)
    Local Integer LWTYP2
    LWTYP2 = func WIPTYP2(LWTYP)

    For [MLK]MLK0 Where STOFCY  = LFCY
&                     & ITMREF  = LITM
&                     & DEMTYP  = LTYP
&                     & DEMNUM  = LNUM
&                     & DEMLIN  = LLIN
&                     & DEMSEQ  = LSEQ
&                     & find(DWIPTYP,LWTYP,LWTYP2)<>0
&                     & FMIFLG  = 2
      LTYP2  = [F:MLK]RESSTYP
      LNUM2  = [F:MLK]RESSNUM
      LLIN2  = [F:MLK]RESSLIN
      LSEQ2  = [F:MLK]RESSSEQ
      Break
    Next
Else
    For [MLK]MLK1 Where STOFCY  = LFCY
&                     & ITMREF  = LITM
&                     & RESSTYP = LTYP
&                     & RESSNUM = LNUM
&                     & RESSLIN = LLIN
&                     & RESSSEQ = LSEQ
&                     & FMIFLG  = 2
      LTYP2  = [F:MLK]DEMTYP
      LNUM2  = [F:MLK]DEMNUM
      LLIN2  = [F:MLK]DEMLIN
      LSEQ2  = [F:MLK]DEMSEQ
      Break
    Next
Endif
End

#-----------------------------------------------------------------------------
# A partir d'article et site, s'agit-il d'un article sujet à contremarque (1 à 1)
Funprog IS_DIRECT_ORDER_CTX(LFCY, LITM)
Value    Char    LFCY
Value    Char    LITM

Local Integer LDIRECTCTX
Local Char    WPTOCOD(GLONPTO)

If clalev ([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev ([F:PTO]) = 0 : Local File PARMTO     [PTO] : Endif

If [F:ITF]ITMREF <> LITM | [F:ITF]STOFCY <> LFCY
    Read [ITF]ITF0=LITM;LFCY
    If fstat : Raz [F:ITF] : Endif
Endif

If [F:ITF]PTOCOD = ""
   Call PARAM(LFCY,"DEFPTO",WPTOCOD) From ADOVAL : # WPTOCOD = GDEFPTO : # GH 20/11/13 bug 94608
Else WPTOCOD = [F:ITF]PTOCOD
Endif
If [F:PTO]PTOCOD <> WPTOCOD
    Read [PTO]PTO0=WPTOCOD
    If fstat : Raz [F:PTO] : Endif
Endif

If [F:PTO]PTODIR = 2 : LDIRECTCTX = 1 : Endif

End LDIRECTCTX

#-----------------------------------------------------------------------------
# existe-t-il des affectations liées à ce document
Funprog LINK_EXISTS(LFCY, LTYP, LNUM, LLIN, LSEQ, LWTYP)
Value    Char    LFCY
Value    Integer LTYP
Value    Char    LNUM
Value    Integer LLIN
Value    Integer LSEQ
Value    Integer LWTYP

Local    Integer LEXIST

If clalev ([F:MLK]) = 0 : Local File MTOLINK    [MLK] : Endif

If func CBNLIB.ISDEM(LWTYP)
    Local Integer LWTYP2
    LWTYP2 = func WIPTYP2(LWTYP)

    Filter [MLK] Where STOFCY  = LFCY
&                    & DEMTYP  = LTYP
&                    & DEMNUM  = LNUM
&                    & DEMLIN  = LLIN
&                    & DEMSEQ  = LSEQ
&                    & find(DWIPTYP,LWTYP,LWTYP2)<>0
&            Order By Key MLK0
Else
    Filter [MLK] Where STOFCY  = LFCY
&                    & RESSTYP = LTYP
&                    & RESSNUM = LNUM
&                    & RESSLIN = LLIN
&                    & RESSSEQ = LSEQ
&            Order By Key MLK1
Endif

LEXIST = 0
For [MLK]
    LEXIST = 1 : Break
Next

Filter [MLK]

End LEXIST

#------------------------------------   IMPORTANT     --------------------------------
# GH 05/07/2012 Ce funprog sera bientôt supprimée en standard, ne pas l'utiliser
#-------------------------------------------------------------------------------------
# existe-t-il des affectations liées à une ligne de contrat
Funprog LINK_EXISTS_DL(LFCY, LTYP, LNUM, LLIN, LWTYP)
Value    Char    LFCY
Value    Integer LTYP
Value    Char    LNUM
Value    Integer LLIN
Value    Integer LWTYP

Local    Integer LEXIST

If clalev ([F:MLK]) = 0 : Local File MTOLINK    [MLK] : Endif

If func CBNLIB.ISDEM(LWTYP)
    Local Integer LWTYP2
    LWTYP2 = func WIPTYP2(LWTYP)

    Filter [MLK] Where STOFCY  = LFCY
&                    & DEMTYP  = LTYP
&                    & DEMNUM  = LNUM
&                    & DEMLIN  = LLIN
&                    & find(DWIPTYP,LWTYP,LWTYP2)<>0
&            Order By Key MLK0
Else
    Filter [MLK] Where STOFCY  = LFCY
&                    & RESSTYP = LTYP
&                    & RESSNUM = LNUM
&                    & RESSLIN = LLIN
&            Order By Key MLK1
Endif

LEXIST = 0
For [MLK]
    LEXIST = 1 : Break
Next

Filter [MLK]

End LEXIST

#-----------------------------------------------------------------------------
# mise à jour ORDERS en référence à buffer MLIK
Subprog UPDORDERS_FROM_MLIK

If clalev ([F:ORDB]) = 0 : Local File ORDERS     [ORDB] : Endif

# maj demande
For [ORDB]ORD3 Where STOFCY = [M:MLIK]STOFCY
&                  & ITMREF = [M:MLIK]ITMREF
&                  & VCRTYP = [M:MLIK]DEMTYP
&                  & VCRNUM = [M:MLIK]DEMNUM
&                  & VCRLIN = [M:MLIK]DEMLIN
&                  & VCRSEQ = [M:MLIK]DEMSEQ
&                  & WIPTYP = [M:MLIK]DWIPTYP
    Readlock [ORDB] Curr
    If fstat = 1  : GOK = -1
                    GLOCK ="$ORDERS"-[M:MLIK]STOFCY-[M:MLIK]DEMNUM-num$([M:MLIK]DEMLIN)-num$([M:MLIK]DEMSEQ)
                    Break
    Elsif fstat   : GOK = 0
                    Call RSTA("ORDB",[M:MLIK]STOFCY-[M:MLIK]DEMNUM-num$([M:MLIK]DEMLIN)-num$([M:MLIK]DEMSEQ))From GLOCK
                    Break
    Endif

    Case [M:MLIK]MAJCOD
        When "C" :         [F:ORDB]MTOQTY += [M:MLIK]LIKQTY
        When "A" :         [F:ORDB]MTOQTY -= [M:MLIK]LIKQTY
        When "M" :         [F:ORDB]MTOQTY  = [M:MLIK]LIKQTY
    Endcase
    If [F:ORDB]MTOQTY < 0 : [F:ORDB]MTOQTY = 0 : Endif

    [F:ORDB]UPDDAT = date$
    [F:ORDB]UPDUSR = GUSER
    Rewrite [ORDB]
    If fstat : GOK=0 : Call FSTA("ORDB") From GLOCK : Break : Endif
    Break
Next
If GOK <= 0 : End : Endif

# maj ressource
For [ORDB]ORD3 Where STOFCY = [M:MLIK]STOFCY
&                  & ITMREF = [M:MLIK]ITMREF
&                  & VCRTYP = [M:MLIK]RESSTYP
&                  & VCRNUM = [M:MLIK]RESSNUM
&                  & VCRLIN = [M:MLIK]RESSLIN
&                  & VCRSEQ = [M:MLIK]RESSSEQ
&                  & find(WIPTYP,2,5,7,9,13)<>0
    Readlock [ORDB] Curr
    If fstat = 1  : GOK = -1
                    GLOCK ="$ORDERS"-[M:MLIK]STOFCY-[M:MLIK]RESSNUM-num$([M:MLIK]RESSLIN)-num$([M:MLIK]RESSSEQ)
                    Break
    Elsif fstat   : GOK = 0
                    Call RSTA("ORDB",[M:MLIK]STOFCY-[M:MLIK]RESSNUM-num$([M:MLIK]RESSLIN)-num$([M:MLIK]RESSSEQ)) From GLOCK
                    Break
    Endif

    Case [M:MLIK]MAJCOD
        When "C" :         [F:ORDB]MTOQTY += [M:MLIK]LIKQTY
        When "A" :         [F:ORDB]MTOQTY -= [M:MLIK]LIKQTY
        When "M" :         [F:ORDB]MTOQTY  = [M:MLIK]LIKQTY
    Endcase
    If [F:ORDB]MTOQTY < 0 : [F:ORDB]MTOQTY = 0 : Endif

    [F:ORDB]UPDDAT = date$
    [F:ORDB]UPDUSR = GUSER
    Rewrite [ORDB]
    If fstat : GOK=0 : Call FSTA("ORDB") From GLOCK : Break : Endif
    Break
Next

End

