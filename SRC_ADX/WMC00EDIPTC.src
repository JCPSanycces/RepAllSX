#<AdxTL>@(#)0.0.0.0 $Revision$Class Protocol
# Supervisor
## CRUD-CLASSE ## EDIPTC
# 2018-11-06 07:04:56 984

Gosub TEST From WMCR_EDIPTC : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,PTCCOD)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# EDIPTC : EDIPTC
# EDIPTCD : EDIPTC EDIPTCD
# EDIPTCM : EDIPTC EDIPTCM
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet EDIPTC._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1,A_N2,A_S2,A_N3,A_S3
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = EDIPTC.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(EDIPTC.ACTX.AFOLDER,nomap,"")>0
 Local File EDIPTC [EPT]
 Local File EDIPTCD [EPTD]
 Local File EDIPTCM [EPTM]
Else
 Local File =EDIPTC.ACTX.AFOLDER+".EDIPTC" [EPT]
 Local File =EDIPTC.ACTX.AFOLDER+".EDIPTCD" [EPTD]
 Local File =EDIPTC.ACTX.AFOLDER+".EDIPTCM" [EPTM]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [EPT] With
& [EPTD]EPTD0 = [F:EPT]PTCCOD,
& [EPTM]EPTM0 = [F:EPT]PTCCOD
& As [LNK_]
Return

############################################################################################
### EDIPTC(WEPT)
############################################################################################
Funprog  _MAJSQL_EDIPTC(WEPT)
Variable Instance WEPT Using C_EDIPTC
Local Integer ASTATUS,A_I,A_J
Default File [F:EPT]
If WEPT.ASTALIN=[V]CST_ANEW
 Call INICRE(WEPT) From ASYRSUB
 SetInstance [F:EPT] With WEPT
 Write [F:EPT]
 If fstat
  Call FSTA("EPT",WEPT,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEPT.updTick = [F:EPT]updTick
Elsif WEPT.ASTALIN=[V]CST_ALL or WEPT.ASTALIN=[V]CST_AUPD
 Call INIUPD(WEPT) From ASYRSUB
 SetInstance [F:EPT] With WEPT
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEPT,"EDIPTC")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:EPT]EPT0 = [F:EPT]PTCCOD
 If fstat
  Call FSTA("EPT",WEPT,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEPT.updTick = [F:EPT]updTick
Elsif WEPT.ASTALIN=[V]CST_ADEL
 SetInstance [F:EPT] With WEPT
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEPT,"EDIPTC")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:EPT]EPT0 = [F:EPT]PTCCOD
 If fstat
  Call FSTA("EPT",WEPT,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK

############################################################################################
### EDIPTCD(WEPTD)
############################################################################################
Funprog  _MAJSQL_EDIPTCD(WEPTD)
Variable Instance WEPTD Using C_EDIPTCD
Local Integer ASTATUS,A_I,A_J
Default File [F:EPTD]
If WEPTD.ASTALIN=[V]CST_ANEW
 Call INICRE(WEPTD) From ASYRSUB
 SetInstance [F:EPTD] With WEPTD
 Write [F:EPTD]
 If fstat
  Call FSTA("EPTD",WEPTD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEPTD.updTick = [F:EPTD]updTick
Elsif WEPTD.ASTALIN=[V]CST_ALL or WEPTD.ASTALIN=[V]CST_AUPD
 Call INIUPD(WEPTD) From ASYRSUB
 SetInstance [F:EPTD] With WEPTD
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEPTD,"EDIPTCD")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:EPTD]EPTD0 = [F:EPTD]PTCCOD;[F:EPTD]NUMLIN
 If fstat
  Call FSTA("EPTD",WEPTD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEPTD.updTick = [F:EPTD]updTick
Elsif WEPTD.ASTALIN=[V]CST_ADEL
 SetInstance [F:EPTD] With WEPTD
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEPTD,"EDIPTCD")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:EPTD]EPTD0 = [F:EPTD]PTCCOD;[F:EPTD]NUMLIN
 If fstat
  Call FSTA("EPTD",WEPTD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK

############################################################################################
### EDIPTCM(WEPTM)
############################################################################################
