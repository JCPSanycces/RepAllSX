#<AdxTL>@(#)11.0.0.0 $Revision$
################################################################################
#    SELECTION DANS LISTE et DANS TABLE CONCERNANT LES NATURES POUR LA TABLE
#    DES COEFFICIENTS DE REEVALUATION
#    MDR
#    Création le : 08.01.2004
#    Modification le : 01.03.2005
#
#    CBO - 29.04.2014  FQ69690  Objet FAM
#-------------------------------------------------------------------------------
#    ****  SELECTION DANS LISTE *****
#
#    SELFAMCOE        Liste des Familles comptables pour la valeur du déterminant
#
#    SELCPTCOE       liste des Comptes et des codes comptables pour les valeurs
#                    des rubriques déterminées
#    SELTABCOE       liste des Comptes et des codes comptables pour les valeurs
#                    des rubriques déterminées
#
#-------------------------------------------------------------------------------
## Appel général
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call SAISIE_CHAR(VALEUR,PARAM,"SELNATCOE","SELNATCOE","") From GSAISIE
End

$ACTION
Local Integer PCRITNAT

Case ACTION
 When "SEL_TABLE"  : PCRITNAT=val(PARAM(1)) : Gosub SELNAT
Endcase

Return
#------------------------------------------------------------------------------------------
# SELNAT : - sélection des Familles comptables dans la table diverse 611
# après affichage de la liste
#        :-  sélection des codes comptables de la table GACCCOUNT
#           pour le choix de la valeur du code comptable
#-----------------------------------------------------------------------------------------
$SELNAT

  Local Char    FLDLEG(12) : FLDLEG = "LEG" : # FQ79483
  Local Char    SGLEGFIL(GLONADI)           : # FQ79483
  Local Char    LLEG(3) : LLEG = PARAM(2)   : # FQ79483

If  PCRITNAT = GVML_NATFAM
#   PARAM(1)=num$(GTD_FAMCPT)
#   PARAM(2) = ""
#   GSOCIETE = [M]CPY
#     # Bricolage pour filtrer sur la législation avec un code société vide FQ79483
#     If GSOCIETE = ""
#       SGLEGFIL = GLEGFIL
#       GLEGFIL  = LLEG
#     Endif
#
#   Gosub SELADI From SUBADI
#
#     If GSOCIETE = "" : # FQ79483
#       GLEGFIL = SGLEGFIL
#     Endif
#
#     TIT    = mess(38,GML_MSGFASPR,1)  : # FQ79483
#     DEFPAG = 1                        : # FQ79483

    OBJET = "FAM"
    CRITERE = ""
Else
     If clalev([F:FACC])=0 : Local File FASACCCOD [FACC] : Endif
     If clalev([F:AXX])=0  : Local File ATEXTRA   [AXX]  : Endif

     Link [FACC] With [AXX]AXX0="GACCCODE";"DESTRA";GLANGUE;[FACC]TYP;[FACC]ACCCOD
&    As   [LFAC]
&    Where TYP = GVML_COGIMMO
     Default File [LFAC]

     NBCOL   = 2
     TIT(0) = mess(12,123,1)  # Choix
     Call TITOBJ("CAC","",TIT(1)) From CONTOBJ
     TIT(0) -= TIT(1)
     COL(1)  = "[F:FACC]ACCCOD"
     TIT(2) = mess(82,123,1)  # Intitulé
     COL(2)  = "[F:AXX]TEXTE"
     CRITERE = "1=1"
     DEFPAG  = 1
     START   = "[F:FACC]ACCCOD"
     ORDRE   = "[F:FACC]ACCCOD"
     SIZLIG  = 220
     SIZCOL  = 150
Endif
Return
