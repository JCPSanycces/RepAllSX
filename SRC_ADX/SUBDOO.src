#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du masque DOO1
#Gestion du masque DOO
########################################
Subprog AM_ALH1(VALEUR)
Variable Char    VALEUR()

Local Integer IALHNUM

  If INCUSTMODE and VALEUR <> GSZALH(0) Then
    If [M:DOO1]ALH1 <> "" Then
      IALHNUM = 0
      Gosub CLEANFLD
    Endif
  Endif
  [M:DOO1]ALH1 = VALEUR
  Affzo [M:DOO1]ALH1
End

########################################
Subprog IB_ALH1

  Gosub MNGBTCHAR
End

