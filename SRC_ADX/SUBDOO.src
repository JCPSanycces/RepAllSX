######################################################################################
# Sous-programmes
######################################################################################
# Désactive les boutons de paramétrage lorsqu'on est en exploitation normale.
# Champs non alphanumérique
$MNGBOUT
  If INCUSTMODE Then
    Raz GBOUT1
    Raz GBOUT2
    Raz GBOUT3
    GBOUT1 = mess(232,196,1) #Titre du bloc
    GBOUT2 = mess(233,196,1) #Titre du champs
  Else
    Raz GBOUT1
    Raz GBOUT2
    Raz GBOUT3
  Endif
Return

#####################################################################################
# Champs alphanumériques
$MNGBTCHAR
  If INCUSTMODE Then
    Raz GBOUT1
    Raz GBOUT2
    Raz GBOUT3
    GBOUT1 = mess(232,196,1) #Titre du bloc
    GBOUT2 = mess(234,196,1) #Ajouter un libellé de liste
  Else
    Raz GBOUT1
    Raz GBOUT2
    Raz GBOUT3
    GBOUT3 = mess(18,100,1) #Sélection
  Endif
Return

##################################################################################################
# Gestion d'un champs déjà paramétré.
$CLEANFLD
Local Integer IRESULT
Local Integer ICOUNT
Local Char SZLANGUE

  ICOUNT = 0
  IRESULT = 0
  SZLANGUE = ""
  #Ce champs est déjà utilisé en tant que TITRE DU CHAMPS. Voulez-vous supprimer son contenu ?
  Call OUINON(mess(236,196,1) - GSZALH(IALHNUM) - mess(237,196,1), IRESULT) From GESECRAN
  If IRESULT = 2 Then
    Call DEBTRANS From GLOCK
    #Supprime les données
    For [BPM]
      [F:BPM]ALHX(IALHNUM) = ""
      Trbegin [BPM]
      Rewrite [BPM]    
      If fstat Then
        Rollback
      Else
        Commit
      Endif
    Next
    #Supprime les données de configuration
    If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=nomap
    If fstat Then
      Return
    Endif
    For ICOUNT = 0 To dim([F:ADS]LAN)-1
      Read [BPG]BPG0="DOO";[F:ADS]LAN(ICOUNT)
      If !fstat Then
        [F:BPG]TTRALH(IALHNUM) = ""
        GSZALH(IALHNUM) = VALEUR
        Trbegin [BPG]
        Rewrite [BPG]    
        If fstat Then
          Rollback
        Else
          Commit
        Endif
      Endif
    Next
    #Supprime les données de la liste associée
    Trbegin [BPG]
    SZLANGUE = "2" + num$(IALHNUM)
    Delete [BPG] Where [F:BPG]BPRTYP = "LIBDOO" and [F:BPG]TTRINT(0) = SZLANGUE
    If fstat Then
      Rollback
    Else
      Commit
    Endif
    SZLANGUE = ""
  Elsif IRESULT = 1 Then
    Case IALHNUM
      When 0
        [M:DOO1]ALH1 = [M:DOO1]ALH1
      When 1
        [M:DOO1]ALH2 = [M:DOO1]ALH2
      When 2
        [M:DOO1]ALH3 = [M:DOO1]ALH3
      When 3
        [M:DOO1]ALH4 = [M:DOO1]ALH4
      When 4
        [M:DOO1]ALH5 = [M:DOO1]ALH5
    Endcase
    Affzo [M:DOO1]
  Endif
Return

########################################
Subprog AM_ALHX(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog IB_ALHX
End

