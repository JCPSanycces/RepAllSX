#<AdxTL>@(#)8.0.0.0 $Revision$
#####################################################################################################
# UTITC40                                                                 Module Tronc Commun       #
#                                                                                                   #
# But de l'utilitaire :                                                                             #
#    Corriger les affectations forcées dans la table MTOLINK :                                      #
#    - mettre FMIFLG à Non si la demande n'est pas de contremarque                                  #
#    - mettre FRCFLG à Non si la demande est une commande ouverte (SOC)                             #
#    - mettre FRCFLG à Non si la ressource est une commande ouverte (POC)                           #
#                             et la demande n'est pas de contremarque                               #
#                                                                                                   #
#####################################################################################################
# Issue 80971 - 2012-06-19 by GH
#####################################################################################################

Call MAJ_UTITC42
End

#-------------------------------------------------------------------
Subprog MAJ_UTITC42

Local Char DOSSIER(30)
DOSSIER=nomap

Call SAIDOS(DOSSIER,"UTITC42 - Correction [MLK]FRCFLG") From SAIDOS

If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTITC42 - Correction [MLK]FRCFLG") From LECFIC
  Call EXE_UTITC42(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif

End

#-------------------------------------------------------------------
Subprog EXE_UTITC42(DOSSIER)
Value Char    DOSSIER

If filinfo(filpath("FIL","MTOLINK","fde", DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","ORDERS","fde", DOSSIER),0)<=0 : End : Endif

Call ECR_TIME("UTITC42 : Correction FRCFLG=2 in table MTOLINK : Started") From DOSSUB

Local File =DOSSIER+".MTOLINK"   [MLK]
Local File =DOSSIER+".ORDERS"    [ORD]

Local Integer NBENR, RW1, RW2

Trbegin [MLK]
  For [MLK]reckey Where FRCFLG=2
    RW1=0 : RW2=0
    Filter [ORD] Where STOFCY=[F:MLK]STOFCY & WIPTYP=[F:MLK]DWIPTYP
    Read [ORD]ORD3 = [F:MLK]STOFCY;[F:MLK]DEMTYP;[F:MLK]DEMNUM;[F:MLK]DEMLIN;[F:MLK]DEMSEQ
    If !fstat
       If [F:ORD]ABBFIL="SOC"
          [F:MLK]FRCFLG=1 : RW1=1
       Endif
       If [F:ORD]FMI=1 & [F:MLK]FMIFLG<>1
          [F:MLK]FMIFLG=1 : RW2=1
       Endif 
       If RW1 | RW2
          GCLE =[F:MLK]STOFCY-[F:MLK]ITMREF-num$([F:MLK]DEMTYP)-[F:MLK]DEMNUM-num$([F:MLK]DEMLIN)-num$([F:MLK]DEMSEQ)-[F:ORD]ABBFIL
       Elsif [F:MLK]FMIFLG<>2 & [F:MLK]FRCFLG=2
          Filter [ORD] Where STOFCY=[F:MLK]STOFCY & WIPTYP=[F:MLK]RWIPTYP
          Read [ORD]ORD3 = [F:MLK]STOFCY;[F:MLK]RESSTYP;[F:MLK]RESSNUM;[F:MLK]RESSLIN;[F:MLK]RESSSEQ
          If !fstat & [F:ORD]ABBFIL="POC"
             [F:MLK]FRCFLG=1 : RW1=1
             GCLE =[F:MLK]STOFCY-[F:MLK]ITMREF-num$([F:MLK]RESSTYP)-[F:MLK]RESSNUM-num$([F:MLK]RESSLIN)-num$([F:MLK]RESSSEQ)-[F:ORD]ABBFIL
          Endif
       Endif
       If RW1 | RW2
           Rewrite [MLK]
           If !fstat : NBENR+=1 : Endif
           Call ECR_TRACE(GCLE-":"-string$(RW1,"FRCFLG->1")-string$(RW2,"FMIFLG->1"),fstat<>0) From GESECRAN
       Endif
    Endif
  Next

  Filter [ORD]
Commit

Call ECR_TIME("UTITC42 : Correction FRCFLG=2 in table MTOLINK : Ended"-"("-num$(NBENR)+" records processed"-")") From DOSSUB

End

#-----------------------------------------------------------------------------------------------
Subprog PATCH(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","MTOLINK","fde",DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","ORDERS","fde",DOSSIER),0)<=0 : End : Endif

If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat : Raz [F:ADS] : Endif

Call EXE_UTITC42(DOSSIER)

End
#-----------------------------------------------------------------------------------------------
#------------------------------------------------------------------#
# Pour exécution depuis dosmaj (validation dossier)                #
#------------------------------------------------------------------#
Subprog UTI_MOUL(APPLI)
Value Char    APPLI

If filinfo(filpath("FIL","MTOLINK","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","ORDERS","fde",APPLI),0)<=0 : End : Endif

If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif

Read [ADS]DOSSIER=APPLI : If fstat : Raz [F:ADS] : Endif

Call EXE_UTITC42(APPLI)

End
