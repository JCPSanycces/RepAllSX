Subprog LEC_GTE_LEG(LEG,TYP)
Value Char LEG
Value Char TYP
fstat = 0
#JASMI - 2017-04-24 - Req. 122336 - START
#If [F:GTE]TYP<>TYP | [F:GTE]LEG<>LEG
# If GNBLEG=1 : LEG = GDOSLEG(1) : Endif
# Read [GTE]GTE0 = TYP;LEG
# If fstat
#  Read [GTE]GTE0 = TYP;""
# Endif
#Endif
If !func TRTHRCPT.IS_X3PEOPLE_EXT_ACC() #if Not X3 People and Not External Accounting
 If [F:GTE]TYP<>TYP | [F:GTE]LEG<>LEG
  If GNBLEG=1 : LEG = GDOSLEG(1) : Endif
  Read [GTE]GTE0 = TYP;LEG
  If fstat
   Read [GTE]GTE0 = TYP;""
  Endif
 Endif
Endif
#JASMI - 2017-04-24 - Req. 122336 - END

End

