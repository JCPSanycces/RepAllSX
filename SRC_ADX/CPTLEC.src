Subprog LEC_TVT_LEG(LEG,TVTCOD)
Value Char LEG
Value Char TVTCOD
If TVTCOD="" : fstat = 5 : End : Endif
fstat = 0
If [F:TVT]VAT<>TVTCOD | [F:TVT]LEG<>LEG
 If GNBLEG=1 : LEG = GDOSLEG(1) : Endif
 Read [TVT]TVT0 = TVTCOD;LEG
 If fstat
  If [F:TVT]VAT<>TVTCOD | [F:TVT]LEG<>""
   Read [TVT]TVT0 = TVTCOD;""
  Else
   fstat = 0
  Endif
 Endif
Endif
End

