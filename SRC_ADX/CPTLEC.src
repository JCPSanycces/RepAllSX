Subprog PARAM(LEG,PARAM,VALEUR)
Value Char    LEG
Value Char    PARAM
Variable Char VALEUR()

$PARAM_
If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
If clalev([F:ADP])=0 : Local File ADOPAR [ADP] : Endif
VALEUR = ""
Read [ADP]ADP1 = PARAM
If fstat : End : Endif

Read [ADW]ADW0 = "*";LEG;PARAM
If fstat
 Read [ADW]ADW0 = "";"";PARAM
Endif
If !fstat
 VALEUR = [F:ADW]VALEUR
Else
 VALEUR = ""
Endif
End

