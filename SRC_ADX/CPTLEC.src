Subprog LEC_ACV(COD,FLG)
Value    Char    COD
Variable Integer FLG
fstat = 0
If [F:ACV]CODACT<>COD
 Read [ACV]CODACT = COD
Endif
If fstat or [F:ACV]FLACT<>2
 FLG = 0
Else
 FLG = 1
Endif
End

