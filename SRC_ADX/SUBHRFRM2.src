$FILTRE_MAT
OK = 0
#66411
## Contrôle de l'appartenance au site
#For [F:CTR] Where REFNUM=MAT & CTRNUM=CTR & CTRDAT<=[M:DIA]DATCPT &
#&                 (XITDAT>=[M:DIA]DATCPT-30 | XITDAT=[0/0/0])
# If [M:DIA]FCY<>""
#  If [M:DIA]FCY=[F:CTR]ETRFCY
