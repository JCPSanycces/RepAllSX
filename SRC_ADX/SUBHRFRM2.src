#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "INIT_DIA"     : Gosub INIT_DIA
 When "EXEC"         : Gosub EXEC
 When "CONTROLE"     : Gosub CONTROLE
Endcase
Return

$INIT_DIA
If clalev([F:ADI])=0  : Local File ATABDIV      [ADI]  : Endif
If clalev([F:BAN])=0  : Local File BANK         [BAN]  : Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
If clalev([F:HRSDP])=0  : Local File SOLDPAY      [HRSDP]  : Endif
#If clalev([F:SDP])=0  : Local File SOLDPAY      [SDP]  : Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
If clalev([F:RIB])=0  : Local File EMPLORIB     [RIB]  : Endif
If clalev([F:ID])=0   : Local File EMPLOID      [ID]   : Endif
If clalev([F:CPT])=0  : Local File EMPLOCPT     [CPT]  : Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
If clalev([F:HRCTR1])=0 : Local File EMPLOCTR     [HRCTR1] : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR     [HRCTR]  : Endif
#If clalev([F:CTR1])=0 : Local File EMPLOCTR     [CTR1] : Endif
#If clalev([F:CTR])=0  : Local File EMPLOCTR     [CTR]  : Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- START
If clalev([F:HRSTL])=0  : Local File STLPAY       [HRSTL]  : Endif
#If clalev([F:STL])=0  : Local File STLPAY       [STL]  : Endif
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- END
If clalev([F:FGR])=0  : Local File FACGROUP     [FGR]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY     [FCY]  : Endif
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- START
If clalev([F:HRFRM])=0  : Local File HRFRMPAY       [HRFRM]  : Endif
#If clalev([F:FRM])=0  : Local File FRMPAY       [FRM]  : Endif
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- END
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
If clalev([F:HRPOA])=0  : Local File POPULA       [HRPOA]  : Endif
#If clalev([F:POA])=0  : Local File POPULA       [POA]  : Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
If clalev([F:ACC])=0  : Local File ACCES        [ACC]  : Endif
If !clalev([F:TCU])   : Local File TABCUR       [TCU]  : Endif

# (C) PROSPER 23/07/10 - Prise en compte des infos comptables au contrat
If clalev([F:CPR])=0  : Local File EMPLOCTRCPT  [CPR]  : Endif

Return

$CONTROLE
If GOK<1
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

$EXEC

Local Char    SYMBOLE(80)
Local Char    NUMBOR (15), OLDBOR(15)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Local Char    MAT(GLONEML), CTR(GLONHRCTR)
#Local Char    MAT(GLONMAT), CTR(GLONCTR)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
Local Char    SITE(GLONFCY)
Local Char    VALPAR(50), TEXTPAY(30)
Local Integer MAXLIGNE, NUMLIGNE, OK, PLEIN, BANVIDE
Local Decimal TOLERE ,TOTAL, MONT
Local Integer JOURD, JOURF

Local Decimal MONTANT
Local Char    DEVSOC ([V]GLONCUR)
Local Integer TYPCOURS
Local Integer STAT
Local Integer FLG

Local Integer  TYPPAYN1
#MIPEA - 2017-05-19- US X3-11287- START
Local Decimal  MTMAT, CURRND, MTRESTE, PCTMAT, AMTMAT
#Local Decimal  MTMAT, CURRND, MTRESTE, PCTMAT
#MIPEA - 2017-05-19- US X3-11287- END
Local Shortint MATLIG

#73280
Local Char FCYH (GLONFCY)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- START
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Read [ADI]CODE=10365;[M:DIA]TYPPAY
#Read [ADI]CODE=10365;[M:DIA]TYPPAY
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- END
#Read [ADI]CODE=365;[M:DIA]TYPPAY
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
[L]TYPPAYN1=[F:ADI]N1
#55572
#Call LECTEXTRA([L]TEXTPAY,"ATABDIV","","365",[M:DIA]TYPPAY) From ATEXTRA
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- START
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Filter [ADI] Where NUMTAB=10365 & LEG=GCURLEG
Call LECTEXTRA([L]TEXTPAY,"ATABDIV","LNGDES","10365",[M:DIA]TYPPAY) From ATEXTRA
Filter [ADI]
#Call LECTEXTRA([L]TEXTPAY,"ATABDIV","LNGDES","10365",[M:DIA]TYPPAY) From ATEXTRA
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- END
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377-END

#Devise société
Read[CPY]CPY0=[M:DIA]CPY
If fstat=0
 DEVSOC=[F:CPY]ACCCUR
Endif

#Type de cours
Call PARAM("","TYPCOURS",VALPAR)From ADOVAL
TYPCOURS=val(VALPAR)

# Devise de la banque
Call LECTURE("TCU",[M:DIA]CUR,"") From CONTOBJ
[L]CURRND=[F:TCU]CURRND

If [M:DIA]STRDATPOA<>[00/00/00] & [M:DIA]ENDDATPOA<>[00/00/00]
 JOURD=day([M:DIA]STRDATPOA)
 If [M:DIA]ENDDATPOA=eomonth([M:DIA]ENDDATPOA)
  JOURF=31
 Else
  JOURF=day([M:DIA]ENDDATPOA)
 Endif
Endif
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START - MESSAGES TO BE AMENDED BELOW TO LOCAL MENU
Call OUVRE_TRACE("Génération des règlements") From LECFIC
Call ECR_TRACE("Génération des règlements",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call PARAM("","AMTFRM",VALPAR)From ADOVAL
TOLERE=val(VALPAR)

#73280
If [M:DIA]FCY<>""
 FCYH=[M:DIA]FCY
Else
 Call LECTURE("CPY",[M:DIA]CPY,"") From CONTOBJ
 FCYH=[F:CPY]MAIFCY
Endif
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 If !find(FCYH,GUSRFCY(1..GNBAUZ))
  Call ECR_TRACE(mess(4,104,1)-":"-FCYH,1) From GESECRAN        : #  Vous n'avez pas les droits pour ce code
  GOK=0 : Return
 Endif
Endif
#

Gosub AFFECTE_COMPTEUR
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
SYMBOLE = "HRFRM"+NUMBOR
#SYMBOLE = "FRM"+NUMBOR
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
Lock =SYMBOLE
Call DEBTRANS From GLOCK
Gosub GENERE_BORDEREAU
Unlock =SYMBOLE
Call FERME_TRACE From LECFIC
Return

$AFFECTE_COMPTEUR
Local Char    SOCIETE(GLONCPY)
Local Char    COMPTEUR(5)
Local Integer STAT
Read [F:BAN]BAN0=[M:DIA]BAN
If fstat=0
 SOCIETE= [F:BAN]CPY
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
#JASMI - 2017-03-23 - START
# Read [TCA]TCA0 = 2;[F:CPY]LEG;[M:HRFRM1]CPY : # Module paye
## Read [TCA]TCA0 = 2 : # Module paye
##MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
# COMPTEUR = [F:TCA]CODNUM(0)
 Call LECTCA(15,STAT) From SUBTCA
 If !STAT
  GMESSAGE = mess(3,10702,1) : # Compteur matricule non dÚfini
  GOK = 0 : Return
 Else
  COMPTEUR= [F:TCA]CODNUM(0)
 Endif
#JASMI - 2017-03-23 - END
 If COMPTEUR=""
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  GMESSAGE = mess(1,10704,1) : # Compteur bordereau non défini
#  GMESSAGE = mess(1,704,1) : # Compteur bordereau non défini
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  GOK = 0 : Return
 Endif
 Read [F:CPY]CPY0=SOCIETE
 If fstat=0
  Call NUMERO(COMPTEUR,[F:CPY]MAIFCY,[M:DIA]DATCPT,"",NUMBOR,STAT) From SUBANM
  If STAT
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
   GMESSAGE = mess(4,10702,1)-COMPTEUR : # "Erreur sur compteur"
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
   GOK = 0 : Return
  Endif
 Endif
Endif
Return

$GENERE_BORDEREAU
GOK      = 1
TOTAL    = 0
NUMLIGNE = 1
PLEIN    = 0
# 27869

#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
MAXLIGNE = dim([M:HRFRM1]REFNUM)
Trbegin [HRFRM]
OLDBOR = [F:HRFRM]NUMFRM
Raz [F:HRFRM]
[F:HRFRM]NUMFRM = NUMBOR
[F:HRFRM]CPY = SOCIETE
[F:HRFRM]BAN = [M:DIA]BAN
#73280
[F:HRFRM]FCYFRM=FCYH
[F:HRFRM]DAT = [M:DIA]DATCPT
[F:HRFRM]MODPAY =[M:DIA]MODPAY
[F:HRFRM]STA = 1
[F:HRFRM]CUR = [M:DIA]CUR

If dim([M:DIA]EXPDAT) > 0 : [F:HRFRM]EXPDAT = [M:DIA]EXPDAT : Endif
If dim([M:DIA]PRODAT) > 0 : [F:HRFRM]PRODAT = [M:DIA]PRODAT : Endif
If dim([M:DIA]BANPRO) > 0 : [F:HRFRM]BANPRO = [M:DIA]BANPRO : Endif
If dim([M:DIA]FASPRO) > 0 : [F:HRFRM]FASPRO = [M:DIA]FASPRO : Endif

If dim([F:HRFRM]CREDAT)>0 : [F:HRFRM]CREDAT = date$ : Endif
If dim([F:HRFRM]CREUSR)>0 : [F:HRFRM]CREUSR = GUSER : Endif
If dim([F:HRFRM]CRETIM)>0 : [F:HRFRM]CRETIM = time  : Endif
Gosub LIGNES_BORDEREAU
#Au moins une ligne pour écrire le bordereau...
If NUMLIGNE>1
 [F:HRFRM]TOT = TOTAL
 Write [F:HRFRM]
 If fstat
  GOK = 0 : Call FSTA("HRFRM") From GLOCK : Goto AB_TR1
 Endif
 If GOK<1 : Goto AB_TR1 : Endif
 Read[F:HRFRM]FRM0=NUMBOR
Else
 Call ECR_TRACE(mess(4,10704,1)-[M:DIA]MODPAY,0) From GESECRAN
 #Aucun règlement à effectuer par
 If OLDBOR<>""
  # On se repositionne sur le bordereau à partir duquel on a lancé la proposition
  Read[F:HRFRM]FRM0=OLDBOR
 Else
  Read[F:HRFRM]FRM0 Last
 Endif
Endif
If PLEIN
 Call ECR_TRACE(mess(8,10704,1),0) From GESECRAN
#MAXLIGNE = dim([M:FRM1]REFNUM)
#Trbegin [FRM]
#OLDBOR = [F:FRM]NUMFRM
#Raz [F:FRM]
#[F:FRM]NUMFRM = NUMBOR
#[F:FRM]CPY = SOCIETE
#[F:FRM]BAN = [M:DIA]BAN
##73280
#[F:FRM]FCYFRM=FCYH
#[F:FRM]DAT = [M:DIA]DATCPT
#[F:FRM]MODPAY =[M:DIA]MODPAY
#[F:FRM]STA = 1
#[F:FRM]CUR = [M:DIA]CUR
#If dim([F:FRM]CREDAT)>0 : [F:FRM]CREDAT = date$ : Endif
#If dim([F:FRM]CREUSR)>0 : [F:FRM]CREUSR = GUSER : Endif
#If dim([F:FRM]CRETIM)>0 : [F:FRM]CRETIM = time  : Endif
#Gosub LIGNES_BORDEREAU
##Au moins une ligne pour écrire le bordereau...
#If NUMLIGNE>1
# [F:FRM]TOT = TOTAL
# Write [FRM]
# If fstat
#  GOK = 0 : Call FSTA("FRM") From GLOCK : Goto AB_TR1
# Endif
# If GOK<1 : Goto AB_TR1 : Endif
# Read[F:FRM]FRM0=NUMBOR
#Else
# Call ECR_TRACE(mess(4,704,1)-[M:DIA]MODPAY,0) From GESECRAN
# #Aucun règlement à effectuer par
# If OLDBOR<>""
#  # On se repositionne sur le bordereau à partir duquel on a lancé la proposition
#  Read[F:FRM]FRM0=OLDBOR
# Else
#  Read[F:FRM]FRM0 Last
# Endif
#Endif
#If PLEIN
# Call ECR_TRACE(mess(8,704,1),0) From GESECRAN
 #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 #Bordereau plein
Endif
Commit
Return

$AB_TR1
Rollback
Return

$LIGNES_BORDEREAU
#76297 : PE pour personnalisation du chargement
[V]GPE = 0
GPOINT = "LIGNES_SPE" : Gosub ENTREE From EXEFNC
If [V]GPE = 1 : Return : Endif

#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
For [HRCTR1]CTR0(2)
 MAT  = [F:HRCTR1]REFNUM

 CTR  = [F:HRCTR1]CTRNUM
 Read [F:ID]ID0=MAT
 If !fstat
  Gosub FILTRE_MAT
 Else
  Call ECR_TRACE(mess(23,100,1)-MAT,0) From GESECRAN : #  Fiche inexistante
  OK = 0
 Endif
 If OK
  Read [HRSDP]SDP0=MAT;CTR
  If fstat
   Raz [F:HRSDP]
   [F:HRSDP]EMP    = MAT
   [F:HRSDP]CTRNUM = CTR
   [F:HRSDP]FCY    = SITE
   [F:HRSDP]SRV    = [F:HRCTR]ETRSRV
   [F:HRSDP]CODACS = [F:ID]CODACS
   Write [HRSDP]
   If fstat : Call FSTA("HRSDP") From GLOCK : OK = 0 : Endif
  Endif
  If OK
   Gosub AFFECTE_MONTANT
   If [L]OK
    #**
    #100950 : This correction is on stand by because PBA don't want it for the moment... (CF. SAM record)
    #Filter [RIB] Where REFNUM=[L]MAT & find(TYPPAY,[M:DIA]TYPPAY,"")<>0 & find(CPYBAN,[M:DIA]BAN,"")<>0
    #**

#MIPEA - 2017-09-14- US X3-33811- START
Filter [F:RIB] Where REFNUM=[L]MAT & find(TYPPAY,[M:DIA]TYPPAY,"")<>0
&                    & MODSTL=[M:DIA]MODPAY
&         Order By Key CLE=TYPPAY;NUMLIG Asc
#Filter [RIB] Where REFNUM=[L]MAT & find(TYPPAY,[M:DIA]TYPPAY,"")<>0
#&                    & MODSTL=[M:DIA]MODPAY
#&         Order By Key CLE=TYPPAY Desc
#MIPEA - 2017-09-14- US X3-33811- END
#MIPEA - 2017-09-14- US X3-33811- START
Local Integer RIBCOUNT
Local Integer FORCOUNT
RIBCOUNT=rowcount([RIB])
#MIPEA - 2017-09-14- US X3-33811- END

    [L]MATLIG=rowcount([RIB])
    If ![L]MATLIG
     Call ECR_TRACE(MAT-mess(6,10704,1),0) From GESECRAN
     # Matricule aucune informations bancaires
    Elsif [L]NUMLIGNE+[L]MATLIG>[L]MAXLIGNE
     [L]PLEIN=1
     Break
    Else
     [L]MTRESTE=[L]MTMAT
     [L]PCTMAT =0
#MIPEA - 2017-05-19- US X3-11287- START
     [L]AMTMAT =0
#MIPEA - 2017-05-19- US X3-11287- END
     For [RIB]CLE(1)
      For [RIB]CLE
#MIPEA - 2017-09-14- US X3-33811- START
      FORCOUNT+=1
#MIPEA - 2017-09-14- US X3-33811- END
       Case [F:RIB]CPYBAN
        When [M:DIA]BAN : [L]BANVIDE=0
        When ""         : [L]BANVIDE=1
       Endcase
       If BANVIDE & TOTAL+[L]MTMAT>=[M:DIA]AMT+TOLERE
         Call ECR_TRACE(mess(9,10704,1)-MAT,0) From GESECRAN
         # Règlement non traité car pas de banque renseignée pour
         Break 2
       Endif
#MIPEA - 2017-05-19- US X3-11287- START
       If [F:RIB]PAYSPT < 2
         [L]MONT   =arr([L]MTMAT*[F:RIB]PAYPCT*0.01,[L]CURRND)
         [L]PCTMAT+=[F:RIB]PAYPCT
         If [L]MONT>[L]MTRESTE | [L]PCTMAT=100 : [L]MONT=[L]MTRESTE : Endif
         [L]MTRESTE-=[L]MONT
       Else
         [L]MONT   =arr([F:RIB]PAYAMT,[L]CURRND)
         [L]AMTMAT+=[F:RIB]PAYAMT
         If [L]MONT>[L]MTRESTE | [L]AMTMAT=[L]MTRESTE | [F:RIB]PAYAMT=0 | FORCOUNT=RIBCOUNT : [L]MONT=[L]MTRESTE : Endif
         [L]MTRESTE-=[L]MONT
       Endif
       If [L]MONT
        Gosub ECRIT_LIGNES
       Endif
      Next
      Break : # on ne fait pas TYPPAY="" si on a trouvé TYPPAY<>""
     Next
    Endif
   Endif
  Endif
 Endif
Next
