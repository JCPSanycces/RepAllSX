Subprog D_INI(VALEUR)
Variable Char    VALEUR()
If dim([M:DIA]ALLFCY)>0
 If [M:DIA]ALLFCY=2 : Effzo FCY : Grizo FCY : Else : Actzo FCY : Endif
Endif
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo FCY : Grizo FCY
Else
 Actzo FCY
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If [M:DIA]ALLFCY=2 : mkstat = 1 : End : Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Read [F:FCY]FCY0=VALEUR
If fstat=0
 If [F:FCY]LEGCPY<>[M:DIA]CPY
   GMESSAGE= VALEUR-mess(30,106,1)-[F:FCY]LEGCPY :# ce site est dans la société
   mkstat=2 : End
 Endif
Endif
End

Subprog D_DATCPT(VALEUR)
Variable Date    VALEUR
VALEUR=date$
End

Subprog AS_TYPPAY(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 # 36772
 #Filter [F:ADI] Where NUMTAB=365
 #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- START
  Filter [F:ADI] Where NUMTAB=10365 & DEFVAL=2 & LEG=GCURLEG
#  Filter [F:ADI] Where NUMTAB=10365 & DEFVAL=2
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- END
# Filter [F:ADI] Where NUMTAB=365 & DEFVAL=2
 #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 Read [F:ADI] First
 If fstat=0
  VALEUR=[F:ADI]CODE
 Endif
 Filter [F:ADI]
Endif
End

Subprog AM_TYPPAY(VALEUR)
Variable Char    VALEUR()
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Read [ADI]CODE=10365;VALEUR
#Read [ADI]CODE=365;VALEUR
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
#MIPEA - 2017-03-23- US X3-11264 ST X3-25377- START
  GCURLEG = [F:ADI]LEG
#MIPEA - 2017-03-23- US X3-11264 ST X3-25377- END
If fstat=0
 If [F:ADI]N1=1 :#Acompte
  Effzo[M:DIA]AMT
  Grizo[M:DIA]AMT
  Actzo[M:DIA]20
 Elsif [F:ADI]N1<0 :#Acompte 13ème mois
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  GMESSAGE=mess(3,10704,1) :#type non autorisé
#  GMESSAGE=mess(3,704,1) :#type non autorisé
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  mkstat=2 : End
 Else
  Effzo[M:DIA]20
  Grizo[M:DIA]20
  Actzo[M:DIA]AMT
 Endif
Endif

#JOJAC / HEGES - 2017-06-06 - X3-42852 - START
If GCURLEG <> 'BRI'
#MIPEA - 2018-04-24-  X3-81201- START
  Chgfmt [M:DIA]EXPDAT With  '-D:MM[/]DD[/]YYYY'
  Chgfmt [M:DIA]PRODAT With  '-D:MM[/]DD[/]YYYY'
#  Chgfmt [M:DIA]EXPDAT With "-D:"+GFMDAT4
#  Chgfmt [M:DIA]PRODAT With "-D:"+GFMDAT4
#MIPEA - 2018-04-24-  X3-81201- END
#JASMI - 2017-07-21 - X3-49730 - START
#  Chgfmt [M:DIA]BANPRO With "-L:10365"
#  Chgfmt [M:DIA]FASPRO With "-L:10365"
  Chgfmt [M:DIA]BANPRO With "-LA:11826"
  Chgfmt [M:DIA]FASPRO With "-LA:1"
Else
#MIPEA - 2018-04-24-  X3-81201- START
  Chgfmt [M:DIA]EXPDAT With 'D:MM[/]DD[/]YYYY'
  Chgfmt [M:DIA]PRODAT With 'D:MM[/]DD[/]YYYY'
#  Chgfmt [M:DIA]EXPDAT With "D:"+GFMDAT4
#  Chgfmt [M:DIA]PRODAT With "D:"+GFMDAT4
#MIPEA - 2018-04-24-  X3-81201- END
  Chgfmt [M:DIA]BANPRO With "LA:11826"
  Chgfmt [M:DIA]FASPRO With "LA:1"
#JASMI - 2017-07-21 - X3-49730 - END
Endif
#JOJAC / HEGES - 2017-06-06 - X3-42852 - END

End

Subprog AM_BAN(VALEUR)
