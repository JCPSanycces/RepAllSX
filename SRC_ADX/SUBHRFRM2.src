Subprog AM_ENDDATPOA(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:DIA]STRDATPOA
#Période incorrecte
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 GMESSAGE = mess(25,10702,1)
# GMESSAGE = mess(25,702,1)
 #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 mkstat = 2 : End
Endif
End

Subprog C_DATCPT(VALEUR)
Variable Date    VALEUR
If [M:DIA]STRDATPOA<>[00/00/00] & [M:DIA]ENDDATPOA<>[00/00/00]
 If VALEUR>[M:DIA]ENDDATPOA
 #La date des écritures doit être comprise entre le
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  GMESSAGE = mess(20,10704,1)-num$([M:DIA]STRDATPOA)-"et le"-num$([M:DIA]ENDDATPOA)
  mkstat=2 : End
 Elsif VALEUR<[M:DIA]STRDATPOA
  GMESSAGE = mess(20,10704,1)-num$([M:DIA]STRDATPOA)-"et le"-num$([M:DIA]ENDDATPOA)
#  GMESSAGE = mess(20,704,1)-num$([M:DIA]STRDATPOA)-"et le"-num$([M:DIA]ENDDATPOA)
#  mkstat=2 : End
# Elsif VALEUR<[M:DIA]STRDATPOA
#  GMESSAGE = mess(20,704,1)-num$([M:DIA]STRDATPOA)-"et le"-num$([M:DIA]ENDDATPOA)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  mkstat=2 : End
 Endif
Endif
End

