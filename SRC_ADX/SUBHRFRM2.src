Call C_BAN(VALEUR)From SUBHRFRM
#Call C_BAN(VALEUR)From SUBFRM
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
# 30749
If mkstat<>0 : End : Endif
#
[M:DIA]CUR=[F:BAN]CUR
Affzo[M:DIA]CUR
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
If clalev([F:CPY])=0 : Local File COMPANY  : Endif
If clalev([F:FCY])=0 : Local File FACILITY : Endif
If clalev([F:BAN])=0 : Local File BANK     : Endif
Call LECTURE("CPY",VALEUR,"") From CONTOBJ
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Call AM_FCYFRM([F:CPY]MAIFCY) From SUBHRFRM
#Call AM_FCYFRM([F:CPY]MAIFCY) From SUBFRM
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
[M:DIA]CUR=[F:BAN]CUR
Affzo[M:DIA]CUR
End

Subprog C_CPY(VALEUR)
