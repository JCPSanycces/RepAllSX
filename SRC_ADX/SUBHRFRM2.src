#   OK=1 : Break
#  Endif
# Endif
#Next
#If OK=0

#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 Filter [F:HRCTR] Where REFNUM=MAT & CTRNUM=CTR & CTRDAT<=[M:DIA]DATCPT
 Read [F:HRCTR]CTR0 Last
 Filter [F:HRCTR]
 If fstat=0
  If [M:DIA]FCY<>""
   If [M:DIA]FCY=[F:HRCTR]ETRFCY : OK=1 : Endif
  Else
   Read[F:FCY]FCY0=[F:HRCTR]ETRFCY
   If fstat=0 & [M:DIA]CPY=[F:FCY]LEGCPY : OK=1 : Endif
  Endif
 Endif

#Endif

If OK=0 : Return : Endif

SITE = [F:HRCTR]ETRFCY
# Filter [F:CTR] Where REFNUM=MAT & CTRNUM=CTR & CTRDAT<=[M:DIA]DATCPT
# Read [F:CTR]CTR0 Last
# Filter [F:CTR]
# If fstat=0
#  If [M:DIA]FCY<>""
#   If [M:DIA]FCY=[F:CTR]ETRFCY : OK=1 : Endif
#  Else
#   Read[F:FCY]FCY0=[F:CTR]ETRFCY
#   If fstat=0 & [M:DIA]CPY=[F:FCY]LEGCPY : OK=1 : Endif
#  Endif
# Endif
#
##Endif
#
#If OK=0 : Return : Endif
#
#SITE = [F:CTR]ETRFCY
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
Call CONTROLE(MAT,datesyst,CTR,"",OK,1) From DIVPAYE
If !OK : Return : Endif

## Contrôle de l'appartenance à la population
If [M:DIA]POP<>""
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 Read [HRPOA]POA0=[M:DIA]POP;MAT
# Read [POA]POA0=[M:DIA]POP;MAT
 #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 If fstat : OK = 0 : Return : Endif
Endif

# Verif infos comptable
Read [F:CPT]CPT0=MAT
If fstat
 # (C) PROSPER 23/07/10 - Prise en compte des infos comptable contrat - contrôle complémentaire
 # Rien au niveau salarié ce qui en soi n'est pas normal ... on vérifie cependant un CPR
 # éventuel ...
 #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  Read [F:CPR]CPR0 = [F:HRCTR]REFNUM ; [F:HRCTR]CTRNUM ; [F:HRCTR]CTRDAT
# Read [F:CPR]CPR0 = [F:CTR]REFNUM ; [F:CTR]CTRNUM ; [F:CTR]CTRDAT
 #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 If fstat
    # Ben là, y'a rien ^^ , on ne précise pas qu'on a aussi fait la recherche sur le contrat,
    # qu'ils aillent donc contrôler déjà pourquoi on pas de CPT !
    OK = 0
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
    Call ECR_TRACE(MAT-mess(5,10704,1),0) From GESECRAN
#    Call ECR_TRACE(MAT-mess(5,704,1),0) From GESECRAN
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
    # Matricule sans informations comptable
 Endif
 Return
Endif

Return

$AFFECTE_MONTANT
If [L]TYPPAYN1=1
 Gosub TRAITE_ACOMPTE
 #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  If FLG=0 : [L]MTMAT=[F:HRCTR]INSAMT : Else [L]MTMAT=0 : Endif
# If FLG=0 : [L]MTMAT=[F:CTR]INSAMT : Else [L]MTMAT=0 : Endif
 #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
Else
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 [L]MTMAT=func SUBHRSLD.GETSOLDE([L]TYPPAYN1)
# [L]MTMAT=func SUBSLD.GETSOLDE([L]TYPPAYN1)
 #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
Endif
Call CONVERT( [L]DEVSOC,[M:DIA]CUR,[L]DEVSOC,[L]TYPCOURS,datesyst,[L]MTMAT,[L]MTMAT
&           , [L]STAT
&           ) From TRTDEV
If STAT
 GMESSAGE = mess(34,110,1)-DEVSOC : # "Erreur de conversion en devise"
 OK = 0 : Return
Endif

If [L]MTMAT<=0 : [L]OK=0 : Endif
Return

$ECRIT_LIGNES

#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- START
Raz [F:HRSTL]
[F:HRSTL]NUMFRM=NUMBOR
[F:HRSTL]NUMLIG=NUMLIGNE
[F:HRSTL]PYRDAT=[M:DIA]DATCPT
[F:HRSTL]TYPPAY=[M:DIA]TYPPAY
[F:HRSTL]REFNUM=MAT
[F:HRSTL]CTRNUM=CTR
#Raz [F:STL]
#[F:STL]NUMFRM=NUMBOR
#[F:STL]NUMLIG=NUMLIGNE
#[F:STL]PYRDAT=[M:DIA]DATCPT
#[F:STL]TYPPAY=[M:DIA]TYPPAY
#[F:STL]REFNUM=MAT
#[F:STL]CTRNUM=CTR
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- END
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Read [ADI]CODE=10387;[M:DIA]MODPAY : # LS 29/04/02
#Read [ADI]CODE=387;[M:DIA]MODPAY : # LS 29/04/02
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Case [F:ADI]N1
 When 1   : [F:HRSTL]NBRVRC = num$(NUMLIGNE) : # Chèque
 When 3,4 : [F:HRSTL]NBRVRC = mess(2,10362,1)  : # Virement
Endcase
#Case [F:ADI]N1
# When 1   : [F:STL]NBRVRC = num$(NUMLIGNE) : # Chèque
# When 3,4 : [F:STL]NBRVRC = mess(2,362,1)  : # Virement
#Endcase
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- START
[F:HRSTL]NBRVRC=[F:HRSTL]NBRVRC-[L]TEXTPAY
[F:HRSTL]FCY=SITE
[F:HRSTL]AMT=MONT
#35383
#TOTAL=TOTAL+MONT
[F:HRSTL]CRY=[F:RIB]BIDCRY
[F:HRSTL]BIDNUM=[F:RIB]BIDNUM
#[F:STL]NBRVRC=[F:STL]NBRVRC-[L]TEXTPAY
#[F:STL]FCY=SITE
#[F:STL]AMT=MONT
##35383
##TOTAL=TOTAL+MONT
#[F:STL]CRY=[F:RIB]BIDCRY
#[F:STL]BIDNUM=[F:RIB]BIDNUM
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- END
#FQ70222 - MABON 27/12/10 - Ajout du champ IBAN
Local Char IBAN
Call IBAN([F:RIB]BIDCRY,[F:RIB]BIDNUM,IBAN) From TRTBPA
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- START
[F:HRSTL]IBAN=IBAN
[F:HRSTL]BICCOD=[F:RIB]BICCOD
#[F:STL]IBAN=IBAN
#[F:STL]BICCOD=[F:RIB]BICCOD
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- END
#JASMI - 2015-08-05 - 109906 - START
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
If func AFNC.ACTIV("KGZA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- START
  [F:HRSTL]BANACCTYP=[F:RIB]BANACCTYP
  [F:HRSTL]BANBRCNUM=[F:RIB]BANBRCNUM
Endif
#JASMI - 2015-08-05 - 109906 - END
#Fin MABON
[F:HRSTL]PAB1=[F:RIB]PAB1
[F:HRSTL]PAB2=[F:RIB]PAB2
[F:HRSTL]BNF=[F:RIB]BNF
#  [F:STL]BANACCTYP=[F:RIB]BANACCTYP
#  [F:STL]BANBRCNUM=[F:RIB]BANBRCNUM
#Endif
##JASMI - 2015-08-05 - 109906 - END
##Fin MABON
#[F:STL]PAB1=[F:RIB]PAB1
#[F:STL]PAB2=[F:RIB]PAB2
#[F:STL]BNF=[F:RIB]BNF
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- END
# MABON - FQ65412- 28/12/10 - Calcul du code motif économique
Local Char    ECOCOD
Local Integer STAT
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Call CALC_BDFECOCOD(MAT,[F:RIB]BIDNUM,[F:HRFRM]BAN,MONT,[F:HRFRM]CUR,[M:DIA]DATCPT,[F:HRFRM]CPY,ECOCOD,STAT) From SUBHRFRM
#Call CALC_BDFECOCOD(MAT,[F:RIB]BIDNUM,[F:FRM]BAN,MONT,[F:FRM]CUR,[M:DIA]DATCPT,[F:FRM]CPY,ECOCOD,STAT) From SUBFRM
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- START
If STAT>0 Then [F:HRSTL]BDFECOCOD = ECOCOD : Endif
# Fin MABON
If dim([F:HRSTL]CREDAT)>0 : [F:HRSTL]CREDAT = date$ : Endif
If dim([F:HRSTL]CREUSR)>0 : [F:HRSTL]CREUSR = GUSER : Endif
If dim([F:HRSTL]CRETIM)>0 : [F:HRSTL]CRETIM = time  : Endif
#HEGES - 2017-12-07 - X3-47793- START
If GCURLEG = 'BRI'
  [F:HRSTL]BNKSRTCOD=[F:RIB]BNKSRTCOD
  [F:HRSTL]BACREF=[F:RIB]BACREF
  [F:HRSTL]BNKACCNAM=[F:RIB]BNKACCNAM
Endif
#HEGES - 2017-12-07 - X3-47793 - END
#If STAT>0 Then [F:STL]BDFECOCOD = ECOCOD : Endif
## Fin MABON
#If dim([F:STL]CREDAT)>0 : [F:STL]CREDAT = date$ : Endif
#If dim([F:STL]CREUSR)>0 : [F:STL]CREUSR = GUSER : Endif
#If dim([F:STL]CRETIM)>0 : [F:STL]CRETIM = time  : Endif
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- END

# 35383 Point d'entrée LIGBOR
GPOINT = "LIGBOR" : Gosub ENTREE From EXEFNC
If OK=0 : Return : Endif
TOTAL=TOTAL+MONT
# fin 35383

NUMLIGNE=NUMLIGNE+1
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- START
Write [HRSTL]
#Write [STL]
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- END
If fstat
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- START
 GOK = 0 : Call FSTA("HRSTL") From GLOCK : Goto AB_TR1
# GOK = 0 : Call FSTA("STL") From GLOCK : Goto AB_TR1
#MIPEA - 2017-03-08- US X3-11264 ST X3-25377- END
Else
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 Call ECR_TRACE(MAT-format$("K:40X",mess(7,10704,1)-[F:ID]NAM)-"/"-CTR,0) From GESECRAN
# Call ECR_TRACE(MAT-format$("K:40X",mess(7,704,1)-[F:ID]NAM)-"/"-CTR,0) From GESECRAN
 #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 #Matricule / Contrat : Règlement généré
 Gosub MAJ_SOLDE
Endif
Return

$MAJ_SOLDE
Raz [L]MONTANT, [L]STAT

#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
Readlock[HRSDP]SDP0=MAT;CTR
#Readlock[SDP]SDP0=MAT;CTR
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
If fstat=0
 #Conversion en monnaie société...
 Call CONVERT ([M:DIA]CUR,DEVSOC,DEVSOC,TYPCOURS,datesyst,MONT,MONTANT,STAT) From TRTDEV
 If !STAT
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  Call ADDSOLDE([L]TYPPAYN1,-[L]MONTANT) From SUBHRSLD
#  Call ADDSOLDE([L]TYPPAYN1,-[L]MONTANT) From SUBSLD
#MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
  If [L]TYPPAYN1=1 : Gosub MAJ_DETAIL : Endif
 Else
  GMESSAGE = mess(34,110,1)-DEVSOC : # "Erreur de conversion en devise"
  GOK = 0 : Return
 Endif
 #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
  Rewrite [HRSDP]
 Unlock [HRSDP]
 If fstat<>0
  GOK = 0 : Call FSTA("HRSDP") From GLOCK : Return
# Rewrite [SDP]
# Unlock [SDP]
# If fstat<>0
#  GOK = 0 : Call FSTA("SDP") From GLOCK : Return
  #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
 Endif
Endif
Return

$TRAITE_ACOMPTE
FLG=-1
MONTANT=0
 #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- START
 # Acompte permanent ?
If [F:HRCTR]INSAMT<>0 & [F:HRCTR]INSDAY<>0
 # Acompte permanent pour la période ?
 # 28744 : Salairé sorti après le jour de l'acompte ou salarié présent
 # & (gdat$([F:CTR]INSDAY,month([M:DIA]DATCPT),year([M:DIA]DATCPT))<=[F:ctr]XITDAT | [F:ctr]XITDAT=[0/0/0])
 If [F:HRCTR]INSDAY>=JOURD & [F:HRCTR]INSDAY<=JOURF & (gdat$([F:HRCTR]INSDAY,month([M:DIA]DATCPT),year([M:DIA]DATCPT))<=[F:HRCTR]XITDAT | [F:HRCTR]XITDAT=[0/0/0])
  Filter [HIP] Where EMP=MAT & CTRNUM=CTR & DAT>=[M:DIA]STRDATPOA & DAT<=[M:DIA]ENDDATPOA
  For [HIP]
   If [F:HIP]MODDAC=2
    FLG=1         :#Acompte permanent déjà été versé le :
    Call ECR_TRACE(MAT-mess(19,10704,1)-num$([F:HIP]DAT),0) From GESECRAN
    Break
   Endif
  Next
  If FLG<>1 : FLG=0 : Endif
  Filter [HIP]
 Endif
Endif
## Acompte permanent ?
#If [F:CTR]INSAMT<>0 & [F:CTR]INSDAY<>0
# # Acompte permanent pour la période ?
# # 28744 : Salairé sorti après le jour de l'acompte ou salarié présent
# # & (gdat$([F:CTR]INSDAY,month([M:DIA]DATCPT),year([M:DIA]DATCPT))<=[F:ctr]XITDAT | [F:ctr]XITDAT=[0/0/0])
# If [F:CTR]INSDAY>=JOURD & [F:CTR]INSDAY<=JOURF & (gdat$([F:CTR]INSDAY,month([M:DIA]DATCPT),year([M:DIA]DATCPT))<=[F:CTR]XITDAT | [F:CTR]XITDAT=[0/0/0])
#  Filter [HIP] Where EMP=MAT & CTRNUM=CTR & DAT>=[M:DIA]STRDATPOA & DAT<=[M:DIA]ENDDATPOA
#  For [HIP]
#   If [F:HIP]MODDAC=2
#    FLG=1         :#Acompte permanent déjà été versé le :
#    Call ECR_TRACE(MAT-mess(19,704,1)-num$([F:HIP]DAT),0) From GESECRAN
#    Break
#   Endif
#  Next
#  If FLG<>1 : FLG=0 : Endif
#  Filter [HIP]
# Endif
#Endif
 #MIPEA - 2017-03-06- US X3-11264 ST X3-25377- END
Return

$MAJ_DETAIL
Read [HIP]HIP0=[L]MAT;[L]CTR;[M:DIA]DATCPT;[L]NUMBOR;1
If fstat
 Raz [F:HIP]
 [F:HIP]EMP    = MAT
 [F:HIP]CTRNUM = CTR
 [F:HIP]DAT    = [M:DIA]DATCPT
 [F:HIP]FRM    = NUMBOR
 [F:HIP]POA    = MONTANT
 [F:HIP]MODDAC = 2 :#Automatique
 [F:HIP]TYPPOA = 1 :#Acompte standard
 Write [HIP]
Else
 [F:HIP]POA+=[L]MONTANT
 Rewrite [HIP] Curr
Endif
If fstat
 GOK = 0 : Call FSTA("HIP") From GLOCK : Return
Endif
Return

