If varmode([M]DISCRGACH,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DISCRGACH" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_DISCRGACH([M]DISCRGACH(indice)) From SUBSIP
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "DISCRGACH" : GZNUM = 2808 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>[M]DISCRGACH(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_DISCRGACH([M]DISCRGACH(indice)) From SUBSIP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DISCRGACH" : GZNUM = 2808 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NBPPL
mkstat = 0
zoncou = "NBPPL"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "SIPAR2"
Return

