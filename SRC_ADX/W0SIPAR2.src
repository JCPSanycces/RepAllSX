####################################
## Bloc tableau 6
####################################
Subprog SAI_NBSPL(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBSPL
mkstat = 0
zoncou = "NBSPL"

## Zone LIBINTTARV
mkstat = 0
zoncou = "LIBINTTARV"
[M]LIBINTTARV(indice) = SI_MES(175+nolign)

## Zone DISCRGVEN
mkstat = 0
zoncou = "DISCRGVEN"
WNUM = [M]DISCRGVEN(indice)
If varmode([M]DISCRGVEN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DISCRGVEN" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_DISCRGVEN([M]DISCRGVEN(indice)) From SUBSIP
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "DISCRGVEN" : GZNUM = 2808 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>[M]DISCRGVEN(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_DISCRGVEN([M]DISCRGVEN(indice)) From SUBSIP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DISCRGVEN" : GZNUM = 2808 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NBSPL
mkstat = 0
zoncou = "NBSPL"

End

