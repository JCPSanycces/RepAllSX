indice = 0
status = 1
zoncou = "NBSPL"
[M]NBSPL = 6
If varmode([M]NBSPL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBSPL" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBSPL
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBSPL = nolign
   status = 75
   Call SAI_NBSPL(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

