# Gestion du masque SIPAR2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone SPLACT
mkstat = 0
zoncou = "SPLACT"
indice = 0
IMPENT = [M]SPLACT
If varinit([M]SPLACT,indice)=0
 IMPENT = 1
Endif
[M]SPLACT = IMPENT

## Zone SPLCPT
mkstat = 0
zoncou = "SPLCPT"
indice = 0
IMPENT = [M]SPLCPT
If varinit([M]SPLCPT,indice)=0
 IMPENT = 1
Endif
[M]SPLCPT = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone LIBW1
mkstat = 0
zoncou = "LIBW1"
indice = 0
If varinit([M]LIBW1,indice)=0
 [M]LIBW1 = "-  HT 1"
Endif

## Zone SPLFINHT1
mkstat = 0
zoncou = "SPLFINHT1"
indice = 0
If varmode([M]SPLFINHT1,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPLFINHT1" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone SPLCRIHT1
mkstat = 0
zoncou = "SPLCRIHT1"
indice = 0
IMPENT = [M]SPLCRIHT1
WNUM = IMPENT
If varinit([M]SPLCRIHT1,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPLCRIHT1,indice)=0
 Call INICOMBO(2232) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_SPLCRIHT1(IMPENT) From SUBSIP
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,2232,1))))
 Endif
 [M]SPLCRIHT1(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPLCRIHT1" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPLCRIHT1(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "SPLCRIHT1" : GZNUM = 5935 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>IMPENT or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_SPLCRIHT1(IMPENT) From SUBSIP
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "SPLCRIHT1" : GZNUM = 5935 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif
[M]SPLCRIHT1 = IMPENT

