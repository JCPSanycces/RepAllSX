#<AdxTL>@(#)4.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
# Issue X3-107197 - 2018-09-12 by CBO : PARAMETER AND ACTIVITY CODE

$ACTION
Case ACTION
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
Endcase
Return


$CONTROLE
Local Integer OK
# Création factures d'escomptes/agios ?
OK=2 : Call OUINON(mess(22,8890,1),OK) From GESECRAN
If OK=2
 TMP = 1  :# Pour afficher des tempon/tempoff
Else
 FIN = 1
Endif
Return


$EXEC
Local Integer CAS : # 1:Création facture tiers client    2:Création facture fournisseur
Local Integer NBFAC
Local Char    TABTYPFAC(GLONGTE)(0..[M]NBLIG)
Local Char    TABNUMFAC(GLONVCR)(0..[M]NBLIG)
Local Decimal AMTIPT
If [F:PYH]SNS = 1 : # Dépense
 CAS = 2
Elsif [F:PYH]SNS = 2 : # Recette
 CAS = 1
Endif

If !GSERVEUR
 Call OUVRE_TRACE(mess(22,8890,1)) From LECFIC
Endif

Call CREFAC(CAS,[F:PYH]NUM,TABTYPFAC,TABNUMFAC,NBFAC)
If GOK = 1
 For I = 0 To NBFAC-1
  Call ECR_TRACE(mess(51,107,1)-TABTYPFAC(I)-TABNUMFAC(I),0) From GESECRAN
 Next
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
 TRA = 1
Endif
Return


#########################################################################
Subprog CREFAC(CAS,NUMREG,TABTYPFAC,TABNUMFAC,NBFAC)
#########################################################################
Value Integer    CAS              : # CAS=1 : Clients ; CAS=2 : Fournisseurs
Value Char       NUMREG           : # No de règlement
Variable Char    TABTYPFAC()      : # Type de facture
Variable Char    TABNUMFAC()(0..) : # Table numéro de factures générées
Variable Integer NBFAC            : # Nombre factures générées

Case CAS
 When 1
  If clalev([F:HEA])=0   : Local File SINVOICE   [HEA]  : Endif : # En-tête facture client
  If clalev([F:HEA1])=0  : Local File SINVOICE   [HEA1] : Endif : # En-tête facture client
  If clalev([F:HEA2])=0  : Local File SINVOICE   [HEA2] : Endif : # En-tête facture client
  If clalev([F:SIH])=0   : Local File SINVOICE   [SIH]  : Endif : # En-tête facture client
  If clalev([F:LIN])=0   : Local File BPCINVLIG  [LIN]  : Endif : # Lignes facture client
  If clalev([F:LIA])=0   : Local File BPCINVLIGA [LIA]  : Endif : # Lignes analytiques facture client
  If clalev([F:TPV])=0   : Local File TABSIVTYP  [TPV]  : Endif : # Type de facture clients
 When 2
  If clalev([F:HEA])=0   : Local File PINVOICE   [HEA]  : Endif : # En-tête facture fournisseur
  If clalev([F:HEA1])=0  : Local File PINVOICE   [HEA1] : Endif : # En-tête facture fournisseur
  If clalev([F:HEA2])=0  : Local File PINVOICE   [HEA2] : Endif : # En-tête facture fournisseur
  If clalev([F:PIH])=0   : Local File SINVOICE   [PIH]  : Endif : # En-tête facture fournisseur
  If clalev([F:LIN])=0   : Local File BPSINVLIG  [LIN]  : Endif : # Lignes facture fournisseur
  If clalev([F:LIA])=0   : Local File BPSINVLIGA [LIA]  : Endif : # Lignes analytique facture fournisseur
  If clalev([F:TPV])=0   : Local File TABPIVTYP  [TPV]  : Endif : # Type de facture fournisseurs
Endcase

If clalev([F:PYH])=0  : Local File PAYMENTH   [PYH]  : Endif : # En-tête règlement
If clalev([F:PYH2])=0 : Local File PAYMENTH   [PYH2] : Endif : # En-tête règlement
If clalev([F:PYD])=0  : Local File PAYMENTD   [PYD]  : Endif : # Ligne règlement
If clalev([F:PYD2])=0 : Local File PAYMENTD   [PYD2] : Endif : # Ligne règlement
If clalev([F:PYA])=0  : Local File PAYMENTA   [PYA]  : Endif : # Lignes règlement analytiques
If clalev([F:CDA])=0  : Local File GACCDENCOD [CDA]  : Endif : # Destinations comptables
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif : # Type de pièces
If clalev([F:DUD2])=0 : Local File GACCDUDATE [DUD2] : Endif : # Echéances
If clalev([F:ADI])=0  : Local File ATABDIV    [ADI]  : Endif : # Table diverse
If clalev([F:TVT])=0  : Local File TABVAT     [TVT]  : Endif : # Table des codes taxe
If clalev([F:TRA])=0  : Local File TABRATVAT  [TRA]  : Endif : # Table des taux de taxe
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif : # Table des cours devises
If clalev([F:GAU])=0  : Local File GAUTACE    [GAU]  : Endif
If clalev([F:GAD])=0  : Local File GAUTACED   [GAD]  : Endif
If clalev([F:GAG])=0  : Local File GAUTACEF   [GAG]  : Endif
If clalev([F:ANM])=0  : Local File ACODNUM    [ANM]  : Endif


Local Char    JOURNAL(GLONJOU)
Local Char    TYPPCE(GLONGTE)
Local Char    TAXE(GLONVAT)
Local Char    MESSA(80)
Local Char    PLANA(GLONCOA)
Local Char    CPTANA(GLONGAC)
Local Integer FLGANA, LASLIGANA
Local Integer STAT, I, NOL, OK, OK1, OKFAC
Local Integer XSOI, XFLGFUP
Local Integer TVA
Local Integer NLED
Local Integer OKCREFAC
Local Integer TLEDTYP(1..len(mess(0,2644,1)))
Local Integer NBLED
Local Decimal BASTVA, BASE, MONTANT
Local Decimal EXERCICE, PERIODE
Local Decimal VATRAT
Local Decimal COEF, CUMANA


Call DEBTRANS From GLOCK
Gosub TRANSAC
End

$TRANSAC
GOK=1
Trbegin [HEA], [LIN], [LIA], [PYD], [PYD2], [DUD]
 # Génération d'une note de débit/note de crédit pour imputation de type Cpt/Tiers
 ## NB : Côté fournisseurs : Note de crédit (INVTYP=4) = Facture (Agio)
 ##                          Note de débit  (INVTYP=3) = Avoir   (Escompte)
 ##      Côté clients      : Note de crédit (INVTYP=4) = Avoir   (Escompte)
 ##                          Note de débit  (INVTYP=3) = Facture (Agio)
 For [PYD]PYD0 Where NUM = NUMREG & ACCTYP = 3 & VCRNUM<>"" & NUMDEP=""
  Readlock [PYH]PYH0 = [F:PYD]NUM
  If fstat=1
   GOK=-1 : GLOCK="$PAYMENTH"-[F:PYH]NUM : Break
  Elsif fstat
   GOK=-0 : Call RSTA("PYH",[F:PYH]NUM) From GLOCK : Break
  Endif
  Raz [F:HEA]
  Call LEC_CPY([F:PYH]CPY) From CPTLEC
  ## En-tête de facture clients ou fournisseurs
  Call LEC_CDA_LEG([F:CPY]LEG,[F:PYD]DENCOD) From CPTLEC
  If [F:CDA]IPTDEP = 2 : OKCREFAC = 1 : Else OKCREFAC = 0 : Endif
  If OKCREFAC
   Gosub GNRFAC
   If OKFAC
    If GOK<1
     Break
    Else
     NBFAC += 1
     If CAS = 1
      TABTYPFAC(NBFAC-1)  = [F:HEA]SIVTYP
     Elsif CAS = 2
      TABTYPFAC(NBFAC-1)  = [F:HEA]PIVTYP
     Endif
     TABNUMFAC(NBFAC-1)  = [F:HEA]NUM
    Endif
   Endif
  Endif
 Next : # Boucle ligne d'imputation esc/agios donnant lieu à la création d'une facture
 If GOK<0   : Goto ROLL_TRANSAC
 Elsif !GOK : Goto AB_TRANSAC
 Endif
Commit
Return


$GNRFAC
## En-tête de facture...
## Type facture
OKFAC = 1
If CAS = 1
 If [F:CDA]BPCPIVTYP = ""
  ## Type de facture non défini pour la destination comptable
  GOK = 0 : Call ECR_TRACE(mess(23,8890,1),1) From GESECRAN : Return
 Endif
 [F:HEA]SIVTYP = [F:CDA]BPCPIVTYP
 Read [HEA2]SIH0 = [F:PYD]VCRNUM
 If fstat : OKFAC = 0 : Return : Endif
 Gosub INI_TSV
Else
 If [F:CDA]BPSPIVTYP = ""
  ## Type de facture non défini pour la destination comptable
  GOK = 0 : Call ECR_TRACE(mess(23,8890,1),1) From GESECRAN : Return
 Endif
 [F:HEA]PIVTYP = [F:CDA]BPSPIVTYP
 Read [HEA2]PIH0 = [F:PYD]VCRNUM
 If fstat : OKFAC = 0 : Return : Endif
 Gosub INI_TPV
Endif

If CAS = 1 : # Clients
 Case [F:HEA]INVTYP
  When 1, 3 : # Facture / note de débit
   [F:HEA]SNS = +1
  When 2, 4  : # Avoir / note de crébit
   [F:HEA]SNS = -1
 Endcase
 Elsif CAS = 2 : # Fournisseurs...
 Case [F:HEA]INVTYP
  When 1, 4 : # Facture / note de crédit
   [F:HEA]SNS = +1
   [F:HEA]PIHTYP = 1                  : # Catég. facture achat (LA533)
  When 2, 3  : # Avoir / note de débit
   [F:HEA]SNS = -1
   [F:HEA]PIHTYP = 3                   : # Catég. facture achat (LA533)
 Endcase
Endif

[F:HEA]CPY       = [F:HEA2]CPY        : # Société
[F:HEA]FCY       = [F:HEA2]FCY        : # Site financier
[F:HEA]ACCDAT    = [F:PYH]ACCDAT      : # Date comptable
[F:HEA]BPR       = [F:HEA2]BPR        : # Fournisseur
[F:HEA]BPRSAC    = [F:HEA2]BPRSAC     : # Collectif fournisseur
[F:HEA]CUR       = [F:PYD]CURLIN      : # Devise (la NC ou ND sera générée à la devise de l'échéance rattachée à l'esc/agio)
[F:HEA]CURTYP    = [F:HEA2]CURTYP     : # Type de cours
[F:HEA]RATDAT    = [F:HEA2]RATDAT     : # Date Cours
[F:HEA]RATDAT    = [F:HEA2]ACCDAT     : # Date taxe sur avoir
[F:HEA]VAC       = [F:HEA2]VAC        : # Régime de TVA
[F:HEA]STRDUDDAT = [F:HEA]ACCDAT      : # Départ échéance
[F:HEA]ORIMOD    = 3                  : # Module Tiers (LA14)
[F:HEA]STA       = 2                  : # Statut (LA509)
[F:HEA]PTE       = [F:HEA2]PTE        : # Conditions de paiement
[F:HEA]BPRPAY    = [F:HEA2]BPRPAY     : # Tiers payeur
[F:HEA]STRDATSVC = [F:HEA2]STRDATSVC  : # Date début prestation
[F:HEA]ENDDATSVC = [F:HEA2]ENDDATSVC  : # Date fin prestation
[F:HEA]INVNUM    = [F:HEA2]NUM        : # N° facture porteuse d'escompte comme facture d'origine
[F:HEA]DEP       = ""
[F:HEA]VATDAT    = [F:HEA2]ACCDAT     : # Date taxe sur avoir
For NLED=0 To len(mess(0,2644,1))-1
 [F:HEA]LED    = [F:HEA2]LED
 [F:HEA]CURLED = [F:HEA2]LED
 [F:HEA]RATMLT = [F:HEA2]RATMLT
 [F:HEA]RATDIV = [F:HEA2]RATDIV
Next
# Sections analytiques de la facture porteuse d'escompte/agios
For I=0 To dim([F:HEA]DIE)-1
 [F:HEA]DIE(I) = [F:HEA2]DIE(I)
 [F:HEA]CCE(I) = [F:HEA2]CCE(I)
Next
# Champs concernant l'adresse : initialisation par rapport à l'échéance porteuse d'escompte
For I=0 To dim([F:HEA]BPRNAM)-1
 [F:HEA]BPRNAM(I) = [F:HEA2]BPRNAM(I)
Next
For I=0 To dim([F:HEA]BPAADDLIG)-1
 [F:HEA]BPAADDLIG(I) = [F:HEA2]BPAADDLIG(I)
Next
[F:HEA]POSCOD = [F:HEA2]POSCOD
[F:HEA]CTY    = [F:HEA2]CTY
[F:HEA]SAT    = [F:HEA2]SAT
[F:HEA]CRY    = [F:HEA2]CRY
[F:HEA]CRYNAM = [F:HEA2]CRYNAM
[F:HEA]BPAINV = [F:HEA2]BPAINV
[F:HEA]BPAPAY = [F:HEA2]BPAPAY

#--- Détermination du type de pièce
Call EVALAUTO(CAS,[F:TPV]COD2,"GTE",TYPPCE)
If TYPPCE = ""
 Call ECR_TRACE(mess(27,110,1),1) From GESECRAN   # Type de pièce non défini
 GOK=0 : Return
Else
 [F:HEA]GTE = TYPPCE
Endif
Gosub CONT_GTE
If GOK<1 : Return : Endif

#--- Détermination du journal
Call EVALAUTO(CAS,[F:TPV]COD2,"JOU",JOURNAL)
If JOURNAL = "" : JOURNAL = [F:GTE]DEFJOU : Endif
If JOURNAL = ""
 ## Journal non défini
 GOK = 0 : Call ECR_TRACE(mess(53,141,1),1) From GESECRAN : Return
Else
 [F:HEA]JOU = JOURNAL
Endif
Gosub CONT_JOU
If GOK<1 : Return : Endif

[F:HEA]BPRDAT    = [F:HEA]ACCDAT  : # Date doc origine
[F:HEA]BPRVCR    = ""             : # doc origine

If CAS = 1
 [F:HEA]BPRFCT  = [F:HEA2]BPRFCT   : # Factor
 [F:HEA]TRSFAM  = [F:HEA2]TRSFAM   : # Famille mouvement
Elsif CAS = 2
 [F:HEA]PAZ       = [F:HEA2]PAZ    : # Bon à payer
 [F:HEA]CEEFLG    = [F:HEA2]CEEFLG :
 [F:HEA]PURTYP    = [F:HEA2]PURTYP : # Type d'achat
 [F:HEA]DAS2    = [F:HEA2]DAS2     : # DAS2
 If dim([F:HEA]SCUVCR)>0 & func AFNC.PARAM("ARGTAX",[F:HEA]CPY)="2"
  # Numérotation Argentine
  Gosub INIARG
  If [F:HEA]TYPVCR<>"" | [F:HEA]CLSVCR<>"" | [F:HEA]SCUVCR<>"" | [F:HEA]SEQVCR<>""
   [F:HEA]BPRVCR = [F:HEA]TYPVCR+[F:HEA]CLSVCR+[F:HEA]SCUVCR+[F:HEA]SEQVCR
  Endif
 Endif
Endif

## Initialisation champs FIY, PER rajouté en V150 pour optimisation
If dim([F:HEA]FIY)>0
 Call SETMAINREF([F:HEA]CPY,GTYPGEN,GTYPANA) From CPTDIV
 Call GETPERSOC([F:HEA]CPY,GTYPGEN,[F:HEA]ACCDAT,EXERCICE,PERIODE) From CPTSUB
 [F:HEA]FIY = EXERCICE
 [F:HEA]PER = PERIODE
Endif

# Numéro de facture
Call LEC_GTE_LEG([F:CPY]LEG,[F:HEA]GTE) From CPTLEC
If [F:GTE]COU = ""
 # Aucune séquence de numérotation définie pour le type de pièce [F:HEA]GTE
 Call ECR_TRACE(mess(103,106,1)-[F:HEA]GTE,1) From GESECRAN
 GOK=0 : Return
Endif

If CAS = 2 or
&  ((func AFNC.ACTIV("KAG") and func AFNC.PARAM("ARGNUM",[F:HEA]CPY)<>"2") or func AFNC.ACTIV("KAG") = 0)
 Call NUMERO([F:GTE]COU,[F:HEA]FCY,[F:HEA]ACCDAT,[F:HEA]JOU,[F:HEA]NUM,STAT) From SUBANM
 If STAT
  # Problème lors de la récupération du compteur
  Gosub MESSAGE From SUBANM
  Call ECR_TRACE(mess(60,199,1)-"("+[F:GTE]COU+") : "+MESSA,1) From GESECRAN
  GOK = 0 : Return
 Endif
Else
 ## Cas des factures clients pour l'Argentine
 Local Char    TYPDOC(GLONADI)
 Local Integer VU
 Filter [ADI] Where NUMTAB = 362
 For [ADI]CODE
  VU = instr(1,[F:ADI]A1,num$([F:HEA]INVTYP))
  If VU
   TYPDOC = [F:ADI]CODE : Break
  Endif
 Next
 Filter [ADI]
 If !VU
  ## Cette catégorie de facture n'est associée à aucun type de document
  GOK = 0 : Call ECR_TRACE(mess(4,8890,1),1) From GESECRAN
  Return
 Endif
 Call NUMEROARG([F:GTE]COU,[F:HEA]FCY,TYPDOC,2,[F:HEA]ACCDAT,[F:HEA]VAC,[F:HEA]NUM,[F:HEA]CAI,[F:HEA]DATVLYCAI,STAT) From SUBANMARG
 If GOK<0 : Return
 Elsif GOK<1 | STAT
  GOK=0
  If STAT
   Gosub MESSAGE From SUBANMARG
   GMESSAGE=mess(104,117,1)-"("+[F:GTE]COU+") : "+MESSA
  Endif
  Return
 Endif
Endif

#--- 26/05/00 GB : controle de chronologie du numéro de facture
Local Integer SEQ
Read [ANM]ANM0 = [F:GTE]COU
If fstat
 Call RSTA("ANM",[F:GTE]COU) From GLOCK : GOK=0 : Return
Endif
If [F:ANM]CTLCHR=2     # Le controle de chronologie du compteur est positionné
 VALEUR = [F:HEA]NUM : OK1 = 1
 Repeat
  Call NUMERO_PREC([F:GTE]COU,[F:HEA]FCY,[F:HEA]ACCDAT,[F:HEA]JOU,VALEUR,SEQ,STAT) From SUBANM
  If VALEUR = [F:HEA]NUM : Break : Endif
  If STAT : GOK = 0 : Break : Endif
  If CAS = 1
   Read [HEA1]SIH0 = VALEUR
  Else
   Read [HEA1]PIH0 = VALEUR
  Endif
  If !fstat
   If [F:HEA1]ACCDAT > [F:HEA]ACCDAT
    #--- Date incorrecte par rapport à la facture précédente
    GOK = 0 : Call ECR_TRACE(mess(101,121,1),1) From GESECRAN
   Endif
   OK1 = 0
  Endif
 Until OK1=0 or SEQ=1
 If GOK<1 : Return : Endif
Endif

Call ACCNUM([F:HEA]ACCNUM) From SUBGAS  : # Numéro interne
If dim([F:HEA]CREDAT)>0 : [F:HEA]CREDAT = date$ : Endif
If dim([F:HEA]CREUSR)>0 : [F:HEA]CREUSR = GUSER : Endif
If dim([F:HEA]EXPNUM)>0 : [F:HEA]EXPNUM = [C]EXPORT : Endif

# Les  montants par code taxe vont être calculés au moment où on créer les lignes factures
[F:HEA]NBRTAX = 0
Raz [F:HEA]AMTNOT, [F:HEA]AMTATI, [F:HEA]TAX, [F:HEA]BASTAX, [F:HEA]AMTTAX

# Lignes de facture fournisseur. On va remplir le fichier BPSINVLIG/BPCINVLIG + calculer
# les montants par code taxe du fichier PINVOICE/SINVOICE
NOL = 1
Raz [F:LIN]
[F:LIN]INVTYP = [F:HEA]INVTYP
[F:LIN]NUM    = [F:HEA]NUM     : # Numéro de facture
[F:LIN]LIG    = NOL            : # No ligne
[F:LIN]FCYLIN = [F:HEA]FCY     : # Site
[F:LIN]BPRLIN = ""             : # Tiers
For NLED=0 To len(mess(0,2644,1))-1
 [F:LIN]COA(NLED) = [F:PYD]COA(NLED)
 [F:LIN]ACC(NLED) = [F:PYD]ACC(NLED)
Next
[F:LIN]SAC = ""
[F:LIN]DES = [F:CDA]DESSHO-[F:PYH]NUM
[F:LIN]VAT = [F:PYD]VATLIN      : # Code TVA
If [F:PYD]AMTLIN<0 & [F:HEA]SNS = 1 : # Facture agio
 AMTIPT = [F:PYD]AMTLIN*-1
Else
 AMTIPT = [F:PYD]AMTLIN
Endif

If [F:CDA]RPCVAT<=2
 [F:LIN]AMTNOTLIN = AMTIPT  : # Montant HT
 [F:LIN]AMTVAT    = 0 : # Montant TVA
Else
 Call LECTAUX([F:PYH]CPY,[F:PYD]VATLIN,[F:HEA]VATDAT,[L]VATRAT,STAT) From CPTINIVAR
 [F:LIN]AMTNOTLIN = ar2(AMTIPT/(1+[L]VATRAT))
 [F:LIN]AMTVAT    = AMTIPT-ar2(AMTIPT/(1+[L]VATRAT)): # Montant TVA
 If dim([F:LIN]THEAMTVAT)>0
  [F:LIN]THEAMTVAT = [F:LIN]AMTVAT
 Endif
Endif
[F:LIN]AMTATILIN = [F:LIN]AMTNOTLIN + [F:LIN]AMTVAT
[F:LIN]TAX1      = ""  : # Code taxe 1 (Pas de code taxe sur les lignes de règlements)
[F:LIN]TAX2      = ""  : # Code taxe 2
[F:LIN]AMTTAX1   = 0   : # Montant taxe 1
[F:LIN]AMTTAX2   = 0   : # Montant taxe 2
Call LEC_TVT_LEG([F:CPY]LEG,[F:LIN]VAT) From CPTLEC
Filter [TRA] Where CPY=[F:HEA]CPY & VAT=[F:LIN]VAT & STRDAT<=[F:HEA]ACCDAT & LEG = [F:TVT]LEG
Read [TRA]TRA0 Last
If fstat>2
 # sinon on se rabat sur le code dossier
 Filter [TRA] Where CPY="" & VAT=[F:LIN]VAT & STRDAT<=[F:HEA]ACCDAT & LEG = [F:TVT]LEG
 Read [TRA]TRA0 Last
Endif
If CAS = 2
 If fstat>2
  [F:LIN]DEDVAT = [F:LIN]AMTVAT
 Else
  Call LECTURE("TCU",[F:HEA]CUR,"") From CONTOBJ
  [F:LIN]DEDVAT = arr([F:TRA]DEDRAT*[F:LIN]AMTVAT/100,[F:TCU]CURRND)
 Endif
Endif

Gosub MONTANT

If CAS = 1
 Call LECTURE("GAC",[F:LIN]ACC(GTYPGEN-1),[F:LIN]COA(GTYPGEN-1)) From CONTOBJ
 Case [F:GAC]VATIPT
  When 1
    [F:LIN]SALTYP = 1 : # Marchandises
  When 2
    [F:LIN]SALTYP = 2 : # Biens et services
 Endcase
Elsif CAS = 2
 [F:HEA]PURTYP    = [F:HEA2]PURTYP     : # Type d'achat
 [F:LIN]PURTYP    = [F:HEA]PURTYP      : # Type d'achat
Endif


FLGANA = 0

Call LSTLEDTYP([F:HEA]CPY,1,TLEDTYP,NBLED) From CPTDIV
Call RECH_ACC(2,[F:HEA]CPY,TLEDTYP,NBLED,[F:LIN]COA,[F:LIN]ACC,PLANA,CPTANA) From CPTDIV
If CPTANA<>""
 FLGANA = 1
 Call LECTURE("ACC",CPTANA,PLANA) From CONTOBJ
 [F:LIN]DSP = [F:PYD]DSP       : # Répartition
 [F:LIN]UOM = [F:GAC]UOM       : # Unité d'oeuvre
 [F:LIN]QTY = [F:PYD]QTYLIN    : # Quantité
Endif

Write [LIN]
If fstat
 GOK = 0 : Call FSTA("PIL") From GLOCK : Return
Endif
If FLGANA
 # Lignes analytiques de factures tiers (fournisseurs/clients)
 Filter [PYA] Where NUM = [F:PYH]NUM & LIN = [F:PYD]LIN
 Read [PYA]PYA0 Last
 Filter [PYA]
 If !fstat
  LASLIGANA = [F:PYA]LINANA : CUMANA = 0
  For [PYA] Where NUM = [F:PYH]NUM & LIN = [F:PYD]LIN
   Raz [F:LIA]
   [F:LIA]NUM       = [F:HEA]NUM       : # Numéro de facture
   [F:LIA]LIG       = NOL              : # No ligne
   [F:LIA]ANALIG    = [F:PYA]LINANA    : # Numéro d'ordre
   [F:LIA]INVTYP    = [F:HEA]INVTYP
   For NLED=0 To len(mess(0,2644,1))-1
    [F:LIA]COA(NLED) = [F:LIN]COA(NLED)
    [F:LIA]ACC(NLED) = [F:LIN]ACC(NLED)
   Next
   For I=0 To dim([F:PYA]CCE)-1
    [F:LIA]DIE(I) = [F:PYA]DIE(I)      : # Axes analytiques
    [F:LIA]CCE(I) = [F:PYA]CCE(I)      : # Sections analytiques
   Next
   If [F:PYD]VATLIN = ""
    [F:LIA]AMT = [F:PYA]AMTANA
   Else
    ## Si l'imputation esc/agio est associé à un code taxe, les montants sont stockés TTC dans PAYMENTA...
    If [F:PYA]LINANA = LASLIGANA
     [F:LIA]AMT = [F:LIN]AMTNOTLIN -  CUMANA
    Else
     [F:LIA]AMT = ar2([F:PYA]AMTANA/(1/[L]VATRAT))
     CUMANA += [F:LIA]AMT
    Endif
   Endif
   [F:LIA]UOM       = [F:LIN]UOM      : # Unité d'oeuvre
   If [F:GAC]UOM<>[F:LIN]UOM          : # Calcul quantité
    Call CALCUL_QTY([LIN]QTY,[F:LIN]UOM,[F:LIA]QTY,[F:GAC]UOM,COEF) From TRTX3
   Else
    [F:LIA]QTY = [F:LIN]QTY
   Endif
   Write [LIA]
   If fstat
    GOK = 0 : Call FSTA("LIA") From GLOCK : Break
   Endif
  Next
  If GOK<1 : Return : Endif
 Endif
Endif

Write [HEA]
If fstat
 GOK = 0 : Call FSTA("HEA") From GLOCK : Return
Endif

# Création des échéances de la facture
Filter [DUD2] Where ACCNUM=[F:HEA2]ACCNUM
Read [DUD2]DUD1 First
If !fstat
 XSOI    = [F:DUD2]SOI
 XFLGFUP = [F:DUD2]FLGFUP
Endif
Case CAS
 When 1
  [F:SIH] = [F:HEA]
 When 2
  [F:PIH] = [F:HEA]
Endcase
If CAS = 1
 Call CREECHE(CAS,XSOI,XFLGFUP,len(mess(0,510,1))) From SUBBIH
Elsif CAS = 2
 Call CREECHE(CAS,XSOI,XFLGFUP,[F:HEA]PAZ) From SUBBIH
Endif
If GOK<1 : Return : Endif

## MAJ champ 'n° facture esc/agios' dans PAYMENTD
Read [PYD2]PYD0 = [F:PYD]NUM ; [F:PYD]LIN
If !fstat
 [F:PYD2]NUMDEP = [F:HEA]NUM
 Rewrite [PYD2]
 If fstat
  GOK = 0 : Call FSTA("PYD2") From GLOCK : Return
 Endif
Endif
Return

$INI_TPV
Read [TPV]TPV0 = [F:HEA]PIVTYP;[F:CPY]LEG
If !fstat
 [F:HEA]INVTYP = [F:TPV]INVTYP        : # Catégorie facture (LA645)
Else
 Read [TPV]TPV0 = [F:HEA]PIVTYP;""
 If !fstat
  [F:HEA]INVTYP = [F:TPV]INVTYP        : # Catégorie facture (LA645)
 Endif
Endif
Return

$INI_TSV
Read [TPV]TSV0 = [F:HEA]SIVTYP;[F:CPY]LEG
If !fstat
 [F:HEA]INVTYP = [F:TPV]INVTYP        : # Catégorie facture (LA645)
Else
 Read [TPV]TSV0 = [F:HEA]SIVTYP;""
 If !fstat
  [F:HEA]INVTYP = [F:TPV]INVTYP        : # Catégorie facture (LA645)
 Endif
Endif
Return

$MONTANT
[F:HEA]AMTNOT += [F:LIN]AMTNOTLIN
[F:HEA]AMTATI += [F:LIN]AMTATILIN
BASTVA = [F:LIN]AMTNOTLIN
TVA = 0
TAXE = [F:LIN]TAX1 : MONTANT = [F:LIN]AMTTAX1 : BASE = [F:LIN]AMTNOTLIN
Gosub SET_TAXE
TAXE = [F:LIN]TAX2 : MONTANT = [F:LIN]AMTTAX2 : BASE = [F:LIN]AMTNOTLIN
Gosub SET_TAXE
TAXE = [F:LIN]VAT  : MONTANT = [F:LIN]AMTVAT  : BASE = BASTVA
TVA = 1
Gosub SET_TAXE
Return

$SET_TAXE
If TAXE<>""
 K = find(TAXE,[F:HEA]TAX(0..[F:HEA]NBRTAX-1))
 If !K
  [F:HEA]NBRTAX += 1 : K = [F:HEA]NBRTAX
  [F:HEA]TAX(K-1) = TAXE
 Endif
 [F:HEA]BASTAX(K-1) += BASE
 [F:HEA]AMTTAX(K-1) += MONTANT
 If !TVA
  Call LEC_TVT_LEG([F:CPY]LEG,TAXE) From CPTLEC
  If [F:TVT]VATCHA=2
   BASTVA += MONTANT
  Endif
 Endif
Endif
Return


$INIARG
## Spécial Argentine
##   Init racine document origine
## + init numéro CAI et date validité CAI par défaut
If dim([F:HEA]CAI)>0
 Local Char    TYPDOC(GLONADI)
 Local Char    TT(2), C(1), SSSS(4), CAI(14)
 Local Char    MESSA(250)
 Local Char    TYPDOC(GLONADI)
 Local Integer VU, X
 X = 0
 For [ADI]CODE Where NUMTAB = 362
  VU = instr(1,[F:ADI]A1,num$([F:HEA]INVTYP))
  If VU
   TYPDOC = [F:ADI]CODE
   [F:HEA]CAI = [F:BPS]CAI(X)
   [F:HEA]DATVLYCAI = [F:BPS]DATVLYCAI(X)
   Local Date DATVAL
   Call TTCSSSS(2,TYPDOC,1,[F:HEA]FCY,[0/0/0],[F:HEA]VAC,TT,C,SSSS,CAI,DATVAL,STAT) From SUBANMARG
   [F:HEA]TYPVCR = [L]TT
   [F:HEA]CLSVCR = [L]C
   [F:HEA]SCUVCR = ""
   [F:HEA]SEQVCR = ""
   Break
  Endif
  X += 1
 Next
Endif
Return


Subprog EVALAUTO(CAS,TRANSAC,ZONE,VALEUR)
Value Integer CAS
Value Char    TRANSAC(), ZONE()
Variable Char VALEUR()
VALEUR=""
Read [GAG]GAG0 = TRANSAC;0;ZONE
If !fstat
 Local Char PROG(20)
 PROG = "WMGAU"+TRANSAC
 Onerrgo RIEN
 If CAS = 1
  If !clalev([F:TB0])
   Local File PINVOICE [TB0]
   [F:TB0] = [F:HEA]
  Endif
 Elsif CAS = 2
  If !clalev([F:TB0])
   Local File SINVOICE [TB0]
   [F:TB0] = [F:HEA]
  Endif
 Endif
 Gosub OUVRE From = PROG
 Gosub LIENS From = PROG
 VALEUR = evalue([F:GAG]FORCLC)
 Onerrgo
Endif
End

$RIEN
Resume

$CONT_GTE
Call LEC_GTE_LEG([F:CPY]LEG,TYPPCE) From CPTLEC
If fstat
 GOK=0 : Call RSTA("GTE",TYPPCE) From GLOCK : Return
Else
 If [F:GTE]ENAFLG<>2    # Type de pièce : GTE \ Fiche inactive
  GOK = 0 : Call ECR_TRACE(mess(22,107,1)-":"-TYPPCE+"\"+mess(2,126,1),1) From GESECRAN : Return
 Elsif [F:GTE]ACS<>""    # Code d'accès
  Call CONTEXE([F:GTE]ACS) From CPTSUB
  If mkstat
   ## Vous n'avez pas les droits d'exécution
   #GOK = 0 : Call ECR_TRACE([F:GTE]ACS-GMESSAGE) From GESECRAN : Return
   GOK = 0 : Call ECR_TRACE([F:GTE]ACS-GMESSAGE,1) From GESECRAN : Return # FGR 17/12/2009 : X3SUIVI60986
  Endif
 Endif
 mkstat=0 : Call CTLVLYDAT([F:HEA]ACCDAT,[F:GTE]VLYSTR,[F:GTE]VLYEND) From CPTSUB
 If mkstat
  GOK=0 : Call ECR_TRACE(mess(22,107,1)-TYPPCE-GMESSAGE,1) From GESECRAN : Return
 Endif
 If [F:GTE]VCRREA<>2
  # Type de pièce non réel
  GOK = 0 : Call ECR_TRACE(mess(59,119,1),1) From GESECRAN : Return
 Endif
Endif
Return

$CONT_JOU
If !clalev([F:JOU]) : Local File GJOURNAL [JOU] : Endif
Call LEC_JOU_LEG([F:CPY]LEG,JOURNAL) From CPTLEC
If fstat
 GOK=0 : Call RSTA("JOU",JOURNAL) From GLOCK : Return
Else
 If [F:JOU]ENAFLG<>2    # Journal : JOU \ Fiche inactive
  GOK = 0 : Call ECR_TRACE(mess(13,105,1)-":"-JOURNAL+"\"+mess(2,126,1),1) From GESECRAN : Return
 Elsif [F:JOU]ACS<>""      # Code d'accès
  Call CONTEXE([F:JOU]ACS) From CPTSUB
  If mkstat
   GMESSAGE = [F:JOU]ACS-GMESSAGE
   GOK = 0 : Call ECR_TRACE(GMESSAGE,1) From GESECRAN : Return
  Endif
 Endif
 If [F:JOU]FCY<>""      # Société/site
  Call VERSOC([F:JOU]FCY,[F:HEA]CPY,[F:HEA]FCY,[F:JOU]JOU) From CFYSUB
  If mkstat
   GMESSAGE = mess(13,105,1)-GMESSAGE    # Journal
   GOK = 0 : Call ECR_TRACE(GMESSAGE,1) From GESECRAN : Return
  Endif
 Endif
 If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
  GMESSAGE = [F:JOU]JOU-mess(8,106,1) : # Journal non autorisé sur ce type de pièce
  GOK = 0 : Call ECR_TRACE(GMESSAGE,1) From GESECRAN : Return
 Endif
Endif
Return


$AB_TRANSAC
Rollback
End

$ROLL_TRANSAC
Rollback
Call ROLL From GLOCK
If GROLL : End : Else : Goto ROLL_TRANSAC : Endif

