#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPYLEGAUT 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone AUSFINSRV
mkstat = 0
zoncou = "AUSFINSRV"
indice = 0
If varmode([M]AUSFINSRV,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "AUSFINSRV" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBLIG From TRTCPYLEGAUT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBLIG" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBLIG From TRTCPYLEGAUT
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBLIG" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone GERDEFVAL
mkstat = 0
zoncou = "GERDEFVAL"
IMPENT = [M]GERDEFVAL(indice)
WNUM = IMPENT
If varinit([M]GERDEFVAL,indice)=0
 IMPENT = 1
Endif
If varmode([M]GERDEFVAL,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_GERDEFVAL(IMPENT) From TRTCPYLEGAUT
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]GERDEFVAL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "GERDEFVAL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]GERDEFVAL(indice)
 Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_GERDEFVAL(IMPENT) From TRTCPYLEGAUT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "GERDEFVAL" : GZNUM = 88 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]GERDEFVAL(indice) = IMPENT

## Zone GEREECNUM
mkstat = 0
zoncou = "GEREECNUM"
SAVACT = GACTION : GACTION = "FMTEECPAY"
Call FMTEECPAY([F:CPY]CRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]GEREECNUM(indice) : Endif
If !mkstat
 SAVACT = GACTION : GACTION = "ASAIEEC"
 GACTION = SAVACT
 If [F:TCY]EECFMTFLG<>2 : Grizo =zoncou : mkstat = 1 : Else : Actzo =zoncou : Endif
 If mkstat=1 : Raz [M]GEREECNUM(indice) : Endif
 If !mkstat
  If varmode([M]GEREECNUM,indice)=0
   If !mkstat
    IMPMOD = 0 : IMPZON = "GEREECNUM" : Gosub ACTION From =IMPTRT
   Endif
   SAVACT = GACTION : GACTION = "CONTTVA"
   Call CONTTVA([M]GEREECNUM(indice),[F:CPY]CRY) From CONTNUM
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "GEREECNUM" : GZNUM = 4145 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_GEREECNUM([M]GEREECNUM(indice)) From TRTCPYLEGAUT
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "GEREECNUM" : GZNUM = 4145 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone GERTAXCEN
mkstat = 0
zoncou = "GERTAXCEN"
If varmode([M]GERTAXCEN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GERTAXCEN" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("BPR","!",[M]GERTAXCEN(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "GERTAXCEN" : GZNUM = 13507 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone GERTAXIDT
mkstat = 0
zoncou = "GERTAXIDT"
If varmode([M]GERTAXIDT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GERTAXIDT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CPYLEGAUT"
Return

