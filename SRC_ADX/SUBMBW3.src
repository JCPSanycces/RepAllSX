#<AdxTL>@(#)12.0.0.0 $Revision$
########################################
Subprog B1_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:MBW3]ITMREF
    Read [ITF]ITF0=[M:MBW3]ITMREF;[M:MBW3]STOFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]MFGLOTQTY
End

########################################
Subprog B2_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:MBW3]ITMREF
    Read [ITF]ITF0=[M:MBW3]ITMREF;[M:MBW3]STOFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]REOMINQTY
End

########################################
Subprog AS_EXTQTY2(VALEUR)
Variable Decimal VALEUR
GBOUT1 = mess(151,198,1)
GBOUT2 = mess(150,198,1)
If [M:MBW3]BOMALT2 = 0
    GBOUT3 = ""
Else
    GBOUT3 = mess(282,198,1)
Endif
End

########################################
Subprog C_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : mkstat = 2 : Endif
If VALEUR < [M:MBW3]COVQTY
    GMESSAGE = mess(120,193,1)-"("+num$([M:MBW3]COVQTY)+")"
    mkstat = 2
Endif
End

########################################
Subprog AM_EXTQTY2(VALEUR)
Variable Decimal VALEUR
Local    Integer OK
Local    Date    WORIDAT
Local    Char    WORIFCY
Local    Integer WLTI
Local    Char    WART
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Integer WALT            # llc 05.03 18397

# llc 05.03 18397
WQTY = VALEUR
If [M:MBW3]ROUNUM <> "" & [M:MBW3]ROUALT <> 0 & [M:MBW3]STRDAT2 <> [0/0/0]
    Raz GMESSAGE
    If clalev([F:TRO]) = 0 : Local File TABROUALT [TRO] : Endif
    If clalev([F:ROH]) = 0 : Local File ROUTING   [ROH] : Endif
    #    Lecture ROUTING
    Read [TRO]TRO0=[M:MBW3]ROUALT
    If fstat
        GMESSAGE = mess(152,193,1)
    Else
        Read [ROH]ROH1=[M:MBW3]STOFCY;[M:MBW3]ROUNUM;[M:MBW3]ROUALT
        If fstat
            GMESSAGE = mess(152,193,1)
        Else
            Call CONTMFGGAM([M:MBW3]STOFCY,WALT,[M:MBW3]STRDAT2,WQTY, [M:MBW3]STU2, 1) From MFGLIB
        Endif
    Endif
    If GMESSAGE <> "" | WALT = 0 : mkstat = 2 : End : Endif

Endif
If [M:MBW3]STRDAT2 = [0/0/0] | [M:MBW3]ENDDAT2 = [0/0/0] : End : Endif

WORIFCY=[M:MBW3]STOFCY
WLTI=0

# lecture ITF
If [F:ITF]ITMREF<>[M:MBW3]ITMREF
    Read [ITF]ITF0=[M:MBW3]ITMREF;[M:MBW3]STOFCY
    If fstat : End : Endif
Endif

WQTY = VALEUR
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# 05.08 47469
If [F:MTS]SCDMODSAI = 1
    # calcul date
    WORIDAT=[M:MBW3]ENDDAT2
    WMEMDAT=[M:MBW3]STRDAT2

    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MBW3]STRDAT2) From MFGLIB

    Affzo [M:MBW3]STRDAT2
    Call CHECK_PAST([M:MBW3]STRDAT2, 2) From MFGLIB
Else
    # calcul date
    WORIDAT=[M:MBW3]STRDAT2
    WMEMDAT=[M:MBW3]ENDDAT2

    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:MBW3]ENDDAT2) From MFGLIB

    Affzo [M:MBW3]ENDDAT2
    Call CHECK_PAST([M:MBW3]ENDDAT2, 2) From MFGLIB
Endif

End

########################################
Subprog AS_STRDAT2(VALEUR)
Variable Date    VALEUR
# jalonnement amont, si nouvel ordre on saisit la date de fin
# llc 03.02 12520
If [F:MTS]SCDMODSAI = 1 & [M:MBW3]ENDDAT2=[0/0/0] : mkstat=2 : End : Endif
End

########################################
Subprog C_STRDAT2(VALEUR)
Variable Date    VALEUR
# If VALEUR > [M:MBW3]ENDDAT2 : mkstat=2 : End : Endif
If VALEUR=[0/0/0] : mkstat=2 : End : Endif

# révision calendriers (llc 06.00)
Call CONTROL_DATE_PLN(VALEUR, [M:MBW3]STOFCY) From MFGLIB
If mkstat : End : Endif

# llc 11.02 16545
If [M:MBW3]ENDDAT2 = [0/0/0] : End : Endif
If [M:MBW3]BOMALT2 = 0
    Call RECH_NOM([M:MBW3]STOFCY, [M:MBW3]STRDAT2, [M:MBW3]BOMALT2,2) From BENCHLIB
Endif

If ([M:MBW3]ROUALT = 0 | [M:MBW3]ROUNUM = "") & ([F:MTS]MFGMODC = 2 | [F:MTS]MFGMODO = 2)
    If [F:ITF]MFGROU = ""
        [M:MBW3]ROUNUM = [M:MBW3]ITMREF
    Else
        [M:MBW3]ROUNUM = [F:ITF]MFGROU
    Endif

    Call RECH_GAM([M:MBW3]STOFCY, [M:MBW3]STRDAT2, [M:MBW3]ROUNUM, [M:MBW3]EXTQTY2,
&                 [M:MBW3]STU2, [M:MBW3]BOMALT2, [M:MBW3]ROUALT) From BENCHLIB
    If [M:MBW3]ROUALT = 0 & [F:MTS]MFGMODM = 2 : Raz [M:MBW3]ROUNUM : Endif                # llc 06.04 22880

Endif

# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:MBW3]ECCVALMAJ)>0
    Call C_STRDAT2(VALEUR, "MBW3") From SUBMBWECC
Endif

End

########################################
Subprog AM_STRDAT2(VALEUR)
Variable Date    VALEUR
Local    Integer WRET
Local    Date    WORIDAT
Local    Char    WORIFCY
Local    Integer WLTI
Local    Char    WART
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY

If [F:MTS]SCDMODSAI = 1 & VALEUR > [M:MBW3]ENDDAT2 : mkstat=2 : End : Endif

# révision calendriers (llc 06.00)
Call CONTROL_DATE_PLN(VALEUR, [M:MBW3]STOFCY) From MFGLIB
If mkstat : End : Endif

# antériorité par rapport à la date du jour ?
Call CHECK_PAST(VALEUR, 2)  From MFGLIB

# llc 03.02 12520
If [F:MTS]SCDMODSAI = 1 : End : Endif

WORIDAT=VALEUR
WORIFCY=[M:MBW3]STOFCY
WLTI=0

# lecture article site
Read [ITF]ITF0=[M:MBW3]ITMREF;[M:MBW3]STOFCY
If fstat : End : Endif
WQTY = [M:MBW3]EXTQTY2
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# calcul date
WMEMDAT = [M:MBW3]STRDAT2

# révision calendriers (llc 06.00)
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:MBW3]ENDDAT2) From MFGLIB

Affzo [M:MBW3]ENDDAT2

# FQ 74761 GA 03/2011 idem AM_ENDDAT2
Gosub INIT_BOM_ROU

End

########################################
Subprog AS_ENDDAT2(VALEUR)
Variable Date    VALEUR

# Si jalonnement aval et date début non renseignée, pas de saisie
If ([F:MTS]SCDMODSAI=2 & [M:MBW3]STRDAT2=[0/0/0]) : mkstat=2 : End : Endif
End

########################################
Subprog C_ENDDAT2(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : mkstat=2 : End : Endif

# révision calendriers (llc 06.00)
Call CONTROL_DATE_PLN(VALEUR, [M:MBW3]STOFCY) From MFGLIB
If mkstat : End : Endif

End

########################################
Subprog AM_ENDDAT2(VALEUR)
Variable Date    VALEUR
Local    Date    WORIDAT
Local    Char    WORIFCY
Local    Integer WLTI
Local    Char    WART
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY

If [F:MTS]SCDMODSAI = 2 & VALEUR < [M:MBW3]STRDAT2 : mkstat = 2 : End : Endif
# llc 03.02 12520
If [F:MTS]SCDMODSAI = 2 : End : Endif
# 08.05 31390
If [F:MTS]SCDMODSAI = 1

    WORIDAT=VALEUR
    WORIFCY=[M:MBW3]STOFCY
    WLTI=0

    # lecture article site
    Read [ITF]ITF0=[M:MBW3]ITMREF;[M:MBW3]STOFCY
    If fstat : End : Endif
    WQTY = [M:MBW3]EXTQTY2
    Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
    ILTI    = int(XLTI)
    WRMD    = XLTI - ILTI
    If WRMD <> 0 : ILTI += 1 : Endif
    WLTI=ILTI

    # calcul date
    WMEMDAT = [M:MBW3]STRDAT2

    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MBW3]STRDAT2) From MFGLIB

    Affzo [M:MBW3]STRDAT2
    Call CHECK_PAST([M:MBW3]STRDAT2, 2) From MFGLIB
    # Issue 104943 - 2015-07-27 by BEEBE : Implementing Versioning
    If dim([M:MBW3]ECCVALMAJ)>0
        Call AM_ENDDAT2(VALEUR, "MBW3") From SUBMBWECC
    Endif
Endif

# FQ 74761 GA 03/2011 code déplacé pour réutilisation
Gosub INIT_BOM_ROU

End
$INIT_BOM_ROU    # FQ 74761 GA 08/2011
If [M:MBW3]BOMALT2 = 0
    Call RECH_NOM([M:MBW3]STOFCY, [M:MBW3]STRDAT2, [M:MBW3]BOMALT2,2) From BENCHLIB
Endif

If ([M:MBW3]ROUALT = 0 | [M:MBW3]ROUNUM = "") & ([F:MTS]MFGMODC = 2 | [F:MTS]MFGMODO = 2)
    If [F:ITF]MFGROU = ""
        [M:MBW3]ROUNUM = [M:MBW3]ITMREF
    Else
        [M:MBW3]ROUNUM = [F:ITF]MFGROU
    Endif

    Call RECH_GAM([M:MBW3]STOFCY, [M:MBW3]STRDAT2, [M:MBW3]ROUNUM, [M:MBW3]EXTQTY2,
&                 [M:MBW3]STU2, [M:MBW3]BOMALT2, [M:MBW3]ROUALT) From BENCHLIB
    If [M:MBW3]ROUALT = 0 & [F:MTS]MFGMODM = 2 : Raz [M:MBW3]ROUNUM : Endif                # llc 06.04 22880
Endif
Affzo [M:MBW3]15

Return

########################################
Subprog AS_BOMALT2(VALEUR)
Variable Decimal VALEUR

If [F:MTS]MFGMODC = 1 & [F:MTS]MFGMODM = 1  : mkstat = 2 : End : Endif # sr 150
#If [F:MTS]MFGMODO = 2 : mkstat = 2 : End : Endif                         # 03.05 29111
If VALEUR = 0
    Call RECH_NOM([M:MBW3]STOFCY, [M:MBW3]STRDAT2, VALEUR,2) From BENCHLIB
Endif

End

########################################
Subprog C_BOMALT2(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 & [F:MTS]MFGMODO <> 2  : mkstat = 2 : Endif    # llc 11.02 16545 + 02.05 28246
End

########################################
Subprog AM_BOMALT2(VALEUR)
Variable Decimal VALEUR
Local    Date    WDAT
Local    Char    WFCY
Local    Integer WALT

If [M:MBW3]STRDAT2=[0/0/0]
    WDAT=date$
Else
    WDAT=[M:MBW3]STRDAT2
Endif

If VALEUR = 0 & [F:MTS]MFGMODO = 2 : End : Endif            # llc 11.02 16545 + 02.05 28246

WFCY=[M:MBW3]STOFCY
#    Lecture BOM
Read [TBO]TBO0=2;VALEUR
If fstat : mkstat=2 : End : Endif
Read [BOH]BOH0=[M:MBW3]ITMREF;VALEUR;2
If fstat : GMESSAGE = mess(95,193,1) : mkstat=2 : End : Endif
Call CONTMFGNOM(WFCY,WALT,WDAT,1) From MFGLIB
If WALT=0 : mkstat=2 : End : Endif
End

########################################
Subprog AS_ROUNUM(VALEUR)
Variable Char    VALEUR()
# sr 211100 contrôle selon transaction
If [F:MTS]MFGMODC = 1 & [F:MTS]MFGMODO = 1
    Raz VALEUR,[M:MBW3]ROUNUM,ROUALT
    mkstat = 2
    End
Endif
End

########################################
Subprog C_ROUNUM(VALEUR)
Variable Char    VALEUR()
# sr 211100 contrôle selon transaction
If [F:MTS]MFGMODM = 1  & VALEUR = ""
    GMESSAGE = mess(31,190,1)
    mkstat = 2
Endif
End

########################################
Subprog AM_ROUNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
    [M:MBW3]ROUALT = 0
    Affzo [M:MBW3]ROUALT
Endif
End

########################################
Subprog AS_ROUALT(VALEUR)
Variable Decimal VALEUR
# sr 211100 contrôle selon transaction
If [F:MTS]MFGMODC = 1 & [F:MTS]MFGMODO = 1
    mkstat = 2
    End
Endif
End

########################################
Subprog C_ROUALT(VALEUR)
Variable Decimal VALEUR
Local    Char    WFCY
Local    Integer WALT
Local    Date    WDAT
Local    Integer NOL
Local    Integer TABTBO(3)
#
If VALEUR = 0
  If [F:MTS]MFGMODM = 2 & [M:MBW3]ROUNUM = ""
     End
  Else
    mkstat = 2
    End
  Endif
Endif
WDAT=[M:MBW3]STRDAT2
WFCY=[M:MBW3]STOFCY
#    Lecture ROUTING
Read [TRO]TRO0=VALEUR
If fstat : mkstat=2 : End : Endif
Read [ROH]ROH1=[M:MBW3]STOFCY;[M:MBW3]ROUNUM;VALEUR
If fstat : mkstat=2 : End : Endif
#
Call CONTMFGGAM(WFCY,WALT,WDAT,[M:MBW3]EXTQTY2, [M:MBW3]STU2, 1) From MFGLIB
If WALT=0 : mkstat=2 : End : Endif
# Contrôle de cohérence des alternatives de nomenclature
If ([F:MTS]MFGMODO = 2 & [M:MBW3]BOMALT2 = 0) : End : Endif            # llc 16545 + 02.05 28246
TABTBO(0)=[F:TRO]BOMALT1
TABTBO(1)=[F:TRO]BOMALT2
TABTBO(2)=[F:TRO]BOMALT3
If !find([M:MBW3]BOMALT2, TABTBO)
   GMESSAGE=mess(53,193,1)
   mkstat=2
   End
Endif
End

########################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
If [F:FCY]FCY <> VALEUR
    If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
    Read [FCY]FCY0=VALEUR
    If fstat : mkstat = 2 : End : Endif
Endif

If [F:FCY]MFGFLG <> 2
    GMESSAGE = mess(1,193,1)
    mkstat = 2
    End
Endif
End

########################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
If GFCY <> VALEUR
    GFCY = VALEUR
Endif
Gosub CHARG_PARAM From FUNGBENCH
End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY(GLONFCY) : # 05/2008 V6 avant (3)

#    Lecture article et article/site
If VALEUR <> [F:ITM]ITMREF
    Read [ITM]ITM0=VALEUR
    If fstat
      GMESSAGE = mess(134,100,1)
      mkstat = 2
      End
    Endif
Endif

#    Lecture article/site
If VALEUR <> [F:ITF]ITMREF | [M:MBW3]STOFCY <> [F:ITF]STOFCY
    Read [ITF]ITF0=VALEUR;[M:MBW3]STOFCY
    If fstat
      GMESSAGE = mess(45,193,1)
      mkstat = 2
      End
    Endif
Endif
#
WFCY = [M:MBW3]STOFCY
Call CONTMFGITM(WFCY,1) From MFGLIB
If mkstat : End : Endif

# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:MBW3]ECCVALMAJ)>0
& &    [M:MBW3]ECCVALMAJ=""
    # Enable, Disable ECCVALMAJ, ECCVALMIN, BOMALT
    Call ECCAFF(VALEUR,"MBW3") From MFGECCLIB
    If func ECCLIB.NBRCPN(VALEUR)
        Local Integer LALT
        LALT = [M]BOMALT2
        # ECC preload of major and minor version
        Raz [M:MBW3]ECCVALMAJ, [M:MBW3]ECCVALMIN
        Call INIECCBOM(VALEUR, [M]STOFCY, [M]STRDAT2, 2, [M]ECCVALMAJ,[M]ECCVALMIN,LALT) From MFGECCLIB
        [M]BOMALT2 = LALT
        Affzo [M:MBW3]ECCVALMAJ, ECCVALMIN, BOMALT2
    Else
        Effzo [M:MBW3]ECCVALMAJ, ECCVALMIN
    Endif
Endif

#    Contrôle filtre par planificateur
Call CTLPLNFLT([M:MBW3]STOFCY, VALEUR, [M:MBW3]PLANNER) From MFGLIB      # llc 11.01 11649
If GMESSAGE <> ""
    mkstat=1
    End
Endif

End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char   VALEUR()
Local    Integer    WLTI, WQUALTI, WMFGLTI
Local    Decimal    XLTI
Local    Integer    ILTI
Local    Decimal    WRMD

[M:MBW3]EXTQTY2 = [F:ITF]REOMINQTY
[M:MBW3]STU2 = [F:ITM]STU

# délai fabrication
XLTI    = [F:ITF]MFGLTI
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WMFGLTI = ILTI

# délai qualité
XLTI    = [F:ITF]QUALTI
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WQUALTI = ILTI

If WQUALTI = 0
    [M:MBW3]AVAOFS = num$(WMFGLTI)
Else
    [M:MBW3]AVAOFS = num$(WMFGLTI)-"(+"+num$(WQUALTI)+")"
Endif

Affzo [M:MBW3]10
# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:MBW3]ECCVALMAJ)>0
    Call AM_ITMREF(VALEUR) From SUBMBWECC
Endif
End

