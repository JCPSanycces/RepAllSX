#    Modification
#    GLE - 27.08.2014    (FQ 102303) : Modification des numéros des tables de messages
#    GBO - 05.06.2006    (FQ 36394)  : Contrôle si société en cours de CIG
#*********************************************************************

End
########################################
$ACTION
 Case ACTION
  When "INIT"        : Gosub INIT
  When "OUVRE"       : Gosub OUVRE
  When "DEBUT"       : Gosub DEBUT
  When "TERMINE"     : Gosub TERMINE
  When "SORTIE"      : Gosub SORTIE
 Endcase
Return

########################################
$INIT

 Global Char G_ACTNAM
 G_ACTNAM=PARAM(1)

 Case G_ACTNAM
  When "CTRLEVT" : Gosub INIT_CTRLEVT
  When "CTRLCIG" : Gosub INIT_CTRLCIG
  When Default
 Endcase

Return

$DEBUT
 Case G_ACTNAM
  When "CTRLEVT" : Gosub DEBUT_CTRLEVT
  When "CTRLCIG" : Gosub DEBUT_CTRLCIG
  When Default
 Endcase
Return

$OUVRE
 Case G_ACTNAM
  When "CTRLEVT" : Gosub OUVRE_CTRLEVT
  When "CTRLCIG" : Gosub OUVRE_CTRLCIG
  When Default
 Endcase
Return

$TERMINE
 Case G_ACTNAM
  When "CTRLEVT" : Gosub TERMINE_CTRLEVT
  When "CTRLCIG" : Gosub TERMINE_CTRLCIG
  When Default
 Endcase
Return

$SORTIE
 If dim(G_ACTNAM)>0 : Kill G_ACTNAM : Endif
Return

#############################################
# Contrôle des événements non comptabilisés
# en clôture exercice
#############################################

#============================================

#------------------------------

INIT_CTRLEVT
Return

#------------------------------

INIT_CTRLCIG
Return

#============================================

#------------------------------

DEBUT_CTRLEVT

 #> Formatage des intitulés et colonnes à afficher pour la liste d'erreur

 Chgtbk [M:LSE]5 With mess(125,GML_MSGCAL,1)                               #"Contrôle des événements non comptabilisés"
 Titcol [M:LSE]NBERR  mess(126,GML_MSGCAL,1), mess(87,GML_MSGCAL,1), "Nbr" # "type éVT.", "PLAN"
#Chgfmt [M:LSE]COL3 With "-K:30X"
 Chgfmt [M:LSE]COL4 With "-K:30X"

 #> Chargement de la boîte de la liste d'erreur.

 Local Integer I_LIG
 For I_LIG=1 To dim(LISTEVT)
  If LISTEVT(I_LIG)="" : Break : Endif
  If I_LIG=dim([M:LSE]COL1)
   [M:LSE]COL1(I_LIG-1)="..."
   Break
  Else
   [M:LSE]COL1(I_LIG-1)=LISTEVT(I_LIG)
   If LISTPLN(I_LIG)=G301AUC
    [M:LSE]COL2(I_LIG-1)="-"
   Else
   [M:LSE]COL2(I_LIG-1)=mess(LISTPLN(I_LIG),3101,1)
   Endif
   [M:LSE]COL3(I_LIG-1)=num$(LISTNBE(I_LIG))
  Endif
 Next I_LIG
 [M:LSE]NBERR=I_LIG-1
 Affzo [M:LSE]

Return

#------------------------------

$DEBUT_CTRLCIG

 #> Formatage des intitulés et colonnes à afficher pour la liste d'erreur

 Chgtbk [M:LSE]5 With mess(203,GML_MSGCIG,1) # "Opération de cession intra-groupe en cours"
 #                    "Référence CIG.",      "CIG",                 "Statut CIG" ,         "Nombre de biens"
 Titcol [M:LSE]NBERR  mess(204,GML_MSGCIG,1),mess(205,GML_MSGCIG,1),mess(206,GML_MSGCIG,1),mess(207,GML_MSGCIG,1)

 #> Chargement de la boîte de la liste d'erreur.

 Local Integer I_LIG
 For I_LIG=1 To dim(LISTCIG)
  If LISTCIG(I_LIG)="" : Break : Endif
  If I_LIG=dim([M:LSE]COL1)
   [M:LSE]COL1(I_LIG-1)="..."
   Break
  Else
   [M:LSE]COL1(I_LIG-1)=LISTCIG   (I_LIG)
   [M:LSE]COL2(I_LIG-1)=LISTCIGDES(I_LIG)
   [M:LSE]COL3(I_LIG-1)=mess(LISTCIGSTA(I_LIG),3131,1)
   [M:LSE]COL4(I_LIG-1)=num$(LISTCIGNBBCO(I_LIG))
  Endif
 Next I_LIG
 [M:LSE]NBERR=I_LIG-1
 Affzo [M:LSE]

Return

#============================================

#------------------------------

$OUVRE_CTRLEVT
Return

#------------------------------

$OUVRE_CTRLCIG
Return

#============================================

#------------------------------

$TERMINE_CTRLEVT
Return

#------------------------------

$TERMINE_CTRLCIG
Return


##############################################

#------------------------------

Subprog AS_NBERR
 Case G_ACTNAM
  When "CTRLCIG"
   GBOUT1= mess(208,GML_MSGCIG,1) # "Détail CIG" 208
   GBOUT2=""
   GBOUT3=""
  When Default
   GBOUT1=""
   GBOUT2=""
   GBOUT3=""
 Endcase
End

Subprog B1_NBERR
 Case G_ACTNAM
  When "CTRLCIG"
   Local Char    PARMSK(250)(1..20) , SAVACT(20)
   SAVACT = GACTION : GACTION = "GOBJETC1"
   Call OBJET_CHAR([M:LSE]COL1(nolign-1),"CIG","") From GOBJET
   GACTION = SAVACT
  When Default
 Endcase
End

Subprog B2_NBERR
 Case G_ACTNAM
  When Default
 Endcase
End

Subprog B3_NBERR
 Case G_ACTNAM
  When Default
 Endcase
End
