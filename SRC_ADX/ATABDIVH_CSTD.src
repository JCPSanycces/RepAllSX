#<AdxTL>@(#)0.0.0.0 $Revision$
#################
# Class ATABDIVH
#################
$ACTION
Case CURPRO
    When ""         : Gosub METHODS
    When Default    : Gosub PROPERTIES
Endcase
Return

###############
# METHODS
###############
$METHODS
Case CURPTH
    When ""
        Case ACTION
            When "AREAD"                  : Gosub AREAD
            When "AINSERT"                : Gosub AINSERT
            When "AUPDATE"                : Gosub AUPDATE
            When "ADELETE"                : Gosub ADELETE
        Endcase
    When "ACOLADI"
        Case ACTION
            When "AREAD_AFTER"   : Gosub ACOLADI_AREAD_AFTER
            When "ADDLINE_AFTER" : Gosub ACOLADI_ADDLINE_AFTER
        Endcase
Endcase
Return


#************************
#* Methods from ATABDIVH
#*!
$AREAD
Local File ATABDIV [ADI_]
Local Integer ILINE

Local Instance ADV Using C_ATABTAB
ADV = NewInstance With C_ATABTAB
[L]ASTATUS = fmet ADV.AREAD(this.NUMTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Local Char DES(250)
DES = fmet ADV.AGETTEXTRA("LNGDES")
this.ADVDES = DES
[L]ASTATUS = fmet this.ASETERROR("NUMTAB",DES,[V]CST_AINFO )
this.ADVDEP = ADV.DEPNUM

For [ADI_] Where [F:ADI_]NUMTAB=this.NUMTAB
    ILINE = fmet this.ADDLINE("ACOLADI",CST_ALASTPOS)
    [L]ASTATUS = fmet this.ACOLADI(ILINE).AREAD([F:ADI_]NUMTAB,[F:ADI_]CODE)
    If ILINE
    If [F:ADI_]DEFVAL=2 : this.VALDEF=[F:ADI_]CODE : Endif
    Endif
    If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

#** Colomn management

#Colonnes Alphanumériques
For ILINE=1 To maxtab(ADV.ACOLALP)
 If ADV.ACOLALP(ILINE)<>null
  If ADV.ACOLALP(ILINE).COLALPDES=AVOID.ACHAR
 #  [L]ASTATUS = fmet this.ACOLADI.ASETATTRIBUTE(evalue("A"+num$(ILINE)),func ASYRSUB.CODATT("H"),func ASYRSUB.BOOLEAN_TO_SYR(2))
  Else
#  [L]ASTATUS = fmet this.ACOLADI.ASETATTRIBUTE(evalue("A"+num$(ILINE)),func ASYRSUB.CODATT("T"),ADV.ACOLALP(ILINE).COLALPDES)
# [L]ASTATUS =  evalue("fmet this.ACOLADI("+num$(ILINE)+").A"+num$(ILINE)+".ASETATTRIBUTE('A"+num$(ILINE)+"',func ASYRSUB.CODATT('T'),ADV.ACOLALP("+num$(ILINE)+").COLALPDES)")
# [L]ASTATUS =  evalue("fmet this.ACOLADI("+num$(ILINE)+").ASETATTRIBUTE('A"+num$(ILINE)+"',func ASYRSUB.CODATT('T'),ADV.ACOLALP("+num$(ILINE)+").COLALPDES)")
  Endif
 Endif
Next

[L]ASTATUS =  fmet this.ACOLADI(1).ASETATTRIBUTE("A1",func ASYRSUB.CODATT('T'),ADV.ACOLALP(1).COLALPDES)

#Colonnes Numériques
#For ILINE=1 To maxtab(ADV.ACOLNUM)
# If ADV.ACOLNUM(ILINE).ACOLNUMDES=AVOID.ACHAR
#  [L]ASTATUS = fmet this.ACOLNUM.ASETATTRIBUTE(evalue("N"+num$(ILINE)),func ASYRSUB.CODATT("H"),func ASYRSUB.BOOLEAN_TO_SYR(2))
# Endif
#Next

#Flag modifiable
If ADV.UPDFLG = func ASYRSUB.BOOLEAN_TO_ADX("true")
Endif

#Filtre société
If ADV.FLGSOC = func ASYRSUB.BOOLEAN_TO_ADX("true")
Endif

#Filtre législation
If ADV.FLGLEG = func ASYRSUB.BOOLEAN_TO_ADX("true")
Endif

#Flag actif
If ADV.FLGENA = func ASYRSUB.BOOLEAN_TO_ADX("true")
Endif

#Longueur modifiable
If ADV.LNGFLG = func ASYRSUB.BOOLEAN_TO_ADX("true")
Endif

FreeInstance ADV
Return


$AINSERT
Local Integer ILINE
#** Control  (Done here because the type 'Interface' of the class APLCOMH)
Gosub CTL_LEAST_ONE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#** Insert
For ILINE=1 To maxtab(this.ACOLADI)
     If this.ACOLADI(ILINE).NUMTAB<>""
        If this.ACOLADI(ILINE).ASTALIN = [V]CST_ANEW
            [L]ASTATUS = fmet this.ACOLADI(ILINE).AINSERT()
            If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
        Endif
    Endif
Next
Return


$AUPDATE
Local Integer ILINE
#** Control (Done here because the type 'Interface' of the class APLCOMH)
Gosub CTL_LEAST_ONE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

#**----------
#** Update
#**----------
#** Deleted lines
For ILINE= 1 To maxtab(this.ACOLADI)
    If this.ACOLADI(ILINE).ASTALIN = CST_ADEL
        [L]ASTATUS = fmet this.ACOLADI(ILINE).ADELETE()
        If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
    Endif
Next
#** Updated lines
For ILINE= 1 To maxtab(this.ACOLADI)
    If this.ACOLADI(ILINE).ASTALIN = CST_AUPD
            [L]ASTATUS = fmet this.ACOLADI(ILINE).AUPDATE()
            If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
    Endif
Next
#** Inserted lines
For ILINE= 1 To maxtab(this.ACOLADI)
    If this.ACOLADI(ILINE).ASTALIN = [V]CST_ANEW
        [L]ASTATUS = fmet this.ACOLADI(ILINE).AINSERT()
        If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
    Endif
Next
Return

$ADELETE
Local Integer ILINE
For ILINE= 1 To maxtab(this.ACOLADI)
    [L]ASTATUS = fmet this.ACOLADI(ILINE).ADELETE()
    If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
Next
Return

$CTL_LEAST_ONE
Local Shortint ERR  : ERR=1
If maxtab(this.ACOLADI)>=1
    Local Integer ILINE
    For ILINE=1 To maxtab(this.ACOLADI)
        If this.ACOLADI(ILINE).ASTALIN<>[V]CST_ADEL
            ERR=0  : Break
        Endif
    Next
Endif
If ERR
    #Il doit y avoir au moins une ligne
    [L]ASTATUS = fmet this.ASETERROR("",mess(178,123,1),[V]CST_AERROR)
    Return
Endif
Return


#*********************************************
#* Methods from APLCOM or Collection ACOLADI
#*!


$ACOLADI_AREAD_AFTER
#Réécriture des ASTALIN car aprés raead toute ligne avec ASTALIN=2
#**Rewrite ASTALIN on lines from APLCOM because they all have ASTALIN=2 after method AREAD
this.ASTALIN = [V]CST_ALL
Return


$ACOLADI_ADDLINE_AFTER
#** To initialize properties of the header
this.NUMTAB = this.APARENT.NUMTAB
Return


#############
# PROPERTIES
#############
#*!
$PROPERTIES
Case CURPRO
    When "NUMTAB"   : Gosub NUMTAB
    When "ACOLADI.CODE" : Gosub ACOLADI_CODE
Endcase
#Les Alphanumériques A1 à A15 & les numériques N1 à N15
If (left$(CURPRO,9)="ACOLADI.A" | left$(CURPRO,9)="ACOLADI.N") & (val(right$(CURPRO,10))>1 & val(right$(CURPRO,10))<15)
  Gosub COLUMN
Endif
Return

#######
$NUMTAB
Case ACTION
    When "CONTROL"   : Gosub NUMTAB_CONTROL
    When "PROPAGATE" : Gosub NUMTAB_PROPAGATE
Endcase
Return

$NUMTAB_CONTROL
Return

$NUMTAB_PROPAGATE
Local Integer ILINE
For ILINE= 1 To maxtab(this.ACOLADI)
    this.ACOLADI(ILINE).NUMCAR = num$(this.NUMTAB)
Next
Return


#######
$ACOLADI_CODE
Case ACTION
    When "CONTROL"   : Gosub ACOLADI_CODE_CONTROL
Endcase
Return

$ACOLADI_CODE_CONTROL
this.CODE=toupper(this.CODE)
#** Unicity of the line index
Local Integer ILINE
Local Shortint OCCUR : OCCUR=0
For ILINE=1 To maxtab(this.APARENT.ACOLADI)
    If this.APARENT.ACOLADI(ILINE).ASTALIN<>[V]CST_ADEL & this.APARENT.ACOLADI(ILINE).CODE=this.CODE
        OCCUR+=1
        If OCCUR>1 : Break : Endif
    Endif
Next
If OCCUR=2
    # Déjà utilisé
    [L]ASTATUS = fmet this.ASETERROR("CODE",this.CODE-":"-mess(94,139,1),[V]CST_AERROR)
Endif
Return


#####
$COLUMN
Case ACTION
 When "CONTROL" : Gosub COLUMN_CONTROL
Endcase
Return


$COLUMN_CONTROL
Local Instance ADV Using C_ATABTAB
ADV = NewInstance With C_ATABTAB
[L]ASTATUS = fmet ADV.AREAD(this.APARENT.NUMTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

#** TODO
#* Identify types on column and write a subrog
#* equivalent to vintage X3 Call CONTROL() From CONTOBJ
#*!


Return
