#<AdxTL>@(#)7.0.0.0 $Revision$
############################################################  
## DOSDICFNC Remplissage du dico des fonctions
############################################################  
$DICFNC  
# Remplissage du dico des fonctions  
Call ECR_TIME(mess(15,125,1)-mess(21,125,1)) From DOSSUB
# MAJ dictionnaire - Fonctions  
Local File =GDOSREF+".AFONCTION" [AFC]  
Local File =GDOSREF+".AVARLOC"   [AVR] 
Local File =[F:ADS]DOSSIER+".AFONCTION"    [DAFC]
Local File =[F:ADS]DOSSIER+".AFONCTION"    [DAF2]
Local File =[F:ADS]DOSSIER+".AREPORTV"     [DARV]
Local File =[F:ADS]DOSSIER+".ACTION"       [DACT]
Local File =[F:ADS]DOSSIER+".AVARLOC"      [DAVR]
If !GCRE
 Local File =[F:ADS]DOSSIER+".AFCTPRF"     [DAFP]
 Local File =[F:ADS]DOSSIER+".AFCTFCY"     [DAFF]
Endif

Local Integer FNCNUM

If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(21,125,1),"") From GESECRAN
Endif

## Effacement anciennes fonctions

If !GCRE    
 Trbegin [DAFC],[DAVR]  
  For [DAFC]CODINT
   K = 0
   If left$([F:DAFC]CODINT,3)="GES"
    K = ([F:DAFC]CODINT<"GES"+GXX)
   Elsif left$([F:DAFC]CODINT,4)="CONS"
    K = ([F:DAFC]CODINT<"CONS"+GXX)
   Else 
    K = ([F:DAFC]CODINT<GXX)
   Endif
   If K
    Call SPEC([F:DAFC]CODACT,SPEC) From DOSSUB    
    If !SPEC    
     Read [AFC]CODINT = [F:DAFC]CODINT    
     If fstat
      Call EFFACE([F:ADS]DOSSIER,[F:DAFC]CODINT)
     Endif
    Endif    
   Endif
  Next DAFC
 Commit   
Endif    

## Mise à jour

For [AFC]
 K = 0
 If left$([F:AFC]CODINT,3)="GES"
  K = ([F:AFC]CODINT<"GES"+GXX)
 Elsif left$([F:AFC]CODINT,4)="CONS"
  K = ([F:AFC]CODINT<"CONS"+GXX)
 Else 
  K = ([F:AFC]CODINT<GXX)
 Endif
 If K
  If GINFO
   Call AFF_VLC(mess(15,125,1)-mess(21,125,1),[F:AFC]CODINT) From GESECRAN
  Endif
  Trbegin [DAFC] , [DAVR] 
   OLD = 0  
   SPEC = 0  
   Read [DAFC]CODINT = [F:AFC]CODINT  
   If !fstat  
    OLD = 1  
    Call SPEC([F:DAFC]CODACT,SPEC) From DOSSUB  
   Endif  
   Call NEWREC([F:ADS]DOSSIER,[F:AFC]CODACT,[F:AFC]MODULE,NEWREC) From DOSSUB  
   If !SPEC  

    If OLD & !NEWREC : # On le vire   

     Call EFFACE([F:ADS]DOSSIER,[F:DAFC]CODINT)

    Elsif NEWREC & !OLD  

     Gosub NUMFNC
     Raz [F:DAFC]  
     [F:DAFC] = [F:AFC]  
     [F:DAFC]CREDAT = date$
     [F:DAFC]CREUSR = GUSER
     If dim([F:DAFC]CRETIM)>0 : [F:DAFC]CRETIM = time : Endif
     [F:DAFC]NUMFNC = FNCNUM
     Write [DAFC]  
     If fstat : Call ERREUR("AFONCTION"-[F:DAFC]CODINT,1) From DOSDIC : Endif
     
     ## Contexte assistant de formules

     For [AVR]AVR0 Where TYP=2 & FCT=[F:DAFC]CODINT
      Raz [F:DAVR]  
      [DAVR] = [AVR] 
      [F:DAVR]CREDAT = date$  
      [F:DAVR]CREUSR = GUSER 
      If dim([F:DAVR]CRETIM)>0 : [F:DAVR]CRETIM = time : Endif
      Write [DAVR]  
      If fstat : Call ERREUR("AVARLOC"-[F:DAVR]FCT,2) From DOSDIC : Endif
     Next AVR 
     
     ## Validation de la fonction

     If [F:DAFC]TYPTRAIT<>2 and [F:DAFC]FCYAUZ=2 and !GCRE
      Call VALCREFNC([F:ADS]DOSSIER,[F:DAFC]CODINT,[F:DAFC]TYP,[F:DAFC]NBOPT,[F:DAFC]FLAG)
     Endif
 
    Elsif NEWREC & OLD

     If [F:DAFC]NUMFNC=[F:AFC]NUMFNC
      FNCNUM = [F:DAFC]NUMFNC
     Else
      Gosub NUMFNC
      Read [DAFC]CODINT = [F:AFC]CODINT
     Endif
     [F:DAF2] = [F:DAFC]
     [F:DAFC] = [F:AFC] 

     ## Protection des options avec code activité

     For B=0 To [F:DAF2]NBOPT-1
      If find([F:DAF2]ACTOPT(B),GSPE(1..GNBSPE))
       L = find([F:DAF2]FLAG(B),[F:DAFC]FLAG(0..[F:DAFC]NBOPT-1))
       If !L
        [F:DAFC]NBOPT += 1
        L = [F:DAFC]NBOPT
       Endif
       [F:DAFC]FLAG(L-1)   = [F:DAF2]FLAG(B)
       [F:DAFC]ACTOPT(L-1) = [F:DAF2]ACTOPT(B)
       [F:DAFC]OPTION(L-1) = [F:DAF2]OPTION(B)
       [F:DAFC]FNCOPT(L-1) = [F:DAF2]FNCOPT(B)
      Endif
     Next B
     
     ## Protection des variables avec code activité

     For B=0 To [F:DAF2]NBVAR-1
      If find([F:DAF2]ACTVAR(B),GSPE(1..GNBSPE))
       L = find([F:DAF2]VARIA(B),[F:DAFC]VARIA(0..[F:DAFC]NBVAR-1))
       If !L    
        [F:DAFC]NBVAR += 1
        L = [F:DAFC]NBVAR
       Endif
       [F:DAFC]ACTVAR(L-1) = [F:DAF2]ACTVAR(B)
       [F:DAFC]VARIA(L-1)  = [F:DAF2]VARIA(B)
       [F:DAFC]VALEUR(L-1) = [F:DAF2]VALEUR(B)
      Endif
     Next B
    
     ## Contexte assistant de formules

     Delete [DAVR] Where TYP=2 & FCT=[F:DAFC]CODINT
     If fstat=1 : Call ERREUR("AVARLOC"-[F:DAFC]CODINT,3) From DOSDIC : Endif
   
     For [AVR] Where TYP=2 & FCT=[F:DAFC]CODINT
      Raz [F:DAVR]  
      [DAVR] = [AVR] 
      [F:DAVR]UPDDAT = date$  
      [F:DAVR]UPDUSR = GUSER 
      If dim([F:DAVR]UPDTIM)>0 : [F:DAVR]UPDTIM = time : Endif
      Write [DAVR]  
      If fstat : Call ERREUR("AVARLOC"-[F:DAVR]FCT,2) From DOSDIC : Endif
     Next AVR 

     ## Réécriture

     [F:DAFC]UPDDAT = date$  
     [F:DAFC]UPDUSR = GUSER 
     If dim([F:DAFC]UPDTIM)>0 : [F:DAFC]UPDTIM = time : Endif
     [F:DAFC]NUMFNC = FNCNUM
     Rewrite [DAFC]  
     If fstat : Call ERREUR("AFONCTION"-[F:DAFC]CODINT,2) From DOSDIC : Endif  

     ## Validation de la fonction

     If [F:DAF2]TYP<>[F:DAFC]TYP or [F:DAF2]FCYAUZ<>[F:DAFC]FCYAUZ or sum([F:DAF2]FLAG)<>sum([F:DAFC]FLAG)
      Call VALMODFNC([F:ADS]DOSSIER,[F:DAFC]CODINT,[F:DAFC]TYP,[F:DAFC]FCYAUZ,[F:DAFC]NBOPT,[F:DAFC]FLAG
&                                                 ,[F:DAF2]TYP,[F:DAF2]FCYAUZ,[F:DAF2]NBOPT,[F:DAF2]FLAG)
     Endif

    Endif  
   Endif  
  Commit  
 Endif
Next AFC

## Renumérotation de AFONCTION

# Plage standard 1..5000
# Plage spécifique > 5001..
# Plage portail et autres 9001..9999
# Plage temporaire 20001..

Trbegin [DAFC]
 X = 20000 : # Plage temporaire
 For [DAFC]CODINT Where NUMFNC<5000
  X += 1
  [F:DAFC]NUMFNC = X
  Rewrite [DAFC]
  If fstat : Call ERREUR("AFONCTION"-[F:DAFC]CODINT,2) From DOSDIC : Endif  
 Next
Commit

Trbegin [DAFC]
 Filter [DAFC] Where NUMFNC<20000
 Read [DAFC]NUMFNC Last
 If fstat : X = 5000 : Else : X = [F:DAFC]NUMFNC : Endif
 Filter [DAFC]
 For [DAFC]CODINT Where NUMFNC>20000
  Read [AFC]CODINT = [F:DAFC]CODINT
  If !fstat & [F:AFC]NUMFNC<5000
   [F:DAFC]NUMFNC = [F:AFC]NUMFNC
  Else
   X += 1
   If X>=9001 & X<=9999 : X = 10000 : Endif
   [F:DAFC]NUMFNC = X
  Endif
  Rewrite [DAFC]
  If fstat : Call ERREUR("AFONCTION"-[F:DAFC]CODINT,2) From DOSDIC : Endif  
 Next
Commit

## Elimination des fonctions avec des actions qui n'existent pas

Trbegin [DAFC]
 For [DAFC] Where ACTION<>""
  Read [DACT]ACTION = [F:DAFC]ACTION
  If fstat
   Delete [DAFC]
   If fstat=1 : Call ERREUR("AFONCTION"-[F:DAFC]CODINT,3) From DOSDIC : Endif  
   Delete [DAVR] Where TYP=2 & FCT=[F:DAFC]CODINT
   If fstat=1 : Call ERREUR("AVARLOC"-[F:DAFC]CODINT,3) From DOSDIC : Endif
   Delete [DARV] Where FONCTION=[F:DAFC]CODINT
   If fstat=1 : Call ERREUR("AREPORTV"-[F:DAFC]CODINT,3) From DOSDIC : Endif    
   If !GCRE
    Delete [DAFP] Where FNC=[F:DAFC]CODINT
    If fstat=1 : Call ERREUR("AFCTPRF"-[F:DAFC]CODINT,3) From DOSDIC : Endif
    Delete [DAFF] Where FNC=[F:DAFC]CODINT
    If fstat=1 : Call ERREUR("AFCTFCY"-[F:DAFC]CODINT,3) From DOSDIC : Endif
   Endif
  Endif
 Next
Commit

## Elimination des menus orphelins

Trbegin [DAFC]
 K = 1
 While K
  K = 0
  For [DAFC]CODINT Where MENU<>"" & [F:DAFC]TYPTRAIT=2
   Read [DAF2]CODINT = [F:DAFC]MENU
   If fstat or [F:DAF2]TYPTRAIT<>2
    Delete [DAFC]
    If fstat
     Call ERREUR("AFONCTION"-[F:DAFC]CODINT,3) From DOSDIC
    Else
     K = 1
    Endif  
   Endif
  Next DAFC
 Wend
Commit

## Elimination des fonctions rattachées à un menu inexistant

Trbegin [DAFC]
 For [DAFC]CODINT Where MENU<>""
  Read [DAF2]CODINT = [F:DAFC]MENU
  If fstat or [F:DAF2]TYPTRAIT<>2
   Delete [DAFC]
   If fstat=1 : Call ERREUR("AFONCTION"-[F:DAFC]CODINT,3) From DOSDIC : Endif  
   Delete [DAVR] Where TYP=2 & FCT=[F:DAFC]CODINT
   If fstat=1 : Call ERREUR("AVARLOC"-[F:DAFC]CODINT,3) From DOSDIC : Endif
   Delete [DARV] Where FONCTION=[F:DAFC]CODINT
   If fstat=1 : Call ERREUR("AREPORTV"-[F:DAFC]CODINT,3) From DOSDIC : Endif    
   If !GCRE
    Delete [DAFP] Where FNC=[F:DAFC]CODINT
    If fstat=1 : Call ERREUR("AFCTPRF"-[F:DAFC]CODINT,3) From DOSDIC : Endif
    Delete [DAFF] Where FNC=[F:DAFC]CODINT
    If fstat=1 : Call ERREUR("AFCTFCY"-[F:DAFC]CODINT,3) From DOSDIC : Endif
   Endif
  Endif
 Next
Commit

Close Local File [AFC] , [AVR] , [DAFC] , [DAF2] , [DARV] , [DACT] , [DAVR] 
If !GCRE : Close Local File [DAFP] , [DAFF] : Endif
Return  

## Attribution du numéro de fonction

$NUMFNC
Read [DAFC]NUMFNC = [F:AFC]NUMFNC
If !fstat
 If [F:AFC]NUMFNC<5000
  Filter [DAFC] Where NUMFNC<5000
 Endif
 Read [DAFC]NUMFNC Last
 FNCNUM = [F:DAFC]NUMFNC+1
 If FNCNUM>=9001 & FNCNUM<=9999
  FNCNUM = 10000
 Endif
 If [F:AFC]NUMFNC>=5000
  FNCNUM = max(FNCNUM,5001)
 Endif
 Filter [DAFC]
Else
 FNCNUM = [F:AFC]NUMFNC
Endif
Return

## Effacement fonction

Subprog EFFACE(APPLI,FONC)
Value Char APPLI , FONC
If !GCRE
 Delete [DAFP] Where FNC=FONC
 If fstat=1 : Call ERREUR("AFCTPRF"-FONC,3) From DOSDIC : Endif
 Delete [DAFF] Where FNC=FONC
 If fstat=1 : Call ERREUR("AFCTFCY"-FONC,3) From DOSDIC : Endif
Endif
Delete [DAVR] Where TYP=2 & FCT=FONC
If fstat=1 : Call ERREUR("AVARLOC"-FONC,3) From DOSDIC : Endif 
Delete [DARV] Where FONCTION=FONC
If fstat=1 : Call ERREUR("AREPORTV"-FONC,3) From DOSDIC : Endif    
Delete [DAFC] Where CODINT=FONC
If fstat=1 : Call ERREUR("AFONCTION"-FONC,3) From DOSDIC : Endif
End

## Validation fonction

Subprog VALCREFNC(APPLI,FCT,TYP,NBR,OPT)
Value Char    APPLI , FCT
Value Integer TYP , NBR
Value Char    OPT()(0..) 
Local File =APPLI+".AFCTFCY" [AFF], =APPLI+".AFCTFCT" [AFT], =APPLI+".FACILITY"  [FCY]
GOK = 1
Call CREATIONFONCTION(FCT,TYP,NBR,OPT) From SUBAFP2
If GOK=1
 Call ECR_TRACE(func AFNC.MES(mess(207,125,1),FCT),0) From GESECRAN : # Fonction # créée
Else
 Call ECR_TRACE(func AFNC.MES(mess(207,125,1),FCT),-1) From GESECRAN : # Fonction # créée
 GOK = 1
Endif
Close Local File
End

Subprog VALMODFNC(APPLI,FCT,TYP,AUZ,NBR,OPT,CURTYP,CURAUZ,CURNBR,CUROPT)
Value Char    APPLI , FCT
Value Integer TYP , AUZ , NBR
Value Char    OPT()(0..)
Value Integer CURTYP , CURAUZ , CURNBR
Value Char    CUROPT()(0..)
Local Char MESSA(250)
Local File =APPLI+".AFCTPRF"   [AFP1] , =APPLI+".AFCTFCY"   [AFF]
&        , =APPLI+".AFCTFCT"   [AFT]  , =APPLI+".FACILITY"  [FCY]
GOK = 1
Call MODIFONCTION(FCT,TYP,AUZ,NBR,OPT,CURTYP,CURAUZ,CURNBR,CUROPT) From SUBAFP2
If TYP<>CURTYP
 If MESSA<>"" : MESSA += ", " : Endif
 MESSA += mess(161,100,1)-mess(CURTYP,1,1) : # Type d'accès
Endif
If AUZ<>CURAUZ
 If MESSA<>"" : MESSA += ", " : Endif
 MESSA += mess(209,125,1)-mess(CURAUZ,1,1) : # Autorisation site
Endif
If sum(OPT)<>sum(CUROPT)
 If MESSA<>"" : MESSA += ", " : Endif
 MESSA += mess(266,142,1)-sum(CUROPT)+"->"+sum(OPT) : # Options
Endif
MESSA = func AFNC.MES(mess(208,125,1),FCT)-":"-MESSA : # Fonction # modifiée
If GOK=1
 Call ECR_TRACE(MESSA,0) From GESECRAN
Else
 Call ECR_TRACE(MESSA,-1) From GESECRAN
 GOK = 1
Endif
Close Local File
End
