#<AdxTL>@(#)9.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour paramètres ASIGMNT et ACLRLOG dans le dossier X3 (uniquement dossier racine)
#----------------------------------------------------------------------------------------#
#
# Valeurs contraignantes (pour législation française) : ACLRLOG à Non et ASIGMNT à Oui
# Valeurs non contraignantes : ACLRLOG à Oui et ASIGMNT à Non
#
# Cet utilitaire permet d'initialiser
# - des valeurs contraignantes sur les valeurs dossiers des dossiers mono-leg FRA
# - des valeurs non contraignantes sur les valeurs dossiers des dossiers mono-leg<>FRA
# - des valeurs non contraignantes sur les valeurs dossiers des dossiers multi-leg
# - des valeurs contraignantes sur les valeurs législation FRA des dossiers multi-leg
#
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update ASIGMNT ans ACLRLOG parameters") From LECFIC
If nomap=GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Endif
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJPAR
End

#-------------------#
$MAJPAR

If DOSSIER<>GDOSX3
 Return
Endif

Local Char WPARAM(30) , WVALEUR(30) , WLEG(GLONADI) , WCMP(GLONCPY) , WFCY(GLONFCY)

Local File =DOSSIER+".ADOVAL" [ADW] , =DOSSIER+".ADOPAR" [ADP] 
Local File ADOSSIER [ADS2]

Read [ADS2]DOSSIER=[L]DOSSIER
If !fstat
 If [F:ADS2]NBLEG>1
  WLEG = ""
 Else
  WLEG = [F:ADS2]DOSLEG(0)
 Endif
 For WPARAM="ASIGMNT","ACLRLOG"
  Read [ADP]ADP1=WPARAM
  If !fstat
   If WLEG="FRA"
    # Dossier mono législation française, les valeurs dossiers doit être être contraignantes
    WVALEUR = ""
    WCMP    = ""
    WFCY    = ""
    Read [ADW]ADW0=WCMP;WFCY;WPARAM
    If !fstat : WVALEUR = [F:ADW]VALEUR : Endif
    Case WPARAM
     When "ACLRLOG" : If WVALEUR<>"1" : WVALEUR = "1" : Gosub TR_PAR : Endif
     When "ASIGMNT" : If WVALEUR<>"2" : WVALEUR = "2" : Gosub TR_PAR : Endif
    Endcase
   Elsif WLEG<>""
    # Dossier mono autre législation, les valeurs dossiers doit être être non contraignantes
    WVALEUR = ""
    WCMP    = ""
    WFCY    = ""
    Read [ADW]ADW0=WCMP;WFCY;WPARAM
    If !fstat : WVALEUR = [F:ADW]VALEUR : Endif
    Case WPARAM
     When "ACLRLOG" : If WVALEUR<>"2" : WVALEUR = "2" : Gosub TR_PAR : Endif
     When "ASIGMNT" : If WVALEUR<>"1" : WVALEUR = "1" : Gosub TR_PAR : Endif
    Endcase
   Else
    # Dossier multi-législation, les valeurs dossiers doit être être non contraignantes
    WVALEUR = ""
    WCMP    = ""
    WFCY    = ""
    Read [ADW]ADW0=WCMP;WFCY;WPARAM
    If !fstat : WVALEUR = [F:ADW]VALEUR : Endif
    Case WPARAM
     When "ACLRLOG" : If WVALEUR<>"2" : WVALEUR = "2" : Gosub TR_PAR : Endif
     When "ASIGMNT" : If WVALEUR<>"1" : WVALEUR = "1" : Gosub TR_PAR : Endif
    Endcase
    # et la valeur législation pour la législation française doit être contraignante
    WVALEUR = ""
    WCMP    = "*"
    WFCY    = "FRA"
    Read [ADW]ADW0=WCMP;WFCY;WPARAM
    If !fstat : WVALEUR = [F:ADW]VALEUR : Endif
    Case WPARAM
     When "ACLRLOG" : If WVALEUR<>"1" : WVALEUR = "1" : Gosub TR_PAR : Endif
     When "ASIGMNT" : If WVALEUR<>"2" : WVALEUR = "2" : Gosub TR_PAR : Endif
    Endcase
   Endif
  Endif
 Next WPARAM
Endif

Close Local File

Return

#-------------------#
$TR_PAR
Trbegin [ADW]
 Read [ADW]ADW0 = WCMP;WFCY;WPARAM
 If fstat
  Raz [F:ADW]
  [F:ADW]CMP    = WCMP
  [F:ADW]FCY    = WFCY
  [F:ADW]PARAM  = WPARAM
  [F:ADW]VALEUR = WVALEUR
  If dim([F:ADW]CREDAT)>0 : [F:ADW]CREDAT = date$ : Endif
  If dim([F:ADW]CRETIM)>0 : [F:ADW]CRETIM = time : Endif
  If dim([F:ADW]CREUSR)>0 : [F:ADW]CREUSR = GUSER : Endif
  Write [ADW]
  If fstat : Call ERREUR("ADOVAL"-WPARAM,1) From DOSDIC : Endif
 Else
  [F:ADW]VALEUR = WVALEUR
  If dim([F:ADW]UPDDAT)>0 : [F:ADW]UPDDAT = date$ : Endif
  If dim([F:ADW]UPDTIM)>0 : [F:ADW]UPDTIM = time : Endif
  If dim([F:ADW]UPDUSR)>0 : [F:ADW]UPDUSR = GUSER : Endif
  Rewrite [ADW]
  If fstat : Call ERREUR("ADOVAL"-WPARAM,2) From DOSDIC : Endif
 Endif
Commit
Call ECR_TIME(WCMP-WFCY-WPARAM-":"-mess(167,139,1)-"("+WVALEUR+")") From DOSSUB : # Paramètre mis à jour
Return

