#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################
Subprog IB_NBRTN

  Raz GBOUT1
  If [M:CMG3]RTNNBR(nolign-1) > 0 Then
    GBOUT1 = mess(nolign,3031,1)
  Endif
End

##########################################################################
Subprog AS_NBRTN

  Call INIT_DESOBJ(nolign)
End

##########################################################################
Subprog C_NBRTN

  Call INIT_DESOBJ(nolign)
End

##########################################################################
Subprog INIT_DESOBJ(ILIGNE)
Value Integer ILIGNE

  If ILIGNE > 0 Then
    Case ILIGNE 
      When 1
        [M:CMG3]DESOBJ = "TSK"
      When 2
        [M:CMG3]DESOBJ = "CLL"
      When 3
        [M:CMG3]DESOBJ = "BAP"
      When 4
        [M:CMG3]DESOBJ = "OPP"
      When 5
        [M:CMG3]DESOBJ = "SOH"
      When 6
        [M:CMG3]DESOBJ = "SIH"
    Endcase
  Endif
End

