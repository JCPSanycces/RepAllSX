Variable Char    VALEUR()
TYD = 4 : Goto AS_CPA
Subprog AS_CPA5(VALEUR)
Variable Char    VALEUR()
TYD = 5 : Goto AS_CPA
Subprog AS_CPA6(VALEUR)
Variable Char    VALEUR()
TYD = 6 : Goto AS_CPA
Subprog AS_CPA7(VALEUR)
Variable Char    VALEUR()
TYD = 7 : Goto AS_CPA
Subprog AS_CPA8(VALEUR)
Variable Char    VALEUR()
TYD = 8 : Goto AS_CPA
Subprog AS_CPA9(VALEUR)
Variable Char    VALEUR()
TYD = 9 : Goto AS_CPA
Subprog AS_CPA10(VALEUR)
Variable Char    VALEUR()
TYD = 10 : : Goto AS_CPA

$AS_CPA
If GIMPORT & TYD>1 : mkstat=2 : End : Endif
#--- En cas de pièce en état Définitif, la modification y est impossible (Demande 49275)
If (GREP="" | GREP="M") & [M]STA>1
 mkstat=2 : End
Endif
End

Subprog C_CPA1(VALEUR)
Variable Char    VALEUR()
TYD = 1 : Goto CONTCPA
Subprog C_CPA2(VALEUR)
Variable Char    VALEUR()
TYD = 2: Goto CONTCPA
Subprog C_CPA3(VALEUR)
Variable Char    VALEUR()
TYD = 3: Goto CONTCPA
Subprog C_CPA4(VALEUR)
Variable Char    VALEUR()
TYD = 4: Goto CONTCPA
Subprog C_CPA5(VALEUR)
Variable Char    VALEUR()
TYD = 5: Goto CONTCPA
Subprog C_CPA6(VALEUR)
Variable Char    VALEUR()
TYD = 6: Goto CONTCPA
Subprog C_CPA7(VALEUR)
Variable Char    VALEUR()
TYD = 7: Goto CONTCPA
Subprog C_CPA8(VALEUR)
Variable Char    VALEUR()
TYD = 8: Goto CONTCPA
Subprog C_CPA9(VALEUR)
Variable Char    VALEUR()
TYD = 9: Goto CONTCPA
Subprog C_CPA10(VALEUR)
Variable Char    VALEUR()
TYD = 10: Goto CONTCPA

$CONTCPA
If VALEUR="" : End : Endif
Gosub SETNOL
Local Char WCOA(GLONCOA),WACC(GLONGAC),ABR(10)
Call MSKABR("CPA"+num$(TYD),ABR) From SUBGASA

Case [M:HAEF]TYPENT
 When 1
 # Entry Type : Column
  WCOA = [M:HAEF]COA(TYD-1)
 When 2
  # Entry Type : Row
  WCOA = evalue("[M:"+ABR+"]COA"+num$(TYD)+"(NOL)")
Endcase

Call LEC_GAC(VALEUR,WCOA) From CPTLEC
If fstat
 Call LEC_BPR(VALEUR) From CPTLEC
 If fstat
  GMESSAGE = mess(38,106,1)
  mkstat = 2 : End
 Endif
Endif
End

