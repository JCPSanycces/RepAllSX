Variable Char    VALEUR()
AXE=19 : Goto CONTCCE
Subprog C_CCE20(VALEUR)
Variable Char    VALEUR()
AXE=20 : Goto CONTCCE

$CONTCCE
If [M]FLGREP=2 : End : Endif

Local Integer I,J,K,LIG
Gosub SETNOL
If [M]DSP(NOL)<>"" : End : Endif #60849

If [M:HAEF]TYPENT=1

 For I=1 To GNBSTR
  For J=1 To GNBTYPLED
   If GSTRCOA(I)=GPLAN(J)
    Call CONTCCE(VALEUR,GCODLED(J),[M:HAEF]DIE(AXE-1),[M]FCYLIN(NOL),[M]ACCDAT,
&                      GSTRACC(I),[M]DIE,"[M]CCE#",NOL) From CPTCNT
   Endif
  Next
 Next

Else

 For I=1 To GNBSTR
  LIG=-1
  For K=0 To [M]NBLIG-1
   If [M]LEDTYP(K)=GSTRTYP(I) & [M]IDTLIN(NOL)=GSTRIDT(I) & [M]ACC(K)=GSTRACC(I)
    LIG=K : Break
   Endif
  Next
  If LIG>=0
   For J=1 To GNBTYPLED
    If GSTRCOA(I)=GPLAN(J)
     Call CONTCCE(VALEUR,"",[M:HAEF]DIE(AXE-1),[M]FCYLIN(NOL),[M]ACCDAT,
&                      GSTRACC(I),[M]DIE,"[M]CCE#",NOL) From CPTCNT
    Endif
   Next
  Endif
 Next
Endif
End

$AFF_CCE
If !mkstat & !GIMPORT & VALEUR<>"" & dim([M]AFFICHE)>0
 Raz [M]AFFICHE
 Call LECTEXTRA([M]AFFICHE,"CACCE","DESTRA",[M:HAEF]DIE(AXE-1),VALEUR) From ATEXTRA
 [M]AFFICHE = VALEUR-":"-[M]AFFICHE : Affzo AFFICHE
Endif
Return

