#<AdxTL>@(#)3.0.0.0 $Revision$
# Issue X3-110105- 2018-10-01 by MDJ : Journal entry an error "File Non-existent LED(10)" in SAIVENTILE
# Issue X3-93418 - 2018-08-09 by FHA : accounting cancel of a payment by setting amount to zero: forbidden
# Issue X3-68928 - 2018-08-24 Bader  : SAIACC: Choose correct text for button 4: either "Account inquiry" or "Analytical account inquiry"
# Issue 101254 - 2018-07-18 by SEMOL : cursor directed to project field then turning the acc. entry into final
#*********************************************************************
#
#                     GESTION DES PIECES COMPTABLES
#
#*********************************************************************
#
# CBO   14.11.17 X3-63004    Bad copy from social to another account (IAS)
#
GBIDC1="" : GBIDC2="" : GFLAG="COL1"
Call OBJET("GAS",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "VERF_TABLE"  : Gosub VERF_TABLE
 When "AB4_DEB"     : Gosub AVTMNT From SAIMONT
 When "BB4_DEB"     : Gosub APSMNT From SAIMONT
 When "AB4_CDT"     : Gosub AVTMNT From SAIMONT
 When "BB4_CDT"     : Gosub APSMNT From SAIMONT
 When "TRT_DIV"     : Gosub TRT_DIV
 When Default
Endcase
Return

######################################################################
$SEL_TABLE
Case TABLE
 When "GASSCHEMA"  : Gosub S_SCHEMA
Endcase
Return

$S_SCHEMA
OBJET = "GDA"
VALEUR = 1
START = "NUMLIG"
Return

######################################################################
$VERF_TABLE
Case TABLE
 When "GASSCHEMA" : Gosub VERF_SCHEMA
Endcase
Return

$VERF_SCHEMA
Local Integer SVGNB : SVGNB=[M]NBLIG
Local Integer OK : OK = 1
SCHEMA = [F:GDA]DIA
If SCHEMA<>""
 Gosub SCHEMA From SUBGA1
 If OK
  If [F:GDE]FLGPAG<>2
   Affzo 20, 25
  Else
   Affzo 50, 60
  Endif
  For I=[L]SVGNB To [M]NBLIG-1
   If [M]DEB(I)=0 & [M]CDT(I)=0
    Raz [M]DEB(I),CDT(I)
   Endif
  Next
  #83797 Passage en modif
  mkstat=4
 Endif
Endif
Return

#######################################################################
$SEL_LISTE
Case LISTE
 When "GASDACDIA" : Gosub S_DACDIA
 When "GASACC"    : Gosub ACC
Endcase
Return

$S_DACDIA
Local Char TEX(GLONAX3)
TIT = mess(52,105,1)
NBTEX = 0
For [GDE] Where FLGLOT=2 : # Catégorie par lot
 Call CONTEXE([F:GDE]ACS) From CPTSUB
 If !mkstat
  If NBTEX<dim(TEXTE)-1
   NBTEX += 1
   TEX(NBTEX)   = [F:GDE]DIA
   Call LECTEXTRA([L]TEX,"GDIAENTRY","DESTRA",[F:GDE]DIA,"") From ATEXTRA
   TEXTE(NBTEX) = format$("K:11X",[F:GDE]DIA)+[L]TEX
  Endif
 Endif
Next
Return

$ACC
TIT = mess(50,106,1)
NBTEX = 0
For I=0 To [F:JCO]FRQNBR-1
 NBTEX += 1
 TEX(NBTEX)   = [F:JCO]FRQACC(I)
 TEXTE(NBTEX) = [F:JCO]FRQCOD(I)-[F:JCO]FRQACC(I)
Next I
Return

#######################################################################
#-- Initialisation des valeurs pour le Tunnel vers les Consultations
#######################################################################
$TRT_DIV

Local Integer IND,AXI,TYD
Local Decimal FIY
Local Char WACC(GLONGAC), WLED(GLONLED), WCUR(GLONCUR)

Case TRAIT
 When "GAC" :
  Case [M:HAEF]TYPENT
   When 1,3
    # Entry Type : Column
    For I=1 To [M:HAEF]NBRLED
     WACC = evalue("[M]ACC"+num$(I)+"("+num$(nolign-1)+")")
     If WACC<>""
      TYD=[M:HAEF]LEDTYP(I-1)
      Call INDLED([M:HAEF]LED(I-1),"",IND,AXI) From CPTDIV
      If GLEDFLGGEN(IND)=2 : Gosub LECTURE : Break : Endif
     Endif
    Next
   When 2
    # Entry Type : Row
    If [M]ACC1(nolign-1)<>""
     WACC=[M]ACC1(nolign-1)
     TYD=[M]LEDTYP(nolign-1)
     Call LECLED([M]CPY,TYD,WLED,WCUR) From CPTDIV
     Call INDLED(WLED,"",IND,AXI) From CPTDIV
     If GLEDFLGGEN(IND)=2 :  Gosub LECTURE : Endif
    Endif
  Endcase

 When "CNA" :
  Case [M:HAEF]TYPENT
   When 1,3
    # Saisie en colonne
    For I=1 To [M:HAEF]NBRLED
     WACC = evalue("[M]ACC"+num$(I)+"("+num$(nolign-1)+")")
     If WACC<>""
      TYD=[M:HAEF]LEDTYP(I-1)
      Call INDLED([M:HAEF]LED(I-1),"",IND,AXI) From CPTDIV
      If GLEDFLGANA(IND)=2 : Gosub LECTURE : Break : Endif
     Endif
    Next
   When 2
    # Entry Type : Row
    If [M]ACC1(nolign-1)<>""
     WACC=[M]ACC1(nolign-1)
     TYD=[M]LEDTYP(nolign-1)
     Call LECLED([M]CPY,TYD,WLED,WCUR) From CPTDIV
     Call INDLED(WLED,"",IND,AXI) From CPTDIV
     If GLEDFLGANA(IND)=2 :  Gosub LECTURE : Endif
    Endif
  Endcase

  #<TODOR 85900
  When "GASVATLIN": Gosub TRT_DIV From SUBGA10
  #TODOR 85900>
Endcase
Return

$LECTURE
Call LEC_GAC(WACC,GLEDCOA(IND)) From CPTLEC
Call GETEXE([M]CPY,TYD,[M]ACCDAT,[L]FIY) From CPTSUB
Call LECTURE("FIY",num$(TYD),[M]CPY+'~'+num$([L]FIY)) From CONTOBJ
Return

Funprog GET_VALUE_FIELD(FLD)
Value Char FLD
Local Char ABR(10)

Call MSKABR(FLD,ABR) From SUBGASA
If ABR="HAE0"
 End evalue("[M:HAE0]"+FLD)
Elsif ABR="HAE1"
 End evalue("[M:HAE1]"+FLD)
Elsif ABR="HAE2"
 End evalue("[M:HAE1]"+FLD)
Endif
End ""

Funprog GET_NAME_FIELD(FLD)
Value Char FLD
Local Char ABR(10)

Call MSKABR(FLD,ABR) From SUBGASA
If ABR="HAE0"
 End "[M:HAE0]"+FLD
Elsif ABR="HAE1"
 End "[M:HAE1]"+FLD
Elsif ABR="HAE2"
 End "[M:HAE2]"+FLD
Endif
End ""

#################################################################
# Etiquette masque HAE0                                         #
#################################################################
#################################################################
Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If sum([M]MTC)     <> "" : mkstat = 2
Elsif sum([M]CHK)  <> "" : mkstat = 2
Elsif     [M]NBLIG <> 0  : mkstat = 2
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If GFLAG<>""
 If clalev([F:GDE])=0 : Local File GDIAENTRY [GDE] : Endif
 If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
 If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
 Call LEC_GDE(GFLAG) From CPTLEC
 Call LEC_FCY(VALEUR) From CPTLEC
 Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
 If [F:GDE]LEG<>"" & [F:CPY]LEG<>[F:GDE]LEG
  GMESSAGE += mess(52,105,1)-GFLAG+"\"+mess(62,127,1)-":"-[F:GDE]LEG
  mkstat = 2 : End
 Endif
Endif
Call GETSOC(VALEUR) From DEVSUB
End

Subprog AM_FCY(VALEUR)
Variable Char     VALEUR
Local Char PARAM(GLONADW)
Local Integer OK, STAT
Call LEC_FCY(VALEUR) From CPTLEC
[M]CPY = [F:FCY]LEGCPY
Call LEC_CPY([M]CPY) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
#--- Gestion multi société - Verrouillage société
Call UNLOCKCPY() From AX3MONO
Call LOCKCPY([M]CPY,OK) From AX3MONO
#If !OK : mkstat=2 : End : Endif #F58178
If !OK
 OK = 2 : Call AVERTIR(mess(216,126,1)-[M]CPY,OK) From GESECRAN
 If OK<>2 : mkstat = 2 : End : Endif
Endif
Call UNLOCKCPY From AX3MONO

# Issue 114426 - 2016-03-21 by RICAR : SIVSUP parameter to split in PIVSUP and GASSUP
# Issue 114426
#--- Parameter "Delete accounting entry" (Use to Delete button)
If dim(GGASSUP)>0
 Call PARAM(VALEUR,"GASSUP",PARAM) From ADOVAL
 GGASSUP=val(PARAM)
Endif
# End issue 114426
#--- Parameter "Lines set to zero prohibited"
If dim(GSIVNULL)>0
 Call PARAM(VALEUR,"SIVNULL",PARAM) From ADOVAL
 GSIVNULL=val(PARAM)
Endif
#--- Code taxe obligatoire
If dim(GSAITAX)>0
 Call PARAM(VALEUR,"SAITAX",PARAM) From ADOVAL
 GSAITAX  = val(PARAM)
Endif
#--- Code taxe exonéré
If dim(GEXETAX)>0
 Call PARAM(VALEUR,"EXETAX",PARAM) From ADOVAL
 GEXETAX  = PARAM
Endif
#--- Initialisation et contrôle des masques
If [M]TYP<>""
 Call INIMSKFMT(VALEUR,GFLAG,[M]TYP,[M]ACCDAT,STAT)  From SUBGASA
 If STAT
  GMESSAGE=""
  Call TITOBJ("GDE","!",GMESSAGE) From CONTOBJ
  Gosub MESSAGE From CPTAUTO
  GMESSAGE -= ":"-[F:GDE]DIA+"\"+mess(86,105,1)+"\"+MESSA
  mkstat =2 : End
 Endif
Endif

#--- Itialisation des cours devise
If [M]RATDAT<>[0/0/0] & [M]CUR<>""
 Gosub CHARG_ZONES_DEV From SUBGA0
 Gosub INIT_COURS From SUBGA0
Endif
Call GETSOC(VALEUR) From DEVSUB

# X3-103268
#If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M]CPY,"PJTMGT")>0 # PJT managed for the company
If func AFNC.ACTIV("PJM") and fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M]CPY,"PJTMGT")>0 # PJT managed for the company
 Local Char ABR(10)
 #--- PJT managed or not
 Call MSKABR("PJTLIN",ABR) From SUBGASA
 If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M]CPY,"PJTMGT")<>2 # PJT not managed for the company
  Chgfmt [M:HAE1]PJT        With "-K:40X"       # Hide PJT field
  If ABR="HAE2"
   Chgfmt [M:HAE2]PJTLIN   With "-K:40X"       # Hide PJTLIN column
  Else
   Chgfmt [M:HAE1]PJTLIN   With "-K:40X"       # Hide PJTLIN column
  Endif
 Else # PJT managed for the company
  Chgfmt [M:HAE1]PJT         With "K:40X"        # Display PJT field
  If ABR="HAE2"
   Chgfmt [M:HAE2]PJTLIN   With "K:40X"       # Display PJTLIN column
   Call PJT_MODFCY(VALEUR, "[M:HAE2]PJTLIN") From TRTPJT
  Else
   Chgfmt [M:HAE1]PJTLIN   With "K:40X"       # Display PJTLIN column
   Call PJT_MODFCY(VALEUR, "[M:HAE1]PJTLIN") From TRTPJT
  Endif
 Endif
Endif
End

Subprog D_CPY(VALEUR)
Variable Char     VALEUR

Call LEC_FCY([M]FCY) From CPTLEC
VALEUR = [F:FCY]LEGCPY
Call LEC_CPY(VALEUR) From CPTLEC
End

Subprog C_TYP(VALEUR)
Variable Char    VALEUR
Call CONTEXE([F:GTE]ACS) From CPTSUB
If mkstat : End : Endif
If [F:GTE]PER>1 & find(GREP,"C","D") : Gosub SETDAT : Endif
End

Subprog AM_TYP(VALEUR)
Variable Char    VALEUR
If GIMPORT : End : Endif

If find(GREP,"C","D")
 Raz [M]ACCDAT, [M]ENTDAT
 Call DEFCODZON("TRAT","TYPRAT","[F:GTE]TYPRAT") From SUBGAS
Endif
Local Integer STAT
#--- Initialisation et contrôle des masques
Call INIMSKFMT([M]FCY,GFLAG,VALEUR,[M]ACCDAT,STAT)  From SUBGASA
If STAT
 GMESSAGE=""
 Call TITOBJ("GDE","!",GMESSAGE) From CONTOBJ
 Gosub MESSAGE From CPTAUTO
 GMESSAGE -= ":"-[F:GDE]DIA+"\"+mess(86,105,1)+"\"+MESSA
 mkstat=2 : End
Endif
If [F:GTE]PER>1 & find(GREP,"C","D") : Gosub SETDAT : Endif

# Suite à l'INIMSKFMT, un RAZ est effectué sous HAEF, dans le cas d'une modification du type de pièce
#  juste avant d'enregistrer... (ou en cours de saisie des lignes d'écritures) => Ré-initialise les cours
#--- Itialisation des cours devise
If [M]CUR<>"" :
 Gosub INIT_COURS From SUBGA0
Endif
Raz [M]FLGDAS # Exigence 82615 : Législation belge
End

Subprog AS_ACCDAT(VALEUR)
Variable Date     VALEUR

If VALEUR=[0/0/0] | ([F:GTE]PER>1 & find(GREP,"C","D"))
 Gosub SETDAT : VALEUR = DAT
Endif
If (GREP="" | GREP="M") & [M]STA>1
 mkstat=2 : End : # Définitif
Elsif [F:GTE]PER>1
 For I=1 To 10
  Call GETPERSOC([M]CPY,I,VALEUR,[M:HAEF]FIY(I-1),[M:HAEF]PER(I-1)) From CPTSUB
  Case [F:GTE]PER
   When 1       :
   When 2       : [M:HAEF]PER(I-1)  = 0
   When Default : [M:HAEF]PER(I-1) += [F:GTE]PER-2
  Endcase
 Next
 mkstat=2 : End
Endif
End

Subprog C_ACCDAT(VALEUR)
Variable Date     VALEUR
#--- Divers contrôles de validité de dates (Transaction, type de pièce, compte, répartition et sections)
Gosub CONTDAT From SUBGA1
If mkstat : End : Endif
If [M]ACCDAT=VALEUR
 If !find(GREP,"C","D") : mkstat=0 : Endif
Endif

#--- Control by module of a document creation date
If clalev([F:AOB])  = 0 : Local File AOBJET [AOB] : Endif
If find(GREP,"C","D")
 Call LECTURE("AOB",GABREV,"") From CONTOBJ
 Local Integer MODULE
 MODULE = [F:AOB]MODULE
 Call CTLDATMOD(MODULE,VALEUR,GSOCIETE) From CPTSUB
 If mkstat : End : Endif
Endif

If GCOMPTA<>3 & !find(GREP,"C","D") & !GIMPORT
 Local Date DATMAX, DATMIN
 If !clalev([F:DAE9]) : Local File =GTABCPT+"GACCENTRYD" [DAE9] : Endif
 Raz DATMAX, DATMIN
 For [DAE9]DAE0 Where TYP = [M]TYP & NUM = [M]NUM & MTC>="A" & MTC<="ZZZZZ"
  DATMAX = max([F:DAE9]MTCDATMAX,DATMAX)
  If DATMIN<>[0/0/0]
   DATMIN = min([F:DAE9]MTCDATMIN,DATMIN)
  Else
   DATMIN = [F:DAE9]MTCDATMIN
  Endif
 Next
 If DATMAX<>[0/0/0] & DATMIN<>[0/0/0]
  If VALEUR>DATMAX
   GMESSAGE = mess(72,105,1)-":"-format$("D:"+GFMDAT,DATMAX)
   mkstat = 2 : End
  Elsif VALEUR<DATMIN
   GMESSAGE = mess(95,105,1)-":"-format$("D:"+GFMDAT,DATMIN)
   mkstat = 2 : End
  Endif
 Endif
 If func AFNC.ACTIV("HDU") & [M]ACCDAT<>VALEUR
  Local Integer FLGHDU
  If !clalev([F:DAE9]) : Local File =GTABCPT+"GACCENTRYD" [DAE9] : Endif
  Raz FLGHDU
  For [DAE9]DAE0 Where TYP = [M]TYP & NUM = [M]NUM & MTC<>""
   FLGHDU=1 : Break
  Next
  If FLGHDU
   GMESSAGE = mess(124,106,1)
   mkstat = 2 : End
  Endif
 Endif
Endif

#--- Itialisation des cours devise
If [M]RATDAT=[0/0/0] & varmode([M]RATDAT)=3
 [M]ACCDAT=VALEUR #F58308
 Call DEFCODZON("DRAT","RATDAT","[0/0/0]") From SUBGAS
 Call D_RATDAT([M]RATDAT)
 If [M]CUR<>""
  Gosub CHARG_ZONES_DEV From SUBGA0
  Gosub INIT_COURS From SUBGA0
 Endif
Endif
End

Subprog AP_ACCDAT(VALEUR)
Variable Date     VALEUR
# Exercice & période
[M]ACCDAT = VALEUR
For I=1 To 10
 Call GETPERSOC([M]CPY,I,VALEUR,[M:HAEF]FIY(I-1),[M:HAEF]PER(I-1)) From CPTSUB
 Case [F:GTE]PER
  When 1       :
  When 2       : [M:HAEF]PER(I-1)  = 0
  When Default : [M:HAEF]PER(I-1) += [F:GTE]PER-2
 Endcase
Next
End

# Appelé sous le CPTBATCH
$SETEXE
Call GETPER([M:HAE0]FCY,GTYPGEN,VALEUR,[M:HAE0]FIY,[M:HAE0]PER) From CPTSUB
Case [F:GTE]PER
 When 1       :
 When 2       : [M:HAE0]PER  = 0
 When Default : [M:HAE0]PER += [F:GTE]PER-2
Endcase
Return

$SETDAT
Local Date    DAT
Raz DAT
Case [F:GTE]PER
 When 1      : # Normale
  DAT = datesyst
 When 2      : # A nouveaux, période 1 premier exercice ouvert
  If GFONCTION<>"GESGAS"
   # Génération de pièces de fin d'exercice <=> mono-référentiel (=V5)
   I = find(2,[F:GTE]AUZLED(0..dim([F:GTE]AUZLED)-1))+find(3,[F:GTE]AUZLED(0..dim([F:GTE]AUZLED)-1))
   Filter [FIY] Where CPY=[M]CPY and FIYSTA=2 and LEDTYP=I
   Read [FIY]FIY0 First
   Filter [FIY]
   If fstat<=2
    Filter [PER] Where FIYNUM=[F:FIY]FIYNUM & LEDTYP=I & CPY=[M]CPY
    Read [PER]PER0 First
    Filter [PER]
     If !fstat & [F:PER]PERSTA=2
     DAT = [F:PER]PERSTR
    Endif
   Endif
   If DAT=[0/0/0]
    GMESSAGE = mess(42,106,1)
    mkstat = 2
   Endif
  Else
   # Saisie de pièces d'à-nouveaux <=> multi-référentiel possible
   For I=1 To 10
    If [M:HAEF]GENC(I-1) = 2
     Filter [FIY] Where CPY=[M]CPY and FIYSTA=2 and LEDTYP=I
     Read [FIY]FIY0 First
     Filter [FIY]
     If fstat<=2
      Filter [PER] Where FIYNUM=[F:FIY]FIYNUM & LEDTYP=I & CPY=[M]CPY
      Read [PER]PER0 First
      Filter [PER]
      If !fstat & [F:PER]PERSTA=2
       If DAT <>[0/0/0] & DAT<>[F:PER]PERSTR : mkstat=2 : Endif
       DAT = [F:PER]PERSTR
      Endif
     Endif
    Endif
   Next
   If DAT=[0/0/0]
    GMESSAGE = mess(42,106,1)
    mkstat = 2
   Elsif mkstat=2
    Raz [L]DAT
    GMESSAGE = mess(11,101,1)
   Endif
  Endif
 When Default   : # Clôture et toutiquanto, last période 1er exer.ouvert
  If GFONCTION<>"GESGAS"
   # Génération de pièces de fin d'exercice <=> mono-référentiel (=V5)
   I = find(2,[F:GTE]AUZLED(0..dim([F:GTE]AUZLED)-1))+find(3,[F:GTE]AUZLED(0..dim([F:GTE]AUZLED)-1))
   For [FIY]FIY0 Where CPY=[M]CPY & LEDTYP=I & FIYSTA=2
    Filter [PER] Where CPY=[M]CPY & LEDTYP=I & FIYNUM=[F:FIY]FIYNUM
    Read [PER]PER0 Last
    Filter [PER]
    If !fstat & [F:PER]PERSTA=2
     DAT = [F:PER]PEREND : Break
    Endif
   Next
   If DAT=[0/0/0]
     GMESSAGE = mess(41,106,1)
    mkstat = 2
   Endif
  Else
   # Saisie de pièces d'à-nouveaux <=> multi-référentiel possible
   For I=1 To 10
    If [M:HAEF]GENC(I-1) = 2
     For [FIY]FIY0 Where CPY=[M]CPY & LEDTYP=I & FIYSTA=2
      Filter [PER] Where CPY=[M]CPY & LEDTYP=I & FIYNUM=[F:FIY]FIYNUM
      Read [PER]PER0 Last
      Filter [PER]
      If !fstat & [F:PER]PERSTA=2
       If DAT <>[0/0/0] & DAT<>[F:PER]PEREND : mkstat=2 : Endif
       DAT = [F:PER]PEREND : Break
      Endif
     Next
    Endif
   Next
   If DAT=[0/0/0]
    GMESSAGE = mess(41,106,1)
    mkstat = 2
   Elsif mkstat=2
    Raz [L]DAT
    GMESSAGE = mess(11,101,1)
   Endif
  Endif
Endcase
Return

Subprog C_NUM(VALEUR)
Variable Char     VALEUR
#F57119 : En import, le Read écrasait les valeurs du fichier importé.
If !GIMPORT
 If VALEUR<>""
  Read [HAE]HAE0 = [M]TYP;VALEUR
  If fstat & [F:GTE]MANNUM<>2 : Raz VALEUR : Endif
 Elsif [F:GTE]COU=""
  GMESSAGE = mess(10,123,1) : mkstat = 1
 Endif
Else
 # Test d'import
 If VALEUR<>""
  If clalev([F:HAE2])=0 : Local File =GTABCPT+"GACCENTRY" [HAE2] : Endif
  Read [HAE2]HAE0 = [M]TYP;VALEUR
  If fstat & [F:GTE]MANNUM<>2 : Raz VALEUR : Endif
 Elsif [F:GTE]COU=""
  GMESSAGE = mess(10,123,1) : mkstat = 1
 Endif
Endif
End

Subprog AP_NUM(VALEUR)
Variable Char     VALEUR
If VALEUR="" : If !GIMPORT : mkstat = 4 : Endif : Endif
End

Subprog D_JOU(VALEUR)
Variable Char     VALEUR
If VALEUR="" : VALEUR = [F:GTE]DEFJOU : Endif
End

Subprog AS_JOU(VALEUR)
Variable Char     VALEUR
If [M]STA>1 & (GREP="M" or GREP="") : mkstat = 2 : End : Endif : # Définitif
End

Subprog C_JOU(VALEUR)
Variable Char     VALEUR
Call LEC_JOU_LEG(GCURLEG,VALEUR) From CPTLEC
Gosub CONTJOU From SUBGA1
If mkstat : End : Endif
End

Subprog AV_STA(VALEUR)
Variable Integer  VALEUR
If !GIMPORT
 If find([M]CAT,2,3)
  Grizo STA   :   mkstat = 1 :   End
 Else
  Actzo STA
 Endif
Endif
End

Subprog D_STA(VALEUR)
Variable Integer  VALEUR
If varinit([M]STA)=0 : VALEUR = 1 : Endif : # Provisoire
End

Subprog AS_STA(VALEUR)
Variable Integer  VALEUR
If ((GREP="M" or GREP="") & VALEUR=2) : mkstat=2 : End : Endif
GMENLOC(3) = 1 : # Le choix 'Annulé' est inaccessible
End

Subprog D_CAT(VALEUR)
Variable Integer  VALEUR
If varinit([M]CAT)=0
 If    [F:GTE]VCRREA=2    : VALEUR=1
 Elsif [F:GTE]VCRSIM=2    : VALEUR=2
 Elsif [F:GTE]VCROUTBSE=2 : VALEUR=4
 Elsif [F:GTE]VCRMOD=2    : VALEUR=5
 Endif
Endif
End

Subprog AS_CAT(VALEUR)
Variable Integer  VALEUR
If [M]STA>1 & (GREP="M" or GREP="") : mkstat=2 : End : Endif
If VALEUR=1 & (GREP="M" or GREP="") : mkstat=2 : End : Endif
End

Subprog C_CAT(VALEUR)
Variable Integer  VALEUR
Call CONTCAT(VALEUR) From SUBGA1
If mkstat : End : Endif
#--- On refuse le passage d'une écriture de simulation en réel si REFSIM est alimentée
If find([M]CAT,2,3) & VALEUR=1 & [M]REFSIM<>''
 GMESSAGE = mess(89,106,1)
 mkstat=2
Endif
End

#################################################################
# Etiquette masque HAE1                                         #
#################################################################

#####------------------------------ Les DATES
Subprog D_ENTDAT(VALEUR)
Variable Date     VALEUR
If VALEUR=[0/0/0] : VALEUR = [M]ACCDAT : Endif
End

Subprog C_ENTDAT(VALEUR)
Variable Date    VALEUR
 If VALEUR < [M]ACCDAT
  GMESSAGE=mess(88,106,1) : mkstat=2
 Endif
End

Subprog D_BANDAT(VALEUR)
Variable Date     VALEUR
If VALEUR=[0/0/0] : VALEUR = [M]ACCDAT : Endif
End

Subprog D_VALDAT(VALEUR)
Variable Date     VALEUR
If VALEUR=[0/0/0] : VALEUR = [M]DUDDAT : Endif
End

Subprog D_DUDDAT(VALEUR)
Variable Date     VALEUR
If VALEUR=[0/0/0] : VALEUR = [M]ACCDAT : Endif
End

Subprog D_RATDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 Call LEC_GTE_LEG(GCURLEG,[M]TYP) From CPTLEC
 If [F:GTE]RATDAT=2 & [M]BPRDATVCR<>[0/0/0]
  VALEUR = [M]BPRDATVCR
 Else
  VALEUR = [M]ACCDAT
 Endif
Endif
End

Subprog AM_RATDAT(VALEUR)
Variable Date    VALEUR
#--- Itialisation des cours devise
If [M]CUR<>""
 [M]RATDAT=VALEUR
 Gosub CHARG_ZONES_DEV From SUBGA0
 Gosub INIT_COURS From SUBGA0
Endif
End

Subprog AM_BPRDATVCR(VALEUR)
Variable Date    VALEUR
If ([M]STA>1 & (GREP="M" or GREP="")) or ([M]ORIMOD<>2) : End : Endif

#--- Itialisation des cours devise (#F58308)
If [M]RATDAT=[0/0/0] & varmode([M]RATDAT)=3
 [M]BPRDATVCR=VALEUR
 Call DEFCODZON("DRAT","RATDAT","[0/0/0]") From SUBGAS
 Call D_RATDAT([M]RATDAT)
 If [M]CUR<>""
  Gosub CHARG_ZONES_DEV From SUBGA0
  Gosub INIT_COURS From SUBGA0
 Endif
Endif
End

#####------------------------------ DEVISES et cours...
Subprog AS_TYPRAT(VALEUR)
Variable Integer VALEUR
If ([M]STA>1 & (GREP="M" or GREP="")) or ([M]ORIMOD<>2) : mkstat=2 : Endif
End

Subprog AM_TYPRAT(VALEUR)
Variable Integer VALEUR
[M]TYPRAT=VALEUR
If [M]RATDAT<>[0/0/0] & [M]CUR<>""
 Gosub CHARG_ZONES_DEV From SUBGA0
 Gosub INIT_COURS From SUBGA0
Endif
End

Subprog D_CUR(VALEUR)
Variable Char     VALEUR
If VALEUR="" & [M]JOU<>""
 Call LEC_JOU_LEG(GCURLEG,[M]JOU) From CPTLEC
 If [F:JOU]TYP=3
  Local Char WCOA(GLONCOA)
  If !clalev([F:BAN]) : Local File BANK    [BAN] : Endif
  If !clalev([F:JCO]) : Local File GJOUCOA [JCO] : Endif
  Call LECMAINPLAN(1,[M]CPY,[L]WCOA) From CPTDIV
  Call LEC_JCO_LEG(GCURLEG,[L]WCOA,[M]JOU) From CPTLEC
  Call LEC_GAC([F:JCO]ACC,[L]WCOA) From CPTLEC
  If [F:GAC]CUR<>""
   [M]CUR = [F:GAC]CUR
   Filter [BAN] Where BANACC=[F:JCO]ACC
   Read [BAN]BAN0 First
   Filter [BAN]
   If !fstat
    If [F:BAN]CHGDAT<>[0/0/0] & [M]ACCDAT < [F:BAN]CHGDAT
     If [F:BAN]OLDCUR<>"" : [M]CUR = [F:BAN]OLDCUR : Endif
    Endif
   Endif
   Call LEC_TCU([M]CUR) From CPTLEC
   VALEUR = [M]CUR : : Affzo [M:HAE1]CUR
   Call AM_CUR([M]CUR) : End
  Endif
 Endif
Endif
If VALEUR=""
 Call LEC_CPY([M]CPY) From CPTLEC
 If !fstat : VALEUR = [F:CPY]ACCCUR : Endif
Endif
#F57098
If varmode([M]CUR)=3
 [M]CUR=VALEUR
 Gosub CHARG_ZONES_DEV From SUBGA0
 Gosub INIT_COURS From SUBGA0
Endif
#End F57098
If VALEUR<>"" : Gosub CURAFF : Endif
End

Subprog AV_CUR(VALEUR)
Variable Char    VALEUR()
If !GIMPORT
 If [M]NBLIG & GREP<>"C" & GREP<>"D"
  Diszo [M]CUR
 Else
  Actzo [M]CUR
 Endif
Endif
End

Subprog AS_CUR(VALEUR)
Variable Char     VALEUR
# 02/08 : Devise : toujours accessible pour atteindre la fenêtre des cours.
#If [M]NBLIG & GREP<>"C" & GREP<>"D" :  mkstat = 2 : Endif
End

Subprog C_CUR(VALEUR)
Variable Char VALEUR()
#If [M]CUR<>VALEUR
# If [M]NBLIG & GREP<>"C" & GREP<>"D" :
# GMESSAGE =mess(9,123,1) :  mkstat = 1   # Modification impossible
# VALEUR=[M]CUR
# Endif
#Endif
If [M]ORIMOD<>2 : End : Endif
Call CONTDEV(VALEUR,[M]ACCDAT) From TRTDEV
If mkstat : End : Endif
End

Subprog AM_CUR(VALEUR)
Variable Char     VALEUR
Local Integer STAT
If !GIMPORT
 [M]CUR=VALEUR : Affzo [M:HAE1]CUR
 Gosub CURAFF
 Gosub CHARG_ZONES_DEV From SUBGA0
 Gosub INIT_COURS From SUBGA0
Endif
End

#CHECK IGNORE_BEGIN
$CURAFF
Local Integer I
For I=0 To 2
 If evalue("dim([M:HAE"+num$(I)+"]CURAFF)>0")
  Case I
   When 0 : [M:HAE0]CURAFF = VALEUR : Affzo [HAE0]CURAFF
   When 1 : [M:HAE1]CURAFF = VALEUR : Affzo [HAE1]CURAFF
   When 2 : [M:HAE2]CURAFF = VALEUR : Affzo [HAE2]CURAFF
  Endcase
 Endif
 If evalue("dim([M:HAE"+num$(I)+"]CURAFF2)>0")
  Case I
   When 0 : [M:HAE0]CURAFF2 = VALEUR : Affzo [HAE0]CURAFF2
   When 1 : [M:HAE1]CURAFF2 = VALEUR : Affzo [HAE1]CURAFF2
   When 2 : [M:HAE2]CURAFF2 = VALEUR : Affzo [HAE2]CURAFF2
  Endcase
 Endif
Next I
#zoncou = "CUR"
Return
#CHECK IGNORE_END

#################################################################
Subprog AS_PJT(VALEUR)
Variable Char    VALEUR()
# X3-103268
#If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M]CPY,"PJTMGT")<>2 : mkstat = 1 : End : Endif
If func AFNC.ACTIV("PJM") and fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M]CPY,"PJTMGT")<>2 : mkstat = 1 : End : Endif
End

#####------------------------------ Les FLAG (DAS,RELANCE,BAP)
Subprog D_FLGDAS(VALEUR)
Variable Integer  VALEUR
# Exigence 82615 : Législation belge --str
#If varinit([M]FLGDAS)=0 : VALEUR=1 : Endif
If varinit([M]FLGDAS)=0 VALEUR=[F:GTE]DAS2 : Endif
# Exigence 82615 : Législation belge --end
End

Subprog AS_FLGDAS(VALEUR)
Variable Integer  VALEUR
Local Decimal EXE
If [M]STA>1 & (GREP="M" or GREP="") & func AFNC.PARAM("FRADGI",[M]CPY)="2"
 Call GETEXE([M]CPY,GTYPLED,[M]ACCDAT,EXE) From CPTSUB
 If !EXE | [F:FIY]FIYSTA<>2
  mkstat=2 : End
 Endif
Endif
If [F:GTE]DAS2<>2 or ([M]CAT<>1 and [M]CAT<>5) : VALEUR = 1 : mkstat = 2 : Endif
End

Subprog D_FLGFUP(VALEUR)
Variable Integer  VALEUR
If varinit([M]FLGFUP)=0
 If [F:GTE]FUP<>2 or ([M]CAT<>1 and [M]CAT<>5) : VALEUR = 1 : Else VALEUR = 2 : Endif
Endif
End

Subprog AS_FLGFUP(VALEUR)
Variable Integer  VALEUR
If [F:GTE]FUP<>2 or ([M]CAT<>1 and [M]CAT<>5) : VALEUR = 1 : mkstat = 2 : Endif
End

Subprog D_FLGPAZ(VALEUR)
Variable Integer  VALEUR
If varinit([M]FLGPAZ)=0
 # Perf... pourquoi lire AUS sur GUSER
 #If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
 #Call LECTURE("AUS",GUSER,"") From CONTOBJ
 Local Char LLEVPAZ(3)
 Call PARAMUTIL("NIVBONPAYE",LLEVPAZ,"","") From SUBAUS
 VALEUR = val(LLEVPAZ)
Endif
End

Subprog AS_FLGPAZ(VALEUR)    # DdM30465
Variable Integer VALEUR
If (GREP<>"C" & GREP<>"D") : mkstat = 2 : End : Endif
Local Char CHAINE(GLONADW)
Call PARAM([M]FCY,"FLGPAZ",CHAINE) From ADOVAL
If val(CHAINE)<>2
 VALEUR = len(mess(0,510,1))
 mkstat = 2 : End
Endif
End

Subprog C_FLGPAZ(VALEUR)
Variable Integer  VALEUR
Local Char LLEVPAZ(3)
Call PARAMUTIL("NIVBONPAYE",LLEVPAZ,"","") From SUBAUS
If VALEUR>val(LLEVPAZ)
 GMESSAGE = mess(29,119,1) : mkstat = 2 : End
Endif
End

#####------------------------------ EXTOURNES
Subprog D_RVS(VALEUR)
Variable Integer  VALEUR
If varinit([M]RVS)=0 : VALEUR = 1 : Endif
End

Subprog AS_RVS(VALEUR)
Variable Integer  VALEUR
If VALEUR=3 : # Extournée
 mkstat = 2 : End
Else
 GMENLOC(3) = 1
 ## Si pièce de règlements (REFINT avec PYH ou FRM) et RVS vaut 'Non' on rend inaccessible la zone (pour ne pas quelle puisse
 ## être modfiée et être passée à "A extourner". Si pièce de règlements (REFINT avec PYH ou FRM) et RVS vaut 'A extourner', on fait un
 ## contrôle en C_RVS
 If VALEUR=1 & (left$([M]REFINT,3)="PYH" | left$([M]REFINT,3)="FRM")
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_RVS(VALEUR)
Variable Integer  VALEUR
If GFONCTION = "GESGAS" & (left$([M]REFINT,3)="PYH" | left$([M]REFINT,3)="FRM") & VALEUR=2
 GMESSAGE = mess(219,107,1)
 mkstat = 2 : End
Endif
End


Subprog AS_RVSDAT(VALEUR)
Variable Date     VALEUR
Case [M]RVS
 When 1
  VALEUR = [0/0/0] : mkstat = 2
 When 3
  mkstat = 2 : End
Endcase

#RMA 85785
If func PORLEGLIB.DIGSIGN("",[M]CPY)
  If !func PORLEGLIB.REVGASOK([M]TYP, [M]ORIMOD) : mkstat = 2 : Endif
Endif
End

Subprog C_RVSDAT(VALEUR)
Variable Date    VALEUR
Local Decimal EXE, PER
If VALEUR<[M]ACCDAT
 GMESSAGE = mess(1,104,1)
 mkstat = 2 : End
Endif

End #ARV150
# #--- Même contrôle de validité que la date comptable...
# Local Char SVGREP : SVGREP=GREP
# GREP="D"
# Gosub SETMSK From SUBGAS
# Call CONTDAT(VALEUR) From SUBGA1
# GREP=SVGREP
# If mkstat : End : Endif
# End
#################################################################
# Etiquette masque HAE2                                         #
#################################################################
Subprog AS_NBLIG
Gosub AFF_NBLIG
End

$AFF_NBLIG
If GIMPORT : Return : Endif
If nolign>0
 Local Char VALEUR(GLONGAC),WACC(GLONGAC)
 Local Integer IND,AXI
 Case [M:HAEF]TYPENT
  When 1
   # Entry Type : Column
   For I=1 To [M:HAEF]NBRLED
    WACC = evalue("[M]ACC"+num$(I)+"("+num$(nolign-1)+")")
    WCOA = [M:HAEF]COA(I-1)
    If WACC<>"" : Break : Endif
   Next
  When 2
   # Entry Type : Row
   WACC = [M]ACC1(nolign-1)
   WCOA = [M]COA1(nolign-1)
  When 3
   # Entry Type : Tab (only mode inquiry)
   For I=1 To [M:HAEF]NBRLED
    WACC = evalue("[M]ACC"+num$(I)+"("+num$(nolign-1)+")")
    If WACC<>""
     WCOA = [M:HAEF]COA(I-1)
     Break
    Endif
   Next
 Endcase
 If WACC<>""
  VALEUR = WACC
  Gosub AFF_ACC
 Elsif dim([M]AFFICHE)>0
  [M]AFFICHE = ""
  Gosub AFFICHE
 Endif
Endif
Return

$AFFICHE
If !GIMPORT : Affzo AFFICHE : Endif
Return

Subprog IB_NBLIG
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8, GBOUT9, GBOUT10

If !GCONSULT & [F:GDE]FLGLOT<2 & ([M]STA<>2 | GREP="C" | GREP="D")
 GBOUT4 = mess(19,103,1)
Endif
#<TODOR 85900
If func SUBGA10.CHECK_VATLINGNR() <> 0 Then
  Local Char VATLINGNR(4)
  # read the VATLINGNR parameter
  Call PARAM([M]FCY, "VATLINGNR", VATLINGNR) From ADOVAL

  If VATLINGNR = "2" or VATLINGNR = "3" Then
    # VAT line generation
    GBOUT10 = mess(158,104,1)
  Endif

  If VATLINGNR = "3" Then
    Local Integer LYESNO : [L]LYESNO = 2
    # Insert VAT line?
    Call OUINON(mess(206,104,1), [L]LYESNO) From GESECRAN
    If [L]LYESNO = 2 Then
      Gosub TRT_DIV From SUBGA10
    Endif
  Elsif VATLINGNR = "2"
    Gosub TRT_DIV From SUBGA10
  Endif
Endif
#TODOR 85900>
If nolign-1>=NBLIG : End : Endif

Local Char WACC(GLONGAC), WSAC(GLONSAC), WLED(GLONLED), WCUR(GLONCUR)

Local Integer IND,AXI

If !GTUNCPT(1)
 Case [M:HAEF]TYPENT
  When 1,3
   # Entry Type : Column
   For I=1 To [M:HAEF]NBRLED
    WACC = evalue("[M]ACC"+num$(I)+"("+num$(nolign-1)+")")
    If WACC<>""
     Call INDLED([M:HAEF]LED(I-1),"",IND,AXI) From CPTDIV
     If GLEDFLGGEN(IND)=2 :  GBOUT1 = mess(1,109,1) : Break : Endif
     # Consultation de compte
    Endif
   Next
  When 2
   # Entry Type : Row
   If [M]ACC1(nolign-1)<>""
    Call LECLED([M]CPY,[M]LEDTYP(nolign-1),WLED,WCUR) From CPTDIV
    Call INDLED(WLED,"",IND,AXI) From CPTDIV
    If GLEDFLGGEN(IND)=2 :  GBOUT1 = mess(1,109,1) : Endif
    # Consultation de compte
   Endif
 Endcase
Endif

If !GTUNCPT(3)
 Case [M:HAEF]TYPENT
  When 1,3
   # Entry Type : Column
   For I=1 To [M:HAEF]NBRLED
    WACC = evalue("[M]ACC"+num$(I)+"("+num$(nolign-1)+")")
    If WACC<>""
     Call INDLED([M:HAEF]LED(I-1),"",IND,AXI) From CPTDIV
     If GLEDFLGANA(IND)=2 :  GBOUT2 = mess(59,109,1) : Break : Endif
     # Consultation de compte analytique
    Endif
   Next
  When 2
   # Entry Type : Row
   If [M]ACC1(nolign-1)<>""
    Call LECLED([M]CPY,[M]LEDTYP(nolign-1),WLED,WCUR) From CPTDIV
    Call INDLED(WLED,"",IND,AXI) From CPTDIV
    If GLEDFLGANA(IND)=2 :  GBOUT2 = mess(59,109,1) : Endif
    # Consultation de compte analytique
   Endif
 Endcase
Endif

GBOUT3 = mess(29,106,1)

If [M]ACCNUM(nolign-1)<>0 & [M]CURAFF=[M]CUR
 Call LEC_GTE_LEG(GCURLEG,[M]TYP) From CPTLEC
 If [F:GTE]DUDDATFLG=2
  Case [M:HAEF]TYPENT
   When 1,3
    # Entry Type : Column
    For I=1 To [M:HAEF]NBRLED
     WSAC = evalue("[M]SAC"+num$(I)+"("+num$(nolign-1)+")")
     If WSAC<>"" & [M:HAEF]LEDTYP(I-1)=[M:HAEF]GENLED
      GBOUT5 = mess(39,117,1)  : Break
     Endif
    Next
   When 2
    # Entry Type : Row
    If [M]SAC1(nolign-1)<>"" & [M]LEDTYP(nolign-1)=[M:HAEF]GENLED
     GBOUT5 = mess(39,117,1)
    Endif
  Endcase
 Endif
 # Si on vient du menu Echéances , on ne doit pas avoir accés au bouton échéances par le tunnel "Pièce",
 # la gestion ou saisie des échéances doit se faire par l'écran correspondant : [SAI1].
 # Le tunnel Pièce n'a qu'un rôle de consultation.
 If clalev([M:SAI1])<> 0 & clalev([M:DDM])<>0 : Raz GBOUT5 : Endif
Endif

If [M]DSP(nolign-1)<>"" & ([M]CURAFF=[M]CUR | GFONCTION<>"GESGAS")
 Gosub AVT_SAIDSP
 GBOUT6 = mess(53,109,1)
Endif

# Requirement 71257 (Init GBOUT7, GBOUT8, GBOUT9)
Gosub IB_NBLIG From CPTTRCVCR
End

$AVT_SAIDSP
If !clalev([F:GAC2]) : Local File =GTABCPT+"GACCOUNT"     [GAC2] : Endif

#--- Axe saisissable si Compte saisi ou généré est suivi en analytique pour cette axe.
Local Char WACC(GLONGAC), WCOA(GLONCOA), CRIBLE
Local Integer NB,I,K        #*X3-110105 +K

# Mise en place de la structure
Local Integer TYD
TYD=[M:HAEF]NBRLED

Gosub AVT_SAIACC
# Boucle sur les référentiels/compte saisi et Ajout dans la strucutre si compte généré.
If [M:HAEF]TYPENT<3
 NB=1
 While NB<=GNBSTR
  If GSTRACC(NB)<>""
   #--- Axe est-il suivi sous le compte 'saisi'
   If [F:GAC2]COA<>GSTRCOA(NB) | [F:GAC2]ACC<>GSTRACC(NB)
    Read [GAC2]GAC0 = GSTRCOA(NB);GSTRACC(NB)
   Endif
   #--- Axe est il suivi sous les comptes générés
   For I=0 To [F:GAC2]COANBR-1
    #--- Recherche les comptes générés
    #      - Vérification que le référentiel/code-plan n'est pas dans les référentiel saisi
    #      - Vérification que le référentiel/code-plan est un référentiel généré (présent sous GPLAN)
    WCOA = [F:GAC2]OTHCOA(I)
    If !find(WCOA,GSTRCOA(1..GNBSTR)) & find(WCOA,GPLAN(1..10))
     Call INIACC(GSTRCOA(NB),GSTRACC(NB),WCOA,WACC,CRIBLE) From CPTINI
     If WACC<>""
      GNBSTR+=1 :  GSTRCOA(GNBSTR)=WCOA :  GSTRACC(GNBSTR) = WACC
      J=find(WCOA,GPLAN(1..10)) : GSTRTYP(GNBSTR) = GTYPLED(J) : GSTRLED(GNBSTR) = GCODLED(J) : GSTRIDT(GNBSTR) = GSTRIDT(NB)
     Endif
    Endif
   Next
  Endif
  NB+=1
 Wend
Endif

# Accès à la répartition + Stock la struture sous LEDDSP/ACCDSP
Raz [M]ACCDSP, [M]LEDDSP

Local Integer SUIVI
Call SUIVI_ANA([M:HAEF]CPY,GSTRTYP,GNBSTR,GSTRCOA,GSTRACC,[M:HAEF]DIE,[M:HAEF]NBRAXI,SUIVI) From CPTDIV
If !SUIVI : mkstat=2 : Return : Endif

For I=1 To GNBSTR
 For J=1 To GNBTYPLED
  If GSTRCOA(I)=GPLAN(J) & GSTRACC(I)<>""
    #*X3-110105 Check that there is no duplication in the ledgers list
    K=instr(1,[M]LEDDSP, GCODLED(J))    #*X3-110105
    If K=0                              #*X3-110105
      [M]ACCDSP += GSTRACC(I)  : [M]ACCDSP+=";"
      [M]LEDDSP += GCODLED(J)  : [M]LEDDSP+=";"
    Endif  #*X3-110105
  Endif
 Next
Next
If len([M]ACCDSP)>1
 [M]LEDDSP = left$([M]LEDDSP,len([M]LEDDSP)-1)
 [M]ACCDSP = left$([M]ACCDSP,len([M]ACCDSP)-1)
Endif

Return

$AVT_SAIACC
Local Integer I,J,K
Local Char WLED(GLONLED),WCUR(GLONCUR), WACC(GLONGAC)
If dim(GNBSTR)<=0  : Global Integer GNBSTR                            : Endif
If dim(GSTRTYP)<=0 : Global Integer GSTRTYP(1..dim([M]SAC1))          : Endif
If dim(GSTRIDT)<=0 : Global Char    GSTRIDT(5)(1..dim([M]SAC1))       : Endif
If dim(GSTRLED)<=0 : Global Char    GSTRLED(GLONLED)(1..dim([M]SAC1)) : Endif
If dim(GSTRCOA)<=0 : Global Char    GSTRCOA(GLONCOA)(1..dim([M]SAC1)) : Endif
If dim(GSTRACC)<=0 : Global Char    GSTRACC(GLONGAC)(1..dim([M]SAC1)) : Endif
Raz GNBSTR,GSTRTYP, GSTRIDT, GSTRLED,GSTRCOA,GSTRACC
Gosub SETNOL
Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  For GNBSTR=1 To TYD
   GSTRTYP(GNBSTR) = evalue("[M:HAEF]LEDTYP("+num$(GNBSTR-1)+")")
   GSTRIDT(GNBSTR) = "1"
   GSTRLED(GNBSTR) = evalue("[M:HAEF]LED("+num$(GNBSTR-1)+")")
   Call INDLED(GSTRLED(GNBSTR),"",I,J) From CPTDIV
   GSTRCOA(GNBSTR) = GLEDCOA(I)
   GSTRACC(GNBSTR) = evalue("[M]ACC"+num$(GNBSTR)+"("+num$(NOL)+")")
  Next
 When 2
  # Entry Type : Row
  GNBSTR=1
  For K=0 To [M]NBLIG-1
   If [M]IDTLIN(NOL)=[M]IDTLIN(K)
    GSTRTYP(GNBSTR) = evalue("[M]LEDTYP("+num$(K)+")")
    GSTRIDT(GNBSTR) = evalue("[M]IDTLIN("+num$(K)+")")
    Call LECLED([M]CPY,GSTRTYP(GNBSTR),WLED,WCUR) From CPTDIV
    GSTRLED(GNBSTR) = WLED
    Call INDLED(GSTRLED(GNBSTR),"",I,J) From CPTDIV
    GSTRCOA(GNBSTR) = GLEDCOA(I)
    GSTRACC(GNBSTR) =  evalue("[M]ACC1("+num$(K)+")")
    GNBSTR+=1
   Endif
  Next
  # dans le cas d'une saisie en cours... [M]NBLIG n'est pas encore incrémenté
  If NOL=[M]NBLIG
   GSTRTYP(GNBSTR) = evalue("[M]LEDTYP("+num$(NOL)+")")
   GSTRIDT(GNBSTR) = evalue("[M]IDTLIN("+num$(K)+")")
   Call LECLED([M]CPY,GSTRTYP(GNBSTR),WLED,WCUR) From CPTDIV
   GSTRLED(GNBSTR) = WLED
   Call INDLED(GSTRLED(GNBSTR),"",I,J) From CPTDIV
   GSTRCOA(GNBSTR) = GLEDCOA(I)
   GSTRACC(GNBSTR) =  evalue("[M]ACC1("+num$(NOL)+")")
   GNBSTR+=1
  Endif
 When 3
  # Entry Type : Tab (only mode Inquiry) : use to Analytical Allocation Inquiry
  For GNBSTR=1 To TYD
   WACC = evalue("[M]ACC"+num$(GNBSTR)+"("+num$(NOL)+")")
   If WACC<>""
    GSTRTYP(1) = evalue("[M:HAEF]LEDTYP("+num$(GNBSTR-1)+")")
    GSTRIDT(1) = "1"
    GSTRLED(1) = evalue("[M:HAEF]LED("+num$(GNBSTR-1)+")")
    Call INDLED(GSTRLED(1),"",I,J) From CPTDIV
    GSTRCOA(1) = GLEDCOA(I)
    GSTRACC(1) = WACC
    GNBSTR = 2 : Break
   Endif
  Next
Endcase
If GNBSTR>0 : GNBSTR-=1 : Endif
Return

Subprog AV_NBLIG
Local  Integer I
Local  Integer OK
If dim([M:HAE0]CPY) >0
 Call LEC_CPY([M:HAE0]CPY) From CPTLEC
Elsif dim([M:HAE1]CPY) >0
 Call LEC_CPY([M:HAE1]CPY) From CPTLEC
Elsif dim([M:HAE2]CPY) >0
 Call LEC_CPY([M:HAE2]CPY) From CPTLEC
Endif

# GDEV1(1) = [M]CUR
GDEV1(1) = [M]CURAFF
GDEV1(2) = [F:CPY]ACCCUR
GDEV1(3) = GSYSCUR

If (status=1 or status=71) & [M]NBLIG=0 : # Exécution schéma/défaut
 I = find([F:GCM]GCM,[F:GDE]GCM(0..[F:GDE]NBRGDA))
 If I & [F:GDE]DIAACC(I-1)<>""
  SCHEMA = [F:GDE]DIAACC(I-1)
  Gosub SCHEMA From SUBGA1
  If mkstat
   Call ERREUR(GMESSAGE) From GESECRAN : mkstat=0
  Elsif OK
   Affzo
  Endif
 Endif
Endif
End

Subprog AVANT_NBLIG
Gosub SETNOL
If [M]FCYLIN(NOL)="" : [M]FCYLIN(NOL) = [M]FCY : Endif
Gosub AFF_NBLIG
Case [M:HAEF]TYPENT
 When 1, 3
  If dim(GLEDREF)>0 & GLEDREF=0 : GLEDREF = [M:HAEF]LEDTYP(0) : Endif
  # Initialisation du code plan pour la saisie en Colonne/Onglet
  For I=1 To [M:HAEF]NBRLED
   If !GIMPORT & GFONCTION="GESGAS": Assign "[M:HAE"+num$(mid$(maskcou,5,1))+"]COA"+num$(I)+"("+num$(NOL)+")" With [M:HAEF]COA(I-1) : Endif
   If dim(GLEDREF)>0 & GLEDREF>0 & [M:HAEF]LEDTYP(I-1)=GLEDREF & evalue("[M]ACC1("+num$(NOL)+")") <>""
    [M]TOTDEB -= [M]DEB(NOL)
    [M]TOTCDT -= [M]CDT(NOL)
   Endif
  Next
 When 2
  # Initialisation du code plan pour la saisie Ligne
  If [M]LEDTYP(NOL)>0
   If dim(GLEDREF)>0 & GLEDREF=0 : GLEDREF = [M]LEDTYP(NOL) : Endif
   [M]COA1(NOL) = evalue("[M:HAEF]COA("+num$(find([F:GCM]LED([M]LEDTYP(NOL)-1),[M:HAEF]LED(0..[M:HAEF]NBRLED-1))-1)+")")
  Endif
  If GLEDREF>0 & [M]LEDTYP(NOL)=GLEDREF
   [M]TOTDEB -= [M]DEB(NOL)
   [M]TOTCDT -= [M]CDT(NOL)
  Endif
Endcase
End

Subprog APRES_NBLIG
Gosub SETNOL
If !find(status,65,68,83)
 Case [M:HAEF]TYPENT
  When 1
   # Entry Type : Column
   For I=1 To [M:HAEF]NBRLED
    If dim(GLEDREF)>0 & GLEDREF>0 & [M:HAEF]LEDTYP(I-1)=GLEDREF & evalue("[M]ACC1("+num$(NOL)+")") <>""
     [M]TOTDEB += [M]DEB(NOL)
     [M]TOTCDT += [M]CDT(NOL)
    Endif
   Next
  When 2
   # Entry Type : Row
   If GLEDREF>0 & [M]LEDTYP(NOL)=GLEDREF
    [M]TOTDEB += [M]DEB(NOL)
    [M]TOTCDT += [M]CDT(NOL)
   Endif
 Endcase
 Affzo TOTDEB, TOTCDT, CURAFF
 If dim([M]SOLDE)>0   : Affzo SOLDE   : Endif
 If dim([M]CURAFF2)>0 : Affzo CURAFF2 : Endif
Endif
If find(status,65,68,83)
 Affzo TOTDEB, TOTCDT, CURAFF
 If dim([M]SOLDE)>0   : Affzo SOLDE   : Endif
 If dim([M]CURAFF2)>0 : Affzo CURAFF2 : Endif
Endif
End

Subprog C_NBLIG
Call C_NBLIG From SUBGA00 : # Y'a plus de place
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

## ----------------------------------------------------------------- FCYLIN
Subprog D_FCYLIN(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" : End : Endif
VALEUR = [M]FCY
End

Subprog C_FCYLIN(VALEUR)
Variable Char     VALEUR
If [F:FCY]LEGCPY<>[M]CPY
 GMESSAGE = mess(30,106,1)-[F:FCY]LEGCPY
 mkstat = 2 : End
Endif
If !GIMPORT & func AFNC.ACTIV("PJM") & fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M]CPY,"PJTMGT")=2 & func TRTPJT.GET_PARAM_PJTSNGDOC(VALEUR)= [V]CST_AYES
 Local Char ABR(10)
 Call MSKABR("PJTLIN",ABR) From SUBGASA
 If ABR="HAE2"
  If [M:HAE1]PJT <> "" and  [M:HAE2]PJTLIN(nolign-1) = ""
   [M:HAE2]PJTLIN(nolign-1) =  [M:HAE1]PJT
   Affzo  [M:HAE2]PJTLIN(nolign-1)
  Endif
 Else
  If [M:HAE1]PJT <> "" and  [M:HAE1]PJTLIN(nolign-1) = ""
   [M:HAE1]PJTLIN(nolign-1) =  [M:HAE1]PJT
   Affzo  [M:HAE1]PJTLIN(nolign-1)
  Endif
 Endif
Endif
End

Subprog AS_FCYLIN(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
If !find(VALEUR,GUSRFCY(1..GNBAUZ)) : mkstat = 2 : End  :  Endif
If [M]MTC(NOL)<>"" | ([M]STA>1 & (GREP="M" or GREP="")) | [M]CHK(NOL)<>"" : mkstat = 2 : End : Endif
If [M:HAEF]TYPENT=1 & [M]IDTLIN(nolign-1)="LIAIS" : mkstat=2 : End : Endif
# Pièce comptable venant d'un autre module
If [M]ORIMOD<>2
 Local Char WSAC(GLONSAC),ABR(10)
 Call MSKABR("FCYLIN",ABR) From SUBGASA
 Case [M:HAEF]TYPENT
  When 1
   # Entry Type : Column
   For I=1 To [M:HAEF]NBRLED
    WSAC = evalue("[M:"+ABR+"]SAC"+num$(I)+"(NOL)")
    If WSAC<>"" : mkstat=2 : Break : Endif
   Next
  When 2
   # Entry Type : Row
   WSAC = evalue("[M:"+ABR+"]SAC1(NOL)")
   If WSAC<>"" : mkstat=2 : Endif
 Endcase
 If mkstat=2 : End : Endif
Endif
End

## ----------------------------------------------------------------- LEDTYP
Subprog AS_LEDTYP(VALEUR)
Variable Integer  VALEUR
Local Integer I
Gosub SETNOL
If [M]MTC(NOL)<>"" | ([M]STA>1 & (GREP="M" or GREP="")) | [M]CHK(NOL)<>""
 mkstat = 2 : End
Endif

# Pièce comptable venant d'un autre module
If [M]ORIMOD<>2
 Local Char WSAC(GLONSAC),ABR(10)
 Call MSKABR("FCYLIN",ABR) From SUBGASA
 Case [M:HAEF]TYPENT
  When 1
   # Entry Type : Column
   For I=1 To [M:HAEF]NBRLED
    WSAC = evalue("[M:"+ABR+"]SAC"+num$(I)+"(NOL)")
    If WSAC<>"" : mkstat=2 : Break : Endif
   Next
  When 2
   # Entry Type : Row
   WSAC = evalue("[M:"+ABR+"]SAC1(NOL)")
   If WSAC<>"" : mkstat=2 : Endif
 Endcase
 If mkstat=2 : End : Endif
Endif

# Liste des référentiels potentiellement saisissable (déjà présent [M:HAEF])
Raz GMENLOC
For I=1 To len(mess(0,2644,1))
 If !find(I,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
   GMENLOC(I) = 1
 Endif
Next
End

Subprog AM_LEDTYP(VALEUR)
Variable Integer  VALEUR
If GIMPORT : End : Endif
Gosub SETNOL
Local Integer I,IND
Local Char WLED(GLONLED),WCUR(GLONCUR)
# Après modification de LEDTYP : Type de référentiel.
#     Saisie par ligne : zone LEDTYP est saisissable uniquement en saisie par ligne => MAJ code plan (COA1)
#     Saisie par colonne : Mise à jour du code plan en AVANT_NBLIG => MAJ code plan COAx (x=1 à 9)
Call LECLED([M]CPY,VALEUR,WLED,WCUR) From CPTDIV
Call INDLED(WLED,"",IND,I) From CPTDIV
[M]COA1(NOL) = GLEDCOA(IND)
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Call CONTPER([M]ACCDAT,VALEUR,[M]FCYLIN(nolign-1)) From CPTSUB
If mkstat=2 : End : Endif
End

## ----------------------------------------------------------------- IDTLIN
Subprog D_IDTLIN(VALEUR)
Variable Char    VALEUR()
Local Char IDT(5)
If nolign<2 : VALEUR="A" : End : Endif
If [M]LEDTYP(nolign-1)=[M]LEDTYP(nolign-2) | [M]IDTLIN(nolign-2)="LIAIS"
  IDT = [M]IDTLIN(nolign-2)
  Call INCLET([L]IDT,type([M]IDTLIN)-10) From CPTLET
  VALEUR=[L]IDT
Else
  VALEUR=[M]IDTLIN(nolign-2)
Endif
End

## ----------------------------------------------------------------- SAC
Subprog AS_SAC1(VALEUR)
Variable Char    VALEUR()
TYD = 1 : Goto SAISAC
Subprog AS_SAC2(VALEUR)
Variable Char    VALEUR()
TYD = 2 : Goto SAISAC
Subprog AS_SAC3(VALEUR)
Variable Char    VALEUR()
TYD = 3 : Goto SAISAC
Subprog AS_SAC4(VALEUR)
Variable Char    VALEUR()
TYD = 4 : Goto SAISAC
Subprog AS_SAC5(VALEUR)
Variable Char    VALEUR()
TYD = 5 : Goto SAISAC
Subprog AS_SAC6(VALEUR)
Variable Char    VALEUR()
TYD = 6 : Goto SAISAC
Subprog AS_SAC7(VALEUR)
Variable Char    VALEUR()
TYD = 7 : Goto SAISAC
Subprog AS_SAC8(VALEUR)
Variable Char    VALEUR()
TYD = 8 : Goto SAISAC
Subprog AS_SAC9(VALEUR)
Variable Char    VALEUR()
TYD = 9 : Goto SAISAC
Subprog AS_SAC10(VALEUR)
Variable Char    VALEUR()
TYD = 10 : Goto SAISAC

$SAISAC
If GIMPORT & TYD>1 : mkstat=2 : End : Endif
Gosub SETNOL
If VALEUR="" & !find(status,5,31,75) : mkstat=2 : End
Elsif [M]MTC(NOL)<>"" | ([M]STA>1 & (GREP="M" or GREP="")) | [M]CHK(NOL)<>""
 mkstat=2 : End
Elsif [M]ORIMOD<>2
 mkstat = 2 : End : # Ca ne vient pas de la compta
Endif
If [M:HAEF]TYPENT=1 & [M]IDTLIN(nolign-1)="LIAIS" : mkstat=2 : End : Endif
# Contrôle exercice/période
If [M:HAEF]TYPENT=1    # Entry Type : Column
 Call CONTPER([M]ACCDAT,[M:HAEF]LEDTYP(TYD-1),[M]FCYLIN(nolign-1)) From CPTSUB
 If mkstat=2 : mkstat=1 : End : Endif
Endif

# Règles de progation
#   Accès à AS_SAC (idem pour AS_ACC - 88148)

# Sauvegarde de la structure
Gosub AVT_SAIACC

Local Integer I,IND, WTYP, WNBRLED
Local Char WCOA(GLONCOA),WACC(GLONGAC),ABR(10),WSAC(GLONSAC) # Issue X3-63004
Call MSKABR("ACC"+num$(TYD),ABR) From SUBGASA
If GNBSTR>=1
 Case [M:HAEF]TYPENT
  When 1 :
   # Saisie en colonne
   WTYP = evalue("[M:HAEF]LEDTYP("+num$(TYD-1)+")")
   WNBRLED=0
   If WTYP>0
    For I=1 To TYD-1
     WSAC = evalue("[M:"+ABR+"]SAC"+num$(I)+"(NOL)")
     WCOA = evalue("[M:HAEF]COA("+num$(I-1)+")")
     If [F:GAC]COA<>WCOA or [F:GAC]ACCSHO<>WSAC
      Read [GAC]GAC1 = WCOA;WSAC
     Endif
     WACC = [F:GAC]ACC
     If WACC<>""
      If WCOA<>[F:GAC]COA
       If !find(WCOA,[F:GAC]OTHCOA(0..[F:GAC]COANBR-1)) & [F:GTE]AUZLED(WTYP-1)<>3 : mkstat = 1 : Break :  Endif
      Endif
     Else
      If I>1 : WNBRLED+=1 : Endif
     Endif
    Next
   Endif
   WCOA = [M:HAEF]COA(TYD-1)
  When 2
   WTYP=find([M]LEDTYP(NOL),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
   If WTYP>0
    WCOA = [M:HAEF]COA(WTYP-1)
   Endif
 Endcase

 If WTYP<1 : mkstat = 1 : Endif
 If mkstat=1 : End : Endif

 If VALEUR=""
  Call INIPRO(WCOA,WACC) From SUBGA1
  Call LEC_GAC(WACC,WCOA) From CPTLEC
  If [F:GAC]SAC=2
    Assign "[M:" + ABR + "]ACC" + num$(TYD) + "(NOL)" With WACC # Issue X3-63004
    VALEUR = [F:GAC]ACCSHO
  Elsif fstat = 0 # Issue X3-63004
    Assign "[M:" + ABR + "]ACC" + num$(TYD) + "(NOL)" With WACC # Issue X3-63004
  Endif
 Elsif TYD>1
  # Ré-initialisation "Forcé" selon les cribles liés au paramétrage de la fiche compte
#  # Issue X3-63004 = VALEUR = SAC field, used for Acc field : better WACC
  WACC = ""
  Call UPDPRO(TYD,WCOA,WACC) From SUBGA1
  If mkstat = 2
   # le paramétrage des valeurs par défaut impose un compte, X3 force la ré-initialisation
   Call LEC_GAC(WACC,WCOA) From CPTLEC
   Assign "[M:" + ABR + "]ACC" + num$(TYD) + "(NOL)" With WACC # Issue X3-63004
   If [F:GAC]SAC=2
    VALEUR = [F:GAC]ACCSHO
   Else
    VALEUR = ""
   Endif
  Else
   # le paramétrage des valeurs par défaut n'impose pas un compte, X3 restaure la valeur saisie (celle ci peut être incompatible)
  Endif
 Endif
Endif
End

#########################
Subprog C_SAC1(VALEUR)
Variable Char    VALEUR()
TYD = 1 : Goto CONTSAC
Subprog C_SAC2(VALEUR)
Variable Char    VALEUR()
TYD = 2 : Goto CONTSAC
Subprog C_SAC3(VALEUR)
Variable Char    VALEUR()
TYD = 3 : Goto CONTSAC
Subprog C_SAC4(VALEUR)
Variable Char    VALEUR()
TYD = 4 : Goto CONTSAC
Subprog C_SAC5(VALEUR)
Variable Char    VALEUR()
TYD = 5 : Goto CONTSAC
Subprog C_SAC6(VALEUR)
Variable Char    VALEUR()
TYD = 6 : Goto CONTSAC
Subprog C_SAC7(VALEUR)
Variable Char    VALEUR()
TYD = 7 : Goto CONTSAC
Subprog C_SAC8(VALEUR)
Variable Char    VALEUR()
TYD = 8 : Goto CONTSAC
Subprog C_SAC9(VALEUR)
Variable Char    VALEUR()
TYD = 9 : Goto CONTSAC
Subprog C_SAC10(VALEUR)
Variable Char    VALEUR()
TYD = 10 : Goto CONTSAC

$CONTSAC
If VALEUR="" : End : Endif
Gosub SETNOL
Local Char WCOA(GLONCOA), WLED(GLONLED), WCUR(GLONCUR),ABR(10)
Call MSKABR("SAC"+num$(TYD),ABR) From SUBGASA

Gosub AVT_SAIACC
Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  WCOA = [M:HAEF]COA(TYD-1)
  Read [GAC]GAC1 = WCOA;VALEUR
  If fstat | [F:GAC]SAC<>2
   GMESSAGE = WCOA-VALEUR-mess(9,106,1)
   mkstat = 2 : End
  Endif
  Call CONTACC([F:GAC]ACC,[M:HAEF]LEDTYP(TYD-1),[M:HAEF]LED(TYD-1),[M]FCYLIN(NOL),[M]CUR,[M]ACCDAT) From SUBGA1
  If mkstat : End : Endif
 When 2
  # Entry Type : Row
  J=find([M]LEDTYP(NOL),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
  If J
   WCOA = [M:HAEF]COA(J-1)
   Read [GAC]GAC1 = WCOA;VALEUR
   If fstat | [F:GAC]SAC<>2
    GMESSAGE = WCOA-VALEUR-mess(9,106,1)
    mkstat = 2 : End
   Endif
   Call LECLED([M]CPY,[M]LEDTYP(nolign-1),WLED,WCUR) From CPTDIV
   Call CONTACC([F:GAC]ACC,[M]LEDTYP(nolign-1),WLED,[M]FCYLIN(NOL),[M]CUR,[M]ACCDAT) From SUBGA1
   If mkstat : End : Endif
  Endif
Endcase

Assign "[M:"+ABR+"]ACC"+num$(TYD)+"(NOL)" With [F:GAC]ACC
## We call the AM_ACCx Sub-program only if the Short Code has changed otherwise this part of code is performed wrongly
## when we reverse a journal or when we generate a journal from a template journal.
# Issue X3-63004 : VALEUR always = [F:GAC]ACCSHO
If evalue("[M:" + ABR + "]SAC" + num$(TYD) + "(NOL)") <> [F:GAC]ACCSHO
#If VALEUR <> [F:GAC]ACCSHO

 Case TYD
  When 1 : Call AM_ACC1(num$(evalue("[M:"+ABR+"]ACC1(NOL)"))) From SUBGA0
  When 2 : Call AM_ACC2(num$(evalue("[M:"+ABR+"]ACC2(NOL)"))) From SUBGA0
  When 3 : Call AM_ACC3(num$(evalue("[M:"+ABR+"]ACC3(NOL)"))) From SUBGA0
  When 4 : Call AM_ACC4(num$(evalue("[M:"+ABR+"]ACC4(NOL)"))) From SUBGA0
  When 5 : Call AM_ACC5(num$(evalue("[M:"+ABR+"]ACC5(NOL)"))) From SUBGA0
  When 6 : Call AM_ACC6(num$(evalue("[M:"+ABR+"]ACC6(NOL)"))) From SUBGA0
  When 7 : Call AM_ACC7(num$(evalue("[M:"+ABR+"]ACC7(NOL)"))) From SUBGA0
  When 8 : Call AM_ACC8(num$(evalue("[M:"+ABR+"]ACC8(NOL)"))) From SUBGA0
  When 9 : Call AM_ACC9(num$(evalue("[M:"+ABR+"]ACC9(NOL)"))) From SUBGA0
  When 10 : Call AM_ACC10(num$(evalue("[M:"+ABR+"]ACC10(NOL)"))) From SUBGA0
 Endcase
Endif
End

## ----------------------------------------------------------------- ACC
Subprog IB_ACC1
TYD = 1 : Goto BOUTACC
Subprog IB_ACC2
TYD = 2 : Goto BOUTACC
Subprog IB_ACC3
TYD = 3 : Goto BOUTACC
Subprog IB_ACC4
TYD = 4 : Goto BOUTACC
Subprog IB_ACC5
TYD = 5 : Goto BOUTACC
Subprog IB_ACC6
TYD = 6 : Goto BOUTACC
Subprog IB_ACC7
TYD = 7 : Goto BOUTACC
Subprog IB_ACC8
TYD = 8 : Goto BOUTACC
Subprog IB_ACC9
TYD = 9 : Goto BOUTACC
Subprog IB_ACC10
TYD = 10 : Goto BOUTACC

$BOUTACC
Raz GBOUT3, GBOUT4
Local Char WCOA(GLONCOA),WACC(GLONGAC),ABR(10)
Gosub SETNOL
Call MSKABR("ACC"+num$(TYD),ABR) From SUBGASA
WACC = evalue("[M:"+ABR+"]ACC"+num$(TYD)+"(NOL)")

Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  WCOA = [M:HAEF]COA(TYD-1)
 When 2
  # Entry Type : Row
  J=find([M]LEDTYP(NOL),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
  If J : WCOA = [M:HAEF]COA(J-1) : Endif
Endcase

Call LEC_JCO_LEG(GCURLEG,[L]WCOA,[F:JOU]JOU) From CPTLEC
If !fstat and [F:JCO]FRQNBR<>0
 GBOUT3 = mess(50,106,1)
Endif

If WACC<>""
 Call LEC_GAC(WACC,WCOA) From CPTLEC
 If !fstat
  GBOUT4 = mess(1,109,1)
 Endif
Endif
End

##########################
Subprog AS_ACC1(VALEUR)
Variable Char    VALEUR()
TYD = 1 : Goto SAIACC
Subprog AS_ACC2(VALEUR)
Variable Char    VALEUR()
TYD = 2 : Goto SAIACC
Subprog AS_ACC3(VALEUR)
Variable Char    VALEUR()
TYD = 3 : Goto SAIACC
Subprog AS_ACC4(VALEUR)
Variable Char    VALEUR()
TYD = 4 : Goto SAIACC
Subprog AS_ACC5(VALEUR)
Variable Char    VALEUR()
TYD = 5 : Goto SAIACC
Subprog AS_ACC6(VALEUR)
Variable Char    VALEUR()
TYD = 6 : Goto SAIACC
Subprog AS_ACC7(VALEUR)
Variable Char    VALEUR()
TYD = 7 : Goto SAIACC
Subprog AS_ACC8(VALEUR)
Variable Char    VALEUR()
TYD = 8 : Goto SAIACC
Subprog AS_ACC9(VALEUR)
Variable Char    VALEUR()
TYD = 9 : Goto SAIACC
Subprog AS_ACC10(VALEUR)
Variable Char    VALEUR()
TYD = 10 : Goto SAIACC

$SAIACC
If GIMPORT & TYD>1 : mkstat=2 : End : Endif
Gosub SETNOL
Local Integer I,IND, WTYP, WNBRLED
Local Char WLED(GLONLED),WCOA(GLONCOA),WSAC(GLONSAC),WCUR(GLONCUR),ABR(10), WACC(GLONGAC),SVGACC(GLONGAC)

Call MSKABR("ACC"+num$(TYD),ABR) From SUBGASA
WSAC = evalue("[M:"+ABR+"]SAC"+num$(TYD)+"(NOL)")
If WSAC<>"" & !find(status,5,31,75)
 mkstat = 2 : End
Elsif [M]MTC(NOL)<>"" | [M]CHK(NOL)<>""
 mkstat = 2 : End
Elsif WSAC<>"" & [M]ORIMOD<>2
 mkstat = 2 : End
Elsif VALEUR<>"" & [M]ORIMOD=3
 If !clalev([F:BAN]) : Local File BANK [BAN] : Endif
 Filter [BAN] Where BANACC=VALEUR
 Read [BAN]BAN0 First
 Filter [BAN]
 If !fstat : mkstat=2 : End : Endif
Endif
If [M:HAEF]TYPENT=1 & [M]IDTLIN(nolign-1)="LIAIS" : mkstat=2 : End : Endif
If [M]STA>1 and (GREP="M" or GREP="")
 mkstat=2 : End
Else
 If [M:HAEF]TYPENT=1      # Entry Type : Column
  WTYP = evalue("[M:HAEF]LEDTYP("+num$(TYD-1)+")")
 Else
  WTYP = evalue("[M:"+ABR+"]LEDTYP("+num$(NOL)+")")
 Endif
 Call CONTPER([M]ACCDAT,WTYP,[M]FCYLIN(nolign-1)) From CPTSUB
 If mkstat=2
  If WSAC<>""
   Assign "[M:"+ABR+"]SAC"+num$(TYD)+"(NOL)" With ""
  Endif
  mkstat=1 : Raz GMESSAGE : End
 Endif
Endif

# Règles de progation
# Sauvegarde de la structure
Gosub AVT_SAIACC
If GNBSTR>=1
 Case [M:HAEF]TYPENT
  When 1 :
   # Entry Type : Column
   WCOA = [M:HAEF]COA(TYD-1)
   WTYP = evalue("[M:HAEF]LEDTYP("+num$(TYD-1)+")")
   WNBRLED=0
   If WTYP>0
    For I=1 To TYD-1
     WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"(NOL)")
     If WACC<>""
      Call LEC_GAC(WACC,evalue("[M:HAEF]COA("+num$(I-1)+")")) From CPTLEC
      If WCOA<>[F:GAC]COA : # Demande 55712
       If !find(WCOA,[F:GAC]OTHCOA(0..[F:GAC]COANBR-1)) & [F:GTE]AUZLED(WTYP-1)<>3 : mkstat = 1 : Break :  Endif
      Endif
     Else
      If I>1 : WNBRLED+=1 : Endif
     Endif
    Next
   Endif
  When 2
   WTYP=find([M]LEDTYP(NOL),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
   If WTYP>0
    WCOA = [M:HAEF]COA(WTYP-1)
   Endif
 Endcase

 If WTYP<1 : mkstat = 1 : Endif
 If mkstat=1 : End : Endif

 If VALEUR=""
  Call INIPRO(WCOA,VALEUR) From SUBGA1
  If VALEUR<>""
   Call LEC_GAC(VALEUR,WCOA) From CPTLEC
   If [F:GAC]SAC=2
    Assign "[M:"+ABR+"]SAC"+num$(TYD)+"(NOL)" With [F:GAC]ACCSHO
   Else
    Assign "[M:"+ABR+"]SAC"+num$(TYD)+"(NOL)" With ""
   Endif
  Endif
 Elsif TYD>1
  # Ré-initialisation "Forcé" selon les cribles liés au paramétrage de la fiche compte
  SVGACC = VALEUR  # stock la valeur saisie
  VALEUR = ""
  Call UPDPRO(TYD,WCOA,VALEUR) From SUBGA1
  If mkstat = 2
   # le paramétrage des valeurs par défaut impose un compte, X3 force la ré-initialisation
   Call LEC_GAC(VALEUR,WCOA) From CPTLEC
   If [F:GAC]SAC=2
    Assign "[M:"+ABR+"]SAC"+num$(TYD)+"(NOL)" With [F:GAC]ACCSHO
   Else
    Assign "[M:"+ABR+"]SAC"+num$(TYD)+"(NOL)" With ""
   Endif
  Else
   # le paramétrage des valeurs par défaut n'impose pas un compte, X3 restaure la valeur saisie (celle ci peut être incompatible)
   VALEUR = SVGACC
  Endif
 Endif
Endif

# X3-68928 2018-08-24 Bader begin Choose correct text for button 4: either "Account inquiry" or "Analytical account inquiry"
If clalev([F:LED])=0 : Local File GLED      [LED]  : Endif : # Chart code
Call LEC_LED([M:HAEF]LED(TYD-1)) From CPTLEC
If [F:LED]GEN < 2 and [F:LED]ANA = 2
    GBOUT4 = mess(59,109,1)   # "Analytical account inquiry"
Else
    GBOUT4 = mess(1,109,1)    # "Account inquiry"
Endif
# X3-68928 2018-08-24 Bader end

If VALEUR<>"" : Gosub AFF_ACC : Endif
End

#########
$AFF_ACC
If !mkstat & !GIMPORT & VALEUR<>"" & dim([M]AFFICHE)>0
 Local Char DESACC(GLONAX3)
 Call LEC_GAC(VALEUR,WCOA) From CPTLEC
 Call LECTEXTRA([L]DESACC,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 [M]AFFICHE = VALEUR-":"-[L]DESACC : Gosub AFFICHE
Endif
Return

##########################
Subprog C_ACC1(VALEUR)
Variable Char    VALEUR()
TYD = 1 : Goto CONTACC
Subprog C_ACC2(VALEUR)
Variable Char    VALEUR()
TYD = 2 : Goto CONTACC
Subprog C_ACC3(VALEUR)
Variable Char    VALEUR()
TYD = 3 : Goto CONTACC
Subprog C_ACC4(VALEUR)
Variable Char    VALEUR()
TYD = 4 : Goto CONTACC
Subprog C_ACC5(VALEUR)
Variable Char    VALEUR()
TYD = 5 : Goto CONTACC
Subprog C_ACC6(VALEUR)
Variable Char    VALEUR()
TYD = 6 : Goto CONTACC
Subprog C_ACC7(VALEUR)
Variable Char    VALEUR()
TYD = 7 : Goto CONTACC
Subprog C_ACC8(VALEUR)
Variable Char    VALEUR()
TYD = 8 : Goto CONTACC
Subprog C_ACC9(VALEUR)
Variable Char    VALEUR()
TYD = 9 : Goto CONTACC
Subprog C_ACC10(VALEUR)
Variable Char    VALEUR()
TYD = 10 : Goto CONTACC


$CONTACC
Local Integer     I, OK
Local Libelle     FLG, BPRNSAI
Local Char        CPT(GLONGAC)

If clalev([F:GDD])=0  : Local File GDIAENTRYD  [GDD] : Endif
If clalev([F:JCO])=0  : Local File GJOUCOA     [JCO] : Endif

Gosub SETNOL
Local Char WLED(GLONLED),WCOA(GLONCOA),WSAC(GLONSAC),WACC(GLONGAC),WCUR(GLONCUR),ABR(10),CURSAI(GLONCUR)
Call MSKABR("ACC"+num$(TYD),ABR) From SUBGASA
WSAC = evalue("[M:"+ABR+"]SAC"+num$(TYD)+"(NOL)")

#ISSUE 83425 - MNO
If ((func AFNC.ACTIV("FIFRC")) and
&  (func AFNC.PARAM("FIFRC", [M]FCY) = "2") and
&  (evalue("[M]ACC"+num$(TYD)+"(NOL)") <> VALEUR) and
&  [M]NUM <> '')
  If (GTYPGEN = [M:HAEW]LEDTYP) and [M]CAT = 1
    If func FIFOCONVAR_CSTD.DOES_FIFO_EXIST_FOR_ACC_CPY_DATE(VALEUR, [M]CPY, [M]ACCDAT) = 0 or
&   func FIFOCONVAR_CSTD.DOES_FIFO_EXIST_FOR_ACC_CPY_DATE(evalue("[M]ACC"+num$(TYD)+"(NOL)"), [M]CPY, [M]ACCDAT) = 0
      GMESSAGE = mess(12,7708,1)
      mkstat = 2
      End
    Endif
  Endif
Endif
#ISSUE END 83425 - MNO

Assign "[M:"+ABR+"]ACC"+num$(TYD)+"(NOL)" With VALEUR

If GCOMPTA<>3  :# Compta
 Case [M:HAEF]TYPENT
  When 1
   # Entry Type : Column
   WCOA = [M:HAEF]COA(TYD-1)
   Call LEC_GDD([F:GDE]DIA,"BPR") From CPTLEC
   If fstat=0 : FLG=1+([F:GDD]DAC=1) : Endif
   If FLG=1 # Tiers non saisi
    BPRNSAI=1 # Tiers non saisi
    Raz OK, FLG
    For I=TYD+1 To [M:HAEF]NBRLED
     WACC = "ACC"+num$(I)
     Read [GDD]GDD0 = [F:GDE]DIA;WACC
     If fstat=0 : FLG=1+([F:GDD]DAC>1) : Endif
     If FLG=1 : OK=1 : Break : Endif : # Compte non saisi
    Next I
    If !OK : # C'est le dernier compte saisissable...
     OK = 0
     For I=1 To TYD-1
      WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"(NOL)")
      If WACC<>"" : OK = 1 : Break : Endif
     Next
     If !OK & VALEUR=""
      GMESSAGE = mess(115,106,1)
      mkstat = 2 : End
     Endif
    Endif
   Endif
   If dim([M]ORIMOD)>0 & [M]ORIMOD<>2 & WSAC="" : BPRNSAI=1 : Endif
   If VALEUR=""
    If !BPRNSAI : Assign "[M:"+ABR+"]SAC"+num$(TYD)+"(NOL)" With "" : Endif
   Endif

   # Possibilité de saisir Aucun compte, atteindre le Tiers qui initialisera les comptes.
   If VALEUR=""
    For I=1 To [M:HAEF]NBRLED
      WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"(NOL)")
      If WACC<>"" : Break : Endif
    Next
    If !BPRNSAI & [M:HAEF]NBRLED=I-1 and evalue("[M:"+ABR+"]BPR("+num$(NOL)+")")="" : End : Endif
   Endif

  When 2
  # Entry Type : Row
   J=find([M]LEDTYP(NOL),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
   If J
    WCOA = [M:HAEF]COA(J-1)
    Call LEC_GDD([F:GDE]DIA,"BPR") From CPTLEC
    If fstat=0 : FLG=1+([F:GDD]DAC=1) : Endif
    If FLG=1 : BPRNSAI=1 : Endif
    If [M]ORIMOD<>2 & WSAC="" : BPRNSAI=1 : Endif
    If VALEUR=""
     If BPRNSAI : mkstat = 1 : Else :  Assign "[M:"+ABR+"]SAC"+num$(TYD)+"(NOL)" With "" : Endif
    Endif
    If mkstat : End : Endif
    If VALEUR="" and evalue("[M:"+ABR+"]BPR("+num$(NOL)+")")="" : End : Endif
   Else
    End
   Endif

 Endcase
Endif
If VALEUR<>""
 CPT = VALEUR

 #-- Référentiel de référence : utile pour les Soldes et Montants du Bouton 'Devise'.
 If dim(GLEDREF)>0 & GLEDREF=0
  Case [M:HAEF]TYPENT
   When 1 : GLEDREF=[M:HAEF]LEDTYP(TYD-1)   # Entry Type : Column
   When 2 : GLEDREF=[M]LEDTYP(TYD-1)        # Entry Type : Row
  Endcase
 Endif

 #-- Recherche du code d'appel
 Call LEC_JCO_LEG(GCURLEG,[L]WCOA,[F:JOU]JOU) From CPTLEC
 If GCOMPTA<>3 : I = find(CPT,[F:JCO]FRQCOD(0..[F:JCO]FRQNBR-1)) : Endif
 If I
  # Code d'appel Journal
  CPT = [F:JCO]FRQACC(I-1)
 Else
  # Code d'appel Compte
  Read [GAC]GAC1 = WCOA;CPT
  If !fstat : CPT = [F:GAC]ACC : Endif
 Endif

 Read [GAC]GAC0 >= WCOA;CPT
 If fstat>2 | left$([F:GAC]ACC,len(CPT))<>CPT
  GMESSAGE = CPT-mess(38,106,1)
  mkstat = 2 : End
 Endif
 If [F:GAC]ENAFLG<>2
  GMESSAGE = mess(2,126,1)
  mkstat = 2 : End
 Endif
 If BPRNSAI & [F:GAC]SAC=2
  GMESSAGE = mess(19,104,1) : mkstat = 2 : End
 Endif
Else
 Raz [F:GAC]
Endif

If [F:GAC]SAC=2
 Assign "[M:"+ABR+"]SAC"+num$(TYD)+"(NOL)" With [F:GAC]ACCSHO
Else
 Assign "[M:"+ABR+"]SAC"+num$(TYD)+"(NOL)" With ""
Endif
Assign "[M:"+ABR+"]ACC"+num$(TYD)+"(NOL)" With [F:GAC]ACC
VALEUR = [F:GAC]ACC

Gosub AVT_SAIACC
[L]CURSAI=[M]CUR
If GFONCTION="GESLOT" & dim([M]CUR)>1 : [L]CURSAI=[M]CUR(nolign-1) : Endif
Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  Call CONTACC([F:GAC]ACC,[M:HAEF]LEDTYP(TYD-1),[M:HAEF]LED(TYD-1),[M]FCYLIN(NOL),[L]CURSAI,[M]ACCDAT) From SUBGA1
  If mkstat : End : Endif
 When 2
  # Entry Type : Row
  Call LECLED([M]CPY,[M]LEDTYP(nolign-1),WLED,WCUR) From CPTDIV
  Call CONTACC([F:GAC]ACC,[M]LEDTYP(nolign-1),WLED,[M]FCYLIN(NOL),[L]CURSAI,[M]ACCDAT) From SUBGA1
  If mkstat : End : Endif
Endcase
End

##########################
Subprog AP_ACC1(VALEUR)
Variable Char    VALEUR()
TYD = 1 : Goto APZACC
Subprog AP_ACC2(VALEUR)
Variable Char    VALEUR()
TYD = 2 : Goto APZACC
Subprog AP_ACC3(VALEUR)
Variable Char    VALEUR()
TYD = 3 : Goto APZACC
Subprog AP_ACC4(VALEUR)
Variable Char    VALEUR()
TYD = 4 : Goto APZACC
Subprog AP_ACC5(VALEUR)
Variable Char    VALEUR()
TYD = 5 : Goto APZACC
Subprog AP_ACC6(VALEUR)
Variable Char    VALEUR()
TYD = 6 : Goto APZACC
Subprog AP_ACC7(VALEUR)
Variable Char    VALEUR()
TYD = 7 : Goto APZACC
Subprog AP_ACC8(VALEUR)
Variable Char    VALEUR()
TYD = 8 : Goto APZACC
Subprog AP_ACC9(VALEUR)
Variable Char    VALEUR()
TYD = 9 : Goto APZACC
Subprog AP_ACC10(VALEUR)
Variable Char    VALEUR()
TYD = 10 : Goto APZACC

$APZACC
Gosub SETNOL
Local Char WCOA(GLONCOA),WSAC(GLONSAC),ABR(10)
Call MSKABR("ACC"+num$(TYD),ABR) From SUBGASA
WSAC = evalue("[M:"+ABR+"]SAC"+num$(TYD)+"(NOL)")

Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  WCOA = [M:HAEF]COA(TYD-1)
 When 2
  # Entry Type : Row
  J=find([M]LEDTYP(NOL),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
  If J : WCOA = [M:HAEF]COA(J-1) : Endif
Endcase

Affzo ="[M:"+ABR+"]SAC"+num$(TYD)+"(NOL)"
Gosub AFF_ACC
End

##########################
Subprog AM_ACC1(VALEUR)
Value Char    VALEUR()
TYD = 1 : Goto MODACC
Subprog AM_ACC2(VALEUR)
Value Char    VALEUR()
TYD = 2 : Goto MODACC
Subprog AM_ACC3(VALEUR)
Value Char    VALEUR()
TYD = 3 : Goto MODACC
Subprog AM_ACC4(VALEUR)
Value Char    VALEUR()
TYD = 4 : Goto MODACC
Subprog AM_ACC5(VALEUR)
Value Char    VALEUR()
TYD = 5 : Goto MODACC
Subprog AM_ACC6(VALEUR)
Value Char    VALEUR()
TYD = 6 : Goto MODACC
Subprog AM_ACC7(VALEUR)
Value Char    VALEUR()
TYD = 7 : Goto MODACC
Subprog AM_ACC8(VALEUR)
Value Char    VALEUR()
TYD = 8 : Goto MODACC
Subprog AM_ACC9(VALEUR)
Value Char    VALEUR()
TYD = 9 : Goto MODACC
Subprog AM_ACC10(VALEUR)
Value Char    VALEUR()
TYD = 10 : Goto MODACC

$MODACC
If !mkstat & !GIMPORT & VALEUR<>""
 Gosub SETNOL
 Local Char WCOA(GLONCOA),WSAC(GLONSAC),ABR(10)
 Call MSKABR("BPR",ABR) From SUBGASA
 Case [M:HAEF]TYPENT
  When 1
   # Entry Type : Column
   WCOA = [M:HAEF]COA(TYD-1)
  When 2
   # Entry Type : Row
   J=find([M]LEDTYP(NOL),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
   If J : WCOA = [M:HAEF]COA(J-1) : Endif
 Endcase
 Call LEC_GAC(VALEUR,WCOA) From CPTLEC
 If dim([M]ACCDES)>0
  Call LECTEXTRA([M]ACCDES(NOL),"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  Affzo [M]ACCDES(NOL)
 Endif
 If [F:GAC]UOM<>"" & [M]UOM(NOL)<>[F:GAC]UOM
  [M]UOM(NOL) = [F:GAC]UOM
  Affzo [M]UOM(NOL)
 Endif
Endif

If func AFNC.ACTIV("PRCSL") & !mkstat & !GIMPORT & dim([M]CSLFLO)>0
 Local Tinyint FLGCSL
 Local Integer ASTATUS, WTYP, WUPDCSL
 Local Char ERRMES(250), WLED(GLONLED), WCUR(GLONCUR)

 # Pre-consolidation : Search the first ledger with "Consolidation" ?
 Raz WUPDCSL
 For I=1 To TYD
  If [M:HAEF]TYPENT=1
   WTYP = evalue("[M:HAEF]LEDTYP("+num$(TYD-1)+")")
   WLED = evalue("[M:HAEF]LED("+num$(TYD-1)+")")
  Else
   WTYP = evalue("[M:"+ABR+"]LEDTYP("+num$(NOL)+")")
   [L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(GACTX,[M]CPY,WTYP,WLED,WCUR,ERRMES)
   If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
  Endif
  [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX,WLED,FLGCSL,ERRMES)
  If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
  If [L]FLGCSL=[V]CST_AYES
   If I=TYD
    Raz [M]CSLFLO(nolign-1)
    Raz [M]CSLBPR(nolign-1)
   Endif
   Break
  Endif
 Next I
Endif
End

## ----------------------------------------------------------------- BPR
Subprog AS_BPR(VALEUR)
Variable Char     VALEUR
Local Integer OK
Gosub SETNOL
Local Char WCOA(GLONCOA),WACC(GLONGAC),WSAC(GLONSAC), ABR(10)
Call MSKABR("BPR",ABR) From SUBGASA

Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  Raz OK
  For I=1 To [M:HAEF]NBRLED
   WCOA = [M:HAEF]COA(I-1)
   WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"(NOL)")
   WSAC = evalue("[M:"+ABR+"]SAC"+num$(I)+"(NOL)")
   If WACC<>""
    Call LEC_GAC(WACC,WCOA) From CPTLEC
    If [F:GAC]SAC=2 : OK=-1 : Break : Endif
   Else
    OK+=1
   Endif
  Next
  # Le tiers est accessible si aucun compte saisi ou si un des comptes saisi est collectif.
  If OK<>[M:HAEF]NBRLED and OK>-1 : mkstat=1 : Endif
 When 2
 # Entry Type : Row
  J=find([M]LEDTYP(NOL),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
  If J
   WCOA = [M:HAEF]COA(J-1)
   WACC = evalue("[M:"+ABR+"]ACC1(NOL)")
   WSAC = evalue("[M:"+ABR+"]SAC1(NOL)")
   If WACC<>""
    Call LEC_GAC(WACC,WCOA) From CPTLEC
    If [F:GAC]SAC<>2 : mkstat = 1 : Endif
   Endif
 Endif
Endcase

If [M]MTC(NOL)<>"" | ([M]STA>1 & (GREP="M" or GREP="")) | [M]CHK(NOL)<>""
 mkstat = 2 : End
Endif
If [M:HAEF]TYPENT=1 & [M]IDTLIN(nolign-1)="LIAIS" : mkstat=2 : End : Endif
# Pièce comptable venant d'un autre module
If [M]ORIMOD<>2
 Local Char WSAC(GLONSAC)
 Call MSKABR("FCYLIN",ABR) From SUBGASA
 Case [M:HAEF]TYPENT
  When 1
   # Entry Type : Column
   For I=1 To [M:HAEF]NBRLED
    WSAC = evalue("[M:"+ABR+"]SAC"+num$(I)+"(NOL)")
    If WSAC<>"" : mkstat=2 : Break : Endif
   Next
  When 2
   # Entry Type : Row
   WSAC = evalue("[M:"+ABR+"]SAC1(NOL)")
   If WSAC<>"" : mkstat=2 : Endif
 Endcase
 If mkstat=2 : End : Endif
Endif

Gosub AFF_BPR
End

$AFF_BPR
If !mkstat & !GIMPORT & VALEUR<>"" & dim([M]AFFICHE)>0
 Call LEC_BPR(VALEUR) From CPTLEC
 [M]AFFICHE = VALEUR-":"-[F:BPR]BPRNAM : Gosub AFFICHE
Endif
Return

Subprog C_BPR(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
Local Char WCOA(GLONCOA),WACC(GLONGAC),ABR(10)
Call MSKABR("BPR",ABR) From SUBGASA
Local Integer LEDIND : LEDIND=1
Local Integer OKBPR  : Raz OKBPR
Local Integer OKACC

Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  For LEDIND=1 To [M:HAEF]NBRLED
   WACC = evalue("[M:"+ABR+"]ACC"+num$(LEDIND)+"(NOL)")
   If WACC<>"" : OKACC=1 : Break : Endif
  Next
  If !OKACC : Raz [M]ACCDSP : Endif
  For LEDIND=1 To [M:HAEF]NBRLED
   WCOA = [M:HAEF]COA(LEDIND-1)
   WACC = evalue("[M:"+ABR+"]ACC"+num$(LEDIND)+"(NOL)")
   If !OKACC
    Raz GNBSTR
    Gosub INITBPR From SUBGA1
    If mkstat : Break : Endif
    [M]ACCDSP +=[F:GAC]ACC+";"
    WACC = [F:GAC]ACC
   Endif
   Gosub CONTBPR From SUBGA1
   If mkstat : Break : Endif
  Next
 When 2

  # Entry Type : Row
  J=find([M]LEDTYP(NOL),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
  If J
   WCOA = [M:HAEF]COA(J-1)
   WACC = evalue("[M:"+ABR+"]ACC1(NOL)")
   For LEDIND=1 To [M:HAEF]NBRLED
    If evalue("[M:"+ABR+"]LEDTYP(NOL)")=[M:HAEF]LEDTYP(LEDIND-1) : Break : Endif
   Next
   If WACC=""
    Gosub INITBPR From SUBGA1
    If mkstat : End : Endif
    WACC = [F:GAC]ACC
   Endif
   Gosub CONTBPR From SUBGA1
   If mkstat : End : Endif
  Endif
Endcase
If mkstat : End : Endif

# Règles de progation (saisie colonne)
If [M:HAEF]TYPENT=1 & !OKACC

 # Sauvegarde de la structure
 Local Integer TYD
 Local Char SVG_ACC(GLONGAC)

 For LEDIND=1 To [M:HAEF]NBRLED
   WCOA = [M:HAEF]COA(LEDIND-1)
   WACC = evalue("[M:"+ABR+"]ACC"+num$(LEDIND)+"(NOL)")
   If WACC=""
    Call INIPRO(WCOA,WACC) From SUBGA1 : Raz mkstat
    If WACC<>"" :
     Call LEC_GAC(WACC,WCOA) From CPTLEC
     Gosub SETACC From SUBGA1
    Endif
   Endif
   SVG_ACC = WACC
   TYD = LEDIND : Gosub AVT_SAIACC
   WACC = SVG_ACC
   Call CONTACC(WACC,[M:HAEF]LEDTYP(LEDIND-1),[M:HAEF]LED(LEDIND-1),[M]FCYLIN(NOL),[M]CUR,[M]ACCDAT) From SUBGA1
   If mkstat : Raz mkstat : GBIDC1="SAC"+num$(LEDIND)+"("+num$(NOL)+")" : Break : Endif
 Next
Endif

If func AFNC.ACTIV("PRCSL") & !mkstat & !GIMPORT & dim([M]CSLBPR)>0 & VALEUR<>[M]BPR(nolign-1)
 Raz [M]CSLBPR(nolign-1)
Endif
End

Subprog AP_BPR(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
Local Char ABR(10)
Call MSKABR("BPR",ABR) From SUBGASA
Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  For I=1 To [M:HAEF]NBRLED
   Affzo = "[M:"+ABR+"]SAC"+num$(I)+"(NOL)"
   Affzo = "[M:"+ABR+"]ACC"+num$(I)+"(NOL)"
  Next
 When 2
  Affzo = "[M:"+ABR+"]SAC1(NOL)"
  Affzo = "[M:"+ABR+"]ACC1(NOL)"
Endcase
Gosub AFF_BPR
If GBIDC1<>""
 Call ERREUR(GMESSAGE) From GESECRAN
 GMESSAGE="" : zonsui = GBIDC1 : Raz GBIDC1
Endif
End

## ----------------------------------------------------------------- MNT

Subprog IB_DEB
Raz GBOUT2,GBOUT3, GBOUT4
Local Char WACC(GLONGAC),ABR(10)
Call MSKABR("DEB",ABR) From SUBGASA
Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  For I=1 To [M:HAEF]NBRLED
   WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"("+num$(nolign-1)+")")
   If WACC<>"" and GLEDREF=[M:HAEF]LEDTYP(I-1)
    GBOUT2 = mess(1,106,1)  : Break
   Endif
  Next
 When 2
  # Entry Type : Row
  If [M]LEDTYP(nolign-1)=GLEDREF :
    GBOUT2 = mess(1,106,1)
  Endif
Endcase
If [F:GDE]FLGLOT<2
 GBOUT3 = mess(53,106,1)
Endif
If [M:SCL]NBRC>0 & nolign-1<[M]NBLIG
 GBOUT4 = mess(63,106,1)
Endif
End

Subprog AS_DEB(VALEUR)
Variable Decimal  VALEUR
Local Char WCOA(GLONCOA),WSAC(GLONSAC),WACC(GLONGAC),ABR(10)
Call MSKABR("DEB",ABR) From SUBGASA
Gosub SETNOL
If [M]MTC(NOL)<>"" | ([M]STA>1 & (GREP="M" or GREP="")) | [M]CHK(NOL)<>""
 mkstat = 2 : End
Elsif [M]CDT(NOL)<>0
 mkstat = 1 : End
Elsif VALEUR<>0 & [M]BPR(NOL)<>"" & [M]ORIMOD<>2
 mkstat = 2 : End
Endif
If [M:HAEF]TYPENT=1 & [M]IDTLIN(nolign-1)="LIAIS" : mkstat=2 : End : Endif
If GREP = "M" & [M]AMTVAT(NOL)<>0
 # S'il y a de la TVA déclarée on réserve l'accès à la modification
 # de la zone aux utilisateurs qui ont le droit de modifier la zone 'TVA déclarée'
 Local Char AUZFCY(20)
 Local Integer OK
 Call DROITSITEF("VATSAI",[M]FCYLIN(NOL),[L]AUZFCY,OK) From CPTSUB
 If !OK : mkstat = 2 : Endif
Endif
# Pièce comptable venant d'un autre module
If [M]ORIMOD<>2 and VALEUR<>0
 Case [M:HAEF]TYPENT
  When 1
   # Entry Type : Column
   For I=1 To [M:HAEF]NBRLED
    WSAC = evalue("[M:"+ABR+"]SAC"+num$(I)+"(NOL)")
    If WSAC<>"" : mkstat=2 : Break : Endif
   Next
  When 2
   # Entry Type : Row
   WSAC = evalue("[M:"+ABR+"]SAC1(NOL)")
   If WSAC<>"" : mkstat=2 : Endif
 Endcase
 If mkstat=2 : End : Endif
Endif

# Initialisation
If !GIMPORT & VALEUR=0 & !varinit([M]CDT,NOL) & !GWEBSERV
 Case [M:HAEF]TYPENT
  When 1
   # Entry Type : Column
   For I=1 To [M:HAEF]NBRLED
    WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"(NOL)")
    If WACC<>""
     WCOA = [M:HAEF]COA(I-1)
     Call LEC_GAC(WACC,WCOA) From CPTLEC
     Case [F:GAC]SNSDEF
      When 2 : mkstat = 2 : # Crédit
      When 3 : If [M]TOTDEB-[M]TOTCDT>0 : mkstat=2  : Endif
     Endcase
     Break
    Endif
   Next
  When 2
   # Entry Type : Row
   WACC = evalue("[M:"+ABR+"]ACC1(NOL)")
   WCOA = evalue("[M:"+ABR+"]COA1(NOL)")
   Call LEC_GAC(WACC,WCOA) From CPTLEC
   Case [F:GAC]SNSDEF
    When 2 : mkstat = 2 : # Crédit
    When 3 : If [M]TOTDEB-[M]TOTCDT>0 : mkstat=2  : Endif
   Endcase
 Endcase
 If mkstat : End: Endif
Endif

#--- Montant forcé
Local Integer TYD : TYD=[M:HAEF]NBRLED
Gosub AVT_SAIACC

# Boucle sur les référentiels/compte saisi et Ajout dans la strucutre si compte généré.
If !clalev([F:GAC2]) : Local File =GTABCPT+"GACCOUNT"     [GAC2] : Endif

Local Char CRIBLE
Local Integer NB,I
NB=1
While NB<=GNBSTR
 If GSTRACC(NB)<>""
  #--- Axe est-il suivi sous le compte 'saisi'
  If [F:GAC2]COA<>GSTRCOA(NB) & [F:GAC2]ACC<>GSTRACC(NB)
   Read [GAC2]GAC0 = GSTRCOA(NB);GSTRACC(NB)
  Endif
  #--- Axe est il suivi sous les comptes générés
  For I=0 To [F:GAC2]COANBR-1
   #--- Recherche les comptes générés
   #      - Vérification que le référentiel/code-plan n'est pas dans les référentiel saisi
   #      - Vérification que le référentiel/code-plan est un référentiel généré (présent sous GPLAN)
   WCOA = [F:GAC2]OTHCOA(I)
   If !find(WCOA,GSTRCOA(1..GNBSTR)) & find(WCOA,GPLAN(1..10))
    Call INIACC(GSTRCOA(NB),GSTRACC(NB),WCOA,WACC,CRIBLE) From CPTINI
    If WACC<>""
     GNBSTR+=1 :  GSTRCOA(GNBSTR) = WCOA :  GSTRACC(GNBSTR) = WACC
     J=find(WCOA,GPLAN(1..10)) : GSTRTYP(GNBSTR) = GTYPLED(J) : GSTRLED(GNBSTR) = GCODLED(J) : GSTRIDT(GNBSTR)=GSTRIDT(NB)
    Endif
   Endif
  Next
 Endif
 NB+=1
Wend
End

Subprog B2_DEB(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
If ([M]TOTDEB-[M]TOTCDT>0 & [M]TOTDEB+[M]TOTCDT>0) or ([M]TOTDEB-[M]TOTCDT<0 & [M]TOTDEB+[M]TOTCDT<0)
 [M]CDT(NOL) = [M]TOTDEB-[M]TOTCDT
 VALEUR = 0 : mkstat = 99
Else
 VALEUR = [M]TOTCDT-[M]TOTDEB
Endif
End

Subprog B3_DEB(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
Gosub SETSOL From SUBGA1
If SOLDE>0
 [M]CDT(NOL) = SOLDE
 VALEUR = 0 : mkstat = 99
Else
 VALEUR = -SOLDE
Endif
End

Subprog AM_DEB(VALEUR)
Variable Decimal VALEUR
If [M]DEB(nolign-1)<>VALEUR
 For I=1 To 10
  Assign "[M]AMT"+num$(I)+"("+num$(nolign-1)+")" With 0
  Assign "[M]AMTFLG"+num$(I)+"("+num$(nolign-1)+")" With 0
  Assign "[M]AMTFRC"+num$(I)+"("+num$(nolign-1)+")" With 0
 Next
Endif
If func AFNC.ACTIV("PRCSL") & dim([M]CSLFLO)>0 & !GIMPORT & VALEUR*[M]DEB(nolign-1)=0 & [M]CSLFLO(nolign-1)<>""
 Raz [M]CSLFLO(nolign-1)
Endif
End

Subprog IB_CDT
Raz GBOUT2, GBOUT3, GBOUT4
Local Char WACC(GLONGAC),ABR(10)
Call MSKABR("CDT",ABR) From SUBGASA
Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  For I=1 To [M:HAEF]NBRLED
   WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"("+num$(nolign-1)+")")
   If WACC<>"" and GLEDREF=[M:HAEF]LEDTYP(I-1)
    GBOUT2 = mess(1,106,1)  : Break
   Endif
  Next
 When 2
  # Entry Type : Row
  If [M]LEDTYP(nolign-1)=GLEDREF :
    GBOUT2 = mess(1,106,1)
  Endif
Endcase
If [F:GDE]FLGLOT<2
 GBOUT3 = mess(53,106,1)
Endif
If [M:SCL]NBRC>0 & nolign-1<[M]NBLIG
 GBOUT4 = mess(63,106,1)
Endif
End

Subprog AS_CDT(VALEUR)
Variable Decimal  VALEUR
Local Char WCOA(GLONCOA),WSAC(GLONSAC),WACC(GLONGAC),ABR(10)
Call MSKABR("CDT",ABR) From SUBGASA
Gosub SETNOL
If [M]MTC(NOL)<>"" | ([M]STA>1 & (GREP="M" or GREP="")) | [M]CHK(NOL)<>""
 mkstat = 2
Elsif [M]DEB(NOL)<>0
 mkstat = 1
Elsif VALEUR<>0 & [M]BPR(NOL)<>"" & [M]ORIMOD<>2
 mkstat = 2 : End
Endif
If [M:HAEF]TYPENT=1 & [M]IDTLIN(nolign-1)="LIAIS" : mkstat=2 : End : Endif
If GREP = "M" & [M]AMTVAT(NOL)<>0
 # S'il y a de la TVA déclarée on réserve l'accès à la modification
 # de la zone aux utilisateurs qui ont le droit de modifier la zone 'TVA déclarée'
 Local Char AUZFCY(20)
 Local Integer OK
 Call DROITSITEF("VATSAI",[M]FCYLIN(NOL),[L]AUZFCY,OK) From CPTSUB
 If !OK : mkstat = 2 : Endif
Endif

#--- Montant forcé
# Mise en place de la structure
Local Integer TYD : TYD=[M:HAEF]NBRLED
Gosub AVT_SAIACC

# Boucle sur les référentiels/compte saisi et Ajout dans la strucutre si compte généré.
If !clalev([F:GAC2]) : Local File =GTABCPT+"GACCOUNT"     [GAC2] : Endif
Local Char CRIBLE
Local Integer NB,I
NB=1
While NB<=GNBSTR
 If GSTRACC(NB)<>""
  #--- Axe est-il suivi sous le compte 'saisi'
  If [F:GAC2]COA<>GSTRCOA(NB) | [F:GAC2]ACC<>GSTRACC(NB)
   Read [GAC2]GAC0 = GSTRCOA(NB);GSTRACC(NB)
  Endif
  #--- Axe est il suivi sous les comptes générés
  For I=0 To [F:GAC2]COANBR-1
   #--- Recherche les comptes générés
   #      - Vérification que le référentiel/code-plan n'est pas dans les référentiel saisi
   #      - Vérification que le référentiel/code-plan est un référentiel généré (présent sous GPLAN)
   WCOA = [F:GAC2]OTHCOA(I)
   If !find(WCOA,GSTRCOA(1..GNBSTR)) & find(WCOA,GPLAN(1..10))
    Call INIACC(GSTRCOA(NB),GSTRACC(NB),WCOA,WACC,CRIBLE) From CPTINI
    If WACC<>""
     GNBSTR+=1 :  GSTRCOA(GNBSTR)=WCOA :  GSTRACC(GNBSTR) = WACC
     J=find(WCOA,GPLAN(1..10)) : GSTRTYP(GNBSTR) = GTYPLED(J) : GSTRLED(GNBSTR) = GCODLED(J) : GSTRIDT(GNBSTR)=GSTRIDT(NB)
    Endif
   Endif
  Next
 Endif
 NB+=1
Wend
End

Subprog B2_CDT(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
If ([M]TOTDEB-[M]TOTCDT>0 & [M]TOTDEB+[M]TOTCDT>0) or ([M]TOTDEB-[M]TOTCDT<0 & [M]TOTDEB+[M]TOTCDT<0)
 VALEUR = [M]TOTDEB-[M]TOTCDT
Else
 [M]DEB(NOL) = [M]TOTCDT-[M]TOTDEB
 Affzo [M]DEB(NOL)
 VALEUR = 0 : mkstat = 99
 zonsui = "DEB("+num$(NOL)+")"
Endif
End

Subprog B3_CDT(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
Gosub SETSOL From SUBGA1
If SOLDE>0
 VALEUR = SOLDE
Else
 [M]DEB(NOL) = -SOLDE
 Affzo [M]DEB(NOL)
 VALEUR = 0 : mkstat = 99
 zonsui = "DEB("+num$(NOL)+")"
Endif
End

Subprog AM_CDT(VALEUR)
Variable Decimal VALEUR
 For I=1 To 10
  Assign "[M]AMT"+num$(I)+"("+num$(nolign-1)+")" With 0
  Assign "[M]AMTFLG"+num$(I)+"("+num$(nolign-1)+")" With 0
  Assign "[M]AMTFRC"+num$(I)+"("+num$(nolign-1)+")" With 0
 Next
If func AFNC.ACTIV("PRCSL") & dim([M]CSLFLO)>0 & !GIMPORT & VALEUR*[M]CDT(nolign-1)=0 & [M]CSLFLO(nolign-1)<>""
 Raz [M]CSLFLO(nolign-1)
Endif
End

## ----------------------------------------------------------------- DES
Subprog D_DES(VALEUR)
Variable Char     VALEUR
If VALEUR="" : VALEUR = [M]DESVCR : Endif
End

Subprog AM_DES(VALEUR)
Variable Char     VALEUR
Gosub SETDES From SUBGA1
End

## ----------------------------------------------------------------- TAX
Subprog D_TAX(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" | GIMPORT : End : Endif
If clalev([F:TVB])=0 : Local File =GTABCPT+"TABVACBPR" [TVB] : Endif
If clalev([F:TVT])=0 : Local File =GTABCPT+"TABVAT"  [TVT] : Endif
Local Char WCOA(GLONCOA),WACC(GLONGAC),ABR(10)
Call MSKABR("TAX",ABR) From SUBGASA
Local Char CODTAX(GLONVAT), VAC(GLONTVB), TIERS(GLONBPR), TYPTIERS(1)
Gosub SETNOL

Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  For I=1 To [M:HAEF]NBRLED
   WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"(NOL)")
   If WACC<>""
    WCOA = [M:HAEF]COA(I-1)
    Call LEC_GAC(WACC,WCOA) From CPTLEC
    If [F:GAC]FLGVAT>1
     Gosub INITAX
     If VALEUR<>"" : Break : Endif
    Endif
   Endif
  Next
 When 2
  # Entry Type : Row
  WACC = evalue("[M:"+ABR+"]ACC1(NOL)")
  WCOA = evalue("[M:"+ABR+"]COA1(NOL)")
  Call LEC_GAC(WACC,WCOA) From CPTLEC
  If [F:GAC]FLGVAT>1 : Gosub INITAX : Endif
Endcase
End

$INITAX
# Paramètre EXETAX (Tronc commun)
If dim(GEXETAX)>0 : VALEUR = GEXETAX : Endif
# Code taxe renseigné au niveau du compte général
If [F:GAC]VAT(0)<>"" : VALEUR = [F:GAC]VAT(0) : Return : Endif
# Code taxe pas obligatoire au niveau du compte
Local Integer INDLIG
If dim(GSAITAX)>0 & GSAITAX=1
 TIERS=""
 For INDLIG=0 To nolign-1
  If [M]BPR(INDLIG)<>"" : TIERS=[M]BPR(INDLIG) : Break : Endif
 Next INDLIG
 If TIERS<>""
  TYPTIERS = " "
  Read [BPR]BPR0 = TIERS
  If !fstat
   If [F:BPR]BPCFLG=2 : TYPTIERS="C"
   Elsif [F:BPR]BPSFLG=2 : TYPTIERS="F" : Endif
  Endif
  Call INIT_REGIME(TIERS,[M]FCYLIN(INDLIG),TYPTIERS,[L]VAC) From CPTSUB
  Call LEC_TVB(GCURLEG,[L]VAC) From CPTLEC
  If !fstat & [F:TVB]ENAFLG=2
   CODTAX = [F:TVB]VAT   # Code taxe associé au régime tiers
   If CODTAX<>""
    Call LEC_TVT_LEG(GCURLEG,CODTAX) From CPTLEC
    If !fstat : VALEUR = CODTAX : Endif
   Endif
  Endif
 Endif
Endif
Return

Subprog AS_TAX(VALEUR)
Variable Char     VALEUR
If !clalev([F:COA])  : Local File =GTABCPT+"GCOA"       [COA] : Endif
Local Char WCOA(GLONCOA),WACC(GLONGAC),ABR(10)
Call MSKABR("TAX",ABR) From SUBGASA
Local Integer I
Gosub SETNOL
mkstat = 1
Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  For I=1 To [M:HAEF]NBRLED
   WCOA = [M:HAEF]COA(I-1)
   If WCOA<>""
    #--- Lecture du code code plan
    Call LEC_COA(WCOA) From CPTLEC
    #--- Est il Gestion des taxes ?
    If [F:COA]TAXMGT = 2 :
     WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"(NOL)")
     Call LEC_GAC(WACC,WCOA) From CPTLEC
     If [F:GAC]FLGVAT>1 : Raz mkstat : Break : Endif
    Endif
   Endif
  Next
 When 2
  # Entry Type : Row
  WCOA = evalue("[M:"+ABR+"]COA1("+num$(NOL)+")")
  If WCOA<>""
   #--- Lecture du code code plan
   Call LEC_COA(WCOA) From CPTLEC
   #--- Est il Gestion des taxes ?
   If [F:COA]TAXMGT = 2 :
    WACC = evalue("[M:"+ABR+"]ACC1("+num$(NOL)+")")
    Call LEC_GAC(WACC,WCOA) From CPTLEC
    If [F:GAC]FLGVAT>1 : Raz mkstat : Endif
   Endif
  Endif
Endcase
If mkstat : End : Endif

If [F:GDE]FLGLOT<>2
 If [M]MTC(NOL)<>"" | ([M]STA>1 & (GREP="M" or GREP="")) | [M]CHK(NOL)<>""
  mkstat = 2 : End
 Endif
 If [M:HAEF]TYPENT=1 & [M]IDTLIN(nolign-1)="LIAIS" : mkstat=2 : End : Endif
 If GREP = "M" & [M]AMTVAT(NOL)<>0
  # On réserve l'accès à la modification de la zone 'Code taxe' aux utilisateurs
  # qui ont le droit de modifier la zone 'TVA déclarée'
  Local Char AUZFCY(20)
  Local Integer OK
  Call DROITSITEF("VATSAI",[M]FCYLIN(NOL),[L]AUZFCY,OK) From CPTSUB
  If !OK : mkstat = 2 : Endif
 Endif
Endif
End

Subprog C_TAX(VALEUR)
Variable Char    VALEUR()
Local Char OPTTVA(1)
If GCOMPTA=3 : End : Endif
If !clalev([F:GTE]) : Local File =GTABCPT+"GTYPACCENT" [GTE] : Endif
If !clalev([F:TVT]) : Local File =GTABCPT+"TABVAT"     [TVT] : Endif
If !clalev([F:COA]) : Local File =GTABCPT+"GCOA"       [COA] : Endif

Local Char WCOA(GLONCOA),WACC(GLONGAC),ABR(10)
Call MSKABR("TAX",ABR) From SUBGASA
Local Integer OK
Gosub SETNOL
If VALEUR=""
 Case [M:HAEF]TYPENT
  When 1
   # Entry Type : Column
   For I=1 To [M:HAEF]NBRLED
    WCOA = [M:HAEF]COA(I-1)
    If WCOA<>""
     #--- Lecture du code code plan
     Call LEC_COA(WCOA) From CPTLEC
     #--- Est il Gestion des taxes ?
     If [F:COA]TAXMGT = 2 :
      WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"(NOL)")
      Call LEC_GAC(WACC,WCOA) From CPTLEC
      If [F:GAC]FLGVAT>1
       GMESSAGE = [F:GAC]ACC-"("-WCOA-")\"-mess(10,123,1)
       mkstat = 2 : Break
      Endif
     Endif
    Endif
   Next
  When 2
   # Entry Type : Row
   WCOA = evalue("[M:"+ABR+"]COA1("+num$(NOL)+")")
   If WCOA<>""
    #--- Lecture du code code plan
    Call LEC_COA(WCOA) From CPTLEC
    #--- Est il Gestion des taxes ?
    If [F:COA]TAXMGT = 2 :
     WACC = evalue("[M:"+ABR+"]ACC1("+num$(NOL)+")")
     Call LEC_GAC(WACC,WCOA) From CPTLEC
     If [F:GAC]FLGVAT>1
      GMESSAGE = mess(10,123,1)
      mkstat = 2
     Endif
    Endif
   Endif
 Endcase
# Issue X3-16347
Else
 Case [M:HAEF]TYPENT
  When 1
   # Entry Type : Column
   If dim([M:HAE1]ORIMOD)>0 & [M:HAE1]ORIMOD=2 & dim([M:HAE1]FLGGEN)>0 & [M:HAE1]FLGGEN=1
    For I=1 To [M:HAEF]NBRLED
     WCOA = [M:HAEF]COA(I-1)
     If WCOA<>""
      Call LEC_COA(WCOA) From CPTLEC
      If [F:COA]TAXMGT = 2 :
       WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"(NOL)")
       Call LEC_GAC(WACC,WCOA) From CPTLEC
       Local Char P_TAX(GLONVAT)  : P_TAX(0)  = VALEUR
       If func FINTVT_SYRA.CTL_TAX(GACTX,WCOA,WACC,P_TAX,GMESSAGE)>=[V]CST_AERROR
        mkstat = 2 : Break
       Endif
      Endif
     Endif
    Next
   Endif
  When 2
   # Entry Type : Row
   If dim([M:HAE1]ORIMOD)>0 & [M:HAE1]ORIMOD=2 & dim([M:HAE1]FLGGEN)>0 & [M:HAE1]FLGGEN=1
    WCOA = evalue("[M:"+ABR+"]COA1("+num$(NOL)+")")
    If WCOA<>""
     Call LEC_COA(WCOA) From CPTLEC
     If [F:COA]TAXMGT = 2 :
      WACC = evalue("[M:"+ABR+"]ACC1("+num$(NOL)+")")
      Call LEC_GAC(WACC,WCOA) From CPTLEC
      Local Char P_TAX(GLONVAT)  : P_TAX(0)  = VALEUR
      If func FINTVT_SYRA.CTL_TAX(GACTX,WCOA,WACC,P_TAX,GMESSAGE)>=[V]CST_AERROR
       mkstat = 2
      Endif
     Endif
    Endif
   Endif
 Endcase
# End Issue X3-16347
Endif
If mkstat : End : Endif
Call PARAM([M]CPY,"CONTVAPCE",OPTTVA) From ADOVAL
If OPTTVA = "2"
 Call LEC_GTE_LEG(GCURLEG,[M]TYP) From CPTLEC
 Call LEC_TVT_LEG(GCURLEG,VALEUR) From CPTLEC
 If [F:GTE]VAT=1 & [F:TVT]VATPAY=1
  OK = 2 : Call AVERTIR(mess(96,106,1),OK) From GESECRAN
  If OK<>2 : mkstat = 2 : End : Endif
 Endif
Endif
End

## ----------------------------------------------------------------- CPA
Subprog AS_CPA1(VALEUR)
Variable Char    VALEUR()
TYD = 1 : Goto AS_CPA
Subprog AS_CPA2(VALEUR)
Variable Char    VALEUR()
TYD = 2 : Goto AS_CPA
