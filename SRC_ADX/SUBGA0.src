Subprog AS_RAT1(VALEUR)
Variable Decimal VALEUR
Goto AS_RAT
Subprog AS_RAT2(VALEUR)
Variable Decimal VALEUR
Goto AS_RAT

$AS_RAT
If [M]STA>1 & (GREP="M" or GREP="") : mkstat = 2 : End
Elsif sum([M]MTC)<>"" : mkstat = 2 : End
Elsif sum([M]CHK)<>"" : mkstat = 2 : End
Elsif [M]ORIMOD<>2    : mkstat = 2 : End
Endif
End

#############################
Subprog AM_RAT1(VALEUR)
Variable Decimal VALEUR
ZON = "RATDIV" : Goto AM_RAT
Subprog AM_RAT2(VALEUR)
Variable Decimal VALEUR
ZON = "RATMLT" : Goto AM_RAT

$AM_RAT

If VALEUR=0 : VALEUR=evalue("[M:SCL]"+ZON+"1("+num$(indice)+")") : Endif
If GIMPORT : End : Endif

# Mise à jour du masque HAEF
For J=0 To min([M:HAEF]NBRC,len(mess(0,2644,1)))-1
 If [M:SCL]LIGLED(J)-1=indice
  Assign "[M:HAEF]"+ZON+"C("+num$(J)+")" With VALEUR
 Endif
Next
End

#############################
Subprog B3_RAT1(VALEUR)
Variable Decimal VALEUR
Goto B3_RAT
Subprog B3_RAT2(VALEUR)
Variable Decimal VALEUR
Goto B3_RAT
Subprog B3_CUR(VALEUR)
Variable Char  VALEUR
Goto B3_RAT


$B3_RAT
Local Integer OK2 : OK2=2
Call DIALWIN(OK2,"DEVISE","OGASCUR") From GESECRAN
End

#--------------------------------------------------#
# Affichage des cours devises                      #
#--------------------------------------------------#
#--------------------------------------------------#
# [M]RAT1    : Cours Diviseur                      #
# [M]CURDIV  : Devise                              #
# [M]RAT2    : Cours multiplicateur                #
# [M]CURMLT  : Devise                              #
#--------------------------------------------------#
$CHARG_ZONES_DEV

Local Char ABR(10)
#-- Sauvegarde la Société
Call MSKABR("CPY",ABR) From SUBGASA
WSOC= evalue("[M:"+ABR+"]CPY")

#-- Masque par défaut du Bloc Devise
#Call MSKABR("CUR",ABR) From SUBGASA
#ABR =  "[M:"+ABR+"]"
#Default Mask ABR

#-- Initialisation du masque commun SAICURLED (sans les cours enregistrés)
Call INIT([M:HAE1]CUR,[L]WSOC,[M:HAE1]TYPRAT,[M:HAE1]RATDAT,0) From SUBSCL
Gosub CHARG_ZONES_DEV From SUBSCL

#-- Sauvegarde les cours enregistrés dans les Zones de stockage [M:HAEF] (utile pour Action commune : SAIRATCUR)
#For J=0 To min([M:HAEF]NBRC,len(mess(0,2644,1)))-1
For J=0 To min([M:HAEF]NBRC,len(mess(0,2644,1))-1)
 [M:HAEF]RATDIVC(J) = [F:HAE]RATDIV(J)
 [M:HAEF]RATMLTC(J) = [F:HAE]RATMLT(J)
Next

#-- Gestion des cours devises du masque de la saisie des pièces HAE1
If dim([M:HAE1]RAT1)>0
 Actzo [M:HAE1]RAT1, CURMLT, RAT2, CURDIV
 Raz [M:HAE1]IDTLED, RAT1, CURMLT, RAT2, CURDIV

 If [M:SCL]NBRC>0
  For J=0 To min([M:SCL]NBRC-1,len(mess(0,2644,1)))
   If J<dim([M]CURMLT)
    [M:HAE1]IDTLED(J) = [M:SCL]IDT(J)
    [M:HAE1]CURDIV(J) = [M:SCL]CUR(J)
    [M:HAE1]CURMLT(J) = [M:SCL]CURLED(J)
    [M:HAE1]RAT1(J) = [F:HAE]RATDIV([M:SCL]LEDTYP(J)-1)
    [M:HAE1]RAT2(J) = [F:HAE]RATMLT([M:SCL]LEDTYP(J)-1)
   Endif
  Next
 Else  # Si aucun cours, afficher 1xxx=1xxx  : Ddm52898 : Ne rien afficher.
  For J=0 To min(5,len(mess(0,2644,1)))
   If J<dim([M]CURMLT)
    [M:HAE1]IDTLED(J) = ""
    [M:HAE1]CURDIV(J) = "" #[M]CUR
    [M:HAE1]CURMLT(J) = "" #[M]CUR
    [M:HAE1]RAT1(J) = 0   # Perf
    [M:HAE1]RAT2(J) = 0   # Perf
   Endif
  Next
 Endif

 Affzo [M:HAE1]IDTLED, RAT1, CURMLT, RAT2, CURDIV

 #-- Grizage des référentiels
 For J=[M:SCL]NBRC To dim(CURMLT)-1
  Grizo [M:HAE1]IDTLED(J), RAT1(J), CURMLT(J), RAT2(J), CURDIV(J)
 Next

Endif
Return

#--------------------------------------------------#
# Sugg V140 : Stocker les cours devises            #
#--------------------------------------------------#
#--------------------------------------------------#
# Initialisation des cours saisis                  #
#------------------------------------------------- #
# [M]RATCUR : Cours société                        #
# [M]RATRPT : Cours dossier (reporting)            #
#--------------------------------------------------#
$INIT_COURS
#Default Mask [HAE1]
Gosub INIT_COURS From SUBSCL

# Remplissage du masque HAEF
For I=0 To len(mess(0,2644,1))-1
 If [F:GCM]LED(I)<>""
  # Devise de pièce = Devise de référentiel
  If [F:GCM]CUR(I)=[M:SCL]CURENT
   Assign "[M:HAEF]RATMLTC("+num$(I)+")" With 1
   Assign "[M:HAEF]RATDIVC("+num$(I)+")" With 1
  Elsif [F:GCM]CUR(I)=[M:SCL]CURLED([M:SCL]LIGLED(I)-1)
   Assign "[M:HAEF]RATMLTC("+num$(I)+")" With [M:SCL]RATMLT([M:SCL]LIGLED(I)-1)
   Assign "[M:HAEF]RATDIVC("+num$(I)+")" With [M:SCL]RATDIV([M:SCL]LIGLED(I)-1)
  Endif
 Endif
Next

# Remplissage du masque HAE1
If dim([M:HAE1]RAT1)>0
 For J=0 To min([M:SCL]NBRC,len(mess(0,2644,1)))-1
  If J<dim([M]CURMLT)
   [M:HAE1]RAT1(J) = [M:SCL]RATDIV(J)
   [M:HAE1]RAT2(J) = [M:SCL]RATMLT(J)
  Endif
 Next
 Gosub GRISE_COURS
Endif

Return

#--------------------------------------------------#
# Grisage des cours saisis                         #
#--------------------------------------------------#
# [M]RAT1 : Cours diviseur                         #
# [M]RAT2 : Cours multiplicateur                   #
#--------------------------------------------------#
$GRISE_COURS
# Grise Cours gère uniquement l'affiche des cours dans la Saisie de pièces (écrans générés)
#      (INIT_COURS de SUBSCL permet d'initialiser correctement les cours des autres fonctions).

For I=0 To [M:SCL]NBRC-1
 If I>dim([M:HAE1]CURMLT)-1 : Break : Endif
 Case [F:GCM]DACRAT([M:SCL]LEDTYP(I)-1)
  When 1 :
   # Multiplicateur
   [M:HAE1]RAT1(I) = 1  : Diszo [M:HAE1]RAT1(I)
  When 2 :
   # Diviseur
   [M:HAE1]RAT2(I)  = 1 : Diszo [M:HAE1]RAT2(I)
  When 3 :
   # Les deux
   Actzo [M:HAE1]RAT1(I), RAT2(I)
 Endcase
 # Devise IN
 If GCURFLG=2 and GLEDFLG([M:SCL]LEDTYP(I))=2
   Diszo [M:HAE1]RAT1(I), RAT2(I)
 Endif
Next
Return
