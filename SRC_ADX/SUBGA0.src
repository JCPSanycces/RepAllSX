## ----------------------------------------------------------------- UOM
Subprog D_UOM(VALEUR)          # Uniquement affiché
Variable Char     VALEUR
If VALEUR<>"" : End : Endif
Local Char WCOA(GLONCOA),WACC(GLONGAC),ABR(10)
Call MSKABR("TAX",ABR) From SUBGASA
Local Integer I
Gosub SETNOL
If VALEUR=""
 Case [M:HAEF]TYPENT
  When 1
   # Entry Type : Column
   For I=1 To [M:HAEF]NBRLED
    WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"(NOL)")
    If WACC<>""
     WCOA = [M:HAEF]COA(I-1)
     Call LEC_GAC(WACC,WCOA) From CPTLEC
     If [F:GAC]FLGUOM=2 : VALEUR = [F:GAC]UOM : Break : Endif
    Endif
   Next
  When 2
   # Entry Type : Row
    WACC = evalue("[M:"+ABR+"]ACC1(NOL)")
    If WACC<>""
     WCOA = evalue("[M:"+ABR+"]COA1(NOL)")
     Call LEC_GAC(WACC,WCOA) From CPTLEC
     If [F:GAC]FLGUOM=2 : VALEUR = [F:GAC]UOM : Endif
    Endif
 Endcase
Endif
End

## ----------------------------------------------------------------- QTY
Subprog D_QTY(VALEUR)
Variable Decimal  VALEUR
Gosub SETQTY From SUBGA1
End

Subprog DD_QTY(OK)
Variable Integer OK
OK=1
Local File AMSKZON [AMZ]
Local Char    MSKREF(20)
Local Integer K
For K=0 To 2
 If evalue("dim([M:HAE"+num$(K)+"]QTY)>0")
  Case K
   When 0 : If GCOMPTA<>3  : MSKREF = "GACCENT0"
            Else           : MSKREF = "GACCENT0"
            Endif
   When 1 : If GCOMPTA<>3  : MSKREF = "WMAC1"+[F:GDE]DIA
            Else           : MSKREF = "GACCENT1"
            Endif
   When 2 : If GCOMPTA<>3  : MSKREF = "WMAC2"+[F:GDE]DIA
            Else           : MSKREF = "GACCENT2"
            Endif
  Endcase
  Break
 Endif
Next K
If MSKREF="" : End : Endif
Read [AMZ]CODE = MSKREF;"QTY"
If fstat=0 & [F:AMZ]SAIAFF=3 : OK=0 : End : Endif
End

Subprog AS_QTY(VALEUR)
Variable Decimal  VALEUR

# QTY est accessible si un au moins des Comptes est coché 'Gestion Unité d'oeuvre'
# En cas de pièce en état Définitif, la modification est possible uniquement si :
#        - Paramèter GCNTANA <> 2
#        - Tous les comptes des Référentiels Flagué "Gestion Analytique" avec exercice/période Ouvert.

Local Char WLED(GLONLED),WCOA(GLONCOA),WACC(GLONGAC),WCUR(GLONCUR),ABR(10)
Local Integer I,IND, TYD, WTYP
Call MSKABR("QTY",ABR) From SUBGASA
Gosub SETNOL
mkstat = 1
Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  For TYD=1 To [M:HAEF]NBRLED
   # Pièce définitive
    If (GREP="" | GREP="M") & [M]STA>1
     WLED = evalue("[M:HAEF]LED("+num$(TYD-1)+")")
     WTYP = evalue("[M:HAEF]LEDTYP("+num$(TYD-1)+")")
     Call INDLED(WLED,"",IND,I) From CPTDIV
     Call CONTPER([M]ACCDAT,WTYP,[M]FCYLIN(nolign-1)) From CPTSUB
     If GCNTANA=2 or mkstat=2
      Raz GMESSAGE : mkstat=2 : Break
     Endif
    Endif
   # Compte unité d'oeuvre
   WACC = evalue("[M:"+ABR+"]ACC"+num$(TYD)+"(NOL)")
   If WACC<>""
    WCOA = [M:HAEF]COA(TYD-1)
    Call LEC_GAC(WACC,WCOA) From CPTLEC
    If [F:GAC]FLGUOM=2 : Raz mkstat : Break : Endif
   Endif
  Next
 When 2
  # Entry Type : Row
   # Pièce définitive
   If (GREP="" | GREP="M") & [M]STA>1
    WTYP = evalue("[M:"+ABR+"]LEDTYP("+num$(NOL)+")")
    Call LECLED([M]CPY,WTYP,WLED,WCUR) From CPTDIV
    Call INDLED(WLED,"",IND,I) From CPTDIV
    Call CONTPER([M]ACCDAT,WTYP,[M]FCYLIN(nolign-1)) From CPTSUB
    If GCNTANA=2 or mkstat=2
     Raz GMESSAGE : mkstat=2 : End
    Endif
   Endif
   # Compte unité d'oeuvre
   WACC = evalue("[M:"+ABR+"]ACC1("+num$(NOL)+")")
   If WACC<>""
    WCOA = evalue("[M:"+ABR+"]COA1("+num$(NOL)+")")
    Call LEC_GAC(WACC,WCOA) From CPTLEC
    If [F:GAC]FLGUOM=2 : Raz mkstat : Endif
   Endif
Endcase
If mkstat : End : Endif
Call AROQTE(VALEUR,[F:GAC]UOM) From CPTINI
End


## ----------------------------------------------------------------- PJTLIN
Subprog AS_PJTLIN(VALEUR)
Variable Char    VALEUR()
# X3-103268
#If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M]CPY,"PJTMGT")<>2
If func AFNC.ACTIV("PJM") and fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,[M]CPY,"PJTMGT")<>2
 mkstat = 1 : End
Else
  If [M:HAE1]PJT<>"" & VALEUR=""
    If [HAE0]STA <> 2 #101254 just when it's final status do not let PJTLIN be populated from PJT
      VALEUR =  [M:HAE1]PJT
    Endif
  Endif
Endif
End


## ----------------------------------------------------------------- DSP
Subprog D_DSP(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : End : Endif
Local Char WCOA(GLONCOA),WACC(GLONGAC),ABR(10)
Call MSKABR("DSP",ABR) From SUBGASA
Local Integer I
Gosub SETNOL
Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  For I=1 To [M:HAEF]NBRLED
   WACC = evalue("[M:"+ABR+"]ACC"+num$(I)+"("+num$(NOL)+")")
   If WACC<>""
    #WCOA = evalue("[M:"+ABR+"]COA"+num$(I)+"("+num$(NOL)+")")
    WCOA = [M:HAEF]COA(I-1)
    Call INIDSP(VALEUR,WACC,WCOA) From SUBGA1
    If VALEUR<>"" : Break : Endif
   Endif
  Next
 When 2
  # Entry Type : Row
  Call INIDSP(VALEUR,[M]ACC1(NOL),[M]COA1(NOL)) From SUBGA1
Endcase
End

Subprog AS_DSP(VALEUR)
Variable Char     VALEUR

# DSP est accessible si un au moins des Référentiels est flagué "Gestion Analytique"
#                    et compte renseigné pour la Saisie Colonne
# En cas de pièce en état Définitif, la modification est possible uniquement si :
#        - Paramèter GCNTANA <> 2
#        - Tous les comptes des Référentiels Flagué "Gestion Analytique" avec exercice/période Ouvert.

Local Char WLED(GLONLED),WCOA(GLONCOA),WACC(GLONGAC),WCUR(GLONCUR),ABR(10)
Local Integer I,IND, TYD, WTYP
Call MSKABR("DSP",ABR) From SUBGASA
Gosub SETNOL
mkstat = 1
Case [M:HAEF]TYPENT
 When 1
  # Entry Type : Column
  For TYD=1 To [M:HAEF]NBRLED
   WLED = evalue("[M:HAEF]LED("+num$(TYD-1)+")")
   WTYP = evalue("[M:HAEF]LEDTYP("+num$(TYD-1)+")")
   Call INDLED(WLED,"",IND,I) From CPTDIV
   # Pièce définitive
    If (GREP="" | GREP="M") & [M]STA>1
     Call CONTPER([M]ACCDAT,WTYP,[M]FCYLIN(nolign-1)) From CPTSUB
     If GCNTANA=2 or mkstat=2
      Raz GMESSAGE : mkstat=2 : Break
     Endif
    Endif
   # Gestion analytique
   If GLEDFLGANA(IND)=2 : Raz mkstat : Break : Endif
  Next
 When 2
  # Entry Type : Row
  WTYP = evalue("[M:"+ABR+"]LEDTYP("+num$(NOL)+")")
  Call LECLED([M]CPY,WTYP,WLED,WCUR) From CPTDIV
  Call INDLED(WLED,"",IND,I) From CPTDIV
  # Pièce définitive
  If (GREP="" | GREP="M") & [M]STA>1
   Call CONTPER([M]ACCDAT,WTYP,[M]FCYLIN(nolign-1)) From CPTSUB
   If GCNTANA=2 or mkstat=2
    Raz GMESSAGE : mkstat=2 : End
   Endif
  Endif
  # Gestion analytique
  If GLEDFLGANA(IND)=2 : Raz mkstat : Endif
Endcase
If mkstat=2 : End : Endif

Raz mkstat
Gosub AVT_SAIDSP
If [M]ACCDSP="" : mkstat=1 : End : Endif

Gosub AFF_DSP
End

Subprog C_DSP(VALEUR)
Variable Char     VALEUR
Local Char    BID(20)
Local Integer I, OK
Gosub SETNOL

#CHECK IGNORE_BEGIN
If VALEUR=""
 If dim([M:HAE0]DSP)>0
  If [M:HAE0]PTF(NOL)<>0 : VALEUR="$" : Endif
 Elsif dim([M:HAE1]DSP) >0
  If [M:HAE1]PTF(NOL)<>0 : VALEUR="$" : Endif
 Elsif dim([M:HAE2]DSP) >0
  If [M:HAE2]PTF(NOL)<>0 : VALEUR="$" : Endif
 Endif
Endif
#CHECK IGNORE_END

Case VALEUR
 When ""
  End
 When "$"
  If !GIMPORT
   OK  = 1
   OK *= [M]DEB(NOL)+[M]CDT(NOL)=sum([M:VT2]TBAMT([M]PTV(NOL)..[M]PTF(NOL)))
   OK *= [M]QTY(NOL)=sum([M:VT2]TBQTY([M]PTV(NOL)..[M]PTF(NOL)))
   If !OK
    GMESSAGE = mess(28,106,1)
    mkstat = 2 : End
   Endif
   Gosub RAZCCE
  Endif
 When Default
  Call CONTDSP(VALEUR,[M]FCYLIN(NOL),[M]ACCDAT) From SUBGA1
  If mkstat : End : Endif
  [M:VTL]TOTREP = [M]DEB(NOL)+[M]CDT(NOL)
  Call CHARGE_VTE_STR(VALEUR,[M]UOM(NOL),[M]LEDDSP,[M]ACCDSP,"") From VENTILE
  Call CONTVENT([M]FCYLIN(NOL),[M]ACCDAT) From SAIVENTILE
  If mkstat : End : Endif
 [M]PTV(NOL) = 0 : [M]PTF(NOL) = 0
 Gosub RAZCCE
Endcase
End

Subprog AP_DSP(VALEUR)
Variable Char VALEUR
Gosub AFF_DSP
End

$AFF_DSP
If !mkstat & !GIMPORT & VALEUR<>"" & dim([M]AFFICHE)>0
 Call LEC_DSP(VALEUR) From CPTLEC
 If !fstat
  [M]AFFICHE = VALEUR-":"-[F:DSP]DES : Gosub AFFICHE
 Endif
Endif
Return



## ----------------------------------------------------------------- CCE

$RAZCCE
For I=1 To 20
 Assign "[M]CCE"+num$(I)+"("+num$(NOL)+")" With ""
Next I
Return

########################
Subprog AV_CCE1(VALEUR)
Variable Char    VALEUR()
AXE = 1 : Goto AVCCE
Subprog AV_CCE2(VALEUR)
Variable Char    VALEUR()
AXE = 2 : Goto AVCCE
Subprog AV_CCE3(VALEUR)
Variable Char    VALEUR()
AXE = 3 : Goto AVCCE
Subprog AV_CCE4(VALEUR)
Variable Char    VALEUR()
AXE = 4 : Goto AVCCE
Subprog AV_CCE5(VALEUR)
Variable Char    VALEUR()
AXE = 5 : Goto AVCCE
Subprog AV_CCE6(VALEUR)
Variable Char    VALEUR()
AXE = 6 : Goto AVCCE
Subprog AV_CCE7(VALEUR)
Variable Char    VALEUR()
AXE = 7 : Goto AVCCE
Subprog AV_CCE8(VALEUR)
Variable Char    VALEUR()
AXE = 8 : Goto AVCCE
Subprog AV_CCE9(VALEUR)
Variable Char    VALEUR()
AXE = 9 : Goto AVCCE
Subprog AV_CCE10(VALEUR)
Variable Char    VALEUR()
AXE = 10 : Goto AVCCE
Subprog AV_CCE11(VALEUR)
Variable Char    VALEUR()
AXE = 11 : Goto AVCCE
Subprog AV_CCE12(VALEUR)
Variable Char    VALEUR()
AXE = 12 : Goto AVCCE
Subprog AV_CCE13(VALEUR)
Variable Char    VALEUR()
AXE = 13 : Goto AVCCE
Subprog AV_CCE14(VALEUR)
Variable Char    VALEUR()
AXE = 14 : Goto AVCCE
Subprog AV_CCE15(VALEUR)
Variable Char    VALEUR()
AXE = 15 : Goto AVCCE
Subprog AV_CCE16(VALEUR)
Variable Char    VALEUR()
AXE = 16 : Goto AVCCE
Subprog AV_CCE17(VALEUR)
Variable Char    VALEUR()
AXE = 17 : Goto AVCCE
Subprog AV_CCE18(VALEUR)
Variable Char    VALEUR()
AXE = 18 : Goto AVCCE
Subprog AV_CCE19(VALEUR)
Variable Char    VALEUR()
AXE = 19 : Goto AVCCE
Subprog AV_CCE20(VALEUR)
Variable Char    VALEUR()
AXE = 20 : Goto AVCCE
End

$AVCCE
# En saisie "Ligne" et "Colonne" => les axes sont toujours présents
#    Format    => FMTDIE(AXE)
#    Intitulé  => INTDIE(AXE)
# Fait dans la génération des écrans
#
# En saisie "Onglet", même écrans de base, les axes évoluent selon le référentiel.
#    Format    => FMTDIE(I)
#    Intitulé  => INTDIE(I)
#
#    I => Indice est recherché dans le tableau de l'écran GACCENTFMT
#
#    En onglet : Masques WMACxONG => x correspond au référentiel
#                                    Par référentiel => 9 axes maxi

# Lecture de Transaction de saisie
Call LEC_GDE([M:HAEF]DACDIA) From CPTLEC
# Mise à jour de GCCEFMT uniquement en saisie "Onglet"
If [F:GDE]TYPENT<>3 : End : Endif

Local Char WREF(GLONLED)
If AXE>9
 GCCEFMT = "-K:15X"
Else
 WREF = evalue("[M:HAEF]DIE"+num$(AXE)+"("+num$(val(mid$(maskcou,5,1))-2)+")")
 If WREF=""
  GCCEFMT = "-K:15X"
 Else
  GCCEFMT = evalue("[M:HAEF]FMTDIE("+num$(find(WREF,[M:HAEF]DIE(0..[M:HAEF]NBRAXI-1))-1)+")")
 Endif
Endif
End

########################
Subprog D_CCE1(VALEUR)
Variable Char    VALEUR()
AXE = 1 : Goto DEFCCE
Subprog D_CCE2(VALEUR)
Variable Char    VALEUR()
AXE = 2 : Goto DEFCCE
Subprog D_CCE3(VALEUR)
Variable Char    VALEUR()
AXE = 3 : Goto DEFCCE
Subprog D_CCE4(VALEUR)
Variable Char    VALEUR()
AXE = 4 : Goto DEFCCE
Subprog D_CCE5(VALEUR)
Variable Char    VALEUR()
AXE = 5 : Goto DEFCCE
Subprog D_CCE6(VALEUR)
Variable Char    VALEUR()
AXE = 6 : Goto DEFCCE
Subprog D_CCE7(VALEUR)
Variable Char    VALEUR()
AXE = 7 : Goto DEFCCE
Subprog D_CCE8(VALEUR)
Variable Char    VALEUR()
AXE = 8 : Goto DEFCCE
Subprog D_CCE9(VALEUR)
Variable Char    VALEUR()
AXE = 9 : Goto DEFCCE
Subprog D_CCE10(VALEUR)
Variable Char    VALEUR()
AXE = 10 : Goto DEFCCE
Subprog D_CCE11(VALEUR)
Variable Char    VALEUR()
AXE = 11 : Goto DEFCCE
Subprog D_CCE12(VALEUR)
Variable Char    VALEUR()
AXE = 12 : Goto DEFCCE
Subprog D_CCE13(VALEUR)
Variable Char    VALEUR()
AXE = 13 : Goto DEFCCE
Subprog D_CCE14(VALEUR)
Variable Char    VALEUR()
AXE = 14 : Goto DEFCCE
Subprog D_CCE15(VALEUR)
Variable Char    VALEUR()
AXE = 15 : Goto DEFCCE
Subprog D_CCE16(VALEUR)
Variable Char    VALEUR()
AXE = 16 : Goto DEFCCE
Subprog D_CCE17(VALEUR)
Variable Char    VALEUR()
AXE = 17 : Goto DEFCCE
Subprog D_CCE18(VALEUR)
Variable Char    VALEUR()
AXE = 18 : Goto DEFCCE
Subprog D_CCE19(VALEUR)
Variable Char    VALEUR()
AXE = 19 : Goto DEFCCE
Subprog D_CCE20(VALEUR)
Variable Char    VALEUR()
AXE = 20 : Goto DEFCCE

$DEFCCE
Gosub SETNOL

#-- Initialisation uniquement en création ou en duplication de pièces...
#If !find(GREP,"C","D"): End : Endif

#-- Pas de passage sur les axes invisibles
If AXE>[M:HAEF]NBRAXI : End : Endif

#-- Pas d'initialisation si une répartition à priori est définie
If [M]DSP(NOL)<>"" : mkstat=1 : End : Endif

#-- Si initialisation déjà faîte (cf FLDAVTCAR) alors contrôle de compatibilité
If VALEUR<>""
 Call ="AS_CCE"+num$(AXE) With VALEUR  From SUBGA0
 If mkstat
  Raz VALEUR, mkstat # Initialisation incompatible
 Else
  End    # Initialisation OK
 Endif
Endif

#--- Axe saisissable si Compte saisi ou généré est suivi en analytique pour cette axe.
If !clalev([F:GAC2]) : Local File =GTABCPT+"GACCOUNT"     [GAC2] : Endif
Local Char WACC(GLONGAC), WCOA(GLONCOA), CRIBLE
Local Integer NB,I

# Mise en place de la structure
Local Integer TYD : TYD=[M:HAEF]NBRLED
Gosub AVT_SAIACC

# Boucle sur les référentiels/compte saisi et Ajout dans la strucutre si compte généré.
NB=1

Call LEC_GDE([M:HAEF]DACDIA) From CPTLEC
While NB<=GNBSTR
 If GSTRACC(NB)<>""
  #--- Initialisation selon le compte saisi...
  Call INICCE(VALEUR,[M:HAEF]DIE(AXE-1),GSTRLED(NB),GSTRACC(NB),[F:GDE]CDE) From CPTINI
  If VALEUR<>"" : Raz mkstat : Break : Endif

  #--- Axe est il suivi sous les comptes générés
  If [F:GAC2]COA<>GSTRCOA(NB) | [F:GAC2]ACC<>GSTRACC(NB) :
   Read [GAC2]GAC0 = GSTRCOA(NB);GSTRACC(NB)
  Endif
  For I=0 To [F:GAC2]COANBR-1
   #--- Recherche les comptes générés
   #      - Vérification que le référentiel/code-plan n'est pas dans les référentiel saisi
   #      - Vérification que le référentiel/code-plan est un référentiel généré (présent sous GPLAN)
   WCOA = [F:GAC2]OTHCOA(I)
   If !find(WCOA,GSTRCOA(1..GNBSTR)) & find(WCOA,GPLAN(1..10))
    Call INIACC(GSTRCOA(NB),GSTRACC(NB),WCOA,WACC,CRIBLE) From CPTINI
    If WACC<>""

     #--- Initialisation selon le compte généré...
     Call INICCE(VALEUR,[M:HAEF]DIE(AXE-1),WCOA,WACC,[F:GDE]CDE) From CPTINI
     If VALEUR<>"" : Raz mkstat : Break 2 : Endif

     #--- Cascade
     GNBSTR+=1 :  GSTRCOA(GNBSTR)=WCOA :  GSTRACC(GNBSTR) = WACC
     J=find(WCOA,GPLAN(1..10)) : GSTRTYP(GNBSTR) = GTYPLED(J) : GSTRLED(GNBSTR) = GCODLED(J) : GSTRIDT(GNBSTR) = GSTRIDT(NB)
    Endif
   Endif
  Next
 Endif
 NB+=1
Wend

#--- Dernière initialisation... ligne précédente
If VALEUR="" & NOL>0
 VALEUR = evalue("[M]CCE"+num$(AXE)+"("+num$(NOL-1)+")")
Endif

End

