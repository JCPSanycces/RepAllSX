Variable Char    VALEUR()
AXE = 20 : Goto SAICCE

$SAICCE
#--- En import, la saisie s'effectue directement dans l'écran VENTILE
If GIMPORT : mkstat = 2 : End : Endif

#--- En cas de pièce en état Définitif, la modification est possible uniquement si :
#        - Paramèter GCNTANA <> 2 and Axe est coché "Modif écriture définitive"
#        - Axes de tous les Référentiels associés  avec exercice/période Ouvert.
#           (Référentiels saisis, générés, automatique)

Local Char WLED(GLONLED), WCOA(GLONCOA),WACC(GLONGAC),WCUR(GLONCUR),ABR(10)
Local Integer I,IND, TYD, WTYP, AXI

If (GREP="" | GREP="M") & [M]STA>1
 Call LEC_DIE([M:HAEF]DIE(AXE-1)) From CPTLEC
 If GCNTANA=2 | [F:DIE]FLGMODACE<>2
  mkstat=2 : End
 Else
  Call MSKABR("QTY",ABR) From SUBGASA
  Case [M:HAEF]TYPENT
   When 1
    # Entry Type : Column
    For TYD=1 To [M:HAEF]NBRLED
     WTYP = evalue("[M:HAEF]LEDTYP("+num$(TYD-1)+")")
     WACC = evalue("[M:"+ABR+"]ACC"+num$(TYD)+"(nolign-1)")
     If WACC<>""
      WLED = evalue("[M:HAEF]LED("+num$(TYD-1)+")")
      Call INDLED(WLED,[M:HAEF]DIE(AXE-1),IND,AXI) From CPTDIV
      If AXI
       Call CONTPER([M]ACCDAT,WTYP,[M]FCYLIN(nolign-1)) From CPTSUB
       If mkstat : Raz GMESSAGE : Break : Endif
      Endif
     Endif
    Next
    If mkstat : End : Endif
   When 2
    # Entry Type : Row
    WTYP = evalue("[M:"+ABR+"]LEDTYP("+num$(nolign-1)+")")
    WACC = evalue("[M:"+ABR+"]ACC1("+num$(nolign-1)+")")
    If WACC<>""
     Call LECLED([M]CPY,WTYP,WLED,WCUR) From CPTDIV
     Call INDLED(WLED,[M:HAEF]DIE(AXE-1),IND,AXI) From CPTDIV
     If AXI
      Call CONTPER([M]ACCDAT,WTYP,[M]FCYLIN(nolign-1)) From CPTSUB
      If mkstat : Raz GMESSAGE : End : Endif
     Endif
    Endif
   Endcase
 Endif
Endif

#--- Pas de saisie si Réparatition à priori.
Gosub SETNOL
If [M]DSP(NOL)<>"" :  mkstat = 1 : End : Endif

#--- Axe saisissable si Compte saisi ou généré est suivi en analytique pour cette axe.
Local Char WACC(GLONGAC), CRIBLE
Local Integer I,J,K,LIG,NB
Local Integer AXI, IND

# Mise en place de la structure
Local Integer TYD : TYD=[M:HAEF]NBRLED
Gosub AVT_SAIACC

mkstat=1 # Aucun accès

# Boucle sur les référentiels/compte saisi et Ajout dans la strucutre si compte généré.
NB=1
If !clalev([F:GAC2]) : Local File =GTABCPT+"GACCOUNT"     [GAC2] : Endif
While NB<=GNBSTR
 If GSTRACC(NB)<>""
  #--- Axe est-il suivi sous le compte 'saisi' ainsi que le référentiel
  If [F:GAC2]COA<>GSTRCOA(NB) | [F:GAC2]ACC<>GSTRACC(NB)
   Read [GAC2]GAC0 = GSTRCOA(NB);GSTRACC(NB)
  Endif
  Call INDLED(GSTRLED(NB),[M:HAEF]DIE(AXE-1),IND,AXI) From CPTDIV
  If AXI & find([M:HAEF]DIE(AXE-1),[F:GAC2]DIE(0..[F:GAC2]DACDIENBR-1))
   Raz mkstat
   If [M:HAEF]TYPENT=2 & GSTRCOA(NB)=[M]COA1(NOL) & GSTRACC(NB)=[M]ACC1(NOL) : End : Endif
  Endif

  #--- Axe est il suivi sous les comptes générés
  For I=0 To [F:GAC2]COANBR-1
   #--- Recherche les comptes générés
   #      - Vérification que le référentiel/code-plan n'est pas dans les référentiel saisi
   #      - Vérification que le référentiel/code-plan est un référentiel généré (présent sous GPLAN)
   WCOA = [F:GAC2]OTHCOA(I)
   If !find(WCOA,GSTRCOA(1..GNBSTR)) & find(WCOA,GPLAN(1..10))
    Call INIACC(GSTRCOA(NB),GSTRACC(NB),WCOA,WACC,CRIBLE) From CPTINI
    If WACC<>""
     #--- Cascade
     GNBSTR+=1 :  GSTRCOA(GNBSTR)=WCOA :  GSTRACC(GNBSTR) = WACC
     J=find(WCOA,GPLAN(1..10)) : GSTRTYP(GNBSTR) = GTYPLED(J) : GSTRLED(GNBSTR) = GCODLED(J) : GSTRIDT(GNBSTR) = GSTRIDT(NB)

     #--- Est-ce accessible...
     If !mkstat
      #--- Lecture du compte
      Read [GAC2]GAC0 = WCOA;WACC
      #--- Axe est il suivi...
      If find([M:HAEF]DIE(AXE-1),[F:GAC2]DIE(0..[F:GAC2]DACDIENBR-1)) : Raz mkstat : Endif
     Endif
    Endif
   Endif
  Next
 Endif
 NB+=1
Wend

# Dans le cas d'une propagation - Transaction de saisie => ligne propagée mais référentiel visible.
If [M:HAEF]TYPENT=2
 For I=1 To GNBSTR
  LIG = -1
  For K=0 To [M]NBLIG-1
   If K<>NOL & [M]LEDTYP(K)=GSTRTYP(I) & [M]IDTLIN(K)=GSTRIDT(I) & [M]ACC(K)=GSTRACC(I)
    LIG=K : Break 2
   Endif
  Next
 Next
 If LIG<>-1 : mkstat=1 : Endif
Endif

If mkstat : End : Endif
Gosub AFF_CCE
End

########################
