######################################################################################
# Issue X3-93418
# DEB
Subprog C_DEB(VALEUR)
Variable Decimal VALEUR
 Gosub CTL_PAYACCNUM
End
# CDT
Subprog C_CDT(VALEUR)
Variable Decimal VALEUR
 Gosub CTL_PAYACCNUM
End
#
$CTL_PAYACCNUM
# If presence of record in PAYACCNUM, value may not be set to zero
If VALEUR=0
 If clalev([F:PAN]) = 0 : Local File PAYACCNUM  [PAN] : Endif
 Filter [PAN] Where ACCNUM=[M]ACCNUM(nolign-1)
 Read [F:PAN]PAN0 First
 If !fstat & [M]ACCNUM(nolign-1)<>0
    GMESSAGE = mess(75,106,1)-mess(3,14,1) :# Ecriture du module Tiers / Module entry AP-AR accounting
    mkstat = 2
    Goto CTL_END
 Endif
 If clalev([F:PMD]) = 0 : Local File PAYACCNUMD [PMD] : Endif
 Filter [PMD] Where ACCNUM=[M]ACCNUM(nolign-1)
 Read [F:PMD]PMD0 First
 If !fstat & [M]ACCNUM(nolign-1)<>0
    GMESSAGE = mess(75,106,1)-mess(3,14,1) :# Ecriture du module Tiers / Module entry AP-AR accounting
    mkstat = 2
 Endif
 Filter [PMD]
 $CTL_END
 Filter [PAN]
Endif
Return
# End issue X3-93418
######################################################################################

