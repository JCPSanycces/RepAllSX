#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque POT1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone DESSHO
mkstat = 0
zoncou = "DESSHO"
indice = 0
If varinit([M]DESSHO,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DESSHO,"POSTE","DESSHO",[M]COD,"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DESSHO,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DESSHO" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone DATSTRVLY
mkstat = 0
zoncou = "DATSTRVLY"
indice = 0
WDATE = [M]DATSTRVLY
If varmode([M]DATSTRVLY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATSTRVLY" : Gosub ACTION From =IMPTRT
 Endif
 If WDATE<>[M]DATSTRVLY or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_DATSTRVLY([M]DATSTRVLY) From SUBPOT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "DATSTRVLY" : GZNUM = 51334 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone DATENDVLY
mkstat = 0
zoncou = "DATENDVLY"
indice = 0
WDATE = [M]DATENDVLY
If varmode([M]DATENDVLY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATENDVLY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "DATDEBFIN"
 Call DATDEBFIN([M]DATENDVLY,[M]DATSTRVLY) From EXEFNC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "DATENDVLY" : GZNUM = 51340 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WDATE<>[M]DATENDVLY or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_DATENDVLY([M]DATENDVLY) From SUBPOT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DATENDVLY" : GZNUM = 51340 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone JOBPOT
mkstat = 0
zoncou = "JOBPOT"
indice = 0
WCHAR = [M]JOBPOT
If varmode([M]JOBPOT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "JOBPOT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_JOBPOT([M]JOBPOT) From SUBPOT
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "JOBPOT" : GZNUM = 45853 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]JOBPOT
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]JOBPOT = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "JOBPOT" : GZNUM = 45853 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]JOBPOT or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_JOBPOT([M]JOBPOT) From SUBPOT
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "JOBPOT" : GZNUM = 45853 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone TEX
mkstat = 0
zoncou = "TEX"
indice = 0
If varmode([M]TEX,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TEX" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone MISWEIFLG
mkstat = 0
zoncou = "MISWEIFLG"
indice = 0
IMPENT = [M]MISWEIFLG
WNUM = IMPENT
If varinit([M]MISWEIFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]MISWEIFLG,indice)=0
 [M]MISWEIFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "MISWEIFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]MISWEIFLG(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_MISWEIFLG(IMPENT) From SUBPOT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "MISWEIFLG" : GZNUM = 1001671 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]MISWEIFLG = IMPENT

## Zone MISEQ
mkstat = 0
zoncou = "MISEQ"
indice = 0
IMPENT = [M]MISEQ
If varinit([M]MISEQ,indice)=0
 IMPENT = 1
Endif
If varmode([M]MISEQ,indice)=0
 [M]MISEQ(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "MISEQ" : Gosub ACTION From =IMPTRT
  IMPENT = [M]MISEQ(indice)
 Endif
Endif
[M]MISEQ = IMPENT

## Zone INDFLG
mkstat = 0
zoncou = "INDFLG"
indice = 0
IMPENT = [M]INDFLG
WNUM = IMPENT
If varinit([M]INDFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]INDFLG,indice)=0
 [M]INDFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "INDFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]INDFLG(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_INDFLG(IMPENT) From SUBPOT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "INDFLG" : GZNUM = 6430 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]INDFLG = IMPENT

## Zone INDWEIFLG
mkstat = 0
zoncou = "INDWEIFLG"
indice = 0
IMPENT = [M]INDWEIFLG
WNUM = IMPENT
If varinit([M]INDWEIFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]INDWEIFLG,indice)=0
 [M]INDWEIFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "INDWEIFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]INDWEIFLG(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_INDWEIFLG(IMPENT) From SUBPOT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "INDWEIFLG" : GZNUM = 1001686 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]INDWEIFLG = IMPENT

## Zone INDEQ
mkstat = 0
zoncou = "INDEQ"
indice = 0
IMPENT = [M]INDEQ
If varinit([M]INDEQ,indice)=0
 IMPENT = 1
Endif
If varmode([M]INDEQ,indice)=0
 [M]INDEQ(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "INDEQ" : Gosub ACTION From =IMPTRT
  IMPENT = [M]INDEQ(indice)
 Endif
Endif
[M]INDEQ = IMPENT

####################################
## Bloc tableau 4
####################################
IMPTBL = 1

## Zone NBRMIS
mkstat = 0
zoncou = "NBRMIS"
indice = 0
status = 1
zoncou = "NBRMIS"
If varmode([M]NBRMIS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRMIS" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRMIS
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRMIS = nolign
   status = 75
   Call SAI_NBRMIS(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 4
####################################
Subprog SAI_NBRMIS(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRMIS
mkstat = 0
zoncou = "NBRMIS"

## Zone MIS
mkstat = 0
zoncou = "MIS"
WCHAR = [M]MIS(indice)
If varmode([M]MIS,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_MIS([M]MIS(indice)) From SUBPOT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]MIS(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "MIS" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]MIS(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "MIS" : GZNUM = 16225 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("MIS","",[M]MIS(indice),"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "MIS" : GZNUM = 16225 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_MIS([M]MIS(indice)) From SUBPOT
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "MIS" : GZNUM = 16225 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call AP_MIS([M]MIS(indice)) From SUBPOT
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "MIS" : GZNUM = 16225 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]MIS(indice) or IMPMOD
       SAVACT = GACTION : GACTION = "STD"
       Call AM_MIS([M]MIS(indice)) From SUBPOT
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "MIS" : GZNUM = 16225 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone MISWEI
mkstat = 0
zoncou = "MISWEI"
If varmode([M]MISWEI,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "MISWEI" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_MISWEI([M]MISWEI(indice)) From SUBPOT
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "MISWEI" : GZNUM = 1001671 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone IND
mkstat = 0
zoncou = "IND"
If varmode([M]IND,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "IND" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_IND([M]IND(indice)) From SUBPOT
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "IND" : GZNUM = 6430 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone INDWEI
mkstat = 0
zoncou = "INDWEI"
If varmode([M]INDWEI,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "INDWEI" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_INDWEI([M]INDWEI(indice)) From SUBPOT
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "INDWEI" : GZNUM = 1001686 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone NBRMIS
mkstat = 0
zoncou = "NBRMIS"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "POT1"
Return

