#<AdxTL>@(#)11.0.0.0 $Revision$
#########################################################################
#  SIXSIH: pour traitements de bascule Integrale --> X3                 #
#########################################################################
# Subprog SI_SIH                                                        #
#     Création des factures / avoirs clients                            #
#########################################################################

Gosub SI_CONTEXT From SIXFONCTION
#SI_SIMU=2
Local File SIPARX3  [SPX]
Local File SIPARVAC [SPV]
Read [SPX] First
Call EXEC From SIXSIH
End


#########################################################################
Subprog EXEC
Local Integer WOUV_TRACE, WERR
Local Char    WMSG

If GTRACE = ""
    Call OUVRE_TRACE("SI_SIH : "+SI_MES(54)) From LECFIC
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR
#----- Vérification cohérence nbre d'axes définis dans "Intégrale" et code activité ANA -----#
Call VARGLOBANA(WMSG,WERR) From SIXGAS
If WERR
    Call ECR_TRACE(WMSG,1) From GESECRAN
Else
    #---- Création enregistrements SINVOICE / SINVOICEV / SINVOICED ------#
    Call ECR_TIME("SI_SIH : "+mess(213,124,1)+" SINVOICE / SINVOICEV / SINVOICED") From DOSSUB
    Call SI_SINVOICE
Endif

$FIN_SIH
Onerrgo
If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif
End


$TRT_ERR
    Call ECR_TRACE( errp-"ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
    GIMPORT=0    # Bug 47776
Resume

#########################################################################

Subprog SI_SINVOICE

#--- pour appel GENSIH

Local Integer LCOD   : LCOD=1                : # 1=Création complète / 2=Garnissage uniquement des classes [M]
Local Char    LMAJ   : LMAJ="C"              : # C=Création
Local Integer LECH   : LECH=1                : # Creation des echeances  1=non / 2=oui
Local Integer LTEST  : LTEST=1               : # 1=Pas ecriture du fichier trace / 2=Ecriture de la trace
Local Char    LTRT   : LTRT="SIXSIH"         : # Traitement contenant les actions appelees par TRTVENFACG
Local Char    LORINUM                        : # No du document origine ( utilisation facultative )
Local Char    LNEWNUM                        : # No de facture creee
Local Integer LERR   : LERR=0                : # Code retour erreur
Local Integer LNBSIH, LNBERR : LNBSIH=0 : LNBERR=0

If SI_SIMU=2 LTEST+=2 Endif

#--- Ouverture standard documents ventes
Gosub OPEN_STD From SIXSQH

#--- Ouverture des tables Integrale
Gosub OPEN_INT From SIXSQH

#--- Ouverture des tables et masques de l'objet SIH

If !clalev([F:SIH])  : Local File =SI_DOSSIER+".SINVOICE"   [SIH] : Endif
If !clalev([F:SIV])  : Local File =SI_DOSSIER+".SINVOICEV"  [SIV] : Endif
If !clalev([F:SID])  : Local File =SI_DOSSIER+".SINVOICED"  [SID] : Endif
If !clalev([F:TSV])  : Local File =SI_DOSSIER+".TABSIVTYP"  [TSV] : Endif
If !clalev([F:SOH])  : Local File =SI_DOSSIER+".SORDER"     [SOH] : Endif
If !clalev([F:SOP])  : Local File =SI_DOSSIER+".SORDERP"    [SOP] : Endif
If !clalev([F:SOQ])  : Local File =SI_DOSSIER+".SORDERQ"    [SOQ] : Endif
If !clalev([F:SDH])  : Local File =SI_DOSSIER+".SDELIVERY"  [SDH] : Endif
If !clalev([F:SDD])  : Local File =SI_DOSSIER+".SDELIVERYD" [SDD] : Endif
If !clalev([F:SRD])  : Local File =SI_DOSSIER+".SRETURND"   [SRD] : Endif
If !clalev([F:HDI])  : Local File =SI_DOSSIER+".HDKTASKINV" [HDI] : Endif
If !clalev([F:SRE])  : Local File =SI_DOSSIER+".SERREQUEST" [SRE] : Endif
If !clalev([F:STJ])  : Local File =SI_DOSSIER+".STOJOU"     [STJ] : Endif
If !clalev([F:STO])  : Local File =SI_DOSSIER+".STOCK"      [STO] : Endif
If !clalev([F:STL])  : Local File =SI_DOSSIER+".STOLOT"     [STL] : Endif
If !clalev([F:GTE])  : Local File =SI_DOSSIER+".GTYPACCENT" [GTE] : Endif
If !clalev([F:CAC])  : Local File =SI_DOSSIER+".GACCCODE"   [CAC] : Endif
If !clalev([F:GAC])  : Local File =SI_DOSSIER+".GACCOUNT"   [GAC] : Endif
If !clalev([F:CON])  : Local File =SI_DOSSIER+".CONTSERV"   [CON] : Endif
If !clalev([F:TRA])  : Local File =SI_DOSSIER+".TABRATVAT"  [TRA] : Endif

If !clalev([M:SIH0]) : Local Mask =SI_DOSSIER+".SIH0"       [SIH0] : Endif
If !clalev([M:SIH1]) : Local Mask =SI_DOSSIER+".SIH1"       [SIH1] : Endif
If !clalev([M:SIH2]) : Local Mask =SI_DOSSIER+".SIH2"       [SIH2] : Endif
If !clalev([M:SIH4]) : Local Mask =SI_DOSSIER+".SIH4"       [SIH4] : Endif
If !clalev([M:SIHV]) : Local Mask =SI_DOSSIER+".SIHV"       [SIHV] : Endif

# Pour les articles gérés avec des nomenclatures, pour ne pas décliner la nomenclature
Global Integer G_LINTYP : G_LINTYP=1
# Numéro des colonnes à garnir avec les 2 remises intégrales
Global Integer GDISCRGNUM1, GDISCRGNUM2

SI_SUBPRG = "SI_SIH"
SI_TABLE = "XIEPV"

Local Char CRITERE (250)
CRITERE  = 'find(TYPPIE,"FA","AV","AC")'  : # type de piece facture / avoir / avoir en valeur
CRITERE += '& FLGMAJ="C"'                 : # comptabilisé
CRITERE += '& FLGREP<2'                   : # pas encore migre dans X3
CRITERE += '& DATPIE>=[F:SPX]STRPER'      : # sur la periode active

CRITDET='LIGSUP<>"S" & !find(NATART, "SD", "ST", "TD", "TP")'

Gosub SI_CRITSUP From SIXFONCTION    : # dans PE : variable SI_SUBPRG a tester car XIEPV commun (devis,cde,facture)

#SI_CRITERE='NUMORD=1862 | NUMORD=1865 | NUMORD=1872'
#SI_CRITERE='NUMORD=2048 | NUMORD=2047'
#SI_CRITERE='NUMORD=2048'

#--- Boucle de creation du fichier de travail ( un enr. par no ordre avec la + grande lettre reliquat )
For [XVH0] Where evalue(CRITERE)
&              & evalue(SI_CRITERE)

   Gosub SINUM_AFF From SIXSQH :  Call AFFBOITE(SINUM) From SUBSIM
   If GTRACE<>""
       # Bug 47804 : Amélio trace
       Case [F:XVH0]TYPPIE
           When"FA" :
               Call ECR_TRACE(mess(4,432,1)-SINUM,0) From GESECRAN
           When"AC","AV" :
               Call ECR_TRACE(mess(5,432,1)-SINUM,0) From GESECRAN
       Endcase
   Endif

   # -- alimenter les classes [F] nécessaires à l'entete ainsi que le masque SIWRKEPV
   Gosub SIWRKEPV From SIXSQH

   # 01/04/08 : Il manquait l'évaluation de CRITDET
   Filter [XVLI] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ & evalue(CRITDET)

   Call GENSIH (LCOD,LMAJ,LECH,LTEST,LTRT,LORINUM,LNEWNUM,LERR) From TRTVENFACG
   If LERR=0 LNBSIH+=1 Else LNBERR+=1 Endif

Next

Call ECR_TIME("SIXSIH :"-SI_MES(119)-num$(LNBSIH)-SI_MES(173)-num$(LNBERR)) From DOSSUB

Kill G_LINTYP
Kill GDISCRGNUM1, GDISCRGNUM2

End


#########################################################################
#    Pour GENSIH composant calcul facture
#    chargement masques SIH0 SIH1 SIH2 SIHV SIH4
#    Actions appelées dans le TRTVENFACG
#########################################################################
$ACTION_GS

Case GWACTION_GS
     When "READ_DETAIL"       Gosub READ_DETAIL
     When "MSK_ENTETE"        Gosub MSK_ENTETE
     When "MSK_DETAIL"        Gosub MSK_DETAIL
     When "AP_READ_DETAIL"    Gosub AP_READ_DETAIL
     When "MSK_VALORISATION"  Gosub MSK_VALORISATION
     When "INICRE"            Gosub INICRE
     When "ERREUR"            Gosub ERREUR
     When "CREATION"          Gosub CREATION
Endcase

Return

#------------------------------------------------------------------------
# Chargement des ecrans entete de commande
#------------------------------------------------------------------------
$MSK_ENTETE
Local Char    WBPCPYR(GLONBPC)


#Setmode
#Infbox IMPZON

Case IMPZON

     When "NUM"        :                               #--- masque SIH0
     When "SIVTYP"     :  Case [F:XVH0]TYPPIE
                               When "FA"  : [M]SIVTYP=[F:SPX]SIVTYP
                               When "AV"  : [M]SIVTYP=[F:SPX]CNOTYP
                               When "AC"  : [M]SIVTYP=[F:SPX]CNVTYP
                          Endcase
     When "SALFCY"     :  [M]SALFCY=[F:SPX]FCY
     When "INVREF"     :  [M]INVREF=[F:XVH0]REFCMD
#                          [M]INVREF=num$([F:XVH0]NUMORD)

     When "INVDAT"     :  [M]INVDAT=[F:XVH0]DATPIE
     When "BPCINV"     :  If [F:XVH0]CLTFAC<>"" [M]BPCINV=func SIXFONCTION.SI_COR("XICLT",[F:XVH0]CLTFAC,"","") Endif
                          # Chargement champs non saisissables sur appel champ saisissable obligatoire
                          # Régime CEE et Nature transaction :
                          # --> Pas de transcodage : Données normalisées
                          If GACTDEB=2
                              # If [F:XVH0]CODREG<>0 [M]EECSCH=num$([F:XVH0]CODREG) Endif
                              If [F:XVH0]CODREG<>0 [M]EECSCHR=num$([F:XVH0]CODREG) Endif : # V6
                              # If [F:XVH0]CODTST<>0 [M]EECNAT="0"+num$([F:XVH0]CODTST) Endif
                              If [F:XVH0]CODTST<>0 [M]EECNATR=num$([F:XVH0]CODTST) Endif : # V6
                          Endif
                          If [F:XVH0]NBREXL<>0 [M]COPNBR=[F:XVH0]NBREXL Endif : # V6
#                                                      #--- masque SIH1
     When "BPRPAY"     :  Gosub CHARG_BPCPYR From SIXSQH : [M]BPRPAY=WBPCPYR : # Bug 47519
                          Gosub CHARG_BPYADD From SIXSQH : # V6
                          If [F:XVH0]CODCLT<>"" [M]BPCORD=func SIXFONCTION.SI_COR("XICLT",[F:XVH0]CODCLT,"","") Endif
                          GBPCNUM=[M]BPCORD
     When "REP"
          Case indice
               When 0  :  If [F:XVH0]CODREP<>""
                             [M]REP(0)=func SIXFONCTION.SI_COR("XIREP",[F:XVH0]CODREP,"","")
                           Else
                             [M]REP(0)=""
                          Endif
          Endcase

     When "VACBPR"     :  [M]VACBPR=func SIXFONCTION.SI_VACBPR("C",[F:XVH0]ASJTVA,[F:XVH0]ASJTPF,[F:XVH0]ASJTAXADD,[M:SIW0]CODPAY)
                          If [M]VACBPR="" : # Bug 48060 : Amélio trace
                            Call ECR_TRACE (SI_MES(276),1) From GESECRAN
                            Call ECR_TRACE (SI_MES(277)-":"-[F:XVH0]ASJTVA-SI_MES(278)-":"-[F:XVH0]ASJTPF-SI_MES(279)-":"-[F:XVH0]ASJTAXADD-SI_MES(280)-":"-[M:SIW0]CODPAY,1) From GESECRAN
                          Endif
     When "PRITYP"     :  If [F:XVH0]FACTTC="O"  [M]PRITYP=2
                            Else                 [M]PRITYP=1
                          Endif
     When "STOMVTFLG"  :  [M]STOMVTFLG=1
     When "STOFCY"     :  If [F:XVH0]CODDPO<>"" [M]STOFCY=func SIXFONCTION.SI_COR("XIDPO",[F:XVH0]CODDPO,"","") Endif

     When "INVSTA"     :  If [F:XVH0]FLGMAJ="C" [M]INVSTA=3 Endif

#                                                      #--- masque SIH2
     When "CUR"        :  If [F:XVH0]CODDVS=""   [M]CUR=[F:SPX]CUR
                            Else                 [M]CUR=func SIXFONCTION.SI_COR("XIDVS",[F:XVH0]CODDVS,"","")
                          Endif
#     When "RATCUR"     :  # Vu 14/03/08
     When "RAT2"        : # V6
                          # Bug 56031 : Alimenter le cours multiplisateur et non le cours diviseur
                          If [F:XVH0]CODDVS<>"" & [F:XVH0]TAUDVS<>0 & [F:XVH0]NAP9<>0
                              [M:SIH2]RAT2=arr([F:XVH0]NAPFRS/[F:XVH0]NAP9,10^-6)
                              [M:SIH2]RAT1=1
                          Endif
     When "STRDUDDAT"  :  If [F:XVH0]DATECH1<>[0/0/0]
                              [M]STRDUDDAT=[F:XVH0]DATECH1
                          Elsif [M]STRDUDDAT=[0/0/0]
                              [M]STRDUDDAT=[M]INVDAT
                          Endif
     When "PTE"        :  If [F:XVH0]MODRGL1<>""
                              Local Char WCLERGL1, WCLERGL2                                       : # Bug 79385
                              If len([F:XVH0]MODRGL1)>2
                                  WCLERGL1=left$([F:XVH0]MODRGL1,2)                               : # Bug 79385
                                  WCLERGL2=right$([F:XVH0]MODRGL1,3)                              : # Bug 79385
                              Else
                                  WCLERGL1=[F:XVH0]MODRGL1
                              Endif
                              [M]PTE=func SIXFONCTION.SI_COR2("XIMODRGL",WCLERGL1,WCLERGL2,"","") : # Bug 79385
                          Endif
                          # Vu 14/03/08 : Si le chp RAT1 n'est pas saisissable, il n'a pas été chargé
                          # On le recharge içi pour être sûr
                          # Bug 56031 : Alimenter le cours multiplisateur et non le cours diviseur
                          If [F:XVH0]CODDVS<>"" & [F:XVH0]TAUDVS<>0 & [F:XVH0]NAP9<>0
                              [M:SIH2]RAT2=arr([F:XVH0]NAPFRS/[F:XVH0]NAP9,10^-6)
                              [M:SIH2]RAT1=1
                          Endif
     When "NBFAC"       :  [M]NBFAC=[M:SIW0]NBFAC
                          For I=0 To [M:SIW0]NBFAC-1 : [M]INVDTAAMT(I)=[M:SIW0]INVDTAAMT(I) : Next I

Endcase

Return

#------------------------------------------------------------------------
# Lecture des enregistrements details
# - le filter des lignes doit être actif
# - on ne fait que de la création de lignes
#------------------------------------------------------------------------
$READ_DETAIL
nolign=0 : LIG_DETAIL="C"     : # uniquement de la creation
Local Decimal CUMQTY

If LEC_DETAIL=0
    Read [XVLI] First
Else
    Read [XVLI] Next
Endif
If    !fstat        : # lecture ok
   LEC_DETAIL=1
Elsif fstat=4       : # fin lecture
   LEC_DETAIL=2
Elsif fstat         : # erreur
   LEC_DETAIL=3   : GBIDC3="XILPV [XVLI]"
Endif

Return

#------------------------------------------------------------------------
# Chargement d'une ligne dans l'ecran SIH4 de la facture
#------------------------------------------------------------------------
$MSK_DETAIL
Local Char WSAU(GLONUOM)

#Setmode
#Infbox IMPZON

GNETMAR=0 : # ne pas controler la marge x fois

Case IMPZON
     When "ITMREF"     :  If [F:XVLI]CODART<>""
                              [M]ITMREF(nolign-1) =func SIXFONCTION.SI_COR("XIART",[F:XVLI]CODART,"","")
                          Endif
     When "ITMDES"     :  [M]ITMDES(nolign-1) =[F:XVLI]NOMART
     When "DSTOFCY"    :  If [F:XVLI]CODDPO<>""
                              [M]DSTOFCY(nolign-1)=func SIXFONCTION.SI_COR("XIDPO",[F:XVLI]CODDPO,"","")
                          Endif
     When "SAU"        :  WSAU=[M]SAU(nolign-1)
                          If [F:XVLI]UNIVEN<>""
                              [M]SAU(nolign-1)=func SIXFONCTION.SI_COR("XIUNIFAC",[F:XVLI]UNIVEN,"","")
                          Endif
                          If WSAU<>[M]SAU(nolign-1) & [M]SAU(nolign-1)<>""
                              # Bug 48690
                              # On vérifie si l'unité de la facture fait partie des unités définies dans l'article
                              # Si ce n'est pas le cas, pour ne pas bloquer :
                              # On garde l'unité initialisée au départ (unité de vente définie ds l'article)
                              #----- Lecture de l'article et article-client si nécessaire -----#
                              If [F:ITM]ITMREF<>[M:SIH4]ITMREF(nolign-1)
                                  Read [ITM] ITM0=[M:SIH4]ITMREF(nolign-1)
                                  If fstat Raz [F:ITM] : Endif
                              Endif
                              If [F:ITU]ITMREF<>[M:SIH4]ITMREF(nolign-1) | [F:ITU]BPCNUM<>[M:SIH1]BPCORD
                                  Read [ITU] ITU0=[M:SIH4]ITMREF(nolign-1);[M:SIH1]BPCORD
                                  If fstat Raz [F:ITU] : Endif
                              Endif
                              #----- Contrôle que l'unité est présente dans l'article ou article-client -----#
                              If !find([M:SIH4]SAU(nolign-1),[F:ITM]STU,[F:ITM]SAU,[F:ITM]PCU,[F:ITU]SAU,[F:ITU]PCU1,[F:ITU]PCU2)
                                  #----- Si ce n'est pas le cas, on remplace par l'unité de vente -----#
                                  [M:SIH4]SAU(nolign-1)=WSAU
                              Endif
                              #-----
                          Endif
     When "QTY"        :  If [F:XVLI]QTELIV<>0 [M]QTY(nolign-1)=[F:XVLI]QTELIV Endif
                          Gosub RECH_VACITM From SIXSQH : # Bug 47592
                          Gosub TRAIT_VACITM From SIXSQH
                          # Autoriser les factures et avoirs avec une qté à 0
                          If [M]QTY(nolign-1)=0 & [F:XVH0]TYPPIE<>"AC" [M]QTY(nolign-1)=1 Endif
     When "GROPRI"     :  If [F:XVLI]QTELIV=0 [M]QTY(nolign-1)=0 : [M]QTYSTU(nolign-1)=0 Endif
                          If [F:XVH0]TYPPIE<>"AC" : # V6
                              [M]GROPRI(nolign-1)=[F:XVLI]PRXUNI
                          Endif                   : # V6
                          Gosub CHARG_DISCRGNUM From SIXSQH
                          Gosub RAZ_DISCRGVAL From SIXSQH
     When "DISCRGVAL1" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "DISCRGVAL2" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "DISCRGVAL3" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "DISCRGVAL4" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "DISCRGVAL5" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "DISCRGVAL6" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "DISCRGVAL7" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "DISCRGVAL8" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "DISCRGVAL9" :  Gosub CHARG_DISCRGVAL From SIXSQH
     When "AMTLIN"     :  # V6 : Avoir en valeur
                          If [F:XVH0]TYPPIE="AC"
                              [M]AMTLIN(nolign-1)=[F:XVLI]PRXUNI
                          Endif
     When "CPRPRI"     :  If [F:XVH0]TYPPIE<>"AC" : # V6
                              [M]CPRPRI(nolign-1)=[F:XVLI]PRXVALFRS : # Bug 48023
                          Endif                   : # V6
                          Gosub TRAIT_NETPRI From SIXSQH
                          Gosub TRAIT_MNTLIN : # Bug 53138 : Alimenter les montants ligne
     When "REP1"       :  If [F:XVLI]CODREP<>""
                               [M]REP1(nolign-1)=func SIXFONCTION.SI_COR("XIREP",[F:XVLI]CODREP,"","")
                          Else
                               [M]REP1(nolign-1)=""
                          Endif
     When "REPRAT1"    :  If [M]REP1(nolign-1)<>"" [M]REPRAT1(nolign-1)=[F:XVLI]TAUCOM Endif

     When "CCE1"       :  Call SI_INICCE("XILPVANA",[F:XVLI]NUMORD,[F:XVLI]LETRLQ,[F:XVLI]NUMLIG,
&                             "[M:SIH4]CCE",nolign-1)  From SIXFONCTION
Endcase

# pour avoir le no. de la piece et la reference article dans l'erreur
#GCLE =[F:XVH0]TYPPIE+" "+[F:XVH0]NUMSER+[F:XVH0]NUMPIE
GCLE=mess(3,40,1)-num$([F:XVLI]NUMLIG)-mess(18,7,1)-[M]ITMREF(nolign-1)

Return

#------------------------------------------------------------------------
# AP_READ_DETAIL : Après chargement de la ligne dans l'écran
#                  (Après SAI_NBLIG)
#------------------------------------------------------------------------
$AP_READ_DETAIL

# Forcer LINTYP à 1 pour les composés
# G_LINTYP a évité la déclinaison de la nomenclature mais LINTYP reste positionné
[M]LINTYP(nolign-1)=1

# 58798 : Vérification des codes taxes
# Message alerte si Code TPF dans intégrale mais pas de code taxe2 dans X3 et inversement
#                si Code taxe additionnelle dans intégrale mais pas de code taxe3 dans X3 et inversement
If  ([F:XVLI]CODTPF>0 & [F:XVH0]ASJTPF="O"     & [M:SIH4]VAT2(nolign-1)="") |
&  (([F:XVLI]CODTPF=0 | [F:XVH0]ASJTPF<>"O")   & [M:SIH4]VAT2(nolign-1)<>"") |
&   ([F:XART]TAXADD="O" & [F:XVH0]ASJTAXADD="O"     & [M:SIH4]VAT3(nolign-1)="") |
&  (([F:XART]TAXADD<>"O" | [F:XVH0]ASJTAXADD<>"O")  & [M:SIH4]VAT3(nolign-1)<>"")
    Call ECR_TRACE (SI_MES(287)-num$(nolign)-":"-[M:SIH4]ITMREF(nolign-1)-":"-SI_MES(285),-1) From GESECRAN
    If ([F:XVLI]CODTPF>0 & [F:XVH0]ASJTPF="O"    & [M:SIH4]VAT2(nolign-1)="") |
&      (([F:XVLI]CODTPF=0 | [F:XVH0]ASJTPF<>"O") & [M:SIH4]VAT2(nolign-1)<>"")
        Call ECR_TRACE (SI_MES(39)+SI_MES(278)+":"+[F:XVH0]ASJTPF-SI_MES(283)+":"+num$([F:XVLI]CODTPF),-1) From GESECRAN
        Call ECR_TRACE (SI_MES(284)+"="+SI_MES(286)+":"+[M:SIH4]VACITM2(nolign-1)-SI_MES(283)+":"+[M:SIH4]VAT2(nolign-1),-1) From GESECRAN
    Endif
    If ([F:XART]TAXADD="O" & [F:XVH0]ASJTAXADD="O"     & [M:SIH4]VAT3(nolign-1)="") |
&      (([F:XART]TAXADD<>"O" | [F:XVH0]ASJTAXADD<>"O") & [M:SIH4]VAT3(nolign-1)<>"")
        Call ECR_TRACE (SI_MES(39)+SI_MES(279)+":"+[F:XVH0]ASJTAXADD-[F:XART]TAXADD,-1) From GESECRAN
        Call ECR_TRACE (SI_MES(284)+"="+SI_MES(286)+":"+[M:SIH4]VACITM3(nolign-1)-SI_MES(283)+":"+[M:SIH4]VAT3(nolign-1),-1) From GESECRAN
    Endif
Endif

Return

#------------------------------------------------------------------------
# MSK_VALORISATION specifique a reprise intégrale ( remplace le calcul )
#------------------------------------------------------------------------
$MSK_VALORISATION
GPE=1
[M:SIH0]INVCLCFLG=1

#-- Chargement du tableau des taxes
For JL=0 To [M:SIW0]NBVAT-1
   [M:SIHV]XVNOT(JL) = [M:SIW0]XVNOT(JL)
   [M:SIHV]XVSMI(JL) = [M:SIW0]XVSMI(JL)
   [M:SIHV]XVRAT(JL) = [M:SIW0]XVRAT(JL)
   [M:SIHV]XVAMT(JL) = [M:SIW0]XVAMT(JL)
   [M:SIHV]XVSUP(JL) = [M:SIW0]XVSUP(JL)
   [M:SIHV]XVATI(JL) = [M:SIW0]XVATI(JL)
   [M:SIHV]XVTAX(JL) = [M:SIW0]XVTAX(JL)
   [M:SIHV]XVTYP(JL) = [M:SIW0]XVTYP(JL)
   [M:SIHV]XVCHA(JL) = 1
   [M:SIHV]XVBAS(JL) = 1
   [M:SIHV]XVSMIP(JL)= [M:SIW0]XVSMI(JL)
Next JL
[M:SIHV]NBVAT=[M:SIW0]NBVAT

# -- chargement du tableau des elements de facturation
Raz JL1
For JL=0 To dim([M:SIW0]INVDTA)-1
   If [M:SIW0]DTANOT(JL)<>0
      [M:SIHV]XFNUM(JL1)    = [M:SIW0]INVDTA(JL)
      [M:SIHV]XFNOT(JL1)    = [M:SIW0]DTANOT(JL)
      [M:SIHV]XFSMI(JL1)    = [M:SIW0]DTANET(JL)
      [M:SIHV]XFRAT(JL1)    = [M:SIW0]DTAVATRAT(JL)
      [M:SIHV]XFVATAMT(JL1) = [M:SIW0]DTAVATAMT(JL)
      [M:SIHV]XFNOTP(JL1)   = [M:SIW0]DTANOT(JL)
      [M:SIHV]XFSMIP(JL1)   = [M:SIW0]DTANET(JL)
      [M:SIHV]XFDTAAMT(JL1) = [M:SIW0]INVDTAAMT(JL)
      [M:SIHV]XFTAX(JL1)    = [M:SIW0]DTAVAT(JL)
      [M:SIHV]AMTCOD(JL1)   = [M:SIW0]INVDTACOD(JL)
      [M:SIHV]DTANOT01(JL1)   = [M:SIW0]DTANOT(JL)    : # V6
      [M:SIHV]DTANET01(JL1)   = [M:SIW0]DTANET(JL)    : # V6
      [M:SIHV]DTAVAT01(JL1)   = [M:SIW0]DTAVAT(JL)    : # V6
      [M:SIHV]DTAVATMT01(JL1) = [M:SIW0]DTAVATAMT(JL) : # V6
      [M:SIHV]DTAVATRT01(JL1) = [M:SIW0]DTAVATRAT(JL) : # V6
      # Bug 53138 : Pour alimenter [F:SIH]AMTNOT et [F:SIH]AMTATI
      [M:SIHV]XFATI(JL1)   = [M:SIHV]XFNOT(JL1)+[M:SIHV]XFVATAMT(JL1)
      JL1 +=1
      [M:SIHV]NBFOOT +=1
   Endif
Next JL
# Bug 53138 : Pour alimenter [F:SIH]AMTNOT et [F:SIH]AMTATI
[M:SIHV]INVNOT = sum([M:SIHV]XVNOT)+sum([M:SIHV]XFNOT)
[M:SIHV]INVATI = sum([M:SIHV]XVATI)+sum([M:SIHV]XFATI)

[M:SIHV]DEVRPT1 = GLOCALDEV : [M:SIHV]DEVRPT2 = GLOCALDEV
If [M:SIH2]CUR<>GLOCALDEV
    # Bug 59031 : Ne pas arrondir le cours en fct de GDECRCU pour avoir les mêmes résultats qu'en V5
#    Local Decimal WCOURS : WCOURS=0 : If [M:SIH2]RAT1<>0 WCOURS=arr([M:SIH2]RAT2/[M:SIH2]RAT1, 10^-GDECRCU) : Endif
    Local Decimal WCOURS : WCOURS=0 : If [M:SIH2]RAT1<>0 WCOURS=[M:SIH2]RAT2/[M:SIH2]RAT1 : Endif
    Local Integer STAT
    Call COURMNT([M:SIH2]CUR,GLOCALDEV,GLOCALDEV,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,1,
&                [M:SIHV]INVNOT,[M:SIHV]INVNOTRPT,WCOURS,STAT) From TRTDEV
    Call COURMNT([M:SIH2]CUR,GLOCALDEV,GLOCALDEV,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,1,
&                [M:SIHV]INVATI,[M:SIHV]INVATIRPT,WCOURS,STAT) From TRTDEV
Else
    [M:SIHV]INVNOTRPT=[M:SIHV]INVNOT
    [M:SIHV]INVATIRPT=[M:SIHV]INVATI
Endif



Return

#------------------------------------------------------------------------
# INICRE specifique a reprise intégrale ( apres INICRE objet )
#------------------------------------------------------------------------
$INICRE
#-- Stockage des donnees adresse
Gosub SIADD From SIXSQH
#-- Stockage du no document Integrale
Gosub SINUM From SIXSQH
#-- Ecriture du texte entete et des textes lignes
Gosub SIWRKTXT From SIXSQH
#-- Stockage des sections analytiques des éléments de facturation
Gosub SIWRKSFICCE From SIXSQH : # V6
#-- Facture validee
[F:SIH]STA=3 : [F:SIV]INVSTA=3   : : # Bug 48170
Return

#------------------------------------------------------------------------
# Erreur lors du garnissage des ecrans facture
#------------------------------------------------------------------------
$ERREUR
If LERR=4
   GBIDC3=GBIDC3-mess(532,197,1)-[F:SGD]VCRNUM+"   "+mess(18,7,1)-[M:SQH2]ITMREF(nolign-1)
Endif
Return

#------------------------------------------------------------------------
# Tables mises a jour lors de la creation de la facture
# ( on est dans une transaction : en cas d'erreur positionner GOK )
#------------------------------------------------------------------------
$CREATION
#----- Mise à jour indicateur "traité" sur entête facture "Intégrale" -----#
# Bug 47682 : Maj du flag ssi on est pas en simulation
If find (GWLTEST,1,2)
#  Update [XVH0] Where NUMORD=[F:XVH0]NUMORD & LETRLQ=[F:XVH0]LETRLQ With FLGREP=2
  Local Integer WNUMORD : WNUMORD=[F:XVH0]NUMORD
  Local Char    WLETRLQ : WLETRLQ=[F:XVH0]LETRLQ
  Update [XVH0] Where NUMORD=WNUMORD & LETRLQ=WLETRLQ With FLGREP=2
Endif
#-----

# 58798 : Vérification du montant TTC
# Message alerte montant TTC dans intégrale différent montant TTC dans X3
If [M:SIHV]INVATI<>[F:XVH0]MNTTOTTTC
    Call ECR_TRACE (SI_MES(129),-1) From GESECRAN
Endif

Return

#########################################################################

#-------------------------------------------------------------------------------------
# Bug 53138 : Alimenter les champs BASTAXLIN1 2 3, AMTTAXLIN1 2 3, AMTNOTLIN AMTATILIN
#             Ces montants sont normalement alimentés par le calcul facture
#             Or le calcul facture n'est pas déclenché pour la migration intégrale
#-------------------------------------------------------------------------------------
# Traitement particulier pour les montants de la ligne    :
# -- > Les montants de la ligne facture ne sont alimentés que par le calcul facture
#      Pour la migration intégrale, le calcul facture n'est pas éxécuté,
#      Les montants lignes sont donc calculés içi à la main
#-------------------------------------------------------------------------------------
$TRAIT_MNTLIN
Local Char    WVAT (GLONVAT)
Local Decimal WRAT, WTAX


If [F:TCU]CUR<>[M:SIH0]CUR Read [TCU]TCU0=[M:SIH0]CUR Endif

If [M]VAT1(nolign-1)<>""
    Raz WRAT : WVAT=[M]VAT1(nolign-1) : Gosub LEC_VAT
    If [F:TVT]VAT<>"" WRAT=[F:TRA]VATRAT Endif
    If dim([F:TRA]VATEXEFLG)>0 & [F:TRA]VATEXEFLG=2 WRAT = 0 : Endif
    [M]BASTAXLIN1(nolign-1)=[F:XVLI]MNTHT
    Call RNDTVA([F:XVLI]MNTHT,WRAT,[F:TCU]CURRND,WTAX) From SUBTVT
    [M]AMTTAXLIN1(nolign-1)=WTAX
Endif
If [M]VAT2(nolign-1)<>""
    Raz WRAT : WVAT=[M]VAT2(nolign-1) : Gosub LEC_VAT
    If [F:TVT]VAT<>"" WRAT=[F:TRA]VATRAT Endif
    If dim([F:TRA]VATEXEFLG)>0 & [F:TRA]VATEXEFLG=2 WRAT = 0 : Endif
    [M]BASTAXLIN2(nolign-1)=[F:XVLI]MNTHT
    Call RNDTVA([F:XVLI]MNTHT,WRAT,[F:TCU]CURRND,WTAX) From SUBTVT
    [M]AMTTAXLIN2(nolign-1)=WTAX
Endif
If [M]VAT3(nolign-1)<>""
    Raz WRAT : WVAT=[M]VAT3(nolign-1) : Gosub LEC_VAT
    If [F:TVT]VAT<>"" WRAT=[F:TRA]VATRAT Endif
    If dim([F:TRA]VATEXEFLG)>0 & [F:TRA]VATEXEFLG=2 WRAT = 0 : Endif
    [M]BASTAXLIN3(nolign-1)=[F:XVLI]MNTHT
    Call RNDTVA([F:XVLI]MNTHT,WRAT,[F:TCU]CURRND,WTAX) From SUBTVT
    [M]AMTTAXLIN3(nolign-1)=WTAX
Endif

[M]AMTNOTLIN(nolign-1)=[F:XVLI]MNTHT
[M]AMTATILIN(nolign-1)=[F:XVLI]MNTHT+[M]AMTTAXLIN1(nolign-1)+[M]AMTTAXLIN2(nolign-1)+[M]AMTTAXLIN3(nolign-1)

Return


#------------------------------------------------------------------------
$LEC_VAT
Local Integer WRET :#--CPO 71937
Gosub QUEL_VATDAT

Raz [F:TRA]

#--CPO 71937 TVT et multi-lég
Call LEC_TVT_LEG(GCURLEG,WVAT,WRET) From TRTLECLEG
If WRET : Raz [F:TVT] : Return : Endif
#If [F:TVT]VAT<>WVAT
#   Read [F:TVT]TVT0=WVAT
#   If fstat : Raz [F:TVT] : Return : Endif
#Endif
#--/CPO

#--CPO 71937 TRA et multi-lèg
#Filter [TRA] Where CPY=GSOCIETE & VAT=WVAT & STRDAT<=GBIDA1
Filter [TRA] Where CPY=GSOCIETE & VAT=WVAT & STRDAT<=GBIDA1 & LEG=[F:TVT]LEG
Read [TRA]TRA0 Last
If fstat>2
  #Filter [TRA] Where CPY="" & VAT=WVAT & STRDAT<=GBIDA1
  Filter [TRA] Where CPY="" & VAT=WVAT & STRDAT<=GBIDA1 & LEG=[F:TVT]LEG
  Read [TRA]TRA0 Last
# Aucun taxe n'est applicable
  If fstat>2 : Filter [TRA] : Return : Endif
Endif
#--/CPO

Filter [TRA]
Return

#------------------------------------------------------------------------
# Date d'application de la taxe pour les avoirs sur facture
$QUEL_VATDAT
GBIDA1=[M:SIH0]INVDAT
If [M:SIH0]INVTYP=2
   If dim([M:SIH2]VATDAT)>0 & [M:SIH2]VATDAT<>[0/0/0]
      GBIDA1=[M:SIH2]VATDAT
   Endif
Endif
Return
