#<AdxTL>@(#)12.0.0.0 $Revision$
#######################################################################
## INTEGAWM  Intégration des Modèles de données
#######################################################################
$INTEG
Call ECR_TRACE(string$(70,"#"),0) From GESECRAN
Call ECR_TRACE("Mise à jour des Modèles de données",0) From GESECRAN

Gosub OUVRE

For [SAWM]AWM0 Where MODELE<GXX
 OBJET = [F:SAWM]MODELE
 OKCOP = 1
 Call OKCOP([F:SAWM]MODULE,[F:SAWM]CODACT,OKCOP) From INTEGSUB
 If OKCOP
  Call ECR_TRACE(mess(77,145,1)-"AWM"-OBJET,0) From GESECRAN
  Gosub COPIE
 Else
  Call ECR_TRACE(mess(78,145,1)-"AWM"-OBJET,0) From GESECRAN
 Endif
Next

For [AWM]AWM0 Where MODULE=1 & MODELE<GXX
 OBJET = [F:SAWM]MODELE
 Read [SAWM]AWM0 = [F:AWM]MODELE
 Call OKSUP(PRODUIT,fstat,[F:AWM]CODACT,[F:SAWM]MODULE,[F:SAWM]CODACT,OKSUP) From INTEGSUB
 If OKSUP
  Gosub SUPPRIME
 Endif
Next

Call ECR_TRACE(string$(70,"#"),0) From GESECRAN
Gosub FERME
Return

#-------------------------------------------------------------#
$OUVRE
Local File AWRKLNK [SAWM]
Local File AWRKTAB [SAWK]
Local File ATEXTE  [SATX]
Local File ACTIV   [SACV]
Local File =DOSSIER+".AWRKLNK"  [AWM]
Local File =DOSSIER+".AWRKTAB"  [AWK]
Local File =DOSSIER+".ATEXTE"   [ATX]
Local File =DOSSIER+".ACTIV"    [ACV]
Return

$FERME
Close Local File [SAWM] , [SATX] , [SACV]  , [SAWK]
Close Local File [AWM]  , [ATX]  , [ACV] , [AWK]
Return

#-------------------------------------------------------------#
$COPIE
If TEST : Return : Endif
Read [AWM]AWM0= OBJET
If !fstat
 Call VERF_MODULE([F:SAWM]MODULE,[F:AWM]MODULE,TYPPRO,OKCOP) From INTEGSUB
Endif
If !OKCOP
 Call ECR_TRACE(func AFNC.MES2(mess(76,145,1),"AWM"-OBJET,LIBMOD([F:AWM]MODULE)),1) From GESECRAN
 Return
Endif
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [AWM]
 Read [AWM]AWM0= OBJET
 If fstat
  WACTIV = ""
  Gosub TETE
  If GOK<1 : Goto AB_TR1 : Endif
  Write [AWM]
 Else
  WACTIV = [F:AWM]CODACT
  Gosub TETE
  If GOK<1 : Goto AB_TR1 : Endif
  Rewrite [AWM]
 Endif
 If fstat
  GOK = 0 : Call FSTA("AWM") From GLOCK : Goto AB_TR1
 Endif
 Delete [AWK] Where MODELE=OBJET
 If fstat=1
  GOK = -1 : GLOCK = "$AWRKTAB"-OBJET : Goto ROLL_TR1
 Endif
 For [SAWK]AWK0 Where MODELE = OBJET
  [F:AWK] = [F:SAWK]
  Write [AWK]
  If fstat
   GOK = 0 : Call FSTA("AWK") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#-------------------------------------------------------------#
$TETE
[F:AWM] = [F:SAWM]
Call MODULE([F:SAWM]MODULE,TYPPRO,[F:AWM]MODULE) From INTEGSUB
Call ACTIV([F:AWM]CODACT,WACTIV) From INTEGSUB
Call TEXTE(DOSSIER,[F:AWM]INTITMOD) From INTEGSUB
Return

#-------------------------------------------------------------#
$SUPPRIME
Call ECR_TRACE(mess(2,24,1)-"AWM"-OBJET,0) From GESECRAN
If TEST : Return : Endif
Call DEBTRANS From GLOCK
Gosub TR2
Return

$TR2
GOK = 1
Trbegin [AWM]
 Delete [AWM] Where MODELE=OBJET
 If fstat=1
  GOK = -1 : GLOCK = "$AWRKLNK"-OBJET : Goto ROLL_TR2
 Endif
 Delete [AWK] Where MODELE=OBJET
 If fstat=1
  GOK = -1 : GLOCK = "$AWRKTAB"-OBJET : Goto ROLL_TR2
 Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

