#<AdxTL>@(#)10.0.0.0 $Revision$
########################################################################
# SUBPQHA             TRAITEMENT des appels d'offres                   #
# suite SUBPQH                                                         #
# -------------------------------------------------------------------- #
#                                                           HN 11/2002 #
# Traitement des actions "Gosub" de l'objet "PQH"                      #
# Les traitements sur champ "Call" se trouvent dans le SUBPQH          #
########################################################################

$DEFTRANS
#--------------------------------------------------------#
# Avant lecture des transactions de saisie disponibles : #
# Si GFLAG est renseigné la transaction est déja choisie #
# par le menu. Vérifier si elle est valide               #
#--------------------------------------------------------#
Local Shortint OUVFICFLG
If !clalev([F:PTR])  Local File PURTRS [PTR] : Endif
If GFLAG<>""
  Read [PTR] PTR0=1;GFLAG
  If fstat | [F:PTR]ENAFLG=1 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  If [F:PTR]ACSCOD<>"" & GPROFIL<>GSUPER
    If !clalev([F:ACC])  Local File ACCES  [ACC] : OUVFICFLG=1 : Endif
    Read [ACC] CODACC=GUSER;[F:PTR]ACSCOD
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG=1  Close Local File [ACC] : Raz OUVFICFLG : Endif
Return

$VARIANTE
#---------------------------------------#
# Après lecture de chaque transaction : #
# La transaction est-elle valide ?      #
# VARCOD contient le code transaction.  #
# Mettre OK à zéro si non valide.       #
#---------------------------------------#
Read [PTR] PTR0=1;VARCOD
If fstat | [F:PTR]ENAFLG=1 OK=0 : Endif
Return

$SETTRANS
#-------------------------------------#
# Après sélection de la transaction : #
# GFLAG = code transaction choisie    #
#-------------------------------------#
If clalev ([F:PTR])=0  Local File PURTRS [PTR] : Endif
Read [PTR] PTR0=1;GFLAG : If fstat Raz [F:PTR] : Endif

#MAE, le 30/01/08, GRP_SITE
GGRPFCY = [F:PTR]GFY
Return

$FILTRE
#--------------------------------------------------------#
# Action filtre : repositionnement du fichier par défaut #
#--------------------------------------------------------#
Default File [PQH]
Return

$AV_IMPRIME
#-----------------------------------------------#
# Avant impression : Chargement nom du document #
#-----------------------------------------------#
If [F:PTR]PTRTYP<>1 | [F:PTR]PTRNUM<>GPTRNUM  : # Relecture transaction si nécessaire
   Read [PTR] PTR0=1;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
#----- Si document renseigné (écran ou transaction), prendre celui-la -----#
If [M:PQH1]DOCNAM(0)<>""
  [L]AREPORT=[M:PQH1]DOCNAM(0)
Elsif [F:PTR]DOCNAM<>""
  [L]AREPORT=[F:PTR]DOCNAM
Endif
Return

$AP_IMPRIME
#---------------------------------------------------------------#
# Apres une impression il faut etre sur d'etre sur le bon enreg #
#---------------------------------------------------------------#
Raz [L]AREPORT
Gosub RELIT From GOBJSUB
Return

$OUVRE
Raz GSOC_ACTIVE
#---------------#
# A l'ouverture #
#---------------#
Local Shortint NOL, WPICK, NBDA
Local Integer  I, J, K, L
Local Char     WPWOCRIT(120)
Local Char     TBPSNUM(GLONBPS)(dim([M:PQH1]BPSNUM)-1)      : # SVG Tableau des fournisseurs
Local Shortint SVGNBFOUMAX, SAVNBLIG, SAVLIGFOU, SAVNOLIGN
#----- Variables locales pour gestion picking liste de gauche -----#
Local  Char    WNUM   (GLONPSH)                             : # Numéro de DA
Local  Char    WBPSNUM(GLONBPS)                             : # Numéro fournisseur
Local  Char    WITMREF(GLONITM)
Local  Integer WLIN, WRET
Local Decimal  WQTY
# Issue X3-65722 - 2018-03-05 by SR :
Local Char WCRITERE(240)
Global Integer GPQH_VERROU  : # Sauvegarde du verrou de l'objet
#-----
If !clalev([M:AD60]) Local Mask ADRBPR   [AD60] : Endif : # Masque adresse fournisseur
If !clalev([M:ASLW]) Local Mask ASELOBJ  [ASLW] : Raz [M:ASLW] : Endif : # Masque sélection objet BPS
If !clalev([M:ASLO]) Local Mask ASELOBJ  [ASLO] : Raz [M:ASLO] : Endif : # Masque sélection objet BPS
If !clalev([M:PCPW]) Local Mask PCRITPSD [PCPW] : Raz [M:PCPW] : Endif
#-----
If !clalev([F:MVS])  Local File BPSUPPMVT  [MVS] : Endif
If !clalev([F:TCY])  Local File TABCOUNTRY [TCY] : Endif
If !clalev([F:POS])  Local File POSCOD     [POS] : Endif
#----- Effacement fichier de travail -----#
Gosub EFFAC_PWRKPF  From SUBPQHA : If OK=0 Return : Endif
Gosub EFFAC_PWRKPWO From SUBPQHA : If OK=0 Return : Endif
#---------------------------------------------------------------------#
# Dans EXEFNC si pas de site par défaut pour le module concerné       #
# GFCYDEF(0) = premier site de la table sites (modif Beinat 15/12/99) #
# FAUX, il faut toujours avoir GFCYDEF(0) = site par défaut du module #
# même si ce site par défaut est vide !                               #
#---------------------------------------------------------------------#
GFCYDEF(0)=GFCYDEF(6)
#-----------------------------------------------------------------#
# Choix transaction, ouverture masques écrans, lecture paramètres #
#-----------------------------------------------------------------#
Local Char    CODE(3)
Local Integer RETOUR
#-------------------------------#
# Sauvegarde variables globales #
#-------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
GCONSDIA=0 : # Rend saisissable les écrans avec abréviation [DIA]
GPTRNUM=[F:PTR]PTRNUM
#------------------------------------#
# Récupération des paramètres Achats #
#------------------------------------#
GFCY=GFCYDEF(6)
Call GETFCYDEF(GFCY,"[F:FCY]PURFLG=2") From TRTX3
Gosub CHARG_PARAM
If GMESSAGE<>""  OK=0 : Return : Endif
#-----
Gosub DECLARE From TABLEAUX
GORITITCOL=1
Return

$OUVRE_BOITE
#-------------------------------#
# Après ouverture de la fenêtre #
#-------------------------------#
#----- Chargement des noms des Currbox de chaque tiroir -----#
Global Char     GBOXPB1(10), GBOXPR1(10)
GBOXPB1="GAU_CHE"+num$(find("PB1",OBJLIS(1..8))) : # Picking des fournisseur
GBOXPR1="GAU_CHE"+num$(find("PR1",OBJLIS(1..8))) : # Picking des DA
#----- Affichage entêtes de colonne variables -----# bug superviseur
#If !GIMPORT
#  Local Char BASPAG(10) : BASPAG="NBLIG" : Gosub TIT_COL From ="W1WE1"+GPTRNUM+"1"
#Endif
Return

$SETBOUT
#-------------------------------------------------------------------------#
# Activation / désactivation des menus (ToolBar) et boutons (bas d'écran) #
#-------------------------------------------------------------------------#
#---------------------------------------------------------------#
# A  : Menu texte                                     Action    #
#      AF : Texte entête                              ACLOB     #
#      AG : Texte pied                                ACLOB     #
# B  : Menu Option                                              #
#      BH : Critères de picking fournisseur           ASELOBJ   #
#      BI : Critères de picking DA                    ASELOBJ   #
#      BJ : Transaction (visu)                        VISUPTA   #
#      BN : Traçabilité pièces                        CONSPIA   #
#---------------------------------------------------------------#
GPQH_VERROU = VERROU : # Sauvegarde du verrou de l'objet
If GREP="C" | GREP="D" | [M:PQH1]PQHNUM<>""
  CHMEN+="FG"
Endif
#-------------------------------#
# Activation menu "Transaction" #
#-------------------------------#
CHMEN+="J"
If GPQH_VERROU | GREP="C"
 CHMEN+="HI"
Endif
If !find(GREP,"C","D") and !find("CONSPIA",GNAVIG(1..GPILNAV)) Then CHMEN += "N" Endif # SYMEU 09/12/2008 : branchement traçabilité pièces
#----- Suppression du bouton : # Code -----#
Call VIREBOUT(CHAINE,"H") From GOBJET
#----- Si flag réponse positionné, suppression du bouton d'annulation -----#
If CLECUR
  If [M:PQH1]WRSPNBR <> 0 : Call VIREBOUT(CHAINE,"A") From GOBJET : Endif
Endif
#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
Gosub SET_BOUT_SPE From GSAISIE
Return


$EXEACT
Return


$AVANTBOUT
#-----------------------------------#
# Avant exécution des boutons       #
#-----------------------------------#
# F = Saisie du texte entete        #
# G = Saisie du texte pied          #
# H = Critères picking fournisseurs #
# I = Critères picking DA           #
# J = Transaction                   #
#-----------------------------------#
Case BOUT
    When "H"  : Call AVBOUT_CRITBPS
Endcase
Return


Subprog AVBOUT_CRITBPS
#---------------------------#
# Avant critère fournisseur #
#---------------------------#
Local Mask ASELOBJ [ASL]
If [M:ASL]OBJ="PQH"
  [M:ASLO]=[M:ASL]
Endif
[M:ASL]=[M:ASLW]
End


$EXEBOUT
Return


$STATUT
#-------------------------------------------#
# Après exécution des boutons de la ToolBar #
# F = Texte entête                          #
# G = Texte pied                            #
# H = Critères fournisseurs                 #
# I = Critères DA                           #
#-------------------------------------------#
Case BOUT
    When "F"     : Gosub APRESBOUT_TEXTE
    When "G"     : Gosub APRESBOUT_TEXTE
    When "H"     : Call APBOUT_CRITBPS : If !GIMPORT  Gosub TIROIR : Endif
    When "I"     : Gosub APRESBOUT_CRITPSD From SUBPQHA
Endcase
Return


$APRESBOUT_TEXTE
#----------------------------------#
# Texte entête et pied de commande #
#----------------------------------#
If mkstat=4 & GREP="" : # Texte modifié
  Gosub ENTRE_MODIF From GOBJSUB
Endif
#----- Affichage icone texte -----#
If !GIMPORT
  If GREP="" & ([M:PQH1]TEX1<>"" | [M:PQH1]TEX2<>"")
    Call SET_IMAGE(4)   From GESECRAN
  Else
    Call RESET_IMAGE(4) From GESECRAN
  Endif
Endif
Return


Subprog APBOUT_CRITBPS
#-------------------------------------------------#
# Positionnement du filtre de picking fournisseur #
#-------------------------------------------------#
Local Mask ASELOBJ [ASL]
[M:ASLW]=[M:ASL]
[M:ASL] =[M:ASLO]
If parse([M:PCPW]FILBPS)  Raz [M:PCPW]FILBPS : End : Endif
If !instr(1,[M:PCPW]FILBPS,"=") & !instr(1,[M:PCPW]FILBPS,">") & !instr(1,[M:PCPW]FILBPS,"<")
  Raz [M:PCPW]FILBPS
Endif
End


$APRESBOUT_CRITPSD
#----------------------------------------#
# Positionnement du filtre de picking DA #
#----------------------------------------#
If !GIMPORT Gosub TIROIR : Endif
Return


$FILGAUCHE
# Issue X3-65722 - 2018-03-05 by SR : Section complètement revue pour :
#Remplissage de FILGAUSUP via ADDCRIT
#Utilisation de CRMUTIL150 pour récupérer les rôles
#----------------------------------------------#
# Filtrer les enregistrements listes de gauche #
#----------------------------------------------#
Raz FILGAUSUP, IFILGAUSUP
GBIDI2=1
If GREP<>"C"
  GBIDC2="M": GFCY=[M:PQH1]PQHFCY : Gosub AUTORIS_OPT From CONTX3
Endif
If (GREP="C" | GREP="D" | [M:PQH1]PQHNUM<>"") & [M:PQH1]PQHFCY<>"" & GBIDI2=1
  If currbox=GBOXPB1
    WCRITERE="[F:BPS]ENAFLG=2"
    If [M:PCPW]FILBPS<>"" WCRITERE+= "& "+ [M:PCPW]FILBPS : Endif
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE(FILGAUSUP,IFILGAUSUP,"BPS") From CRMUTIL150
  Elsif currbox=GBOXPR1
    WCRITERE="[F:FCY]LEGCPY = GSOCIETE & [F:PSH]CLEFLG<>2"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    If [M:PCPW]WPSHNUM<>""
        WCRITERE="pat([F:PSH]PSHNUM,[M:PCPW]WPSHNUM)<>0"
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    If GPQHBUY=2 & GBUYFLT=2
      WCRITERE="([F:PSD]LINBUY=[M:PQH1]REQUSR | [F:PSD]LINBUY='')"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    If [M:PCPW]WDEM=2
      WCRITERE="[F:PSH]REQUSR=[M:PQH1]REQUSR"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    If [M:PCPW]WPEC<>2
      WCRITERE="[F:PSD]NBAOF=0"
    Else
      WCRITERE="[F:PSD]NBAOF<>0"
    Endif
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    WCRITERE="[F:PSD]LINCLEFLG<>2"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    If [M:PCPW]WAPPFLG=2
      WCRITERE="[F:PSD]LINAPPFLG>2"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    If [M:PCPW]WBPSNUM<>""
       WCRITERE="(pat([F:PSD]BPSNUM,[M:PCPW]WBPSNUM)<>0"
       WCRITERE+=" | [F:PSD]BPSNUM='')"
       Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    If [M:PCPW]WITMREF<>""
        WCRITERE="pat([F:PSD]ITMREF,[M:PCPW]WITMREF)<>0"
        Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    If [M:PCPW]WDATFIN<>[0/0/0]
      If [M:PCPW]CHXDAT=1
        WCRITERE=' EXTORDDAT<=[M:PCPW]WDATFIN'
      Else
        WCRITERE='EXTRCPDAT<=[M:PCPW]WDATFIN'
      Endif
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    # Issue X3-85951 - 2018-05-28 by MUARN : ajout PJT
    If [M:PCPW]WPJT <> ""
      WCRITERE='[F:PSD]PJT=[M:PCPW]WPJT'
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    # End issue X3-85951
    Call AJOUTE_CONDITION_ROLE(FILGAUSUP,IFILGAUSUP,"PSH") From CRMUTIL150
  Endif
Elsif currbox=GBOXPB1
  CRITERE="[F:BPS]BPSNUM=''"
  Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
Elsif currbox=GBOXPR1
  WCRITERE="[F:PSD]PSHNUM=''"
  Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
Endif
Return


$AP_FILGAUCHE
#---------------------------------------------------------#
# Après pagination avant ou arrière d'une liste de gauche #
#---------------------------------------------------------#
If !find(currbox,GBOXPB1,GBOXPR1) Return : Endif
WPICK=2 : Gosub ACTUALIS_MARQUAGE
Return


$TIROIR
#---------------------------------------------------#
# Click sur un tiroir                               #
# Désormais entièrement géré par l'objet :          #
# - le remplissage                                  #
# - et l'actualisation (boules bleues)              #
#   par l'appel à la suite de l'action AP_FILGAUCHE #
# ------------------------------------------------- #
# Autres appels par l'applicatif dans les cas       #
# d'abandon, d'après création, d'après modif ...etc #
#---------------------------------------------------#
If !find(currbox,GBOXPB1, GBOXPR1)  Return : Endif
#-----
ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
If find(currbox,GBOXPB1,GBOXPR1)
  WPICK=2 : Gosub ACTUALIS_MARQUAGE
Endif
Return


$DEB_PICK
#---------------#
# Début picking #
#---------------#
If !find(currbox,GBOXPB1,GBOXPR1) Return : Endif
If currbox=GBOXPB1
  SAVNBLIG=[M:PQH1]NBFOU
Elsif currbox=GBOXPR1
  SAVNBLIG=[M:PQH1]NBLIG
Endif
WRET=0
Return


$PICKE
#----------------------#
# Nouvel élément pické #
#----------------------#
If !find(currbox,GBOXPB1, GBOXPR1) Return : Endif
If REP=""
  If !CLECUR | !VERROU | !ACTMOD | GCONSULT  OK=0 : Return : Endif
Endif
Case currbox
  When GBOXPB1 : Gosub PICKE_BPS
  When GBOXPR1 : Gosub PICKE_PSD
Endcase
Return


$DEPICK
#------------------------#
# Nouvel élément dépické #
#------------------------#
If !find(currbox,GBOXPB1,GBOXPR1) Return : Endif
Case currbox
  When GBOXPB1 : Gosub DEPICK_BPS
  When GBOXPR1 : Gosub DEPICK_PSD
Endcase
Return


$FIN_PICK
#-------------#
# Fin picking #
#-------------#
If REP=""
  If !VERROU
    GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return
  Elsif !CLECUR | !ACTMOD | GCONSULT
    GMESSAGE=mess(9,123,1)  : GERR=1 : OK=0 : Return
  Endif
Endif
Gosub APRES_PICKING
Return


$APRES_MODIF
#------------------------------------#
# Après modification de chaque champ #
#------------------------------------#
Return


$ACTUALIS_MARQUAGE
#---------------------------------------------------------------#
# Actualisation des éléments "pickés" dans les listes de gauche #
# WPICK : 0 = On ne fait rien                                   #
#         1 = Enlever le marquage des éléments "pickés"         #
#         2 = Marquer les éléments "pickés"                     #
#---------------------------------------------------------------#
If currbox=GBOXPB1
  If [M:PQH1]NBFOU>0
    For I=0 To [M:PQH1]NBFOU-1
      Gosub MARQUAGE_LIGNE
    Next I
  Endif
Elsif currbox=GBOXPR1
  If [M:PQH1]NBLIG>0
    For I=0 To [M:PQH1]NBLIG-1
      Gosub MARQUAGE_LIGNE
    Next I
  Endif
Endif
Return

$MARQUAGE_LIGNE
#--------------------------------------------------------------#
# Actualisation d'un élément "pické" dans les listes de gauche #
# WPICK : 0 = On ne fait rien                                  #
#         1 = Enlever le marquage de l'élément "pické"         #
#         2 = Marquer l'élément "pické"                        #
#     I : indice de la ligne du tableau à traiter              #
#--------------------------------------------------------------#
#----- Si appel depuis Subprog (C_NBLIG.. etc) les variables locales n'existent pas !
If dim(FILGAUSUP)<1
  #----- Variables locales superviseur -----#
  Local Integer FILTREG : FILTREG=1
  Local Integer INDCUR  : INDCUR=1
  Local Char    FILTSUP(240), FILROLE(250) , FILSUITE(250), CRITERE(250)
  Local Char    FILGAUSUP(240)(0..3)
  Local Char    WINPROG(GLONADC), ACTION(20) : WINPROG="WGOPQH"
  Local Char    HINTLIS(10)(0..8)
  #-----
  HINTLIS(val(right$(GBOXPB1,8)))="BPS0"
  HINTLIS(val(right$(GBOXPR1,8)))="PSD0"
  #----- Variables locales pour gestion picking liste de gauche -----#
  Local Char     WNUM(GLONVCR), WBPSNUM(GLONBPS)
  Local Integer  WLIN, SAVLIGFOU
  Local Shortint J, K
Endif
#-----
If !find(currbox,GBOXPB1, GBOXPR1) Return : Endif
Case currbox
  When GBOXPB1 : J=WPICK
                 WBPSNUM=[M:PQH1]BPSNUM(I)
                 Read [BPS]BPS0=WBPSNUM       : If fstat Raz [F:BPS] : Endif
                 Read [BPR]BPR0=WBPSNUM       : If fstat Raz [F:BPR] : Endif
                 Read [TMD]TMD0= [F:BPS]MDL   : If fstat Raz [F:TMD] : Endif
                 Case WPICK
                   When 1 : Gosub DEPICK From GOBJSUB
                   When 2 : Gosub REPICK From GOBJSUB
                 Endcase
                 WPICK=J
  When GBOXPR1 : J=WPICK
                 For [PWO]PWO0 Where PRONUM=adxuid(2)
&                                  & CODFNC="PQH"
&                                  & LINNUM=[M:PQH1]PQHLIN(I)
                   If WPICK=2 & [F:PWO]QTYSTU=0 : WPICK=0
                   Elsif [F:PWO]WIPNUM<>""
                     WNUM=[F:PWO]WIPNUM
                     WLIN=[F:PWO]PSDLIN
                     Read [PSD]PSD0=WNUM;WLIN     : If fstat Raz [F:PSD] : Endif
                     Read [PSH]PSH0=[F:PSD]PSHNUM : If fstat Raz [F:PSH] : Endif
                     Read [FCY]FCY0=[F:PSD]PSHFCY : If fstat Raz [F:FCY] : Endif
                     Read [ITM]ITM0=[F:PSD]ITMREF : If fstat Raz [F:ITM] : Endif
                   Else
                     WPICK=0
                   Endif
                   Case WPICK
                   When 1 : Gosub DEPICK From GOBJSUB
                   When 2 : Gosub REPICK From GOBJSUB
                   Endcase
                   WPICK=J
                 Next
Endcase
WPICK=J
Return

#----------------------------#
# Sélection d'un fournisseur #
#----------------------------#
$PICKE_BPS
WBPSNUM=[F:BPS]BPSNUM
#----- Lecture du fournisseur -----#
Read [BPS] BPS0=WBPSNUM      : If fstat Raz [F:BPS] : Endif
Read [BPR] BPR0=WBPSNUM      : If fstat Raz [F:BPR] : Endif
Read [TMD] TMD0= [F:BPS]MDL  : If fstat Raz [F:TMD] : Endif
If !evalue(FILGAUSUP)  OK=0 : Return : Endif
Call CTLBPRCPY([F:BPS]BPSNUM,num$([M:PQH1]PQHFCY)) From CONTX3
If mkstat
  OK=0 : Return
Endif
#----- Avertissement si fournisseur en litige -----#
If [F:BPS]DOUFLG>1
  OK=2 : Call AVERTIR([F:BPS]BPSNUM-mess(4,194,1),OK) From GESECRAN
  If OK<>2  OK=0 : Return  Else  OK=1 : Endif
Endif
#-----
I=[M:PQH1]NBFOU
nolign=I+1
WBPSNUM=[F:BPS]BPSNUM
[M:PQH1]BPSNUM(nolign-1)=[F:BPS]BPSNUM
Gosub CHARG_LIG_BPS
nolign=I+1 : [M:PQH1]NBFOU+=1
status=73  : Call APRES_NBFOU From SUBPQH
Affzo [PQH1]BPSNUM(nolign-1)
Return


$DEPICK_BPS
#------------------------------#
# Déselection d'un fournisseur #
#------------------------------#
WBPSNUM=[F:BPS]BPSNUM
#----- Lecture du fournisseur -----#
Read [BPS] BPS0=WBPSNUM
If fstat Raz [F:BPS] : Endif
Raz J
While J<[M:PQH1]NBFOU
  K=find([F:BPS]BPSNUM,[M:PQH1]BPSNUM(J..[M:PQH1]NBFOU-1))
  I=J+(K-1)
  If K=0
    J=[M:PQH1]NBFOU
  Elsif [M:PQH1]BPSNUM(I)=[F:BPS]BPSNUM
    nolign=I+1 : status=65
    Call C_NBFOU From SUBPQH
    If mkstat
      OK=0 : Return
    Endif
    Call AVANT_NBFOU From SUBPQH
    If !mkstat
      Dela I,1,[M:PQH1]NBFOU-1 [M:PQH1]NBFOU : [M:PQH1]NBFOU-=1
    Endif
    J+=K : K=0
  Else
    J+=K : K=0
  Endif
Wend
Return

#--------------------#
# Sélection d'une DA #
#--------------------#
$PICKE_PSD
WNUM=[F:PSD]PSHNUM : WLIN=[F:PSD]PSDLIN
#----- Lecture ligne DA sélectionnée si nécessaire -----#
Read [PSD] PSD0=WNUM;WLIN     : If fstat Raz [F:PSD] : Endif
Read [PSH] PSH0=[F:PSD]PSHNUM : If fstat Raz [F:PSH] : Endif
Read [FCY] FCY0=[F:PSD]PSHFCY : If fstat Raz [F:FCY] : Endif
Read [ITM] ITM0=[F:PSD]ITMREF : If fstat Raz [F:ITM] : Endif
If !evalue(FILGAUSUP)  OK=0 : Return : Endif
If WRET=0
  #----- Date de réception prévue inférieure à la date limite de l'appel d'offre ! -----#
  If [F:PSD]EXTRCPDAT<[M:PQH1]RSPDEA
    OK=2 : Call AVERTIR(mess(308,194,1),OK) From GESECRAN
    If OK=1  WRET=1 : OK=0 : Return : Endif
    WRET=2
  Endif
Elsif WRET=1
  OK=0 : Return
Endif
Raz I,K,J
If [M:PCPW]WRGP=2   : # Regroupement
  While J<[M:PQH1]NBLIG
    K=find([F:ITM]ITMREF,[M:PQH1]ITMREF(J..[M:PQH1]NBLIG-1))
    I=(J+(K-1))
    If K<>0 & [M:PQH1]LINRSPNBR(I)<>0
      J+=K : K=0
    Else
      J=[M:PQH1]NBLIG
    Endif
  Wend
Endif
#-- Si K =0 en regroupement c'est qu'on a pas trouvé de ligne sur laquelle ajoutée
#-- Si K<>0 I contient le numéro de ligne sur laquelle il faut ajouter
If (K<=0 & [M:PCPW]WRGP=2) | [M:PCPW]WRGP=1
  I=[M:PQH1]NBLIG
  nolign=I+1
  K=1 : # Ajout nouvelle ligne
  Raz [M:PQH1]UPDFLG(nolign-1)
Else
  Raz K
Endif
nolign=I+1
SAVNBLIG=nolign
NOL=nolign-1
[L]WITMREF=[F:PSD]ITMREF
#----- Contrôle code acheteur sur article ou article-site -----#
Call CTLITMBUY([L]WITMREF,[M:PQH1]REQUSR,mkstat) From TRTACHCTL1
If mkstat=0
  Gosub CHARG_LIG_ART From SUBPQHA
Else
  GMESSAGE=[F:PSD]ITMREF-GMESSAGE
  Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE
  OK=0 : Return
Endif
If K=1
  I=[M:PQH1]NBLIG
  nolign=I+1
  status=0  : Call LINNUM("PQDLIN") From TABLEAUX
  [M:PQH1]NBLIG+=1
  status=71 : Call APRES_NBLIG From SUBPQH
Endif
Gosub CREMOD_PWO
#PICFLG=1
#---- Vérification que le fournisseur n'est pas déja dans la liste
If [F:PSD]BPSNUM<>""
  [L]WBPSNUM=[F:PSD]BPSNUM
  If !find([L]WBPSNUM,[M:PQH1]BPSNUM(0..[M:PQH1]NBFOU-1))
    Raz [F:BPS] : [F:BPS]BPSNUM=[F:PSD]BPSNUM
    [L]SAVLIGFOU=[M:PQH1]NBFOU
    Gosub PICKE_BPS From SUBPQHA
  Endif
Endif
nolign=SAVNBLIG
Return


$DEPICK_PSD
#----------------------#
# Déselection d'une DA #
#----------------------#
WNUM=[F:PSD]PSHNUM : WLIN=[F:PSD]PSDLIN
Read [PSD] PSD0=WNUM;WLIN     : If fstat Raz [F:PSD] : Endif
#----- Recherche lignes à supprimer -----#
Raz J, K
K=find([F:PSD]PSHNUM,[M:PQH1]PSHNUM(J..[M:PQH1]NBLIG-1))
If K<>0 & [M:PQH1]PSDLIN(K-1)<>[F:PSD]PSDLIN
  K=0
Endif
If K=0
  For [PWO]PWO0 Where PRONUM=adxuid(2)
&                   & CODFNC="PQH"
&                   & WIPTYP=2
&                   & WIPNUM=[F:PSD]PSHNUM
&                   & PSDLIN=[F:PSD]PSDLIN
&                   & QTYPUU<>0
    K=find([F:PWO]LINNUM,[M:PQH1]PQHLIN(J..[M:PQH1]NBLIG-1))
    If K<>0 Break : Endif
  Next
Endif
If K=0 Return : Endif
I=K-1
If K<>0
  If [M:PQH1]LINRSPNBR(I) <> 0
    GMESSAGE = mess(37,194,1)
    GERR=1 : OK=0 : Return
  Endif
  WPWOCRIT ="PRONUM=adxuid(2) & CODFNC='PQH'"
  WPWOCRIT-="& LINNUM=[M:PQH1]PQHLIN(I) & WIPNUM=[F:PSD]PSHNUM & PSDLIN=[F:PSD]PSDLIN"
  Gosub MAJZERO_PWO
  Gosub MAJ_LIG_ART  From SUBPQHA
  If [M:PQH1]QTYPUU(I)=0
    nolign=I+1
    status=65 : Call AVANT_NBLIG From SUBPQH
    Dela I,1,[M:PQH1]NBLIG-1 [M:PQH1]NBLIG : [M:PQH1]NBLIG-=1
  Endif
Endif
Return


$VERIF_PSD
#-------------------------------------------#
# Vérification si nouvellement pické ou pas #
#-------------------------------------------#
OK=1
For [PSA]PSA0 Where PSHNUM=[F:PSD]PSHNUM & PSDLIN=[F:PSD]PSDLIN & PQHNUM=[M:PQH1]PQHNUM
  OK=0
  If OK=0 : Break : Endif
Next
Return


$APRES_PICKING
#------------------------------------------------------------#
# L'après picking se fait à chaque sélection                 #
#------------------------------------------------------------#
If currbox=GBOXPB1
  Affzo [PQH1]15
  [M:PQH1]BPSNBR=[M:PQH1]NBFOU
  Affzo [PQH1]BPSNBR
Endif
If currbox=GBOXPR1
  Affzo [PQH1]10
  If SAVLIGFOU<>[M:PQH1]NBFOU
    Affzo [PQH1]15
    [M:PQH1]BPSNBR=[M:PQH1]NBFOU
    Affzo [PQH1]BPSNBR
  Endif
Endif
Gosub GRISAGE
Return

$GRISAGE
#-----------------------------------------------------#
# Traitement du grisage et dégrisage des champs écran #
#-----------------------------------------------------#
If [M:PQH1]NBLIG=0 & GREP="C"
  If GNBAUZ>1 Actzo [PQH1]PQHFCY : Endif
Else
  If GNBAUZ>1 Diszo [PQH1]PQHFCY : Endif
Endif
Return

$DEFLIG
#----------------------------------#
# Définition du fichier des lignes #
# -------------------------------- #
# Critère lecture     (CRIT)       #
# Nom du fichier      (FICLIG)     #
# Abréviation fichier (ABLIG)      #
# Zone numéro ligne   (ZONLIG)     #
#----------------------------------#
Default File [PQD]
Default Mask [PQH1]
CRIT = 'PQHNUM = "' + [M:PQH1]PQHNUM+'"'
FICLIG = "PQUOTATD" : ABLIG = "PQD"
ZONLIG = "PQDLIN"
Return

$INICRE_LIG
#----------------------------#
# Avant le Write de la ligne #
#----------------------------#
[F:PQD]PQHNUM = [F:PQH]PQHNUM
[F:PQD]PQHFCY = [F:PQH]PQHFCY
[F:PQD]CPY    = GSOCIETE
#----- Création ou duplication du texte ligne -----#
Gosub CHARG_TEXT_LIGNE
Return

$INIMOD_LIG
#-----------------------------------------------------------------------#
# Avant le Rewrite de la ligne : Création ou duplication du texte ligne #
#-----------------------------------------------------------------------#
Gosub CHARG_TEXT_LIGNE
Return

$VALLIG
#----------------------------------------------------------------------#
# SIGN vaut +1 en création ou modification                             #
#      vaut -1 en annulation (TRTLIG="A") ou avant modif. (TRTLIG="M") #
# en modif on passe d'abord avec SIGN=-1                               #
#----------------------------------------------------------------------#
Case SIGN
  When  1 : Gosub CRELIG
  When -1 : Gosub SUPLIG
  When Default
Endcase
Return

$CRELIG
#----------------#
# Création ligne #
#----------------#
#----- Ecriture des sections de la ligne appel d'offre -----#
Call ENREG_ACCCCE(nolign-1,"","[M:PQH1]LINDSP","[M:PQH1]CCE","PQD",
&                 0,[F:PQD]PQHNUM,[F:PQD]PQDLIN,0,"",TRTLIG) From TRTX3CPT
If GOK<1  Return : Endif
#-----
If [F:ITM]ITMREF<>[M:PQH1]ITMREF(nolign-1)
  Read [ITM] ITM0=[M:PQH1]ITMREF(nolign-1) : If fstat  Raz [F:ITM] : Endif
Endif
#-- On récupère le numéro de ligne dans la classe [M] car on va s'en servir
[M:PQH1]PQDLIN(nolign-1)=[F:PQD]PQDLIN
Return

$SUPLIG
#-------------------#
# Suppression ligne #
#-------------------#
If TRTLIG="A"
  #----- Suppression comptes et sections de la ligne de commande -----#
  Call ENREG_ACCCCE(0,"","","","PQD",0,[F:PQD]PQHNUM,[F:PQD]PQDLIN,0,"","A") From TRTX3CPT
  If GOK<1  Return : Endif
  #----- Suppression du texte ligne si nécessaire -----#
  If left$([F:PQD]LINTEX,3)="PQD"
    Local Integer WRET
    Call SUP_CLOB([F:PQD]LINTEX,WRET) From TRTX3TEX
  Endif
Elsif TRTLIG="M"
  #----- Cas particulier où l'on modifie le texte en le supprimant -----#
  If [M:PQH1]LINTEX(nolign-1)="" & left$([F:PQD]LINTEX,3)="PQD"
    Call SUP_CLOB([F:PQD]LINTEX,WRET) From TRTX3TEX
  Endif
Endif
#-----
If GREP="A"  Gosub SUP_PSA : Endif
Return

$RAZCRE
#------------------------------------------------------#
# Valeurs par défaut et initialisations avant création #
#------------------------------------------------------#
Gosub EFFAC_PWRKPF  From SUBPQHA  : # Suppression fichier de travail fournisseur
Gosub EFFAC_PWRKPWO From SUBPQHA  : # Suppression fichier de travail DA en compte
# Effacement des masques de critères fournisseur, critères DA, adresses fourn.
# Effacement zone PQHCOU : repèrage ligne ayant des besoins
Raz [M:PQH1]PQHCOU,[M:ASLW],[M:PCPW],[M:AD60]
#-- Par défaut dans les critères de picking besoins
#-- Da signée à oui, besoins pris en compte à oui, regroupement à oui
[M:PCPW]WDEM=1
[M:PCPW]WAPPFLG=2
[M:PCPW]WPEC=1
[M:PCPW]WRGP=2
[M:PCPW]CHXDAT=2
Actzo [PQH1]1-99
GFCY = GFCYDEF(6)
Call GETFCYDEF(GFCY,"[F:FCY]PURFLG=2") From TRTX3
If GNBAUZ=1 & GFCY<>""  Diszo [PQH1]PQHFCY : Endif
#-----
Gosub CHARG_PARAM
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL From SUBPQHA
#-----
Call GLOBVAR(GFCY) From WWGLOBACH
If GPQHBUY=0  GPQHBUY=1 : Endif
Chgtzn [M:PQH1]REQUSR With mess(GPQHBUY,562,1)
[M:PQH1]PQHFCY = GFCY
[M:PQH1]PQHDAT = date$
[M:PQH1]RSPDEA = date$
[M:PQH1]REQUSR = GUSER
Affzo [PQH1]1-99
#----- Gestion des textes -----#
Call RAZ_CLOB From ACLOB : GCONSDIA=0 : # Rend saisissable le texte
Raz [M:PQH1]TEX1,[M:PQH1]TEX2
Call RESET_IMAGE (4) From GESECRAN
#----- Mise à jour des listes de gauche picking -----#
If !GIMPORT
  Gosub TIROIR
Endif
Return

$RAZDUP
#---------------------------------------------------------------------#
# Valeurs par défaut, initialisations et sauvegarde avant duplication #
#---------------------------------------------------------------------#
Gosub CHARG_PWF From SUBPQHA
#-----------------------------------------------------#
# Effacement entête : RSPNBR nombre réponse           #
# Effacement lignes articles : RSPNBR nombre réponses #
# Effacement lignes fourniss : RSPNBR nombre réponses #
#                              FUPDAT date relance    #
#                              FUPNBR nombre réponses #
#-----------------------------------------------------#
Local Shortint I
Raz [M:PQH1]PQHNUM
#----- Gestion des textes -----#
Call RAZ_CLOB From ACLOB : GCONSDIA=0 : # Rend saisissable le texte
If left$([M:PQH1]TEX1,3)="PQH"
  Call DUP_CLOB("PQH",[M:PQH1]TEX1,WRET) From TRTX3TEX
  If WRET<1  Raz [M:PQH1]TEX1 : Endif
Endif
If left$([M:PQH1]TEX2,3)="PQH"
  Call DUP_CLOB("PQH",[M:PQH1]TEX2,WRET) From TRTX3TEX
  If WRET<1  Raz [M:PQH1]TEX2 : Endif
Endif
For I=0 To [M:PQH1]NBLIG-1
  If left$([M:PQH1]LINTEX(I),3)="PQD"
    Call DUP_CLOB("PQD",[M:PQH1]LINTEX(I),WRET) From TRTX3TEX
    If WRET<1  Raz [M:PQH1]LINTEX(I) : Endif
  Endif
  Raz [M:PQH1]CREFLG(I),[M:PQH1]UPDFLG(I),[M:PQH1]LINRSPNBR(I)
Next I
#-----
For I=0 To [M:PQH1]NBFOU-1
  Raz [M:PQH1]RSPNBR(I),[M:PQH1]FUPDAT(I),[M:PQH1]FUPNBR(I)
Next I
#----- Le demandeur ne peut être modifié que s'il n'y a pas de filtre -----#
If GPQHBUY<2 | GBUYFLT<2
  [M:PQH1]REQUSR=GUSER : Actzo [PQH1]REQUSR : Affzo [PQH1]REQUSR
Endif
#----- Mise à jour des listes de gauche picking -----#
If !GIMPORT Gosub TIROIR : Endif
Return

$LIENS
#--------------------------------------------#
# Chargement GFCY : Site de la facture       #
# Récupération des paramètres ACHATS         #
#--------------------------------------------#
Raz [M:PQH1]PQHCOU, [M:PCPW], [M:ASLW]
[M:PQH1]WRSPNBR=[F:PQH]RSPNBR
[M:PCPW]WDEM=1
[M:PCPW]WAPPFLG=2
[M:PCPW]WPEC=1
[M:PCPW]WRGP=2
[M:PCPW]CHXDAT=2
If GFCY <> [F:PQH]PQHFCY
  GFCY = [F:PQH]PQHFCY
  Gosub CHARG_PARAM
Endif
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL From SUBPQHA
#-----
Gosub EFFAC_PWRKPWO From SUBPQHA
Actzo [PQH1]1-99
Diszo [PQH1]PQHFCY
Gosub LIENS From TABLEAUX
Gosub CHARG_FOU
If [M:PQH1]PQHCOU<>0
  Gosub CHARG_PWO From SUBPQHA
Endif
Affzo [PQH1]15 : Actzo [PQH1]NBFOU : # Activation tableau fournisseurs
For I=0 To [M:PQH1]NBFOU-1
  Diszo [M:PQH1]BPSNUM(I) : # Désactivation 1er champ de la ligne du tableau fournisseur
Next I
If GPQHBUY<2 | GBUYFLT<2 Actzo [PQH1]REQUSR Else Diszo [PQH1]REQUSR : Endif
#-----
If GFONC1="GESPQH"  Call RAZ_CLOB From ACLOB : Endif
GCONSDIA=0
#----- Affichage icone texte -----#
If [M:PQH1]TEX1<>"" | [M:PQH1]TEX2<>""
  Call SET_IMAGE (4)   From GESECRAN
Else
  Call RESET_IMAGE (4) From GESECRAN
Endif
#-----
If GHISTO  GCONSDIA=2 : Endif
#----- Mise à jour des listes de gauche picking -----#
If !GIMPORT Gosub TIROIR : Endif
Return


$LIENS_LIG
#------------------------------------------------#
# Après lecture ligne [F:PQD] remplissage du PWO #
#------------------------------------------------#
If [M:PQH1]STU(nolign-1)="" & [M:PQH1]RETQTYSTU(nolign-1)<>0
  If [F:ITM]ITMREF<>[M:PQH1]ITMREF(nolign-1)
    Read [ITM]ITM0=[M:PQH1]ITMREF(nolign-1)
    If fstat Raz [F:ITM] : Endif
  Endif
  [M:PQH1]STU(nolign-1)=[F:ITM]STU
Endif
If [M:PQH1]PSHNUM(nolign-1)<>""
  [M:PQH1]PQHCOU+=1
  [M:PQH1]PQHLIN(nolign-1)=[M:PQH1]PQHCOU
Endif
#----- Chargement sections analytiques -----#
Call CHARG_ACCCCE(nolign-1,"","","[M:PQH1]CCE",
&                "PQD",0,[F:PQD]PQHNUM,[F:PQD]PQDLIN,0,"") From TRTX3CPT
Return


$VERIF
#--------------------------#
# Vérification en création #
# et modification          #
#--------------------------#
If [M:PQH1]NBLIG = 0
  GERR = 1 : GMESSAGE = mess(61,199,1)
  OK = 0 : Return
Endif
If [M:PQH1]NBFOU = 0
  GERR = 1 : GMESSAGE = mess(57,194,1)
  OK = 0
Endif
Return

$INICRE
#---------------------------#
# Chargement avant le Write #
#---------------------------#
Local Integer STAT
If GMANCOU<>2 | (GMANCOU=2 & vireblc([M:PQH1]PQHNUM,2)="")
  Call NUMERO(GCODNUM,[M:PQH1]PQHFCY,[M:PQH1]PQHDAT,"",[F:PQH]PQHNUM,STAT) From SUBANM
  If GOK<0
    Return
  Elsif GOK<1 | STAT<>0
    GOK=0 : GERR=1 : GMESSAGE=GCODNUM-mess(60,199,1)
    Return
  Endif
  [M:PQH1]PQHNUM = [F:PQH]PQHNUM
Endif
[F:PQH]LINNBR = [M:PQH1]NBLIG
[F:PQH]BPSNBR = [M:PQH1]BPSNBR
[F:PQH]RSPNBR = [M:PQH1]WRSPNBR
[F:PQH]CPY    = GSOCIETE
#-----
If GREP="D"
  For I=0 To [M:PQH1]NBFOU-1  Raz [M:PQH1]CREFLG1(I) : Next I
Endif
#---------------------------------------------------#
# Création ou duplication des textes entête et pied #
#---------------------------------------------------#
Gosub CHARG_TEXT_ENTETE
Return

$CREATION
#-------------------------#
# Après Write de l'entête #
#-------------------------#
Gosub CREATION From TABLEAUX
If GOK < 1 : Return : Endif
#Création ou modif de la table des fournisseurs sélectionnés
Gosub CREMODFOU
Gosub CREMODPSA
Return

$APRES_CRE
#-------------------------#
# Affichage numéro de AOF #
#-------------------------#
Gosub EFFAC_PWRKPF  From SUBPQHA
Gosub EFFAC_PWRKPWO From SUBPQHA
Affzo [PQH1]PQHNUM
#----- Impression bon d'AOF -----#
If [F:PTR]PTRTYP<>1 | [F:PTR]PTRNUM<>GPTRNUM : # Relecture transaction si nécessaire
   Read [PTR] PTR0=1;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
If[F:PTR]DOCFLG=2
   Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
   Gosub SET_CLE From GOBJSUB :   CLECUR=1   : # SET_CLE parce que création
   #-----
   If [M:PQH1]DOCNAM(0)<>""
     [L]REPORT1=[M:PQH1]DOCNAM(0)
   Elsif [F:PTR]DOCNAM<>""
     [L]REPORT1=[F:PTR]DOCNAM
   Endif
   #-----
   Call ETAT([L]REPORT1,"GESPQH",TBPAR,TBVAL) From ETAT
Endif
   Gosub RELIT From GOBJSUB
Return

$AVANT_MODFIC
#---------------------------------------------------------------#
# Avant chargement des nouvelles valeurs dans la classe [F:PQH] #
#---------------------------------------------------------------#
#----- Cas particulier où l'on modifie le texte en le supprimant -----#
If [M:PQH1]TEX1="" & left$([F:PQH]TEX1,3)="PQH"
  Call SUP_CLOB([F:PQH]TEX1,WRET) From TRTX3TEX
Endif
If [M:PQH1]TEX2="" & left$([F:PQH]TEX2,3)="PQH"
  Call SUP_CLOB([F:PQH]TEX2,WRET) From TRTX3TEX
Endif
Return

$INIMOD
#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
[F:PQH]LINNBR = [M:PQH1]NBLIG
[F:PQH]BPSNBR = [M:PQH1]BPSNBR
[F:PQH]RSPNBR = [M:PQH1]WRSPNBR
#---------------------------------------------------#
# Création ou duplication des textes entête et pied #
#---------------------------------------------------#
Gosub CHARG_TEXT_ENTETE
Return

$MODIF
#-------------------------------#
# Après Rewrite de l'entête AOF #
#-------------------------------#
Gosub MODIF From TABLEAUX
If GOK < 1 : Return : Endif
For I=0 To [L]SVGNBFOUMAX-1
 K= find([L]TBPSNUM(I),[M:PQH1]BPSNUM(0..[M:PQH1]NBFOU-1))
 #-- Le fournisseur y était et n'y est plus
 If K=0
   Delete [PQF] Where [F:PQF]PQHNUM = [F:PQH]PQHNUM & [F:PQF]BPSNUM=[L]TBPSNUM(I)
   If fstat : GOK = 0 : Break : Endif
 Elsif K<>0
   #--- Le fournisseur y était mais a été supprimé
   If [M:PQH1]CREFLG1(K-1)=0
     Delete [F:PQF] Where [F:PQF]PQHNUM = [F:PQH]PQHNUM & [F:PQF]BPSNUM=[L]TBPSNUM(I)
     If fstat : GOK = 0 : Break : Endif
   Endif
 Endif
Next I
If GOK<1 : Return : Endif
For [PWO]PWO0 Where PRONUM=adxuid(2) & CODFNC="PQH" & QTYSTU=0
  K=find([F:PWO]LINNUM,[M:PQH1]PQHLIN(0..[M:PQH1]NBLIG-1))
  If K=0
    Delete [PSA] Where PSHNUM=[F:PWO]WIPNUM & PSDLIN=[F:PWO]PSDLIN & PQHNUM=[M:PQH1]PQHNUM
    If fstat GOK=0 : Call FSTA("PSA") From GLOCK : Break : Endif
    Update [PSD] Where PSHNUM=[F:PWO]WIPNUM & PSDLIN=[F:PWO]PSDLIN With NBAOF-=1
    If fstat GOK=0 : Call FSTA("PSD") From GLOCK : Break : Endif
  Endif
Next
If GOK<1 : Return : Endif
#2eme phase : Création ou modification des enregistrements
Gosub CREMODFOU
Gosub CREMODPSA
Return

$APRES_MOD
#----------------------------------#
# Après modification : réaffichage #
#----------------------------------#
Gosub EFFAC_PWRKPF  From SUBPQHA     : # Effacement fichiers de travail
Gosub EFFAC_PWRKPWO From SUBPQHA     : # Effacement fichiers de travail
Gosub LIENS From SUBPQHA
If !GIMPORT  Affzo [PQH1]10-15 : Endif

Return

$ANNULE
#--------------------------------------#
# Supression des textes entête et pied #
#--------------------------------------#
If left$([F:PQH]TEX1,3)="PQH"
  Call SUP_CLOB([F:PQH]TEX1,GBIDI1) From TRTX3TEX
Endif
If left$([F:PQH]TEX2,3)="PQH"
  Call SUP_CLOB([F:PQH]TEX2,GBIDI1) From TRTX3TEX
Endif
#----- Annulation des lignes article
Gosub ANNULE From TABLEAUX
If GOK < 1 : Return : Endif
#Annulation des lignes fournisseurs sélectionnés
Delete [F:PQF] Where PQHNUM = [M:PQH1]PQHNUM
If fstat = 1
  GOK = -1
  GLOCK = "$PQUOTATF"
  Return
Endif
Return

$AP_ANNULE
#------------------#
# Après annulation #
#------------------#
Local Shortint SAVGOK : SAVGOK=GOK  : # Sauvegarde de GOK
Gosub EFFAC_PWRKPF  From SUBPQHA    : # Effacement fichiers de travail
Gosub EFFAC_PWRKPWO From SUBPQHA    : # Effacement fichiers de travail
#----- Mise à jour des listes de gauche picking (reporté en FIN_ACTION) -----#
GOK=SAVGOK                          : # Restitution de GOK
Return


$FIN_ACTION
#--------------------#
# Après toute action #
#--------------------#
If REPONSE=GSTAANU
  #----- Mise à jour des listes de gauche picking après une annulation -----#
  If !GIMPORT & [M:PQH1]PQHFCY=""  Raz CRITERE : Gosub TIROIR : Endif
Endif
Return


$ABANDON
#----------------------------------------------------#
# Abandon création et modification par l'utilisateur #
#----------------------------------------------------#
Local Shortint SAVGOK : SAVGOK=GOK  : # Sauvegarde de GOK
Gosub EFFAC_PWRKPF  From SUBPQHA    : # Effacement fichiers de travail
Gosub EFFAC_PWRKPWO From SUBPQHA    : # Effacement fichiers de travail
Gosub SUPPRESS_TEX  From SUBPQHA    : # Effacement des textes
If GREP="C" & !GIMPORT & BOUT="A" Raz [M:PQH1] :  Actzo [PQH1] : Gosub TIROIR : Endif
If GREP="C" & !GIMPORT : Raz [M:PQH1]PQHNUM : Endif
Raz [M:PCPW], [M:ASLW]
GOK=SAVGOK                          : # Restitution de GOK
Return

$FERME
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Raz [M:ASLO], [M:ASLW]
Gosub EFFAC_PWRKPF  From SUBPQHA : # Effacement fichiers de travail
Gosub EFFAC_PWRKPWO From SUBPQHA : # Effacement fichiers de travail
#-----
Gosub REST_GLOB From TRTX3GLOB
#-----
If clalev([M:AD60])  Close Local Mask [AD60] : Endif
#-----
If GFONC1="GESPQH"
  Raz GMENBOUT, GCONSDIA, GORITITCOL
Endif
#----- Effacement icone texte -----#
Call RESET_IMAGE (4) From GESECRAN
#-----
If dim(GPQH_VERROU)>0  Kill GPQH_VERROU, GBOXPB1, GBOXPR1 : Endif
Return


########################### Gosub ####################################
$CREMODFOU
#---------------------------------------------------#
#Création de la table des fournisseurs sélectionnés #
#---------------------------------------------------#
Call GETFIN([F:PQH]PQHFCY,GFINRSP) From DEVSUB
If GFINRSP=""  GFINRSP=[F:PQH]PQHFCY : Endif
For I=0 To [M:PQH1]NBFOU-1
  If [M:PQH1]CREFLG1(I)=0
    #-----
    nolign=I+1 : [F:PQF]=[M:PQH1] : # Transclasse !!
    #-----
    [F:PQF]BPSNUM   = [M:PQH1]BPSNUM(I)
    [F:PQF]BPAADD   = [M:PQH1]BPAADD(I)
    [F:PQF]BPRNAM(0)= [M:PQH1]BPSNAM(I)
    [F:PQF]FUPDAT   = [M:PQH1]FUPDAT(I)
    [F:PQF]FUPNBR   = [M:PQH1]FUPNBR(I)
    [F:PQF]RSPNBR   = [M:PQH1]RSPNBR(I)
    [F:PQF]PRNFLG   = max([M:PQH1]PRNFLG(I),1)
    [F:PQF]PQHNUM   = [M:PQH1]PQHNUM
    [F:PQF]PQHFCY   = [M:PQH1]PQHFCY
    [F:PQF]COPNBR   = [M:PQH1]COPNBR(I)
    [F:PQF]CREDAT   = date$
    [F:PQF]CREUSR   = GUSER
    [F:PQF]CPY      = GSOCIETE
    Readlock [PWF] PWF0=adxuid(2);[M:PQH1]BPSNUM(I)
    If fstat
      If GACTSAD=2 : # Stockage systématique de l'adresse !
        If [F:BPR]BPRNUM<>[F:PQF]BPSNUM
          Read [BPR] BPR0=[F:PQF]BPSNUM
          If fstat Raz [F:BPR] : Endif
        Endif
        If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:PQF]BPSNUM | [F:BPA]BPAADD<>[F:PQF]BPAADD
          Read [BPA] BPA0=1;[F:PQF]BPSNUM;[F:PQF]BPAADD
          If fstat Raz [F:BPA] : Endif
        Endif
        [F:PQF]BPRNAM(0)    = [F:BPR]BPRNAM(0)
        [F:PQF]BPRNAM(1)    = [F:BPR]BPRNAM(1)
        [F:PQF]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
        [F:PQF]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
        [F:PQF]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
        [F:PQF]CRY          = [F:BPA]CRY
        [F:PQF]CRYNAM       = [F:BPA]CRYNAM
        [F:PQF]SAT          = [F:BPA]SAT
        [F:PQF]POSCOD       = [F:BPA]POSCOD
        [F:PQF]CTY          = [F:BPA]CTY
      Else
        Raz [F:PQF]BPRNAM(1),[F:PQF]BPAADDLIG,[F:PQF]CRY,[F:PQF]CRYNAM,
&           [F:PQF]SAT,[F:PQF]POSCOD,[F:PQF]CTY
      Endif
    Else
      [F:PQF]=[F:PWF]
      [F:PQF]CREDAT=date$
      [F:PQF]CREUSR=GUSER
    Endif
    Write [PQF]
    If fstat : GOK=0 : Call FSTA("PQF") From GLOCK : Break : Endif
    #----- Mise à jour derniers mouvements fournisseurs -----#
    Call MAJENC_BPS([F:PQF]BPSNUM,1,[F:PQF]PQHFCY,GLOCALDEV,1,[F:PQH]PQHDAT,
&                   [F:PQH]PQHNUM,0,0,0) From TRTBPMVT
    #-----
  Else
    If [M:PQH1]UPDFLG1(I)=1  : # on a modifié l'adresse
      Readlock [PQF] PQF0=[M:PQH1]PQHNUM;[M:PQH1]BPSNUM(I)
      If !fstat
        Read [PWF] PWF0=adxuid(2);[M:PQH1]BPSNUM(I)
        If fstat
          [F:PQF]BPAADD=[M:PQH1]BPAADD(I)
          [F:PQF]UPDDAT=date$
          [F:PQF]UPDUSR=GUSER
          If GACTSAD=2 : # Stockage systématique de l'adresse !
            If [F:BPR]BPRNUM<>[F:PQF]BPSNUM
              Read [BPR] BPR0=[F:PQF]BPSNUM
              If fstat Raz [F:BPR] : Endif
            Endif
            If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:PQF]BPSNUM | [F:BPA]BPAADD<>[F:PQF]BPAADD
              Read [BPA] BPA0=1;[F:PQF]BPSNUM;[F:PQF]BPAADD
              If fstat Raz [F:BPA] : Endif
            Endif
            [F:PQF]BPRNAM(0)    = [F:BPR]BPRNAM(0)
            [F:PQF]BPRNAM(1)    = [F:BPR]BPRNAM(1)
            [F:PQF]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
            [F:PQF]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
            [F:PQF]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
            [F:PQF]CRY          = [F:BPA]CRY
            [F:PQF]CRYNAM       = [F:BPA]CRYNAM
            [F:PQF]SAT          = [F:BPA]SAT
            [F:PQF]POSCOD       = [F:BPA]POSCOD
            [F:PQF]CTY          = [F:BPA]CTY
          Else
            Raz [F:PQF]BPRNAM(1),[F:PQF]BPAADDLIG,[F:PQF]CRY,[F:PQF]CRYNAM,
&               [F:PQF]SAT,[F:PQF]POSCOD,[F:PQF]CTY
          Endif
        Else
          [F:PQF]=[F:PWF]
          [F:PQF]UPDDAT=date$
          [F:PQF]UPDUSR=GUSER
        Endif
        Rewrite [PQF]
        If fstat GOK=0 : Call FSTA("PQF") From GLOCK : Break : Endif
      Endif
    Endif
  Endif
Next I
Return

$CHARG_FOU
#-----------------------------------------#
# Chargement de la liste des fournisseurs #
#-----------------------------------------#
SAVNOLIGN=nolign
Default Mask [PQH1]
Raz I
For [PQF] PQF0 Where [PQF]PQHNUM=[F:PQH]PQHNUM
  [M:PQH1]BPSNUM(I) = [F:PQF]BPSNUM
  If [F:BPS]BPSNUM <> [M:PQH1]BPSNUM(I)
    Read [BPS]BPS0=[M:PQH1]BPSNUM(I)  : If fstat Raz [F:BPS] : Endif
  Endif
  If [F:BPR]BPRNUM <> [M:PQH1]BPSNUM(I)
    Read [BPR]BPR0=[M:PQH1]BPSNUM(I)  : If fstat Raz [F:BPR] : Endif
  Endif
  #-----
  nolign=I+1 : [M:PQH1]=[F:BPR] : [M:PQH1]=[F:BPS] : [M:PQH1]=[F:PQF] : # Transclasse !!
  #-----
  [M:PQH1]BPSNAM(I) = [F:PQF]BPRNAM(0)
  [M:PQH1]BPSTYP(I) = [F:BPS]BPSTYP
  [M:PQH1]BPAADD(I) = [F:PQF]BPAADD
  [M:PQH1]FUPDAT(I) = [F:PQF]FUPDAT
  [M:PQH1]FUPNBR(I) = [F:PQF]FUPNBR
  [M:PQH1]RSPNBR(I) = [F:PQF]RSPNBR
  [M:PQH1]PRNFLG(I) = [F:PQF]PRNFLG
  #----- Alimentation à partir du modèle d'édition du fournisseur -----#
  nolign=I+1 : Call ALI_PRTMOD("PQH1",7) From TRTX3
  #-----
  [M:PQH1]CREFLG1(I)= I+1
  [M:PQH1]UPDFLG1(I)= 0
  [L]TBPSNUM(I)=[F:PQF]BPSNUM
  I+=1
Next
[M:PQH1]NBFOU  = I
[L]SVGNBFOUMAX=[M:PQH1]NBFOU
[M:PQH1]BPSNBR = [F:PQH]BPSNBR
nolign=SAVNOLIGN
Return

$CHARG_PWO
#-------------------------------------------------#
# Chargement du ficher des besoins pris en compte #
#-------------------------------------------------#
Call DEBTRANS From GLOCK
$TR_CHARGPWO
  GOK=1
  Trbegin [PWO]
  Raz I
    For I=0 To [M:PQH1]NBLIG-1
      If [M:PQH1]PQHLIN(I)<>0
        For [PSA]PSA1 Where PQHNUM=[M:PQH1]PQHNUM & PQDLIN=[M:PQH1]PQDLIN(I)
          GOK=1
          Read [PWO]PWO0=adxuid(2);"PQH";[M:PQH1]PQHLIN(I);2;[F:PSA]PSHNUM;[F:PSA]PSDLIN
          If fstat
            [F:PWO]PRONUM=adxuid(2)
            [F:PWO]CODFNC="PQH"
            [F:PWO]LINNUM=[M:PQH1]PQHLIN(I)
            [F:PWO]PSDLIN=[F:PSA]PSDLIN
            [F:PWO]WIPSTA=2
            [F:PWO]WIPNUM=[F:PSA]PSHNUM
            [F:PWO]WIPTYP=2
            If [F:PSD]PSHNUM<>[F:PSA]PSHNUM | [F:PSD]PSDLIN<>[F:PSA]PSDLIN
              Read [PSD]PSD0=[F:PSA]PSHNUM;[F:PSA]PSDLIN : If fstat Raz [F:PSD] : Endif
            Endif
            [F:PWO]ITMREF=[F:PSD]ITMREF
            [F:PWO]PUU   =[F:PSA]PUU
            [F:PWO]QTYPUU=[F:PSA]QTYPUU
            [F:PWO]STU   =[F:PSA]STU
            [F:PWO]QTYSTU=[F:PSA]QTYSTU
            Write [PWO]
            If fstat GOK=0 : Call FSTA("PWO") From GLOCK : Break : Endif
          Endif
        Next
        If GOK=0 : Break : Endif
      Endif
    Next
    If GOK=0 : Goto AB_CHARGPWO : Endif
Commit
$FIN_CHARGPWO
Return

$AB_CHARGPWO
Rollback : Goto FIN_CHARGPWO
$ROLL_CHARGPWO
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_CHARGPWO : Endif : Goto FIN_CHARGPWO

$CHARG_PWF
#-----------------------------------------------------#
# Chargement du ficher des fournisseur en duplication #
#-----------------------------------------------------#
Call DEBTRANS From GLOCK
$TR_CHARGPWF
  GOK=1
  Trbegin [PWF]
  For [PQF]PQF0 Where PQHNUM=[M:PQH1]PQHNUM
    Raz [F:PWF]
    [F:PWF]=[F:PQF] : [F:PWF]PRONUM=adxuid(2)
    Write [PWF]
    If fstat GOK=0 : Call FSTA("PWF") From GLOCK : Break : Endif
  Next
  If GOK=0 : Goto AB_CHARGPWF : Endif
Commit
$FIN_CHARGPWF
Return

$AB_CHARGPWF
Rollback : Goto FIN_CHARGPWF
$ROLL_CHARGPWF
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_CHARGPWF : Endif : Goto FIN_CHARGPWF


$EFFAC_PWRKPF
#----------------------------------------------------#
# Effacement fichiers de travail                     #
#----------------------------------------------------#
Call DEBTRANS From GLOCK
$TR_EFFACPWF
GOK=1
Trbegin [PWF]
  Delete [PWF] Where PRONUM=adxuid(2)
  If fstat=1  GOK=-1 : OK=0 : GLOCK="$PWRKPQF"-num$(adxuid(2))
              Goto ROLL_EFFACPWF
  Elsif fstat GOK=0  : OK=0 : Call RSTA("PWF",num$(adxuid(2))) From GLOCK
              Goto AB_EFFACPWF
  Endif
Commit
Return
$AB_EFFACPWF
Rollback : Return
$ROLL_EFFACPWF
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_EFFACPWF : Endif : Return


$EFFAC_PWRKPWO
#----------------------------------------------------#
# Effacement fichiers de travail                     #
#----------------------------------------------------#
Call DEBTRANS From GLOCK
$TR_EFFACPWO
GOK=1
Trbegin [PWO]
  Delete [PWO] Where PRONUM=adxuid(2) & CODFNC="PQH"
  If fstat=1  GOK=-1 : OK=0 : GLOCK="$PWRKORDERS"-num$(adxuid(2))-"PQH"
              Goto ROLL_EFFACPWO
  Elsif fstat GOK=0  : OK=0 : Call RSTA("PWO",num$(adxuid(2))-"PQH") From GLOCK
              Goto AB_EFFACPWO
  Endif
Commit
Return
$AB_EFFACPWO
Rollback : Return
$ROLL_EFFACPWO
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_EFFACPWO : Endif : Return


$CHARG_LIG_ART
#---------------------------------#
# Chargement de la ligne article  #
# NOL doit exister et être chargé #
#---------------------------------#
If [F:PSD]PSHNUM<>"" & [F:PSD]PSDLIN<>0
  If [F:ITM]ITMREF<>[F:PSD]ITMREF
   Read [ITM]ITM0=[F:PSD]ITMREF : If fstat Raz [F:ITM] : Endif
  Endif
  Raz GBIDD1
  GBIDD1+=[F:PSD]QTYSTU
  GBIDD1-=[F:PSD]ORDQTYSTU
  [M:PQH1]RETQTYSTU(NOL)+=GBIDD1
  [M:PQH1]STU(NOL)       =[F:PSD]STU
  #--- Si sélection de la première DA on ramène infos de la DA
  #--- si la ligne n'a pas été modifiée
  If [M:PQH1]PSHNUM(NOL)=""
    If [M:PQH1]CREFLG(NOL)=0 & [M:PQH1]UPDFLG(NOL)=0
      [M:PQH1]ITMREF (NOL)= [F:PSD]ITMREF
      [M:PQH1]ITMDES (NOL)= [F:PSD]ITMDES
      [M:PQH1]PQDPJT (NOL)= [F:PSD]PJT
      [M:PQH1]RCPDAT (NOL)= [F:PSD]EXTRCPDAT
      [M:PQH1]ITMDES1(NOL)= [F:PSD]ITMDES1
      #----- Chargement sections analytiques -----#
      If [F:PSD]PSHNUM<>""
        Call CHARG_ACCCCE(NOL,"","","[M:PQH1]CCE",
&                      "PSD",0,[F:PSD]PSHNUM,[F:PSD]PSDLIN,0,"") From TRTX3CPT
      Endif
    Endif
    [M:PQH1]PQHCOU+=1
    [M:PQH1]PQHLIN(NOL)   =[M:PQH1]PQHCOU
    [M:PQH1]PSHNUM(NOL)   =[F:PSD]PSHNUM
    [M:PQH1]PSDLIN(NOL)   =[F:PSD]PSDLIN
  #--- Si sélection d'une seconde DA, on réinitialise uniquement en création
  Else
    [M:PQH1]PSHNUM(NOL)="$"
    [M:PQH1]PSDLIN(NOL)= 0
    If [M:PQH1]CREFLG(NOL)= 0 & [M:PQH1]UPDFLG(NOL)=0
      Raz [M:PQH1]PQDPJT(NOL)
      #-- On prend la date la plus petite
      If [F:PSD]EXTRCPDAT<[M:PQH1]RCPDAT(NOL)
        [M:PQH1]RCPDAT(NOL)=[F:PSD]EXTRCPDAT
      Endif
      #----- Chargement des désignations article -----#
      #Call CHARGE_ITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PQH1]ITMDES(NOL)) From TRTX3
      #If [M:PQH1]ITMDES(NOL)="" [M:PQH1]ITMDES(NOL)=[F:ITM]ITMDES1 : Endif
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PQH1]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
      #[M:PQH1]ITMDES1 (NOL) = [F:ITM]ITMDES1
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PQH1]ITMDES1(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129

      Gosub RAZ_CCE From SUBPQH
    Endif
    #-- En modif mettre updflg à jour
    If [M:PQH1]CREFLG(NOL)<>0
      [M:PQH1]UPDFLG(NOL)=1
    Endif
  Endif
    If [M:PQH1]PUU(NOL)=""
      [M:PQH1]PUU(NOL)=[F:ITM]PUU
      # Recalcul de la quantité en UA de l'article
      Call PCAL_QTY(GBIDD1,[M:PQH1]STU(NOL),GBIDD2,[F:ITM]PUU,
&                   [M:PQH1]ITMREF(NOL),"",1,GBIDD1)  From TRTACHQTE1
      [M:PQH1]QTYPUU(NOL)+=GBIDD2
    Else
      # Recalcul de la quantité en UA de l'article
      Call PCAL_QTY(GBIDD1,[M:PQH1]STU(NOL),GBIDD2,[M:PQH1]PUU(NOL),
&                   [M:PQH1]ITMREF(NOL),"",1,GBIDD1)  From TRTACHQTE1
      [M:PQH1]QTYPUU(NOL)+=GBIDD2
    Endif
Else
  Raz [M:PQH1]PQDPJT(NOL), [M:PQH1]QTYPUU(NOL)
  If [F:ITM]ITMREF<>VALEUR
    Read [ITM] ITM0=VALEUR : If fstat  Raz [F:ITM] : Endif
  Endif
  #----- Chargement des désignations article -----#
  #Call CHARGE_ITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PQH1]ITMDES(NOL)) From TRTX3
  #If [M:PQH1]ITMDES(NOL)=""  [M:PQH1]ITMDES(NOL)=[F:ITM]ITMDES1 : Endif
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PQH1]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  #[M:PQH1]ITMDES1(NOL)=[F:ITM]ITMDES1
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PQH1]ITMDES1(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129

  [M:PQH1]PUU(NOL)    =[F:ITM]PUU
  [M:PQH1]STU(NOL)    =[F:ITM]STU
  Affzo [PQH1]ITMDES(NOL), ITMDES1(NOL), PUU(NOL)
Endif
#----- Récupération du lien texte article -----#
[M:PQH1]LINTEX(NOL)=[F:ITM]PURTEX
Return

$CHARG_LIG_BPS
#------------------------------------#
# Chargement de la ligne fournisseur #
#------------------------------------#
If [F:BPS]BPSNUM <> WBPSNUM
  Read [BPS]BPS0=WBPSNUM : If fstat Raz [F:BPS] : Endif
Endif
If [F:BPR]BPRNUM <> WBPSNUM
  Read [BPR]BPR0=WBPSNUM : If fstat Raz [F:BPR] : Endif
Endif
#-----
[M:PQH1]=[F:BPR] : [M:PQH1]=[F:BPS] : # Transclasse !!
#-----
[M:PQH1]BPSNAM(nolign-1) = [F:BPS]BPSNAM
[M:PQH1]BPSTYP(nolign-1) = [F:BPS]BPSTYP
[M:PQH1]BPAADD(nolign-1) = [F:BPR]BPAADD
#----- Alimentation à partir du modèle d'édition du fournisseur -----#
Call ALI_PRTMOD("PQH1",7) From TRTX3
#-----
[M:PQH1]CREFLG1(nolign-1)= 0
[M:PQH1]BPSNBR+=1
Return


#---------------------------------#
# Duplication d'une ligne article #
#---------------------------------#
$COPIE_LIG
[M:PQH1]ITMREF    (J) = [M:PQH1]ITMREF (L)
[M:PQH1]ITMDES    (J) = [M:PQH1]ITMDES (L)
[M:PQH1]ITMDES1   (J) = [M:PQH1]ITMDES1 (L)
[M:PQH1]PQDPJT    (J) = [M:PQH1]PQDPJT (L)
[M:PQH1]PUU       (J) = [M:PQH1]PUU (L)
[M:PQH1]STU       (J) = [M:PQH1]STU (L)
[M:PQH1]QTYPUU    (J) = [M:PQH1]QTYPUU (L)
[M:PQH1]LTI       (J) = [M:PQH1]LTI (L)
[M:PQH1]RCPDAT    (J) = [M:PQH1]RCPDAT (L)
#----- Sections analytiques -----#
For K=1 To GNBDIE
  Assign "[M:PQH1]CCE"+num$(K)+"(J)" With evalue("[M:PQH1]CCE"+num$(K)+"(L)")
Next K
#----- Pas de besoin pris en compte
Raz [M:PQH1]PSHNUM(J), [M:PQH1]PSDLIN(J), [M:PQH1]RETQTYSTU(NOL), [M:PQH1]PQHLIN(J)
#----- Duplication du texte si nécessaire -----#
[M:PQH1]LINTEX(J)=[M:PQH1]LINTEX(L)
If left$([M:PQH1]LINTEX(J),3)="PQD"
  Call DUP_CLOB("PQD",[M:PQH1]LINTEX(J),GBIDI1) From TRTX3TEX
  If GBIDI1<1  Raz [M:PQH1]LINTEX(J) : Endif
Endif
Return


$SUPPRESS_TEX
#-----------------------------------------#
# Suppression des textes après un abandon #
#-----------------------------------------#
#----- Suppression texte entête et pied -----#
If GREP="D"
  If left$([M:PQH1]TEX1,3)="PQH"
    Call SUP_CLOB([M:PQH1]TEX1,GBIDI1) From TRTX3TEX
  Endif
  If left$([M:PQH1]TEX2,3)="PQH"
    Call SUP_CLOB([M:PQH1]TEX2,GBIDI1) From TRTX3TEX
  Endif
Endif
#----- Suppression des textes ligne -----#
For I=0 To [M:PQH1]NBLIG-1
  If left$([M:PQH1]LINTEX(I),3)="PQD" & [M:PQH1]CREFLG(I)=0
    Call SUP_CLOB([M:PQH1]LINTEX(I),GBIDI1) From TRTX3TEX
  Endif
Next I
#-----
Call RAZ_CLOB From ACLOB
Return


$CREMOD_PWO
#-----------------------------------#
# Création du fichier de travail    #
# de prise en compte                #
# NOL doit exister et être          #
# renseigné                         #
# lors du picking d'une besoin ou DA#
#-----------------------------------#
Call DEBTRANS From GLOCK
$TR_CREPWO
  GOK=1
  Trbegin [PWO]
  Readlock [PWO]PWO0=adxuid(2);"PQH";[M:PQH1]PQHLIN(NOL);2;[F:PSD]PSHNUM;[F:PSD]PSDLIN
 #-- Peut arriver si on dépick puis repick
  If !fstat
    [F:PWO]QTYPUU = [F:PSD]QTYPUU-[F:PSD]ORDQTYPUU
    [F:PWO]PUU    = [F:PSD]PUU
    [F:PWO]STU    = [F:PSD]STU
    Call PCAL_QTY([F:PWO]QTYPUU,[F:PWO]PUU,[F:PWO]QTYSTU,[F:PWO]STU,
&               [F:PWO]ITMREF,[F:PSD]BPSNUM,1,GBIDD1)  From TRTACHQTE1
    Rewrite [PWO]
    If fstat GOK=0 : Call FSTA("PWO") From GLOCK : Goto AB_CREPWO : Endif
  Else
    [F:PWO]PRONUM = adxuid(2)
    [F:PWO]CODFNC = "PQH"
    [F:PWO]LINNUM = [M:PQH1]PQHLIN(NOL)
    [F:PWO]WIPTYP = 2
    [F:PWO]WIPSTA = 2
    [F:PWO]WIPNUM = [F:PSD]PSHNUM
    [F:PWO]PSDLIN = [F:PSD]PSDLIN
    [F:PWO]ITMREF = [F:PSD]ITMREF
    [F:PWO]QTYPUU = [F:PSD]QTYPUU-[F:PSD]ORDQTYPUU
    [F:PWO]PUU    = [F:PSD]PUU
    [F:PWO]STU    = [F:PSD]STU
    Call PCAL_QTY([F:PWO]QTYPUU,[F:PWO]PUU,[F:PWO]QTYSTU,[F:PWO]STU,
&               [F:PWO]ITMREF,[F:PSD]BPSNUM,1,GBIDD1)  From TRTACHQTE1
    Write [PWO]
    If fstat GOK=0 : Call FSTA("PWO") From GLOCK : Goto AB_CREPWO : Endif
  Endif
Commit
$FIN_CREPWO
Return

$AB_CREPWO
Rollback : Goto FIN_CREPWO
$ROLL_CREPWO
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_CREPWO : Endif : Goto FIN_CREPWO


$MAJZERO_PWO
#------------------------------------------------------------------------#
# Effacement des quantités ou suppression fichier de travail des besoins #
#------------------------------------------------------------------------#
Call DEBTRANS From GLOCK
$TR_MAJPWO
GOK=1
Trbegin [PWO]
  For [PWO]PWO0 Where evalue(WPWOCRIT)
    Readlock [PWO] Curr
    If !fstat
      Look [PSA] PSA0(3)=[F:PWO]WIPNUM;[F:PWO]PSDLIN;[M:PQH1]PQHNUM
      [G:PSA]currind=1 : [G:PSA]currlen=0 : # Réinitialisation clé par défaut
      If !fstat
        Raz [F:PWO]QTYPUU, [F:PWO]QTYSTU
        Rewrite [PWO]
        If fstat GOK=0 : Call FSTA("PWO") From GLOCK : Goto AB_MAJPWO : Endif
      Else
        Delete [PWO]
        If fstat GOK=0 : Call FSTA("PWO") From GLOCK : Goto AB_MAJPWO : Endif
      Endif
    Endif
  Next
Commit
$FIN_MAJPWO
Raz WPWOCRIT
Return

$AB_MAJPWO
Rollback : Goto FIN_MAJPWO
$ROLL_MAJPWO
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_MAJPWO : Endif : Goto FIN_MAJPWO


$CREMODPSA
#------------------------------------------#
# Création ou modification du fichier lien #
#------------------------------------------#
For I=0 To [M:PQH1]NBLIG-1
  For [PWO] PWO0 Where PRONUM=adxuid(2) & CODFNC="PQH" & LINNUM=[M:PQH1]PQHLIN(I)
    Readlock [PSA]PSA0=[F:PWO]WIPNUM;[F:PWO]PSDLIN;[M:PQH1]PQHNUM;[M:PQH1]PQDLIN(I)
    # On trouve le liens nouvelle quantité zéro, on supprime
    If !fstat & [F:PWO]QTYSTU=0
      Delete [PSA] Where PSHNUM=[F:PWO]WIPNUM & PSDLIN=[F:PWO]PSDLIN & PQHNUM=[M:PQH1]PQHNUM &
&                        PQDLIN=[M:PQH1]PQDLIN(I)
      If fstat GOK=0 : Call FSTA("PSA") From GLOCK : Break : Endif
      Update [PSD] Where PSHNUM=[F:PWO]WIPNUM & PSDLIN=[F:PWO]PSDLIN With NBAOF-=1
      If fstat GOK=0 : Call FSTA("PSD") From GLOCK : Break : Endif
    Elsif !fstat
      #-- Si la lecture s'est bien passée et que la quantité a été modifié
      #-- Ne peut arriver que si on a dépické puis repické et qu'entre temps la DA a été
      #-- Modifiée
      If [F:PWO]QTYSTU<> [F:PSA]QTYSTU
        [F:PSA]QTYPUU=[F:PWO]QTYPUU
        [F:PSA]PUU   =[F:PWO]PUU
        [F:PSA]QTYSTU=[F:PWO]QTYSTU
        [F:PSA]STU   =[F:PWO]STU
        Rewrite [PSA]
        If fstat GOK=0 : Call FSTA("PSA") From GLOCK : Break : Endif
      Endif
    Else
      #-- On crée un nouveau lien
      [F:PSA]PSHNUM=[F:PWO]WIPNUM
      [F:PSA]PSDLIN=[F:PWO]PSDLIN
      [F:PSA]PQHNUM=[M:PQH1]PQHNUM
      [F:PSA]PQDLIN=[M:PQH1]PQDLIN(I)
      [F:PSA]QTYPUU=[F:PWO]QTYPUU
      [F:PSA]PUU   =[F:PWO]PUU
      [F:PSA]QTYSTU=[F:PWO]QTYSTU
      [F:PSA]STU   =[F:PWO]STU
      Write [PSA]
      If fstat GOK=0 : Call FSTA("PSA") From GLOCK : Break : Endif
      Update [PSD] Where PSHNUM=[F:PSA]PSHNUM & PSDLIN=[F:PSA]PSDLIN With NBAOF+=1
      If fstat GOK=0 : Call FSTA("PSD") From GLOCK : Break : Endif
    Endif
  Next
Next
Return


$SUP_PSA
#-----------------------------------------#
# Suppression d'un enr. dans fichier lien #
# en suppression seulement                #
#-----------------------------------------#
#-- On supprime tous les liens avec la ligne
For [PSA] PSA1 Where PQHNUM=[F:PQH]PQHNUM & PQDLIN=[F:PQD]PQDLIN
  Update [PSD] Where PSHNUM=[F:PSA]PSHNUM & PSDLIN=[F:PSA]PSDLIN With NBAOF-=1
  If fstat  GOK=0 : Call FSTA("PSD") From GLOCK : Break : Endif
Next
Delete [PSA] Where PQHNUM=[F:PQH]PQHNUM & PQDLIN=[F:PQD]PQDLIN
If fstat  GOK=0 : Call FSTA("PSA") From GLOCK : Endif
Return


$MAJ_LIG_ART
#----------------------------------------------#
# Depick d'une DA sur ligne qui en a plusieurs #
# I= numéro de ligne à mettre à jour           #
#----------------------------------------------#
Raz GBIDD1, GBIDD2
If [M:PQH1]CREFLG(I)<>0
  [M:PQH1]UPDFLG(I)=1
Endif
[M:PQH1]RETQTYSTU(I)-=[F:PSD]QTYSTU
[M:PQH1]RETQTYSTU(I)+=[F:PSD]ORDQTYSTU
GBIDD1=[F:PSD]ORDQTYSTU-[F:PSD]QTYSTU
# Recalcul de la quantité
Call PCAL_QTY(GBIDD1,[M:PQH1]STU(I),GBIDD2,[M:PQH1]PUU(I),
&             [M:PQH1]ITMREF(I),"",1,GBIDD1)  From TRTACHQTE1
[M:PQH1]QTYPUU(I)+=GBIDD2
Raz [L]NBDA
For [PWO]PWO0 Where PRONUM=adxuid(2)
&                 & CODFNC="PQH"
&                 & LINNUM=[M:PQH1]PQHLIN(I)
&                 & QTYSTU<>0
   If [F:PWO]WIPNUM<>[F:PSD]PSHNUM | [F:PWO]PSDLIN<>[F:PSD]PSDLIN
     [L]NBDA+=1
     WNUM=[F:PWO]WIPNUM
     WLIN=[F:PWO]PSDLIN
   Endif
Next
If [L]NBDA=1
  [M:PQH1]PSHNUM(I)=WNUM
  [M:PQH1]PSDLIN(I)=WLIN
  #-- Récupération des valeur de la DA uniquement en création si
  #-- rien n'a été modifié
  If [M:PQH1]CREFLG(I)=0 & [M:PQH1]UPDFLG(I)=0
    Read [PSD]PSD0=WNUM;WLIN     : If fstat Raz [F:PSD] : Endif
    #-- On reprend les valeurs de la DA
    [M:PQH1]PQDPJT (I)= [F:PSD]PJT
    [M:PQH1]RCPDAT (I)= [F:PSD]EXTRCPDAT
    [M:PQH1]ITMDES1(I)= [F:PSD]ITMDES1
    #----- Chargement des sections analytiques -----#
    For J=1 To GOPTCANA
      If evalue("[F:PSD]CCE"+num$(J))<>""
        Assign "[M:PQH1]CCE"+num$(J)+"(I)" With evalue("[F:PSD]CCE"+num$(J))
      Endif
    Next J
  Endif
Elsif [L]NBDA=0
  Raz [M:PQH1]PSHNUM(I), [M:PQH1]PSDLIN(I)
Endif
Return


#--------------------------------------#
# Chargement des textes entête et pied #
#--------------------------------------#
$CHARG_TEXT_ENTETE
If [M:PQH1]TEX1<>""
  If left$([M:PQH1]TEX1,3)="PQH"
    Call CRE_CLOB([M:PQH1]TEX1,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif left$([M:PQH1]TEX1,3)<>"BPS"
    Call DUP_CLOB("PQH",[M:PQH1]TEX1,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:PQH]TEX1=[M:PQH1]TEX1
Endif
If [M:PQH1]TEX2<>""
  If left$([M:PQH1]TEX2,3)="PQH"
    Call CRE_CLOB([M:PQH1]TEX2,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif left$([M:PQH1]TEX2,3)<>"BPS"
    Call DUP_CLOB("PQH",[M:PQH1]TEX2,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:PQH]TEX2=[M:PQH1]TEX2
Endif
Return


#---------------------------------#
# Chargement du texte de la ligne #
#---------------------------------#
$CHARG_TEXT_LIGNE
If [M:PQH1]LINTEX(nolign-1)<>""
  If left$([M:PQH1]LINTEX(nolign-1),3)="PQD"
    Call CRE_CLOB([M:PQH1]LINTEX(nolign-1),GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif !find(left$([M:PQH1]LINTEX(nolign-1),3),"ITM","ITP")
    Call DUP_CLOB("PQD",[M:PQH1]LINTEX(nolign-1),GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:PQD]LINTEX=[M:PQH1]LINTEX(nolign-1)
Endif
Return


#-------------------------------------------------------------#
# Affichage entêtes colonnes variables (sections analytiques) #
#-------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & dim([M:PQH1]CCE1)>0
  Local Char BASPAG(10)
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WE1"+GPTRNUM+"1"
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:PQH1]NBLIG=0
    [M:PQH1]NBLIG=1 : Affzo [PQH1]10 : Effzo [PQH1]10
  Endif
  #-----
Endif
Raz GSOC_UPDFLG
Return


#-------------------------------------------------------------------------#
# Chargement des globales référentiels, comptes et sections de la société #
# Chargement des paramètres achats                                        #
#-------------------------------------------------------------------------#
$CHARG_PARAM
Call GETCPY (GFCY,"PTR",1,GPTRNUM) From TRTX3CPT
#----- Lecture des affectations compteur si changement société -----#
If GSOC_UPDFLG
  If dim(OK)<1  Local Integer OK : Endif
  #----- Compteur des appels d'offres -----#
  Call LECTCA(6,OK) From SUBTCA
  If fstat | !OK
    GERR=1 : GMESSAGE=mess(64,199,1) : Return
  Endif
  GMANCOU=[F:TCA]MANCOU(0):GCODNUM=[F:TCA]CODNUM(0)
Endif
#-----
Call GLOBVAR(GFCY) From WWGLOBACH
If GPQHBUY=0  GPQHBUY=1 : Endif
Chgtzn [M:PQH1]REQUSR With mess(GPQHBUY,562,1)
Return

