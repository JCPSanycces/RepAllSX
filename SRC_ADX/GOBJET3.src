#<AdxTL>@(#)9.0.0.0 $Revision$
######################################################################
## Gestion des objets combinés                                      ##
######################################################################
$CREATION
# Si y'a pas de ligne, on va pas créer grand-chose...
If evalue("[M]"+BASPAG)=0
 Call ERREUR(mess(178,123,1)) From GESECRAN
# Il doit y avoir au moins une ligne
 GOK = 0 : zonsui =   BASPAG : Return
Endif
OK = 1
ACTION = "VERIF_CRE" : Gosub ACTION From GOBJSUB
If !OK : GOK = 0 : Return : Endif
Call DEBTRANS From GLOCK
If TEMPON : Call TEMPON("V") From GESECRAN : Endif

Gosub TR1
If TEMPON : TEMPON=0 : Call TEMPOFF From GESECRAN : Endif
If GOK>=1
 ACTION = "APRES_CRE" : Gosub ACTION From GOBJSUB
 If dim(NBLNK)>0 & NBLNK>0 : Gosub LIAISONS From GOBJET1 : Endif
 If OPTENA & !AUTENA & ABRENA<>"" & evalue("[M:"+ABRENA+"]ENAFLG")<>1
  Assign "[M:"+ABRENA+"]ENAFLG" With 1
  Gosub AFF_ENAFLG From =WINPROG
  Call MESSAGE(mess(108,75,1)) From GESECRAN : # Le flag actif ne peut pas être passé à Oui
 Endif
 CLECUR = 1
 Call ESPION(NOMFIC,1,IDENT,"") From ESPION
 If GADONIX=2 : Call TRACE_COR(ABREV,CLECUR1,CLECUR2,"C") From GOBJET : Endif
 If GRPDEB<>"" : Call ENVOI_GROUPE(GRPDEB) From AWRK : Endif
Else
 If GRPDEB<>""
  Call VIRE_GROUPE(GRPDEB) From AWRK
  GOK = 0
 Endif
 Gosub RSTCLE From GOBJSUB
Endif
Return

$TR1
GOK = 1
GRPDEB = ""
Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 ACTION = "DEBUT_CRE" : Gosub ACTION From GOBJSUB
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 If dim(ANOWRITE)<=0 or !ANOWRITE
  For nolign = 1 To evalue("[M]"+BASPAG)
   Raz [F]
   IMA = 1
   Gosub CHARGEFIC From =WINPROG
   Gosub INICRE From GOBJSUB
   If find(evalue("type([F]"+CLELIG+")"),1,2,4,5,6,7,8,9)
    Assign "[F]"+CLELIG With nolign
   Endif
   If OPTENA & !AUTENA & dim([F]ENAFLG)>0 & [F]ENAFLG<>1
    [F]ENAFLG = 1
   Endif
   ACTION = "INICRE" : Gosub ACTION From GOBJSUB
   If GOK<1 : Break : Endif
   # Vérification du rôle
   Onerrgo RIEN
   ER = 0
   OK = evalue(FILROLE)
   Onerrgo
   If !ER & !OK
    Call ERREUR(mess(97,126,1)) From GESECRAN : # Vous n'avez pas les droits pour créer cette fiche
    GOK = 0 : Break
   Endif
   Write
   If fstat
    GOK=0 : Call FSTA(ABFIC) From GLOCK : Break
   Endif
   ACTION = "CREATION" : Gosub ACTION From GOBJSUB
   If GOK<1 : Break : Endif
  Next nolign
 Endif
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

 ACTION = "MODIF" : Gosub ACTION From GOBJSUB
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

 Gosub SET_CLE From GOBJSUB
 Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
 Call WRKGLOB(170,[L]IDENT,[L]NOMFIC,[L]NOMINT) From GOBJACT
 Call WORKPLUS(2,ABREV,"C",IDENT,"",0,1,0,GRPDEB) From AWRK
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

Commit
Return

$AB_TR1
Rollback
ACTION = "AB_CREATION" : Gosub ACTION From GOBJSUB
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL
 ACTION = "AB_CREATION" : Gosub ACTION From GOBJSUB
 Return
Else
 Goto TR1
Endif

$RIEN
ER = errn
Resume

##############################################################
$MODIF
If GADONIX=2 
 Call VERIF_GRP(ABREV,CLECUR1,CLECUR2,OK) From GOBJET
 If !OK : GOK = 0 : Return : Endif
Endif
# Si y'a pas de ligne, on va pas créer grand-chose...
If evalue("[M]"+BASPAG)=0
 Call ERREUR(mess(178,123,1)) From GESECRAN
# Il doit y avoir au moins 1 ligne
 GOK = 0 : zonsui = BASPAG : Return
Endif
OK = 1
ACTION = "VERIF_MOD" : Gosub ACTION From GOBJSUB
If !OK : zonsui = BASPAG : GOK = 0 : Return : Endif
Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
Call DEBTRANS From GLOCK
If TEMPON : Call TEMPON("V") From GESECRAN : Endif
Gosub TR2
If TEMPON : TEMPON=0 : Call TEMPOFF From GESECRAN : Endif
If GOK>=1
 ACTION = "APRES_MOD" : Gosub ACTION From GOBJSUB
 If dim(NBLNK)>0 & NBLNK>0 : Gosub LIAISONS From GOBJET1 : Endif
 If SAVENA<>0
  Assign "[M:"+ABRENA+"]ENAFLG" With SAVENA
  Gosub AFF_ENAFLG From =WINPROG
  Call MESSAGE(mess(109,75,1)) From GESECRAN : # Le flag actif ne peut pas être modifié
 Endif
 Call ESPION(NOMFIC,2,IDENT,"") From ESPION
 If GADONIX=2 : Call TRACE_COR(ABREV,CLECUR1,CLECUR2,"M") From GOBJET : Endif
 If GRPDEB<>"" : Call ENVOI_GROUPE(GRPDEB) From AWRK : Endif
Elsif GRPDEB<>""
 Call VIRE_GROUPE(GRPDEB) From AWRK
 GOK = 0
Endif
Return

$TR2
GOK = 1
GRPDEB = ""
Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 ACTION = "DEBUT_MOD" : Gosub ACTION From GOBJSUB
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 # mb 25.3.5 on pouvait perdre la classe [F] courante suite à un remplissage de liste de gauche
 Gosub AFF_CLE From GOBJSUB
 Gosub CRITTAB
 Read [F] First
 Call WRKGLOB(171,[L]IDENT,[L]NOMFIC,[L]NOMINT) From GOBJACT
 Call WORKPLUS(2,ABREV,"M",IDENT,"",0,1,1,GRPDEB) From AWRK
 If evalue("dim([F:"+ABFIC+"]CREDAT)")>0
  SAVDAT = evalue("[F:"+ABFIC+"]CREDAT")
 Endif
 If evalue("dim([F:"+ABFIC+"]CREUSR)")>0
  SAVUSR = evalue("[F:"+ABFIC+"]CREUSR")
 Endif
 If evalue("dim([F:"+ABFIC+"]CRETIM)")>0
  SAVTIM = evalue("[F:"+ABFIC+"]CRETIM")
 Endif
 SAVENA = 0
 If OPTENA & !AUTENA & ABRENA<>""
& & evalue("dim([F:"+ABFIC+"]ENAFLG)")>0 & evalue("dim([M:"+ABRENA+"]ENAFLG)")>0 
& & evalue("[F:"+ABFIC+"]ENAFLG")<>evalue("[M:"+ABRENA+"]ENAFLG")
  SAVENA = evalue("[F:"+ABFIC+"]ENAFLG")
 Endif
 Gosub SAV_LIAISONS From GOBJET1
 Gosub DEFAUT From =PROGOBJ
 If dim(ANOWRITE)<=0 or !ANOWRITE
  Delete [F] Where evalue(CRITERE)
  If fstat=1 | fstat>5
   GOK=-1 : GLOCK="$"+NOMFIC-CLECUR1 : Goto ROLL_TR2
  Endif
  For nolign=1 To evalue("[M]"+BASPAG)
   Raz [F]
   IMA = 1
   Gosub CHARGEFIC From =WINPROG
   Gosub INIMOD From GOBJSUB
   If evalue("dim([F:"+ABFIC+"]CREDAT)")>0
    Assign "[F:"+ABFIC+"]CREDAT" With SAVDAT
   Endif
   If evalue("dim([F:"+ABFIC+"]CREUSR)")>0
    Assign "[F:"+ABFIC+"]CREUSR" With SAVUSR
   Endif
   If evalue("dim([F:"+ABFIC+"]CRETIM)")>0
    Assign "[F:"+ABFIC+"]CRETIM" With SAVTIM
   Endif
   If SAVENA
    Assign "[F:"+ABFIC+"]ENAFLG" With SAVENA
   Endif
   If find(evalue("type([F]"+CLELIG+")"),1,2,4,5,6,7,8,9)
    Assign "[F]"+CLELIG With nolign
   Endif
   ACTION = "INICRE" : Gosub ACTION From GOBJSUB
   If GOK<1 : Break : Endif
 # Vérification du rôle
   Onerrgo RIEN
   ER = 0
   OK = evalue(FILROLE)
   Onerrgo
   If !ER & !OK
    Call ERREUR(mess(97,126,1)) From GESECRAN : # Vous n'avez pas les droits pour créer cette fiche
    GOK = 0 : Break
   Endif
   Write
   If fstat
    GOK=0 : Call FSTA(ABFIC) From GLOCK : Break
    Goto AB_TR2
   Endif
   ACTION = "CREATION" : Gosub ACTION From GOBJSUB
   If GOK<1 : Break : Endif
  Next nolign
 Endif
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif

 ACTION = "MODIF" : Gosub ACTION From GOBJSUB
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif

 Filter [F]
 Call WORKPLUS(2,ABREV,"M",IDENT,"",0,1,2,GRPDEB) From AWRK
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$CRITTAB
Gosub SET_CLE From GOBJSUB
CRITTAB = ""
If TPCLE1=1
 CRITTAB = CLEPRIM+"='"+CLECUR1+"'"
Elsif TPCLE1=3
 If CLECUR1=""
  CRITTAB = CLEPRIM+"=[0/0/0]"
 Elsif instr(1,CLECUR1,"/")
  CRITTAB = CLEPRIM+"=["+CLECUR1+"]" 
 Elsif len(CLECUR1)=8
  CRITTAB = CLEPRIM+"='"+CLECUR1+"'"
 Endif
Else
 CRITTAB = CLEPRIM+"="+CLECUR1
Endif
For CL=0 To dim(CLESEC)-1
 If CLESEC(CL)=CLELIG
  Break
 Elsif CLESEC(CL)<>""
  If CRITTAB<>"" : CRITTAB-="& " : Endif
  If TPCLE2(CL)=1
   CRITTAB += CLESEC(CL)+"='"+CLECUR2(CL)+"'"
  Elsif TPCLE2(CL)=3
   If CLECUR2(CL)=""
    CRITTAB += CLESEC(CL)+"=[0/0/0]"
   Elsif instr(1,CLECUR2(CL),"/")
    CRITTAB += CLESEC(CL)+"=["+CLECUR2(CL)+"]"
   Elsif len(CLECUR2(CL))=8 
    CRITTAB += CLESEC(CL)+"='"+CLECUR2(CL)+"'"
   Endif
  Else
   CRITTAB += CLESEC(CL)+"="+CLECUR2(CL)
  Endif
 Endif
Next CL
Gosub CRITERE From GOBJSUB : # pour récupérer FILTSUP
Raz CRITERE, ICRITERE : CRITERE=CRITTAB : # Pour ne pas récupérer FILTRE
Gosub DEFAUT From =PROGOBJ
If CRITERE="" : CRITERE = "1=1" : Endif
If FILTSUP="" : FILTSUP = "1=1" : Endif
If FILROLE="" : FILROLE = "1=1" : Endif
Filter [F] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE)
Return

#############################################################
$CHARGE
MA = 1 : Gosub SETMASK From =WINPROG
Raz [M]
nolign = 0
Gosub CRITTAB
ACTION = "LIENS0" : Gosub ACTION From GOBJSUB
Gosub DEFAUT From =PROGOBJ
For [F]
 If nolign>=MAXLIG
  Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
  Break
 Endif
 nolign += 1
 IMA = 1
 Gosub CHARGEMSK From =WINPROG
 ACTION = "LIENS" : Gosub ACTION From GOBJSUB
Next
Filter [F]
Assign "[M]"+BASPAG With nolign
ACTION = "LIENS2" : Gosub ACTION From GOBJSUB
CLECUR = 1
Return


