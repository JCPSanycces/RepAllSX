#<AdxTL>@(#)3.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# deletion of AFWEEKCAL parameter 114504
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("deletion of AFWEEKCAL parameter") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJADP
End

#-------------------#
$MAJADP

Onerrgo ERR
If DOSSIER=nomap
 Local File ADOPAR [ADP]
 Local File ADOVAL [ADW]
 Local File ADOVALAUS [ADU]
Else
 Local File =DOSSIER+".ADOPAR" [ADP]
 Local File =DOSSIER+".ADOVAL" [ADW]
 Local File =DOSSIER+".ADOVALAUS" [ADU]
Endif

Trbegin [ADP]
Delete [ADP] Where PARAM="AFWEEKCAL"
Delete [ADW] Where PARAM="AFWEEKCAL"
Delete [ADU] Where PARAM="AFWEEKCAL"
Commit

Onerrgo
Return

$ERR
Resume

