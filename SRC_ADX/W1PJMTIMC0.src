End

$ON_RATMUL
Onevent AFTER_CHANGE Gosub AMM_RATMUL From W1PJMTIMC0
Onevent CONTROL Call C_RATMUL(zc) From W1PJMTIMC0
Return

Subprog C_RATMUL(VALEUR)
Variable Decimal VALEUR
Gosub _AFF
End

$AMM_RATMUL
Call AM_RATMUL(zc)
If !mkstat & GOBJET
 zoncou = "RATMUL" : Gosub APRES_MODIF From =GPROGRAMME
