#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTIMC0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:58"
A_USER  = "DOC"
A_STAMP = "20181109230558"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMTIMC0 [PJTC0]
Gosub HORODAT
Local Inpbox "PJMTIMC0" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJTC0] As [SIM_]
Grizo [PJTC0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJTC0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=115 : Y1(0)=1 : Y2(0)=25
Return

$ON_CATCOD
Onevent CONTROL Call C_CATCOD(zc) From W1PJMTIMC0
Onevent AFTER_CHANGE Gosub AMM_CATCOD From W1PJMTIMC0
Return

Subprog C_CATCOD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CATCOD" : GZNUM = 52045 : Endif
If !GWEBSERV
 If !mkstat
  ## Action CONTVCR
  Call CONTVCR(VALEUR) From TRTDIV
  If mkstat : GERR = 1 : GZONE = "CATCOD" : GZNUM = 52045 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CATCOD
Call AM_CATCOD(zc)
If !mkstat & GOBJET
 zoncou = "CATCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CATCOD(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CATCOD(VALEUR) From SUBPJTC
If mkstat : GERR = 1 : GZONE = "CATCOD" : GZNUM = 52045 : Endif
Gosub _AFF
End

$ON_DESAXX
Onevent INIT_AREA Call D_DESAXX(zc) From W1PJMTIMC0
Onevent AFTER_CHANGE Gosub AMM_DESAXX From W1PJMTIMC0
Onevent BEFORE_INPUT Call AS_DESAXX(zc) From W1PJMTIMC0
Onevent CONTROL Call C_DESAXX(zc) From W1PJMTIMC0
Return

Subprog IB_DESAXX(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_DESAXX(VALEUR)
Variable Char    VALEUR()
If varinit([M]DESAXX,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"PJMTIMCAT","DESAXX",CATCOD,"") From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_DESAXX(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_DESAXX(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_DESAXX(zc) From W1PJMTIMC0
Gosub _AFF
End

Subprog C_DESAXX(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DESAXX" : GZNUM = 8 : Endif
Gosub _AFF
End

$AMM_DESAXX
Call AM_DESAXX(zc)
If !mkstat & GOBJET
 zoncou = "DESAXX" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DESAXX(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_DESAXX(VALEUR) From SUBPJTC
If mkstat : GERR = 1 : GZONE = "DESAXX" : GZNUM = 8 : Endif
Gosub _AFF
End

Subprog B1_DESAXX(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_DESAXX" : PROGSUB = "SUBPJTC" : PROGSPE = "SPEPJTC" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PJMTIMCAT"
 PARMSK(2) = "DESAXX"
 PARMSK(3) = CATCOD
 PARMSK(4) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_DESAXX" : PROGSUB = "SUBPJTC" : PROGSPE = "SPEPJTC" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

