#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AHISTO","AHISTO",3,"") From GTRAITE
End

####################################################################################
##
## Archive / Purge
##
####################################################################################
#   - SEAUTH    : Archive / Purge Sage Exchange authorization records
#   - SEBPC     : Archive / Purge Sage Exchange one-time-use card records
####################################################################################
# HISTO = 1 => Archive
#
#              The data is passed from APPLI to HISAPL
#              The historical data is deleted from APPLI
#              Uniquement des contrôles liés au dossier APPLI
#              Only the controls in the folder APPLI
#
#
# EPUR  = 1 => Purge
#
#    Either Purge only (EPUR=1 et HISTO=0)
#         The data is deleted from APPLI
#         Only the controls in the folder APPLI
#
#    Either Purge as result of archive (EPUR=1 et HISTO=1)
#         The archive has made the necessary checks (cf HISTO=1)
#         The purge concerns the folder HISAPL but no control over this folder.
#
####################################################################################

$ACTION
If [F:AHI]COD<>"SEPP" : Return : Endif
Case ACTION
  When "OUVRE" : Gosub OUVRE_SEPP
  When "HISTO" : Gosub HISTO_SEPP
  When "EPURE" : Gosub EPURE_SEPP
  When "FERME" : Gosub FERME_SEPP
Endcase
Return

$OUVRE_SEPP
Case TABLE
  When "SEAUTH"
    If !clalev([F:SER]) : Local File =[L]APPLI+".SEPRC"      [SER] : Endif
    If !clalev([F:SOH]) : Local File =[L]APPLI+".SORDER"     [SOH] : Endif
    If !clalev([F:SDH]) : Local File =[L]APPLI+".SDELIVERY"  [SDH] : Endif
    If !clalev([F:SIH]) : Local File =[L]APPLI+".SINVOICE"   [SIH] : Endif
    If !clalev([F:PYH]) : Local File =[L]APPLI+".PAYMENTH"   [PYH] : Endif
  When "SEBPC"
    If !clalev([F:SEU]) : Local File =[L]APPLI+".SEAUTH"     [SEU] : Endif
Endcase
Return

$HISTO_SEPP
Case TABLE
  When "SEAUTH" : Call SEAUTH(date$-[F:AHI]TIM1,SOCIETE,OKHIS)
  When "SEBPC"  : Call SEBPC(OKHIS)
Endcase
Return

$EPURE_SEPP
Case TABLE
  When "SEAUTH" : Call SEAUTH(date$-[F:AHI]TIM2,SOCIETE,OKEPU)
  When "SEBPC"  : Call SEBPC(OKEPU)
Endcase
Return

$FERME_SEPP
Case TABLE
  When "SEAUTH"
    If clalev([F:SER]) : Close Local File [SER] : Endif
    If clalev([F:SOH]) : Close Local File [SOH] : Endif
    If clalev([F:SDH]) : Close Local File [SDH] : Endif
    If clalev([F:SIH]) : Close Local File [SIH] : Endif
    If clalev([F:PYH]) : Close Local File [PYH] : Endif
  When "SEBPC"
    If clalev([F:SEU]) : Close Local File [SEU] : Endif
Endcase
Return

####################################################################################
Subprog SEAUTH(DAT,CPY,OK)
Value    Date    DAT
Value    Char    CPY
Variable Integer OK
# Auth date or payment date still in valid range
If [F:F1]AUTDAT>DAT | [F:F1]PAYDAT>DAT
  Raz OK : End
Endif
# Voided and no auth date
If [F:F1]STAFLG=5 & [F:F1]AUTDAT=[0/0/0]
  End
Endif
# Only delete if linked document has already been purged
If find([F:F1]STAFLG,6,7)
  If [F:F1]SOHNUM<>""
    Look [SOH]SOH0=[F:F1]SOHNUM
    If !fstat : Raz OK : End : Endif
  Endif
  If [F:F1]SDHNUM<>""
    Look [SDH]SDH0=[F:F1]SDHNUM
    If !fstat : Raz OK : End : Endif
  Endif
  If [F:F1]SIHNUM<>""
    Look [SIH]SIH0=[F:F1]SIHNUM
    If !fstat : Raz OK : End : Endif
  Endif
  If [F:F1]PAYNUM<>""
    Look [PYH]PYH0=[F:F1]PAYNUM
    If !fstat : Raz OK : End : Endif
  Endif
  If find([F:F1]VCRTYP,50,51)
    Look [PYH]PYH0=[F:F1]VCRNUM
    If !fstat : Raz OK : End : Endif
  Endif
Endif
If [L]CPY<>""
  Read [SER]SER0=[F:F1]PRCCOD
  If !fstat & [F:SER]CPY<>[L]CPY
    Raz OK : End
  Endif
Endif
End


####################################################################################
Subprog SEBPC(OK)
Variable Integer OK
Look [SEU]SEU5=[F:F1]BPCNUM;[F:F1]ACCNCKNAM
If !fstat : Raz OK : End : Endif
End
