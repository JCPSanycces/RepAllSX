#<AdxTL>@(#)10.0.0.0 $Revision$
###############################################################################################################
#
#   Génération XML d'un échantillon ciblé                                                         Version 140
#   Module CRM
#
#   MGGINXML    : Extraction XML de l'échantillon
#
###############################################################################################################
###############################################################################################################
Subprog MGGINXML(SZRECNUM, SZTGPCOD, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZRECNUM
Value Char SZTGPCOD
Value Integer IGENERICFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF

  ICHAPTER = 0
  IERRINF = 0
  SZFULLRETFILE = ""
  SZRETFILENAME = ""
  If SZRECNUM = "" Then
    End
  Endif

Local Char SZQURNUM
Local Char SZTGPNUM
Local Char SZINLINETGR
Local Integer IDISPPPL

  If !clalev([F:MQR]) : Local File MKGQUR [MQR] : Endif
  Read [MQR] MQR0 = SZRECNUM
  If fstat Then
    End
  Else
    IDISPPPL = [F:MQR]FINPPL
    SZQURNUM = SZRECNUM
    SZINLINETGR = [F:MQR]TGR
  Endif
  Call TEMPON("L") From GESECRAN
  ##################
  #Génération de la feuille de style si SZXSLSHEET = STD
  If toupper(SZXSLSHEET) = "STD" Then
    SZXSLSHEET = "MGGSTD"
    Call GENSTDMGGXSL(SZXSLSHEET)
  Endif
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
  If !clalev([F:AOB]) : Local File AOBJET [AOB] : Endif
  If !clalev([F:SSP]) : Local File SELSSP [SSP] : Endif
  If !clalev([F:SSC]) : Local File SELSSPCPN [SSC] : Endif
  If !clalev([F:MQP]) : Local File MKGQURPPL [MQP] : Endif
  If !clalev([F:QCR]) : Local File QURCRI [QCR] : Endif
  If !clalev([F:QCV]) : Local File QURCRIVAL [QCV] : Endif
  If !clalev([F:QTP]) : Local File QURTMP [QTP] : Endif
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  If !clalev([F:TGL]) : Local File TGRLIS [TGL] : Endif
  If !clalev([F:TGP]) : Local File TGRSSP [TGP] : Endif
  If !clalev([F:FID]) : Local File FIEDIC [FID] : Endif
  If !clalev([F:TLF]) : Local File TGRLISFIE [TLF] : Endif
  If !clalev([F:TLL]) : Local File TGRLISLNK [TLL] : Endif
  #Si aucun  support de présentation n'est indiqué, on peut le support par défaut associé à la cible.
  If SZTGPCOD = "" Then
    Read [TGL]TGL0=SZINLINETGR
    If fstat Then
      Call TEMPOFF From GESECRAN
      End
    Else
      SZTGPNUM = [F:TGL]TGRSSPDEF
    Endif
  Else
    SZTGPNUM = SZTGPCOD
  Endif

Local Char SZTGR
Local Char SZPRETAB
Local Char SZFIEZOOM
Local Char SZKEYLNK
Local Integer ITER
Local Integer ICRIFIETYP
Local Char SZQUITMASK(8)
Local Char SZTABSRT
Local Char SZABRSRT
Local Char SZFIESRT
Local Char SZABRTGR
Local Integer ISRTTYP
Local Integer ISRTMGC1
Local Integer ISRTDATATYP
Local Integer IONLY1KEY
Local Integer IADISEPARATOR

  IADISEPARATOR = 0
  SZKEYLNK = ""
  SZFIEZOOM = ""
  SZTABSRT = ""
  SZABRSRT = ""
  SZFIESRT = ""
  SZABRTGR = ""
  IONLY1KEY = 0
  ISRTTYP = 0
  ISRTMGC1 = 0
  ISRTDATATYP = 0
  SZQUITMASK = "00000000"

Local Char SZADXIFS
Local Char SZADXIRS

#Variables traitement généré n°1
Local Char SZPROGNAME
Local Integer IPRGSUFIX
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Integer IEXIST

#Variables traitement généré n°2
Local Char SZPROG2NAME
Local Integer IPRG2SUFIX
Local Char SZFULL2SRC(250)
Local Char SZFULL2ADX(250)
Local Integer I2EXIST

  #On sauvegarde les variables adxifs et adxirs
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  ################################
  #On génère un fichier de code d'exécution d'un affichage de ciblage
  Raz SZPROGNAME
  Raz SZFULLSRC
  Raz SZFULLADX
  Raz IEXIST
  IPRGSUFIX = 1
  While 1
    SZPROGNAME = "CRMRD" + num$(IPRGSUFIX)
    SZFULLSRC = filpath("TRT",SZPROGNAME,"src",nomap)
    SZFULLADX = filpath("TRT",SZPROGNAME,"adx",nomap)
    #Contrôle de l'existence du src
    IEXIST = 0
    Call EXISTE(SZFULLSRC,IEXIST) From ORDSYS
    If IEXIST Then
        #Calcul un nouveau suffixe pour le traitement
        IPRGSUFIX += 1
    Else
      #Contrôle de l'existence de l'adx
      IEXIST = 0
      Call EXISTE(SZFULLADX,IEXIST) From ORDSYS
      If IEXIST Then
        #Calcul un nouveau suffixe pour le traitement
        IPRGSUFIX += 1
      Else
        Break
      Endif
    Endif
  Wend
  #Ouverture du traitement à générer
  Openo SZFULLSRC, 0 Using [CRM3]
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%" Using [CRM3]
  Wrseq "#Traitement généré d'exécution de l'affichage du résultat d'un ciblage marketing" Using [CRM3]
  Wrseq "Subprog DISPMGG(SZFULLRETFILE, SZRETFILENAME)" Using [CRM3]
  Wrseq "Variable Char SZFULLRETFILE" Using [CRM3]
  Wrseq "Variable Char SZRETFILENAME" Using [CRM3]
  #Ouvre toutes les tables à utiliser
  Wrseq "If !clalev([F:QTP]) : Local File QURTMP [QTP] : Endif" Using [CRM3]
  Wrseq "If !clalev([F:TLF]) : Local File TGRLISFIE [TLF] : Endif" Using [CRM3]
  Wrseq "If !clalev([F:FDF]) : Local File FIEDICFIE [FDF] : Endif" Using [CRM3]
  Wrseq "If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif" Using [CRM3]
  Wrseq "If !clalev([F:TGP]) : Local File TGRSSP [TGP] : Endif" Using [CRM3]
  Wrseq "If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif" Using [CRM3]
  ##############################
  #On commence par mettre en place toute l'infrastructure XML
  Wrseq "Gosub XMLMGG1 From SUBMGGXML" Using [CRM3]
  Wrseq "SZPECONTEXT = " + '"' + SZPECONTEXT + '"' Using [CRM3]
  Wrseq "SZSUBPROG = " + '"' + "MGGINXML" + '"' Using [CRM3]
  Wrseq "IGENERICFILENAME = " + num$(IGENERICFILENAME) Using [CRM3]
  Wrseq "SZRECNUM = " + '"' + SZRECNUM + '"' Using [CRM3]
  Wrseq "SZXSLSHEET = " + '"' + SZXSLSHEET + '"' Using [CRM3]
  Wrseq "SZXMLTGR = " + '"' + SZINLINETGR + '"' Using [CRM3]
  Wrseq "SZXMLTGPNUM = " + '"' + SZTGPNUM + '"' Using [CRM3]
  Wrseq "Gosub XMLMGG2 From SUBMGGXML" Using [CRM3]
  Wrseq "Gosub XMLPART2 From CRMXML140" Using [CRM3]
  #Génération des titre des colonnes
  Wrseq "Gosub MGGXMLTITCOL From SUBMGGXML" Using [CRM3]
  #############################
  #On génére un sous-programme d'ouverture de tables pour effectuer des contrôles de types
  Raz SZPROG2NAME
  Raz SZFULL2SRC
  Raz SZFULL2ADX
  Raz I2EXIST
  IPRG2SUFIX = 1
  #Détermine un nom disponible pour le traitement
  While 1
    SZPROG2NAME = "CRMRF" + num$(IPRG2SUFIX)
    SZFULL2SRC = filpath("TRT",SZPROG2NAME,"src",nomap)
    SZFULL2ADX = filpath("TRT",SZPROG2NAME,"adx",nomap)
    #Contrôle de l'existence du src
    I2EXIST = 0
    Call EXISTE(SZFULL2SRC,I2EXIST) From ORDSYS
    If I2EXIST Then
      #Calcul un nouveau suffixe pour le traitement
      IPRG2SUFIX += 1
    Else
      #Contrôle de l'existence de l'adx
      I2EXIST = 0
      Call EXISTE(SZFULL2ADX,I2EXIST) From ORDSYS
      If I2EXIST Then
        #Calcul un nouveau suffixe pour le traitement
        IPRG2SUFIX += 1
      Else
        Break
      Endif
    Endif
  Wend
  #Ouverture du traitement à générer
  Openo SZFULL2SRC, 0 Using [CRM4]
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%" Using [CRM4]
  Wrseq "#Traitement généré d'ouverture de tables pour contrôle de type" Using [CRM4]
  Wrseq "$OPENTAB" Using [CRM4]
  #Ouvre la table cible
  Read [MQR]MQR0=SZQURNUM
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11101101"
    Gosub QDISPRESULT
    Call TEMPOFF From GESECRAN
    End
  Endif
  SZTGR = [F:MQR]TGR
  Read [ATB]CODFIC=SZTGR
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11101101"
    Gosub QDISPRESULT
    Call TEMPOFF From GESECRAN
    End
  Endif
  Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + [F:MQR]TGR + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM3]
  Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + [F:MQR]TGR + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM4]
  #Ensuite les tables de critères
  Filter [TLF] Where [F:TLF]TGRTAB = SZTGR and [F:TLF]TGRSSPNUM = SZTGPNUM
  SZPRETAB = ""
  For [TLF] TLF1
    If [F:TLF]TGRTABLNK <> "" Then
      If [F:TLF]TGRTABLNK <> SZTGR Then
        If [F:TLF]TGRTABLNK <> SZPRETAB Then
          SZPRETAB = [F:TLF]TGRTABLNK
          Read [ATB]CODFIC=SZPRETAB
          If fstat Then
            #Erreur. Il faut nettoyer les ressources avant de dépiler.
            SZQUITMASK = "11101101"
            Gosub QDISPRESULT
            Break
          Else
            Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + SZPRETAB + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM3]
            Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + SZPRETAB + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM4]
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [TLF]
  If GERR Then
    Call TEMPOFF From GESECRAN
    End
  Endif
  Wrseq "Return" Using [CRM4]
  #Génération du sous-programme de fermeture des tables utilisées pour le contrôle de type.
  #D'abord la table cible
  Wrseq "$CLOSETAB" Using [CRM4]
  Read [ATB]CODFIC=SZTGR
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11101101"
    Gosub QDISPRESULT
    Call TEMPOFF From GESECRAN
    End
  Else
    Wrseq "Close Local File [" + [F:ATB]ABRFIC + ']' Using [CRM4]
  Endif
  Filter [TLF] Where [F:TLF]TGRTAB = SZTGR and [F:TLF]TGRSSPNUM = SZTGPNUM
  SZPRETAB = ""
  For [TLF] TLF1
    If [F:TLF]TGRTABLNK <> "" Then
      If [F:TLF]TGRTABLNK <> SZTGR Then
        If [F:TLF]TGRTABLNK <> SZPRETAB Then
          SZPRETAB = [F:TLF]TGRTABLNK
          Read [ATB]CODFIC=SZPRETAB
          If fstat Then
            #Erreur. Il faut nettoyer les ressources avant de dépiler.
            SZQUITMASK = "11101101"
            Gosub QDISPRESULT
            Break
          Else
            Wrseq "Close Local File [" + [F:ATB]ABRFIC + ']' Using [CRM4]
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [TLF]
  If GERR Then
    Call TEMPOFF From GESECRAN
    End
  Endif
  Wrseq "Return" Using [CRM4]
  Wrseq "#Fin du traitement généré" Using [CRM4]
  #Fermeture du traitement généré
  Openo Using [CRM4]
  #Compilation du traitement généré
  Local Integer IVALIDOK
  IVALIDOK = 1
  Call VALID("TRT", SZPROG2NAME, nomap, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11100111"
    Gosub QDISPRESULT
    Call TEMPOFF From GESECRAN
    End
  Endif
  If GMESSAGE <> "" Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11100111"
    Gosub QDISPRESULT
    Call TEMPOFF From GESECRAN
    End
  Endif
  #Création du Link
  Read [ATB]CODFIC=SZTGR
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11100111"
    Gosub QDISPRESULT
    Call TEMPOFF From GESECRAN
    End
  Else
    SZABRTGR = [F:ATB]ABRFIC
    Read [TGL]TGL0=SZTGR
    If fstat Then
      #Erreur. Il faut nettoyer les ressources avant de dépiler.
      SZQUITMASK = "11100111"
      Gosub QDISPRESULT
      Call TEMPOFF From GESECRAN
      End
    Else
      Read [TGP]TGP0=SZTGPNUM
      If fstat Then
        #Erreur. Il faut nettoyer les ressources avant de dépiler.
        SZQUITMASK = "11100111"
        Gosub QDISPRESULT
        Call TEMPOFF From GESECRAN
        End
      Else
        SZTABSRT = [F:TGP]TABSRT
        SZFIESRT = [F:TGP]FIESRT
        ISRTTYP = [F:TGP]FIESRTTYP
        Wrseq "Link [" + [F:ATB]ABRFIC + "] With" Using [CRM3]
        #On link toujours avec QURTMP
        Wrseq "& [QTP]QTP2 = [F:" + [F:ATB]ABRFIC + ']' + [F:TGL]TGRMAIKEY Using [CRM3]
        SZFIEZOOM = "[F:" + [F:ATB]ABRFIC + ']' + [F:TGL]TGRMAIKEY
      Endif
    Endif
  Endif
  #Génération des expressions de lien
  Filter [TLF] Where [F:TLF]TGRTAB = SZTGR and [F:TLF]TGRSSPNUM = SZTGPNUM
  SZPRETAB = ""
  For [TLF] TLF1
    If [F:TLF]TGRTABLNK <> "" Then
      If [F:TLF]TGRTABLNK <> SZTGR Then
        If [F:TLF]TGRTABLNK <> SZPRETAB Then
          SZPRETAB = [F:TLF]TGRTABLNK
          Read [TLL]TLL0=SZTGR;[F:TLF]TGRTABLNK
          If fstat Then
            #Erreur. Il faut nettoyer les ressources avant de dépiler.
            SZQUITMASK = "11100111"
            Gosub QDISPRESULT
            Break
          Else
            Read [ATB]CODFIC=[F:TLL]TGRLNK
            If fstat Then
              #Erreur. Il faut nettoyer les ressources avant de dépiler.
              SZQUITMASK = "11100111"
              Gosub QDISPRESULT
              Break
            Else
              Wrseq "& ,[" + [F:ATB]ABRFIC + ']' + [F:TLL]TGRLNKIDX + ' = ' + [F:TLL]TGREXPLNK Using [CRM3]
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [TLF]
  If GERR Then
    Call TEMPOFF From GESECRAN
    End
  Endif
  Wrseq "& As [LNK]" Using [CRM3]
  #Définit l'ordre de tri pour l'affichage du résultat.
  Read [TGL]TGL0=SZTGR
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11100111"
    Gosub QDISPRESULT
    Call TEMPOFF From GESECRAN
    End
  Else
    Read [ATB]CODFIC=SZTABSRT
    If fstat Then
      #Erreur. Il faut nettoyer les ressources avant de dépiler.
      SZQUITMASK = "11100111"
      Gosub QDISPRESULT
      Call TEMPOFF From GESECRAN
      End
    Else
      SZABRSRT = [F:ATB]ABRFIC
      SZKEYLNK = "[F:" + [F:ATB]ABRFIC + ']' + SZFIESRT
      IONLY1KEY = 1
      If ISRTTYP = 1 Then
        #Tri ascendant
        Wrseq "& Order By Key KBID = " + SZKEYLNK + " Asc" Using [CRM3]
      Elsif ISRTTYP = 2 Then
        #Tri descendant
        Wrseq "& Order By Key KBID = " + SZKEYLNK + " Desc" Using [CRM3]
      Endif
    Endif
  Endif
  #Détermine quelle est la colonne qui contient le champ de tri
  ITER = 1
  Filter [TLF] Where [F:TLF]TGRTAB = SZTGR and [F:TLF]TGRSSPNUM = SZTGPNUM Order By [F:TLF]TGRFIEORD Asc
  For [TLF] Hint Key TLF0
    If ITER > 250 Then
      Break
    Endif
    If [F:TLF]TGRFIE = SZFIESRT Then
      If [F:TLF]TGRTABLNK = SZTABSRT Then
        ISRTMGC1 = ITER
        Break
      Endif
    Endif
    ITER += 1
  Next
  Filter [TLF]
  #On ouvre les tables nécessaires aux contrôles de type des champs
  Gosub OPENTAB From =SZPROG2NAME
  #Les liens sont posés
  #On place le filtre sur QURTMP
  Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' + " and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
  Wrseq "For [LNK] KBID" Using [CRM3]
  #Ecriture de la balise de début d'enregistrement
  Wrseq "Gosub DOSTARTMGGRECORD From CRMXML140" Using [CRM3]
  ITER = 1
  Filter [TLF] Where [F:TLF]TGRTAB = SZTGR and [F:TLF]TGRSSPNUM = SZTGPNUM Order By [F:TLF]TGRFIEORD Asc
  For [TLF] Hint Key TLF0
    If ITER > 250 Then
      Break
    Endif
    Read [ATB]CODFIC=[F:TLF]TGRTABLNK
    If fstat Then
      #Erreur. Il faut nettoyer les ressources avant de dépiler.
      SZQUITMASK = "11100111"
      Gosub QDISPRESULT
      Break
    Else
      ICRIFIETYP = evalue("Type([F:" + [F:ATB]ABRFIC + "]" + [F:TLF]TGRFIE + ")")
      If ICRIFIETYP = 1 or ICRIFIETYP = 2 Then
        Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE
        If fstat Then
          Wrseq "SZDATAFORFILL = num$([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
        Else
          If [F:ATZ]CODTYP = "M" or [F:ATZ]CODTYP = "MM" Then
            Wrseq "If [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + " = 0" Using [CRM3]
            Wrseq "SZDATAFORFILL = " + '"' + '"' Using [CRM3]
            Wrseq "Else" Using [CRM3]
            Wrseq "SZDATAFORFILL = mess([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ", " + num$([F:ATZ]NOLIB) + ", 2)" Using [CRM3]
            Wrseq "Endif" Using [CRM3]
          Else
            Wrseq "SZDATAFORFILL = num$([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
          Endif
        Endif
      Endif
      If ICRIFIETYP = 3 Then
        Wrseq "SZDATAFORFILL = format$(GFMD,[F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
      Endif
      If ICRIFIETYP >= 4 and ICRIFIETYP <= 9 Then
        Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE
        If fstat Then
          Wrseq "SZDATAFORFILL = num$([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
        Else
          If [F:ATZ]CODTYP = "M" or [F:ATZ]CODTYP = "MM" Then
            Wrseq "If [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + " = 0" Using [CRM3]
            Wrseq "SZDATAFORFILL = " + '"' + '"' Using [CRM3]
            Wrseq "Else" Using [CRM3]
            Wrseq "SZDATAFORFILL = mess([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ", " + num$([F:ATZ]NOLIB) + ", 2)" Using [CRM3]
            Wrseq "Endif" Using [CRM3]
          Else
            Wrseq "SZDATAFORFILL = num$([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
          Endif
        Endif
      Endif
      If ICRIFIETYP >= 10 and ICRIFIETYP < 500 Then  # FGR 04/02/2015 : X3SUIVI105938
        Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE
        If fstat Then
          Wrseq "SZDATAFORFILL = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
        Else
          If [F:ATZ]CODTYP = "ADI" Then
            IADISEPARATOR = instr(1, [F:ATZ]EXPLIEN, ";")
            IADISEPARATOR -= 1
            Wrseq "Read [ADI] CODE = " + left$([F:ATZ]EXPLIEN, IADISEPARATOR) + ";[F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            Wrseq "If fstat" Using [CRM3]
            Wrseq "SZDATAFORFILL = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            Wrseq "Else" Using [CRM3]
            Wrseq "Call GET_LIB(" + left$([F:ATZ]EXPLIEN, IADISEPARATOR) + ",[F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ", SZDATAFORFILL) From CRM_UTIL" Using [CRM3]
            Wrseq "Endif" Using [CRM3]
          Else
            Wrseq "SZDATAFORFILL = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
          Endif
        Endif
      Endif
    Endif
    Wrseq "SZATTTABLE = " + '"' + [F:TLF]TGRTABLNK + '"' Using [CRM3]
    Wrseq "SZATTFIELD = " + '"' + [F:TLF]TGRFIE + '"' Using [CRM3]
    Wrseq "Gosub WRITEMGGFIELD From CRMXML140" Using [CRM3]
    ITER += 1
  Next
  Filter [TLF]
  If GERR Then
    Call TEMPOFF From GESECRAN
    End
  Endif
  #Ecriture de la balise de fin d'enregistrement
  Wrseq "Gosub DOENDMGGRECORD From CRMXML140" Using [CRM3]
  Wrseq "IRECORDCOUNT += 1" Using [CRM3]
  Wrseq "Next" Using [CRM3]
  Wrseq "Filter [LNK]" Using [CRM3]
  #On termine le fichier XML
  Wrseq "Gosub XMLPART3 From CRMXML140" Using [CRM3]
  #On ferme les tables utilisées pour le contrôle de type
  Gosub CLOSETAB From =SZPROG2NAME
  #On supprime le traitement SZPROG2NAME
  I2EXIST = 1
  Call EFFACE(SZFULL2SRC, I2EXIST) From ORDSYS
  I2EXIST = 1
  Call EFFACE(SZFULL2ADX, I2EXIST) From ORDSYS
  #On termine le traitement SZPROGNAME
  Wrseq "End" Using [CRM3]
  Wrseq "#Fin du traitement généré" Using [CRM3]
  #Fermeture du traitement généré
  Openo Using [CRM3]

  #Compilation du traitement généré
Local Integer IVALIDOK

  IVALIDOK = 1
  Call VALID("TRT", SZPROGNAME, nomap, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "10110111"
    Gosub QDISPRESULT
    Call TEMPOFF From GESECRAN
    End
  Endif
  If GMESSAGE <> "" Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "10110111"
    Gosub QDISPRESULT
    Call TEMPOFF From GESECRAN
    End
  Endif
  Call TEMPOFF From GESECRAN
  #Exécution du traitement généré
  Call DISPMGG(SZFULLRETFILE, SZRETFILENAME) From =SZPROGNAME
  If GERR Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "10110111"
    Gosub QDISPRESULT
    End
  Endif
  #Suppression du traitement généré après service rendu
  IEXIST = 1
  Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  IEXIST = 1
  Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
End

##################################################################
# Programme de remise en état des ressources suite à une arrêt sur erreur dans DISPRESULT
##################################################################
$QDISPRESULT
  #####################################################################
  #Table des tâches de nettoyage :
  #
  # 0 : On restaure les variables adxifs et adxirs
  # 1 : On ferme le fichier CRMRDXXX
  # 2 : Suppression physique du fichier CRMRDXXX.src
  # 3 : Suppression physique du fichier CRMRDXXX.adx
  # 4 : On ferme le fichier CRMRFNNN
  # 5 : Suppression physique du fichier CRMRFNNN.src
  # 6 : Suppression physique du fichier CRMRFNNN.adx
  # 7 : Suppression de toutes les populations du ciblage dans QURTMP
  ######################################################################
  #On signale toujours l'erreur
  GERR = 1
  #On restaure les variables adxifs et adxirs
  If val(mid$(SZQUITMASK, 1, 1)) Then
    adxifs = SZADXIFS
    adxirs = SZADXIRS
  Endif
  #On ferme le fichier CRMRDXXX
  If val(mid$(SZQUITMASK, 2, 1)) Then
    Openo Using [CRM3]
  Endif
  #Suppression physique du fichier CRMRDXXX.src
  If val(mid$(SZQUITMASK, 3, 1)) Then
    IEXIST = 1
    Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  Endif
  #Suppression physique du fichier CRMRDXXX.adx
  If val(mid$(SZQUITMASK, 4, 1)) Then
    IEXIST = 1
    Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
  Endif
  #On ferme le fichier CRMRFNNN
  If val(mid$(SZQUITMASK, 5, 1)) Then
    Openo Using [CRM4]
  Endif
  #Suppression physique du fichier CRMRFNNN.src
  If val(mid$(SZQUITMASK, 6, 1)) Then
    IEXIST = 1
    Call EFFACE(SZFULL2SRC, IEXIST) From ORDSYS
  Endif
  #Suppression physique du fichier CRMRFNNN.adx
  If val(mid$(SZQUITMASK, 7, 1)) Then
    IEXIST = 1
    Call EFFACE(SZFULL2ADX, IEXIST) From ORDSYS
  Endif
  #Suppression de toutes les populations du ciblage dans QURTMP
  If val(mid$(SZQUITMASK, 8, 1)) Then
    Call DEBTRANS From GLOCK
    Trbegin [QTP]
    Delete [QTP] Where [F:QTP]QURNUM = SZQURNUM
    If fstat Then
      Rollback
    Else
      Commit
    Endif
  Endif
Return

#########################################################################
# Première étape génération XML
#########################################################################
$XMLMGG1
Local Integer IRECORDCOUNT
Local Char SZATTTABLE
Local Char SZATTFIELD
Local Char SZXMLTGR
Local Char SZXMLTGPNUM
Local Char SZXCTITLES
Local Char SZXCOLTITLE
Local Char SZRECNUM
Local Integer IGENERICFILENAME
Local Char SZXSLSHEET

  SZXCOLTITLE = "XCOLTITLE"
  SZXCTITLES = "XCTITLES"
  IRECORDCOUNT = 1
  Gosub XMLPART1 From CRMXML140
  If SZXCOLTITLE = "" Then
    SZXCOLTITLE = "XCOLTITLE"
  Endif
  If SZXCTITLES = "" Then
    SZXCTITLES = "XCTITLES"
  Endif

Local Char SZPECONTEXT
Return

#########################################################################
# Deuxième étape génération XML
#########################################################################
$XMLMGG2
  #Obtient le titre du support de présentation utilisé
  Read [TGP]TGP0=SZXMLTGPNUM
  If fstat Then
    Call TEXTE(19066, SZHTMLTITLE) From OBJDIV      #Consultation ciblage
  Else
    Call LECTEXTRA(SZHTMLTITLE, "TGRSSP", "TGRAXX", [F:TGP]TGRSSPNUM, "") From ATEXTRA
  Endif
Return

#########################################################################
# Ecriture du titre des colonnes
#########################################################################
$MGGXMLTITCOL
Local Integer ITERCOL
Local Char SZTEXTE(GLONDCO)

  ITERCOL = 0
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXCTITLES + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Filter [TLF] Where [F:TLF]TGRTAB = SZXMLTGR and [F:TLF]TGRSSPNUM = SZXMLTGPNUM Order By [F:TLF]TGRFIEORD Asc
  For [TLF] Hint Key TLF0
    If ITERCOL > 250 Then
      Break
    Endif
    #On prend d'abord le nom du champ depuis la définition des critères de ciblage
    #Sinon depuis ATABZON
    Read [FDF]FDF0=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE;GAUSCRMI
    If fstat Then
      Read [FDF]FDF0=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE;""
      If fstat Then
        Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE
        If fstat Then
          SZDATAFORFILL = [F:TLF]TGRFIE
        Else
          Call TEXTE([F:ATZ]NOLONG, SZDATAFORFILL) From OBJDIV
        Endif
      Else
        Call LECTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
        If SZTEXTE = "" Then
          Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE
          If fstat Then
            SZDATAFORFILL = [F:TLF]TGRFIE
          Else
            Call TEXTE([F:ATZ]NOLONG, SZDATAFORFILL) From OBJDIV
          Endif
        Else
          SZDATAFORFILL = SZTEXTE
        Endif
      Endif
    Else
      Call LECTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
      If SZTEXTE = "" Then
        Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE
        If fstat Then
          SZDATAFORFILL = [F:TLF]TGRFIE
        Else
          Call TEXTE([F:ATZ]NOLONG, SZDATAFORFILL) From OBJDIV
        Endif
      Else
        SZDATAFORFILL = SZTEXTE
      Endif
    Endif
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = A + SZXCOLTITLE + " T=" + VQ + [F:TLF]TGRTABLNK + VQ + " F=" + VQ + [F:TLF]TGRFIE + VQ + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Gosub WRITEXML2 From CRMXML140
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = B + SZXCOLTITLE + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    ITERCOL += 1
  Next
  Filter [TLF]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXCTITLES + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

###############################################################
#Génération de la feuille de style standard
###############################################################
Subprog GENSTDMGGXSL(SZXSLSHEET)
Value Char SZXSLSHEET

#Caractères XML
Local Char A(2)
Local Char B(4)
Local Char C(4)
Local Char D(2)
Local Char VQ(2)
Local Char SP(2)

  SP = '_'
  VQ = '"'
  A = "<"
  B = "</"
  C = "/>"
  D = ">"

Local Integer IWHERE
Local Char SZHTMLTITLE(250)
Local Char SZLABELFORFILL(250)
Local Char SZDATAFORFILL(250)
Local Char SZBUFFTOFILL(250)(2)      #Buffers d'écriture
Local Char SZADXIFS                  #Séparateurs
Local Char SZADXIRS                  #Séparateurs
Local Char SZXMLFILENAME(250)
Local Char SZWFNAME(250)
Local Char SZSUBPROG
Local Char SZAOBABREV

  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  Raz SZBUFFTOFILL
  Raz SZLABELFORFILL
  Raz SZDATAFORFILL
  IWHERE = 1

Local Char SZCTAOB
Local Char SZCTAOBTITLE(100)
Local Char SZCTAOBNUM(100)
Local Char SZCTLEVEL
Local Char SZCTPARENTAOB
Local Char SZCTPARENTNUM

  SZCTAOB = ""
  SZCTAOBTITLE = ""
  SZCTAOBNUM = ""
  SZCTLEVEL = ""
  SZCTPARENTAOB = ""
  SZCTPARENTNUM = ""
  #Fichier XSL
  SZWFNAME = SZXSLSHEET
  SZXMLFILENAME = ""
  #Ouverture du fichier XSL
  Call BUILDFICNAME(IWHERE, SZWFNAME, "xsl", SZXMLFILENAME) From CRMXML140
  If SZXMLFILENAME = "" Then
    #Erreur lors de l'ouverture du fichier XML
    IERRINF = 95
    ICHAPTER = 177
    #On restaure les variables adxifs et adxirs
    adxifs = SZADXIFS
    adxirs = SZADXIRS
    End
  Endif

#Définition des couleurs par défaut.
Local Char SZTABLEBORDER
Local Char SZHEADERTEXT
Local Char SZHEADERBACK
Local Char SZHEADERBORDER
Local Char SZLINETEXT
Local Char SZLINEBACK

  SZLINEBACK = "#E6F0F5"
  SZLINETEXT = "#006699"
  SZHEADERBORDER = "#006699"
  SZHEADERBACK = "#FF9933"
  SZHEADERTEXT = "#006699"
  SZTABLEBORDER = "#006699"
  #Modification des couleurs standards par point d'entrée
  Gosub PE_MGGCOLXSL From TRTCRMPE
  Openo SZXMLFILENAME, 0 Using [FXSL]
  #<?xml version="1.0" encoding="ISO-8859-1" standalone="yes" ?>
  SZBUFFTOFILL(0) = A + "?xml version=" + VQ + "1.0" + VQ + " encoding=" + VQ  + "ISO-8859-1" + VQ + " standalone=" + VQ + "yes" + VQ + " ?" + D
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" version="1.0">
  SZBUFFTOFILL(0) = A + "xsl:stylesheet xmlns:xsl=" + VQ + "http://www.w3.org/1999/XSL/Transform" + VQ + " version=" + VQ + "1.0" + VQ + D
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<xsl:output method="html"/><xsl:template match="/">
  SZBUFFTOFILL(0) = A + "xsl:output method=" + VQ + "html" + VQ + "/><xsl:template match=" + VQ + "/" + VQ + D
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<HTML><HEAD><TITLE><xsl:value-of select="//XUTILITY/XTITLE"/></TITLE><STYLE>
  SZBUFFTOFILL(0) = A + "HTML" + D + A + "HEAD" + D + A + "TITLE" + D + A + "xsl:value-of select=" + VQ + "//XUTILITY/XTITLE" + VQ + "/></TITLE><STYLE>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #TABLE.cX3Table {BORDER-STYLE:solid;BORDER-COLOR:#006699;BORDER-WIDTH:1;FONT-SIZE:x-small}
  SZBUFFTOFILL(0) = "TABLE.cX3Table {BORDER-STYLE:solid;BORDER-COLOR:" + SZTABLEBORDER + ";BORDER-WIDTH:1;FONT-SIZE:x-small}"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #TD.cX3TDHeader {FONT-STYLE:ITALIC;COLOR:#006699;BACKGROUND-COLOR:#FF9933;BORDER-STYLE:solid;BORDER-COLOR:#006699;BORDER-WIDTH:1}
  SZBUFFTOFILL(0) = "TD.cX3TDHeader {FONT-STYLE:ITALIC;COLOR:" + SZHEADERTEXT + ";BACKGROUND-COLOR:" + SZHEADERBACK + ";BORDER-STYLE:solid;BORDER-COLOR:" + SZHEADERBORDER + ";BORDER-WIDTH:1}"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #TD.cX3TDLine {FONT-STYLE:NORMAL;COLOR:#006699;BACKGROUND-COLOR:#E6F0F5}
  SZBUFFTOFILL(0) = "TD.cX3TDLine {FONT-STYLE:NORMAL;COLOR:" + SZLINETEXT + ";BACKGROUND-COLOR:" + SZLINEBACK + "}"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #</STYLE></HEAD><BODY><DIV><xsl:apply-templates select="//XCTITLES"/></DIV></BODY></HTML></xsl:template>
  SZBUFFTOFILL(0) = "</STYLE></HEAD><BODY><DIV><xsl:apply-templates select=" + VQ + "//XCTITLES" + VQ + "/></DIV></BODY></HTML></xsl:template>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<xsl:template match="//XCTITLES">
  SZBUFFTOFILL(0) = "<xsl:template match=" + VQ + "//XCTITLES" + VQ + D
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<TABLE CELLSPACING="5" CELLPADDING="5" CLASS="cX3Table">
  SZBUFFTOFILL(0) = A + "TABLE CELLSPACING=" + VQ + "5" + VQ + " CELLPADDING=" + VQ + "5" + VQ + " CLASS=" + VQ + "cX3Table" + VQ + D
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<THEAD><TR><xsl:apply-templates select="./XCOLTITLE"/></TR></THEAD>
  SZBUFFTOFILL(0) = "<THEAD><TR><xsl:apply-templates select=" + VQ + "./XCOLTITLE" + VQ + "/></TR></THEAD>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<TBODY><xsl:apply-templates select="//XRECORD"/></TBODY></TABLE></xsl:template>
  SZBUFFTOFILL(0) = "<TBODY><xsl:apply-templates select=" + VQ + "//XRECORD" + VQ + "/></TBODY></TABLE></xsl:template>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<xsl:template match="//XCOLTITLE"><TD CLASS="cX3TDHeader"><xsl:apply-templates/></TD></xsl:template>
  SZBUFFTOFILL(0) = "<xsl:template match=" + VQ + "//XCOLTITLE" + VQ + "><TD CLASS=" + VQ + "cX3TDHeader" + VQ + "><xsl:apply-templates/></TD></xsl:template>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<xsl:template match="//XRECORD"><TR><xsl:apply-templates select="./XFIELD"/></TR></xsl:template>
  SZBUFFTOFILL(0) = "<xsl:template match=" + VQ + "//XRECORD" + VQ + "><TR><xsl:apply-templates select=" + VQ + "./XFIELD" + VQ + "/></TR></xsl:template>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #<xsl:template match="//XFIELD"><TD CLASS="cX3TDLine"><xsl:apply-templates/></TD></xsl:template></xsl:stylesheet>
  SZBUFFTOFILL(0) = "<xsl:template match=" + VQ + "//XFIELD" + VQ + "><TD CLASS=" + VQ + "cX3TDLine" + VQ + "><xsl:apply-templates/></TD></xsl:template></xsl:stylesheet>"
  Wrseq SZBUFFTOFILL(0)  Using [FXSL]
  #On ferme le fichier XML
  Openo Using [FXSL]
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
End
