#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRC06   Migration de la table SALESREP       Module TC        #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   #--- Issue 108760 by TS
   #Call SAIDOS(DOSSIER,"") From SAIDOS
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
   #---
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  #--- Issue 108760 By TS
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  #---
  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRC06") From LECFIC
  Endif

  #Call RAZ_UUMGTRTTRC06(DOSSIER)
  Call MAJ_UUMGTRTTRC06(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

Subprog MAJ_UUMGTRTTRC06(DOSSIER)
Value Char DOSSIER

#--- Issue 108760 by TS
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
#---
Local Integer ERR
##1 - verifications
####################

If [F:ADS]MODULE(8)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC06",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

Local Char WNAMREPM
Call MIGTABNAME (DOSSIER,"SALESREP",WNAMREPM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC06",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMREPM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC06",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC06",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC06",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Integer NBLUS, ERR, NBCOMMIT
# Issue 112303 - 2015-11-09 by MAE : Déplacement des variables
#Local Char WTAB_REP (100) (adxwrb)
#Local Shortint WCPT_REP

Call ECR_TIME("UUMGTRTTRC06 tables REP Process : Update REP") From DOSSUB
Call ECR_TRACE("UUMGTRTTRC06 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"SALESREP",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:REP])  = 0 : Local File =DOSSIER+".SALESREP"    [REP]  : Endif   # Fichier X3 "Vide"

If clalev([F:REPM]) = 0 : Local File =DOSSIER+"."+WNAMREPM   [REPM] : Endif   # Fichier X3 renommé Avant Migration

If clalev([F:BPR]) = 0 : Local File =DOSSIER+".BPARTNER"   [BPR] : Endif   # Tiers

#-----  Déclaration des variables -----#
# Issue 112303 - 2015-11-09 by MAE : Déplacement des variables
Local Char WTAB_REP (100) (adxwrb)
Local Shortint WCPT_REP
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=2
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE,NBCOMMIT

# Déclaration des variables communes de travail
Local Integer I, J

#Lecture de la table CADIEDEF
Local File =[F:ADS]DOSSIER+".CADIEDEF"     [CDI]
Local Integer NBCDI : NBCDI=nbrecord([CDI])
Local Char WDIE(GLONDIE)(0..20)
Local Integer WNBRDIE
Local Integer WI
Raz WI
Read [CDI]CDI0 = 3
  If !fstat
    WNBRDIE = [F:CDI]NBRDIE
    For WI=0 To [F:CDI]NBRDIE-1
      WDIE(WI)=[F:CDI]DIE(WI)
    Next
  Endif

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTTRC06",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(2))

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRC06" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_REP00
Raz NB
If STOP=1
 STOP = 0
 CRITERE = "[F:REPM]REPNUM>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [REP]
GOK = 1

For [REPM] Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1
  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTTRC06" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_REP
  Endif
  # version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_REP
  Endif
  [F:REP] = [F:REPM]

  #Appel proc de migration sur entete
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_REP
    If GOK<1 : Break : Endif
  Endif

  # Passage en V7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_REP
    If GOK<1 : Break : Endif
  Endif


  ############################
  #-- Boucle sur les lignes
  ############################
  If GOK<1 : Break : Endif

  # --- alimentation des champs et écriture enreg
  #--- Issue 108760 by TS
  #If NEWMOTEUR
  #    Gosub REP_STK : # pour stocker ref
  #    WriteB [F:REP]
  #Else
  #    Write [F:REP]
  #Endif
  #If fstat
  # If NEWMOTEUR & adxwrb>1
  #    Call ECR_TRACE("File SALESREP, Error ="-num$(fstat),1) From GESECRAN
  #    Gosub REP_ERRTRA : # pour afficher les ref
  #  Else
  #    Call ECR_TRACE("File SALESREP(REPNUM)"-[F:REP]REPNUM+", Error ="-num$(fstat),1) From GESECRAN
  #  Endif
  #  GOK=0 : Break
  #Endif
  Gosub REP_STK : # pour stocker ref
  WriteB [F:REP]
  If fstat
    Call ECR_TRACE("File SALESREP, Error ="-num$(fstat),1) From GESECRAN
    Gosub REP_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif
  #---

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:REPM]REPNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC06",7,ERR) From TRTMIG : #7=Erreur
Else
  #--- Issue 108760 by TS
  #If NEWMOTEUR & adxwrb>1
    Flush [F:REP]
    If fstat
        Call ECR_TRACE("File SALESREP, Error ="-num$(fstat),1) From GESECRAN
        Gosub REP_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
  #--- Issue 108760 by TS
  #Endif
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(2)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTTRC06",NBMIGKEY,TABMIGKEY,NBLUS,NB+NBCOMMIT,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTTRC06",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_REP00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [REP]
Close Local File [REPM]
Close Local File [BPR]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"SALESREP",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTTRC06") From TRTMIG
Call ECR_TIME("UUMGTRTTRC06 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

################################################
$MAJV6_REP
Gosub RECUP_BPR
Return
################################################
$MAJV7_REP
Return
################################################
$RAZV6_REP
Raz [F:REP]BPAADD
Raz [F:REP]CFY
If dim([F:REP]CRESTP)>0 Raz [F:REP]CRESTP : Endif
Raz [F:REP]CUR
Raz [F:REP]DIE
If dim([F:REP]IDTSGL)>0 Raz [F:REP]IDTSGL : Endif
If dim([F:REP]UPDSTP)>0 Raz [F:REP]UPDSTP : Endif
Return
################################################
$RAZV7_REP
Return
################################################
$RECUP_BPR

If ([F:REP]CUR="" | [F:REP]BPAADD="")
  If [F:BPR]BPRNUM<>[F:REP]REPNUM
     Read [BPR]BPR0=[F:REP]REPNUM : If fstat Raz [F:BPR] Endif
  Endif
  If [F:REP]CUR=""    [F:REP]CUR=[F:BPR]CUR : Endif
  If [F:REP]BPAADD="" [F:REP]BPAADD=[F:BPR]BPAADD : Endif
Endif

#mise à jour des sections analytiques
Raz WI
For WI=0 To WNBRDIE-1
   If WI<dim([F:REP]DIE)
    If [F:REP]DIE(WI)="" [F:REP]DIE(WI)=WDIE(WI) : Endif
   Else
    Break
   Endif
Next
Return


################################################
$REP_STK
Call STK (WTAB_REP,WCPT_REP,[F:REP]REPNUM) From TRTMIG
Return
##############################################################################################
$REP_ERRTRA
Call ERRTRA (WTAB_REP,WCPT_REP,"File SALESREP(REPNUM)=") From TRTMIG
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
#--- Issue 108760 by TS
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
#---
Call MAJ_UUMGTRTTRC06(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTTRC06(APPLI)
End

#######################################################################
# Suppression pour pouvoir relancer la moulinette
########################################################################
Subprog RAZ_UUMGTRTTRC06(DOSSIER)
Value Char DOSSIER

Local Integer ERR
##1 - verifications
####################
If [F:ADS]MODULE(8)<>2 : End : Endif          : # N= no module

Local Char WNAMREPM
Call MIGTABNAME (DOSSIER,"SALESREP",WNAMREPM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMREPM,"fde",[F:ADS]DOSSIER),0) < 0 :  End : Endif

Call MIGTABRAZ (DOSSIER,"SALESREP",ERR) From TRTMIG

Call MIGRAZKEY (DOSSIER,"UUMGTRTTRC06",ERR) From TRTMIG

End

