#<AdxTL>@(#)2.0.0.0 $Revision$
## Changement de clé pour les tables ayant LEG en deuxième partie de clé (GTYPACCENT, GJOURNAL)
## Exemple : Changement de clé dans GJOURNAL
## Si les champs LEG ou CPY ou GTE/VCR existent dans la table liée
## On change la clé dans la table liée si la législation de CPY correspond à la legislation du code journal
## sur lequel on fait le changement de clé. Si on change la clé sur un code journal avec législation="",
## alors on change la clé si la législation de CPY n'a pas d'enregistrement avec ce code journal dans GJOURNAL

## Si les champs LEG ou CPY ou GTE/VCR n'existent pas dans la table liée
## On change la clé dans la table liée si le code journal n'est décliné sur aucune autre législation que celle
## sur laquelle on fait le changement de clé => dernier enregistrement dans GJOURNAL sur ce code

## SUPP = LEG

## Key change for the tables with LEG in the second part of the index (GTYPACCENT, GJOURNAL)
## For example : Change key in GJOURNAL
## If the linked table contains one of these fields : LEG or CPY or GTE/VCR, X3 changes the key in the
## linked table if the company's legislation matches with the journal code's legislation. These fields allow X3
## to find the recording's legislation. If the key change occurs with an empty legislation, then the key change
## is done in the linked table,if it doesn't exist a journal recording with the same company's legislation
## as the linked table's recording.

## If the fields LEG or CPY or GTE/VCR don't exist in the linked table, the change key occurs in the
## linked table if there is no more recording of this journal code in GJOURNAL => last recording
## of the code journal in GJOURNAL.

## SUPP = LEG

Subprog CHGCOD(OBJET,CLE1,CLE2,OK)
Value    Char OBJET
Variable Char CLE1()
Variable Char CLE2()(1..)
Variable Integer OK
Local Char    VALBOUT(30), PARBOUT(250)(1..4)
PARBOUT(1) = OBJET
PARBOUT(2) = CLE2(1)
PARBOUT(3) = CLE1
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","CHGCLELEG","CHGCOD",3,"") From GTRAITE
CLE1 = PARBOUT(3)
CLE2(1) = PARBOUT(2)
OK = val(PARBOUT(4))
End

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "CONTROLE" : Gosub CONTROLE
 When "SORTIE"   : Gosub SORTIE
 When "EXEC"     : Gosub EXEC
Endcase
Return

#################################################################################################
$INIT
Local Char     OCODE(250), NCODE(250), TEXTE(250)
Local Char     PROGOBJ(GLONADC) , PROGSUB(GLONADC) , PROGSPE(GLONADC) , PROGSPV(GLONADC)
Local Integer  PSUB , PSPE , PSPV , PSTD
Local Char     TYP(GLONAOB), ABREV(GLONAOB)
Local Char     SAVFONC(GLONAFC) , IDENT(250), OIDENT(250), DEFMSK(250)
Local Char     CODE(250), OFMT(250), NFMT(250), FMT2(250), NOMDOS(20)(1..2)
Local Char     PCLE1(250), PCLE2(250), SUPP(250)(16)
Local Integer  I, LG, NDOS
Global Char    GOTHLEG(GLONADI) (1..GNBLEG) : # Array of the legislations of CODE
Global Integer GNBROTHLEG                   : # Number of legislations
Local Char     SAVCLEPRI(GLONAVA)

Local File AOBJET [AOB_] , ATABLE [ATB_] , ATABZON [ATZ_] , ATEXTE [ATX] , ATEXTRA [AXX]
Local File ATABZON    [ATZZ] : # Used to fill the array GOTHLEG
Local File COMPANY    [CPY]
Local File FACILITY   [FCY]
Local File GACCENTRY  [HAE]
Local File GACCENTRYD [DAE]

NDOS = 1 : NOMDOS(NDOS) = nomap(0)
If GDOSH<>""
 NDOS += 1 : NOMDOS(NDOS) = GDOSH
Endif

TYP   = PARAM(1)
CODE  = PARAM(2)
Call SUPPN(PARAM(3),SUPP) From CONTOBJ
SUPP  = PARAM(3)
ABREV = PARAM(1)
PARAM(4)  = "0"           : # Status de retour
If TYP="" : FIN = 1 : Return : Endif

Read [AOB_]ABREV = TYP
If fstat : FIN=1 : Return : Endif

Read [ATB_]CODFIC = [F:AOB_]NOMFIC
If fstat : FIN=1 : Return : Endif

Call SETPROG(TYP,PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
Gosub NOMFIC From =PROGOBJ
Gosub TIT    From =PROGOBJ
Gosub SETCLE From =PROGOBJ
CLEPRI  = CLEPRIM
CLEPRIM = CLESEC
CLESEC  = CLEPRI

Local File =NOMFIC [AN__]
Gosub OUVFIC From =PROGOBJ
Raz GOTHLEG, GNBROTHLEG

# Fill the globals
Filter [F:AN__] Where evalue(CLEPRIM)=CODE & LEG<>SUPP
For [F:AN__]
 GNBROTHLEG +=1
 GOTHLEG(GNBROTHLEG) = [F:AN__]LEG
Next
Filter [F:AN__]

Assign "[F]"+CLEPRIM With CODE
[F]LEG=SUPP

# FGR 22/04/2013 : X3SUIVI71937 : changement de clé sur PK > 2 éléments (début)
  #Read [F]=
Local Integer IREADDEF

  Assign "[F]"+CLEPRIM With CODE
  [F]LEG=SUPP
  IREADDEF = 0 # Doit être positionné à 0 par READ_CHGCOD si utilisé
  ACTION = "READ_CHGCOD" : Gosub ACTION From GOBJET
  If IREADDEF = 0 Then
    Read [F]=
  Endif
  If fstat : FIN=1 : Return : Endif
  [F:AN__] = [F]
# FGR 22/04/2013 : X3SUIVI71937 : changement de clé sur PK > 2 éléments (fin)

DEFMSK = dbgstr(1)
Local Mask CHGCOD [DIAX]
Default Mask DEFMSK

Call FORMCLE2(NFMT) From =PROGOBJ
I=instr(1,NFMT,":")
If I & !instr(1,left$(NFMT,I-1),"P") : OFMT=left$(NFMT,I-1)+"P"+right$(NFMT,I) : Endif
Call FORMCLE(FMT2,LG,TEXTE) From =PROGOBJ

Raz [M:DIAX]
[M:DIAX]TYP    = TYP    : # Object
[M:DIAX]LIBOBJ = TIT    : # Description of the object
[M:DIAX]OFMT   = OFMT   : # Format of the former code
[M:DIAX]NFMT   = NFMT   : # Format of the new code
[M:DIAX]OCODE = num$(evalue("[F:"+[L]ABFIC+"]"+CLEPRIM))
[M:DIAX]CLE2 = 1
[M:DIAX]SUPP = num$(evalue("[F:"+[L]ABFIC+"]"+CLESEC))

# Description of the parameter
If [M:DIAX]CLE2
 If left$(FMT2,1)="L"
  [M:DIAX]INTIT += mess(val([M:DIAX]SUPP),val(right$(FMT2,3)),1)
 Else
  [M:DIAX]INTIT += [M:DIAX]SUPP
 Endif
Endif
If [M:DIAX]INTIT<>""
 [M:DIAX]INTIT ="("+[M:DIAX]INTIT+")"
Endif

# Description of the former code
If [F:ATB_]INTIT<>""
 If evalue("type([F:"+[L]ABFIC+"]"+[F:ATB_]INTIT+")")>10
  [M:DIAX]INTIT -= evalue("[F:"+[L]ABFIC+"]"+[F:ATB_]INTIT)
 Else
  TEXTE=""
  Read [ATZ_]CODZONE = [F:ATB_]CODFIC ; [F:ATB_]INTIT
  If !fstat
   If [F:ATZ_]CODTYP="ATX"
    Call TEXTE(evalue("[F:"+[L]ABFIC+"]"+[F:ATB_]INTIT),TEXTE) From OBJDIV
   Elsif find([F:ATZ_]CODTYP,"AXX","AX1","AX2","AX3")
    If [M:DIAX]CLE2
     PCLE1 = CODE
     PCLE2 = SUPP
    Else
     PCLE1 = CODE
    Endif
    Call LECTEXTRA(TEXTE,[F:ATB_]CODFIC,[F:ATB_]INTIT,PCLE1,PCLE2) From ATEXTRA
   Endif
  Endif
  If TEXTE<>""
   If [M:DIAX]INTIT<>"" : [M:DIAX]INTIT-= TEXTE
   Else                 : [M:DIAX]INTIT = TEXTE
   Endif
  Endif
 Endif
Endif
Return

#################################################################################################
## Check that no record exists with the new code/leg
$CONTROLE
Call CONTROLE(ABREV,"",num$([M:DIAX]SUPP),num$([M:DIAX]NCODE),mkstat) From CONTOBJ
If mkstat=0
 GERR=1 : GMESSAGE = mess(22,100,1) : # Fiche déjà existante
 SAI=1 : Return
Endif
OCODE = num$([M:DIAX]OCODE)
NCODE = num$([M:DIAX]NCODE)
SUPP = num$([M:DIAX]SUPP)
Return

#################################################################################################
## Kill the globals
$SORTIE
Kill GOTHLEG, GNBROTHLEG
Return

#################################################################################################
$EXEC
GOK=1
For I=NDOS To 1 Step -1
 Call CHGTCLE(NOMDOS(I),TYP,OCODE,NCODE,SUPP(0),CLEPRIM,CLESEC)
 If GOK<1 : Break : Endif
Next I
If GOK<1 : FIN=1 : Return : Endif
CODE = NCODE
SAVFONC = GFONCTION
GFONCTION = "GES"+TYP
Call IDENT3(TYP,IDENT,CODE,SUPP) From GOBJTXT
Call ESPION(NOMFIC,6,OIDENT,IDENT) From ESPION
Call WORKFLOW(2,TYP,"H",IDENT) From AWRK
GFONCTON = SAVFONC
PARAM(2) = CODE
PARAM(3) = SUPP(0)
PARAM(4) = "1"
Return

#################################################################################################
Subprog CHGTCLE(APPLI,ABREV,OCODE,NCODE,SUPP,PCLE1,PCLE2)
Value Char APPLI()
Value Char ABREV()
Value Char OCODE()
Value Char NCODE()
Value Char SUPP()
Value Char PCLE1()
Value Char PCLE2()
# 0 = No field in the table allow us to find the legislation of the record
# 1 = Field with data type ADI 909 (miscellaneous table for LEG) exists in the table
# 2 = Field with data type CPY exists in the table
# 3 = Fields with data type GTE and VCR exist in the table
Local Integer FLGLEGCPY :# Enable to find the legislation of the record
Local Char    NAMFLD(GLONAVA)  # Name of the field whose data type is ADI, CPY or GTE
Local Char    NAMFLD2(GLONAVA) # Name of the field whose data type is VCR
Local Integer INDFCY, INDCPY

Gosub DEFVAR From CHGCOD
Onerrgo ERRCHG

If nomap=APPLI or filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<0
 Local File ADOVAL [ADW]
Else
 Local File =APPLI+".ADOVAL" [ADW]
Endif
Read [ADW]ADW0 = "";"";"TYPDBA"
Close Local File [ADW]

Gosub OUVFIC From CHGCOD

Call OUVRE_VLC(mess(2,115,1)-APPLI,"","") From GESECRAN : # Changement de code
Call AFF_VLC(mess(56,123,1),"") From GESECRAN : # Table

#FICANU = GJOURNAL or GTYPACCENT
Read [AOB_]ABREV = ABREV
Read [ATB_]CODFIC = [F:AOB_]NOMFIC
If fstat : GOK=0 : End : Endif
FICANU = [F:ATB_]CODFIC

SUBCLE(1) = PCLE1
SUBCLE(2) = PCLE2
NBCLE     = 2

If ![L]TRANS : Call DEBTRANS From GLOCK : Endif
FICDEB = "" : Gosub TR1

If APPLI<>HISDOS
 ACTION = "AP_CHANGE" : Gosub ACTION From GOBJET
Endif

Call FERME_VLC From GESECRAN
End

#################################################################################################
$TR1
FICOUV=0 : CONTINUE=0 : GOK=1
If ![L]TRANS : Trbegin [ATZ_] : Endif
For [ATZ_]LIEN(2) Where LIEN=FICANU & CODFIC>FICDEB
  FICHIER = [F:ATZ_]CODFIC
  Read [ATB_]CODFIC = FICHIER
  Call AFF_VLC(mess(56,123,1),[F:ATZ_]CODFIC) From GESECRAN : # Table
  K = 0
  If [F:ATB_]TYPFIC=3 & nomap=APPLI & filinfo(filpath("FIL",FICHIER,"fde"),0)>0 : # Table système
   K = 1
  Elsif filinfo(filpath("FIL",FICHIER,"fde",APPLI),0)>0
   K = 1
  Endif
  If K & APPLI=HISDOS
   Call VUE_OK(FICHIER,APPLI,"FIL",K) From DOSVUE
   K = !K
  Endif
  If K
   # Fill the variables FLGLEGCPY & NAMFLD
   Raz NAMFLD, NAMFLD2
   FLGLEGCPY = 0
   Filter [ATZZ] Where CODFIC=FICHIER &
&   ( (CODTYP="ADI" & instr(1,EXPLIEN,"909")) | CODTYP="CPY" | CODTYP="GTE")
&  Order By CODTYP;NUMLIG
   Read [ATZZ] First
   Filter [ATZZ]
   If !fstat
    Case [F:ATZZ]CODTYP
     When "ADI"    : FLGLEGCPY = 1 : NAMFLD = [F:ATZZ]CODZONE
     When "CPY"    : FLGLEGCPY = 2 : NAMFLD = [F:ATZZ]CODZONE
     When "GTE"    : FLGLEGCPY = [F:ATZZ]NUMLIG : NAMFLD = [F:ATZZ]CODZONE
      Filter [ATZZ] Where CODFIC=FICHIER & CODTYP="VCR" & NUMLIG>FLGLEGCPY
      Read [ATZZ]NUMLIG First
      Filter [ATZZ]
      If !fstat
       FLGLEGCPY = 3 : NAMFLD2 = [F:ATZZ]CODZONE
      Else
       FLGLEGCPY = 0 : Raz NAMFLD
      Endif
    Endcase
   Endif
   # There are another records in the table GJOURNAL with this journal code
   # and the fields LEG, CPY, GTE and VCR, aren't in the table FICHIER => No change key in the table FICHIER
   If GNBROTHLEG<>0 & FLGLEGCPY=0 : K = 0 : Endif
  Endif
  If K
   If nomap=APPLI
    Local File =FICHIER
   Else
    Local File =APPLI+"."+FICHIER
   Endif
   ANCIEN = OCODE : NOUVEAU = NCODE
   Raz NBZ , INDZ  , NOCRIT , CRITERE , ICRITERE , NBCRIT

   For [ATZ_]LIEN
    If FICHIER<>[F:AOB_]NOMFIC or !find([F:ATZ_]CODZONE,SUBCLE)
     NOLIEN = 0
     NBZ += 1
     ZONE(NBZ) = [F:ATZ_]CODZONE
     DIME(NBZ) = evalue("dim([F:"+[ATB_]ABRFIC+"]"+[F:ATZ_]CODZONE+")")
     SUBCRIT = ""
     If [F:ATZ_]EXPLIEN=""
      Case evalue("type([F:AN__]"+SUBCLE(1)+")")
       When 1,2,4,5,6,7,8,9
        VALEUR = num$(evalue("[F:AN__]"+SUBCLE(1)))
       When 3
        VALEUR = '['+num$(evalue("[F:AN__]"+SUBCLE(1)))+']'
       When Default
        VALEUR = '"'+evalue("[F:AN__]"+SUBCLE(1))+'"'
      Endcase
      If DIME(NBZ)=1
       SUBCRIT = [F:ATZ_]CODZONE+'='+VALEUR
      Endif
      SZONE(NBZ,1) = [F:ATZ_]CODZONE
      TYPZ(NBZ,1) = 1
     Else
      CLE1 = vireblc(format$("KT:80X",[F:ATZ_]EXPLIEN),2)
      I1 = 0
      I2 = 0
      While CLE1<>""
       I1 += 1
       K = instr(1,CLE1,";")
       If K
        SZONE(NBZ,I1) = left$(CLE1,K-1) : CLE1 = right$(CLE1,K+1)
       Else
        SZONE(NBZ,I1) = CLE1 : CLE1 = ""
       Endif
       # zone CTRLVL de dim>1, on fait ici comme si l’expression de lien n’est pas FCY;DEP;ITM;CTRLVL mais FCY;DEP;ITM;CTRLVL(indice)
       If DIME(NBZ)>1 & SZONE(NBZ,I1)=ZONE(NBZ) : SZONE(NBZ,I1)+="(indice)" : Endif
      Wend
      For I1=1 To NBCLE
       Read [AT2_]CODZONE = FICHIER;SZONE(NBZ,I1)
       If !fstat
        TYPZ(NBZ,I1) = 1
        Case evalue("type([F:AN__]"+SUBCLE(I1)+")")
         When 1,2,4,5,6,7,8,9
          VALEUR = num$(evalue("[F:AN__]"+SUBCLE(I1)))
         When 3
          VALEUR = '['+num$(evalue("[F:AN__]"+SUBCLE(I1)))+']'
         When Default
          VALEUR = '"'+evalue("[F:AN__]"+SUBCLE(I1))+'"'
        Endcase
        If SUBCRIT<>"" : SUBCRIT += " & " : Endif
        SUBCRIT += SZONE(NBZ,I1)+'='+VALEUR
        If NBCRIT=1 & CRITERE="("+SUBCRIT+")" : Break : Endif
        # optimisation du critere pour éviter des ‘or’ inutiles
       Else
        TYPZ(NBZ,I1) = 0 : # Case of [V]GSUPCLE
       Endif
      Next I1
     Endif
     If NOLIEN
      NBZ -= 1
     Elsif NOCRIT=0
      If SUBCRIT=""
       NOCRIT=1
      Else
       K = 0
       For I3=1 To dim(CRITERE)
        K = instr(1,CRITERE(I3),"("+SUBCRIT+")")
        If K : Break : Endif
       Next I3
       If !K
        If NBCRIT
         For I3=1 To dim(CRITERE)
          # optimisation du critere pour éviter des ‘or’ inutiles
          If pat(CRITERE(I3),string$(NBCRIT-1,"("+SUBCRIT+" & *) | ")+"("+SUBCRIT+" & *)")
           Raz CRITERE , ICRITERE , NBCRIT
           Break
          Endif
         Next I3
        Endif
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+SUBCRIT+")","|") From GOBJSUB
        NBCRIT += 1
       Endif
      Endif
     Endif
    Endif
   Next ATZ_
   If NBZ<>0
    If NOCRIT : Raz CRITERE : Endif
    Gosub TRT_NORM
    If GOK<1 : Break : Endif
   Endif
   If MAXFIC
    FICOUV += 1
    If FICOUV>=MAXFIC
     CONTINUE = 1 : FICDEB = FICHIER : Break
    Endif
   Endif
  Endif
 Next ATZ_(2)
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Elsif !CONTINUE
  ## Key change in the table GJOURNAL
  If APPLI<>HISDOS
   Gosub NOMFIC From ="WO"+ABREV
   Gosub SETCLE From ="WO"+ABREV
   CLEPRI  = CLEPRIM
   CLEPRIM = CLESEC
   CLESEC  = CLEPRI
   If APPLI=nomap
    Local File =NOMFIC [CHGT]
   Else
    Local File =APPLI+"."+NOMFIC [CHGT]
   Endif
   Raz CRITERE , ICRITERE

    Case evalue("type([F:CHGT]"+CLEPRIM+")")
     When 1,2,4,5,6,7,8,9 : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLEPRIM+'='+OCODE,"") From GOBJSUB
     When 3               : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLEPRIM+'=['+num$(OCODE)+']',"") From GOBJSUB
     When Default         : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLEPRIM+'="'+OCODE+'"',"") From GOBJSUB
    Endcase
    If CLESEC<>""
     Case evalue("type([F:CHGT]"+CLESEC+")")
      When 1,2,4,5,6,7,8,9 : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLESEC+'='+SUPP,"&") From GOBJSUB
      When 3               : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLESEC+'=['+num$(SUPP)+']',"&") From GOBJSUB
      When Default         : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLESEC+'="'+SUPP+'"',"&") From GOBJSUB
     Endcase
    Endif

   For [CHGT] Where evalue(CRITERE)
    If dim([L]CLEVALEUR)<0
     Case evalue("type([F:CHGT]"+CLEPRIM+")")
      When 1,2,4,5,6,7,8,9
       Assign "[F:CHGT]"+CLEPRIM With val(NCODE)
      When 3
       Assign "[F:CHGT]"+CLEPRIM With gdat$(NCODE)
      When Default
       Assign "[F:CHGT]"+CLEPRIM With NCODE
     Endcase
    Else
     Case evalue("type([F:CHGT]"+CLEVALEUR+")")
      When 1,2,4,5,6,7,8,9
       Assign "[F:CHGT]"+CLEVALEUR With val(NCODE)
      When 3
       Assign "[F:CHGT]"+CLEVALEUR With gdat$(NCODE)
      When Default
       Assign "[F:CHGT]"+CLEVALEUR With NCODE
     Endcase
    Endif
    If APPLI<>HISDOS
     ACTION = "CHANGE" : Gosub ACTION From GOBJET
    Endif
    If   GOK<1 : Break : Endif
    Rewrite [CHGT]
    If fstat
     GOK=0 : Call FSTA("CHGT") From GLOCK : Break
    Endif
   Next CHGT
   If   GOK<0 : Goto ROLL_TR1
   Elsif !GOK : Goto AB_TR1
   Endif
  Endif
 Endif
If ![L]TRANS : Commit : Endif
If CONTINUE
 Close Local File
 Gosub OUVFIC From CHGCOD
 Goto TR1
Endif

## Vérif dans les paramètres
If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 or APPLI=HISDOS
 Return
Endif
If nomap=APPLI
 Local File ADOPAR [ADP]
&         , ADOVAL [ADW]
Else
 Local File =APPLI+".ADOPAR" [ADP]
&         , =APPLI+".ADOVAL" [ADW]
Endif
If ![L]TRANS : Trbegin [ADW] : Endif

 For [ADP] Where OBJET=ABREV or TRAIT="SUB"+ABREV
  OK = 1
  If SUPP<>"" & [F:ADP]VALUES(0)<>"" & SUPP<>[F:ADP]VALUES(0)
   OK = 0
  Endif
  If OK=1
   For [ADW] Where PARAM=[F:ADP]PARAM & VALEUR=OCODE
    OK = 0 : INDCPY = 0
    If GNBROTHLEG=0
     OK = 1
    Else
     # Paramètre défini au niveau législation
     If [F:ADW]CMP="*" & ( [F:ADW]FCY=SUPP | (SUPP="" & !find([F:ADW]FCY,GOTHLEG(1..GNBROTHLEG))) )
      OK = 1
     Else
      # Paramètre défini au niveau société
      If ([F:ADW]CMP<>"*" & [F:ADW]CMP<>"")
       INDCPY = find([F:ADW]CMP,GSOC(1..GNBSOC))
      Endif
      # Paramètre défini au niveau site
      If [F:ADW]CMP="" & [F:ADW]FCY<>""
       INDFCY = find([F:ADW]FCY,GSITE(1..GNBSITE))
       If INDFCY
        INCPY = find(GSOCSITE(INDFCY),GSOC(1..GNBSOC))
       Endif
      Endif
      If INDCPY
       If GLEGSOC(INDCPY)=SUPP : OK=1 : Endif
       If SUPP="" & !find(GLEGSOC(INDCPY),GOTHLEG(1..GNBROTHLEG)) : OK = 1 : Endif
      Endif
     Endif
    Endif
    If OK=1
     [F:ADW]VALEUR = NCODE
     Rewrite [ADW]
     If fstat
      GOK=0 : Call FSTA("ADW") From GLOCK : Break 2
     Endif
    Endif
   Next ADW
  Endif
 Next ADP
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
If ![L]TRANS : Commit : Endif
Close Local File [ADP] , [ADW]
Return

$TRT_NORM
If CRITERE<>""
 Filter [F] Where evalue(CRITERE)
Endif
For [F]
 REW = 0
 For I=1 To NBZ
  For J=0 To DIME(I)-1
   indice = J
   Gosub TEST
  Next J
 Next I
 If REW
  Rewrite [F]
  If fstat
   For I=1 To adxmto
    If FICHIER=filename(I) | instr(1,filename(I),"/"+FICHIER)
     Break
    Endif
   Next
   GOK=0 : Call FSTA(fileabre(I)) From GLOCK : Break
  Endif
 Endif
Next
Filter [F]
Return

$TEST
# OK = 1 : Change the field in the record
# OK = 0 : Don't change the field in therecord
OK = 1
For K=1 To NBCLE
 If TYPZ(I,K)=1
  If instr(1,SZONE(I,K),"(")
   If evalue("[F:"+[F:ATB_]ABRFIC+"]"+SZONE(I,K))<>evalue("[F:AN__]"+SUBCLE(K))
    OK=0 : Break
   Endif
  Elsif J=0 | evalue("dim([F:"+[F:ATB_]ABRFIC+"]"+SZONE(I,K)+")")>J
   If evalue("[F:"+[F:ATB_]ABRFIC+"]"+SZONE(I,K)+"("+num$(J)+")")<>evalue("[F:AN__]"+SUBCLE(K))
    OK = 0 : Break
   Endif
  Endif
 Else
  If left$(SZONE(I,K),1)>="A" & left$(SZONE(I,K),1)<="Z"
   If evalue("[F:"+[F:ATB_]ABRFIC+"]"+SZONE(I,K))<>evalue("[F:AN__]"+SUBCLE(K))
    OK = 0 : Break
   Endif
  # FGR 22/04/2013 : X3SUIVI71937 : changement de clé sur PK > 2 éléments (début)
  #Elsif SZONE(I,K)="[V]GSUPCLE" | SZONE(I,K)="GSUPCLE"
  Elsif SZONE(I,K)="[V]GSUPCLE" | SZONE(I,K)="GSUPCLE" | SZONE(I,K)="[V]GCURLEG" | SZONE(I,K)="GCURLEG"
  # FGR 22/04/2013 : X3SUIVI71937 : changement de clé sur PK > 2 éléments (fin)
   OK = 0
   # No way to find the legislation of the record
   # and there's no record in the table GJOURNAL with this journal code

   #If FLGLEGCPY=0 & GNBROTHLEG=0
   If GNBROTHLEG=0
    OK = 1
   # NAMFLD contains a LEG
   Elsif FLGLEGCPY=1 & ( (SUPP="" & !find(evalue("[F:"+[F:ATB_]ABRFIC+"]"+NAMFLD),GOTHLEG(1..GNBROTHLEG)))
&                      | evalue("[F:"+[F:ATB_]ABRFIC+"]"+NAMFLD)=SUPP )
    OK = 1
   # NAMFLD contains a CPY
   Elsif FLGLEGCPY=2 & evalue("[F:"+[F:ATB_]ABRFIC+"]"+NAMFLD)<>""
    INDCPY = find(evalue("[F:"+[F:ATB_]ABRFIC+"]"+NAMFLD),GSOC(1..GNBSOC))
    If INDCPY & GLEGSOC(INDCPY)=SUPP : OK = 1 : Endif
    If INDCPY & SUPP="" & !find(GLEGSOC(INDCPY),GOTHLEG(1..GNBROTHLEG)) : OK = 1 : Endif
   Elsif FLGLEGCPY=3 & evalue("[F:"+[F:ATB_]ABRFIC+"]"+NAMFLD)<>""
&                    & evalue("[F:"+[F:ATB_]ABRFIC+"]"+NAMFLD2)<>""
    Read [HAE]HAE0=evalue("[F:"+[F:ATB_]ABRFIC+"]"+NAMFLD);evalue("[F:"+[F:ATB_]ABRFIC+"]"+NAMFLD2)
    If !fstat
     INDCPY = find([F:HAE]CPY,GSOC(1..GNBSOC))
     If INDCPY & GLEGSOC(INDCPY)=SUPP : OK = 1 : Endif
     If INDCPY & SUPP="" & !find(GLEGSOC(INDCPY),GOTHLEG(1..GNBROTHLEG)) : OK = 1 : Endif
    Endif
   Endif
   If OK=0 : Break : Endif
  Else
   If evalue(SZONE(I,K))<>evalue("[F:AN__]"+SUBCLE(K))
    OK = 0 : Break
   Endif
  Endif
 Endif
Next K
If OK
 NTYP = evalue("type([F:"+[F:ATB_]ABRFIC+"]"+ZONE(I)+"("+num$(J)+"))")
 Case NTYP
  When 1,2,4,5,6,7,8,9
   Assign "[F:"+[F:ATB_]ABRFIC+"]"+ZONE(I)+"("+num$(J)+")" With val(NOUVEAU)
  When Default
   Assign "[F:"+[F:ATB_]ABRFIC+"]"+ZONE(I)+"("+num$(J)+")" With NOUVEAU
 Endcase
 REW = 1
Endif
Return

$ROLL_TR1
If ![L]TRANS
 Rollback
 Call ROLL From GLOCK
 If GROLL : Return : Else : Goto TR1 : Endif
Else
 Return
Endif

$AB_TR1
If ![L]TRANS : Rollback : Endif
Return

$ERRCHG
Call ECR_TRACE(errp+"("+num$(errl)+")"-":"-errmes$(errn)-errm,1) From GESECRAN
If adxlog & ![L]TRANS : Rollback : Endif
End
