#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe PJMTSKLNK
#######################################################################################
# METHODS                                                                             #
#######################################################################################
$SETERROR
#Value Char PRO ()
#Value Char MES ()
#Value Integer STA
#Local Integer ARET_VALUE

Local Char SLEVEL(250)

  # Issue X3-28737/X3-26990- 2017-08-07 by TEJAC
  SLEVEL = func AFNC.MES3(mess(958,2260,1), this.OPPNUM, this.TASCOD, num$(this.SEQNUM))
  #[L]ARET_VALUE = fmet this.ASETERROR (PRO, SLEVEL + "\" + MES, STA)                                                    # Issue X3-85933 - 2018-06-19 by FGR
  [L]ARET_VALUE = fmet this.ASETERROR (func OPPOR_CSTD_PROGS_COM.GET_PROPERTY_TITLE(this, PRO), SLEVEL + "\" + MES, STA) # Issue X3-85933 - 2018-06-19 by FGR
Return

#######################################################################################
$COPY
#Variable Instance TARGET Using C_PJMTSKLNK : #
#Variable Instance TECCLA Using C_PJMACOPY : #
#Value Integer TECIDX
#Local Integer ARET_VALUE

Local Instance TECPJMCOPY Using C_TECPJMCOPY
Local Integer NI
Local Integer ILINE

  # Issue X3-27611 - 2017-11-27 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # --------------------
  TECPJMCOPY = NewInstance C_TECPJMCOPY AllocGroup null
  [L]ARET_VALUE = fmet this.COPY_LOAD_PROPERTIES(TECPJMCOPY, TECCLA, TECIDX)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Goto COPY_END
  Endif
  # --------------------
  # 1°) copy properties and translated texts
  [L]ARET_VALUE = func TECPJMCOPY_CSTD.DO_COPY_CHAIN(TECPJMCOPY, TECCLA, this, TARGET)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Goto COPY_END
  Endif
  # ---------------------------
$COPY_END
  If TECPJMCOPY <> null Then
    FreeGroup TECPJMCOPY
  Endif
Return

###################################################################################################
$COPY_LOAD_PROPERTIES
#Variable Instance TECPJMCOPY Using C_TECPJMCOPY : #
#Variable Instance TECCLA Using C_PJMACOPY : #
#Value Integer TECIDX
#Local Integer ARET_VALUE

Local Char SCHAINE(250)

  # Issue X3-27611 - 2017-11-27 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # --------------------
  Raz SCHAINE
  SCHAINE += "func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK("
  SCHAINE += "CLATARGET.ACTX,"
  SCHAINE += "CLATARGET.OPPNUM,"
  SCHAINE += "fmet TECCLA.GET_TASK_RECODIFIED(func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT_TASCOD(CLAFROM.ACTX, CLAFROM.PIMOPPTASLNK)))"
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("#" + SCHAINE, "PIMOPPTASLNK"))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("TASLNKTYP", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("TASLNKCSTR", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("TASLNKLAG", AVOID.ACHAR))
Return

