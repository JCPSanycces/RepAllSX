#<AdxTL>@(#)12.0.0.0 $Revision$
#<AdxTL>@(#)2.0.0.0 $Revision$
########################################################################
# TRTX3ESR : Traitements pour gestion des signatures électroniques     #
#            ESR => e-Signature Rules                  GA 10/2007      #
########################################################################
# Actions de l'écran ESIGNRUL [M:ESR], appelé par l'action SAIESIGNR
########################################################################
# CTLPASSE(LABRFIC,LRET)
# - ouverture de la fenêtre de saisie du mot de passe
########################################################################
# Fonctions appelées par les actions spécifiques d'un objet:
# Subprog E_SIGNATURE(LCPT,LABRFIC,LFCY,LDAT,LRET)
# Subprog WRI_CHGNUM(LABRFIC)
# Subprog DEL_CHGNUM(LABRFIC)
#
# Etiquettes appelées par les actions spécifiques d'un objet:
# $OUV_ESR
# $FIN_ESR
########################################################################

$ACTION
# Point d'entree generique actions e-Signatures ESR_+ACTION
# Ne pas oublier de tester GACTION dans le point d'entree
# Mettre GPE <> 0 pour inhiber l'action standard
#
Global Char GPOINT(30)
GPOINT = "ESR_"+ACTION
GPE    = 0
Gosub  ENTREE From EXEFNC
If GPE <> 0
   Return
Endif
#
Case ACTION
 When "OUVRE"    :  Gosub OUVRE
 When "DEBUT"    :  Gosub DEBUT
 When "OK"       :  Gosub BOUTON_OK
 When "END"      :  Gosub BOUTON_FIN
 When "FIN"      :  Gosub FIN
 When "FINSAI"   :  Gosub FINSAI
Endcase
Return

#--------------------------------------------------------------#
$DEBUT
  GFLGPWDOK = 0
  Raz [M:ESR]
Return
#--------------------------------------------------------------#
$FINSAI
  Raz [M:ESR]
Return

#--------------------------------------------------------------#
$BOUTON_OK
GMOTPWD = [M:ESR]MOTPWD : # Motif choisi - table div. ADI 101 : # FQ 46355 déplacé depuis FINSAI
If [M:ESR]SAIPWD="" & GFLGPWD<>1
   GFLGPWDOK=0 : # aucun mot de passe: renvoyer une erreur, sauf si GFLFPWD=1
Else
   GFLGPWDOK=1
Endif
Return

#--------------------------------------------------------------#
$BOUTON_FIN
   GFLGPWDOK=0 : # renvoyer une erreur
   # Issue 121159 - 2017-01-26 by MAE : on renvoit une erreur pour ne pas enregistrer si le mdp n'est pas bon
   mkstat = 2
Return


#--------------------------------------------------------------#
$FIN     : # Après Bouton Ok ou Fin
  Raz [M:ESR]
Return

#--------------------------------------------------------------#
$OUVRE
  If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
  If clalev([F:ADW])=0 : Local File ADOVAL  [ADW] : Endif
  If clalev([F:AES])=0 : Local File AESPION [AES] : Endif
  Gosub OUV_ESR
Return

#--------------------------------------------------------------#
$OUV_ESR : # Etiquette d'init pour les points d'entrée
  If dim(GCHGNUM)  <=0 : Global Char     GCHGNUM (GLONVCR)   : Endif
  If dim(GMOTPWD)  <=0 : Global Char     GMOTPWD (GLONADI)   : Endif
  If dim(GFLGPWDOK)<=0 : Global Shortint GFLGPWDOK           : Endif
  If dim(GFLGPWD)  <=0 : Global Shortint GFLGPWD : GFLGPWD=0 : Endif
Return

#--------------------------------------------------------------#
$FIN_ESR : # Etiquette de raz, sauf GFLGPWD qui conserve sa valeur
  Raz GCHGNUM, GMOTPWD, GFLGPWDOK
Return


#--------------------------------------------------------------#

Subprog C_SAIPWD(VALEUR)
Variable Char    VALEUR()
Local Integer WRET
#
 Local Char    MOTPASSE(24)
 Read [AUS]CODUSR = GUSER
 MOTPASSE = VALEUR
 Call CTLPAS(MOTPASSE,WRET) From GESUSER
 If !WRET
  GMESSAGE = mess(25,100,1) : # Mot de passe incorrect
  mkstat  = 2 : End
 Else GFLGPWDOK=1
 Endif
#
End

#--------------------------------------------------------------#

Subprog C_MOTPWD(VALEUR)
Variable Char    VALEUR()
  If dim(GMOTPWD)>0 GMOTPWD = VALEUR Endif
End

##################### Fin des ctrl écran [M:ESR] ####################

#-------------------------------------------------------------------#
# Appel de la fenêtre de e-Signature
#-------------------------------------------------------------------#

Subprog CTLPASSE(LABRFIC,LRET)
Value    Char    LABRFIC
Variable Integer LRET

Local Char PARAM(30)(1..3) , WVALTMP(GLONVCR)
Local Char     WPROGSPE(GDIMFIC)
PARAM(1)="2"                           # option: à préciser
PARAM(2)=LABRFIC                       # table courante (facultatif)

Call TRTSPE(nomap,"SAIESIGNR",WPROGSPE) From SUBACT
Call SAISIE_CHAR(WVALTMP,PARAM,"FESIGNRUL","TRTX3ESR",WPROGSPE) From GSAISIE
If dim(GFLGPWDOK)>0 LRET=GFLGPWDOK Endif

End


#-------------------------------------------------------------------#
# Ctrl e-Signature si le champ XFLGPWD existe sur la table entête   #
#     LCPT    code du compteur  (par défaut "ESR")
#     LABRFIC abréviation du fichier courant exemple "BOH"
#     LFCY    site courant      (facultatif)
#     LDAT    date de référence (facultatif)
#     LRET    code retour (0=ok, sinon erreur)
#-------------------------------------------------------------------#

Subprog E_SIGNATURE(LCPT,LABRFIC,LFCY,LDAT,LRET)
Value    Char     LCPT
Value    Char     LABRFIC
Value    Char     LFCY
Value    Date     LDAT
Variable Integer  LRET

Local    Char     WVAL(GLONVCR) : # Prochaine valeur du compteur
Local    Char     WCPT(GLONANM)       : # Code du compteur à utiliser
Local    Date     WDAT
Local    Integer  WRET          : # FQ 45682

  LRET = 1
  If evalue("dim([F:"+LABRFIC+"]XFLGPWD)")>0 | evalue("dim([F:"+LABRFIC+"]FLGPWD)")>0
     Call CTLPASSE(LABRFIC,LRET) From TRTX3ESR
     # Modifications non validées ? # FQ 45224 01/2008 avant Return au lieu de End
     If LRET < 1 : GMESSAGE=mess(18,176,1) : OK=0 : GPE=-1 : End : Endif
  Endif

# Prochain compteur de mise à jour ?
  If LCPT="" : WCPT="ESR" Else WCPT=left$(LCPT,3) Endif
  If LDAT=[0/0/0] : WDAT=date$ Endif
#
# FQ 45682 remplacement LRET par WRET
  Call NUMERO(WCPT,LFCY,WDAT,"",WVAL,WRET) From SUBANM
  If WRET=0
     If evalue("dim([F:"+LABRFIC+"]XCHGNUM)")>0
            Assign "[F:"+LABRFIC+"]XCHGNUM" With WVAL
     Endif
     If dim(GCHGNUM)>0 GCHGNUM = WVAL Endif
  Endif

End

#-------------------------------------------------------------------#
# Maj des infos si les champ XCHGNUM et XMOTPWD existent            #
#     LABRFIC abréviation du fichier courant exemple "BOH"
#     LRET    code retour (0=ok, sinon erreur)
#-------------------------------------------------------------------#

Subprog WRI_CHGNUM(LABRFIC)
Value    Char     LABRFIC

If evalue("dim([F:"+LABRFIC+"]CHGNUM)")>0 & dim(GCHGNUM)>0
       Assign "[F:"+LABRFIC+"]CHGNUM" With GCHGNUM
Endif
If evalue("dim([F:"+LABRFIC+"]XCHGNUM)")>0 & dim(GCHGNUM)>0
       Assign "[F:"+LABRFIC+"]XCHGNUM" With GCHGNUM
Endif

If evalue("dim([F:"+LABRFIC+"]MOTPWD)")>0 & dim(GMOTPWD)>0
       Assign "[F:"+LABRFIC+"]MOTPWD" With GMOTPWD
Endif
If evalue("dim([F:"+LABRFIC+"]XMOTPWD)")>0 & dim(GMOTPWD)>0
       Assign "[F:"+LABRFIC+"]XMOTPWD" With GMOTPWD
Endif

End


#-------------------------------------------------------------------#
# Maj des infos si les champ XCHGNUM et XMOTPWD existent            #
#     LABRFIC abréviation du fichier courant exemple "BOH"
#     LRET    code retour (0=ok, sinon erreur)
#-------------------------------------------------------------------#

Subprog DEL_CHGNUM(LABRFIC)
Value    Char     LABRFIC
# supprimer ou rajouter des lignes d'audit pour cette nomenclature ?
End

