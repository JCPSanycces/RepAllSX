####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EDIXMLFILD
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_MSGCOD From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_MSGREL From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_MSGFILNOR From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_NUMORDER From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_NUMLIN From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_SORT From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_REPCOD From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_ALIAS From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_EXPRESSION From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_PROTOPATH From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_DESCRIPTION From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_PATHID From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_PATHSTR From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_PATHTYPE From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_PATHREST From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_CONDITIONSTR From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_CONDITIONPAT From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub AINIT From WMC0EDIXMLFILD : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EDIXMLFILD
Gosub _ALOADATTRIBUTE_MSGCOD From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_MSGREL From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_MSGFILNOR From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_NUMLIN From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_SORT From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_ALIAS From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EDIXMLFILD
Gosub LNKPRO_MSGCOD From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub LNKPRO_MSGFILNOR From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub LNKPRO_REPCOD From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Gosub LNKPRO_ALIAS From WMC1EDIXMLFILD : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



