# Gestion du masque CNTBPC1

######################################################################################
## Etiquette ajoutée par le superviseur (écran CNTBPC1) 08/03/2005 14:52:27 (CCORA)
######################################################################################
Subprog IB_NBCNT
Call IB_NBCNT From TRTBPA
End

Subprog AS_NBCNT
Call AS_NBCNT From TRTBPA
End

Subprog B2_NBCNT
Call B2_NBCNT From TRTBPA
End

Subprog APRES_NBCNT
Call APRES_NBCNT From TRTBPA
# Spécifique à l'import --> Recharger nolign pour sortir de la boucle de saisie 
nolign = [M]NBCNT
End

Subprog AS_CCNCRM(VALEUR)
Variable Char    VALEUR()
Call AS_CCNCRM(VALEUR) From TRTBPA
End

Subprog C_CCNCRM(VALEUR)
Variable Char    VALEUR()
Call C_CCNCRM(VALEUR) From TRTBPA
End

Subprog AM_CCNCRM(VALEUR)
Variable Char    VALEUR()
Call AM_CCNCRM(VALEUR) From TRTBPA
End


