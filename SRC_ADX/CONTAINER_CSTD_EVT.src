#<AdxTL>@(#)0.0.0.0 $Revision$
#Class CONTAINER event's

#######################################################################################
$AINSERT_CONTROL_BEFORE
  Gosub AINSERT_OR_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$AUPDATE_CONTROL_BEFORE
  Gosub AINSERT_OR_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$AINSERT_OR_AUPDATE_CONTROL_BEFORE
  Local Char WTEXTE(50)
  Local Char WMESSAGE(250)
  Local File PORDERQ [POQ1]
  If maxtab (this.CTRD) = AVOID.ADEC
    WMESSAGE = mess(17,106,1)
    [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, [V]CST_AERROR)
    Return
  Endif
  If this.TCTRNUM = AVOID.ACHAR
    Call TEXTE(52437, WTEXTE) From OBJDIV
    WMESSAGE = mess(10,123,1)
    [L]ASTATUS = fmet this.ASETERROR (WTEXTE, WMESSAGE, [V]CST_AERROR)
    Return
  Endif
Return

#######################################################################################
$AINSERT_CONTROL_AFTER
  Gosub AINSERT_OR_AUPDATE_CONTROL_AFTER
Return

#######################################################################################
$AUPDATE_CONTROL_AFTER
  Local Char WCPYLIN(GLONCPY)
  Local Char WBPSNUM(GLONVCR)
  Local Char WTEXTE(50)
  Gosub AINSERT_OR_AUPDATE_CONTROL_AFTER
  #fields not modifiable
  #Container ID
  If this.CTRUID <> this.snapshot.CTRUID & this.snapshot.CTRUID<>AVOID.ACHAR
        Call TEXTE(53633, WTEXTE) From OBJDIV
        WMESSAGE = WTEXTE + " : " + mess(9,123,1)
        [L]ASTATUS = fmet this.ASETERROR ("CTRUID", WMESSAGE, [V]CST_AERROR)
        Return
  Endif
  If this.FCY <> this.snapshot.FCY
        WMESSAGE = mess(3,45,1)+ " : " + mess(9,123,1)
        [L]ASTATUS = fmet this.ASETERROR ("FCY", WMESSAGE, [V]CST_AERROR)
        Return
  Endif
  If this.BPSNUM <> this.snapshot.BPSNUM & this.snapshot.BPSNUM<>AVOID.ACHAR
        WMESSAGE = mess(17,7,1)+ " : " + mess(9,123,1)
        [L]ASTATUS = fmet this.ASETERROR ("BPSNUM", WMESSAGE, [V]CST_AERROR)
        Return
  Endif
  If this.TCTRNUM <> this.snapshot.TCTRNUM
    Call TEXTE(52437, WTEXTE) From OBJDIV
    WMESSAGE = WTEXTE+ " : " + mess(9,123,1)
    [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, [V]CST_AERROR)
    Return
  Endif
Return

#######################################################################################
$AINSERT_OR_AUPDATE_CONTROL_AFTER
  Local File TABCONTAINER  [TCTR]
  Local Char WCPYLIN(GLONCPY)
  Local Char WBPSNUM(GLONVCR)
  Local Char WNUM(10)
  Local Integer WIND

  WNUM="0123456789"

  #container ID format : total length = 11 (4 alpha + 7 numeric)
  If this.CTRUID <> AVOID.ACHAR
    If len(this.CTRUID) <> 11
     WMESSAGE = mess(487,194,1)
      [L]ASTATUS = fmet this.ASETERROR ("CTRUID", WMESSAGE, [V]CST_AERROR)
      Return
    Endif
    For I = len(this.CTRUID) To 1 Step -1
      J = instr(1,WNUM,mid$(this.CTRUID,I,1))
      If (J <> 0 &  I<=4) | (J=0  & I>4)
        WMESSAGE = mess(487,194,1)
        [L]ASTATUS = fmet this.ASETERROR ("CTRUID", WMESSAGE, [V]CST_AERROR)
        Return
      Endif
    Next I
  Endif
  If this.TCTRNUM<>AVOID.ACHAR
     Read [TCTR] TCTR0=this.TCTRNUM
     If fstat
      WMESSAGE = mess(483,194,1)
      [L]ASTATUS = fmet this.ASETERROR ("TCTRNUM", WMESSAGE, [V]CST_AERROR)
      Return
     Else
     # Issue 111256 US2 : pas de transclasse car écrasement des zones techniques
      this.TARWEI = [F:TCTR]TARWEI
      this.MAXWEI = [F:TCTR]MAXWEI
      this.USFVOL = [F:TCTR]USFVOL
      # End issue 111256 US2
     Endif
  Endif

  this.TOTLINWEU = AVOID.ADEC
  this.TOTLINVOU = AVOID.ADEC
  this.TOTLINAMT = AVOID.ADEC
  For I=1 To maxtab(this.CTRD)
    #cohérence entre les sites des lignes : ils doivent tous appartenir à la même sté juridique
    If this.CTRD(I)<>null and find(this.CTRD(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)<1
      If this.CTRD(I).LEGCPY <> AVOID.ACHAR & WCPYLIN = AVOID.ACHAR
        WCPYLIN   = this.CTRD(I).LEGCPY
      Endif
      If WCPYLIN<>AVOID.ACHAR & this.CTRD(I).LEGCPY <> AVOID.ACHAR & WCPYLIN<>this.CTRD(I).LEGCPY
        WMESSAGE = mess(485,194,1)
        [L]ASTATUS = fmet this.ASETERROR ("FCY", WMESSAGE, [V]CST_AERROR)
        Break
      Endif
      #cohérence entre les fournisseurs des lignes
      If this.CTRD(I).BPSNUM <> AVOID.ACHAR & WBPSNUM = AVOID.ACHAR
        WBPSNUM   = this.CTRD(I).BPSNUM
      Endif
      If WBPSNUM<>AVOID.ACHAR & this.CTRD(I).BPSNUM<>AVOID.ACHAR & this.BPSNUM<>AVOID.ACHAR
&       & this.CTRD(I).BPSNUM<>WBPSNUM & this.BPSNUM<>this.CTRD(I).BPSNUM
        WMESSAGE = mess(486,194,1)
        [L]ASTATUS = fmet this.ASETERROR ("BPSNUM", WMESSAGE, [V]CST_AERROR)
        Break
      Endif
      WRET = fmet this.CTRD(I)._CALC_TOTAUX()
    Endif
  Next I
# Issue 111256 US2
#calcul du poids courant : somme du poids des lignes  + tare du conteneur
this.CRRWEI = this.TOTLINWEU + this.TARWEI
#calcul du poids disponible : poids max - poids total des lignes
this.AVAWEI = this.MAXWEI - this.TOTLINWEU
If this.AVAWEI <0 this.AVAWEI = 0 Endif
#calcul du volume disponible
this.AVAVOL = this.USFVOL - this.TOTLINVOU
If this.AVAVOL <0 this.AVAVOL = 0 Endif
# End issue 111256 US2
Return

#######################################################################################
$AINSERT_BEFORE
  Local Char WSEQ_CODE(25)
  Local Integer WMANUAL
  Local Char WMESSAGE(250)
  Local Char WCOMP(250)

  #gestion du compteur
  #If this.CTRNUM=AVOID.ACHAR     # Issue X3-86304 - 2018-04-23 by MAE
    If func TCA_TOOL.LECTCA(this.ACTX, 6, fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY,"LEGCPY"),
&         fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY,"LEG"),16, WSEQ_CODE, WMANUAL, WMESSAGE) = [V]CST_AFALSE
       [L]ASTATUS = fmet this.ASETERROR ("CTRNUM", mess(64,199,1), [V]CST_AERROR)
    Endif
    If (this.CTRNUM = AVOID.ACHAR ) | (this.CTRNUM <> AVOID.ACHAR & WMANUAL= [V]CST_ANO)  # Issue X3-86304 - 2018-04-23 by MAE : si affectation manuelle à Non, compteur obligatoire
      #Appel du numéro
      [L]ASTATUS=func ANM_TOOL.NUMERO(this.ACTX,WSEQ_CODE,this.FCY,date$,WCOMP,this.CTRNUM,WMESSAGE)
      If [L]ASTATUS>= [V]CST_AERROR
         [L]ASTATUS = fmet this.ASETERROR ("CTRNUM", WMESSAGE, [V]CST_AERROR)
      Endif
    Endif
  #Endif                          # Issue X3-86304 - 2018-04-23 by MAE
  If this.CTRNUM = AVOID.ACHAR
    [L]ASTATUS = fmet this.ASETERROR ("CTRNUM", mess(10,123,1), [V]CST_AERROR)
  Endif
Return

#######################################################################################
$CTRD_AINSERT_CONTROL_BEFORE
  Gosub CTRD_AINSERT_OR_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$CTRD_AUPDATE_CONTROL_BEFORE
  Gosub CTRD_AINSERT_OR_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
#MAE, exi 108538
$CTRD_AINSERT_OR_AUPDATE_CONTROL_BEFORE
  Local File PORDERQ[POQ1]
  Read[POQ1]POQ0 = this.POHNUM;this.POPLIN;this.POQSEQ
  If fstat <> [V]CST_AOK
    WMESSAGE = func ASYRFNC.MES1(mess(93,140,1),"PORDERQ")
    [L]ASTATUS = fmet this.ASETERROR (this.POHNUM, WMESSAGE, [V]CST_AERROR)
    Return
  Endif
Return
#MAE, FIN exi 108538

#######################################################################################
$CTRD_AINSERT_CONTROL_AFTER
  #fields mandatory
  If this.QTYPUU = AVOID.ADEC
    [L]ASTATUS = fmet this.ASETERROR ("", mess(83,182,1), [V]CST_AERROR)
  Endif
Return

#######################################################################################
$CTRD_AUPDATE_CONTROL_AFTER
  #no update if shipment <> ""
  If this.SHIPNUM <> AVOID.ACHAR & this.snapshot.SHIPNUM <> AVOID.ACHAR
    WMESSAGE = mess(488,194,1)
    [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, [V]CST_AERROR)
    Return
  Endif

  If this.QTYPUU = AVOID.ADEC
    [L]ASTATUS = fmet this.ASETERROR ("", mess(83,182,1), [V]CST_AERROR)
  Endif
  # QTYVOU and QTYWEU are not calculated in the class, because, in import,
  # they can be imported and they don't have to be recalulate
  # Calcul du coefficient UOM/UA
  If this.QTYUOM<>AVOID.ADEC
    #----- Dans tous le cas calcul coefficient conversion UOM vers UA -----#
    this.UOMPUUCOE =arr(this.QTYPUU/this.QTYUOM,0.00000001)
  Endif
  If this.UOMPUUCOE=AVOID.ADEC : this.UOMPUUCOE=1 : Endif

  If this.snapshot.QTYUOM <> AVOID.ADEC
    #Calcul de la quantité en UA
    this.QTYPUU = this.snapshot.QTYPUU * this.QTYUOM /this.snapshot.QTYUOM
    Call QTEARR(this.QTYPUU,this.PUU) From TRTDIV
    # Issue X3-82714 - 2018-03-30 by MAE : read ITM for having [F:ITM]PUUSTUCOE
    Local File ITMMASTER [ITM]
    If [F:ITM]ITMREF <> this.ITMREF
      Read[ITM]ITM0 = this.ITMREF
    Endif
    #Calcul de la qté en US
    #this.QTYSTU = this.snapshot.QTYSTU * this.QTYUOM /this.snapshot.QTYUOM
    this.QTYSTU = this.QTYUOM * [F:ITM]PUUSTUCOE
    # End issue X3-82714
    Call QTEARR(this.QTYSTU,this.STU) From TRTDIV
 Endif
Return

#######################################################################################
$CTRD_ADDLINE_AFTER
  #INIT Key, necessary or not ?
  this.CTRNUM = this.APARENT.CTRNUM
  this.CTRLIN = 1 + max(this.APARENT.CTRD(1..maxtab(this.APARENT.CTRD)).CTRLIN)
Return

#######################################################################################
$CTRD_AINSERT_BEFORE
Return

#######################################################################################
$CTRD_ADELETE_CONTROL_AFTER
  # Issue 56547 - 2017-11-03 by MAE : pb de perf
  If this.SHIPNUM <> AVOID.ACHAR & this.snapshot.SHIPNUM <>  AVOID.ACHAR
     WMESSAGE = mess(488,194,1)
     [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, [V]CST_AERROR)
  Endif
Return

