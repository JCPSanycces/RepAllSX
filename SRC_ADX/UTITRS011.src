#<AdxTL>@(#)5.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
##########################################################################
# UTITRS008   Initialization AUTDEPCUS and DENPAY  #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap

If DOSSIER<>""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  If !GSERVEUR
    Call OUVRE_TRACE("Process UTITRS008") From LECFIC
  Endif

  If nomap<>GDOSX3
    Call MAJ_UTIDEP(nomap)
  Else
    Local Integer OK
    Call OUINON("Run the process on all folders of the solution",OK) From GESECRAN
    If OK<>2 : End : Endif
    If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
    For [ADS]
      If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
        Call MAJ_UTIDEP(nomap)
      Endif
    Next
  Endif

  Call TEMPOFF From GESECRAN
  If !GSERVEUR
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
Endif
End

########################################################################
Subprog MAJ_UTIDEP(DOSSIER)
Value Char    DOSSIER

If !clalev([F:ADW]) : Local File =DOSSIER+".ADOVAL" [ADW]  : Endif
If !clalev([F:ADW2]): Local File =DOSSIER+".ADOVAL" [ADW2] : Endif
If !clalev([F:ACV]) : Local File =DOSSIER+".ACTIV"  [ACV]  : Endif

Call ECR_TRACE("UTITRS008: Process Start on:"-DOSSIER,0) From GESECRAN

Call MAJ_UTIAUTDEPCUS([F:ADS]DOSSIER)
Call MAJ_UTIDENPAY([F:ADS]DOSSIER)

Call ECR_TRACE("UTITRS011: Process Finish on:"-DOSSIER,0) From GESECRAN

End

#  - In USA mono-legislation folder, value “Yes” at folder level;
#  - In multi-legislation folder, value “Yes” at folder level.
#     Multi-legislation depends on LEG activity code.
#     List of legislation installed is in general parameter DOSLEG.
########################################################################
Subprog MAJ_UTIAUTDEPCUS(DOSSIER)
Value Char    DOSSIER

Local Char    DOSLEG
Local Integer MULTILEG

MULTILEG = func AFNC.ACTIV("LEG")
Call PARAM("","LEG",DOSLEG) From ADOVAL

Raz [F:ADW2]
[ADW2]VALEUR = "2"
If MULTILEG | DOSLEG="USA"  # Multi-leg or USA mono
  [ADW2]VALEUR = "2"
Endif

Call UPDATE_PARAM("AUTDEPCUS")
End

########################################################################
Subprog MAJ_UTIDENPAY(DOSSIER)
Value Char    DOSSIER

For [ADW2] Where PARAM="DENDEP"
  Call UPDATE_PARAM("DENPAY")
Next

End

# Using ADW2 as the seed values
########################################################################
Subprog UPDATE_PARAM(NAMPAR)
Value Char       NAMPAR

Trbegin [ADW] : GOK=1

Read [ADW]ADW0=[F:ADW2]CMP;[F:ADW2]FCY;NAMPAR
If fstat                # Value does not exist, create
  Raz [F:ADW]
  [F:ADW] = [F:ADW2]
  [F:ADW]PARAM  = NAMPAR
  [F:ADW]CREDAT = date$
  [F:ADW]CREDATTIM = time
  [F:ADW]CREUSR = GUSER
  Write [ADW]
  If fstat
    GOK=0
  Else
    Call ECR_TRACE("UTITRS011:"-NAMPAR-[ADW]CMP-[ADW]FCY-"created",0) From GESECRAN
  Endif
Elsif [F:ADW]VALEUR=""  # Param value is blank, copy from DENDEP
  [F:ADW]VALEUR = [ADW2]VALEUR
  [F:ADW]UPDDAT = date$
  [F:ADW]UPDDATTIM = time
  [F:ADW]UPDUSR = GUSER
  Rewrite [ADW]
  If fstat
    GOK=0
  Else                  # Param value is already set, don't change
    Call ECR_TRACE("UTITRS011:"-NAMPAR-[ADW]CMP-[ADW]FCY-"updated",0) From GESECRAN
  Endif
Else
    Call ECR_TRACE("UTITRS011:"-NAMPAR-[ADW]CMP-[ADW]FCY-"unchanged:"-[F:ADW]VALEUR,0) From GESECRAN
Endif

If GOK : Commit
Else
  Rollback
  Call ECR_TRACE("UTITRS011:"-NAMPAR-"error:"-num$(fstat),0) From GESECRAN
Endif

End

########################################################################
# For automatic execution during patch integration
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif
If filinfo(filpath("FIL","AOBJET","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","ATYPE", "fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTIDEP(APPLI)
End

########################################################################
# For execution during folder validation
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char    APPLI
#  If APPLI=GDOSX3 End : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif
If filinfo(filpath("FIL","AOBJET","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","ATYPE", "fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTIDEP(APPLI)
End
