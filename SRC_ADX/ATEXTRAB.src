#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char VALEUR, TABLE, CHAMP, CLE1, CLE2
TABLE = "GTYPACCENT"
CHAMP = "SHOTRA"
CLE1  = "FAC"
CLE2  = ""
GCURLEG = "FRA"
#GCURLEG = "USA"
Raz VALEUR

Call LECTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2) From ATEXTRA
Infbox VALEUR
End


#  Idée est de dérouter la lecture des intitulés traduisibles pour les données déclinées par législation
#  Une des problématiques est la lecture hiérarchisée...
#
#   - 1ère Lecture selon une législation courante = GCURLEG
#     (GCURLEG = La législation de la société, initialisation sous GETSOC du traitement supervsieur DEVSUB)
#
#   - 2ème lecture avec une législation = VIDE => Toutes législations.
#
#  Solution 1 : Déterminer à partir du nom de la table si celle-ci est déclinée par législation.
#               (Inconvénient 1 à 2 lectures !)
#
#  Solution 2 : Variable globales GTABLEG contenant la liste des tables déclinées par législation
#               (Inialiser via le traitement GLOBxxx)


$ACTION
Case ACTION
 When "LECTEXTRA" : Gosub LECTEXTRA_LEG
Endcase
Return


$LECTEXTRA_LEG
# Solution 2 - Variable globale qui détermine si la table est une donnée déclinée

If dim(GNBTABLEG)>0 & dim(GTABLEG)>0

 If !find(TABLE,GTABLEG(1..GNBTABLEG)) : OK = 1 : Return : Endif
 If left$(CHAMP,3)<>"DES" and left$(CHAMP,3)<>"SHO" : Return : Endif

Else

 # Solution 1 - Lecture pour déterminer si la table est une donnée déclinée
 If clalev([ATI])=0 : Local File ATABIND [ATI] : Endif
 Local Char    WCLE1(250) , WCLE2(250)
 Local Char    PCLE(GLONAVA)(1..16)
 Local Integer NBCLE , I1 , I2

 # Lecture de ma table Index
 Read [ATI]NUMLIG(2) = TABLE;1

 # Récup des zones d'index
 WCLE1  = [F:ATI]DESCRIPT
 NBCLE = 0
 While WCLE1<>""
  I1 = instr(1,WCLE1,"+")
  I2 = instr(1,WCLE1,"-")
  If I2
   If I1 : I1 = min(I1,I2) : Else : I1 = I2 : Endif
  Endif
  If I1
   WCLE2 = left$(WCLE1,I1-1)
   WCLE1 = right$(WCLE1,I1+1)
  Else
   WCLE2 = WCLE1
   WCLE1 = ""
  Endif
  NBCLE += 1
  PCLE(NBCLE) = WCLE2
 Wend

 If NBCLE<>2 :  OK = 1 : Return : Endif

 # Index CLE2 => Table déclinée par législation
 #If NBCLE <> 2 | PCLE(2)<>"LEG" : OK = 1 : Return : Endif

 # ou
 If clalev([ATZ])=0 : Local File ATABZON [ATZ] : Endif
 Read [ATZ]CODZONE = TABLE;PCLE(2)
 If [ATZ]CODTYP="ADI" & instr(1,[ATZ]EXPLIEN,"909")
  OK = 0
 Else
  OK = 1 : Return
 Endif
Endif


# Lecture avec Variable Globale GCURLEG
If CLE2="" : CLE2 = GCURLEG : Endif
Call LECTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2)
If VALEUR=""
 CLE2 = ""
 Call LECTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2)
 If VALEUR=""
  # Les intitulés sont devenus obligatoires, au niveau exploitation, aucune problématique.
  # Au niveau du paramètrage, X3 accepte qu'une donnée déclinée par législation saisie sur une donnée également déclinée par législation
  # soit de législation différente (champ LEG vide pour l'une, champ LEG<>vide pour l'autre)
  # Exemple : Sous la fonction de Type de Pièces (GESGTE), le journal est saisissable. Ces 2 données sont déclinées par législation.
  #           Si un type de Pièces est Toutes législations (le champ LEG vide), le journal saisi peut être de n'importe quelle législation.
  #           Si le journal n'a pas dans ce cas un enregistrement "Toutes législations", le libellé restait vide.
  #           Dans ce cas, X3 lit le premier enregistrement trouvé d'où le Read First ci-dessous.
  If clalev([ATI])=0 : Local File ATABIND [ATI] : Endif
  Local Char    WCLE1(250) , WCLE2(250)
  Local Char    PCLE(GLONAVA)(1..16)
  Local Integer NBCLE , I1 , I2

  If TABLE = 'TABPAYTERM'
   Read [ATI]NUMLIG(2) = TABLE;3
  Else
   Read [ATI]NUMLIG(2) = TABLE;1
  Endif

  # Récup des zones d'index
  WCLE1  = [F:ATI]DESCRIPT
  NBCLE = 0
  While WCLE1<>""
   I1 = instr(1,WCLE1,"+")
   I2 = instr(1,WCLE1,"-")
   If I2
    If I1 : I1 = min(I1,I2) : Else : I1 = I2 : Endif
   Endif
   If I1
    WCLE2 = left$(WCLE1,I1-1)
    WCLE1 = right$(WCLE1,I1+1)
   Else
    WCLE2 = WCLE1
    WCLE1 = ""
   Endif
   NBCLE += 1
   PCLE(NBCLE) = WCLE2
  Wend
  If NBCLE<>2 :  OK = 1 : Return : Endif
  If clalev([WLEC]) : Close Local File [WLEC] : Endif
  Local File =TABLE [WLEC]
  KEYCRI =PCLE(1)+"='"+CLE1+"'"
  Filter [WLEC] Where evalue(KEYCRI)
  Read [WLEC] First
  If !fstat
   CLE1 = evalue("[F:WLEC]"+PCLE(1))
   CLE2 = evalue("[F:WLEC]"+PCLE(2))
   Call LECTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2)
  Endif
  Filter [WLEC]
  Close Local File [WLEC]
 Endif
Endif
Return

#----------------------------------------------------------------------------------------------------#
# Lecture d'un texte traduisible
#----------------------------------------------------------------------------------------------------#

Subprog LECTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2)
Variable Char    VALEUR()
Value    Char    TABLE, CHAMP, CLE1, CLE2
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
Read [AXX]AXX0 = TABLE;CHAMP;GLANGUE;CLE1;CLE2
If fstat=0
 VALEUR = [F:AXX]TEXTE
Else
 Read [AXX]AXX0 = TABLE;CHAMP;GLANDEF;CLE1;CLE2
 If fstat=0
  VALEUR = [F:AXX]TEXTE
 Else
  VALEUR = ""
 Endif
Endif
End
