#**
#* INTERNAL USE ONLY !!!
#* This Function allows to concat severals propeties into JSON string.
#* The result have to be inserted into JSON object !
#*
#* @param CODS : Char Array : Properties name.
#* @param VALS : Char Array : Properties  values.
#* @return CLOB : Char : The string that need to be inserted into JSON object.
#*!
Subprog STRINGIFY_PROPS(CODS, VALS, CLOB)
Value Char CODS()(1..)
Value Char VALS()(1..)
Variable Clbfile CLOB()

Local Integer I
Local Char SEP(2)
CLOB = "" : SEP = ""
For I=1 To maxtab(CODS)
  If (len(CODS(I)) > 0)
    Append CLOB, SEP+'"' + CODS(I) + '":' + VALS(I)
    SEP = ","
  Endif
Next I
End
