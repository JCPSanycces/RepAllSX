#<AdxTL>@(#)0.0.0.0 $Revision$Class EDI partners
# Supervisor
## ATY-ATYPE ## EPR
# 2018-11-09 07:14:14 684

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,PARCOD,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char PARCOD
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File EDIPARTNER [EPR]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".EDIPARTNER" [EPR]
Endif

Default File [F:EPR]
Read [F:EPR]EPR0 = [L]PARCOD
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]PARCOD)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]PARCOD)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


