##########################################################################
Subprog AM_HNAFLG(VALEUR)
Variable Integer VALEUR

If VALEUR = 2
    Actzo [M:HNA1]HNAAFC
    Actzo [M:HNA1]HNARET
Else
    [M:HNA1]HNAAFC = ""
    [M:HNA1]HNARET = 1
    Grizo [M:HNA1]HNAAFC
    Grizo [M:HNA1]HNARET
Endif

[M:HNA1]HNAFLG = VALEUR
Affzo [M:HNA1]
End



