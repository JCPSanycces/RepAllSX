#<AdxTL>@(#)9.0.0.0 $Revision$
########################################
Subprog AS_NBLIG
GBOUT1 = mess(157,198,1)
End

########################################
Subprog B1_NBLIG
Local Integer  L : L = nolign - 1
Call OBJET("ITF",[M:MBW2]MFGFCY,[M:MBW2]ITMREF(L)) From GOBJET  
End

########################################
Subprog B3_NBLIG
Local Mask MTKM [MTKM]
Local Integer     REPONSE, L
Local Shortint    SAVNOLIGN 
Local Integer     ETABOU(1..GNBBOU), SAVGOBJET
 
SAVNOLIGN=nolign 
SAVGOBJET=GOBJET 
Call SAVBOUT From GESECRAN 
GOBJET=0 

L = nolign-1
Local Mesbox Mask [MTKM]
&  Button mess(64,123,1)
&  With left$(mess(64,123,1),1)
&  Coded GSTAOK 
&  Titled mess(242,198,1) As [MTKM]
Raz [M:MTKM]
[M:MTKM]MFGFCY      = [M:MBW2]MFGFCY
[M:MTKM]STU         = [M:MBW2]STU(L)
[M:MTKM]MFMEXTQTY   = [M:MBW2]RETQTY(L)
[M:MTKM]MFMUSEQTY   = [M:MBW2]USEQTY(L)
[M:MTKM]MFMALLQTY   = [M:MBW2]ALLQTY(L)
[M:MTKM]MFMSHTQTY   = [M:MBW2]SHTQTY(L)
[M:MTKM]MFMTRKFLG   = [M:MBW2]MFMTRKFLG(L)
[M:MTKM]MFMRESQTY   = [M:MTKM]MFMEXTQTY - [M:MTKM]MFMUSEQTY
If [F:ITM]ITMREF    <>[M:MBW2]ITMREF(L)
   Read [F:ITM]ITM0 = [M:MBW2]ITMREF(L) 
   If fstat : Raz [F:ITM] : Endif 
Endif
[M:MTKM]NEGSTO = [F:ITM]NEGSTO
Grizo [M:MTKM]
Boxact [MTKM]
$D_MTKM
ETABOU(GVALI)=1 
ETABOU(GSPE1)=1
Call SETBOUT(ETABOU) From GESECRAN        
#
Boxinp [MTKM] Using REPONSE
Case REPONSE : 
     When GSTAOK, GSTARET: Goto F_MTKM
     When Default :   Goto D_MTKM
Endcase
$F_MTKM
Boxclr [MTKM]
Close Local Mask [MTKM] 
nolign=SAVNOLIGN 
GOBJET=SAVGOBJET 
Call RESTBOUT From GESECRAN 
End

########################################
Subprog AV_DIFFSTO(VALEUR)
Variable Decimal VALEUR
Local Integer L : L = nolign-1
If VALEUR < 0
  pcolor = GCOUL(1)
Else 
  pcolor = GCOUL(0)
Endif
End

