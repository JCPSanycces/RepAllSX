Callui RETOUR="" With     "UIAction="+chr$(1)+"GetFileAlways",
&                         "UIRemoteFile="+ chr$(1) +PATH,
&                         "UILocalDir="+ chr$(1) +"UserTemp",
&                         "UILocalFile="+ chr$(1) +"EXPBOM.csv"

# commandes
PATH = "tmp"+"/"+tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) + ".ilach"
Callui RETOUR="" With     "UIAction="+chr$(1)+"GetFileAlways",
&                         "UIRemoteFile="+ chr$(1) +PATH,
&                         "UILocalDir="+ chr$(1) +"UserTemp",
&                         "UILocalFile="+ chr$(1) +"EXPACH.csv"

# commandes
PATH = "tmp"+"/"+tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) + ".ilsto"
