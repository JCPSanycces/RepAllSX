#<AdxTL>@(#)5.0.0.0 $Revision$
#Gestion du masque ORPINT
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBORPINT","ORPINT",4,"SPEORPINT") From GTRAITE
End

######################################################################################
$ACTION
#Infbox "ACTION="+ACTION
Case ACTION
 When "OUVRE_BATCH"  : Gosub OUVRE : #entrée en Batch
 When "INIT"         : Gosub OUVRE : #entrée en Interactif
 When "DEBUT"        : Gosub DEBUT
 When "CONTROLE"     : Gosub CONTROLE
 When "EXEC"         : Gosub EXEC
 When "TERMINE"      : Gosub TERMINE
 When Default
Endcase
Return

######################################################################################
$OUVRE
Local Integer OK , STAT

Local Mask ORPINT [DIA] : # Saisie paramètres
Raz [M:DIA]
If clalev ([F:ORP]) = 0 : Local File ORDOPPAR [ORP] : Endif
Call GET_DERLU([M:DIA]ID,"ORP","")

If !GSERVEUR ## Issue 114236/116377 - 2016-02-15 by RBA modified 2016-02-29
#If !GBATCH ## Issue 105264 - 2015-02-01 by RBA
  If [M:DIA]ID<>"" ## Issue 83812 - 2012-27-09 by RBA - on met dans controle pour gerer en mode batch
      Call AP_ID([M:DIA]ID)
  Endif
Endif

If !pat(GVERSION,"1.5.*")
    Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Endif
Gosub CHARG_PARAM From FUNMOPT

Return

$DEBUT
# Issue 98932 - 2014-07-04 by RBA : Volumes managment evolution
If [M:DIA]ID<>""
 Call AM_TYPEXP([M:DIA]TYPEXP)
Endif
#/ Issue 98932 - 2014-07-04 by RBA : Volumes managment evolution
Call AM_OPTION([M:DIA]OPTION)
Affzo [M:DIA]
Return

#######################################################
$CONTROLE
If GSTATUT=7
 FIN = 1 : # Sortie du GSAISIE par la touche FIN
 Return
Endif
If !GSERVEUR
 TMP = 1
Endif

If GSERVEUR ## Issue 114236/116377 - 2016-02-15 by RBA modified 2016-02-29
##If GBATCH ## Issue 105264 - 2015-02-01 by RBA
  If [M:DIA]ID<>"" ## Issue 83812 - 2012-27-09 by RBA
      Call AP_ID([M:DIA]ID)
  Endif
Endif

If [M:DIA]OPTION=2 : #preparation des données
    If vireblc([M:DIA]DRTISS,2)="" & [M:DIA]TYPEXP=2
        GERR=1
        SAI=1
        GMESSAGE=mess(55,7710,1)
        Return
    Endif
Endif
If [M:DIA]OPTION=4 : #récupération des données
    If vireblc([M:DIA]DRTRCP,2)="" & [M:DIA]TYPEXP=2
        GERR=1
        SAI=1
        GMESSAGE=mess(56,7710,1)
        Return
    Endif
    If vireblc([M]DRTSTO,2)="" & [M:DIA]TYPEXP=2
        GMESSAGE=""
        Call TEXTE(39111,GMESSAGE) From OBJDIV
        GMESSAGE -= ":"-mess(10,123,1)
        GERR=1
        SAI=1
# Issue 98932 - 2014-07-04 by RBA : Volumes managment evolution
#        GZONE = "DRTSTO"
        GZONE = "VOLFILSTO"
#/ Issue 98932 - 2014-07-04 by RBA : Volumes managment evolution
        Return
    Endif
Endif
Return

###############################################################
$TERMINE
  TRA=0
  If !GSERVEUR
    TRA = 1
  Endif
Return

######################################################################################
$EXEC
Local Char     WMESS(150)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
Local Date     WENDDAT, WENDDATMAX
Local Integer  WHDEB,WHFIN, WHWRK
Local Integer  NBOF
Local Integer NBERR : NBERR=0
TIT  = mess(53,7710,1)
# lecture site
Call LECTURE ("FCY", [M:DIA]MFGFCY, "") From CONTOBJ

If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
##Call PRTSCR("ORPINT","DIA","",0,1) From ATRTX3
Call TRACE_MASQUE("ORPINT","DIA",nomap) From GTRAITE
Call ECR_TRACE(string$(100,"="),0) From GESECRAN
WHDEB = time

Gosub CHK_DATE

If [M]OPTION=2
    # lecture en cours
    Call TEMPON(mess(3,100,1)) From GESECRAN
    # préparation des critères de filtre
    Gosub SEL_OF
    # traitement des OF
    Gosub TRT_OF
    Gosub TRF_FILES
    Call TEMPOFF From GESECRAN
Endif

If [M]OPTION=2
    If [M:DIA]TRACE1 = 2
        WHFIN = time
        WHWRK = WHFIN-WHDEB
        J = mod(WHWRK,60)
        K = WHWRK/60
        K = int(K)
        WMESS=mess(106,190,1)+":"-num$(K)-mess(2,301,1)-num$(J)
        Call ECR_TRACE(WMESS,0) From GESECRAN
    Endif

    # aucun OF extrait
    If !NBOF : Call MESSAGE(mess(88,193,1)) From GESECRAN : Endif

    #VPO 12/03/10 63219 : ajout point d'entree
    GPOINT = "AFTER_EXP" : Gosub ENTREE From EXEFNC
Endif

If [M]OPTION=4
    # ecriture en cours
    Call TEMPON(mess(4,100,1)) From GESECRAN
    Gosub OPTIMX3
    Call TEMPOFF From GESECRAN

    #VPO 12/03/10 63219 : ajout point d'entree
    GPOINT = "AFTER_IMP" : Gosub ENTREE From EXEFNC

Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

########################################################################
# Traitement des ordres
$TRT_OF
Call TRT_WST('ORP',[M:DIA]MFGFCY,[M:DIA]MFGFCY,[F:ORP]TWCPIT,[F:ORP]MWSPIT,[F:ORP]WSTPIT ,[F:ORP]RPLPIT,"",OK) From PITWST

Call TRT_OF('ORP',[M:DIA]MFGFCY,"",[F:ORP]OPEPIT,"",[F:ORP]ITMPIT,
&                [F:ORP]BPCPIT,[F:ORP]PJTPIT,[F:ORP]ORDPIT,
&                [F:ORP]BOMPIT,[F:ORP]GRUBOMFLG,[F:ORP]POFPIT,[F:ORP]STOPIT,
&                [F:ORP]RSSPIT,
&                CRITERE1,CRITERE2,[M:DIA]FORMULE,
&               [M:DIA]TRACE1,[M:DIA]TRTMOD,[M:DIA]CALSTRDAT,WENDDAT,NBOF,OK) From PITMFG
Return


########################################################################
# Contrôle horizon sélectionné (dépassement)
$CHK_DATE
Local Integer WCALDAYNBR
# si dates incohérentes, on force ...
    # calcul horizon en fonction des marges amont/aval
    [M:DIA]CALSTRDAT = [M:DIA]STRDAT - (GOPTAMMAR * 7)
    WCALDAYNBR = ((GOPTAVMAR*7) + [M:DIA]ENDDAT) - [M:DIA]CALSTRDAT

    WENDDAT = [M:DIA]CALSTRDAT + WCALDAYNBR

    # calcul date maximum pour un horizon limite de 2 ans
    WENDDATMAX = gdat$(day([M:DIA]CALSTRDAT),month([M:DIA]CALSTRDAT),year([M:DIA]CALSTRDAT)+2)

    # 03.06 35472
    If WENDDAT > WENDDATMAX
        # si dépassement, on force 2 ans et on écrit une trace
        WCALDAYNBR = WENDDATMAX - [M:DIA]CALSTRDAT
        [M:DIA]STRDAT    = [M:DIA]CALSTRDAT + (GOPTAMMAR * 7)
        [M:DIA]ENDDAT    = [M:DIA]CALSTRDAT + WCALDAYNBR
        WENDDAT           = [M:DIA]ENDDAT
        If [M:DIA]TRACE1 = 2
            WMESS = mess(139,193,1)
            Call ECR_TRACE(WMESS,2) From GESECRAN
            WMESS = mess(306,197,1)-tolower(mess(94,100,1))-format$(GFMD,[M:DIA]CALSTRDAT)-
&                   tolower(mess(95,100,1))-format$(GFMD,WENDDATMAX)
            Call ECR_TRACE(WMESS,1) From GESECRAN
            Raz WMESS
        Endif
    Endif
Return


########################################################################
# Préparation du filtre sur la table encours (WOx)
$SEL_OF
Raz CRITERE
Raz CRITERE1
Raz CRITERE2

If [M:DIA]WOSFLG = 2
    Case [M:DIA]MRPFLG
        When 1:     CRITERE  = "[F:OPS]OPSSTA=3&[F:OPS]OPSTYP=2"
        When 2:     CRITERE  = "[F:OPS]OPSSTA=3&[F:OPS]OPSTYP=1"
        When 3:     CRITERE  = "[F:OPS]OPSSTA=3"
    Endcase
    Gosub LOAD_CRITERE
Endif

If [M:DIA]WOPFLG = 2
    CRITERE  = "[F:OPS]OPSSTA=2"
    Gosub LOAD_CRITERE
Endif

If [M:DIA]WOFFLG = 2
    CRITERE  = "[F:OPS]OPSSTA=1"
    Gosub LOAD_CRITERE
Endif

# fin de la première partie
CRITERE1 += ")"

#----------------------------------------------------------------------------------------------
GPOINT = "OPTDATSEL"
Gosub  ENTREE From EXEFNC
If !GPE
    CRITERE = "[F:OPS]OPESTR>=[M:DIA]CALSTRDAT"
    Gosub LOAD_CRITERE2

    CRITERE = "[F:OPS]OPEEND<=[M:DIA]ENDDAT"
    Gosub LOAD_CRITERE2

    CRITERE  = "[F:OPS]MFGFCY = [M:DIA]MFGFCY"
    Gosub LOAD_CRITERE2
Endif

Return

########################################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

########################################################################
$LOAD_CRITERE2
If len(CRITERE)+len(CRITERE1)+1 < 225
  CRITERE1 += "&"
  CRITERE1 += CRITERE
Else
  If CRITERE2 <> ""
     CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE
Endif
Return

########################################################################
# transfert fichiers serveur vers client
$TRF_FILES
Local Char PATH (GDIMFIC)
Local Char WFICHIER (GDIMFIC)
Local Integer STAT

Local Char MACHINE(GDIMFIC) , MACFIC(GDIMFIC)
Call MACHINE([M:DIA]DRTISS,MACHINE,MACFIC) From ORDSYS

#on doit basculer le fichier dans le repertoire des fichiers destination
Gosub TRF_TEC
Gosub TRF_WO
Return

########################################################################
# transfert fichiers serveur vers client -> données techniques
$TRF_TEC_OLD
# centres de charge
PATH = "tmp"+"/"+tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) + ".ilcdc"
Callui RETOUR="" With     "UIAction="+chr$(1)+"GetFileAlways",
&                         "UIRemoteFile="+ chr$(1) +PATH,
&                         "UILocalDir="+ chr$(1) +"UserTemp",
&                         "UILocalFile="+ chr$(1) +"EXPGRRES.csv"

#postes de charge
PATH = "tmp"+"/"+tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) + ".ilwst"
Callui RETOUR="" With     "UIAction="+chr$(1)+"GetFileAlways",
&                         "UIRemoteFile="+ chr$(1) +PATH,
&                         "UILocalDir="+ chr$(1) +"UserTemp",
&                         "UILocalFile="+ chr$(1) +"EXPRES.csv"

