######################################################################################

Subprog CONTREP(NAMEREP)
Variable Char NAMEREP()
Local Integer ER
Local Char    REPERT(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(10)
  If left$(NAMEREP,1)="#"
   GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
   mkstat   = 2
   End
  Endif
  Call MACHINE(NAMEREP,MACHINE,REPERT) From ORDSYS
  Call GET_OS(MACHINE,OS) From ORDSYS
  If OS="" Then
    GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
    mkstat=2 : End
  Endif
  Call EXISTE(NAMEREP,ER) From ORDSYS
  If ER<>2 Then
    GERR=1
    GMESSAGE = mess(9,141,1) :  # Répertoire inexistant
    mkstat = 2 : End
  Endif
End


##########################################################################
## CONTROLES DES REPERTOIRES SAISIS
##########################################################################
######################################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
# Issue 98932 - 2014-07-04 by RBA : Volumes managment evolution
#If GBATCH & VALEUR=1
# GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
# mkstat = 2 : End
#Endif
If VALEUR=1
 If GBATCH : GMESSAGE = mess(163,141,1) : mkstat = 2 : End
 Else
   Raz [M]VOLFILISS : Grizo [M]VOLFILISS : Raz [M]DRTISS
   Raz [M]VOLFILSTO : Grizo [M]VOLFILSTO : Raz [M]DRTSTO
   Raz [M]VOLFILRCP : Grizo [M]VOLFILRCP : Raz [M]DRTRCP
 Endif
Endif
#/ Issue 98932 - 2014-07-04 by RBA : Volumes managment evolution

End

######################################################################################
Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
# Issue 98932 - 2014-07-04 by RBA : Volumes managment evolution
#  Call SET_NOMFIC("DRTRCP",[M:DIA]DRTRCP,VALEUR)
#  Call SET_NOMFIC("DRTSTO",[M:DIA]DRTSTO,VALEUR)
#  Call SET_NOMFIC("DRTISS",[M:DIA]DRTISS,VALEUR)
#  Affzo [M:DIA]DRTRCP
#  Affzo [M:DIA]DRTSTO
#  Affzo [M:DIA]DRTISS
#  If VALEUR=1
#     Grizo [M:DIA]DRTRCP
#     Grizo [M:DIA]DRTSTO
#     Grizo [M:DIA]DRTISS
#  Else
#     Actzo [M:DIA]DRTRCP
#     Actzo [M:DIA]DRTSTO
#     Actzo [M:DIA]DRTISS
#  Endif

If VALEUR=1
 Raz [M]VOLFILISS
 Raz [M]DRTISS
 Grizo [M]VOLFILISS
 Raz [M]VOLFILRCP
 Raz [M]DRTRCP
 Grizo [M]VOLFILRCP
 Raz [M]VOLFILSTO
 Raz [M]DRTSTO
 Grizo [M]VOLFILSTO
Else
 Actzo [M:DIA]VOLFILISS
 Actzo [M:DIA]VOLFILSTO
 Actzo [M:DIA]VOLFILRCP
Endif
Affzo [M:DIA]VOLFILISS
Affzo [M:DIA]VOLFILSTO
Affzo [M:DIA]VOLFILRCP
#/ Issue 98932 - 2014-07-04 by RBA : Volumes managment evolution

End


Subprog SET_NOMFIC(COLREP,NOMIMP,TYPEXP)
Value Char COLREP()
Variable Char NOMIMP()
Value Integer TYPEXP
Local Char    FICSRV(GDIMFIC) , URL(GDIMFIC)
Local Char    REPERT(GDIMFIC) , MACHINE(GDIMFIC)

Read [ORP]ORP0=[M:DIA]ID
If !fstat
    If (GOS(1)="unix" & pat(left$([F:ORP]DRTISS,3),"!:\")) or left$([F:ORP]DRTISS,1)="#"
     If TYPEXP=1
        NOMIMP=evalue("[F:ORP]"+COLREP)
     Endif
    Elsif GOS(1)<>"unix" & pat(left$([F:ORP]DRTISS,3),"!:\") & filinfo([F:ORP]DRTISS,0)<=0
     If TYPEXP=1
        NOMIMP=evalue("[F:ORP]"+COLREP)
     Endif
    Else
     If TYPEXP=2
        NOMIMP=evalue("[F:ORP]"+COLREP)
     Else
        Call SET_NAMCLI(NOMIMP) From ORDSYS
     Endif
    Endif
Else
  If TYPEXP=1
    Call SET_NAMCLI(NOMIMP) From ORDSYS
  Endif
Endif

End



