######################################################################################
## Etiquette ajoutée par le superviseur (écran ORPINT) 07/09/2009 09:56:05 (VPO)
######################################################################################
Subprog AM_OPTION(VALEUR)
Variable Integer VALEUR
If VALEUR=4
    [M:DIA]TRTMOD=1
    Grizo [M:DIA]TRTMOD
    Grizo [M:DIA]STRDAT
    Grizo [M:DIA]ENDDAT
    Grizo [M:DIA]FORMULE
    Grizo [M:DIA]20
    Grizo [M:DIA]25
    Grizo [M:DIA]TRACE1
    Actzo [M:DIA]TRACE2
Else
    If VALEUR<>[M:DIA]OPTION
        [M:DIA]TRTMOD=2
    Endif
    Actzo [M:DIA]TRTMOD
    Actzo [M:DIA]STRDAT
    Actzo [M:DIA]ENDDAT
    Actzo [M:DIA]FORMULE
    Actzo [M:DIA]20
    Actzo [M:DIA]25
    Actzo [M:DIA]TRACE1
    Grizo [M:DIA]TRACE2
Endif
End



