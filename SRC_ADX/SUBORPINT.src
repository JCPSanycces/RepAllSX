&                         "UILocalFile="+ chr$(1) +"EXPSTOCK.csv"

# ressources secondaires
PATH = "tmp"+"/"+tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) + ".ilrss"
Callui RETOUR="" With     "UIAction="+chr$(1)+"GetFileAlways",
&                         "UIRemoteFile="+ chr$(1) +PATH,
&                         "UILocalDir="+ chr$(1) +"UserTemp",
&                         "UILocalFile="+ chr$(1) +"EXPRESSEC.csv"


Return

###############################################################################

$TRF_TEC
# centres de charge
PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilcdc")
WFICHIER = filpath([M:DIA]DRTISS,"EXPGRRES","csv","","",MACHINE)
If [M:DIA]TYPEXP=1
    Call COPCLI(PATH ,WFICHIER ,STAT) From ORDSYS
Elsif [M:DIA]TYPEXP=2
    Call COPIE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
Endif

#postes de charge
PATH = filpath("tmp",tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) ,"ilwst")
