&                         "UIRemoteFile="+ chr$(1) +PATH,
&                         "UILocalDir="+ chr$(1) +"UserTemp",
&                         "UILocalFile="+ chr$(1) +"EXPGRRESMatrix.csv"

# postes de remplacement
PATH = "tmp"+"/"+tolower([M:DIA]MFGFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")) + ".ilrpw"
