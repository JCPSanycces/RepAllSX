#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################
# UTITC27   Moulinette d'entretien des listes de gauche des    Module TC #
#           objets                                                       #
##########################################################################
# FGR 06/11/2009 : X3SUIVI58800
##########################################################################
Local Char DOSSIER(30)

  If 0=1 Then
    DOSSIER = nomap
    # Issue 108760 - 2015-08-07 by MAE :
    #Call SAIDOS(DOSSIER,"") From SAIDOS
    Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      # Issue 108760 - 2015-08-07 by MAE :
      #Read [ADS]DOSSIER=[L]DOSSIER
      #If fstat THEN
      #  Raz [F:ADS]
      #Endif
      If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("Correction") From LECFIC
      Call MAJ_UTITC27(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    For [ADS]DOSSIER
      If [F:ADS]DOSSIER <> "X3INDV6" and [F:ADS]DOSSIER <> "X3TESTV6" and [F:ADS]DOSSIER <> "DEMOAVV" and [F:ADS]DOSSIER <> "DEMOFRA" and [F:ADS]DOSSIER <> "DEMOTEST" Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTITC27(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC27(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Char WOBJET(GLONAOB)
Local Integer WNBR
Local Integer B_OK

  Call ECR_TRACE("UTITC27: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  If clalev([F:AOB]) = 0 : Local File =DOSSIER + ".AOBJET"  [AOB] : Endif
  Raz COMPTEUR
  #
  For WOBJET="PI1", "PN1", "PO1", "PO2", "PO3", "PR1", "PT1", "PT2", "SD2", "SI1", "SO1", "SO2", "SO3", "SQ1", "SR1"
    Read [AOB]ABREV=WOBJET
    If !fstat Then
      If [F:AOB]CODACT = "" Then # FGR 10/06/2011 : X3SUIVI73582 : Slt s'il n'y a pas de code activité
        Call MAJ_SEL(DOSSIER, WOBJET) From PATCHAOB
        #
        If [F:AOB]TYPGES <> 4 Then
          # Pas de fenêtre pour les browsers
          Call VALID("O" + WOBJET, DOSSIER, 1, B_OK) From VALWIN
          If B_OK <> 1 Then
            Call ECR_TRACE("Erreur revalidation fenêtre O" + WOBJET, 1) From GESECRAN
          Endif
        Endif
        #
        Call VALID (WOBJET, DOSSIER, 1, B_OK) From VALOBJ
        If B_OK <> 1 Then
          Call ECR_TRACE("Erreur revalidation objet" - WOBJET, 1) From GESECRAN
        Endif
        #
        COMPTEUR += 1
      Endif
    Endif
  Next WOBJET
  #
  Close Local File [AOB]
  Call ECR_TRACE("UTITC27 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI
  #If fstat THEN
  #  Raz [F:ADS]
  #Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"AOBJET") : End : Endif
  # End MAE 108760
  Call MAJ_UTITC27(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"AOBJET") : End : Endif
  Call MAJ_UTITC27(APPLI)
End

