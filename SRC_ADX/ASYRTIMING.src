Call LECTURE("#@C:\temp\ADMIN.tra",2) From TIMING
End

##       Subprog START(TMPFILE,SPROG)
##       Funprog STOP(ACTX,TMPFILE,SPROG,LOGFILE)
#######################
## Exemple :
##                STAT=func ASYRTIMING.START("",1)
##                STAT=func ASYRTIMING.STOP(MYACTX,"",1,WFICTRACE)
############################################################################

Funprog START(TMPFILE,SPROG)
Value Char    TMPFILE() : #Nom du fichier tempo sans extension et sans chemin (facultatif)
Value Integer SPROG : #Sou-pro 0=Non , 1=Oui

Local Integer ARET_VALUE
Local Char FILEPATH(GDIMFIC)

If [L]TMPFILE=""
FILEPATH=filpath("!tmp",tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(1)),"tra","","","")
Else
FILEPATH=filpath("!tmp",[L]TMPFILE,"tra","","","")
Endif
Call _ACTIVE(FILEPATH,SPROG)

End [L]ARET_VALUE

#-----------------------------------------------------------------------------#
Funprog STOP(ACTX,TMPFILE,SPROG,LOGFILE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char    TMPFILE() : #Nom du fichier tempo sans extension et sans chemin (facultatif)
Value Integer SPROG     : #Sou-pro 0=Non , 1=Oui
Variable Char LOGFILE   : #Nom du fichier de trace en retour

Local Integer ARET_VALUE

dbgstr(131) = ""
dbglong(20) = 0

Local Char FILEPATH(GDIMFIC)
If [L]TMPFILE=""
FILEPATH=filpath("!tmp",tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(1)),"tra","","","")
Else
FILEPATH=filpath("!tmp",[L]TMPFILE,"tra","","","")
Endif
If filinfo(FILEPATH,0)<=0
 # Fichier inexistant
 [L]ARET_VALUE= fmet ACTX.ASETERROR("","|"+FILEPATH-":"-mess(101,100,1),[V]CST_AERROR)
 End [L]ARET_VALUE
Endif

[L]ARET_VALUE = func _ARRET(ACTX,TMPFILE,FILEPATH,SPROG,LOGFILE)
End [L]ARET_VALUE

#-------------------------------------------------------------------------#
Subprog _ACTIVE(FILEPATH,SPROG)
Value Char    FILEPATH() : #chemin du fichier tempo
Value Integer SPROG : #Sou-pro 0=Non , 1=Oui
Openo [L]FILEPATH , 0
Openo
I = instr(1,[L]FILEPATH,"@")
If I
 dbgstr(131) = right$([L]FILEPATH,I+1)
Else
 dbgstr(131) = [L]FILEPATH
Endif
dbglong(20) = 200
End

#-----------------------------------------------------#
$CALCUL1
Local Char    LIGNE(250) , TRAITE(120) , PROG(120)
Local Integer PIL
Local Integer I , J , K , LL
Local Decimal TEMPS , PILT(1..2000) , TOTAL
Local Char    PILP(50)(1..2000) , PILS(80)(1..2000)
Local Char    TBPROG(120)(1..2000)
Local Integer NBPROG
Local Decimal NBAPP(1..2000) , TMP(1..2000)
Local Decimal HH,RESTE
Local Integer MM,SS,MS

fstat = 0
Rdseq LIGNE
LL = 0
While fstat=0
 LL += 1
 K = instr(1,LIGNE,",")
 If K
  TRAITE = vireblc(left$(LIGNE,K-1),2)
  L = instr(1,TRAITE,"$")
  If L
   TRAITE = left$(TRAITE,L-1)
  Endif
  J = instr(1,TRAITE,"TRT/")
  If J
   TRAITE = right$(TRAITE,J+4)
  Endif
  L = instr(L+1,LIGNE,":")
  If L
   PROG  = vireblc(seg$(LIGNE,K+1,L-1),2)
   TEMPS = val(right$(LIGNE,L+1))
   If right$(PROG,len(PROG)-2)="(1)"
    If PIL>=dim(PILP) : Break : Endif
    PIL += 1
    PILP(PIL) = TRAITE
    PILS(PIL) = "Call"-left$(PROG,len(PROG)-3)
    PILT(PIL) = TEMPS
   Elsif right$(PROG,len(PROG)-2)="(2)"
    If SPROG
     If PIL>=dim(PILP) : Break : Endif
     PIL += 1
     PILP(PIL) = TRAITE
     PILS(PIL) = "Gosub"-left$(PROG,len(PROG)-3)
     PILT(PIL) = TEMPS
    Endif
   Elsif right$(PROG,len(PROG)-2)="(0)"
    If PIL>0
     PROG = vireblc(left$(PROG,len(PROG)-3),2)
     If SPROG or PROG<>""
      K = find(PILS(PIL)-"From"-PILP(PIL),TBPROG(1..NBPROG))
      If K=0
       If NBPROG>=dim(TBPROG) : Break : Endif
       NBPROG += 1
       TBPROG(NBPROG) = PILS(PIL)-"From"-PILP(PIL)
       K = NBPROG
      Endif
      NBAPP(K) += 1
      TMP(K)   += TEMPS-PILT(PIL)
      For J=1 To PIL-1
       PILT(J) += TEMPS-PILT(PIL)
      Next J
      PIL -= 1
     Endif
    Endif
   Else
    Infbox "2) ligne"-num$(LL)-":"-LIGNE : End
   Endif
  Else
   Infbox "3) ligne"-num$(LL)-":"-LIGNE : End
  Endif
 Else
  Infbox "4) ligne"-num$(LL)-":"-LIGNE : End
 Endif
 Rdseq LIGNE
Wend

For K=1 To NBPROG
 If find(TBPROG(K)
& ,"Call OUINON From GESECRAN"
& ,"Call ERREUR From GESECRAN"
& ,"Call ERRTIT From GESECRAN"
& ,"Call MESSAGE From GESECRAN"
& ,"Call AVERTIR From GESECRAN"
& ,"Call ABANDON From GESECRAN"
& ,"Call SAITEX From GESECRAN"
& ,"Call LECFIC From LECFIC"
& )
  TMP(K) = 0
 Endif
 For LIGNE = "Gosub SAISIE_BOITE From WG"
  If left$(TBPROG(K),len(LIGNE))=LIGNE
   TMP(K) = 0
  Endif
 Next LIGNE
Next K

Sorta NBPROG TMP,NBAPP,TBPROG Order By -TMP(indice+1)
Return

#------------------------#
$CALCUL2
TOTAL = sum(TMP(1..NBPROG))
# Issue 83075 - 2012-07-09 by VPO : traduire temps total en hh:mm:ss:000
#Call ECR_TRACE(mess(75,126,1)-":"-num$(TOTAL)-"ms",0) From GESECRAN : # Temps total
HH=int(TOTAL/(60*60*1000))
RESTE=TOTAL-(HH*(60*60*1000))
MM=int(RESTE/(60*1000))
RESTE-=(MM*(60*1000))
SS=int(RESTE/1000)
MS=RESTE-(SS*1000)
Return

#-------------------------------------------------------------------------#
Funprog _ARRET(ACTX,TMPFILE,FILEPATH,SPROG,LOGFILE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char    TMPFILE() : #Nom du fichier tempo sans extension et sans chemin (facultatif)
Value Char    FILEPATH() : #chemin du fichier tempo
Value Integer SPROG : #Sou-pro 0=Non , 1=Oui
Variable Char LOGFILE : #Nom du fichier de trace en retour

Local Integer ARET_VALUE
Local Integer STAT

Openi FILEPATH
adxifs = ""
adxirs = chr$(10)

Onerrgo ERREUR
Gosub CALCUL1

Local Instance MYLOG Using C_ALOG
MYLOG=NewInstance C_ALOG
STAT=fmet MYLOG.ABEGINLOG(mess(93,126,1)-TMPFILE)

Gosub CALCUL2
Onerrgo

# Temps total
STAT=fmet MYLOG.APUTLINE(mess(75,126,1)-":"-num$(TOTAL)-"ms"-"->"-format$("N:10#",HH)+":"+format$("N0:2#",MM)+":"+format$("N0:2#",SS)+":"+format$("N0:3#",MS)-"(hh:mm:ss:000)",[V]CST_AINFO)

For K=1 To NBPROG
# Issue 83075 - 2012-07-09 by VPO : augmenter taille des nombres affichés sur timing
# LIGNE =  format$("K:50X",TBPROG(K))
# LIGNE -= format$("N:6#",NBAPP(K))
# LIGNE += format$("N:8#",TMP(K))-"ms"
# If TOTAL>0
#  LIGNE -= format$("N:2.2#",100*TMP(K)/TOTAL)+" %"
# Endif
# Call ECR_TRACE(LIGNE,0) From GESECRAN
 If TOTAL>0
   LIGNE=func ALOG_CSTD.FORMAT5(TBPROG(K),format$("N:20#",NBAPP(K)),format$("N:25#",TMP(K))-"ms",format$("N:2.2#",100*TMP(K)/TOTAL)+" %","",50,20,30,10,0)
 Else
   LIGNE=func ALOG_CSTD.FORMAT5(TBPROG(K),format$("N:20#",NBAPP(K)),format$("N:25#",TMP(K))-"ms","","",50,20,30,0,0)
 Endif
 STAT=fmet MYLOG.APUTLINE(LIGNE,[V]CST_AINFO)
Next K

STAT=fmet MYLOG.AENDLOG
LOGFILE=fmet MYLOG.AGETNAME
FreeInstance MYLOG
End [L]ARET_VALUE

#-------------------#
$ERREUR
# Fichier inexistant
[L]ARET_VALUE= fmet ACTX.ASETERROR("",mess(93,126,1)-num$(errl)-LIGNE-num$(LL)-errmes$(errn)-errm,[V]CST_AERROR)
End [L]ARET_VALUE
