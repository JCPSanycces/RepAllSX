# Gestion du masque MAC8
##########################################################################################################
Subprog IB_NBNOR
  Raz GBOUT1
  If [M:MAC8]CONNUM(nolign - 1) <> "" Then
    Call TEXTE(5562, GBOUT1) From OBJDIV      #Détail
  Endif
End

##########################################################################################################
Subprog IB_NBCRS

  Raz GBOUT1
  If [M:MAC9]BCONNUM(nolign - 1) <> "" Then
    Call TEXTE(5562, GBOUT1) From OBJDIV      #Détail
  Endif
End

