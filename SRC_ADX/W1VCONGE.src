Call TEXTE(45582,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_POP(zc) From W1VCONGE
Onkey   2 Titled GBOUTS Call S_POP(zc) From W1VCONGE
Onkey 144 Titled GBOUTP Call P_POP(zc) From W1VCONGE
Onkey 146 Titled GBOUTA Call SA_POP(zc) From W1VCONGE
Gosub _AFF
End

Subprog C_POP(VALEUR)
Variable Char    VALEUR()
## Action CONTPOP
Call CONTPOP(VALEUR,GCURLEG) From SUBPOP
If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("POP","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
 If !mkstat
  ## Action STD
  Call C_POP(VALEUR) From VCONGE
  If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
 Endif
Endif
Gosub _AFF
End

