$ON_TYPJOU
Onevent INIT_AREA Call D_TYPJOU(zc) From W1VCONGE
Onevent BEFORE_INPUT Call AS_TYPJOU(zc) From W1VCONGE
Return

Subprog D_TYPJOU(VALEUR)
Variable Integer VALEUR
If varinit([M]TYPJOU,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TYPJOU(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


