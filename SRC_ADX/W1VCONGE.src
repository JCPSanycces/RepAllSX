$AV_DATDEB
Chgfmt [M]DATDEB(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DATDEB" : GZNUM = 55304 : Endif
If !mkstat
 ## Action STD
 Call C_DATDEB(VALEUR) From VCONGE
 If mkstat : GERR = 1 : GZONE = "DATDEB" : GZNUM = 55304 : Endif
Endif
Gosub _AFF
End

