#<AdxTL>@(#)1.0.0.0 $Revision$
Raz GPILOBJ ,GNBMASKOUV
Call OBJET("ABW",GBIDC1,GBIDC2) From GOBJET
End

#------------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "LIENS"      : Gosub LIENS
 When "SETBOUT"    : Gosub SETBOUT
 When "STATUT"     : Gosub STATUT
 When "AVANTBOUT"  : Gosub AVANTBOUT
 When "RAZDUP"     : Gosub RAZDUP
 When "RAZCRE"     : Gosub RAZCRE
 When "VERIF_CRE"  : Gosub VERIF_CRE
Endcase
Return

#------------------------------------------------------------#
$OUVRE
Call MACHINE_BO("",GBIDC3) From ABICREBAS
If GBIDC3 = ""
 Call ECR_TRACE(mess(78,148,1),1) From GESECRAN : # Impossible de déterminer la machine BO
 OK = 0 : Return
Endif
Return

#------------------------------------------------------------#
$LIENS
Gosub CHARGE
Gosub GRISE_SOL
Gosub GRISE_DBA
Return

$VERIF_CRE
Call VERF_DOS([M]COD,[M]SOLBI,OK)
Return

Subprog VERF_DOS(COD,SOLBI,OK)
Value Char COD , SOLBI
Variable Integer OK
Local Integer ER
Local Char    MACHINE(250)
Onerrgo ER
If clalev([F:ADS])=0 : Local File ADOSSIER  [ADS] : Endif
OK = 1
Read [ADS]DOSSIER = COD
If !fstat
 # Ce code est déjà utilisé pour un nom de dossier
 GMESSAGE = COD-":"-mess(100,148,1)
 OK = 0 : End
Endif
For [ADS] Where DOSSIER<>nomap
 If filinfo(filpath("FIL","ABIDATWRH","fde",[F:ADS]DOSSIER),0)>0
  Local File =[F:ADS]DOSSIER+".ABIDATWRH" [ABW2]
  If !ER
   Read [F:ABW2]ABW0 = [L]COD
   If !ER & !fstat
    # Datawarehouse déja présent dans le dossier
    Call ERREUR([L]COD-":"-mess(91,148,1)-[F:ADS]DOSSIER) From GESECRAN
    OK = 0 : Break
   Endif
  Endif
  If clalev([F:ABW2])>0 : Close Local File [ABW2] : Endif
 Endif
Next ADS
If !OK : End : Endif
Call MACHINE_BO(SOLBI,MACHINE) From ABICREBAS
If MACHINE<>"" & filinfo(filpath("FIL","ADOVAL","fde",[L]COD,"",MACHINE),0)>0
 Call TYPDOS(MACHINE+"@"+[L]COD,K,CHAINE) From DOSCONT
 # Ce dossier correspond à une application
 Call ERREUR([L]COD-":"-mess(208,139,1)-CHAINE) From GESECRAN
 OK = 0 : End
Endif
Call VERF_REFBO(MACHINE,[L]COD,CHAINE,OK)
If !OK
 # Ce datawarehouse est utilisé par le dossier #
 Call ECR_TRACE(func AFNC.MES(mess(98,148,1),CHAINE),-1) From GESECRAN
 OK = 0 : End
Endif
End

Subprog VERF_REFBO(MACHINE,COD,REFBO,OK)
Value    Char    MACHINE,COD
Variable Char    REFBO
Variable Integer OK
Local Char    CHAINE(250) , ORDRE(250) , LISFIC(30)(1..50)
Local Integer NBFIC , K , I , OKREF
Gosub SET_EXT
OK = 0
If nomap=GDOSX3
 OK = 1
Elsif filinfo(filpath("",nomap,EXT,[L]COD,"",MACHINE),0)>0
 OK = 1
Else
 CHAINE = filpath("","","",[L]COD,"",MACHINE)
 K = instr(1,CHAINE,"@")
 If K : CHAINE = right$(CHAINE,K+1) : Endif
 ORDRE = 'lsadx -a'-[L]COD-CHAINE
 Call SYSTEME2(MACHINE,ORDRE,'',NBFIC,LISFIC) From ORDSYS
 NBFIC = min(NBFIC,dim(LISFIC))
 OKREF = 0
 REFBO = ""
 For I=1 To NBFIC
  K = instr(1,LISFIC(I),"."+EXT)
  If K : OKREF += 1 : Endif
 Next I
 If !OKREF
  OK = 1
 Else
  For I=1 To NBFIC
   K = instr(1,LISFIC(I),"."+EXT)
   If K
    REFBO = left$(LISFIC(I),K-1)
    Break
   Endif
  Next I
 Endif
Endif
End

$SET_EXT
Local Schar EXT(6)
EXT = "x3ref"
Return

$ER
ER = errn
Resume

$CHARGE
Local Integer ER
Call MACHINE_BO([M]SOLBI,[M]MACHINE) From ABICREBAS
Call VAR_BOWORLD("os",[M]SOLBI,"database",[M]TYPOS,ER) From ABICREBAS
Call VAR_BOWORLD("path",[M]SOLBI,"",[M]REP,ER) From ABICREBAS
Call VAR_BOWORLD("type",[M]SOLBI,"database",[M]TYPDBA,ER) From ABICREBAS
If dim([M]DATNAM)>0
 Call VAR_BOWORLD("name",[M]SOLBI,"database",[M]DATNAM,ER) From ABICREBAS
Endif
If dim([M]DATSRC)>0
 Onerrgo ER
 Call VARADX("DATASOURCE",[M]MACHINE,[M]DATSRC) From ADXD
 Onerrgo
Endif
Return

$GRISE_SOL
Gosub CONNECT
If OK_CONNECT & GADONIX<>2
 Diszo SOLBI
Else
 Actzo SOLBI
Endif
Return

$CONNECT
Local Integer OK_CONNECT
Onerrgo ER
OK_CONNECT = (filinfo(filpath("","","","","",[M]MACHINE),0)>0)
Onerrgo
If !ER
 OK_CONNECT = 1
Else
 OK_CONNECT = 0
Endif
Return

$GRISE_DBA
Case [M]TYPDBA
 When "ORACLE"
  [M]GRPFIL = 0
  Affzo GRPFIL
  Grizo GRPFIL
  Gosub CONNECT
  If OK_CONNECT & filinfo(filpath("","","",[M]COD,"",[M]MACHINE),0)>0
   Diszo SIZDAT , SIZIDX , CODDBA
  Else
   Actzo SIZDAT , SIZIDX , CODDBA
  Endif
 When "SQLSERVER"
  [M]SIZDAT = 0
  [M]SIZIDX = 0
  Affzo SIZDAT , SIZIDX
  Grizo SIZDAT , SIZIDX
  Gosub CONNECT
  If OK_CONNECT & filinfo(filpath("","","",[M]COD,"",[M]MACHINE),0)>0
   Diszo GRPFIL , CODDBA
  Else
   Actzo GRPFIL , CODDBA
  Endif
Endcase
Return

#----------------------------------#
$RAZDUP
$RAZCRE
If GADONIX=2
 Actzo SOLBI
Else
 Call PREM_SOLBI([M]SOLBI)
 Diszo SOLBI
 Gosub CHARGE
 Actzo CODDBA
 Case [M]TYPDBA
  When "ORACLE"
   Grizo GRPFIL
   Actzo SIZDAT , SIZIDX
  When "SQLSERVER"
   Grizo SIZDAT , SIZIDX
   Actzo GRPFIL
 Endcase
Endif
Return

#----------------------------------#
Subprog PREM_SOLBI(SOLBI)
Variable Char SOLBI
Local Char LIGNE(250) , NOMFIC(GDIMFIC)
Local Integer OKSOL , I , J
Call BOWORLD(NOMFIC) From ABICREBAS
If NOMFIC="" : Return : Endif
Openi NOMFIC,0 Using [BOS_]
Iomode adxifs ""  Using [BOS_]
Iomode adxirs chr$(10)  Using [BOS_]
Iomode adxium GUTF8  Using [BOS_]
Raz OKSOL
Rdseq LIGNE Using [BOS_]
While !fstat
 If instr(1,toupper(LIGNE),"<SOLUTION ")
  If instr(1,toupper(LIGNE),toupper("ID='"+GINSTID+"'"))
   OKSOL = 1
  Else
   OKSOL = 0
  Endif
 Elsif OKSOL & instr(1,toupper(LIGNE),toupper("</SOLUTION>"))
  OKSOL = 0
 Endif
 If OKSOL : # On est dans le noeud de la bonne solution x3
  If instr(1,toupper(LIGNE),toupper("<SOLUTIONBI "))
   I = instr(1,toupper(LIGNE),toupper("ID='"))
   If I
    I += 3
    J = instr(I+1,toupper(LIGNE),"'")
    If J
     SOLBI = seg$(LIGNE,I+1,J-1)
     Break
    Endif
   Endif
  Endif
 Endif
 Rdseq LIGNE Using [BOS_]
Wend
Openi Using [BOS_]
End

#----------------------------------#
$SETBOUT
Local Integer ER
Gosub CONNECT
If CLECUR=0 | REP="M" | !VERROU | !OK_CONNECT
 Call VIREBOUT(CHAINE,"V") From GOBJET
Else
 Call EXISTE_LOK(K)
 If K : CHMEN += "1" : Endif
 CHMEN += "2"
Endif
Return

Subprog EXISTE_LOK(OK)
Variable Integer OK
Local Char LOK(10)
Local Integer ER
OK = 0
Gosub CONNECT
If OK_CONNECT
 For LOK="synchro","valid","epuration"
  If filinfo(filpath("",LOK,"",[M]COD,"",[M]MACHINE),0)>0
   OK = 1 : Break
  Endif
 Next LOK
Endif
End

#----------------------------------#
$AVANTBOUT
Case BOUT
 When "V"
  If clalev([F:AXX]) : Close Local File [AXX] : Endif
  If clalev([F:ATX]) : Close Local File [ATX] : Endif
Endcase
Return

#----------------------------------#
$STATUT
Case BOUT
 When "1"
  Local Char LOK(10)
  Local Integer STAT
  For LOK="synchro","valid","epuration"
   If filinfo(filpath("",LOK,"",[M]COD,"",[M]MACHINE),0)>0
    Call EFFACE(filpath("",LOK,"",[M]COD,"",[M]MACHINE),STAT) From ORDSYS
   Endif
  Next LOK

 When "2"
  Local Integer STAT
  Call OUVRE_VLC(mess(2,148,1),"","") From GESECRAN
  Call AFF_VLC(mess(2,148,1),mess(78,134,1)) From GESECRAN
  Call OUVRE_TRACE("") From LECFIC
  Call VALIDATION_PARTIEL(nomap,[M]COD,2,1,STAT)
  Call FERME_TRACE From LECFIC
  Call FERME_VLC From GESECRAN
  If !STAT : Call LEC_TRACE From LECFIC : Endif
Endcase
Return

#----------------------------------#
Subprog VALIDATION_PARTIEL(APPLI,DATWAR,FORCE,SILENCE,OK)
Value Char APPLI , DATWAR
Value Integer FORCE , SILENCE
Variable Integer OK

Local Integer  I , J , K , W , L , STAT , ER , PARTIEL , USRFORCE
Local Char     MACHINE(GDIMFIC) , CHAINE(255)
Local Char     ORDSYS(250) , SUF(3) , FIC(GDIMFIC)

Global Integer GCRE

If clalev([F:ABW])=0 : Local File =APPLI+".ABIDATWRH" [ABW] : Endif

PARTIEL  = 1
USRFORCE = 1

Gosub VALID From ABIVALBAS

End

#------------------------------------------------------------#
Subprog AM_SOLBI(VALEUR)
Variable Char    VALEUR()
[M]SOLBI = VALEUR
Gosub CHARGE
Affzo
Gosub GRISE_DBA
End

Subprog D_CODDBA(VALEUR)
Variable Integer VALEUR
Local File ADOSSIER [AD_]
Read [AD_]DOSSIER=GDOSX3
If !fstat
 VALEUR = [F:AD_]CODDBA
Endif
Close Local File [AD_]
End
