#<AdxTL>@(#)1.0.0.0 $Revision$
#--------------------------------------------------------------------------
#                       Budgets Opérationnels
#--------------------------------------------------------------------------
#   Objet    : ENT
#   Fonction : GESENT - Entité
#   Action   : GOBJET
#   Ecran concerné : ENT1
#   Description : Définition d'entité pour les budgets opérationnels
#
#--------------------------------------------------------------------------

Raz GPILOBJ,GNBMASKOUV
Call OBJET("ENT",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "LIENS"        : Gosub LIENS
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "CREATION"     : Gosub CREATION
 When "APRES_CRE"    : Gosub APRES_CRE
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "MODIF"        : Gosub MODIF
 When "AP_CHANGE"    : Gosub AP_CHANGE
 When "ANNULE"       : Gosub ANNULE
 When "AP_ANNULE"    : Gosub AP_ANNULE
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "SEL_LISTE"    : Gosub SEL_LISTE
 When "RAZDUP"       : Gosub RAZDUP
 When Default
Endcase
Return

$OUVRE
#Tables utilisées
If !clalev([F:LED]) : Local File GLED       [LED] : Endif
If !clalev([F:DIE]) : Local File GDIE       [DIE] : Endif
If !clalev([F:CCE]) : Local File CACCE      [CCE] : Endif
If !clalev([F:PER]) : Local File PERIOD     [PER] : Endif
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:GCM]) : Local File GACM       [GCM] : Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([F:FIY]) : Local File FISCALYEAR [FIY] : Endif
If !clalev([F:ENV]) : Local File ENVELOPPE  [ENV] : Endif
If !clalev([F:BUD]) : Local File BUD        [BUD] : Endif
If !clalev([F:CYM]) : Local File GCCEPYM    [CYM] : Endif
If !clalev([F:CRY]) : Local File GCCEGRUPYM [CRY] : Endif
If !clalev([F:ENT2]) : Local File ENTITE    [ENT2] : Endif

#Variables utiles
Local Libelle LEDTYPGEN, LEDTYPANA
Local Char CODLED(GLONLED), DEVLED(GLONCUR), AXE(GLONDIE)
Local Integer GRISE, OKDIE
Local Integer I,J
Default Mask [ENT1]
Return

$SETBOUT
If GREP<>"C" & GREP<>"D"
 If [M]NOMPYM<>""
  If [M]LEV=1
   Look [CRY]CRY4 =[M]NOMPYM;[M]ENT
  Else
   Look [CRY]CRY4 =[M]NOMPYM;[M]ENTRAT
  Endif
  If !fstat
   CHMEN +="2"
  Endif
  Look [CYM]CYM0 = [M]NOMPYM
  If !fstat
   CHMEN +="3"
  Endif
 Endif

Endif
CHMEN+="1"

Return

$LIENS
Call LECTEXTRA([M:ENT1]DESTRA,"ENTITE","DESTRA",[M:ENT1]ENT,"") From ATEXTRA
Call LECTEXTRA([M:ENT1]SHOTRA,"ENTITE","SHOTRA",[M:ENT1]ENT,"") From ATEXTRA
Actzo [M:ENT1]
If [F:ENT]CPY<>""
 Call C_CPY([F:ENT]CPY)
 Call AM_CPY([F:ENT]CPY)
Else
  I=0
  For [DIE]DIE0 Where ENT=2
   Actzo [M:ENT1]COCHE(I)
   [M:ENT1]SELDIE(I) = [F:DIE]DIE
   If find([F:DIE]DIE,[F:ENT]DIE(0..dim([F:ENT]DIE)-1))
    [M:ENT1]COCHE(I)  = 2
    Filter [BUD] Where (DIE1=[F:DIE]DIE & CCE1=[M:ENT1]ENT) | (DIE2=[F:DIE]DIE & CCE2=[M:ENT1]ENT)
&   | (DIE3=[F:DIE]DIE & CCE3=[M:ENT1]ENT)| (DIE4=[F:DIE]DIE & CCE4=[M:ENT1]ENT)| (DIE5=[F:DIE]DIE & CCE5=[M:ENT1]ENT)
&   | (DIE6=[F:DIE]DIE & CCE6=[M:ENT1]ENT)| (DIE7=[F:DIE]DIE & CCE7=[M:ENT1]ENT)| (DIE8=[F:DIE]DIE & CCE8=[M:ENT1]ENT)
&   | (DIE9=[F:DIE]DIE & CCE9=[M:ENT1]ENT)
    Look [BUD] First
    If !fstat : Grizo [M:ENT1]COCHE(I) : Endif
    Filter [BUD]
    #
   Endif
   I+=1
  Next
  [M:ENT1]NBDIE = I
Endif
Local Char TOPENT(GLONENT)
Call GETFIRSTENT([F:ENT]ENT,TOPENT)
[M:ENT1]NOMPYM=left$(TOPENT,5)
Affzo [M:ENT1]
Return

$RAZDUP
Actzo [M]
Gosub MAJDIE
If [M]CPY<>""
 Grizo [M]NBDIE
Endif
Affzo [M]
Return

$MODIF
Gosub TEXTRA
Gosub MODCCE
Gosub MAJLEV
Return

$VERIF_CRE
#28/04/11 - pk une seule entité de niveau 1
#For [ENT]ENT0
# If [F:ENT]LEV=1 & [M]LEV=1
#  #Il ne peut y avoir qu'une seule entité de niveau 1 sur le dossier
#  GMESSAGE=mess(168,108,1)
#  OK=0 : Break
# Endif
#Next
OKDIE=0
For I=0 To [M]NBDIE-1
 If [M:ENT1]COCHE(I)=2 : OKDIE=1 : Break : Endif
Next
If !OKDIE
 #Au moins un axe doit être renseigné
 GMESSAGE=mess(135,107,1)
 GOK=0
Endif
Return

$CREATION
Gosub TEXTRA
Return

$APRES_CRE
#En création d'une entité, il faut créer une section analytique 'entité' sur l'axe
Gosub CRECCE
Return

$VERIF_MOD
OKDIE=0
For I=0 To [M]NBDIE-1
 If [M:ENT1]COCHE(I)=2 : OKDIE=1 : Break : Endif
Next
If !OKDIE
 #Au moins un axe doit être renseigné
 GMESSAGE=mess(135,107,1)
 GOK=0
Endif
Return

$MAJDIE
Raz [M]DIE
J=0
For I=0 To [M]NBDIE-1
 If [M]COCHE(I)=2
  [M]DIE(J)=[M]SELDIE(I)
  J+=1
 Endif
Next
Return

$CRECCE
#Création des sections sur le ou les axe(s) selectionné(s)
For I=0 To [M]NBDIE-1
 If [M]COCHE(I)=2
  Raz [F:CCE]
  [F:CCE]DIE    = [M]SELDIE(I)
  [F:CCE]CCE    = [M:ENT1]ENT
  [F:CCE]ENAFLG = [M:ENT1]ENAFLG
  [F:CCE]ACS    = [M:ENT1]ACS
  [F:CCE]VLYSTR = [M:ENT1]VLYSTR
  [F:CCE]VLYEND = [M:ENT1]VLYEND
  [F:CCE]FCY    = [M:ENT1]CPY
  [F:CCE]BUDTRK = 2
  [F:CCE]IPT    = 2
  Write [CCE]
  If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Break : Endif
  Call DUPTEXTRA("ENTITE","DESTRA",CLECUR1,"","CACCE","DESTRA",[M]SELDIE(I),[M:ENT1]ENT)  From ATEXTRA
  Call DUPTEXTRA("ENTITE","SHOTRA",CLECUR1,"","CACCE","SHOTRA",[M]SELDIE(I),[M:ENT1]ENT)  From ATEXTRA
 Endif
Next
Return

$MODCCE
For [DIE]DIE0 Where ENT=2
 I=find([F:DIE]DIE,[M]DIE(0..dim([F:ENT]DIE)-1))
 If I
  J=find([F:DIE]DIE,[M]SELDIE(0..[M]NBDIE-1))
  If J & [M]COCHE(J-1)=2
   Readlock [CCE]CCE0 = [M]SELDIE(J-1);[M:ENT1]ENT
   If fstat
    #La section n'existe pas on la créer
    Raz [F:CCE]
    [F:CCE]DIE    = [M]SELDIE(J-1)
    [F:CCE]CCE    = [M:ENT1]ENT
    [F:CCE]ENAFLG = [M:ENT1]ENAFLG
    [F:CCE]ACS    = [M:ENT1]ACS
    [F:CCE]VLYSTR = [M:ENT1]VLYSTR
    [F:CCE]VLYEND = [M:ENT1]VLYEND
    [F:CCE]FCY    = [M:ENT1]CPY
    [F:CCE]BUDTRK = 2
    [F:CCE]IPT    = 2
    Write [CCE]
    If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Break : Endif
    Call DUPTEXTRA("ENTITE","DESTRA",CLECUR1,"","CACCE","DESTRA",[M]SELDIE(J-1),[M:ENT1]ENT)  From ATEXTRA
    Call DUPTEXTRA("ENTITE","SHOTRA",CLECUR1,"","CACCE","SHOTRA",[M]SELDIE(J-1),[M:ENT1]ENT)  From ATEXTRA
   Else
    #La section existe on la modifie simplement
    [F:CCE]ENAFLG = [M:ENT1]ENAFLG
    [F:CCE]ACS    = [M:ENT1]ACS
    [F:CCE]VLYSTR = [M:ENT1]VLYSTR
    [F:CCE]VLYEND = [M:ENT1]VLYEND
    [F:CCE]FCY    = [M:ENT1]CPY
    [F:CCE]IPT    = 2
    Rewrite [CCE]
    If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Break : Endif
    Call MAJTEXTRA([M:ENT1]DESTRA,"CACCE","DESTRA",[M]SELDIE(J-1),[M:ENT1]ENT) From ATEXTRA
    Call MAJTEXTRA([M:ENT1]SHOTRA,"CACCE","SHOTRA",[M]SELDIE(J-1),[M:ENT1]ENT) From ATEXTRA
   Endif
  Endif
 Else
  #Si décoché, suppression de la section correspondante
  Look [CCE]CCE0 = [F:DIE]DIE;[M:ENT1]ENT
  If !fstat
   Delete [CCE]CCE0 = [F:DIE]DIE;[M:ENT1]ENT
   If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Break : Endif
  Endif
 Endif
Next
Return


$MAJLEV
Local File ENTITE [ENTR]
Local File ENTITE [ENT1], ENTITE [ENT2], ENTITE [ENT3], ENTITE [ENT4], ENTITE [ENT5], ENTITE [ENT6], ENTITE [ENT7],ENTITE [ENT8]
For [ENT1]ENT0 Where ENTRAT=[M]ENT
 Readlock [ENTR]ENT0=[F:ENT1]ENT
 If !fstat
  [F:ENTR]LEV=[M]LEV+1
  Rewrite [ENTR]
  If fstat : GOK = 0 : Call FSTA("ENTR") From GLOCK : Endif
 Endif
 For [ENT2]ENT0 Where ENTRAT=[F:ENT1]ENT
  Readlock [ENTR]ENT0=[F:ENT2]ENT
  If !fstat
   [F:ENTR]LEV=[M]LEV+2
   Rewrite [ENTR]
   If fstat : GOK = 0 : Call FSTA("ENTR") From GLOCK : Endif
  Endif
  For [ENT3]ENT0 Where ENTRAT=[F:ENT2]ENT
   Readlock [ENTR]ENT0=[F:ENT3]ENT
   If !fstat
    [F:ENTR]LEV=[M]LEV+3
    Rewrite [ENTR]
    If fstat : GOK = 0 : Call FSTA("ENTR") From GLOCK : Endif
   Endif
   For [ENT4]ENT0 Where ENTRAT=[F:ENT3]ENT
    Readlock [ENTR]ENT0=[F:ENT4]ENT
    If !fstat
     [F:ENTR]LEV=[M]LEV+4
     Rewrite [ENTR]
     If fstat : GOK = 0 : Call FSTA("ENTR") From GLOCK : Endif
    Endif
    For [ENT5]ENT0 Where ENTRAT=[F:ENT4]ENT
     Readlock [ENTR]ENT0=[F:ENT5]ENT
     If !fstat
      [F:ENTR]LEV=[M]LEV+5
      Rewrite [ENTR]
      If fstat : GOK = 0 : Call FSTA("ENTR") From GLOCK : Endif
     Endif
     For [ENT6]ENT0 Where ENTRAT=[F:ENT5]ENT
      Readlock [ENTR]ENT0=[F:ENT6]ENT
      If !fstat
       [F:ENTR]LEV=[M]LEV+6
       Rewrite [ENTR]
       If fstat : GOK = 0 : Call FSTA("ENTR") From GLOCK : Endif
      Endif
      For [ENT7]ENT0 Where ENTRAT=[F:ENT6]ENT
       Readlock [ENTR]ENT0=[F:ENT7]ENT
       If !fstat
        [F:ENTR]LEV=[M]LEV+7
        Rewrite [ENTR]
        If fstat : GOK = 0 : Call FSTA("ENTR") From GLOCK : Endif
       Endif
       For [ENT8]ENT0 Where ENTRAT=[F:ENT7]ENT
        Readlock [ENTR]ENT0=[F:ENT8]ENT
        If !fstat
         [F:ENTR]LEV=[M]LEV+8
         Rewrite [ENTR]
         If fstat : GOK = 0 : Call FSTA("ENTR") From GLOCK : Endif
        Endif
       Next
      Next
     Next
    Next
   Next
  Next
 Next
Next
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("ENTITE","DESTRA",CLECUR1,"","ENTITE","DESTRA",[M:ENT1]ENT,"")  From ATEXTRA
 Call DUPTEXTRA("ENTITE","SHOTRA",CLECUR1,"","ENTITE","SHOTRA",[M:ENT1]ENT,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M:ENT1]DESTRA,"ENTITE","DESTRA",[M:ENT1]ENT,"") From ATEXTRA
Call MAJTEXTRA([M:ENT1]SHOTRA,"ENTITE","SHOTRA",[M:ENT1]ENT,"") From ATEXTRA
Return

$AP_CHANGE
Call CHGTEXTRA("ENTITE","DESTRA",[M:ENT1]ENT,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("ENTITE","SHOTRA",[M:ENT1]ENT,"",NCODE,"") From ATEXTRA
Return

$ANNULE
#En fait il faut surpprimer la/les section(s) correspondante(s) sur tous les axes
Delete [CCE] Where CCE=[M]ENT
If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Return : Endif
For [DIE]DIE0
 Call SUPTEXTRA("CACCE","DESTRA",[F:DIE]DIE,[M:ENT1]ENT) From ATEXTRA
 Call SUPTEXTRA("CACCE","SHOTRA",[F:DIE]DIE,[M:ENT1]ENT) From ATEXTRA
Next

# Annulation des Textes Traduisibles
Call SUPTEXTRA("ENTITE","DESTRA",[M:ENT1]ENT,"") From ATEXTRA
Call SUPTEXTRA("ENTITE","SHOTRA",[M:ENT1]ENT,"") From ATEXTRA
Return

$AP_ANNULE
#Suppression dans la pyramide
#- n'est possible que si l'entité n'est pas une entité de rattachement
#  => cela et pris en compte dans la table ENTITE, champ ENTRAT suppression->bloquant
#-idem pour rattachement
#-en revanche si l'entité est de dernier niveau de sa branche, on passe ici
# (elle est donc déclaré en tant que section dans la pyramide)
# => On doit alors
# 1) supprimé les liens dans GCCEGRUPYM, GCCEPYMLIK
# 2) Changer sont entité de rattachement en Section si aucune autre entité n'est rattachée à cette entité de rattachement
# En allant au plus simple suffit de détruire et recréer !!
If [M]CPY<>""
 Local Char TOPENT(GLONENT)
 Call GETFIRSTENT([M]ENTRAT,[L]TOPENT)
 Call EFFACE(left$(TOPENT,5),1) From PYRDELCCE
 Call GENPYR(TOPENT,0)
Endif
Return

$SEL_TABLE
Case TABLE
 When "SELENT"
  If !clalev([F:ENT]) : Local File ENTITE [ENT] : Endif
  Default File [ENT]
  If PARAM(1)<>""
   CRITERE = 'CPY="'+PARAM(1)+'" | CPY=""'
  Endif
  OBJET = "ENT"
Endcase
Return

$SEL_LISTE
Case LISTE
 When "SELCPY" : Gosub S_CPYENT
Endcase
Return

$S_CPYENT
Local Libelle LEDTYPGEN, LEDTYPANA
Local Char CODLED(GLONLED), DEVLED(GLONCUR)
Local Char TEXTE(GLONDES)(1..max(1,nbrecord([CPY])),1..2)
Local Char TEX(GLONDES)(1..max(1,nbrecord([CPY])))
TIT = mess(40,100,1) :# Choix
TIT(1)=mess(26,113,1) :# Société
TIT(2)=mess(3,113,1) :# Intitulé
Local Integer NBTEX : NBTEX=0
For [CPY]CPY0 Where CPYLEGFLG=2
 Call SETMAINREF([F:CPY]CPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
 Call LECLED([F:CPY]CPY,LEDTYPANA,CODLED,DEVLED) From CPTDIV
 Call LECTURE("LED",CODLED,"") From CONTOBJ
 If [F:LED]GDD=2 :# Référentiel Flagué Budgets opérationnels
  NBTEX += 1
  TEX(NBTEX)   = [F:CPY]CPY
  TEXTE(NBTEX,1) = [F:CPY]CPY
  TEXTE(NBTEX,2) = [F:CPY]CPYNAM
 Endif
Next
Return


######################################################################################
##------------------------- Etiquettes de l'écran ENT1 -----------------------------##
######################################################################################

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer INDENV, INDENT, INDCCE3

If GREP="C" | GREP="D" : End : Endif
If clalev([F:BUD])=0 : Local File BUD [BUD] :Endif
Columns [BUD] (BUD)

#Si une enveloppe contient l'entité ou qu'une ligne budgétaire utilise l'entité, on ne peut changer la société
GRISE=0
For [ENV]ENV0
 If [F:ENV]ENTMNA=[M]ENT | [F:ENV]ENTAPP=[M]ENT | [F:ENV]ENTRAT=[M]ENT : GRISE=1 : Break : Endif
 Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
 For [BUD] Where evalue('CCE'+num$(INDENV))=[F:ENV]ENV and evalue('[F:BUD]CCE'+num$(INDENT))=[M]ENT
  GRISE=1 : Break 2
 Next
Next
If GRISE
  Grizo [M]CPY
  mkstat=2
Endif
Columns [BUD] (BUD)
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 #La société existe?
 If !find(VALEUR,GSOC(1..GNBSOC))
  GMESSAGE = mess(81,116,1) :# Société incorrecte
  mkstat=2 : End
 Endif
 #Contrôle que le référentiel de la société contient un axe entité
 Local Libelle LEDTYPGEN, LEDTYPANA
 Local Char CODLED(GLONLED), DEVLED(GLONCUR)
 Call SETMAINREF(VALEUR,LEDTYPGEN,LEDTYPANA) From CPTDIV
 Call LECLED(VALEUR,LEDTYPANA,CODLED,DEVLED) From CPTDIV
 Call LECTURE("LED",CODLED,"") From CONTOBJ
 If [F:LED]GDD<>2
  #Seules sont autorisées les sociétés/sites dont le référentiel analytique principal est flagué Gestion des dépenses
  GMESSAGE = mess(114,108,1)
  mkstat=2 : End
 Endif
        # Raz [M]NBDIE,SELDIE,COCHE,DIE
        # #Axes des entités de la société
        # For I=0 To dim([F:LED]DIE)-1
        #  Call LECTURE("DIE",[F:LED]DIE(I),"") From CONTOBJ
        #  If [F:DIE]ENT=2
        #   [M]DIE(0)=[F:DIE]DIE
        #   [M]SELDIE(0)=[F:DIE]DIE
        #   [M]COCHE(0)=2
        #   [M]NBDIE=1
        #   Break :#Puisqu'il n'y a qu'un seul axe flagué ENT entité par référentiel
        #  Endif
        # Next
        # Affzo [M]
        # Grizo [M]NBDIE
        #Else
        # #société vide on charge toutes les axes entité suceptibles d'être utilisé
        # I=0
        # Raz [M]NBDIE,DIE,COCHE
        # For [DIE]DIE0 Where ENT=2
        #  [M:ENT1]SELDIE(I) = [F:DIE]DIE
        #  I+=1
        # Next
        # [M:ENT1]NBDIE = I
        # Affzo [M]
        # Actzo [M]NBDIE
Endif

If [M]LEV>1
  #Contrôle si une entité de rattachement
  # société vide : la société de l'entité de rattachement doit être vide également!
  # société renseignée : la société de l'entité de rattachement doit être identique ou vide
  # [M]ENT de niveau X
  #----/t entité  au-dessus (niveau X-1)
  #A: Si CPY(X-1)<>Vide -> CPY(X)=CPY(X-1)
  #B: Si CPY(X-1)=Vide  -> CPY(X)=Vide OU Autre si pas d'entité rattaché (=pas de ctrl)
  #                     -> CPY(X)=Vide OU CPY(X+1) si entité rattachée à celle en cours
  #----/t entité en-dessous (niveau X+1)
  #C: si CPY(X+1)<>Vide -> CPY(X)=Vide OU CPY(X+1)
  #D: si CPY(X+1)=Vide  -> CPY(X)=Vide

 Local File ENTITE [ENT2], ENTITE [ENT3]
 Local Integer ISRAT,ISRATVIDE,ISRATPLEIN : ISRAT=0 : ISRATVIDE=0 : ISRATPLEIN=0
 Local Char SOCDOWN(GLONCPY) : SOCDOWN=""
 Filter [ENT3] Where ENTRAT=[M]ENT
 Look [ENT3]ENT0 First
 If !fstat : ISRAT=1 : Endif
 If ISRAT
  For [ENT3]ENT0 Where CPY=""
   ISRATVIDE=1 : Break
  Next
  #D: si CPY(X+1)=Vide  -> CPY(X)=Vide
  If ISRATVIDE & VALEUR<>""
   If GREP<>"D" : Raz [M]CPY : Affzo [M]CPY : Endif
   #Une entité fille à sa société à vide, donc la société de cette entité ne peut être que vide
   GMESSAGE=mess(101,108,1)
   mkstat=2 : End
  Endif
  #C: si CPY(X+1)<>Vide -> CPY(X)=Vide OU CPY(X+1)
  For [ENT3]ENT0 Where CPY<>""
   If SOCDOWN<>"" & SOCDOWN<>VALEUR
    If VALEUR<>""
     #Des entités rattachées comportent des sociétés différentes, le code société de cette entité doit être à blanc.
     GMESSAGE=mess(231,108,1)
     If GREP<>"D" : Raz [M]CPY : Affzo [M]CPY : Endif
     mkstat=2 : Break
    Endif
   Endif
   ISRATPLEIN=1
   SOCDOWN=[F:ENT3]CPY
  Next
 Endif
 Filter [ENT3]
 If mkstat=2 : End : Endif

 Read [ENT2]ENT0 = [M]ENTRAT
 If !fstat
  If [F:ENT2]CPY<>""
   #A: Si CPY(X-1)<>Vide -> CPY(X)=CPY(X-1)
   If VALEUR<>[F:ENT2]CPY
   [M]CPY=[F:ENT2]CPY : Affzo [M]CPY
    #L'entité ne peut pas être rattachée à une entité de société différente
    GMESSAGE=mess(187,108,1)
    mkstat=2 : End
   Endif
  Else
   #B: Si CPY(X-1)=Vide  -> CPY(X)=Vide OU Autre si pas d'entité rattachée (=pas de ctrl)
   #                     -> CPY(X)=Vide OU CPY(X+1) si entité rattachée à celle en cours
   If ISRAT
    If VALEUR<>"" & VALEUR<>SOCDOWN
     #Société incompatible avec la/les entité(s) rattachée(s)
     GMESSAGE=mess(230,108,1)
     mkstat=2 : End
    Endif
   Endif
  Endif
 Endif
Endif
If [M]NBDIE=0
 Call AM_CPY(VALEUR)
Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Raz [M]NBDIE,SELDIE,COCHE,DIE
 #Axes des entités de la société
 For I=0 To dim([F:LED]DIE)-1
  Call LECTURE("DIE",[F:LED]DIE(I),"") From CONTOBJ
  If [F:DIE]ENT=2
   [M]DIE(0)=[F:DIE]DIE
   [M]SELDIE(0)=[F:DIE]DIE
   [M]COCHE(0)=2
   [M]NBDIE=1
   Break :#Puisqu'il n'y a qu'un seul axe flagué ENT entité par référentiel
  Endif
 Next
 Affzo [M]
 Grizo [M]COCHE :#Pour laisser le clic droi Section accessible
Else
 #société vide on charge toutes les axes entité suceptibles d'être utilisé
 I=0
 Raz [M]NBDIE,DIE,COCHE
 For [DIE]DIE0 Where ENT=2
  [M:ENT1]SELDIE(I) = [F:DIE]DIE
  I+=1
 Next
 [M:ENT1]NBDIE = I
 Affzo [M]
 Actzo [M]NBDIE
Endif
End

Subprog AM_COCHE(VALEUR)
Variable Integer VALEUR
Local Integer J
If GIMPORT & [M]CPY=""
 J = 0
 Raz [M]DIE
 For I=0 To [M]NBDIE-1
  If find([M]SELDIE(I),[F:ENT]DIE)
   [M]COCHE(I) = 2
   [M]DIE(J) = [M]SELDIE(I)
   J +=1
   If indice=I : VALEUR = 2 : Endif
  Endif
 Next
 End
Endif

[M]COCHE(nolign-1)=VALEUR
Raz [M]DIE
J=0
For I=0 To [M]NBDIE-1
 If [M]COCHE(I)=2
  [M]DIE(J)=[M]SELDIE(I)
  J+=1
 Endif
Next
End

Subprog C_ENTAPP(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR=[M]ENT
Endif
If VALEUR<>[M]ENT
 Call CONTROLE("ENT","!$",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : End : Endif
 If [F:ENT]ACS<>""
  Call CONTEXE([F:ENT]ACS) From CPTSUB
  If mkstat : End : Endif
 Endif
Endif
End

Subprog C_ENTRAT(VALEUR)
Variable Char    VALEUR()
Local File ENTITE [ENT2]
If VALEUR<>""
 If VALEUR=[M]ENT
  #Une entité ne peut pas être rattachée à elle-même
  GMESSAGE = mess(106,108,1)
  mkstat = 2 : End
 Endif

 ## Ctrl important que pas entité fille de celle en cours en modif
 Local Integer NBENT : #Nb d'entité fille
 Local Integer NBNIV : #Nb de niveau
 Local Char LISTENTF(GLONENT)(1..50) :#liste des entités filles
 Local Char LISTCPYF(GLONCPY)(1..50) :#liste des sociétés des entités filles
 Call GETENTFILLE([M]ENT,NBENT,NBNIV,LISTENTF,LISTCPYF)
 If find(VALEUR,LISTENTF(1..50))
  Raz [M]ENTRAT : Affzo [M]ENTRAT
  #L'entité ne peut être rattachée à une de ses entités filles
  GMESSAGE=mess(229,108,1)
  mkstat=2 : End
 Endif

 Read [ENT2]ENT0 = VALEUR
 If !fstat
  [M]LEV = [F:ENT2]LEV+1
  #En création/duplication
  If GREP="C" :#| GREP="D"
   [M]CPY=[F:ENT2]CPY : Affzo [M]CPY
   End
  Endif
  #En modif
  If [M]CPY<>""
   If [F:ENT2]CPY<>[M]CPY & [F:ENT2]CPY<>""
    #L'entité ne peut pas être rattachée à une entité de société différente
    GMESSAGE=mess(187,108,1)
    mkstat=2 : End
   Endif
  Else
   If [F:ENT2]CPY<>""
    #L'entité ne peut pas être rattachée à une entité de société différente
    GMESSAGE=mess(187,108,1)
    mkstat=2 : End
   Endif
  Endif
  If [F:ENT]ACS<>""
   Call CONTEXE([F:ENT]ACS) From CPTSUB
   If mkstat : End : Endif
  Endif
 Endif
Else
 [M]LEV = 1
Endif
End

Subprog GETENTFILLE(ENTDEP,NBENT,NBNIV,LISTENTF,LISTCPYF)
Value Char    ENTDEP : #entité de départ
Variable Integer NBENT : #Nb d'entité fille
Variable Integer NBNIV : #Nb de niveau
Variable Char LISTENTF()(1..) :#liste des entités filles
Variable Char LISTCPYF()(1..) :#liste des sociétés des entités filles

Local File ENTITE [ENT1], ENTITE [ENT2], ENTITE [ENT3], ENTITE [ENT4], ENTITE [ENT5], ENTITE [ENT6], ENTITE [ENT7],ENTITE [ENT8]
# Liste des entités de rattachement qui seront donc des groupes...
Local Char LISTENTFGRP(GLONENT)(1..200)
Local Integer K,J

NBNIV=1 : K=1 : J=1

For [ENT1]ENT0 Where ENTRAT=ENTDEP
 NBNIV=2
 LISTENTF(K)=[F:ENT1]ENT
 LISTCPYF(K)=[F:ENT1]CPY : K+=1
 For [ENT2]ENT0 Where ENTRAT=[F:ENT1]ENT
  If !find([F:ENT1]ENT,LISTENTFGRP(1..200)) : LISTENTFGRP(J)=[F:ENT1]ENT : J+=1 : Endif
  NBNIV=3
  LISTENTF(K)=[F:ENT2]ENT
  LISTCPYF(K)=[F:ENT2]CPY : K+=1
  For [ENT3]ENT0 Where ENTRAT=[F:ENT2]ENT
   If !find([F:ENT2]ENT,LISTENTFGRP(1..200)) : LISTENTFGRP(J)=[F:ENT2]ENT : J+=1 : Endif
   NBNIV=4
   LISTENTF(K)=[F:ENT3]ENT
   LISTCPYF(K)=[F:ENT3]CPY : K+=1
   For [ENT4]ENT0 Where ENTRAT=[F:ENT3]ENT
    If !find([F:ENT3]ENT,LISTENTFGRP(1..200)) : LISTENTFGRP(J)=[F:ENT3]ENT : J+=1 : Endif
    NBNIV=5
    LISTENTF(K)=[F:ENT4]ENT
    LISTCPYF(K)=[F:ENT4]CPY : K+=1
    For [ENT5]ENT0 Where ENTRAT=[F:ENT4]ENT
     If !find([F:ENT4]ENT,LISTENTFGRP(1..200)) : LISTENTFGRP(J)=[F:ENT4]ENT : J+=1 : Endif
     NBNIV=6
     LISTENTF(K)=[F:ENT5]ENT
     LISTCPYF(K)=[F:ENT5]CPY : K+=1
     For [ENT6]ENT0 Where ENTRAT=[F:ENT5]ENT
      If !find([F:ENT5]ENT,LISTENTFGRP(1..200)) : LISTENTFGRP(J)=[F:ENT5]ENT : J+=1 : Endif
      NBNIV=7
      LISTENTF(K)=[F:ENT6]ENT
      LISTCPYF(K)=[F:ENT6]CPY : K+=1
      For [ENT7]ENT0 Where ENTRAT=[F:ENT6]ENT
       If !find([F:ENT6]ENT,LISTENTFGRP(1..200)) : LISTENTFGRP(J)=[F:ENT6]ENT : J+=1 : Endif
       NBNIV=8
       LISTENTF(K)=[F:ENT7]ENT
       LISTCPYF(K)=[F:ENT7]CPY : K+=1
       For [ENT8]ENT0 Where ENTRAT=[F:ENT7]ENT
        If !find([F:ENT7]ENT,LISTENTFGRP(1..200)) : LISTENTFGRP(J)=[F:ENT7]ENT : J+=1 : Endif
        NBNIV=9
        LISTENTF(K)=[F:ENT8]ENT
        LISTCPYF(K)=[F:ENT8]CPY : K+=1
       Next
      Next
     Next
    Next
   Next
  Next
 Next
Next

NBENT=K-1
#Local Char RES(250),RES2(250)
#For I=1 To J-1
# RES += LISTENTFGRP(I)+chr$(10)
#Next
#For I=1 To K-1
# RES2+= LISTENTF(I)-": cpy=>"+LISTCPYF(I)+chr$(10)
#Next
#Infbox "Il y a"-num$(NBNIV)-"niveaux"+chr$(10)+"Liste des"-num$(J-1)-"entités rattachée qui sont elles mêmes des groupes:"+chr$(10)+RES
#Infbox "Liste des"-num$(K-1)-"entités rattachée:"+chr$(10)+RES2
End

Subprog VERFENTSUP(ENTITE,STAT)
Value Char ENTITE
Variable Integer STAT
#useful var
Local File ENTITE [ENTA],ENTITE [ENTB]
Local Char ENTRAT
Read [ENTA]ENT0= ENTITE
If !fstat
 ENTRAT=[F:ENTA]ENTRAT
 For I=[F:ENTA]LEV To 1 Step -1
  Read [ENTB]ENT0=ENTRAT
  If !fstat
   If [F:ENTB]CPY<>"" : STAT=0 : Break : End : Endif
   ENTRAT=[F:ENTB]ENTRAT
  Endif
 Next
Endif
End STAT


