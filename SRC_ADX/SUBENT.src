Subprog IB_NBDIE
If [M]COCHE(nolign-1)<>2
 Raz GBOUT1
Endif
End

#########################################################
##--- Fonctions liées à la pyramide de rattachement ---##
#########################################################

Subprog GETFIRSTENT(VALEUR,RES)
Variable Char VALEUR()
Variable Char RES
#---------------------------------------------------------#
# Retourne l'entité de niveau 1, sommet de la pyramide de #
# rattachement concernant l'entité passée en paramètre.   #
#---------------------------------------------------------#
If VALEUR<>""
 Read [ENT]ENT0 = VALEUR
 If !fstat
  If [F:ENT]LEV>2
   Call GETFIRSTENT([F:ENT]ENTRAT,RES)
  Elsif [F:ENT]LEV=2
   RES=[F:ENT]ENTRAT
  Elsif [F:ENT]LEV=1
   RES=VALEUR
  Endif
 Endif
Endif
End

##################################################################
##--- Fonctions de génération de la pyramide de rattachement ---##
##################################################################

Subprog GENPYRENT(VALEUR)
Variable Char VALEUR()
If VALEUR<>""
 # Recherche de l'entité de niveau 1, qui sera le sommet de la pyramide de rattachement concernant l'entité en cours
 Read [ENT]ENT0 = VALEUR
 If !fstat
  If [F:ENT]LEV>2
   Call GENPYRENT([F:ENT]ENTRAT)
  Elsif [F:ENT]LEV=2
   Call GENPYR([F:ENT]ENTRAT,1)
  Elsif [F:ENT]LEV=1
   Local File ENTITE [ENTA]
   Filter [ENTA] Where ENTRAT=VALEUR
   Read [ENTA] First
   If !fstat
    Call GENPYR(VALEUR,1)
   Else
    #Il doit y avoir au moins 2 niveaux pour générer une pyramide
    Call MESSAGE(mess(104,108,1)) From GESECRAN
   Endif
   Filter [ENTA]
  Endif
 Endif
Endif
End

Subprog GENPYR(VALEUR,TRC_OK)
Variable Char VALEUR()
Value Integer TRC_OK
If !clalev([F:CYM]) : Local File GCCEPYM    [CYM] : Endif
If !clalev([F:CRY]) : Local File GCCEGRUPYM [CRY] : Endif
If !clalev([F:CYK]) : Local File GCCEPYMLIK [CYK] : Endif
Local File ENTITE [ENT1], ENTITE [ENT2], ENTITE [ENT3], ENTITE [ENT4], ENTITE [ENT5], ENTITE [ENT6], ENTITE [ENT7],ENTITE [ENT8]
Local Char NOMPYR(5),INTPYR(30)
Local Integer OK

Read [ENT]ENT0 = VALEUR
If !fstat

 NOMPYR=left$([F:ENT]ENT,5)

 Read [CYM]CYM0 = NOMPYR
 If !fstat
  Call LECTEXTRA(INTPYR,"GCCEPYM","DESTRA",NOMPYR,"") From ATEXTRA
  # Une pyramide avec ce nom existe déjà. Souhaitez vous la remplacer?
  Call AVERTIR("["+NOMPYR+"]"-INTPYR-" :"-mess(103,108,1),OK) From GESECRAN
  If OK=2
   Call EFFACE(NOMPYR,1) From PYRDELCCE
  Else
   End
  Endif
 Endif

 Call DEBTRANS From GLOCK
 Gosub TR_GENPYR

Endif
End

$TR_GENPYR
GOK = 1
Trbegin [CYM],[CRY],[CYK]
 If [M]DIE(0)<>""
  Call LECTEXTRA(INTPYR,"ENTITE","DESTRA",[F:ENT]ENT,"") From ATEXTRA

  If TRC_OK
   #Création de la pyramide
   Call OUVRE_TRACE(mess(188,108,1)) From LECFIC
   Call ECR_TRACE("---------------------------------------------",0) From  GESECRAN
   Call ECR_TRACE(mess(188,108,1)-":"-NOMPYR-"/"-INTPYR,0) From GESECRAN
   Call ECR_TRACE("---------------------------------------------",0) From  GESECRAN
  Endif

  #Création de la pyramide sur un axe
  Raz [CYM]
  [F:CYM]PYM = NOMPYR
  [F:CYM]DIE = [M]DIE(0)
  [F:CYM]CREUSR = GUSER
  [F:CYM]CREDAT = date$
  [F:CYM]CRETIM = time
  Write [CYM]
  If fstat : GOK = 0 : Call FSTA("CYM") From GLOCK : Rollback : Return : Endif
  Call DUPTEXTRA("ENTITE","DESTRA",[F:ENT]ENT,"","GCCEPYM","DESTRA",NOMPYR,"")  From ATEXTRA
  If GOK<1 : Rollback : Return : Endif
  Call DUPTEXTRA("ENTITE","SHOTRA",[F:ENT]ENT,"","GCCEPYM","SHOTRA",NOMPYR,"")  From ATEXTRA
  If GOK<1 : Rollback : Return : Endif
  # Combien de niveau?
  Local Integer NBNIV : NBNIV=1
  # Liste des entités de rattachement qui seront donc des groupes...
  Local Char LISTENT(GLONENT)(0..200) : LISTENT(0)=[F:ENT]ENT
  K=1
  # Liste des entités de rattachement qui seront donc des groupes...
  Local Char LISTENTRAT(GLONENT)(0..200) : LISTENTRAT(0)=[F:ENT]ENT
  J=1

  For [ENT1]ENT0 Where ENTRAT=[F:ENT]ENT
   NBNIV=2
   LISTENT(K)=[F:ENT1]ENT : K+=1
   For [ENT2]ENT0 Where ENTRAT=[F:ENT1]ENT
    If !find([F:ENT1]ENT,LISTENTRAT(1..200)) : LISTENTRAT(J)=[F:ENT1]ENT : J+=1 : Endif
    NBNIV=3
    LISTENT(K)=[F:ENT2]ENT : K+=1
    For [ENT3]ENT0 Where ENTRAT=[F:ENT2]ENT
     If !find([F:ENT2]ENT,LISTENTRAT(1..200)) : LISTENTRAT(J)=[F:ENT2]ENT : J+=1 : Endif
     NBNIV=4
     LISTENT(K)=[F:ENT3]ENT : K+=1
     For [ENT4]ENT0 Where ENTRAT=[F:ENT3]ENT
      If !find([F:ENT3]ENT,LISTENTRAT(1..200)) : LISTENTRAT(J)=[F:ENT3]ENT : J+=1 : Endif
      NBNIV=5
      LISTENT(K)=[F:ENT4]ENT : K+=1
      For [ENT5]ENT0 Where ENTRAT=[F:ENT4]ENT
       If !find([F:ENT4]ENT,LISTENTRAT(1..200)) : LISTENTRAT(J)=[F:ENT4]ENT : J+=1 : Endif
       NBNIV=6
       LISTENT(K)=[F:ENT5]ENT : K+=1
       For [ENT6]ENT0 Where ENTRAT=[F:ENT5]ENT
        If !find([F:ENT5]ENT,LISTENTRAT(1..200)) : LISTENTRAT(J)=[F:ENT5]ENT : J+=1 : Endif
        NBNIV=7
        LISTENT(K)=[F:ENT6]ENT : K+=1
        For [ENT7]ENT0 Where ENTRAT=[F:ENT6]ENT
         If !find([F:ENT6]ENT,LISTENTRAT(1..200)) : LISTENTRAT(J)=[F:ENT6]ENT : J+=1 : Endif
         NBNIV=8
         LISTENT(K)=[F:ENT7]ENT : K+=1
         For [ENT8]ENT0 Where ENTRAT=[F:ENT7]ENT
          If !find([F:ENT7]ENT,LISTENTRAT(1..200)) : LISTENTRAT(J)=[F:ENT7]ENT : J+=1 : Endif
          NBNIV=9
          LISTENT(K)=[F:ENT7]ENT : K+=1
         Next
        Next
       Next
      Next
     Next
    Next
   Next
  Next

  Local Char RES(250),RES2(250)
  For I=0 To J
   RES += LISTENTRAT(I)+chr$(10)
  Next
  For I=0 To K
   RES2+= LISTENT(I)+chr$(10)
  Next

  #"Il y a"-num$(NBNIV)-"niveaux"+chr$(10)+"Liste des"-num$(J)-"entités  de rattachement:"+chr$(10)+RES
  #"Liste des"-num$(K)-"entités:"+chr$(10)+RES2

  For I=0 To J-1
   R=1
   For [ENT]ENT0 Where ENTRAT=LISTENTRAT(I) & find([F:ENT]ENT,LISTENT(0..200))
    If !find([F:ENT]ENT,LISTENTRAT(1..200))
     #Groupe pyramide analytique-L'entité est une "simple" entité
     Raz [CRY]
     [F:CRY]PYM    = NOMPYR
     [F:CRY]GRU    = [F:ENT]ENTRAT
     [F:CRY]CCE    = [F:ENT]ENT
     [F:CRY]LIN    = R : R+=1
     [F:CRY]LEV    = ([F:ENT]LEV-1)*10
     [F:CRY]BUDTRK = 2
     [F:CRY]PRNROW = ([F:ENT]LEV-1)*10
     [F:CRY]CREUSR = GUSER
     [F:CRY]CREDAT = date$
     Write [CRY]
     If fstat : GOK = 0 : Call FSTA("CRY") From GLOCK : Break 2 : Endif
     #Avec les intitulés traduisible de l'entité
     Call DUPTEXTRA("ENTITE","DESTRA",[F:ENT]ENTRAT,"","GCCEGRUPYM","DESTRA",NOMPYR,[F:ENT]ENTRAT)  From ATEXTRA
     If GOK<1 : Break 2 : Endif
     Call DUPTEXTRA("ENTITE","SHOTRA",[F:ENT]ENTRAT,"","GCCEGRUPYM","SHOTRA",NOMPYR,[F:ENT]ENTRAT)  From ATEXTRA
     If GOK<1 : Break 2 : Endif
     #Liens pyramides sections
     Raz[CYK]
     [F:CYK]PYM = NOMPYR
     [F:CYK]LEV = ([F:ENT]LEV-1)*10
     [F:CYK]DIE = [M]DIE(0)
     [F:CYK]CCE = [F:ENT]ENT
     [F:CYK]GRU = [F:ENT]ENTRAT
     [F:CYK]PRNROW = ([F:ENT]LEV-1)*10
     Write [CYK]
     If fstat : GOK = 0 : Call FSTA("CYK") From GLOCK : Break 2 : Endif
    Else
     If [F:ENT]ENTRAT<>""
      Raz [CRY]
      [F:CRY]PYM    = NOMPYR
      [F:CRY]GRU    = [F:ENT]ENTRAT
      [F:CRY]SBBGRU = [F:ENT]ENT
      [F:CRY]LIN    = R : R+=1
      [F:CRY]LEV    = ([F:ENT]LEV-1)*10
      [F:CRY]BUDTRK = 2
      [F:CRY]PRNROW = ([F:ENT]LEV-1)*10
      [F:CRY]CREUSR = GUSER
      [F:CRY]CREDAT = date$
      Write [CRY]
      If fstat : GOK = 0 : Call FSTA("CRY") From GLOCK : Break 2 : Endif
      #Avec les intitulés traduisible de l'entité
      Call DUPTEXTRA("ENTITE","DESTRA",[F:ENT]ENTRAT,"","GCCEGRUPYM","DESTRA",NOMPYR,[F:ENT]ENTRAT)  From ATEXTRA
      If GOK<1 : Break 2 : Endif
      Call DUPTEXTRA("ENTITE","SHOTRA",[F:ENT]ENTRAT,"","GCCEGRUPYM","SHOTRA",NOMPYR,[F:ENT]ENTRAT)  From ATEXTRA
      If GOK<1 : Break 2 : Endif
      #Liens pyramides sections
      Raz[CYK]
      [F:CYK]PYM = NOMPYR
      [F:CYK]LEV = ([F:ENT]LEV-1)*10
      [F:CYK]DIE = [M]DIE(0)
      [F:CYK]CCE = [F:ENT]ENT
      [F:CYK]GRU = [F:ENT]ENTRAT
      [F:CYK]PRNROW = ([F:ENT]LEV-1)*10
      Write [CYK]
      If fstat : GOK = 0 : Call FSTA("CYK") From GLOCK : Break 2 : Endif
     Endif
    Endif
   Next
  Next
  If GOK<1
   If TRC_OK : Call FERME_TRACE From LECFIC : Endif
   Rollback
   Return
  Endif
  If TRC_OK
   Call ECR_TRACE(mess(192,108,1),0) From  GESECRAN :#La création de la pyramide s'est bien déroulée
   Call ECR_TRACE(num$(J)-mess(189,108,1),0) From  GESECRAN :#Groupes
   Call ECR_TRACE(num$(NBNIV)-mess(190,108,1),0) From  GESECRAN :#Niveaux
   Call ECR_TRACE(num$(K)-mess(191,108,1),0) From  GESECRAN :#Entités/Sections
   # Call ECR_TRACE("Sur"-num$(NBNIV)-"niveaux & Concernant"-num$(K)-"entités, dont"-num$(J)-"entités  de rattachement",0) From  GESECRAN
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE   From LECFIC
  Endif

 Endif :#[M]DIE(0)<>""
Commit
Return


