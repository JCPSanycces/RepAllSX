#<AdxTL>@(#)5.0.0.0 $Revision$
################################################################################
# Revision 91546, July 31st, 2013
################################################################################
$ACTION

  Case ACTION
    When "SEL_TABLE" : Gosub SEL_TABLE
    When "SEL_LISTE" : Gosub SEL_LISTE
  Endcase

Return

################################################################################
$SEL_TABLE

If !clalev([BAN2]) : Local File BANK [BAN2] : Endif

#91546.sn
If dim(ABAN)<=0
  Global Char ABAN(GLONBAN)(1..nbrecord([F:BAN2]))
Else
  Raz ABAN
Endif

Local Integer NUMBANS
CRITERE="1=1"
If PARAM(1) <> ""
  CRITERE="BAN=PARAM(1)"
Endif

For [F:BAN2] Where evalue(CRITERE)
  Call ACCES_POINTAGE(GOK,[F:BAN2]BAN) From SUBCHK
  If GOK
    NUMBANS+=1
    ABAN(NUMBANS) = [F:BAN2]BAN
  Endif
Next

CRITERE="find(BAN,ABAN)"
#91546.en

DEFPAG=1

If !clalev([BEH]) : Local File BANREC [BEH] : Endif


OBJET = "BNR"

If PARAM(1) <> ""
    CRITERE = "& BAN='"+PARAM(1)+"'"
Endif

ORDRE="[F:BEH]RBKNUM desc"

Return
################################################################################
#91546.sn
$SEL_LISTE

If !clalev([BEH2]) : Local File BANREC [BEH2] : Endif

Local Char TEX(30)(1..nbrecord([F:BEH2])), TEXTE(GLONDES)(1..nbrecord([F:BEH2]),1..5)
Local Char TIT(GLONDES)(0..5)

Filter [F:BEH2] Order By RBKNUM Desc

For [BEH2]

  If NBTEX>=dim(TEX)-1 : Break : Endif

  Call ACCES_POINTAGE(GOK,[F:BEH2]BAN) From SUBCHK
  If GOK
    NBTEX += 1
    TEX(NBTEX) = [F:BEH2]RBKNUM
    TEXTE(NBTEX,2) = [F:BEH2]RBKDES
    TEXTE(NBTEX,3) = format$("D:"+GFMDAT,[F:BEH2]BNKDAT)
    TEXTE(NBTEX,4) = mess([F:BEH2]STAFLG,17,1) #Status is local menu 17
    TEXTE(NBTEX,5) = [F:BEH2]BAN
  Endif

Next
Filter [F:BEH2]
TIT(0) = mess(6,865,1)  : # Bank Statements
TIT(1) = mess(42,117,1) : # Statement
TIT(2) = mess(30,109,1) : # Title
TIT(3) = mess(3,11,1)   : # Date
TIT(4) = mess(9,105,1)  : # Status
TIT(5) = mess(13,602,1) : # Bank
Raz mkstat, GMESSAGE
Return

#91546.en
