######################################################################################
Subprog IB_LOT
If [M]PNHNUM(nolign-1)<>"" | [M]DETSDHNUM(nolign-1)<>"" Raz GBOUT2 Endif
End
######################################################################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
Local Shortint NOL : NOL=nolign-1
Local Char     WVCRNUMORI
Local Integer  LRET, WVCRTYPORI, WVCRLINORI

If [M:SRS1]PNHNUM(NOL) <> ""
    WVCRNUMORI = [M:SRS1]PNHNUM(NOL)
    WVCRTYPORI = 8
    WVCRLINORI = [M:SRS1]PNDLIN(NOL)
Elsif [M:SRS1]DETSDHNUM(NOL) <> "" & [M:SRS1]PNHNUM(NOL) = ""
    WVCRNUMORI = [M:SRS1]DETSDHNUM(NOL)
    WVCRTYPORI = 4
    WVCRLINORI = [M:SRS1]SDDLIN(NOL)
Endif

LRET = func STKACT.FSTKCTRLOT(VALEUR,"SRS1",NOL,[M:SRS1]ITMREF(NOL),[M:SRS1]BPSLOT(NOL),
&                          33,[M:SRS0]SRHNUM,[M:SRS1]SRDLIN(NOL),
&                          WVCRNUMORI, WVCRTYPORI, WVCRLINORI, 0,
&                          [M:SRS0]STOFCY,"LOCTYP",[M:SRS1]GESLOT(NOL))
If mod(LRET,2)=1
    Diszo [M:SRS1]BPSLOT(NOL)
Else
    Actzo [M:SRS1]BPSLOT(NOL)
Endif
If mkstat=2 End Endif
Affzo [M:SRS1]BPSLOT(NOL)
End
######################################################################################
Subprog C_NBSLO(VALEUR)
Variable Decimal VALEUR
Local Shortint NOL : NOL=nolign-1
Call STKCTRNBSLO(VALEUR, [M:SRS1]SAU(NOL), [M:SRS1]QTY(NOL)) From STKACT
End
######################################################################################
Subprog C_SLO(VALEUR)
Variable Char    VALEUR()
Local Shortint NOL : NOL=nolign-1
Local Char     WVCRNUMORI
Local Integer  WVCRTYPORI, WVCRLINORI

If VALEUR<>""
  If [M:SRS1]PNHNUM(NOL) <> ""
      WVCRNUMORI = [M:SRS1]PNHNUM(NOL)
      WVCRTYPORI = 8
      WVCRLINORI = [M:SRS1]PNDLIN(NOL)
  Elsif [M:SRS1]DETSDHNUM(NOL) <> "" & [M:SRS1]PNHNUM(NOL) = ""
      WVCRNUMORI = [M:SRS1]DETSDHNUM(NOL)
      WVCRTYPORI = 4
      WVCRLINORI = [M:SRS1]SDDLIN(NOL)
  Endif
  Call STKCTRSLO(VALEUR, [M:SRS1]NBSLO(NOL), [M:SRS1]LOT(NOL),
&               [M:SRS1]ITMREF(NOL),[M:SRS1]BPSLOT(NOL),[M:SRS1]GESLOT(NOL), WVCRNUMORI, WVCRTYPORI, WVCRLINORI, 0,
&               [M:SRS0]STOFCY, [M:SRS1]SLOF(NOL)) From STKACT
  If mkstat=2 End : Endif
  Affzo [M:SRS1]SLOF(NOL)
Endif

End
######################################################################################
Subprog B1_SLO(VALEUR)
Variable Char    VALEUR()
Local Shortint NOL : NOL=nolign-1
Call RECLASTSLO([M:SRS1]ITMREF(NOL), [M:SRS1]LOT(NOL), "","", VALEUR) From STKLIB
End


