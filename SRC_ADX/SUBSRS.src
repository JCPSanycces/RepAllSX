Subprog C_ETAR(VALEUR)
Variable Char    VALEUR()
If VALEUR="0000" : End : Endif
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:SRS0]STOFCY,'')=1
  If [M:SRS2]DPEDATR<>[0/0/0] & [M:SRS2]ARVDATR<>[0/0/0]
    If [M:SRS2]DPEDATR=[M:SRS2]ARVDATR & VALEUR<=[M:SRS2]ETDR
       # BRBAN 107887
       Call ERREUR(mess(98,7711,1)) From GESECRAN
       mkstat=2
    Endif
  Endif
Endif
End


#                                                                            # hcb 110327 deb
Subprog AS_SERNUM(VALEUR)
Variable Char    VALEUR()
If dim([M:SRS1]LOCTYP) > 0
   If  [M:SRS1]LOCTYP(nolign-1) <> [F:TLO]LOCTYP
       Read [TLO]TLO0=[M:SRS1]STOFCY;[M:SRS1]LOCTYP(nolign-1)
       If fstat
          Raz [F:TLO]
       Endif
   Endif
   If [F:ITM]SERMGTCOD = 4 & [F:TLO]LOCCAT = 2
      mkstat = 2
   Endif
Endif
End
