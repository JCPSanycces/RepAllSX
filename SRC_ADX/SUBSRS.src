  If func PORLEGLIB.DIGSIGN(VALEUR,'')=1
    Actzo  [M:SRS2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,ATDTCODR,MANDOCR,GLBDOCR
    Call DIS_MANDOC(GFONCTION) From TRNDOC
  Else
    Diszo  [M:SRS2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,ATDTCODR,MANDOCR,GLBDOCR
  Endif
