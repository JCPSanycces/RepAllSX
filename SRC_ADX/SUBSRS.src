If [M:SRS1]LOCTYP(nolign-1)<>VALEUR
   Call RAZLOC([M:SRS1]LOC(nolign-1),[M:SRS1]WLOCSEQ(nolign-1)) From STKACT
Endif
#                                                                            # hcb 110327 deb
If dim([M:SRS1]SERNUM) > 0 & [F:ITM]SERMGTCOD = 4 & [F:TLO]LOCCAT = 2
   Raz   [M:SRS1]SERNUM (nolign-1)
   Raz   [M:SRS1]SERNUMF(nolign-1)
   Affzo [M:SRS1]SERNUM (nolign-1)
   Affzo [M:SRS1]SERNUMF(nolign-1)
