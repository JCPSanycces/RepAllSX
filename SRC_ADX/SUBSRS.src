#<AdxTL>@(#)5.0.0.0 $Revision$
#@ Check diff -CPO-16/12/13
Call OBJET ("SRS", GBIDC1, GBIDC2) From GOBJET
End
#######################################################################
#                                                                     #
# SUBSRS : GESTION DES RETOURS MATIERE DE SOUS TRAITANCE   MAE - 05/08#
#                                                                     #
#######################################################################
# Issue X3-58977 - 20171220 by LD : PCU on stock transaction from credit memo incorrect

$ACTION
Case ACTION
 When "DEFTRANS"      : Gosub DEFTRANS
 When "VARIANTE"      : Gosub VARIANTE
 When "SETTRANS"      : Gosub SETTRANS
 When "OUVRE"         : Gosub OUVRE
 When "OUVRE_BOITE"   : Gosub OUVRE_BOITE
 When "FERME"         : Gosub FERME
 When "FILTRE"        : Gosub FILTRE
 When "AVANTBOUT"     : Gosub AVANTBOUT
 When "SETBOUT"       : Gosub SETBOUT
 When "EXEBOUT"       : Gosub EXEBOUT         #85785
 When "STATUT"        : Gosub STATUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "GRISE"         : Gosub GRISE
 When "VERIF_CRE"     : Gosub VERIF_CRE
 When "RAZCRE"        : Gosub RAZCRE
 When "INICRE"        : Gosub INICRE
 When "CREATION"      : Gosub CREATION
 When "ABANDON"       : Gosub ABANDON
 When "APRES_CRE"     : Gosub APRES_CRE
 When "AB_CREATION"   : Gosub AB_CRE_MOD
 When "LIENS"         : Gosub LIENS
 When "AVANT_MODFIC"  : Gosub AVANT_MODFIC
 When "VERIF_MOD"     : Gosub VERIF_MOD
 When "INIMOD"        : Gosub INIMOD
 When "MODIF"         : Gosub MODIF
 When "APRES_MOD"     : Gosub APRES_MOD
 When "AB_MODIF"      : Gosub AB_CRE_MOD
 When "VERF_ANU"      : Gosub VERF_ANU
 When "ANNULE"        : Gosub ANNULE
 When "DEFLIG"        : Gosub DEFLIG
 When "LIENS_LIG"     : Gosub LIENS_LIG
 When "INICRE_LIG"    : Gosub INI_LIG
 When "INIMOD_LIG"    : Gosub INI_LIG
 When "VALLIG"        : Gosub VALLIG
 When "FILGAUCHE"     : Gosub FILGAUCHE
 When "AP_FILGAUCHE"  : Gosub AP_FILGAUCHE
 When "HINT"          : Gosub HINT_KEY
 When "DEB_PICK"      : Gosub DEB_PICK
 When "PICKE"         : Gosub PICKE
 When "DEPICK"        : Gosub DEPICK
 When "FIN_PICK"      : Gosub FIN_PICK
 When "AVANT_SUITE"   : Gosub AVANT_SUITE  : # 87368
When Default
Endcase
#---------------- #
# Actions champs  #
#---------------- #
Case ACTION
 When "AAPRES_NBLIG" : Gosub AAPRES_NBLIG
 When "AB5_NBLIG"    : Gosub AB5_NBLIG
 When "BB5_NBLIG"    : Gosub BB5_NBLIG
 When "AB2_BPAADD"   : Gosub AB2_BPAADD     # FGR 10/11/2009 : X3SUIVI57700
 When "BB2_BPAADD"   : Gosub BB2_BPAADD     # FGR 10/11/2009 : X3SUIVI57700
 When Default
Endcase
Return

#########################################################################
# FGR 10/11/2009 : X3SUIVI57700 (début)
#######################################
$AB2_BPAADD
Local Integer IMODCHAMP

  IMODCHAMP = varmode([M:SRS0]BPAADD)
  If IMODCHAMP = 1 or IMODCHAMP = 2 Then
    Actzo [M:SRS0]BPAADD
  Endif
Return

#######################################
$BB2_BPAADD
  If IMODCHAMP = 1 Then
    Grizo [M:SRS0]BPAADD
  Elsif IMODCHAMP = 2 Then
    Diszo [M:SRS0]BPAADD
  Endif
Return
# FGR 10/11/2009 : X3SUIVI57700 (fin)
#########################################################################

#########################################################################
$DEFTRANS
# Si on ne vient pas de la gestion des retours
If GFONC1 <> "GESSRS" Raz GFLAG Endif
Return

#########################################################################
$VARIANTE
# La transaction lu est elle utilisable ?
If clalev ([F:SLT])=0 Local File SALTRS [SLT] Endif
Read [SLT]SLT0=8;[F:AWI]TRN
If fstat
   OK = 0
Elsif [F:SLT]ENAFLG<>2
   OK = 0
Endif
Return

#########################################################################
$SETTRANS

If dim(GSVGWRHOBY)   <=0 : Global Integer  GSVGWRHOBY    : Endif

If dim(GSLTSRGWAIFLG)<=0 : Global Shortint GSLTSRGWAIFLG : Endif
If dim(GSLTPRNCOD1)  <=0 : Global Libelle  GSLTPRNCOD1   : Endif
If dim(GSLTPRNNBFLG1)<=0 : Global Shortint GSLTPRNNBFLG1 : Endif

If dim(WSLTTRSFAM)   <=0 : Local  Char     WSLTTRSFAM(GLONADI) : Endif
If dim(WSLTTRSCOD)   <=0 : Local  Char     WSLTTRSCOD(GLONADI) : Endif

Local  Shortint WSLTDOCFLG, WSLTUOMSAIFLG, WSLTPRNCOD1
Local  Char     WSLTDOCNAM(10), WSLTENTCOD(GLONGAU)
#Global Char     GSTRNUM(GLONTRS)

If clalev ([F:SLT])=0 Local File SALTRS [SLT] Endif
Read [SLT]SLT0=8;GFLAG
If clalev ([F:DTR])=0 Local File DIETRS [DTR] Endif
Read [DTR]DTR0="SLT";8;GFLAG;0;0

GSLTSRGWAIFLG  = [F:SLT]SRGWAIFLG
GSLTPRNCOD1    = [F:SLT]PRNCOD1
GSLTPRNNBFLG1  = [F:SLT]PRNNBFLG1

WSLTTRSFAM     = [F:SLT]TRSFAM : Gosub VERIF_TRSFAM From TRTVENSTK
WSLTTRSCOD     = [F:SLT]TRSCOD : Gosub VERIF_TRSCOD From TRTVENSTK

WSLTDOCFLG     = [F:SLT]DOCFLG
WSLTDOCNAM     = [F:SLT]DOCNAM
WSLTUOMSAIFLG  = [F:SLT]UOMSAIFLG

# Dépôt entête obligatoire ou non (mono-dépôt)
If GWRHACT=2
  GWRHOBY = [F:SLT]WRHOBY
Else
  GWRHOBY = 1
Endif
GSVGWRHOBY = GWRHOBY

GGRPFCY = [F:SLT]GFY

Close Local File [DTR]
Return

#########################################################################
$OUVRE
If dim(GSVGWRHOBY)   <=0 : Global Integer  GSVGWRHOBY    : Endif

Raz GSOC_ACTIVE
#-----------------------------------#
# Sauvegarde des variables globales #
#-----------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
#--CPO 75115 Nouveau champ SRHTYP
Global Char     GCPTENDNBR (GLONANM) : # Compteur no xx (Retour définitif)
If clalev([F:TRE])=0 : Local File TABSRHTYP [TRE] : Endif

Global Char     GNUM(GLONVCR)  : # N° DE RETOUR
Global Shortint GRELITSRS      : # GRELITSRS = 1 pour relire le retour

Local  Decimal  WLIVTTC        : # En livraison TTC
Local  Integer  WRTNLINNBR     : # Nb lignes retournées pour la livraison
Local  Integer  WPICK
Local  Shortint IBOX
Local Shortint  DKSOK            # RMA * 85785

Raz GRELITSRS
#--CPO Lors du 75115
GDLVTYP = 3 :# 3 - pour sous-traitance GDLVTYP = 2

#-----------------------------------------------------------#
# Si module achat                                           #
# Fichiers : Retour fsseur entête, Retour fsseur détail     #
#-----------------------------------------------------------#
If GMODU(6)=2 : # Module achat actif
  If clalev([F:PNH]) =0 Local File PRETURN    [PNH]  : Endif : # Retour fsseur entête
  If clalev([F:PND]) =0 Local File PRETURND   [PND]  : Endif : # Retour fsseur détail
  If clalev([F:PTD]) =0 Local File PRECEIPTD  [PTD]  : Endif : # réception détail
  If clalev([F:POQ]) =0 Local File PORDERQ    [POQ]  : Endif
Endif

If !clalev([F:GCM]) Local File GACM [GCM] : Endif

# 40127 : Return status management
If !clalev([F:SDD1]) Local File SDELIVERYD [SDD1]  Endif
# 40127

GFCY = GFCYDEF (7)
# Ctrl site par défaut par rapport au critère, si aucun site par défaut, charge le 1er site correspondant au critere
Call GETFCYDEF(GFCY,"[F:FCY]WRHFLG=2") From TRTX3
# Chargement globales référenciels, comptes et sections de la société
Gosub CHARG_PARAM

#--CPO 107883 Issue revealed by RMA 24/04/2015
##--CPO 75115 Recherche du compteur en fonction du SRHTYP
#Gosub REC_CPT_RET From SUBSRS
#If GERR=1 OK=0 : Return Endif

GORITITCOL=1

# C'est une fonction vente qui travaille sur un site d'expédition
# On surcharge donc le site par défaut du module avec celui d'expédition
# pour que les contrôles d'autorisation des sites soient corrects.
GFCYDEF(0) = GFCYDEF(7)

#------------------------------------------------------------#
# --> Récupération du code compteur                          #
#------------------------------------------------------------#
If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
Read [TCA] TCA0=5
If fstat : Call ERREUR(mess(64,199,1)) From GESECRAN : OK=0 : Return : Endif
GMANCOU=[F:TCA]MANCOU(17) : GCPT=[F:TCA]CODNUM(17)

If !clalev ([F:FCY]) : Local File FACILITY   [FCY] : Endif

# Déclaration des fenêtres d'adresse
Local Mask ADRBPC [ADB2]

# Si présence module Support Client, gestion du parc client
If GMODU(12)=2
    If !clalev ([M:MACW]) : Local Mask MACW [MACW] : Endif
Endif
#-------------------------#
# Ouverture masques stock #
#-------------------------#
#-- Ecran stockage mvt du document
If !clalev([M:ENTW])
    Local Mask STOENTW  [ENTW]
    [M:ENTW]WZONPCU    = "SAU"
    [M:ENTW]WZONQUC    = "QTY"
    [M:ENTW]WZONCCS    = "SAUSTUCOE"
    [M:ENTW]WZONQUS    = "QTYSTU"
    [M:ENTW]WZONSTOUPD = "WSTOUPD"
Endif
#-- Ecran de travail enreg mvt du document
If clalev([M:STW])=0 Local Mask STOWORK   [STW]  : Endif
Raz [M:STW]
If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif

Gosub STK_INILOC From STKLOC

#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0
  If clalev([F:DEB]) =0 Local File DEB [DEB]  : Endif
  Global Integer GMODMSDGFORDEB : GMODMSDGFORDEB = 1
Endif
#--/

# FGR 28/07/2015 : X3SUIVI108078 : Optimisation (début)
  Link [SRD] With [ITM]ITM0=[F:SRD]ITMREF,
&                 [ITU]ITU0=[F:SRD]ITMREF;[F:SRH]BPCORD
&              As [LSRD]
# FGR 28/07/2015 : X3SUIVI108078 : Optimisation

Gosub DECLARE From TABLEAUX

# BRBAN 28-06-2014 SAM 93745 US2
If func AFNC.ACTIV('DKS') > 0
  If clalev([F:PTDKD])=0 : Local File DKSDATA [PTDKD] : Endif
Endif
Return

####################################################################
$OUVRE_BOITE

# Récupération des noms de currbox des tiroirs
Global Char     GBOXSD2(10), GBOXPN1(10)
GBOXSD2 = "GAU_CHE"+num$(find("SD2",OBJLIS(1..8)))
GBOXPN1 = "GAU_CHE" +num$(find("PN1",OBJLIS(1..8)))

Return
####################################################################
$FERME
Raz GORITITCOL

#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0 and dim(GMODMSDGFORDEB)>0
  Kill GMODMSDGFORDEB
Endif
#--/

#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB
Return

#########################################################################
$FILTRE
Default File [SRH]
#-- On n'accède qu'aux retour de matière de sous traitance
FILTSUP = "[F:SRH]SCORTN = 2"
Return
#########################################################################
# Avant éxécution des boutons et menus
#########################################################################
$AVANTBOUT
Local Char    WFONC1(30)
Local Integer I, WLIG, WCOD, WMODULE
Local Char    WTYP(4), WTEX(12), SYMBOLE2(50)

GERR=0
WMODULE = 5
Case BOUT
 When "E" :   [M]CNTNAM=[M:ADB2]CNTNAM                             : # Adresse livraison
 When "1" : If [M:SRS0]SRHNUM = "" | [M:SRS0]STOFCY = ""           #85785
              OK = 0 : Return
            Else
              If func PORLEGLIB.DIGSIGN([M:SRS0]STOFCY, "") <> 1
                OK = 0 : Return
              Endif
            Endif
Endcase
Return
####################################################################
$SETBOUT
#--------------------------------------------------------#
# Suppression boutons changement de code / duplication   #
#--------------------------------------------------------#
Call VIREBOUT(CHAINE,"DH") From GOBJET
# ------------------------------------------------------------------------------------- #
# Activation/Désactivation des menus                                                    #
# ------------------------------------------------------------------------------------- #
#     E : Adresse            : Actif si ret.en ligne ou création ou duplication         #
#     F : Crit. picking      : Actif si client et site renseignés                       #
#                                    si modif, il faut avoir des droits de modif        #
#     B : Info douanières    : Actif si retour en ligne                                 #
#     D : Transaction                                                                   #
# ------------------------------------------------------------------------------------- #
If GREP="C" | GREP="D" | CLECUR CHMEN += "E" Endif
If CLECUR : CHMEN += "B" : Endif
CHMEN += "D"
If ([M]BPCORD<>"" | COUZON="BPCORD" & CZ<>"") & [M]STOFCY<>""
    If GREP<>"C"
        GBIDC2="M": GFCY=[M]STOFCY : Gosub AUTORIS_OPT From CONTX3
        If GBIDI2 CHMEN+="F" Endif
    Else
        CHMEN+="F"
    Endif
Endif

#Parc client
If REP="" & GMODU(12)=2
    CHMEN += "7"
Endif

#85785
If GREP<>"" | !CLECUR
  Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
If [M:SRS0]STOFCY <> ""
  If func PORLEGLIB.DIGSIGN([M:SRS0]STOFCY, "") <> 1
    Call VIREBOUT(CHAINE,"1") From GOBJET
  Endif
Endif
If dim([M:SRS0]SRHCFMFLG)>0
  If [M:SRS0]SRHCFMFLG = 2
    Call VIREBOUT(CHAINE,"A1") From GOBJET
  Endif
Endif

# BRBAN 28-07-2014 SAM 93745 US2
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:SRS0]STOFCY,'')=1
  If [M:SRS0]SRHCFMFLG = 2 & GREP = "" & [M:SRS0]SRHNUM <> "" & func PORLEGLIB.DOCCTR(5,[F:BPC]BPCNUM,[F:SRH]SRHTYP,[F:SRH]STOFCY)=1
    Read [F:PTDKD]DKD0 = "SAFT-PT";[M:SRS0]SRHTYP;[M:SRS0]SRHNUM
    # BRBAN 24-03-2015 #106027
    If !fstat & [F:PTDKD]ATDTCOD = "" & func PORLEGLIB1.CTRL_COMDAT([F:SRH]STOFCY,[F:SRH]DPEDATR,[F:SRH]ETDR)=1
      CHMEN+='U'
    Endif
  Endif
Endif


Gosub SET_BOUT_SPE From GSAISIE

Return

###########################################################################################
#    Après execution des menus                                                            #
###########################################################################################
$STATUT

Case BOUT
    When "E"    :  If [M:ADB2]ADBFLG = 2 | [M]CNTNAM <> [M:ADB2]CNTNAM
                       If GREP <> "C" & GREP <> "M" & GREP <> "D"
                          Gosub MAJADRESSE          : # Adresse client livré
                       Endif
                       If [M:ADB2]BPRNAM(0) <> ""
                          [M:SRS0]BPDNAM = [M:ADB2]BPRNAM(0)
                          Affzo [M:SRS0]BPDNAM
                       Endif
                   Endif
    When "B"    :  If mkstat=4 & GREP=""                               : # Informations CEE
                      GREP="M" : REP="M" : # Pour forcer le bouton 'enregistrer'
                   Endif
    When "F"    :  Gosub TIROIR        : # Critères picking
    When "U"
       # BRBAN 25-07-2014 SAM 93745 US2 - Update ATDTCOD
       If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([F:SDH]STOFCY, '')=1
         Read [F:PTDKD]DKD0='SAFT-PT';[F:SRH]SRHTYP;[F:SRH]SRHNUM
         If !fstat & [F:PTDKD]ATDTCOD <> ''
          [M:SRS2]ATDTCODR = [F:PTDKD]ATDTCOD
          Affzo [M:SRS2]ATDTCODR
          Diszo [M:SRS2]ARVDATR,DPEDATR,ETDR,ETAR,LICPLATER,TRLLICPLATER
          Diszo [M:SRS2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,ATDTCODR,MANDOCR,GLBDOCR
         Endif
       Endif
Endcase

Return
#########################################################################
# 87368
#######################################################################
# Après exécution d'une action et avant l'exécution de l'action suite #
#######################################################################
$AVANT_SUITE
Case BOUT
  When "E" :  # After execution Adresse and before execution recalculate prices
    # Not trigger recalculate prices if globale not informed
    OK=0
Endcase
Return
# 87368
#########################################################################
$APRES_MODIF

# Pour l'activation/désactivation de l'option critère picking
If find (COUZON,"STOFCY","BPCORD") Gosub SETBOUT From GOBJSUB : Endif

# On vient de modifier une ligne de retour maj en stock
If GRELITSRS = 1
   Raz GRELITSRS
   Gosub RELIT From GOBJSUB
   OK = 0
Endif

If find(COUZON,"STOFCY","BPCORD","BPAADD","ITMREFSEL")
   If COUZON="BPAADD" [M:SRS0]BPAADD=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   If COUZON="BPCORD" [M:SRS0]BPCORD=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="STOFCY" [M:SRS0]STOFCY=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   Gosub TIROIR
Endif

#RMA * 85785
If find(COUZON, "RTNDAT", "QTY", "QTYEXT", "PRIORD", "NETPRINOT")
   [L]DKSOK = 0
Endif

Return

####################################################################
$VERIF_CRE
Gosub VERIF

Return
####################################################################
$RAZCRE
# Pas d'init. du site de vente pour ne pas filtrer au départ
GFCY=GFCYDEF(7)
#------------------------------------------------------------------------#
# Chargement site stock par défaut                                       #
# Chargement globales référenciels, comptes et sections de la société    #
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
# Récupération des paramètres vente du site / de la société              #
# Récupération des paramètres stock du site / de la société              #
# -----------------------------------------------------------------------#
# Ctrl site par défaut par rapport au critère, si aucun site par défaut, charge le 1er site correspondant au critere
Call GETFCYDEF(GFCY,"[F:FCY]WRHFLG=2") From TRTX3
Gosub CHARG_PARAM : : If GERR=1 OK=0 : Return Endif

#--CPO 75115 Init et recherche du compteur en fonction du SRHTYP
Local Char WSRHTYP(GLONTRE) : Local Integer  WSRHCAT
Gosub SRHTYP From SUBSRH
[M:SRS0]SRHTYP=WSRHTYP : [M:SRS0]SRHCAT=WSRHCAT

Gosub REC_CPT_RET From SUBSRS
If GERR=1 OK=0 : Return Endif
#--

Gosub AFF_TITCOL
GFCY=GFCYDEF(5)
# Ctrl site par défaut par rapport au critère, si aucun site par défaut, charge le 1er site correspondant au critere
Call GETFCYDEF(GFCY,"[F:FCY]SALFLG=2 & [F:FCY]LEGCPY=GSOCIETE") From TRTX3
Call GLOBVAR(GFCY,"VEN") From TRTX3
[M:SRS0]STOFCY = GFCY
Call GLOBSTOFCY([M:SRS0]STOFCY) From TRTVENGLOB

[M:SRS0]RTNDAT = date$

[M:SRS0]TRSCOD = WSLTTRSCOD
[M:SRS2]TRSFAM = WSLTTRSFAM
# Effacement des masques adresses
Raz [M:ADB2]

#--CPO X3Suivi 75115 Libellé Catégorie --#
[M:SRS0]WSRHCAT = mess(8,105,1) - ':' - mess([M:SRS0]SRHCAT,493,1)

# Gestion de l'état des zones
Gosub ETAT_ZONE

Affzo [M:SRS0]1-99
Affzo [M:SRS1]1-99
Affzo [M:SRS2]1-99
# Remplissage des boites de picking
Gosub REMPBOX

If dim([M:SRS1]WRHE)>0
   Call WRHINIT([M:SRS1]WRHE,[M:SRS0]STOFCY,4) From STKWRH
Endif
# Actzo ou Grizo des dépôts selon le site
Gosub WRH_ETAT

#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0 and dim(GMODMSDGFORDEB)>0
  Raz GMODMSDGFORDEB
Endif
#--/

#RMA * 85785
If dim([M:SRS0]SRHCFMFLG) > 0
  Chgfmt [M:SRS0]SRHCFMFLG   With "-LA1:15X"
Endif

Return
####################################################################
$INICRE
# -- Raz variable utilisée pour la maj des mvts clients, livraison
Raz WLIVTTC, WRTNLINNBR
If dim([F:SRH]CPY)>0 : [F:SRH]CPY=GSOCIETE : Endif
# -- Alimentation flag "retour matière sous traitance" à OUI
[F:SRH]SCORTN = 2
# Alimentation dépôt entête si mono-dépôt
If dim([M:SRS1]WRHE)>0 & GWRHOBY=2
  [F:SRH]WRHE = [M:SRS1]WRHE
Else
  [F:SRH]WRHE = ""
Endif
# -- Récupération du compteur de retour
If  GMANCOU <> 2 | (GMANCOU=2 & vireblc([M:SRS0]SRHNUM,2)="")
    Call NUMERO (GCPT,[F:SRH]STOFCY,[F:SRH]RTNDAT,"",GNUM,STAT) From SUBANM
    If GOK<0 Return Endif
    If STAT = 0
        [F:SRH]SRHNUM  = GNUM
        [M:SRS0]SRHNUM = GNUM
        Affzo [M:SRS0]SRHNUM
    Else
       # problème lors de la récupération du compteur
       GERR=1:GMESSAGE = mess(60,199,1)
       GOK = 0
    Endif
Endif
# Chargement adresses libres
Gosub CHARGEADR

Return

####################################################################
$CREATION

# -- Enregistrement des lignes du tableau
Gosub CREATION From TABLEAUX
If GOK < 1  Return  Endif
# Bug 52920 : Pas de maj mvt client pour les retours sous-traitance
#If WLIVTTC <> 0
#   # -- Maj mouvement client (décrémentation livré en prêt)
#   Call MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY,
#&               0, WLIVTTC, "-", "D", "", [F:SDH]LND) From TRTBPMVT
#   If GOK < 1  Return  Endif
#Endif
# Maj des statistiques
Call VALSTA("SRH",1) From SUBPS2
If GOK < 1 : Return : Endif

# FGR 04/01/2011 : X3SUIVI70100 (début) c'est mieux dans la transaction
# Si présence module Support Client, gestion du parc client
#If GMODU(12)=2                                           : # Bug 84870 : Pas de gestion du parc si inter-site
If GMODU(12)=2 & !([F:SRH]BETFCY=2 & [F:SRH]BETCPY<>2)    : # Bug 84870
   Gosub TRT_MACRULE
   If GOK < 1 : Return : Endif  # ... et ajout de la gestion d'erreur
Endif
# FGR 04/01/2011 : X3SUIVI70100 (fin) c'est mieux dans la transaction

Gosub DEVERROU_PICKING

#85785 * RMA
##--CPO for RMA Issue 75115 Digital signature of shipments and customer returns
## ----------------------------------------------------------- #
## Digital signature of shipments and customer returns         #
## ----------------------------------------------------------- #
#If func AFNC.ACTIV("DKS") & func AFNC.PARAM("PORDKS",[F:SRH]CPY)="2"
#  Gosub DIGSIGN From SUBSRHA
#Endif
## ----------------------------------------------------------- #

Return

####################################################################
$ABANDON

Gosub DEVERROU_PICKING

# Remise à 0 de l'écran STOENTW
Call DELSTOENTW (-1,-1,"SRS1",1,1,[M:SRS0]STOFCY,1,"") From STKENT


Actzo [M:SRS0]SRHNUM
If GREP="C"
   Raz GREP
   Gosub REMPBOX
Endif

Return

####################################################################
$APRES_CRE
Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)

# FGR 04/01/2011 : X3SUIVI70100 (début) déplacé dans la transaction
# Si présence module Support Client, gestion du parc client
#If GMODU(12)=2
#   Gosub TRT_MACRULE
#Endif
# FGR 04/01/2011 : X3SUIVI70100 (fin) déplacé dans la transaction

# -- Impression du bon de retour
If !GIMPORT & WSLTDOCFLG = 2
    Gosub SET_CLE From GOBJSUB
    CLECUR = 1
    Call ETAT(WSLTDOCNAM,"GESSRS",TBPAR,TBVAL) From ETAT
Endif

# Vide la table de travail de la gestion des emplacements
Local Integer WRET
Call STKDELRES(0,[M:SRS0]STOFCY,"",WRET) From STKLOC

# -- Impression des étiquettes -----#
If GSLTPRNCOD1>1 & sum([M:SRS1]RTNSTOUPD) > [M:SRS1]NBLIG
    Local Char    LCRIT(250)
    Local Char WPARAM(GLONVCR)(1..4) , WVALEUR(10)
    Local Integer WCREATION
    WPARAM(1) = [M:SRS0]STOFCY
    WPARAM(2) = num$(13)
    WPARAM(3) = [M:SRS0]SRHNUM
#                                                                                           # hcb X3-91077 - X3-92342 deb
#   Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
        Case GSLTPRNCOD1
             When 2 :
               Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE1","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette stock
             When 6 :
               Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE2","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette nouveau contenant
             When 7 :
               If !clalev([F:LPN])  : Local File LPN          [LPN]  : Endif
               Raz WCREATION
               LCRIT   = "STOFCY=[M:SRS0]STOFCY"
               LCRIT  += "&VCRNUM>=[M:SRS0]SRHNUM"
               LCRIT  += "&VCRNUM<=[M:SRS0]SRHNUM"
               LCRIT  += "&PRTFLG <> 2"
               Filter [F:LPN] Where evalue(LCRIT)
&              Order By Key LPN0
               For [LPN]
                   WCREATION = 2
                   Break
               Next
               Filter [LPN]
               If WCREATION = 2
                  Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE3","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette stock et contenant créé
               Else
                  Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE1","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette stock
               Endif
             When Default
        Endcase
#                                                                                           # hcb X3-91077 - X3-92342 fin
Endif

Gosub RELIT From GOBJSUB
[M:SRS0]SRHNUM = [F:SRH]SRHNUM

Return

####################################################################
$AB_CRE_MOD

Gosub DEVERROU_PICKING

Affzo [M:SRS1]15
Return

####################################################################
$LIENS
Local Char WSVGGREP(1)

[L]DKSOK = 1 #RMA * 85785

# -- Remise à zéro du masque STOENTW
Call DELSTOENTW (-1,-1,"SRS1",1,1,[M:SRS0]STOFCY,1,"") From STKENT

GFCY = [F:SRH]STOFCY
#------------------------------------------------------------------------#
# Chargement globales référenciels, comptes et sections de la société    #
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
# Chargement des sections analytiques entête du document                 #
# Récupération des paramètres vente du site / de la société              #
# Réalimentation param stock : TRSVENLND                                 #
# -----------------------------------------------------------------------#
#Call GETDEV(GFCY)  From DEVSUB
Gosub CHARG_PARAM : Gosub AFF_TITCOL

#--CPO 75115 Recherche du compteur en fonction du SRHTYP
Gosub REC_CPT_RET From SUBSRS

Call CHARG_CCEH("SRS2","NBAXE","SRH") From TRTX3CPT
If GFCYDEF(5)<>""
    Call GLOBVAR(GFCYDEF(5),"VEN") From TRTX3
Else
    Call GLOBVAR(GFCY,"VEN") From TRTX3
Endif
Call GLOBSTOFCY(GFCY) From TRTVENGLOB

GBPCNUM = [F:SRH]BPCORD
#-------------------------------------------------------#
# Lecture Client livré   : Alimentation du nom client   #
#-------------------------------------------------------#
If [F:BPD]BPCNUM <> [F:SRH]BPCORD | [F:BPD]BPAADD <> [F:SRH]BPAADD
   Read [BPD]BPD0 = [F:SRH]BPCORD;[F:SRH]BPAADD
   If fstat : Raz [F:BPD]:Call RSTA("BPD",[F:SRH]BPCORD) From GLOCK : Endif
Endif
If [F:SRH]BPDNAM(0) <> ""
     [M:SRS0]BPDNAM = [F:SRH]BPDNAM(0)
Else [M:SRS0]BPDNAM = [F:BPD]BPDNAM
Endif

#---------------------------#
# Alimentation des adresses #
#---------------------------#
[M:ADB2]ADBBPR       = [F:SRH]BPCORD
[M:ADB2]BPAADD       = [F:SRH]BPAADD
[M:ADB2]BPRNAM(0)    = [F:SRH]BPDNAM(0)
[M:ADB2]BPRNAM(1)    = [F:SRH]BPDNAM(1)
[M:ADB2]BPAADDLIG(0) = [F:SRH]BPDADDLIG(0)
[M:ADB2]BPAADDLIG(1) = [F:SRH]BPDADDLIG(1)
[M:ADB2]BPAADDLIG(2) = [F:SRH]BPDADDLIG(2)
[M:ADB2]POSCOD       = [F:SRH]BPDPOSCOD
[M:ADB2]CTY          = [F:SRH]BPDCTY
[M:ADB2]SAT          = [F:SRH]BPDSAT
[M:ADB2]CRY          = [F:SRH]BPDCRY
[M:ADB2]CRYNAM       = [F:SRH]BPDCRYNAM
[M:ADB2]CNTNAM       = [F:SRH]CNDNAM

If [M:ADB2]BPRNAM <> "" | [M:ADB2]BPAADDLIG <> "" |
&  [M:ADB2]POSCOD <> "" | [M:ADB2]CTY <> "" |
&  [M:ADB2]SAT    <> "" |
&  [M:ADB2]CRY    <> "" | [M:ADB2]CRYNAM <> ""
    [M:ADB2]ADBFLG = 3
Else
    [M:ADB2]ADBFLG = 0
Endif

If !clalev ([F:BPA]) : Local File BPADDRESS [BPA] : Endif
If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:SRH]BPCORD | [F:BPA]BPAADD<>[F:SRH]BPAADD
    Read [BPA]BPA0=1;[F:SRH]BPCORD;[F:SRH]BPAADD
    If fstat Raz [F:BPA] Endif
Endif
If !clalev ([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
If [F:TCY]CRY<>[F:BPA]CRY
    Read [TCY]TCY0=[F:BPA]CRY
    If fstat Raz [F:TCY] Endif
Endif
GETATCEE = [F:TCY]EECFLG
# Alimentation pays client livré pour affichage et ctrl n°identification CEE
If [M:ADB2]CRY<>""
    [M:SRS0]EECNUMCRY=[M:ADB2]CRY
Else
    [M:SRS0]EECNUMCRY=[F:BPA]CRY
Endif

# Raz des champs critères picking
Raz [M:SRS0]CRISDHNUM, [M:SRS0]CRIITMREF

#--CPO X3Suivi 75115 Libellé Catégorie --#
[M:SRS0]WSRHCAT = mess(8,105,1) - ':' - mess([M:SRS0]SRHCAT,493,1)

# -- Chargement des lignes dans le tableau
Gosub LIENS From TABLEAUX

# Gestion de l'état des zones
WSVGGREP = GREP : Raz GREP
Gosub ETAT_ZONE
GREP = WSVGGREP


# -- Grise les colonnes ne pouvant plus être modifiées
Call STKDISCOL("SRS1",[M]NBLIG) From STKECR

# Remplissage des boites de picking
Gosub REMPBOX

# Actzo ou Grizo des dépôts selon le site
GWRHOBY = GSVGWRHOBY
Gosub WRH_ETAT

#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0 and dim(GMODMSDGFORDEB)>0
  Raz GMODMSDGFORDEB
Endif
#--/

# BRBAN 28/07/2014 SAM #93745 US2
If func AFNC.ACTIV('KPO')>0
  If func PORLEGLIB.DIGSIGN("", [F:SRH]CPY)=1
    Actzo [M:SRS2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,MANDOCR
    Diszo [M:SRS2]ATDTCODR
    If func PORLEGLIB.DOCCTR(5,[F:SRH]BPCORD ,[F:SRH]SRHTYP,[F:SRH]STOFCY)=1
      If [F:SRH]SRHCFMFLG<>2
        Actzo [M:SRS2]ATDTCODR
      Else
        Read [F:PTDKD]DKD0 = "SAFT-PT";[F:SRH]SRHTYP;[F:SRH]SRHNUM
        If !fstat & [F:PTDKD]ATDTCOD<>''
          Diszo [M:SRS2]ARVDATR,DPEDATR,ETDR,ETAR,LICPLATER,TRLLICPLATER
          Diszo [M:SRS2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,ATDTCODR,MANDOCR,GLBDOCR
          [M:SRS2]ATDTCODR= [F:PTDKD]ATDTCOD
          Affzo [M:SRS2]ATDTCODR
        Endif
      Endif
    Endif
    If [M:SRS2]GLBDOCR = 2
      Diszo [M:SRS2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR
    Endif
    Call DIS_MANDOC(GFONCTION) From TRNDOC
    Chgfmt [M:SRS0]SRHCFMFLG   With "LA1:15X"
  Else
    Diszo [M:SRS2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,MANDOCR,ATDTCODR,GLBDOCR
    If dim([M:SRS0]SRHCFMFLG) > 0
      Chgfmt [M:SRS0]SRHCFMFLG   With "-LA1:15X"
    Endif
  Endif
Endif
#-

Return

####################################################################
$AVANT_MODFIC
#------------------------------------------#
# Traitement avant modification            #
#------------------------------------------#
# Maj des statistiques
Call VALSTA("SRH",-1) From SUBPS2
If GOK < 1 : Return : Endif

# Si modification de la date, forcage de la modif sur les lignes
If !find(GREP,"C","D") & [F:SRH]RTNDAT<>[M:SRS0]RTNDAT
   Local Integer NLIG
   For NLIG = 0 To [M]NBLIG-1
      [M]UPDFLG(NLIG) = 1
   Next NLIG
Endif
# Réalimenter [M]WRHE avec [F]WRHE pour ne pas écraser le mono-dépôt
If dim([M:SRS1]WRHE)>0
   [M:SRS1]WRHE = [F:SRH]WRHE
Endif
Return

####################################################################
$VERIF_MOD

#RMA * 85785
If func PORLEGLIB.DIGSIGN([M:SRS0]STOFCY, "")
  If [M:SRS0]SRHCFMFLG = 2 & ![L]DKSOK
    OK       = 0 : GERR = 1
    GMESSAGE = mess(51,7711,1) + mess(654,7773,1)
  Endif
Endif

Gosub VERIF

Return

####################################################################
$INIMOD
# -- Raz variable utilisée pour la maj des mvts clients, livraison
Raz WLIVTTC, WRTNLINNBR

# Chargement adresses libres
Gosub CHARGEADR

Return

####################################################################
$MODIF
#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0 and dim(GMODMSDGFORDEB)>0 and GMODMSDGFORDEB<>2
  If [F:SRH]EECNUMDEB>0
      Filter [F:DEB] Where EECNUMDEB=[F:SRH]EECNUMDEB and VCRNUM=[F:SRH]SRHNUM and CPY=[F:SRH]CPY
      Read [F:DEB]First
      If fstat : Raz [F:DEB] : Endif
      Filter [F:DEB]
      If [F:DEB]DEBDAT<>[0/0/0]
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB)-mess(98,107,1)-format$("DD2",[F:DEB]DEBDAT),0) From GESECRAN
      Else
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB),0) From GESECRAN
      Endif
      GMODMSDGFORDEB = 2
  Endif
Endif
#--/

If [M:SRS1]BETFCY=2 & [M:SRS0]BPSNUM<>"" & [M:SRS0]PNHFCY<>""
    # Si sup.ligne, pour recherche éventuelle dernier n°retour vente d'une ligne retour fsseur
    If clalev([F:SRD1])=0 Local File SRETURND [SRD1] Endif
Endif

# -- Modification des lignes d'un retour #
Gosub MODIF From TABLEAUX
If GOK < 1  Return  Endif

If [M:SRS1]BETFCY=2 & [M:SRS0]BPSNUM<>"" & [M:SRS0]PNHFCY<>""
    #FQ 65292
    #CPO - Problème découvert lors de la correction de cette fiche
    #Close Local File [SRD1] : Default File [SRS]
    Close Local File [SRD1] : Default File [SRH]
    #fin FQ 65292
Endif

# Bug 52920 : Pas de maj mvt client pour les retours sous-traitance
#If WLIVTTC <> 0
#   # -- Maj mouvement client (décrément. si augmentation retour et inverse)
#   Call MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY,
#&               0, WLIVTTC, "-", "D", "", [F:SDH]LND) From TRTBPMVT
#   If GOK < 1  Return  Endif
#Endif
# Maj des statistiques
Call VALSTA("SRH",1) From SUBPS2
If GOK < 1 : Return : Endif

# FGR 04/01/2011 : X3SUIVI70100 (début) c'est mieux dans la transaction
# Si présence module Support Client, gestion du parc client
#If GMODU(12)=2                                           : # Bug 84870 : Pas de gestion du parc si inter-site
If GMODU(12)=2 & !([F:SRH]BETFCY=2 & [F:SRH]BETCPY<>2)    : # Bug 84870
   Gosub TRT_MACRULE_MOD
   If GOK < 1 : Return : Endif  # ... et ajout de la gestion d'erreur
Endif
# FGR 04/01/2011 : X3SUIVI70100 (fin) c'est mieux dans la transaction

Gosub DEVERROU_PICKING

#85785 * RMA
##--CPO for RMA Issue 75115 Digital signature of shipments and customer returns
## ----------------------------------------------------------- #
## Digital signature of shipments and customer returns         #
## ----------------------------------------------------------- #
#If func AFNC.ACTIV("DKS") & func AFNC.PARAM("PORDKS",[F:SRH]CPY)="2"
#  Gosub DIGSIGN From SUBSRHA
#Endif
## ----------------------------------------------------------- #

Return

####################################################################
$APRES_MOD

Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)

# FGR 04/01/2011 : X3SUIVI70100 (début) déplacé dans la transaction
# Si présence module Support Client, gestion du parc client
#If GMODU(12)=2
#   Gosub TRT_MACRULE_MOD
#Endif
# FGR 04/01/2011 : X3SUIVI70100 (fin) déplacé dans la transaction

# -- Impression du bon de retour
If !GIMPORT & WSLTDOCFLG = 2
    Gosub SET_CLE From GOBJSUB
    CLECUR = 1
    Call ETAT(WSLTDOCNAM,"GESSRS",TBPAR,TBVAL) From ETAT
Endif

# Vide la table de travail de la gestion des emplacements
Local Integer WRET
Call STKDELRES(0,[M:SRS0]STOFCY,"",WRET) From STKLOC

# -- Impression des étiquettes -----#
If GSLTPRNCOD1>1 & sum([M:SRS1]RTNSTOUPD) > [M:SRS1]NBLIG
    Local Char    LCRIT(250)
    Local Char WPARAM(GLONVCR)(1..4) , WVALEUR(10)
    Local Integer WCREATION
    WPARAM(1) = [M:SRS0]STOFCY
    WPARAM(2) = num$(13)
    WPARAM(3) = [M:SRS0]SRHNUM
#                                                                                           # hcb X3-91077 - X3-92342 deb
#   Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
        Case GSLTPRNCOD1
             When 2 :
               Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE1","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette stock
             When 6 :
               Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE2","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette nouveau contenant
             When 7 :
               If !clalev([F:LPN])  : Local File LPN          [LPN]  : Endif
               Raz WCREATION
               LCRIT   = "STOFCY=[M:SRS0]STOFCY"
               LCRIT  += "&VCRNUM>=[M:SRS0]SRHNUM"
               LCRIT  += "&VCRNUM<=[M:SRS0]SRHNUM"
               LCRIT  += "&PRTFLG <> 2"
               Filter [F:LPN] Where evalue(LCRIT)
&              Order By Key LPN0
               For [LPN]
                   WCREATION = 2
                   Break
               Next
               Filter [LPN]
               If WCREATION = 2
                  Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE3","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette stock et contenant créé
               Else
                  Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE1","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette stock
               Endif
             When Default
        Endcase
#                                                                                           # hcb X3-91077 - X3-92342 fin
Endif

Gosub RELIT From GOBJSUB
[M:SRS0]SRHNUM = [F:SRH]SRHNUM

Return
####################################################################
$VERF_ANU
OK = 1
# "Stock mis à jour ! Utilisez le bouton contextuel 'Modif mvts de stock'"
If   sum([M:SRS1]RTNSTOUPD) > [M:SRS1]NBLIG
   GERR=1 : GMESSAGE=mess(72,192,1)+"\"+mess(121,192,1)-mess(262,198,1)
   OK=0   : Return
Endif

#85785
If func PORLEGLIB.DIGSIGN([M:SRS0]STOFCY, "")
  If [M:SRS0]SRHCFMFLG = 2
    OK       = 0 : GERR = 1
    GMESSAGE = mess(51,7711,1) + mess(654,7773,1)
  Endif
Endif
Return

###############################################################
$ANNULE

Local  Decimal  WLIVTTC        : # En livraison TTC
Local  Integer  WRTNLINNBR     : # Nb lignes retournées pour la livraison

# Raz des variables utilisées pour la maj des mvts clients, livraison
Raz WLIVTTC, WRTNLINNBR

#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0 and dim(GMODMSDGFORDEB)>0 and GMODMSDGFORDEB<>2
  If [F:SRH]EECNUMDEB>0
      Filter [F:DEB] Where EECNUMDEB=[F:SRH]EECNUMDEB and VCRNUM=[F:SRH]SRHNUM and CPY=[F:SRH]CPY
      Read [F:DEB]First
      If fstat : Raz [F:DEB] : Endif
      Filter [F:DEB]
      If [F:DEB]DEBDAT<>[0/0/0]
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB)-mess(98,107,1)-format$("DD2",[F:DEB]DEBDAT),0) From GESECRAN
      Else
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB),0) From GESECRAN
      Endif
      GMODMSDGFORDEB = 2
  Endif
Endif
#--/

If sum([M:SRS1]PNDLIN)<>0
    # Pour recherche dernier n°retour vente d'une ligne retour fsseur
    If clalev([F:SRD1])=0 Local File SRETURND [SRD1] Endif
Endif
Gosub ANNULE From TABLEAUX : # Effacement des lignes
If GOK<1 : Return : Endif
If sum([M:SRS1]PNDLIN)<>0
    Close Local File [SRD1] : Default File [SRH]
Endif

# Bug 52920 : Pas de maj mvt client pour les retours sous-traitance
#If WLIVTTC <> 0
#   # -- Maj mouvement client (incrément livré en prêt)
#   Call MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY,
#&               0, WLIVTTC, "-", "D", "", [F:SDH]LND) From TRTBPMVT
#   If GOK < 1  Return  Endif
#Endif

# Maj des statistiques
Call VALSTA("SRH",-1) From SUBPS2
If GOK < 1 : Return : Endif
Return

###############################################################
$DEFLIG
#----------------------------------#
# Définition du fichier des lignes #
#----------------------------------#
# Critère de lecture      (CRIT)   #
# Nom du fichier          (FICLIG) #
# Abréviation du fichier  (ABLIG)  #
# Zone numéro de ligne    (ZONLIG) #
#----------------------------------#
Default Mask [SRS1]
# FGR 24/07/2015 : X3SUIVI109796 : Optimisation (début)
#Default File [SRD]
#Default File [LSRD]
If dim(SAVACT) >= 0 and find(SAVACT,"MODIF","CREATION","ANNULE") Then
  Default File [SRD]
Else
  Default File [LSRD]
Endif
# FGR 24/07/2015 : X3SUIVI109796 : Optimisation (fin)

CRIT = '[F:SRD]SRHNUM="'+[M:SRS0]SRHNUM+'"'
FICLIG = "SRETURND" : ABLIG = "SRD"
ZONLIG = "SRDLIN"
Return

####################################################################
$INI_LIG
Local Shortint NOL

[F:SRD]SRHNUM = [M:SRS0]SRHNUM
[F:SRD]STOFCY = [M:SRS0]STOFCY
If dim([F:SRD]CPY)>0 : [F:SRD]CPY=GSOCIETE : Endif

NOL=nolign-1
# -- Alimentation des zones de détail
[F:SRD]SDHNUM = [M]DETSDHNUM(NOL)
[F:SRD]RTNDAT = [M]RTNDAT
[F:SRD]STOFCY = [M]STOFCY

If ACTION="INICRE_LIG"
  # Alimentation dépôt ligne si renseigné
  If dim([M:SRS1]WRH)>0 & [M:SRS1]WRH(NOL)<>""
    [F:SRD]WRH = [M:SRS1]WRH(NOL)
  Else
   [F:SRD]WRH = ""
  Endif
Endif

[F:SRD]PJT    = [M:SRS1]DPJT(NOL) :#--CPO 71065 Code affaire en-tête / lignes
[F:SRD]SRHCAT = [M:SRS0]SRHCAT    :#--CPO 75115 SRHCAT contient la catègorie de retour

Return

####################################################################
$LIENS_LIG
Local Shortint NOL

NOL = nolign-1

If [F:SRD]SDHNUM <> ""
    # -- Lecture entête livraison
    Read [SDH] SDH0=[F:SRD]SDHNUM
    If fstat
         Call RSTA ("SDH",[F:SRD]SDHNUM)  From GLOCK
         Raz [F:SDH]
    Endif
    # -- Lecture détail livraison
    Read [SDD] SDD0=[F:SRD]SDHNUM;[F:SRD]SDDLIN
    If fstat
         Call RSTA ("SDD",[F:SRD]SDHNUM-num$([F:SRD]SDDLIN)) From GLOCK
         Raz [F:SDD]
    Endif

    # -- Alimentation des zones de détail par la livraison
    [M]DETSDHNUM(NOL)  = [F:SRD]SDHNUM

    [M]SIHNUMFAC(NOL)  = [F:SDH]SIHNUM
    [M]STOMGTCOD(NOL)  = [F:SDD]STOMGTCOD
    [M]CUR(NOL)        = [F:SDH]CUR
Endif
# FGR 27/07/2015 : X3SUIVI108078 : Optimisation (début)
# -- Lecture article
#If [F:ITM]ITMREF<>[F:SRD]ITMREF
#    Read [ITM]ITM0=[F:SRD]ITMREF
#    If fstat Call RSTA ("ITM",[F:SRD]ITMREF)  From GLOCK : Raz [F:ITM] : Endif
#Endif
#If [F:ITM]ITMREF<>[F:SRD]ITMREF | [F:ITU]BPCNUM<>[F:SRH]BPCORD
#    Read [ITU]ITU0=[F:SRD]ITMREF;[F:SRH]BPCORD
#    If fstat Raz [F:ITU] : Endif
#Endif
# FGR 27/07/2015 : X3SUIVI108078 : Optimisation (fin)

Gosub ALI_DACSAUCOE

If [F:SRD]PNHNUM<>""
   # -- Lecture retour fournisseur
   Read [PNH]PNH0=[F:SRD]PNHNUM
   If fstat Call RSTA ("PNH",[F:SRD]PNHNUM)  From GLOCK : Raz [F:PNH] : Endif
   # -- Lecture détail retour fournisseur
   Read [PND] PND0=[F:SRD]PNHNUM;[F:SRD]PNDLIN
   If fstat Call RSTA ("PND",[F:SRD]PNHNUM-num$([F:SRD]PNDLIN)) From GLOCK : Raz [F:PND] : Endif
   [M]PNHFCY = [F:PNH]PNHFCY
   [M]BPSNUM = [F:PNH]BPSNUM
   [M]PNDQTYSTU(NOL)  = [F:PND]QTYSTU - [F:PND]SRDQTYSTU
Elsif [M]BETFCY=2
   # alimentation du site reception pour la maj des stock transféré et en transit
   Call RECPRHFCY([M]BPCORD, [M]BPAADD, [M]PNHFCY) From TRTVENISOC
   If GERR=1 Raz GMESSAGE : Raz GERR Endif : # Si aucun trouvé tanpis on continue
Endif

# Calcul de la quantité livrée dans l'unité du retour
If [F:SDD]SAU=[F:SRD]SAU & [F:SDD]SAUSTUCOE=[F:SRD]SAUSTUCOE
    # 77101 : Tout est retourné en US, on peut afficher la qté livrée à 0
    If [F:SDD]RTNQTYSTU>=[F:SDD]QTYSTU
      [M]DLVQTY(NOL) = 0
    Else
      [M]DLVQTY(NOL) = [F:SDD]QTY - [F:SDD]RTNQTY
    Endif
Else
    # l'unité de la livraison n'est pas l'unité du retour
    # On repart de la qté livrée en US et on convertit dans l'unité de retour
    Local Decimal WDLVQTY
    WDLVQTY = [F:SDD]QTYSTU - [F:SDD]RTNQTYSTU
    WDLVQTY=WDLVQTY/[F:SRD]SAUSTUCOE
    Call QTEARR(WDLVQTY, [F:SRD]SAU) From TRTDIV
    [M]DLVQTY(NOL)     = WDLVQTY
Endif
[M]DLVQTYSTU(NOL)  = [F:SDD]QTYSTU - [F:SDD]RTNQTYSTU

#----- Chargement sections analytiques -----#
Call CHARG_CCE("SRS1",NOL,"SRD",0,[F:SRD]SRHNUM,[F:SRD]SRDLIN,0,"") From TRTX3CPT
# -- Alimentation des zones de sauvegarde
[M]XQTY(NOL)       = [M]QTY(NOL)
[M]XQTYSTU(NOL)    = [M]QTYSTU(NOL)
[M]YRTNSTOUPD(NOL) = [M]RTNSTOUPD(NOL)
Raz [M]WSTOUPD(NOL)
If [M]RTNSTOUPD(NOL)=2
  # Recherche du contenu des zones stock d'une ligne document dans le fichier STOJOU
  Call RECSTO_F ("SRS1", [M:SRS0]STOFCY, 13,
&              [M:SRS0]SRHNUM, [M:SRS1]SRDLIN(NOL), NOL, "") From STKECR
  [M:SRS1]WSTOFLG(NOL)=1
Else
  Raz [M:SRS1]WSTOFLG(NOL)
Endif

#--CPO 71065 Code affaire en-tête / lignes
[M:SRS1]DPJT(NOL)=[F:SRD]PJT
#--/CPO

Return
#########################################################################
# ------------------------------------ #
# Alimentation du flag coef modifiable #
# ------------------------------------ #
$ALI_DACSAUCOE
If [M]SAU(NOL)=[M]STU(NOL)
    [M]DACSAUCOE(NOL)=1
Elsif [M]SAU(NOL)=[F:ITM]SAU
    [M]DACSAUCOE(NOL)=[F:ITM]DACSAUCOE
Elsif [M]SAU(NOL)=[F:ITU]SAU | [M]SAU(NOL)=[F:ITU]PCU1 | [M]SAU(NOL)=[F:ITU]PCU2
    [M]DACSAUCOE(NOL)=1
Else
    Local Integer I    : # L'unité est une unité de conditionnement
    For I=0 To dim([F:ITM]PCU)-1
       If find([F:ITM]PCU(I),[M]SAU(NOL))
          [M]DACSAUCOE(NOL)=[F:ITM]DACPCUCOE(I)
          Break
       Endif
    Next I
Endif
Return
#########################################################################
$VALLIG
#----------------------------------------------------------------#
# En création     : TRTLIG = "C" et SIGN = +1 (après le write)   #
# En modification : TRTLIG = "M" et SIGN = -1 (avant le rewrite) #
#                                   SIGN = +1 (après le rewrite) #
# En annulation   : TRTLIG = "A" et SIGN = -1 (avant le delete)  #
#----------------------------------------------------------------#
Local Char    WMAJ
Local Integer WOPT, WWIN, WRET
Local Decimal WQTE, WQTY, WSHT, WCNVDELTAQTY
Local Integer NOL
Local Decimal DELTAQTY     : # Delta de la quantité livrée    (en + ou -)
Local Decimal DELTAQTYSTU  : # Delta de la quantité livrée US (en + ou -)
Local Decimal ECARTQTY     : # Ecart entre qte cde et qte liv (en + ou -)
Local Integer WMAJ_PNH     : WMAJ_PNH=1

NOL  = nolign-1
WMAJ = "C"        : # Création allocation
WWIN = 0          : # Inutilisé
WRET = 0          : # Code retour

# -- lecture livraison avec lock

If [F:SRD]SDHNUM <> "" Gosub LEC_LIV : If GOK <= 0  Return  Endif : Endif

# -- lecture retour fournisseur avec lock
If [F:SRD]PNHNUM <> "" Gosub LEC_PNH : If GOK <= 0  Return  Endif : Endif


If GOK < 1  Return  Endif

If TRTLIG = "C"             : Gosub VALLIGCRE : Endif
If TRTLIG = "M" & SIGN = +1 : Gosub VALLIGMOD : Endif
If TRTLIG = "A"             : Gosub VALLIGANN : Endif
If GOK<1 Return Endif

If [F:SRD]SDHNUM <> "" Unlock [SDH] : Unlock [SDD] Endif
If [F:SRD]PNHNUM <> "" Unlock [PNH] : Unlock [PND] Endif

#If TRTLIG = "A"
#    #----- Suppression comptes et sections de la ligne de facture -----#
#    Delete [CAL] Where ABRFIC="SRD" & VCRNUM=[F:SRD]SRHNUM & VCRLIN=[F:SRD]SRDLIN
#    If fstat=1
#      GOK=-1 : GLOCK="$CPTANALIN SRD 0"-[F:SRD]SRHNUM-num$([F:SRD]SRDLIN) : Return
#    Endif
# --> Création et Modification
#Elsif SIGN = +1
    #----- Ecriture des sections de la ligne de devis -----#
#    Gosub MAJSRD_CPTANALIN
#Endif

#FQ 65292
#----- Ecriture des sections de la ligne de devis -----#
  Gosub MAJSRD_CPTANALIN
#fin FQ 65292

# Maj des statistiques
Call VALSTA("SRD",SIGN) From SUBPS2
If GOK < 1 : Return : Endif
Return
####################################################################
#------------------------------------------- #
# Ecriture des sections de la ligne de devis #
#------------------------------------------- #
#$MAJSRD_CPTANALIN
#If dim(I)<1  Local Integer I : Endif
#-----
#If TRTLIG="M"
#  Readlock [CAL] CAL0="SRD";0;[F:SRD]SRHNUM;[F:SRD]SRDLIN;0;"";1
#  If fstat=1
#    GOK=-1 : GLOCK="$CPTANALIN SRD 0"-[F:SRD]SRHNUM-num$([F:SRD]SRDLIN) : Return
#  Elsif fstat
#    GOK=0  : Call RSTA("CAL","SRD 0"-[F:SRD]SRHNUM-num$([F:SRD]SRDLIN)) From GLOCK : Return
#  Endif
#Else
#  Raz [F:CAL]
#  [F:CAL]ABRFIC="SRD"
#  [F:CAL]VCRNUM=[F:SRD]SRHNUM
#  [F:CAL]VCRLIN=[F:SRD]SRDLIN
#  [F:CAL]ANALIG=1
#Endif
#-----
#For I=1 To max(GNBCOA,2)
#  [F:CAL]LED(I-1)=GLEDSOC(I)
#  [F:CAL]COA(I-1)=GCOA(I)
#Next I
#For I=1 To max(GNBDIE,GOPTCANA)
#  [F:CAL]DIE(I-1)=GDIE(I)
#  [F:CAL]CCE(I-1)=evalue("[M:SRS1]CCE"+num$(I)+"(nolign-1)")
#Next I
#-----
#If TRTLIG="M"  Rewrite [CAL]  Else  Write [CAL] : Endif
#If fstat  GOK=0 : Call FSTA("CAL") From GLOCK : Return : Endif
#Return
####################################################################

#------------------------------------------- #
# Ecriture des sections de la ligne de retour#
#------------------------------------------- #
#FQ 65292
$MAJSRD_CPTANALIN
# --> Annulation
If SIGN = -1 & TRTLIG = "A"
    #----- Suppression comptes et sections de la ligne de retour -----#
    Call ENREG_ACCCCE(0,"","","","SRD",0,[F:SRD]SRHNUM,[F:SRD]SRDLIN,0,"","A") From TRTX3CPT
    If GOK<1  Return : Endif
    #-----
Elsif TRTLIG="M" & SIGN=-1
# --> Création et Modification
Elsif SIGN = +1
    #----- Ecriture des comptes et sections dans la table CPTANALIN -----#
    Call ENREG_ACCCCE(nolign-1,"","","[M:SRS1]CCE","SRD",
&                     0,[F:SRD]SRHNUM,[F:SRD]SRDLIN,0,"",TRTLIG) From TRTX3CPT
    If GOK<1  Return : Endif
    #-----
Endif

Return
#fin FQ 65292
#########################################################################
#-----------------------------------------------------------------------#
# ETIQUETTES APPELEES PAR LES ACTIONS OBJETS                            #
#-----------------------------------------------------------------------#
#########################################################################
#---------------------------------------#
# Mise à jour de l'adresse              #
#---------------------------------------#
$MAJADRESSE
Call DEBTRANS From GLOCK
$TR_ADR
GOK=1
Trbegin [SRH]
  Readlock [SRH] SRH0=[M]SRHNUM
  If fstat=1  GOK=-1 : GLOCK="$SRETURN"-[M]SRHNUM          : Goto ROLL_ADR
  Elsif fstat GOK=0  : Call RSTA("SRH",[M]SRHNUM) From GLOCK : Goto AB_ADR : Endif
  [F:SRH]CNDNAM = [M:ADB2]CNTNAM
  If [M:ADB2]ADBFLG = 2 Gosub CHARGE_ADRBPD Endif
  Rewrite [SRH]
  If fstat GOK=0 : Call FSTA("SRH") From GLOCK : Goto AB_ADR : Endif
Commit
Gosub RELIT From GOBJSUB  # FGR 24/07/2014 : X3SUIVI100377
Return

$ROLL_ADR
Rollback : Call ROLL From GLOCK
If !GROLL Goto TR_ADR : Endif
Return

$AB_ADR
Rollback
Return

#---------------------------------------#
# Alimentation de l'adresse livraison   #
#---------------------------------------#
$CHARGE_ADRBPD
[F:SRH]BPDNAM(0)    = [M:ADB2]BPRNAM(0)
[F:SRH]BPDNAM(1)    = [M:ADB2]BPRNAM(1)
[F:SRH]BPDADDLIG(0) = [M:ADB2]BPAADDLIG(0)
[F:SRH]BPDADDLIG(1) = [M:ADB2]BPAADDLIG(1)
[F:SRH]BPDADDLIG(2) = [M:ADB2]BPAADDLIG(2)
[F:SRH]BPDPOSCOD    = [M:ADB2]POSCOD
[F:SRH]BPDCTY       = [M:ADB2]CTY
[F:SRH]BPDSAT       = [M:ADB2]SAT
[F:SRH]BPDCRY       = [M:ADB2]CRY
[F:SRH]BPDCRYNAM    = [M:ADB2]CRYNAM
Return

#------------------------------------------------------#
# Chargement des adresses libres avant (ré)écriture    #
#------------------------------------------------------#
$CHARGEADR
Local Integer I
# Alimentation de l'adresse livraison
[F:SRH]CNDNAM = [M:ADB2]CNTNAM
If GACTSAD=2 & find([M:ADB2]ADBFLG,0,1) Call CHARGE_ADRMSK("ADB2", [F:SRH]BPCORD) From TRTVENDIV : Endif
Gosub CHARGE_ADRBPD
Return

#########################################################################
$LEC_LIV

# -- Lecture lockée entête livraison
Readlock [SDH] SDH0=[F:SRD]SDHNUM
If   fstat = 1 GOK =-1
     GLOCK = "$SDELIVERY"-[F:SRD]SDHNUM
     Return
Elsif fstat  GOK = 0
     Call RSTA ("SDH",[F:SRD]SDHNUM)  From GLOCK
     Return
Endif

# -- Lecture lockée détail livraison
Readlock [SDD] SDD0=[F:SRD]SDHNUM;[F:SRD]SDDLIN

If fstat = 1 GOK = -1
   GLOCK = "$SDELIVERYD"-[F:SRD]SDHNUM-num$([F:SRD]SDDLIN)
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SDD",[F:SRD]SDHNUM-num$([F:SRD]SDDLIN)) From GLOCK
   Return
Endif
Return

########################################################################
$LEC_PNH
# -- Lecture lockée entête retour fournisseur
Readlock [PNH] PNH0=[F:SRD]PNHNUM
If fstat = 1 GOK =-1
     GLOCK = "$PRETURN"-[F:SRD]PNHNUM : Return
Elsif fstat=5
     WMAJ_PNH=0 : Return
Elsif fstat  GOK = 0
     Call RSTA ("PNH",[F:SRD]PNHNUM)  From GLOCK : Return
Endif

# -- Lecture lockée détail retour fournisseur
Readlock [PND] PND0=[F:SRD]PNHNUM;[F:SRD]PNDLIN
If fstat = 1 GOK = -1
    GLOCK = "$PRETURND"-[F:SRD]PNHNUM-num$([F:SRD]PNDLIN) : Return
Elsif fstat=5
    WMAJ_PNH=0 : Return
Elsif fstat  GOK =  0
    Call RSTA ("PND",[F:SRD]PNHNUM-num$([F:SRD]PNDLIN)) From GLOCK : Return
Endif
Return

#########################################################################
$VALLIGCRE
#----------------------------------#
# Traitement de VALLIG en création #
#----------------------------------#

DELTAQTY    = [F:SRD]QTY
DELTAQTYSTU = [F:SRD]QTYSTU

# Réalimentation du no ligne retour pour maj stock
[M]SRDLIN(NOL) = [F:SRD]SRDLIN

If [F:SRD]SDHNUM <> "" & DELTAQTYSTU <> 0
    # -- Maj du détail livraison (qté retour en uv & us)
    Gosub CONV_DELTAQTY
    Gosub MAJLIV
    If GOK <= 0 : Return : Endif
Endif
# -- Maj mouvement client si facture non émise(décrémentation livré en prêt)
If [M]SIHNUMFAC(NOL) = "" & DELTAQTYSTU <> 0
    WLIVTTC += WCNVDELTAQTY * [F:SDD]NETPRIATI
Endif

If [F:SRD]PNHNUM <> "" & WMAJ_PNH=1
   # -- Maj du détail retour fournisseur (qté retour en us)
   If DELTAQTYSTU <> 0
       Gosub MAJPND : If GOK < 1 Return Endif
   Endif
Endif

# -- Maj du stock
If [M]RTNSTOUPD(NOL)=2
   Gosub MAJ_STOCK
   If GOK < 1 Return Endif
Endif

Return

#########################################################################
$VALLIGMOD
#--------------------------------------------------#
# Traitement de VALLIG en modification (SIGN = +1) #
#--------------------------------------------------#

DELTAQTY    = [M]QTY(NOL)    - [M]XQTY(NOL)
DELTAQTYSTU = [M]QTYSTU(NOL) - [M]XQTYSTU(NOL)

# -- Maj du détail livraison (qté retour en uv & us)
If DELTAQTYSTU <> 0 & [F:SRD]SDHNUM <> ""
    Gosub CONV_DELTAQTY
    Gosub MAJLIV
    If GOK <= 0 : Return : Endif
Endif
# -- Maj mouvement client si facture non émise(décrémentation livré en prêt)
If [M]SIHNUMFAC(NOL) = "" & DELTAQTYSTU <> 0
#   WLIVTTC += DELTAQTY * [F:SDD]NETPRIATI
    WLIVTTC += WCNVDELTAQTY * [F:SDD]NETPRIATI
Endif

#maj du retour fournisseur
If [F:SRD]PNHNUM <> "" & WMAJ_PNH=1
   # -- Maj du détail retour fournisseur (qté retour en us)
   If DELTAQTYSTU <> 0
       Gosub MAJPND : If GOK < 1 Return Endif
   Endif
Endif


# -- Maj du stock
If [M]RTNSTOUPD(NOL)=2 & [M]WSTOSEQ(NOL)<>0
   Gosub MAJ_STOCK
   If GOK < 1 Return Endif
Endif

Return

#########################################################################
$VALLIGANN
#--------------------------------------#
# Traitement de VALLIG en annulation   #
#--------------------------------------#
DELTAQTY    = -1 * [F:SRD]QTY
DELTAQTYSTU = -1 * [F:SRD]QTYSTU

# -- Maj du détail livraison (qté retour en uv & us)
If DELTAQTYSTU <> 0 & [F:SRD]SDHNUM <>""
    Gosub CONV_DELTAQTY
    Gosub MAJLIV
    If GOK <= 0 : Return : Endif
Endif
# -- Maj mouvement client (incrémentation livré en prêt)
If [M]SIHNUMFAC(NOL) = "" & DELTAQTYSTU <> 0
#   WLIVTTC -= [F:SRD]QTY * [F:SDD]NETPRIATI
    WLIVTTC -= WCNVDELTAQTY * [F:SDD]NETPRIATI
Endif
#maj du retour fournisseur
If [F:SRD]PNHNUM <> "" & WMAJ_PNH=1
   # -- Maj du détail retour fournisseur (qté retour en us)
   If DELTAQTYSTU <> 0
       Gosub MAJPND : If GOK < 1 Return Endif
   Endif
Endif

Return
#########################################################################
$CONV_DELTAQTY
#-----------------------------------------------------------------------------#
# Conversion delta de la qté retournée dans l'unité de vente de la livraison  #
#-----------------------------------------------------------------------------#
# -- Alimentation quantité retournée en UV
If [F:SDD]SAU=[F:SRD]SAU & [F:SDD]SAUSTUCOE=[F:SRD]SAUSTUCOE
    WCNVDELTAQTY    = DELTAQTY
Else
    WCNVDELTAQTY=DELTAQTYSTU/[F:SDD]SAUSTUCOE
    WCNVDELTAQTY = arr(WCNVDELTAQTY,0.000001)
Endif
Return

# picking
#########################################################################
$MAJLIV
Local  Integer  WRTNLINNBR     : # Nb lignes retournées pour la livraison

#-------------------------#
# Maj ligne de livraison  #
#-------------------------#
# -- la ligne étaient totalement retournée
If [F:SDD]RTNQTYSTU = [F:SDD]QTYSTU
   WRTNLINNBR -= 1
Endif

# -- Alimentation quantité retournée en UV
#[F:SDD]RTNQTY    += DELTAQTY
[F:SDD]RTNQTY    += WCNVDELTAQTY
# -- Alimentation quantité retournée en US
[F:SDD]RTNQTYSTU += DELTAQTYSTU
# -- la ligne est maintenant totalement retournée
If [F:SDD]RTNQTYSTU = [F:SDD]QTYSTU
   WRTNLINNBR += 1
Endif

# -- la quantitée retournée > quantitée livrée
If [F:SDD]RTNQTYSTU > [F:SDD]QTYSTU
   GERR = 1 : GMESSAGE=[F:SDD]SDHNUM-mess(64,192,1)
   GOK = 0  : Return
Endif

# -- Récriture du détail livraison
Rewrite [SDD]
If fstat : GOK = 0 : Call FSTA("SDD") From GLOCK : Return : Endif

#-------------------------#
# Maj entête livraison    #
#-------------------------#
# -- Alimentation nombre lignes totalement retournées
[F:SDH]RTNLINNBR += WRTNLINNBR

# -- Maj etat de retour
# 40127 : Return status management
#If    [F:SDH]RTNLINNBR  = 0 & [F:SDD]RTNQTYSTU=0 : [F:SDH]RTNSTA = 1
#Elsif [F:SDH]RTNLINNBR >= [F:SDH]LINNBR : [F:SDH]RTNSTA = 3
#Else                                    : [F:SDH]RTNSTA = 2
#Endif
If [F:SDH]RTNLINNBR >= [F:SDH]LINNBR : [F:SDH]RTNSTA = 3
Else
    Filter [SDD1] Where SDHNUM=[F:SDD]SDHNUM & SDDLIN<>[F:SDD]SDDLIN & RTNQTYSTU<>0
    Read [SDD1]SDD0 First
    If fstat = 0
        [F:SDH]RTNSTA=2
    Else
        If [F:SDH]RTNLINNBR  = 0 & [F:SDD]RTNQTYSTU=0
            [F:SDH]RTNSTA = 1
        Else
            [F:SDH]RTNSTA = 2
        Endif
    Endif
    Filter [SDD1]
Endif
# 40127

# -- Récriture de l'entête livraison
Rewrite [SDH]
If fstat : GOK = 0 : Call FSTA("SDH") From GLOCK : Return : Endif
Return
#########################################################################
$MAJPND
#---------------------------------#
# Maj ligne de retour fournisseur #
#---------------------------------#
# -- Alimentation quantité retournée en US
[F:PND]SRDQTYSTU += DELTAQTYSTU
# -- pas de maj si qté retournée > qté du retour
If [F:PND]SRDQTYSTU > [F:PND]QTYSTU
   GERR = 1 : GMESSAGE=[F:PND]PNHNUM-mess(275,192,1) : GOK  = 0 : mkstat = 2 : Return
Endif
# -- Alimentation du n°retour vente
If TRTLIG="C"
    [F:PND]SRHNUM=[F:SRD]SRHNUM
    [F:PND]SRDLIN=[F:SRD]SRDLIN
Elsif TRTLIG="A"
    # Suppression de la ligne : Recherche du dernier n° retour
    If [F:PND]SRDQTYSTU<>0
        Call RECH_DERSRDPND
    Else
        Raz [F:PND]SRHNUM, [F:PND]SRDLIN
    Endif
Endif
# -- Récriture du détail retour fournisseur
Rewrite [PND]
If fstat : GOK = 0 : Call FSTA("PND") From GLOCK : Return : Endif

Return


#########################################################################
$ETAT_ZONE

#--CPO 71065 Code affaire sur les retours
If GPJTSNGDOC = G_NON Then
  Call PJT_MODFCY([M:SRS0]STOFCY, "[M:SRS1]DPJT") From TRTPJT
Endif
#--/CPO

Actzo [M:SRS1]1-99

If GREP = "C"
   If GMANCOU <> 2
      Diszo [M:SRS0]SRHNUM
   Endif
Else
   Diszo [M:SRS0]STOFCY, BPCORD, BPAADD
   Diszo [M:SRS0]SRHTYP                   :#--CPO 75115
Endif

#--CPO 71065 Code affaire sur les retours
If GPJTSNGDOC = G_OUI Then
  Call PJT_MODFCY([M:SRS0]STOFCY, "[M:SRS1]DPJT") From TRTPJT
Endif
#--/CPO

Return

#########################################################################
$DEVERROU_PICKING
#-----------------------------------------------------------------------#
# Déverrouillage des livraisons et des retours bloqués par le picking   #
#-----------------------------------------------------------------------#
Local Integer I
Local Char    SYMBOLE2(50)
# Déblocage des livraisons en cours de picking
For I=0 To [M:SRS1]NBLIG-1
   If [M:SRS1]CREFLG(I)=0 & [M:SRS1]DETSDHNUM(I)<>""
      SYMBOLE2 = "SDH"+[M:SRS1]DETSDHNUM(I)
      Unlock = SYMBOLE2
   Endif
   If [M:SRS1]CREFLG(I)=0 & [M:SRS1]PNHNUM(I)<>""
       SYMBOLE2 = "PNH"+[M:SRS1]PNHNUM(I)
       Unlock = SYMBOLE2
   Endif
Next I
Return

#########################################################################
$VERIF
#---------------------------------------------------#
# Verifications et traitements avant creation/modif #
#---------------------------------------------------#
# --> Vérification que tous les axes entête ont bien été saisis (s'il sont saississables)
If GHEADIE = 1 : # Axes entêtes saisissables (Initialisé par GETCPY)
   If dim([M]NBAXE)>0
      For nolign = 1 To GNBDIE
          If [M]CCE(nolign-1)="" & GOBLDIE(nolign)=2
             GERR=1 : GMESSAGE=mess(177,199,1) : OK=0 : Break
          Endif
      Next nolign
   Endif
   If OK = 0 Return Endif
Endif

# Issue X3-44998 - 2017-07-27 by CPO : Duplicated sale documents: analytical dimension not controlled (idem X3SUIVI93839)
#--This control has to be done also during Creation/Update of a document (moved outside GREP="D")
Gosub VERIF_CTL_ALLCCE From SUBSRS
If OK=0 : Return : Endif
# End issue X3-44998

# BRBAN 01/09/2014 #93745
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:SRS0]STOFCY,'')=1
  Local Integer WQTENOK,WIJ
  Raz WQTENOK,WIJ
  For WIJ=0 To [M:SRS1]NBLIG-1
    If [M:SRS1]QTY(WIJ)=0 : WQTENOK=WIJ+1 : Break : Endif
  Next
  If WQTENOK : GERR=1 : GMESSAGE = mess(160,195,1)-num$(WQTENOK)-mess(579,199,1) : OK=0 : Return : Endif
Endif
#-

#---------------------------------------------------------------------#
# Contrôle de cohérence entre les quantités de STOENTW et le document #
#          et vérifie que les info lot sont validées                  #
#---------------------------------------------------------------------#
Call CTLSTOENT( "SRS1", "QTYSTU", [M:SRS1]NBLIG, OK ) From STKECR
If OK=0 Return : Endif
# --> Il doit y avoir au moins une ligne
If [M:SRS1]NBLIG = 0
   GERR=1 : GMESSAGE=mess(61,199,1)
   OK = 0
Endif

#--CPO 71065 Code affaire sur les retours
Call PJT_CONTROLE_HEAD_DETAIL("[M:SRS2]PJT", "[M:SRS1]DPJT") From TRTPJT
If GERR <> 0 Then
  OK = 0
  Return
Endif
#--/CPO

Return

###############################################################
$MAJLIVENT

# -- Alimentation nombre lignes totalement retournées
[F:SDH]RTNLINNBR += WRTNLINNBR

# -- Maj etat de retour
If    [F:SDH]RTNLINNBR  = 0             : [F:SDH]RTNSTA = 1
Elsif [F:SDH]RTNLINNBR >= [F:SDH]LINNBR : [F:SDH]RTNSTA = 3
Else                                    : [F:SDH]RTNSTA = 2
Endif

# -- Récriture de l'entête livraison
Rewrite [SDH]
If fstat : GOK = 0 : Call FSTA("SDH") From GLOCK : Return : Endif
Return

#--------------------------------------------------------------------------#
# Chargement des globales référenciels, comptes et sections de la société  #
#--------------------------------------------------------------------------#
$CHARG_PARAM

Call GETCPY(GFCY,"SLT",8,GFLAG) From TRTX3CPT

#--CPO 71065 Code affaire sur les retours
GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC(GFCY)
#--/CPO

Return
##########################################################################################################
#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & dim([M:SRS1]CCE1)>0
  Local Char BASPAG(10)
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WK8"+GFLAG+"1"
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:SRS1]NBLIG=0
    [M:SRS1]NBLIG=1 : Affzo [SRS1]15 : Effzo [SRS1]15
  Endif
  #-----
Endif
Raz GSOC_UPDFLG
Return
###############################################################
#-------------------------------#
# Maj des stocks                #
#-------------------------------#
$MAJ_STOCK
Local Decimal LQTA
Local Decimal LSHT
Local Integer LNBR, LNBJ, LRET

Raz [M:STW]
[M:STW]STOFCY  = [M:SRS0]STOFCY
[M:STW]TRSTYP  = 33
[M:STW]TRAFLG  = 1 : # Pas de trace
[M:STW]VCRTYP  = 13
[M:STW]VCRNUM  = [M:SRS0]SRHNUM
[M:STW]VCRLIN  = [M:SRS1]SRDLIN  (NOL)
[M:STW]ITMREF  = [M:SRS1]ITMREF  (NOL)
[M:STW]MVTDES  = [M:SRS1]MVTDES  (NOL)
[M:STW]PJT     = ""
[M:STW]TRSFAM  = [M:SRS2]TRSFAM
[M:STW]TRSCOD  = [M:SRS0]TRSCOD
[M:STW]BPRNUM  = [M:SRS0]BPCORD
If [M:SRS1]BETFCY=2
    [M:STW]TRFFCY = [M:SRS0]PNHFCY
    [M:STW]BETCPY = [M:SRS1]BETCPY
Else
    [M:STW]TRFFCY = ""
    [M:STW]BETCPY = 1
Endif

[M:STW]IPTDAT  = [M:SRS0]RTNDAT

#--- Bug 72471
#If [M:SRS1]DETSDHNUM(NOL) <> "" & [M:SRS1]PNHNUM(NOL) = ""
#    [M:STW]VCRTYPORI = 4
#    [M:STW]VCRNUMORI = [M:SRS1]DETSDHNUM (NOL)
#    [M:STW]VCRLINORI = [M:SRS1]SDDLIN    (NOL)
#Elsif [M:SRS1]PNHNUM(NOL) <> ""
#    [M:STW]VCRTYPORI = 8
#    [M:STW]VCRNUMORI = [M:SRS1]PNHNUM (NOL)
#    [M:STW]VCRLINORI = [M:SRS1]PNDLIN    (NOL)
#Endif
If [M:SRS1]PNHNUM(NOL) <> ""
    [M:STW]VCRTYPORI2 = 8
    [M:STW]VCRNUMORI2 = [M:SRS1]PNHNUM(NOL)
    [M:STW]VCRLINORI2 = [M:SRS1]PNDLIN(NOL)
Endif
If [M:SRS1]DETSDHNUM(NOL) <> ""
    [M:STW]VCRTYPORI = 4
    [M:STW]VCRNUMORI = [M:SRS1]DETSDHNUM(NOL)
    [M:STW]VCRLINORI = [M:SRS1]SDDLIN(NOL)
Endif
#---

[M:STW]CCECOD  ="STKSRT"

Call ALISTOWORK (2,[M:SRS1]WSTOSEQ(NOL),LQTA,LSHT,LNBR,LNBJ,LRET) From STKINT
Call MAJ_STOCK From STKMAJ

If GOK
   If GREP <> "A"
      Call STKFREQCQ("SRS1",[M:SRS0]STOFCY,NOL,[M:SRS1]ITMREF(NOL),"","V",[M:SRS1]QUAFLG(NOL),0) From STKACT   # hcb V6CQ (freq)
   Endif
Endif
Return
#########################################################################
$EXEBOUT
#85785

Case BOUT
  When "1" : CLECUR1 = [M:SRS0]SRHNUM : Gosub RELIT From GOBJSUB
Endcase

Return
#####################################################################
#               LES ACTIONS SUR LES ZONES    ENTETE                 #
#####################################################################
Subprog C_SRHNUM(VALEUR)
Variable Char    VALEUR()
# Pour ne pas essayer de dupliquer
If GREP="" & VALEUR = "" mkstat=2 : End : Endif
# On est pas passé par Fichier Nouveau
If GREP <> "C" & GREP <> "D"
   If [M]SRHNUM <> ""
      Look [F:SRH]SRH0=[M]SRHNUM
      If fstat
         Look [F:SRH]SRH0=VALEUR
         #Il y avait un enr en ligne et la clé saisie n'existe pas --> Création interdite
         If fstat : GMESSAGE=mess(178,199,1) : mkstat=2 : Endif
      Endif
   Else
      Look [F:SRH]SRH0=VALEUR
      #Il n'y avait pas d'enr en ligne et la clé saisie n'existe pas --> Création interdite
      If fstat : GMESSAGE=mess(178,199,1) : mkstat=2 : Endif
   Endif
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran SRS1) 24/02/2006 14:48:16 (LD)
######################################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()

Local Integer IRETOUR  # FGR 11/08/2014 : X3SUIVI102048

#Gbn-100166
# Chargement des globales référenciels, comptes et sections de la société
GFCY=VALEUR : Gosub CHARG_PARAM : If GERR=1 mkstat=2 : End Endif

If [M:SRS0]BPCORD<>"" & [M:SRS0]BPAADD<>""
#   Alimentation flag inter-site et inter-société
    Call ALIBETCPY(13,VALEUR,[M:SRS0]BPCORD,[M:SRS0]BPAADD,[M:SRS0]PNHFCY,[M:SRS0]BPSNUM,[M:SRS1]BETFCY,[M:SRS1]BETCPY) From TRTVENISOC
    If [M:SRS1]BETFCY=2
        # Retour inter-site
        # Le site de réception rattaché au clt livré est aussi le site de réception
        If VALEUR=[M:SRS0]PNHFCY
            Local Integer WOK : WOK=1
            Call AVERTIR (mess(184,191,1), WOK) From GESECRAN
            If WOK=1 mkstat=2 : End : Endif
        Endif
    Endif
    Affzo [M:SRS1]BETFCY, BETCPY
Endif

# Alimentation du code structure
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If [F:CPY]CPY<>GSOCIETE
    Read [CPY] CPY0=GSOCIETE
    If fstat Raz [F:CPY] Endif
Endif
[M:SRS0]PLISTC=[F:CPY]PLISTC

# Chargement des globales référenciels, comptes et sections de la société
#GFCY=VALEUR : Gosub CHARG_PARAM                                          #Gbn-100166-Deplacement en début de sous-pro

#--CPO 75115 Init et recherche du compteur en fonction du SRHTYP
# ------------------------------------
# FGR 11/08/2014 : X3SUIVI102048 (début) : Si SRHTYP n'existe pas dans la nouvelle législation on l'efface pour en chercher un qui ira.
If [M:SRS0]SRHTYP<>""
  Call LEC_TRE_LEG(GCURLEG, [M:SRS0]SRHTYP, IRETOUR) From TRTLECLEG
  If IRETOUR <> 0 Then
    Raz [M:SRS0]SRHTYP
  Endif
Endif
# FGR 11/08/2014 : X3SUIVI102048 (fin)
# ------------------------------------
If [M:SRS0]SRHTYP=""
  Local Char WSRHTYP(GLONTRE) : Local Integer  WSRHCAT
  Gosub SRHTYP From SUBSRH
  [M:SRS0]SRHTYP=WSRHTYP : [M:SRS0]SRHCAT=WSRHCAT
  Affzo [M:SRS0]SRHTYP,SRHCAT
Endif
Gosub REC_CPT_RET From SUBSRS :     # Recherche du compteur retour
#--
# Affichage entêtes colonnes variables (sections analytiques) en cas de changement de société
Gosub AFF_TITCOL From SUBSRS
# Effacement tableau des sections entête si changement société
If dim([M:SRS2]NBAXE)>0 & [M:SRS2]NBAXE>0
  [M:SRS0]STOFCY=VALEUR
  Effzo [SRS2]15 : Affzo [SRS2]15
Endif
#--- Bug 65478
If dim([M:SRS1]WRHE)>0
   Call WRHINIT([M:SRS1]WRHE,VALEUR,4) From STKWRH
Endif
#---
# Actzo ou Grizo des dépôts selon le site
[M]STOFCY=VALEUR
Gosub WRH_ETAT

#RMA * 85785
If func PORLEGLIB.DIGSIGN(VALEUR,"") = 1
  Chgfmt [M:SRS0]SRHCFMFLG   With "LA1:15X"
Else
  If dim([M:SRS0]SRHCFMFLG) > 0
    Chgfmt [M:SRS0]SRHCFMFLG   With "-LA1:15X"
  Endif
Endif

End
######################################################################################
Subprog C_SRHTYP(VALEUR)
Variable Char    VALEUR()

If VALEUR="" : mkstat=2 : End : Endif
#--Contrôle que le type de retour pointe sur une catégorie acceptée par la transaction

# X3-1152 : Non invoiceable deliveries
#If GDLVTYP<4 & [F:TRE]SRHCAT<>GDLVTYP : mkstat = 2 : Endif
If GDLVTYP<>4 & [F:TRE]SRHCAT<>GDLVTYP : mkstat = 2 : Endif
# X3-1152 : Non invoiceable deliveries

#--CPO X3Suivi 75115 Libellé Catégorie --#
[M:SRS0]WSRHCAT = mess(8,105,1) - ':' - mess([F:TRE]SRHCAT,493,1)
Affzo [M:SRS0]WSRHCAT

# BRBAN 23-07-2014 SAM 93745 US2
If func AFNC.ACTIV('KPO')>0
  If func PORLEGLIB.DIGSIGN([M:SRS0]STOFCY,'')=1
    Actzo  [M:SRS2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,ATDTCODR,MANDOCR,GLBDOCR
    Call DIS_MANDOC(GFONCTION) From TRNDOC
  Else
    Diszo  [M:SRS2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,ATDTCODR,MANDOCR,GLBDOCR
  Endif
Endif
#-

End

Subprog AM_SRHTYP(VALEUR)
Variable Char    VALEUR()
#--Init de la catégorie de retour
[M:SRS0]SRHCAT = [F:TRE]SRHCAT
Affzo [M:SRS0]SRHCAT

#--Init du compteur en fonction du type de retour
#--Afin d'avoir la bonne valeur dans le sous-pro REC_CPT_RET
[M:SRS0]SRHTYP=VALEUR
Gosub REC_CPT_RET From SUBSRS : If GERR=1 : mkstat=2 : Endif

If GMANCOU=1 & [M:SRS0]SRHNUM <> ""
   Effzo [M:SRS0]SRHNUM
Endif

If GREP="C" & GMANCOU<>2
   Diszo [M:SRS0]SRHNUM
Else
   Actzo [M:SRS0]SRHNUM
Endif

End
######################################################################################
Subprog AM_BPCORD(VALEUR)
Variable Char    VALEUR()

GBPCNUM = VALEUR
# Recherche du client livré par défaut
Read [BPD]BPD0 = VALEUR;[F:BPC]BPDADD
If fstat=0 & [F:BPD]ENAFLG=2 [M:SRS0]BPAADD = [F:BPD]BPAADD : Endif
If [M:SRS0]BPAADD = ""
   Filter [BPD] Where [BPD]BPCNUM=VALEUR & BPCLOC<>"" & ENAFLG=2
   Read [BPD]BPD0 First
   If fstat = 0 [M:SRS0]BPAADD = [F:BPD]BPAADD Endif
   Filter [BPD]
Endif

Read [BPR]BPR0 = VALEUR
If fstat<>0 Raz [F:BPR] Endif
[M:SRS0]LAN = GLANGUE
If [F:BPR]LAN<>"" [M:SRS0]LAN=[F:BPR]LAN : Endif
# Utile pour l'init. des sections : La Section par défaut "SRH" utile [M:SRS0]BPCORD
[M:SRS0]BPCORD = VALEUR

If [M:SRS0]BPAADD<>""
    Local Char WBPCORD(GLONBPC), WBPAADD(GLONBPD)  : WBPCORD=VALEUR : WBPAADD=[M:SRS0]BPAADD
    Gosub CLILIV
Endif
Affzo [M]BPAADD, BPDNAM
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran SRS1) 02/11/2005 15:57:04 (LD)
######################################################################################
Subprog AP_BPAADD(VALEUR)
Variable Char    VALEUR()
# Si saisie de l'adresse
If [M:ADB2]BPRNAM(0) <> ""
   [M]BPDNAM = [M:ADB2]BPRNAM(0)
   Affzo [M]BPDNAM
Endif
End
########################################
Subprog AM_BPAADD(VALEUR)
Variable Char    VALEUR()
Local Char WBPCORD(GLONBPC), WBPAADD(GLONBPD)  : WBPCORD=[M:SRS0]BPCORD : WBPAADD=VALEUR

# --> Si utilisation du bouton adresse, il ne faut pas passer en AM_
If !GIMPORT & VALEUR = [M]BPAADD End : Endif

Gosub CLILIV
Affzo [M]BPDNAM
End
#####################################################################
$CLILIV
If [F:BPD]LAN<>"" [M:SRS0]LAN = [F:BPD]LAN : Endif
[M:SRS0]BPDNAM =[F:BPD]BPDNAM(0)
# Alimentation code adresse (client livré) dans [M:ADB2] pour saisie adresse libre
If dim([M:ADB2]BPAADD) > 0
   [M:ADB2]BPAADD = WBPAADD
   Call RECH_CNTNAM(WBPCORD, WBPAADD, [M:ADB2]CNTNAM) From TRTVENDIV
Endif
# Alimentation des champs relatifs au infos douanières
[M:SRS0]EECICT=[F:BPD]EECICT
[M:SRS0]ICTCTY=[F:BPD]ICTCTY
[M:SRS0]FFWNUM=[F:BPD]FFWNUM
[M:SRS0]FFWADD=[F:BPD]FFWADD
If dim([M:SRS0]BPIEECNUM)>0
    Call INIEECNUM (WBPCORD,WBPAADD,WBPCORD,[M:SRS0]BPIEECNUM,[M:SRS0]EECNUMCRY) From TRTVENDIV
    [M:SRS0]EECLOC=[F:BPD]EECLOC
    # Lecture table modes de livraison
    If clalev ([F:TMD]) <= 0 Local File TABMODELIV [TMD] Endif
    If [F:BPD]MDL<>""
       Read [TMD]TMD0=[F:BPD]MDL
       If fstat=0 [M:SRS0]EECTRN=[F:TMD]EECTRN : Endif
    Endif
Endif
If [M:SRS0]STOFCY<>"" & WBPCORD<>"" & WBPAADD<>""
#   Alimentation flag inter-site et inter-société
    Call ALIBETCPY(13,[M:SRS0]STOFCY,WBPCORD,WBPAADD,[M:SRS0]PNHFCY,[M:SRS0]BPSNUM,[M:SRS1]BETFCY,[M:SRS1]BETCPY) From TRTVENISOC
    If [M:SRS1]BETFCY=2
        # Retour inter-site
        # Le site de réception rattaché au clt livré est aussi le site de réception
        If [M:SRS0]STOFCY=[M:SRS0]PNHFCY
            Local Integer WOK : WOK=1
            Call AVERTIR (mess(184,191,1), WOK)From GESECRAN
            If WOK=1 mkstat=2 : Return : Endif
        Endif
    Endif
    Affzo [M:SRS1]BETFCY, BETCPY
Endif

Return
#---------------------------------------------------#
#########################################################################
Subprog RECH_DERSRDPND
#---------------------------------------------------------------------------------#
# Recherche dernier no retour vente de la ligne retour fsseur suite à suppression #
#---------------------------------------------------------------------------------#

Filter [SRD1] Where PNHNUM=[F:PND]PNHNUM & PNDLIN=[F:PND]PNDLIN
&            Order By Key NEWCLE=PNHNUM;PNDLIN
Read [SRD1]NEWCLE Last
If fstat = 0
   If ([F:SRD1]SRHNUM=[F:SRD]SRHNUM) & ([F:SRD1]SRDLIN=[F:SRD]SRDLIN)
      # Le dernier n°retour vente est celui qui est en cours de suppression : On lit le précédent
      Read [SRD1]NEWCLE Prev
      If fstat = 0
         [F:PND]SRHNUM = [F:SRD1]SRHNUM
         [F:PND]SRDLIN = [F:SRD1]SRDLIN
      Else
         Raz [F:PND]SRHNUM, [F:PND]SRDLIN
      Endif
   Else
      # Le dernier n°retour vente n'est pas celui qui est en cours de suppression : On le prend
      [F:PND]SRHNUM = [F:SRD1]SRHNUM
      [F:PND]SRDLIN = [F:SRD1]SRDLIN
   Endif
Else
   # Il n'y a pas d'autre retour vente pour cette ligne de retour fsseur
   Raz [F:PND]SRHNUM, [F:PND]SRDLIN
Endif
Filter [SRD1]
End
