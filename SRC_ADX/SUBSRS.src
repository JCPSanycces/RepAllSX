######################################################################################
## Etiquette ajoutée par le superviseur (écran SRS2) 07/09/2006 10:40:37 (LD)
######################################################################################
Subprog C_NBAXE
If !find(status,1,4,5,20,21,26,92,93) | GIMPORT End : Endif
#----- Contrôle Sections d'entête obligatoires si saisissables -----#
If [M:SRS2]NBAXE>0 & GHEADIE=1
  Local Integer I
  For I=1 To [M:SRS2]NBAXE
    If CCE(I-1)="" & GOBLDIE(I)=2
      mkstat=1 : GMESSAGE= mess(46,106,1)-GDIE(I) : Break
    Endif
  Next I
Endif
End
#####################################################################
#               LES ACTIONS SUR LES ZONES    DETAIL                 #
#####################################################################
Subprog IB_NBLIG
Local Integer NOL : NOL = nolign-1

# Bouton  1 : Saisie texte ligne
# Bouton  2 : Saisie des entrées
# Bouton  3 : Appel sous-pro INFOLOT
# Bouton  4 : Fenêtre complément lot
# Bouton  5 : Fenêtre détail en modification
# Bouton  6 : Tunnel livraison
# Bouton  7 : Tunnel retour fournisseur
# Bouton  8 : Situation ligne

# MHB 19/12/08 : ajout n° pièce sur intitulés clics droits
GBOUT6 = GBOUT6-[M]DETSDHNUM(nolign-1) : # Livraison
GBOUT8 = GBOUT8-[M]PNHNUM(nolign-1)    : # Retour fournisseur
GBOUT9 = mess(164,198,1)               : # Situation ligne

If nolign <= [M]NBLIG & nolign>0
    If [M:SRS1]RTNSTOUPD(NOL) = 2
        If [F:SLT]STRNUM<>GFLAG Read [SLT]SLT0=8;GFLAG
                                If fstat Raz [F:SLT] Endif
                                Endif
        # --> Particularité retour
        #     Ligne déjà créée  et flag maj stock était déjà à oui       bt B5 : Fenêtre détail en modification
        #     Ligne déjà créée  et flag maj stock est passé de non à oui bt B2 : Saisie des entrées
        #     Ligne en création et flag maj stock à oui                  bt B2 : Saisie des entrées
        #     [M]WSTOUPD est utilisé dans l'action SAISTOENT avec [M]CREFLG
        #              PARMSK(3) = "WQSRH"+GFLAG+mid$("SM",(!!([M:SRL1]CREFLG(nolign-1)))+1,1)
        #      devient PARMSK(3) = "WQSRH"+GFLAG+mid$("SM",((!!([M:SRL1]CREFLG(nolign-1)))&![M:SRL1]WSTOUPD(nolign-1))+1,1)
        Call STKINIBTN( 2, 5, 3, 4, "SRS1", "SLT", [M:SRS1]ITMREF(nolign-1), [M:SRS0]STOFCY ) From STKENT
    Else
        Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5
    Endif
    If [M]DETSDHNUM(NOL) = ""  Raz GBOUT6 : Endif
    If [M]PNHNUM(NOL) = ""  Raz GBOUT8 : Endif
Else
    Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8
Endif

#85785 * RMA * can't change the document values if validated
If func PORLEGLIB.DIGSIGN([M:SRS0]STOFCY, "") & [M]SRHCFMFLG = 2
  Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5
Endif

End
##########################################################################
## Etiquette ajoutée par le superviseur 17/07/2003 17:06:02 (LD)
##########################################################################
Subprog AVANT_NBLIG
Local Integer NOL : NOL=nolign-1

If status=75
    Call SRSINIZONENT
Else
    If [M:SRS1]STOMGTCOD(NOL)<>1 & [M:SRS1]RTNSTOUPD(NOL)=2
        # Si ligne gérée en stock
        # --> Lecture article et règle de gestion
        Call LECFICENT([M:SRS0]STOFCY,[M:SRS0]BPCORD,"",nolign-1,33,[M:SRS0]TRSCOD,0) From STKECR
    Endif
Endif

# ------------------------ #
# Suppression d'une ligne  #
# ------------------------ #
If find(status,65,68,83)
    If [M]DETSDHNUM(NOL)<>""
        # Ligne issue d'une livraison : Réincrémenter la qté à retourner (pr les ctrls)
        For  I = 0 To [M:SRS1]NBLIG -1
            If [M]DETSDHNUM(I) = [M]DETSDHNUM(NOL) & [M]SDDLIN(I) = [M]SDDLIN(NOL)
                [M]DLVQTYSTU(I) += [M]XQTYSTU(NOL)
            Endif
        Next I
    Elsif [M]PNHNUM(NOL)<>""
        # Ligne issue d'un retour fsseur : Réincrémenter la qté à retourner (pr les ctrls)
        For  I = 0 To [M:SRS1]NBLIG -1
            If [M]PNHNUM(I) = [M]PNHNUM(NOL) & [M]PNDLIN(I) = [M]PNDLIN(NOL)
                [M]PNDQTYSTU(I) += [M]XQTYSTU(NOL)
            Endif
        Next I
    Endif
Endif

End
########################################
Subprog C_NBLIG
Local Integer NOL, OK : NOL=nolign-1

If [M]NBLIG=0
   #Existe dans SUBSRH a faire ??? Actzo [M:SRS0]STOFCY, BPCORD, BPAADD
   Actzo [M:SRS0]SRHTYP                   :#--CPO 75115
Else
   #Existe dans SUBSRH a faire ??? Diszo [M:SRS0]STOFCY, BPCORD, BPAADD
   Diszo [M:SRS0]SRHTYP                   :#--CPO 75115
Endif

# --> Controle de suppression de lignes
If status = 65
   NOL=nolign-1
   # --> pour supprimer cette ligne, il faut la désélectionner de la liste 'sélection livraison'
   If [M:SRS1]DETSDHNUM(NOL)<>"" & [M:SRS1]CREFLG(NOL)=0 & [M:SRS1]PNHNUM(NOL)<>""
       GMESSAGE=mess(223,192,1) : mkstat=2 : End
   Endif
   # --> pour supprimer cette ligne, il faut la désélectionner de la liste 'sélection retours fournisseur'
   If [M:SRS1]PNHNUM(NOL)<>"" & [M:SRS1]CREFLG(NOL)=0
      GMESSAGE=mess(273,192,1) : mkstat=2 : End
   Endif
   # --> Ligne gérée en stock : Suppression ssi la ligne n'a pas encore été crée
   If [M:SRS1]RTNSTOUPD(NOL)=2
       If [M:SRS1]CREFLG(NOL)=0
           Call DELSTOENTW (NOL,NOL,"SRS1",1,1,[M:SRS0]STOFCY,1,"") From STKENT
       Else
           # La suppression d'une ligne validée doit se faire via la fenêtre de modification
           GMESSAGE = mess (6,184,1) : mkstat = 2 : End
       Endif
   Endif
Endif
If status = 68 | status = 83
   For NOL=nolign-1 To nolign1-1
      # --> pour supprimer cette ligne, il faut la désélectionner de la liste 'sélection livraison'
      If [M:SRS1]DETSDHNUM(NOL)<>"" & [M:SRS1]CREFLG(NOL)=0 & [M:SRS1]PNHNUM(NOL)<>""
          GMESSAGE = mess(223,192,1) : mkstat=2 : Break
      Endif
      # --> pour supprimer cette ligne, il faut la désélectionner de la liste 'sélection retours fournisseur'
      If [M:SRS1]PNHNUM(NOL)<>"" & [M:SRS1]CREFLG(NOL)=0
         GMESSAGE=mess(273,192,1) : mkstat=2 : Break
      Endif
      # --> Ligne gérée en stock : Suppression ssi la ligne n'a pas encore été crée
      If [M:SRS1]CREFLG(NOL)<>0 & [M:SRS1]RTNSTOUPD(NOL)=2
          # La suppression d'une ligne validée doit se faire via la fenêtre de modification
          GMESSAGE = mess (6,184,1) : mkstat=2 : Break
      Endif
   Next NOL
   If !mkstat Call DELSTOENTW (nolign-1,nolign1-1,"SRS1",1,1,[M:SRS0]STOFCY,1,"") From STKENT : Endif
Endif

#85785
If func PORLEGLIB.DIGSIGN([M:SRS0]STOFCY, "")
  If [M:SRS0]SRHCFMFLG = 2 & (find (status,65,68,83,73) | GMODIF = 2)
    GMESSAGE = mess(51,7711,1) + mess(654,7773,1)
    mkstat = 2
  Endif
Endif

End
########################################
$AAPRES_NBLIG
#---------------------------------------------------#
# Appel sous-pro OUVENT pour déterminer l'ouverture #
#       de la fenêtre détail SAISTOENT              #
#---------------------------------------------------#
Local Shortint WRET
Local Char     LSUP(1)
Local Shortint NOL : NOL=nolign-1

If [M:SRS1]STOMGTCOD(NOL)=1 | [M:SRS1]RTNSTOUPD(NOL)=1 | [M:SRS1]QTY(NOL)=0
 Raz GOUVENT :  Return
Endif
If [F:ITM]ITMREF<>[M:SRS1]ITMREF(NOL)
  Read [ITM]ITM0=[M:SRS1]ITMREF(NOL)
  If fstat Raz [F:ITM] : Endif
Endif
If [F:SLT]STRNUM<>GFLAG Read [SLT]SLT0=8;GFLAG
                        If fstat Raz [F:SLT] : Endif
                        Endif
If [F:ITM]LOTMGTCOD>1 If !clalev([F:STL]) Local File STOLOT [STL]  : Endif : Endif
# Controle ouverture fenetre saisie des entrées
# Pour cela aliment les variables GOUVENT et GOUVLOT
# Grise les champs ne pouvant plus être modifiés (sous-pro STKDISLIG)
# LSUP = Option : "O"=Même si WSTOFLG=0, garder ce qui se trouve déjà dans STOENTW (lignes liées à la liv)
#If [M:SRL1]DETSDHNUM(NOL)<>"" LSUP="O" Endif

# Issue X3-58977
If [F:ITM]STOMGTCOD>1 & !find([M:SRS1]SAU(NOL),[F:ITM]STU,[F:ITM]PCU)
  [M:ENTW]WZONPCU = "STU"
  [M:ENTW]WZONQUC = "QTYSTU"
Else
  [M:ENTW]WZONPCU = "SAU"
  [M:ENTW]WZONQUC = "QTY"
Endif
# End issue X3-58977

Call OUVENT([M:SRS0]STOFCY,"SRS1",33,[M:SRS0]TRSCOD,[M:SRS0]BPCORD,13,
&           [M:SRS0]RTNDAT,NOL,[M:SRS1]NBLIG,"SLT",LSUP,WRET) From STKENT

Return
########################################
#-----------------------------------------------#
# fenêtre détail en modification                #
#-----------------------------------------------#
$AB5_NBLIG
Local Shortint NOL : NOL=nolign-1
#-- Habilitation Modification mvts stock si on trouve K dans la chaine des boutons autorisés
Raz GBIDI2
GFCY=[M:SRS0]STOFCY
GBIDC2="K" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GMESSAGE=mess(2,104,1)
   GOUVENT=0
   Return
Endif

If [M:SRS0]SRHNUM<>""
  SYMBOLE2="SRS"+[M:SRS0]SRHNUM
  Lock=SYMBOLE2
  If fstat
    GMESSAGE=[M:SRS0]SRHNUM-mess(10,100,1)
    Call ERREUR(GMESSAGE) From GESECRAN
    GOUVENT=0
    Return
  Endif
Endif
GOUVENT=2
Return
########################################
$BB5_NBLIG
If [M:SRS0]SRHNUM<>""
  SYMBOLE2="SRS"+[M:SRS0]SRHNUM
  Unlock=SYMBOLE2
Endif
If GRELITSRS=1
    mkstat=4
Endif
Return

# -------------------------------------- QTY ------------------------
########################################
Subprog AS_QTY(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL : NOL = nolign-1

End

########################################
Subprog C_QTY(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL : NOL = nolign-1
Local    Decimal WQTYSTU
Local    Decimal WQTY, WDLV_QTYSTU, WPND_QTYSTU

# BRBAN 01/09/2014 #93745
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:SRS0]STOFCY,'')=1 & VALEUR = 0
  GMESSAGE = mess(83,123,1) : mkstat = 2 : End
Endif
#-

Call CNVQTY(VALEUR,[M]SAUSTUCOE(NOL),[M]STU(NOL), WQTYSTU) From TRTVENQTE
# -- Quantité retour = 0 erreur
If VALEUR = 0 | WQTYSTU = 0
   GMESSAGE = mess(83,123,1) : mkstat = 2 : End
Endif

# -- Si retour issu livraison             : Quantité retour > quantité livrée ?
If [M]DETSDHNUM(NOL) <> ""
    # -- Calcul qté retour prévue en US pour la ligne de livraison
    WQTY = VALEUR : WCOEF=[M]SAUSTUCOE(NOL) : Gosub CALC_DLV_QTYSTU
    If [M]DLVQTYSTU(NOL) - WDLV_QTYSTU < 0 GMESSAGE = mess(64,192,1) : mkstat = 2 : End : Endif
    If [M]PNHNUM(NOL) = ""
        # La qté retournée ne doit pas être réceptionnée (passer dans ce cas par le picking retour fsseur)
        If [M]DLVQTYSTU(NOL)-WDLV_QTYSTU-[M]RCPQTYSTU(NOL)<0  GMESSAGE=mess(282,192,1)-"\"-mess(150,191,1) : mkstat = 2 : End : Endif
    Endif
# -- Si retour issu retour fournisseur    : Quantité retour > quantité retournée ?
Elsif [M]PNHNUM(NOL) <> ""
    # -- Calcul qté retour prévue en US pour la ligne de retour fournisseur
    WQTY = VALEUR : WCOEF=[M]SAUSTUCOE(NOL) : Gosub CALC_PND_QTYSTU
    If [M]PNDQTYSTU(NOL) - WPND_QTYSTU < 0 GMESSAGE = mess(275,192,1) : mkstat = 2 : End : Endif
Endif

End
# --------------------------------------------------------- #
# Calcul qté retour en US pour la ligne de livraison        #
# --------------------------------------------------------- #
$CALC_DLV_QTYSTU
Local Integer I
Local Decimal WQTYSTU

# -- Calcul qté retour en US pour la ligne de livraison
Raz WDLV_QTYSTU
For  I = 0 To [M:SRS1]NBLIG -1
    If [M]DETSDHNUM(I) = [M]DETSDHNUM(NOL) & [M]SDDLIN(I) = [M]SDDLIN(NOL)
        WDLV_QTYSTU += [M]QTYSTU(I) - [M]XQTYSTU(I)
    Endif
Next I
WDLV_QTYSTU -= [M]QTYSTU(NOL) - [M]XQTYSTU(NOL)
If [M]SAU(NOL)<>[M]STU(NOL)
    Call CNVQTY(WQTY,WCOEF,[M]STU(NOL),WQTYSTU) From TRTVENQTE
Else
    WQTYSTU=WQTY
Endif
WDLV_QTYSTU += WQTYSTU - [M]XQTYSTU(NOL)
Return
# --------------------------------------------------------- #
# Calcul qté retour en US pour la ligne de retour fsseur    #
# --------------------------------------------------------- #
$CALC_PND_QTYSTU
Local Integer I
Local Decimal WQTYSTU

# -- Calcul qté retour en US pour la ligne de retour fsseur
Raz WPND_QTYSTU
For  I = 0 To [M:SRS1]NBLIG -1
    If [M]PNHNUM(I) = [M]PNHNUM(NOL) & [M]PNDLIN(I) = [M]PNDLIN(NOL)
        WPND_QTYSTU += [M]QTYSTU(I) - [M]XQTYSTU(I)
    Endif
Next I
WPND_QTYSTU -= [M]QTYSTU(NOL) - [M]XQTYSTU(NOL)
If [M]SAU(NOL)<>[M]STU(NOL)
    Call CNVQTY(WQTY,[M]SAUSTUCOE(NOL),[M]STU(NOL),WQTYSTU) From TRTVENQTE
Else
    WQTYSTU=WQTY
Endif
WPND_QTYSTU += WQTYSTU - [M]XQTYSTU(NOL)
Return


########################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL
NOL = nolign-1

#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0 and dim(GMODMSDGFORDEB)>0 and GMODMSDGFORDEB<>2
  If [M]CREFLG(NOL) <> 0 and !find(GREP,"C","D") and [F:SRH]EECNUMDEB>0
    If (VALEUR <> 0 and [M]QTY(NOL)=0) or ([M]QTY(NOL)<=[M]EXTQTY(NOL) and [M]QTY(NOL)<>VALEUR)
      Filter [F:DEB] Where EECNUMDEB=[F:SRH]EECNUMDEB and VCRNUM=[F:SRH]SRHNUM and CPY=[F:SRH]CPY
      Read [F:DEB]First
      If fstat : Raz [F:DEB] : Endif
      Filter [F:DEB]
      If [F:DEB]DEBDAT<>[0/0/0]
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB)-mess(98,107,1)-format$("DD2",[F:DEB]DEBDAT),0) From GESECRAN
      Else
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB),0) From GESECRAN
      Endif
      GMODMSDGFORDEB = 2
    Endif
  Endif
Endif
#--/

# -- calcul quantité en US
Call CNVQTY(VALEUR,[M]SAUSTUCOE(NOL),[M]STU(NOL), [M]QTYSTU(NOL)) From TRTVENQTE

# -- alimentation du déduit facture
If [M]XQTY(NOL) = 0 & VALEUR <> 0
   If  [M]SIHNUMFAC(NOL) = "" : [M]RTNINVUPD(NOL) = 2
   Else                         [M]RTNINVUPD(NOL) = 1
   Endif
   Affzo [M]RTNINVUPD(NOL)
Endif

End
########################################
Subprog AS_RTNSTOUPD(VALEUR)
Variable Integer VALEUR
Local    Integer NOL
NOL = nolign-1

# Pas de saisie du flag maj stock si article non géré en stock
If [M]STOMGTCOD(NOL)=1 mkstat=2 : End : Endif
# Pas de changement du flag maj stock si la ligne existait et qu'elle est déjà maj en stock
If [M]CREFLG(NOL) <> 0 & [M]RTNSTOUPD(NOL) = 2 & [M]YRTNSTOUPD(NOL) = 2 mkstat = 2 Endif
End
##########################################################################
## Etiquette ajoutée par le superviseur 18/07/2003 14:19:57 (LD)
##########################################################################
Subprog AM_RTNSTOUPD(VALEUR)
Variable Integer VALEUR
Local    Integer NOL : NOL=nolign-1
Local    Integer WRET

If VALEUR=2
    # La ligne était à l'état "non gérée en stock" : Ts les champs stock sont grizés
    # Elle passe à l'état "gérée en stock"         : Il faut diszoner les champs stocks

    #   Initialisation et grisage champs stock sur ligne document d'entrée
    #   si "U" Pas d'initialisation des unités et coefficients
    Call INIZONENT([M]ITMREF(NOL),"SRS1",[M]STOFCY,[M]BPCORD,2,"U",NOL,33,[M]TRSCOD,[M]SRHNUM,3,1) From STKECR
    If mkstat End : Endif

    Raz [M]WSTOFLG(NOL)
        [M]WSTOUPD(NOL)=1
    If [M:SRS1]DETSDHNUM(NOL)<>"" | [M:SRS1]PNHNUM(NOL)<>""
        If [F:SLT]STRNUM<>GFLAG Read [SLT]SLT0=8;GFLAG
                                If fstat Raz [F:SLT] Endif
        Endif
        # Lecture des mouvements de stock d'une ligne de document pour stockage dans écran de travail STOENTW
        Call STJSTOENTW("SRS1",33,13,[M:SRS0]RTNDAT,NOL,[M:SRS1]NBLIG,"SLT",3,WRET) From STKENT
        # WRET=1 : Erreur pour stockage dans ENTW : La ligne ne peut pas être créée
        # WRET=2 : Aucune ligne ds ENTW : Tt a déjà été retourné : Pas de ligne à créer (avoirs de facture)
        # WRET=4 : Il y a des lignes ENTW mais il y a aussi des mvts en attente : La ligne peut être créée
        # WRET=6 : Aucune ligne ds ENTW : Ts les mvts st en attente : La ligne ne peut pas être créée
        If WRET=4
            Call MESSAGE([M:SRS1]DETSDHNUM(NOL)-":"-[M:SRS1]ITMREF(NOL)-mess(152,191,1)) From GESECRAN
        Elsif WRET<>0
            #MAE, le 03/03/09, bg 52928
            If WRET=2
                Call ERREUR([M:SRS1]DETSDHNUM(NOL)-":"-[M:SRS1]ITMREF(NOL)-":"-mess(367,199,1)) From GESECRAN
            Endif
            If WRET=6
                Call ERREUR([M:SRS1]DETSDHNUM(NOL)-":"-[M:SRS1]ITMREF(NOL)-":"-mess(284,192,1)-"\"-mess(153,191,1)) From GESECRAN
            Endif
            mkstat=2 : End
        Endif
        Diszo [M:SRS1]SAU(NOL), QTY(NOL), SAUSTUCOE(NOL)
        #      Il faut désactiver les champs lot, n°série
        Call STKDISZONPIC("SRS1", NOL) From TRTVENSTK
    Endif
Else
    #   Pas de mise à jour des stock
    Call DELSTOENTW (NOL,NOL,"SRS1",1,1,[M:SRS0]STOFCY,1,"") From STKENT

    Raz [M]GESLOT(NOL), [M]WSTOSEQ(NOL), [M]WSTOFLG(NOL), [M]WSRUFLG(NOL), [M]WSTOUPD(NOL)
    Call STKRAZGRILIG("SRS1", NOL) From TRTVENSTK
    [M]WSTOFLG(NOL)=2 : # Article non géré en stock
Endif

End

