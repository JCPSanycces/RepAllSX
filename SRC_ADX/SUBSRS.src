Subprog AS_CCE14(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=14 : Gosub AS_CCEX
End

Subprog C_CCE14(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=14 : Gosub C_CCEX
End

Subprog D_CCE15(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=15 : Gosub D_CCEX
End

Subprog AS_CCE15(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=15 : Gosub AS_CCEX
End

Subprog C_CCE15(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=15 : Gosub C_CCEX
End

Subprog D_CCE16(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=16 : Gosub D_CCEX
End

Subprog AS_CCE16(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=16 : Gosub AS_CCEX
End

Subprog C_CCE16(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=16 : Gosub C_CCEX
End

Subprog D_CCE17(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=17 : Gosub D_CCEX
End

Subprog AS_CCE17(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=17 : Gosub AS_CCEX
End

Subprog C_CCE17(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=17 : Gosub C_CCEX
End

Subprog D_CCE18(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=18 : Gosub D_CCEX
End

Subprog AS_CCE18(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=18 : Gosub AS_CCEX
End

Subprog C_CCE18(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=18 : Gosub C_CCEX
End

Subprog D_CCE19(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=19 : Gosub D_CCEX
End

Subprog AS_CCE19(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=19 : Gosub AS_CCEX
End

Subprog C_CCE19(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=19 : Gosub C_CCEX
End

Subprog D_CCE20(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=20 : Gosub D_CCEX
End

Subprog AS_CCE20(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=20 : Gosub AS_CCEX
End

Subprog C_CCE20(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=20 : Gosub C_CCEX
End

$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE>GNBDIE Return : Endif
Call INIT_CCE(VALEUR,AXE,"SRSD","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,[M:SRS0]RTNDAT) From TRTX3CPT
Return

######################################################################################
########################################
#-------------------------------#
# Test de modification de ligne #
#-------------------------------#
$TEST_MOD_ANU

# --> pour supprimer cette ligne, il faut la désélectionner de la liste 'sélection livraison'
If [M:SRS1]DETSDHNUM(NOL)<>"" & [M:SRS1]CREFLG(NOL)=0
   GMESSAGE=mess(223,192,1) : mkstat=2 : Return
Endif

Return

#######################################################################

#########################################################################
# TRAITEMENTS LIES AU PICKING                                           #
#########################################################################

#########################################################################
# Actions de l'objet                                                    #
#########################################################################

#########################################################################
$HINT_KEY
Case currbox
 When GBOXSD2  : HINTLIS(val(right$(GBOXSD2,8)))="SDD3"
 When GBOXPN1  : HINTLIS(val(right$(GBOXPN1,8)))="PND2"
 When Default  : Return
Endcase
Return

#########################################################################
$TIROIR

ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
WPICK=2
Gosub RAFFRAICHI

Return
#########################################################################
$FILGAUCHE

If GFONC1 <> "GESSRS"
   If ILIS=0 adxmxl=0 Endif
Endif

Case currbox
 When GBOXSD2 : Gosub FILGAUCHE1
 When GBOXPN1 : Gosub FILGAUCHE2
 When Default : Return
Endcase

Return
#########################################################################
$FILGAUCHE1

If !find(currbox,GBOXSD2) Return Endif

If (GREP="" & !CLECUR)
   FILGAUSUP(0)='[F:SDD]BPCORD=""&[F:SDD]BPAADD=""&[F:SDD]ITMREF=""'
   Return
Endif

# Pour optimiser, on filtre sur le client même si celui-ci n'est pas renseigné
# --> on ne pourra picker un retour que lorsque le client aura été saisi
##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON = "BPCORD"
##   FILGAUSUP(0) ='[F:SDD]BPCORD=CZ'
##Else
##   FILGAUSUP(0) ='[F:SDD]BPCORD=[M:SRS0]BPCORD'
##Endif
FILGAUSUP(0) ='[F:SDD]BPCORD=[M:SRS0]BPCORD'

# Particularité pour [M]BPAADD : On le charge dans l'action APRES_MODIF
If [M:SRS0]BPAADD <> ""  FILGAUSUP(0)+='&[F:SDD]BPAADD=[M:SRS0]BPAADD'    Endif


# Les livraisons doivent être validées et de sous traitance
FILGAUSUP(1) ='&[F:SDH]CFMFLG=2&[F:SDH]SCO=2&[F:SDH]INVFLG<>2'
FILGAUSUP(1)+='&[F:SDD]QTY>[F:SDD]RTNQTY'

# Utilisation des critères de picking renseignés depuis l'option Critères picking
If [M:SRS0]CRIITMREF<>""      FILGAUSUP(1)+=' & [F:SDD]ITMREF =[M:SRS0]CRIITMREF' Endif
If [M:SRS0]CRISDHNUM<>""      FILGAUSUP(1)+=' & [F:SDH]SDHNUM =[M:SRS0]CRISDHNUM' Endif

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON = "STOFCY"
##   If CZ <> ""             FILGAUSUP(1)+='&[F:SDH]STOFCY=CZ'              Endif
##Else
##   If [M:SRS0]STOFCY <> "" FILGAUSUP(1)+='&[F:SDH]STOFCY=[M:SRS0]STOFCY'  Endif
##Endif
If [M:SRS0]STOFCY <> "" FILGAUSUP(1)+='&[F:SDH]STOFCY=[M:SRS0]STOFCY'  Endif

If [M:SRS0]BPCINV <> ""    FILGAUSUP(1)+='&[F:SDH]BPCINV=[M:SRS0]BPCINV'  Endif
If [M:SRS0]SALFCY <> ""    FILGAUSUP(1)+='&[F:SDH]SALFCY=[M:SRS0]SALFCY'  Endif



# X3-65724 (LC-14/02/18)   Filter in left picking list and row permission
#GBIDC3="" : Call FILROLE("SDH",GBIDC3) From SUBARL
#If GBIDC3<>"" FILGAUSUP(3)= "& " + GBIDC3 : Endif
#Raz FILSUITE,IFILSUITE # X3-88182 (LCC-06/08/18) Pagination on invoice picking list
Call AJOUTE_CONDITION_ROLE(FILSUITE,IFILSUITE,"SDH") From CRMUTIL150
# END X3-65724 (LC-14/02/18)   Filter in left picking list and row permission


#--CPO 71065 Code affaire
If [M]NBLIG > 0 | ([M]NBLIG = 0 & [M]PJT <> "")
  If GPJTSNGDOC = G_OUI Then
    FILGAUSUP(2)+='&[F:SDH]PJT=[M]PJT'
  Endif
Endif
#--/CPO
#--CPO 75115 Nouveaux champs SRHTYP et SRHCAT
If  [M]SRHCAT>0 & [M]SRHCAT<4
  FILGAUSUP(2)+='& [F:SDH]SDHCAT=[M]SRHCAT'
Endif
#--/CPO

Return

#########################################################################
#-----------------------------------------------------------------------#
# Filtre des enregistrements pour picking des retours fsseurs           #
#-----------------------
#------------------------------------------------#
$FILGAUCHE2


If !find(currbox,GBOXPN1) Return Endif

# On désactive le picking si pas en cours de traitement et aucun enregistrement
#                         ou si on est pas inter-site ou si on a pas de site de réception
#                         ou si on a déjà pické une ligne de livraison
If (GREP="" & !CLECUR) | [M:SRS1]BETFCY<>2 | [M:SRS0]PNHFCY="" | (sum([M:SRS1]DETSDHNUM)<>"" & sum([M:SRS1]PNHNUM)="")
   FILGAUSUP(0)='[F:PND]BPSNUM=""&[F:PND]ITMREF=""'
   FILGAUSUP(1)=""
   Return
Endif

# 91134
##le site de retour est le client livré (en inter site)
#If [M:SRS0]BPCORD <> ""
#    FILGAUSUP(0)='[F:PND]PNHFCY=[M:SRS0]BPCORD'
#Else
#    FILGAUSUP(0)='1=1'
#Endif
#le site de retour est le site réception rattaché au client livré (alimenté par ALIBETCPY)
FILGAUSUP(0)='[F:PND]PNHFCY=[M:SRS0]PNHFCY'
# 91134

# Utilisation des critères de picking renseignés depuis l'option Critères picking

If [M:SRS0]CRIITMREF<>""      FILGAUSUP(0)+=' & [F:PND]ITMREF =[M:SRS0]CRIITMREF' Endif
If [M:SRS0]CRIPNHNUM<>""      FILGAUSUP(0)+=' & [F:PNH]PNHNUM =[M:SRS0]CRIPNHNUM' Endif


# Les retours fournisseurs doivent être inter-sites et validés
FILGAUSUP(1) ='&[F:PNH]BETFCY=2 & [F:PNH]CFMFLG=2'

# les retours fournisseurs doivent être de type "retour de réception pour sous-traitance"
FILGAUSUP(1)+='&[F:PND]LINCAT=2 '

# Les lignes de retours fournisseurs ne doivent pas être déjà retournées
FILGAUSUP(1)+='&[F:PND]QTYSTU >[F:PND]SRDQTYSTU'

# Les lignes de retours fournisseurs doivent être issues d'un flux automatique (sinon, il faut picker la liv.)
FILGAUSUP(1)+='&[F:PND]LINAUTFLG<>1'

# Les lignes de retours fournisseurs doivent être issus d'une réception
FILGAUSUP(1)+='&[F:PND]PTHNUM<>"" & [F:PND]PTDLIN<>0 '

# Un retour concerne un seul site de vente donc un seul fournisseur
If [M:SRS0]BPSNUM <> ""       FILGAUSUP(1)+='&[F:PNH]BPSNUM=[M:SRS0]BPSNUM' Endif


# X3-65724 (LC-14/02/18)   Filter in left picking list and row permission
#GBIDC3="" : Call FILROLE("PNH",GBIDC3) From SUBARL
#If GBIDC3<>"" FILGAUSUP(3)= "& " + GBIDC3 : Endif
# Raz FILSUITE,IFILSUITE # X3-88182 (LCC-06/08/18) Pagination on invoice picking list
Call AJOUTE_CONDITION_ROLE(FILSUITE,IFILSUITE,"PNH") From CRMUTIL150
# END X3-65724 (LC-14/02/18)   Filter in left picking list and row permission


Return
#########################################################################
$AP_FILGAUCHE
Case currbox
 When GBOXSD2,GBOXPN1 : WPICK=2 : Gosub RAFFRAICHI
 When Default
Endcase
Return

#########################################################################
$DEB_PICK
Local Integer I, J, NOL
Local Char    SYMBOLE2(50)
Return

#########################################################################
$PICKE
If REP=""
   If !CLECUR | !VERROU | !ACTMOD | GCONSULT OK=0
      Return
   Endif
Endif

Case currbox
 When GBOXSD2 : Gosub SEL1
 When GBOXPN1 : Gosub SEL2
 When Default
Endcase

Return

#########################################################################
$DEPICK
Case currbox
 When GBOXSD2 : Gosub DESEL1
 When GBOXPN1 : Gosub DESEL2
 When Default
Endcase

Return

#########################################################################
$FIN_PICK
#--CPO 71065 Code affaire
Call PJT_INFO_MSG From TRTPJT

If REP=""
   If !VERROU
      GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return
   Elsif !CLECUR | !ACTMOD | GCONSULT
      GMESSAGE=mess(9,123,1)  : GERR=1 : OK=0 : Return
   Endif
Endif

Case currbox
   When GBOXSD2, GBOXPN1 :
       Affzo [M:SRS0]1-99 : Affzo [M:SRS1]1-99 : Affzo [M:SRS2]1-99
       Gosub ATT_ECRAN
       zonsui = "[M:SRS1]NBLIG("+num$(NOL)+")"
    When Default
Endcase

Return

#########################################################################
# Etiquettes de traitement                                              #
#########################################################################

#########################################################################
$ATT_ECRAN
If [M:SRS1]NBLIG = 0
   Actzo [M:SRS0]STOFCY, BPCORD, BPAADD
   Actzo [M:SRS0]SRHTYP                   :#--CPO 75115
Else
   Diszo [M:SRS0]STOFCY, BPCORD, BPAADD
   Diszo [M:SRS0]SRHTYP                   :#--CPO 75115
Endif
Return

#########################################################################
$REMPBOX

ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB

Return

#########################################################################
$SEL1
Local Decimal WQTYSAU, LQTYSTU
#--- Bug 78668
Local Char WWRH(GLONWRH), WWRHE(GLONWRH)
Local Char SWPJTMSG(250)  : # 71065 : PJT

Read [SDD]SDD0=[F:SDD]SDHNUM;[F:SDD]SDDLIN
If fstat
   Call RSTA("RSTA",[F:SDD]SDHNUM-num$([F:SDD]SDDLIN)) From GLOCK : OK=0 : Return
Endif
# Vérif. si la ligne n'a pas été retournée depuis le dernier raffraichissement de la liste de picking
If [F:SDD]QTY <= [F:SDD]RTNQTY
    GMESSAGE = [F:SDD]SDHNUM-":"-mess(27,159,1)-[F:SDD]ITMREF-":"-mess(251,192,1) : OK=0 : Return
Endif
Read [SDH]SDH0=[F:SDD]SDHNUM
If fstat
   Call RSTA("RSTA",[F:SDD]SDHNUM) From GLOCK : OK=0 : Return
Endif

# Date de livraison > date de retour
If [F:SDH]SHIDAT > [M]RTNDAT : # ACA - 48197 - date liv->date expé
   GMESSAGE = mess(328,192,1) : OK=0 : Return
Endif

# Si 1ère ligne, alimentation des zones d'entête
If [M]NBLIG = 0
#--- Alimentation des paramètres
   If [M:SRS0]STOFCY = ""
      #Call GETDEV([F:SDH]STOFCY) From DEVSUB
      # Chargement globales référenciels, comptes et sections de la société
      GFCY=[F:SDH]STOFCY : Gosub CHARG_PARAM
      Call GLOBSTOFCY([F:SDH]STOFCY) From TRTVENGLOB
      [M]STOFCY     = [F:SDH]STOFCY
   Endif
   Read [FCY]FCY0=[F:SDH]SALFCY
   If [F:FCY]LEGCPY <> GSOCIETE
      GERR=1 : GMESSAGE=[F:SDH]SDHNUM+"\"+mess(2,194,1)
      OK=0   : Return
   Endif
#    alim. GSOCIETE,GFINRSP,GLOCALDEV
   If [M:SRS0]SALFCY = ""
      #Call GETDEV([F:SDH]SALFCY) From DEVSUB
      # Chargement globales référenciels, comptes et sections de la société
      GFCY=[F:SDH]SALFCY : Gosub CHARG_PARAM
      Call GLOBVAR([F:SDH]SALFCY,"VEN") From TRTX3
      [M]SALFCY     = [F:SDH]SALFCY
   Endif
   #--CPO 71065 Code affaire sur les retours
   #--Pour ce qui est du PJT de l'en-tête
   [M:SRS2]PJT=[F:SDH]PJT
   If func TRTPJT.IS_PJT_AVAILABLE([F:SDH]PJT, "[M:SRS2]PJT",SWPJTMSG) = G_NON Then
     Raz  [M:SRS2]PJT
     Call PJT_ADD_MSG([F:SDH]PJT,SWPJTMSG) From TRTPJT
   Endif
   #--Contôle du PJT de la première ligne pickée
   #--Selon mail CH : ne pas contrôler
   #--/CPO
   [M]BPCORD     = [F:SDH]BPCORD
   [M]BPAADD     = [F:SDH]BPAADD
   [M]BPDNAM     = [F:SDH]BPDNAM
   [M]BPCINV     = [F:SDH]BPCINV
   [M]STOFCYDLV  = [F:SDH]STOFCY

   [M]EECICT     = [F:SDH]EECICT
   [M]ICTCTY     = [F:SDH]ICTCTY
   [M]FFWNUM     = [F:SDH]FFWNUM
   [M]FFWADD     = [F:SDH]FFWADD
   If dim([M]EECLOC)>0
       [M]EECLOC    = [F:SDH]EECLOC
       [M]EECTRN    = [F:SDH]EECTRN
       [M]BPIEECNUM = [F:SDH]BPIEECNUM
   Endif
#   Alimentation du nom client livré
   If [M]BPDNAM(0) = ""
#      -- recherche nom client livré
       If [F:BPD]BPCNUM <> [F:SDH]BPCORD | [F:BPD]BPAADD <> [F:SDH]BPAADD
           Read [BPD] BPD0 = [F:SDH]BPCORD;[F:SDH]BPAADD
       Endif
       [M]BPDNAM = [F:BPD]BPDNAM
   Endif
   # --- adresse livraison
   [M:ADB2]ADBBPR       = [F:SDH]BPCORD
   [M:ADB2]BPRNAM(0)    = [F:SDH]BPDNAM(0)
   [M:ADB2]BPRNAM(1)    = [F:SDH]BPDNAM(1)
   [M:ADB2]BPAADDLIG(0) = [F:SDH]BPDADDLIG(0)
   [M:ADB2]BPAADDLIG(1) = [F:SDH]BPDADDLIG(1)
   [M:ADB2]BPAADDLIG(2) = [F:SDH]BPDADDLIG(2)
   [M:ADB2]POSCOD       = [F:SDH]BPDPOSCOD
   [M:ADB2]CTY          = [F:SDH]BPDCTY
   [M:ADB2]SAT          = [F:SDH]BPDSAT
   [M:ADB2]CRY          = [F:SDH]BPDCRY
   [M:ADB2]CRYNAM       = [F:SDH]BPDCRYNAM
   [M:ADB2]CNTNAM       = [F:SDH]CNDNAM
   If [M:ADB2]BPRNAM <> "" |  [M:ADB2]BPAADDLIG <> "" |
&      [M:ADB2]POSCOD <> "" |  [M:ADB2]CTY <> "" |
&      [M:ADB2]SAT    <> "" |
&      [M:ADB2]CRY    <> "" |  [M:ADB2]CRYNAM <> ""
        [M:ADB2]ADBFLG = 3
   Else
        [M:ADB2]ADBFLG = 0
   Endif
   # Chargement des sections analytiques entête du document
   Call CHARG_CCEH("SRS2","NBAXE","SDH") From TRTX3CPT
   #FQ 65292
   #CPO - Problème découvert lors de la correction de cette fiche
   # On complète les sections vides
   If dim([M:SRS2]NBAXE)>0
      Local Integer I
      Local Char    SECTION
      [M:SRS2]NBAXE=GNBDIE
      For I=1 To GNBDIE
        If [M:SRS2]CCE(I-1)=""
          [M:SRS2]DIE(I-1)=GDIE(I)
          Call INISEC(SECTION,"SRS",GDIE(I)) From SUBCDE
          [M:SRS2]CCE(I-1)=SECTION
        Endif
      Next I
   Endif
   #fin FQ 65292
Else
   # Contrôle des conditions des regroupement
   Gosub CTL_LIV
   If OK=0 Return Endif
Endif

# Contrôle de l'insertion
If [M]NBLIG+1 >= dim([M]ITMREF)-1
   GERR=1 : GMESSAGE=mess(122,199,1)
   OK=0   : Return
Endif

SYMBOLE2 = "SDH"+[F:SDH]SDHNUM
Lock = SYMBOLE2
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[F:SDH]SDHNUM-":"-mess(10,100,1)
   OK=1   : Return
Endif

#--- Sélection correcte

# Ouverture de la ligne
nolign = [M]NBLIG
Insa nolign,1,[M]NBLIG [M]NBLIG
[M]NBLIG += 1
nolign = [M]NBLIG
NOL = nolign-1
status = 0
Call LINNUM("SRDLIN") From TABLEAUX

#--CPO 71065 Code affaire sur les retours
[M:SRS1]DPJT(NOL)=[F:SDD]PJT
#--/CPO

#-- Initialisation des zones de stock et ctrl si l'article est ok
Default Mask [SRS1]
#--CPO 82374 Pb abréviation passée "SRS1" et pas "SR1"
Call INIZONENT([F:SDD]ITMREF,"SRS1",[M]STOFCY,[M]BPCORD,2,"U", NOL,33,[M]TRSCOD,[M]SRHNUM,3,0) From STKECR
If mkstat
    Dela NOL,1,[M:SRS1]NBLIG-1 [M:SRS1]NBLIG : [M:SRS1]NBLIG-=1
    If [M]NBLIG=0 Raz [M]SALFCY Endif
    Unlock = SYMBOLE2 :  GERR=1 : OK=0 : Return
Endif

# -- alimentation du masque
[M]DETSDHNUM(NOL)  = [F:SDH]SDHNUM

#--- Bug 78668
If dim([M:SRS1]WRHE)>0 WWRHE=[M:SRS1]WRHE     Endif
If dim([M:SRS1]WRH)>0  WWRH =[M:SRS1]WRH(NOL) Endif
#---
[M:SRS1] = [F:SDD]
[M:SRS1] = [F:SDH]
#--- Bug 78668
If dim([M:SRS1]WRHE)>0 [M:SRS1]WRHE    =WWRHE Endif
If dim([M:SRS1]WRH) >0 [M:SRS1]WRH(NOL)=WWRH  Endif
#---
# -- qté restant en prêt
#[M]DLVQTY(NOL)     = [F:SDD]QTY - [F:SDD]RTNQTY
#[M]DLVQTYSTU(NOL)  = [F:SDD]QTYSTU - [F:SDD]RTNQTYSTU
#[M]QTY(NOL)        = [M]DLVQTY(NOL)
# -- calcul quantité en US
#Call CNVQTY([M]QTY(NOL),[M]SAUSTUCOE(NOL),[M]STU(NOL), [M]QTYSTU(NOL)) From TRTVENQTE

# -- Calcul qté restante en US
LQTYSTU             = [F:SDD]QTYSTU - [F:SDD]RTNQTYSTU
[M]DLVQTYSTU(NOL)   = LQTYSTU
[M]QTYSTU(NOL)      = LQTYSTU

# Bug 77101
If LQTYSTU=[F:SDD]QTYSTU
  # Qté restante =Qté livrée
  # -- Qté retour en UV = Qté livrée en UV
  [M]QTY(NOL)=[F:SDD]QTY
Else
  # Qté restants <Qté livrée
  # -- Recalcul de la qté restante en UV à partir de l'US
  # Si on tombe sur un chiffre rond ok sinon on met tout en US
  # Calcul de la qté en UV
  WQTYSAU=LQTYSTU / [M:SRS1]SAUSTUCOE(NOL)
  WQTY=WQTYSAU
  Call QTEARR(WQTY,[M:SRS1]SAU(NOL)) From TRTDIV
  If WQTYSAU=WQTY
      # On tombe sur un chiffre rond : ok
      [M:SRS1]QTY(NOL)=WQTYSAU
  Else
      # On ne tombe pas sur un chiffre rond : on met tout en US
      Gosub CONV_LIG_SAUSTU
  Endif
Endif
[M]DLVQTY(NOL)      = [M]QTY(NOL)

# -- Lecture article
If [F:ITM]ITMREF<>[M]ITMREF(NOL)
    Read [ITM]ITM0=[M]ITMREF(NOL)
    If fstat Call RSTA ("ITM",[M]ITMREF(NOL))  From GLOCK : Raz [F:ITM] : Endif
Endif
If [F:ITM]ITMREF<>[F:SRD]ITMREF | [F:ITU]BPCNUM<>[F:SRH]BPCORD
    Read [ITU]ITU0=[F:SRD]ITMREF;[F:SRH]BPCORD
    If fstat Raz [F:ITU] : Endif
Endif
Gosub ALI_DACSAUCOE

# Si l'article est géré en stock : on force la mise à jour des stocks
If [M]STOMGTCOD(NOL) > 1
   [M]RTNSTOUPD(NOL) = 2
Else
   [M]RTNSTOUPD(NOL) = 1
   [M]WSTOFLG(NOL)=2 : # Article non géré en stock
Endif
# Chargement sections analytiques
#Call CHARG_ACCCCE(NOL,"","","[M:SRS1]CCE",
#&                    "SDD",0,[F:SDD]SDHNUM,[F:SDD]SDDLIN,0,"") From TRTX3CPT

#FQ 65292
#CPO - Problème découvert lors de la correction de cette fiche
# -- Chargement sections analytiques
If [F:SDD]SDHNUM<>"" and [F:SDD]SDDLIN>0
    Call CHARG_ACCCCE(NOL,"","","[M:SRS1]CCE",
&                        "SDD",0,[F:SDD]SDHNUM,[F:SDD]SDDLIN,0,"") From TRTX3CPT
Endif
#fin FQ 65292
# -- Initialisation des sections analytiques vides
Local Integer I
Local Char    SECTION
For I=1 To GNBDIE
    If evalue("dim([M:SRS1]CCE"+num$(I)+"(NOL))") >0 & evalue("[M:SRS1]CCE"+num$(I)+"(NOL)")=""
        Call INISEC(SECTION, "SRSD", I) From TRTX3CPT
        Assign "[M:SRS1]CCE"+num$(I)+"(NOL)" With SECTION
    Endif
Next

Gosub CHARG_STOENTW

# Bug 75739
# Point d'entrée pour compléter l'alimentation de l'écran détail retour
GPOINT="ALIPICSRS" : Gosub ENTREE From EXEFNC

Return
#########################################################################################
$CHARG_STOENTW
Local Integer WRET

If [M:SRS1]STOMGTCOD(NOL)>1 & [M:SRS1]WSTOFLG(NOL)=0
    If [F:SLT]STRNUM<>GFLAG Read [SLT]SLT0=8;GFLAG
                            If fstat Raz [F:SLT] Endif
                            Endif
    # Lecture des mouvements de stock d'une ligne de document pour stockage dans écran de travail STOENTW
    Call STJSTOENTW("SRS1",33,13,[M:SRS0]RTNDAT,NOL,[M:SRS1]NBLIG,"SLT",3,WRET) From STKENT
    # WRET=1 : Erreur pour stockage dans ENTW : La ligne ne peut pas être créée
    # WRET=2 : Aucune ligne ds ENTW : Tt a déjà été retourné : Pas de ligne à créer (avoir sur facture)
    # WRET=4 : Il y a des lignes ENTW mais il y a aussi des mvts en attente : La ligne peut être créée
    # WRET=6 : Aucune ligne ds ENTW : Ts les mvts st en attente : La ligne ne peut pas être créée
    If WRET=4
        Call MESSAGE([M:SRS1]DETSDHNUM(NOL)-":"-[M:SRS1]ITMREF(NOL)-mess(152,191,1)) From GESECRAN
    Elsif WRET<>0
        #MAE, le 03/03/09, bg 52928
        If WRET=2
           Call ERREUR([M:SRS1]DETSDHNUM(NOL)-":"-[M:SRS1]ITMREF(NOL)-":"-mess(367,199,1)) From GESECRAN
        Endif
        If WRET=6
            Call ERREUR([M:SRS1]DETSDHNUM(NOL)-":"-[M:SRS1]ITMREF(NOL)-":"-mess(284,192,1)-"\"-mess(153,191,1)) From GESECRAN
        Endif
        Dela NOL,1,[M:SRS1]NBLIG-1 [M:SRS1]NBLIG : [M:SRS1]NBLIG-=1
        If [M]NBLIG=0 Raz [M]SALFCY Endif
        Case currbox
            When GBOXSD2 : SYMBOLE2 = "SDH"+[F:SDD]SDHNUM
                           Unlock = SYMBOLE2

            When GBOXPN1 : SYMBOLE2 = "PNH"+[F:PNH]PNHNUM
                           Unlock = SYMBOLE2
                           If [F:SDH]SDHNUM<>""
                               SYMBOLE2 = "SDH"+[F:SDH]SDHNUM
                               Unlock = SYMBOLE2
                           Endif
        Endcase
        GERR=1 : OK=0 : Return
    Endif
Endif

# Bug 75739
## Point d'entrée pour compléter l'alimentation de l'écran détail retour
#GPOINT="ALIPICSRL" : Gosub ENTREE From EXEFNC

Return
#########################################################################
$DESEL1
Local Integer I, J, SNOL
Raz I, J, SNOL
OK = 0
If [M]NBLIG <> 0
   While OK <> 1
      I = find([F:SDD]SDHNUM,[M]DETSDHNUM(J..[M]NBLIG-1))
      If !I Break Endif
      If [M]CREFLG(J+I-1)=0 & [F:SDD]SDDLIN=[M]SDDLIN(J+I-1)
         SNOL = J+I-1
         Dela SNOL,1,[M]NBLIG-1 [M]NBLIG
         [M]NBLIG -= 1
         If [M]NBLIG=0 Raz [M]SALFCY Endif
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif

# Si suite à désélection de la ligne, il n'y a plus de ligne sélectionnée
# sur cette livraison, il faut la débloquer
Raz I,J
OK = 2
If [M:SRS1]NBLIG <> 0
   While OK <> 1
      I = find([F:SDD]SDHNUM,[M:SRS1]DETSDHNUM(J..[M:SRS1]NBLIG-1))
      If !I Break Endif
      If [M:SRS1]CREFLG(J+I-1)=0
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif
If OK = 2
   # Unlock entête livraison
   SYMBOLE2 = "SDH"+[F:SDD]SDHNUM
   Unlock = SYMBOLE2
Endif

Return

#########################################################################
$CTL_LIV
Local Char SWPJTMSG(250)  : # 71065 : PJT
#---------------------------------------------------------------------------------------#
# Contrôle de la ligne livraison sélectionnée                                           #
# Elle doit être cohérente par rapport aux autres lignes sélectionnées                  #
#---------------------------------------------------------------------------------------#
If [F:SDH]BPCORD<>[M]BPCORD | [F:SDH]BPAADD<>[M]BPAADD
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF+"\"+mess(187,192,1)+"\"+mess(224,192,1)
   Return
Endif
If [F:SDH]BPCINV<>[M]BPCINV
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF+"\"+mess(187,192,1)+"\"+mess(101,191,1)
   Return
Endif
If [F:SDH]SALFCY<>[M]SALFCY
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF+"\"+mess(187,192,1)+"\"+mess(103,192,1)
   Return
Endif
If [F:SDH]PLISTC<>[M]PLISTC
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SOHNUM-mess(27,159,1)-[F:SDD]ITMREF+"\"+mess(187,192,1)+"\"+mess(305,192,1)
   Return
Endif
#--- CPO 72237 Le champ BPIEECNUM est soumis à code activité
#If [F:SDH]BPIEECNUM<>[M]BPIEECNUM | [F:SDH]EECICT<>[M]EECICT
If (dim([M]BPIEECNUM)>0 & [F:SDH]BPIEECNUM<>[M]BPIEECNUM) | [F:SDH]EECICT<>[M]EECICT
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF+"\"+mess(187,192,1)+"\"+mess(303,192,1)
   Return
Endif
If dim([M]EECLOC)>0 & [F:SDH]EECLOC<>[M]EECLOC
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF+"\"+mess(187,192,1)+"\"+mess(304,192,1)
   Return
Endif
#--CPO 71065 - Code affaire à la ligne (Partie : rajout paramètre société pour contrôle documents mono-affaire)
If func TRTPJT.IS_PJT_AVAILABLE([F:SDD]PJT, "[M:SRS1]DPJT",SWPJTMSG) = G_NON Then
  Call PJT_ADD_MSG([F:SDD]PJT,SWPJTMSG) From TRTPJT
  OK = 0
  Return
Endif
#--/CPO
Return
#########################################################################
$RAFFRAICHI
#-----------------------------------------------------------------------#
# Raffraichissement des listes de picking pour les lignes déjà saisies  #
#-----------------------------------------------------------------------#

Case currbox
    When GBOXSD2 :
        If sum([M:SRS1]SDDLIN) <> 0
           For I=0 To [M:SRS1]NBLIG-1
              # La ligne est issue d'un picking livraison réalisé au cours de cette transaction
            If [M:SRS1]DETSDHNUM(I) <> "" & [M:SRS1]CREFLG(I) = 0
                Read [SDD]SDD0=[M:SRS1]DETSDHNUM(I);[M:SRS1]SDDLIN(I)
              # MAE bg 53149 Endif
             If    WPICK=1 Gosub DEPICK From GOBJSUB
             Elsif WPICK=2 Gosub REPICK From GOBJSUB
             Endif
            Endif
           Next I
       Endif
    When GBOXPN1 :
        If sum([M:SRS1]PNDLIN)<>0
                   For I=0 To [M:SRS1]NBLIG-1
                      # Ligne issue d'un picking retour fsseur réalisé au cours de cette transaction
                      If [M:SRS1]PNHNUM(I)<>"" & [M:SRS1]CREFLG(I)=0
                         Read [PND]PND0=[M:SRS1]PNHNUM(I);[M:SRS1]PNDLIN(I)
                         If    WPICK=1 Gosub DEPICK From GOBJSUB
                         Elsif WPICK=2 Gosub REPICK From GOBJSUB
                         Endif
                      Endif
                   Next I
                Endif
     When Default
Endcase
Return
##########################################################################


##########################################################################
##########################################################################
#     ETIQUETTES APPELEES PAR LES COMPOSANTS D'ENTREE EN STOCK
##########################################################################
#########################################################################
# Bouton Détail  en click droit sur NBLIG  Action SAISTOENT             #
# Fenêtre Détail en APRES_NBLIG            Action SAISTOENT             #
#########################################################################
# ETIQUETTES APPELEES PAR TRTSTOENTA                                    #
#########################################################################
#-----------------------------------------------------------------------#
# Appelée dans CHARG_PARAM_STOENT                                       #
# Chargement Ecran STOENT (partie parametrage) creations des entrées    #
#-----------------------------------------------------------------------#
Subprog CHARG_PARAM_STOENT (LLIG)
Value Integer LLIG
[M:ENT]STOFCY    = [M:SRS0]STOFCY
[M:ENT]ITMREF    = [M:SRS1]ITMREF(LLIG)
[M:ENT]QTYTOENT  = [M:SRS1]QTY(LLIG)
[M:ENT]PCUTOENT  = [M:SRS1]SAU(LLIG)
[M:ENT]COETOENT  = [M:SRS1]SAUSTUCOE(LLIG)
[M:ENT]STU       = [M:SRS1]STU(LLIG)
[M:ENT]VCRNUM    = [M:SRS0]SRHNUM
[M:ENT]VCRLIN    = [M:SRS1]SRDLIN(LLIG)
[M:ENT]WSTOSEQ   = [M:SRS1]WSTOSEQ(LLIG)
[M:ENT]MVTDES    = [M:SRS1]MVTDES(LLIG)
[M:ENT]PRI       = [M:SRS1]PRIORD(LLIG)
[M:ENT]QUAFLG    = [M:SRS1]QUAFLG(LLIG)        # hcb V6CQ
[M:ENT]QUAFRE    = [M:SRS1]QUAFRE(LLIG)        # hcb V6CQ
If dim([M:SRS1]WRH)>0
  [M:ENT]XWRH    = [M:SRS1]WRH(LLIG)
Endif
[M:ENT]TRSTYP    = 33                          : # Type mouvement (M.704)
[M:ENT]TRSCOD    = [M:SRS0]TRSCOD              : # code mouvement
[M:ENT]TRSFAM    = [M:SRS2]TRSFAM
[M:ENT]IPTDAT    = [M:SRS0]RTNDAT              : # Date imputation
[M:ENT]BPRNUM    = [M:SRS0]BPCORD

[M:ENT]SRGWAIFLG = GSLTSRGWAIFLG
[M:ENT]PRNCOD1   = GSLTPRNCOD1
[M:ENT]PRNNBFLG1 = GSLTPRNNBFLG1
[M:ENT]CCECODS   = GSTODIE

If [M:SRS1]PNHNUM(LLIG) <> ""
    [M:ENT]VCRTYPORI = 8
    [M:ENT]VCRNUMORI = [M:SRS1]PNHNUM(LLIG)
    [M:ENT]VCRLINORI = [M:SRS1]PNDLIN(LLIG)
    [M:ENT]STOFCYORI = [M:SRS0]PNHFCY
    GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
Elsif [M:SRS1]DETSDHNUM(LLIG) <> ""
    [M:ENT]VCRTYPORI = 4
    [M:ENT]VCRNUMORI = [M:SRS1]DETSDHNUM(LLIG)
    [M:ENT]VCRLINORI = [M:SRS1]SDDLIN(LLIG)
    If [F:SDH]SDHNUM <> [M:SRS1]DETSDHNUM(LLIG)
        Read [SDH]SDH0=[M:SRS1]DETSDHNUM(LLIG)
        If fstat Raz [F:SDH] Endif
    Endif
    [M:ENT]STOFCYORI = [F:SDH]STOFCY
    GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
Else
    GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
Endif
[M:ENT]BPRNUM = [M:SRS0]BPCORD
[M:ENT]FILLOCENT="[F:TLO]LOCCAT<>3"
End
#-----------------------------------------------------------------------#
# Appelée dans MAJ_LIGNE_DOCUMENT                                       #
# Chargement Ecran STOENT (partie parametrage) creations des entrées    #
# Donne la main pour maj ligne du document, et grise les champs stock   #
# LPCU    : Unité utilisée dans le détail                               #
# LCOEF   : Coefficient utilisé dans  le détail                         #
# LQTYSTU : Qté en US à répercuter dans le doc                          #
#-----------------------------------------------------------------------#
$MAJ_LIG_SRS
Local Decimal WQTYSAU, WQTY

Local Integer NOL : NOL=LLIGDOC
If !find(GACTION, "SAISTOENT","SAISTOENTM") Return Endif    # hcb 110327
#--- Cas de la suppression : 24/11/03 (tests HN)
If LQTYSTU=0
  If [M:SRS1]CREFLG(NOL)<>0
    [M:SRS1]QTY(NOL)=0
    [M:SRS1]QTYSTU(NOL)=0
    Return
  Elsif [M:SRS1]CREFLG(NOL)=0
    Raz [M:SRS1]WSTOFLG(NOL) : Grizo [M:SRS1]QTY(NOL)
  Endif
Endif
# Dans la fenêtre détail : l'unité ou le coefficient UV-US ou la qté sont différents du document d'origine
# Si la qté en US est modifiée report sur la ligne document origine
If LQTYSTU<>[M:SRS1]QTYSTU(LLIGDOC)
    If LCOEF<>0
    # -- Coef. unique sur toutes les lignes
        If LPCU=[M:SRS1]SAU(LLIGDOC)
        # -- L'entrée a été saisie dans l'unité du document (UV) : On récalcule la qté retour en UV
            If LCOEF=[M:SRS1]SAUSTUCOE(LLIGDOC)
                [M:SRS1]QTY(LLIGDOC)=LQTYSTU / LCOEF
                [M:SRS1]QTYSTU(LLIGDOC)=LQTYSTU
            Else
                # Le coefficient a été modifié
                If [M:SRS1]DACSAUCOE(LLIGDOC)=2
                    # Il est modifiable       : Il est répercuté
                    [M:SRS1]QTY(LLIGDOC)=LQTYSTU / LCOEF
                    [M:SRS1]QTYSTU(LLIGDOC)=LQTYSTU
                    [M:SRS1]SAUSTUCOE(LLIGDOC)=LCOEF
                    # Recalcul de l'ancienne qté retour avec le nvx coefficient
                    WQTY=[M:SRS1]XQTYSTU(LLIGDOC) / LCOEF
                    Call QTEARR(WQTY, [M:SRS1]SAU(LLIGDOC)) From TRTDIV
                    [M:SRS1]XQTY(LLIGDOC)= WQTY
                    # Recalcul de la qté livrée avec le nvx coefficient
                    WQTY=[M:SRS1]DLVQTYSTU(LLIGDOC) / LCOEF
                    Call QTEARR(WQTY, [M:SRS1]SAU(LLIGDOC)) From TRTDIV
                    [M:SRS1]DLVQTY(LLIGDOC)= WQTY
                Else
                    # -- Il n'est pas modifiable : Il n'est pas répercuté
                    #    On recalcule la qté retour ds l'unité du document(UV)
                    #    Si on tombe sur un chiffre rond ok sinon on met tout en US
                    Gosub RECALC_QTYSAU
                Endif
            Endif
        Else
            # -- L'entrée a été saisie en US ou ds une autre unité
            #    On recalcule la qté retour ds l'unité du document(UV)
            #    Si on tombe sur un chiffre rond ok sinon on met tout en US
            Gosub RECALC_QTYSAU
        Endif
    Else
    # -- Coef. non unique sur toutes les lignes : on met tout en US
         Gosub CONV_LIG_SAUSTU
    Endif
    Affzo [M:SRS1]SAU(LLIGDOC), QTY(LLIGDOC), DLVQTY(LLIGDOC), SAUSTUCOE(LLIGDOC)
Endif

If [M:SRS1]SAU(LLIGDOC)=[M:SRS1]STU(LLIGDOC)
  Affzo [M:SRS1]SAUSTUCOE(LLIGDOC) : # pb diszo
  Diszo [M:SRS1]SAUSTUCOE(LLIGDOC)
  Affzo [M:SRS1]SAUSTUCOE(LLIGDOC) : # pb diszo
Endif

Return


$RECALC_QTYSAU
# ------------------------------------------------------------- #
# Recalcul de la qté retour ds l'unité du document (UV)         #
#    Si on tombe sur un chiffre rond ok sinon on met tout en US #
# ------------------------------------------------------------- #
# Calcul de la qté en UV
WQTYSAU=LQTYSTU / [M:SRS1]SAUSTUCOE(LLIGDOC)
WQTY=WQTYSAU
Call QTEARR(WQTY,[M:SRS1]SAU(LLIGDOC)) From TRTDIV
If WQTYSAU=WQTY
    # On tombe sur un chiffre rond : ok
    [M:SRS1]QTY(LLIGDOC)=WQTYSAU
    [M:SRS1]QTYSTU(LLIGDOC)=LQTYSTU
Else
    # On ne tombe pas sur un chiffre rond : on met tout en US
    Gosub CONV_LIG_SAUSTU
Endif
Return
# ------------------------------------------------------------- #
# Passage de la ligne retour en US                              #
# --> L'UV devient l'US                                         #
# --> La qté en UV devient la qté en US                         #
# --> Conversion en US toutes les quantités qui étaient en UV   #
# --> Le coef. UV-US est forcé à 1                              #
# ------------------------------------------------------------- #
$CONV_LIG_SAUSTU
[M:SRS1]QTYSTU(NOL)=LQTYSTU
[M:SRS1]SAU(NOL)=[M:SRS1]STU (NOL)
[M:SRS1]QTY(NOL)=LQTYSTU
# Il faut reconvertir en US toutes les quantités qui étaient en UV
[M:SRS1]XQTY(NOL)   =[M:SRS1]XQTY(NOL)*[M:SRS1]SAUSTUCOE(NOL)
[M:SRS1]DLVQTY(NOL) =[M:SRS1]DLVQTY(NOL)*[M:SRS1]SAUSTUCOE(NOL)
#
[M:SRS1]SAUSTUCOE(NOL)=1
Return
#########################################################################
# ETIQUETTES APPELEES PAR TRTSTOENTB                                    #
#########################################################################
#-----------------------------------------------------------------------#
# Appelée dans CTL_LIGNE_DOCUMENT                                       #
# Donne la main pour effectuer avant stockage dans STOENTW:             #
#  - contrôles de quantités                                             #
#  - affectation diverses                                               #
# En cas d'erreur, donner une valeur différente de 0 à mkstat           #
# Attention : Il est de la responsabilité de chaque document d'afficher #
#             les messages d'erreurs.                                   #
# Variables disponibles :                                               #
# LQTYSTU = Quantité totale en unité de stock des lignes de détail      #
# LPCU    = Unité utilisée dans le détail si unique sinon ""            #
# LCOEF   = Coefficient UC/US si unique sinon ""                        #
#-----------------------------------------------------------------------#
$CTL_LIG_SRS
#------------------------------------------#
# Contrôle au sortir de la saisie de stock #
# ou modif de stock                        #
#------------------------------------------#
If dim(NOL)<0       : Local Shortint NOL       : Endif
If dim(TRTLIG)<0    : Local Char     TRTLIG(1) : Endif
If dim(SVGNOL)<0    : Local Integer  SVGNOL    : Endif
If !find (GACTION,"SAISTOENT","SAISTOENTM") Return Endif           # hcb 110327
Local Integer OK
Local Decimal WRTNQTYSTU, WEXTQTYSTU
SVGNOL=nolign : # Sauvegarde du nolign ecran stock
NOL=LLIGDOC
nolign=NOL+1
NEWQTE =LQTYSTU
# Modification de la quantité
If LQTYSTU>0 & LQTYSTU<>[M:SRS1]QTYSTU(NOL)
    If [M:SRS1]DETSDHNUM(NOL) <> ""
        # -- Quantité retour > quantité livrée ?
        If LQTYSTU - [M:SRS1]XQTYSTU(NOL) > [M:SRS1]DLVQTYSTU(NOL)
           GMESSAGE = mess(64,192,1) : mkstat = 2 : Return
        Endif
    Endif
#controle sur la quantité du retour fournisseur
    If [M:SRS1]PNHNUM(NOL)<>""
    # -- Quantité retour > quantité retour fournisseur ?
        If LQTYSTU - [M:SRS1]XQTYSTU(NOL) > [M:SRS1]PNDQTYSTU(NOL)
           GMESSAGE = mess(275,192,1) : mkstat = 2 : Return
        Endif
    Endif
Endif
# Contrôle du stock retourné
If [M:SRS1]DETSDHNUM(NOL)<>"" | [M:SRS1]PNHNUM(NOL)<>""
    Call CTR_STK_RETCLI(OK) From STKENT
    If OK mkstat = 2 : Return Endif
Endif

If [M:SRS1]CREFLG(NOL)<>0
  #-- Si la quantité est à 0 (suppression de ligne)
  If LQTYSTU = 0
    TRTLIG="A" : status=65
  Else
    TRTLIG="M" : status=75
  Endif
#  Gosub TEST_MOD_ANU
#  If mkstat Call ERREUR(GMESSAGE) From GESECRAN : nolign=SVGNOL : Return : Endif
Endif
nolign=SVGNOL
Return
#########################################################################
# ETIQUETTES APPELEES PAR TRTSTOENMA                                    #
#########################################################################
#-----------------------------------------------------------------------#
# Appelée dans CHARG_PARAM_STOENTM                                      #
# Chargement Ecran STOENTM (partie parametrage) modification des entrées#
#-----------------------------------------------------------------------#
Subprog CHARG_PARAM_STOENTM (LLIG)
Value Integer LLIG

If LLIG<>999999
  [M:ENM]STOFCY   = [M:SRS0]STOFCY
  [M:ENM]ITMREF   = [M:SRS1]ITMREF(LLIG)
  [M:ENM]QTYTOENT = [M:SRS1]QTY(LLIG)
  [M:ENM]PCUTOENT = [M:SRS1]SAU(LLIG)
  [M:ENM]COETOENT = [M:SRS1]SAUSTUCOE(LLIG)
  [M:ENM]STU      = [M:SRS1]STU(LLIG)
  [M:ENM]VCRNUM   = [M:SRS0]SRHNUM
  [M:ENM]VCRLIN   = [M:SRS1]SRDLIN(LLIG)
  [M:ENM]MVTDES   = [M:SRS1]MVTDES(LLIG)
  [M:ENM]QUAFLG   = [M:SRS1]QUAFLG(LLIG)        # hcb V6CQ
  [M:ENM]QUAFRE   = [M:SRS1]QUAFRE(LLIG)        # hcb V6CQ
  If dim([M:SRS1]WRH)>0
    [M:ENM]XWRH   = [M:SRS1]WRH(LLIG)
  Endif
  [M:ENM]PJT      = ""
  [M:ENM]TRSTYP   = 33                   : # Type mouvement (M.704)
  [M:ENM]TRSCOD   = [M:SRS0]TRSCOD       : # Code mouvement
  [M:ENM]TRSFAM   = [M:SRS2]TRSFAM
  [M:ENM]BPRNUM   = [M:SRS0]BPCORD
  If dim([M:SRS1]BETCPY)>0 : [M:ENM]BETCPY = [M:SRS1]BETCPY : Endif
     :
  If [M:SRS1]DETSDHNUM (LLIG)<> "" | [M:SRS1]PNHNUM (LLIG)<> ""
      GSAIFLG="000000020000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
  Else
      GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
  Endif
Else : # Cas de la suppression
# ???
  [M:ENM]STOFCY   = [F:SRD]STOFCY
  [M:ENM]ITMREF   = [F:SRD]ITMREF
  [M:ENM]QTYTOENT = [F:SRD]QTY
  [M:ENM]PCUTOENT = [F:SRD]SAU
  [M:ENM]COETOENT = [F:SRD]SAUSTUCOE
  [M:ENM]STU      = [F:SRD]STU
  [M:ENM]VCRNUM   = [F:SRD]SRHNUM
  [M:ENM]VCRLIN   = [F:SRD]SRDLIN
  [M:ENM]MVTDES   = ""
  [M:ENM]PJT      = ""
  [M:ENM]TRSTYP   = 33                   : # Type mouvement (M.704)
  [M:ENM]TRSCOD   = [F:SRH]TRSCOD        : # Code mouvement
  [M:ENM]TRSFAM   = [F:SRH]TRSFAM
  [M:ENM]BPRNUM   = [F:SRH]BPCORD
  [M:ENM]BETCPY   = [F:SRH]BETCPY
  If [F:SRD]SDHNUM <> "" | [F:SRD]PNHNUM <> ""
      GSAIFLG="000000020000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
  Else
      GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
  Endif
Endif
[M:ENM]FILLOCENT="[F:TLO]LOCCAT<>3"
[M:ENM]SRGWAIFLG = GSLTSRGWAIFLG
[M:ENM]PRNCOD1   = GSLTPRNCOD1
[M:ENM]PRNNBFLG1 = GSLTPRNNBFLG1
End
#-----------------------------------------------------------------------#
# Appelée dans MAJ_MODIFICATION_LIGNE                                   #
# Mise à jour du document origine suite à modifications                 #
# le masque du document origine est chargé avec les nouvelles valeurs   #
#-----------------------------------------------------------------------#
########################################
$TRT_MAJ_DOCUMENT
Local Integer LOK

If dim(NOL)<0 :  Local Shortint NOL: Endif
If dim(TRTLIG)<0 Local Char    TRTLIG(1) : Endif

Local Char       SYMBOLE2(50)
Local Shortint   WSUPP
Local Integer    SIGN, WSTAT, SAVNOLIGN, I, OK, WSRDLIN, WRETOUR
Local Decimal    WLIVTTC, DELTAQTY, DELTAQTYSTU

NOL=LLIGDOC
nolign=NOL+1
WSRDLIN=[M:SRS1]SRDLIN(NOL)

Raz WSUPP, WLIVTTC
# Mise à jour des quantités
Gosub MAJ_LIG_SRS
If [M:SRS1]QTYSTU(NOL)=0
    TRTLIG="A"
    # Si la ligne doit être supprimée, on regarde s'il y en a d'autre sur le retour
    # pour déterminer si l'entête retour doit être supprimée
    Filter [SRD] Where SRHNUM=[M:SRS0]SRHNUM & SRDLIN<>[M:SRS1]SRDLIN(NOL)
&                Order By Key SRD0
    Read [SRD]SRD0 First
    If fstat WSUPP = 1 Endif
    Filter [SRD]
Else
    TRTLIG="M"
Endif

#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0 and dim(GMODMSDGFORDEB)>0 and GMODMSDGFORDEB<>2
  If !find(GREP,"C","D") and [F:SRH]EECNUMDEB>0
      Filter [F:DEB] Where EECNUMDEB=[F:SRH]EECNUMDEB and VCRNUM=[F:SRH]SRHNUM and CPY=[F:SRH]CPY
      Read [F:DEB]First
      If fstat : Raz [F:DEB] : Endif
      Filter [F:DEB]
      If [F:DEB]DEBDAT<>[0/0/0]
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB)-mess(98,107,1)-format$("DD2",[F:DEB]DEBDAT),0) From GESECRAN
      Else
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB),0) From GESECRAN
      Endif
      GMODMSDGFORDEB = 2
  Endif
Endif
#--/

# --- Contrôles OK, suite de la mise à jour
If [M:SRS1]QTYSTU(NOL)=0
  status=65 : nolign=NOL+1
  Dela NOL,1,[M:SRS1]NBLIG-1 [M:SRS1]NBLIG : [M:SRS1]NBLIG-=1
Endif

# --- Lecture de l'entête retour
If WSUPP = 1
   Readlock [SRH]SRH0=[M:SRS0]SRHNUM
Else
   Read [SRH]SRH0=[M:SRS0]SRHNUM
Endif
If fstat = 1 GOK = -1
   GLOCK = "$SRETURN"-[M:SRS0]SRHNUM : Return
Elsif fstat  GOK =  0
   Call RSTA ("SRH",[M:SRS0]SRHNUM) From GLOCK : Return
Endif


#-- Maj du détail retour
Readlock [SRD]SRD0=[M:SRS0]SRHNUM;WSRDLIN
If fstat = 1 GOK = -1
   GLOCK = "$SRETURND"-[M:SRS0]SRHNUM-num$(WSRDLIN)
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SRD",[M:SRS0]SRHNUM-num$(WSRDLIN)) From GLOCK
   Return
Endif
SIGN=-1
#----- Mise à jour statistiques ligne retour -----#
Call VALSTA ("SRD",SIGN) From SUBPS2
If GOK<1 : Return : Endif

If TRTLIG="A"
  #FQ 65292
  #----- Mise à jour de CPTANALIN -----#
  Gosub MAJSRD_CPTANALIN
  #fin FQ 65292
  DELTAQTY    = -1 * [F:SRD]QTY
  DELTAQTYSTU = -1 * [F:SRD]QTYSTU
  #-- Suppression de la ligne de retour
  Delete [SRD] Where SRHNUM=[M:SRS0]SRHNUM & SRDLIN=WSRDLIN
  If fstat GOK=0 : Call FSTA("SRD") From GLOCK : Return : Endif
Else
  DELTAQTY    = [M]QTY(NOL)    - [M]XQTY(NOL)
  DELTAQTYSTU = [M]QTYSTU(NOL) - [M]XQTYSTU(NOL)

  [F:SRD]QTY=[M:SRS1]QTY(NOL)
  [F:SRD]QTYSTU=[M:SRS1]QTYSTU(NOL)
  [F:SRD]SAU=[M:SRS1]SAU(NOL)
  [F:SRD]SAUSTUCOE=[M:SRS1]SAUSTUCOE(NOL)
  [F:SRD]DLVQTY=[M:SRS1]DLVQTY(NOL)
  SIGN=1
  #-- Réécriture de la ligne de retour
  Rewrite [SRD]
  If fstat GOK=0 : Call FSTA("SRD") From GLOCK : Return : Endif
  #----- Mise à jour statistiques ligne retour -----#
  Call VALSTA ("SRD",SIGN) From SUBPS2
  If GOK<1 : Return : Endif
Endif

#----- Si tout s'est bien déroulé -----#
If GOK = 1
  GRELITSRS = 1
Endif

# Maj de la livraison correspondante
If [F:SRD]SDHNUM <> "" & DELTAQTYSTU <> 0
   Local Integer WMAJ_LIV : WMAJ_LIV=1
   Gosub LEC_LIV
   If GOK < 1 Return Endif
   If WMAJ_LIV = 1
       Local Decimal WCNVDELTAQTY
       Gosub CONV_DELTAQTY
       Gosub MAJLIV
       If GOK < 1 Return Endif
       If [F:SDH]SIHNUM = ""
#          WLIVTTC += DELTAQTY * [F:SDD]NETPRIATI
          WLIVTTC += WCNVDELTAQTY * [F:SDD]NETPRIATI
       Endif
    Endif
Endif

# Maj du retour correspondant
If [F:SRD]PNHNUM <> "" & DELTAQTYSTU <> 0
   Local Integer WMAJ_PNH : WMAJ_PNH=1
   Gosub LEC_PNH
   If GOK < 1 Return Endif
   If WMAJ_PNH = 1
       Local Decimal WCNVDELTAQTY
       If TRTLIG="A"
           # Pour recherche dernier n°retour vente d'une ligne retour fsseur
           If clalev([F:SRD1])=0 Local File SRETURND [SRD1] Endif
       Endif
       Gosub MAJPND
       If GOK < 1 Return Endif
       If sum([M:SRS1]PNDLIN)<>0 & TRTLIG="A"
           Close Local File [SRD1]
           Default File [SRH]
       Endif
       If [F:SDH]SIHNUM = ""
#          WLIVTTC += DELTAQTY * [F:SDD]NETPRIATI
          WLIVTTC += WCNVDELTAQTY * [F:SDD]NETPRIATI
       Endif
    Endif
    Unlock [PNH] : Unlock [PND]
Endif


If WSUPP=1 Delete  [SRH] : Endif
If fstat GOK=0 : Call FSTA("SRH") From GLOCK : Return : Endif

WSENS = "-"
# Bug 52920 : Pas de maj mvt client pour les retours sous-traitance
# Maj du livré en prêt
#If WLIVTTC <> 0
#   Call MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY,
#&               0, WLIVTTC, WSENS, "D", "", [F:SDH]LND) From TRTBPMVT
#   If GOK < 1 Return Endif
#Endif
Return

##########################################################################
#########################################################################
# SRSINIZONENT                                                          #
#    Appelé en AVANT-NBLIG en modification d'une ligne de retour        #
#                                                                       #
#    - Lecture des tables articles                                      #
#    - Lecture de la règle de gestion à appliquer                       #
#    - Si ligne non créée ou créée mais elle devient gérée en stock     #
#         Si ligne gérée en stock :                                     #
#            Désactivation lot, n° série                                #
#    - Si ligne déjà créée :                                            #
#         Si ligne non gérée en stock :                                 #
#            Grisage des champs stock                                   #
#         Si ligne gérée en stock     :                                 #
#            Désactivation des champs stock                             #
#                                                                       #
#                                                                       #
#########################################################################
Subprog SRSINIZONENT
Local Integer NOL : NOL=nolign-1

If [M:SRS1]STOMGTCOD(NOL)<>1 & [M:SRS1]RTNSTOUPD(NOL)=2
    # Si ligne gérée en stock
    # --> Lecture article et règle de gestion (sf si on va le faire ds INIZONENT)
    Call LECFICENT([M:SRS0]STOFCY,[M:SRS0]BPCORD,"",nolign-1,33,[M:SRS0]TRSCOD,0) From STKECR
Endif

If [M:SRS1]CREFLG(NOL)=0 | ([M:SRS1]CREFLG(NOL)<>0 & [M:SRS1]RTNSTOUPD(NOL)=2 & [M:SRS1]YRTNSTOUPD(NOL)=1)
    # ---------------------------------------------------------------------------------------------------- #
    # La ligne n'est pas encore créée ou elle est déjà créée mais le flag maj stock est passé de non à oui #
    # ---------------------------------------------------------------------------------------------------- #
    Actzo [M:SRS1]QTY(NOL)

    If [M:SRS1]STOMGTCOD(NOL)<>1 & [M:SRS1]RTNSTOUPD(NOL)=2
        # -------------------- #
        # Ligne gérée en stock #
        # -------------------- #
        If [M:SRS1]DETSDHNUM(NOL)="" & [M:SRS1]PNHNUM(NOL)="" & [M:SRS1]WSTOFLG(NOL)=0
            # Si retour direct
            # et les champs stocks ne sont pas renseignés : Il faut "réactiver la ligne"
            #
            # (cas particulier où on a passé le flg mvt de stock de non à oui)
            Call STKACTLIG(NOL) From STKECR
            #   Initialisation et grisage champs stock sur ligne document d'entrée
            #   si "U" Pas d'initialisation des unités et coefficients
            Call INIZONENT([M:SRS1]ITMREF(NOL),"SRS1",[M:SRS0]STOFCY,[M:SRS0]BPCORD,2,"U",NOL,12,[M]TRSCOD,"",3,1) From STKECR
            If mkstat End : Endif
            If dim([M:SRS1]PRIORD)>0  Raz [M:SRS1]PRIORD(NOL) : Actzo PRIORD(NOL) : Endif
            If dim([M:SRS1]MVTDES)>0  Raz [M:SRS1]MVTDES(NOL) : Actzo MVTDES(NOL) : Endif
        Elsif [M:SRS1]DETSDHNUM(NOL)<>"" | [M:SRS1]PNHNUM(NOL)<>""
           # Il faut Activer/Désactiver les chmps
           #
           #      Il faut désactiver les champs lot, n°série
           # (cas particulier où on a passé le flg mvt de stock de non à oui
           Call STKDISZONPIC("SRS1", NOL) From TRTVENSTK
           #MAE, le 30/09/2010, bg67156
           # Désactivation des zones stock si plus d'un détail stock
           If func STKENT.CAL_NBENTW([M:SRS1]WSTOSEQ(NOL)) > 1
              Call STKDISLIG(NOL) From STKECR
           Endif
        Endif
    Endif
Else
    # ----------------------- #
    # La ligne est déjà créée #
    # ----------------------- #
    If [M:SRS1]STOMGTCOD(NOL)=1 | [M:SRS1]RTNSTOUPD(NOL)=1
        # --> Si ligne non gérée en stock, grizage des champs stock
        Actzo [M:SRS1]QTY(NOL)
        Call STKGRILIG ("SRS1", NOL) From TRTVENSTK
    Else
        Diszo [M:SRS1]SAU(NOL), QTY(NOL), SAUSTUCOE(NOL)
        Call STKDISLIG(NOL) From STKECR : # Diszone les champs stocks ne pouvznt plu être modifiés
        If dim([M]PRIORD)>0  Diszo [M]PRIORD(NOL) : Endif
        If dim([M]MVTDES)>0  Diszo [M]MVTDES(NOL) : Endif
    Endif
Endif
End

#########################################################################
#---------------------------------------#
#   Gestion du parc client              #
#---------------------------------------#
$TRT_MACRULE
Local Integer WRET, WTYP
Local Integer WERR  # FGR 20/05/2009 : X3SUIVI55175 Variable non déclarée

  Raz WERR          # FGR 20/05/2009 : X3SUIVI55175 Variable non déclarée
  Raz WRET
  WTYP=6
  For [SRD]SRD0 Where SRHNUM=[F:SRH]SRHNUM
    If [F:ITM]ITMREF <> [F:SRD]ITMREF
      Read [ITM]ITM0 = [F:SRD]ITMREF
      If fstat Then
        Raz [F:ITM]
      Endif
    Endif
    If [F:SRD]SAUSTUCOE=0 Then
      [F:SRD]SAUSTUCOE=1
    Endif
    If [F:ITM]SERMGTCOD < 2
      # Pas de gestion des no série
      Gosub CHARGE_MACW
      # Appel au composant d'intégration
      Call MACRULE(WTYP,[F:SRH]BPCORD,WRET) From TRTMACRULE
      If WRET Then
        Gosub ERR_MACRULE
        Break                           # FGR 04/01/2011 : X3SUIVI70100
      Endif
    Else
      # Gestion des no séries
      For [STJ]STJ1 Where STOFCY=[F:SRH]STOFCY & VCRTYP=13 & VCRNUM=[F:SRD]SRHNUM
&                       & VCRLIN=[F:SRD]SRDLIN & REGFLG<>2 & QTYSTU>0
        Gosub CHARGE_MACW
        # Appel au composant d'intégration
        Call MACRULE(WTYP,[F:SRH]BPCORD,WRET) From TRTMACRULE
        If WRET Then
          Gosub ERR_MACRULE
          Break                         # FGR 04/01/2011 : X3SUIVI70100
        Endif
      Next
      If WRET Then                      # FGR 04/01/2011 : X3SUIVI70100
        Break
      Endif
    Endif
  Next
Return

# Traitement des erreurs
$ERR_MACRULE
  GOK = 0                               # FGR 04/01/2011 : X3SUIVI70100
  If WERR=0
    Call ECR_TRACE (mess(90,182,2),0)   From GESECRAN
    WERR=1
  Endif
  If [M:MACW]MACSERNUM=""
    Call ECR_TRACE ([F:SRD]ITMREF-":"-mess(WRET,182,2),0) From GESECRAN
  Else
    Call ECR_TRACE ([F:SRD]ITMREF-[M:MACW]MACSERNUM-":"-mess(WRET,182,2),0) From GESECRAN
  Endif
Return

# Chargement du masque [MACW]
$CHARGE_MACW
Raz [M:MACW]
[M:MACW]MACPDTCOD  = [F:SRD]ITMREF
[M:MACW]MACORIVCR  = [F:SRD]SRHNUM
[M:MACW]MACORIVCRL = [F:SRD]SRDLIN
[M:MACW]SALFCY     = [F:SRH]SALFCY
[M:MACW]MACITNDAT  = [F:SRH]RTNDAT
[M:MACW]PREORI     = 3
[M:MACW]PREORIVCR  = [F:SRD]SDHNUM
[M:MACW]PREORIVCRL = [F:SRD]SDDLIN
If [F:ITM]SERMGTCOD < 2
   [M:MACW]MACQTY     = [F:SRD]QTYSTU
Else
   [M:MACW]MACQTY     = abs([F:STJ]QTYSTU)
   [M:MACW]MACSERNUM  = [F:STJ]SERNUM
Endif
  # FGR 12/11/2009 : X3SUIVI56282 (début)
  Local Char SZMACWCNT(GLONDES)
  Local Char SZMACWPRE(GLONDES)

  SZMACWCNT = "SUBSRS"
  SZMACWPRE = ""
  Gosub PE_MACWAUTO From TRTCRMPE
  # FGR 12/11/2009 : X3SUIVI56282 (fin)
Return

$TRT_MACRULE_MOD
Local Integer WRET, WTYP

  Raz WRET
  WTYP=6
  For NOL=0 To [M:SRS1]NBLIG-1
    If [M:SRS1]UPDFLG(NOL)<>0 & [M:SRS1]RTNSTOUPD(NOL)=2 & [M:SRS1]YRTNSTOUPD(NOL)<>2
      If [F:ITM]ITMREF <> [M:SRS1]ITMREF(NOL)
        Read [ITM]ITM0 = [M:SRS1]ITMREF(NOL)
        If fstat Then
          Raz [F:ITM]
        Endif
      Endif
      # Gestion des no séries
      If [F:ITM]SERMGTCOD > 1
        For [STJ]STJ1 Where STOFCY=[M:SRS0]STOFCY & VCRTYP=13 & VCRNUM=[M:SRS0]SRHNUM
&                         & VCRLIN=[M:SRS1]SRDLIN(NOL) & REGFLG<>2
          Gosub CHARGE_MACW_MOD
          # Appel au composant d'intégration
          Call MACRULE(WTYP,[M:SRS0]BPCORD,WRET) From TRTMACRULE
          If WRET Then
            Break 2
          Endif
        Next
      Endif
    Endif
  Next
  If WRET
    GOK = 0                             # FGR 04/01/2011 : X3SUIVI70100
    Call ECR_TRACE (mess(90,182,2),0)   From GESECRAN
    Call ECR_TRACE (mess(WRET,182,2),0) From GESECRAN
  Endif
Return

# Chargement du masque [MACW]
$CHARGE_MACW_MOD
Raz [M:MACW]
[M:MACW]MACPDTCOD  = [M:SRS1]ITMREF(NOL)
[M:MACW]MACORIVCR  = [M:SRS0]SRHNUM
[M:MACW]MACORIVCRL = [M:SRS1]SRDLIN(NOL)
[M:MACW]MACITNDAT  = [M:SRS0]RTNDAT
[M:MACW]SALFCY     = [M:SRS0]SALFCY
[M:MACW]PREORI     = 3
[M:MACW]PREORIVCR  = [M:SRS1]DETSDHNUM(NOL)
[M:MACW]PREORIVCRL = [M:SRS1]SDDLIN(NOL)
[M:MACW]MACQTY     = abs([F:STJ]QTYSTU)
[M:MACW]MACSERNUM  = [F:STJ]SERNUM
  # FGR 12/11/2009 : X3SUIVI56282 (début)
  Local Char SZMACWCNT(GLONDES)
  Local Char SZMACWPRE(GLONDES)

  SZMACWCNT = "SUBSRS"
  SZMACWPRE = "MOD"
  Gosub PE_MACWAUTO From TRTCRMPE
  # FGR 12/11/2009 : X3SUIVI56282 (fin)
Return
######################################################################################
$SEL2
#-----------------------------------------------------------------------#
# Sélection d'une ligne de retour fsseur                                #
#-----------------------------------------------------------------------#

Local Decimal WCOEF, WQTY, WQTYSAU, LQTYSTU

Read [PND]PND0=[F:PND]PNHNUM;[F:PND]PNDLIN

If fstat
   Call RSTA("RSTA",[F:PND]PNHNUM-num$([F:PND]PNDLIN)) From GLOCK : OK=0 : Return
Endif
# Vérif. si la ligne n'a pas été retournée depuis le dernier raffraichissement de la liste de picking
If [F:PND]QTYSTU <= [F:PND]SRDQTYSTU
    GMESSAGE = [F:PND]PNHNUM-":"-mess(27,159,1)-[F:PND]ITMREF-":"-mess(271,192,1) : OK=0 : Return
Endif
Read [PNH]PNH0=[F:PND]PNHNUM
If fstat
   Call RSTA("RSTA",[F:PND]PNHNUM) From GLOCK : OK=0 : Return
Endif

# Date de livraison > date de retour
If [F:PNH]RTNDAT > [M]RTNDAT
   GMESSAGE = mess(326,192,1) : OK=0 : Return
Endif

# Si 1ère ligne, alimentation des zones d'entête
If [M]NBLIG = 0
    # On Vérifie que le client n'est pas le site de vente (correspond au fsseur)
    If [M:SRS0]BPCORD=[F:PNH]BPSNUM
        Local Integer WOK : WOK=1
        Call AVERTIR (mess(151,191,1), WOK)From GESECRAN
        If WOK=1  GERR=1 : OK=0 : Return : Endif
    Endif
    # Récupération du site lié au fournisseur
    # Ce doit être un site de vente sur la même soc. juridique que le site de réception
    If [F:BPR]BPRNUM<>[F:PNH]BPSNUM
        Read [BPR]BPR0=[F:PNH]BPSNUM : If fstat Raz [F:BPR] Endif
    Endif
    If [F:BPR]FCY<>""
        If [F:FCY]FCY<>[F:BPR]FCY
            Read [FCY]FCY0=[F:BPR]FCY : If fstat Raz [F:FCY] Endif
        Endif
        If [F:FCY]SALFLG=2
            If [F:FCY]LEGCPY <> GSOCIETE
                GERR=1 : GMESSAGE=[F:PNH]PNHNUM+"\"+mess(272,192,1) : OK=0   : Return
            Endif
        Endif
    Endif
    If [F:BPR]FCY="" | [F:FCY]SALFLG<>2
        GERR=1 : GMESSAGE=[F:PNH]PNHNUM-":"-mess(8,701,1)-mess(256,194,1)
    Endif
    [M:SRS0]BPSNUM=[F:PNH]BPSNUM
    [M:SRS0]SALFCY=[F:BPR]FCY
    Call GLOBVAR([M:SRS0]SALFCY,"VEN") From TRTX3
Else
  # On contrôle si on peut modifier le retour
    Gosub AVANT_MOD : If GERR=1 Return : Endif
  # Contrôle des conditions des regroupement
   Gosub CTL_PND
   If OK=0 Return Endif
Endif

# Contrôle de l'insertion
If [M]NBLIG+1 >= dim([M]ITMREF)-1
   GERR=1 : GMESSAGE=mess(122,199,1)
   OK=0   : Return
Endif

#-----
# TS : Si on picke un retour fournisseur, il faut absolument qu'il soit issu d'une
#      réception provenant elle-même d'une livraison : sinon on refuse
#      --> filtre sur réception<>"" à ajouter dans FILGAUCHE2
#-----

# Si retour de réception on lit la réception pour voir si elle liée à une livraison
Raz [F:SDH], [F:SDD]
If [F:PND]PTHNUM<>"" & [F:PND]PTDLIN<>0
    Read [PTD]PTD0=[F:PND]PTHNUM;[F:PND]PTDLIN
    If fstat
       Call RSTA("RSTA",[F:PND]PTHNUM-num$([F:PND]PTDLIN)) From GLOCK : OK=0 : Return
    Endif
    If [F:PTD]SDHNUM<>""
        Read [SDH]SDH0=[F:PTD]SDHNUM
        If fstat
           Call RSTA("RSTA",[F:PTD]SDHNUM) From GLOCK : OK=0 : Return
        Endif
        If [F:PTD]SDDLIN<>0
            Read [SDD]SDD0=[F:PTD]SDHNUM;[F:PTD]SDDLIN
            If fstat
               Call RSTA("RSTA",[F:PTD]SDHNUM-num$([F:PTD]SDDLIN)) From GLOCK : OK=0 : Return
            Endif
        Endif
    Endif
Endif

SYMBOLE2 = "PNH"+[F:PNH]PNHNUM
Lock = SYMBOLE2
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[F:PNH]PNHNUM-":"-mess(10,100,1)
   OK=0   : Return
Endif
If [F:SDH]SDHNUM<>""
    SYMBOLE2 = "SDH"+[F:SDH]SDHNUM
    Lock = SYMBOLE2
    If fstat
       # modification en cours sur un autre poste
       GERR=1 : GMESSAGE=[F:SDH]SDHNUM-":"-mess(10,100,1)
       OK=0   : Return
    Endif
Endif

# ---------------------------------------
# FGR 18/07/2014 : X3SUIVI91606 (début) : Il n'y a pas de trans-classe depuis [F:PNH], donc je le fais champ par champ
[M:SRS2]LICPLATER    = [F:PNH]LICPLATER
[M:SRS2]TRLLICPLATER = [F:PNH]TRLLICPLATER
[M:SRS2]DPEDATR      = [F:PNH]DPEDATR
[M:SRS2]ETDR         = [F:PNH]ETDR
[M:SRS2]ARVDATR      = [F:PNH]ARVDATR
[M:SRS2]ETAR         = [F:PNH]ETAR
# FGR 18/07/2014 : X3SUIVI91606 (fin)
# ---------------------------------------

#FQ 65292
#CPO - Problème découvert lors de la correction de cette fiche
#Pavé déplacé avant l'incrémentation de NBLIG
# Si retour de réception issu d'une livraison, alimentation du retour vente en fonction de la livraison
# -- Chargement des sections analytiques entête du document
If [M:SRS1]NBLIG=0
  If [F:SDD]SDHNUM<>"" & [F:SDD]SDDLIN<>0
    Call CHARG_CCEH("SRS2","NBAXE","SDH") From TRTX3CPT
  Endif
Endif
#fin FQ 65292
#FQ 65292
#CPO - Problème découvert lors de la correction de cette fiche
#Pavé déplacé avant l'incrémentation de NBLIG
If [M]NBLIG=0
  If [F:SDD]SDHNUM<>""
    [M:SRS0]ICTCTY=[F:SDH]ICTCTY
    [M:SRS0]FFWNUM=[F:SDH]FFWNUM
    [M:SRS0]FFWADD=[F:SDH]FFWADD
    [M:SRS0]EECICT=[F:SDH]EECICT
    If dim([M]EECLOC)>0
      [M:SRS0]EECLOC    = [F:SDH]EECLOC
      [M:SRS0]BPIEECNUM = [F:SDH]BPIEECNUM
      [M:SRS0]EECTRN    = [F:SDH]EECTRN
    Endif
  Endif
Endif
#fin FQ 65292

#--- Sélection correcte

# Ouverture de la ligne
nolign = [M]NBLIG
Insa nolign,1,[M]NBLIG [M]NBLIG
[M]NBLIG += 1
nolign = [M]NBLIG
NOL = nolign-1
status = 0
Call LINNUM("SRDLIN") From TABLEAUX

#-- Initialisation des zones de stock et ctrl si l'article est ok
Default Mask [SRS1]
Call INIZONENT([F:PND]ITMREF,"SRS1",[M]STOFCY,[M]BPCORD,2,"U",NOL,33,[M]TRSCOD,[M]SRHNUM,3,0) From STKECR
If mkstat
   Dela NOL,1,[M:SRS1]NBLIG-1 [M:SRS1]NBLIG : [M:SRS1]NBLIG-=1
   If [M]NBLIG=0 Raz [M]SALFCY, [M]BPCINV  Endif
   SYMBOLE2 = "PNH"+[F:PNH]PNHNUM
   Unlock = SYMBOLE2
   If [F:SDH]SDHNUM<>""
       SYMBOLE2 = "SDH"+[F:SDH]SDHNUM
       Unlock = SYMBOLE2
   Endif
   OK=0 : GERR=1 : Return
Endif

#FQ 65292
#CPO - Problème découvert lors de la correction de cette fiche
#Partie initialisation sections en-tête déplacée avant l'incrémentation de NBLIG
#Si retour de réception issu d'une livraison, alimentation du retour en fonction de la livraison
If [F:SDD]SDHNUM<>"" & [F:SDD]SDDLIN<>0
    [M:SRS1]=[F:SDD]
    [M]DETSDHNUM(NOL)=[F:SDH]SDHNUM
#    If [M:SRS1]NBLIG=0    # Chargement des sections analytiques entête du document
#        Call CHARG_CCEH("SRS2","NBAXE","SDH") From TRTX3CPT
#    Endif
#Else
#    If [M:SRS1]NBLIG=0    # Chargement des sections analytiques entête du document
#        Call CHARG_CCEH("SRS2","NBAXE","PNH") From TRTX3CPT
#    Endif
Endif
#fin FQ 65292
# -- Initialisation des sections analytiques vides
Local Integer I
Local Char    SECTION
If dim([M:SRS2]NBAXE)>0
  [M:SRS2]NBAXE=GNBDIE
  For I=1 To GNBDIE
    If [M:SRS2]CCE(I-1)=""
      [M:SRS2]DIE(I-1)=GDIE(I)
      Call INISEC(SECTION,"SRS",GDIE(I)) From SUBCDE
      [M:SRS2]CCE(I-1)=SECTION
    Endif
  Next I
Endif

# -- alimentation du masque
[M]ITMREF(NOL)    = [F:PND]ITMREF
[M]RTNREN(NOL)    = [F:PND]RTNREN
[M]STU(NOL)       = [F:PND]STU
[M]DETSALFCY(NOL) = [M:SRS0]SALFCY
[M]DETBPCINV(NOL) = [M:SRS0]BPCINV
[M]PNHNUM(NOL)    = [F:PND]PNHNUM
[M]PNDLIN(NOL)    = [F:PND]PNDLIN

# On vérifie si l'unité du retour est une unité de vente
# Si oui, on la prend
# Si non et on a une livraison, on prend l'unité de vente de la livraison
# Si on a pas de livraison, l'unité de vente sera l'unité de stock
If [F:PND]UOM<>[F:PND]STU
    Call CTLUOM([M:SRS1]ITMREF(NOL),2,[M:SRS0]BPCORD,[F:PND]UOM,WCOEF,GBIDC1,GBIDC2,
&               [M:SRS1]DACSAUCOE(NOL)) From STKACT
    If mkstat=0
        [M:SRS1]SAU(NOL)      =[F:PND]UOM
        [M:SRS1]SAUSTUCOE(NOL)=[F:PND]UOMSTUCOE
    Elsif [F:SDD]SAU<>""
        Raz GMESSAGE
        [M:SRS1]SAU(NOL)      =[F:SDD]SAU
        [M:SRS1]SAUSTUCOE(NOL)=[F:SDD]SAUSTUCOE
    Else
        Raz GMESSAGE
        [M:SRS1]SAU(NOL)      =[F:PND]STU
        [M:SRS1]SAUSTUCOE(NOL)=1
    Endif
Else
    [M:SRS1]SAU(NOL)      =[F:PND]STU
    [M:SRS1]SAUSTUCOE(NOL)=1
Endif

# -- calcul quantité en US
LQTYSTU           = [F:PND]QTYSTU - [F:PND]SRDQTYSTU
[M]QTYSTU(NOL)    = LQTYSTU
# -- Recalcul de la qté retour en UV à partir de l'US
# Si on tombe sur un chiffre rond ok sinon on met tout en US
# Calcul de la qté en UV
WQTYSAU=LQTYSTU / [M:SRS1]SAUSTUCOE(NOL)
WQTY=WQTYSAU
Call QTEARR(WQTY,[M:SRS1]SAU(NOL)) From TRTDIV
If WQTYSAU=WQTY
    # On tombe sur un chiffre rond : ok
    [M:SRS1]QTY(NOL)=WQTYSAU
Else
    # On ne tombe pas sur un chiffre rond : on met tout en US
    [M:SRS1]SAU(NOL)=[M:SRS1]STU (NOL)
    [M:SRS1]QTY(NOL)=LQTYSTU
    [M:SRS1]SAUSTUCOE(NOL)=1
Endif

[M]PNDQTYSTU(NOL) = [M]QTYSTU(NOL)    #quantité de retour fournisseur

# -- Lecture article
If [F:ITM]ITMREF<>[M]ITMREF(NOL)
    Read [ITM]ITM0=[M]ITMREF(NOL)
    If fstat Call RSTA ("ITM",[M]ITMREF(NOL))  From GLOCK : Raz [F:ITM] : Endif
Endif
# -- Alimentation du flag coef modifiable
If [M]SAU(NOL)=[M]STU(NOL)
    [M]DACSAUCOE(NOL)=1
Elsif [M]SAU(NOL)=[F:ITM]SAU
    [M]DACSAUCOE(NOL)=[F:ITM]DACSAUCOE
Else
    Local Integer I    : # L'unité est une unité de conditionnement
    For I=0 To dim([F:ITM]PCU)-1
       If find([F:ITM]PCU(I),[M]SAU(NOL))
          [M]DACSAUCOE(NOL)=[F:ITM]DACPCUCOE(I)
          Break
       Endif
    Next I
Endif


[M]RTNINVUPD(NOL) = 1
If [F:SDD]SDHNUM=""
    # ----------------------------------------------------- #
    # On a aucune livraison                                 #
    # ----------------------------------------------------- #
    # On récupère la désignation standard du retour fsseur
    [M]ITMDES1(NOL)   = [F:PND]ITMDES1
    # On recherche la désignation traduite dans la langue du client
    #Call CHARGE_ITMDES("DES1AXX", [M:SRS0]LAN,[M:SRS1]ITMREF(NOL),[M:SRS1]ITMDES(NOL)) From TRTX3
    #If [M:SRS1]ITMDES(NOL) = "" [M:SRS1]ITMDES(NOL) = [M:SRS1]ITMDES1(NOL) Endif
    Call CHARGE_DEFITMDES("DES1AXX", [M:SRS0]LAN,[M:SRS1]ITMREF(NOL),[M:SRS1]ITMDES(NOL), "[F:PND]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
    # Récupération du prix net du retour et conversion
    If [M:SRS1]SAU(NOL)=[F:PND]UOM             : # retour client et retour fsseur st ds la même unité
        [M]NETPRI(NOL) = [F:PND]NETPRI
    Else                                       : # retour client et retour fsseur ne st pas ds la même unité
        Local Decimal WPRIX
        If [M:SRS1]SAU(NOL)=[F:PND]STU         : # retour client en US, retour fsseur ds une autre unité
            WPRIX=[F:PND]NETPRI/[F:PND]UOMSTUCOE
        Elsif [F:PND]UOM=[F:PND]STU            : # retour fsseur en US, retour client ds une autre unité
            WPRIX=[F:PND]NETPRI*[M:SRS1]SAUSTUCOE(NOL)
        Else                                   : # retour client et retour fsseur ds une autre unité que l'US
            WPRIX=[F:PND]NETPRI/[F:PND]UOMSTUCOE
            WPRIX=WPRIX*[M:SRS1]SAUSTUCOE(NOL)
        Endif
        WPRIX=arr(WPRIX,10^-GDECPRI) : [M:SRS1]NETPRI(NOL)=WPRIX
    Endif
    # Dans les retours achat le prix est tjs en HT, donc on calcule le prix TTC
    [M]NETPRINOT(NOL) = [M:SRS1]NETPRI(NOL)
    [M]CUR(NOL)       = [F:PND]NETCUR
#    Call CLCTAXEPRI([M]NETPRINOT(NOL),[F:PND]VAT,1,GSOCIETE,[M]DEXTRTNDAT(NOL),[M]QTY(NOL),[F:PND]CLCAMT1,[F:PND]CLCAMT2,
#&                   [M]NETPRIATI(NOL)) From TRTX3
#    [M]STOMGTCOD(NOL) = [F:PND]STOMGTCOD
Else
    # ----------------------------------------------------- #
    # On a une livraison : On récupère tout de la livraison #
    # ----------------------------------------------------- #
    If [F:SDH]ORIFCY<>"" [M]ORIFCY = [F:SDH]ORIFCY : Endif

    [M]CUR(NOL)       = [F:SDH]CUR
    # Récupération du prix net de la livraison et conversion
    If [M:SRS1]SAU(NOL)<>[F:SDD]SAU            : # retour client et livraison ne st pas ds la même unité
        Local Decimal WPRIX
        If [M:SRS1]SAU(NOL)=[F:SDD]STU         : # retour client en US, livraison ds une autre unité
            WPRIX=[F:SDD]NETPRINOT/[F:SDD]SAUSTUCOE : WPRIX=arr(WPRIX,10^-GDECPRI)
            [M:SRS1]NETPRINOT(NOL)=WPRIX
            WPRIX=[F:SDD]NETPRIATI/[F:SDD]SAUSTUCOE : WPRIX=arr(WPRIX,10^-GDECPRI)
            [M:SRS1]NETPRIATI(NOL)=WPRIX
        Elsif [F:SDD]SAU=[F:SDD]STU            : # livraison en US, retour client ds une autre unité
            WPRIX=[F:SDD]NETPRINOT*[M:SRS1]SAUSTUCOE(NOL) : WPRIX=arr(WPRIX,10^-GDECPRI)
            [M:SRS1]NETPRINOT(NOL)=WPRIX
            WPRIX=[F:SDD]NETPRIATI*[M:SRS1]SAUSTUCOE(NOL) : WPRIX=arr(WPRIX,10^-GDECPRI)
            [M:SRS1]NETPRIATI(NOL)=WPRIX
        Else                                   : # retour client et livraison ds une autre unité que l'US
            WPRIX=[F:SDD]NETPRINOT/[F:SDD]SAUSTUCOE
            WPRIX=WPRIX*[M:SRS1]SAUSTUCOE(NOL)  : WPRIX=arr(WPRIX,10^-GDECPRI)
            [M:SRS1]NETPRINOT(NOL)=WPRIX
            WPRIX=[F:SDD]NETPRIATI/[F:SDD]SAUSTUCOE
            WPRIX=WPRIX*[M:SRS1]SAUSTUCOE(NOL)  : WPRIX=arr(WPRIX,10^-GDECPRI)
            [M:SRS1]NETPRIATI(NOL)=WPRIX
        Endif
        If [F:SDH]PRITYP=1
            [M:SRS1]NETPRI(NOL)=[M:SRS1]NETPRINOT(NOL)
        Else
            [M:SRS1]NETPRI(NOL)=[M:SRS1]NETPRIATI(NOL)
        Endif
    Endif
    #FQ 65292
    #CPO - Problème découvert lors de la correction de cette fiche
    #Il faut déplacer ce pavé avant l'incrémentation de NBLIG, à cause du test sur NBLIG=0
    #If [M]NBLIG=0
    #    [M:SRS0]ICTCTY=[F:SDH]ICTCTY
    #    [M:SRS0]FFWNUM=[F:SDH]FFWNUM
    #    [M:SRS0]FFWADD=[F:SDH]FFWADD
    #    [M:SRS0]EECICT=[F:SDH]EECICT
    #    If dim([M]EECLOC)>0
    #       [M:SRS0]EECLOC    = [F:SDH]EECLOC
    #       [M:SRS0]BPIEECNUM = [F:SDH]BPIEECNUM
    #       [M:SRS0]EECTRN    = [F:SDH]EECTRN
    #    Endif
    #Endif
    #fin FQ 65292

    [M]SIHNUMFAC(NOL) = [F:SDH]SIHNUM

    # Calcul de la qté livrée en US : Qté livrée - Qté retournée
    LQTYSTU           = [F:SDD]QTYSTU - [F:SDD]RTNQTYSTU
    [M]DLVQTYSTU(NOL)    = LQTYSTU
    # Affichage de la qté livrée dans l'unité de vente du retour
    If [M]SAU(NOL)<>[M]STU(NOL)
        WQTY=LQTYSTU / [M:SRS1]SAUSTUCOE(NOL)
        Call QTEARR(WQTY,[M:SRS1]SAU(NOL)) From TRTDIV
        [M]DLVQTY(NOL)= WQTY
    Else
        [M]DLVQTY(NOL)= LQTYSTU
    Endif

    If [M]SIHNUMFAC(NOL) = "" [M]RTNINVUPD(NOL)=2 Endif
Endif
# Si le retour d'achat est en attente d'avoir on fera un avoir (sf si on pas encore facturé)
If [F:PND]LININVFLG=1 & [M]RTNINVUPD(NOL)=1 [M]RTNCNOFLG(NOL)=2 Endif
# Si l'article est géré en stock : on force la mise à jour des stocks
If [M]STOMGTCOD(NOL) > 1
   [M]RTNSTOUPD(NOL) = 2
Else
   [M]RTNSTOUPD(NOL) = 1
   [M]WSTOFLG(NOL)=2 : # Article non géré en stock
Endif
#[M]ORDUPD(NOL)=1

# Chargement sections analytiques
If [F:SDD]SDHNUM<>""
    Call CHARG_ACCCCE(NOL,"","","[M:SRS1]CCE",
&                        "SDD",0,[F:SDD]SDHNUM,[F:SDD]SDDLIN,0,"") From TRTX3CPT
#FQ 65292
#CPO - Problème découvert lors de la correction de cette fiche
#Dans ce cas précis, c'est le code section par défaut qui sera utilisé
#Entité - "Document d'origine"
#Else
    #Call CHARG_ACCCCE(NOL,"","","[M:SRS1]CCE",
#&                        "PND",0,[F:PND]PNHNUM,[F:PND]PNDLIN,0,"") From TRTX3CPT
#fin FQ 65292
Endif
# -- Initialisation des sections analytiques vides
Local Integer I
Local Char    SECTION
For I=1 To GNBDIE
    If evalue("dim([M:SRS1]CCE"+num$(I)+"(NOL))") >0 & evalue("[M:SRS1]CCE"+num$(I)+"(NOL)")=""
        #FQ 65292
        #Call INISEC(SECTION, "SRD", I) From TRTX3CPT
        Call INISEC(SECTION, "SRSD", I) From TRTX3CPT
        #fin FQ 65292
        Assign "[M:SRS1]CCE"+num$(I)+"(NOL)" With SECTION
    Endif
Next

Gosub CHARG_STOENTW

# Bug 75739
# Point d'entrée pour compléter l'alimentation de l'écran détail retour
GPOINT="ALIPICSRS" : Gosub ENTREE From EXEFNC

Return
####################################################################
$AVANT_MOD
OK = 1
# -- Modification impossible si pas les droits d'accès
If [F:SRH]AUZUSR <> "" & [F:SRH]AUZUSR <> GUSER & GAUZRET = 1
   GERR=1 : GMESSAGE=mess(71,192,1)
   OK = 0
Endif
Return


#########################################################################
$CTL_PND
#---------------------------------------------------------------------------------------#
# Contrôle de la ligne retour fsseur sélectionnée                                       #
# Elle doit être cohérente par rapport aux autres lignes sélectionnées                  #
#---------------------------------------------------------------------------------------#
If [F:PNH]BPSNUM<>[M]BPSNUM
   OK=0 : GERR=1
   GMESSAGE=[F:PNH]PNHNUM-":"-mess(26,159,1)-":"-[F:PNH]BPSNUM-"\"-mess(274,192,1)-"("-mess(26,159,1)-"="-[M:SRS0]BPSNUM-")"
   Return
Endif
Return
#########################################################################
$DESEL2
Local Integer I, J, SNOL
Local Char    WSDHNUM
Raz I, J, SNOL
OK = 0
If [M]NBLIG <> 0
   While OK <> 1
      I = find([F:PND]PNHNUM,[M]PNHNUM(J..[M]NBLIG-1))
      If !I Break Endif
      If [M]CREFLG(J+I-1)=0 & [F:PND]PNDLIN=[M]PNDLIN(J+I-1)
         WSDHNUM=[M]DETSDHNUM(SNOL)
         SNOL = J+I-1
         Dela SNOL,1,[M]NBLIG-1 [M]NBLIG
         [M]NBLIG -= 1
         If [M]NBLIG=0 Raz [M]SALFCY, [M]BPCINV, [M]BPSNUM  Endif
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif

# Si suite à désélection de la ligne, il n'y a plus de ligne sélectionnée
# sur ce retour, il faut le débloquer
Raz I,J
OK = 2
If [M:SRS1]NBLIG <> 0
   While OK <> 1
      I = find([F:PND]PNHNUM,[M:SRS1]PNHNUM(J..[M:SRS1]NBLIG-1))
      If !I Break Endif
      If [M:SRS1]CREFLG(J+I-1)=0
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif
If OK = 2
   # Unlock entête retour
   SYMBOLE2 = "PNH"+[F:PND]PNHNUM
   Unlock = SYMBOLE2
   If WSDHNUM<>""
       # Unlock entête livraison
       SYMBOLE2 = "SDH"+WSDHNUM
       Unlock = SYMBOLE2
   Endif
Endif

Return

