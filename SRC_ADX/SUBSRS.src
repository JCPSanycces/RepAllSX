Subprog C_BPSLOT(VALEUR)
Variable Char    VALEUR()
If dim([M:SRS1]SLO)>0
    Call STKCTRLOF(VALEUR, [M:SRS1]ITMREF(nolign-1), [M:SRS1]LOT(nolign-1), [M:SRS1]SLO(nolign-1), [M:SRS1]NBSLO(nolign-1), [M:SRS1]GESLOT(nolign-1) ) From STKACT
Else
    Call STKCTRLOF(VALEUR, [M:SRS1]ITMREF(nolign-1), [M:SRS1]LOT(nolign-1), "", 1, [M:SRS1]GESLOT(nolign-1) ) From STKACT
Endif
End
######################################################################################

Subprog AS_WRHE(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2 & VALEUR<>"" & [M]NBLIG<>0
   GMESSAGE=mess(342,184,1) : mkstat=2
Endif
End

Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2
  VALEUR = [M:SRS1]WRHE : mkstat=2 : End
Endif
If VALEUR=""
  VALEUR = [M:SRS1]WRHE
Endif
End

Subprog C_WRH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

#--- Bug 60553
Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
If [M:SRS1]WRH(nolign-1)<>""
   Raz [M:SRS1]LOC(nolign-1)
Endif
End

#########################################
$GRISE
# Accès à un document créé en multi-dépôt avec une transaction mono-dépôt
# --> pas d'application du mono-dépôt
If [F:SRH]WRHE="" & GWRHOBY=2
   GWRHOBY=1
   #--- Bug 62402
   #Call MESSAGE(mess(351,184,1)) From GESECRAN
   If [M]STOFCY<>[F:FCY]FCY : Read [FCY]FCY0=[M]STOFCY : Endif
   If [F:FCY]WRHGES=2 : Call MESSAGE(mess(351,184,1)) From GESECRAN : Endif
   #---
Endif
Return

#------------------------------------------#
# Actzo ou Grizo des dépôts selon le site  #
#------------------------------------------#
$WRH_ETAT
If GWRHACT<>2 Return Endif
If [M]STOFCY<>[F:FCY]FCY
   Read [FCY]FCY0=[M]STOFCY
Endif
If [F:FCY]WRHGES=2
   If find(GREP,"C","D")
      Actzo [M:SRS1]WRHE
      If GWRHOBY=2
         Diszo [M:SRS1]WRH
      Else
         Actzo [M:SRS1]WRH
      Endif
   Elsif [M:SRS1]WRHE<>""
      Diszo [M:SRS1]WRHE
      Diszo [M:SRS1]WRH
   Else
      Actzo [M:SRS1]WRHE
      Actzo [M:SRS1]WRH
   Endif
Else
  Raz   [M:SRS1]WRHE
  Grizo [M:SRS1]WRHE
  Grizo [M:SRS1]WRH
Endif
Return

