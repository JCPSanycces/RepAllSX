#<AdxTL>@(#)9.0.0.0 $Revision$
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "FERME"     : Gosub FERME
 When "INICRE"    : Gosub INICRE
 When "LIENS"     : Gosub LIENS
 When "RAZCRE"    : Gosub RAZCRE
 When "SETBOUT"   : Gosub SETBOUT
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "AV_ANNULE" : Gosub AV_ANNULE
 When "ANNULE"    : Gosub ANNULE
 When "AP_ANNULE" : Gosub AP_ANNULE
 When "APRES_CRE" : Gosub APRES_CRE
 When "APRES_MOD" : Gosub APRES_MOD
 When "FILTRE"    : Gosub FILTRE
 When "FILGAUCHE" : Gosub FILGAUCHE
 When default
Endcase
Return

$OUVRE
Global Integer GISSOCONSULT
GISSOCONSULT = GCONSULT
GCONSULT = 1

Call TEMPON("R") From GESECRAN
Gosub CMNOUVRE From TRTSRE4
Gosub CMNDEBUT From TRTSRE4
Call TEMPOFF From GESECRAN

If GERR > 0
    OK = 0
Endif

Return

####################################################
$FILGAUCHE
FILGAUCHE = 'SSS = GIDENT & TYP = "SOL"'
Return

####################################################
$FILTRE
FILTSUP = 'SSS = GIDENT & TYP = "SOL"'
Return

####################################################
$LIENS
[M:SSO0]CXTSYNSRE = "SSOSRE"
[M:SSO0]CXTSYNSOL = "SSO"

#Chargement de la solution
Read [SOL] SOL0 = [M:SSO0]SOLNUM
If !fstat
    [M:SSO0]SRENUM = [F:SOL]SRENUM
    [M:SSO1] = [F:SOL]
    [M:SSO2] = [F:SOL]
    [M:SSO3] = [F:SOL]
    [M:SSO4] = [F:SOL]
Endif

#Affiche la famille de compétence
If [M:SSO1]PBLGRP = ""
    [M:SSO1]PBLCLA = ""
Else
    Read [PBL] PBL0 = [M:SSO1]PBLGRP
    If fstat
        [M:SSO1]PBLCLA = ""
    Else
        # FGR 23/09/2009 : X3SUIVI58024
        #[M:SSO1]PBLCLA = [F:PBL]GRPPBLDES
        Call LECTEXTRA([M:SSO1]PBLCLA,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
Endif

##################################################
#  Affiche le nom du créateur de la solution en clair
##################################################
If [M:SSO1]CREUSR <> ""
     If !clalev([F:AUS]) Local File AUTILIS [AUS] : Endif
     Read [AUS] CODUSR = [M:SSO1]CREUSR
     If !fstat
         [M:SSO1]FULNAMUSR = [F:AUS]NOMUSR
     Endif
     Affzo [M:SSO1]FULNAMUSR
Endif

##################################################
#  Affiche les clobs
##################################################
#Lecture des clobs
Gosub LOADHD3 From SUBSSOB

#####################################################
#  Remplit les tableaux
#####################################################
Local Integer TESTNBLIG
Local Integer I

# Chargement du tableau des mots clés
TESTNBLIG = 0
I = 0
For I = 0 To dim([F:SOL]KEYWRD) - 1
    If [M:SSO3]KEYWRD(I) = ""
        Break
    Endif
    TESTNBLIG += 1
Next

[M:SSO3]NBWRD = TESTNBLIG

# Chargement du tableau des solutions associées
TESTNBLIG = 0
I = 0
For I = 0 To dim([F:SOL]CODSOL) - 1
    If [M:SSO4]CODSOL(I) = ""
        Break
    Endif
    TESTNBLIG += 1
Next

I = 0 

For I = 0 To TESTNBLIG - 1
    Read [SOL] SOL0 = [M:SSO4]CODSOL(I)
    [M:SSO4]SOLCREDAT(I) = [F:SOL]CREDAT
Next

[M:SSO4]NBLIG = TESTNBLIG

Gosub SETNEWSOL From SUBSSOB

Gosub DISPICON From SUBSSOB
Affzo [M:SSO1]
Affzo [M:SSO2]
Affzo [M:SSO3]
Affzo [M:SSO4]
Return

###############################################
$FERME

Gosub CMNFINSAI From TRTSRE4
Gosub CMNFINSAI2 From TRTSRE4

#Nettoie tous les écrans.
Raz [M:SSO0]
Raz [M:SSO1]
Raz [M:SSO2]
Raz [M:SSO3]
Raz [M:SSO4]

GCONSULT = GISSOCONSULT 
Kill GISSOCONSULT
Return

$INICRE
Return

$VERIF_CRE
Return

$VERIF_MOD
Return

$CREATION
Return

$MODIF
Return

##########################################################################
$AV_ANNULE
Return

##########################################################################
$ANNULE
Return

##########################################################################
$AP_ANNULE
Return

####################################################################
$APRES_CRE
Return

############################################################################
$APRES_MOD
Return

###########################################################################
$RAZCRE
Return

####################################################
$SETBOUT
Local Integer IFUNOPEN
IFUNOPEN = 0

If [M:SSO4]CODSOL(0) <> ""
    #Visualiser les solutions associées
    IFUNOPEN = 0
    Call ISFUNOPEN("GESSOL", IFUNOPEN) From CRMUTIL140
    If !IFUNOPEN
        CHMEN += "G"
    Endif
Endif

    #Visualiser la demande
If [M:SSO0]SRENUM <> ""
    IFUNOPEN = 0
    Call ISFUNOPEN("GESSRE", IFUNOPEN) From CRMUTIL140
    If !IFUNOPEN
        CHMEN += "I"
    Endif
Endif

#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
Gosub SET_BOUT_SPE From GSAISIE

Call VIREBOUT(CHAINE,"H") From GOBJET    
Return
