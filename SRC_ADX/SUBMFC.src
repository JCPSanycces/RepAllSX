#<AdxTL>@(#)3.0.0.0 $Revision$
# SUBMFC :  Objet pour Consultation seulement           #
# PRIX DE REVIENT DE FABRICATION et DE SOUS-TRAITANCE   #
#-------------------------------------------------------#

$ACTION
Case ACTION
 When      "OUVRE"         Gosub OUVRE
 When      "SETBOUT"       Gosub SETBOUT
 When      "AVANTBOUT"     Gosub AVANTBOUT
 When      "EXEBOUT"       Gosub EXEBOUT
 When      "FILTRE"        Gosub FILTRE
 When      "LIENS"         Gosub LIENS
 When      "BOITE"         Gosub BOITE
 When      "TITRE"         Gosub TITFEN
 When      "AB1_VCRNUM"    Gosub AB1_VCRNUM
 When      "BB1_VCRNUM"    Gosub BB1_VCRNUM
 When      "APRES_MODIF"   Gosub APRES_MODIF
 When      "AFFMASK"       Gosub AFFMASK
 When      "AV_IMPRIME"    Gosub AV_IMPRIME
 # Issue 101696 - 2014-11-13 by JUSYN : Reading record to display data. Error was data wasn't displayed when coming from other screen.
 When      "AVANT_OUVRE"   Gosub AVANT_OUVRE
 When Default
Endcase
Return

$AB1_VCRNUM
GCONSULT = 2 # pour ne voir que l'OF concerné
Return

$BB1_VCRNUM
GCONSULT = 0 # pour rétablir la situation
Return

$OUVRE
Local Mask MFCDET
If GMODU(8)=2  # Module GPAO
   Local File MFGHEAD [MFG]
Endif
If GMODU(6)=2  # Module Achats
   Local File SCOHEAD [SCO]
Endif
Local Char TITFOLD

# 105537.sn MJH 7/30/2015
Char BLOCKTITLE
If find(GFONC1, "GESSCC")
  Call TEXTE (1897, BLOCKTITLE) From OBJDIV
Else
  Call TEXTE (11127, BLOCKTITLE) From OBJDIV
Endif
# 105537.en MJH 7/30/2015
Return

# Issue 73411 - 2011-09-29 by CCC
$BOITE
# affectation de la bonne fonction suite à navigation
If find(GFONC1,"GESMFCP","VISUMFCP")
    MENFON = "GESMFCP"
Elsif find(GFONC1,"GESSCCP","VISUSCCP")
    MENFON = "GESSCCP"
Endif
Return

$TITFEN
# titre de la fenêtre selon la fonction (v 140)
If find(GFONC1,"GESMFCP","GESSCCP","VISUMFCP","VISUSCCP")
  TIT = mess(238,195,1) # "Consultation coût prévisionnel"
Else
  TIT = mess(237,195,1) # "Consultation prix revient"
Endif

If find(GFONC1,"GESSCC")# 105537.sn MJH 7/30/2015
  Call TEXTE (54141, TIT) From OBJDIV
Endif

If find(GFONC1,"GESMFC","GESMFCP", "GESMFCP", "GESSCCP" , "GESSCC")
  Call TEXTE (22454, TITFOLD) From OBJDIV
Else
  TITFOLD = TIT # intitulé évalué dans la fenetre # Original
Endif# 105537.en MJH 7/30/2015

Return

$SETBOUT
Call VIREBOUT(CHAINE,"CMADH") From GOBJET
If !CLECUR
    Call VIREBOUT(CHAINE,"1") From GOBJET  # Bouton Détail
Endif
Return

$AVANTBOUT
# positionner les var globales que si on vient du menu Couts de fabrication
If BOUT = "2" & GFONCTION = "GESMFC"
   GFLTITM = [M:MFC0]ITMREF  # pour historique
   GFLTFCY = [M:MFC0]STOFCY
Endif
Return

$EXEBOUT
Case REP
  When "2"
      If GFONCTION = "GESMFC"
        GFLTITM = ""
        GFLTFCY = ""
      Endif
Endcase
Return

$AFFMASK
Case GFONC1
    When "GESMFC","GESMFCP"   : [M:MFC0]VCRTYP=10
    When "VISUMFC","VISUMFCP" : [M:MFC0]VCRTYP=10 # FQ 64658 GA 09/2010 Ergonomie
    When "GESSCC","GESSCCP"   : [M:MFC0]VCRTYP=36
    When "VISUSCC","VISUSCCP" : [M:MFC0]VCRTYP=36
Endcase
#MAE, 1/04/08, en débranchement depuis article et article site,
#ALIMENTATION des clés pour avoir uniquement ceux de l'article
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM", "GESITF")
        If find(GNAVIG(GPILNAV-1),"GESITM")
            [M:MFC0]ITMREF=[M:ITM0]ITMREF
            Case [M:MFC0]VCRTYP
             When 10 : Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
             When 36 : Call FIND_GFCYDEF(6) From TRTX3  # FQ 54218
            Endcase
            [M:MFC0]STOFCY=GFCY
        Else If find(GNAVIG(GPILNAV-1),"GESITF")
            [M:MFC0]ITMREF=[M:ITF0]ITMREF
            [M:MFC0]STOFCY=[M:ITF0]STOFCY
            Endif
        Endif
        Filter [MFC] Where STOFCY=[M:MFC0]STOFCY
&                & ITMREF=[M:MFC0]ITMREF
        Read [MFC]MFC0 First
        Filter [MFC]

        If fstat = 0
          [M]VCRTYP = [F:MFC]VCRTYP
          [M]MFCTYP = [F:MFC]MFCTYP
          [M]UID = [F:MFC]UID
        Endif

        CLE1=[M]ITMREF
        CLE2(0)=[M]STOFCY
        CLE2(1)=num$([F:MFC]VCRTYP)
        CLE2(2)=[F:MFC]VCRNUM
        CLE2(3)=num$([F:MFC]VCRLIN)
        CLE2(4)=num$([F:MFC]MFCTYP)
        CLE2(5)=num$([F:MFC]UID)
# Issue 101696 - 2014-11-13 by JUSYN : Reading record in AVANT_OUVRE in order to be able to display data directly when coming from another screen (GESMFG, GESSCO).
    Elsif find(GNAVIG(GPILNAV-1),"GESMFG") & find(GFONC1,"VISUMFC","VISUMFCP") # FQ 64658 GA 09/2010 Ergonomie
#        [M:MFC0]ITMREF=GFLTITM
#        [M:MFC0]STOFCY=GFLTFCY
#        [M:MFC0]VCRTYP=10
#        [M:MFC0]VCRNUM=GFLTMFGNUM
#        Filter [MFC] Where STOFCY=[M:MFC0]STOFCY
#&                        & ITMREF=[M:MFC0]ITMREF
#&                        & VCRTYP=[M:MFC0]VCRTYP
#&                        & VCRNUM=[M:MFC0]VCRNUM
#        Read [MFC]MFC0 First
#        If !fstat
#          [M]VCRTYP = [F:MFC]VCRTYP
#          [M]MFCTYP = [F:MFC]MFCTYP
#          [M]UID    = [F:MFC]UID
#        Endif
#        CLE1=[M:MFC0]ITMREF
#        CLE2(0)=[M:MFC0]STOFCY
#        CLE2(1)=num$([M:MFC0]VCRTYP)
#        CLE2(2)=[M:MFC0]VCRNUM
#        CLE2(3)=num$([F:MFC]VCRLIN)
#        CLE2(4)=num$([F:MFC]MFCTYP)
#        CLE2(5)=num$([F:MFC]UID)
#        # Issue 101696 - 2014-10-27 by JUSYN : Key fields not visible
#        Affzo [M:MFC0]ITMREF
#        Affzo [M:MFC0]STOFCY
#        Affzo [M:MFC0]VCRNUM
    Elsif find(GNAVIG(GPILNAV-1),"GESSCO") & find(GFONC1,"VISUSCC","VISUSCCP")
#        [M:MFC0]ITMREF=GFLTITM
#        [M:MFC0]STOFCY=GFLTFCY
#        [M:MFC0]VCRTYP=36
#        [M:MFC0]VCRNUM=GFLTMFGNUM
#        Filter [MFC] Where STOFCY=[M:MFC0]STOFCY
#&                        & ITMREF=[M:MFC0]ITMREF
#&                        & VCRTYP=[M:MFC0]VCRTYP
#&                        & VCRNUM=[M:MFC0]VCRNUM
#        Read [MFC]MFC0 First
#        If !fstat
#          [M]VCRTYP = [F:MFC]VCRTYP
#          [M]MFCTYP = [F:MFC]MFCTYP
#          [M]UID    = [F:MFC]UID
#        Endif
#        CLE1=[M:MFC0]ITMREF
#        CLE2(0)=[M:MFC0]STOFCY
#        CLE2(1)=num$([M:MFC0]VCRTYP)
#        CLE2(2)=[M:MFC0]VCRNUM
#        CLE2(3)=num$([F:MFC]VCRLIN)
#        CLE2(4)=num$([F:MFC]MFCTYP)
#        CLE2(5)=num$([F:MFC]UID)
    Endif
Endif
Return

$FILTRE
FILTSUP="UID=0"
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM","GESITF")
       FILTSUP="1=1"
    Endif
Endif

# FQ 64658 GA 09/2010 Ergonomie
If dim(GFLTFCY)>0 & GFLTFCY<>""
    FILTSUP += '& STOFCY="'+GFLTFCY+'"'
Endif
#If dim(GFLTITM)>0 & GFLTITM<>"" #98320.os MJH ITMREF filter is not needed if we have MFGNUM
#    FILTSUP += '& ITMREF="'+GFLTITM+'"'
#Endif#98320.oe
If dim(GFLTMFGNUM)>0 & GFLTMFGNUM<>""
    FILTSUP += '& VCRNUM="'+GFLTMFGNUM+'"'
Endif


Char BLOCKTITLE# 105537.n MJH 7/30/2015
Case GFONC1
    When "GESMFCP"           : FILTSUP += "& VCRTYP=10 & find(MFCTYP,1,2,3)"
                               Call TEXTE (54136, BLOCKTITLE) From OBJDIV # 105537.n MJH 7/30/2015
    When "GESMFC"            : FILTSUP += "& VCRTYP=10 & MFCTYP=4"
                               Call TEXTE (11127, BLOCKTITLE) From OBJDIV # 105537.n MJH 7/30/2015
    When "VISUMFC"           : FILTSUP += "& VCRTYP=10 & MFCTYP=4"          # FQ 64658 GA 09/2010 Prix de revient
    When "VISUMFCP"          : FILTSUP += "& VCRTYP=10 & find(MFCTYP,1,2)"  # FQ 64658 GA 09/2010 Prévisionnel
    When "GESSCC"            : FILTSUP += "& VCRTYP=36 & MFCTYP=4"
                               Call TEXTE (1897, BLOCKTITLE) From OBJDIV # 105537.n MJH 7/30/2015
    When "GESSCCP"           : FILTSUP += "& VCRTYP=36 & find(MFCTYP,1,2,3)"
                               Call TEXTE (11127, BLOCKTITLE) From OBJDIV # 105537.n MJH 7/30/2015
    When "VISUSCC"           : FILTSUP += "& VCRTYP=36 & MFCTYP=4"
    When "VISUSCCP"          : FILTSUP += "& VCRTYP=36 & find(MFCTYP,1,2)"
Endcase

Return

$LIENS
Read [ITM]ITM0 = [M:MFC0]ITMREF
If !fstat
   [M:MFC0]STU    = [F:ITM]STU
   [M:MFC0]STU0   = [F:ITM]STU
   [M:MFC0]STU1   = [F:ITM]STU
   [M:MFC0]STU2   = [F:ITM]STU
   [M:MFC0]TCLCOD = [F:ITM]TCLCOD
   [M:MFC0]ITMSTA = [F:ITM]ITMSTA
   [M:MFC0]BRDCOD = [F:ITM]BRDCOD
#CCC (30/07/04) bug 23924 :   [M:MFC0]PRIDIV = [F:ITM]PRIDIV
Endif
Read [ITF]ITF0 = [M:MFC0]ITMREF;[M:MFC0]STOFCY
If !fstat
   [M:MFC0]OVECOD = [F:ITF]OVECOD
Endif

[M:MFC1]TOTWITOVE = [M:MFC1]OVETOT + [M:MFC1]CSTTOT

If BLOCKTITLE <> "" #105537.sn MJH 7/30/2015
  Chgtbk [M:MFC1]15 With BLOCKTITLE
Else
  Chgtbk [M:MFC1]15 With mess([F:MFC]MFCTYP,2355,1) #original
Endif #105537.en MJH 7/30/2015

[M:MFC2]MATTOT = sum([F:MFC]MATCPNCST)
[M:MFC2]MACTOT = sum([F:MFC]MACCPNCST)+sum([F:MFC]MACCST)
[M:MFC2]LABTOT = sum([F:MFC]LABCPNCST)+sum([F:MFC]LABCST)
[M:MFC2]SCOTOT = sum([F:MFC]SCOCPNCST)+sum([F:MFC]SCOCST)
[M:MFC2]INVDTATOT = sum([F:MFC]INVDTACPN)+sum([F:MFC]INVDTACST)
[M:MFC2]OVETOT = [F:MFC]OVEMATCPN+[F:MFC]OVEMACCPN+[F:MFC]OVELABCPN+[F:MFC]OVESCOCPN+[F:MFC]OVETOT
[M:MFC2]CSTTOT = [M:MFC2]MATTOT+[M:MFC2]MACTOT+[M:MFC2]LABTOT+[M:MFC2]SCOTOT+[M:MFC2]INVDTATOT
[M:MFC2]TOTWITOVE = [M:MFC2]OVETOT + [M:MFC2]CSTTOT

If BLOCKTITLE <> "" #105537.sn MJH 7/30/2015
  Chgtbk [M:MFC2]15 With BLOCKTITLE
Else
  Chgtbk [M:MFC2]15 With mess([F:MFC]MFCTYP,2355,1) #original
Endif #105537.en MJH 7/30/2015

Case [M:MFC0]VCRTYP
    When 10 :
        # Issue 91667 - 2013-08-06 by CCC
        #If [F:MFI]MFGNUM<>[M:MFC0]VCRNUM & [F:MFI]MFGLIN<>[M:MFC0]VCRLIN
        If [F:MFI]MFGNUM<>[M:MFC0]VCRNUM | [F:MFI]MFGLIN<>[M:MFC0]VCRLIN
            Raz [F:MFI]
            Read [MFI]MFI0=[M:MFC0]VCRNUM;[M:MFC0]VCRLIN
        Endif
        If dim([M:MFC0]ECCVALMAJ)>0
            [M:MFC0]ECCVALMAJ = [F:MFI]ECCVALMAJ
            [M:MFC0]ECCVALMIN = [F:MFI]ECCVALMIN
        Endif
        [M:MFC0]MFGSTA=[F:MFI]MFGSTA
        [M:MFC0]EXTQTY = [F:MFI]EXTQTY
        [M:MFC0]CPLQTY = [F:MFI]CPLQTY
        [M:MFC3]BOMALTTYP = 2
    When 36 :
        # Issue 91667 - 2013-08-06 by CCC
        #If [F:SCI]SCONUM<>[M:MFC0]VCRNUM & [F:SCI]SCILIN<>[M:MFC0]VCRLIN
        If [F:SCI]SCONUM<>[M:MFC0]VCRNUM | [F:SCI]SCILIN<>[M:MFC0]VCRLIN
            Raz [F:SCI]
            Read [SCI]SCI0=[M:MFC0]VCRNUM;[M:MFC0]VCRLIN
        Endif
        If [F:SCO]SCONUM<>[M:MFC0]VCRNUM
            Raz [F:SCO]
            Read [SCO]SCO0=[M:MFC0]VCRNUM
        Endif
        If dim([M:MFC0]ECCVALMAJ)>0
            [M:MFC0]ECCVALMAJ = [F:SCI]ECCVALMAJ
            [M:MFC0]ECCVALMIN = [F:SCI]ECCVALMIN
        Endif
        [M:MFC0]MFGSTA = [F:SCO]SCOSTA
        [M:MFC0]EXTQTY = [F:SCI]EXTQTY
        [M:MFC0]CPLQTY = [F:SCI]CPLQTY
        [M:MFC3]BOMALTTYP = 3
Endcase
[M:MFC1]DETFLG=1
[M:MFC1]MATFLG=([M:MFC1]MATTOT<>0)+1
[M:MFC1]MACFLG=([M:MFC1]MACTOT<>0)+1
[M:MFC1]LABFLG=([M:MFC1]LABTOT<>0)+1
[M:MFC1]SCOFLG=([M:MFC1]SCOTOT<>0)+1
[M:MFC1]INVDTAFLG=([M:MFC1]INVDTATOT<>0)+1
[M:MFC1]OVEFLG=([M:MFC1]OVETOT<>0)+1
[M:MFC1]TOTFLG=1
Call CHARGE_GRAPHE("[MFC1]") From SUBMFCG
[M:MFC2]DETFLG=1
[M:MFC2]MATFLG=([M:MFC2]MATTOT<>0)+1
[M:MFC2]MACFLG=([M:MFC2]MACTOT<>0)+1
[M:MFC2]LABFLG=([M:MFC2]LABTOT<>0)+1
[M:MFC2]SCOFLG=([M:MFC2]SCOTOT<>0)+1
[M:MFC2]INVDTAFLG=([M:MFC2]INVDTATOT<>0)+1
[M:MFC2]OVEFLG=([M:MFC2]OVETOT<>0)+1
[M:MFC2]TOTFLG=1
Call CHARGE_GRAPHE("[MFC2]") From SUBMFCG
Return

$APRES_MODIF
If find(COUZON,"DETFLG","MATFLG","MACFLG","LABFLG","SCOFLG","INVDTAFLG","OVEFLG","TOTFLG")
    Assign func STKLIB.MSKDEF+COUZON With zc
    OK = -1
    Call CHARGE_GRAPHE(func STKLIB.MSKDEF) From SUBMFCG
Endif
Return

$AV_IMPRIME
If [M:MFC0]VCRTYP=36
    REPORT1 = "SCOCOST"
Endif
Return
########################################

Subprog AV_CUR(VALEUR)
Variable Char     VALEUR
Call GETDEV([M]STOFCY) From DEVSUB
VALEUR = [F:TCU]CUR
End

Subprog B1_VCRNUM(VALEUR) # à modéliser !
Variable Char     VALEUR
GCONSULT = 1
Case [M:MFC0]VCRTYP
    When 10 :
         Local File  MFGHEAD [MFG] Where MFGFCY=[M]STOFCY & MFGTRKFLG = 6
         Call OBJET("MFG",VALEUR,"") From GOBJET
    When 36 :
         Local File  SCOHEAD [SCO] Where POHFCY=[M]STOFCY & SCOTRKFLG = 6
         Call OBJET("SCO",VALEUR,"") From GOBJET
Endcase
GCONSULT = 0
End

Subprog C_VCRNUM(VALEUR)
Variable Char     VALEUR
Filter [MFC] Where STOFCY=[M:MFC0]STOFCY
&                & ITMREF=[M:MFC0]ITMREF
&                & VCRTYP=[M:MFC0]VCRTYP
&                & VCRNUM=VALEUR
&                & UID   =0
Read [MFC]MFC0 First
Filter [MFC]
#Look [MFC]MFC0 = [M]STOFCY;[M]ITMREF;[M]YEA;10;[M]VCRTYP;VALEUR;
If fstat
  mkstat = 2 : GMESSAGE = mess(23,100,1)
Else
    [M:MFC0]MFCTYP = [F:MFC]MFCTYP
Endif

##GCONSULT = 0 # rétablir tout après tunnel
##Filter [MFG]
End

Subprog C_STOFCY(VALEUR)
Variable Char     VALEUR
Call CONTROLE("ITF","!",VALEUR,[M]ITMREF,mkstat) From CONTOBJ
End

##########################################################################
## Etiquette ajoutée par le superviseur 06/05/2003 17:07:02 (TB)
##########################################################################
Subprog IB_VCRNUM
##Filter [MFG] Where MFGFCY=[M]STOFCY & MFGTRKFLG = 6
# avant le tunnel sur les OF (modélisé)
End

##########################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran MFC0) 17/05/2006 16:34:07 (CCC)
######################################################################################
Subprog IB_MFGNUM
End

Subprog C_MFGNUM(VALEUR)
Variable Char    VALEUR()
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran MFC0) 01/06/2006 10:07:28 (CCC)
######################################################################################
Subprog AS_VCRTYP(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=1 To len(mess(0,701,1))
    If !find(I,10,36) : GMENLOC(I)=1 : Endif
Next
End


######################################################################################

Funprog INTVCRTYP
    Case GFONC1
        When "GESMFC","GESMFCP" : End mess(10,701,1)
        When "GESSCC","GESSCCP" : End mess(36,701,1)
    Endcase
End ""

# Issue 101696 - 2014-11-13 by JUSYN : Reading first record of MFGCOST to be able to display its data.
$AVANT_OUVRE

If dim(GFLTMFGNUM)>0 & GFLTMFGNUM<>""
    Gosub FILTRE
    Filter [MFC] Where evalue(FILTSUP) Order By VCRLIN Asc
    Read [MFC] First
    Filter [MFC]
    If fstat <= 2
        SAVCLE2(1)=num$([F:MFC]VCRTYP)
        SAVCLE2(2)=[F:MFC]VCRNUM
        SAVCLE2(3)=num$([F:MFC]VCRLIN)
        SAVCLE2(4)=num$([F:MFC]MFCTYP)
        SAVCLE2(5)=num$([F:MFC]UID   )
    Endif
Endif

Return

