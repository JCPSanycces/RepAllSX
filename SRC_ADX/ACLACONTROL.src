#<AdxTL>@(#)0.0.0.0 $Revision$
Gosub TEST From ACLAVAL
End

#-----------------------------------------------------------------#
# Here groupe all the checks that are initially not necessay but repeated due to the fact that some classes were created
# before the screen controle was completed.
#-----------------------------------------------------------------#
Subprog VERIF_VALID_CLA(DOSSIER, CODCLA,RES_OK,AERR)
Value Char       DOSSIER
Value Char       CODCLA
Variable Integer RES_OK
Variable  Instance  AERR(1..) Using C_AERROR

Gosub OPEN_FILE From ACLAVALLEC

Local Char    LIST_NAM(GLONAVB)(0..)
Local Char    PROPERTY(250),TABCLA(GLONACLA)(1..50),TABPTR(GLONAVB)(1..50),OBJ(50),CHPIND(GLONAVA)(1..)
Local Integer NBRIND,I,RES,NUM,NBCLA,ISACTX
Local Char    L_ERR_MSG(250)

Local Char    RES_COD(80)(0..),RES_CLA(GLONACLA)(0..), RES_TIT(30)(0..)
Local Integer RES_TYP(0..), RES_MOD(0..), RES_ORD(0..), RES_NBR
Local Char    WWCODPAR(80)(0..),WWCODCLAPAR(GLONACLA)(0..),WWCODCUR(80)(0..),WWFLDCLE(250)(0..), WWINTITPAR(30)(0..)
Local Integer WWTYPINTPAR(0..), WWADRVAL(0..), WWTYPKEY(0..), WWNUMPAR(0..),WWTYPPAR(0..),WWNOLIB(0..),WWLNG(0..),WWTYPAFF(0..), WWNBRPARALL

Local Char TBCLA(GLONACLA)(1..)
Local Char TBPRO(GLONAVA)(1..)
Local Char TBCOL(GLONAVA)(1..)
Local Char TBPTR(250)(1..)

Local Integer NBCLE
Local Char    CLE(GLONAVB)(1..),CHAINE(250)

Local Integer I,WMINI,WMAXI
Local Char WCODCOL(GLONAVB),ERRMES(250)

Call RESERVED_NAME_LIST(LIST_NAM)

RES_OK = 1

# 1  basic control
Read [F:ACLA]ACLA0 = [L]CODCLA
If fstat
 RES_OK = 0
 Call  ADD_AERR( [L]CODCLA-":"-mess(4,140,1),[V]CST_AERROR,0,AERR)  : # absent class
 End
Elsif !fstat
 If [F:ACLA]CODACT<>""
  Read [ACV]CODACT = [F:ACLA]CODACT
  If fstat or [F:ACV]FLACT<>2
   RES_OK = 0
   #91436 warning sur classe/rep inactive
   #Call  ADD_AERR([L]CODCLA-":"-mess(31,140,1)-"("+[F:ACLA]CODACT+")",[V]CST_AERROR,0,AERR)
   Call  ADD_AERR([L]CODCLA-":"-mess(31,140,1)-"("+[F:ACLA]CODACT+")",[V]CST_AWARNING,0,AERR)
   End
  Endif
 Endif
 #90869
 Call VERIF_CLA_RECURS([L]DOSSIER,[L]CODCLA,AERR,RES_OK)
 If RES_OK<>1
  End
 Endif
 Call CREATE_1_1([L]DOSSIER,[L]CODCLA,"",TBCLA,TBPRO,TBPTR,TBCOL,RES_OK) From ACLAVALLEC
 If RES_OK<>1
  RES_OK = 0
  Call  ADD_AERR( [L]CODCLA-":"-mess(59,140,1),[V]CST_AERROR,0,AERR)  : # Problème de récursivité des classes 1..1
  End
 Endif
Endif

If [F:ACLA]TYPCLA=5
 If[F:ACLA]KEYINT=""
  RES_OK = 0
  Call  ADD_AERR(mess(1,7940,1)-":"-mess(10,123,1),[V]CST_AERROR,0,AERR)  : #  : # Mandatories keys
  End
 Endif
Endif

# Control persitant
If [F:ACLA]TYPCLA=2
 Read [F:ATB]CODFIC  = [F:ACLA]TABREF
 If fstat
  RES_OK = 0
  Call  ADD_AERR([F:ACLA]TABREF-":"-mess(124,124,1),[V]CST_AERROR,0,AERR)  : # table inexistante
  End
 Endif
 Read [ATI]CODIND =  [F:ACLA]TABREF;[F:ACLA]INDREF
 If fstat
  RES_OK = 0
  Call  ADD_AERR([F:ACLA]INDREF-":"-mess(207,115,1),[V]CST_AERROR,0,AERR)  : #  absent index
 Elsif !fstat & [F:ATI]HOMONYM=2
  RES_OK = 0
  Call  ADD_AERR([F:ACLA]TABREF-"("-[F:ATI]CODIND-")"-mess(1,9025,1),[V]CST_AERROR,0,AERR)  : #  absent index
  End
 Else
  Raz NBRIND,CHPIND
  Call SETCLE(NBRIND,CHPIND,[F:ATI]DESCRIPT) From LNKSUB
   For J=1 To NBRIND
    Read [F:ACLAF]ACLAF0 = [L]CODCLA;CHPIND(J)
    If fstat
     RES_OK = 0
     Call  ADD_AERR(func AFNC.MES2(mess(46,140,1),[L]CHPIND(J),[L]CODCLA),[V]CST_AERROR,0,AERR)  : #  # CHAMP $1$ NON PRESENT DANS LA CLASSE $2$
    Endif
   Next
 Endif
Endif


# 2: check Act of collection is of type "Dimentionnement"
Gosub VERIF_ACLAC

# 3: loop on each property and check
Gosub VERIF_ACLAF

# 4 Controls methods
Gosub VERIF_ACLAM

# 5: loop on each lined table and check
Gosub VERIF_ACLAK

#6 : Check Options
Gosub VERIF_ACLAO

Gosub CLOSE_FILE From ACLAVALLEC

End

#--------------#
$VERIF_ACLAO
For [ACLAO] Where CODCLA=[L]CODCLA
 If func SUBASW2.CONTROL_SDATA([F:ACLAO]OPTCND,L_ERR_MSG)=0
  Call ADD_AERR(mess(245,143,1)-[F:ACLAO]OPTCOD-":"-L_ERR_MSG,[V]CST_AERROR,0,AERR)
 Endif
Next
Return

#--------------#
$VERIF_ACLAC
For [ACLAC] Where CODCLA = [L]CODCLA & ACTCOL<>""
  Read [ACV]CODACT = [F:ACLAC]ACTCOL
  If !fstat
   If [ACV]TYP <> 2
    # Le Code activité $1$ associé au Groupe $2$ n'est pas de type Dimensionnement.
    RES_OK = 0
    Call  ADD_AERR(func AFNC.MES2( mess(111,143,1),[F:ACLAC]ACTCOL,[F:ACLAC]CODCOL),[V]CST_AERROR,0,AERR)
   Endif
  Else
   # Code activité inexistant
   RES_OK = 0
   Call  ADD_AERR([F:ACLAC]ACTCOL+": "+mess(22,150,1),[V]CST_AERROR,0,AERR)
  Endif
Next
Return

#--------------#
$VERIF_ACLAM
For [ACLAM] Where CODCLA= [L]CODCLA
 For I=0 To maxtab(LIST_NAM)
  If toupper([ACLAM]CODMET )=toupper(LIST_NAM(I))
   RES_OK = 0
   Call  ADD_AERR(mess(2,7974,1)-[ACLAM]CODMET+" : "+mess(129,133,1),[V]CST_AERROR,0,AERR)#  : code reserve
  Endif
 Next
Next
Return

#--------------#
$VERIF_ACLAF
For [ACLAF] Where CODCLA = [L]CODCLA
 If [F:ACLAF]ACTFLD="" or ([F:ACLAF]ACTFLD<>"" and func ASYRFNC.ACTIVDOS(DOSSIER,[F:ACLAF]ACTFLD)>0)

  # 3.1 check if FLDCLA is reserved
  For I=0 To maxtab(LIST_NAM)
   If toupper([ACLAF]FLDCLA)=toupper(LIST_NAM(I))
    RES_OK = 0
    Call  ADD_AERR(mess(34,140,1)-[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"+" : "+mess(129,133,1),[V]CST_AERROR,0,AERR)#  : code reserve
   Endif
  Next

  # 3.2 property code can not be the same with a collection code (except for property of instance)
  For [ACLAC] Where CODCLA = [L]CODCLA & CODCOL=[F:ACLAF]FLDCLA
    If [F:ACLAF]LNKCLA=""
     RES_OK = 0
     # Code déjà utilisé pour une propriété ou une collection.
     Call  ADD_AERR(mess(199,123,1)-[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"-":"-mess(146,143,1),[V]CST_AERROR,0,AERR)
     Break
    Endif
  Next

  # 3.3 CHECK FLDGRP:
  #      a colleciton applied to an instance must have the same code of the instance
  #      a collection can not be used both for instance and property
  If [F:ACLAF]FLDGRP<>""
   Read [ACLAC]ACLAC0=[L]CODCLA;[F:ACLAF]FLDGRP
   If fstat
    # Collection inexistante.
    RES_OK = 0
    Call  ADD_AERR([F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"+"/"+[F:ACLAF]FLDGRP-":"-mess(144,143,1),[V]CST_AERROR,0,AERR)
   Else
    If [F:ACLAF]LNKCLA = ""
     For [ACLAF2] Where CODCLA = [L]CODCLA
      If [F:ACLAF2]LNKCLA<>""
       If ([F:ACLAF]FLDGRP = [ACLAF2]FLDCLA) or ([F:ACLAF]FLDGRP = [ACLAF2]FLDGRP)
        # Collection déjà utilisé pour une propriété d'instance.
        RES_OK = 0
        Call  ADD_AERR(mess(199,123,1)-[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"-":"-mess(151,143,1),[V]CST_AERROR,0,AERR)
        Break
       Endif
      Endif
     Next

    Elsif [F:ACLAF]FLDGRP<>[F:ACLAF]FLDCLA
     # Collection d'une propriété d'instance doit avoir le même code que le code de la propriété.
     RES_OK = 0
     Call  ADD_AERR(mess(199,123,1)-[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"-":"-mess(150,143,1),[V]CST_AERROR,0,AERR)
    Endif
   Endif
  Endif


  # 3.4: check that each parameter/key related to the properties has a value that is coherent with the type
  Raz RES_COD,RES_CLA, RES_TIT, L_ERR_MSG
  Raz RES_TYP, RES_MOD, RES_ORD, RES_NBR
  Raz WWCODPAR,WWCODCLAPAR,WWCODCUR,WWFLDCLE, WWINTITPAR
  Raz WWTYPINTPAR, WWADRVAL, WWTYPKEY, WWNUMPAR,WWTYPPAR,WWNOLIB,WWLNG,WWTYPAFF, WWNBRPARALL
  Raz  NBCLE
  Raz CLE,CHAINE

  # 3.4.1 check parameters
  If [F:ACLAF]CODTYP<>""
   #Call LOAD_TYPE_PARAM([L]DOSSIER,[F:ACLAF]CODTYP,RES_COD,RES_TYP,RES_TIT,RES_MOD,RES_CLA,RES_ORD,RES_NBR) From AFNC
   Read [ATY]CODTYP = [F:ACLAF]CODTYP
   If fstat
      RES_OK = 0
      L_ERR_MSG = mess(34,140,1)-'"'+[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"+'"'-mess(82,133,1)-[F:ACLAF]CODTYP : # Type de données inexistant
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
   Else
    If [F:ATY]TYPSELSYR=2
     Read [F:ACLA2]ACLA0 = [F:ATY]CODCLA
     If !fstat
      If find([F:ACLA2]TYPCLA,2,5)>0
       If[F:ACLA2]TYPCLA=2 : # persistant
        Read [F:ATI]CODIND = [F:ACLA2]TABREF;[F:ACLA2]INDREF
        CHAINE = [F:ATI]DESCRIPT
       Elsif [F:ACLA2]TYPCLA=5 : # Interface
        CHAINE = vireblc([F:ACLA2]KEYINT,4)
       Endif
       Call SETCLE([L]NBCLE,[L]CLE,CHAINE) From LNKSUB
      Endif
     Endif
    Endif
    For [ATYR]ATYR0 Where CODTYP=[F:ATY]CODTYP  & ENARUL=2
     If func AFNC.ACTIV([ATYR]ACTRUL)>0
       If ([ATYR]PRGRUL<>[V]CST_ANAMCTLREF)
&   or ([ATYR]PRGRUL=[V]CST_ANAMCTLREF & [F:ATY]CODCLA<>[L]CODCLA)
&   or [ATYR]PRGRUL=[V]CST_ANAMCTLREF & [F:ATY]CODCLA=[L]CODCLA &([L]NBCLE>0 &  find([F:ACLAF]FLDCLA,[L]CLE)=0)
        For [ATYRP]ATYRP1 Where CODTYP=[ATYR]CODTYP &  TYPRUL=[ATYR]TYPRUL & TRTRUL=[ATYR]TRTRUL  & PRGRUL=[ATYR]PRGRUL
         If !find([ATYRP]PARCOD,[L]RES_COD)
          [L]RES_COD([L]RES_NBR)     = [ATYRP]PARCOD
          [L]RES_ORD([L]RES_NBR)     = [L]RES_NBR+1
          Call TEXTE([ATYRP]PARTIT,[L]RES_TIT([L]RES_NBR)) From OBJDIV
          [L]RES_TYP([L]RES_NBR)  = [ATYRP]PARTYP
          [L]RES_MOD([L]RES_NBR)  = [ATYRP]PARMOD
          [L]RES_CLA([L]RES_NBR)  = [ATYRP]PARCLA
          [L]RES_NBR+=1
         Endif
        Next
       Endif
     Endif
    Next
    For I=0 To [L]RES_NBR-1
     # Only the functionnal parameters will be checked, the imposed parameters will be managed automatically at validation time.
     If !find(RES_COD(I),"AINSTANCE","APRONAME","AVALCNT","AEXIST","AVALUE","AFORMAT")
      Read [ACLFP]ACLFP0 = [L]CODCLA;1;1;[F:ACLAF]FLDCLA;[L]RES_COD(I)
      If fstat & RES_COD(I)<>"AFILTER"
       RES_OK = 0
       L_ERR_MSG = mess(34,140,1)-'"'+[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"+'"'-mess(50,140,1)-'"'+[L]RES_COD(I)+'" : '+mess(141,143,1) # Valeur non définie.
       Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR)
      Elsif !fstat
       If !func SUBACLA2.L_CHECK_PARAMETER([F:ACLAF]FLDCLA,[F:ACLAF]CODTYP,[F:ACLFP]CODPAR,[F:ACLAF]ACTFLD,[F:ACLFP]VALEUR, [L]RES_TYP(I), [L]RES_MOD(I), [F:ACLAF]FLDGRP, [F:ACLFP]CODCLA, 2, L_ERR_MSG
& )
        RES_OK = 0
        L_ERR_MSG = mess(34,140,1)-'"'+[F:ACLFP]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"+'"'-mess(50,140,1)-'"'+[F:ACLFP]CODPAR+'" : '+L_ERR_MSG
        Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR)
       Endif
      Endif
     Endif
    Next
   Endif
  Endif

  # 3.4.2 check ATYPE+keys
  If [F:ACLAF]CODTYP<>""
   Read [ATY]CODTYP = [F:ACLAF]CODTYP
   If fstat
      RES_OK = 0
      L_ERR_MSG = mess(34,140,1)-'"'+[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"+'"'-mess(82,133,1)-[F:ACLAF]CODTYP : # Type de données inexistant
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
   Elsif !find([F:ACLA]TYPCLA,3,4) & [F:ATY]TYPSELSYR=3 & [F:ATY]TYPPROSYR=""
      #Le prototype est obligatoire pour utiliser un type de données Rich media
      RES_OK = 0
      L_ERR_MSG = mess(34,140,1)-'"'+[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"+'"'-mess(249,143,1)
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
   Elsif !find([F:ACLA]TYPCLA,3,4) & [F:ATY]TYPSELSYR=3 & [F:ATY]SUPFLG=2
     If [F:ACLAF]LOBTAB="" | [F:ACLAF]LOBFLD=""
      #La table et le champ du lob sont obligatoires pour un type de données Rich media avec gestion superviseur
      RES_OK = 0
      L_ERR_MSG = mess(34,140,1)-'"'+[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"+'"'-mess(180,143,1)
      Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
     Else
      Read [F:ATB]CODFIC  = [F:ACLAF]LOBTAB
      If fstat
       RES_OK = 0
       L_ERR_MSG = mess(34,140,1)-'"'+[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"+'"'
       Call  ADD_AERR(L_ERR_MSG-":"-mess(124,124,1)-[F:ACLAF]LOBTAB,[V]CST_AERROR,0,AERR)  : # table inexistante
      Else
       #106394
       If [F:ATY]TYPSELSYR=3 & [F:ATY]SUPFLG=2 & [F:ACLA]TABREF<>"" & [F:ACLAF]LOBTAB<>[F:ACLA]TABREF
        Read [ATZ]CODZONE=[F:ACLA]TABREF;[F:ACLAF]FLDCLA
        If !fstat
          RES_OK = 0
          #La table indiquée est $2$ alors qu'il existe un champ de même nom dans la table $1$ associée à la classe
          L_ERR_MSG = mess(34,140,1)-[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"-":"-func AFNC.MES2(mess(288,143,1),[F:ACLA]TABREF,[F:ACLAF]LOBTAB)
          Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
        Endif
       Endif

       Read [ATI]NUMLIG = [F:ACLAF]LOBTAB;1
       If !fstat
        Call CHARGE_CLE([F:ATI]CODFIC,[F:ATI]DESCRIPT,[L]DOSSIER,[F:ATY]CODCLA,[F:ACLAF]FLDCLA,1,WWCODPAR,WWCODCUR,WWTYPPAR,
& WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,
& WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,WWNBRPARALL) From SUBACLA

        For I=0 To [L]WWNBRPARALL-1
         Read [ACLFP]ACLFP0 = [L]CODCLA;1;2;[F:ACLAF]FLDCLA;[L]WWCODPAR(I)
         If fstat
          RES_OK = 0
          L_ERR_MSG = mess(34,140,1)-'"'+[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"+'"'-mess(50,140,1)-'"'+[L]WWCODPAR(I)+'" : '+mess(141,143,1) # Valeur non définie.
          Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR)
         Elsif !fstat
          If !func SUBACLA2.L_CHECK_PARAMETER([F:ACLAF]FLDCLA,[F:ACLAF]CODTYP,[F:ACLFP]CODPAR,[F:ACLAF]ACTFLD,[F:ACLFP]VALEUR, [L]WWTYPINTPAR(I), [L]WWADRVAL(I), [F:ACLAF]FLDGRP, [F:ACLFP]CODCLA, 2,
& L_ERR_MSG)
           RES_OK = 0
           L_ERR_MSG = mess(34,140,1)-'"'+[F:ACLFP]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"+'"'-mess(50,140,1)-'"'+[F:ACLFP]CODPAR+'" : '+L_ERR_MSG
           Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR)
          Endif
         Endif
        Next
       Endif
      Endif
     Endif
 #  Elsif !fstat & !find([F:ACLA]TYPCLA,3,4) & [F:ATY]TYPSELSYR=3 & [F:ATY]SUPFLG=1
 #    For J=6 To 9
 #     Read [ATYR]ATYR0=[ATY]CODTYP;J
 #     If fstat
 #       # Les règles $1$ \sont obligatoires pour le type "$2$" sans gestion superviseur
 #       RES_OK = 0
 #       L_ERR_MSG = mess(34,140,1)-'"'+[F:ACLAF]FLDCLA+'"'-func AFNC.MES2(mess(163,143,1),
 #&             mess(6,7961,1)-mess(7,7961,1)-mess(8,7961,1)-mess(9,7961,1),
 #&             mess(3,7881,1))
 #       Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
 #       Break
 #     Endif
 #    Next J
   Elsif [F:ATY]CODCLA<> ""
    Call CHARGE_CLA_ATI_CLE([L]DOSSIER,[F:ATY]CODCLA,[F:ACLAF]FLDCLA,1,WWCODPAR,WWCODCUR,WWTYPPAR,WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,
& WWNBRPARALL) From SUBACLA
    For I=0 To [L]WWNBRPARALL-1
     Read [ACLFP]ACLFP0 = [L]CODCLA;1;2;[F:ACLAF]FLDCLA;[L]WWCODPAR(I)
      If fstat
        RES_OK = 0
        L_ERR_MSG = mess(34,140,1)-'"'+[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"+'"'-mess(51,140,1)-'"'+[L]WWCODPAR(I)+'" : '+mess(141,143,1) # Valeur non définie.
        Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR)
      Else
        If !func SUBACLA2.L_CHECK_PARAMETER([F:ACLAF]FLDCLA,[F:ACLAF]CODTYP,[F:ACLFP]CODPAR,[F:ACLAF]ACTFLD,[F:ACLFP]VALEUR, [L]WWTYPINTPAR(I), [L]WWADRVAL(I), [F:ACLAF]FLDGRP, [F:ACLFP]CODCLA, 2,
& L_ERR_MSG)
         RES_OK = 0
         L_ERR_MSG = mess(34,140,1)-'"'+[F:ACLFP]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"+'"'-mess(51,140,1)-'"'+[F:ACLFP]CODPAR+'" : '+L_ERR_MSG
         Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR)
        Endif
      Endif
    Next
   Endif
  Elsif [F:ACLAF]CODTYP="" & [F:ACLAF]LNKCLA=""
    RES_OK = 0
    L_ERR_MSG = mess(34,140,1)-'"'+[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"+'"'-mess(183,143,1)
    Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
    Break
  Endif

  ## control dependance
  If [F:ACLAF]TABCONT<>""
   If !func SUBACLA2.L_CHECK_PARAMETER([F:ACLAF]FLDCLA,[F:ACLAF]CODTYP,"TABCONT",[F:ACLAF]ACTFLD,[F:ACLAF]TABCONT,[F:ATY]TYPTYP ,2,[F:ACLAF]FLDGRP, [F:ACLAF]CODCLA,2,[L]ERRMES)
    L_ERR_MSG = mess(34,140,1)-[M:ACLA6]FLDCLA(I)-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"-":"-mess(66,00139,1)-[L]ERRMES
    Call ADD_AERR(L_ERR_MSG,[V]CST_AERROR,0,AERR) From ACLACONTROL
   Endif
  Endif

  If [F:ACLAF]INTFLD=0
   RES_OK = 0
   # Propriété xxx Erreur zone "" : Zone obligatoire
   L_ERR_MSG=mess(34,140,1)-[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"-":"-mess(32,126,1)-'"'+func AMK_TOOL.GET_FIELD_LABEL("ACLA6","ZINTFLD")+'"'
   Call ADD_AERR(L_ERR_MSG-":"-mess(10,123,1),[V]CST_AERROR,0,AERR)
  Endif

  If  [F:ACLAF]INTSHTFLD=0
   RES_OK = 0
   # Propriété xxx Erreur zone "" : Zone obligatoire
   L_ERR_MSG=mess(34,140,1)-[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")"-":"-mess(32,126,1)-'"'+func AMK_TOOL.GET_FIELD_LABEL("ACLA6","ZINTSHTFLD")+'"'
   Call ADD_AERR(L_ERR_MSG-":"-mess(10,123,1),[V]CST_AERROR,0,AERR)
  Endif

  # Collection obligatoire pour un pointeur
  If [F:ACLAF]LNKCLA<>"" & [F:ACLAF]FLDGRP=""
   Call ADD_AERR(mess(63,140,1)-[F:ACLAF]FLDCLA-"("+mess(3,40,1)-num$([F:ACLAF]NUMLIG)+")",[V]CST_AERROR,0,AERR)
  Endif
 Endif
Next
Return

#--------------#
$VERIF_ACLAK
Local Char SAVTABREF(GLONATB) : SAVTABREF = [ACLA]TABREF

For [ACLAK] Where CODCLA = [L]CODCLA

 # 5.0 Origin talbe not referenced
 RES_OK = 0
 If [ACLAK]TABORI=SAVTABREF
  RES_OK = 1
 Endif
 If !RES_OK
  For [ACLAK2] Where CODCLA = [L]CODCLA
   If [ACLAK]TABORI=[ACLAK2]TABLNK
    RES_OK = 1 : Break
   Endif
  Next
 Endif
 If !RES_OK
  Call  ADD_AERR(func AMK_TOOL.GET_FIELD_LABEL("ACLA3", "TABORI")-[F:ACLAK]TABORI+": "+mess(93,139,1),[V]CST_AERROR,0,AERR)
 Endif

 # 5.1 reference "Gestion par classe", the linked class should be persistant
 Read [ACLA2]ACLA0 = [F:ACLAK]CLALNK
 If fstat
  # Classe inexistante
  Call  ADD_AERR(func AMK_TOOL.GET_FIELD_LABEL("ACLA3", "REFLNK")-[F:ACLAK]REFLNK+": "+mess(4,140,1),[V]CST_AERROR,0,AERR)
  OK = 0
 Elsif [F:ACLAK]CLALNK = [L]CODCLA and [F:ACLAK]FLGA = 2
  # Gestion par classe
  Call  ADD_AERR(func AMK_TOOL.GET_FIELD_LABEL("ACLA3", "REFLNK")-[F:ACLAK]REFLNK+": "+func AMK_TOOL.GET_FIELD_LABEL("ACLA3", "FLGA")+": "+mess(153,143,1),[V]CST_AERROR,0,AERR)
  OK = 0
 Elsif !find([F:ACLA2]TYPCLA,2,5) and [F:ACLAK]FLGA = 2
  # Gestion par classe
  Call  ADD_AERR(func AMK_TOOL.GET_FIELD_LABEL("ACLA3", "REFLNK")-[F:ACLAK]REFLNK+": "+func AMK_TOOL.GET_FIELD_LABEL("ACLA3", "FLGA")+": "+mess(153,143,1),[V]CST_AERROR,0,AERR)
  OK = 0
 Endif

 # 5.2 Check REFLNK: the references should be a valide one.
 Call DECODE_PRO([F:ACLAK]REFLNK,0,"PTR",[L]DOSSIER,"","",[F:ACLAK]CODCLA,TABPTR,TABCLA,OBJ,ISACTX,NBCLA) From SUBASW
 If (NBCLA>1 & TABCLA(NBCLA)="") or NBCLA=0
  RES_OK = 0
  Call  ADD_AERR(func AFNC.MES1(mess(112,143,1), [F:ACLAK]REFLNK),[V]CST_AERROR,0,AERR) # Référence $1$ n'est pas valide.
 Else
  If NBCLA>1
   Read [ACLAF]ACLAF0 = TABCLA(NBCLA-1);TABPTR(NBCLA)
  Else
   Read [ACLAF]ACLAF0 = [F:ACLAK]CODCLA;TABPTR(NBCLA)
  Endif
  If !fstat
   If [F:ACLAF]FLDGRP<>""
    Read [ACLAC]ACLAC0 =  [F:ACLAF]CODCLA;[F:ACLAF]FLDGRP
    If !fstat
     WCODCOL =  [ACLAC]CODCOL
     WMINI = [ACLAC]MINCOL-1
     WMAXI = [ACLAC]MAXCOL
    Endif
   Endif
  Endif
  Case [F:ACLAK]TYPLNK
   When 1 : # 0..1
    If WMINI<>0 or WMAXI<>1 : Call  ADD_AERR([ACLAF]CODCLA-":"-[F:ACLAK]REFLNK-":"-mess(98,139,1),[V]CST_AERROR,0,AERR) : RES_OK = 0: Break : Endif : # : type DE LIEN INCORRECT
   When 2 : # 0..n
    If WCODCOL="" : Call  ADD_AERR([ACLAF]CODCLA-":"-[F:ACLAK]REFLNK-":"-mess(98,139,1),[V]CST_AERROR,0,AERR)  :  RES_OK = 0: Break : Endif : # : type DE LIEN INCORREC
   When 3 : # 1..1
    If WMINI<>1 or WMAXI<>1 : Call  ADD_AERR([ACLAF]CODCLA-":"-[F:ACLAK]REFLNK-":"-mess(98,139,1),[V]CST_AERROR,0,AERR) : RES_OK = 0: Break : Endif : # : type DE LIEN INCORRECT
   When 4 : # 1..n
    If WCODCOL="" : Call  ADD_AERR([ACLAF]CODCLA-":"-[F:ACLAK]REFLNK-":"-mess(98,139,1),[V]CST_AERROR,0,AERR)  :  RES_OK = 0 : Break : Endif : # : type DE LIEN INCORRECT
  Endcase
  # Verification that all fields indexes are present in the bodies
  If  [F:ACLAK]TABLNK<>""
   Raz NBRIND,CHPIND
   Read [F:ATI]CODIND =  [F:ACLAK]TABLNK;[F:ACLAK]CLELNK
   If fstat
     RES_OK = 0
    Raz L_ERR_MSG
    L_ERR_MSG += func AMK_TOOL.GET_FIELD_LABEL("ACLA3", "TABLNK")+' "'+[F:ACLAK]TABLNK+'"'
    L_ERR_MSG -= func AMK_TOOL.GET_FIELD_LABEL("ACLA3", "CLELNK")+' "'+[F:ACLAK]CLELNK+'"'
    Call  ADD_AERR(L_ERR_MSG-":"-mess(207,115,1),[V]CST_AERROR,0,AERR)  : #  absent index
   Endif
  Endif
 Endif
Next
Return

#--------------#
Subprog VERIF_CLA_RECURS(DOSSIER,CODCLA,AERR,STA)
Value Char DOSSIER,CODCLA
Variable  Instance  AERR(1..) Using C_AERROR
Variable Integer STA

Local Char TBCLAPARENT(250)(1..)

 For [ACLAF]ACLAF1 Where CODCLA=[L]CODCLA & LNKCLA<>""
  Raz  [L]TBCLAPARENT
  [L]TBCLAPARENT(1)=[L]CODCLA
  Call FIND_SUBCLASS([L]CODCLA,[F:ACLAF]FLDGRP,[L]DOSSIER,[ACLAF]FLDCLA,[ACLAF]LNKCLA,AERR,STA,[L]TBCLAPARENT)
 Next

End

Subprog FIND_SUBCLASS(CODCLA,GROUPE,DOSSIER,FLD,ACLASSE,AERR,STA,TBCLAPARENT)
Value Char       CODCLA,GROUPE
Value Char       DOSSIER
Value Char       FLD
Value Char       ACLASSE
Variable Instance AERR(1..) Using C_AERROR
Variable Integer STA
Variable Char TBCLAPARENT ()(1..)

Local Integer I,M

Local Char    L_ERR_MSG(250)

If find(ACLASSE,[L]TBCLAPARENT)>0
 For I=1 To maxtab(TBCLAPARENT)
  If [L]TBCLAPARENT(I)<>""
   If L_ERR_MSG=""
    L_ERR_MSG=[L]TBCLAPARENT(I)
   Else
    L_ERR_MSG+="/"+[L]TBCLAPARENT(I)
   Endif
  Endif
 Next
 Call  ADD_AERR([L]CODCLA-":"-mess(67,140,1)-"("+ACLASSE+")"+"\"+L_ERR_MSG+"/"+ACLASSE,[V]CST_AERROR,0,AERR)  : # Problème de récursivité des classes
 STA=0
 End
Endif

Local Integer NOCLAFIND
NOCLAFIND=maxtab(TBCLAPARENT)+1
[L]TBCLAPARENT(NOCLAFIND) = ACLASSE

Local File =DOSSIER+".ACLAFLD"    [ACLAF9]
Local Integer N_ACLAF9
Local Char ACLAF9_FLDGRP(GLONAVA) (1..)
Local Char ACLAF9_FLDCLA(GLONAVA) (1..)
Local Char ACLAF9_LNKCLA(GLONACLA) (1..)
For [ACLAF9]ACLAF1 Where CODCLA=ACLASSE & LNKCLA<>""
 N_ACLAF9+=1
 ACLAF9_FLDGRP(N_ACLAF9)=[F:ACLAF9]FLDGRP
 ACLAF9_FLDCLA(N_ACLAF9)=[F:ACLAF9]FLDCLA
 ACLAF9_LNKCLA(N_ACLAF9)=[F:ACLAF9]LNKCLA
Next
Close Local File [ACLAF9]
For I=1 To N_ACLAF9
 Call FIND_SUBCLASS([L]CODCLA,ACLAF9_FLDGRP(I),DOSSIER,ACLAF9_FLDCLA(I),ACLAF9_LNKCLA(I),AERR,STA,TBCLAPARENT)
Next
#On ne doit garder que les parents
[L]TBCLAPARENT(NOCLAFIND) = ""
End

#--------------#
Subprog ADD_AERR(WMES,WSTA,WNUM,AERR)
Value Char WMES
Value Integer WSTA,WNUM
Variable  Instance  AERR(1..) Using C_AERROR
Local Integer I

If WSTA = 0 : WSTA = [V]CST_AERROR : Endif
If WMES =""  : WMES ="unknown error" : Endif
If WNUM = 0 :  WNUM=9101 : Endif

I=maxtab(AERR)+1
AERR(I) = NewInstance C_AERROR AllocGroup AERR
AERR(I).STA = [L]WSTA
AERR(I).MES = [L]WMES
AERR(I).NUM = [L]WNUM

End

#--------------#
Funprog HAS_AERR(AERR)
Variable  Instance  AERR(1..) Using C_AERROR

Local Integer I,HAS_ERR
HAS_ERR=0
For I=1 To maxtab(AERR)
  If AERR(I).STA>[V]CST_AWARNING
   HAS_ERR=1
   Break
  Endif
Next

End HAS_ERR

#--------------#
Subprog TRACE_AERR(AERR)
Variable  Instance  AERR(1..) Using C_AERROR

Local Integer I

For I=1 To maxtab(AERR)
 If AERR(I)<>null
  If AERR(I).STA>[V]CST_AWARNING
   Call ECR_TRACE(AERR(I).MES,1) From GESECRAN
   If GTRACE=""
    Break
   Endif
  Elsif AERR(I).STA=[V]CST_AWARNING
   Call ECR_TRACE(AERR(I).MES,-1) From GESECRAN
  Else
   Call ECR_TRACE(AERR(I).MES,0) From GESECRAN
  Endif
 Endif
Next
End

#--------------#
#RESERVED_NAME_LIST
Subprog RESERVED_NAME_LIST(LIST_NAM)
Variable Char LIST_NAM()(0..)
Local Integer NBRNAM

LIST_NAM(NBRNAM) = "CURPTH" :  NBRNAM+=1 :            # class path
LIST_NAM(NBRNAM) = "CURPRO" :  NBRNAM+=1 :            # class path for property
LIST_NAM(NBRNAM) = "ACTX" :  NBRNAM+=1 :            # class path for property
LIST_NAM(NBRNAM) = "ACTION" :  NBRNAM+=1 :            # method action


LIST_NAM(NBRNAM) = "ADXSQLREC" :  NBRNAM+=1 :            # récupère le statu d’une instruction Execsql
LIST_NAM(NBRNAM) = "extsize"      :  NBRNAM+=1 :             # taille des extents lob sur l’instruction Append
LIST_NAM(NBRNAM) = "ISOMESS" :  NBRNAM+=1 :                      # Nom de la langue courante ISO

# MÉTHODES SYSTEMES :
LIST_NAM(NBRNAM) = "FREESNAPHOT" :  NBRNAM+=1 :                # Libère les instances et les sous-instances snaphot d’une instance donnée
LIST_NAM(NBRNAM) = "freeSysSnapshot" :  NBRNAM+=1 :    # Libère les instances et les sous-instances snaphot système d’une instance donnée
LIST_NAM(NBRNAM) = "getModified" :  NBRNAM+=1 :             # Donne la liste des propriétés modifiée par rapport aux valeurs du snaphot
LIST_NAM(NBRNAM) = "getSysModified" :  NBRNAM+=1 :       # Donne la liste des propriétés modifiée par rapport aux valeurs du snaphot systeme
LIST_NAM(NBRNAM) = "modified" :  NBRNAM+=1 :                    # Méthode appliquée à une propriété, elle indique si la propriété a été modifié sur l’indice
# indiqué par rapport au snapshot.
LIST_NAM(NBRNAM) = "sysModified" :  NBRNAM+=1 :             # Méthode appliquée à une propriété, elle indique si la propriété a été modifié sur l’indice
# indiqué par rapport au snapshot système.
LIST_NAM(NBRNAM) = "revertToSnapshot" :  NBRNAM+=1 : # Recopie les valeurs des snapshots dans l’instance et les sous-instances courantes.
LIST_NAM(NBRNAM) = "REVERTTOSYSSNAPSHOT" :  NBRNAM+=1 :                                       # Recopie les valeurs des snapshots système dans l’instance et les sous-instances courantes.
LIST_NAM(NBRNAM) = "revertUpdTick" :  NBRNAM+=1 :         # Recopie les valeurs des updtick des snaphots dans l’instance et les sous-instances courantes.
LIST_NAM(NBRNAM) = "OBJECTTYPE" :  NBRNAM+=1 :                # Rend une chaîne contenant le nom de la classe de l’instance
LIST_NAM(NBRNAM) = "objectNbs" :  NBRNAM+=1 :                 # Rend le nombre de propriétés d’une instance
LIST_NAM(NBRNAM) = "objectVar" :  NBRNAM+=1 :                  # Rend le nom de nième propriété
LIST_NAM(NBRNAM) = "ALLOCGRP" :  NBRNAM+=1 :                      # Rend le nom du groupe d’allocation de l’instance.

#• PROPRIÉTÉES SYSTÈMES :
LIST_NAM(NBRNAM) = "accessorEnabled" :  NBRNAM+=1 :    # Propriété modifiable qui indique si les accesseurs d’une instance sont actifs ou non.
LIST_NAM(NBRNAM) = "isReadonly" :  NBRNAM+=1 :                 # Propriété modifiable qui indique si une instance est en lecture seule ou non.
LIST_NAM(NBRNAM) = "SNAPSHOT" :  NBRNAM+=1 :                   # Propriété indiquant la référence vers le snapshot de l’instance.
LIST_NAM(NBRNAM) = "snapshotEnabled" :  NBRNAM+=1 :  # Propriété modifiable qui indique si les snapshots sont activés ou non.
LIST_NAM(NBRNAM) = "sysSnapshot" :  NBRNAM+=1 :            # Propriété indiquant la référence vers le snapshot système de l’instance.
LIST_NAM(NBRNAM) = "sysSnapshotEnabled" :  NBRNAM+=1 :                                        # Propriété modifiable qui indique si les snapshots système sont activés ou non.
LIST_NAM(NBRNAM) = "this" :  NBRNAM+=1 :                              # Indique la référence de l’instance elle-même.
LIST_NAM(NBRNAM) = "updTick" :  NBRNAM+=1 :                      # Propriété modifiable renseignée à partir des SetIntances.

#• FONCTIONS SIMPLES :
LIST_NAM(NBRNAM) = "JSONPROTO" :  NBRNAM+=1 :                  # Je ne sais pas, il faudra demander à Darina.
LIST_NAM(NBRNAM) = "cast" :  NBRNAM+=1 :                             # Converti une référence vers un ‘object’ en référence vers une classe donnée.
LIST_NAM(NBRNAM) = "CLACMP" :  NBRNAM+=1 :                       # Compare les valeurs de deux classes de variables. (au sens adonix)
LIST_NAM(NBRNAM) = "datetime$" :  NBRNAM+=1 :                 # Rend la date et heure courante en type Datetime
LIST_NAM(NBRNAM) = "gdatetime$" :  NBRNAM+=1 :               # Converti une chaîne en type Datetime
LIST_NAM(NBRNAM) = "CALLSTACK" :  NBRNAM+=1 :                     # Rend la Ième entrée de la pile d’execution courante.
LIST_NAM(NBRNAM) = "evalueSData" :  NBRNAM+=1 :             # Fonction utilisable dans une clause Where pour l’évaluation de critère sous forme SDATA.
LIST_NAM(NBRNAM) = "getUuid" :  NBRNAM+=1 :                     # Rend un nouvel UUID avec type Uuident.
LIST_NAM(NBRNAM) = "HEAPDMP" :  NBRNAM+=1 :                  # Génère un fichier dump de la heap des objets et rend le path vers ce fichier. (Consultable
# avec LECTRACE)
LIST_NAM(NBRNAM) = "NullUuid" :  NBRNAM+=1 :                     # Rend un UUID nulle de type Uuident.
LIST_NAM(NBRNAM) = "toUuid" :  NBRNAM+=1 :                        # Converti une chaine valide en Uuident
LIST_NAM(NBRNAM) = "XGETCHAR" :  NBRNAM+=1 :                    # Rend le nième caractère d’une chaîne ou d’un clob
LIST_NAM(NBRNAM) = "NewInstance" :  NBRNAM+=1 :                    # Rend une nouvelle instance d’une classe donnée.
LIST_NAM(NBRNAM) = "objectExist" :  NBRNAM+=1 :                       # Rend une valeur 1 si une classe donnée existe ou non. 0 sinon.

#• TYPES DE DONNÉES :
LIST_NAM(NBRNAM) = "UUDIDENT" :  NBRNAM+=1 :                                  # Type UUID
LIST_NAM(NBRNAM) = "Datetime" :  NBRNAM+=1 :                                   # Type Datetime
LIST_NAM(NBRNAM) = "Instance" :  NBRNAM+=1 :                                 # Type référence vers un object

#• INSTRUCTIONS
LIST_NAM(NBRNAM) = "CloseCom" :  NBRNAM+=1 :                                  # Ferme explicitement tous les canaux vers un serveur un port donné.
LIST_NAM(NBRNAM) = "DELETEBYKEY" :  NBRNAM+=1 :                           # Supprime un enregistrement sur sa clé sous condition d’updtick.
LIST_NAM(NBRNAM) = "RewriteByKey" :  NBRNAM+=1 :                         # Modifie un enregistrement sur sa clé sous condition d’updtick.
LIST_NAM(NBRNAM) = "FreeInstance" :  NBRNAM+=1 :                   # Libère une instance ou un Groupe d’allocation d’instance.
LIST_NAM(NBRNAM) = "SyrRecv" :  NBRNAM+=1 :                                       # Envoie une requête vers le serveur Syracuse
LIST_NAM(NBRNAM) = "SyrSend" :  NBRNAM+=1 :                                     # Attend et reçoit une requête du serveur Syracuse
LIST_NAM(NBRNAM) = "SetInstance" :  NBRNAM+=1 :                   # Copie les valeurs d’une instance vers une classe de variable et inversement.

#• CHAMP SYSTÈME DE FICHIER
LIST_NAM(NBRNAM) = "updTick" :  NBRNAM+=1 :                                      # Reçoit le timestamp d’un enregistrement. (non modifiable)


End
