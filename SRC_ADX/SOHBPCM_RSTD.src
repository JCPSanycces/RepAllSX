#<AdxTL>@(#)1.0.0.0 $Revision$
#############################################################################
# Traitement SOHBPCM_RSTD : Liste commandes --> 3 onglets sur mobile        #
#   Classe représentation SOHBPCM : Liste des cdes (3 onglets sur mobile)   #
#   Classe données        SOHBPCM : Liste des cdes (3 onglets sur mobile)   #
#       Nota : le champ THIS.TESTJDE est dispo pour test                    #
#############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When ""
        Case [L]AEVENT
          When "AQUERY_TRANS_AFTER"    : Gosub AQUERY_TRANS_AFTER      : #-- Permet d'alimenter la query avant affichage         --#
          When "AREAD_AFTER"           : Gosub AREAD_AFTER             : #-- Lecture supplementaire avant affichage Détail       --#
        Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return
#--------------------------------------
#####################################################################
## $AQUERY_TRANS_AFTER : Alimente propriétés exposées de la query  ##
#####################################################################
$AQUERY_TRANS_AFTER

Local File ATEXTRA   [AXX]
Local File FACILITY  [FCY]

#-- Site vente --#
this.WSALFCY   = this.SOQ.SALFCY
Read [FCY]FCY0 = this.SOQ.SALFCY
If !fstat
   this.WSALFCY  -= '(' + [F:FCY]FCYSHO + ')'
Endif

#-- Site expédition --#
this.WSTOFCY   = this.SOQ.STOFCY
Read [FCY]FCY0 = this.SOQ.STOFCY
If !fstat
   this.WSTOFCY  -= '(' + [F:FCY]FCYSHO + ')'
Endif

#-- Article --#
this.WITMREF  = this.SOQ.ITMREF
Gosub DES_ARTICLE

Return

#####################################################################
## $AREAD_AFTER : Alimente propriétés exposées du détail           ##
#####################################################################
$AREAD_AFTER

Local File BPCUSTOMER [BPC]
Local File ATEXTRA    [AXX]
Local File BPARTNER   [BPR]
Local File SORDERP    [SOP] : #-- Commandes de vente - Prix --#

#-- Lecture BPC (client) pour la ligne de commande --#
Read [F:BPC]BPC0=this.SOQ.BPCORD
this.WBPCNAM = [F:BPC]BPCNAM

#-- Calcul somme de plusieurs zones : Qté liste prépa (LPRQTY) + Qté en prépa (OPRQTY) + Qté préparé (PREQTY) --#
this.WQTYPREENC  = this.SOQ.LPRQTY  + this.SOQ.OPRQTY + this.SOQ.PREQTY

#-- Alim propriété exposées depuis ATEXTRA --#
Gosub DES_ARTICLE

#-- Unité de vente et de stock --#
Read [SOP]SOP0 = this.SOQ.SOHNUM;this.SOQ.SOPLIN;this.SOQ.SOQSEQ
If !fstat
   this.WSAU = [F:SOP]SAU
Endif

Return

#################################################
## $DES_ARTICLE : Lecture désignation article  ##
#################################################
$DES_ARTICLE

Read [AXX]AXX0 = "ITMMASTER";"DES1AXX";this.ACTX.LAN;this.SOQ.ITMREF;""
If !fstat
   this.WITMDES  =  [F:AXX]TEXTE
Endif

Return


##############################
## $PROPERTIES              ##
##############################
$PROPERTIES
  Case CURPRO
    When Default
  Endcase
Return

