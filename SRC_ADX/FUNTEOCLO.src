#<AdxTL>@(#)5.0.0.0 $Revision$
#########################################################################
#                                                                       #
# Fonction de Clôture/Solde en série   (selon FUNTDUCLO et FUNMFGS)     #
#                                                                       #
# Actions:                                                              #
# - TRTTEOCLO  : Action traitement de Clôture/Solde en série            #
# - TRTCLESCO  : Action traitement de Solde Ordre de sous-traitance     #
#   PARAM(1) = WSCONUM : Référence de l'ordre de sous-traitance         #
#                                                                       #
#########################################################################
# Subprog MAJ_SOLDE: Transaction de solde d'un ordre de sous-traitance  #
#                    Après l'appui sur le bouton "Solde"                #
#########################################################################
# Subprog TRTCLESCO(LSCONUM) Solde   d'un ordre de sous-traitance       #
# Subprog TRTCLOSCO(LSCONUM) Cloture d'un ordre de sous-traitance       #
#                                                                       #
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "OUVRE_BATCH": Gosub OUVRE_BATCH  : # Issue 89575 GA 11/2013 trt "batchable"
 When "EXEC"       : Gosub EXEC         : # Issue 89575 GA 11/2013 trt "batchable"
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "TERMINE"    : Gosub TERMINE
 When Default
Endcase

# Actions liées à la saisie fenêtre
Case ACTION
 When "SETBOUT"       : Gosub SETBOUT   : # Issue 89575 GA 11/2013 ajout [M:DIA]WTRAIT
 When "BOUTON"        : Gosub BOUTON
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "FIN"           : Gosub FIN
 When Default
Endcase

Return

#########################################################################
#    Actions liés au type traitement et affichage divers                #
#########################################################################
$INIT
#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev ([F:FCY]) = 0 : Local File FACILITY    [FCY] : Endif
If clalev ([F:ITM]) = 0 : Local File ITMMASTER   [ITM] : Endif
If clalev ([F:ITF]) = 0 : Local File ITMFACILIT  [ITF] : Endif
If clalev ([F:ITV]) = 0 : Local File ITMMVT      [ITV] : Endif
If clalev ([F:ITG]) = 0 : Local File ITMCATEG    [ITG] : Endif
If clalev ([F:TUN]) <= 0 : Local File TABUNIT    [TUN] : Endif
If clalev ([F:ORD]) <= 0 : Local File ORDERS     [ORD] : Endif
If clalev ([F:POQ]) <= 0 : Local File PORDERQ    [POQ] : Endif
If clalev ([F:STJ]) <= 0 : Local File STOJOU     [STJ] : Endif
#If clalev ([M:OPSK])<= 0 : Local Mask OPSK       [OPSK]: Endif  # FQ 76170 GA 09/2011
If clalev ([M:ORDK])<= 0 : Local Mask ORDK       [ORDK]: Endif

Gosub CHARG_PARAM
Gosub STK_INILOC From STKLOC
#Gosub OPEN_FILES_SCO From SCOLIB cf CHARG_PARAM

Return

#########################################################################
$INIT_DIA

Raz [M:DIA]
Call FIND_GFCYDEF(6) From TRTX3   # FQ 54218
[M:DIA]WPOHFCY = GFCY
Gosub CHARG_PARAM                 # mm 12.02
Affzo [M:DIA]


#NSH-added test
#Infbox "in init_dia"
#    If GMODU(8) <> 20
#       Diszo [M:DIA]PRFFLG
#    Endif
#NSH end added test

Return


#########################################################################
$OUVRE
Local    Char     CRITERE(250), CRITSUP(250), CUSFLT(250)
Local    Integer  REPONSE
Local    Integer  WOK
Local    Char     WMESS1(80)
Local    Integer  NBMODIF

Global   Integer  GSTOP
Global   Integer  GGIVE_UP
Global    Char    GWMESS2(250)
Global   Char     GWAICTL(2)

Raz CRITERE, CRITSUP

Gosub SEL_EO

Return

#########################################################################
$SEL_EO

# Criteres de selection

CRITERE = "[F:SCO]SCOSTA = 1"

CRITERE -= ' & [F:SCO]POHFCY = "' +[M:DIA]WPOHFCY+'"'

# N° EO
If [M:DIA]WNUMDEB <> ""
     CRITERE -= ' & [F:SCO]SCONUM >= "' +[M:DIA]WNUMDEB+'"'
Endif
If [M:DIA]WNUMFIN <> ""
    CRITERE -= ' & [F:SCO]SCONUM <= "' +[M:DIA]WNUMFIN+'"'
Endif

# Dates
If [M:DIA]WDATDEB <> [0/0/0]
   CRITERE -= ' & [F:SCO]ORDDAT >= [' +format$(GFMD,[M:DIA]WDATDEB)+']'
Endif
If [M:DIA]WDATFIN <> [0/0/0]
   CRITERE -= ' & [F:SCO]RETDAT <= [' +format$(GFMD,[M:DIA]WDATFIN)+']'
Endif

# article
If [M:DIA]WITMDEB <> ""
   CRITERE -= ' & [F:SCI]ITMREF >= "' +[M:DIA]WITMDEB+'"'
Endif
If [M:DIA]WITMFIN<> ""
   CRITERE -= ' & [F:SCI]ITMREF <= "' +[M:DIA]WITMFIN+'"'
Endif

# affaire
If [M:DIA]WPJTDEB <> ""
    CRITERE -= ' & [F:SCI]PJT >="'+[M:DIA]WPJTDEB+'"'
Endif
If [M:DIA]WPJTFIN <> ""
    CRITERE -= ' & [F:SCI]PJT <="'+[M:DIA]WPJTFIN+'"'
Endif

# FQ 59339 GA 11/2009 avant BPSNUM (+ écran TEOSEL1 corrigé aussi)
# fournisseur
If [M:DIA]WBPSDEB <> ""
    CRITERE -= ' & [F:SCO]BPRNUM >="'+[M:DIA]WBPSDEB+'"'
Endif
If [M:DIA]WBPSFIN <> ""
    CRITERE -= ' & [F:SCO]BPRNUM <="'+[M:DIA]WBPSFIN+'"'
Endif

CRITSUP = "1=1"
# commande de Vente
If [M:DIA]WSOHDEB <> ""
    CRITSUP -= ' & [F:SCI]VCRTYPORI = 2'
    CRITSUP -= ' & [F:SCI]VCRNUMORI = "' +[M:DIA]WSOHDEB+'"'
Endif
If [M:DIA]WSOHFIN <> ""
   CRITSUP -= ' & [F:SCI]VCRTYPORI = 2'
   CRITSUP -= ' & [F:SCI]VCRNUMORI = "' +[M:DIA]WSOHFIN+'"'
Endif

# commande d'achat
If [M:DIA]WPOHDEB <> ""
    CRITSUP -= ' & [F:SCI]ITMSTA = 3'
    CRITSUP -= ' & [F:SCI]POHNUM = "' +[M:DIA]WPOHDEB+'"'
Endif
If [M:DIA]WPOHFIN <> ""
   CRITSUP -= ' & [F:SCI]ITMSTA = 3'
   CRITSUP -= ' & [F:SCI]POHNUM = "' +[M:DIA]WPOHFIN+'"'
Endif


# Filtre Ordre de sous-traitance Soldé
If [M:DIA]CLOSED = 2
   CRITSUP -= ' & [F:SCO]SCOTRKFLG = 5 '
Endif

# Filtre Article lancé non produit
If [M:DIA]LANFLG = 2
   CRITSUP -= ' & [F:SCI]EXTQTY > 0 & [F:SCI]CPLQTY > 0 '
Endif

# Filtre Qté réalisée < Qté prévue
If [M:DIA]QTYFLG = 2
   CRITSUP -= ' & [F:SCI]CPLQTY >= [F:SCI]EXTQTY '

Endif

Return
#########################################################################
$SETBOUT                     # Issue 89575 GA 11/2013 ajout [M:DIA]WTRAIT

If dim([M:DIA]WTRAIT)>0 & !GBATCH
# ------------------------------------------------------------------------------------- #
# Boutons bas d'écrans                                                                  #
# ------------------------------------------------------------------------------------- #
   Case [M:DIA]WTRAIT
     When 2 : Call VIREBOUT(CHMEN,"2") From GOBJET # Solde
     When 3 : Call VIREBOUT(CHMEN,"1") From GOBJET # Clôture
     When Default :
   Endcase
   Gosub SET_BOUT_SPE From GSAISIE
Endif

Return


#########################################################################
$DEBUT

Local Char    TIT(50) : Call TEXTE(23553,TIT) From OBJDIV    # "Clôture/solde en série"
Default Mask [EOS1]

Gosub LIRE
If [M:EOS1]NBLIG=0
    GERR=2 : GMESSAGE=mess(910,196,1)
    FIN=1
Endif

#
Return

#########################################################################
$LIRE
Local Integer WRET,WOPE,WITM,WMAT
Local Char LWAICTL(2)   # Issue 99496 - 2014-10-31 by CCC

REP=""
Raz [M:EOS1]
If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Elsif GSERVEUR                         # Issue 89575 GA 11/2013 trt "batchable"
    Local Char    WTIT(50) :  Call TEXTE(23553,WTIT) From OBJDIV    # "Clôture/solde en série"
    Call ECR_TRACE(WTIT-"-"-mess(3,45,1)-[M:DIA]WPOHFCY,0) From GESECRAN
Endif

Raz CUSFLT
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif

# GA 01/2010 remplacement de [F:VEO] par un Link que (cf FUNTDUCLO pour les OF)
#Filter [F:VEO] Where evalue(CRITERE) & evalue(CRITSUP)
#nolign = 0
#For [F:VEO]
Link [F:SCI] With [F:SCO]SCO0 = [F:SCI]SCONUM As [XPEO]
Filter [F:XPEO] Where evalue(CRITERE) & evalue(CRITSUP) & evalue(CUSFLT)
nolign = 0
For [XPEO]
    GPE = 0
    GPOINT="CHECKPEO" : Gosub ENTREE From EXEFNC
    If GPE : Goto SUIV : Endif

    # la situation de l'ordre doit être au moins encours
    If [F:SCO]SCOTRKFLG < 4 : Goto SUIV : Endif

    Read [F:SCS]SCS0 = [F:SCO]SCONUM;[F:SCI]SCILIN
    If fstat     : Raz [F:SCS] : Endif

    Raz WRET,WOPE,WITM,WMAT
    # Issue 84906 GA 01/2013 pas de solde de l'EO si commande non soldée
    #If [M:DIA]POHFLG = 2
     # Ctrl si commande d'achat en cours, non soldée
       Call CTRL_POH_CLEFLG(WRET,WOPE,WITM)
       If WRET=1 : Goto SUIV : Endif
    #Endif
    If [M:DIA]CNSFLG = 2
     # Ctrl si matière non consommée
       Call CTRL_SCM_USEQTY(WRET,WMAT)
       If WRET=2 : Goto SUIV : Endif
    Endif

    # Issue 99496 - 2014-11-03 by CCC : pending transaction control
    #       We can use [F:SCI]PRHFCY because all components come from the same company as product
    #       and EOMMVTWAI is defined by company
    If [M:DIA]WTRAIT=3
        Raz LWAICTL
        Call PARAM([F:SCI]PRHFCY, "EOMMVTWAI", LWAICTL) From ADOVAL
        If LWAICTL="2" & func CTRL_WAITRS_EO([F:SCO]SCONUM)
            Goto SUIV
        Endif
    Endif

    Read [F:ITM]ITM0 = [F:SCI]ITMREF
    If !fstat
        nolign += 1
        If nolign >= dim([M:EOS1]ITMREF) : Break : Endif
        [M:EOS1] = [F:SCO]
        [M:EOS1] = [F:SCI]
        [M:EOS1]SRVITMREF(nolign-1) = [F:SCS]SRVITMREF
        [M:EOS1]WPOHFCY = [F:SCO]POHFCY
   Endif
$SUIV
Next
Filter [F:XPEO]
[M:EOS1]NBLIG= nolign
Affzo [M:EOS1]

Return

#########################################################################
$BOUTON
Case BOUT
    When "1" : Gosub SOLDE   : FIN=1
    When "2" : Gosub CLOTURE : FIN=1
    When "3" : Gosub INCLUDE
    When "4" : Gosub EXCLUDE
Endcase
Return

#########################################################################
$SOLDE

Call TEMPON("V") From GESECRAN
If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif

NBMODIF =0
For nolign=1 To [M:EOS1]NBLIG
    GSTOP=0
    GGIVE_UP=0
    GWMESS2= ""
    If [M:EOS1]SCOTRKFLG(nolign-1)>=4 & [M:EOS1]FMODIF(nolign-1)= 2
        Call TRTCLESCO([M:EOS1]SCONUM(nolign-1))
        If GSTOP =0
            WMESS1=mess(641,197,1)-[M:EOS1]SCONUM(nolign-1)-mess(3,279,1)
            Call ECR_TRACE(WMESS1,0) From GESECRAN
            If GWMESS2 <>"" : Call ECR_TRACE(GWMESS2,0) From GESECRAN : Endif
            NBMODIF +=1
        Else
           If GGIVE_UP= 0
              If  GWMESS2 <>"" : Call ECR_TRACE(GWMESS2,-1) From GESECRAN : Endif
           Else
              WMESS1=mess(641,197,1)-[M:EOS1]SCONUM(nolign-1)-":"-mess(7,21,1)
              Call ECR_TRACE(WMESS1,1) From GESECRAN
           Endif
        Endif
    Endif
Next

If NBMODIF
    WMESS1=num$(NBMODIF)-mess(362,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Else
    WMESS1=mess(371,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Endif


Call TEMPOFF From GESECRAN
Return


#########################################################################
$CLOTURE


Call TEMPON("V") From GESECRAN
If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif


# Issue 99496 - 2014-11-03 by CCC : We can use [M:EOS1]WPOHFCY because all components come from the same company
#                                   and EOMMVTWAI is defined by company
Raz GWAICTL
Call PARAM([M:EOS1]WPOHFCY, "EOMMVTWAI", GWAICTL) From ADOVAL

NBMODIF =0
For nolign=1 To [M:EOS1]NBLIG
    GSTOP=0
    GGIVE_UP=0
    GWMESS2= ""
    If [M:EOS1]FMODIF(nolign-1)= 2
        Call TRTCLOSCO([M:EOS1]SCONUM(nolign-1),[M:DIA]PRFFLG)
        If GSTOP =0
            WMESS1=mess(641,197,1)-[M:EOS1]SCONUM(nolign-1)-":"-mess(3,17,1)
            Call ECR_TRACE(WMESS1,0) From GESECRAN
            NBMODIF +=1
            If GWMESS2 <>"" : Call ECR_TRACE(GWMESS2,0) From GESECRAN : Endif
        Else
           If GGIVE_UP= 0
              If  GWMESS2 <>"" : Call ECR_TRACE(GWMESS2,-1) From GESECRAN : Endif
           Else
              WMESS1=mess(641,197,1)-[M:EOS1]SCONUM(nolign-1)-":"-mess(7,21,1)
              Call ECR_TRACE(WMESS1,1) From GESECRAN
           Endif
        Endif
    Endif
Next

Call ECR_TRACE(" ", 0) From GESECRAN
If NBMODIF
    WMESS1=num$(NBMODIF)-mess(362,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Else
    WMESS1=mess(371,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Endif


Call TEMPOFF From GESECRAN
Return

#########################################################################
$INCLUDE
Local Integer I
For I = 0 To [M:EOS1]NBLIG-1
    [M:EOS1]FMODIF(I) = 2
Next
Affzo [M:EOS1]10
Return

#########################################################################
$EXCLUDE
Local Integer I
For I = 0 To [M:EOS1]NBLIG-1
    [M:EOS1]FMODIF(I) = 1
Next
Affzo [M:EOS1]10
Return

#########################################################################
$TERMINE
# FQ 66881 GA 09/2010 Cloture / Solde en batch
If !GSERVEUR
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif
Return

#######################################################################
$FIN
#--- Sup. des globales propres à ce traitement
If dim(GSTOP)>0         : Kill  GSTOP       : Endif
If dim(GWMESS2)>0       : Kill  GWMESS2     : Endif
If dim(GWAICTL)>0       : Kill  GWAICTL     : Endif


Return

#########################################################################
$OUVRE_BATCH                 # Issue 89575 GA 11/2013 trt "batchable"
If !GBATCH Return Endif
Local Mask TEOSEL0 [M:DIA]
Gosub INIT_DIA
[M:DIA]WTRAIT=2 : Affzo [M:DIA]WTRAIT
Return
#########################################################################
$EXEC                        # Issue 89575 GA 11/2013 trt "batchable"

# En batch , il vaut mieux mettre onerrgo # Issue 89575 GA 11/2013
If GSERVEUR
    Onerrgo ERRBATCH
Endif

If GSERVEUR
   If clalev([M:EOS1])=0 Local Mask TEOSEL1  [EOS1] Endif
   #Gosub INIT  # déjà ok
   Gosub OUVRE
   Gosub DEBUT
   Gosub INCLUDE
   # Issue 113046 - 2015-12-10 by SR : Init CLODAT
   [M:EOS1]CLODAT = date$
   Case [M:DIA]WTRAIT
     When 2 : Gosub SOLDE   : FIN=1
     When 3 : Gosub CLOTURE : FIN=1
     When Default : Call ECR_TRACE("Aucun traitement demandé ?",1) From GESECRAN
   Endcase
Endif


Return
##########################################################################
# pour les batchs                                                        #
##########################################################################
Subprog PARAM(DOSSIER,USER,P1,P2,OK)
#-----------------------------#
# obligatoire pour les batchs #
#-----------------------------#
Value    Char    DOSSIER   : # dossier de lancement
Value    Char    USER      : # utilisateur
Variable Char    P1()(1..) : # on peut avoir 2 fois 50 chaînes de 15 caractères
Variable Char    P2()(1..)
Variable Integer OK

Local Char    WIN (GLONFEN)
WIN="DTEOCLO"
Call PARAM (DOSSIER,USER,P1,P2,OK,TIT,WIN) From CPTTRT

Call TRACE_DEBUG("Paramètres batch: site="-[M:DIA]WCRFCY)

End
###########################################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

#########################################################################
$CHARG_PARAM
#----- Variables globales
Call GLOBVAR(GFCY)    From WWGLOBSTO
Call GLOBVAR(GFCY)    From WWGLOBACH
If GMODU(8)=2
   Call GLOBVAR(GFCY)    From WWGLOBGPA
Endif
#
Gosub OPEN_FILES_SCO From SCOLIB
If clalev ([F:STA]) <= 0 : Local File STOALL     [STA] : Endif
If clalev ([F:STO]) <= 0 : Local File STOCK      [STO] : Endif
If clalev ([F:STL]) <= 0 : Local File STOLOT     [STL] : Endif
If clalev ([F:TRU]) <= 0 : Local File TABALLRUL  [TRU] : Endif
If clalev ([F:SRU]) <= 0 : Local File TABSTORUL  [SRU] : Endif
If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif
#
If clalev ([M:STW] )<= 0 : Local Mask STOWORK    [STW] : Endif  # masque STOCK
If clalev ([M:SVW] )<= 0 : Local Mask STOVALWORK [SVW] : Endif
If clalev ([M:VALW])<= 0 : Local Mask STOVALW    [VALW]: Endif
If clalev ([M:ENTW])<= 0 : Local Mask STOENTW    [ENTW]: Endif  # masque de travail entrée
If clalev ([M:SOW] )<= 0 : Local Mask STOSORW    [SOW] : Endif  # masque de travail sorties
If clalev ([M:ALP] )<= 0 : Local Mask ALLPAR     [ALP] : Endif  # masque de travail sorties
#
Return
##########################################################################
Subprog TRACE_DEBUG(LMESS)
Value Char LMESS
If GUSER="GAxxx"
  If GSERVEUR | GBATCH
     Call ECR_TRACE(LMESS,0) From GESECRAN
  Endif
Endif
End


##########################################################################
Subprog IB_NBLIG
Local Integer L : L = nolign-1
If L>= 0
    GBOUT1 = mess(473,198,1)
Endif

End


######################################################################################
## Etiquette ajoutée par le superviseur (écran TEOSEL1) 06/03/2006 16:07:03 (GA)
######################################################################################
Subprog C_CLODAT(VALEUR)
Variable Date    VALEUR
End

Subprog AS_CLODATDET(VALEUR)
Variable Date    VALEUR
End

Subprog C_CLODATDET(VALEUR)
Variable Date    VALEUR
End


######################################################################################

Subprog TRTCLESCO(VCRNUM)
Value    Char    VCRNUM
  If [F:SCO]SCONUM<>VCRNUM
     Read [F:SCO]SCO0 = VCRNUM
     If fstat : Raz [F:SCO] : GERR=1 : End : Endif
  Endif
  Gosub SOLDE_EO
End

Subprog TRTCLOSCO(VCRNUM,CALMFC)
Value    Char    VCRNUM
Value    Integer CALMFC

Read [F:SCO]SCO0 = VCRNUM
If fstat : Raz [F:SCO] : End : Endif
Gosub CLOTURE_EO

# Issue 99496 - 2014-11-07 by CCC : Like Work orders : propose to calculate cost
If [F:SCO]SCOSTA=4 & CALMFC=2
    SAV_GFONCTION = GFONCTION
    GFONCTION="FUNWIPMFC"
    Call AUTORIS From EXEFNC
    If GNBAUZ>0
        If clalev([F:SCI])=0 : Local File SCOITM [SCI] : Endif
        Filter [SCI] Where SCONUM=VCRNUM
        Read [SCI] First
        Filter [SCI]
        Call CALMFC([F:SCI]PRHFCY,36,VCRNUM) From FUNWIPMFC
    Endif
    GFONCTION=SAV_GFONCTION
    Call AUTORIS From EXEFNC
Endif

End

######################################################################################
# Clôture EO - selon CLOTURE_OF de FUNMFGS
######################################################################################
$CLOTURE_EO
Local Integer OK,LRET,LOPE,LITM,LMAT,WAUTO,STAT
Local Integer WOPECLENBR, WITMCLENBR, WMATCLENBR
Local Decimal WQTYCONS,WWQTYCONS,WRAPP,WWQTY, WCOEFF
Local Char    WNUMTEX(12)
Local Integer WRETOUR,STAT, WFICFLG
Local Char    WMSG(80)
#If dim(GCTLCLE)<0 : Local Integer GCTLCLE : GCTLCLE=0   : Endif # Issue 79167 use GCTLOERCLE
If dim(GCLODAT)<0 : Local Date    GCLODAT : Raz GCLODAT : Endif
#
# sr 10.04 demande 23789
Local Integer WTRTTYP
WTRTTYP = 2

Raz WMSG
# 11552 11.03 MM : fonction clôture EO en série, sans message d'avertissement
If dim(GSTOP)<0
    #"Clore l'ordre de sous-traitance ?"
    Call OUINON(mess(912,196,1),OK) From GESECRAN
    If OK <> 2 : Return : Endif
Endif
GCLODAT = [M:EOS1]CLODAT

Raz WAUTO
#WAUTO = 0 : On ne suit pas automatiquement les matières
#WAUTO = 1 : On suit automatiquement les matières

Raz LRET,LOPE,LITM,LMAT
Local Char LWAICTL(2)   # Issue 99496 - 2014-10-31 by CCC

If dim(GSTOP)>0
  # Activer la post-consommation des matières
  If [M:DIA]MATFLG = 2
      WAUTO=1
  Endif

    # Issue 99496 - 2014-10-31 by CCC
    If dim(GWAICTL)>0
        LWAICTL=GWAICTL
    Else
        Raz LWAICTL
        Call PARAM([F:SCS]PRHFCY, "EOMMVTWAI", LWAICTL) From ADOVAL
    Endif
    If LWAICTL="2" & func CTRL_WAITRS_EO([F:SCO]SCONUM)
        Call ECR_TRACE(mess(477,194,1),0) From GESECRAN
        GSTOP=1
        GGIVE_UP=1
        Return
    Endif
Else
# cas de cloture EO en série: Ctrl déjà pris en compte au niveau des critères de sélection

# Les conditions permettent-elles de clore l'EO ?
# ----------------------------------------------
  Call CTRL_VALID(LRET,LOPE,LITM,LMAT)

  If LOPE = 1
  # Issue 84906 GA 01/2013: pas de clôture si opé commandée non soldée
  ##  # Issue 79167 use GCTLOERCLE
  ##  # "Une opération de sous-traitance est commandée ou en cours. Solde impossible "
  ##  Case GCTLEORCLE
  ##      When 1,2
  ##           # Issue 83821 GA 10/2012 message plus explicite
  ##           Call AVERTIR(mess(431,194,1),OK) From GESECRAN
  ##           If OK <> 2 : Return : Endif
  ##      When Default
             Call ERREUR(mess(93,193,1)) From GESECRAN
             Return
  ##  Endcase
  Endif

  If LITM = 1
     # "Au moins un article lancé n'a pas été produit"
     # Issue 83821 GA 10/2012 message plus explicite
        Call AVERTIR(mess(432,194,1),OK) From GESECRAN
        If OK <> 2 : Return : Endif
  Endif

  If LMAT = 1
    # Issue 79167 use GCTLOERCLE instead of GCTLCLE
    # "Au moins une matière n'a pas été consommée"
    Case GCTLEORCLE
        When 1,3
            # Issue 83821 GA 10/2012 message plus explicite
             Call AVERTIR(mess(433,194,1),OK) From GESECRAN
             If OK <> 2 : Return : Endif
        When Default
             Call ERREUR(mess(83,190,1)) From GESECRAN
             Return
    Endcase
  Endif

  # Y-a-t-il des matières à mode de déstockage automatique non soldées ?
  # --------------------------------------------------------------------
  #GA If [F:SCO]CPLQTY = 0 | [F:MTS]MATTRKFLG <> 2 : WAUTO = 0
  If [F:SCI]CPLQTY = 0 : WAUTO = 0
  Else Call CTRL_MAT(LRET)
    If LRET > 0
       Local Date WDATE : WDATE = date$
       Call STKCTRIPT(WDATE,[F:SCO]POHFCY,"1") From STKLIB
       If GMESSAGE = ""
          Raz OK
          Call OUINON(mess(207,190,1),OK) From GESECRAN
          If OK = 2 : WAUTO = 1 : Endif
       Endif
    Endif
  Endif

    # Issue 99496 - 2014-11-03 by CCC : pending transaction control
    Raz LWAICTL
    Call PARAM([F:SCS]PRHFCY, "EOMMVTWAI", LWAICTL) From ADOVAL
    If LWAICTL="2" & func CTRL_WAITRS_EO([F:SCO]SCONUM)
        Call ERREUR(mess(477,194,1)) From GESECRAN
        Return
    Endif
Endif

# étiquette (technique) pour faciliter l'ingénierie
$CLOTURE_SUITE
#----- Variables globales
Gosub CHARG_PARAM
#
Call DEBTRANS From GLOCK
Trbegin [SCO]
#----------------------- Solde opération -----------------------------#
Filter [F:SCS] Where SCONUM =[F:SCO]SCONUM
For [F:SCS]

    Gosub SOLDE_OPE
    Gosub REWRITE_SCS From SCOLIB
Next
If GOK < 1 : Goto TR_ROLLCLO : Endif
Filter [F:SCS]

#----------------------- Solde de l'article lancé -----------------------------#
# Issue 85502 GA 11/2012 raz modif 84355 on solde car l'utilisateur a choisi de le faire
# Issue 84355 GA 09/2012 sauf si Article Commandé ITMSTA=3
Filter [F:SCI] Where SCONUM = [F:SCO]SCONUM
For [F:SCI]

    Gosub SOLDE_ITM
    Gosub REWRITE_SCI From SCOLIB
Next
If GOK < 1 : Goto TR_ROLLCLO : Endif
Filter [F:SCI]

#----------------------- Solde des matières   -----------------------------#
Filter [F:SCM] Where SCONUM = [F:SCO]SCONUM #### & MATSTA <> 4 & CPNTYP <> 5 & SCOFLG=2
Local Integer WMATSOL
Raz WMATSOL
For [F:SCM]
    Gosub SOLDE_MAT
    If GOK < 1 : Break : Endif
    Gosub REWRITE_SCM From SCOLIB
Next
If GOK < 1 : Goto TR_ROLLCLO : Endif
Filter [F:SCM]

# Issue 82823 GA 06/2012 idem FUNMFGS
Call CREWIPCPNVAL([F:SCO]SCONUM)
If GOK < 1 : Goto TR_ROLLCLO : Endif

# Issue 89606 remplacement de [M]SCONUM Ko
#----------------------- Maj  Entête EO ------------------------------------#
Readlock [F:SCO]SCO0 Curr
If fstat=1  GOK=-1 : GLOCK="$SCOHEAD"-[F:SCO]SCONUM : Goto TR_ROLLCLO
Elsif fstat GOK=0  : Call RSTA("SCO",[F:SCO]SCONUM) From GLOCK : Goto TR_ROLLCLO
Endif
[F:SCO]OPECLENBR += WOPECLENBR
If [F:SCO]OPECLENBR > [F:SCO]OPELINNBR : [F:SCO]OPECLENBR = [F:SCO]OPELINNBR : Endif
[F:SCO]MATCLENBR += WMATCLENBR
If [F:SCO]MATCLENBR > [F:SCO]MATLINNBR : [F:SCO]MATCLENBR = [F:SCO]MATLINNBR : Endif
[F:SCO]ITMCLENBR += WITMCLENBR
If [F:SCO]ITMCLENBR > [F:SCO]ITMLINNBR : [F:SCO]ITMCLENBR = [F:SCO]ITMLINNBR : Endif
[F:SCO]SCOTRKFLG = 5

[F:SCO]SCOSTA= 4
[F:SCO]CLODAT = GCLODAT

Gosub REWRITE_SCO From SCOLIB
If GOK > 0
  #----- MISE à jour Entête de Wipcost: date de dernier suivi -----#
  If !clalev([F:MWH])  : Local File MFGWIP    [MWH]  : Endif
  Readlock [MWH]MWH0=36;[F:SCO]SCONUM
  If fstat=1  GOK=-1 : GLOCK="$MFGWIP 36;"-[F:SCO]SCONUM : Goto TR_ROLLCLO
  Elsif !fstat
    [F:MWH]MFGTRKFLG = [F:SCO]SCOTRKFLG
    [F:MWH]TRKLAST   = date$
    Rewrite [MWH]
    If fstat
       GOK = 0 : Call FSTA("MWH") From GLOCK : Goto TR_ROLLCLO
    Endif
  Endif
  Commit
  Goto FINCLO
Endif

$TR_ROLLCLO
Rollback
If dim(GGIVE_UP)>0 : GGIVE_UP=1 : GSTOP=1 : Endif

$FINCLO
# 11552 11.03 MM : fonction solde EO en série, sans message d'avertissement
If dim(GWMESS2)>0
    If WMSG <> "" : GWMESS2 = WMSG : Return : Endif
Else
    If WMSG <> "" : Call MESSAGE(WMSG) From GESECRAN : Endif
Endif
If dim(GCLODAT)>0       : Kill  GCLODAT     : Endif
Return

###########################################################################
$SOLDE_ITM
If [F:SCI]ITMSTA <> 5
   Gosub SCI_ITMSTA_CLO From SCOLIB

   # v6 affectations
   Gosub SUP_MTO_SCI From SCOMTOLIB

 # Maj encours
   Call UPDATE_EOX("A") From SCOLIB
   If GOK < 1 : Return : Endif

   WITMCLENBR += 1
Endif
Return

###########################################################################
$SOLDE_OPE
If [F:SCS]OPESTA <> 3   # Issue 90024 GA 05/2013 avant 5
   Gosub SCS_OPESTA_CLO From SCOLIB

   Call UPDATE_SCX("A") From SCOLIB
   If GOK < 1 : Return : Endif

   WOPECLENBR += 1
Endif
Return

##############################################################
# selon SOLDE_MAT de FUNMFGS
#Solde d'une matière . Traitement appelé aussi depuis ???
##############################################################
$SOLDE_MAT
Local Integer WCUNFLG
#Local        Integer WNO_REAJUST : Raz WNO_REAJUST
#Local        Decimal LQTA, LSHT, LDIS
#Local        Integer LNBR, LNBJ, LRET, J
#Local        Decimal WWALLQTY,WWSHTQTY
#Local Char   WCCE(20)


Read [F:ITM]ITM0 = [F:SCM]CPNITMREF
If fstat : Raz [F:ITM] : Endif
Read [F:ITF]ITF0 = [F:SCM]CPNITMREF;[F:SCM]STOFCY
If fstat : Raz [F:ITF] : Endif
If [F:ITF]CUNFLG = 2
   If [F:SCM]ALLSTA > 3
      Gosub REC_LOC From SCOSTKAUTLIB  # FQ 59339 GA 11/2009 avant SCOSTKLIB
   Else
      Filter [F:STO] Where STOFCY = [F:ITF]STOFCY & ITMREF = [F:ITF]ITMREF & CUNLOKFLG = 1
&                    Order By Key STO3
      Read [F:STO]STO3 First
      If fstat WCUNFLG = 2 : Endif
      Filter [F:STO]
   Endif
Endif
If [F:SCM]SCMTRKFLG < 5 & [F:SCM]SCOFLG=2
#On ne maj que les matières à code retrait post-conso
   If [F:ITF]STOCOD = 2 & WCUNFLG <> 2 & WAUTO > 0
     # Maj de SCOMAT + sortie stock selon qté backflush
     Gosub MAJ_STKSOR_SCM From SCOSTKAUTLIB
     If GOK < 1 : LRET = 1 : End : Endif
   Endif
Endif

[F:SCM]SCMTRKFLG = 5
[F:SCM]MATSTA = 3
WMATCLENBR += 1

# FQ 58252 GA 09/2009 à faire dans tous les cas
# supression des allocations restantes
Call UPDATE_ALL("A") From SCOALL

# v6 affectations
Gosub SUP_MTO_SCM From SCOMTOLIB

Call UPDATE_MSX("A",0) From SCOLIB

Return


##############################################################
# selon DESOLDE_MAT de FUNMFGS
#dé-Solde d'une matière . Traitement appelé aussi depuis ???
##############################################################
$DESOLDE_MAT
Local    Integer  WRET
Local    Decimal  WALL, WSHT, WWRK, WDIFF
Local    Integer  WALLTYP
Local    Char     WCOD(1)
#
Read [F:ITM]ITM0 = [F:SCM]CPNITMREF
If fstat : Raz [F:ITM] : Endif
Read [F:ITF]ITF0 = [F:SCM]CPNITMREF;[F:SCM]STOFCY
If fstat : Raz [F:ITF] : Endif
If [F:SCM]USEQTY = 0
   [F:SCM]SCMTRKFLG = 1
   [F:SCM]MATSTA = 1
Else
   [F:SCM]SCMTRKFLG = 4
   [F:SCM]MATSTA = 2
Endif
Case [F:SCM]ALLSTA
     When 2,3:      WALLTYP = 1    # allocation globale
     When 4,5:      WALLTYP = 2    # allocation détaillée
     When Default : WALLTYP = 0    # pas d'allocation
Endcase
#
If WALLTYP <> 0
    WALL = [F:SCM]RETQTY - [F:SCM]USEQTY
    WSHT = 0
    WCOD = "C"
    Call ALLOCATION(WCOD, WALLTYP, WALL, WSHT, WRET) From SCOALL
    If WRET  = 9 : Return : Endif        # llc 07.01 9308
    If WRET <> 0 : GOK = 0 : Return : Endif
    [F:SCM]ALLQTY     = WALL
    [F:SCM]SHTQTY     = WSHT
    # mise à jour statut allocation
    Case [F:SCM]ALLSTA
        When 2,4:   If [F:SCM]SHTQTY = 0  : [F:SCM]ALLSTA += 1 : Endif
        When 3,5:   If [F:SCM]SHTQTY <> 0 : [F:SCM]ALLSTA -= 1 : Endif
    Endcase
Endif
WMATCLENBR -= 1

Return

###########################################################################
# Solde EO
###########################################################################
$SOLDE_EO
Local Integer OK,LRET,LOPE,LITM,LMAT,WPREC,WAUTO
Local Integer WOPECLENBR, WITMCLENBR, WMATCLENBR
Local Char    WNUMTEX(12)
Local Integer WRETOUR,STAT, WFICFLG
Local Decimal WQTYCONS,WWQTYCONS,WRAPP, WWQTY, WCOEFF
Local Char     WMSG(80)
# sr 10.04 demande 23789
Local Integer WTRTTYP
WTRTTYP = 1

#
Raz WMSG
# 11552 11.03 MM : fonction solde EO en série, sans message d'avertissement
If dim(GSTOP)<0
    #"Solder l'ordre de sous-traitance ?"
    Call OUINON(mess(911,196,1),OK) From GESECRAN
    If OK <> 2 : Return : Endif
Endif

Raz LRET,LOPE,LITM,LMAT

Raz WAUTO
#WAUTO = 0 : On ne suit pas automatiquement les matières
#WAUTO = 1 : On suit automatiquement les matières

Raz LRET

If dim(GSTOP)>0
  # Activer la post-consommation des matières
  If [M:DIA]MATFLG = 2
      WAUTO=1
  Endif
Else
# cas du solde EO en série: Ctrl déjà pris en compte au niveau des critères de sélection

# Les conditions permettent-elles de solder l'EO ?
# ----------------------------------------------
  Call CTRL_VALID(LRET,LOPE,LITM,LMAT)
  If LRET = 1
  # Issue 84906 GA 01/2013 pas de solde si commande non soldée
    ## # "Une opération de sous-traitance est commandée ou en cours. Solde impossible "
    ## # Issue 83821 GA 10/2012 message [encore] plus explicite
    ##    Call AVERTIR(mess(431,194,1),OK) From GESECRAN
    ##    If OK <> 2 : Return : Endif
      Call ERREUR(mess(237,193,1)) From GESECRAN
      OK=0 : Return
  Endif

  If LITM = 1
     # "Au moins un article lancé n'a pas été produit"
     # Issue 83821 GA 10/2012 message plus explicite
        Call AVERTIR(mess(432,194,1),OK) From GESECRAN
        If OK <> 2 : Return : Endif
  Endif

  If LMAT = 1
     # "Au moins une matière n'a pas été consommée"
     # Issue 83821 GA 10/2012 message plus explicite
       Call AVERTIR(mess(433,194,1),OK) From GESECRAN
       If OK <> 2 : Return : Endif
  Endif

Endif

# Y-a-t-il des matières à mode de déstockage automatique non soldées ?
# --------------------------------------------------------------------
Raz WAUTO,LRET
#WAUTO = 0 : On ne suit pas automatiquement les matières
#WAUTO = 1 : On suit automatiquement les matières

#GA If [F:SCO]CPLQTY = 0 | [F:MTS]MATTRKFLG <> 2 : WAUTO = 0
If [F:SCI]CPLQTY = 0 : WAUTO = 0
Else Call CTRL_MAT(LRET)
    If LRET > 0
        Local Date WDATE : WDATE = date$
        Call STKCTRIPT(WDATE,[F:SCO]POHFCY,"1") From STKLIB
        If GMESSAGE = ""
            If  dim(GSTOP) >0
                If [M:DIA]MATFLG=2 : WAUTO = 1 : Endif
            Else
                Raz OK
                Call OUINON(mess(207,190,1),OK) From GESECRAN
                If OK = 2: WAUTO = 1 : Endif
            Endif
        Endif
    Endif
Endif

#----- Variables globales
Gosub CHARG_PARAM
#

Call DEBTRANS From GLOCK
Trbegin [SCO]
#----------------------- Solde opération -----------------------------#
Filter [F:SCS] Where SCONUM =[F:SCO]SCONUM

For [F:SCS]

       Gosub SOLDE_OPE
       If GOK < 1 : Break : Endif

       Gosub REWRITE_SCS From SCOLIB
Next
Filter [F:SCS]
If GOK < 1 : Goto TR_ROLL : Endif

#----------------------- Solde article lancé -----------------------------#
Filter [F:SCI] Where SCONUM = [F:SCO]SCONUM
For [F:SCI]

       Gosub SOLDE_ITM
       If GOK < 1 : Break : Endif

       Gosub REWRITE_SCI From SCOLIB
Next
Filter [F:SCI]
If GOK < 1 : Goto TR_ROLL : Endif

#----------------------- Solde des matières   -----------------------------#
Filter [F:SCM] Where SCONUM = [F:SCO]SCONUM #### & [F:SCM]SCMTRKFLG < 5 & [F:SCM]MATSTA <> 4 & [F:SCM]CPNTYP <> 5
Local Integer WMATSOL
Raz WMATSOL
For [F:SCM]
    Gosub SOLDE_MAT
    If GOK < 1 : Break : Endif
    Gosub REWRITE_SCM From SCOLIB
Next
Filter [F:SCM]
If GOK < 1 : Goto TR_ROLL : Endif

# Issue 89606 remplacement de [M]SCONUM Ko
#----------------------- Maj  Entête EO ------------------------------------#
Readlock [F:SCO]SCO0 Curr
If fstat=1  GOK=-1 : GLOCK="$SCOHEAD"-[F:SCO]SCONUM : Goto TR_ROLLCLO
Elsif fstat GOK=0  : Call RSTA("SCO",[F:SCO]SCONUM) From GLOCK : Goto TR_ROLLCLO
Endif
[F:SCO]OPECLENBR += WOPECLENBR
If [F:SCO]OPECLENBR > [F:SCO]OPELINNBR : [F:SCO]OPECLENBR = [F:SCO]OPELINNBR : Endif
[F:SCO]MATCLENBR += WMATCLENBR
If [F:SCO]MATCLENBR > [F:SCO]MATLINNBR : [F:SCO]MATCLENBR = [F:SCO]MATLINNBR : Endif
[F:SCO]ITMCLENBR += WITMCLENBR
If [F:SCO]ITMCLENBR > [F:SCO]ITMLINNBR : [F:SCO]ITMCLENBR = [F:SCO]ITMLINNBR : Endif
[F:SCO]SCOTRKFLG = 5

Gosub REWRITE_SCO From SCOLIB
If GOK > 0
    #----- MISE à jour Entête de Wipcost: date de dernier suivi -----#
    If !clalev([F:MWH])  : Local File MFGWIP    [MWH]  : Endif
    Readlock [MWH]MWH0=36;[F:SCO]SCONUM
    If fstat=1  GOK=-1 : GLOCK="$MFGWIP 36;"-[F:SCO]SCONUM : Goto TR_ROLL
    Elsif !fstat
      [F:MWH]MFGTRKFLG = [F:SCO]SCOTRKFLG
      [F:MWH]TRKLAST   = date$
      Rewrite [MWH]
      If fstat
         GOK = 0 : Call FSTA("MWH") From GLOCK : Goto TR_ROLL
      Endif
    Endif
    Commit
    Goto FIN_SOLDE
Endif

$TR_ROLL
Rollback
If dim(GGIVE_UP)>0 : GGIVE_UP=1 : GSTOP=1 : Endif

$FIN_SOLDE
# fonction solde EO en série, sans message d'avertissement
If dim(GWMESS2)>0
    If WMSG <> "" : GWMESS2 = WMSG : Return : Endif
Else
    If WMSG <> "" : Call MESSAGE(WMSG) From GESECRAN : Endif
Endif
Return

###########################################################################
# inspiré (librement !) de CTR_VALID de FUNMFGS:
# - ctrl des lignes de commande non soldées
# - ctrl des matières non consommées
# NB: pas de ctrl "suivi" dans le cas des ordres de sous-traitance
###########################################################################
Subprog CTRL_VALID(LRET,LOPE,LITM,LMAT)
Variable Integer LRET,LOPE,LITM,LMAT

  Call CTRL_POH_CLEFLG (LRET,LOPE,LITM)
  If LRET<>0 : End : Endif

  Call CTRL_SCM_USEQTY (LRET,LMAT)
  If LRET<>0 : End : Endif

# PE manquant par rapport a cloture d'OF
# demande 38620 : Possibilite de modifier la valeur des indicateur LOPE,LMAT,LITM
GPOINT = "CUSCTLSUP" : Gosub ENTREE From EXEFNC
End

###########################################################################
# selon de CTR_MAT de FUNMFGS:
###########################################################################
Subprog CTRL_MAT(LRET)
Variable Integer LRET
Local Decimal WRAPP, WQTYCONS
If !clalev([F:SCOW]) : Local File SCOHEAD  [SCOW] : Endif
If !clalev([F:SCIW]) : Local File SCOITM   [SCIW] : Endif
If !clalev([F:SCSW]) : Local File SCOSRV   [SCSW] : Endif
If !clalev([F:SCMW]) : Local File SCOMAT   [SCMW] : Endif

Filter [F:SCMW] Where SCONUM = [F:SCO]SCONUM & CPNTYP <> 5 & MATSTA<>4 & SCOFLG=2
For [F:SCMW]
    If [F:SCMW]SCMTRKFLG < 5
       Read [F:ITM]ITM0 = [F:SCMW]CPNITMREF
       If fstat : Raz [F:ITM] : Endif
       If [F:ITM]SERMGTCOD = 1
           Read [F:ITF]ITF0 = [F:SCMW]CPNITMREF;[F:SCMW]STOFCY
           If fstat : Raz [F:ITF] : Endif
           If [F:ITF]STOCOD = 2
              Read [F:SCI]SCI0 = [F:SCMW]SCONUM;[F:SCMW]SCILIN
              If !fstat
                  WRAPP    = [F:SCMW]RETQTY / [F:SCI]EXTQTY
                  WQTYCONS = [F:SCI]CPLQTY * WRAPP
                  Call QTEARR(WQTYCONS,[F:SCMW]STU) From TRTDIV
                  If [F:SCMW]USEQTY < WQTYCONS
                     LRET = 2
                  Endif
              Endif
           Endif
       Endif
    Endif
Next
End

###########################################################################
Subprog CTRL_POH_CLEFLG(LRET,LOPE,LITM)
Variable Integer LRET,LOPE,LITM
LRET=0
Local Decimal WRAPP, WQTYCONS
Local Integer WWIP : WWIP = 0

If !clalev([F:SCOW]) : Local File SCOHEAD  [SCOW] : Endif
If !clalev([F:SCIW]) : Local File SCOITM   [SCIW] : Endif
If !clalev([F:SCSW]) : Local File SCOSRV   [SCSW] : Endif
If !clalev([F:SCMW]) : Local File SCOMAT   [SCMW] : Endif

# Issue 83444 selon FUNMFGS 2012-09-06 by CCC : LOPE mal calculé
Local Integer WSTAOPE  # 0 : aucune opé n'est à suivre
                       # 1 : il existe une opé non suivie
                       # 2 : il n'existe que des opé en cours
Local Integer WQTYOPE  # 0 : toutes les opé suivies ont réalisé une qté suffisante
                       # 2 : il existe une opé avec une qté réalisée insuffisante

Filter [F:SCSW] Where SCONUM = [F:SCO]SCONUM
For    [F:SCSW]
    # Issue 84355 GA 09/2012
    #If [F:SCSW]OPESTA=4            : # Opération en cours
    If find([F:SCSW]OPESTA,4,5,6)   : # Opération Commandée / Réceptionnée / Facturée
       Filter [F:POQ] Where VCRTYPORI=36
&                         & VCRNUMORI=[F:SCSW]SCONUM
&                         & VCRLINORI=[F:SCSW]SCILIN
&                         & VCRSEQORI=[F:SCSW]SCSLIN
       For    [F:POQ]
           If fstat : Raz [F:POQ] : Break : Endif
           If [F:POQ]LINCLEFLG <> 2 : LRET = 1 : LOPE = 1 : Break : Endif
       Next
       Filter [F:POQ]
    Endif
# Issue 84906 GA 01/2013 solde interdit si et seulement service commandé et non soldé
 ## # Issue 84355 GA 09/2012 selon Issue 83444 - 2012-09-06 by CCC : LOPE mal calculé
 ##   If    [F:SCS]SCSTRKFLG < 4
 ##       WSTAOPE = 1
 ##   Elsif [F:SCS]SCSTRKFLG < 5
 ##       If WSTAOPE <> 1 : WSTAOPE = 2 : Endif
 ##       WRAPP    = [F:SCS]EXTQTY / [F:SCI]EXTQTY
 ##       WQTYCONS = [F:SCI]CPLQTY * WRAPP
 ##       Call QTEARR(WQTYCONS,[F:SCS]OPESTU) From TRTDIV
 ##       If [F:SCS]CPLQTY < WQTYCONS
 ##           WQTYOPE = 2
 ##       Endif
 ##   Endif
 ##   If [F:SCS]SCSTRKFLG > 3 : WWIP += 1 : Endif
Next

# Issue 84906 GA 01/2013 solde interdit si et seulement service commandé et non soldé
## # Issue 83444 selon FUNMFGS
## LOPE = WSTAOPE + WQTYOPE

Filter [F:SCIW] Where SCONUM = [F:SCO]SCONUM
For    [F:SCIW]
    If find([F:SCIW]ITMSTA,3,4)   : # Article Commandé ou Réceptionné
       Filter [F:POQ] Where VCRTYPORI=36
&                         & VCRNUMORI=[F:SCIW]SCONUM
&                         & VCRLINORI=[F:SCIW]SCILIN
&                         & VCRSEQORI=0
       For [POQ]
           If fstat : Raz [F:POQ] : Break : Endif
           If [F:POQ]LINCLEFLG <> 2 : LRET = 1 : LITM = 1 : Break : Endif
       Next
       Filter [F:POQ]
    Endif
Next
End

###########################################################################
Subprog CTRL_SCM_USEQTY(LRET,LMAT)
Variable Integer LRET,LMAT
LRET=0

If !clalev([F:SCOW]) : Local File SCOHEAD  [SCOW] : Endif
If !clalev([F:SCIW]) : Local File SCOITM   [SCIW] : Endif
If !clalev([F:SCSW]) : Local File SCOSRV   [SCSW] : Endif
If !clalev([F:SCMW]) : Local File SCOMAT   [SCMW] : Endif

Filter [F:SCMW] Where SCONUM=[F:SCI]SCONUM & SCILIN=[F:SCI]SCILIN & SCOFLG=2 & CPNTYP<>5 & MATSTA<>4
For [F:SCMW]
  If [F:SCMW]RETQTY>0 & [F:SCMW]USEQTY=0
   # Issue 84906 LRET=2 pour éviter la confusion avec Service en commande
   # Matière mise à dispo du sous-traitant non consommée
     LRET=2 : LMAT=1
  Endif
Next
Filter [F:SCMW]
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran TEOSEL0) 06/03/2006 17:25:40 (GA)
######################################################################################
Subprog C_WPOHFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
   Call CONTROLE("FCY","",VALEUR,"",mkstat) From CONTOBJ
   If mkstat : GMESSAGE = mess(23,100,1)
     End
   Endif
Endif
End

Subprog AM_WPOHFCY(VALEUR)
Variable Char    VALEUR()
If GFCY<>VALEUR
   GFCY=VALEUR
   Gosub CHARG_PARAM
Endif
End

