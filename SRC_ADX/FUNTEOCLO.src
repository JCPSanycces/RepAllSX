##########################################################################
# Added below section to disable the "Actual sub-contract price"
# field if the Manufacturing module is not licensed
Subprog AV_WPOHFCY(VALEUR)
    Variable Char VALEUR()

    If GMODU(8) <> 2
       Raz [M:DIA]PRFFLG
       Grizo [M:DIA]PRFFLG
    Endif
End
