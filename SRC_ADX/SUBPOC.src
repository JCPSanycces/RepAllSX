$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE>GNBDIE  Return : Endif
Call INIT_CCE(VALEUR,AXE,"POC","[M:POC2]LINACC(",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
If GMODIF<>2  mkstat=2 : Return : Endif
Call SAIS_CCE(VALEUR,AXE,"[M:POC2]LINACC(","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#

# Issue 82858 - 2012-06-20 by MUARN : controle validite section analytique
Local    Shortint NOL : NOL=nolign-1
Call CTRL_CCE(VALEUR,AXE,"[M:POC2]LINACC(",GFINRSP,[M:POC2]POPSTRDAT(NOL)) From TRTX3CPT
#Call CTRL_CCE(VALEUR,AXE,"[M:POC2]LINACC(",GFINRSP,[M:POC0]ORDDAT) From TRTX3CPT

Return


Subprog AS_QUAFLG(VALEUR)
#---------------------------------------#
# Avant saisie du code contrôle qualité #
#---------------------------------------#
Variable Integer  VALEUR
If [F:ITM]ITMREF<>[M:POC2]ITMREF
  Read [ITM] ITM0=[M:POC2]ITMREF
  If fstat Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF<>[M:POC2]ITMREF | [F:ITF]STOFCY<>[M:POC2]PRHFCY
  Read [ITF] ITF0=[M:POC2]ITMREF;[M:POC2]PRHFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
If [F:ITP]ITMREF<>[M:POC2]ITMREF | [F:ITP]BPSNUM<>[M:POC0]BPSNUM
  Read [ITP] ITP0=[M:POC2]ITMREF;[M:POC0]BPSNUM
  If fstat Raz [F:ITP]
    [F:ITP]QUAFLG=[F:ITF]QUAFLG                             # hcb V6CQ
  Endif
Endif

If [F:ITP]QUAFLG=2 mkstat=2 : Endif
If [F:ITF]STOMGTCOD<2 VALEUR=1 : mkstat=2 : End : Endif
End


Subprog AS_NBFAC
#--------------------#
# Avant saisie NBFAC #
#--------------------#
If [M:POC0]BETFCY=2 & [M:POC0]BETCPY<>2  mkstat=2 : Endif
If [M:POC3]NBFAC=0
  If [F:BPR]BPRNUM<>[M:POC0]BPSNUM
    Read [BPR] BPR0=[M:POC0]BPSNUM : If fstat Raz [F:BPR] : Endif
  Endif
  If [F:BPS]BPSNUM<>[M:POC0]BPSNUM
    Read [BPS] BPS0=[M:POC0]BPSNUM : If fstat Raz [F:BPS] : Endif
  Endif
  Call INIT_ELEMENTS (5,[M:POC1]CHGTYP,[F:BPS]CUR,[M:POC1]CUR) From TRTACHELT1
  Affzo [POC3]1-99
Endif
End

Subprog C_NBFAC
#-----------------------------------------------------#
# Contrôle sur numéro de ligne élément de facturation #
#-----------------------------------------------------#
Local Shortint NOL : NOL=nolign-1
#----- Interdiction de l'insertion et de la suppression sur commande soldée -----#
If find(status,65,73,82) & [M:POC1]CLEFLG=2
  GMESSAGE=mess(47,194,1)  : mkstat=2 : End
Endif
#----- Test suppression d'un élément non ajouté -----#
If status=65
  If [M:POC3]INVDTAFLG(NOL)=1
    GMESSAGE=mess(136,194,1) : mkstat=2 : End
  Elsif [M:POC3]INVCPLAMT<>0
    GMESSAGE=mess(343,194,1) : mkstat=2 : End
  Endif
Endif
End

Subprog AVANT_NBFAC
#---------------------------------#
# Avant ligne élément facturation #
#---------------------------------#
End

Subprog APRES_NBFAC
#---------------------------------------------#
# Après ligne tableau éléments de facturation #
#---------------------------------------------#
End

Subprog AS_INVDTA(VALEUR)
#---------------------------------------------#
# Avant saisie du No d'élément de facturation #
#---------------------------------------------#
Variable Decimal VALEUR
#If [M:POC3]INVDTAFLG(nolign-1)<>0 mkstat=2 : Endif
End

Subprog C_INVDTA(VALEUR)
#----------------------------------------------------#
# Contrôle No d'élément déja présent dans le tableau #
#----------------------------------------------------#
Variable Decimal VALEUR
If find(VALEUR,[M:POC3]INVDTA) & find(VALEUR,[M:POC3]INVDTA)<>nolign
  GMESSAGE=mess(102,194,1) : mkstat=1
Endif
End

Subprog AM_INVDTA(VALEUR)
#------------------------------------------------#
# Après modif No d'élément : chargement libellé, #
#       valeur par défaut et indicateur d'ajout. #
#------------------------------------------------#
Variable Decimal VALEUR
Local    Shortint NOL : NOL=nolign-1
Local    Integer  STAT
#-----
If [F:PFI]DISVATFLG=2
  GMESSAGE=mess(412,194,1) : GERR=1 : mkstat=1 : End
Endif
#-----
Call LECTEXTRA(GBIDC3,"PFOOTINV","SHOAXX",num$([F:PFI]PFINUM),"") From ATEXTRA
[M:POC3]INVDTALIB(NOL)=GBIDC3
[M:POC3]AMTCOD(NOL)=[F:PFI]AMTCOD
If [F:PFI]AMTCOD=2
  Call CONVERT(GLOCALDEV,GCUR,GLOCALDEV,[M:POC1]CHGTYP,datesyst,
&              [F:PFI]DEFVAL,GBIDD3,STAT) From TRTDEV
  [M:POC3]INVDTAAMT(NOL)=GBIDD3
  [M:POC3]AMTCODLIB(NOL)=GCUR
  [M:POC3]FORMAT(NOL)   ="NZ:"+GDEVFMT1(max(find(GCUR,GDEVISE(1..GNBDEV)),1))+"[ ]"
Else
  [M:POC3]INVDTAAMT(NOL)=[F:PFI]DEFVAL
  [M:POC3]AMTCODLIB(NOL)="%"
  [M:POC3]FORMAT(NOL)   =func TRTX3FNC.GETFMTREM(1)
Endif
If dim([M:POC3]DISVATFLG)>0  [M:POC3]DISVATFLG(NOL)=[F:PFI]DISVATFLG : Endif
[M:POC3]DEBCDT(NOL)=[F:PFI]INCDCR
[M:POC3]CLCORD(NOL)=[F:PFI]CLCORD
[M:POC3]CLCBAS(NOL)=[F:PFI]CLCBAS
[M:POC3]INVDTAFLG(NOL)=2 : # Elément saisi manuellement
Raz [M:POC3]INVORDAMT(NOL), [M:POC3]INVLINAMT(NOL), [M:POC3]INVCPLAMT(NOL),
&   [M:POC3]INVDTAVAT(NOL)
If dim([M:POC3]DTADISBAS)>0  Raz [M:POC3]DTADISBAS(NOL) : Endif
If [F:PFI]VATRUL=2
  Local Char WVAT(GLONVAT)
  If !clalev([F:TVC])  Local File TABVAC [TVC] : Endif
  Call RECHVATFOOT(2,[M:POC0]BPSNUM,[F:PFI]PFINUM,"POC3",WVAT) From TRTX3
  [M:POC3]INVDTAVAT(NOL)=WVAT
Endif
[M:POC3]INVLINFLG(NOL)=[F:PFI]DSPLIN
[M:POC3]INVORDFLG(NOL)=[F:PFI]DACORD
[M:POC3]DSP(NOL)      =[F:PFI]DSP
[M:POC3]INVDTA(NOL)=VALEUR : Call AM_INVDTAAMT([M:POC3]INVDTAAMT(NOL))
If !GIMPORT
  Affzo [POC3]INVDTALIB(NOL), INVDTAAMT(NOL), AMTCODLIB(NOL), INVORDAMT(NOL), DSP(NOL)
Endif
End

Subprog AS_INVDTAAMT(VALEUR)
Variable Decimal VALEUR
If [M:POC3]INVLINFLG(nolign-1)=6| (dim([M:POC3]DISVATFLG)>0 & [M:POC3]DISVATFLG(nolign-1)=2)
  mkstat=2
Endif
End

Subprog AM_INVDTAAMT(VALEUR)
#-------------------------------------------------------------#
# Après modif d'un montant élément de facturation (Mt saisi): #
#-------------------------------------------------------------#
Variable Decimal  VALEUR
#-----
Local    Shortint NOL    : NOL=nolign-1
Local    Integer  SIGN   : SIGN=1-2*([M:POC3]DEBCDT(NOL)-1)
#-----
Raz [M:POC3]INVORDAMT(NOL)
#----- C'est une remise sur taxe (Settlement discount) -----#
If dim([M:POC3]DISVATFLG)>0 & [M:POC3]DISVATFLG(NOL)=2
  Raz [M:POC3]INVORDAMT(NOL) : End
Endif
#----- C'est un montant -----#
If [M:POC3]AMTCOD(NOL)=2
  [M:POC3]INVORDAMT(NOL)=VALEUR*SIGN
Endif
#-----
End

Subprog AS_INVDTAVAT(VALEUR)
#---------------------------#
# Avant saisie du code taxe #
#---------------------------#
Variable Char    VALEUR()
If VALEUR="" &
& ([M:POH3]INVLINFLG(NOL)>1 | (dim([M:POH3]DISVATFLG)>0 & [M:POH3]DISVATFLG(NOL)=2))
  mkstat=2 : End
Endif
End

