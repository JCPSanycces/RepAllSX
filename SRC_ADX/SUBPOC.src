######################################################################
# CTL_ITMREF : S/P de contrôle sur référence article                 #
#                               ou référence chez le fournisseur     #
# ------------------------------------------------------------------ #
# Subprog CTL_ITMREF(REFERENCE,TYP)                                  #
#    REFERENCE : Référence article (interne ou celle du fournisseur) #
#    TYP       : "ITP" = Référence chez le fournisseur (ITMREFBPS)   #
#                "ITM" = Référence interne (ITMREF)                  #
######################################################################
Subprog CTL_ITMREF(REFERENCE,TYP)
Value Char REFERENCE
Value Char TYP
#--------------------------------------------------#
# controle reference article                       #
# attention on est soit avec itmref soit itmrefbps #
#--------------------------------------------------#
Local Integer WLECTOK
WLECTOK = 0
If TYP = "ITP"
   Read [ITP]ITP2 = [M:POC0]BPSNUM ; REFERENCE
   If fstat
      #----- L'article n'est pas référencé chez le fournisseur -----#
      Raz [F:ITP], [F:ITM]
      GMESSAGE=mess(8,194,1) : mkstat=2 : End
   Else
      WLECTOK=1
      Read [ITM] ITM0=[F:ITP]ITMREF
      If fstat
      #----- Article achat sans article maitre -----#
        Raz [F:ITM]
        GMESSAGE=mess(5,194,1) : mkstat=2 : End
      Endif
      #----- Article acheté -----#
      Call CONTROLE("ITM","B",[F:ITM]ITMREF,"",mkstat) From CONTOBJ
      If mkstat End : Endif
   Endif
   Filter [ITP]
Else
   Read [ITP]ITP0 = REFERENCE ; [M:POC0]BPSNUM
   If fstat = 0      : WLECTOK = 1
   Else  Raz [F:ITP]
   Endif
Endif
#--- Les contrôles suivants ne sont pas effectués pour les contrats inter-sites ---#
If [M:POC0]BETFCY<>2
  #----- Contrôle si article réceptionné (contrôle supprimé) -----#
  # If [F:ITM]RCPFLG<>2 GMESSAGE=mess(99,194,1)  : mkstat=2 : End : Endif
  #----- Contrôle si article avec DA obligatoire -----#
  If [F:ITM]PRQFLG=2  GMESSAGE=mess(164,194,1) : mkstat=2 : End : Endif
Else
  # Issue 113089 - 2016-05-24 by SR : Inter site ou Inter société
  If [M:POC0]BETFCY = 2 | [M:POC0]BETCPY = 2
    # Issue 113089/18495 - 2017-01-20 by MUARN : modif messages
    If [F:ITM]RCPFLG<>2 GMESSAGE=mess(576,194,1)   : mkstat=2 : End : Endif :# non réceptionnable
    If [F:ITM]DLVFLG<>2 GMESSAGE=mess(575,194,1)  : mkstat=2 : End : Endif :# non livrable
  Endif
  # Vu avec CH : Inutile
  #----- Contrats inter-sites intra-société l'article doit être géré en stock -----#
#  If [M:POC0]BETCPY=1
#    If TYP="ITP"
#      Call CONTROLE("ITM","I",[F:ITM]ITMREF,"",mkstat) From CONTOBJ
#      If mkstat  End : Endif
#    Endif
#  Endif
  # End issue 113089
Endif
#----- Contrôle article en fin de vie ------#
If [F:ITM]LIFENDDAT<>[0/0/0] & [F:ITM]LIFENDDAT<[M:POC0]ORDDAT
  mkstat=1 : GMESSAGE=mess(12,318,1) : End
Endif
#-------------------------------------------#
# vérification couple article - fournisseur #
#-------------------------------------------#
If WLECTOK = 1
   [M:POC2]PUU = [F:ITP]PUU
   If TYP = "ITP"
      [M:POC2]ITMREF    = [F:ITP]ITMREF
      Affzo [POC2]PUU ,ITMREF
   Else
      [M:POC2]ITMREFBPS = [F:ITP]ITMREFBPS
      Affzo [POC2]PUU ,ITMREFBPS
   Endif
Else
   [M:POC2]PUU = [F:ITM]PUU
   Raz [M:POC2]ITMREFBPS
Endif
#----- Lecture BPARTNER si nécessaire pour chargement LAN -----#
If [F:BPR]BPRNUM<>[M:POC0]BPSNUM
   Read [BPR] BPR0=[M:POC0]BPSNUM
   If fstat Raz [F:BPR] : [F:BPR]LAN=GLANGUE : Endif
Endif
#-----
If [M:POC0]BETFCY<>2 : # Pas de contrôle acheteur pour contrats inter-site
  If GBUYFLT = 2 & mkstat = 0
    GFCY = [M:POC0]POHFCY
    If TYP = "ITP"
      Call CTLITMBUY([M:POC2]ITMREF,[M:POC1]BUY,mkstat) From TRTACHCTL1
    Else
      Call CTLITMBUY(REFERENCE,[M:POC1]BUY,mkstat)      From TRTACHCTL1
    Endif
    If mkstat <> 0 : End : Endif
  Endif
Endif
#-----------------------------------------------------------------#
# Si site de réception affiché ou invisible ou contrat inter-site #
# il faut verifier article site existe  et bloquer la saisie      #
# cas des articles gérer en stock                                 #
# si non gere en stock --> site demande                           #
#-----------------------------------------------------------------#
If [M:POC2]PRHFCY="" [M:POC2]PRHFCY=[M:POC1]RCPFCY : Endif
If [M:POC2]LINSTOFCY="" [M:POC2]LINSTOFCY=[M:POC1]STOFCY : Endif
If TYP="ITP"
  Read [ITF] ITF0=[M:POC2]ITMREF;[M:POC2]PRHFCY
Else
  Read [ITF] ITF0=REFERENCE;[M:POC2]PRHFCY
Endif
If fstat & [M:POC2]PRHFCY<>[M:POC1]RCPFCY
  [M:POC2]PRHFCY=[M:POC1]RCPFCY
  If TYP="ITP"
    Read [ITF] ITF0=[M:POC2]ITMREF;[M:POC2]PRHFCY
  Else
    Read [ITF] ITF0=REFERENCE;[M:POC2]PRHFCY
  Endif
Endif
# Issue X3-55891 - 2018-09-25 by SR : Essayer encore avec le site de réception par défaut
If fstat  & [M:POC2]PRHFCY<>GRCPFCY
  [M:POC2]PRHFCY=GRCPFCY
  If TYP="ITP"
    Read [ITF] ITF0=[M:POC2]ITMREF;[M:POC2]PRHFCY
  Else
    Read [ITF] ITF0=REFERENCE;[M:POC2]PRHFCY
  Endif
Endif
# End issue X3-55891
If fstat
  Raz [F:ITF]
  If [F:ITM]STOMGTCOD>1
    If [F:PTR]RCPFCYCOD>1
      GMESSAGE=mess(25,192,1)-[M:POC2]PRHFCY : mkstat=2 : End
    Elsif [F:ITM]STOMGTCOD>1
      Raz [M:POC2]PRHFCY, [M:POC2]FCYADD
    Endif
  Endif
Endif
If [M:POC0]BETFCY=2
  If TYP="ITP"
    Read [ITF] ITF0=[M:POC2]ITMREF;[M:POC2]LINSTOFCY
  Else
    Read [ITF] ITF0=REFERENCE;[M:POC2]LINSTOFCY
  Endif
  If fstat & [M:POC2]LINSTOFCY<>[M:POC1]STOFCY
    [M:POC2]LINSTOFCY=[M:POC1]STOFCY
    If TYP="ITP"
      Read [ITF] ITF0=[M:POC2]ITMREF;[M:POC2]LINSTOFCY
    Else
      Read [ITF] ITF0=REFERENCE;[M:POC2]LINSTOFCY
    Endif
  Endif
  If fstat
    Raz [F:ITF]
    If [F:ITM]STOMGTCOD>1
      If [F:PTR]RCPFCYCOD>1
        GMESSAGE=mess(25,192,1)-[M:POC2]LINSTOFCY : mkstat=2 : End
      Elsif [F:ITM]STOMGTCOD>1
        Raz [M:POC2]LINSTOFCY
      Endif
    Endif
  Endif
  #----- Si géré en stock l'article-site d'expédition doit exister ! -----#
  If [M:POC2]LINSTOFCY<>"" & [F:ITM]STOMGTCOD>1
    Look [ITF] ITF0=[F:ITM]ITMREF;[M:POC2]LINSTOFCY
    If fstat
      GMESSAGE=[F:ITM]ITMREF-mess(25,192,1)-[M:POC2]LINSTOFCY : GERR=1 : mkstat=1 : End
    Endif
  Endif
  #----- Contrats inter-sites l'article-vente doit exister -----#
  If [M:POC0]SALFCY<>""
    Call CONTROLE("ITS","",[F:ITM]ITMREF,"",mkstat) From CONTOBJ
    If mkstat  End : Endif
  Endif
Endif
End


###############################################################################
# Contrôle après modif sur référence article ou référence chez le fournisseur #
###############################################################################
$CTL_AM_ITMREF
Local Integer WRETOUR
# Issue X3-55891 - 2018-09-25 by SR : Déclinaison par site
Local Integer WITMBPS
#----- Contrôle si article actif ? -----#
If [F:ITM]ITMSTA=3
  WRETOUR=2
  Call AVERTIR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")",WRETOUR) From GESECRAN
  If WRETOUR=1  mkstat=1 : Return : Endif
Elsif [F:ITM]ITMSTA<>1
  Call ERREUR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")") From GESECRAN
  mkstat=1 : Return
Endif
#--- Les contrôles suivants ne sont pas effectués pour les contrats inter-sites ---#
If [M:POC0]BETFCY<>2
  #----- L'article fait-il l'objet d'une commande ouverte ? -----#
  Filter [POCB] Where ITMREF=REFART & STRDAT<=date$ & ENDDAT>=date$
  Look [POCB] POC2 First
  Filter [POCB]
  If !fstat
    WRETOUR=2 : Call AVERTIR(mess(1,194,1),WRETOUR) From GESECRAN
    If WRETOUR=1 mkstat=1 : Return : Endif
  Endif
  #----- Test existence article-fournisseur -----#
  If [F:ITP]ITMREF<>REFART | [F:ITP]BPSNUM<>[M:POC0]BPSNUM
    Read [ITP] ITP0=REFART;[M:POC0]BPSNUM : If fstat Raz [F:ITP] : Endif
  Endif
  # Issue 77999 - 2011-11-18 by VPO : référencement inutile si fournisseur de type Divers
  If [F:BPS]BPSNUM<>[M:POC0]BPSNUM
    Read [BPS] BPS0=[M:POC0]BPSNUM : If fstat Raz [F:BPS] : Endif
  Endif
  # Issue X3-55891 - 2018-09-25 by SR : Fait pas le composant
#  #----- Si fournisseur <> Divers -----#
#  If [F:BPS]BPSTYP<>3
#    #----- Si article non générique -----#
#    If [F:ITP]ITMREF="" & [F:ITM]GENFLG<>2
#      If GITMBPS=1
#        GMESSAGE=mess(8,194,1) : GERR=1 : mkstat=1 : Return
#      Elsif GITMBPS=2
#        WRETOUR=2 : Call AVERTIR(mess(8,194,1),WRETOUR) From GESECRAN
#        If WRETOUR=1 mkstat=1 : Return : Endif
#      Endif
#    Endif
#  Endif
Endif
##----- Test article en litige -----#
#If [F:ITP]DOUFLG=3
#  GMESSAGE=mess(9,194,1) : GERR=1 : mkstat=1 : Return
#Elsif [F:ITP]DOUFLG=2
#  WRETOUR=2 : Call AVERTIR(mess(9,194,1),WRETOUR) From GESECRAN
#  If WRETOUR=1 mkstat=1 : Return : Endif
#Endif
Raz WRETOUR, WITMBPS
# Intersite
If [M:POC0]BETFCY=2 & [M:POC0]BETCPY <>2
  Call CTRL_DOUFLG(2,REFART,[M:POC0]BPSNUM,[M:POC2]PRHFCY,WITMBPS,WRETOUR) From TRTACHCTL1
Else
  Call CTRL_DOUFLG(1,REFART,[M:POC0]BPSNUM,[M:POC2]PRHFCY,WITMBPS,WRETOUR) From TRTACHCTL1
Endif
# Si problème
If WRETOUR<> 0
  # Si "pas trouvé" ou "pas trouvé au bon niveau par rapport aux paramètres généraux"
  # ou trouvé au niveau article-fournisseur et douteux avec blocage
  # ou trouvé au niveau article-fournisseur-site et douteux avec blocage , mais site non saisissable: On sort
  If (find(WITMBPS,0,1) | (WITMBPS =2 and varmode([M:POC2]PRHFCY)<>0))
      mkstat = 2
      Return
  # Si trouvé niveau article-fournisseur-site et douteux avec blocage
  # et site saisissable,on raze le site de réception.
  # Il faudra en saisir un
  Elsif WITMBPS =2 and varmode([M:POC2]PRHFCY)=0
    Raz [M:POC2]PRHFCY
    If !GIMPORT : Affzo [M:POC2]PRHFCY : Endif
  Endif
Endif
# End issue X3-55891
#--- En inter-sites
If [M:POC0]BETFCY=2
  #-- Vérification que l'article site expédition existe
  #-- Autres contrôles sur l'article pour les ventes
  Gosub AM_BETITMREF
  If mkstat<>0 Return : Endif
Endif
#----- Initialisation des valeurs par défaut -----#
Call D_FIMHOR([M:POC2]FIMHOR)       From SUBPOC
[M:POC2]FIMHORUOM=1
[M:POC2]FRTHOR   =[F:ITM]FRTHOR
Call D_FRTHORUOM([M:POC2]FRTHORUOM) From SUBPOC
Call D_NBCOA                        From SUBPOC
#----- Récupération du 1er code tarif actif et de type normal -----#
Call D_PLI([M:POC2]PLI)
#----- Lecture BPARTNER si nécessaire pour chargement LAN -----#
If [F:BPR]BPRNUM<>[M:POC0]BPSNUM
   Read [BPR] BPR0=[M:POC0]BPSNUM
   If fstat Raz [F:BPR] : [F:BPR]LAN=GLANGUE : Endif
Endif
#----- Chargement des désignations article -----#
#Call CHARGE_ITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[M:POC2]ITMDES) From TRTX3
#If [M:POC2]ITMDES="" [M:POC2]ITMDES=[F:ITM]ITMDES1 : Endif
Call CHARGE_DEFITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[M:POC2]ITMDES, "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
#[M:POC2]ITMDES1=[F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:POC2]ITMDES1, "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
#----- Récupération des liens texte article ou article-fournisseur -----#
If [F:ITP]ITMREF<>REFART | [F:ITP]BPSNUM<>[M:POC0]BPSNUM
  Read [ITP] ITP0=REFART;[M:POC0]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
If [F:ITP]TEX<>""
  [M:POC2]LINTEX=[F:ITP]TEX
Else
  [M:POC2]LINTEX=[F:ITM]PURTEX
Endif
#----- Affichage onglet article -----#
Affzo [POC2]1-99
#----- Récupération prix de valorisation -----#
Call VALORIS_LIGNE From SUBPOC
Return


####################################################################
# Mise à jour flag màj à cause des désignations articles modifiées #
####################################################################
$MAJ_LIGPRI
If [M:POC2]NBLIG=0 Return : Endif
Local Shortint I
For I=0 To [M:POC2]NBLIG-1
  [M:POC2]UPDFLG(I)=1
Next I
Return


#####################################################################
# CONVERT_INVDTAAMT : S/P de conversion des éléments de facturation #
#                     après un changement de devise commande ou de  #
#                     type de cours commande                        #
# ----------------------------------------------------------------- #
# Subprog CONVERT_INVDTAAMT (DEV,TYP)                               #
#    DEV  : Nouveau code devise                                     #
#    TYP  : Nouveau type de cours                                   #
#####################################################################
Subprog CONVERT_INVDTAAMT (DEV,TYP)
Value Char     DEV
Value Integer  TYP
Local Integer  I, STAT
If [M:POC3]NBFAC>0
  For I=0 To [M:POC3]NBFAC-1
    If [M:POC3]AMTCOD(I)=2
      [M:POC3]FORMAT(I)="NZ:"+[F:TCU]CURFMT1
      Call CONVERT([M:POC1]CUR,DEV,GLOCALDEV,TYP,[M:POC0]ORDDAT,
&                  [M:POC3]INVDTAAMT(I),GBIDD2,STAT) From TRTDEV
      [M:POC3]INVDTAAMT(I)=GBIDD2
    Endif
  Next I
Endif
End


###############################################
# Valorisation de la ligne article du contrat #
###############################################
Subprog VALORIS_LIGNE
Local Integer SNOLIGN    : SNOLIGN=nolign
Local Decimal ANC_AMTVLT : ANC_AMTVLT=[M:POC2]AMTVLT
Local Integer STAT
#----- Chargement et affichage prix unitaire de valorisation -----#
If [M:POC2]PLI<>"" & [M:POC2]NBLIG=0
  GPUU=[M:POC2]PUU : Call RECH_TARIF ("POV",0) From TRTACHTAR1
# Issue 116821 - 2016-06-01 by MUARN : suppression du code tarif, récupération première ligne condition tarifaire
# sinon raz prix valorisation
Elsif [M:POC2]NBLIG<>0
  If [M:POC2]PRIVLT<>[M:POC2]NETPRI(0)
    [M:POC2]PRIVLT=[M:POC2]NETPRI(0)
  Endif
Else
  Raz [M:POC2]PRIVLT
Endif
If !GIMPORT Affzo [POC2]PRIVLT : Endif
#----- Calcul nouveau montant prévu de l'article -----#
[M:POC2]AMTVLT=[M:POC2]EXTQTYPUU*[M:POC2]PRIVLT
Call ARRDEV([M:POC2]AMTVLT,[M:POC1]CUR) From TRTDIV
If ANC_AMTVLT<>[M:POC2]AMTVLT
  [M:POC3]TOTVLT+=([M:POC2]AMTVLT-ANC_AMTVLT)
  If !GIMPORT Affzo [POC3]TOTVLT : Endif
Endif
nolign=SNOLIGN
End


###################################
# Ajout ligne article sur contrat #
###################################
$DIVADDLIN
Local Integer OK

# Issue 71069 - 2016-01-29 by MUARN : PJT
# A faire avant tout le reste
If GPJTSNGDOC = G_NON & [F:POH]CLEFLG=1 Then
 Call PJT_MODFCY([M:POC0]POHFCY,"[M:POC2]PJT") From TRTPJT
Endif

#----- Vérification que le contrat n'est pas périmé -----#
If [M:POC1]ENDDAT<date$
  GMESSAGE=mess(236,194,1) : GERR=1 : Return
Endif
#----- Relecture si nécessaire du fournisseur -----#
If [F:BPS]BPSNUM<>[M:POC0]BPSNUM
  Read [BPS] BPS0=[M:POC0]BPSNUM : If fstat Raz [F:BPS] : Endif
Endif
#----- Contrôle multi-lignes autorisé -----#
If [F:BPS]SEVLIN=1 & [M:POC2]NBART>0
  GMESSAGE=mess(34,194,1)  : GERR=1   : mkstat=2 : Return
Endif
#-----
If [M:POC2]NBART>dim([M:POC2]XITMREF)-1 mkstat=2 : Return : Endif : # Maximum lignes atteint
If GREP=""
  Gosub AVANT_MOD From SUBPOCA : If !OK mkstat=2 : Return : Endif
Endif
#----- Vérification que le contrat n'est pas utilisé sur un autre poste -----#
OK=1 : Gosub VERROU From SUBPOCA
If !OK  mkstat=2 : GMESSAGE=mess(10,100,1) : GERR=1 : Return : Endif
#-----
Gosub MAJ_PWRKPO  From SUBPOCA
If mkstat Return : Endif
Actzo [POC2]1-99
Effzo [POC2]10-99
[M:POC2]POPLIN   =[M:POC1]LASTPOPLIN+1
[M:POC2]PRHFCY   =[M:POC1]RCPFCY
[M:POC2]LINSTOFCY=[M:POC1]STOFCY
[M:POC2]XPUUFLG  =2
[M:POC2]FIMHORUOM=1
[M:POC2]XSTRDAT  =[M:POC1]STRDAT
[M:POC2]XENDDAT  =[M:POC1]ENDDAT
[M:POC2]WCURVLT  =[M:POC1]CUR
# Issue 90991 - 2013-11-06 by MUARN : supression données en commande ouverte
#[M:POC2]CPRCUR = GLOCALDEV # Issue 70985 - 2012-03-26 by MUARN : landed cost
[M:POC2]EECICT2  =[F:BPS]EECICT : # Incoterm
# Issue 71069 - 2016-03-22 by MUARN : pjt
[M:POC2]PJT=[M:POC1]PJTH
If GACTDEB=2
  If [F:BPR2]BPRNUM<>[F:BPS]BPSINV
    Read [BPR2] BPR0=[F:BPS]BPSINV : If fstat  Raz [F:BPR2] : Endif
  Endif
  [M:POC2]EECNUM2=[F:BPR2]EECNUM : # Identification CEE
  [M:POC2]EECLOC2=[F:BPS]EECLOC  : # Lieu de transport CEE
Endif
Call FMTREM("POC2",GCUR) From TRTPRICE
If [M:POC0]BETFCY=2
  If [F:BPC]BPCNUM<>[M:POC0]BPCORD
    Read [BPC]BPC0=[M:POC0]BPCORD : If fstat  Raz [F:BPC] : Endif
  Endif
  If [M:POC0]BETCPY<>2
    Grizo [POC2]PLI, PRIVLT, WCURVLT, 30
  Endif
Else
  Grizo [POC2]LINSTOFCY
Endif
If GREP ="" GREP="M" : mkstat=4 : Endif : # Activation de la touche "Enregistrer"
If GREP="M"  GAPPFLG=2 : Endif

# Issue 71069 - 2016-01-29 by MUARN : PJT
# A faire après tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY([M:POC0]POHFCY,"[M:POC2]PJT") From TRTPJT
Endif

# Issue 90991 - 2013-11-05 by MUARN : supression données en commande ouverte
## Issue 84130 - 2012-09-28 by MUARN : coeff/cout modifiable si pas de SDC
#If [M:POC2]STCNUM<> ""
#  Diszo [POC2]CPRAMT, CPRCOE
#Else
#  Actzo [POC2]CPRAMT, CPRCOE
#Endif

Return


#########################################
# Suppression ligne article sur contrat #
#########################################
$DIVSUPLIN
If [M:POC2]ITMREF="" Goto FIN_DIVSUPLIN : Endif : # si l'onglet article est vide, c'est fini !
Local Shortint L,  NOL
Local Integer  OK, STAT
#----- Vérification si ligne supprimable -----#
NOL=find([M:POC2]POPLIN,[M:POC2]XPOPLIN(0..[M:POC2]NBART-1))-1
If NOL>=0
  OK=1 : Gosub VERF_ANUART From SUBPOCA
  If !OK mkstat=2 : Return : Endif
Endif
#----- Confirmation de la suppression de la ligne article du contrat -----#
# OK=2 : Call OUINON(mess(261,199,1)-[M:POC0]POHNUM-num$([M:POC2]POPLIN)-
# &                  [M:POC2]ITMREF,OK) From GESECRAN
# If OK=1 OK=0 : mkstat=2 : Return : Endif
#----- Vérification que le contrat n'est pas utilisé sur un autre poste -----#
OK=1 : Gosub VERROU From SUBPOCA
If !OK  mkstat=2 : GMESSAGE=mess(10,100,1) : GERR=1 : Return : Endif
#----- Contrôles et questions d'avant modification -----#
If GREP=""
  Gosub AVANT_MOD From SUBPOCA : If !OK mkstat=2 : Return : Endif
Endif
#-----
L=find([M:POC2]POPLIN,[M:POC2]XPOPLIN(0..[M:POC2]NBART-1))
#----- Mise à jour totaux prévus -----#
[M:POC3]TOTVLT-=[M:POC2]AMTVLT
If !GIMPORT Affzo [POC3]TOTVLT : Endif
#-----
If L<>0
  Gosub EFFAC_ART_PWRKPO From SUBPOCA : # Effacement ligne article fichiers travail
  Dela L-1,1,[M:POC2]NBART-1 [M:POC2]NBART : [M:POC2]NBART-=1
Endif
Effzo [POC2]10-99 : Grizo [POC2]10-99 : Affzo [POC2]1-99
#----- Autorisation de la modification fournisseur et devise en création -----#
If GREP="C" & [M:POC2]NBART<1
  Actzo [POC0]POHFCY, BPSNUM
  If [M:POC0]BETFCY<>2 | [M:POC0]BETCPY=2
    Actzo [POC1]CUR, RCPFCY
  Else
    Actzo [POC1]RCPFCY
  Endif
  If [M:POC0]BETFCY=2  Actzo [POC1]STOFCY : Endif
Endif
#-----
If GREP ="" GREP="M" : mkstat=4 : Endif : # Activation de la touche "Enregistrer"
If GREP="M"  GAPPFLG=2 : Endif
Return
$FIN_DIVSUPLIN
Effzo [POC2]10-99 : Grizo [POC2]10-99 : Affzo [POC2]1-99
#----- Autorisation de la modification fournisseur et devise en création -----#
If GREP="C" & [M:POC2]NBART<1
  Actzo [POC0]POHFCY, BPSNUM
  If [M:POC0]BETFCY<>2 | [M:POC0]BETCPY=2
    Actzo [POC1]CUR,RCPFCY
  Else
    Actzo [POC1]RCPFCY
  Endif
  If [M:POC0]BETFCY=2  Actzo [POC1]STOFCY : Endif
Endif
Return

$CTRL_INTERSITE
#-----------------------------------------------------#
# Contrôle et chargement des zones pour l'inter-sites #
# --------------------------------------------------- #
# WPOHFCY : Site de commande                          #
# WBPSNUM : Fournisseur de la commande                #
# WORI    : Origine de l'appel (1=POHFCY, 2=BPSNUM)   #
#-----------------------------------------------------#
Raz GRCPFCY
Call CTRL_INTERSITE(WPOHFCY,WBPSNUM,2,[M:POC0]BETFCY,[M:POC0]BETCPY,[M:POC0]SALFCY,
&                   [M:POC1]STOFCY,[M:POC0]BPCORD,[M:POC1]INVFCY,[M:POC1]BPCINV,GBIDI3) From TRTACHCTL1
If mkstat  GERR=1 : Return : Endif
If [M:POC0]BETFCY=2 : Actzo [POC1]STOFCY : Endif
#----- Si inter-sites et site d'expédition vide, il doit être saisissable -----#
If !GIMPORT & [M:POC0]BETFCY=2 & [M:POC1]STOFCY=""
  If [F:PTR]PTRTYP<>5 | [F:PTR]PTRNUM<>GPTRNUM
    Read [PTR] PTR0=5;GPTRNUM : If fstat  Raz [F:PTR] : Endif
  Endif
  If [F:PTR]STOFCYCOD<>1
    GMESSAGE=mess(257,194,1) : GERR=1 : mkstat=1 : Return
  Endif
Endif
#----- Si inter-sociétés et site de facturation vide, il doit être saisissable -----#
If !GIMPORT & [M:POC0]BETCPY=2 & [M:POC0]SALFCY<>"" & [M:POC1]INVFCY=""
  If [F:PTR]PTRTYP<>5 & [F:PTR]PTRNUM<>GPTRNUM
    Read [PTR] PTR0=5;GPTRNUM : If fstat  Raz [F:PTR] : Endif
  Endif
  If [F:PTR]INVFCYCOD<>1
    GMESSAGE=mess(297,194,1) : GERR=1 : mkstat=1 : Return
  Endif
Endif
#-----
If [M:POC0]BETFCY=2
  Actzo [POC1]STOFCY
  Actzo [POC2]LINSTOFCY
  [POC2]LINSTOFCY=[POC1]STOFCY
Else
  Grizo [POC1]STOFCY
  Grizo [POC2]LINSTOFCY
Endif
Affzo [POC0]BETFCY, BETCPY, SALFCY
Affzo [POC1]STOFCY, INVFCY
Return


$CTRL_BETINVFCY
#-- En inter-sociétés (si facturation)
If [M:POC0]BETCPY=2
  #--- Contrôle sur le site de facturation qui doit être client
  If !clalev([F:BPR2])  Local File BPARTNER  [BPR2] : Endif
  Read [BPR2] BPR2(2)=2;[L]BETINVFCY
  If fstat  Raz [F:BPR2] : Endif
  [G:BPR2]currind=1 : [G:BPR2]currlen=0 : # Réinitialisation clé par défaut
  #----- Vérification que le tiers associé au site commande est client -----#
  If [F:BPR2]BPCFLG<>2
    GMESSAGE=[L]BETINVFCY-mess(258,194,1) : GERR=1 : mkstat=1 : Return
  Endif
  #-- En inter-société Recherche et contrôle du client facture
  Raz GBIDC2, GBIDC3
  Call RECBPCINV([L]BETINVFCY, [M:POC0]SALFCY, GBIDC2) From TRTVENISOC
Endif
Return


$AM_BETITMREF
Raz GMESSAGE, GERR
#--- Appel au programme de contrôle des ventes
Call C_ITMREF(VALEUR, [M:POC0]ORDDAT,1) From TRTVENISOC
If GMESSAGE<>""  mkstat=1 : Return: Endif
#----- Si inter-sites, contrôle que l'unité convienne pour les ventes -----#
Call CTLUOM(VALEUR,2,[M:POC0]BPCORD,[M:POC2]PUU,GBIDD2,GBIDC2,GBIDC3,GBIDI3) From STKACT
If mkstat  Return : Endif
Return


$RECH_BPRADD
Raz [L]BETRCPFCY
Filter [BPD] Where BPCNUM=[L]BPCNUM & ENAFLG=2
  For [BPD]BPD0
    #--- Vérification que le site apparatient à la meme société
    If [F:BPD]RCPFCY<>""
      Read [FCY]FCY0=[F:BPD]RCPFCY
      If !fstat & [F:FCY]LEGCPY = GSOCIETE
        [L]BETRCPFCY=[F:BPD]RCPFCY : Break
      Endif
    Endif
  Next
Filter [BPD]
Return


#------------------------------------------------------------#
# Grisage/dégrisage des champs écran en fonction du contexte #
#------------------------------------------------------------#
$GRISAGE_POC
If [M:POC0]BETFCY=2
  Actzo [POC1]INVFCY
  Actzo [POC2]PRHFCY, LINSTOFCY
  If [M:POC0]BETCPY=2
    Diszo [POC1]PTE, CUR, CHGTYP, VACBPR
    If dim([M:POC1]ZCUR)>0    Diszo [POC1]ZCUR    : Endif
    If dim([M:POC1]ZVACBPR)>0 Diszo [POC1]ZVACBPR : Endif
    Actzo [POC1]30
    Actzo [POC2]PLI, PRIVLT, WCURVLT
    Actzo [POC2]30
    Actzo [POC3]5-10
  Else
    Grizo [POC1]PTE, CUR, CHGTYP, VACBPR
    #VPO 28/03/11 71422 pb de focus si grizo sur tableau déjà invisible
    If varmode([M:POC1]CCE)<>3
        Grizo [POC1]30
    Endif
    If dim([M:POC1]ZCUR)>0    Grizo [POC1]ZCUR    : Endif
    If dim([M:POC1]ZVACBPR)>0 Grizo [POC1]ZVACBPR : Endif
    Grizo [POC2]PLI, PRIVLT, WCURVLT, 30
    Grizo [POC3]5-10
  Endif
  Diszo [POC3]15
Else
  Actzo [POC1]PTE, CUR, CHGTYP, VACBPR, 30
  If dim([M:POC1]ZCUR)>0    Actzo [POC1]ZCUR    : Endif
  If dim([M:POC1]ZVACBPR)>0 Actzo [POC1]ZVACBPR : Endif
  Actzo [POC2]PRHFCY
  Grizo [POC2]LINSTOFCY
  Actzo [POC2]PLI, PRIVLT, WCURVLT, 30
  Actzo [POC3]5-10 : Diszo [POC3]15
Endif
Return


########################################################################
# INIT_COMPTES_LIGNE : S/P d'initialisation               MBT 19/09/06 #
#                des comptes d'une ligne de contrat                    #
# -------------------------------------------------------------------- #
# Subprog INIT_COMPTES_LIGNE                                           #
########################################################################
Subprog INIT_COMPTES_LIGNE
#-----
Local    Shortint I
If [M:POC2]NBCOA=0
  [M:POC2]NBCOA=GNBCOA
  For I=1 To GNBCOA
    [M:POC2]COA(I-1)=GCOA(I)
  Next I
Endif
#----- Chargement de comptes avec "" pour désactiver l'action d'init -----#
For I=1 To GNBCOA
  [M:POC2]LINACC(I-1)=""
Next I
#-----
Local    Char     ID1(20)(1..1), ID2(20)(1..3)
Local    Shortint J, SAVNOLIGN : SAVNOLIGN=nolign
Local    Integer  STA
Local    Char     TPLAN  (GLONCOA)(1..10)
Local    Char     TCOMPTE(GLONGAC)(1..10)
Local    Char     WMESSAGE(80)
#-----
If !clalev([F:GAD])  Local File GAUTACED [GAD] : Endif
Local File PORDER [TB0], PORDERQ [TB1], CPTANALIN [TB2]
#-----
[F:TB0]=[M:POC0] : [F:TB0]=[M:POC1] : [F:TB0]=[M:POC2] : [F:TB0]=[M:POC3]
[F:TB1]=[M:POC0] : [F:TB1]=[M:POC1] : [F:TB1]=[M:POC2] : [F:TB1]=[M:POC3]
If [F:TB1]LINPURTYP=0  [F:TB1]LINPURTYP=1 : Endif
#----- Chargement table liée PORDERP pour la pièce auto PORD -----#
If !GIMPORT
  [F:POP]=[M:POC0] : [F:POP]=[M:POC1] : [F:POP]=[M:POC2] : [F:POP]=[M:POC3]
Endif
If [F:ITM]ITMREF<>[M:POC2]ITMREF
  Read [ITM] ITM0=[M:POC2]ITMREF : If fstat  Raz [F:ITM] : Endif
Endif
For I=0 To dim([F:POP]TSICOD)-1
  [F:POP]TSICOD(I)=[F:ITM]TSICOD(I)
Next I
#----- Initialisation des codes taxe -----#
Call ALIVATCOD(2,[M:POC0]BPSNUM,[M:POC2]ITMREF,"POC2",0) From TRTX3
[F:POP]VAT(0)=[M:POC2]VAT(0)
[F:POP]VAT(1)=[M:POC2]VAT(1)
[F:POP]VAT(2)=[M:POC2]VAT(2)
If func AFNC.ACTIV("PTX")
  If dim([M:POC2]TAXRCP)>0  [F:POP]TAXRCP =[M:POC2]TAXRCP : Endif
  If dim([M:POC2]TAXISS)>0  [F:POP]TAXISS =[M:POC2]TAXISS : Endif
  If dim([M:POC2]TAXOTH1)>0 [F:POP]TAXOTH1=[M:POC2]TAXRCP : Endif
  If dim([M:POC2]TAXOTH2)>0 [F:POP]TAXOTH2=[M:POC2]TAXRCP : Endif
Endif
#----- Chargement pseudo fichier lignes comptables CPTANALIN [TB2] -----#
Raz [F:TB2]
[F:TB2]ABRFIC="POP"
[F:TB2]VCRNUM=[M:POC0]POHNUM
[F:TB2]VCRLIN=[M:POC2]POPLIN
[F:TB2]ANALIG=1
For I=1 To max(GNBCOA,2)
  J=GTYPLED(I)
  If J
    [F:TB2]LED(J-1)=GLEDSOC(I)
    [F:TB2]COA(J-1)=GCOA(I)
    [F:TB2]ACC(J-1)=[M:POC2]LINACC(I-1)
  Endif
Next I
For I=1 To max(GNBDIE,GOPTCANA)
  [F:TB2]DIE(I-1)=GDIE(I)
  If evalue("dim([M:POC2]CCE"+num$(I)+")")>0
    [F:TB2]CCE(I-1)=evalue("[M:POC2]CCE"+num$(I)+"(0)")
  Endif
Next I
#-----
Raz ID1,ID2
#-----
Call COMPTE("PORD",1,ID1,ID2,TPLAN,TCOMPTE,STA,WMESSAGE) From TRTACHCDE1
If STA
  Raz TPLAN, TCOMPTE
Else
  For I=1 To 10
    If TPLAN(I)<>""
     #J=find(TPLAN(I),GCOA(1..GNBCOA))
      J=find([F:GAD]LEDTYP(I-1),GTYPLED(1..GNBTYPLED))
      If J
        [M:POC2]LINACC(J-1)=TCOMPTE(I)
      Endif
    Endif
  Next I
Endif
#-----
Close Local File [TB0], [TB1], [TB2]
nolign=SAVNOLIGN
End


$AFFICH_ACC
#----------------------------------------------------------#
# Affichage des comptes de la ligne élément de facturation #
#----------------------------------------------------------#
If dim(I)<1     Local Integer I    : Endif
If dim(PLAN)<1  Local Integer PLAN : Endif
For I=1 To GNBCOA
  If PLAN<>I : # Ne pas afficher si on se trouve en init sur le champ
    Case I
      When  1 : Affzo [POC3]ACC1 (NOL)
      When  2 : Affzo [POC3]ACC2 (NOL)
      When  3 : Affzo [POC3]ACC3 (NOL)
      When  4 : Affzo [POC3]ACC4 (NOL)
      When  5 : Affzo [POC3]ACC5 (NOL)
      When  6 : Affzo [POC3]ACC6 (NOL)
      When  7 : Affzo [POC3]ACC7 (NOL)
      When  8 : Affzo [POC3]ACC8 (NOL)
      When  9 : Affzo [POC3]ACC9 (NOL)
      When 10 : Affzo [POC3]ACC10(NOL)
    Endcase
  Endif
Next I
Return


########################################################################
# INIT_COMPTES_INVDTA : S/P d'initialisation              MBT 28/12/07 #
#                des comptes d'un élément de facturation               #
# -------------------------------------------------------------------- #
# Subprog INIT_COMPTES_INVDTA (NOL)                                    #
#   NOL    : Indice de la ligne de l'élément à traiter (nolign-1)      #
########################################################################
Subprog INIT_COMPTES_INVDTA (NOL)
Value    Shortint NOL
#-----
Local    Shortint I
#----- Chargement de comptes avec "" pour désactiver l'action d'init -----#
For I=1 To 10
  If evalue("dim([M:POC3]ACC"+num$(I)+")")>0
    Assign "[M:POC3]ACC"+num$(I)+"(NOL)" With ""
  Endif
Next I
#----- Si ligne vide, pas la peine d'initialiser ! -----#
If [M:POC3]INVDTA(NOL)=0  End : Endif
#-----
Local    Libelle  WCDTFLG
Local    Char     ID1(20)(1..1), ID2(20)(1..3), CODPIECE(GLONGAU)
Local    Shortint J, LIG, SAVNOLIGN : SAVNOLIGN=nolign
Local    Integer  STA
Local    Char     TPLAN  (GLONCOA)(1..10)
Local    Char     TCOMPTE(GLONGAC)(1..10)
Local    Char     WMESSAGE(80)
#-----
If [M:POC3]DEBCDT(NOL)=2 & [M:POC3]INVDTAAMT(NOL)=0
  [M:POC3]INVDTAAMT(NOL)=-1 : WCDTFLG=1
Else
  Raz WCDTFLG
Endif
#-----
Local File PORDER [TB0], PVCRFOOT [TB1], CPTANALIN [TB2]
nolign=NOL+1
#----- Chargement pseudo fichier entête PORDER [TB0] -----#
[F:TB0]=[M:POC0] : [F:TB0]=[M:POC1] : [F:TB0]=[M:POC2] : [F:TB0]=[M:POC3]
#-----
For I=0 To dim([F:TB0]INVDTALIN1)-1 : [F:TB0]INVDTALIN1(I)=GINVDTALIN(I) : Next I
#----- Chargement pseudo fichier ligne éléments facturation PVCRFOOT [TB1] -----#
[F:TB1]=[M:POC0] : [F:TB1]=[M:POC1] : [F:TB1]=[M:POC2] : [F:TB1]=[M:POC3]
[F:TB1]VCRNUM=[M:POC0]POHNUM
[F:TB1]VCRTYP=5
[F:TB1]IND   =NOL+1
#----- Pour forcer la condition de la pièce auto et charger le compte et la nature -----#
If [F:TB1]INVLINFLG=2 | [F:TB1]INVLINFLG=3 | [F:TB1]INVLINFLG=4 | [F:TB1]INVLINFLG=5
  [F:TB1]INVLINFLG=0
Endif
#----- Chargement pseudo fichier lignes comptables CPTANALIN [TB2] -----#
Raz [F:TB2]
[F:TB2]ABRFIC="PVF"
[F:TB2]VCRTYP=5
[F:TB2]VCRNUM=[M:POC0]POHNUM
[F:TB2]VCRSEQ=NOL+1
[F:TB2]ANALIG=1
For I=1 To max(GNBCOA,2)
  J=GTYPLED(I)
  If J
    [F:TB2]LED(J-1)=GLEDSOC(I)
    [F:TB2]COA(J-1)=GCOA(I)
    [F:TB2]ACC(J-1)=evalue("[M:POC3]ACC"+num$(I)+"(NOL)")
  Endif
Next I
For I=1 To max(GNBDIE,GOPTCANA)
  [F:TB2]DIE(I-1)=GDIE(I)
  If evalue("dim([M:POC3]PFICCE"+num$(I)+")")>0
    [F:TB2]CCE(I-1)=evalue("[M:POC3]PFICCE"+num$(I)+"(NOL)")
  Endif
Next I
#----- Chargement des identifiants (pas indispensable) -----#
ID1(1)=[M:POC0]POHNUM : # Num pas chargé en création si cteur auto !!
ID2(1)=[M:POC0]POHNUM
ID2(2)="5"
ID2(3)=num$(NOL+1)
If [M:POC0]POHNUM="" Raz ID1,ID2 : Endif
#-----
CODPIECE="POCV"
#----- Lecture de la pièce automatique -----#
If clalev([F:GAU])<=0 Local File GAUTACE   [GAU] : Endif
Read [GAU] GAU0=CODPIECE
If fstat
  Raz [F:GAU] : CODPIECE="PORD"
  [F:TB1]VCRTYP=3
  [F:TB2]VCRTYP=3
  If ID2(2)="5"  ID2(2)="3" : Endif
Endif
#----- Recherche du numéro de ligne de la pièce auto -----#
If clalev([F:GAD])<=0 Local File GAUTACED  [GAD] : Endif
Filter [GAD] Where COD=CODPIECE & LINNUM>0
For [GAD]
  If instr(1,vireblc([F:GAD]ACCKEY(0),4),"INVDTA")
    LIG=[F:GAD]LINNUM : Break
  Endif
Next
Filter [GAD]
If LIG=0
  Look [GAD] GAD0=CODPIECE;9
  If !fstat  LIG=9  Else  LIG=120 : Endif
Endif
#----- Recherche des comptes à l'aide de la pièce auto -----#
Call COMPTE(CODPIECE,LIG,ID1,ID2,TPLAN,TCOMPTE,STA,WMESSAGE) From CPTCOD
If STA
  Raz TPLAN, TCOMPTE, GMESSAGE
Else
  If [F:GAD]COD<>CODPIECE | [F:GAD]LINNUM<>LIG
    Read [GAD] GAD0=CODPIECE;LIG : If fstat  Raz [F:GAD] : Endif
  Endif
  For I=1 To 10
    If TPLAN(I)<>""
     #J=find(TPLAN(I),GCOA(1..GNBCOA))
      J=find([F:GAD]LEDTYP(I-1),GTYPLED(1..GNBTYPLED))
      If J
        Assign "[M:POC3]ACC"+num$(J)+"(NOL)" With TCOMPTE(I)
      Endif
    Endif
  Next I
Endif
#-----
Close Local File [TB0], [TB1], [TB2]
If WCDTFLG=1  [M:POC3]INVDTAAMT(NOL)=0 : Endif
nolign=SAVNOLIGN
#-----
End


###############################################################################
# Préparation des sections analytiques d'une ligne d'élément de facturation   #
# --------------------------------------------------------------------------- #
# Si la clé de répartion est renseignée                                       #
#    il faut "mettre à blanc" toutes les sections                             #
# Si l'axe est suivi en analytique et que la section correspondante est vide  #
#    il faut forcer l'initialisation grâce au Raz                             #
# Si l'axe n'est pas suivi en analytique                                      #
#    il faut "mettre  à blanc" la section correspondante                      #
# --------------------------------------------------------------------------- #
# NOL contient l'indice de la ligne en cours                                  #
# [M:POC3]ACC1-10(NOL) contient les comptes                                   #
# GBIDI2 : 0 = Pas d'affichage des sections analytiques                       #
#          1 = Affichage des sections analytiques                             #
###############################################################################
$PREP_INIT_PFICCE
#-----
If dim(I)<1    Local Integer I             : Endif
If dim(WCCE)<1 Local Char    WCCE(GLONCCE) : Endif
#----- Si clé de répartition renseignée, pas de sections analytiques -----#
If !varinit([M:POC3]DSP,NOL)  [M:POC3]DSP(NOL)=[F:GAC]DSP : Endif
If [M:POC3]DSP(NOL)<>""
  For I=1 To GNBDIE
    If evalue("dim([M:POC3]PFICCE"+num$(I)+")")>0
      Assign"[M:POC3]PFICCE"+num$(I)+"(NOL)" With ""
    Endif
  Next I
#----- Pas de section si pas de suivi analytique sur l'axe concerné -----#
Else
  For I=1 To GNBDIE
    WCCE=evalue("[M:POC3]PFICCE"+num$(I)+"(NOL)")
    Raz mkstat
    Call SAIS_CCE(WCCE,I,"[M:POC3]ACC","[M:POC3]DSP") From TRTX3CPT
    If mkstat
      Assign "[M:POC3]PFICCE"+num$(I)+"(NOL)" With ""
      Raz mkstat
    Elsif evalue("[M:POC3]PFICCE"+num$(I)+"(NOL)")=""
      #----- Raz pour forcer l'initialisation -----#
      Case I
        When  1 : Raz [M:POC3]PFICCE1 (NOL)
        When  2 : Raz [M:POC3]PFICCE2 (NOL)
        When  3 : Raz [M:POC3]PFICCE3 (NOL)
        When  4 : Raz [M:POC3]PFICCE4 (NOL)
        When  5 : Raz [M:POC3]PFICCE5 (NOL)
        When  6 : Raz [M:POC3]PFICCE6 (NOL)
        When  7 : Raz [M:POC3]PFICCE7 (NOL)
        When  8 : Raz [M:POC3]PFICCE8 (NOL)
        When  9 : Raz [M:POC3]PFICCE9 (NOL)
        When 10 : Raz [M:POC3]PFICCE10(NOL)
        When 11 : Raz [M:POC3]PFICCE11(NOL)
        When 12 : Raz [M:POC3]PFICCE12(NOL)
        When 13 : Raz [M:POC3]PFICCE13(NOL)
        When 14 : Raz [M:POC3]PFICCE14(NOL)
        When 15 : Raz [M:POC3]PFICCE15(NOL)
        When 16 : Raz [M:POC3]PFICCE16(NOL)
        When 17 : Raz [M:POC3]PFICCE17(NOL)
        When 18 : Raz [M:POC3]PFICCE18(NOL)
        When 19 : Raz [M:POC3]PFICCE19(NOL)
        When 20 : Raz [M:POC3]PFICCE20(NOL)
      Endcase
    Endif
  Next I
Endif
#----- Affichage des sections analytiques -----#
If GBIDI2=1
  Affzo [POC3]DSP(NOL)
  Gosub AFFICH_PFICCE From SUBPOC
Endif
Return


$AFFICH_PFICCE
#-----------------------------------------------------------------#
# Affichage des sections analytiques ligne élément de facturation #
#-----------------------------------------------------------------#
If dim(I)<1  Local Integer I : Endif
For I=1 To GNBDIE
  Case I
    When  1 : Affzo [POC3]PFICCE1 (NOL)
    When  2 : Affzo [POC3]PFICCE2 (NOL)
    When  3 : Affzo [POC3]PFICCE3 (NOL)
    When  4 : Affzo [POC3]PFICCE4 (NOL)
    When  5 : Affzo [POC3]PFICCE5 (NOL)
    When  6 : Affzo [POC3]PFICCE6 (NOL)
    When  7 : Affzo [POC3]PFICCE7 (NOL)
    When  8 : Affzo [POC3]PFICCE8 (NOL)
    When  9 : Affzo [POC3]PFICCE9 (NOL)
    When 10 : Affzo [POC3]PFICCE10(NOL)
    When 11 : Affzo [POC3]PFICCE11(NOL)
    When 12 : Affzo [POC3]PFICCE12(NOL)
    When 13 : Affzo [POC3]PFICCE13(NOL)
    When 14 : Affzo [POC3]PFICCE14(NOL)
    When 15 : Affzo [POC3]PFICCE16(NOL)
    When 16 : Affzo [POC3]PFICCE17(NOL)
    When 17 : Affzo [POC3]PFICCE17(NOL)
    When 18 : Affzo [POC3]PFICCE18(NOL)
    When 19 : Affzo [POC3]PFICCE19(NOL)
    When 20 : Affzo [POC3]PFICCE20(NOL)
  Endcase
Next I
Return

