# Issue 90991 - 2013-11-05 by MUARN : supression données en commande ouverte
#Subprog AM_CPRCOE(VALEUR)
#Variable Decimal VALEUR
#If VALEUR=0  mkstat=2 : End : Endif
#End

#                                           # hcb 71276 deb
Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local Char    WECCVALMAJ(GLONECS)
Local Char    WECCVALMIN(GLONEVL)
Local Char    PITM(GLONITM)
Raz WECCVALMAJ
Raz WECCVALMIN
Raz PITM
If [F:ITM]ITMREF <> [M:POC2]ITMREF
 Read [F:ITM]ITM0 = [M:POC2]ITMREF
 If fstat : Raz [F:ITM] : Endif
Endif
# si version majeure trouvée et si article gere la version mineure : recherche derniere version mineure
If VALEUR  <> "" & [F:ITM]ECCSTO = 3
   WECCVALMAJ = VALEUR
   PITM = [F:ITM]ITMREF
   Gosub READECCMIN From STKACT
   [M:POC2]ECCVALMIN = WECCVALMIN
   Affzo [M:POC2]ECCVALMIN
Elsif VALEUR = "" & [M:POC2]ECCVALMIN <> ""
      Raz   [M:POC2]ECCVALMIN
      Affzo [M:POC2]ECCVALMIN
Endif

End

#                                           # hcb 71276 fin

######################################################################################
# Issue 71069 - 2016-01-12 by MUARN : PJT
Subprog AM_PJTH(VALEUR)
Variable Char    VALEUR()
If [M:POC2]NBART > 0
  If func SUBPOCA.REPERCUTE_PJTH([M:POC1]PJTH, VALEUR) <> 0 Then
    mkstat=2 : End
  Endif

Else
  [M:POC2]PJT=VALEUR : Affzo [POC2]PJT
  # Issue 71069 - 2016-09-07 by MUARN : PJT
  Gosub AM_PJTH From SUBPOCA
Endif
End

Subprog AM_PJT(VALEUR)
Variable Char    VALEUR()
# mise à jours des conditions tarifaires
If [M:POC2]NBLIG>0
  If func SUBPOCA.REPERCUTE_PJT(VALEUR) <> 0 Then
    mkstat=2 : End
  Endif
Endif

End


