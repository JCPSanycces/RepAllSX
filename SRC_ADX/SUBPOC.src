#<AdxTL>@(#)9.0.0.0 $Revision$
#########################################################################
# SUBPOC : Gestion des commandes ouvertes d'achat           CG 20/01/98 #
#           Modifié                                         HN Sep 2003 #
# --------------------------------------------------------------------- #
# Traitements sur champ "Call" de l'objet "POC"    modifié MBT 03/01/01 #
# Le traitement des actions "Gosub" se trouvent dans le SUBPOCA         #
#                                                                       #
# GSYSCUR   = Devise dossier (reporting)                                #
# GLOCALDEV = Devise société                                            #
# GCUR      = Devise commande                                           #
# GFINRSP   = Site financier                                            #
#########################################################################

$ACTION
#---------------------------------#
# Actions de l'objet POC (GOBJET) #
#---------------------------------#
Case ACTION
 When "DEFTRANS"     : Gosub DEFTRANS      From SUBPOCA
 When "VARIANTE"     : Gosub VARIANTE      From SUBPOCA
 When "SETTRANS"     : Gosub SETTRANS      From SUBPOCA
 When "AVANT_OUVRE"  : Gosub AVANT_OUVRE   From SUBPOCA # Issue 116835 - 2016-05-31 by SR
 When "FILTRE"       : Gosub FILTRE        From SUBPOCA
 When "AV_IMPRIME"   : Gosub AV_IMPRIME    From SUBPOCA
 When "AP_IMPRIME"   : Gosub AP_IMPRIME    From SUBPOCA
 When "OUVRE"        : Gosub OUVRE         From SUBPOCA
 When "AFFMASK"      : Gosub AFFMASK       From SUBPOCA
 When "AVANTBOUT"    : Gosub AVANTBOUT     From SUBPOCA
 When "SETBOUT"      : Gosub SETBOUT       From SUBPOCA
 When "EXEBOUT"      : Gosub EXEBOUT       From SUBPOCA
 When "FIN_ACTION"   : Gosub FIN_ACTION    From SUBPOCA
 When "STATUT"       : Gosub STATUT        From SUBPOCA
 When "DEFLIG"       : Gosub DEFLIG        From SUBPOCA
 When "LIENS_LIG"    : Gosub LIENS_LIG     From SUBPOCA
 When "INICRE_LIG"   : Gosub INICRE_LIG    From SUBPOCA
 When "INIMOD_LIG"   : Gosub INIMOD_LIG    From SUBPOCA
 When "VALLIG"       : Gosub VALLIG        From SUBPOCA
 When "RAZCRE"       : Gosub RAZCRE        From SUBPOCA
 When "RAZDUP"       : Gosub RAZDUP        From SUBPOCA
 When "LIENS"        : Gosub LIENS         From SUBPOCA
 When "APRES_MODIF"  : Gosub APRES_MODIF   From SUBPOCA
 When "VERIF_CRE"    : Gosub VERIF         From SUBPOCA
 When "INICRE"       : Gosub INICRE        From SUBPOCA
 When "CREATION"     : Gosub CREATION      From SUBPOCA
 When "APRES_CRE"    : Gosub APRES_CRE     From SUBPOCA
 When "AB_CREATION"  : Gosub AB_CREATION   From SUBPOCA
 When "AVANT_MOD"    : Gosub AVANT_MOD     From SUBPOCA
 When "VERIF_MOD"    : Gosub VERIF         From SUBPOCA
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC  From SUBPOCA
 When "INIMOD"       : Gosub INIMOD        From SUBPOCA
 When "MODIF"        : Gosub MODIF         From SUBPOCA
 When "APRES_MOD"    : Gosub APRES_MOD     From SUBPOCA
 When "ABANDON"      : Gosub ABANDON       From SUBPOCA
 When "AB_MODIF"     : Gosub AB_MODIF      From SUBPOCA
 When "VERF_ANU"     : Gosub VERF_ANU      From SUBPOCA
 When "ANNULE"       : Gosub ANNULE        From SUBPOCA
 When "AP_ANNULE"    : Gosub AP_ANNULE     From SUBPOCA
 When "FERME"        : Gosub FERME         From SUBPOCA
#---------------------------#
# Actions champs modèlisées #
#---------------------------#
 When "BAM_BPSNUM"   : Gosub BAM_BPSNUM
 When "AAM_PRHFCY"   : Gosub AAM_PRHFCY
 When "BAM_PRHFCY"   : Gosub BAM_PRHFCY
 When "AB4_NBART"    : Gosub AB4_NBART # Issue 116835 - 2016-05-30 by SR
 When "BB4_NBART"    : Gosub BB4_NBART # Issue 116835 - 2016-05-30 by SR
#--------------------------------------------#
# Action sur les affichages divers (GACTION) #
#   - DIVADDLIN : Ajout d'une ligne article  #
#   - DIVSUPLIN : Suppression ligne article  #
#--------------------------------------------#
 When "TRT_DIV"
   Case TRAIT
    When "DIVADDLIN" : Gosub DIVADDLIN
    When "DIVSUPLIN" : Gosub DIVSUPLIN
   Endcase
 When Default
Endcase
Return


Subprog AM_POHFCY(VALEUR)
#------------------------------------------------------#
#        Après modification du site de commande        #
# ---------------------------------------------------- #
# Rechargement GSOCIETE : Société juridique            #
#              GLOCALDEV: Devise sté juridique         #
#              GFINRSP  : Site financier               #
#              GFCY     : Site de commande             #
#              GRCPFCY  : Site de réception par défaut #
# Récupération des paramètres achats                   #
#------------------------------------------------------#
Variable Char     VALEUR
GFCY=VALEUR : Gosub CHARG_PARAM From SUBPOCA
If GMESSAGE<>""
  Local Char WMESS(80) : WMESS=GMESSAGE
  GERR=1
  GFCY=[M:POC0]POHFCY : Gosub CHARG_PARAM From SUBPOCA
  GMESSAGE=WMESS
  mkstat=1 : End
Endif
# Issue 71069 - 2016-01-12 by MUARN : PJT
# A faire avant tout le reste
If GPJTSNGDOC = G_NON Then
 Call PJT_MODFCY(VALEUR,"[M:POC2]PJT") From TRTPJT
Endif
#----- Contrôle et chargement des zones inter-sites -----#
If [M:POC0]BPSNUM<>"" & [M:POC0]BETFCY<>0
  Local Char    WPOHFCY(GLONFCY) : [L]WPOHFCY=VALEUR
  Local Char    WBPSNUM(GLONBPS) : [L]WBPSNUM=[M:POC0]BPSNUM
  Local Libelle WORI             : [L]WORI=1
  Gosub CTRL_INTERSITE
  If mkstat
    End
  Else
    Gosub GRISAGE_POC : # Grisage/dégrisage des champs écran en fonction du contexte
  Endif
Endif
#-----
[M:POC1]BUY   =GUSER
[M:POC1]RCPFCY=GRCPFCY
[M:POC1]INVFCY=GFINRSP
[M:POC2]PRHFCY=GRCPFCY
If [F:FCY]FCY<>[M:POC2]PRHFCY
  Read [FCY] FCY0=[M:POC2]PRHFCY : If fstat Raz [F:FCY] : Endif
Endif
[M:POC2]FCYADD=[F:FCY]BPAADD
#----- Effacement tableau des sections entête -----#
If dim([M:POC1]NBAXE)>0 & [M:POC1]NBAXE>0
  [M:POC0]POHFCY=VALEUR
  Effzo [POC1]30 : Affzo [POC1]30 : Setmok [POC1] With 0
Endif
#----- Si changement de société -----#
If GSOC_UPDFLG
  If [M:POC0]BPSNUM<>""
    Call INIT_ESCOMPTE([M:POC1]BPSINV,GSOCIETE,"F",[M:POC1]DEP) From CPTSUB
    Call AM_DEP([M:POC1]DEP) From SUBPOC
    Affzo [POC1]DEP
  Endif
Endif
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL From SUBPOCA
# Issue 71069 - 2016-01-12 by MUARN : PJT
# A faire apres tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY(VALEUR,"[M:POC2]PJT") From TRTPJT
Endif
End


Subprog C_POHNUM(VALEUR)
#-------------------------------------#
# Contrôle sur numéro de commande     #
# pas de duplication sur les contrats #
#-------------------------------------#
Variable Char     VALEUR
If GREP<>"C" & GREP<>"D"
  Look [POH] POH0=VALEUR
  If fstat   GMESSAGE=mess(178,199,1) : mkstat=1 : Endif
Elsif GMANCOU=2
  VALEUR=vireblc(VALEUR,2)
  Look [POH] POH0=VALEUR
  If !fstat  GMESSAGE=mess(22,100,1)  : mkstat=1 : Endif
Endif
End


Subprog AV_FILLER3(VALEUR)
#---------------------------------------------------#
# Affichage de "/" si affichage du numéro d'avenant #
#---------------------------------------------------#
Variable Char    VALEUR()
If [M:POC0]REVNUM<>0  VALEUR="/" Else VALEUR="" : Endif
End


Subprog IB_BPSNUM
#---------------------------------------#
# Initialisation bouton sur fournisseur #
#---------------------------------------#
If [M:POC0]BPSNUM="" Raz GBOUT2 : Endif : # Suppression bouton adresse fournisseur
Raz [M:POC0]WTRAIT

Call IB_NOTECHECK([M:POC0]BPSNUM,"BPSNUM",4)  From TRTNTSCTL # supplier notes

End


Subprog AM_BPSNUM(VALEUR)
#-------------------------#
# Après modif fournisseur #
#-------------------------#
Variable Char     VALEUR
Local    Integer  I
Local    Char     SECTION(GLONCCE)
Local    Char     WPOHFCY(GLONFCY) : [L]WPOHFCY=[M:POC0]POHFCY
Local    Char     WBPSNUM(GLONBPS) : [L]WBPSNUM=VALEUR
Local    Libelle  WORI             : [L]WORI=2
If !GIMPORT
  [M:POC0]WTRAIT=9  : # Court-circuite l'appel de la saisie adresse en après modif
  If [F:BPS]BPSTYP<>3
    If [M:AD63]ADBFLG>0 & [M:POC0]BPSNUM<>"" Raz [M:AD63] : Endif
    If [M:AD64]ADBFLG>0 & [M:POC0]BPSNUM<>"" Raz [M:AD64] : Endif
  Else
    [M:POC0]WTRAIT=0 : # Active l'appel de la saisie adresse en après modif
  Endif
  #----- Affichage des observations fournisseur -----#
  If len([F:BPS]BPSREM) Call MESSAGE([F:BPS]BPSREM) From GESECRAN : Endif
Endif
#----- Lecture BPARTNER si nécessaire pour chargement CUR, LAN -----#
If [F:BPR]BPRNUM<>VALEUR
  Read [BPR] BPR0=VALEUR
  If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
GCUR=[F:BPS]CUR
[M:POC1]CUR    =[F:BPS]CUR
[M:POC2]WCURVLT=[F:BPS]CUR
# Issue 90991 - 2013-11-06 by MUARN : supression données en commande ouverte
#[M:POC2]CPRCUR = GLOCALDEV # Issue 70985 - 2012-03-26 by MUARN : landed cost
[M:POC3]WCUR   =[F:BPS]CUR
[M:POC3]WCUR1  =[F:BPS]CUR
[M:AD63]BPAADD =[F:BPS]BPAADD
[M:AD64]BPAADD =[F:BPS]BPAADD
#--------------------------------------------------#
# Type de donnée MC1 = devise commande (GCUR)      #
#                MC2 = devise société  (GLOCALDEV) #
#                MC3 = devise dossier  (GSYSCUR)   #
#--------------------------------------------------#
GDEV1(1)=GCUR : GDEV1(2)=GLOCALDEV : GDEV1(3)=GSYSCUR
For I=1 To 3
  GDEVFM1(I)=GDEVFMT1(max(find(GDEV1(I),GDEVISE(1..GNBDEV)),1))
Next I
#-----
If [M:AD63]ADBFLG=2  [M:POC0]XBPRNAM=[M:AD63]BPRNAM(0)
                Else [M:POC0]XBPRNAM=[F:BPS]BPSNAM    : Endif
If !GIMPORT Affzo [POC0]XBPRNAM : Endif
If [F:BPS]BPRPAY=""
  [M:POC1]BPRPAY=VALEUR
  [M:POC1]BPAPAY=[F:BPS]BPAADD
Else
  [M:POC1]BPRPAY=[F:BPS]BPRPAY
  [M:POC1]BPAPAY=[F:BPS]BPAPAY
Endif
If [F:BPS]BPSINV=""
  [M:POC1]BPSINV=VALEUR
  [M:POC1]BPAINV=[F:BPS]BPAADD
Else
  [M:POC1]BPSINV=[F:BPS]BPSINV
  [M:POC1]BPAINV=[F:BPS]BPAINV
Endif
[M:POC0]BPSNUM = VALEUR
[M:POC1]MDL    = [F:BPS]MDL
[M:POC1]BPTNUM = [F:BPS]BPTNUM
[M:POC1]CHGTYP = [F:BPS]CHGTYP
[M:POC2]EECICT2= [F:BPS]EECICT : # Incoterm
If GACTDEB=2
  If [F:BPR2]BPRNUM<>[F:BPS]BPSINV
    Read [BPR2] BPR0=[F:BPS]BPSINV : If fstat  Raz [F:BPR2] : Endif
  Endif
  [M:POC2]EECNUM2=[F:BPR2]EECNUM : # Identification CEE
  [M:POC2]EECLOC2=[F:BPS]EECLOC  : # Lieu de transport CEE
Endif
#----- Alimentation à partir du modèle d'édition du fournisseur commande -----#
Call ALI_PRTMOD("POC0",9) From TRTX3
#----- Condition de paiement du tiers payé -----#
Call INIPTE ([M:POC1]BPRPAY, VALEUR, "F", [M:POC1]PTE) From TRTX3
#----- Escompte du tiers facturant -----#
Call INIT_ESCOMPTE([M:POC1]BPSINV,GSOCIETE,"F",[M:POC1]DEP) From CPTSUB
Call AM_DEP([M:POC1]DEP) From SUBPOC
#----- Contrôle et chargement des zones inter-sites -----#
Gosub CTRL_INTERSITE : If mkstat  Raz [M:POC0]BPSNUM : End : Endif
[M:POC1]RCPFCY=GRCPFCY
[M:POC2]PRHFCY=GRCPFCY
If [F:FCY]FCY<>[M:POC2]PRHFCY
  Read [FCY] FCY0=[M:POC2]PRHFCY : If fstat Raz [F:FCY] : Endif
Endif
[M:POC2]FCYADD=[F:FCY]BPAADD
#----- Chargement du régime taxe du fournisseur -----#
Call INIT_REGIME(VALEUR,[M:POC0]POHFCY,"F",[M:POC1]VACBPR) From CPTSUB
#----- Chargement du type de régime taxe -----#
# 71937 : Multilégislation
#If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[M:POC1]VACBPR
#  Read [ADI] CODE=1;[M:POC1]VACBPR : If fstat Raz [F:ADI] : Endif
#Endif
#[M:POC1]VACTYP=[F:ADI]N1
If !clalev([F:TVB]) Local File TABVACBPR [TVB] Endif
Local Integer GRET
Call LEC_TVB_LEG(GCURLEG,[M:POC1]VACBPR,GRET) From TRTLECLEG
If GRET Raz [F:TVB] : Endif
[M:POC1]VACTYP=[F:TVB]REGVAC
# 71937 : Multilégislation
#----- Chargement du cours devise -----#
Call COURSITE(GCUR,GFCY,[M:POC1]CHGTYP,[M:POC0]ORDDAT,[M:POC1]CHGCOE,I) From TRTDEV
#----- Chargement libellés et formats colonnes tarif -----#
If GPLISTC<>[F:BPS]PLISTC
  GPLISTC=[F:BPS]PLISTC
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
  Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
  Call TARIFCHGT(6)                From TRTPRICE
  #----- Affichage entêtes de colonne variables -----#
  If !GIMPORT
    Local Char BASPAG(10) : BASPAG="NBLIG" : Gosub TIT_COL From ="W1WE5"+GPTRNUM+"2"
  Endif
Endif
Call FMTREM("POC2",GCUR) From TRTPRICE
#----- Conversion Mt mini commande -----#
If GSYSCUR<>GCUR
  Local Integer STAT
  Call CONVERT(GSYSCUR,GCUR,GLOCALDEV,[M:POC1]CHGTYP,[M:POC0]ORDDAT,
&              [F:BPS]ORDMINAMT,[M:POC3]WORDMINAMT,STAT) From TRTDEV
Else
  GBIDD1=1
  [M:POC3]WORDMINAMT=[F:BPS]ORDMINAMT
Endif
#------ Chargement des éléments de facturation -----#
Call INIT_ELEMENTS (5,[M:POC1]CHGTYP,[F:BPS]CUR,GCUR) From TRTACHELT1
#----- Initialisation des sections analytiques -----#
If dim([M:POC1]NBAXE)>0
  [M:POC1]NBAXE=GNBDIE
  For I=1 To GNBDIE
    [M:POC1]DIE(I-1)=GDIE(I)
    Call INISEC(SECTION,"POH",GDIE(I)) From SUBCDE
    [M:POC1]CCE(I-1)=SECTION
  Next I
Endif
#----- Relecture BPR et BPS au cas ou le INISEC casse les buffers -----#
If [F:BPR]BPRNUM<>VALEUR
  Read [BPR] BPR0=VALEUR : If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>VALEUR
  Read [BPS] BPS0=VALEUR : If fstat Raz [F:BPS] : Endif
Endif
#----- Activation / désactivation site de vente et .. si contrat inter-site -----#
If [M:POC0]BETFCY=2
  #----- Récupération du 1er code tarif actif et de type normal -----#
  Call D_PLI([M:POC2]PLI)
  #----- Récupération prix de valorisation -----#
  Call VALORIS_LIGNE From SUBPOC
Endif
#----- Grisage/dégrisage des champs écran en fonction du contexte -----#
Gosub GRISAGE_POC
#----- Récupération du lien texte entête ou pied -----#
If GPURTEXORD=1
  [M:POC1]TEX1=[F:BPS]ORDTEX : Raz [M:POC1]TEX2
Else
  [M:POC1]TEX2=[F:BPS]ORDTEX : Raz [M:POC1]TEX1
Endif
#----- Affichage des 3 onglets -----#
If !GIMPORT
  Affzo [POC1]1-99 : Affzo [POC2]1-99 : Affzo [POC3]1-99
Endif
If [M:POC1]CUR=GLOCALDEV Diszo [POC1]CHGTYP : Endif
End


$BAM_BPSNUM
#---------------------------------------#
# Après exécution de l'action SAIADRBPR #
# ------------------------------------- #
# Si fournisseur divers :               #
#   Copie de l'adresse commande sur     #
#            l'adresse d'expédition     #
#---------------------------------------#
If !GIMPORT & [F:BPS]BPSTYP=3 & [M:POC0]WTRAIT=0
  [M:AD64]=[M:AD63] : # Copie de l'adresse commande sur adresse d'expédition
Endif
Return


Subprog AM_ORDDAT(VALEUR)
#-----------------------------------#
# Après modif de la date du contrat #
#-----------------------------------#
Variable Date    VALEUR
[M:POC1]STRDAT=VALEUR
[M:POC1]ENDDAT=VALEUR+365
If !GIMPORT Affzo [POC1]STRDAT, ENDDAT : Endif
End


Subprog C_SALFCY(VALEUR)
#-----------------------------------#
# Contrôle site de vente :          #
# Obligatoire si contrat inter-site #
# et sur même société juridique     #
#-----------------------------------#
Variable Char    VALEUR()
If [M:POC0]BETFCY=2 & VALEUR=""                     mkstat=1 : End : Endif
If [F:FCY]LEGCPY<>GSOCIETE GMESSAGE=mess(2,194,1) : mkstat=1 : End : Endif
End


Subprog C_BPSINV(VALEUR)
#--------------------------------#
# Contrôle fournisseur facturant #
#--------------------------------#
Variable Char    VALEUR()
#----- Vérification que la structure soit identique -----#
If [F:BPS]PLISTC<>GPLISTC
  GMESSAGE=mess(141,199,1)-"("+[F:BPS]PLISTC-"<>"-GPLISTC+")"
  mkstat=1 : End
Endif
End

Subprog AM_BPSINV(VALEUR)
#--------------------------------------#
# Après modif du fournisseur facturant #
#--------------------------------------#
Variable Char    VALEUR()
If !clalev([F:BPS2])  Local File BPSUPPLIER [BPS2] : Endif
Read [BPS2] BPS0=[M:POC0]BPSNUM : If fstat  Raz [F:BPS2] : Endif
If [F:BPS2]BPSINV=VALEUR
  [M:POC1]BPAINV=[F:BPS2]BPAINV
Elsif [F:BPS]BPSINV=VALEUR
  [M:POC1]BPAINV=[F:BPS]BPAINV
Else
  [M:POC1]BPAINV=[F:BPS]BPAADD
Endif
#------ Chargement des éléments de facturation -----#
[M:POC1]BPSINV=VALEUR
Call INIT_ELEMENTS (5,[M:POC1]CHGTYP,[F:BPS2]CUR,GCUR) From TRTACHELT1
#-----
Call INIT_ESCOMPTE([M:POC1]BPSINV,GSOCIETE,"F",[M:POC1]DEP) From CPTSUB
Call AM_DEP([M:POC1]DEP) From SUBPOC
If !GIMPORT  Affzo [POC1]BPAINV, DEP : Affzo [POC3]1-99 : Endif
End

Subprog C_BPAINV(VALEUR)
#---------------------------------------------#
# Contrôle code adresse fournisseur facturant #
#---------------------------------------------#
Variable Char    VALEUR()
Look [BPA] BPA0=1;[M:POC1]BPSINV;VALEUR
If fstat  GMESSAGE=mess(16,199,1) : mkstat=1 : End : Endif
End

Subprog AM_BPRPAY(VALEUR)
#---------------------------#
# Après modif du tiers payé #
#---------------------------#
Variable Char    VALEUR()
If !clalev([F:BPS2])  Local File BPSUPPLIER [BPS2] : Endif
Read [BPS2] BPS0=[M:POC0]BPSNUM : If fstat  Raz [F:BPS2] : Endif
If [F:BPS2]BPRPAY=VALEUR
  [M:POC1]BPAPAY=[F:BPS2]BPAPAY
Else
  If [F:BPS2]BPSNUM<>VALEUR
    Read [BPS2] BPS0=VALEUR : If fstat  Raz [F:BPS2] : Endif
  Endif
  If [F:BPS2]BPRPAY=VALEUR
    [M:POC1]BPAPAY=[F:BPS2]BPAPAY
  Elsif [F:BPS2]BPAADD<>""
    [M:POC1]BPAPAY=[F:BPS2]BPAADD
  Else
    If [F:BPR]BPRNUM<>VALEUR
      Read [BPR] BPR0=VALEUR : If fstat  Raz [F:BPR] : Endif
    Endif
    [M:POC1]BPAPAY=[F:BPR]BPAADD
    #----- Rechargement du  business partner commande si nécessaire -----#
    If [F:BPR]BPRNUM<>[M:POC0]BPSNUM
      Read [BPR] BPR0=[M:POC0]BPSNUM : If fstat  Raz [F:BPR] : Endif
    Endif
  Endif
Endif
If !GIMPORT  Affzo [POC1]BPAPAY : Endif
#----- Condition de paiement du tiers payé -----#
If [F:BPS2]BPSNUM<>VALEUR
  Read [BPS2] BPS0=VALEUR : If fstat  Raz [F:BPS2] : Endif
Endif
If GPAYTERM=1 & [F:BPS2]PTE<>""
  [M:POC1]PTE=[F:BPS2]PTE : If !GIMPORT  Affzo [POC1]PTE : Endif
Endif
#-----
End

Subprog C_BPAPAY(VALEUR)
#----------------------------------#
# Contrôle code adresse tiers payé #
#----------------------------------#
Variable Char    VALEUR()
Look [BPA] BPA0=1;[M:POC1]BPRPAY;VALEUR
If fstat  GMESSAGE=mess(16,199,1) : mkstat=1 : End : Endif
End


Subprog C_STRDAT(VALEUR)
#--------------------------------------------#
# Controle date début de validité du contrat #
#--------------------------------------------#
Variable Date     VALEUR
If VALEUR>[M:POC1]DATMIN & [M:POC1]DATMIN<>[0/0/0]
  GMESSAGE=mess(70,199,1) : mkstat=2 : End
Endif
If [M:POC2]NBART=0 & [M:POC2]XSTRDAT<>[0/0/0]
  [M:POC2]XSTRDAT=VALEUR : Affzo [POC2]XSTRDAT
Endif
End


Subprog C_ENDDAT(VALEUR)
#------------------------------------------#
# Contrôle date fin de validité du contrat #
#------------------------------------------#
Variable Date     VALEUR
If VALEUR<[M:POC1]STRDAT
  mkstat=2 : End
Endif
If VALEUR<[M:POC1]DATMAX & [M:POC1]DATMAX<>[0/0/0]
  GMESSAGE=mess(70,199,1) : mkstat=2 : End
Endif
If VALEUR<[M:POC0]ORDDAT
  GMESSAGE=mess(98,199,1) : mkstat=2 : End
Endif
If [M:POC2]NBART=0 & [M:POC2]XENDDAT<>[0/0/0]
  [M:POC2]XENDDAT=VALEUR : Affzo [POC2]XENDDAT
Endif
End


Subprog AM_DEP(VALEUR)
#----------------------#
# Après modif Escompte #
#----------------------#
Variable Char    VALEUR()
Call ALIDISVAT(VALEUR,"POC3") From TRTACHELT1
End


Subprog AM_CUR(VALEUR)
#--------------------------------------#
#          Après modif devise          #
# ------------------------------------ #
# Chargement et affichage cours devise #
# Conversion éléments de facturation   #
#--------------------------------------#
Variable Char    VALEUR()
Local    Integer I
Local    Char    SECTION(GLONCCE)
GCUR=VALEUR
[M:POC2]WCURVLT=VALEUR
[M:POC3]WCUR   =VALEUR
[M:POC3]WCUR1  =VALEUR
#--------------------------------------------------#
# Type de donnée MC1 = devise commande (GCUR)      #
#                MC2 = devise société  (GLOCALDEV) #
#                MC3 = devise dossier  (GSYSCUR)   #
#--------------------------------------------------#
GDEV1(1)=GCUR : GDEV1(2)=GLOCALDEV : GDEV1(3)=GSYSCUR
For I=1 To 3
  GDEVFM1(I)=GDEVFMT1(max(find(GDEV1(I),GDEVISE(1..GNBDEV)),1))
Next I
#-----
I=0
Call COURSITE(GCUR,GFCY,[M:POC1]CHGTYP,[M:POC0]ORDDAT,[M:POC1]CHGCOE,I) From TRTDEV
#----- Conversion éléments de facturation -----#
Call CONVERT_INVDTAAMT(VALEUR,[M:POC1]CHGTYP) From SUBPOC
#----- Chargement formats colonnes tarif -----#
Call FMTREM("POC2",GCUR) From TRTPRICE
#----- Conversion Mt mini commande -----#
If GSYSCUR<>GCUR
  Local Integer STAT
  Call CONVERT(GSYSCUR,GCUR,GLOCALDEV,[M:POC1]CHGTYP,[M:POC0]ORDDAT,
&              [F:BPS]ORDMINAMT,[M:POC3]WORDMINAMT,STAT) From TRTDEV
Else
  GBIDD1=1 : [M:POC3]WORDMINAMT=[F:BPS]ORDMINAMT
Endif
#----- Initialisation des sections analytiques -----#
If dim([M:POC1]NBAXE)>0
  [M:POC1]NBAXE=GNBDIE
  For I=1 To GNBDIE
    If [M:POC1]CCE(I-1)=""
      [M:POC1]DIE(I-1)=GDIE(I)
      Call INISEC(SECTION,"POH",GDIE(I)) From SUBCDE
      [M:POC1]CCE(I-1)=SECTION
    Endif
  Next I
Endif
#----- Relecture des enreg BPR et BPS au cas ou le INISEC casse les buffers -----#
If [F:BPR]BPRNUM<>[M:POC0]BPSNUM
  Read [BPR] BPR0=[M:POC0]BPSNUM : If fstat  Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[M:POC0]BPSNUM
  Read [BPS] BPS0=[M:POC0]BPSNUM : If fstat  Raz [F:BPS] : Endif
Endif
#-----
If !GIMPORT
  Affzo [POC1]CHGCOE,30 : Affzo [POC3]5,10
Endif
If VALEUR=GLOCALDEV
  Diszo [POC1]CHGTYP, CHGCOE
Else
  Actzo [POC1]CHGTYP, CHGCOE
Endif
End


Subprog AM_CHGTYP(VALEUR)
#--------------------------------------#
#      Après modif type de cours       #
# ------------------------------------ #
# Chargement et affichage cours devise #
# Conversion éléments de facturation   #
#--------------------------------------#
Variable Integer  VALEUR
Local    Integer  I
Call COURSITE(GCUR,GFCY,VALEUR,[M:POC0]ORDDAT,[M:POC1]CHGCOE,I) From TRTDEV
#----- Conversion éléments de facturation -----#
Call CONVERT_INVDTAAMT(GCUR,VALEUR) From SUBPOC
#----- Conversion Mt mini commande et Mt encours autorisé -----#
If GSYSCUR<>GCUR
  Local Integer STAT
  Call CONVERT(GSYSCUR,GCUR,GLOCALDEV,VALEUR,[M:POC0]ORDDAT,
&              [F:BPS]ORDMINAMT,[M:POC3]WORDMINAMT,STAT) From TRTDEV
Else
  GBIDD1=1 : [M:POC3]WORDMINAMT=[F:BPS]ORDMINAMT
Endif
If !GIMPORT
  Affzo [POC1]CHGCOE : Affzo [POC3]5,10
Endif
End


Subprog AM_BUY (VALEUR)
#------------------------------------------------------------#
# Après modif acheteur : Chargement des sections analytiques #
#------------------------------------------------------------#
Variable Char    VALEUR()
[M:POC1]BUY=VALEUR
Local Char     SECTION(GLONCCE)
Local Shortint I
#----- Initialisation des sections analytiques -----#
If dim([M:POC1]NBAXE)>0
  [M:POC1]NBAXE=GNBDIE
  For I=1 To GNBDIE
    If [M:POC1]CCE(I-1)=""
      [M:POC1]DIE(I-1)=GDIE(I)
      Call INISEC(SECTION,"POH",GDIE(I)) From SUBCDE
      [M:POC1]CCE(I-1)=SECTION
    Endif
  Next I
Endif
#----- Relecture des enreg BPR et BPS au cas ou le INISEC casse les buffers -----#
If [F:BPR]BPRNUM<>[M:POC0]BPSNUM
  Read [BPR] BPR0=[M:POC0]BPSNUM : If fstat  Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[M:POC0]BPSNUM
  Read [BPS] BPS0=[M:POC0]BPSNUM : If fstat  Raz [F:BPS] : Endif
Endif
#-----
If !GIMPORT Affzo [POC1]30 : Endif
End

Subprog C_RCPFCY(VALEUR)
Variable Char VALEUR() # FGR 19/1/2010 : X3SUIVI60986

#---------------------------#
# Controle site d'expédtion #
#---------------------------#
If [M:POC0]BETFCY<>2 : End : Endif
If VALEUR=[M:POC1]STOFCY
  GMESSAGE=mess(259,194,1) : mkstat=1
Endif
End

Subprog AM_RCPFCY(VALEUR)
#-------------------------------#
# Après modif site de réception #
#-------------------------------#
Variable Char    VALEUR()
If [M:POC2]NBART>0 | [M:POC2]ITMREF<>"" | [M:POC2]ITMREFBPS<>""
  VALEUR=[M:POC1]RCPFCY : mkstat=1 : End : # Pas de modif si des lignes existent
Endif
If [M:POC2]ITMREF="" & GREP="C"
  [M:POC2]PRHFCY=VALEUR : Affzo [POC2]PRHFCY
Endif
If [F:FCY]FCY<>[M:POC2]PRHFCY
  Read [FCY] FCY0=[M:POC2]PRHFCY : If fstat Raz [F:FCY] : Endif
Endif
[M:POC2]FCYADD=[F:FCY]BPAADD : Affzo [POC2]FCYADD
End

Subprog AM_INVFCY(VALEUR)
#-----------------------------------#
#     Apres-modif site facturation  #
# --------------------------------- #
Variable Char    VALEUR()
If [M:POC0]BETCPY=2
  Local Char BETINVFCY(GLONFCY)
  [L]BETINVFCY=VALEUR
  Gosub CTRL_BETINVFCY
  If !mkstat
    [M:POC1]BPCINV=[F:BPC]BPCNUM
    #------ Chargement des éléments de facturation -----#
     Call IS_DTAPOH([M:POC0]POHFCY,[M:POC0]SALFCY,"POC3",[M:POC0]BPSNUM,
&                   [M:POC1]BPCINV,[M:POC1]CHGTYP,[M:POC1]CUR,[M:POC0]ORDDAT,
&                   GBIDI3) From FUNBCH
  Endif
Endif
End

Subprog C_STOFCY(VALEUR)
#----------------------------#
# Contrôle site d'expédition #
#----------------------------#
Variable Char    VALEUR()
If [F:FCY]LEGCPY<>GCPY GMESSAGE=mess(2,194,1) : mkstat=1 : Endif
If VALEUR=[M:POC1]RCPFCY
  GMESSAGE=mess(259,194,1) : mkstat=1 : End
Endif
End

Subprog AM_STOFCY(VALEUR)
Variable Char VALEUR() # FGR 19/1/2010 : X3SUIVI60986
#----------------------#
# AM site d'expédition #
#----------------------#
If [M:POC2]ITMREF="" & [M:POC2]LINSTOFCY<>VALEUR
  [M:POC2]LINSTOFCY=VALEUR
  Affzo [POC2]LINSTOFCY
Endif
End

Subprog C_NBAXE
#----------------#
# Contrôle NBAXE #
#----------------#
If !find(status,1,4,5,20,21,26,92,93) | GIMPORT End : Endif
If [M:POC0]BETFCY=2 End : Endif : # Pas de contrôle pour les contrats inter-sites !
#----- Contrôle sections obligatoires -----#
If [M:POC1]NBAXE>0 & GHEADIE=1 : # Sections d'entête saisissables
  Local Integer I
  For I=1 To [M:POC1]NBAXE
    Call CTRL_CCEH([M:POC1]CCE(I-1),I,GFINRSP,[M:POC1]ENDDAT) From TRTX3CPT
    If mkstat  Break : Endif
  Next I
Endif
End

Subprog C_NBART
#---------------------------------------------#
# Contrôle sur tableau des références article #
#---------------------------------------------#
Local Integer NOL, OK, STAT
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
# Issue X3-102918 - 2018-08-03 by SR :Exploitation de WSTATUS
#If    status=65             : # Annulation simple
If    WSTATUS=65             : # Annulation simple
      NOL=nolign-1 : Gosub TEST_ANUART
# Issue X3-102918 - 2018-08-03 by SR :Exploitation de WSTATUS
#Elsif status=68 | status=83 : # Annulation multiple
Elsif WSTATUS=68 | WSTATUS=83 : # Annulation multiple
      For NOL=nolign-1 To nolign1-1
          Gosub TEST_ANUART
          If mkstat : Break : Endif
      Next NOL
Endif
# Issue X3-102918 - 2018-08-03 by SR :Exploitation de WSTATUS
#If find(status,1,4,5,20,21,26,92,93) |
#&      (status>128 & status<141) Gosub TEST_EXITART  : Endif
If find(WSTATUS,1,4,5,20,21,26,92,93) |
&      (WSTATUS>128 & WSTATUS<141) Gosub TEST_EXITART  : Endif
# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End

$TEST_ANUART
#----------------------------------#
# Test pour annulation de la ligne #
#----------------------------------#
If dim([M:POC2]XITMREF)<nolign mkstat=2 : Return : Endif : # Maximum lignes atteint
#----- L'utilisateur a-t-il droit à la modification ? -----#
GBIDC2="M" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  mkstat=2 : Return : Endif
#----- Chargement onglet article en cas d'annulation multiple -----#
If nolign>0 & nolign<=[M:POC2]NBART & [M:POC2]NBART>0
  If [M:POC2]XPOPLIN(NOL)<>[M:POC2]POPLIN
    Gosub MAJ_PWRKPO       From SUBPOCA
    Gosub CHARG_ONGLET_ART From SUBPOCA
    Affzo [POC2]10-99
  Endif
Endif
#----- Vérification si ligne supprimable -----#
OK=1 : Gosub VERF_ANUART From SUBPOCA
If !OK mkstat=2 : Return : Endif
#----- Vérification que le contrat n'est pas utilisé sur un autre poste -----#
OK=1 : Gosub VERROU From SUBPOCA
If !OK  mkstat=2 : GMESSAGE=mess(10,100,1) : GERR=1 : Return : Endif
GAPPFLG=2
Return

$TEST_EXITART
#-------------------------------------------------------#
# Sortie du tableau des lignes articles :               #
# empêcher le réaffichage à la prochaine prise de focus #
#-------------------------------------------------------#
# If [M:POC2]XUPDFLG(0)<5 [M:POC2]XUPDFLG(0)+=5 : Endif
If [M:POC2]NBART>0 [M:POC2]XNOLIGN=nolign : Endif
Return


Subprog IB_NBART
#----------------------------------#
# Activation boutons "Ajout ligne" #
#----------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4
#----- L'utilisateur a-t-il droit à la modification ? -----#
GBIDC2="M" : Gosub AUTORIS_OPT From CONTX3
If GBIDI2  GBOUT1=mess(421,198,1) : Endif
If !find("CONSPIA",GNAVIG(1..GPILNAV)) Then
  GBOUT3=mess(19,723,1) : # Traçabilité pièces
Endif
If !find("GESPOD",GNAVIG(1..GPILNAV)) Then
  GBOUT4=mess(358,198,1) : # Demandes de livraison
Endif
End

Subprog AS_NBART
#---------------------------------------------#
# Avant saisie tableau des références article #
#---------------------------------------------#
#VPO 18/04/11 73246 on fait un raz pour se mettre sur le bon article dès le 1er clic
Raz [M:POC2]XNOLIGN
#If [M:POC2]XNOLIGN>0 & [M:POC2]XNOLIGN<=[M:POC2]NBART
#  nolign=[M:POC2]XNOLIGN
#  Raz [M:POC2]XNOLIGN
#  End
#Endif
If [M:POC2]XUPDFLG(0)>4 [M:POC2]XUPDFLG(0)-=5 : End : Endif
Local Shortint NOL : NOL=nolign-1

# Issue 71069 - 2016-01-29 by MUARN : PJT
# A faire avant tout le reste
If GPJTSNGDOC = G_NON & [F:POH]CLEFLG=1 Then
 Call PJT_MODFCY([M:POC0]POHFCY,"[M:POC2]PJT") From TRTPJT
Endif
If nolign>0 & nolign<=[M:POC2]NBART & [M:POC2]NBART>0
  If [M:POC2]XPOPLIN(NOL)<>[M:POC2]POPLIN
    Gosub MAJ_PWRKPO       From SUBPOCA : If mkstat  End : Endif
    Gosub CHARG_ONGLET_ART From SUBPOCA
    Affzo [POC2]10-99
  Endif
Elsif [M:POC2]NBART=1
  NOL=0
  If [M:POC2]XPOPLIN(NOL)<>[M:POC2]POPLIN
    Gosub MAJ_PWRKPO       From SUBPOCA : If mkstat  End : Endif
    Gosub CHARG_ONGLET_ART From SUBPOCA
    Affzo [POC2]10-99
  Endif
Elsif [M:POC2]NBART=0 & [M:POC2]ITMREF<>""
  Gosub MAJ_PWRKPO  From SUBPOCA
  Diszo [POC2]ITMREF, ITMREFBPS
Endif
## Issue 71069 - 2016-01-29 by MUARN : PJT
# A faire après tout le reste normalement, mais là on doit repasser après (si DL existantes, on ne peut plus saisir)
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY([M:POC0]POHFCY,"[M:POC2]PJT") From TRTPJT
Endif
# Issue 71069 - 2016-03-30 by MUARN : PJT
Look [POQ] POQ0(2)=[M:POC0]POHNUM;[M:POC2]POPLIN
#----- Si pas d'existence de demandes de livraison alors modification PJT -----#
If !fstat Diszo [M:POC2]PJT : Affzo [M:POC2]PJT : Endif
# End issue 71069
# Issue 90991 - 2013-11-05 by MUARN : supression données en commande ouverte
# Issue 84130 - 2012-09-28 by MUARN : coeff/cout modifiable si pas de SDC
#If [M:POC2]STCNUM<> ""
#  Diszo [POC2]CPRAMT, CPRCOE
#Else
#  Actzo [POC2]CPRAMT, CPRCOE
#Endif

End


Subprog AVANT_NBART
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
#--------------------------------------------------------------------------#
# Avant ligne NBART : Si suppression ligne, suppression fichier de travail #
#--------------------------------------------------------------------------#
# Issue X3-102918 - 2018-08-03 by SR :Exploitation de WSTATUS
#If status=65 | status=68 | status=83
If WSTATUS=65 | WSTATUS=68 | WSTATUS=83
  #----- Mise à jour totaux prévus -----#
  Local Integer STAT
  [M:POC3]TOTVLT-=[M:POC2]AMTVLT
  Gosub EFFAC_ART_PWRKPO From SUBPOCA : # Effacement ligne article fichiers travail
  If !GIMPORT
    Effzo [POC2]10-99 : Grizo [POC2]10-99 : Affzo [POC2]10-99
    Affzo [POC3]TOTVLT
  Endif
  If GREP="C" & [M:POC2]NBART<2
    Actzo [POC0]POHFCY, BPSNUM
    If [M:POC0]BETFCY<>2 Actzo [POC1]CUR, RCPFCY Else Actzo [POC1]RCPFCY : Endif
  Endif
Endif
# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End

# Issue 116835 - 2016-05-30 by SR
#---------------------------------------------#
# avant tunnel vers les demandes de livraison
#---------------------------------------------#
AB4_NBART
Local Integer  SAVCONSULT
SAVCONSULT =GCONSULT
If GREP="M"
  GCONSULT = 1
Endif
Return

#---------------------------------------------#
# Retour tunnel vers les demandes de livraison
#---------------------------------------------#
$BB4_NBART
GCONSULT = SAVCONSULT
Return
# End issue 116835


Subprog IB_ITMREF
#------------------------------------------#
# Activation boutons "Article-Fournisseur" #
#------------------------------------------#
Raz GBOUT3, GBOUT4
GBOUT2=mess(23,198,1)
#----- Positionnement filtre pour sélection article -----#
# Issue 113089 - 2016-05-24 by SR : Receipt and deliverable items only
If [M:POC0]BETFCY=2
  GBIDC3="RCPFLG = 2 & DLVFLG = 2"    : # Articles réceptionnables et livrables
Else
# Issue 112754 - 2016-11-28 by SR : Services
  #GBIDC3="SCSFLG<>2 & PHAFLG<>2" : # Articles non sous-traitance et non fantôme
  GBIDC3="PHAFLG<>2" : # Articles non fantôme
Endif

Call IB_NOTECHECK([M:POC2]ITMREF,"ITMREF",3)  From TRTNTSCTL # product notes

End


Subprog C_ITMREF(VALEUR)
#----------------------------#
# Contrôle référence article #
#----------------------------#
Variable Char    VALEUR()
If VALEUR=""
  [M:POC2]ITMREFBPS=""
  Affzo [POC2]ITMREFBPS
Else
  # Issue 113089 - 2016-05-24 by SR : vu avec CH : Inutile
#  If [M:POC0]BETFCY=2 & [M:POC0]BETCPY=1
#    Call CONTROLE("ITM","I",VALEUR,"",mkstat)  From CONTOBJ : # Géré en stock
#    If mkstat End : Endif
#  Else
    # Issue 112754 - 2016-09-23 by SR
    Call C_ITMREF("POC",VALEUR) From TRTACHCTL1 : # Acheté et non sous-traitance
    If mkstat End : Endif
  #Endif
  Call CTL_ITMREF (VALEUR,"ITM") From SUBPOC
Endif
#                                                                                  # hcb 71276 deb
If VALEUR <> [M:POC2]ITMREF
   If dim([M]ECCVALMAJ) > 0
      Raz [M]ECCVALMAJ
      Raz [M]ECCVALMIN
   Endif
Endif
#                                                                                  # hcb 71276 fin

End


Subprog AM_ITMREF(VALEUR)
#-------------------------------#
# Après modif référence article #
#-------------------------------#
Variable Char    VALEUR()
Local    Char    REFART(GLONITM) : REFART=VALEUR
# Issue 90991 - 2013-11-05 by MUARN : supression données en commande ouverte
#Local    Decimal  WCPRAMT, WCPRAMTDEV # Issue 70985 - 2012-02-23 by MUARN : landed cost
#Local    Integer  STAT # Issue 70985 - 2012-02-23 by MUARN : landed cost
[M:POC2]ITMREF=VALEUR
If VALEUR<>""
  Gosub CTL_AM_ITMREF
  If !mkstat
    If GREP="C"
      Diszo [POC0]POHFCY, BPSNUM
      If [M:POC0]BETFCY<>2 Diszo [POC1]CUR, RCPFCY Else Diszo [POC1]RCPFCY : Endif
    Endif
    Diszo [POC2]ITMREFBPS
    # Issue 112754 - 2016-10-18 by SR : Init de ITMKND selon le type d'article
      [M:POC2]ITMKND = 1
      If [F:ITM]ITMREF <> VALEUR
        Read [F:ITM]ITM0 = VALEUR
        If fstat : Raz [F:ITM] : Endif
      Endif
      If [F:ITM]SCSFLG = 2 : [M:POC2]ITMKND = 3 : Endif
      Affzo [M:POC2]ITMKND
      # End issue 112754
  Else
    Raz VALEUR, [M:POC2]ITMREF, [M:POC2]ITMREFBPS : Affzo [POC2]ITMREFBPS : mkstat=1
    # Issue 112754 - 2016-10-20 by SR : Sortir si pb
    End
  Endif
  #----- Initialisation des landed cost -----#
  # Issue 90991 - 2013-11-05 by MUARN : supression données en commande ouverte
  # Issue 70985 - 2012-02-17 by MUARN : alimentation coefficient frais d'approche et coût achat forfaitaire
#  Call RECH_COST([M:POC2]PRHFCY,[M:POC0]BPSNUM, VALEUR, [M:POC2]CPRCOE, WCPRAMT, [M:POC2]STCNUM) From STCLIB
#  If GLOCALDEV <> GSYSCUR
#    Call CONVERT2(GSYSCUR,GLOCALDEV,GLOCALDEV,[M:POC1]CHGTYP,[M:POC0]ORDDAT,
#&                       WCPRAMT,WCPRAMTDEV,STAT) From TRTDEV
#    [M:POC2]CPRAMT=arr(WCPRAMTDEV,10^-GDECPRI)
#  Else
#   [M:POC2]CPRAMT = WCPRAMT
#  Endif
#  If [M:POC2]CPRCOE=0 [M:POC2]CPRCOE=1 Endif
#
#  # Issue 84130 - 2012-09-28 by MUARN : coeff/cout modifiable si pas de SDC
#  If [M:POC2]STCNUM<> ""
#    Diszo [POC2]CPRAMT, CPRCOE
#  Else
#    Actzo [POC2]CPRAMT, CPRCOE
#  Endif
#
#  Affzo [POC2]CPRCOE, CPRAMT, STCNUM
# Issue 112754 - 2016-10-20 by SR : ne sert à rien
  # End
Else
    Actzo [POC2]ITMREFBPS
Endif
End


Subprog IB_ITMREFBPS
#------------------------------------------#
# Activation boutons "Article-Fournisseur" #
#------------------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4
GBOUT1=mess(23,198,1)
End


Subprog C_ITMREFBPS(VALEUR)
#------------------------------------------------#
# Contrôle référence article chez le fournisseur #
#------------------------------------------------#
Variable Char     VALEUR
#----- On autorise des contrats inter-site sans ligne article -----#
If VALEUR="" & [M:POC2]ITMREF="" & ([M:POC0]BETFCY<>2 | GREP="d")
  GMESSAGE=mess(107,194,1) : mkstat=2 : End
Endif
If VALEUR=""
 If [M:POC2]ITMREF="" [M:POC2]PUU="" : Endif
 End
Endif
Local Char WITMREF1(GLONITM)
WITMREF1=VALEUR
Call CTL_ITMREF (WITMREF1,"ITP") From SUBPOC
End


Subprog AM_ITMREFBPS(VALEUR)
#---------------------------------------------------#
# Après modif référence article chez le fournisseur #
#---------------------------------------------------#
Variable Char     VALEUR
Local    Char     REFART(GLONITM) : REFART=[M:POC2]ITMREF
# Issue 90991 - 2013-11-05 by MUARN : supression données en commande ouverte
#Local    Decimal  WCPRAMT, WCPRAMTDEV # Issue 70985 - 2012-02-23 by MUARN : landed cost
#Local    Integer  STAT # Issue 70985 - 2012-02-23 by MUARN : landed cost
[M:POC2]ITMREFBPS=VALEUR
Gosub CTL_AM_ITMREF
If !mkstat & GREP="C"
  Diszo [POC0]POHFCY, BPSNUM
  If [M:POC0]BETFCY<>2 Diszo [POC1]CUR, RCPFCY Else Diszo [POC1]RCPFCY : Endif
  # Issue 112754 - 2016-10-18 by SR : Init de ITMKND selon le type d'article
  [M:POC2]ITMKND = 1
  If [F:ITM]ITMREF <> [M:POC2]ITMREF
    Read [F:ITM]ITM0 = [M:POC2]ITMREF
    If fstat : Raz [F:ITM] : Endif
  Endif
  If [F:ITM]SCSFLG = 2 : [M:POC2]ITMKND = 3 : Endif
  Affzo [M:POC2]ITMKND
  # End issue 112754
Elsif mkstat
  Raz [M:POC2]ITMREF, VALEUR, [M:POC2]ITMREFBPS : Affzo [POC2]ITMREF : mkstat=1
  # Issue 112754 - 2016-10-20 by SR : sortir si Pb
  End
Endif
#----- Initialisation des landed cost -----#
# Issue 90991 - 2013-11-05 by MUARN : supression données en commande ouverte
## Issue 70985 - 2012-02-17 by MUARN : alimentation coefficient frais d'approche et coût achat forfaitaire
#Call RECH_COST([M:POC2]PRHFCY,[M:POC0]BPSNUM, [M:POC2]ITMREF, [M:POC2]CPRCOE, WCPRAMT,[M:POC2]STCNUM) From STCLIB
#If GLOCALDEV <> GSYSCUR
#  Call CONVERT2(GSYSCUR,GLOCALDEV,GLOCALDEV,[M:POC1]CHGTYP,[M:POC0]ORDDAT,
#&                       WCPRAMT,WCPRAMTDEV,STAT) From TRTDEV
#  [M:POC2]CPRAMT=arr(WCPRAMTDEV,10^-GDECPRI)
#Else
# [M:POC2]CPRAMT = WCPRAMT
#Endif
#If [M:POC2]CPRCOE=0 [M:POC2]CPRCOE=1 Endif
#Affzo [POC2]CPRCOE, CPRAMT
End


Subprog AM_ITMDES(VALEUR)
#------------------------------------------------#
# Après modif de la désignation article traduite #
#------------------------------------------------#
Variable Char    VALEUR()
Gosub MAJ_LIGPRI
End


Subprog AM_ITMDES1(VALEUR)
#-------------------------------------------#
# Après modif de la désignation article std #
#-------------------------------------------#
Variable Char    VALEUR()
Gosub MAJ_LIGPRI
End


Subprog IB_PRHFCY
#-----------------------------------------------------#
# Initialisation bouton "Int Stock" et "Article-site" #
#-----------------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT4, GBOUT5 : # GBOUT3 est défini par l'action CONSSFC !
If [F:ITM]ITMREF<>[M:POC2]ITMREF
  Read [ITM] ITM0=[M:POC2]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITM]STOMGTCOD<2 Raz GBOUT3 : Endif
GBOUT4=mess(4,198,1) : # Article-site
End


Subprog C_PRHFCY(VALEUR)
#----------------------------#
# Contrôle site de réception #
#----------------------------#
Variable Char     VALEUR
#----- On autorise des contrats inter-site sans ligne article -----#
If VALEUR="" & ([M:POC0]BETFCY<>2 | [M:POC0]BETCPY=2 | [M:POC2]ITMREF<>"")
  mkstat=1
Endif
If [M:POC0]BETFCY=2
  If VALEUR=[M:POC2]LINSTOFCY
    GMESSAGE=mess(259,194,1) : mkstat=2 : End
  Endif
Endif
End


$AAM_PRHFCY
#-------------------------------------------------------------#
# Avant exécution de l'action GOBJETC0A (tunnel article-site) #
#-------------------------------------------------------------#
Local Char SITE  (GLONFCY) : SITE=VALEUR
Local Char WOBJET(GLONAOB) : WOBJET="ITF"
#----- Restauration de l'ancienne valeur et blocage sur le champ -----#
If GBIDI1=1  VALEUR=[M:POC2]PRHFCY : mkstat=1 : Endif
If GBIDI1<>2 WOBJET="" : Endif : # Pas d'exécution du tunnel
GFLTITM=[M:POC2]ITMREF
Return


$BAM_PRHFCY
#-------------------------------------------------------------#
# Après exécution de l'action GOBJETC0A (tunnel article-site) #
#-------------------------------------------------------------#
Raz GFLTITM
If GBIDI1=0  Return : Endif
VALEUR=SITE
Read [ITF] ITF0=[M:POC2]ITMREF;VALEUR
If fstat Raz [F:ITF] : Endif
If [F:ITF]ITMREF="" mkstat=1 : Endif
Return

Subprog AM_PRHFCY(VALEUR)
#-----------------------------------------------------------------------#
# Après modif du site de réception : chargement code adresse par défaut #
#-----------------------------------------------------------------------#
Variable Char    VALEUR()
Local    Char    WITMREF(GLONITM)
# Issue X3-55891 - 2018-09-25 by SR : exploitation table article/fournisseur/site
Local Integer WITMBPS : WITMBPS = 0
Local Integer WRETOUR
#-- La classe [F:FCY] peut être perdue après le tunnel
If [F:FCY]FCY<>VALEUR
  Read [FCY] FCY0=VALEUR : If fstat Raz [F:FCY] : Endif
Endif
# Issue X3-55891 - 2018-09-25 by SR : exploitation table article/fournisseur/site
# Contrôle des stauts du fournisseur par rapport au nouveau site
Raz WRETOUR, WITMBPS
# Intersite
If [M:POC0]BETFCY=2 & [M:POC0]BETCPY <>2
  Call CTRL_DOUFLG(2,[M:POC2]ITMREF,[M:POC0]BPSNUM,VALEUR,WITMBPS,WRETOUR) From TRTACHCTL1
Else
  Call CTRL_DOUFLG(1,[M:POC2]ITMREF,[M:POC0]BPSNUM,VALEUR,WITMBPS,WRETOUR) From TRTACHCTL1
Endif
If WRETOUR <> 0
  mkstat=2 : End
Endif
# End issue X3-55891
[M:POC2]FCYADD=[F:FCY]BPAADD
Affzo [POC2]FCYADD
#----- Contrôle unicité article+site de réception -----#
Look [POC] POC1=[M:POC0]POHNUM;[F:ITM]ITMREF;VALEUR
If !fstat  GMESSAGE=mess(90,194,1) : GERR=1 : mkstat=1 : End : Endif
#--- Vérification que le site de réception correspond à une adresse client livré
If [M:POC0]SALFCY<>""
  Local Char BETRCPFCY(GLONFCY)
  Local Char BPCNUM   (GLONBPC)
  [L]BETRCPFCY=VALEUR
  [L]BPCNUM=[M:POC0]BPCORD
  Gosub CTRL_BPRADD From TRTACHCTL1
  If [L]BETRCPFCY="" : GMESSAGE=mess(267,194,1) : mkstat=1 : End : Endif
  If[M:POC2]NBART=0
    GRCPFCY=VALEUR
    [M:POC1]RCPFCY=VALEUR : Affzo [POC1]RCPFCY
  Endif
Endif
[M:POC2]PRHFCY=VALEUR
WITMREF=[M:POC2]ITMREF
If [F:ITM]ITMREF<>WITMREF
  Read [ITM]ITM0=WITMREF
  If fstat Raz [F:ITM] : Endif
Endif
Call CTL_ITMREF(WITMREF,"ITM") : If mkstat  End : Endif
#----- Initialisation des codes taxe si nécessaire -----#
If func AFNC.ACTIV("PTX")
  Call ALIVATCOD(2,[M:POC0]BPSNUM,[M:POC2]ITMREF,"POC2",0) From TRTX3
Endif
#-----
Gosub MAJ_LIGPRI
End


Subprog D_FCYADD(VALEUR)
#------------------------------------------#
# Initialisation adresse site de réception #
#------------------------------------------#
Variable Char    VALEUR()
If [F:FCY]FCY<>[M:POC2]PRHFCY
  Read [FCY] FCY0=[M:POC2]PRHFCY : If fstat Raz [F:FCY] : Endif
Endif
VALEUR=[F:FCY]BPAADD
End


Subprog IB_FCYADD
#-----------------------------------------------------------------------#
# Init bouton code adresse pour charger [F:FCY] avant sélection adresse #
#-----------------------------------------------------------------------#
If [F:FCY]FCY<>[M:POC2]PRHFCY
  Read [FCY] FCY0=[M:POC2]PRHFCY : If fstat Raz [F:FCY] : Endif
Endif
Raz GBIDC3 : # Utilisé par l'action SAISELADR pour le nom
End


Subprog C_FCYADD(VALEUR)
#--------------------------#
# Contrôle du code adresse #
#--------------------------#
Variable Char    VALEUR()
If [M:POC2]ITMREF="" & VALEUR=""  End : Endif
If !clalev([F:BPA])  Local File BPADDRESS [BPA] : Endif
Read [BPA] BPA0=3;[M:POC2]PRHFCY;VALEUR
If fstat Raz [F:BPA] : mkstat=1 : End : Endif
If VALEUR<>[M:POC2]FCYADD
  Gosub MAJ_LIGPRI
Endif
End


Subprog AM_FCYADD(VALEUR)
#-----------------------------#
# Après modif du code adresse #
#-----------------------------#
Variable Char    VALEUR()
#----- Initialisation des codes taxe si nécessaire -----#
If func AFNC.ACTIV("PTX")
  [M:POC2]FCYADD=VALEUR
  Call ALIVATCOD(2,[M:POC0]BPSNUM,[M:POC2]ITMREF,"POC2",0) From TRTX3
Endif
#-----
End


Subprog C_LINSTOFCY(VALEUR)
#----------------------------#
# Contrôle site d'expédition #
#----------------------------#
Variable Char    VALEUR()
If [M:POC0]BETFCY<>2
  Raz VALEUR : End
Elsif [M:POC2]ITMREF<>""
  #----- Contrôle si inter-sites (valeur obligatoire ...etc) -----#
  If VALEUR=""  mkstat=1 : End : Endif
  If [F:FCY]LEGCPY<>GCPY   GMESSAGE=mess(2,194,1)   : mkstat=1 : End : Endif
  If VALEUR=[M:POC2]PRHFCY GMESSAGE=mess(259,194,1) : mkstat=1 : End : Endif
Endif
End

Subprog AM_LINSTOFCY(VALEUR)
#----------------------------------#
# Après modif du site d'expédition #
#----------------------------------#
Variable Char    VALEUR()
If [M:POC0]BETFCY=2
  If [F:ITM]ITMREF<>[M:POC2]ITMREF
    Read [ITM] ITM0=[M:POC2]ITMREF : If fstat  Raz [F:ITM] : Endif
  Endif
  #----- Si géré en stock l'article-site d'expédition doit exister ! -----#
  If [F:ITM]STOMGTCOD>1
    Look [ITF] ITF0=[F:ITM]ITMREF;VALEUR
    If fstat
      GMESSAGE=[F:ITM]ITMREF-mess(25,192,1)-VALEUR : GERR=1 : mkstat=1 : End
    Endif
  Endif
Endif
End


Subprog C_PUU(VALEUR)
#------------------------#
# Contrôle unité d'achat #
#------------------------#
Variable Char     VALEUR
#----- On autorise des contrats inter-site sans ligne article -----#
If VALEUR=""
  If [M:POC0]BETFCY<>2 | [M:POC2]ITMREF<>""
    mkstat=1 : End
  Else
    End
  Endif
Endif
#----- Contrôle unité achat -----#
If VALEUR<>[F:ITM]PUU & VALEUR<>[F:ITP]PUU
  GMESSAGE=mess(221,197,1) : mkstat=1 : End
Endif
#----- Contrôle unité vente -----#
If [M:POC0]SALFCY<>"" & GMODU(5)=2
  If clalev([F:BPR])=0 Local File BPARTNER   [BPR] : Endif
  Filter [BPR] Where BETFCY=2 & FCY=[M:POC1]RCPFCY
  Read [BPR] BPR2 First : If fstat Raz [F:BPR] : Endif
  Filter [BPR]
  Local Char UNIVEN(GLONUOM)
  Call CONTSAUIMP(VALEUR,[M:POC2]ITMREF,[F:BPR]BPRNUM,UNIVEN) From TRTVENCTL
  If UNIVEN="" GMESSAGE=mess(183,194,1) : mkstat=1 : End : Endif
Endif
End


Subprog IB_EXTQTYPUU
#-----------------------------------------------------#
# Désactivation bouton "Stock par site" si nécessaire #
#-----------------------------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4 : # GBOUT1 est chargé par l'action CONSSFC
If [F:ITM]ITMREF<>[M:POC2]ITMREF
  Read [ITM] ITM0=[M:POC2]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF<>[M:POC2]ITMREF | [F:ITF]STOFCY<>[M:POC2]PRHFCY
  Read [ITF] ITF0=[M:POC2]ITMREF;[M:POC2]PRHFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
If [F:ITF]STOMGTCOD<2  Raz GBOUT1 : Endif
End


Subprog C_EXTQTYPUU(VALEUR)
#---------------------------------------------------#
# Contrôle quantité prévue avec qté minimum d'achat #
#---------------------------------------------------#
Variable Decimal  VALEUR
Local Integer WOK
If VALEUR=0  End : Endif
If [F:ITP]ITMREF<>[M:POC2]ITMREF & [F:ITP]BPSNUM<>[M:POC0]BPSNUM
  Read [ITP] ITP0=[M:POC2]ITMREF;[M:POC0]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
If [F:ITP]PUU=""  End : Endif
Local Decimal WQTY,WCOEUOM
WQTY=VALEUR
If [F:ITP]PUU<>[M:POC2]PUU
  Call PCAL_QTY(VALEUR,[M:POC2]PUU,WQTY,[F:ITP]PUU,"","",1,WCOEUOM) From TRTACHQTE1
Endif
#VPO 15/10/10 17730/59532 contrôle selon paramètre
If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
#If WQTY<[F:ITP]PURMINQTY
If WQTY<[F:ITP]PURMINQTY & GPOHMINQTY<3
  GMESSAGE=mess(14,194,1)-num$([F:ITP]PURMINQTY)-num$([F:ITP]PUU)
  If GPOHMINQTY=1
      mkstat=2 : End
  Else : #GPOHMINQTY=2
      WOK=2
      Call AVERTIR (GMESSAGE, WOK)From GESECRAN
      If WOK=1
          Raz GMESSAGE
          mkstat=2 : End
      Endif
      Raz GMESSAGE
  Endif
Endif
End


Subprog AM_EXTQTYPUU(VALEUR)
#-----------------------------------#
# Après modif de la quantité prévue #
#-----------------------------------#
Variable Decimal VALEUR
Local Integer OK
Look [POQ] POQ0(2)=[M:POC0]POHNUM;[M:POC2]POPLIN
[G:POQ]currind=1 : [G:POQ]currlen=0 : # Réinitialisation clé par défaut
#----- Si existence de demandes de livraison alors message d'avertissement -----#
If !fstat
  OK=2 : Call AVERTIR(mess(184,194,1),OK) From GESECRAN
  If OK=1 : mkstat=1 : End : Endif
Endif
#----- Recherche prix pour valoriser la ligne du contrat -----#
[M:POC2]EXTQTYPUU=VALEUR
Call VALORIS_LIGNE From SUBPOC
End


Subprog AP_EXTQTYPUU(VALEUR)
#----------------------------#
# Après zone quantité prévue #
#----------------------------#
Variable Decimal VALEUR
#----- Si pas modif qté et si différent de création ligne alors pas de message -----#
If [M:POC2]EXTQTYPUU=VALEUR & LINCREFLG<>0  End : Endif
#----- Message si qté nulle -----#
If VALEUR=0 & [M:POC2]ITMREF<>""
  Local Integer OK
  OK=2 : Call OUINON(mess(178,194,1),OK) From GESECRAN
  If OK=1 mkstat=1 : End : Endif
Endif
End


Subprog D_FIMHOR(VALEUR)
#------------------------------#
# Initialisation horizon ferme #
#------------------------------#
Variable Decimal  VALEUR
If [F:ITM]ITMREF<>[M:POC2]ITMREF
  Read [ITM] ITM0=[M:POC2]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
VALEUR=[F:ITM]FIMHOR
Case [F:ITM]FIMHORUOM
  When 2       : VALEUR  = 7*int (VALEUR/5)+mod(VALEUR,5)
  When 3       : VALEUR *= 7
  When 4       : VALEUR *= 14
  When 5       : VALEUR *= 30
  When Default
Endcase
End


Subprog IB_FIMHOR
#-------------------------------------------#
# Activation bouton sur champ horizon ferme #
#-------------------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4
GBOUT1=mess(34,198,1) : # Répart qté
End


Subprog D_FRTHOR(VALEUR)
#---------------------------------#
# Initialisation horizon planifié #
#---------------------------------#
Variable Decimal VALEUR
If [F:ITM]ITMREF<>[M:POC2]ITMREF
  Read [ITM] ITM0=[M:POC2]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
VALEUR=[F:ITM]FRTHOR
End


Subprog IB_FRTHOR
#----------------------------------------------#
# Activation bouton sur champ horizon planifié #
#----------------------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4
GBOUT1=mess(34,198,1) : # Répart qté
End


Subprog D_FRTHORUOM(VALEUR)
#-------------------------------------#
# Initialisation unité tps hor planif #
#-------------------------------------#
Variable Integer VALEUR
If [F:ITM]ITMREF<>[M:POC2]ITMREF
  Read [ITM] ITM0=[M:POC2]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
VALEUR=[F:ITM]FRTHORUOM
If VALEUR=0  VALEUR = 1 : Endif
End


Subprog C_XSTRDAT(VALEUR)
#--------------------------------------#
# Contrôle date début validité article #
#--------------------------------------#
Variable Date     VALEUR
If VALEUR<[M:POC1]STRDAT
  GMESSAGE=mess(20,199,1) : mkstat=2 : End
Endif
#----- Ne doit pas être supérieure date deb première ligne tarif -----#
If [M:POC2]NBLIG>0
  If VALEUR>[M:POC2]POPSTRDAT(0)
    GMESSAGE=mess(99,199,1) : mkstat=2 : End
  Endif
Endif
End


Subprog AM_XSTRDAT(VALEUR)
#------------------------------------#
# Après modif date début de validité #
#------------------------------------#
Variable Date    VALEUR
If [M:POC1]DATMIN=[0/0/0] | VALEUR<[M:POC1]DATMIN
  [M:POC1]DATMIN=VALEUR
Endif
End


Subprog C_XENDDAT(VALEUR)
#------------------------------------#
# Contrôle date fin validité article #
#------------------------------------#
Variable Date    VALEUR
If VALEUR<[M:POC2]XSTRDAT
  mkstat=2 : End
Endif
#----- Cette date ne doit pas être supérieure à entête -----#
If VALEUR>[M:POC1]ENDDAT
  GMESSAGE=mess(20,199,1) : mkstat=2 : End
Endif
#----- Date ne doit pas etre inferieure date deb derniere ligne tarif -----#
If [M:POC2]NBLIG>0
  If VALEUR<[M:POC2]POPSTRDAT([M:POC2]NBLIG-1)
    GMESSAGE=mess(99,199,1) : mkstat=2 : End
  Endif
Endif
# Issue 105241 - 2015-01-12 by SR
# Issue 113899 - 2016-01-22 by MUARN : si date strictement supérieure
#----- Date ne doit pas etre inferieure à la date D'une DL existante -----#
Filter [POQ] Where POHNUM=[M:POC0]POHNUM
&                & POPLIN=[M:POC2]POPLIN
&                & DEMRCPDAT>VALEUR
Look [POQ] POQ0 First
If !fstat  GMESSAGE=mess(480,194,1) : mkstat=2 : GMODIF=1 : Endif
Filter [POQ]
# End issue 105241
End


Subprog AM_XENDDAT(VALEUR)
#----------------------------------#
# Après modif date fin de validité #
#----------------------------------#
Variable Date    VALEUR
If [M:POC1]DATMAX=[0/0/0] | VALEUR>[M:POC1]DATMAX | [M:POC2]XENDDAT=[M:POC1]DATMAX
  [M:POC1]DATMAX=VALEUR
Endif
#----- Modification date fin d'application du tarif si tarif créé manuellement -----#
If [M:POC2]NBLIG>0 & [M:POC2]POPCREFLG([M:POC2]NBLIG-1)=1 &
&  ([M:POC2]POPDAT([M:POC2]NBLIG-1)=[M:POC2]XENDDAT |
&   [M:POC2]POPDAT([M:POC2]NBLIG-1)<VALEUR)
  [M:POC2]POPDAT([M:POC2]NBLIG-1)=VALEUR
  [M:POC2]UPDFLG([M:POC2]NBLIG-1)=1
Endif
#-----
End


Subprog D_PLI(VALEUR)
#--------------------------------------------------------------------#
# Initialisation code tarif : 1er code tarif actif et de type normal #
#--------------------------------------------------------------------#
Variable Char    VALEUR()
#----- Si inter-sites intra-société, pas de code tarif -----#
If [M:POC0]BETFCY=2 & [M:POC0]BETCPY<>2
  VALEUR="" : End
Endif
#-----
If [F:BPS]BPSNUM<>[M:POC0]BPSNUM
  Read [BPS] BPS0=[M:POC0]BPSNUM : If fstat Raz [F:BPS] : Endif
Endif
If clalev([F:PPC])=0  Local File PPRICCONF [PPC] : Endif
#----- Tarif inter-sociétés -----#
If [M:POC0]BETCPY=2
 # Issue 106642 - 2015-03-02 by SR : Pas de fournisseur hors-groupe
 # Filter [PPC] Where PLISTC=[F:BPS]PLISTC & PLIENAFLG=2 & PLITYP=1 & BETCPY=2
  Filter [PPC] Where PLISTC=[F:BPS]PLISTC & PLIENAFLG=2 & PLITYP=1 & PLIBPRCNR<>1
  Read [PPC] PPC1 First : If fstat  Raz [F:PPC] : Endif
  VALEUR=[F:PPC]PLI
Endif
#----- Tarif normal -----#
If [M:POC0]BETCPY<>2 | VALEUR=""
  # Issue 106642 - 2015-03-02 by SR : Pas de fournisseur Groupe
  #Filter [PPC] Where PLISTC=[F:BPS]PLISTC & PLIENAFLG=2 & PLITYP=1 & BETCPY<>2
  Filter [PPC] Where PLISTC=[F:BPS]PLISTC & PLIENAFLG=2 & PLITYP=1 & PLIBPRCNR<>2
  Read [PPC] PPC1 First : If fstat  Raz [F:PPC] : Endif
  VALEUR=[F:PPC]PLI
Endif
#-----
Filter [PPC]
End


Subprog IB_PLI
#-----------------------------------#
# Activation bouton "tarifs achats" #
#-----------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4
GBOUT1=mess(50,198,1)
#----- Relecture si nécessaire du fournisseur -----#
If [F:BPS]BPSNUM<>[M:POC0]BPSNUM
  Read [BPS] BPS0=[M:POC0]BPSNUM : If fstat Raz [F:BPS] : Endif
Endif
End


Subprog C_PLI(VALEUR)
#---------------------#
# Contrôle code tarif #
#---------------------#
Variable Char     VALEUR
If VALEUR=""  End : Endif
#----- Relecture si nécessaire du fournisseur -----#
If [F:BPS]BPSNUM<>[M:POC0]BPSNUM
  Read [BPS] BPS0=[M:POC0]BPSNUM : If fstat Raz [F:BPS] : Endif
Endif
#----- Test du code structure -----#
If [F:BPS]PLISTC<>[F:PPC]PLISTC
  GMESSAGE=mess(54,194,1)  : mkstat=2
Elsif [F:PPC]PLITYP<>1
  GMESSAGE=mess(312,194,1) : mkstat=2
Endif
End


Subprog AM_PLI(VALEUR)
#---------------------------#
# Après modif du code tarif #
#---------------------------#
Variable Char     VALEUR
# Issue 116821 - 2016-06-01 by MUARN : suppression du code tarif
#If VALEUR="" | [M:POC2]NBLIG<>0  End : Endif
#----- Recherche prix pour valoriser la ligne du contrat -----#
[M:POC2]PLI=VALEUR
Call VALORIS_LIGNE From SUBPOC
End


Subprog D_NBCOA
#---------------------------------------#
# Initialisation du tableau des comptes #
#---------------------------------------#
Local Integer I
[M:POC2]NBCOA=GNBCOA
For I=1 To GNBCOA
  [M:POC2]COA(I-1)=GCOA(I)
Next I
Call INIT_COMPTES_LIGNE
End


Subprog AS_LINACC(VALEUR)
#------------------------#
# Avant saisie du compte #
#------------------------#
Variable Char    VALEUR()
Call AVSAI_ACC(VALEUR,nolign,"[M:POC2]LINACC(") From TRTX3CPT
End


Subprog C_LINACC(VALEUR)
#-----------------#
# Contrôle compte #
#-----------------#
Variable Char    VALEUR()
Call CTRL_ACC(VALEUR,nolign,GFINRSP,[M:POC0]ORDDAT,[M:POC1]CUR,"[M:POC2]LINACC(") From TRTX3CPT
End


Subprog AM_LINACC(VALEUR)
#------------------------------#
# Après modification du compte #
#------------------------------#
Variable Char    VALEUR()
Local    Shortint I
Local    Shortint NOL : NOL=nolign-1
#-----
# Issue 122292 - 2017-03-29 by MUARN : ne pas faire en import
# Issue 106746 - 2015-04-02 by SR :
Local    Shortint NOL1
If GREP = "C" & !GIMPORT
  For NOL1 =NOL+1 To dim(GCOA)-1
      If NOL1<=GNBCOA-1
         Assign "[M:POC2]LINACC(NOL1)" With ""
      Else
         Break
      Endif
  Next
Endif
# End issue 106746
Call APMOD_ACC(VALEUR,nolign,"[M:POC2]LINACC(") From TRTX3CPT
#-----
If [F:GAC]COA<>GCOA(nolign) | [F:GAC]ACC<>VALEUR
   Read [GAC] GAC0=GCOA(nolign);VALEUR : If fstat Raz [F:GAC] : Endif
Endif
If nolign=1
  [M:POC2]LINACC(0)=VALEUR
  If !varinit([M:POC2]LINPURTYP)
    Call D_LINPURTYP ([M:POC2]LINPURTYP) : # Chargement type d'achat
  Endif
Endif
# Issue X3-71903 - 2018-01-18 by MUARN : mise à jour de CPTANALIN
If [M:POC2]NBLIG>0 & [M:POC2]POPCREFLG([M:POC2]NBLIG-1)=1
  # boucle sur les conditions tarifaire
  For I = 0 To [M:POC2]NBLIG - 1
    # Que si pas de DL sur la ligne de condition tarifaire.
    Filter [POQ] Where POHNUM=[M:POC0]POHNUM
&                & POPLIN=[M:POC2]POPLIN
&                & WIPSTA=1
&                & DEMRCPDAT>=[M:POC2]POPSTRDAT(I)
&                & DEMRCPDAT<=[M:POC2]POPDAT(I)
    Look [POQ] POQ0 First
    If fstat <>0
      [M:POC2]UPDFLG(I)=1
    Endif
    Filter [POQ]
  Next I
Endif
End


Subprog D_LINPURTYP(VALEUR)
#--------------------------------------------------------------#
# Initialisation du type d'achat en fonction du compte général #
#--------------------------------------------------------------#
Variable Integer VALEUR
#----- Initialisation des compte si nécessaure
If [M:POC2]NBCOA=0
  Call D_NBCOA
Endif
#----- Recherche compte général -----#
Local Integer I
Call RECH_INDACC(1,I) From TRTX3CPT
If I>0
  #----- Lecture du compte si nécessaire -----#
  If [F:GAC]COA<>GCOA(I) | [F:GAC]ACC<>[M:POC2]LINACC(I-1)
    Read [GAC] GAC0=GCOA(I);[M:POC2]LINACC(I-1) : If fstat  Raz [F:GAC] : Endif
  Endif
  #-----
  If [F:GAC]VATIPT=5
    VALEUR=3
  Elsif [F:GAC]VATIPT=4
    VALEUR=2
  Else
    VALEUR=1
  Endif
Else
  VALEUR=1
Endif
End


Subprog AM_LINPURTYP(VALEUR)
#------------------------------------#
# Après modification du type d'achat #
#------------------------------------#
Variable Integer VALEUR
Local Integer OK
OK=2 : Call OUINON(mess(340,194,1),OK) From GESECRAN
If OK=2
  Local Integer  I
  Local Integer  SAV_NOLIGN           : SAV_NOLIGN=nolign
  Local Char     SAV_LINACC1(GLONGAC) : SAV_LINACC1=[M:POC2]LINACC(0)
  Local Char     SAV_LINACC2(GLONGAC) : SAV_LINACC2=[M:POC2]LINACC(1)
  [M:POC2]LINPURTYP=VALEUR
  Call INIT_COMPTES_LIGNE
  [M:POC2]LINPURTYP=VALEUR : # Modifié par le Call !
  If [M:POC2]LINACC(0)<>SAV_LINACC1
    nolign=1 : Call AM_LINACC([M:POC2]LINACC(0))
  Endif
  If [M:POC2]LINACC(1)<>SAV_LINACC2
    nolign=2 : Call AM_LINACC([M:POC2]LINACC(1))
  Endif
  If !GIMPORT  Affzo [POC2]20 : Endif
  nolign=SAV_NOLIGN
Endif
End


Subprog IB_NBLIG
#-----------------------------------------#
# Activation bouton "Explication du prix" #
#-----------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4
If [M:POC2]POPSTRDAT(nolign-1)<>[0/0/0]
  GBOUT2=mess(386,198,1)  : # Explication du prix
Endif
End


Subprog C_NBLIG
#-------------------------------------------------#
# Il y a généralement des contrôles pour vérifier #
# qu'on peut annuler ou modifier une ligne        #
#-------------------------------------------------#
GMODIF=2
Local Integer NOL, OK
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
# Issue X3-102918 - 2018-08-03 by SR :Exploitation de WSTATUS
#If status=65                            : # Annulation simple
If WSTATUS=65                            : # Annulation simple
  NOL=nolign-1 : Gosub TEST_ANU
#Elsif status=68 | status=83             : # Annulation multiple
Elsif WSTATUS=68 | WSTATUS=83             : # Annulation multiple
  For NOL=nolign-1 To nolign1-1
    Gosub TEST_ANU : If mkstat  Break : Endif
  Next NOL
#Elsif status=75                         : # Modification
Elsif WSTATUS=75                         : # Modification
  NOL=nolign-1 : Gosub TEST_MOD
#Elsif status=73 | status=82             : # Insertion
Elsif WSTATUS=73 | WSTATUS=82             : # Insertion
  NOL=nolign-1 : Gosub TEST_INSERT
#Elsif find(status,1,4,5,20,21,26,92,93) |
#&         (status>128 & status<141)
Elsif find(WSTATUS,1,4,5,20,21,26,92,93) |
&         (WSTATUS>128 & WSTATUS<141)
  Gosub TEST_VALID                      : # Validation (sortie du tableau)
Endif
# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End

TEST_MOD
#---------------------------------------------------------------#
# Test pour modification d'une ligne                            #
# GREVFLG : Indicateur modification avec avenant (1=Non, 2=Oui) #
# GMODIF  : Indicateur modification autorisée    (1=Non, 2=Oui) #
#           Non si ligne créée par une DL                       #
#---------------------------------------------------------------#
If [M:POC2]POPCREFLG(NOL)=2
  GMESSAGE=mess(28,199,1) : mkstat=2 : GMODIF=1 : Return
Else
  Gosub EXIST_DL_FERME
Endif
Return

$TEST_ANU
#------------------------------------#
# Test pour annulation de la ligne   #
# Interdit si ligne créée par une DL #
#------------------------------------#
If [M:POC2]POPCREFLG(NOL)=2
  GMESSAGE=mess(28,199,1) : mkstat=2 : GMODIF=1 : Return
Else
  Gosub EXIST_DL_FERME
Endif
Return

$EXIST_DL_FERME
Filter [POQ] Where POHNUM=[M:POC0]POHNUM
&                & POPLIN=[M:POC2]POPLIN
&                & WIPSTA=1
&                & DEMRCPDAT>=[M:POC2]POPSTRDAT(NOL)
&                & DEMRCPDAT<=[M:POC2]POPDAT(NOL)
Look [POQ] POQ0 First
If !fstat  GMESSAGE=mess(28,199,1) : mkstat=2 : GMODIF=1 : Endif
Filter [POQ]
Return

$TEST_INSERT
#---------------------------------#
# Test pour insertion d'une ligne #
#---------------------------------#
If dim([M:POC2]POPSTRDAT)<[M:POC2]NBLIG+2
  GMESSAGE=mess(122,199,1) : mkstat=2 : GMODIF=1
Endif
Return

$TEST_VALID
#---------------------------------#
# Test à la validation des lignes #
#---------------------------------#
Return


Subprog AVANT_NBLIG
#-----------------------------------------------------------#
# Avant ligne : Initialisation des champs si nouvelle ligne #
#-----------------------------------------------------------#
Local Shortint NOL : NOL=nolign-1
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
If [M:POC2]CREFLG(NOL)=0
  #----- Relecture fichiers si nécessaire -----#
  If [F:BPR]BPRNUM<>[M:POC0]BPSNUM
    Read [BPR] BPR0=[M:POC0]BPSNUM : If fstat Raz [F:BPR] : Endif
  Endif
  If [F:BPS]BPSNUM<>[M:POC0]BPSNUM
    Read [BPS] BPS0=[M:POC0]BPSNUM : If fstat Raz [F:BPS] : Endif
  Endif
  If [F:ITM]ITMREF<>[M:POC2]ITMREF
    Read [ITM] ITM0=[M:POC2]ITMREF : If fstat Raz [F:ITM] : Endif
  Endif
  If [F:ITP]ITMREF<>[M:POC2]ITMREF | [F:ITP]BPSNUM<>[M:POC0]BPSNUM
    Read [ITP] ITP0=[M:POC2]ITMREF;[M:POC0]BPSNUM : If fstat Raz [F:ITP] : Endif
  Endif
  # Issue 122511 - 2017-04-28 by SR : Lire Article-Site
  If [F:ITF]ITMREF<>[M:POC2]ITMREF | [F:ITF]STOFCY<>[M:POC0]POHFCY
    Read [ITF] ITF0=[M:POC2]ITMREF;[M:POC0]POHFCY
    If fstat  Raz [F:ITF] : Endif
  Endif
  # End issue 121511
  #-----
  If [M:POC2]POPSTRDAT(NOL)=[0/0/0]
  # Issue 122511 - 2017-04-28 by SR : Priorité à Article-Fournisseur si [F:ITP]QUAFLG = 0 : enreg inexistant
    #----- Initialisation code contrôle qualité -----#
#    If [F:ITP]QUAFLG>1
#      [M:POC2]QUAFLG(NOL)=2
#    Elsif [F:ITP]QUAFLG>0
#      [M:POC2]QUAFLG(NOL)=1
##    Elsif [F:ITM]QUAFLG>1            # hcb V6CQ
##      [M:POC2]QUAFLG(NOL)=2          # hcb V6CQ
#    Else
#      [M:POC2]QUAFLG(NOL)=1
#    Endif
    If [F:ITP]QUAFLG <> 0
       If find([F:ITP]QUAFLG,2,3) [M:POC2]QUAFLG(NOL)=2 Else [M:POC2]QUAFLG(NOL)=1 : Endif
    Else
       If find([F:ITF]QUAFLG,2,3) [M:POC2]QUAFLG(NOL)=2 Else [M:POC2]QUAFLG(NOL)=1 : Endif
    Endif
    # End issue 122511
    #----- Initialisation majoration CEE -----#
    If GACTDEB=2
      If [F:ITP]EECINCRAT=0
        [M:POC2]EECINCRAT(NOL)=[F:BPS]EECINCRAT
      Else
        [M:POC2]EECINCRAT(NOL)=[F:ITP]EECINCRAT
      Endif
    Endif
    #----- Initialisation pays d'origine -----#
    [M:POC2]ORICRY(NOL)=[F:BPR]CRY
    #----- Initialisation flag recherche tarif -----#
    [M:POC2]PRIFLG(NOL)=1
  Endif
  # Issue 71069 - 2016-01-15 by MUARN : pjt
  [M:POC2]PJT1(NOL) = [M:POC2]PJT
Endif
# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End


Subprog APRES_NBLIG
#-------------#
# Après ligne #
#-------------#
Local Shortint NOL  : NOL=nolign-1
Local Integer  STAT, SAV_NBLIG
Local Decimal  SAV_NETPRI
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
#----- Abandon de la ligne -----#
# Issue X3-102918 - 2018-08-03 by SR :Exploitation de WSTATUS et restore status
#If status=6 | status=7 | status=27 | status=28
If WSTATUS=6 | WSTATUS=7 | WSTATUS=27 | WSTATUS=28
   status = WSTATUS
  End
Endif
#----- Suppression de la ligne, recalcul date fin ligne précédente -----#
# Issue X3-102918 - 2018-08-03 by SR :Exploitation de WSTATUS
#If status=65 | status=68 | status=83 : # Suppression ligne
If WSTATUS=65 | WSTATUS=68 | WSTATUS=83 : # Suppression ligne
  If NOL<[M:POC2]NBLIG-1 & NOL>0
    [M:POC2]POPDAT(NOL-1)=[M:POC2]POPSTRDAT(NOL+1)-1
    [M:POC2]UPDFLG(NOL-1)=1
  Elsif NOL=[M:POC2]NBLIG-1 & NOL>0
    [M:POC2]POPDAT(NOL-1)=[M:POC2]XENDDAT
    [M:POC2]UPDFLG(NOL-1)=1
  Endif
  SAV_NBLIG =[M:POC2]NBLIG
  SAV_NETPRI=[M:POC2]NETPRI(NOL)
  [M:POC2]NBLIG-=1
  [M:POC2]NETPRI(NOL)=[M:POC2]NETPRI(NOL+1)
  Call VALORIS_LIGNE
  [M:POC2]NBLIG      =SAV_NBLIG
  [M:POC2]NETPRI(NOL)=SAV_NETPRI
  GAPPFLG=2
  # Issue X3-102918 - 2018-08-03 by SR :restore status
  status = WSTATUS
  End
Endif
#----- Valorisation de la ligne de contrat -----#
If NOL=0
  If [M:POC2]NETPRI(NOL)=0
    Call VALORIS_LIGNE
  Else
    If [M:POC2]PRIVLT<>[M:POC2]NETPRI(NOL)
      [M:POC2]PRIVLT=[M:POC2]NETPRI(NOL)
      If !GIMPORT Affzo [POC2]PRIVLT : Endif
      [M:POC3]TOTVLT-=[M:POC2]AMTVLT
      [M:POC2]AMTVLT =[M:POC2]EXTQTYPUU*[M:POC2]PRIVLT
      Call ARRDEV([M:POC2]AMTVLT,[M:POC1]CUR) From TRTDIV
      [M:POC3]TOTVLT+=[M:POC2]AMTVLT
      Local Integer STAT
      #----- Conversion Total HT en EURO -----#
      If [M:POC1]CUR<>GSYSCUR
        Call CONVERT([M:POC1]CUR,GSYSCUR,GLOCALDEV,[M:POC1]CHGTYP,[M:POC0]ORDDAT,
&                    [M:POC3]TOTVLT,GBIDD2,STAT) From TRTDEV
      Else
        GBIDD2=[M:POC3]TOTVLT
      Endif
      If !GIMPORT Affzo [POC3]TOTVLT : Endif
    Endif
  Endif
Endif
#----- Ajout de ligne en modif de cde --> Raz signatures -----#
If GREP="M" & [M:POC2]CREFLG(NOL)=0  GAPPFLG=2 : Endif
# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End


Subprog AS_POPSTRDAT(VALEUR)
#---------------------------------------#
# Avant saisie date début d'application #
#---------------------------------------#
Variable Date    VALEUR
If GMODIF=1 mkstat=2 : End : Endif
If VALEUR=[0/0/0] & nolign=1
  VALEUR=[M:POC2]XSTRDAT
Endif
End


Subprog C_POPSTRDAT(VALEUR)
#-----------------------------------#
# Contrôle date début d'application #
#-----------------------------------#
Variable Date    VALEUR
If VALEUR<[M:POC2]XSTRDAT | VALEUR>[M:POC2]XENDDAT
  GMESSAGE=mess(20,199,1) : mkstat=2 : End
Endif
If [M:POC2]NBLIG<>0
  If nolign<>1 & VALEUR<=[M:POC2]POPSTRDAT(nolign-2)
    GMESSAGE=mess(73,199,1) : mkstat=2 : End
  Elsif nolign<[M:POC2]NBLIG & VALEUR>=[M:POC2]POPSTRDAT(nolign)
    GMESSAGE=mess(73,199,1) : mkstat=2 : End
  Endif
  # Issue 107577 - 2015-04-09 by MUARN : ne pas prendre en compte les lignes soldée LINSTA
  Filter [POQ] Where POHNUM=[M:POC0]POHNUM
&                  & POPLIN=[M:POC2]POPLIN
&                  & WIPSTA=1
&                  & DEMRCPDAT>=VALEUR
&                  & LINSTA < 3
  Read [POQ] POQ0 Last
  Filter [POQ]
  If !fstat
    GMESSAGE=mess(400,194,1)-"("+num$([F:POQ]DEMRCPDAT)+")" : mkstat=2 : End
  Endif
Endif
End


Subprog AM_POPSTRDAT(VALEUR)
#---------------------------------------------------#
# Après modification de la date début d'application #
#---------------------------------------------------#
Variable Date     VALEUR
Local    Shortint NOL : NOL=nolign-1
#------ Mise à jour date fin ligne précédente -----#
If NOL>0
  [M:POC2]POPDAT(NOL-1)=VALEUR-1
  [M:POC2]UPDFLG(NOL-1)=1
Endif
#----- Mise à jour date fin ligne en cours -----#
If NOL>=[M:POC2]NBLIG-1
  #----- Date fin = date fin validité ligne article -----#
  [M:POC2]POPDAT(NOL)=[M:POC2]XENDDAT
Endif
If [M:POC2]POPDAT(NOL)=[0/0/0]
  #----- Date fin = date début ligne suivante - 1 jour -----#
  If NOL<[M:POC2]NBLIG-1 & [M:POC2]POPSTRDAT(NOL+1)<>[0/0/0]
    [M:POC2]POPDAT(NOL)=[M:POC2]POPSTRDAT(NOL+1)-1
  Endif
Endif
[M:POC2]POPSTRDAT(NOL)=VALEUR
#----- Recherche tarif -----#
If [M:POC2]PRIFLG(NOL)<>2
  [M:POC2]PRIFLG(NOL)=2
  If [M:POC2]PLI<>""
    GPUU=[M:POC2]PUU : Call RECH_TARIF ("POC",NOL) From TRTACHTAR1
    nolign=NOL+1
  Endif
  If !GIMPORT
    Affzo [POC2]GROPRI(NOL)
    If GCOLREM(0)<>"" Affzo [POC2]DISCRGVAL1(NOL) : Endif
    If GCOLREM(1)<>"" Affzo [POC2]DISCRGVAL2(NOL) : Endif
    If GCOLREM(2)<>"" Affzo [POC2]DISCRGVAL3(NOL) : Endif
    If GCOLREM(3)<>"" Affzo [POC2]DISCRGVAL4(NOL) : Endif
    If GCOLREM(4)<>"" Affzo [POC2]DISCRGVAL5(NOL) : Endif
    If GCOLREM(5)<>"" Affzo [POC2]DISCRGVAL6(NOL) : Endif
    If GCOLREM(6)<>"" Affzo [POC2]DISCRGVAL7(NOL) : Endif
    If GCOLREM(7)<>"" Affzo [POC2]DISCRGVAL8(NOL) : Endif
    If GCOLREM(8)<>"" Affzo [POC2]DISCRGVAL9(NOL) : Endif
    Affzo [POC2]NETPRI(NOL)
  Endif
Endif
End


Subprog AS_GROPRI(VALEUR)
#---------------------------#
# Avant saisie du prix brut #
#---------------------------#
Variable Decimal VALEUR
#----- Si inter-sociétés, on autorise quand même la modification du tarif -----#
#If [M:POC0]BETCPY=2  mkstat=2 : End : Endif
End

Subprog IB_GROPRI
#------------------------------------------------------#
# Activation boutons "Tarifs" et "Explication du prix" #
#------------------------------------------------------#
Raz GBOUT4
GBOUT1=mess(42,198,1)  : # Tarifs
GBOUT3=mess(386,198,1) : # Explication du prix
End

Subprog PASLINPOC(DISCRGNUM)
#--------------------------------------#
# Avant saisie des remises/frais tarif #
#--------------------------------------#
Value Integer DISCRGNUM
If DISCRGNUM<1 | DISCRGNUM>9 End : Endif
If GMODIF<>2 | GCOLREM(DISCRGNUM-1)="" mkstat=2 : Endif
#----- Si inter-sociétés, on autorise quand même la modification du tarif -----#
#If [M:POC0]BETCPY=2  mkstat=2 : End : Endif
End

