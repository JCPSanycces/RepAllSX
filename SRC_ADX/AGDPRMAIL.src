#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################
#  Function AGDPRMAI
#  extraction in database for all emails
#  numreq is a counter
#  can be executed in batch mode
# ----------------------------------------------------------------------- #
# Action  : AGDPRMAI
# Screen  : AGDPRMAI  [AGMAI]
# Windows : AGDPRMAI
# file AGDPRMAI
#################################################################################
# in batch mode is possible
Gosub OUVRE
Call EXTRACT
Call EXPORT
Gosub TERMINE
End
#################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "FINSAI"       : Gosub TERMINE
    When "BOUTON"       : Gosub BOUTON

  Endcase
Return

##############################################
$OUVRE
#--------- files
Local File AGDPRSETTING [AGS]
Local File AGDPRMAI     [AGMAI]

#--------- variables

Local Integer WSAVIUM
Local Char    WSAVIFS(10) , WSAVIRS(5)


#--------- initialisations
[L]WSAVIFS= adxifs
[L]WSAVIRS= adxirs
[L]WSAVIUM= adxium


Return

##############################################
$TERMINE
LogicClose File [AGS]
LogicClose File [AGMAI]

adxifs =[L]WSAVIFS
adxirs =[L]WSAVIRS
adxium =[L]WSAVIUM

Return

##############################################
$DEBUT
Raz [M:AGMAI]
Affzo [M:AGMAI]
Return

##############################################
$BOUTON
Case BOUT
    When "S" : Call EXTRACT
    When "E" : Call EXPORT
Endcase
Return

###################################################################
# extraction in all database type mail
###################################################################
Subprog EXTRACT
# typ = 2 email
If func SEARCH_EMAIL(nomap,2,GMESSAGE)=[V]CST_AERROR
      If !GSERVEUR
           Call ERREUR(GMESSAGE) From GESECRAN
      Endif
Endif
End
###################################################################
# export in format csv on local desktop
# can be launched in batch mode just after the extract but only in TRA directory
###################################################################
Subprog EXPORT

Local Char ZFIC (GDIMFIC)
Local Char WFICORI (GDIMFIC)
Local Integer WERROR
Local Integer WOK

Local Char WMESSAGE (GDIMFIC)


  Filter[F:AGMAI] Order By Key AGMAI1 Asc
  If rowcount([F:AGMAI]) = 0
      If !GSERVEUR
          Call  WARNING(mess(13,155,1),WOK) From GESECRAN
      Endif
  Else
      ZFIC = filpath("TRA", "ALISTGDPRMAIL" , "tra","","",adxmac(0))
      Openo ZFIC, 0                   Using [WFTP]
      Iomode adxium GUTF8             Using [WFTP]
      Iomode adxirs chr$(13)+chr$(10) Using [WFTP]
      Iomode adxifs ';'               Using [WFTP]

      WMESSAGE = "Mail;Table;Key table;Field"

      Wrseq WMESSAGE   Using [WFTP]

      For [F:AGMAI]
            WMESSAGE = [F:AGMAI]MAICOD+";"+[F:AGMAI]TABCOD+";"+[F:AGMAI]TABKEY+";"+[F:AGMAI]TABFLD
            Wrseq WMESSAGE  Using [WFTP]
      Next
      Openo                 Using [WFTP]
      If !GSERVEUR
          # upload fichier
          WFICORI = ZFIC
          ZFIC= "ALISTGDPRMAIL.csv"
          Call SET_NAMCLI(ZFIC) From ORDSYS
          Call MOVCLI(WFICORI,ZFIC,WERROR) From ORDSYS
          If WERROR
             Call ERREUR(mess(12,139,1)) From GESECRAN
          Endif
          Call EFFACE(WFICORI, WERROR) From ORDSYS
          # end of process
          Call  MESSAGE(mess(27,150,1)) From GESECRAN
      Else
          # "you can find export file under :"
          Call ECR_TRACE (mess(16,155,1)- ZFIC,0) From GESECRAN
      Endif
  Endif
  Filter[F:AGMAI]


End

###################################################################
# Search for a code in tables with predefined data types
#
# @param PDOSSIER : Folder name
# @param PTYPAGS  : mail type
# @param PMSG     : error message
# @return [V]CST_AERROR if an error occured otherwise [V]CST_AOK
###################################################################

Funprog SEARCH_EMAIL (PDOSSIER,PTYPAGS,PMSG)
Value Char PDOSSIER
Value Integer PTYPAGS
Variable Char PMSG

Local Integer LNBFLD, LRET
Local Integer WNUMREQ

Local Integer WOK
Local Char WFILTRE (GDIMFIC)
Local Char VCRFLD(GDIMFIC) (0..300)

LRET = [V]CST_AOK
Raz PMSG

# Recording will be done on current folder
Local File =PDOSSIER+".ATABZON" [ATZ]
Local File =PDOSSIER+".ATYPE"   [ATY]

If GSERVEUR
    Call ECR_TRACE (mess(14,155,1),0) From GESECRAN
Else
    # generation of Email addresses list
     Call TEMPON(mess(14,155,1)) From GESECRAN
Endif

# Remove old records
If func DEL_RECORD(PDOSSIER,PTYPAGS,PMSG)=[V]CST_AERROR
      #"Problem during deletion records"
      Call ECR_TRACE (mess(15,155,1),1) From GESECRAN
      Goto FIN_SEARCH
Endif

WNUMREQ = 0
# For each mail type (must be activated Enaflg = 2)
Filter [AGS] Where TYP = PTYPAGS and ENAFLG = 2
If rowcount([F:AGS]) = 0
      If !GSERVEUR
          Call  WARNING(mess(18,155,1),WOK) From GESECRAN
      Else
          #("Rien a traiter , le paramétrage des setttings n a pas été fait
          Call ECR_TRACE (mess(18,155,1),0) From GESECRAN
      Endif
      Filter [AGS]
      Goto FIN_SEARCH
Endif

For [AGS]
  If [F:AGS]CODATY <> ""
      Read [ATY]CODTYP=[F:AGS]CODATY
      If fstat
        LRET = [V]CST_AERROR
        PMSG = [F:AGS]CODATY-mess(51,139,1)
        If GSERVEUR
            Call ECR_TRACE (PMSG,1) From GESECRAN
        Endif
        Break
      Else
        # Data type must be numeric or alphanumeric
        If [F:ATY]TYPTYP>7
            LRET = [V]CST_AERROR
            PMSG = [F:AGS]CODATY-mess(51,139,1)-mess([F:ATY]TYPTYP,30,1)
            If GSERVEUR
                Call ECR_TRACE (PMSG,1) From GESECRAN
            Endif
            Break
        Endif
        # For each table containing at least 1 field with the data type...
        For [ATZ]CODTYP(2) Where [F:ATZ]CODTYP=[F:AGS]CODATY
            # check if the table exists excluede AGDPRMAI
            If [F:ATZ]CODFIC <> "AGDPRMAI"
              If filinfo(filpath("FIL",[F:ATZ]CODFIC,"fde",PDOSSIER),0)>=0
                Local File =PDOSSIER+"."+[F:ATZ]CODFIC [VCR]
                # Get formula that allow to get the key of a record
                KEYFOR=func TRTAGSEA.KEYFORM(PDOSSIER,[ATZ]CODFIC,"VCR")
                Raz WFILTRE
                Raz VCRFLD
                # pas de filtre
                WFILTRE = "1=1"
                Raz LNBFLD
                For [ATZ]CODTYP
                    If evalue("dim([F:VCR]"+[F:ATZ]CODZONE+")") >= 0
                        VCRFLD(LNBFLD) = [F:ATZ]CODZONE
                        LNBFLD+=1
                    Endif
                Next
                Raz PMSG
                Gosub RECORD_VCR
                If LRET=[V]CST_AERROR
                    Call ECR_TRACE (PMSG,1) From GESECRAN
                    Break 2
                Else
                    If PMSG <> ""
                        Call ECR_TRACE (PMSG,0) From GESECRAN
                    Endif
                Endif
                LogicClose File [VCR]
              Endif
             Endif
           Next
      Endif
  Else
      # ici type donnée est vide on prend que table et code champs
      If filinfo(filpath("FIL",[F:AGS]CODATB,"fde",PDOSSIER),0)>=0
         If [F:AGS]CODATB <> "AGDPRMAI"
                Local File =PDOSSIER+"."+[F:AGS]CODATB [VCR]
                Read [ATZ]CODZONE =[F:AGS]CODATB;[F:AGS]CODFLD
                If fstat = 0
                    # Get formula that allow to get the key of a record
                    KEYFOR=func TRTAGSEA.KEYFORM(PDOSSIER,[ATZ]CODFIC,"VCR")
                    Raz WFILTRE
                    Raz VCRFLD
                    # pas de filtre
                    WFILTRE = "1=1"
                    Raz LNBFLD
                    If evalue("dim([F:VCR]"+[F:ATZ]CODZONE+")") >= 0
                        VCRFLD(LNBFLD) = [F:ATZ]CODZONE
                        LNBFLD=1
                    Endif
                    Raz PMSG
                    Gosub RECORD_VCR
                    If LRET=[V]CST_AERROR
                        Call ECR_TRACE (PMSG,1) From GESECRAN
                        Break
                    Else
                        If PMSG <> ""
                            Call ECR_TRACE (PMSG,0) From GESECRAN
                        Endif
                    Endif
                Endif
                LogicClose File [VCR]
            Endif
      Endif
  Endif
Next
Filter [AGS]

# read if file empty or not
Filter [AGMAI]
If rowcount([F:AGMAI]) = 0
      If !GSERVEUR
          Call  WARNING(mess(18,155,1),WOK) From GESECRAN
      Else
          #("Rien a traiter , le paramétrage des settings n a pas été fait
          Call ECR_TRACE (mess(18,155,1),0) From GESECRAN
      Endif
Else
      If !GSERVEUR
      # end of process
          Call  MESSAGE(mess(27,150,1)) From GESECRAN
      Endif
Endif


$FIN_SEARCH
If !GSERVEUR
   Call TEMPOFF From GESECRAN
Endif

LogicClose File [ATZ], [ATY]
End LRET

#--------------------------#
#  Write Record key of all documents
#--------------------------#
$RECORD_VCR
# As reading of [VCR] will be done in function of AUUID, all values must be set
# if field does not exist not blocking.
If dim([F:VCR]AUUID) < 0
    PMSG = func AFNC.MES(mess(21,155,1),[F:ATZ]CODFIC)-mess(22,155,1)
    Return
Endif


Filter [VCR] Where AUUID=NullUuid
Look [VCR] First
Filter [VCR]
If fstat=[V]CST_AOK
    # if field uid  not init but not blocking.
    PMSG = func AFNC.MES(mess(20,155,1),[F:ATZ]CODFIC)-mess(22,155,1)
    Return
Endif

Local Uuident VCRAUUID
Local Integer WIND_FLD, STOP, LNBVCR
Local Char WEMAIL(GDIMFIC)

VCRAUUID = NullUuid

$LOOP_VCR
Trbegin [AGMAI]

Raz STOP, LNBVCR
# Order the reading with common and unique field in all tables to be able to manage GMAXUPDTRS
Filter [VCR] Where evalue(WFILTRE)
&                & AUUID>VCRAUUID
&            Order By AUUID
For [VCR]
    [F:AGMAI]TABCOD = [F:ATZ]CODFIC
    [F:AGMAI]TABKEY = evalue(KEYFOR)

    For WIND_FLD=0 To LNBFLD-1
        If VCRFLD(WIND_FLD) <> ""
          WEMAIL = evalue("[F:VCR]"+VCRFLD(WIND_FLD))
          # mail must contain un "@"
          If  WEMAIL <> "" and instr(1,WEMAIL,"@") <>0
              [F:AGMAI]MAICOD   = WEMAIL
              [F:AGMAI]TABFLD   = VCRFLD(WIND_FLD)
              # Check if the record already exists on ne le met qu un seul fpis dans la table pas de duplciate
              Look [F:AGMAI]AGMAI1=[F:AGMAI]MAICOD;[F:AGMAI]TABCOD;[F:AGMAI]TABFLD
              If fstat<>[V]CST_AOK
                    # If not -> create it
                    WNUMREQ +=1
                    [F:AGMAI]NUMREQ  = WNUMREQ
                    Write [AGMAI]
                    If fstat
                        LRET = [V]CST_AERROR
                        PMSG = "[F:AGMAI]"-mess(26,125,1)-func GLOCK.GET_FSTAT_MSG(fstat)
                        Break 2
                    Endif
                    LNBVCR +=1
              Endif
          Endif
        Endif
    Next WIND_FLD
    If LNBVCR>GMAXUPDTRS
        VCRAUUID = [F:VCR]AUUID
        STOP=1
    Endif
Next
Filter [VCR]
If LRET=[V]CST_AOK
    Commit
    If STOP
        Goto LOOP_VCR
    Endif
Else
    Rollback
Endif
Return
###################################################################
#  Delete record in file
# @param PDOSSIER : Folder name
# @param PTYPAGS  : mail type
# @param PMSG     : error message
# @return [V]CST_AERROR if an error occured otherwise [V]CST_AOK
###################################################################
Funprog DEL_RECORD (PDOSSIER,PTYPAGS,PMSG)
Value Char PDOSSIER
Value Integer PTYPAGS
Variable Char PMSG

Local Integer LNBFLD, LRET
# Remove old records
Trbegin [AGMAI]
Delete [AGMAI] Where 1=1
If fstat
    Rollback
    LRET = [V]CST_AERROR
    PMSG = "[F:AGMAI]"-mess(28,125,1)-func GLOCK.GET_FSTAT_MSG(fstat)
    If GSERVEUR
         Call ECR_TRACE (PMSG,1) From GESECRAN
    Endif
Else
    Commit
Endif

End LRET

