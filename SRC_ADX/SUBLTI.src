############################################################
Subprog C_SIMFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1  | VALEUR = 2
  End
Else 
 mkstat = 2
Endif
End
#############################################################
Subprog AS_SIMFLG(VALEUR)
Variable Integer VALEUR
If [M]NBLIG = 0
  Gosub LOA_STATUTS From FUNSTOLTI
Endif
End

#############################################################
Subprog AM_NEWSTAQQQ(VALEUR)
Variable Char    VALEUR()
If left$(VALEUR,1)<>"Q"
    mkstat=2
    End
Endif
Read [TST]TST0=VALEUR
If !fstat
    Call GET_ATEXTRA("TABSTASTO","STAAXX",GLANGUE,[M]SHOAXXQQQ(nolign-1)) From TRTX3TEX
Endif
End
#############################################################
Subprog AM_NEWSTARRR(VALEUR)
Variable Char    VALEUR()
If left$(VALEUR,1)<>"R"
    mkstat=2
    End
Endif
Read [TST]TST0=VALEUR
If !fstat
    Call GET_ATEXTRA("TABSTASTO","STAAXX",GLANGUE,[M]SHOAXXRRR(nolign-1)) From TRTX3TEX
Endif
End

#############################################################
Subprog C_DATJOUR(VALEUR)
Variable Integer VALEUR

If VALEUR=2
   Effzo [M]IPTDAT 
   Grizo [M]IPTDAT
Else
   [M]IPTDAT = date$
   Actzo [M]IPTDAT
Endif

End


