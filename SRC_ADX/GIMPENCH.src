#<AdxTL>@(#)209.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","GIMPENCH","DIMPENCH",4,"XYGIMPENCH") From GTRAITE
End

#######################################################
$ACTION
Case ACTION
 When "INIT"         : Gosub INIT
 When "CONTROLE"     : Gosub CONTROLE
 When "EXEC"         : Gosub EXEC
 When "TERMINE"      : Gosub TERMINE
 When "OUVRE_BATCH"  : Gosub OUVRE
 When Default
Endcase
Return

#######################################################
$INIT
Local Integer I , J, NBFIC, IMPSTA
Local Char    MESSAGE(80)
Local Char    NOMFIC(GDIMFIC) , FICBAS(GDIMFIC)
Local Char    REPERT(GDIMFIC)
Local Char    MACHINE(GDIMFIC)
Local Char    TIT(50)
TIT  = mess(45,141,1)-mess(52,141,1)-PARAM(1) : # Enchaînement Importation
Gosub OUVRE
Local Mask IMPENCH [DIA]
Raz [M:IMP2]
Raz [M:DIA]
[M:DIA]CODE = PARAM(1)
Return

#######################################################
$CONTROLE
If !GSERVEUR & [M:DIA]TEST<>2
 TMP = 1
Endif
If GSTATUT=7
 FIN = 1 : # Sortie du GSAISIE par la touche FIN
Endif
Return

#######################################################
$EXEC
If !GSERVEUR & [M:DIA]TEST<>2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

NBFIC = 0
For [AEN]CODE Where CODE=[M:DIA]CODE & NUMLIG>0
 Raz [M:IMP2] : #115259
 NBFIC += 1
 Call CHARGE_MODELE([F:AEN]MODELE,IMPSTA) From GIMPOBJ
 If IMPSTA : Break : Endif
 If [F:AOE]OBJ<>""
  Read [AOB_]ABREV = [F:AOE]OBJ
  If fstat : Break : Endif
 Endif
 NOMFIC = [F:AEN]CHEMIN
 If instr(1,NOMFIC,"[")<>0 & instr(1,NOMFIC,"]")<>0
  Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
  #SAM 110461 {
  NOMFIC = func ASYRSTO.AGET_VOLFILPATH([F:AEN]CHEMIN)
  #} SAM 110461
 Endif
 If NOMFIC=""
  If [M:IMP2]NOMIMP<>""
   If GOS="unix" & !pat(left$([M:IMP2]NOMIMP,3),"!:\") & left$([M:IMP2]NOMIMP,1)<>"\"
    NOMFIC = [M:IMP2]NOMIMP
   Elsif GOS<>"unix" & left$([M:IMP2]NOMIMP,1)<>"/"
    NOMFIC = [M:IMP2]NOMIMP
   Endif
  Endif
 Endif
 If !instr(1,NOMFIC,"@") & !find(left$(NOMFIC,1),"/") & !pat(left$(NOMFIC,3),"!:\")
  Call GETREP("REPIMPDEF",REPERT) From SUBEXPOBJ
  If REPERT<>""
   Call MACHINE(REPERT,MACHINE,REPERT) From ORDSYS
   Call SETFIC(REPERT,NOMFIC,MACHINE,NOMFIC) From SUBEXPOBJ
  Endif
 Endif
 [M:IMP2]NOMIMP = NOMFIC
 [M:IMP2]TYPEXP = 2
 [M:IMP2]MODIMP = [F:AEN]MODELE
 [M:IMP2]VOLFIL = [F:AEN]CHEMIN     # Issue X3-43015 - 2017-06-20 by CCC : set VOLFIL used by the control in import
 If [M:DIA]TEST=2
  Call TRAITE_CHAR(VALEUR,PARAM,"DIMPOBJ2","TRTIMPOBJ","",3,"XYTRTIMPOBJ") From GTRAITE
 Else
  Call IMPORTSIL([M:IMP2]MODIMP,[M:IMP2]NOMIMP) From GIMPOBJ
 Endif
 IMPSTA = [M:IMP2]STAT
 If IMPSTA : Break : Endif
Next

If !GSERVEUR & [M:DIA]TEST<>2
 Call FERME_TRACE From LECFIC
Endif
Return

###############################################################
$TERMINE
If !GSERVEUR & [M:DIA]TEST<>2
 TRA = 1
Else
 TRA = 0
Endif
Return

#######################################################
$OUVRE
If clalev([F:AEN])=0  : Local File AENCHAINE  [AEN]  : Endif
If clalev([F:AOE])=0  : Local File AOBJEXT    [AOE]  : Endif
If clalev([F:AOD])=0  : Local File AOBJEXTD   [AOD]  : Endif
If clalev([F:AOR])=0  : Local File AOBJEXTR   [AOR]  : Endif
If clalev([F:APX])=0  : Local File APARIMPEXP [APX]  : Endif

If clalev([F:ACC_])=0 : Local File ACCES      [ACC_] : Endif
If clalev([F:AOB_])=0 : Local File AOBJET     [AOB_] : Endif
If clalev([F:AWI_])=0 : Local File AWINDOW    [AWI_] : Endif
If clalev([F:ATY_])=0 : Local File ATYPE      [ATY_] : Endif
If clalev([F:AMK_])=0 : Local File AMSK       [AMK_] : Endif
If clalev([F:AMZ_])=0 : Local File AMSKZON    [AMZ_] : Endif
If clalev([F:ATB_])=0 : Local File ATABLE     [ATB_] : Endif
If clalev([F:ATZ_])=0 : Local File ATABZON    [ATZ_] : Endif
If clalev([F:ATI_])=0 : Local File ATABIND    [ATI_] : Endif
If clalev([F:AMP_])=0 : Local File AMSKPAR    [AMP_] : Endif
If clalev([F:AFC_])=0 : Local File AFONCTION  [AFC_] : Endif
If clalev([F:ACV_])=0 : Local File ACTIV      [ACV_] : Endif
If clalev([F:ANM_])=0 : Local File ACODNUM    [ANM_] : Endif

If clalev([M:AOE0])=0 : Local Mask AOE0       [AOE0] : Endif
If clalev([M:AOE1])=0 : Local Mask AOE1       [AOE1] : Endif
If clalev([M:AOE2])=0 : Local Mask AOE2       [AOE2] : Endif
If clalev([M:IEX])=0  : Local Mask IMPTEST    [IEX]  : Endif
If clalev([M:IMP2])=0 : Local Mask IMPOBJ2    [IMP2] : Endif
Return

########################################
## Etiquettes ecran IMPENCH           ##
########################################
Subprog IB_CODE
If GADONIX<>2
 GBOUT2 = ""
Endif
End

Subprog C_CODE(VALEUR)
Value   Char VALEUR()
Look [AEN]CODE(1) = VALEUR
If fstat
 GMESSAGE = mess(23,100,1) : # Fiche inexistante
 mkstat = 2 : End
Endif
For [AEN] Where CODE=VALEUR & NUMLIG>0
 Read [AOE]AOE0 = [F:AEN]MODELE
 If !fstat & [F:AOE]IMPORT<>2
  GMESSAGE = [F:AEN]MODELE-":"-mess(109,141,1) : # Import impossible sur ce modèle
  mkstat = 1 : Break
 Endif
 Call CONTEXE([F:AOE]ACS) From SUBACS
 If mkstat : GMESSAGE = mess(97,141,1)-[F:AOE]EXT-":"-GMESSAGE : Break : Endif : # Modèle import-export
Next AEN
End

Subprog AS_TEST(VALEUR)
Variable Integer  VALEUR()
End

