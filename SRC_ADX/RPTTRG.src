#<AdxTL>@(#)0.0.0.0 $Revision$ pre process for German tax dec
#** #############################################################################################
#*Handler for the report preprocess.
#*
#* @param     NBPAR       Variable Integer      Number of parameters
#* @param     PARAMETRE   Variable Char()(1..)  Report parameters as strings.
#*
#*! #############################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Local Char PARAMR, REPCODE
Local Integer NUMREQ , K
#Report generation is only possible when germant tax return dialog is open
#otherwise => End
  If !clalev([M:TRG0])
     End
  Endif

# Get the report code from report name.
Call GETPARAM("__REPORT",NBPAR,PARAMETRE,PARAMR) From ETAT
K = instr(1,PARAMR,".")
If K : REPCODE = left$(PARAMR,K-1)  : Endif


# Get the report ID for the selection using AREPORTM.NUMREQ.
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAMR) From ETAT : NUMREQ = val(PARAMR)
PARAMR = num$(NUMREQ)

# Set the numedt parameter.
PARAMR = num$(NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAMR) From ETAT


# Set the site parameter with the information from the header screen [M:TRG0]
PARAMR = [M:TRG0]FCY
Call SETPARAM("site",NBPAR,PARAMETRE,PARAMR) From ETAT

#If site is set then set also the sitename
If PARAMR <> ""
  PARAMR = [F:FCY]FCYNAM
  Call SETPARAM("fcyname",NBPAR,PARAMETRE,PARAMR) From ETAT
Endif

#Set the currency parameter with the information from the header screen [M:TRG0]
PARAMR = [M:TRG0]CURSEL
Call SETPARAM("cur",NBPAR,PARAMETRE,PARAMR) From ETAT

#Set the datbegin (start date) parameter with the information from the header screen [M:TRG0]
PARAMR = [M:TRG0]DATDEB
Call SETPARAM("datbegin",NBPAR,PARAMETRE,PARAMR) From ETAT

#Set the  (end date) parameter with the information from the header screen [M:TRG0]
PARAMR = [M:TRG0]DATFIN
Call SETPARAM("datende",NBPAR,PARAMETRE,PARAMR) From ETAT

#Set the taxno parameter with the information from the header screen [M:TRG0]
PARAMR = [M:TRG0]CRN
Call SETPARAM("steuernr",NBPAR,PARAMETRE,PARAMR) From ETAT


#Set the kz10 parameter with the information from the property screen TRGPROP0 (TRGP)
If [M:TRGP]KNZ10 = 2 Then
  PARAMR = " 1"
Else
  PARAMR = " "
Endif
Call SETPARAM("kz10",NBPAR,PARAMETRE,PARAMR) From ETAT

#Set the kz22 parameter with the information from the property screen TRGPROP0 (TRGP)
If [M:TRGP]KNZ22 = 2 Then
  PARAMR = " 1"
Else
  PARAMR = " "
Endif
Call SETPARAM("kz22",NBPAR,PARAMETRE,PARAMR) From ETAT

#Set the kz23 parameter with the information from the property screen TRGPROP0 (TRGP)
If ( dim( [M:TRGP]KNZ23 ) > 0 ) and ( [M:TRGP]KNZ23 = 2 ) Then
  PARAMR = " 1"
Else
  PARAMR = " "
Endif
Call SETPARAM("kz23",NBPAR,PARAMETRE,PARAMR) From ETAT

#Set the kz26 parameter with the information from the property screen TRGPROP0 (TRGP)
If [M:TRGP]KNZ26 = 2 Then
  PARAMR = " 1"
Else
  PARAMR = " "
Endif
Call SETPARAM("kz26",NBPAR,PARAMETRE,PARAMR) From ETAT

#Set the kz29 parameter with the information from the property screen TRGPROP0 (TRGP)
If [M:TRGP]KNZ29 = 2 Then
  PARAMR = " 1"
Else
  PARAMR = " "
Endif
Call SETPARAM("kz29",NBPAR,PARAMETRE,PARAMR) From ETAT

If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif



#Set the societe (Company) parameter
#PARAMR = func GETCOMPANY()
PARAMR = func GERVATCSVLIB.GETLECOMPANY([M:TRG0]GRP, [M:TRG0]CPY)
Call SETPARAM("societe",NBPAR,PARAMETRE,PARAMR) From ETAT


#Set the bprnum(business partner number) parameter.
PARAMR = func GETBPRNUM(func GETCOMPANY())
Call SETPARAM("bprnum",NBPAR,PARAMETRE,PARAMR) From ETAT

#got to sub INS_ARM which fills the AREPORTM table.
Gosub INS_ARM
End



#** #############################################################################################
#* Determines the Company/Group for setting the report parameter Societe
#*
#*  @return Result          Local char  Company/Group
#*
#*! #############################################################################################
Funprog GETCOMPANY()
Local Char RESULT(30)
If [M:TRG0]GRP <>""  Then
    RESULT = [M:TRG0]GRP
  # Read [F:CPY]CPY0 = [M:XEV0]GRP
  #If fstat = 0
#      If [F:CPY]XFCPY <> "" Then
#         Read [F:CPY]CPY0 = [F:CPY]XFCPY
#         If fstat = 0
#            SOCIETE = [F:CPY]CPY
#         Else
#            SOCIETE = ""
#         Endif
#       Endif
#      RESULT = ""
#    Endif
Else
   RESULT = [M:TRG0]CPY
Endif
End RESULT




#** #############################################################################################
#* Determines the BPRNUM of the taxcenter of the company
#*
#*  @return Result          Local char  BPRNUM
#*
#*! #############################################################################################
Funprog GETBPRNUM(COMP)
  Value Char COMP
  Local Char RESULT(30)
  If [M:TRG0]CRN <>""  Then
  Filter [F:CPY] Where [F:CPY]CPY = COMP #GERTAXIDT = [M:TRG0]CRN
   For [CPY]
    RESULT = [CPY]GERTAXCEN
   Next
  Filter [F:CPY]


#   Filter [F:CPY] Where GERTAXIDT = [M:TRG0]CRN
#   For [CPY]
#    RESULT = [CPY]GERTAXCEN
#   Next
#   Filter [F:CPY]
Endif
End RESULT






#** ########################################################################
#*INS_ARM writes data from the grid in mask [M:TRG1] to the AREPORTM table
#** ########################################################################
$INS_ARM
Local Integer J1
Local Integer REPLINE(106)
Local Decimal AMTVATBASE(106)
Local Decimal AMTVAT(106)

Gosub SETLINECODEARRAYS

J1 = 0
If !clalev([F:ARM])  : Local File AREPORTM [ARM]  :  Endif
GOK = 1
Call DEBTRANS From GLOCK
If !clalev([M:TRG1]) : Default Mask [M:TRG1] : Endif

Trbegin [ARM]

For I = 0 To 105
  J1 +=1
  Raz [F:ARM]
  [F:ARM]RPTCOD = REPCODE
  [F:ARM]USR    = GUSER
  [F:ARM]NUMREQ = NUMREQ
  [F:ARM]NUMLIG = J1

  [F:ARM]CLEA1  = num$([L]REPLINE(I))
  [F:ARM]CLEMD1 = [L]AMTVATBASE(I)
  [F:ARM]CLEMD2  = [L]AMTVAT(I)
  [F:ARM]CREDAT = date$
    Write [ARM]
  If fstat
   GOK = 0
  Endif

Next
#if writing not possible =>Rollback
If GOK<1 : Rollback  : Endif
Commit
#Infbox("NUMREQ: " + num$(NUMREQ))
Return


#** #############################################################################################################
#*SETLINECODEARRAYS Set the Tax amount and Transactionsum amount in the right fields of the Linecode arrays
#*             The index of the array is equivalent to the linecode
#*
#** #############################################################################################################
#*!
$SETLINECODEARRAYS
Local Integer K
Local Char ERRKZ

ERRKZ = "N"
K=0
Raz [L]REPLINE
Raz [L]AMTVATBASE
Raz [L]AMTVAT
For K=0 To 106
   [L]REPLINE(val([M:TRG1]REPLINE(K)))     = val([M:TRG1]REPLINE(K))
   [L]AMTVATBASE(val([M:TRG1]REPLINE(K))) = [M:TRG1]AMTVATBASE(K)
   [L]AMTVAT(val([M:TRG1]REPLINE(K)))    = [M:TRG1]AMTVAT(K)
Next

Return

