  When  2 : Filter [TMP] Where NUMREQ=REQUETE Order By Key CLE=TRICCE1;TRICCE2
  When  1 : Filter [TMP] Where NUMREQ=REQUETE Order By Key CLE=TRICCE1
 Endcase
Endif
For [TMP]CLE(NBCLE) Where evalue(FILTRE) & evalue(FILDET)
 If NOL>=MAXLIG
  SUITE = 1 : Break
 Endif
 Gosub CHARGE
 If sigma(1,NBCOL,abs(MONTANT(indcum)))<>0
  NOL += 1
 Endif
Next
[M]NBLIG = NOL
Filter [TMP]
Return

$PPREC
If NIVEAU=0 : Goto TOTAL : Endif
Effzo [BLA2] 20
NOL = MAXLIG
RETOUR = 0
For K=NIVEAU To 1 Step -1
 FILTRE = ""
 For J=1 To K-1
  If FILTRE<>"" : FILTRE -= '&' : Endif
  If DETAIL
   FILTRE -= 'DET'+mid$(CHIFFRES,J,1)+'="'+evalue("DEB"+num$(J))+'"'
  Else
   FILTRE -= 'TRICCE'+mid$(CHIFFRES,J,1)+'="'+evalue("DEB"+num$(J))+'"'
  Endif
 Next J
 If FILTRE<>"" : FILTRE -= '&' : Endif
 If DETAIL
  FILTRE -= 'DET'+mid$(CHIFFRES,K,1)+'<"'+evalue("DEB"+num$(K))+'"'
 Elsif DETSIT=2 & K=NIVEAU
  FILTRE -= '((TRICCE'+mid$(CHIFFRES,K,1)+'="'+evalue("DEB"+num$(K))+'" & FCY<"'+DEBFCY+'") | (TRICCE'+mid$(CHIFFRES,K,1)+'<"'+evalue("DEB"+num$(K))+'"))'
 Else
  FILTRE -= 'TRICCE'+mid$(CHIFFRES,K,1)+'<"'+evalue("DEB"+num$(K))+'"'
 Endif
 Gosub CHARGE_PREC
 If RETOUR : Break : Endif
Next K
[M:BLA2]NBLIG = MAXLIG
If NOL>0
 Dela 0,NOL [M:BLA2]NBLIG
 [M:BLA2]NBLIG -= NOL
Endif
Affzo [BLA2] 20
Return

