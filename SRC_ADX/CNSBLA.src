  When  1 : Filter [TMP] Where NUMREQ=REQUETE Order By Key CLE=TRICCE1 Desc
 Endcase
Endif
For [TMP]CLE(NBCLE) Where evalue(FILTRE) & evalue(FILDET)
 If NOL=0
  Raz MONTANT,CHARGE,PRODUI,ENGAGE,PREENG,BUDGET
  Raz QTEANA,QTEENG,QTEPRE,QTEBUD
  For [TMP]CLE
   Gosub CALCUL
  Next
  Gosub TOTAUX
  If sigma(1,NBCOL,abs(MONTANT(indcum)))<>0
   RETOUR = 1 : Break
  Endif
 Else
  NOL -= 1
  Gosub CHARGE
  If sigma(1,NBCOL,abs(MONTANT(indcum)))=0
   NOL += 1
  Endif
 Endif
Next
Filter [TMP]
Return

$TOTAL
Effzo [BLA2] 20
Filter [TMP] Where NUMREQ=REQUETE Order By Key CLE=FCY
SUITE  = 0
RETOUR = 0
NOL = 0
If DETSIT=2
 For [TMP]CLE(1)
  Gosub CHARGE
  NOL += 1
  If NOL>=MAXLIG : Break : Endif
 Next
 [M:BLA2]NBLIG = NOL
Else
 Gosub CHARGE
 [M:BLA2]NBLIG = 1
Endif
Affzo [BLA2] 20
Return

$CHARGE
Raz MONTANT,CHARGE,PRODUI,ENGAGE,PREENG,BUDGET
Raz QTEANA,QTEENG,QTEPRE,QTEBUD
For [TMP]CLE
 Gosub CALCUL
Next
Gosub TOTAUX
For I=1 To NIVEAU
 Assign "[M:BLA2]LIB"+num$(I)+"("+num$(NOL)+")" With evalue("[F:TMP]LIBCCE"+mid$(CHIFFRES,I,1))
 Assign "[M:BLA2]TRI"+num$(I)+"("+num$(NOL)+")" With evalue("[F:TMP]TRICCE"+mid$(CHIFFRES,I,1))
 If DETAIL & [M:EDA]TYP(I-1)<3
  SECTION = evalue("[F:TMP]DET"+mid$(CHIFFRES,I,1))
  Assign "[M:BLA2]COMPTE"+num$(I)+"("+num$(NOL)+")" With SECTION
  LIBSEC = evalue("[F:TMP]LIBCCE"+mid$(CHIFFRES,I,1))
  If [M:EDA]PYRSEC(I-1)<>""
   If [M:EDA]INTCOURT=2
    DESTRA = "SHOTRA"
   Else
    DESTRA = "DESTRA"
   Endif
   Case [M:EDA]TYP(I-1)
    When 1
     Call LECTEXTRA(LIBSEC,"GACCOUNT",DESTRA,[M:EDA]COA,SECTION) From ATEXTRA
    When 2
     Call LECTEXTRA(LIBSEC,"CACCE",DESTRA,[M:EDA]AXE(I-1),SECTION) From ATEXTRA
   Endcase
  Endif
  Assign "[M:BLA2]LIB"+num$(I)+"("+num$(NOL)+")" With LIBSEC
 Else
  Assign "[M:BLA2]COMPTE"+num$(I)+"("+num$(NOL)+")" With evalue("[F:TMP]CCE"+mid$(CHIFFRES,I,1))
 Endif
Next I
If DETSIT=2
 [M:BLA2]SITE(NOL) = [F:TMP]FCY
Endif
For COL=1 To NBCOL
 Assign "COL"+num$(COL)+"("+num$(NOL)+")" With MONTANT(COL)
Next COL
Return

##################################################
## Evaluation des colonnes
##################################################
$CALCUL
SNSBUD = 1
Filter [BLA]
Filter [BLQ]
Filter [BLM]
Filter [BUD]
Raz [F:BLA]
Raz [F:BLQ]
Raz [F:BLM]
Raz [F:BUD]
If [F:TMP]CLEN1 : Read [BLA]BLA1 = [F:TMP]CLEN1 : Endif
If [F:TMP]CLEN2 : Read [BLQ]BLQ1 = [F:TMP]CLEN2 : Endif
If [F:TMP]CLEN3 : Read [BLM]BLM1 = [F:TMP]CLEN3 : Endif
If [F:TMP]CLEN4
 Read [BUD]BUD1 = [F:TMP]CLEN4
 If !fstat
  Read [GAC]GAC0=[F:BUD]COA;[F:BUD]ACC
  If !fstat
   Read [CLS]CLS0=V_LEG;[F:GAC]CLSCOD
   If [F:CLS]SNSANA = 2 : SNSBUD = -1 : Endif
  Else
   fstat = 0
   If [F:GRY]PYM<>[F:BUD]COA | [F:GRY]GRU<>[F:BUD]ACC
    Read [F:GRY]GRY0 = [F:BUD]COA;[F:BUD]ACC;1
   Endif
   If !fstat
    Call LEC_COA([F:GRY]COA) From CPTLEC
    Call LEC_CLS([F:COA]LEGCLS,[F:GRY]CLSCOD) From CPTLEC
    If [F:CLS]SNSANA = 2 : SNSBUD = -1 : Endif
   Endif
  Endif
 Endif
Endif
For P=1 To NBPER
 PDEB = [F:TMP]PERSTR(P-1)-1
 PFIN = [F:TMP]PEREND(P-1)-1
 If PDEB>=0
  If DEVORG=DEVIMP
   CHARGE(P) += sum([F:BLA]DEB(PDEB..PFIN))
   PRODUI(P) += sum([F:BLA]CDT(PDEB..PFIN))
   ENGAGE(P) += sum([F:BLM]CMM(PDEB..PFIN))
   PREENG(P) += sum([F:BLM]CMMPRP(PDEB..PFIN))
  Else
   CHARGE(P) += sum([F:BLA]DEBLED(PDEB..PFIN))
   PRODUI(P) += sum([F:BLA]CDTLED(PDEB..PFIN))
   ENGAGE(P) += sum([F:BLM]CMMLED(PDEB..PFIN))
   PREENG(P) += sum([F:BLM]CMMPRPLED(PDEB..PFIN))
  Endif
  BUDGET(P) += sum([F:BUD]AMT(PDEB..PFIN)) * SNSBUD
  QTEANA(P) += sum([F:BLQ]QTY(PDEB..PFIN))
  QTEENG(P) += sum([F:BLQ]QTYCMM(PDEB..PFIN))
  QTEPRE(P) += sum([F:BLQ]QTYPRP(PDEB..PFIN))
  QTEBUD(P) += sum([F:BUD]QTY(PDEB..PFIN)) * SNSBUD
 Endif
Next P
Return

$TOTAUX
Call LECTURE("TCU",DEVIMP,"") From CONTOBJ
If DEVIMP<>DEVORG & DEVIMP<>DEVSOC
 For P=1 To NBPER
  CHARGE(P) = arr(CHARGE(P)*COURS,[F:TCU]CURRND)
  PRODUI(P) = arr(PRODUI(P)*COURS,[F:TCU]CURRND)
  ENGAGE(P) = arr(ENGAGE(P)*COURS,[F:TCU]CURRND)
  PREENG(P) = arr(PREENG(P)*COURS,[F:TCU]CURRND)
 Next P
Endif
If DEVIMP<>DEVBUD
 For P=1 To NBPER
  BUDGET(P) = arr(BUDGET(P)*COURBUD,[F:TCU]CURRND)
 Next P
Endif
If DIVISE<>0
 For P=1 To NBPER
  CHARGE(P) = arr(CHARGE(P)/DIVISE,[F:TCU]CURRND)
  PRODUI(P) = arr(PRODUI(P)/DIVISE,[F:TCU]CURRND)
  ENGAGE(P) = arr(ENGAGE(P)/DIVISE,[F:TCU]CURRND)
  PREENG(P) = arr(PREENG(P)/DIVISE,[F:TCU]CURRND)
  BUDGET(P) = arr(BUDGET(P)/DIVISE,[F:TCU]CURRND)
  QTEANA(P) = arr(QTEANA(P)/DIVISE,[F:TCU]CURRND)
  QTEENG(P) = arr(QTEENG(P)/DIVISE,[F:TCU]CURRND)
  QTEPRE(P) = arr(QTEPRE(P)/DIVISE,[F:TCU]CURRND)
  QTEBUD(P) = arr(QTEBUD(P)/DIVISE,[F:TCU]CURRND)
 Next P
Endif
For COL=1 To NBCOL
 P = PERCOL(COL)
 T = TYPCOL(COL)
 If T>27
  T -= 12
  SIGNE = -1
 Else
  SIGNE = +1
 Endif
 If (find(T,22,23,24) & BUDGET(P)=0) or (find(T,25,26,27) & QTEBUD(P)=0)
  MONTANT(COL) = 0
 Else
  Case T
   When  1 : MONTANT(COL) = CHARGE(P)
   When  2 : MONTANT(COL) = PRODUI(P)
   When  3 : MONTANT(COL) = CHARGE(P)-PRODUI(P)
   When  4 : MONTANT(COL) = PRODUI(P)-CHARGE(P)
   When  5 : MONTANT(COL) = SENS*ENGAGE(P)
   When  6 : MONTANT(COL) = SENS*PREENG(P)
   When  7 : MONTANT(COL) = SENS*(CHARGE(P)-PRODUI(P)+ENGAGE(P))
   When  8 : MONTANT(COL) = SENS*(CHARGE(P)-PRODUI(P)+ENGAGE(P)+PREENG(P))
   When  9 : MONTANT(COL) = BUDGET(P)
   When 10 : MONTANT(COL) = QTEANA(P)
   When 11 : MONTANT(COL) = QTEENG(P)
   When 12 : MONTANT(COL) = QTEPRE(P)
   When 13 : MONTANT(COL) = QTEANA(P)+QTEENG(P)
   When 14 : MONTANT(COL) = QTEANA(P)+QTEENG(P)+QTEPRE(P)
   When 15 : MONTANT(COL) = QTEBUD(P)
   When 16 : MONTANT(COL) = BUDGET(P)-(CHARGE(P)-PRODUI(P))
   When 17 : MONTANT(COL) = BUDGET(P)-(CHARGE(P)-PRODUI(P)+ENGAGE(P))
   When 18 : MONTANT(COL) = BUDGET(P)-(CHARGE(P)-PRODUI(P)+ENGAGE(P)+PREENG(P))
   When 19 : MONTANT(COL) = QTEBUD(P)-QTEANA(P)
   When 20 : MONTANT(COL) = QTEBUD(P)-(QTEANA(P)+QTEENG(P))
   When 21 : MONTANT(COL) = QTEBUD(P)-(QTEANA(P)+QTEENG(P)+QTEPRE(P))
   When 22 : MONTANT(COL) = ar2(100*(BUDGET(P)-(CHARGE(P)-PRODUI(P)))/BUDGET(P))
   When 23 : MONTANT(COL) = ar2(100*(BUDGET(P)-(CHARGE(P)-PRODUI(P)+ENGAGE(P)))/BUDGET(P))
   When 24 : MONTANT(COL) = ar2(100*(BUDGET(P)-(CHARGE(P)-PRODUI(P)+ENGAGE(P)+PREENG(P)))/BUDGET(P))
   When 25 : MONTANT(COL) = ar2(100*(QTEBUD(P)-QTEANA(P))/QTEBUD(P))
   When 26 : MONTANT(COL) = ar2(100*(QTEBUD(P)-(QTEANA(P)+QTEENG(P)))/QTEBUD(P))
   When 27 : MONTANT(COL) = ar2(100*(QTEBUD(P)-(QTEANA(P)+QTEENG(P)+QTEPRE(P)))/QTEBUD(P))
  Endcase
 Endif
 MONTANT(COL) *= SIGNE
Next COL
Return

######################################################################################
## Bouton Menu Export Global
######################################################################################
$EXPORT_XLS

##NEW
#* X3-84387
Local  Integer  OKK     (1..500)
Local  Integer  NTYPTYP (1..dim(OKK))
Local  Decimal  NLNGTYP (1..dim(OKK))
Local  Integer  NBRAMZ
Local Char      SAVXCA(80)

Local Char      AMZCODZON(255) (1..dim(OKK))
Local Tinyint   AMZLIEN(255)   (1..dim(OKK))
Local Decimal   AMZLONG        (1..dim(OKK))
Local Integer   XNBRAMZ  : [L]XNBRAMZ=0
Local  Integer  WIND_NBRAMZ
#* X3-84387 END

Local Char    FICCLI(GDIMFIC) , FICSRV(GDIMFIC) , URL(GDIMFIC)
Local Integer I , J , K , ER , ZNBLIG, ERSTA, EXPCLI
Local Char CNSCOD(GLONACN), INTITULE(250)
If !clalev([F:AFC]) : Local File AFONCTION [AFC] : Endif
If !clalev([F:AMZ]) : Local File AMSKZON  [AMZ] : Endif
If !clalev([F:ACT]) : Local File ACTION   [ACT] : Endif
If !clalev([F:ACN]) : Local File ACONSULT [ACN] : Endif
If !clalev([F:ATY]) : Local File ATYPE    [ATY] : Endif
If !clalev([F:ATX]) : Local File ATEXTE   [ATX] : Endif

If BOUT="B"     # CSV export
 EXPCLI= 1
Elsif BOUT="C"  # Excel export
 EXPCLI= 2
Endif

CNSCOD = "BLA"
Call TEMPON(mess(6,100,1)) From GESECRAN   :  # Opération en cours ...

##Creation file csv (ex: name = Fnnnnnnnnnnnn_BLA.csv)
##Creation file xsl (ex: name = Fnnnnnnnnnnnn_BLA.xls)
Gosub SET_INIVAR From ALHE
FICCLI = [L]CNSCOD+"."+[L]EXT
Call SET_FICNAM(FICCLI,FICSRV,URL) From ORDSYS
Onerrgo ERREUR From GCONSULT

Openo FICSRV,0 Using [ST_]
If [L]EXPCLI=1  # CSV export
 Iomode adxifs IFS Using [ST_]
Else            # Excel export
 Iomode adxifs chr$(9) Using [ST_] # pour avoir une tabulation al aplace de ; ou ,
Endif
Iomode adxirs IRS Using [ST_]
Iomode adxium IUM Using [ST_]

## Recherche bloc de NBLIG
ZNBLIG = -1
Read [AMZ]CODE =NOMMSK(1);"NBLIG"
If !fstat
 ZNBLIG = [AMZ]NUMBLOC
Endif
If ZNBLIG=-1 : Return : Endif

## Entetes des champs
Gosub PREMIER
For [AMZ]CODZON Where CODMSK=NOMMSK(1) & [AMZ]SAIAFF<=2  & [AMZ]NUMBLOC = ZNBLIG & [AMZ]CODZON<>"NBLIG"
  #*X3-84387
  Gosub CTL_AMZ From GCONSULT
  [L]XNBRAMZ+=1
  # X3-84387  K = func AFNC.ACTIV([F:AMZ]CODACT) : # mb 13.8.9
  # X3-84387  K *= evalue("dim([M:"+ABMSK(1)+"]"+[F:AMZ]CODZON+")")>0 : # mb 13.8.9
  If K
    If [L]EXPCLI=1  # CSV
      Wrseq '"'+ func GCONSULT.INTIT_XLS([F:AMZ]INTIT,[F:AMZ]INTEVAL) + '"'; Using [ST_]
    Else            # XLS
      Wrseq '"'+ [AMZ]CODZON + '"'; Using [ST_]
    Endif
  Endif
Next
If [L]EXPCLI<>1 : Wrseq '"'+ "&&&" + '"'; Using [ST_] : Endif
Wrseq Using [ST_]

Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2

########
$LEC_XLS

##NEW X3-84387
## Ecriture Ecran en cours
For I=0 To evalue("[M:"+ABMSK(1)+"]NBLIG-1")
  Raz  [L]NBRAMZ

  For XK=1 To XNBRAMZ
    ##
    Raz   [F:AMZ]
    [F:AMZ]CODZON = [L]AMZCODZON(XK)
    [F:AMZ]LONG   = [L]AMZLONG(XK)
    [F:AMZ]LIEN   = [L]AMZLIEN(XK)
    ##
    [L]NBRAMZ += 1

    If [L]OKK([L]NBRAMZ)
      Case NTYPTYP([L]NBRAMZ)
        When 1,2,3
          Wrseq evalue("[M:"+ABMSK(1)+"]"+[F:AMZ]CODZON+"(I)") ; Using [ST_]
        When 4,5,6
          If [L]EXPCLI=1   # CSV
            # We have to keep all decimals also for export in CSV format
            If [F:AMZ]LONG>0
              WLNG = num$([F:AMZ]LONG)
            Elsif NLNGTYP([L]NBRAMZ)>0
              WLNG = num$(NLNGTYP([L]NBRAMZ))
            Else
              WLNG="15.9"
            Endif
            If instr(1,WLNG,".")=0 : WLNG += ".9" : Endif
              GBIDC1 = format$("N:"+WLNG,evalue("[M:"+ABMSK(1)+"]"+[F:AMZ]CODZON+"(I)"))
              GBIDC1 = ctrans(GBIDC1," ","")
              #end 121957
            Else  # XLS
              #  Pour conserver toutes les décimales dans les données exportées en Excel      CC : 11/02/2013 Bug 87168
              #  C'est le format de la cellule Excel qui tronquera
              SAVXCA=adxsca    :# On met le séparateur de millier à " " bug 63184
              adxsca = left$(adxsca,2)+" "+right$(adxsca,4)
              GBIDC1=vireblc(format$("Nz3:15.9",evalue("[M:"+ABMSK(1)+"]"+[F:AMZ]CODZON+"(I)")),4)
              adxsca=SAVXCA
            Endif
             Wrseq GBIDC1 ; Using [ST_]
        When 7
          GBIDC1 = evalue("[M:"+ABMSK(1)+"]"+[F:AMZ]CODZON+"(I)")
          Gosub EVMODZ From GCONSULT
          If  EXPCLI<>1 & instr(1,GBIDC1,chr$(9))
            Local Integer III
            III=instr(1,GBIDC1,chr$(9))
            While III>0
              GBIDC1= left$(GBIDC1,III-1)-right$(GBIDC1,III+1)
              III = instr(1,GBIDC1,chr$(9))
            Wend
          Endif
          If EXPCLI = 2  # XLS
            Wrseq '"'+GBIDC1+'"'; Using [ST_]
          Else
            If TADDEGAL=1
              Wrseq  '="'+GBIDC1+'"'; Using [ST_]
            Else
              Wrseq '"'+GBIDC1+'"'; Using [ST_]
            Endif
          Endif
        When 8
          Wrseq format$("D:"+GFMDAT4,evalue("[M:"+ABMSK(1)+"]"+[F:AMZ]CODZON+"(I)")); Using [ST_]
        Endcase

        If find([AMZ]LIEN,2,3)>0
          Wrseq '"'+ evalue("[M:"+ABMSK(1)+"]"+"Z"+[F:AMZ]CODZON+"(I)") + '"'; Using [ST_] : # Intitulé
        Endif
      Endif
    Next AMZ
    Wrseq Using [ST_]
  Next I


Onerrgo ERREUR From GCONSULT

If SUITE<>0
  Gosub SUITE
  #* X3-84387 : jira X3-67273
  # si apres charge page suivante on a 0 dans nblig c'est que c'est fin du fichier
  If evalue("[M:"+ABMSK(1)+"]NBLIG") <> 0
    Goto LEC_XLS
  Endif
Endif

Setmode
Openo Using [ST_]
Onerrgo

If !ERSTA
  Case EXPCLI
    When 1 : # CSV
      Call OPEN_HTTP(URL) From ORDSYS
    When 2 : #  Excel
      Gosub EXPORT_EXCEL From GCONSULT
  Endcase
Endif

Gosub PREMIER
Call TEMPOFF From GESECRAN
Return

####* X3-84387 replaced by LEC_XLS (NEW)###############################################################
$LEC_XLS_OLD
## Ecriture Ecran en cours
For I=0 To evalue("[M:"+ABMSK(1)+"]NBLIG-1")
 For [AMZ]CODZON Where CODMSK=NOMMSK(1) & [AMZ]SAIAFF<=2  & [AMZ]NUMBLOC = ZNBLIG & [AMZ]CODZON<>"NBLIG"
  K = func AFNC.ACTIV([F:AMZ]CODACT) : # mb 13.8.9
  K *= evalue("dim([M:"+ABMSK(1)+"]"+[F:AMZ]CODZON+")")>0 : # mb 13.8.9
  If K
   Read [F:ATY]CODTYP = [F:AMZ]CODTYP
   If !fstat
    Case [F:ATY]TYPTYP
     When 1,2,3
      Wrseq evalue("[M:"+ABMSK(1)+"]"+[F:AMZ]CODZON+"(I)") ; Using [ST_]
     When 4,5,6
      GBIDC1 = format$("N:12.2",evalue("[M:"+ABMSK(1)+"]"+[F:AMZ]CODZON+"(I)"))
      GBIDC1 = ctrans(GBIDC1,".",",")
      GBIDC1 = ctrans(GBIDC1," ","")
      Wrseq GBIDC1 ; Using [ST_]
     When 7
      If EXPCLI = 2  # XLS
       Wrseq evalue("[M:"+ABMSK(1)+"]"+[F:AMZ]CODZON+"(I)"); Using [ST_]
      Else
       Wrseq '"'+evalue("[M:"+ABMSK(1)+"]"+[F:AMZ]CODZON+"(I)")+'"'; Using [ST_]
      Endif
     When 8
      Wrseq evalue("[M:"+ABMSK(1)+"]"+[F:AMZ]CODZON+"(I)"); Using [ST_]
    Endcase
   Endif
  Endif
 Next AMZ
 Wrseq Using [ST_]
Next I

Onerrgo ERREUR From GCONSULT
If SUITE<>0
 Gosub SUITE
 Goto LEC_XLS
Endif
Setmode
Openo Using [ST_]
Onerrgo
If !ERSTA
 Case EXPCLI
  When 1 : # CSV
   Call OPEN_HTTP(URL) From ORDSYS
  When 2 : #  Excel
   Gosub EXPORT_EXCEL From GCONSULT
 Endcase
Endif
Gosub PREMIER
Call TEMPOFF From GESECRAN
Return

######################################################################################
## Ecran CONSBLA2 (Tunnels)
######################################################################################
Subprog IB_NBLIG
Raz GBOUT1 , GBOUT2 , GBOUT3 , GBOUT4 , GBOUT5 , GBOUT6
Raz GBOUT7 , GBOUT8 , GBOUT9 , GBOUT10 , GBOUT11 , GBOUT12
Local Integer I , NOL , OKENG
Local Char    COMPTE(30)
NOL = nolign-1
For I=1 To 12
 If [M]TUNNEL(I-1)
  COMPTE = evalue("[M]COMPTE"+num$(I)+"("+num$(NOL)+")")
  Assign "GBOUT"+num$(I) With [M]TUNLIB(I-1)-COMPTE
 Endif
Next I
OKENG = 0
For I=1 To [M:BLA1]NIVEAU
 If ([M:EDA]TYP(I-1)=1 or [M:EDA]TYP(I-1)=2) & ([M:EDA]PYRSEC(I-1)="" or [M:BLA1]DETAIL=2)
  OKENG = 1 : Break
 Endif
Next I
If !OKENG or [M]TUNNEL(13)=0 : Raz GBOUT13 : Endif : # Engagements
If !OKENG or [M]TUNNEL(14)=0 : Raz GBOUT14 : Endif : # Pré-engagements
End

Subprog B1_NBLIG
Local Integer T : T = 1
Goto TUNNEL

Subprog B2_NBLIG
Local Integer T : T = 2
Goto TUNNEL

Subprog B3_NBLIG
Local Integer T : T = 3
Goto TUNNEL

Subprog B4_NBLIG
Local Integer T : T = 4
Goto TUNNEL

Subprog B5_NBLIG
Local Integer T : T = 5
Goto TUNNEL

Subprog B6_NBLIG
Local Integer T : T = 6
Goto TUNNEL

Subprog B7_NBLIG
Local Integer T : T = 7
Goto TUNNEL

Subprog B8_NBLIG
Local Integer T : T = 8
Goto TUNNEL

Subprog B9_NBLIG
Local Integer T : T = 9
Goto TUNNEL

Subprog B10_NBLIG
Local Integer T : T = 10
Goto TUNNEL

Subprog B11_NBLIG
Local Integer T : T = 11
Goto TUNNEL

Subprog B12_NBLIG
Local Integer T : T = 12
Goto TUNNEL

$TUNNEL
Local Integer NOL
Local Char    PARAM(250)(1..10) , FILTANA(250)
Local Char    CONSULT(GLONACN) , SITE(GLONFCY) , COMPTE(30)
Local Date    DATDEB , DATFIN
Local Char    PLAN(GLONCOA) , AXE(GLONDIE)(0..9) , VALANA(50)
Local Integer I , J , K
Local Integer OKFILT
NOL = nolign-1
If [M:BLA2]SITE(NOL)<>""
 SITE = [M:BLA2]SITE(NOL)
Elsif [M:BLA1]FCYDEB=[M:BLA1]FCYFIN
 SITE = [M:BLA1]FCYDEB
Else
 SITE = ""
Endif
COMPTE = evalue("[M]COMPTE"+num$(T)+"("+num$(NOL)+")")
DATDEB = [M:BLA1]DATDEB1
DATFIN = [M:BLA1]DATFIN1
If [M:BLA1]DATDEB2<>[0/0/0]
 DATDEB = min(DATDEB,[M:BLA1]DATDEB2)
 DATFIN = max(DATFIN,[M:BLA1]DATFIN2)
 If [M:BLA1]DATDEB3<>[0/0/0]
  DATDEB = min(DATDEB,[M:BLA1]DATDEB3)
  DATFIN = max(DATFIN,[M:BLA1]DATFIN3)
 Endif
Endif
Case [M]TUNNEL(T-1)
 When 1
  CONSULT  = "NAT"
  PARAM(1) = [M:BLA1]CPY       : # Société
  PARAM(2) = SITE              : # Site
  PARAM(3) = num$([M]TUNLED)   : # Type de référentiel
  PARAM(4) = COMPTE            : # Compte
  PARAM(5) = ""                : # Tiers
  PARAM(6) = ""                : # Collectif
  PARAM(7) = DATDEB            : # Date début
  PARAM(8) = DATFIN            : # Date fin
  #PARAM(9) = [M]TUNDEV         : # Devise
  PARAM(9) = [M:EDA]DEVORG     : # Devise
  Gosub FILTANA
  PARAM(10) = FILTANA           : # Filtre compte/sections
 When 2
  CONSULT  = "SEC"
  PARAM(1) = [M:BLA1]CPY       : # Société
  PARAM(2) = SITE              : # Site
  PARAM(3) = num$([M]TUNLED)   : # Type de référentiel
  PARAM(4) = [M]TUNAXE(T-1)    : # Axe ana
  PARAM(5) = COMPTE            : # Section ana
  PARAM(6) = DATDEB            : # Date début
  PARAM(7) = DATFIN            : # Date fin
  #Dmd 65319
  #PARAM(8) = [M]TUNDEV         : # Devise
  PARAM(8) = [M:EDA]DEVORG     : # Devise
  Gosub FILTANA
  PARAM(9) = FILTANA           : # Filtre compte/sections
Endcase
Call GCONSULT(CONSULT,"",PARAM) From GCONSULT
End

$FILTANA
Local Char PREMSITE(GLONFCY)
Call LECTURE("CPY",[M:BLA1]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG=2
 OKFILT = 1
 Read [GCM]GCM0 = [F:CPY]ACM
 Read [LED]LED0 = [F:GCM]LED([M]TUNLED-1)
Else
 OKFILT = 0
 PREMSITE = ""
 For [FGR]FGR0 Where CPY=[M:BLA1]CPY
  If [F:FGR]FCY=GFCYDEF
   PREMSITE = GFCYDEF
  Elsif PREMSITE=""
   PREMSITE = [F:FGR]FCY
  Endif
  Read [CPY]CPY0 = [F:FGR]CPY
  Read [GCM]GCM0 = [F:CPY]ACM
  Read [LED]LED0 = [F:GCM]LED([M]TUNLED-1)
  If OKFILT=0
   PLAN = [F:LED]COA
   For I=0 To [F:LED]DIENBR-1
    AXE(I) = [F:LED]DIE(I)
   Next I
   OKFILT = 1
  Else
   If [F:LED]COA<>PLAN : OKFILT = 0 : Break : Endif
   For I=0 To [F:LED]DIENBR-1
    If [F:LED]DIE(I)<>AXE(I)
     OKFILT = 0 : Break 2
    Endif
   Next I
  Endif
 Next
Endif
If OKFILT
 FILTANA = ""
 For I=1 To [M:BLA1]NIVEAU
  If I<>T & [M:EDA]PYRSEC(I-1)=""
   VALANA = evalue('[M:BLA2]COMPTE'+num$(I)+'('+num$(NOL)+')')
   If VALANA="<"+mess(23,147,1)+">" : VALANA = "" : Endif
   Case [M:EDA]TYP(I-1)
    When 1
     If FILTANA<>"" : FILTANA -= '&' : Endif
     FILTANA -= '[DAA]ACC="'+VALANA+'"'
    When 2
     J = find([M:EDA]AXE(I-1),[F:LED]DIE)
     If J
      If FILTANA<>"" : FILTANA -= '&' : Endif
      FILTANA -= '[DAA]CCE('+num$(J-1)+')="'+VALANA+'"'
     Endif
    When 3
     If FILTANA<>"" : FILTANA -= '&' : Endif
     FILTANA -= '[DAA]BPR="'+VALANA+'"'
   Endcase
  Elsif I<>T & [M:BLA1]DETAIL=2 & [M:EDA]PYRSEC(I-1)<>""
   VALANA = evalue('[M:BLA2]COMPTE'+num$(I)+'('+num$(NOL)+')')
   If VALANA="<"+mess(23,147,1)+">" : VALANA = "" : Endif
   Case [M:EDA]TYP(I-1)
    When 1
     If FILTANA<>"" : FILTANA -= '&' : Endif
     FILTANA -= '[DAA]ACC="'+VALANA+'"'
    When 2
     J = find([M:EDA]AXE(I-1),[F:LED]DIE)
     If J
      If FILTANA<>"" : FILTANA -= '&' : Endif
      FILTANA -= '[DAA]CCE('+num$(J-1)+')="'+VALANA+'"'
     Endif
   Endcase
  Endif
 Next I
Else
 PARAM(2) = PREMSITE
Endif
Return


#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(1)<>2 End Endif

Call VALGTC(APPLI,"BLA") From SUBGTC

End

