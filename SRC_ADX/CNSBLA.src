#<AdxTL>@(#)9.0.0.0 $Revision$
# Issue X3-84387 - 2018-04-16 by MDJ : PERF EXPORT CSV_XLS

GFONCTION="EDITBLA"
Raz GTUNCPT, GPILNAV
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"EDITBLA","PRTBLA","",1,"") From GTRAITE
End

Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"FCNSBLA","CNSBLA","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"    : Gosub DEBUT
 When "SETBOUT"  : Gosub SETBOUT
 When "BOUTON"   : Gosub BOUTON
 When "SUI"      : Gosub SUITE
 When "PRE"      : Gosub RETOUR
 When "FIR"      : Gosub PREMIER
 When "LAS"      : Gosub DERNIER
 When "EDI"      : Local Integer CALCUL : CALCUL = REQUETE
                 : Gosub IMPRIME From PRTBLA
 When "MEN"      : If BOUT="B" | BOUT="C" : Gosub EXPORT_XLS : Endif
Endcase
Return

$DEBUT
Local Integer MAXCOL : MAXCOL = 10 : # Maximum de colonnes de valeur
Local Integer MAXTRI : MAXTRI = 12 : # Maximum de comptes/sections
Local Integer MAXPER : MAXPER = 3  : # Maximum de périodes
Local Integer LONCPT
Local Integer REQUETE , NBGRP , MAXLIG
Local Integer NOL
Local Char    DEB1(30) , DEB2(30) , DEB3(30) , DEB4(30)
Local Char    DEB5(30) , DEB6(30) , DEB7(30) , DEB8(30)
Local Char    DEB9(30) , DEB10(30) , DEB11(30) , DEB12(30)
Local Char    DEBFCY(GLONFCY)
Local Integer COL , NBCOL , TYPCOL(1..MAXCOL) , PERCOL(1..MAXCOL)
Local Decimal MONTANT(1..MAXCOL)
Local Integer PDEB , PFIN
Local Integer TYPTRI(1..MAXTRI) , PYRLEV(1..MAXTRI)
Local Char    AXE(GLONDIE)(1..MAXTRI) , PYRAM(GLONGYM)(1..MAXTRI)
Local Char    INTIT(GLONDES)
Local Integer NBPER
Local Date    DDEB(1..MAXPER) , DFIN(1..MAXPER)
Local Decimal CHARGE(1..MAXPER) , PRODUI(1..MAXPER)
Local Decimal ENGAGE(1..MAXPER) , PREENG(1..MAXPER) , BUDGET(1..MAXPER)
Local Decimal QTEANA(1..MAXPER) , QTEENG(1..MAXPER) , QTEPRE(1..MAXPER) , QTEBUD(1..MAXPER)
Local Integer SUITE , RETOUR
Local Char    DEVORG(GLONCUR) , DEVIMP(GLONCUR) , DEVSOC(GLONCUR) , DEVBUD(GLONCUR)
Local Decimal COURS , COURBUD , DIVISE
Local Integer DETSIT , NBCLE
Local Integer SPSTAT , SENS , SIGNE , NIVEAU
Local Char    PLAN(GLONCOA)
Local Integer I , J , K , P , T
Local Integer DETAIL , RELIT
Local Char    FILDET(255) , LIBDET(255)(1..2) , LIBSEC(50) , SECTION(GLONCCE) , DESTRA(10)
Local Char    SAVCLE(GLONCCE)(1..MAXTRI)
Local Integer SAVSUI , SAVRET , SAVLIG
Local Char    CHIFFRES(20)
Local Integer SNSBUD
Local Char    V_LEG(GLONADI)

If clalev([F:TMP])=0 : Local File TMPBLA     [TMP] : Endif
If clalev([F:BLA])=0 : Local File BALANA     [BLA] : Endif
If clalev([F:BLQ])=0 : Local File BLAQTY     [BLQ] : Endif
If clalev([F:BLM])=0 : Local File BLACMM     [BLM] : Endif
If clalev([F:BUD])=0 : Local File BUD        [BUD] : Endif
If clalev([F:BUP])=0 : Local File BUDPAR     [BUP] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:CLS])=0 : Local File GACCCLS    [CLS] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif
If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif

CHIFFRES = "123456789ABC"
LONCPT   = max(GLONGAC,GLONCCE,GLONGRY,GLONCYR,GLONBPR)
MAXLIG   = dim([M:BLA2]COL1)
REQUETE  = val(PARAM(1))
NBGRP    = [M:EDA]NBAXE
NBCOL    = [M:EDA]NBCOL
NBPER    = [M:EDA]NBPER
For I=1 To NBPER
 DDEB(I) = [M:EDA]DATDEB(I-1)
 DFIN(I) = [M:EDA]DATFIN(I-1)
Next I
For I=1 To NBCOL
 TYPCOL(I) = [M:EDA]TYPCOL(I-1)-1
 PERCOL(I) = [M:EDA]PERCOL(I-1)
Next I
For I=1 To NBGRP
 TYPTRI(I) = [M:EDA]TYP(I-1)
 AXE(I)    = [M:EDA]AXE(I-1)
 PYRAM(I)  = [M:EDA]PYRSEC(I-1)
 PYRLEV(I) = [M:EDA]NIVSEC(I-1)
Next I
DEVORG  = [M:EDA]DEVORG
DEVIMP  = [M:EDA]DEVIMP
If [M:EDA]BUD<>""
 Read [BUP]BUP0 = [M:EDA]BUD
 DEVBUD = [F:BUP]CUR
Else
 DEVBUD  = DEVIMP
Endif
COURS   = [M:EDA]COURANA
COURBUD = [M:EDA]COURBUD
DIVISE  = [M:EDA]DIVISE
If [M:EDA]SENS=1
 SENS = +1
Else
 SENS = -1
Endif
DETSIT = [M:EDA]DETSIT
Read [CPY]CPY0 = [M:EDA]CPY
If [F:CPY]CPYLEGFLG<>2
 Filter [FGR] Where CPY=[M:EDA]CPY
 Read [FGR]FGR0 First
 Filter [FGR]
 Read [FCY]FCY0 = [F:FGR]FCY
 Read [CPY]CPY0 = [F:FCY]LEGCPY
Endif
Read [GCM]GCM0 = [F:CPY]ACM
DEVSOC = [F:GCM]CUR([M:EDA]LEDTYP-1)
Read [LED]LED0 = [F:GCM]LED([M:EDA]LEDTYP-1)
PLAN = [F:LED]COA
V_LEG = [F:CPY]LEG

Raz [M:BLA1]
[M:BLA1]CPY    = [M:EDA]CPY
[M:BLA1]FCYDEB = [M:EDA]FCYDEB
[M:BLA1]FCYFIN = [M:EDA]FCYFIN
For I=1 To NBPER
 Assign "[M:BLA1]DATDEB"+num$(I) With [M:EDA]DATDEB(I-1)
 Assign "[M:BLA1]DATFIN"+num$(I) With [M:EDA]DATFIN(I-1)
Next I
[M:BLA1]CUR = DEVIMP

# Pour permettre l'export global des données, on gère des intitulés évalués dans les écrans
# L'export gère en entête de colonne uniquement les intitulés des zones du bloc tableau dans le masque
# Ces intitulés sont alimentés par [M:BLA2]INTCOL, [M:BLA2]INTCOMPTE et [M:BLA2]INTLIB
For I=1 To NBCOL
 INTIT = mess(TYPCOL(I)+1,637,1)
 If NBPER>1
  INTIT -= "(P"+num$(PERCOL(I))+")"
 Endif
 Case I
  When  1 : Titcol [M:BLA2]NBLIG INTIT For COL1
  When  2 : Titcol [M:BLA2]NBLIG INTIT For COL2
  When  3 : Titcol [M:BLA2]NBLIG INTIT For COL3
  When  4 : Titcol [M:BLA2]NBLIG INTIT For COL4
  When  5 : Titcol [M:BLA2]NBLIG INTIT For COL5
  When  6 : Titcol [M:BLA2]NBLIG INTIT For COL6
  When  7 : Titcol [M:BLA2]NBLIG INTIT For COL7
  When  8 : Titcol [M:BLA2]NBLIG INTIT For COL8
  When  9 : Titcol [M:BLA2]NBLIG INTIT For COL9
  When 10 : Titcol [M:BLA2]NBLIG INTIT For COL10
 Endcase
 If dim([M:BLA2]INTCOL)>I-1 : [M:BLA2]INTCOL(I-1) = INTIT : Endif

Next I
Call LECTURE("TCU",DEVIMP,"") From CONTOBJ
For I=1 To NBCOL
 Case TYPCOL(I)
  When 0
   FMT = "-N:13.2"
  When 1,2,3,4,5,6,7,8,9,16,17,18,28,29,30
   If [F:TCU]DECNBR=0
    FMT = "NP3z:13#"
   Else
    FMT = "NP3z:13."+num$([F:TCU]DECNBR)
   Endif
  When 10,11,12,13,14,15,19,20,21,31,32,33
   FMT = "NP3z:9.2"
  When 22,23,24,25,26,27,34,35,36,37,38,39,40
   FMT = "NPz:6.2"
 Endcase
 Case I
  When  1 : Chgfmt [BLA2]COL1  With FMT
  When  2 : Chgfmt [BLA2]COL2  With FMT
  When  3 : Chgfmt [BLA2]COL3  With FMT
  When  4 : Chgfmt [BLA2]COL4  With FMT
  When  5 : Chgfmt [BLA2]COL5  With FMT
  When  6 : Chgfmt [BLA2]COL6  With FMT
  When  7 : Chgfmt [BLA2]COL7  With FMT
  When  8 : Chgfmt [BLA2]COL8  With FMT
  When  9 : Chgfmt [BLA2]COL9  With FMT
  When 10 : Chgfmt [BLA2]COL10 With FMT
 Endcase
Next I
For I=NBCOL+1 To MAXCOL
 Case I
  When  1 : Chgfmt [BLA2]COL1  With "-N:13.2"
  When  2 : Chgfmt [BLA2]COL2  With "-N:13.2"
  When  3 : Chgfmt [BLA2]COL3  With "-N:13.2"
  When  4 : Chgfmt [BLA2]COL4  With "-N:13.2"
  When  5 : Chgfmt [BLA2]COL5  With "-N:13.2"
  When  6 : Chgfmt [BLA2]COL6  With "-N:13.2"
  When  7 : Chgfmt [BLA2]COL7  With "-N:13.2"
  When  8 : Chgfmt [BLA2]COL8  With "-N:13.2"
  When  9 : Chgfmt [BLA2]COL9  With "-N:13.2"
  When 10 : Chgfmt [BLA2]COL10 With "-N:13.2"
 Endcase
Next I
NIVEAU = NBGRP
FILDET = "1=1"
Affzo [BLA1]

$REMPLIT
DETAIL = ([M:BLA1]DETAIL=2)
[M:BLA2]TUNLED = [M:EDA]LEDTYP
[M:BLA2]TUNDEV = DEVIMP
If DETSIT=2
 NBCLE = NIVEAU+1
 Chgfmt [M:BLA2]SITE With "KP:5X"
Else
 NBCLE = NIVEAU
 Chgfmt [M:BLA2]SITE With "-K:5X"
Endif
Raz [M:BLA2]TUNNEL
For I=0 To [M:EDA]NBCOL-1
 Case [M:EDA]TYPCOL(I)
  When 7,13
   [M:BLA2]TUNNEL(13) = 1 : # Engagements
  When 6,12
   [M:BLA2]TUNNEL(14) = 1 : # Pré-engagements
 Endcase
Next I
For I=1 To NIVEAU
 Case I
  When  1 : Chgfmt [BLA2]COMPTE1  With "KP:"+num$(LONCPT)+"X" : Chgfmt [BLA2]LIB1  With "KP:"+num$(GLONDES)+"X"
  When  2 : Chgfmt [BLA2]COMPTE2  With "KP:"+num$(LONCPT)+"X" : Chgfmt [BLA2]LIB2  With "KP:"+num$(GLONDES)+"X"
  When  3 : Chgfmt [BLA2]COMPTE3  With "KP:"+num$(LONCPT)+"X" : Chgfmt [BLA2]LIB3  With "KP:"+num$(GLONDES)+"X"
  When  4 : Chgfmt [BLA2]COMPTE4  With "KP:"+num$(LONCPT)+"X" : Chgfmt [BLA2]LIB4  With "KP:"+num$(GLONDES)+"X"
  When  5 : Chgfmt [BLA2]COMPTE5  With "KP:"+num$(LONCPT)+"X" : Chgfmt [BLA2]LIB5  With "KP:"+num$(GLONDES)+"X"
  When  6 : Chgfmt [BLA2]COMPTE6  With "KP:"+num$(LONCPT)+"X" : Chgfmt [BLA2]LIB6  With "KP:"+num$(GLONDES)+"X"
  When  7 : Chgfmt [BLA2]COMPTE7  With "KP:"+num$(LONCPT)+"X" : Chgfmt [BLA2]LIB7  With "KP:"+num$(GLONDES)+"X"
  When  8 : Chgfmt [BLA2]COMPTE8  With "KP:"+num$(LONCPT)+"X" : Chgfmt [BLA2]LIB8  With "KP:"+num$(GLONDES)+"X"
  When  9 : Chgfmt [BLA2]COMPTE9  With "KP:"+num$(LONCPT)+"X" : Chgfmt [BLA2]LIB9  With "KP:"+num$(GLONDES)+"X"
  When 10 : Chgfmt [BLA2]COMPTE10 With "KP:"+num$(LONCPT)+"X" : Chgfmt [BLA2]LIB10 With "KP:"+num$(GLONDES)+"X"
  When 11 : Chgfmt [BLA2]COMPTE11 With "KP:"+num$(LONCPT)+"X" : Chgfmt [BLA2]LIB11 With "KP:"+num$(GLONDES)+"X"
  When 12 : Chgfmt [BLA2]COMPTE12 With "KP:"+num$(LONCPT)+"X" : Chgfmt [BLA2]LIB12 With "KP:"+num$(GLONDES)+"X"
 Endcase
 Case TYPTRI(I)
  When 1
   If PYRAM(I)<>"" & !DETAIL
    Call LECTEXTRA(INTIT,"GACCPYM","SHOTRA",PYRAM(I),"") From ATEXTRA
    If INTIT=""
     Call LECTEXTRA(INTIT,"GACCPYM","DESTRA",PYRAM(I),"") From ATEXTRA
    Endif
    INTIT -= "("+num$(PYRLEV(I))+")"
   Else
    Call LECTEXTRA(INTIT,"GCOA","COLHEA",PLAN,"") From ATEXTRA
    [M:BLA2]TUNNEL(I-1) = 1
    [M:BLA2]TUNAXE(I-1) = PLAN
    [M:BLA2]TUNLIB(I-1) = INTIT
   Endif
  When 2
   If PYRAM(I)<>"" & !DETAIL
    Call LECTEXTRA(INTIT,"GCCEPYM","SHOTRA",PYRAM(I),"") From ATEXTRA
    If INTIT=""
     Call LECTEXTRA(INTIT,"GCCEPYM","DESTRA",PYRAM(I),"") From ATEXTRA
    Endif
    INTIT -= "("+num$(PYRLEV(I))+")"
   Else
    Call LECTEXTRA(INTIT,"GDIE","COLHEA",AXE(I),"") From ATEXTRA
    [M:BLA2]TUNNEL(I-1) = 2
    [M:BLA2]TUNAXE(I-1) = AXE(I)
    [M:BLA2]TUNLIB(I-1) = INTIT
   Endif
  When 3
   INTIT = mess(31,105,1) : # Tiers
 Endcase
 Case I
  When  1 : Titcol [M:BLA2]NBLIG INTIT For COMPTE1  : If varmode([M:BLA2]LIB1)<3  : Titcol [M:BLA2]NBLIG INTIT For LIB1  : Endif
  When  2 : Titcol [M:BLA2]NBLIG INTIT For COMPTE2  : If varmode([M:BLA2]LIB2)<3  : Titcol [M:BLA2]NBLIG INTIT For LIB2  : Endif
  When  3 : Titcol [M:BLA2]NBLIG INTIT For COMPTE3  : If varmode([M:BLA2]LIB3)<3  : Titcol [M:BLA2]NBLIG INTIT For LIB3  : Endif
  When  4 : Titcol [M:BLA2]NBLIG INTIT For COMPTE4  : If varmode([M:BLA2]LIB4)<3  : Titcol [M:BLA2]NBLIG INTIT For LIB4  : Endif
  When  5 : Titcol [M:BLA2]NBLIG INTIT For COMPTE5  : If varmode([M:BLA2]LIB5)<3  : Titcol [M:BLA2]NBLIG INTIT For LIB5  : Endif
  When  6 : Titcol [M:BLA2]NBLIG INTIT For COMPTE6  : If varmode([M:BLA2]LIB6)<3  : Titcol [M:BLA2]NBLIG INTIT For LIB6  : Endif
  When  7 : Titcol [M:BLA2]NBLIG INTIT For COMPTE7  : If varmode([M:BLA2]LIB7)<3  : Titcol [M:BLA2]NBLIG INTIT For LIB7  : Endif
  When  8 : Titcol [M:BLA2]NBLIG INTIT For COMPTE8  : If varmode([M:BLA2]LIB8)<3  : Titcol [M:BLA2]NBLIG INTIT For LIB8  : Endif
  When  9 : Titcol [M:BLA2]NBLIG INTIT For COMPTE9  : If varmode([M:BLA2]LIB9)<3  : Titcol [M:BLA2]NBLIG INTIT For LIB9  : Endif
  When 10 : Titcol [M:BLA2]NBLIG INTIT For COMPTE10 : If varmode([M:BLA2]LIB10)<3 : Titcol [M:BLA2]NBLIG INTIT For LIB10 : Endif
  When 11 : Titcol [M:BLA2]NBLIG INTIT For COMPTE11 : If varmode([M:BLA2]LIB11)<3 : Titcol [M:BLA2]NBLIG INTIT For LIB11 : Endif
  When 12 : Titcol [M:BLA2]NBLIG INTIT For COMPTE12 : If varmode([M:BLA2]LIB12)<3 : Titcol [M:BLA2]NBLIG INTIT For LIB12 : Endif
 Endcase
 If dim([M:BLA2]INTCOMPTE)>I-1 : [M:BLA2]INTCOMPTE(I-1) = INTIT : Endif
 If dim([M:BLA2]INTLIB)>I-1 & evalue("varmode([M:BLA2]LIB"+num$(I)+")")<3 : [M:BLA2]INTLIB(I-1) = INTIT : Endif

Next I
For I=NIVEAU+1 To MAXTRI
 Case I
  When  1 : Chgfmt [BLA2]COMPTE1  With "-K:15X" : Chgfmt [BLA2]LIB1  With "-K:15X"
  When  2 : Chgfmt [BLA2]COMPTE2  With "-K:15X" : Chgfmt [BLA2]LIB2  With "-K:15X"
  When  3 : Chgfmt [BLA2]COMPTE3  With "-K:15X" : Chgfmt [BLA2]LIB3  With "-K:15X"
  When  4 : Chgfmt [BLA2]COMPTE4  With "-K:15X" : Chgfmt [BLA2]LIB4  With "-K:15X"
  When  5 : Chgfmt [BLA2]COMPTE5  With "-K:15X" : Chgfmt [BLA2]LIB5  With "-K:15X"
  When  6 : Chgfmt [BLA2]COMPTE6  With "-K:15X" : Chgfmt [BLA2]LIB6  With "-K:15X"
  When  7 : Chgfmt [BLA2]COMPTE7  With "-K:15X" : Chgfmt [BLA2]LIB7  With "-K:15X"
  When  8 : Chgfmt [BLA2]COMPTE8  With "-K:15X" : Chgfmt [BLA2]LIB8  With "-K:15X"
  When  9 : Chgfmt [BLA2]COMPTE9  With "-K:15X" : Chgfmt [BLA2]LIB9  With "-K:15X"
  When 10 : Chgfmt [BLA2]COMPTE10 With "-K:15X" : Chgfmt [BLA2]LIB10 With "-K:15X"
  When 11 : Chgfmt [BLA2]COMPTE11 With "-K:15X" : Chgfmt [BLA2]LIB11 With "-K:15X"
  When 12 : Chgfmt [BLA2]COMPTE12 With "-K:15X" : Chgfmt [BLA2]LIB12 With "-K:15X"
 Endcase
Next I
[M:BLA1]NIVEAU = NIVEAU
Gosub PREMIER
Return

$SETBOUT
CHBOU = "I09"
If SUITE  : CHBOU += ">" : Endif
If RETOUR : CHBOU += "<" : Endif
CHMEN = "3BC"
For I=1 To NIVEAU
 If [M:EDA]PYRSEC(I-1)<>"" or [M:BLA1]DETAIL=2
  CHMEN += "4"
  Break
 Endif
Next I
If [M:BLA1]DETAIL<>2
 If NIVEAU<NBGRP : CHMEN += "1" : Endif
 If NIVEAU>0     : CHMEN += "2" : Endif
Endif
Return

###########################################################
## Gestion niveau de totaux
###########################################################
$BOUTON
Case BOUT
 When "1" : Gosub NIVPLUS
 When "2" : Gosub NIVMOINS
 When "3" : GOK = 2 : FIN = 1
 When "4" : Gosub DETAILS
Endcase
Return

$NIVPLUS
NIVEAU += 1
Gosub REMPLIT
Return

$NIVMOINS
NIVEAU -= 1
Gosub REMPLIT
Return

$DETAILS
If [M:BLA1]DETAIL=2
 [M:BLA1]DETAIL = 1
 FILDET = "1=1"
 Raz [M:BLA1]LIBDET
 RELIT = 1
Else
 For I=1 To NIVEAU
  SAVCLE(I) = evalue("[M:BLA2]TRI"+num$(I)+"(0)")
 Next I
 SAVSUI = SUITE
 SAVRET = RETOUR
 SAVLIG = nolign
 [M:BLA1]DETAIL = 2
 FILDET = ""
 Raz [M:BLA1]LIBDET
 [M:BLA1]LIBDET(0) = mess(60,109,1) : # Détail comptes/sections
 For I=1 To NIVEAU
  If FILDET<>"" : FILDET -= "&" : Endif
  FILDET -= 'CCE'+mid$(CHIFFRES,I,1)+'="'+evalue("[M:BLA2]COMPTE"+num$(I)+'('+num$(nolign-1)+')')+'"'
  If I>1
   [M:BLA1]LIBDET(1) += " / "
   [M:BLA1]LIBDET(2) += " / "
  Endif
  [M:BLA1]LIBDET(1) += evalue("[M:BLA2]COMPTE"+num$(I)+'('+num$(nolign-1)+')')
  [M:BLA1]LIBDET(2) += evalue("[M:BLA2]LIB"+num$(I)+'('+num$(nolign-1)+')')
 Next I
 If DETSIT=2
  If FILDET<>"" : FILDET -= "&" : Endif
  FILDET -= 'FCY="'+[M:BLA2]SITE(nolign-1)+'"'
  [M:BLA1]LIBDET(1) += " / "+[M:BLA2]SITE(nolign-1)
  Read [FCY]FCY0 = [M:BLA2]SITE(nolign-1)
  [M:BLA1]LIBDET(2) += " / "+[F:FCY]FCYSHO
 Endif
Endif
Affzo [BLA1]DETAIL, LIBDET
Gosub REMPLIT
Return

###########################################################
## Gestion pagination
###########################################################
$PREMIER
For I=1 To MAXTRI
 If RELIT
  Assign "DEB"+num$(I) With SAVCLE(I)
 Else
  Assign "DEB"+num$(I) With ""
 Endif
Next I
If DETSIT=2
 DEBFCY = ""
Endif
Gosub PSUIV
If RELIT
 RELIT  = 0
 SUITE  = SAVSUI
 RETOUR = SAVRET
 zonsui = "NBLIG("+num$(SAVLIG-1)+")"
Else
 RETOUR = 0
Endif
Return

$DERNIER
For I=1 To MAXTRI
 Assign "DEB"+num$(I) With chr$(255)
Next I
If DETSIT=2
 DEBFCY = ""
Endif
Gosub PPREC
SUITE = 0
Return

$SUITE
For I=1 To NIVEAU
 If DETAIL
  Assign "DEB"+num$(I) With evalue("[M:BLA2]COMPTE"+num$(I)+"("+num$([M:BLA2]NBLIG-1)+")")
 Else
  Assign "DEB"+num$(I) With evalue("[M:BLA2]TRI"+num$(I)+"("+num$([M:BLA2]NBLIG-1)+")")
 Endif
Next I
If DETSIT=2
 DEBFCY = [M:BLA2]SITE([M:BLA2]NBLIG-1)
Endif
Gosub PSUIV
RETOUR = 1
Return

$RETOUR
For I=1 To NIVEAU
 If DETAIL
  Assign "DEB"+num$(I) With evalue("[M:BLA2]COMPTE"+num$(I)+"(0)")
 Else
  Assign "DEB"+num$(I) With evalue("[M:BLA2]TRI"+num$(I)+"(0)")
 Endif
Next I
If DETSIT=2
 DEBFCY = [M:BLA2]SITE(0)
Endif
Gosub PPREC
SUITE = 1
Return

$PSUIV
If NIVEAU=0 : Goto TOTAL : Endif
Effzo [BLA2] 20
NOL = 0
SUITE = 0
For K=NIVEAU To 1 Step -1
 FILTRE = ""
 For J=1 To K-1
  If FILTRE<>"" : FILTRE -= '&' : Endif
  If DETAIL
   FILTRE -= 'DET'+mid$(CHIFFRES,J,1)+'="'+evalue("DEB"+num$(J))+'"'
  Else
   FILTRE -= 'TRICCE'+mid$(CHIFFRES,J,1)+'="'+evalue("DEB"+num$(J))+'"'
  Endif
 Next J
 If FILTRE<>"" : FILTRE -= '&' : Endif
 If DETAIL
  FILTRE -= 'DET'+mid$(CHIFFRES,K,1)+'>"'+evalue("DEB"+num$(K))+'"'
 Else
  If RELIT & K=NIVEAU
   FILTRE -= 'TRICCE'+mid$(CHIFFRES,K,1)+'>="'+evalue("DEB"+num$(K))+'"'
  Elsif DETSIT=2 & K=NIVEAU
   FILTRE -= '((TRICCE'+mid$(CHIFFRES,K,1)+'="'+evalue("DEB"+num$(K))+'" & FCY>"'+DEBFCY+'") | (TRICCE'+mid$(CHIFFRES,K,1)+'>"'+evalue("DEB"+num$(K))+'"))'
  Else
   FILTRE -= 'TRICCE'+mid$(CHIFFRES,K,1)+'>"'+evalue("DEB"+num$(K))+'"'
  Endif
 Endif
 Gosub CHARGE_SUIV
 If SUITE : Break : Endif
Next K
Affzo [BLA2] 20
Return

$CHARGE_SUIV
