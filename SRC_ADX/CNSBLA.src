&                                                             ;TRICCE6;TRICCE7;TRICCE8;TRICCE9
  When  8 : Filter [TMP] Where NUMREQ=REQUETE Order By Key CLE=TRICCE1;TRICCE2;TRICCE3;TRICCE4;TRICCE5
&                                                             ;TRICCE6;TRICCE7;TRICCE8
  When  7 : Filter [TMP] Where NUMREQ=REQUETE Order By Key CLE=TRICCE1;TRICCE2;TRICCE3;TRICCE4;TRICCE5
&                                                             ;TRICCE6;TRICCE7
  When  6 : Filter [TMP] Where NUMREQ=REQUETE Order By Key CLE=TRICCE1;TRICCE2;TRICCE3;TRICCE4;TRICCE5
&                                                             ;TRICCE6
  When  5 : Filter [TMP] Where NUMREQ=REQUETE Order By Key CLE=TRICCE1;TRICCE2;TRICCE3;TRICCE4;TRICCE5
