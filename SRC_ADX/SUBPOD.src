#<AdxTL>@(#)6.0.0.0 $Revision$
#########################################################################
# SUBPOD : Gestion des demandes de livraison d'achat        CG 15/01/98 #
# --------------------------------------------------------------------- #
# Traitements sur champ "Call" de l'objet "POD"                         #
# Le traitement des actions "Gosub" se trouvent dans le SUBPODA         #
#                                                                       #
# GCUR    = devise societe         GSYSCUR = devise dossier             #
# GFINRSP = site financier                                              #
#########################################################################

$ACTION
#---------------------------------#
# Actions de l'objet POD (GOBJET) #
#---------------------------------#
Case ACTION
 When "FILTRE"       : Gosub FILTRE          From SUBPODA
 When "AV_IMPRIME"   : Gosub AV_IMPRIME      From SUBPODA
 When "OUVRE"        : Gosub OUVRE           From SUBPODA
 When "SETBOUT"      : Gosub SETBOUT         From SUBPODA
 When "AVANTBOUT"    : Gosub AVANTBOUT       From SUBPODA
 When "EXEBOUT"      : Gosub EXEBOUT         From SUBPODA
 When "STATUT"       : Gosub STATUT          From SUBPODA
 When "DEFLIG"       : Gosub DEFLIG          From SUBPODA
 When "LIENS_LIG"    : Gosub LIENS_LIG       From SUBPODA
 When "INICRE_LIG"   : Gosub INICRE_LIG      From SUBPODA
 When "INIMOD_LIG"   : Gosub INIMOD_LIG      From SUBPODA
 When "VALLIG"       : Gosub VALLIG          From SUBPODA
 When "LIENS"        : Gosub LIENS           From SUBPODA
 When "AVANT_MOD"    : Gosub AVANT_MOD       From SUBPODA
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC    From SUBPODA
 When "INIMOD"       : Gosub INIMOD          From SUBPODA
 When "VERIF_MOD"    : Gosub VERIF_MOD       From SUBPODA
 When "MODIF"        : Gosub MODIF           From SUBPODA
 When "APRES_MOD"    : Gosub APRES_MOD       From SUBPODA
 When "FIN_MOD"      : Gosub ABANDON         From SUBPODA
 When "AB_MODIF"     : Gosub AB_MODIF        From SUBPODA
 When "ABANDON"      : Gosub ABANDON         From SUBPODA
 When "FERME"        : Gosub FERME           From SUBPODA
#---------------------------#
# Actions champs modèlisées #
#---------------------------#
 When "AB6_NBLIG"    : Gosub AB6_NBLIG
 When "AB2_XPRHFCY"  : Gosub AB2_XPRHFCY
 When "BB2_XPRHFCY"  : Gosub BB2_XPRHFCY
 When Default
Endcase
Return


#######################################################################
#############  ETIQUETTES           ###################################
#######################################################################

$INSERTION_BESOIN
#----- Contrôle uniquement si la quantité prévue n'est pas nulle -----#
If [M:POD1]EXTQTYPUU<>0
  Local    Shortint I
  Local    Integer  OK
  Local    Decimal  CUMQTE
# #----- Calcul du cumul des quantités (fermes et planifiées) -----#
  If [M:POD1]NBLIG>0
    For I=0 To [M:POD1]NBLIG-1
       CUMQTE+=[M:POD1]QTYPUU(I)
    Next I
  Endif
  CUMQTE-=[F:POC]RTNQTYPUU
# #----- Ajout du total des quantités besoins pris en compte -----#
  Call PCAL_QTY([M:PPI1]TOTQTY,[M:PPI1]UOM,GBIDD3,[F:POC]PUU,
&               [F:POC]ITMREF,[F:POC]BPSNUM,1,GBIDD2) From TRTACHQTE1
  CUMQTE+=GBIDD3
# #----- La quantité totale commandée est supérieure à la quantité prévue -----#
  If CUMQTE>[M:POD1]EXTQTYPUU
    If GPOCQTY=2 : # Contrôle bloquant
      GMESSAGE=num$(CUMQTE)-[M:POD1]PUU-":"-mess(91,194,1) : GERR=1
      Raz [M:PPI1]PICQTY : Return
    Else         : # Contrôle non bloquant
      OK=2 : Call AVERTIR(num$(CUMQTE)-[M:POD1]PUU-":"-mess(91,194,1),OK) From GESECRAN
      If OK=1 Raz [M:PPI1]PICQTY : Return : Endif
    Endif
  Endif
Endif

Local Decimal QTEUA, SAV_QTEUA
Local Decimal WCOEUOM
Local Integer WNOLIGN
WNOLIGN  = nolign

Local Decimal WRETQTY, WRETQTYPUU
Local Integer NBRLIG , NBRRETARD , NBRFERME , NBRPLANIF ,NBPOSTE
Local Integer TABLIG (0..[M:PPI1]NBLIG-1)
Local Integer WIND_TAB, II, WTRAIT
Local Integer I,J,K

Local Date WFINFERME
Local Date WFINPLANIFIE
WFINFERME = date$ + [F:POC]FIMHOR
#----------------------------------
# le tableau de prise en compte est deja borné en fonction de horizon planifié
#-----------------------------------
NBRLIG    = 0
NBRRETARD = 0 : NBRFERME = 0 : NBRPLANIF = 0
#----------------------------------------------#
# il faut calculer le nombre de ligne à creer  #
# tri du tableau sur date fin besoin           #
#----------------------------------------------#
Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]ENDDAT (indice),
&                                          [M:PPI1]PICQTY (indice)

For I = 0 To [M:PPI1]NBLIG -1
   If [M:PPI1]PICQTY (I) <> 0
          If [M:PPI1]ENDDAT (I) < date$
                      NBRRETARD +=1
          Elsif [M:PPI1]ENDDAT (I) <=WFINFERME
                      NBRFERME +=1
          Else        NBRPLANIF +=1
          Endif
          NBRLIG +=1
          TABLIG (NBRLIG -1) = I
   Endif
Next I
NBPOSTE = NBRLIG
If NBRLIG = 0 : Return : Endif
If NBRRETARD<>0 NBRLIG=NBRLIG+1-NBRRETARD : Endif

status = 73

If dim ([M]WIPSTA) < [M]NBLIG+NBRLIG
  GMESSAGE=mess(122,199,1) : GERR=1 : Raz [M:PPI1]PICQTY : Return
Endif

WTRAIT = 0
Local Decimal WTOTQTY, WTOTRETQTY
Raz WTOTQTY, WTOTRETQTY

Call DEBTRANS From GLOCK
Trbegin [PWO]
  Raz [F:PWO]
  [F:PWO]PRONUM = adxuid(1)
  [F:PWO]CODFNC = "POD"
  [F:PWO]ITMREF = [M:POD1]ITMREF
  [F:PWO]PUU    = [M:POD1]PUU
  [F:PWO]STU    = [M:POD1]STU
  #---------------------- Cas des lignes en retard ---------------------#
  # on a indice dans le tableau TABLIG                                  #
  # creation ligne CF jour à la date du jour                            #
  # il faut d abord cumuler les qtés et ensuite on cree une seule ligne #
  #---------------------------------------------------------------------#
  For II = 0 To NBRRETARD - 1
      WIND_TAB = TABLIG (II)
      WTOTQTY    += [M:PPI1]PICQTY (WIND_TAB)
      WTOTRETQTY += min([M:PPI1]PICQTY(WIND_TAB),[M:PPI1]RMNEXTQTY(WIND_TAB))
  Next II
  If WTOTQTY <> 0
      WTRAIT = 1 : Gosub CRELIG : # retard
  Endif
  status = 73
  #---------------------- Cas des lignes jour (ferme) ----------------------#
  # on a indice dans le tableau TABLIG                                      #
  # creation ligne CF jour                                                  #
  # si ligne chevauche une periode, on ajoute sur periode planifié tant pis #
  #-------------------------------------------------------------------------#
  For II = NBRRETARD To NBRFERME+NBRRETARD-1
      WIND_TAB = TABLIG (II)
      WTRAIT = 2 : Gosub CRELIG : # ferme
  Next II
  status = 73
  #------------- Cas des lignes semaines ou mois -------------#
  # on a indice dans le tableau TABLIG                        #
  # creation ligne planifie semaine ou mois                   #
  # on rajoute sur ligne existante ou creation nouvelle ligne #
  #-----------------------------------------------------------#
  For II = NBRFERME+NBRRETARD To NBRPLANIF+NBRRETARD+NBRFERME -1
      WIND_TAB = TABLIG (II)
      WTRAIT = 3   : # semaine ou mois, attention il peut exister wtrait  = 4
      Gosub CRELIG
  Next II
Commit

#----------------------------------#
# affichage des nouvelles lignes   #
#----------------------------------#
If [M:POD1]NBLIG<>0
  Affzo [POD1]XEARQTY, 25
Endif

nolign = WNOLIGN
If ASFLG=1  Call AVANT_NBLIG From SUBPOD : GMODIF=0 : Endif
#-------------------------------------------------------------#
# le GQSEQ n a pas changé car ligne en retard sur date jour   #
#-------------------------------------------------------------#

Return


#######################################################################
$CRELIG

#-------------------------------------------------------------------#
# il faut vérifier si on peut l' inserer simplement dans le tableau #
# date de fin besoin > date de la ligne GQSEQ                       #
# Gqseq première ligne  soldée avant la ligne nolign = 1            #
#-------------------------------------------------------------------#
Local Integer WDERLIG, K, WTRT
Local Char WTRT(1)
WTRT = "C"
WDERLIG = [M:POD1]NBLIG
If WDERLIG = 0
          #--------------------------#
          # creation premiere ligne  #
          #--------------------------#
          K = 0 : WTRT = "C"
          Goto CRELIG_010
Endif
 #--------------------------------------------#
 # si date besoin > date début ligne          #
 #  ajout sur ligne 0   k=1 et wtrt = "m"     #
 # sinon                                      #
 # insertion avant la premiere ligne          #
 #          k = 0 et wtrt = "c"               #
 # attention au cas retard --> creation ligne #
 #         sur date$                          #
 #--------------------------------------------#
If WTRAIT = 1
    If [M:POD1]EXTRCPDAT (0) < date$
         If date$ >= [M:POD1]EXTRCPDAT (WDERLIG-1)
                K = WDERLIG : WTRT = "C"
         Else
                Call DICHOTOMIE(WDERLIG,I,J,K,WTRT,date$)
         Endif
    Else
         K = 0 : WTRT = "C"
    Endif
Else
    If [M:PPI1]ENDDAT (WIND_TAB) < [M:POD1]EXTRCPDAT (0)
           If [M:PPI1]ENDDAT (WIND_TAB) > [M:POD1]STRRCPDAT (0)
                K = 1 : WTRT = "M"
           Else K = 0 : WTRT = "C"
           Endif
    Elsif [M:PPI1]ENDDAT (WIND_TAB) >= [M:POD1]EXTRCPDAT (WDERLIG-1)
       #--------------------------------------------------------------------------#
       # attention a insertion ligne si la ligne precedente                       #
       # est de cadencement jour et que la date se trouve sur cette semaine       #
       # dans ce cas insertion nouvelle ligne mais cadencement jour avec planifié #
       # a faire sur charge_lig    plus loin dans prog  avec wtrait = 4           #
       #--------------------------------------------------------------------------#
        If WTRAIT = 3 and [M:POD1]CAD (WDERLIG-1) = 1
                Local Shortint W_YEA_WDERLIG , W_YEA
                Local Shortint W_WEE_WDERLIG , W_WEE

                W_YEA_DERLIG  = val(left$([M]EXTRCPDAT (WDERLIG-1),4))
                W_YEA         = val(left$([M:PPI1]ENDDAT (WIND_TAB),4))
                W_WEE_DERLIG  = week([M]EXTRCPDAT (WDERLIG-1))
                W_WEE         = week([M:PPI1]ENDDAT (WIND_TAB))

                If W_WEE_DERLIG = 53
                      If  year(aweek (W_WEE_DERLIG,W_YEA_DERLIG) + 3) <> W_YEA_DERLIG
                             W_WEE_DERLIG = 1
                      Endif
                Elsif W_WEE_DERLIG = 0
                      If  dayn(aweek (W_WEE_DERLIG,W_YEA_DERLIG)+ 3) < 4
                             W_WEE_DERLIG = 1
                      Else   W_WEE_DERLIG = 53
                      Endif
                Endif

                If W_WEE = 53
                      If  year(aweek (W_WEE,W_YEA) + 3) <> W_YEA
                             W_WEE = 1
                      Endif
                Elsif W_WEE = 0
                      If  dayn(aweek (W_WEE,W_YEA)+ 3) < 4
                             W_WEE = 1
                      Else   W_WEE = 53
                      Endif
                Endif
                If W_YEA = W_YEA_DERLIG
                      If W_WEE <= W_WEE_DERLIG
                              WTRAIT = 4
                      Endif
                Endif
        Endif
        #-----------------------------------#
        # insertion apres la derniere ligne #
        #-----------------------------------#
        K = WDERLIG : WTRT = "C"
    Else
          Call DICHOTOMIE(WDERLIG,I,J,K,WTRT,[M:PPI1]ENDDAT(WIND_TAB))
    Endif
Endif


$CRELIG_010
nolign = K
#----------------#
# creation ligne #
#----------------#
If WTRT = "C"
        status=73 : Call INSERE("POQSEQ") From TABLEAUX
        If mkstat <> 2
               #----------------------------------------#
               # il faut vérifier cadencement précédent #
               # et cadencement suivant                 #
               #----------------------------------------#
               Call CADENCEMENT (WIND_TAB,WTRAIT) From SUBPOD
               If mkstat = 2
                   #---------------------------------------------#
                   # on ajoute sur la ligne semaine ou mois      #
                   # tant pis pour le planifié on ne le prend pas#
                   #---------------------------------------------#
                        # A VOIR ?????????? et signaler qd meme
                        # .. modifier le message  attention à qté
                   [M:PPI1]PICQTY (WIND_TAB) = 0
                   GERR=1
               Else
                   If dim([M:POD1]WIPSTA) = [M:POD1]NBLIG+1
                         Insa nolign,1 [M:POD1]NBLIG : # pas de borne sinon plantage
                   Else  Insa nolign,1,[M:POD1]NBLIG [M:POD1]NBLIG
                   Endif
                   [M:POD1]NBLIG+=1
                   nolign+=1
                   status=0 : Call LINNUM("POQSEQ") From TABLEAUX
                   Gosub CHARGE_LIG
                   Call APRES_NBLIG From SUBPOD
               Endif
      Else
          #----------------------------------------------------#
          # probleme donc il ne faut pas mettre a jour encours #
          #----------------------------------------------------#
          [M:PPI1]PICQTY (WIND_TAB) = 0
      Endif
Elsif WTRT = "M"
          #-----------------------------#
          # on ajoute sur ligne trouvée #
          #-----------------------------#
          Call PCAL_QTY([M:PPI1]PICQTY(WIND_TAB),[M:PPI1]UOM,GBIDD3,[F:POC]PUU,
&                       [F:POC]ITMREF,[F:POC]BPSNUM,3,WCOEUOM) From TRTACHQTE1
          QTEUA=[M:PPI1]PICQTY(WIND_TAB)*WCOEUOM
          WRETQTY=min([M:PPI1]PICQTY(WIND_TAB),[M:PPI1]RMNEXTQTY(WIND_TAB))
          If WRETQTY<>[M:PPI1]PICQTY(WIND_TAB)
            Call PCAL_QTY(WRETQTY,[M:PPI1]UOM,WRETQTYPUU,[F:POC]PUU,
&                         [F:POC]ITMREF,[F:POC]BPSNUM,1,WCOEUOM) From TRTACHQTE1
          Else
            WRETQTYPUU=GBIDD3
          Endif
          #----- Appel au point d'entrée permettant de choisir l'arrondi de la qté UA -----#
          If dim(NOL)<1  Local Shortint NOL : Endif
          NOL=0 : SAV_QTEUA=QTEUA
          Gosub POINT_PURQTYRND From SUBPOHB
          #----- Recalcul quantité prise après arrondi éventuel de l'UA -----#
          Call PCAL_QTY(QTEUA,[F:POC]PUU,GBIDD3,[M:PPI1]UOM,
&                       [F:POC]ITMREF,[F:POC]BPSNUM,1,GBIDD1) From TRTACHQTE1
          #----- Si qté prise inférieure au besoin pris en compte, ajuster qtés à la hausse -----#
          If GBIDD3<WRETQTY
            QTEARR=arr(SAV_QTEUA,10^-WNBDEC)
            If QTEARR>=SAV_QTEUA-10^-(WNBDEC+3)
              QTEUA=QTEARR
            Else
              QTEUA=QTEARR+10^-WNBDEC
            Endif
            WRETQTYPUU=QTEUA
          Endif
          If WRETQTYPUU=0  WRETQTYPUU=QTEUA : Endif
          GBIDD3=QTEUA
          #-----
          [M:POD1]QTYPUU    (nolign-1) += GBIDD3
          If [M:POD1]WIPSTA(nolign-1)=1
            [M:POD1]ORDQTYPUU += GBIDD3
            If [M:POD1]LINSTA(nolign-1)=2
              [M:POD1]XEARQTY += GBIDD3
            Endif
          Endif
          [M:POD1]RETQTYPUU (nolign-1) += WRETQTYPUU
          If [M:POD1]POHLIN(nolign-1)=0
            [M:POD1]POHCOU+=1 : [M:POD1]POHLIN(nolign-1)=[M:POD1]POHCOU
          Endif
          [F:PWO]LINNUM = [M:POD1]POHLIN(nolign-1)
          [F:PWO]WIPTYP = [M:PPI1]WIPTYP(WIND_TAB)
          [F:PWO]WIPSTA = [M:PPI1]WIPSTA(WIND_TAB)
          If [M:PPI1]WIPNUM(WIND_TAB)<>""
            [F:PWO]WIPNUM = [M:PPI1]WIPNUM(WIND_TAB)
            [F:PWO]PSDLIN = 0
          Else
            [F:PWO]WIPNUM = [M:PPI1]VCRNUM(WIND_TAB)
            [F:PWO]PSDLIN = [M:PPI1]VCRLIN(WIND_TAB)
          Endif
          [F:PWO]QTYPUU = WRETQTYPUU
          Call PCAL_QTY(WRETQTY,[M:PPI1]UOM,[F:PWO]QTYSTU,[F:PWO]STU,
&                       [F:POC]ITMREF,[F:POC]BPSNUM,1,WCOEUOM) From TRTACHQTE1
          Write [PWO]
          If fstat GOK=0 : Endif
Endif

Return


#######################################################################

$CHARGE_LIG
#-----------------------#
# chargement ligne jour #
#-----------------------#
If WTRAIT = 1
       #------- cumul des retard en ferme sur date jour
       [M:POD1]WIPSTA    (nolign-1) = 1
       [M:POD1]LINSTA    (nolign-1) = 1
       [M:POD1]CAD       (nolign-1) = 1
       [M:POD1]EXTRCPDAT (nolign-1) = date$
Elsif WTRAIT = 2
       #------- ferme
       [M:POD1]WIPSTA    (nolign-1) = 1
       [M:POD1]LINSTA    (nolign-1) = 1
       [M:POD1]CAD       (nolign-1) = 1
       [M:POD1]EXTRCPDAT (nolign-1) = [M:PPI1]ENDDAT (WIND_TAB)
Elsif WTRAIT = 4
       #------- cas ou on aurait du creer une semaine mais un jour existe deja
       #------- dans ce cas creation ligne jour avec planifié
       [M:POD1]WIPSTA    (nolign-1) = 2
       [M:POD1]LINSTA    (nolign-1) = 1
       [M:POD1]CAD       (nolign-1) = 1
       [M:POD1]EXTRCPDAT (nolign-1) = [M:PPI1]ENDDAT (WIND_TAB)
Else
       #------- planifié semaine ou mois
       [M:POD1]WIPSTA    (nolign-1) = 2
       [M:POD1]LINSTA    (nolign-1) = 1
       If [F:POC]FRTHORUOM = 5
              [M:POD1]CAD  (nolign-1) = 3
       Else   [M:POD1]CAD  (nolign-1) = 2
       Endif
       [M:POD1]EXTRCPDAT (nolign-1) = [M:PPI1]ENDDAT (WIND_TAB)
Endif
If [M:POD1]POHLIN(nolign-1)=0
       [M:POD1]POHCOU+=1 : [M:POD1]POHLIN(nolign-1)=[M:POD1]POHCOU
Endif
If WTRAIT = 1
       Call PCAL_QTY(WTOTQTY,[M:PPI1]UOM,GBIDD3,[F:POC]PUU,
&                    [F:POC]ITMREF,[F:POC]BPSNUM,3,WCOEUOM) From TRTACHQTE1
       QTEUA=WTOTQTY*WCOEUOM
       For II=0 To NBRRETARD-1
         WIND_TAB = TABLIG (II)
         [F:PWO]LINNUM = [M:POD1]POHLIN(nolign-1)
         [F:PWO]WIPTYP = [M:PPI1]WIPTYP(WIND_TAB)
         [F:PWO]WIPSTA = [M:PPI1]WIPSTA(WIND_TAB)
         If [M:PPI1]WIPNUM(WIND_TAB)<>""
           [F:PWO]WIPNUM = [M:PPI1]WIPNUM(WIND_TAB)
           [F:PWO]PSDLIN = 0
         Else
           [F:PWO]WIPNUM = [M:PPI1]VCRNUM(WIND_TAB)
           [F:PWO]PSDLIN = [M:PPI1]VCRLIN(WIND_TAB)
         Endif
         WRETQTY=min([M:PPI1]PICQTY(WIND_TAB),[M:PPI1]RMNEXTQTY(WIND_TAB))
         Call PCAL_QTY(WRETQTY,[M:PPI1]UOM,[F:PWO]QTYPUU,[F:PWO]PUU,
&                      [F:POC]ITMREF,[F:POC]BPSNUM,1,WCOEUOM) From TRTACHQTE1
         Call PCAL_QTY(WRETQTY,[M:PPI1]UOM,[F:PWO]QTYSTU,[F:PWO]STU,
&                      [F:POC]ITMREF,[F:POC]BPSNUM,1,WCOEUOM) From TRTACHQTE1
         Write [PWO]
         If fstat GOK=0 : Break : Endif
       Next II
       If WTOTRETQTY<>WTOTQTY
         Call PCAL_QTY(WTOTRETQTY,[M:PPI1]UOM,WRETQTYPUU,[F:POC]PUU,
&                      [F:POC]ITMREF,[F:POC]BPSNUM,1,WCOEUOM) From TRTACHQTE1
       Else
         WRETQTYPUU=GBIDD3
       Endif
Else
       WRETQTY=min([M:PPI1]PICQTY(WIND_TAB),[M:PPI1]RMNEXTQTY(WIND_TAB))
       Call PCAL_QTY([M:PPI1]PICQTY(WIND_TAB),[M:PPI1]UOM,GBIDD3,[F:POC]PUU,
&                    [F:POC]ITMREF,[F:POC]BPSNUM,3,WCOEUOM) From TRTACHQTE1
       QTEUA=[M:PPI1]PICQTY(WIND_TAB)*WCOEUOM
       WTOTRETQTY=WRETQTY
       [F:PWO]LINNUM = [M:POD1]POHLIN(nolign-1)
       [F:PWO]WIPTYP = [M:PPI1]WIPTYP(WIND_TAB)
       [F:PWO]WIPSTA = [M:PPI1]WIPSTA(WIND_TAB)
       If [M:PPI1]WIPNUM(WIND_TAB)<>""
         [F:PWO]WIPNUM = [M:PPI1]WIPNUM(WIND_TAB)
         [F:PWO]PSDLIN = 0
       Else
         [F:PWO]WIPNUM = [M:PPI1]VCRNUM(WIND_TAB)
         [F:PWO]PSDLIN = [M:PPI1]VCRLIN(WIND_TAB)
       Endif
       If WRETQTY<>[M:PPI1]PICQTY(WIND_TAB)
         Call PCAL_QTY(WRETQTY,[M:PPI1]UOM,WRETQTYPUU,[F:POC]PUU,
&                      [F:POC]ITMREF,[F:POC]BPSNUM,1,WCOEUOM) From TRTACHQTE1
       Else
         WRETQTYPUU = GBIDD3
       Endif
       Call PCAL_QTY(WRETQTY,[M:PPI1]UOM,[F:PWO]QTYSTU,[F:PWO]STU,
&                    [F:POC]ITMREF,[F:POC]BPSNUM,1,WCOEUOM) From TRTACHQTE1
       Write [PWO]
       If fstat GOK=0 : Endif
Endif
#----- Récupération texte ligne DA -----#
If GPURTEXPSH=2
  Call RECHERCHE_DA_TEX(adxuid(1),"POD",[M:POD1]POHLIN(nolign-1),[M:POD1]LINTEX(nolign-1)) From TRTACHCDE1
Endif
#----- Appel au point d'entrée permettant de choisir l'arrondi de la qté UA -----#
If dim(NOL)<1  Local Shortint NOL : Endif
NOL=0 : SAV_QTEUA=QTEUA
Gosub POINT_PURQTYRND From SUBPOHB
#----- Recalcul quantité prise après arrondi éventuel de l'UA -----#
Call PCAL_QTY(QTEUA,[F:POC]PUU,GBIDD3,[M:PPI1]UOM,
&             [F:POC]ITMREF,[F:POC]BPSNUM,1,GBIDD1) From TRTACHQTE1
#----- Si qté prise inférieure au besoin pris en compte, ajuster qtés à la hausse -----#
If GBIDD3<WTOTRETQTY
  QTEARR=arr(SAV_QTEUA,10^-WNBDEC)
  If QTEARR>=SAV_QTEUA-10^-(WNBDEC+3)
    QTEUA=QTEARR
  Else
    QTEUA=QTEARR+10^-WNBDEC
  Endif
  WRETQTYPUU=QTEUA
Endif
If WRETQTYPUU=0  WRETQTYPUU=QTEUA : Endif
#-----
[M:POD1]QTYPUU    (nolign-1) = QTEUA
[M:POD1]RETQTYPUU (nolign-1) = WRETQTYPUU
[M:POD1]XPRHFCY   (nolign-1) = [F:POC]PRHFCY
[M:POD1]XFCYADD   (nolign-1) = [F:POC]FCYADD
[M:POD1]USEPLC    (nolign-1) = [F:POC]USEPLC
[M:POD1]MON  (nolign-1)      = val(mid$([M]EXTRCPDAT(nolign-1),5,2))
[M:POD1]YEA  (nolign-1)      = val(left$([M]EXTRCPDAT(nolign-1),4))
[M:POD1]WEE  (nolign-1)      = week([M:POD1]EXTRCPDAT(nolign-1))
#----- Initialisation des comptes et type d'achat si nécessaire -----#
If [M:POD1]LINACC(0)="" & [M:POD1]LINACC(1)=""
  Call INIT_COMPTES_LIGNE(nolign-1)
Endif
If [M:POD1]LINPURTYP=0
  Call INIT_LINPURTYP
Endif
#-----
If [M:POD1]WEE (nolign-1)  = 53
      #--------------------------------------------------------------#
      # on regarde si le 4 jour de la semaine est sur annee suivante #
      #--------------------------------------------------------------#
      If  year(aweek ([M]WEE (nolign-1),[M]YEA (nolign-1)) + 3) <> [M]YEA (nolign-1)
                 [M:POD1]WEE (nolign-1) = 1
      Endif
Elsif [M:POD1]WEE (nolign-1) = 0
      #---------------------------------------------------------------#
      # on regarde si le 4 jour de la semaine est sur annee precedente#
      #---------------------------------------------------------------#
      If  dayn(aweek ([M]WEE (nolign-1),[M]YEA (nolign-1))+ 3) < 4
                 [M:POD1]WEE (nolign-1) = 1
      Else       [M:POD1]WEE (nolign-1) = 53
      Endif
Endif

#-------------------------#
# chargement zone wrcpdat #
#-------------------------#
Local Shortint WJOUR ,WMOIS ,WANNEE
Local Char WDATE(10)
WANNEE = val(left$([M]EXTRCPDAT (nolign-1),4))
WMOIS  = val(mid$([M]EXTRCPDAT (nolign-1),5,2))
WJOUR  = val(right$([M]EXTRCPDAT (nolign-1),7))

If [M]CAD (nolign-1) = 1           : # cadencement jour
  Gosub DAT8 From SUBPODA
  [M]WRCPDAT (nolign-1)    = WDATE
  [M]STRRCPDAT(nolign-1)   = [M]EXTRCPDAT (nolign-1)
  #----- Ajustement date théorique réception en fonction des indisponibilités -----#
  If [M:POD1]XPRHFCY(nolign-1)=""  [M:POD1]XPRHFCY(nolign-1)=[M:POD1]PRHFCY : Endif
  If [F:FCY]FCY<>[M:POD1]XPRHFCY(nolign-1)
    Read [FCY] FCY0=[M:POD1]XPRHFCY(nolign-1)
    If fstat Raz [F:FCY] : Endif
  Endif
  If nolign>1
    GBIDA1=[M:POD1]EXTRCPDAT(nolign-2)
  Else
    GBIDA1=[M:POD1]EXTRCPDAT(nolign-1)
  Endif
  Call CTL_JOU2([M:POD1]EXTRCPDAT(nolign-1),GBIDA1,[F:FCY]UVYDAY,[F:FCY]UVYCOD,1) From CONTX3
  If mkstat
    GMESSAGE=mess(245,194,1)-[M:POD1]XPRHFCY(nolign-1)+"\"+GMESSAGE
    GMESSAGE=format$("D:"+GFMDAT,[M:POD1]EXTRCPDAT(nolign-1))-GMESSAGE
    Call MESSAGE(GMESSAGE) From GESECRAN
  Endif
Elsif [M]CAD (nolign-1) = 3        : # cadencement mois
  [M]STRRCPDAT (nolign-1)  = gdat$(1,[M]MON(nolign-1),[M]YEA(nolign-1))
  [M:POD1]EXTRCPDAT (nolign-1) = eomonth([M]STRRCPDAT(nolign-1))
  Local Char WWMOIS
  If len(num$(WMOIS))= 1
      WWMOIS = "0"+num$(WMOIS)
  Else  WWMOIS = num$(WMOIS)
  Endif
  WDATE= format$("K:2#[-]4#",WWMOIS+num$(WANNEE))
  [M]WRCPDAT (nolign-1) = WDATE
Else                               : # cadencement semaine
  [M]STRRCPDAT(nolign-1) = aweek([M]WEE(nolign-1),[M]YEA(nolign-1))
  [M]EXTRCPDAT(nolign-1) = aweek([M]WEE(nolign-1),[M]YEA(nolign-1))+6
  Local Char WSEM
  If len(num$([M]WEE(nolign-1)))= 1
        WSEM = "00"+num$([M]WEE(nolign-1))
  Elsif len(num$([M]WEE(nolign-1)))= 2
        WSEM = "0"+num$([M]WEE(nolign-1))
  Else  WSEM = num$([M]WEE(nolign-1))
  Endif
  WDATE= format$("K:3#[-]4#",WSEM+num$([M]YEA (nolign-1)))
  [M]WRCPDAT (nolign-1) = WDATE
Endif

Return


#######################################################################
################### SUBPROG ###########################################
#######################################################################

Subprog CADENCEMENT(WIND_TAB,WTRAIT)
Value Integer WIND_TAB
Value Integer WTRAIT
#-------------------------------------------------#
# attention l  insertion n a pas encore ete faite #
#-------------------------------------------------#

#---------------------------------------------------#
# on vérifie date avec ligne précédente ou suivante #
#---------------------------------------------------#
If nolign > 0
    If [M]CAD (nolign-1) = 1
        If  [M:PPI1]ENDDAT (WIND_TAB) < [M]EXTRCPDAT(nolign-1) & WTRAIT <> 1
                  GMESSAGE = mess(77,194,1) : mkstat = 2 : End
        Else
            If  date$ < [M]EXTRCPDAT(nolign-1) & WTRAIT = 1
                  GMESSAGE = mess(77,194,1) : mkstat = 2 : End
            Endif
        Endif
    Else
    #------- ligne precedente est une semaine ou mois
        If  [M:PPI1]ENDDAT (WIND_TAB) <= [M]EXTRCPDAT(nolign-1) & WTRAIT <> 1
                  GMESSAGE = mess(77,194,1) : mkstat = 2 : End
        Else
            If  date$ <= [M]EXTRCPDAT(nolign-1) & WTRAIT = 1
                  GMESSAGE = mess(77,194,1) : mkstat = 2 : End
            Endif
        Endif
    Endif
Endif
If nolign < [M]NBLIG
    If [M]CAD (nolign) = 1
       If  [M:PPI1]ENDDAT(WIND_TAB) > [M]EXTRCPDAT (nolign) & WTRAIT <> 1
                  GMESSAGE = mess(77,194,1) : mkstat = 2 : End
       Else
            If date$ > [M]EXTRCPDAT (nolign) & WTRAIT = 1
                  GMESSAGE = mess(77,194,1) : mkstat = 2 : End
            Endif
       Endif
    Else
       If  [M:PPI1]ENDDAT(WIND_TAB) >= [M]EXTRCPDAT (nolign) & WTRAIT <> 1
                  GMESSAGE = mess(77,194,1) : mkstat = 2 : End
       Else
            If  date$  >= [M]EXTRCPDAT (nolign) & WTRAIT = 1
                  GMESSAGE = mess(77,194,1) : mkstat = 2 : End
            Endif
       Endif
    Endif
Endif


#---------------------------------------------------#
#on vérifie date début avec lig précédente-suivante #
#---------------------------------------------------#
If nolign > 0
    If [M]CAD (nolign-1) = 1
       If  [M:PPI1]ENDDAT (WIND_TAB) <  [M]STRRCPDAT(nolign-1) & WTRAIT <> 1
                GMESSAGE = mess(77,194,1) : mkstat = 2 : End
       Else
            If  date$  <  [M]STRRCPDAT(nolign-1) & WTRAIT = 1
                GMESSAGE = mess(77,194,1) : mkstat = 2 : End
            Endif
       Endif
   Else
      If   [M:PPI1]ENDDAT(WIND_TAB) <= [M]STRRCPDAT (nolign-1) & WTRAIT <> 1
              GMESSAGE = mess(77,194,1) : mkstat = 2 : End
      Else
           If   date$  >= [M]STRRCPDAT (nolign-1) & WTRAIT = 1
              GMESSAGE = mess(77,194,1) : mkstat = 2 : End
           Endif
      Endif
   Endif
Endif
If nolign < [M]NBLIG
    If [M]CAD (nolign) = 1
       If   [M:PPI1]ENDDAT(WIND_TAB) >  [M]STRRCPDAT (nolign) & WTRAIT <> 1
               GMESSAGE = mess(77,194,1) : mkstat = 2 : End
       Else
          If  date$ >  [M]STRRCPDAT (nolign) & WTRAIT = 1
               GMESSAGE = mess(77,194,1) : mkstat = 2 : End
          Endif
       Endif
    Else
      If   [M:PPI1]ENDDAT(WIND_TAB) >= [M]STRRCPDAT (nolign) & WTRAIT <> 1
              GMESSAGE = mess(77,194,1) : mkstat = 2 : End
      Else
           If   date$  >= [M]STRRCPDAT (nolign) & WTRAIT = 1
              GMESSAGE = mess(77,194,1) : mkstat = 2 : End
           Endif
      Endif
   Endif
Endif

End

###################################################################
Subprog DICHOTOMIE (WDERLIG,I,J,K,WTRT,WDATE)
Value    Integer WIND_TAB
Value    Integer WDERLIG
Variable Integer I
Variable Integer J
Variable Integer K
Variable Char    WTRT
Value    Date    WDATE

#--------------------------#
# recherche par dichotomie #
#--------------------------#
I = 1
J = WDERLIG
While I < J-1
         K = int((I+J) /2)
         If WDATE  < [M:POD1]EXTRCPDAT (K-1)
                   J = K-1
                   K = 0
         Elsif  WDATE  > [M:POD1]EXTRCPDAT (K-1)
                   I = K
                   K = 0
         Else  I = K : J = K
               If [M]CAD (K-1) = 1 : WTRT = "C"
               Else                  WTRT = "M"
               Endif
         Endif
Wend
#----------------------------------#
# si on n 'a pas trouve l indice   #
#----------------------------------#
If K = 0
    If WDATE  <= [M:POD1]EXTRCPDAT (I-1) & WDATE >= [M:POD1]STRRCPDAT (I-1)
              K = I
              If [M]CAD (K-1) = 1 : WTRT = "C"
              Else                  WTRT = "M" : Endif
    Elsif WDATE  <= [M:POD1]EXTRCPDAT (J-1) & WDATE >= [M:POD1]STRRCPDAT (J-1)
              K = J
              If [M]CAD (K-1) = 1 : WTRT = "C"
              Else                  WTRT = "M" : Endif
    Else
              WTRT = "C" : K = I
    Endif
Endif

End



#######################################################################
#############  ACTIONS CHAMPS       ###################################
#######################################################################

Subprog C_POPLIN(VALEUR)
#-------------------------------------------------#
# Contrôle sur numéro de ligne article du contrat #
#-------------------------------------------------#
Variable Decimal VALEUR
If VALEUR=0 mkstat=2 : Endif
Look [POC] POC0=[M:POD1]POHNUM;VALEUR
If fstat GMESSAGE=mess(23,100,1): mkstat=2 : Endif
End


Subprog IB_NBLIG
#------------------------#
# Activation des boutons #
#------------------------#
# Issue 17667 - 2012-01-16 by VPO : ajout visu des DA consommées sur POD1 - GBOUT9
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT9
#----- L'utilisateur a-t-il droit à la modification ? -----#
GBIDC2="M" : Gosub AUTORIS_OPT From CONTX3
If GBIDI2 & date$<=[M:POD1]ENDDAT  GBOUT2=mess(99,198,1) : Endif : # Besoins
If [M:POD1]NBLIG>0
  If nolign<=dim([M:POD1]WIPSTA)
    If [M:POD1]WRCPDAT(nolign-1)<>""
      GBOUT5=mess(38,198,1)        : # Texte
      If [M:POD1]WIPSTA(nolign-1)=1
        If GMODU(2)=2 : # Test présence du module compta
          # Issue 118288 - 2016-10-05 by MUARN : axe et budget
          #GBOUT1=mess(37,198,1)    : # Budget
          If [M:POD1]POQSEQ(nolign-1)<>0
            If dim([M:POD1]NBAXE)>0
              Local Char    CRITERE(250)
              If !clalev([F:CAL])  Local File CPTANALIN  [CAL] : Endif
              If !clalev([F:PO3])  Local File PORDERP    [PO3] : Endif
              CRITERE = "POHNUM=[M:POD1]POHNUM & POPLIN=[M:POD1]POPLIN"
              # Issue X3-74127 - 2018-03-19 by MUARN : WRCPDAT n'est pas au format date EXTRCPDAT l'est
              #CRITERE -= ' & STRDAT<= [' +format$(GFMD,[M:POD1]WRCPDAT(nolign-1))+']'
              CRITERE -= ' & STRDAT <= [M:POD1]EXTRCPDAT(nolign-1)'
              Filter [PO3] Where evalue(CRITERE)
              Read [PO3] POP1 Last : If fstat Raz [F:PO3] : Endif
              Filter [PO3]
              If [F:PO3]POHNUM<>""
                GBOUT1=mess(37,198,1)    : # Budget
                Read [CAL] CAL0="POP";0;[M:POD1]POHNUM;[M:POD1]POPLIN;[F:PO3]POPSEQ : If fstat  Raz [F:CAL] : Endif
                Call CHARG_CCEX("POD1","NBAXE","CAL","DIE","CCE") From TRTX3CPT
              Endif
            Endif
          Endif
          If GPURCMM=2 & [M:POD1]CMMNUM(nolign-1)<>""
            GBOUT6=mess(160,198,1) : # Engagement
          Endif
        Endif
      Endif
      #---
      # Issue 17667 - 2012-01-16 by VPO : ajout visu des DA consommées sur POD1 - GBOUT9
      If [M:POD1]RETQTYPUU(nolign-1)>0  &
&        [M:POD1]BETFCY<>2
        If [M:POD1]CREFLG(nolign-1)<>0
          Filter [PSO] Where POHNUM=[M:POD1]POHNUM
&                          & POPLIN=[M:POD1]POPLIN
&                          & POQSEQ=[M:POD1]POQSEQ(nolign-1)
          Look [PSO] PSO1 First
          Filter [PSO]
        Else
          Filter [PWO] Where PRONUM=adxuid(1)
&                          & CODFNC="POD"
&                          & LINNUM=[M:POD1]POHLIN(nolign-1)
&                          & WIPTYP=2
&                          & WIPSTA=2
          Look [PWO] PWO0 First
          Filter [PWO]
        Endif
        If !fstat
          GBOUT9=mess(387,198,1)  : # Visualisation DA consommées
        Endif
      Endif
      #---
      If [M:POD1]CAD(nolign-1)<>1
        GBOUT4=mess(11,198,1)      : # Eclatement
      Endif
      If [M:POD1]CAD(nolign-1)=1
        GBOUT3=mess(12,198,1)      : # Solde
      Endif
    Endif
  Endif
Endif
#----- Si solde non autorisé, désactivation du bouton de solde -----#
GBIDC2="T": Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  Raz GBOUT3 : Endif
End


Subprog B3_NBLIG
#------------------------------------------------------------#
# Solde de la ligne cadencement jour                         #
# Attention les lignes soldées peuvent être affichées        #
# On ne peut pas modifier une ligne soldée par une réception #
#------------------------------------------------------------#
If [M:POD1]WRCPDAT(nolign-1)=""   End : Endif
If [M:POD1]CAD(nolign-1)<>1
  GMESSAGE=mess(92,194,1) : GERR=1 : End
Endif
If [M:POD1]PTHNUM(nolign-1)<>"" & [M:POD1]SALFCY=""
  GMESSAGE=mess(93,194,1) : GERR=1 : End
Endif
If [F:POH]CLEFLG=2
  GMESSAGE=mess(47,194,1) : GERR=1 : End
Endif
If [F:POH]APPFLG<3
  GMESSAGE=mess(84,194,1) : GERR=1 : End
Endif
#-----
Local Integer WRETOUR
If [M:POD1]LINSTA(nolign-1)=3
  #----- Dé-solde de la ligne oui/non -----#
  Call OUINON(mess(43,194,1),WRETOUR) From GESECRAN
  If WRETOUR=1  End : Endif
Elsif [M:POD1]BETFCY=2 & [M:POD1]SALFCY<>"" & [M:POD1]CREFLG(nolign-1)<>0
  #----- Solde côté achats permis si la ligne est soldée côté ventes -----#
  If clalev([F:SOQ])=0 Local File SORDERQ [SOQ] : Endif
  If [F:SOQ]SOHNUM<>[M:POD1]OCNNUM |
&    [F:SOQ]SOPLIN<>[M:POD1]OCNLIN |
&    [F:SOQ]SOQSEQ<>[M:POD1]OCNSEQ(nolign-1)
    Read [SOQ] SOQ0=[M:POD1]OCNNUM;[M:POD1]OCNLIN;[M:POD1]OCNSEQ(nolign-1)
    If fstat Raz [F:SOQ] : Endif
  Endif
  If [F:SOQ]SOQSTA=3
    Call OUINON(mess(226,194,1),WRETOUR) From GESECRAN
    If WRETOUR=1 End : Endif
  Else
    #--- Si lignes "vierges" il vaut mieux passer par la suppression ---#
#   If [F:SOQ]ALLQTY=0 & [F:SOQ]ODLQTY=0      : # Contrôle bloquant supprimé !
#     GMESSAGE=mess(225,194,1) : GERR=1 : End : # Solde permis demande 10004
#   Endif                                     : #       du 07/09/2001
    #--- Contrôles supplément. pour contrat inter-site si solde d'une ancienne ligne ---#
    Raz [M:SORW]
    [M:SORW]MAJCOD = "S"                      : # Solde
    [M:SORW]SOHNUM = [M:POD1]OCNNUM           : # No contrat vente
    [M:SORW]SOPLIN = [M:POD1]OCNLIN           : # No ligne article (identique achat-vente)
    [M:SORW]SOQSEQ = [M:POD1]OCNSEQ(nolign-1) : # No séquence DL vente
    Call CTL_MAJ_SOQ From TRTVENMSIT
    If GMESSAGE<>""  GERR=1 : End : Endif
  Endif
Endif
If [M:POD1]LINSTA (nolign-1)= 2
  #----- Si ligne en retard, mise a jour avance-retard uniquement sur du ferme -----#
  If [M:POD1]WIPSTA(nolign-1)=1
    [M:POD1]XEARQTY-=[M:POD1]QTYPUU(nolign-1)
  Endif
  [M:POD1]LINSTA(nolign-1)=3
Elsif [M:POD1]LINSTA(nolign-1)=3
  #-- Ligne soldée on réactive si date demande < date jour màj av-ret et sur du ferme --#
  If [M:POD1]EXTRCPDAT(nolign-1)<date$
    If [M:POD1]WIPSTA(nolign-1)=1
      [M:POD1]XEARQTY+=[M:POD1]QTYPUU(nolign-1)
    Endif
    [M:POD1]LINSTA(nolign-1)=2
  Else
    [M:POD1]LINSTA(nolign-1)=1
  Endif
Else
  [M:POD1]LINSTA(nolign-1)=3
Endif
[M:POD1]UPDFLG(nolign-1)=1
If !GIMPORT Affzo [POD1]XEARQTY, LINSTA(nolign-1) : Endif
mkstat=4 : GMODIF=9
End


$AB6_NBLIG
#-------------------------------------------------#
# Avant exécution du bouton tunnel sur engagement #
#-------------------------------------------------#
Local Shortint NOL             : NOL=nolign-1
Local Char     WOBJET(GLONAOB) : WOBJET="CMM"
Local Char     WCLE1 (GLONVCR) : WCLE1=[M:POD1]CMMNUM(NOL)
Local Char     WCLE2 (GLONVCR) : WCLE2=""
If [M:POD1]NBLIG=0 | [M:POD1]WRCPDAT(NOL)="" | [M:POD1]CMMNUM(NOL)="" |
&  GMODU(2)<>2 | GPURCMM<>2
  WOBJET=""
Endif
Return

Subprog C_NBLIG
#-------------------------------------------------#
# Il y a généralement des contrôles pour vérifier #
# qu'on peut annuler ou modifier une ligne        #
#-------------------------------------------------#
If GMODIF=9 status=131 : Endif : # Bouton Solde pour le WEB
GMODIF=1
If GREP = "C"  : End : Endif
Local Integer NOL
If    status=65             : # Annulation simple
      NOL=nolign-1 : Gosub TEST_ANU
Elsif status=68 | status=83 : # Annulation multiple
      For NOL=nolign-1 To nolign1-1
          Gosub TEST_ANU
          If mkstat : Break : Endif
      Next NOL
Endif
If status=75             NOL=nolign-1 : Gosub TEST_MOD    : Endif
If status=73 | status=82 NOL=nolign-1 : Gosub TEST_INSERT : Endif
If find(status,1,4,5,20,21,26,92,93) |
&      (status>128 & status<141)        Gosub TEST_VALID  : Endif
End

$TEST_INSERT
#-----------------------------------#
# Test pour l'insertion d'une ligne #
#-----------------------------------#
Return

$TEST_MOD
#------------------------------------#
# Test pour modification d'une ligne #
#------------------------------------#
If [M:POD1]LINSTA(NOL)=3
  GMESSAGE=mess(32,194,1) : # Ligne commande soldée. Modif ou suppress interdite.
  mkstat=2 : GMODIF=0 : Return
Endif
If [M:POD1]BETFCY=2 & [M:POD1]SALFCY<>"" & [M:POD1]CREFLG(nolign-1)<>0
  #---------------------------------------------------------------------------------#
  # Contrôles supplémentaires pour contrat inter-site si modif d'une ancienne ligne #
  #---------------------------------------------------------------------------------#
  Raz [M:SORW]
  [M:SORW]MAJCOD = "M"                 : # Modification
  [M:SORW]SOHNUM = [M:POD1]OCNNUM      : # No contrat vente
  [M:SORW]SOPLIN = [M:POD1]OCNLIN      : # No ligne article (identique achat-vente)
  [M:SORW]SOQSEQ = [M:POD1]OCNSEQ(NOL) : # No séquence DL vente
  Call CTL_MAJ_SOQ From TRTVENMSIT
  If GMESSAGE<>"" mkstat=2 : GMODIF=0 : Return : Endif
Endif
Return

$TEST_ANU
#----------------------------------#
# Test pour annulation de la ligne #
#----------------------------------#
If [M:POD1]LINSTA(NOL)=3
  GMESSAGE=mess(32,194,1) : # Ligne commande soldée. Modif ou suppress interdite.
  mkstat=2 : GMODIF=0 : Return
Elsif [M:POD1]INVQTYPUU(NOL)<>0
  GMESSAGE=mess(442,197,1)-mess(54,123,1) : # Ligne facturée Suppression impossible
  mkstat=2 : Return
Endif
If [M:POD1]BETFCY=2 & [M:POD1]SALFCY<>"" & [M:POD1]CREFLG(nolign-1)<>0
  #------------------------------------------------------------------------------------#
  # Contrôles supplémentaires pour contrat inter-site si suppress d'une ancienne ligne #
  #------------------------------------------------------------------------------------#
  Raz [M:SORW]
  [M:SORW]MAJCOD = "A"                 : # Suppression (Annulation)
  [M:SORW]SOHNUM = [M:POD1]OCNNUM      : # No contrat vente
  [M:SORW]SOPLIN = [M:POD1]OCNLIN      : # No ligne article (identique achat-vente)
  [M:SORW]SOQSEQ = [M:POD1]OCNSEQ(NOL) : # No séquence DL vente
  Call CTL_MAJ_SOQ From TRTVENMSIT
  If GMESSAGE<>"" mkstat=2 : GMODIF=0 : Return : Endif
Endif
Return

$TEST_VALID
#-----------------------------------------------------#
# Test à la validation des lignes, on sort du tableau #
#-----------------------------------------------------#
Return


Subprog AVANT_NBLIG
#-------------#
# Avant ligne #
#-------------#
#----- Mise à jour qté en cde sur PORDERC, test du statut ferme -----#
If [M:POD1]WIPSTA(nolign-1)=1
  [M:POD1]ORDQTYPUU -= [M:POD1]QTYPUU(nolign-1)
  If [M:POD1]LINSTA(nolign-1)=2
    [M:POD1]XEARQTY -= [M:POD1]QTYPUU(nolign-1)
  Endif
Endif

# Issue 90991 - 2013-11-04 by MUARN : ajout SDC au niveau site
If [M:POD1]STCNUM(nolign-1)<> ""
  Diszo [POD1]CPRAMT(nolign-1), CPRCOE(nolign-1)
Else
  Actzo [POD1]CPRAMT(nolign-1), CPRCOE(nolign-1)
Endif

#----- Avant ligne : Si suppression ligne, suppression besoins ligne -----#
If status=65 | status=68 | status=83
  Gosub EFFAC_LIG_PWRKORDERS From SUBPODA
  #----- Suppression du texte ligne si la ligne est créée et supprimée -----#
  If [M:POD1]CREFLG(nolign-1)=0 & left$([M:POD1]LINTEX(nolign-1),3)="POQ"
    Call SUP_CLOB([M:POD1]LINTEX(nolign-1),GBIDI1) From TRTX3TEX
  Endif
Endif
End


Subprog APRES_NBLIG
#-------------#
# Après ligne #
#-------------#
If status=6 | status=7 | status=27 | status=28 | [M:POD1]WRCPDAT(nolign-1)=""
  #----- Si abandon ligne, suppression besoins ligne -----#
  If [M:POD1]POHLIN(nolign-1)=0 & [M:POD1]CTLPOHCOU<>0
    [M:POD1]POHLIN(nolign-1)=[M:POD1]CTLPOHCOU
    Gosub EFFAC_LIG_PWRKORDERS From SUBPODA
    Raz [M:POD1]POHLIN(nolign-1), [M:POD1]CTLPOHCOU
  Endif
Endif
Raz [M:POD1]CTLPOHCOU
#----- Mise à jour qté en cde sur PORDERC, test du statut ferme -----#
If [M:POD1]WIPSTA(nolign-1)=1
  [M:POD1]ORDQTYPUU += [M:POD1]QTYPUU(nolign-1)
  If [M:POD1]LINSTA(nolign-1)=2
    [M:POD1]XEARQTY += [M:POD1]QTYPUU(nolign-1)
  Endif
Endif
Affzo [POD1]XEARQTY
End


Subprog AS_WRCPDAT(VALEUR)
#------------------------------#
# Avant saisie période demande #
#------------------------------#
Variable Char    VALEUR()
#If [M:POD1]CREFLG(nolign-1)<>0 | GMODIF=0 mkstat=2 : Endif
If ([M:POD1]BETFCY=2 & [M:POD1]CREFLG(nolign-1)<>0) | GMODIF=0  mkstat=2 : Endif
End


Subprog C_WRCPDAT(VALEUR)
#--------------------------#
# Contrôle période demande #
#--------------------------#
Variable Char    VALEUR()
#If VALEUR=[M:POD1]WRCPDAT(nolign-1)  End : Endif
#-------------------------------------------------#
# Dans zone saisie on enleve les caractères alpha #
# on chasse les blancs aussi                      #
# ensuite on regarde si jour - semaine ou mois    #
#-------------------------------------------------#
[M:POD1]CAD (nolign-1) = 0
[M:POD1]YEA (nolign-1) = 0
[M:POD1]WEE (nolign-1) = 0
[M:POD1]MON (nolign-1) = 0
Local Char WDATE (10), A(1)
WDATE=""
For I=1 To len(VALEUR)
  A=mid$(VALEUR,I,1)
  If ascii(A)>=48 & ascii(A)<=57
    WDATE += A
  Endif
Next I
Case len(WDATE)
  When 4       : Gosub LENDAT4 From SUBPODA : # cadencement mois
  When 5       : Gosub LENDAT5 From SUBPODA : # cadencement semaine
  When 6       : Gosub LENDAT6 From SUBPODA : # cadencement jour ou mois
  When 7       : Gosub LENDAT7 From SUBPODA : # cadencement semaine
  When 8       : Gosub LENDAT8 From SUBPODA : # cadencement jour
  When Default : mkstat = 2
Endcase
If mkstat=2 | [M:POD1]CAD(nolign-1)=0
  GMESSAGE=mess(68,194,1) : End
Endif
VALEUR=WDATE
#----- On vérifie que cadencement >= cadencement ligne précédente -----#
If nolign>1 & [M:POD1]CAD(nolign-1)<[M:POD1]CAD(nolign-2)
  GMESSAGE=mess(77,194,1) : mkstat=2 : End
Endif
#----- On vérifie que cadencement <= cadencement ligne suivante -----#
If nolign<[M:POD1]NBLIG & [M:POD1]CAD(nolign-1)>[M:POD1]CAD(nolign)
  GMESSAGE=mess(77,194,1) : mkstat=2 : End
Endif

# Issue 90991 - 2013-11-05 by MUARN : ajout SDC au niveau site
# Issue 120000 - 2016-11-25 by SR : sr si première ligne : XPRHFCY déjà chargé
If [M:POD1]XPRHFCY(nolign-1)="" | nolign=1
  Local    Decimal  WCPRAMT, WCPRAMTDEV
  Local    Integer  STAT
  Call RECH_COST([M:POD1]PRHFCY,[M:POD1]BPSNUM, [M:POD1]ITMREF, [M:POD1]CPRCOE(nolign-1), WCPRAMT, [M:POD1]STCNUM(nolign-1)) From STCLIB
  If GLOCALDEV <> GSYSCUR
    Call CONVERT2(GSYSCUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                       WCPRAMT,WCPRAMTDEV,STAT) From TRTDEV
    [M:POD1]CPRAMT(nolign-1)=arr(WCPRAMTDEV,10^-GDECPRI)
  Else
   [M:POD1]CPRAMT(nolign-1) = WCPRAMT
  Endif
  If [M:POD1]CPRCOE(nolign-1)=0 [M:POD1]CPRCOE(nolign-1)=1 Endif
  [M:POD1]CPRCUR(nolign-1)=GCUR
  If [M:POD1]STCNUM(nolign-1)<> ""
    Diszo [POD1]CPRAMT(nolign-1), CPRCOE(nolign-1)
  Else
    Actzo [POD1]CPRAMT(nolign-1), CPRCOE(nolign-1)
  Endif
Endif

#--------------------------------------------------------------------#
# Calcul de la date                                                  #
#  si jour :  calcul du numéro de la semaine                         #
#             strrcpdat = extrccpdat                                 #
#  si sem  :  calcul dernier jour semaine dans extrcpdat             #
#             calcul premier jour semaine dans strrcpdat             #
#  si mois :  calcul premiere semaine mois                           #
#             calcul premier jour mois    dans strrcpdat             #
#             calcul dernier jour mois    dans extrcpdat             #
# attention a semaine 53 si le jeudi appartient à l'année suivante   #
# attention a semaine 0  idem                                        #
#--------------------------------------------------------------------#
If [M:POD1]CAD(nolign-1)=1
  If left$(GFMDAT,2)="YY"
    #----- GFMDAT=YY/MM/DD   WDATE=AAAA-MM-JJ
    [M:POD1]YEA(nolign-1)      =val(left$(VALEUR,4))
    [M:POD1]MON(nolign-1)      =val(mid$(VALEUR,6,2))
    [M:POD1]EXTRCPDAT(nolign-1)=gdat$(val(right$(VALEUR,9)),[M]MON(nolign-1),[M]YEA(nolign-1))
  Elsif left$(GFMDAT,2)="MM" & right$(GFMDAT,len(GFMDAT)-1)="YY"
    #----- GFMDAT=MM/DD/YY   WDATE=MM-JJ-AAAA
    [M:POD1]YEA(nolign-1)      =val(right$(VALEUR,7))
    [M:POD1]MON(nolign-1)      =val(left$(VALEUR,2))
    [M:POD1]EXTRCPDAT(nolign-1)=gdat$(val(mid$(VALEUR,4,2)),[M]MON(nolign-1),[M]YEA(nolign-1))
  Else    : #  wdate = jj-mm-aaaa
    [M:POD1]YEA(nolign-1)      =val(right$(VALEUR,7))
    [M:POD1]MON(nolign-1)      =val(mid$(VALEUR,4,2))
    [M:POD1]EXTRCPDAT(nolign-1)=gdat$(val(left$(VALEUR,2)),[M]MON(nolign-1),[M]YEA(nolign-1))
  Endif
  #----- Ajustement date théorique de réception en fonction des indisponibilités -----#
  If [M:POD1]XPRHFCY(nolign-1)=""  [M:POD1]XPRHFCY(nolign-1)=[M:POD1]PRHFCY : Endif
  If [F:FCY]FCY<>[M:POD1]XPRHFCY(nolign-1)
    Read [FCY] FCY0=[M:POD1]XPRHFCY(nolign-1) : If fstat Raz [F:FCY] : Endif
  Endif
  If nolign>1
    GBIDA1=[M:POD1]EXTRCPDAT(nolign-2)
  Else
    GBIDA1=[M:POD1]EXTRCPDAT(nolign-1)
  Endif
  Call CTL_JOU2([M:POD1]EXTRCPDAT(nolign-1),GBIDA1,[F:FCY]UVYDAY,[F:FCY]UVYCOD,1) From CONTX3
  If mkstat
    End
  Else
    VALEUR=format$("D:"+GFMDAT4,gdat$(val(right$([M:POD1]EXTRCPDAT(nolign-1),7)),
&                                     val(mid$  ([M:POD1]EXTRCPDAT(nolign-1),5,2)),
&                                     val(left$ ([M:POD1]EXTRCPDAT(nolign-1),4))))
  Endif
  #-----
  [M:POD1]STRRCPDAT(nolign-1)=[M:POD1]EXTRCPDAT(nolign-1)
  [M:POD1]WEE(nolign-1)      =week([M]EXTRCPDAT(nolign-1))
  If [M:POD1]WEE(nolign-1)=53
    #----- On regarde si le 4 jour de la semaine est sur annee suivante -----#
    If year(aweek([M:POD1]WEE(nolign-1),[M:POD1]YEA(nolign-1))+ 3)<>[M:POD1]YEA(nolign-1)
      [M:POD1]WEE(nolign-1)=1
    Endif
  Elsif [M:POD1]WEE(nolign-1)=0
    #----- On regarde si le 4 jour est sur l année précédente -----#
    If dayn(aweek([M:POD1]WEE(nolign-1),[M:POD1]YEA(nolign-1))+3)<4
      [M:POD1]WEE(nolign-1)=01
    Else
      [M:POD1]WEE(nolign-1)=53
    Endif
  Endif
Elsif [M:POD1]CAD(nolign-1)=2
  [M:POD1]YEA(nolign-1)      =val(right$(VALEUR,5))
  [M:POD1]WEE(nolign-1)      =val(left$(VALEUR,3))
  [M:POD1]EXTRCPDAT(nolign-1)=aweek([M:POD1]WEE(nolign-1),[M:POD1]YEA(nolign-1))+6
  [M:POD1]STRRCPDAT(nolign-1)=aweek([M:POD1]WEE(nolign-1),[M:POD1]YEA(nolign-1))
Else
  [M:POD1]YEA(nolign-1)      =val(right$(VALEUR,4))
  [M:POD1]MON(nolign-1)      =val(left$(VALEUR,2))
  #----- Dernier jour du mois -----#
  [M:POD1]STRRCPDAT(nolign-1)=gdat$(1,[M:POD1]MON(nolign-1),[M:POD1]YEA(nolign-1))
  [M:POD1]EXTRCPDAT(nolign-1)=eomonth([M:POD1]STRRCPDAT(nolign-1))
  #-----------------------------------------------------------------#
  # Calcul premiere semaine mois  attention au 4 jour de la semaine #
  # premier jour du mois                                            #
  # semaine de ce jour  si le 4 jour est dans le mois ok            #
  #                     sinon + 1 dans semaine attention a année    #
  #-----------------------------------------------------------------#
  [M:POD1]STRRCPDAT(nolign-1)=gdat$(1,[M:POD1]MON(nolign-1),[M:POD1]YEA(nolign-1))
  [M:POD1]WEE(nolign-1)      =week([M:POD1]STRRCPDAT(nolign-1))
  If dayn([M:POD1]STRRCPDAT(nolign-1))>4
    [M:POD1]WEE(nolign-1)+=1
    If [M:POD1]WEE(nolign-1)=53
      #----- On regarde si le 4 jour de la semaine est sur annee suivante -----#
      If year(aweek([M:POD1]WEE(nolign-1),[M:POD1]YEA(nolign-1))+3)<>[M:POD1]YEA(nolign-1)
        [M:POD1]WEE(nolign-1)=1
      Endif
    Elsif [M:POD1]WEE(nolign-1)=0
      [M:POD1]WEE(nolign-1)=1
    Endif
    #----- Recalcul du premier jour du mois = premier jour de la première semaine -----#
    [M:POD1]STRRCPDAT(nolign-1)=aweek([M:POD1]WEE(nolign-1),[M:POD1]YEA(nolign-1))
  Endif
Endif
#----- La date doit être > à date du jour -----#
#If [M:POD1]EXTRCPDAT(nolign-1)<date$
#  GMESSAGE=mess(65,194,1) : mkstat = 2 : End
#Endif
#----- La date doit être > à date debut validité -----#
If [M:POD1]EXTRCPDAT(nolign-1)<[M:POD1]STRDAT
  GMESSAGE=mess(78,194,1) : mkstat = 2 : End
Endif
#-----------------------------------#
# La date doit être > à date av-ret #
# inutilise puisque xeardat = date$ #
#-----------------------------------#
#If [M:POD1]EXTRCPDAT(nolign-1)<[M:POD1]XEARDAT
#  GMESSAGE=mess(66,194,1) : mkstat = 2 : End
#Endif
#----- La date doit être < à date fin validité -----#
If [M:POD1]EXTRCPDAT(nolign-1)>[M:POD1]ENDDAT
  GMESSAGE=mess(67,194,1) : mkstat = 2 : End
Endif
#----- On vérifie date avec ligne précédente ou suivante -----#
If nolign>1
  If [M:POD1]CAD(nolign-1)=1 & [M:POD1]CAD(nolign-2)=1
    If [M:POD1]EXTRCPDAT(nolign-1)<[M:POD1]EXTRCPDAT(nolign-2)
      GMESSAGE=mess(77,194,1) : mkstat = 2 : End
    Endif
  Else
    If [M:POD1]EXTRCPDAT(nolign-1)<=[M:POD1]EXTRCPDAT(nolign-2)
      GMESSAGE=mess(77,194,1) : mkstat = 2 : End
    Endif
  Endif
Endif
If nolign<[M:POD1]NBLIG
  If [M:POD1]CAD(nolign-1)=1 & [M:POD1]CAD(nolign)=1
    If [M:POD1]EXTRCPDAT(nolign-1)>[M:POD1]EXTRCPDAT(nolign)
      GMESSAGE=mess(77,194,1) : mkstat = 2 : End
    Endif
  Else
    If [M:POD1]EXTRCPDAT(nolign-1)>=[M:POD1]EXTRCPDAT(nolign)
      GMESSAGE=mess(77,194,1) : mkstat = 2 : End
    Endif
  Endif
Endif
#----- On vérifie date début avec lig précédente-suivante -----#
If nolign>1
  If [M:POD1]CAD(nolign-1)=1 & [M:POD1]CAD(nolign-2)=1
    If [M:POD1]STRRCPDAT(nolign-1)<[M:POD1]STRRCPDAT(nolign-2)
      GMESSAGE=mess(77,194,1) : mkstat = 2 : End
    Endif
  Else
    If [M:POD1]STRRCPDAT(nolign-1)<=[M:POD1]STRRCPDAT(nolign-2)
      GMESSAGE=mess(77,194,1) : mkstat = 2 : End
    Endif
  Endif
  #----- Date début ne doit pas être inférieure à date fin ligne précédente -----#
  If [M:POD1]STRRCPDAT(nolign-1)<[M:POD1]EXTRCPDAT(nolign-2)
    GMESSAGE=mess(77,194,1) : mkstat = 2 : End
  Endif
Endif
If nolign<[M:POD1]NBLIG
  If [M:POD1]CAD(nolign-1)=1 & [M:POD1]CAD(nolign)=1
    If [M:POD1]STRRCPDAT(nolign-1)>[M:POD1]STRRCPDAT(nolign)
      GMESSAGE=mess(77,194,1) : mkstat = 2 : End
    Endif
  Else
    If [M:POD1]STRRCPDAT(nolign-1)>=[M:POD1]STRRCPDAT(nolign)
      GMESSAGE=mess(77,194,1) : mkstat = 2 : End
    Endif
  Endif
Endif
If [M:POD1]CAD(nolign-1)=1 | [M:POD1]CAD(nolign-1)=3  Goto FINCTRDAT : Endif
#----- Test sur cadencement semaine -----#
If [M:POD1]WEE(nolign-1)=0
  GMESSAGE=mess(73,194,1) : mkstat = 2 : End
Endif
#-------------------------------------------#
# Test numéro semaine avec ligne précédente #
# certainement test inutile mais on conserve#
#-------------------------------------------#
If nolign>1
  If [M:POD1]CAD(nolign-1)=2 & [M:POD1]YEA(nolign-1)=[M:POD1]YEA(nolign-2)
    If [M:POD1]WEE(nolign-1)<=[M:POD1]WEE(nolign-2)
      GMESSAGE=mess(77,194,1) : mkstat = 2 : End
    Endif
  Endif
Endif
#----- Test sur semaine suivante -----#
If nolign<[M:POD1]NBLIG
  If [M:POD1]CAD(nolign-1)=2 & [M:POD1]YEA(nolign-1)=[M:POD1]YEA(nolign)
    If [M:POD1]WEE(nolign-1)>=[M:POD1]WEE(nolign)
      GMESSAGE=mess(77,194,1) : mkstat = 2 : End
    Endif
  Endif
Endif
#----- Test sur semaine système sur la première ligne -----#
If nolign=1 & [M:POD1]WEE(0)<=[M:POD1]WEESYST
  If [M:POD1]YEA(0)=[M:POD1]YEASYST
    GMESSAGE=mess(75,194,1) : mkstat  = 2 : End
  Endif
Endif
#----- Test sur semaine date fin validité -----#
If [M:POD1]WEE(nolign-1)>[M:POD1]WEEENDDAT
  If [M:POD1]YEA(nolign-1)=[M:POD1]YEAENDDAT
    GMESSAGE=mess(76,194,1) : mkstat = 2 : End
  Endif
Endif
$FINCTRDAT
#----- Contrôle article en fin de vie ------#
If [F:ITM]ITMREF<>[M:POD1]ITMREF
  Read [ITM] ITM0=[M:POD1]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITM]LIFENDDAT<>[0/0/0] & [F:ITM]LIFENDDAT<[M:POD1]EXTRCPDAT(nolign-1)
  mkstat=1 : GMESSAGE=mess(12,318,1) : End
Endif
#----- Contrôle statut de l'article -----#
If [F:ITM]ITMSTA<>1 & [F:ITM]ITMSTA<>3
  GMESSAGE=mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")"
  mkstat=1 : End
Endif
#----- Etat de la ligne : en retard si < date jour -----#
If [M:POD1]EXTRCPDAT(nolign-1)<date$
  [M:POD1]LINSTA(nolign-1)=2
Else
  [M:POD1]LINSTA(nolign-1)=1
Endif
Affzo [POD1]LINSTA(nolign-1)
End


Subprog AM_WRCPDAT(VALEUR)
#-----------------------------------#
# Après modif de la période demande #
#-----------------------------------#
Variable Char    VALEUR()
#----- Avertissement : La date devrait être > à date du jour -----#
Local Integer OK
If [M:POD1]EXTRCPDAT(nolign-1)<date$
  OK=2 : Call AVERTIR(mess(65,194,1), OK) From GESECRAN
  If OK<>2  mkstat=1 : End : Endif
Endif
#----- Cadencement différent de jour --> statut = Planifié -----#
If [M:POD1]CAD(nolign-1)<>1
  [M:POD1]WIPSTA(nolign-1)=2
#---------------------------------------------------------------------------#
# Valeur par défaut du statut lorsque le cadencement est en jour :          #
#   - Planifié : si date de réception prévue > date du jour + horizon ferme #
#   - Ferme    : dans les autres cas                                        #
#---------------------------------------------------------------------------#
Elsif [M:POD1]WIPSTA(nolign-1)=0 | [M:POD1]CREFLG(nolign-1)=0
  If [M:POD1]EXTRCPDAT(nolign-1)>date$+[F:POC]FIMHOR
    [M:POD1]WIPSTA(nolign-1)=2
  Else
    [M:POD1]WIPSTA(nolign-1)=1
  Endif
Endif
#-----
If [M:POD1]LINACC(0)="" & [M:POD1]LINACC(1)=""
  Call INIT_COMPTES_LIGNE(nolign-1)
Endif
If [M:POD1]LINPURTYP=0
  Call INIT_LINPURTYP
Endif
#----- Optimisation du séquencement si possible -----#
If [M:POD1]POQSEQ(nolign-1)<>0
  Local Integer SAV_STATUS : SAV_STATUS=status
  status=65 : Call C_NBLIG : # La ligne est-elle "supprimable" ?
  If !mkstat
    # Issue 79317 - 2012-01-16 by VPO : perte des liens prequiso par exemple
    #----- Si DA prise en compte, il faut la récupérer pour la nouvelle ligne -----#
    Gosub RECUP_BESOIN
    #-----
    [M:POD1]POQSEQ(nolign-1)=0
    [M:POD1]CREFLG(nolign-1)=0
    [M:POD1]UPDFLG(nolign-1)=1
    [M:POD1]CMMNUM(nolign-1)=""
  Else
    Raz mkstat, GMESSAGE
  Endif
  status=SAV_STATUS
Endif
#-----

End

$RECUP_BESOIN
    #----- Si DA prise en compte, il faut la récupérer pour la nouvelle ligne -----#
    If [M:POD1]RETQTYPUU(nolign-1)<>0 & [M:POD1]POHLIN(nolign-1)=0
      Call DEBTRANS From GLOCK
      Trbegin [PWO]
      [F:PWO]PRONUM=adxuid(1)
      [F:PWO]CODFNC="POD"
      [F:PWO]WIPTYP=2
      [F:PWO]WIPSTA=2
      [F:PWO]ITMREF=[M:POD1]ITMREF
      For [PSO] PSO1 Where POHNUM=[M:POD1]POHNUM
&                        & POPLIN=[M:POD1]POPLIN
&                        & POQSEQ=[M:POD1]POQSEQ(nolign-1)
        If [M:POD1]POHLIN(nolign-1)=0
          [M:POD1]POHCOU+=1 : [M:POD1]POHLIN(nolign-1)=[M:POD1]POHCOU
        Endif
        [F:PWO]LINNUM=[M:POD1]POHLIN(nolign-1)
        [F:PWO]WIPNUM=[F:PSO]PSHNUM
        [F:PWO]PSDLIN=[F:PSO]PSDLIN
        [F:PWO]QTYPUU=[F:PSO]QTYPUU
        [F:PWO]PUU   =[F:PSO]PUU
        [F:PWO]QTYSTU=[F:PSO]QTYSTU
        [F:PWO]STU   =[F:PSO]STU
        Write [PWO]
        If fstat  GOK=0 : Call FSTA("PWO") From GLOCK : Break : Endif
      Next
      If GOK=1  Commit  Else  Raz [M:POD1]POHLIN(nolign-1) : Rollback : Endif
    Endif
Return

Subprog AS_WIPSTA(VALEUR)
#---------------------#
# Avant saisie statut #
#---------------------#
Variable Integer  VALEUR
If GMODIF=0  mkstat=2 : End : Endif
Local    Integer  NOL  : NOL=nolign-1
#----- Contrôle modif statut autorisée (LLC) -----#
If [M:POD1]BETFCY=2 & [M:POD1]SALFCY<>"" & [M:POD1]CREFLG(NOL)<>0
  Raz [M:SORW]
  [M:SORW]MAJCOD = "T"                 : # Modification
  [M:SORW]SOHNUM = [M:POD1]OCNNUM      : # No contrat vente
  [M:SORW]SOPLIN = [M:POD1]OCNLIN      : # No ligne article (identique achat-vente)
  [M:SORW]SOQSEQ = [M:POD1]OCNSEQ(NOL) : # No séquence DL vente
  Call CTL_MAJ_SOQ From TRTVENMSIT
  If [M:SORW]ERRCOD<>0  mkstat=2 : End : Endif
Endif
#-- Filtre menu local on désactive tout et on active type d'ordre ferme planifié --#
If dim(GMENLOC)>0
  For I=1 To dim(GMENLOC)-1
    GMENLOC(I)=1
  Next I
  GMENLOC(1)=0 : GMENLOC(2)=0
Endif
#----- Cadencement différent de jour --> statut = Planifié sans saisie -----#
If [M:POD1]CAD(nolign-1)<>1
  VALEUR=2 : mkstat=2 : End
Endif
End


Subprog AP_WIPSTA(VALEUR)
#-------------------#
# Après zone statut #
#-------------------#
Variable Integer  VALEUR
Raz GMENLOC
End


Subprog D_WIPTYP(VALEUR)
