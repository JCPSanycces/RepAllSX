########################################################################
# INIT_COMPTES_LIGNE : S/P d'initialisation               MBT 20/09/06 #
#                des comptes d'une ligne de contrat                    #
# -------------------------------------------------------------------- #
# Subprog INIT_COMPTES_LIGNE (NOL)                                     #
#   NOL    : Indice de la ligne de DL en cours (nolign-1)              #
########################################################################
Subprog INIT_COMPTES_LIGNE (NOL)
Value    Shortint NOL
#-----
Local    Shortint I
If [M:POD1]NBCOA=0
  [M:POD1]NBCOA=GNBCOA
  For I=1 To GNBCOA
    [M:POD1]COA(I-1)=GCOA(I)
  Next I
Endif
#----- Chargement de comptes avec "" pour désactiver l'action d'init -----#
For I=1 To GNBCOA
  [M:POD1]LINACC(I-1)=""
Next I
#-----
Local    Char     ID1(20)(1..1), ID2(20)(1..3)
Local    Shortint J, SAVNOLIGN : SAVNOLIGN=nolign
Local    Integer  STA
Local    Char     TPLAN  (GLONCOA)(1..10)
Local    Char     TCOMPTE(GLONGAC)(1..10)
Local    Char     WMESSAGE(80)
#-----
If !clalev([F:GAD])  Local File GAUTACED [GAD] : Endif
Local File PORDER [TB0], PORDERQ [TB1], CPTANALIN [TB2]
#-----
[F:TB0]=[M:POD1]
[F:TB0]INVFCY=GFINRSP : # Prendre site financier de la société comme site facturation
#-----
[F:TB1]=[M:POD1]
If [F:TB1]LINPURTYP=0  [F:TB1]LINPURTYP=1 : Endif
#----- Chargement table liée PORDERP pour la pièce auto PORD -----#
If !GIMPORT
  [F:POP]=[M:POD1]
Endif
If [F:ITM]ITMREF<>[M:POD1]ITMREF
  Read [ITM] ITM0=[M:POD1]ITMREF : If fstat  Raz [F:ITM] : Endif
Endif
For I=0 To dim([F:POP]TSICOD)-1
  [F:POP]TSICOD(I)=[F:ITM]TSICOD(I)
Next I
#----- Initialisation des codes taxe -----#
Call ALIVATCOD(2,[M:POD1]BPSNUM,[M:POD1]ITMREF,"POP",0) From TRTX3
#----- Chargement pseudo fichier lignes comptables CPTANALIN [TB2] -----#
Raz [F:TB2]
[F:TB2]ABRFIC="POP"
[F:TB2]VCRNUM=[M:POD1]POHNUM
[F:TB2]VCRLIN=[M:POD1]POPLIN
[F:TB2]VCRSEQ=[M:POD1]POQSEQ(NOL)
[F:TB2]ANALIG=1
For I=1 To [M:POD1]NBCOA
  J=GTYPLED(I)
  If J
    [F:TB2]LED(J-1)=GLEDSOC(I)
    [F:TB2]COA(J-1)=[M:POD1]COA(I-1)
    [F:TB2]ACC(J-1)=[M:POD1]LINACC(I-1)
  Endif
Next I
For I=1 To [M:POD1]NBAXE
  [F:TB2]DIE(I-1)=[M:POD1]DIE(I-1)
  [F:TB2]CCE(I-1)=[M:POD1]CCE(I-1)
Next I
#-----
ID1(1)=[M:POD1]POHNUM
ID2(1)=[M:POD1]POHNUM
ID2(2)=num$([M:POD1]POPLIN)
ID2(3)=num$([M:POD1]POQSEQ(NOL))
If [M:POD1]CREFLG(NOL)=0  Raz ID1,ID2 : Endif
#-----
Call COMPTE("PORD",1,ID1,ID2,TPLAN,TCOMPTE,STA,WMESSAGE) From TRTACHCDE1
If STA
  Raz TPLAN, TCOMPTE
Else
  For I=1 To 10
    If TPLAN(I)<>""
     #J=find(TPLAN(I),GCOA(1..GNBCOA))
      J=find([F:GAD]LEDTYP(I-1),GTYPLED(1..GNBTYPLED))
      If J
        [M:POD1]LINACC(J-1)=TCOMPTE(I)
      Endif
    Endif
  Next I
Endif
#-----
Close Local File [TB0], [TB1], [TB2]
nolign=SAVNOLIGN
End


################################################################
# Initialisation du type d'achat en fonction du compte général #
################################################################
Subprog INIT_LINPURTYP
#----- Recherche compte général -----#
Local Integer I
Call RECH_INDACC(1,I) From TRTX3CPT
If I>0
  #----- Lecture du compte si nécessaire -----#
  If [F:GAC]COA<>GCOA(I) | [F:GAC]ACC<>[M:POD1]LINACC(I-1)
    Read [GAC] GAC0=GCOA(I);[M:POD1]LINACC(I-1) : If fstat  Raz [F:GAC] : Endif
  Endif
  #-----
  If [F:GAC]VATIPT=5
    [M:POD1]LINPURTYP=3
  Elsif [F:GAC]VATIPT=4
    [M:POD1]LINPURTYP=2
  Else
    [M:POD1]LINPURTYP=1
  Endif
Else
  [M:POD1]LINPURTYP=1
Endif
End

# Issue 71276 - 2015-03-20 by SR : Versions
######################################################################################

Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local    Integer  NOL  : NOL=nolign-1
#----- Contrôle modif statut autorisée (LLC) -----#
If [M:POD1]BETFCY=2 & [M:POD1]SALFCY<>"" & [M:POD1]CREFLG(NOL)<>0
  Raz [M:SORW]
  [M:SORW]MAJCOD = "T"                 : # Modification
  [M:SORW]SOHNUM = [M:POD1]OCNNUM      : # No contrat vente
  [M:SORW]SOPLIN = [M:POD1]OCNLIN      : # No ligne article (identique achat-vente)
  [M:SORW]SOQSEQ = [M:POD1]OCNSEQ(NOL) : # No séquence DL vente
  [M:SORW]QTY    = 0
  Call CTL_MAJ_SOQ From TRTVENMSIT
  If [M:SORW]ERRCOD<>0  mkstat=2 : End : Endif
Endif
End

######################################################################################
Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local Char    WECCVALMAJ(GLONECS)
Local Char    WECCVALMIN(GLONICVVAL)
Local Char    PITM(GLONITM)
Raz WECCVALMAJ
Raz WECCVALMIN
Raz PITM
If [F:ITM]ITMREF <> [M:POD1]ITMREF
 Read [F:ITM]ITM0 = [M:POD1]ITMREF
 If fstat : Raz [F:ITM] : Endif
Endif
# si version majeure trouvée et si article gere la version mineure : recherche derniere version mineure
If VALEUR  <> "" & [F:ITM]ECCSTO = 3
   WECCVALMAJ = VALEUR
   PITM = [F:ITM]ITMREF
   Gosub READECCMIN From STKACT
   [M:POD1]ECCVALMIN(nolign-1) = WECCVALMIN
   Affzo [M:POD1]ECCVALMIN(nolign-1)
Elsif VALEUR = "" & [M:POD1]ECCVALMIN(nolign-1) <> ""
      Raz   [M:POD1]ECCVALMIN(nolign-1)
      Affzo [M:POD1]ECCVALMIN(nolign-1)

Endif
End

######################################################################################
Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
Local    Integer  NOL  : NOL=nolign-1
#----- Contrôle modif statut autorisée (LLC) -----#
If [M:POD1]BETFCY=2 & [M:POD1]SALFCY<>"" & [M:POD1]CREFLG(NOL)<>0
  Raz [M:SORW]
  [M:SORW]MAJCOD = "T"                 : # Modification
  [M:SORW]SOHNUM = [M:POD1]OCNNUM      : # No contrat vente
  [M:SORW]SOPLIN = [M:POD1]OCNLIN      : # No ligne article (identique achat-vente)
  [M:SORW]SOQSEQ = [M:POD1]OCNSEQ(NOL) : # No séquence DL vente
  [M:SORW]QTY    = 0
  Call CTL_MAJ_SOQ From TRTVENMSIT
  If [M:SORW]ERRCOD<>0  mkstat=2 : End : Endif
Endif
End

# End issue 71276
######################################################################################

