Subprog IB_QTYPUU
#----------------------------------------------#
# Initialisation boutons sur champ quantité UA #
#----------------------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4 : # GBOUT1 est chargé avec l'action CONSSFC
If [F:ITF]ITMREF<>[M:POD1]ITMREF | [F:ITF]STOFCY<>[M:POD1]PRHFCY
  Read [ITF] ITF0=[M:POD1]ITMREF;[M:POD1]PRHFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
