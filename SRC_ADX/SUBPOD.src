If GMODIF=0  mkstat=2 : End : Endif
End

#VPO 09/12/10 17667
#--------------------------------------------------------------#
# MESSAGE_QTE : S/P d'avertissement sur contrôle des quantités #
#--------------------------------------------------------------#
# Subprog MESSAGE_QTE (CODE,NOL)                               #
#    CODE  : 1 = Affichage du message                          #
#            2 = Chargement de GMESSAGE car action de contrôle #
#    NOL   : Indice de la ligne en cours (nolign-1)            #
#                                                              #
# Remarque : GBIDD2 = Quantité en PUU                          #
#--------------------------------------------------------------#
Subprog MESSAGE_QTE (CODE,NOL)
Value Integer  CODE
Value Shortint NOL
Local Integer WOK
Local Integer WNB : WNB=0
Raz GMESSAGE, mkstat

[M:POD1]UPDPSDFLG(NOL)=1

#--- Test qté inférieure à qté initiale besoins pris en compte (sauf contremarque) ---#
If GBIDD2<>[M:POD1]RETQTYPUU(NOL)
  If [M:POD1]CREFLG(NOL)=0 & GBIDD2<>[M:POD1]RETQTYPUU(NOL)
    Local Integer WPRONUM
    Local Char    WCODFNC(3)
    Local Integer WLINNUM
    WPRONUM=adxuid(1)
    WCODFNC="POD"
    WLINNUM=[M:POD1]POHLIN(NOL)
    Filter [PWO] Where PRONUM=WPRONUM
&                    & CODFNC=WCODFNC
&                    & LINNUM=WLINNUM
    #VPO 09/12/10 17667 si une seule ligne de DA, on autorise la modif
    #Read [PWO] PWO0 First
    For [PWO]PWO0
       If [F:PWO]WIPSTA=2 & [F:PWO]WIPTYP=2
        WNB+=1
       Else
        WNB+=2
       Endif
    Next
    Filter [PWO]
    #If !fstat
    If WNB>1 & GBIDD2<[M:POD1]RETQTYPUU(NOL)
      GMESSAGE=mess(3,194,1)-num$([M:POD1]RETQTYPUU(NOL))-[M:POD1]PUU : mkstat=1 : End
    Elsif WNB=1
        #le flag va servir pour la mise à jour en modif sur vallig
        [M:POD1]UPDPSDFLG(NOL)=2
    Endif
  Elsif [M:POD1]CREFLG(NOL)<>0
    If !clalev([F:PSO])  Local File PREQUISO  [PSO] : Endif
    Filter [PSO] Where POHNUM=[M:POD1]POHNUM
&                    & POPLIN=[M:POD1]POPLIN
&                    & POQSEQ=[M:POD1]POQSEQ(NOL)
    #VPO 09/12/10 17667 si une seule ligne de DA, on autorise la modif
    #Read [PSO] PSO1 First
    For [PSO]PSO1
        WNB+=1
    Next
    Filter [PSO]
    #If !fstat
    If WNB>1 & GBIDD2<[M:POD1]RETQTYPUU(NOL)
      GMESSAGE=mess(3,194,1)-num$([M:POD1]RETQTYPUU(NOL))-[M:POD1]PUU : mkstat=1 : End
    Elsif WNB=1
        #le flag va servir pour la mise à jour en modif sur vallig
        [M:POD1]UPDPSDFLG(NOL)=2
    Endif
  Endif
Endif
#----- Positionnement mkstat et affichage si CODE=1 -----#
If GMESSAGE<>""
  mkstat=1
  If CODE=1 GERR=1 : Endif
  End
Endif
End

Subprog C_QTYPUU(VALEUR)
#----------------------#
# Contrôle quantité UA #
#----------------------#
Variable Decimal  VALEUR
Local Integer WOK
#VPO 09/12/10 17667 si une seule ligne de DA, on autorise la modif
#----- Test qté inférieure à qté initiale besoins pris en compte -----#
#If VALEUR<[M:POD1]RETQTYPUU(nolign-1)
#  GMESSAGE=mess(3,194,1)-num$([M:POD1]RETQTYPUU(nolign-1))-[M:POD1]PUU : mkstat=1 : End
#Endif
NOL=nolign-1 : GBIDD2=VALEUR
Call MESSAGE_QTE(2,NOL)
If mkstat : End : Endif
#----- Test qté inférieure à qté minimum d'achat -----#
#VPO 15/10/10 17730/59532 contrôle selon paramètre
If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
#If VALEUR<[M:POD1]PURMINQTY
If VALEUR<[M:POD1]PURMINQTY & GPOHMINQTY<3
  GMESSAGE=mess(14,194,1)-num$([M:POD1]PURMINQTY)-[M:POD1]PUU
  If GPOHMINQTY=1
      mkstat=1 : End
  Else : #GPOHMINQTY=2
      WOK=2
      Call AVERTIR (GMESSAGE, WOK)From GESECRAN
      If WOK=1
          Raz GMESSAGE
          mkstat=1 : End
      Endif
      Raz GMESSAGE
  Endif
Endif
If [M:POD1]BETFCY=2 & [M:POD1]SALFCY<>"" & [M:POD1]CREFLG(nolign-1)<>0
  #---------------------------------------------------------------------------------#
  # Contrôles supplémentaires pour contrat inter-site si modif d'une ancienne ligne #
  #---------------------------------------------------------------------------------#
  Raz [M:SORW]
  [M:SORW]MAJCOD = "Q"                      : # Modification quantité
  [M:SORW]SOHNUM = [M:POD1]OCNNUM           : # No contrat vente
  [M:SORW]SOPLIN = [M:POD1]OCNLIN           : # No ligne article (idem achat-vente)
  [M:SORW]SOQSEQ = [M:POD1]OCNSEQ(nolign-1) : # No séquence DL vente
  [M:SORW]QTY    = VALEUR                   : # Quantité
  Call CTL_MAJ_SOQ From TRTVENMSIT
  If GMESSAGE<>"" mkstat=1 : End : Endif
  #--------------------------------------------------------------------------------#
  # Quantité inférieure à quantité attendue en réception ! (en cours d'expédition) #
  #--------------------------------------------------------------------------------#
  If VALEUR<[M:POD1]ORIQTYPUU(nolign-1)-[M:SORW]QTY
    GMESSAGE=mess(206,194,1)-num$([M:SORW]QTY)-[M:POD1]PUU : mkstat=1 : End
  Endif
Endif
End


Subprog AM_QTYPUU(VALEUR)
#-------------------------#
# Après modif quantité UA #
#-------------------------#
Variable Decimal  VALEUR
#----- Pas de contrôle si la quantité prévue est nulle -----#
If [M]EXTQTYPUU=0 End : Endif
Local    Integer  OK
Local    Shortint I
Local    Decimal  CUMQTE
#----- Calcul du cumul des quantités (fermes et planifiées) -----#
CUMQTE=VALEUR                      : # + Valeur actuelle
If nolign<=[M:POD1]NBLIG
  CUMQTE-=[M:POD1]QTYPUU(nolign-1) : # - Valeur précédente
Endif
If [M:POD1]NBLIG>0
  For I=0 To [M:POD1]NBLIG-1
    If [M:POD1]LINSTA(I)<>3  CUMQTE+=[M:POD1]QTYPUU(I) : Endif
  Next I
Endif
CUMQTE-=[F:POC]RTNQTYPUU
CUMQTE+=[F:POC]RCPQTYPUU
Raz GMESSAGE
#----- La quantité est supérieure à la quantité globale -----#
If VALEUR>[M:POD1]EXTQTYPUU
  GMESSAGE=mess(70,194,1)
#----- La quantité totale commandée est supérieure à la quantité prévue -----#
Elsif CUMQTE>[M:POD1]EXTQTYPUU
  GMESSAGE=num$(CUMQTE)-[M:POD1]PUU-":"-mess(91,194,1)
Endif
#----- Affichage des messages -----#
If GMESSAGE<>""
  If GPOCQTY=2 : # Contrôle bloquant
    GERR=1 : mkstat=1 : End
  Else         : # Contrôle non bloquant
    OK=2 : Call AVERTIR(GMESSAGE,OK) From GESECRAN
    If OK=1 mkstat=1 : Raz GMESSAGE : End : Endif
  Endif
Endif
End

