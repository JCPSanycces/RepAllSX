Subprog AM_XPRHFCY(VALEUR)
#-----------------------------------------------------------------------#
# Après modif du site de réception : chargement code adresse par défaut #
#-----------------------------------------------------------------------#
Variable Char    VALEUR()
Local    Shortint NOL : NOL=nolign-1
If VALEUR=[M:POD1]PRHFCY
  [M:POD1]XFCYADD(NOL)=[F:POC]FCYADD
Else
  [M:POD1]XFCYADD(NOL)=[F:FCY]BPAADD
Endif
Affzo [POD1]XFCYADD(NOL)

# Issue 90991 - 2013-11-05 by MUARN : ajout SDC au niveau site
Local    Decimal  WCPRAMT, WCPRAMTDEV
Local    Integer  STAT
Call RECH_COST(VALEUR,[M:POD1]BPSNUM, [M:POD1]ITMREF, [M:POD1]CPRCOE(NOL), WCPRAMT, [M:POD1]STCNUM(NOL)) From STCLIB
If GLOCALDEV <> GSYSCUR
  Call CONVERT2(GSYSCUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                       WCPRAMT,WCPRAMTDEV,STAT) From TRTDEV
  [M:POD1]CPRAMT(NOL)=arr(WCPRAMTDEV,10^-GDECPRI)
Else
 [M:POD1]CPRAMT(NOL) = WCPRAMT
Endif
If [M:POD1]CPRCOE(NOL)=0 [M:POD1]CPRCOE(NOL)=1 Endif
If [M:POD1]STCNUM(NOL)<> ""
  Diszo [POD1]CPRAMT(NOL), CPRCOE(NOL)
Else
  Actzo [POD1]CPRAMT(NOL), CPRCOE(NOL)
Endif

End


