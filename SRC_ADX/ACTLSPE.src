Local File =APPLI+".ATYPE" [ATYT]
Call TRACE_TIT(mess(260,115,1)) : # Contrôle des types de données
For [ATYT] Where CODTYP<GXX
 STAT = func CTLSPEATY(APPLI,DOSREF,[F:ATYT]CODTYP,IMPACT,ERROR,CTRLCLOUD) : # Dom June 16,2016
 NBE = max(STAT,NBE)
Next ATYT
Gosub TRACE_FIN
End

#----------------------------------------#
