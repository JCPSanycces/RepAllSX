Local Integer STAT , NBE
Local File =APPLI+".ATABTAB" [ADVT]
Call TRACE_TIT(mess(261,115,1)) : # Contrôle des tables diverses
For [ADVT]
 STAT = func CTLSPEADI(APPLI,DOSREF,[F:ADVT]NUMTAB,ERROR,CTRLCLOUD) : # Dom June 16,2016
 NBE = max(STAT,NBE)
Next ADVT
Gosub TRACE_FIN
End

#----------------------------------------#
