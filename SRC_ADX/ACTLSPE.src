#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ACTLSPE","ACTLSPE",3,"") From GTRAITE
End

# Modification done by Dom June 16,2016
# A local menu called CTRLCLOUD has been added:
# When set to 2 (true), the controls are reinforced for the cloud
# in this case:
#    any additional field in a standard table, in a standard screen is forbidden
#    any additional tab in a standard windows is forbidden
#    any entry point declaration is displayed as a warning
# In order to be the less disruptive, I added a CTRLCLOUD variable that must be defined in the parameter masks
# This parameter has been added in every CTRL funprog (even if it is not used everywhere)
#-----------------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase
Return

#----------------------------------#
$INIT
Local Integer ERROR(1..3) , IMPACT
Local Char    MESSAGE(250) , VERSION(20)
Local Char    APPLI(GLONADS) , DOSREF(GLONADD)
Local Char    MACHINE(GLONAMC) , DOSAPP(GDIMFIC)
Local Libelle CTRLCLOUD : # Dom June 16, 2016 : Libelle still used for V6 compatibility reason

VERSION = "V2015-04-20"

Return

#----------------------------------#
$CONTROLE
[L] = [M]
If [L]APPLI="" : [L]APPLI = nomap : Endif
If [L]DOSREF="" : [L]DOSREF = GDOSX3 : Endif
If [L]APPLI=GDOSX3
 Call ERREUR([L]APPLI-":"-mess(222,139,1)) From GESECRAN : # Dossier racine
 SAI = 1 : Return
Endif
If [L]DOSREF<>""
 Call MACHINE([L]DOSREF,MACHINE,DOSAPP) From ORDSYS
 If func DOSCONT.APPX3([L]DOSREF)<>DOSAPP
  # Le dossier n'est pas un dossier racine
  Call ERREUR([L]DOSREF-":"-mess(1919,9900,1)) From GESECRAN
  SAI = 1 : Return
 Endif
 Call C_DOSSIER([L]DOSREF) From DOSCONT
 If mkstat
  Call ERREUR(GMESSAGE) From GESECRAN
  GMESSAGE = "" : SAI = 1 : Return
 Endif
 Call CTL_DROIT_DOSSIER([L]DOSREF,"") From DOSCONT
 If mkstat
  Call ERREUR(GMESSAGE) From GESECRAN
  GMESSAGE = "" : SAI = 1 : Return
 Endif
Endif
Return

#----------------------------------#
$TERMINE
TRA = 1
GERRTRACE = 0
Return

#----------------------------------#
$EXEC
If !GSERVEUR
 Call TEMPON("O") From GESECRAN
 # Contrôles des verticaux et spécifiques du dossier $1$ par rapport au dossier $2$
 Call OUVRE_TRACE(func AFNC.MES2(mess(256,115,1),APPLI,DOSREF)) From LECFIC
Endif

# Version
Call ECR_TRACE(mess(126,105,1)-VERSION,0) From GESECRAN

Global Char GXX(1)
GXX = "z"
Raz ERROR

Call CTLSPEACVS(APPLI,DOSREF,ERROR,CTRLCLOUD) : # Dom June 16,2016
Call CTLSPETABS(APPLI,DOSREF,ERROR,CTRLCLOUD) : # Dom June 16,2016
Call CTLSPEATYS(APPLI,DOSREF,IMPACT,ERROR,CTRLCLOUD) : # Dom June 16,2016
Call CTLSPEADIS(APPLI,DOSREF,ERROR,CTRLCLOUD) : # Dom June 16,2016
Call CTLSPEAMLS(APPLI,DOSREF,ERROR,CTRLCLOUD) : # Dom June 16,2016
Call CTLSPEMSKS(APPLI,DOSREF,ERROR,CTRLCLOUD) : # Dom June 16,2016
Call CTLSPEWINS(APPLI,DOSREF,ERROR,CTRLCLOUD) : # Dom June 16,2016
Call CTLSPEACTS(APPLI,DOSREF,ERROR,CTRLCLOUD) : # Dom June 16,2016
Call CTLSPECLAS(APPLI,DOSREF,ERROR,CTRLCLOUD) : # Dom June 16,2016
Call CTLSPEREPS(APPLI,DOSREF,ERROR,CTRLCLOUD) : # Dom June 16,2016
Call CTLSPETRTS(APPLI,DOSREF,ERROR,CTRLCLOUD) : # Dom June 16,2016

# Nombre d'erreurs trouvées : $1$ Erreur(s) grave(s), $2$ erreur(s), $3$ risque(s)
Call ECR_TRACE("\"+func AFNC.MES3(mess(257,115,1),num$(ERROR(3)),num$(ERROR(2)),num$(ERROR(1))),0) From GESECRAN
If !GSERVEUR
 Call FERME_TRACE From LECFIC
 Call TEMPOFF From GESECRAN
Endif
Return

#----------------------------------------#
Subprog CTLSPEACVS(APPLI,DOSREF,ERROR,CTRLCLOUD) : # Dom June 16,2016
Value    Char    APPLI , DOSREF
Variable Integer ERROR(1..)
Value Libelle CTRLCLOUD : # Dom June 16,2016
Local Integer STAT , NBE
Local File =APPLI+".ACTIV" [ACVT]
Call TRACE_TIT(mess(258,115,1)) : # Contrôle des codes activité
For [ACVT] Where CODACT<GXX
 STAT = func CTLSPEACV(APPLI,DOSREF,[F:ACVT]CODACT,ERROR,CTRLCLOUD) : # Dom June 16,2016
 NBE = max(STAT,NBE)
Next ACVT
Gosub TRACE_FIN
End

#----------------------------------------#
Subprog CTLSPETABS(APPLI,DOSREF,ERROR,CTRLCLOUD) : # Dom June 16,2016
Value    Char    APPLI , DOSREF
Variable Integer ERROR(1..)
Value Libelle CTRLCLOUD : # Dom June 16,2016
Local Integer STAT , NBE
Local File =APPLI+".ATABLE" [ATBT]
Call TRACE_TIT(mess(259,115,1)) : # Contrôle des tables
For [ATBT] Where CODFIC<GXX
 STAT = func CTLSPETAB(APPLI,DOSREF,[F:ATBT]CODFIC,ERROR,CTRLCLOUD) : # Dom June 16,2016
 NBE = max(STAT,NBE)
Next ATBT
Gosub TRACE_FIN
End

#------------------------------------------------#
