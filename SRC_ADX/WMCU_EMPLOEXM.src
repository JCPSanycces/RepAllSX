#<AdxTL>@(#)0.0.0.0 $Revision$Class Degrees
# Supervisor
## CRUD-CLASSE ## EMPLOEXM
# 2018-11-06 07:06:14 079


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(EMPLOEXM,ASTATUS)
Variable Instance EMPLOEXM Using C_EMPLOEXM
Variable Integer ASTATUS

If EMPLOEXM = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOEXM

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_EMPLOEXM

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(EMPLOEXM,ASTATUS)
Variable Instance EMPLOEXM Using C_EMPLOEXM
Variable Integer ASTATUS

If EMPLOEXM = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOEXM
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
EMPLOEXM.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_EMPLOEXM
Else
 Gosub AUPDATE_EMPLOEXM
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = EMPLOEXM.freeSnapshot
EMPLOEXM.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOEXM._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOEXM._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOEXM._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If EMPLOEXM.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOEXM.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(EMPLOEXM.ASTALIN)<>""
 [L]A_ASTALIN = EMPLOEXM.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER

If [V]CST_ASTALIN(EMPLOEXM.ASTALIN)<>""
 [L]A_ASTALIN = EMPLOEXM.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_EMPLOEXM
Trbegin [F:HREXM]
 Gosub AUPDATE_EMPLOEXM
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_EMPLOEXM
[L]A_ASTALIN = EMPLOEXM.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOEXM._MAJSQL_EMPLOEXM(EMPLOEXM))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


[L]A_ASTALIN = EMPLOEXM.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If EMPLOEXM.snapshotEnabled=1
 [L]A_RETIK = EMPLOEXM.revertUpdTick
Endif

[L]ASTATUS = max(fmet EMPLOEXM.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(EMPLOEXM.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EMPLOEXM.ASTALIN = [V]CST_ALL
Endif
Return



