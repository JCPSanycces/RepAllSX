#<AdxTL>@(#)6.0.0.0 $Revision$
#########################################################################################
# Programme : PREPLOFGRP                                                                #
#                                                                                       #
# Fonction  :                                                                           #
#      1- Maj de la table TMPLOFGRP                                                     #
#    Création :                                                                         #
#    MDJ - 18/05/2012 - FQ-76033 Traitement préparatoire à l'état FASLSTGRP (nouveau)   #
#########################################################################################
#  Modification :
# UUUUU jj.mm.aaaa nnnnnn_nn Cccccccccccccccccccccccccccccccccccccccccccccccccccccccc
#
# MDJ   03.02.2016 114161    Intitulés Code comptable absents (en sqlserver)  #
#########################################################################################

$ACTION

    Case ACTION
        When "OUVRE" :   Gosub OUVRE
        When "EXEC"  :   Gosub EXEC
        When "FIN"   :   Gosub FIN
    Endcase
Return
######################################################################################
$OUVRE
#=============================================================================
# traitement PREPLOFGRP : alimentation de la table TMPLOFGRP
#=============================================================================
If clalev([F:TLG])=0    :    Local File TMPLOFGRP       [TLG]   : Endif
If clalev([F:TLGM])=0   :    Local File TMPLOFGRP       [TLGM]  : Endif

If clalev([F:FAS])=0    :    Local File FXDASSETS       [FAS]   : Endif
If clalev([F:LOF])=0    :    Local File LAYOUTFAS       [LOF]   : Endif

If clalev([F:CPY])=0    :    Local File COMPANY         [CPY]   : Endif
If clalev([F:FCY])=0    :    Local File FACILITY        [FCY]   : Endif    # Sites financiers
If clalev([F:FCYG])=0   :    Local File FACILITY        [FCYG]  : Endif    # Sites géographiques
If clalev([F:CAC])=0    :    Local File GACCCODE        [CAC]   : Endif    # Codes comptables
If clalev([F:AFF])=0   :    Local File AFCTFCY        [AFF]  : Endif       # Profil fonction site

Return
######################################################################################
$FIN

Unlock PREPLOFGRP

Return
######################################################################################
$EXEC

Lock PREPLOFGRP With lockwait = 3
If fstat
   Return
Endif

Gosub MAJ_TMPLOFGRP

Return
###################################################
$MAJ_TMPLOFGRP
#------------------------------------------------------------------------------------#
#--- Création table temporaire TMPLOFGRP pour l' état FASLSTGRP                   ---#
#------------------------------------------------------------------------------------#

   Gosub OUVRE

    Local Integer I             # Compteur paramètres / Indices
    Local Char    LDEVRPT       # Devise de reporting
    Local Integer LLED          # Référentiel
    Local Char    LCPYDEB       # Société
    Local Char    LCPYFIN
    Local Char    LFCYDEB       # Site financier
    Local Char    LFCYFIN
    Local Integer LTYPDETDEB    # Type détention
    Local Integer LTYPDETFIN
    Local Char    LCCPTDEB      # Code comptable
    Local Char    LCCPTFIN
    Local Char    LACGGRPDEB    # Famille comptable
    Local Char    LACGGRPFIN
    Local Char    LBPRDEB       # Fournisseur
    Local Char    LBPRPFIN
    Local Date    LPURDATDEB    # Date Achat
    Local Date    LPURDATFIN
    Local Date    LDATCPTDEB    # Date Imputation
    Local Date    LDATCPTFIN
    Local Date    LDATMESDEB    # Date mise en service
    Local Date    LDATMESFIN
    Local Date    LDATCREDEB    # Date création
    Local Date    LDATCREFIN
    Local Char    LREFDEB       # référence bien comptable
    Local Char    LREFFIN
    Local Integer LACTIF        # Actif ?
    Local Date    LDATNULL      : LDATNULL = [01/01/1900]
#    Local Integer LTRI2         # Critère de tri 2
#    Local Integer LTRI3         # Critère de tri 3
    Local Integer LDET          # Détail ?
    Local Integer LEDTNUM       # Identifiant session
    Local Char    LCRITERE  (250) # Critère de sélection
    Local Char    LCRITERE2 (250) # Critère de sélection
    Local Char    LCRITERE3 (250) # Critère de sélection
    Local Char    SCPY         # Société traitée
    Local Char    SFCY         # Site financier traité
    Local Char    X3PRF        # Code profil user
    Local Char    X3FCT        # Fonction

    Local Char    RCOA        # Plan de compte
    Local Decimal MNTDEV      # Montants en devise de reporting
    Local Integer TYPCUR      # Type de cours
    Local Date    DATCOURS    # Date cours
    Local Integer STAT


    If clalev([TLG])=0 : Local File TMPLOFGRP [TLG] : Endif
    Trbegin [TLG]
    Delete [TLG] Where CREUSR = GUSER
    If fstat = 1
      Rollback
      Return
    Else
       Commit
    Endif

   Call GETPARAM("devrpt",NBPAR,PARAMETRE,LDEVRPT)
   Call GETPARAM("referentiel",NBPAR,PARAMETRE,PARAM) : LLED=val(PARAM)
   Call GETPARAM("cpydeb",NBPAR,PARAMETRE,LCPYDEB)
   Call GETPARAM("cpyfin",NBPAR,PARAMETRE,LCPYFIN)
   Call GETPARAM("fcydeb",NBPAR,PARAMETRE,LFCYDEB)
   Call GETPARAM("fcyfin",NBPAR,PARAMETRE,LFCYFIN)
   Call GETPARAM("typdetdeb",NBPAR,PARAMETRE,PARAM)    : LTYPDETDEB = val(PARAM)
   Call GETPARAM("typdetfin",NBPAR,PARAMETRE,PARAM)    : LTYPDETFIN = val(PARAM)
   Call GETPARAM("ccptdeb",NBPAR,PARAMETRE,LCCPTDEB)
   Call GETPARAM("ccptfin",NBPAR,PARAMETRE,LCCPTFIN)
   Call GETPARAM("acggrpdeb",NBPAR,PARAMETRE,LACGGRPDEB)
   Call GETPARAM("acggrpfin",NBPAR,PARAMETRE,LACGGRPFIN)
   Call GETPARAM("bprdeb",NBPAR,PARAMETRE,LBPRDEB)
   Call GETPARAM("bprfin",NBPAR,PARAMETRE,LBPRFIN)
   Call GETPARAM("purdatdeb",NBPAR,PARAMETRE,PARAM)    : LPURDATDEB    =  PARAM
   Call GETPARAM("purdatfin",NBPAR,PARAMETRE,PARAM)    : LPURDATFIN    =  PARAM
   Call GETPARAM("datcptdeb",NBPAR,PARAMETRE,PARAM)    : LDATCPTDEB    =  PARAM
   Call GETPARAM("datcptfin",NBPAR,PARAMETRE,PARAM)    : LDATCPTFIN    =  PARAM
   Call GETPARAM("datmesdeb",NBPAR,PARAMETRE,PARAM)    : LDATMESDEB    =  PARAM
   Call GETPARAM("datmesfin",NBPAR,PARAMETRE,PARAM)    : LDATMESFIN    =  PARAM
   Call GETPARAM("datcredeb",NBPAR,PARAMETRE,PARAM)    : LDATCREDEB    =  PARAM
   Call GETPARAM("datcrefin",NBPAR,PARAMETRE,PARAM)    : LDATCREFIN    =  PARAM
   Call GETPARAM("refdeb",NBPAR,PARAMETRE,LREFDEB)
   Call GETPARAM("reffin",NBPAR,PARAMETRE,LREFFIN)
   Call GETPARAM("actif",NBPAR,PARAMETRE,PARAM)        : LACTIF     = val(PARAM)
   Call GETPARAM("detail",NBPAR,PARAMETRE,PARAM)       : LDET       = val(PARAM)
   Call GETPARAM("edtnum",NBPAR,PARAMETRE,PARAM)       : LEDTNUM    = val(PARAM)
   Call GETPARAM("typcur",NBPAR,PARAMETRE,PARAM)       : LTYPCUR    = val(PARAM)
   Call GETPARAM("datcours",NBPAR,PARAMETRE,PARAM)     : LDATCOURS  =  PARAM

   Call GETPARAM("X3PRF",NBPAR,PARAMETRE,X3PRF)
   Call GETPARAM("X3FCT",NBPAR,PARAMETRE,X3FCT)


   LCRITERE  = "1=1"
   LCRITERE2 = "1=1"
   LCRITERE3 = "1=1"
   #            When "cpydeb" :
#                  If LCPYDEB <> ""
#                     LCRITERE =    "CPY>='"+LCPYDEB+"'"
#                  Else
#                     LCRITERE =    "CPY<='"+LCPYFIN+"'"
#                  Endif
#            When "cpyfin" :
#                  If LCPYDEB <> ""
#                     LCRITERE += "& CPY<='"+LCPYFIN+"'"
#                  Endif
   For I=1 To NBPAR
      J=instr(1,[L]PARAMETRE(I),"=")
      If J
         [L]PARAM  = left$([L]PARAMETRE(I),J-1)
         [L]VALEUR = right$([L]PARAMETRE(I),J+1)
         Case [L]PARAM
            When "cpydeb"        :     LCRITERE += "& CPY>='"+LCPYDEB+"'"
            When "cpyfin"        :     LCRITERE += "& CPY<='"+LCPYFIN+"'"
            When "fcydeb"        :     LCRITERE += "& FCY>='"+LFCYDEB+"'"
            When "fcyfin"        :     LCRITERE += "& FCY<='"+LFCYFIN+"'"
            When "ccptdeb"       :     LCRITERE += "& ACCCOD>='"+LCCPTDEB+"'"
            When "ccptfin"       :     LCRITERE += "& ACCCOD<='"+LCCPTFIN+"'"
            When "acggrpdeb"     :     LCRITERE += "& ACGGRP>='"+LACGGRPDEB+"'"
            When "acggrpfin"     :     LCRITERE += "& ACGGRP<='"+LACGGRPFIN+"'"

            When "bprdeb"       :    LCRITERE2   = "  BPR>='"+LBPRDEB+"'"
            When "bprfin"       :    LCRITERE2  += "& BPR<='"+LBPRFIN+"'"
            When "purdatdeb"    :    LCRITERE2  += "& PURDAT>= ["+format$(GFMD,LPURDATDEB)+"]"
            When "purdatfin"    :    LCRITERE2  += "& PURDAT<= ["+format$(GFMD,LPURDATFIN)+"]"
            When "datcptdeb"    :    LCRITERE2  += "& AASIPTDAT>= ["+format$(GFMD,LDATCPTDEB)+"]"
            When "datcptfin"    :    LCRITERE2  += "& AASIPTDAT<= ["+format$(GFMD,LDATCPTFIN)+"]"
            When "datmesdeb"    :    LCRITERE2  += "& ITSDAT>= ["+format$(GFMD,LDATMESDEB)+"]"
            When "datmesfin"    :    LCRITERE2  += "& ITSDAT<= ["+format$(GFMD,LDATMESFIN)+"]"
            When "datcredeb"    :    LCRITERE2  += "& CREDAT>= ["+format$(GFMD,LDATCREDEB)+"]"
            When "datcrefin"    :    LCRITERE2  += "& CREDAT<= ["+format$(GFMD,LDATCREFIN)+"]"

            When "refdeb"       :    LCRITERE3  =  "  AASREF>='"+LREFDEB+"'"
            When "reffin"       :    LCRITERE3 +=  "& AASREF<='"+LREFFIN+"'"
            When "typdetdeb"    :    LCRITERE3 +=  "&  OWNTYP>='"+LTYPDETDEB+"'"
            When "typdetfin"    :    LCRITERE3 +=  "&  OWNTYP<='"+LTYPDETFIN+"'"

            When "actif"
                  If LACTIF=1
                     LCRITERE3 +=    "& ENAFAS<>1"
                  Else
                     LCRITERE3 +=    "& ENAFAS=1"
                  Endif
         Endcase
      Endif
   Next

#--------------------------------
   If clalev([TLG])=0 : Local File TMPLOFGRP [TLG] : Endif
   Trbegin [TLG]
   Delete [TLG] Where CREUSR = GUSER
   If fstat=1 | fstat>5
       Rollback
    Else
        Commit
   Endif
   #
   Trbegin [TLG]
   SCPY= ""
   SFCY= ""

   Filter [FAS] Where ( evalue(LCRITERE)) and (evalue(LCRITERE2))  and (evalue(LCRITERE3))
   For [FAS]FAS2   Where ( CREORI = GVML_CORGLOF)
      If [F:FAS]CPY <> SCPY
         Read [CPY]CPY0 = [F:FAS]CPY
         SCPY = [F:FAS]CPY
      Endif

      If [F:FAS]FCY <> SFCY
         Read [AFF]AFF0 = [F:FAS]FCY;X3PRF;X3FCT
         If fstat <> 0
            Goto NEXTFAS
          Endif
         Read [FCY]FCY0 = [F:FAS]FCY
         SFCY= [F:FAS]FCY
      Endif

      # Boucle sur les dépenses rattachées au bien comptable
      Filter [LOF] Where AASREF=[F:FAS]AASREF Order By FLGMAIN
      For [LOF] LOF6
         #1-----------
         Local Integer TYPLED
         Raz[TLGM]
         [F:TLGM]       = [F:FAS]
         Call LECPLAN([F:FAS]CPY,LLED,RCOA) From CPTDIV
         [F:TLGM]COA=RCOA
         # Issue 114161 Read[CAC]CAC0="15";[F:FAS]ACCCOD;RCOA
         Read[CAC]CAC0=15;[F:FAS]ACCCOD;RCOA
         If fstat=0
            Call LECTEXTRA([F:TLGM]ACCDES,"GACCCODE","DESTRA","15",[F:FAS]ACCCOD) From ATEXTRA
         Endif
         [F:TLGM]          = [F:LOF]
         [F:TLGM]CPYNAM    = [F:CPY]CPYNAM
         [F:TLGM]FCYNAM    = [F:FCY]FCYNAM
         [F:TLGM]IASCUR    = [F:FAS]IASCUR
         [F:TLGM]LED       = LLED
         [F:TLGM]DEVRPT    = LDEVRPT
         [F:TLGM]TYPCUR    = LTYPCUR
         [F:TLGM]DATCOURS  = LDATCOURS
         Gosub CONVERT_MONTANTS
      #========================================================
      # Récupération des infos en provenance du plan comptable
      #========================================================
         [F:TLG]=[F:TLGM]
         [F:TLG]EDTNUM = LEDTNUM
         [F:TLG]CREUSR = GUSER
         [F:TLG]CREDAT = date$
         Write [F:TLG]
         If fstat <> 0
            GOK=0
            Rollback
            Unlock[TLG]
         Else
            Commit
            Unlock[TLG]
         Endif
         #1------------
      Next
      $NEXTFAS
    Next
   Filter[FAS]


Commit

Unlock PREPLOFGRP

Return
######################################################################################
$CHARGE_TLGM_FAS

     [F:TLGM]   = [F:FAS]
Return
######################################################################################
$CHARGE_TLGM_LOF
Local Integer RRET

   [F:TLGM]   = [F:LOF]


Return
######################################################################################
$CONVERT_MONTANTS
Local Integer TYPLED
Local Integer STAT
Local Decimal COURS : COURS = 1

      Call LECLEDMAIN(3,[F:FAS]CPY,TYPLED) From CPTDIV

      If TYPLED = LLED and LDEVRPT <> [F:FAS]IASCUR and [F:FAS]IASCUR<> ""
       #------------------------------------------------------------------------
       # 1 - Conversion des montants IAS en devise de reporting
       #------------------------------------------------------------------------
       #-1---> Montants Dépenses
       Call CDVCAL( COURS, [F:FAS]IASCUR, LDEVRPT, [F:FAS]CPY, LTYPCUR, LDATCOURS) From TRTDIV
       [F:TLGM]COURS = COURS

       Call CONVERT3 ( [F:FAS]IASCUR, LDEVRPT, GCOUDEV, LTYPCUR, LDATCOURS,
&                      [F:LOF]AMTNOTCPY, MNTDEV,COURS, STAT) From CPTSUB
      If STAT = 0
         Call GET_MNT_ARRONDI (MNTDEV, LDEVRPT, MNTDEV) From GLOBIENS
         [F:TLGM]AMTNOTCPY =  MNTDEV
      Endif
      #
      Call CONVERT3 ( [F:FAS]IASCUR, LDEVRPT, GCOUDEV, LTYPCUR, LDATCOURS,
&                     [F:LOF]AMTVATCPY, MNTDEV, COURS, STAT) From CPTSUB
      If STAT = 0
         Call GET_MNT_ARRONDI (MNTDEV, LDEVRPT, MNTDEV) From GLOBIENS
         [F:TLGM]AMTVATCPY =  MNTDEV
      Endif
      #
      Call CONVERT3 ( [F:FAS]IASCUR, LDEVRPT, GCOUDEV, LTYPCUR, LDATCOURS,
&                     [F:LOF]AMTVATRCPY, MNTDEV, COURS, STAT) From CPTSUB
      If STAT = 0
         Call GET_MNT_ARRONDI (MNTDEV, LDEVRPT, MNTDEV) From GLOBIENS
         [F:TLGM]AMTVATRCPY =  MNTDEV
      Endif
      #-2---> Montants Bien comptable
      Call CONVERT3 ( [F:FAS]IASCUR, LDEVRPT, GCOUDEV, LTYPCUR, LDATCOURS,
&                     [F:FAS]IASETRNOT, MNTDEV,COURS, STAT) From CPTSUB
      If STAT = 0
          Call GET_MNT_ARRONDI (MNTDEV, LDEVRPT, MNTDEV) From GLOBIENS
          [F:TLGM]IASETRNOT =  MNTDEV
      Endif
      Call CONVERT3 ( [F:FAS]IASCUR, LDEVRPT, GCOUDEV, LTYPCUR, LDATCOURS,
&                     [F:FAS]IVCVATAMTI, MNTDEV,COURS, STAT) From CPTSUB
      If STAT = 0
         Call GET_MNT_ARRONDI (MNTDEV, LDEVRPT, MNTDEV) From GLOBIENS
         [F:TLGM]IVCVATAMTI =  MNTDEV
      Endif
      #
      Call CONVERT3 ( [F:FAS]IASCUR, LDEVRPT, GCOUDEV, LTYPCUR, LDATCOURS,
&                      [F:FAS]DEDVATAMTI, MNTDEV, COURS, STAT) From CPTSUB
      If STAT = 0
         Call GET_MNT_ARRONDI (MNTDEV, LDEVRPT, MNTDEV) From GLOBIENS
         [F:TLGM]DEDVATAMTI =  MNTDEV
      Endif
  Else
     If TYPLED <>  LLED and LDEVRPT <> [F:FAS]ACGCUR
         Call CDVCAL( COURS, [F:FAS]ACGCUR, LDEVRPT, [F:FAS]CPY, LTYPCUR, LDATCOURS) From TRTDIV
         [F:TLGM]COURS = COURS
         #------------------------------------------------------------------------
         # 1 - Conversion des montants PCG en devise de reporting
         #------------------------------------------------------------------------
         #-1---> Montants Dépenses
         Call CONVERT3 ( [F:FAS]ACGCUR, LDEVRPT, GCOUDEV, LTYPCUR, LDATCOURS,
&                        [F:LOF]AMTNOTCPY, MNTDEV,COURS, STAT) From CPTSUB
         If STAT = 0
           Call GET_MNT_ARRONDI (MNTDEV, LDEVRPT, MNTDEV) From GLOBIENS
            [F:TLGM]AMTNOTCPY =  MNTDEV
         Endif
      #
        Call CONVERT3 ( [F:FAS]ACGCUR, LDEVRPT, GCOUDEV, LTYPCUR, LDATCOURS,
&                       [F:LOF]AMTVATCPY, MNTDEV, COURS, STAT) From CPTSUB
        If STAT = 0
           Call GET_MNT_ARRONDI (MNTDEV, LDEVRPT, MNTDEV) From GLOBIENS
           [F:TLGM]AMTVATCPY =  MNTDEV
        Endif
      #
        Call CONVERT3 ( [F:FAS]ACGCUR, LDEVRPT, GCOUDEV, LTYPCUR, LDATCOURS,
&                       [F:LOF]AMTVATRCPY, MNTDEV, COURS, STAT) From CPTSUB
        If STAT = 0
           Call GET_MNT_ARRONDI (MNTDEV, LDEVRPT, MNTDEV) From GLOBIENS
           [F:TLGM]AMTVATRCPY =  MNTDEV
        Endif
      #-2---> Montants Bien comptable
        Call CONVERT3 ( [F:FAS]ACGCUR, LDEVRPT, GCOUDEV, LTYPCUR, LDATCOURS,
&                       [F:FAS]ACGETRNOT, MNTDEV, COURS, STAT) From CPTSUB
       If STAT = 0
           Call GET_MNT_ARRONDI (MNTDEV, LDEVRPT, MNTDEV) From GLOBIENS
           [F:TLGM]ACGETRNOT =  MNTDEV
       Endif
       Call CONVERT3 ( [F:FAS]ACGCUR, LDEVRPT, GCOUDEV, LTYPCUR, LDATCOURS,
&                      [F:FAS]IVCVATAMT, MNTDEV, COURS, STAT) From CPTSUB
       If STAT = 0
          Call GET_MNT_ARRONDI (MNTDEV, LDEVRPT, MNTDEV) From GLOBIENS
          [F:TLGM]IVCVATAMT =  MNTDEV
       Endif
       #
       Call CONVERT3 ( [F:FAS]ACGCUR, LDEVRPT, GCOUDEV, LTYPCUR, LDATCOURS,
&                      [F:FAS]DEDVATAMT, MNTDEV, COURS, STAT) From CPTSUB
       If STAT = 0
          Call GET_MNT_ARRONDI (MNTDEV, LDEVRPT, MNTDEV) From GLOBIENS
          [F:TLGM]DEDVATAMT =  MNTDEV
        Endif
     Endif
 Endif


Return
######################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
End
####################################################
#================================================================
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L

   Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
   L = len(PARAM)
   If right$(PARAM,L-2)="deb"
      If VALEUR=string$(len(VALEUR)," ")
          VALEUR = ""
      Endif
   Endif

End
####################################################

