#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
## Etiquette ajoutée par le superviseur (Objet DKK) 09/27/2010 16:56:09 (RMA)
######################################################################################
$ACTION
Case ACTION
  When "INICRE"     : Gosub INICRE
  When "INIMOD"     : Gosub INIMOD
  When "LIENS"      : Gosub LIENS
  When "CHANGE"     : Gosub CHANGE
  When "ANNULE"     : Gosub ANNULE
  When Default
Endcase

Return
######################################################################################
##
######################################################################################
$INICRE
Gosub MAJ_AXX

Return
######################################################################################
##
######################################################################################
$CHANGE
Update [AXX] Where CODFIC="DKSKEY" & IDENT1=[L]SUPP & IDENT2=[L]OCODE With IDENT2=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA DKSKEY"-[L]SUPP-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]SUPP-[L]OCODE) From GLOCK : Return
Endif

Return
######################################################################################
##
######################################################################################
$ANNULE
Delete [AXX] Where CODFIC="DKSKEY" & IDENT1=[L]SUPP & IDENT2=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]SUPP-[L]CODE) From GLOCK : Return
Endif

Return
######################################################################################
##
######################################################################################
$INIMOD
Gosub MAJ_AXX

Return
######################################################################################
##
######################################################################################
$LIENS
Call LECTEXTRA([M:DKK1]KEYDES,"DKSKEY","KEYDES",[F:DKK]KEYCODE,num$([F:DKK]KEYVER)) From ATEXTRA

Return
######################################################################################
##
######################################################################################
$MAJ_AXX

Call MAJTEXTRA ([M:DKK1]KEYDES,"DKSKEY","KEYDES",[F:DKK]KEYCODE,num$([F:DKK]KEYVER)) From ATEXTRA

Return
######################################################################################
## Field Actions
######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran DKK1) 29-09-2010 19:15:09 (RMA)
######################################################################################
Subprog IB_ANMCODE

If [M:DKK1]ANMCODE(indice) = "" : End : Endif

If !func AFNC.ACTIV("DKS") : End : Endif

If !clalev([F:DKD]) : Local File DKSDATA [DKD] : Endif

Filter [F:DKD] Where [F:DKD]ANMCODE=[M:DKK1]ANMCODE(indice)
Read [F:DKD] First
Filter [F:DKD]

If !fstat
    Diszo [M:DKK1]ANMCODE(indice)
Endif

End
######################################################################################
