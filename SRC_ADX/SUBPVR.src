#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion objet PVR
Call OBJET("PVR",GBIDC1,"") From GOBJET
End

$ACTION

  Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "LIENS"     : Gosub LIENS
    When "FERME"      : Gosub FERME
    When "INIMOD"      : Gosub INIMOD
    When "INICRE"      : Gosub INICRE
    When "RAZDUP"      : Gosub RAZDUP
    When Default
  Endcase
Return

#################################
$OUVRE
Gosub OUVRE From TOOLSVAR
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

#################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#################################
$LIENS
GCURLEG=[F:PVR]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
#Gosub LOAD_TAB
Return

###################################
$INICRE
$INIMOD
#Gosub SAVE_TAB
Return

###################################
$RAZDUP
 Effzo[M]10
 [M]NBPVR=0
Return

#################################
$LOAD_TAB
If GCURLEG="" : Raz [M] : Return : Endif
nolign=1
For [F:PVR] Where LEG=GCURLEG
  [M]=[F:PVR]
  [M]KEYPVR(nolign-1) = func CRE_KEY(GCURLEG,[M]TYPFRT(nolign-1),[M]DESCATACN(nolign-1),[M]CRITTPS(nolign-1),[M]LEV(nolign-1),[M]DOSSIER(nolign-1),
&                                 [M]POP(nolign-1),[M]CPY(nolign-1),[M]FCY(nolign-1),[M]REFNUM(nolign-1),[M]CTRNUM(nolign-1),[M]SERVICE(nolign-1),
&                                 [M]CLLCVT(nolign-1),[M]PROFIL(nolign-1))
 nolign+=1
Next
[M]NBPVR=nolign-1
Affzo [M]
Return

#################################
$SAVE_TAB
Delete [F:PVR] Where LEG=GCURLEG
If fstat=1
 GOK =-1 : GLOCK = "$PARVAR" : Return
Endif
For nolign=1 To [M]NBPVR
 [F:PVR]=[M]
 [F:PVR]LEG=GCURLEG
 Write [PVR]
 If fstat<>0
  GOK = 0 : Call FSTA("PVR") From GLOCK : Break
 Endif
Next
Return

#################################
#*  Création de la clé : Dispositif + Catégorie + Critère temps + niveau + valeur relative au niveau
Funprog CRE_KEY( LEG,TYPFRT, DESCATACN, CRITTPS, LEV, ADXDOS, POP, CPY, FCY, REFNUM, CTRNUM, SERVICE, CLLCVT, PRFCOD)
Value    Char    LEG, ADXDOS, POP, CPY, FCY, REFNUM, CTRNUM, SERVICE, CLLCVT, PRFCOD
Value    Integer TYPFRT, DESCATACN, CRITTPS, LEV
Local    Char    KEYPVR
# LEG+SYSTEM USED+ACTION CATEGORY+ TIME CRITERION+LEVEL
  KEYPVR=LEG+"~"+num$(TYPFRT)+"~"+num$(DESCATACN)+"~"+num$(CRITTPS)+"~"+num$(LEV)
  Case LEV
    When 1 : KEYPVR += "~"+ADXDOS
    When 2 : KEYPVR += "~"+POP
    When 3 : KEYPVR += "~"+CPY
    When 4 : KEYPVR += "~"+FCY
    When 5 : KEYPVR += "~"+REFNUM
    When 6 : KEYPVR += "~"+CTRNUM
    When 7 : KEYPVR += "~"+SERVICE
    When 8 : KEYPVR += "~"+CLLCVT
    When 9 : KEYPVR += "~"+PRFCOD
  Endcase
End KEYPVR

######################################################################################
#           GESTION DES CHAMPS DE L'ECRAN PVR0
######################################################################################

#**
#* Reconstitution de la clé KEYPVR après changement du dispositif
#*
#* @param VALEUR
#*!
Subprog AM_TYPFRT(VALEUR)
Variable Integer VALEUR

  [M]KEYPVR(nolign-1) = func CRE_KEY(GCURLEG,VALEUR,[M]DESCATACN(nolign-1),[M]CRITTPS(nolign-1),[M]LEV(nolign-1),[M]DOSSIER(nolign-1),
&                                    [M]POP(nolign-1),[M]CPY(nolign-1),[M]FCY(nolign-1),[M]REFNUM(nolign-1),
&                                    [M]CTRNUM(nolign-1),[M]SERVICE(nolign-1),[M]CLLCVT(nolign-1),[M]PROFIL(nolign-1))
End

#**
#* Reconstitution de la clé KEYPVR après changement de la catégorie
#*
#* @param VALEUR
#*!
Subprog AM_DESCATACN(VALEUR)
Variable Integer VALEUR

  [M]KEYPVR(nolign-1) = func CRE_KEY(GCURLEG,[M]TYPFRT(nolign-1),VALEUR,[M]CRITTPS(nolign-1),[M]LEV(nolign-1),[M]DOSSIER(nolign-1),
&                                    [M]POP(nolign-1),[M]CPY(nolign-1),[M]FCY(nolign-1),[M]REFNUM(nolign-1),
&                                    [M]CTRNUM(nolign-1),[M]SERVICE(nolign-1),[M]CLLCVT(nolign-1),[M]PROFIL(nolign-1))
End

#**
#* Reconstitution de la clé KEYPVR après changement du critère temps
#*
#* @param VALEUR
#*!
Subprog AM_CRITTPS(VALEUR)
Variable Integer VALEUR
Local    Integer I, NOL, NOL2

  [M]KEYPVR(nolign-1) = func CRE_KEY(GCURLEG,[M]TYPFRT(nolign-1),[M]DESCATACN(nolign-1),VALEUR,[M]LEV(nolign-1),[M]DOSSIER(nolign-1),
&                                    [M]POP(nolign-1),[M]CPY(nolign-1),[M]FCY(nolign-1),[M]REFNUM(nolign-1),
&                                    [M]CTRNUM(nolign-1),[M]SERVICE(nolign-1),[M]CLLCVT(nolign-1),[M]PROFIL(nolign-1))

End

#**
#* Reconstitution de la clé KEYPVR après changement du niveau
#*
#* @param VALEUR
#*!
Subprog AM_LEV(VALEUR)
Variable Integer VALEUR

  # On annule d'abord la valeur du champ rattaché à l'ancien niveau
  Case [M]LEV(nolign-1)
    When 2 : [M]DOSSIER(nolign-1) = ""
    When 3 : [M]POP(nolign-1)     = ""
    When 4 : [M]CPY(nolign-1)     = ""
    When 5 : [M]FCY(nolign-1)     = ""
    When 6 : [M]REFNUM(nolign-1)  = ""
    When 7 : [M]CTRNUM(nolign-1)  = ""
    When 8 : [M]SERVICE(nolign-1) = ""
    When 9 : [M]CLLCVT(nolign-1)  = ""
    When 10 : [M]PROFIL(nolign-1)  = ""
    Affzo [M]

  Endcase

  If VALEUR=2 Then
    [M]LEV(nolign-1)=VALEUR
    [M]DOSSIER(nolign-1)=nomap
    Call VERIF_UNICITE([M]DOSSIER(nolign-1))
  Endif

  [M]KEYPVR(nolign-1) = func CRE_KEY(GCURLEG,[M]TYPFRT(nolign-1),[M]DESCATACN(nolign-1),[M]CRITTPS(nolign-1),VALEUR,
&                                    [M]DOSSIER(nolign-1),[M]POP(nolign-1),[M]CPY(nolign-1),[M]FCY(nolign-1),
&                                    [M]REFNUM(nolign-1),[M]CTRNUM(nolign-1),[M]SERVICE(nolign-1),
&                                    [M]CLLCVT(nolign-1),[M]PROFIL(nolign-1))
End

######################################################################################
# La combinaison Dispositif+Catégorie+Critère temps+Niveau+champ relatif au niveau doit
# être unique
######################################################################################
Subprog VERIF_UNICITE(VALEUR)
Value Char    VALEUR

  Call UNICITE(GCURLEG+"~"+num$([M]TYPFRT(nolign-1))+"~"+num$([M]DESCATACN(nolign-1))+"~"+num$([M]CRITTPS(nolign-1))+"~"+num$([M]LEV(nolign-1))+"~"+VALEUR, [M]KEYPVR) From OBJDIV
  If GMESSAGE="" Then
    [M]KEYPVR(nolign-1)=GCURLEG+"~"+num$([M]TYPFRT(nolign-1))+"~"+num$([M]DESCATACN(nolign-1))+"~"+num$([M]CRITTPS(nolign-1))+"~"+num$([M]LEV(nolign-1))+"~"+VALEUR
  Endif
End

Subprog AM_DOSSIER(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_POP(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_SERVICE(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_CLLCVT(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_PROFIL(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

######################################################################################
# Seul le champ relatifs au niveau sélectionné peut être saisissable
