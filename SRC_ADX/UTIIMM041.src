#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIIMM041   UTI process                                    Module 14   #
#            correction utility
#
# Issue X3-55064 - 2017-09-18 by CBO : The location must have a financial FCY
#
##########################################################################
Local Char WDOSSIER(30) : WDOSSIER = GDOSX3

  Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

  If WDOSSIER <> ""
    If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

    If func AFNC.ACTIVDOS(WDOSSIER, "PHY") <= 0
      End
    Endif

    Call TEMPON("O") From GESECRAN

    Call OUVRE_TRACE("Correction UTIIMM041") From LECFIC
    Call MAJ_UTIIMM041(WDOSSIER)

    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif

Close Local File
End

##########################################################################
# location's facility must be financial
Subprog MAJ_UTIIMM041(DOSSIER)
Value Char DOSSIER()

  If (func DOSSUB.ISHISTFOLD(DOSSIER))
    Call ECR_TRACE("UTIIMM041 : Not to perform on archive folder : "+DOSSIER,0) From GESECRAN
    End
  Endif

  Local Integer WNB_LCT, WNB_PHY

  If filinfo(filpath("FIL", "PHYLCT", "fde", DOSSIER), 0) <= 0
    Call ECR_TRACE("UTIIMM041 : PHYLCT table not found on folder : " + DOSSIER, 1) From GESECRAN
    End
  Endif

  Call ECR_TRACE("UTIIMM041 : Update of FCY in PHYLCT table with the financial one (folder :" - DOSSIER - ")", 0) From GESECRAN

  # table PHYLCT
  If clalev([F:LCT]) :  Close File  [LCT]   :  Endif
  Local File =DOSSIER + ".PHYLCT" [LCT]

  # table FACILITY
  If clalev([F:FCY]) :  Close File  [FCY]   :  Endif
  Local File =DOSSIER + ".FACILITY"  [FCY]

  # table PHYELT
  If clalev([F:PHY]) :  Close File  [PHY]   :  Endif
  Local File =DOSSIER + ".PHYELT"  [PHY]

  GOK = 1
  Trbegin [LCT]

  For [F:LCT]LCT0

    Read[FCY]FCY0= [F:LCT]FCY
    If fstat
      Call ECR_TRACE("Warning facility not read <" - [F:LCT]FCY - "> fstat =" - num$(fstat), 0) From GESECRAN
    Else
      If [F:FCY]FINFLG <> 2

        Call ECR_TRACE([F:LCT]LCTCOD - "Location :" - [F:LCT]FCY - "facility is replaced by" - [F:FCY]FINRSPFCY, 0) From GESECRAN

        # verify the FCY of physical elements
        Filter [PHY] Where LCTCOD = [F:LCT]LCTCOD and FCY <> [F:FCY]FINRSPFCY
        For [F:PHY]PHY0

          Call ECR_TRACE("->" - [PHY]PHYREF - "Physical element has" - [PHY]FCY - "facility instead of" - [F:FCY]FINRSPFCY, 0) From GESECRAN
          WNB_PHY += 1

        Next
        Filter [PHY]

        WNB_LCT += 1
        [F:LCT]FCY = [F:FCY]FINRSPFCY
        Rewrite [LCT]
        If fstat
          GOK = 0
          Break
        Endif
      Endif
    Endif
  Next

  If GOK
    Commit
    Call ECR_TRACE("UTIIMM041 :" - num$(WNB_LCT) - "updated locations", 0) From GESECRAN
    Call ECR_TRACE("UTIIMM041 :" - num$(WNB_PHY) - "physical elements with a different FCY than location", 0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("Errors detected in UTIIMM041 migration - Rollback executed fstat =" - num$(fstat) - "for location =" - [F:LCT]LCTCOD, 1) From GESECRAN
  Endif
  Close File  [PHY], [LCT], [FCY]

  Call ECR_TRACE("", 0) From GESECRAN
  Call ECR_TRACE("End of MAJ_FCY_LOCATION", 0) From GESECRAN

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3
    End
  Endif

  If filinfo(filpath("FIL", "PHYLCT", "fde", APPLI), 0) <= 0
    End
  Endif

  Call MAJ_UTIIMM041(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI=GDOSX3
    End
  Endif

  If filinfo(filpath("FIL", "PHYLCT", "fde", APPLI), 0) <= 0
    End
  Endif

  Call MAJ_UTIIMM041(APPLI)
End

