#<AdxTL>@(#)169.0.0.0 $Revision$
Local Char    TPLAN(GLONCOA)(1..len(mess(0,2644,1))), TCOMPTE(GLONGAC)(1..len(mess(0,2644,1)))
Local Integer STAT
Local Integer I
Local Char    ID1(20)(1..5) , ID2(20)(1..5)
Local Char    MESSA(250)

# Identificateur de la première table (en-tête)
ID1(1) = "FACMPD250000049"
# Identificateur de la deuxième table (lignes)
ID2(1) = "FACMPD250000049"
ID2(2) = "2"

## BPCIN est le code de la pièce automatique
## 2 est le numéro de la ligne d'écriture générée

Call COMPTE("BPCIN",2,ID1,ID2,TPLAN,TCOMPTE,STAT,MESSA)

If STAT
 Call ECR_TRACE(MESSA,1) From GESECRAN
Else
 For I=1 To len(mess(0,2644,1))
 # Infbox TPLAN(I)-TCOMPTE(I)
 Next
Endif
End

##############################################################
Subprog COMPTE(REFGAD,LIG,IDENT1,IDENT2,TPLAN,TCOMPTE,STAT,MESSA)
Value    Char    REFGAD
Value    Integer LIG
Value    Char    IDENT1()(1..)
Value    Char    IDENT2()(1..)
Variable Char    TPLAN()(1..)
Variable Char    TCOMPTE()(1..)
Variable Integer STAT
Variable Char    MESSA

Local Integer I , J , K , ERR , OK
Local Char    CLECPT(50) , CODCPT(10) , MSKCPT(10) , SITE(GLONFCY)
Local Char    TIERS(GLONBPR), IDENT(30)
Local Char    SITE(GLONFCY)
Local Integer NBCLE
Local Char    CLE(10)(1..8)
Local Char    PROG(10)
Local Integer TLEDTYP(1..len(mess(0,2644,1)))
Local Integer NBLEDTYP
# Issue 95188 - 2014-01-09 by SR
Local Integer TBTYPLED (1..len(mess(0,2644,1)))
Local Integer TBNBRLED

STAT = 0
If clalev([F:ATI])=0 : Local File ATABIND  [ATI] : Endif
If clalev([F:CAC])=0 : Local File GACCCODE [CAC] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
If clalev([F:GAU])=0 : Local File GAUTACE  [GAU] : Endif
If clalev([F:GAD])=0 : Local File GAUTACED [GAD] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif

Read [GAU]GAU0 = REFGAD
If fstat : MESSA = REFGAD : STAT = 1 : Goto FIN : Endif
Read [GAD]GAD0 = REFGAD;LIG
If fstat : STAT = 2 : Goto FIN : Endif
PROG = "WMGAU"+REFGAD
Gosub OUVRE From =PROG

## Types Référentiels pour lesquels un compte sera mouvementé
# Issue 95188 - 2014-01-09 by SR : Liste des types de référentiel de la société
Call LSTLEDTYP(GSOCIETE,0,[L]TBTYPLED,[L]TBNBRLED) From CPTDIV
Raz TLEDTYP, NBLEDTYP
For I=1 To [F:GAD]NBRLED
# Issue 95188 - 2014-01-09 by SR : si référentiel doit être mouvementé
 If find([F:GAD]LEDTYP(I-1),[L]TBTYPLED(1..[L]TBNBRLED))
   NBLEDTYP += 1
  TLEDTYP(NBLEDTYP) = [F:GAD]LEDTYP(I-1)
 Endif
Next

Local Char TSAC(GLONSAC)(1..NBLEDTYP), TCOA(GLONCOA)(1..NBLEDTYP), TACC(GLONGAC)(1..NBLEDTYP)

# Lecture table déclenchante no 1
If clalev([F:TB0])=0
 Onerrgo ERREUR
 Local File =[F:GAU]TBL [TB0]
 Onerrgo
 If ERR :  MESSA = [F:GAU]TBL : STAT = 3 : Goto FIN : Endif
 Gosub CLE From =PROG
 If NBCLE>dim(IDENT1) : STAT = 4 : Goto FIN : Endif
 CRITERE = ""

 For I=1 To NBCLE
  If I>1 : CRITERE += " & " : Endif
  Case evalue("type([F:TB0]"+CLE(I)+")")
   When 1,2,4,5,6,7,8,9
    CRITERE += CLE(I)+'='+IDENT1(I)
   When 3
    CRITERE += CLE(I)+'=['+format$(GFMD,gdat$(IDENT1(I)))+']'
   When Default
    CRITERE += CLE(I)+'="'+IDENT1(I)+'"'
  Endcase
 Next I
 Default File [TB0]

 Filter [TB0] Where evalue(CRITERE)
 Read First
Endif

# Lecture table déclenchante no 2
If [F:GAD]LINTBL1<>"" & clalev([F:TB1])=0
 Onerrgo ERREUR
 Local File =[F:GAD]LINTBL1 [TB1]
 Onerrgo
 If ERR : MESSA = [F:GAD]LINTBL1 : STAT = 6 : Goto FIN : Endif
 Default File [TB1]
 CRITERE = ""
 For I=1 To NBCLE
  If I>1 : CRITERE += " & " : Endif
  Case evalue("type([F:TB1]"+CLE(I)+")")
   When 1,2,4,5,6,7,8,9
    CRITERE += CLE(I)+'='+IDENT2(I)
   When 3
    CRITERE += CLE(I)+'=['+format$(GFMD,gdat$(IDENT2(I)))+']'
   When Default
    CRITERE += CLE(I)+'="'+IDENT2(I)+'"'
  Endcase
 Next I
 Filter [TB1] Where evalue(CRITERE)
 Read First
 If fstat>2 : MESSA = [F:GAD]LINTBL1 : STAT = 10 : Goto FIN : Endif
Endif

OK = 1
# Test des conditions
If [F:GAU]FORCND<>""
 OK = evalue([F:GAU]FORCND)
 If !OK : End : Endif
Endif
For I=0 To dim([F:GAD]FORCND)-1
 If [F:GAD]FORCND(I)<>""
  OK = evalue([F:GAD]FORCND(I))
  If !OK : Break : Endif
 Endif
Next
If !OK : Goto FIN : Endif

If GSOCIETE<>""
 Call EVAL_CHAR(SITE,"FCY",1,0,GFCYDEF,STAT) From CPTAUTO
 If STAT : MESSA = "FCY" : Goto FIN : Endif
 Read [FCY]FCY0 = SITE
 If fstat : MESSA = SITE : STAT = 14 : Goto FIN : Endif
 If [F:FCY]FINFLG<>2
  SITE = [F:FCY]FINRSPFCY : # Site financier
  Read [FCY]FCY0 = SITE
  If fstat : MESSA = SITE : STAT = 14 : Goto FIN : Endif
 Endif
 Call GETSOC(SITE) From DEVSUB
Endif

Call CPTNAT(NBLEDTYP,TLEDTYP,TCOA,TACC,TSAC,TIERS,0,IDENT,datesyst,STAT,MESSA) From TRTPCE
If STAT : Goto FIN : Endif
Raz TPLAN, TCOMPTE
For I=1 To NBLEDTYP
 Assign "TPLAN("+num$(TLEDTYP(I))+")" With TCOA(I)
 Assign "TCOMPTE("+num$(TLEDTYP(I))+")" With TACC(I)
Next

$FIN
If STAT : Gosub MESSAGE From CPTAUTO : Endif
End


$ERREUR
ERR = errn
Resume
