#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE"          : Gosub OUVRE_AFCPAR
  When "INIT"           : Gosub INIT_AFCPAR
  When "DEBUT"          : Gosub DEBUT_AFCPAR
  When "CONTROLE"       : Gosub CONTROLE_AFCPAR
  When "EXEC"           : Gosub EXEC_AFCPAR
  When "APRES_MODIF"    : Gosub APRES_MODIF_AFCPAR
  When "BOUTON"         : Gosub BOUTON_AFCPAR
  When "OK"             : Gosub OK_AFCPAR
  When "END"            : Gosub END_AFCPAR
  When "FIN"            : Gosub FIN_AFCPAR
Endcase
Return
############################################################
$OUVRE_AFCPAR
If !clalev([F:AFC])  Local File AFONCTION    [AFC] : Endif
If !clalev([F:ACT])  Local File ACTION       [ACT] : Endif
If !clalev([F:ATR])  Local File ACTPAR       [ATR] : Endif
Return
############################################################
$INIT_AFCPAR
Return
############################################################
$CONTROLE_AFCPAR
Return
############################################################
$EXEC_AFCPAR
Return
############################################################
$FIN_AFCPAR
#If [M:AFCP]NBAFC > 0
#  Call PRTSCR("XXAFCPAR","AFCP","",0,0) From ATRTX3
#  Call IMPSCR From ATRTX3
#Endif
Return
############################################################
$DEBUT_AFCPAR
Raz [M:AFCP]
Affzo [M:AFCP]
Return
############################################################
$APRES_MODIF_AFCPAR
Return
############################################################
$BOUTON_AFCPAR
Return
############################################################
$OK_AFCPAR
Call TEMPOFF From GESECRAN
Affzo [M:AFCP]
Return
############################################################
$END_AFCPAR
Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran XXAFCPAR) 02/03/2006 10:19:45 (GA)
######################################################################################
Subprog AS_PARAM(VALEUR)
Variable Char    VALEUR()
Raz [M:AFCP]
Affzo [M:AFCP]
End

Subprog AM_PARAM(VALEUR)
Variable Char    VALEUR()
Local    Char    WCODPAR(GLONREF) : WCODPAR=VALEUR
Local    Integer I
If VALEUR="" : mkstat=2 : End : Endif
Filter [AFC] Where NBVAR>0
For [AFC]
   For I=0 To [F:AFC]NBVAR
     If ([F:AFC]CODPAR(I) = WCODPAR)
       nolign=[M:AFCP]NBAFC+1
       [M:AFCP]CODINT(nolign-1) = [F:AFC]CODINT
       [M:AFCP]NOM   (nolign-1) = [F:AFC]NOM
       Call TEXTE([M:AFCP]NOM(nolign-1),[M:AFCP]ZNOM(nolign-1)) From OBJDIV
       [M:AFCP]NOVAR(nolign-1) = I+1
       [M:AFCP]NBAFC += 1
       nolign=1
       Break
     Endif
   Next
   If [M:AFCP]NBAFC=20 : Break : Endif
Next
Filter [AFC]
#
Filter [ATR] Where CODPAR = WCODPAR
For [ATR]
   Read [ACT]ACTION = [F:ATR]ACTION
   If !fstat
     nolign=[M:AFCP]NBACT+1
     [M:AFCP]ZACTION(nolign-1) = [F:ACT]ACTION
     [M:AFCP]INTITA (nolign-1) = [F:ACT]INTITA
     [M:AFCP]NOPAR  (nolign-1) = [F:ATR]NOPAR
     Call TEXTE([M:AFCP]INTITA(nolign-1),[M:AFCP]ZINTITA(nolign-1)) From OBJDIV
     [M:AFCP]NBACT += 1
     nolign=1
   Endif
   If [M:AFCP]NBACT=20 : Break : Endif
Next
Filter [ATR]
nolign=1
#
Affzo [M:AFCP]

End


######################################################################################


