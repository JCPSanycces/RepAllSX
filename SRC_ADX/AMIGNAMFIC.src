#<AdxTL>@(#)10.0.0.0 $Revision$ Migration des pièces jointes
Local Char PARAM(10)(1..2) , VALEUR(10)
Raz GNBMASKOUV, GPILOBJ
Call TRAITE_CHAR(VALEUR,PARAM,"","AMIGNAMFIC","AMIGNAMFIC",4,"") From GTRAITE
End

#-----------------------------#
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "DEBUT"    : Gosub DEBUT
 When "SETBOUT"  : Gosub SETBOUT
 When "BOUTON"   : Gosub BOUTON
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
Endcase
Return

#-----------------------------#
$INIT
If clalev([F:AVL])=0 : Local File AVOLUME [AVL] : Endif
Local Mask AMIGNAMFIC [AMIG1]
TIT = mess(345,139,1) : # Migration des noms de fichiers
PARAM(1) = ""
Return

#-----------------------------#
$DEBUT
Raz [M]
Call CHECK_FILE([M]NBRREP,[M]REPERT,[M]VOLUME,[M]NOMBRE,[M]NBRVOL,[M]CODVOL,[M]PATVOL)
Sorta [M]NBRREP [M]NBRREP Order By [M]VOLUME(indice),[M]REPERT(indice)
[M]TOTAL = sum([M]NOMBRE)
For I=1 To [M]NBRVOL
 [M]ACTVOL(I-1) = 2
 [M]REAVOL(I-1) = 0
 [M]CREVOL(I-1) = 0
Next I
For I=1 To [M]NBRREP
 If [M]VOLUME(I-1) = mess(341,139,1) : # Volume inexistant
  If [M]NBRVOL>=dim([M]CODVOL)
   Call ECR_TRACE(mess(347,139,1),0) From GESECRAN : # Trop de volumes
   Break
  Else
   [M]NBRVOL += 1
   [M]PATVOL([M]NBRVOL-1) = [M]REPERT(I-1)
   [M]CODVOL([M]NBRVOL-1) = ""
   [M]ACTVOL([M]NBRVOL-1) = 1
   [M]REAVOL([M]NBRVOL-1) = 1
   [M]CREVOL([M]NBRVOL-1) = 1
  Endif
 Endif
Next I
Sorta [M]NBRVOL [M]NBRVOL Order By [M]CODVOL(indice),[M]PATVOL(indice)
Affzo
For I=1 To [M]NBRVOL
 If [M]ACTVOL(I-1)=2
  Grizo [M:AMIG1]PATVOL(I-1),CODVOL(I-1),REAVOL(I-1),CREVOL(I-1)
 Endif
Next I
Return

#-----------------------------#
$SETBOUT
If PARAM(1)="" or filinfo(filpath("TRA",PARAM(1),"tra"),7)<=0 : Call VIREBOUT(CHMEN,"2") From GOBJET : Endif
Return

#-----------------------------#
$BOUTON
Case BOUT
 When "1" : Gosub VALID
 When "2" : Gosub TRACE
 When "3" : Gosub DEBUT
 When "4" : Gosub VERIF
Endcase
Return

#----------------------------#
$VALID
REPONSE = GSTAOK
FIN = 1
Return

#----------------------------#
$TRACE
If PARAM(1)<>"" : Call LECFIC("TRA",PARAM(1),"tra") From LECFIC : Endif
Return

#----------------------------#
$VERIF
# Contrôle des pièces jointes
Call OUVRE_TRACE(mess(353,139,1)) From LECFIC
Call CONTROL_FILE_ON_SPACE
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
Return

#-----------------------------------#
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1 : Return
Endif
Return

#-----------------------------#
$EXEC
Call OUVRE_TRACE(TIT) From LECFIC
Call VALID_FILE
Call FERME_TRACE From LECFIC
PARAM(1) = GTRACE
If !GSERVEUR
 SAI = 1
Endif
Return

#---------------------------------------------------#
Subprog CONTROL_FILE_ON_SPACE
Local Integer  I , J , K , L , OK , NBZ , DIME , OKU , NBU , IV
Local Char     TBZ(GLONAVA)(1..10) , FICHIER(255) , ZONE(50)
Local Char     REPERT(255) , CHAINE(255) , CHAINE2(255) , SEP(1)
Local Char     MESSAGE(255) , VOLUME(GLONAVL)
Local Char     TBD(GLONADI)(1..100)
Local Integer  NBD
Local Shortint MAXVOL : MAXVOL = dim([M:AMIG1]CODVOL)
Local Shortint NBV
Local Char     VBV(GLONAVL)(1..MAXVOL) , TBV(250)(1..MAXVOL)
Local Shortint LBV(1..MAXVOL)
Local Integer  TOPLST

Local File ATABDIV [ADI] , ATABZON [ATZ]
If clalev([F:AVL])=0 : Local File AVOLUME [AVL] : Endif

NBD = 0
For [ADI] Where NUMTAB=902
 If [F:ADI]CODE="RTF" & find([F:ADI]N1,0,3)    : # Type des fichiers .rtf gérés en clob
 Elsif [F:ADI]CODE="TXT" & find([F:ADI]N1,0,3) : # Type des fichiers .txt gérés en clob
 Elsif [F:ADI]CODE="PIC" & find([F:ADI]N1,0,2) : # Type des images gérées en blob
 Else
  NBD += 1
  TBD(NBD) = [F:ADI]CODE
 Endif
Next ADI
For [ADI]CODE Where NUMTAB=902 & N1=1 : # Only file
 If !find([F:ADI]CODE,TBD)
  NBD += 1
  TBD(NBD) = [F:ADI]CODE
 Endif
Next ADI

Read [ATZ]CODZONE="AOBJTXT";"NAM"
NBZ = 1
TBZ(NBZ) = [F:ATZ]CODZONE

NBV = 0
For [AVL]
 NBV += 1
 If !instr(1,[F:AVL]ROOT,"@") and !find(left$([F:AVL]ROOT,1),"\","/") & !instr(1,[F:AVL]ROOT,":")
  TBV(NBV) = filpath([F:AVL]ROOT,"","","","","")
 Else
  TBV(NBV) = [F:AVL]ROOT
 Endif
 VBV(NBV) = [F:AVL]VOLUME
 LBV(NBV) = len(TBV(NBV))
Next AVL
Sorta NBV LBV,VBV,TBV Order By LBV(indice+1) Desc

Local File =[F:ATZ]CODFIC [AA_]

For [AA_]
 OK = 1
 If [F:ATZ]CODFIC="AOBJTXT" & !find([F:AA_]TYPDOC,TBD(1..NBD))
  OK = 0
 Endif
 If OK
  For I=1 To NBZ
   DIME = evalue("dim([F:AA_]"+TBZ(I)+")")
   If DIME=1
    [L]ZONE = "[F:AA_]"+TBZ(I)
    [L]FICHIER = evalue("[F:AA_]"+TBZ(I))
    Gosub LOG_CONTROL
   Else
    For J=1 To DIME
     [L]ZONE = "[F:AA_]"+TBZ(I)+"("+num$(J-1)+")"
     [L]FICHIER = evalue("[F:AA_]"+TBZ(I)+"("+num$(J-1)+")")
     Gosub LOG_CONTROL
    Next J
   Endif
  Next I
 Endif
Next AA_

Close Local File

End

#-----------------------------------#
$LOG_CONTROL
If find(left$([L]FICHIER,1),"[")
 K = instr(1,[L]FICHIER,"]")
 If K
  If !TOPLST
   Case [F:ATZ]CODFIC
    When "AOBJTXT"
     TOPLST = 1
     Call ECR_TRACE("Object - Key - File",0) From GESECRAN
     Call ECR_TRACE(string$(50,"-"),0) From GESECRAN
   Endcase
  Endif
  Case [F:ATZ]CODFIC
   When "AOBJTXT" : CHAINE = [F:AA_]ABREV+"("+func AFNC.INTABR([F:AA_]ABREV)+") - "+[F:AA_]IDENT1-[F:AA_]IDENT2
   When Default   : CHAINE = ""
  Endcase
  [L]VOLUME = seg$([L]FICHIER,2,K-1)
  IV = find([L]VOLUME,VBV)
  If IV
   [L]FICHIER = TBV(IV)+right$(FICHIER,K+1)
   If filinfo([L]FICHIER,0)>0
    #Call ECR_TRACE(CHAINE+"- |"+[L]FICHIER-": OK",0) From GESECRAN
   Else
    Call ECR_TRACE(CHAINE+"- |"+[L]FICHIER-":"-mess(101,100,1),1) From GESECRAN : # Fichier inexistant
   Endif
  Else
   Call ECR_TRACE(CHAINE+" - "+[L]VOLUME-":"-mess(341,139,1),1) From GESECRAN : # Volume inexistant
  Endif
 Endif
Endif
Return

#------------------------------------------------------------------#
Subprog VALID_FILE
Local Shortint MAXVOL : MAXVOL = dim([M:AMIG1]CODVOL)
Local Shortint NBV
Local Char     VBV(GLONAVL)(1..MAXVOL) , TBV(250)(1..MAXVOL)
Local Shortint LBV(1..MAXVOL)
Local Integer  I , J , K , L , OK , NBZ , DIME , OKU , NBU
Local Char     TBZ(GLONAVA)(1..10) , FICHIER(255) , ZONE(50)
Local Char     REPERT(255) , CHAINE(255) , CHAINE2(255) , SEP(1)
Local Char     MESSAGE(255) , VOLUME(GLONAVL)
Local Char     TBD(GLONADI)(1..100)
Local Integer  NBD , TOPLST

Local File ATABDIV [ADI] , ATABZON [ATZ]
If clalev([F:AVL])=0 : Local File AVOLUME [AVL] : Endif

# Create volumes
Trbegin [AVL]
 For I=1 To [M]NBRVOL
  If [M]CREVOL(I-1)=2
   Raz [F:AVL]
   [F:AVL]VOLUME = [M]CODVOL(I-1)
   [F:AVL]ROOT   = [M]PATVOL(I-1)
   [F:AVL]VOLTYP = 1
   Write [AVL]
   If fstat
    Call ERREUR([F:AVL]VOLUME,1) From DOSDIC
   Endif
  Endif
  [M]LENVOL(I-1) = len([M]PATVOL(I-1))
 Next I
Commit

Sorta [M]NBRVOL [M]NBRVOL Order By [M]LENVOL(indice),[M]PATVOL(indice) Desc

Call PARAM("","DIRPCE",[L]REPERT) From ADOVAL
If [L]REPERT=""
 Call PARAM("","DIRPCE1",CHAINE) From ADOVAL
 Call PARAM("","DIRPCE2",CHAINE2) From ADOVAL
 [L]REPERT = CHAINE+CHAINE2
Endif

NBD = 0
For [ADI] Where NUMTAB=902
 If [F:ADI]CODE="RTF" & find([F:ADI]N1,0,3)    : # Type des fichiers .rtf gérés en clob
 Elsif [F:ADI]CODE="TXT" & find([F:ADI]N1,0,3) : # Type des fichiers .txt gérés en clob
 Elsif [F:ADI]CODE="PIC" & find([F:ADI]N1,0,2) : # Type des images gérées en blob
 Else
  NBD += 1
  TBD(NBD) = [F:ADI]CODE
 Endif
Next ADI
For [ADI]CODE Where NUMTAB=902 & N1=1 : # Only file
 If !find([F:ADI]CODE,TBD)
  NBD += 1
  TBD(NBD) = [F:ADI]CODE
 Endif
Next ADI

Read [ATZ]CODZONE="AOBJTXT";"NAM"
NBZ = 1
TBZ(NBZ) = [F:ATZ]CODZONE

NBU = 0
Local File =[F:ATZ]CODFIC [AA_]
Trbegin [AA_]
 For [AA_]
  OK = 1
  If [F:ATZ]CODFIC="AOBJTXT" & !find([F:AA_]TYPDOC,TBD(1..NBD))
   OK = 0
  Endif
  If OK
   For I=1 To NBZ
    DIME = evalue("dim([F:AA_]"+TBZ(I)+")")
    If DIME=1
     [L]ZONE = "[F:AA_]"+TBZ(I)
     [L]FICHIER = evalue("[F:AA_]"+TBZ(I))
     Gosub UPDATE_FILE
    Else
     For J=1 To DIME
      [L]ZONE = "[F:AA_]"+TBZ(I)+"("+num$(J-1)+")"
      [L]FICHIER = evalue("[F:AA_]"+TBZ(I)+"("+num$(J-1)+")")
      Gosub UPDATE_FILE
     Next J
    Endif
   Next I
  Endif
 Next AA_
Commit

Close Local File

Call ECR_TRACE(func AFNC.MES1(mess(344,139,1),num$(NBU)),0) From GESECRAN

If !GSERVEUR
 # $1$ fichiers ont été modifiés
 Call MESSAGE(func AFNC.MES1(mess(344,139,1),num$(NBU))) From GESECRAN
Endif

End

#-------------------#
$UPDATE_FILE
If [L]FICHIER=""
 Return
Elsif find(left$([L]FICHIER,1),"[")
 Return
Elsif find(left$([L]FICHIER,1),"'",'"','=')
 Return
Elsif find(left$([L]FICHIER,2),'#@')
 Gosub UPDATE_PC
 Return
Elsif find(left$([L]FICHIER,1),'#')
 Return
Endif
If left$([L]FICHIER,1)="%" & [L]REPERT<>""
 If instr(1,[L]REPERT,"\")
  SEP = "\"
 Else
  SEP = "/"
 Endif
 K = find(right$([L]REPERT,len([L]REPERT)),'/','\')
 L = find(left$([L]FICHIER,1),'/','\')
 If K and L
  [L]FICHIER = [L]REPERT + right$([L]FICHIER,2)
 Elsif !K and !L
  [L]FICHIER = [L]REPERT + SEP + right$([L]FICHIER,2)
 Else
  [L]FICHIER = [L]REPERT + right$([L]FICHIER,2)
 Endif
Endif
If left$([L]FICHIER,1)='%'
 Return
Endif
Gosub UPDATE_PATH
Return

#---------------------------#
$UPDATE_PATH
Local Char TEMP(250)
Local Integer P
TR = 0
For V=1 To [M]NBRVOL
 If ([M]CREVOL(V-1)=2 or [M]REAVOL(V-1)=2 or [M]ACTVOL(V-1)=2) & [M]CODVOL(V-1)<>""
  If left$([L]FICHIER,len([M]PATVOL(V-1)))=[M]PATVOL(V-1)
   TR = V : Break
  Endif
 Endif
Next V
If TR
 Readlock [AA_] Curr
 If !fstat
  TEMP = right$([L]FICHIER,len([M]PATVOL(TR-1))+1)

  #SAM 108866
  P = instr(1,TEMP,'\')
  While P
   TEMP = left$(TEMP,P-1)+'/'+right$(TEMP,P+1)
    P = instr(P+1,TEMP,'\')
  Wend
  Assign ZONE With "["+[M]CODVOL(TR-1)+"]"+TEMP

  If dim([F:AA_]UPDDATTIM)>0
   [F:AA_]UPDDATTIM = datetime$
  Endif
  Rewrite [AA_]
  If fstat
   Call ERREUR([F:ATZ]CODFIC-[M]PATVOL(TR-1),2) From DOSDIC
  Else
   If !TOPLST
    Case [F:ATZ]CODFIC
     When "AOBJTXT"
      TOPLST = 1
      Call ECR_TRACE("Object - Key - File",0) From GESECRAN
      Call ECR_TRACE(string$(50,"-"),0) From GESECRAN
    Endcase
   Endif
   Case [F:ATZ]CODFIC
    When "AOBJTXT" : CHAINE = [F:AA_]ABREV+"("+func AFNC.INTABR([F:AA_]ABREV)+") - "+[F:AA_]IDENT1-[F:AA_]IDENT2
    When Default   : CHAINE = ""
   Endcase
   Call ECR_TRACE(CHAINE+' - |'+evalue(ZONE),0) From GESECRAN
   NBU += 1
  Endif
 Endif
Endif
Return

#----------------------#
$UPDATE_PC
TR = 0
For V=1 To [M]NBRVOL
 If [M]REAVOL(V-1)=2 & [M]CODVOL(V-1)<>"" & [M]PATVOL(V-1)=mess(354,139,1)
  TR = V : Break
 Endif
Next V
If TR
 Readlock [AA_] Curr
 If !fstat
  K = instr(1,[L]FICHIER,":")
  If K
   Assign ZONE With "["+[M]CODVOL(TR-1)+"]"+right$([L]FICHIER,K+1)
   If dim([F:AA_]UPDDATTIM)>0
    [F:AA_]UPDDATTIM = datetime$
   Endif
   Rewrite [AA_]
   If fstat
    Call ERREUR([F:ATZ]CODFIC-[M]PATVOL(TR-1),2) From DOSDIC
   Else
    If !TOPLST
     Case [F:ATZ]CODFIC
      When "AOBJTXT"
       TOPLST = 1
       Call ECR_TRACE("Object - Key - File",0) From GESECRAN
       Call ECR_TRACE(string$(50,"-"),0) From GESECRAN
     Endcase
    Endif
    Case [F:ATZ]CODFIC
     When "AOBJTXT" : CHAINE = [F:AA_]ABREV+"("+func AFNC.INTABR([F:AA_]ABREV)+") - "+[F:AA_]IDENT1-[F:AA_]IDENT2
     When Default   : CHAINE = ""
    Endcase
    Call ECR_TRACE(CHAINE+' - |'+evalue(ZONE),0) From GESECRAN
    NBU += 1
   Endif
  Endif
 Endif
Endif
Return

#------------------------------------------------------------------#
Subprog TRACE_FILE(REP,VOL)
Value Char REP , VOL
Local Integer  I , J , K , L , OK , NBZ , DIME , OKU , NBU
Local Char     TBZ(GLONAVA)(1..10) , FICHIER(255) , ZONE(50)
Local Char     REPERT(255) , CHAINE(255) , CHAINE2(255) , SEP(1)
Local Char     MESSAGE(255) , VOLUME(GLONAVL)
Local Char     TBD(GLONADI)(1..100)
Local Integer  NBD
Local Shortint MAXVOL : MAXVOL = dim([M:AMIG1]CODVOL)
Local Shortint NBV
Local Char     VBV(GLONAVL)(1..MAXVOL) , TBV(250)(1..MAXVOL)
Local Shortint LBV(1..MAXVOL)
Local Integer  TOPLST

Local File ATABDIV [ADI] , ATABZON [ATZ]
If clalev([F:AVL])=0 : Local File AVOLUME [AVL] : Endif

Call PARAM("","DIRPCE",[L]REPERT) From ADOVAL
If [L]REPERT=""
 Call PARAM("","DIRPCE1",CHAINE) From ADOVAL
 Call PARAM("","DIRPCE2",CHAINE2) From ADOVAL
 [L]REPERT = CHAINE+CHAINE2
Endif

NBD = 0
For [ADI] Where NUMTAB=902
 If [F:ADI]CODE="RTF" & find([F:ADI]N1,0,3)    : # Type des fichiers .rtf gérés en clob
 Elsif [F:ADI]CODE="TXT" & find([F:ADI]N1,0,3) : # Type des fichiers .txt gérés en clob
 Elsif [F:ADI]CODE="PIC" & find([F:ADI]N1,0,2) : # Type des images gérées en blob
 Else
  NBD += 1
  TBD(NBD) = [F:ADI]CODE
 Endif
Next ADI
For [ADI]CODE Where NUMTAB=902 & N1=1 : # Only file
 If !find([F:ADI]CODE,TBD)
  NBD += 1
  TBD(NBD) = [F:ADI]CODE
 Endif
Next ADI

Read [ATZ]CODZONE="AOBJTXT";"NAM"
NBZ = 1
TBZ(NBZ) = [F:ATZ]CODZONE

NBV = 0
For [AVL]
 NBV += 1
 If !instr(1,[F:AVL]ROOT,"@") and !find(left$([F:AVL]ROOT,1),"\","/") & !instr(1,[F:AVL]ROOT,":")
  TBV(NBV) = filpath([F:AVL]ROOT,"","","","","")
 Else
  TBV(NBV) = [F:AVL]ROOT
 Endif
 VBV(NBV) = [F:AVL]VOLUME
 LBV(NBV) = len(TBV(NBV))
Next AVL
Sorta NBV LBV,VBV,TBV Order By LBV(indice+1) Desc

Local File =[F:ATZ]CODFIC [AA_]

For [AA_]
 OK = 1
 If [F:ATZ]CODFIC="AOBJTXT" & !find([F:AA_]TYPDOC,TBD(1..NBD))
  OK = 0
 Endif
 If OK
  For I=1 To NBZ
   DIME = evalue("dim([F:AA_]"+TBZ(I)+")")
   If DIME=1
    [L]ZONE = "[F:AA_]"+TBZ(I)
    [L]FICHIER = evalue("[F:AA_]"+TBZ(I))
    Gosub LOG_FILE
   Else
    For J=1 To DIME
     [L]ZONE = "[F:AA_]"+TBZ(I)+"("+num$(J-1)+")"
     [L]FICHIER = evalue("[F:AA_]"+TBZ(I)+"("+num$(J-1)+")")
     Gosub LOG_FILE
    Next J
   Endif
  Next I
 Endif
Next AA_

Close Local File

End

#-------------------#
$LOG_FILE
If [L]FICHIER=""
 Return
Elsif find(left$([L]FICHIER,1),"[")
 K = instr(1,[L]FICHIER,"]")
 If K & find(seg$([L]FICHIER,2,K-1),VBV)
  [L]MESSAGE = mess(338,139,1) : # Nom de fichiers avec [volume]
  [L]VOLUME = mess(346,139,1) : # Validés
 Else
  [L]MESSAGE = mess(339,139,1) : # Nom de fichiers avec volumes inexistant
  [L]VOLUME  = mess(342,139,1) : # Anomalie
 Endif
 Gosub LOG_INC
 Return
Elsif find(left$([L]FICHIER,1),"'",'"','=')
 # Nom de fichier commençant par $1$
 [L]MESSAGE = func AFNC.MES1(mess(336,139,1),"',=,"+'"')
 [L]VOLUME  = mess(342,139,1) : # Anomalie
 Gosub LOG_INC
 Return
Elsif find(left$([L]FICHIER,2),'#@')
 # Fichiers sur poste client
 [L]MESSAGE = mess(354,139,1)
 [L]VOLUME  = mess(341,139,1) : # Volume inexistant
 Gosub LOG_INC
 Return
Elsif find(left$([L]FICHIER,1),'#')
 [L]MESSAGE = func AFNC.MES1(mess(336,139,1),'#')
 [L]VOLUME  = mess(342,139,1) : # Anomalie
 Gosub LOG_INC
 Return
Endif
If left$([L]FICHIER,1)="%" & [L]REPERT<>""
 If instr(1,[L]REPERT,"\")
  SEP = "\"
 Else
  SEP = "/"
 Endif
 K = find(right$([L]REPERT,len([L]REPERT)),'/','\')
 L = find(left$([L]FICHIER,1),'/','\')
 If K and L
  [L]FICHIER = [L]REPERT + right$([L]FICHIER,2)
 Elsif !K and !L
  [L]FICHIER = [L]REPERT + SEP + right$([L]FICHIER,2)
 Else
  [L]FICHIER = [L]REPERT + right$([L]FICHIER,2)
 Endif
Endif
If left$([L]FICHIER,1)='%'
 [L]MESSAGE = func AFNC.MES1(mess(336,139,1),'%')
 [L]VOLUME  = mess(342,139,1) : # Anomalie
 Gosub LOG_INC
 Return
Endif
TR = 0
For V=1 To NBV
 If left$([L]FICHIER,LBV(V))=TBV(V)
  TR = V : Break
 Endif
Next V
If TR
 [L]MESSAGE = TBV(TR)
 [L]VOLUME  = func AFNC.MES1(mess(343,139,1),VBV(TR)) : # Volume $1$ à valider
 Gosub LOG_INC
Else
 L = 0
 K = instr(1,[L]FICHIER,"\")
 If K
  SEP = "\"
 Else
  K = instr(1,[L]FICHIER,"/")
  SEP = "/"
 Endif
 While K
  L = K
  K = instr(L+1,[L]FICHIER,SEP)
 Wend
 If L
  [L]MESSAGE = left$([L]FICHIER,L-1)
  [L]VOLUME  = mess(341,139,1) : # Volume inexistant
  Gosub LOG_INC
 Else
  [L]MESSAGE = mess(337,139,1) : # Fichiers sans répertoire
  [L]VOLUME  = mess(342,139,1) : # Anomalie
  Gosub LOG_INC
 Endif
Endif
Return

#---------------------------#
$LOG_INC
If [L]MESSAGE=[L]REP & [L]VOLUME=[L]VOL
 If !TOPLST
  Case [F:ATZ]CODFIC
   When "AOBJTXT"
    TOPLST = 1
    Call ECR_TRACE("Object - Key - File",0) From GESECRAN
    Call ECR_TRACE(string$(50,"-"),0) From GESECRAN
  Endcase
 Endif
 Case [F:ATZ]CODFIC
  When "AOBJTXT" : CHAINE = [F:AA_]ABREV+"("+func AFNC.INTABR([F:AA_]ABREV)+") - "+[F:AA_]IDENT1-[F:AA_]IDENT2
  When Default   : CHAINE = ""
 Endcase
 Call ECR_TRACE(CHAINE+' - |'+[L]FICHIER,0) From GESECRAN
Endif
Return

#------------------------------------------------------------------#
Subprog CHECK_FILE(NBR,REP,VOL,QTE,NBV,VBV,TBV)
Variable Shortint NBR
Variable Char     REP()(1..) , VOL()(1..)
Variable Decimal  QTE(1..)
Variable Shortint NBV
Variable Char     VBV()(1..) , TBV()(1..)
Local Integer  I , J , K , L , OK , NBZ , DIME , OKU
Local Char     TBZ(GLONAVA)(1..10) , FICHIER(255) , ZONE(50)
Local Shortint LBV(1..)
Local Char     REPERT(255) , CHAINE(255) , CHAINE2(255) , SEP(1)
Local Char     MESSAGE(255) , VOLUME(GLONAVL)
Call PARAM("","DIRPCE",[L]REPERT) From ADOVAL
If [L]REPERT=""
 Call PARAM("","DIRPCE1",CHAINE) From ADOVAL
 Call PARAM("","DIRPCE2",CHAINE2) From ADOVAL
 [L]REPERT = CHAINE+CHAINE2
Endif
Local File ATABZON [ATZ]
NBV = 0
For [AVL]
 NBV += 1
 If !instr(1,[F:AVL]ROOT,"@") and !find(left$([F:AVL]ROOT,1),"\","/") & !instr(1,[F:AVL]ROOT,":")
  TBV(NBV) = filpath([F:AVL]ROOT,"","","","","")
 Else
  TBV(NBV) = [F:AVL]ROOT
 Endif
 VBV(NBV) = [F:AVL]VOLUME
 LBV(NBV) = len(TBV(NBV))
Next AVL
Sorta NBV LBV,VBV,TBV Order By LBV(indice+1) Desc
Gosub ATTACHEMENTS
#Gosub OTHERS
Close Local File
End

#--------------------------------------------#
$ATTACHEMENTS
Local Char    TBD(GLONADI)(1..)
Local Integer NBD
Local File ATABDIV [ADI]

NBD = 0
For [ADI] Where NUMTAB=902
 If [F:ADI]CODE="RTF" & find([F:ADI]N1,0,3)    : # Type des fichiers .rtf gérés en clob
 Elsif [F:ADI]CODE="TXT" & find([F:ADI]N1,0,3) : # Type des fichiers .txt gérés en clob
 Elsif [F:ADI]CODE="PIC" & find([F:ADI]N1,0,2) : # Type des images gérées en blob
 Else
  NBD += 1
  TBD(NBD) = [F:ADI]CODE
 Endif
Next ADI
For [ADI]CODE Where NUMTAB=902 & N1=1 : # Only file
 If !find([F:ADI]CODE,TBD)
  NBD += 1
  TBD(NBD) = [F:ADI]CODE
 Endif
Next ADI

Read [ATZ]CODZONE="AOBJTXT";"NAM"
NBZ = 1
TBZ(NBZ) = [F:ATZ]CODZONE
Local File =[F:ATZ]CODFIC [AA_]
Gosub VERFTAB
Close Local File [AA_]
Return

#--------------------------------------#
$OTHERS
For [ATZ]CODTYP(2) Where CODTYP="FIC"
 NBZ = 0
 For [ATZ]CODTYP
  NBZ += 1
  TBZ(NBZ) = [F:ATZ]CODZONE
 Next ATZ
 Local File =[F:ATZ]CODFIC [AA_]
 Gosub VERFTAB
 Close Local File [AA_]
Next ATZ(2)
Return

#----------------#
$VERFTAB
For [AA_]
 OK = 1
 If [F:ATZ]CODFIC="AOBJTXT" & !find([F:AA_]TYPDOC,TBD(1..NBD))
  OK = 0
 Endif
 If OK
  For I=1 To NBZ
   DIME = evalue("dim([F:AA_]"+TBZ(I)+")")
   If DIME=1
    [L]ZONE = "[F:AA_]"+TBZ(I)
    [L]FICHIER = evalue("[F:AA_]"+TBZ(I))
    Gosub VERFFIC
   Else
    For J=1 To DIME
     [L]ZONE = "[F:AA_]"+TBZ(I)+"("+num$(J-1)+")"
     [L]FICHIER = evalue("[F:AA_]"+TBZ(I)+"("+num$(J-1)+")")
     Gosub VERFFIC
    Next J
   Endif
  Next I
 Endif
Next AA_
Return

#-------------------#
$VERFFIC
If [L]FICHIER=""
 Return
Elsif find(left$([L]FICHIER,1),"[")
 K = instr(1,[L]FICHIER,"]")
 If K & find(seg$([L]FICHIER,2,K-1),VBV)
  [L]MESSAGE = mess(338,139,1) : # Nom de fichiers avec [volume]
  [L]VOLUME = mess(346,139,1) : # Validés
 Else
  [L]MESSAGE = mess(339,139,1) : # Nom de fichiers avec volumes inexistant
  [L]VOLUME  = mess(342,139,1) : # Anomalie
 Endif
 Gosub INCREMENT
 Return
Elsif find(left$([L]FICHIER,1),"'",'"','=')
 # Nom de fichier commençant par $1$
 [L]MESSAGE = func AFNC.MES1(mess(336,139,1),"',=,"+'"')
 [L]VOLUME  = mess(342,139,1) : # Anomalie
 Gosub INCREMENT
 Return
Elsif find(left$([L]FICHIER,2),'#@')
 # Fichiers sur poste client
 [L]MESSAGE = mess(354,139,1)
 [L]VOLUME  = mess(341,139,1) : # Volume inexistant
 Gosub INCREMENT
 Return
Elsif find(left$([L]FICHIER,1),'#')
 [L]MESSAGE = func AFNC.MES1(mess(336,139,1),'#')
 [L]VOLUME  = mess(342,139,1) : # Anomalie
 Gosub INCREMENT
 Return
Endif
If left$([L]FICHIER,1)="%" & [L]REPERT<>""
 If instr(1,[L]REPERT,"\")
  SEP = "\"
 Else
  SEP = "/"
 Endif
 K = find(right$([L]REPERT,len([L]REPERT)),'/','\')
 L = find(left$([L]FICHIER,1),'/','\')
 If K and L
  [L]FICHIER = [L]REPERT + right$([L]FICHIER,2)
 Elsif !K and !L
  [L]FICHIER = [L]REPERT + SEP + right$([L]FICHIER,2)
 Else
  [L]FICHIER = [L]REPERT + right$([L]FICHIER,2)
 Endif
Endif
If left$([L]FICHIER,1)='%'
 [L]MESSAGE = func AFNC.MES1(mess(336,139,1),'%')
 [L]VOLUME  = mess(342,139,1) : # Anomalie
 Gosub INCREMENT
 Return
Endif
TR = 0
For V=1 To NBV
 If left$([L]FICHIER,LBV(V))=TBV(V)
  TR = V : Break
 Endif
Next V
If TR
 [L]MESSAGE = TBV(TR)
 [L]VOLUME  = func AFNC.MES1(mess(343,139,1),VBV(TR)) : # Volume $1$ à valider
 Gosub INCREMENT
Else
 L = 0
 K = instr(1,[L]FICHIER,"\")
 If K
  SEP = "\"
 Else
  K = instr(1,[L]FICHIER,"/")
  SEP = "/"
 Endif
 While K
  L = K
  K = instr(L+1,[L]FICHIER,SEP)
 Wend
 If L
  [L]MESSAGE = left$([L]FICHIER,L-1)
  [L]VOLUME  = mess(341,139,1) : # Volume inexistant
  Gosub INCREMENT
 Else
  [L]MESSAGE = mess(337,139,1) : # Fichiers sans répertoire
  [L]VOLUME  = mess(342,139,1) : # Anomalie
  Gosub INCREMENT
 Endif
Endif
Return

#------------------#
$INCREMENT
K = find([L]MESSAGE,[L]REP(1..[L]NBR))
If K
 [L]QTE(K) += 1
Elsif [L]NBR<dim([L]REP)
 [L]NBR += 1
 [L]REP([L]NBR) = [L]MESSAGE
 [L]VOL([L]NBR) = [L]VOLUME
 [L]QTE([L]NBR) += 1
Endif
Return

#--------------------------------------------------------------------#
Subprog IB_NBRREP
GBOUT2 = mess(31,124,1) : # Détail
End

Subprog B2_NBRREP
Local Integer NOL
NOL = nolign-1
If NOL<0 : End : Endif
# Répertoire/Volume
Call OUVRE_TRACE(mess(31,124,1)-[M]REPERT(NOL)-mess(340,139,1)+'="'+[M]VOLUME(NOL)+'"') From LECFIC
Call TRACE_FILE([M]REPERT(NOL),[M]VOLUME(NOL))
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog C_NBRVOL
Local Integer NOL
NOL = nolign-1
If NOL>=0 & find(status,68,65,83) : # Couper/Suppressions
 Look [AVL]CODE=[M]CODVOL(NOL)
 If !fstat
  mkstat = 1 : End
 Endif
Endif
End

Subprog AS_REAVOL(VALEUR)
Variable Integer VALEUR
Local Integer NOL
NOL = nolign-1
If NOL>=0 & [M]CREVOL(NOL)=2
 VALEUR = 1
 mkstat = 2 : End
Endif
End

Subprog C_CODVOL(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
NOL = nolign-1
If VALEUR=""
 Call ERREUR(mess(10,123,1)) From GESECRAN : # Zone obligatoire
 mkstat = 2 : End
Endif
If NOL>=0
 If [M]CREVOL(NOL)=2
  Look [AVL]CODE=VALEUR
  If !fstat
   # Fiche déjà existante
   Call ERREUR(VALEUR-":"-mess(22,100,1)) From GESECRAN
   mkstat = 2 : End
  Endif
 Elsif [M]REAVOL(NOL)=2
  Look [AVL]CODE=VALEUR
  If fstat
   # Volume inexistant
   Call ERREUR(VALEUR-":"-mess(341,139,1)) From GESECRAN
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog AS_PATVOL(VALEUR)
Variable Char    VALEUR()
NOL = nolign-1
If NOL>=0
 If [M]REAVOL(NOL)=2
  mkstat = 2 : End
 Elsif [M]CREVOL(NOL)<>2 & [M]REAVOL(NOL)<>2
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_PATVOL(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]PATVOL) From OBJDIV
End

Subprog AS_CODVOL(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
NOL = nolign-1
If NOL>=0 & [M]CREVOL(NOL)<>2 & [M]REAVOL(NOL)<>2
 mkstat = 1 : End
Endif
End
