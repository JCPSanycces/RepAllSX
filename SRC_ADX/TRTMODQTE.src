#<AdxTL>@(#)11.0.0.0 $Revision$
########################################################################
# Traitement TRTMODQTE - Modification de la quantité livrée            #
#                                                                      #
########################################################################
# Action SAIMODQTE
#    Paramètres     - LABR    Abréviation masque : "SDH1" par exemple
#                   - LNOL    No ligne écran (nolign-1)
#
########################################################################
# Issue 77481 - 20180307 by LD : Deletion of the last line of an inter-company validated delivery with a not managed stock product.

$ACTION

# Traitement de modification des sorties
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "DEBUT"     : Gosub DEBUT
 When "SETBOUT"   : Gosub SETBOUT
 When "ENR"       : Gosub ENR
 When "ABA"       : Gosub ABA
 When "FINSAI"    : Gosub FINSAI
 When Default
Endcase

Return

#########################################################################
$OUVRE

Local Char    LABR            : # Abréviation masque origine
Local Integer LNOL            : # No ligne courante (nolign-1) masque origine
Local Integer WGENR           : # 1 si on a enregistré , 0 sinon

# Récupération des paramètres
LABR = PARAM(1)
LNOL = val(PARAM(2))
Raz WGENR

 # Ouverture fenêtre de modifications des quantités --> on ressort #Fq74160-Gbn
 If GOUVQTE<>1
  FIN=1
  Return
 Endif

#--- Bug 51844
If LABR="SDH1" & [M:SDH1]STOMGTCOD(LNOL)>1
   Call ERREUR([M:SDH1]ITMREF(LNOL)-mess(189,177,1)) From GESECRAN
   Call AS_NBLIG From W1SDH1
   FIN=1 : Return
Endif
#---

Return

#########################################################################
$DEBUT

Raz [M:SQT]

If LABR="SDH1"
   [M:SQT]VCRTYP    = 4
   [M:SQT]VCRNUM    = [M:SDH0]SDHNUM
   [M:SQT]STOFCY    = [M:SDH0]STOFCY
   [M:SQT]ITMREF    = [M:SDH1]ITMREF(LNOL)
   [M:SQT]VCRLIN    = [M:SDH1]SDDLIN(LNOL)
   [M:SQT]PCU       = [M:SDH1]SAU(LNOL)
   [M:SQT]STU       = [M:SDH1]STU(LNOL)
   [M:SQT]PCUSTUCOE = [M:SDH1]SAUSTUCOE(LNOL)
   [M:SQT]SORQTY    = [M:SDH1]QTYSTU(LNOL)
Endif
[M:SQT]COEFUCUS = " ="+format$("N:5.4",[M:SQT]PCUSTUCOE)-[M:SQT]STU
[M:SQT]PECQTY   = [M:SQT]SORQTY

Return

#########################################################################
$SETBOUT

If !find("A",CHBOU) CHBOU+="A" Endif
If !find("E",CHBOU) CHBOU+="E" Endif

Return

#########################################################################
$ENR
If !clalev([M:SOM]) Local Mask STOSORM [SOM] Endif

# On a enregistré
WGENR = 1
[M:SOM]NBLIG     = 0
[M:SOM]SORQTY    = [M:SQT]SORQTY
[M:SOM]SORQTYACT = [M:SQT]SORQTY
[M:SOM]PECQTY    = [M:SQT]PECQTY
[M:SOM]PECQTYACT = [M:SQT]PECQTY
[M:SOM]SHTQTY    = 0

# Transaction de mise à jour
Call DEBTRANS From GLOCK
Trbegin [SDH]

If LABR="SDH1"
   Gosub APRES_STOSOM From SUBSDHA1
   If [M:SDH1]BETFCY = 2  & [M:SDH1]STOMGTCOD(nolign-1) = 1                                 # hcb 86563
      Local Integer WRET                                                                    # hcb 86563
      # Issue 77481
      #Call STKMAJITV([F:SDH]PRHFCY,[M:SDH1]ITMREF(LNOL),2,DELTAQTYSTU,1,WRET) From STKLIB   # hcb 86563
      Call STKMAJITV([F:SDH]PRHFCY,[M:SQT]ITMREF,2,DELTAQTYSTU,1,WRET) From STKLIB   # hcb 86563
      # End issue 77481
      If WRET : GOK = 0 : Endif                                                             # hcb 86563
  Endif                                                                                     # hcb 86563
Endif

If GOK=0
   GERR=1 : Goto AB_TRT
Endif

Commit
# Pour sortir
FIN = 1

Return

#########################################################################
$ABA
[M:SQT]PECQTY   = [M:SQT]SORQTY
Affzo [M:SQT]PECQTY

Return

#########################################################################
$FINSAI

# Si on a pas enregistré
If WGENR<>1 : Return : Endif

Default Mask "["+LABR+"]"
# Affichage de l'écran contenant les lignes de document
Affzo [M]1-99

# Bug 63221
If [F:SDH]LINNBR = 0
   Affzo [M:SDH0]1-99 : Affzo [M:SDH2]1-99 : Affzo [M:SDH3]1-99
Endif

#If WGENR=1 mkstat=4 Endif

Return

#########################################################################
$AB_TRT

Rollback

Return

#########################################################################
# Action sur champs
#########################################################################

Subprog C_PECQTY(VALEUR)
Variable Decimal VALEUR
Local    Integer OK

If VALEUR=0
   OK=2
   Call OUINON(mess(102,184,1),OK) From GESECRAN
   If OK<>2 mkstat=2 Endif
Endif

End

#########################################################################

