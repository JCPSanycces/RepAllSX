## Définition des triggers d'audit pour SData
##  Issu du modele ATRIGGER
##
##  SData - Version 0005_S
#
#  Subprog SD_TRIGGER(APPLI,TABLE)        # Definition du trigger SData
#
#######################################################################

### Lct interne
#CHECK IGNORE_BEGIN

Goto TEST_SETTRIG
#Goto TEST_SQLREAD
#Goto TEST_SQLMAJ
#Goto TEST1

$TEST1
Local File ZJJ1 [ZZ]
Trbegin [ZZ]
For WI=1 To 5  #50
  Case "D"
    When "C"
      [ZZ]CODE="YY"+num$(WI)
      [ZZ]A1="A1"+num$(WI)
      [ZZ]A2="A2"+num$(WI)
      [ZZ]TIMSTP="TIMSTP"+num$(WI)
      [ZZ]CREDATTIM=timestamp$
      Write [ZZ]
    When "U"
      Readlock [ZZ]ZJ10="YY"+num$(WI)
      [ZZ]TIMSTP+="-RW"
      [ZZ]UPDDATTIM=timestamp$
      Rewrite [ZZ]
    When "D"
      Delete [ZZ]ZJ10="YY"+num$(WI)
  Endcase
Next
Commit
End


$TEST2
Local File ZJJ1 [ZZ]
Local Integer WI
WI=1
Trbegin [ZZ]
      [ZZ]CODE="XX"+num$(WI)
      [ZZ]A1="A1"+num$(WI)
      [ZZ]A2="A2"+num$(WI)
      [ZZ]TIMSTP="TIMSTP"+num$(WI)
      [ZZ]CREDATTIM=timestamp$
      Write [ZZ]

      Readlock [ZZ]ZJ10="XX"+num$(WI)
      [ZZ]TIMSTP+="-RW"
      [ZZ]UPDDATTIM=timestamp$
      Rewrite [ZZ]

      Delete [ZZ]ZJ10="XX"+num$(WI)

      [ZZ]CODE="XX"+num$(WI)
      [ZZ]A1="A1"+num$(WI)
      [ZZ]A2="A2"+num$(WI)
      [ZZ]TIMSTP="TIMSTP"+num$(WI)+"CR"
      [ZZ]CREDATTIM=timestamp$
      Write [ZZ]

      Delete [ZZ]ZJ10="XX"+num$(WI)
#Sleep 1
      [ZZ]CODE="XX"+num$(WI)
      [ZZ]A1="A1"+num$(WI)
      [ZZ]A2="A2"+num$(WI)
      [ZZ]TIMSTP="TIMSTP"+num$(WI)+"CR"
      [ZZ]CREDATTIM=timestamp$
      Write [ZZ]

Commit

End

$TEST_SETTRIG
Call OUVRE_TRACE("TEST_SETTRIG") From LECFIC
#Trbegin ADOVAL
Call SD_TRIGGER(nomap, "ZJJ1")
#Commit
Call ECR_TRACE("test",0) From GESECRAN

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End


$TEST_SQLMAJ
Local Char DOSSIER : DOSSIER=nomap
Local Integer STAT
#Dbgaff
Call OUVRE_TRACE("TEST_SQLMAJ") From LECFIC
Call SET_ROWID(DOSSIER,STAT) From ASDUTITR2
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

$TEST_SQLREAD
Local Char DOSSIER : DOSSIER=nomap
Local Char TABLE : TABLE ="AJSAUDIT"
Local Decimal MAXROW

Call GET_ROWID(DOSSIER,TABLE,MAXROW) From ASDUTITR2
Call MESSAGE (num$(MAXROW)) From GESECRAN
End

#CHECK IGNORE_END


####  Rq sur scrit SQL de ASDAUDIT ###
# Afin de contenir plus qu'un entier (int), il faudrait que ROWID soit basculé en numeric ou bigint
#  Script issu de MS SQL Server Management Studio
# USE [rtx3p_v7_sql]
# GO
# /****** Objet :  Table [X3].[AJSAUDIT]    Date de génération du script : 04/16/2010 11:25:57 ******/
# SET ANSI_NULLS ON
# GO
# SET QUOTED_IDENTIFIER ON
# GO
# CREATE TABLE [X3].[AJSAUDIT](
# [SEQ_0] [numeric](13, 1) NOT NULL,
# [TBL_0] [nvarchar](10) NOT NULL,
# [DAT_0] [datetime] NOT NULL,
# [HOU_0] [nvarchar](8) NOT NULL,
# [EVT_0] [nvarchar](10) NOT NULL,
# [ID_0] [nvarchar](150) NOT NULL,
# [TIMSTP_0] [nvarchar](20) NOT NULL,
# [ROWID] [bigint] IDENTITY(1,1) NOT NULL,   <--
#  CONSTRAINT [AJSAUDIT_ROWID] PRIMARY KEY NONCLUSTERED
# (
# [ROWID] ASC
# )WITH (PAD_INDEX  = OFF, STATISTICS_NORECOMPUTE  = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS  = ON, ALLOW_PAGE_LOCKS  = ON) ON [PRIMARY]
# ) ON [PRIMARY]
#
##############################################################################


Subprog SD_TRIGGER(APPLI,TABLE)
Value Char APPLI                            # De la forme SUPERV ou sodaix01:5000@SUPERV
Value Char TABLE                            # Code table

Local Char OPT
Local Integer  NBCLE , BASE
Local Char     CLENAM(GLONAVA)(1..16)
Local Integer  CLETYP(1..16)
Local Integer  OKTRIG
Local Char     CHAINE(250)
Local Integer  I1 , I2, HASTIMSTP

If clalev([F:ADS])=0 : Local File ADOSSIER           [ADS] : Endif
If clalev([F:ATB])=0 : Local File =APPLI+".ATABLE"   [ATB] : Endif
If clalev([F:ATZ])=0 : Local File =APPLI+".ATABZON"  [ATZ] : Endif
If clalev([F:ATI])=0 : Local File =APPLI+".ATABIND"  [ATI] : Endif
If clalev([F:ATY])=0 : Local File =APPLI+".ATYPE"    [ATY] : Endif
If clalev([F:ACV])=0 : Local File =APPLI+".ACTIV"    [ACV] : Endif

Read [ADS]DOSSIER = APPLI
BASE = [F:ADS]TYPDBA
Read [ATB]CODFIC = TABLE
If dim([F:ATB]AUDSDA)<=0
 OKTRIG = 0
Else
 OKTRIG = ([F:ATB]AUDSDA=2)
Endif

#OKTRIG=1

If dim([F:ATB]ASDCLE)>0 & [F:ATB]ASDCLE<>""   # Zone à définir dans table et écran AUDWRK
 Read [ATI]CODIND = TABLE;[F:ATB]ASDCLE
#Elsif 1=1   # test sur table ZJJ1
# Read [ATI]CODIND = TABLE;"ZJ11"
Else
 Read [ATI]NUMLIG(2) = TABLE;1
Endif
CHAINE = [F:ATI]DESCRIPT
NBCLE = 0
While CHAINE<>""
 NBCLE += 1
 I1 = instr(1,CHAINE,"+")
 I2 = instr(1,CHAINE,"-")
 If    I1 & I2  : I1 = min(I1,I2)
 Elsif I2 & !I1 : I1 = I2
 Endif
 If I1
  CLENAM(NBCLE) = left$(CHAINE,I1-1)
  CHAINE        = right$(CHAINE,I1+1)
 Else
  CLENAM(NBCLE) = CHAINE
  CHAINE        = ""
 Endif
 Read [ATZ]CODZONE = TABLE;CLENAM(NBCLE)
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 CLETYP(NBCLE) = [F:ATY]TYPTYP
Wend

#
HASTIMSTP=0
Read [ATZ]CODZONE = TABLE;"CREDATTIM"
If fstat=0
  Read [ATY]CODTYP = [F:ATZ]CODTYP
 If fstat=0 : # and [F:ATY]TYPTYP=7
    HASTIMSTP=1
  Endif
Endif
OPT="C"
Call SD_VALTRIG(OKTRIG,BASE,APPLI,TABLE,OPT
&            ,NBCLE,CLENAM,CLETYP, HASTIMSTP)
#
HASTIMSTP=0
Read [ATZ]CODZONE = TABLE;"UPDDATTIM"
If fstat=0
  Read [ATY]CODTYP = [F:ATZ]CODTYP
 If fstat=0 : # and [F:ATY]TYPTYP=7
    HASTIMSTP=1
  Endif
Endif
OPT="U"
Call SD_VALTRIG(OKTRIG,BASE,APPLI,TABLE,OPT
&            ,NBCLE,CLENAM,CLETYP, HASTIMSTP)
#
OPT="D"
Call SD_VALTRIG(OKTRIG,BASE,APPLI,TABLE,OPT
&            ,NBCLE,CLENAM,CLETYP, 0)
End

##############################################################################
Subprog SD_VALTRIG(CAS,BASE,APPLI,TABLE,OPT
&              ,NBCLE,CLENAM,CLETYP, HASTIMSTP)
Value Integer CAS
Value Integer BASE
Value Char    APPLI             # De la forme SUPERV ou sodaix01:5000@SUPERV
Value Char    TABLE
Value Char    OPT               # I, U, D
Value Integer NBCLE
Value Char    CLENAM()(1..)
Value Integer CLETYP(1..)
Value Integer HASTIMSTP         # La table auditée à une rubrique CREDATTIM ou UPDDATTIM

Local Integer NBRQT , EFFACE
Local Char    RQT(250)(1..2000)

Call SD_DEFTRIG(0,BASE,APPLI,TABLE,OPT
&             ,NBCLE,CLENAM,CLETYP,HASTIMSTP,NBRQT,RQT)            # Drop
EFFACE = 1
Gosub EXEC

If CAS=1
 If func AFNC.ACTIVDOS(APPLI, "ASD")                                # Code activite SData
     Call SD_DEFTRIG(1,BASE,APPLI,TABLE,OPT
&             ,NBCLE,CLENAM,CLETYP,HASTIMSTP,NBRQT,RQT)
     If NBRQT=0
      Call ECR_TRACE(mess(89,127,1),1) From GESECRAN : # Erreur en création des triggers : trop de champs
      End
     Endif
     EFFACE = 0
     Gosub EXEC
 Endif
Endif
End

$EXEC
If 1=2 and GUSER="JPJ"
 Call ECR_TRACE(" # # TRACE # # # # # #" ,0) From GESECRAN
 For I=1 To NBRQT
  Call ECR_TRACE(RQT(I),0) From GESECRAN
 Next I
Endif

Onerrgo ERREUR
Case BASE
 When 1 : Execsql From "3" Sql RQT(1..NBRQT)
 When 2 : Execsql From "5" Sql RQT(1..NBRQT)
Endcase
Onerrgo
Return

$ERREUR
If !EFFACE
 Call ECR_TRACE(mess(6,123,1)-num$(errn)-errmes$(errn)-errm,1) From GESECRAN : # Erreur
Endif
Resume

##############################################################################
Subprog SD_DEFTRIG(CAS,BASE,APPLI,TABLE,OPT
&              ,NBCLE,CLENAM,CLETYP,HASTIMSTP,NBRQT,RQT)
Value    Integer CAS
Value    Integer BASE
Value    Char    APPLI
Value    Char    TABLE
Value    Char    OPT
Value    Integer NBCLE
Value    Char    CLENAM()(1..)
Value    Integer CLETYP(1..)
Variable Integer NBRQT
Value    Integer HASTIMSTP
Variable Char    RQT()(1..)

Local Integer I , J , K , I1 , I2 , J1 , J2 , ER
Local Integer II , JJ , KK , IC
Local Integer NLIG , NTRI , NREMP , OKLIG , NCRI , NCOL
Local Integer PSPE
Local Char    TEXTE(250)(1..300)
Local Char    CRLF(2)
Local Char    LIGNE(250) , CHAMP(250) , CHAINE(250)
Local Char    REMPLACE(250)(1..10)
Local Char    CRITERE(250)(1..10)
Local Char    CND(30) , ACTION(20)

CRLF = " "+chr$(10)

Raz RQT
NBRQT = 0

If CAS=1
 Call CRETRI(BASE,OPT,NLIG,TEXTE)
Else
 Call SUPTRI(BASE,NLIG,TEXTE)
Endif

K = 1
I = 1
While I<=NLIG
  LIGNE = TEXTE(I)
  II = 1 : JJ = 1 : KK = 1
  Gosub TRT_LIGNE : If ER : Break : Endif
  I += 1
Wend
If ER
 NBRQT = 0
Else
 NBRQT = K-1
Endif
End

$TRT_LIGNE
OKLIG = 1
If OKLIG
 While LIGNE<>""
  I1 = instr(1,LIGNE,"#<")
  I2 = instr(1,LIGNE,">#")
  If I1 & I2 & I2>I1
   CHAMP = left$(LIGNE,I1-1)
   Gosub STOCKE
   CHAMP = seg$(LIGNE,I1+2,I2-1)
   Gosub REMPLACE
   For J1=1 To NREMP
    CHAMP = REMPLACE(J1)
    Gosub STOCKE
   Next J1
   LIGNE = right$(LIGNE,I2+2)
  Else
   CHAMP = LIGNE
   Gosub STOCKE : If ER : Break : Endif
   LIGNE = ""
  Endif
 Wend
 CHAMP = CRLF
 Gosub STOCKE
 If ER
  Return
 Elsif K>=dim(RQT)
  ER = 1
 Else
  K += 1
 Endif
Endif
Return

$STOCKE
If len(RQT(K))+len(CHAMP)<=250
 RQT(K) += CHAMP
Elsif K<dim(RQT)
 K += 1
 RQT(K) = CHAMP
Else
 ER = 1
Endif
Return

$REMPLACE
NREMP = 1
Case toupper(CHAMP)
 When "DOSSIER"
  REMPLACE(1) = APPLI
 When "TABLE"
  REMPLACE(1) = TABLE
 When "NOMTRIG"
  Case OPT
   When "C" : REMPLACE(1) = "SDINS"
   When "U" : REMPLACE(1) = "SDUPD"
   When "D" : REMPLACE(1) = "SDDEL"
  Endcase
 When "ACTION"
  Case OPT
   When "C" : REMPLACE(1) = "INSERT"
   When "U" : REMPLACE(1) = "UPDATE"
   When "D" : REMPLACE(1) = "DELETE"
  Endcase
 When "TABAUDITH"
  REMPLACE(1) = "AJSAUDIT"
 When "OLDCLE1","NEWCLE1"
  If toupper(CHAMP)="OLDCLE1"
   J2 = 1
  Else
   J2 = 2
  Endif
  REMPLACE(1) = ""
#  If NBCLE>=2
   For J1=1 To NBCLE
    If J1>1
     Call OPER(BASE,12,CHAINE)
     REMPLACE(1) += CHAINE
     Call CONSTANTE(BASE,7,"~",CHAINE)
     REMPLACE(1) += CHAINE
     Call OPER(BASE,12,CHAINE)
     REMPLACE(1) += CHAINE
    Endif
    Call NOMCHAMP(BASE,J2,CLENAM(J1),1,1,CHAINE)
    Call TOCHAR(BASE,CLETYP(J1),CHAINE,CHAINE)
    REMPLACE(1) += CHAINE
   Next J1
 When "TIMSTP"
  If HASTIMSTP
    Case OPT
      When "C"
        J2=2
        Call NOMCHAMP(BASE,J2,"CREDATTIM",1,1,CHAINE)
      When "U"
        J2=2
        Call NOMCHAMP(BASE,J2,"UPDDATTIM",1,1,CHAINE)
      When "D" : J2=1
    Endcase
    Call TOCHAR(BASE,7,CHAINE,CHAINE)
    REMPLACE(1) = CHAINE
  Else
    Call CONSTANTE(BASE,7," ",CHAINE)
    REMPLACE(1) = CHAINE
  Endif
 When Default
  REMPLACE(1) = "#<"+CHAMP+">#"
Endcase
Return


Subprog CRETRI(BASE,OPT,NLIG,TEXTE)
Value    Integer BASE
Value    Char    OPT
Variable Integer NLIG
Variable Char    TEXTE()(1..)
Local Integer I , J , K , NTRI
Local Char    TRIG(250)(1..200)
NLIG = 0
Case BASE
 When 1 : Gosub CRETRI_ORA : # Oracle
 When 2 : Gosub CRETRI_SQL : # Sql
Endcase
Call DEFTRI(BASE,OPT,NTRI,TRIG) From ASDUTITR2
For I=1 To NTRI
 NLIG += 1 : TEXTE(NLIG) = TRIG(I)
Next I
End

Subprog SUPTRI(BASE,NLIG,TEXTE)
Value    Integer BASE
Variable Integer NLIG
Variable Char    TEXTE()(1..)
NLIG = 0
Case BASE
 When 1 : Gosub SUPTRI_ORA : # Oracle
 When 2 : Gosub SUPTRI_SQL : # Sql
Endcase
End

#################################################################
## Syntaxes pour créer un trigger
#################################################################
$CRETRI_ORA
NLIG += 1 : TEXTE(NLIG) = "Create or Replace Trigger"
NLIG += 1 : TEXTE(NLIG) = " #<DOSSIER>#.#<TABLE>#_#<NOMTRIG>#"
NLIG += 1 : TEXTE(NLIG) = " After #<ACTION>#"
NLIG += 1 : TEXTE(NLIG) = " On #<DOSSIER>#.#<TABLE>#"
NLIG += 1 : TEXTE(NLIG) = " For Each Row"
Return

$CRETRI_SQL
NLIG += 1 : TEXTE(NLIG) = "Create Trigger "
NLIG += 1 : TEXTE(NLIG) = " #<DOSSIER>#.#<TABLE>#_#<NOMTRIG>#"
NLIG += 1 : TEXTE(NLIG) = " On #<DOSSIER>#.#<TABLE>#"
NLIG += 1 : TEXTE(NLIG) = " After #<ACTION>#"
NLIG += 1 : TEXTE(NLIG) = " As"
Return

#################################################################
## Syntaxes pour supprimer un trigger
#################################################################
$SUPTRI_ORA
NLIG += 1 : TEXTE(NLIG) = "Drop Trigger #<DOSSIER>#.#<TABLE>#_#<NOMTRIG>#"
Return

$SUPTRI_SQL
NLIG += 1 : TEXTE(NLIG) = "Drop Trigger #<DOSSIER>#.#<TABLE>#_#<NOMTRIG>#"
Return

#################################################################
## Syntaxes diverses
#################################################################
Subprog NOMCHAMP(BASE,OLDNEW,CHAMP,INDIC,FLG2,CHAINE)
Value    Integer BASE
Value    Integer OLDNEW
Value    Char    CHAMP
Value    Integer INDIC
Value    Integer FLG2
Variable Char    CHAINE()
Case BASE
 When 1
  If FLG2
   CHAINE = ":"
  Else
   CHAINE = ""
  Endif
  If OLDNEW=1
   CHAINE += "OLD."
  Else
   CHAINE += "NEW."
  Endif
  CHAINE += CHAMP+"_"+num$(INDIC-1)
 When 2
  CHAINE = ""
  If OLDNEW=1
   CHAINE += "Deleted."
  Else
   CHAINE += "Inserted."
  Endif
  CHAINE += CHAMP+"_"+num$(INDIC-1)
Endcase
End

Subprog OPER(BASE,OPER,CHAINE)
Value    Integer BASE
Value    Integer OPER
Variable Char    CHAINE()
Case BASE
 When 1
  Case OPER
   When  1 : CHAINE = "="
   When  2 : CHAINE = "!="
   When  3 : CHAINE = ">"
   When  4 : CHAINE = ">="
   When  5 : CHAINE = "<"
   When  6 : CHAINE = "<="
   When  7 : CHAINE = " like "
   When 11 : CHAINE = " or "
   When 12 : CHAINE = " || "
  Endcase
 When 2
  Case OPER
   When  1 : CHAINE = "="
   When  2 : CHAINE = "!="
   When  3 : CHAINE = ">"
   When  4 : CHAINE = ">="
   When  5 : CHAINE = "<"
   When  6 : CHAINE = "<="
   When  7 : CHAINE = " like "
   When 11 : CHAINE = " or "
   When 12 : CHAINE = " + "
  Endcase
Endcase
End

Subprog CONSTANTE(BASE,TYP,VALEUR,CHAINE)
Value    Integer BASE
Value    Integer TYP
Value    Char    VALEUR
Variable Char    CHAINE()
Case BASE
 When 1
  Case TYP
   When 7
    CHAINE = "'"+VALEUR+"'"
   When 8
    CHAINE = "to_date('"+VALEUR+"','YYYYMMDD')"
   When Default
    CHAINE = VALEUR
  Endcase
 When 2
  Case TYP
   When 7
    CHAINE = "'"+VALEUR+"'"
   When 8
    CHAINE = "CONVERT(DATETIME,'"+VALEUR+"')"
   When Default
    CHAINE = VALEUR
  Endcase
Endcase
End

Subprog TOCHAR(BASE,TYP,VALEUR,CHAINE)
Value    Integer BASE
Value    Integer TYP
Value    Char    VALEUR
Variable Char    CHAINE()
Case BASE
 When 1
  Case TYP
   When 7       : CHAINE = VALEUR
   When 8       : CHAINE = "to_char("+VALEUR+",'DDMMYYYY')"
   When Default : CHAINE = "to_char("+VALEUR+")"
  Endcase
 When 2
  Case TYP
   When 7       : CHAINE = VALEUR
   When 8       : CHAINE = "CONVERT(VARCHAR,"+VALEUR+",103)"
   When Default : CHAINE = "CONVERT(VARCHAR,"+VALEUR+")"
  Endcase
Endcase
End

Subprog LIKE(BASE,CHAINE)
Value    Integer BASE
Variable Char    CHAINE()
Case BASE
 When 1 : CHAINE = ctrans(CHAINE,"*?","%_")
 When 2 : CHAINE = ctrans(CHAINE,"*?","%_")
Endcase
End
