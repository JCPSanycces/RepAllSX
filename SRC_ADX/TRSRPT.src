#<AdxTL>@(#)7.0.0.0 $Revision$
####################################################
## Contrôles de saisie
####################################################
$ACTION
Case ACTION
 When "OUVRE"  : Gosub OUVRE
 When "INIPAR" : Gosub INIPAR
 When "CONT1"  : Gosub CONT1
Endcase
Return


Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Char    VALEUR(250)
Local Char    ETAT(GLONARP) , TYP_ETAT(GLONARP)
Local Char    VALEUR(30) , PARAM(50)
Local Char    SOCIETE(GLONCPY), BANCPY(GLONCPY)
Local Integer I , J , K
Local Integer NBSOC
Local Char    TBSOC(GLONCPY)(1..GNBSOC)
Local Char    PLAN(GLONCOA), LEDTYP(1)

# EMERAUDE - Feature MULTILEG- Requirement 71216
Local Integer NBRLEG
Local Char    TABLEG(GLONADI)(1..GNBSOC)

Gosub OUVRE

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT) From ETAT
K = instr(1,ETAT,".")
If K
 ETAT = left$(ETAT,K-1)
Endif

## Pour ne plus tester l'état en dur
Call GETPARAM("typetat",NBPAR,PARAMETRE,TYP_ETAT) From ETAT
If TYP_ETAT="?????" : TYP_ETAT = ETAT : Endif

## Vérif de la société
Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE) From ETAT

## Bug 51676 : init NBSOC, TBSOC
If SOCIETE<>"?????"
 If SOCIETE<>""
  Read [CPY]CPY0 = SOCIETE
  If fstat
   # Société incorrecte
   Call ECR_TRACE(mess(81,116,1),1) From GESECRAN
   GOK = 0 : End
  Endif
  If [F:CPY]CPYLEGFLG<>2
   NBSOC = 0
   For [FGR]FGR0 Where CPY=SOCIETE
    Read [FCY]FCY0 = [F:FGR]FCY
    If !find([F:FCY]LEGCPY,TBSOC(1..NBSOC))
     NBSOC += 1
     TBSOC(NBSOC) = [F:FCY]LEGCPY
    Endif
   Next
   Read [CPY]CPY0 = TBSOC(1)
  Else
   NBSOC = 1
   TBSOC(1) = SOCIETE
  Endif
 Else
  # Société non initialisée et bank non obligatoire => On ne connait pas la sté
  NBSOC = 0
  For [CPY]CPY0 Where CPYLEGFLG=2
   NBSOC += 1
   TBSOC(NBSOC) = [F:CPY]CPY
  Next
 Endif
 Call LEGCPY(TBSOC,NBRLEG,TABLEG) From CPTDIV
 GCURLEG = TABLEG(1)
Endif

# Si on demande un groupe de collectif, init du paramètre plan

Call GETPARAM("grpcol",NBPAR,PARAMETRE,VALEUR) From ETAT
If VALEUR<>"?????"
 PLAN = ""
 For ISOC=1 To NBSOC
  Read [CPY]CPY0 = TBSOC(ISOC)
  Read [GCM]GCM0 = [F:CPY]ACM
  Read [LED]LED0 = [F:GCM]LED([F:GCM]GENLEDTYP-1)
  If PLAN=""
   PLAN = [F:LED]COA
  Elsif PLAN<>[F:LED]COA
   Call ECR_TRACE(mess(57,109,1)-":"-SOCIETE,1) From GESECRAN : # Plans incompatibles
   GOK = 0 : Break
  Endif
 Next ISOC
 Call SETPARAM("plan",NBPAR,PARAMETRE,PLAN) From ETAT
Endif
If !GOK : End : Endif

## Vérif du code d'accès sur la banque

Call GETPARAM("banque",NBPAR,PARAMETRE,VALEUR) From ETAT
If VALEUR="?????"
 Call GETPARAM("bank",NBPAR,PARAMETRE,VALEUR) From ETAT
Endif
If VALEUR<>"?????" & VALEUR<>""
 If clalev([F:BAN])=0 : Local File BANK   [BAN] : Endif
 If clalev([F:ACS])=0 : Local File ACCES  [ACS] : Endif
 Call LECTURE("BAN",VALEUR,"") From CONTOBJ
 If fstat
  Call ERREUR(VALEUR-":"-mess(140,100,1)) From GESECRAN : # Banque inexistante
  GOK = 0 : End
 Elsif [F:BAN]ACS<>""
  Read [ACS]CODACC = GUSER;[F:BAN]ACS
  If fstat or [F:ACS]CONSUL<>2
   Call ERREUR(VALEUR-":"-mess(25,120,1)) From GESECRAN : # Vous n'avez pas accès à la banque
   GOK = 0 : End
  Endif
 Endif
 Call SETPARAM("bancpy",NBPAR,PARAMETRE,[F:BAN]CPY) From ETAT
 If [F:BAN]CPY<> [F:CPY]CPY : Read [CPY]CPY0 = [F:BAN]CPY : Endif
 GCURLEG = [F:CPY]LEG
 If [F:GCM]GCM<> [F:CPY]ACM : Read [GCM]GCM0 = [F:CPY]ACM : Endif
 LEDTYP = num$([F:GCM]GENLEDTYP)
 Call SETPARAM("ledtyp",NBPAR,PARAMETRE,LEDTYP) From ETAT
 If NBSOC=0
  NBSOC=1 : TBSOC(NBSOC)=[F:BAN]CPY
  Call LEGCPY(TBSOC,NBRLEG,TABLEG) From CPTDIV : GCURLEG=TABLEG(1)
 Endif
Endif


# EMERAUDE - Feature MULTILEG- Requirement 71216
#------------------------------------------------------------------
If find(TYP_ETAT,"BANQUE","ECHTIERS","PREVISION")
 Gosub TRTGTE From RPTLEG
Endif
#----------
If find(TYP_ETAT,"LETTREVIRR","LETTREVIRB","REMTRT","REMCHQ")
 K=0
 Gosub TRTTPY From RPTLEG
 Gosub TRT_TED From RPTLEG
Endif
#------------------------------------------------------------------
If find(TYP_ETAT,"REMTRT")
 Gosub TRT_TAM From RPTLEG
Endif
End

$OUVRE
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif
If clalev([F:DIE])=0 : Local File GDIE       [DIE] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif
If clalev([F:ARM])=0 : Local File AREPORTM   [ARM] : Endif
If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
If clalev([F:TPY])=0 : Local File TABPAYTYP  [TPY] : Endif
If clalev([F:CDA])=0 : Local File GACCDENCOD [CDA] : Endif
If clalev([F:TED])=0 : Local File TABCODEDT  [TED] : Endif
If clalev([F:TAM])=0 : Local File TABPAM     [TAM] : Endif
Return

$INIPAR
Local Integer K
Local Integer REFERENTIEL
Local Char    SOCIETE(GLONCPY)
Case [M]PARCOD(nolign-1)
 When "grpcol", "grpcoll" : # Groupe de collectifs
  Gosub SETSOC
  If SOCIETE<>""
   Read [GCM]GCM0 = [F:CPY]ACM
   Read [LED]LED0 = [F:GCM]LED([F:GCM]GENLEDTYP-1)
  Endif
 When "coldeb", "colldeb" : # Collectifs
  Gosub SETSOC
  If SOCIETE<>""
   Read [GCM]GCM0 = [F:CPY]ACM
   Read [LED]LED0 = [F:GCM]LED([F:GCM]GENLEDTYP-1)
   Filter [GAC] Where COA=[F:LED]COA
  Endif
 When "modreg"
  Gosub SETSOC
Endcase
Return

$CONT1
Case [M]PARCOD(nolign-1)
 When "codbud"
  If clalev([F:BUP])=0 : Local File BUDPAR    [BUP] : Endif
  Read [BUP]BUP0 = VALEUR
 When "coldeb"
  Filter [GAC]
 When "grpcol", "grpcoll"
  Gosub SETSOC
  If SOCIETE<>""
   Read [GCM]GCM0 = [F:CPY]ACM
   Read [LED]LED0 = [F:GCM]LED([F:GCM]GENLEDTYP-1)
  Endif
 When "modreg"
  [M]OBJET(nolign-1) = ""
  Gosub SETSOC
  Call CONTTAM(VALEUR,[F:CPY]LEG,"") From SUBTAM
Endcase
Return

$SETSOC
SOCIETE = ""
K = find("societe",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
If K
 SOCIETE = [M:RPT]VALINT1(K-1)
 Read [CPY]CPY0 = SOCIETE
 If [F:CPY]CPYLEGFLG<>2
  Read [FGR]FGR0(1) = SOCIETE
  Read [FCY]FCY0 = [F:FGR]FCY
  SOCIETE = [F:FCY]LEGCPY
  Read [CPY]CPY0 = SOCIETE
 Endif
Endif
Return

