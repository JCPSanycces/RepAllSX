#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTI009119  Creation period and termination period dates    #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If [F:ADS]MODULE(8)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Deletion of tax record") From LECFIC

  Call MAJ_UTI009125(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTI009125(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR
Local Char CPYNAME(200)
Local Char GCURLEG(200)

CPYNAME = func AFNC.PARAMDOS(nomap,"TAXRECCPY")
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Filter [CPY] Where CPY=CPYNAME
Read [CPY]CPY0 Last
Filter [CPY]
If !fstat
  GCURLEG=[F:CPY]LEG
Endif



If clalev([F:HRCTR])>0  : Close Local File [HRCTR]  : Endif
Local File =DOSSIER+".EMPLOCTR" [HRCTR]

If clalev([F:FCY])>0  : Close Local File [FCY]  : Endif
Local File =DOSSIER+".FACILITY" [FCY]


If clalev([F:HRCTR5])>0  : Close Local File [HRCTR5]  : Endif
Local File =DOSSIER+".EMPLOCTR" [HRCTR5]

#Call ECR_TRACE("UTI009125 : Reset of tax cycle dates on contracts : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#

Raz COMPTEUR
Call DEBTRANS From GLOCK



If func DIVPAYE.IS_KZA(GCURLEG) Then
  If clalev([F:CTRSA])>0  : Close Local File [CTRSA]  : Endif
  Local File =DOSSIER+".EMPLOCTRSA" [CTRSA]


  If clalev([F:CTRSA5])>0  : Close Local File [CTRSA5]  : Endif
  Local File =DOSSIER+".EMPLOCTRSA" [CTRSA5]


  If clalev([F:ETR])>0  : Close Local File [ETR]  : Endif
  Local File =DOSSIER+".EMPLOTAXREC" [ETR]


  Trbegin [HRCTR], [CTRSA],[ETR]
  Gosub MAJACVKZA
Endif



If func DIVPAYE.IS_AFRICA_LEG(GCURLEG) Then
  If clalev([F:CTRAFR])>0  : Close Local File [CTRAFR]  : Endif
  Local File =DOSSIER+".EMPLOCTRAFR" [CTRAFR]

  If clalev([F:CTRAFR5])>0  : Close Local File [CTRAFR5]  : Endif
  Local File =DOSSIER+".EMPLOCTRAFR" [CTRAFR5]


  If clalev([F:ETA])>0  : Close Local File [ETA]  : Endif
  Local File =DOSSIER+".EMPLOTAXAFR" [ETA]

  Trbegin [HRCTR], [CTRAFR],[ETA]
  Gosub MAJACVKAQ
Endif



If !GOK
  Raz COMPTEUR
  Rollback
Else
  Commit
Endif

Close Local File [HRCTR]

#Call ECR_TRACE("UTI009125 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End

$MAJACVKAQ


Local Integer MYFLG,THISTAXYEAR
Local Date STRDAT,ENDDAT
Local Integer VARCONTRACT


If CPYNAME <> "" Then

    Link    [HRCTR]
&     With  [FCY]FCY0 = [HRCTR]ETRFCY
&     As    [LNK9]
&   Where   [FCY]LEGCPY=CPYNAME
Else
  Call ECR_TRACE("UTI009125 : No company specified : "+DOSSIER,0) From GESECRAN
  End

Endif



For [LNK9]

Delete [F:ETA] Where CTRNUM = [HRCTR]CTRNUM & REFNUM = [HRCTR]REFNUM

Next
Call ECR_TRACE("UTI009126 :Deletion of tax records complete : "+DOSSIER,0) From GESECRAN

Return

##############################
$MAJACVKZA

Local Integer MYFLG,THISTAXYEAR
Local Date STRDAT,ENDDAT
Local Integer VARCONTRACT


If CPYNAME <> "" Then

    Link    [HRCTR]
&     With  [FCY]FCY0 = [HRCTR]ETRFCY
&     As    [LNK9]
&   Where   [FCY]LEGCPY=CPYNAME
Else
  Call ECR_TRACE("UTI009125 : No company specified : "+DOSSIER,0) From GESECRAN
  End

Endif



For [LNK9]

Delete [F:ETR] Where CTRNUM = [HRCTR]CTRNUM & REFNUM = [HRCTR]REFNUM

Next
Call ECR_TRACE("UTI009126 :Deletion of tax records complete : "+DOSSIER,0) From GESECRAN
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(8)<>2 : End : Endif

If filinfo(filpath("FIL","EMPLOCTR","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTI009125(APPLI)
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH_X3(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
# On  regarde si le module est à "Oui"
If [F:ADS]MODULE(8) <> 2 : End : Endif

If filinfo(filpath("FIL","EMPLOCTR","fde",APPLI),0)<=0 : End : Endif
#-----------------End-Dev--------------------------#
Call MAJ_UTI009125(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
#If APPLI=GDOSX3 : End : Endif
If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(8)<>2 : End : Endif                                 : # 1= Paie

If filinfo(filpath("FIL","EMPLOCTR","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTI009125(APPLI)
End

