#<AdxTL>@(#)0.0.0.0 $Revision$
Call OBJET("GCU",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE_BOITE": Gosub OUVRE_BOITE
 When "LIENS"      : Gosub LIENS
 When "VERIF_CRE"  : Gosub VERIF
 When "VERIF_MOD"  : Gosub VERIF
 When "GAUCHE"     : Gosub GAUCHE
 When "CREATION"   : Gosub CREATION 
 When "MODIF"      : Gosub MODIF 
 When "AP_CHANGE"  : Gosub AP_CHANGE
 When "ANNULE"     : Gosub ANNULE
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
Endcase
Return

$INICRE
$INIMOD
If dim([F:GCU]DES)>0
 [F:GCU]DES = [M:GCU1]DESTRA
Endif
Return

$OUVRE_BOITE
Local Integer BROWTCU
Local Char    BOXTCU(10)
BROWTCU = find("TCU",OBJLIS(1..8)) : BOXTCU = "GAU_CHE"+num$(BROWTCU)
Return

$LIENS
Call LECTEXTRA([M]DESTRA,"GRPCUR","DESTRA",[M]GRP,"") From ATEXTRA
Call LECTEXTRA([M]SHOTRA,"GRPCUR","SHOTRA",[M]GRP,"") From ATEXTRA
Return

$VERIF
If [M]NBRCUR<2
 GMESSAGE=mess(46,119,1) : # Il faut au moins 2 devises
 OK = 0
Endif
Return

$GAUCHE
Case currbox
 When BOXTCU
  If [F:TCU]CUR<>"" & !find([F:TCU]CUR,[M]CUR(0..[M]NBRCUR-1)) & [M]NBRCUR<dim([M]CUR)
   OK = 0
   Case REP
    When "C","M","D"
     OK = 1
    When ""
     If CLECUR & VERROU & ACTMOD & !GCONSULT
      OK = 1
     Endif
   Endcase
   If OK
    [M]CUR([M]NBRCUR)   = [F:TCU]CUR
    [M]NBRCUR += 1
    Affzo NBRCUR,CUR
    If REP=""
     Gosub ENTRE_MODIF From GOBJSUB
    Endif
   Endif
  Endif
Endcase
Return

$CREATION 
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GRPCUR","DESTRA",CLECUR1,"","GRPCUR","DESTRA",[M]GRP,"")  From ATEXTRA
 Call DUPTEXTRA("GRPCUR","SHOTRA",CLECUR1,"","GRPCUR","SHOTRA",[M]GRP,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESTRA,"GRPCUR","DESTRA",[M]GRP,"") From ATEXTRA
Call MAJTEXTRA([M]SHOTRA,"GRPCUR","SHOTRA",[M]GRP,"") From ATEXTRA
Return

$AP_CHANGE
Call CHGTEXTRA("GRPCUR","DESTRA",[M]GRP,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GRPCUR","SHOTRA",[M]GRP,"",NCODE,"") From ATEXTRA
Return

$ANNULE
Call SUPTEXTRA("GRPCUR","DESTRA",[M]GRP,"") From ATEXTRA
Call SUPTEXTRA("GRPCUR","SHOTRA",[M]GRP,"") From ATEXTRA
Return




###############################
## Etiquette de l'écran GCU1 ##
###############################

Subprog C_CUR(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]CUR(0..[M]NBRCUR-1)) From OBJDIV
End

