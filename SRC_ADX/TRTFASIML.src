################################################################################
################################################################################


################################################################################
Subprog AM_IASCGU(VALEUR)
Variable Char    VALEUR()

Local Char    WCCPY
Local Integer WI
Local Integer LOK
Local Char    CRITACT2(250)
Local Char    CRITACT(250), SREQUETE(250)

  #If (GUSER = "MWA" ) Then : Dbgaff : Endif

  Call ACTCHGCRIT From TRCPROCOM : # prise en compte de la modification des critÃĻres
  If ( mkstat = 2 ) Then
    End
  Else
    Disable GSTAOK
    Disable GSTABOU+1
    Effzo [M:IML1]20-30 : # initialisation en cas de changement de critÃĻre
    Call ANNULE_DEPRECIATION(G_NON)
  Endif

  If ( find(G_OUI, [M:MHC]FLGCPY)<>0 ) Then
    # Traitement cas mono sociÃĐtÃĐ
    # VÃĐrifier qu'il y a au moins un bien ÃĐligible sur l'UGT, sinon pas la peine d'aller plus loin
    SREQUETE = 'CPY=[M:MHC]CPY(find(G_OUI, [M:MHC]FLGCPY)-1)'
  Else
    # Traitement cas multi sociÃĐtÃĐ
    SREQUETE = '1=1'
  Endif

  [M:IML1]IASCGU = VALEUR : Affzo [M:IML1]IASCGU

  # Si l'UGT concerne plusieurs sociÃĐtÃĐs : Rejet avec le message : Aucune sociÃĐtÃĐ ne doit ÃŠtre saisie
  Gosub SET_CRITACT

  Filter [FAS] Where evalue(SREQUETE) &evalue(CRITACT)
  Read [FAS]FAS1 First
  Filter [FAS]
  If (!fstat) Then
    WI = find(G_OUI, [M:MHC]FLGCPY)
    If (WI <> 0) Then
      WCCPY = [FAS]CPY
      CRITACT2 = CRITACT + "&CPY <> '" + WCCPY + "'"
      Filter [FAS2] Where evalue(CRITACT2)
      Read [FAS2]FAS1 First
      Filter [FAS2]
      If (!fstat) Then
        # Aucun bien n'est dÃĐfini sur cette UGT
        GMESSAGE = mess(443,GML_MSGFAS,1) + WCCPY  + ',' + [FAS2]CPY + ')'  + '\' + mess(445,GML_MSGFAS,1)
        GERR = 1 : mkstat = 2 : End
      Endif
    Endif
  Elsif ( fstat > 2 ) Then
    If ( [M:IML1]IASCGU <> "" ) Then
      # Aucun bien sur l'UGT, on ne peut pas la choisir
      GMESSAGE = mess(135,GML_MSGFAS,1)
      GERR = 1 : mkstat = 2 : End
    Endif
  Endif

  Filter [F:FAS] Where evalue(SREQUETE) &evalue(CRITACT)
  #>>>>>>>>>>>>
  For [F:FAS]
    # Si l'UGT contient des biens dont le site n'est pas habilitÃĐ pour l'utilisateur : Rejet avec le message
    If ( find([F:FAS]FCY, [M:MHC]FCY) = 0 ) Then
      Call OUINON(mess(450,GML_MSGFAS,1) +  '\' + mess(451,GML_MSGFAS,1)  +  '\' + mess(452,GML_MSGFAS,1), LOK) From GESECRAN
      If (LOK = G_NON)
        [M:IML1]IASCGU =  ""
        Affzo [M:IML1]IASCGU
        GERR     = 1
        mkstat   = 2
      Endif
      Break
    Endif
  Next
  #<<<<<<<<<<<
  Filter [F:FAS]

  If ( [M:IML1]IASCGU <> "" ) Then
    Call ALIM_VN("",[M:IML1]IASCGU)
  Endif

End

########################################
Subprog C_IASCGU(VALEUR)
Variable Char    VALEUR()

End

########################################
Subprog AP_IASCGU(VALEUR)
Variable Char    VALEUR()

  If ( ACTTYPGES=GTAMUNI ) Then
    If ( VALEUR = "" ) Then
      Actzo [M:IML1]AASREF
    Else
      Diszo [M:IML1]AASREF
    Endif
  Else
    Diszo [M:IML1]AASREF
  Endif
End

