#-----------------------------------------------------
# Affichage d'une boite de selection des UGT
#-----------------------------------------------------
$SET_UGT

# A dÃĐporter dans SELLISFAS ou SELLISTAB ????????

  Local Integer I
  Local Char    WCLIB
  Local Char    WCNUMTAB
  Local Integer WI
  Local Char    WCSOCCOCHE

  I = 0

  WCSOCCOCHE = ""
  #>>>>>>>>>
  For WI = 0 To [M:MHC]NBCPY - 1
    If ( [M:MHC]FLGCPY (WI) = G_OUI ) Then : WCSOCCOCHE = [M:MHC]CPY (WI) :  Endif
  Next
  #<<<<<<<<<

  WCNUMTAB = '613'
  Filter[F:ADI] Where ([F:ADI]NUMTAB =  val(WCNUMTAB) )

  # FQ64191
  Local Integer NBUGT
  NBUGT = rowcount([F:ADI])
  If (NBUGT > 200 ) Then
  Local Char     TEX(50)(0..NBUGT) , TEXTE(80)(0..NBUGT)
  Endif

  #-1 ------------------------
  If ( WCSOCCOCHE <> "" ) Then
    # Si une seule sociÃĐtÃĐ cochÃĐe --> Bouche sur les UGT de la table 413
    # Recherche si des biens de la sociÃĐtÃĐ sont liÃĐs a l'UGT
    For [F:ADI]
      Filter[F:FAS] Where ([F:FAS]CPY =  WCSOCCOCHE  and [F:FAS]IASCGU  =  [F:ADI]CODE)
      Read[FAS] First
      If (!fstat) Then
        I    += 1
        TEX(I)   = [F:ADI]CODE
        WCLIB = ""
        Call LECTEXTRA(WCLIB,"ATABDIV","LNGDES",WCNUMTAB, [F:ADI]CODE ) From ATEXTRA
        If ( WCLIB = "" ) Then
          Call LECTEXTRA(WCLIB,"ATABDIV","SHODES",WCNUMTAB, [F:ADI]CODE ) From ATEXTRA
        Endif
        TEXTE(I) = format$("Kb:20X",[F:ADI]CODE + '               ') + WCLIB
      Endif
      Filter[F:FAS]
    Next
    Filter [F:ADI]

    TIT = mess(153,GML_MSGFAS,1)
    NBTEX = I
  #-1 ------------------------
  Else
    # Si pas de soc  cochÃĐes --> toute les UGT de la table 413 sont affichÃĐes
    For [F:ADI]
      I    += 1
      TEX(I)   = [F:ADI]CODE
      WCLIB = ""
      Call LECTEXTRA(WCLIB,"ATABDIV","LNGDES",WCNUMTAB, [F:ADI]CODE ) From ATEXTRA
      If  ( WCLIB = "" ) Then
        Call LECTEXTRA(WCLIB,"ATABDIV","SHODES",WCNUMTAB, [F:ADI]CODE ) From ATEXTRA
      Endif
      TEXTE(I) = format$("Kb:20X",[F:ADI]CODE + '                ') + WCLIB
    Next

    TIT = mess(153,GML_MSGFAS,1)
    NBTEX = I

  Endif
  #-1 ------------------------

  Filter [F:ADI]

Return


#================================================
$CALCUL_DEPRECIATION
#
# Calcul de la dÃĐprÃĐciation ou de l'annulation de dÃĐprÃĐciation
# - Si UGT : calcul du prorata de dÃĐprÃĐciation a appliquer au bien
# - AppelÃĐ par $MAS1_ALIM_TMP1 ou $MAS1_APPL_DIRT
#

  [F:DEPC] = [F:DEPW]
  [F:WFAS] = [F:FASW]
  # FQ60330
  # Call CAL_VALEUR_NETTE ( "RFP", [F:DEPW]DPRBAS, 3, [F:DEPW]NBV ) From GLOBB4
  # FQ67577
  Call CAL_VALEUR_NETTE ( "RFP", [F:DEPW]DPRBAS, 2, 0, [F:DEPW]NBV ) From GLOBB4

  Read[FAS]FAS0=[F:DEPW]AASREF
  #- 1 ----------------------------------
  If ( [M:IML1]IMLANNFLG = G_OUI ) Then
    # -----------------------
    # Annulation dÃĐprÃĐciation
    # -----------------------
    [F:DEPW]IML       = 0
    [F:DEPW]IMLRVE    = 0
    # FQ51385
    [F:DEPW]IMLTYP    = 0
    [F:DEPW]INTIMLTYP = ""
    [F:DEPW]EXTIMLTYP = ""
  #- 1 ----------------------------------
  Elsif ( abs([M:IML1]IML) > 0 ) Then
    # ----------------------
    # DÃĐprÃĐciation
    # ----------------------
    #- 2 -----------------------
    If  ( [F:DEPW]STRDPRDAT > [M:IML1]DATENDPER ) Then
      # Un bien comptable commenÃ§ant Ã  s'amortir aprÃĻs la fin de la pÃĐriode courante ne peut pas ÃŠtre dÃĐprÃĐciÃĐ
      [F:DEPW]IML = 0
    #- 2 -----------------------
    Elsif  ([F:DEPW]RVAAMT <> 0) Then
      # Un bien comptable ayant subi une rÃĐÃĐvaluation dans la pÃĐriode  ne peut ÃŠtre dÃĐprÃĐciÃĐ
      [F:DEPW]IML = 0
    #- 2 -----------------------
    Elsif  ([F:DEPW]DPM = G_DPMCA) Then
      # Un bien comptable amorti selon le mode "CA"   ne peut pas ÃŠtre dÃĐprÃĐciÃĐ
      [F:DEPW]IML = 0
    #- 2 -----------------------
    Elsif ([F:DEPW]ENDDPEFLG = G_OUI )  Then
      # Un bien comptable ayant la dotation exercice forcÃĐene peut ÃŠtre dÃĐprÃĐciÃĐ
      [F:DEPW]IML = 0
    Else
      #- 3 -----------------------
      If ( [F:FAS]AASTYP = GVML_TIGOODW ) Then
        #-- DÃĐprÃĐciation d'un bien Goodwill
        If ( GMRESTDEPGW > [F:DEPW]NBV ) Then
          [F:DEPW]IML    = [F:DEPW]NBV
          GMRESTDEPGW   -= [F:DEPW]NBV
        Else
          [F:DEPW]IML    = GMRESTDEPGW
          GMRESTDEPGW    = 0
        Endif
      #- 3 -----------------------
      Else
        #-- DÃĐprÃĐciation d'un bien NON Goodwill

        # En unitaire : Maj de la valeur marchÃĐ
        If ( ACTTYPGES=GTAMUNI ) and [F:DEPW]NSPVAL <> [M:IML1]NSPVAL
           [F:DEPW]NSPVAL = [M:IML1]NSPVAL
        Endif
        #Fq-86764 If (abs([F:DEPW]NSPVAL) > 0 and abs([F:DEPW]NSPVAL) > abs([F:DEPW]NBV) )
        #==> si paramÃĻtre IMLNSPNBV est  positionnÃĐ Ã  oui, on ne tient pas compte de la valeur marchÃĐ
        #==> pour dire si un bien peut ÃŠtre dÃĐprÃĐciÃĐ
        If (abs([F:DEPW]NSPVAL) > 0 and abs([F:DEPW]NSPVAL) > abs([F:DEPW]NBV) ) and ( GIMLNSPNBV <> G_OUI )
          # Un bien comptable disposant d'une valeur marchÃĐ >0 et > Ã  sa valeur nette ne peut ÃŠtre dÃĐprÃĐciÃĐ
          [F:DEPW]IML    = 0
        Else
          # On divise par le total de Valeur nette dont les biens sont dÃĐprÃĐciables
          If ( GMSOMNONGOOD = 0 ) Then
            [F:DEPW]IML    = 0
          Else
            [F:DEPW]IML    = GMDEPNONGOOD * [F:DEPW]NBV /   GMSOMNONGOOD
          Endif

          # FQ60330
          Call GET_MNT_ARRONDI ([F:DEPW]IML, [M:IML1]CUR, [F:DEPW]IML) From GLOBIENS

          # Maj de la valeur rÃĐsiduellle
          If ( ACTTYPGES = GTAMUNI ) Then
            [F:DEPW]RSDVAL = [M:IML1]RSDVAL
            [F:DEPW]NBV    -= [F:DEPW]IML
            [F:DEPW]NBV    += [F:DEPW]IMLRVE
          Endif

          # On planque le dernier bien sur lequel on a mis de la dÃĐprÃĐciation pour le complÃĐter avec
          # le solde si besoin
          GLAST_BCO      = [F:DEPW]AASREF
        Endif
      Endif
      #- 3 -----------------------
    Endif
    #- 2 -----------------------

    [M:IML1]IMLREP   -= [F:DEPW]IML : # On dÃĐcrÃĐmente la zone pour l'ÃĐventuel delta
    [F:DEPW]IMLRVE    = 0
    # FQ51385
    [F:DEPW]IMLTYP    = [M:IML1]IMLTYP
    [F:DEPW]INTIMLTYP = [M:IML1]INTIMLTYP
    [F:DEPW]EXTIMLTYP = [M:IML1]EXTIMLTYP

  #- 1 ----------------------------------
  Elsif abs([M:IML1]IMLRVE) > 0 Then
    # -----------------------
    # Reprise de dÃĐprÃĐciation
    # ----------------------

    If [F:DEPW]IMLRVELIM = 0 Then
      # Si pas de plafond reprise sur le bien, pas de reprise non plus !
      [F:DEPW]IMLRVE    = 0
    Elsif [F:FAS]AASTYP = GVML_TIGOODW
      # Cas d'un bien Goodwill
      [F:DEPW]IMLRVE    = 0
    Elsif abs([M:IML1]IMLRVE) >= abs([M:IML1]IMLRVELIM) Then
      # Si Reprise UGT >= Somme(Plafond reprise des biens)
      [F:DEPW]IMLRVE    = [F:DEPW]IMLRVELIM
    Elsif abs([M:IML1]IMLRVE) < abs([M:IML1]IMLRVELIM) Then
      # Si Reprise UGT < Somme(Plafond reprise des biens)
      [F:DEPW]IMLRVE    = [M:IML1]IMLRVE * [F:DEPW]IMLRVELIM / [M:IML1]IMLRVELIM
      Call GET_MNT_ARRONDI ([F:DEPW]IMLRVE, [M:IML1]CUR, [F:DEPW]IMLRVE) From GLOBIENS
    Else
      # Sinon Reprise bien = 0
      [F:DEPW]IMLRVE    = 0
    Endif

    # FQ103473
    # On planque le dernier bien sur lequel on a mis de la dÃĐprÃĐciation pour le complÃĐter avec
    # le solde si besoin
    If [F:DEPW]IMLRVE <> 0
      GLAST_BCO         = [F:DEPW]AASREF
    Endif

    [M:IML1]IMLREP   -= [F:DEPW]IMLRVE : # On dÃĐcrÃĐmente la zone pour l'ÃĐventuel delta FQ103473
    [F:DEPW]IML       = 0
    # FQ51385
    [F:DEPW]IMLTYP    = [M:IML1]IMLTYP
    [F:DEPW]INTIMLTYP = [M:IML1]INTIMLTYP
    [F:DEPW]EXTIMLTYP = [M:IML1]EXTIMLTYP

    # FQ72008 Maj de la valeur valeur nette
    If ( ACTTYPGES = GTAMUNI ) Then
      # FQ115085
      If ( [F:DEPW]IMLRVE = [F:DEPW]IMLRVELIM ) Then
        [M:IML1]IMLREP = 0
      Endif
      [F:DEPW]NBV    -= [F:DEPW]IML
      [F:DEPW]NBV    += [F:DEPW]IMLRVE
    Endif
  Endif
  #- 1 ----------------------------------
Return


######################################################################
# Points d'entrÃĐe de l'action mÃĐtier communs unitaire / massif
######################################################################

#=====================================================================
$ACTMET
  #If (GUSER = "MWA") Then : Infbox "ACTMET"-ACTMET : Endif
  Case ACTMET
    When "CRITMEN"            :   Gosub CRITMEN              # U  - Activation menu ou bouton
    When "SET_PRECHARGE"      :   Gosub SET_PRECHARGE        # U  - A positionner Ã  G_OUI s'il n'y a pas de bouton sÃĐlectionner
    When "SET_CRITACT"        :   Gosub SET_CRITACT          # UM - CRITACT critÃĻre de sÃĐlection particulier Ã  l'action mÃĐtier
    When "SET_GLO_MAS"        :   Gosub SET_GLO_MAS          # M  -
    When "FILL_HEA"           :   Gosub FILL_HEA             # U  - Alimentation partie spÃĐcifique en-tÃŠte

    When "AM_FLGCPY"          :   Gosub AM_FLGCPY            # M  - Modification sociÃĐtÃĐ

    # Locker
    When "OUVR_LOCK"          :   Gosub OUVR_LOCK            # UM - Ouverture de tables annexes pour les lock
    When "MAS1_CONTROLE"      :   Gosub MAS1_CONTROLE        # UM - Exclusion ÃĐlÃĐment de la population Ã  sÃĐlectionner
    When "MAS1_LOCK_AUTRE"    :   Gosub MAS1_LOCK_AUTRE      # UM - Lock objet liÃĐ Ã  l'enr en ligne de la population
    When "MAS1_LOCK_MONTANT"  :   Gosub MAS1_LOCK_MONTANT    # UM - Totalisation de montant
    When "CLOS_LOCK"          :   Gosub CLOS_LOCK            # UM - Close lock

    # Charger
    When "OUVR_ALIM_TMP1"     :   Gosub OUVR_ALIM_TMP1       # UM - Ouverture de tables annexes pour l'alim des table tmp.
    When "MAS1_ALIM_TMP1"     :   Gosub MAS1_ALIM_TMP1       # UM - Transfert zones tables de donnÃĐes -> tables tempo
    When "END_ALIM_TMP1"      :   Gosub END_ALIM_TMP1        # UM - A la fin de l'alim de tbl tempo mais avant le commit pour rÃĐpartir le delta

    # Applique_temp
    When "OUVR_APPL_TMP1"     :   Gosub OUVR_APPL_TMP1       # UM - Ouverture de tables annexes
    When "TMP1_APPL_TMP1"     :   Gosub TMP1_APPL_TMP1       # UM - Application des paramÃĻtres de l'action aux enr de la table temporaire principale
    When "TPF1_APPL_TPF1"     :   Gosub TPF1_APPL_TPF1       # UM - Application des paramÃĻtres de l'action aux enr de la table temporaire annexe

    # s/p "REPORT_MASK" Report objet principal dans les masques (unitaire uniquement)

    When "TMP1_ALIM_MASK"     :   Gosub TMP1_ALIM_MASK       # U  - Tansfert table temporaire principale -> masques de l'ÃĐcran
    When "REAF_ALIM_MASK"     :   Gosub REAF_ALIM_MASK       # U  - Tansfert tables temporaires -> masques de l'ÃĐcran (pour rÃĐaffichage)

    # Applique_dirt Mise Ã  jour directe (massif uniquement)
    When "OUVR_APPL_DIRT"     :   Gosub OUVR_APPL_DIRT       # M  - Ouverture de tables annexes pour la maj directe en massif
    When "MAS1_APPL_DIRT"     :   Gosub MAS1_APPL_DIRT       # M  - Mise Ã  jour directe des tables de donnÃĐes avec les paramÃĻtres de l'action
    When "END_APPL_DIRT"      :   Gosub END_APPL_DIRT        # M  - A la fin de la maj directe mais avant le commit pour rÃĐpartir le delta
    When "CLOS_APPL_DIRT"     :   Gosub CLOS_APPL_DIRT       # M  - A la fin de la maj directe mais aprÃĻs le commit pour rÃĐpartir le delta

    # reporter
    When "OUVR_ALIM_TABLE"    :   Gosub OUVR_ALIM_TABLE      # UM - Ouverture tables annexes avant report tables tempo -> tables de donnÃĐes
    When "TMP1_ALIM_TABLE"    :   Gosub TMP1_ALIM_TABLE      # UM - Report table temporaire principale -> table de donnÃĐes
    When "TPF1_ALIM_TABLE"    :   Gosub TPF1_ALIM_TABLE      # UM - Report table temporaire par plan   -> table de donnÃĐes par plan
    When "END_ALIM_TABLE"     :   Gosub END_ALIM_TABLE       # UM - A la fin report tables tempo -> tables de donnÃĐes avant le commit
    When "CLOS_ALIM_TABLE"    :   Gosub CLOS_ALIM_TABLE      # UM - A la fin report tables tempo -> tables de donnÃĐes aprÃĻs le commit
    When Default
  Endcase
Return

#=====================================================================
# Unitaire / massif : CritÃĻre de sÃĐlection particulier Ã  l'action mÃĐtier
$SET_CRITACT

  # CRITACT contient les critÃĻres de sÃĐlection suppplÃĐmentaires Ã  appliquer Ã  la population Ã  sÃĐlectionner
  # Les biens modÃĻles ou ceux ayant fait l'objet d'une sortie "rÃĐelle" sont exclus de la sÃĐlection
  # les biens classÃĐs pour vente
  # En massif on ne sÃĐlectionne pas les immobilisations nÃĐgatives

  #Fq54343-Gestion des concessions
  CRITACT   = "(OWNTYP<>GVML_TDMODEL&OWNTYP<>GVML_TDANNUL&OWNTYP<>GVML_TDCONCE&"
  # FQ95754_3 CRITACT  += "([M:IML1]DATEFF=[0/0/0]  or PURDAT <= [M:IML1]DATEFF) and "
  CRITACT  += "([M:IML1]DATEFF=[0/0/0]  or PURDAT <= [M:IML1]DATEFF) and SALCLSDAT = [0/0/0] and "
  CRITACT  += "(ISSDAT=[0/0/0] or (ISSDAT<>[0/0/0] and EXTISSFLG=G_OUI)))"

  If ( ACTTYPGES=GTAMMAS ) Then
    If ( dim([M:IML1]IASCGU) < 0 ) Then
      CRITACT += "&2=1"
    Else
      If ( [M:IML1]IASCGU <> "" ) Then
        CRITACT += "&IASCGU=[M:IML1]IASCGU"
      Elsif ( [M:IML1]AASREF <> "" ) Then
        CRITACT += "&(AASREF=[M:IML1]AASREF or CMP=[M:IML1]AASREF)"
      Else
        # Comme Ã§a aucun bien ne risque d'ÃŠtre sÃĐlectionnÃĐ (0=1 c'est pas prÃĻs d'arriver !)
        CRITACT += "&0=1"
      Endif
    Endif
   Endif
Return

#=====================================================================
# Unitaire : Modif de la variable dÃĐclenchant le prÃĐchargement en unitaire PRECHARGE
$SET_PRECHARGE
  PRECHARGE=G_NON
Return


#=====================================================================
# Unitaire : critÃĻre dÃĐsactivation / activation menu CRITMEN
$CRITMEN
  Local Integer ACCFCY
  Local Char AUZFCY (15)
  # AccÃĻs selon droit Ã  l'option
  Call DROITSITE ( [M:FAS0]FCY, [L]AUZFCY, [L]ACCFCY ) From SUPCPT
  If ( not [L]ACCFCY or not instr(1, [L]AUZFCY, 'V') ) Then
    CRITMEN = "1=0"
  Else
    CRITMEN = "1=1"
  Endif
Return

#=====================================================================
# Unitaire : Permet d'alimenter des zones spÃĐcifiques de l'en-tÃŠte de la fenÃŠtre
$FILL_HEA

Return

################################################################################
$AM_FLGCPY
    Disable GSTAOK
    Disable GSTABOU+1
    Effzo [M:IML1]IASCGU
    Effzo [M:IML1]20-30 : # initialisation en cas de changement de critÃĻre
    Call ANNULE_DEPRECIATION(G_NON)
End

#=====================================================================
# massif :
$SET_GLO_MAS
  G_NOCHOI_SELALL  = G_OUI
  G_NOCHOI_CONTSOC = G_NON
  G_CPYTAB_DISABLE = G_OUI
  G_FCYTAB_DISABLE = G_OUI
Return

#=====================================================================
# Unitaire / massif : Sert Ã  ouvrir des tables utilisÃĐes dans MAS1_CONTROLE ET MAS1_LOCK_AUTRE
$OUVR_LOCK
  Gosub OUVRE_TABLES
  If ( ACTTYPGES=GTAMMAS ) Then
    Filter [FASW] Where not(evalue(CRITSUPR)) &evalue(CRITACT)
    Read [FASW] First
    Filter [FASW]
    If !(fstat > 2) Then
      # Des biens viennent sur une sociÃĐtÃĐ oÃđ l'utilisateur n'est pas habilitÃĐ ! C'est interdit !
      RMES  = mess(246,GML_MSGFAS,1)-':'-[M:IML1]IASCGU-mess(247,GML_MSGFAS,1) : GOK   = 0  : Return
    Endif
  Endif
Return

#=====================================================================
# Unitaire / massif
$CLOS_LOCK

Global  Decimal GMSOMGOODW
Global  Decimal GMSOMNONGOOD
Global  Decimal GMDEPGOODW
Global  Decimal GMDEPNONGOOD
Global  Decimal GMRESTDEPGW

  GMSOMNONGOOD   = TOTOBJAMT(0)
  GMSOMGOODW     = TOTOBJAMT(1)
  If ( abs([M:IML1]IML) > 0 ) Then
    If  ( abs([M:IML1]IML) > abs(GMSOMGOODW) ) Then
      GMDEPGOODW     = GMSOMGOODW
      GMRESTDEPGW    = GMSOMGOODW
      GMDEPNONGOOD   = [M:IML1]IML - GMSOMGOODW
    Else
      GMDEPGOODW     = [M:IML1]IML
      GMRESTDEPGW    = [M:IML1]IML
      GMDEPNONGOOD   = 0
    Endif
  Endif
Return

#=====================================================================
# Massif : contrÃīle pour, ÃĐventuellement, exclure le bien de la population sÃĐlectionnÃĐe
#          pour exclure le bien GOK = 0
$MAS1_CONTROLE
 #Fq67577-Pologne
 If G_ACTKPL=G_OUI & func TRTFASMDR.IS_MDR_PENDING([F:MAS1]CPY, [F:MAS1]AASREF, 0, [M:IML1]DPRPLN)>0
  GOK=0
 Endif

 #Fq96270-Annulation de dÃĐprÃĐciation UGT : exlusion des biens de l'UGT non dÃĐprÃĐciÃĐs (cas des biens sortis avec annulation de la dÃĐprÃĐciation puis
 #                                         annulation de sortie par exemple)
 If  ([M:IML1]IASCGU <> "") and ([M:IML1]IMLANNFLG = G_OUI)
   # Recherche du contexte contenant le plan Ã  traiter
   If ([F:CNX]CPY<>[F:MAS1]CPY) or !find([M:IML1]DPRPLN,[F:CNX]PLNCAA)
     For [F:CNX] Where CPY=[F:MAS1]CPY
       If find([M:IML1]DPRPLN,[F:CNX]PLNCAA) : Break : Endif
     Next
   Endif
   # Recherche de la pÃĐriode courante du contexte
   If ([F:FIS]CPY<>[F:MAS1]CPY) or ([F:FIS]CNX<>[F:CNX]CNX) or ([F:FIS]STAFIY<>GVML_TECOURA)
     Read [F:FIS]FIY1=[F:MAS1]CPY;[F:CNX]CNX;GVML_TECOURA
   Endif

   # FQ102807 exclure les biens sortis exercice prÃĐcÃĐdent
   If [F:MAS1]ISSDAT <> [0/0/0] and [F:MAS1]ISSDAT < [F:FIS]DATSTRFIY
     GOK = 0
     Return
   Endif

   # Lecture des informations d'amortissement pÃĐriode courante
   Read [F:DEP]DEP0=[F:MAS1]AASREF;[M:IML1]DPRPLN;[F:FIS]DATENDFIY;[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
   If (!fstat) and ([F:DEP]IML=0 and [F:DEP]IMLRVE=0) and ([FASW]OWNTYP<>GVML_TDANNUL) and ([FASW]OWNTYP<>GVML_TDMODEL)
     GOK=0
   Endif
 Endif
Return

#=====================================================================
# Unitaire / massif : Lock d'objet liÃĐ Ã  l'enregistrement en ligne
$MAS1_LOCK_AUTRE
Return

#=====================================================================
# Unitaire / massif : Sert Ã  alimenter les zones montant de TMPMASLCK OBJAMT
$MAS1_LOCK_MONTANT

  # - Totalisation des valeurs nettes des biens dont la valeur nette >= valeur marchÃĐ
  # - Si valeur nette pÃĐriodique < valeur marchÃĐ --> le bien n'est pas pris en compte
  #   dans le calcul du prorata de rÃĐpartition de la dÃĐprÃĐciation

  # Lecture de DEPREC du bien  pour le plan saisi
  Read [DEP]DEP5=[F:MAS1]AASREF;[M:IML1]DPRPLN;[M:IML1]DATENDFIY;[M:IML1]DATSTRPER
  #-1 ---------------
  If (fstat)  Then
    # S'il n'y a pas de ligne sur la pÃĐriode/exercice courant, on rejette le bien : GOK  = 0
    GOK  = 0
    Return
  #-1 ---------------
  Endif

  # Gestion Immo goodwill
  Read[FAS]FAS0=[F:MAS1]AASREF
  If ( fstat = 0 ) Then
    If ( [F:FAS]AASTYP = GVML_TIGOODW ) Then
      # Si type de bien GOODWILL on prend systÃĐmatiquement la val nette F.P dans (1)
      [F:TML]OBJAMT(1)= [F:DEP]NBV
    #Fq-86764  Elsif ( abs([F:DEP]NBV) < abs([F:DEP]NSPVAL) ) Then
    #==> si paramÃĻtre IMLNSPNBV est  positionnÃĐ Ã  oui, on ne tient pas compte de la valeur marchÃĐ
    #==> pour dire si un bien peut ÃŠtre dÃĐprÃĐciÃĐ
    Elsif ( abs([F:DEP]NBV) < abs([F:DEP]NSPVAL) ) and ( GIMLNSPNBV <> G_OUI )
      # Sinon autre type et val.nette F.P est < Ã  la val. marchÃĐ, elle n'est pas prise en compte dans (0)
      [F:TML]OBJAMT(0)= 0
      GOK  = 0
      Return
    Else
      # Sinon autre type et val.nette F.P est >= Ã  la valeur marchÃĐ, on la prend pas en compte dans (0)
      [F:TML]OBJAMT(0)= [F:DEP]NBV
    Endif
  Endif

  #-1 ---------------

Return

#=====================================================================
# Unitaire / massif : Sert Ã  ouvrir des tables utilisÃĐes dans MAS1_ALIM_TMP1
$OUVR_ALIM_TMP1

  Gosub OUVRE_TABLES
  Gosub DETERMINE_DEPRECIATION_REPRISE

  #GIMLTOT       = 0
  #GIMLRVETOT    = 0
  #GIMLTOTORI    = 0
  #GIMLRVEORI    = 0

Return

#=====================================================================
# Unitaire / massif : AppelÃĐ si CONTROLE
#                     Chargement de la population en table temporaire
#                     Etiquette appelÃĐe par le s/p CHARGER
#                     Si une erreur se produit dans cette ÃĐtiquette
#                     Alimenter RMES avec le message qui doit apparaÃŪtre
#                     dans une boÃŪte en unitaire ou en massif
$MAS1_ALIM_TMP1

  #**************************
  # Chargement table temporaire TMPFASMAS [F:TMP1] avec infos du bien comptable [F:MAS1]
  [F:TMP1]TRTNUM     = NUMACT
  [F:TMP1]CPY        = [F:MAS1]CPY
  [F:TMP1]OBJREF     = [F:MAS1]AASREF
  [F:TMP1]AASDES1    = [F:MAS1]AASDES1
  [F:TMP1]IASCGU     = [F:MAS1]IASCGU
  [F:TMP1]ITSDAT     = [F:MAS1]ITSDAT
  [F:TMP1]ACGCUR     = [F:MAS1]ACGCUR
  [F:TMP1]IASCUR     = [F:MAS1]IASCUR

  # On alimente dans la table temporaire les deux valorisations, et on alimentera
  # la colonne ETRNOT de l'ÃĐcran FASIML2 dans $MFS_LIENS avec l'une ou l'autre en fonction de la norme
  [F:TMP1]IASETRNOT  = [F:MAS1]IASETRNOT
  [F:TMP1]ACGETRNOT  = [F:MAS1]ACGETRNOT

  # FQ102807 exclure les biens sortis exercice prÃĐcÃĐdent
  If [F:MAS1]ISSDAT <> [0/0/0] and [F:MAS1]ISSDAT < [M:IML1]DATSTRFIY
    RMES = mess(143, GML_MSGFAS, 1) - [F:MAS1]CPY - ':' - mess(62, GML_MSGFAS, 1)
    GOK = 0
    Return
  Endif

  # Nouvelle  position :;  RÃĐcupÃĐration des infos de DEPREC et contrÃīles
  Read [DEP]DEP5=[F:MAS1]AASREF;[M:IML1]DPRPLN;[M:IML1]DATENDFIY;[M:IML1]DATSTRPER

  If ( [M:IML1]IMLANNFLG=G_NON and [F:DEP]DEPSTA <> GVML_SCCAL ) Then
    # Annulation de la modif prÃĐcÃĐdente car pas de trace ouverte Ã  ce stade
    RMES  = mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(163,GML_MSGFAS,1) : GOK = 0 : Return
  Endif
  If ( [M:IML1]IMLANNFLG=G_NON and ([F:DEP]IML <> 0 or [F:DEP]IMLRVE <> 0)  ) Then
    # Annulation de la modif prÃĐcÃĐdente car pas de trace ouverte Ã  ce stade
    RMES  = mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(164,GML_MSGFAS,1) : GOK = 0 : Return
  Endif
  If ( [F:DEP]RVAAMT > 0 or  [F:DEP]RVADAT <> [0/0/0] )  Then
    # Si rÃĐÃĐvaluation dans la pÃĐriode on ne peut pas dÃĐprÃĐcier
    RMES  = mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(424,GML_MSGFAS,1) : GOK = 0 : Return
  Endif
  If ( [F:DEP]DPM = G_DPMCA )  Then
    # Si mode "CA" on ne peut pas dÃĐprÃĐcier
    RMES  = mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(610,GML_MSGFAS,1) : GOK = 0 : Return
  Endif
  If ( [F:DEP]STRDPRDAT > [M:IML1]DATENDPER ) Then
    # Date de dÃĐbut d'amortissement supÃĐrieure Ã  la date de fin pÃĐriode courante
    RMES  = mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(389,GML_MSGFAS,1) : GOK = 0 : Return
  Endif
  If ( ([F:MAS1]GACACN = GVML_NIENCOU or [F:MAS1]IASACN = GVML_NIENCOU) and [F:DEP]DPM <> G_DPMSA ) Then
    # Nature du bien "Immo en cours" et mode du plan <> "SA"
    RMES  = mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(604,GML_MSGFAS,1) : GOK = 0 : Return
  Endif
  If ( [F:DEP]ENDDPEFLG = G_OUI )  Then
    # Exclusion des biens ayant la dotation exercice forcÃĐe
    RMES  = mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(501,GML_MSGFAS,1) : GOK = 0 : Return
  Endif

  # Travail dans le buffer [DEPW] pour calculer la dÃĐprÃĐciation
  [F:DEPW] = [F:DEP]

  Gosub CALCUL_DEPRECIATION

  # Exploitation des infos calculÃĐes et mises Ã  jour dans DEPW

  GIMLTOT          += [F:DEPW]IML
  GIMLTOTORI       += [F:DEPW]IML

  GIMLRVETOT       += [F:DEPW]IMLRVE
  GIMLRVEORI       += [F:DEPW]IMLRVE

  [F:TMP1]FLGERR     = G_NON
  [F:TMP1]FLGMOD     = G_OUI
  [F:TMP1]           = [F:DEP]
  [F:TMP1]FLGERR     = G_NON

  # FQ51385
  [F:TMP1]IMLTYP     = [M:IML1]IMLTYP
  [F:TMP1]INTIMLTYP  = [M:IML1]INTIMLTYP
  [F:TMP1]EXTIMLTYP  = [M:IML1]EXTIMLTYP

  # Utilisation de rubrique du tranfert
  [F:TMP1]IMLANNFLG  = [M:IML1]IMLANNFLG
  [F:TMP1]DATEFF     = [M:IML1]DATEFF

  # Informations spÃĐcifiques
  [F:TMP1]TRTNUM     = NUMACT
  [F:TMP1]OBJREF     = [F:DEPW]AASREF
  [F:TMP1]DPRPLN     = [F:DEPW]DPRPLN
  [F:TMP1]FIYENDDAT  = [F:DEPW]FIYENDDAT
  [F:TMP1]PERSTRDAT  = [F:DEPW]PERSTRDAT
  [F:TMP1]PERENDDAT  = [F:DEPW]PERENDDAT
  [F:TMP1]STRDPRDAT  = [F:DEPW]STRDPRDAT
  [F:TMP1]DPRBAS     = [F:DEPW]DPRBAS
  [F:TMP1]NSPVAL     = [F:DEPW]NSPVAL

  If ( ACTTYPGES=GTAMUNI ) Then
    [F:TMP1]NBV   = [F:DEPW]NBV
    [F:TMP1]NBVO  = [F:DEPW]NBV + [F:DEPW]IML - [F:DEPW]IMLRVE
  Else
    [F:TMP1]NBV   = [F:DEPW]NBV - [F:DEPW]IML + [F:DEPW]IMLRVE
    [F:TMP1]NBVO  = [F:DEPW]NBV
  Endif

  [F:TMP1]IMLRVELIM  = [F:DEPW]IMLRVELIM
  [F:TMP1]IML        = [F:DEPW]IML
  [F:TMP1]IMLRVE     = [F:DEPW]IMLRVE
  [F:TMP1]RSDVAL     = [F:DEPW]RSDVAL

  Write [TMP1]
  If (fstat) Then
    Case fstat
      When 1
        # Erreur entrÃĐe sortie.
        RMES = mess(104,GML_MSGFAS,1)-"TMPMASFAS"-mess(105,GML_MSGFAS,1)-"05"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF
        GOK  = -1
      When 3
        # Tentative d'ÃĐcriture en double
        RMES = mess(129,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF+"/"+num$([F:TMP1]DPRPLN)
        GOK  = 0
      When Default
    Endcase
    Return
  Else
    NBTMP+=1
  Endif

Return

#=====================================================================
# Unitaire / massif : Traitement Ã  fin de chargement de table temporaire
$END_ALIM_TMP1

  # Me permet d'affecter le delta s'il y en a

  #-1 -----------------
  If (GOK = 1) Then
    # On n'est pas en erreur
    If ( [M:IML1]IMLANNFLG = G_NON ) Then
      #FQ103473
      #If ( [M:IML1]IML > 0 ) Then
      #  # DÃĐprÃĐciation
      #  # ----------------------
        If ( [M:IML1]IMLREP <> 0 ) Then
          # S'il reste un reliquat (+ ou -) on le rÃĐparti sur le dernier bien dÃĐprÃĐciÃĐ
          Read[TMP1]MFS0=NUMACT;GLAST_BCO
          If (fstat) Then
            # Erreur entrÃĐe sortie.
            RMES = mess(104,GML_MSGFAS,1)-"TMPPLNFAS"-mess(105,GML_MSGFAS,1)-"04"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+GLAST_BCO+"/"+num$([M:IML1]DPRPLN)
            GOK  = -1
            Return
          Endif

          #FQ103473
          If ( [M:IML1]IML > 0 ) Then
            # DÃĐprÃĐciation
            # ----------------------
            [F:TMP1]IML    += [M:IML1]IMLREP
            [F:TMP1]NBV    -= [M:IML1]IMLREP
            GIMLTOT        += [M:IML1]IMLREP
            GIMLTOTORI     += [M:IML1]IMLREP
          Elsif ( [M:IML1]IMLRVE > 0 ) Then
            # Reprise de DÃĐprÃĐciation
            # ----------------------
            [F:TMP1]IMLRVE += [M:IML1]IMLREP
            [F:TMP1]NBV    += [M:IML1]IMLREP
            GIMLRVETOT     += [M:IML1]IMLREP
            GIMLRVEORI     += [M:IML1]IMLREP
          Endif

          Rewrite [TMP1]

          If fstat Then
            Case fstat
              When 1
                # Erreur entrÃĐe sortie.
                # FGR26052004
                RMES = mess(104,GML_MSGFAS,1)-"TMPPLNFAS"-mess(105,GML_MSGFAS,1)-"04"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF+"/"+num$([F:TMP1]DPRPLN)
                GOK  = -1
              When 3
                # Tentative d'ÃĐcriture en double
                # FGR26052004
                RMES = mess(129,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF+"/"+num$([F:TMP1]DPRPLN)
                GOK  = 0
              When Default
            Endcase
            Return
          Endif
          [M:IML1]IMLREP = 0
        Endif
      #FQ103473
      #Endif
    Endif
  Endif
  #-1 -----------------
  Kill GLAST_BCO
Return

#=====================================================================
# Unitaire / massif : Ouverture de tables annexes
$OUVR_APPL_TMP1
  # Ouverture de tables liÃĐes Ã  explorer ou Ã  mettre Ã  jour  par l'action massive
  If !(clalev([F:MAS1]))   : Local File FXDASSETS   [MAS1]   : Endif
Return

#=====================================================================
# Unitaire / massif : Application paramÃĻtres action au contenu de la table temporaire principale
$TMP1_APPL_TMP1
Return

#-------------------------------------------------------------------------------
# Unitaire / massif : Chargement de la population en table temporaire
#                     Etiquette appelÃĐe par le s/p CHARGER
#                     Si une erreur se produit dans cette ÃĐtiquette
#                     Alimenter RMES avec le message qui doit apparaÃŪtre
#                     dans une boÃŪte en unitaire ou en massif
#=====================================================================
# Unitaire / massif : Application paramÃĻtres action au contenu de la table temporaire annexe (par plan)
$TPF1_APPL_TPF1
Return

#=====================================================================
# Massif : Sert Ã  ouvrir des tables utilisÃĐes dans MAS1_APPL_DIRT
$OUVR_APPL_DIRT
  Gosub OUVRE_TABLES
  Gosub DETERMINE_DEPRECIATION_REPRISE
  Gosub ENTETE_TRACE_DETAIL
Return


#=====================================================================
# Massif : Traitement avec maj tables de donnÃĐes : mise Ã  jour directe (si pas CONTROLE)
$MAS1_APPL_DIRT

Local Integer LCDRET, LREVTCREE
Local Char    LCDINT
Local Integer WICONTEXTE
Local Integer WCCODRET, WSCODRET
Local Date    WDDATEC(1..5), WDDATES(1..5)
Local Char    PEVETYP
Local Integer LRET
Local Integer RERROR

  WIVMMAJ = G_NON

  # FQ102807 exclure les biens sortis exercice prÃĐcÃĐdent
  If [F:MAS1]ISSDAT <> [0/0/0] and [F:MAS1]ISSDAT < [M:IML1]DATSTRFIY
    Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, [M:IML1]DPRPLN, G_NON,
&        mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(62,GML_MSGFAS,1) ) From TRCPROCOM
    GOK = 0
    Return
  Endif

  Read [DEP]DEP5=[F:MAS1]AASREF;[M:IML1]DPRPLN;[M:IML1]DATENDFIY;[M:IML1]DATSTRPER
  If (fstat) Then
    Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, [M:IML1]DPRPLN, G_NON,
&        mess(104,GML_MSGFAS,1)-"DEPREC"-mess(105,GML_MSGFAS,1)-"03"-mess(106,GML_MSGFAS,1)-[F:DEP]AASREF+"/"+num$([F:DEP]DPRPLN)
&                        ) From TRCPROCOM
    GOK = 0 : Return
  Endif

  If ( [M:IML1]IMLANNFLG=G_NON and [F:DEP]DEPSTA <> GVML_SCCAL ) Then
    Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, [M:IML1]DPRPLN, G_NON,
&        mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(163,GML_MSGFAS,1) ) From TRCPROCOM
    GOK   = 0 : Return
  Endif

  If ( [M:IML1]IMLANNFLG=G_NON and ([F:DEP]IML <> 0 or [F:DEP]IMLRVE <> 0)  ) Then
    RMES  = mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(164,GML_MSGFAS,1)
    Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, [M:IML1]DPRPLN, G_NON,
&                         mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(164,GML_MSGFAS,1)
&                        ) From TRCPROCOM
    GOK = 0 : Return
  Endif

  # si rÃĐÃĐvaluation dans la pÃĐriode on ne peut pas dÃĐprÃĐcier
  If ( [F:DEP]RVAAMT <> 0 or  [F:DEP]RVADAT <> [0/0/0] )  Then
    RMES  = mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(424,GML_MSGFAS,1)
    Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, [M:IML1]DPRPLN, G_NON,
&                         mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(424,GML_MSGFAS,1)
&                        ) From TRCPROCOM
    GOK = 0 : Return
  Endif

  # si mode "CA" on ne peut pas dÃĐprÃĐcier
  If ( [F:DEP]DPM = G_DPMCA )  Then
    RMES  = mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(610,GML_MSGFAS,1)
    Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, [M:IML1]DPRPLN, G_NON,
&                         mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(610,GML_MSGFAS,1)
&                        ) From TRCPROCOM
    GOK = 0 : Return
  Endif

  # Si dÃĐbut d'amort. > Ã  dÃĐbut de pÃĐriode de l'exercice en cours on ne peut pas dÃĐprÃĐcier
  If ( [F:DEP]STRDPRDAT > [M:IML1]DATENDPER ) Then
    # Date de dÃĐbut d'amortissement supÃĐrieure Ã  la date de fin pÃĐriode courante
    RMES  = mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(389,GML_MSGFAS,1)
    Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, [M:IML1]DPRPLN, G_NON,
&                         mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(389,GML_MSGFAS,1)
&                        ) From TRCPROCOM
    GOK = 0 : Return
  Endif

  # Si le bien est de nature En cours et le mode <> "SA"
  If ( ([F:MAS1]GACACN = GVML_NIENCOU or [F:MAS1]IASACN = GVML_NIENCOU) and [F:DEP]DPM <> G_DPMSA ) Then
    # Nature du bien "Immo en cours" et mode du plan <> "SA"
    RMES  = mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(604,GML_MSGFAS,1)
    Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, [M:IML1]DPRPLN, G_NON,
&                         mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(164,GML_MSGFAS,1)
&                        ) From TRCPROCOM
    GOK = 0 : Return
  Endif

  # Exclusion des biens ayant la dotation pÃĐriode
  If ( [F:DEP]ENDDPEFLG = G_OUI ) Then
    RMES  = mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(501,GML_MSGFAS,1)
    Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, [M:IML1]DPRPLN, G_NON,
&                         mess(143,GML_MSGFAS,1)-[F:DEP]CPY-':'-mess(501,GML_MSGFAS,1)
&                        ) From TRCPROCOM
    GOK = 0 : Return
  Endif

  #==
  [F:DEPW] = [F:DEP]
  #==

  Gosub CALCUL_DEPRECIATION
  Gosub ECRIT_TRACE_DETAIL

  [F:DEP]IML        = [F:DEPW]IML
  [F:DEP]IMLRVE     = [F:DEPW]IMLRVE
  # FQ51385
  [F:DEP]IMLTYP     = [F:DEPW]IMLTYP
  [F:DEP]INTIMLTYP  = [F:DEPW]INTIMLTYP
  [F:DEP]EXTIMLTYP  = [F:DEPW]EXTIMLTYP
  [F:DEP]RSDVAL     = [F:DEPW]RSDVAL
  [F:DEP]DEPSTA     = GVML_SCNOCAL
  [F:DEP]NBV        = [F:DEPW]NBV-[F:DEPW]IML+[F:DEPW]IMLRVE

  #==
  Rewrite [DEP]
  #==
  If (fstat) Then
    Case fstat
      When 1
        # Erreur entrÃĐe sortie.
        RMES = mess(104,GML_MSGFAS,1)-"DEPREC"-mess(105,GML_MSGFAS,1)-"04"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:DEP]AASREF+"/"+num$([F:DEP]DPRPLN)
        GOK  = -1
      When 3
        # Tentative d'ÃĐcriture en double
        RMES = mess(129,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:DEP]AASREF+"/"+num$([F:DEP]DPRPLN)
        GOK  = 0
      When Default
    Endcase
    Return
  Endif

  # Indicateur du bien sont mis "Ã  recalculer"
  [F:MAS1]FLGCLC                  = G_OUI
  [F:MAS1]FLGCNXCLC([F:DEP]CNX-1) = G_OUI

  [F:MAS1]UPDUSR=GUSER #FQ104286
  [F:MAS1]UPDDAT=date$ #FQ104286
  #==
  Rewrite [MAS1]
  #==
  If (fstat)
    # Erreur technique
    RMES= mess(104,GML_MSGFAS,1)+" FXDASSETS"+mess(105,GML_MSGFAS,1)+" 01"+mess(106,GML_MSGFAS,1)-[F:MAS1]AASREF
    GOK=0 : Return
  Endif

  #-1 -------------------------
  If ( dim(FLGSIM) > 0 & FLGSIM = G_NON ) Then


    If ( [M:IML1]IMLANNFLG = G_NON ) Then
      # GÃĐnÃĐration d'un ÃĐvÃĐnement que l'on soit en unitaire ou en massif
      LCDINT= "FASIML"+num$([F:DEPW]DPRPLN)
      Call GENER_EVE(GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,[M:IML1]DATEFF,[0/0/0],LCDRET) From GENEVE
      If ( LCDRET > 20 ) Then : RMES  = mess(107,GML_MSGFAS,1)-num$(LCDRET)-'(A)' : GOK = 0 : Return : Endif
    Else
      # Extourner ÃĐvÃĐnement
      LCDINT= "FASIML"+num$([F:DEPW]DPRPLN)
      Call ANNULE_EVE(GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,[M:IML1]DATEFF,LREVTCREE,LCDRET) From GENEVE
      If ( LCDRET > 20 ) Then : RMES  = mess(107,GML_MSGFAS,1)-num$(LCDRET)-'(B)' : GOK = 0 : Return : Endif
    Endif

    NBCPYMAJ += 1
  Endif
  #-1 -------------------------
Return


#=====================================================================
# Massif : Traitement Ã  fin de la maj directe
$END_APPL_DIRT

Local Integer LCDRET, LREVTCREE, LERROR, N_I
Local Char    LCDINT
Local Decimal IML_TRACE, IMLRVE_TRACE : # Pour indiquer dans la trace le reliquat en dÃĐprÃĐciation ou en reprise de dÃĐprÃĐciation FQ103473

  # Lorsqu'il reste un reliquat aprÃĻs ventilation de la dÃĐprÃĐciation (le montant Ã  rÃĐpartir IMLREP <> 0)
  # le traitement applique ce reliquat au dernier bien dÃĐprÃĐciÃĐ. ce qui a pour consÃĐquence le traitement
  # ci-dessous. Avec comme inconvÃĐnient de rajouter une ligne dans le compte-rendu portant le reliquat
  # appliquÃĐ au dernier. Ceci n'arrive pas lorsque l'on est d'abord passer par contrÃīler. Cela n'arrive
  # donc pas souvent. SI Ã  l'avenir l'on souhaite ne plus avoir cette ligne supplÃĐmentaire deux solutions
  # peuvent ÃŠtre mise en oeuvre 1Â°) imposer d'ÃŠtre passÃĐ par le bouton contrÃīler avant de pouvoir faire OK.
  # 2Â°) Alimenter GLAST_BCO dans l'action MAS1_LOCK_MONTANT afin de l'avoir Ã  disposition lors de l'execution
  # de l'action MAS1_APPL_DIRT et dÃĐporter une partie du traitement ci-dessous Ã  savoir l'application du
  # reliquat au dernier bien.
  # L'autre partie du traitement (ÃĐvÃĐnement, rewrite, ecriture trace) devenant inutile.

  #-1 --------------------------
  If ( GOK = 1 ) Then
    # On n'est pas en erreur
    If ( [M:IML1]IMLANNFLG = G_NON ) Then
      #FQ103473
      #If ( [M:IML1]IML <> 0 ) Then
      #  #-------------
      #  # DÃĐprÃĐciation
      #  #-------------
        If ( [M:IML1]IMLREP <> 0 ) Then
          # S'il reste un reliquat (+ ou -) on le rÃĐparti sur le dernier bien dÃĐprÃĐciÃĐ
          Filter [MAS1] Where AASREF=GLAST_BCO
          Read [MAS1] First
          Filter [MAS1]

          Read [DEP]DEP5=GLAST_BCO;[M:IML1]DPRPLN;[M:IML1]DATENDFIY;[M:IML1]DATSTRPER
          #FQ103473
          #[F:DEPW]    = [F:DEP]
          #[F:DEPW]IML = [M:IML1]IMLREP
          #Gosub ECRIT_TRACE_DETAIL

          #FQ103473
          If ( [M:IML1]IML <> 0 ) Then
            #-------------
            # DÃĐprÃĐciation
            #-------------
            [F:DEP]IML    += [M:IML1]IMLREP
            [F:DEP]NBV    -= [M:IML1]IMLREP
            [F:DEPW]       = [F:DEP]
            IML_TRACE      = [M:IML1]IMLREP
            IMLRVE_TRACE   = 0
          Elsif ( [M:IML1]IMLRVE <> 0 ) Then
            #-------------
            # Reprise de DÃĐprÃĐciation
            #-------------
            [F:DEP]IMLRVE += [M:IML1]IMLREP
            [F:DEP]NBV    += [M:IML1]IMLREP
            [F:DEPW]       = [F:DEP]
            IML_TRACE      = 0
            IMLRVE_TRACE   = [M:IML1]IMLREP
          Endif

          Gosub ECRIT_TRACE_DETAIL

          # Il faut extourner l'ÃĐvÃĐnement du dernier bien et le regÃĐnÃĐrer avec les bonnes valeurs de dÃĐprÃĐciation et de reprise
          If ( dim(FLGSIM) > 0 and FLGSIM = G_NON ) Then
            # 1Â°) on extourne celui qu'on vient de passer (dans MAS1_APPL_DIRT)
            LCDINT= "FASIML"+num$([F:DEPW]DPRPLN)
            #Fq-64122 Call TEMPO_EVT() From GENEVE
            Call ANNULE_EVE(GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,[M:IML1]DATEFF,LREVTCREE,LCDRET) From GENEVE
            If ( LCDRET > 20 ) Then : RMES  = mess(107,GML_MSGFAS,1)-num$(LCDRET)-'(C)' : GOK = 0 : Return : Endif

            # 2Â°) et on le repasse complÃĻtement car la valeur RVARVE est calculÃĐe Ã  partir de IML et RVARVE
            #Fq-64122  Call TEMPO_EVT() From GENEVE
            Call GENER_EVE(GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,[M:IML1]DATEFF,[0/0/0],LCDRET) From GENEVE
            If ( LCDRET > 20 ) Then : RMES  = mess(107,GML_MSGFAS,1)-num$(LCDRET)-'(D)' : GOK = 0 : Return : Endif
          Endif

          [F:DEP]DEPSTA  = GVML_SCNOCAL
          #==
          Rewrite [DEP]
          #==
          If (fstat) Then
            Case fstat
              When 1
                # Erreur entrÃĐe sortie.
                # FGR26052004
                RMES = mess(104,GML_MSGFAS,1)-"DEPREC"-mess(105,GML_MSGFAS,1)-"04"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:DEP]AASREF+"/"+num$([F:DEP]DPRPLN)
                GOK  = -1
              When 3
                # Tentative d'ÃĐcriture en double
                # FGR26052004
                RMES = mess(129,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:DEP]AASREF+"/"+num$([F:DEP]DPRPLN)
                GOK  = 0
              When Default
            Endcase
            Return
          Endif
          [M:IML1]IMLREP = 0
        Endif
      #FQ103473
      #Endif
    Endif
  Endif
  #-1 --------------------------

  Kill GLAST_BCO
  Gosub FERME_TRACE_DETAIL
  Gosub TOTAL_TRACE_DETAIL
  Gosub KILL_TRACE_DETAIL

Return



#=====================================================================
# Massif : Traitement Ã  fin de la maj directe
$CLOS_APPL_DIRT

Local Integer LERROR

  If ( GOK = 1) Then
    # ----------------------
    # On n'est pas en erreur
    # ----------------------
    If ( dim(FLGSIM) > 0 & FLGSIM = G_NON ) Then
      Call RECALCUL_SOCIETE(LERROR)
      If ( LERROR <> 0 ) Then
        If ( LERROR = -3 ) Then
          Call ECR_TRACE_ERREUR([F:MAS1]CPY,"",[M:IML1]DPRPLN, G_NON,mess(103,GML_MSGCAL,1)-':'-mess(102,GML_MSGCAL,1)) From TRCPROCOM
          GOK  = 0
        Else
          Call ECR_TRACE_ERREUR([F:MAS1]CPY,"",[M:IML1]DPRPLN, G_NON,mess(103,GML_MSGCAL,1)-':'-mess(104,GML_MSGCAL,1)) From TRCPROCOM
          GOK  = 0
        Endif
      Endif
    Endif
  Endif

Return

#=====================================================================
# Unitaire : Permet de reporter les infos de TMP1 dans les masques de l'objet mÃĐtier
#            Positionner ACTMODIF Ã  1 si des infos de l'objet mÃĐtier sont modifiÃĐes
$TMP1_ALIM_MASK

Local Integer I_PLN

  # Affectation des champs du plan  du bien courant
  I_PLN = find([F:TMP1]DPRPLN,[M:FAS3]DPRPLN)
  [M:FAS3]IML      (I_PLN-1)   = [F:TMP1]IML
  [M:FAS3]IMLRVE   (I_PLN-1)   = [F:TMP1]IMLRVE
  # FQ51385
  [M:FAS3]IMLTYP   (I_PLN-1)   = [F:TMP1]IMLTYP
  [M:FAS3]EXTIMLTYP(I_PLN-1)   = [F:TMP1]EXTIMLTYP
  [M:FAS3]INTIMLTYP(I_PLN-1)   = [F:TMP1]INTIMLTYP
  [M:FAS3]NSPVAL   (I_PLN-1)   = [F:TMP1]NSPVAL

  [M:FAS3]NBV      (I_PLN-1)   = [F:TMP1]NBV
  [M:FAS3]RSDVAL   (I_PLN-1)   = [F:TMP1]RSDVAL

  [M:FAS3]DEPSTA   (I_PLN-1)                = GVML_SCNOCAL
  [M:FAS0]FLGCLC                            = G_OUI
  [M:FAS0]FLGCNXCLC([M:FAS3]CNX(I_PLN-1)-1) = G_OUI


  #  Report valeur marchÃĐ sur les autres plans avec conversion ÃĐventuelle

Local Integer WIRET
Local Decimal WDMONT2
Local Char    WCDEV2
Local Integer WITYPDEV
Local Date    WDDATE(1..5)
Local Char    WCDEV1
Local Decimal WMNEWVM
Local Integer WICONTEXTE
Local Integer WICODERET
Local Integer WIPLAN
Local Integer WI
Local Date    WDDAT2

  Call GET_CNX_FROM_PLAN ([M:FAS0]CPY, [F:TMP1]DPRPLN, WICONTEXTE) From GLOBIENS
  Call GET_CNX_DAT([M:FAS0]CPY, WICONTEXTE, WDDATE, WICODERET) From GLOBIENS
  WDDAT2   = WDDATE(4)
  WCDEV1   = [M:FAS3]CUR   (I_PLN-1)
  WMNEWVM  = [F:TMP1]NSPVAL

  #>>>>>>>>>>>>>>>
  For WI=0 To NBLIG1-1
    If ( [M:FAS3]NSPVAL (WI) <> 0 ) Then
      WIPLAN = [M:FAS3]DPRPLN (WI)
      If ( WIPLAN <> [F:TMP1]DPRPLN-1 ) Then
        # Devise du contexte
        WCDEV2   = [M:FAS3]CUR (WI)
        # Type de devise du contexte
        Call GET_CNX_FROM_PLAN ([M:FAS0]CPY, WIPLAN, WICONTEXTE) From GLOBIENS
        WITYPDEV = func GLOBIENS.GET_TYPDEV_CNX ([M:FAS0]CPY, WICONTEXTE)
        Call GET_CNX_DAT([M:FAS0]CPY,WICONTEXTE,WDDATE, WICODERET) From GLOBIENS
        If ( WDDAT2 = WDDATE(4) ) Then
          # Dates fin de periode identiques
          If ( WCDEV1 = WCDEV2 ) Then
            [M:FAS3]NSPVAL (WI) = [F:TMP1]NSPVAL
          Else
            # Devises diffÃĐrentes => Conversion avec WDDATE(4) comme date de rÃĐfÃĐrence,
            Call CONVERT3(WCDEV1, WCDEV2, WCDEV2, WITYPDEV, WDDATE(4), WMNEWVM, WDMONT2, 0, WIRET) From CPTSUB
            If ( WIRET = 0 ) Then
              Call GET_MNT_ARRONDI (WDMONT2, WCDEV2, WDMONT2 ) From GLOBIENS
            Else
              WDMONT2 = WMNEWVM
            Endif
            [M:FAS3]NSPVAL   (WI)     = WDMONT2
          Endif
        Endif
      Endif
    Endif
  Next
  #<<<<<<<<<<<<<
  # Maj des champs UPDx - FQ104286
  [M:FAS9]UPDUSR=GUSER
  [M:FAS9]UPDDAT=date$

  ACTMODIF=1
Return

#=====================================================================
# Unitaire : Permet de rÃĐafficher les masques de l'objet mÃĐtier si des modifs
#            y ont ÃĐtÃĐ reportÃĐes.
$REAF_ALIM_MASK
  Affzo [M:FAS3]
Return



#=====================================================================
# Unitaire / massif : Ouverture de tables annexes avant report du contenu des tables temporaires dans les tables de donnÃĐes
$OUVR_ALIM_TABLE

  Gosub OUVRE_TABLES
  Gosub ENTETE_TRACE_DETAIL
  If clalev([F:DEP2]) = 0 : Local File DEPREC       [DEP2] : Endif : # Amortissements

Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de donnÃĐes principale
$TMP1_ALIM_TABLE
  # Pour chaque bien de la table TMPMASFAS,
  # transfert des infos de TMPMASFAS [TMP1] dans la table FXDASSETS [MAS1]
  # Pas de rewrite : la mise Ã  jour est prise en charge par le traitement standard

Local Integer LCDRET, LREVTCREE
Local Char    LCDINT

  Read [DEP]DEP5=[F:TMP1]OBJREF;[F:TMP1]DPRPLN;[F:TMP1]FIYENDDAT;[F:TMP1]PERSTRDAT

  If (fstat) Then
    RMES  = mess(104,GML_MSGFAS,1)-"DEPREC"-mess(105,GML_MSGFAS,1)-"03"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF+"/"+num$([F:TMP1]DPRPLN)
    GOK   = 0
    Return
  Endif

  #==
  [F:DEPW] = [F:DEP]
  #==
  [F:DEPW]IML        = [F:TMP1]IML
  [F:DEPW]IMLRVE     = [F:TMP1]IMLRVE
  # FQ51385
  [F:DEPW]IMLTYP     = [F:TMP1]IMLTYP
  [F:DEPW]INTIMLTYP  = [F:TMP1]INTIMLTYP
  [F:DEPW]EXTIMLTYP  = [F:TMP1]EXTIMLTYP
  [F:DEPW]NSPVAL     = [F:TMP1]NSPVAL

  Gosub ECRIT_TRACE_DETAIL

  [F:DEPW]NBV  = [F:DEP]NBV - [F:DEPW]IML + [F:DEPW]IMLRVE

  #-1 -----------------------
  If ( ACTTYPGES=GTAMUNI or ( ACTTYPGES=GTAMMAS and dim(FLGSIM)>0 and FLGSIM=G_NON ) ) Then
    # GÃĐnÃĐration d'un ÃĐvÃĐnement que l'on soit en unitaire ou en massif
    #-2 -----------------------
    If ( [F:TMP1]IMLANNFLG = G_NON ) Then
      # GÃĐnÃĐrer ÃĐvÃĐnement
      LCDINT= "FASIML"+num$([F:DEPW]DPRPLN)
      Call GENER_EVE(GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,[F:TMP1]DATEFF,[0/0/0],LCDRET) From GENEVE
      If ( LCDRET > 20 )  Then
        If ( ACTTYPGES = GTAMUNI ) Then
          GERR=1 : GMESSAGE= mess(107,GML_MSGFAS,1) -num$(LCDRET)-'(F)' : Return
        Else
          RMES  = mess(107,GML_MSGFAS,1)-num$(LCDRET)-'(E)' : GOK   = 0 : Return
        Endif
      Endif
    #-2 -----------------------
    Else
      # Extourner ÃĐvÃĐnement
      LCDINT= "FASIML"+num$([F:DEPW]DPRPLN)
      Call ANNULE_EVE(GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,[F:TMP1]DATEFF,LREVTCREE,LCDRET) From GENEVE
      If ( LCDRET > 20 ) Then
        If ( ACTTYPGES = GTAMUNI ) Then
          GERR=1 : GMESSAGE= mess(107,GML_MSGFAS,1) -num$(LCDRET)-'(F)' : Return
        Else
          RMES  = mess(107,GML_MSGFAS,1)-num$(LCDRET)-'(F)' : GOK   = 0 : Return
        Endif
      Endif
    Endif
    #-2 -----------------------
  Endif
  #-1 -----------------------


  #-1 -----------------------
  If ( ACTTYPGES=GTAMUNI or (ACTTYPGES=GTAMMAS and dim(FLGSIM)>0 and FLGSIM=G_NON) ) Then

    [F:DEP] = [F:DEPW]
    [F:DEP]DEPSTA = GVML_SCNOCAL
    Rewrite [DEP]
    If !(fstat) Then
      GOK   = 1
    Else
      If ( ACTTYPGES = GTAMUNI ) Then
        GMESSAGE= mess(104,GML_MSGFAS,1)-"DEPREC"-mess(105,GML_MSGFAS,1)-"04"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:DEP]AASREF+"/"+num$([F:DEP]DPRPLN)
        GERR   = 1 : Return
      Else
        RMES    = mess(104,GML_MSGFAS,1)-"DEPREC"-mess(105,GML_MSGFAS,1)-"04"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:DEP]AASREF+"/"+num$([F:DEP]DPRPLN)
        GOK   = 0  : Return
      Endif
    Endif
  Endif
  #-1 -----------------------


  # Indicateur du bien sont mis "Ã  recalculer"
  [F:MAS1]FLGCLC                  = G_OUI
  [F:MAS1]FLGCNXCLC([F:DEP]CNX-1) = G_OUI

  [F:MAS1]UPDUSR=GUSER #FQ104286
  [F:MAS1]UPDDAT=date$ #FQ104286

Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire annexe dans la table de donnÃĐes annexe
$TPF1_ALIM_TABLE

Return

#=====================================================================
# Unitaire / massif : Traitement Ã  fin Report du contenu de la table temporaire annexe dans la table de donnÃĐes annexe
$END_ALIM_TABLE

  Gosub FERME_TRACE_DETAIL
  Gosub TOTAL_TRACE_DETAIL
  Gosub KILL_TRACE_DETAIL
Return

#=====================================================================
# Massif : Traitement Ã  fin de la maj directe
$CLOS_ALIM_TABLE

Local Integer LERROR

  If ( GOK = 1 ) Then
    # On n'est pas en erreur
    If ( dim(FLGSIM) > 0 & FLGSIM = G_NON ) Then
      Call RECALCUL_SOCIETE(LERROR)
      If ( LERROR <> 0 ) Then
        If ( LERROR = -3 ) Then
          Call ECR_TRACE_ERREUR([F:MAS1]CPY,"",[M:IML1]DPRPLN,G_NON,mess(103,GML_MSGCAL,1)-':'-mess(102,GML_MSGCAL,1)) From TRCPROCOM
        Else
          Call ECR_TRACE_ERREUR([F:MAS1]CPY,"",[M:IML1]DPRPLN,G_NON,mess(103,GML_MSGCAL,1)-':'-mess(104,GML_MSGCAL,1)) From TRCPROCOM
        Endif
        GOK  = 0
      Endif
    Endif
  Endif
Return


################################################################################
# GESTION DES TRACES
################################################################################
#-------------------------------------------------------------------------------
$GESTRACE
  Case TRTYP
    When 1
      # Ouverture
      Call OUVRE_TRACE ("DÃĐprÃĐciation massive",1) From TRACEABX3
    When 20
      # ParamÃĻtres Ã  appliquer
      Gosub PARAM_TRT_DEPREC
    When Default
  Endcase
Return

#-------------------------------------------------------------------------------
$PARAM_TRT_DEPREC

# ParamÃĻtres et valeurs relative au traitement de dÃĐprÃĐciation
Local Char CHAINE(150)

Global Char    GFMTDEV(10)              : # Format de reprÃĐsentation des montants

  GFMTDEV = func GLOBIENS.GET_FORMAT_DEVISE ([M:IML1]CUR, 'NzZ:', 3)
  #Fq-86764 "DÃĐprÃĐcier si Valeur marchÃĐ > VN (Param IMLNSPNBV)"
  CHAINE  = left$(mess(894,GML_MSGFAS,1)+string$(50, ' '), 52)+':'-mess(GIMLNSPNBV,1,1)
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  If ( [M:IML1]IMLANNFLG = G_OUI ) Then
    CHAINE  = left$(mess(442,GML_MSGFAS,1)+string$(30, ' '), 32) +':' -  left$(mess(441,GML_MSGFAS,1)+string$(30, ' '), 30)
  Else
    CHAINE  = left$(mess(442,GML_MSGFAS,1)+string$(30, ' '), 32) +':' -  left$(mess(148,GML_MSGFAS,1)+string$(30, ' '), 30)
  Endif
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  CHAINE  = left$(mess(152,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-mess([M:IML1]DPRPLN,GML_NPLAN,1)
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  CHAINE  = left$(mess(154,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-[M:IML1]CUR
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  CHAINE  = left$(mess(155,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-num$([M:IML1]DATSTRFIY)-'-'-num$([M:IML1]DATENDFIY)
  If ( [M:IML1]DATSTRPER <> [0/0/0] ) Then
    CHAINE += string$(5, ' ')+mess(156,GML_MSGFAS,1)-':'-num$([M:IML1]DATSTRPER)-'-'-num$([M:IML1]DATENDPER)
  Endif
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  CHAINE = left$(mess(153,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-[M:IML1]IASCGU
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
Return

#-------------------------------------------------------------------------------
$PARAM_TRT_DEPREC1

  CHAINE   = left$(mess(157,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-num$([M:IML1]DATEFF)
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  CHAINE   = left$(mess(158,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-mess([M:IML1]IMLTYP, GML_TYPDEPR,1)
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  CHAINE   = left$(mess(158,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-[M:IML1]INTIMLTYP
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  CHAINE   = left$(mess(159,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-[M:IML1]EXTIMLTYP
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  CHAINE   = left$(mess(146,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-format$(GFMTDEV,[M:IML1]NSPVAL)
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  CHAINE   = left$(mess(160,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-format$(GFMTDEV,[M:IML1]USEVAL)
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  CHAINE   = left$(mess(161,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-format$(GFMTDEV,[M:IML1]RCOVAL)
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  CHAINE   = left$(mess(147,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-format$(GFMTDEV,[M:IML1]NBV)
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  CHAINE   = left$(mess(148,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-format$(GFMTDEV,[M:IML1]IML)
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  If ( [M:IML1]IML <> [M:IML1]IMLCLC ) Then
    CHAINE = left$(mess(273,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-format$(GFMTDEV,[M:IML1]IMLCLC)
    Local Decimal LECART
    LECART = [M:IML1]IMLCLC - [M:IML1]IML
    CHAINE-= left$(mess(275,GML_MSGFAS,1)+string$(10, ' '), 10)+':'-format$(GFMTDEV,LECART)
    Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  Endif
  CHAINE   = left$(mess(149,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-format$(GFMTDEV,[M:IML1]IMLRVE)
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  If ( [M:IML1]IMLRVE <> [M:IML1]IMLRVECLC ) Then
    CHAINE = left$(mess(274,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-format$(GFMTDEV,[M:IML1]IMLRVECLC)
    Local Decimal LECART
    LECART = [M:IML1]IMLRVECLC - [M:IML1]IMLRVE
    CHAINE-= left$(mess(275,GML_MSGFAS,1)+string$(10, ' '), 10)+':'-format$(GFMTDEV,LECART)
    Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
  Endif
  CHAINE   = left$(mess(162,GML_MSGFAS,1)+string$(30, ' '), 32)+':'-format$(GFMTDEV,[M:IML1]IMLBLC)
  Call ECR_TRACE("",GTRC_PARAM, CHAINE,0,1) From TRACEABX3
Return

#-------------------------------------------------------------------------------
$DECLARE_TRACE_DETAIL
# DÃĐclaration des colonnes du tableau de compte rendu
                            # 1 : Largeur de la colonne
                            # 2 : Stockage des cumuls (c'est pour Ã§a que c'est dÃĐclarÃĐ en dÃĐcimal)

If  ( ACTTYPGES=GTAMUNI ) Then :  Return  : Endif

Global Decimal LCRCOL(0..10,1..2)
  Raz LCRCOL
  LCRCOL(0,1)  =  9        : # Nombre de colonnes
  LCRCOL(1,1)  =  3        : # SociÃĐtÃĐ
  LCRCOL(2,1)  = GLONAAS-2 : # Bien
  LCRCOL(3,1)  = 12        : # Valeur Bilan
  LCRCOL(4,1)  = 12        : # Valeur marchÃĐ
  LCRCOL(5,1)  = 12        : # Valeur nette
  LCRCOL(6,1)  = 12        : # DÃĐprÃĐciation
  LCRCOL(7,1)  = 12        : # Reprise
  LCRCOL(8,1)  = 12        : # Solde dÃĐprÃĐciation
  LCRCOL(9,1)  = 12        : # Plafond reprise


Global Decimal TCRCOL(0..10,1..2)
  # Totalisation des montants
  Raz TCRCOL
  TCRCOL(0,1)  =  9        : # Nombre de colonnes
  TCRCOL(1,1)  =  3        : # SociÃĐtÃĐ
  TCRCOL(2,1)  = GLONAAS-2 : # Bien
  TCRCOL(3,1)  = 12        : # Valeur Bilan
  TCRCOL(4,1)  = 12        : # Valeur marchÃĐ
  TCRCOL(5,1)  = 12        : # DÃĐprÃĐciation
  TCRCOL(6,1)  = 12        : # Reprise
  TCRCOL(7,1)  = 12        : # Solde dÃĐprÃĐciation
  TCRCOL(8,1)  = 12        : # Plafond reprise
  TCRCOL(9,1)  = 12        : # Valeur nette

  TCRCOL(3,2)  = 0         : # Valeur Bilan
  TCRCOL(4,2)  = 0         : # Valeur marchÃĐ
  TCRCOL(5,2)  = 0         : # DÃĐprÃĐciation
  TCRCOL(6,2)  = 0         : # Reprise
  TCRCOL(7,2)  = 0         : # Solde dÃĐprÃĐciation
  TCRCOL(8,2)  = 0         : # Plafond reprise
  TCRCOL(9,2)  = 0         : # Valeur nette

Local Integer N_ILINE
Global Integer LCRLINE : LCRLINE = LCRCOL(0,1)+1

  For N_ILINE = 1 To LCRCOL(0,1)
    LCRLINE += LCRCOL(N_ILINE,1)
  Next N_ILINE

Global Char    LCRCHAR(LCRLINE)         : # Chaine de compte rendu
Global Char    GSVCPY(GLONCPY)          : # SociÃĐtÃĐ planquÃĐe
  Raz GSVCPY
Return

#-------------------------------------------------------------------------------
$ENTETE_TRACE_DETAIL

  If  ( ACTTYPGES = GTAMUNI ) Then : Return : Endif

  If ( dim(GSVCPY) < 0 ) Then
    Gosub PARAM_TRT_DEPREC1
    Gosub DECLARE_TRACE_DETAIL
  Else
    LCRCHAR  = string$(LCRLINE, '*')
    Call ECR_TRACE(GSVCPY,GTRC_CRACTIO, LCRCHAR,0,1) From TRACEABX3
    LCRCHAR  = "*"
    LCRCHAR += left$(mess(143,GML_MSGFAS,1)+string$(LCRCOL(1,1), ' '), LCRCOL(1,1))+"*"
    LCRCHAR += left$(mess(144,GML_MSGFAS,1)+string$(LCRCOL(2,1), ' '), LCRCOL(2,1))+"*"
    LCRCHAR += left$(mess(145,GML_MSGFAS,1)+string$(LCRCOL(3,1), ' '), LCRCOL(3,1))+"*"
    LCRCHAR += left$(mess(146,GML_MSGFAS,1)+string$(LCRCOL(4,1), ' '), LCRCOL(4,1))+"*"
    LCRCHAR += left$(mess(148,GML_MSGFAS,1)+string$(LCRCOL(5,1), ' '), LCRCOL(5,1))+"*"
    LCRCHAR += left$(mess(149,GML_MSGFAS,1)+string$(LCRCOL(6,1), ' '), LCRCOL(6,1))+"*"
    LCRCHAR += left$(mess(150,GML_MSGFAS,1)+string$(LCRCOL(7,1), ' '), LCRCOL(7,1))+"*"
    LCRCHAR += left$(mess(151,GML_MSGFAS,1)+string$(LCRCOL(8,1), ' '), LCRCOL(8,1))+"*"
    LCRCHAR += left$(mess(147,GML_MSGFAS,1)+string$(LCRCOL(9,1), ' '), LCRCOL(9,1))+"*"
    Call ECR_TRACE(GSVCPY,GTRC_CRACTIO, LCRCHAR,0,1) From TRACEABX3
    LCRCHAR  = string$(LCRLINE, '*')
    Call ECR_TRACE(GSVCPY,GTRC_CRACTIO, LCRCHAR,0,1) From TRACEABX3
  Endif

Return


#-------------------------------------------------------------------------------
$ECRIT_TRACE_DETAIL

  Local Decimal WIMLCUM
  Local Decimal WIMLRVECUM

  If ( ACTTYPGES = GTAMUNI ) Then : Return : Endif

  If ( GSVCPY <> [F:DEPW]CPY ) Then
    If ( GSVCPY <> "" ) Then  :  Gosub FERME_TRACE_DETAIL  : Endif
    GSVCPY = [F:DEPW]CPY

    Gosub ENTETE_TRACE_DETAIL

    LCRCOL(3,2)  = 0        : # Valeur Bilan
    LCRCOL(4,2)  = 0        : # Valeur marchÃĐ
    LCRCOL(5,2)  = 0        : # DÃĐprÃĐciation
    LCRCOL(6,2)  = 0        : # Reprise
    LCRCOL(7,2)  = 0        : # Solde dÃĐprÃĐciation
    LCRCOL(8,2)  = 0        : # Plafond reprise
    LCRCOL(9,2)  = 0        : # Valeur nette
  Endif

  If ACTMET<>"END_APPL_DIRT" : # FQ72144
    LCRCHAR  = "*"
    LCRCHAR += left$([F:DEPW]CPY+string$(LCRCOL(1,1), ' '), LCRCOL(1,1))+"*"
    LCRCHAR += left$([F:DEPW]AASREF+string$(LCRCOL(2,1), ' '), LCRCOL(2,1))+"*"
    LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(3,1), ' ')+format$(GFMTDEV,[F:DEPW]DPRBAS), LCRCOL(3,1))+"*"
    LCRCOL(3,2) += [F:DEPW]DPRBAS
    LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(4,1), ' ')+format$(GFMTDEV,[F:DEPW]NSPVAL), LCRCOL(4,1))+"*"
    LCRCOL(4,2) += [F:DEPW]NSPVAL
    LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(5,1), ' ')+format$(GFMTDEV,[F:DEPW]IML), LCRCOL(5,1))+"*"
    LCRCOL(5,2) += [F:DEPW]IML
    LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(6,1), ' ')+format$(GFMTDEV,[F:DEPW]IMLRVE), LCRCOL(6,1))+"*"
    LCRCOL(6,2) += [F:DEPW]IMLRVE
    WIMLCUM    = ([F:DEPW]EXEIMLCUM + [F:DEPW]PERIMLCUM)
    WIMLRVECUM = ([F:DEPW]EXERVECUM + [F:DEPW]PERRVECUM )
    LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(7,1), ' ')+format$(GFMTDEV, WIMLCUM-WIMLRVECUM), LCRCOL(7,1))+"*"
    LCRCOL(7,2) += WIMLCUM-WIMLRVECUM
    LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(8,1), ' ')+format$(GFMTDEV,[F:DEPW]IMLRVELIM), LCRCOL(8,1))+"*"
    LCRCOL(8,2) += [F:DEPW]IMLRVELIM
    LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(9,1), ' ')+format$(GFMTDEV,[F:DEPW]NBV-[F:DEPW]IML+[F:DEPW]IMLRVE), LCRCOL(9,1))+"*"
    LCRCOL(9,2) += [F:DEPW]NBV-[F:DEPW]IML+[F:DEPW]IMLRVE
  Else
    LCRCHAR  = "*"
    LCRCHAR += left$([F:DEPW]CPY+string$(LCRCOL(1,1), ' '), LCRCOL(1,1))+"*"
    LCRCHAR += left$([F:DEPW]AASREF+string$(LCRCOL(2,1), ' '), LCRCOL(2,1))+"*"
    LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(3,1), ' ')+format$(GFMTDEV,0), LCRCOL(3,1))+"*"
    LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(4,1), ' ')+format$(GFMTDEV,0), LCRCOL(4,1))+"*"
    LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(5,1), ' ')+format$(GFMTDEV,IML_TRACE), LCRCOL(5,1))+"*"
    LCRCOL(5,2) += IML_TRACE
    LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(6,1), ' ')+format$(GFMTDEV,IMLRVE_TRACE), LCRCOL(6,1))+"*"
    LCRCOL(6,2) += IMLRVE_TRACE
    LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(7,1), ' ')+format$(GFMTDEV,0), LCRCOL(7,1))+"*"
    LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(8,1), ' ')+format$(GFMTDEV,0), LCRCOL(8,1))+"*"
    LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(9,1), ' ')+format$(GFMTDEV,IMLRVE_TRACE-IML_TRACE), LCRCOL(9,1))+"*"
    #LCRCOL(9,2) += ([F:DEPW]IML+[F:DEPW]IMLRVE)*-1 FQ103473
    LCRCOL(9,2) += IMLRVE_TRACE-IML_TRACE
  Endif

  Call ECR_TRACE([F:DEPW]CPY,GTRC_CRACTIO, LCRCHAR,0,1) From TRACEABX3

Return

#-------------------------------------------------------------------------------
$FERME_TRACE_DETAIL

  If ( ACTTYPGES = GTAMUNI ) Then : Return : Endif


  LCRCHAR = string$(LCRLINE, '*')
  Call ECR_TRACE(GSVCPY,GTRC_CRACTIO, LCRCHAR,0,1) From TRACEABX3

  LCRCHAR  = "*"
  LCRCHAR += left$(string$(LCRCOL(1,1), ' '), LCRCOL(1,1))+"*"
  LCRCHAR += left$(string$(LCRCOL(2,1), ' '), LCRCOL(2,1))+"*"
  LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(3,1), ' ')+format$(GFMTDEV,LCRCOL(3,2)), LCRCOL(3,1))+"*"
  LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(4,1), ' ')+format$(GFMTDEV,LCRCOL(4,2)), LCRCOL(4,1))+"*"
  LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(5,1), ' ')+format$(GFMTDEV,LCRCOL(5,2)), LCRCOL(5,1))+"*"
  LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(6,1), ' ')+format$(GFMTDEV,LCRCOL(6,2)), LCRCOL(6,1))+"*"
  LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(7,1), ' ')+format$(GFMTDEV,LCRCOL(7,2)), LCRCOL(7,1))+"*"
  LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(8,1), ' ')+format$(GFMTDEV,LCRCOL(8,2)), LCRCOL(8,1))+"*"
  LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(9,1), ' ')+format$(GFMTDEV,LCRCOL(9,2)), LCRCOL(9,1))+"*"
  Call ECR_TRACE(GSVCPY,GTRC_CRACTIO, LCRCHAR,0,1) From TRACEABX3

  LCRCHAR = string$(LCRLINE, '*')
  Call ECR_TRACE(GSVCPY,GTRC_CRACTIO, LCRCHAR,0,1) From TRACEABX3

  # Totalisations des montants
  TCRCOL(3,2) += LCRCOL(3,2)
  TCRCOL(4,2) += LCRCOL(4,2)
  TCRCOL(5,2) += LCRCOL(5,2)
  TCRCOL(6,2) += LCRCOL(6,2)
  TCRCOL(7,2) += LCRCOL(7,2)
  TCRCOL(8,2) += LCRCOL(8,2)
  TCRCOL(9,2) += LCRCOL(9,2)
Return

#-------------------------------------------------------------------------------
$TOTAL_TRACE_DETAIL
#  Totalisations des montants

  If ( ACTTYPGES=GTAMUNI ) Then : Return  : Endif

  LCRCHAR = string$(LCRLINE, '*')
  # FQ51385
  # Call ECR_TRACE(GSVCPY,GTRC_DBFINTRC, LCRCHAR,0,1) From TRACEABX3
  Call ECR_TRACE(GSVCPY,GTRC_DBFINTR, LCRCHAR,0,1) From TRACEABX3

  LCRCHAR  = "*"
  LCRCHAR += left$(string$(LCRCOL(1,1), ' '), LCRCOL(1,1))+"*"
  LCRCHAR += left$(string$(LCRCOL(2,1), mess(447,GML_MSGFAS,1)), LCRCOL(2,1))+"*"
  LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(3,1), ' ')+format$(GFMTDEV,TCRCOL(3,2)), LCRCOL(3,1))+"*"
  LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(4,1), ' ')+format$(GFMTDEV,TCRCOL(4,2)), LCRCOL(4,1))+"*"
  LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(5,1), ' ')+format$(GFMTDEV,TCRCOL(5,2)), LCRCOL(5,1))+"*"
  LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(6,1), ' ')+format$(GFMTDEV,TCRCOL(6,2)), LCRCOL(6,1))+"*"
  LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(7,1), ' ')+format$(GFMTDEV,TCRCOL(7,2)), LCRCOL(7,1))+"*"
  LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(8,1), ' ')+format$(GFMTDEV,TCRCOL(8,2)), LCRCOL(8,1))+"*"
  LCRCHAR += func GLOBIENS.AX3_RIGHT(string$(LCRCOL(9,1), ' ')+format$(GFMTDEV,TCRCOL(9,2)), LCRCOL(9,1))+"*"
  Call ECR_TRACE(GSVCPY,GTRC_DBFINTR, LCRCHAR,0,1) From TRACEABX3

  LCRCHAR = string$(LCRLINE, '*')
  # FQ51385
  # Call ECR_TRACE(GSVCPY,GTRC_DBFINTRC, LCRCHAR,0,1) From TRACEABX3
  Call ECR_TRACE(GSVCPY,GTRC_DBFINTR, LCRCHAR,0,1) From TRACEABX3
Return


#-------------------------------------------------------------------------------
$KILL_TRACE_DETAIL

  If dim(LCRCOL)  > 0 Then  : Kill LCRCOL   : Endif
  If dim(LCRLINE) > 0 Then  : Kill LCRLINE  : Endif
  If dim(LCRCHAR) > 0 Then  : Kill LCRCHAR  : Endif
  If dim(GSVCPY)  > 0 Then  : Kill GSVCPY   : Endif
  If dim(GFMTDEV) > 0 Then  : Kill GFMTDEV  : Endif
Return

################################################################################
$MFS_LIENS

  # Alimentation de la colonne "Valeur entrÃĐe HT" en fonction de la norme du plan
  If ( func GLOBIENS.GET_NORME_PLAN ([F:MFS]CPY,[M:IML1]DPRPLN) = GVML_NPIAS ) Then
    [M:MFS0]ETRNOT(nolign-1) = [M:MFS0]IASETRNOT(nolign-1) : # plan normÃĐ IAS/IFRS
  Else
    [M:MFS0]ETRNOT(nolign-1) = [M:MFS0]ACGETRNOT(nolign-1) : # plan normÃĐ CRC2002-10
  Endif
Return

################################################################################
$MFS_LIENS2

  # alimentation des totaux
  [M:MFS0]IMLTOT    = GIMLTOT
  [M:MFS0]IMLRVETOT = GIMLRVETOT
  [M:MFS0]IMLTOTORI = GIMLTOTORI
  [M:MFS0]IMLRVEORI = GIMLRVEORI
Return

################################################################################
# GESTION ECRAN CONTROLE DES MODIFICATIONS
################################################################################
#-------------------------------------------------------------------------------
$LOADPLN
#==============================================================#
# Si click sur un bien du tableau du Haut :                    #
# Cette action est appelÃĐe pour chaque enregistrement lu dans  #
# la table temporaire par plan pour l'objet mÃĐtier sur lequel  #
# on vient de cliquer.                                         #
# Alimenter ici les zones du tableau par plan spÃĐcifique Ã  l'  #
# action                                                       #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#

  # Chargement du masque tableau des infos "spÃĐcifiques" par plan suite Ã  clique sur bien
  # AppelÃĐe pour chaque enreg de la table temporaire
  # Masque: [M:MFS0]   Table: [F:TPF]   Ligne courante: nolign

  [M:MFS0]STRDPRDAT(nolign-1)  = [F:TPF]STRDPRDAT
  [M:MFS0]DPRBAS(nolign-1)     = [F:TPF]DPRBAS
  [M:MFS0]NSPVAL(nolign-1)     = [F:TPF]NSPVAL
  [M:MFS0]NBV(nolign-1)        = [F:TPF]NBV
  [M:MFS0]IML(nolign-1)        = [F:TPF]IML
  [M:MFS0]IMLRVE(nolign-1)     = [F:TPF]IMLRVE
  [M:MFS0]IMLCLC(nolign-1)     = [F:TPF]IMLCLC
  [M:MFS0]IMLRVECLC(nolign-1)  = [F:TPF]IMLRVECLC
  [M:MFS0]IMLBLC(nolign-1)     = [F:TPF]IMLBLC
  [M:MFS0]IMLRVELIM(nolign-1)  = [F:TPF]IMLRVELIM



Return

#-------------------------------------------------------------------------------
$SAVEPLN
#==============================================================#
# Cette action est appelÃĐe pour chaque enregistrement de la    #
# table temporaire Ã  mettre Ã  jour.                            #
# Alimenter ici les zones spÃĐcifiques Ã  l'action de la table   #
# temporaire par plan Ã  partir des zones du tableau par plan   #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#

  # MAJ table temporaire avec les infos "spÃĐcifiques" du masque tableau des infos par plan
  # AppelÃĐe pour chaque enreg de la table temporaire
  # Table: [F:TPF]   Masque: [M:MFS0]   Ligne courante: nolign

  [F:TPF]IML                   = [M:MFS0]IML(nolign-1)
  [F:TPF]IMLRVE                = [M:MFS0]IMLRVE(nolign-1)
Return


#-------------------------------------------------------------------------------
# Cette procÃĐdure permet de restaurer les dÃĐprÃĐciations de chaque BCO avec la
# valeur calculÃĐe par le programme, en particulier lorsque l'utilisateur
# ne souhaite pas conserver les modifications qu'il a pu faire lors du contrÃīle.
#-------------------------------------------------------------------------------
$RESTAURE_IMLCLC
  Local Integer N_I

  #>>>>>>>>>>>>>>>>>>>>
  For N_I = 1 To NBOBJ
    # Pour chaque BCO, on met Ã  jour la table [F:TPF] en initialisant IML Ã  IMLCLC
    Read[TMP1]MFS0=[M:MFS0]TRTNUM(N_I-1);[M:MFS0]OBJREF(N_I-1)
    If ( fstat ) Then
      # Erreur entrÃĐe sortie.
      RMES = mess(104,GML_MSGFAS,1)-"TMPPLNFAS"-mess(105,GML_MSGFAS,1)-"04"-mess(106,GML_MSGFAS,1)-num$([M:MFS0]TRTNUM(N_I-1))+"/"+[M:MFS0]OBJREF(N_I-1)
      GOK  = -1 : Return
    Endif
    [F:TMP1]IML = [F:TMP1]IMLCLC
    #==
    Rewrite [TMP1]
    #==
    If (fstat) Then
      Case fstat
        When 1
          # Erreur entrÃĐe sortie.
          RMES = mess(104,GML_MSGFAS,1)-"TMPPLNFAS"-mess(105,GML_MSGFAS,1)-"04"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[M:MFS0]OBJREF(N_I-1)
          GOK  = -1
        When 3
          # Tentative d'ÃĐcriture en double
          RMES = mess(129,GML_MSGFAS,1)-num$(NUMACT)+"/"+[M:MFS0]OBJREF(N_I-1)
          GOK  = 0
        When Default
      Endcase
      Return
    Endif
  Next N_I
  #<<<<<<<<<<<<<<<<<<<<

  # Restauration du cumul calculÃĐ
  [M:IML1]IML = [M:IML1]IMLCLC : Affzo [M:IML1]IML
Return

#-------------------------------------------------------------------------------
# Cette procÃĐdure permet de restaurer les reprises dÃĐprÃĐciations de chaque BCO avec la
# valeur calculÃĐe par le programme, en particulier lorsque l'utilisateur
# ne souhaite pas conserver les modifications qu'il a pu faire lors du contrÃīle.
#-------------------------------------------------------------------------------
$RESTAURE_IMLRVECLC
  Local Integer N_I

  #>>>>>>>>>>>>>>>>>>>>
  For N_I = 1 To NBOBJ
    # Pour chaque BCO, on met Ã  jour la table [F:TPF] en initialisant IMLRVE Ã  IMLRVECLC
    #Read [F:TPF]TPF0 = [M:MFS0]TRTNUM(N_I-1);[M:MFS0]OBJREF(N_I-1);[M:IML1]DPRPLN
    Read[TMP1]MFS0=[M:MFS0]TRTNUM(N_I-1);[M:MFS0]OBJREF(N_I-1)
    If fstat Then
      # Erreur entrÃĐe sortie.
      RMES = mess(104,GML_MSGFAS,1)-"TMPPLNFAS"-mess(105,GML_MSGFAS,1)-"04"-mess(106,GML_MSGFAS,1)-num$([M:MFS0]TRTNUM(N_I-1))+"/"+[M:MFS0]OBJREF(N_I-1)
      GOK  = -1 : Return
    Endif
    [F:TMP1]IMLRVE = [F:TMP1]IMLRVECLC
    #==
    Rewrite [TMP1]
    #==
    If (fstat) Then
      Case fstat
        When 1
          # Erreur entrÃĐe sortie.
          RMES = mess(104,GML_MSGFAS,1)-"TMPPLNFAS"-mess(105,GML_MSGFAS,1)-"04"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[M:MFS0]OBJREF(N_I-1)
          GOK  = -1
        When 3
          # Tentative d'ÃĐcriture en double
          RMES = mess(129,GML_MSGFAS,1)-num$(NUMACT)+"/"+[M:MFS0]OBJREF(N_I-1)
          GOK  = 0
        When Default
      Endcase
      Return
    Endif
  Next N_I
  #<<<<<<<<<<<<<<<<<<<<

  # Restauration du cumul calculÃĐ
  [M:IML1]IMLRVE = [M:IML1]IMLRVECLC : Affzo [M:IML1]IMLRVE
Return


################################################################################
# SOUS-PROGRAMMES
################################################################################
########################################
Funprog GET_RVARVE(PIML, PRVADEV)
Value Decimal PIML
Value Decimal PRVADEV
Local Decimal LARENDRE

  If ( PIML = 0 ) Then
    LARENDRE = 0
  Elsif ( PRVADEV = 0 ) Then
    LARENDRE = 0
  Elsif ( abs(PIML) >= abs(PRVADEV) ) Then
    LARENDRE = PRVADEV
  Elsif ( abs(PIML) < abs(PRVADEV) ) Then
    LARENDRE = PIML
  Endif
End LARENDRE

########################################
Subprog RECALCUL_SOCIETE(RERROR)
Variable Integer RERROR

  Local Integer LAUTORISEE  : # Utilisateur habilitÃĐ pour au moins un site de la sociÃĐtÃĐ

  If ( ACTTYPGES <> GTAMMAS ) Then : End : Endif

  Global Char  GFILTRE_FAS(250)
  # Local Char    TBFCY(GLONCPY)(1..func AFNC.ACTIV("SIT")) : # X3-89794
  Local Char    TABFCY(GLONFCY)(1..func AFNC.ACTIV("SIT")) : # X3-97068
  Local Integer TABCNT(0..G300MAX-1)

  Local  Integer LAUTORISEE  : # Utilisateur habilitÃĐ pour au moins un site de la sociÃĐtÃĐ
  Local  Integer N_I, LCNXCOR, N_E
  Local  Decimal LERROR

  Gosub OUVRE_TABLES
  GFILTRE_FAS  = "(OWNTYP<>GVML_TDANNUL and OWNTYP<>GVML_TDMODEL and "
  GFILTRE_FAS += "(ISSDAT=[0/0/0] or (ISSDAT<>[0/0/0] and EXTISSFLG=G_OUI)))"
  GFILTRE_FAS += "&IASCGU='"+[M:IML1]IASCGU+"'"
  RERROR      = 0

  #-------------------------------------------------------------------
  #-----------------    C   A   L   C   U   L      -------------------
  #-------------------------------------------------------------------

  #-- Ouverture ÃĐcran CALDIV
  If clalev([M:DIV])=0  : Local Mask CALDIV     [DIV]  :  Endif             : # Infos diverses
  If clalev([M:DIV2])=0  : Local Mask CALDIV2    [DIV2] :  Endif             : # Infos diverses FQ77877
  # Heure de dÃĐmarrage
  Global Integer G_TIMD     : G_TIMD = time
  #-- Traitement demandeur
  [M:DIV]TRTDEM    = "CALSOC"
  #--
  # Initialisation des constantes
  [M:DIV]DATNUL    = [0/0/0]
  [M:DIV]MNTNUL    = 0
  [M:DIV]DATFMT    = "D:" + GFMDAT4
  [M:DIV]CSTLVLMAX = 10
  [M:DIV]CSTFIYMAX = func AFNC.ACTIV("NFIY")   : # Annexe FQ-86764 var non initialisÃĐe Ã  tort
  [M:DIV]TRTLVL    = 0                    : # Niveau atteint dans le traitement
  [M:DIV]BDEBUG    = 2                    : # Debug

  [M:DIV]BFS1OPN = 0
  [M:DIV]BFS2OPN = 0
  [M:DIV]ERROR   = 0
  [M:DIV]LVL     = 0
  [M:DIV]PROPLN = ""                      : # Plan de production Ã  charger

  # RÃĐcupÃĐration du "Nom" des champs de l'ÃĐcran CALDEP dans le tableau [M:DIV]TDFN
  # Il est dimensionnÃĐ Ã  200 si dÃĐpassement, il faut modifier la dimension de [M:DIV]TDFN et LNBF ci-dessous
  Local Integer LNBF   : LNBF = 200
  Call CAL_LEC_CALDEP_FLD( LNBF, [M:DIV]TDFN, [M:DIV]NBF ) From GLOBB0
  If ([M:DIV]NBF > LNBF and GADONIX = 2) Then
    #-- DÃĐbordement du tableau contenant les champs de l'ÃĐcran  CALDEP dans la fonction ( CAL_LEC_CALDEP_FLD)
    Call ECR_TRACE(mess(151,GML_MSGCAL,1),1) From GLOBB0
    [M:DIV]NBF = 0
    Goto FIN_CALCULER_SOCIETES
  Endif

  # Evaluation du booleen Read avant Rewrite
  Local Integer RTRN
  Call CMP_CALDEP_DEPREC_EQ (RTRN) From GLOBB0
  [M:DIV]BLECMAJ = !(RTRN)
  If ( [M:DIV]BLECMAJ ) Then
    # DEPREC & CALDEP ne sont pas en phase
    Call ECR_TRACE(mess(150,GML_MSGCAL,1),1) From GLOBB0
  Endif


  N_E = 1
  #>>>>>>>>>>>>>>>>>>
  For N_I = 1 To [M:IML1]NBCPY

    [M:DIV]SOC    = [M:IML1]TCPY(N_I-1)             : # SociÃĐtÃĐ courante
    Raz          TABFCY
    LAUTORISEE = 0
    # Pour tous les Etablissements financier de la sociÃĐtÃĐ
    Filter [FCY] Where ( LEGCPY = [M:IML1]TCPY(N_I-1) and FINFLG = G_OUI)
    # >>>>>>>
    For [FCY]FCY1
      # Utilisateur habilitÃĐ Ã  la fonction pour le site
      #-3 -----------------------------
      If ( GUSRFCY(1) = "\" or find([F:FCY]FCY, GUSRFCY(1..GNBAUZ)) ) Then
        LAUTORISEE = 1
        # -- Etablissement
        # # X3-89794
        #TABFCY  (N_E-1)  = [F:FCY]FCY
        TABFCY  (N_E)  = [F:FCY]FCY
        N_E += 1
      Endif
      #-3 -----------------------------
    Next FCY1
    # >>>>>>>
    Filter [FCY]

    If (dim(G_CLCTRC)<0) Then :
      Global Integer G_CLCTRC : G_CLCTRC = 0  : # Pas d'ÃĐcriture dans trace
    Endif
    If ( LAUTORISEE ) Then
      Call GET_CNX_FROM_PLAN ([M:IML1]TCPY(N_I-1), [M:IML1]DPRPLN, LCNXCOR) From GLOBIENS
      TABCNT(0) = LCNXCOR
      Call TEMPON(mess(78,GML_MSGCAL,1)-[M:IML1]TCPY(N_I-1)) From GESECRAN
      #    ************** FQ88613
      Call CALCULER_SOCIETE([M:IML1]TCPY(N_I-1), TABFCY, TABCNT, G_NON, LERROR ) From GLOBB
      #    **************
      Call TEMPOFF() From GESECRAN
      If ( LERROR <> 0 ) Then
        RERROR = LERROR
        Break
      Endif
    Endif

  Next N_I
  #<<<<<<<<<<<<

$FIN_CALCULER_SOCIETES
  If (dim(G_TIMD)    >0) Then : Kill G_TIMD   : Endif
  If (dim(G_CLCTRC)  >0) Then : Kill G_CLCTRC : Endif
  # Fermeture ÃĐcran CALDIV
  If (clalev([M:DIV]))  Then : Close Local Mask [DIV]  : Endif : # Infos diverses
  If (clalev([M:DIV2]))  Then : Close Local Mask [DIV2]  : Endif : # Infos diverses FQ77877

  #-------------------------------------------------------------------
  #-----------------    C   A   L   C   U   L      -------------------
  #-------------------------------------------------------------------

  If ( dim(GFILTRE_FAS) > 0 ) Then
    # On teste si elle existe pour ÃĐventuellement la dÃĐtruire, mais si tout c'est bien passÃĐ, c'est
    # le calcul qui la dÃĐtruit dÃĻs qu'il a utilisÃĐ son contenu.
    Kill GFILTRE_FAS
  Endif

End

########################################
Funprog GET_CPY_IML()

Local Char LCPY(GLONCPY)
  LCPY = ""
  If ( find(G_OUI, [M:MHC]FLGCPY)<>0 ) Then
    LCPY = [M:MHC]CPY(find(G_OUI, [M:MHC]FLGCPY)-1)
  Endif
End LCPY


#-------------------------------------------------------------------------------
$CONTROL_IML_EXISTE
Local Char LSAASCGU(250)


  # -----------------------------------------
  CRITACT  = "OWNTYP <> GVML_TDANNUL and OWNTYP <> GVML_TDMODEL and "
  CRITACT += "([M:IML1]DATEFF=[0/0/0] or PURDAT <= [M:IML1]DATEFF) and "
  CRITACT += "(ISSDAT=[0/0/0] or (ISSDAT<>[0/0/0] and EXTISSFLG=G_OUI))"

  #-1 ----------------------------
  If ( ACTTYPGES=GTAMMAS ) Then
    If dim([M:IML1]IASCGU) < 0 Then
      CRITACT += "&2=1"
    Else
      If [M:IML1]IASCGU <> "" Then
        CRITACT += "&IASCGU=[M:IML1]IASCGU"
      Elsif [M:IML1]AASREF <> "" Then
        CRITACT += "&(AASREF=[M:IML1]AASREF or CMP=[M:IML1]AASREF)"
      Else
        # Comme Ã§a aucun bien ne risque d'ÃŠtre sÃĐlectionnÃĐ
        CRITACT += "&0=1"
      Endif
    Endif
  Endif
  #-1 ----------------------------

  #-1 ----------------------------
  If ([IML1]IASCGU <> "" ) Then
    LSAASCGU = "[FASW]IASCGU=[IML1]IASCGU"
  Else
    LSAASCGU = "([FASW]AASREF=[M:IML1]AASREF or [FASW]CMP=[M:IML1]AASREF)"
  Endif
  #-1 ----------------------------

  #==
  Link [DEPW] With [FASW]FAS0=AASREF As [IML]
  Filter [IML]
  #-1 ----------------------------
  If ( ACTTYPGES = GTAMMAS ) Then
      Filter [IML] Where DPRPLN=[M:IML1]DPRPLN
&            and FIYENDDAT=[F:FIS]DATENDFIY and PERENDDAT=[M:IML1]DATENDPER
&            and (IML<>0 or IMLRVE<>0)
&            and [FASW]OWNTYP<>GVML_TDANNUL and [FASW]OWNTYP<>GVML_TDMODEL
&            and ([FASW]ISSDAT=[0/0/0] or ([FASW]ISSDAT<>[0/0/0] and [FASW]EXTISSFLG=G_OUI))
&            and evalue(LSAASCGU)
  #-1 ----------------------------
  Else
      Filter [IML] Where [F:FASW]AASREF=[M:FAS0]AASREF
&          and DPRPLN=[M:IML1]DPRPLN
&          and FIYENDDAT=[F:FIS]DATENDFIY and PERENDDAT=[F:FIS2]DATENDPER([F:FIS2]INDCURPER-1)
&          and (IML<>0 or IMLRVE<>0)
&          and [FASW]OWNTYP<>GVML_TDANNUL and [FASW]OWNTYP<>GVML_TDMODEL
&          and ([FASW]ISSDAT=[0/0/0] or ([FASW]ISSDAT<>[0/0/0] and [FASW]EXTISSFLG=G_OUI))
&          and evalue(LSAASCGU)
  Endif
  #-1 ----------------------------
  Read [IML]First
  Filter [IML]
  If fstat > 2 Then
    [M:IML1]IMLANNFLG = G_NON : Affzo [M:IML1]IMLANNFLG : Diszo [M:IML1]IMLANNFLG
    Call ANNULE_DEPRECIATION(G_NON)
  Else
    [M:IML1]IMLANNFLG = G_NON : Affzo [M:IML1]IMLANNFLG : Actzo [M:IML1]IMLANNFLG
    Call ANNULE_DEPRECIATION(G_OUI)
  Endif
  #==

Return

################################################################################
# ECRAN : FASIML2
################################################################################
#-------------------------------------------------------------------------------
$MFS_ABANDON
  GIMLTOT    = GIMLTOTORI
  GIMLRVETOT = GIMLRVEORI

Return

#-------------------------------------------------------------------------------
MFS_CREATION
Return

#-------------------------------------------------------------------------------
$MFS_FIN
Local Integer LOK

Local Char    LFMTDEV(10)  : # Format de reprÃĐsentation des montants selon la devise

  If ( [M:IML1]IMLANNFLG = G_OUI ) Then
    [M:IML1]IML = 0
    [M:IML1]IMLCLC = 0
    Affzo [M:IML1]IML
    Return
  Endif

  If ( [M:IML1]IMLCLC <> 0 ) Then
    # DdÃĐprÃĐciation
    If ( abs([M:IML1]IMLCLC) <> abs([M:IML1]IML) ) Then
      # Cumul dÃĐprÃĐciation calculÃĐ diffÃĐrent de celui consÃĐcutif aux ajustements manuels
      LFMTDEV = func GLOBIENS.GET_FORMAT_DEVISE ([M:IML1]CUR, 'NzZ<:', 3)
      Call OUINON(mess(276,GML_MSGFAS,1)+'\'+
&                 mess(148,GML_MSGFAS,1)-':'-format$(LFMTDEV,[M:IML1]IML)+'\'+
&                 mess(273,GML_MSGFAS,1)-':'-format$(LFMTDEV,[M:IML1]IMLCLC)+'\'+
&                 mess(275,GML_MSGFAS,1)-':'-format$(LFMTDEV,[M:IML1]IML-[M:IML1]IMLCLC)+'\'+
&                 mess(277,GML_MSGFAS,1), LOK) From GESECRAN
      If ( LOK = G_NON ) Then
        Gosub RESTAURE_IMLCLC
        FIN = 1 : GERR = 1 : Return
      Endif
    Endif
  Elsif ( [M:IML1]IMLRVECLC <> 0 ) Then
    # Reprise de dÃĐprÃĐciation
    If ( abs([M:IML1]IMLRVECLC) <> abs([M:IML1]IMLRVE) ) Then
      # Cumul dÃĐprÃĐciation calculÃĐ diffÃĐrent de celui consÃĐcutif aux ajustements manuels
      LFMTDEV = func GLOBIENS.GET_FORMAT_DEVISE ([M:IML1]CUR, 'NzZ<:', 3)
      Call OUINON(mess(278,GML_MSGFAS,1)+'\'+
&                 mess(149,GML_MSGFAS,1)-':'-format$(LFMTDEV,[M:IML1]IMLRVE)+'\'+
&                 mess(274,GML_MSGFAS,1)-':'-format$(LFMTDEV,[M:IML1]IMLRVECLC)+'\'+
&                 mess(275,GML_MSGFAS,1)-':'-format$(LFMTDEV,[M:IML1]IMLRVE-[M:IML1]IMLRVECLC)+'\'+
&                 mess(277,GML_MSGFAS,1), LOK) From GESECRAN
      If ( LOK = G_NON ) Then
        Gosub RESTAURE_IMLRVECLC
        FIN = 1 : GERR = 1 : Return
      Endif
    Endif
  Endif
Return


########################################
Subprog CHGACTPARM()
#
# Ce paragraphe est dupliquÃĐ du traitement ACTCHGCRIT de TRCPROCOM car il faut en cas
# de changement de paramÃĻtre vider les tables temporaires.
#

 #-1 -----------------------
 If ( ACTSTATUS <> STA_DEBUT ) Then
   Local Integer POK,ERR,NBDLREC
   Local Char    MES
   # En unitaire on ne pose pas la question car le OK peut appliquer les paramÃĐtres mÃŠme s'il y a
   # eu un premier clic sur contrÃīler.
   #-2 -----------------------
   If ( ACTTYPGES = GTAMMAS ) Then
     # Massif :
     # ParamÃĻtre modifiÃĐ. Vous devrez utiliser le bouton CONTROLER pour appliquer les nouvelles valeurs.
     # Voulez-vous continuer ?
     MESSAGE=mess(433,GML_MSGFAS,1)+".\"+mess(434,GML_MSGFAS,1)+".\"+mess(432,GML_MSGFAS,1)+" ?"
     Call OUINON(MESSAGE,POK) From GESECRAN
     Case POK
       When G_OUI
         ACTSTATUS=STA_DEBUT
         #=> Unlock la population
         Call UNLOCKER(NUMACT,MES,ERR) From TRCPROCOM
         #=> Vider la table temporaire principale
         Call VIDER(NUMACT,TMPTAB,NBDLREC,ERR) From TRCPROCOM
         If ( ACTGESPLN=G_OUI ) Then
           #=> Vider la table temporaire par plan
           Call VIDER(NUMACT,TMPTABPLN,NBDLREC,ERR) From TRCPROCOM
         Endif
       When Default
         mkstat = 2
     Endcase
   Endif
   #-2 -----------------------
 Endif
 #-1 -----------------------
End


########################################
Subprog CHGACTPARM2()
#
# Ce paragraphe est dupliquÃĐ du traitement ACTCHGCRIT de TRCPROCOM car il faut en cas
# de changement de paramÃĻtre vider les tables temporaires.
#

  #-1 -----------------------
  If ( ACTSTATUS <> STA_DEBUT ) Then
    Local Integer POK,ERR,NBDLREC
    Local Char    MES
    #-2 -----------------------
    If ( ACTTYPGES = GTAMUNI ) Then
      MESSAGE=mess(502,GML_MSGFAS,1) + mess([M:IML1]DPRPLN,GML_NPLAN,1) + '.' + '\' + mess(503,GML_MSGFAS,1)
      Call OUINON(MESSAGE,POK) From GESECRAN
      Case POK
        When G_OUI
          ACTSTATUS=STA_DEBUT
          #=> Unlock la population
          Call UNLOCKER(NUMACT,MES,ERR) From TRCPROCOM
         #=> Vider la table temporaire principale
          Call VIDER(NUMACT,TMPTAB,NBDLREC,ERR) From TRCPROCOM
          If ( ACTGESPLN=G_OUI ) Then
            #=> Vider la table temporaire par plan
            Call VIDER(NUMACT,TMPTABPLN,NBDLREC,ERR) From TRCPROCOM
          Endif
        When Default
          mkstat = 2
      Endcase
    Endif
    #-2 -----------------------
  Endif
  #-1 -----------------------
End


######################################################################################
## GESTION DE LA RUBRIQUE IML sur l'ÃĐcran de controle (Programme SUBMFS)            ##
######################################################################################

#---- Avant saisie ---------------------
Subprog AS_IML_MFS(VALEUR)
Variable Decimal VALEUR

  Local Char    LFMTDEV(10)  : # Format de reprÃĐsentation des montants selon devise

  GIML_AV  = VALEUR

  If ( [M:IML1]IMLANNFLG = G_OUI ) Then
    # Si on est en annulation, on n'a le droit de rien faire !
    mkstat = 2 : End
  Endif
  #
  If ( [M:IML1]IMLCLC = 0 and [M:IML1]IMLRVECLC <> 0 ) Then
    # si on est en reprise, impossible de saisir une dÃĐprÃĐciation
    mkstat = 2 : End
  Endif
  #Fq-86764   If ( abs([M:MFS0]NSPVAL(nolign-1)) > 0 and abs([M:MFS0]NSPVAL(nolign-1)) >= abs([M:MFS0]NBV(nolign-1)) ) Then
  #==> si paramÃĻtre IMLNSPNBV est  positionnÃĐ Ã  oui, on ne tient pas compte de la valeur marchÃĐ
  #==> pour dire si un bien peut ÃŠtre dÃĐprÃĐciÃĐ
  If ( abs([M:MFS0]NSPVAL(nolign-1)) > 0 and abs([M:MFS0]NSPVAL(nolign-1)) >= abs([M:MFS0]NBV(nolign-1)) ) and
&          ( GIMLNSPNBV <> G_OUI )
    # Si une valeur marchÃĐ est indiquÃĐe et qu'elle est >= Ã  la valeur nette :
    #     on ne peut avoir de dÃĐprÃĐciation
    mkstat   = 2 : End
  Endif

  If ( [M:MFS0]IML(nolign-1) = [M:MFS0]IMLCLC(nolign-1) ) Then
    GBOUT1 = ""
  Else
    LFMTDEV = func GLOBIENS.GET_FORMAT_DEVISE ([M:IML1]CUR, 'NzZ<:', 3)
    GBOUT1 = GBOUT1 + '('+format$(LFMTDEV,[M:MFS0]IMLCLC(1-1))+')'
  Endif
End

#---- Bouton 1    ----------------------
Subprog B1_IML_MFS(VALEUR)
Variable Decimal VALEUR

  # Call CALCUL_IML ([M:MFS0]IMLCLC(1-1), [M:MFS0]IML(1-1)) : # GLE 02/02/05 FICHE 28107
  VALEUR = [M:MFS0]IMLCLC(nolign-1)
End

#---- AprÃĻs_modif ----------------------
Subprog AM_IML_MFS(VALEUR)
Variable Decimal VALEUR

  Local Char    LFMTDEV(10)              : # Format de reprÃĐsentation des montants

  LFMTDEV = func GLOBIENS.GET_FORMAT_DEVISE ([M:IML1]CUR, 'NzZ<:', 3)
  If ( abs(VALEUR) > abs([M:MFS0]NBVO(nolign-1)) ) Then
    # La dÃĐprÃĐciation ne peut excÃĐder la valeur nette origine
    GMESSAGE = mess(488,GML_MSGFAS,1)-'('+format$(LFMTDEV,[M:MFS0]NBVO(nolign-1))+')'
    GERR = 1 : mkstat = 2 : End
  Endif

  [M:MFS0]NBV(nolign-1) = [M:MFS0]NBVO(nolign-1) - VALEUR : Affzo [M:MFS0]NBV(nolign-1)

  If ( ACTTYPGES = GTAMUNI ) Then
    [M:MFS0]NSPVAL(nolign-1) = [M:MFS0]NBVO(nolign-1) - VALEUR
    Affzo [M:MFS0]NSPVAL(nolign-1)
  Endif

  GIMLTOT  = GIMLTOT  - GIML_AV + VALEUR
  [M:MFS0]IMLTOT  = GIMLTOT : Affzo [M:MFS0]IMLTOT

End

#########################################################################
## GESTION DE LA RUBRIQUE IMLRVE_MFS :
#########################################################################
#---- Avant saisie ---------------------
Subprog AS_IMLRVE_MFS(VALEUR)
Variable Decimal VALEUR

  Local Char    LFMTDEV(10)   : # Format de reprÃĐsentation des montants

  GIMLRVE_AV  = VALEUR

  If ( [M:IML1]IMLANNFLG = G_OUI ) Then
    # Si on est en annulation, on n'a le droit de rien faire !
    mkstat = 2 : End
  Endif

  If [M:IML1]IMLCLC <> 0 and [M:IML1]IMLRVECLC = 0 Then
    # si on est en dÃĐprÃĐciation, impossible de saisir une reprise
    mkstat = 2 : End
  Endif

  If [M:MFS0]IMLRVE(nolign-1) = [M:MFS0]IMLRVECLC(nolign-1) Then
    GBOUT1 = ""
  Else
    LFMTDEV = func GLOBIENS.GET_FORMAT_DEVISE ([M:IML1]CUR, 'NzZ<:', 3)
    GBOUT1 = GBOUT1 + '('+format$(LFMTDEV,[M:MFS0]IMLRVECLC(1-1))+')'
  Endif
End

#---- Bouton 1  -----------------------------------------------------------------##
Subprog B1_IMLRVE_MFS(VALEUR)
Variable Decimal VALEUR

  VALEUR = [M:MFS0]IMLRVECLC(nolign-1)
End

#---- AprÃĻs_modif ---------------------------------------------------------------##
Subprog AM_IMLRVE_MFS(VALEUR)
Variable Decimal VALEUR

Local Char    LFMTDEV(10)    : # Format de reprÃĐsentation des montants selon devise

  GIMLRVETOT  = GIMLRVETOT  - GIMLRVE_AV + VALEUR
  [M:MFS0]IMLRVETOT = GIMLRVETOT : Affzo [M:MFS0]IMLRVETOT

  LFMTDEV = func GLOBIENS.GET_FORMAT_DEVISE ([M:IML1]CUR, 'NzZ<:', 3)
  If ( abs(VALEUR) > 0 and [M:MFS0]IMLRVELIM(nolign-1) = 0 ) Then
    # Aucune reprise ne peut ÃŠtre saisie pour ce bien
    GMESSAGE = mess(270,GML_MSGFAS,1) : GERR = 1 : mkstat = 2 : End
  Elsif abs(VALEUR) > abs([M:MFS0]IMLRVELIM(nolign-1)) Then
    # Le montant de la reprise ne peut excÃĐder le plafond de reprise
    GMESSAGE = mess(269,GML_MSGFAS,1)-'('+format$(LFMTDEV,[M:MFS0]IMLRVELIM(nolign-1))+')' : GERR = 1 : mkstat = 2 : End
  Endif
End

