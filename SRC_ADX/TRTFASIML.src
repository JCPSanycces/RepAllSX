Subprog C_AASREF(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog AP_AASREF(VALEUR)
Variable Char    VALEUR()
End

################################################################################
Subprog AS_DPRPLN(VALEUR)
Variable Integer VALEUR

Local  Integer LISTE_MODE (2) : # liste des modes des plans qu'on veut conserver dans la combo
Local  Integer NB_PLN         : # Nombre de plans conservÃĐs dans la combo

  If ( ACTTYPGES = GTAMUNI ) Then
    # Unitaire
    If ( dim(GPARMPLN)<0 ) Then
      # Dans la combo des plans ne doivent figurer que les plans gÃĐrÃĐs selon la norme IAS/IFRS
      LISTE_MODE(0) = GVML_NPIAS   : # IAS
      LISTE_MODE(1) = GVML_NPCRC   : # CRC2002-10
      Call VIRE_PLN_STD_NOK ([M:FAS0]CPY, LISTE_MODE, NB_PLN) From GLOBIENS
      #Fq67577-Pologne
      If G_ACTKPL=G_OUI & [M:FPC]LEG="POL"
       Local Integer I_PLN
       For I_PLN=1 To [M:FAS3]NBLIG1
        If [M:FAS3]KMDRDEV(I_PLN-1)<>0
         GMENLOC(I_PLN)=1
        Endif
       Next I_PLN
      Endif
      #Fin-Pologne
    Else
      [M:IML1]DPRPLN = GPARMPLN
    Endif
  Else
    # Massif
    If ( find(G_OUI, [M:MHC]FLGCPY)<>0 ) Then
      # Si une sociÃĐtÃĐ est cochÃĐe
      LISTE_MODE(0) = GVML_NPIAS   : # IAS
      LISTE_MODE(1) = GVML_NPCRC   : # CRC2002-10
      Call VIRE_PLN_STD_NOK ([M:MHC]CPY(find(G_OUI, [M:MHC]FLGCPY)-1), LISTE_MODE, NB_PLN) From GLOBIENS
      If ( NB_PLN = 0 ) Then
          # Tous les plans sont standards aucun n'est normÃĐ pas de dÃĐprÃĐciation possible
          # Vos diffÃĐrents plans ne sont pas gÃĐrÃĐs dans un mode permettant la dÃĐprÃĐciation
          GMESSAGE = mess(408,GML_MSGFAS,1)
          mkstat = 0 : GERR = 2
      Endif
    Else
      GMENLOC(G301AUC) = 1
      If ([M:IML1]IASCGU <> "") Then
        # Si aucune sociÃĐtÃĐ n'est cochÃĐe : Traitement multi sociÃĐtÃĐ
        # On ne peut pas Ã  ce niveau filtrer les plans. On est obligÃĐ de laisser en choisir un,
        # et de contrÃīler ensuite s'il peut ÃŠtre pris ou pas !
        # En plus Ã§a sera plus performant.
        Gosub EFFACE_PLAN
      Else
      Endif
    Endif
  Endif
End

##-----------------------------------------------------------------------------------
## Recherche de toutes les sociÃĐtÃĐs ayant des biens dont l'UGT = UGT saisi
## Puis recherche de tous les plans normÃĐs (CRC200210 ou IAS) qui sont gÃĐrÃĐs par ces
## sociÃĐtÃĐs
##-----------------------------------------------------------------------------------
$EFFACE_PLAN

Local Char    WCCPY    : # SociÃĐtÃĐ courante
Local Integer N_I      : # Indice du plan
Local Integer LCONTEXT : # Contexte du plan
Local Integer I_PLN    : # Rang du plan dans le contexte

Local Integer B_NORME

  WCCPY  = ""
  B_NORME = 0

  If clalev([F:CNX])  = 0 : Local File CONTEXT     [CNX]  : Endif : # Contextes


  Filter [F:FAS] Where [F:FAS]IASCGU=[M:IML1]IASCGU
  #>1 >>>>>>>>>>>>>>>>
  For [F:FAS]
    #-2 ---------------------
    If ( [F:FAS]CPY <> WCCPY ) Then
      WCCPY  = [F:FAS]CPY
      # si un plan n'est pas normÃĐ ou n'est pas gÃĐrÃĐ par l'une des sociÃĐtÃĐs --> on le supprime de la combo
      # --------------------------
      #>3 >>>>>>>>>>>>>>>>
      For N_I = 1 To G301MAX
        Call GET_CNX_FROM_PLAN (WCCPY, N_I, LCONTEXT) From GLOBIENS : # A quel contexte appartient le plan ?
        #-4 ---------------------
        If ( LCONTEXT > 0 ) Then
          Read [CNX]CNX0=WCCPY;LCONTEXT : # Le contexte est-il gÃĐrÃĐ pour cette sociÃĐtÃĐ ?
          I_PLN=find(N_I,[F:CNX]PLNCAA)
          If ( I_PLN = 0 ) Then
            # Le plan n'est pas gÃĐrÃĐ pour ce contexte
            GMENLOC(N_I) = 1
          Else
            # Le plan n'est pas normÃĐ IAS/IFRS ou CRC2002-10
            If ( [F:CNX]PLNSTD(I_PLN-1) <> GVML_NPCRC and [F:CNX]PLNSTD(I_PLN-1) <> GVML_NPIAS ) Then
              GMENLOC(N_I) = 1
            Else
              B_NORME = 1
            Endif
          Endif
        Else
          # Le contexte (donc le plan) n'est pas gÃĐrÃĐ pour cette sociÃĐtÃĐ
          GMENLOC(N_I) = 1
        Endif
        #-4 ---------------------
      Next N_I
      #>3 >>>>>>>>>>>>>>>>
    Endif
    #-2 ---------------------
  Next
  #<1 <<<<<<<<<<<<<<
  Filter [FAS]

  If ( not B_NORME ) Then
    # OpÃĐration impossible : Aucun plan n'est normÃĐ IAS/IFRS ou CRC2002_10
    GMESSAGE = mess(628,GML_MSGFAS,1)
    mkstat = 0 : GERR = 2
  Endif

Return


########################################
Subprog AM_DPRPLN(VALEUR)
Variable Integer VALEUR

Local Char WCPY1, WCPY2
Local Char WCERRCPY
Local Integer LCNXCOR, BFIRST

  #If (GUSER = "MWA") Then : Dbgaff : Endif


  # prise en compte du changement de paramÃĻtre
  If ( ACTTYPGES=GTAMMAS ) Then
    Call CHGACTPARM
  Else
    Call CHGACTPARM2
  Endif


  # ------------------------------
  Call ACTION_BLOCK (ACB_EFFZO, "FASIML1", "NBCPY") From GLOBIENS
  [M:IML1]NBCPY = 0
  # ------------------------------

  #-1 -----------------------------
  If ( ACTTYPGES = GTAMUNI ) Then
    #-- Unitaire
    Call GET_CNX_FROM_PLAN ([M:FAS0]CPY, VALEUR, LCNXCOR) From GLOBIENS
    # Traitement cas mono sociÃĐtÃĐ
    Read [CNX]CNX0=[M:FAS0]CPY;LCNXCOR

    Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TECOURA
    Read [FIS]FIY0 Last
    Filter [FIS]
    [F:FIS2] = [F:FIS]

    # ContrÃīle que la pÃĐriode courante du plan du bien a ÃĐtÃĐ calculÃĐe
    If not func GLOBIENS.IS_PLN_CALCULATE([M:FAS0]CPY, [M:IML1]AASREF, LCNXCOR, VALEUR,
&                                          [F:FIS2]DATENDFIY, [F:FIS2]DATENDPER([F:FIS2]INDCURPER-1)) Then
      GMESSAGE  = mess(589,GML_MSGFAS,1) : GERR = 1 : mkstat = 2 : End
    Endif

    # AccÃĻs Ã  la pÃĐriode courante du plan du bien pour contÃīler s'il peut ÃŠtre dÃĐprÃĐciÃĐ
    Read [DEPW]DEP5=[M:IML1]AASREF;[M:IML1]DPRPLN;[M:IML1]DATENDFIY;[M:IML1]DATSTRPER
    If (!fstat) Then
      #Fq-86764 If ( [F:DEPW]NSPVAL <> 0 and abs([DEPW]NSPVAL) > abs([DEPW]NBV)  ) Then
      #==> si paramÃĻtre IMLNSPNBV est  positionnÃĐ Ã  oui, on ne tient pas compte de la valeur marchÃĐ
      #==> pour dire si un bien peut ÃŠtre dÃĐprÃĐciÃĐ
      If ( [F:DEPW]NSPVAL <> 0 and abs([DEPW]NSPVAL) > abs([DEPW]NBV)  ) and ( GIMLNSPNBV <> G_OUI )
        # ???????????? si valeur marchÃĐ <>0 et > Ã  sa valeur nette ne peut pas ÃŠtre dÃĐprÃĐciÃĐ
        [M:IML1]NBV       += [F:DEPW]NBV
        [M:IML1]IMLRVELIM += [F:DEPW]IMLRVELIM
        [M:IML1]IMLBLC    += [F:DEPW]IMLBLC
      Elsif  ( abs([F:DEPW]RVAAMT) > 0 ) Then
        # Un bien comptable ayant subi une rÃĐÃĐvaluation dans la pÃĐriode  ne peut ÃŠtre dÃĐprÃĐciÃĐ
        [M:IML1]NSPVAL = 0
        Diszo [M:IML1]NSPVAL
        Diszo [M:IML1]USEVAL
        GERR= 1 : GMESSAGE = mess(454,GML_MSGFAS,1) : zonsui = "[M:MHC]FLGCPY(find(G_OUI, [M:MHC]FLGCPY)-1)" : End
      Elsif  ( [F:DEPW]DPM = G_DPMCA ) Then
        # Un bien comptable amorti en mode "CA" ne peut pas ÃŠtre dÃĐprÃĐciÃĐ
        [M:IML1]NSPVAL = 0
        Diszo [M:IML1]NSPVAL
        Diszo [M:IML1]USEVAL
        GERR= 1 : GMESSAGE = mess(610,GML_MSGFAS,1) : zonsui = "[M:MHC]FLGCPY(find(G_OUI, [M:MHC]FLGCPY)-1)" : End
      Elsif ( [F:DEPW]ENDDPEFLG = G_OUI )  Then
        # Un bien comptable ayant sa dotation exercice  forcÃĐe ne peut ÃŠtre dÃĐprÃĐciÃĐ
        [M:IML1]NSPVAL = 0
        Diszo [M:IML1]NSPVAL
        Diszo [M:IML1]USEVAL
        GERR= 1 : GMESSAGE = mess(501,GML_MSGFAS,1) : zonsui = "[M:MHC]FLGCPY(find(G_OUI, [M:MHC]FLGCPY)-1)" : End
      Elsif ( [F:DEPW]STRDPRDAT > [M:IML1]DATENDPER ) Then
        # Date de dÃĐbut d'amortissement supÃĐrieure Ã  la date de fin pÃĐriode courante
        [M:IML1]NSPVAL = 0
        Diszo [M:IML1]NSPVAL
        Diszo [M:IML1]USEVAL
        GERR= 1 : GMESSAGE = mess(389,GML_MSGFAS,1) : zonsui = "[M:MHC]FLGCPY(find(G_OUI, [M:MHC]FLGCPY)-1)" : End
      Elsif (([M:FAS1]GACACN = GVML_NIENCOU or [M:FAS1]IASACN = GVML_NIENCOU) and [F:DEPW]DPM <> G_DPMSA) Then
        # Nature du bien "Immo en cours" et mode du plan <> "SA"
        [M:IML1]NSPVAL = 0
        Diszo [M:IML1]NSPVAL
        Diszo [M:IML1]USEVAL
        GERR= 1 : GMESSAGE = mess(604,GML_MSGFAS,1) : zonsui = "[M:MHC]FLGCPY(find(G_OUI, [M:MHC]FLGCPY)-1)" : End
      Endif
    Endif

    If (GERR = 1) Then : End : Endif

    [M:IML1]TCPY([M:IML1]NBCPY) = [F:CNX]CPY
    [M:IML1]NBCPY              += 1

  #-1 -----------------------------
  Else
    #-- Massif
    # Traitement cas multi sociÃĐtÃĐ
    # 1Â°) Regarder si toutes les sociÃĐtÃĐs (qui ont un bien sur cette UGT) gÃĻre le plan sÃĐlectionnÃĐ
    # 2Â°) Si oui, dans chaque sociÃĐtÃĐ :
    #     aÂ°) La devise de gestion du contexte correspondant doit ÃŠtre identique
    #     bÂ°) L'exercice courant doit ÃŠtre identique
    #     cÂ°) Soit aucun n'est dÃĐcoupÃĐ en pÃĐriode
    #     dÂ°) Soit tous le sont, et la pÃĐriode courante doit ÃŠtre la mÃŠme
    # Si tout Ã§a n'est pas vÃĐrifiÃĐ, le plan ne peut ÃŠtre choisi
    # -----------------------------------------------------------------------------------
    BFIRST    = G_OUI
    Gosub SET_CRITACT
    # >>>>>>>>>>>>>>>>>>>
    For [FAS]FAS1(1) Where evalue(CRITACT)
      #-2 -----------------------------
      If ( BFIRST = G_OUI ) Then
        BFIRST = G_NON
        WCPY1 = [F:FAS]CPY
        Call GET_CNX_FROM_PLAN ([F:FAS]CPY, VALEUR, LCNXCOR) From GLOBIENS
        Read [CNX]CNX0=[F:FAS]CPY;LCNXCOR
        If (fstat) Then
          GMESSAGE  = mess(143,GML_MSGFAS,1)-[F:FAS]CPY-':'-mess(168,GML_MSGFAS,1)-'"'+mess(VALEUR,GML_NPLAN,1)+'"'-mess(169,GML_MSGFAS,1)
          GERR  = 1 : mkstat = 2 : Break
        Endif
        # ------------------
        Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TECOURA
        Read [FIS]FIY0 Last
        Filter [FIS]

        [F:FIS2] = [F:FIS]
        Gosub CONTROL_CONTEXTE
        If (GERR = 1) Then : Break : Endif
      #-2 -----------------------------
      Else
        WCPY2 = [F:FAS]CPY
        WCERRCPY =  '\' + mess(446,GML_MSGFAS,1) + WCPY1 + ' & ' + WCPY2  + ')'
        Read [CNX1]CNX0=[F:FAS]CPY;LCNXCOR
        If (fstat) Then
          # Le plan doit ÃŠtre gÃĐrÃĐ pour qu'une dÃĐprÃĐciation puisse ÃŠtre rÃĐalisÃĐe
          GMESSAGE  = mess(143,GML_MSGFAS,1)-[F:FAS]CPY-':'-mess(168,GML_MSGFAS,1)-'"'+mess(VALEUR,GML_NPLAN,1)+'"'-mess(169,GML_MSGFAS,1)
          GERR = 1 : mkstat = 2 : Break
        Endif
        #Fq-86764 [F:FIS2] = [F:FIS1]
        [F:FIS2] = [F:FIS]

        Gosub CONTROL_CONTEXTE
        If (GERR = 1) Then : Break : Endif
        #-3 -----------------------------
        If ( [F:CNX1]CUR <> [F:CNX]CUR ) Then
          # DÃĐprÃĐciation multi-sociÃĐtÃĐ impossible pour ce plan
          # La devise des plan est incompatible entre le sociÃĐtÃĐs
          GMESSAGE  = mess(137,GML_MSGFAS,1)-':'-mess(138,GML_MSGFAS,1)  + WCERRCPY
          GERR=1: mkstat=2 : Break
        #-3 -----------------------------
        Else
          Filter [FIS1] Where CPY=[F:CNX1]CPY and CNX=[F:CNX1]CNX and STAFIY=GVML_TECOURA
          Read [FIS1]FIY0 Last
          Filter [FIS1]
          If ( [F:FIS1]DATSTRFIY <> [F:FIS]DATSTRFIY or [F:FIS1]DATENDFIY <> [F:FIS]DATENDFIY ) Then
            # DÃĐprÃĐciation multi-sociÃĐtÃĐ impossible pour ce plan
            # Les exercice courant sont diffÃĐrents
            GMESSAGE  = mess(137,GML_MSGFAS,1)-':'-mess(139,GML_MSGFAS,1) + WCERRCPY
            GERR= 1: mkstat=2: Break
          Else
            If ( [F:FIS1]DATSTRPER([F:FIS1]INDCURPER-1) <> [F:FIS]DATSTRPER([F:FIS]INDCURPER-1) ) Then
              # DÃĐprÃĐciation multi-sociÃĐtÃĐ impossible pour ce plan
              # La pÃĐriode courante est diffÃĐrente entre les sociÃĐtÃĐs
              GMESSAGE  = mess(137,GML_MSGFAS,1)-':'-mess(141,GML_MSGFAS,1) + WCERRCPY
              GERR=1: mkstat=2: Break
            Elsif ( [F:FIS1]DATENDPER([F:FIS1]INDCURPER-1) <> [F:FIS]DATENDPER([F:FIS]INDCURPER-1) ) Then
              # DÃĐprÃĐciation multi-sociÃĐtÃĐ impossible pour ce plan
              # La pÃĐriode courante est diffÃĐrente entre les sociÃĐtÃĐs
              GMESSAGE  = mess(137,GML_MSGFAS,1)-':'-mess(141,GML_MSGFAS,1) + WCERRCPY
              GERR=1: mkstat=2: Break
            Endif
          Endif
        Endif
        #-3 -----------------------------
      Endif
      #-2 -----------------------------
      [M:IML1]TCPY([M:IML1]NBCPY) = [F:FAS]CPY
      [M:IML1]NBCPY              += 1
    Next
    # <<<<<<<<<<<<<<<<<
    If ( BFIRST = G_OUI ) Then
      # La population est vide. Modifiez vos critÃĻres de sÃĐlection
      zonsui = "[M:IML1]IASCGU" : GMESSAGE  = mess(467,GML_MSGFAS,1) : GERR=2:  End
    Endif
  Endif
  #-1 -----------------------------


  If ( GERR = 1 ) Then :  End : Endif

  Call ACTION_BLOCK (ACB_AFFZO, "FASIML1", "NBCPY") From GLOBIENS
  [M:IML1]CUR       = [F:CNX]CUR
  [M:IML1]DATSTRFIY = [F:FIS]DATSTRFIY
  [M:IML1]DATENDFIY = [F:FIS]DATENDFIY
  [M:IML1]DATSTRPER = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
  [M:IML1]DATENDPER = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
  [M:IML1]DATEFF    = [M:IML1]DATENDPER
  [M:IML1]DPRPLN=VALEUR
  Affzo [M:IML1]DPRPLN
  Gosub CONTROL_IML_EXISTE
  If ( GERR = 1 ) Then :  End : Endif

  If ( [M:IML1]AASREF <> "" or [M:IML1]IASCGU <> "" ) Then
     Call ALIM_VN([M:IML1]AASREF,[M:IML1]IASCGU)
  Endif

  If ( VALEUR = G301CPT ) Then
    [M:IML1]IMLTYP = GML_TDEXCEPT
  Elsif ( VALEUR = G301IAS ) Then
    [M:IML1]IMLTYP = GML_TDEXPLOI
  Endif

End

#-------------------------------------------------------------------------------
$CONTROL_CONTEXTE
  If not ( func GLOBIENS.IS_UGT_CALCULATE
&        ([F:FIS2]CPY, LCNXCOR, [F:FAS]IASCGU, [F:FIS2]DATENDFIY, [F:FIS2]DATENDPER([F:FIS2]INDCURPER-1)) ) Then
    #Fq-86764 GMESSAGE  = mess(143,GML_MSGFAS,1)-[F:FIS2]CPY-':'-mess(165,GML_MSGFAS,1)-'"'
    # ==> le message de ne faisait pas apparaÃŪtre la sociÃĐtÃĐ en erreur
    GMESSAGE  = mess(143,GML_MSGFAS,1)-[F:WFAS]CPY-':'-mess(165,GML_MSGFAS,1)-'"'
    GMESSAGE += mess(LCNXCOR,GML_NCONTEXT,1)+'"'-mess(166,GML_MSGFAS,1)
    GERR = 1 : mkstat = 2
  Endif
Return


########################################
Subprog C_DPRPLN(VALEUR)
Variable Integer VALEUR

  #------------------------------------------------------------------------------------------
  # ContrÃīle de l'existence d'une dÃĐprÃĐciation dans la pÃĐriode
  # (cas oÃđ l'on arrive d'une ligne du plan d'amortissement ==> on ne passe pas en AM_DPRPLN
  #------------------------------------------------------------------------------------------
  If ( ACTTYPGES = GTAMUNI ) Then
    Read [DEP]DEP0 =[M:FAS0]AASREF;VALEUR;[M:IML1]DATENDFIY;[M:IML1]DATENDPER
    If (!fstat) Then
      If (abs([F:DEP]NBV) > 0) Then
        [M:IML1]NBV =  [F:DEP]NBV
      Endif
      If  (abs([F:DEP]IML) > 0)  Then
        Diszo [M:IML1]
        Actzo[M:IML1]IMLANNFLG
        If ( [M:IML1]IMLANNFLG <> G_OUI) Then
          GMESSAGE=mess(462,GML_MSGFAS,1) : GERR=1
          [M:IML1]NSPVAL = 0
          Diszo [M:IML1]NSPVAL
          Diszo [M:IML1]USEVAL
          Affzo [M:IML1]
        Endif
      Endif
    Endif
  Else
    If ( [M:IML1]IASCGU = "" ) Then
      # Lors d'un traitement massif de dÃĐprÃĐciation, l'unitÃĐ gÃĐnÃĐratice de trÃĐsorerie doit ÃŠtre saisi
      zonsui = "[M:IML1]IASCGU"
      GMESSAGE  = mess(591,GML_MSGFAS,1) : GERR = 2 :  End
    Endif
  Endif

End

################################################################################
Subprog AM_IMLANNFLG(VALEUR)
Variable Integer VALEUR



End

########################################
Subprog C_IMLANNFLG(VALEUR)
Variable Integer VALEUR

  If ([M:IML1]IASCGU <> "" ) Then
    If (func GLOBIENS.IS_CHAMP_ENABLE ("[M:IML1]IMLANNFLG", 0) = G_OUI) Then
      # Si le champ est saisissable, l'utilisateur n'a d'autre choix que de le cocher !
      If ( VALEUR = G_NON )  Then : GMESSAGE  = mess(170,GML_MSGFAS,1) : GERR = 1 : mkstat = 2 : Endif
      [M:IML1]IMLANNFLG = VALEUR : Affzo [M:IML1]IMLANNFLG
    Endif
  Else
    [M:IML1]IMLANNFLG = VALEUR : Affzo [M:IML1]IMLANNFLG
  Endif
End

################################################################################
Subprog AM_NSPVAL(VALEUR)
Variable Decimal VALEUR
Local Integer LOK

  #If (GUSER = "MWA") Then : Dbgaff : Endif
  GAUTORISNULL  = G_NON

  # prise en compte du changement de paramÃĻtre
  Call CHGACTPARM
  If ( mkstat = 0 ) Then
    Call GET_VALEUR_RECOUVRABLE(VALEUR, [M:IML1]USEVAL)
  Endif

  If ( ACTTYPGES = GTAMUNI ) Then
    If ( abs([M:IML1]RCOVAL) < abs([M:IML1]RSDVAL) ) Then
      # La valeur rÃĐsiduelle (x) va ÃŠtre remplacÃĐe par la valeur recouvrable (future valeur nette) (x) Confirmez-vous ?
      Call OUINON(mess(463,GML_MSGFAS,1)-num$([M:IML1]RSDVAL)-mess(464,GML_MSGFAS,1)-num$([M:IML1]NBV-[M:IML1]IML)+'\'+ mess(452,GML_MSGFAS,1),
&          LOK) From GESECRAN
      If (LOK=G_NON) Then
        GERR = 1 : mkstat = 2
      Else
        [M:IML1]RSDVAL  = [M:IML1]NBV - [M:IML1]IML
      Endif
    Endif
  Endif

End

########################################
Subprog C_NSPVAL(VALEUR)
#
# Controle Valeur marchÃĐ
#
Variable Decimal VALEUR

  [M:IML1]NSPVAL = VALEUR

  If ( ACTTYPGES = GTAMUNI ) Then
    If ( VALEUR < 0 and [M:IML1]NBV > 0 or
&        VALEUR > 0 and [M:IML1]NBV < 0    ) Then
      # Valeur invalide
      GMESSAGE  = mess(627,GML_MSGFAS,1)
      GERR = 1 : mkstat = 2
    Endif
  Endif

End

################################################################################
Subprog AM_USEVAL(VALEUR)
Variable Decimal VALEUR

  # prise en compte du changement de paramÃĻtre
  Call CHGACTPARM

  #If (GUSER = "MWA") Then : Dbgaff : Endif
  GAUTORISNULL = G_NON
End

########################################
Subprog C_USEVAL(VALEUR)
Variable Decimal VALEUR

Local    Integer LOK


  If (VALEUR = 0 and [M:IML1]NSPVAL = 0 and GAUTORISNULL  = G_NON) Then
    # Les valeurs 'marchÃĐ' et 'usage' sont Ã  0. La dÃĐprÃĐciation sera ÃĐgale Ã  la valeur nette. Confirmez-vous ?
    Call OUINON(mess(456,GML_MSGFAS,1)  +  '\' + mess(452,GML_MSGFAS,1), LOK) From GESECRAN
    If ( LOK = G_NON)
      # ParamÃĐtrage incomplet
      GMESSAGE  = mess(161,GML_MSGFASPR,1)
      GERR      = 1
      Disable GSTAOK
      Disable GSTABOU+1
    Else
      GAUTORISNULL  = G_OUI
      Enable GSTAOK
      Enable GSTABOU+1
    Endif
  Else
    [M:IML1]USEVAL = VALEUR
  Endif

  If ( ACTTYPGES = GTAMMAS ) Then
    If ( [M:IML1]IASCGU = "" ) Then
      # Lors d'un traitement massif de dÃĐprÃĐciation, l'unitÃĐ gÃĐnÃĐratice de trÃĐsorerie doit ÃŠtre saisi
      zonsui = "[M:IML1]IASCGU"
      GMESSAGE  = mess(591,GML_MSGFAS,1) : GERR = 2 :  End
    Endif
  Endif

  If ( ACTTYPGES = GTAMUNI ) Then
    If ( VALEUR < 0 and [M:IML1]NBV > 0 or
&        VALEUR > 0 and [M:IML1]NBV < 0    ) Then
      # Valeur invalide
      GMESSAGE  = mess(627,GML_MSGFAS,1)
      GERR = 1 : mkstat = 2
    Endif
  Endif

End

########################################
Subprog AP_USEVAL(VALEUR)
Variable Decimal VALEUR
Local Integer LOK

  # prise en compte du changement de paramÃĻtre
  Call CHGACTPARM
  If ( mkstat = 0 ) Then
    Call GET_VALEUR_RECOUVRABLE([M:IML1]NSPVAL, VALEUR)
  Endif

  If ( ACTTYPGES = GTAMUNI ) Then
    If ( abs([M:IML1]RCOVAL) < abs([M:IML1]RSDVAL) ) Then
      # La valeur rÃĐsiduelle (x) va ÃŠtre remplacÃĐe par la valeur recouvrable (future valeur nette) (x) Confirmez-vous ?
      Call OUINON(mess(463,GML_MSGFAS,1)- num$([M:IML1]RSDVAL ) - mess(464,GML_MSGFAS,1)- num$([M:IML1]NBV - [M:IML1]IML) + '\' + mess(452,GML_MSGFAS,1)  ,  LOK) From GESECRAN
      If ( LOK = G_NON ) Then
        GERR = 1 : mkstat = 2
      Else
        [M:IML1]RSDVAL  = [M:IML1]NBV - [M:IML1]IML
      Endif
    Endif
  Endif

End




#####################################################
#############   SOUS-PROGRAMMES   ###################
#####################################################

########################################
Subprog ALIM_VN(PBCO, PUGT)
#
#  Calcul de la valeur nette prÃĐsentÃĐe Ã  l'ÃĐcran
#
#  EntrÃĐe  : RÃĐfÃĐrence bien                     ( Unitaire : DÃĐprÃĐciation d'un bien )
#            UnitÃĐ gÃĐnratrice de trÃĐsorerie     ( Massif   : DÃĐprÃĐciation d'une UGT )
#
#  Remarque : le calcul de la valeur nette totale permettant de dÃĐterminer la dÃĐprÃĐciation
#  tient compte des biens dont la valeur marchÃĐ propre est > VN du bien
#
#
Value Char PBCO
Value Char PUGT


  # Si "Annulation dÃĐprÃĐciation"
  If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:IML1]IMLANNFLG", 0) = G_OUI ) Then : End : Endif

  [M:IML1]IMLMAX    = 0
  [M:IML1]NBV       = 0
  [M:IML1]IMLRVELIM = 0
  [M:IML1]IMLBLC    = 0

  # Traitement unitaire
  #- 1 ------------------------
  If ( PBCO <> "" ) Then
    Read [DEPW]DEP5=PBCO;[M:IML1]DPRPLN;[M:IML1]DATENDFIY;[M:IML1]DATSTRPER
    If (!fstat) Then
      [M:IML1]NBV         = [F:DEPW]NBV       : Affzo [M:IML1]NBV
      [M:IML1]IMLRVELIM   = [F:DEPW]IMLRVELIM : Affzo [M:IML1]IMLRVELIM
      [M:IML1]IMLBLC      = [F:DEPW]IMLBLC    : Affzo [M:IML1]IMLBLC
      [M:IML1]RSDVAL      = [F:DEPW]RSDVAL

      If ( [F:DEPW]NSPVAL <> 0 ) Then
        # Si la valeur marchÃĐ est renseignÃĐe :
        # Calcul de la valeur recouvrable Ã  partir de la valeur marchÃĐ
        # Proposition de mise Ã  jour de la valeur residuelle avec la valeur recouvrable
        # si la valeur recouvrable devient infÃĐrieure Ã  la valeur residuelle
        [M:IML1]NSPVAL = [F:DEPW]NSPVAL
        Call AM_NSPVAL([M:IML1]NSPVAL)

        Affzo [M:IML1]NSPVAL
        Actzo [M:IML1]NSPVAL
        Actzo [M:IML1]USEVAL
      Endif

      # Un bien comptable ayant subi une rÃĐÃĐvaluation dans la pÃĐriode  ne peut ÃŠtre dÃĐprÃĐciÃĐ
      If ( [F:DEPW]RVAAMT <> 0 ) Then
        [M:IML1]NSPVAL = 0
        GERR= 1: GMESSAGE = mess(424,GML_MSGFAS,1)
        Diszo [M:IML1]NSPVAL
        Diszo [M:IML1]USEVAL
      Endif

      # Un bien comptable amorti selon le mode "CA"  ne peut ÃŠtre dÃĐprÃĐciÃĐ
      If ( [F:DEPW]DPM = G_DPMCA ) Then
        [M:IML1]NSPVAL = 0
        GERR= 1: GMESSAGE = mess(610,GML_MSGFAS,1)
        Diszo [M:IML1]NSPVAL
        Diszo [M:IML1]USEVAL
      Endif

      # Un bien comptable ayant sa dotation exercice  forcÃĐe ne peut ÃŠtre dÃĐprÃĐciÃĐ
      If ( [F:DEPW]ENDDPEFLG = G_OUI )  Then
        [M:IML1]NSPVAL = 0
        GERR= 1 : GMESSAGE = mess(501,GML_MSGFAS,1)
        Diszo [M:IML1]NSPVAL
        Diszo [M:IML1]USEVAL
      Endif

      # Si le bien a un dÃĐbut d'amort. > Ã  date de fin de la pÃĐriode courante de l'exercice en cours
      If ( [F:DEPW]STRDPRDAT > [M:IML1]DATENDPER ) Then
        # Date de dÃĐbut d'amortissement supÃĐrieure Ã  la date de fin pÃĐriode courante
        [M:IML1]NSPVAL = 0
        GERR= 1: GMESSAGE = mess(389,GML_MSGFAS,1)
        Diszo [M:IML1]NSPVAL
        Diszo [M:IML1]USEVAL
      Endif

      # Si la Nature du bien "Immo en cours" et le mode du plan <> "SA"
      If (([M:FAS1]GACACN = GVML_NIENCOU or [M:FAS1]IASACN = GVML_NIENCOU) and [F:DEPW]DPM <> G_DPMSA) Then
        # Nature du bien "Immo en cours" et mode du plan <> "SA"
        [M:IML1]NSPVAL = 0
        GERR= 1: GMESSAGE = mess(604,GML_MSGFAS,1)
        Diszo [M:IML1]NSPVAL
        Diszo [M:IML1]USEVAL
      Endif
    Endif
  #- 1 ------------------------
  Else
    # Traitement massif UGT

    Gosub SET_CRITACT
    Filter [F:FAS] Where [F:FAS]IASCGU=PUGT &evalue(CRITACT)

    For [F:FAS]
      Read [DEPW]DEP5=[F:FAS]AASREF;[M:IML1]DPRPLN;[M:IML1]DATENDFIY;[M:IML1]DATSTRPER
      If (!fstat) Then
        If ( [F:DEPW]ENDDPEFLG = G_OUI ) Then
          # Un bien comptable ayant la dotation pÃĐriode forcÃĐe ne peut ÃŠtre dÃĐprÃĐciÃĐ
        Elsif  (abs([F:DEPW]RVAAMT) > 0) Then
          # Un bien comptable ayant subi une rÃĐÃĐvaluation dans la pÃĐriode  ne peut ÃŠtre dÃĐprÃĐciÃĐ
        Elsif  ([F:DEPW]DPM = G_DPMCA ) Then
          # Un bien comptable amorti selon le mode CA  ne peut ÃŠtre dÃĐprÃĐciÃĐ
        Elsif ( [F:DEPW]STRDPRDAT > [M:IML1]DATENDPER ) Then
          # Un bien avec dÃĐbut d'amort. > Ã  fin de pÃĐriode courante ne peut pas ÃŠtre dÃĐpreciÃĐ
        Elsif ( [F:DEPW]ENDDPEFLG = G_OUI ) Then
          # Un bien ayant une dotation exercice forcÃĐe ne peut pas ÃŠtre dÃĐpreciÃĐ
        Else
          #Fq-86764 If ( abs([F:DEPW]NSPVAL) > abs([F:DEPW]NBV) )  Then
          # If ( abs([F:DEPW]NSPVAL) > abs([F:DEPW]NBV) ) or ( GIMLNSPNBV = G_OUI )  Then
          If ( abs([F:DEPW]NSPVAL) > abs([F:DEPW]NBV) )  Then
            [M:IML1]IMLMAX      += [F:DEPW]NBV
          Endif
          [M:IML1]NBV         += [F:DEPW]NBV
          If ( [F:FAS]AASTYP <> GVML_TIGOODW ) Then
            [M:IML1]IMLRVELIM   += [F:DEPW]IMLRVELIM
          Endif
          [M:IML1]IMLBLC      += [F:DEPW]IMLBLC
          [M:IML1]RSDVAL      += [F:DEPW]RSDVAL
        Endif
      Endif
    Next
    Filter [FAS]
    Affzo [M:IML1]NBV
    Affzo [M:IML1]IMLBLC
    Affzo [M:IML1]IMLRVELIM
   Affzo [M:IML1]IMLMAX
  Endif
  #- 1 ------------------------

  Gosub DETERMINE_DEPRECIATION_REPRISE
End

########################################
Subprog GET_VALEUR_RECOUVRABLE(PMARCHE, PUSAGE)
#
#  Calcul de la valeur recouvrable ÃĐgale au max( valeur marchÃĐ, valeur d'usage ).
#  et actualisation ( dÃĐprÃĐciation ou reprise de dÃĐprÃĐciation ) en fonction de
#  la nouvelle valeur recouvrable.
#
#  EntrÃĐe  : Valeur marchÃĐ
#            Valeur d'usage
#  Sortie  : Valeur recouvrable
#            DÃĐprÃĐciation
#            Reprise de dÃĐprÃĐciation
#
#
Value Decimal PMARCHE
Value Decimal PUSAGE


  If ( abs(PMARCHE) > abs(PUSAGE) ) Then
    [M:IML1]RCOVAL = PMARCHE
  Else
    [M:IML1]RCOVAL = PUSAGE
  Endif
  Affzo [M:IML1]RCOVAL


  # Actualisation en fonction de la valeur recouvrable
  Raz  [M:IML1]IML, [M:IML1]IMLRVE
  If ( abs([M:IML1]NBV) > abs([M:IML1]RCOVAL) ) Then
    # DÃĐprÃĐciation : Valeur nette ramenÃĐe Ã  la valeur recouvrable
    [M:IML1]IML =  [M:IML1]NBV - [M:IML1]RCOVAL
  Else
    # Reprise de DÃĐprÃĐciation : Valeur nette ramenÃĐe Ã  la valeur recouvrable
    [M:IML1]IMLRVE =  [M:IML1]RCOVAL - [M:IML1]NBV
  Endif
  Affzo [M:IML1]IML, IMLRVE

  # RÃĐinitialisation de champs en cas de modification des paramÃĻtres
  Raz   [M:IML1]IMLREP, [M:IML1]IMLRVECLC, [M:IML1]IMLRVEBLC
  Affzo [M:IML1]IMLREP,         IMLRVECLC,         IMLRVEBLC

End

########################################
Subprog ANNULE_DEPRECIATION(OUINON)
#
# Grise ou dÃĐgrise les champs en fonction
# de l'annulation de la dÃĐprÃĐciation
#

Variable Integer OUINON

  #-1 --------------
  If ( OUINON = G_OUI ) Then
    # FQ51385
    [M:IML1]IMLTYP    = 0
    [M:IML1]INTIMLTYP = ""
    [M:IML1]EXTIMLTYP = ""
    [M:IML1]NSPVAL    = 0
    [M:IML1]USEVAL    = 0
    [M:IML1]RCOVAL    = 0
    [M:IML1]NBV       = 0
    [M:IML1]IML       = 0
    [M:IML1]IMLREP    = 0
    [M:IML1]IMLRVE    = 0
    [M:IML1]IMLBLC    = 0
    Call ACTION_BLOCK (ACB_AFFZO, "FASIML1", "DATEFF") From GLOBIENS
    # FQ51385
    Diszo [M:IML1]IMLTYP
    Diszo [M:IML1]INTIMLTYP
    Diszo [M:IML1]EXTIMLTYP
    Diszo [M:IML1]NSPVAL
    Diszo [M:IML1]USEVAL
    If ( ACTTYPGES = GTAMUNI ) Then
       # Ce bien a dÃĐjÃ  ÃĐtÃĐ dÃĐprÃĐciÃĐ dans la pÃĐriode : vous devez d'abord annuler cette dÃĐprÃĐciation
       GMESSAGE=mess(462,GML_MSGFAS,1) : GERR=1
    Endif
  #-1 --------------
  Else
    # FQ51385
    Actzo [M:IML1]IMLTYP
    Actzo [M:IML1]INTIMLTYP
    Actzo [M:IML1]EXTIMLTYP
    Actzo [M:IML1]NSPVAL
    Actzo [M:IML1]USEVAL
  Endif
  #-1 --------------
End


#================================================
$DETERMINE_DEPRECIATION_REPRISE
#
# Calcul la DeprÃĐciation ou la Reprise
# en ramenant la valeur nette et valeur recouvrable
# si la valeur nette est diminuÃĐe, il s'agit d'une dÃĐprÃĐciation.
# si la valeur nette est augmentÃĐe il s'agit d'une reprise de dÃĐprÃĐciation.
#
#

  If ( dim(GLAST_BCO) < 0 ) Then
    Global Char GLAST_BCO(GLONAAS)
  Endif

  If ( [M:IML1]IMLANNFLG = G_NON ) Then
    # DÃĐpreciation / Reprise dÃĐprÃĐciation
    Affzo [M:IML1]NBV
    Affzo [M:IML1]IMLRVELIM
    Affzo [M:IML1]IMLBLC
    If ( abs([M:IML1]NBV) < abs([M:IML1]RCOVAL) ) Then
      # Reprise de DÃĐprÃĐciation : Valeur nette ramenÃĐe Ã  la valeur recouvrable
      [M:IML1]IML     = 0
      [M:IML1]IMLRVE  = [M:IML1]RCOVAL - [M:IML1]NBV
    Else
      # DÃĐprÃĐciation : Valeur nette ramenÃĐe Ã  la valeur recouvrable
      [M:IML1]IML     = [M:IML1]NBV - [M:IML1]RCOVAL
      [M:IML1]IMLRVE  = 0
    Endif
  Else
    # Annulation DÃĐpreciation
    [M:IML1]IML     = 0
    [M:IML1]IMLRVE  = 0
  Endif
  Affzo [M:IML1]IML
  Affzo [M:IML1]IMLRVE

  [M:IML1]IMLCLC    = [M:IML1]IML
  [M:IML1]IMLRVECLC = [M:IML1]IMLRVE

  # FQ103473 : utilisation de [M:IML1]IMLREP ÃĐgalement pour la reprise de dÃĐprÃĐciation
  If [M:IML1]IMLRVE <> 0
    [M:IML1]IMLREP = [M:IML1]IMLRVE
  Else
    [M:IML1]IMLREP = [M:IML1]IML
  Endif
  #

Return

########################################
Subprog EXT_CANCEL_IML_DEP (PCLASSE, RERREUR)
#
#   Annule la dÃĐprÃĐciation effectuÃĐe sur la classe DEPREC PCLASSE ouverte
#
Value    Char    PCLASSE     : # Classe DEPREC ouverte
Variable Integer RERREUR     : # Erreur =  0  OK
                               #        =  1  Enregistrement DEPREC non trouvÃĐ
                               #        =  2  Enregistrement rÃĐÃĐcriture DEPREC
                               #        =  3  Enregistrement DEPREC non dÃĐprÃĐciÃĐ
                               #        > 20  Erreur dans le programme Erreur_EVE

Local Char    LCDINT
Local Integer LCDRET, LREVTCREE

    # Approche optimiste
    RERREUR = 0

    If ( evalue(PCLASSE+"IML") = 0 ) Then : RERREUR = 3 : End  : Endif

    Gosub CANCEL_IML

    If ( LCDRET > 20 ) Then : RERREUR = LCDRET : End : Endif
End

########################################
Subprog EXT_CANCEL_IML (PREF, PPLAN, PDTFNEXE, PDTFNPER, RERREUR)
#
#   Annule la dÃĐprÃĐciation effectuÃĐe sur le plan du bien passÃĐ en paramÃĻtre
#

Value    Char    PREF        : # RÃĐfÃĐrence Bien
Value    Integer PPLAN       : # Plan d'amortissement
Value    Date    PDTFNEXE    : # Date de fin de l'exercice courant
Value    Date    PDTFNPER    : # Date de fin de pÃĐriode courante

Variable Integer RERREUR     : # Erreur =  0  OK
                               #        =  1  Enregistrement DEPREC non trouvÃĐ
                               #        =  2  Enregistrement rÃĐÃĐcriture DEPREC
                               #        =  3  Enregistrement DEPREC non dÃĐprÃĐciÃĐ
                               #        > 20  Erreur dans le programme Erreur_EVE

Local Char    LCDINT, PCLASSE
Local Integer LCDRET, LREVTCREE

    # Approche optimiste
    RERREUR = 0

    # Ouverture du ficher DEPW en local
    Local File DEPREC [DEPW]
    PCLASSE = "[F:DEPW]"

    # Lecture DEPREC pÃĐriode courante
    Read [DEPW]DEP0=PREF;PPLAN;PDTFNEXE;PDTFNPER
    If ( fstat ) Then : RERREUR = 1 : End : Endif

    If ( [F:DEPW]IML = 0 ) Then : RERREUR = 3 : End  : Endif

    Gosub CANCEL_IML

    If ( LCDRET > 20 ) Then : RERREUR = LCDRET : End : Endif

    Rewrite [DEPW]
    If (fstat) Then : RERREUR = 2 : End : Endif

    # Fermeture DEPW en local
    Close File [DEPW]
End

$CANCEL_IML
    # -----------------------
    # Annulation dÃĐprÃĐciation
    # -----------------------
    Assign PCLASSE+"NBV"       With evalue(PCLASSE+"NBV") + evalue(PCLASSE+"IML")
    Assign PCLASSE+"IML"       With 0
    Assign PCLASSE+"IMLRVE"    With 0
    # FQ51385
    Assign PCLASSE+"IMLTYP"    With 0
    Assign PCLASSE+"INTIMLTYP" With ""
    Assign PCLASSE+"EXTIMLTYP" With ""

    # Extourner ÃĐvÃĐnement
    LCDINT= "FASIML"+num$(evalue(PCLASSE+"DPRPLN"))
    Call ANNULE_EVE(GVML_OMBIEN,evalue(PCLASSE+"CPY"),evalue(PCLASSE+"FCY"),evalue(PCLASSE+"AASREF"),0,LCDINT,
&                               evalue(PCLASSE+"PERENDDAT"),LREVTCREE,LCDRET) From GENEVE
Return

