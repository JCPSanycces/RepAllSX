##############################################################################################
##--------------------------------------------------------------------------------------------
##--------------------------------------------------------------------------------------------
##  TRAITEMENT MASSIF : La fonction FASIMLM permet d'inserer l'action FASIMLM dans le menu
##  L'action FASIMLM appelle la fenÃĻtre FASIMLM
##       - La fenÃĻtre FASIMLM appelle les ÃĐcrans MCFASCRI3, FASIML1, ASELOBJ et est liÃĐ au
##         traitement TRTFASIML
##--------------------------------------------------------------------------------------------
##  TRAITEMENT UNITAIRE : Le click droit sur une ligne Amortissement
##  L'action DÃĐprÃĐcier (Bouton 6 sur la variable de bas de tableau NBLIG1)
##  L'etiquette B6_NBLIG1 de SUBFAS  appelle le programme TRTFASIML
##--------------------------------------------------------------------------------------------
##  TRAITEMENT COMMUN MASSIF ET UNITAIRE
##       - Le traitement TRTFASIML
##              PARAM (1) = GTAMASS
##              PARAM (2) = "FASIMLM"
##       - Le bouton CONTROLER appelle le traitement SUBMFS
##              - le traitement SUBMFS affiche l'ÃĐcran FASIML2
##--------------------------------------------------------------------------------------------
## GÃĐnÃĐralitÃĐs traitement
## $ACTION        : Recoit des actions du superviseur mais aussi du programmme SUBMFS
## $INIT          : func GLOBIENS.GET_TRTMOD_NAM(): RÃĐcupÃĻre 'TRCPROACT' dans TRTMODACT
## $OK & $EXEC    :  Unit/massif
##    - TRTFASIML appelle le traitement TRCPROACT  (Gosub ACTION From =TRTMODACT)
##      - TRCPROACT appelle le traitement TRMPROACT ou TRUPROACT suivant le paramÃĻtre PARAM(1)
##        - TRMPROACT appelle TRCPROCOM: CritÃĻre de sÃĐlect,charge population de bien Ã  traiter
##          - TRCPROCOM appelle diffÃĐrentes fonctions de TRTFASIML. Exemple :
##             - ACTTRTACT=ACTTRTPRE+"T"+ACTMETNAM (ACTTRTPRE = "TR" et ACTMETNAM=PARAM(2))
##             - ACTMET="MAS1_CONTROLE"
##             - Gosub ACTMET From =ACTTRTACT
## $ACTMET        : Dispatche les actions mÃĐtiers envoyÃĐes depuis TRCPROCOM
##--------------------------------------------------------------------------------------------
## $CONTROLE : controle de cohÃĐrence des infos saisie
##--------------------------------------------------------------------------------------------
## Traitement Unitaire & Massif
## $SET_CRITACT   : Unit/massif: Ajoute critÃĻres suppl Ã  appliquer Ã  population Ã  sÃĐlectionner
## $OUVR_LOCK     : Unit/massif: Ouvre les tables utilisÃĐes ds MAS1_CONTROLE & MAS1_LOCK_AUTRE
## $OUVR_ALIM_TMP1: Unit/massif: Sert Ã  ouvrir des tables utilisÃĐes dans MAS1_ALIM_TMP1
##                Gosub $DETERMINE_DEPRECIATION_REPRISE
## $MAS1_ALIM_TMP1: Unit/massif : SI CONTROLE : Chargement de la population en table tempo.
##                AppelÃĐ par TRCPROCOM (qui boucle sur les biens selectionnÃĐs)
##                Trait un bien  ([F:MAS1]AASREF)
##                appelle $CALCUL_DEPRECIATION            :  Alimente [F:DEPW] pour un bien
##                Write [TPF1] : Charge le rÃĐsultat des amortissements dans la table tempo.
##                Write [TMP1] : Charge table temp TMPFASMAS [F:TMP1] avec bien compt [F:MAS1]
## $END_ALIM_TMP1 : Unit/massif : Traitement Ã  fin de chargement de table temporaire
##                S'il reste un reliquat (+ ou -),on le rÃĐparti sur le dernier bien dÃĐprÃĐciÃĐ
##
## $OUVR_ALIM_TABLE: Unit/massif:Ouv tables annexes avant report tables temp ds Tables donnÃĐes
## $TMP1_ALIM_TABLE: Unit/massif:Report infos table temp princip dans table donnÃĐes princip
##   Pour chaque bien de TMPMASFAS, transf infos de TMPMASFAS[TMP1] ds table FXDASSETS[MAS1]
##   Pas de rewrite : la mise Ã  jour est prise en charge par le traitement standard
## $TPF1_ALIM_TABLE: Unit/massif: Report infos table temp annexe ds table de donnÃĐes annexe
##                Rewrite [DEP] + Call GENER_EVE
## $END_ALIM_TABLE: Unit/massif:Trt fin Report infos table temp annexe ds table donnÃĐes annexe
##--------------------------------------------------------------------------------------------
## Traitement Unitaire uniquement
## $TMP1_ALIM_MASK : Unit : alimentation des champs de l'objet (ex : Ecran FAS)
## REAF_ALIM_MASK  : Unit : affzo de l'ÃĐcran objet
##--------------------------------------------------------------------------------------------
##--------------------------------------------------------------------------------------------
## Traitement Massif uniquement
## $MAS1_CONTROLE  : Massif : Permet d'exclure certains biens de la selection
## $OUVR_APPL_DIRT : Massif : Sert Ã  ouvrir des tables utilisÃĐes dans MAS1_APPL_DIRT
## $MAS1_APPL_DIRT : Massif : Traitmt avec maj tables donnÃĐes : maj directe (si pas CONTROLE)
##                     Gosub CALCUL_DEPRECIATION  + Rewrite [DEP]  + Call GENER_EVE
## $END_APPL_DIRT  : Massif : Traitmt Ã  fin maj directe (affectÃĐ le delta s'il y en a)
##                     Gosub FERME_TRACE_DETAIL
## $MAS1_LOCK_MONTANT : Massif : Sert Ã  alimenter les zones montant de TMPMASLCK OBJAMT
## $CLOS_APPL_DIRT : Massif : Traitement Ã  fin de la maj directe : Call RECALCUL_SOCIETE
## $CLOS_ALIM_TABLE: Massif : Traitement Ã  fin de la maj directe : Call RECALCUL_SOCIETE
##--------------------------------------------------------------------------------------------
## Ecran de contrÃīle
## $LOADPLN :Charge tableau plan Ã  partir de [F:TPF]: AppelÃĐ pour chaque enreg de tab temp
## $SAVEPLN :Charge [F:TPF] Ã  partir tableau plan: AppelÃĐ pour chaque enr de tab temp modifiÃĐ
## $MFS_FIN : traitement en fin de maj sur ecran de contrÃīle
##--------------------------------------------------------------------------------------------
##--------------------------------------------------------------------------------------------
## SOUS-PROGRAMMES appartenant a un autre source et appelÃĐ par ce source
##  Call AM_FLGCPY([M:MHC]FLGCPY(nolign-1)) From TRMPROACT (TRMPROACT : Action mÃĐtier massive)
##  Call ACTCHGCRIT() From TRCPROCOM (TRCPROCOM : trt communs aux modÃĻles massif et unitaire)
##--------------------------------------------------------------------------------------------
##--------------------------------------------------------------------------------------------
## Trace
## $GESTRACE  :    Gosub PARAM_TRT_DEPREC
##--------------------------------------------------------------------------------------------
################################################################################




#==============================================================#
#            Gestion de l'action mÃĐtier FASIML                 #
#==============================================================#

######################################################################
# Etiquettes modÃĻle Traitement standard / saisie fenÃŠtre / GOBJET
######################################################################

$ACTION
  If ( dim(ORIACT)>0 & ORIACT<>"" ) Then
    # Cas ACTION du modÃĻle massif/unitaire
    Case ORIACT
      When "TRTOBJ"
        # ACTION appelÃĐe par le SUBMFS (traitement de l'ÃĐcran de controle)
        Case ACTION
          When "CREATION"  : Gosub MFS_CREATION
          When "FIN"       : Gosub MFS_FIN
          When "ABANDON"   : Gosub MFS_ABANDON
          When "LIENS"     : Gosub MFS_LIENS
          When "LIENS2"    : Gosub MFS_LIENS2
          When Default
       Endcase
     When Default
   Endcase
  Else
    # Cas ACTION Stantard X3

    Case ACTION
      When "INIT_DIA"      : Gosub INIT_DIA
      When "INIT"          : Gosub INIT
      When "AVANT_PAR"     : Gosub AVANT_PAR
      When "OUVRE_BATCH"   : Gosub OUVRE_BATCH
      When "OUVRE"         : Gosub OUVRE
      When "DEBUT"         : Gosub DEBUT
      When "APRES_MODIF"   : Gosub APRES_MODIF
      When "SETBOUT"       : Gosub SETBOUT
      When "AVANT_BOUTON"  : Gosub AVANT_BOUTON : # FQ101395
      When "BOUTON"        : Gosub BOUTON

      When "AP_CHOIX"      : Gosub AP_CHOIX
      When "ABANDON"       : Gosub ABANDON
      When "END"           : Gosub END_BOITE
      When "AVANT_OK"      : Gosub AVANT_OK     : # FQ101395
      When "OK"            : Gosub OK
      When "ABA"           : Gosub ABA
      When "FIN"           : Gosub FIN
      When "CONTROLE"      : Gosub CONTROLE
      When "SEL_LISTE"     : Gosub SEL_LISTE

      When "EXEC"          : Gosub EXEC
      When "TERMINE"       : Gosub TERMINE
      When "SORTIE"        : Gosub SORTIE
    Endcase
  Endif
Return


################################################################################
################################################################################

#=======================================
$OUVRE_BATCH
  # Massif - Batch : Saisie ParamÃĻtres & ExcÃĐcution
  #FQ-64915 Gosub ACTION From =TRTMODACT
  Gosub OUVRE_TABLES
Return

#=======================================
$INIT_DIA
  # Massif - Batch : Saisie paramÃĻtres
  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT
Return

#=======================================
$INIT
  # Massif - Interactif
  # Massif - Batch       : ExÃĐcution
 Global Integer GCONTROLE
 GCONTROLE = G_OUI
  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT
  #FQ-64915
  If GSERVEUR Then
    Gosub CREE_GLOBTRT
  Endif

Return

#=======================================
$AVANT_PAR
  # Massif - Interactif
  # Massif - Batch       : Execution
  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT
  # Ouverture des masques de la fenÃŠtre de l'action massive pour pouvoir les garder jusqu'Ã 
  # EXEC - Ouverture manuelle des masques de la fenÃŠtre.
  Local Char WINACT : WINACT = ACTMETNAM+"M"
  Local Integer I_MSK
  If !clalev([F:AWI]) : Local File AWINDOW : Endif
  If !clalev([F:AMK]) : Local File AMSK    : Endif
  Read [AWI]AWI0=WINACT
  If not (fstat) Then
    Local Mask =[F:AWI]MSKENT
    For I_MSK=0 To [F:AWI]NBMSK
      Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
      Local Mask =[F:AMK]CODMSK
    Next I_MSK
  Endif
Return

#=======================================
$OUVRE
  # Unitaire
  # Massif - Interactif
  # Massif - Batch : Saisie ParamÃĻtres & ExcÃĐcution

  #FQ-64915
  If !GSERVEUR
    Gosub CREE_GLOBTRT
  Endif

  # Lorsque l'action "DÃĐprÃĐcier" est lancÃĐe depuis une ligne de plan FAS3
  # on rÃĐcupÃĻre ici le param(6) de l'action FASIML qui va servir Ã 
  # alimenter le champ DPRPLN de [IML1] et on le sauvegarde dans la
  # variable GPARMPLN
  If ( dim(PARAM(6))>0 and PARAM(6)<> "" ) Then
    Global Integer GPARMPLN
    GPARMPLN=val(PARAM(6))
  Endif

  If ( dim(TRTMODACT) < 0 ) Then
    Global Char TRTMODACT
    TRTMODACT = func GLOBIENS.GET_TRTMOD_NAM()
  Endif
  Gosub ACTION From =TRTMODACT

  Gosub OUVRE_TABLES
Return

#=FQ-64915 ====================================================================
$CREE_GLOBTRT
  #==> DÃĐclaration globales nÃĐcessaires Ã   la fonction

  Global Integer GIABANDON

  Global Integer GCNX
  Global Char    GCPY
  Global Decimal GNBVO
  Global Integer GCCLFLG
  Global Integer GLOK
  Global Integer GINDCURPER

  Global Integer GIML_NOLIGN
  Global Integer GAUTORISNULL     : # Val.marchÃĐ et val.d'usage = 0 acceptÃĐ par utilisateur (OUI/NON)
  Global Decimal GIMLTOT
  Global Decimal GIML_AV
  Global Decimal GIMLRVE_AV
  Global Decimal GIMLRVETOT
  Global Decimal GIMLTOTORI
  Global Decimal GIMLRVEORI

  GAUTORISNULL  = G_NON
  GIMLTOT       = 0
  GIMLRVETOT    = 0
  GIMLTOTORI    = 0
  GIMLRVEORI    = 0
  GIABANDON     = G_NON

Return
#=======================================
$DEBUT
  # Unitaire
  # Massif - Interactif
  # Massif - Batch : Saisie ParamÃĻtres & ExcÃĐcution

Local Integer LCDRET, CRETOUR
Local Char    LMESSAGE
Local Integer NBPLAN
Local Integer LOK
Local Integer LCNX

  If !GBATCH : Raz [M:IML1] : Endif #gbo-fq64915

  #- 1 ---------------------
  If ( ACTTYPGES=GTAMUNI )

    # Traitement unitaire

    [M:IML1]AASREF = [M:FAS0]AASREF
    Affzo [M:IML1]AASREF
    Diszo [M:IML1]AASREF
    Diszo [M:IML1]IASCGU

    Read[FAS]FAS0=[M:IML1]AASREF
    If ( [F:FAS]IASCGU <> "" ) Then
      # Le bien ne doit pas ÃŠtre rattachÃĐ Ã  une UGT
      GMESSAGE  = mess(265, GML_MSGFAS,1)-[F:FAS]IASCGU + '.' - mess(472,GML_MSGFAS,1)
      GERR      = 1 : FIN=1  : Return
    Elsif ( [F:FAS]CMPSTA = GVML_SBPRINC ) Then
      # Seule une rÃĐfÃĐrence de bien autonome ou principale peut ÃŠtre indiquÃĐe
      GMESSAGE  = mess(473,GML_MSGFAS,1) + '\' + mess(474,GML_MSGFAS,1)
      GERR      = 1 : FIN=1  : Return
    Elsif ( [F:FAS]CMPSTA <> GVML_SBAUTON  and [F:FAS]CMPSTA <> GVML_SBPOOL and [F:FAS]CMPSTA <> GVML_SBLVA) Then
      # Seule une rÃĐfÃĐrence de bien autonome peut ÃŠtre indiquÃĐe FQ67615
      GMESSAGE  = mess(475,GML_MSGFAS,1)
      GERR      = 1 : FIN=1  : Return
    Elsif ( [F:FAS]OWNTYP = GVML_TDMODEL ) Then
      # Le bien en modÃĻle n'est pas dÃĐprÃĐciable
      GMESSAGE  = mess(460,GML_MSGFAS,1)
      GERR      = 1 : FIN=1  : Return
    Elsif ( [F:FAS]OWNTYP = GVML_TDANNUL ) Then
      # Un bien annulÃĐ n'est pas dÃĐprÃĐciable
      GMESSAGE  = mess(592,GML_MSGFAS,1)
      GERR      = 1 : FIN=1  : Return
    Endif

    # Cas oÃđ l'on active l'action depuis une ligne de plan de FAS3
    # dans PARMPLN on a le plan passÃĐ en paramÃĻtre de l'action

    #- 2 ---------------------
    If (dim(GPARMPLN)>0 & GPARMPLN > 0) Then

      [M:IML1]DPRPLN=GPARMPLN : Affzo [M:IML1]DPRPLN

      If ( func GLOBIENS.GET_NORME_PLAN ([M:FAS0]CPY,[M:IML1]DPRPLN) <> GVML_NPIAS  and
&          func GLOBIENS.GET_NORME_PLAN ([M:FAS0]CPY,[M:IML1]DPRPLN) <> GVML_NPCRC  ) Then

        # Ce plan n'est pas  gÃĐrÃĐ selon la norme IAS/IFRS ==> pas de dÃĐprÃĐciation
        Disable GSTAOK : Disable  GSTABOU+1
        GMESSAGE= mess(461,GML_MSGFAS,1): mkstat=2
        GERR=1 : FIN=1 : Return
      Else
        Diszo [M:IML1]DPRPLN
      Endif

      #Fq67577-Pologne
      If G_ACTKPL=G_OUI & [M:FPC]LEG="POL" & [M:FAS3]KMDRDEV(find(GPARMPLN,[M:FAS3]DPRPLN)-1)<>0
       Disable GSTAOK : Disable GSTABOU+1
       GMESSAGE=mess(827,GML_MSGFAS,1) #"Action impossible : modernisation en cours"
       GERR = 1 : FIN = 1 : Return
      Endif
      #Fin-Pologne

      # Indicateur annulation de dÃĐprÃĐciation
      [M:IML1]IMLANNFLG = G_NON :  Diszo [M:IML1]IMLANNFLG

      # Recherche de la pÃĐriode courante et de l'exercice courant
      Raz  [M:IML1]DATSTRFIY
      Raz  [M:IML1]DATENDFIY
      Raz  [M:IML1]DATSTRPER
      Raz  [M:IML1]DATENDPER
      Call GET_CNX_FROM_PLAN ([M:FAS0]CPY, [M:IML1]DPRPLN,  LCNX) From GLOBIENS
      Read [CNX]CNX0=[M:FAS0]CPY;LCNX
      If (!fstat) Then
        [M:IML1]CUR = [F:CNX]CUR
        # Lecture de l'exercice courant du plan modÃĻle
        Read [FIS]FIY1=[F:CNX]CPY;[F:CNX]CNX;GVML_TECOURA
        If (!fstat)
          [M:IML1]DATSTRFIY = [F:FIS]DATSTRFIY
          [M:IML1]DATENDFIY = [F:FIS]DATENDFIY
          [M:IML1]DATSTRPER = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
          [M:IML1]DATENDPER = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
          [M:IML1]DATEFF    = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
        Endif
      Endif
      Affzo [M:IML1]
      Call C_DPRPLN([M:IML1]DPRPLN)

      # Si le bien a une date de dÃĐbut amortissement postÃĐrieure Ã  la date de fin de pÃĐriode en cours
      If ( [F:DEP]STRDPRDAT > [M:IML1]DATENDPER  ) Then
        # Date de dÃĐbut d'amortissement supÃĐrieure Ã  la date de fin pÃĐriode courante
        GMESSAGE = mess(389,GML_MSGFAS,1) : GERR= 1 : FIN=1 : Return
      Endif

      # Si le bien est de nature En cours
      If ( ([M:FAS1]GACACN = GVML_NIENCOU or [M:FAS1]IASACN = GVML_NIENCOU) and [F:DEP]DPM <> G_DPMSA ) Then
        # Nature du bien "Immo en cours" et mode du plan <> "SA"
        GMESSAGE = mess(604,GML_MSGFAS,1) : GERR= 1 : FIN=1 : Return
      Endif

    #- 2 ---------------------
    Else
      # On supprime de la combo les plans qui ne sont pas gÃĐrÃĐs selon la norme IAS/IFRS ou CRC2002-10
      Local  Integer LISTE_MODE (2) : # liste des modes des plans qu'on veut conserver dans la combo
      Local  Integer NB_PLN         : # Nombre de plans conservÃĐs dans la combo
      LISTE_MODE(0) = GVML_NPIAS   : # IAS
      LISTE_MODE(1) = GVML_NPCRC   : # CRC2002-10
      Call VIRE_PLN_STD_NOK ([M:FAS0]CPY, LISTE_MODE, NBPLAN) From GLOBIENS

      #>>> Action rÃĐservÃĐe aux plans gÃĐrÃĐs selon les normes IFRS ou CRC 2002-10"
      If ( NBPLAN=0 ) Then
        GERR=1
        Disable GSTAOK : Disable  GSTABOU+1
        GMESSAGE= mess(497,GML_MSGFAS,1) : mkstat=2 : FIN=1 : Return
      Endif
    Endif
    #- 2 ---------------------

    # Si le bien est sorti et que la sortie est rÃĐelle
    If ( [M:FAS4]ISSDAT <> [0/0/0]) and ([M:FAS4]EXTISSFLG = G_NON ) Then
      # Le bien comptable est sorti, il ne peut ÃŠtre modifiÃĐ
      GMESSAGE = mess(66,GML_MSGFAS,1) : GERR= 1 : FIN=1 : Return
    Endif

    # Le bien a fait l'objet d'un classement pour vente. FQ95754_3
    If ( [M:FAS4]SALCLSDAT <> [0/0/0] )
      GMESSAGE = mess(931,GML_MSGFAS,1) : GERR= 1 : FIN=1 : Return
    Endif

    # Si le type de dÃĐtention = "En modÃĻle"
    If ( [M:FAS1]OWNTYP = GVML_TDMODEL ) Then
      # OpÃĐration impossible : le type de dÃĐtention est "En modÃĻle
      GMESSAGE = mess(65,GML_MSGFAS,1) : GERR= 1 : FIN=1 : Return
    Endif

    #FQ54343
    # Si le type de dÃĐtention = "En concession"
    If ( [M:FAS1]OWNTYP = GVML_TDCONCE ) Then
      # OpÃĐration impossible : le type de dÃĐtention est "En concession
      GMESSAGE = mess(703,GML_MSGFAS,1) : GERR= 1 : FIN=1 : Return
    Endif

    # Si le type de dÃĐtention = "AnnulÃĐ"
    If ( [F:FAS]OWNTYP = GVML_TDANNUL ) Then
      # Un bien annulÃĐ n'est pas dÃĐprÃĐciable
      GMESSAGE = mess(592,GML_MSGFAS,1) : GERR= 1 : FIN=1 : Return
    Endif

    If ( [M:IML1]AASREF <> "" ) Then
      Call ALIM_VN([M:IML1]AASREF,"")
    Endif

    # (Massif et Unitaire)
    Gosub ACTION From =TRTMODACT

    #--> On rend le masque invalide pour faire tous les contrÃīles
    Setmok [M:IML1] With 0

  #- 1 ---------------------
  Else

    If !GBATCH | (GBATCH & [M:IML1]IASCGU="" & !find(G_OUI,[M:MHC]FLGCPY))
     [M:IML1]IMLANNFLG = G_NON
     Affzo [M:IML1]IMLANNFLG
     Diszo [M:IML1]IMLANNFLG

     # (Massif et Unitaire)
     Gosub ACTION From =TRTMODACT

     #--> On rend le masque invalide pour faire tous les contrÃīles
     Setmok [M:IML1] With 0

     Diszo [M:IML1]AASREF

     Call ACTION_BLOCK (ACB_EFFZO, "FASIML1", "IASCGU") From GLOBIENS
     Call ACTION_BLOCK (ACB_EFFZO, "FASIML1", "DPRPLN") From GLOBIENS
    Endif

  Endif
  #- 1 ---------------------

  If ( [M:IML1]DPRPLN = G301CPT ) Then
    [M:IML1]IMLTYP = GML_TDEXCEPT
  Elsif ( [M:IML1]DPRPLN = G301IAS ) Then
    [M:IML1]IMLTYP = GML_TDEXPLOI
  Endif


  Gosub KILL_TRACE_DETAIL
Return
