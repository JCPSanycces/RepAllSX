$CONTROLE
If ABANDON_TRT : Return : Endif #Fq63487-GBN-63487
Local Integer LOK
  Gosub ACTION From =TRTMODACT

  If FIN = 1 : Return : Endif

  #-1 --------------------------
  If ( GCONTROLE = G_OUI ) Then
    #-2 --------------------------
    If ( [M:IML1]IASCGU = "" and [M:IML1]AASREF = "" ) Then
      # Impossible de dÃĐprÃĐcier car les rÃĐfÃĐrences 'Bien' et 'UGT' sont absentes
      GMESSAGE = mess(457,GML_MSGFAS,1)
      GERR     = 1 : SAI = 1
    #-2 --------------------------
    Elsif ([M:IML1]USEVAL = 0 and [M:IML1]NSPVAL = 0  and GAUTORISNULL  = G_NON  and  [M:IML1]IMLANNFLG = G_NON)
      # Impossible de dÃĐprÃĐcier car 'Valeur marchÃĐ' et 'Valeur nette' sont absentes
      GMESSAGE = mess(458,GML_MSGFAS,1)
      GERR     = 1 : SAI = 1
    #-2 --------------------------
    Elsif ( abs([M:IML1]RCOVAL) > abs([M:IML1]NBV) and [M:IML1]IMLRVELIM = 0 ) Then
      [M:IML1]IMLRVE = 0 : Affzo [M:IML1]IMLRVE
      GMESSAGE = mess(498,GML_MSGFAS,1)
      GERR     = 1 : SAI = 1
    #-2 --------------------------
    Elsif ( abs([M:IML1]IMLRVE) > abs([M:IML1]IMLRVELIM) ) Then
      If ( ACTTYPGES = GTAMUNI ) Then
        # La reprise de dÃĐprÃĐciation est supÃĐrieure au plafond de reprise.
        # Si vous confirmez, la reprise sera limitÃĐe au plafond de reprise.Confirmez-vous ?
        Call OUINON(mess(484,GML_MSGFAS,1)+'\'+ mess(485,GML_MSGFAS,1)+'\'+ mess(277,GML_MSGFAS,1), LOK) From GESECRAN
        If ( LOK = G_OUI ) Then
         [M:IML1]IMLRVEBLC =  [M:IML1]IMLRVE - [M:IML1]IMLRVELIM
        Else
          [M:IML1]IMLRVEBLC  = 0
          GERR      = 1 : SAI = 1
        Endif
        Affzo [M:IML1]IMLRVEBLC
     Endif
    Endif
    #-2 --------------------------
  Endif
  #-1 --------------------------

Return

#======================================= FQ101395
$AVANT_OK
  Gosub AVANT_CONTROLER_OK
Return

#======================================= FQ101395
$AVANT_CONTROLER_OK
  #- 1---------------------------
  If ( abs([M:IML1]RCOVAL) > abs([M:IML1]NBV) and [M:IML1]IMLRVELIM = 0 )
    If ( GIABANDON <> G_OUI ) Then
      #  Rejet : Reprise de dÃĐprÃĐciation impossible, les biens sÃĐlectionnÃĐs ne portent pas de dÃĐprÃĐciation
      GIABANDON = G_NON
      GMESSAGE  = mess(498,GML_MSGFAS,1)
      GERR      = 1
      FOK       = 0 : # Pour ne pas executer l'action OK
      FIN       = 0 : # Pour rester sur la fenÃŠtre
    Endif
    [M:IML1]IMLRVE = 0  : Affzo [M:IML1]IMLRVE
  #- 1---------------------------
  Elsif (GIMLNSPNBV <> G_OUI) and (ACTTYPGES=GTAMMAS and [M:IML1]RCOVAL <> 0 and abs([M:IML1]RCOVAL) < abs([M:IML1]IMLMAX))
    #  Rejet : La valeur recouvrable ne peut pas ÃŠtre > Ã  la somme des valeurs nettes des biens avec valeur marchÃĐ > VN
    GMESSAGE  = mess(476,GML_MSGFAS,1) - num$( [M:IML1]IMLMAX) + mess(482,GML_MSGFAS,1) + '\' + mess(477,GML_MSGFAS,1) + num$( [M:IML1]IMLMAX)
    GERR      = 1
    FOK       = 0 : # Pour ne pas executer l'action OK
    FIN       = 0 : # Pour rester sur la fenÃŠtre
    [M:IML1]IMLRVE = 0 : Affzo [M:IML1]IMLRVE
  #- 1---------------------------
  Elsif ( abs([M:IML1]IMLRVE) > abs([M:IML1]IMLRVELIM) )
    #  Reprise de dÃĐprÃĐciation impossible car la reprise de dÃĐprÃĐciation est supÃĐrieure au plafond de reprise.
    Call OUINON(mess(484,GML_MSGFAS,1)+'\'+ mess(485,GML_MSGFAS,1)+'\'+ mess(277,GML_MSGFAS,1), LOK) From GESECRAN
    If ( LOK = G_NON ) Then
      FOK = 0 : # Pour ne pas executer l'action OK
      FIN = 0 : # Pour rester sur la fenÃŠtre
    Else
      [M:IML1]IMLRVEBLC =  [M:IML1]IMLRVE - [M:IML1]IMLRVELIM  : Affzo [M:IML1]IMLRVEBLC
    Endif
  Endif
Return

