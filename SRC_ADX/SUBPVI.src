#**
#* VĂ©rification existence de la variable dans le code liste fourni dans le paramĂ¨tre CODPVI
#*
#* @param VALEUR
#*!
Subprog C_VRACOD(VALEUR)
Variable Char    VALEUR()
Local    Char    CODPVH(GLONPVH)

  Call CONTROLE_VRACOD("CODPVI", VALEUR) From TOOLSVAR
End

Subprog C_ELTAMT(VALEUR)
Variable Char    VALEUR()
Local    Char    TEX(80)(1..200), TIT(80)(0..2), PARAM(80)(1..2)
Local    Integer NBTEX

  PARAM(1)='PARIND'
  Gosub SELAMT From TRTSELAMT
  If !find(VALEUR, TEX) Then
    mkstat=2
  Endif
End

Subprog AS_CODCOT(VALEUR)
Variable Char    VALEUR()
If instr(1,[M]ELTAMT(nolign-1),"COT")=0 Then
  mkstat=2
Endif
End

