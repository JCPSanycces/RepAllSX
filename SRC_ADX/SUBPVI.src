#<AdxTL>@(#)7.0.0.0 $Revision$
Call OBJET("PVI",GBIDC1,"") From GOBJET
End

$ACTION
  Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "LIENS"      : Gosub LIENS
    When "FERME"      : Gosub FERME
    When "INIMOD"      : Gosub INIMOD
    When "INICRE"      : Gosub INICRE
    When "RAZDUP"      : Gosub RAZDUP
    When Default
  Endcase
Return

#################################
$OUVRE
Gosub OUVRE From TOOLSVAR
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

#################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#################################
$LIENS
GCURLEG=[F:PVI]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
#Gosub LOAD_TAB
Return

###################################
$RAZDUP
 Effzo[M]10
 [M]NBPVI=0
Return

###################################
$INICRE
$INIMOD
#Gosub SAVE_TAB
Return

#################################
$LOAD_TAB
If GCURLEG="" : Raz [M] : Return : Endif
nolign=1
For [F:PVI] Where LEG=GCURLEG
 [M]=[F:PVI]
 [M]KEYPVI(nolign-1) = func CRE_KEY(GCURLEG,[M]ELTAMT(nolign-1),[M]CODFDS(nolign-1),[M]CODREP(nolign-1),
&                           [M]CODCOT(nolign-1),[M]LEV(nolign-1),[M]ADXDOS(nolign-1),[M]POP(nolign-1),
&                           [M]CPY(nolign-1),[M]FCY(nolign-1),[M]REFNUM(nolign-1),[M]CTRNUM(nolign-1),
&                           [M]SERVICE(nolign-1),[M]CLLCVT(nolign-1),[M]PRFCOD(nolign-1))
 nolign+=1
Next
[M]NBPVI=nolign-1
Affzo [M]
Return

#################################
$SAVE_TAB
Delete [F:PVI] Where LEG=GCURLEG
If fstat=1
 GOK =-1 : GLOCK = "$PARVARIND" : Return
Endif
For nolign=1 To [M]NBPVI
 [F:PVI]=[M]
 [F:PVI]LEG=GCURLEG
 Write [PVI]
 If fstat<>0
  GOK = 0 : Call FSTA("PVI") From GLOCK : Break
 Endif
Next
Return

#################################
#*  CrĂ©ation de la clĂ© : ElĂ©ment montant + niveau + valeur relative au niveau
Funprog CRE_KEY( LEG, ELTAMT, CODFDS, CODREP, CODCOT, LEV, ADXDOS, POP, CPY, FCY, REFNUM, CTRNUM, SERVICE, CLLCVT, PRFCOD)
Value    Char    LEG, ELTAMT, CODFDS, CODREP, CODCOT, ADXDOS, POP, CPY, FCY, REFNUM, CTRNUM, SERVICE, CLLCVT, PRFCOD
Value    Integer LEV
Local    Char    KEYPVI

  KEYPVI=LEG+"~"+ELTAMT+"~"+CODFDS+"~"+CODREP+"~"+CODCOT+"~"+num$(LEV)
  Case LEV
    When 1 : KEYPVI += "~"+ADXDOS
    When 2 : KEYPVI += "~"+POP
    When 3 : KEYPVI += "~"+CPY
    When 4 : KEYPVI += "~"+FCY
    When 5 : KEYPVI += "~"+REFNUM
    When 6 : KEYPVI += "~"+CTRNUM
    When 7 : KEYPVI += "~"+SERVICE
    When 8 : KEYPVI += "~"+CLLCVT
    When 9 : KEYPVI += "~"+PRFCOD
  Endcase
End KEYPVI

######################################################################################
#           GESTION DES CHAMPS DE L'ECRAN PVI0
######################################################################################

#**
#* Reconstitution de la clĂ© KEYPVI aprĂ¨s changement de l'Ă©lĂ©ment montant
#*
#* @param VALEUR
#*!
Subprog AM_ELTAMT(VALEUR)
Variable Char    VALEUR()

  [M]KEYPVI(nolign-1) = func CRE_KEY(GCURLEG,VALEUR,[M]CODFDS(nolign-1),[M]CODREP(nolign-1),[M]CODCOT(nolign-1),[M]LEV(nolign-1),
&                                    [M]ADXDOS(nolign-1),[M]POP(nolign-1),[M]CPY(nolign-1),[M]FCY(nolign-1),
&                                    [M]REFNUM(nolign-1),[M]CTRNUM(nolign-1),[M]SERVICE(nolign-1),
&                                    [M]CLLCVT(nolign-1),[M]PRFCOD(nolign-1))
End

#**
#* Reconstitution de la clĂ© KEYPVI aprĂ¨s changement du champ Fond
#*
#* @param VALEUR
#*!
Subprog AM_CODFDS(VALEUR)
Variable Char    VALEUR()

  [M]KEYPVI(nolign-1) = func CRE_KEY(GCURLEG,[M]ELTAMT(nolign-1),[M]CODFDS(nolign-1),VALEUR,[M]CODCOT(nolign-1),[M]LEV(nolign-1),
&                                    [M]ADXDOS(nolign-1),[M]POP(nolign-1),[M]CPY(nolign-1),[M]FCY(nolign-1),
&                                    [M]REFNUM(nolign-1),[M]CTRNUM(nolign-1),[M]SERVICE(nolign-1),
&                                    [M]CLLCVT(nolign-1),[M]PRFCOD(nolign-1))
End

#**
#* Reconstitution de la clĂ© KEYPVI aprĂ¨s changement du champ Code rĂ©partition
#*
#* @param VALEUR
#*!
Subprog AM_CODREP(VALEUR)
Variable Char    VALEUR()

  [M]KEYPVI(nolign-1) = func CRE_KEY(GCURLEG,[M]ELTAMT(nolign-1),VALEUR,[M]CODREP(nolign-1),[M]CODCOT(nolign-1),[M]LEV(nolign-1),
&                                    [M]ADXDOS(nolign-1),[M]POP(nolign-1),[M]CPY(nolign-1),[M]FCY(nolign-1),
&                                    [M]REFNUM(nolign-1),[M]CTRNUM(nolign-1),[M]SERVICE(nolign-1),
&                                    [M]CLLCVT(nolign-1),[M]PRFCOD(nolign-1))
End

#**
#* Reconstitution de la clĂ© KEYPVI aprĂ¨s changement du champ cotisation
#*
#* @param VALEUR
#*!
Subprog AM_CODCOT(VALEUR)
Variable Char    VALEUR()

  [M]KEYPVI(nolign-1) = func CRE_KEY(GCURLEG,[M]ELTAMT(nolign-1),[M]CODFDS(nolign-1),[M]CODREP(nolign-1),VALEUR,[M]LEV(nolign-1),
&                                    [M]ADXDOS(nolign-1),[M]POP(nolign-1),[M]CPY(nolign-1),[M]FCY(nolign-1),
&                                    [M]REFNUM(nolign-1),[M]CTRNUM(nolign-1),[M]SERVICE(nolign-1),
&                                    [M]CLLCVT(nolign-1),[M]PRFCOD(nolign-1))
End

#**
#* Reconstitution de la clĂ© KEYPVI aprĂ¨s changement du niveau
#*
#* @param VALEUR
#*!
Subprog AM_LEV(VALEUR)
Variable Integer VALEUR

  # On annule d'abord la valeur du champ rattachĂ© Ă  l'ancien niveau
  Case [M]LEV(nolign-1)
    When 2 : [M]ADXDOS(nolign-1)  = ""
    When 3 : [M]POP(nolign-1)     = ""
    When 4 : [M]CPY(nolign-1)     = ""
    When 5 : [M]FCY(nolign-1)     = ""
    When 6 : [M]REFNUM(nolign-1)  = ""
    When 7 : [M]CTRNUM(nolign-1)  = ""
    When 8 : [M]SERVICE(nolign-1) = ""
    When 9 : [M]CLLCVT(nolign-1)  = ""
    When 10 : [M]PRFCOD(nolign-1)  = ""
  Endcase

  If VALEUR=2 Then
    [M]LEV(nolign-1)=VALEUR
    [M]ADXDOS(nolign-1)=nomap
    Call VERIF_UNICITE([M]ADXDOS(nolign-1))
  Endif

  [M]KEYPVI(nolign-1) = func CRE_KEY(GCURLEG,[M]ELTAMT(nolign-1),[M]CODFDS(nolign-1),[M]CODREP(nolign-1),[M]CODCOT(nolign-1),VALEUR,
&                                    [M]ADXDOS(nolign-1),[M]POP(nolign-1),[M]CPY(nolign-1),[M]FCY(nolign-1),
&                                    [M]REFNUM(nolign-1),[M]CTRNUM(nolign-1),[M]SERVICE(nolign-1),
&                                    [M]CLLCVT(nolign-1),[M]PRFCOD(nolign-1))
End

######################################################################################
# La combinaison ElĂ©ment montant+Niveau+champ relatif au niveau doit ĂŞtre unique
######################################################################################
Subprog VERIF_UNICITE(VALEUR)
Value Char    VALEUR

  Call UNICITE(GCURLEG+"~"+[M]ELTAMT(nolign-1)+"~"+[M]CODFDS(nolign-1)+"~"+[M]CODREP(nolign-1)+"~"+[M]CODCOT(nolign-1)+"~"+num$([M]LEV(nolign-1))+"~"+VALEUR, [M]KEYPVI) From OBJDIV
  If GMESSAGE="" Then
    [M]KEYPVI(nolign-1)=GCURLEG+"~"+[M]ELTAMT(nolign-1)+"~"+[M]CODFDS(nolign-1)+"~"+[M]CODREP(nolign-1)+"~"+[M]CODCOT(nolign-1)+"~"+num$([M]LEV(nolign-1))+"~"+VALEUR
  Endif
End

Subprog AM_ADXDOS(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_POP(VALEUR)
Variable Char    VALEUR()

  Call VERIF_UNICITE(VALEUR)
End

Subprog AM_CPY(VALEUR)
