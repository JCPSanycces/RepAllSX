#<AdxTL>@(#)8.0.0.0 $Revision$
# Issue X3-107197 - 2018-09-12 by CBO : PARAMETER AND ACTIVITY CODE
#*X3-39795  MWA  Manage ORIGIN and ORICOD fields in GL Entry
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","BNKTRSIMP","BNKTRSIMP",4,"") From GTRAITE
End

# Issue X3-107197 - 2018-09-11 by CBO : PARAMETER AND ACTIVITY CODE

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "EXEC"        : Gosub EXEC
 When "CONTROLE"    : Gosub CONTROLE
 When "TERMINE"     : Gosub FIN

 When "DEBUT"       : Gosub DEBUT
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0

 When "OUVRE_BATCH" : Gosub OUVRE_BATCH

Endcase
Return

$INIT
$OUVRE_BATCH
If !clalev([M:BTI]) : Local Mask BNKTRSIMP [BTI] : Endif

If !clalev([F:TCU]) : Local File TABCUR  [TCU] : Endif
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif

Return

$DEBUT
If GCONSDIA : Return : Endif
Raz [M:BTI]
Local Char CHEMIN(250)

##-- VOLFIL initialization
[M]TYPEXP=2
If [M]VOLFIL="" & !GBATCH
 If func AFNC.ACTIV("CASIN")   # Issue X3-107197
  Call PARAMUTIL("IMPBNKTRSF",CHEMIN,"","") From SUBAUS
 Endif   # Issue X3-107197
 If CHEMIN<>"" & left$(CHEMIN,1)="["
  [M]VOLFIL = CHEMIN
 Else
  [M]VOLFIL = "["+GDIRCASH+"]"
 Endif
Endif
Actzo [M]VOLFIL

Affzo [M:BTI]
Return

##################################################################
$CONTROLE
If GOK=0 : FIN=1 : Return : Endif

Onerrgo ERREUR From CONTROLE
If !clalev([F:BTI]) : Local File BNKTRSIMP [BTI] : Endif
Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

If FIN : Return : Endif
Call AVERTDGI(2,"",1,SAI) From CPTDIV2
If SAI : Return : Endif

##--- Nom du fichier importé
Local Char    DIR_FICBAN(GDIMFIC), MACHIN(80), IRS(2), OS(20), SEPDOS(1), FICIMP(50)
Local Integer OK, I
[L]SEPDOS = "/"
For I=len([M]FIC) To 1 Step -1
 If mid$([M]FIC,I,1)=[L]SEPDOS : Break : Endif
Next I
[L]FICIMP = right$([M]FIC,I+1)


If [M]TRC=2 : TRA = 1 : Endif
TMP = 1
Return

##################################################################
$EXEC
If !GSERVEUR and [M]TRC=2
 Call TITAWI(BCRIT,GMESSAGE) From OBJDIV
 Call OUVRE_TRACE(GMESSAGE) From LECFIC
 If [M]TYPEXP=2
  Call ECR_TRACE("|"+mess(55,100,1)-":"-[M]VOLFIL,0) From GESECRAN
 Endif
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 GMESSAGE=""
Endif

Call DEBTRANS From GLOCK
Trbegin [BTI]

# Suppression des données de la table temporaire
Delete [BTI] Where 1=1
If fstat : Call FSTA("BTI") From GLOCK : Rollback : FIN=1 : Return : Endif

# New parameter to take back the name of the file when Import from client
Call IMPORT([M:BTI]FIC,[L]FICIMP,OS,OK)
If OK<1
 If OK=-1 : TRA= 0 : Endif
 FIN=1 : Rollback : Return
Else
 Commit
Endif

# Comptabilisation
Local Char CRIT(250),MESSAGE(250)
Local Integer STAT
If dim([V]GNUMPCE)<1 : Global Char GNUMPCE(GLONVCR) : Endif
If dim([V]GTYPPCE)<1 : Global Char GTYPPCE(GLONVCR) : Endif

Local Char    PCEAUTO(GLONGAU)

Trbegin [BTI]
GOK=1
 Filter [BTI] Where FICHIER =[L]FICIMP
 For [BTI]
  CRIT="[F:TB0]FICHIER='"+[F:BTI]FICHIER+"' & [F:TB0]LIN="+num$([F:BTI]LIN)
  If func AFNC.ACTIV("CASIN")   # Issue X3-107197
    Call PARAM([F:BTI]CODCPY,"GAUCASH",PCEAUTO) From ADOVAL
  Endif   # Issue X3-107197
  If PCEAUTO="" : PCEAUTO = "CASH" : Endif
  # X3-39795 MWA Start
  # Call VALPCE2(PCEAUTO,CRIT,STAT,MESSAGE) From CPTAUTO
  Local Char    TZONE(10)(1..10)           : # Table of the zones to be forced (Ex: ORICOD)
  Local Char    TVAL(30)(1..10)            : # Table of values for zones to be forced
  TZONE(5)="ORIGIN" : TVAL(5)="2"               : # X3-39795 MWA Automatic loading
  TZONE(6)="ORICOD" : TVAL(6)= [L]PCEAUTO       : # X3-39795 MWA
  Call VALPCE4(PCEAUTO,CRIT,STAT,MESSAGE,TZONE,TVAL) From CPTAUTO
  # X3-39795 MWA End
  If STAT
   If [M]TRC=2 :
    Call ECR_TRACE(MESSAGE,1) From GESECRAN
    Call ECR_TRACE(mess(35,117,1),1) From GESECRAN
   Endif
   GOK=0 : Break
  Elsif [V]GTYPPCE="" or [V]GNUMPCE=""
   # Pièce non générée
   If [M]TRC=2 : Call ECR_TRACE(mess(35,117,1),1) From GESECRAN : Endif
   GOK = 0 : Break
  Else
   # Pièce
   If [M]TRC=2 : Call ECR_TRACE(mess(12,107,1)-":"-[V]GTYPPCE-[V]GNUMPCE,0) From GESECRAN : Endif
  Endif
 Next
If !GOK
 Rollback
Else
 Commit
Endif
If !GSERVEUR & [M]TRC=2
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Call FERME_TRACE From LECFIC
Endif
Return

#######################################################
## Traitement de fin (lecture trace)
#######################################################
$FIN
If !GSERVEUR
 TRA=1
Endif
Return

###############################################
Subprog IMPORT(CHEMIN,FICHIER,OS,OK)
###############################################
Value    Char    CHEMIN()
Variable Char    FICHIER()
Value    Char    OS()
Variable Integer OK

Local Char    RECTYP(4)(1..7)
Local Schar   CTEST(1)
Local Char    INDIC(4), ZONE(255), MESSA(80), SVGMNT(20)
Local Integer I, J, K, LONG
Local Integer NBPCE
Local Date    SVGDAT

# Variables pour Poste Client
Local Char FICDON(GDIMFIC),URL(GDIMFIC)
Local Integer STAT

If [M]TYPEXP=1 : # Client
 Call COPSRV(FICHIER,FICDON,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  Call ERREUR(mess(164,141,1)) From GESECRAN
  OK = -1 : End
 Elsif STAT>1
  # Fichier inexistant
  Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  OK = -1 : End
 Endif
 If !GSERVEUR and [M]TRC=2
  Call ECR_TRACE("|"+mess(55,100,1)-":"-[L]FICHIER,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  GMESSAGE=""
 Endif
Else
 FICDON = CHEMIN
Endif

# Différence selon L'Interface : SCTE (Concept) ou L1000 ou SFRPT (XRT)
If func AFNC.ACTIV("SFRPT")
 Gosub IMPORTATION_SFRPT
Elsif func AFNC.ACTIV("T1000")
 Gosub IMPORTATION_T1000
Else
 Gosub IMPORTATION_SCTE
Endif
End

$IMPORTATION_SCTE
Openi FICDON,0

# Caractères pourris du début
J=0 : Gosub LECTEST
While ascii(CTEST)<32 & !fstat
 J +=1 : Gosub LECTEST
Wend

RECTYP(1)="0001"
RECTYP(2)="0002"
RECTYP(3)="0003"
RECTYP(4)="0004"
RECTYP(5)="0005"
RECTYP(6)="0009"
RECTYP(7)="9999"
[L]LONG=133

Openi FICDON,J
I = [L]LONG
Local Schar FILLER(I)
Gosub LECTURE

# Séparateur d'enregistrement
K=0 : Gosub LECTEST
While ascii(CTEST)<32 & !fstat
 K +=1 : Gosub LECTEST
Wend

Openi FICDON,J
I = [L]LONG + K
Local Schar FILLER(I)
Gosub LECTURE

[L]OK=1
Raz [L]NBPCE


While fstat=0

 Case left$([L]FILLER,4)

  When [L]RECTYP(1)                 :  # Ligne en-tête (Identifiant 0001)

   [L]ZONE   = mid$([L]FILLER,5,6)
   [L]SVGDAT = gdat$(val(left$([L]ZONE,2)),val(mid$([L]ZONE,3,2)),val(mid$([L]ZONE,5,2)))
   [L]INDIC  = [L]RECTYP(1)

  When [L]RECTYP(2)                 :  # Ligne date et support (Identifiant 0002)
   If find([L]INDIC,[L]RECTYP(1)) :# OK

    Raz [F:BTI] , [L]SVGMNT
    [F:BTI]FICHIER = [L]FICHIER
    [F:BTI]LIN     = [L]NBPCE+1
    [F:BTI]ACCDAT  = [L]SVGDAT

    [L]INDIC = [L]RECTYP(2)
    [F:BTI]CODCPY = vireblc(mid$([L]FILLER,5,4),2)
    [L]ZONE= mid$([L]FILLER,21,6)
    [F:BTI]VALDAT = gdat$(val(left$([L]ZONE,2)),val(mid$([L]ZONE,3,2)),val(mid$([L]ZONE,5,2)))
    [F:BTI]CODSUP = vireblc(mid$([L]FILLER,33,16),2)
    [F:BTI]DESSUP = vireblc(mid$([L]FILLER,49,20),2)
   Else
    If [L]INDIC="" :
     # Pas d'enregistrement émetteur
     If [M]TRC=2 : Call ECR_TRACE(mess(161,117,1),1) From GESECRAN   : Endif
    Else
     # Struture de lignes incorrect
     If [M]TRC=2 : Call ECR_TRACE(mess(15,173,1),1) From GESECRAN  : Endif
    Endif
    [L]OK=0
   Endif

  When [L]RECTYP(3)                  :  # Ligne de contrepartie (Identifiant 0003)
   If find([L]INDIC,[L]RECTYP(2))  :# OK
    [L]INDIC = [L]RECTYP(3)
    [F:BTI]OFFACC = vireblc(mid$([L]FILLER,5,16),1)
    [L]ZONE = mid$([L]FILLER,21,1)
    If [L]ZONE="C" : [F:BTI]OFFSNS = -1 : Else [F:BTI]OFFSNS = 1 : Endif
    [F:BTI]OFFCOD = vireblc(mid$([L]FILLER,37,16),2)
    [F:BTI]OFFREF = vireblc(mid$([L]FILLER,53,8),2)
    [F:BTI]OFFDES = vireblc(mid$([L]FILLER,61,32),2)
   Else
    If [L]INDIC="" :
     # Pas d'enregistrement émetteur
     If [M]TRC=2 : Call ECR_TRACE(mess(161,117,1),1) From GESECRAN   : Endif
    Else
     # Struture de lignes incorrect
     If [M]TRC=2 : Call ECR_TRACE(mess(15,173,1),1) From GESECRAN  : Endif
    Endif
    [L]OK=0
   Endif

  When [L]RECTYP(4)                :     # Ligne banque et compte (Identifiant 0004)
   If find([L]INDIC,[L]RECTYP(3))  :# OK
    [L]INDIC = [L]RECTYP(4)
    [F:BTI]FCYLIN = vireblc(mid$([L]FILLER,5,3),1)
    [F:BTI]ACC    = vireblc(mid$([L]FILLER,8,13),1)
    [L]ZONE = mid$([L]FILLER,21,1)
    If [L]ZONE="C" : [F:BTI]SNS = -1 : Else [F:BTI]SNS = 1 : Endif
    [L]ZONE= vireblc(mid$([L]FILLER,22,15),2)
    If val([L]ZONE)=0
     # Montant nul
     If [M]TRC=2 : Call ECR_TRACE(mess(177,117,1),0) From GESECRAN : Endif
    Else
     # Arrondi
     [L]SVGMNT = [L]ZONE
    Endif
    [F:BTI]REF = vireblc(mid$([L]FILLER,37,8),2)
    [F:BTI]DES = vireblc(mid$([L]FILLER,45,32),2)
   Else
    If [L]INDIC=""
     # Pas d'enregistrement émetteur
     If [M]TRC=2 : Call ECR_TRACE(mess(161,117,1),1) From GESECRAN : Endif
    Else
     # Struture de lignes incorrect
     If [M]TRC=2 : Call ECR_TRACE(mess(15,173,1),1) From GESECRAN  : Endif
    Endif
    [L]OK=0
   Endif

  When [L]RECTYP(5)              :   # Ligne devise (Identifiant 0005)

    [F:BTI]CUR= vireblc(mid$([L]FILLER,5,16),2)
    Call LECTURE("TCU",[F:BTI]CUR,"") From CONTOBJ
    If fstat
     # Devise inexistante
     If [M]TRC=2 : Call ECR_TRACE(mess(151,105,1),1) From GESECRAN   : Endif
     [L]OK=0
    Endif

    [F:BTI]RAT = val(mid$([L]FILLER,23,12))
    [L]ZONE    = vireblc(mid$([L]FILLER,35,15),2)
    If val([L]ZONE)=0
     # Montant nul
     If [M]TRC=2 : Call ECR_TRACE(mess(177,117,1),0) From GESECRAN : Endif
    Elsif len([L]ZONE)-[F:TCU]DECNBR<0
     [L]OK=0
     # Format des nombres incorrects - Montant transaction
     If [M]TRC=2 : Call ECR_TRACE(mess(22,173,1)-"-"-mess(23,173,1),0) From GESECRAN : Endif
    Else
     # Arrondi
     # Issue X3-81398
     # [F:BTI]AMTCUR = val(left$([L]ZONE,len([L]ZONE)-[F:TCU]DECNBR)+"."+right$([L]ZONE,len([L]ZONE)-[F:TCU]DECNBR+1))
     [F:BTI]AMTCUR = val(left$([L]ZONE,len([L]ZONE)-([F:TCU]DECNBR+1))+"."+right$([L]ZONE,len([L]ZONE)-([F:TCU]DECNBR-1)))
     # End issue X3-81398
    Endif

  When [L]RECTYP(6)                :     # Ligne banque et compte (Identifiant 0009)

    If find([L]INDIC,[L]RECTYP(4))  :# OK

     [F:BTI]OPENUM = vireblc(mid$([L]FILLER,17,7),2)
     [L]NBPCE += 1

     Call LECTURE("CPY",[F:BTI]CODCPY,"") From CONTOBJ
     If fstat
      # Société inexistante
      If [M]TRC=2 : Call ECR_TRACE(mess(16,104,1),1) From GESECRAN   : Endif
      [L]OK=0 : Break
     Endif
     Call LECTURE("TCU",[F:CPY]ACCCUR,"") From CONTOBJ
     If fstat
      # Devise inexistante
      If [M]TRC=2 : Call ECR_TRACE(mess(151,105,1),1) From GESECRAN   : Endif
      [L]OK=0 : Break
     Endif

     # Arrondi
     If val([L]SVGMNT)<>0
      If len([L]SVGMNT)-[F:TCU]DECNBR<0
       [L]OK=0
       # Format des nombres incorrects - Montant référentiel
       If [M]TRC=2 : Call ECR_TRACE(mess(22,173,1)-"-"-mess(25,173,1),0) From GESECRAN : Endif
      Else
       # Issue X3-81398
       # [F:BTI]AMTLOC = val(left$([L]SVGMNT,len([L]SVGMNT)-[F:TCU]DECNBR)+"."+right$([L]SVGMNT,len(SVGMNT)-[F:TCU]DECNBR+1))
       [F:BTI]AMTLOC = val(left$([L]SVGMNT,len([L]SVGMNT)-([F:TCU]DECNBR+1))+"."+right$([L]SVGMNT,len([L]SVGMNT)-([F:TCU]DECNBR-1)))
       # End issue X3-81398
      Endif
     Endif

     If [F:BTI]CUR=""  # dans le cas où il n'y a pas d'enregsitrement 0005, alors initialisation Devise société
      [F:BTI]CUR    = [F:CPY]ACCCUR
      [F:BTI]AMTCUR = [F:BTI]AMTLOC
     Endif

     If [L]OK
      Write [BTI]
      If fstat
       GOK=0 : Call FSTA("BTI") From GLOCK : Return
      Endif
      [L]INDIC = [L]RECTYP(1)
     Endif

    Else

     If [L]INDIC=""
      # Pas d'enregistrement émetteur
      If [M]TRC=2 : Call ECR_TRACE(mess(161,117,1),1) From GESECRAN  : Endif
     Else
      # Struture de lignes incorrect
      If [M]TRC=2 : Call ECR_TRACE(mess(15,173,1),1) From GESECRAN  : Endif
     Endif
     [L]OK=0
    Endif

  When [L]RECTYP(7)                :     # Ligne Total (Identifiant 9999)
    [L]OK=1 : Break

  When Default
   # Code enregistrement inexistant
   If [M]TRC=2 : Call ECR_TRACE(mess(170,117,1)-left$([L]FILLER,4),1) From GESECRAN : Endif
   [L]OK=0
 Endcase

 If ![L]OK : Break : Endif
 Gosub LECTURE

Wend
If ![L]NBPCE or ![L]OK
 OK=0
 # Fichier non importé
 If [M]TRC=2 : Call ECR_TRACE(mess(14,173,1),1) From GESECRAN : Endif
Else
 # Fichier importé
 If [M]TRC=2 : Call ECR_TRACE(mess(13,173,1),0) From GESECRAN  : Endif
Endif
Return


$LECTURE
Getseq 1, FILLER
# Fin de fichier
If mid$(FILLER,len(FILLER),1)="" : fstat = 4 : Endif
Return

$LECTEST
Getseq 1, CTEST
Return


#############################################################################
$IMPORTATION_T1000
Openi FICDON,0

# Caractères pourris du début
J=0 : Gosub LECTEST
While ascii(CTEST)<32 & !fstat
 J +=1 : Gosub LECTEST
Wend

[L]LONG=218

Openi FICDON,J
I = [L]LONG
Local Schar FILLER(I)
Gosub LECTURE

# Séparateur d'enregistrement
K=0 : Gosub LECTEST
While ascii(CTEST)<32 & !fstat
 K +=1 : Gosub LECTEST
Wend

Openi FICDON,J
I = [L]LONG + K
Local Schar FILLER(I)
Gosub LECTURE

[L]OK=1
Raz [L]NBPCE, [L]INDIC


While fstat=0

 If [L]INDIC=""
  Raz [F:BTI], [L]SVGMNT

  [F:BTI]JOU = vireblc(mid$([L]FILLER,1,3),2)

  [L]ZONE   = mid$([L]FILLER,4,6)
  [L]SVGDAT = gdat$(val(left$([L]ZONE,2)),val(mid$([L]ZONE,3,2)),val(mid$([L]ZONE,5,2)))
  [F:BTI]ACCDAT  = [L]SVGDAT

  [F:BTI]FICHIER = [L]FICHIER
  [F:BTI]LIN     = [L]NBPCE+1
  [F:BTI]OPENUM  = vireblc(mid$([L]FILLER,106,7),2)
  [F:BTI]CODSUP  = vireblc(mid$([L]FILLER,10,2),2)   # Type de pièce
  [F:BTI]CODCPY  = vireblc(mid$([L]FILLER,165,15),1)
  [F:BTI]FCYLIN  = vireblc(mid$([L]FILLER,180,15),1)
  [F:BTI]CUR     = vireblc(mid$([L]FILLER,215,3),2)
  Call LECTURE("TCU",[F:BTI]CUR,"") From CONTOBJ
  If fstat
   # Devise inexistante
   If [M]TRC=2 : Call ECR_TRACE(mess(151,105,1),1) From GESECRAN   : Endif
   [L]OK=0
  Endif

  [L]ZONE= mid$([L]FILLER,78,6)
  [F:BTI]VALDAT = gdat$(val(left$([L]ZONE,2)),val(mid$([L]ZONE,3,2)),val(mid$([L]ZONE,5,2)))

  # Informations montants
  [L]ZONE= vireblc(mid$([L]FILLER,85,20),2)
  If val([L]ZONE)=0
   # Montant nul
   If [M]TRC=2 : Call ECR_TRACE(mess(177,117,1),0) From GESECRAN : Endif
  Else
   # Arrondi
   [L]SVGMNT = [L]ZONE
  Endif

  [L]ZONE= vireblc(mid$([L]FILLER,195,20),2)
  If val([L]ZONE)=0
   # Montant nul
   If [M]TRC=2 : Call ECR_TRACE(mess(177,117,1),0) From GESECRAN : Endif
  Elsif len([L]ZONE)-[F:TCU]DECNBR<0
   [L]OK=0
   # Format des nombres incorrects - Montant transaction
   If [M]TRC=2 : Call ECR_TRACE(mess(22,173,1)-"-"-mess(23,173,1),0) From GESECRAN : Endif
  Else
   # Arrondi
   # Issue X3-81398
   # [F:BTI]AMTCUR = val(left$([L]ZONE,len([L]ZONE)-[F:TCU]DECNBR)+"."+right$([L]ZONE,len([L]ZONE)-[F:TCU]DECNBR+1))
   [F:BTI]AMTCUR = val(left$([L]ZONE,len([L]ZONE)-([F:TCU]DECNBR+1))+"."+right$([L]ZONE,len([L]ZONE)-([F:TCU]DECNBR-1)))
   # End issue X3-81398
  Endif

  # Information 1ère ligne
  [F:BTI]OFFACC = vireblc(mid$([L]FILLER,12,13),1)
  [F:BTI]OFFDES = vireblc(mid$([L]FILLER,52,25),2)
  [L]ZONE = mid$([L]FILLER,84,1)
  If [L]ZONE="C" : [F:BTI]OFFSNS = -1 : Else [F:BTI]OFFSNS = 1 : Endif
  [F:BTI]OFFREF = vireblc(mid$([L]FILLER,39,13),2)

 Else
  # Information 2ème ligne
  [F:BTI]ACC = vireblc(mid$([L]FILLER,12,13),1)
  [F:BTI]DES = vireblc(mid$([L]FILLER,52,25),2)
  [L]ZONE = mid$([L]FILLER,84,1)
  If [L]ZONE="C" : [F:BTI]SNS = -1 : Else [F:BTI]SNS = 1 : Endif
  [F:BTI]REF = vireblc(mid$([L]FILLER,39,13),2)
 Endif


 If [L]INDIC="OK"

  [L]NBPCE += 1

  Call LECTURE("CPY",[F:BTI]CODCPY,"") From CONTOBJ
  If fstat
   # Société inexistante
   If [M]TRC=2 : Call ECR_TRACE(mess(16,104,1),1) From GESECRAN   : Endif
   [L]OK=0 : Break
  Endif
  Call LECTURE("TCU",[F:CPY]ACCCUR,"") From CONTOBJ
  If fstat
   # Devise inexistante
   If [M]TRC=2 : Call ECR_TRACE(mess(151,105,1),1) From GESECRAN   : Endif
   [L]OK=0 : Break
  Endif
  # Arrondi
  If val([L]SVGMNT)<>0
   If len([L]SVGMNT)-[F:TCU]DECNBR<0
    [L]OK=0
    # Format des nombres incorrects - Montant référentiel
    If [M]TRC=2 : Call ECR_TRACE(mess(22,173,1)-"-"-mess(25,173,1),0) From GESECRAN : Endif
   Else
    # Issue X3-81398
    # [F:BTI]AMTLOC = val(left$([L]SVGMNT,len([L]SVGMNT)-[F:TCU]DECNBR)+"."+right$([L]SVGMNT,len(SVGMNT)-[F:TCU]DECNBR+1))
    [F:BTI]AMTLOC = val(left$([L]SVGMNT,len([L]SVGMNT)-([F:TCU]DECNBR+1))+"."+right$([L]SVGMNT,len([L]SVGMNT)-([F:TCU]DECNBR-1)))
    # End issue X3-81398
   Endif
  Endif
  If [F:BTI]CUR=""  # dans le cas où il n'y a pas d'enregsitrement 0005, alors initialisation Devise société
   [F:BTI]CUR    = [F:CPY]ACCCUR
   [F:BTI]AMTCUR = [F:BTI]AMTLOC
  Endif

  If [L]OK
   Write [BTI]
   If fstat
    GOK=0 : Call FSTA("BTI") From GLOCK : Return
   Endif
   Raz [L]INDIC
  Endif

 Else
  [L]INDIC="OK"
 Endif

 If ![L]OK : Break : Endif
 Gosub LECTURE
Wend

If ![L]NBPCE or ![L]OK
 OK=0
 # Fichier non importé
 If [M]TRC=2 : Call ECR_TRACE(mess(14,173,1),1) From GESECRAN : Endif
Else
 # Fichier importé
 If [M]TRC=2 : Call ECR_TRACE(mess(13,173,1),0) From GESECRAN  : Endif
Endif
Return




#############################################################################
$IMPORTATION_SFRPT

Openi FICDON,0

# Caractères pourris du début
J=0 : Gosub LECTEST
While ascii(CTEST)<32 & !fstat
 J +=1 : Gosub LECTEST
Wend

[L]LONG=246

Openi FICDON,J
I = [L]LONG
Local Schar FILLER(I)
Gosub LECTURE

# Séparateur d'enregistrement
K=0 : Gosub LECTEST
While ascii(CTEST)<32 & !fstat
 K +=1 : Gosub LECTEST
Wend

Openi FICDON,J
I = [L]LONG + K
Local Schar FILLER(I)
Gosub LECTURE

[L]OK=1
Raz [L]NBPCE, [L]INDIC

If !clalev([F:BAN]) : Local File BANK     [BAN] : Endif
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
Local Char    PLAN(GLONCOA)      : # Plan de compte
Local Char    DEVLED(GLONCUR)    : # Devise de référentiel

While fstat=0

 If [L]INDIC=""
  Raz [F:BTI]

  [F:BTI]FICHIER = [L]FICHIER
  [F:BTI]LIN     = [L]NBPCE+1
  [F:BTI]CODCPY = vireblc(mid$([L]FILLER,101,8),1)
  If [F:BTI]CODCPY<>[F:CPY]CPY
   Call LECTURE("CPY",[F:BTI]CODCPY,"") From CONTOBJ
   If fstat
    # Société inexistante
    If [M]TRC=2 : Call ECR_TRACE(mess(16,104,1),1) From GESECRAN   : Endif
    [L]OK=0 : Break
   Endif
   Call SETMAINREF([F:CPY]CPY,GTYPGEN,GTYPANA) From CPTDIV
   Call LECPLAN([F:CPY]CPY,GTYPGEN,PLAN) From CPTDIV
   Call SETCUR(1,[F:CPY]CPY,DEVLED) From CPTDIV
  Endif

  [F:BTI]OFFACC = vireblc(mid$([L]FILLER,1,100),1)
  Filter [BAN] Where COA=PLAN & BANACC=[F:BTI]OFFACC
  Read [BAN]BAN0 First
  Filter [BAN]
  If !fstat & [F:BAN]FCY<>""
   [F:BTI]FCYLIN  = [F:BAN]FCY
  Elsif [F:CPY]MAIFCY<>""
   [F:BTI]FCYLIN  = [F:CPY]MAIFCY
  Else
   Filter [FCY] Where LEGCPY=[F:CPY]CPY
   Read [FCY]FCY0 First
   Filter [FCY]
   If !fstat
    [F:BTI]FCYLIN  = [F:FCY]FCY
   Endif
  Endif

  [L]ZONE = mid$([L]FILLER,109,1)
  If [L]ZONE="C" : [F:BTI]OFFSNS = -1 : Else [F:BTI]OFFSNS = 1 : Endif

  [L]ZONE   = mid$([L]FILLER,110,8)
  [L]SVGDAT = gdat$(val(left$([L]ZONE,2)),val(mid$([L]ZONE,3,2)),val(mid$([L]ZONE,5,4)))
  [F:BTI]ACCDAT  = [L]SVGDAT

  [F:BTI]CUR     = vireblc(mid$([L]FILLER,161,3),2)
  Call LECTURE("TCU",[F:BTI]CUR,"") From CONTOBJ
  If fstat
   # Devise inexistante
   If [M]TRC=2 : Call ECR_TRACE(mess(151,105,1),1) From GESECRAN   : Endif
   [L]OK=0
  Endif

  # Informations montants
  [L]ZONE= vireblc(mid$([L]FILLER,141,20),2)
  If val([L]ZONE)=0
   # Montant nul
   If [M]TRC=2 : Call ECR_TRACE(mess(177,117,1),0) From GESECRAN : Endif
  Elsif len([L]ZONE)-[F:TCU]DECNBR<0
   [L]OK=0
   # Format des nombres incorrects - Montant transaction
   If [M]TRC=2 : Call ECR_TRACE(mess(22,173,1)-"-"-mess(23,173,1),0) From GESECRAN : Endif
  Else
   # Arrondi
   # Issue X3-81398
   # [F:BTI]AMTCUR = val(left$([L]ZONE,len([L]ZONE)-[F:TCU]DECNBR)+"."+right$([L]ZONE,len([L]ZONE)-[F:TCU]DECNBR+1))
   [F:BTI]AMTCUR = val(left$([L]ZONE,len([L]ZONE)-([F:TCU]DECNBR+1))+"."+right$([L]ZONE,len([L]ZONE)-([F:TCU]DECNBR-1)))
   # End issue X3-81398
  Endif

  Call LECTURE("TCU",DEVLED,"") From CONTOBJ
  [L]ZONE= vireblc(mid$([L]FILLER,141,20),2)
  If val([L]ZONE)=0
   # Montant nul
   If [M]TRC=2 : Call ECR_TRACE(mess(177,117,1),0) From GESECRAN : Endif
  Elsif len([L]ZONE)-[F:TCU]DECNBR<0
   [L]OK=0
   # Format des nombres incorrects - Montant référentiel
   If [M]TRC=2 : Call ECR_TRACE(mess(22,173,1)-"-"-mess(25,173,1),0) From GESECRAN : Endif
  Else
   # Arrondi
   # Issue X3-81398
   # [F:BTI]AMTLOC = val(left$([L]ZONE,len([L]ZONE)-[F:TCU]DECNBR)+"."+right$([L]ZONE,len([L]ZONE)-[F:TCU]DECNBR+1))
   [F:BTI]AMTLOC = val(left$([L]ZONE,len([L]ZONE)-([F:TCU]DECNBR+1))+"."+right$([L]ZONE,len([L]ZONE)-([F:TCU]DECNBR-1)))
   # End issue X3-81398
  Endif

  [F:BTI]OFFREF = vireblc(mid$([L]FILLER,164,10),2)
  [F:BTI]OFFDES = vireblc(mid$([L]FILLER,174,30),2)
  [F:BTI]CODSUP = vireblc(mid$([L]FILLER,204,10),2)   # Type de pièce
  [F:BTI]JOU    = vireblc(mid$([L]FILLER,214,10),2)
  [F:BTI]OPENUM = vireblc(mid$([L]FILLER,232,10),2)


 Else
  # Information 2ème ligne
  [F:BTI]ACC = vireblc(mid$([L]FILLER,1,100),1)
  [F:BTI]DES = vireblc(mid$([L]FILLER,174,30),2)
  [L]ZONE = mid$([L]FILLER,109,1)
  If [L]ZONE="C" : [F:BTI]SNS = -1 : Else [F:BTI]SNS = 1 : Endif
  [F:BTI]REF = vireblc(mid$([L]FILLER,39,13),2)
 Endif


 If [L]INDIC="OK"

  [L]NBPCE += 1
  Write [BTI]
  If fstat
   GOK=0 : Call FSTA("BTI") From GLOCK : Return
  Endif
  Raz [L]INDIC

 Else
  [L]INDIC="OK"
 Endif

 If ![L]OK : Break : Endif
 Gosub LECTURE
Wend

If ![L]NBPCE or ![L]OK
 OK=0
 # Fichier non importé
 If [M]TRC=2 : Call ECR_TRACE(mess(14,173,1),1) From GESECRAN : Endif
Else
 # Fichier importé
 If [M]TRC=2 : Call ECR_TRACE(mess(13,173,1),0) From GESECRAN  : Endif
Endif
Return


#############################################################################
## Ecran BNKTRSIMP
############################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M]VOLFIL, [M]FIC
 Grizo [M]VOLFIL
 End
Else
 [M]VOLFIL = "["+GDIRCASH+"]"
 Actzo [M]VOLFIL
 Affzo [M]VOLFIL
Endif
End

###############################################################################
##  Contrôle du Volume
###############################################################################
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
#Control that the file exists
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FIC,E_TYPE_FILEREAD,GMESSAGE)
End

###############################################################################
##  Contrôle en saisie du paramètre IMPBNKTRSF
###############################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK

Case PARAM
 When "IMPBNKTRSF"
 If VALEUR="" : End : Endif
 # Calling when we define the value in IMPBNKTRSF parameter : this should be value defined as
 # [VOL]\name of file so the TYPEXP = 2 = serveur par défaut
 Local Char FIL(GDIMFIC)
 Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
 mkstat = func ASYRSTO.CTL_VOLFIL(2,VALEUR,[L]FIL,E_TYPE_FOLDER,GMESSAGE)
 If mkstat=2 : OK=0 : Else OK=1 : Endif
Endcase
End

####################################################
## Formules de la pièces automatiques CASH
####################################################
Funprog JOU(PARACC)
Value Char PARACC()
If PARACC="" : End "" : Endif
If clalev([F:JCO])=0 : Local File GJOUCOA [JCO] : Endif
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Local Char PLAN(GLONCOA)
If [F:TB0]CODCPY<>""
 Call LECMAINPLAN(1,[F:TB0]CODCPY,PLAN) From CPTDIV
 Call LEC_CPY([F:TB0]CODCPY) From CPTLEC
Endif
If PLAN<>""
 Filter [JCO] Where [F:JCO]COA=PLAN & [F:JCO]ACC=PARACC & ([F:JCO]LEG=[F:CPY]LEG | [F:JCO]LEG="")
 # "Last" : To read the record which has the CPY's LEG
 Read [JCO] Last
Else
 Filter [JCO] Where [F:JCO]ACC=PARACC
 Read [JCO] First
Endif
Filter [JCO]
If !fstat
 End [F:JCO]JOU
Else
 End ""
Endif
End

