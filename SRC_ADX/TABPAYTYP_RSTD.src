########################################################
## Gestion des textes                                 ##
########################################################
Subprog TEXTE(NUM,VALEUR)
Value    Integer NUM
Variable Char    VALEUR
Local File ATEXTE [ATX]
Local Char LANG(10)
LANG = fmet GACTX.APARAM.AGETVALCHAR(1,"","LANGUAGE")
Read [ATX]NUMERO = LANG;NUM
If fstat=0
 VALEUR = [F:ATX]TEXTE
Else
 Read [ATX]NUMERO = "FRA";NUM
 If fstat=0
  VALEUR = [F:ATX]TEXTE
 Else
  VALEUR = ""
 Endif
Endif
End

