#<AdxTL>@(#)6.0.0.0 $Revision$
# Representation TABPAYTYP
###########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
         When "AREAD_AFTER" : Gosub AREAD_AFTER
    Endcase
   When "TPY"
    Case [L]AEVENT
         When "AREAD_AFTER" : Gosub AREAD_AFTER_TPY
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


##########################################################################################################
$AREAD_AFTER_TPY
Local File ATABZON [ATZ]
Local Integer I

For I=1 To maxtab(this.LISDACSUP)
 Read [ATZ]CODZONE="PAYMENTH";this.LISDACSUP(I).ZONSUP
 If !fstat
  Call TEXTE([F:ATZ]NOCOURT,this.LISDACSUP(I).LIBSUP)
 Endif
 Case this.LISDACSUP(I).DACSUP
   When 1       : this.LISDACSUP(I).DACSUP = 2 : this.LISDACSUP(I).SUPOBL = 2
   When 2       : this.LISDACSUP(I).DACSUP = 2 : this.LISDACSUP(I).SUPOBL = 1
   When Default : this.LISDACSUP(I).DACSUP = 1 : this.LISDACSUP(I).SUPOBL = 1
 Endcase
Next
Return


##########################################################################################################
$AREAD_AFTER
Case this.TPY.DACBAN
  When 1 :       this.TPY.DACBAN = 2 : this.BANOBL = 2
  When 2 :       this.TPY.DACBAN = 2 : this.BANOBL = 1
  When Default : this.TPY.DACBAN = 1 : this.BANOBL = 1
Endcase
Case this.TPY.DACCPY
