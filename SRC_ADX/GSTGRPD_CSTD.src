$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

########################################################################################################################

# 2018-01-18 DNE REMOVED BEGIN
#$ADELETE_CONTROL_BEFORE
#    ASTATUS = fmet this.ASETERROR("", "ADELETE_CONTROL_BEFORE", [V]CST_AERROR)
#Return
# 2018-01-18 DNE REMOVED END

$PROPERTY_CPY
    Case [L]ARULE
        When "CONTROL"   : Gosub PROPERTY_CPY_CONTROL
# 2018-01-09 DNE INSERT BEGIN
        When "PROPAGATE" : Gosub PROPERTY_CPY_PROPAGATE
# 2018-01-09 DNE INSERT END
    Endcase
Return

$PROPERTY_CPY_CONTROL
    #TODO(R): check whether the following is still needed
    If find(this.ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) > 0 Then
        Return
    Endif

    Local File COMPANY [CPY]

    # Optimization for we use the company's database record in CONTROL and PROPAGATE.
    # So it is highly propable that the company record is already loaded.
    Call LEC_CPY( this.CPY ) From CPTLEC
    If fstat = 0
        If [F:CPY]LEG <> "AUS"
            # Company '$1$' must be assigned to the Australian legislation.
            ASTATUS = fmet this.ASETERROR("CPY", func ASYRFNC.MES1(mess(23,7704,1), this.CPY), [V]CST_AERROR)
        Endif
        If [F:CPY]ACCCUR <> "AUD" #X3-75779
            # Accounting currency of company must be 'AUD'.
            ASTATUS = fmet this.ASETERROR("CPY", mess(46,7704,1), [V]CST_AERROR)
        Endif
        If [F:CPY]CPYLEGFLG <> [V]CST_AYES
            # Company '$1$' must be a legal company.
            ASTATUS = fmet this.ASETERROR("CPY", func ASYRFNC.MES1(mess(24,7704,1), this.CPY), [V]CST_AERROR)
        Endif
        If [F:CPY]CRN = ""
            # No ABN number assigned to GST member company '$1$'
            ASTATUS = fmet this.ASETERROR("CPY", func ASYRFNC.MES1(mess(25,7704,1), this.CPY), [V]CST_AERROR)
        Endif
# 2018-03-01 DNE INSERT BEGIN (X3-78886)
        If func AFNC.PARAM( "AUSVAT", [F:CPY]CPY ) <> "2" # Parameter "AUSVAT" not set for company.
            # 'Paramter $1$ is not acitve for $2$.'
            ASTATUS = fmet this.ASETERROR( "CPY", func ASYRFNC.MES2(mess(47,7704,1), "AUSVAT", this.CPY ), [V]CST_AERROR )
        Endif
# 2018-03-01 DNE INSERT END
    Endif
Return

# 2018-01-09 DNE INSERT BEGIN
PROPERTY_CPY_PROPAGATE
    Local File COMPANY [CPY]

    # Optimization for we use the company's database record in CONTROL and PROPAGATE.
    Call LEC_CPY( this.CPY ) From CPTLEC

    # Fill fields.
    If !fstat
        this.ABN = [F:CPY]CRN
    Endif
Return
# 2018-01-09 DNE INSERT END

$PROPERTY_DATFOR
    Case [L]ARULE
        When "CONTROL" : Gosub PROPERTY_DATFOR_CONTROL
    Endcase
Return

$PROPERTY_DATFOR_CONTROL
# 2018-01-10 DNE INSERT BEGIN
    If ( this.DATFOR = [0/0/0] ) or ( this.DATCES = [0/0/0] )
        Return
    Endif
# 2018-01-10 DNE INSERT END

    #TODO(R): check whether the following is still needed
    If find(this.ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) > 0
        Return
    Endif
    If this.DATFOR > this.DATCES Then
        # Formation date has to be prior to the cessation date.
        ASTATUS = fmet this.ASETERROR("DATFOR", mess(26,7704,1), [V]CST_AERROR)
    Endif
Return

########################################################################################################################

