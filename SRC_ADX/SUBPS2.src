#<AdxTL>@(#)6.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Call OBJET("PS2",GBIDC1,GBIDC2) From GOBJET
End

############################################################
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "CREATION"      : Gosub CREATION
 When "MODIF"         : Gosub MODIF
 When "VERIF_CRE"     : Gosub VERIF_CRE
 When "VERIF_MOD"     : Gosub VERIF_MOD
 When "APRES_CRE"     : Gosub APRES_CRE
 When "APRES_MOD"     : Gosub APRES_MOD
 When "INICRE"        : Gosub INICRE
 When "LIENS"         : Gosub LIENS
 When "SETBOUT"       : Gosub SETBOUT
 When "EXEBOUT"       : Gosub EXEBOUT
 When "ANNULE"        : Gosub ANNULE
 When "CHANGE"        : Gosub CHANGE
 When "AV_ANNULE"     : Gosub AV_ANNULE
 When "AP_ANNULE"     : Gosub AP_ANNULE
 When "AP_CHANGE"     : Gosub AP_CHANGE
 When "SEL_LISTE"     : Gosub SEL_LISTE
 When "VERF_LISTE"    : Gosub VERF_LISTE
Endcase
Return

############################################################
$OUVRE
Local Char DECLENCHE(GLONPS1)
Read [ACN]ACN0 = "STA"
Return

# Added by Dom Nov 25, 2011 for Syracuse
Funprog PREFIX_TRT_PROTO
Gosub PREFIXE
End "W"+LETTRE+PFIX3

$PREFIXE
Local Char LETTRE(1) , PFIX1(3) , PFIX2(3), PFIX3(3)
LETTRE = "M"
PFIX1  = "STT"
PFIX2  = "STA"
PFIX3  = "STS"
Return

############################################################
$SETBOUT
If !CLECUR or REP<>"" or !VERROU
 Call VIREBOUT(CHAINE,"12") From GOBJET
Endif
If CLECUR
 Local Integer OKACC
 Call LECACC([F:PS2]ACS,OKACC) From SUBACS
 If !OKACC
  Call VIREBOUT(CHAINE,"MAH") From GOBJET
 Endif
Endif
Return

############################################################
$INICRE
Raz [F:PS2]LSTDAT
Effzo [M:PS21]LSTDAT
Return

############################################################
$EXEBOUT
Case REP
 When "1" : Gosub VALID
Endcase
Return

############################################################
$VALID
Call LECTURE("PS2",[M]COD,"") From CONTOBJ
Call TEMPON("V") From GESECRAN
If DECLENCHE<>"" & DECLENCHE<>[M]RLG
 Call MAJTRT2(DECLENCHE,nomap,0)
 DECLENCHE = [M]RLG
Endif
Call MAJTRT1([M]COD,nomap,0)
Call MAJTRT2([M]RLG,nomap,0)
Call MAJTRT3([M]COD,nomap,0) From SUBPS6
Call TEMPOFF From GESECRAN
If GERR & dim([M:PS21]ENAFLG)>0
 Read [PS2]PS20 = CLECUR1
 [M]ENAFLG = [F:PS2]ENAFLG
 Affzo [PS21]ENAFLG
Endif
Return

############################################################
$APRES_CRE
DECLENCHE = ""
Gosub VALID
Return

############################################################
$APRES_MOD
Gosub VALID
Return

############################################################
$AV_ANNULE
Local Char DECLENCHE(GLONPS1)
DECLENCHE = [F:PS2]RLG
Return

############################################################
$AP_ANNULE
Local Char FIC1(250) , NOMTRT(GLONADC)
Local Integer SYSTA
Gosub PREFIXE
NOMTRT = "W"+LETTRE+PFIX2+CODE
FIC1 = filpath("TRT",NOMTRT,"src",[L]APPLI)
If filinfo(FIC1,0)>=0
 Call EFFACE(FIC1,SYSTA) From ORDSYS
Endif
Call EFFACE_ADX("",[L]APPLI,NOMTRT,SYSTA) From ORDSYS
Call MAJTRT2(DECLENCHE,nomap,0)
Return

############################################################
$AP_CHANGE
Local Char FIC1(250) , NOMTRT(GLONADC)
Local Integer SYSTA
Gosub PREFIXE
NOMTRT = "W"+LETTRE+PFIX2+OCODE
FIC1 = filpath("TRT",NOMTRT,"src",APPLI)
If filinfo(FIC1,0)>=0
 Call EFFACE(FIC1,SYSTA) From ORDSYS
Endif
Call EFFACE_ADX("",APPLI,NOMTRT,SYSTA) From ORDSYS
Call MAJTRT1(NCODE,APPLI,0)
If clalev([F:PS2])=0 : Local File PARSTA2 [PS2] : Endif
Read [PS2]PS20=NCODE
If !fstat
 Call MAJTRT2([F:PS2]RLG,APPLI,0)
Endif
Return

$ANNULE
Delete [AXX] Where CODFIC="PARSTA2" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Delete [AXX] Where CODFIC="PARSTALIG" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

$CHANGE
Update [AXX] Where CODFIC="PARSTA2" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA PARSTA2"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Update [AXX] Where CODFIC="PARSTALIG" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA PARSTALIG"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

########################################
$LIENS
Call LECTURE("PS1",[F:PS2]RLG,"") From CONTOBJ
DECLENCHE = [F:PS2]RLG
Read [ATB]CODFIC = [F:PS1]RLGTBL
[M]NBABR = 1
[M]ABREV(1) = [F:ATB]ABRFIC
For I=0 To [F:PS1]NBRTBL-1
 If [F:PS1]ABRLNK<>""
  ABR = [F:PS1]ABRLNK
 Else
  Read [ATB]CODFIC = [F:PS1]TBL(I)
  ABR = [F:ATB]ABRFIC
 Endif
 If !find(ABR,[M]ABREV(1..[M]NBABR))
  [M]NBABR += 1 : [M]ABREV([M]NBABR) = ABR
 Endif
Next I
For I=0 To [F:PS2]NBRFLD-1
 [M]FLDNUM(I) = I+1
 If [F:PS2]TBLABR<>""
  ABR = [F:PS2]TBLABR
 Else
  Read [ATB]CODFIC = [F:PS2]TBL(I)
  ABR = [F:ATB]ABRFIC
 Endif
 If !find(ABR,[M]ABREV(1..[M]NBABR))
  [M]NBABR += 1 : [M]ABREV([M]NBABR) = ABR
 Endif
Next I
nolign = 0
For [PSL] Where COD=[F:PS2]COD
 nolign += 1
 [M:PS22] = [F:PSL]
 If [M:PS22]VARNAM(nolign-1)<>""
  I = find([M:PS22]VARNAM(nolign-1),[F:PS1]VARNAM)
  If I
   Call LECTEXTRA([M:PS22]AMTDES(nolign-1),"PARSTA1","VARINTIT",[F:PS1]COD,num$(I)) From ATEXTRA
  Endif
  [M:PS22]NUMVAR(nolign-1) = 0
 Else
  [M:PS22]NUMVAR(nolign-1) = nolign
  Call LECTEXTRA([M:PS22]AMTDES(nolign-1),"PARSTALIG","INTITVAR",[M:PS20]COD,num$(nolign)) From ATEXTRA
 Endif
Next
[M:PS22]NBRAMT = nolign
For I=0 To [M]NBRFRM-1
 [M]NUMFRM(I) = I+1
Next
Call GRISE_PERTYP([F:PS2]PERPRG)
Call GRISE_UPDLEV([F:PS2]RLG)
Return

########################################
$CREATION
For nolign=1 To [M]NBRAMT
 [F:PSL] = [M:PS22]
 [F:PSL]COD = [F:PS2]COD
 [F:PSL]NUMLIG = nolign
 Write [PSL]
 If fstat
  GOK=0 : Call FSTA("PSL") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
Call MAJTEXTRA([M:PS20]INTIT,"PARSTA2","INTIT",[M:PS20]COD,"") From ATEXTRA
Call MAJTEXTRA([M:PS20]INTSHO,"PARSTA2","INTSHO",[M:PS20]COD,"") From ATEXTRA

# Duplication
If GREP ="D"
 For I=0 To [M:PS22]NBRFLD-1
  Call DUPTEXTRA("PARSTA2","FLDINTIT",CLECUR1,num$([M]FLDNUM(I)),"PARSTA2","FLDINTIT",[M:PS20]COD,num$(I+1)) From ATEXTRA
 Next I
 For I=0 To [M:PS23]NBRFRM-1
  Call DUPTEXTRA("PARSTA2","INTITFRM",CLECUR1,num$([M]NUMFRM(I)),"PARSTA2","INTITFRM",[M:PS20]COD,num$(I+1)) From ATEXTRA
 Next I
 For I=0 To [M:PS22]NBRAMT-1
  If [M:PS22]VARNAM(I)=""
   Call DUPTEXTRA("PARSTALIG","INTITVAR",CLECUR1,num$([M]NUMVAR(I)),"PARSTALIG","INTITVAR",[M:PS20]COD,num$(I+1)) From ATEXTRA
  Endif
 Next I
 Return
Endif

# Sauvegarde des textes avant modif (intitulés des champs)
For I=0 To [M:PS22]NBRFLD-1
 If [M]FLDNUM(I)<>0
  Call DUPTEXTRA("PARSTA2","FLDINTIT",[M:PS20]COD,num$([M]FLDNUM(I)),"PARSTA2","FLDINTIT"
&  ,[M:PS20]COD,chr$(255)+num$(I+1)) From ATEXTRA
 Endif
Next
# Suppression des anciens textes (intitulés des champs)
Delete [AXX] Where CODFIC="PARSTA2" & ZONE="FLDINTIT" & IDENT1=[M:PS20]COD & left$(IDENT2,1)<>chr$(255)
If fstat=1
 GOK=-1 : Call RSTA("AXX","PARSTA2"-[M:PS20]COD) From GLOCK : Return
Endif
# Restauration des textes qui ont été conservés (intitulés des champs)
Update [AXX] Where CODFIC="PARSTA2" & ZONE="FLDINTIT" & IDENT1=[M:PS20]COD & left$(IDENT2,1)=chr$(255)
&            With [AXX]IDENT2 = right$([AXX]IDENT2,2)
If fstat=1
 GOK=-1 : Call RSTA("AXX","PARSTA2"-[M:PS20]COD) From GLOCK : Return
Endif
# Mise à jour des nouveaux textes (intitulés des champs)
For I=0 To [M:PS22]NBRFLD-1
 Call MAJTEXTRA([M:PS22]FLDINTIT(I),"PARSTA2","FLDINTIT",[M:PS20]COD,num$(I+1)) From ATEXTRA
 [M:PS22]FLDNUM(I) = I+1
Next I

# Sauvegarde des textes avant modif (intitulés des colonnes)
For I=0 To [M:PS23]NBRFRM-1
 If [M]NUMFRM(I)<>0
  Call DUPTEXTRA("PARSTA2","INTITFRM",[M:PS20]COD,num$([M]NUMFRM(I)),"PARSTA2","INTITFRM"
&  ,[M:PS20]COD,chr$(255)+num$(I+1)) From ATEXTRA
 Endif
Next
# Suppression des anciens textes (intitulés des colonnes)
Delete [AXX] Where CODFIC="PARSTA2" & ZONE="INTITFRM" & IDENT1=[M:PS20]COD & left$(IDENT2,1)<>chr$(255)
If fstat=1
 GOK=-1 : Call RSTA("AXX","PARSTA2"-[M:PS20]COD) From GLOCK : Return
Endif
# Restauration des textes qui ont été conservés (intitulés des colonnes)
Update [AXX] Where CODFIC="PARSTA2" & ZONE="INTITFRM" & IDENT1=[M:PS20]COD & left$(IDENT2,1)=chr$(255)
&            With [AXX]IDENT2 = right$([AXX]IDENT2,2)
If fstat=1
 GOK=-1 : Call RSTA("AXX","PARSTA2"-[M:PS20]COD) From GLOCK : Return
Endif
# Mise à jour des nouveaux textes (intitulés des colonnes)
For I=0 To [M:PS23]NBRFRM-1
 Call MAJTEXTRA([M:PS23]INTITFRM(I),"PARSTA2","INTITFRM",[M:PS20]COD,num$(I+1)) From ATEXTRA
 [M:PS23]NUMFRM(I) = I+1
Next I

# Sauvegarde des textes avant modif (intitulés des variables)
For I=0 To [M:PS22]NBRAMT-1
 If [M]NUMVAR(I)<>0
  Call DUPTEXTRA("PARSTALIG","INTITVAR",[M:PS20]COD,num$([M]NUMVAR(I)),"PARSTALIG","INTITVAR"
&  ,[M:PS20]COD,chr$(255)+num$(I+1)) From ATEXTRA
 Endif
Next
# Suppression des anciens textes (intitulés des variables)
Delete [AXX] Where CODFIC="PARSTALIG" & ZONE="INTITVAR" & IDENT1=[M:PS20]COD & left$(IDENT2,1)<>chr$(255)
If fstat=1
 GOK=-1 : Call RSTA("AXX","PARSTALIG"-[M:PS20]COD) From GLOCK : Return
Endif
# Restauration des textes qui ont été conservés (intitulés des variables)
Update [AXX] Where CODFIC="PARSTALIG" & ZONE="INTITVAR" & IDENT1=[M:PS20]COD & left$(IDENT2,1)=chr$(255)
&            With [AXX]IDENT2 = right$([AXX]IDENT2,2)
If fstat=1
 GOK=-1 : Call RSTA("AXX","PARSTALIG"-[M:PS20]COD) From GLOCK : Return
Endif
# Mise à jour des nouveaux textes (intitulés des variables)

For I=0 To [M:PS22]NBRAMT-1
 If [M:PS22]VARNAM(I)=""
  Call MAJTEXTRA([M:PS22]AMTDES(I),"PARSTALIG","INTITVAR",[M:PS20]COD,num$(I+1)) From ATEXTRA
  [M:PS22]NUMVAR(I) = I+1
 Endif
Next I
Return

########################################
$MODIF
Delete [PSL] Where COD=[F:PS2]COD
If fstat=1
 GOK=-1 : Call RSTA("PSL",[F:PS2]COD) From GLOCK
Else
 Gosub CREATION
Endif
Return

########################################
$VERIF_CRE
$VERIF_MOD
If [M]NBRFRM=0
 [M]NBRFRM = [M]NBRAMT
 For I=0 To [M]NBRAMT-1
  [M]INTITFRM(I) = [M]AMTDES(I)
  [M]AMTFRM(I) = "C"+num$(I+1)
  [M]CUMFRM(I) = 1
 Next I
 Affzo NBRFRM, INTITFRM, AMTFRM, CUMFRM
Endif
Return

############################################################
$SEL_LISTE
Case LISTE
 When "PS2SELVAR"
  Call LECTURE("PS1",PARAM(1),"") From CONTOBJ
  For I=1 To [F:PS1]NBRVAR
   TEX(I)   = [F:PS1]VARNAM(I-1)
   TEXTE(I) = format$("K:11X",[F:PS1]VARNAM(I-1))+func AFNC.TEXTRA("PARSTA1","VARINTIT",[F:PS1]COD,num$(I))
  Next I
  NBTEX = [F:PS1]NBRVAR
 When "PS2SELFRM"
  Local Char OVAL(80) : OVAL = VALEUR
  NBTEX = 0
  For I=1 To [M]NBRAMT
   NBTEX += 1
   TEX(NBTEX) = "C"+num$(I)
   TEXTE(NBTEX) = TEX(NBTEX) - [M]AMTDES(I-1)
  Next I
  For I=1 To [M]NBRAMT
   If [M]FRTFLG(I-1)=2
    NBTEX += 1
    TEX(NBTEX) = "P"+num$(I)
    TEXTE(NBTEX) = TEX(NBTEX) - [M]AMTDES(I-1)-mess(102,126,1) : # (prévisions)
   Endif
  Next I
  For I=1 To [M]NBRAMT
   NBTEX += 1
   TEX(NBTEX) = "CC"+num$(I)
   TEXTE(NBTEX) = TEX(NBTEX) - [M]AMTDES(I-1)-mess(103,126,1) : # (n-1)
  Next I
  For I=1 To [M]NBRAMT
   If [M]FRTFLG(I-1)=2
    NBTEX += 1
    TEX(NBTEX) = "PP"+num$(I)
    TEXTE(NBTEX) = TEX(NBTEX) - [M]AMTDES(I-1)-mess(104,126,1) : # (prévisions n-1)
   Endif
  Next I
Endcase
Return

############################################################
$VERF_LISTE
Case LISTE
 When "PS2SELFRM"
  VALEUR = OVAL+VALEUR
Endcase
mkstat = 2
Return

#########################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File PARSTA2   [PS21]
 Local File PARSTALIG [PSL1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".PARSTA2"   [PS21]
 Local File =[M]DOSORG+".PARSTALIG" [PSL1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File PARSTA2   [PS22]
 Local File PARSTALIG [PSL2]
 Local File ATEXTRA   [AXX2]
Else
 Local File =[M]DOSDES+".PARSTA2"   [PS22]
 Local File =[M]DOSDES+".PARSTALIG" [PSL2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Local Integer I
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [PS21] , [PS22] , [PSL1] , [PSL2], [AXX1] , [AXX2] , [ADS1] , [ADS2]
Return

$TR_COP
GOK = 1
Trbegin [PS22]
 Delete [PS22] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".PARSTA2" : Goto ROLL_TR_COP
 Endif
 Delete [PSL2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".PARSTALIG" : Goto ROLL_TR_COP
 Endif
 Delete [AXX2] Where CODFIC="PARSTA2" & IDENT1=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATEXTRA" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AXX2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AXX2] Where CODFIC="PARSTALIG" & IDENT1=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATEXTRA" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AXX2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [PS21]PS20 Where COD=TABLE
  [F:PS22] = [F:PS21]
  Call COPTEXTRA("PARSTA2","INTIT",[F:PS22]COD,"") From ATEXTRA
  Call COPTEXTRA("PARSTA2","INTSHO",[F:PS22]COD,"") From ATEXTRA
  For I=1 To [F:PS22]NBRFLD
   Call COPTEXTRA("PARSTA2","FLDINTIT",[F:PS22]COD,num$(I)) From ATEXTRA
  Next I
  For I=1 To [F:PS22]NBRFRM
   Call COPTEXTRA("PARSTA2","INTITFRM",[F:PS22]COD,num$(I)) From ATEXTRA
  Next I
  If dim([F:PS22]UPDUSR)>0 : [F:PS22]UPDUSR = GUSER : Endif
  If dim([F:PS22]UPDDAT)>0 : [F:PS22]UPDDAT = date$ : Endif
  Write [PS22]
  If fstat
   GOK=0 : Call FSTA("PS22") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 I = 0
 For [PSL1]PSL0 Where COD=TABLE
  I += 1
  [F:PSL2] = [F:PSL1]
  If [F:PSL2]VARNAM=""
   Call COPTEXTRA("PARSTALIG","INTITVAR",[F:PS22]COD,num$(I)) From ATEXTRA
  Endif
  Write [PSL2]
  If fstat
   GOK=0 : Call FSTA("PSL2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If ! GROLL : Goto TR_COP : Endif
Return

#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
If APPLI=GDOSX3 : End : Endif
# Validation transactions depuis génération des patchs
Call GENDOS(APPLI)
End

#########################################################
## Pg de mise à jour globale
#########################################################
Subprog GENDOS(APPLI)
Value Char    APPLI
Local Integer OK, I
If clalev([F:PS1])=0  : Local File =APPLI+".PARSTA1"    [PS1]  : Endif
If clalev([F:PS2])=0  : Local File =APPLI+".PARSTA2"    [PS2]  : Endif
If clalev([F:PSL])=0  : Local File =APPLI+".PARSTALIG"  [PSL]  : Endif
If clalev([F:ATB])=0  : Local File =APPLI+".ATABLE"     [ATB]  : Endif
If clalev([F:ATZ])=0  : Local File =APPLI+".ATABZON"    [ATZ]  : Endif
If clalev([F:ATI])=0  : Local File =APPLI+".ATABIND"    [ATI]  : Endif
If clalev([F:ATY])=0  : Local File =APPLI+".ATYPE"      [ATY]  : Endif
If clalev([F:PS22])=0 : Local File =APPLI+".PARSTA2"    [PS22] : Endif
If clalev([F:AOB])=0  : Local File =APPLI+".AOBJET"     [AOB]  : Endif
If clalev([F:SAT])=0  : Local File =APPLI+".STAT"       [SAT]  : Endif
If clalev([F:AMP])=0  : Local File =APPLI+".AMSKPAR"    [AMP]  : Endif
If clalev([F:ACV])=0  : Local File =APPLI+".ACTIV"      [ACV]  : Endif

For [PS22]
 Call ECR_TRACE([F:PS22]COD,0) From GESECRAN
 Read [PS2]PS20=[F:PS22]COD
 Call MAJTRT1([F:PS22]COD,APPLI,1)
 Call MAJTRT2([F:PS22]RLG,APPLI,1)
 Call MAJTRT3([F:PS22]COD,APPLI,1) From SUBPS6
Next
Close Local File
End

#-------------------------------------------------------#
# Pg de mise à jour
#-------------------------------------------------------#

## Traitement associé au code

Subprog MAJTRT1(CODE,DOSSIER,SILENCE)
Value Char CODE
Value Char DOSSIER
Value Integer SILENCE

Local Integer I , J , K , K1 , K2 , C , NBFIC , STAT , OKVAL
Local Char    TBFIC(GLONATB)(1..30) , ABFIC(GLONABR)(0..30) , MESSAGE(250)
Local Char    CLFIC(GLONATB)(0..30) , LNKFIC(80)(0..30) , TBAFIC(30)(1..30)
Local Integer LIEN(1..30)
Local Integer FLLIEN
Local Char    EXPLIEN(250) , CHAINE(250) , SCHAINE(250) , TEXTE(30)
Local Char    NOMTRT(GLONADC) , FICTRT(250)
Local Char    CLE(17)(1..16) , DESCLE(250) , CHTEST(250)
Local Char    ABR(GLONABR)
Local Integer NBCLE
Local Char    MAGIC(80)
Local Char    CLE(GLONID1)(1..16)
Local Integer MAXCRI : MAXCRI = dim([F:PS2]TBL)
Local Char    INTIT(80)(MAXCRI) , INTFIC(GLONATB)(MAXCRI) , INTABR(5)(MAXCRI)
Local Char    INTLIEN(250)(MAXCRI) , INTCLE(GLONANX)(MAXCRI)
Local Char    INTTYP(5)(MAXCRI)
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)
Local Integer TT , OKZOOM , SPA
Local Char    OBJET(GLONAOB) , TABLE(GLONATB) , ACTION(20) , OBJET2(GLONAOB)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If clalev([F:PS1])=0 : Local File PARSTA1    [PS1] : Endif
If clalev([F:PS2])=0 : Local File PARSTA2    [PS2] : Endif
If clalev([F:PSL])=0 : Local File PARSTALIG  [PSL] : Endif
If clalev([F:ATB])=0 : Local File ATABLE     [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE      [ATY] : Endif
If clalev([F:ATI])=0 : Local File ATABIND    [ATI] : Endif
If clalev([F:AOB])=0 : Local File AOBJET     [AOB] : Endif
If clalev([F:SAT])=0 : Local File STAT       [SAT] : Endif
If clalev([F:AMP])=0 : Local File AMSKPAR    [AMP] : Endif

MAGIC  = mess(77,133,1) : # Superviseur Adonix
Gosub PREFIXE
NOMTRT = "W"+LETTRE+PFIX2+CODE
FICTRT = filpath("TRT",NOMTRT,"src",APPLI,"",MACHINE)

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

adxifs = ""
adxirs = chr$(10)
adxium = GUTF8

If !SILENCE
 Call TEMPON(mess(159,133,1)-NOMTRT) From GESECRAN : # Validation du traitement
Endif

OKVAL = 1
Gosub TRT_INI1
If !OKVAL
 Call ECR_TRACE(MESSAGE,-1) From GESECRAN
 Gosub DESACTIVE
Else
 Gosub TRT_DEB1
 Gosub ETIQUETTE1
 Gosub TRT_FIN1
 If !OKVAL
  Call ECR_TRACE(MESSAGE,1) From GESECRAN
  Gosub DESACTIVE
 Else
  Call VALID("TRT",NOMTRT,DOSSIER,STAT) From VALMSKSUB
 Endif
Endif

If !SILENCE
 Call TEMPOFF From GESECRAN
Endif

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

End

#--------------------------------------------------------------#
## Désactivation d'une stat en erreur
#--------------------------------------------------------------#

$DESACTIVE
If !adxlog
 Gosub TR_STAT
Else
 Gosub MAJ_STAT
Endif
If GOK=1
 Call ECR_TRACE(CODE-":"-mess(62,139,1),-1) From GESECRAN : # Fiche désactivée
 GERR = 1
Endif
Return

$TR_STAT
GOK=1
Trbegin [PS2]
 Gosub MAJ_STAT
 If GOK<0 : Goto AB_TR_STAT : Endif
Commit
Return

$AB_TR_STAT
Rollback
Return

$MAJ_STAT
Readlock [PS2]PS20 = CODE
If fstat=1
 GOK = -1 : GLOCK = "$PARSTA2"
Else
 [F:PS2]ENAFLG = 1
 Rewrite [PS2]
 If fstat
  GOK = 0 : Call FSTA("PS2") From GLOCK
 Endif
Endif
Return

#-------------------------------------------------------#
$TRT_DEB1
Openo FICTRT , 0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq "#"-mess(6,124,1)-CODE : # Mise à jours statistique
Wrseq
Return

#-------------------------------------------------------#
$TRT_FIN1
Wrseq
Openo
Return

#-------------------------------------------------------#
$TRT_INI1

Read [PS2]PS20 = CODE
Read [PS1]PS10 = [F:PS2]RLG
If fstat
 MESSAGE = [F:PS2]RLG-":"-mess(62,126,1) : # Déclencheur statistique
 OKVAL = 0 : Return
Endif

# Recherche des tables à ouvrir

NBFIC = 0
For I=0 To [F:PS1]NBRTBL-1
 If [F:PS1]TBL(I)<>[F:PS1]RLGTBL
  If [F:PS1]ABRLNK(I)<>""
   ABR = [F:PS1]ABRLNK(I)
  Else
   Read [ATB]CODFIC = [F:PS1]TBL(I)
   If fstat
    MESSAGE = [F:PS1]TBL(I)-":"-mess(124,124,1) : # Table inexistante
    OKVAL = 0 : Break
   Endif
   ABR = [F:ATB]ABRFIC
  Endif
  If !find(ABR,ABFIC(1..NBFIC))
   NBFIC += 1
   TBFIC(NBFIC)  = [F:PS1]TBL(I)
   LNKFIC(NBFIC) = [F:PS1]EXPLNK(I)
   ABFIC(NBFIC)  = ABR
   CLFIC(NBFIC)  = [F:PS1]CLELNK(I)
   TBAFIC(NBFIC) = [F:PS1]TBL(I)+"~"+ABR
  Endif
 Endif
Next I
If !OKVAL : Return : Endif
For I=0 To [F:PS2]NBRFLD-1
 If [F:PS2]TBL(I)<>[F:PS1]RLGTBL
  If [F:PS2]TBLABR(I)<>""
   ABR = [F:PS2]TBLABR(I)
  Else
   Read [ATB]CODFIC = [F:PS2]TBL(I)
   If fstat
    MESSAGE = [F:PS2]TBL(I)-":"-mess(124,124,1) : # Table inexistante
    OKVAL = 0 : Break
   Endif
   ABR = [F:ATB]ABRFIC
  Endif
  If !find(ABR,ABFIC(1..NBFIC))
   NBFIC += 1
   TBFIC(NBFIC)  = [F:PS2]TBL(I)
   ABFIC(NBFIC)  = ABR
   LNKFIC(NBFIC) = ""
   TBAFIC(NBFIC) = [F:PS2]TBL(I)+"~"+ABR
  Endif
 Endif
Next I
If !OKVAL : Return : Endif
For I=0 To [F:PS2]NBRFLD-1
 Read [ATZ]CODZONE = [F:PS2]TBL(I);[F:PS2]FLDNAM(I)
 If fstat
  # Champ $1$ inexistant dans la table $2$
  MESSAGE = func AFNC.MES2(mess(222,115,1),[F:PS2]FLDNAM(I),[F:PS2]TBL(I))
  OKVAL = 0 : Break
 Endif
 If [F:ATZ]LIEN<>""
  If [F:PS2]TBLABR(I)<>""
   ABR = [F:PS2]TBLABR(I)
  Else
   Read [ATB]CODFIC = [F:PS2]TBL(I)
   If fstat
    MESSAGE = [F:PS2]TBL(I)-":"-mess(124,124,1) : # Table inexistante
    OKVAL = 0 : Break
   Endif
   ABR = [F:ATB]ABRFIC
  Endif
  J = find([F:ATZ]LIEN+"~"+ABR,TBAFIC(1..NBFIC))
  If [F:ATZ]LIEN<>[F:PS1]RLGTBL & J=0
   If [F:ATZ]EXPLIEN=""
    INTLIEN(I) = "[F:"+ABR+"]"+[F:PS2]FLDNAM(I)
    If [F:PS2]FLDIND(I)<>0
     INTLIEN(I) += "("+num$([F:PS2]FLDIND(I))+")"
    Endif
   Else
    CHAINE = vireblc(format$("KT:120X",[F:ATZ]EXPLIEN),2)
    INTLIEN(I) = ""
    While CHAINE<>""
     J = instr(1,CHAINE,";")
     If J
      SCHAINE = left$(CHAINE,J-1) : CHAINE = right$(CHAINE,J+1)
     Else
      SCHAINE = CHAINE : CHAINE = ""
     Endif
     If SCHAINE>="A" & left$(SCHAINE,1)<="Z"
      SCHAINE = "[F:"+ABR+"]"+SCHAINE
     Endif
     Repeat
      J = instr(1,SCHAINE,"indice")
      If J
       SCHAINE = left$(SCHAINE,J-1)+num$([F:PS2]FLDIND(I))+right$(SCHAINE,J+6)
      Endif
     Until J=0
     If INTLIEN(I)<>"" : INTLIEN(I) += ";" : Endif
     INTLIEN(I) += SCHAINE
    Wend
   Endif
   Read [ATB]CODFIC = [F:ATZ]LIEN
   If fstat
    MESSAGE = [F:ATZ]LIEN-":"-mess(124,124,1) : # Table inexistante
    OKVAL = 0 : Break
   Else
    INTABR(I) = [F:ATB]ABRFIC
   Endif
  Else
   Read [ATB]CODFIC = [F:ATZ]LIEN
   If fstat
    MESSAGE = [F:ATZ]LIEN-":"-mess(124,124,1) : # Table inexistante
    OKVAL = 0 : Break
   Else
    If ABFIC(J)<>""
     INTABR(I) = ABFIC(J)
    Else
     INTABR(I) = [F:ATB]ABRFIC
    Endif
   Endif
  Endif
  Read [ATI]NUMLIG(2) = [F:ATB]CODFIC;1
  INTFIC(I) = [F:ATB]CODFIC
  INTCLE(I) = [F:ATI]CODIND
 Else
  Read [ATB]CODFIC = [F:PS2]TBL(I)
  INTFIC(I) = [F:PS2]TBL(I)
  If [F:PS2]TBLABR(I)<>""
   INTABR(I) = [F:PS2]TBLABR(I)
  Else
   INTABR(I) = [F:ATB]ABRFIC
  Endif
 Endif
 If [F:ATZ]NOLIB<>0 : # mb 13.11.02 bug 16358
  INTIT(I) = "mess([F:"+INTABR(I)+"]"+[F:ATZ]CODZONE+","+num$([F:ATZ]NOLIB)+",1)"
 Elsif [F:ATB]INTIT<>""
  Read [ATZ]CODZONE = [F:ATB]CODFIC;[F:ATB]INTIT
  INTIT(I) = "[F:"+INTABR(I)+"]"+[F:ATB]INTIT
 Elsif [F:ATB]INTITC<>""
  Read [ATZ]CODZONE = [F:ATB]CODFIC;[F:ATB]INTITC
  INTIT(I) = "[F:"+INTABR(I)+"]"+[F:ATB]INTITC
 Endif
 INTTYP(I) = [F:ATZ]CODTYP
Next I
If !OKVAL : Return : Endif
For I=1 To NBFIC
 If ABFIC(I)=""
  Read [ATB]CODFIC = TBFIC(I)
  If fstat
   MESSAGE = TBFIC(I)-":"-mess(124,124,1) : # Table inexistante
   OKVAL = 0 : Break
  Endif
  ABFIC(I) = [F:ATB]ABRFIC
 Endif
 If CLFIC(I)=""
  Read [ATI]NUMLIG(2) = TBFIC(I);1
  CLFIC(I) = [F:ATI]CODIND
 Endif
Next I
Read [ATB]CODFIC = [F:PS1]RLGTBL
If fstat
 MESSAGE = [F:PS1]RLGTBL-":"-mess(124,124,1) : # Table inexistante
 OKVAL = 0 : Return
Endif
ABFIC(0) = [F:ATB]ABRFIC
Read [ATI]NUMLIG(2) = [F:PS1]RLGTBL;1
CLFIC(0) = [F:ATI]CODIND
Return

#-------------------------------------------------------#
$ETIQUETTE1

Wrseq "Subprog MAJSTA(SIGN)"
Wrseq "Value Integer SIGN"
Wrseq
Wrseq "Local Char    CRIT1(20) , CRIT2(20) , CRIT3(20) , CRIT4(20)"
Wrseq "Local Char    CRIT5(20) , CRIT6(20) , CRIT7(20) , CRIT8(20)"
Wrseq "Local Char    SOCIETE(GLONCPY) , SITE(GLONFCY) , VALPAR(10)"
Wrseq "Local Char    INTIT(50)(1.."+num$(MAXCRI)+")"
Wrseq "Local Date    DAT"
Wrseq "Local Decimal MONTANT(1..10)"
Wrseq "Local Integer ISITE , ISOC , STAT , COURTYP"
Wrseq

# Ouverture des fichiers

Wrseq "Gosub OUVRE"
Wrseq

# Société, site

Case [F:PS2]UPDLEV
 When 1 : # Dossier
  Wrseq 'SOCIETE = ""'
  Wrseq 'SITE    = ""'
 When 2
  Gosub SETSOC
  Wrseq 'SITE    = ""'
 When 3
  Gosub SETSOC
  Wrseq 'SITE    = [F:'+[F:PS1]FCYTBL+"]"+[F:PS1]FCYFLD
Endcase
Wrseq

# Etablissement des liens

Wrseq "Gosub LIENS"

# Date de validité

VARIA = "[F:"+ABFIC(0)+"]"+[F:PS1]DATFLD
If [F:PS2]VLYSTR<>[0/0/0]
 Wrseq "If "+VARIA+"<["+format$(GFMD,[F:PS2]VLYSTR)+"] : End : Endif"
Endif
If [F:PS2]VLYEND<>[0/0/0]
 Wrseq "If "+VARIA+">["+format$(GFMD,[F:PS2]VLYEND)+"] : End : Endif"
Endif
Wrseq

# Critères de déclenchement

For I=0 To dim([F:PS1]CRI)-1
 If [F:PS1]CRI(I)<>""
  Wrseq "If !("+vireblc(format$("KT:255X",[F:PS1]CRI(I)),2)+")"
  Wrseq " End"
  Wrseq "Endif"
 Endif
Next I
For I=0 To dim([F:PS2]CRI)-1
 If [F:PS2]CRI(I)<>""
  Wrseq "If !("+vireblc(format$("KT:255X",[F:PS2]CRI(I)),2)+")"
  Wrseq " End"
  Wrseq "Endif"
 Endif
Next I
Wrseq

# Evaluation des critères

Wrseq 'Raz CRIT1 , CRIT2 , CRIT3 , CRIT4 , CRIT5 , CRIT6 , CRIT7 , CRIT8'
For I=0 To [F:PS2]NBRFLD-1
 If [F:PS2]TBL(I)=[F:PS1]RLGTBL
  ABR = ABFIC(0)
 Elsif [F:PS2]TBLABR(I)<>""
  ABR = [F:PS2]TBLABR(I)
 Else
  Read [ATB]CODFIC = [F:PS2]TBL(I)
  ABR = [F:ATB]ABRFIC
 Endif
 VARIA = "[F:"+ABR+"]"+[F:PS2]FLDNAM(I)
 If [F:PS2]FLDIND(I)<>0
  VARIA += "("+num$([F:PS2]FLDIND(I))+")"
 Endif
 Read [ATZ]CODZONE = [F:PS2]TBL(I);[F:PS2]FLDNAM(I)
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 Wrseq 'CRIT'+num$(I+1)+' = ';
 Case [F:PS2]FLDTYP(I)
  When 1,2,3,4,5,6
   Wrseq 'num$('+VARIA+')'
  When 7
   Wrseq 'mid$('+VARIA+','+num$([F:PS2]FLDPOS(I))+','+num$([F:PS2]FLDLON(I))+')'
  When 8
   Wrseq 'format$("D:YYYYMMDD",'+VARIA+')'
 Endcase
Next I
For I=[F:PS2]NBRFLD+1 To MAXCRI
 Wrseq "CRIT"+num$(I)+' = "$$$"'
Next I
Wrseq

# Evaluation des intitulés

For I=0 To [F:PS2]NBRFLD-1
 If INTIT(I)<>""
  SPA = 0
  If INTLIEN(I)<>""
   Wrseq 'Read ['+INTABR(I)+']'+INTCLE(I)+' = '+INTLIEN(I)
   Wrseq 'If fstat'
   Wrseq ' INTIT('+num$(I+1)+') = mess(167,123,1) : # Divers'
   Wrseq 'Else'
   SPA = 1
  Endif
  Case INTTYP(I)
   When "ATX"
    Wrseq space$(SPA);'If '+INTIT(I)+'=0'
    Wrseq space$(SPA);' INTIT('+num$(I+1)+') = mess(167,123,1) : # Divers'
    Wrseq space$(SPA);'Else'
    Wrseq space$(SPA);' Call TEXTE('+INTIT(I)+',INTIT('+num$(I+1)+')) From OBJDIV'
    Wrseq space$(SPA);'Endif'
   When "AXX","AX1","AX2","AX3"
    Wrseq space$(SPA);'Read [AXX]AXX0 = "'+INTFIC(I)+'";"'+right$(INTIT(I),instr(1,INTIT(I),"]")+1)+'";GLANGUE';
    Read [ATI]NUMLIG(2) = INTFIC(I);1
    CHAINE = [F:ATI]DESCRIPT
    If INTFIC(I)=[F:PS1]RLGTBL
     ABR = ABFIC(0)
    Else
     Read [ATB]CODFIC = INTFIC(I)
     ABR = [F:ATB]ABRFIC
    Endif
    Raz CLE, NBCLE
    While CHAINE<>""
     K = instr(1,CHAINE,"+")
     J = instr(1,CHAINE,"-")
     If K & J
      K = min(K,J)
     Elsif J & !K
      K = J
     Endif
     NBCLE += 1
     If K
      CLE(NBCLE) = left$(CHAINE,K-1)
      CHAINE = right$(CHAINE,K+1)
     Else
      CLE(NBCLE) = CHAINE
      CHAINE = ""
     Endif
    Wend
    Wrseq ";num$([F:"+ABR+"]"+CLE(1)+")";
    For K=2 To NBCLE
     If CHAINE=""
      CHAINE += ";"
     Elsif len(CHAINE)>200
      Wrseq CHAINE;
      CHAINE = '+"~"+'
     Else
      CHAINE += '+"~"+'
     Endif
     CHAINE += "num$([F:"+ABR+"]"+CLE(K)+")"
    Next K
    Wrseq CHAINE
    Wrseq space$(SPA);'If fstat'
    Wrseq space$(SPA);' INTIT('+num$(I+1)+') = mess(167,123,1) : # Divers'
    Wrseq space$(SPA);'Else'
    Wrseq space$(SPA);' INTIT('+num$(I+1)+') = [F:AXX]TEXTE'
    Wrseq space$(SPA);'Endif'
   When Default
    Wrseq space$(SPA);'INTIT('+num$(I+1)+') = '+INTIT(I)
  Endcase
  If SPA
   Wrseq 'Endif'
  Endif
 Endif
Next I
Wrseq

# Evaluation de la date

VARIA = "[F:"+[F:PS1]DATTBL+"]"+[F:PS1]DATFLD
Wrseq "If "+VARIA+"=[0/0/0] : End : Endif"
If [F:PS2]PERPRG<>""
 Wrseq "DAT = ";VARIA
 Wrseq "Call CADRE(DAT) From ";[F:PS2]PERPRG
Else
 Case [F:PS2]PERTYP
  When 1 : # Jour
   Wrseq "DAT = ";VARIA
  When 2 : # Semaine
   Wrseq "DAT = aweek(week("+VARIA+"),year("+VARIA+"))"
  When 3 : # Quinzaine
   Wrseq "If day("+VARIA+")>15"
   Wrseq " DAT = gdat$(16,month("+VARIA+"),year("+VARIA+"))"
   Wrseq "Else"
   Wrseq " DAT = gdat$(1,month("+VARIA+"),year("+VARIA+"))"
   Wrseq "Endif"
  When 4 : # Mois
   Wrseq "DAT = gdat$(1,month("+VARIA+"),year("+VARIA+"))"
  When 5 : # Trimestre
   Wrseq "DAT = gdat$(1,3*int((month("+VARIA+")-1)/3)+1,year("+VARIA+"))"
  When 6 : # Année
   Wrseq "DAT = gdat$(1,1,year("+VARIA+"))"
  When 7 : # Décade
   Wrseq "If day("+VARIA+")>20"
   Wrseq " DAT = gdat$(21,month("+VARIA+"),year("+VARIA+"))"
   Wrseq "Elsif day("+VARIA+")>10"
   Wrseq " DAT = gdat$(11,month("+VARIA+"),year("+VARIA+"))"
   Wrseq "Else"
   Wrseq " DAT = gdat$(01,month("+VARIA+"),year("+VARIA+"))"
   Wrseq "Endif"
 Endcase
Endif
Wrseq

# Evaluation des montants

Wrseq "Raz MONTANT"
I = 1
For [PSL] Where COD=[F:PS2]COD
 If [F:PSL]AMTFOR<>""
  Wrseq "MONTANT("+num$(I)+") = "+vireblc(format$("KT:255X",[F:PSL]AMTFOR),2)
 Endif
 I += 1
Next
Wrseq

# Conversion en devise

Wrseq "Gosub CONV_DEVISE"
Wrseq

# Mise à jour du fichier STAT

Wrseq 'Call MAJSTA(SIGN,"'+[F:PS2]UPDCOD+'",SOCIETE,SITE,CRIT1,CRIT2,CRIT3,CRIT4,CRIT5,CRIT6,CRIT7,CRIT8,'
Wrseq '&           INTIT,DAT,MONTANT,'+num$([F:PS2]NBRFLD)+') From SUBPS2'

Wrseq
Wrseq "End"
Wrseq

# Ouverture des fichiers avant un zoom : # mb 30.11.4 bug 27469

Wrseq "$OUVRE"
For I=1 To NBFIC
 Wrseq "If clalev([F:"+ABFIC(I)+"])=0 : Local File "+TBFIC(I)+" ["+ABFIC(I)+"] : Endif"
Next I
For I=0 To [F:PS2]NBRFLD-1
 # If INTIT(I)<>"" & INTFIC(I)<>"" & !find(INTFIC(I),TBFIC(1..NBFIC)) :  # bug 46056
 If INTIT(I)<>"" & INTFIC(I)<>"" & !find(INTABR(I),ABFIC(1..NBFIC))
  Wrseq "If clalev([F:"+INTABR(I)+"])=0 : Local File "+INTFIC(I)+" ["+INTABR(I)+"] : Endif"
 Endif
Next I
I =  find("AXX",INTTYP(0..[F:PS2]NBRFLD-1))
I += find("AX1",INTTYP(0..[F:PS2]NBRFLD-1))
I += find("AX2",INTTYP(0..[F:PS2]NBRFLD-1))
I += find("AX3",INTTYP(0..[F:PS2]NBRFLD-1))
If I
 Wrseq "If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif"
Endif
Wrseq "Return"
Wrseq

# Fermeture des fichiers après un Zoom : # mb 28.5.1 bug 9275

Wrseq "$FERME"
For I=1 To NBFIC
 Wrseq "If clalev([F:"+ABFIC(I)+"])>0 : Close Local File ["+ABFIC(I)+"] : Endif"
Next I
For I=0 To [F:PS2]NBRFLD-1
 If INTIT(I)<>"" & INTFIC(I)<>"" & !find(INTABR(I),ABFIC(1..NBFIC))
  Wrseq "If clalev([F:"+INTABR(I)+"])>0 : Close Local File ["+INTABR(I)+"] : Endif"
 Endif
Next I
Wrseq "If clalev([F:"+ABFIC(0)+"])>0 : Close Local File ["+ABFIC(0)+"] : Endif"
I =  find("AXX",INTTYP(0..[F:PS2]NBRFLD-1))
I += find("AX1",INTTYP(0..[F:PS2]NBRFLD-1))
I += find("AX2",INTTYP(0..[F:PS2]NBRFLD-1))
I += find("AX3",INTTYP(0..[F:PS2]NBRFLD-1))
If I
 Wrseq "If clalev([F:AXX])>0 : Close Local File [AXX] : Endif"
Endif
Wrseq "Return"
Wrseq

# Sous-programmes d'établissement des zooms
Wrseq "$ZOOM"
Wrseq "Raz [M]OBJBOU, OBJCLE, OBJSEC"
For I=1 To [F:PS2]NBRFLD
 Read [ATZ]CODZONE = [F:PS2]TBL(I-1);[F:PS2]FLDNAM(I-1)
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 If [F:PS2]FLDPOS(I-1)=1 & [F:PS2]FLDLON(I-1)=[F:PS2]FLDLNG(I-1)
  OKZOOM = 0
  If [F:ATY]OBJLIEN<>"" | [F:ATY]CODTYP ="VCR"
   SCHAINE = ""
   CHAINE = vireblc(format$("KT:120X",[F:ATZ]EXPLIEN),2)
   If CHAINE<>""
    J = instr(1,CHAINE,";")
    If J
     SCHAINE = left$(CHAINE,J-1)
     CHAINE  = right$(CHAINE,J+1)
     If !instr(1,CHAINE,";") & left$(SCHAINE,1)<"A"
      OKZOOM = 1
     Endif
    Elsif [F:ATY]CODTYP = "VCR"
     OKZOOM = 1
    Endif
   Else
    OKZOOM = 1
    CHAINE = [F:PS2]FLDNAM(I-1)
    If [F:PS2]FLDIND(I-1)>0 : CHAINE += "("+num$([F:PS2]FLDIND(I-1))+")" : Endif
   Endif
  Endif
  If OKZOOM
   Repeat
    J = instr(1,SCHAINE,"indice")
    If J
     SCHAINE = left$(SCHAINE,J-1)+num$([F:PS2]FLDIND(I-1))+right$(SCHAINE,J+6)
    Endif
   Until J=0
   If SCHAINE<>""
    SCHAINE = 'num$('+SCHAINE+')'
   Else
    SCHAINE = '""'
   Endif
   CHAINE = "[M:STA2]CLE(max(0,nolign-1))"
   If [F:ATY]CODTYP ="VCR"
    Read [AMP]CODPAR = 2;[F:PS2]TBL(I-1);[F:PS2]FLDNAM(I-1);"VCROBJ"
    If !fstat
     Onerrgo
     OBJET2 = evalue([F:AMP]VALPAR)
     Onerrgo
    Endif
   Else
    OBJET2 = [F:ATY]OBJLIEN
   Endif
   Read [AOB]ABREV = OBJET2
   If !fstat
    Wrseq 'If [M:STA1]NIVEAU='+num$(I)
    Wrseq ' Call TEXTE('+num$([F:AOB]LIBEL)+',GBOUT7) From OBJDIV'
    Wrseq ' [M]OBJBOU = "'+OBJET2+'"'
    Wrseq ' [M]OBJCLE = '+CHAINE
    Wrseq ' [M]OBJSEC = '+SCHAINE
    Wrseq 'Endif'
   Endif
  Endif
 Endif
Next I
Wrseq "Return"
Wrseq

# Sous-programme d'établissement des liens

Wrseq "$LIENS"
Raz LIEN
If NBFIC>0
 Wrseq "indice=0"
Endif

$LIEN
FLLIEN = 0
For I=1 To NBFIC
 If LIEN(I)=0
  If LNKFIC(I)<>""
   [F:ATZ]LIEN = TBFIC(I)
   ABL = ABFIC(0)
   ABR = ABFIC(I)
   Gosub SET_LIEN
  Else
   Read [ATZ]LIEN(2) = TBFIC(I);[F:PS1]RLGTBL
   If fstat=0
    ABL = ABFIC(0)
    ABR = ABFIC(I)
    Gosub SET_LIEN
   Else
    Read [ATZ]LIEN(2) = [F:PS1]RLGTBL;TBFIC(I)
    If fstat=0
     ABL = ABFIC(I)
     ABR = ABFIC(0)
     Gosub SET_LIEN_INV
    Else
     For J=1 To NBFIC
      If LIEN(J)=1
       Read [ATZ]LIEN(2) = TBFIC(I);TBFIC(J)
       If fstat=0
        ABL = ABFIC(J)
        ABR = ABFIC(I)
        Gosub SET_LIEN
        Break
       Else
        Read [ATZ]LIEN(2) = TBFIC(J);TBFIC(I)
        If fstat=0
         ABL = ABFIC(J)
         ABR = ABFIC(I)
         Gosub SET_LIEN_INV
         Break
        Endif
       Endif
      Endif
     Next J
    Endif
   Endif
  Endif
 Endif
Next I
If sum(LIEN(1..NBFIC))<>NBFIC
 If FLLIEN
  Goto LIEN
 Else
  OKVAL = 0 : MESSAGE = mess(7,124,1) : # Liens impossible
  Return
 Endif
Endif

Wrseq "Return"
Wrseq

# Conversion en devise

Wrseq "$CONV_DEVISE"
If [F:PS2]UPDLEV=1
 CHAINE = "GSYSCUR"
Else
 CHAINE = "GDEVSOC(ISOC)"
Endif
For [PSL] Where COD=[F:PS2]COD
 If [F:PSL]CNV=2
  Wrseq 'Call PARAML(SITE,"CHGTYP",VALPAR) From ADOVAL'
  Wrseq 'COURTYP = val(VALPAR)'
  Wrseq 'If COURTYP=0 : COURTYP = 1 : Endif'
  Break
 Endif
Next PSL
Wrseq 'If dim(WVERMNTNBR)<0'
Wrseq ' Global Char WVERMNTTAB(30)(1..300)'
Wrseq ' Global Char WVERMNTKEY(30)'
Wrseq ' Global Decimal WVERMNTDEC(1..300)'
Wrseq ' Global Integer WVERMNTNBR'
Wrseq ' WVERMNTNBR = 1'
Wrseq 'Endif'
Wrseq 'Local Integer WI'
I = 1
For [PSL] Where COD=[F:PS2]COD
 If [F:PSL]CNV=2 and [F:PSL]DEVORG<>"" and [F:PSL]DEVDES<>""
  Wrseq 'WVERMNTKEY =  '+vireblc(format$("KT:250X",[F:PSL]DEVORG),2)
  Wrseq 'WVERMNTKEY += '+vireblc(format$("KT:250X",[F:PSL]DEVDES),2)
  Wrseq 'WVERMNTKEY += '+CHAINE
  Wrseq 'WVERMNTKEY += num$(COURTYP)'
  Wrseq 'WVERMNTKEY += num$([F:'+[F:PS1]DATTBL+']'+[F:PS1]DATFLD+')'
  Wrseq 'WVERMNTKEY += num$(MONTANT('+num$(I)+'))'
  Wrseq 'WI = find(WVERMNTKEY,WVERMNTTAB(1..WVERMNTNBR))'
  Wrseq 'If WI'
  Wrseq ' MONTANT('+num$(I)+') = WVERMNTDEC(WI)'
  Wrseq 'Else'
  Wrseq ' Call CONVERT('+vireblc(format$("KT:250X",[F:PSL]DEVORG),2)
&                   +','+vireblc(format$("KT:250X",[F:PSL]DEVDES),2)
&                   +','+CHAINE
&                   +','+"COURTYP"
&                   +','+"[F:"+[F:PS1]DATTBL+"]"+[F:PS1]DATFLD
&                   +','+"MONTANT("+num$(I)+")"
&                   +','+"MONTANT("+num$(I)+")"
&                   +','+"STAT) From TRTDEV"
  Wrseq ' WVERMNTDEC(WVERMNTNBR) = MONTANT('+num$(I)+')'
  Wrseq ' WVERMNTTAB(WVERMNTNBR) = WVERMNTKEY'
  Wrseq ' If WVERMNTNBR>=300'
  Wrseq '  WVERMNTNBR = 1'
  Wrseq '  Raz WVERMNTDEC , WVERMNTTAB'
  Wrseq ' Else'
  Wrseq '  WVERMNTNBR += 1'
  Wrseq ' Endif'
  Wrseq 'Endif'
 Endif
 I += 1
Next
Wrseq "Return"
Wrseq
Return

#-------------------------------------------------------#
$SET_LIEN
If CLFIC(I)<>""
 Read [ATI]CODIND = TBFIC(I);CLFIC(I)
 If fstat
  Read [ATI]NUMLIG(2) = [F:ATZ]LIEN;1
 Endif
Else
 Read [ATI]NUMLIG(2) = [F:ATZ]LIEN;1
Endif
DESCLE = [F:ATI]DESCRIPT
C = 0
While DESCLE<>""
 C += 1
 K1 = instr(1,DESCLE,"+")
 K2 = instr(1,DESCLE,"-")
 If K1 & K2     : K1 = min(K1,K2)
 Elsif K2 & !K1 : K1 = K2
 Endif
 If K1
  CLE(C) = left$(DESCLE,K1-1) : DESCLE = right$(DESCLE,K1+1)
 Else
  CLE(C) = DESCLE : DESCLE = ""
 Endif
 CLE(C) = "[F:"+ABR+"]"+CLE(C)
Wend
Read [ATB]CODFIC = TBFIC(I)
If LNKFIC(I)<>""
 CHAINE = LNKFIC(I)
Else
 CHAINE = vireblc(format$("KT:80X",[F:ATZ]EXPLIEN),2)
Endif
CHTEST = ""
C = 0
If CHAINE=""
 EXPLIEN = "[F:"+ABL+"]"+[F:ATZ]CODZONE
 CHTEST = CLE(1)+"<>"+EXPLIEN
Else
 EXPLIEN = ""
 While CHAINE<>""
  C += 1
  K = instr(1,CHAINE,";")
  If K
   SCHAINE = left$(CHAINE,K-1) : CHAINE = right$(CHAINE,K+1)
  Else
   SCHAINE = CHAINE : CHAINE = ""
  Endif
  If EXPLIEN<>"" : EXPLIEN += ";" : Endif
  If left$(SCHAINE,1)>="A" & left$(SCHAINE,1)<="Z"
   Read [ATZ]CODZONE = [F:ATB]ABRFIC;SCHAINE
   If !fstat
    SCHAINE = "[F:"+ABL+"]"+SCHAINE
   Endif
  Endif
  EXPLIEN += SCHAINE
  If CHTEST<>"" : CHTEST += " | " : Endif
  CHTEST += CLE(C)+"<>"+SCHAINE
 Wend
Endif
If CHTEST<>"" : Wrseq "If "+CHTEST : Endif
Wrseq space$(CHTEST<>"");"Read ["+ABFIC(I)+"]"+CLFIC(I)+" = "+EXPLIEN
Wrseq space$(CHTEST<>"");"If fstat : Raz [F:"+ABFIC(I)+"] : Endif"
If CHTEST<>"" : Wrseq "Endif" : Endif
FLLIEN = 1
LIEN(I) = 1
Return

#----------------------------------#
$SET_LIEN_INV
Read [ATI]NUMLIG(2) = [F:ATZ]CODFIC;1
Read [ATB]CODFIC = [F:ATZ]CODFIC
DESCLE = [F:ATI]DESCRIPT
C = 0
While DESCLE<>""
 C += 1
 K1 = instr(1,DESCLE,"+")
 K2 = instr(1,DESCLE,"-")
 If K1 & K2     : K1 = min(K1,K2)
 Elsif K2 & !K1 : K1 = K2
 Endif
 If K1
  CLE(C) = left$(DESCLE,K1-1) : DESCLE = right$(DESCLE,K1+1)
 Else
  CLE(C) = DESCLE : DESCLE = ""
 Endif
 CLE(C) = "[F:"+ABR+"]"+CLE(C)
Wend
Read [ATI]NUMLIG(2) = [F:ATZ]LIEN;1
Read [ATB]CODFIC = [F:ATZ]LIEN
CHAINE = [F:ATI]DESCRIPT
CHTEST = ""
C = 0
EXPLIEN = ""
While CHAINE<>""
 C += 1
 K = instr(1,CHAINE,"+")
 L = instr(1,CHAINE,"-")
 If    K & L  : K = min(K,L)
 Elsif L & !K : K = L
 Endif
 If K
  SCHAINE = left$(CHAINE,K-1) : CHAINE = right$(CHAINE,K+1)
 Else
  SCHAINE = CHAINE : CHAINE = ""
 Endif
 If EXPLIEN<>"" : EXPLIEN += ";" : Endif
 If left$(SCHAINE,1)>="A" & left$(SCHAINE,1)<="Z"
  SCHAINE = "[F:"+ABL+"]"+SCHAINE
 Endif
 EXPLIEN += SCHAINE
 If CHTEST<>"" : CHTEST += " | " : Endif
 CHTEST += CLE(C)+"<>"+SCHAINE
Wend
Wrseq "If "+CHTEST
Wrseq " Read ["+ABFIC(I)+"]"+CLFIC(I)+"("+num$(C)+") = "+EXPLIEN
Wrseq " If fstat : Raz [F:"+ABFIC(I)+"] : Endif"
Wrseq "Endif"
FLLIEN = 1
LIEN(I) = 1
Return

#----------------------#
$SETSOC
If [F:PS1]CPYFLD<>""
 Wrseq 'SOCIETE = [F:'+[F:PS1]CPYTBL+"]"+[F:PS1]CPYFLD
Else
 Wrseq 'SITE    = [F:'+[F:PS1]FCYTBL+"]"+[F:PS1]FCYFLD
 Wrseq 'ISITE   = find(SITE,GSITE(1..GNBSITE))'
 Wrseq 'If !ISITE : End : Endif'
 Wrseq 'SOCIETE = GSOCSITE(ISITE)'
Endif
Wrseq 'ISOC    = find(SOCIETE,GSOC(1..GNBSOC))'
Wrseq 'If !ISOC : End : Endif'
Return

#-------------------------------------------------------#
# Traitement de mise à jour pour un code déclenchant
#-------------------------------------------------------#

Subprog MAJTRT2(CODE,DOSSIER,SILENCE)
Value Char CODE
Value Char DOSSIER
Value Integer SILENCE

Local Integer STAT
Local Char    NOMTRT(GLONADC) , FICTRT(GDIMFIC) , MAGIC(80)
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If clalev([F:PS1])=0 : Local File =APPLI+".PARSTA1" [PS1] : Endif
If clalev([F:PS2])=0 : Local File =APPLI+".PARSTA2" [PS2] : Endif

Read [PS1]PS10 = CODE

MAGIC  = mess(77,133,1) : # Superviseur Adonix
Gosub PREFIXE From SUBPS2
NOMTRT = "W"+LETTRE+PFIX1+CODE
FICTRT = filpath("TRT",NOMTRT,"src",APPLI,"",MACHINE)

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

adxifs = ""
adxirs = chr$(10)
adxium = GUTF8

If !SILENCE
 Call TEMPON(mess(159,133,1)-NOMTRT) From GESECRAN : # Validation du traitement
Endif

Gosub TRT_DEB2
Gosub ETIQUETTE2
Gosub TRT_FIN2

If !SILENCE
 Call TEMPOFF From GESECRAN
Endif

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

End

#-------------------------------------------------------#
$TRT_DEB2
Openo FICTRT , 0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq "#"-mess(6,124,1)-CODE : # Mise à jours statistique
Wrseq
Return

#-------------------------------------------------------#
$TRT_FIN2
Wrseq
Openo
Call VALID("TRT",NOMTRT,DOSSIER,STAT) From VALMSKSUB
Return

#-------------------------------------------------------#
$ETIQUETTE2
Wrseq "Subprog MAJSTA(SIGN)"
Wrseq "Value Integer SIGN"
For [PS2] Where RLG=[F:PS1]COD & TYP=1 & ENAFLG=2
 Wrseq "Call MAJSTA(SIGN) From W"+LETTRE+PFIX2+[F:PS2]COD
 Wrseq "If GOK<1 : End : Endif"
Next
Wrseq "End"
Wrseq
Return

#####################################################################
Subprog MAJSTA(SIGN,CODE,SOCIETE,SITE
&             ,CRIT1,CRIT2,CRIT3,CRIT4,CRIT5,CRIT6,CRIT7,CRIT8
&             ,INTIT,DAT,MONTANT,NIVCUM)
Value Integer SIGN
Value Char    CODE
Value Char    SOCIETE
Value Char    SITE
Value Char    CRIT1
Value Char    CRIT2
Value Char    CRIT3
Value Char    CRIT4
Value Char    CRIT5
Value Char    CRIT6
Value Char    CRIT7
Value Char    CRIT8
Value Char    INTIT()(1..)
Value Date    DAT
Value Decimal MONTANT(1..)
Value Integer NIVCUM

GPOINT = "DEBMAJSTA" : Gosub ENTREE From EXEFNC

Local Integer OK , I , MAXCRI
Local Char    DESIG(50)

# mb 25.2.2013 Reprise modif correction bug 71034
For I=1 To 8
 Assign("CRIT"+num$(I)) With vireblc(evalue("CRIT"+num$(I)),1)
Next I

OK = 0
For I=1 To min(dim(MONTANT),dim([F:SAT]AMT))
 If MONTANT(I)<>0 : OK = 1 : Break : Endif
Next I
If !OK : End : Endif : # C'est pas la peine de créer des enregs à 0
If clalev([F:SAT])=0 : Local File STAT    [SAT] : Endif
If clalev([F:PS2])=0 : Local File PARSTA2 [PS2] : Endif
MAXCRI = dim([F:PS2]TBL)
DESIG = INTIT(NIVCUM)
Gosub NIVSTA
If NIVCUM>7
 DESIG = INTIT(7) : CRIT8 = "$$$" : Gosub NIVSTA
Endif
If NIVCUM>6
 DESIG = INTIT(6) : CRIT7 = "$$$" : Gosub NIVSTA
Endif
If NIVCUM>5
 DESIG = INTIT(5) : CRIT6 = "$$$" : Gosub NIVSTA
Endif
If NIVCUM>4
 DESIG = INTIT(4) : CRIT5 = "$$$" : Gosub NIVSTA
Endif
If NIVCUM>3
 DESIG = INTIT(3) : CRIT4 = "$$$" : Gosub NIVSTA
Endif
If NIVCUM>2
 DESIG = INTIT(2) : CRIT3 = "$$$" : Gosub NIVSTA
Endif
If NIVCUM>1
 DESIG = INTIT(1) : CRIT2 = "$$$" : Gosub NIVSTA
Endif
End

$NIVSTA
Case MAXCRI
 When 1 : Readlock [SAT]SAT0 = CODE;SOCIETE;SITE;DAT;CRIT1
 When 2 : Readlock [SAT]SAT0 = CODE;SOCIETE;SITE;DAT;CRIT1;CRIT2
 When 3 : Readlock [SAT]SAT0 = CODE;SOCIETE;SITE;DAT;CRIT1;CRIT2;CRIT3
 When 4 : Readlock [SAT]SAT0 = CODE;SOCIETE;SITE;DAT;CRIT1;CRIT2;CRIT3;CRIT4
 When 5 : Readlock [SAT]SAT0 = CODE;SOCIETE;SITE;DAT;CRIT1;CRIT2;CRIT3;CRIT4;CRIT5
 When 6 : Readlock [SAT]SAT0 = CODE;SOCIETE;SITE;DAT;CRIT1;CRIT2;CRIT3;CRIT4;CRIT5;CRIT6
 When 7 : Readlock [SAT]SAT0 = CODE;SOCIETE;SITE;DAT;CRIT1;CRIT2;CRIT3;CRIT4;CRIT5;CRIT6;CRIT7
 When 8 : Readlock [SAT]SAT0 = CODE;SOCIETE;SITE;DAT;CRIT1;CRIT2;CRIT3;CRIT4;CRIT5;CRIT6;CRIT7;CRIT8
Endcase
If fstat=1
 GOK = -1 : GLOCK="$STAT"-CODE : Return
Elsif fstat
 Raz [F:SAT]
 [F:SAT]COD  = CODE
 [F:SAT]CPY  = SOCIETE
 [F:SAT]FCY  = SITE
 For I=1 To MAXCRI
  Case I
   When 1 : [F:SAT]CRI1 = CRIT1 : [F:SAT]DES1 = INTIT(1)
   When 2 : [F:SAT]CRI2 = CRIT2 : [F:SAT]DES2 = INTIT(2)
   When 3 : [F:SAT]CRI3 = CRIT3 : [F:SAT]DES3 = INTIT(3)
   When 4 : [F:SAT]CRI4 = CRIT4 : [F:SAT]DES4 = INTIT(4)
   When 5 : [F:SAT]CRI5 = CRIT5 : [F:SAT]DES5 = INTIT(5)
   When 6 : [F:SAT]CRI6 = CRIT6 : [F:SAT]DES6 = INTIT(6)
   When 7 : [F:SAT]CRI7 = CRIT7 : [F:SAT]DES7 = INTIT(7)
   When 8 : [F:SAT]CRI8 = CRIT8 : [F:SAT]DES8 = INTIT(8)
  Endcase
 Next I
 [F:SAT]DAT  = DAT
 Gosub CUMSTA
 Write [SAT]
Else
 Gosub CUMSTA
 Rewrite [SAT]
Endif
If fstat
 GOK = 0 : Call FSTA("SAT") From GLOCK : Return
Endif
Return

$CUMSTA
For I=1 To min(dim(MONTANT),dim([F:SAT]AMT))
 [F:SAT]AMT(I-1) += SIGN*MONTANT(I)
Next I
GPOINT = "MAJSTA" : Gosub ENTREE From EXEFNC
Return

################################################################
## Mise à jour en temps réel                                  ##
################################################################
Subprog VALSTA(CODE,SIGN)
Value Char    CODE
Value Integer SIGN
Local Integer OKTRT
Local Char NOMTRT(GLONADC)
Gosub PREFIXE
NOMTRT = "W"+LETTRE+PFIX1+CODE
Call EXISTE_ADX("","",NOMTRT,OKTRT) From ORDSYS
If OKTRT>0
 If clalev([F:SAT])=0 : Local File STAT [SAT] : Endif
 Call MAJSTA(SIGN) From =NOMTRT
Endif
End

################################################################
## Mise à jour en batch                                       ##
################################################################
Subprog VALBATCH(CODE,SOCIETE,SITE,DAT1,DAT2,CAS)
Value Char    CODE
Value Char    SOCIETE
Value Char    SITE
Value Date    DAT1
Value Date    DAT2
Value Integer CAS

Local Integer I
Local Date    DATDEB , DATFIN , DATMAX
Local Char    NOMTRT(GLONADC) , CRITERE(250) , CRITEFF(250) , SCRITERE(250)
Local Char    MAJCOD(10)

If GTRACE<>""
 # Validation statistiques du au
 MESSA = mess(11,124,1)-CODE-SOCIETE-SITE-mess(94,100,1)-format$("D:"+GFMDAT4,DAT1)-mess(95,100,1)-format$("D:"+GFMDAT4,DAT2)
 Call ECR_TRACE(MESSA,0) From GESECRAN
Endif

Gosub PREFIXE

If clalev([F:PS1])=0 : Local File PARSTA1    [PS1] : Endif
If clalev([F:PS2])=0 : Local File PARSTA2    [PS2] : Endif
If clalev([F:SAT])=0 : Local File STAT       [SAT] : Endif
If clalev([F:SAP])=0 : Local File STATPRV    [SAP] : Endif
If clalev([F:ATB])=0 : Local File ATABLE     [ATB] : Endif

Read [PS2]PS20 = CODE
MAJCOD = [F:PS2]UPDCOD

DATDEB = DAT1
DATFIN = DAT2


# Effacement
If CAS = 1
 CRITEFF = 'COD="'+MAJCOD+'"'
 If DATDEB<>[0/0/0]
  CRITEFF -= "& DAT>=["+format$(GFMD,DATDEB)+"]"
 Endif
 If DATFIN<>[0/0/0]
  CRITEFF -= "& DAT<=["+format$(GFMD,DATFIN)+"]"
 Endif
 If SOCIETE<>""
  CRITEFF -= '& CPY="'+SOCIETE+'"'
 Endif
 If SITE<>""
  CRITEFF -= '& FCY="'+SITE+'"'
 Endif
 Trbegin [SAT] , [PS2]
  For [SAT]SAT0 Where evalue(CRITEFF)
   [F:SAP] = [F:SAT]
   Read [SAP]SAP0 =
   If !fstat
    Raz [F:SAT]AMT
    Rewrite [SAT]
   Else
    Delete [SAT]SAT0 Curr
   Endif
   If fstat=1
    GOK=-1 : GLOCK="$STAT"-CODE : Rollback : Break
   Endif
  Next SAT
  DATMAX = [0/0/0]
 Commit
Endif

# Regénération de tous les codes actifs ayant le même UPDCOD

Filter [PS2] Where ENAFLG=2 & UPDCOD=MAJCOD
Read [PS2]PS20 First
While fstat<=2

 Read [PS1]PS10 = [F:PS2]RLG
 NOMTRT = "W"+LETTRE+PFIX2+[F:PS2]COD

# Ouverture des fichiers

 Gosub OUVRE From =NOMTRT

# Critère de parcours

 CRITERE = ""
 If DATDEB<>[0/0/0]
  CRITERE = [F:PS1]DATFLD+">=["+format$(GFMD,DATDEB)+"]"
 Endif
 If DATFIN<>[0/0/0]
  If CRITERE<>"" : CRITERE += " & " : Endif
  CRITERE += [F:PS1]DATFLD+"<=["+format$(GFMD,DATFIN)+"]"
 Endif
 If SOCIETE<>"" & [F:PS1]CPYFLD<>""
  If CRITERE<>"" : CRITERE += " & " : Endif
  CRITERE += [F:PS1]CPYFLD+'="'+SOCIETE+'"'
 Endif
 If SITE<>"" & [F:PS1]FCYFLD<>""
  If CRITERE<>"" : CRITERE += " & " : Endif
  CRITERE += [F:PS1]FCYFLD+'="'+SITE+'"'
 Endif

# Mise à jour

 Call DEBTRANS From GLOCK
 If SOCIETE<>"" & [F:PS1]CPYFLD="" & SITE="" & [F:PS1]FCYFLD<>"" : # mb 7.10.2 bug 15982
  For I=1 To GNBSITE
   If GSOCSITE(I)=SOCIETE
    SCRITERE = CRITERE
    If SCRITERE<>"" : SCRITERE += " & " : Endif
    SCRITERE += [F:PS1]FCYFLD+'="'+GSITE(I)+'"'
    Call TR1(SCRITERE,NOMTRT)
   Endif
  Next
 Else
  If CRITERE="" : CRITERE = "1=1" : Endif
  Call TR1(CRITERE,NOMTRT)
 Endif

 Read [PS2]PS20 Next
Wend
Filter [PS2]
End

Subprog TR1(CRITERE,NOMTRT)
Value Char CRITERE
Value Char NOMTRT
Local Date DATMAX
Gosub TR2
End

$TR2
GOK = 1
DATMAX = [F:PS2]LSTDAT
Trbegin [SAT] , [PS2]
 Local File =[F:PS1]RLGTBL : # Fichier par défaut
 For [F] Where evalue(CRITERE)
  Call MAJSTA(+1) From =NOMTRT
  If GOK<1 : Break : Endif
  DATMAX = max(DATMAX,evalue("[F]"+[F:PS1]DATFLD))
 Next
 If   GOK<0 : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 [F:PS2]LSTDAT = DATMAX
 Rewrite [PS2]
 If fstat
  GOK=0 : Call FSTA("PS2") From GLOCK : Goto AB_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If ! GROLL : Goto TR2 : Endif
Return

########################################
## Ecran PS20                         ##
########################################
Subprog AM_COD(VALEUR)
Variable Char    VALEUR()
[M:PS21]UPDCOD = VALEUR : Affzo [PS21]UPDCOD
End

########################################
## Ecran PS21                         ##
########################################
Subprog AS_CRI(VALEUR)
Variable Char    VALEUR()
If indice>0 & [M]CRI(indice-1)=""
 mkstat = 1 : End
Endif
End

Subprog C_CRI(VALEUR)
Variable Char    VALEUR()
Gosub C_FORMULE
End

Subprog AS_UPDLEV(VALEUR)
Variable Integer VALEUR
Call LECTURE("PS1",[M]RLG,"") From CONTOBJ
If [F:PS1]CPYFLD="" & [F:PS1]FCYFLD=""
 VALEUR = 1 : mkstat = 2
Endif
End

Subprog C_UPDLEV(VALEUR)
Variable Integer VALEUR
Call LECTURE("PS1",[M]RLG,"") From CONTOBJ
If VALEUR=3 & [F:PS1]FCYFLD=""
 GMESSAGE = mess(123,123,1) : mkstat = 2 : # Un champ site doit être défini
Endif
End

Subprog IB_RLG
End

Subprog AM_RLG(VALEUR)
Variable Char VALEUR
Call LECTURE("PS1",VALEUR,"") From CONTOBJ
Read [ATB]CODFIC = [F:PS1]RLGTBL
[M]NBABR = 1
[M]ABREV(1) = [F:ATB]ABRFIC
For I=0 To [F:PS1]NBRTBL-1
 If [F:PS1]ABRLNK<>""
  ABR = [F:PS1]ABRLNK
 Else
  Read [ATB]CODFIC = [F:PS1]TBL(I)
  ABR = [F:ATB]ABRFIC
 Endif
 If !find(ABR,[M]ABREV(1..[M]NBABR))
  [M]NBABR += 1 : [M]ABREV([M]NBABR) = ABR
 Endif
Next I
For I=0 To [F:PS2]NBRFLD-1
 If [F:PS2]TBLABR<>""
  ABR = [F:PS2]TBLABR
 Else
  Read [ATB]CODFIC = [F:PS2]TBL(I)
  ABR = [F:ATB]ABRFIC
 Endif
 If !find(ABR,[M]ABREV(1..[M]NBABR))
  [M]NBABR += 1 : [M]ABREV([M]NBABR) = ABR
 Endif
Next I
Call GRISE_UPDLEV(VALEUR)
End

Subprog GRISE_UPDLEV(VALEUR)
Value Char VALEUR
Call LECTURE("PS1",VALEUR,"") From CONTOBJ
If [F:PS1]CPYFLD="" & [F:PS1]FCYFLD=""
 [M:PS21]UPDLEV = 1
 Affzo [PS21]UPDLEV
 Grizo [PS21]UPDLEV
Else
 Actzo [PS21]UPDLEV
Endif
End

Subprog C_PERPRG(VALEUR)
Variable Char    VALEUR()
Call GRISE_PERTYP(VALEUR)
End

Subprog GRISE_PERTYP(VALEUR)
Value Char VALEUR
If VALEUR<>""
 Effzo [PS21]PERTYP
 Grizo [PS21]PERTYP
Else
 Actzo [PS21]PERTYP
Endif
End

########################################
## Ecran PS22                         ##
########################################
Subprog C_FLDNAM(VALEUR)
Variable Char    VALEUR()
Local Decimal LONGUEUR
Local Integer OK
Read [ATZ]CODZONE = [M]TBL(nolign-1);VALEUR
If fstat
 Call ERREUR(mess(9,124,1)) From GESECRAN : # Champ inexistant
 mkstat = 2 : End
Endif
Read [ATY]CODTYP = [F:ATZ]CODTYP
If find([F:ATZ]CODTYP,"AXX","AX1","AX2","AX3")
 LONGUEUR = 20
Elsif [F:ATY]LNGTYP<>0
 LONGUEUR = [F:ATY]LNGTYP
Else
 LONGUEUR = [F:ATZ]LONG
Endif
If LONGUEUR>20
 OK = 1
 Call AVERTIR(mess(2,124,1),OK) From GESECRAN : # Champ trop long
 If OK<>2 : mkstat = 2 : End : Endif
 LONGUEUR = 20
Endif
[M]FLDLNG(nolign-1) = LONGUEUR
[M]FLDTYP(nolign-1) = [F:ATY]TYPTYP
If VALEUR<>[M]FLDNAM(nolign-1)
 Call TEXTE([F:ATZ]NOCOURT,[M]FLDINTIT(nolign-1)) From OBJDIV
Endif
End

Subprog AS_FLDIND(VALEUR)
Variable Decimal VALEUR
Gosub DIMMAX
If DIMMAX<2 : mkstat=1 : End : Endif
End

$DIMMAX
Local Integer DIMMAX
Read [ATZ]CODZONE = [M]TBL(nolign-1);[M]FLDNAM(nolign-1)
DIMMAX = 0
If [F:ATZ]CODACT<>""
 Read [ACV]CODACT=[F:ATZ]CODACT
 If [F:ACV]DIME<>0 : DIMMAX = [F:ACV]DIME : Endif
Endif
If DIMMAX=0
 DIMMAX = [F:ATZ]DIME
Endif
Return

Subprog C_FLDIND(VALEUR)
Variable Decimal VALEUR
Gosub DIMMAX
If VALEUR>=DIMMAX : mkstat = 1 : End : Endif
End

Subprog AS_FLDPOS(VALEUR)
Variable Decimal VALEUR
If [M]FLDTYP(nolign-1)<>7
 mkstat = 1 : End
Elsif VALEUR=0
 VALEUR = 1
Endif
End

Subprog C_FLDPOS(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 or VALEUR>[M]FLDLNG(nolign-1)
 mkstat = 1 : End
Endif
End

Subprog AS_FLDLON(VALEUR)
Variable Decimal VALEUR
If [M]FLDTYP(nolign-1)<>7
 VALEUR = [M]FLDLNG(nolign-1)
 mkstat = 2 : End
Elsif VALEUR=0
 VALEUR = [M]FLDLNG(nolign-1)
Endif
End

Subprog C_FLDLON(VALEUR)
Variable Decimal VALEUR
If VALEUR<>int(VALEUR) or VALEUR<1 or VALEUR+[M]FLDPOS(nolign-1)-1>[M]FLDLNG(nolign-1)
 mkstat = 1 : End
Endif
End

Subprog D_TBL(VALEUR)
Variable Char    VALEUR()
Call LECTURE("PS1",[M]RLG,"") From CONTOBJ
VALEUR = [F:PS1]RLGTBL
End

Subprog AS_TBL(VALEUR)
Variable Char    VALEUR()
Local Integer I , J
Call LECTURE("PS1",[M]RLG,"") From CONTOBJ
I = 0 : [M]TABFIL(I) = [F:PS1]RLGTBL
For J=1 To [F:PS1]NBRTBL
 K = 1
 For T=0 To I
  If [F:PS1]TBL(J-1)=[M]TABFIL(T) & [F:PS1]ABRLNK(J-1)=[M]ABRFIL(T)
   K = 0 : Break
  Endif
 Next T
 If K
  I += 1 : [M]TABFIL(I) = [F:PS1]TBL(J-1) : [M]ABRFIL(I) = [F:PS1]ABRLNK(J-1)
 Endif
Next J
End

Subprog C_TBL(VALEUR)
Variable Char    VALEUR()
Local Integer OK , NOL
Call LECTURE("PS1",[M]RLG,"") From CONTOBJ
If VALEUR=[F:PS1]RLGTBL : End : Endif
If find(VALEUR,[F:PS1]TBL(0..[F:PS1]NBRTBL-1)) : End : Endif
Read [ATZ]LIEN(2) = VALEUR;[F:PS1]RLGTBL
If fstat
 Read [ATZ]LIEN(2) = [F:PS1]RLGTBL;VALEUR
 If fstat
  For NOL=0 To [F:PS1]NBRTBL-1
   Read [ATZ]LIEN(2) = VALEUR;[F:PS1]TBL(NOL)
   If fstat=0
    OK = 1 : Break
   Else
    Read [ATZ]LIEN(2) = [F:PS1]TBL(NOL);VALEUR
    If fstat=0 : OK = 1 : Break : Endif
# X3BY contrôles supplémentaires sur la clé
   Endif
  Next NOL
  If !OK
   GMESSAGE = mess(1,124,1)-[F:PS1]RLGTBL : mkstat = 2 : End
#  Pas de lien vers la table
  Endif
 Endif
Endif
End

Subprog C_VARNAM(VALEUR)
Variable Char    VALEUR()
Call LECTURE("PS1",[M]RLG,"") From CONTOBJ
If VALEUR<>""
 Local Integer I
 I = find(VALEUR,[F:PS1]VARNAM(0..[F:PS1]NBRVAR-1))
 If I=0
  GMESSAGE = mess(3,124,1) : mkstat = 2 : End
# Variable non définie
 Else
  Call LECTEXTRA([M]AMTDES(nolign-1),"PARSTA1","VARINTIT",[F:PS1]COD,num$(I)) From ATEXTRA
  [M]AMTFOR(nolign-1) = [F:PS1]VARFOR(I-1)
  If [F:PS1]VARCUR(nolign-1)<>""
   [M]CNV(nolign-1)    = 2
   [M]DEVORG(nolign-1) = [F:PS1]VARCUR(I-1)
  Else
   [M]CNV(nolign-1)    = 1
  Endif
  Affzo AMTDES(nolign-1) , AMTFOR(nolign-1) , CNV(nolign-1) , DEVORG(nolign-1)
 Endif
Endif
End

Subprog C_NBRFLD
Local Char ABR(4)
If status<7
 For I=0 To [M]NBRFLD-1
  If [M]TBLABR(I)<>""
   ABR = [M]TBLABR(I)
  Else
   Read [ATB]CODFIC = [M]TBL(I)
   ABR  = [F:ATB]ABRFIC
  Endif
  If !find(ABR,[M]ABREV(1..[M]NBABR))
   [M]NBABR += 1 : [M]ABREV([M]NBABR) = ABR
  Endif
 Next I
Endif
End

Subprog AS_AMTDES(VALEUR)
Variable Char    VALEUR()
If [M]VARNAM(nolign-1)<>"" : mkstat = 2 : End : Endif
End

Subprog AS_AMTFOR(VALEUR)
Variable Char    VALEUR()
If [M]VARNAM(nolign-1)<>"" : mkstat = 2 : End : Endif
End

Subprog C_AMTFOR(VALEUR)
Variable Char    VALEUR()
Gosub C_FORMULE
End

$C_FORMULE
Local Integer I , J , K
Local Char    ABR(10)
I=0

$CONTFORM
J = instr(I+1,VALEUR,"[")
If J
 K = instr(J+1,VALEUR,"]")
 If K
  ABR = seg$(VALEUR,J+1,K-1)
  If !instr(1,ABR,"/")
   If left$(ABR,2)="F:"
    ABR = right$(ABR,3)
   Endif
   If !find(ABR,[M]ABREV(1..[M]NBABR))
    GMESSAGE = ABR-mess(5,124,1) : mkstat = 2 : End
#    Table non accessible
   Endif
  Endif
  I = K
  Goto CONTFORM
 Endif
Endif
Return

Subprog AS_DEVORG(VALEUR)
Variable Char    VALEUR()
If [M]CNV(nolign-1)<>2
 mkstat = 1 : End
Endif
End

Subprog C_DEVORG(VALEUR)
Variable Char    VALEUR()
If [M]CNV(nolign-1)=2 and VALEUR=""
 mkstat = 2 : GMESSAGE = mess(10,123,1) : End
Endif
End

Subprog AS_DEVDES(VALEUR)
Variable Char    VALEUR()
If [M]CNV(nolign-1)<>2
 mkstat = 1 : End
Endif
End

Subprog C_DEVDES(VALEUR)
Variable Char    VALEUR()
If [M]CNV(nolign-1)=2 and VALEUR=""
 mkstat = 2 : GMESSAGE = mess(10,123,1) : End
Endif
End

Subprog AS_AMTFRM(VALEUR)
Variable Char    VALEUR()
Local Integer I
GFRMNB = 0
For I=1 To [M]NBRAMT
 GFRMNB += 1
 GFRMVAR(GFRMNB) = "C"+num$(I) : GFRMLIB(GFRMNB) = [M]AMTDES(I-1)
Next I
For I=1 To [M]NBRAMT
 If [M]FRTFLG(I-1)=2
  GFRMNB += 1
  GFRMVAR(GFRMNB) = "P"+num$(I) : GFRMLIB(GFRMNB) = [M]AMTDES(I-1)-mess(102,126,1) : # (prévisions)
 Endif
Next I
For I=1 To [M]NBRAMT
 GFRMNB += 1
 GFRMVAR(GFRMNB) = "CC"+num$(I) : GFRMLIB(GFRMNB) = [M]AMTDES(I-1)-mess(103,126,1) : # (n-1)
Next I
For I=1 To [M]NBRAMT
 If [M]FRTFLG(I-1)=2
  GFRMNB += 1
  GFRMVAR(GFRMNB) = "PP"+num$(I) : GFRMLIB(GFRMNB) = [M]AMTDES(I-1)-mess(104,126,1) : # (prévisions n-1)
 Endif
Next I
End

Subprog C_AMTFRM(VALEUR)
Variable Char    VALEUR()
Default [L]
If [M]NBRAMT>0
 Local Decimal C1, CC1 : C1 = 1 : CC1 = 1
 If [M]FRTFLG(0)=2 : Local Decimal P1, PP1 : P1 = 1 : PP1 = 1 : Endif
Endif
If [M]NBRAMT>1
 Local Decimal C2, CC2 : C2 = 1 : CC2 = 1
 If [M]FRTFLG(1)=2 : Local Decimal P2, PP2 : P2 = 1 : PP2 = 1 : Endif
Endif
If [M]NBRAMT>2
 Local Decimal C3, CC3 : C3 = 1 : CC3 = 1
 If [M]FRTFLG(2)=2 : Local Decimal P3, PP3 : P3 = 1 : PP3 = 1 : Endif
Endif
If [M]NBRAMT>3
 Local Decimal C4, CC4 : C4 = 1 : CC4 = 1
 If [M]FRTFLG(3)=2 : Local Decimal P4, PP4 : P4 = 1 : PP4 = 1 : Endif
Endif
If [M]NBRAMT>4
 Local Decimal C5, CC5 : C5 = 1 : CC5 = 1
 If [M]FRTFLG(4)=2 : Local Decimal P5, PP5 : P5 = 1 : PP5 = 1 : Endif
Endif
If [M]NBRAMT>5
 Local Decimal C6, CC6 : C6 = 1 : CC6 = 1
 If [M]FRTFLG(5)=2 : Local Decimal P6, PP6 : P6 = 1 : PP6 = 1 : Endif
Endif
If [M]NBRAMT>6
 Local Decimal C7, CC7 : C7 = 1 : CC7 = 1
 If [M]FRTFLG(6)=2 : Local Decimal P7, PP7 : P7 = 1 : PP7 = 1 : Endif
Endif
If [M]NBRAMT>7
 Local Decimal C8, CC8 : C8 = 1 : CC8 = 1
 If [M]FRTFLG(7)=2 : Local Decimal P8, PP8 : P8 = 1 : PP8 = 1 : Endif
Endif
If [M]NBRAMT>8
 Local Decimal C9, CC9 : C9 = 1 : CC9 = 1
 If [M]FRTFLG(8)=2 : Local Decimal P9, PP9 : P9 = 1 : PP9 = 1 : Endif
Endif
If [M]NBRAMT>9
 Local Decimal C10, CC10 : C10 = 1 : CC10 = 1
 If [M]FRTFLG(9)=2 : Local Decimal P10, PP10 : P10 = 1 : PP10 = 1 : Endif
Endif
Onerrgo ERRFRM
X = evalue(VALEUR)
Onerrgo
End

$ERRFRM
GMESSAGE = VALEUR+"\"+errmes$(errn)+"\"+errm
mkstat = 2
Resume
