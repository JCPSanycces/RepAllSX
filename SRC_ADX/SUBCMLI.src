#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du masque CFGMLI
$ACTION
Case ACTION
  When "OUVRE"    : Gosub OUVRE_CMLI
  When "DEBUT"    : Gosub DEBUT_CMLI
  When "OK"       : Gosub OK_CMLI
Endcase
Return
############################################################
$OUVRE_CMLI
Local Integer W_I, W_J
#
If clalev([F:AML])  = 0 : Local File AMENLOC   [AML]  : Endif
If clalev([F:AST])  = 0 : Local File APLSTD    [AST]  : Endif
If clalev([F:TLP1]) = 0 : Local File TABLINCFG [TLP1] : Endif
Return
############################################################
$DEBUT_CMLI
Raz [M:CMLI]
Filter [AST] Where LANCHP = 760     &
&                  LAN    = GLANGUE &
&                  LANNUM > 0
&            Order By Key CLE
#
For [AST]
  If [F:AST]LANNUM <= dim([M:CMLI]TXT)
    [M:CMLI]TXT([F:AST]LANNUM-1) = [F:AST]LANMES
    [M:CMLI]NBLIG = [F:AST]LANNUM
  Endif
Next
Filter [AST]
Affzo [M:CMLI]
Return
############################################################
$OK_CMLI
Trbegin [AST]
GOK = 1
W_J = 0
Filter [AST] Where LANCHP = 760     &
&                  LAN    = GLANGUE &
&                  LANNUM > 0
&            Order By Key CLE
#
For [AST]
  Readlock [AST] Curr
  Case fstat
    When 1 :
      GOK = -1
      Break
    When 0 :
      If [F:AST]LANNUM > [M:CMLI]NBLIG
        Delete [AST]
        If fstat
          GOK = 0
          Call FSTA("AST") From GLOCK
          Break
        Endif
      Else
        If [F:AST]LANMES <> [M:CMLI]TXT([F:AST]LANNUM-1)
          [F:AST]LANMES = [M:CMLI]TXT([F:AST]LANNUM-1)
          [F:AST]UPDDAT = date$
          If dim([F:AST]UPDTIM)>0 [F:AST]UPDTIM = time Endif # Issue 94387 GA 11/2013 special V7/V8
          [F:AST]UPDUSR = GUSER
          Rewrite [AST]
          If fstat
            GOK = 0
            Call FSTA("AST") From GLOCK
            Break
          Endif
        Endif
      Endif
      W_J = [F:AST]LANNUM
    When Default :
      GOK = 0
      Call FSTA("AST") From GLOCK
      Break
  Endcase
Next
Filter [AST]
If GOK = 1 & W_J < [M:CMLI]NBLIG
  For W_I = W_J To [M:CMLI]NBLIG-1
    Raz [F:AST]
    [F:AST]LANCHP = 760
    [F:AST]LANNUM = W_I+1
    [F:AST]LAN    = GLANGUE
    [F:AST]LANMES = [M:CMLI]TXT(W_I)
    [F:AST]CREDAT = date$
    [F:AST]CREUSR = GUSER
    If dim([F:AST]CRETIM)>0 [F:AST]CRETIM = time Endif # Issue 94387 GA 11/2013 special V7/V8
    Write [AST]
    If fstat
      GOK = 0
      Call FSTA("AST") From GLOCK
      Break
    Endif
  Next W_I
Endif
#
Readlock [AST]CLE=760;0;GLANGUE
Case fstat
  When 1 :
    GOK = -1
  When 0 :
    [F:AST]LANMES=string$([M:CMLI]NBLIG,"1")
    Rewrite [AST]
    If fstat
      GOK = 0
      Call FSTA("AST") From GLOCK
    Endif
  When Default :
    GOK = 0
    Call FSTA("AST") From GLOCK
Endcase
#
Readlock [AML]MENLOC=760
Case fstat
  When 1 :
    GOK = -1
  When 0 :
    [F:AML]MAXI=120
    Rewrite [AML]
    If fstat
      GOK = 0
      Call FSTA("AML") From GLOCK
    Endif
  When Default :
    GOK = 0
    Call FSTA("AML") From GLOCK
Endcase
Case GOK
  When 1  :
    Commit
  When -1 :
    Rollback
    GERR = 1
    GMESSAGE = mess(10,100,1)-"APLSTD"
  When Default :
    GERR = 1
    GMESSAGE = mess(12,100,1)-"APLSTD"
    Rollback
Endcase
FIN = 1
Call MENULOC From GENMENULOC
Return
############################################################
Subprog C_NBLIG
Case status
  When 65 :
    If nolign < 2
      mkstat = 2
    Else
      Local Integer W_I
      Filter [TLP1]
      For [TLP1]
        W_I = 1
        While evalue("dim([F:TLP1]CFGNUM"+num$(W_I)+")>0")
          If  evalue("[F:TLP1]CFGNUM"+num$(W_I)+">=nolign")
            mkstat = 2
            Break
          Endif
          W_I += 1
        Wend
        W_I = 1
        While evalue("dim([F:TLP1]CFGALP"+num$(W_I)+")>0")
          If  evalue("[F:TLP1]CFGALP"+num$(W_I)+">=nolign")
            mkstat = 2
            Break
          Endif
          W_I += 1
        Wend
      Next
      Filter [TLP1]
    Endif
    If mkstat = 2
      GMESSAGE = mess(159,188,1)
    Endif
Endcase
End
