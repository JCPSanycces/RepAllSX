############################################################
Subprog AM_APLFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  [M:AAP]ATXFLG = 1
Endif
Affzo [M:AAP]ATXFLG
End
############################################################
Subprog AM_ATXFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  [M:AAP]APLFLG = 1
Endif
Affzo [M:AAP]APLFLG
End


