#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"ASEAAPL","ASEAAPL","",1,"") From GTRAITE
End


$ACTION
Case ACTION
  When "OUVRE"          : Gosub OUVRE_SEAAPL
  When "INIT"           : Gosub INIT_SEAAPL
  When "DEBUT"          : Gosub DEBUT_SEAAPL
  When "CONTROLE"       : Gosub CONTROLE_SEAAPL
  When "EXEC"           : Gosub EXEC_SEAAPL
  When "APRES_MODIF"    : Gosub APRES_MODIF_SEAAPL
  When "BOUTON"         : Gosub BOUTON_SEAAPL
  When "AVANT_OK"       : Gosub AVOK_SEAAPL
  When "OK"             : Gosub OK_SEAAPL
  When "END"            : Gosub END_SEAAPL
  When "FIN"            : Gosub FIN_SEAAPL
Endcase
Return
############################################################
$OUVRE_SEAAPL
Return
############################################################
$INIT_SEAAPL
Return
############################################################
$CONTROLE_SEAAPL
Return
############################################################
$EXEC_SEAAPL
Return
############################################################
$FIN_SEAAPL
If [M:AAP]NBLIG5 > 0
  Call PRTSCR("ASEAAPL","AAP","",0,0) From ATRTX3
  Call IMPSCR From ATRTX3
Endif
Return
############################################################
$INIT_DIA_SEAAPL
Return
############################################################
$DEBUT_SEAAPL
If clalev([F:AST]) = 0 : Local File APLSTD [AST] : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE [ATX] : Endif

Raz [M:AAP]
[M:AAP]LAN    = GLANGUE 
Affzo [M:AAP]
Return
############################################################
$APRES_MODIF_SEAAPL
Return
############################################################
$BOUTON_SEAAPL
Return
############################################################
$AVOK_SEAAPL
If [M:AAP]NBLIG1 = 0 & [M:AAP]NBLIG2 = 0 & [M:AAP]NBLIG3 = 0 & [M:AAP]NBLIG4 = 0 
  GERR = 1
  FIN  = 0
Endif
Return
############################################################
$OK_SEAAPL
Local Integer I, J, K, L
Local Char    WCR1(30)(max(1,[M:AAP]NBLIG1))
Local Char    WCR2(30)(max(1,[M:AAP]NBLIG2))
Local Char    WCR3(30)(max(1,[M:AAP]NBLIG3))
Local Char    WCR4(30)(max(1,[M:AAP]NBLIG4))
#
For I = 0 To [M:AAP]NBLIG1 -1
  WCR1(I) = [M:AAP]CRIT1(I)
Next I
#
For I = 0 To [M:AAP]NBLIG2 -1
  WCR2(I) = [M:AAP]CRIT2(I)
Next I
#
For I = 0 To [M:AAP]NBLIG3 -1
  WCR3(I) = [M:AAP]CRIT3(I)
Next I
For I = 0 To [M:AAP]NBLIG4 -1
  WCR4(I) = [M:AAP]CRIT4(I)
Next I
#
Affzo [M:AAP]5-35
Effzo [M:AAP]40
If [M:AAP]APLFLG = 2
  Call SEAAPL(I,WCR1,WCR2,WCR3,WCR4)
Endif
If [M:AAP]ATXFLG = 2
  Call SEAATX(I,WCR1,WCR2,WCR3,WCR4)
Endif
[M:AAP]FND = num$([M:AAP]NBLIG5)
Affzo [M:AAP]FND
Affzo [M:AAP]
FIN = 0
Return
############################################################
$END_SEAAPL
Return
############################################################
############################################################
Subprog SEAAPL(LOPT,LCR1,LCR2,LCR3,LCR4)
Value    Integer LOPT
Value    Char    LCR1()
Value    Char    LCR2()
Value    Char    LCR3()
Value    Char    LCR4()
#
Local Char    WMSG(80)
Local Char    WBUF(250) 
Local Integer K, L
#
Filter [AST] Where LAN = [M:AAP]LAN 
&            Order By Key CLE
For [AST]
  If [M]CASSE=2
      WBUF = ctrans([F:AST]LANMES)
  Else
      WBUF = toupper(ctrans([F:AST]LANMES))
  Endif
  For K = 0 To dim(LCR1)-1
    If [M]CASSE=2
        If LCR1(K) = "" | pat(WBUF,"*"+ctrans(LCR1(K))+"*")
          Break
        Endif    
    Else
        If LCR1(K) = "" | pat(WBUF,"*"+toupper(ctrans(LCR1(K)))+"*")
          Break
        Endif    
    Endif
  Next K
  If K <> dim(LCR1)
    For K = 0 To dim(LCR2)-1
      If [M]CASSE=2
          If LCR2(K) = "" | pat(WBUF,"*"+ctrans(LCR2(K))+"*")
            Break
          Endif    
    Else
          If LCR2(K) = "" | pat(WBUF,"*"+toupper(ctrans(LCR2(K)))+"*")
            Break
          Endif    
    Endif
    Next K
    If K <> dim(LCR2)
      For K = 0 To dim(LCR3)-1
        If [M]CASSE=2
            If LCR3(K) = "" | pat(WBUF,"*"+ctrans(LCR3(K))+"*")
              Break
            Endif    
        Else
            If LCR3(K) = "" | pat(WBUF,"*"+toupper(ctrans(LCR3(K)))+"*")
              Break
            Endif    
        Endif
      Next K
      If K <> dim(LCR3)
        For K = 0 To dim(LCR4)-1
          If [M]CASSE=2
              If LCR4(K) = "" | pat(WBUF,"*"+ctrans(LCR4(K))+"*")
                Break
              Endif    
          Else
              If LCR4(K) = "" | pat(WBUF,"*"+toupper(ctrans(LCR4(K)))+"*")
                Break
              Endif    
          Endif
        Next K
        If K <> dim(LCR4)
          Gosub LOA_APL
          If L <> 0
            Break
          Endif
        Endif
      Endif
    Endif
  Endif 
Next
Filter [AST]
End
############################################################
$LOA_APL
L = 0
If [M:AAP]NBLIG5 < dim([M:AAP]LANCHP)-1
  [M:AAP]LANCHP ([M:AAP]NBLIG5) = [F:AST]LANCHP
  [M:AAP]LANNUM ([M:AAP]NBLIG5) = [F:AST]LANNUM
  [M:AAP]LANMES ([M:AAP]NBLIG5) = [F:AST]LANMES
  [M:AAP]NBLIG5 += 1
  [M:AAP]FND     = num$([M:AAP]NBLIG5)
  If [M:AAP]NBLIG5 < 10
    Affzo [M:AAP]LANCHP([M:AAP]NBLIG5-1)
    Affzo [M:AAP]LANNUM([M:AAP]NBLIG5-1)
    Affzo [M:AAP]LANMES([M:AAP]NBLIG5-1)
  Endif
  Affzo [M:AAP]FND 
Else
  L = 1
Endif
Return
############################################################
Subprog SEAATX(LOPT,LCR1,LCR2,LCR3,LCR4)
Value    Integer LOPT
Value    Char    LCR1()
Value    Char    LCR2()
Value    Char    LCR3()
Value    Char    LCR4()
#
Local Char    WMSG(80)
Local Char    WBUF(250) 
Local Integer K, L
#
Filter [ATX] Where LAN = [M:AAP]LAN 
&            Order By Key NUMERO
For [ATX]
  WBUF = toupper(ctrans([F:ATX]TEXTE))
  For K = 0 To dim(LCR1)-1
    If LCR1(K) = "" | pat(WBUF,"*"+toupper(ctrans(LCR1(K)))+"*")
      Break
    Endif    
  Next K
  If K <> dim(LCR1)
    For K = 0 To dim(LCR2)-1
      If LCR2(K) = "" | pat(WBUF,"*"+toupper(ctrans(LCR2(K)))+"*")
        Break
      Endif    
    Next K
    If K <> dim(LCR2)
      For K = 0 To dim(LCR3)-1
        If LCR3(K) = "" | pat(WBUF,"*"+toupper(ctrans(LCR3(K)))+"*")
          Break
        Endif    
      Next K
      If K <> dim(LCR3)
        For K = 0 To dim(LCR4)-1
          If LCR4(K) = "" | pat(WBUF,"*"+toupper(ctrans(LCR4(K)))+"*")
            Break
          Endif    
        Next K
        If K <> dim(LCR4)
          Gosub LOA_ATX
          If L <> 0
            Break
          Endif
        Endif
      Endif
    Endif
  Endif 
Next
#Filter [AST]
Filter [ATX]
End
############################################################
$LOA_ATX
L = 0
If [M:AAP]NBLIG5 < dim([M:AAP]LANCHP)-1
  [M:AAP]LANCHP ([M:AAP]NBLIG5) = 0
  [M:AAP]LANNUM ([M:AAP]NBLIG5) = [F:ATX]NUMERO
  [M:AAP]LANMES ([M:AAP]NBLIG5) = [F:ATX]TEXTE
  [M:AAP]NBLIG5 += 1
  [M:AAP]FND     = num$([M:AAP]NBLIG5)
  If [M:AAP]NBLIG5 < 10
    Affzo [M:AAP]LANCHP([M:AAP]NBLIG5-1)
    Affzo [M:AAP]LANNUM([M:AAP]NBLIG5-1)
    Affzo [M:AAP]LANMES([M:AAP]NBLIG5-1)
  Endif
  Affzo [M:AAP]FND 
Else
  L = 1
Endif
Return
############################################################
Subprog AS_CRIT1(VALEUR)
Variable Char    VALEUR()
If nolign = 1
  [M:AAP]TXT1(nolign-1) = ""
Else
  [M:AAP]TXT1(nolign-1) = mess(2,56,1)
Endif
Affzo [M:AAP]TXT1(nolign-1)
End
