#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################
# SUBMML : Transactions Suivi des matières              SR      06/00 #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:BTS]BENCHTRS Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                                                                     #
# Génération      écran  de saisie à partir de l'écran MTKBENCHM      #
#                                                                     #
# Nom des écrans de base générés : WTxyyyz                            #
#                                  x = 51 pour plan global            #
#                                  x = 52 pour plan de travail        #
#                                  x = 53 pour regroupements          #
#                                  x = 60 pour suivi des temps        #
#                                  x = 61 pour suivi des matières     #
#                                                                     #
#                                  yyy = nom de la transaction        #
#                                                                     #
#                                  z = numéro d'ordre de l'écran      #
# Exemple:                                                            #
#######################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE   
                      Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="BTS"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=61
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M]BTSTYP = 61
 When "SETBOUT"     : Gosub SETBOUT  
 When "EXEBOUT"     : Gosub EXEBOUT  
 When "LIENS"       : Gosub TRT_DIETRS From SUBDST : Gosub LIENS
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INICRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Delete [AXX] Where CODFIC="BENCHTRS" & IDENT1=num$([F:BTS]BTSTYP) & IDENT2=[F:BTS]BTSNUM
                      Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="BTS"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When Default
Endcase
Return

#-------------------------------------------------------#
# Définir le dossier pour la génération des écrans      #
#-------------------------------------------------------#
$OUVRE
Local Char    LIBEL(30) , MASKREF(GLONAMK)
Local Integer ER
Local Char     WMODU(3) : WMODU="T"
Local Char     WNOMOBJ(GLONAOB)
Local Char     WNOMTRS(GLONTRS)
Local Char     WACSCOD(GLONACS)
Local Char     WLIBEL(30)
Local Shortint WNUM
Local Shortint WENAFLG

MASKREF = "MTKBENCHM"

If clalev ([F:AMZ]) <= 0  : Local File AMSKZON [AMZ] : Endif
If clalev ([F:AMK])  = 0  : Local File AMSK    [AMK] : Endif
If clalev ([F:AMA])  = 0  : Local File AMSKACT [AMA] : Endif
If clalev ([F:AMP])  = 0  : Local File AMSKPAR [AMP] : Endif
If clalev ([F:ADS])  = 0  : Local File ADOSSIER[ADS] : Endif

Return


#-------------------------------------------------------#
# Ne traiter que les transactions du suivi des temps    #
#-------------------------------------------------------#
$FILTRE
FILTSUP="BTSTYP=61"
Return

#------------------------------------------#  
# Désactivation bouton validation et copie #  
#------------------------------------------#  
$SETBOUT  
If GREP <>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif  
Call VIREBOUT(CHAINE,"H") From GOBJET
Return  
  
#------------------------------------------------#  
# Après appui sur bouton "Validation" ou "copie" #  
#------------------------------------------------#  
$EXEBOUT  
MASKREF = "MTKBENCHM"
Case REP  
  When "1" : Call DEBTRANS From GLOCK  
             Trbegin ADOVAL  
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
When Default  
Endcase  
Return  
 
#------------------------------------------------#  
# Chargement enregistrement                      #  
#------------------------------------------------#  
$LIENS
Actzo [M:MML1]15
Actzo [M:MML3]2
MASKREF = "MTKBENCHM"
If clalev([M:DST])
  [M:DST]CCESCR  = 3
  Affzo [M:DST]
  Grizo [M:DST]10
Endif

If dim([M:MML1]WRHCOD) >0
    If [M:MML1]WRHCOD=0  [M:MML1]WRHCOD=3  : Endif : # Dépôt
Endif
If dim([M:MML1]WRHCOD) >0
  If [M:MML1]WRHOBY = 2
    Grizo [M:MML1]WRHCOD 
  Else
    Actzo [M:MML1]WRHCOD
  Endif
Endif

Gosub PE_MFGTRS From SUBMFX

# chargement champs paramétrés
[M]NBRFLD = 0
Gosub CHARGE_CHAMP 
Raz [M]DAC
For NOL=0 To [F:BTS]NBRFLD-1 
    K = find([F:BTS]FLD(NOL),[M]FLD(0..[M]NBRFLD)) 
    If K 
      [M]DAC(K-1) = [F:BTS]DAC(NOL) 
     Endif
Next NOL
Gosub TRI

Return

$RAZCRE
If clalev([M:DST])
  [M:DST]CCESCR  = 3
  Affzo [M:DST]
  Grizo [M:DST]10
Endif

Raz [M:MML1], [M:MML2], [M:MML3]

If dim([M:MML1]WRHCOD)>0 [M:MML1]WRHCOD=3 Endif

[M:MML2]FILTDEF = 1
[M:MML2]FILTFLG = 1
[M:MML2]STOCODDEF = 1
[M:MML2]CRIT1 = 1
[M:MML2]CRIT2 = 2

Gosub PE_MFGTRS From SUBMFX

If !GIMPORT
    Affzo [M:MML2]
Endif

Return

#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
Gosub CHARGE_ATEXTRA From SUBMML
Gosub PE_MFGTRS From SUBMFX
Return

#----------------------------------------#
# Création ou modif du texte traductible #
#----------------------------------------#
$CHARGE_ATEXTRA
Call MAJTEXTRA([M:MML0]DESAXX,"BENCHTRS","DESAXX",num$([M:MML0]BTSTYP),[M:MML0]BTSNUM) From ATEXTRA
[F:BTS]BTSDES   =GLANGUE+"~"+[M:MML0]DESAXX
[F:BTS]BTSTYPCAR=num$([F:BTS]BTSTYP)
Return

#################################################
$APRES_MODIF
Gosub PE_MFGTRS From SUBMFX
Return

#------------------------------------------------#
# Génération ou suppression de l'écran de saisie #
#------------------------------------------------#
$TRT_ECRAN

If dim(APPLI)<0 Local Char APPLI : Endif
If dim(WMODU)<0 Local Char WMODU(3) : WMODU="T" : Endif
If APPLI=""    APPLI=nomap       : Endif
If WMODU="T"   WMODU="T"+format$("N0:2",[M:MML0]BTSTYP) : Endif
Local Char     MFROM(GLONAMK)
Local Char     MTO(GLONAMK), MTOB(GLONAMK)
Local Integer  TBLOC(15)
Local Char     TZONE(GLONAVA)(200)
Local Integer  TMOD(200)
Local Char     TINT(1)(200)
Local Char     TTAB(1)(1)
Local Char     TFLD(1)(1)
Local Integer  OPT1, OPT2, OPT3, RETOUR
Local Integer  IZON, I, FLAG
Local Char     BOUTONS(10)(4)
Local Char     TEXTE(40), LISTE(3), REPONS(1), WOPTION(15)  
Local Char     WNOMMSK(GLONAMK)
Local Shortint WFLGMSK

Local Integer OK , NOL , NCOL , LANCUR, J
Local Decimal RANG, WRANG
#---------------- Noms fenêtres et traitement ---------#
Local Char     WINREF1(GLONFEN) : WINREF1="IMBM"
Local Char     NOMWIN1(GLONFEN) : NOMWIN1="WIMBM"+[M:MML0]BTSNUM
Local Char     NOMTRT1(GLONADC) : NOMTRT1="WGIMBM"+[M:MML0]BTSNUM
Local Char     NOMMSKENT(GLONAMK)    # Nom du masque d'entête de la fenêtre

If clalev([F:AMK2])=0 : Local File =APPLI+".AMSK"    [AMK2] : Endif
If clalev([F:AMZ2])=0 : Local File =APPLI+".AMSKZON" [AMZ2] : Endif
If clalev([F:AMA2])=0 : Local File =APPLI+".AMSKACT" [AMA2] : Endif
If clalev([F:AMP2])=0 : Local File =APPLI+".AMSKPAR" [AMP2] : Endif
If clalev([F:ADS])=0  : Local File  ADOSSIER [ADS] : Endif
If !find(ACTION,"ANNULE","MASSE")
    If [M:MML1]OFFLG = 1 & [M:MML1]BOMFLG = 1    
        Call ERREUR(mess(25,190,1)) From GESECRAN
       Return
    Endif 
Endif
MFROM ="MTKBENCHM"
MTO   = "WT"+num$([M:MML0]BTSTYP)+[M:MML0]BTSNUM+"1"
If ACTION <> "ANNULE"
        Gosub TR1
        If GOK=1
                Call VALID(MTO,APPLI,1,GLANGUE,1,OK) From VALMSK
        Endif
Endif

If ACTION="ANNULE" :  Call DELMSK(MTO, APPLI) From MSKDIV : Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif
Return


$TR1
GOK = 1
Call DELMSK(MTO,APPLI) From MSKDIV
Read [AMK]CODMSK = MFROM
[F:AMK2] = [F:AMK]
[F:AMK2]CODMSK = MTO
[F:AMK2]MDL = 1                # !!
NCOL = 0
NCOL = find(1,[F:AMK2]TYPBLOC(0..dim([F:AMK]TYPBLOC)-1))
If NCOL
        For J = 1 To 9
           K = instr(1,[F:AMK2]OPTION(NCOL-1),num$(J))
           If K
               [F:AMK2]OPTION(NCOL-1) = left$([F:AMK2]OPTION(NCOL-1),K-1) + 
&                                       right$([F:AMK2]OPTION(NCOL-1),K+1)
           Endif
        Next J
        If [F:BTS]NBRCOL > 0 # Gestion des colonnes fixes
            [F:AMK2]OPTION(NCOL-1) += num$([F:BTS]NBRCOL)
        Endif
        [F:AMK2]ACTBLOC(NCOL-1) = ""
        [F:AMK2]NBLIGT(NCOL-1)  = [F:BTS]NBRLIG
Endif
#     [F:AMK2]TRTAUTO = MTO
Write [AMK2]
If fstat
       GOK=0 : Call FSTA("AMK2") From GLOCK : Return
Endif
Read [AMZ]CODE = MFROM;"NBLIG"
If fstat=0 : J=[F:AMZ]NUMBLOC : Else J=0 : Endif
For [AMZ]CODZON Where CODMSK=MFROM & CODTYP <> "CCE"
         NOL = find([F:AMZ]CODZON,[F:BTS]FLD(0..[F:BTS]NBRFLD-1))
         OK = 0
         If NOL & [F:BTS]DAC(NOL-1)<>0
             OK = 1 : RANG = [F:BTS]DAC(NOL-1)
         Endif
         If [F:AMZ]CODTYP="ABS"
             OK = 1 : RANG = 0
         Elsif [F:AMZ]CODZON ="PECFLG"
             OK = 1 : RANG = 1
         Elsif [F:AMZ]CODZON ="IPTDAT"
             OK = 1 : RANG = 2
         Elsif [F:AMZ]CODZON ="MATTYP"
             OK = 1 : RANG = 3
         Elsif [F:AMZ]SAIAFF=3 | (J & [F:AMZ]NUMBLOC<>J)
             OK = 1 : RANG = [F:AMZ]NOZONE
         Endif
         If RANG > WRANG : WRANG = RANG : Endif
         [F:AMZ2] = [F:AMZ]
         [F:AMZ2]CODMSK = MTO
         [F:AMZ2]NOZONE = RANG
         If [F:AMZ]CODTYP="ABS"
             [F:AMZ2]SAIAFF = 1
         Elsif find([F:AMZ2]CODZON,"PECFLG","IPTDAT","MATTYP")
             [F:AMZ2]SAIAFF = 1
         Elsif find([F:AMZ2]CODZON,"FILTMAT","WRHE")
            Case [F:AMZ2]CODZON
                When "FILTMAT" : [F:AMZ2]SAIAFF = [F:BTS]FILTFLG
                When "WRHE"    : [F:AMZ2]SAIAFF = [F:BTS]WRHCOD
            Endcase
         Elsif !OK 
               [F:AMZ2]SAIAFF = 3
         Else
             [F:AMZ2]SAIAFF = [F:AMZ]SAIAFF
         Endif
         Gosub PE_MFGTRS From SUBMFX
         If [F:AMZ2]SAIAFF=3 & [F:AMZ2]OPTFOR<>"" & left$([F:AMZ2]OPTFOR,1)<>"-"
             [F:AMZ2]OPTFOR = "-"+[F:AMZ2]OPTFOR
         Endif
         Write [AMZ2]
         If fstat
             GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
         Endif
Next
If GOK < 1 : Return : Endif
RANG = WRANG
For [AMZ]CODZON Where CODMSK=MFROM & CODTYP = "CCE"
    RANG = RANG + 1
    [F:AMZ2] = [F:AMZ]
    [F:AMZ2]CODMSK = MTO
    [F:AMZ2]NOZONE = RANG
    [F:AMZ2]SAIAFF = 1
    Gosub PE_MFGTRS From SUBMFX
    # on laisse cette ligne a cause du point d entree qui peut intervenir sur SAIAFF
    If [F:AMZ2]SAIAFF=3 & [F:AMZ2]OPTFOR<>"" & left$([F:AMZ2]OPTFOR,1)<>"-"
       [F:AMZ2]OPTFOR = "-"+[F:AMZ2]OPTFOR
    Endif
    Write [AMZ2]
    If fstat
       GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
    Endif
Next
If GOK < 1 : Return : Endif

For [AMA] Where TYPAFF=1 & CODAFF=MFROM
         [F:AMA2] = [F:AMA]
         [F:AMA2]CODAFF = MTO
         Write [AMA2]
         If fstat
             GOK=0 : Call FSTA("AMA2") From GLOCK : Break
         Endif
Next
If     GOK < 0 : Return : Endif
For [AMP] Where TYPAFF=1 & CODAFF=MFROM
         [F:AMP2] = [F:AMP]
         [F:AMP2]CODAFF = MTO
         Write [AMP2]
         If fstat
             GOK=0 : Call FSTA("AMP2") From GLOCK : Break
         Endif
Next
Return

######################################################################################
# Etiquettes gestion paramétrage affichage
######################################################################################
$CHARGE_CHAMP
# dans quel bloc se situe le tableau ?
Read [AMZ]CODE = MASKREF;"NBLIG"
If fstat=0 : J=[F:AMZ]NUMBLOC : Else J=0 : Endif

For [AMZ]CODZON Where CODMSK=MASKREF &  CODTYP <> "CCE"    
    OK = 1
    If [F:AMZ]CODTYP="ABS" | [F:AMZ]SAIAFF=3 | (J & [F:AMZ]NUMBLOC<>J) |
&      find([F:AMZ]CODZON,"PECFLG","IPTDAT","MATTYP")
        OK = 0
    Endif
    If OK & !find([F:AMZ]CODZON,[M]FLD(0..[M]NBRFLD-1))
        NOL = [M]NBRFLD
        [M]FLD(NOL) = [F:AMZ]CODZON
        Gosub LIBEL 
        [M]NBRFLD += 1 
    Endif 
Next 
Return 

######################################################################################
$LIBEL
If [F:AMZ]INTEVAL <> ""
    Onerrgo ERRLIB
    ER = 0
    [M]INTIT(NOL) = evalue([F:AMZ]INTEVAL)
    If ER
        [M]INTIT(NOL) = [F:AMZ]INTEVAL
    Endif
    Onerrgo
Else
    Call TEXTE([F:AMZ]INTIT,LIBEL) From OBJDIV
    [M]INTIT(NOL) = LIBEL
Endif
Return

######################################################################################
$ERRLIB
ER = errn
Resume

######################################################################################
$TRI
For NOL=0 To [M]NBRFLD-1
 If [M]DAC(NOL)=0 : [M]DAC(NOL) = 9999 : Endif
Next NOL
Sorta [M]NBRFLD [M]NBRFLD Order By [M]DAC(indice)
For NOL=0 To [M]NBRFLD-1
 If [M]DAC(NOL)=9999 : [M]DAC(NOL) = 0 : Endif
Next NOL
Return


#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW" [AWI] : Endif : # Si appel par le FUNMFGTRS
If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR" [AWP] : Endif : # Si appel par le FUNMFGTRS
If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par le FUNSTKTRS

#----- Suppression fenêtre -----#
Gosub TRT_SUP_FEN 
If [M:MML0]ENAFLG=1 : Return : Endif
#----- Génération fenêtre pour suivi si transaction active -----#
Delete [AWI] Where WIN=NOMWIN1
If fstat=1  GOK=-1 : GLOCK="$AWINDOW"-NOMWIN1
Elsif fstat GOK=0  : Call RSTA ("AWI",NOMWIN1) From GLOCK
Endif
Delete [AWP] Where WIN=NOMWIN1
If fstat=1  GOK=-1 : GLOCK="$AWINPAR"-NOMWIN1
Elsif fstat GOK=0  : Call RSTA ("AWP",NOMWIN1) From GLOCK
Endif

Read [AWI] AWI0=WINREF1
If !fstat
  [F:AWI]WIN       = NOMWIN1
  WNOMMSK=MTO
  [F:AWI]NOMMSK(0) = WNOMMSK
  [F:AWI]ACS       = [M:MML0]ACSCOD
  If dim([F:AWI]LIBEL)>0
     Call LECTEXTRA([F:AWI]LIBEL,"BENCHTRS","DESAXX",num$([M:MML0]BTSTYP),[M:MML0]BTSNUM) From ATEXTRA
  Endif
  [F:AWI]ENAFLG    = 2
  [F:AWI]TRN       = [M:MML0]BTSNUM
  [F:AWI]MDL = 1                # !!

  # Issue 79269 - New entry Point to Hide/Show Specific Tab
  Gosub PE_MFGTRSWIN From SUBMFX 

  Write [AWI]
  If fstat GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
  For [AWP] AWP0 Where WIN=WINREF1
    [F:AWP]WIN = NOMWIN1
    Write [AWP]
    If fstat GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
  For [AWB] AWB0 Where WIN=WINREF1
    [F:AWB]WIN = NOMWIN1
    Write [AWB]
    If fstat GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
  Next
  For [AWT] AWT0 Where WIN=WINREF1
    [F:AWT]WIN = NOMWIN1
    Write [AWT]
    If fstat GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif

Endif
Call VALID(NOMWIN1,APPLI,1,OK) From VALWIN
Return


#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
#----- Suppression ----#
Call DELWIN(NOMWIN1,APPLI) From MSKDIV
Return



######################################################################################
# Etiquettes écran
######################################################################################

########################################
#-----------------------#
# Avant zone code actif #
#-----------------------#
Subprog AV_ENAFLG(VALEUR)
Variable Integer VALEUR
If GREP<>"C" & VALEUR=0 VALEUR=2 : Endif
End

########################################
Subprog AM_BTSNUM(VALEUR)
Variable Char    VALEUR()
Local Integer OK , I, NOL
Local Char    LIBEL(30) , MASKREF(GLONAMK)
Local Integer INC : INC = 0

If GREP = "C" | [M:MML3]NBRFLD = 0
    MASKREF = "MTKBENCHM"
    [M]NBRFLD = 0
    Gosub CHARGE_CHAMP
Endif

# activation par défaut des champs si tableau vide (création)
OK = max([M:MML3]DAC(0..[M:MML3]NBRFLD - 1))
If !OK  
    For I = 0 To [M:MML3]NBRFLD-1
        INC += 5
        [M:MML3]DAC(I) = INC
    Next I
Endif
If !GIMPORT : Affzo [M:MML3]10 : Endif

End

########################################
Subprog B1_NBRFLD
Local Integer I
If [M:MML3]DAC(nolign-1) = 0
    [M:MML3]DAC(nolign-1) = max([M:MML3]DAC(0..[M:MML3]NBRFLD - 1)) + 5
    If !GIMPORT : Affzo [M:MML3]10 : Endif
Else
    For I = 0 To [M:MML3]NBRFLD - 1
        If [M:MML3]DAC(I) > [M:MML3]DAC(nolign-1) 
            [M:MML3]DAC(I) -= 5        
        Endif
    Next I
    [M:MML3]DAC(nolign-1) = 0
    If !GIMPORT : Affzo [M:MML3]10 : Endif
Endif
mkstat = 4
End

########################################
Subprog AS_NBRFLD
Raz GBOUT1, GBOUT2, GBOUT3
If [M:MML3]FLD(nolign-1) <> "" 
    GBOUT1 = mess(306,198,1) 
    GBOUT2 = mess(396,198,1)
    GBOUT3 = mess(385,198,1)
Endif
End

########################################
Subprog B2_NBRFLD
Local Integer NOL
Gosub TRI    
If !GIMPORT : Affzo [M:MML3]10 : Endif
End

########################################
Subprog B3_NBRFLD
Local Integer I, NOL
Local Integer INC : INC = 0
Gosub TRI    
For I = 0 To [M:MML3]NBRFLD - 1
    If [M:MML3]DAC(I) = 0 : Break : Endif
    INC += 5
    [M:MML3]DAC(I) = INC
Next I
If !GIMPORT : Affzo [M:MML3]10 : Endif
End

########################################
Subprog AS_FILTDEF(VALEUR)
Variable Integer VALEUR
If [M:MML1]OFFLG = 1 : mkstat = 2 : End : Endif
End

########################################
Subprog AS_FILTFLG(VALEUR)
Variable Integer VALEUR
If [M:MML1]OFFLG = 1 : VALEUR = 3 : mkstat = 2 : End : Endif
End

########################################
Subprog C_CRIT2(VALEUR)
Variable Integer VALEUR
If VALEUR = [M:MML2]CRIT1 : GMESSAGE = mess(144,193,1) : mkstat = 1 : End : Endif
End

#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(7)<>2 End Endif

# Validation transactions depuis génération des patchs
Call GENPATCH(61,APPLI) From FUNMFGTRS

End
###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #                                          
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

# Génération transactions à partir du dico des types de transaction
Call GENDOS(61,APPLI) From FUNMFGTRS

End


########################################
Subprog AS_CRIT1(VALEUR)
Variable Integer VALEUR
GMENLOC(5) = 1
End

########################################
Subprog AS_CRIT2(VALEUR)
Variable Integer VALEUR
GMENLOC(5) = 1
End

########################################
Subprog AS_BTSNUM(VALEUR)
Variable Char    VALEUR()
[M:MML0]BTSTYP = 61
End


########################################################
# Pour exécution de la copie en masse depuis le menu : #
# Utilitaires - Dictionnaire - Copie transactions      #
########################################################
$TRTCOP
Local Integer MODULE    : MODULE=8
Local Integer TYP       : TYP=61
Local Char    CODTAB(GLONTRS) : CODTAB=TABLE
#-----
Gosub OUVRE_COPTRS From SELTRS
Gosub EXEC_COPTRS  From SELTRS
Gosub FERME_COPTRS From SELTRS
Return
