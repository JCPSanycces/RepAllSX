Subprog AM_WRHOBY(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
    [M:MML1]WRHCOD = 1
    Grizo [M:MML1]WRHCOD
Else
    Actzo [M:MML1]WRHCOD
Endif
Affzo [M:MML1]WRHCOD
End


