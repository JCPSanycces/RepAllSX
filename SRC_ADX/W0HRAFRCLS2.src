#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRAFRCLS2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone LIGNUM
mkstat = 0
zoncou = "LIGNUM"
indice = 0
status = 1
zoncou = "LIGNUM"
If varmode([M]LIGNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LIGNUM" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]LIGNUM
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]LIGNUM = nolign
   status = 75
   Call SAI_LIGNUM(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone LIGNUMREM
mkstat = 0
zoncou = "LIGNUMREM"
indice = 0
status = 1
zoncou = "LIGNUMREM"
If varmode([M]LIGNUMREM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LIGNUMREM" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]LIGNUMREM
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]LIGNUMREM = nolign
   status = 75
   Call SAI_LIGNUMREM(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone LIGNUMTOT
mkstat = 0
zoncou = "LIGNUMTOT"
indice = 0
status = 1
zoncou = "LIGNUMTOT"
If varmode([M]LIGNUMTOT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LIGNUMTOT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]LIGNUMTOT
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]LIGNUMTOT = nolign
   status = 75
   Call SAI_LIGNUMTOT(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_LIGNUM(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone LIGNUM
mkstat = 0
zoncou = "LIGNUM"

## Zone LIGNUM
mkstat = 0
zoncou = "LIGNUM"

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_LIGNUMREM(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone LIGNUMREM
mkstat = 0
zoncou = "LIGNUMREM"

## Zone LIGNUMREM
mkstat = 0
zoncou = "LIGNUMREM"

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_LIGNUMTOT(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone LIGNUMTOT
mkstat = 0
zoncou = "LIGNUMTOT"

## Zone LIGNUMTOT
mkstat = 0
zoncou = "LIGNUMTOT"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HRAFRCLS2"
Return

