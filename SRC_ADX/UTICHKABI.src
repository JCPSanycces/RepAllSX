#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTICHKABI Check BI setup                                               #
##########################################################################
Local Char DOSSIER(30)

DOSSIER = nomap
#Call SAIDOS(DOSSIER, "") From SAIDOS
If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call UTICHKABI(DOSSIER,[V]CST_AYES)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif
End

##########################################################################
Subprog UTICHKABI(DOSSIER,PSIM)
Value Char DOSSIER
Value Integer PSIM

Local Integer NBERR, NBWRN
Local Integer NBFLD
Local Char    FLDDIM(255)(1..)
Local Char    FLDORG(255)(1..)
Local Char    MSGERR(255)

Call ECR_TRACE("UTICHKABI: Process Start on : "+DOSSIER,0) From GESECRAN

If filinfo(filpath("FIL","ATABLE","fde",DOSSIER),0)<0 : End : Endif
If filinfo(filpath("FIL","ATABIND","fde",DOSSIER),0)<0 : End : Endif
If filinfo(filpath("FIL","ABIDIM","fde",DOSSIER),0)<0 : End : Endif
If filinfo(filpath("FIL","ABIDIMFLD","fde",DOSSIER),0)<0 : End : Endif
Local File =DOSSIER+".ABIDIM" [ABI]
Local File =DOSSIER+".ABIDIMFLD" [ABJ]

Call ECR_TRACE("-- Check if Incremental update is possible"-string$(PSIM=[V]CST_AYES,"(Simulation)")-" --",0) From GESECRAN
Trbegin [ABI]
For [ABI] Where find(TYPMAJ,1,3)<>0
    Raz NBFLD, FLDORG
    For [ABJ] Where [ABJ]CODDIM=[F:ABI]CODDIM
        NBFLD+=1
        FLDDIM(NBFLD) = [F:ABJ]FLDDIM
        FLDORG(NBFLD) = [F:ABJ]FLDORG
    Next
    LRES = func SUBABI.CHECK_INCUPD(DOSSIER, [F:ABI]TABORG, [F:ABI]INDLEC, FLDDIM, FLDORG, NBFLD, [F:ABI]CLE, MSGERR)
    If LRES<>[V]CST_AOK
        Call ECR_TRACE("Update dimension"-[F:ABI]CODDIM,0) From GESECRAN
        [F:ABI]TYPMAJ = 2
        Rewrite [ABI]
        If fstat
            Call ECR_TRACE(func GLOCK.GET_FSTAT_MSG(fstat),1) From GESECRAN
            NBERR+=1
        Endif
    Endif
Next
If PSIM=[V]CST_AYES
    Rollback
Else
    Commit
Endif

LogicClose File [ABI]
LogicClose File [ABJ]
Call ECR_TRACE("UTICHKABI ended with " - num$(NBERR) - "errors & "+num$(NBWRN)-"warnings",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call UTICHKABI(APPLI,[V]CST_ANO)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  Call UTICHKABI(APPLI,[V]CST_ANO)
End

