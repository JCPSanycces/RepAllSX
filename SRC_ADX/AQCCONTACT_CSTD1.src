#<AdxTL>@(#)2.0.0.0 $Revision$
# Class AQCCONTACT


$METHODS
Case [L]CURPTH
   When ""
      Case [L]ACTION
      When "AREAD_AFTER" : Gosub AREAD_AFTER
      When "CONTACTOP"   : Gosub CONTACTOP
      Endcase
Endcase
Return


$PROPERTIES
Case [L]CURPRO
Endcase
Return

#########################################################################
$AREAD_AFTER

Local File AQCBPR [AQCBPR]
Read [AQCBPR]BPR0=this.BPANUM  # Aparent ????? for BPR .. then set BPR = 'AAAAA'.
If !fstat
   this.BPANUM="TEST " +  this.BPANUM   #[F:AQCBPR]BPRNAM(0)
   #If this.APARENT.COD<>null
   ##### this.APARENT.COD.COD="AAAAAA" modify parent property test ...........
Endif
LogicClose File [AQCBPR]
Return


Return
#######################################################################
$CONTACTOP

Local Instance  AQCCONTACT Using C_AQCCONTACT
AQCCONTACT = NewInstance C_AQCCONTACT AllocGroup null
[L]ASTATUS = fmet AQCCONTACT.AREAD(BPATYP,BPANUM.CCNCRM)
#            WOK= fmet this.ASETATTRIBUTE("TEXTDES","$isDisabled","true")
#            WOK= fmet this.ASETATTRIBUTE("CUR","$isDisabled","true")
this.AQCCONTACT.CCNCRM="111111111111122"
FreeGroup AQCCONTACT


Return
#######################################################################

