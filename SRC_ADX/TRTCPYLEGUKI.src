Subprog C_SRTCOD(VALEUR)
Variable Char    VALEUR()
  If len(VALEUR) > 0 Then
    If len(VALEUR) > 6 | len(VALEUR) < 6 Then
      GERR=1
      GMESSAGE = "Sort code must be 6 characters"
      mkstat=2 : End
    Endif
  Else
    VALEUR = ""
  Endif
End



Subprog AM_SRTCOD(VALEUR)
Variable Char    VALEUR()
Local Char FTWO(5), STWO(5), STR(8)
FTWO = left$(VALEUR,2) : FTWO = FTWO+"-"
STWO = right$(left$(VALEUR,4),3) : STWO = STWO+"-"
STR = FTWO+STWO+right$(VALEUR,5)

VALEUR = STR
If VALEUR = "--" : VALEUR = "" : Endif
Affzo [M:CPYUKI]SRTCOD(nolign-1)

End


Subprog AS_SRTCOD(VALEUR)
Variable Char    VALEUR()
Local Char LEF(2), MID(2) ,RIG(2)
LEF = left$(VALEUR,2)
MID = right$(left$(VALEUR,5),4)
RIG = right$(VALEUR,7)

VALEUR = LEF+MID+RIG
If VALEUR = "--" : VALEUR = "" : Endif
Affzo [M:CPYUKI]SRTCOD(nolign-1)

End

#DEHEN - 2017-03-21 - X3-15932 - END

