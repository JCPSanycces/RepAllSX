######################################################################################
Subprog AP_AOR3(VALEUR)
Variable Char    VALEUR()
  Call CHECK_AOR(VALEUR)
  [M:CPYUKI]ACCOFFREF = num$([M:CPYUKI]TAXDTT)+"P"+[M:CPYUKI]AOR2+VALEUR
  Affzo [M:CPYUKI]ACCOFFREF
  Affzo [M:CPYUKI]AOR3
  Affzo [M:CPYUKI]AOR2
End


######################################################################################
#DEHEN - Address selection - START
$SEL_BPA
Local Char    ZON(30) , ABR(GLONABR)
Local Integer DEB , SUITE
Local Char    WCOD(GLONADR)(1..GNBSEL) , WDES(GLONDES)(1..GNBSEL) , WPOS(GLONPOS)(1..GNBSEL)
Local File   (Char BPAADD(GLONADR) , Char BPADES(GLONDES) , Char POSCOD(GLONPOS))
&             From Variable WCOD , WDES , WPOS As [ADR_] Order By BPAADD

NBCOL = 0
For ZON="BPAADD","BPADES","POSCOD"
 NBCOL += 1
 COL(NBCOL) = "[F:ADR_]"+ZON
 COLTYP(NBCOL) = evalue("type([F:ADR_]"+ZON+")")
 Call TITZON("BPADDRESS",ZON,TIT(NBCOL)) From CONTOBJ
Next ZON
Gosub LEC_BPA

Return

$LEC_BPA
Raz J , SUITE
For I=DEB To [M:BPA]NBADR-1
 If J>=dim(WCOD)
  SUITE = 1 : Break
 Endif
 J += 1
 WCOD(J) = [M:BPA]CODADR(I)
 WDES(J) = [M:BPA]BPADES(I)
 WPOS(J) = [M:BPA]POSCOD(I)
Next I

For I=J+1 To dim(WCOD)
 WCOD(I) = chr$(255)
Next I
adxmxl = J

Return
#DEHEN - Address selection - START

