#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
  Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "DEBUT"        : Gosub DEBUT
  When "OK"           : Gosub OK
  When "SEL_TABLE"    : Gosub SEL_TABLE
  Endcase
Return

$OUVRE
  If clalev([F:CPYUKI])=0 : Local File HRCOMPANYUKI [CPYUKI]  : Endif
  If clalev([F:CUAL])=0   : Local File HRCPYUKALL [CUAL]      : Endif
  If clalev([F:CUCA])=0   : Local File HRCPYUKCAR [CUCA]      : Endif
Return

$DEBUT
Local Integer COUNT : COUNT = 0
  Raz [M:CPYUKI]
  [M]CPY = [M:CPY0]CPY
  [M:CPYUKI]CPYNAM = [M:CPY0]CPYNAM #DEHEN - 2017-03-20 - X3-29512
  Read [F:CPYUKI]CPYUKI0 = [M:CPY0]CPY
  If !fstat
    [M:CPYUKI] = [F:CPYUKI]
  Else
    Return
  Endif

  Affzo [M:CPYUKI]

#HEGES - 2017-02-15 - X3-31138 - Start
If [M:CPYUKI]APPLEVALL <> 2
  If dim([M:CPYUKI]APPLEVAMT)>0 : Chgfmt [M:CPYUKI]APPLEVAMT With "-N:5" : Endif
Endif
#HEGES - 2017-02-15 - X3-31138 - End

#ALHAR - 2017-08-16 - X3-47333 - fields removed
#For [CUAL]CUAL0 Where [F:CUAL]CPY = [M:CPYUKI]CPY
#    [M:CPYUKI]ALLDAT(COUNT) = [F:CUAL]DAT
#    [M:CPYUKI]ALLAMT(COUNT) = [F:CUAL]AMT
#COUNT+=1
#Next
#ALHAR - 2017-08-16 - X3-47333 - end

#ALHAR - 2017-08-16 - X3-47333 - fields removed
#Assign "[M:CPYUKI]NBALL" With COUNT
#ALHAR - 2017-08-16 - X3-47333 - end

#DEHEN - 2017-04-04 - X3-31054 - Once off employment allowance - START
If [M:CPYUKI]CLMEMPALL = 2 : Grizo [M:CPYUKI]CLMEMPALL : [M:CPYUKI]CLMEMPVAL = "3000.00" : Endif
#DEHEN - 2017-04-04 - X3-31054 - Once off employment allowance - END

#HEGES - 2017-05-08 - X3-36056 - Start
nolign = 0
For [CUCA]CUCA0 Where [F:CUCA]CPY = [M:CPYUKI]CPY
    [M:CPYUKI]CARREG(nolign) = [F:CUCA]CARREG
    [M:CPYUKI]CARMAK(nolign) = [F:CUCA]CARMAK
    [M:CPYUKI]CARMOD(nolign) = [F:CUCA]CARMOD
    [M:CPYUKI]FUETYP(nolign) = [F:CUCA]FUETYP
    [M:CPYUKI]EMISSI(nolign) = [F:CUCA]EMISSI
    [M:CPYUKI]LISPRI(nolign) = [F:CUCA]LISPRI
    [M:CPYUKI]LISPRI(nolign) = [F:CUCA]LISPRI
#MASHI - 2017-06-09 - JIRA X3-44323 - START
#    [M:CPYUKI]CASEQU(nolign) = [F:CUCA]CASEQU
    [M:CPYUKI]DATREG(nolign) = [F:CUCA]DATREG
#    [M:CPYUKI]DATAVA(nolign) = [F:CUCA]DATAVA
#    [M:CPYUKI]FUEPRO(nolign) = [F:CUCA]FUEPRO
#    [M:CPYUKI]PVTPRO(nolign) = [F:CUCA]PVTPRO
#MASHI - 2017-06-09 - JIRA X3-44323 - END
nolign+=1
Next

Assign "[M:CPYUKI]NBCAR" With nolign
#HEGES - 2017-05-08 - X3-36056 - End
Affzo [M:CPYUKI]

Return

$OK
Local Integer RETVAL, FLG, HRMC
#ALHAR - 2017-08-16 - X3-47333 - fields removed
##HEGES - 2017-04-21 - X3-34179 - START
#For I=0 To [M:CPYUKI]NBALL-1
#  If [M:CPYUKI]ALLDAT(I) = [0/0/0]
#    GERR=1
#    GMESSAGE = mess(00001,00104,1)
#    mkstat = 1
#    FIN = 0
#    Return
#  Else
#    If [M:CPYUKI]ALLAMT(I) < 0
#      GERR=1
#      GMESSAGE = mess(00083,00123,1)
#      mkstat = 1
#      FIN = 0
#      Return
#    Endif
#  Endif
#Next I
##HEGES - 2017-04-21 - X3-34179 - END
#ALHAR - 2017-08-16 - X3-47333 - end

Call DEBTRANS From GLOCK
[V]GOK = 1
Trbegin [F:CUAL]
Delete [CUAL] Where CPY = [M:CPYUKI]CPY
  If fstat
    GOK=0 : Call FSTA("CPYUKI") From GLOCK
  Endif
  If !GOK : Goto AB_TR1 : Return : Endif

#ALHAR - 2017-08-16 - X3-47333 - fields removed
#For I=0 To [M:CPYUKI]NBALL-1
#If [M:CPYUKI]ALLDAT(I) <> [0/0/0]
#    [CUAL]CPY = [M:CPYUKI]CPY
#    [CUAL]DAT = [M:CPYUKI]ALLDAT(I)
#    [CUAL]AMT = [M:CPYUKI]ALLAMT(I)
#    [CUAL]LINNUM = I+1
#  Write [CUAL]
#Endif
#Next I
#ALHAR - 2017-08-16 - X3-47333 - end

Commit
  If fstat
    GOK=0 : Call FSTA("CPYUKI") From GLOCK
  Endif
  If !GOK : Goto AB_TR1 : Return : Endif

  #DEHEN - 2017-03-15 - X3-15932 - START
  If [M:CPYUKI]NBBAN >= 1 Then
    FLG = func CHECK_BNKFLGS()
    If FLG = 1 Then
      GERR = 1
      GMESSAGE = "A default flag for banking details has not been selected."
      mkstat = 1
      FIN = 0
      Return
    Endif

    HRMC = func CHECK_HRMCFLG()
    If HRMC = 1 Then
      [M:CPYUKI]HMRC = 2
      GERR = 1
      GMESSAGE = "Default HMRC flag for banking details has not been selected."
      mkstat = 1
      FIN = 0
      Return
    Endif

    RETVAL = func CHECK_BANKCODES()
    If RETVAL = 1 Then
      GERR=1
      GMESSAGE = "A sort code, IBAN code or BIC code is required"
      mkstat = 1
      FIN = 0
      Return
    Endif
  Endif
  #DEHEN - 2017-03-15 - X3-15932 - END

  Trbegin [F:CPYUKI]
  Read [F:CPYUKI]CPYUKI0 = [M:CPY0]CPY
  If fstat
    [F:CPYUKI]    = [M:CPYUKI]
    [F:CPYUKI]CPY = [M:CPY0]CPY
    Write [F:CPYUKI]
    Commit
  Else
    [F:CPYUKI] = [M:CPYUKI]
    Rewrite [F:CPYUKI]
    Commit
  Endif
  If fstat
    GOK=0 : Call FSTA("CPYUKI") From GLOCK
  Endif

  If !GOK : Goto AB_TR1 : Return : Endif

#HEGES - 2017-05-08 - X3-36056 - Start
Call DEBTRANS From GLOCK
[V]GOK = 1
Trbegin [F:CUCA]
Delete [CUCA] Where CPY = [M:CPYUKI]CPY
  If fstat
    GOK=0 : Call FSTA("CPYUKI") From GLOCK
  Endif
  If !GOK : Goto AB_TR1 : Return : Endif
For I=0 To [M:CPYUKI]NBCAR-1
  [CUCA]CPY = [M:CPYUKI]CPY
  If [M:CPYUKI]CARREG(I) <> ''
    [CUCA]CARREG = [M:CPYUKI]CARREG(I)
    [CUCA]CARMAK = [M:CPYUKI]CARMAK(I)
    [CUCA]CARMOD = [M:CPYUKI]CARMOD(I)
    [CUCA]FUETYP = [M:CPYUKI]FUETYP(I)
    [CUCA]EMISSI = [M:CPYUKI]EMISSI(I)
    [CUCA]LISPRI = [M:CPYUKI]LISPRI(I)
#MASHI - 2017-06-09 - JIRA X3-44323 - START
#    [CUCA]CASEQU = [M:CPYUKI]CASEQU(I)
    [CUCA]DATREG = [M:CPYUKI]DATREG(I)
#    [CUCA]DATAVA = [M:CPYUKI]DATAVA(I)
#    [CUCA]FUEPRO = [M:CPYUKI]FUEPRO(I)
#    [CUCA]PVTPRO = [M:CPYUKI]PVTPRO(I)
#MASHI - 2017-06-09 - JIRA X3-44323 - END
    Write [CUCA]
  Endif
Next I
Commit
  If fstat
    GOK=0 : Call FSTA("CPYUKI") From GLOCK
  Endif
  If !GOK : Goto AB_TR1 : Return : Endif
#HEGES - 2017-05-08 - X3-36056 - End
Return

$AB_TR1
  Rollback
  Call ERREUR(mess (17,107,1)) From GESECRAN :#Rollback suite à une erreur dans la transaction

Return

$SEL_TABLE
Case TABLE
  When "SELCPYAD" : Gosub SEL_BPA
    #OBJET = "CPYAD"
    #CRITERE = 'BPANUM=[M:CPYUKI]CPY'

  Endcase

Return

#DEHEN - 2017-02-17 - X3-13063 - START

Funprog CHECK_BANKCODES()
nolign = 0
Local Integer I,ERR : I = 0
For I=1 To [M:CPYUKI]NBBAN
  nolign += 1
  If [M:CPYUKI]SRTCOD(nolign-1) = "" & [M:CPYUKI]IBAN(nolign-1) = "" & [M:CPYUKI]BIC(nolign-1) = "" Then
    ERR = 1
  Endif
Next


End ERR

#DEHEN - 2017-03-28 - X3-30932 - START
Subprog CHECK_AOR(VALEUR)
  Variable Char VALEUR
  Local Integer N1, N2, N3, N4, N5, N6, N7, N8, N9, N10, N11, N12, N13, TOTAL
  Local Char NUM1(1), NUM2(1), NUM3(1)
  TOTAL = 0
  REMAIN = 0
  #Breakdown of TAXDTT number
  NUM1 = left$(num$([M:CPYUKI]TAXDTT),1)
  NUM2 = right$(left$(num$([M:CPYUKI]TAXDTT),2),2)
  NUM3 = right$(num$([M:CPYUKI]TAXDTT),3)
  N1 = val(NUM1) : N1 = N1 * 9
  N2 = val(NUM2) : N2 = N2 * 10
  N3 = val(NUM3) : N3 = N3 * 11
  N4 = 576
  #Breakdown of reminder numbers
  N6 = val(left$(VALEUR,1))             : N6  = N6  * 8
  N7 = val(right$(left$(VALEUR,2),2))   : N7  = N7  * 7
  N8 = val(right$(left$(VALEUR,3),3))   : N8  = N8  * 6
  N9 = val(right$(left$(VALEUR,4),4))   : N9  = N9  * 5
  N10 = val(right$(left$(VALEUR,5),5))  : N10 = N10 * 4
  N11 = val(right$(left$(VALEUR,6),6))  : N11 = N11 * 3
  N12 = val(right$(left$(VALEUR,7),7))  : N12 = N12 * 2
  N13 = val(right$(left$(VALEUR,8),8))  : N13 = N13 * 1
#Infbox(num$(N13)) #TODO : Reloading of number After Field Change #DEHEN : DO NOT REMOVE
  #Total and check validation
  TOTAL = N1 + N2 + N3 + N4 + N6 + N7 + N8 + N9 + N10 + N11 + N12 + N13
  Integer REM : REM = mod(TOTAL,23)
  #Breakdown of N5 from table definition
  #toupper([M:CPYUKI]AOR2)
  Case  REM
    When 0 : [M:CPYUKI]AOR2 = "A" : N5 = 0
    When 1 : [M:CPYUKI]AOR2 = "B" : N5 = 1
    When 2 : [M:CPYUKI]AOR2 = "C" : N5 = 2
    When 3 : [M:CPYUKI]AOR2 = "D" : N5 = 3
    When 4 : [M:CPYUKI]AOR2 = "E" : N5 = 4
    When 5 : [M:CPYUKI]AOR2 = "F" : N5 = 5
    When 6 : [M:CPYUKI]AOR2 = "G" : N5 = 6
    When 7 : [M:CPYUKI]AOR2 = "H" : N5 = 7
    When 8 : [M:CPYUKI]AOR2 = "X" : N5 = 8
    When 9 : [M:CPYUKI]AOR2 = "J" : N5 = 9
    When 10 : [M:CPYUKI]AOR2 = "K" : N5 = 10
    When 11 : [M:CPYUKI]AOR2 = "L" : N5 = 11
    When 12 : [M:CPYUKI]AOR2 = "M" : N5 = 12
    When 13 : [M:CPYUKI]AOR2 = "N" : N5 = 13
    When 14 : [M:CPYUKI]AOR2 = "Y" : N5 = 14
    When 15 : [M:CPYUKI]AOR2 = "P" : N5 = 15
    When 16 : [M:CPYUKI]AOR2 = "Q" : N5 = 16
    When 17 : [M:CPYUKI]AOR2 = "R" : N5 = 17
    When 18 : [M:CPYUKI]AOR2 = "S" : N5 = 18
    When 19 : [M:CPYUKI]AOR2 = "T" : N5 = 19
    When 20 : [M:CPYUKI]AOR2 = "Z" : N5 = 20
    When 21 : [M:CPYUKI]AOR2 = "V" : N5 = 21
    When 22 : [M:CPYUKI]AOR2 = "W" : N5 = 22
  Endcase

  TOTAL = TOTAL + N5

  If N5>22 Then
    GERR=1
    GMESSAGE = "Invalid account reference number"
    mkstat=2 : End
  Endif

End
#DEHEN - 2017-03-28 - X3-30932 - END

#DEHEN - 2017-03-28 - X3-15932 : Check for Default and HRMMC flags - START
Funprog CHECK_BNKFLGS()
nolign = 0
Local Integer I,FLG : I = 0 : FLG = 1
If [M:CPYUKI]NBBAN = 1 Then
  [M:CPYUKI]DEFFLG(nolign) = 2
  FLG = 2
Else
  For I = 1 To [M:CPYUKI]NBBAN
    nolign += 1
    If [M:CPYUKI]DEFFLG(nolign-1) = 2 Then
      FLG = 2
      Break
    Endif
  Next
Endif
End FLG

Funprog CHECK_HRMCFLG()
nolign = 0
Local Integer I,FLG : I = 0 : FLG = 1
If [M:CPYUKI]NBBAN = 1 Then
  [M:CPYUKI]HMRC(nolign) = 2
  FLG = 2
Else
  For I = 1 To [M:CPYUKI]NBBAN
    nolign += 1
    If [M:CPYUKI]HMRC(nolign-1) = 2 Then
      FLG = 2
      Break
    Endif
  Next
Endif
End FLG
#DEHEN - 2017-03-28 - X3-15932 : Check for Default and HRMMC flags - END
