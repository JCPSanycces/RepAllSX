Subprog AM_TAXDTT(VALEUR)
Variable Char    VALEUR()
  [M:CPYUKI]AOR1 = num$(VALEUR)+"P"
  [M:CPYUKI]ACCOFFREF = [M:CPYUKI]AOR1+[M:CPYUKI]AOR2+[M:CPYUKI]AOR3
  Affzo [M:CPYUKI]AOR1
  Affzo [M:CPYUKI]ACCOFFREF

End

