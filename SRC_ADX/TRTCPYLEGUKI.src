Subprog AM_APPLEVALL(VALEUR)
Variable Integer VALEUR
If VALEUR <> 2
  If dim([M:CPYUKI]APPLEVAMT)>0 : Chgfmt [M:CPYUKI]APPLEVAMT With "-Nz:5.2" : Endif
Else
  If dim([M:CPYUKI]APPLEVAMT)>0 : Chgfmt [M:CPYUKI]APPLEVAMT With "Nz:5.2" : Endif
Endif
End


