#DEHEN - 2017-04-04 - X3-31054 - Once off employment allowance - START
Subprog C_CLMEMPALL(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    Local Integer YESNO : YESNO = 2
    Local Char STAXSTR(9), STAXEND(9) : STAXSTR  = "TAXSTRDAT" : STAXEND = "TAXENDDAT"
    Local Date DTAXSTR, DTAXEND
    Local Char TMP_TAXSTRDAT(12), TMP_TAXENDDAT(12)

    #Get the tax dates
    Call PARAM([M:CPYUKI]CPY, STAXSTR, TMP_TAXSTRDAT) From ADOVAL
    If TMP_TAXSTRDAT = "" Then : TMP_TAXSTRDAT = "00000000" : Endif
    DTAXSTR = gdat$(TMP_TAXSTRDAT)

    #End Date
    Call PARAM([M:CPYUKI]CPY, STAXEND, TMP_TAXENDDAT) From ADOVAL
    If TMP_TAXENDDAT = "" Then : TMP_TAXENDDAT = "00000000" : Endif
    DTAXEND = gdat$(TMP_TAXENDDAT)

    Call OUINON(mess(00030,011800,1)-num$(DTAXSTR)-"-"-num$(DTAXEND)-mess(00140,00102,1)-":"-num$(date$), YESNO) From GESECRAN
    If YESNO = 1
      GERR=1
      mkstat=2 : End
    Else
      [M:CPYUKI]EMPALLDAT = date$
      Grizo [M:CPYUKI]CLMEMPALL
      Affzo [M:CPYUKI]CLMEMPALL
      Affzo [M:CPYUKI]EMPALLDAT

    Endif
  Endif
End
#DEHEN - 2017-04-04 - X3-31054 - Once off employment allowance - End

