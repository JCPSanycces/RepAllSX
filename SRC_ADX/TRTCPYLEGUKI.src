Subprog C_CARREG(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ''
    Call UNICITE(VALEUR,[M:CPYUKI]CARREG(0..[M:CPYUKI]NBCAR-1)) From OBJDIV
  Else
    GERR=1
    GMESSAGE = mess(00083,00123,1)
    mkstat = 2
Endif
End

Subprog C_DATAVA(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] and VALEUR < [M:CPYUKI]DATREG(nolign-1) #HEGES - 2017-05-15 - X3-36910
  GERR=1
  GMESSAGE = mess(00001,00104,1)
  mkstat = 2
Endif
End


