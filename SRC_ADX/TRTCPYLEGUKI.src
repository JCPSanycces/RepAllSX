Subprog C_DEFFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  Call UNICITE(VALEUR,[M:CPYUKI]DEFFLG(0..[M:CPYUKI]NBBAN-1)) From OBJDIV
  #Affzo [M:CPYUKI]DEFFLG
Endif

End

Subprog C_HMRC(VALEUR)
