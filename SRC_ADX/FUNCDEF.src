#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du masque CFGDEF
$ACTION
Case ACTION
  When "OUVRE"       : Gosub OUVRE_DEFAUT
  When "DEBUT"       : Gosub DEBUT_DEFAUT
  When "SETBOUT"     : Gosub SETBOUT_DEFAUT
  When "APRES_MODIF" : Gosub APRES_MODIF_DEFAUT
  When "BOUTON"      : Gosub BOUTON_DEFAUT
  When "ENR"         : Gosub ENR_DEFAUT
  When "FIN"         : Gosub FIN_DEFAUT
Endcase
Return
############################################################
$OUVRE_DEFAUT
If clalev([F:ATB]) = 0 : Local File ATABLE    [ATB]  : Endif
If clalev([F:ATI]) = 0 : Local File ATABIND   [ATI]  : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:CDF]) = 0 : Local File CFGDEF    [CDF]  : Endif
If clalev([F:CQU]) = 0 : Local File CFGQST    [CQU]  : Endif
#
If clalev([F:ITS]) = 0 : Local File ITMSALES  [ITS]  : Endif
If clalev([F:BOH]) = 0 : Local File BOM       [BOH]  : Endif
If clalev([F:BOD]) = 0 : Local File BOMD      [BOD]  : Endif
If clalev([F:ITU]) = 0 : Local File ITMBPC    [ITU]  : Endif
If clalev([F:ITC]) = 0 : Local File ITMCOST   [ITC]  : Endif
If clalev([F:ITP]) = 0 : Local File ITMBPS    [ITP]  : Endif
If GMODU(8) = 2
  If clalev([F:ROH]) = 0 : Local File ROUTING   [ROH]  : Endif
  If clalev([F:ROO]) = 0 : Local File ROUOPE    [ROO]  : Endif
Endif
#
Local Integer W_TYP
Local Char    W_FIC(10)
Local Char    W_ABR(10)
Local Integer W_I
REP = ""
Return
############################################################
$SETBOUT_DEFAUT
If REP <> ""
  ETABOU(GENRE) = 1
ELSe
  ETABOU(GENRE) = 0
Endif
Return
############################################################
$APRES_MODIF_DEFAUT
REP = "M"
Return
############################################################
$DEBUT_DEFAUT
Raz [M:CDEF]
If GMODU(8) = 2
  [M:CDEF]SYMPAR = "HILNS"
Else
  [M:CDEF]SYMPAR = "HILNS"
Endif
Filter [CDF] Where RECCOD = 0
&            Order By Key CDF0      
For [CDF]
  W_TYP = [F:CDF]CODFIC
  Call CONV_FIC(W_TYP,W_FIC,W_ABR) From CFGLIB 
  Read [ATZ]CODZONE=W_FIC;[F:CDF]CODFLD
  If fstat = 0
    If [M:CDEF]NBLIG < dim([M:CDEF]CODFIC)
      [M:CDEF]NBLIG += 1
      nolign = [M:CDEF]NBLIG
      [M:CDEF] = [F:CDF]
      W_TYP = [F:CDF]CODFIC
      Call CONV_FIC(W_TYP,W_FIC,W_ABR) From CFGLIB 
      Call TEXTFIC(W_FIC,[M:CDEF]CODFLD(nolign-1),2,[M:CDEF]FLDTXT(nolign-1)) From OBJDIV 
      If [F:ATZ]CODTYP = "M"
        [M:CDEF]DEFTXT(nolign-1) = mess(val([F:CDF]DEFVAL),[F:ATZ]NOLIB,1)
      Else
        [M:CDEF]DEFTXT(nolign-1) = ""
      Endif 
      If [F:ATZ]CODTYP = "M"
        [M:CDEF]NATFLD(nolign-1) = mess(1,30,1)-":"-num$([F:ATZ]NOLIB)
      Else
        Case [F:CDF]DEFTYP
          When 1, 2, 4, 5, 6, 7, 9 : [M:CDEF]NATFLD(nolign-1) = mess(2,252,1)
          When 3                   : [M:CDEF]NATFLD(nolign-1) = mess(3,252,1)
          When Default             : [M:CDEF]NATFLD(nolign-1) = mess(1,252,1)
        Endcase
      Endif
    Else
      Break
    Endif
  Endif
Next
Filter [CDF]
Affzo [M:CDEF]
Return
############################################################
$BOUTON_DEFAUT
Case BOUT
  When "a" : Call PRTSCR("CFGDEF","CDEF","",0,0) From ATRTX3
Endcase
Return
############################################################
$ENR_DEFAUT
Trbegin [CDF]
GOK = 1
Filter [CDF]
For [CDF]
  Readlock Curr
  Case fstat
    When 1 :
      GOK = -1
      Break
    When 0 :
      Delete [CDF]
      If fstat
        GOK = 0
        Call FSTA("CDF") From GLOCK
        Break
      Endif
    When Default :
      GOK = 0
      Call FSTA("CDF") From GLOCK
      Break
  Endcase
Next
Filter [CDF]
#
If GOK = 1
  For W_I = 0 To [M:CDEF]NBLIG -1
    Raz [F:CDF]
    nolign = W_I +1
    [F:CDF] = [M:CDEF]
    [F:CDF]RECCOD = 0
    [F:CDF]EXPNUM = [C]EXPORT
    [F:CDF]CREUSR = GUSER
    [F:CDF]CREDAT = date$
    Write [CDF]
    If fstat
      GOK = 0
      Call FSTA("CDF") From GLOCK
      Break
    Endif
  Next W_I
Endif
# Fin transaction
Case GOK
  When 1  : 
    Commit
  When -1 : 
    Rollback
    GERR = 1
    GMESSAGE = mess(10,100,1)-"CFGDEF"
  When Default :
    GERR = 1
    GMESSAGE = mess(12,100,1)-"CFGDEF"
    Rollback
Endcase
Call TEMPON(mess(76,188,1)) From GESECRAN
Call GEN_WUVAR(nomap,"","") From CFGLIBA
adxmbm = adxmbm
Call TEMPOFF From GESECRAN
#
FIN = 1
Return
############################################################
$FIN_DEFAUT
Call IMPSCR From ATRTX3
Return
############################################################
# Actions ecran
############################################################
Subprog C_CODFIC(VALEUR)
Variable Integer VALEUR
End
############################################################
Subprog AS_CODFLD(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog C_CODFLD(VALEUR)
Variable Char    VALEUR()
Local Integer W_TYP : W_TYP = [M:CDEF]CODFIC(nolign-1)
Local Char    W_FIC(10) 
Local Char    W_ABR(10)
#
Call CONV_FIC(W_TYP,W_FIC,W_ABR) From CFGLIB
Filter [ATI] Where CODFIC  = W_FIC &
&                  HOMONYM = 1  
&            Order By Key CODIND
For [ATI]
  If instr(1,[F:ATI]DESCRIPT,VALEUR)
    mkstat = 2
    Break
  Endif
Next
Filter [ATI]
Read [ATZ]CODZONE=W_FIC;VALEUR
If fstat = 0
  If find([F:ATZ]CODTYP,"TEX","AXT")
    mkstat = 2
  Endif
Else
  mkstat = 2
Endif
If mkstat
  GMESSAGE = mess(W_TYP,752,1)-VALEUR+" : "+mess(3,188,1)
Else
  Local File = W_FIC [XXX]
  [M:CDEF]DEFTYP(nolign-1) = evalue("type([F:XXX]"+VALEUR+")")
  If [F:ATZ]CODTYP = "M"
    [M:CDEF]NATFLD(nolign-1) = mess(1,30,1)-":"-num$([F:ATZ]NOLIB)
  Else
    Case [M:CDEF]DEFTYP(nolign-1)
      When 1, 2, 4, 5, 6, 7, 9 : [M:CDEF]NATFLD(nolign-1) = mess(2,252,1)
      When 3                   : [M:CDEF]NATFLD(nolign-1) = mess(3,252,1)
      When Default             : [M:CDEF]NATFLD(nolign-1) = mess(1,252,1)
    Endcase
  Endif
  Affzo [M:CDEF]NATFLD(nolign-1)
Endif
End
############################################################
Subprog C_SCENUM(VALEUR)
Variable Char    VALEUR()
Local Integer W_I, W_J
W_I = nolign-1
#
For W_J = 0 To [M:CDEF]NBLIG-1
  If [M:CDEF]CODFIC(W_J) = [M:CDEF]CODFIC(W_I) &
&    [M:CDEF]CODFLD(W_J) = [M:CDEF]CODFLD(W_I) &
&    [M:CDEF]SCENUM(W_J) = VALEUR              &
&    W_J <> W_I
    GMESSAGE = mess(24,123,1)-num$(W_J+1)
    mkstat = 2
    Break
  Endif
Next W_J
End
############################################################
Subprog C_DEFVAL(VALEUR)
Variable Char    VALEUR()
Local Integer W_TYP : W_TYP = [M:CDEF]CODFIC(nolign-1)
Local Char    W_FIC(10) 
Local Char    W_ABR(10)
Local Integer W_NAT, W_RET
#
Call CONV_FIC(W_TYP,W_FIC,W_ABR) From CFGLIB
Read [ATZ]CODZONE=W_FIC;[M:CDEF]CODFLD(nolign-1)
If fstat = 0
  [M:CDEF]DEFTYP(nolign-1) = evalue("type("+W_ABR+[F:ATZ]CODZONE+")")
  [M:CDEF]DEFTXT(nolign-1) = ""
  Onerrgo C_DEFVAL_ERR
  Assign W_ABR+[F:ATZ]CODZONE With evalue(VALEUR)
  Onerrgo
  If mkstat = 0
    If [F:ATZ]CODTYP = "M"
      If val(VALEUR) < 1 | val(VALEUR) > 122 | mess(val(VALEUR),[F:ATZ]NOLIB,1) = ""
        mkstat = 2
      Else
        [M:CDEF]DEFTXT(nolign-1) =  mess(val(VALEUR),[F:ATZ]NOLIB,1)
      Endif
    Else
      If [F:ATZ]LIEN <> "" 
        Local File =[F:ATZ]LIEN [LOO]
        Call CTRFLD([F:ATZ]CODFIC,[F:ATZ]CODZONE,W_RET) From WUVAR
        Close Local File [LOO]
        If W_RET <> 0
          mkstat = 2
        Endif
      Endif
    Endif
  Endif
Else
  mkstat = 2
Endif
#
If mkstat <> 0
  GMESSAGE = mess(37,124,1)
Endif
End
############################################################
C_DEFVAL_ERR
mkstat = 2
Resume

