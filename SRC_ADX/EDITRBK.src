#<AdxTL>@(#)2.0.0.0 $Revision$
# LS 06/10/1998 
# EDITION PAR CODE POINTAGE DES ECRITURES RAPPROCHEES (RAPPROCHEMENT BANCAIRE)

Subprog IMPRIME(NBPAR,PARAMETRE)
Value Integer NBPAR
Value Char    PARAMETRE()()

Call EDITRBK
End
######################################################################
Subprog EDITRBK
Local Integer I

If dim([M:SAI1]NBLIG)<=0 or dim([M:SAI1]CHK)<=0 : # GH 15/12/99 Bug 3864
 Call ERREUR(mess(20,135,1)) From GESECRAN : # Etat non exécutable directement
 GOK=0 : [M:RPT]NBRPAR=0 : End
Endif

Local File EDITRBK [EBK]
Default Mask [M:SAI1]

Call DEBTRANS From GLOCK
Trbegin [EBK]
 Delete [EBK] Where BAN=[M]BAN
 If fstat=1 | fstat>5
  GOK=-1 : Call RSTA("EBK","") From GLOCK : Goto ROLL
 Endif
 For I=0 To [M]NBLIG-1
  If [M]CHK(I) <> "" & left$([M]CHK(I),1)<>"_"
   Raz [F:EBK]
   [F:EBK]BAN    = [M]BAN
   [F:EBK]CHK    = [M]CHK(I)
   [F:EBK]NUMLIN = I+1
   [F:EBK]ACCDAT = [M]ACCDAT(I)
   [F:EBK]SNS    = [M]SNS(I)
   [F:EBK]AMTCUR = [M]AMTBNQ(I)
   [F:EBK]CUR    = [M]CUR
   [F:EBK]DES    = [M]DES(I)
   [F:EBK]CIB    = [M]BANCIB(I)
   If [M]ACCNUM(I) = 0    : # Ecriture de relevé bancaire
    [F:EBK]RBK    = "BANQUE"
    [F:EBK]REF    = [M]REFB(I)
    [F:EBK]ENTNUM = [M]REFC(I)
   Else
    [F:EBK]RBK    = "COMPTE"
    [F:EBK]REF    = [M]REFC(I)
    [F:EBK]ENTNUM = [M]REFB(I)
   Endif
   Write [EBK]
   If fstat
    GOK = 0 : Call FSTA("EBK") From GLOCK : Break
   Endif
  Endif
 Next I
 If GOK = 0 : Goto ROLL : Endif
Commit
End

$ROLL
Rollback
End
