#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# ACTION PJMEVEN
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "OK"           : Gosub OK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If dim(GZINSPJM) <= 0 Then
    GMESSAGE = mess(186,123,1)
    FIN = 0
  Endif
  # -----------------------------
  NAVIG = GACTION
  # -----------------------------
Return

##########################################################################################################
$DEBUT
Local Char SCONTEXT(250)  # Calling context
Local Char SKEYCALL(250)  # Calling key
Local Integer ILINE       # Line for budget/task
Local Integer ILINEOPE    # Line for operation
Local Integer IOPENUM
Local Integer IOPESPLNUM

  # -----------------------------
  SCONTEXT = PARAM(1)
  SKEYCALL = PARAM(2)
  If SCONTEXT = "PJMOPE" Then
    IOPENUM = val(PARAM(3))
    IOPESPLNUM = val(PARAM(4))
  Endif
  # -----------------------------
  Case SCONTEXT
    When "OPPORPJM"
      Gosub DEBUT_OPPORPJM
    When "PJMBUD"
      Gosub DEBUT_PJMBUD
    When "PJMTAS"
      Gosub DEBUT_PJMTAS
    When "PJMOPE"
      Gosub DEBUT_PJMOPE
    When Default
      GMESSAGE = mess(186,123,1)
      GERR = 1
      FIN = 1
      Return
  Endcase
Return

##########################################################################################################
$DEBUT_OPPORPJM
  # -----------------------------
  [M:PEVE]DATEVEN = date$
  [M:PEVE]EVENEMENT = 1
  [M:PEVE]COMMEVEN = GZINSPJM.PJM(1).OPPCOMTEX
  # -----------------------------
  Affzo [M:PEVE]1-99
Return

##########################################################################################################
$DEBUT_PJMBUD
  ILINE = fmet GZINSPJM.PJM(1).BUD_GET_INDEX(SKEYCALL)
  If ILINE < 1 Then
    GMESSAGE = func AFNC.MES1(mess(239,2260,1), SKEYCALL)
    GERR = 1
    FIN = 1
    Return
  Endif
  # -----------------------------
  [M:PEVB]DATEVEN = date$
  [M:PEVB]EVENEMENT = 1
  [M:PEVB]COMMEVEN = GZINSPJM.PJM(1).BUD(ILINE).PBUCOMTEX
  # -----------------------------
  Affzo [M:PEVB]1-99
Return

##########################################################################################################
$DEBUT_PJMTAS
  ILINE = fmet GZINSPJM.PJM(1).TAS_GET_INDEX(SKEYCALL)
  If ILINE < 1 Then
    GMESSAGE = func AFNC.MES1(mess(255,2260,1), SKEYCALL)
    GERR = 1
    FIN = 1
    Return
  Endif
  # -----------------------------
  [M:PEVT]DATEVEN = date$
  [M:PEVT]EVENEMENT = 1
  [M:PEVT]COMMEVEN = GZINSPJM.PJM(1).TAS(ILINE).TASCOMTEX
  # -----------------------------
  Affzo [M:PEVT]1-99
Return

##########################################################################################################
$DEBUT_PJMOPE
  ILINE = fmet GZINSPJM.PJM(1).TAS_GET_INDEX(SKEYCALL)
  If ILINE < 1 Then
    GMESSAGE = func AFNC.MES1(mess(255,2260,1), SKEYCALL)
    GERR = 1
    FIN = 1
    Return
  Endif
  ILINEOPE = fmet GZINSPJM.PJM(1).TAS(ILINE).RTKO_GET_INDEX(IOPENUM, IOPESPLNUM)
  If ILINEOPE < 1 Then
    GMESSAGE = func AFNC.MES2(mess(247,2260,1), num$(IOPENUM), num$(IOPESPLNUM))
    GERR = 1
    FIN = 1
    Return
  Endif
  # -----------------------------
  [M:PEVO]DATEVEN = date$
  [M:PEVO]EVENEMENT = 1
  [M:PEVO]COMMEVEN = GZINSPJM.PJM(1).TAS(ILINE).RTKO(ILINEOPE).OPECOMTEX
  # -----------------------------
  Affzo [M:PEVO]1-99
Return

##########################################################################################################
$OK
  Case SCONTEXT
    When "OPPORPJM"
      Gosub OK_OPPORPJM
    When "PJMBUD"
      Gosub OK_PJMBUD
    When "PJMTAS"
      Gosub OK_PJMTAS
    When "PJMOPE"
      Gosub OK_PJMOPE
  Endcase
Return

##########################################################################################################
$OK_OPPORPJM
Local Instance TECOPPACT Using C_TECOPPACT
Local Integer IRET

  # -----------------------------
  # Issue X3-101833 - 2018-08-01 by FGR : BEGIN
  If [M:PEVE]EVENEMENT = 3 Then
    If func CHECK_FRCDLTALLFLG(AVOID.ACHAR, AVOID.ACHAR) = [V]CST_ANO Then
      Return
    Endif
  Endif
  # Issue X3-101833 - 2018-08-01 by FGR : END
  # -----------------------------
  TECOPPACT = NewInstance C_TECOPPACT AllocGroup null
  #
  TECOPPACT.COMTEX = [M:PEVE]COMMEVEN
  TECOPPACT.EVTDAT = [M:PEVE]DATEVEN
  # -----------------------------
  Case [M:PEVE]EVENEMENT
    When 1
      # Launch
      IRET = fmet GZINSPJM.PJM_PROJECT_LAUNCH(SKEYCALL, TECOPPACT)
    When 2
      # Delivery
      IRET = fmet GZINSPJM.PJM_PROJECT_DELIVERY(SKEYCALL, TECOPPACT)
    When 3
      # Solde
      IRET = fmet GZINSPJM.PJM_PROJECT_CLOSING(SKEYCALL, TECOPPACT)
    When 4
      # Suspension
      IRET = fmet GZINSPJM.PJM_PROJECT_SUSPENSION(SKEYCALL, TECOPPACT)
    When 5
      # Reactivate
      IRET = fmet GZINSPJM.PJM_PROJECT_REACTIVATE(SKEYCALL, TECOPPACT)
  Endcase
  # -----------------------------
  If TECOPPACT.LOGFILNAM <> AVOID.ACHAR Then
    GTRACE = TECOPPACT.LOGFILNAM
    Call LEC_TRACE From LECFIC
  Endif
  # -----------------------------
  # In all cases, reload the project : if success : it have change. If failed the record in memory is corrupted
  Gosub RELIT_GZINSPJM From SUBPJMA
  # -----------------------------
  If TECOPPACT <> null Then
    FreeGroup TECOPPACT
  Endif
  # -----------------------------
Return

##########################################################################################################
$OK_PJMBUD
Local Instance TECOPPACT Using C_TECOPPACT
Local Integer IRET

  # -----------------------------
  # Issue X3-101833 - 2018-08-01 by FGR : BEGIN
  If [M:PEVB]EVENEMENT = 2 Then
    If func CHECK_FRCDLTALLFLG(AVOID.ACHAR, SKEYCALL) = [V]CST_ANO Then
      Return
    Endif
  Endif
  # Issue X3-101833 - 2018-08-01 by FGR : END
  # -----------------------------
  TECOPPACT = NewInstance C_TECOPPACT AllocGroup null
  #
  TECOPPACT.COMTEX = [M:PEVB]COMMEVEN
  TECOPPACT.EVTDAT = [M:PEVB]DATEVEN
  # -----------------------------
  Case [M:PEVB]EVENEMENT
    When 1
      # Delivery
      IRET = fmet GZINSPJM.PJM_BUDGET_DELIVERY(GZINSPJM.OPPNUM, SKEYCALL, TECOPPACT)
    When 2
      # Solde
      IRET = fmet GZINSPJM.PJM_BUDGET_CLOSING(GZINSPJM.OPPNUM, SKEYCALL, TECOPPACT)
    When 3
      # Suspension
      IRET = fmet GZINSPJM.PJM_BUDGET_SUSPENSION(GZINSPJM.OPPNUM, SKEYCALL, TECOPPACT)
    When 4
      # Reactivate
      IRET = fmet GZINSPJM.PJM_BUDGET_REACTIVATE(GZINSPJM.OPPNUM, SKEYCALL, TECOPPACT)
  Endcase
  # -----------------------------
  If TECOPPACT.LOGFILNAM <> AVOID.ACHAR Then
    GTRACE = TECOPPACT.LOGFILNAM
    Call LEC_TRACE From LECFIC
  Endif
  # -----------------------------
  # In all cases, reload the project : if success : it have change. If failed the record in memory is corrupted
  Gosub RELIT_GZINSPJM From SUBPJMA
  # -----------------------------
  If TECOPPACT <> null Then
    FreeGroup TECOPPACT
  Endif
  # -----------------------------
Return

##########################################################################################################
$OK_PJMTAS
Local Instance TECOPPACT Using C_TECOPPACT
Local Integer IRET
Local Integer ILINTSK
Local Integer NI
Local Integer NANSWER

  # -----------------------------
  # Issue X3-101833 - 2018-08-01 by FGR : BEGIN
  If [M:PEVT]EVENEMENT = 3 Then
    If func CHECK_FRCDLTALLFLG(SKEYCALL, AVOID.ACHAR) = [V]CST_ANO Then
      Return
    Endif
  Endif
  # Issue X3-101833 - 2018-08-01 by FGR : END
  # -----------------------------
  TECOPPACT = NewInstance C_TECOPPACT AllocGroup null
  #
  TECOPPACT.COMTEX = [M:PEVT]COMMEVEN
  TECOPPACT.EVTDAT = [M:PEVT]DATEVEN
  # -----------------------------
  Case [M:PEVT]EVENEMENT
    When 1
      # Planed
      IRET = fmet GZINSPJM.PJM_TASK_PLANNED(GZINSPJM.OPPNUM, SKEYCALL, TECOPPACT)
    When 2
      # Launch
      IRET = fmet GZINSPJM.PJM_TASK_LAUNCH(GZINSPJM.OPPNUM, SKEYCALL, TECOPPACT)
    When 3
      # Close
      IRET = fmet GZINSPJM.PJM_TASK_CLOSING(GZINSPJM.OPPNUM, SKEYCALL, TECOPPACT)
    When 4
      # Suspension
      IRET = fmet GZINSPJM.PJM_TASK_SUSPENSION(GZINSPJM.OPPNUM, SKEYCALL, TECOPPACT)
    When 5
      # Reactivate
      IRET = fmet GZINSPJM.PJM_TASK_REACTIVATE(GZINSPJM.OPPNUM, SKEYCALL, TECOPPACT)
  Endcase
  # -----------------------------
  If TECOPPACT.LOGFILNAM <> AVOID.ACHAR Then
    GTRACE = TECOPPACT.LOGFILNAM
    Call LEC_TRACE From LECFIC
  Endif
  # -----------------------------
  # In all cases, reload the project : if success : it have change. If failed the record in memory is corrupted
  Gosub RELIT_GZINSPJM From SUBPJMA
  # -----------------------------
  If TECOPPACT <> null Then
    FreeGroup TECOPPACT
  Endif
  # -----------------------------
Return

##########################################################################################################
$OK_PJMOPE
Local Instance TECOPPACT Using C_TECOPPACT
Local Integer IRET

  # -----------------------------
  TECOPPACT = NewInstance C_TECOPPACT AllocGroup null
  #
  TECOPPACT.COMTEX = [M:PEVO]COMMEVEN
  TECOPPACT.EVTDAT = [M:PEVO]DATEVEN
  # -----------------------------
  Case [M:PEVO]EVENEMENT
    When 1
      # Close
      IRET = fmet GZINSPJM.PJM_TASK_RTKO_CLOSING(GZINSPJM.OPPNUM, SKEYCALL, IOPENUM, IOPESPLNUM, TECOPPACT)
    When 2
      # Suspension
      IRET = fmet GZINSPJM.PJM_TASK_RTKO_SUSPENSION(GZINSPJM.OPPNUM, SKEYCALL, IOPENUM, IOPESPLNUM, TECOPPACT)
    When 3
      # Reactivate
      IRET = fmet GZINSPJM.PJM_TASK_RTKO_REACTIVATE(GZINSPJM.OPPNUM, SKEYCALL, IOPENUM, IOPESPLNUM, TECOPPACT)
  Endcase
  # -----------------------------
  If TECOPPACT.LOGFILNAM <> AVOID.ACHAR Then
    GTRACE = TECOPPACT.LOGFILNAM
    Call LEC_TRACE From LECFIC
  Endif
  # -----------------------------
  # In all cases, reload the project : if success : it have change. If failed the record in memory is corrupted
  Gosub RELIT_GZINSPJM From SUBPJMA
  # -----------------------------
  If TECOPPACT <> null Then
    FreeGroup TECOPPACT
  Endif
  # -----------------------------
Return

##########################################################################################################
# [M:PEVE]/[M:PEVB]
##########################################################################################################
Subprog AM_DATEVEN(VALEUR)
Variable Date    VALEUR

  If VALEUR < date$ Then
    VALEUR = date$
    mkstat = 2
  Endif
End

##########################################################################################################
# SUBROUTINES
##########################################################################################################
Funprog CHECK_FRCDLTALLFLG(SRTASCOD, SRPBUCOD)
Value Char SRTASCOD
Value Char SRPBUCOD

Local Integer IARENDRE
Local Integer IRET
Local Integer NI
Local Integer NZ
Local Char STBPBUCOD(GLONPBU)(1..)
Local Char STBTASCOD(GLONTAC)(1..)
Local Char STBTASCOD1(GLONTAC)(1..)
Local Integer ISTKCHK

  # Issue X3-101833 - 2018-08-01 by FGR
  IARENDRE = [V]CST_AYES
  # ---------------------------
  ISTKCHK = [V]CST_AYES
  Gosub CHECK_BEGIN_MLK From PJMACTTAS
  # ---------------------------
  If SRTASCOD <> AVOID.ACHAR Then
    # Check for a task family
    IRET = fmet GZINSPJM.PJM(1).TAS_GET_FAMILY(SRTASCOD, STBTASCOD)
  Elsif SRPBUCOD <> AVOID.ACHAR Then
    # Check for tasks linked to a budget family
    IRET = fmet GZINSPJM.PJM(1).BUD_GET_FAMILY(SRPBUCOD, STBPBUCOD)
    NE = 0
    For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS)
      If GZINSPJM.PJM(1).TAS(NI) <> null and find(GZINSPJM.PJM(1).TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If find(GZINSPJM.PJM(1).TAS(NI).PBUCOD, STBPBUCOD(1..maxtab(STBPBUCOD))) <> 0 Then
          Raz STBTASCOD1
          IRET = fmet GZINSPJM.PJM(1).TAS_GET_FAMILY(GZINSPJM.PJM(1).TAS(NI).TASCOD, STBTASCOD1)
          For NZ = 1 To maxtab(STBTASCOD1)
            If STBTASCOD1(NZ) <> AVOID.ACHAR Then
              If find (STBTASCOD1(NZ), STBTASCOD(1..maxtab(STBTASCOD))) = 0 Then
                NE += 1
                STBTASCOD(NE) = STBTASCOD1(NZ)
              Endif
            Else
              Break
            Endif
          Next NZ
        Endif
      Endif
    Next NI
  Else
    # check all tasks
    NE = 0
    For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS)
      If GZINSPJM.PJM(1).TAS(NI) <> null and find(GZINSPJM.PJM(1).TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        NE += 1
        STBTASCOD(NE) = GZINSPJM.PJM(1).TAS(NI).TASCOD
      Endif
    Next NI
  Endif
  # ---------------------------
  For NZ = 1 To maxtab(STBTASCOD)
    NI = fmet GZINSPJM.PJM(1).TAS_GET_INDEX(STBTASCOD(NZ))
    If GZINSPJM.PJM(1).TAS(NI) <> null and find(GZINSPJM.PJM(1).TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      For NE = 1 To maxtab(GZINSPJM.PJM(1).TAS(NI).RITT)
        If GZINSPJM.PJM(1).TAS(NI).RITT(NE) <> null and find(GZINSPJM.PJM(1).TAS(NI).RITT(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If GZINSPJM.PJM(1).TAS(NI).RITT(NE).FRCDLTALLFLG = [V]CST_ANO Then
            Gosub CHECK_CURRENT_MLK_0 From PJMACTTAS
          Endif
          Gosub CHECK_CURRENT_MLK_1 From PJMACTTAS
        Endif
      Next NE
    Endif
  Next NZ
  # ---------------------------
  Gosub CHECK_END_MLK From PJMACTTAS
End IARENDRE

