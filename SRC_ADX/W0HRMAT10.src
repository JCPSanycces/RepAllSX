#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT10 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRVIS
mkstat = 0
zoncou = "NBRVIS"
indice = 0
status = 1
zoncou = "NBRVIS"
If varmode([M]NBRVIS,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBRVIS From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBRVIS : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRVIS" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRVIS
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRVIS = nolign
   status = 75
   Call SAI_NBRVIS(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_NBRVIS From SUBEML2
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NBRVIS" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone WMEDDAT
mkstat = 0
zoncou = "WMEDDAT"
indice = 0
If varmode([M]WMEDDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WMEDDAT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_WMEDDAT([M]WMEDDAT) From SUBEML2
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "WMEDDAT" : GZNUM = 212 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone WMEDHOU
mkstat = 0
zoncou = "WMEDHOU"
indice = 0
WCHAR = [M]WMEDHOU
If varmode([M]WMEDHOU,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WMEDHOU" : Gosub ACTION From =IMPTRT
 Endif
 If WCHAR<>[M]WMEDHOU or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_WMEDHOU([M]WMEDHOU) From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WMEDHOU" : GZNUM = 847 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone WMEDCTR
mkstat = 0
zoncou = "WMEDCTR"
indice = 0
WCHAR = [M]WMEDCTR
If varmode([M]WMEDCTR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WMEDCTR" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]WMEDCTR,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "WMEDCTR" : GZNUM = 5481 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTVCR"
  Call CONTVCR([M]WMEDCTR) From TRTDIV
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WMEDCTR" : GZNUM = 5481 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("CTR","",[M]WMEDCTR,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "WMEDCTR" : GZNUM = 5481 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]WMEDCTR or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_WMEDCTR([M]WMEDCTR) From SUBEML2
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "WMEDCTR" : GZNUM = 5481 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone WMEDTYP
mkstat = 0
zoncou = "WMEDTYP"
indice = 0
WCHAR = [M]WMEDTYP
If varmode([M]WMEDTYP,indice)=0
 SAVACT = GACTION : GACTION = "DEFHRMDT"
 Call DEFHRMDT([M]WMEDTYP,[M]WMEDLEG,[F:FCY]LEGCPY) From SUBHRMDT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]WMEDTYP : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call AS_WMEDTYP([M]WMEDTYP) From SUBEML2
  GACTION = SAVACT
  If mkstat=1 : Raz [M]WMEDTYP : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "WMEDTYP" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   If vireblc([M]WMEDTYP,2)=""
    mkstat = 1 : GMESSAGE = mess(10,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "WMEDTYP" : GZNUM = 46458 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTHRMDT"
    Call CONTHRMDT([M]WMEDTYP,[M]WMEDLEG,[F:FCY]LEGCPY) From SUBHRMDT
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "WMEDTYP" : GZNUM = 46458 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "CONTOBJN"
     Local Char    VALEUR(250)
     VALEUR = [M]WMEDTYP
     Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
     [M]WMEDTYP = VALEUR
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "WMEDTYP" : GZNUM = 46458 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      SAVACT = GACTION : GACTION = "STD"
      Call C_WMEDTYP([M]WMEDTYP) From SUBEML2
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "WMEDTYP" : GZNUM = 46458 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
      If !mkstat
       SAVACT = GACTION : GACTION = "STD"
       Call AP_WMEDTYP([M]WMEDTYP) From SUBEML2
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "WMEDTYP" : GZNUM = 46458 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
       If !mkstat
        If WCHAR<>[M]WMEDTYP or IMPMOD
         SAVACT = GACTION : GACTION = "STD"
         Call AM_WMEDTYP([M]WMEDTYP) From SUBEML2
         GACTION = SAVACT
         If mkstat : GERR = 1 : GZONE = "WMEDTYP" : GZNUM = 46458 : Endif
         Gosub AFF From GSAISIE
         If mkstat : End : Endif
        Endif
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone WMEDDCT
mkstat = 0
zoncou = "WMEDDCT"
indice = 0
WCHAR = [M]WMEDDCT
If varmode([M]WMEDDCT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WMEDDCT" : Gosub ACTION From =IMPTRT
 Endif
 If WCHAR<>[M]WMEDDCT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_WMEDDCT([M]WMEDDCT) From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WMEDDCT" : GZNUM = 46457 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone WMEDAPT
mkstat = 0
zoncou = "WMEDAPT"
indice = 0
WCHAR = [M]WMEDAPT
If varmode([M]WMEDAPT,indice)=0
 SAVACT = GACTION : GACTION = "DEFHRMDP"
 Call DEFHRMDP([M]WMEDAPT,[M]WMEDLEG,[F:FCY]LEGCPY) From SUBHRMDP
 GACTION = SAVACT
 If mkstat=1 : Raz [M]WMEDAPT : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call AS_WMEDAPT([M]WMEDAPT) From SUBEML2
  GACTION = SAVACT
  If mkstat=1 : Raz [M]WMEDAPT : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "WMEDAPT" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTHRMDP"
   Call CONTHRMDP([M]WMEDAPT,[M]WMEDLEG,[F:FCY]LEGCPY) From SUBHRMDP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "WMEDAPT" : GZNUM = 46455 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTOBJN"
    Local Char    VALEUR(250)
    VALEUR = [M]WMEDAPT
    Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
    [M]WMEDAPT = VALEUR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "WMEDAPT" : GZNUM = 46455 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call AP_WMEDAPT([M]WMEDAPT) From SUBEML2
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "WMEDAPT" : GZNUM = 46455 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]WMEDAPT or IMPMOD
       SAVACT = GACTION : GACTION = "STD"
       Call AM_WMEDAPT([M]WMEDAPT) From SUBEML2
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "WMEDAPT" : GZNUM = 46455 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone WMEDOBS
mkstat = 0
zoncou = "WMEDOBS"
indice = 0
WCHAR = [M]WMEDOBS
If varmode([M]WMEDOBS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WMEDOBS" : Gosub ACTION From =IMPTRT
 Endif
 If WCHAR<>[M]WMEDOBS or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_WMEDOBS([M]WMEDOBS) From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WMEDOBS" : GZNUM = 1775 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone MEDORG
mkstat = 0
zoncou = "MEDORG"
indice = 0
If varmode([M]MEDORG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "MEDORG" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Local Char    VALEUR(250)
 VALEUR = [M]MEDORG
 Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
 [M]MEDORG = VALEUR
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "MEDORG" : GZNUM = 35085 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTORG"
  Call CONTORG([M]MEDORG) From SUBORG
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "MEDORG" : GZNUM = 35085 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone MEDPOS
mkstat = 0
zoncou = "MEDPOS"
indice = 0
WCHAR = [M]MEDPOS
SAVACT = GACTION : GACTION = "FMTPOSPAY"
Call FMTPOSPAY(GPAYS) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]MEDPOS : Endif

## Zone MEDCTY
mkstat = 0
zoncou = "MEDCTY"
indice = 0
WCHAR = [M]MEDCTY
SAVACT = GACTION : GACTION = "FMTCTYPAY"
Call FMTCTYPAY(GPAYS) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]MEDCTY : Endif

## Zone WMEDLEG
mkstat = 0
zoncou = "WMEDLEG"
indice = 0
If varinit([M]WMEDLEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]WMEDLEG,"909","") From SUBADI
 GACTION = SAVACT
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone WADD4
mkstat = 0
zoncou = "WADD4"
indice = 0
IMPENT = [M]WADD4
If varinit([M]WADD4,indice)=0
 IMPENT = 1
Endif
If varmode([M]WADD4,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WADD4(IMPENT) From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]WADD4(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "WADD4" : Gosub ACTION From =IMPTRT
  IMPENT = [M]WADD4(indice)
 Endif
Endif
[M]WADD4 = IMPENT

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBRVIS(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRVIS
mkstat = 0
zoncou = "NBRVIS"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBRVIS From SUBEML2
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBRVIS" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone NBRVIS
mkstat = 0
zoncou = "NBRVIS"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HRMAT10"
Return

