#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe OPPORCRM
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE          From OPPORCRM_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE          From OPPORCRM_CSTD_EVENTS
        When "ACONTROL"                : Gosub ACONTROL                        From OPPORCRM_CSTD_EVENTS
        When "ADELETE_CONTROL_BEFORE"  : Gosub ADELETE_CONTROL_BEFORE          From OPPORCRM_CSTD_EVENTS
      Endcase
    When "STPSTB"
      Case [L]AEVENT
        When "ADELLINE_BEFORE"         : Gosub STPSTB_ADELLINE_BEFORE          From OPPORCRM_CSTD_EVENTS  # Issue X3-36832 - 2017-06-01 by FGR
      Endcase
    When Default
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SETERROR"                : Gosub SETERROR                            From OPPORCRM_CSTD_METHODS # Issue X3-51863 - 2017-08-07 by FGR
    When "COMPUTE_AMT"             : Gosub COMPUTE_AMT                         From OPPORCRM_CSTD_METHODS
    When "CURRENT_STEP"            : Gosub CURRENT_STEP                        From OPPORCRM_CSTD_METHODS
    When "COMPUTE_OPPSTEA2"        : Gosub COMPUTE_OPPSTEA2                    From OPPORCRM_CSTD_METHODS
    When "COMPUTE_OPPREACDA"       : Gosub COMPUTE_OPPREACDA                   From OPPORCRM_CSTD_METHODS
    When "COUNT_PRESALE_STEP"      : Gosub COUNT_PRESALE_STEP                  From OPPORCRM_CSTD_METHODS
    When "INIT_FIRST_STEP"         : Gosub INIT_FIRST_STEP                     From OPPORCRM_CSTD_METHODS
    When "INIT_PRESALE_STEP"       : Gosub INIT_PRESALE_STEP                   From OPPORCRM_CSTD_METHODS
    When "COUNT_POSTSALE_STEP"     : Gosub COUNT_POSTSALE_STEP                 From OPPORCRM_CSTD_METHODS
    When "INIT_POSTSALE_STEP"      : Gosub INIT_POSTSALE_STEP                  From OPPORCRM_CSTD_METHODS
    # STPSTA
    When "STPSTA_GET_INDEX"        : Gosub STPSTA_GET_INDEX                    From OPPORCRM_CSTD_METHODS # Issue X3-67352 - 2017-12-11 by FGR
    # STPSTB
    When "STPSTB_GET_INDEX"        : Gosub STPSTB_GET_INDEX                    From OPPORCRM_CSTD_METHODS # Issue X3-67352 - 2017-12-11 by FGR
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "OPPNBQ"                      : Gosub OPPNBQ                          From OPPORCRM_CSTD_PROPERTIES
    When "DAMAVE"                      : Gosub DAMAVE                          From OPPORCRM_CSTD_PROPERTIES
    When "DAMCUM"                      : Gosub DAMCUM                          From OPPORCRM_CSTD_PROPERTIES
    When "PBYPRJ"                      : Gosub PBYPRJ                          From OPPORCRM_CSTD_PROPERTIES
    When "OPPSUC"                      : Gosub OPPSUC                          From OPPORCRM_CSTD_PROPERTIES
  Endcase
Return

