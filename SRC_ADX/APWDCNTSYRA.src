#<AdxTL>@(#)0.0.0.0 $Revision$
#X3-99985
# Gestion du masque APWDCNTSYRA
Local Char VALEUR(GLONADD) , PARAM(250)
Call SAISIE_CHAR(VALEUR,PARAM,"APWDCNTSYRA","APWDCNTSYRA","") From GSAISIE
End

#-----------------------------------#
$ACTION
Case ACTION
 When "END"   : PARAM(1) = "1" : PARAM(2)=""
 When "OK"    : Gosub OK
 When "DEBUT" : Gosub DEBUT   #X3 106953 09/04/2018
Endcase
Return

$OK
Local Integer ASTATUS
Local Char MESSAGE(250)

  #if ASTATUS=0, PARAM(2) will contain X3USER value
  ASTATUS = func ASYRFNC.ACHECKSYRCONNECT(GACTX,[M]USER,[M]PASSE,PARAM(2),[L]MESSAGE)
  If ASTATUS>=[V]CST_AERROR
    PARAM(1)=num$(ASTATUS)
    PARAM(2)=""
    GMESSAGE = mess(233,100,1) : # Incorrect user code or password
    GERR = 1 : FIN=0
  Else
    PARAM(1)=num$(ASTATUS)
  Endif
Return

#X3 106953 09/04/2018
$DEBUT
# Clear the screen's fields upon entry
Raz [M]
Return

