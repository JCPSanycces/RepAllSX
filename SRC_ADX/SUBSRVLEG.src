#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog DISPLAY_HIDE()

If (func AFNC.ACTIV("FTRH")>0)
  If func DIVPAYE.IS_KFR()
    Chgfmt [M:SRV1]TRESRV2 With "K:6X"
  Else
    Chgfmt [M:SRV1]TRESRV2 With "-K:6X" : Raz [M:SRV1]TRESRV2
  Endif
Endif

If (func AFNC.ACTIV("FCQH")>0)
  If func DIVPAYE.IS_KFR()
    Chgfmt [M:SRV1]TRESRV With "K:8X"
  Else
    Chgfmt [M:SRV1]TRESRV With "-K:8X" : Raz [M:SRV1]TRESRV
  Endif
Endif

##########
#refresh all screens
  Affzo [M:SRV1]
##########

End

