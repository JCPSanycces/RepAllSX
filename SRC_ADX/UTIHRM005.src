#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIHRM005 - Reset UIF status         #
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER,"") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Reset UIF status on ZAF contracts") From LECFIC
    Call MAJ_UTIHRM005(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIHRM005(DOSSIER)
Value Char DOSSIER
Local Char CODE (GLONACV)
Local Integer WRITECOUNT, WRITEERROR

  Call ECR_TRACE("UTIHRM005 : Reset UIF status on ZAF contracts : "+DOSSIER,0) From GESECRAN
  # ------------------------------------
  Local File =DOSSIER+".ACTIV" [ACVHR]
  # ------------------------------------
  WRITEERROR = 0
  Read [ACVHR]CODACT = "FZAPH"
  If fstat
    Call ECR_TRACE("UTIHRM005: Process aborted as activity code FZAPH does not exist on : "+DOSSIER,1) From GESECRAN
    WRITEERROR = 1
  Else
    If [F:ACVHR]FLACT <> 2
      Call ECR_TRACE("UTIHRM005: Process aborted as activity code FZAPH is inactive on : "+DOSSIER,1) From GESECRAN
      WRITEERROR = 1
    Endif
  Endif
  If WRITEERROR = 0 Then
    # ------------------------------------
    Local File =DOSSIER+".EMPLOCTRSA" [CTRSA]
    Local File =DOSSIER+".EMPLOCTR" [HRCTR]
    Local File =DOSSIER+".FACILITY" [FCY]
    # ------------------------------------
    Link [HRCTR] With [F:FCY]FCY0=[F:HRCTR]ETRFCY,
&                     [F:CTRSA]CTRSA0~=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&                  As [LNK9]
&               Where [F:FCY]LEG = "ZAF"
    Trbegin [CTRSA]
    For [LNK9]
      If [F:CTRSA]UIFSTA = 3 or [F:CTRSA]UIFSTA = 4 Then
        [F:CTRSA]UIFSTA = 1
        Rewrite [F:CTRSA]
        If fstat Then
          WRITECOUNT = 0
          WRITEERROR = 1
        Else
          WRITECOUNT +=1
        Endif
      Endif
      If WRITEERROR = 1 Then
        Break
      Endif
    Next
    If WRITEERROR Then
      Rollback
      Call ECR_TRACE("UTIHRM005: Process aborted due to write failure to EMPLOCTRSA on : "+DOSSIER,0) From GESECRAN
    Else
      Commit
      Call ECR_TRACE("UTIHRM005: Process completed on : "+DOSSIER+" - Records affected "+num$(WRITECOUNT),0) From GESECRAN
    Endif
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","EMPLOCTRSA","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "EMPLOCTRSA") : End : Endif
  If filinfo(filpath("FIL","EMPLOCTR","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "EMPLOCTR") : End : Endif
  If filinfo(filpath("FIL","FACILITY","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "FACILITY") : End : Endif
  # -------------------------
  Call MAJ_UTIHRM005(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","EMPLOCTRSA","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "EMPLOCTRSA") : End : Endif
  If filinfo(filpath("FIL","EMPLOCTR","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "EMPLOCTR") : End : Endif
  If filinfo(filpath("FIL","FACILITY","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "FACILITY") : End : Endif
  # -------------------------
  Call MAJ_UTIHRM005(APPLI)
End

