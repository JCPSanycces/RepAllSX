#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################################################
# Définition d'un script d'appel
##########################################################################################################
##########################################################################################################
$ACTION
  #Infbox "ACTION="+ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "SETBOUT"      : Gosub SETBOUT
    When "DEBUT"        : Gosub DEBUT
    When "FINSAI"       : Gosub FINSAI
    When "END"          : Gosub FINEND
    When "BOUTON"       : Gosub BOUTON
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  #PARAM(1) : Code du script
  #PARAM(2) : CREATION ou MODIF

Global Integer GCNDCASE
Global Integer GICANNEW
Global Integer GICANSAV
Global Integer GPHX8DIRTY

  GICANNEW = 1
  GICANSAV = 0
  GPHX8DIRTY = 0
  GCNDCASE = 0
Return

##########################################################################################################
$SETBOUT
  #Bouton Nouveau
  If GICANNEW Then
    ETABOU(GSPE1) = 1
  Else
    ETABOU(GSPE1) = 0
  Endif
  #Bouton Enregistrer
  If GICANSAV or GPHX8DIRTY Then
    ETABOU(GSPE2) = 1
  Else
    ETABOU(GSPE2) = 0
  Endif
Return

##########################################################################################################
$DEBUT
Local Integer ISOK
Local Char SZQSTFOUND(GLONQSS)   # FGR 24/07/2014 : X3SUIVI101656

  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If !clalev([F:TCA]): Local File TABCOUAFF [TCA] : Endif
  #
  [M:PHX8]MUSTCONV = 0
  ISOK = 1
  SZQSTFOUND = ""
  #
  If PARAM(1) = "" Then
    If PARAM(2) = "CREATION" Then
      Gosub SETSCPNUM
    Else
      FIN = 1
      Return
    Endif
  Else
    [M:PHX8]SCPNUM = PARAM(1)
    If PARAM(2) = "CREATION" Then
      Gosub SETSCPNAME
    Endif
    Call LOADQST("", 1, SZQSTFOUND, ISOK)
  Endif
  #
  Affzo [M:PHX8]1-99
Return

##########################################################################################################
$FINEND
Local Integer IRETOUR

  If GPHX8DIRTY <> 0 Then
    IRETOUR = 1
    # Vous n'avez pas enregistré votre saisie. Confirmez-vous ?
    Call OUINON (mess(611,177,1), IRETOUR) From GESECRAN
    If IRETOUR = 1 Then
      FIN = 0
    Endif
  Endif
Return

##########################################################################################################
$FINSAI
  Raz [M:PHX8]   # Nettoie l'écran avant de partir.
  Kill GICANNEW
  Kill GICANSAV
  Kill GPHX8DIRTY
  Kill GCNDCASE
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      Gosub ONNEW
    When "B"
      Gosub ONSAVE
    When Default
  Endcase
Return

##########################################################################################################
$ONNEW
Local Integer INBQST

  INBQST = 0
  Call RAZPHX8ZO
  #Calcul un nouveau numéro de question
  [M:PHX8]STRQST = 2
  Filter [SCQ] Where [F:SCQ]SCPNUM=[M:PHX8]SCPNUM
  INBQST = 0
  For [SCQ]
    INBQST += 1
    # Recherche s'il existe déjà une question de départ
    If [F:SCQ]STRQST = 2 Then
      [M:PHX8]STRQST = 1
    Endif
  Next
  Filter [SCQ]
  #
  [M:PHX8]QSTNUM = num$(INBQST+1)
  #
  #Affecte les informations de stockage par défaut.
  [M:PHX8]ASWTAB = 1
  [M:PHX8]ASWKEY = "CLLCMP"
  #
  Affzo [M:PHX8]1-99
  #
  GICANNEW = 0
  GICANSAV = 1
Return

##########################################################################################################
$ONSAVE
Local Integer NI
Local Integer NE
Local Char SZTOASSIGN(GLONDCO)

  If [M:PHX8]QSTNUM = "" or [M:PHX8]QST = "" Then
    Return
  Endif
  #
  Call DEBTRANS From GLOCK
  Trbegin [SCP], [SCP], [SQC]
  Readlock [SCQ]SCQ0=[M:PHX8]SCPNUM;[M:PHX8]QSTNUM
  If fstat Then
    # Il s'agit d'une nouvelle questions
    [F:SCQ]SCPNUM = [M:PHX8]SCPNUM
    [F:SCQ]QSTNUM = [M:PHX8]QSTNUM
    [F:SCQ]STRQST = [M:PHX8]STRQST
    [F:SCQ]QST    = [M:PHX8]QST
    [F:SCQ]QSTTYP = [M:PHX8]QSTTYP
    [F:SCQ]ASWTAB = [M:PHX8]ASWTAB
    [F:SCQ]ASWFIE = [M:PHX8]ASWFIE
    [F:SCQ]ASWKEY = [M:PHX8]ASWKEY
    Write [SCQ]
    If fstat Then
      GMESSAGE = mess(100,141,1) - "(a)"
      GERR = 1
      Rollback
      Return
    Endif
  Else
    # Il s'agit d'une modification
    # 1°) D'abord on détruit les conditions déjà enregistrées
    Delete [SQC] Where [F:SQC]SCPNUM=[M:PHX8]SCPNUM and [F:SQC]QSTNUM=[M:PHX8]QSTNUM
    If fstat Then
      GMESSAGE = mess(369,196,1) - "(b)"  #Erreur lors de l'enregistrement des conditions.
      GERR = 1
      Rollback
      Return
    Endif
    # 2°) Ensuite on réécrit la question
    [F:SCQ]SCPNUM = [M:PHX8]SCPNUM
    [F:SCQ]QSTNUM = [M:PHX8]QSTNUM
    [F:SCQ]STRQST = [M:PHX8]STRQST
    [F:SCQ]QST    = [M:PHX8]QST
    [F:SCQ]QSTTYP = [M:PHX8]QSTTYP
    [F:SCQ]ASWTAB = [M:PHX8]ASWTAB
    [F:SCQ]ASWFIE = [M:PHX8]ASWFIE
    [F:SCQ]ASWKEY = [M:PHX8]ASWKEY
    Rewrite [SCQ]
    If fstat Then
      GMESSAGE = mess(101,141,1) - "(c)"
      GERR = 1
      Unlock [SCQ]
      Rollback
      Return
    Endif
  Endif
  # FGR 17/08/2009 : X3SUIVI57123 il manquait -1 à [M:PHX8]NBCND
  For NI = 0 To [M:PHX8]NBCND-1
    If [M:PHX8]QSTTYP = 1 Then
      # L'alpha est traité différemment
      #For NE = 0 To dim([M:PHX8]CND)-1
      For NE = 0 To dim([M:PHX8]ALHCND)-1  # FGR 16/06/2009 : X23SUIVI55329
        SZTOASSIGN = evalue("[M:PHX8]ALHCND"+num$(NE)+"("+num$(NI)+")")
        If SZTOASSIGN <> "" or [M:PHX8]CND(NI) = 2 Then
          # FGR 17/08/2009 : X3SUIVI57116 : [M:PHX8]CND(NI)=2-Quitter. Seul cas où il n'y a rien de saisi en condition
          Raz [F:SQC]
          [F:SQC]SCPNUM    = [M:PHX8]SCPNUM
          [F:SQC]QSTNUM    = [M:PHX8]QSTNUM
          [F:SQC]CND       = [M:PHX8]CND(NI)
          [F:SQC]CNDNUM    = num$(NI)
          [F:SQC]NEXQST    = [M:PHX8]NEXQST(NI)
          [F:SQC]ALHCND    = SZTOASSIGN
          Write [SQC]
          If fstat Then
            GMESSAGE = mess(369,196,1) - "(d)"  #Erreur lors de l'enregistrement des conditions.
            GERR = 1
            Rollback
            Return
          Endif
        Endif
      Next NE
    Else
      Raz [F:SQC]
      [F:SQC]SCPNUM        = [M:PHX8]SCPNUM
      [F:SQC]QSTNUM        = [M:PHX8]QSTNUM
      [F:SQC]CND           = [M:PHX8]CND(NI)
      [F:SQC]CNDNUM        = num$(NI)
      [F:SQC]NEXQST        = [M:PHX8]NEXQST(NI)
      [F:SQC]ALHCND        = ""
      [F:SQC]NUMCNDMIN     = [M:PHX8]NUMCNDMIN(NI)
      [F:SQC]NUMCNDMAX     = [M:PHX8]NUMCNDMAX(NI)
      [F:SQC]DATCNDMIN     = [M:PHX8]DATCNDMIN(NI)
      [F:SQC]DATCNDMAX     = [M:PHX8]DATCNDMAX(NI)
      Write [SQC]
      If fstat Then
        GMESSAGE = mess(369,196,1) - "(e)"  #Erreur lors de l'enregistrement des conditions.
        GERR = 1
        Rollback
        Return
      Endif
    Endif
  Next NI
  #
  #Supprime les éventuelles autres question de départ déjà définies
  If [M:PHX8]STRQST = 2 Then
    Filter [SCQ] Where [F:SCQ]SCPNUM=[M:PHX8]SCPNUM and [F:SCQ]QSTNUM<>[M:PHX8]QSTNUM and [F:SCQ]STRQST=2
    For [SCQ]
      [F:SCQ]STRQST = 1
      Rewrite [SCQ]
      If fstat Then
        GMESSAGE = mess(101,141,1) - "(f)"
        GERR = 1
        Filter [SCQ]
        Rollback
        # FGR 08/02/2010 : X3SUIVI60986
        #Return
        Break
      Endif
    Next
    Filter [SCQ]
    If GERR Then
      # FGR 08/02/2010 : X3SUIVI60986
      Return
    Endif
  Endif
  #
  Commit
  GISCPDEF = 1
  GICANNEW = 1
  GICANSAV = 0
  GPHX8DIRTY = 0
  GIRELITOBJ = 1
Return

##########################################################################################################
Subprog RAZPHX8ZO

  Effzo [M:PHX8]10
  Effzo [M:PHX8]15
  [M:PHX8]NBCND = 0
  Effzo [M:PHX8]45
End

##########################################################################################################
Subprog LOAD_ADI_M
Local Integer IADISEPARATOR

  IADISEPARATOR = 0
  If [M:PHX8]ASWFIE = "" or [M:PHX8]ASWTAB = 0 Then
    [M:PHX8]CNDTYP = ""
    [M:PHX8]ICNDTYP = 0
  Else
    If [M:PHX8]ASWTAB = 1 Then
      Read [ATZ]CODZONE="BPARTNER";[M:PHX8]ASWFIE
    Elsif [M:PHX8]ASWTAB = 2 Then
      Read [ATZ]CODZONE="BPCUSTOMER";[M:PHX8]ASWFIE
    Elsif [M:PHX8]ASWTAB = 3 Then
      Read [ATZ]CODZONE="CONTACTCRM";[M:PHX8]ASWFIE
    Endif
    If fstat Then
      [M:PHX8]CNDTYP = ""
      [M:PHX8]ICNDTYP = 0
    Else
      If [F:ATZ]CODTYP = "ADI" Then
        IADISEPARATOR = instr(1, [F:ATZ]EXPLIEN, ";")
        IADISEPARATOR -= 1
        [M:PHX8]CNDTYP = "ADI"
        [M:PHX8]ICNDTYP = val(left$([F:ATZ]EXPLIEN, IADISEPARATOR))
      Elsif [F:ATZ]CODTYP = "M" Then
        If [F:ATZ]NOLIB = 1 Then
          [M:PHX8]CNDTYP = ""
          [M:PHX8]ICNDTYP = 0
        Else
          [M:PHX8]CNDTYP = "M"
          [M:PHX8]ICNDTYP = [F:ATZ]NOLIB
        Endif
      Endif
    Endif
  Endif
End

######################################################################################
Subprog COPY_TB_ALHCND
Local Char SZTOASSIGN(50)
Local Char SZVALEUR(type([M:PHX8]ALHCND)-10)   # FGR 24/07/2014 : X3SUIVI101656
Local Integer NI
Local Integer NE

  # FGR 16/06/2009 : X23SUIVI55329 (début)
  For NI = 0 To dim([M:PHX8]ALHCND)-1
    SZTOASSIGN = "[M:PHX8]ALHCND"+num$(NI)+"("+num$([M:PHX8]NOLCND)+")"
    Assign SZTOASSIGN With ""
  Next NI
  #
  NE = 0
  For NI = 0 To dim([M:PHX8]ALHCND)-1
    SZVALEUR = [M:PHX8]ALHCND(NI)
    If SZVALEUR <> "" Then
      SZTOASSIGN = "[M:PHX8]ALHCND"+num$(NE)+"("+num$([M:PHX8]NOLCND)+")"
      Assign SZTOASSIGN With SZVALEUR
      NE += 1
    Endif
  Next NI
  # FGR 16/06/2009 : X23SUIVI55329 (fin)
End

##########################################################################################################
Subprog LOADQST(SZNUMQST, IFIRST, SZQSTFOUND, IOK)
Value Char SZNUMQST
Value Integer IFIRST
Variable Char SZQSTFOUND
Variable Integer IOK

Local Integer IM
Local Integer IALHNUM
#Local Char SZPRECND                         # FGR 24/07/2014 : X3SUIVI101656
Local Char SZNUMQSTLOCAL(type(SZNUMQST)-10)  # FGR 24/07/2014 : X3SUIVI101656
Local Char SZTOASSIGN(50)
Local Integer INBCND
Local Integer INBCNA

  Call RAZPHX8ZO
  IM = 0
  IALHNUM = 0
  #SZPRECND = ""      # FGR 24/07/2014 : X3SUIVI101656
  SZNUMQSTLOCAL = ""
  #Recherche la question de départ
  If IFIRST = 1 Then
    Filter [SCQ] Where [F:SCQ]SCPNUM = [M:PHX8]SCPNUM and [F:SCQ]STRQST = 2 Order By [F:SCQ]QSTNUM Asc
    For [SCQ]
      SZNUMQSTLOCAL = [F:SCQ]QSTNUM
      Break
    Next
    Filter [SCQ]
  Else
    SZNUMQSTLOCAL = SZNUMQST
  Endif
  Read [SCQ]SCQ0=[M:PHX8]SCPNUM;SZNUMQSTLOCAL
  If fstat Then
    IOK = 0
    End
  Endif
  SZQSTFOUND     = [F:SCQ]QSTNUM
  [M:PHX8]QSTNUM = [F:SCQ]QSTNUM
  [M:PHX8]STRQST = [F:SCQ]STRQST
  [M:PHX8]QST    = [F:SCQ]QST
  [M:PHX8]QSTTYP = [F:SCQ]QSTTYP
  [M:PHX8]ASWTAB = [F:SCQ]ASWTAB
  [M:PHX8]ASWFIE = [F:SCQ]ASWFIE
  [M:PHX8]ASWKEY = [F:SCQ]ASWKEY
  Affzo [M:PHX8]10
  Affzo [M:PHX8]45
  Call LOAD_ADI_M
  #
  INBCND = 0
  INBCNA = 0
  SZSVCNDNUM = ""
  Filter [SQC] Where SCPNUM=[M:PHX8]SCPNUM and QSTNUM=[M:PHX8]QSTNUM Order By CNDNUM
  For [SQC]
    If [M:PHX8]QSTTYP = 1 Then
      # L'alpha est traité différemment
      If SZSVCNDNUM <> [F:SQC]CNDNUM Then
        If SZSVCNDNUM <> "" Then
          # pour ne pas le faire la première fois
          INBCNA = 0
          INBCND += 1
        Endif
        SZSVCNDNUM = [F:SQC]CNDNUM
        #
        [M:PHX8]CND(INBCND) = [F:SQC]CND
        [M:PHX8]NEXQST(INBCND) = [F:SQC]NEXQST
      Endif
      #
      SZTOASSIGN = "[M:PHX8]ALHCND"+num$(INBCNA)+"("+num$(INBCND)+")"
      Assign SZTOASSIGN With [F:SQC]ALHCND
      INBCNA += 1
    Else
      [M:PHX8]CND(INBCND)       = [F:SQC]CND
      [M:PHX8]NEXQST(INBCND)    = [F:SQC]NEXQST
      [M:PHX8]NUMCNDMIN(INBCND) = [F:SQC]NUMCNDMIN
      [M:PHX8]NUMCNDMAX(INBCND) = [F:SQC]NUMCNDMAX
      [M:PHX8]DATCNDMIN(INBCND) = [F:SQC]DATCNDMIN
      [M:PHX8]DATCNDMAX(INBCND) = [F:SQC]DATCNDMAX
      INBCND += 1
    Endif
  Next
  Filter [SQC]
  #
  If [M:PHX8]QSTTYP = 1 Then
    # Pour l'alpha il faut le faire ici une dernière fois.
    # on n'a pas incrémenté pour la dernière condition
    INBCND += 1
  Endif
  [M:PHX8]NBCND = INBCND
  Affzo [M:PHX8]15
  #
  Call AFFICHE_CONDITION(0)
  #
  IOK = 1
End

##########################################################################################################
Subprog AFFICHE_CONDITION(NUMLIG)
Value Integer NUMLIG

Local Integer INBCNA
Local Char SZTOASSIGN(100)

  [M:PHX8]NOLCND = NUMLIG
  #
  Effzo [M:PHX8]20
  Effzo [M:PHX8]25
  Effzo [M:PHX8]30
  Effzo [M:PHX8]35
  Effzo [M:PHX8]40
  #
  If [M:PHX8]QSTTYP = 1 Then
    # Alphabétique
    # ------------
    For INBCNA = 0 To 9
      SZTOASSIGN = "[M:PHX8]ALHCND"+num$(INBCNA)+"("+num$(NUMLIG)+")"
      If evalue(SZTOASSIGN) <> "" Then
        [M:PHX8]ALHCND(INBCNA) = evalue(SZTOASSIGN)
      Else
        Break
      Endif
    Next INBCNA
    [M:PHX8]NBCNA = INBCNA
    Affzo [M:PHX8]20
  Elsif [M:PHX8]QSTTYP = 2 Then
    # Numérique
    # ---------
    If [M:PHX8]CND(NUMLIG) = 6 or [M:PHX8]CND(NUMLIG) = 7 or [M:PHX8]CND(NUMLIG) = 8 or [M:PHX8]CND(NUMLIG) = 9 Then
      # 6:Supérieur à // 7:Sup. ou égal à // 8:Inférieur à // 9:Inf. ou égal à
      [M:PHX8]NUMCND5 = [M:PHX8]NUMCNDMIN(NUMLIG)
      Affzo [M:PHX8]25
    Elsif [M:PHX8]CND(NUMLIG) = 10 Then
      # 10:Compris entre
      [M:PHX8]NUMCNDMIN6 = [M:PHX8]NUMCNDMIN(NUMLIG)
      [M:PHX8]NUMCNDMAX6 = [M:PHX8]NUMCNDMAX(NUMLIG)
      Affzo [M:PHX8]30
    Endif
  Elsif [M:PHX8]QSTTYP = 3 Then
    # Date
    # ----
    If [M:PHX8]CND(NUMLIG) = 13 or [M:PHX8]CND(NUMLIG) = 14 Then
      # 13:Avant le // 14:Après le
      [M:PHX8]DATCND7 = [M:PHX8]DATCNDMIN(NUMLIG)
      Affzo [M:PHX8]35
    Elsif [M:PHX8]CND(NUMLIG) = 10 Then
      # 10:Compris entre
      [M:PHX8]DATCNDMIN8 = [M:PHX8]DATCNDMIN(NUMLIG)
      [M:PHX8]DATCNDMAX8 = [M:PHX8]DATCNDMAX(NUMLIG)
      Affzo [M:PHX8]40
    Endif
  Elsif [M:PHX8]QSTTYP = 4 Then
    # Boolean
    # -------
    # rien a faire de spécial
  Endif
  Call ACCES_CONDITIONS(NUMLIG)
End

##########################################################################################################
Subprog ACCES_CONDITIONS(NUMLIG)
Value Integer NUMLIG

  # FLORENT ICI : tenir compte aussi de la valeur de CND
  # comme dans IB_NBCND de SUBPHX6
  Diszo [M:PHX8]20 # Conditions alphabétiques
  Diszo [M:PHX8]25 # Numérique
  Diszo [M:PHX8]30 # Intervalle numérique
  Diszo [M:PHX8]35 # Date
  Diszo [M:PHX8]40 # Intervalle date
  #
  If [M:PHX8]QSTTYP = 1 Then
    # Alphabétique
    Actzo [M:PHX8]20
  Elsif [M:PHX8]QSTTYP = 2 Then
    # Numérique
    If [M:PHX8]CND(NUMLIG) = 6 or [M:PHX8]CND(NUMLIG) = 7 or [M:PHX8]CND(NUMLIG) = 8 or [M:PHX8]CND(NUMLIG) = 9 Then
      # 6:Supérieur à // 7:Sup. ou égal à // 8:Inférieur à // 9:Inf. ou égal à
      Actzo [M:PHX8]25
    Elsif [M:PHX8]CND(NUMLIG) = 10 Then
      # 10:Compris entre
      Actzo [M:PHX8]30
    Endif
  Elsif [M:PHX8]QSTTYP = 3 Then
    # Date
    If [M:PHX8]CND(NUMLIG) = 13 or [M:PHX8]CND(NUMLIG) = 14 Then
      # 13:Avant le // 14:Après le
      Actzo [M:PHX8]35
    Elsif [M:PHX8]CND(NUMLIG) = 10 Then
      # 10:Compris entre
      Actzo [M:PHX8]40
    Endif
  Elsif [M:PHX8]QSTTYP = 4 Then
    # Boolean
    # rien a faire de spécial
  Endif
End

##########################################################################################################
$SETSCPNAME
  If [M:PHX8]SCPNUM <> "" Then
    If [M:PHO6]SCPNAM <> "" Then
      Read [SCP]SCP0=[M:PHX8]SCPNUM
      If !fstat Then
        #Création de l'enregistrement Script
        Call DEBTRANS From GLOCK
        Trbegin [SCP]
        [F:SCP]SCPNAM = [M:PHO6]SCPNAM
        [F:SCP]SALFCY = [M:PHO6]SALFCY # FGR 03/09/2008 : X3SUIVI43507
        Rewrite [SCP]
        If fstat Then
          GMESSAGE = mess(100,141,1)
          GERR = 1
          Rollback
        Else
          Commit
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$SETSCPNUM
# Récupération du compteur Script d'appel
Local Char SZCPTNUM(GLONVCR)
Local Char SZCPT(GLONANM)
Local Integer ISTAT

  SZCPTNUM = ""
  SZCPT = ""
  ISTAT = 0
  Read [TCA]TCA0=13
  If fstat Then
    GERR = 1
    GMESSAGE = mess(64,199,1)
  Endif
  GMANCOU = [F:TCA]MANCOU(3)
  SZCPT = [F:TCA]CODNUM(3)
  Call NUMERO (SZCPT, [M:PHO6]SALFCY, date$, "", SZCPTNUM, ISTAT) From SUBANM  # FGR 03/09/2008 : X3SUIVI43507
  If ISTAT = 0 Then
    [M:PHO6]SCPNUM = SZCPTNUM
    [M:PHX8]SCPNUM = SZCPTNUM
    GSZSCRNUM = SZCPTNUM
  Else
   # problème lors de la récupération du compteur
   GMESSAGE = mess(60,199,1) - "(STAT=" + num$(ISTAT) + ")"
   GERR = 1
   FIN = 1   # FGR 24/07/2014 : X3SUIVI101656 : Si c'est en erreur on ne continue pas.
   Return    # FGR 24/07/2014 : X3SUIVI101656 : Si c'est en erreur on ne continue pas.
  Endif
  #Création de l'enregistrement Script
  Call DEBTRANS From GLOCK
  Trbegin [SCP]
  [F:SCP]SCPNUM = SZCPTNUM
  [F:SCP]SCPNAM = [M:PHO6]SCPNAM
  [F:SCP]SALFCY = [M:PHO6]SALFCY  # FGR 03/09/2008 : X3SUIVI43507
  [F:SCP]SCPFLG = 1
  [F:SCP]CREUSR = GUSER
  [F:SCP]CREDAT = date$
  Write [SCP]
  If fstat Then
    GMESSAGE = mess(100,141,1)
    GERR = 1
    Rollback
    Return
  Else
    Commit
  Endif
Return
