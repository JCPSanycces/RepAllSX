#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion objet SLA
Call OBJET ("SLA",GBIDC1,GBIDC2) From GOBJET
End
#######################################################################
# SUBSLA : Transactions de saisie des avoirs             JL  23/04/98 #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:SLT]SALTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                                                                     #
# Génération des  écrans de saisie à partir des écrans de base SIH1   #
#                                                              SIH2   #
#                                                              SIH4   #
# Nom des écrans générés : WKxyyyz                                    #
#                            x = type de la transaction (STRTYP)      #
#                                1 -    devis                         #
#                                2 -    commandes                     #
#                                3 -    commandes ouvertes            #
#                                5 -    factures / avoirs             #
#                                6 -    retours client                #
#                                7 -    retours prêt                  #
#                                                                     #
#                          yyy = no de la transaction   (STRNUM)      #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                1 et 2 devis                         #
#                                1 et 2 cde ouverte                   #
#                                1 2 3 et 4 commande                  #
#                                1 2 et 4 facture                     #
#######################################################################
# Issue X3-58942 - 20171226 by LD : Error 6: Variable Non-existent FLOPHYCODD saving changes to credit memo entry transaction

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE From SUBSLI
                      Gosub OUVRE From SUBSLX
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="SLT"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=5
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub AFFMASK    # FGR 10/04/2015 : X3SUIVI105605
                      Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE From SUBSLI
 When "SETBOUT"     : Gosub SETBOUT From SUBSLI
 When "EXEBOUT"     : Gosub EXEBOUT From SUBSLI
 When "EFFMASK"     : [M]STRTYP = 5
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE From SUBSLI
 When "LIENS"       : If dim([M:ETR2]STACOD)>0 & dim([M:ETR2]STASCR)>0 :# Particularité pour les avoirs : Statut
                        [M:ETR2]STACOD=[F:SLT]AQRCOD
                        [M:ETR2]STASCR=[F:SLT]AQRSCR
                      Endif
                      Gosub LIENS From SUBSLI
                      Gosub LIENS From SUBSLX : Gosub TRT_DIETRS From SUBDST
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN From SUBSLI
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN From SUBSLI
 When "ANNULE"      : Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="SLT"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN From SUBSLI
                      Gosub ANNULE From SUBSLX
 When "APRES_MODIF" : Gosub APRES_MODIF From SUBSLX
 When "INICRE"      : If dim([M:ETR2]STACOD)>0 & dim([M:ETR2]STASCR)>0 :# Particularité pour les avoirs : Statut
                        [F:SLT]AQRCOD=[M:ETR2]STACOD
                        [F:SLT]AQRSCR=[M:ETR2]STASCR
                        If [F:SLT]AQRSCR=0 [F:SLT]AQRSCR=1: Endif
                        If [F:SLT]AQRCOD=0 [F:SLT]AQRCOD=1: Endif
                      Endif
                      [F:SLT]STACOD=[M:SLI4]STACOD
                      Gosub INICRE From SUBSLI
                      Gosub INICRE From SUBSLX
 When "INIMOD"      : If dim([M:ETR2]STACOD)>0 & dim([M:ETR2]STASCR)>0 :# Particularité pour les avoirs : Statut
                        [F:SLT]AQRCOD=[M:ETR2]STACOD
                        [F:SLT]AQRSCR=[M:ETR2]STASCR
                        If [F:SLT]AQRSCR=0 [F:SLT]AQRSCR=1: Endif
                        If [F:SLT]AQRCOD=0 [F:SLT]AQRCOD=1: Endif
                      Endif
                      [F:SLT]STACOD=[M:SLI4]STACOD
                      Gosub INICRE From SUBSLI
                      Gosub INICRE From SUBSLX
 When "SEL_TABLE"   : Gosub SEL_TABLE  From SUBSLI : # Sélection sur code pièce auto
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When Default
Endcase
Return

$VERIF_CRE
Gosub VERIF
Return

$VERIF_MOD
Gosub VERIF
Return

$VERIF
If func AFNC.ACTIV("INVCA")>0
  # Issue 110584 - 2015-08-27 by BRBAN : Change field values to "Display"
  If [M:SLA1]INVCAN=2
    Gosub DISPLAY_INVCA
  Endif
Endif
Return

$AFFMASK
  # FGR 10/04/2015 : X3SUIVI105605
  Call EDD_FIELDS(2) From SUBSLI
Return

$DISPLAY_INVCA
[M:SLA1]INVDTACOD=2
Affzo [M:SLA1]INVDTACOD

[M:SLI2]BPCORDCOD  = 2
[M:SLI2]BPCGRUCOD  = 2
[M:SLI2]PJTCOD     = 2
[M:SLI2]CNORENCOD  = 2
[M:SLI2]VACBPRCOD  = 2
[M:SLI2]STOMVTCOD  = 2
[M:SLI2]TRSFAMCOD  = 2
[M:SLI2]BPCPYRCOD  = 2
[M:SLI2]BPAADDCOD  = 2
[M:SLI2]REPCOD     = 2
[M:SLI2]BELVCSCOD  = 2
[M:SLI2]PRITYPCOD  = 2
[M:SLI2]STOFCYCOD  = 2
[M:SLI2]EECICTCOD  = 2
[M:SLI2]CURCOD     = 2
[M:SLI2]DESCOD     = 2
[M:SLI2]BPRSACCOD  = 2
[M:SLI2]PTECOD     = 2
[M:SLI2]DEPCOD     = 2
[M:SLI2]LICPLATCOD = 2
[M:SLI2]DPEDATCOD  = 2
[M:SLI2]ETDCOD     = 2
[M:SLI2]RATCURCOD  = 2
[M:SLI2]BPRFCTCOD  = 2
[M:SLI2]DUDDATCOD  = 2
[M:SLI2]TRAPLTCOD  = 2
[M:SLI2]ARVDATCOD  = 2
[M:SLI2]ETACOD     = 2

# Issue 115340
If dim ([M:SLI2]SSTENTCOD) > 0
  [M:SLI2]SSTENTCOD = 2
  Affzo [M:SLI2]SSTENTCOD
Endif
If dim ([M:SLI2]DCLEECNUMCOD) > 0
  [M:SLI2]DCLEECNUMCOD = 2
  Affzo [M:SLI2]DCLEECNUMCOD
Endif
If dim([M:SLI2]UMRNUMCOD)>0
  [M:SLI2]UMRNUMCOD = 2
  Affzo [M:SLI2]UMRNUMCOD
Endif
If dim([M:SLI2]SVCDATCOD) > 0
  [M:SLI2]SVCDATCOD = 2
  Affzo [M:SLI2]SVCDATCOD
Endif
If dim([M:SLI2]FLD40RENCOD) > 0
  [M:SLI2]FLD40RENCOD = 2
  Affzo [M:SLI2]FLD40RENCOD
Endif
If dim([M:SLI2]FLD41RENCOD) > 0
  [M:SLI2]FLD41RENCOD = 2
  Affzo [M:SLI2]FLD41RENCOD
Endif
# End issue 115340

Affzo [M:SLI2]BPCORDCOD,BPCGRUCOD,PJTCOD,CNORENCOD,VACBPRCOD,STOMVTCOD,TRSFAMCOD
Affzo [M:SLI2]BPCPYRCOD,BPAADDCOD,REPCOD,BELVCSCOD,PRITYPCOD,STOFCYCOD
Affzo [M:SLI2]EECICTCOD,CURCOD,DESCOD,BPRSACCOD,PTECOD,DEPCOD
Affzo [M:SLI2]LICPLATCOD,DPEDATCOD,DESCOD,ETDCOD,RATCURCOD,BPRFCTCOD
Affzo [M:SLI2]DUDDATCOD,TRAPLTCOD,ARVDATCOD,ETACOD

[M:SLI3]ITMDESCOD = 2
[M:SLI3]GROPRICOD = 2
[M:SLI3]AMTLINCOD = 2
[M:SLI3]REPCODD   = 2
If dim([M:SLI3]FLOPHYCODD) > 0
  [M:SLI3]FLOPHYCODD = 2
  Affzo [M:SLI3]FLOPHYCODD
Endif
[M:SLI3]ITMDES1COD = 2
[M:SLI3]CPRPRICOD  = 2
[M:SLI3]VACITMCOD = 2
[M:SLI3]SVCDATCODD = 2
# Issue X3-58942
#Affzo [M:SLI3]GROPRICOD,AMTLINCOD,REPCODD,FLOPHYCODD
Affzo [M:SLI3]GROPRICOD,AMTLINCOD,REPCODD
# End issue X3-58942
Affzo [M:SLI3]ITMDESCOD,ITMDES1COD,CPRPRICOD,VACITMCOD,SVCDATCODD

If dim([M:SLX1]DISCRGCOD1)>0
  [M:SLX1]DISCRGCOD1 = 2
Endif
If dim([M:SLX1]DISCRGCOD2)>0
  [M:SLX1]DISCRGCOD2 = 2
Endif
If dim([M:SLX1]DISCRGCOD3)>0
  [M:SLX1]DISCRGCOD3 = 2
Endif
If dim([M:SLX1]DISCRGCOD4)>0
  [M:SLX1]DISCRGCOD4 = 2
Endif
If dim([M:SLX1]DISCRGCOD5)>0
  [M:SLX1]DISCRGCOD5 = 2
Endif
If dim([M:SLX1]DISCRGCOD6)>0
  [M:SLX1]DISCRGCOD6 = 2
Endif
If dim([M:SLX1]DISCRGCOD7)>0
  [M:SLX1]DISCRGCOD7 = 2
Endif
If dim([M:SLX1]DISCRGCOD8)>0
  [M:SLX1]DISCRGCOD8 = 2
Endif
If dim([M:SLX1]DISCRGCOD9)>0
  [M:SLX1]DISCRGCOD9 = 2
Endif

Affzo [M:SLX1]

[M:DST]HEACCECOD = 2
For I=0 To [M:DST]NBDIE-1
  [M:DST]CCECOD(I)=2
Next
Affzo [M:DST]

Return
