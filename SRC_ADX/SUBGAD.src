#<AdxTL>@(#)2.0.0.0 $Revision$
Local File GAUTACE [GAU]
Read [GAU]GAU0  = "FXDPR"
GBIDI1 = 1
Call OBJET("GAD",[F:GAU]COD,"1") From GOBJET
End

$ACTION
Case ACTION
 When "EFFMASK"           : Gosub EFFMASK
 When "OUVRE"             : Gosub OUVRE
 When "TITRE"             : Gosub TIT
 When "OUVRE_BOITE"       : Gosub OUVRE_BOITE
 When "LIENS"             : Gosub LIENS
 When "CREATION"          : Gosub CREATION
 When "MODIF"             : Gosub MODIF
 When "FILTRE"            : Gosub FILTRE
 When "FILGAUCHE"         : Gosub FILGAUCHE
 When "INICRE"            : Gosub INICRE
 When "INIMOD"            : Gosub INIMOD
 When "RAZCRE"            : Gosub RAZCRE
 When "DEFBOUT"           : Gosub DEFBOUT
 When "AFFMASK"           : Gosub AFFMASK
 When "APRES_CRE"         : Gosub VERIF
 When "APRES_MOD"         : Gosub VERIF
 When "DEFTRANS"          : Gosub DEFTRANS
 When "SEL_LISTE"         : Gosub SEL_LISTE
 When "CHANGE"            : Gosub CHANGE
 When "AP_CHANGE"         : Gosub AP_CHANGE
 When "ANNULE"            : Gosub ANNULE
 When "FIN"               : Gosub FIN
 When "ABANDON"           : Gosub ABANDON
Endcase
Return

$OUVRE
If clalev([F:CCL])=0 : Local File GACCCODLIG [CCL] : Endif
If clalev([F:ATB])=0 : Local File ATABLE     [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON    [AMZ] : Endif
If clalev([F:GDE])=0 : Local File GDIAENTRY  [GDE] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
Local Char SYMBOLE2(250)
Local Integer NLED, NLEG
Local Integer AXE
GMODIF = 0
Local Mask GAU9 [GAU9]
Raz [M:GAU9]
Call LECLIB

Global Integer GNBLIGCAC
Local Mask CAC1 [CAC1]
GNBLIGCAC = dim([M:CAC1]CPT)
Close Local Mask [CAC1]
Return

$FIN
If dim(GGADLINOK)>0
 Kill GNBGADLINOK,GGADLINOK
Endif
Return

$DEFTRANS
Case GBIDI1
 When 1
  GFLAG = "GAD"
 When 2
  GFLAG = "GADT"
Endcase
Return

$EFFMASK
[M]COD = [F:GAU]COD : Affzo [GAD0]COD
Return

$OUVRE_BOITE
Return

$TIT
Return

$LIENS
Call LECTEXTRA([M]DESTRA,"GAUTACED","DESTRA",[M]COD,num$([M]LINNUM)) From ATEXTRA
Raz [M]FORCLC
Gosub CHARGE_INTIT
Read [ATB]CODFIC = [F:GAU]TBL : [M]ABR0 = [F:ATB]ABRFIC
If [F:GAD]LINTBL1<>""
 Read [ATB]CODFIC = [F:GAD]LINTBL1 : [M]ABR1 = [F:ATB]ABRFIC
 For I=0 To dim([M]FORCND)-1
  Call SUBST([M]FORCND(I),"TB1",[M]ABR1)
 Next
Endif
If [F:GAD]LIKTBL2<>""
 Call SUBST([M]LIKTBL2,"TB0",[M]ABR0)
 Call SUBST([M]LIKTBL2,"TB1",[M]ABR1)
 Call SUBST([M]LIKTBL2,"TB2",[M]ABR2)
Endif
If [F:GAD]LINTBL2<>""
 Read [ATB]CODFIC = [F:GAD]LINTBL2 : [M]ABR2 = [F:ATB]ABRFIC
 For I=0 To dim([M]FORCND)-1
  Call SUBST([M]FORCND(I),"TB2",[M]ABR2)
 Next
Endif
For I=0 To dim([M]FORCND)-1
 Call SUBST([M]FORCND(I),"TB0",[M]ABR0)
Next
#--------------------------------------
[M:GAD1]NBRLED = 0 : Raz [M:GAD1]LEDTYP
For NLED = 0 To dim([F:GAD]LEDTYP)-1
 If [F:GAD]LEDTYP(NLED)<>0
  [M:GAD1]LEDTYP(NLED) = [F:GAD]LEDTYP(NLED)
  [M:GAD1]NBRLED += 1
 Endif
Next
#--------------------------------------
[M:GAD1]NBLEG = 0 : Raz [M:GAD1]ACT
Filter [ADI] Where NUMTAB=909
 For [ADI]CODE
  [M:GAD1]LEG([M:GAD1]NBLEG) = [F:ADI]CODE
  If find([F:ADI]CODE,[F:GAD]ACTLEG(0..dim([F:GAD]ACTLEG)-1))
   [M:GAD1]ACT([M:GAD1]NBLEG) = 2
  Else
   [M:GAD1]ACT([M:GAD1]NBLEG) = 1
  Endif
  [M:GAD1]NBLEG +=1
 Next
Filter [ADI]
#--------------------------------------
If [F:GAU]TRCFLG=2
 [M:GAD1]FMTTRCFLG = "K:15X"
Else
 [M:GAD1]FMTTRCFLG = "-K:15X"
Endif
#--------------------------------------
For [GAG] Where COD=[F:GAD]COD & LINNUM=[F:GAD]LINNUM
 ## Chargement écran GAD2 : formules hors Axes/Sections
 J = find([F:GAG]FLD,[M]FLD(0..[M]NBLIG-1))
 If J
  [M]FORCLC(J-1) = [F:GAG]FORCLC
  Call SUBST([M]FORCLC(J-1),"TB0",[M]ABR0)
  If [F:GAD]LINTBL1<>""
   Call SUBST([M]FORCLC(J-1),"TB1",[M]ABR1)
  Endif
  If [F:GAD]LINTBL2<>""
   Call SUBST([M]FORCLC(J-1),"TB2",[M]ABR2)
  Endif
 Endif
 ## Chargement écran GAD3 : formule Axes/Sections
 J = find([F:GAG]FLD,[M:GAD3]FLDAXI(0..[M:GAD3]NBAXI-1))
 If J
  [M:GAD3]FORCLCAXI(J-1) = [F:GAG]FORCLC
  Call SUBST([M:GAD3]FORCLCAXI(J-1),"TB0",[M]ABR0)
  If [F:GAD]LINTBL1<>""
   Call SUBST([M:GAD3]FORCLCAXI(J-1),"TB1",[M]ABR1)
  Endif
  If [F:GAD]LINTBL2<>""
   Call SUBST([M:GAD3]FORCLCAXI(J-1),"TB2",[M]ABR2)
  Endif
 Endif
 J = find([F:GAG]FLD,[M:GAD3]FLDCCE(0..[M:GAD3]NBAXI-1))
 If J
  [M:GAD3]FORCLCCCE(J-1) = [F:GAG]FORCLC
  Call SUBST([M:GAD3]FORCLCCCE(J-1),"TB0",[M]ABR0)
  If [F:GAD]LINTBL1<>""
   Call SUBST([M:GAD3]FORCLCCCE(J-1),"TB1",[M]ABR1)
  Endif
  If [F:GAD]LINTBL2<>""
   Call SUBST([M:GAD3]FORCLCCCE(J-1),"TB2",[M]ABR2)
  Endif
 Endif
Next
Gosub CHARGE_LIBIND
For I=0 To [M]NBRTYP-1
 Call SUBST([M]ACCCND(I),"TB0",[M]ABR0)
 Call SUBST([M]ACCKEY(I),"TB0",[M]ABR0)
 If [F:GAD]LINTBL1<>""
  Call SUBST([M]ACCCND(I),"TB1",[M]ABR1)
  Call SUBST([M]ACCKEY(I),"TB1",[M]ABR1)
 Endif
 If [F:GAD]LINTBL2<>""
  Call SUBST([M]ACCCND(I),"TB2",[M]ABR2)
  Call SUBST([M]ACCKEY(I),"TB2",[M]ABR2)
 Endif
Next I
Return

$INICRE
$INIMOD
If dim([F:GAD]DES)>0
 [F:GAD]DES = [M:GAD0]DESTRA
Endif
#Initialiser pour objet GAD pour textes traduisibles
[F:GAD]LINNUMCAR = num$([F:GAD]LINNUM)

For I=0 To dim([F:GAD]FORCND)-1
 Call SUBST([F:GAD]FORCND(I),[M]ABR0,"TB0")
 If [F:GAD]LINTBL1<>""
  Call SUBST([F:GAD]FORCND(I),[M]ABR1,"TB1")
 Endif
 If [F:GAD]LINTBL2<>""
  Call SUBST([F:GAD]FORCND(I),[M]ABR2,"TB2")
 Endif
Next
If [F:GAD]LIKTBL2<>""
 Call SUBST([F:GAD]LIKTBL2,[M]ABR0,"TB0")
 If [F:GAD]LINTBL1<>""
  Call SUBST([F:GAD]LIKTBL2,[M]ABR1,"TB1")
 Endif
 If [F:GAD]LINTBL2<>""
  Call SUBST([F:GAD]LIKTBL2,[M]ABR2,"TB2")
 Endif
Endif
For I=0 To [M]NBRTYP-1
 Call SUBST([F:GAD]ACCCND(I),[M]ABR0,"TB0")
 Call SUBST([F:GAD]ACCKEY(I),[M]ABR0,"TB0")
 If [F:GAD]LINTBL1<>""
  Call SUBST([F:GAD]ACCCND(I),[M]ABR1,"TB1")
  Call SUBST([F:GAD]ACCKEY(I),[M]ABR1,"TB1")
 Endif
 If [F:GAD]LINTBL2<>""
  Call SUBST([F:GAD]ACCCND(I),[M]ABR2,"TB2")
  Call SUBST([F:GAD]ACCKEY(I),[M]ABR2,"TB2")
 Endif
Next I
For NLED=0 To [M:GAD1]NBRLED-1
 [F:GAD]LEDTYP(NLED) = [M:GAD1]LEDTYP(NLED)
Next
If dim([F:GAD]ACTLEG)>0
 For I=0 To dim([F:GAD]ACTLEG)-1
  [F:GAD]ACTLEG(I)=""
 Next
 NLEG=0
 [F:GAD]NBRLEG=0
 For I=0 To [M:GAD1]NBLEG-1
  If [M:GAD1]ACT(I)=2
   [F:GAD]ACTLEG(NLEG)=[M:GAD1]LEG(I)
   [F:GAD]NBRLEG+=1
   NLEG+=1
  Endif
 Next
Endif
Return

$VERIF
Local Char    WCHAINE(250) , TABLE(10) , ABR(GLONABR)(1..50)
Local Char    CONSTANTE(80) , OBJET(5) , ZONE(GLONAVA)
Local Integer K1 , K2 , K3 , NBABR , TYP1 , TYP2
Local Decimal MINI , MAXI
Local Integer NBTAB
Local Char    TAB(GLONATB)(1..999)
Raz NBTAB, TAB
Read [ATB]CODFIC = [F:GAU]TBL
NBABR = 1 : ABR(NBABR) = [F:ATB]ABRFIC
For K1=0 To [F:GAU]NBRTBL-1
 Read [ATB]CODFIC = [F:GAU]LIKTBL(K1)
 NBABR += 1 : ABR(NBABR) = [F:ATB]ABRFIC
Next K1
If [F:GAD]LINTBL1<>""
 Read [ATB]CODFIC = [F:GAD]LINTBL1
 NBABR += 1 : ABR(NBABR) = [F:ATB]ABRFIC
Endif
If [F:GAD]LINTBL2<>""
 Read [ATB]CODFIC = [F:GAD]LINTBL2
 NBABR += 1 : ABR(NBABR) = [F:ATB]ABRFIC
Endif
For K1=0 To [F:GAD]NBRTBL-1
 Read [ATB]CODFIC = [F:GAD]LIKTBL(K1)
 NBABR += 1 : ABR(NBABR) = [F:ATB]ABRFIC
Next K1
For K=0 To dim([M:GAD1]FORCND)-1
 WCHAINE = [M:GAD1]FORCND(K)
 CHAMP  = ""
 If WCHAINE<>""
  Gosub VERF_FORMULE From SUBGAU
 Endif
Next
For K=0 To [M:GAD2]NBLIG-1
 WCHAINE = [M:GAD2]FORCLC(K)
 CHAMP  = [M:GAD2]FLD(K)
 If CHAMP = "LIB"
  WCHAINE = "'"+WCHAINE+"'"
 Endif
 If WCHAINE<>""
  Gosub VERF_FORMULE From SUBGAU
 Endif
Next K
For K=0 To [M:GAD3]NBAXI-1
 # Vérif formules codes axes
 WCHAINE = [M:GAD3]FORCLCAXI(K)
 CHAMP  = [M:GAD3]FLDAXI(K)
 If WCHAINE<>""
  Gosub VERF_FORMULE From SUBGAU
 Endif
 # Vérif formules codes sections
 WCHAINE = [M:GAD3]FORCLCCCE(K)
 CHAMP  = [M:GAD3]FLDCCE(K)
 If WCHAINE<>""
  Gosub VERF_FORMULE From SUBGAU
 Endif
Next K
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
## Sauvegarde formules lignes (Hors Axes/Sections)
For I=0 To [M]NBLIG-1
 If [M]FORCLC(I)<>""
  [F:GAG]COD    = [F:GAD]COD
  [F:GAG]LINNUM = [F:GAD]LINNUM
  [F:GAG]FLD    = [M]FLD(I)
  [F:GAG]FORCLC = [M]FORCLC(I)
  Gosub WRITE_GAF
  If GOK<1 : Break : Endif
 Endif
Next I
## Sauvegarde formules Axes/Sections
For AXE=0 To [M:GAD3]NBAXI-1
 If [M:GAD3]FORCLCAXI(AXE)<>""
  [F:GAG]COD    = [F:GAD]COD
  [F:GAG]LINNUM = [F:GAD]LINNUM
  [F:GAG]FLD    = [M:GAD3]FLDAXI(AXE)
  [F:GAG]FORCLC = [M:GAD3]FORCLCAXI(AXE)
  Gosub WRITE_GAF
  If GOK<1 : Break : Endif
 Endif
 If [M]FORCLCCCE(AXE)<>""
  [F:GAG]COD    = [F:GAD]COD
  [F:GAG]LINNUM = [F:GAD]LINNUM
  [F:GAG]FLD    = [M:GAD3]FLDCCE(AXE)
  [F:GAG]FORCLC = [M:GAD3]FORCLCCCE(AXE)
  Gosub WRITE_GAF
  If GOK<1 : Break : Endif
 Endif
Next
Return

$WRITE_GAF
Call SUBST([F:GAG]FORCLC,[M]ABR0,"TB0")
If [F:GAD]LINTBL1<>""
 Call SUBST([F:GAG]FORCLC,[M]ABR1,"TB1")
Endif
If [F:GAD]LINTBL2<>""
 Call SUBST([F:GAG]FORCLC,[M]ABR2,"TB2")
Endif
Write [GAG]
If fstat
 GOK = 0 : Call FSTA("GAG") From GLOCK : Return
Endif
Return


$MODIF
Delete [GAG] Where COD=[F:GAD]COD & LINNUM=[F:GAD]LINNUM
If fstat=1
 GOK=-1 : GLOCK = "$GAUTACEF"-[F:GAD]COD-num$([F:GAD]LINNUM) : Return
Endif
Gosub CREATION
Return

$DEFBOUT
Call VIREBOUT(CHAINE,"S") From GOBJET
Return

$AFFMASK
If !GPILSEL & GNBGAUCHE<>0 & GCONSULT<>2
    Gosub REMPLIT From GOBJSUB
Endif
Grizo [GAD0]COD
Return

$FILGAUCHE
# Liste gauche par législation
If currbox="GAU_CHE" & dim([F:GAD]ACTLEG)>0 & GNBLEG>1
 Local Char LEGUSER(GLONADW)
 Call PARAMUTIL("LEGFIL",LEGUSER,GUSER,"") From SUBAUS
 FILGAUCHE = 'COD="'+[M:GAD0]COD+'"'
 If LEGUSER<>""
  # Si le paramètre LEGFIL est renseigner, afficher dans la liste gauche les lignes
  # pour lesquelles la législation de LEGFIL est active.
  FILGAUCHE -= '& find("'+LEGUSER+'",[F:GAD]ACTLEG(0..dim([F:GAD]ACTLEG)-1))'
 Else
  # Si le paramètre LEGFIL est vide, afficher dans la liste gauche toutes les lignes
  # pour lesquelles au moins une des législations déclarées dans le dossier est active
  If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER = nomap
  If !fstat
   If !clalev([F:GAD3]) : Local File GAUTACED [GAD3] : Endif
   Filter [GAD3] Where COD=[M:GAD0]COD
   Global Integer GGADLINOK(1..max(1,nbrecord([GAD3])))
   Global Integer GNBGADLINOK : GNBGADLINOK=0
   For [GAD3]GAD0
    If func SUBGAD.TABCMP([F:ADS]DOSLEG(0..[F:ADS]NBLEG),[F:GAD3]ACTLEG(0..dim([F:GAD3]ACTLEG)-1))=1
     GNBGADLINOK+=1
     GGADLINOK(GNBGADLINOK)=[F:GAD3]LINNUM
    Endif
   Next
   Filter [GAD3]
   FILGAUCHE -= '& find(LINNUM,GGADLINOK(1..GNBGADLINOK))>0'
  Endif
 Endif
Endif
If currbox="GAU_CHE1"
 FILGAUSUP(0) = 'COD="'+[M:GAD0]COD+'"'
Endif
Return

Funprog TABCMP(TAB1,TAB2)
#Return 1 if a value of TAB1 is find in TAB2
#Return 0 if there is no value of TAB1 in TAB2
Value Char TAB1()()
Value Char TAB2()()
Local Integer I
For I=0 To dim(TAB1)-1
 If TAB1(I)<>"" & find(TAB1(I),TAB2(0..dim(TAB2)-1))
  End 1
 Endif
Next
End 0

$FILTRE
If !GPILSEL : FILTSUP = 'COD="'+[F:GAU]COD+'"' : Endif
Return

$RAZCRE
Read [ATB]CODFIC = [F:GAU]TBL : [M]ABR0 = [F:ATB]ABRFIC
Gosub CHARGE_INTIT : Affzo [GAD2]INTIT
Gosub CHARGE_LEG
Return

$CHARGE_LEG
Filter [ADI] Where NUMTAB=909
For [ADI]CODE
 [M:GAD1]LEG([M:GAD1]NBLEG) = [F:ADI]CODE
 [M:GAD1]ACT([M:GAD1]NBLEG) = 2
 [M:GAD1]NBLEG +=1
Next
Filter [ADI]
Affzo [GAD1]NBLEG,LEG,ACT
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GAUTACED","DESTRA",CLECUR2,CLECUR1,"GAUTACED","DESTRA",[M]COD,num$([M]LINNUM)) From ATEXTRA
Endif
Call MAJTEXTRA([M]DESTRA,"GAUTACED","DESTRA",[M]COD,num$([M]LINNUM)) From ATEXTRA
Return

$CHANGE
If dim([F:CHGT]LINNUMCAR)>0
 [F:CHGT]LINNUMCAR= num$([F:CHGT]LINNUM)
Endif
Return

$AP_CHANGE
Call CHGTEXTRA("GAUTACED","DESTRA",SUPP,OCODE,SUPP,NCODE) From ATEXTRA
Return


$ANNULE
Call SUPTEXTRA("GAUTACED","DESTRA",SUPP,[L]CODE) From ATEXTRA
Return


$CHARGE_INTIT
###########################################################
## Chargement écran GAD2 : Formules lignes hors sections
###########################################################
Local Integer I
Local Integer TYPREF
I = -1

If [M]LINTYP=2
 I += 1 : [M]FLD(I) = "STR" : [M]INTIT(I) = mess(27,105,1) : # Valeur début
 I += 1 : [M]FLD(I) = "END" : [M]INTIT(I) = mess(28,105,1) : # Valeur fin
Endif
I += 1 : [M]FLD(I) = "FCY"  : [M]INTIT(I) = mess(29,105,1) : # Site
## Affichage des comptes des référentiels sélectionnés pour la ligne de pièce automatique
For TYPREF = 1 To len(mess(0,2644,1))
 If find(TYPREF,[M:GAD1]LEDTYP(0..dim([M:GAD1]LEDTYP)-1))
  I += 1 : [M]FLD(I) = "ACC"+num$(TYPREF) : [M]INTIT(I) = mess(30,105,1)-mess(TYPREF,2644,1) : # Compte référentiel mess(TYPREF,2644,1)
 Endif
Next
I += 1 : [M]FLD(I) = "BPR"  : [M]INTIT(I) = mess(31,105,1) : # Tiers
I += 1 : [M]FLD(I) = "AMT"  : [M]INTIT(I) = mess(32,105,1) : # Montant
## Pour chaque type de référentiel, possibilité de mettre un montant forcé
For TYPREF = 1 To len(mess(0,2644,1))
 I += 1 : [M]FLD(I) = "AMTL"+num$(TYPREF) : [M]INTIT(I) = mess(174,105,1)-mess(TYPREF,2644,1): # Montant référentiel
Next
I += 1 : [M]FLD(I) = "QTY"  : [M]INTIT(I) = mess(33,105,1) : # Quantité
I += 1 : [M]FLD(I) = "UNT"  : [M]INTIT(I) = mess(34,105,1) : # Unité
I += 1 : [M]FLD(I) = "SNS"  : [M]INTIT(I) = mess(35,105,1) : # Sens
I += 1 : [M]FLD(I) = "DES"  : [M]INTIT(I) = mess(36,105,1) : # Libellé
I += 1 : [M]FLD(I) = "DSP"  : [M]INTIT(I) = mess(38,105,1) : # Répartition
I += 1 : [M]FLD(I) = "TAX"  : [M]INTIT(I) = mess(39,105,1) : # Taxe
I += 1 : [M]FLD(I) = "PJTLIN" : [M]INTIT(I) = mess(217,105,1) : # Project

If [M]LINTBL2<>""
 I += 1 : [M]FLD(I) = "AMTA" : [M]INTIT(I) = mess(40,105,1) : # Montant analytique
 I += 1 : [M]FLD(I) = "QTYA" : [M]INTIT(I) = mess(41,105,1) : # Quantité analytique
Endif
I += 1 : [M]FLD(I) = "ST1" : [M]INTIT(I) = mess(42,105,1)  : # Code stat 1
I += 1 : [M]FLD(I) = "ST2" : [M]INTIT(I) = mess(43,105,1)  : # Code stat 2
I += 1 : [M]FLD(I) = "ST3" : [M]INTIT(I) = mess(44,105,1)  : # Code stat 3
## Affichage contrepartie des référentiels sélectionnés pour la ligne de pièce automatique
For TYPREF = 1 To len(mess(0,2644,1))
 If find(TYPREF,[M:GAD1]LEDTYP(0..dim([M:GAD1]LEDTYP)-1))
  I += 1 : [M]FLD(I) = "OFF"+num$(TYPREF) : [M]INTIT(I) = mess(61,105,1)-mess(TYPREF,2644,1)  : # Contrepartie mess(TYPREF,2644,1)
 Endif
Next

If func AFNC.ACTIV("CSL")
 I += 1 : [M]FLD(I) = "CSLC" : [M]INTIT(I) = mess(177,105,1) : # Partenaire
Elsif func AFNC.ACTIV("PRCSL")
 I += 1 : [M]FLD(I) = "CSLB" : [M]INTIT(I) = mess(177,105,1) : # Partenaire
Endif

If func AFNC.ACTIV("CSL1")
 I += 1 : [M]FLD(I) = "CSLF" : [M]INTIT(I) = mess(178,105,1) : # Flux
Endif

I += 1 : [M]FLD(I) = "IDL" : [M]INTIT(I) = mess(173,105,1) : # Identifiant ligne
I += 1 : [M]FLD(I) = "LIB" : [M]INTIT(I) = mess(106,105,1) : # Critère de détail libre
I += 1 : [M]FLD(I) = "FREREF" : [M]INTIT(I) = mess(152,105,1) : # Référence Libre

# Zones supp de l'écran GACCENTR1
For [AMZ]CODE Where CODMSK="GACCENTR1" & CODZON>="X" & CODACT<>"" & NUMBLOC=6
 I += 1 : [M]FLD(I) = [F:AMZ]CODZON
 Call TEXTE([F:AMZ]INTIT,[M]INTIT(I)) From OBJDIV
Next

# Pour pouvoir ajouter des lignes au paramétrage
GPOINT = "CHARGE" : Gosub ENTREE From EXEFNC

[M]NBLIG = I+1


###############################################
## Chargement écran GAD3 : Formules sections
###############################################
I =- 1
For AXE = 1 To dim([M:GAD3]FLDAXI)
 I += 1 : [M:GAD3]FLDAXI(I) = "DIE"+num$(AXE) : [M:GAD3]FLDCCE(I) = "CCE"+num$(AXE) : [M:GAD3]INTITAXI(I) = mess(170,105,1)-num$(AXE) : # Axe x
Next
[M:GAD3]NBAXI = I+1

Return


$CHARGE_LIBIND
For NOL=0 To [M]NBRTYP-1
 [M]LIBIND(NOL) = [M:GAU9]LIBEL(GNBLIGCAC*([M]TYPACCCOD(NOL)-1)+[M]ACCNUM(NOL)-1)
Next NOL
Return

# Issue X3-122423 - 2017-04-17 by VAVIL
Subprog SUBST(CHAINE,AB1,AB2)
Variable Char CHAINE
Value    Char AB1
Value    Char AB2
Local Integer K
Local Char    SEP(1)
Repeat
SEP = ":"
K = instr(1,CHAINE,SEP+AB1+"]")
If !K
  SEP = "["
  K = instr(1,CHAINE,SEP+AB1+"]")
Endif
If K
  CHAINE = left$(CHAINE,K-1)+SEP+AB2+"]"+right$(CHAINE,K+len(AB1)+2)
Endif
Until K=0
End

