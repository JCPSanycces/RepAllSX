#<AdxTL>@(#)4.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise a jour champ dans les modeles de données
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Mise a jour champ dans les modeles de données") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Else
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJFLG
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJFLG
End

#-------------------#
$MAJFLG
Local File =DOSSIER+".AWRKLNK"   [AWM]
Local File =DOSSIER+".APATCHMOD" [APH]
Local Integer MODIF
# Mise à jour de la table AWRKLNK
Call ECR_TRACE(mess(81,125,1)-"AWRKLNK:"-time$,0) From GESECRAN
Trbegin [AWM]
For [AWM]AWM0 
 MODIF = 0
 If dim([AWM]FLGWRK)>0 & [AWM]FLGWRK<2 & dim([AWM]FLGAPH)>0 & [AWM]FLGAPH<2  & [AWM]FLGEXA<2 & [F:AWM]FLGSTR<2
  Read [APH]APH0 = [F:AWM]MODELE;1
  If !fstat
   If dim([AWM]FLGAPH)>0
    [F:AWM]FLGAPH = 2
    MODIF  = 1
   Endif
  Else
   If dim([AWM]FLGWRK)>0
    [F:AWM]FLGWRK= 2
    MODIF  = 1
   Endif
  Endif
  If MODIF
   Rewrite [AWM]
   If fstat
    Call ERREUR("AWRKLNK"-[F:AWM]MODELE,1) From DOSDIC
   Endif
  Endif
 Endif
Next
Commit

Close Local File [AWM],[APH]

Return








