$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 51241: RES='Content type'
   When 5296: RES='Code'
  Endcase
 When "ENG":
  Case _ID
   When 51241: RES='Content type '
   When 5296: RES='Code'
  Endcase
 When "ITA":
  Case _ID
   When 51241: RES='Content type'
   When 5296: RES='Codice'
  Endcase
 When "POR":
  Case _ID
   When 51241: RES='Tipo conteúdo'
   When 5296: RES='Cód.'
  Endcase
 When "SPA":
  Case _ID
   When 51241: RES='Tipo contenido'
   When 5296: RES='Código'
  Endcase
 When "BRI":
  Case _ID
   When 51241: RES='Content type '
   When 5296: RES='Code'
  Endcase
 When "GER":
  Case _ID
   When 51241: RES='Typ Content'
   When 5296: RES='Code'
  Endcase
 When "POL":
  Case _ID
   When 51241: RES='Typ zawartości'
   When 5296: RES='Kod'
  Endcase
 When "CHI":
  Case _ID
   When 51241: RES='内容类型'
   When 5296: RES='代码'
  Endcase
 When "ARB":
  Case _ID
   When 51241: RES='نوع المحتوى'
   When 5296: RES='رمز '
  Endcase
Endcase
Return
