#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
    Case [L]CURPTH
        When ""
            Case [L]AEVENT
                When "AINSERT_CONTROL_BEFORE" : Gosub EVENT_CONTROL_BEFORE
                When "AUPDATE_CONTROL_BEFORE" : Gosub EVENT_CONTROL_BEFORE
                When "AREAD_AFTER" : Gosub AREAD_AFTER
            Endcase
        When "LINES"
            Case [L]AEVENT
                When "ADDLINE_AFTER" : Gosub ADDLINE_AFTER
                When "AREAD_AFTER" : Gosub AREAD_AFTER_LINES
            Endcase
    Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#ASTATUS = fmet this.ASETERROR( "", [L]CURPRO - [L]ARULE, [V]CST_AOK )
    Case [L]CURPRO
        When "CODBFF"
            Case [L]ARULE
                When "PROPAGATE" : Gosub PROPAGATE_CODBFF
            Endcase
        When "FILTYP"
            Case [L]ARULE
              When "INIT"
                If this.FILTYP = 0 : this.FILTYP = 1 : Endif
              When "CONTROL" :   Gosub CONTROL_FILTYP
              When "PROPAGATE" : Gosub PROPAGATE_FILTYP
            Endcase
        When "LINES.SCTSTR"
            Case [L]ARULE
                When "PROPAGATE" : Gosub PROPAGATE_LINES_SCTSTR
            Endcase
        When "LINES.SCTEND"
            Case [L]ARULE
                When "PROPAGATE" : Gosub PROPAGATE_LINES_SCTEND
            Endcase
        When "LINES.CODBFF"
            Case [L]ARULE
                When "PROPAGATE" : Gosub PROPAGATE_LINES_CODBFF
            Endcase
        When "LINES.SCT"
            Case [L]ARULE
                When "PROPAGATE" : Gosub PROPAGATE_LINES_SCT
            Endcase
    Endcase

Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


############################################################################################
# Implementation
############################################################################################

$PROPAGATE_CODBFF
    Local Integer I

    # Loop lines of LINES collection to assign CODBFF with header CODBFF value.
    For I = 1 To maxtab( this.LINES )
        If this.LINES(I) <> null
            this.LINES(I).CODBFF = this.CODBFF
        Endif
    Next I
Return

#control filetype. The file type of the segment has to be the same as for the file format
$CONTROL_FILTYP
Local Tinyint VALID : VALID = 1
Local Integer C
Local File BSISCT [BSISCT]
Local Char LASTELT(GLONBSIELT) : [L]LASTELT = ""
  VALID = 1
  For [L]C = 1 To maxtab(this.LINES)
    If this.LINES([L]C) <> null
&        and this.LINES([L]C).ASTALIN <> [V]CST_ADEL
&        and this.LINES([L]C).ASTALIN <> [V]CST_ANEWDEL
        Read [F:BSISCT]BSISCT0 = this.LINES(C).SCT
        If [F:BSISCT]FILTYP <> this.FILTYP
          ASTATUS = fmet this.ASETERROR("", mess(82,7703,1), [V]CST_AERROR)
          VALID = 0
          Break
        Endif
        If this.FILTYP = 3                    # CAMT > check if for all segments Camt element mapping is identical
            If [L]LASTELT = ""
                [L]LASTELT = [F:BSISCT]CODELT
            Else
                If [L]LASTELT <> [F:BSISCT]CODELT   # Camt element mapping wrong
                    ASTATUS = fmet this.ASETERROR("", mess(195,7703,1), [V]CST_AERROR)
                    VALID = 0
                    Break
                Endif
            Endif
        Endif
    Endif
  Next
LogicClose File [BSISCT]
Return

#set field depending on filetype
$PROPAGATE_FILTYP
  Gosub SET_FIELD_FLDSEP
  Gosub SET_LINE_PROPERTIES
Return


$PROPAGATE_LINES_SCTSTR
    Local Integer I

    # If this line is checked...
    If this.SCTSTR = 2 Then
        # ... loop all lines except the current and remove check mark.
        For I = 1 To maxtab( this.APARENT.LINES )
            If ( this.APARENT.LINES(I) <> null ) and ( this.LIN <> this.APARENT.LINES(I).LIN )
                this.APARENT.LINES(I).SCTSTR = 1
            Endif
        Next I
    Endif
Return

$PROPAGATE_LINES_SCTEND
    Local Integer I

    # If this line is checked...
    If this.SCTEND = 2 Then
        # ... loop all lines except the current and remove check mark.
        For I = 1 To maxtab( this.APARENT.LINES )
            If ( this.APARENT.LINES(I) <> null ) and ( this.LIN <> this.APARENT.LINES(I).LIN )
                this.APARENT.LINES(I).SCTEND = 1
            Endif
        Next I
    Endif
Return


$PROPAGATE_LINES_SCT
Local File BSISCT [BSISCT]
Local Char DESCRIPTION(30)
    Read [F:BSISCT]BSISCT0 = this.SCT
    If !fstat
        this.LEV = [F:BSISCT]LEV
        Call LECTEXTRA(GACTX,this.DES,DESCRIPTION,"BSISCT","DESAXX",[F:BSISCT]CODSCT ,"") From ASYRFNC
       this.DES = DESCRIPTION

    Endif
LogicClose File [BSISCT]

Return


##
# The following functionality is used to set the order of the include rules if the user has changed the order
# This functionality is not integrated in the standard yet. So we have to manage it by our own.
#
$EVENT_CONTROL_BEFORE
    Local Integer I, J, N
    [L]N = 0

    # loop through all lines
    For [L]I = 1 To maxtab(this.LINES)
        If this.LINES([L]I) <> null
&           and this.LINES([L]I).ASTALIN <> [V]CST_ADEL
&           and this.LINES([L]I).ASTALIN <> [V]CST_ANEWDEL
&       Then
            [L]N += 1
            If this.LINES([L]I).AORDER  <> this.LINES([L]I).LIN Then
                # delete the line
                ASTATUS = fmet this.ADELLINE("LINES", this.LINES([L]I).AORDER)
                # add new line
                [L]J = fmet this.ADDLINE("LINES", this.LINES([L]I).AORDER)
                If [L]J <> [V]CST_ANOTDEFINED Then
                    # copy contents
                    this.LINES([L]J).CODBFF = this.CODBFF
                    this.LINES([L]J).LIN    = this.LINES([L]I).AORDER
                    this.LINES([L]J).SCT    = this.LINES([L]I).SCT
                    this.LINES([L]J).LEV    = this.LINES([L]I).LEV
                    this.LINES([L]J).SCTSTR = this.LINES([L]I).SCTSTR
                    this.LINES([L]J).SCTEND = this.LINES([L]I).SCTEND
                    this.LINES([L]J).TABTYP = this.LINES([L]I).TABTYP
                    this.LINES([L]J).SEGOBY = this.LINES([L]I).SEGOBY
                    this.LINES([L]J).DBACT  = this.LINES([L]I).DBACT
                Endif
            Endif
        Endif
    Next [L]I
    If [L]N = 0 Then
        ASTATUS = fmet this.ASETERROR("", mess(32,7703,1), [V]CST_AERROR)
    Elsif N > 1 and this.FILTYP = 2
        ASTATUS = fmet this.ASETERROR("", mess(81,7703,1), [V]CST_AERROR)
    Endif
Return

$AREAD_AFTER
    #angre US X3-990 240417
    Local Integer C
    Local File BSISCT [BSISCT]
    Local Char DESCRIPTION(30)
    For [L]C = 1 To maxtab(this.LINES)
      Read [F:BSISCT]BSISCT0 = this.LINES([L]C).SCT
      If !fstat
      this.LINES([L]C).LEV = [F:BSISCT]LEV
      Call LECTEXTRA(GACTX,this.LINES([L]C).DES,DESCRIPTION,"BSISCT","DESAXX",[F:BSISCT]CODSCT ,"") From ASYRFNC
      this.LINES([L]C).DES = DESCRIPTION
    Endif
    Next
    LogicClose File [BSISCT]
    #enable/disable field FLDSEP
    Gosub SET_FIELD_FLDSEP
Return


$AREAD_AFTER_LINES
    Gosub PROPAGATE_LINES_CODBFF
Return


$ADDLINE_AFTER
    Gosub SET_CSV_LINE_ATTRIBUTES From BSIFILFMTD_CSTD
Return


$PROPAGATE_LINES_CODBFF
    If this.APARENT.FILTYP = 2
      ASTATUS = fmet this.ASETATTRIBUTE("SCTSTR", "$isDisabled", "true")
      ASTATUS = fmet this.ASETATTRIBUTE("SCTEND", "$isDisabled", "true")
      ASTATUS = fmet this.ASETATTRIBUTE("TABTYP", "$isDisabled", "true")
      ASTATUS = fmet this.ASETATTRIBUTE("SEGOBY", "$isDisabled", "true")
      ASTATUS = fmet this.ASETATTRIBUTE("DBACT", "$isDisabled", "true")
    Else
      ASTATUS = fmet this.ASETATTRIBUTE("SCTSTR", "$isDisabled", "false")
      ASTATUS = fmet this.ASETATTRIBUTE("SCTEND", "$isDisabled", "false")
      ASTATUS = fmet this.ASETATTRIBUTE("TABTYP", "$isDisabled", "false")
      ASTATUS = fmet this.ASETATTRIBUTE("SEGOBY", "$isDisabled", "false")
      ASTATUS = fmet this.ASETATTRIBUTE("DBACT", "$isDisabled", "false")
    Endif
Return


$SET_FIELD_FLDSEP
    If this.FILTYP = 1                        # MT940
      this.FLDSEP = ""
      ASTATUS = fmet this.ASETATTRIBUTE("FLDSEP", "$isDisabled", "true")
    Elsif this.FILTYP = 2 or this.FILTYP = 3  # CSV or CAMT
      ASTATUS = fmet this.ASETATTRIBUTE("FLDSEP", "$isDisabled", "false")
    Endif
Return

$SET_LINE_PROPERTIES
   Local Integer I

    # loop through all lines

    For [L]I = 1 To maxtab(this.LINES)
      If this.FILTYP = 2
        ASTATUS = fmet this.LINES(I).ASETATTRIBUTE("SCTSTR", "$isDisabled", "true")
        ASTATUS = fmet this.LINES(I).ASETATTRIBUTE("SCTEND", "$isDisabled", "true")
        ASTATUS = fmet this.LINES(I).ASETATTRIBUTE("TABTYP", "$isDisabled", "true")
        ASTATUS = fmet this.LINES(I).ASETATTRIBUTE("SEGOBY", "$isDisabled", "true")
        ASTATUS = fmet this.LINES(I).ASETATTRIBUTE("DBACT", "$isDisabled", "true")
      Else
        ASTATUS = fmet this.LINES(I).ASETATTRIBUTE("SCTSTR", "$isDisabled", "false")
        ASTATUS = fmet this.LINES(I).ASETATTRIBUTE("SCTEND", "$isDisabled", "false")
        ASTATUS = fmet this.LINES(I).ASETATTRIBUTE("TABTYP", "$isDisabled", "false")
        ASTATUS = fmet this.LINES(I).ASETATTRIBUTE("SEGOBY", "$isDisabled", "false")
        ASTATUS = fmet this.LINES(I).ASETATTRIBUTE("DBACT", "$isDisabled", "false")
      Endif
    Next
Return

