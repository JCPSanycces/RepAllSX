##################################
Funprog EXISTE_MTC (PBCO, PPLN, PDTDBEXE, PDTFNPER)
Value Char    PBCO
Value Integer PPLN
Value Date    PDTDBEXE
Value Date    PDTFNPER

Local Integer RTRN

  #FQ-66451 If !(clalev([F:WDEP]))  : Local File DEPREC     [WDEPW]  : Endif
  If !(clalev([F:WDEP]))  : Local File DEPREC     [WDEP]  : Endif
  Filter [WDEP] Where
&        AASREF=PBCO and DPRPLN=PPLN and FIYSTRDAT >= PDTDBEXE and PERENDDAT <= PDTFNPER and MTCDPEDAT <> [0/0/0]
  Read [WDEP] First
  If (fstat)
   RTRN = 0
  Else
   RTRN = 1
  Endif
  Filter [WDEP]

End RTRN
##=================================================================================
Funprog RVACOEF(RVACOEREF,PURDAT,AASIPTDAT,ITSDAT,ACGGRP,ACCCOD,PERSTRDAT)

Value    Char    RVACOEREF
Value    Date    PURDAT
Value    Date    AASIPTDAT
Value    Date    ITSDAT
Value    Date    PERSTRDAT
Value    Char    ACGGRP
Value    Char    ACCCOD

Local Shortint RVACOEF
RVACOEF = 1


Local Char    LCLETAB, LCLETAB2, LCLEACT, LCLEACT2, LNAT
Local Decimal LINDINI, LINDACT, COEFF,CDRET
Local Integer LMOIS, LANNEE


If ! clalev ([F:COD]) : Local File RVACOED  [F:COD] : Endif
If ! clalev ([F:COH]) : Local File RVACOEH  [F:COH] : Endif

  Read[COH]COH0= RVACOEREF

  Case  [F:COH]CRITDAT
    When GVML_DATACH  :  LMOIS = month([L]PURDAT)    :  LANNEE = year([L]PURDAT)
    When GVML_DATCPT  :  LMOIS = month([L]AASIPTDAT) :  LANNEE = year([L]AASIPTDAT)
    When GVML_DATMES  :  LMOIS = month([L]ITSDAT)    :  LANNEE = year([L]ITSDAT)
    When Default
  Endcase

  Case  [F:COH]CRITNAT
    When GVML_NATFAM  :  LNAT = [L]ACGGRP
    When GVML_NATCCO  :  LNAT = [L]ACCCOD
    When Default
  Endcase

  CDRET     = 0
  LCLETAB   = sum(num$(LANNEE),num$(LNAT),num$(LMOIS))
  LCLETAB2  = sum(num$(LANNEE),num$(LNAT),num$(0))

  LCLEACT  = sum(num$(year([L]PERSTRDAT )),num$(LNAT),num$(month([L]PERSTRDAT)))
  LCLEACT2 = sum(num$(year([L]PERSTRDAT )),num$(LNAT),num$(0))

  # FQ81292
  #Filter [COD]Where CPY=[F:COH]CPY and RVACOEREF=[F:COH]RVACOEREF and
#&                   CRITNAT = [F:COH]CRITNAT and CRITDAT=[F:COH]CRITDAT
  #Read[COD]COD1=LCLETAB
  #If (fstat)
  #  Read[COD]COD1=LCLETAB2
  #  If fstat
  #      [L]RVACOEF = 1
  #  Else
  #      [L]RVACOEF = 2
  #  Endif
  #Else
  #    [L]RVACOEF = 2
  #Endif
  Filter [COD] Where CRITNAT=[F:COH]CRITNAT and CRITDAT=[F:COH]CRITDAT
  Read[COD]COD0=[F:COH]RVACOEREF;LCLETAB
  If (fstat)
    Read[COD]COD0=[F:COH]RVACOEREF;LCLETAB2
  Endif

  If (fstat)
      [L]RVACOEF = 1
  Else
      [L]RVACOEF = 2
  Endif
  # FQ81292
End RVACOEF
######################################################################################
$CALC_RVAVMA_ENDFIY

  #-- Fq-79819 -rééval fin exercice-------------------------
  # si on calcule les nouvelles valeurs à partir d'une ligne de l'écran de contrôle
  #-1 --------------------------
  If ( PINDICE )
    CHAMP=PCLASSE+"FLGERR(PINDICE-1)"       : Assign CHAMP With G_NON
    CHAMP=PCLASSE+"FLGMOD(PINDICE-1)"       : Assign CHAMP With G_OUI
    CHAMP=PCLASSE+"MSGERR (PINDICE-1)"      : Assign CHAMP With ""
    #-2 ----------------------
    If  ( LNSPVAL = evalue(PCLASSE+"NBVO(PINDICE-1)") )
      # "Valeur marché invalide"
      CHAMP=PCLASSE+"MSGERR (PINDICE-1)"    : Assign CHAMP With mess(395,GML_MSGFAS,1)
      CHAMP=PCLASSE+"FLGERR (PINDICE-1)"    : Assign CHAMP With G_OUI
      CHAMP=PCLASSE+"FLGMOD (PINDICE-1)"    : Assign CHAMP With G_OUI
      Return
    #-2 ----------------------
    Else
      #==============================
      # Réévaluation valeur MARCHE
      #===============================
      CHAMP=PCLASSE+"RVATIADAT(PINDICE-1)"    : Assign CHAMP With  GVML_ERENDEX
      CHAMP=PCLASSE+"RVATYP(PINDICE-1)"       : Assign CHAMP With  GVML_MODVMA
      CHAMP=PCLASSE+"RVADAT(PINDICE-1)"       : Assign CHAMP With  evalue (PCLASSE+"RVADAT(PINDICE-1)")
      CHAMP=PCLASSE+"RVACOE(PINDICE-1)"       : Assign CHAMP With 1
      CHAMP=PCLASSE+"RVACOEREF(PINDICE-1)"    : Assign CHAMP With ""
      CHAMP=PCLASSE+"NSPVAL(PINDICE-1)"       : Assign CHAMP With LNSPVAL
      CHAMP=PCLASSE+"RVAAMT(PINDICE-1)"       : Assign CHAMP With evalue (PCLASSE+"NSPVAL(PINDICE-1)-"+PCLASSE+"NBVO(PINDICE-1)")

      If (evalue(PCLASSE+"RVAAMT(PINDICE-1)") = 0)
        # "Montant réévaluation invalide"
        CHAMP=PCLASSE+"MSGERR (PINDICE-1)"    : Assign CHAMP With mess(400,GML_MSGFAS,1)
        CHAMP=PCLASSE+"FLGERR (PINDICE-1)"    : Assign CHAMP With G_OUI
        CHAMP=PCLASSE+"FLGMOD (PINDICE-1)"    : Assign CHAMP With G_NON
        Return
      Endif
    Endif
    #-2 ----------------------

  #-1 --------------------------
  Else
    CHAMP=PCLASSE+"FLGERR"                  : Assign CHAMP With G_NON
    CHAMP=PCLASSE+"FLGMOD"                  : Assign CHAMP With G_OUI
    CHAMP=PCLASSE+"MSGERR"                  : Assign CHAMP With ""

    CHAMP=PCLASSE+"RVATIADAT"               : Assign CHAMP With  [M:FASR]RVATIADAT
    CHAMP=PCLASSE+"RVATYP"                  : Assign CHAMP With  GVML_MODVMA
    CHAMP=PCLASSE+"RVADAT"                  : Assign CHAMP With  [M:FASR]RVADAT
    CHAMP=PCLASSE+"RVACOE"                  : Assign CHAMP With 1
    CHAMP=PCLASSE+"RVACOEREF"               : Assign CHAMP With ""
#    CHAMP=PCLASSE+"PERREFCLC"               : Assign CHAMP With [M:FASR]PERSTRDAT
#    CHAMP=PCLASSE+"PERREFCLCT"              : Assign CHAMP With [M:FASR]PERSTRDAT
    #-2 ----------------------
    If  (LNSPVAL = evalue(PCLASSE+"NBVO"))
      # Valeur marché invalide
      CHAMP=PCLASSE+"MSGERR"            : Assign CHAMP With mess(395,GML_MSGFAS,1)
      CHAMP=PCLASSE+"FLGERR"            : Assign CHAMP With G_OUI
      CHAMP=PCLASSE+"FLGMOD"            : Assign CHAMP With G_OUI
      Return
    #-2 ----------------------
    Else
      CHAMP=PCLASSE+"NSPVAL"                  : Assign CHAMP With LNSPVAL
      CHAMP=PCLASSE+"RVAAMT"                  : Assign CHAMP With evalue (PCLASSE+"NSPVAL-"+PCLASSE+"NBVO")

      If (evalue(PCLASSE+"RVAAMT") = 0)
        # "Montant réévaluation invalide"
        CHAMP=PCLASSE+"MSGERR"    : Assign CHAMP With mess(400,GML_MSGFAS,1)
        CHAMP=PCLASSE+"FLGERR"    : Assign CHAMP With G_OUI
        CHAMP=PCLASSE+"FLGMOD"    : Assign CHAMP With G_NON
        Return
      Endif
    Endif
    #-2 ----------------------
  Endif
  #-1 ---------------------
Return

#-----------------------------------------------------
$CALC_RVACOE_ENDFIY_MFS0

  #FQ-85936 Réévaluation par coefficient  "Fin exercice"
  [M:MFS0]FLGERR(PINDICE-1)      =  G_NON
  [M:MFS0]FLGMOD(PINDICE-1)      =  G_OUI
  [M:MFS0]MSGERR(PINDICE-1)      =  ""

  [M:MFS0]RVATIADAT(PINDICE-1)   = [M:FASR]RVATIADAT
  [M:MFS0]RVATYP(PINDICE-1)      = [M:FASR]RVATYP
  [M:MFS0]RVADAT(PINDICE-1)      = [M:FASR]RVADAT
  [M:MFS0]RVACOEREF(PINDICE-1)   = LRVACOEREF
  [M:MFS0]RVACOE(PINDICE-1)      = LRVACOE

  #-1 ---------------
  If ([M:MFS0]RVACOE(PINDICE-1) <> 0) Then
    # << Coefficent <> 0 >>

      # Autres types de réévaluations FQ85936
      Local Decimal XCUME_1R, XCUMP_1R, XDPER, XEXCE_1R, XEXCP_1R, XEXCR
      Local Decimal XCUME_1T, XCUMP_1T, XDPET, XEXCE_1T, XEXCP_1T, XEXCT
      Local Decimal XTRFE_1,  XTRFP_1,  XTRF,  XIMLE_1,  XIMLP_1,  XIML, XRVEE_1, XRVEP_1, XRVE
      Local Decimal XIMLBLC, XNBV, XRVAAMT, XBASE

      Call  CAL_RVACOE_ENDFIY ( LRVACOE, [M:FASR]CUR, [M:MFS0]NBVO(PINDICE-1),
&    [M:MFS0]DPRBASO(PINDICE-1),[M:MFS0]DPRCUMO(PINDICE-1)    ,[M:MFS0]PERCLOCUMO(PINDICE-1) ,[M:MFS0]PERENDDPE(PINDICE-1),
&                               [M:MFS0]EXCCUM(PINDICE-1)     ,[M:MFS0]PERCLOEXCO(PINDICE-1) ,[M:MFS0]PEREXCDPR(PINDICE-1),
&                               [M:MFS0]EXECLOCUTO(PINDICE-1) ,[M:MFS0]PERCLOCUTO(PINDICE-1) ,[M:MFS0]DPET(PINDICE-1),
&                               [M:MFS0]EXCCUMT(PINDICE-1)    ,[M:MFS0]PERCLOEXTO(PINDICE-1) ,[M:MFS0]PEREXCDPRT(PINDICE-1),
&                               [M:MFS0]EXETRFCUMO(PINDICE-1) ,[M:MFS0]PERTRFCUM(PINDICE-1)  ,[M:MFS0]IMLRVETRF(PINDICE-1),
&                               [M:MFS0]EXEIMLCUMO(PINDICE-1) ,[M:MFS0]PERIMLCUMO(PINDICE-1) ,[M:MFS0]IMLO(PINDICE-1),
&                               [M:MFS0]EXERVECUMO(PINDICE-1) ,[M:MFS0]PERRVECUMO(PINDICE-1) ,[M:MFS0]IMLRVEO(PINDICE-1),
&                         XBASE,XCUME_1R, XCUMP_1R, XDPER, XEXCE_1R, XEXCP_1R, XEXCR,
&                               XCUME_1T, XCUMP_1T, XDPET, XEXCE_1T, XEXCP_1T, XEXCT,
&                               XTRFE_1,  XTRFP_1,  XTRF,  XIMLE_1,  XIMLP_1,  XIML, XRVEE_1, XRVEP_1, XRVE,
&                               XIMLBLC, XNBV, [M:MFS0]RVAAMT(PINDICE-1) ) From GLOBB6

    #[M:MFS0]NBV(PINDICE-1) = [M:MFS0]NBVO(PINDICE-1)
    [M:MFS0]NBV(PINDICE-1)  = [M:MFS0]NBVO(PINDICE-1) + [M:MFS0]RVAAMT(PINDICE-1)

    # <<< Réévaluation >>>>
    If ([M:MFS0]RVAAMT(PINDICE-1) = 0) Then
      # "Montant réévaluation invalide"
      [M:MFS0]MSGERR (PINDICE-1) =  mess(400,GML_MSGFAS,1)
      [M:MFS0]FLGERR (PINDICE-1) =  G_OUI
      [M:MFS0]FLGMOD (PINDICE-1) =  G_NON
    Endif

  #-1 ---------------
  Else
    # << Coefficient = 0 >>
    # "Coefficient invalide"
    [M:MFS0]MSGERR (PINDICE-1)  =  mess(173,GML_MSGFAS,1)
    [M:MFS0]FLGERR (PINDICE-1)  =  G_OUI
    [M:MFS0]FLGMOD (PINDICE-1)  =  G_OUI
  Endif
  #-1 ---------------

  If ([M:MFS0]FLGERR(PINDICE-1) = G_OUI and [M:MFS0]FLGMOD(PINDICE-1) <> G_OUI) Then
    [M:MFS0]RVACOEREF(PINDICE-1) =  ""
    [M:MFS0]RVACOE(PINDICE-1)    =  1
    [M:MFS0]RVATIADAT(PINDICE-1) =  0
    [M:MFS0]RVADAT(PINDICE-1)    =  [0/0/0]
    [M:MFS0]RVATYP(PINDICE-1)    =  0
    [M:MFS0]RVAAMT(PINDICE-1)    =  0
  Endif

Return


#-----------------------------------------------------
$CALC_RVACOE_ENDFIY_TMP1


  #FQ-85936 Réévaluation par coefficient  "Fin exercice"

  CHAMP=PCLASSE+"FLGERR"          : Assign CHAMP With G_NON
  CHAMP=PCLASSE+"FLGMOD"          : Assign CHAMP With G_OUI
  CHAMP=PCLASSE+"MSGERR"          : Assign CHAMP With ""

  CHAMP=PCLASSE+"RVATIADAT"       : Assign CHAMP With [M:FASR]RVATIADAT
  CHAMP=PCLASSE+"RVATYP"          : Assign CHAMP With [M:FASR]RVATYP
  CHAMP=PCLASSE+"RVADAT"          : Assign CHAMP With [M:FASR]RVADAT
  CHAMP=PCLASSE+"RVACOEREF"       : Assign CHAMP With LRVACOEREF
  CHAMP=PCLASSE+"RVACOE"          : Assign CHAMP With LRVACOE

  Local Decimal XCUME_1R, XCUMP_1R, XDPER, XEXCE_1R, XEXCP_1R, XEXCR
  Local Decimal XCUME_1T, XCUMP_1T, XDPET, XEXCE_1T, XEXCP_1T, XEXCT
  Local Decimal XTRFE_1,  XTRFP_1,  XTRF,  XIMLE_1,  XIMLP_1,  XIML, XRVEE_1, XRVEP_1, XRVE
  Local Decimal XIMLBLC, XNBV, XRVAAMT, XBASE

  #-1 ------------------------------------
  If (evalue (PCLASSE+"RVACOE") > 0)
    # << Coefficent <> 0 >>

    # Autres types de réévaluations FQ85936
    Case PCLASSE
    When "[F:TMP1]"

      Call  CAL_RVACOE_ENDFIY ( LRVACOE, [M:FASR]CUR, [F:TMP1]NBVO,
&               [F:TMP1]DPRBASO,[F:TMP1]DPRCUMO    ,[F:TMP1]PERCLOCUMO ,[F:TMPC]PERENDDPE,
&                               [F:TMPC]EXCCUM     ,[F:TMP1]PERCLOEXCO ,[F:TMPC]PEREXCDPR,
&                               [F:TMP1]EXECLOCUTO ,[F:TMP1]PERCLOCUTO ,[F:TMPC]DPET,
&                               [F:TMPC]EXCCUMT    ,[F:TMP1]PERCLOEXTO ,[F:TMPC]PEREXCDPRT,
&                               [F:TMP1]EXETRFCUMO ,[F:TMPC]PERTRFCUM  ,[F:TMPC]IMLRVETRF,
&                               [F:TMP1]EXEIMLCUMO ,[F:TMP1]PERIMLCUMO ,[F:TMP1]IMLO,
&                               [F:TMP1]EXERVECUMO ,[F:TMP1]PERRVECUMO ,[F:TMP1]IMLRVEO,
&                         XBASE,XCUME_1R, XCUMP_1R, XDPER, XEXCE_1R, XEXCP_1R, XEXCR,
&                               XCUME_1T, XCUMP_1T, XDPET, XEXCE_1T, XEXCP_1T, XEXCT,
&                               XTRFE_1,  XTRFP_1,  XTRF,  XIMLE_1,  XIMLP_1,  XIML, XRVEE_1, XRVEP_1, XRVE,
&                               XIMLBLC, XNBV, [F:TMP1]RVAAMT ) From GLOBB6
      #[F:TMP1]NBV = [F:TMP1]NBVO
      [F:TMP1]NBV  = [F:TMP1]NBVO + [F:TMP1]RVAAMT

    When "[M:MFS0]"

      Call  CAL_RVACOE_ENDFIY ( LRVACOE, [M:FASR]CUR, [M:MFS0]NBVO,
&               [M:MFS0]DPRBASO,[M:MFS0]DPRCUMO    ,[M:MFS0]PERCLOCUMO ,[M:MFS0]PERENDDPE,
&                               [M:MFS0]EXCCUM     ,[M:MFS0]PERCLOEXCO ,[M:MFS0]PEREXCDPR,
&                               [M:MFS0]EXECLOCUTO,[M:MFS0]PERCLOCUTO,[M:MFS0]DPET,
&                               [M:MFS0]EXCCUMT    ,[M:MFS0]PERCLOEXTO,[M:MFS0]PEREXCDPRT,
&                               [M:MFS0]EXETRFCUMO ,[M:MFS0]PERTRFCUM  ,[M:MFS0]IMLRVETRF,
&                               [M:MFS0]EXEIMLCUMO ,[M:MFS0]PERIMLCUMO ,[M:MFS0]IMLO,
&                               [M:MFS0]EXERVECUMO ,[M:MFS0]PERRVECUMO ,[M:MFS0]IMLRVEO,
&                         XBASE,XCUME_1R, XCUMP_1R, XDPER, XEXCE_1R, XEXCP_1R, XEXCR,
&                               XCUME_1T, XCUMP_1T, XDPET, XEXCE_1T, XEXCP_1T, XEXCT,
&                               XTRFE_1,  XTRFP_1,  XTRF,  XIMLE_1,  XIMLP_1,  XIML, XRVEE_1, XRVEP_1, XRVE,
&                               XIMLBLC, XNBV, [M:MFS0]RVAAMT ) From GLOBB6


      #[M:MFS0]NBV = [M:MFS0]NBVO
      [M:MFS0]NBV  = [M:MFS0]NBVO + [M:MFS0]RVAAMT

    Endcase

    # << Réévaluation >>
    If (evalue (PCLASSE+"RVAAMT") = 0)
        # Montant réévaluation invalide"
        CHAMP=PCLASSE+"MSGERR"        : Assign CHAMP With mess(400,GML_MSGFAS,1)
        CHAMP=PCLASSE+"FLGERR"        : Assign CHAMP With G_OUI
        CHAMP=PCLASSE+"FLGMOD"        : Assign CHAMP With G_NON
    Endif

  #-1 ------------------------------------
  Else
    # <<< Coefficent = 0 >>>
    # Coefficient invalide
    CHAMP=PCLASSE+"MSGERR"        : Assign CHAMP With mess(173,GML_MSGFAS,1)
    CHAMP=PCLASSE+"FLGERR"        : Assign CHAMP With G_OUI
    CHAMP=PCLASSE+"FLGMOD"        : Assign CHAMP With G_OUI
  Endif
  #-1 ------------------------------------

  If  ( evalue (PCLASSE+"FLGERR") = G_OUI and evalue (PCLASSE+"FLGMOD") <> G_OUI )
    CHAMP=PCLASSE+"RVACOEREF"     : Assign CHAMP With ""
    CHAMP=PCLASSE+"RVACOE"        : Assign CHAMP With 1
    CHAMP=PCLASSE+"RVADAT"        : Assign CHAMP With [0/0/0]
    CHAMP=PCLASSE+"RVATYP"        : Assign CHAMP With 0
    CHAMP=PCLASSE+"RVATIADAT"     : Assign CHAMP With 0
    CHAMP=PCLASSE+"RVAAMT"        : Assign CHAMP With 0
  Endif

Return
