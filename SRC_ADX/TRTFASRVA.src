##################################
Subprog AV_NBOBJ_MFS

  If ([M:MFS0]NBOBJ > 1)
    Enable GSTAANU
    Enable 65
    GBOUT1=""
   Else
    Disable GSTAANU
    Disable 65
    GBOUT1=""
  Endif

End
##################################
Subprog AV_RVACOE_MFS(VALEUR)
Variable Decimal VALEUR

  #-1 ---------------------------
  If  (ACTTYPGES = GTAMUNI)
    Diszo [M:MFS0]NSPVAL(nolign-1)
    Diszo [M:MFS0]RVACOE(nolign-1)
  #-1 ---------------------------
  Else
    #-2 ---------------------------
    If ( [M:FASR]CCLRVAFLG <> G_OUI )
      # <<< Réévaluation >>>
      #-3 ---------------------------
      If ([M:FASR]RVATYP = GVML_MODVMA)
        Diszo [M:MFS0]RVACOE(nolign-1)
        If [M:MFS0]FLGMOD(nolign-1)=G_OUI
          [M:MFS0]RVATYP(nolign-1) = GVML_MODVMA
          Actzo[M:MFS0]NSPVAL(nolign-1)
        Else
          # FQ-29764
          Diszo[M:MFS0]NSPVAL(nolign-1)
        Endif
      #-3 ---------------------------
      Else
        If [M:MFS0]FLGMOD(nolign-1)=G_OUI & [M:MFS0]FLGERR(nolign-1)<> G_OUI
          If [M:FASR]RVATYP = GVML_MODCOE
            [M:MFS0]RVATYP(nolign-1) = GVML_MODCOE
          Endif
          If [M:FASR]RVATYP = GVML_MODIND
            [M:MFS0]RVATYP(nolign-1) = GVML_MODIND
          Endif
          Actzo [M:MFS0]RVACOE(nolign-1)
          Diszo [M:MFS0]NSPVAL(nolign-1)
        Endif
      Endif
      #-3 ---------------------------
      If ( [M:MFS0]FLGMOD(nolign-1) <> G_OUI and [M:MFS0]FLGERR(nolign-1) = G_OUI )
        Diszo [M:MFS0]RVACOE(nolign-1)
        Diszo [M:MFS0]NSPVAL(nolign-1)
      Endif
    #-2 ---------------------------
    Else
      # <<< Annulation réévaluation >>>
      Diszo [M:MFS0]RVACOE(nolign-1)
      Diszo [M:MFS0]NSPVAL(nolign-1)
    Endif
    #-2 ---------------------------
  Endif
  #-1 ---------------------------
  Affzo [M:MFS0]NBOBJ

End
##################################
Subprog AM_RVACOE_MFS(VALEUR)
Variable Decimal VALEUR

Local Integer PLIGNE
Local Char MES, RVAMOD
Local Integer ERR

  #FQ-64311  If ( VALEUR <= 1 )
  If ( VALEUR <= 0 )
    # " Coefficient invalide "
    GERR=1 :   GMESSAGE=mess(173,GML_MSGFAS,1) : mkstat=2 : End
  Endif

  Case  [M:FASR]RVATYP
    When GVML_MODIND  :    RVAMOD = "IND"
    When GVML_MODCOE  :    RVAMOD = "COE"
    When Default
  Endcase

  If (ACTTYPGES = GTAMMAS) & ([M:FASR]RVATYP <> GVML_MODVMA & [M:MFS0]FLGMOD(nolign-1)=G_OUI)
    If [M:FASR]CCLRVAFLG <> G_OUI
      [M:MFS0]RVACOEREF(nolign-1)=""
      PLIGNE=nolign
      Call APPLIQUE_REEVAL("[M:MFS0]",RVAMOD, PLIGNE, VALEUR) From TRTFASRVA

      Call GET_MNT_ARRONDI ([M:MFS0]DPRBAS,     [M:FASR]CUR, [M:MFS0]DPRBAS)      From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]PERCLOCUM,  [M:FASR]CUR, [M:MFS0]PERCLOCUM)   From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]PERCLOEXC,  [M:FASR]CUR, [M:MFS0]PERCLOEXC)   From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]DPRCUM,     [M:FASR]CUR, [M:MFS0]DPRCUM)      From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]EXETRFCUM,  [M:FASR]CUR, [M:MFS0]EXETRFCUM)   From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]EXEIMLCUM,  [M:FASR]CUR, [M:MFS0]EXEIMLCUM)   From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]PERIMLCUM,  [M:FASR]CUR, [M:MFS0]PERIMLCUM)   From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]EXERVECUM,  [M:FASR]CUR, [M:MFS0]EXERVECUM)   From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]PERRVECUM,  [M:FASR]CUR, [M:MFS0]PERRVECUM)   From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]IMLBLC,     [M:FASR]CUR, [M:MFS0]IMLBLC)      From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]NBV,        [M:FASR]CUR, [M:MFS0]NBV)         From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]NBVT,       [M:FASR]CUR, [M:MFS0]NBVT)        From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]PERCLOCUMT, [M:FASR]CUR, [M:MFS0]PERCLOCUMT)  From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]PERCLOEXCT, [M:FASR]CUR, [M:MFS0]PERCLOEXCT)  From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]EXECLOCUMT, [M:FASR]CUR, [M:MFS0]EXECLOCUMT)  From GLOBIENS
    Else
      Gosub ANNU_REEVAL
    Endif
  Endif

  Affzo [M:MFS0]NBOBJ

End
##################################
Subprog C_RVACOE_MFS(VALEUR)
Variable Decimal VALEUR

End
##################################
Subprog AV_NSPVAL_MFS(VALEUR)
Variable Decimal VALEUR

  #-1 --------------------------------
  If  (ACTTYPGES = GTAMUNI)
    Diszo [M:MFS0]NSPVAL(nolign-1)
    Diszo [M:MFS0]RVACOE(nolign-1)
  #-1 --------------------------------
  Else
    #-2 --------------------------------
    If ( [M:FASR]CCLRVAFLG <> G_OUI )
      # <<< Réévaluation >>>
      If ([M:FASR]RVATYP = GVML_MODVMA)
        If ([M:MFS0]FLGERR(nolign-1) <> G_OUI )
          [M:MFS0]RVATYP(nolign-1) = GVML_MODVMA
          Actzo[M:MFS0]NSPVAL(nolign-1)
          Diszo [M:MFS0]RVACOE(nolign-1)
        Endif
      Else
        If ( [M:MFS0]FLGERR(nolign-1) <> G_OUI )
          If [M:FASR]RVATYP = GVML_MODCOE
            [M:MFS0]RVATYP(nolign-1) = GVML_MODCOE
          Endif
          If ( [M:FASR]RVATYP = GVML_MODIND )
            [M:MFS0]RVATYP(nolign-1) = GVML_MODIND
          Endif
          Actzo [M:MFS0]RVACOE(nolign-1)
        Endif
        Diszo [M:MFS0]NSPVAL(nolign-1)
      Endif
    #-2 --------------------------------
    Else
      # <<< Annulation réévaluation >>>
      Diszo [M:MFS0]RVACOE(nolign-1)
      Diszo [M:MFS0]NSPVAL(nolign-1)
    Endif
    #-2 --------------------------------
  Endif
  #-1 --------------------------------
  Affzo [M:MFS0]NBOBJ

End
##################################
Subprog AM_NSPVAL_MFS(VALEUR)
Variable Decimal VALEUR

Local Integer PLIGNE
Local Char MES, RVAMOD
Local Integer ERR

  #FQ-64311   If ( VALEUR <= [M:MFS0]NBVO(nolign-1) )
  #FQ-64311  Valeur Marché ne doit pas être < VNC début période
  If ( abs(VALEUR) = [M:MFS0]NBVO(nolign-1) )
    # Valeur Marché ne doit pas être = VNC début période
    GERR=1 : GMESSAGE= mess(372,GML_MSGFAS,1)+" : "-num$([M:MFS0]NBVO(nolign-1)) : mkstat=2 : End
  Endif

  If (ACTTYPGES = GTAMMAS and [M:FASR]RVATYP = GVML_MODVMA and [M:MFS0]FLGMOD(nolign-1) = G_OUI)
    If ([M:FASR]CCLRVAFLG <> G_OUI)
      PLIGNE=nolign
      Call APPLIQUE_REEVAL("[M:MFS0]","VMA", PLIGNE, VALEUR) From TRTFASRVA

      Call GET_MNT_ARRONDI ([M:MFS0]DPRBAS,     [M:FASR]CUR, [M:MFS0]DPRBAS)      From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]PERCLOCUM,  [M:FASR]CUR, [M:MFS0]PERCLOCUM)   From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]PERCLOEXC,  [M:FASR]CUR, [M:MFS0]PERCLOEXC)   From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]DPRCUM,     [M:FASR]CUR, [M:MFS0]DPRCUM)      From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]EXETRFCUM,  [M:FASR]CUR, [M:MFS0]EXETRFCUM)   From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]EXEIMLCUM,  [M:FASR]CUR, [M:MFS0]EXEIMLCUM)   From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]PERIMLCUM,  [M:FASR]CUR, [M:MFS0]PERIMLCUM)   From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]EXERVECUM,  [M:FASR]CUR, [M:MFS0]EXERVECUM)   From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]PERRVECUM,  [M:FASR]CUR, [M:MFS0]PERRVECUM)   From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]IMLBLC,     [M:FASR]CUR, [M:MFS0]IMLBLC)      From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]NBV,        [M:FASR]CUR, [M:MFS0]NBV)         From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]NBVT,       [M:FASR]CUR, [M:MFS0]NBVT)        From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]PERCLOCUMT, [M:FASR]CUR, [M:MFS0]PERCLOCUMT)  From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]PERCLOEXCT, [M:FASR]CUR, [M:MFS0]PERCLOEXCT)  From GLOBIENS
      Call GET_MNT_ARRONDI ([M:MFS0]EXECLOCUMT, [M:FASR]CUR, [M:MFS0]EXECLOCUMT)  From GLOBIENS
    Else
      Gosub ANNU_REEVAL
    Endif
  Endif

  Affzo [M:MFS0]NBOBJ

End
