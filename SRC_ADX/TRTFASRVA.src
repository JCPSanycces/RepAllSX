#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#                                                                       #
# Action métier : "REEVALUER"  Réévaluation d'un bien comptable         #
#                                                                         #
#########################################################################
#
#      FASRVA0  :  Entête  Réévaluation - unitaire         (OAC0)
#      FASRVA   :  Paramètres de réévaluation - unitaire   (FASR)
#      FASRVAM  :  Paramètres de réévaluation - massif     (FASR)
#
#************************************************************************
#    Création 06.01.2004
#
#************************************************************************
#    Dernières modifications
# CBO   23.12.2014  FQ104164  : Erreur evt fiscal valeurs origine
# MWA   10.09.2014  FQ95754_3 : Classement pour vente (Sprint 38 - US 3) Opération interdite pour un bien classé pour vente
# MDJ   30.10.2013  FQ92611   : Suppression champs CRETIM et UPDTIM
# MDJ   19.08.2013  FQ91891   : Rééval.début période : valeur nette affichée erronée
# MDJ   26.04.2013  FQ89419   :  Seule la rééval du plan comptable doit avoir une effet sur les plans Fiscal/Minimum
# MDJ   29.01.2013  FQ87640   : Annulation de rééval et EXECLOCUMT non remis à sa valeur initiale
# MDJ   25.01.2013  FQ85936   : Cas d'une rééval. fin exercice par VMA : calcul/stockage de la VN après rééval.
# MDJ   24.12.2012  FQ84817   : Correction annexe au pb d'evt plan fiscal
# MWA   28.11.2012  FQ85936   : Réévaluation fin d'exercice par coefficient (plan normés IAS uniquement)
# MDJ   12.09.2012  FQ79819   : Réévaluation fin d'exercice (plan normés IAS uniquement)
# MWA   16.04.2012  FQ81475   : Valeur marché ne doit pas être remise à 0.
# GLE   04.02.2012  FQ81292   : Correction suite 79483+79741
# MDJ   20.02.2012  FQ80075   : Evénements générés à tort quand RVAAMT=0
# MDJ   20.02.2012  FQ79741   : Exclusion des biens sans correspondance dans la table des coeff.
# GLE   08.02.2012  FQ79483   : Gestion du paramétrage des coefficients de réévaluation sans code société
# MDJ   08.11.2011  FQ77221   : Massif direct : suppression contrôle NBV > RSDVAL
# MDJ   29.07.2011  FQ75459   : Massif :  pb en maj des  plans FISCAL et MINIMUM + ctrl G_RVALIB
# MDJ   06.01.2011  FQ67995   : Réévaluation libre comptable pour sociétés françaises
# GBO   25.02.2011  FQ67577   : Pologne - Modernisation
# MDJ   22.12.2010  Fq70141   : Vérification de sources (interne)
# GBO   27.09.2010  FQ67531   : Rééval inopérante sans erreur : conséquence 65636
# GBO   02.08.2010  FQ65636   : NC30-38 : archivage plan d'amortissement avant rééval
# MDJ   02.08.2010  FQ66451   : Abréviation incorrecte
# MDJ   03.06.2010  FQ65178   : Interdiction de réévaluer les biens négatifs
# MDJ   26.05.2010  FQ64910   : Exécution Réévaluation en Batch et déclaration des variables globales
# MWA   03.05.2010  FQ64311   : Réévaluation négative
# MDJ   19.04.2010  FQ64120   : Contrôle des plans à réévaluer : normé IAS/IFRS si législation française
# MDJ   26.11.2009  FQXXXXX   : Prise en compte société pour lecture table des coeff.
# GBO   xx.xx.xxxx  FQ54343   : Gestion des concessions
# MDJ   16.10.2009  FQ58289   : Passage en résiduel et conservation du Prorata
#
#************************************************************************
# GTAMUNI unitaire ou GTAMMAS massif
Local Char MASUNI : MASUNI=GTAMMAS
  Call LAUNCH_ACT(MASUNI)
End
#==============================================================#
#            Gestion de l'action métier FASRVA                 #
#==============================================================#
$ACTION

  Case ACTION
    When "INIT"         : Gosub INIT
    When "INIT_DIA"     : Gosub INIT_DIA
    When "LIENS"        : Gosub LIENS     : # FQ85936
    When "AVANT_PAR"    : Gosub AVANT_PAR
    When "OUVRE"        : Gosub OUVRE
    When "OUVRE_BATCH"  : Gosub OUVRE_BATCH
    When "DEBUT"        : Gosub DEBUT
    When "SETBOUT"      : Gosub SETBOUT
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "END"          : Gosub END_BOITE
    When "OK"           : Gosub OK
    When "AVANT_OK"     : Gosub AVANT_OK
    When "ABA"          : Gosub ABA
    When "EXEC"         : Gosub EXEC
    When "FIN"          : Gosub FIN
    When "TERMINE"      : Gosub TERMINE
    When "SORTIE"       : Gosub SORTIE
    When "SEL_TABLE"    : Gosub SEL_TABCOE
    When Default
   Endcase
Return

#=====================================================================
$OUVRE_BATCH             # (Massif uniquement - Soumission batch uniquement)
  Gosub OUVRE_TABLES
Return
#=====================================================================
$INIT_DIA                    # (Massif - Saisie des paramètres)

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT
  Raz [M:FASR]
  [M:FASR]CCLRVAFLG=G_NON
  [M:FASR]RVADEVFLG=G_OUI

Return
#=====================================================================
$INIT                    # (Massif uniquement - interactif et exécution batch)

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT

  #FQ-64910
  If GSERVEUR
    Gosub CREE_GLOBTRT
  Endif

Return
#=====================================================================
$LIENS                   # (Massif uniquement - interactif et exécution batch)
  If ORIACT="TRTOBJ"
    # FQ85936 : alimentation de l'écran MFS0 de contrôle avec la table TMPMASFA2
    Read [F:MF2]MF10=[F:MFS]TRTNUM;[F:MFS]OBJREF
    If !fstat
      [M:MFS0]PERENDDPE(nolign-1)  = [F:MF2]PERENDDPE
      [M:MFS0]EXCCUM(nolign-1)     = [F:MF2]EXCCUM
      [M:MFS0]PEREXCDPR(nolign-1)  = [F:MF2]PEREXCDPR
      [M:MFS0]DPET(nolign-1)       = [F:MF2]DPET
      [M:MFS0]EXCCUMT(nolign-1)    = [F:MF2]EXCCUMT
      [M:MFS0]PEREXCDPRT(nolign-1) = [F:MF2]PEREXCDPRT
      [M:MFS0]PERTRFCUM(nolign-1)  = [F:MF2]PERTRFCUM
      [M:MFS0]IMLRVETRF(nolign-1)  = [F:MF2]IMLRVETRF
    Endif
  Endif
Return
#=====================================================================
$AVANT_PAR               # (Massif uniquement - Interactif et soumission batch)

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()

  Gosub ACTION From =TRTMODACT

  # Ouverture des masques de la fenêtre de l'action massive pour pouvoir les garder jusqu'à
  # EXEC - Ouverture manuelle des masques de la fenêtre.
  Local Char WINACT : WINACT=ACTMETNAM+"M"
  Local Integer I_MSK

  If !clalev([F:AWI]) : Local File AWINDOW : Endif
  If !clalev([F:AMK]) : Local File AMSK    : Endif

  Read [AWI]AWI0=WINACT
  If !fstat
  Local Mask =[F:AWI]MSKENT
  For I_MSK=0 To [F:AWI]NBMSK
    Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
    Local Mask =[F:AMK]CODMSK
  Next I_MSK
Endif

Return
#=====================================================================
$OUVRE                   # (Massif interactif et Unitaire)

#FQ-64910
#FQ-85936
  If !GSERVEUR
    Gosub CREE_GLOBTRT
  Endif

  GLOK=G_NON
  # Dans le cas où l'action est lancée depuis une ligne de plan de FAS3
  # on récupère ici le param(6) de l'action FASRVA qui va servir à
  # alimenter le champ DPRPLN de [FASR] et on le sauvegarde dans la
  # variable GPARMPLN
  If ( dim(PARAM(6))>0 & PARAM(6)<> "" )
     Global Integer GPARMPLN
     GPARMPLN=val(PARAM(6))
     #FQ-67995 ---------------------------------------------------------
     #Fq-79819 If func GLOFCYCPY.GET_SOC_PAYS( [M:FAS0]CPY ) = "FR"
     If [M:FPC]LEG="FRA"
        Call GET_CNX_FROM_PLAN ([M:FAS0]CPY, GPARMPLN, GCNX) From GLOBIENS
        Read [CNX]CNX0=[M:FAS0]CPY;GCNX
        I_PLN = find(GPARMPLN,[F:CNX]PLNCAA(0..[F:CNX]NBPLC-1))
        If I_PLN > 0
           If ( [F:CNX]PLNSTD(I_PLN-1) <> GVML_NPIAS )
              #*Fq-89419 GPARMPLN = G301CPT #FQ-67995
              G_RVALIB = G_OUI
              #*Fq-89419 si le plan pour lequel une réévaluation est demandée (via clic droit s/une ligne de plan)
              # est le plan Fiscal ou le plan Minimum ==> c'est le plan comptable qui est imposé à la réévaluation
              If ( GPARMPLN=G301FIS ) or ( GPARMPLN=G301MIN )
                   GPARMPLN = G301CPT #FQ-67995
              Endif
           Else
              G_RVALIB = G_NON
           Endif
        Endif
     Else
       G_RVALIB = G_NON
     Endif
     #FQ-67995E
  Endif

  If dim(TRTMODACT)<0
    Global Char TRTMODACT
    TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Endif

  Gosub ACTION From =TRTMODACT
  Gosub OUVRE_TABLES

Return
#=FQ-64910 ====================================================================
$CREE_GLOBTRT

  #==> Déclaration globales nécessaires à  la fonction
  Global Integer GCNX
  Global Char    GCPY
  Global Decimal GNBVO            # Valeur nette avant réévaluation (début période)
  Global Decimal GNBVTO           # Valeur nette théorique avant réévaluation (début période)
  Global Integer GCCLFLG
  Global Integer GLOK
  Global Integer GINDCURPER

  Global Integer G_RVATYP
  Global Decimal G_RVACOE
  Global Char    G_RVACOEREF
  Global Decimal G_NSPVAL
  Global Char    G_RVAAPR
  Global Integer G_CCLRVA
  Global Decimal GRVADEVCHG   #Fq-64311
  Global Decimal GRVADERRVE   #Fq-67995
  Global Integer G_RVALIB     #Fq-67995
  Global Decimal GDPRCUMO     #Fq-67995b
  Global Char    GDPMO_F      #Fq-67995b
  Global Char    GDPMO_M      #Fq-67995b
  Global Integer GCUMFLGO_F   : GCUMFLGO_F = G_NON #Fq-67995b
  Global Decimal GNBVO_C      # Valeur nette comptable plan comptable avant réévaluation (début période)
  Global Decimal GNBVO_F      # Valeur nette comptable plan fiscal avant réévaluation (début période)
  Global Decimal GNBVO_M      # Valeur nette comptable plan minimum avant réévaluation (début période)
  Global Decimal GDPEO        #Fq-79819
  Global Decimal GDPED        : GDPED = 0   #Fq-79819

Return
#=====================================================================
$DEBUT # (Massif et Unitaire)

Local Integer LCDRET, CRETOUR
Local Char    LMESSAGE
Local Integer NBPLAN

  If !(GBATCH)
    # Si saisie paramètre batch, on n'initialise pas ici le masque
    Raz [M:FASR]
    [M:FASR]CCLRVAFLG=G_NON
  Endif
  #-1 -------------------------
  If ( ACTTYPGES=GTAMUNI )
    #Fq67577-Pologne
    If G_ACTKPL=G_OUI & [M:FPC]LEG="POL" & dim(GPARMPLN)>0 & [M:FAS3]KMDRDEV(find(GPARMPLN,[M:FAS3]DPRPLN)-1)<>0
     GERR=1 : GMESSAGE = mess(827,GML_MSGFAS,1) : FIN=1 : mkstat=2 : Return
    Endif
    #Fin-pologne
    #===================================
    #Fq54343-Gestion des concessions
    If ( [M:FAS1]OWNTYP = GVML_TDCONCE )
      # "Opération impossible : le type de détention est "En modèle"
      GERR= 1: GMESSAGE = mess(703,GML_MSGFAS,1) : FIN=1  : mkstat=2 :  Return
    Endif

    #>>>> En UNITAIRE uniquement
    # Cas où l'on active l'action depuis une ligne de plan de FAS3
    # dans PARMPLN on a le plan passé en paramètre de l'action
    #-2 -------------------------
    If ( dim(GPARMPLN)>0 & GPARMPLN > 0 )
      [M:FASR]DPRPLN=GPARMPLN
         Affzo [M:FASR]DPRPLN : Diszo [M:FASR]DPRPLN
      # Indicateur annulation de réévaluation
      [M:FASR]CCLRVAFLG = G_NON :  Diszo [M:FASR]CCLRVAFLG
      # Initialisation des dates période courante & exercice courant
      Raz  [M:FASR]FIYSTRDAT
      Raz  [M:FASR]FIYENDDAT
      Raz  [M:FASR]PERSTRDAT
      Raz  [M:FASR]PERENDDAT
      GCPY = [M:FAS0]CPY
      Call GET_CNX_FROM_PLAN (GCPY, [M:FASR]DPRPLN, GCNX) From GLOBIENS
      Read [CNX]CNX0=GCPY;GCNX
      [M:FASR]CUR = [F:CNX]CUR
      Read [FIS]FIY1=[F:CNX]CPY;[F:CNX]CNX;GVML_TECOURA
      [M:FASR]FIYSTRDAT = [F:FIS]DATSTRFIY
      [M:FASR]FIYENDDAT = [F:FIS]DATENDFIY
      [M:FASR]PERSTRDAT = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
      [M:FASR]PERENDDAT = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)

      # Affectation de RVATIADAT
      # Si une réévaluation avec prise d'effet "Début de période" dans les périodes closes de l'exercice
      # la réévaluation de la période doit prendre aussi effet début de période
      Filter [DEP] Where AASREF    = [M:FAS0]AASREF
&                    and DPRPLN    = [M:FASR]DPRPLN
&                    and FIYENDDAT = [M:FASR]FIYENDDAT
&                    and PERENDDAT < [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
&                    and RVATIADAT <> 0
      Read[DEP] Last
      Filter [DEP]
      If ( fstat = 0 and [F:DEP]RVATIADAT = GVML_ERDBPE )
        [M:FASR]RVATIADAT = GVML_ERDBPE : Affzo [M:FASR]RVATIADAT : Diszo [M:FASR]RVATIADAT
      Endif

      #*Fq-79819 If ([M:FASR]RVATIADAT = GVML_ERDBPE)
      #*Fq-79819   [M:FASR]RVADAT    = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
      #*Fq-79819 Else
      #*Fq-79819   [M:FASR]RVADAT    = [F:FIS]DATSTRFIY
      #*Fq-79819 Endif

       Case [M:FASR]RVATIADAT
          When GVML_ERDBPE  : [M:FASR]RVADAT  = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
          When GVML_ERENDEX : [M:FASR]RVADAT  = [F:FIS]DATENDFIY
          When Default      : [M:FASR]RVADAT  = [F:FIS]DATSTRFIY
       Endcase

      GINDCURPER        = [F:FIS]INDCURPER
      Affzo [M:FASR]5
      #==
      # Contrôle le bien a-t'il été réévalué dans la période
      Read [DEP]DEP0 =[M:FAS0]AASREF;[M:FASR]DPRPLN;[M:FASR]FIYENDDAT;[M:FASR]PERENDDAT
      #=======================================
      #FQ-64311  If ([F:DEP]RVAAMT > 0)
      If ([F:DEP]RVAAMT <> 0)
         [M:FASR]CCLRVAFLG = G_OUI : Affzo[M:FASR]CCLRVAFLG
         Diszo [M:FASR]5
         #Fq-79819 [M:FASR]RVATYP = 0
         [M:FASR]RVATYP = [F:DEP]RVATYP
         [M:FASR]RVATIADAT = [F:DEP]RVATIADAT  #Fq-79819
         # Ce bien a déjà été réévalué dans la période : vous devez d'abord annuler cette réévaluation
         # On ne met pas le mkstat à 2 car on peut continuer par l'annulation de la réévaluation
         GMESSAGE=mess(134,GML_MSGFAS,1) : GERR=1
      Endif
      # Valeur marché
      #FQ-64311  If ([F:DEP]NSPVAL > 0 )   : [M:FASR]NSPVAL=[F:DEP]NSPVAL : Endif
      If ([F:DEP]RSDVAL <> 0 )   : [M:FASR]RSDVAL=[F:DEP]RSDVAL : Endif   #FQ-64311


      If ([F:DEP]PERSTRDAT <> [F:DEP]FIYSTRDAT and [M:FASR]RVATIADAT = GVML_ERDBEX and
&       func TRTFASRVA.EXISTE_MTC ([M:FAS0]AASREF, [F:DEP]DPRPLN, [F:DEP]FIYSTRDAT, [F:DEP]PERENDDAT) )
        # "Réévaluation début exercice impossible si changement de méthode dans l'exercice"
        # Passage en début de période
        If G_RVALIB <> G_OUI  #Fq-67995
           [M:FASR]RVATIADAT = GVML_ERDBPE
           Affzo [M:FASR]RVATIADAT
        Else
          GMESSAGE=mess(600,GML_MSGFAS,1) : GERR=1 : FIN=1 :  mkstat=2 :  Return
        Endif  #Fq-67995
      Endif

      [F:DEPC] = [F:DEP]
      #Fq-79819 si date prise d'effet <> fin exercice
      If [M:FASR]RVATIADAT <> GVML_ERENDEX
          #Fq-79819 If ( [M:FASR]RVATIADAT = GVML_ERDBEX and [M:FASR]RVATYP <> GVML_MODVMA )
          If ( [M:FASR]RVATIADAT = GVML_ERDBEX)
             Call CAL_VALEUR_NETTE ( "RDE", [F:DEPC]DPRBAS, 2, 0, GNBVO_C  ) From GLOBB4
             Call CAL_VALEUR_NETTE ( "TDE", [F:DEPC]DPRBAS, 2, 0, GNBVTO )   From GLOBB4
          Elsif [M:FASR]RVATIADAT <> GVML_ERENDEX  #*FQ-79819 pas de recalcul si Fin exercice
             Call CAL_VALEUR_NETTE ( "RDP", [F:DEPC]DPRBAS, 2, 0, GNBVO_C  ) From GLOBB4
             Call CAL_VALEUR_NETTE ( "TDP", [F:DEPC]DPRBAS, 2, 0, GNBVTO )   From GLOBB4
          Endif
       Else #Fq-79819 si date prise d'effet =fin exercice
          GNBVO_C = [F:DEP]NBV
          GNBVTO  = [F:DEP]NBVT
       Endif
      [M:FASR]NBVO = GNBVO_C
      GNBVO = GNBVO_C
      #=======================================
      If ( [F:DEP]BSEVAL < 0 )    #Fq-65178
        # Le bien a une base d'amortissement négative, il ne peut pas être réévalué
        GERR= 1: GMESSAGE = mess(807,GML_MSGFAS,1) : FIN=1 :  mkstat=2 :  Return
      Endif
      #=======================================
      If ( [F:DEP]IML <> 0  or [F:DEP]IMLRVE <> 0 )
        # Le bien a été déprécié dans la période, il ne peut pas être réévalué.
        GERR= 1: GMESSAGE = mess(425,GML_MSGFAS,1) : FIN=1 :  mkstat=2 :  Return
      Endif
      #=======================================
      If ( [F:DEP]DPM = G_DPMCA  )
        # Un plan amorti selon le mode "CA" ne peut pas être réévalué.
        GERR= 1: GMESSAGE = mess(611,GML_MSGFAS,1) : FIN=1 :  mkstat=2 :  Return
      Endif
      #=======================================
      If ( ([F:DEP]STRDPRDAT > [M:FASR]PERENDDAT) )
        # Date de début d'amortissement supérieure à la date de fin période courante
        GERR= 1: GMESSAGE = mess(389,GML_MSGFAS,1) : FIN=1  : mkstat=2 :  Return
      Endif
      #===================================
      If ( [F:DEP]IMLRVELIM <> 0 )
        # "Le bien a un Plafond de reprise de dépréciation"
        GERR=1 : GMESSAGE=mess(240,GML_MSGFAS,1) : FIN=1  : mkstat=2 :  Return
      Endif
      #===================================
      If ([F:DEP]DFDBLC <> 0 or [F:DEP]DFD <> 0 or [F:DEP]DFDRVE )
        # "Réévaluation impossible si le plan possède de l'amortissement différé"
        GERR=1 : GMESSAGE=mess(602,GML_MSGFAS,1) : FIN=1  : mkstat=2 :  Return
      Endif
    Endif
    #-2 -------------------------
    #===================================
    If ( [M:FAS4]ISSDAT <> [0/0/0]) and ([M:FAS4]EXTISSFLG <> G_OUI )
      # "le bien comptable est sorti, il ne peut être modifié"
      GERR= 1: GMESSAGE = mess(66,GML_MSGFAS,1) : FIN=1  : mkstat=2 :  Return
    Endif
    #===================================
    # Le bien a fait l'objet d'un classement pour vente. FQ95754_3
    If ( [M:FAS4]SALCLSDAT <> [0/0/0] )
      GERR= 1: GMESSAGE = mess(931,GML_MSGFAS,1) : FIN=1 : mkstat=2 : Return
    Endif
    #===================================
    If ( [M:FAS1]OWNTYP = GVML_TDMODEL )
      # "Opération impossible : le type de détention est "En modèle"
      GERR= 1: GMESSAGE = mess(65,GML_MSGFAS,1) : FIN=1  : mkstat=2 :  Return
    Endif
    #===================================
    If ( [M:FAS1]OWNTYP = GVML_TDANNUL )
      # "Opération impossible : le type de détention est "Annulé"
      GERR= 1: GMESSAGE = mess(603,GML_MSGFAS,1) : FIN=1  : mkstat=2 :  Return
    Endif
    #===================================
    If ( [M:FAS1]GACACN  =  GVML_NIENCOU) or ([M:FAS1]IASACN  =  GVML_NIENCOU )
      # "le bien comptable a une nature de compte d'encours"
      GERR= 1: GMESSAGE = mess(416,GML_MSGFAS,1) : FIN=1  : mkstat=2 :  Return
    Endif
  Endif
  #-1 -------------------------
  GCCLFLG=[M:FASR]CCLRVAFLG

  Gosub ACTION From =TRTMODACT

  ##--> On rend le masque invalide pour faire tous les contrôles
  If ( ACTTYPGES = GTAMUNI )   : Setmok [M:FASR] With 0 : Endif

  # En V5 toujours à Oui ( à faire évoluer en V5.1)
  [M:FASR]RVADEVFLG = G_OUI
  Affzo [M:FASR]RVADEVFLG
  Diszo [M:FASR]RVADEVFLG

Return

#=====================================================================
$APRES_MODIF

   Gosub ACTION From =TRTMODACT

   G_RVATYP    = [M:FASR]RVATYP
   G_RVACOE    = [M:FASR]RVACOE
   G_RVACOEREF = [M:FASR]RVACOEREF
   If ( ACTTYPGES = GTAMUNI )   : G_NSPVAL = [M:FASR]NSPVAL : Endif
   G_RVAAPR = [M:FASR]RVAAPR
   G_CCLRVA = [M:FASR]CCLRVAFLG
   Case COUZON
     When "RVATYP"
       G_RVATYP = val(CZ)
     When "RVACOE"
       G_RVACOE = val(CZ)
     When "RVACOEREF"
       G_RVACOEREF = CZ
     When "NSPVAL"
       G_NSPVAL = val(CZ)
     When "CCLRVAFLG"
       G_CCLRVA = val(CZ)
     When "RVAAPR"
       G_RVAAPR = CZ
   Endcase

Return
#=====================================================================
$SETBOUT                 # (Massif interactif et unitaire : )

  Gosub ACTION From =TRTMODACT

        If ( ( dim(GPARMPLN)>0 & GPARMPLN > 0 ) and [M:FASR]CCLRVAFLG = G_OUI )
    # Sauf si on vient d'une ligne d'un plan et on est en annulation
    Return
  Endif

  If ( ACTTYPGES = GTAMUNI and dim(CHBOU) <> -1 and !pat(CHBOU, "*A*") )
    # Si abandon n'est pas actif le reste non plus
    Call VIREBOUT (CHBOU,"O") From GOBJET
    Call VIREBOUT (CHMEN,"D") From GOBJET
    Return
  Endif

  #FQ-64311 If  ( ACTTYPGES = GTAMUNI and [F:DEP]RVAAMT > 0  and  ACTSTATUS <> 8 )
  If  ( ACTTYPGES = GTAMUNI and [F:DEP]RVAAMT <> 0  and  ACTSTATUS <> 8 )
    If ( G_CCLRVA <> G_OUI )
    # Si on est en unitaire, que le bien a déjà été réévalué et que le flag annulation n'est pas positionné
    Call VIREBOUT (CHBOU,"O") From GOBJET
    Call VIREBOUT (CHMEN,"D") From GOBJET
    Endif
    Return
  Endif

  If ( G_RVATYP  = GVML_MODVMA  and  ACTTYPGES = GTAMMAS  and  ACTSTATUS <> 8 )
    # Si on est en massif et que la réévaluation est par valeur marché
    # Dans ce cas, OK n'est disponible que si l'utilisateur est passé par contrôler
    # car dans ce cas, l'application doit mettre en erreur les biens sans valeur marché.
    Call VIREBOUT (CHBOU,"O") From GOBJET
  Endif

  If  ( G_RVATYP = 0 and G_CCLRVA <> G_OUI )
    # Si le type de réévaluation n'est pas renseigné
    Call VIREBOUT (CHBOU,"O") From GOBJET
    Call VIREBOUT (CHMEN,"D") From GOBJET
    Return
  Endif

  #Fq-67995 If ( G_RVATYP  = GVML_MODVMA )
  #Fq-79819 If ( G_RVATYP  = GVML_MODVMA )  and ( G_RVALIB <> G_OUI )
  If ( G_RVATYP  = GVML_MODVMA )  and ( G_RVALIB <> G_OUI ) #dde CRI and ( [M:FASR]RVATIADAT <> GVML_ERENDEX )
    #FQ-64311 If ( ACTTYPGES = GTAMUNI and (G_NSPVAL <= [M:FASR]NBVO or G_RVAAPR = "") )
    #FQ-85936    If ( ACTTYPGES = GTAMUNI and  G_RVAAPR = "")
    #FQ-85936  Uniquement si l'on n'est pas en annulation de réévaluation (sinon CHBOU = variable inexistante...)
    If ( ACTTYPGES = GTAMUNI and  G_RVAAPR = "" and  G_CCLRVA <> G_OUI)
      # Si on est en unitaire et que ( val. marché <= val. nette avant réév. ou evaluateur non renseigné )
      Call VIREBOUT (CHBOU,"O") From GOBJET
      Call VIREBOUT (CHMEN,"D") From GOBJET
      Return
    Elsif ( ACTTYPGES = GTAMMAS and G_RVAAPR = "" )
      # Si on est en massif et que evaluateur non renseigné
      Call VIREBOUT (CHBOU,"O") From GOBJET
      Call VIREBOUT (CHMEN,"D") From GOBJET
      Return
    Endif
  Endif

   #FQ-85936  Uniquement si l'on n'est pas en annulation de réévaluation (sinon CHBOU = variable inexistante...)
   If  G_CCLRVA <> G_OUI
    If ( (G_RVATYP  = GVML_MODCOE or G_RVATYP  = GVML_MODIND ) and G_RVACOE <= 0. and G_RVACOEREF = "" )
        # Si le type de réévaluation est "par coefficient" ou "par indice" et le coefficient <= 0.
        Call VIREBOUT (CHBOU,"O") From GOBJET
        Call VIREBOUT (CHMEN,"D") From GOBJET
    Endif
  Endif

Return
#=====================================================================
$AP_CHOIX
  Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$BOUTON                  # (Massif interactif et unitaire)
  Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$END_BOITE               # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$AVANT_OK                # (Massif intéractif et unitaire)
  If ( ACTTYPGES = GTAMMAS and ACTSTATUS <> 8 )
    If ( [M:FASR]RVATYP = GVML_MODVMA and [M:FASR]CCLRVAFLG <> G_OUI )
      # "Il faut passer par controler pour renseigner la valeur marché
      GERR=1 : GMESSAGE=mess(388,GML_MSGFAS,1) : FIN=0
    Endif
  Endif
Return
#=====================================================================
$OK                      # (Massif interactif et unitaire)
  Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$ABA                     # (unitaire)

  # Réinitialisation de l'écran des paramètres
  If ( ACTTYPGES=GTAMUNI )
    If ( dim(GPARMPLN)>0 & GPARMPLN > 0 )
      [M:FASR]DPRPLN=GPARMPLN : Affzo [M:FASR]DPRPLN : Diszo [M:FASR]DPRPLN
      Actzo [M:FASR]
      Effzo [M:FASR]
      Diszo [M:FASR]
    Else
      Actzo [M:FASR]
      If ( [M:FASR]CCLRVAFLG = G_OUI)   : Diszo [M:FASR]CCLRVAFLG : Endif
      Effzo [M:FASR]
    Endif
  Endif

  [M:FASR]RVADEVFLG = G_OUI : Affzo [M:FASR]RVADEVFLG : Diszo [M:FASR]RVADEVFLG

  Gosub ACTION From =TRTMODACT

Return
#=====================================================================
$EXEC                    # (Massif intéractif et batch)
  Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$FIN                     # ()

 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$TERMINE                 # ()

  Gosub ACTION From =TRTMODACT

  #==> Suppression des globales nécessaires à la fonction
  If dim(GCNX)     >0        : Kill GCNX           : Endif
  If dim(GCPY)     >0        : Kill GCPY           : Endif
  If dim(GNBVO)    >0        : Kill GNBVO          : Endif
  If dim(GNBVTO)   >0        : Kill GNBVTO         : Endif
  If dim(GPARMPLN) >0        : Kill GPARMPLN       : Endif
  If dim(GLOK)     >0        : Kill GLOK           : Endif
  If dim(PARAM(6)) >0        : Raz PARAM(6)        : Endif
  If dim(GINDCURPER) >0      : Kill GINDCURPER     : Endif

  If dim(G_RVATYP)   >0      : Kill G_RVATYP     : Endif
  If dim(G_RVACOE)   >0      : Kill G_RVACOE     : Endif
  If dim(G_RVACOEREF)>0      : Kill G_RVACOEREF  : Endif
  If dim(G_NSPVAL)   >0      : Kill G_NSPVAL     : Endif
  If dim(G_RVAAPR)   >0      : Kill G_RVAAPR     : Endif
  If dim(G_CCLRVA)   >0      : Kill G_CCLRVA     : Endif
  If dim(GRVADEVCHG) >0      : Kill GRVADEVCHG   : Endif   #Fq-64311
  If dim(GRVADERRVE) >0      : Kill GRVADERRVE   : Endif   #Fq-67995
  If dim(G_RVALIB) >0        : Kill G_RVALIB     : Endif   #Fq-67995
  If dim(GDPMO_F) >0         : Kill GDPMO_F      : Endif   #Fq-67995
  If dim(GDPMO_M) >0         : Kill GDPMO_M      : Endif   #Fq-67995
  If dim(GCUMFLGO_F) >0      : Kill GCUMFLGO_F   : Endif   #Fq-67995
  If dim(GNBVO_C) >0         : Kill GNBVO_C      : Endif   #Fq-67995
  If dim(GNBVO_F) >0         : Kill GNBVO_F      : Endif   #Fq-67995
  If dim(GNBVO_M) >0         : Kill GNBVO_M      : Endif   #Fq-67995
  If dim(GDPED) >0           : Kill GDPED       : Endif    #Fq-79819


Return
#=====================================================================
$SORTIE
  Gosub ACTION From =TRTMODACT
Return
######################################################################
######################################################################
# Points d'entrée de l'action métier communs unitaire / massif
######################################################################
######################################################################
$ACTMET
  Case ACTMET

    When "AM_FLGCPY"       : Gosub AM_FLGCPY        # M  - En cas de changement de société

    When "CRITMEN"         : Gosub CRITMEN          # U  - Activation menu ou bouton
    When "SET_PRECHARGE"   : Gosub SET_PRECHARGE    # U  - A positionner à G_OUI s'il n'y a pas de bouton sélectionner
    When "SET_CRITACT"     : Gosub SET_CRITACT      # UM - CRITACT critère de sélection particulier à l'action métier
    When "SET_TRACE_NAME"  : Gosub SET_TRACE_NAME   # M  - Alimentation de TRACE_NAME : titre de la trace
    When "FILL_HEA"        : Gosub FILL_HEA         # U  - Alimentation partie spécifique en-tête

    # SP/locker
    When "OUVR_LOCK"       : Gosub OUVR_LOCK        # UM - Ouverture de tables annexes pour les lock
    When "MAS1_CONTROLE"   : Gosub MAS1_CONTROLE    # M  - Exclusion élément de la population à sélectionner
    When "MAS1_LOCK_AUTRE" : Gosub MAS1_LOCK_AUTRE  # UM - Lock objet lié à l'enr en ligne de la population

    # SP/charger
    When "OUVR_ALIM_TMP1"  : Gosub OUVR_ALIM_TMP1   # UM - Ouverture de tables annexes pour l'alim des table tmp.
    When "MAS1_ALIM_TMP1"  : Gosub MAS1_ALIM_TMP1   # UM - Transfert zones tables de données -> tables tempo

    # SP/applique_temp
    When "OUVR_APPL_TMP1"  : Gosub OUVR_APPL_TMP1   # UM - Ouverture de tables annexes
    When "TMP1_APPL_TMP1"  : Gosub TMP1_APPL_TMP1   # UM - Application des paramètres de l'action aux enr de la table temporaire principale

    # SP/report_mask Report objet principal dans les masques (unitaire uniquement)
    When "TMP1_ALIM_MASK"  : Gosub TMP1_ALIM_MASK   # U  - Tansfert table temporaire principale -> masques de l'écran
    When "REAF_ALIM_MASK"  : Gosub REAF_ALIM_MASK   # U  - Tansfert tables temporaires -> masques de l'écran (pour réaffichage)

    # SP/applique_dirt Mise à jour directe (massif uniquement)
    When "OUVR_APPL_DIRT"  : Gosub OUVR_APPL_DIRT   # M  - Ouverture de tables annexes pour la maj directe en massif
    When "MAS1_APPL_DIRT"  : Gosub MAS1_APPL_DIRT   # M  - Mise à jour directe des tables de données avec les paramètres de l'action

    # SP/reporter
    When "OUVR_ALIM_TABLE" : Gosub OUVR_ALIM_TABLE  # UM - Ouverture tables annexes avant report tables tempo -> tables de données
    When "TMP1_ALIM_TABLE" : Gosub TMP1_ALIM_TABLE  # UM - Report table temporaire principale -> table de données

  When Default
 Endcase

Return
#=====================================================================
# Massif : remise du masque à blanc dans le cas d'un changement de société
$AM_FLGCPY

  Effzo [M:FASR]
  [M:FASR]RVATYP = 0
  Affzo [M:FASR]

  [M:FASR]RVADEVFLG = G_OUI
  Affzo [M:FASR]RVADEVFLG
  Diszo [M:FASR]RVADEVFLG


Return
#=====================================================================
# Unitaire : critère désactivation / activation menu CRITMEN
$CRITMEN
  Local Integer ACCFCY
  Local Char AUZFCY (15)

  # Accès selon droit à l'option
  Call DROITSITE ( [M:FAS0]FCY, [L]AUZFCY, [L]ACCFCY ) From SUPCPT
  If ( not [L]ACCFCY or not instr(1, [L]AUZFCY, 'V') )
    CRITMEN = "1=0"
  Else
    CRITMEN = "1=1"
  Endif

Return
#=====================================================================
# Unitaire : Modif de la variable déclenchant le préchargement en unitaire PRECHARGE
$SET_PRECHARGE
  PRECHARGE=G_NON
Return
#=====================================================================
# Massif : Alimentation / modification de la variable TRACE_NAME
$SET_TRACE_NAME
# Réévaluation  :  Traitement Massif
  TRACE_NAME=mess(373,GML_MSGFAS,1)
Return
#=====================================================================
# Unitaire : Modif de la variable déclenchant le préchargement en unitaire CRITACT
$SET_CRITACT

  # Les biens "modèles" "annulés
  # les biens de natures "En cours"
  # les biens classés pour vente
  # ou ceux ayant fait l'objet d'une sortie "réelle" sont exclus de la sélection
  # ainsi que les biens de nature immo encours

  #FQ54343-Gestion des concessions
  CRITACT  = "OWNTYP<>GVML_TDMODEL&OWNTYP<>GVML_TDANNUL&OWNTYP<>GVML_TDCONCE&"
  CRITACT += "SALCLSDAT = [0/0/0] and " : # FQ95754_3
  CRITACT += "(ISSDAT=[0/0/0] or EXTISSFLG=G_OUI) and "
  CRITACT += "(GACACN <> GVML_NIENCOU or IASACN <> GVML_NIENCOU)"

Return
#=====================================================================
# Unitaire : Permet d'alimenter des zones spécifiques de l'en-tête de la fenêtre
$FILL_HEA
Return
#=====================================================================
# Unitaire et massif : Pour ouvrir des tables utilisées par MAS1_CONTROLE et MAS1_LOCK_AUTRE
$OUVR_LOCK
  # Ouverture de tables liées à explorer ou à mettre à jour  par l'action massive
  Gosub OUVRE_TABLES
Return
#=====================================================================
# Unitaire / massif : contrôle élément pour retrait de la population
$MAS1_CONTROLE

  # Lecture pour contrôle et exclusion eventuelle
  Read [DEP]DEP0 =[F:MAS1]AASREF;[M:FASR]DPRPLN;[M:FASR]FIYENDDAT;[M:FASR]PERENDDAT

  #-1 ----------------------
  If ( ACTTYPGES=GTAMMAS & [M:FASR]CCLRVAFLG <> G_OUI )
    # Pas de réévaluation possible dans les cas ci-dessous
    #=======================================
    If ([F:DEP]STRDPRDAT > [M:FASR]PERENDDAT)
     # Si la Date de début d'amortissement supérieure à la date de fin période/exercice en cours
     GOK=0 : Return
    Endif
    #=======================================
    # Si le bien a déjà fait l'objet d'une réévaluation
    #FQ-64311  If ( [F:DEP]RVAAMT > 0 )
    If ( [F:DEP]RVAAMT <> 0 )
     GOK=0 : Return
    Endif
    #=======================================
    # Si le bien possède du différé
    If ( [F:DEP]DFDBLC <> 0 or [F:DEP]DFD <> 0 or [F:DEP]DFDRVE <> 0 )
     GOK=0 : Return
    Endif
    #=======================================
    # Si le bien a une base d'amortissement négative
    If ( [F:DEP]BSEVAL < 0 )    #Fq-65178
      GOK=0 : Return
    Endif
    #=======================================
    # Si le bien a été déprécié dans la période
    If ( [F:DEP]IML <> 0 or [F:DEP]IMLRVE <> 0 )
     GOK=0 : Return
    Endif
    #=======================================
    # Si le bien a un plafond de reprise
    If ( [F:DEP]IMLRVELIM <> 0 )
     GOK=0 : Return
    Endif
    #=======================================
    # S'il s'agit d'une réévaluation avec prise d'effet "Début Exe." et chgt de méth. réalisée dans l'exercice
    If ([F:DEP]PERSTRDAT <> [F:DEP]FIYSTRDAT and [M:FASR]RVATIADAT = GVML_ERDBEX and
&     func TRTFASRVA.EXISTE_MTC ([F:MAS1]AASREF, [F:DEP]DPRPLN, [F:DEP]FIYSTRDAT, [F:DEP]PERENDDAT) )
        # "Réévaluation début exercice impossible si changement de méthode dans l'exercice"
     GOK=0 : Return
    Endif
    #=======================================
    #Fq67577-Pologne-Modernisation en cours.
    If G_ACTKPL=G_OUI & [M:FPC]LEG="POL" & [F:DEP]KMDRDEV<>0
     GOK=0 : Return
    Endif
    #Fin-Pologne
    #=======================================
    #*Fq-79819 le bien doit être recalculé avant réévaluation fin exercice
    If  [M:FASR]RVATIADAT = GVML_ERENDEX and [F:MAS1]FLGCNXCLC([F:DEP]CNX-1) = G_OUI
       GOK=0 : Return
    Endif
    #=======================================
  Endif
  #-1 ----------------------
  # Pas d'annulation de réévaluation dans les cas ci-dessous
  If ( ACTTYPGES=GTAMMAS & [M:FASR]CCLRVAFLG = G_OUI )
    # Si le bien n'a pas fait l'objet d'une réévaluation
    If ( [F:DEP]RVAAMT = 0 )
     GOK=0 : Return
    Endif
  Endif
  #Fq-79741 Dans tous les cas : si la rééval. est basée sur la table des coeff. on ne réévalue pas un bien qui n'a pas de paramétrage prévu
  # dans la table des coeff. de rééval.
  If [M:FASR]RVACOEREF   <> ""
     Local Integer RET
     RET = func TRTFASRVA.RVACOEF([M:FASR]RVACOEREF,[F:MAS1]PURDAT,[F:MAS1]AASIPTDAT,[F:MAS1]ITSDAT,[F:MAS1]ACGGRP,[F:MAS1]ACCCOD,[M:FASR]PERSTRDAT)
     If RET = 1
        GOK=0 : Return
     Endif
  Endif

Return
#=====================================================================
# Unitaire / massif : Lock d'objet lié à l'enregistrement en ligne
#                     Alimenter RMES si un message soit apparaître
$MAS1_LOCK_AUTRE
Return
#=====================================================================
# Unitaire / massif : Sert à ouvrir des tables utilisées dans MAS1_ALIM_TMP1
$OUVR_ALIM_TMP1
  # Ouverture de tables liées à explorer ou à mettre à jour  par l'action massive
  Gosub OUVRE_TABLES
Return
#=====================================================================
$OUVRE_TABLES

  # Ouverture de tables liées à explorer ou à mettre à jour  par l'action massive
  If !(clalev([F:MAS2]))  : Local File FXDASSETS  [MAS2]  : Endif  # Pour les Composants
  If !(clalev([F:CNX]))   : Local File CONTEXT    [CNX]   : Endif  # les contextes
  If !(clalev([F:FIS]))   : Local File FISCYEAR   [FIS]   : Endif  # les exercices
  If !(clalev([F:DEP]))   : Local File DEPREC     [DEP]   : Endif  # les plans d'amortissement

  If !(clalev([F:DEPF]))  : Local File DEPREC     [DEPF]  : Endif  # Plan Fiscal pour rééval. Libre
  If !(clalev([F:DEPM]))  : Local File DEPREC     [DEPM]  : Endif  # Plan Minimum pour rééval. Libre
  If !(clalev([F:DEPW]))  : Local File DEPREC     [DEPW]  : Endif  #  "         "
  If !(clalev([F:DEPX]))  : Local File DEPREC     [DEPX]  : Endif  #  "         "
  If !(clalev([F:DEPO]))  : Local File DEPREC     [DEPO]  : Endif  #  "         "
  If !(clalev([F:DEPP]))  : Local File DEPREC     [DEPP]  : Endif  # exercice/période précédente
  If !(clalev([F:DEPC]))  : Local File DEPREC     [DEPC]  : Endif
  If !(clalev([F:COH]))   : Local File RVACOEH    [COH]   : Endif  # tables des coeff (entête)
  If !(clalev([F:COD]))   : Local File RVACOED    [COD]   : Endif  # tables des coeff (détail)
  If !(clalev([F:EFS]))   : Local File EFASREEVAL [EFS]   : Endif  # tables des événements
  # FQ104164
  If !(clalev([F:DEPFO]))  : Local File DEPREC     [DEPFO]  : Endif  # Plan Fiscal avant modif pour rééval. Libre
  If !(clalev([F:DEPMO]))  : Local File DEPREC     [DEPMO]  : Endif  # Plan Minimum avant modif pour rééval. Libre

Return
#=====================================================================
# Unitaire / massif : Chargement de la population en table temporaire
#                     Etiquette appelée par le s/p CHARGER
#                     Si une erreur se produit dans cette étiquette
#                     Alimenter RMES avec le message qui doit apparaître
#                     dans une boîte en unitaire ou en massif
$MAS1_ALIM_TMP1
Local Integer OK, LFLGOK
Local Decimal COEFF

  #**************************
  Raz [F:TMP1]
  Raz [F:TMPC]    #FQ-85936

  # Chargement table temporaire TMPPLNFAS [F:TMP1] avec infos du plan  d'amort [F:DEP]
  [F:TMP1]FLGERR = G_NON
  [F:TMP1]FLGMOD = G_OUI
  [F:TMP1]MSGERR    = ""

  Raz GNBVO_C
  Raz GNBVTO

  # Date période exercice précédent pour récupérer la VNC début de période "courante"
  Local Integer RCONTX
  Call GET_CNX_FROM_PLAN ([F:MAS1]AASREF,[M:FASR]DPRPLN, RCONTX) From GLOBIENS
  Local Date    RCNXDAT(1..5)
  Local Integer RCRET
  Call GET_CNX_DAT([F:MAS1]CPY,RCONTX,RCNXDAT,RCRET) From GLOBIENS

  # Lecture DEPREC pour l'exercice et la période courante
  Filter [DEP] Where(AASREF=[F:MAS1]AASREF & DPRPLN=[M:FASR]DPRPLN & FIYENDDAT=[M:FASR]FIYENDDAT
&            & PERENDDAT=[M:FASR]PERENDDAT )
  Read[DEP] First
  #-1 --------------------
  If ( fstat <> 0 )
    If ( fstat <> 4 )
      [F:TMP1]FLGERR = G_OUI
      [F:TMP1]FLGMOD = G_NON
      # "ERREUR entrée/sortie ==> Fichier"
      RMES=mess(104,GML_MSGFAS,1)-num$([F:MAS1]AASREF)+"/"+num$([F:DEP]DPRPLN)
      GOK=0 : Return
    Endif
  #-1 --------------------
  Else
    # VNC début période "courante" à partir de l'exercice précédent
    # à défaut la VNC début de périodes est égale à la base d'amortissement
    [F:DEPC] = [F:DEP]
    If [M:FASR]RVATIADAT <> GVML_ERENDEX
       #Fq-79819  If ( [M:FASR]RVATIADAT = GVML_ERDBEX and [M:FASR]RVATYP <> GVML_MODVMA )  or ( G_RVALIB = G_OUI )
       If ( [M:FASR]RVATIADAT = GVML_ERDBEX )  or ( G_RVALIB = G_OUI )
          Call CAL_VALEUR_NETTE ( "RDE", [F:DEPC]DPRBAS, 2, 0, GNBVO_C  ) From GLOBB4
          Call CAL_VALEUR_NETTE ( "TDE", [F:DEPC]DPRBAS, 2, 0, GNBVTO ) From GLOBB4
       Else
          #Fq-79819If ( G_RVALIB <> G_OUI )
          If ( G_RVALIB <> G_OUI )
             Call CAL_VALEUR_NETTE ( "RDP", [F:DEPC]DPRBAS, 2, 0, GNBVO_C  ) From GLOBB4
             Call CAL_VALEUR_NETTE ( "TDP", [F:DEPC]DPRBAS, 2, 0, GNBVTO ) From GLOBB4
          Endif
       Endif
     Else   #Fq-79819 si date prise d'effet= fin exercice
        GNBVO_C = [F:DEPC]NBV
        GNBVTO  = [F:DEPC]NBVT
     Endif
   #=====================
   # -----------------------------------------------------------
   # Informations du plan (par transclasse) [F:TMP1]  = [F:DEP]
   # ------------------
    Gosub ALIM_TMP1  From TRTFASRVA
    # ------------------
    Write [TMP1]
    #- 2 ------------------
    If ( fstat <> 0 )
      Case fstat
        When 1
          # Erreur entrée sortie.
          RMES="La table TMPMASFAS est verrouillée."
          GOK=-1
        When 3
          # Tentative d'écriture en double
          RMES=mess(129,GML_MSGFAS,1)+[F:TMP1]TRTNUM+"/"+[F:TMP1]OBJREF+"/"+[F:TMP1]DPRPLN
          GOK=0
        When Default
      Endcase
      Return
    Else
      NBTMP+=1
    Endif
    #- 2 ------------------


     #FQ-85936
     [F:TMPC]        = [F:MAS1]
     # Chargement table temporaire TMPMASFA2 [F:TMPC] avec infos complémentaires du bien comptable [F:MAS1]
     [F:TMPC]TRTNUM     = NUMACT
     [F:TMPC]OBJREF     = [F:MAS1]AASREF
     [F:TMPC]OBJREFO    = [F:MAS1]AASREF
     Gosub ALIM_TMPC  From TRTFASRVA
     Write [TMPC]
     If (fstat) Then
      Case fstat
        When 1
          # Erreur technique - Entrée sortie.
          RMES=mess(104,403,1)-"TMPMASFA2"-mess(105,403,1)-"05"-mess(106,403,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF
          GOK=-1
        When 3
          # Erreur technique - Tentative d'écriture en double
          RMES=mess(129,403,1)-num$(NUMACT)+"/"+[F:TMPC]OBJREF
          GOK=0
        When Default
      Endcase
      Return
     Endif


  Endif
  #-1 --------------------
  Filter [DEP]

Return
#----------------------------------------------------
$ALIM_TMP1
#====================================================
# Chargement table temporaire TMPMASFAS [F:TMP1]
# avec infos du bien comptable [F:MAS1]
# et du plan d'amortissement traité [F:DEP]
#====================================================
  [F:TMP1]DPRPLN       = [F:DEP]DPRPLN
  [F:TMP1]DPM          = [F:DEP]DPM
  [F:TMP1]DPMO         = [F:DEP]DPM
  [F:TMP1]DPMT         = [F:DEP]DPM
  [F:TMP1]FIYENDDAT    = [F:DEP]FIYENDDAT
  [F:TMP1]PERENDDAT    = [F:DEP]PERENDDAT
  [F:TMP1]STRDPRDAT    = [F:DEP]STRDPRDAT
  [F:TMP1]BSEVAL       = [F:DEP]BSEVAL
  [F:TMP1]EXERVADEV    = [F:DEP]EXERVADEV
  [F:TMP1]PERRVADEV    = [F:DEP]PERRVADEV
  If (ACTTYPGES=GTAMUNI)
    [F:TMP1]NSPVAL     = [M:FASR]NSPVAL
    [F:TMP1]NSPVALO    = [M:FASR]NSPVAL
    [F:TMP1]RVACOE     = [M:FASR]RVACOE
  Else
    [F:TMP1]NSPVAL     = [F:DEP]NSPVAL
    [F:TMP1]NSPVALO    = [F:DEP]NSPVAL
    [F:TMP1]RVACOE     = [F:DEP]RVACOE
  Endif
  [F:TMP1]RVACOEREF  = [M:FASR]RVACOEREF
  [F:TMP1]DPRBAS     = [F:DEP]DPRBAS
  [F:TMP1]DPRBASO    = [F:DEP]DPRBAS
  [F:TMP1]IML        = [F:DEP]IML
  [F:TMP1]EXETRFCUM  = [F:DEP]EXETRFCUM
  [F:TMP1]EXEIMLCUM  = [F:DEP]EXEIMLCUM
  [F:TMP1]PERIMLCUM  = [F:DEP]PERIMLCUM
  [F:TMP1]EXETRFCUMO = [F:DEP]EXETRFCUM
  [F:TMP1]EXEIMLCUMO = [F:DEP]EXEIMLCUM
  [F:TMP1]PERIMLCUMO = [F:DEP]PERIMLCUM
  [F:TMP1]IMLRVE     = [F:DEP]IMLRVE
  [F:TMP1]EXERVECUM  = [F:DEP]EXERVECUM
  [F:TMP1]PERRVECUM  = [F:DEP]PERRVECUM
  [F:TMP1]EXERVECUMO = [F:DEP]EXERVECUM
  [F:TMP1]PERRVECUMO = [F:DEP]PERRVECUM
  [F:TMP1]IMLRVELIM  = [F:DEP]IMLRVELIM
  [F:TMP1]RVAAMT     = [F:DEP]RVAAMT
  [F:TMP1]RVAAMTO    = [F:DEP]RVAAMT
  # ------------------------
  # Informations spécifiques
  # ------------------------
  [F:TMP1]TRTNUM     = NUMACT
  [F:TMP1]OBJREF     = [F:MAS1]AASREF
  [F:TMP1]PERCLOCUM  = [F:DEP]PERCLOCUM
  [F:TMP1]PERCLOCUMO = [F:DEP]PERCLOCUM
  [F:TMP1]PERCLOEXC  = [F:DEP]PERCLOEXC
  [F:TMP1]PERCLOEXCO = [F:DEP]PERCLOEXC
  [F:TMP1]DPRCUM     = [F:DEP]DPRCUM
  [F:TMP1]DPRCUMO    = [F:DEP]DPRCUM
  [F:TMP1]DPRCUMFLG  = [F:DEP]DPRCUMFLG
  [F:TMP1]NBVO       = GNBVO_C
  [F:TMP1]NBVTO      = GNBVTO
  [F:TMP1]IMLBLC     = [F:DEP]IMLBLC + ([F:DEP]IML - [F:DEP]IMLRVE)
  [F:TMP1]IMLBLCO    = [F:DEP]IMLBLC + ([F:DEP]IML - [F:DEP]IMLRVE)
  [F:TMP1]RVATIADAT  = [M:FASR]RVATIADAT
  If ( [M:FASR]RVATIADAT = GVML_ERDBEX )
    [F:TMP1]PERREFCLC  = [F:DEP]FIYSTRDAT
    [F:TMP1]PERREFCLCT = [F:DEP]FIYSTRDAT
    #*Fq-85936   Elsif ( [M:FASR]RVATIADAT = GVML_ERENDEX and [M:FASR]RVATYP = GVML_MODCOE) Then
    #*Fq-85936     # FQ85936 la logique voudrait que l'on pré-alimente ces deux champs avec les valeurs de Deprec  mais ....
    #*Fq-85936     ==> MWA : pas besoin de toucher à ces champs en rééval. fin exercice
    #*Fq-85936     [F:TMP1]PERREFCLC  = [F:DEP]PERREFCLC
    #*Fq-85936     [F:TMP1]PERREFCLCT = [F:DEP]PERREFCLCT
  Else
    If  ( [M:FASR]RVATIADAT <> GVML_ERENDEX ) #Fq-79819
       [F:TMP1]PERREFCLC  = [F:DEP]PERSTRDAT
       [F:TMP1]PERREFCLCT = [F:DEP]PERSTRDAT
    Endif
  Endif
  [F:TMP1]RVADAT     = [M:FASR]RVADAT
  [F:TMP1]RVATYP     = [M:FASR]RVATYP
  [F:TMP1]IASCUR     = [M:FASR]CUR
  [F:TMP1]PERCLOCUMT = [F:DEP]PERCLOCUMT
  [F:TMP1]PERCLOCUTO = [F:DEP]PERCLOCUMT
  [F:TMP1]PERCLOEXCT = [F:DEP]PERCLOEXCT
  [F:TMP1]PERCLOEXTO = [F:DEP]PERCLOEXCT
  [F:TMP1]EXECLOCUMT = [F:DEP]EXECLOCUMT
  [F:TMP1]EXECLOCUTO = [F:DEP]EXECLOCUMT
  GDPEO              = [F:DEP]PERENDDPE   #Fq-79819
  If G_RVALIB = G_OUI #
    Gosub ALIM_TMP1_LIB From TRTFASRVALIB  #Fq-67995
  Endif
  #-1 --------------------------------
  If ([M:FASR]CCLRVAFLG <> G_OUI )
    # <<< Réévaluation >>>
    #-2 --------------------------------
    If (ACTTYPGES=GTAMUNI)
      [F:TMP1]RVACOE     = [M:FASR]RVACOE
    #-2 --------------------------------
    Else
      If ([F:TMP1]FLGERR <> G_OUI )
        If ([M:FASR]RVACOEREF <> "")
          Call RECH_RVACOE([M:FASR]RVACOEREF, COEFF)
          [F:TMP1]RVACOE     = COEFF
          [F:TMP1]RVACOEREF  = [M:FASR]RVACOEREF
        Else
          [F:TMP1]RVACOE     = [M:FASR]RVACOE
          [F:TMP1]RVACOEREF  = ""
        Endif
      Else
        [F:TMP1]RVACOE = 1
        [F:TMP1]RVACOEREF = ""
      Endif
    Endif
    #-2 --------------------------------
    #Fq-64311  If ([M:FASR]RVATYP <> GVML_MODVMA and [F:TMP1]RVACOE <= 1)
    If ([M:FASR]RVATYP <> GVML_MODVMA and [F:TMP1]RVACOE = 1)
      # Coefficient invalide
      [F:TMP1]FLGERR   = G_OUI
      [F:TMP1]FLGMOD   = G_OUI
      [F:TMP1]RVACOE   = 1
      [F:TMP1]RVACOEREF = ""
      #Fq-79741 [F:TMP1]MSGERR   = mess(107,GML_MSGFAS,1)
      [F:TMP1]MSGERR   = mess(173,GML_MSGFAS,1)
    Elsif ([M:FASR]RVATYP = GVML_MODVMA and [F:TMP1]NSPVAL = 0)
      # Valeur Marché invalide
      [F:TMP1]FLGERR   = G_OUI
      [F:TMP1]FLGMOD   = G_OUI
      [F:TMP1]RVACOE   = 1
      [F:TMP1]RVACOEREF = ""
      [F:TMP1]MSGERR   = mess(395,GML_MSGFAS,1)
    Endif
  #-1 --------------------------------
  Else
    # <<< Annulation de réévaluation >>>
    [F:TMP1]RVACOE = 1
  Endif
  #-1 --------------------------------
  #=====================================================================================
  # Chargement table temporaire TMPFASMAS [F:TMP1] avec infos du bien comptable [F:MAS1]
  #=====================================================================================
  [F:TMP1]TRTNUM     = NUMACT
  [F:TMP1]OBJREF     = [F:MAS1]AASREF
  [F:TMP1]AASDES1    = [F:MAS1]AASDES1
  [F:TMP1]CPY        = [F:MAS1]CPY
  [F:TMP1]ACCCOD     = [F:MAS1]ACCCOD
  [F:TMP1]ACGGRP     = [F:MAS1]ACGGRP
  [F:TMP1]PURDAT     = [F:MAS1]PURDAT
  [F:TMP1]ITSDAT     = [F:MAS1]ITSDAT
  [F:TMP1]AASIPTDAT  = [F:MAS1]AASIPTDAT

Return

$ALIM_TMPC
#====================================================
# Chargement table temporaire TMPMASFA2 [F:TMPC]
# avec infos du bien comptable [F:MAS1]
# et du plan d'amortissement traité [F:DEP]
#====================================================
  [F:TMPC]PERENDDPE    = [F:DEP]PERENDDPE
  [F:TMPC]EXCCUM       = [F:DEP]EXCCUM
  [F:TMPC]PEREXCDPR    = [F:DEP]PEREXCDPR
  [F:TMPC]DPET         = [F:DEP]DPET
  [F:TMPC]EXCCUMT      = [F:DEP]EXCCUMT
  [F:TMPC]PEREXCDPRT   = [F:DEP]PEREXCDPRT
  [F:TMPC]PERTRFCUM    = [F:DEP]PERTRFCUM
  [F:TMPC]IMLRVETRF    = [F:DEP]IMLRVETRF
Return

#=====================================================================
# Unitaire / massif : Ouverture de tables annexes
$OUVR_APPL_TMP1

  # Ouverture de tables liées à explorer ou à mettre à jour  par l'action massive
  If !(clalev([F:MAS1]))   : Local File FXDASSETS   [MAS1]   : Endif

Return
#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire annexe (par plan)
$TMP1_APPL_TMP1
Local Char RVAMOD
Local Integer I_PLN

#Infbox "TRTFASRVA - TMP1_APPL_TMP1"

  If ( [M:FASR]CCLRVAFLG = G_OUI )
    Raz[F:TMP1]RVAAPR  : Raz [F:TMP1]RVACMT
    If ( dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS )   : ACTMODIF=1 : Endif
  Else
    If ( [M:FASR]RVAAPR <> "" )
      [F:TMP1]RVAAPR=[M:FASR]RVAAPR
    If ( dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS )   : ACTMODIF=1 : Endif
    Endif
    If ( [M:FASR]RVACMT <> "" )
      [F:TMP1]RVACMT =[M:FASR]RVACMT
    If ( dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS )   : ACTMODIF=1 : Endif
    Endif
  Endif
  If ( [M:FASR]CCLRVAFLG <> G_OUI )
    Case  [M:FASR]RVATYP
      When GVML_MODIND  :  RVAMOD = "IND"
      When GVML_MODCOE  :  RVAMOD = "COE"
      When GVML_MODVMA  :  RVAMOD = "VMA"
      When Default
    Endcase
    Call APPLIQUE_REEVAL("[F:TMP1]",RVAMOD, 0, 0) From TRTFASRVA

    Call GET_MNT_ARRONDI ([F:TMP1]DPRBAS,     [M:FASR]CUR, [F:TMP1]DPRBAS)      From GLOBIENS
    Call GET_MNT_ARRONDI ([F:TMP1]PERCLOCUM,  [M:FASR]CUR, [F:TMP1]PERCLOCUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([F:TMP1]PERCLOEXC,  [M:FASR]CUR, [F:TMP1]PERCLOEXC)   From GLOBIENS
    Call GET_MNT_ARRONDI ([F:TMP1]DPRCUM,     [M:FASR]CUR, [F:TMP1]DPRCUM)      From GLOBIENS
    Call GET_MNT_ARRONDI ([F:TMP1]EXETRFCUM,  [M:FASR]CUR, [F:TMP1]EXETRFCUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([F:TMP1]EXEIMLCUM,  [M:FASR]CUR, [F:TMP1]EXEIMLCUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([F:TMP1]PERIMLCUM,  [M:FASR]CUR, [F:TMP1]PERIMLCUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([F:TMP1]EXERVECUM,  [M:FASR]CUR, [F:TMP1]EXERVECUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([F:TMP1]PERRVECUM,  [M:FASR]CUR, [F:TMP1]PERRVECUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([F:TMP1]IMLBLC,     [M:FASR]CUR, [F:TMP1]IMLBLC)      From GLOBIENS
    Call GET_MNT_ARRONDI ([F:TMP1]NBV,        [M:FASR]CUR, [F:TMP1]NBV)         From GLOBIENS
    Call GET_MNT_ARRONDI ([F:TMP1]NBVT,       [M:FASR]CUR, [F:TMP1]NBVT)        From GLOBIENS
    Call GET_MNT_ARRONDI ([F:TMP1]PERCLOCUMT, [M:FASR]CUR, [F:TMP1]PERCLOCUMT)  From GLOBIENS
    Call GET_MNT_ARRONDI ([F:TMP1]PERCLOEXCT, [M:FASR]CUR, [F:TMP1]PERCLOEXCT)  From GLOBIENS
    Call GET_MNT_ARRONDI ([F:TMP1]EXECLOCUMT, [M:FASR]CUR, [F:TMP1]EXECLOCUMT)  From GLOBIENS

  Else
    Gosub ANNU_REEVAL
  Endif


Return
#====================================================
#
$ANNU_REEVAL
Local Char LREF
Local Char LCDINT
Local Date LRVADAT

  If ( ACTTYPGES = GTAMUNI )
    LREF=[M:FAS0]AASREF
    Filter [DEP] Where (AASREF=[M:FAS0]AASREF & DPRPLN = [M:FASR]DPRPLN)
    Read [DEP]DEP0 =[M:FAS0]AASREF;[M:FASR]DPRPLN;[M:FASR]FIYENDDAT;[M:FASR]PERENDDAT
  Else
    LREF=[F:TMP1]OBJREF
    Filter [DEP] Where (AASREF=[F:TMP1]OBJREF & DPRPLN = [M:FASR]DPRPLN)
    Read [DEP]DEP0 =[F:TMP1]OBJREF;[M:FASR]DPRPLN;[M:FASR]FIYENDDAT;[M:FASR]PERENDDAT
  Endif
  #-1 ------------------------
  If !(fstat)
    If [F:DEP]RVATIADAT <> GVML_ERENDEX #Fq-79819
      [F:TMP1]BSEVAL  = [F:DEP]BSEVAL
      # lecture événement de réévaluation pour récupérer
      # les anciennes valeurs du  bien (celle d'avant réévaluation)
      Filter [EFS] Where ( REF=LREF & DPRPLN= [M:FASR]DPRPLN )
      Read [EFS]Last
      If !(fstat)
        [F:TMP1]DPM         = [F:EFS]DPM
        [F:TMP1]DPMT        = [F:EFS]DPM
        [F:TMP1]DPRBAS      = [F:EFS]DPRBASO
        [F:TMP1]DPRCUM      = [F:EFS]DPRCUMO
        [F:TMP1]DPRCUMFLG   = [F:EFS]DPRCUMFLGO
        [F:TMP1]PERCLOCUM   = [F:EFS]PERCLOCUMO
        [F:TMP1]PERCLOEXC   = [F:EFS]PERCLOEXCO
        #*FQ-87640 [F:TMP1]EXECLOCUMT  = [F:EFS]EXECLOCUMT
        [F:TMP1]EXECLOCUMT  = [F:EFS]EXECLOCUMO
        #FQ-87640 [F:TMP1]PERCLOCUMT  = [F:EFS]PERCLOCUMT
        [F:TMP1]PERCLOCUMT  = [F:EFS]PERCLOCUMO
        #FQ-87640 [F:TMP1]PERCLOEXCT  = [F:EFS]PERCLOEXCT
        [F:TMP1]PERCLOEXCT  = [F:EFS]PERCLOEXCO
        [F:TMP1]PERREFCLC   = [F:EFS]PERREFCLC
        [F:TMP1]PERREFCLCT  = [F:EFS]PERREFCLCT
        GNBVO_C             = [F:EFS]NBVO
        [F:TMP1]NBV         = [F:EFS]NBVO
        [F:TMP1]NBVO        = [F:EFS]NBVO
        [F:TMP1]NBVT        = [F:EFS]DPRBASO - [F:EFS]EXECLOCUMT
        [F:TMP1]NBVTO       = [F:EFS]DPRBASO - [F:EFS]EXECLOCUMT
        [F:TMP1]EXETRFCUM   = [F:EFS]EXETRFCUMO
        [F:TMP1]EXEIMLCUM   = [F:EFS]EXEIMLCUMO
        [F:TMP1]PERIMLCUM   = [F:EFS]PERIMLCUMO
        [F:TMP1]EXERVECUM   = [F:EFS]EXERVECUMO
        [F:TMP1]PERRVECUM   = [F:EFS]PERRVECUMO
        [F:TMP1]IMLBLC      = [F:EFS]EXEIMLCUMO + [F:EFS]PERIMLCUMO
&                         - [F:EFS]EXERVECUMO - [F:EFS]PERRVECUMO -[F:EFS]EXETRFCUMO
        [F:TMP1]IMLRVELIM   = [F:EFS]IMLRVELIM
      Endif
      Filter [EFS]
    Endif #Fq-79819

#*Fq-85936 # FQ-85936
#*Fq-85936 # ==> MWA : pas besoin de toucher à ces champs en rééval. fin exercice
#*Fq-85936 If ([F:DEP]RVATYP = GVML_MODCOE and [F:DEP]RVATIADAT = GVML_ERENDEX ) Then
#*Fq-85936    [F:TMP1]PERREFCLC   = [F:EFS]PERREFCLC
#*Fq-85936    [F:TMP1]PERREFCLCT  = [F:EFS]PERREFCLCT
#*Fq-85936  Endif

    [F:TMP1]RVADAT        = [0/0/0]
    [F:TMP1]RVAAMT        = 0
    [F:TMP1]RVATIADAT     = 0
    [F:TMP1]RVATYP        = 0
    [F:TMP1]RVACOE        = 0
    [F:TMP1]RVACOEREF     = ""
  Endif
  #-1 ------------------------
  Filter [DEP]

Return
#====================================================
#
$ANNU_REEVAL_DIRT

  LCDINT= "FASRVA"+num$([M:FASR]DPRPLN)

  Filter [DEPO] Where (AASREF=[F:MAS1]AASREF & DPRPLN = [M:FASR]DPRPLN)
  Read [DEPO]DEP0 =[F:MAS1]AASREF;[M:FASR]DPRPLN;[M:FASR]FIYENDDAT;[M:FASR]PERENDDAT
  #-1 ---------------------------
  If !(fstat)
    If [F:DEP]RVATIADAT <> GVML_ERENDEX #Fq-79819
      LRVADAT = [F:DEPO]RVADAT
      [F:DEPW]BSEVAL = [F:DEPO]BSEVAL
      # Ajout lecture événement de réévaluation pour récupérer
      # les anciennes valeurs du  bien (avant réévaluation)

      Filter [EFS] Where ( REF=[F:MAS1]AASREF and DPRPLN=[M:FASR]DPRPLN )
      Read [EFS]Last
      If !(fstat)
        [F:DEPW]DPM         = [F:EFS]DPM
        [F:DEPW]DPMT        = [F:EFS]DPM
        [F:DEPW]DPRBAS      = [F:EFS]DPRBASO
        [F:DEPW]DPRCUM      = [F:EFS]DPRCUMO
        [F:DEPW]DPRCUMFLG   = [F:EFS]DPRCUMFLGO
        [F:DEPW]PERCLOCUM   = [F:EFS]PERCLOCUMO
        [F:DEPW]PERCLOEXC   = [F:EFS]PERCLOEXCO
        #FQ-87640 [F:DEPW]EXECLOCUMT  = [F:EFS]EXECLOCUMT
        [F:DEPW]EXECLOCUMT  = [F:EFS]EXECLOCUMO
        #FQ-87640 [F:DEPW]PERCLOCUMT  = [F:EFS]PERCLOCUMT
        [F:DEPW]PERCLOCUMT  = [F:EFS]PERCLOCUMO
        #FQ-87640 [F:DEPW]PERCLOEXCT  = [F:EFS]PERCLOEXCT
        [F:DEPW]PERCLOEXCT  = [F:EFS]PERCLOEXCO
        GNBVO_C             = [F:EFS]NBVO
        [F:DEPW]NBV         = [F:EFS]NBVO
        [F:DEPW]NBVT        = [F:EFS]DPRBASO - [F:EFS]EXECLOCUMT
        GNBVTO              = [F:EFS]DPRBASO - [F:EFS]EXECLOCUMT
        [F:DEPW]EXETRFCUM   = [F:EFS]EXETRFCUMO
        [F:DEPW]EXEIMLCUM   = [F:EFS]EXEIMLCUMO
        [F:DEPW]PERIMLCUM   = [F:EFS]PERIMLCUMO
        [F:DEPW]EXERVECUM   = [F:EFS]EXERVECUMO
        [F:DEPW]PERRVECUM   = [F:EFS]PERRVECUMO
        [F:DEPW]IMLBLC      = [F:EFS]EXEIMLCUMO + [F:EFS]PERIMLCUMO
&                         - [F:EFS]EXERVECUMO - [F:EFS]PERRVECUMO - [F:EFS]EXETRFCUMO
        [F:DEPW]IMLRVELIM   = [F:EFS]IMLRVELIM
        [F:DEPW]RVACRB      = 0
      Endif
      Filter [EFS]
    Endif #Fq-79819
    [F:DEPW]RVADAT     = [0/0/0]
    [F:DEPW]RVAAMT     = 0
    [F:DEPW]RVATYP     = 0
    [F:DEPW]RVATIADAT     = 0
    [F:DEPW]RVACOE     = 0
    [F:DEPW]RVACOEREF  = ""
  Endif
  #-1 ---------------------------
  Filter [DEPO]

  LOK = G_OUI
  If ( FLGDET = G_OUI )
    Call SEP_COMPTE_RENDU([F:MAS1]CPY)
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO,[F:MAS1]AASREF+"/"+[F:MAS1]AASDES1,0,1) From TRACEABX3
    Gosub ECR_DETAIL_OLD
  Endif

Return
#=====================================================================
# Unitaire : Permet de reporter les infos de TMP1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TMP1_ALIM_MASK

  # Affectation des champs du bien comptable courant
  [M:FAS0]RVAAPR    = [F:TMP1]RVAAPR
  [M:FAS0]RVACMT    = [F:TMP1]RVACMT

  # Affectation des champs du plan  du bien courant
  I_PLN = find([F:TMP1]DPRPLN,[M:FAS3]DPRPLN)
  [M:FAS3]BSEVAL(I_PLN-1)       = [F:TMP1]BSEVAL
  [M:FAS3]DPRBAS(I_PLN-1)       = [F:TMP1]DPRBAS
  [M:FAS3]NSPVAL(I_PLN-1)       = [F:TMP1]NSPVAL
  [M:FAS3]EXETRFCUM(I_PLN-1)    = [F:TMP1]EXETRFCUM
  [M:FAS3]EXEIMLCUM(I_PLN-1)    = [F:TMP1]EXEIMLCUM
  [M:FAS3]PERIMLCUM(I_PLN-1)    = [F:TMP1]PERIMLCUM
  [M:FAS3]EXERVECUM(I_PLN-1)    = [F:TMP1]EXERVECUM
  [M:FAS3]PERRVECUM(I_PLN-1)    = [F:TMP1]PERRVECUM
  [M:FAS3]PERCLOCUM(I_PLN-1)    = [F:TMP1]PERCLOCUM
  [M:FAS3]PERCLOEXC(I_PLN-1)    = [F:TMP1]PERCLOEXC
  [M:FAS3]PERCLOCUMT(I_PLN-1)   = [F:TMP1]PERCLOCUMT
  [M:FAS3]PERCLOEXCT(I_PLN-1)   = [F:TMP1]PERCLOEXCT
  [M:FAS3]EXECLOCUMT(I_PLN-1)   = [F:TMP1]EXECLOCUMT
  [M:FAS3]DPRCUM(I_PLN-1)       = [F:TMP1]DPRCUM
  [M:FAS3]DPRCUMFLG(I_PLN-1)    = [F:TMP1]DPRCUMFLG
  [M:FAS3]RVAAMT(I_PLN-1)       = [F:TMP1]RVAAMT
  [M:FAS3]RVACOE(I_PLN-1)       = [F:TMP1]RVACOE
  [M:FAS3]RVACOEREF(I_PLN-1)    = [F:TMP1]RVACOEREF
  [M:FAS3]RVATIADAT(I_PLN-1)    = [F:TMP1]RVATIADAT
  [M:FAS3]PERREFCLC(I_PLN-1)    = [F:TMP1]PERREFCLC
  [M:FAS3]PERREFCLCT(I_PLN-1)   = [F:TMP1]PERREFCLCT
  [M:FAS3]RVADAT(I_PLN-1)       = [F:TMP1]RVADAT
  [M:FAS3]RVATYP(I_PLN-1)       = [F:TMP1]RVATYP
  [M:FAS3]LEGCUM(I_PLN-1)       -= GRVADERRVE
  If [M:FASR]RVATIADAT=GVML_ERENDEX #Fq-79819
     #*Fq-85936 If ([M:FASR]RVATYP = GVML_MODCOE ) Then : # FQ85936
     #+Fq-85936 Idem pour réévaluation fin exercice par VMA
       [M:FAS3]NBV(I_PLN-1)       = [F:TMP1]NBVO  + [F:TMP1]RVAAMT
       [M:FAS3]NBVT(I_PLN-1)      = [F:TMP1]NBVTO + [F:TMP1]RVAAMT
     #*Fq-85936     Else
     #*Fq-85936        [M:FAS3]NBV(I_PLN-1)       = [F:TMP1]NBVO
     #*Fq-85936        [M:FAS3]NBVT(I_PLN-1)      = [F:TMP1]NBVTO
     #*Fq-85936  Endif
  Endif
  #--------------------------
  # Mise à jour des valeurs marchés sur les autres plans
  # ayant même date de début de période
  If ([M:FASR]RVATYP = GVML_MODVMA and [M:FASR]CCLRVAFLG <> G_OUI)
    Gosub MAJ_VMA_UNITAIRE
  Endif
  # Affectation de NSPVAL à effectuer toujours après MAJ_VMA_UNITAIRE
  [M:FAS3]NSPVAL(I_PLN-1)       = [F:TMP1]NSPVAL
  #-1 ------------------------------------
  If ( [M:FASR]CCLRVAFLG <> G_OUI )
     #Fq-67995 If ([M:FASR]RVATYP = GVML_MODVMA )
     #Fq-79819 If ([M:FASR]RVATYP = GVML_MODVMA or G_RVALIB=G_OUI )
     If ([M:FASR]RVATYP = GVML_MODVMA or G_RVALIB=G_OUI ) and ( [M:FASR]RVATIADAT <> GVML_ERENDEX  )
        # Passage en résiduel  si rééval par "Valeur Marché" ( sauf si le bien vient juste d'être créé )
        # ou bien si réévaluation Libre
        If ( [M:FAS3]LSTCLODAT (I_PLN-1) <> [0/0/0]  or
&          ([M:FAS3]LSTCLODAT (I_PLN-1) = [0/0/0] and [F:DEP]STRDPRDAT < [F:DEP]FIYSTRDAT)  ) and
&          ( [M:FASR]RVATIADAT <> GVML_ERENDEX) #Fq-79819
           Local Integer LPRATYP
           Call GET_DPM_RSD([M:FAS0]CPY, [M:FAS3]DPM(I_PLN-1),[M:FAS3]DPM (I_PLN-1), LPRATYP) From TRTFAS
           [M:FAS3]DPMT(I_PLN-1)   = [M:FAS3]DPM (I_PLN-1)
           If LPRATYP > 0
              [M:FAS3]PRATYP(I_PLN-1) = LPRATYP
           Else
              [M:FAS3]PRATYP(I_PLN-1) = [F:DEP]PRATYP
           Endif
        Endif
        If G_RVALIB = G_OUI
          Gosub ALIM_MASK_LIB     From TRTFASRVALIB  #Fq-67995
        Endif
#        Endif
     Endif
  #-1 ------------------------------------
  Else

    # Annulation de révaluation
    Filter [EFS] Where ( REF= [M:FAS0]AASREF & DPRPLN= [M:FAS3]DPRPLN(I_PLN-1) )
    Read [EFS]Last
    If !(fstat)
      If  [F:EFS]RVATIADAT <> GVML_ERENDEX #Fq-79819
         # lecture événement de réévaluation pour récupérer le mode avant réévaluation
         [M:FAS3]DPM   (I_PLN-1) = [F:EFS]DPM
         [M:FAS3]PRATYP(I_PLN-1) = [F:EFS]PRATYP
         [M:FAS3]DPMT  (I_PLN-1) = [F:EFS]DPM
      Endif
    Endif
    If G_RVALIB = G_OUI
       Gosub ALIM_MASK_LIB From TRTFASRVALIB #Fq-67995
    Endif
  Endif
  #-1 ------------------------------------
   If  [F:TMP1]RVATIADAT <> GVML_ERENDEX #Fq-79819
      [M:FAS3]NBV(I_PLN-1)           = [F:TMP1]NBV
      [M:FAS3]NBVT(I_PLN-1)          = [F:TMP1]NBVT
   Else
      #*Fq-85936 If ([M:FAS3]RVATYP(I_PLN-1) = GVML_MODCOE ) Then : # FQ85936
      #*Fq-85936 : Dans tous les cas : si rééval fin exercice, on calcule la Valeur nette après réévaluation
        [M:FAS3]NBV(I_PLN-1)           = [F:TMP1]NBVO  + [F:TMP1]RVAAMT
        [M:FAS3]NBVT(I_PLN-1)          = [F:TMP1]NBVTO + [F:TMP1]RVAAMT
      #*Fq-85936Else
      #*Fq-85936[M:FAS3]NBV(I_PLN-1)           = [F:TMP1]NBVO
      #*Fq-85936[M:FAS3]NBVT(I_PLN-1)          = [F:TMP1]NBVTO
      #*Fq-85936Endif
      Endif
  [M:FAS3]DEPSTA   (I_PLN-1)     = GVML_SCNOCAL
  [M:FAS0]FLGCLC                            = G_OUI
  [M:FAS0]FLGCNXCLC([M:FAS3]CNX(I_PLN-1)-1) = G_OUI
  # Maj des champs UPDx - GBO-FQ62719
  [M:FAS9]UPDUSR=GUSER
  [M:FAS9]UPDDAT=date$

  ACTMODIF=1

Return
#=====================================================================
# Unitaire : Permet de réafficher les masques de l'objet métier si des modifs
#            y ont été reportées.
$REAF_ALIM_MASK
  Affzo [M:FAS3]
  Affzo [M:FAS9]   #FQ62719
Return
#=====================================================================
# Massif : Sert à ouvrir des tables utilisées dans MAS1_APPL_MAS1
$OUVR_APPL_DIRT
 Local Char    TRC_CPY  # Société courante : rupture société pour émission en-tête trace
  Gosub OUVRE_TABLES
Return
#=====================================================================
# Massif : Application paramètres action aux tables de données : mise à jour directe
$MAS1_APPL_DIRT

  Local Integer LCDRET, LOK
  Local Char    LCDINT(10), RTEXT
  Local Char    LMESSAGE
  Local Integer RCOD
  Local Decimal WNBV
  Local Integer WICONTEXTE
  Local Integer RERROR

  Raz WNBV
  Raz GNBVO_C
  Raz GNBVTO

  If ([F:MAS1]CPY <> TRC_CPY)
    If  (FLGDET = G_OUI)
      Call ENTETE_COMPTE_RENDU([F:MAS1]CPY) From TRTFASRVA
    Endif
    TRC_CPY=[F:MAS1]CPY
  Endif
  #----------------------------------------------------------------------------------------------------
  # MAJ directe de la table FXDASSETS (TMP1) et de la table DEPREC à partir des infos de [FASR]et [MAS1]
  # La table DEPREC située à l'intérieur d'un trbegin subit également un rollback en cas d'erreur
  # MAJ la table TMPMASFAS [F:TMP1] avec les infos saisies en paramètre à appliquer
  #----------------------------------------------------------------------------------------------------
  [F:MAS1]RVAAPR=[M:FASR]RVAAPR
  [F:MAS1]RVACMT=[M:FASR]RVACMT

  # Alimentation de la table DEPREC [F:DEP] (période courante)
  Readlock [DEP]DEP0=[F:MAS1]AASREF;[M:FASR]DPRPLN;[M:FASR]FIYENDDAT; [M:FASR]PERENDDAT
  If (fstat)
    RMES = mess(104,GML_MSGFAS,1)+" DEPREC "+mess(105,GML_MSGFAS,1)+" 01 "+mess(106,GML_MSGFAS,1)+num$(fstat)
    LOK = G_NON
    GOK=0 : Return
  Else
    LOK = G_OUI
  Endif

  #-- Valeur nette début période
  [F:DEPC] = [F:DEP]
  If [M:FASR]RVATIADAT <> GVML_ERENDEX
    #Fq-89419  If ( [M:FASR]RVATIADAT = GVML_ERDBEX and [M:FASR]RVATYP <> GVML_MODVMA )
     #Fq-XXXXX pourquoi test sur VMA ??
    If ( [M:FASR]RVATIADAT = GVML_ERDBEX )
      Call CAL_VALEUR_NETTE ( "RDE", [F:DEPC]DPRBAS, 2, 0, GNBVO_C  ) From GLOBB4
      Call CAL_VALEUR_NETTE ( "TDE", [F:DEPC]DPRBAS, 2, 0, GNBVTO ) From GLOBB4
    Else
      Call CAL_VALEUR_NETTE ( "RDP", [F:DEPC]DPRBAS, 2, 0, GNBVO_C  ) From GLOBB4
      Call CAL_VALEUR_NETTE ( "TDP", [F:DEPC]DPRBAS, 2, 0, GNBVTO ) From GLOBB4
    Endif
  Else   #Fq-79819 si date prise d'effet= fin exercice
     GNBVO_C= [F:DEP]NBV
     GNBVTO = [F:DEP]NBVT
  Endif

  # Prise en compte des infos saisies en paramètre à appliquer pour le plan considéré
  [F:DEPW] = [F:DEP]
  LOK = G_NON
  If ([M:FASR]CCLRVAFLG <> G_OUI)
    GCCLFLG = G_NON

    If G_RVALIB <> G_OUI
       Gosub REEVAL_DIRT
    Else
       Gosub REEVAL_DIRT_LIB From TRTFASRVALIB #Fq-67995
    Endif

    Call GET_MNT_ARRONDI ([F:DEPW]DPRBAS,     [M:FASR]CUR, [F:DEPW]DPRBAS)      From GLOBIENS
    Call GET_MNT_ARRONDI ([F:DEPW]PERCLOCUM,  [M:FASR]CUR, [F:DEPW]PERCLOCUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([F:DEPW]PERCLOEXC,  [M:FASR]CUR, [F:DEPW]PERCLOEXC)   From GLOBIENS
    Call GET_MNT_ARRONDI ([F:DEPW]DPRCUM,     [M:FASR]CUR, [F:DEPW]DPRCUM)      From GLOBIENS
    Call GET_MNT_ARRONDI ([F:DEPW]EXETRFCUM,  [M:FASR]CUR, [F:DEPW]EXETRFCUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([F:DEPW]EXEIMLCUM,  [M:FASR]CUR, [F:DEPW]EXEIMLCUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([F:DEPW]PERIMLCUM,  [M:FASR]CUR, [F:DEPW]PERIMLCUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([F:DEPW]EXERVECUM,  [M:FASR]CUR, [F:DEPW]EXERVECUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([F:DEPW]PERRVECUM,  [M:FASR]CUR, [F:DEPW]PERRVECUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([F:DEPW]IMLBLC,     [M:FASR]CUR, [F:DEPW]IMLBLC)      From GLOBIENS
    Call GET_MNT_ARRONDI ([F:DEPW]NBV,        [M:FASR]CUR, [F:DEPW]NBV)         From GLOBIENS
    Call GET_MNT_ARRONDI ([F:DEPW]NBVT,       [M:FASR]CUR, [F:DEPW]NBVT)        From GLOBIENS
    Call GET_MNT_ARRONDI ([F:DEPW]PERCLOCUMT, [M:FASR]CUR, [F:DEPW]PERCLOCUMT)  From GLOBIENS
    Call GET_MNT_ARRONDI ([F:DEPW]PERCLOEXCT, [M:FASR]CUR, [F:DEPW]PERCLOEXCT)  From GLOBIENS
    Call GET_MNT_ARRONDI ([F:DEPW]EXECLOCUMT, [M:FASR]CUR, [F:DEPW]EXECLOCUMT)  From GLOBIENS
  Else
    GCCLFLG = G_OUI
    If G_RVALIB <> G_OUI
       Gosub ANNU_REEVAL_DIRT
    Else
       Gosub ANNU_REEVAL_DIRT_LIB From TRTFASRVALIB  #Fq-67995
    Endif
  Endif
  #- 1 -------------------
  If ( LOK = G_OUI )
    #-----------------------------------
    [F:DEPX] = [F:DEP]
    If ( [F:DEP]RVATIADAT <> GVML_ERENDEX ) Then : # FQ85936
#    If ( [M:FASR]RVATIADAT <> GVML_ERENDEX ) Then : # FQ85936
       [F:DEP]  = [F:DEPW]
    Else
      # FQ85936
      [F:DEP]RVATIADAT  =  [F:DEPW]RVATIADAT
      [F:DEP]RVATYP     =  [F:DEPW]RVATYP
      [F:DEP]RVADAT     =  [F:DEPW]RVADAT
      [F:DEP]RVACOEREF  =  [F:DEPW]RVACOEREF
      [F:DEP]RVACOE     =  [F:DEPW]RVACOE
      [F:DEP]RVAAMT     =  [F:DEPW]RVAAMT
    Endif : # FQ85936
    #-----------------------------------
    [F:DEP]DEPSTA    = GVML_SCNOCAL
    # si réévaluation on ne met à jour les flags que si on est en réévaluation par valeur marché
    # ou si le cumul d'amortissement est <> 0
    #Fq-67995 If ([M:FASR]CCLRVAFLG <> G_OUI
    If G_RVALIB <> G_OUI
      If ( [M:FASR]CCLRVAFLG <> G_OUI ) and
&         ( [F:DEP]RVATYP = GVML_MODVMA or ([F:DEP]RVATYP <> GVML_MODVMA and [F:DEP]DPRCUM <> 0 ) )
        If ([M:FASR]RVATYP <> GVML_MODCOE and [M:FASR]RVATIADAT <> GVML_ERENDEX ) Then : #FQ85936
          [F:DEP]DPRCUMFLG  = G_OUI
        Endif : # FQ85936
      Endif
    Endif
    #-2 ------------------------------------
    If ( [M:FASR]CCLRVAFLG <> G_OUI )
       # Passage en résiduel  si rééval par "Valeur Marché" ( sauf si le bien vient juste d'être créé )
       #Fq-79819 If ( [M:FASR]RVATYP = GVML_MODVMA )   or ( G_RVALIB=G_OUI )
       If ( [M:FASR]RVATYP = GVML_MODVMA )   or ( G_RVALIB=G_OUI ) and  ( [M:FASR]RVATIADAT <> GVML_ERENDEX  )
          If ( [F:DEP]LSTCLODAT <> [0/0/0] or
&            ([F:DEP]LSTCLODAT =  [0/0/0] and [F:DEP]STRDPRDAT < [F:DEP]FIYSTRDAT) )
             Local Integer LPRATYP
             Call GET_DPM_RSD([F:MAS1]CPY, [F:DEP]DPM, [F:DEP]DPM, LPRATYP) From TRTFAS
             [F:DEP]DPMT    = [F:DEP]DPM
             If LPRATYP > 0
                [F:DEP]PRATYP  = LPRATYP
             Endif
          Endif
       Endif
       #-2 ------------------------------------
    Else

      #*FQ-79819 On ne récupère le mode que si l'on n'est pas en rééval. fin exercice
      #*Fq-85936 Correction MDJ If ( [M:FASR]RVATIADAT <> GVML_ERENDEX )
      If ( [F:DEPX]RVATIADAT <> GVML_ERENDEX )
         # Annulation de révaluation
         Filter [EFS] Where ( REF= [F:MAS1]AASREF & DPRPLN= [F:DEP]DPRPLN )
         Read [EFS]Last
         If !(fstat)
           # lecture événement de réévaluation pour récupérer le mode avant réévaluation
           [F:DEP]DPM    = [F:EFS]DPM
           [F:DEP]PRATYP = [F:EFS]PRATYP
           [F:DEP]DPMT   = [F:EFS]DPM
         Endif
       Endif
    Endif
    #- 2 -----------------------
    If ( FLGSIM <> G_OUI )
      # on n'est pas en simulation
      #------------------
      [F:DEP]DEPSTA = GVML_SCNOCAL
      #Fq-85936      If [F:DEP]RVATIADAT = GVML_ERENDEX #Fq-79819
      If [F:DEPX]RVATIADAT = GVML_ERENDEX #Fq-85936
         #*Fq-85936 If ( [F:DEP]RVATYP = GVML_MODCOE) Then : # FQ85936
         #*Fq-85936 : Dans tous les cas : si rééval fin exercice, on calcule la Valeur nette après réévaluation
           [F:DEP]NBV  = GNBVO_C + [F:DEP]RVAAMT
           [F:DEP]NBVT = GNBVTO  + [F:DEP]RVAAMT
         #*Fq-85936 Else
         #*Fq-85936 [F:DEP]NBV  = GNBVO_C
         #*Fq-85936 [F:DEP]NBVT = GNBVTO
         #*Fq-85936 Endif
      Endif
      Rewrite[DEP]
      If (fstat)
        RMES = mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 02"+mess(106,GML_MSGFAS,1)+num$(fstat)
        GOK=0 : Return
      Endif
      #Fq-75459
      #Fq-89419 If G_RVALIB = G_OUI
      If G_RVALIB = G_OUI and  [M:FASR]DPRPLN=G301CPT
         Read[DEPF]DEP0= [F:DEP]AASREF;G301FIS;[F:DEP]FIYENDDAT;[F:DEP]PERENDDAT
         If fstat=0
            [F:DEPF]DEPSTA = GVML_SCNOCAL
            Rewrite[DEPF]
            If (fstat)
               RMES = mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 02"+mess(106,GML_MSGFAS,1)+num$(fstat)
               GOK=0 : Return
            Endif
         Endif
         Read[DEPM]DEP0= [F:DEP]AASREF;G301MIN;[F:DEP]FIYENDDAT;[F:DEP]PERENDDAT
         If fstat=0
            [F:DEPM]DEPSTA = GVML_SCNOCAL
            Rewrite[DEPM]
            If (fstat)
               RMES = mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 02"+mess(106,GML_MSGFAS,1)+num$(fstat)
               GOK=0 : Return
            Endif
         Endif
      Endif #Fq-75459
      #-----------
      #------------------
      # Indicateur du bien sont mis "à recalculer"
      [F:MAS1]FLGCLC                  = G_OUI
      [F:MAS1]FLGCNXCLC([F:DEP]CNX-1) = G_OUI

      # Maj des infos UPD du bien comptable-GBO-FQ62719
      [F:MAS1]UPDUSR=GUSER
      [F:MAS1]UPDDAT=date$
      #*FQ92611 [F:MAS1]UPDTIM=time

      Rewrite [MAS1]
      If (fstat)
        RMES = mess(104,GML_MSGFAS,1)+" FXDASSETS"+mess(105,GML_MSGFAS,1)+" 02"+mess(106,GML_MSGFAS,1)+num$(fstat)
        GOK=0 : Return
      Endif
      If (GOK)
         [F:DEP] = [F:DEPX]
         [F:DEP]NBV=GNBVO_C
         If G_RVALIB <>  G_OUI
            Gosub GENER_RVA_EVE From TRTFASRVA
         Else
            Gosub GENER_RVA_EVE_LIB From TRTFASRVALIB #Fq-67995
         Endif
      Endif
    Endif
    #- 2 -----------------------
    If ( FLGDET = G_OUI )
      Gosub ECR_DETAIL_NEW
    Endif
    GOK=1 : NBCPYMAJ+=1
 Endif
 #- 1 -------------------

Return
#=====================================================================
# Massif : Sert à ouvrir des tables utilisées dans MAS1_APPL_MAS1
$CLOS_APPL_DIRT
  If !clalev([F:MAS2]) : Local File FXDASSETS [MAS2] : Endif
Return
#=====================================================================
# Unitaire / massif : Ouverture de tables annexes avant report du contenu des tables temporaires dans les tables de données
$OUVR_ALIM_TABLE

Local Char TRC_CPY  : Raz TRC_CPY

  # Ouverture de tables liées à explorer ou à mettre à jour  par l'action massive
  Gosub OUVRE_TABLES
Return
#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire annexe dans la table de données annexe
$TMP1_ALIM_TABLE

Local Integer LCDRET, RCOD
Local Char    LCDINT(10), RTEXT
Local Decimal WNBV
Local Integer WICONTEXTE
Local Integer RERROR
Local Integer I_FIS : I_FIS = 0  #Fq-67995
Local Integer I_MIN : I_MIN = 0  #Fq-67995
  #--------------------------------------------------------------------
  # Pour chaque bien de la table TMPMASFAS,
  # transfert des infos de TMPMASFAS [TMP1] dans la table FXDASSETS [MAS1]
  # Transfert des zones [TMP1] dans l'enregistrement de la table à mettre à jour
  # rewrite de la table choisie. Utiliser GOK pour interrompre le traitement.
  # Pour chaque bien de la table TMPPLNFAS,
  # transfert des infos de TMPPLNFAS [TMP1] dans la table DEPREC [DEP]
  #--------------------------------------------------------------------
  Raz WNBV

  #-> A rupture société on émet un en-tête dans la trace
  If (ACTTYPGES = GTAMMAS and [F:TMP1]CPY<>TRC_CPY)
    If  (FLGDET = G_OUI)
      Call ENTETE_COMPTE_RENDU([F:TMP1]CPY) From TRTFASRVA
    Endif
    TRC_CPY=[F:TMP1]CPY
  Endif
  #--------------------------------------------------------------------
  # On passe dans TMP1_ALIM_TABLE en massif et en unitaire
  # Ceci afin de rendre possible la génération des événements en unitaire
  # En unitaire, le reste des opérations est pris en charge par la transaction appelante (TMP1_ALIM_MASK)
  # (pas de trace pas de mise à jour du bien courant)
  # La fonction IS_OBJ_MAIN oui/non permet de savoir s'il s'agit du bien traité dans l'appelant
  # dont les plans sont mis à jour par l'appelant à différencier des autres biens (ex: composant)
  # qui eux sont à mettre à jour.
  #--------------------------------------------------------------------
  # Si prise d'effet "Début d'exercice"
  If ( [F:TMP1]RVATIADAT = GVML_ERDBEX )
    # Aucune réévaluation dans les périodes closes de l'ex. ne doit avoir pris effet "début de période"
    Filter [DEP] Where AASREF    = [F:TMP1]OBJREF
&                  and DPRPLN    = [F:TMP1]DPRPLN
&                  and FIYENDDAT = [F:TMP1]FIYENDDAT
&                  and PERENDDAT < [F:TMP1]PERSTRDAT
&                  and RVATIADAT <> 0
    Read[DEP] Last
    Filter [DEP]
    If ( fstat = 0 and [F:DEP]RVATIADAT = GVML_ERDBPE )
      # Prise d'effet inapplicable : Bien comptable déjà réévalué avec effet "Début de période"
      RMES = mess(630,GML_MSGFAS,1)
      Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,[F:DEP]DPRPLN, G_OUI, mess(171,GML_MSGFAS,1)) From TRCPROCOM
      Return
    Endif
  Endif

  # Lecture DEPREC période courante
  Read [DEP]DEP0=[F:TMP1]OBJREF;[F:TMP1]DPRPLN;[F:TMP1]FIYENDDAT;[F:TMP1]PERENDDAT
  If (fstat)
    RMES=mess(104,GML_MSGFAS,1)-"DEPREC"-mess(105,GML_MSGFAS,1)-"03"-mess(106,GML_MSGFAS,1)-[F:TMP1]TRTNUM+"/"+[F:TMP1]OBJREF+"/"+[F:TMP1]DPRPLN
    GOK=0
    Return
  Endif
#  #----- Mise Ã  jour des plans Fiscal et Minimum
   #Fq-89419 If G_RVALIB = G_OUI
   If G_RVALIB = G_OUI and  [M:FASR]DPRPLN=G301CPT
      # Lecture DEPREC fiscal période courante
      Read [DEPF]DEP0=[F:TMP1]OBJREF;G301FIS;[F:TMP1]FIYENDDAT;[F:TMP1]PERENDDAT
      If fstat = 0
        I_FIS=1
        # FQ104164
        [F:DEPFO] = [F:DEPF]
      Endif
      Read [DEPM]DEP0=[F:TMP1]OBJREF;G301MIN;[F:TMP1]FIYENDDAT;[F:TMP1]PERENDDAT
      If fstat = 0
        I_MIN=1
        # FQ104164
        [F:DEPMO] = [F:DEPM]

      Endif
   Endif #Fq-67995
  #- 1------------------------------
  If ( ACTTYPGES = GTAMMAS )
    #- 2------------------------------
    If ([M:FASR]CCLRVAFLG <> G_OUI)
      # << Réévaluation >>
      #==
      #FQ-64311  If ([F:DEP]RVAAMT > 0 or [F:DEP]RVADAT <> [0/0/0])
      If ([F:DEP]RVAAMT <> 0 or [F:DEP]RVADAT <> [0/0/0])
        # Bien comptable déjà réévalué dans la période "
        RMES = mess(171,GML_MSGFAS,1)
        Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,[F:DEP]DPRPLN, G_OUI, mess(171,GML_MSGFAS,1)) From TRCPROCOM
        Return
      Endif
      #==
      If ( [F:DEP]IMLRVELIM <> 0 )
       # Bien comptable ayant un plafond de dépréciation"
       RMES = mess(240,GML_MSGFAS,1)
        Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,[F:DEP]DPRPLN,G_OUI,  mess(240,GML_MSGFAS,1)) From TRCPROCOM
        Return
      Endif
      #--
      If ([F:DEP]PERSTRDAT <> [F:DEP]FIYSTRDAT and [M:FASR]RVATIADAT = GVML_ERDBEX and
&       func TRTFASRVA.EXISTE_MTC ([F:MAS1]AASREF, [F:DEP]DPRPLN, [F:DEP]FIYSTRDAT, [F:DEP]PERENDDAT) )
        # "Réévaluation début exercice impossible si changement de méthode dans l'exercice"
        Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,[F:DEP]DPRPLN, G_OUI, mess(600,GML_MSGFAS,1)) From TRCPROCOM
        Return
      Endif
      #==
      #=======================================
      If ( [F:DEP]BSEVAL < 0 )    #Fq-65178
        # Base d'amortissement négative, ne peut pas être réévalué
        RMES = mess(807,GML_MSGFAS,1)
        Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,[F:DEP]DPRPLN,G_OUI,  mess(807,GML_MSGFAS,1)) From TRCPROCOM
        Return
      Endif
      #==
      If ( [F:DEP]IML <> 0 )
        # Bien comptable ayant subi une dépréciation dans la période"
        RMES = mess(425,GML_MSGFAS,1)
        Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,[F:DEP]DPRPLN,G_OUI,  mess(425,GML_MSGFAS,1)) From TRCPROCOM
        Return
      Endif
      #==
      If ( [F:DEP]DPM = G_DPMCA )
        # Plan amorti selon le mode "CA" ne peut pas être réévalué
        RMES = mess(611,GML_MSGFAS,1)
        Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,[F:DEP]DPRPLN,G_OUI,  mess(611,GML_MSGFAS,1)) From TRCPROCOM
        Return
      Endif
      #==
      If   (  [F:DEP]STRDPRDAT  > [F:TMP1]PERENDDAT )
        # Bien ayant une date de début d'amortissement  > date de fin période courante
        RMES = mess(389,GML_MSGFAS,1)
        Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,[F:DEP]DPRPLN,G_OUI,  mess(389,GML_MSGFAS,1)) From TRCPROCOM
        Return
      Endif
      # "Si le bien n'a pas encore subi de clôture la prise d'effet ne peut être que "Début Exe."
      If ([M:FASR]RVATYP = GVML_MODVMA and [F:DEP]LSTCLODAT = [0/0/0] and [M:FASR]RVATIADAT = GVML_ERDBPE and
&         [F:DEP]STRDPRDAT >= [F:DEP]FIYSTRDAT and [F:DEP]STRDPRDAT < [F:DEP]PERSTRDAT )
        RMES = mess(605,GML_MSGFAS,1)
        Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,[F:DEP]DPRPLN,G_OUI,  mess(605,GML_MSGFAS,1)) From TRCPROCOM
      Endif
    #- 2------------------------------
    Else
      # << Annulation de  réévaluation >>
      #==
      If ([F:DEP]RVAAMT = 0 or [F:DEP]RVADAT = [0/0/0])
        # Annulation réévaluation sur bien comptable non réévalué ! "
        RMES = mess(172,GML_MSGFAS,1)
        Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,[F:DEP]DPRPLN,G_OUI,  mess(172,GML_MSGFAS,1)) From TRCPROCOM
        Return
      Endif
    Endif
    #- 2------------------------------
    If ( FLGDET = G_OUI )
      Call SEP_COMPTE_RENDU([F:MAS1]CPY)
      Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO,[F:MAS1]AASREF+"/"+[F:MAS1]AASDES1,0,1) From TRACEABX3
      GNBVO_C =[F:TMP1]NBVO
      Gosub ECR_DETAIL_OLD
    Endif
  Endif
  #- 1------------------------------
  #------------------------------
  [F:DEPW] = [F:DEP]
  #------------------------------
  LOK = G_NON
  Gosub CHARGE_DEP

  If ([F:TMP1]MSGERR <> "" and ACTTYPGES = GTAMMAS )
    Call ECR_TRACE_ERREUR([F:TMP1]CPY,[F:TMP1]OBJREF,[F:TMP1]DPRPLN, G_OUI, [F:TMP1]MSGERR) From TRCPROCOM
    LOK=G_NON
  Endif
  #- 1------------------------------
  If (LOK = G_OUI)
    #- 2------------------------------
    If ( (ACTTYPGES = GTAMMAS and dim(FLGSIM) > 0 and FLGSIM <> G_OUI ) or ACTTYPGES = GTAMUNI )
      [F:MAS1]RVAAPR = [F:TMP1]RVAAPR
      [F:MAS1]RVACMT = [F:TMP1]RVACMT

      #--------------------------------------------------
      [F:DEPX] = [F:DEP]
      [F:DEP]  = [F:DEPW]
      #-------------------
      #  Bien à "non calculé"
      [F:DEP]DEPSTA  = GVML_SCNOCAL
      # on ne met à jour les flags que si on est en réévaluation par valeur marché
      # ou que l'on n'est pas en réévaluation par valeur marché et que le cumul d'amortissement est <> 0
      If G_RVALIB <> G_OUI
        If ( GCCLFLG <> G_OUI and
&             ([F:DEP]RVATYP = GVML_MODVMA or ([F:DEP]RVATYP <> GVML_MODVMA and [F:DEP]DPRCUM <> 0)) )
          If ([F:DEP]RVATYP <> GVML_MODCOE and [F:DEP]RVATIADAT <> GVML_ERENDEX ) Then : #FQ85936
             [F:DEP]DPRCUMFLG  = G_OUI
          Endif : #FQ85936
       Endif
      Endif

      #-3 ------------------------------------
      If ( GCCLFLG <> G_OUI )
         # Passage en résiduel  si rééval par "Valeur Marché" ( sauf si le bien vient juste d'être créé )
         # et sauf si l'on réévalue avec prise d'effet "fin d'exercice"
         #Fq-79819 ([F:TMP1]RVATYP = GVML_MODVMA   or G_RVALIB = G_OUI )
         If ([F:TMP1]RVATYP = GVML_MODVMA   or G_RVALIB = G_OUI ) and ( [F:TMP1]RVATIADAT <> GVML_ERENDEX )
            If ( [F:DEP]LSTCLODAT <> [0/0/0] or
&              ( [F:DEP]LSTCLODAT  = [0/0/0] and [F:DEP]STRDPRDAT < [F:DEP]FIYSTRDAT) ) and
&              ( [F:TMP1]RVATIADAT <> GVML_ERENDEX)  #Fq-79819
              Local Integer LPRATYP
              Call GET_DPM_RSD([F:MAS1]CPY, [F:DEP]DPM, [F:DEP]DPM, LPRATYP) From TRTFAS
              [F:DEP]DPMT    = [F:DEP]DPM
              If LPRATYP > 0
                [F:DEP]PRATYP  = LPRATYP
              Endif
            Endif
            #*Fq-89419  If G_RVALIB = G_OUI #Fq-67995b
             If ( G_RVALIB = G_OUI ) and ( [M:FASR]DPRPLN=G301CPT )
               [F:DEP]LEGCUM -=GRVADERRVE
               If I_FIS > 0
                  [F:DEPF]RVATIADAT    =  0
                  [F:DEPF]RVATYP       =  0
                  [F:DEPF]RVADAT       =  [F:DEP]RVADAT
                  [F:DEPF]PERREFCLC    =  [F:DEP]FIYSTRDAT
                  [F:DEPF]PERREFCLCT   =  [F:DEP]FIYSTRDAT
                  GDPRCUMO = [F:DEPF]DPRCUM
                  [F:DEPF]DPRCUM      -=   GRVADERRVE    #Fq-67995b
                  [F:DEPF]DPRCUMFLG    =   G_OUI         #Fq-67995b
                  [F:DEPF]EXECLOCUMT  -=   GRVADERRVE    #Fq-67995b
                  [F:DEPF]DPRBAS       =  [F:DEPF]DPRBAS  +  [F:DEP]RVAAMT
                  [F:DEPF]RVAAMT       =  [F:DEP]RVAAMT
                  GDPMO_F              =  [F:DEPF]DPM
                  If ( [F:DEPF]LSTCLODAT <> [0/0/0] or
&                    ( [F:DEPF]LSTCLODAT  = [0/0/0] and [F:DEPF]STRDPRDAT < [F:DEPF]FIYSTRDAT) ) and
&                    ( [F:TMP1]RVATIADAT <> GVML_ERENDEX ) #Fq-79819
                     Local Integer LPRATYP
                     Call GET_DPM_RSD([F:MAS1]CPY, GDPMO_F, [F:DEPF]DPM, LPRATYP) From TRTFAS
                     [F:DEPF]DPMT    = [F:DEPF]DPM
                     If LPRATYP > 0
                       [F:DEPF]PRATYP  = LPRATYP
                     Endif
                  Endif
               Endif #Fq-67995b
               If I_MIN > 0 #Fq-67995b
                  [F:DEPM]PERREFCLC    =  [F:DEP]FIYSTRDAT
                  [F:DEPM]PERREFCLCT   =  [F:DEP]FIYSTRDAT
                  [F:DEPM]RVADAT       =  [F:DEP]RVADAT
                  [F:DEPM]DPRBAS       =  [F:DEPM]DPRBAS  +  [F:DEP]RVAAMT
                  [F:DEPM]RVAAMT       =  [F:DEP]RVAAMT
                  GDPMO_M              =  [F:DEPM]DPM
                  If ( [F:DEPM]LSTCLODAT <> [0/0/0] or
&                    ( [F:DEPM]LSTCLODAT  = [0/0/0] and [F:DEPM]STRDPRDAT < [F:DEPM]FIYSTRDAT) ) and
&                    ( [F:TMP1]RVATIADAT <> GVML_ERENDEX ) #Fq-79819
                     Local Integer LPRATYP
                     Call GET_DPM_RSD([F:MAS1]CPY, GDPMO_M, [F:DEPM]DPM, LPRATYP) From TRTFAS
                     [F:DEPM]DPMT    = [F:DEPM]DPM
                     If LPRATYP > 0
                       [F:DEPM]PRATYP  = LPRATYP
                     Endif
                  Endif
               Endif    #Fq-67995b
            Endif       #Fq-67995b
         Endif
         #-3 ------------------------------------
      Else

         # Annulation de révaluation
         If ([F:TMP1]RVATIADAT <> GVML_ERENDEX)   #*Fq-85936 Correction MDJ
          Filter [EFS] Where ( REF= [F:MAS1]AASREF & DPRPLN= [F:DEP]DPRPLN )
          Read [EFS]Last
          If !(fstat)
              # lecture événement de réévaluation pour récupérer le mode avant réévaluation
               [F:DEP]DPM        = [F:EFS]DPM
               [F:DEP]PRATYP     = [F:EFS]PRATYP
               [F:DEP]DPMT       = [F:EFS]DPM
               [F:DEP]DPRCUMFLG  = [F:EFS]DPRCUMFLGO  #Fq-67995b
          Endif
         Endif
         If I_FIS > 0
            #Fq-67995
            # Annulation de révaluation plan fiscal
            Filter [EFS] Where ( REF= [F:MAS1]AASREF & DPRPLN= G301FIS )
            Read [EFS]Last
            If !(fstat)
               # lecture événement de réévaluation pour récupérer le mode avant réévaluation
               [F:DEPF]DPM        = [F:EFS]DPM
               [F:DEPF]PRATYP     = [F:EFS]PRATYP
               [F:DEPF]DPMT       = [F:EFS]DPM
               [F:DEPF]DPRBAS     = [F:EFS]DPRBASO     #Fq-67995b
               [F:DEPF]DPRCUM     = [F:EFS]DPRCUMO     #Fq-67995b
               [F:DEPF]DPRCUMFLG  = [F:EFS]DPRCUMFLGO  #Fq-67995b
               [F:DEPF]EXECLOCUMT = [F:EFS]EXECLOCUMO  #Fq-67995b
               [F:DEPF]DEPSTA   = GVML_SCNOCAL
               Rewrite [DEPF]
               If (fstat)
                  RMES = mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 05"+mess(106,GML_MSGFAS,1)+num$(fstat)
                  GOK=0 : Return
               Endif
            Endif
         Endif
        If I_MIN > 0
            #Fq-67995
            # Annulation de révaluation plan minimum
            Filter [EFS] Where ( REF= [F:MAS1]AASREF & DPRPLN= G301MIN )
            Read [EFS]Last
            If !(fstat)
               # lecture événement de réévaluation pour récupérer le mode avant réévaluation
               [F:DEPM]DPM        = [F:EFS]DPM
               [F:DEPM]PRATYP     = [F:EFS]PRATYP
               [F:DEPM]DPMT       = [F:EFS]DPM
               [F:DEPM]DPRBAS     = [F:EFS]DPRBASO     #Fq-67995b
               [F:DEPM]DPRCUM     = [F:EFS]DPRCUMO     #Fq-67995b
               [F:DEPM]DPRCUMFLG  = [F:EFS]DPRCUMFLGO  #Fq-67995b
               [F:DEPM]EXECLOCUMT = [F:EFS]EXECLOCUMO  #Fq-67995b
               [F:DEPM]DEPSTA     = GVML_SCNOCAL
               Rewrite [F:DEPM]
               If (fstat)
                  RMES = mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 05"+mess(106,GML_MSGFAS,1)+num$(fstat)
                  GOK=0 : Return
               Endif
            Endif
         Endif
      Endif
      #-3 ------------------------------------
      [F:DEP]DEPSTA = GVML_SCNOCAL
      If [F:DEP]RVATIADAT = GVML_ERENDEX #Fq-79819
         #*Fq-85936 If ([F:DEP]RVATYP = GVML_MODCOE ) Then : #FQ85936
         #*Fq-85936 : Dans tous les cas : si rééval fin exercice, on calcule la Valeur nette après réévaluation
           [F:DEP]NBV  = GNBVO_C + [F:DEP]RVAAMT
           [F:DEP]NBVT = GNBVTO  + [F:DEP]RVAAMT
         #*Fq-85936 Else
         #*Fq-85936    [F:DEP]NBV  = GNBVO_C
         #*Fq-85936    [F:DEP]NBVT = GNBVTO
         #*Fq-85936 Endif
         Endif
      Rewrite [DEP]
      If (fstat)
        RMES = mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 05"+mess(106,GML_MSGFAS,1)+num$(fstat)
        GOK=0 : Return
      Endif
      If G_RVALIB = G_OUI and I_FIS > 0  #Fq-67995b
        [F:DEPF]DEPSTA = GVML_SCNOCAL
        Rewrite [DEPF]
        If (fstat)
          RMES = mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 05"+mess(106,GML_MSGFAS,1)+num$(fstat)
          GOK=0 : Return
        Endif
      Endif #Fq-67995b
      If G_RVALIB = G_OUI and I_MIN > 0  #Fq-67995b
       [F:DEPM]DEPSTA = GVML_SCNOCAL
        Rewrite [DEPM]
        If (fstat)
          RMES = mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 05"+mess(106,GML_MSGFAS,1)+num$(fstat)
          GOK=0 : Return
        Endif
      Endif  #Fq-67995b

      # Indicateur du bien sont mis "à recalculer"
      [F:MAS1]FLGCLC                  = G_OUI
      [F:MAS1]FLGCNXCLC([F:DEP]CNX-1) = G_OUI

      # Maj des infos UPD du bien comptable-GBO-FQ62719
      [F:MAS1]UPDUSR=GUSER
      [F:MAS1]UPDDAT=date$
      #*FQ92611 [F:MAS1]UPDTIM=time

      Rewrite [MAS1]
      If (fstat)
        RMES = mess(104,GML_MSGFAS,1)+" FXDASSETS"+mess(105,GML_MSGFAS,1)+" 02"+mess(106,GML_MSGFAS,1)+num$(fstat)
        GOK=0 : Return
      Endif

      If (ACTTYPGES = GTAMMAS and FLGDET = G_OUI)      # Massif uniquement
        Gosub ECR_DETAIL_NEW
        NBCPYMAJ+=1
      Endif
      [F:DEP] = [F:DEPX]
      [F:DEP]NBV=GNBVO_C
      If ( GCCLFLG = G_OUI )
        [F:DEPW]NBV= [F:TMP1]NBV
      Endif
      If G_RVALIB <>  G_OUI
        Gosub GENER_RVA_EVE From TRTFASRVA
      Else
        Gosub GENER_RVA_EVE_LIB From TRTFASRVALIB #Fq-67995
      Endif
    Endif
    #- 2------------------------------
    # En simulation, écriture des nouvelles valeurs dans la trace
    If (ACTTYPGES = GTAMMAS and FLGDET = G_OUI  and FLGSIM = G_OUI)
      Gosub ECR_DETAIL_NEW
      NBCPYMAJ+=1
    Endif
    If (ACTTYPGES = GTAMMAS and  GCCLFLG <> G_OUI)
      Gosub MAJ_VMA_MASSIF
    Endif
  Endif
  #- 1------------------------------

Return
#----------------------------------------------
$MAJ_VMA_MASSIF
# Infbox "TRTFASRVA - MAJ_VMA_MASSIF"

  Filter[DEP] Where AASREF=[F:MAS1]AASREF and DPRPLN <> [M:FASR]DPRPLN  and
&                   FIYENDDAT=[M:FASR]FIYENDDAT and PERSTRDAT=[M:FASR]PERSTRDAT

  #>>>>>>>>>>>>>>>>>>
  For [DEP] With Stability
    If ( [F:DEP]NSPVAL = [F:DEPX]NSPVAL  and [F:DEP]RATCUR = [F:DEPW]RATCUR )
      [F:DEP]NSPVAL = [F:DEPW]NSPVAL
    Endif
    Rewrite[DEP]
    If (fstat)
      RMES = mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 02"+mess(106,GML_MSGFAS,1)+num$(fstat)
      GOK=0 : Break
    Endif
  Next
  #<<<<<<<<<<<<<<<<<<
  Filter[DEP]

Return

#----------------------------------------------
$MAJ_VMA_UNITAIRE
# infbox "TRTFASRVA - MAJ_VMA_UNITAIRE"
  # Mise à jour des valeurs marchés sur les autres plans ayant même date de début de période
  # s'il possédait déjà une valeur marché d'MAJ_VMA_UNITAIRE montant égal à celle modifiée par la réévaluation

Local Integer J

  # >>>>>>>>>
  For J = 1 To [M:FAS3]NBLIG1
    If ( [M:FAS3]DPRPLN(J-1) <> [F:TMP1]DPRPLN and [M:FAS3]NSPVAL(J-1) <> 0  and
&        [M:FAS3]NSPVAL(J-1) = [M:FAS3]NSPVAL(I_PLN-1))
      If ( [M:FAS3]PERSTRDAT(J-1) = [M:FASR]PERSTRDAT )
        [M:FAS3]NSPVAL(J-1)  = [F:TMP1]NSPVAL
      Endif
    Endif
  Next J
  # <<<<<<<<

Return
######################################################################
# Points d'entrée objet de reprise
######################################################################

#=====================================================================
# Traitement du tableau des infos par plan de l'objet de reprise.
#=====================================================================
# L'écran de reprise de l'action Réévaluation ne comprenant qu'un tableau
# dans lequel sont "mélangées" les infos des tables FXDASSETS et DEPREC,
# on ne passe plus par le traitement du tableau par plan, même si l'action
# porte bien sur un plan.

$LOADPLN
Return

$SAVEPLN
Return
#=====================================================================
$CHARGE_DEP

If ( [F:DEP]EXERVADEV  <> [F:TMP1]EXERVADEV)  : [F:DEPW]EXERVADEV  = [F:TMP1]EXERVADEV  : LOK = G_OUI : Endif
If ( [F:DEP]PERRVADEV  <> [F:TMP1]PERRVADEV)  : [F:DEPW]PERRVADEV  = [F:TMP1]PERRVADEV  : LOK = G_OUI : Endif
If ( [F:DEP]NSPVAL     <> [F:TMP1]NSPVAL)     : [F:DEPW]NSPVAL     = [F:TMP1]NSPVAL     : LOK = G_OUI : Endif
If ( [F:DEP]DPRBAS     <> [F:TMP1]DPRBAS)     : [F:DEPW]DPRBAS     = [F:TMP1]DPRBAS     : LOK = G_OUI : Endif
If ( [F:DEP]PERCLOCUM  <> [F:TMP1]PERCLOCUM)  : [F:DEPW]PERCLOCUM  = [F:TMP1]PERCLOCUM  : LOK = G_OUI : Endif
If ( [F:DEP]PERCLOEXC  <> [F:TMP1]PERCLOEXC)  : [F:DEPW]PERCLOEXC  = [F:TMP1]PERCLOEXC  : LOK = G_OUI : Endif
If ( [F:DEP]DPRCUM     <> [F:TMP1]DPRCUM)     : [F:DEPW]DPRCUM     = [F:TMP1]DPRCUM     : LOK = G_OUI : Endif
If ( [F:DEP]RVAAMT     <> [F:TMP1]RVAAMT)     : [F:DEPW]RVAAMT     = [F:TMP1]RVAAMT     : LOK = G_OUI : Endif
If ( [F:DEP]EXETRFCUM  <> [F:TMP1]EXETRFCUM)  : [F:DEPW]EXETRFCUM  = [F:TMP1]EXETRFCUM  : LOK = G_OUI : Endif
If ( [F:DEP]EXEIMLCUM  <> [F:TMP1]EXEIMLCUM)  : [F:DEPW]EXEIMLCUM  = [F:TMP1]EXEIMLCUM  : LOK = G_OUI : Endif
If ( [F:DEP]PERIMLCUM  <> [F:TMP1]PERIMLCUM)  : [F:DEPW]PERIMLCUM  = [F:TMP1]PERIMLCUM  : LOK = G_OUI : Endif
If ( [F:DEP]EXERVECUM  <> [F:TMP1]EXERVECUM)  : [F:DEPW]EXERVECUM  = [F:TMP1]EXERVECUM  : LOK = G_OUI : Endif
If ( [F:DEP]PERRVECUM  <> [F:TMP1]PERRVECUM)  : [F:DEPW]PERRVECUM  = [F:TMP1]PERRVECUM  : LOK = G_OUI : Endif
If ( [F:DEP]NBV        <> [F:TMP1]NBV)        : [F:DEPW]NBV        = [F:TMP1]NBV        : LOK = G_OUI : Endif
If ( [F:DEP]NBVT       <> [F:TMP1]NBVT)       : [F:DEPW]NBVT       = [F:TMP1]NBVT       : LOK = G_OUI : Endif
If ( [F:DEP]RVACOE     <> [F:TMP1]RVACOE)     : [F:DEPW]RVACOE     = [F:TMP1]RVACOE     : LOK = G_OUI : Endif
If ( [F:DEP]RVATIADAT  <> [F:TMP1]RVATIADAT)  : [F:DEPW]RVATIADAT  = [F:TMP1]RVATIADAT  : LOK = G_OUI : Endif
If ( [F:DEP]RVADAT     <> [F:TMP1]RVADAT)     : [F:DEPW]RVADAT     = [F:TMP1]RVADAT     : LOK = G_OUI : Endif
If ( [F:DEP]RVATYP     <> [F:TMP1]RVATYP)     : [F:DEPW]RVATYP     = [F:TMP1]RVATYP     : LOK = G_OUI : Endif
If ( [F:DEP]RVACOEREF  <> [F:TMP1]RVACOEREF)  : [F:DEPW]RVACOEREF  = [F:TMP1]RVACOEREF  : LOK = G_OUI : Endif
If ( [F:DEP]PERCLOCUMT <> [F:TMP1]PERCLOCUMT) : [F:DEPW]PERCLOCUMT = [F:TMP1]PERCLOCUMT : LOK = G_OUI : Endif
If ( [F:DEP]PERCLOEXCT <> [F:TMP1]PERCLOEXCT) : [F:DEPW]PERCLOEXCT = [F:TMP1]PERCLOEXCT : LOK = G_OUI : Endif
If ( [F:DEP]EXECLOCUMT <> [F:TMP1]EXECLOCUMT) : [F:DEPW]EXECLOCUMT = [F:TMP1]EXECLOCUMT : LOK = G_OUI : Endif
If ( [F:DEP]PERREFCLC  <> [F:TMP1]PERREFCLC)  : [F:DEPW]PERREFCLC  = [F:TMP1]PERREFCLC  : LOK = G_OUI : Endif
If ( [F:DEP]PERREFCLCT <> [F:TMP1]PERREFCLCT) : [F:DEPW]PERREFCLCT = [F:TMP1]PERREFCLCT : LOK = G_OUI : Endif


Return
#=====================================================================
$REEVAL_DIRT
Local Decimal COEFF, LCOEFF
# infbox "TRTFASRVA -REEVAL_DIRT"

  # Approche optimiste
  RMES = ""
  LOK = G_OUI
  #- 1 -----------------------------------
  If  ([M:FASR]RVATYP = GVML_MODCOE or [M:FASR]RVATYP = GVML_MODIND)
    #=====
    # Réévaluation par COEFFICIENT ou par INDICE
    # On réévalue la base et les cumuls ( sauf le cumul P-1 si prise d'effet "Début d'exercice")
    #=====
    If ( [M:FASR]RVACOEREF = "" )
      If ( [M:FASR]RVACOE <= 0 )
        #  Vous devez saisir le coefficient à appliquer pour chaque bien traité
        Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,[F:DEPW]DPRPLN,G_OUI,mess(136,GML_MSGFAS,1)) From TRCPROCOM
        LOK = G_NON :  GOK=0  : Return
      Else
        LCOEFF = [M:FASR]RVACOE
      Endif
    Else
      Call RECH_RVACOE([M:FASR]RVACOEREF, COEFF)
      LCOEFF = COEFF
    Endif


    # si le coefficient est > 1 on calcule les nouvelles valeurs
    # après réévaluation, sinon, on ne fait rien
    #- 2 -----------------------------------
    #Fq-64311 If ( LCOEFF > 1 )
    If ( LCOEFF > 0 )
      [F:DEPW]RVATIADAT  =  [M:FASR]RVATIADAT
      [F:DEPW]RVATYP     =  [M:FASR]RVATYP
      [F:DEPW]RVADAT     =  [M:FASR]RVADAT
      [F:DEPW]RVACOEREF  =  [M:FASR]RVACOEREF
      [F:DEPW]RVACOE     =  LCOEFF

      #- 3 ---------------------------------------
      If ( [M:FASR]RVATIADAT = GVML_ERENDEX ) Then  #Fq-85936
        # << Coefficent <> 0 >>

      Local Decimal XIMLBLC
      Call  CAL_RVACOE_ENDFIY ( LCOEFF, [M:FASR]CUR, [F:DEP]NBV,
&                [F:DEP]DPRBAS, [F:DEP]DPRCUM    ,[F:DEP]PERCLOCUM ,[F:DEP]PERENDDPE,
&                               [F:DEP]EXCCUM    ,[F:DEP]PERCLOEXC ,[F:DEP]PEREXCDPR,
&                               [F:DEP]EXECLOCUMT,[F:DEP]PERCLOCUMT,[F:DEP]DPET,
&                               [F:DEP]EXCCUMT   ,[F:DEP]PERCLOEXCT,[F:DEP]PEREXCDPRT,
&                               [F:DEP]EXETRFCUM ,[F:DEP]PERTRFCUM ,[F:DEP]IMLRVETRF,
&                               [F:DEP]EXEIMLCUM ,[F:DEP]PERIMLCUM ,[F:DEP]IML,
&                               [F:DEP]EXERVECUM ,[F:DEP]PERRVECUM ,[F:DEP]IMLRVE,
&               [F:DEPW]DPRBAS, [F:DEPW]DPRCUM     ,[F:DEPW]PERCLOCUM  ,[F:DEPW]PERENDDPE,
&                               [F:DEPW]EXCCUM     ,[F:DEPW]PERCLOEXC  ,[F:DEPW]PEREXCDPR,
&                               [F:DEPW]EXECLOCUMT ,[F:DEPW]PERCLOCUMT ,[F:DEPW]DPET,
&                               [F:DEPW]EXCCUMT    ,[F:DEPW]PERCLOEXCT ,[F:DEPW]PEREXCDPRT,
&                               [F:DEPW]EXETRFCUM  ,[F:DEPW]PERTRFCUM  ,[F:DEPW]IMLRVETRF,
&                               [F:DEPW]EXEIMLCUM  ,[F:DEPW]PERIMLCUM  ,[F:DEPW]IML,
&                               [F:DEPW]EXERVECUM  ,[F:DEPW]PERRVECUM  ,[F:DEPW]IMLRVE,
&                      XIMLBLC, [F:DEPW]NBV, [F:DEPW]RVAAMT ) From GLOBB6

        #[F:DEPW]NBV    = [F:DEP]NBV
        #[F:DEPW]DPRBAS = [F:DEP]DPRBAS

      Else
      #- 3 ---------------------------------------
        #Fq-67995 [F:DEPW]NBV        =  GNBVO   * LCOEFF
        #Fq-67995 [F:DEPW]NBVT       =  GNBVTO  * LCOEFF
        [F:DEPW]DPRBAS     =  [F:DEP]DPRBAS     * LCOEFF
        [F:DEPW]DPRCUM     =  [F:DEP]DPRCUM     * LCOEFF
        If ([M:FASR]RVATYP <> GVML_MODCOE and [M:FASR]RVATIADAT <> GVML_ERENDEX ) Then : #FQ85936
          If ([F:DEP]DPRCUM <> 0)   : [F:DEPW]DPRCUMFLG  =  G_OUI : Endif
        Endif : #FQ85936

        # EXECLOCUMT = EXECLOCUMO * LCOEFF
        [F:DEPW]EXECLOCUMT =  [F:DEP]EXECLOCUMT * LCOEFF

        If ( [M:FASR]RVATIADAT = GVML_ERDBEX )
          [F:DEPW]PERREFCLC  = [F:DEP]FIYSTRDAT
          [F:DEPW]PERREFCLCT = [F:DEP]FIYSTRDAT
          [F:DEPW]PERCLOCUM  = [F:DEP]PERCLOCUM
          [F:DEPW]PERCLOCUMT = [F:DEP]PERCLOCUMT
          [F:DEPW]PERCLOEXC  = [F:DEP]PERCLOEXC
          [F:DEPW]PERCLOEXCT = [F:DEP]PERCLOEXCT
        Else
          [F:DEPW]PERREFCLC  = [F:DEP]PERSTRDAT
          [F:DEPW]PERREFCLCT = [F:DEP]PERSTRDAT
          [F:DEPW]PERCLOCUM  = [F:DEP]PERCLOCUM   * LCOEFF
          [F:DEPW]PERCLOCUMT = [F:DEP]PERCLOCUMT  * LCOEFF
          [F:DEPW]PERCLOEXC  = [F:DEP]PERCLOEXC   * LCOEFF
          [F:DEPW]PERCLOEXCT = [F:DEP]PERCLOEXCT  * LCOEFF
        Endif

        [F:DEPW]EXETRFCUM  =  [F:DEP]EXETRFCUM  * LCOEFF
        [F:DEPW]EXEIMLCUM  =  [F:DEP]EXEIMLCUM  * LCOEFF
        [F:DEPW]PERIMLCUM  =  [F:DEP]PERIMLCUM  * LCOEFF
        [F:DEPW]EXERVECUM  =  [F:DEP]EXERVECUM  * LCOEFF
        [F:DEPW]PERRVECUM  =  [F:DEP]PERRVECUM  * LCOEFF

        Call GET_MNT_ARRONDI ( [F:DEPW]EXETRFCUM,  [M:FASR]CUR, [F:DEPW]EXETRFCUM )   From GLOBIENS
        Call GET_MNT_ARRONDI ( [F:DEPW]EXEIMLCUM,  [M:FASR]CUR, [F:DEPW]EXEIMLCUM )   From GLOBIENS
        Call GET_MNT_ARRONDI ( [F:DEPW]PERIMLCUM,  [M:FASR]CUR, [F:DEPW]PERIMLCUM )   From GLOBIENS
        Call GET_MNT_ARRONDI ( [F:DEPW]EXERVECUM,  [M:FASR]CUR, [F:DEPW]EXERVECUM )   From GLOBIENS
        Call GET_MNT_ARRONDI ( [F:DEPW]PERRVECUM,  [M:FASR]CUR, [F:DEPW]PERRVECUM )   From GLOBIENS
        [F:DEPW]IMLBLC     =  [F:DEPW]EXEIMLCUM + [F:DEPW]PERIMLCUM
&                          -  [F:DEPW]EXERVECUM - [F:DEPW]PERRVECUM - [F:DEPW]EXETRFCUM
        Call GET_MNT_ARRONDI ( [F:DEPW]DPRBAS,     [M:FASR]CUR, [F:DEPW]DPRBAS )      From GLOBIENS
        Call GET_MNT_ARRONDI ( [F:DEPW]DPRCUM,     [M:FASR]CUR, [F:DEPW]DPRCUM )      From GLOBIENS
        Call GET_MNT_ARRONDI ( [F:DEPW]IMLBLC,     [M:FASR]CUR,  [F:DEPW]IMLBLC )     From GLOBIENS
        Call GET_MNT_ARRONDI ( [F:DEPW]PERCLOCUM , [M:FASR]CUR, [F:DEPW]PERCLOCUM  )  From GLOBIENS
        Call GET_MNT_ARRONDI ( [F:DEPW]PERCLOEXC,  [M:FASR]CUR,  [F:DEPW]PERCLOEXC)   From GLOBIENS
        Call GET_MNT_ARRONDI ( [F:DEPW]PERCLOCUMT, [M:FASR]CUR, [F:DEPW]PERCLOCUMT)   From GLOBIENS
        Call GET_MNT_ARRONDI ( [F:DEPW]PERCLOEXCT, [M:FASR]CUR, [F:DEPW]PERCLOEXCT )  From GLOBIENS
        Call GET_MNT_ARRONDI ( [F:DEPW]EXECLOCUMT, [M:FASR]CUR, [F:DEPW]EXECLOCUMT )  From GLOBIENS

        #FQ-67995 ------------------------------------------------------
        If ( [M:FASR]RVATIADAT = GVML_ERDBEX )
          [F:DEPW]NBV = [F:DEPW]DPRBAS - [F:DEPW]DPRCUM - [F:DEPW]IMLBLC
        Else
          [F:DEPW]NBV = [F:DEPW]DPRBAS - [F:DEPW]DPRCUM - [F:DEPW]PERCLOCUM -  [F:DEPW]PERCLOEXC - [F:DEPW]IMLBLC
        Endif
        #FQ-67995 ------------------------------------------------------
        #FQ-81475 [F:DEPW]NSPVAL     =  0
        #FQ-64311 [F:DEPW]RVAAMT     =  abs([F:DEPW]NBV - GNBVO)
        [F:DEPW]RVAAMT     =  [F:DEPW]NBV - GNBVO_C
      Endif
      #- 3 ---------------------------------------


      #FQ-64311 If ( [F:DEPW]RVAAMT = 0 )
      #FQ-77221 If ( [F:DEPW]RVAAMT = 0 or [F:DEPW]NBV < [F:DEP]RSDVAL )
      If ( [F:DEPW]RVAAMT = 0  )
        # "Montant réévaluation invalide"
        Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,[F:DEPW]DPRPLN,G_OUI,mess(400,GML_MSGFAS,1)) From TRCPROCOM
        LOK=G_NON
         #Fq-80075 Return
      Endif
    #- 2 -----------------------------------
    Else
      # "Coefficient invalide"
      Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,[F:DEPW]DPRPLN,G_OUI,mess(173,GML_MSGFAS,1)) From TRCPROCOM
      LOK=G_NON
         #Fq-80075 Return
    Endif
    #- 2 -----------------------------------
  Endif
  #- 1 -----------------------------------

  If (LOK = G_OUI and FLGDET = G_OUI)
    Call SEP_COMPTE_RENDU([F:MAS1]CPY)
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO,[F:MAS1]AASREF+"/"+[F:MAS1]AASDES1,0,1) From TRACEABX3
    Gosub ECR_DETAIL_OLD
  Endif


Return
#=====================================================================
################################################################################
# Traitement de gestion du compte-rendu- informations particulières à l'action
################################################################################
$GESTRACE

  Case TRTYP
    When 1
      # Ouverture
      If !clalev([F:XTRA]) : Local File TRCABX3 [XTRA] : Endif
      Call OUVRE_TRACE (mess(373,GML_MSGFAS,1),1)                                                  From TRACEABX3 # "Réévaluation : traitement massif"
    When 20
      # Paramètres à appliquer
      Call ECR_TRACE("",GTRC_PARAM,mess(374,GML_MSGFAS,1)-format$("DD2",[M:FASR]RVADAT),0,1)       From TRACEABX3 #  "Date d'effet  :"
      Call ECR_TRACE("",GTRC_PARAM,"",0,1)                                                  From TRACEABX3
      Call ECR_TRACE("",GTRC_PARAM,mess(375,GML_MSGFAS,1)-mess([M:FASR]DPRPLN,3101,1),0,1)          From TRACEABX3 # "Plan d'amortissement  :"
      If [M:FASR]PERSTRDAT <> [0/0/0]
        Call ECR_TRACE("",GTRC_PARAM,mess(376,GML_MSGFAS,1)-format$("DD2",[M:FASR]PERSTRDAT),0,1)  From TRACEABX3 # "Début période traitée  : "
        Call ECR_TRACE("",GTRC_PARAM,mess(377,GML_MSGFAS,1)-format$("DD2",[M:FASR]PERENDDAT),0,1)  From TRACEABX3 # "Fin période traitée  :  "
      Else
        Call ECR_TRACE("",GTRC_PARAM,mess(378,GML_MSGFAS,1)-format$("DD2",[M:FASR]FIYSTRDAT),0,1)  From TRACEABX3 # "Début exercice traité  :  "
        Call ECR_TRACE("",GTRC_PARAM,mess(379,GML_MSGFAS,1)-format$("DD2",[M:FASR]FIYENDDAT),0,1)  From TRACEABX3 # "Fin exercice traité  :   "
      Endif
      If [M:FASR]CCLRVAFLG <> G_OUI
        # Fq-85936
        Call ECR_TRACE("",GTRC_PARAM,mess(597,GML_MSGFAS,1)-mess([M:FASR]RVATIADAT,3273,1),0,1)     From TRACEABX3 # "Prise d'effet      :   "
        Call ECR_TRACE("",GTRC_PARAM,mess(380,GML_MSGFAS,1)-mess([M:FASR]RVATYP,3253,1),0,1)        From TRACEABX3 # "Mode réévaluation  :   "
      Else
        Call ECR_TRACE("",GTRC_PARAM,mess(381,GML_MSGFAS,1),0,1)                                   From TRACEABX3 # "Annulation de réévaluation  :  "
      Endif
    When Default
  Endcase

Return
#---------------------------------------------------------------------------------#
# Alimentation du coefficient ou de la valeur appliquée à chaque bien             #
#---------------------------------------------------------------------------------#
Subprog RECH_LTEXT_COMPTE_RENDU(PCLASSE,PMOD,LTEXT)
Value Char      PCLASSE         # Classe contenant les informations de sortie
Value Char      PMOD            # Mode réévaluation : Coefficient, Indice ou Valeur Marché
Variable Char   LTEXT

Local Decimal LVAL

 Case PMOD
   When (num$(GVML_MODIND))
     LVAL =  evalue(PCLASSE+"RVACOE")
     LTEXT = mess(382,GML_MSGFAS,1)-(format$("N:3.6",LVAL))  #  " Coeff. appliqué = "
   When (num$(GVML_MODCOE))
     LVAL =  evalue(PCLASSE+"RVACOE")
     LTEXT = mess(382,GML_MSGFAS,1)-(format$("N:3.6",LVAL))  # " Coeff. appliqué = "
   When (num$(GVML_MODVMA))
     LVAL = evalue(PCLASSE+"NSPVAL")
     LTEXT = mess(383,GML_MSGFAS,1)-(format$('N:'+GFMT3,LVAL)) # " Valeur marché = "
  Endcase
End
#=====================================================================
#--------------------------------------------------------------#
# Edition de l'en-tête du compte-rendu dans la trace           #
# à chaque rupture société                                     #
#--------------------------------------------------------------#
Subprog ENTETE_COMPTE_RENDU(PCPY)
Value Char PCPY

Local Char LIGNE(115)

  Call ECR_TRACE(PCPY,GTRC_CRACTIO,"",0,1) From TRACEABX3

  LIGNE =string$(115,"=") : Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
  LIGNE =space$(2)
  LIGNE+=left$(mess(002,3141,1)+space$(21),21)+"!"+space$(1)
  LIGNE+=space$(max(0,18-len(mess(510,GML_MSGFAS,1))))+mess(510,GML_MSGFAS,1) # Val. bilan rééval.
  LIGNE+=space$(max(0,18-len(mess(146,GML_MSGFAS,1))))+mess(146,GML_MSGFAS,1) # Valeur marché
  LIGNE+=space$(max(0,17-len(mess(511,GML_MSGFAS,1))))+mess(511,GML_MSGFAS,1) # Coefficient
  LIGNE+=space$(max(0,18-len(mess(147,GML_MSGFAS,1))))+mess(147,GML_MSGFAS,1) # Valeur nette
  LIGNE+=space$(max(0,18-len(mess(512,GML_MSGFAS,1))))+mess(512,GML_MSGFAS,1) # Montant rééval.
  Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
  LIGNE =string$(115,"=") : Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3

End
#--------------------------------------------------------------#
# Emission de la ligne  référence BCO / désignation dans la    #
# trace                                                        #
#--------------------------------------------------------------#
Subprog BCO_COMPTE_RENDU(PCPY,PREF,PDES,PSTATUS,PMES)
Value Char PCPY
Value Char PREF
Value Char PDES
Value Char PSTATUS
Value Char PMES

Local Char LIGNE(115)

  LIGNE ="  "
  LIGNE+=PREF
  LIGNE+=space$(20-len(PREF))
  LIGNE+="              ! "
  LIGNE+=PMES
  LIGNE+=space$(115-len(PMES))
  If (PSTATUS="Ok")
    Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
  Elsif (PSTATUS="Erreur")
    Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,1,1) From TRACEABX3
  Endif
End
#--------------------------------------------------------------#
# Emission d'un séparateur dans la trace                       #
#--------------------------------------------------------------#
Subprog SEP_COMPTE_RENDU(PCPY)
Value Char PCPY #FQ-70141
Local Char LIGNE(115)

  LIGNE="-------------------------------------------------------------------------------------------------------------------"
  Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
End

#=====================================================================
$ECR_DETAIL_OLD

  Local Char LIGNE(115)


  # anciennes  valeurs (ligne 1)
  LIGNE=left$(mess(212,GML_MSGFAS,1)+space$(23),23)+"!"+space$(1)
  LIGNE+=space$(18-len(format$('N:'+GFMT3,[F:DEP]DPRBAS)))+format$('N:'+GFMT3,[F:DEP]DPRBAS)
  LIGNE+=space$(19-len(format$('N:'+GFMT3,[F:DEP]NSPVAL)))+format$('N:'+GFMT3,[F:DEP]NSPVAL)
  LIGNE+=space$(13-len(format$('N:3.6',[F:DEP]RVACOE)))+format$('N:'+GFMT3,[F:DEP]RVACOE)
  #If (GCCLFLG = G_OUI)
  If (GCCLFLG <> G_OUI)
    LIGNE+=space$(18-len(format$('N:'+GFMT3,GNBVO_C)))+format$('N:'+GFMT3,GNBVO_C)
  Else
    LIGNE+=space$(18-len(format$('N:'+GFMT3,[F:DEP]NBV)))+format$('N:'+GFMT3,[F:DEP]NBV)
  Endif
  LIGNE+=space$(18-len(format$('N:'+GFMT3,[F:DEP]RVAAMT )))+format$('N:'+GFMT3,[F:DEP]RVAAMT)
  Call ECR_TRACE([F:MAS1]CPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
Return

#=====================================================================
$ECR_DETAIL_NEW

  Local Char LIGNE(115)

  # Nouvelles  valeurs (ligne 1)
  LIGNE=left$(mess(218,GML_MSGFAS,1)+space$(23),23)+"!"+space$(1)
  LIGNE+=space$(18-len(format$('N:'+GFMT3,[F:DEPW]DPRBAS)))+format$('N:'+GFMT3,[F:DEPW]DPRBAS)
  LIGNE+=space$(19-len(format$('N:'+GFMT3,[F:DEPW]NSPVAL)))+format$('N:'+GFMT3,[F:DEPW]NSPVAL)
  LIGNE+=space$(13-len(format$('N:3.6',[F:DEPW]RVACOE)))+format$('N:'+GFMT3,[F:DEPW]RVACOE)
  If (GCCLFLG <> G_OUI)
  LIGNE+=space$(18-len(format$('N:'+GFMT3,[F:DEPW]NBV)))+format$('N:'+GFMT3,[F:DEPW]NBV)
  Else
      LIGNE+=space$(18-len(format$('N:'+GFMT3,GNBVO_C)))+format$('N:'+GFMT3,GNBVO_C)
  Endif
  LIGNE+=space$(18-len(format$('N:'+GFMT3,[F:DEPW]RVAAMT )))+format$('N:'+GFMT3,[F:DEPW]RVAAMT)
  Call ECR_TRACE([F:MAS1]CPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
Return

#==========================================================================
# Génération d'un événement de Réévaluation ou d'Annulation de Réévaluation
#==========================================================================
$GENER_RVA_EVE

  Local Integer  LCDRET, LREVTCREE
  LCDRET = 0 #Fq-80075
  #Fq-64311
  If [F:DEPW]BSEVAL > 0 # Facture
     If ( [F:DEPW]RVAAMT < 0 )
        If ( [F:DEPW]EXERVADEV + [F:DEPW]PERRVADEV ) >= 0
           GRVADEVCHG = [F:DEPW]EXERVADEV+ [F:DEPW]PERRVADEV +[F:DEPW]RVAAMT
        Else
           GRVADEVCHG =  [F:DEPW]RVAAMT
        Endif
     Else #----- [F:DEPW]RVAAMT > 0
        If ( [F:DEPW]EXERVADEV + [F:DEPW]PERRVADEV ) < 0
           If abs(( [F:DEPW]EXERVADEV + [F:DEPW]PERRVADEV ) ) <= abs([F:DEPW]RVAAMT)
             GRVADEVCHG = -([F:DEPW]EXERVADEV + [F:DEPW]PERRVADEV )  # solde de la réserve
           Else
            GRVADEVCHG =  [F:DEPW]RVAAMT
           Endif
        Else
           GRVADEVCHG =  0
        Endif
     Endif
  Endif #Fq-64311
  If ( GCCLFLG <> G_OUI )
      If [F:DEPW]RVAAMT <> 0 #Fq-80075
        # Réévaluation
        Local Date LDATEVT, LDATCPT
        LCDINT  = "FASRVA"+num$([F:DEP]DPRPLN)
        LDATEVT = max([F:DEPW]RVADAT,    [F:DEPW]STRDPRDAT)
        LDATCPT = max([F:DEPW]PERSTRDAT, [F:DEPW]STRDPRDAT)
        #<<<Fq-79819  --------------------------
        If [F:DEPW]RVATIADAT = GVML_ERENDEX
          If ( [F:DEPW]RVATYP = GVML_MODVMA ) Then : # Fq-85936
            #* réévaluation fin exercice ==> on n'a pas toutes les infos pour alimenter
            #*les champs [DEPW] de l'événement
            #*
            If !(clalev([F:DEPS]))  : Local File DEPREC     [DEPS]  : Endif  # Sauve valeurs après rééval fin FIY
            [DEPS]  =  [DEPW]
            [F:DEPW]NBV        = [F:DEPS]NSPVAL
            [F:DEPW]DPRBAS     = [F:DEPS]NSPVAL
            [F:DEPW]DPRCUM     = 0
            [F:DEPW]DPRCUMFLG  = G_OUI
            [F:DEPW]PERCLOCUM  = 0
            [F:DEPW]PERCLOEXC  = 0
            [F:DEPW]EXECLOCUMT = 0
            [F:DEPW]PERCLOCUMT = 0
            [F:DEPW]PERCLOEXCT = 0
            [F:DEPW]EXETRFCUM  = 0
            [F:DEPW]EXEIMLCUM  = 0
            [F:DEPW]PERIMLCUM  = 0
            [F:DEPW]EXERVECUM  = 0
            [F:DEPW]PERRVECUM  = 0
            [F:DEPW]IMLBLC     = 0
            If ( [F:DEP]LSTCLODAT <> [0/0/0] or ([F:DEP]LSTCLODAT =  [0/0/0] and [F:DEP]STRDPRDAT < [F:DEP]FIYSTRDAT) )
               Local Integer LPRATYP
               Call GET_DPM_RSD([F:DEP]CPY, [F:DEP]DPM, [F:DEP]DPM, LPRATYP) From TRTFAS
               [F:DEP]DPMT    = [F:DEP]DPM
               If LPRATYP > 0
                 [F:DEP]PRATYP  = LPRATYP
               Endif
            Endif
          Else
            # Fq-85936
            If !(clalev([F:DEPS]))  : Local File DEPREC     [DEPS]  : Endif  # Sauve valeurs après rééval fin FIY
            [DEPS]  =  [DEPW]
            Call  CAL_RVACOE_ENDFIY ( [F:DEPW]RVACOE, func GLOFCYCPY.GET_DEVISE_PLN([F:DEP]CPY,[F:DEP]DPRPLN), [F:DEP]NBV,
&                     [F:DEP]DPRBAS,  [F:DEP]DPRCUM    ,[F:DEP]PERCLOCUM ,[F:DEP]PERENDDPE,
&                                     [F:DEP]EXCCUM    ,[F:DEP]PERCLOEXC ,[F:DEP]PEREXCDPR,
&                                     [F:DEP]EXECLOCUMT,[F:DEP]PERCLOCUMT,[F:DEP]DPET,
&                                     [F:DEP]EXCCUMT   ,[F:DEP]PERCLOEXCT,[F:DEP]PEREXCDPRT,
&                                     [F:DEP]EXETRFCUM ,[F:DEP]PERTRFCUM ,[F:DEP]IMLRVETRF,
&                                     [F:DEP]EXEIMLCUM ,[F:DEP]PERIMLCUM ,[F:DEP]IML,
&                                     [F:DEP]EXERVECUM ,[F:DEP]PERRVECUM ,[F:DEP]IMLRVE,
&                     [F:DEPW]DPRBAS, [F:DEPW]DPRCUM     ,[F:DEPW]PERCLOCUM  ,[F:DEPW]PERENDDPE,
&                                     [F:DEPW]EXCCUM     ,[F:DEPW]PERCLOEXC  ,[F:DEPW]PEREXCDPRT,
&                                     [F:DEPW]EXECLOCUMT ,[F:DEPW]PERCLOCUMT ,[F:DEPW]DPET,
&                                     [F:DEPW]EXCCUMT    ,[F:DEPW]PERCLOEXCT ,[F:DEPW]PEREXCDPR,
&                                     [F:DEPW]EXETRFCUM  ,[F:DEPW]PERTRFCUM  ,[F:DEPW]IMLRVETRF,
&                                     [F:DEPW]EXEIMLCUM  ,[F:DEPW]PERIMLCUM  ,[F:DEPW]IML,
&                                     [F:DEPW]EXERVECUM  ,[F:DEPW]PERRVECUM  ,[F:DEPW]IMLRVE,
&                                     [F:DEPW]IMLBLC, [F:DEPW]NBV, [F:DEPW]RVAAMT ) From GLOBB6
            GDPEO = [F:DEP]PERENDDPE
            GDPED = [F:DEPW]PERENDDPE
          Endif
        Else
           GDPEO = 0
        Endif  #>>> Fq-79819  ----

        Call GENER_EVE (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,LDATEVT,LDATCPT,LCDRET) From GENEVE
        If [F:DEPW]RVATIADAT = GVML_ERENDEX  #>>> Fq-79819
           [DEPW]  =  [DEPS]
        Endif  #>>> Fq-79819
        #Fq-67995 ---------
     Endif #Fq-80075
  Else
     # Annulation réévaluation
     If [F:DEPW]RVATIADAT = GVML_ERENDEX    #Fq-79819
     Else
       GRVADERRVE = 0
       GDPED = GDPEO
       GDPEO = 0
     Endif
     LCDINT= "FASRVA"+num$([F:DEP]DPRPLN)
     Call ANNULE_EVE (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,[F:DEP]RVADAT,LREVTCREE,LCDRET) From GENEVE
  Endif

  If (LCDRET)
    RMES = mess(173,GML_MSGFAS,1)-num$(LCDRET)
    GOK=0
  Endif

Return
######################################################################
# Sous-pro et routines communes
######################################################################
#=====================================================================
Subprog LAUNCH_ACT(PACTTYP)
Value Char PACTTYP

  Case PACTTYP
    When "U"
      Raz GPILOBJ
      Call DEFVAR From GLOBIMM
      Call INIVAR From GLOBIMM
      Call OBJET("FAS",GBIDC1,GBIDC2) From GOBJET
    When "M"
      Local Char PARAM(30)(1..5)
      Local Char VALEUR
      PARAM(1)="M"       # Massif / unitaire
      PARAM(2)="FASRVA"  # Nom de l'action métier
      PARAM(3)="2"       # Objet métier de référence
      PARAM(4)=num$(2)   # Mono société
      PARAM(5)=num$(2)   # Plan d'amortissement
      Call TRAITE_CHAR(VALEUR,PARAM,"","TRTFASRVA","FASRVAM",4,"") From GTRAITE
    When Default
  Endcase
End


######################################################################
#========================================================================
#  Gestion du masque FASRVA : Paramètres
#========================================================================

##################################
Subprog AS_DPRPLN(VALEUR)
Variable Integer VALEUR

Local  Integer LISTE_STD (1) : # liste des normes des plans qu'on veut conserver dans la combo
Local  Integer NBPLAN
Local  Integer LRSTD

  LISTE_STD = 0

  If ( ACTTYPGES=GTAMUNI )
    If ( dim(GPARMPLN) < 0 )
      Call VIRE_PLN_STD_NOK ([M:FAS0]CPY, LISTE_STD, NBPLAN) From GLOBIENS
    Else
      [M:FASR]DPRPLN = GPARMPLN
    Endif
  Else
    Call VIRE_PLN_STD_NOK ([M:MHC]CPY(find(G_OUI, [M:MHC]FLGCPY)-1), LISTE_STD, NBPLAN) From GLOBIENS
  Endif

  GMENLOC(G301AUC)=1
  GMENLOC(G301SUB)=1 #FQ-67995
  GMENLOC(G301FIS)=1 #FQ-67995
  GMENLOC(G301MIN)=1 #FQ-67995
  GMENLOC(G301ORI)=1 #FQ-67995
  GMENLOC(G301R76)=1 #FQ-67995


End
##################################
Subprog AM_DPRPLN(VALEUR)
Variable Integer VALEUR
Local Integer  LCDRET
Local Char     LMESSAGE
Local Integer I_PLN   #Fq-67995
  #Infbox "TRTFASRVA AM-DPRPLN"
  # Chargement des dates de l'exercice courant et de la période courante
  Raz  [M:FASR]FIYSTRDAT
  Raz  [M:FASR]FIYENDDAT
  Raz  [M:FASR]PERSTRDAT
  Raz  [M:FASR]PERENDDAT

  If ( ACTTYPGES=GTAMUNI )
    # FQ-81475  Raz    [M:FASR]NSPVAL
    GCPY = [M:FAS0]CPY
    #Fq-67995
    #Fq-79819    If func GLOFCYCPY.GET_SOC_PAYS( [M:FAS0]CPY ) = "FR"
    If [M:FPC]LEG="FRA"
       G_RVALIB = G_OUI
    Endif
  Else
    GCPY = [M:MHC]CPY(find(G_OUI, [M:MHC]FLGCPY)-1)
    If func GLOFCYCPY.GET_SOC_PAYS(GCPY) = "FR"  #Fq-67995
       G_RVALIB = G_OUI
    Endif
  Endif

  Call GET_CNX_FROM_PLAN (GCPY, VALEUR, GCNX) From GLOBIENS
  Read [CNX]CNX0=GCPY;GCNX
  I_PLN = find(VALEUR,[F:CNX]PLNCAA(0..[F:CNX]NBPLC-1))
  If I_PLN > 0
     If ( [F:CNX]PLNSTD(I_PLN-1) <> GVML_NPIAS ) and ( G_RVALIB= G_OUI )
        G_RVALIB = G_OUI
     Else
        G_RVALIB = G_NON
     Endif
  Endif #Fq-67995E

  [M:FASR]CUR = [F:CNX]CUR
  # Lecture de l'exercice courant du plan modèle
  Read [FIS]FIY1=GCPY;GCNX;GVML_TECOURA
  [M:FASR]FIYSTRDAT = [F:FIS]DATSTRFIY
  [M:FASR]FIYENDDAT = [F:FIS]DATENDFIY
  GINDCURPER = [F:FIS]INDCURPER
  [M:FASR]PERSTRDAT = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
  [M:FASR]PERENDDAT = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
  If ([M:FASR]RVATIADAT = GVML_ERDBPE)
    [M:FASR]RVADAT    = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
  Else
    [M:FASR]RVADAT    = [F:FIS]DATSTRFIY
  Endif
   #Fq-67995
  If G_RVALIB=G_OUI
    [M:FASR]RVATIADAT = GVML_ERDBEX
    Affzo [M:FASR]RVATIADAT
 Endif
 #Fq-67995E
  Affzo [M:FASR]5
  #-1 --------------------------
  If ( ACTTYPGES=GTAMUNI )

    # Affectation de RVATIADAT
    # Si une réévaluation avec prise d'effet "Début de période" dans les périodes closes de l'exercice
    # la réévaluation de la période doit prendre aussi effet début de période
    Filter [DEP] Where AASREF    = [M:FAS0]AASREF
&                  and DPRPLN    = [M:FASR]DPRPLN
&                  and FIYENDDAT = [M:FASR]FIYENDDAT
&                  and PERENDDAT < [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
&                  and RVATIADAT <> 0
    Read[DEP] Last
    Filter [DEP]
    If ( fstat = 0 and [F:DEP]RVATIADAT = GVML_ERDBPE )
      [M:FASR]RVATIADAT = GVML_ERDBPE : Affzo [M:FASR]RVATIADAT : Diszo [M:FASR]RVATIADAT
    Endif

    #==
    Read [DEP]DEP0 =[M:FAS0]AASREF;VALEUR;[M:FASR]FIYENDDAT;[M:FASR]PERENDDAT
    #-2 --------------------------
    If !(fstat)
      # Valeur nette début de période :
      [F:DEPC] = [F:DEP]
      #Fq-79819 si date prise d'effet <> fin exercice
      If [M:FASR]RVATIADAT <> GVML_ERENDEX   #Fq-79819
        #Fq-89419 If ( [M:FASR]RVATIADAT = GVML_ERDBEX and [M:FASR]RVATYP <> GVML_MODVMA )   or ( G_RVALIB = G_OUI )
        #Fq-XXXXX pourquoi test sur VMA ??
        If ( [M:FASR]RVATIADAT = GVML_ERDBEX )   or ( G_RVALIB = G_OUI )
          Call CAL_VALEUR_NETTE ( "RDE", [F:DEPC]DPRBAS, 2, 0, GNBVO_C  ) From GLOBB4
          Call CAL_VALEUR_NETTE ( "TDE", [F:DEPC]DPRBAS, 2, 0, GNBVTO ) From GLOBB4
        Else
          If  G_RVALIB <> G_OUI
             Call CAL_VALEUR_NETTE ( "RDP", [F:DEPC]DPRBAS, 2, 0, GNBVO_C  ) From GLOBB4
             Call CAL_VALEUR_NETTE ( "TDP", [F:DEPC]DPRBAS, 2, 0, GNBVTO ) From GLOBB4
          Endif
        Endif
      Else   #Fq-79819 si date prise d'effet= fin exercice
         GNBVO_C=[F:DEP]NBV
         GNBVTO =[F:DEP]NBVT
      Endif
      GNBVO=GNBVO_C
      #Fq-64311 If ( [F:DEP]NSPVAL > 0 )   : [M:FASR]NSPVAL = [F:DEP]NSPVAL : Endif
      If ( [F:DEP]NSPVAL <> 0 )   : [M:FASR]NSPVAL = [F:DEP]NSPVAL : Endif

      If ([F:DEP]PERSTRDAT <> [F:DEP]FIYSTRDAT and [M:FASR]RVATIADAT = GVML_ERDBEX and
&       func TRTFASRVA.EXISTE_MTC ([M:FAS0]AASREF, VALEUR, [F:DEP]FIYSTRDAT, [F:DEP]PERENDDAT) )
        # "Réévaluation début exercice impossible si changement de méthode dans l'exercice"
        # Passage en début de période
        [M:FASR]RVATIADAT = GVML_ERDBPE
        Affzo [M:FASR]RVATIADAT
      Endif
      #==
      If ( [F:DEP]DFDBLC <> 0 or [F:DEP]DFD <> 0 or [F:DEP]DFDRVE <> 0 )
        # "Réévaluation impossible si le plan possède de l'amortissement différé"
        GMESSAGE=mess(602,GML_MSGFAS,1) : mkstat = 2 : GERR=1 : End
      Endif
      #==
      If ([F:DEP]STRDPRDAT > [M:FASR]PERENDDAT)
         # date debamort > date fin période courante
        GMESSAGE=mess(389,GML_MSGFAS,1) : mkstat = 2 : GERR=1 : End
      Endif
      #==
      If  ( [F:DEP]IMLRVELIM <> 0 )
        # le bien a un plafond de dépréciation
        GMESSAGE=mess(240,GML_MSGFAS,1) : mkstat = 2 : GERR=1 : End
      Endif
      #==
      If ([M:FASR]RVATYP = GVML_MODVMA and [F:DEP]LSTCLODAT = [0/0/0] and [M:FASR]RVATIADAT = GVML_ERDBPE and
&         [F:DEP]STRDPRDAT >= [F:DEP]FIYSTRDAT and [F:DEP]STRDPRDAT < [F:DEP]PERSTRDAT )
        # "Si le bien n'a pas encore subi de clôture la prise d'effet ne peut être que "Début Exe."
        GMESSAGE=mess(605,GML_MSGFAS,1) : GERR=1 : mkstat = 2 :  End
      Endif
      #=======================================
      If ( [F:DEP]BSEVAL < 0 )    #Fq-65178
        # Le bien a une base d'amortissement négative, il ne peut pas être réévalué
        GMESSAGE=mess(807,GML_MSGFAS,1) : mkstat = 2 : GERR=1 :  End
      Endif
      #==
      If  ( [F:DEP]IML <> 0 or [F:DEP]IMLRVE <> 0 )
        # Ce plan a déjà été déprécié dans la période
        GMESSAGE=mess(425,GML_MSGFAS,1) : mkstat = 2 : GERR=1 :  End
      Endif
      #==
      If  ( [F:DEP]DPM = G_DPMCA )
        # Un plan amorti selon le mode "CA" ne peut pas être réévalué
        GMESSAGE=mess(611,GML_MSGFAS,1) : mkstat = 2 : GERR=1 :  End
      Endif
      #==
      If ([M:FASR]CCLRVAFLG <> G_OUI and [F:DEP]STRDPRDAT > [M:FASR]PERENDDAT)
        # le bien a une date de début d'amortissement > fin période courante
        GMESSAGE=mess(389,GML_MSGFAS,1) : mkstat = 2 : GERR=1 :  End
      Endif
      #==
      #FQ-64311 If  ( [F:DEP]RVAAMT > 0  )
      If  ( [F:DEP]RVAAMT <> 0  )
        [M:FASR]CCLRVAFLG = G_OUI : Affzo[M:FASR]CCLRVAFLG : Diszo[M:FASR]CCLRVAFLG
        # le flag d'annulation est actif : on grise les boutons OK et CONTROLER
        # tant que l'utilisateur n'a pas coché la case "Annulation de la rééval."
        Diszo [M:FASR]RVACOEREF : Diszo [M:FASR]RVACOE  : Diszo [M:FASR]RVATIADAT
        Diszo [M:FASR]NSPVAL    : Diszo [M:FASR]RVAAPR  : Diszo [M:FASR]RVACMT
        #Fq-79819 [M:FASR]RVATYP = 0      : Affzo [M:FASR]RVATYP  : Diszo [M:FASR]RVATYP
        [M:FASR]RVATYP = [F:DEP]RVATYP     : Affzo [M:FASR]RVATYP  : Diszo [M:FASR]RVATYP
        [M:FASR]RVATIADAT = [F:DEP]RVATIADAT     : Affzo [M:FASR]RVATIADAT  : Diszo [M:FASR]RVATIADAT #Fq-79819
        # Ce bien a déjà été réévalué dans la période : vous devez d'abord annuler cette réévaluation
        # On ne met pas de mkstat = 2 car dans ce cas on peut continuer par l'annulation de réévaluation
        GERR=1 : GMESSAGE=mess(134,GML_MSGFAS,1)
      Else
        [M:FASR]CCLRVAFLG = G_NON : Affzo[M:FASR]CCLRVAFLG : Diszo [M:FASR]CCLRVAFLG
        Actzo [M:FASR]RVACOEREF : Actzo [M:FASR]RVACOE  : Actzo [M:FASR]RVATIADAT
        #Fq-67995
        If G_RVALIB <> G_OUI
           Actzo [M:FASR]NSPVAL    : Actzo [M:FASR]RVAAPR  : Actzo [M:FASR]RVACMT
         Endif #Fq-67995E
        [M:FASR]RVATYP = 0      : Affzo [M:FASR]RVATYP  : Actzo [M:FASR]RVATYP
      Endif
    Endif
    #-2 --------------------------
    # Valeur nette début période
    [F:DEPC] = [F:DEP]
    #Fq-79819 si date prise d'effet <> fin exercice
    If  [M:FASR]RVATIADAT <> GVML_ERENDEX
          #Fq-79819 If ( [M:FASR]RVATIADAT = GVML_ERDBEX and [M:FASR]RVATYP <> GVML_MODVMA )   or ( G_RVALIB = G_OUI )
          If ( [M:FASR]RVATIADAT = GVML_ERDBEX )   or ( G_RVALIB = G_OUI )
          Call CAL_VALEUR_NETTE ( "RDE", [F:DEPC]DPRBAS, 2, 0, GNBVO_C  ) From GLOBB4
          Call CAL_VALEUR_NETTE ( "TDE", [F:DEPC]DPRBAS, 2, 0, GNBVTO ) From GLOBB4
       Else
          If  G_RVALIB <> G_OUI
             Call CAL_VALEUR_NETTE ( "RDP", [F:DEPC]DPRBAS, 2, 0, GNBVO_C  ) From GLOBB4
             Call CAL_VALEUR_NETTE ( "TDP", [F:DEPC]DPRBAS, 2, 0, GNBVTO ) From GLOBB4
          Endif
       Endif
    Else #Fq-79819 si date prise d'effet= fin exercice
       GNBVO_C =   [F:DEP]NBV
       GNBVTO  =   [F:DEP]NBVT
    Endif
       [M:FASR]NBVO = GNBVO_C : Affzo [M:FASR]NBVO
    GNBVO = GNBVO_C
    GCCLFLG =  [M:FASR]CCLRVAFLG
  #-1 --------------------------
  Else
    # En massif en cas de changement de plan on repasse l'annulation à non
    [M:FASR]CCLRVAFLG = G_NON : Affzo[M:FASR]CCLRVAFLG : Actzo[M:FASR]CCLRVAFLG
  Endif
  #-1 --------------------------

  Affzo [M:FASR]5

  # Si le plan est modifié et que l'on est déjà passé par Contrôler
  If ( ACTSTATUS = 8 )
    If ( ACTTYPGES = GTAMMAS )
      Call ACTCHGCRIT From TRCPROCOM
      # Si abandon sur ACTCHGCRIT mkstat= 2.
      If ( mkstat <> 0 )   : End : Endif
    Else
      Call CHGACTPARM From TRTFASRVA
    Endif
  Endif

End

##################################
Subprog AP_DPRPLN(VALEUR)
Variable Integer VALEUR

End
##################################
Subprog C_DPRPLN(VALEUR)
Variable Integer VALEUR

End
##################################
Subprog AM_CCLRVAFLG(VALEUR)
Variable Integer VALEUR

  GCCLFLG =  VALEUR
  #-1 -----------------
  If ( VALEUR = G_OUI )
    # Anulation réévaluation
    Raz[M:FASR]RVACOEREF  : Diszo[M:FASR]RVACOEREF
    Raz[M:FASR]RVACOE     : Diszo[M:FASR]RVACOE
    [M:FASR]RVATIADAT = 0 : Diszo[M:FASR]RVATIADAT
    [M:FASR]RVATYP    = 0 : Diszo[M:FASR]RVATYP
    Raz[M:FASR]RVAAPR     : Diszo[M:FASR]RVAAPR
    Raz[M:FASR]RVACMT     : Diszo[M:FASR]RVACMT
    Diszo [M:FASR]DPRPLN
    If ( ACTTYPGES = GTAMUNI )
      [M:FASR]CCLRVAFLG = VALEUR : Diszo [M:FASR]CCLRVAFLG
      Diszo[M:FASR]NSPVAL
    Endif
  #-1 -----------------
  Else
    # Réévaluation
    If ( ACTTYPGES=GTAMMAS )
      Actzo [M:FASR]
      If ( [M:FASR]CCLRVAFLG = G_OUI)   : Diszo [M:FASR]CCLRVAFLG : Endif
      Effzo [M:FASR]
      # En V5 toujours à Oui ( à faire évoluer en V5.1)
      [M:FASR]RVADEVFLG = G_OUI : Affzo [M:FASR]RVADEVFLG : Diszo [M:FASR]RVADEVFLG
      zonsui = "[M:FASR]DPRPLN"
    Endif
  Endif
  #-1 -----------------

  # Si le flag est modifié et que l'on est déjà passé par Contrôler
  If ( ACTSTATUS = 8 )
    Call CHGACTPARM From TRTFASRVA
  Endif

End
######################################################################################
## Fq-67995 Etiquette ajoutée par le superviseur (écran FASRVA) 10/01/2011 11:54:48 (MDJ)
######################################################################################
Subprog AS_RVATIADAT(VALEUR)
Variable Integer VALEUR

  #*FQ-79819
  If [M:FASR]PERENDDAT <> [M:FASR]FIYENDDAT
    GMENLOC(GVML_ERENDEX) = 1
  Endif

 #Fq-67995
 If G_RVALIB=G_OUI
   GMENLOC(GVML_ERDBPE)  = 1
   GMENLOC(GVML_ERENDEX) = 1  #Fq-79819 pas de prise effet fin exercice si Réévaluation libre
   [M:FASR]RVATIADAT = GVML_ERDBEX
   Affzo [M:FASR]RVATIADAT
 Endif
 #Fq-67995E

End
##################################
Subprog AM_RVATIADAT(VALEUR)
Variable Integer VALEUR

  #*Fq-79819 si prise d'effet fin exercice ==> mode rééval. = uniquement valeur marché
  If VALEUR = GVML_ERENDEX
    [M:FASR]RVATYP = GVML_MODVMA
    Affzo [M:FASR]RVATYP
    Diszo [M:FASR]RVACOEREF
    Actzo  [M:FASR]RVAAPR  #*FQ-85936
    If  ( ACTTYPGES=GTAMUNI )
      GNBVO_C = [F:DEP]NBV
      [M:FASR]NBVO = GNBVO_C
      GNBVO = GNBVO_C
    Endif
  Endif

  #-1 --------------------------
  If ( ACTTYPGES=GTAMUNI )
    If ([F:DEP]PERSTRDAT <> [F:DEP]FIYSTRDAT and VALEUR = GVML_ERDBEX and
&     func TRTFASRVA.EXISTE_MTC ([M:FAS0]AASREF, [F:DEP]DPRPLN, [F:DEP]FIYSTRDAT, [F:DEP]PERENDDAT) )
      # "Réévaluation début exercice impossible si changement de méthode dans l'exercice"
      GMESSAGE=mess(600,GML_MSGFAS,1) : mkstat = 2 : GERR=1 : End
    Endif
    If ([M:FASR]RVATYP = GVML_MODVMA and [F:DEP]LSTCLODAT = [0/0/0] and VALEUR = GVML_ERDBPE and
&         [F:DEP]STRDPRDAT >= [F:DEP]FIYSTRDAT and [F:DEP]STRDPRDAT < [F:DEP]PERSTRDAT )
      # "Si le bien n'a pas encore subi de clôture la prise d'effet ne peut être que "Début Exe."
      GMESSAGE=mess(605,GML_MSGFAS,1) : GERR=1 : mkstat = 2 :  End
    Endif
    #*Fq-79819 le bien doit être recalculé avant réévaluation fin exercice
    If VALEUR = GVML_ERENDEX and [M:FAS0]FLGCNXCLC([F:DEP]CNX-1) = G_OUI
      # GMESSAGE=mess(nnn,GML_MSGFAS,1)
      GMESSAGE= "le bien doit être recalculé avant réévaluation fin exercice"
      mkstat = 2 : GERR=1 : End
    Endif
  Endif
  #-1 --------------------------
   #*Fq-84817   Case VALEUR
   #*Fq-84817      When GVML_ERDBPE  : [M:FASR]RVADAT   = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
   #*Fq-84817      When GVML_ERENDEX : [M:FASR]RVADAT   = [F:FIS]DATENDFIY  #*Fq-79819
   #*Fq-84817      When Default      : [M:FASR]RVADAT   = [F:FIS]DATSTRFIY
   #*Fq-84817   Endcase
   Case VALEUR
      When GVML_ERDBPE  : [M:FASR]RVADAT   = [M:FASR]PERSTRDAT
      When GVML_ERENDEX : [M:FASR]RVADAT   = [M:FASR]FIYENDDAT
      When Default      : [M:FASR]RVADAT   = [M:FASR]FIYSTRDAT
   Endcase
   Affzo [M:FASR]RVADAT

  #== Fq-91891 Si prise d'effet modifiée ==> recalcul de la valeur nette selon prise d'effet
  If (ACTTYPGES = GTAMUNI) and (VALEUR <> [M:FASR]RVATIADAT)
    Read [DEP]DEP0 =[M:FAS0]AASREF;[M:FASR]DPRPLN;[M:FASR]FIYENDDAT;[M:FASR]PERENDDAT
    #-2 --------------------------
    If !(fstat)
      # Valeur nette début de période :
      [F:DEPC] = [F:DEP]
      # si date prise d'effet <> fin exercice
      If VALEUR<> GVML_ERENDEX
        If ( VALEUR= GVML_ERDBEX )   or ( G_RVALIB = G_OUI )
          Call CAL_VALEUR_NETTE ( "RDE", [F:DEPC]DPRBAS, 2, 0, GNBVO_C  ) From GLOBB4
          Call CAL_VALEUR_NETTE ( "TDE", [F:DEPC]DPRBAS, 2, 0, GNBVTO )   From GLOBB4
        Else
          If  G_RVALIB <> G_OUI
             Call CAL_VALEUR_NETTE ( "RDP", [F:DEPC]DPRBAS, 2, 0, GNBVO_C  ) From GLOBB4
             Call CAL_VALEUR_NETTE ( "TDP", [F:DEPC]DPRBAS, 2, 0, GNBVTO )   From GLOBB4
          Endif
        Endif
      Else  # si date prise d'effet= fin exercice
         GNBVO_C=[F:DEP]NBV
         GNBVTO =[F:DEP]NBVT
      Endif
      GNBVO=GNBVO_C
      If ( [F:DEP]NSPVAL <> 0 )
         [M:FASR]NSPVAL = [F:DEP]NSPVAL
      Endif
      [M:FASR]NBVO = GNBVO_C : Affzo [M:FASR]NBVO
      GNBVO = GNBVO_C
     Endif
     Affzo [M:FASR]
  Endif
  #== Fq-91891

  # Si le mode de réévaluation est modifié et que l'on est déjà passé par Contrôler
  If ( ACTSTATUS = 8 ) :   Call CHGACTPARM : Endif

End
##################################
Subprog C_RVADAT(VALEUR)
Variable Date    VALEUR

  If ( VALEUR < [M:FASR]PERSTRDAT or VALEUR > [M:FASR]PERENDDAT )
    # date de réévaluation non comprise dans la période
    GERR=1   : GMESSAGE=mess(531,GML_MSGFAS,1) : mkstat=2 : End
  Endif

End
######################################################################################
## Fq-79819 (écran FASRVA) 12/09/2012 10:25:34 (MDJ)
######################################################################################
Subprog AS_RVATYP(VALEUR)
Variable Integer VALEUR

  #*Fq-79819 si prise d'effet fin exercice ==> mode rééval. = uniquement valeur marché
  If [M:FASR]RVATIADAT = GVML_ERENDEX
    Actzo [M:FASR]NSPVAL
  Endif
  #             si prise d'effet fin exercice ==> mode rééval. = ouverture aux autres types de réévaluaion
#  If [M:FASR]RVATIADAT = GVML_ERENDEX
#    GMENLOC(GVML_MODCOE)= 1
#    GMENLOC(GVML_MODIND)= 1
#    Raz [M:FASR]RVACOEREF :  Diszo [M:FASR]RVACOEREF
#    Raz [M:FASR]RVACOE    :  Diszo [M:FASR]RVACOE
#    Actzo [M:FASR]NSPVAL
#  Endif

End

##################################
Subprog AM_RVATYP(VALEUR)
Variable Integer VALEUR


  [M:FASR]RVACOEREF = ""
  [M:FASR]RVACOE = 0
  Effzo [M:FASR]RVAAPR
  Effzo [M:FASR]ZRVAAPR
  If (ACTTYPGES = GTAMUNI)
    # DEB FQ-81475
    #Effzo [M:FASR]NSPVAL
    If([F:DEP]NSPVAL <> 0)
      [M:FASR]NSPVAL = [F:DEP]NSPVAL
      Affzo [M:FASR]NSPVAL
    Endif
    Actzo[M:FASR]NSPVAL
    # FIN FQ-81475
    If (VALEUR= GVML_MODVMA and [F:DEP]LSTCLODAT = [0/0/0] and [M:FASR]RVATIADAT= GVML_ERDBPE and
&         [F:DEP]STRDPRDAT >= [F:DEP]FIYSTRDAT and [F:DEP]STRDPRDAT < [F:DEP]PERSTRDAT )
      # "Si le bien n'a pas encore subi de clôture la prise d'effet ne peut être que "Début Exe."
      GMESSAGE=mess(605,GML_MSGFAS,1) : GERR=1 : mkstat = 2 :  End
    Endif
  Endif
  #------------------
  Case VALEUR
    When GVML_MODVMA
      Raz [M:FASR]RVACOEREF :  Diszo [M:FASR]RVACOEREF
      Raz [M:FASR]RVACOE    :  Diszo [M:FASR]RVACOE
      If G_RVALIB <> G_OUI  #Fq-67995
        Actzo [M:FASR]RVAAPR
      Endif
      Actzo [M:FASR]RVACMT
      If (ACTTYPGES = GTAMUNI)
        #FQ-64311 If([F:DEP]NSPVAL > 0)
        If([F:DEP]NSPVAL <> 0)
          [M:FASR]NSPVAL = [F:DEP]NSPVAL
        Endif
        Actzo[M:FASR]NSPVAL
      Endif
    When GVML_MODCOE
      Actzo [M:FASR]RVACOEREF
      Actzo [M:FASR]RVACOE
      Actzo [M:FASR]RVACMT
      If (ACTTYPGES = GTAMUNI)
        # FQ-81475 Raz [M:FASR]NSPVAL
        Diszo[M:FASR]NSPVAL
      Endif
      Raz [M:FASR]RVAAPR  :  Diszo [M:FASR]RVAAPR
    When GVML_MODIND
      Actzo [M:FASR]RVACOEREF
      Raz [M:FASR]RVACOE  :  Diszo[M:FASR]RVACOE
      If (ACTTYPGES = GTAMUNI)
        # FQ-81475 Raz [M:FASR]NSPVAL
        Diszo[M:FASR]NSPVAL
      Endif
      Raz [M:FASR]RVAAPR  :  Diszo [M:FASR]RVAAPR
      Actzo [M:FASR]RVACMT
    When Default
  Endcase
  #------------------

  # Si le mode de réévaluation est modifié et que l'on est déjà passé par Contrôler
  If ( ACTSTATUS = 8 )
    If ( ACTTYPGES = GTAMMAS )
      Call ACTCHGCRIT From TRCPROCOM
    Else
      Call CHGACTPARM From TRTFASRVA
    Endif
  Endif

End
##################################
Subprog C_RVACOEREF(VALEUR)
Variable Char    VALEUR()

  If (VALEUR = "" and [M:FASR]RVATYP = GVML_MODIND and [M:FASR]CCLRVAFLG <> G_OUI )
    # Coef de rééval. "Obligatoire si mode de réévaluation = Indice "
    GERR=1 :   GMESSAGE=mess(175,GML_MSGFAS,1) : mkstat=2 : End
  Endif

  If (VALEUR <>  "" and [M:FASR]RVATYP = GVML_MODVMA)
    #  " Interdit si mode de réévaluation = Valeur Marché "
    GERR=1 :  GMESSAGE=mess(176,GML_MSGFAS,1) :  mkstat=2 : End
  Endif

End
##################################
Subprog AM_RVACOEREF(VALEUR)
Variable Char VALEUR

# Table de référence de coefficients :
#                     - rubrique OB si Mode de Réévaluation = "Indice"
#                     - rubrique FA si Mode de Réévaluation = "Coefficient"
#                     - rubrique I si Mode de Réévaluation = "Valeur marché"
#  récupération du coefficient ou de l'indice à appliquer, dans la
#                             table de référence sélectionnée
Local Integer PLIGNE
Local Integer LMOIS, LANNEE
Local Char LNAT
Local Decimal COEFF, LCOEFF

  #-1 -----------------------
  If ( VALEUR = "")
    Actzo [M:FASR]RVACOE
  #-1 -----------------------
  Else
    Effzo [M:FASR]RVACOE  :   Diszo [M:FASR]RVACOE
    Read[COH]COH0=VALEUR  : # FQ79483
   #-2 -----------------------
   If !(fstat)
      #-3 ---------------------
      If  (ACTTYPGES=GTAMUNI)
        Case  [F:COH]CRITDAT
          When GVML_DATACH  :  LMOIS = month([M:FAS1]PURDAT)    :  LANNEE = year([M:FAS1]PURDAT)
          When GVML_DATCPT  :  LMOIS = month([M:FAS1]AASIPTDAT) :  LANNEE = year([M:FAS1]AASIPTDAT)
          When GVML_DATMES  :  LMOIS = month([M:FAS1]ITSDAT)    :  LANNEE = year([M:FAS1]ITSDAT)
          When Default
        Endcase
        Case  [F:COH]CRITNAT
          When GVML_NATFAM  :  LNAT = [M:FAS1]ACGGRP
          When GVML_NATCCO  :  LNAT = [M:FAS1]ACCCOD
          When Default
        Endcase
        Gosub RECH_COEFF
        [M:FASR]RVACOE = COEFF
        #Fq-64311 If ([M:FASR]RVACOE > 1)
        If ([M:FASR]RVACOE > 0)
          Diszo [M:FASR]RVACOE
        Else
          [M:FASR]RVACOE = 1
          Actzo[M:FASR]RVACOE
        Endif
      Endif
      #-3 ---------------------
    Endif
    #-2 -----------------------
    # Si la table de référence des coeff est modifiée et que l'on est déjà passé par Contrôler
    # on n'utilise pas ici le sous-programme de TRCPROCOM car l'on veut recharger la table temporaire
    # pour appliquer les différents coefficients à la population de biens
    If ( ACTSTATUS = 8  ) :   Call CHGACTPARM  : Endif
  Endif
  #-1 -----------------------

End
#---------------------------------
$SEL_TABCOE

  # SEL_TABCOE : liste des tables de référence dans la table RVACOEH
  Local Char CODFIC    : CODFIC = "RVACOEH"

  OBJET = "COE"
  If (ACTTYPGES = GTAMUNI)
    If [M:FAS1]ACGGRP=""
      # Inutile de proposer des coefficient pas famille si le bien n'a pas de famille
      CRITERE = '((CPY=[M:FAS0]CPY) or (CPY="" and LEG=[M:FPC]LEG)) and CRITNAT=GVML_NATCCO'
    Else
      CRITERE = '(CPY=[M:FAS0]CPY) or (CPY="" and LEG=[M:FPC]LEG)'
    Endif
  Else
    CRITERE = '(CPY=[M:MHC]CPY(find(G_OUI, [M:MHC]FLGCPY)-1)) or (CPY="" and LEG=[M:FPC]LEG)'
  Endif
  Default File [COH]
  Affzo [M:FASR]

  DEFPAG=1 : # FQ79483
Return
##################################
Subprog AV_RVACOE(VALEUR)
Variable Decimal VALEUR
  If ([M:FASR]RVATYP = GVML_MODVMA)
    Diszo [M:FASR]RVACOE
  Else
    If (ACTTYPGES = GTAMUNI)   : Diszo [M:FASR]NSPVAL : Endif
    Diszo [M:FASR]RVAAPR
  Endif

End
##################################
Subprog AM_RVACOE(VALEUR)
Variable Decimal VALEUR

Local Char MES
Local Integer ERR

  If (ACTTYPGES = GTAMMAS)
    #FQ-64311 If (VALEUR <= 1)  or ([M:FASR]RVATYP = GVML_MODVMA)
      If (VALEUR <= 0)  or ([M:FASR]RVATYP = GVML_MODVMA)
      # " Coefficient invalide "
      GERR=1 :   GMESSAGE=mess(173,GML_MSGFAS,1) : mkstat=2 : End
    Endif
  Endif


  If (ACTTYPGES = GTAMUNI)
    Local Decimal L_NBV  : # Valeur nette réévaluée estimée
    Call GET_MNT_ARRONDI (GNBVO_C * VALEUR,     [M:FASR]CUR, L_NBV)      From GLOBIENS
    [M:FASR]RVAAMT =  L_NBV-GNBVO_C      #Fq-85936
    Affzo [M:FASR]RVAAMT                                 #Fq-85936
  Endif

  # En unitaire : si le coefficient est modifié et que l'on est déjà passé par Contrôler
  If ( ACTSTATUS = 8 ) :   Call CHGACTPARM  : Endif

End
##################################
Subprog C_RVACOE(VALEUR)
Variable Decimal VALEUR


  If ( [M:FASR]DPRPLN <> 0 )
    If ([M:FASR]RVATYP = GVML_MODCOE and [M:FASR]CCLRVAFLG <> G_OUI)
      If (VALEUR = 0 and ACTTYPGES = GTAMUNI)
        # Coef. de rééval. : "obligatoire si mode de réévaluation = Coefficient "
        GERR=1 :  GMESSAGE=mess(177,GML_MSGFAS,1) : mkstat=2 : End
      Else
        #FQ-64311 If ( (ACTTYPGES = GTAMUNI and VALEUR <= 1) )
        If ( (ACTTYPGES  =  GTAMUNI and  VALEUR <= 0) )
          # " Coefficient doit être > 1"
          GERR=1 :   GMESSAGE=mess(384,GML_MSGFAS,1) : mkstat=2 : End
        Endif
      Endif
    Endif
  Endif



End
##################################
Subprog AM_NSPVAL(VALEUR)
Variable Decimal VALEUR

Local Integer PLIGNE

If ( [M:FASR]RVATYP = GVML_MODVMA )
  If (VALEUR = 0 and [M:FASR]CCLRVAFLG <> G_OUI)
    # Obligatoire si mode de réévaluation = Valeur Marché
    GERR=1 : GMESSAGE=mess(178,GML_MSGFAS,1) : mkstat=2 : End
  Endif

  If (ACTTYPGES = GTAMUNI)
    If (GNBVO_C < 0 and VALEUR >= 0 ) or ( GNBVO_C > 0 and ( VALEUR <= 0 or VALEUR <[M:FASR]RSDVAL ))
      GERR=1 :   GMESSAGE=mess(395,GML_MSGFAS,1) : mkstat=2 : End
    Endif
    #FQ-64311 If ([M:FASR]RVATYP = GVML_MODVMA and VALEUR <= GNBVO)
    #FQ-64311 Valeur Marché ne doit pas être < VNC début période
    If ( VALEUR = GNBVO_C )
      GERR=1 : GMESSAGE=mess(805,GML_MSGFAS,1): mkstat=2 : End
    Endif

    [M:FASR]RVAAMT =  VALEUR -GNBVO_C      #Fq-79819
    Affzo [M:FASR]RVAAMT                   #Fq-79819
  Endif
  Actzo  [M:FASR]RVAAPR
Endif


  # Si le mode de réévaluation est modifié et que l'on est déjà passé par Contrôler
  If ( ACTSTATUS = 8 ) :   Call CHGACTPARM : Endif

End
##################################
Subprog C_NSPVAL(VALEUR)
Variable Decimal VALEUR

If ( [M:FASR]RVATYP = GVML_MODVMA )
  If [M:FASR]CCLRVAFLG <> G_OUI #*FQ-85936
     If (VALEUR = 0 )
        # Obligatoire si mode de réévaluation = Valeur Marché
        GERR=1 : GMESSAGE=mess(178,GML_MSGFAS,1) : mkstat=2 : End
     Else
        If [M:FASR]RVAAPR= ""
          Actzo [M:FASR]RVAAPR
          Affzo [M:FASR]RVAAPR
       Endif
     Endif  #*FQ-85936
  Endif

  If (ACTTYPGES = GTAMUNI)
    If (GNBVO_C < 0 and VALEUR >= 0 ) or (GNBVO_C  > 0 and ( VALEUR <= 0 or VALEUR <[M:FASR]RSDVAL ))
       GERR=1 :   GMESSAGE=mess(395,GML_MSGFAS,1) : mkstat=2 : End
    Endif
    #FQ-64311 If ([M:FASR]RVATYP = GVML_MODVMA and VALEUR <= GNBVO)
    #FQ-64311 Valeur Marché ne doit pas être < VNC début période
    If ( VALEUR = GNBVO_C )
      GERR=1 : GMESSAGE=mess(805,GML_MSGFAS,1) : mkstat=2 : End
    Endif
  Endif
Endif



End
##################################
Subprog C_RVAAPR(VALEUR)
Variable Char    VALEUR()

#Fq-67995 If (VALEUR = "" and [M:FASR]RVATYP = GVML_MODVMA and [M:FASR]CCLRVAFLG <> G_OUI)
  If ( VALEUR = "" and [M:FASR]RVATYP = GVML_MODVMA and [M:FASR]CCLRVAFLG <> G_OUI and
&      G_RVALIB <> G_OUI )
    # Obligatoire si mode de réévaluation = Valeur Marché
    GERR=1 : GMESSAGE=mess(178,GML_MSGFAS,1)
    mkstat=2 : End
  Endif

End
##################################
Subprog AV_RVACOEREF(VALEUR)
Variable Decimal    VALEUR()
End
#====================================================
Subprog APPLIQUE_REEVAL(PCLASSE,PMOD,PINDICE,PVALEUR)
#
# Alimentation des enregistrements de TMP1 ou MFS0             #
#
Value Char      PCLASSE         # Classe contenant les informations de sortie
Value Char      PMOD            # Mode réévaluation : Coefficient, Indice ou Valeur Marché
Value Decimal   PVALEUR         # Coefficient ou montant Valeur Marché
Value Decimal   PINDICE         # <> 0 : nolign de l'écran de contrôle (M:MFS0]
                                # = 0 table temporaire [F:TMP1]
  Case PMOD
    When "IND" , "COE"
      If G_RVALIB <> G_OUI
         Gosub CALC_RVACOE  From TRTFASRVA
      Else
         Gosub CALC_RVACOE_LIB From TRTFASRVALIB #Fq-67995
      Endif
    When "VMA"
      If G_RVALIB <> G_OUI
         Gosub CALC_RVAVMA      From TRTFASRVA
      Else
         Gosub CALC_RVAVMA_LIB  From TRTFASRVALIB #Fq-67995
      Endif
  Endcase

End
#-----------------------------------------------------
$CALC_RVACOE


Local Decimal LRVACOE
Local Char    CHAMP, LRVACOEREF
Local Char    LMESSAGE
Local Integer LCDRET

 #-1 -----------------------------
 If ( ACTTYPGES = GTAMUNI )
   LRVACOE    = [M:FASR]RVACOE
   LRVACOEREF = [M:FASR]RVACOEREF
 #-1 -----------------------------
 Else
   #-2 -----------------------------
   If PINDICE
     LRVACOE = PVALEUR
   #-2 -----------------------------
   Else
      If ( [M:FASR]RVACOE > 1 )
        LRVACOE = [M:FASR]RVACOE
      Else
        LRVACOE = evalue(PCLASSE+"RVACOE")
      Endif
      LRVACOEREF = [M:FASR]RVACOEREF
    Endif
    #-2 -----------------------------
  Endif
  #-1 -----------------------------

  If ( PINDICE )
    # si on calcule les nouvelles valeurs à partir d'une ligne de l'écran de contrôle
       Gosub CALC_RVACOE_MFS0 From TRTFASRVA
  Else
    # si l'on calcule les nouvelles valeurs au chargement de l'écran de contrôle
       Gosub CALC_RVACOE_TMP1 From TRTFASRVA
  Endif

Return
#-----------------------------------------------------
$CALC_RVACOE_MFS0

  #-- Fq-79819 -rééval fin exercice-------------------------
  If [M:FASR]RVATIADAT = GVML_ERENDEX : Gosub CALC_RVACOE_ENDFIY_MFS0 : Return  : Endif

  [M:MFS0]FLGERR(PINDICE-1)      =  G_NON
  [M:MFS0]FLGMOD(PINDICE-1)      =  G_OUI
  [M:MFS0]MSGERR(PINDICE-1)      =  ""

  [M:MFS0]RVATIADAT(PINDICE-1)   = [M:FASR]RVATIADAT
  [M:MFS0]RVATYP(PINDICE-1)      = [M:FASR]RVATYP
  [M:MFS0]RVADAT(PINDICE-1)      = [M:FASR]RVADAT
  [M:MFS0]RVACOEREF(PINDICE-1)   = LRVACOEREF
  [M:MFS0]RVACOE(PINDICE-1)      = LRVACOE

  #-1 ---------------
  #FQ-64311 If ([M:MFS0]RVACOE(PINDICE-1) > 1)
  If ([M:MFS0]RVACOE(PINDICE-1) <> 0)
    # << Coefficient > 1 >>
    #FQ-66648 [M:MFS0]NBV(PINDICE-1)         =  [M:MFS0]NBVO(PINDICE-1)        *  LRVACOE
    #FQ-66648 [M:MFS0]NBVT(PINDICE-1)        =  [M:MFS0]NBVTO(PINDICE-1)       *  LRVACOE
    [M:MFS0]DPRBAS(PINDICE-1)      =  [M:MFS0]DPRBASO(PINDICE-1)     *  LRVACOE
    [M:MFS0]DPRCUM(PINDICE-1)      =  [M:MFS0]DPRCUMO(PINDICE-1)     *  LRVACOE
    [M:MFS0]IMLBLC(PINDICE-1)      =  [M:MFS0]IMLBLCO(PINDICE-1)     *  LRVACOE
    If ([M:MFS0]DPRCUM(PINDICE-1) <> 0 )   : [M:MFS0]DPRCUMFLG(PINDICE-1)=  G_OUI : Endif
    [M:MFS0]EXECLOCUMT(PINDICE-1)  =  [M:MFS0]EXECLOCUTO(PINDICE-1)  *  LRVACOE

    If ( [M:MFS0]RVATIADAT(PINDICE-1) = GVML_ERDBEX )
      [M:MFS0]PERREFCLC(PINDICE-1)  = [M:FASR]FIYSTRDAT
      [M:MFS0]PERREFCLCT(PINDICE-1) = [M:FASR]FIYSTRDAT
      [M:MFS0]PERCLOCUM(PINDICE-1)  = [M:MFS0]PERCLOCUMO(PINDICE-1)
      [M:MFS0]PERCLOEXC(PINDICE-1)  = [M:MFS0]PERCLOEXCO(PINDICE-1)
      [M:MFS0]PERCLOCUMT(PINDICE-1) = [M:MFS0]PERCLOCUTO(PINDICE-1)
      [M:MFS0]PERCLOEXCT(PINDICE-1) = [M:MFS0]PERCLOEXTO(PINDICE-1)
    Else
      If ( [M:MFS0]RVATIADAT(PINDICE-1)<> GVML_ERENDEX ) #Fq-79819
        [M:MFS0]PERREFCLC(PINDICE-1)  = [M:FASR]PERSTRDAT
        [M:MFS0]PERREFCLCT(PINDICE-1) = [M:FASR]PERSTRDAT
        [M:MFS0]PERCLOCUM(PINDICE-1)  = [M:MFS0]PERCLOCUMO(PINDICE-1)  *  LRVACOE
        [M:MFS0]PERCLOEXC(PINDICE-1)  = [M:MFS0]PERCLOEXCO(PINDICE-1)  *  LRVACOE
        [M:MFS0]PERCLOCUMT(PINDICE-1) = [M:MFS0]PERCLOCUTO(PINDICE-1)  *  LRVACOE
        [M:MFS0]PERCLOEXCT(PINDICE-1) = [M:MFS0]PERCLOEXTO(PINDICE-1)  *  LRVACOE
      Endif
    Endif

    [M:MFS0]EXETRFCUM(PINDICE-1)   =  [M:MFS0]EXETRFCUMO(PINDICE-1)  *  LRVACOE
    [M:MFS0]EXEIMLCUM(PINDICE-1)   =  [M:MFS0]EXEIMLCUMO(PINDICE-1)  *  LRVACOE
    [M:MFS0]PERIMLCUM(PINDICE-1)   =  [M:MFS0]PERIMLCUMO(PINDICE-1)  *  LRVACOE
    [M:MFS0]EXERVECUM(PINDICE-1)   =  [M:MFS0]EXERVECUMO(PINDICE-1)  *  LRVACOE
    [M:MFS0]PERRVECUM(PINDICE-1)   =  [M:MFS0]PERRVECUMO(PINDICE-1)  *  LRVACOE
    [M:MFS0]IMLBLC(PINDICE-1)      =  [M:MFS0]EXEIMLCUM(PINDICE-1)
&                                  +  [M:MFS0]PERIMLCUM(PINDICE-1)
&                                  -  [M:MFS0]EXERVECUM(PINDICE-1)
&                                  -  [M:MFS0]PERRVECUM(PINDICE-1)
&                                  -  [M:MFS0]EXETRFCUM(PINDICE-1)

    # FQ-81475
    # [M:MFS0]NSPVAL(PINDICE-1)      =  0

    #FQ-66648 ----------------
    Call GET_MNT_ARRONDI ([M:MFS0]DPRBAS,     [M:FASR]CUR, [M:MFS0]DPRBAS)      From GLOBIENS
    Call GET_MNT_ARRONDI ([M:MFS0]PERCLOCUM,  [M:FASR]CUR, [M:MFS0]PERCLOCUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([M:MFS0]PERCLOEXC,  [M:FASR]CUR, [M:MFS0]PERCLOEXC)   From GLOBIENS
    Call GET_MNT_ARRONDI ([M:MFS0]DPRCUM,     [M:FASR]CUR, [M:MFS0]DPRCUM)      From GLOBIENS
    Call GET_MNT_ARRONDI ([M:MFS0]EXETRFCUM,  [M:FASR]CUR, [M:MFS0]EXETRFCUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([M:MFS0]EXEIMLCUM,  [M:FASR]CUR, [M:MFS0]EXEIMLCUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([M:MFS0]PERIMLCUM,  [M:FASR]CUR, [M:MFS0]PERIMLCUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([M:MFS0]EXERVECUM,  [M:FASR]CUR, [M:MFS0]EXERVECUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([M:MFS0]PERRVECUM,  [M:FASR]CUR, [M:MFS0]PERRVECUM)   From GLOBIENS
    Call GET_MNT_ARRONDI ([M:MFS0]IMLBLC,     [M:FASR]CUR, [M:MFS0]IMLBLC)      From GLOBIENS
    Call GET_MNT_ARRONDI ([M:MFS0]PERCLOCUMT, [M:FASR]CUR, [M:MFS0]PERCLOCUMT)  From GLOBIENS
    Call GET_MNT_ARRONDI ([M:MFS0]PERCLOEXCT, [M:FASR]CUR, [M:MFS0]PERCLOEXCT)  From GLOBIENS
    Call GET_MNT_ARRONDI ([M:MFS0]EXECLOCUMT, [M:FASR]CUR, [M:MFS0]EXECLOCUMT)  From GLOBIENS

    If ( [M:MFS0]RVATIADAT(PINDICE-1) = GVML_ERDBEX )
       [M:MFS0]NBV(PINDICE-1)  =  [M:MFS0]DPRBAS(PINDICE-1)  - [M:MFS0]DPRCUM(PINDICE-1)- [M:MFS0]IMLBLC(PINDICE-1)
       [M:MFS0]NBVT(PINDICE-1) =  [M:MFS0]DPRBAS(PINDICE-1) - [M:MFS0]DPRCUM(PINDICE-1)-
&                                 [M:MFS0]PERCLOCUM(PINDICE-1) - [M:MFS0]PERCLOEXC(PINDICE-1) - [M:MFS0]IMLBLC(PINDICE-1)
    Else
       [M:MFS0]NBV(PINDICE-1) =   [M:MFS0]DPRBAS(PINDICE-1)     - [M:MFS0]DPRCUM(PINDICE-1) -
&                                 [M:MFS0]PERCLOCUMT(PINDICE-1) - [M:MFS0]PERCLOEXCT(PINDICE-1) - [M:MFS0]IMLBLC(PINDICE-1)
       [M:MFS0]NBVT(PINDICE-1) =  [M:MFS0]DPRBAS(PINDICE-1)     - [M:MFS0]EXECLOCUMT(PINDICE-1)-
&                                 [M:MFS0]PERCLOCUMT(PINDICE-1) - [M:MFS0]PERCLOEXCT(PINDICE-1) - [M:MFS0]IMLBLC(PINDICE-1)
    Endif
    #FQ-66648 ----------------

    #FQ-64311  [M:MFS0]RVAAMT(PINDICE-1)      =  abs([M:MFS0]NBV(PINDICE-1)-[M:MFS0]NBVO(PINDICE-1))
    [M:MFS0]RVAAMT(PINDICE-1)      =  [M:MFS0]NBV(PINDICE-1)-[M:MFS0]NBVO(PINDICE-1)

    # <<< Réévaluation >>>>
    #FQ-64311 If ([M:MFS0]RVAAMT(PINDICE-1) = 0)
    If ([M:MFS0]RVAAMT(PINDICE-1) = 0)
      # "Montant réévaluation invalide"
      [M:MFS0]MSGERR (PINDICE-1) =  mess(400,GML_MSGFAS,1)
      [M:MFS0]FLGERR (PINDICE-1) =  G_OUI
      [M:MFS0]FLGMOD (PINDICE-1) =  G_NON
    Endif

  #-1 ---------------
  Else
    #FQ-64311 << Coefficient <= 1 >>
    # << Coefficient = 0 >>
    # "Coefficient invalide"
    [M:MFS0]MSGERR (PINDICE-1)  =  mess(173,GML_MSGFAS,1)
    [M:MFS0]FLGERR (PINDICE-1)  =  G_OUI
    [M:MFS0]FLGMOD (PINDICE-1)  =  G_OUI
  Endif
  #-1 ---------------

  If  ([M:MFS0]FLGERR(PINDICE-1) = G_OUI and [M:MFS0]FLGMOD(PINDICE-1) <> G_OUI)
    [M:MFS0]RVACOEREF(PINDICE-1) =  ""
    [M:MFS0]RVACOE(PINDICE-1)    =  1
    [M:MFS0]RVATIADAT(PINDICE-1) =  0
    [M:MFS0]RVADAT(PINDICE-1)    =  [0/0/0]
    [M:MFS0]RVATYP(PINDICE-1)    =  0
    [M:MFS0]RVAAMT(PINDICE-1)    =  0
  Endif

Return
#-----------------------------------------------------
$CALC_RVACOE_TMP1


  #-- Fq-79819 -rééval fin exercice-------------------------
  If [M:FASR]RVATIADAT = GVML_ERENDEX : Gosub CALC_RVACOE_ENDFIY_TMP1 : Return  : Endif

  CHAMP=PCLASSE+"FLGERR"          : Assign CHAMP With G_NON
  CHAMP=PCLASSE+"FLGMOD"          : Assign CHAMP With G_OUI
  CHAMP=PCLASSE+"MSGERR"          : Assign CHAMP With ""

  CHAMP=PCLASSE+"RVATIADAT"       : Assign CHAMP With [M:FASR]RVATIADAT
  CHAMP=PCLASSE+"RVATYP"          : Assign CHAMP With [M:FASR]RVATYP
  CHAMP=PCLASSE+"RVADAT"          : Assign CHAMP With [M:FASR]RVADAT
  CHAMP=PCLASSE+"RVACOEREF"       : Assign CHAMP With LRVACOEREF
  CHAMP=PCLASSE+"RVACOE"          : Assign CHAMP With LRVACOE

  #-1 ------------------------------------
  #Fq-64311 If (evalue (PCLASSE+"RVACOE") > 1)
  #Fq-64311 << Coefficent > 1. >>
  If (evalue (PCLASSE+"RVACOE") > 0)
    # << Coefficent <> 0 >>
    ##FQ-66648 CHAMP=PCLASSE+"NBV"             : Assign CHAMP With evalue (PCLASSE+"NBVO*LRVACOE")
    ##FQ-66648 CHAMP=PCLASSE+"NBVT"            : Assign CHAMP With evalue (PCLASSE+"NBVTO*LRVACOE")
    CHAMP=PCLASSE+"DPRBAS"          : Assign CHAMP With evalue (PCLASSE+"DPRBASO*LRVACOE")
    CHAMP=PCLASSE+"DPRCUM"          : Assign CHAMP With evalue (PCLASSE+"DPRCUMO*LRVACOE")
    If (evalue (PCLASSE+"DPRCUM") <> 0)   : CHAMP=PCLASSE+"DPRCUMFLG" : Assign CHAMP With G_OUI : Endif
    CHAMP=PCLASSE+"EXECLOCUMT"      : Assign CHAMP With evalue (PCLASSE+"EXECLOCUTO*LRVACOE")

    If ( evalue (PCLASSE+"RVATIADAT") = GVML_ERDBEX )
      CHAMP=PCLASSE+"PERREFCLC"     : Assign CHAMP With [M:FASR]FIYSTRDAT
      CHAMP=PCLASSE+"PERREFCLCT"    : Assign CHAMP With [M:FASR]FIYSTRDAT
      CHAMP=PCLASSE+"PERCLOCUM"     : Assign CHAMP With evalue (PCLASSE+"PERCLOCUMO")
      CHAMP=PCLASSE+"PERCLOEXC"     : Assign CHAMP With evalue (PCLASSE+"PERCLOEXCO")
      CHAMP=PCLASSE+"PERCLOCUMT"    : Assign CHAMP With evalue (PCLASSE+"PERCLOCUTO")
      CHAMP=PCLASSE+"PERCLOEXCT"    : Assign CHAMP With evalue (PCLASSE+"PERCLOEXTO")
   Else
      If ( evalue (PCLASSE+"RVATIADAT") <>  GVML_ERENDEX ) #Fq_79819
        CHAMP=PCLASSE+"PERREFCLC"     : Assign CHAMP With [M:FASR]PERSTRDAT
        CHAMP=PCLASSE+"PERREFCLCT"    : Assign CHAMP With [M:FASR]PERSTRDAT
        CHAMP=PCLASSE+"PERCLOCUM"     : Assign CHAMP With evalue (PCLASSE+"PERCLOCUMO*LRVACOE")
        CHAMP=PCLASSE+"PERCLOEXC"     : Assign CHAMP With evalue (PCLASSE+"PERCLOEXCO*LRVACOE")
        CHAMP=PCLASSE+"PERCLOCUMT"    : Assign CHAMP With evalue (PCLASSE+"PERCLOCUTO*LRVACOE")
        CHAMP=PCLASSE+"PERCLOEXCT"    : Assign CHAMP With evalue (PCLASSE+"PERCLOEXTO*LRVACOE")
      Endif
    Endif

    CHAMP=PCLASSE+"EXETRFCUM"       : Assign CHAMP With evalue (PCLASSE+"EXETRFCUMO*LRVACOE")
    CHAMP=PCLASSE+"EXEIMLCUM"       : Assign CHAMP With evalue (PCLASSE+"EXEIMLCUMO*LRVACOE")
    CHAMP=PCLASSE+"PERIMLCUM"       : Assign CHAMP With evalue (PCLASSE+"PERIMLCUMO*LRVACOE")
    CHAMP=PCLASSE+"EXERVECUM"       : Assign CHAMP With evalue (PCLASSE+"EXERVECUMO*LRVACOE")
    CHAMP=PCLASSE+"PERRVECUM"       : Assign CHAMP With evalue (PCLASSE+"PERRVECUMO*LRVACOE")

    Case PCLASSE
    When "[F:TMP1]"
       Call GET_MNT_ARRONDI ( [F:TMP1]EXETRFCUM,  [M:FASR]CUR, [F:TMP1]EXETRFCUM )   From GLOBIENS
       Call GET_MNT_ARRONDI ( [F:TMP1]EXEIMLCUM,  [M:FASR]CUR, [F:TMP1]EXEIMLCUM )   From GLOBIENS
       Call GET_MNT_ARRONDI ( [F:TMP1]PERIMLCUM,  [M:FASR]CUR, [F:TMP1]PERIMLCUM )   From GLOBIENS
       Call GET_MNT_ARRONDI ( [F:TMP1]EXERVECUM,  [M:FASR]CUR, [F:TMP1]EXERVECUM )   From GLOBIENS
       Call GET_MNT_ARRONDI ( [F:TMP1]PERRVECUM,  [M:FASR]CUR, [F:TMP1]PERRVECUM )   From GLOBIENS
     When "[M:MFS0]"
        Call GET_MNT_ARRONDI ( [M:MFS0]EXETRFCUM,  [M:FASR]CUR, [M:MFS0]EXETRFCUM )   From GLOBIENS
        Call GET_MNT_ARRONDI ( [M:MFS0]EXEIMLCUM,  [M:FASR]CUR, [M:MFS0]EXEIMLCUM )   From GLOBIENS
        Call GET_MNT_ARRONDI ( [M:MFS0]PERIMLCUM,  [M:FASR]CUR, [M:MFS0]PERIMLCUM )   From GLOBIENS
        Call GET_MNT_ARRONDI ( [M:MFS0]EXERVECUM,  [M:FASR]CUR, [M:MFS0]EXERVECUM )   From GLOBIENS
        Call GET_MNT_ARRONDI ( [M:MFS0]PERRVECUM,  [M:FASR]CUR, [M:MFS0]PERRVECUM )   From GLOBIENS
     Endcase

    CHAMP=PCLASSE+"IMLBLC"          : Assign CHAMP With
&   evalue(PCLASSE+"EXEIMLCUM+"+PCLASSE+"PERIMLCUM-"+PCLASSE+"EXERVECUM-"+PCLASSE+"PERRVECUM-"+PCLASSE+"EXETRFCUM")
    # FQ-81475
    #CHAMP=PCLASSE+"NSPVAL"          : Assign CHAMP With 0

    Case PCLASSE
    When "[F:TMP1]"
       Call GET_MNT_ARRONDI ( [F:TMP1]DPRBAS,     [M:FASR]CUR, [F:TMP1]DPRBAS )      From GLOBIENS
       Call GET_MNT_ARRONDI ( [F:TMP1]PERCLOCUM,  [M:FASR]CUR, [F:TMP1]PERCLOCUM )   From GLOBIENS
       Call GET_MNT_ARRONDI ( [F:TMP1]PERCLOEXC,  [M:FASR]CUR, [F:TMP1]PERCLOEXC )   From GLOBIENS
       Call GET_MNT_ARRONDI ( [F:TMP1]DPRCUM,     [M:FASR]CUR, [F:TMP1]DPRCUM )      From GLOBIENS
       Call GET_MNT_ARRONDI ( [F:TMP1]IMLBLC,     [M:FASR]CUR, [F:TMP1]IMLBLC )      From GLOBIENS
       Call GET_MNT_ARRONDI ( [F:TMP1]PERCLOCUMT, [M:FASR]CUR, [F:TMP1]PERCLOCUMT )  From GLOBIENS
       Call GET_MNT_ARRONDI ( [F:TMP1]PERCLOEXCT, [M:FASR]CUR, [F:TMP1]PERCLOEXCT )  From GLOBIENS
       Call GET_MNT_ARRONDI ( [F:TMP1]EXECLOCUMT, [M:FASR]CUR, [F:TMP1]EXECLOCUMT )  From GLOBIENS
    When "[M:MFS0]"
       Call GET_MNT_ARRONDI ( [M:MFS0]DPRBAS,     [M:FASR]CUR, [F:TMP1]DPRBAS )      From GLOBIENS
       Call GET_MNT_ARRONDI ( [M:MFS0]PERCLOCUM,  [M:FASR]CUR, [M:MFS0]PERCLOCUM )   From GLOBIENS
       Call GET_MNT_ARRONDI ( [M:MFS0]PERCLOEXC,  [M:FASR]CUR, [M:MFS0]PERCLOEXC )   From GLOBIENS
       Call GET_MNT_ARRONDI ( [M:MFS0]DPRCUM,     [M:FASR]CUR, [M:MFS0]DPRCUM )      From GLOBIENS
       Call GET_MNT_ARRONDI ( [M:MFS0]IMLBLC,     [M:FASR]CUR, [M:MFS0]IMLBLC )      From GLOBIENS
       Call GET_MNT_ARRONDI ( [M:MFS0]PERCLOCUMT,  [M:FASR]CUR, [M:MFS0]PERCLOCUMT ) From GLOBIENS
       Call GET_MNT_ARRONDI ( [M:MFS0]PERCLOEXCT,  [M:FASR]CUR, [M:MFS0]PERCLOEXCT ) From GLOBIENS
       Call GET_MNT_ARRONDI ( [M:MFS0]EXECLOCUMT,  [M:FASR]CUR, [M:MFS0]EXECLOCUMT ) From GLOBIENS
    Endcase

    #FQ-66648 -----------------------------------------------------------------------------------------------
    If ( evalue (PCLASSE+"RVATIADAT") = GVML_ERDBEX )
       CHAMP=PCLASSE+"NBV"   : Assign CHAMP With  evalue(PCLASSE+"DPRBAS-"+PCLASSE+"DPRCUM-"+PCLASSE-"IMLBLC")
       CHAMP=PCLASSE+"NBVT"  : Assign CHAMP With  evalue(PCLASSE+"DPRBAS-"+PCLASSE+"EXECLOCUMT")
    Else
       CHAMP=PCLASSE+"NBV"   : Assign CHAMP With
&                              evalue(PCLASSE+"DPRBAS-"+PCLASSE+"DPRCUM-"+PCLASSE-"PERCLOCUM-"+PCLASSE-"PERCLOEXC-"+PCLASSE-"IMLBLC")
       CHAMP=PCLASSE+"NBVT"  : Assign CHAMP With
&                               evalue(PCLASSE+"DPRBAS-"+PCLASSE+"EXECLOCUMT-"+PCLASSE-"PERCLOCUMT-"+PCLASSE-"PERCLOEXCT")
    Endif
    #FQ-66648 -----------------------------------------------------------------------------------------------
    #FQ-64311  CHAMP=PCLASSE+"RVAAMT"          : Assign CHAMP With evalue ("abs("+PCLASSE+"NBV - "+PCLASSE+"NBVO)")
    CHAMP=PCLASSE+"RVAAMT"          : Assign CHAMP With evalue (PCLASSE+"NBV - "+PCLASSE+"NBVO")

    # << Réévaluation >>
    If (evalue (PCLASSE+"RVAAMT") = 0)
        # Montant réévaluation invalide"
        CHAMP=PCLASSE+"MSGERR"        : Assign CHAMP With mess(400,GML_MSGFAS,1)
        CHAMP=PCLASSE+"FLGERR"        : Assign CHAMP With G_OUI
        CHAMP=PCLASSE+"FLGMOD"        : Assign CHAMP With G_NON
    Endif

  #-1 ------------------------------------
  Else
    #FQ-64311  <<< Coefficent <= 1. >>>
    # <<< Coefficent = 0 >>>
    # Coefficient invalide
    CHAMP=PCLASSE+"MSGERR"        : Assign CHAMP With mess(173,GML_MSGFAS,1)
    CHAMP=PCLASSE+"FLGERR"        : Assign CHAMP With G_OUI
    CHAMP=PCLASSE+"FLGMOD"        : Assign CHAMP With G_OUI
  Endif
  #-1 ------------------------------------

  If  ( evalue (PCLASSE+"FLGERR") = G_OUI and evalue (PCLASSE+"FLGMOD") <> G_OUI )
    CHAMP=PCLASSE+"RVACOEREF"     : Assign CHAMP With ""
    CHAMP=PCLASSE+"RVACOE"        : Assign CHAMP With 1
    CHAMP=PCLASSE+"RVADAT"        : Assign CHAMP With [0/0/0]
    CHAMP=PCLASSE+"RVATYP"        : Assign CHAMP With 0
    CHAMP=PCLASSE+"RVATIADAT"     : Assign CHAMP With 0
    CHAMP=PCLASSE+"RVAAMT"        : Assign CHAMP With 0
  Endif

Return
#====================================================
#
$CALC_RVAVMA

Local Decimal LNSPVAL
Local Integer LRVATYP
Local Char    LMESSAGE
Local Integer LCDRET

  #-1 --------------------------
  If ( ACTTYPGES = GTAMUNI )
    LNSPVAL = [M:FASR]NSPVAL
  Elsif (PINDICE)
    LNSPVAL = PVALEUR
  Else
    LNSPVAL = evalue(PCLASSE+"NSPVAL")
  Endif
  #-- Fq-79819 -rééval fin exercice-------------------------
  If [M:FASR]RVATIADAT = GVML_ERENDEX : Gosub CALC_RVAVMA_ENDFIY : Return  : Endif

  # si on calcule les nouvelles valeurs à partir d'une ligne de l'écran de contrôle
  #-1 --------------------------
  If ( PINDICE )
    CHAMP=PCLASSE+"FLGERR(PINDICE-1)"       : Assign CHAMP With G_NON
    CHAMP=PCLASSE+"FLGMOD(PINDICE-1)"       : Assign CHAMP With G_OUI
    CHAMP=PCLASSE+"MSGERR (PINDICE-1)"      : Assign CHAMP With ""
    #-2 ----------------------

    #Fq-64311  If  ( LNSPVAL <= evalue(PCLASSE+"NBVO(PINDICE-1)") )
    If  ( LNSPVAL = evalue(PCLASSE+"NBVO(PINDICE-1)") )
      # "Valeur marché invalide"
      CHAMP=PCLASSE+"MSGERR (PINDICE-1)"    : Assign CHAMP With mess(395,GML_MSGFAS,1)
      CHAMP=PCLASSE+"FLGERR (PINDICE-1)"    : Assign CHAMP With G_OUI
      CHAMP=PCLASSE+"FLGMOD (PINDICE-1)"    : Assign CHAMP With G_OUI
      Return
    #-2 ----------------------
    Else
      #==============================
      # Réévaluation valeur MARCHE
      #===============================
      CHAMP=PCLASSE+"RVATIADAT(PINDICE-1)"    : Assign CHAMP With  GVML_ERDBPE
      CHAMP=PCLASSE+"RVATYP(PINDICE-1)"       : Assign CHAMP With  GVML_MODVMA
      CHAMP=PCLASSE+"RVADAT(PINDICE-1)"       : Assign CHAMP With  evalue (PCLASSE+"RVADAT(PINDICE-1)")
      CHAMP=PCLASSE+"RVACOE(PINDICE-1)"       : Assign CHAMP With 1
      CHAMP=PCLASSE+"RVACOEREF(PINDICE-1)"    : Assign CHAMP With ""
      If ( evalue (PCLASSE+"RVATIADAT") = GVML_ERDBEX )
        CHAMP=PCLASSE+"PERREFCLC(PINDICE-1)"    : Assign CHAMP With [M:FASR]FIYSTRDAT
        CHAMP=PCLASSE+"PERREFCLCT(PINDICE-1)"   : Assign CHAMP With [M:FASR]FIYSTRDAT
      Else
        If  ( evalue (PCLASSE+"RVATIADAT") <> GVML_ERENDEX ) #Fq-79819
         CHAMP=PCLASSE+"PERREFCLC(PINDICE-1)"    : Assign CHAMP With [M:FASR]PERSTRDAT
         CHAMP=PCLASSE+"PERREFCLCT(PINDICE-1)"   : Assign CHAMP With [M:FASR]PERSTRDAT
        Endif
      Endif
      CHAMP=PCLASSE+"NBV(PINDICE-1)"          : Assign CHAMP With LNSPVAL
      CHAMP=PCLASSE+"NBVT(PINDICE-1)"         : Assign CHAMP With LNSPVAL
      CHAMP=PCLASSE+"DPRBAS(PINDICE-1)"       : Assign CHAMP With LNSPVAL
      CHAMP=PCLASSE+"DPRCUM(PINDICE-1)"       : Assign CHAMP With 0
      CHAMP=PCLASSE+"DPRCUMFLG(PINDICE-1)"    : Assign CHAMP With G_OUI
      CHAMP=PCLASSE+"PERCLOCUM(PINDICE-1)"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"PERCLOEXC(PINDICE-1)"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"EXECLOCUMT(PINDICE-1)"   : Assign CHAMP With 0
      CHAMP=PCLASSE+"PERCLOCUMT(PINDICE-1)"   : Assign CHAMP With 0
      CHAMP=PCLASSE+"PERCLOEXCT(PINDICE-1)"   : Assign CHAMP With 0
      CHAMP=PCLASSE+"EXETRFCUM(PINDICE-1)"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"EXEIMLCUM(PINDICE-1)"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"PERIMLCUM(PINDICE-1)"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"EXERVECUM(PINDICE-1)"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"PERRVECUM(PINDICE-1)"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"IMLBLC(PINDICE-1)"       : Assign CHAMP With 0
      CHAMP=PCLASSE+"NSPVAL(PINDICE-1)"       : Assign CHAMP With LNSPVAL
      #Fq-64311  CHAMP=PCLASSE+"RVAAMT(PINDICE-1)"       : Assign CHAMP With evalue ("Abs("+PCLASSE+"NBV(PINDICE-1)-"+PCLASSE+"NBVO(PINDICE-1))")
      CHAMP=PCLASSE+"RVAAMT(PINDICE-1)"       : Assign CHAMP With evalue (PCLASSE+"NBV(PINDICE-1)-"+PCLASSE+"NBVO(PINDICE-1)")

      If (evalue(PCLASSE+"RVAAMT(PINDICE-1)") = 0)
        # "Montant réévaluation invalide"
        CHAMP=PCLASSE+"MSGERR (PINDICE-1)"    : Assign CHAMP With mess(400,GML_MSGFAS,1)
        CHAMP=PCLASSE+"FLGERR (PINDICE-1)"    : Assign CHAMP With G_OUI
        CHAMP=PCLASSE+"FLGMOD (PINDICE-1)"    : Assign CHAMP With G_NON
        Return
      Endif
    Endif
    #-2 ----------------------

  #-1 --------------------------
  Else
    CHAMP=PCLASSE+"FLGERR"                  : Assign CHAMP With G_NON
    CHAMP=PCLASSE+"FLGMOD"                  : Assign CHAMP With G_OUI
    CHAMP=PCLASSE+"MSGERR"                  : Assign CHAMP With ""

    CHAMP=PCLASSE+"RVATIADAT"               : Assign CHAMP With  [M:FASR]RVATIADAT
    CHAMP=PCLASSE+"RVATYP"                  : Assign CHAMP With  GVML_MODVMA
    CHAMP=PCLASSE+"RVADAT"                  : Assign CHAMP With  [M:FASR]RVADAT
    CHAMP=PCLASSE+"RVACOE"                  : Assign CHAMP With 1
    CHAMP=PCLASSE+"RVACOEREF"               : Assign CHAMP With ""
    If ( evalue (PCLASSE+"RVATIADAT") = GVML_ERDBEX )
      CHAMP=PCLASSE+"PERREFCLC"               : Assign CHAMP With [M:FASR]FIYSTRDAT
      CHAMP=PCLASSE+"PERREFCLCT"              : Assign CHAMP With [M:FASR]FIYSTRDAT
    Else
        If  ( evalue (PCLASSE+"RVATIADAT") <> GVML_ERENDEX ) #Fq-79819
           CHAMP=PCLASSE+"PERREFCLC"               : Assign CHAMP With [M:FASR]PERSTRDAT
           CHAMP=PCLASSE+"PERREFCLCT"              : Assign CHAMP With [M:FASR]PERSTRDAT
        Endif
    Endif
    #-2 ----------------------
    #Fq-64311  If ( LNSPVAL <= evalue(PCLASSE+"NBVO") )
    If  (LNSPVAL = evalue(PCLASSE+"NBVO"))
      # Valeur marché invalide
      CHAMP=PCLASSE+"MSGERR"            : Assign CHAMP With mess(395,GML_MSGFAS,1)
      CHAMP=PCLASSE+"FLGERR"            : Assign CHAMP With G_OUI
      CHAMP=PCLASSE+"FLGMOD"            : Assign CHAMP With G_OUI
      Return
    #-2 ----------------------
    Else
      CHAMP=PCLASSE+"NBV"                     : Assign CHAMP With LNSPVAL
      CHAMP=PCLASSE+"NBVT"                    : Assign CHAMP With LNSPVAL
      CHAMP=PCLASSE+"DPRBAS"                  : Assign CHAMP With LNSPVAL
      CHAMP=PCLASSE+"DPRCUM"                  : Assign CHAMP With 0
      CHAMP=PCLASSE+"DPRCUMFLG"               : Assign CHAMP With G_OUI
      CHAMP=PCLASSE+"PERCLOCUM"               : Assign CHAMP With 0
      CHAMP=PCLASSE+"PERCLOEXC"               : Assign CHAMP With 0
      CHAMP=PCLASSE+"EXECLOCUMT"              : Assign CHAMP With 0
      CHAMP=PCLASSE+"PERCLOCUMT"              : Assign CHAMP With 0
      CHAMP=PCLASSE+"PERCLOEXCT"              : Assign CHAMP With 0
      CHAMP=PCLASSE+"EXETRFCUM"               : Assign CHAMP With 0
      CHAMP=PCLASSE+"EXEIMLCUM"               : Assign CHAMP With 0
      CHAMP=PCLASSE+"PERIMLCUM"               : Assign CHAMP With 0
      CHAMP=PCLASSE+"EXERVECUM"               : Assign CHAMP With 0
      CHAMP=PCLASSE+"PERRVECUM"               : Assign CHAMP With 0
      CHAMP=PCLASSE+"IMLBLC"                  : Assign CHAMP With 0
      CHAMP=PCLASSE+"NSPVAL"                  : Assign CHAMP With LNSPVAL
      #Fq-64311  CHAMP=PCLASSE+"RVAAMT"        : Assign CHAMP With evalue ("abs("+PCLASSE+"NBV-"+PCLASSE+"NBVO)")
      CHAMP=PCLASSE+"RVAAMT"                  : Assign CHAMP With evalue (PCLASSE+"NBV-"+PCLASSE+"NBVO")

      If (evalue(PCLASSE+"RVAAMT") = 0)
        # "Montant réévaluation invalide"
        CHAMP=PCLASSE+"MSGERR"    : Assign CHAMP With mess(400,GML_MSGFAS,1)
        CHAMP=PCLASSE+"FLGERR"    : Assign CHAMP With G_OUI
        CHAMP=PCLASSE+"FLGMOD"    : Assign CHAMP With G_NON
        Return
      Endif
    Endif
    #-2 ----------------------
  Endif
  #-1 ---------------------

Return
#========================================================================
#
Subprog CHGACTPARM()
#
# En après modif de chaque  champ de paramètre de l'action métier.
# Permet, si un paramètre a déjà été appliqué à la population sélectionnée,
#   de demander si on veut prendre en compte le nouveau paramètre
#      - Si oui, on nettoie tout ce qui avait été calculé à partir des  paramètres précédents et on
# revient à l'étape d'application des nouveaux paramètres
#     - Si non, on retourne en saisie sur le champ
# ------------------------------------------------------------------------------

Local Integer POK,ERR,NBDLREC
Local Char    MES

  If ( ACTSTATUS <> STA_DEBUT )
    # "Vous avez modifié un paramètre. Le résultat de la réévaluation va changer.Voulez-vous continuer ?"
    Call OUINON (mess(398,GML_MSGFAS,1),POK) From GESECRAN
    Case POK
      When G_OUI
        ACTSTATUS=STA_DEBUT
        # Unlock de la population
        Call UNLOCKER(NUMACT,MES,ERR) From TRCPROCOM
        # Vider les tables de travail
        Call VIDER(NUMACT,TMPTAB,NBDLREC,ERR) From TRCPROCOM         # table temporaire principale
        If ( ACTGESPLN = G_OUI )
          Call VIDER(NUMACT,TMPTABPLN,NBDLREC,ERR) From TRCPROCOM    # table temporaire par plan
        Endif
      When Default
        mkstat = 2 : End
    Endcase
  Endif

End
#=====================================================================

#---------------------------------------------------------------------------------------------
Subprog RECH_RVACOE(RVACOEREF, LCOEFF)
#
# Massif : Recherche des coefficients : récupération du coefficient ou de l'indice à appliquer
#          dans la   table de référence sélectionnée
#
Value    Char    RVACOEREF
Variable Decimal LCOEFF

Local Integer LMOIS
Local Integer LANNEE
Local Char    LNAT

  Read[COH]COH0= RVACOEREF

  Case  [F:COH]CRITDAT
    When GVML_DATACH  :  LMOIS = month([F:MAS1]PURDAT)    :  LANNEE = year([F:MAS1]PURDAT)
    When GVML_DATCPT  :  LMOIS = month([F:MAS1]AASIPTDAT) :  LANNEE = year([F:MAS1]AASIPTDAT)
    When GVML_DATMES  :  LMOIS = month([F:MAS1]ITSDAT)    :  LANNEE = year([F:MAS1]ITSDAT)
    When Default
  Endcase

  Case  [F:COH]CRITNAT
    When GVML_NATFAM  :  LNAT = [F:MAS1]ACGGRP
    When GVML_NATCCO  :  LNAT = [F:MAS1]ACCCOD
    When Default
  Endcase

  Gosub RECH_COEFF

  LCOEFF = COEFF

End
#-----------------------------------------------------------
$RECH_COEFF

Local Char  LCLETAB, LCLETAB2, LCLEACT, LCLEACT2
Local Decimal LINDINI, LINDACT, COEFF,CDRET

  CDRET     = 0
  LCLETAB   = sum(num$(LANNEE),LNAT,num$(LMOIS))
  LCLETAB2  = sum(num$(LANNEE),LNAT,num$(0))

  LCLEACT  = sum(num$(year([M:FASR]PERSTRDAT )),LNAT,num$(month([M:FASR]PERSTRDAT)))
  LCLEACT2  = sum(num$(year([M:FASR]PERSTRDAT )),LNAT,num$(0))

  # clé = Année de la date correspondant à CRITDAT
  #       Valeur de la rubrique nature CRITNAT
  #       Mois de la date correspondant à CRITDAT
  # DEBUT FQ79483
#  Filter [COD]Where CPY=[F:COH]CPY and RVACOEREF=[F:COH]RVACOEREF and
#&                   CRITNAT = [F:COH]CRITNAT and CRITDAT=[F:COH]CRITDAT
  #Read[COD]COD0=LCLETAB
  #If (fstat)
  #  Read[COD]COD0=LCLETAB2
  #Endif
  Filter [COD] Where CRITNAT=[F:COH]CRITNAT and CRITDAT=[F:COH]CRITDAT
  Read[COD]COD0=[F:COH]RVACOEREF;LCLETAB
  If (fstat)
    Read[COD]COD0=[F:COH]RVACOEREF;LCLETAB2
  Endif
  # FIN FQ79483

  #-1 ---------------------
  If (fstat)
    COEFF = 1
  #-1 ---------------------
  Else
    #-2 ---------------------
    If ([M:FASR]RVATYP = GVML_MODCOE)
      # Rééval. par coef. : détermination du coefficient à appliquer
      #FQ-64311  If ([F:COD]RVACOE > 0 )
      If ([F:COD]RVACOE <> 0 )
        COEFF = [F:COD]RVACOE
      Else
        COEFF = 1
      Endif
    Endif
    #-2 ---------------------

    #-2 ---------------------
    If ([M:FASR]RVATYP = GVML_MODIND)
      # Rééval. par indice : détermination de l'indice initial puis de l'indice actuel
      If ( [F:COD]RVAIND <= 0 )
        # indice initial non trouvé
        CDRET = 10
        COEFF = 1
      Else
        LINDINI = [F:COD]RVAIND
        # Détermination de l'indice actuel
        #               clé = ANNEE de la période courante ou de l'exercice courant
        #                     Valeur de la rubrique nature CRITNAT
        #                     MOIS de la période courante ou de l'exercice courant
        # DEBUT FQ79483
        #Read[COD]COD0= LCLEACT
        #If (fstat)
        #  Read[COD]COD0= LCLEACT2
        #Endif
        Read[COD]COD0=[F:COH]RVACOEREF;LCLEACT
        If (fstat)
          Read[COD]COD0=[F:COH]RVACOEREF;LCLEACT2
        Endif
        # FIN FQ79483
        If (fstat)
          LINDACT= LINDINI
        Else
          LINDACT= [F:COD]RVAIND
        Endif
        If (LINDINI > 0)
          #--- Indice actuel/Indice initial ---
          COEFF = arr((LINDACT/LINDINI),0.0000005)
          #Fq-64311  If ( COEFF <= 1 )
          ##Fq-64311   indice actuel/indice initial <= à 1
          If ( COEFF = 0  )
            #  indice actuel/indice initial = 0
            CDRET = 20
            COEFF = 1
          Endif
        Endif
      Endif
    Endif
    #-2 ---------------------
  Endif
  #-1 ---------------------
  Filter[COD]

  If (ACTTYPGES=GTAMUNI and COEFF = 1)
    Case  CDRET
      When 10 : GMESSAGE=mess(414,GML_MSGFAS,1)  # indice initial non trouvé
      When 20 : GMESSAGE=mess(415,GML_MSGFAS,1)  # indice actuel/indice initial <= à 1
      When Default : GMESSAGE=mess(385,GML_MSGFAS,1)  # " Coefficient/indice non trouvé dans la table de référence saisie"
    Endcase
    Actzo[M:FASR]RVACOE
    GERR=1 :  mkstat=2 : Return
  Endif

Return
