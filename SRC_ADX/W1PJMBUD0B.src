#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMBUD0B 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [28/09/2018]
A_HEURE = "23:05:34"
A_USER  = "DOC"
A_STAMP = "20180928230534"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMBUD0B [PJBU0B]
Gosub HORODAT
Local Inpbox "PJMBUD0B" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJBU0B] As [SIM_]
Grizo [PJBU0B]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJBU0B]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=100 : Y1(0)=1 : Y2(0)=10
Return

$ON_CUR
Return

$ON_ZCUR
Onevent BEFORE_AREA Gosub AV_ZCUR From W1PJMBUD0B
Return

$AV_ZCUR
Call LECTEXTRA(zc,"TABCUR","INTDES",num$([M]CUR(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_CAMTBUDGET
Onevent BEFORE_AREA Gosub AV_CAMTBUDGET From W1PJMBUD0B
Return

$AV_CAMTBUDGET
## Action INIDEV
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PJBU0B]CUR,GDEVISE(1..GNBDEV)),1))
Chgfmt [M]CAMTBUDGET(indice) With "NPz3:"+GDEVFMT
Gosub _AFF
Return

$ON_PBUSOR
Onevent AFTER_CHANGE Gosub AMM_PBUSOR From W1PJMBUD0B
Return

$AMM_PBUSOR
Call AM_PBUSOR(zc)
If !mkstat & GOBJET
 zoncou = "PBUSOR" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PBUSOR(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_PBUSOR(VALEUR) From SUBPJBU
If mkstat : GERR = 1 : GZONE = "PBUSOR" : GZNUM = 50781 : Endif
Gosub _AFF
End

$ON_PBUSTARTDT
Onevent AFTER_CHANGE Gosub AMM_PBUSTARTDT From W1PJMBUD0B
Onevent BEFORE_AREA Gosub AV_PBUSTARTDT From W1PJMBUD0B
Return

$AV_PBUSTARTDT
Chgfmt [M]PBUSTARTDT(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$AMM_PBUSTARTDT
Call AM_PBUSTARTDT(zc)
If !mkstat & GOBJET
 zoncou = "PBUSTARTDT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PBUSTARTDT(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_PBUSTARTDT(VALEUR) From SUBPJBU
If mkstat : GERR = 1 : GZONE = "PBUSTARTDT" : GZNUM = 1805 : Endif
Gosub _AFF
End

$ON_PBUENDDT
Onevent AFTER_CHANGE Gosub AMM_PBUENDDT From W1PJMBUD0B
Onevent BEFORE_AREA Gosub AV_PBUENDDT From W1PJMBUD0B
Return

$AV_PBUENDDT
Chgfmt [M]PBUENDDT(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$AMM_PBUENDDT
Call AM_PBUENDDT(zc)
If !mkstat & GOBJET
 zoncou = "PBUENDDT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PBUENDDT(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_PBUENDDT(VALEUR) From SUBPJBU
If mkstat : GERR = 1 : GZONE = "PBUENDDT" : GZNUM = 1806 : Endif
Gosub _AFF
End

$ON_ORIPBU
Return

$ON_PBUNUM
Return

$CHG_STY
Return


