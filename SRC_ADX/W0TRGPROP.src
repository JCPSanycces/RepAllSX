#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TRGPROP 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone SUBMITTER
mkstat = 0
zoncou = "SUBMITTER"
indice = 0
IMPENT = [M]SUBMITTER
If varinit([M]SUBMITTER,indice)=0
 IMPENT = 1
Endif
If varmode([M]SUBMITTER,indice)=0
 [M]SUBMITTER(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SUBMITTER" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SUBMITTER(indice)
 Endif
Endif
[M]SUBMITTER = IMPENT

## Zone CRN
mkstat = 0
zoncou = "CRN"
indice = 0
If varmode([M]CRN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CRN" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone DFV
mkstat = 0
zoncou = "DFV"
indice = 0
IMPENT = [M]DFV
WNUM = IMPENT
If varinit([M]DFV,indice)=0
 IMPENT = 1
Endif
If varmode([M]DFV,indice)=0
 [M]DFV(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFV" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DFV(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_DFV(IMPENT) From TRGP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "DFV" : GZNUM = 49958 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]DFV = IMPENT

## Zone KNZ23
mkstat = 0
zoncou = "KNZ23"
indice = 0
IMPENT = [M]KNZ23
If varinit([M]KNZ23,indice)=0
 IMPENT = 1
Endif
If varmode([M]KNZ23,indice)=0
 [M]KNZ23(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "KNZ23" : Gosub ACTION From =IMPTRT
  IMPENT = [M]KNZ23(indice)
 Endif
Endif
[M]KNZ23 = IMPENT

## Zone KNZ10
mkstat = 0
zoncou = "KNZ10"
indice = 0
IMPENT = [M]KNZ10
If varinit([M]KNZ10,indice)=0
 IMPENT = 1
Endif
If varmode([M]KNZ10,indice)=0
 [M]KNZ10(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "KNZ10" : Gosub ACTION From =IMPTRT
  IMPENT = [M]KNZ10(indice)
 Endif
Endif
[M]KNZ10 = IMPENT

## Zone KNZ22
mkstat = 0
zoncou = "KNZ22"
indice = 0
IMPENT = [M]KNZ22
If varinit([M]KNZ22,indice)=0
 IMPENT = 1
Endif
If varmode([M]KNZ22,indice)=0
 [M]KNZ22(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "KNZ22" : Gosub ACTION From =IMPTRT
  IMPENT = [M]KNZ22(indice)
 Endif
Endif
[M]KNZ22 = IMPENT

## Zone KNZ29
mkstat = 0
zoncou = "KNZ29"
indice = 0
IMPENT = [M]KNZ29
If varinit([M]KNZ29,indice)=0
 IMPENT = 1
Endif
If varmode([M]KNZ29,indice)=0
 [M]KNZ29(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "KNZ29" : Gosub ACTION From =IMPTRT
  IMPENT = [M]KNZ29(indice)
 Endif
Endif
[M]KNZ29 = IMPENT

## Zone KNZ26
mkstat = 0
zoncou = "KNZ26"
indice = 0
IMPENT = [M]KNZ26
If varinit([M]KNZ26,indice)=0
 IMPENT = 1
Endif
If varmode([M]KNZ26,indice)=0
 [M]KNZ26(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "KNZ26" : Gosub ACTION From =IMPTRT
  IMPENT = [M]KNZ26(indice)
 Endif
Endif
[M]KNZ26 = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone TYPEXP
mkstat = 0
zoncou = "TYPEXP"
indice = 0
IMPENT = [M]TYPEXP
WNUM = IMPENT
If varinit([M]TYPEXP,indice)=0
 IMPENT = 1
Endif
If varmode([M]TYPEXP,indice)=0
 [M]TYPEXP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYPEXP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYPEXP(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_TYPEXP(IMPENT) From TRGP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TYPEXP" : GZNUM = 32516 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]TYPEXP = IMPENT

## Zone VOLFIL
mkstat = 0
zoncou = "VOLFIL"
indice = 0
If varmode([M]VOLFIL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VOLFIL" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_VOLFIL([M]VOLFIL) From TRGP
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "VOLFIL" : GZNUM = 49957 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "TRGPROP"
Return

