              When 10
                If ICRIFIETYP = 1 or ICRIFIETYP = 2 Then
                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= 0' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= 0' Using [CRM1]
                      Else
                        Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '= 0' Using [CRM1]
                      Endif
