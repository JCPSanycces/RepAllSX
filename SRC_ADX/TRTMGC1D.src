                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= [00/00/00]' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= [00/00/00]' Using [CRM1]
                      Else
                        Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '= [00/00/00]' Using [CRM1]
                      Endif
                    Next
                  Endif
                Elsif ICRIFIETYP >= 4 and ICRIFIETYP <= 9 Then
                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= 0' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= 0' Using [CRM1]
                      Else
                        Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '= 0' Using [CRM1]
                      Endif
                    Next
                  Endif
                Elsif ICRIFIETYP >= 10 Then
                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= "' + '"' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= "' + '"' Using [CRM1]
                      Else
                        Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '= "' + '"' Using [CRM1]
                      Endif
                    Next
                  Endif
                Endif
            Endcase
          Endif
        Endif
        Wrseq '& )' Using [CRM1]
        Break
      Endif
      If GERR Then
        Break
      Endif
    Next
    Filter [QCR]
    # FGR 09/02/2010 : X3SUIVI60986
    If GERR Then
      Break
    Endif
    #On ajoute les parenthèses à droite du critère
    ICURCRIPOS = instr(ISTARTCTL, SZPPLGRUDIO, SZCRIDIO)
    ITERRIGHT = 1
    SZPARLIS = ""
    While 1
      #On se déplace vers la droite
      IOUTOFRANGE = ICURCRIPOS + ITERRIGHT
      If IOUTOFRANGE > len(SZPPLGRUDIO) Then
        Break
      Elsif mid$(SZPPLGRUDIO, IOUTOFRANGE, 1) = "&" Then
        Break
      Elsif mid$(SZPPLGRUDIO, IOUTOFRANGE, 1) = "|" Then
        Break
      Elsif mid$(SZPPLGRUDIO, IOUTOFRANGE, 1) = "+" Then
        Break
      Elsif mid$(SZPPLGRUDIO, IOUTOFRANGE, 1) = "-" Then
        Break
      Endif
      SZPARLIS = SZPARLIS + mid$(SZPPLGRUDIO, IOUTOFRANGE, 1)
      ITERRIGHT += 1
      ILOOPSECURE += 1
      If ILOOPSECURE > 50000 Then
        Break
      Endif
    Wend
    If SZPARLIS <> "" Then
      Wrseq "& " + SZPARLIS Using [CRM1]
    Endif
    ICRIDIOPOS += 1
    SZPPLGRUBUFF = right$(SZPPLGRUDIO, ICRIDIOPOS)
    INOCRILEFT = 1
    For ITERVALCRI = 1 To len(SZPPLGRUBUFF)
      If instr(1, "123456789", mid$(SZPPLGRUBUFF, ITERVALCRI, 1)) Then
        SZCRIDIO = mid$(SZPPLGRUBUFF, ITERVALCRI, 1)
        ICRIDIO = val(SZCRIDIO)
        ICRIDIOPOS = instr(1, SZPPLGRUDIO, SZCRIDIO)
        INOCRILEFT = 0
        Break
      Endif
    Next
    If INOCRILEFT Then
      Break
    Endif
    If GERR Then
      Break
    Endif
    ILOOPSECURE += 1
    If ILOOPSECURE > 50000 Then
      Break
    Endif
  Wend
  # FGR 09/02/2010 : X3SUIVI60986
  If GERR Then
    Return
  Endif
Return

################################################################################################
##############################################
# Code commun aux opérateurs simples
##############################################
$COMMONOPD
  If ICRIFIETYP = 1 or ICRIFIETYP = 2 Then
    If IUSEUSERDIM Then
      If left$([F:QCV]CRIVAL, 2) = "??" Then
        SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
        Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + SZDYNVARIABLE Using [CRM1]
      Else
        Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + [F:QCV]CRIVAL Using [CRM1]
      Endif
    Else
      For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
        If ITERFIEDIM = 0 Then
          If left$([F:QCV]CRIVAL, 2) = "??" Then
            SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
            Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + SZDYNVARIABLE Using [CRM1]
          Else
            Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + [F:QCV]CRIVAL Using [CRM1]
          Endif
        Else
          If left$([F:QCV]CRIVAL, 2) = "??" Then
            SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
            Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + SZMEMEDOPD + SZDYNVARIABLE Using [CRM1]
          Else
            Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + SZMEMEDOPD + [F:QCV]CRIVAL Using [CRM1]
          Endif
        Endif
      Next
    Endif
  Elsif ICRIFIETYP = 3 Then
    If IUSEUSERDIM Then
      If instr(1, [F:QCV]CRIVAL, "date$") Then
        Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + ' [' + format$(GFMD,evalue([F:QCV]CRIVAL)) + ']' Using [CRM1]
      Else
        If left$([F:QCV]CRIVAL, 2) = "??" Then
          SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
          Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + SZDYNVARIABLE  Using [CRM1]
        Else
          Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + ' [' + format$(GFMD,[F:QCV]CRIVALDAT) + ']' Using [CRM1]
        Endif
      Endif
    Else
      For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
        If ITERFIEDIM = 0 Then
          If instr(1, [F:QCV]CRIVAL, "date$") Then
            Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + ' [' + format$(GFMD,evalue([F:QCV]CRIVAL)) + ']' Using [CRM1]
          Else
            If left$([F:QCV]CRIVAL, 2) = "??" Then
              SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
              Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + SZDYNVARIABLE Using [CRM1]
            Else
              Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + ' [' + format$(GFMD,[F:QCV]CRIVALDAT) + ']' Using [CRM1]
            Endif
          Endif
        Else
          If instr(1, [F:QCV]CRIVAL, "date$") Then
            Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + SZMEMEDOPD + ' [' + format$(GFMD,evalue([F:QCV]CRIVAL)) + ']' Using [CRM1]
          Else
            If left$([F:QCV]CRIVAL, 2) = "??" Then
              SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
              Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + SZMEMEDOPD + SZDYNVARIABLE Using [CRM1]
            Else
              Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + SZMEMEDOPD + ' [' + format$(GFMD,[F:QCV]CRIVALDAT) + ']' Using [CRM1]
            Endif
          Endif
        Endif
      Next
    Endif
  Elsif ICRIFIETYP >= 4 and ICRIFIETYP <= 9 Then
    If IUSEUSERDIM Then
      If left$([F:QCV]CRIVAL, 2) = "??" Then
        SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
        Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + SZDYNVARIABLE Using [CRM1]
      Else
        Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + [F:QCV]CRIVAL Using [CRM1]
      Endif
    Else
      For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
        If ITERFIEDIM = 0 Then
          If left$([F:QCV]CRIVAL, 2) = "??" Then
            SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
            Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + SZDYNVARIABLE Using [CRM1]
          Else
            Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + [F:QCV]CRIVAL Using [CRM1]
          Endif
        Else
          If left$([F:QCV]CRIVAL, 2) = "??" Then
            SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
            Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + SZMEMEDOPD + SZDYNVARIABLE Using [CRM1]
          Else
            Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + SZMEMEDOPD + [F:QCV]CRIVAL Using [CRM1]
          Endif
        Endif
      Next
    Endif
  Elsif ICRIFIETYP >= 10 Then
    IEMPSTRING = 0
    If [F:QCV]CRIVAL = '""' or [F:QCV]CRIVAL = "''" or [F:QCV]CRIVAL = "" Then
      If IUSEUSERDIM Then
        Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + '""' Using [CRM1]
      Else
        For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
          If ITERFIEDIM = 0 Then
            Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + '""' Using [CRM1]
          Else
            Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + SZMEMEDOPD + '""' Using [CRM1]
          Endif
        Next
      Endif
      IEMPSTRING = 1
    Endif
    If !IEMPSTRING Then
      If IUSEUSERDIM Then
        If left$([F:QCV]CRIVAL, 2) = "??" Then
          SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
          If evalue(SZDYNVARIABLE) = "" Then
            Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + '""' Using [CRM1]
          Else
            Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + SZDYNVARIABLE Using [CRM1]
          Endif
        Else
          Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + '"' + [F:QCV]CRIVAL + '"' Using [CRM1]
        Endif
      Else
        For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
          If ITERFIEDIM = 0 Then
            If left$([F:QCV]CRIVAL, 2) = "??" Then
              SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
              If evalue(SZDYNVARIABLE) = "" Then
                Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + '""' Using [CRM1]
              Else
                Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + SZDYNVARIABLE Using [CRM1]
              Endif
            Else
              Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + SZMEMEDOPD + '"' + [F:QCV]CRIVAL + '"' Using [CRM1]
            Endif
          Else
            If left$([F:QCV]CRIVAL, 2) = "??" Then
              SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
              If evalue(SZDYNVARIABLE) = "" Then
                Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + SZMEMEDOPD + '""' Using [CRM1]
              Else
                Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + SZMEMEDOPD + SZDYNVARIABLE Using [CRM1]
              Endif
            Else
              Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + SZMEMEDOPD + '"' + [F:QCV]CRIVAL + '"' Using [CRM1]
            Endif
          Endif
        Next
      Endif
    Endif
  Endif
Return
