#<AdxTL>@(#)9.0.0.0 $Revision$
#######################################################################################################################
#
#  Gestion du ciblage marketing                                              Module CRM          18 mars 2002
#
#######################################################################################################################
#  Traitement de génération d'une population sur la base d'un support de sélection de type :
#  LIAISON DE PREMIER NIVEAU
#######################################################################################################################
# Liste des sous-programmes :
# GENRTFLEV    : Génération d'une population
# QGENRTFLEV   : Programme de remise en état des ressources suite à une arrêt sur erreur dans GENRTFLEV
#######################################################################################################################
################################################################################################
Subprog GENRTFLEV(SZQURCOD, IPPLORDCOD, IALLTARGET, SZGRUGRU)
Value Char SZQURCOD
Value Integer IPPLORDCOD
Value Integer IALLTARGET
Variable Char SZGRUGRU

Local Integer IMQP7COUNT
Local Integer ISTHERECRIIN
Local Char SZMESSNOCRI(250)
Local Integer IREP

  ISTHERECRIIN = 0
  SZMESSNOCRI = ""
  IREP = 0
  IMQP7COUNT = 0
  If IALLTARGET = 0 Then
    Filter [QCR] Where [F:QCR]QURNUM = SZQURCOD and [F:QCR]PPLORD = IPPLORDCOD
    For [QCR]QCR1
      ISTHERECRIIN += 1
    Next
    Filter [QCR]
    If ISTHERECRIIN = 0 Then
      #Aucun critère n'a été saisie pour la population n° XXX.
      #Voulez-vous inclure la totalité de la cible dans cette population?
      If !clalev([F:MQP7]) : Local File MKGQURPPL [MQP7] : Endif
      Filter [MQP7] Where [F:MQP7]QURNUM = SZQURCOD
      For [MQP7]MQP1
        IMQP7COUNT += 1
        If [F:MQP7]PPLORD = IPPLORDCOD Then
          Break
        Endif
      Next
      Filter [MQP7]
      SZMESSNOCRI = mess(752,196,1) - num$(IMQP7COUNT) + '.' - mess(753,196,1)
      IREP = 0
      Call OUINON(SZMESSNOCRI, IREP) From GESECRAN
      If IREP = 2 Then
        IALLTARGET = 1
      Else
        End
      Endif
    Endif
  Endif

Local Char SZCRIOPD
Local Char SZPRETAB
Local Char SZKEYIND
Local Char SZBESTKEY
Local Char SZSUBKEY
Local Char SZCRIDIO
Local Char SZVALOPD
Local Char SZSPTFLT(250)
Local Char SZFLT1(250)
Local Char SZFLT2(250)
Local Char SZFLT3(250)
Local Char SZKEYPAE
Local Char SZABRPAE
Local Char SZQUITMASK(8)
Local Char SZPARLIS
Local Char SZTGR
Local Char SZABRTGR
Local Char SZTGRMAIKEY
Local Char SZPPLGRUDIO(250)
Local Char SZGRUDEFR(250)
Local Char SZGRUDEFL(250)
Local Char SZMSTOPD(2)(10)   #Opérateurs logiques traduits
Local Char SZCRIL
Local Char SZLNKTABLIS(30)(10)
Local Char SZGRUX2(250)
Local Char SZPPLGRUBUFF(250)
Local Char SZQCVCRIVAL(50)
Local Date DQCVCRIVALDAT
Local Integer IALRLNK
Local Integer IINDLEV
Local Integer IPLUSPOS
Local Integer IKEYPOS
Local Integer ISTARTCTL
Local Integer IFIRCRICTL
Local Integer ICRIDIO
Local Integer ICRIDIOCNT
Local Integer ICRIFIETYP
Local Integer ICRIFIEDIM
Local Integer INBVAL
Local Integer IFLTSTR
Local Integer ILOOPSECURE
Local Integer IOUTOFRANGE
Local Integer ITERLEFT
Local Integer ITERRIGHT
Local Integer ICURCRIPOS
Local Integer ITER
Local Integer ITER2
Local Integer ITERFIEDIM
Local Integer ICREATELNK
Local Integer IEMPSTRING
Local Integer ICRIDIOPOS
Local Integer INOCRILEFT
Local Integer ITERVALCRI
Local Integer IUSERDIMLEV
Local Integer IUSEUSERDIM
Local Integer IDIMLEVPOS1
Local Integer IDIMLEVPOS2
Local Integer IDIMLEVPOS3
#Variables utilisées pour la génération de traitements
Local Char SZADXIFS
Local Char SZADXIRS
#Variables traitement généré n°1
Local Char SZPROGNAME
Local Integer IPRGSUFIX
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Integer IEXIST
#Variables traitement généré n°2
Local Char SZPROG2NAME
Local Integer IPRG2SUFIX
Local Char SZFULL2SRC(250)
Local Char SZFULL2ADX(250)
Local Integer I2EXIST
Local Integer IVALIDOK

  SZPRETAB = ""
  SZKEYIND = ""
  SZBESTKEY = ""
  SZSUBKEY = ""
  SZCRIDIO = ""
  SZVALOPD = ""
  SZSPTFLT = ""
  SZFLT1 = ""
  SZFLT2 = ""
  SZFLT3 = ""
  SZKEYPAE = ""
  SZABRPAE = ""
  SZTGR = ""
  SZABRTGR = ""
  SZTGRMAIKEY = ""
  SZGRUX2 = SZGRUGRU
  IINDLEV = 0
  IPLUSPOS = 0
  IKEYPOS = 0
  ISTARTCTL = 0
  IFIRCRICTL = 0
  ICRIDIO = 0
  ICRIDIOCNT = 0
  ICRIFIETYP = 0
  INBVAL = 0
  IFLTSTR = 0
  ILOOPSECURE = 0
  SZQUITMASK = "00000000"
  ICREATELNK = 0
  IEMPSTRING = 0
  #On sauvegarde les variables adxifs et adxirs
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  ################################
  #On génère un fichier de code d'exécution d'une recherche de population
  Raz SZPROGNAME
  Raz SZFULLSRC
  Raz SZFULLADX
  Raz IEXIST
  IPRGSUFIX = 1
  While 1
    SZPROGNAME = "CRMRT" + num$(IPRGSUFIX)
    SZFULLSRC = filpath("TRT",SZPROGNAME,"src",nomap)
    SZFULLADX = filpath("TRT",SZPROGNAME,"adx",nomap)
    #Contrôle de l'existence du src
    IEXIST = 0
    Call EXISTE(SZFULLSRC,IEXIST) From ORDSYS
    If IEXIST Then
      #Calcul un nouveau suffixe pour le traitement
      IPRGSUFIX += 1
    Else
      #Contrôle de l'existence de l'adx
      IEXIST = 0
      Call EXISTE(SZFULLADX,IEXIST) From ORDSYS
      If IEXIST Then
        #Calcul un nouveau suffixe pour le traitement
        IPRGSUFIX += 1
      Else
        Break
      Endif
    Endif
    ILOOPSECURE += 1
    If ILOOPSECURE > 50000 Then
      Break
    Endif
  Wend
  #Ouverture du traitement à générer
  Openo SZFULLSRC, 0 Using [CRM1]
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%" Using [CRM1]
  Wrseq "#Traitement généré d'exécution d'un ciblage marketing" Using [CRM1]
  Wrseq "Subprog LOOKUPMGG" Using [CRM1]
  #############################
  #On génére un sous-programme d'ouverture de tables pour effectuer des contrôles de types
  Raz SZPROG2NAME
  Raz SZFULL2SRC
  Raz SZFULL2ADX
  Raz I2EXIST
  IPRG2SUFIX = 1
  #Détermine un nom disponible pour le traitement
  While 1
    SZPROG2NAME = "CRMRX" + num$(IPRG2SUFIX)
    SZFULL2SRC = filpath("TRT",SZPROG2NAME,"src",nomap)
    SZFULL2ADX = filpath("TRT",SZPROG2NAME,"adx",nomap)
    #Contrôle de l'existence du src
    I2EXIST = 0
    Call EXISTE(SZFULL2SRC,I2EXIST) From ORDSYS
    If I2EXIST Then
      #Calcul un nouveau suffixe pour le traitement
      IPRG2SUFIX += 1
    Else
      #Contrôle de l'existence de l'adx
      I2EXIST = 0
      Call EXISTE(SZFULL2ADX,I2EXIST) From ORDSYS
      If I2EXIST Then
        #Calcul un nouveau suffixe pour le traitement
        IPRG2SUFIX += 1
      Else
        Break
      Endif
    Endif
    ILOOPSECURE += 1
    If ILOOPSECURE > 50000 Then
      Break
    Endif
  Wend
  #Ouverture du traitement à générer
  Openo SZFULL2SRC, 0 Using [CRM2]
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%" Using [CRM2]
  Wrseq "#Traitement généré d'ouverture de tables pour contrôle de type" Using [CRM2]
  Wrseq "$OPENTAB" Using [CRM2]
  #Ouvre toutes les tables à utiliser
  #D'abord la table cible
  If [F:SSP]SPTTGR = "" Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11101100"
    Gosub QGENRTFLEV
    End
  Endif
  Read [ATB]CODFIC=[F:SSP]SPTTGR
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11101100"
    Gosub QGENRTFLEV
    End
  Else
    SZTGR = [F:SSP]SPTTGR
    If SZTGR = "" Then
      #Erreur. Il faut nettoyer les ressources avant de dépiler.
      SZQUITMASK = "11101100"
      Gosub QGENRTFLEV
      End
    Else
      SZABRTGR = [F:ATB]ABRFIC
      Read [TGL]TGL0=SZTGR
      If fstat Then
        #Erreur. Il faut nettoyer les ressources avant de dépiler.
        SZQUITMASK = "11101100"
        Gosub QGENRTFLEV
        End
      Else
        If [F:TGL]TGRMAIKEY = "" Then
          #Erreur. Il faut nettoyer les ressources avant de dépiler.
          SZQUITMASK = "11101100"
          Gosub QGENRTFLEV
          End
        Else
          SZTGRMAIKEY = [F:TGL]TGRMAIKEY
        Endif
      Endif
    Endif
    Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + [F:SSP]SPTTGR + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM1]
    Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + [F:SSP]SPTTGR + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM2]
  Endif
  #Ensuite les tables de critères
  SZPRETAB = ""
  Filter [QCR] Where [F:QCR]QURNUM = SZQURCOD and [F:QCR]PPLORD = IPPLORDCOD
  For [QCR]QCR1
    If [F:QCR]CRITAB <> "" Then
      If [F:QCR]CRITAB <> SZTGR Then
        If [F:QCR]CRITAB <> SZPRETAB Then
          SZPRETAB = [F:QCR]CRITAB
          Read [ATB]CODFIC=[F:QCR]CRITAB
          If fstat Then
            #Erreur. Il faut nettoyer les ressources avant de dépiler.
            SZQUITMASK = "11101100"
            Gosub QGENRTFLEV
            Break
          Else
            Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + [F:QCR]CRITAB + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM1]
            Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + [F:QCR]CRITAB + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM2]
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [QCR]
  If GERR Then
    End
  Endif
  Wrseq "Return" Using [CRM2]
  #Génération du sous-programme de fermeture des tables utilisées pour le contrôle de type.
  #D'abord la table cible
  Wrseq "$CLOSETAB" Using [CRM2]
  Read [ATB]CODFIC=[F:SSP]SPTTGR
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11101100"
    Gosub QGENRTFLEV
    End
  Else
    Wrseq "Close Local File [" + [F:ATB]ABRFIC + ']' Using [CRM2]
  Endif
  SZPRETAB = ""
  Filter [QCR] Where [F:QCR]QURNUM = SZQURCOD and [F:QCR]PPLORD = IPPLORDCOD
  For [QCR] QCR1
    If [F:QCR]CRITAB <> "" Then
      If [F:QCR]CRITAB <> SZTGR Then
        If [F:QCR]CRITAB <> SZPRETAB Then
          SZPRETAB = [F:QCR]CRITAB
          Read [ATB]CODFIC=[F:QCR]CRITAB
          If fstat Then
            #Erreur. Il faut nettoyer les ressources avant de dépiler.
            SZQUITMASK = "11101100"
            Gosub QGENRTFLEV
            Break
          Else
            Wrseq "Close Local File [" + [F:ATB]ABRFIC + ']' Using [CRM2]
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [QCR]
  If GERR Then
    End
  Endif
  Wrseq "Return" Using [CRM2]
  Wrseq "#Fin du traitement généré" Using [CRM2]
  #Fermeture du traitement généré
  Openo Using [CRM2]

  #Compilation du traitement généré
  IVALIDOK = 1
  Call VALID("TRT", SZPROG2NAME, nomap, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11100110"
    Gosub QGENRTFLEV
    End
  Endif
  If GMESSAGE <> "" Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11100110"
    Gosub QGENRTFLEV
    End
  Endif
  #Avant de générer un Link, on détermine si au moins un critère a été posé sur une table liée.
  #Sinon, il suffit de poser une filtre sur la cible.
  ICREATELNK = 0
  Filter [QCR] Where [F:QCR]QURNUM = SZQURCOD and [F:QCR]PPLORD = IPPLORDCOD
  For [QCR] QCR1
    If [F:QCR]CRITAB <> SZTGR Then
      ICREATELNK += 1
      Break
    Endif
  Next
  Filter [QCR]
  #Création du Link
  If ICREATELNK Then
    Read [ATB]CODFIC=[F:SSP]SPTTGR
    If fstat Then
      #Erreur. Il faut nettoyer les ressources avant de dépiler.
      SZQUITMASK = "11100110"
      Gosub QGENRTFLEV
      End
    Else
      Wrseq "Link [" + [F:ATB]ABRFIC + "] With" Using [CRM1]
    Endif
    #Génération des expressions de lien
    SZPRETAB = ""
    ITER = 0
    IFIRCRICTL = 0
    Raz SZLNKTABLIS
    Filter [QCR] Where [F:QCR]QURNUM = SZQURCOD and [F:QCR]PPLORD = IPPLORDCOD
    For [QCR]QCR1
      If [F:QCR]CRITAB <> "" Then
        #Vérifie si la table n'a pas déjà été liée
        ITER = 0
        IALRLNK = 0
        While SZLNKTABLIS(ITER) <> ""
          If [F:QCR]CRITAB = SZLNKTABLIS(ITER) Then
            IALRLNK = 1
            Break
          Endif
          ITER += 1
          If ITER >= dim(SZLNKTABLIS) Then
            Break
          Endif
        Wend
        If !IALRLNK Then
          #Cherche un emplacement de libre dans SZLNKTABLIS
          For ITER = 0 To dim(SZLNKTABLIS)-1
            If SZLNKTABLIS(ITER) = "" Then
              SZLNKTABLIS(ITER) = [F:QCR]CRITAB
              Break
            Endif
          Next
          Filter [SSC] Where [F:SSC]SPTNUM = [F:SSP]SPTNUM and [F:SSC]SPTTAB = [F:QCR]CRITAB
          For [SSC]SSC1
            If [F:SSC]SPTTAB = [F:QCR]CRITAB Then
              If [F:SSC]SPTKEY <> "" Then
                Read [ATB]CODFIC=[F:SSC]SPTTAB
                If fstat Then
                  #Erreur. Il faut nettoyer les ressources avant de dépiler.
                  SZQUITMASK = "11100110"
                  Gosub QGENRTFLEV
                  Break
                Else
                  If IFIRCRICTL Then
                    Wrseq "& ,[" + [F:ATB]ABRFIC + ']' + [F:SSC]SPTIDX + ' = ' + [F:SSC]SPTFLT Using [CRM1]
                  Else
                    Wrseq "& [" + [F:ATB]ABRFIC + ']' + [F:SSC]SPTIDX + ' = ' + [F:SSC]SPTFLT Using [CRM1]
                    IFIRCRICTL += 1
                  Endif
                Endif
              Endif
            Endif
          Next
          Filter [SSC]
          If GERR Then
            Break
          Endif
        Endif
      Endif
    Next
    Filter [QCR]
    If GERR Then
      End
    Endif
    Wrseq "& As [LNK]" Using [CRM1]
    #Définit l'ordre de tri pour la boucle de For de recherche
    Wrseq "& Order By Key KBID = [F:" + SZABRTGR + ']' + SZTGRMAIKEY + " Asc" Using [CRM1]
  Endif
  #Déclaration des variables utiles pour la boucle de recherche
  Wrseq "Local Integer IPERF" Using [CRM1]
  Wrseq "Local Integer INTR" Using [CRM1]
  Wrseq "Local Integer IPBL" Using [CRM1]
  Wrseq "Local Char SZCLE" Using [CRM1]
  Wrseq "Local Integer ICLECOUNT" Using [CRM1]
  Wrseq "Local Integer ICUT" Using [CRM1]
  Wrseq "IPERF = 0" Using [CRM1]
  Wrseq "INTR = 0" Using [CRM1]
  Wrseq "IPBL = 0" Using [CRM1]
  Wrseq "SZCLE = " + '"' + '"' Using [CRM1]
  Wrseq "ICUT = 5000" Using [CRM1]
  Wrseq "ICLECOUNT = ICUT" Using [CRM1]
  #Nettoyage de la table
  Wrseq "Call DEBTRANS From GLOCK" Using [CRM1]
  Wrseq "Trbegin [QTP]" Using [CRM1]
  Wrseq "Delete [QTP] Where [F:QTP]QURNUM = " + '"' + SZQURCOD + '"' + " and [F:QTP]PPLORD = " + num$(IPPLORDCOD) Using [CRM1]
  Wrseq "If fstat" Using [CRM1]
  Wrseq "Rollback" Using [CRM1]
  Wrseq "GERR = 1" Using [CRM1]
  Wrseq "Else" Using [CRM1]
  Wrseq "Commit" Using [CRM1]
  Wrseq "Endif" Using [CRM1]
  Wrseq "If GERR : End : Endif" Using [CRM1]
  #Les liens sont posés
  #On s'occupe du filtre
  #On ouvre d'abord les tables nécessaires aux contrôles de type des champs
  Gosub OPENTAB From =SZPROG2NAME
  Wrseq "While ICLECOUNT >= ICUT" Using [CRM1]
  Wrseq "ICLECOUNT = 0" Using [CRM1]
  If IALLTARGET Then
    Case SZABRTGR
      When "AIN"
        Wrseq "Filter [" + SZABRTGR + "] Where ([F:" + SZABRTGR + ']' + SZTGRMAIKEY + " > SZCLE and [F:AIN]CNTTYP=1) " Using [CRM1]
      When "LDS"
        Wrseq "Filter [" + SZABRTGR + "] Where ([F:" + SZABRTGR + ']' + SZTGRMAIKEY + " > SZCLE and [F:LDS]PSTTYP=2) " Using [CRM1]
      When Default
        Wrseq "Filter [" + SZABRTGR + "] Where [F:" + SZABRTGR + ']' + SZTGRMAIKEY + " > SZCLE" Using [CRM1]
    Endcase
  Else
    If ICREATELNK Then
      Case SZABRTGR
        When "AIN"
          Wrseq "Filter [LNK] Where ([F:" + SZABRTGR + ']' + SZTGRMAIKEY + " > SZCLE and [F:AIN]CNTTYP=1) & " Using [CRM1]
        When "LDS"
          Wrseq "Filter [LNK] Where ([F:" + SZABRTGR + ']' + SZTGRMAIKEY + " > SZCLE and [F:LDS]PSTTYP=2)& " Using [CRM1]
        When Default
          Wrseq "Filter [LNK] Where [F:" + SZABRTGR + ']' + SZTGRMAIKEY + " > SZCLE & " Using [CRM1]
      Endcase
    Else
      Case SZABRTGR
        When "AIN"
          Wrseq "Filter [" + SZABRTGR + "] Where ([F:" + SZABRTGR + ']' + SZTGRMAIKEY + " > SZCLE and [F:AIN]CNTTYP=1) & " Using [CRM1]
        When "LDS"
          Wrseq "Filter [" + SZABRTGR + "] Where ([F:" + SZABRTGR + ']' + SZTGRMAIKEY + " > SZCLE and [F:LDS]PSTTYP=2) & " Using [CRM1]
        When Default
          Wrseq "Filter [" + SZABRTGR + "] Where [F:" + SZABRTGR + ']' + SZTGRMAIKEY + " > SZCLE & " Using [CRM1]
      Endcase
    Endif
  Endif
  #On ajoute les critères de ciblage
  If !IALLTARGET Then
    #Traduction du regroupement des critères pour la gestion des parenthèses
    SZPPLGRUDIO = vireblc(SZGRUX2, 4)
    Gosub TRNSCRIGRU
    #Génération du filtre
    Gosub GENFILTER
    If GERR Then
      #Erreur. Il faut nettoyer les ressources avant de dépiler.
      SZQUITMASK = "11100110"
      Gosub QGENRTFLEV
    Endif
  Endif
  If GERR Then
    End
  Endif
  If ICREATELNK Then
    Wrseq "For [LNK] KBID" Using [CRM1]
  Else
    Wrseq "For [" + SZABRTGR + ']' Using [CRM1]
  Endif
  Wrseq "SZCLE = [F:" + SZABRTGR + ']' + SZTGRMAIKEY Using [CRM1]
  Wrseq "Read [QTP] QTP1 = " + '"' + SZQURCOD + '";' + num$(IPPLORDCOD) + ";[F:" + SZABRTGR + ']' + SZTGRMAIKEY Using [CRM1]
  Wrseq "If fstat" Using [CRM1]
  Wrseq "If IPERF = 0" Using [CRM1]
  Wrseq "Call DEBTRANS From GLOCK" Using [CRM1]
  Wrseq "Trbegin [QTP]" Using [CRM1]
  Wrseq "INTR = 1" Using [CRM1]
  Wrseq "Endif" Using [CRM1]
  Wrseq "[F:QTP]QURNUM = " + '"' + SZQURCOD + '"' Using [CRM1]
  Wrseq "[F:QTP]PPLORD = " + num$(IPPLORDCOD) Using [CRM1]
  Wrseq "[F:QTP]SPTTYP = 4" Using [CRM1]
  Wrseq "[F:QTP]CRINUM = 0" Using [CRM1]
  Wrseq "[F:QTP]CRIVALNUM = 0" Using [CRM1]
  Wrseq '[F:QTP]WKGTAB = ""' Using [CRM1]
  Wrseq "[F:QTP]SPTLEV = 0" Using [CRM1]
  Wrseq '[F:QTP]KEYREC = ""' Using [CRM1]
  Wrseq "[F:QTP]KEYTGR = [F:" + SZABRTGR + ']' + SZTGRMAIKEY Using [CRM1]
  Wrseq "Write [QTP]" Using [CRM1]
  Wrseq "If fstat" Using [CRM1]
  Wrseq "Rollback" Using [CRM1]
  Wrseq "GERR = 1" Using [CRM1]
  Wrseq "IPBL = 1" Using [CRM1]
  Wrseq "INTR = 0" Using [CRM1]
  Wrseq "Break" Using [CRM1]
  Wrseq "Else" Using [CRM1]
  Wrseq "If IPERF >= 500" Using [CRM1]
  Wrseq "Commit" Using [CRM1]
  Wrseq "IPERF = 0" Using [CRM1]
  Wrseq "INTR = 0" Using [CRM1]
  Wrseq "Else" Using [CRM1]
  Wrseq "IPERF += 1" Using [CRM1]
  Wrseq "Endif" Using [CRM1]
  Wrseq "Endif" Using [CRM1]
  Wrseq "Endif" Using [CRM1]
  Wrseq "ICLECOUNT += 1" Using [CRM1]
  Wrseq "If ICLECOUNT >= ICUT : Break : Endif" Using [CRM1]
  Wrseq "If IPBL : Break : Endif" Using [CRM1]
  Wrseq "Next" Using [CRM1]
  If ICREATELNK Then
    Wrseq "Filter [LNK]" Using [CRM1]
  Else
    Wrseq "Filter [" + SZABRTGR + ']' Using [CRM1]
  Endif
  Wrseq "If IPBL : Break : Endif" Using [CRM1]
  Wrseq "Wend" Using [CRM1]
  Wrseq "If INTR" Using [CRM1]
  Wrseq "If !IPBL" Using [CRM1]
  Wrseq "Commit" Using [CRM1]
  Wrseq "Endif" Using [CRM1]
  Wrseq "Endif" Using [CRM1]
  #Ferme toutes les tables utilisées
  #D'abord la table cible
  Wrseq "Close Local File [" + SZABRTGR + ']' Using [CRM1]
  SZPRETAB = ""
  Filter [QCR] Where [F:QCR]QURNUM = SZQURCOD and [F:QCR]PPLORD = IPPLORDCOD
  For [QCR] QCR1
    If [F:QCR]CRITAB <> "" Then
      If [F:QCR]CRITAB <> SZTGR Then
        If [F:QCR]CRITAB <> SZPRETAB Then
          SZPRETAB = [F:QCR]CRITAB
          Read [ATB]CODFIC=[F:QCR]CRITAB
          If fstat Then
            #Erreur. Il faut nettoyer les ressources avant de dépiler.
            SZQUITMASK = "11100110"
            Gosub QGENRTFLEV
            Break
          Else
            Wrseq "Close Local File [" + [F:ATB]ABRFIC + ']' Using [CRM1]
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [QCR]
  If GERR Then
    End
  Endif
  #On ferme les tables utilisées pour le contrôle de type
  Gosub CLOSETAB From =SZPROG2NAME
  #On supprime le traitement SZPROG2NAME
  I2EXIST = 1
  Call EFFACE(SZFULL2SRC, I2EXIST) From ORDSYS
  I2EXIST = 1
  Call EFFACE(SZFULL2ADX, I2EXIST) From ORDSYS
  #On termine le traitement SZPROGNAME
  Wrseq "End" Using [CRM1]
  Wrseq "#Fin du traitement généré" Using [CRM1]
  #Fermeture du traitement généré
  Openo Using [CRM1]
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS

  #Compilation du traitement généré
  IVALIDOK = 1
  Call VALID("TRT", SZPROGNAME, nomap, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "00110000"
    Gosub QGENRTFLEV
    End
  Endif
  If GMESSAGE <> "" Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "00110000"
    Gosub QGENRTFLEV
    End
  Endif
  #Exécution du traitement généré
  Call LOOKUPMGG From =SZPROGNAME
  #Suppression du traitement généré après service rendu
  IEXIST = 1
  Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  IEXIST = 1
  Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
  #Si erreur, il faut supprimer le contenu de la table QURTMP pour le ciblage courant
  If GERR Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "00000001"
    Gosub QGENRTFLEV
    End
  Endif
End

################################################################################################
##################################################################
# Programme de remise en état des ressources suite à une arrêt sur erreur dans GENRTFLEV
##################################################################
$QGENRTFLEV
  #####################################################################
  #Table des tâches de nettoyage :
  # 0 : On restaure les variables adxifs et adxirs
  # 1 : On ferme le fichier CRMRTXXX
  # 2 : Suppression physique du fichier CRMRTXXX.src
  # 3 : Suppression physique du fichier CRMRTXXX.adx
  # 4 : On ferme le fichier CRMRXNNN
  # 5 : Suppression physique du fichier CRMRXNNN.src
  # 6 : Suppression physique du fichier CRMRXNNN.adx
  # 7 : Suppression de toutes les populations du ciblage dans QURTMP
  ######################################################################
  #On signale toujours l'erreur
  GERR = 1
  If val(mid$(SZQUITMASK, 1, 1)) Then
    #On restaure les variables adxifs et adxirs
    adxifs = SZADXIFS
    adxirs = SZADXIRS
  Endif
  If val(mid$(SZQUITMASK, 2, 1)) Then
    #On ferme le fichier CRMRTXXX
    Openo Using [CRM1]
  Endif
  If val(mid$(SZQUITMASK, 3, 1)) Then
    #Suppression physique du fichier CRMRTXXX.src
    IEXIST = 1
    Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  Endif
  If val(mid$(SZQUITMASK, 4, 1)) Then
    #Suppression physique du fichier CRMRTXXX.adx
    IEXIST = 1
    Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
  Endif
  If val(mid$(SZQUITMASK, 5, 1)) Then
    #On ferme le fichier CRMRXNNN
    Openo Using [CRM2]
  Endif
  If val(mid$(SZQUITMASK, 6, 1)) Then
    #Suppression physique du fichier CRMRXNNN.src
    IEXIST = 1
    Call EFFACE(SZFULL2SRC, IEXIST) From ORDSYS
  Endif
  If val(mid$(SZQUITMASK, 7, 1)) Then
    #Suppression physique du fichier CRMRXNNN.adx
    IEXIST = 1
    Call EFFACE(SZFULL2ADX, IEXIST) From ORDSYS
  Endif
  If val(mid$(SZQUITMASK, 8, 1)) Then
    #Suppression de toutes les populations du ciblage dans QURTMP
    Call DEBTRANS From GLOCK
    Trbegin [QTP]
    Delete [QTP] Where [F:QTP]QURNUM = SZQURCOD
    If fstat Then
      Rollback
    Else
      Commit
    Endif
  Endif
Return

################################################################################################
################################################################
# Traduit le regroupement des critères avec uniquement des éléments de 1 caractère
################################################################
$TRNSCRIGRU
  Raz SZGRUDEFR
  Raz SZGRUDEFL
  Raz SZMSTOPD
  Raz SZCRIL
  Raz ITER
  Raz ITER2
  #Traduction des opérateurs
  ITER = 1
  Filter [QCR] Where [F:QCR]QURNUM = SZQURCOD and [F:QCR]PPLORD = IPPLORDCOD
  For [QCR]QCR1
    Case [F:QCR]CRIOPD
      When 1
        SZMSTOPD(ITER) = '.'
      When 2
        SZMSTOPD(ITER) = '&'
      When 3
        SZMSTOPD(ITER) = '|'
      When 4
        SZMSTOPD(ITER) = '+'
      When 5
        SZMSTOPD(ITER) = '-'
      When Default
    Endcase
    ITER += 1
  Next
  Filter [QCR]
  ITER = 1
  While ITER < len(SZPPLGRUDIO)
    If !instr(1, "()&|!0123456789", mid$(SZPPLGRUDIO, ITER, 1)) Then
      While !instr(1, "()&|!0123456789", mid$(SZPPLGRUDIO, ITER, 1))
        If ITER >= len(SZPPLGRUDIO) Then
          Break 2
        Endif
        SZGRUDEFL = left$(SZPPLGRUDIO, ITER-1)
        SZGRUDEFR = right$(SZPPLGRUDIO, ITER+1)
        SZPPLGRUDIO = SZGRUDEFL + SZGRUDEFR
        ILOOPSECURE += 1
        If ILOOPSECURE > 50000 Then
          Break
        Endif
      Wend
      SZGRUDEFL = left$(SZPPLGRUDIO, ITER - 1)
      SZGRUDEFR = right$(SZPPLGRUDIO, ITER)
      ITER2 = 1
      SZCRIL = ""
      While 1
        If instr(1, "0123456789", mid$(SZGRUDEFR, ITER2, 1)) Then
          SZCRIL = SZCRIL + mid$(SZGRUDEFR, ITER2, 1)
          ITER2 += 1
        Else
          If SZCRIL = "" Then
            ITER2 += 1
          Else
            Break
          Endif
        Endif
        ILOOPSECURE += 1
        If ILOOPSECURE > 50000 Then
          Break
        Endif
      Wend
      SZPPLGRUDIO = SZGRUDEFL + SZMSTOPD(val(SZCRIL)) + SZGRUDEFR
    Endif
    ITER += 1
    ILOOPSECURE += 1
    If ILOOPSECURE > 50000 Then
      Break
    Endif
  Wend
Return

################################################################################################
#######################################################################
# Génération du filtre
#######################################################################
$GENFILTER
Local Char SZDYNVARIABLE(50)
Local Char SZDYNCONTENT(50)
Local Decimal IDYNCONTENT
Local Char SZMEMEDOPD

  SZDYNCONTENT = ""
  SZDYNVARIABLE = ""
  SZMEMEDOPD = ""
  IDYNCONTENT = 0
  #On définit le critère le début à traiter
  ICRIDIOPOS = 1
  For ITERVALCRI = 1 To len(SZPPLGRUDIO)
    If instr(1, "123456789", mid$(SZPPLGRUDIO, ITERVALCRI, 1)) Then
      SZCRIDIO = mid$(SZPPLGRUDIO, ITERVALCRI, 1)
      ICRIDIO = val(SZCRIDIO)
      ICRIDIOPOS = instr(1, SZPPLGRUDIO, SZCRIDIO)
      Break
    Endif
  Next
  #Initialisation des variables pour la génération du filtre
  ISTARTCTL = 1
  ICRIDIOCNT = 0
  IFIRCRICTL = 0
  While instr(ISTARTCTL, SZPPLGRUDIO, SZCRIDIO)
    #Ajoute l'opérateur inter-critères s'il ne s'agit pas du premier critère.
    ICRIDIOCNT = 0
    Filter [QCR] Where [F:QCR]QURNUM = SZQURCOD and [F:QCR]PPLORD = IPPLORDCOD
    For [QCR]QCR1
      ICRIDIOCNT += 1
      If ICRIDIOCNT = ICRIDIO Then
        If IFIRCRICTL Then
          Case [F:QCR]CRIOPD
            When 2
              SZCRIOPD = "&"
            When 3
              SZCRIOPD = "|"
            When 4
              SZCRIOPD = "&!"
            When 5
              SZCRIOPD = "|!"
          Endcase
          Wrseq "& " + SZCRIOPD Using [CRM1]
        Else
          SZCRIOPD = ""
          IFIRCRICTL = 1
        Endif
      Endif
    Next
    Filter [QCR]
    #On ajoute les parenthèses à gauche du critère
    ICURCRIPOS = instr(ISTARTCTL, SZPPLGRUDIO, SZCRIDIO)
    ITERLEFT = 1
    SZPARLIS = ""
    While 1
      #On se déplace vers la gauche
      IOUTOFRANGE = ICURCRIPOS - ITERLEFT
      If IOUTOFRANGE <= 0 Then
        Break
      Elsif mid$(SZPPLGRUDIO, IOUTOFRANGE, 1) = "&" Then
        Break
      Elsif mid$(SZPPLGRUDIO, IOUTOFRANGE, 1) = "|" Then
        Break
      Elsif mid$(SZPPLGRUDIO, IOUTOFRANGE, 1) = "+" Then
        Break
      Elsif mid$(SZPPLGRUDIO, IOUTOFRANGE, 1) = "-" Then
        Break
      Endif
      SZPARLIS = SZPARLIS + mid$(SZPPLGRUDIO, IOUTOFRANGE, 1)
      ITERLEFT += 1
      ILOOPSECURE += 1
      If ILOOPSECURE > 50000 Then
        Break
      Endif
    Wend
    If SZPARLIS <> "" Then
      Wrseq "& " + SZPARLIS Using [CRM1]
    Endif
    ICRIDIOCNT = 0
    Filter [QCR] Where [F:QCR]QURNUM = SZQURCOD and [F:QCR]PPLORD = IPPLORDCOD
    For [QCR]QCR1
      ICRIDIOCNT += 1
      If ICRIDIOCNT = ICRIDIO Then
        INBVAL = 0
        Filter [QCV] Where [F:QCV]QURNUM = SZQURCOD and [F:QCV]PPLORD = IPPLORDCOD and [F:QCV]CRINUM = [F:QCR]CRINUM
        For [QCV]QCV1
          If INBVAL > 0 Then
            #LSE 20050214 Correction dans cas différent utilisation &
            If [F:QCR]CRICND <>2 Then
              SZVALOPD = '| '
            Else
              SZVALOPD = '& '
            Endif
          Else
            Wrseq '& (' Using [CRM1]
            SZVALOPD = ""
          Endif
          Read [ATB]CODFIC=[F:QCR]CRITAB
          If fstat Then
            GERR = 1
            Break
          Else
            ICRIFIETYP = evalue("Type([F:" + [F:ATB]ABRFIC + "]" + [F:QCR]CRIFIE + ")")
            ICRIFIEDIM = evalue("Dim([F:" + [F:ATB]ABRFIC + "]" + [F:QCR]CRIFIE + ")")
            IUSEUSERDIM = 0
            If instr(1, [F:QCR]CRIFIE, '(') Then
              IDIMLEVPOS1 = instr(1, [F:QCR]CRIFIE, '(')
              If instr(1, [F:QCR]CRIFIE, ')') Then
                IDIMLEVPOS2 = instr(1, [F:QCR]CRIFIE, ')')
                If IDIMLEVPOS2 > IDIMLEVPOS1 Then
                  IDIMLEVPOS3 = IDIMLEVPOS2 - IDIMLEVPOS1
                  If IDIMLEVPOS3 > 1 Then
                    IUSERDIMLEV = val(mid$([F:QCR]CRIFIE, IDIMLEVPOS1+1, IDIMLEVPOS3-1))
                    If IUSERDIMLEV < ICRIFIEDIM Then
                      IUSEUSERDIM = 1
                    Endif
                  Endif
                Endif
              Endif
            Endif
            Case [F:QCR]CRICND
              When 1
                SZMEMEDOPD = "="
                Gosub COMMONOPD
              When 2
                SZMEMEDOPD = "<>"
                Gosub COMMONOPD
              When 6
                SZMEMEDOPD = ">"
                Gosub COMMONOPD
              When 7
                SZMEMEDOPD = ">="
                Gosub COMMONOPD
              When 8
                SZMEMEDOPD = "<"
                Gosub COMMONOPD
              When 9
                SZMEMEDOPD = "<="
                Gosub COMMONOPD
              When 3
                If ICRIFIETYP >= 10 and ICRIFIETYP < 500 Then  # FGR 04/02/2015 : X3SUIVI105938
                  IEMPSTRING = 0
                  If [F:QCV]CRIVAL = '""' or [F:QCV]CRIVAL = "''" or [F:QCV]CRIVAL = "" Then
                    If IUSEUSERDIM Then
                      Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '=""' Using [CRM1]
                    Else
                      For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                        If ITERFIEDIM = 0 Then
                          Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '=""' Using [CRM1]
                        Else
                          Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '=""' Using [CRM1]
                        Endif
                      Next
                    Endif
                    IEMPSTRING = 1
                  Endif
                  If !IEMPSTRING Then
                    If IUSEUSERDIM Then
                      If left$([F:QCV]CRIVAL, 2) = "??" Then
                        SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                        If evalue(SZDYNVARIABLE) = "" Then
                          Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '=""' Using [CRM1]
                        Else
                          SZDYNCONTENT = evalue(SZDYNVARIABLE)
                          Wrseq '& ' + SZVALOPD + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '), ' + 'toupper("' + SZDYNCONTENT + '*")) <> 0' Using [CRM1]
                        Endif
                      Else
                        Wrseq '& ' + SZVALOPD + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '), ' + 'toupper("' + [F:QCV]CRIVAL + '*")) <> 0' Using [CRM1]
                      Endif
                    Else
                      For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                        If ITERFIEDIM = 0 Then
                          If left$([F:QCV]CRIVAL, 2) = "??" Then
                            SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                            If evalue(SZDYNVARIABLE) = "" Then
                              Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '=""' Using [CRM1]
                            Else
                              SZDYNCONTENT = evalue(SZDYNVARIABLE)
                              Wrseq '& ' + SZVALOPD + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '), ' + 'toupper("' + SZDYNCONTENT + '*")) <> 0' Using [CRM1]
                            Endif
                          Else
                            Wrseq '& ' + SZVALOPD + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '), ' + 'toupper("' + [F:QCV]CRIVAL + '*")) <> 0' Using [CRM1]
                          Endif
                        Else
                          If left$([F:QCV]CRIVAL, 2) = "??" Then
                            SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                            If evalue(SZDYNVARIABLE) = "" Then
                              Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '=""' Using [CRM1]
                            Else
                              SZDYNCONTENT = evalue(SZDYNVARIABLE)
                              Wrseq '& |' + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '), ' + 'toupper("' + SZDYNCONTENT + '*")) <> 0' Using [CRM1]
                            Endif
                          Else
                            Wrseq '& |' + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '), ' + 'toupper("' + [F:QCV]CRIVAL + '*")) <> 0' Using [CRM1]
                          Endif
                        Endif
                      Next
                    Endif
                  Endif
                Endif
              When 4
                If ICRIFIETYP >= 10 Then
                  IEMPSTRING = 0
                  If [F:QCV]CRIVAL = '""' or [F:QCV]CRIVAL = "''" or [F:QCV]CRIVAL = "" Then
                    If IUSEUSERDIM Then
                      Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '=""' Using [CRM1]
                    Else
                      For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                        If ITERFIEDIM = 0 Then
                          Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '=""' Using [CRM1]
                        Else
                          Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '=""' Using [CRM1]
                        Endif
                      Next
                    Endif
                    IEMPSTRING = 1
                  Endif
                  If !IEMPSTRING Then
                    If IUSEUSERDIM Then
                      If left$([F:QCV]CRIVAL, 2) = "??" Then
                        SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                        If evalue(SZDYNVARIABLE) = "" Then
                          Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '=""' Using [CRM1]
                        Else
                          SZDYNCONTENT = evalue(SZDYNVARIABLE)
                          Wrseq '& ' + SZVALOPD + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '), ' + 'toupper("*' + SZDYNCONTENT + '*")) <> 0' Using [CRM1]
                        Endif
                      Else
                        Wrseq '& ' + SZVALOPD + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '), ' + 'toupper("*' + [F:QCV]CRIVAL + '*")) <> 0' Using [CRM1]
                      Endif
                    Else
                      For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                        If ITERFIEDIM = 0 Then
                          If left$([F:QCV]CRIVAL, 2) = "??" Then
                            SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                            If evalue(SZDYNVARIABLE) = "" Then
                              Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '=""' Using [CRM1]
                            Else
                              SZDYNCONTENT = evalue(SZDYNVARIABLE)
                              Wrseq '& ' + SZVALOPD + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '), ' + 'toupper("*' + SZDYNCONTENT + '*")) <> 0' Using [CRM1]
                            Endif
                          Else
                            Wrseq '& ' + SZVALOPD + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '), ' + 'toupper("*' + [F:QCV]CRIVAL + '*")) <> 0' Using [CRM1]
                          Endif
                        Else
                          If left$([F:QCV]CRIVAL, 2) = "??" Then
                            SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                            If evalue(SZDYNVARIABLE) = "" Then
                              Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '=""' Using [CRM1]
                            Else
                              SZDYNCONTENT = evalue(SZDYNVARIABLE)
                              Wrseq '& |' + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '), ' + 'toupper("*' + SZDYNCONTENT + '*")) <> 0' Using [CRM1]
                            Endif
                          Else
                            Wrseq '& |' + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '), ' + 'toupper("*' + [F:QCV]CRIVAL + '*")) <> 0' Using [CRM1]
                          Endif
                        Endif
                      Next
                    Endif
                  Endif
                Endif
              When 5
                If ICRIFIETYP >= 10 Then
                  IEMPSTRING = 0
                  If [F:QCV]CRIVAL = '""' or [F:QCV]CRIVAL = "''" or [F:QCV]CRIVAL = "" Then
                    If IUSEUSERDIM Then
                      Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '=""' Using [CRM1]
                    Else
                      For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                        If ITERFIEDIM = 0 Then
                          Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '=""' Using [CRM1]
                        Else
                          Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '=""' Using [CRM1]
                        Endif
                      Next
                    Endif
                    IEMPSTRING = 1
                  Endif
                  If !IEMPSTRING Then
                    If IUSEUSERDIM Then
                      If left$([F:QCV]CRIVAL, 2) = "??" Then
                        SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                        If evalue(SZDYNVARIABLE) = "" Then
                          Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '=""' Using [CRM1]
                        Else
                          SZDYNCONTENT = evalue(SZDYNVARIABLE)
                          Wrseq '& ' + SZVALOPD + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '), ' + 'toupper("*' + SZDYNCONTENT + '")) <> 0' Using [CRM1]
                        Endif
                      Else
                        Wrseq '& ' + SZVALOPD + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '), ' + 'toupper("*' + [F:QCV]CRIVAL + '")) <> 0' Using [CRM1]
                      Endif
                    Else
                      For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                        If ITERFIEDIM = 0 Then
                          If left$([F:QCV]CRIVAL, 2) = "??" Then
                            SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                            If evalue(SZDYNVARIABLE) = "" Then
                              Wrseq '& ' + SZVALOPD + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '=""' Using [CRM1]
                            Else
                              SZDYNCONTENT = evalue(SZDYNVARIABLE)
                              Wrseq '& ' + SZVALOPD + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '), ' + 'toupper("*' + SZDYNCONTENT + '")) <> 0' Using [CRM1]
                            Endif
                          Else
                            Wrseq '& ' + SZVALOPD + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '), ' + 'toupper("*' + [F:QCV]CRIVAL + '")) <> 0' Using [CRM1]
                          Endif
                        Else
                          If left$([F:QCV]CRIVAL, 2) = "??" Then
                            SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                            If evalue(SZDYNVARIABLE) = "" Then
                              Wrseq '& |' + '[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '=""' Using [CRM1]
                            Else
                              SZDYNCONTENT = evalue(SZDYNVARIABLE)
                              Wrseq '& |' + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '), ' + 'toupper("*' + SZDYNCONTENT + '")) <> 0' Using [CRM1]
                            Endif
                          Else
                            Wrseq '& |' + 'pat(toupper([F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '), ' + 'toupper("*' + [F:QCV]CRIVAL + '")) <> 0' Using [CRM1]
                          Endif
                        Endif
                      Next
                    Endif
                  Endif
                Endif
              When 10
                If ICRIFIETYP = 1 or ICRIFIETYP = 2 Then
                  If INBVAL Then
                    If INBVAL < 2 Then
                      If left$([F:QCV]CRIVAL, 2) = "??" Then
                        SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                        Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<=' + SZDYNVARIABLE Using [CRM1]
                      Else
                        Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<=' + [F:QCV]CRIVAL Using [CRM1]
                      Endif
                      If !IUSEUSERDIM Then
                        For ITERFIEDIM = 1 To min(10, ICRIFIEDIM-1)
                          Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '>=' + SZQCVCRIVAL Using [CRM1]
                          If left$([F:QCV]CRIVAL, 2) = "??" Then
                            SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                            Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '<=' + SZDYNVARIABLE Using [CRM1]
                          Else
                            Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '<=' + [F:QCV]CRIVAL Using [CRM1]
                          Endif
                        Next
                      Endif
                    Endif
                  Else
                    If left$([F:QCV]CRIVAL, 2) = "??" Then
                      SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                      IDYNCONTENT = evalue(SZDYNVARIABLE)
                      SZQCVCRIVAL = num$(IDYNCONTENT)
                      Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '>=' + SZDYNVARIABLE Using [CRM1]
                    Else
                      SZQCVCRIVAL = [F:QCV]CRIVAL
                      Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '>=' + [F:QCV]CRIVAL Using [CRM1]
                    Endif
                  Endif
                Elsif ICRIFIETYP = 3 Then
                  If INBVAL Then
                    If INBVAL < 2 Then
                      If instr(1, [F:QCV]CRIVAL, "date$") Then
                        Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<= [' + format$(GFMD,evalue([F:QCV]CRIVAL)) + ']' Using [CRM1]
                      Else
                        If left$([F:QCV]CRIVAL, 2) = "??" Then
                          SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                          Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<=' + SZDYNVARIABLE Using [CRM1]
                        Else
                          Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<= [' + format$(GFMD,[F:QCV]CRIVALDAT) + ']' Using [CRM1]
                        Endif
                      Endif
                      If !IUSEUSERDIM Then
                        For ITERFIEDIM = 1 To min(10, ICRIFIEDIM-1)
                          Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '>= [' + format$(GFMD, DQCVCRIVALDAT) + ']' Using [CRM1]
                          If instr(1, [F:QCV]CRIVAL, "date$") Then
                            Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '<= [' + format$(GFMD,evalue([F:QCV]CRIVAL)) + ']' Using [CRM1]
                          Else
                            If left$([F:QCV]CRIVAL, 2) = "??" Then
                              SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                              Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '<=' + SZDYNVARIABLE Using [CRM1]
                            Else
                              Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '<= [' + format$(GFMD,[F:QCV]CRIVALDAT) + ']' Using [CRM1]
                            Endif
                          Endif
                        Next
                      Endif
                    Endif
                  Else
                    If instr(1, [F:QCV]CRIVAL, "date$") Then
                      DQCVCRIVALDAT = evalue([F:QCV]CRIVAL)
                      Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '>= [' + format$(GFMD,evalue([F:QCV]CRIVAL)) + ']' Using [CRM1]
                    Else
                      If left$([F:QCV]CRIVAL, 2) = "??" Then
                        SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                        DQCVCRIVALDAT = evalue(SZDYNVARIABLE)
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '>=' + SZDYNVARIABLE Using [CRM1]
                      Else
                        DQCVCRIVALDAT = [F:QCV]CRIVALDAT
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '>= [' + format$(GFMD,[F:QCV]CRIVALDAT) + ']' Using [CRM1]
                      Endif
                    Endif
                  Endif
                Elsif ICRIFIETYP >= 4 and ICRIFIETYP <= 9 Then
                  If INBVAL Then
                    If INBVAL < 2 Then
                      If left$([F:QCV]CRIVAL, 2) = "??" Then
                        SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                        Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<=' + SZDYNVARIABLE Using [CRM1]
                      Else
                        Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<=' + [F:QCV]CRIVAL Using [CRM1]
                      Endif
                      If !IUSEUSERDIM Then
                        For ITERFIEDIM = 1 To min(10, ICRIFIEDIM-1)
                          Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '>=' + SZQCVCRIVAL Using [CRM1]
                          If left$([F:QCV]CRIVAL, 2) = "??" Then
                            SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                            Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '<=' + SZDYNVARIABLE Using [CRM1]
                          Else
                            Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '<=' + [F:QCV]CRIVAL Using [CRM1]
                          Endif
                        Next
                      Endif
                    Endif
                  Else
                    If left$([F:QCV]CRIVAL, 2) = "??" Then
                      SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                      IDYNCONTENT = evalue(SZDYNVARIABLE)
                      SZQCVCRIVAL = num$(IDYNCONTENT)
                      Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '>=' + SZDYNVARIABLE Using [CRM1]
                    Else
                      SZQCVCRIVAL = [F:QCV]CRIVAL
                      Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '>=' + [F:QCV]CRIVAL Using [CRM1]
                    Endif
                  Endif
                Elsif ICRIFIETYP >= 10 Then
                  IEMPSTRING = 0
                  If [F:QCV]CRIVAL = '""' or [F:QCV]CRIVAL = "''" or [F:QCV]CRIVAL = "" Then
                    If INBVAL Then
                      If INBVAL < 2 Then
                        Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<="' + '"' Using [CRM1]
                        If !IUSEUSERDIM Then
                          For ITERFIEDIM = 1 To min(10, ICRIFIEDIM-1)
                            Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '>="' + '"' Using [CRM1]
                            Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '<="' + '"' Using [CRM1]
                          Next
                        Endif
                      Endif
                    Else
                      Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '>=""' Using [CRM1]
                    Endif
                    IEMPSTRING = 1
                  Endif
                  If !IEMPSTRING Then
                    If INBVAL Then
                      If INBVAL < 2 Then
                        If left$([F:QCV]CRIVAL, 2) = "??" Then
                          SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                          If evalue(SZDYNVARIABLE) = "" Then
                            Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<=""' Using [CRM1]
                          Else
                            Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<=' + SZDYNVARIABLE Using [CRM1]
                          Endif
                        Else
                          Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<="' + [F:QCV]CRIVAL + '"' Using [CRM1]
                        Endif
                        If !IUSEUSERDIM Then
                          For ITERFIEDIM = 1 To min(10, ICRIFIEDIM-1)
                            If SZQCVCRIVAL = "" Then
                              Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '>=""' Using [CRM1]
                            Else
                              Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '>="' + SZQCVCRIVAL + '"' Using [CRM1]
                            Endif
                            If left$([F:QCV]CRIVAL, 2) = "??" Then
                              SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                              If evalue(SZDYNVARIABLE) = "" Then
                                Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '<=""' Using [CRM1]
                              Else
                                Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '<=' + SZDYNVARIABLE Using [CRM1]
                              Endif
                            Else
                              Wrseq '& & [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '<="' + [F:QCV]CRIVAL + '"' Using [CRM1]
                            Endif
                          Next
                        Endif
                      Endif
                    Else
                      If left$([F:QCV]CRIVAL, 2) = "??" Then
                        SZDYNVARIABLE = right$([F:QCV]CRIVAL, 3)
                        If evalue(SZDYNVARIABLE) = "" Then
                          SZQCVCRIVAL = ""
                          Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '>=""' Using [CRM1]
                        Else
                          SZQCVCRIVAL = SZDYNVARIABLE
                          Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '>=' + SZDYNVARIABLE Using [CRM1]
                        Endif
                      Else
                        SZQCVCRIVAL = [F:QCV]CRIVAL
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '>="' + [F:QCV]CRIVAL + '"' Using [CRM1]
                      Endif
                    Endif
                  Endif
                Endif
            Endcase
          Endif
          INBVAL += 1
        Next
        Filter [QCV]
        #Gestion du critère "Rien" ou "Vide"
        If INBVAL = 0 Then
          Wrseq '& (' Using [CRM1]
          Read [ATB]CODFIC=[F:QCR]CRITAB
          If fstat Then
            GERR = 1
            # FGR 09/02/2010 : X3SUIVI60986
            #Return
            Break
          Else
            ICRIFIETYP = evalue("Type([F:" + [F:ATB]ABRFIC + "]" + [F:QCR]CRIFIE + ")")
            ICRIFIEDIM = evalue("Dim([F:" + [F:ATB]ABRFIC + "]" + [F:QCR]CRIFIE + ")")
            IUSEUSERDIM = 0
            If instr(1, [F:QCR]CRIFIE, '(') Then
              IDIMLEVPOS1 =  instr(1, [F:QCR]CRIFIE, '(')
              If instr(1, [F:QCR]CRIFIE, ')') Then
                IDIMLEVPOS2 =  instr(1, [F:QCR]CRIFIE, ')')
                If IDIMLEVPOS2 > IDIMLEVPOS1 Then
                  IDIMLEVPOS3 = IDIMLEVPOS2 - IDIMLEVPOS1
                  If IDIMLEVPOS3 > 1 Then
                    IUSERDIMLEV = val(mid$([F:QCR]CRIFIE, IDIMLEVPOS1+1, IDIMLEVPOS3-1))
                    If IUSERDIMLEV < ICRIFIEDIM Then
                      IUSEUSERDIM = 1
                    Endif
                  Endif
                Endif
              Endif
            Endif
            Case [F:QCR]CRICND
              When 1
                If ICRIFIETYP = 1 or ICRIFIETYP = 2 Then
                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= 0' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= 0' Using [CRM1]
                      Else
                        Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '= 0' Using [CRM1]
                      Endif
                    Next
                  Endif
                Elsif ICRIFIETYP = 3 Then
                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= [00/00/00]' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= [00/00/00]' Using [CRM1]
                      Else
                        Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '= [00/00/00]' Using [CRM1]
                      Endif
                    Next
                  Endif
                Elsif ICRIFIETYP >= 4 and ICRIFIETYP <= 9 Then
                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= 0' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= 0' Using [CRM1]
                      Else
                        Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '= 0' Using [CRM1]
                      Endif
                    Next
                  Endif
                Elsif ICRIFIETYP >= 10 and ICRIFIETYP < 500 Then  # FGR 04/02/2015 : X3SUIVI105938
                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= "' + '"' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= "' + '"' Using [CRM1]
                      Else
                        Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '= "' + '"' Using [CRM1]
                      Endif
                    Next
                  Endif
                Endif
              When 2
                If ICRIFIETYP = 1 or ICRIFIETYP = 2 Then
                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<> 0' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<> 0' Using [CRM1]
                      Else
                        Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '<> 0' Using [CRM1]
                      Endif
                    Next
                  Endif
                Elsif ICRIFIETYP = 3 Then
                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<> [00/00/00]' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<> [00/00/00]' Using [CRM1]
                      Else
                        Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '<> [00/00/00]' Using [CRM1]
                      Endif
                    Next
                  Endif
                Elsif ICRIFIETYP >= 4 and ICRIFIETYP <= 9 Then
                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<> 0' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<> 0' Using [CRM1]
                      Else
                        Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '<> 0' Using [CRM1]
                      Endif
                    Next
                  Endif
                Elsif ICRIFIETYP >= 10 Then
                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<> "' + '"' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '<> "' + '"' Using [CRM1]
                      Else
                        Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '<> "' + '"' Using [CRM1]
                      Endif
                    Next
                  Endif
                Endif
              When 3
                If ICRIFIETYP >= 10 Then
                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= "' + '"' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= "' + '"' Using [CRM1]
                      Else
                        Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '= "' + '"' Using [CRM1]
                      Endif
                    Next
                  Endif
                Endif
              When 4
                If ICRIFIETYP >= 10 Then
                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= "' + '"' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= "' + '"' Using [CRM1]
                      Else
                        Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '= "' + '"' Using [CRM1]
                      Endif
                    Next
                  Endif
                Endif
              When 5
                If ICRIFIETYP >= 10 Then
                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= "' + '"' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '= "' + '"' Using [CRM1]
                      Else
                        Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '= "' + '"' Using [CRM1]
                      Endif
                    Next
                  Endif
                Endif
              When 6
                If ICRIFIETYP = 1 or ICRIFIETYP = 2 Then
                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '> 0' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
                        Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '> 0' Using [CRM1]
                      Else
                        Wrseq '& |[F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '(' + num$(ITERFIEDIM) + ')' + '> 0' Using [CRM1]
                      Endif
                    Next
                  Endif
                Elsif ICRIFIETYP = 3 Then
                  If IUSEUSERDIM Then
                    Wrseq '& [F:' + [F:ATB]ABRFIC + ']' + [F:QCR]CRIFIE + '> [00/00/00]' Using [CRM1]
                  Else
                    For ITERFIEDIM = 0 To min(10, ICRIFIEDIM-1)
                      If ITERFIEDIM = 0 Then
