#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################################################
# ROUTINES ABOUT CURRENCIES
##############################################################################################################
# GET_CUR    : returns for a given company the currencies attached to the main general/analytical/IAS ledger
##############################################################################################################

#########################################################################################################
## GET_CUR
#########################################################################################################
#**
#* Returns for a given company:<ul>
#* <li>The currency attached to the main General Ledger    if CAS = 1
#* <li>The currency attached to the main Analytical Ledger if CAS = 2
#* <li>The currency attached to the main IAS Ledger        if CAS = 3
#* </ul>
#*
#* @param ACTX    Context
#* @param CAS     1=Main General Ledger ; 2=Main Analytical Ledger ; 3=Main IAS Ledger
#* @param COMPANY Company or Site
#* @param LEDCUR  Ledger currency
#* @param ERRMES  Error message
#*!
Funprog GET_CUR(ACTX,CAS,COMPANY,LEDCUR,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Integer  CAS         : # 1:Main General Ledger   2:Main Analytical Ledger 3:Main IAS Ledger
Value    Char     COMPANY()   : # Company or Site
Variable Char     LEDCUR()    : # Ledger Currency
Variable Char     ERRMES()    : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Char    LEDCOD(GLONLED) : # Ledger Code
Local Tinyint LEDTYPGEN       : # Main General Ledger Type
Local Tinyint LEDTYPANA       : # Main Analytical Ledger Type
Local Tinyint LEDTYPIAS       : # Main IAS Ledger Type

[L]ASTATUS = func FINACM_SYRA.GET_MAINLEDTYP(ACTX,COMPANY,LEDTYPGEN,LEDTYPANA,LEDTYPIAS,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

Case CAS
 When 1
  [L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(ACTX,COMPANY,LEDTYPGEN,LEDCOD,LEDCUR,ERRMES)
 When 2
  [L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(ACTX,COMPANY,LEDTYPANA,LEDCOD,LEDCUR,ERRMES)
 When 3
  [L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(ACTX,COMPANY,LEDTYPIAS,LEDCOD,LEDCUR,ERRMES)
Endcase
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
End [L]ASTATUS
