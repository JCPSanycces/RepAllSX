######################################################################################################

Subprog C_VOLFIL( VALEUR )
Variable Char VALEUR()

    Gosub ENUM_VOLFIL_TYPE From ASYRSTO
    mkstat = func ASYRSTO.CTL_VOLFIL( [M]TYPIMP, VALEUR, [M]NAMIMP, E_TYPE_FILEREAD, GMESSAGE )
End


Subprog AM_TYPIMP( VALEUR )
Variable Integer VALEUR
If VALEUR <> [M]TYPIMP
    If VALEUR = 1
        Raz   [M]VOLFIL
        Affzo [M]VOLFIL
        Grizo [M]VOLFIL
    Else
         Actzo [M]VOLFIL
         [M]VOLFIL = ""
         Affzo [M]VOLFIL
    Endif
Endif
End

######################################################################################
## Section automatically added (screen SWIIMPBVR) 06/02/2015 13:19:00 (UBA)
######################################################################################
Subprog AV_TYPIMP(VALEUR)
Variable Integer VALEUR
    Call AM_TYPIMP(VALEUR)
End


######################################################################################

######################################################################################
## Section automatically added (screen SWIIMPBVR) 06/26/2015 08:19:39 (UBA)
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
   GTOLDEP = int(val(func AFNC.PARAM("TOLDEP", VALEUR)))
   GDEVPRC = int(val(func AFNC.PARAM("DEVPRC", VALEUR)))
   GDEVAMT = int(val(func AFNC.PARAM("DEVAMT", VALEUR)))
End


