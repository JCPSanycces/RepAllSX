#<AdxTL>@(#)10.0.0.0 $Revision$
#########################################################################
# Pour exécution hors intégration de patch
#########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER,"") From SAIDOS
  If DOSSIER <> "" Then
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE(mess(591,196,1)) From LECFIC
    Call GENSTDSSP(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
End
#########################################################################

#####################################################################################################################
# Génération des supports de sélections standards X3                                   Module CRM     14 mars 2002  #
#                                                                                                                   #
#####################################################################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
    End
  Endif
  If [F:ADS]MODULE(12) <> 2 Then
    End
  Endif
  Call GENSTDSSP(APPLI)
End

#######################################################################
Subprog GENSTDSSP(SZAPPLI)
Value Char SZAPPLI

Local Integer IPBL

  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TRACE(mess(592,196,1) + SZAPPLI,0) From GESECRAN  #Début de la génération des supports de sélections.
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  If !clalev([F:SSP]) : Local File =SZAPPLI+".SELSSP" [SSP] : Endif
  If !clalev([F:SSC]) : Local File =SZAPPLI+".SELSSPCPN" [SSC] : Endif
  IPBL = 0
  #On commence par effacer tous les éventuels supports standards existants.
  Call DEBTRANS From GLOCK
  Trbegin [SSP], [SSC]
  Delete [SSP] Where [F:SSP]SPTSTD = 1
  If fstat Then
    Rollback
    IPBL = 1
    #Erreur lors de la supression des supports de sélections standards.
    Call ECR_TRACE(mess(595,196,1) - [F:BPC]BPCNUM,1) From GESECRAN
  Endif
  If IPBL Then
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    Call ECR_TRACE(mess(593,196,1),0) From GESECRAN  #Génération des supports de sélections interrompue sur erreur.
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    End
  Endif
  Delete [SSC] Where [F:SSC]SPTCPNSTD = 1
  If fstat Then
    Rollback
    IPBL = 1
    #Erreur lors de la supression des composants des supports de sélections standards.
    Call ECR_TRACE(mess(596,196,1) - [F:BPC]BPCNUM,1) From GESECRAN
  Endif
  If IPBL Then
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    Call ECR_TRACE(mess(593,196,1),0) From GESECRAN  #Génération des supports de sélections interrompue sur erreur.
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    End
  Endif
  If !IPBL Then
    Commit
  Endif
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TRACE(mess(594,196,1) + SZAPPLI,0) From GESECRAN  #Génération des supports de sélections terminée sans erreurs.
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
End
