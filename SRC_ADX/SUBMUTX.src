Subprog AM_IMPFLG(VALEUR)
Variable Integer VALEUR

If VALEUR=2 : Actzo [DIA]PRT : Else Diszo [DIA]PRT : Endif
End

######################################################################################
## Section automatically added (screen MULTIWOX) 07/01/2015 11:13:35 (BEEBE)
## Issue 104943 - 2015-07-01 by BEEBE : implementing versioning ECC
######################################################################################

Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
If func ECCLIB.NBRCPN([M]ITMREF)<1
    mkstat=2
Endif
End

######################################################################################
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Integer LRET
Local Char LMSG(250)

# Issue number - 2016-02-02 by JUSYN : Validation on date done on routing versions, start date here [0/0/0]
Call CTRECC([M]ITMREF,"DIA","ECCVALMAJ",VALEUR,[M]ECCVALMIN,
&           [0/0/0],LRET,LMSG) From ECCLIB

# Issue 111417 - 2015-10-01 by CCC : don't change error code if it's not necessary
If func ECCLIB.NBRCPN([M]ITMREF)=1
    [M]ECCERRCOD = LRET
    [M]ECCERRMSG = LMSG
Endif

# Issue 111414/11 - 2016-02-11 by JUSYN : Extend message with "BOM" to make it clearer.
If LRET=1
    GMESSAGE=LMSG
    Gosub ERR_TIT
    If TIT <> ""
        Call ERRTIT(GMESSAGE,mess(32,126,1)-'"'+mess(153,198,1)-'-'-TIT+'"') From GESECRAN : # Error zone ...
        GMESSAGE = ""
    Endif
    mkstat=2
    End
Endif
If VALEUR<>[M:DIA]ECCVALMAJ
    GMODIF=3
Endif

# Issue 110957 - 2015-10-19 by GH - Setting values for Change Request screen fields
If dim([M:DIA]CRID)=1 & (VALEUR="" | func ECCLIB.NBRCPN([M:DIA]ITMREF)=1)
    [M:DIA]CRID = func TRTX3FNC.CCMID([M:DIA]ITMREF,VALEUR,[M:DIA]ECCVALMIN)
    Affzo [DIA]CRID
    If dim([M:DIA]CRFLG)>0
       [M:DIA]CRFLG = string$([M:DIA]CRID<>"","151") : Affzo [DIA]CRFLG
    Endif
Endif

End

######################################################################################
Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
If func ECCLIB.NBRCPN([M]ITMREF)<2
    mkstat=2
Endif
End

######################################################################################
Subprog C_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
Local Integer LRET

Raz [M]ECCERRMSG, [M]ECCERRCOD
# Issue number - 2016-02-02 by JUSYN : Validation on date done on routing versions, start date here [0/0/0]
Call CTRECC([M]ITMREF,"DIA","ECCVALMIN", [M]ECCVALMAJ,VALEUR,
&           [0/0/0],LRET,[M]ECCERRMSG) From ECCLIB

[M]ECCERRCOD = LRET

If LRET>=1
    GMESSAGE=[M]ECCERRMSG
    # Issue 111414/11 - 2016-02-11 by JUSYN : Extend message with "BOM" to make it clearer.
    Gosub ERR_TIT
    If TIT <> ""
        Call ERRTIT(GMESSAGE,mess(32,126,1)-'"'+mess(153,198,1)-'-'-TIT+'"') From GESECRAN : # Error zone ...
        GMESSAGE = ""
    Endif
    mkstat=2
    End
Endif
If VALEUR<>[M:DIA]ECCVALMIN
    GMODIF=3
Endif

# Issue 110957 - 2015-10-19 by GH - Setting values for Change Request screen fields
If dim([M:DIA]CRID)=1 & func ECCLIB.NBRCPN([M:DIA]ITMREF)=2
    [M:DIA]CRID = func TRTX3FNC.CCMID([M:DIA]ITMREF,[M:DIA]ECCVALMAJ,VALEUR)
    Affzo [DIA]CRID
    If dim([M:DIA]CRFLG)>0
       [M:DIA]CRFLG = string$([M:DIA]CRID<>"","151") : Affzo [DIA]CRFLG
    Endif
Endif
End

# Issue 111414/11 - 2016-02-02 by JUSYN : Validations for Routing versions
######################################################################################
## Section automatically added (screen MULTIWOX) 02/02/2016 09:26:56 (JUSYN)
######################################################################################
Subprog AS_ROUECCMAJ(VALEUR)
Variable Char    VALEUR()

If func RVMLIB.NBRCPNROU([M:DIA]ROUNUM) < 1
   mkstat = 1
Endif

End

######################################################################################
Subprog C_ROUECCMAJ(VALEUR)
Variable Char    VALEUR()
Local Integer   LRET

If VALEUR = ""
   GMESSAGE = mess(10,123,1) : LRET=1
Else
   Call CTRROUECC([M:DIA]ROUNUM,[M:DIA]MFGFCY,"DIA","ROUECCMAJ",VALEUR,[M:DIA]ROUECCMIN,
&                 [M:DIA]STRDAT,LRET,GMESSAGE) From RVMLIB
Endif

If find(LRET,1,4)
   Gosub ERR_TIT
   If TIT <> ""
      Call ERRTIT(GMESSAGE,mess(32,126,1)-'"'+mess(63,198,1)-'-'-TIT+'"') From GESECRAN : # Error zone...
      GMESSAGE = ""
   Endif
   mkstat = 2 : End
Endif

End

######################################################################################
Subprog AS_ROUECCMIN(VALEUR)
Variable Char    VALEUR()

If func RVMLIB.NBRCPNROU([M:DIA]ROUNUM) < 2
   mkstat = 1
Endif
End

######################################################################################
Subprog C_ROUECCMIN(VALEUR)
Variable Char    VALEUR()
Local Integer LRET

If VALEUR = ""
   GMESSAGE = mess(10,123,1) : LRET=1
Else
   Call CTRROUECC([M:DIA]ROUNUM,[M:DIA]MFGFCY,"DIA","ROUECCMIN",[M:DIA]ROUECCMAJ,VALEUR,
&                 [M:DIA]STRDAT,LRET,GMESSAGE) From RVMLIB
Endif
If find(LRET,1,4)
   Gosub ERR_TIT
   If TIT <> ""
      Call ERRTIT(GMESSAGE,mess(32,126,1)-'"'+mess(63,198,1)-'-'-TIT+'"') From GESECRAN : # Error zone ...
      GMESSAGE = ""
   Endif
   mkstat = 2 : End
Endif
End


######################################################################################
$ERR_TIT
Local Char TIT(GLONDES)
If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
Read [AMZ]CODE = maskcou;zoncou
If !fstat
   If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
   Read [ATX]NUMERO = GLANGUE;[F:AMZ]INTIT
   If !fstat : TIT=[F:ATX]TEXTE : Endif
Endif
Return

