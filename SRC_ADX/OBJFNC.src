#<AdxTL>@(#)74.0.0.0 $Revision$
Subprog GENFONC(APPLI,OBJET)
Value Char APPLI
Value Char OBJET
Local Integer MENU : MENU = 1
Goto GENFON

Subprog GENFONC2(APPLI,OBJET)
Value Char APPLI
Value Char OBJET
Local Integer MENU : MENU = 0
Goto GENFON

$GENFON
If nomap=APPLI
 Local File AFONCTION [AFC], =adxtms [STD], AOBJET [AOB], AWINDOW [AWI]
Else
 Local File =APPLI+".AFONCTION" [AFC]
 Local File =APPLI+"."+adxtms   [STD]
 Local File =APPLI+".AOBJET"    [AOB]
Endif
Read [AOB]ABREV = OBJET
If fstat : End : Endif
Local Char    FONCTION(GLONAFC) , TEXTE(80) , OLDMEN(GLONAFC)
Local Integer I , X , MODFONC , CREFONC , FNCNUM , FLWEB, WMODIFACV
FONCTION = "GES"+OBJET
Raz CREFONC , MODFONC , OLDMEN
Read [AFC]CODINT = FONCTION
If fstat
 CREFONC = 1
 Read [AFC]NUMFNC Last
 If fstat>2 : FNCNUM = 1 : Else : FNCNUM = [F:AFC]NUMFNC+1 : Endif
 If FNCNUM>=9001 & FNCNUM<=9999
  FNCNUM = 10000
 Endif
 If GADONIX<>2
  FNCNUM = max(FNCNUM,5001)
 Endif
Else
 MODFONC = 1
Endif
If MODFONC | CREFONC
 Gosub TR1
Endif
End

$TR1
GOK=1
Trbegin [AFC]
 If CREFONC
  Raz [F:AFC]
  [F:AFC]CODINT    = FONCTION
  [F:AFC]CODEXT    = FONCTION
  [F:AFC]NUMFNC    = FNCNUM
  Call TEXTE([F:AOB]LIBEL,TEXTE) From OBJDIV
  [F:AFC]NOM       = [F:AOB]LIBEL
  [F:AFC]LIBMENU   = [F:AOB]LIBEL
  [F:AFC]TYPTRAIT  = 1
  [F:AFC]CODACT    = [F:AOB]CODACT
  If [F:AOB]ZSITE<>""
   [F:AFC]FCYAUZ   = 2
  Else
   [F:AFC]FCYAUZ   = 1
  Endif
  If dim([F:AFC]CREDAT)>0 : [F:AFC]CREDAT = date$ : Endif
  If dim([F:AFC]CREUSR)>0 : [F:AFC]CREUSR = GUSER : Endif
  If dim([F:AFC]CRETIM)>0 : [F:AFC]CRETIM = time  : Endif
  [F:AFC]TYP   = 2
  [F:AFC]MODULE = [F:AOB]MODULE
  [F:AFC]MENU   = [F:AOB]MENU
  [F:AFC]RANG   = [F:AOB]RANG
  [F:AFC]RPT1   = [F:AOB]RPT1
  [F:AFC]RPT2   = [F:AOB]RPT2
  [F:AFC]ACTION = "GOBJET"
  [F:AFC]CODPAR(0) = "OBJET"
  [F:AFC]VALPAR(0) = '"'+[F:AOB]ABREV+'"'
  [F:AFC]CODPAR(1) = "OBJZON"
  [F:AFC]VALPAR(1) = '""'
  Write [AFC]
  If fstat
   GOK=0 : Call FSTA("AFC") From GLOCK : Goto AB_TR1
  Endif
  If GADONIX=2 : Call TRACE_COR("AFC",FONCTION,"","C") From GOBJET : Endif
 Elsif MODFONC
  Readlock [AFC]CODINT = FONCTION
  If fstat=1
   GOK = -1 : GLOCK = "$AFONCTION"-FONCTION : Goto ROLL_TR1
  Endif
  If dim([F:AFC]UPDDAT)>0 : [F:AFC]UPDDAT = date$ : Endif
  If dim([F:AFC]UPDUSR)>0 : [F:AFC]UPDUSR = GUSER : Endif
  If dim([F:AFC]UPDTIM)>0 : [F:AFC]UPDTIM = time  : Endif
  If [F:AFC]CODACT=""
   [F:AFC]CODACT = [F:AOB]CODACT
   WMODIFACV = 1
  Endif
  Rewrite [AFC]
  If fstat
   GOK = 0 : Call FSTA("AFC") From GLOCK : Goto AB_TR1
  Endif
  If GADONIX=2 and WMODIFACV>0 : Call TRACE_COR("AFC",FONCTION,"","M") From GOBJET : Endif
 Endif
Commit

Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

