#<AdxTL>@(#)5.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
Raz GBIDC1, GBIDC2
Call OBJET("CCE",GBIDC1,GBIDC2) From  GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "SETBOUT"    : Gosub SETBOUT
 When "LIENS"      : Gosub LIENS
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "ANNULE"     : Gosub ANNULE
 When "AP_CHANGE"  : Gosub CHANGE
 When "SEL_TABLE"  : Gosub SEL_TABLE
 When "AVANT_SUITE": Gosub AVANT_SUITE
Endcase
Return

$LIENS 
If GMODU(2)=2 :# Compta
 # Pyramides analytiques
 nolign = 0
 [M]NBRPYR = 0
 Link [F:CPC] With [F:CPH]CPH0=[F:CPC]PYR
&             As [LNK]
&             Where [F:CPH]AXE=[M]AXI & pat([M]CCE,[F:CPC]CCE)
 For [F:LNK]
  nolign += 1
  [M]PYR(nolign-1) = [F:CPC]PYR
  [M]GRP(nolign-1) = [F:CPC]GRP
  [M]NBRPYR += 1
 Next
Endif
GBIDI1 = [F:CCE]AXI
Return 
 
$OUVRE
If GMODU(2)=2 :# Compta
 If clalev([F:CPC])=0  : Local File CPYRAMIDC [CPC]  : Endif
 If clalev([F:CPC2])=0 : Local File CPYRAMIDC [CPC2] : Endif
 If clalev([F:CPH])=0  : Local File CPYRAMIDH [CPH]  : Endif
 If clalev([F:CPG])=0  : Local File CPYRAMIDG [CPG]  : Endif
Endif
Return

$SETBOUT
# Suggestion 10418 : Tunnel vers consultation (CP : 26/07/02)
CHMEN +="1" 
If dim([M:CCE2]BUD)>0 & [M:CCE2]BUD=2
 CHMEN += "2"
Endif    
Return

$CREATION
If GMODU(2)=2 :# Compta
 Gosub CRE_CPC
 If GOK<1 : Return : Endif
Endif
Return

$MODIF
If GMODU(2)=2 :# Compta
 Gosub SUPP_CPC
 If GOK<1 : Return : Endif
 Gosub CRE_CPC
 If GOK<1 : Return : Endif
Endif
Return

$SUPP_CPC
# Lignes supprimées
Link [F:CPC2] With [F:CPH]CPH0=[F:CPC2]PYR
&             As [LNK]
&             Where [F:CPH]AXE=[M]AXI & [F:CPC2]CCE=[M]CCE
For [LNK]
 Lock ="CPG"+[F:CPC2]GRP
 If fstat
  GOK=-1 : GMESSAGE = [F:CPC2]GRP-mess(10,100,1) :  # Modification en cours sur un autre poste
  Break
 Endif
 I=find([F:CPC2]GRP,[M]GRP)
 If !I
  Delete [F:CPC] Where GRP=[F:CPC2]GRP & LIN=[F:CPC2]LIN
  If fstat=1 or fstat>5
   GOK=-1 : GLOCK="$CPC"-[F:CPC2]GRP-num$([F:CPC2]LIN)
   Break
  Endif
  # Renumérotation des lignes suivantes
  For [F:CPC]CPC0 Where GRP=[F:CPC2]GRP & LIN>[F:CPC2]LIN With Lock
   If fstat=1
    GOK=-1 : GLOCK="$CPYRAMIDC"-[F:CPC2]GRP
    Break
   Endif
   [F:CPC]LIN -= 1
   Rewrite [F:CPC]
   If fstat
    GOK=0 : Call FSTA("CPC") From GLOCK
    Break
   Endif
  Next
 Endif
Next
If GOK<1 : Return : Endif
Return

$CRE_CPC
# Lignes rajoutées
For I=0 To [M]NBRPYR-1
 Filter [F:CPC2] Where GRP=[M]GRP(I) & pat([M]CCE,[F:CPC2]CCE)
 Read [F:CPC2]CPC0 First
 If fstat
  Lock ="CPG"+[M]GRP(I)
  If fstat
   GOK=-1 : GMESSAGE = [M]GRP(I)-mess(10,100,1) : # Modification en cours sur un autre poste
   Break
  Endif
  # Vérification que le groupe n'a pas été supprimé entretemps
  Read [F:CPG]CPG0(1)=[M]GRP(I)
  If !fstat
   Filter [F:CPC2] Where GRP=[M]GRP(I)
   Read [F:CPC2]CPC0 Last
   Raz [F:CPC]
   [F:CPC]GRP = [M]GRP(I)
   [F:CPC]PYR = [M]PYR(I)
   [F:CPC]LIN = [F:CPC2]LIN+1
   [F:CPC]CCE = [M]CCE
   [F:CPC]EXPNUM = [C]EXPORT
   [F:CPC]CREDAT = date$
   [F:CPC]CREUSR = GUSER
   Write [F:CPC]
   If fstat
    GOK=0 : Call FSTA("CPC") From GLOCK
    Break
   Endif
  Endif
 Endif
Next
Filter [F:CPC2]
If GOK<1 : Return : Endif
Return

$ANNULE
If GMODU(2)=2 :# Compta
 # Lignes supprimées
 Link [F:CPC2] With [F:CPH]CPH0=[F:CPC2]PYR
&              As [LNK]
&              Where [F:CPH]AXE=[F:CCE]AXI & [F:CPC2]CCE=[F:CCE]CCE
 For [LNK]
  Lock ="CPG"+[F:CPC2]GRP
  If fstat
   GOK=-1 : GMESSAGE = [F:CPC2]GRP-mess(10,100,1) :   # Modification en cours sur un autre poste
   Break
  Endif
  Delete [F:CPC] Where GRP=[F:CPC2]GRP & LIN=[F:CPC2]LIN
  If fstat=1 or fstat>5
   GOK=-1 : GLOCK="$CPC"-[F:CPC2]GRP-num$([F:CPC2]LIN)
   Break
  Endif
  # Renumérotation des lignes suivantes
  For [F:CPC]CPC0 Where GRP=[F:CPC2]GRP & LIN>[F:CPC2]LIN With Lock
   If fstat=1
    GOK=-1 : GLOCK="$CPYRAMIDC"-[F:CPC2]GRP
    Break
   Endif
   [F:CPC]LIN -= 1
   Rewrite [F:CPC]
   If fstat
    GOK=0 : Call FSTA("CPC") From GLOCK
    Break
   Endif
  Next
 Next
 If GOK<1 : Return : Endif
Endif
Return

$CHANGE
If clalev([F:CPC])=0 : Local File CPYRAMIDC [CPC] : Endif
If clalev([F:CPH])=0 : Local File CPYRAMIDH [CPH] : Endif
Trbegin [CPC]
 For [CPH]CPH0 Where TYP=2 & AXE=val(SUPP)
  For [CPC]CPC2 Where PYR=[F:CPH]PYR & CCE=OCODE
   [F:CPC]CCE = NCODE
   Rewrite [CPC]
   If fstat
    GOK = 0 : Call FSTA("CPC") From GLOCK : Break 2
   Endif
  Next
 Next
Commit
Return

$AVANT_SUITE
# Amélioration V130 : Tunnel vers budget par section  (CP : 16/07/01)
# Stop l'action "suite" (GOK initialisé dans SUBBUS)
# mb test 25.3.2
# Bug 13268 (29/03/02)
If !GBIDI3 : OK=0 : Endif 
Return

#########################################################################
# Etiquettes du masque CCE2
#########################################################################
Subprog AS_FIYEND(VALEUR)
Variable Integer VALEUR
RAZE = evalue("GRANA"+num$([M]AXI)) 
If RAZE<>2 
 VALEUR = 1 : mkstat = 2
Elsif VALEUR=0
 VALEUR = 2
Endif 
End

Subprog C_PYR(VALEUR)
Variable Char     VALEUR
If [F:CPH]AXE<>[M]AXI
 GMESSAGE = mess(40,103,1) :# Axe incorrect
 mkstat=1 : End
Endif
Call CONTEXE([F:CPH]ACS) From SUBACS
If mkstat : End : Endif
I = find(VALEUR,[M]PYR(0..nolign-2))
If !I & nolign<[M]NBRPYR
 I=find(VALEUR,[M]PYR(nolign,[M]NBRPYR-1))
 If I : I+=nolign : Endif
Endif
If I
 GMESSAGE = mess(29,100,1)-num$(I) :# Code déjà saisi en ligne
 mkstat=1 : End
Endif
End

Subprog C_GRP(VALEUR)
Variable Char     VALEUR
Read [F:CPG]CPG0(1)=VALEUR
If fstat
 GMESSAGE = mess(23,100,1) :# Fiche inexistante
 mkstat=1 : End
Endif
If [F:CPG]TYP=1
 GMESSAGE = mess(24,103,1) :# Groupe nature
 mkstat=1 : End
Endif
If [F:CPG]PYR<>[M]PYR(nolign-1)
 GMESSAGE = mess(34,103,1)-[F:CPG]PYR :# Pyramide section
 mkstat=1 : End
Endif
End

Subprog C_NBRPYR
Case status
 When 65,68,83
  Filter [F:CPC] Where GRP=[M]GRP(nolign-1) & pat([M]CCE,[F:CPC]CCE)
  Read [F:CPC]CPC0 First
  If fstat=0 & [M]CCE<>[F:CPC]CCE :# Section définie par joker
   # définie par joker ... suppression impossible
   GMESSAGE = [M]GRP(nolign-1)-[M]CCE-mess(64,103,1)-[F:CPC]CCE-mess(1,115,1)
   mkstat = 1
  Endif
  Filter [F:CPC]
 When 75
  Filter [F:CPC] Where GRP=[M]GRP(nolign-1) & pat([M]CCE,[F:CPC]CCE)
  Read [F:CPC]CPC0 First
  If fstat=0 & [M]CCE<>[F:CPC]CCE :# Section définie par joker
   # définie par joker ... modification impossible
   GMESSAGE = [M]GRP(nolign-1)-[M]CCE-mess(64,103,1)-[F:CPC]CCE-mess(9,123,1)
   mkstat = 1
  Endif
  Filter [F:CPC]
Endcase
End

#########################################################################
# Actions modélisées
#########################################################################

$SEL_TABLE
Case TABLE
 When "SELCCECPH"
  OBJET = "PYC"
  If PARAM(1)<>""
   CRITERE = "AXE="+PARAM(1)
  Endif
 When "SELCCECPG"
  OBJET = "PGC"
  START = "GRP"
  CRITERE = "[F:CPG]TYP=2"
  If PARAM(1)<>""
   CRITERE -= "& [F:CPG]PYR='"+PARAM(1)+"'"
  Endif
Endcase
Return

