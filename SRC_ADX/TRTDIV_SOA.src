###########################################################################
# lit la devise (pour récupérer le format) puis ARRONDIT le montant
Subprog ARRDEV(MNT,DEV)
Variable Decimal MNT
Variable Char DEV
#Global Char GLOCALDEV(GLONCUR)  : # Devise locale
Local Char SOA_GLOCALDEV(GLONCUR)  : # Devise locale    ????
Call GLOCALDEV(SOA_GLOCALDEV) From ESSGLOB_SOA
If DEV = "" : DEV = SOA_GLOCALDEV : Endif
Local File TABCUR [TCU]
Call LECDEV(DEV)
If fstat = 0
 MNT = arr(MNT,[F:TCU]CURRND)
Endif
End

###########################################################################
# lit la devise (si nécessaire) pour récupérer le format
Subprog LECDEV(DEV)
Value Char DEV
#Global Char GLOCALDEV(GLONCUR)  : # Devise locale
Local Char SOA_GLOCALDEV(GLONCUR)  : # Devise locale    ????
Call GLOCALDEV(SOA_GLOCALDEV) From ESSGLOB_SOA
If DEV="" : DEV = SOA_GLOCALDEV : Endif
If DEV<>[F:TCU]CUR
 Read [TCU]TCU0 = DEV
Else        :# (Modif TB 13/08/99) NE PAS ECRASER SVP !!!!!!
 fstat = 0  :# fstat est attendu en retour du sous-pro
Endif
# BY Il vaut mieux ne pas passer par LECTURE
# ca ralentit dans les gros tableaux
#Call LECTURE("TCU",DEV,"") From CONTOBJ
End
###########################################################################

