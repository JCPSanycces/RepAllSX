#<AdxTL>@(#)0.0.0.0 $Revision$Class Entity
# Supervisor
## ATY-ATYPE ## ENT
# 2018-11-09 07:14:12 982

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,ENT,AENABLE,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char ENT
Value Tinyint AENABLE
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File ENTITE [ENT]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".ENTITE" [ENT]
Endif

Default File [F:ENT]
Read [F:ENT]ENT0 = [L]ENT
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]ENT)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]ENT)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

If dim([F:ENT]ENAFLG) & [F:ENT]ENAFLG<>2 : # Inactive record
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]ENT)-":"-mess(2,126,1),[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


