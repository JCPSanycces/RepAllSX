#<AdxTL>@(#)2.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Call EXEC(NBPAR,PARAMETRE)
End

## Search of the entered or displayed columns in the  Financial Data Extraction.

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Local Char    FDENAM(GLONTXS) :# Name of the Financial Data Extraction to print
Local Char    REPNAM(GLONARP) :# Name of the report
Local Char    PARAM(2)
Local Integer J, NBCOL

If clalev([F:TXA])=0 : Local File TXSAC [TXA] : Endif

Call GETPARAM("tableau",NBPAR,PARAMETRE,[L]FDENAM) From ETAT
Call GETPARAM("nbcol",NBPAR,PARAMETRE,[L]PARAM) From ETAT
NBCOL = val([L]PARAM)

J = 0

For [TXA]TXA0 Where TXSNAM=[L]FDENAM & SAICOL<>0 & SAICOL<>3: # Not hidden columns
 J +=1
 PARAM = num$([F:TXA]NUMCOL)
 Call SETPARAM("col"+num$(J),NBPAR,PARAMETRE,PARAM) From ETAT
 If J=NBCOL : Break : Endif
Next
If J=0
# Pas de colonne à afficher
 Call ERREUR(mess(228,111,1)) From GESECRAN
 GOK = -1 : End
Endif
End
