#<AdxTL>@(#)2.0.0.0 $Revision$
# Configurator - Issue 84080 suite 82989 GA 08/2012
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTICFG001: Configurator - Issue 84080 suite 82989") From LECFIC
#-----
  Call MAJ_UTICFG001(nomap)
#-----
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End

########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  Call MAJ_UTICFG001(APPLI)
End

########################################################################
Subprog MAJ_UTICFG001(DOSSIER)
Value Char DOSSIER

Local Integer IERR
Local Integer B_OK

# Issue 85540 - suite Issue 84095 code activité
#  Call LECACT("CFG",B_OK) From TRTX3
#  If DOSSIER = "X3" | !B_OK Then
#    End
#  Endif
  If DOSSIER = "X3" End Endif
  If filinfo(filpath("FIL","CFGQST","fde",DOSSIER),0) < 0 : End : Endif

  If GTRACE<>""  # Issue 105776 GA 02/2015 called from CFGLIBA
    #------------------------------------------------------
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    Call ECR_TIME("UTICFG001: Folder "+DOSSIER) From DOSSUB
    #------------------------------------------------------
  Endif
  IERR = 0
  Call MAJFIC("CFGQST",DOSSIER,1) From VALDIC
  Gosub CTL_CFGQST
  If GTRACE<>""  # Issue 105776 GA 02/2015 called from CFGLIBA
     Call ECR_TIME("UTICFG001: End of check for Configurator - Issue 84080 suite 82989") From DOSSUB
  Endif
  #------------------------------------------------------
End

$CTL_CFGQST
# Issue 84095
If DOSSIER<>nomap
   Local File =DOSSIER+".CFGQST" [CQU]
Else
   Local File CFGQST [CQU]
Endif
Trbegin [CQU]
  Local Shortint WCPT
  For [CQU] Where find(QSTNUM,"BOMALTRE","ROUALTRE") With Lock
    Delete [CQU] Curr
    WCPT+=1
  Next
Commit
If WCPT>0 & GTRACE<>""  # Issue 105776 GA 02/2015 called from CFGLIBA
  Call ECR_TIME("UTICFG001:"-num$(WCPT)-"rows deleted") From DOSSUB
Endif
Close Local File [CQU]
Return
