#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CLC0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CODCLA
mkstat = 0
zoncou = "CODCLA"
indice = 0
If varmode([M]CODCLA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODCLA" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CODCLA,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CODCLA" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTHRCLC"
  Call CONTHRCLC([M]CODCLA,GCURLEG,GSOCIETE) From SUBHRCLC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODCLA" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJW"
   PARAM(1) = "HRCLC"
   Local Char    VALEUR(250)
   VALEUR = [M]CODCLA
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
   [M]CODCLA = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CODCLA" : GZNUM = 5296 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]LEG,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]LEG,"909","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]LEG,"909",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call C_LEG([M]LEG) From SUBHRCLC
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]LEG or IMPMOD
       SAVACT = GACTION : GACTION = "STD"
       Call AM_LEG([M]LEG) From SUBHRCLC
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DESCLA
mkstat = 0
zoncou = "DESCLA"
indice = 0
If varinit([M]DESCLA,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DESCLA,"CLACTR","DESCLA",[M]CODCLA,[M]LEG) From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DESCLA,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DESCLA" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]DESCLA,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "DESCLA" : GZNUM = 8 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBRDOC
mkstat = 0
zoncou = "NBRDOC"
indice = 0
status = 1
zoncou = "NBRDOC"
If varmode([M]NBRDOC,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBRDOC From SUBHRCLC
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBRDOC : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRDOC" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRDOC
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRDOC = nolign
   status = 75
   Call SAI_NBRDOC(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_NBRDOC From SUBHRCLC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NBRDOC" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone TYPCLA
mkstat = 0
zoncou = "TYPCLA"
indice = 0
IMPENT = [M]TYPCLA
WNUM = IMPENT
If varinit([M]TYPCLA,indice)=0
 IMPENT = 1
Endif
If varmode([M]TYPCLA,indice)=0
 [M]TYPCLA(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYPCLA" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYPCLA(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_TYPCLA(IMPENT) From SUBHRCLC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TYPCLA" : GZNUM = 680 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]TYPCLA = IMPENT

## Zone CDNCLA
mkstat = 0
zoncou = "CDNCLA"
indice = 0
If varmode([M]CDNCLA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CDNCLA" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ROWCLA
mkstat = 0
zoncou = "ROWCLA"
indice = 0
If varmode([M]ROWCLA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ROWCLA" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone FLGBEFCLA
mkstat = 0
zoncou = "FLGBEFCLA"
indice = 0
IMPENT = [M]FLGBEFCLA
If varinit([M]FLGBEFCLA,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGBEFCLA,indice)=0
 [M]FLGBEFCLA(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGBEFCLA" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGBEFCLA(indice)
 Endif
Endif
[M]FLGBEFCLA = IMPENT

## Zone FLGAFTCLA
mkstat = 0
zoncou = "FLGAFTCLA"
indice = 0
IMPENT = [M]FLGAFTCLA
If varinit([M]FLGAFTCLA,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGAFTCLA,indice)=0
 [M]FLGAFTCLA(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGAFTCLA" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGAFTCLA(indice)
 Endif
Endif
[M]FLGAFTCLA = IMPENT

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone DESCTRCLA
mkstat = 0
zoncou = "DESCTRCLA"
indice = 0
If varmode([M]DESCTRCLA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DESCTRCLA" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TXTCLA
mkstat = 0
zoncou = "TXTCLA"
indice = 0
If varmode([M]TXTCLA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TXTCLA" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBRDOC(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRDOC
mkstat = 0
zoncou = "NBRDOC"
SAVACT = GACTION : GACTION = "STD"
Call C_NBRDOC From SUBHRCLC
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "NBRDOC" : GZNUM = 0 : Endif
Gosub AFF From GSAISIE
If mkstat : End : Endif

## Zone DOCCLA
mkstat = 0
zoncou = "DOCCLA"
IMPENT = [M]DOCCLA(indice)
If varinit([M]DOCCLA,indice)=0
 IMPENT = 1
Endif
[M]DOCCLA(indice) = IMPENT

## Zone DOCCLAA
mkstat = 0
zoncou = "DOCCLAA"
WCHAR = [M]DOCCLAA(indice)
If varmode([M]DOCCLAA,indice)=0
 SAVACT = GACTION : GACTION = "AFMTSAI"
 Call ASAISIE([M]DOCCLAA(indice),"M") From FMTVAR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]DOCCLAA(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "DOCCLAA" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]DOCCLAA(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "DOCCLAA" : GZNUM = 5169 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "AFMTCONT"
   Call CONTROLE([M]DOCCLAA(indice),"M",[M]NOLIB,20,[M]VALINT(nolign-1)) From FMTVAR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DOCCLAA" : GZNUM = 5169 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "ACONTACL"
    Call CONTACL([M]VALINT(nolign-1),"M","","") From SUBACL
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "DOCCLAA" : GZNUM = 5169 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "CONTUNI"
     Call UNICITE2([M]DOCCLAA(indice),[M]NBRDOC,[M]DOCCLAA) From OBJDIV
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "DOCCLAA" : GZNUM = 5169 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]DOCCLAA(indice) or IMPMOD
       SAVACT = GACTION : GACTION = "STD"
       Call AM_DOCCLAA([M]DOCCLAA(indice)) From SUBHRCLC
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "DOCCLAA" : GZNUM = 5169 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone NBRDOC
mkstat = 0
zoncou = "NBRDOC"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CLC0"
Return

