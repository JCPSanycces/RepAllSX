#<AdxTL>@(#)3.0.0.0 $Revision$
###########################################################################
# UTITRS007  UTI process                                     Module TRS   #
#            Initialization TREACC (Cash)
###########################################################################

If clalev([F:ADS])=0  
    Local File ADOSSIER [ADS] 
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER 
  If fstat <> 0 
        Raz [F:ADS] 
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTITRS007(WDOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTITRS007(DOSSIER)
Value Char DOSSIER

Local Integer WCOMPTEUR
Call ECR_TRACE("UTITRS007 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:BAN])  =0  Local File =DOSSIER+".BANK"   [BAN] : Endif

WCOMPTEUR = 0
Call DEBTRANS From GLOCK

Trbegin [BAN]
For [BAN] Where BANCSH=2
   Readlock [BAN] Curr    
   If fstat = 0
      # --- fields and rewrite 
      [F:BAN]TREACC = [F:BAN]BANACC
      Rewrite [F:BAN]
      If !fstat WCOMPTEUR += 1 Endif
   Endif
Next
Commit

Close Local File [BAN]

Call ECR_TRACE("UTITRS007 : "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTITRS007 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI 
If fstat : Raz [F:ADS] : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif                               

If filinfo(filpath("FIL","BANK","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTITRS007(APPLI)        
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif                             
If filinfo(filpath("FIL","BANK","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTITRS007(APPLI)        
End


