# Superviseur
# Gestion du masque GENMPS 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone PROSEL
mkstat = 0
zoncou = "PROSEL"
indice = 0
IMPENT = [M]PROSEL
WNUM = IMPENT
If varinit([M]PROSEL,indice)=0
 IMPENT = 1
Endif
If varmode([M]PROSEL,indice)=0
 [M]PROSEL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PROSEL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PROSEL(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PROSEL(IMPENT) From TRTMPS
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PROSEL" : GZNUM = 6028 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]PROSEL = IMPENT

## Zone SELVAR
