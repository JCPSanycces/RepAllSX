If varinit([M]ALLCPY,indice)=0
 IMPENT = 2
Endif
If varmode([M]ALLCPY,indice)=0
 SAVACT = GACTION : GACTION = "BSALLCPY"
 Call AS_ALLCPY(IMPENT) From DIVPAYE
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]ALLCPY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ALLCPY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ALLCPY(indice)
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CALLCPY"
  Call C_ALLCPY(IMPENT) From DIVPAYE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ALLCPY" : GZNUM = 6052 : Endif
  Gosub AFF From GSAISIE
