    mkstat   = 2 : End
  Endif
  If ( VALEUR > [M:CNX2]HRZEXE ) Then
    # Le nombre d'exercices avec périodes doit être inférieur ou égal au nombre d'exercices à calculer
    GMESSAGE = mess(286,GML_MSGFASPR,1) :  GERR  = 1
    mkstat   = 2 : End
  Endif
End

######################################################################################
Subprog D_HRZEXE(VALEUR)
Variable Decimal VALEUR

Local Char    L_PARAM
Local Integer L_HRZEXE


  # Nombre d'exercices à calculer
  Call PARAM("","NBEXESTO",L_PARAM) From ADOVAL
  If (L_PARAM = "" ) Then
    L_HRZEXE = 2
  Else
    L_HRZEXE = val(L_PARAM)
  Endif

  VALEUR = L_HRZEXE
End
