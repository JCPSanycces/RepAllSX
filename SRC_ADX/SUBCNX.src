Raz  GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("CNX",GBIDC1,GBIDC2) From GOBJET
End
################################################################################
$ACTION

  Case ACTION
    When "OUVRE"            : Gosub OUVRE
    When "SETBOUT"          : Gosub SETBOUT
    When "VERROU"           : Gosub VERROU
    When "DEVERROU"         : Gosub DEVERROU
    When "RAZCRE"           : Gosub RAZCRE
    When "CREATION"         : Gosub CREATION
    When "MODIF"            : Gosub MODIF
    When "VERF_ANU"         : Gosub VERF_ANU
    When "ANNULE"           : Gosub ANNULE
    When "AP_ANNULE"        : Gosub AP_ANNULE
    When "LIENS"            : Gosub LIENS
    When "APRES_MOD"        : Gosub APRES_MOD
    When "APRES_CRE"        : Gosub APRES_CRE
    When "INICRE"           : Gosub INICRE
    When "INIMOD"           : Gosub INIMOD
    When "VERIF_CRE"        : Gosub VERIF_CRE
    When "VERIF_MOD"        : Gosub VERIF_MOD
    When "AVANT_MODFIC"     : Gosub AVANT_MODFIC
    When "APRES_MODIF"      : Gosub APRES_MODIF
    When "ABANDON"          : Gosub ABANDON
    When "FERME"            : Gosub FERME
    When Default
  Endcase

Return
################################################################################
#-------------------------------------------------------------------------------
$OUVRE
Global Char    LAST_CPY(GLONCPY)
Global Char    GSV_CPY(GLONCPY)
Global Char    LAST_CUR(GLONCUR)
Global Char    GDPM(GLONDPM)(6)
Global Integer GCNXSUB
Global Integer GSVVALCNX
Global Integer LAST_CURTYP
Global Integer GLOCK_FAS
Global Integer G_CMENDFIY     # Exercice  courant   : modification de la date de fin
Global Integer G_S2MSTRFIY    # Exercice  suivant2  : modification de la date de début
Global Integer G_SMENDFIY     # Exercice  suivant   : modification de la date de fin
Global Integer G_S2MENDFIY    # Exercice  suivant2  : modification de la date de fin
Global Integer G_CMPER        # Exercice  courant   : modification des périodes
Global Integer G_SMPER        # Exercice  suivant   : modification des périodes
Global Integer G_S2MPER       # Exercice suivant2   : modification des périodes
Global Integer G_NEWPLN       # Ajout nouveau plan
Global Integer G_NEWPOIDS     # Modification poids des périodes
Global Integer G_NEWFIY       # Ajout nouvel exercice
Global Date    G_STRFIY       # Début nouvel exercice
Global Date    G_ENDFIY       # Fin nouvel exercice
Global Integer G_MODCNX       # Modification nécessitant un recalcul des biens
Global Integer G_MODPST       # Modification du type de comptabilisation
Global Integer G_MODFIY       # Modification du différé et du rat39bis
Global Integer G_ADDPLN       # Ajout d'un plan à un contexte
Local  Char    L_CPY(GLONCPY) # société pour contrôle habilitation
Global Char    G_PAYS
Global Date    GCURSTRPER    # Période courante de l'exercice  courant
Global Integer GPLNADEL      # n° plan à supprimer
Global Integer EXE_COUR      # indice ligne de l'exercice courant
Global Integer GDECAUTO      #*FQ-64247 indicateur de découpage auto des exercices/périodes
Global Integer GFRADGI       #*FQ-70465 indicateur législation française de la société

# FQ88911 : ajout des tableaux pour gérer les exercices modifiés : ici anciennes valeurs
Global Integer GNBEXE
GNBEXE = 20 # limite de stockage
Global Integer GO_NB_EXE, GTO_NB_PER(1..GNBEXE)
Global Date GTO_DEBEXE(1..GNBEXE), GTO_FINEXE(1..GNBEXE)
Global Date GTO_DEBPER(1..GNBEXE, 24), GTO_FINPER(1..GNBEXE, 24), GO_DEBPERCUR, GO_FINPERCUR
Global Integer G_CFUTUR      # Modif dans 1 exe > (suivant + 1)


   G_CMENDFIY    =  0
   G_S2MSTRFIY   =  0
   G_SMENDFIY    =  0
   G_S2MENDFIY   =  0
   G_CMPER       =  0
   G_SMPER       =  0
   G_S2MPER      =  0
   G_NEWPLN      =  0
   G_NEWFIY      =  0
   G_NEWPOIDS    =  0
   G_STRFIY      = [0/0/0]
   G_ENDFIY      = [0/0/0]
   GCURSTRPER    = [0/0/0]
   G_MODCNX      = G_NON
   G_MODFIY      = G_NON
   G_MODPST      = G_NON
   G_ADDPLN      = G_NON
   GLOCK_FAS     = G_NON
   G_PAYS        = ""
   G_MOD         = G_OUI
   GPLNADEL      = 0
   GDECAUTO      = G_NON   #*FQ-64247
   GFRADGI       = G_NON   #*FQ-70465
   G_CFUTUR      = 0

  Raz GSVVALCNX
  #---------------
  Call DPM(GVML_MALIPUR, GDPM(1)) From TRTFAS            : # LINEAIRE PUR
  Call DPM(GVML_MADGFRA, GDPM(2)) From TRTFAS            : # DEGRESSIF FRANCAIS
  #---------------
  If clalev([F:CNX])  = 0 : Local File CONTEXT    [CNX]  : Endif : # Contextes
  If clalev([F:CNXM]) = 0 : Local File CONTEXT    [CNXM] : Endif : # Contextes
  If clalev([F:CNXS]) = 0 : Local File CONTEXT    [CNXS] : Endif : # Contextes
  If clalev([F:FIS])  = 0 : Local File FISCYEAR   [FIS]  : Endif : # Exercices
  If clalev([F:FISM]) = 0 : Local File FISCYEAR   [FISM] : Endif : # Exercices
  If clalev([F:FISS]) = 0 : Local File FISCYEAR   [FISS] : Endif : # Exercices
  If clalev([F:CPY])  = 0 : Local File COMPANY    [CPY]  : Endif : # Société
  If clalev([F:FCY])  = 0 : Local File FACILITY   [FCY]  : Endif : # Sites
  If clalev([F:FAS])  = 0 : Local File FXDASSETS  [FAS]  : Endif : # Bien comptables
  If clalev([F:DEP])  = 0 : Local File DEPREC     [DEP]  : Endif : # Plans d'amortissements
  If clalev([F:DEPZ]) = 0 : Local File DEPREC     [DEPZ] : Endif : # Plans d'amortissements
  If clalev([F:DMO])  = 0 : Local File DPRMODOPT  [DMO]  : Endif : # Option mode d'amortissement
  If clalev([F:PPH])  = 0 : Local File PROPLNH    [PPH]  : Endif : # Plan de production
  If clalev([F:PPL])  = 0 : Local File PROPLN     [PPL]  : Endif
  If G_ACTCCN=G_OUI
      If clalev([F:RPR])  = 0 : Local File CCNRPR    [RPR]  : Endif : #Fq-70181
  Endif
  # --------------------------------
  # Ouverture de l'écran pour contrôler la méthode dans TRTFAS
  Local Mask METH [METH]
  #59486 --------------------------------
  Local Mask CNX1 [CNX1]
  If clalev([F:AMZ])  = 0 : Local File AMSKZON     [AMZ]  : Endif
  Global Integer GINTITB2
  Read [AMZ]CODE="CNX1";"BOUTRPRACC"
  If fstat=0
    GINTITB2= [F:AMZ]INTIT
  Endif
  #59486 -
Return
#-------------------------------------------------------------------------------
$APRES_MOD

  # recharger les globales d'environnement
  Gosub CHARGE_ENVIRONNEMENT From SUBCNX2

  # Relire dans APRES_MODIF
  CLECUR1 = num$([M:CNX0]CNX)
  CLECUR2 = [M:CNX0]CPY
  Gosub RELIT From GOBJSUB
  Disable  GSTAENR

Return
#-------------------------------------------------------------------------------
$APRES_CRE

  # recharger les globales d'environnement
  Gosub CHARGE_ENVIRONNEMENT From SUBCNX2

  # ------------------------
  [M:CNX1]PLNMOD    = 0
  [M:CNX1]PLNMODFLG = G_NON
  [M:CNX1]CURPLNMOD = ""
  [M:CNX1]ZCURPLNMOD = ""
  [M:CNX1]RATCURPLN = 0
  # ------------------------
  Affzo [M:CNX1]PLNMOD
  Affzo [M:CNX1]PLNMODFLG
  Affzo [M:CNX1]CURPLNMOD
  Affzo [M:CNX1]ZCURPLNMOD
  Diszo [M:CNX1]RATCURPLN
  # ------------------------
  Diszo [M:CNX1]PLNMOD
  Diszo [M:CNX1]PLNMODFLG
  # ------------------------

  CLECUR1 = num$([M:CNX0]CNX)
  CLECUR2 = [M:CNX0]CPY
  Gosub RELIT From GOBJSUB

Return
#-------------------------------------------------------------------------------
$AP_ANNULE

  # recharger les variables d'environnement
  Gosub CHARGE_ENVIRONNEMENT From SUBCNX2

Return
#-------------------------------------------------------------------------------
$AVANT_MOD

  # Contrôle habilitation / société
  L_CPY = [M:CNX0]CPY
  Gosub AUZ_CPY
  If !OK
    Return
  Endif

Return
#-------------------------------------------------------------------------------
$APRES_MODIF
Local Char LLOCK(200)
Local Integer LCNX
Local Integer LPLN

  #--------------------------
  If COUZON = "CPY"
    # --------------------------
    Call DELOCKE_FAS(GSV_CPY, GLOCK_FAS) From SUBCNX2
    If func GLOBIENS.LOCK_SYMBOLE ("FAS", CZ, "", 0) = 0
      OK        = 0
      GMESSAGE  = G_MSGQUILOCK
      Return
    Else
      GLOCK_FAS = G_OUI
    Endif
    # --------------------------
    # Contrôle habilitation / société
    L_CPY = CZ
    Gosub AUZ_CPY
    If !OK
      Return
    Endif
    # --------------------------
  Else
    If GLOCK_FAS <> G_OUI
      If func GLOBIENS.LOCK_SYMBOLE ("FAS", [M:CNX0]CPY, "", 0) = 0
        OK        = 0
        GMESSAGE  = G_MSGQUILOCK
        Return
      Else
        GLOCK_FAS = G_OUI
      Endif
    Endif
    # --------------------------
  Endif
  # --------------------------
  If GREP = "C"
    If func GLOBIENS.IS_SYMBOLE_LOCKED ("CNX", [M:CNX0]CPY, "") = 0
       # Test si la société est verrouillée sur cette table pour en empêcher la création
       OK        = 0
       GMESSAGE  = G_MSGQUILOCK
       Return
    Endif
  Endif
  #--------------------------

Return
#-------------------------------------------------------------------------------
$AUZ_CPY

  # Fonction de contrôle de l'habilitation / société
  If GNBAUZ <> GNBSITE
    # Pas d'habilitation tous sites
    If L_CPY <> ""
      mkstat=0
      Call CONTALLFCY(L_CPY) From SUPCPT
      If mkstat
        OK     = 0
        mkstat = 0
      Endif
    Else
      OK       = 0
      # Vous n'êtes pas habilité pour la modification des paramètrages par défaut
      GMESSAGE = mess(113,GML_MSGFASPR,1)
    Endif
  Endif

Return
#-------------------------------------------------------------------------------
$VERROU
Local Char LLOCK(200)

  LLOCK = func GLOBIENS.GET_KEY_CONTEXT ([M:CNX0]CPY, [M:CNX0]CNX)
  If func GLOBIENS.IS_SYMBOLE_LOCKED ("CNX", [M:CNX0]CPY, LLOCK) = 0
    # Test si la société est verrouillée sur cette table pour en empêcher la modification
    OK = 0
  Else
    If func GLOBIENS.LOCK_SYMBOLE_CPY ("CNX", [M:CNX0]CPY, LLOCK, 0) = 0
      # on teste rien, normalement ça marche puisqu'on a pu locker l'enregistrement
      # et que la société n'est pas lockée
    Endif
  Endif

Return
#-------------------------------------------------------------------------------
$DEVERROU
Local Char LLOCK(200)

  LLOCK = func GLOBIENS.GET_KEY_CONTEXT ([M:CNX0]CPY, [M:CNX0]CNX)
  Call UNLOCK_SYMBOLE_CPY ("CNX", [M:CNX0]CPY, LLOCK) From GLOBIENS

Return

#-------------------------------------------------------------------------------
$ABANDON

  G_MODCNX = G_NON #Fq-81074
  Call DELOCKE_FAS([M:CNX0]CPY, GLOCK_FAS) From SUBCNX2

Return
#-------------------------------------------------------------------------------
$SETBOUT

Local Integer LSTAT : # réponse call VERFALLCPY

  # Désactivation des actions   "Changer de clé"
  Call VIREBOUT(CHAINE,"H") From GOBJET
  # ------------------------------
  Call VIREBOUT (CHAINE, "D") From GOBJET
  # ------------------------------
  # Pas de suppression du paramétrage d'1 société si pas d'habilitation "tous sites de la société"
  Call VERFALLFCY([M:CNX0]CPY,[L]LSTAT) From SUPCPT
  If [L]LSTAT < 1
    Call VIREBOUT(CHAINE,"A") From GOBJET
  Endif

  If [M:CNX0]CNX = G300CPFI
    # Le plan comptable est obligatoire : on ne peut donc pas supprimer le contexte comptable et fiscal
    # s'il y a au moins un bien sur la société
    # FQ79284 : optimisation en remplaçant une boucle FOR par un LOOK
    Filter [F:FAS] Where CPY=[M:CNX0]CPY
    #Fq93596 Look [F:FAS] First
    Read [F:FAS]FAS1(2) First
    Filter [F:FAS]

    If !fstat
      Call VIREBOUT (CHAINE, "A") From GOBJET   : # Supprimer
    Endif

    # S'il existe un autre contexte que le contexte comptable et fiscal le contexte comptable et fiscal
    # ne peut être détruit puisque le plan comptable est obligatoire
    For [CNXM]CNX0  Where CPY=[M:CNX0]CPY and CNX<>[M:CNX0]CNX
      Call VIREBOUT (CHAINE, "A") From GOBJET   : # Supprimer
      Break
    Next
  Endif

  #Fq-64476
  If [M:CNX1]FLGCNXUO = G_OUI
     Read[PPH]PPH3 = [M:CNX0]CPY; [M:CNX0]CNX
     If fstat=0
       Call VIREBOUT (CHAINE, "A") From GOBJET   : # Supprimer
     Endif
  Endif #Fq-64476

  # FQ73087
  If GREP = "" and [M]CPY<>"" and [M]CNX<>0
    CHMEN += "D"
  Endif
Return
#-------------------------------------------------------------------------------
$VERF_ANU
Local Integer N_I

  If func GLOBIENS.LOCK_SYMBOLE ("FAS", [M:CNX0]CPY, "", 0) = 0
    # Si on ne peut pas locker la société sur les biens,
    # on ne peut pas supprimer ce contexte
    GMESSAGE = G_MSGQUILOCK
    FIN      = 0
    GERR     = 1
    Return
  Endif

  # Le contexte comptable et fiscal ne peut être détruit s'il y a des biens sur la société
  N_I = 0
  For [FAS]FAS1  Where CPY=[M:CNX0]CPY
    # On regarde s'il y a au moins un bien pour faire confirmer la suppression du contexte
    N_I += 1
    Break
    # ------------------
    # Suite de la boucle
  Next
  If N_I > 0
    If [M:CNX0]CNX = G300CPFI
      # Le contexte comptable et fiscal est obligatoire lorsqu'il y a des biens sur la société. suppression impossible.
      GMESSAGE = mess(97,GML_MSGFASPR,1)
      FIN      = 0
      GERR     = 1
      Return
    Else
      # Il y a des biens sur le contexte :
      # que vous souhaitez supprimer. Confirmez-vous ?
      Call OUINON(mess(71,GML_MSGFASPR,1)-'"'+mess([M:CNX0]CNX,GML_NCONTEXT,1)+'"'-mess(72,GML_MSGFASPR,1), OK) From GESECRAN
      If (OK = 1)
        # Suppression du contexte n'a pas été confirmée
        GMESSAGE = mess(73,GML_MSGFASPR,1)
        FIN      = 0
        GERR     = 1
        Return
      Endif
    Endif
  Endif

Return
#-------------------------------------------------------------------------------
$RAZCRE
Local Integer N_I, N_E

  Gosub DESACT_CHAMP
  # --------------------------------
  [M:CNX0]CPY    = LAST_CPY    : Affzo [M:CNX0]CPY
  [M:CNX1]CUR    = LAST_CUR    : Affzo [M:CNX1]CUR
  [M:CNX1]CURTYP = LAST_CURTYP : Affzo [M:CNX1]CURTYP
  # --------------------------------

  [M:CNX1]PLNMOD = 0
  Affzo [M:CNX1]PLNMOD :   Diszo [M:CNX1]PLNMOD
  [M:CNX1]RATCURPLN = 0
  Affzo [M:CNX1]RATCURPLN:   Diszo [M:CNX1]RATCURPLN

  # Infos concessions
  # -----------------
  If G_ACTCCN=G_OUI
   Grizo [M:CNX1]25
  Endif

Return
#-------------------------------------------------------------------------------
$LIENS
Local Integer N_I, N_E
Local Integer LCNX
Local Integer LPLN
Local Char    RLED, RCOA, RDEVLED

  Raz [F:CNXS]
  Raz [F:FISS]

  # FQ74931 : si le contexte chargé précédement avait plus de plans que celui-ci, les Diszo faits sur les PLNCAA
  #           sont conservés et posent problème lorsqu'on ajoute un plan. Il faut faire un Actzo pour tout
  #           réinitialiser.
  Actzo [M:CNX1]20
  #---------------
  Gosub AFFICHE_EXO_PER From SUBCNX2

  Local Integer ERR
  Call LOAD_FASPARCPY([M:CNX0]CPY,"",G_NON,ERR) From GLOFCYCPY

  Read[CPY]CPY0=[M:CNX0]CPY
  If fstat=0
     G_PAYS = [F:CPY]CRY
  Endif

  #70465 Voir si le paramètre ACCPERCTL est à "Oui"
  If func GLOBIENS.ACCPERCTL([F:CPY]CPY)
    GFRADGI= G_OUI
  Else
    GFRADGI= G_NON
  Endif

  # FQ93002 : désactiver le diszo complet du masque (fait en crt si GFRADGI = G_OUI)
  If GREP = "C" and GFRADGI = G_OUI
    Actzo [M:CNX2]
  Endif

  Gosub DESACT_CHAMP
  # FQ74931
  G_ADDPLN = G_NON
  #---------------
  For N_I = 1 To [M:CNX1]NBPLC
    Diszo [M:CNX1]PLNCAA(N_I-1)  : Affzo [M:CNX1]PLNCAA(N_I-1)
    [M:CNX1]PLNMGT(N_I-1)    = G_OUI
    [M:CNX1]PLNMGTSV(N_I-1)  = [M:CNX1]PLNMGT(N_I-1)
    [M:CNX1]FLUTRATSV(N_I-1) = [M:CNX1]FLUTRATXS(N_I-1)
    [M:CNX1]FLUTRAASV(N_I-1) = [M:CNX1]FLUTRAACC(N_I-1)
    [M:CNX1]PLNSTDSV(N_I-1)  = [M:CNX1]PLNSTD(N_I-1)
    If [M:CNX1]LNKPLN(N_I-1) <> 0
       [M:CNX1]FLGLNKPLN(N_I-1) = G_OUI
       #@fq64544
       If G_ACTLNK=G_OUI
        If func GLOLNK.IS_LNK_POSTED_PLN([M:CNX0]CPY, [M:CNX1]PLNCAA(N_I-1))=G_OUI
         Grizo [M:CNX1]FLGLNKPLN(N_I-1)
         Grizo [M:CNX1]LNKPLN(N_I-1)
        Else
         Actzo [M:CNX1]FLGLNKPLN(N_I-1)
         Actzo [M:CNX1]LNKPLN(N_I-1)
        Endif
        Affzo [M:CNX1]FLGLNKPLN(N_I-1)
        Affzo [M:CNX1]LNKPLN(N_I-1)
       Endif
       #
    Else
       [M:CNX1]FLGLNKPLN(N_I-1) = G_NON
    Endif
    [M:CNX1]FLGPROACC(N_I-1) = func SUBTPE.PLAN_COMPTABILISE([M:CNX0]CPY,[M:CNX1]PLNCAA(N_I-1),G_NON) #gbn
    If ( [M:CNX1]FLGPROACC(N_I-1) = G_OUI )
      [M:CNX1]BOUTPROACC(N_I-1)    = "128"
    Endif
    Call  LECLED([M:CNX0]CPY,[M:CNX1]LEDTYP(N_I-1),RLED,RDEVLED) From CPTDIV
    [M:CNX1]LED(N_I-1)= RLED
    If [M:CNX1]ORIBASDPR(N_I-1)=GVML_OBSAI
     Actzo [M:CNX1]LEDTYP(N_I-1)
     Actzo [M:CNX1]LED(N_I-1)
    Else
     Diszo [M:CNX1]LEDTYP(N_I-1)
     Diszo [M:CNX1]LED(N_I-1)
    Endif
    Call LECPLAN([M:CNX0]CPY,[M:CNX1]LEDTYP(N_I-1),RCOA) From CPTDIV
    [M:CNX1]COA(N_I-1)= RCOA
    # ---------------------
    # Suite de la boucle
  Next N_I
  #---------------
  # Infos concessions
  #------------------
  If G_ACTCCN=G_OUI
   If [M]CNX=G300CPFI
    If [M:CNX1]CCNFLG=G_OUI
     If [M:CNX1]CCNMOD=GVML_GCFIR
      Grizo [M:CNX1]25 : Actzo [M:CNX1]CCNFLG
      Actzo [M:CNX1]CCNMOD
      [M:CNX1]FLGRPRACC=G_NON
     Else
      Actzo [M:CNX1]25
      [M:CNX1]FLGRPRACC=func SUBTPE.RPR_COMPTABILISE([M:CNX0]CPY,G_OUI)
     Endif
     #Fq-59486
     If ( [M:CNX1]FLGRPRACC = G_OUI )
        Local Char    LIBZON(100)
        Call TEXTE(GINTITB2, LIBZON) From OBJDIV
        [M:CNX1]BOUTRPRACC   = "128"
        Chgtzn [M:CNX1]BOUTRPRACC  With LIBZON
     Else
        Chgtzn [M:CNX1]BOUTRPRACC With " "
     Endif
     # Appeler le sous-pro indiquant si les provisions sont comptabilisables #raf
     If [M:CNX1]CCNGRTFLG <> G_OUI
      [M:CNX1]CCNGRTPLN = 0
      Diszo [M:CNX1]CCNGRTPLN
     Endif
    Else
     Chgtzn [M:CNX1]BOUTRPRACC With ""  #*FQ-59486
     Diszo [M:CNX1]BOUTRPRACC           #*FQ-59486
     Grizo [M:CNX1]25 : Actzo [M:CNX1]CCNFLG
    Endif
  Else
    Chgtzn [M:CNX1]BOUTRPRACC With ""   #*FQ-59486
    Grizo [M:CNX1]25
  Endif
Endif
 Affzo [M:CNX1]
 Affzo [M:CNX2]

 # FQ118563
 For N_E = 1 To [M:CNX2]NBFIY
   If [M:CNX2]STAFIY(N_E-1) = GVML_TEPREC
     Diszo [M:CNX2]DFDTYP(N_E-1)
     Diszo [M:CNX2]DFDCOD(N_E-1)
     Diszo [M:CNX2]DFDRAT(N_E-1)
   Endif
 Next N_E
Return
#-------------------------------------------------------------------------------
$FERME
 If dim(G_CMENDFIY)>0   : Kill G_CMENDFIY    : Endif
 If dim(G_S2MSTRFIY)>0  : Kill G_S2MSTRFIY   : Endif
 If dim(G_SMENDFIY)>0   : Kill G_SMENDFIY    : Endif
 If dim(G_S2MENDFIY)>0  : Kill G_S2MENDFIY   : Endif
 If dim(G_CMPER)>0      : Kill G_CMPER       : Endif
 If dim(G_SMPER)>0      : Kill G_SMPER       : Endif
 If dim(G_S2MPER)>0     : Kill G_S2MPER      : Endif
 If dim(G_NEWPLN)>0     : Kill G_NEWPLN      : Endif
 If dim(G_NEWFIY)>0     : Kill G_NEWFIY      : Endif
 If dim(G_MODCNX)>0     : Kill G_MODCNX      : Endif
 If dim(G_MODFIY)>0     : Kill G_MODFIY      : Endif
 If dim(G_NEWPOIDS)>0   : Kill G_NEWPOIDS    : Endif
 If dim(G_ADDPLN)>0     : Kill G_ADDPLN      : Endif
 If dim(G_MODPST)>0     : Kill G_MODPST      : Endif
 If dim(G_PAYS)>0       : Kill G_PAYS        : Endif
 If dim(GPLNADEL)>0     : Kill GPLNADEL      : Endif
 If dim(EXE_COUR)>0     : Kill EXE_COUR      : Endif
 If dim(GDECAUTO)>0     : Kill GDECAUTO      : Endif  #*FQ-64247
 If dim(GFRADGI)>0      : Kill GFRADGI       : Endif  #*FQ-70465
 If dim(G_CFUTUR)>0     : Kill G_CFUTUR       : Endif
 Enable 65 : # status Suppression ligne
 Enable 73 : # status insertion ligne

Return
#-------------------------------------------------------------------------------
$CREATION


 If G_MODCNX = G_OUI or GREP="C"  #Fq-81074
    # Vérification de la validité du paramètrage des concessions
    If G_ACTCCN=G_OUI
       If [M:CNX1]CCNFLG=G_OUI & [M:CNX1]CCNMOD=GVML_GCRNW
          Gosub VERIF_CCN From SUBCNX2
       Endif
    Endif

    #----
    Local Integer N_I, N_E, N_DEBUT, I_PER
    Local Date D_DTPERPLNC
#   Local Char SREQUETE(250)
    Local Integer NFGR, MY_NOLIGN, LRET

    # ------------------------------
    Raz GSVVALCNX
    # ------------------------------
    # Si aucune période n'est définie pour un exercice saisi, on crée une période correspondant à l'exercice
    Local Integer I_PLN
    Local Integer I_NEWPER
    Local Integer I_FIYCOU
    Local Integer I_FIYSUI, I_FIYSUI2, I_FIYSUIN, I_FIY
    Local Decimal NB_YEAR
    Local Integer NB_MONTH
    Local Integer NB_WEEK
    Local Integer NB_DAY
    Local Integer CNX_NORME : CNX_NORME=G_NON
    Local Integer I_CNX

    I_FIYCOU=find(GVML_TECOURA,[M:CNX2]STAFIY)
    If I_FIYCOU>0 & [M:CNX2]NBRPER(I_FIYCOU-1)= 0 & [M:CNX2]DATENDPER(0)= [0/0/0]
       I_CNX=I_FIYCOU
       Gosub CREE_PERIODE_PLAN
       [M:CNX2]NBRPER(I_FIYCOU-1)= 1
    Else
       If [M:CNX2]NBRPER(I_FIYCOU-1)> 0 & !find (GVML_SPCOURA, [M:CNX3]STAPER(0..[M:CNX3]NBPERC-1))
          For I_PER = 1 To  [M:CNX3]NBPERC-1
             #*FQ-64242[M:CNX3]INDFISYEA(I_PER-1) = I_FIYCOU and [M:CNX3]STAPER  (I_PER-1) <> GVML_SPCLOSE
             If  (GDECAUTO = G_OUI  and  [M:CNX3]INDFISYEA(I_PER-1) = I_FIYCOU and [M:CNX3]STAPER(I_PER-1) <> GVML_SPCLOSE and
&                                        [M:CNX3]STAPER(I_PER-1)<> GVML_SPFERME ) or
&                   (GDECAUTO <> G_OUI  and  [M:CNX3]INDFISYEA(I_PER-1) = I_FIYCOU and [M:CNX3]STAPER(I_PER-1) <> GVML_SPCLOSE )
                [M:CNX3]STAPER  (I_PER-1)  = GVML_SPCOURA
                [M:CNX3]TYPPST  (I_PER-1)  = GVML_TPSTPRO
                Break
             Endif
          Next I_PER

          # FQ89972 : si on n'a tjrs pas de periode courante, on affecte avec le test évitant juste les périodes closes
          If !find (GVML_SPCOURA, [M:CNX3]STAPER(0..[M:CNX3]NBPERC-1))
            For I_PER = 1 To  [M:CNX3]NBPERC-1
              If [M:CNX3]INDFISYEA(I_PER-1) = I_FIYCOU and [M:CNX3]STAPER(I_PER-1) <> GVML_SPCLOSE
                [M:CNX3]STAPER  (I_PER-1)  = GVML_SPCOURA
                [M:CNX3]TYPPST  (I_PER-1)  = GVML_TPSTPRO
                Break
              Endif
            Next I_PER
          Endif
       Endif
    Endif

    #-Extension de l'obligation d'être périodique à l'exercice suivant
    I_FIYSUI=find(GVML_TESUIV,[M:CNX2]STAFIY)
    If I_FIYSUI>0 & [M:CNX2]NBRPER(I_FIYSUI-1)= 0
       I_CNX=I_FIYSUI
       Gosub CREE_PERIODE_PLAN
       [M:CNX2]NBRPER(I_FIYSUI-1)= 1
    Endif
    If I_FIYSUI>0
       If  [M:CNX2]INDCURPER(I_FIYSUI-1) = 0
          [M:CNX2]INDCURPER(I_FIYSUI-1) = 1
       Endif
    Endif

    #-Extension de l'obligation d'être périodique à l' exercice suivant du suivant
    I_FIYSUI2=find(GVML_TESUIV2,[M:CNX2]STAFIY)
    If I_FIYSUI2>0 & [M:CNX2]NBRPER(I_FIYSUI2-1)= 0
       I_CNX=I_FIYSUI2
       Gosub CREE_PERIODE_PLAN
       [M:CNX2]NBRPER(I_FIYSUI2-1)= 1
    Endif
    If I_FIYSUI2>0
       If  [M:CNX2]INDCURPER(I_FIYSUI2-1) = 0
          [M:CNX2]INDCURPER(I_FIYSUI2-1) = 1
       Endif
    Endif

    For I_FIY = 1   To [M:CNX2]NBFIY
       #-Extension de l'obligation d'être périodique aux autres exercices
       If [M:CNX2]STAFIY(I_FIY-1) < 2  & [M:CNX2]NBRPER(I_FIY-1)=0
          I_CNX=I_FIY
          Gosub CREE_PERIODE_PLAN
          [M:CNX2]NBRPER(I_FIY-1)= 1
       Else
          If  [M:CNX2]INDCURPER(I_FIY-1) = 0
             [M:CNX2]INDCURPER(I_FIY-1) = 1
          Endif
       Endif
    Next I_FIY

    # ------------------------------
    If [M:CNX3]NBPERC > 0
      Sorta [M:CNX3]NBPERC [M:CNX3]NBPERC Order By [M:CNX3]INDFISYEA(indice), [M:CNX3]DATSTRPER(indice)
      Call CONTROLE_LIGNE_VIDE() From SUBCNX2 #Fq67417
    Endif

  Endif #FQ-81074
  # ------------------------------
  If GOK = 1
    # Enregistrement des exercices
    For nolign = 1 To [M]NBFIY
      Raz [F:FIS]
      For I = 1 To 24
         [F:FIS]DATSTRPER(I-1) = [0/0/0]
         [F:FIS]DATENDPER(I-1) = [0/0/0]
      Next I
      # ------------------------------
      MY_NOLIGN = nolign
      # ------------------------------
      [F:FIS] = [M:CNX2]
      [F:FIS] = [M:CNX0]
      # ------------------------------
      # Chargement des périodes si besoin
      [F:FIS]NBRPER = 0
      N_DEBUT       = 1
      D_DTPERPLNC   = [0/0/0]
      # ------------------------------
      For N_I = 0 To [M:CNX3]NBPERC-1
        # ------------------------------
        If [M:CNX3]INDFISYEA(N_I) = nolign
&         and [M:CNX3]DATSTRPER(N_I) <> [0/0/0] and [M:CNX3]DATENDPER(N_I) <> [0/0/0]
          # ------------------------------
          If   [M:CNX3]DATENDPER(N_I) <> [M:CNX3]DATENDPERS(N_I)
                If D_DTPERPLNC = [0/0/0]
                   D_DTPERPLNC   = [M:CNX3]DATENDPERS(N_I)
                Endif
          Endif
          # ------------------------------
          [F:FIS]DATSTRPER(N_DEBUT-1) = [M:CNX3]DATSTRPER(N_I)
          [F:FIS]DATENDPER(N_DEBUT-1) = [M:CNX3]DATENDPER(N_I)
          [F:FIS]NBRMONPER(N_DEBUT-1) = [M:CNX3]NBRMONPER(N_I)
          [F:FIS]NBRWEKPER(N_DEBUT-1) = [M:CNX3]NBRWEKPER(N_I)
          [F:FIS]NBRDAYPER(N_DEBUT-1) = [M:CNX3]NBRDAYPER(N_I)
          [F:FIS]STAPER(N_DEBUT-1)    = [M:CNX3]STAPER(N_I)
          [F:FIS]TYPPST(N_DEBUT-1)    = [M:CNX3]TYPPST(N_I)
          #Fq67417
          If [M:CNX3]TYPPST(N_I)=GVML_TPSTDEF & [M:CNX3]TYPPSTS(N_I)=GVML_TPSTPRO
           [M:CNX3]LSTTYPPRO(N_I)=G_OUI
          Endif
          [F:FIS]LSTTYPPRO(N_DEBUT-1) = [M:CNX3]LSTTYPPRO(N_I)
          [F:FIS]DFDCOD               = [M:CNX2]DFDCOD(nolign-1)
          [F:FIS]DFDRAT               = [M:CNX2]DFDRAT(nolign-1)
          [F:FIS]DFDTYP               = [M:CNX2]DFDTYP(nolign-1)
          [F:FIS]RAT39BIS             = [M:CNX2]RAT39BIS(nolign-1)
          If [F:FIS]STAPER(N_DEBUT-1) = GVML_SPCOURA    #*Fq-62537 & [F:FIS]INDCURPER = 0
             [F:FIS]INDCURPER = N_DEBUT
          Endif
          #[F:FIS]LSTTYPPRO(N_DEBUT-1) = [M:CNX3]LSTTYPPRO(N_I) #Fq67417
          N_DEBUT                    += 1
        Endif

        # FQ67615
        [F:FIS]LVATYP            = [M:CNX2]LVATYP(nolign-1)
        [F:FIS]LVALIM            = [M:CNX2]LVALIM(nolign-1)
        # ------------------------------
        # Suite de la boucle
      Next N_I
      # ------------------------------
      [F:FIS]NBRPER = N_DEBUT - 1
      # ------------------------------
       If [F:FIS]DATSTRPER(0) <> [F:FIS]DATSTRFIY
       # La date de début  de la première période n'est pas égale à la date de début d'exercice
       GMESSAGE = mess(239,GML_MSGFASPR,1)-num$([F:FIS]DATSTRFIY)-num$([F:FIS]DATSTRPER([F:FIS]NBRPER-1))
       GOK      = 0
       Break
      Endif
      If [F:FIS]NBRPER > 0
        If [F:FIS]DATENDPER([F:FIS]NBRPER-1) <> [F:FIS]DATENDFIY
          # La date de fin de la dernière période n'est pas égale à la fin d'exercice
          GOK      = 0
          GMESSAGE = mess(85,GML_MSGFASPR,1)-num$([F:FIS]DATENDFIY)-num$([F:FIS]DATENDPER([F:FIS]NBRPER-1))
          Break
        Endif
        For I_PER = [F:FIS]NBRPER To 23
          [F:FIS]DATSTRPER(I_PER) = [0/0/0]
          [F:FIS]DATENDPER(I_PER) = [0/0/0]
        Next I_PER
        # ------------------------------
      Endif
      # ------------------------------
      Write [FIS]
      If fstat
        GOK = 0
        Break
      Endif
      # ------------------------------
      # mise à jour de DEPREC si la gestion du périodique a changé
# FQ88911 : on ne passe plus de exe à per ou inversement (tjrs periodique)
#      If  D_DTPERPLNC <> [0/0/0]
#        # si la gestion du périodique a changé par rapport à la situation précédente (géré ou pas géré)
#        # ou si la date de fin de période courante planquée a changé par rapport à la situation précédente
#        # ------------------------------
#        NFGR = nolign
#        SREQUETE = ""
#        For N_I = 0 To [F:CNX]NBPLC-1
#          If SREQUETE <> ""
#            SREQUETE += '|'
#          Endif
#          SREQUETE   += 'DPRPLN='+num$([F:CNX]PLNCAA(N_I))
#          #------------------------------------
#          # Suite de la boucle
#        Next N_I
#        # ------------------------------
#        If SREQUETE = ""
#          SREQUETE = "1=1"
#        Else
#          SREQUETE = "(" + SREQUETE + ")"
#        Endif
#        # ------------------------------
#        If GREP = "M"
#          Gosub GERE_CHGT_PERIODIQUE
#          If fstat
#            GOK = 0
#            Break
#          Endif
#        Endif
#        # ------------------------------
#      Endif
      #------------------------------------
    Next nolign
  Endif

  # FQ93731 (ne passer qu'en création. En modif l'appel doit être fait ailleurs)
  If GREP = "C" and GOK = 1 # FQ96110
    Local Integer WCNXERR
    Local Char WSOCERR(30), WMESS(250)
    If func SUBCNX2.CTRL_CNX ([M:CNX0]CPY, [M:CNX0]CNX, 0, WSOCERR, WCNXERR, WMESS)
      GMESSAGE = WMESS
      GOK      = 0
      Return
    Endif
  Endif
  # ------------------------------
  #Fq-91082 If GOK = 1
  #Fq-81074 If ( GREP = "C" ) or (GREP = "M"  )
  #Fq-91082 If ( GREP = "C" or GREP = "M" ) and G_MODCNX=G_OUI
  If GOK=1 and ( GREP="C" or G_MODCNX=G_OUI )
      Gosub GERE_AJOUT_PLAN
  Endif
  #Fq-91082 Endif
  # ------------------------------
  #Fq-81074 If GOK = 1
  #Fq-91082 If GOK = 1  & G_MODCNX=G_OUI
  If GOK=1 and ( GREP="C" or G_MODCNX=G_OUI )
    Gosub GERE_SUIVI_FLUX From SUBCNX2
  Endif
  #------------------------------
  #Fq-81074 If GOK = 1 & GREP <> "C"
  #Fq-91082 If GOK = 1 & GREP <> "C"  & G_MODCNX=G_OUI
  If GOK=1 and ( GREP="C" or G_MODCNX=G_OUI )
    Gosub GERE_ACTIVATION_NORME From SUBCNX2
  Endif
  # ------------------------------
  If GOK = 0 and fstat <> 0
    #*Fq-74559 Call FSTA("FIY") From GLOCK
    Call FSTA("FIS") From GLOCK
    Return
  Endif
  # ------------------------------
  #Fq-81074  If GOK=1
   If GOK=1 and ( GREP="C" or G_MODCNX=G_OUI )
     # FQ88911 ajout LRET en param
     Call UPD_FAS_FLGCLC([M:CNX0]CNX, LRET) From SUBCNX2
     If LRET > 0
        GOK=0 : Return
     Endif
  Endif
  # ------------------------------ FQ66894
  #If GOK=1 : # FQ70511
  If GOK=1 and GREP = "C"
     Call UPD_FAS_FLGFLX([M:CNX0]CNX, LRET) From SUBCNX2
     If LRET > 0
        GOK=0 : Return
     Endif
  Endif

  # ------------------------------
  Call DELOCKE_FAS([M:CNX0]CPY, GLOCK_FAS) From SUBCNX2
  # ------------------------------
Return
#-------------------------------------------------------------------------------
# FQ88911 : on ne passe plus de exe à per ou inversement (tjrs periodique)
# GERE_CHGT_PERIODIQUE à supprimer
$GERE_CHGT_PERIODIQUE_A_SUPP
# Gère les modifications sur les plans des biens pour traiter le cas des exercices
# qui deviennent découpés en période, ou le cas où le découpage en périodes est retiré

Local Integer N_Z
Local Date    LMADATE

  If [M:CNX2]STAFIY(nolign-1) = GVML_TECOURA or [M:CNX2]STAFIY(nolign-1) = GVML_TESUIV or
&    [M:CNX2]STAFIY(nolign-1) = GVML_TESUIV2
    # pour l'exercice courant ou suivant ou suivant2 on met à jour les enregistrements de DEPREC
    Call TEMPON(mess(98,GML_MSGFASPR,1)) From GESECRAN
      # ---------------------------------------------------------------------------------
      # ON GERE LE PERIODIQUE
      # a°) on met à jour la clé de l'exercice modifié
      If ( D_DTPERPLNC = [0/0/0]) or (D_DTPERPLNC = [F:FIS]DATENDFIY )
      #   # On n'était pas en périodique avant
      #   # ==================================
         Update [DEP] Where CPY        = [F:FIS]CPY
&                          &CNX        = [M:CNX0]CNX
&                          &FIYENDDAT  = [F:FIS]DATENDFIY
&                          &PERENDDAT  = [F:FIS]DATENDFIY
&                          &evalue(SREQUETE)
&                    With PERENDDAT=[F:FIS]DATENDPER([F:FIS]INDCURPER-1),
&                         PERSTRDAT=[F:FIS]DATSTRPER([F:FIS]INDCURPER-1),
&                         DEPSTA=GVML_SCNOCAL
        If fstat
          Call TEMPOFF() From GESECRAN
          Return
        Endif
        #<<<<<<<<<Fq-70181
        If G_ACTCCN=G_OUI
           Update [RPR] Where CPY       = [F:FIS]CPY
&                            &FIYENDDAT = [F:FIS]DATENDFIY
&                            &PERENDDAT = [F:FIS]DATENDFIY
&                     With  PERENDDAT=[F:FIS]DATENDPER([F:FIS]INDCURPER-1),
&                           PERSTRDAT=[F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
           If fstat
              Call TEMPOFF() From GESECRAN
              Return
           Endif
        Endif   #Fq-70181>>>>>>>>>
     Else
        # On était en périodique avant
        # ============================
        For N_Z = [F:FIS]NBRPER To 1 Step -1
          Filter [DEP] Where CPY       = [M:CNX0]CPY
&                           &CNX       = [M:CNX0]CNX
&                           &FIYSTRDAT = [F:FIS]DATSTRFIY
&                           &PERSTRDAT = [F:FIS]DATSTRPER(N_Z-1)
&                           &evalue(SREQUETE)
          Read [DEP]DEP3 First
          Filter [DEP]
          If fstat
            # On le trouve pas : la période a du changer. On regardera par rapport à la précédente
            # Ou bien la société ne comporte aucun bien
            fstat = 0
          Else

            If [F:DEP]PERENDDAT <> [F:FIS]DATENDPER(N_Z-1)
              # La fin de période est différente. Faut modifier cette date...mais d'abord détruire celles qui suivent...
              # ------------------------------
              Delete [DEP] Where CPY = [F:FIS]CPY
&                                &CNX       = [M:CNX0]CNX
&                                &FIYENDDAT = [F:FIS]DATENDFIY
&                                &PERSTRDAT > [F:FIS]DATSTRPER(N_Z-1)
&                                &evalue(SREQUETE)
              If fstat
                Break
              Endif
              #<<<<<<<<<Fq-70181
              If G_ACTCCN=G_OUI
                Delete [RPR] Where CPY       = [F:FIS]CPY
&                            &FIYENDDAT = [F:FIS]DATENDFIY
&                            &PERSTRDAT > [F:FIS]DATSTRPER(N_Z-1)
                If fstat
                   Break
                Endif
              Endif   #Fq-70181>>>>>>>>>
              # ------------------------------
              # ... puis modifier la date de fin de période
              Update [DEP] Where CPY       = [M:CNX0]CPY
&                               &CNX       = [M:CNX0]CNX
&                               &FIYSTRDAT = [F:FIS]DATSTRFIY
&                               &PERSTRDAT = [F:FIS]DATSTRPER(N_Z-1)
&                               &evalue(SREQUETE)
&                    With PERENDDAT=[F:FIS]DATENDPER(N_Z-1),
&                         PERSTRDAT=[F:FIS]DATSTRPER(N_Z-1),
&                         DEPSTA=GVML_SCNOCAL
              If fstat
                GOK = 0
                Break
              Endif
              #<<<<<<<<<Fq-70181
              If G_ACTCCN=G_OUI
                Update [RPR] Where CPY  = [F:FIS]CPY
&                            &FIYSTRDAT = [F:FIS]DATSTRFIY
&                            &PERSTRDAT = [F:FIS]DATSTRPER(N_Z-1)
&                    With PERENDDAT=[F:FIS]DATENDPER(N_Z-1),
&                         PERSTRDAT=[F:FIS]DATSTRPER(N_Z-1)
                If fstat
                   GOK = 0
                   Break
                Endif
              Endif   #Fq-70181>>>>>>>>>
              # ------------------------------
              # REMARQUE : Au pire, au moins la première période devrait pouvoir être lue puisque
              # la date de début de période ne peut pas changer.
              # ------------------------------
            Else
              # Début et fin de période sont identiques... c'est bien on fait rien !
            Endif
          Endif
          # ------------------
          # Suite de la boucle
        Next N_Z
        If fstat
          GOK = 0
          Call TEMPOFF() From GESECRAN
          Return
        Endif
      # ---------------------------------------------------------------------------------
  Endif
    Call TEMPOFF() From GESECRAN
  Else
    # pour les exercices après le suivant, on détruit toutes les lignes de DEPREC
    # Pas la peine de le faire ici, le calcul le fait déjà tout seul... ça gagne du temps !
  Endif

Return
#-------------------------------------------------------------------------------
$GERE_AJOUT_PLAN

Local Char    LCURPCG, LSREQUETE(250), LDPMSA(GLONDPM)
Local Integer LNCNX, N_E, N_I, STAT, LERRDPM

  Read[CNXM]CNX0=[M:CNX0]CPY;G300CPFI
  If fstat
    # Il n'y a pas de contexte comptable et fiscal : c'est pas bon !
    GOK = 0
  Else
    Call TEMPON(mess(99,GML_MSGFASPR,1)) From GESECRAN
    LCURPCG = [F:CNXM]CUR
    If ( [M:CNX1]PLNMODFLG = G_OUI )  & ( [M:CNX1]PLNMOD <> 0 )
      # ----------------------------------------------------------------
      # 1-On ajoute selon un plan modèle
      # ----------------------------------------------------------------
      # Lecture du plan modèle
      Call GET_CNX_FROM_PLAN ([M:CNX0]CPY, [M:CNX1]PLNMOD, LNCNX) From GLOBIENS
      Read [CNXM]CNX0=[M:CNX0]CPY;LNCNX
      If fstat
        # On n'arrive pas à lire le plan modèle : c'est pas bon !
        GOK = 0
      Else
        # Lecture de l'exercice courant du plan modèle
        Read [FISM]FIY1=[M:CNX0]CPY;[F:CNXM]CNX;GVML_TECOURA
        If fstat
          # On n'arrive pas à lire l'exercice courant du contexte modèle : c'est pas bon !
          GOK = 0
        Else
          Read [FIS]FIY1=[M:CNX0]CPY;[M:CNX0]CNX;GVML_TECOURA
          If fstat
            # On n'arrive pas à lire l'exercice courant du nouveau contexte : c'est pas bon !
            GOK = 0
          Else
            If [M:CNX0]CNX <> G300CPFI
              # __________________________________________________________________
              # Le nouveau plan ne fait pas partie du contexte comptable et fiscal
              # __________________________________________________________________
              # Le plan modèle est périodique, on prend la première période quoi qu'il en soit
                LSREQUETE = "PERENDDAT=[F:FISM]DATENDPER([F:FISM]INDCURPER-1)"
              # ----------------------------------
              Raz [F:FAS]
              For [DEP]DEP3 Hint Key DEP3 Where CPY=[M:CNX0]CPY and DPRPLN=[M:CNX1]PLNMOD and
&                                               FIYENDDAT=[F:FISM]DATENDFIY and evalue(LSREQUETE)
                # ----------------------------------
                If find (G301IAS, [M:CNX1]PLNCAA(0..[M:CNX1]NBPLC-1)) > 0
                  # L'entête bien ne peut être mise à jour que pour le contexte IAS
                  If [F:FAS]AASREF <> [F:DEP]AASREF
                    Read[FAS]FAS0=[F:DEP]AASREF
                    # FQ-56630 If fstat # ajout test s/date sortie du bien
                    If fstat  or ([F:FAS]ISSDAT <>  [0/0/0] and [F:FAS]ISSDAT < [F:FISM]DATSTRFIY and [F:FAS]FLGUPDISS=G_OUI )
                      GOK = 0
                      Break
                    Else
                      Gosub TRAITE_MAJ_IAS
                      If GOK = 0
                        Break
                      Endif
                    Endif
                  Endif
                Endif
                # ----------------------------------
                For N_E = 1 To [M:CNX1]NBPLC
                  #----------------------------------
                  If [M:CNX1]PLNMGT(N_E-1) = G_OUI and [M:CNX1]PLNMGTSV(N_E-1) <> G_OUI
                    # ----------------------------------
                    Raz [F:DEPZ]
                    [F:DEPZ]          = [F:DEP]
                    [F:DEPZ]DPRPLN    = [M:CNX1]PLNCAA(N_E-1)
                    [F:DEPZ]FIYSTRDAT = [F:FIS]DATSTRFIY
                    [F:DEPZ]FIYENDDAT = [F:FIS]DATENDFIY
                    [F:DEPZ]PERSTRDAT = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
                    [F:DEPZ]PERENDDAT = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
                    # ----------------------------------
                    [M:METH] = [F:DEPZ]
                    [M:METH] = [F:FAS]
                    [M:METH]FLGBCO = G_OUI
                    # Controle de la méthode pour chaque plan d'amortissement
                    Call CONTROLE_METHODE () From TRTFAS
                    # Si le mode d'amt n'est pas autorisé au plan, on met SA
                    If ( [M:METH]MSGERR ) or ( [F:DEPZ]DPM = "" )
                      [F:DEPZ]DPM       = G_DPMSA
                      [F:DEPZ]CRBVEHCOD = ""
                      [F:DEPZ]ALWCOD    = GVML_RPAUCUN
                      [F:DEPZ]DPRRAT    = 0
                      [F:DEPZ]DPRRATFLG = G_NON
                      [F:DEPZ]DPRDUR    = 0
                    Endif
                    # ----------------------------------
                    If [F:CNXM]CUR <> [M:CNX1]CUR
                      # On converti les cumuls exercices précédents si le nouveau plan n'est pas dans
                      # la même devise que le plan modèle
                      Gosub CONVERT_VAL_EXERCICE
                    Endif
                    # ----------------------------------
                    # On remet à 0 toutes les rubriques périodiques
                    Gosub INIT_VAL_PERIODIQUE
                    # ----------------------------------
                    [F:DEPZ]DEPSTA = GVML_SCNOCAL
                    G_NEWPLN = G_OUI
                    # ----------------------------------
                    [F:DEPZ]CNX       = [M:CNX0]CNX  #Fq-68267
                    If   [F:DEPZ]DPM  = " "          #Fq-67828
                      [F:DEPZ]DPM       = G_DPMSA
                    Endif   #Fq-67828
                    Write [DEPZ]
                    If fstat
                      GOK = 0
                      Break
                    Endif
                  Endif
                  # ----------------------------------
                  # Suite de la boucle
                Next N_E
                If GOK = 0
                  Break
                Endif
                # ----------------------------------
                # Suite de la boucle
              Next
              # __________________________________________________________________
            Else
              # __________________________________________________________________
              # Le nouveau plan fait partie du contexte comptable et fiscal
              # __________________________________________________________________
              # Le plan modèle est périodique, on prend la première période quoi qu'il en soit
               LSREQUETE = "PERENDDAT=[F:FISM]DATENDPER([F:FISM]INDCURPER-1)"
              # ----------------------------------
              For [DEP]DEP3 Hint Key DEP3 Where CPY=[M:CNX0]CPY and DPRPLN=[M:CNX1]PLNMOD and
&                                   FIYENDDAT=[F:FISM]DATENDFIY and evalue(LSREQUETE)
              # ----------------------------------
              For N_E = 1 To [M:CNX1]NBPLC

                 # ----------------------------------
                 If [M:CNX1]PLNMGT(N_E-1) = G_OUI and [M:CNX1]PLNMGTSV(N_E-1) <> G_OUI
                    # ----------------------------------
                    Raz [F:DEPZ]
                    [F:DEPZ]          = [F:DEP]
                    [F:DEPZ]DPRPLN    = [M:CNX1]PLNCAA(N_E-1)
                    [F:DEPZ]FIYSTRDAT = [F:FIS]DATSTRFIY
                    [F:DEPZ]FIYENDDAT = [F:FIS]DATENDFIY
                    [F:DEPZ]PERSTRDAT = [0/0/0]
                    [F:DEPZ]PERENDDAT = [0/0/0]
                    # Si le nouveau plan est le "Fiscal" et que la société est française
                    # que le mode est différent de "LP" et "DF" ==> on met "SA"
                    If ( [M:CNX1]PLNCAA(N_E-1) = G301FIS )   &
&                      ( [M:FPC]LEG = "FRA" )
                       If [F:DEP]DPM  <>  G_DPMLP and [F:DEP]DPM  <>  G_DPMDF
                          [F:DEPZ]DPM  = G_DPMSA
                       Endif
                    Endif
                    # ----------------------------------
                    If [F:CNXM]CUR <> [M:CNX1]CUR
                       # On converti les cumuls exercices précédents si le nouveau plan n'est pas dans
                       # la même devise que le plan modèle
                       Gosub CONVERT_VAL_EXERCICE
                    Endif
                    # ----------------------------------
                    # On remet à 0 toutes les rubriques périodiques
                    Gosub INIT_VAL_PERIODIQUE
                    # ----------------------------------
                    [F:DEPZ]DEPSTA = GVML_SCNOCAL
                    G_NEWPLN = G_OUI
                    [F:DEPZ]CNX       = [M:CNX0]CNX  #Fq-68267
                    If   [F:DEPZ]DPM = " "           #Fq-67828
                       [F:DEPZ]DPM       = G_DPMSA
                    Endif   #Fq-67828
                    For N_I = 1 To [F:FIS]INDCURPER
                       [F:DEPZ]PERSTRDAT = [F:FIS]DATSTRPER(N_I-1)
                       [F:DEPZ]PERENDDAT = [F:FIS]DATENDPER(N_I-1)
                       Write [DEPZ]
                       If fstat
                          GOK = 0
                          Break
                       Endif
                       # ----------------------------------
                       # Suite de la boucle
                    Next N_I
                    If GOK = 0
                       Break
                    Endif
                 Endif
               # ----------------------------------
               # Suite de la boucle
                Next N_E
                If GOK = 0
                 Break
                Endif
               # ----------------------------------
                # Suite de la boucle
              Next
             # __________________________________________________________________
            Endif
          Endif
        Endif
      Endif
      # ----------------------------------------------------------------
    Else
      # ----------------------------------------------------------------
      # 2-On n'ajoute pas selon un plan modèle
      # ----------------------------------------------------------------
      # On récupère le code "SANS AMORTISSEMENT"
      Call DPM(GVML_MANOAMT, LDPMSA) From TRTFAS
      # ----------------------------------
      Read [FIS]FIY1=[M:CNX0]CPY;[M:CNX0]CNX;GVML_TECOURA
      If fstat
        # On n'arrive pas à lire l'exercice courant du nouveau contexte : c'est pas bon !
        GOK = 0
      Else
          # ----------------------------------
         For N_E = 1 To [M:CNX1]NBPLC
           If [M:CNX1]PLNMGT(N_E-1) = G_OUI and [M:CNX1]PLNMGTSV(N_E-1) <> G_OUI
              For [FAS]FAS1  Where CPY=[M:CNX0]CPY
                 # FQ-56630 If fstat # ajout test s/date sortie du bien
                 If  ([F:FAS]ISSDAT <>  [0/0/0] and [F:FAS]ISSDAT < [F:FIS]DATSTRFIY  and [F:FAS]FLGUPDISS = G_OUI)
                    Goto NEXTBCO
                 Endif
                 # ----------------------------------
                 If [M:CNX1]PLNCAA(N_E-1) = G301IAS
                    Gosub TRAITE_MAJ_IAS
                    If GOK = 0
                      Break
                    Endif
                  Endif
                  Raz [F:DEPZ]
                  [F:DEPZ]             = [F:FAS]
                  [F:DEPZ]DPRPLN       = [M:CNX1]PLNCAA(N_E-1)
                  [F:DEPZ]FIYSTRDAT    = [F:FIS]DATSTRFIY
                  [F:DEPZ]FIYENDDAT    = [F:FIS]DATENDFIY
                  [F:DEPZ]PERSTRDAT  = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
                  [F:DEPZ]PERENDDAT  = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
                  If [M:CNX1]ORIBASDPR(N_E-1) = GVML_OBPCG
                     MTDES              = [F:FAS]ACGETRNOT + [F:FAS]IVCVATAMT - [F:FAS]DEDVATAMT
                     If [M:CNX1]CURPLNMOD <> ""
                        Call CONVERT3([M:CNX1]CURPLNMOD, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, MTDES, [F:DEPZ]BSEVAL, [M:CNX1]RATCURPLN, STAT) From CPTSUB
                     Else
                        [F:DEPZ]BSEVAL =MTDES
                    Endif
                  Else
                     If [M:CNX1]ORIBASDPR(N_E-1) = GVML_OBIAS
                        MTDES              = [F:FAS]IASETRNOT + [F:FAS]IVCVATAMTI - [F:FAS]DEDVATAMTI
                        If [M:CNX1]CURPLNMOD <> ""
                           Call CONVERT3([M:CNX1]CURPLNMOD,[M:CNX1]CUR,GCOUDEV,[M:CNX1]CURTYP,date$,MTDES,[F:DEPZ]BSEVAL,[M:CNX1]RATCURPLN, STAT) From CPTSUB
                        Else
                           [F:DEPZ]BSEVAL =MTDES
                        Endif
                     Endif
                  Endif
                  # si flag plan subvention coché la base = 0
                  # ----------------------------------
                  [F:DEPZ]DPRBAS       = [F:DEPZ]BSEVAL
                  # ----------------------------------
                  If LDPMSA <> ""
                     [F:DEPZ]DPM          = LDPMSA
                  Else
                     [F:DEPZ]DPM          = G_DPMSA
                  Endif
                  [F:DEPZ]STRDPRDAT    = [F:FAS]PURDAT
                  [F:DEPZ]ALWCOD       = GVML_RPAUCUN
                  # ----------------------------------
                  # DECLENCHER LES ASSOCIATIONS
                  Gosub DECLENCHE_ASSOCIATION From SUBCNX2
                  # ----------------------------------
                  [F:DEPZ]DEPSTA = GVML_SCNOCAL
                  G_NEWPLN = G_OUI
                  [F:DEPZ]CNX       = [M:CNX0]CNX  #Fq-68267
                  If   [F:DEPZ]DPM = " "           #Fq-67828
                    [F:DEPZ]DPM       = G_DPMSA
                  Endif   #Fq-67828
                  For N_I = 1 To [F:FIS]INDCURPER
                     [F:DEPZ]PERSTRDAT = [F:FIS]DATSTRPER(N_I-1)
                     [F:DEPZ]PERENDDAT = [F:FIS]DATENDPER(N_I-1)
                     Write [DEPZ]
                     If fstat
                      GOK = 0
                        Break
                     Endif
                     # ----------------------------------
                     # Suite de la boucle
                  Next N_I
                  If GOK = 0
                     Break
                  Endif
                  # ----------------------------------
                  # Suite de la boucle
                 $NEXTBCO
              Next
              If GOK = 0
                Break
              Endif
           Endif
          # ----------------------------------
          # Suite de la boucle
        Next N_E
        # __________________________________________________________________
      Endif
      # ----------------------------------------------------------------
    Endif
    Call TEMPOFF() From GESECRAN
  Endif

Return
#-------------------------------------------------------------------------------
$CONVERT_VAL_EXERCICE
Local Integer STAT

  [F:DEPZ]RATCUR = [M:CNX1]RATCURPLN

  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]BSEVAL, [F:DEPZ]BSEVAL, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]DPRBAS, [F:DEPZ]DPRBAS, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]RVAAMT, [F:DEPZ]RVAAMT, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]NSPVAL, [F:DEPZ]NSPVAL, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]RSDVAL, [F:DEPZ]RSDVAL, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]EXCDPR, [F:DEPZ]EXCDPR, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]EXCDPRI, [F:DEPZ]EXCDPRI, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]EXCDPRT, [F:DEPZ]EXCDPRT, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]ENDDPE, [F:DEPZ]ENDDPE, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]ENDDPEI, [F:DEPZ]ENDDPEI, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]ENDDPET, [F:DEPZ]ENDDPET, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]EXCCUM, [F:DEPZ]EXCCUM, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]EXCCUMI, [F:DEPZ]EXCCUMI, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]EXCCUMT, [F:DEPZ]EXCCUMT, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]DPRCUM, [F:DEPZ]DPRCUM, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]PERCLOEXC, [F:DEPZ]PERCLOEXC, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]PERCLOEXCI, [F:DEPZ]PERCLOEXCI, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]PERCLOEXCT, [F:DEPZ]PERCLOEXCT, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]ALWAMT, [F:DEPZ]ALWAMT, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]ALWCUM, [F:DEPZ]ALWCUM, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]CRBAMT, [F:DEPZ]CRBAMT, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]CRBCUM, [F:DEPZ]CRBCUM, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]PERIMLCUM, [F:DEPZ]PERIMLCUM, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]EXEIMLCUM, [F:DEPZ]EXEIMLCUM, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]PERRVECUM, [F:DEPZ]PERRVECUM, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]EXERVECUM, [F:DEPZ]EXERVECUM, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]EXERVADEV, [F:DEPZ]EXERVADEV, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]EXECLOCUMI, [F:DEPZ]EXECLOCUMI, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Call CONVERT3([F:CNXM]CUR, [M:CNX1]CUR, GCOUDEV, [M:CNX1]CURTYP, date$, [F:DEP]EXECLOCUMT, [F:DEPZ]EXECLOCUMT, [M:CNX1]RATCURPLN, STAT) From CPTSUB

Return
#-------------------------------------------------------------------------------
$INIT_VAL_PERIODIQUE

  [F:DEPZ]PERCLOCUM  = 0
  [F:DEPZ]PERCLOCUMT = 0
  [F:DEPZ]PERCLOCUMI = 0
  [F:DEPZ]PERENDDPE  = 0
  [F:DEPZ]DPET       = 0
  [F:DEPZ]DPEI       = 0
  [F:DEPZ]PERRVADEV  = 0

Return
#-------------------------------------------------------------------------------
$TRAITE_MAJ_IAS
Local Char    LGAC, LIASACC
Local Integer LGACACN, LIASACN
Local Integer STAT
Local Integer N_I

  [F:FAS]IASCUR           = [M:CNX1]CUR
  [F:FAS]IASCURTYP        = 0
  [F:FAS]IASRATCUR        = [M:CNX1]RATCURPLN
  Call CONVERT3(LCURPCG, [M:CNX1]CUR, GCOUDEV, [F:FAS]IASCURTYP, date$, [F:FAS]ACGETRNOT, [F:FAS]IASETRNOT,  [M:CNX1]RATCURPLN, STAT) From CPTSUB

  [F:FAS]IVCVATRATI       = [F:FAS]IVCVATRAT
  [F:FAS]IVCVATFLGI       = [F:FAS]IVCVATFLG
  If [F:FAS]IVCVATFLGI = G_OUI
    Call CONVERT3(LCURPCG, [M:CNX1]CUR, GCOUDEV, [F:FAS]IASCURTYP, date$, [F:FAS]IVCVATAMT, [F:FAS]IVCVATAMTI, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Else
    [F:FAS]IVCVATAMTI = [F:FAS]IASETRNOT * ([F:FAS]IVCVATRATI/100)
    Call GET_MNT_ARRONDI ([F:FAS]IVCVATAMTI, [M:CNX1]CUR, [F:FAS]IVCVATAMTI) From GLOBIENS
  Endif

  [F:FAS]DEDVATRATI       = [F:FAS]DEDVATRAT
  [F:FAS]DEDVATFLGI       = [F:FAS]DEDVATFLG
  If [F:FAS]DEDVATFLGI = G_OUI
    Call CONVERT3(LCURPCG, [M:CNX1]CUR, GCOUDEV, [F:FAS]IASCURTYP, date$, [F:FAS]DEDVATAMT, [F:FAS]DEDVATAMTI, [M:CNX1]RATCURPLN, STAT) From CPTSUB
  Else
    [F:FAS]DEDVATAMTI = [F:FAS]IVCVATAMTI * ([F:FAS]DEDVATRATI/100)
    Call GET_MNT_ARRONDI ([F:FAS]DEDVATAMTI, [M:CNX1]CUR, [F:FAS]DEDVATAMTI) From GLOBIENS
  Endif
  # ----------------------------------
  If [F:FAS]ACCCOD <> ""
    Call GET_GAC_IAS_FROM_GACCODE (GVML_COGIMMO, [F:FAS]ACCCOD, GGACIMMO, GIASIMMO, LGACACN, LGAC, LIASACN, LIASACC) From GLOBIENS
    [F:FAS]IASACN   = 0
    [F:FAS]IASACC   = ""
    If LIASACN <> 0
      [F:FAS]IASACN = LIASACN
      [F:FAS]IASACC = LIASACC
    Endif
  Endif
  # ----------------------------------
  N_I = find(GVML_TECOURA,[M:CNX2]STAFIY)

  If N_I and ([F:FAS]ISSDAT>=[M:CNX2]DATSTRFIY(N_I-1) or [F:FAS]ISSDAT=[0/0/0])
    [F:FAS]FLGCLC                   = G_OUI
    [F:FAS]FLGCNXCLC([M:CNX0]CNX-1) = G_OUI
     If G_ACTCCN=G_OUI
       [F:FAS]FLGRPRCLC = G_OUI  #*Fq-70181
     Endif
  Endif

  Rewrite [FAS]
  If fstat
    GOK = 0
  Endif
  # ----------------------------------

Return


#-------------------------------------------------------------------------------
$MODIF
Local Integer LRET

  # Vérification de la validité du paramètrage des concessions

  If G_ACTCCN=G_OUI
   If [M:CNX1]CCNFLG=G_OUI & [M:CNX1]CCNMOD=GVML_GCRNW
    Gosub VERIF_CCN From SUBCNX2
   Endif
  Endif

  # si modif découpage ou modif type de comptabilisation
  If ( G_MODCNX = G_OUI )  or ( G_MODPST = G_OUI )
     # ------------------------------
     # on détruit tout et on recrée
     Gosub DETRUIT_EXERCICES
     If G_MODCNX=G_OUI  #Fq-81074
        Gosub TRAITE_DESTRUCTION_PLAN
        # -----------------
        # Destruction du plan dans les association
        Gosub MENAGE_ASSOCIATION From SUBCNX2
        Gosub MENAGE_MODES_AMT
     Endif  #Fq-81074
     # ------------------------------
     # Pour tous les tableaux
     Gosub CREATION
  Endif
  # ------------------------------

  If GOK=1 & GREP <> "C"  & G_MODCNX = G_OUI

    # FQ88911 ajout LRET en param
    Call UPD_FAS_FLGCLC([M:CNX0]CNX, LRET) From SUBCNX2
    If LRET > 0
      GOK=0
      Return
    Endif

    # FQ88911 trt revu et déplacé dans SUBCNX2
    Local Date WFDSC_PER, WFDEC_PER, WFDEC_FIY # début de la 1° période modifiée : fin de la 1° période modifiée : fin d'exercice de la 1° période modifiée
    Local Date WLDEC_FIY  # fin d'exercice de la dernière période modifiée
    Local Date WODE_PER_COU, WNDE_PER_COU #  ancienne fin de période courante : nouvelle fin de période courante

    # recherche des périodes modifiées
    Call CHANGED_PER_DATES([M:CNX0]CPY, [M:CNX0]CNX,
&          WFDSC_PER, WFDEC_PER, WFDEC_FIY,
&          WLDEC_FIY,
&          WODE_PER_COU, WNDE_PER_COU) From SUBCNX2

    If dim(G_CMENDFIY) > 0 and
&      WFDSC_PER <> [0/0/0] and
&      (G_CMENDFIY or G_SMENDFIY or
&       G_S2MSTRFIY or G_S2MENDFIY or
&       G_CMPER or G_SMPER or G_S2MPER or
&       G_NEWPLN or G_NEWPOIDS or G_NEWFIY or G_CFUTUR)

      Gosub REPORT_CHGT_PERIODES From SUBCNX2


      # FQ88911 le message d'avertissement est déplacé en VERIF_MOD : ici non traité
      # maj des Plans de Production s'il en existe pour ce contexte
      If [M:CNX1]FLGCNXUO = G_OUI

        Gosub MAJ_PLANPROD From SUBCNX2

      Endif
    Endif
  Endif


  # FQ93731
  If GOK = 1 # FQ96110
    Local Integer WCNXERR
    Local Char WSOCERR(30), WMESS(250)
    If func SUBCNX2.CTRL_CNX([M:CNX0]CPY, [M:CNX0]CNX, 0, WSOCERR, WCNXERR, WMESS) <> 0
       GMESSAGE = WMESS
       GOK      = 0
       Return
    Endif
  Endif

  If ( GOK=1 )  &  ( GREP = "M" )  &  ( G_ADDPLN = G_OUI )
     Gosub GERE_AJOUT_PLAN
     # ------------------------------
     If GOK = 1
        Gosub GERE_SUIVI_FLUX From SUBCNX2
     Endif
     #------------------------------
     If GOK = 1 & GREP <> "C"
       Gosub GERE_ACTIVATION_NORME  From SUBCNX2
     Endif
     # ------------------------------

     If GOK = 0 and fstat <> 0
       Call FSTA("FIS") From GLOCK
       Return
     Endif
     # ------------------------------
     If GOK=1
        # FQ88911 ajout LRET en param
        Call UPD_FAS_FLGCLC([M:CNX0]CNX, LRET) From SUBCNX2
        If LRET > 0
           GOK=0 : Return
        Endif
      Endif
  Endif

  If ( GPLNADEL > 1 )
     Gosub TRAITE_DESTRUCTION_PLAN
     # -----------------
     # Destruction du plan dans les association
     Gosub MENAGE_ASSOCIATION    From SUBCNX2
     Gosub MENAGE_MODES_AMT
     # ------------------------------
     # ------------------------------
     If GOK=1
        # FQ88911 ajout LRET en param
        Call UPD_FAS_FLGCLC([M:CNX0]CNX, LRET) From SUBCNX2
        If LRET > 0
           GOK=0 : Return
        Endif
      Endif
  Endif

  # ------------------------------ FQ66894
  # FQ70511 : si G_MODCNX est à G_OUI c'est qu'il y a un redécoupage et donc un recalcul sera à faire, inutile de mettre les flux à
  #           régénérer puisque le calcul le fera.
  #If GOK=1
  If GOK=1 and G_MODCNX <> G_OUI
    Local Integer N_E
    For N_E = 1 To [M:CNX1]NBPLC
      If ([M:CNX1]FLUTRATXS(N_E-1) <> [M:CNX1]FLUTRATSV(N_E-1))
&     or ([M:CNX1]FLUTRAACC(N_E-1) <> [M:CNX1]FLUTRAASV(N_E-1))
        Call UPD_FAS_FLGFLX([M:CNX0]CNX, LRET) From SUBCNX2
        If LRET > 0
          GOK=0 : Return
        Endif
        Break
      Endif
    Next
  Endif

  # FQ67615
  Gosub MODIF From SUBCNX2

  # ------------------------------
  Call DELOCKE_FAS([M:CNX0]CPY, GLOCK_FAS) From SUBCNX2
  # ------------------------------
Return

#-------------------------------------------------------------------------------
$ANNULE
  # -----------------
  Gosub GERE_SUIVI_FLUX From SUBCNX2 #Fq-57780 bis
  Local Integer LRET                                 : # FQ66894
  Call UPD_FAS_FLGFLX([M:CNX0]CNX,LRET) From SUBCNX2 : # FQ66894
  # -----------------
  Gosub DETRUIT_EXERCICES
  Gosub TRAITE_DESTRUCTION_PLAN
  # -----------------
  # Destruction du plan dans les association
  Gosub MENAGE_ASSOCIATION From SUBCNX2
  Gosub MENAGE_MODES_AMT
  # -----------------
  Call DELOCKE_FAS([M:CNX0]CPY, GLOCK_FAS) From SUBCNX2
  # -----------------
Return

#---------------------------------------------------------------------------
$TRAITE_DESTRUCTION_PLAN
Local Char SREQUETE(250), SREQEVT(250)
Local Integer N_I
Local Integer N_NBPLNDEL, TBPLNDEL(0..14)
  # -----------------
  Raz TBPLNDEL
  N_NBPLNDEL = -1
  # -----------------
  SREQUETE = ""
  SREQEVT  = ""


  # Préparation de la requête -------
  # 1- cas de la suppression d'une ligne de plan d'un contexte plan du contexte
  If GPLNADEL > 1
      SREQUETE   += 'DPRPLN='+num$(GPLNADEL)
      SREQEVT    += 'PLN='+num$(GPLNADEL)
      N_NBPLNDEL += 1
      TBPLNDEL(N_NBPLNDEL) = GPLNADEL
  #Fq-79487  Endif
  # 2- autres cas de suppression des DEPREC d'un contexte avant re-création
  # à cause d'un  re-découpage des exercices/périodes ou d'une modif. du type de comptabilisation
  Else
     For N_I = 1 To [M:CNX1]NBPLC
        If   (GREP = "A")    and ([M:CNX1]PLNMGT(N_I-1)  = G_OUI ) or
&            (GREP = "M")    and ([M:CNX1]PLNMGT(N_I-1) <> G_OUI and [M:CNX1]PLNMGTSV(N_I-1) = G_OUI)
           If SREQUETE <> ""
              SREQUETE += "|"
           Endif
           SREQUETE   += 'DPRPLN='+num$([M:CNX1]PLNCAA(N_I-1))
           # -----------------
           If SREQEVT <> ""
              SREQEVT += "|"
           Endif
           SREQEVT   += 'PLN='+num$([M:CNX1]PLNCAA(N_I-1))
           # -----------------
           N_NBPLNDEL += 1
           TBPLNDEL(N_NBPLNDEL) = [M:CNX1]PLNCAA(N_I-1)
           # -----------------
        Endif
        # -----------------
        # Suite de la boucle
     Next N_I
     # -----------------
  Endif #Fq-79487


  # Destruction du plan de DEPREC
  If SREQUETE <> ""
    SREQUETE = "("+SREQUETE+")"
    Delete [DEP] Where CPY=[M:CNX0]CPY &evalue(SREQUETE)
    If fstat
      GOK = 0
      Call RSTA("DEP",CLECUR1-CLECUR2-num$(CLECUR2(1))) From GLOCK
      Return
    Endif
  Endif
  # -----------------

Return


#-------------------------------------------------------------------------------
$MENAGE_MODES_AMT
Local Integer N_I

  For N_I = 0 To N_NBPLNDEL
    Delete [DMO] Where OPTCPY=[M:CNX0]CPY and DPRPLN=TBPLNDEL(N_I)
    If fstat
      GOK = 0
      Call RSTA("DMO",CLECUR1-CLECUR2-num$(CLECUR2(1))) From GLOCK
      Break
    Endif
    # ------------------
    # Suite de la boucle
  Next N_I
  If GOK = 0
    Return
  Endif
Return

#-------------------------------------------------------------------------------
$DETRUIT_EXERCICES
  # Suppression des exercices
  Delete [FIS] Where CPY=[M:CNX0]CPY and CNX=[M:CNX0]CNX
  If fstat
    GOK = 0
    Call RSTA("FIS",CLECUR1-CLECUR2-num$(CLECUR2(1))) From GLOCK
    Return
  Endif
  # ------------------
Return
#-------------------------------------------------------------------------------
$INICRE
  # un peu obligé de le faire ici parce que le trans-classe se fait dans l'ordre
  # des écrans, et le champs CPY de CNX2 est encore vide à ce point. Du coup la société
  # est effacée à l'enregistrement.
  # Mettre ce trans-classe ici rétabli la situation
  [F:CNX] = [M:CNX0]

Return
#-------------------------------------------------------------------------------
$INIMOD

Return
#-------------------------------------------------------------------------------
$VERIF_MOD

#========================================================================
# Vérification d'une modification des dates de :
#   - Fin exercice courant / début exercice suivant
#   - Fin exercice suivant / début exercice suivant2
#   - Fin exercice suivant2
#   - Redécoupage des périodes de l'exercice courant
#   - Redécoupage des périodes de l'exercice suivant
#   - Redécoupage des périodes de l'exercice suivant2
#
#> S'il n'y pas de biens sur la société du contexte, pas la peine de contrôler les modifications de découpage

 Local Integer EXISTBCO
 #Fq-81074 Local Integer NBBCO
 Local Integer EXISTPLP
 Local Integer NBPLP
 Local Integer LRET
 Local Char MESSA(255)

 #FQ93596 > Il y a des biens ?
 #FQ93596   Filter [FAS] Where CPY=[M:CNX0]CPY
 #FQ93596       Look[FAS] First
 #FQ93596   #Fq-81074 NBBCO = rowcount([F:FAS])
 #FQ93596   Filter [FAS]
 #FQ93596   #Fq-81074 If NBBCO

 #Fq93596
 Filter [F:FAS] Where CPY=[M:CNX0]CPY
  Read [FAS]FAS1(2) First
 Filter [F:FAS] #Fq93596 END

 If fstat=0
    EXISTBCO=1
 Else
    EXISTBCO=0
 Endif

 Filter[F:PPH] Where CPY= [M:CNX0]CPY and CNX= [M:CNX0]CNX
   #Fq-81074 NBPPL = rowcount([F:PPH])
   Look [F:PPH] First
 Filter[F:PPH]
 #Fq-81074 If NBPPL
 If fstat=0
    # Issue 110938 EXISTPPL=1
    EXISTPLP=1
 Else
    # Issue 110938 EXISTPPL=0
    EXISTPLP=0
 Endif

 If !clalev([F:CFIS])  : Local File FISCYEAR  [CFIS]  : Endif  # Exercice courant
 If !clalev([F:SFIS])  : Local File FISCYEAR  [SFIS]  : Endif  # Exercice suivant
 If !clalev([F:S2FI])  : Local File FISCYEAR  [S2FI]  : Endif  # Exercice suivant2

 If (!EXISTBCO) & (!EXISTPLP)
   Return
 Endif

 Local Integer CTRL_OK : CTRL_OK=1   # Erreur ?

  # Indices
  Local Integer I_CNXCOU       # ligne correspondant à l'exercice courant dans CNX2
  Local Integer I_CNXSUI       # ligne correspondant à l'exercice suivant dans CNX2
  Local Integer I_CNXSUI2      # ligne correspondant à l'exercice suivant du suivant dans CNX2
  Local Integer I_PER          # Indice de parcours des périodes
  Local Integer I_BEGFIYPER    # Indice première période exercice dans le masque CNX3
  Local Integer I_LSTFIYPER    # Indice dernière période exercice dans le masque CNX3
  Local Integer I_LSTPERSUI    # Indice dernière période exercice suivant dans masque CNX3
  Local Integer I_LSTPERSUI2   # Indice dernière période exercice suivant+1 dans masque CNX3

  # Compteurs
  Local Integer NB_CPER        # Nombre de périodes pour l'exercice courant
  Local Integer NB_SPER        # Nombre de périodes pour l'exercice suivant
  Local Integer NB_S2PER       # Nombre de périodes pour l'exercice suivant

  # Nouvelles dates
  Local Date    N_COUENDPER # Nouvelle date de fin de période courante
  Local Date    N_COUENDFIY # Nouvelle date de fin d'exercice courant
# FQ88911
  Local Date    N_SUISTRFIY # Nouvelle date de deb d'exercice suivant
  Local Date    N_SUIENDFIY # Nouvelle date de fin d'exercice suivant
  #> On retrie
  If [M:CNX3]NBPERC > 0
    Sorta [M:CNX3]NBPERC [M:CNX3]NBPERC Order By [M:CNX3]INDFISYEA(indice), [M:CNX3]DATSTRPER(indice)
    Call CONTROLE_LIGNE_VIDE() From SUBCNX2 #Fq67417
  Endif


     #> Recherche / lecture exercice courant et suivant et suivant2
     I_CNXCOU  = find(GVML_TECOURA,[M:CNX2]STAFIY)
     I_CNXSUI  = find(GVML_TESUIV, [M:CNX2]STAFIY)
     I_CNXSUI2 = find(GVML_TESUIV2,[M:CNX2]STAFIY)

   If I_CNXCOU = 0
      OK=0
      GERR     = 1
      #"Exercice courant non défini"
      GMESSAGE = mess(194,GML_MSGFASPR,1)
      Return
   Endif

   If I_CNXSUI = 0
      OK=0
      GERR     = 1
      #"Exercice suivant non défini"
      GMESSAGE = mess(195,GML_MSGFASPR,1)
      Return
   Endif

    # FQ88911 : ajout des tableaux pour gérer les exercices modifiés

    Read [F:CFIS]FIY1  = [M:CNX0]CPY;[M:CNX0]CNX;GVML_TECOURA
    Read [F:SFIS]FIY1  = [M:CNX0]CPY;[M:CNX0]CNX;GVML_TESUIV
    Read [F:S2FI]FIY1  = [M:CNX0]CPY;[M:CNX0]CNX;GVML_TESUIV2

    GO_NB_EXE = GVML_TECOURA # courant
    GTO_NB_PER(GO_NB_EXE) = [F:CFIS]NBRPER
    GTO_DEBEXE(GO_NB_EXE) = [F:CFIS]DATSTRFIY
    GTO_FINEXE(GO_NB_EXE) = [F:CFIS]DATENDFIY
    GTO_DEBPERCUR = [F:CFIS]DATSTRPER([F:CFIS]INDCURPER - 1)
    GTO_FINPERCUR = [F:CFIS]DATENDPER([F:CFIS]INDCURPER - 1)

    For I_PER = 1 To [F:CFIS]NBRPER
      GTO_DEBPER(GO_NB_EXE, I_PER - 1) = [F:CFIS]DATSTRPER(I_PER - 1)
      GTO_FINPER(GO_NB_EXE, I_PER - 1) = [F:CFIS]DATENDPER(I_PER - 1)
    Next

    GO_NB_EXE += 1 # suivant
    GTO_NB_PER(GO_NB_EXE) = [F:SFIS]NBRPER
    GTO_DEBEXE(GO_NB_EXE) = [F:SFIS]DATSTRFIY
    GTO_FINEXE(GO_NB_EXE) = [F:SFIS]DATENDFIY

    For I_PER = 1 To [F:SFIS]NBRPER
      GTO_DEBPER(GO_NB_EXE, I_PER - 1) = [F:SFIS]DATSTRPER(I_PER - 1)
      GTO_FINPER(GO_NB_EXE, I_PER - 1) = [F:SFIS]DATENDPER(I_PER - 1)
    Next

    GO_NB_EXE += 1 # suivant + 1
    GTO_NB_PER(GO_NB_EXE) = [F:S2FI]NBRPER
    GTO_DEBEXE(GO_NB_EXE) = [F:S2FI]DATSTRFIY
    GTO_FINEXE(GO_NB_EXE) = [F:S2FI]DATENDFIY

    For I_PER = 1 To [F:S2FI]NBRPER
      GTO_DEBPER(GO_NB_EXE, I_PER - 1) = [F:S2FI]DATSTRPER(I_PER - 1)
      GTO_FINPER(GO_NB_EXE, I_PER - 1) = [F:S2FI]DATENDPER(I_PER - 1)
    Next


    # FQ 88911 anciennes dates des exercices futurs
    For [FIS]FIY0 Where CPY = [M:CNX0]CPY and CNX = [M:CNX0]CNX and STAFIY = 0
        GO_NB_EXE += 1
        If GO_NB_EXE > GNBEXE
            Break
        Endif

        GTO_NB_PER(GO_NB_EXE) = [F:FIS]NBRPER
        GTO_DEBEXE(GO_NB_EXE) = [F:FIS]DATSTRFIY
        GTO_FINEXE(GO_NB_EXE) = [F:FIS]DATENDFIY

        For I_PER = 1 To [F:FIS]NBRPER
          GTO_DEBPER(GO_NB_EXE, I_PER - 1) = [F:FIS]DATSTRPER(I_PER - 1)
          GTO_FINPER(GO_NB_EXE, I_PER - 1) = [F:FIS]DATENDPER(I_PER - 1)
        Next
    Next







   #-------------------------------------------------
   #> Comparaison des dates de l'exercice courant
   #-------------------------------------------------
   If [F:CFIS]DATENDFIY<>[M:CNX2]DATENDFIY(I_CNXCOU-1)
      N_COUENDFIY=[M:CNX2]DATENDFIY(I_CNXCOU-1)
      G_CMENDFIY = 1
   Else
      N_COUENDFIY=[0/0/0]
   Endif

   #> Comptage du nombre de périodes définies dans CNX3, indice 1ère et dernière période de l'exercice
   NB_CPER=0
   For I_PER=1 To [M:CNX3]NBPERC
     If [M:CNX3]INDFISYEA(I_PER-1) = I_CNXCOU & [M:CNX3]DATENDPER(I_PER-1)<>[0/0/0]
        NB_CPER+=1
     Endif
     If [M:CNX3]INDFISYEA(I_PER-1) <> I_CNXCOU & NB_CPER>0
        I_LSTFIYPER=I_PER-1
        I_BEGFIYPER=I_LSTFIYPER-NB_CPER+1
        Local Integer LSTPERCOU
        Break
     Endif
   Next I_PER

   If dim(LSTPERCOU)<0
      I_LSTFIYPER=I_PER-1
      I_BEGFIYPER=I_LSTFIYPER-NB_CPER+1
   Endif

   #> Evolution du nombre de périodes ?
   If [F:CFIS]NBRPER<>NB_CPER
      G_CMPER=1
   Else
      For I_PER = [F:CFIS]INDCURPER To [F:CFIS]NBRPER
         If I_PER = [F:CFIS]INDCURPER & [F:CFIS]DATSTRPER(I_PER-1)<>[M:CNX3]DATSTRPER(I_BEGFIYPER+I_PER-2)
            N_COUENDPER=[M:CNX3]DATSTRPER(I_BEGFIYPER+I_PER-1)
         Else
            N_COUENDPER=[0/0/0]
         Endif
         If [F:CFIS]DATSTRPER(I_PER-1)<>[M:CNX3]DATSTRPER(I_BEGFIYPER+I_PER-2)
            G_CMPER=1
            Break
         Endif
         If [F:CFIS]DATENDPER(I_PER-1)<>[M:CNX3]DATENDPER(I_BEGFIYPER+I_PER-2)
            G_CMPER=1
            Break
         Endif
      Next I_PER
   Endif
   #-------------------------------------------------
   #> Comparaison des dates de l'exercice suivant
   #-------------------------------------------------
  # FQ88911 gestion des dates de deb et fin
  If [F:SFIS]DATSTRFIY <> [M:CNX2]DATSTRFIY(I_CNXSUI - 1)
    N_SUISTRFIY = [M:CNX2]DATSTRFIY(I_CNXSUI - 1)
   Else
      N_SUISTRFIY = [0/0/0]
  Endif

  If [F:SFIS]DATENDFIY <> [M:CNX2]DATENDFIY(I_CNXSUI - 1)
    G_SMENDFIY = 1
    N_SUIENDFIY = [M:CNX2]DATENDFIY(I_CNXSUI - 1)
   Else
      N_SUIENDFIY = [0/0/0]
  Endif
   #> Comptage du nombre de périodes définies dans CNX3, indice 1ère et dernière période de l'exercice
   NB_SPER       =    0
   G_SMPER       =    0
   I_LSTPERSUI   =    0
   For I_PER=1 To [M:CNX3]NBPERC
      If [M:CNX3]INDFISYEA(I_PER-1) = I_CNXSUI & [M:CNX3]DATENDPER(I_PER-1)<>[0/0/0]
         NB_SPER+=1
      Endif
      If ( [M:CNX3]INDFISYEA(I_PER-1) <> I_CNXSUI & NB_SPER >0 )
         I_LSTPERSUI   =   1
         I_LSTFIYPER   =   I_PER-1
         I_BEGFIYPER   =   I_LSTFIYPER-NB_SPER+1
         Break
      Endif
   Next I_PER

   If ( I_LSTPERSUI = 0 )
      I_LSTFIYPER   =   I_PER-1
      I_BEGFIYPER   =   I_LSTFIYPER-NB_SPER+1
   Endif
   #> Evolution du nombre de périodes ?
   If [F:SFIS]NBRPER<>NB_SPER or ([F:SFIS]NBRPER = 0 )
      G_SMPER = 1
   Else
      For I_PER = [F:SFIS]INDCURPER To [F:SFIS]NBRPER
         If [F:SFIS]DATSTRPER(I_PER-1)<>[M:CNX3]DATSTRPER(I_BEGFIYPER+I_PER-2) or
&           [F:SFIS]DATENDPER(I_PER-1)<>[M:CNX3]DATENDPER(I_BEGFIYPER+I_PER-2)
            G_SMPER=1
            Break
         Endif
      Next I_PER
   Endif

   #-------------------------------------------------
   #> Comparaison des dates de l'exercice suivant+1
   #-------------------------------------------------
   If I_CNXSUI2 > 0
      If [F:S2FI]DATSTRFIY<>[M:CNX2]DATSTRFIY(I_CNXSUI2-1) : G_S2MSTRFIY = 1 : Endif
      If [F:S2FI]DATENDFIY<>[M:CNX2]DATENDFIY(I_CNXSUI2-1) : G_S2MENDFIY = 1 : Endif

      #> Comptage du nombre de périodes définies dans CNX3, indice 1ère et dernière période de l'exercice
      NB_S2PER      =   0
      G_S2MPER      =   0
      I_LSTPERSUI2  =   0

      For I_PER=1 To [M:CNX3]NBPERC
         If [M:CNX3]INDFISYEA(I_PER-1) = I_CNXSUI2 & [M:CNX3]DATENDPER(I_PER-1) <> [0/0/0]
            NB_S2PER+=1
         Endif
         If [M:CNX3]INDFISYEA(I_PER-1) <> I_CNXSUI2 & NB_S2PER>0
            I_LSTPERSUI2  = 1
            I_LSTFIYPER   = I_PER-1
            I_BEGFIYPER   = I_LSTFIYPER-NB_S2PER+1
            Break
         Endif
      Next I_PER

     If ( I_LSTPERSUI2 = 0 )
        I_LSTFIYPER   =   I_PER-1
        I_BEGFIYPER   =   I_LSTFIYPER-NB_S2PER+1
     Endif

     #> Evolution du nombre de périodes ?
     If ( [F:S2FI]NBRPER   <>   NB_S2PER ) or ([F:S2FI]NBRPER = 0 )
        G_S2MPER = 1
     Else
        For I_PER = [F:S2FI]INDCURPER To [F:S2FI]NBRPER
           If [F:S2FI]DATSTRPER(I_PER-1)   <> [M:CNX3]DATSTRPER(I_BEGFIYPER+I_PER-2) or
&             [F:S2FI]DATENDPER(I_PER-1)   <> [M:CNX3]DATENDPER(I_BEGFIYPER+I_PER-2)
              G_S2MPER=1
              Break
           Endif
        Next I_PER
     Endif
  Endif



   #> Modifications exercice  et / ou période : on demande à l'utilisateur ce qu'il veut faire
   #  Les mises à jour sont faites dans $AVANT_MODFIC
   If dim(G_CMENDFIY) > 0 and
&    ( G_CMENDFIY or G_SMENDFIY or G_S2MSTRFIY or G_S2MENDFIY or
&      G_CMPER    or G_SMPER    or G_S2MPER or
&      G_NEWPLN   or G_MODCNX=G_OUI or G_NEWFIY)

      # "Modification des dates de périodes et/ou d'exercice ou de certains paramètres du contexte"+":"
      MESSA  = mess(238,GML_MSGFASPR,1)+":"
      MESSA += "\"+mess(197,GML_MSGFASPR,1)               # "cette opération va lancer un traitement de suppression des informations"
      MESSA += "\"+mess(198,GML_MSGFASPR,1)+"."           # "d'amortissements futures des biens existants sur ce contexte."
      MESSA += "\"+mess(217,GML_MSGFASPR,1)+"."           # "Un calcul devra être relancé."
      MESSA += "\"+mess(200,GML_MSGFASPR,1)+"?"           # "Confirmez-vous ?"
      Call AVERTIR(MESSA,OK) From GESECRAN
      OK -= 1

      If OK=0
        Return
      Endif

      # FQ88911 le message d'avertissement déplacé depuis MODIF

      # maj des Plans de Production s'il en existe pour ce contexte
      If [M:CNX1]FLGCNXUO = G_OUI

        # MESSA  = "Si des plans de production sont définis pour ce contexte :"
        # MESSA += "Vous devrez reventiler les UO en fonction du nouveau découpage du contexte"
        MESSA  = mess(228, GML_MSGFASPR, 1)
        MESSA += mess(229, GML_MSGFASPR, 1)
        Call AVERTIR(MESSA, OK) From GESECRAN
        OK -= 1
        If OK=0
          Return
        Endif
      Endif
   Endif

Return
#========================================================================
$VERIF_CRE
Local Date    DATE_CTRL
Local Integer N_I, LNCNX
Local Integer LCNX
Local Date    PCPTDAT(1..5)
Local Date    PSUBDAT(1..5)
Local Date    PMODDAT(1..5)
Local Date    PCNXDAT(1..5)
Local Integer PRET1, PRET2
Local Integer CRET1, CRET2


  If [M:CNX1]PLNCAA(0)= 0
     #-Au moins un plan doit être défini pour ce contexte
     GERR     = 1   :   GMESSAGE = mess(215,GML_MSGFASPR,1)
     mkstat = 2 : Return
  Endif

  Affzo [M:CNX2]
  #**---------------------------------------------------------------------------------
  # Si on ajoute un plan avec "plan modèle" la date de début exercice courant du nouveau plan
  # doit être égale à la date de début d'exercice courant du plan modèle.
  #**------------------------------------------------------------------------------------------
  If ( [M:CNX1]PLNMOD <> 0 )  & ( [M:CNX1]PLNMODFLG = G_OUI )
     Call GET_CNX_FROM_PLAN ([M:CNX0]CPY, [M:CNX1]PLNMOD, LNCNX) From GLOBIENS
     If [M:CNX0]CNX <> G300CPFI or LNCNX <> G300CPFI
        # Ce test ne se fait que si l'ajout ne porte pas sur le contexte comptable et fiscal
        # ou qu'il porte sur le contexte comptable et fiscal et que le plan modèle ne fait pas
        # parti de ce même contexte.
        # -----------------
        Read [FISM]FIY1=[M:CNX0]CPY;LNCNX;GVML_TECOURA
        # -----------------
        For N_I = 1 To [M:CNX2]NBFIY
           If [M:CNX2]STAFIY(N_I-1) = GVML_TECOURA
               If [M:CNX2]DATSTRFIY(N_I-1) <> [F:FISM]DATSTRFIY
                 #*205- Le nouveau plan doit avoir même définition exercices et périodes que le plan modèle
                 #*!
                 Local Char MESSA(255)
                 MESSA   = mess(205,GML_MSGFASPR,1)
                 MESSA  += "  "+ mess(262,GML_MSGFASPR,1)
                 Call OUINON(MESSA, OK) From GESECRAN
                 If (OK = 1)
                    # création sans plan modèle
                    GMESSAGE = mess(263,GML_MSGFASPR,1)
                    [M:CNX1]PLNMOD = 0 : Affzo [M:CNX1]PLNMOD
                    [M:CNX1]PLNMODFLG = G_NON : Affzo [M:CNX1]PLNMODFLG
                    FIN      = 0
                    GERR     = 1
                    Break : Return
                  Endif
               Endif
               Break
           Endif
           # -----------------
           # Suite de la boucle
        Next N_I
        If GERR = 1
           Return
        Endif
     Endif
     # en création on initialise les périodes à partir des périodes du plan modèle
     If GREP = "C"
        # -----------------
        Call GET_CNX_FROM_PLAN ([M:CNX0]CPY, [M:CNX1]PLNMOD, LNCNX) From GLOBIENS
        If [M:CNX0]CNX <> G300CPFI or LNCNX <> G300CPFI
           # -----------------
           # Lecture des exercices
           N_DEBUT          = 1
           EXE_COUR         = 0
           nolign           = 1
           For [FIS]FIY0 Where CPY=[M:CNX0]CPY and CNX=LNCNX
              If  [F:FIS]STAFIY = GVML_TEPREC
                 # On ne reprend pas les exercice clos du plan modèle
              Else
                 [M:CNX2]DATSTRFIY(nolign-1)  = [F:FIS]DATSTRFIY
                 [M:CNX2]DATENDFIY(nolign-1)  = [F:FIS]DATENDFIY
                 [M:CNX2]RAT39BIS(nolign-1)   = [F:FIS]RAT39BIS
                 [M:CNX2]DFDCOD(nolign-1)     = [F:FIS]DFDCOD
                 [M:CNX2]DFDRAT(nolign-1)     = [F:FIS]DFDRAT
                 [M:CNX2]DFDTYP(nolign-1)     = [F:FIS]DFDTYP
                 [M:CNX2]STAFIY(nolign-1)     = [F:FIS]STAFIY
                 [M:CNX2]INDCURPER(nolign-1)  = [F:FIS]INDCURPER
                 [M:CNX2]NBRPER(nolign-1)     = [F:FIS]NBRPER
                 [M:CNX2]EVTCREFLG(nolign-1)  = [F:FIS]EVTCREFLG

                 If [M:CNX2]STAFIY(nolign-1) = GVML_TECOURA
                    EXE_COUR = nolign
                 Endif
                 # ------------------------------
                 If [F:FIS]STAFIY = GVML_TECOURA
                    [M:CNX3]YEACLICK = nolign
                 Endif

                # FQ67615
                [M:CNX2]LVATYP(nolign-1) = [F:FIS]LVATYP
                [M:CNX2]LVALIM(nolign-1) = [F:FIS]LVALIM

                 # ------------------------------
                 # Chargement des périodes si besoin
                 If [F:FIS]NBRPER > 0
                    For N_I = 0 To [F:FIS]NBRPER-1
                       [M:CNX3]INDFISYEA(N_DEBUT-1)  = nolign
                       [M:CNX3]DATSTRPER(N_DEBUT-1)  = [F:FIS]DATSTRPER(N_I)
                       [M:CNX3]DATENDPER(N_DEBUT-1)  = [F:FIS]DATENDPER(N_I)
                       [M:CNX3]DATENDPERS(N_DEBUT-1) = [F:FIS]DATENDPER(N_I)
                       [M:CNX3]NBRMONPER(N_DEBUT-1)  = [F:FIS]NBRMONPER(N_I)
                       [M:CNX3]NBRWEKPER(N_DEBUT-1)  = [F:FIS]NBRWEKPER(N_I)
                       [M:CNX3]NBRDAYPER(N_DEBUT-1)  = [F:FIS]NBRDAYPER(N_I)
                       [M:CNX3]STAPER(N_DEBUT-1)     = [F:FIS]STAPER(N_I)
                       [M:CNX3]TYPPST(N_DEBUT-1)     = [F:FIS]TYPPST(N_I)
                       [M:CNX3]LSTTYPPRO(N_DEBUT-1)  = [F:FIS]LSTTYPPRO(N_I)
                       #---------------
                       N_DEBUT += 1
                       # Suite de la boucle
                    Next N_I
                 Endif
                 nolign += 1
              Endif
              # ------------------------------
              # Suite de la boucle
           Next FIY0
           # ------------------------------
           [M:CNX2]NBFIY  = nolign-1
           [M:CNX3]NBPERC = N_DEBUT-1
           Call AFFICHE_PERIODE()
           # ------------------------------
        Endif
     Endif
   Endif
   Affzo [M:CNX2]
   Affzo [M:CNX3]

  #Fq-67828 Vérifications avant la création
  # Il doit y avoir des exercices de saisis
  If [M:CNX2]NBFIY < 2
    If [M:CNX2]NBFIY < 1
      zonsui = "[M:CNX2]DATSTRFIY"
    Else
      zonsui = "[M:CNX2]DATENDFIY"
    Endif
    # 70465 Deux exercices doivent au moins exister
#    If GREP="C" and GFRADGI=G_OUI
#      Gosub CRE_EXE_PER From SUBCNX2
#    Else
#      GERR     = 1   :  GMESSAGE = mess(8,GML_MSGFASPR,1)
#      Return
#   Endif
  Endif

  # Il doit y avoir un exercice courant
  Call GET_DATE_DEBUT_EXERCICE (GVML_TECOURA, DATE_CTRL) From SUBCNX2
  If DATE_CTRL = [0/0/0]
    # Définir un exercice courant
    GERR     = 1   :  GMESSAGE = mess(9,GML_MSGFASPR,1)
    Return
  Endif
Return
#-------------------------------------------------------------------------------
$AVANT_MODFIC

#========================================================================
# Prise en compte d'une modification de paramètres lié à l'amortissement
# Soit mise à jour des DEPSTA, soit ajout de la modif dans la pile
# stockée dans CONTEXT (pile des modifs de paramétrage en attente)
#========================================================================
Local Integer RCOD
# Si modif prorata temporis
If [M:CNX1]PROWEK   <> [F:CNX]PROWEK
    If [M:CNX4]UPDWAIPAR(0)<>"CALCNX"
      Call ADD_UPD_WAI_CNX([M:CNX0]CPY, [M:CNX0]CNX, "CNX", "PROWEK", mess([M:CNX1]PROWEK,1,1), "[M:CNX4]", RCOD) From UPDWAICNX
    Endif
Endif

For nolign = 1 To [M:CNX2]NBFIY-1
   Read [FIS]FIY0=[M:CNX0]CPY;[M:CNX0]CNX;[M:CNX2]DATSTRFIY(nolign-1)
   If !fstat
      # Si modif Taux 39 bis
      If [M:CNX2]RAT39BIS(nolign-1)  <> [F:FIS]RAT39BIS |
&        [M:CNX2]DFDTYP(nolign-1)    <> [F:FIS]DFDTYP  |
&        [M:CNX2]DFDCOD(nolign-1)    <> [F:FIS]DFDCOD  |
&        [M:CNX2]DFDRAT(nolign-1)    <> [F:FIS]DFDRAT
         If [M:CNX4]UPDWAIPAR(0)<> "CALCNX"
            If [M:CNX2]RAT39BIS(nolign-1)  <> [F:FIS]RAT39BIS
               Call ADD_UPD_WAI_CNX([M:CNX0]CPY, [M:CNX0]CNX, "CNX", "RAT39BIS", num$([M:CNX2]RAT39BIS(nolign-1)), "[M:CNX4]", RCOD) From UPDWAICNX
             Endif
            # Si modif Type différé
            If [M:CNX2]DFDTYP(nolign-1)  <> [F:FIS]DFDTYP
               Call ADD_UPD_WAI_CNX([M:CNX0]CPY, [M:CNX0]CNX, "CNX", "DFDTYP", mess([M:CNX2]DFDTYP(nolign-1),3232,1), "[M:CNX4]", RCOD) From UPDWAICNX
            Endif
            # Si modif Règle différé
            If [M:CNX2]DFDCOD(nolign-1)  <> [F:FIS]DFDCOD
               Call ADD_UPD_WAI_CNX([M:CNX0]CPY, [M:CNX0]CNX, "CNX", "DFDCOD", mess([M:CNX2]DFDCOD(nolign-1),3239,1), "[M:CNX4]", RCOD) From UPDWAICNX
            Endif
            # Si modif Taux différé
            If [M:CNX2]DFDRAT(nolign-1)  <> [F:FIS]DFDRAT
               Call ADD_UPD_WAI_CNX([M:CNX0]CPY, [M:CNX0]CNX, "CNX", "DFDRAT", num$([M:CNX2]DFDRAT(nolign-1)), "[M:CNX4]", RCOD) From UPDWAICNX
            Endif
         Endif
      Endif
   Endif
Next

#========================================================================
# Mise à jour des biens en cas de modification du découpage exercice
# et/ ou période du contexte :
#        - Modification exercice courant (découpage périodique)
#                Suppression des enr DEPREC postérieurs à la période courante
#        - Modification exercice courant (date de fin d'exercice)
#                Suppression des enr DEPREC postérieurs à la période courante
#                Mise à jour de la date de fin d'exercice de la période courante
#                Mise à jour de la date de fin d'exercice des périodes closes.
#                Mise à jour de la date de fin exercice sur le flux exercice.
#        - Modification du découpage périodique de l'exercice suivant
#                Suppression de tous les DEPREC de l'exercice suivant
#========================================================================

# FQ88911 : trt revu et déplacé dans SUBCNX2
# FQ88911 : appel déplacé dans modif

#  If dim(G_CMENDFIY) > 0 and
#&    (G_CMENDFIY or G_SMENDFIY or G_S2MSTRFIY or G_S2MENDFIY or
#&     G_CMPER or G_SMPER or G_S2MPER or
#&     G_NEWPLN or G_NEWPOIDS)
#
#    Gosub REPORT_CHGT_PERIODES From SUBCNX2
#
#  Endif
Return


#-------------------------------------------------------------------------------
$DESACT_CHAMP
  # ------------------------
  # Le plan comptable pour [M:CNX0]CNX = G300CPFI et le plan pour les autres n'est jamais désactivable
  # sauf en interne pour les cas de reprises qui nécessitent de pouvoir tout modifier.
  If GADONIX <> 2
    Diszo [M:CNX1]PLNMGT(0)
    Read [F:CPY]CPY0=[M:CNX0]CPY
    If [M:CNX0]CNX = G300CPFI and [F:CPY]CRY = "FR"
      Diszo [M:CNX1]FLUTRATXS(0)
    Else
      Actzo [M:CNX1]FLUTRATXS(0)
    Endif
  Endif
  # ------------------------
    Actzo [M:CNX1]PROWEK
  # ------------------------
  If  [M:CNX0]CNX = G300CPFI
    Diszo [M:CNX1]CURTYP
  Else
    Actzo [M:CNX1]CURTYP
  Endif
  # ------------------------
  If (GREP <> "C") or [M:CNX0]CNX = G300CPFI

    # ------------------------
    If GREP = "C" and [M:CNX0]CNX <> G300CPFI
      Actzo [M:CNX1]CUR
    Else
      Diszo [M:CNX1]CUR
    Endif
    # ------------------------
    [M:CNX1]CURPLNMOD = ""
    [M:CNX1]RATCURPLN = 0
    # ------------------------
    Affzo [M:CNX1]PLNMOD      :   Diszo [M:CNX1]PLNMOD
    Affzo [M:CNX1]PLNMODFLG   :   Diszo [M:CNX1]PLNMODFLG
    Diszo [M:CNX1]RATCURPLN
    # ------------------------
  Else
    Actzo [M:CNX1]CUR
    If GREP = "C"
      [M:CNX1]RATCURPLN = 0
      Affzo [M:CNX1]RATCURPLN
    Endif
  Endif
  # ------------------------
  If GREP = "C"
    Diszo [M:CNX0]ICOINFO
  Else
    [M:CNX0]ICOINFO = "21"   :   Actzo [M:CNX0]ICOINFO : # On est obligé de réaffecter la valeur de l'icône, bug Superviseur
  Endif
Return

#========================================================================
#-Création automatique d'une période pour les contextes ayant un plan
$CREE_PERIODE_PLAN

 I_NEWPER=[M:CNX3]NBPERC
 If [M:CNX3]DATENDPER  (I_NEWPER) <>  [0/0/0] : Return
 Else
    [M:CNX3]DATSTRPER  (I_NEWPER)  = [M:CNX2]DATSTRFIY(I_CNX-1)
    [M:CNX3]DATENDPER  (I_NEWPER)  = [M:CNX2]DATENDFIY(I_CNX-1)
    [M:CNX3]INDFISYEA  (I_NEWPER)  = I_CNX
    Call CALCUL_NB_D_M_W_Y ([M:CNX3]DATSTRPER(I_NEWPER), [M:CNX3]DATENDPER(I_NEWPER), NB_DAY, NB_MONTH, NB_WEEK, NB_YEAR) From GLOBIENS
    [M:CNX3]NBRMONPER  (I_NEWPER)  = NB_MONTH
    [M:CNX3]NBRWEKPER  (I_NEWPER)  = NB_WEEK
    [M:CNX3]NBRDAYPER  (I_NEWPER)  = NB_DAY
    If [M:CNX2]STAFIY(I_CNX-1)= GVML_TECOURA
       [M:CNX3]STAPER     (I_NEWPER)  = GVML_SPCOURA
       [M:CNX3]TYPPST     (I_NEWPER)  = GVML_TPSTPRO
    Else
       [M:CNX3]STAPER     (I_NEWPER)  = GVML_SPFERME
       [M:CNX3]TYPPST     (I_NEWPER)  = 0
       [M:CNX2]INDCURPER  (I_CNX-1) = 1
    Endif
    If [M:CNX2]INDCURPER  (I_CNX-1) = 0
       [M:CNX2]INDCURPER  (I_CNX-1) = 1
    Endif
    [M:CNX3]DATENDPERS (I_NEWPER)  = [0/0/0]
    [M:CNX3]NBPERC+=1
 Endif

Return
################################################################################
# Fonctions locales
################################################################################

###############################################################################
Subprog MODIF_PARAM(PTYP, PPAR, PVAL, RNBBCO)
Value    Char    PTYP
Value    Char    PPAR
Value    Char    PVAL
Variable Integer RNBBCO

#> En fonction du paramètre, positionnement des indicateurs

#> Comptage du nombre de biens comptables concernés par la modification

#> Si le nombre de biens est inférieur au seuil, mise à jour direct

#> Si le nombre de biens est supérieur ou égal au seuil, mise à jour du ou des contextes concernés

End

###############################################################################
# Ecran : CNX0
################################################################################
########################################
Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()

  Call ACTION_CPY (VALEUR) From GLOFCYCPY
  GSV_CPY = VALEUR

  If GDEBUG<>G_OUI : GBOUT1 = "" : Endif #FQ61803

End

########################################
Subprog AP_CPY(VALEUR)
Variable Char    VALEUR()

  LAST_CPY = VALEUR
  GDEFSOC  = VALEUR
  #70465 Voir si le paramètre ACCPERCTL est à "Oui"
  If func GLOBIENS.ACCPERCTL(VALEUR)
    GFRADGI= G_OUI
  Else
    GFRADGI= G_NON
  Endif

End
########################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

  If GREP = ""
    [M:CNX0]CNX = 0
    Affzo [M:CNX0]CNX
  Endif

End
########################################
Subprog AS_CNX(VALEUR)
Variable Integer VALEUR

Local Integer N_I

  If GREP = ""
    # La duplication n'est pas permise : en visu on ne propose donc que les contextes déjà gérés
    Call VIRE_CNX_NON_GERES ([M:CNX0]CPY) From GLOBIENS
  Elsif GREP = "C"
    Read [CNXM]CNX0=[M:CNX0]CPY;G300CPFI
    If fstat
      # si le contexte comptable et fiscal n'existe pas, on ne peut créer que lui.
      # Il est obligatoire
      For N_I = 1 To G301MAX
        # --------------------------
        If N_I <> G300CPFI
          GMENLOC(N_I) = 1
        Endif
        # --------------------------
        # Suite de la boucle
      Next N_I
      [M:CNX0]CNX = G300CPFI
      Affzo [M:CNX0]CNX
      Gosub DESACT_CHAMP
    Else
      # En création on ne propose que les contextes qui ne sont pas encore gérés
      Call VIRE_CNX_GERES ([M:CNX0]CPY) From GLOBIENS
      Actzo [M:CNX0]CNX
    Endif
  Endif

#*Fq-89984 Déplacé en AM_CNX
#*Fq-89984  If G_ACTCCN=G_OUI
#*Fq-89984   If VALEUR=G300CPFI | [M:CNX0]CNX=G300CPFI
#*Fq-89984    Actzo [M:CNX1]CCNFLG
#*Fq-89984  Else
#*Fq-89984    Grizo [M:CNX1]25
#*Fq-89984  Endif
#*Fq-89984  Endif

   #GMENLOC(5) = 1

End
########################################
Subprog AP_CNX(VALEUR)
Variable Integer VALEUR
End
########################################
Subprog AM_CNX(VALEUR)
Variable Integer VALEUR

Local Integer N_BLU, N_I, N_DEBUT

  Raz GSVVALCNX
  If GREP = "C"
    Call INIT_PLAN (VALEUR) From SUBCNX2
    If VALEUR = G300CPFI
      [M:CNX0]CNX       = VALEUR
      # ------------------------
      # Pour le comptable et fiscal : forcer la devise société
      [M:CNX0]CNX = VALEUR
      For [CPY] Where CPY=[M:CNX0]CPY
        [M:CNX1]CUR    = [F:CPY]ACCCUR
        [M:CNX1]CURTYP = 1
        G_PAYS =  [F:CPY]CRY
        Affzo [M:CNX1]CUR,CURTYP
        Break
      Next
    Else
      [M:CNX0]CNX      = VALEUR
    Endif
  Endif

  #*Fq-89984
  If G_ACTCCN=G_OUI
   If VALEUR=G300CPFI | [M:CNX0]CNX=G300CPFI
    Actzo [M:CNX1]CCNFLG
   Else
    Grizo [M:CNX1]25
   Endif
  Endif

End
################################################################################
# Ecran : CNX1
################################################################################

########################################
Subprog AP_CURTYP(VALEUR)
Variable Integer VALEUR

  LAST_CURTYP = VALEUR
End

########################################
Subprog AP_CUR(VALEUR)
Variable Char    VALEUR()
Local Integer L_BCO :   LBCO= G_NON

  LAST_CUR = VALEUR
  [M:CNX1]PLNMODFLG  = G_NON   :    Diszo [M:CNX1]PLNMODFLG
  [M:CNX1]PLNMOD     = 0       :    Diszo [M:CNX1]PLNMOD
  # -----------------------
  If  (GREP="C") or ( GREP="M") &
&    ( [M:CNX1]PLNMGT(nolign-1)=G_OUI &  [M:CNX1]PLNMGTSV(nolign-1)<> G_OUI  &
&      [M:CNX1]PLNCAA(nolign-1) <> G301SUB )
    # Si on est en création et qu'il y a des biens sur la société on active le plan modèle
    For [FAS]FAS1 Hint Key FAS1 Where CPY=[M:CNX0]CPY
      Actzo [M:CNX1]PLNMODFLG
      [M:CNX1]PLNMOD= 0 : Affzo[M:CNX1]PLNMOD : Diszo[M:CNX1]PLNMOD
      L_BCO = G_OUI
      Break
      # --------------
      # Suite de la boucle
    Next
    If L_BCO <> G_OUI
       [M:CNX1]PLNMODFLG  = G_NON   :   Diszo [M:CNX1]PLNMODFLG
       [M:CNX1]PLNMOD     = 0       :   Diszo [M:CNX1]PLNMOD
    Endif
   Endif
  # -----------------------
End
########################################
Subprog AM_PLNMODFLG(VALEUR)
Variable Integer VALEUR

  If VALEUR = G_OUI &  [M:CNX1]PLNMODFLG <> G_OUI
    Actzo [M:CNX1]PLNMOD : Affzo [M:CNX1]PLNMOD
    [M:CNX1]CURPLNMOD = ""  :  Affzo [M:CNX1]CURPLNMOD
    Diszo [M:CNX1]CURPLNMOD
    If dim([M:CNX1]ZCURPLNMOD) > 0 : Affzo [M:CNX1]ZCURPLNMOD : Endif
    G_ADDPLN = G_OUI
    If [M:CNX1]ORIBASDPR(nolign-1) = GVML_OBPCG & [M:CNX1]PLNCAA(nolign-1) <> G301CPT
           [M:CNX1]PLNMOD = G301CPT
        Else
           If [M:CNX1]ORIBASDPR(nolign-1)= GVML_OBIAS & [M:CNX1]PLNCAA(nolign-1) <> G301IAS
              [M:CNX1]PLNMOD = G301IAS
           Else
              [M:CNX1]PLNMOD = G301CPT
           Endif
        Endif
  Else
    [M:CNX1]CURPLNMOD = GDEVSOC       :  Affzo [M:CNX1]CURPLNMOD
    If dim([M:CNX1]ZCURPLNMOD) > 0    :  Affzo [M:CNX1]ZCURPLNMOD : Endif
    Diszo [M:CNX1]PLNMOD
    [M:CNX1]PLNMODFLG = G_NON         :  Affzo [M:CNX1]PLNMODFLG
  Endif
  If VALEUR <> G_OUI
     [M:CNX1]PLNMOD     = 0            :  Diszo [M:CNX1]PLNMOD
     [M:CNX1]RATCURPLN  = 0            :  Diszo [M:CNX1]RATCURPLN
  Endif

[M:CNX1]PLNMODFLG = VALEUR : Affzo [M:CNX1]PLNMODFLG

End
########################################
Subprog AS_PLNMOD(VALEUR)
Variable Integer VALEUR

  Call VIRE_PLN_NON_GERES ([M:CNX0]CPY, 0)From GLOBIENS

End
########################################
Subprog AM_PLNMOD(VALEUR)
Variable Integer VALEUR

Local Integer LSVCNX, LCNXTMP
Local Decimal WCOURS
Local Integer WSPSTAT

  If VALEUR <> 0
     LSVCNX    = [M:CNX0]CNX
     Call GET_CNX_FROM_PLAN ([M:CNX0]CPY, VALEUR, LCNXTMP) From GLOBIENS
     # On affiche la devise de plan modèle
     Read[CNXM]CNX0=[M:CNX0]CPY;LCNXTMP
     [M:CNX1]CURPLNMOD = [F:CNXM]CUR   :   Affzo [M:CNX1]CURPLNMOD
     G_ADDPLN = G_OUI
   Endif

   [M:CNX1]PLNMOD = VALEUR : Affzo [M:CNX1]PLNMOD

If  [M:CNX1]PLNMODFLG = G_OUI and  VALEUR  > 0
   Call CDVCAL(WCOURS,[M:CNX1]CURPLNMOD,[M:CNX1]CUR,GSOCIETE,[M:CNX1]CURTYP,date$) From TRTDIV
   [M:CNX1]RATCURPLN=WCOURS
   Affzo [M:CNX1]RATCURPLN
Endif

End

########################################
Subprog AP_PLNMOD(VALEUR)
Variable Integer VALEUR

Local Integer LNCNX
Local Date    PMODDAT(1..5)
Local Date    PCNXDAT(1..5)
Local Integer PRET1, PRET2

# Le plan modèle est obligatoire
If VALEUR < 1  and [M:CNX1]PLNMODFLG = G_OUI
   GMESSAGE  = mess(84,GML_MSGFASPR,1) :  GERR  = 1  : mkstat=2 : End
   End
Endif

If [M:CNX1]PLNMODFLG = G_OUI
  Call GET_CNX_FROM_PLAN ([M:CNX0]CPY, VALEUR, LNCNX) From GLOBIENS
  Call GET_CNX_DAT([M:CNX0]CPY,[M:CNX0]CNX,PCNXDAT,PRET1) From GLOBIENS
  Call GET_CNX_DAT([M:CNX0]CPY,LNCNX,PMODDAT,PRET2)       From GLOBIENS
  If PCNXDAT(1)<> [0/0/0]
     If             ( PCNXDAT(1)  <> PMODDAT(1) ) or
&                   ( PCNXDAT(2)  <> PMODDAT(2) ) or
&                   ( PCNXDAT(3)  <> PMODDAT(3) ) or
&                   ( PCNXDAT(4)  <> PMODDAT(4) )
          #Le plan modèle doit avoir même définition exercices et périodes que le contexte saisi
          GERR     = 1
          GMESSAGE = mess(205,GML_MSGFASPR,1)
          mkstat = 2 : End
      Endif
   Endif
   G_ADDPLN = G_OUI
Endif

[M:CNX1]PLNMOD = VALEUR : Affzo [M:CNX1]PLNMOD

End

########################################
Subprog C_PLNMOD(VALEUR)
Variable Integer VALEUR

Local Integer LNCNX
Local Date    PMODDAT(1..5)
Local Date    PCNXDAT(1..5)
Local Integer PRET1, PRET2

# Le plan modèle est obligatoire
If VALEUR < 1  and [M:CNX1]PLNMODFLG = G_OUI
   GMESSAGE  = mess(84,GML_MSGFASPR,1) :  GERR  = 1  : mkstat=2 : End
   End
Endif

If [M:CNX1]PLNMODFLG = G_OUI
  Call GET_CNX_FROM_PLAN ([M:CNX0]CPY, VALEUR, LNCNX) From GLOBIENS
  Call GET_CNX_DAT([M:CNX0]CPY,[M:CNX0]CNX,PCNXDAT,PRET1) From GLOBIENS
  Call GET_CNX_DAT([M:CNX0]CPY,LNCNX,PMODDAT,PRET2)       From GLOBIENS
  If PCNXDAT(1)<> [0/0/0]
     If             ( PCNXDAT(1)  <> PMODDAT(1) ) or
&                   ( PCNXDAT(2)  <> PMODDAT(2) ) or
&                   ( PCNXDAT(3)  <> PMODDAT(3) ) or
&                   ( PCNXDAT(4)  <> PMODDAT(4) )
          #Le plan modèle doit avoir même définition exercices et périodes que le contexte saisi
          GERR     = 1
          GMESSAGE = mess(205,GML_MSGFASPR,1)
          mkstat = 2 : End
      Endif
   Endif
    G_ADDPLN = G_OUI
Endif

End
########################################
Subprog AV_RATCURPLN(VALEUR)
Variable Decimal VALEUR

If  [M:CNX1]PLNMODFLG = G_OUI or  [M:CNX1]PLNMOD  > 0
  Call CDVCAL(VALEUR,[M:CNX1]CURPLNMOD,[M:CNX1]CUR,GSOCIETE,[M:CNX1]CURTYP,date$) From TRTDIV
Endif

End

########################################
Subprog AS_PLN(VALEUR)
Variable Integer VALEUR

For[CNX] Where CPY=[M:CNX0]CPY & [F:CNX]FLGCNXUO = G_OUI
   Read [CNX] First
   If !(fstat)
       [M:CNX1]FLGCNXUO = G_NON :  Diszo [M:CNX1]FLGCNXUO
   Else
        Actzo [M:CNX1]FLGCNXUO  :  Affzo [M:CNX1]FLGCNXUO
   Endif
Next

End
########################################
Subprog AS_FLGCNXUO(VALEUR)
Variable Integer VALEUR

If VALEUR =  G_OUI
   For [PPH] Where CPY=[M:CNX0]CPY  & CNX = [M:CNX0]CNX
      Read [PPH]PPH3 First
      If (fstat=0)
         Diszo [M:CNX1]FLGCNXUO :  Affzo [M:CNX1]FLGCNXUO
         Break #Fq-70141
      Else
         Actzo [M:CNX1]FLGCNXUO :  Affzo [M:CNX1]FLGCNXUO
      Endif
   Next
Endif

End
########################################
Subprog AM_FLGCNXUO(VALEUR)
Variable Integer VALEUR

# Si décochage indicateur de gestion du plan de production
If VALEUR <> G_OUI &  [M:CNX1]FLGCNXUO = G_OUI
   For [PPH] Where CPY=[M:CNX0]CPY  & CNX = [M:CNX0]CNX
      Read [PPH]PPH3 First
      If !(fstat)
         [M:CNX1]FLGCNXUO = VALEUR  :  Diszo [M:CNX1]FLGCNXUO
         #"Il y a un plan de production portant sur ce contexte"
         GERR=1 : GMESSAGE  = mess(219,GML_MSGFASPR,1) :  Enable  GSTAENR
         mkstat=2
      Endif
   Next
Endif

# Si cochage indicateur de gestion du plan de production
If VALEUR = G_OUI &  [M:CNX1]FLGCNXUO <> G_OUI
   For[CNX] Where CPY=[M:CNX0]CPY & [F:CNX]FLGCNXUO = G_OUI
      Read [CNX] First
      If !(fstat)
         [M:CNX1]FLGCNXUO = G_NON :  Diszo [M:CNX1]FLGCNXUO
         #"Il y a déjà un contexte de cette société qui gère les UO "
         GERR=1 : GMESSAGE= mess(221,GML_MSGFASPR,1) :  Enable  GSTAENR
         mkstat=2
      Else
         Actzo [M:CNX1]FLGCNXUO
      Endif
   Next
 Endif

Affzo [M:CNX1]FLGCNXUO

End
########################################
Subprog B2_NBPLC
 Local Integer I_UPD

 For I_UPD = 1 To 10
  [M:CNX4]UPDWAITYP(I_UPD-1)=""
  [M:CNX4]UPDWAIPAR(I_UPD-1)=""
  [M:CNX4]UPDWAIINT(I_UPD-1)=""
  [M:CNX4]UPDWAIBCO(I_UPD-1)=0
 Next I_UPD

 Local Integer RCOD
 Call ADD_UPD_WAI_CNX([M:CNX0]CPY, [M:CNX0]CNX, "CNX", "CALCNX", "", "", RCOD) From UPDWAICNX
 If !RCOD
  If !clalev([F:WCNX]) : Local File CONTEXT [WCNX] : Endif
  Read [F:WCNX]CNX0=[M:CNX0]CPY;[M:CNX0]CNX
  [M:CNX4]=[F:WCNX]
 Endif

 GREP="M"
 mkstat=4

End
########################################
Subprog AS_NBPLC

 If [M:CNX1]FLGPROACC(nolign-1) <> G_OUI : GBOUT3="" : Endif

 If GREP<>""
  GBOUT1=""
  GBOUT2=""
  GBOUT3=""
 Endif

 If [M:CNX1]PLNCAA(nolign-1) = G301CPT
#Fq-81074    For [FAS]FAS1 Hint Key FAS1 Where CPY=[M:CNX0]CPY
#Fq-81074       Read [FAS]First
#Fq-81074       If fstat=0
#Fq-81074          Disable 65 : # status Suppression ligne
#Fq-81074       Else
#Fq-81074         Enable 65
#Fq-81074      Endif
#Fq-81074    Next

    Filter [F:FAS] Where CPY=[M:CNX0]CPY
      #Fq93596  Look [F:FAS] First
      Read [FAS]FAS1(2) First
    Filter [F:FAS]

    If fstat=0
       Disable 65 : # status Suppression ligne
    Else
       Enable 65
    Endif
 Endif

 If [M:CNX4]UPDWAINBR=0
  GBOUT1=""
 Endif

 If [M:CNX4]UPDWAITYP(0)="CNX" & [M:CNX4]UPDWAIPAR(0)="CALCNX"
  GBOUT2=""
 Endif

End
########################################
Subprog C_NBPLC
Local Integer NOL, OK

  If status=65  and   [M:CNX1]PLNCAA(nolign-1) > 1
     #Fq93596 Read[FAS]FAS1=[M:CNX0]CPY
     Filter [F:FAS] Where CPY=[M:CNX0]CPY
        Read [FAS]FAS1(2) First
     Filter [F:FAS]

        If fstat = 0
          # 292 Attention, vous allez supprimez définitivement le plan
          # 77 Sur lequel des biens existent. confirmez-vous ?
          Call OUINON(mess(292,GML_MSGFASPR,1)-'"'+mess([M:CNX1]PLNCAA(nolign-1),GML_NPLAN,1)+'"'-mess(77,GML_MSGFASPR,1), OK) From GESECRAN
          If OK = 1
            GERR     = 1
            GMESSAGE = mess(78,GML_MSGFASPR,1) : # Enregistrement de la modification abandonné par l'utilisateur
            mkstat=2 : End
          Else
            GPLNADEL = [M:CNX1]PLNCAA(nolign-1)
            #Fq-79487
            [M:CNX1]PLNCAA(nolign-1)= 0
            [M:CNX1]PLNMGT(nolign-1)= 0
            [M:CNX1]PLNMGTSV(nolign-1)= 0
            [M:CNX1]ORIBASDPR(nolign-1)= 0
            [M:CNX1]PLNSTD(nolign-1)= 0
            [M:CNX1]PLNSTDSV(nolign-1)= 0
            [M:CNX1]LEDTYP(nolign-1)= 0
            [M:CNX1]LED(nolign-1)= ""
            [M:CNX1]COA(nolign-1)= ""
            [M:CNX1]FLUTRATXS(nolign-1)= ""
            [M:CNX1]FLUTRATSV(nolign-1)= ""
            [M:CNX1]FLUTRAACC(nolign-1)= 0
            [M:CNX1]FLUTRAASV(nolign-1)= 0
            [M:CNX1]FLGLNKPLN(nolign-1)= 0
            [M:CNX1]LNKPLN(nolign-1)= 0
            [M:CNX1]FLGPROACC(nolign-1)= 0
            [M:CNX1]BOUTPROACC(nolign-1)= ""
            #Fq-79487 ne pas décrémenter la var. de bas de tableau ici car sinon
            #Fq-79487 il y a des trous dans les var. dimensionnées de la table des contextes
            #Fq-79487  [M:CNX1]NBPLC -=1
            #Fq-79487  Affzo[M:CNX1]
            Disable 65 : # status Suppression ligne
          Endif
        Endif
      # -----------------
      # Suite de la boucle
    If GERR = 1
      End
    Endif
   Endif

End
########################################
Subprog AS_PLNCAA(VALEUR)
Variable Integer VALEUR

Local Integer N_I, N_L, NOL, I
Local Integer I_PLN
NOL = nolign-1
  #---------------------------------------------------------------
  # Contrôler que le plan n'existe pas déjà :
  #   1°) sur une autre ligne pour ce contexte
  #   2°) sur un autre contexte pour la même société
  # ---------------------------------------------------------------
  GMENLOC(G301AUC) = 1

#Fq-74561  For [FAS]Where CPY=[M:CNX0]CPY
#Fq-74561     Read [FAS]First
#Fq-74561     If fstat=0
#Fq-74561        For N_L = 1 To [M:CNX1]NBPLC-1
#Fq-74561           If  [M:CNX1]PLNMGTSV(N_L-1)= G_OUI
#Fq-74561              Diszo  [M:CNX1]PLNCAA(N_L-1) : Affzo [M:CNX1]PLNCAA(N_L-1)
#Fq-74561           Endif
#Fq-74561        Next N_L
#Fq-74561     Endif
#Fq-74561  Next

 #Fq93596   For [FAS]FAS1 Hint Key FAS1 Where CPY=[M:CNX0]CPY
 #Fq93596      For N_L = 1 To [M:CNX1]NBPLC-1
 #Fq93596        If  [M:CNX1]PLNMGTSV(N_L-1)= G_OUI
 #Fq93596           Diszo  [M:CNX1]PLNCAA(N_L-1) : Affzo [M:CNX1]PLNCAA(N_L-1)
 #Fq93596        Endif
 #Fq93596      Next N_L
 #Fq93596      Break
 #Fq93596  Next

 #Fq93596
 Filter [F:FAS] Where CPY=[M:CNX0]CPY
  Read [FAS]FAS1(2) First
 Filter [F:FAS] #Fq93596
 If fstat=0
     For N_L = 1 To [M:CNX1]NBPLC-1
        If  [M:CNX1]PLNMGTSV(N_L-1)= G_OUI
           Diszo  [M:CNX1]PLNCAA(N_L-1) : Affzo [M:CNX1]PLNCAA(N_L-1)
        Endif
     Next N_L
 Endif #Fq93596 END

  For [CNX] Where CPY=[M:CNX0]CPY
     For I_PLN=1 To G301MAX-1
       #FQ-50453 If find (I_PLN, [F:CNX]PLNCAA(0..14)) > 0
       #*FQ99052 If find (I_PLN, [M:CNX1]PLNCAA(0..14)) > 0 and ([M:CNX1]PLNMGTSV(nolign-1) = G_OUI)
       If find (I_PLN, [F:CNX]PLNCAA(0..14)) > 0
           GMENLOC(I_PLN) = 1
       Endif
       If find (I_PLN, [M:CNX1]PLNCAA(0..14)) > 0
           GMENLOC(I_PLN) = 1
       Endif #*FQ99052 END
       # ------------------------------
       # Suite de la boucle
     Next I_PLN
  Next

   #*FQ-50453
   If NOL <> 0
     For I=1 To NOL
       If   [M:CNX1]PLNCAA(I-1) <> 0 #FQ99052 and ([M:CNX1]PLNMGTSV(I-1) = G_OUI)
          GMENLOC([M:CNX1]PLNCAA(I-1)) = 1
       Endif
     Next
   Endif   #*FQ-50453

 [M:CNX1]FLGLNKPLN(nolign-1) = G_NON
 [M:CNX1]LNKPLN(nolign-1)    = 0

 If [M:CNX0]CNX  <> G300CPFI
    GMENLOC(G301CPT) = 1
    GMENLOC(G301FIS) = 1
    GMENLOC(G301MIN) = 1
    GMENLOC(G301SUB) = 1
 Else
    If nolign=1
       [M:CNX1]PLNCAA(nolign-1)= G301CPT
       Diszo [M:CNX1]PLNCAA(nolign-1)
       Diszo [M:CNX1]FLGLNKPLN(nolign-1)
    Else
       GMENLOC(G301CPT) = 1
       Actzo [M:CNX1]FLGLNKPLN(nolign-1)
    Endif
 Endif

  If G_ACTIAS      <> G_OUI   : GMENLOC(G301IAS)  = 1  : Endif
  If G_ACTGRT      <> G_OUI   : GMENLOC(G301SUB)  = 1  : Endif
  If [M:FPC]FLGIAS <> G_OUI  :  GMENLOC(G301IAS)  = 1  : Endif

  Affzo  [M:CNX1]FLGLNKPLN(nolign-1)
  Affzo  [M:CNX1]LNKPLN(nolign-1)

End
########################################
Subprog AM_PLNCAA(VALEUR)
Variable Integer VALEUR
Local Integer N_I
Local Integer L_BCO   :   L_BCO = G_NON

  If ( VALEUR > 0 )  and ( [M:CNX1]PLNMGTSV(nolign-1) <> G_OUI )
     [M:CNX1]LNKPLN(nolign-1)=0
     Affzo [M:CNX1]LNKPLN(nolign-1)
     #----------------------------------------------------------------
     # Contrôler que le plan n'existe pas déjà :
     #   1°) sur une autre ligne pour ce contexte
     #   2°) sur un autre contexte pour la même société
     #----------------------------------------------------------------
     For N_I = 1 To [M:CNX1]NBPLC-1
        I= find(VALEUR,[M:CNX1]PLNCAA(0..14))
        If I > 0  & I <> nolign
           # Ce plan est déjà défini à la ligne
           GMENLOC(VALEUR)=1
           GMESSAGE = mess(212,GML_MSGFASPR,1)- ": "+num$(I)   : GERR     = 1
           mkstat   = 2 : End
        Endif
       # ------------------------------
       # Suite de la boucle
     Next N_I

     If GERR <> 1
        For [CNX] Where CPY=[M:CNX0]CPY
           Read [CNX]
           If fstat = 0
              If find(VALEUR,[F:CNX]PLNCAA(0..14))
                 # Ce plan est déjà géré pour le contexte
                 GMENLOC(VALEUR)=1
                 GMESSAGE = mess(213,GML_MSGFASPR,1)- ": "+mess([F:CNX]CNX,3100,1)   : GERR     = 1
                 mkstat   = 2 : End #CHECK IGNORE_LINE
              Endif
           Endif
        Next
       If [M:CNX0]CNX  <> G300CPFI
           If VALEUR = G301CPT or VALEUR = G301FIS or VALEUR = G301MIN or VALEUR = G301SUB
             #"Ce plan ne peut faire partie que du contexte comptable et fiscal"
             GMESSAGE = mess(218,GML_MSGFASPR,1)   :  GERR     = 1
             mkstat   = 2 : End
           Endif
       Endif
     Endif
     [M:CNX1]PLNMGT(nolign-1)    =  G_OUI     :   Affzo [M:CNX1]PLNMGT(nolign-1)
     [M:CNX1]PLNMGTSV(nolign-1)  =  G_NON     :   Affzo [M:CNX1]PLNMGTSV(nolign-1)
     Call AM_PLNMGT(G_OUI)
   Endif

   If VALEUR <> G301SUB
      # Si on est en création et qu'il y a des biens sur la société on active le plan modèle
      For [FAS]FAS1 Hint Key FAS1 Where CPY=[M:CNX0]CPY
        Actzo [M:CNX1]PLNMODFLG
        L_BCO = G_OUI
        Break
        # --------------
        # Suite de la boucle
      Next
   Endif

   If L_BCO <> G_OUI
      [M:CNX1]PLNMODFLG  = G_NON   :   Diszo [M:CNX1]PLNMODFLG
      [M:CNX1]PLNMOD     = 0       :   Diszo [M:CNX1]PLNMOD
   Endif

   [M:CNX1]LNKPLN(nolign-1)=0
   If nolign=1
     Diszo [M:CNX1]LNKPLN(nolign-1)
   Endif
   Affzo [M:CNX1]LNKPLN(nolign-1)

End
########################################
Subprog C_PLNCAA(VALEUR)
Variable Integer VALEUR
Local Integer NOL

If  [M:CNX1]PLNCAA(nolign-1) < 1
   mkstat = 2 : End
Endif

End
########################################
Subprog AP_PLNCAA(VALEUR)
Variable Integer VALEUR

If  [M:CNX1]PLNCAA(nolign-1) < 1
   mkstat = 2 : End
Endif

If ( [M:CNX0]CNX = G300CPFI ) & ( VALEUR = 1 )
 Diszo [M:CNX1]PLNCAA(nolign-1) : Affzo [M:CNX1]PLNCAA(nolign-1)
Endif

If VALEUR <> [M:CNX1]PLNCAA(nolign-1) and ( VALEUR > 0 )
  If VALEUR <> G301CPT
     [M:CNX1]PLNSTD(nolign-1)=GVML_NPSTD
   Else
     [M:CNX1]PLNSTD(nolign-1)=GVML_NPCRC
   Endif
   Actzo  [M:CNX1]PLNSTD(nolign-1) :    Affzo  [M:CNX1]PLNSTD(nolign-1)
Endif

Call AM_PLNCAA(VALEUR)

End
########################################
Subprog AM_PLNMGT(VALEUR)
Variable Integer VALEUR

Local Integer L_BCO : L_BCO = G_NON

  If GREP = "M"
     If VALEUR = G_OUI & [M:CNX1]PLNMGTSV(nolign-1) <> G_OUI
        G_ADDPLN = G_OUI
        [M:CNX1]PLNMGT(nolign-1) = VALEUR
        Call AP_CUR([M:CNX1]CUR)
        If [M:CNX1]PLNCAA(nolign-1)<> G301SUB
           # Si il a  des biens sur la société et qu'il ne s'agit pas d'un plan de subvention : on active le plan modèle
           For [FAS]FAS1 Hint Key FAS1 Where CPY=[M:CNX0]CPY
              Actzo [M:CNX1]PLNMODFLG : Affzo [M:CNX1]PLNMODFLG
              [M:CNX1]PLNMOD      = 0    #Fq-67828 Actzo [M:CNX1]PLNMOD
              L_BCO    = G_OUI
              Break
              # --------------
              # Suite de la boucle
           Next
        Endif
        If L_BCO <> G_OUI
           [M:CNX1]PLNMODFLG  = G_NON   :   Diszo [M:CNX1]PLNMODFLG
           [M:CNX1]PLNMOD     = 0       :   Diszo [M:CNX1]PLNMOD
        Endif
     Elsif VALEUR <> G_OUI and [M:CNX1]PLNMGTSV(nolign-1) = G_OUI
        # On décoche la gestion des flux, ils seront éventuellement supprimés à la validation
        [M:CNX1]FLUTRATXS(nolign-1) = ""
        [M:CNX1]FLUTRAACC(nolign-1) = G_NON
        Affzo [M:CNX1]FLUTRATXS(nolign-1),FLUTRAACC(nolign-1)
     Endif
  Endif

End
########################################
Subprog AS_ORIBASDPR(VALEUR)
Variable Integer VALEUR

Local Integer WIAS : WIAS=G_NON

  If [M:CNX0]CNX  = G300CPFI &
&   ( [M:CNX1]PLNCAA(nolign-1)  = G301CPT or  [M:CNX1]PLNCAA(nolign-1) = G301FIS or
&     [M:CNX1]PLNCAA(nolign-1)  = G301MIN )
      GMENLOC(2) = 1
      GMENLOC(3) = 1
      GMENLOC(4) = 1
   Endif

   If  [M:CNX1]PLNCAA(nolign-1)=G301IAS
      GMENLOC(1) = 1
      GMENLOC(3) = 1
      GMENLOC(4) = 1
   Endif

   If  [M:CNX1]PLNCAA(nolign-1)=G301SUB
      GMENLOC(1) = 1
      GMENLOC(2) = 1
      GMENLOC(4) = 1
   Else
      GMENLOC(3) = 1
   Endif

If  [M:CNX1]PLNCAA(nolign-1) <> G301IAS
 #·Si le plan « IAS » n’est pas créé sur la société : on ne présente pas la base "IAS"
  For [CNX]CNX0 Where CPY=[M:CNX0]CPY
     If (!find(G301IAS,[F:CNX]PLNCAA(0..14))) and (!find(G301IAS,[M:CNX1]PLNCAA(0..14)))
        WIAS  = G_NON
     Else
        WIAS  = G_OUI  : Break
     Endif
  Next
  If WIAS <> G_OUI
      GMENLOC(2) = 1
  Endif
Endif
   If  [M:CNX1]PLNCAA(nolign-1) < 1
      mkstat = 2 : End
   Endif

End
########################################
Subprog AM_ORIBASDPR(VALEUR)
Variable Integer VALEUR
Local Char    RLED, RCOA, RDEVLED

   If (VALEUR <> [M:CNX1]ORIBASDPR(nolign-1)) and ([M:CNX1]PLNMGTSV(nolign-1)= G_OUI)
      G_MODCNX = G_OUI
   Endif

  If ( GREP = "M" )  &
&     [M:CNX1]PLNMGT(nolign-1)   = G_OUI &
&     [M:CNX1]PLNMGTSV(nolign-1) <> G_OUI
     # On crée un nouveau plan dans un contexte existant
     If  [M:CNX1] FLGCNXUO <> G_OUI  & [M:CNX1]PLNCAA (nolign-1) <> G301SUB
        #[M:CNX1]PLNMODFLG        = G_OUI
         Actzo [M:CNX1]PLNMODFLG : Affzo [M:CNX1]PLNMODFLG
        #Fq-67828 Actzo [M:CNX1]PLNMOD
        #Fq-67828 If VALEUR = GVML_OBPCG & [M:CNX1]PLNCAA(nolign-1) <> G301CPT
        #Fq-67828   [M:CNX1]PLNMOD = G301CPT
        #Fq-67828 Else
        #Fq-67828   If VALEUR = GVML_OBIAS & [M:CNX1]PLNCAA(nolign-1) <> G301IAS
        #Fq-67828      [M:CNX1]PLNMOD = G301IAS
        #Fq-67828   Else
        #Fq-67828      [M:CNX1]PLNMOD = G301CPT
        #Fq-67828   Endif
        #Fq-67828 Endif
        #Fq-67828 Affzo [M:CNX1]PLNMOD
        #Fq-67828 Actzo [M:CNX1]PLNMOD
     Else
        If [M:CNX1]PLNCAA(nolign-1)= G301FIS
           # maj des Plans de Production s'il en existe pour ce contexte
           Local Char MESSA(255)
           Local Integer OK
           #Si des biens sont en mode UO sur le plan modèle, ils auront un mode SA sur le plan fiscal
           MESSA  = mess(240,GML_MSGFASPR,1)
           Call AVERTIR(MESSA,OK) From GESECRAN
           OK-=1
           If OK=0 :   End : Endif
           [M:CNX1]PLNMODFLG   = G_NON  :    Diszo [M:CNX1]PLNMODFLG
           [M:CNX1]PLNMOD      = 0      :    Diszo [M:CNX1]PLNMOD
        Endif
     Endif
     Local Integer L_BCO : L_BCO = G_NON
     If  [M:CNX1]PLNCAA(nolign-1) <> G301SUB
        # Si on est en création et qu'il y a des biens sur la société on active le plan modèle
        For [FAS]FAS1 Hint Key FAS1 Where CPY=[M:CNX0]CPY
           Actzo [M:CNX1]PLNMODFLG
           [M:CNX1]PLNMOD = 0 : Diszo [M:CNX1]PLNMOD
           L_BCO = G_OUI
           Break
           # --------------
           # Suite de la boucle
        Next
     Endif
#*Fq-57476
      If L_BCO = G_NON
         [M:CNX1]PLNMODFLG  = G_NON   :   Diszo [M:CNX1]PLNMODFLG
         [M:CNX1]PLNMOD     = 0       :   Diszo [M:CNX1]PLNMOD
      Else   #Attention, vous n'avez pas saisi de plan modèle : Confirmez-vous ce choix ?
         Local Integer LOK
         Call OUINON(mess(241,GML_MSGFASPR,1), LOK) From GESECRAN
         If ( LOK = G_OUI)  : End : Endif
         [M:CNX1]PLNMODFLG   = G_OUI  :    Actzo [M:CNX1]PLNMODFLG  : Affzo [M:CNX1]PLNMODFLG
         Actzo [M:CNX1]PLNMOD    : Affzo [M:CNX1]PLNMOD
         zonsui="[M:CNX1]PLNMOD"
      Endif

  Endif

#*Fq-57476  Call AM_PLNMOD([M:CNX1]PLNMOD)

#Fq61384-Pas d'alimentation du référentiel
# L'alimentation auto du référentiel est déplacé dans l'étiquette AP_ORIBASDPR afn qu'elle soit exécutée
# systèmatiquement.
# # Alimentation du référentiel
#
#  If VALEUR<>GVML_OBSAI
#   Local Integer LLEDTYP, I_LED
#   Case VALEUR
#    When GVML_OBPCG : LLEDTYP=1
#    When GVML_OBSUB : LLEDTYP=1
#    When GVML_OBIAS : LLEDTYP=3
#    When Default    : LLEDTYP=1
#   Endcase
#   [M:CNX1]LEDTYP(nolign-1)=LLEDTYP
#   Call  LECLED([M:CNX0]CPY,[M:CNX1]LEDTYP(nolign-1),RLED,RDEVLED) From CPTDIV
#   If RLED <> ""
#    [M:CNX1]LED(nolign-1)=RLED
#     Call LECPLAN([M:CNX0]CPY,[M:CNX1]LEDTYP(nolign-1),RCOA) From CPTDIV
#    [M:CNX1]COA(nolign-1)= RCOA
#   Endif
#   Grizo [M:CNX1]LEDTYP(nolign-1)
#   Grizo [M:CNX1]LED(nolign-1)
#  Else
#   Actzo [M:CNX1]LEDTYP(nolign-1)
#   Diszo [M:CNX1]LED(nolign-1)
#  Endif

End

######################################################################################
Subprog AP_ORIBASDPR(VALEUR)
Variable Integer VALEUR

  Local Char    RLED, RCOA, RDEVLED

  # Alimentation du référentiel
  If VALEUR <> GVML_OBSAI
     Local Integer LLEDTYP, I_LED
     Case VALEUR
        When GVML_OBPCG : LLEDTYP=[M:FPC]GENLEDTYP
        When GVML_OBSUB : LLEDTYP=[M:FPC]GENLEDTYP
        When GVML_OBIAS : LLEDTYP=[M:FPC]IASLEDTYP
        When Default    : LLEDTYP=[M:FPC]GENLEDTYP
     Endcase
    # Fin FQ65632
    [M:CNX1]LEDTYP(nolign-1)=LLEDTYP
    Call  LECLED([M:CNX0]CPY,[M:CNX1]LEDTYP(nolign-1),RLED,RDEVLED) From CPTDIV
    If RLED <> ""
       [M:CNX1]LED(nolign-1)=RLED
       Call LECPLAN([M:CNX0]CPY,[M:CNX1]LEDTYP(nolign-1),RCOA) From CPTDIV
      [M:CNX1]COA(nolign-1)= RCOA
    Endif
    Grizo [M:CNX1]LEDTYP(nolign-1)
    Grizo [M:CNX1]LED(nolign-1)
    Local Integer RERROR
    If GFRADGI = G_OUI and ( [M:CNX1]LEDTYP(nolign-1) <> [M:CNX1]LEDTYP(0) )
       #"Ce plan doit figurer dans un autre contexte car il est géré par un référentiel différent du référentiel."
       GERR=1   :  GMESSAGE = mess(268,GML_MSGFASPR,1)-" "-num$([M:CNX1]LED(0))
       mkstat=2 : End
    Endif
    # 70465 Alimentation auto des exercices/périodes
    If GFRADGI=G_OUI  and  nolign=1
       Gosub CRE_EXE_PER From SUBCNX2
    Endif
  Else
     Actzo [M:CNX1]LEDTYP(nolign-1)
     Diszo [M:CNX1]LED(nolign-1)
  Endif
  Affzo [M:CNX1]LEDTYP(nolign-1)

End
######################################################################################
Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
 Local Integer I
 For I=1 To 10
  If I<>GVML_TLSOC & I<>GVML_TLIAS
   GMENLOC(I)=1
  Endif
 Next I
End

###################################
Subprog AM_LEDTYP(VALEUR)
Variable Integer VALEUR

Local Integer RERROR
 If GFRADGI=G_OUI
   If nolign > 1 and VALEUR <> [M:CNX1]LEDTYP(0)
      #  Call COMP_DECOUP_CPTA ([M:CNX0]CPY, [M:CNX1]LEDTYP(0), VALEUR, RERROR) From SUBCNX2
      # Endif
      #
      # If RERROR
      #  #Le découpage comptable de ce référentiel n'est pas identique à celui des autres référentiels du contexte.
      #  GERR=1   :  GMESSAGE = mess(266,GML_MSGFASPR,1)
      #  mkstat=2 : End
      #"Ce plan doit figurer dans un autre contexte car il est géré par un référentiel différent du référentiel"
      GERR=1   :  GMESSAGE = mess(268,GML_MSGFASPR,1)-" "-num$([M:CNX1]LED(0))
      mkstat=2 : End
   Endif
 Endif

 [M:CNX1]LED(nolign-1)=[M:FPC]LED(VALEUR-1)
 [M:CNX1]COA(nolign-1)=[M:FPC]COA(VALEUR-1)

 [M:CNX1]LEDTYP(nolign-1)=VALEUR

 # 70465 Alimentation auto des exercices/périodes
 If GFRADGI=G_OUI and nolign=1
   Gosub CRE_EXE_PER From SUBCNX2
 Endif
End

###################################
Subprog AS_PLNSTD(VALEUR)
Variable Integer VALEUR
Local Integer IS_MODIFIABLE : IS_MODIFIABLE=G_NON

If  [M:CNX1]PLNCAA(nolign-1) < 1
   mkstat = 2 : End
Endif
 # S/P définit si la zone est saisissable ou non et, si elle l'est,
 # les valeurs posibles
 # La zone est toujours accessible en création ou en duplication
Read[CPY]CPY0=[M:CNX0]CPY
If fstat=0
   G_PAYS = [F:CPY]CRY
Endif

 If [M]PLNMGT (nolign-1) = G_OUI &   [M]PLNMGTSV (nolign-1) <> G_OUI
    #If G_PAYS = "FR"      #  Pays = France
    If  [M:FPC]LEG = "FRA"
      Case [M]PLNCAA(nolign-1)
         When G301CPT
                       GMENLOC(GVML_NPIAS)=1
                       [M:CNX1]PLNSTD(nolign-1) = GVML_NPCRC
                       Affzo   [M:CNX1]PLNSTD(nolign-1)
         When G301FIS, G301MIN, G301ORI, G301R76, G301RET
                       [M:CNX1]PLNSTD(nolign-1)  = GVML_NPSTD
                       GMENLOC(GVML_NPCRC)=1
                       GMENLOC(GVML_NPIAS)=1
         When G301SUB
                       [M:CNX1]PLNSTD(nolign-1)  = [M:CNX1]PLNSTD(0)
                       GMENLOC(GVML_NPIAS)=1
         When G301IAS
                       GMENLOC(GVML_NPSTD)=1
                       GMENLOC(GVML_NPCRC)=1
         When G301LI1, G301LI2, G301LI3, G301LI4, G301LI5, G301LI6
                        mkstat=0
         When Default : mkstat=0
      Endcase
    Else
      #  Pays = Etranger
      Case [M]PLNCAA(nolign-1)
         When G301IAS
                       GMENLOC(GVML_NPSTD)=1
                       GMENLOC(GVML_NPCRC)=1
         When Default: GMENLOC(GVML_NPCRC)=1
      Endcase
    Endif

  Else  # en modification
      #  Pays = France
      #If G_PAYS = "FR"
      If [M:FPC]LEG = "FRA"
        Case [M]PLNCAA(nolign-1)
          When G301FIS,  G301MIN, G301ORI, G301R76, G301RET, G301SUB
               mkstat = 0
          When G301CPT
              GMENLOC(GVML_NPIAS)=1
          When G301IAS
             GMENLOC(GVML_NPSTD)=1
             GMENLOC(GVML_NPCRC)=1
          When Default
                mkstat = 0
        Endcase
      Else
        #  Pays = Etranger
        Case [M]PLNCAA(nolign-1)
          When G301IAS
             GMENLOC(GVML_NPSTD)=1
             GMENLOC(GVML_NPCRC)=1
          When Default          :    GMENLOC(GVML_NPCRC)=1
        Endcase
      Endif

   If mkstat = 0
     IS_MODIFIABLE = func SUBCNX2.IS_PLNSTD_MODIFIABLE([M]CPY,[M]CNX)
     If IS_MODIFIABLE=G_OUI
        Case [M:CNX1]PLNSTD(nolign-1)
          When GVML_NPIAS
              GMENLOC(GVML_NPSTD)=1
              GMENLOC(GVML_NPCRC)=1
          When GVML_NPCRC
              GMENLOC(GVML_NPSTD)=1
          When GVML_NPSTD
          When Default
        Endcase
     Elsif IS_MODIFIABLE = G_NON
        mkstat=2
     Elsif IS_MODIFIABLE=-1
     Endif
   Endif
Endif


End
########################################
Subprog AM_PLNSTD(VALEUR)
Variable Integer VALEUR

   If ( VALEUR <> [M:CNX1]PLNSTD(nolign-1) )  and ( [M:CNX1]PLNMGTSV(nolign-1)= G_OUI )
      G_MODCNX = G_OUI
   Endif

End
########################################
Subprog AS_FLGLNKPLN(VALEUR)
Variable Integer VALEUR
   #@fq64544
   If G_ACTLNK=G_OUI
    If func GLOLNK.IS_LNK_POSTED_PLN([M:CNX0]CPY, [M:CNX1]PLNCAA(nolign-1))=G_OUI
     End
    Endif
   Endif
End
########################################
Subprog AS_LNKPLN(VALEUR)
Variable Integer VALEUR

   If  [M:CNX1]PLNCAA(nolign-1) < 1
      mkstat = 2 : End
   Endif

   #@fq64544
   If G_ACTLNK=G_OUI
    If func GLOLNK.IS_LNK_POSTED_PLN([M:CNX0]CPY, [M:CNX1]PLNCAA(nolign-1))=G_OUI
     End
    Endif
   Endif

   If  [M:CNX1]FLGLNKPLN(nolign-1)= G_OUI
      Actzo [M:CNX1]LNKPLN(nolign-1)
   Else
      [M:CNX1]LNKPLN(nolign-1)=0
      Affzo [M:CNX1]LNKPLN(nolign-1)
      Diszo [M:CNX1]LNKPLN(nolign-1)
   Endif

   If [M:CNX1]FLGLNKPLN(nolign-1) = G_OUI
      For I_PLN = 1 To G301MAX
         If  (!find(I_PLN,[M:CNX1]PLNCAA(0..14))) or ( I_PLN = [M:CNX1]PLNCAA(nolign-1))
            GMENLOC(I_PLN) = 1
         Endif
      Next I_PLN
   Endif

End
########################################
Subprog C_LNKPLN(VALEUR)
Variable Integer VALEUR

End
########################################
Subprog AM_LNKPLN(VALEUR)
Variable Integer VALEUR

   If VALEUR <> 0 &  !find([M:CNX1]LNKPLN(nolign-1),[M:CNX1]PLNCAA(0..14))
     #"le plan lié doit être géré dans le même contexte"
     GERR=1   :  GMESSAGE = mess(223,GML_MSGFASPR,1)
     [M:CNX1]FLGLNKPLN(nolign-1)= G_NON
     [M:CNX1]LNKPLN(nolign-1) = 0
     Affzo  [M:CNX1]LNKPLN(nolign-1)
     zonsui = "[M:CNX1]FLGLNKPLN(nolign-1)"
   Else
      If ( VALEUR <> [M:CNX1]LNKPLN(nolign-1) )  and ( [M:CNX1]PLNMGTSV(nolign-1)= G_OUI )
         G_MODCNX = G_OUI
      Endif
   Endif

End
################################################################################
# Ecran : CNX2 Tableau Exercices
################################################################################

#-------------------------------------------------------------------------------
# Champs du bloc concession :
#-------------------------------------------------------------------------------

#
# Flag d'activation de la gestion des concessions
#----------------------------
Subprog AM_CCNFLG(VALEUR)
Variable Integer VALEUR

 Case VALEUR
  When G_OUI
   Actzo [M:CNX1]CCNMOD     : [M:CNX1]CCNMOD=GVML_GCFIR
  When G_NON
   Effzo [M:CNX1]CCNMOD     : Diszo [M:CNX1]CCNMOD
   Effzo [M:CNX1]CCNGRTFLG  : Diszo [M:CNX1]CCNGRTFLG
   Effzo [M:CNX1]CCNRPRTYP  : Diszo [M:CNX1]CCNRPRTYP
   Effzo [M:CNX1]CCNINDPLN  : Diszo [M:CNX1]CCNINDPLN
   #Fq-XXXXX Effzo [M:CNX1]CCNGRTPLN  : Diszo [M:CNX1]CCNGRTPLN
   [M:CNX1]CCNGRTPLN = 0 : Diszo [M:CNX1]CCNGRTPLN
   #Fq-XXXXX Effzo [M:CNX1]CCNCADPLN  : Diszo [M:CNX1]CCNCADPLN
   [M:CNX1]CCNCADPLN  = 0 : Diszo [M:CNX1]CCNCADPLN
 Endcase
End

#
# Mode de gestion des concessions : 1er bien de la concession ou transmis par renouvellement
#----------------------------

Subprog C_CCNMOD(VALEUR)
Variable Integer VALEUR
 If VALEUR=GVML_GCRNW
  Local Integer LNBPLN : LNBPLN=[M:CNX1]NBPLC
  Local Integer I_PLN, LNBPLNSAI
  For I_PLN=1 To [M:CNX1]NBPLC
   # FQ106989_1
#   If [M:CNX1]ORIBASDPR(I_PLN-1)=GVML_OBSAI & [M:CNX1]PLNCAA(I_PLN-1)<>G301SUB & [M:CNX1]PLNCAA(I_PLN-1)<>G301IAS
#    LNBPLNSAI+=1
#   Elsif [M:CNX1]PLNCAA(I_PLN-1)=G301IAS | [M:CNX1]PLNCAA(I_PLN-1)=G301SUB
#    LNBPLN-=1
#   Endif
   If [M:CNX1]ORIBASDPR(I_PLN-1)=GVML_OBSAI & [M:CNX1]PLNCAA(I_PLN-1)<>G301IAS
    LNBPLNSAI+=1
   Elsif [M:CNX1]PLNCAA(I_PLN-1)=G301IAS
    LNBPLN-=1
   Endif
  Next I_PLN
  LNBPLN-=LNBPLNSAI
  If LNBPLN<2
   GERR=2   :  GMESSAGE = mess(245,GML_MSGFASPR,1) : mkstat=2 : End  #"Définir au moins deux plans (Hors subvention et IAS/IFRS) pour choisir ce mode de gestion"
  Endif
 Endif
End

#----------------------------
Subprog AM_CCNMOD(VALEUR)
Variable Integer VALEUR

 Case VALEUR
  When GVML_GCFIR
   Effzo [M:CNX1]CCNGRTFLG  : Diszo [M:CNX1]CCNGRTFLG
   Effzo [M:CNX1]CCNRPRTYP  : Diszo [M:CNX1]CCNRPRTYP
   #Fq-XXXXX Effzo [M:CNX1]CCNINDPLN  : Diszo [M:CNX1]CCNINDPLN
   #FQ-XXXXX Effzo [M:CNX1]CCNGRTPLN  : Diszo [M:CNX1]CCNGRTPLN
   [M:CNX1]CCNGRTPLN = 0  : Diszo [M:CNX1]CCNGRTPLN
   #FQ-XXXXXEffzo [M:CNX1]CCNCADPLN  : Diszo [M:CNX1]CCNCADPLN
   [M:CNX1]CCNCADPLN = 0  : Diszo [M:CNX1]CCNCADPLN
  When GVML_GCRNW
   Actzo [M:CNX1]CCNGRTFLG  : [M:CNX1]CCNGRTFLG = G_NON
  #Actzo [M:CNX1]CCNRPRTYP  : [M:CNX1]CCNRPRTYP = GVML_CPFIS : Affzo [M:CNX1]CCNRPRTYP
   Actzo [M:CNX1]CCNRPRTYP  : [M:CNX1]CCNRPRTYP = GVML_CPCPT : Affzo [M:CNX1]CCNRPRTYP
   Actzo [M:CNX1]CCNINDPLN  : [M:CNX1]CCNINDPLN = G301CPT    : Affzo [M:CNX1]CCNINDPLN
   #Fq-XXXXX Diszo [M:CNX1]CCNGRTPLN
   [M:CNX1]CCNGRTPLN = 0  : Diszo [M:CNX1]CCNGRTPLN
   Actzo [M:CNX1]CCNCADPLN
   Local Integer I_PLN
   For I_PLN=2 To [M:CNX1]NBPLC
    If [M:CNX1]PLNCAA(I_PLN-1)<>G301IAS & [M:CNX1]PLNCAA(I_PLN-1)<>G301SUB & [M:CNX1]ORIBASDPR(I_PLN-1)<>GVML_OBSAI &
&      [M:CNX1]PLNCAA(I_PLN-1)<>G301FIS
     [M:CNX1]CCNCADPLN = [M:CNX1]PLNCAA(I_PLN-1) : Affzo [M:CNX1]CCNCADPLN : Break
    Endif
   Next I_PLN
   #Fq69493-Si on a que les plans comptable et fiscal, on met le comptable dans caducité et fiscal dans industriel
   If find(G301FIS,[M:CNX1]PLNCAA) & [M:CNX1]CCNCADPLN=G301CPT
    [M:CNX1]CCNINDPLN = G301FIS : Affzo [M:CNX1]CCNINDPLN
    [M:CNX1]CCNCADPLN = G301CPT : Affzo [M:CNX1]CCNCADPLN
   Endif
 Endcase

End
#----------------------------
Subprog AM_CCNGRTFLG(VALEUR)
Variable Integer VALEUR

    If VALEUR=G_OUI
     Local Integer LNBPLN : LNBPLN=[M:CNX1]NBPLC
     If find(G301IAS,[M:CNX1]PLNCAA) : LNBPLN-=1 : Endif
     # FQ106989_1 If find(G301SUB,[M:CNX1]PLNCAA) : LNBPLN-=1 : Endif
     If LNBPLN<3
      GERR=2   :  GMESSAGE = mess(246,GML_MSGFASPR,1) : mkstat=2 : End # "Définir au moins trois plans (Hors subvention et IAS/IFRS) pour activer la gestion des subventions"
     Endif
      # FQ106989_1 Local Integer LPLN_OBSAI
      Local Integer LPLN_OBSAISUB : LPLN_OBSAISUB = 0
      For I_PLN=1 To [M:CNX1]NBPLC
      # FQ106989_1 If [M:CNX1]PLNCAA(I_PLN-1)<>G301IAS & [M:CNX1]PLNCAA(I_PLN-1)<>G301SUB &
      If [M:CNX1]PLNCAA(I_PLN-1)<>G301IAS &
&      [M:CNX1]PLNCAA(I_PLN-1)<>[M:CNX1]CCNINDPLN & [M:CNX1]PLNCAA(I_PLN-1)<>[M:CNX1]CCNCADPLN
          If [M:CNX1]PLNCAA(I_PLN-1)<>G301IAS &
&            [M:CNX1]PLNCAA(I_PLN-1)<>[M:CNX1]CCNINDPLN & [M:CNX1]PLNCAA(I_PLN-1)<>[M:CNX1]CCNCADPLN
             #Fq-63155 [M:CNX1]ORIBASDPR(I_PLN-1)=GVML_OBSAI : LPLN_OBSAI=1
             # FQ106989_1 If  [M:CNX1]ORIBASDPR(I_PLN-1)=GVML_OBSAI  : LPLN_OBSAI=1
             If  find([M:CNX1]ORIBASDPR(I_PLN-1), GVML_OBSAI, GVML_OBSUB) > 0  : LPLN_OBSAISUB =1
               Actzo [M:CNX1]CCNGRTPLN : [M:CNX1]CCNGRTPLN=[M:CNX1]PLNCAA(I_PLN-1) : Affzo [M:CNX1]CCNGRTPLN
               Break
             Endif
          Endif
       Endif
      Next I_PLN
      # FQ106989_1 If !LPLN_OBSAI
      If !LPLN_OBSAISUB
       GERR=2   :  GMESSAGE = mess(247,GML_MSGFASPR,1) : mkstat=2 : End # "Définir un plan dont l'origine base d'amortissement est à saisir pour activer la gestion des subventions"
      Endif
    Else
#Fq-XXXXX      Effzo [M:CNX1]CCNGRTPLN
#Fq-XXXXX      Diszo [M:CNX1]CCNGRTPLN
     [M:CNX1]CCNGRTPLN = 0  : Diszo [M:CNX1]CCNGRTPLN
    Endif

End
#----------------------------
Subprog AS_CCNINDPLN(VALEUR)
Variable Integer VALEUR
 Local Char LCCNPLN : LCCNPLN="IND"
 Gosub FILTRE_PLAN_CCN From SUBCNX2
End

#----------------------------
Subprog AS_CCNGRTPLN(VALEUR)
Variable Integer VALEUR
 Local Char LCCNPLN : LCCNPLN="GRT"
 Gosub FILTRE_PLAN_CCN From SUBCNX2
End

#----------------------------
Subprog AM_CCNGRTPLN(VALEUR)
Variable Integer VALEUR
 Local Integer I_PLN
 I_PLN=find(VALEUR,[M:CNX1]PLNCAA)
 # FQ106989
 # If I_PLN & [M:CNX1]ORIBASDPR(I_PLN-1)<>GVML_OBSAI
 If I_PLN & [M:CNX1]ORIBASDPR(I_PLN-1)<>GVML_OBSAI & [M:CNX1]ORIBASDPR(I_PLN-1)<>GVML_OBSUB
  GERR     = 1
  GMESSAGE = mess(251,GML_MSGFASPR,1) # "L'origine base d'amortissement de ce plan n'est pas : A saisir"
  mkstat   = 2
  End
 Endif
End

#----------------------------
Subprog AS_CCNCADPLN(VALEUR)
Variable Integer VALEUR
 Local Char LCCNPLN : LCCNPLN="CAD"
 Gosub FILTRE_PLAN_CCN  From SUBCNX2
End
########################################
Subprog AFFICHE_PERIODE()
Local Integer N_I, N_E

  Call CALCUL_TOTAUX2 (3, -1) From SUBCNX2
  [M:CNX2]NBPER2 = 0
  Call ACTION_BLOCK (ACB_EFFZO, "CNX2", "DATSTRPER") From GLOBIENS

  If [M:CNX2]NBRPER([M:CNX3]YEACLICK-1) > 0
    N_E = 1
    Sorta [M:CNX3]NBPERC [M:CNX3]NBPERC Order By [M:CNX3]INDFISYEA(indice), [M:CNX3]DATSTRPER(indice)
    Call CONTROLE_LIGNE_VIDE() From SUBCNX2 #Fq67417
    For N_I = 1 To [M:CNX3]NBPERC
      # ------------------
      If [M:CNX3]INDFISYEA(N_I-1) = [M:CNX3]YEACLICK
&       and [M:CNX3]DATSTRPER(N_I-1) <> [0/0/0] and [M:CNX3]DATENDPER(N_I-1) <> [0/0/0]
        [M:CNX2]INDCNX3(N_E-1)       = N_I
        [M:CNX2]DATSTRPER(N_E-1)     = [M:CNX3]DATSTRPER(N_I-1)
        [M:CNX2]DATENDPER(N_E-1)     = [M:CNX3]DATENDPER(N_I-1)
        [M:CNX2]DATENDPERS(N_E-1)    = [M:CNX3]DATENDPERS(N_I-1)
        [M:CNX2]NBRMONPER(N_E-1)     = [M:CNX3]NBRMONPER(N_I-1)
        [M:CNX2]NBRWEKPER(N_E-1)     = [M:CNX3]NBRWEKPER(N_I-1)
        [M:CNX2]NBRDAYPER(N_E-1)     = [M:CNX3]NBRDAYPER(N_I-1)
        [M:CNX2]STAPER(N_E-1)        = [M:CNX3]STAPER(N_I-1)
        [M:CNX2]TYPPST(N_E-1)        = [M:CNX3]TYPPST(N_I-1)
       #[M:CNX2]LSTTYPPRO(N_E-1)     = [M:CNX3]LSTTYPPRO(N_I-1)#Fq67417
        If [M:CNX1]FLGCNXUO = G_OUI
           Filter[PPH]Where CPY = [M:CNX0]CPY & CNX = [M:CNX0]CNX
              For[PPH]
              If !(fstat)
                 #Read[PLP]PLP0 = [F:PPH]PROPLN; [M:CNX2]DATENDFIY([M:CNX3]YEACLICK-1) ;[M:CNX2]DATENDPER(N_E-1) : # FQ68726
                 #Fq70608
                 Read[PPL]PPL0 = [F:PPH]PROPLN; [M:CNX2]DATENDFIY([M:CNX3]YEACLICK-1) ;[M:CNX2]DATENDPER(N_E-1)
                 If !(fstat)
                    [M:CNX2]RSDQTY(N_E-1) +=  [F:PPL]RSDQTY
                    [M:CNX2]EXTQTY(N_E-1) +=  [F:PPL]EXTQTY
                    [M:CNX2]CPLQTY(N_E-1) +=  [F:PPL]CPLQTY
                    [M:CNX2]FIYQTY(N_E-1) +=  [F:PPL]FIYQTY
                 Endif
            Endif
           Next
           Filter[PPH]
        Endif
        Call CALCUL_TOTAUX2 (2, N_E) From SUBCNX2
        N_E += 1
      Endif
      # ------------------
      # Suite de la boucle
    Next N_I

    [M:CNX2]NBPER2 = N_E - 1
    Call AFFICHE_TOTAUX3()   From SUBCNX2
  Endif

End
########################################
Subprog AVANT_NBFIY
Local Integer N_I, N_E

  # Valeurs par défaut de la ligne
  If varinit([M:CNX2]FLGFIYPRO, nolign-1) = 0
    [M:CNX2]FLGFIYPRO(nolign-1) = G_NON        : # NON    Exercice manuel
    Affzo [M:CNX2]FLGFIYPRO(nolign-1)
  Endif

  If GREP <> "C"
     GBOUT1= ""
     GBOUT2= ""
  Endif

  If varinit([M:CNX2]STAFIY, nolign-1) = 0
    [M:CNX2]STAFIY(nolign-1) = 0               : # vide   Statut exercice
    Affzo [M:CNX2]STAFIY(nolign-1)
  Endif
  Call COLOR_EXERCICE(nolign) From SUBCNX2

  #70465 Voir si le paramètre ACCPERCTL est à "Oui"
  If GFRADGI=G_OUI
     If GREP="C"
        Gosub CRE_EXE_PER From SUBCNX2
     Endif
      Diszo [M:CNX2]DATSTRFIY
      Diszo [M:CNX2]DATENDFIY
      Diszo [M:CNX2]DATSTRPER
      Diszo [M:CNX2]DATENDPER
      Diszo [M:CNX2]NBRMONPER
      Diszo [M:CNX2]NBRWEKPER
      Diszo [M:CNX2]NBRDAYPER
      Actzo [M:CNX2]TYPPST :   Affzo [M:CNX2]TYPPST
      Disable 65 : # status Suppression ligne
      Disable 73 : # status insertion ligne
      GBOUT1=""
      GBOUT2=""
      GBOUT3=""
      GBOUT4=""
      GBOUT5=""
   Else
      Enable 65 : # status Suppression ligne
      Enable 73 : # status insertion ligne
   Endif


End
########################################
Subprog C_NBFIY

  If status>=61 and status<=90

  Endif
End

########################################
Subprog AS_NBFIY

  If nolign >= [M]NBFIY
    # Si on est sur la dernière ligne on ne peut pas dire que c'est l'exercice courant
    GBOUT1 = ""
  Endif

  #Fq-73079 If GREP <> "C"
  If GREP <> "C"   or GFRADGI = G_OUI
    # On ne peut définir l'exercice courant qu'en création/duplication
    # On ne peut définir le découpage identique au découpage comptable qu'en création/duplication
    GBOUT1 = ""
    GBOUT2 = ""        #*Fq-62537
  Endif

  # S'il y a des périodes, on les recopie dans le tableaux CNX2
  If nolign > 0
     [M:CNX3]YEACLICK = nolign
  Else
      [M:CNX3]YEACLICK = 1
  Endif
  Call AFFICHE_PERIODE()
  Call ACTION_BLOCK (ACB_AFFZO, "CNX2", "DATSTRPER") From GLOBIENS

   #70465 Voir si le paramètre ACCPERCTL est à "Oui"
  If GFRADGI=G_OUI
      Diszo [M:CNX2]DATSTRFIY
      Diszo [M:CNX2]DATENDFIY
      Disable 65 : # status Suppression ligne
      Disable 73 : # status insertion ligne
      GBOUT1=""
      GBOUT2=""
      GBOUT3=""
      GBOUT4=""
      GBOUT5=""
  Else
      Enable 65 : # status Suppression ligne
      Enable 73 : # status insertion ligne
  Endif

End
########################################
Subprog B1_NBFIY
# Bouton fixe l'exercice en cours
Local Integer N_I

  # on interdit l'action s'il n'y a pas d'exercice après
  If nolign = [M]NBFIY
    # L'exercice courant ne peut être le dernier de la liste
    GMESSAGE = mess(1,GML_MSGFASPR,1) :  GERR  = 1
    End
  Endif

  # on efface tout ce qui est déjà défini et on clos ceux qui précèdent le futur courant
  For N_I=1 To [M:CNX2]NBFIY
    If N_I < nolign
      [M:CNX2]STAFIY(N_I-1) = GVML_TEPREC   : # Clos
    Else
      [M:CNX2]STAFIY(N_I-1) = 0             : # vide
    Endif
  Next N_I
  [M:CNX2]STAFIY(nolign-1)   = GVML_TECOURA   : # Courant
  [M:CNX2]STAFIY(nolign)     = GVML_TESUIV    : # Suivant
  [M:CNX2]STAFIY(nolign+1)   = GVML_TESUIV2   : # Suivant2
  Call ACTION_BLOCK (ACB_AFFZO, "CNX2", "NBFIY") From GLOBIENS
  G_MODCNX = G_OUI
End

########################################
Subprog AV_DATSTRFIY(VALEUR)
Variable Date    VALEUR

  Call COLOR_EXERCICE(nolign) From SUBCNX2

  # FQ67615
  If nolign = 1
    Gosub AFFICH_LVA From SUBCNX2
  Endif
End

########################################
Subprog AS_DATSTRFIY(VALEUR)
Variable Date    VALEUR

  If nolign > 1
    mkstat = 2 : End
  Endif

End
########################################
Subprog AS_DATENDFIY(VALEUR)
Variable Date    VALEUR

  # La fin d'exercice n'est pas modifiable sur un exercice clos
  If [M:CNX2]STAFIY(nolign-1) = GVML_TEPREC
    mkstat = 2 : End
  Endif

  # La fin d'exercice n'est pas modifiable si l'exercice suivant est clos
  If nolign < [M:CNX2]NBFIY
    If [M:CNX2]STAFIY(nolign) = GVML_TEPREC
      mkstat = 2 : End
    Endif
  Endif

  # Sur les lignes>1 la date de début d'exercice est la fin du précédent + 1
  If nolign > 1
    [M:CNX2]DATSTRFIY(nolign-1) = [M:CNX2]DATENDFIY(nolign-2) + 1
    Affzo [M:CNX2]DATSTRFIY(nolign-1)
    # --------------------------------
    If day([M:CNX2]DATSTRFIY(nolign-1)) = day([M:CNX2]DATSTRFIY(nolign-2))
&      and month([M:CNX2]DATSTRFIY(nolign-1)) = month([M:CNX2]DATSTRFIY(nolign-2))
      # Si la date (JJMM) debut exercice nolign-1 = celle nolign-2, la date de fin JJMM est la même pour la bonne année
      [M:CNX2]DATENDFIY(nolign-1) = gdat$(day([M:CNX2]DATENDFIY(nolign-2)), month([M:CNX2]DATENDFIY(nolign-2)), year([M:CNX2]DATENDFIY(nolign-2))+1)
      Affzo [M:CNX2]DATENDFIY(nolign-1)
    Else
      # Sinon on propose 12 mois à partir du début de l'exercice nolign-1
      [M:CNX2]DATENDFIY(nolign-1) = gdat$(day(DATSTRFIY(nolign-1))-1, month(DATSTRFIY(nolign-1))+12, year(DATSTRFIY(nolign-1)))
      Affzo [M:CNX2]DATENDFIY(nolign-1)
    Endif
  Else
    # On propose 12 mois à partir du début de l'exercice nolign-1
    [M:CNX2]DATENDFIY(nolign-1) = gdat$(day(DATSTRFIY(nolign-1))-1, month(DATSTRFIY(nolign-1))+12, year(DATSTRFIY(nolign-1)))
    Affzo [M:CNX2]DATENDFIY(nolign-1)
  Endif
End

########################################
Subprog AM_DATENDFIY(VALEUR)
Variable Date    VALEUR

   If  nolign > [M]NBFIY
      G_NEWFIY  = 1
      G_ENDFIY  = VALEUR
      G_STRFIY  = [M:CNX2]DATSTRFIY(nolign-1)
      G_MODCNX  = G_OUI
   Else
      G_NEWFIY=0
   Endif

  [M:CNX2]DATENDFIY(nolign-1) = VALEUR

  # Si on modifie la date de fin d'exercice, on dit que l'exercice n'est pas calculé
  If nolign-1 < [M]NBFIY
    If [M:CNX2]DATSTRFIY(nolign) <> VALEUR+1
      [M:CNX2]DATSTRFIY(nolign) = VALEUR + 1
      Affzo [M:CNX2]DATSTRFIY(nolign)
    Endif
  Endif
  If (nolign >= 2) &  ([M:CNX2]STAFIY(nolign-2)= GVML_TESUIV)
     [M:CNX2]STAFIY(nolign-1)= GVML_TESUIV2
     Affzo [M:CNX2]STAFIY(nolign-1)
  Endif

   If VALEUR <>   [M:CNX2]DATENDFIY(nolign-1)
       G_MODCNX = G_OUI
       G_CMENDFIY = 1
       [M:CNX2]DATENDFIY(nolign-1) = VALEUR
      Affzo [M:CNX2]DATENDFIY(nolign)
    Endif

End
########################################
Subprog C_DATENDFIY(VALEUR)
Variable Date    VALEUR

  If VALEUR <= [M]DATSTRFIY(nolign-1)
    # La date de fin doit être supérieure à la date de début
    GMESSAGE = mess(3,GML_MSGFASPR,1) :  GERR  = 1
    mkstat   = 2 : End
  Endif
End

########################################
Subprog AS_RAT39BIS(VALEUR)
Variable Decimal VALEUR

  # Le 39bis n'est accessible que pour le contexte comptable et fiscal
  If [M:CNX0]CNX <> G300CPFI
    mkstat = 2 : End
  Endif

  # Le 39bis n'est pas accessible sur un exercice clos
  If [M:CNX2]STAFIY(nolign-1) = GVML_TEPREC
    mkstat = 2 : End

  Endif
End
Subprog AM_RAT39BIS(VALEUR)
Variable Decimal VALEUR

If VALEUR <>  [M:CNX2]RAT39BIS(nolign-1)
   [M:CNX2]RAT39BIS(nolign-1)= VALEUR : Affzo  [M:CNX2]RAT39BIS(nolign-1)
   G_MODCNX=G_OUI
Endif

End
######################################################################################
Subprog AS_DFDTYP(VALEUR)
Variable Integer VALEUR

Local Integer  I_FIS, I_MIN

 # FQ118563
 If ([M:CNX2]STAFIY(nolign-1) <> GVML_TEPREC)
   I_FIS=find(G301FIS,[M:CNX1]PLNCAA(0..[M:CNX1]NBPLC-1))
   I_MIN=find(G301MIN,[M:CNX1]PLNCAA(0..[M:CNX1]NBPLC-1))

   # FQ-90432 différé espagnol 2013 2014
   If [M:FPC]LEG ="SPA" and [M:CNX0]CNX = G300CPFI and (
&     year([M:CNX2]DATSTRFIY(nolign-1)) = 2013 or year([M:CNX2]DATSTRFIY(nolign-1)) = 2014 or
&     year([M:CNX2]DATENDFIY(nolign-1)) = 2013 or year([M:CNX2]DATENDFIY(nolign-1)) = 2014)

      GMENLOC(GVML_DFBENEF) = 1
      GMENLOC(GVML_DFDEFIC) = 1
      GMENLOC(GVML_DFREPR) = 1
      GMENLOC(GVML_DFD1314) = 0 # différé espagnol 2013 2014 autorisé

      Affzo [M:CNX2]DFDTYP(nolign-1)
      Affzo [M:CNX2]DFDCOD(nolign-1)
      Affzo [M:CNX2]DFDRAT(nolign-1)
      Actzo [M:CNX2]DFDTYP(nolign-1)
      Diszo [M:CNX2]DFDCOD(nolign-1)
      Diszo [M:CNX2]DFDRAT(nolign-1)
   Elsif ( I_FIS=0 ) or ( I_MIN=0 ) or ( [M:CNX2]STAFIY(nolign-1) <> GVML_TECOURA ) or
&     !([M:FPC]LEG ="FRA")
#   If ( I_FIS=0 ) or ( I_MIN=0 ) or ( [M:CNX2]STAFIY(nolign-1) <> GVML_TECOURA ) or
#&     !([M:FPC]LEG ="FRA")
      VALEUR=0
      [M:CNX2]DFDTYP(nolign-1)  = VALEUR
      [M:CNX2]DFDCOD(nolign-1)  = 0
      [M:CNX2]DFDRAT(nolign-1)  = 0
      Diszo [M:CNX2]DFDTYP(nolign-1)
      Diszo [M:CNX2]DFDCOD(nolign-1)
      Diszo [M:CNX2]DFDRAT(nolign-1)
   Else
      # FQ-90432 différé espagnol 2013 2014
      GMENLOC(GVML_DFBENEF) = 0
      GMENLOC(GVML_DFDEFIC) = 0
      GMENLOC(GVML_DFREPR) = 0
      GMENLOC(GVML_DFD1314) = 1 # différé espagnol 2013 2014 interdit

      Affzo [M:CNX2]DFDTYP(nolign-1)
      Affzo [M:CNX2]DFDCOD(nolign-1)
      Affzo [M:CNX2]DFDRAT(nolign-1)
      Actzo [M:CNX2]DFDTYP(nolign-1)
      Actzo [M:CNX2]DFDCOD(nolign-1)
      Actzo [M:CNX2]DFDRAT(nolign-1)
   Endif

   Affzo [M:CNX2]NBFIY
 Endif

End

Subprog AM_DFDTYP(VALEUR)
Variable Integer VALEUR
If VALEUR <>  [M:CNX2]DFDTYP(nolign-1)
#   [M:CNX2]DFDTYP(nolign-1) = VALEUR : Affzo  [M:CNX2]DFDTYP(nolign-1) FQ-90432
   G_MODCNX=G_OUI
Endif

   # FQ-90432 différé espagnol 2013 2014
   If VALEUR = GVML_DFD1314

      [M:CNX2]DFDCOD(nolign-1) = GVML_RGPOURC
      [M:CNX2]DFDRAT(nolign-1) = 30
      Diszo [M:CNX2]DFDCOD(nolign-1)
      Diszo [M:CNX2]DFDRAT(nolign-1)
   Elsif [M:CNX2]DFDTYP(nolign-1) = GVML_DFD1314
      [M:CNX2]DFDCOD(nolign-1) = GVML_RGAUCUN
      [M:CNX2]DFDRAT(nolign-1) = 0
   Endif

End
######################################################################################
Subprog AS_DFDCOD(VALEUR)
Variable Integer VALEUR

# Si type différé = "Différé déficitaire" ou "Différé bénéficiaire"
# ==> Règle = "Pourcentage" (2)  ou "Pas de Dérogatoire" (3)
If [M:CNX2]DFDTYP(nolign-1) =  GVML_DFDEFIC or  [M:CNX2]DFDTYP(nolign-1)= GVML_DFBENEF
   GMENLOC(GVML_RGAUCUN) = 1
   GMENLOC(GVML_RGREPDR) = 1
# FQ-90432
Elsif [M:CNX2]DFDTYP(nolign-1) = GVML_DFD1314
   Diszo [M:CNX2]DFDCOD(nolign-1)
Else
   # Si type différé = "Reprise différée"
   # ==> Règle = "Pourcentage" (2) ou "Reprise sur durée résiduelle" (4)
      If [M:CNX2]DFDTYP(nolign-1) =  GVML_DFREPR
         GMENLOC(GVML_RGAUCUN) = 1
         GMENLOC(GVML_RGNODER) = 1
      Else
         # Si type différé = "Aucun"
         # ==> Règle = "Aucune" (1)
            If [M:CNX2]DFDTYP(nolign-1) =  GVML_DFAUCUN or [M:CNX2]DFDTYP(nolign-1) = 0
               GMENLOC(GVML_RGPOURC) = 1
               GMENLOC(GVML_RGNODER) = 1
               GMENLOC(GVML_RGREPDR) = 1
               Diszo [M:CNX2]DFDRAT(nolign-1)
            Endif
      Endif
Endif

Affzo [M:CNX2]DFDCOD(nolign-1)
Affzo [M:CNX2]DFDRAT(nolign-1)

End
######################################################################################
Subprog AM_DFDCOD(VALEUR)
Variable Integer VALEUR

 If VALEUR <>  [M:CNX2]DFDCOD(nolign-1)
    If VALEUR <> GVML_RGPOURC
       [M:CNX2]DFDRAT(nolign-1) =  0
       Diszo  [M:CNX2]DFDRAT(nolign-1)
    Else
       Actzo  [M:CNX2]DFDRAT(nolign-1)
    Endif
    [M:CNX2]DFDCOD(nolign-1)= VALEUR : Affzo  [M:CNX2]DFDCOD(nolign-1)
    G_MODCNX=G_OUI
 Endif

End
######################################################################################
Subprog AP_DFDCOD(VALEUR)
Variable Integer VALEUR

Call AM_DFDCOD(VALEUR)

End
######################################################################################
Subprog C_DFDCOD(VALEUR)
Variable Integer VALEUR

   If [M:CNX2]DFDTYP(nolign-1) =  GVML_DFDEFIC or  [M:CNX2]DFDTYP(nolign-1)= GVML_DFBENEF
      If  VALEUR <> GVML_RGPOURC &  VALEUR <> GVML_RGNODER
         # "Règle invalide pour ce type différé"
         GMESSAGE = mess(224,GML_MSGFASPR,1) : GERR  = 1
         mkstat   = 2 : End
      Endif
   Endif

   If [M:CNX2]DFDTYP(nolign-1) =  GVML_DFREPR
      If VALEUR <> GVML_RGPOURC &  VALEUR <> GVML_RGREPDR
         #"Règle invalide pour ce type différé"
         GMESSAGE = mess(224,GML_MSGFASPR,1) : GERR  = 1
         mkstat   = 2 : End
      Endif
   Endif

End
##########################################################################
Subprog AS_DFDRAT(VALEUR)
Variable Decimal VALEUR
# FQ-90432
If [M:CNX2]DFDTYP(nolign-1) = GVML_DFD1314
   Diszo [M:CNX2]DFDRAT(nolign-1)
Endif

 If  [M:CNX2]DFDCOD(nolign-1) <> GVML_RGPOURC
   Effzo [M:CNX2]DFDRAT(nolign-1)
   Diszo [M:CNX2]DFDRAT(nolign-1)
 Endif

End
##########################################################################
Subprog C_DFDRAT(VALEUR)
Variable Decimal VALEUR

   If VALEUR = 0 & [M:CNX2]DFDCOD(nolign-1) =  GVML_RGPOURC
      GMESSAGE = mess(225,GML_MSGFASPR,1) : GERR  = 1
      mkstat   = 2 : End
   Else
      If VALEUR <>  0 & [M:CNX2]DFDCOD(nolign-1) <>  GVML_RGPOURC
         Effzo [M:CNX2]DFDRAT(nolign-1)
         Diszo [M:CNX2]DFDRAT(nolign-1)
      Endif
   Endif

End
Subprog AM_DFDRAT(VALEUR)
Variable Decimal VALEUR
    If VALEUR <>  [M:CNX2]DFDRAT(nolign-1)
      [M:CNX2]DFDRAT(nolign-1)= VALEUR : Affzo  [M:CNX2]DFDRAT(nolign-1)
      G_MODCNX=G_OUI
   Endif
End
################################################################################
# Ecran : CNX2 Tableau Périodes
################################################################################
########################################
Subprog PER_CALCUL_PERIODES (P_NB_PER)
# Calcule les différentes périodes en fonction du nombre de périodes passées
Value Integer P_NB_PER

Local Date DATE_DEB_PER
Local Date DDEBNEXTPER
Local Date DATE_FIN_EXE               #Fq-52208
Local Integer MOIS_AJOUT
Local Integer MAX_FOR

  If P_NB_PER = 0
    Call CALCUL_TOTAUX2(3, -1) From SUBCNX2
    Call RAZ_TAB_PER_CUMULE () From SUBCNX2
    Call AFFICHE_TOTAUX3()     From SUBCNX2
  Else
    MOIS_AJOUT = arr (12/P_NB_PER, 0)
    Call CALCUL_TOTAUX2 (3, -1) From SUBCNX2
    Call RAZ_TAB_PER_CUMULE()   From SUBCNX2
    [M:CNX2]NBPER2 = P_NB_PER
    DATE_DEB_PER   = [M:CNX2]DATSTRFIY([M:CNX3]YEACLICK-1)
    DATE_FIN_EXE   = [M:CNX2]DATENDFIY([M:CNX3]YEACLICK-1)    #Fq-52208
    MAX_FOR        = [M:CNX2]NBPER2

    For nolign=1 To MAX_FOR
      DDEBNEXTPER = gdat$ (1, month(DATE_DEB_PER)+MOIS_AJOUT, year(DATE_DEB_PER))

      [M:CNX2]DATSTRPER(nolign-1) = DATE_DEB_PER
      #Fq-52208 [M:CNX2]DATENDPER(nolign-1) = DATE_DEB_NEXT_PER - 1

      If  DDEBNEXTPER - 1 < DATE_FIN_EXE                 #Fq-52208
         [M:CNX2]DATENDPER(nolign-1) = DDEBNEXTPER - 1   #Fq-52208
      Else                                                     #Fq-52208
         [M:CNX2]DATENDPER(nolign-1) = DATE_FIN_EXE            #Fq-52208
      Endif                                                    #Fq-52208

      Call PER_CALCUL_POIDS(nolign, G_NON) From SUBCNX2
      Call VAL_DEFAUT_PER3()               From SUBCNX2
      Call CALCUL_TOTAUX2 (2, nolign)      From SUBCNX2
      Call SEND_PERIODE_EN_GLOBAL (nolign) From SUBCNX2

      If [M:CNX2]DATENDPER(nolign-1) = DATE_FIN_EXE   #Fq-52208
         [M:CNX2]NBPER2 = nolign                      #Fq-52208
         Break                                        #Fq-52208
      Endif                                           #Fq-52208

      DATE_DEB_PER = DDEBNEXTPER
      # ------------------
      # Suite de la boucle
    Next nolign

   #Fq-68242Call ACTION_BLOCK (ACB_AFFZO, "CNX2", "NBPER2") From GLOBIENS   #?????

    Call ACTION_BLOCK (ACB_AFFZO, "CNX2", "NBPER2") From GLOBIENS
    Call AFFICHE_TOTAUX3() From SUBCNX2
  Endif

  [M:CNX2]NBRPER([M:CNX3]YEACLICK-1) = [M:CNX2]NBPER2
  G_MODCNX=G_OUI
  mkstat = 4

End

########################################
Subprog RECALCUL_TOTAUX()

Local Integer N_I

  Call CALCUL_TOTAUX2 (0, 0) From SUBCNX2
  For N_I = 1 To [M:CNX2]NBPER2
    Call CALCUL_TOTAUX2 (2, N_I) From SUBCNX2
    # ------------------
    # Suite de la boucle
  Next N_I
  Call AFFICHE_TOTAUX3() From SUBCNX2
End
########################################
Subprog SUPPRIME_PERIODE (N_I, P_MAX_TABLO)
Value Integer N_I
Value Integer P_MAX_TABLO

  If status = 65
    # Traitement de la suppression de ligne
    #-----------------------------
    # Comme on détruit une ligne, il faut marquer la ligne correspondante du tableau global
    # comme détruite, mais ne pas la détruire physiquement, sinon, ça va faire merdouiller les
    # indices du troisième onglet.
    [M:CNX3]INDFISYEA([M:CNX2]INDCNX3(N_I-1)-1) = 9999
    Affzo [M:CNX3]INDFISYEA([M:CNX2]INDCNX3(N_I-1)-1)
    #-----------------------------
    If P_MAX_TABLO < 2
      [M:CNX2]DATSTRPER(N_I-1) = [M:CNX3]DATSTRPER([M:CNX3]YEACLICK-1)
      Affzo [M:CNX2]DATSTRPER(N_I-1)
    Else
      If N_I < P_MAX_TABLO
        # ne faire qqchose que si on n'est pas sur la dernière ligne
        If N_I >= 2
          # A partir de la 2ème ligne
          [M:CNX2]DATSTRPER(N_I) = [M:CNX2]DATENDPER(N_I-2)+1
          Affzo [M:CNX2]DATSTRPER(N_I)
          N_I    += 1
          nolign  = N_I
          Call PER_CALCUL_POIDS (N_I, G_OUI) From SUBCNX2
          Call SEND_PERIODE_EN_GLOBAL (N_I)  From SUBCNX2
          N_I    -= 1
        Else
          # Pour le première ligne la date de début de la future première période est ramenée au début d'exercice
          [M:CNX2]DATSTRPER(N_I) = [M:CNX2]DATSTRPER(N_I-1)
          Affzo [M:CNX2]DATSTRPER(N_I)
          N_I    += 1
          nolign  = N_I
          Call PER_CALCUL_POIDS (N_I, G_OUI) From SUBCNX2
          Call SEND_PERIODE_EN_GLOBAL (N_I)  From SUBCNX2
        Endif
      Else
        # Pour la dernière ligne on positionne la date de fin d'exercice sur la future dernière période
        [M:CNX2]DATENDPER(N_I-2)   = [M:CNX2]DATENDPER(N_I-1)
        Affzo [M:CNX2]DATENDPER(N_I-2)
        N_I    -= 1
        nolign  = N_I
        Call PER_CALCUL_POIDS (N_I, G_OUI)   From SUBCNX2
        Call SEND_PERIODE_EN_GLOBAL (N_I)    From SUBCNX2
      Endif
    Endif
    Call RECALCUL_TOTAUX()
  Endif
  G_MODCNX = G_OUI
End
######################################################################################
Subprog AV_FLGPROACC(VALEUR)
Variable Integer VALEUR

End
########################################
Subprog AVANT_NBPER2

  Call VAL_DEFAUT_PER3 () From SUBCNX2
  Call DISABLE_POIDS ()   From SUBCNX2
  Call RECALCUL_TOTAUX()
  Call COLOR_PERIODE(nolign) From SUBCNX2

    #70465 Voir si le paramètre ACCPERCTL est à "Oui"
  If GFRADGI=G_OUI
        Diszo [M:CNX2]DATSTRPER
        Diszo [M:CNX2]DATENDPER
        Diszo [M:CNX2]NBRMONPER
        Diszo [M:CNX2]NBRWEKPER
        Diszo [M:CNX2]NBRDAYPER
        If GREP = "C" # FQ93954
          Diszo [M:CNX2]TYPPST
        Else
          Actzo [M:CNX2]TYPPST
        Endif
        Affzo [M:CNX2]TYPPST
        Disable 65 : # status Suppression ligne
        Disable 73 : # status insertion ligne
        GBOUT1=""
        GBOUT2=""
        GBOUT3=""
        GBOUT4=""
        GBOUT5=""
  Else
      Enable 65 : # status Suppression ligne
      Enable 73 : # status insertion ligne
  Endif

End
########################################
Subprog AS_NBPER2

Local Integer P_LIGNE
Local Date    DATE_DEB_EXE
Local Date    DATE_FIN_EXE
Local Decimal NB_YEAR
Local Integer NB_MONTH
Local Integer NB_WEEK
Local Integer NB_DAY

  DATE_DEB_EXE   = [M:CNX2]DATSTRFIY([M:CNX3]YEACLICK-1)
  DATE_FIN_EXE   = [M:CNX2]DATENDFIY([M:CNX3]YEACLICK-1)

  Call CALCUL_NB_D_M_W_Y (DATE_DEB_EXE, DATE_FIN_EXE, NB_DAY, NB_MONTH, NB_WEEK, NB_YEAR) From GLOBIENS
  Call PERIODE_SAISISSABLE() From SUBCNX2
  # --------------------------------
  If nolign = 1 and [M:CNX2]DATENDPERS(nolign-1) <> [0/0/0]
    # Sur la première ligne si la date planquée est renseignée on ne peut plus insérer/supprimer de ligne
    Disable 65 : # status Suppression ligne
    Disable 73 : # status insertion ligne
  Elsif [M:CNX2]STAPER(nolign-1) = GVML_SPCLOSE

    # si la période est close, interfacée ou calcul réel on ne peut plus insérer/supprimer de ligne
    Disable 65 : # status Suppression ligne
    Disable 73 : # status insertion ligne
    GBOUT6=""
    GBOUT7=""
# FQ88911 ajout de GVML_SPCOURA et GVML_SPOUVER
  Elsif [M:CNX2]STAPER(nolign-1) = GVML_SPCOURA or
&       [M:CNX2]STAPER(nolign-1) = GVML_SPOUVER

    Disable 65 : # status Suppression ligne
    Disable 73 : # status insertion ligne
# FQ88911
# si la période précédente est ouverte :
# on ne peut modifier la dernière période parce que cela retaillerait la précédente
# OU
# si la période précédente est comptabilisée, on ne peut pas supprimer la dernière, cela retaillerait 1 per compta (non modifiable)
# si la période précédente a 1 trf de site et ouverte, on ne peut pas supprimer, cela retaillerait 1 per à trf futrur (non modifiable)

  Elsif nolign > 1 and ( +
&       (nolign = [M:CNX2]NBPER2 and [M:CNX2]STAPER(nolign - 2) = GVML_SPOUVER) or +
&       (func SUBCNX2.PER_EXIST_POSTED([F:CPY]LEG, [M:CNX0]CPY, [M:CNX0]CNX, DATE_FIN_EXE, [M:CNX2]DATSTRPER(nolign - 2), [M:CNX2]DATENDPER(nolign - 2))) or +
&       ([M:CNX2]STAPER(nolign - 2) = GVML_SPOUVER and func SUBCNX2.FUTURTRFSITE_EXIST([M:CNX0]CPY, [M:CNX2]DATSTRPER(nolign-2))))

      Disable 65 : # status Suppression ligne
      Disable 73 : # status insertion ligne

  # FQ89970 :
  # pas de transfert futur
  # Période courante   : elle n'est pas détruite, donc le problème sera pour les trfs de date supérieure à l'ancienne fin de période
  # Périodes suivantes : elle sont détruites, donc le problème sera pour les trfs de date supérieure au début de période
  Elsif (([M:CNX2]STAPER(nolign-1) = GVML_SPCOURA and +
&          func SUBCNX2.FUTURTRFSITE_EXIST([M:CNX0]CPY, [M:CNX2]DATENDPER(nolign-1))) or +
&        ([M:CNX2]STAPER(nolign-1) <> GVML_SPCOURA and +
&         func SUBCNX2.FUTURTRFSITE_EXIST([M:CNX0]CPY, [M:CNX2]DATSTRPER(nolign-1))))

      Disable 65 : # status Suppression ligne
      Disable 73 : # status insertion ligne

  Else
    Enable 65 : # status Suppression ligne
    Enable 73 : # status insertion ligne
  Endif

  # --------------------------------
  If  [M:CNX2]STAPER(nolign-1) = GVML_SPOUVER
     GBOUT6=""
  Else
     #Fq-74562 If func GLOBIENS.PERCPT_STATE([M:CNX0]CPY,[M:CNX1]LEDTYP(0), [M:CNX2]DATSTRPER(nolign-1)) <> 2 #Fq- 73861
     If (GFRADGI = G_OUI) and ( func GLOBIENS.PERCPT_STATE([M:CNX0]CPY,[M:CNX1]LEDTYP(0), [M:CNX2]DATSTRPER(nolign-1)) <> 2 )#Fq- 73861
        GBOUT6=""
     Endif  #Fq- 73861
  Endif
  If  [M:CNX2]STAPER(nolign-1) = GVML_SPFERME
     GBOUT7=""
  Endif
  # --------------------------------
  # On interdit le redécoupage si on est sur la période courante
  If  ( [M:CNX2]NBPER2 > 1 )  &
&     ( [M:CNX2]STAPER(nolign-1) = GVML_SPCOURA ) or  ( [M:CNX2]STAPER(nolign)   = GVML_SPOUVER  )
      #*Fq-62537 &     ( [M:CNX2]STAPER(nolign-1) = GVML_SPCOURA ) &  ( [M:CNX2]STAPER(nolign)   = GVML_SPOUVER  )
      GBOUT1 = ""
      GBOUT2 = ""
      GBOUT3 = ""
      GBOUT4 = ""
      GBOUT5 = ""
  Endif
  If [M:CNX2]STAPER(nolign-1) = GVML_SPCOURA
      Local Integer NOL : NOL=nolign-1
      [M:CNX2]INDCURPER(nolign-1) = NOL
      GBOUT5 = ""
      GBOUT6 = ""
      GBOUT7 = ""
  Endif
  # --------------------------------
  # on interdit l'action si il n'y a pas une période courante ou non-ouverte avant
  If  ( nolign  > 1 )  & ( [M:CNX2]STAPER(nolign-2) <> GVML_SPCOURA & [M:CNX2]STAPER(nolign-2) <> GVML_SPOUVER )
    GBOUT6=""
  Else
     # --------------------------------
     # La première période d'un exercice ne peut être ouverte que si
     # la dernière période de l'exercice précédent est "Courante" ou "Ouverte"
     If  nolign = 1
        P_LIGNE = find([M:CNX2]DATSTRPER(nolign-1), [M:CNX3]DATSTRPER(0..[M:CNX3]NBPERC-1))
        If ( P_LIGNE> 1 ) &
&          ( [M:CNX3]STAPER(P_LIGNE-2) <>  GVML_SPOUVER ) &
&          ( [M:CNX3]STAPER(P_LIGNE-2) <>  GVML_SPCOURA )
           GBOUT6=""
        Endif
     Endif
   Endif
 # On ne peut pas ouvrir une période sur un exercice postérieur à l'exercice suivant
  If  STAFIY([M:CNX3]YEACLICK-1) = GVML_TESUIV2 or STAFIY([M:CNX3]YEACLICK-1) = 0
     GBOUT6=""
  Endif
  # --------------------------------
  # S'il y a une période ouverte sur l'exercice suivant on ne peut pas fermer cette période
  If  STAFIY([M:CNX3]YEACLICK-1) = GVML_TECOURA
     If !clalev([F:FIS]) : Local File FISCYEAR  [FIS] : Endif
     Read [F:FIS]FIY1  = [M:CNX0]CPY;[M:CNX0]CNX;GVML_TESUIV
     If fstat=0
        If find (GVML_SPOUVER, [F:FIS]STAPER(0..[F:FIS]NBRPER-1))
           GBOUT7=""
        Endif
     Endif
   Endif
  # --------------------------------
  If  ( [M:CNX2]STAPER(nolign-1) <> GVML_SPOUVER ) or
&     ( [M:CNX2]STAPER(nolign)   <> GVML_SPFERME  & [M:CNX2]STAPER(nolign) <> 0 )
     GBOUT7=""
  Else
      If [M:CNX2]TYPPST(nolign-1) = GVML_TPSTDEF
         For [DEP]DEP7 Where FLGDEV=G_OUI & CPY=[M:CNX0]CPY & CNX = [M:CNX0]CNX &
&                            FIYENDDAT= [M:CNX2]DATENDFIY([M:CNX3]YEACLICK-1) & PERENDDAT = [M:CNX2]DATENDPER(nolign-1)
           Read[DEP]First
           If (!fstat)
              GBOUT7=""
              Break
           Endif
         Next
      Else
         If  [M:CNX2]TYPPST(nolign-1)     = GVML_TPSTPRO
             #[M:CNX2]LSTTYPPRO(nolign-1)  = G_OUI#Fq67417
         Endif
      Endif
  Endif

 Affzo [M:CNX2]NBPER2

 If GFRADGI=G_OUI   #Fq-73079
      Diszo [M:CNX2]DATSTRPER,DATENDPER,DATENDPER,NBRMONPER,NBRWEKPER,NBRDAYPER
      Actzo [M:CNX2]TYPPST(nolign-1) :   Affzo [M:CNX2]TYPPST(nolign-1)
      GBOUT1 = ""
      GBOUT2 = ""
      GBOUT3 = ""
      GBOUT4 = ""
      GBOUT5 = ""
      Disable 65 : # status Suppression ligne
      Disable 73 : # status insertion ligne
# FQ88911
#  Else
#      Enable 65 : # status Suppression ligne
#      Enable 73 : # status insertion ligne
 # FQ93002
 Else
    If GREP = "C"
        Diszo [M:CNX2]TYPPST(nolign-1)
    Else
        Actzo [M:CNX2]TYPPST(nolign-1)
    Endif
    Affzo [M:CNX2]TYPPST(nolign-1)
 Endif #Fq-73079

End
########################################
Subprog APRES_NBPER2

  Call RECALCUL_TOTAUX()
  If [M:CNX2]DATENDPER(nolign-1)<>[0/0/0]
    Call REPORTE_PERIODES_CNX3() From SUBCNX2
  Endif

  [M:CNX2]NBRPER([M:CNX3]YEACLICK-1) = [M:CNX2]NBPER2

End

########################################
Subprog C_NBPER2

Local Date DATE_DEB_EXE

  If [M:CNX2]NBPER2 = 0
    End
  Elsif status = 65
    # Supprime ligne
    Call SUPPRIME_PERIODE (nolign, [M:CNX2]NBPER2)
  Elsif status = 73
    # Insert ligne : y a rien à faire ça marche tout seul !
  Else
    DATE_DEB_EXE = [M:CNX2]DATSTRFIY([M:CNX3]YEACLICK-1)
    If DATE_DEB_EXE = [0/0/0]
      # là interdit de saisir ce tableau
      mkstat = 2 : End
    Endif
  Endif

End
########################################
Subprog B1_NBPER2
# Mensuel
  Call PER_CALCUL_PERIODES (12)
End
########################################
Subprog B2_NBPER2
# Bimestriel
  Call PER_CALCUL_PERIODES (6)
End
########################################
Subprog B3_NBPER2
# Trimestriel
  Call PER_CALCUL_PERIODES (4)
End
########################################
Subprog B4_NBPER2
# Semestriel
  Call PER_CALCUL_PERIODES (2)
End
########################################
Subprog B5_NBPER2
# RAZ périodes
  Call PER_CALCUL_PERIODES (0)
End
########################################
Subprog B6_NBPER2

# Permet d'ouvrir une période non-ouverte
Local Integer N_I
Local Integer P_LIGNE
N_I = nolign

  # la période doit être sur l'exercice courant ou suivant et ne pas être déjà ouverte
  If  STAFIY([M:CNX3]YEACLICK-1) = GVML_TESUIV2 or STAFIY([M:CNX3]YEACLICK-1) = 0
& or  [M:CNX2]STAPER(N_I-1) = GVML_SPOUVER
     GBOUT6="" : End
  Endif
     #FQ-74562 if func GLOBIENS.PERCPT_STATE([M:CNX0]CPY,[M:CNX1]LEDTYP(0), [M:CNX2]DATSTRPER(nolign-1)) <> 2 #Fq- 73861
     If (GFRADGI = G_OUI) and ( func GLOBIENS.PERCPT_STATE([M:CNX0]CPY,[M:CNX1]LEDTYP(0), [M:CNX2]DATSTRPER(nolign-1)) <> 2 )#Fq- 73861
     GBOUT6="" : End
  Endif  #Fq- 73861

  # Si la période est la 1ère de l'exercice, la dernière période de l'exercice précédent
  # doit être "Courante ou "Ouverte
  If N_I = 1
     P_LIGNE = find([M:CNX2]DATSTRPER(N_I-1), [M:CNX3]DATSTRPER(0..[M:CNX3]NBPERC-1))
        If ( P_LIGNE> 1 ) &
&          ( [M:CNX3]STAPER(P_LIGNE-2) <>  GVML_SPOUVER ) &
&          ( [M:CNX3]STAPER(P_LIGNE-2) <>  GVML_SPCOURA )
        GBOUT6="" : End
     Endif
  Endif

  If ( N_I = 1 )  & ( [M:CNX2]STAPER(N_I-1) = GVML_SPCLOSE  )
     GBOUT6="" : End
  Endif

  # on interdit l'action si il n'y a pas une période courante ou ouverte avant
    If  (N_I > 1 ) & ( [M:CNX2]STAPER(N_I-2) <> GVML_SPCOURA & [M:CNX2]STAPER(N_I-2) <> GVML_SPOUVER )
    GBOUT6=""
  Else
    [M:CNX2]STAPER(N_I-1) = GVML_SPOUVER
    Affzo  [M:CNX2]STAPER(N_I-1)
    [M:CNX2]TYPPST(N_I-1) = GVML_TPSTPRO
    Actzo [M:CNX2]TYPPST(N_I-1) :     Affzo [M:CNX2]TYPPST(N_I-1)
    P_LIGNE = find([M:CNX2]DATSTRPER(N_I-1), [M:CNX3]DATSTRPER(0..[M:CNX3]NBPERC-1))
    [M:CNX3]STAPER(P_LIGNE-1)    = [M:CNX2]STAPER(N_I-1)
    [M:CNX3]TYPPST(P_LIGNE-1)    = [M:CNX2]TYPPST(N_I-1)
   #[M:CNX3]LSTTYPPRO(P_LIGNE-1) = [M:CNX2]LSTTYPPRO(N_I-1)#Fq67417
    Call ACTION_BLOCK (ACB_AFFZO, "CNX3",  "NBPERC") From GLOBIENS
    If GREP <> "C"  #Fq-67828
     Enable  GSTAENR
    Endif  #Fq-67828
    G_MODPST=G_OUI
  Endif

End
#################################################
Subprog B7_NBPER2

# Permet de fermer la dernière période ouverte
Local Integer N_I
Local Integer P_LIGNE
N_I = nolign

   # Si on a du "Comptabilisé"
   If func GLOBIENS.IS_DEJA_COMPTABILISE
&      ([M:CNX0]CPY,[M:CNX0]CNX,[M:CNX2]DATSTRPER(nolign-1),[M:CNX2]DATENDPER(nolign-1) ) = G_OUI
      # Si typpst=définitif   ==> on ne peut pas fermer la période
      If [M:CNX2]TYPPST(nolign-1) = GVML_TPSTDEF
         GBOUT7="" :  End
      Endif
   Endif

   # Si typpst passe de provisoire à définitif, l'interface comptable supprimera les écritures  provisoire
   If [M:CNX2]TYPPST(nolign-1) = GVML_TPSTPRO   # & VALEUR = GVML_TPSTDEF
      #[M:CNX2]LSTTYPPRO(nolign-1) = G_OUI#Fq67417
   Endif

   If  ( [M:CNX2]STAPER(N_I-1) <> GVML_SPOUVER ) or ( [M:CNX2]STAPER(N_I) <> GVML_SPFERME & [M:CNX2]STAPER(N_I) <> 0 )
     GBOUT7="" : End
   Endif

   [M:CNX2]STAPER(N_I-1) = GVML_SPFERME
   Affzo [M:CNX2]STAPER(N_I-1)
   [M:CNX2]TYPPST(N_I-1)= 0
   Diszo [M:CNX2]TYPPST(N_I-1)  :     Affzo [M:CNX2]TYPPST(N_I-1)
   P_LIGNE = find([M:CNX2]DATSTRPER(N_I-1), [M:CNX3]DATSTRPER(0..[M:CNX3]NBPERC-1))
   [M:CNX3]STAPER(P_LIGNE-1)    = [M:CNX2]STAPER(N_I-1)
   [M:CNX3]TYPPST(P_LIGNE-1)    = [M:CNX2]TYPPST(N_I-1)
  #[M:CNX3]LSTTYPPRO(P_LIGNE-1) = [M:CNX2]LSTTYPPRO(N_I-1)#Fq67417
   Call ACTION_BLOCK (ACB_AFFZO,  "CNX3",  "NBPERC" ) From GLOBIENS
   If GREP <> "C"  #Fq-67828
      Enable  GSTAENR
   Endif  #Fq-67828
   G_MODPST=G_OUI

End
########################################
Subprog AV_DATSTRPER(VALEUR)
Variable Date    VALEUR

  Call COLOR_PERIODE(nolign) From SUBCNX2
End
########################################
Subprog AS_DATSTRPER(VALEUR)
Variable Date    VALEUR

  # Cette date ne peut jamais être saisie, mais en faisant comme ça, on est automatiquement
  # positionné en saisie dans la colonne suivante si on tente de saisir ici !
  mkstat = 2
   If GFRADGI=G_OUI
      Affzo [M:CNX2]DATSTRPER(nolign-1) :  Diszo [M:CNX2]DATSTRPER(nolign-1)
  Endif

End
########################################
Subprog AS_DATENDPER(VALEUR)
Variable Date    VALEUR

Local Date    DATE_DEB_EXE
Local Integer N_I

    If GFRADGI = G_OUI
       Diszo [M:CNX2]DATSTRPER(nolign-1)
    Endif
  # ----------------------------------------------------------------
  N_I = nolign
  # ----------------------------------------------------------------
   If [M]STAPER(nolign-1) = GVML_SPCOURA
      If ( nolign < [M:CNX2]NBPER2 & [M]STAPER (nolign) = GVML_SPOUVER )
         mkstat = 2 : End
      Else
         If nolign=[M:CNX2]NBPER2 & (find (GVML_SPOUVER, [M:CNX3]STAPER(0..[M:CNX3]NBPERC-1)))
            mkstat = 2 : End
         Endif
      Endif
   Endif

  If [M]STAPER(nolign-1) = GVML_SPCLOSE  or [M]STAPER(nolign-1) = GVML_SPOUVER
     # la date de fin n'est pas accessible sur une période close, courante ou ouverte
     mkstat = 2
  Elsif (nolign < [M:CNX2]NBPER2) and ([M]STAPER(nolign) = GVML_SPCLOSE or [M]PERCRT(nolign) = G_OUI )
     # La date de fin n'est pas accessible si la période suivante est close (normalement ça ne peut pas arriver)
     mkstat = 2
  Else
     If nolign = 1
        DATE_DEB_EXE           = [M:CNX2]DATSTRFIY([M:CNX3]YEACLICK-1)
        If [M]DATSTRPER(nolign-1)<> DATE_DEB_EXE & VALEUR<>[0/0/0]
          Local Integer UPDSTRFIY
        Endif
        [M]DATSTRPER(nolign-1) = DATE_DEB_EXE
        If dim(UPDSTRFIY)>0
          Call PER_CALCUL_POIDS (nolign, G_OUI) From SUBCNX2
        Endif
        If [M:CNX2]TYPPST(nolign-1) = 0 # FQ93002 GVML_TPSTPRO au lieu de 0 conditionné
          [M:CNX2]TYPPST(nolign-1) = GVML_TPSTPRO
        Endif
        Affzo  [M:CNX2]TYPPST(nolign-1)
        Affzo [M]DATSTRPER(nolign-1)
     Else
        [M]DATSTRPER(nolign-1) = [M]DATENDPER(nolign-2) + 1
        Affzo [M]DATSTRPER(nolign-1)
     Endif

  Endif
     # ----------------------------------------------------------------
     # Sur les lignes>1 la date de début de période est la fin du précédent + 1
     If nolign > 2  and [M:CNX2]DATENDPER(nolign-1) = [0/0/0]
        # --------------------------------
        If day([M:CNX2]DATSTRPER(nolign-1)) = day([M:CNX2]DATSTRPER(nolign-2))
&          and [M:CNX2]DATENDPER(nolign-2) = eomonth([M:CNX2]DATSTRPER(nolign-2))
           [M:CNX2]DATENDPER(nolign-1) = eomonth([M:CNX2]DATSTRPER(nolign-1))
           Affzo [M:CNX2]DATENDPER(nolign-1)
        Else
           # Sinon on propose la fin d'exercice
           [M:CNX2]DATENDPER(nolign-1) = [M:CNX2]DATENDFIY([M:CNX3]YEACLICK-1)
           Affzo [M:CNX2]DATENDPER(nolign-1)
        Endif
        # --------------------------------
     Else
        # --------------------------------
        # On propose la fin d'exercice si la date de fin de période est vide
        # --------------------------------
     Endif
   #Fq-68242 Call PER_CALCUL_POIDS (nolign, G_OUI) From SUBCNX2
   #Fq-68242 REPORTE_PERIODES_CNX3()

     VALEUR = [M:CNX2]DATENDPER(nolign-1)

     If GFRADGI=G_OUI
          Affzo [M:CNX2]DATSTRPER(nolign-1) :  Diszo [M:CNX2]DATSTRPER(nolign-1)
          Affzo [M:CNX2]DATENDPER(nolign-1) :  Diszo [M:CNX2]DATENDPER(nolign-1)
     Endif


End

########################################
Subprog C_DATENDPER(VALEUR)
Variable Date    VALEUR

Local Date DATE_FIN_EXE

  If VALEUR <= [M]DATSTRPER(nolign-1)
    # la date de fin ne peut être <= au début
    GMESSAGE = mess(3,GML_MSGFASPR,1)   :  GERR     = 1
    mkstat   = 2 : End
  Endif

  DATE_FIN_EXE = [M:CNX2]DATENDFIY([M:CNX3]YEACLICK-1)
  If VALEUR > DATE_FIN_EXE
    # la date de fin ne peut être > à la fin d'exercice
    GMESSAGE = mess(4,GML_MSGFASPR,1) :  GERR     = 1
    mkstat   = 2 : End
  Endif

# FQ88911 test deplacé depuis AM_DATENDPER

  If VALEUR <> [0/0/0] and VALEUR <> [M:CNX2]DATENDPER(nolign-1)
    For N_I = 1 To [M:CNX3]NBPERC
      # FQ88911 2013.05.27
#      If  [M:CNX3]DATSTRPER(N_I-1) > VALEUR
      If  [M:CNX3]DATSTRPER(N_I-1) >= [M:CNX2]DATSTRPER(nolign-1)
#        If func GLOBIENS.IS_DEJA_COMPTABILISE([M:CNX0]CPY, [M:CNX0]CNX,
#&               [M:CNX3]DATSTRPER(N_I-1), [M:CNX3]DATENDPER(N_I-1) ) = G_OUI

        If func SUBCNX2.PER_EXIST_POSTED([F:CPY]LEG, [M:CNX0]CPY, [M:CNX0]CNX, DATE_FIN_EXE, [M:CNX3]DATSTRPER(N_I-1), [M:CNX3]DATENDPER(N_I-1))
          # Il y a du comptabilisé , vous ne pouvez pas redécouper cette période
          # FQ88911 mess298  remplace 230
          GMESSAGE = mess(298, GML_MSGFASPR, 1)
          GERR     = 1
          mkstat   = 2
          Break
        Endif
      Endif
    Next
  Endif

  # FQ89970 :
  # Période courante   : elle n'est pas détruite, donc le problème sera pour les trfs de date supérieure à l'ancienne fin de période
  # Périodes suivantes : elle sont détruites, donc le problème sera pour les trfs de date supérieure au début de période
  If [M:CNX2]STAPER(nolign-1) = GVML_SPCOURA
    If func SUBCNX2.FUTURTRFSITE_EXIST([M:CNX0]CPY, [M:CNX2]DATENDPER(nolign-1))
#   Il y a un transfert de site dans une période future , vous ne pouvez pas redécouper cette période
      GMESSAGE = mess(300, GML_MSGFASPR, 1)
      GERR     = 1
      mkstat   = 2
    Endif
  Else
    If func SUBCNX2.FUTURTRFSITE_EXIST([M:CNX0]CPY, [M:CNX2]DATSTRPER(nolign-1))
      GMESSAGE = mess(300, GML_MSGFASPR, 1)
      GERR     = 1
      mkstat   = 2
    Endif
  Endif
End
########################################
Subprog AM_DATENDPER(VALEUR)
Variable Date    VALEUR
Local Integer N_I

# FQ88911 : il n'y a plus rien dans ce test depuis FQ68242
#If (VALEUR =  [M:CNX2]DATENDFIY([M:CNX3]YEACLICK-1)) and  ([M:CNX2]DATENDPER(nolign-1) <> VALEUR ) &
#&   ( [M:CNX2]DATSTRPER(nolign-1)  =   [M:CNX2]DATSTRFIY([M:CNX3]YEACLICK-1) )
    #Fq-68242 [M:CNX2]NBPER2 = 1
#Endif

# FQ88911 test deplacé dans C_DATENDPER
#If VALEUR <> [0/0/0] and VALEUR <> [M:CNX2]DATENDPER(nolign-1)
#   [M:CNX2]DATENDPER(nolign-1) = VALEUR  : Affzo [M:CNX2]DATENDPER(nolign-1)
#   For N_I = 1 To [M:CNX3]NBPERC
#      If  [M:CNX3]DATSTRPER(N_I-1) > [M:CNX2]DATENDPER(nolign-1)
#         If func GLOBIENS.IS_DEJA_COMPTABILISE
#&           ([M:CNX0]CPY,[M:CNX0]CNX,[M:CNX3]DATSTRPER(N_I-1),[M:CNX3]DATENDPER(N_I-1) ) = G_OUI
#            Diszo [M:CNX2]DATENDPER(nolign-1) : Affzo [M:CNX2]DATENDPER(nolign-1)
#            # Il y a du comptabilisé , vous ne pouvez pas redécouper l'exercice
#            GMESSAGE = mess(230,GML_MSGFASPR,1) :  GERR     = 1
#            mkstat   = 2 : Break : End
#         Endif
#      Endif
#   Next
#Endif

  # FQ88911 : utilisé dans les fonctions dessous
  [M:CNX2]DATENDPER(nolign-1) = VALEUR

  If nolign=1 and  [M:CNX2]INDCURPER(nolign-1) < 0
     [M:CNX2]INDCURPER(nolign-1) = 1
  Endif

  Call PER_CALCUL_POIDS (nolign, G_OUI) From SUBCNX2
  Call REPORTE_PERIODES_CNX3() From SUBCNX2

  G_MODCNX = G_OUI

End
######################################################################################
Subprog AM_NBRMONPER(VALEUR)
Variable Decimal VALEUR
Local Integer P_LIGNE

If VALEUR <> [M:CNX2]NBRMONPER(nolign-1)
   [M:CNX2]NBRMONPER(nolign-1)= VALEUR
   P_LIGNE = find([M:CNX2]DATSTRPER(nolign-1), [M:CNX3]DATSTRPER(0..[M:CNX3]NBPERC-1))
   [M:CNX3]NBRMONPER(P_LIGNE-1)    = [M:CNX2]NBRMONPER(nolign-1)
   Affzo [M:CNX2]NBRMONPER(nolign-1)
   Affzo [M:CNX3]NBRMONPER(P_LIGNE-1)
   G_MODCNX   = G_OUI
   G_NEWPOIDS = 1
Endif

End
######################################################################################
Subprog AM_NBRWEKPER(VALEUR)
Variable Decimal VALEUR
Local Integer P_LIGNE

If VALEUR <> [M:CNX2]NBRWEKPER(nolign-1)
   [M:CNX2]NBRWEKPER(nolign-1)= VALEUR
   P_LIGNE = find([M:CNX2]DATSTRPER(nolign-1), [M:CNX3]DATSTRPER(0..[M:CNX3]NBPERC-1))
   [M:CNX3]NBRWEKPER(P_LIGNE-1)    = [M:CNX2]NBRWEKPER(nolign-1)
   Affzo [M:CNX2]NBRWEKPER(nolign-1)
   Affzo [M:CNX3]NBRWEKPER(P_LIGNE-1)
   G_MODCNX = G_OUI
   G_NEWPOIDS = 1
Endif

End
######################################################################################
Subprog AM_NBRDAYPER(VALEUR)
Variable Decimal VALEUR
Local Integer P_LIGNE

If VALEUR <> [M:CNX2]NBRDAYPER(nolign-1)
    [M:CNX2]NBRDAYPER(nolign-1)= VALEUR
   P_LIGNE = find([M:CNX2]DATSTRPER(nolign-1), [M:CNX3]DATSTRPER(0..[M:CNX3]NBPERC-1))
   [M:CNX3]NBRDAYPER(P_LIGNE-1)    = [M:CNX2]NBRDAYPER(nolign-1)
   Affzo [M:CNX2]NBRDAYPER(nolign-1)
   Affzo [M:CNX3]NBRDAYPER(P_LIGNE-1)
   G_MODCNX   = G_OUI
   G_NEWPOIDS = 1
Endif

End
######################################################################################
Subprog AS_TYPPST(VALEUR)
Variable Integer VALEUR

# S'il a eu du comptabilisé on ne peut pas avoir un type de compta provisoire
If func GLOBIENS.IS_DEJA_COMPTABILISE
&      ([M:CNX0]CPY,[M:CNX0]CNX,[M:CNX2]DATSTRPER(nolign-1),[M:CNX2]DATENDPER(nolign-1) ) = G_OUI
    GMENLOC(2) = 1   # uniquement Définitif
Else
   If GREP <> "M"
      If [M:CNX2]STAPER(nolign-1) = GVML_SPCOURA or [M:CNX2]STAPER(nolign-1) = GVML_SPOUVER
         [M:CNX2]TYPPST(nolign-1) = GVML_TPSTPRO
         Affzo  [M:CNX2]TYPPST(nolign-1)
      Endif
   Endif
   If  [M:CNX2]STAPER(nolign-1) = GVML_SPFERME
       GMENLOC(1) = 1   # ni définitif
       GMENLOC(2) = 1   # ni provisoire
       Diszo  [M:CNX2]TYPPST(nolign-1) # FQ93954 A enlever si le superviseur prend en compte ce cas
       Affzo  [M:CNX2]TYPPST(nolign-1)
   Endif
Endif

 If GFRADGI=G_OUI
    If func GLOBIENS.IS_DESYNC_CNX([F:CNX]CPY, [F:CNX]CNX) = G_OUI
       Diszo  [M:CNX2]TYPPST(nolign-1)
       GMESSAGE = mess(284,GML_MSGFASPR,1) :  GERR     = 1
       mkstat   = 2 : End
    Else
       # FQ93002-mdj If [M:CNX2]STAPER(nolign-1)= GVML_SPOUVER
      If [M:CNX2]STAPER(nolign-1)= GVML_SPOUVER  or [M:CNX2]STAPER(nolign-1)= GVML_SPCOURA
         Actzo[M:CNX2]TYPPST(nolign-1)  # FQ93002
         Affzo [M:CNX2]TYPPST(nolign-1) # FQ93002
      Endif
    Endif
 # FQ93002
 Else
    If GREP = "C"
        Diszo [M:CNX2]TYPPST
    Else
        Actzo [M:CNX2]TYPPST
    Endif
 FQ93954
    If GMENLOC(1) = 1 and GMENLOC(2) = 1 # FQ93954 action de sécurisation
       Diszo  [M:CNX2]TYPPST(nolign-1)
    Endif


    Affzo [M:CNX2]TYPPST(nolign-1)
 Endif

End
########################################
Subprog B1_TYPPST(VALEUR)
Variable Integer VALEUR

 Local Integer I_DEF
 # Le passage de provisoire à définitif est étendu à toutes les périodes suivantes : closes, courantes ou ouvertes
 For I_DEF=nolign To [M:CNX2]NBPER2
   # on ne mets pas à jour les périodes non-ouvertes ou celles pour lesquelles il y a du comptabilisé
   If  [M:CNX2]STAPER(I_DEF-1) = GVML_SPFERME  or
&       (func GLOBIENS.IS_DEJA_COMPTABILISE
&       ([M:CNX0]CPY,[M:CNX0]CNX,[M:CNX2]DATSTRPER(I_DEF-1),[M:CNX2]DATENDPER(I_DEF-1) ) = G_OUI)
   Else
      [M:CNX2]TYPPST(I_DEF-1)=VALEUR
      Affzo  [M:CNX2]TYPPST(I_DEF-1)
      P_LIGNE = find([M:CNX2]DATSTRPER(I_DEF-1), [M:CNX3]DATSTRPER(0..[M:CNX3]NBPERC-1))
      [M:CNX3]TYPPST(P_LIGNE-1)    = [M:CNX2]TYPPST(I_DEF-1)
      Affzo [M:CNX3]TYPPST(P_LIGNE-1)
     #[M:CNX3]LSTTYPPRO(P_LIGNE-1) = G_OUI#Fq67417
     #Affzo [M:CNX3]LSTTYPPRO(P_LIGNE-1)#Fq67417
      G_MODPST = G_OUI
   Endif
 Next I_DEF

End
########################################
Subprog C_TYPPST(VALEUR)
Variable Integer VALEUR

  If [M:CNX2]TYPPST(nolign-1) = GVML_TPSTDEF & VALEUR = GVML_TPSTPRO
    If func GLOBIENS.IS_DEJA_COMPTABILISE
&      ([M:CNX0]CPY,[M:CNX0]CNX,[M:CNX2]DATSTRPER(nolign-1),[M:CNX2]DATENDPER(nolign-1) ) = G_OUI
      #"il y a du comptabilisé , vous ne pouvez pas modifier le type de comptabilisation"
      GMESSAGE = mess(226,GML_MSGFASPR,1)
      GERR  = 1
      mkstat = 2
      End
    Endif
    If [M:CNX0]CNX=G300CPFI & G_ACTCCN=G_OUI & [M:CNX1]CCNFLG=G_OUI & [M:CNX1]CCNMOD=GVML_GCRNW &
&     func GLOCCN.IS_RPR_DEJA_COMPTABILISE([M:CNX0]CPY,[M:CNX2]DATSTRPER(nolign-1),[M:CNX2]DATENDPER(nolign-1) )=G_OUI
     #"il y a du comptabilisé , vous ne pouvez pas modifier le type de comptabilisation"
      GMESSAGE = mess(226,GML_MSGFASPR,1)
      GERR  = 1
      mkstat = 2
      End
    Endif

  Elsif ( GFRADGI = G_OUI ) and ( [M:CNX2]TYPPST(nolign-1) = GVML_TPSTPRO ) and ( VALEUR = GVML_TPSTDEF )

    If func GLOBIENS.PERCPT_STATE([M:CNX0]CPY,[M:CNX1]LEDTYP(0), [M:CNX2]DATSTRPER(nolign-1)) <> 2 #70465
      #"La période n'est pas ouverte en COMPTA, le type de comptabilisation ne peut pas être mis à "réel""
      GMESSAGE = mess(267,GML_MSGFASPR,1)
      GERR  = 1
      mkstat = 2
      End
    Endif

    #Fq67417 [M:CNX2]LSTTYPPRO(nolign-1) = G_OUI
    Local Char MESSA(255)
    Local Integer OK
    # "Attention : l'interface comptable supprimera les pièces provisoires déjà comptabilisées pour cette période
    MESSA  = mess(227,GML_MSGFASPR,1)
    Call AVERTIR(MESSA,OK) From GESECRAN
    OK-=1
    If OK =  0
      #Fq67417 [M:CNX2]LSTTYPPRO(nolign-1) = G_NON
      [M:CNX2]TYPPST(nolign-1) = GVML_TPSTPRO
      Affzo [M:CNX2]TYPPST(nolign-1)
      mkstat=4
      End
    Endif

    #Fq67417 [M:CNX2]LSTTYPPRO(nolign-1) = G_OUI
#    [M:CNX2]TYPPST(nolign-1) = GVML_TPSTDEF
#    Affzo [M:CNX2]TYPPST(nolign-1)
    For I_PER= 1 To  [M:CNX2]NBPER2-1
      If [M:CNX2]STAPER(I_PER-1) = GVML_SPCLOSE

        [M:CNX2]TYPPST(I_PER-1) = GVML_TPSTDEF
        Affzo [M:CNX2]TYPPST(I_PER-1)
        P_LIGNE = find([M:CNX2]DATSTRPER(I_PER-1), [M:CNX3]DATSTRPER(0..[M:CNX3]NBPERC-1))
        [M:CNX3]TYPPST(P_LIGNE-1)    = [M:CNX2]TYPPST(I_PER-1)
# FQ93954        Affzo [M:CNX3]TYPPST(P_LIGNE-1)
      Endif
    Next I_PER
  Endif

End
########################################
Subprog AM_TYPPST(VALEUR)
Variable Integer VALEUR
Local Integer I_PER


P_LIGNE = find([M:CNX2]DATSTRPER(nolign-1), [M:CNX3]DATSTRPER(0..[M:CNX3]NBPERC-1))
#[M:CNX3]TYPPST(P_LIGNE-1)    = [M:CNX2]TYPPST(nolign-1)
#Affzo [M:CNX3]TYPPST(P_LIGNE-1)
[M:CNX3]TYPPST(P_LIGNE-1)    = VALEUR

G_MODPST = G_OUI

End
##########################################################################
Subprog AM_FLGLNKPLN(VALEUR)
Variable Integer VALEUR

If ( VALEUR <> [M:CNX1]FLGLNKPLN(nolign-1) ) and  ( [M:CNX1]PLNMGTSV(nolign-1)= G_OUI )
   G_MODCNX = G_OUI
Endif

If VALEUR=G_OUI
   Actzo [M:CNX1]LNKPLN(nolign-1)
Else
   [M:CNX1]LNKPLN(nolign-1) = 0
   Effzo [M:CNX1]LNKPLN(nolign-1)
Endif

Affzo [M:CNX1]LNKPLN(nolign-1)

End
######################################################################################
######################################################################################
#                 F O N C T I O N S      D I V E R S E S
######################################################################################
######################################################################################
##  Alimentation auto des exercices/périodes
######################################################################################
Subprog B2_NBFIY

Local Integer NBPER       : NBPER    = 1
Local Integer NBPERFAY
Local Decimal NB_YEAR
Local Integer NB_MONTH
Local Integer NB_WEEK
Local Integer NB_DAY

  If !clalev([F:PER]) : Local File PERIOD     [PER] : Endif
  If !clalev([F:FAY]) : Local File FISCALYEAR [FAY] : Endif

  If ( [M:CNX1]PLNMOD <> 0 )  & ( [M:CNX1]PLNMODFLG = G_OUI )
    GERR=1   :  GMESSAGE = mess(242,GML_MSGFASPR,1)-num$(mess([M:CNX1]PLNMOD,3101,1) )
     mkstat=2 :  End
  Endif
  # Lecture des exercices
  EXE_COUR = 0
  nolign           = 1
  For [FAY]FIY0 Where CPY=[M:CNX0]CPY and LEDTYP=[M:CNX1]LEDTYP(0) and FIYSTA < 3
     [M:CNX2]DATSTRFIY(nolign-1)  = [F:FAY]FIYSTR
     [M:CNX2]DATENDFIY(nolign-1)  = [F:FAY]FIYEND
     [M:CNX2]STAFIY(nolign-1)  = 0
     # ------------------------------
     [M:CNX3]YEACLICK = nolign
     NBPERFAY = 0
     # Chargement des périodes si besoin
     For[PER]PER0 Where  CPY=[M:CNX0]CPY and LEDTYP=[M:CNX1]LEDTYP(0) and FIYNUM = [F:FAY]FIYNUM
        [M:CNX3]INDFISYEA(NBPER-1)     = nolign
        [M:CNX3]DATSTRPER(NBPER-1)     = [F:PER]PERSTR
        [M:CNX3]DATENDPER(NBPER-1)     = [F:PER]PEREND
        [M:CNX3]DATENDPERS(NBPER-1)    = [F:PER]PEREND
        Call CALCUL_NB_D_M_W_Y ([M:CNX3]DATSTRPER(NBPER-1), [M:CNX3]DATENDPER(NBPER-1), NB_DAY, NB_MONTH, NB_WEEK, NB_YEAR) From GLOBIENS
        [M:CNX3]NBRMONPER  (NBPER-1)   = NB_MONTH
        [M:CNX3]NBRWEKPER  (NBPER-1)   = NB_WEEK
        [M:CNX3]NBRDAYPER  (NBPER-1)   = NB_DAY
        Case  [F:PER]PERSTA
           When 2 # ==> période ouverte
              [M:CNX3]STAPER     (NBPER-1)  = GVML_SPOUVER
              [M:CNX3]TYPPST     (NBPER-1)  = GVML_TPSTPRO
              [M:CNX2]INDCURPER  (NBPER-1)  = 1
           When 1 # ==> période non-ouverte
             [M:CNX3]STAPER     (NBPER-1)  = GVML_SPFERME
             [M:CNX3]TYPPST     (NBPER-1)  = 0
             [M:CNX2]INDCURPER  (NBPER-1)  = 1
           When 3 # ==> période fermée
             [M:CNX3]STAPER     (NBPER-1)  = GVML_SPCLOSE
             [M:CNX3]TYPPST     (NBPER-1)  = 0
             [M:CNX2]INDCURPER  (NBPER-1)  = 1
        Endcase
       #---------------
        NBPER    += 1
        NBPERFAY += 1
        # Suite de la boucle
     Next
     [M:CNX2]NBRPER(nolign-1) =  NBPERFAY
     nolign += 1
    #  ------------------------------
    # Suite de la boucle
  Next
  # ------------------------------
  GDECAUTO=G_OUI   #*FQ-64247
  [M:CNX2]NBFIY  = nolign-1
  [M:CNX3]NBPERC = NBPER-1
  [M:CNX3]YEACLICK = 1
  Call AFFICHE_PERIODE()

   Affzo [M:CNX1]
   Affzo [M:CNX2]
   Affzo [M:CNX3]
End
######################################################################################
## Ajout bouton vert si Provisions Comptabilisables
######################################################################################
Subprog AV_BOUTRPRACC(VALEUR)
Variable Char    VALEUR()

  If G_ACTCCN=G_OUI
   If [M]CNX=G300CPFI
    If [M:CNX1]CCNFLG=G_OUI
     If [M:CNX1]CCNMOD=GVML_GCFIR
      Grizo [M:CNX1]25 : Actzo [M:CNX1]CCNFLG
      Actzo [M:CNX1]CCNMOD
      [M:CNX1]FLGRPRACC=G_NON
     Else
      Actzo [M:CNX1]25
      [M:CNX1]FLGRPRACC=func SUBTPE.RPR_COMPTABILISE([M:CNX0]CPY,G_OUI)
     Endif
     #Fq-59486
     If ( [M:CNX1]FLGRPRACC = G_OUI )
        Local Char    LIBZON(100)
        Call TEXTE(GINTITB2, LIBZON) From OBJDIV
        [M:CNX1]BOUTRPRACC   = "128"
        Chgtzn [M:CNX1]BOUTRPRACC  With LIBZON
     Else
        Chgtzn [M:CNX1]BOUTRPRACC With ""
     Endif
     If [M:CNX1]CCNGRTFLG <> G_OUI
      [M:CNX1]CCNGRTPLN = 0
      Diszo [M:CNX1]CCNGRTPLN
     Endif
    Else
     Chgtzn [M:CNX1]BOUTRPRACC With ""  #*FQ-59486
     Diszo [M:CNX1]BOUTRPRACC           #*FQ-59486
     Grizo [M:CNX1]25 : Actzo [M:CNX1]CCNFLG
    Endif
  Else
    Chgtzn [M:CNX1]BOUTRPRACC With ""   #*FQ-59486
    Grizo [M:CNX1]25
  Endif
Endif

End
