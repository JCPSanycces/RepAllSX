#<AdxTL>@(#)0.0.0.0 $Revision$ Inquiry PITV
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SEL_TABLE"  : Gosub SEL_TABLE
  When "SETBOUT"    : Gosub SETBOUT
  When "DEB_CRIT"   : Raz [M:CPITV] :  [M:CPITV] = [M:PITV1] : Call C_VLTCOD([M]VLTCOD) # X3-58149 MJH 10/4/2017 activate/disable lots when entering criteria
  When "FIN_CRIT"   : [M:PITV1] = [M:CPITV]
  When Default
Endcase
Return

$OUVRE
  Local Char    CRITERE1(255) (10)
  Local Integer WSKIP, WLIG, WPAGE, RECORD_COUNT

  If !clalev([F:ITF])  : Local File ITMFACILIT   [ITF]  : Endif
  If !clalev([F:CPY])  : Local File COMPANY      [CPY]  : Endif
  If !clalev([F:ITVP]) : Local File ITMMVTPIT    [ITVP] : Endif
  If !clalev([F:SLFP]) : Local File STOLOTFCYPIT [SLFP] : Endif
  If !clalev([F:STPP]) : Local File STOCOSTPIT   [STPP] : Endif
  If !clalev([F:ITCP]) : Local File ITMCOSTPIT   [ITCP] : Endif
  If !clalev([F:FIY])  : Local File FISCALYEAR   [FIY]  : Endif
  If !clalev([F:PER])  : Local File PERIOD       [PER]  : Endif
  If !clalev([F:ITM])  : Local File ITMMASTER    [ITM]  : Endif
  If !clalev([F:AXX])  : Local File ATEXTRA      [AXX]  : Endif
  If !clalev([F:TCM])  : Local File TABCOSTMET   [TCM]  : Endif
  If !clalev([F:STO])  : Local File STOCK        [STO]  : Endif

  Default Mask [M:PITV1]
  [M:PITV1]STOFCY = GFCYDEF(7)
  Call AM_STOFCY([M:PITV1]STOFCY)

  SUITE  = 1
  RETOUR = 1

Return
######################################################################################

$SETBOUT
  #X3-58149 MJH 10/4/2017 activate/disable lots based on valuation method when returning from criteria
  Call C_VLTCOD([M]VLTCOD)
Return

######################################################################################

$LOA_LIGNE
Local Integer RECORD_START
Local Integer RECORD_MAX
Local Integer VAL_CHG, VERSIONS
Raz VAL_CHG, VERSIONS

  Call CHANGE_COLUMNS([M:PITV1]VLTNUM)

  Raz CRITERE1

  CRITERE1(0)  = 'STOFCY = [M:PITV1]STOFCY'
  If [M:PITV1]ITMREF <> ''
    CRITERE1(1) += ' & ITMREF = [M:PITV1]ITMREF'
  Endif
  CRITERE1(2) += ' & ([F:ITF]VLTCOD = [M:PITV1]VLTCOD or find([M:PITV1]VLTCOD,[F:ITF]VLTCODHIS))'
  If [M:PITV1]LOTF   <> '' : CRITERE1(3) += ' & LOT >= [M:PITV1]LOTF'     : Endif
  If [M:PITV1]LOTT   <> '' : CRITERE1(4) += ' & LOT <= [M:PITV1]LOTT'     : Endif
  If [M:PITV1]FIYNUM <> 0  : CRITERE1(5) += ' & FIYNUM = [M:PITV1]FIYNUM' : Endif
  If [M:PITV1]PERF   <> 0  : CRITERE1(6) += ' & PERNUM >= [M:PITV1]PERF'  : Endif
  If [M:PITV1]PERT   <> 0  : CRITERE1(7) += ' & PERNUM <= [M:PITV1]PERT'  : Endif

  If find([M:PITV1]VLTNUM,1,2) : CRITERE1(8) -= "And CSTTYP = " + num$([M:PITV1]VLTNUM) : Endif

  Case [M:PITV1]VLTNUM
    When 1,2 : Gosub FILTER_STANDARD #Standard/Revised standard
    When 4   : Gosub FILTER_AVERAGE  #Average
    When 5,8 : Gosub FILTER_FIFO     #FIFO
    When 6   : Gosub FILTER_AVGLOT   #Average Lot
  Endcase

  Affzo [M:PITV1]


  If VAL_CHG = 1
    GERR = 2
    GMESSAGE = mess(504,184,1)
    Chgfmt [M:PITV2]VALMTHDCHG With "K:" + num$(type([M:PITV2]VALMTHDCHG)-10) + "X" # Show/Hide enterable
  Else
    Chgfmt [M:PITV2]VALMTHDCHG With "-K:" + num$(type([M:PITV2]VALMTHDCHG)-10) + "X" # Show/Hide enterable
  Endif

  #X3-57758 MJH 10/4/2017 Only display versions if there are any records with versions
  If dim([M:PITV2]ECCVALMAJ)>0
    If VERSIONS = 1
      Chgfmt [M:PITV2]ECCVALMAJ     With "K:"   + num$(type([M:PITV2]ECCVALMAJ))        + "X" # Show
      Chgfmt [M:PITV2]ECCVALMIN     With "K:"   + num$(type([M:PITV2]ECCVALMIN))        + "X" # Show
    Else
      Chgfmt [M:PITV2]ECCVALMAJ     With "-K:"  + num$(type([M:PITV2]ECCVALMAJ))        + "X" # Hide
      Chgfmt [M:PITV2]ECCVALMIN     With "-K:"  + num$(type([M:PITV2]ECCVALMIN))        + "X" # Hide
    Endif
  Endif


Return
######################################################################################


$LECTURE

  RECORD_COUNT = 0
  SUITE  = 0
  RETOUR = 0
  NBLU   = 1
  WBUT   = 0

  Case CHGPAG
  When 1 : #Search
    nolign = 1
    WPAGE  = 0

    Gosub LOA_LIGNE

    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 : #Next
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0

    Gosub LOA_LIGNE

    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 : #Last
    Raz [M:PITV2]
    WLIG = 0
    RECORD_COUNT = -1
    Gosub LOA_LIGNE #changes record count and returns RECORD_COUNT when RECORD_COUNT = -1
    WLIG = RECORD_COUNT
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0

    Gosub LOA_LIGNE

    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 : #Back
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0

    Gosub LOA_LIGNE

    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
  Endcase

Return

######################################################################################

$SEL_TABLE
  Case COUZON
    When "PERF" : Gosub S_PER
    When "PERT" : Gosub S_PER
    When "LOTF" : Gosub S_LOT
    When "LOTT" : Gosub S_LOT
  Endcase
Return

######################################################################################
$S_PER

  CRITERE="[F:PER]CPY='"+GSOCIETE+"' AND [F:PER]LEDTYP=1 AND [F:PER]FIYNUM="+num$([M:PITV1]FIYNUM)
  TIT(0)=mess(18,100,1) # window title

  NBCOL  = 0
  NBCOL += 1 : COL(NBCOL)="PERNUM" : Call TITZON("PERIOD","PERNUM",TIT(NBCOL)) From CONTOBJ
  NBCOL += 1 : COL(NBCOL)="PERSTR" : Call TITZON("PERIOD","PERSTR",TIT(NBCOL)) From CONTOBJ
  NBCOL += 1 : COL(NBCOL)="PEREND" : Call TITZON("PERIOD","PEREND",TIT(NBCOL)) From CONTOBJ

  Default File [PER]

Return

######################################################################################
$S_LOT

  CRITERE  = "[F:STO]STOFCY='"+[M]STOFCY+"'"
  CRITERE += " and [F:STO]LOT<>''"
  If [M]ITMREF <> ""
    CRITERE += " and [F:STO]ITMREF='"+[M]ITMREF+"'"
  Endif
  If COUZON = "LOTF" and [M]LOTF <> ""
    CRITERE += " and [F:STO]LOT>='"+[M]LOTF+"'"
  Endif
  If COUZON = "LOTT" and [M]LOTT <> ""
    CRITERE += " and [F:STO]LOT>='"+[M]LOTT+"'"
  Endif
  TIT(0)=mess(18,100,1) # window title

  NBCOL  = 0
  NBCOL += 1 : COL(NBCOL)="LOT"    : Call TITZON("STOCK","LOT",TIT(NBCOL)) From CONTOBJ
  NBCOL += 1 : COL(NBCOL)="ITMREF" : Call TITZON("STOCK","ITMREF",TIT(NBCOL)) From CONTOBJ
  NBCOL += 1 : COL(NBCOL)="STA"    : Call TITZON("STOCK","STA",TIT(NBCOL)) From CONTOBJ

  Default File [STO]

Return

######################################################################################
## Filter and fill table for Standard cost
######################################################################################
$FILTER_STANDARD

  Link [ITCP] With [ITM]ITM0 = [ITCP]ITMREF,
&                  [AXX]AXX0 = "ITMMASTER";"DES1AXX";GLANGUE;ITMREF;"",
&                  [ITF]ITF0 = [ITCP]ITMREF;[ITCP]STOFCY
&             As [TMP] Where evalue(CRITERE1)
&             Order By [F:ITCP]PEREND;[F:ITCP]ITMREF;[F:ITCP]CSTCHGDAT;[F:ITCP]ECCVALMAJ;[F:ITCP]ECCVALMIN

  If RECORD_COUNT =  -1
    RECORD_COUNT = rowcount([TMP])
    Return
  Endif

  Local Decimal LPERBEGQTY,LPERBEGCST,LPERRCPQTY,LPERRCPCST,LPERISSQTY,LPERISSCST,LPERVALCHG,LPERAMTDEV,LPERENDQTY,LPERENDCST
  Local Char LITMREF(GLONITM)
  Local Char LTEXTE(80), LECCVALMAJ(GLONICVVAL), LECCVALMIN(GLONICVVAL)
  Local Date LPEREND
  Local Decimal START_COST
  Local Decimal END_COST

  For [TMP]
    If LITMREF = [TMP]ITMREF and LPEREND = [TMP]PEREND and LECCVALMAJ = [TMP]ECCVALMAJ and LECCVALMIN = [TMP]ECCVALMIN

      END_COST    =  [F:ITCP]STDCST
      LPERRCPQTY  += [F:ITCP]PERRCPQTY
      LPERRCPCST  += [F:ITCP]PERRCPCST
      LPERISSQTY  += [F:ITCP]PERISSQTY
      LPERISSCST  += [F:ITCP]PERISSCST
      LPERVALCHG  += [F:ITCP]PERVALCHG
      LPERAMTDEV  += [F:ITCP]PERAMTDEV
      LPERENDQTY  =  [F:ITCP]PERENDQTY
      LPERENDCST  =  [F:ITCP]PERENDCST

    Elsif LITMREF <> ''
      #Write record
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub SET_RECORD
          Gosub CASE_CHGPAG
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif

      #get next record starting
      Gosub SET_FIRST

    Else #First time through
      Gosub SET_FIRST
    Endif
  Next

  If WLIG >= WSKIP
    If nolign <= MAXLIG
      Gosub SET_RECORD
      Gosub CASE_CHGPAG
    Endif
  Else
    WLIG += 1
  Endif

Return
########################################
$SET_FIRST
  LPEREND     = [F:ITCP]PEREND
  LITMREF     = [F:ITCP]ITMREF
  LTEXTE      = [F:AXX]TEXTE
  START_COST  = [F:ITCP]STDCST
  END_COST    = [F:ITCP]STDCST
  LPERBEGQTY  = [F:ITCP]PERBEGQTY
  LPERBEGCST  = [F:ITCP]PERBEGCST
  LPERRCPQTY  = [F:ITCP]PERRCPQTY
  LPERRCPCST  = [F:ITCP]PERRCPCST
  LPERISSQTY  = [F:ITCP]PERISSQTY
  LPERISSCST  = [F:ITCP]PERISSCST
  LPERVALCHG  = [F:ITCP]PERVALCHG
  LPERAMTDEV  = [F:ITCP]PERAMTDEV
  LPERENDQTY  = [F:ITCP]PERENDQTY
  LPERENDCST  = [F:ITCP]PERENDCST
  LECCVALMAJ  = [F:ITCP]ECCVALMAJ
  LECCVALMIN  = [F:ITCP]ECCVALMIN
Return
########################################
$SET_RECORD
  [M:PITV2]NBLIG = nolign
  [M:PITV2]PEREND(nolign-1)     = LPEREND
  [M:PITV2]ITMREF(nolign-1)     = LITMREF
  [M:PITV2]ITMDES(nolign-1)     = LTEXTE
  [M:PITV2]STDCSTSTR(nolign-1)  = START_COST
  [M:PITV2]STDCSTEND(nolign-1)  = END_COST
  [M:PITV2]BEGBASQTY(nolign-1)  = LPERBEGQTY
  [M:PITV2]BEGBASAMT(nolign-1)  = LPERBEGCST
  [M:PITV2]PERRCPQTY(nolign-1)  = LPERRCPQTY
  [M:PITV2]PERRCPAMT(nolign-1)  = LPERRCPCST
  [M:PITV2]PERISSQTY(nolign-1)  = LPERISSQTY
  [M:PITV2]PERISSAMT(nolign-1)  = LPERISSCST
  [M:PITV2]PERVALCHG(nolign-1)  = LPERVALCHG
  [M:PITV2]PERAMTDEV(nolign-1)  = LPERAMTDEV
  [M:PITV2]ENDBASQTY(nolign-1)  = LPERENDQTY
  [M:PITV2]ENDBASAMT(nolign-1)  = LPERENDCST
  [M:PITV2]ECCVALMAJ(nolign-1)  = LECCVALMAJ
  [M:PITV2]ECCVALMIN(nolign-1)  = LECCVALMIN

  #X3-57758 MJH 10/4/2017 Only display versions if there are any records with versions
  If LECCVALMAJ <> '' or LECCVALMIN <> ''
    VERSIONS = 1
  Endif

  [M:PITV2]VALMTHDCHG(nolign-1) = func STKPITLIB.VAL_METH_CHK([ITF]VLTCODDAT,[F:ITCP]PERSTR,[F:ITCP]PEREND)
  If [M:PITV2]VALMTHDCHG(nolign-1) <> ""
    Chgstl [M:PITV2]VALMTHDCHG With "AWARNHIGH"
    VAL_CHG = 1
  Endif

Return

######################################################################################
## Filter and fill table for Average cost
######################################################################################
$FILTER_AVERAGE
  Link [ITVP] With [ITM]ITM0 = [ITVP]ITMREF,
&                  [AXX]AXX0 = "ITMMASTER";"DES1AXX";GLANGUE;ITMREF;"",
&                  [ITF]ITF0 = [ITVP]ITMREF;[ITVP]STOFCY
&             As [TMP] Where evalue(CRITERE1)
&             Order By [F:ITVP]PEREND;[F:ITVP]ITMREF

  If RECORD_COUNT =  -1
    RECORD_COUNT = rowcount([TMP])
    Return
  Endif

  Local Integer LINE
  Local Integer TABLE_LINE
  LINE = 0
  For [TMP]
    If WLIG >= WSKIP
      If nolign <= MAXLIG

        [M:PITV2]NBLIG = nolign
        [M:PITV2]PEREND(nolign-1)     = [F:ITVP]PEREND
        [M:PITV2]ITMREF(nolign-1)     = [F:ITVP]ITMREF
        [M:PITV2]ITMDES(nolign-1)     = [F:AXX]TEXTE
        [M:PITV2]BEGBASQTY(nolign-1)  = [F:ITVP]BEGBASQTY
        [M:PITV2]BEGBASAMT(nolign-1)  = [F:ITVP]BEGBASAMT
        [M:PITV2]BEGAVC(nolign-1)     = [F:ITVP]BEGAVC
        [M:PITV2]PERRCPQTY(nolign-1)  = [F:ITVP]PERRCPQTY
        [M:PITV2]PERRCPAMT(nolign-1)  = [F:ITVP]PERRCPAMT
        [M:PITV2]PERISSQTY(nolign-1)  = [F:ITVP]PERISSQTY
        [M:PITV2]PERISSAMT(nolign-1)  = [F:ITVP]PERISSAMT
        [M:PITV2]PERVALCHG(nolign-1)  = [F:ITVP]PERVALCHG
        [M:PITV2]PERAMTDEV(nolign-1)  = [F:ITVP]PERAMTDEV
        [M:PITV2]ENDBASQTY(nolign-1)  = [F:ITVP]ENDBASQTY
        [M:PITV2]ENDBASAMT(nolign-1)  = [F:ITVP]ENDBASAMT
        [M:PITV2]ENDAVC(nolign-1)     = [F:ITVP]ENDAVC

        [M:PITV2]VALMTHDCHG(nolign-1) = func STKPITLIB.VAL_METH_CHK([ITF]VLTCODDAT,[F:ITVP]PERSTR,[F:ITVP]PEREND)
        If [M:PITV2]VALMTHDCHG(nolign-1) <> ""
          Chgstl [M:PITV2]VALMTHDCHG With "AWARNHIGH"
          VAL_CHG = 1
        Endif

        Gosub CASE_CHGPAG
      Else
        Break
      Endif
    Else
      WLIG += 1
    Endif
  Next
Return

######################################################################################
## Filter and fill table for FIFO/LIFO
######################################################################################
$FILTER_FIFO
  Link [STPP] With [ITM]ITM0 ~= [STPP]ITMREF,
&                  [AXX]AXX0 ~= "ITMMASTER";"DES1AXX";GLANGUE;ITMREF;"",
&                  [ITF]ITF0 ~= [STPP]ITMREF;[STPP]STOFCY
&             As [TMP] Where evalue(CRITERE1)
&             Order By [F:STPP]FIYNUM;[F:STPP]PERNUM;[F:STPP]ITMREF;[F:STPP]CSTDAT;[F:STPP]CSTCOU

  If RECORD_COUNT =  -1
    RECORD_COUNT = rowcount([TMP])
    Return
  Endif

  For [TMP]
    If WLIG >= WSKIP
      If nolign <= MAXLIG

        [M:PITV2]NBLIG = nolign
        [M:PITV2]PEREND(nolign-1)       = [F:STPP]PEREND
        [M:PITV2]ITMREF(nolign-1)       = [F:STPP]ITMREF
        [M:PITV2]ITMDES(nolign-1)       = [F:AXX]TEXTE

        [M:PITV2]RCPDAT(nolign-1)       = format$("DD2",[F:STPP]CSTDAT)

        [M:PITV2]CSTCOU(nolign-1)       = [F:STPP]CSTCOU
        [M:PITV2]BEGBASQTY(nolign-1)    = [F:STPP]PERBEGQTY
        [M:PITV2]BEGBASAMT(nolign-1)    = [F:STPP]PERBEGCST
        [M:PITV2]PERRCPQTY(nolign-1)    = [F:STPP]PERRCPQTY
        [M:PITV2]PERRCPAMT(nolign-1)    = [F:STPP]PERRCPCST
        [M:PITV2]PERISSQTY(nolign-1)    = [F:STPP]PERISSQTY
        [M:PITV2]PERISSAMT(nolign-1)    = [F:STPP]PERISSCST
        [M:PITV2]PERVALCHG(nolign-1)    = [F:STPP]PERVALCHG
        [M:PITV2]PERVALCHGQTY(nolign-1) = [F:STPP]PERVALCHGQTY
        [M:PITV2]PERAMTDEV(nolign-1)    = [F:STPP]PERAMTDEV
        [M:PITV2]ENDBASQTY(nolign-1)    = [F:STPP]PERENDQTY
        [M:PITV2]ENDBASAMT(nolign-1)    = [F:STPP]PERENDCST

        [M:PITV2]VALMTHDCHG(nolign-1) = func STKPITLIB.VAL_METH_CHK([ITF]VLTCODDAT,[F:STPP]PERSTR,[F:STPP]PEREND)
        If [M:PITV2]VALMTHDCHG(nolign-1) <> ""

        If VAL_CHG <> 1
          Chgstl [M:PITV2]VALMTHDCHG With "AWARNHIGH"
          VAL_CHG = 1
        Endif

        Endif

        Gosub CASE_CHGPAG
      Else
        Break
      Endif
    Else
      WLIG += 1
    Endif
  Next
Return


######################################################################################
## Filter and fill table for Average Lot cost
######################################################################################
$FILTER_AVGLOT
  Link [SLFP] With [ITM]ITM0 = [SLFP]ITMREF,
&                  [AXX]AXX0 = "ITMMASTER";"DES1AXX";GLANGUE;ITMREF;"",
&                  [ITF]ITF0 = [SLFP]ITMREF;[SLFP]STOFCY
&             As [TMP] Where evalue(CRITERE1)
&             Order  By FIYNUM;PERNUM;ITMREF;LOT;SLO

  If RECORD_COUNT =  -1
    RECORD_COUNT = rowcount([TMP])
    Return
  Endif

  For [TMP]
    If WLIG >= WSKIP
      If nolign <= MAXLIG

        [M:PITV2]NBLIG = nolign
        [M:PITV2]PEREND(nolign-1)     = [F:SLFP]PEREND
        [M:PITV2]ITMREF(nolign-1)     = [F:SLFP]ITMREF
        [M:PITV2]ITMDES(nolign-1)     = [F:AXX]TEXTE
        [M:PITV2]LOT(nolign-1)        = [F:SLFP]LOT
        [M:PITV2]SLO(nolign-1)        = [F:SLFP]SLO
        [M:PITV2]BEGBASQTY(nolign-1)  = [F:SLFP]BEGBASQTY
        [M:PITV2]BEGBASAMT(nolign-1)  = [F:SLFP]BEGBASAMT
        [M:PITV2]BEGAVC(nolign-1)     = [F:SLFP]BEGAVC
        [M:PITV2]PERRCPQTY(nolign-1)  = [F:SLFP]PERRCPQTY
        [M:PITV2]PERRCPAMT(nolign-1)  = [F:SLFP]PERRCPAMT
        [M:PITV2]PERISSQTY(nolign-1)  = [F:SLFP]PERISSQTY
        [M:PITV2]PERISSAMT(nolign-1)  = [F:SLFP]PERISSAMT
        [M:PITV2]PERVALCHG(nolign-1)  = [F:SLFP]PERVALCHG
        [M:PITV2]PERAMTDEV(nolign-1)  = [F:SLFP]PERAMTDEV
        [M:PITV2]ENDBASQTY(nolign-1)  = [F:SLFP]ENDBASQTY
        [M:PITV2]ENDBASAMT(nolign-1)  = [F:SLFP]ENDBASAMT
        [M:PITV2]ENDAVC(nolign-1)     = [F:SLFP]ENDAVC

        [M:PITV2]VALMTHDCHG(nolign-1) = func STKPITLIB.VAL_METH_CHK([ITF]VLTCODDAT,[F:SLFP]PERSTR,[F:SLFP]PEREND)
        If [M:PITV2]VALMTHDCHG(nolign-1) <> ""
          Chgstl [M:PITV2]VALMTHDCHG With "AWARNHIGH"
          VAL_CHG = 1
        Endif

        Gosub CASE_CHGPAG
      Else
        Break
      Endif
    Else
      WLIG += 1
    Endif
  Next
Return

######################################################################################
$CASE_CHGPAG
  Case CHGPAG
    When 1
      NBLU    = 2
      nolign += 1
      NOL    += 1
    When 2
      NBLU    = 2
      nolign += 1
      NOL    += 1
    When -1
      NBLU    = 2
      nolign += 1
      NOL    -= 1
    When -2
      NBLU    = 2
      nolign += 1
  Endcase
Return

######################################################################################
Subprog CHANGE_COLUMNS(LVLTCOD)
Value Integer LVLTCOD

  Raz [PITV2]

  Case LVLTCOD
    When 1,2  : Call USE_STD  #Standard
    When 4    : Call USE_AVG  #Average
    When 5,8  : Call USE_TIER #FIFO/LIFO
    When 6    : Call USE_LOTS #Average Lot
    When Default
  Endcase

End

##############################################
Subprog USE_STD

  Chgfmt [M:PITV2]LOT           With "-K:"  + num$(type([M:PITV2]LOT)-10)           + "X" # Show/Hide enterable
  Chgfmt [M:PITV2]SLO           With "-K:"  + num$(type([M:PITV2]SLO)-10)           + "X" # Show/Hide enterable
  Chgfmt [M:PITV2]CSTCOU        With "-K:"  + num$(type([M:PITV2]CSTCOU))           + "X" # Show/Hide enterable
  Chgfmt [M:PITV2]PERVALCHGQTY  With "-K:"  + num$(type([M:PITV2]PERVALCHGQTY))     + "X" # Show/Hide enterable
  Chgfmt [M:PITV2]RCPDAT        With "-K:"  + num$(type([M:PITV2]RCPDAT))           + "X" # Show/Hide enterable
  Chgfmt [M:PITV2]STDCSTSTR     With "K:"   + num$(type([M:PITV2]STDCSTSTR))        + "X" # Show/Hide enterable
  Chgfmt [M:PITV2]STDCSTEND     With "K:"   + num$(type([M:PITV2]STDCSTSTR))        + "X" # Show/Hide enterable
  Chgfmt [M:PITV2]BEGAVC        With "-K:"  + num$(type([M:PITV2]BEGAVC))           + "X" # Show/Hide enterable
  Chgfmt [M:PITV2]ENDAVC        With "-K:"  + num$(type([M:PITV2]ENDAVC))           + "X" # Show/Hide enterable

  #X3-57758 MJH 10/4/2017 Only display versions if there are any records with versions
#  If dim([M:PITV2]ECCVALMAJ)>0
#    Chgfmt [M:PITV2]ECCVALMAJ     With "K:"   + num$(type([M:PITV2]ECCVALMAJ))        + "X" # Show/Hide enterable
#    Chgfmt [M:PITV2]ECCVALMIN     With "K:"   + num$(type([M:PITV2]ECCVALMIN))        + "X" # Show/Hide enterable
#  Endif
End

