######################################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()

  Call GETSOC(VALEUR) From DEVSUB
  Read [CPY]CPY0 = GSOCIETE

  [M]CUR  = [F:CPY]ACCCUR
  Affzo [M]CUR

  Local Integer LFIY, LPER, LNBPER
  Call GETPERIOD(VALEUR,GTYPGEN,date$,LFIY,LPER) From CPTSUB
  Call NBPER(GSOCIETE,GTYPGEN,LFIY,LNBPER) From CPTSUB
  [M]FIYNUM = LFIY
  [M]PERF = 1
  [M]PERT = LNBPER

  Call C_PERF([M]PERF)
  Call C_PERT([M]PERT)

  If [M]ITMREF<> ""
    Filter [ITF] Where ITMREF = [M]ITMREF and STOFCY = VALEUR
    Look [ITF] First
    If fstat : Raz [M]ITMREF : Endif
    Filter [ITF]
  Endif

  Affzo [M]

End

######################################################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()

End

######################################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
  If VALEUR <> ''
    Filter [ITF]
    Read [ITF]ITF0 = VALEUR;[M]STOFCY
    If fstat
      GMESSAGE = mess(00025,00192,1) : mkstat=2 : End
    Endif

  Endif
End

######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
  If VALEUR <> ''
    Filter [ITF]
    Read [ITF]ITF0 = VALEUR;[M]STOFCY
    If !fstat
      [M]VLTCOD = [F:ITF]VLTCOD
    Endif

  Endif
End

######################################################################################
Subprog C_VLTCOD(VALEUR)
Variable Char    VALEUR()

  Read [TCM]TCM0 = VALEUR
  If fstat
    End
  Endif

  [M]VLTNUM = [F:TCM]ISSVLTCOD(0)

  If [M]VLTNUM = 6
    Actzo [M]LOTT
    Actzo [M]LOTF
  Else
    Raz [M]LOTT, [M]LOTF
    Grizo [M]LOTT
    Grizo [M]LOTF
  Endif

End

######################################################################################
Subprog AM_LOTF(VALEUR)
Variable Char    VALEUR()

  If VALEUR > [M]LOTT
    [M]LOTT = VALEUR
  Endif

End

######################################################################################
Subprog C_FIYNUM(VALEUR)
Variable Decimal VALEUR

  If VALEUR <> 0
    Read [FIY]FIY0 = GSOCIETE;1;VALEUR
    If fstat or [F:FIY]FIYSTA = 1
      GMESSAGE = mess(00034,00113,1) : mkstat=2 : End     # Fiscal year not opened
    Endif
  Endif

End

######################################################################################
Subprog AM_FIYNUM(VALEUR)
Variable Decimal VALEUR

  [M]FIYNUM = VALEUR
  Call C_PERF([M]PERF)
  Call C_PERT([M]PERT)
End

######################################################################################

Subprog C_PERF(VALEUR)
Variable Decimal VALEUR

  If VALEUR <> 0
    Read [PER]PER0 =GSOCIETE;1;[M]FIYNUM;VALEUR
    If !fstat
      [M]DATES = [F:PER]PERSTR
      Affzo [M]DATES
    Else
      GMESSAGE = mess(178,107,1) : mkstat=2 : End     # Incorrect period
    Endif

    #MJH X3-113286. Restrict only when period is 'Not open' instead of when it is not 'Open'
    #If [F:PER]PERSTA<>2
    If [F:PER]PERSTA=1
      GMESSAGE = mess(35,101,1) : mkstat = 2 : End    # Period not open
    Endif
  Endif

End

Subprog AM_PERF(VALEUR)
Variable Decimal VALEUR

  If VALEUR > [M]PERT
    [M]PERT = VALEUR
  Endif

End

######################################################################################
Subprog C_PERT(VALEUR)
Variable Decimal VALEUR

  If VALEUR <> 0
    Read [PER]PER0 =GSOCIETE;1;[M]FIYNUM;VALEUR
    If !fstat
      [M]DATEE = [F:PER]PEREND
      Affzo [M]DATEE
    Else
      Raz [M]DATEE
      GMESSAGE = mess(178,107,1) : mkstat=2 : End     # Incorrect period
    Endif

    #MJH X3-113286. Restrict only when period is 'Not open' instead of when it is not 'Open'
    #If [F:PER]PERSTA<>2
    If [F:PER]PERSTA=1
      Raz [M]DATEE
      GMESSAGE = mess(35,101,1) : mkstat = 2 : End    # Period not open
    Endif
  Endif


End

