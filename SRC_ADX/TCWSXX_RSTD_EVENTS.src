###############################################################################

$AQUERY_DECODE_CRITERIA_AFTER
  NBPRO += 1 : TBPRO(NBPRO) = "AWS_DEST"    : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AWS.DEST"     : TBFIL(NBPRO) = "[LNK_]DEST"
  NBPRO += 1 : TBPRO(NBPRO) = "AWS_CHRONO"  : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AWS.CHRONO"   : TBFIL(NBPRO) = "[LNK_]CHRONO"
  NBPRO += 1 : TBPRO(NBPRO) = "AWS_CLEDEC"  : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AWS.CLEDEC"   : TBFIL(NBPRO) = "[LNK_]CLEDEC"
  #US X3-27346 by RBA 03-08-2017 SAM 121897
  Case WREP
    When "HIS"   :
      NBPRO += 1 : TBPRO(NBPRO) = "AWS_EMETTEUR"  : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AWS.EMETTEUR"   : TBFIL(NBPRO) = "[LNK_]EMETTEUR"
      NBPRO += 1 : TBPRO(NBPRO) = "AWS_ACTSIG"    : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "AWS.ACTSIG"     : TBFIL(NBPRO) = "[LNK_]ACTSIG"
      NBPRO += 1 : TBPRO(NBPRO) = "AWS_FLGSIG"    : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "AWS.FLGSIG"     : TBFIL(NBPRO) = "[LNK_]FLGSIG"
    When "TOSIG" :
      NBPRO += 1 : TBPRO(NBPRO) = "AWS_EMETTEUR"  : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AWS.EMETTEUR"   : TBFIL(NBPRO) = "[LNK_]EMETTEUR"
    When "SIG"   :
      NBPRO += 1 : TBPRO(NBPRO) = "AWS_EMETTEUR"  : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AWS.EMETTEUR"   : TBFIL(NBPRO) = "[LNK_]EMETTEUR"
    When ""   : #SXX
      NBPRO += 1 : TBPRO(NBPRO) = "AWS_EMETTEUR"  : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AWS.EMETTEUR"   : TBFIL(NBPRO) = "[LNK_]EMETTEUR"
      NBPRO += 1 : TBPRO(NBPRO) = "AWS_ACTSIG"    : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "AWS.ACTSIG"     : TBFIL(NBPRO) = "[LNK_]ACTSIG"
      NBPRO += 1 : TBPRO(NBPRO) = "AWS_FLGSIG"    : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "AWS.FLGSIG"     : TBFIL(NBPRO) = "[LNK_]FLGSIG"
  Endcase
  #/US X3-27346 by RBA 03-08-2017 SAM 121897
Return

###############################################################################

$AQUERY_PRIMARYKEYS_AFTER
  ASTDKEY = ""
  Case WREP
    When "HIS" :
      ASTDKEY = ASTDKEY + "[LNK_]CHRONO desc;"
    When "" : #SXX History
      ASTDKEY = ASTDKEY + "[LNK_]CHRONO desc;"
    When Default :
      ASTDKEY = ASTDKEY + "[LNK_]CHRONO asc;"
  Endcase
Return

###############################################################################

$AQUERY_OPEN_AFTER
  Local Char TAB_DEST(100)(1..)
  Local Char TAB_CHRONO(100)(1..)
  Local Char TAB_CLEDEC(100)(1..)

  #US X3-27346 by RBA 03-08-2017 SAM 121897
  Case WREP
    When "HIS"   :
      Local Char TAB_EMETTEUR(100)(1..)
      Local Char TAB_ACTSIG(100)(1..)
      Local Integer TAB_FLGSIG(1..)
    When "TOSIG" :
      Local Char TAB_EMETTEUR(100)(1..)
    When "SIG"   :
      Local Char TAB_EMETTEUR(100)(1..)
    When ""   : #SXX
      Local Char TAB_EMETTEUR(100)(1..)
      Local Char TAB_ACTSIG(100)(1..)
      Local Integer TAB_FLGSIG(1..)
  Endcase
  #/US X3-27346 by RBA 03-08-2017 SAM 121897

  Local Integer I, J
  Local Char WKEYNUM(50)
  Local Integer WKEYLIN

  Local Char WUSER(5) : WUSER = GACTX.USER #user to be used into filters #  If WUSER = "RBA" : WUSER = "CH" : Endif
#If GACTX.USER = 'RBA' : WUSER = 'CH' : Endif
  Local File AWRKHISSUI [AWS]

  Case WCODOBJ
    When "SQH"
      Case WREP
        When "HIS"   : Gosub FILTER_SQH_HIS   #historique
        When "TOSIG" : Gosub FILTER_SQH_TOSIG #a signer
        When "SIG"   : Gosub FILTER_SQH_SIG   #Signé
      Endcase
    When "SOH"
      Case WREP
        When "HIS"   : Gosub FILTER_SOH_HIS   #historique
        When "TOSIG" : Gosub FILTER_SOH_TOSIG #a signer
        When "SIG"   : Gosub FILTER_SOH_SIG   #Signé
      Endcase
    When "SOC"
      Case WREP
        When "HIS"   : Gosub FILTER_SOC_HIS   #historique
        When "TOSIG" : Gosub FILTER_SOC_TOSIG #a signer
        When "SIG"   : Gosub FILTER_SOC_SIG   #Signé
      Endcase
    When "SXX"       : Gosub FILTER_SXX       #Historique tout vente
  Endcase

  J = 0
  For [AWS]
    I = instr(1,[AWS]CLEDEC,"~")
    If I > 0
      WKEYNUM = left$([AWS]CLEDEC, I-1)
      WKEYLIN = val(right$([AWS]CLEDEC, I+1))
      Case func GET_CODDOC([AWS]CODEVT, [AWS]CODWRK)
        When "SQH" : #n'arrive jamais - il n'y a pas de signature au niveau ligne pour ce document
        When "SOH" : #n'arrive jamais - il n'y a pas de signature au niveau ligne pour ce document
        When "SOC" : #n'arrive jamais - il n'y a pas de signature au niveau ligne pour ce document
      Endcase
    Else
      WKEYNUM = [AWS]CLEDEC
      WKEYLIN = 0
      Case func GET_CODDOC([AWS]CODEVT, [AWS]CODWRK)
        When "SQH" : Gosub SET_TAB_VAL_SQH_HEAD
        When "SOH" : Gosub SET_TAB_VAL_SOH_HEAD
        When "SOC" : Gosub SET_TAB_VAL_SOC_HEAD
      Endcase
    Endif
  Next
  LogicClose File [AWS]

  #US X3-27346 by RBA 03-08-2017 SAM 121897
#  Local File    (
#&               Char    DEST(100),
#&               Char    CHRONO(100),
#&               Char    CLEDEC(100)
#&             ) From Variable
#&   TAB_DEST, TAB_CHRONO, TAB_CLEDEC As [LNK_]
  Case WREP
    When "HIS"   : Gosub SET_QUERY_DATA_HIS
    When "TOSIG" : Gosub SET_QUERY_DATA_TOSIG
    When "SIG"   : Gosub SET_QUERY_DATA_SIG
    When ""      : Gosub SET_QUERY_DATA_HIS #SXX
  Endcase
  #/US X3-27346 by RBA 03-08-2017 SAM 121897
Return

$SET_QUERY_DATA_HIS
  Local File    (
&               Char    DEST(100),
&               Char    CHRONO(100),
&               Char    CLEDEC(100),
&               Char    EMETTEUR(100),
&               Char    ACTSIG(100),
&               Integer FLGSIG
&             ) From Variable
&   TAB_DEST, TAB_CHRONO, TAB_CLEDEC, TAB_EMETTEUR, TAB_ACTSIG, TAB_FLGSIG As [LNK_]
Return

$SET_QUERY_DATA_TOSIG
  Local File    (
&               Char    DEST(100),
&               Char    CHRONO(100),
&               Char    CLEDEC(100),
&               Char    EMETTEUR(100)
&             ) From Variable
&   TAB_DEST, TAB_CHRONO, TAB_CLEDEC, TAB_EMETTEUR As [LNK_]
Return

$SET_QUERY_DATA_SIG
  Local File    (
&               Char    DEST(100),
&               Char    CHRONO(100),
&               Char    CLEDEC(100),
&               Char    EMETTEUR(100)
&             ) From Variable
&   TAB_DEST, TAB_CHRONO, TAB_CLEDEC, TAB_EMETTEUR As [LNK_]
Return


###############################################################################

$FILTER_SQH_HIS #historique
  Filter [AWS] Where
&       find('SQHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & ([F:AWS]CODWRK<>'SQHSIGNCR')
&       &
&       find([F:AWS]FLGSIG,1,5)
&       &
&       [F:AWS]ACTSIG <> 'AUT' & [F:AWS]ACTSIG <> 'NCR'
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_SQH_TOSIG #a signer
  Filter [AWS] Where
&       find('SQHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & ([F:AWS]CODWRK<>'SQHSIGNCR')
&       &
&       [F:AWS]FLGSIG=3
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_SQH_SIG #Signé
  Filter [AWS] Where
&       [F:AWS]CODEVT='SQHSIG' & find([F:AWS]CODWRK,'SQHSIGNOT','SQHSIGREJ')<>0
&       &
&       [F:AWS]FLGSIG=2
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_SOH_HIS #historique
  Filter [AWS] Where
&       find('SOHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & ([F:AWS]CODWRK<>'SOHSIGNCR')
&       &
&       find([F:AWS]FLGSIG,1,5)
&       &
&       [F:AWS]ACTSIG <> 'AUT' & [F:AWS]ACTSIG <> 'NCR'
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_SOH_TOSIG #a signer
  Filter [AWS] Where
&       find('SOHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & ([F:AWS]CODWRK<>'SOHSIGNCR')
&       &
&       [F:AWS]FLGSIG=3
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_SOH_SIG #Signé
  Filter [AWS] Where
&       [F:AWS]CODEVT='SOHSIG' & find([F:AWS]CODWRK,'SOHSIGNOT','SOHSIGREJ')<>0
&       &
&       [F:AWS]FLGSIG=2
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_SOC_HIS #historique
  Filter [AWS] Where
&       find('SOCSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & ([F:AWS]CODWRK<>'SOCSIGNCR')
&       &
&       find([F:AWS]FLGSIG,1,5)
&       &
&       [F:AWS]ACTSIG <> 'AUT' & [F:AWS]ACTSIG <> 'NCR'
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_SOC_TOSIG #a signer
  Filter [AWS] Where
&       find('SOCSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & ([F:AWS]CODWRK<>'SOCSIGNCR')
&       &
&       [F:AWS]FLGSIG=3
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_SOC_SIG #Signé
  Filter [AWS] Where
&       [F:AWS]CODEVT='SOCSIG' & find([F:AWS]CODWRK,'SOCSIGNOT','SOCSIGREJ')<>0
&       &
&       [F:AWS]FLGSIG=2
&       &
&       [F:AWS]DEST=WUSER
Return

###############################################################################

$FILTER_SXX #Historique tout vente
  Filter [AWS] Where
&      (
&       (find('SQHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & [F:AWS]CODWRK<>'SQHSIGNCR')
&       |
&       (find('SOHSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & [F:AWS]CODWRK<>'SOHSIGNCR')
&       |
&       (find('SOCSIG',[F:AWS]CODEVT,[F:AWS]CODWRK)<>0 & [F:AWS]CODWRK<>'SOCSIGNCR')
&      )
&      &
&      [F:AWS]ACTSIG <> 'AUT' & [F:AWS]ACTSIG <> 'NCR'
&      &
&      find([F:AWS]FLGSIG,1,5)
&      &
&      [F:AWS]DEST=WUSER
Return

###############################################################################

$SET_TAB_VAL_SQH_HEAD
  Local File SQUOTE [SQH]
  Read [SQH]SQH0 = WKEYNUM
  If !fstat
    Gosub SET_TAB_VAL
  Endif
  LogicClose File [SQH]
Return

###############################################################################

$SET_TAB_VAL_SOH_HEAD
  Local File SORDER [SOH]
  Read [SOH]SOH0 = WKEYNUM
  If !fstat
    Gosub SET_TAB_VAL
  Endif
  LogicClose File [SOH]
Return

###############################################################################

$SET_TAB_VAL_SOC_HEAD
  Local File SORDER [SOH]
  Read [SOH]SOH0 = WKEYNUM
  If !fstat
    Gosub SET_TAB_VAL
  Endif
  LogicClose File [SOH]
Return

###############################################################################

$SET_TAB_VAL
  J = J + 1
  TAB_DEST(J)   = [AWS]DEST
  TAB_CHRONO(J) = [AWS]CHRONO
  TAB_CLEDEC(J) = [AWS]CLEDEC

  #US X3-27346 by RBA 03-08-2017 SAM 121897
  If dim(TAB_EMETTEUR)>0 : TAB_EMETTEUR(J) = [AWS]EMETTEUR : Endif
  If dim(TAB_ACTSIG)>0   : TAB_ACTSIG(J)   = [AWS]ACTSIG   : Endif
  If dim(TAB_FLGSIG)>0   : TAB_FLGSIG(J)   = [AWS]FLGSIG   : Endif
  #/US X3-27346 by RBA 03-08-2017 SAM 121897
Return

###############################################################################

$AQUERY_TRANS_AFTER
  Local Char WQRY_AMT(50) #US X3-21771 by RBA 01-25-2017 SAM 121176
  Local Char WQRY_CUR(10) #US X3-21771 by RBA 01-25-2017 SAM 121176

  Gosub SET_QUERY_PROPERTIES_AWS

  Local Integer I
  I = instr(1,this.AWS.CLEDEC,"~")
  Gosub GET_KEYS
  If WREP = "TOSIG" or WREP = "SIG" or WREP = "HIS"
    Case this.AWS.CODDOC
      When "SQH" : Gosub SET_QUERY_PROPERTIES_SQH
      When "SOH" : Gosub SET_QUERY_PROPERTIES_SOH
      When "SOC" : Gosub SET_QUERY_PROPERTIES_SOC
    Endcase
  Else #WREP is empty means PXX
    Case this.AWS.CODDOC
      When "SQH" : Gosub SET_QUERY_PROPERTIES_SQH_PXX
      When "SOH" : Gosub SET_QUERY_PROPERTIES_SOH_PXX
      When "SOC" : Gosub SET_QUERY_PROPERTIES_SOC_PXX
    Endcase

    Gosub SET_QUERY_URLDOC
  Endif
Return

###############################################################################

$GET_KEYS
  If I > 0
    this.AWS.KEYNUM = left$(this.AWS.CLEDEC, I-1)
    this.AWS.KEYLIN = val(right$(this.AWS.CLEDEC, I+1))
  Else
    this.AWS.KEYNUM = this.AWS.CLEDEC
    this.AWS.KEYLIN = 0
  Endif
Return

###############################################################################

$SET_QUERY_PROPERTIES_AWS
  this.AWS.DEST       = [LNK_]DEST
  this.AWS.CHRONO     = [LNK_]CHRONO
  this.AWS.CLEDEC     = [LNK_]CLEDEC

  Local File AWRKHISSUI [AWS]
  Read [AWS]AWS0 = this.AWS.CHRONO;this.AWS.DEST
  If !fstat
    SetInstance this.AWS With [F:AWS]
    this.AWS.EMAIL    = func GET_EMAIL([LNK_]DEST, [AWS]EMAIL)  #    this.AWS.EMAIL    = [AWS]EMAIL
    this.AWS.CODDOC   = func GET_CODDOC([AWS]CODEVT, [AWS]CODWRK)

    Case this.AWS.CODDOC  #US X3-21771 by RBA 01-25-2017 SAM 121176
      When "SQH" :   WQRY_AMT = [F:AWS]VALCTX4
                     WQRY_CUR = [F:AWS]VALCTX6
      When "SOH" :   WQRY_AMT = [F:AWS]VALCTX4
                     WQRY_CUR = [F:AWS]VALCTX6
      When "SOC" :   WQRY_AMT = [F:AWS]VALCTX4
                     WQRY_CUR = [F:AWS]VALCTX6
    Endcase #/US X3-21771 by RBA 01-25-2017 SAM 121176

  Endif
  LogicClose File [AWS]
Return

###############################################################################

$SET_QUERY_PROPERTIES_SQH
  Local File SQUOTE [SQH]
  Read [SQH]SQH0 = this.AWS.KEYNUM
  If !fstat
    this.QRY_CPY    = [SQH]CPY
    this.QRY_SALFCY = [SQH]SALFCY
    this.QRY_QUODAT = [SQH]QUODAT
    this.QRY_CUSREF = [SQH]CUSQUOREF
    this.QRY_BPCORD = [SQH]BPCORD
    this.QRY_AMT    = val(WQRY_AMT) #US X3-21771 by RBA 01-25-2017 SAM 121176
    this.QRY_CUR    = WQRY_CUR      #US X3-21771 by RBA 01-25-2017 SAM 121176
    If dim(this.QRY_REPONSE) > 0 and dim(this.AWS.OPERATION) > 0 : this.QRY_REPONSE = this.AWS.OPERATION : Endif #US X3-23534 by RBA 02-17-2017 SAM 121219
  Endif
  LogicClose File [SQH]
Return

###############################################################################

$SET_QUERY_PROPERTIES_SQH_PXX
  Local File SQUOTE [SQH]
  Read [SQH]SQH0 = this.AWS.KEYNUM
  If !fstat
    this.QRY_CPY    = [SQH]CPY
    this.QRY_FCY    = [SQH]SALFCY # ou STOFCY
    this.QRY_DAT    = [SQH]QUODAT
    this.QRY_CUSREF = [SQH]CUSQUOREF
    this.QRY_BPCORD = [SQH]BPCORD
    this.QRY_AMT    = val(WQRY_AMT) #US X3-21771 by RBA 01-25-2017 SAM 121176
    this.QRY_CUR    = WQRY_CUR      #US X3-21771 by RBA 01-25-2017 SAM 121176
    this.QRY_TYPVCR = 9 #sales quotes
  Endif
  LogicClose File [SQH]
Return

