#<AdxTL>@(#)4.0.0.0 $Revision$
################################################################################################
#                SUBHRCLC
## MABOS - 10/12/12-FQ81085-US1025-Tunnel
## MABOS - 08/01/13-FQ81085-US1126-The selecting list depends on the defined local menus
#                                 -Parameter TYPDOC on the leg or Not
################################################################################################
Raz GPILOBJ
Call OBJET("HRCLC",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "FERME"     : Gosub FERME
 When "LIENS"     : Gosub LIENS
 When "FILTRE"    : Gosub FILTRE
 When "INICRE"    : Gosub INICRE
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "VERIF_CRE" : Gosub VERIF_CRE :#MABOS-08/01/13-FQ81085-US1126
 When "VERIF_MOD" : Gosub VERIF_MOD :#MABOS-08/01/13-FQ81085-US1126
 When "ANNULE"    : Gosub ANNULE
 When "CHGCOD"    : Gosub CHGCOD
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "FIN_TABLE" : Gosub FIN_TABLE
  When "APRES_MODIF" : Gosub APRES_MODIF
# When "RAZCRE" : Gosub RAZCRE
Endcase
Return

$APRES_MODIF
#If GUSER="MABOS" : Dbgaff : Endif
#
#If zoncou="DOCCLAA" Then  :Endif
Return

$FILTRE
If (GFONCTION="GESEML" | GFONCTION="GESHRENT" | GFONCTION="GESCTR" | GFONCTION1="GESCTR") and GFONCTION<>"GESTXC"
 If FILTSUP<>"" : FILTSUP += " & " : Endif
 FILTSUP += "TYPCLA="+num$(2)
 # SEGAY 09/021/13 US1127 81085
 If maskcou = "CTRDOC"
    FILTSUP += "& find("+num$([M:CDOC]DOCCLA)+",DOCCLA)>0"
 Else
 # END SEGAY 09/021/13 US1127 81085
    FILTSUP += "& find("+num$([M:MCL]DOCCLA)+",DOCCLA)>0"
 Endif
 #MABOS- 10/12/12-FQ81085-US 1025-Tunnel
# If GFONCTION1="GESCTR" & GLEGFIL="" & GCURLEG="" Then
#  FILTSUP += " & LEG=''"
# Endif
Elsif GFONCTION="GESTXC" :#MABOS
   If FILTSUP<>"" : FILTSUP += " & " : Endif
   FILTSUP += "find("+num$([M:TXC0]DOCCLA)+",DOCCLA)>0"

Endif
Return

# FQ81085 - MABON 23/04/12 - Field LEG has been added
$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

# FQ81085 - MABON 23/04/12 - Field LEG has been added
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONHRCLC) : Endif
VCOD = CLE2
Return

$LIENS
#MABOS-08/01/13-FQ81085-US1126-The selecting list depends on the defined local menus
Local Char NUMLIB(10)
Local Integer PNOLIB, NOKPAR
Local Char WMESS(250)
Local Integer ONLEG   :#- 1 : Parameter TYPDOC on the leg or 0: Not
WMESS =""
Call PARAM([F:HRCLC]LEG,"TYPDOC",NUMLIB,ONLEG)
Gosub AFF_PNOLIB
nolign=1
NOKPAR=0
For I=0 To dim([F:HRCLC]DOCCLA)-1
    If ![F:HRCLC]DOCCLA(I) : Break : Endif
    Call VERIF_AML_TYPDOC([M]DOCCLA(I),[M:CLC0]NOLIB,WMESS,[M]DOCCLAA(I),NOKPAR)
    nolign+=1
Next
If NOKPAR &  WMESS<>"" Then
    WMESS -= mess(141,143,1) :# 'Valeur non définie'
    WMESS -= mess(158,10701,1)-"("+NUMLIB+")" : # pour le menu local du paramètre TYPDOC
Endif
If WMESS<>"" Then
    Call MESSAGE(WMESS) From GESECRAN
Endif
[M]NBRDOC=nolign-1
#end MABOS-08/01/2013


# FQ81085 - MABON 23/04/12 - DESCLA becomes a translatable text
GCURLEG = [F:HRCLC]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Call LECTEXTRA([M]DESCLA,"CLACTR","DESCLA",[M]CODCLA,GCURLEG) From ATEXTRA

# To display or to hide fields based on legislation code
Gosub DISPLAY_HIDE
# End MABON


Return

#**
#* FQ81085 - MABON 23/04/12 - Display or Hide Legislation field : hide it if LEGFIL is filled
#*!
$DISPLAY_HIDE
#Case GLEGFIL
# When ""
#   Chgfmt [M]LEG  With "K:"+num$(GLONADI)+"B"
#   Chgfmt [M]ZLEG With "KP:"+num$(GLONAX1)+"B"
# When Default
#   Chgfmt [M]LEG  With "-K:"+num$(GLONADI)+"B"
#   Chgfmt [M]ZLEG With "-KP:"+num$(GLONAX1)+"B"
#Endcase
Return

#**
#* FQ81085 - MABON 23/04/12 - Initialisation of field LEG with param LEGFIL
#*!
$INICRE
  If GLEGFIL<>"" & GCURLEG="" Then
    GCURLEG=GLEGFIL
  Endif
Return

#**
#* FQ81085 - MABON 23/04/12 - DESCLA becomes a translatable text
#*!
$MODIF

$CREATION
If GREP="D"
 ## In duplication mode we keep the translated text
 Call DUPTEXTRA("CLACTR","DESCLA",CLECUR1,"","CLACTR","DESCLA",[F:HRCLC]CODCLA,GCURLEG)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESCLA,"CLACTR","DESCLA",[F:HRCLC]CODCLA,GCURLEG) From ATEXTRA
Return


# MABOS-08/01/13-FQ81085-US1126-The selecting list depends on the defined local menus
$VERIF_CRE
$VERIF_MOD
Local Char WMESS(250)
Local Char NUMLIB(10)
Local Char WLEG(5)
Local Integer ONLEG :#- 1 : Parameter TYPDOC on the leg or 0: Not
#MIPEA - 2017-07-04- US X3-14396- START
Local Integer NOKPAR
#MIPEA - 2017-07-04- US X3-14396- END
  WLEG=[M]LEG
  Gosub CTR_LEG_TYPDOC
  NOKPAR=0
  If WMESS="" Then
    # Control on Parameter TYPDOC
    If [M:CLC0]NOLIB<>0 Then
      For I=0 To [M:CLC0]NBRDOC-1
         WPDOC=[M:CLC0]DOCCLA(I)
         Call VERIF_AML_TYPDOC(WPDOC,[M:CLC0]NOLIB,WMESS,[M:CLC0]DOCCLAA(I),NOKPAR)
      Next I
      If WMESS <>"" Then
        WMESS-= mess(141,143,1) :# 'Valeur non définie'
        WMESS-= mess(158,10701,1)-"("+num$([M:CLC0]NOLIB)+")" : # pour le menu local du paramètre TYPDOC
      Endif
    Endif
  Endif
  If WMESS<>"" Then
    zonsui="[M:CLC0]LEG"
  Else
    # Control on DOCCLAA
    If [M:CLC0]NBRDOC =0 Then
      WMESS = mess(10,123,1) :# Zone obligatoire'
      zonsui="[M:CLC0]DOCCLAA"
    Endif
  Endif
  If WMESS<>"" Then
    GERR=1
    GMESSAGE=WMESS
  Endif
Return
# End MABOS

#**
#* FQ81085 - MABON 23/04/12 - To delete translated texts (data type AX3)
#*!
$ANNULE
Call SUPTEXTRA("CLACTR","DESCLA",SUPP,[L]CODE) From ATEXTRA
Return

# 29/06/12 - PCA - Default the LEG
$RAZCRE
If dim([M]LEG)>0 Then
 [M]LEG=GLEGFIL
 Affzo [M]LEG
Endif
Return


Subprog AM_TYPCLA(VALEUR)
Variable Integer VALEUR

If VALEUR=2 :#Spécifique
 Effzo[M]CDNCLA : Grizo[M]CDNCLA
Else
 Actzo[M]CDNCLA
Endif
End

Subprog C_LEG(VALEUR)
Variable Char VALEUR
Local Char NUMLIB(10)
Local Char WMESS(250)
Local Char WLEG(5)
Local Integer ONLEG : # MABOS-08/01/13-FQ81085-US1126- 1 : Parameter TYPDOC on the leg or 0: Not
# MABOS-08/01/13-FQ81085-US1126-The selecting list depends on the defined local menus
WLEG=VALEUR
Gosub CTR_LEG_TYPDOC
If WMESS<>"" Then
  GMESSAGE = WMESS
  mkstat=2

Endif
End
# End MABOS-08/01/13

#**
#* FQ81085 - MABON 23/04/12 - Changes GCURLEG from new value of LEG
#*!
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

Local Integer PNOLIB,NOKPAR
Local Char TMPLEG (20)
Local Char NUMLIB(10)
Local Char WMESS(250)

# MABOS-08/01/13-FQ81085-US1126-The selecting list depends on the defined local menus
 TMPLEG = VALEUR
 WMESS=""
 NOKPAR =0
 If TMPLEG <> GCURLEG
  If (find (GREP,"C","D")> 0 ) Then
    If [M:CLC0]NOLIB<>0 Then
      For I=0 To [M:CLC0]NBRDOC-1
         WPDOC=[M:CLC0]DOCCLA(I)
         Call VERIF_AML_TYPDOC(WPDOC,[M:CLC0]NOLIB,WMESS,[M:CLC0]DOCCLAA(I),NOKPAR)
         Affzo [M:CLC0]DOCCLAA(I)
     Next I
     If NOKPAR &  WMESS<>"" Then
         WMESS -= mess(141,143,1) :# 'Valeur non définie'
         WMESS -= mess(158,10701,1)-"("+NUMLIB+")" : # pour le menu local du paramètre TYPDOC
         Call MESSAGE(WMESS) From GESECRAN
     Endif
     If NOKPAR
        mkstat=2 : End
     Endif
    Endif
   Endif
 Endif
GCURLEG = VALEUR
End


$CTR_LEG_TYPDOC
  Call PARAM(WLEG,"TYPDOC",NUMLIB,ONLEG)
  Gosub AFF_PNOLIB
Return

$AFF_PNOLIB
[M:CLC0]NOLIB=0
WMESS=""
If NUMLIB<>"0" & NUMLIB<>"" Then
  If mess(1,val(NUMLIB),1)="" Then
     WMESS =  (mess(156,10701,1)-"("+NUMLIB+")") : # Le menu local du paramètre TYPDOC n'est pas correctement renseigné
  Else
     [M:CLC0]NOLIB=val(NUMLIB)
  Endif
Else
  WMESS = mess(157,10701,1) :# Le paramètre TYPDOC n'est pas correctement renseigné
Endif
Affzo [M:CLC0]NOLIB
Return

########################################
#To change the main code
$CHGCOD
Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return

#**
#* FQ81085 - MABON 23/04/12 - Object HRCLC selection
#*!
$SEL_TABLE


Case TABLE
 When "SELHRCLC"

 If clalev ([F:HRCLC])=0 : Local File CLACTR [HRCLC] : Endif
#* FQ81085 - SEGAY 06/09/12 - Object HRCLC selection
  Gosub SAVE_GLEGFIL From TOOLSHRLEG

Filter [F:HRCLC]
  OBJET     = "HRCLC"
  START     = "[F:HRCLC]CODCLA"
  EXPSTART  = "[F:HRCLC]CODCLA>='"+VALEUR+"'"


  If dim([M]LEG)>0 Then
    If dim([M]LEG)>1 Then
      EXPSTART += '& [F:HRCLC]LEG="'+[M]LEG(nolign-1)+'"'
    Else
      EXPSTART += '& [F:HRCLC]LEG="'+[M]LEG+'"'
    Endif
  Endif


  OPTIONS = "|"
#  SUPP    = [F:HRCLC]CODCLA
  SUPP    = VALEUR
#  ORDRE = "[F:HRCLC]ROWCLA"
  #Filter based on code legislation



   If PARAM(1)<>""
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRCLC]LEG="'+PARAM(1)+'" | [F:HRCLC]LEG="")',"&") From GOBJSUB
   Endif
   # MABOS-08/01/13-FQ81085-US1126- If Parameter TYPDOC on the leg
  # If dim([M]ONLEG)>0 & [M]ONLEG = 1 Then
    #  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:HRCLC]LEG<>""',"&") From GOBJSUB
 #  Endif
#* FQ81085 - SEGAY 06/09/12 - Object HRCLC selection
  If GNAVIG(GPILNAV)="GESCTR" | GNAVIG(GPILNAV)="GESHRENT" # SEGAY 09/01/13 US1127 81085
      GLEGFIL=GCURLEG
  Endif
Endcase


Return

#**
#* FQ81085 - MABON 23/04/12 - Object HRCLC selection
#*!
$FIN_TABLE
Local Char MLEG
Case TABLE
 When "SELHRCLC" :
  #* FQ81085 - SEGAY 06/09/12 - Object HRCLC selection
  Gosub RESTAURE_GLEGFIL From TOOLSHRLEG

If (GNAVIG(GPILNAV)="GESCTR" and GFONCTION="GESCTR") | (GNAVIG(GPILNAV)="GESHRENT" and GFONCTION="GESHRENT") # SEGAY 09/01/13 US1127 81085
 If [F:HRCLC]CODCLA<>"" Then
  [M]ACTSELECT(nolign-1) = 2
  Endif
Endif


    If dim([M]LEG)>0 Then
      If dim([M]LEG)>1 Then
        [M]LEG(nolign-1)=[F:HRCLC]LEG
      Else
        [M]LEG=[F:HRCLC]LEG
      Endif
    Endif
    If dim([M]DESCLA)>0 & dim([M]LEG)>0 Then
      # We don't use ATEXTRA.LECTEXTRA because there is ACTIONB which initializes LEG if this is blank
#      Call LECTEXTRA([M]DESCLA(nolign-1),"CLACTR","DESCLA",[F:HRCLC]CODCLA,[M]LEG(nolign-1)) From ATEXTRA
      If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
      MLEG=""
      If dim([M]LEG)>1 Then MLEG=[M]LEG(nolign-1) : Else MLEG=[M]LEG : Endif
      Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANGUE;[F:HRCLC]CODCLA;MLEG
      If fstat=0
        If dim([M]DESCLA)>1 Then
          [M]DESCLA(nolign-1) = [F:AXX]TEXTE
        Else
          [M]DESCLA = [F:AXX]TEXTE
        Endif
      Else
       Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANDEF;[F:HRCLC]CODCLA;MLEG
       If fstat=0
        If dim([M]DESCLA)>1 Then
          [M]DESCLA(nolign-1) = [F:AXX]TEXTE
        Else
          [M]DESCLA = [F:AXX]TEXTE
        Endif
       Else
        If dim([M]DESCLA)>1 Then
          [M]DESCLA(nolign-1) = ""
        Else
          [M]DESCLA = ""
        Endif
       Endif
      Endif
#      If dim([M]DESCLA)>1 Then
#        Affzo [M]DESCLA(nolign-1)
#      Else
#        Affzo [M]DESCLA
#      Endif
    Endif
#  Endif
#Endif

  If GFONCTION="GESHRCLC" Then
    [M:CLC0]=[F:HRCLC]
    Gosub LIENS From SUBHRCLC
    Affzo [M:CLC0]
  Endif
Endcase


Return

#**
#* FQ81085 - MABON 23/04/12 - nel towards object HRCLC
#*
#* @param COD
#* @param LEG
#* @param SOC
#*!
Subprog TUNHRCLC(COD,LEG,SOC)
Variable Char    COD()
Value    Char    LEG
Value    Char    SOC
#Local    Char    VCOD(GLONHRCLC), MLEG
Local    Char    MLEG
Local    Char    CRITERE(250)
Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONHRCLC)
 TOKILL = 1
Endif


If clalev([F:HRCLC])=0 : Local File CLACTR [HRCLC] : Endif
# To update the HRCLC code after the tunnel order
VCOD = COD


If GNBLEG = 1
 LEG = GDOSLEG
#Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
# LEG = GCURLEG
Elsif LEG=""              : # If LEG="" then firstly we search a HRCLC record with LEG="" secondly a HRCLC record with LEG<>""
 Read [HRCLC]CLC0 = VCOD;LEG
 If fstat
  Read [HRCLC]CLC0(1)=VCOD
  If !fstat
   LEG = [F:HRCLC]LEG
  Endif
 Endif
Endif

#If VCOD<>"" Then
#  Read [HRCLC]CLC0 = VCOD;LEG
#  If fstat : LEG = "" : Endif
#Endif

If VCOD="" & GLECOBJ=2
  #If no code is specified, it's better to select one of the curent legislation
  #MABOS- 10/12/12-FQ81085-US 1025-Tunnel
  If dim(FILTSUP)<=0 Then Local Char FILTSUP(240)  :Endif

  Gosub FILTRE
  Filter [HRCLC] Where LEG=[L]LEG & evalue(FILTSUP)
  Read [F:HRCLC] First
  Filter [HRCLC]
  If !fstat : VCOD=[F:HRCLC]CODCLA : Endif
# Else #MABOS- 10/12/12-FQ81085-US 1025-Tunnel
Elsif VCOD<>""
  Read [HRCLC]CLC0 = VCOD;LEG
Endif
If fstat : LEG = "" : Endif


Call OBJET("HRCLC",LEG,VCOD) From GOBJET
#COD = [F:HRCLC]CODCLA
COD = VCOD

If dim([M]LEG)>0 Then


  If dim([M]DESCLA)>0 Then
  # We don't use ATEXTRA.LECTEXTRA because there is ACTIONB which initializes LEG if this is blank
#  Call LECTEXTRA([M]DESCLA(nolign-1),"CLACTR","DESCLA",COD,[M]LEG(nolign-1)) From ATEXTRA
  If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
  If dim([M]LEG)>1 Then
    [M]LEG(nolign-1)=[F:HRCLC]LEG
  Else
    [M]LEG=[F:HRCLC]LEG
  Endif
  Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANGUE;COD;[F:HRCLC]LEG
  If fstat=0
   [M]DESCLA(nolign-1) = [F:AXX]TEXTE
  Else
   Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANDEF;COD;[F:HRCLC]LEG
   If fstat=0
    [M]DESCLA(nolign-1) = [F:AXX]TEXTE
   Else
    [M]DESCLA(nolign-1) = ""
   Endif
  Endif
  If dim([M]LEG)>1 Then
    Affzo [M]DESCLA(nolign-1)
    Affzo [M]LEG(nolign-1)
  Else
    Affzo [M]DESCLA
    Affzo [M]LEG
  Endif

 Endif
Endif
  #MABOS- 10/12/12-FQ81085-US 1025-Tunnel
Call CONTHRCLC(COD,[F:HRCLC]LEG,"")
If GMESSAGE <>""  Then
Raz [F:HRCLC]
If dim([M]LEG)>1 Then
    [M]DESCLA(nolign-1)=""
    [M]LEG(nolign-1)=""
    [M]CLASPE(nolign-1)=COD
    Affzo [M]CLASPE(nolign-1)
    Affzo [M]DESCLA(nolign-1)
    Affzo [M]LEG(nolign-1)
  Else
    [M]CLASPE=COD
    [M]DESCLA=""
    [M]LEG=""
    Affzo [M]CLASPE
    Affzo [M]DESCLA
    Affzo [M]LEG
  Endif
Endif

If TOKILL : Kill VCOD : Endif


End


# To do a generic Call CONTSEL... from
# Added by DBA le 13\08 to use it in GESPRF, GESPOT and GESJOT (Administrative tab)
##################################################
Subprog CONTSEL(COD,LEG,SOC)
Value    Char    COD
Value    Char    LEG()
Value    Char    SOC()
Call CONTHRCLC(COD,LEG,SOC)
End


Subprog CONTHRCLC(COD,LEG,SOC)

Value    Char    COD
Value    Char    LEG()
Value    Char    SOC()
Local Integer    CAS
Local Integer   DOCNUM
Local Integer   TYPED

[L]TYPED=0

If (GNAVIG(GPILNAV)="GESCTR" and GFONCTION="GESCTR") | (GNAVIG(GPILNAV)="GESHRENT" and GFONCTION="GESHRENT") # SEGAY 09/01/13 US1127 81085
   # SEGAY 09/01/13 US1127 81085
   If maskcou = "CTRDOC"
      If [M:CDOC]ACTSELECT(nolign-1)<>2
          If dim([M]LEG)>0 Then
              If dim([M]LEG)>1 Then
                LEG=[M:CDOC]LEG(nolign-1)
              Else
                LEG=[M:CDOC]LEG
              Endif
          Endif
          [L]TYPED=1
      Endif
   Else
    # END SEGAY 09/021/13 US1127 81085
      If [M:MCL]ACTSELECT(nolign-1)<>2
          If dim([M]LEG)>0 Then
              If dim([M]LEG)>1 Then
                LEG=[M:MCL]LEG(nolign-1)
              Else
                LEG=[M:MCL]LEG
              Endif
          Endif
          [L]TYPED=1
      Endif
   Endif
Endif






If (GNAVIG(GPILNAV)="GESCTR" | GNAVIG(GPILNAV)="GESHRENT") and [L]TYPED=1 # SEGAY 09/01/13 US1127 81085
  If clalev([F:HRCLC])=0 : Local File CLACTR [HRCLC] : Endif
  If GFONCTION = "GESHRCLC" | COD="" : End : Endif

  If func AFNC.ACTIV("LEG")=0
   LEG = GDOSLEG
  Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
   LEG = GCURLEG
  Endif

  # CAS=1 => Record without Legislation (LEG = "")
  # CAS=2 => Record with    Legislation (LEG <>"")

  CAS = 1 : # Legislation is empty

  If LEG<>""
    DOCNUM=DOCCLA


    Filter [F:HRCLC] Where [F:HRCLC]TYPCLA=2 and [F:HRCLC]LEG=[L]LEG and [F:HRCLC]CODCLA=[L]COD and find([L]DOCNUM, [F:HRCLC]DOCCLA(0..9))>0
    Read [F:HRCLC]CLC0 First

    If fstat=4
#      If !(dim([M]ONLEG)>0 & [M]ONLEG = 1) Then : #MABOS - 08/01/13-FQ81085-US1126- If not Param TYPDOC on the leg-
         Filter [HRCLC] Where [HRCLC]TYPCLA=2 and [HRCLC]LEG="" and [HRCLC]CODCLA=[L]COD and find([L]DOCNUM, [HRCLC]DOCCLA(0..9))>0
         Read [F:HRCLC]CLC0 First
#      Endif
    Else

      CAS = 2 : # Legislation isn't empty
    Endif
  Else
    Filter [HRCLC] Where [F:HRCLC]TYPCLA=2 & [HRCLC]CODCLA=[L]COD & find([L]DOCNUM, [HRCLC]DOCCLA(0..9))>0
    Read [F:HRCLC]CLC0(1)=[L]COD
    If !fstat
      LEG = [F:HRCLC]LEG
      CAS = 2
    Endif
  Endif

  If fstat
    Filter [HRCLC] Where [F:HRCLC]TYPCLA=2 & [HRCLC]CODCLA=[L]COD & find([L]DOCNUM, [HRCLC]DOCCLA(0..9))>0
    Look [HRCLC]CLC0 First
    If !fstat
     # Fiche inexistante pour la législation courante
      GMESSAGE = [L]COD-":"-mess(14,10712,1)-"["+[L]LEG+"]"
    Else
      # Fiche inexistante
      GMESSAGE = [L]COD-":"-mess(23,100,1)
    Endif
    Filter [HRCLC]
    mkstat = 2 : End
  Endif
  Filter [HRCLC] : #MABOS- 10/12/12-FQ81085-US 1025-Tunnel
  If CAS=2
     Call CONTROLE("HRCLC","",LEG,COD,mkstat) From CONTOBJ
  Else
     Call CONTROLE("HRCLC","","",COD,mkstat) From CONTOBJ
  Endif
Endif



End





######################################################################################
#MABOS-08/01/13-FQ81085-US1126-The selecting list depends on the defined local menus
#* Find the good local menu for the title, depending on the leg

#* @param PNUMDOC : Numéric Field Document (Item of ML)
#* @param PNOLIB : Numéric Field ML Document type
#* @param WMESS2 : WMESS2 :message
#* @return PNOMDOC : Alpha Field Name of Document
#* @return NOKPAR : is no good(1) is good(0)
#*!
Subprog VERIF_AML_TYPDOC(PNUMDOC,PNOLIB, WMESS2,PNOMDOC,NOKPAR)
Value    Integer PNUMDOC
Value Integer PNOLIB
Variable Char    WMESS2, PNOMDOC
Variable Integer NOKPAR

Local    Char    NUMLIB(10)
    If PNUMDOC <>0 Then

      If PNOLIB <> 0 Then
        If mess(PNUMDOC,PNOLIB,1)<>"" Then
          PNOMDOC=mess(PNUMDOC,PNOLIB,1)
        Else
          PNOMDOC= num$(PNUMDOC)
          WMESS2 +=PNOMDOC+"-"
          NOKPAR=1
        Endif
      Else
        PNOMDOC=num$(PNUMDOC)
      Endif
    Else
      PNOMDOC = ""
    Endif

End

