Subprog IB_DOCCLAA
 If clalev([F:AST])=0  : Local File APLSTD  [AST]  : Endif
 If [M:CLC0]NOLIB<100
  Read [AST]CLE = 0;[M:CLC0]NOLIB;GLANGUE
 Else
  Read [AST]CLE = 200;[M:CLC0]NOLIB-200;GLANGUE
 Endif
 GBOUT1=[F:AST]LANMES
End

#MABOS-08/01/13-FQ81085-US1126-The selecting list depends on the defined local menus
#**
#* Value of Parameter + on the leg or Not
#*
#* @param LEG
#* @param PARAM
#* @param VALEUR ->
#* @param ONLEG  -> On the leg (1) or  Not (0)
#*!
Subprog PARAM(LEG,PARAM,VALEUR,ONLEG)
Value Char    LEG
Value Char    PARAM
Variable Char VALEUR
Variable Integer ONLEG :#  - 1 : Parameter TYPDOC on the leg or - 0: Not
Gosub PARAM_
End

$PARAM_
If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
If clalev([F:ADP])=0 : Local File ADOPAR [ADP] : Endif
VALEUR = ""
ONLEG=1   :# Parameter TYPDOC on the leg
Read [ADP]ADP1 = PARAM
If fstat : Return : Endif
Case [F:ADP]NIVDEF

 When 5 : # Législation
  Read [ADW]ADW0 = "*";LEG;PARAM
  If fstat
   Read [ADW]ADW0 = "";"";PARAM
   ONLEG=0 :# Parameter TYPDOC NOT on the leg
  Endif
Endcase
If !fstat
 VALEUR = [F:ADW]VALEUR
Else
 VALEUR = ""
Endif

Return
# END #MABOS-02/01/2013
