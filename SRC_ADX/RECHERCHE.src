########################################################################
# MB le 22-3-99 : Il est prÃĐfÃĐrable d'utiliser le
#                 Call SELECT(CRITERE,FICHIER,ok) From ASELECT
########################################################################
Local Char FILTRE(250)
Call FILTRE(FILTRE,"GACCOUNT")
End

Subprog CRITERE(CRITERE,FICH)
Variable Char CRITERE()
Value    Char FICH()
Local Mask    RECHERCHE [RCH]
[M]FMT = "K:15X"
Local Mesbox  Mask [RCH]
& Button mess(64,123,1) , mess(65,123,1)
& With left$(mess(64,123,1),1) , left$(mess(65,123,1),1)
& Coded GSTAOK , GSTAFIN
& Titled mess(157,124,1)
& As [RECH]
Local Integer FLABR
FLABR = 0
Goto RECHERCHE

Subprog FILTRE(CRITERE,FICH)
Variable Char CRITERE()
Value    Char FICH()
Local Mask    RECHERCHE [FLT]
[M]FMT = "K:15X"
Local Mesbox  Mask [FLT]
& Button mess(64,123,1) , mess(65,123,1)
& With left$(mess(64,123,1),1) , left$(mess(65,123,1),1)
& Coded GSTAOK , GSTAFIN
& Titled mess(157,124,1)
& As [RECH]
Local Integer FLABR
FLABR = 0
Goto RECHERCHE

Subprog FILTABR(CRITERE,FICH)
Variable Char CRITERE()
Value    Char FICH()
Local Mask    RECHERCHE [FLT]
[M]FMT = "K:15X"
Local Mesbox  Mask [FLT]
& Button mess(64,123,1) , mess(65,123,1)
& With left$(mess(64,123,1),1) , left$(mess(65,123,1),1)
& Coded GSTAOK , GSTAFIN
& Titled mess(157,124,1)
& As [RECH]
Local Integer FLABR
FLABR = 1
Goto RECHERCHE

$RECHERCHE
Onerrgo ERREUR From CONTROLE
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
Onerrgo
If GERREUR : GERREUR=0 : mkstat=2 : End : Endif
Local Char    VALEUR(50) , ZZ(20) , REP(1)
Local Integer I, STAT
Local Integer ETABOU(1..GNBBOU) , REPONSE , SAVOBJET
Local Char    SAVPROG(10)

SAVOBJET = GOBJET
SAVPROG  = GPROGRAMME
Call SAVBOUT From GESECRAN

Boxact [RECH]
If FICH<>[M]FICH : Raz [M] : Endif
If FICH=""
 Call SELFIC([M]FICH) From SELFIC
 If [M]FICH="" : End : Endif
Else
 [M]FICH=FICH
Endif

Read [ATB]CODFIC = [M]FICH
Affzo
GOBJET = 0

$CHOI
Raz ETABOU
ETABOU(GABAN) = 1
ETABOU(GVALI) = 1
Call SETBOUT(ETABOU) From GESECRAN
Boxinp [RECH] Using REPONSE
Case REPONSE
 When GSTAESC , GSTAFIN : STAT=1 : Goto FIN
 When GSTAOK  , GSTARET : Goto VALID
Endcase
Goto CHOI

$VALID
CRITERE=""
If [M]ZONE(0)="" : Goto FIN : Endif

For I=0 To [M]NBLIG-1
 If [M]ZONE(I)<>""
  If I<>0 : CRITERE += " & " : Endif
  Case [M]TYPZON(I)
   When 1
    VALEUR = num$([M]VALRECH(I))
   When 2,3,4,5,6
    VALEUR = num$([M]VALRECH(I))
   When 7
    VALEUR = '"'+[M]VALRECH(I)+'"'
   When 8
    If [M]VALRECH(I)=[0/0/0]
     VALEUR = "[00/00/0000]"
    Else
     VALEUR = "["+format$(GFMD,gdat$([M]VALRECH(I)))+"]"
    Endif
  Endcase
  ZZ=[M]ZONE(I)
  If FICH="" | FLABR : ZZ="["+[F:ATB]ABRFIC+"]"+ZZ : Endif
  Case [M]OPER(I)
   When 1
    If instr(1,VALEUR,"*")=0 & instr(1,VALEUR,"?")=0
     CRITERE += ZZ + "="  + VALEUR
    Else
     CRITERE += "pat(" + ZZ + "," + VALEUR + ")"
    Endif
   When 2 : CRITERE += ZZ + ">"  + VALEUR
   When 3 : CRITERE += ZZ + "<"  + VALEUR
   When 4
    If instr(1,VALEUR,"*")=0 & instr(1,VALEUR,"?")=0
     CRITERE += ZZ + "<>" + VALEUR
    Else
     CRITERE += "!pat(" + ZZ + "," + VALEUR + ")"
    Endif
  Endcase
 Endif
Next I

$FIN
Boxclr [RECH]
GOBJET = SAVOBJET
GPROGRAMME = SAVPROG
Call RESTBOUT From GESECRAN
If STAT : mkstat=2 : Endif
End

############################################################
Subprog ADDCRIT(SUBCRIT,CRITERE,ER)
Value Char       SUBCRIT
Variable Char    CRITERE()
Variable Integer ER
If ER=0
 If len(CRITERE) + len(SUBCRIT) > 255
  Call ERREUR(mess(4,159,1)) From GESECRAN
  ER=1
 Elsif CRITERE<>""
  CRITERE -= "&"-SUBCRIT
 Else
  CRITERE  = SUBCRIT
 Endif
Endif
End

Subprog ADDPAT(ZONE,VALEUR,CRITERE,ER)
Value    Char    ZONE
Value    Char    VALEUR
Variable Char    CRITERE()
Variable Integer ER
Local Char    RACINE(30) , RACINE2(30)
Local Integer J , K , L
J=instr(1,VALEUR,"*")
K=instr(1,VALEUR,"?")
If J<>0 | K<>0
 If J=0 : J = len(VALEUR)+1 : Endif
 If K=0 : K = len(VALEUR)+1 : Endif
 RACINE = left$(VALEUR,min(J,K)-1)
 If RACINE<>""
  L = len(RACINE)
  RACINE2 = left$(RACINE,L-1)+chr$(ascii(mid$(RACINE,L,1))+1)
  Call ADDCRIT(ZONE+'>="'+RACINE+'"',CRITERE,ER)
  Call ADDCRIT(ZONE+'<"'+RACINE2+'"',CRITERE,ER)
 Endif
 Call ADDCRIT('PAT('+ZONE+',"'+VALEUR+'")',CRITERE,ER)
Elsif VALEUR<>""
 Call ADDCRIT(ZONE+'>="'+VALEUR+'"',CRITERE,ER)
Endif
End


#########################################################################
# Etiquettes du masque RECHERCHE
#########################################################################
Subprog C_ZONE(VALEUR)
Variable Char VALEUR()
Local Integer DIME, I, OK
Local Char    ZZ(15)
Gosub SETNOL
VALEUR=toupper(VALEUR)
I=instr(1,VALEUR,"(")
If I<>0
 ZZ=left$(VALEUR,I-1) : DIME=val(right$(VALEUR,I+1)) : VALEUR=ZZ+"("+num$(DIME)+")"
Else
 ZZ=VALEUR : DIME=0
Endif
OK = 1
Read [ATZ]CODZONE = [F:ATB]CODFIC ; ZZ
If fstat
 OK = 0
Elsif [F:ATZ]CODACT<>""
 Read [ACV]CODACT = [F:ATZ]CODACT
 If !fstat
  If [F:ACV]DIME<>0 & DIME>[F:ACV]DIME-1
   OK = 0
  Elsif [F:ATZ]DIME<>0 & DIME>[F:ATZ]DIME-1
   OK = 0
  Endif
 Endif
Elsif [F:ATZ]DIME<>0 & DIME>[F:ATZ]DIME-1
 OK = 0
Endif
If !OK
 # Champ inexistant
 Call ERREUR(mess(41,100,1)) From GESECRAN : mkstat=2 : End
Endif
End

Subprog AP_ZONE(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Read [ATY]CODTYP = [F:ATZ]CODTYP
[M]TYPZON(NOL) = [F:ATY]TYPTYP
[M]NOLIB(NOL)  = [F:ATZ]NOLIB
[M]OPT(NOL)    = [F:ATZ]OPTION
If [M]NOLIB(NOL)=999
 [M]NOLIB(NOL)  = 0
 [M]TYPZON(NOL) = 2
Endif
End

Subprog S_ZONE(VALEUR)
Variable Char VALEUR
Local Char ABREV(5)
Call SELVAR([M]FICH,ABREV,VALEUR) From SELFIC
End

Subprog AS_OPER(VALEUR)
Variable Integer VALEUR
If [M]ZONE(nolign-1)="" : mkstat=1 : End : Endif
End

Subprog AV_VALRECH
Gosub SETNOL
Case [M]TYPZON(NOL)
 When 1
  [M]FMT="Nf:3#"
 When 2, 3, 4, 5, 6
  [M]FMT="Nf:12F"
 When 8
  [M]FMT="DzZf:"+GFMDAT
 When 7
  [M]FMT="Kf:20X"
Endcase
End

Subprog C_VALRECH
Case [M]TYPZON(nolign-1)
 When 1
  If val(num$(zc))<1 or val(num$(zc))>len(mess(0,[M]NOLIB(nolign-1),1))
   GMESSAGE = mess(83,123,1) : mkstat = 1 : End
  Else
   [M]INTIT(nolign-1) = mess(val(num$(zc)),[M]NOLIB(nolign-1),1)
   Affzo INTIT(nolign-1)
  Endif
 When 7
  Effzo INTIT(nolign-1)
  If instr(1,zc,'"')<>0 : GMESSAGE = '" :'-mess(94,123,1) : mkstat = 2 : End
  Elsif instr(1,[M]OPT(nolign-1),"A") : zc=toupper(zc)
  Endif
 When Default
  Effzo INTIT(nolign-1)
Endcase
End

$SETNOL
Local Integer NOL
NOL=nolign-1
Return
########################################
Subprog S_VALRECH
Gosub SETNOL
Local Integer NOLIB , VALLIB
Read [ATZ]CODZONE = [F:ATB]CODFIC ; [M]ZONE(NOL)
Read [ATY]CODTYP  = [F:ATZ]CODTYP
If [F:ATY]TYPTYP=1
 NOLIB = [F:ATY]NOLIB
 If NOLIB=0 : NOLIB = [F:ATZ]NOLIB : Endif
 If NOLIB<>0
  VALLIB = val(num$(zc))
  Call SAILIB(NOLIB,VALLIB) From GESECRAN
  zc = num$(VALLIB) 
Endif
Elsif [F:ATY]OBJLIEN<>""
 Case type(zc)
  When 1,2,3,4,5,6,7,8,9
   Call SELNUM([F:ATY]OBJLIEN,"",zc,"") From SELOBJ
  When Default
   Call SELECT([F:ATY]OBJLIEN,"",zc,"") From SELOBJ
 Endcase
Endif
mkstat = 2
End

#####################################################
## Remplit le masque RECHERCHE d'abrÃĐviation ABMSK ##
## en fonction du CRITERE                          ##
## pour la table FICH d'abrÃĐviation ABFIC          ##
#####################################################
Subprog FILRECH(CRITERE,FICH,ABFIC,ABMSK)
Value Char CRITERE(), FICH(), ABFIC(), ABMSK()
Local Integer I, J, K, L, NOL, AA,MM, JJ, PATTERN
Local Char    SEP(1), ZVAL(20), ZZ(20)

If ABMSK="" : ABMSK="[M]" : Endif
If [L]FICH<>""
 Assign ABMSK+"FICH" With [L]FICH
Endif
If CRITERE="" : Goto FIN_FILRECH : Endif

If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
If !clalev([F:ATY]) : Local File ATYPE [ATY]  : Endif
If ABFIC="" & FICH<>""
 Read [ATB]CODFIC = FICH
 If fstat=0 : ABFIC=[F:ATB]ABRFIC : Endif
Elsif FICH="" & ABFIC<>""
 Read [ATB]ABRFIC = ABFIC
 If fstat=0
  FICH=[F:ATB]CODFIC
  Assign ABMSK+"FICH" With [L]FICH
 Endif
Endif
If FICH="" or ABFIC="" : End : Endif

Assign ABMSK+"FMT" With "KF:20X"
I = instr(1,CRITERE,"["+ABFIC+"]")
L = len(ABFIC)
While I
 # Recherche de la zone
 J=0
 For SEP = "<", ">", "=", "," 
  K = instr(I+2+L,CRITERE,SEP) 
  If K & (!J | K<J) : J=K : Endif 
 Next
 If !J : Break : Endif
 SEP = mid$(CRITERE,J,1)
 Assign ABMSK+"ZONE("+num$(NOL)+")" With vireblc(seg$(CRITERE,I+2+L,J-1),2)

 # Recherche de l'opÃĐrateur
 K = 0
 Case SEP
  When "=" : K = 1 : PATTERN = 0
  When ">" : K = 2 : PATTERN = 0
  When "<" : If mid$(CRITERE,J+1,1)=">" : K = 4 : J += 1
             Else                       : K = 3
             Endif
             PATTERN = 0
  When "," : If mid$(CRITERE,I-5,5)="!pat("   : K = 4
             Elsif mid$(CRITERE,I-4,4)="pat(" : K = 1 
             Endif
             PATTERN = 1
 Endcase
 If !K : Break : Endif
 Assign ABMSK+"OPER("+num$(NOL)+")" With K

 # Recherche de la valeur
 K = instr(J+1,CRITERE,"&") : If !K : K=len(CRITERE)+1 : Endif
 ZVAL=vireblc(seg$(CRITERE,J+1,K-1),2)

 # Autres affectations
 CRITERE = right$(CRITERE,K+1)
 ZZ = evalue(ABMSK+"ZONE("+num$(NOL)+")")
 K = instr(1,ZZ,"(")
 If K : ZZ = left$(ZZ,K-1) : Endif
 Read [ATZ]CODZONE = FICH ; ZZ
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 Assign ABMSK+"TYPZON("+num$(NOL)+")" With [F:ATY]TYPTYP
 Assign ABMSK+"NOLIB("+num$(NOL)+")"  With [F:ATZ]NOLIB
 Assign ABMSK+"OPT("+num$(NOL)+")"    With [F:ATZ]OPTION
 If evalue(ABMSK+"NOLIB("+num$(NOL)+")")=999
  Assign ABMSK+"NOLIB("+num$(NOL)+")"  With 0
  Assign ABMSK+"TYPZON("+num$(NOL)+")" With 2
 Endif

 K = 0
 Case evalue(ABMSK+"TYPZON("+num$(NOL)+")")
  When 1 : # Menu local
   J = evalue(ABMSK+"NOLIB("+num$(NOL)+")")
   I = val(ZVAL)
   If J & I>=1 & I<=len(mess(0,J,1))
    Assign ABMSK+"INTIT("+num$(NOL)+")" With mess(I,J,1)
    K=1
   Endif
  When 7 : # on supprime les ""
   ZVAL=mid$(ZVAL,2,len(ZVAL)-2-PATTERN)
  When 8
   JJ=val(mid$(ZVAL,2,2))
   MM=val(mid$(ZVAL,5,2))
   AA=val(mid$(ZVAL,8,4))
   ZVAL=gdat$(JJ,MM,AA)
 Endcase 
 Assign ABMSK+"VALRECH("+num$(NOL)+")" With ZVAL 
 If !K : Assign ABMSK+"INTIT("+num$(NOL)+")" With "" : Endif

 I = instr(1,CRITERE,"["+ABFIC+"]")
 NOL+=1
Wend

$FIN_FILRECH
Assign ABMSK+"NBLIG" With NOL
End
