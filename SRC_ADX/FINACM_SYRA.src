#<AdxTL>@(#)2.0.0.0 $Revision$
##############################################################################################################
# ROUTINES ABOUT ACCOUNT CORE MODELS
##############################################################################################################
# GET_GCM        : returns the accounting core model for a given company
# GET_FINSTC     : returns the complete accounting structure for the company used as parameter
# GET_FINREDSTC  : returns the accounting structure for a given company, limited to the given ledger types
# GET_ANASTC     : returns the complete analytical structure for a given company
# GET_ANAREDSTC  : returns the analytical structure for a given company, limited to the given ledger types
# GET_LSTLED     : returns the list of ledger codes and currencies defined for a given company
# GET_MAINLEDTYP : returns for a given company the ledger types corresponding to the main general/analytical/IAS ledgers
# GET_LSTLEDTYP  : returns the list of the ledger types defined for a company. An option specifies the kind of the ledgers
# GET_LEDCUR     : returns the ledger code and the ledger currency for a given company and given ledger type
#
# Private routines :
# _GET_STC
##############################################################################################################


#####################################################################################################################
## GET_GCM
#####################################################################################################################
#**
#* Returns the accounting core model for a given company
#*
#* @param ACTX    Context
#* @param CPYFCY  Company or Site
#* @param MODEL   Accounting Core Model
#* @param ERRMES  Error message
#*!
Funprog GET_GCM(ACTX,CPYFCY,MODEL,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    CPYFCY    : # Company or Site
Variable Char    MODEL     : # Accounting Core Model
Variable Char    ERRMES()  : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Integer ICPY, ISITE
Local Char CPY(GLONCPY)
ICPY=fmet ACTX.ACACHE.ACPY.AGETINDEX(CPYFCY)
If ICPY=[V]CST_ANOTDEFINED
 ISITE = fmet ACTX.ACACHE.AFCY.AGETINDEX(CPYFCY)
 If ISITE=[V]CST_ANOTDEFINED
  [L]ASTATUS = [V]CST_AERROR : ERRMES = CPYFCY-mess(21,104,1) : End [L]ASTATUS
 Endif
 CPY=fmet ACTX.ACACHE.AFCY.AGETVALCHAR(CPYFCY,"LEGCPY")
 ICPY=fmet ACTX.ACACHE.ACPY.AGETINDEX(CPY)
 If ICPY = [V]CST_ANOTDEFINED
  [L]ASTATUS = [V]CST_AERROR : ERRMES = CPYFCY-mess(21,104,1) : End [L]ASTATUS
 Endif
 MODEL = fmet ACTX.ACACHE.ACPY.AGETVALCHAR(CPY,"ACM")
Else
 MODEL = fmet ACTX.ACACHE.ACPY.AGETVALCHAR(CPYFCY, "ACM")
Endif
End [L]ASTATUS


#####################################################################################################################
## GET_FINSTC
#####################################################################################################################
#**
#* Returns the Complete Accounting Structure for the company used as parameter (COMPANY)<br>
#* This sub-program allows to know the accounting data (accounts/dimension types) that must be entered by the user or initialized
#* in background in the upstream documents and the main data linked to (ledger currencies, chart of accounts format, chart of
#* accounts column header, dimension types formats, dimension types column header)<br>
#* Note : The main ledgers are returned in first position since they must be entered/initialized firsly in the documents
#*
#* @param ACTX       Context
#* @param COMPANY    Company
#* @param USEDACDIE  1:If the [F:CPY]DACDIE Flag must NOT be used / 2:If the [F:CPY]DACDIE Flag must be used
#* @param NBRLED     Number of ledger types (max 10)
#* @param LEDTYP     Array of ledger types
#* @param LEDCOD     Array of ledger codes
#* @param LEDCUR     Array of ledger currencies
#* @param COA        Array of chart of accounts
#* @param COAFMT     Array of chart of accounts Formats
#* @param COACOLHEA  Array of chart of accounts column headers
#* @param NBRDIE     Number of dimension types (max 20)
#* @param DIE        Array of dimension types
#* @param DIEFMT     Dimension Types Formats
#* @param DIECOLHEA  Dimension Types Column Header
#* @param DIEOBYFLG  Obligatory Flags (Y/N)
#* @param ERRMES     Error message
#*!
Funprog GET_FINSTC(ACTX,COMPANY,USEDACDIE,NBRLED,LEDTYP,LEDCOD,LEDCUR,COA,COAFMT,COACOLHEA,NBRDIE,DIE,DIEFMT,DIECOLHEA,DIEOBYFLG,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COMPANY          : # Company
Value    Integer  USEDACDIE        : # 1:If the [F:CPY]DACDIE Flag must NOT be used / 2:If the [F:CPY]DACDIE Flag must be used
Variable Integer  NBRLED           : # Number of ledger types (max 10)
Variable Tinyint  LEDTYP(1..)      : # Ledger Types
Variable Char     LEDCOD()(1..)    : # Ledger Codes
Variable Char     LEDCUR()(1..)    : # Ledger Currencies
Variable Char     COA()(1..)       : # Chart of accounts
Variable Char     COAFMT()(1..)    : # Chart of accounts Formats
Variable Char     COACOLHEA()(1..) : # Chart of account Column Header
Variable Integer  NBRDIE           : # Number of Dimension Types (max 20)
Variable Char     DIE()(1..)       : # Dimension Types (DIE)
Variable Char     DIEFMT()(1..)    : # Dimension Types Formats
Variable Char     DIECOLHEA()(1..) : # Dimension Types Column Header
Variable Integer  DIEOBYFLG(1..)   : # Obligatory Flags (Y/N)
Variable Char     ERRMES()         : # Error message

Local  Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Integer APPCASE : APPCASE = 1  : # Application case

[L]ASTATUS = func FINACM_SYRA._GET_STC(ACTX,APPCASE,COMPANY,USEDACDIE,NBRLED,LEDTYP,LEDCOD,LEDCUR,COA,COAFMT,COACOLHEA,NBRDIE,DIE,DIEFMT,DIECOLHEA,DIEOBYFLG,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR
 ERRMES = ERRMES : End [L]ASTATUS
Endif

End [L]ASTATUS


#####################################################################################################################
## GET_FINREDSTC
#####################################################################################################################
#**
#* Returns the accounting structure for the company used as parameter (COMPANY) limited to the ledger types used as parameter<br>
#* This sub-program returns the same data as the GET_FINSTC Sub-program but reduced to a list of ledger types used as parameter
#*
#* @param ACTX       Context
#* @param COMPANY    Company
#* @param USEDACDIE  1:If the [F:CPY]DACDIE Flag must NOT be used / 2:If the [F:CPY]DACDIE Flag must be used
#* @param NBRLED     Number of ledger types (max 10)
#* @param LEDTYP     Array of ledger types
#* @param LEDCOD     Array of ledger codes
#* @param LEDCUR     Array of ledger currencies
#* @param COA        Array of chart of accounts
#* @param COAFMT     Array of chart of accounts Formats
#* @param COACOLHEA  Array of chart of accounts column headers
#* @param NBRDIE     Number of dimension types (max 20)
#* @param DIE        Array of dimension types
#* @param DIEFMT     Dimension Types Formats
#* @param DIECOLHEA  Dimension Types Column Header
#* @param DIEOBYFLG  Obligatory Flag (Y/N)
#* @param ERRMES     Error message
#*!
Funprog GET_FINREDSTC(ACTX,COMPANY,USEDACDIE,NBRLED,LEDTYP,LEDCOD,LEDCUR,COA,COAFMT,COACOLHEA,NBRDIE,DIE,DIEFMT,DIECOLHEA,DIEOBYFLG,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COMPANY          : # Company
Value    Integer  USEDACDIE        : # 1:If the [F:CPY]DACDIE Flag must NOT be used / 2:If the [F:CPY]DACDIE Flag must be used
Value    Integer  NBRLED           : # Number of ledger types (max 10)
Value    Tinyint  LEDTYP(1..)      : # Ledger Type (Position 1:Main General, Position 2:Main Analytical)
Variable Char     LEDCOD()(1..)    : # Ledger Code
Variable Char     LEDCUR()(1..)    : # Ledger Currency
Variable Char     COA()(1..)       : # Chart of accounts
Variable Char     COAFMT()(1..)    : # Chart of accounts Formats
Variable Char     COACOLHEA()(1..) : # Chart of account Column Header
Variable Integer  NBRDIE           : # Number of Dimension Types (max 20)
Variable Char     DIE()(1..)       : # Axes (DIE)
Variable Char     DIEFMT()(1..)    : # Dimension Types Formats
Variable Char     DIECOLHEA()(1..) : # Dimension Types Column Header
Variable Integer  DIEOBYFLG(1..)   : # Obligatory Flag (Y/N)
Variable Char     ERRMES()         : # Error message

Local  Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Integer APPCASE : APPCASE = 2  : # Application case

[L]ASTATUS = func FINACM_SYRA._GET_STC(ACTX,APPCASE,COMPANY,USEDACDIE,NBRLED,LEDTYP,LEDCOD,LEDCUR,COA,COAFMT,COACOLHEA,NBRDIE,DIE,DIEFMT,DIECOLHEA,DIEOBYFLG,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR
 ERRMES = ERRMES : End [L]ASTATUS
Endif
End [L]ASTATUS


#####################################################################################################################
## GET_ANASTC
#####################################################################################################################
#**
#* Returns the complete analytical structure for the company used as parameter (COMPANY).<br>
#* This sub-program allows to know the analytical data that must be entered by the user or initialized in background in the upstream
#* documents and the main data linked to (dimension types formats, dimension types column header)<br>
#* <u>Note</u> : The dimension types attached to the main ledgers are returned in first position
#*
#* @param ACTX      Context
#* @param COMPANY   Company
#* @param USEDACDIE 1:If the [F:CPY]DACDIE Flag must NOT be used / 2:If the [F:CPY]DACDIE Flag must be used
#* @param NBRDIE    Number of Dimension Types (max 20)
#* @param DIE       Dimension types
#* @param DIEFMT    Dimension Types Formats
#* @param DIECOLHEA Dimension Types Column Header
#* @param DIEOBYFLG Obligatory Flags (Y/N)
#* @param ERRMES    Error message
#*!
Funprog GET_ANASTC(ACTX,COMPANY,USEDACDIE,NBRDIE,DIE,DIEFMT,DIECOLHEA,DIEOBYFLG,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COMPANY          : # Company
Value    Integer  USEDACDIE        : # 1:If the [F:CPY]DACDIE Flag must NOT be used / 2:If the [F:CPY]DACDIE Flag must be used
Variable Integer  NBRDIE           : # Number of Dimension Types (max 20)
Variable Char     DIE()(1..)       : # Dimension types (DIE)
Variable Char     DIEFMT()(1..)    : # Dimension Types Formats
Variable Char     DIECOLHEA()(1..) : # Dimension Types Column Header
Variable Integer  DIEOBYFLG(1..)   : # Obligatory Flags (Y/N)
Variable Char     ERRMES()         : # Error message

Local  Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Integer APPCASE : APPCASE = 3     : # Application case

Local  Integer  NBRLED                  : # Number of ledger types (max 10)
Local  Tinyint  LEDTYP(1..)             : # Ledger Type (Position 1:Main General, Position 2:Main Analytical)
Local  Char     LEDCUR(GLONCUR)(1..)    : # Ledger Currencies
Local  Char     LEDCOD(GLONLED)(1..)    : # Ledger Codes
Local  Char     COA(GLONCOA)(1..)       : # Chart of accounts
Local  Char     COAFMT(15)(1..)         : # Chart of accounts Formats
Local  Char     COACOLHEA(GLONAX1)(1..) : # Chart of accounts Column Header


[L]ASTATUS = func FINACM_SYRA._GET_STC(ACTX,APPCASE,COMPANY,USEDACDIE,NBRLED,LEDTYP,LEDCOD,LEDCUR,COA,COAFMT,COACOLHEA,NBRDIE,DIE,DIEFMT,DIECOLHEA,DIEOBYFLG,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR
 ERRMES = ERRMES : End [L]ASTATUS
Endif


End [L]ASTATUS


#####################################################################################################################
## GET_ANAREDSTD
#####################################################################################################################
#**
#* Returns the Analytical Structure for the company used as parameter (COMPANY) limited to the ledger types used as parameter<br>
#* This sub-program returns the same data as the GET_ANASTC Sub-program but reduced to a list of ledger types used as parameter
#*
#* @param ACTX      Context
#* @param COMPANY   Company
#* @param USEDACDIE 1:If the [F:CPY]DACDIE Flag must NOT be used / 2:If the [F:CPY]DACDIE Flag must be used
#* @param NBRLED    Number of ledger types (max 10)
#* @param LEDTYP    Ledger Types
#* @param NBRDIE    Number of Dimension Types (max 20)
#* @param DIE       Dimension Types
#* @param DIEFMT    Dimension Types Formats
#* @param DIECOLHEA Dimension Types Column Header
#* @param DIEOBYFLG Obligatory Flags (Y/N)
#* @param ERRMES    Error message
#*!
Funprog GET_ANAREDSTC(ACTX,COMPANY,USEDACDIE,NBRLED,LEDTYP,NBRDIE,DIE,DIEFMT,DIECOLHEA,DIEOBYFLG,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COMPANY          : # Company
Value    Integer  USEDACDIE        : # 1:If the [F:CPY]DACDIE Flag must NOT be used / 2:If the [F:CPY]DACDIE Flag must be used
Value    Integer  NBRLED           : # Number of ledger types (max 10)
Value    Tinyint  LEDTYP(1..)      : # Ledger Types
Variable Integer  NBRDIE           : # Number of Dimension Types (max 20)
Variable Char     DIE()(1..)       : # Dimension Types (DIE)
Variable Char     DIEFMT()(1..)    : # Dimension Types Formats
Variable Char     DIECOLHEA()(1..) : # Dimension Types Column Header
Variable Integer  DIEOBYFLG(1..)   : # Obligatory Flags (Y/N)
Variable Char     ERRMES()         : # Error message

Local  Char     LEDCUR(GLONCUR)(1..len(mess(0,2644,1)))    : # Ledger Currencies
Local  Char     LEDCOD(GLONLED)(1..len(mess(0,2644,1)))    : # Ledger Codes
Local  Char     COA(GLONCOA)(1..len(mess(0,2644,1)))       : # Charts of accounts
Local  Char     COAFMT(15)(1..len(mess(0,2644,1)))         : # Charts of accounts Formats
Local  Char     COACOLHEA(GLONAX1)(1..len(mess(0,2644,1))) : # Charts of accounts Column Header

Local  Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Integer APPCASE : APPCASE = 4   : # Application case

[L]ASTATUS = func FINACM_SYRA._GET_STC(ACTX,APPCASE,COMPANY,USEDACDIE,NBRLED,LEDTYP,LEDCOD,LEDCUR,COA,COAFMT,COACOLHEA,NBRDIE,DIE,DIEFMT,DIECOLHEA,DIEOBYFLG,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR
 ERRMES = ERRMES : End [L]ASTATUS
Endif

End [L]ASTATUS


#####################################################################################################################
## GET_LSTLED
#####################################################################################################################
#**
#* Returns the list of ledger codes defined for the company used as parameter (COMPANY) with the currencies linked to.
#*
#* @param ACTX    Context
#* @param COMPANY Company
#* @param NBRLED  Number of ledger types (max 10)
#* @param LEDCOD  Ledger Codes
#* @param LEDCUR  Ledger Currencies
#* @param ERRMES  Error message
#*!
Funprog GET_LSTLED(ACTX,COMPANY,NBRLED,LEDCOD,LEDCUR,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COMPANY          : # Company
Variable Integer  NBRLED           : # Number of ledger types (max 10)
Variable Char     LEDCOD()(1..)    : # Ledger Codes
Variable Char     LEDCUR()(1..)    : # Ledger Currencies
Variable Char     ERRMES()         : # Error message

Local  Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Integer  ICPY, NBRDIEMAX

ICPY = fmet ACTX.ACACHE.ACPY.AGETINDEX(COMPANY)
If ICPY = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = COMPANY-mess(16,104,1) : End [L]ASTATUS
Endif
NBRDIEMAX = fmet ACTX.ACACHE.ACPY.AGETVALNUM(COMPANY,"NBRDIE")

Local Char     COA(GLONCOA)(1..len(mess(0,2644,1)))       : # Chart of accounts
Local Char     COAFMT(15)(1..len(mess(0,2644,1)))         : # Chart of accounts Formats
Local Char     COACOLHEA(GLONAX1)(1..len(mess(0,2644,1))) : # Chart of account Column Header
Local Integer  NBRDIE                                     : # Number of Dimension Types

If NBRDIEMAX>0
 Local Char     DIE(GLONDIE)(1..NBRDIEMAX)                 : # Dimension Types
 Local Char     DIEFMT(15)(1..NBRDIEMAX)                   : # Dimension Types Formats
 Local Char     DIECOLHEA(GLONAX1)(1..NBRDIEMAX)           : # Dimension Types Column Headers
 Local Integer  DIEOBYFLG(1..NBRDIEMAX)                    : # Obligatory Flags (Y/N)
Else
 Local Char     DIE(GLONDIE)                               : # Dimension Types
 Local Char     DIEFMT(15)                                 : # Dimension Types Formats
 Local Char     DIECOLHEA(GLONAX1)                         : # Dimension Types Column Headers
 Local Tinyint  LEDTYP                                     : # Ledger Types
 Local Integer  DIEOBYFLG                                  : # Obligatory Flags (Y/N)
Endif
Local Tinyint  LEDTYP(1..len(mess(0,2644,1)))              : # Ledger Types

Local Integer APPCASE : APPCASE = 5 # Application case

[L]ASTATUS = func FINACM_SYRA._GET_STC(ACTX,APPCASE,COMPANY,1,NBRLED,LEDTYP,LEDCOD,LEDCUR,COA,COAFMT,COACOLHEA,NBRDIE,DIE,DIEFMT,DIECOLHEA,DIEOBYFLG,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR
 ERRMES = ERRMES : End [L]ASTATUS
Endif

End [L]ASTATUS



#####################################################################################################################
## GET_MAINLEDTYP
#####################################################################################################################
#**
#* Returns for the company used as parameter :<ul>
#* <li>The Ledger Type which corresponds to the main General Ledger (LEDTYPGEN)
#* <li>The Ledger Type which corresponds to the main Analytical Ledger (LEDTYPANA)
#* <li>The Ledger Type which corresponds to the main IAS Ledger (LEDTYPIAS)
#* </ul>
#*
#* @param ACTX      Context
#* @param CPYFCY    Company or Site
#* @param LEDTYPGEN Main General Ledger Type
#* @param LEDTYPANA Main Analytical Ledger Type
#* @param LEDTYPIAS Main IAS Ledger Type
#* @param ERRMES    Error message
#*!
Funprog GET_MAINLEDTYP(ACTX,CPYFCY,LEDTYPGEN,LEDTYPANA,LEDTYPIAS,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    CPYFCY      : # Company or Site
Variable Tinyint LEDTYPGEN   : # Main General Ledger Type
Variable Tinyint LEDTYPANA   : # Main Analytical Ledger Type
Variable Tinyint LEDTYPIAS   : # Main IAS Ledger Type
Variable Char    ERRMES()    : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Char    ACMCOD(GLONGCM) : # Accounting core model
Local Integer IACM

[L]ASTATUS = func FINACM_SYRA.GET_GCM(ACTX,CPYFCY,ACMCOD,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

IACM = fmet ACTX.ACACHE.GGCM.AGETINDEX(ACMCOD)
If IACM = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = ACMCOD-mess(198,105,1) : End [L]ASTATUS
Endif
LEDTYPGEN = fmet ACTX.ACACHE.GGCM.AGETVALNUM(ACMCOD,"LEDTYPGEN")
LEDTYPANA = fmet ACTX.ACACHE.GGCM.AGETVALNUM(ACMCOD,"LEDTYPANA")
LEDTYPIAS = fmet ACTX.ACACHE.GGCM.AGETVALNUM(ACMCOD,"LEDTYPIAS")
End [L]ASTATUS

########################################################################################################
## GET_LSTLEDTYP
########################################################################################################
#**
#* Returns the list of ledger types defined for the company used as parameter (COMPANY). This list depends on the APPCASE parameter
#*
#* @param ACTX      Contexte
#* @param COMPANY   Company
#* @param APPCASE   0 = returns all the ledgers
#*                  1 = returns only the non automatic ledgers
#*                  2 = returns only the automatic ledgers
#*                  3 = returns only the non automatic ledgers ticked "analytical ledger"
#*                  4 = returns only the ledgers ticked "budget ledger"
#* @param NBRLED    Number of the ledger types
#* @param LEDTYP    List of the ledgers types
#* @param ERRMES    Error message
#*!

Funprog GET_LSTLEDTYP(ACTX,COMPANY,APPCASE,NBRLED,LEDTYP,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COMPANY          : # Company
Value    Integer  APPCASE          : # Application cases
Variable Integer  NBRLED           : # Number of ledger types
Variable Tinyint  LEDTYP(1..)      : # List of ledger types
Variable Char     ERRMES()         : # Error message

Local Char    ACMCOD(GLONGCM)      : # Accounting core model ofthe company
Local Integer IACM, ILED           : # Search index
Local Integer I
Local Char    LISLED(GLONLED)(1..len(mess(0,2644,1))) : # List of all the ledger codes. Allows to know if it is an automatic ledger
Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Raz NBRLED
Raz LEDTYP
[L]ASTATUS = func FINACM_SYRA.GET_GCM(ACTX,COMPANY,ACMCOD,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

IACM = fmet ACTX.ACACHE.GGCM.AGETINDEX(ACMCOD)
If IACM = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = ACMCOD-mess(198,105,1) : End [L]ASTATUS
Endif

For I=1 To len(mess(0,2644,1))
 LED = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(ACMCOD,"LED"+num$(I))
 If LED<>""
  ILED = fmet ACTX.ACACHE.LED.AGETINDEX(LED)
  If ILED = [V]CST_ANOTDEFINED
   [L]ASTATUS = [V]CST_AERROR : ERRMES = mess(208,111,1)-LED-mess(23,100,1) : Break
  Endif
  Case APPCASE
   When 0 : NBRLED+=1 : LEDTYP(NBRLED)=I
   When 1 : If !find(LED,LISLED) : NBRLED+=1 : LEDTYP(NBRLED)=I : Endif
   When 2 : If find(LED,LISLED)  : NBRLED+=1 : LEDTYP(NBRLED)=I : Endif
   When 3 : If !find(LED,LISLED) & fmet ACTX.ACACHE.LED.AGETVALNUM(LED,"LEDFLGANA")=2
             NBRLED+=1 : LEDTYP(NBRLED)=I
            Endif
   When 4 : If fmet ACTX.ACACHE.LED.AGETVALNUM(LED,"LEDFLGBUD")=2 : NBRLED+=1 : LEDTYP(NBRLED)=I : Endif
  Endcase
  LISLED(I) = LED
 Endif
Next
End [L]ASTATUS

#####################################################################################################################
## GET_LEDCUR
#####################################################################################################################
#**
#* Returns for the company and the Ledger Type used as parameter :<ul>
#* <li>The Ledger Code
#* <li>The Ledger Currency
#* </ul>
#*
#* @param ACTX    Context
#* @param COMPANY Company
#* @param LEDTYP  Ledger Type
#* @param LEDCOD  Ledger Code
#* @param LEDCUR  Ledger Currency
#* @param ERRMES  Error message
#*!
Funprog GET_LEDCUR(ACTX,COMPANY,LEDTYP,LEDCOD,LEDCUR,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COMPANY() : # Company
Value    Integer  LEDTYP    : # Ledger Type
Variable Char     LEDCOD()  : # Ledger Code
Variable Char     LEDCUR()  : # Ledger Currency
Variable Char     ERRMES()  : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

If LEDTYP<1 : End [L]ASTATUS : Endif

If adxtyp=33 | !clalev([F:GCM]) : Local File GACM      [GCM] : Endif

Local Char    ACMCOD(GLONGCM) : # Accounting core model
Local Integer ICPY, IACM

ICPY=fmet ACTX.ACACHE.ACPY.AGETINDEX(COMPANY)
If ICPY = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = COMPANY-mess(16,104,1) : End [L]ASTATUS
Endif
ACMCOD = fmet ACTX.ACACHE.ACPY.AGETVALCHAR(COMPANY,"ACM")
IACM = fmet ACTX.ACACHE.GGCM.AGETINDEX(ACMCOD)
If IACM = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = ACMCOD-mess(198,105,1) : End [L]ASTATUS
Endif
If IACM
 LEDCOD = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(ACMCOD,"LED"+num$(LEDTYP))
 LEDCUR = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(ACMCOD,"CUR"+num$(LEDTYP))
Endif
End [L]ASTATUS


#####################################################################################################################
## _GET_STC
#####################################################################################################################
#**
#* Called by the following public subprograms : GET_FINSTC, GET_FINREDSTC, GET_ANASTC, GET_ANAREDSTC, GET_LSTLED
#*
#* @private
#* @param ACTX      Context
#* @param APPCASE   Application case
#* @param COMPANY   Company
#* @param USEDACDIE 1:If the [F:CPY]DACDIE Flag must NOT be used / 2:If the [F:CPY]DACDIE Flag must be used
#* @param NBRLED    Number of ledger types (max 10)
#* @param LEDTYP    Ledger Type (Position 1:Main General, Position 2:Main Analytical)
#* @param LEDCOD    Ledger Code
#* @param LEDCUR    Ledger Currency
#* @param COA       Chart of accounts
#* @param COAFMT    Chart of accounts Formats
#* @param COACOLHEA Chart of account Column Header
#* @param NBRDIE    Number of Dimension Types (max 20)
#* @param DIE       Axes
#* @param DIEFMT    Dimension Types Formats
#* @param DIECOLHEA Dimension Types Column Header
#* @param DIEOBYFLG Mandatory (O/N)
#* @param ERRMES    Error message
#*!
Funprog _GET_STC(ACTX,APPCASE,COMPANY,USEDACDIE,NBRLED,LEDTYP,LEDCOD,LEDCUR,COA,COAFMT,COACOLHEA,NBRDIE,DIE,DIEFMT,DIECOLHEA,DIEOBYFLG,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Integer  APPCASE          : # Application case
Value    Char     COMPANY          : # Company
Value    Integer  USEDACDIE        : # 1:If the [F:CPY]DACDIE Flag must NOT be used / 2:If the [F:CPY]DACDIE Flag must be used
Variable Integer  NBRLED           : # Number of ledger types (max 10)
Variable Tinyint  LEDTYP(1..)      : # Ledger Type (Position 1:Main General, Position 2:Main Analytical)
Variable Char     LEDCUR()(1..)    : # Ledger Currency
Variable Char     LEDCOD()(1..)    : # Ledger Code
Variable Char     COA()(1..)       : # Chart of accounts
Variable Char     COAFMT()(1..)    : # Chart of accounts Formats
Variable Char     COACOLHEA()(1..) : # Chart of account Column Header
Variable Integer  NBRDIE           : # Number of Dimension Types (max 20)
Variable Char     DIE()(1..)       : # Axes (DIE)
Variable Char     DIEFMT()(1..)    : # Dimension Types Formats
Variable Char     DIECOLHEA()(1..) : # Dimension Types Column Header
Variable Integer  DIEOBYFLG(1..)   : # Mandatory (O/N)
Variable Char     ERRMES()         : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Char    ACMCOD(GLONGCM)
Local Char    LLED(GLONLED)
Local Char    DIECOD(GLONDIE)
Local Integer I, J
Local Integer IACM, ILED, ICOA, IDIE, ICPY
Local Integer NBRMAINLED                    : # Number of main ledger types (max 3)
Local Integer NBRDIEMAX                     : # Number of dimensions type managed by the company
Local Integer FLGDACDIE                     : # 'Upstream Entry' Flag for the dimension types

ICPY = fmet ACTX.ACACHE.ACPY.AGETINDEX(COMPANY)
If ICPY = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = COMPANY-mess(16,104,1) : End [L]ASTATUS
Endif
NBRDIEMAX = fmet ACTX.ACACHE.ACPY.AGETVALNUM(COMPANY,"NBRDIE")

If NBRDIEMAX>0
 Local Char    DIECODCPY(GLONDIE)(1..NBRDIEMAX)     : # Dimension Types managed by the company
 Local Integer OBYDIECPY(1..NBRDIEMAX)              : # Dimension Types managed by the company
 Local Integer DACDIECPY(1..NBRDIEMAX)              : # Dimension Types managed by the company
 ICPY = fmet ACTX.ACACHE.CPYDIE.AGETINDEX(COMPANY)

 For I=1 To NBRDIEMAX
  DIECODCPY(I) =  fmet ACTX.ACACHE.CPYDIE.AGETVALCHAR(COMPANY,"DIE"+num$(I))
  OBYDIECPY(I) =  fmet ACTX.ACACHE.CPYDIE.AGETVALNUM(COMPANY,"OBYDIE"+num$(I))
  DACDIECPY(I) =  fmet ACTX.ACACHE.CPYDIE.AGETVALNUM(COMPANY,"DACDIE"+num$(I))
 Next
Endif

ACMCOD = fmet ACTX.ACACHE.ACPY.AGETVALCHAR(COMPANY,"ACM")

Case APPCASE
 When 1, 3, 5
  Gosub GET_LED_COA
  If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 When 2, 4
  Raz NBRDIE
  For I=1 To NBRLED
   LEDCOD(I) = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(ACMCOD,"LED"+num$(LEDTYP(I)))
   LEDCUR(I) = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(ACMCOD,"CUR"+num$(LEDTYP(I)))
   ILED = fmet ACTX.ACACHE.LED.AGETINDEX(LEDCOD(I))
   If ILED = [V]CST_ANOTDEFINED
    [L]ASTATUS = [V]CST_AERROR : ERRMES = mess(208,111,1)-LEDCOD(I)-mess(23,100,1) : Break
   Endif
   COA(I)    = fmet ACTX.ACACHE.LED.AGETVALCHAR(LEDCOD(I),"LEDCOA")
   [L]ASTATUS = func FINACC_SYRA.GET_COAFMT(ACTX,COA(I),COAFMT(I),ERRMES)
   If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
   [L]ASTATUS = func FINACC_SYRA.GET_COACOLHEA(ACTX,COA(I),COACOLHEA(I),ERRMES)
   If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
   Gosub GET_DIMENSIONS
   If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
  Next
  If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
Endcase
End [L]ASTATUS

$GET_LED_COA
Raz NBRLED, NBRDIE

IACM = fmet ACTX.ACACHE.GGCM.AGETINDEX(ACMCOD)
If IACM = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = ACMCOD-mess(198,105,1) : Return
Endif

## Firstly, we load the 3 main ledgers (Social, Analytical, IAS), with their chart of accounts and dimension types
NBRLED = 1
LEDTYP(NBRLED) = fmet ACTX.ACACHE.GGCM.AGETVALNUM(ACMCOD,"LEDTYPGEN")
LEDCOD(NBRLED) = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(ACMCOD,"LEDGEN")
LEDCUR(NBRLED) = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(ACMCOD,"CUR"+num$(LEDTYP(NBRLED)))
If fmet ACTX.ACACHE.GGCM.AGETVALNUM(ACMCOD,"LEDTYPGEN")<>fmet ACTX.ACACHE.GGCM.AGETVALNUM(ACMCOD,"LEDTYPANA")
 NBRLED += 1
 LEDTYP(NBRLED) = fmet ACTX.ACACHE.GGCM.AGETVALNUM(ACMCOD,"LEDTYPANA")
 LEDCOD(NBRLED) = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(ACMCOD,"LEDANA")
 LEDCUR(NBRLED) = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(ACMCOD,"CUR"+num$(LEDTYP(NBRLED)))
Endif
If fmet ACTX.ACACHE.GGCM.AGETVALNUM(ACMCOD,"LEDTYPIAS")<>AVOID.AINT
& & fmet ACTX.ACACHE.GGCM.AGETVALNUM(ACMCOD,"LEDTYPGEN")<>fmet ACTX.ACACHE.GGCM.AGETVALNUM(ACMCOD,"LEDTYPIAS")
& & fmet ACTX.ACACHE.GGCM.AGETVALNUM(ACMCOD,"LEDTYPANA")<>fmet ACTX.ACACHE.GGCM.AGETVALNUM(ACMCOD,"LEDTYPIAS")
 NBRLED += 1
 LEDTYP(NBRLED) = fmet ACTX.ACACHE.GGCM.AGETVALNUM(ACMCOD,"LEDTYPIAS")
 LEDCOD(NBRLED) = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(ACMCOD,"LEDIAS")
 LEDCUR(NBRLED) = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(ACMCOD,"CUR"+num$(LEDTYP(NBRLED)))
Endif
NBRMAINLED = NBRLED

## Secondly, we load the other ledger types
For I=1 To len(mess(0,2644,1))
 If !find(I,LEDTYP(1..NBRMAINLED))
  LLED = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(ACMCOD,"LED"+num$(I))
  If LLED<>"" & !find(LLED,LEDCOD(1..NBRLED)) : # Allows to exclude the Automatic Ledger Types....
   NBRLED += 1
   LEDTYP(NBRLED) = I
   LEDCOD(NBRLED) = LLED
   LEDCUR(NBRLED) = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(ACMCOD,"CUR"+num$(I))
  Endif
 Endif
Next

If APPCASE = 5 : Return : Endif

For I=1 To NBRLED
 ILED = fmet ACTX.ACACHE.LED.AGETINDEX(LEDCOD(I))
 If ILED = [V]CST_ANOTDEFINED
  [L]ASTATUS = [V]CST_AERROR : ERRMES = mess(208,111,1)-LEDCOD(I)-mess(23,100,1) : Break
 Endif
 If ILED
  COA(I)    = fmet ACTX.ACACHE.LED.AGETVALCHAR(LEDCOD(I),"LEDCOA")
  [L]ASTATUS = func FINACC_SYRA.GET_COAFMT(ACTX,COA(I),COAFMT(I),ERRMES)
  If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
  [L]ASTATUS = func FINACC_SYRA.GET_COACOLHEA(ACTX,COA(I),COACOLHEA(I),ERRMES)
  If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
  Gosub GET_DIMENSIONS
  If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
 Endif
Next I
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return


$GET_DIMENSIONS
If NBRDIE>=NBRDIEMAX | NBRDIEMAX=0 : Return : Endif
For IDIE=1 To fmet ACTX.ACACHE.LED.AGETVALNUM(LEDCOD(I),"LEDDIENBR")
 DIECOD = fmet ACTX.ACACHE.LED.AGETVALCHAR(LEDCOD(I),"DIE"+num$(IDIE))
 J = find(DIECOD,DIECODCPY(1..NBRDIEMAX))
 If J<>0
  FLGDACDIE = DACDIECPY(J)
 Else
  FLGDACDIE = 2
 Endif
 If DIECOD<>"" & !find(DIECOD,DIE(1..NBRDIE)) & NBRDIE<dim(DIE) & (USEDACDIE<>2 | FLGDACDIE=2)
  NBRDIE       += 1
  DIE(NBRDIE)  = DIECOD
  [L]ASTATUS = func FINCCE_SYRA.GET_DIEFMT(ACTX,DIE(NBRDIE),DIEFMT(NBRDIE),ERRMES)
  If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
  [L]ASTATUS = func FINCCE_SYRA.GET_DIECOLHEA(ACTX,DIE(NBRDIE),DIECOLHEA(NBRDIE),ERRMES)
  If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
  J = find(DIECOD,DIECODCPY(1..NBRDIEMAX))
  If J<>0
   DIEOBYFLG(NBRDIE) = OBYDIECPY(J)
  Else
   DIEOBYFLG(NBRDIE) = 1
  Endif
  If NBRDIE>=NBRDIEMAX : Break : Endif
 Endif
Next IDIE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

