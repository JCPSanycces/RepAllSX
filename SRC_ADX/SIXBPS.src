#<AdxTL>@(#)4.0.0.0 $Revision$
#########################################################################
#  SIXBPS : pour traitements de bascule Integrale --> X3                #
#########################################################################
#                                                                       #
# Subprog SIXBPS                                                        #
#     Création des fournisseurs                                         #
#########################################################################
#Dbgaff
Gosub SI_CONTEXT From SI_FONCTION
SI_SIMU=2
Local File SIPARX3  [SPX]
Read [SPX] First
Call EXEC From SIXBPS
End

#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE

If GTRACE = ""
#  "Migration des fournisseurs"
    Call OUVRE_TRACE("SIXBPS : "+SI_MES(34)) From LECFIC     
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR
#---- Création enregistrement BPSUPPLIER ------#
Call ECR_TIME("SI_BPSUPPLIER : "+mess(213,124,1)+" BPSUPPLIER") From DOSSUB
Call SI_BPSUPPLIER
If GOK<>1 : Onerrgo : Goto FIN_FIN : Endif


$FIN_FIN
If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End


$TRT_ERR
    Call ECR_TRACE( "ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
    GOK = 0
    GIMPORT=0    # CCC (25/04/08) Bug 47131
Resume


#########################################################################
# Création des fournisseurs
#########################################################################
Subprog SI_BPSUPPLIER

########--------------------------------------------------------- Ouvertures tables X3 #
If !clalev([F:FCY])  : Local File =SI_DOSSIER+".FACILITY"   [FCY] : Endif   # Socièté
If !clalev([F:BPS])  : Local File =SI_DOSSIER+".BPSUPPLIER" [BPS] : Endif   # Fournisseur
If !clalev([F:BPT])  : Local File =SI_DOSSIER+".BPCARRIER"  [BPT] : Endif   # Transporteur 
If !clalev([F:BPR])  : Local File =SI_DOSSIER+".BPARTNER"   [BPR] : Endif   # Business Partner
If !clalev([F:BPA])  : Local File =SI_DOSSIER+".BPADDRESS"  [BPA] : Endif   # Adresses
If !clalev([F:BID])  : Local File =SI_DOSSIER+".BID"        [BID] : Endif   # Relevé Identité Bancaire
If !clalev([F:TCY])  : Local File =SI_DOSSIER+".TABCOUNTRY" [TCY] : Endif   # Pays
If !clalev([F:TCU])  : Local File =SI_DOSSIER+".TABCUR"     [TCU] : Endif   # Devises
If !clalev([F:TMD])  : Local File =SI_DOSSIER+".TABMODELIV" [TMD] : Endif   # Livraison
If !clalev([F:TLA])  : Local File =SI_DOSSIER+".TABLAN"     [TLA] : Endif   # Langues
If !clalev([F:ABN])  : Local File =SI_DOSSIER+".ABANK"      [ABN] : Endif   # Banque
If !clalev([F:BPD])  : Local File =SI_DOSSIER+".BPDLVCUST"  [BPD] : Endif   # Clients livrés
If !clalev([F:CNT])  : Local File =SI_DOSSIER+".CONTACT"    [CNT] : Endif   # Contact
If !clalev([F:AIN])  : Local File =SI_DOSSIER+".CONTACTCRM" [AIN] : Endif   # Contact crm
If !clalev([F:BSG])  : Local File =SI_DOSSIER+".BPSCATEG"   [BSG] : Endif   # Categorie fournisseur 
If !clalev([F:CAC])  : Local File =SI_DOSSIER+".GACCCODE"   [CAC] : Endif   # Codes comptables   # hcb 70899


If !clalev([F:ADI])  : Local File =SI_DOSSIER+".ATABDIV"    [ADI] : Endif   # table diverse
If !clalev([F:AXX])  : Local File =SI_DOSSIER+".ATEXTRA"    [AXX] : Endif   # Textes
If !clalev([F:ATZ])  : Local File =SI_DOSSIER+".ATABZON"    [ATZ] : Endif   # Libellé rubrique 

########--------------------------------------------------------- Ouvertures tables Integrale #

If !clalev([F:XFOU]) : Local File =SI_DOSSIER+".XIFOU"      [XFOU] : Endif  # Fournisseurs
If !clalev([F:XDQE]) : Local File =SI_DOSSIER+".XIFOUDMBQE" [XDQE] : Endif  # Domiciliation bancaire 
If !clalev([F:XBLN]) : Local File =SI_DOSSIER+".XIBLNFIC"   [XBLN] : Endif  # Bloc notes
If !clalev([F:XITL]) : Local File =SI_DOSSIER+".XIITLFOU"   [XITL] : Endif  # Contacts  

########--------------------------------------------------------- Définitions rubriques # 

Local Integer STOP
Local Integer LRET
Local Integer LERR    # 0=OK 1=Erreur => pas d'écriture de l'enregistrement
Local Char    BPA_ADD_ATABZON(25)
Local Char    PTE_ATABZON(25)
Local Char    BPS_INV_ATABZON(25) 
Local Char    BPR_PAY_ATABZON(25) 
Local Char    BPS_RSK_ATABZON(25) 
Local Char    ACC_COD_ATABZON(25) 
Local Char    VAC_BPR_ATABZON(25) 
Local Integer I

########--------------------------------------------------------- Initialisation variables contextuelles #

SI_SUBPRG = "SIXBPS"
SI_TABLE  = "XIFOU"
Gosub SI_CRITSUP From SIXFONCTION

########--------------------------------------------------------- Récuperation des correspondances #

# regime de TVA  table diverse 1
SI_TABLE = "BPSUPPLIER"
Gosub SI_INIVALEUR From SIXFONCTION
GIMPORT = 2   


# mémorisation libellé devise
Call TEXTFIC("BPSUPPLIER","BPAADD",2,BPA_ADD_ATABZON) From OBJDIV  
# mémorisation libellé condition paiement
Call TEXTFIC("BPSUPPLIER","PTE",2,PTE_ATABZON) From OBJDIV  
# mémorisation libellé client facture 
Call TEXTFIC("BPSUPPLIER","BPSINV",2,BPS_INV_ATABZON) From OBJDIV  
# mémorisation libellé tiers paye  
Call TEXTFIC("BPSUPPLIER","BPRPAY",2,BPR_PAY_ATABZON) From OBJDIV  
# mémorisation libellé tiers risque  
Call TEXTFIC("BPSUPPLIER","BPSRSK",2,BPS_RSK_ATABZON) From OBJDIV  
# mémorisation libellé code comptable  
Call TEXTFIC("BPSUPPLIER","ACCCOD",2,ACC_COD_ATABZON) From OBJDIV  
# mémorisation Regime taxe   
Call TEXTFIC("BPSUPPLIER","VACBPR",2,VAC_BPR_ATABZON) From OBJDIV  


########--------------------------------------------------------- Traitement #

$LOOP_FOU

Call DEBTRANS From GLOCK

#SI_CRITERE = "CODFOU = 'DIVERS'"

# Traitement des fournisseurs
For [XFOU] Where left$(CODFOU,2)<>"$$"
&              & FLGREP <2
&              & evalue(SI_CRITERE)

    Trbegin [BPS]

    Call AFFBOITE([F:XFOU]CODFOU) From SUBSIM

    LERR = 0

    # creation fournisseur (BPSUPPLIER)
    If LERR = 0
       Gosub CRE_BPS
       If GOK <= 0 & SI_SIMU <> 2
          Break
       Endif
    Endif

    #----    creation RIB (BID)
    If LERR = 0
       Gosub CRE_BID 
       If GOK <= 0 & SI_SIMU <> 2 
          Break
       Endif
    Endif

    # creation business partner (BPARTNER)
    If LERR = 0
       Gosub CRE_BPR
       If GOK <= 0 & SI_SIMU <> 2 
          Break
       Endif
    Endif

    #----    creation adresse (BPADDRESS)
    If LERR = 0
       Gosub CRE_BPA 
       If GOK <= 0 & SI_SIMU <> 2 
          Break
       Endif
    Endif

    #----    creation contact (CONTACT)
    If LERR = 0
       Gosub CRE_CNT 
       If GOK <= 0 & SI_SIMU <> 2 
          Break
       Endif
    Endif

    If LERR=0 & SI_SIMU<>2
#      Readlock [XFOU] Curr
       [F:XFOU]FLGREP = 2
       Rewrite [XFOU]
       Commit
    Else
        Rollback
    Endif
Next


If SI_SIMU<>2

#----    creation transporteur (BPCARRIER)

     Gosub CRE_BPT 

# si pas simulation controle que  le fournisseur groupe et facture existent 
    If !clalev([F:BPS1])  : Local File =SI_DOSSIER+".BPSUPPLIER" [BPS1] : Endif   # Fournisseur
    Local Integer WCTRBPC
    Call DEBTRANS From GLOCK
    For [BPS] 
        Raz WCTRBPC 
        If [F:BPS]BPSINV <> "" & [F:BPS]BPSINV <> [F:BPS]BPSNUM 
           Look [BPS1]BPS0=[F:BPS]BPSINV
           If fstat
              # Fournisseur facture inexistant
              Call ECR_TRACE(mess(24,121,1)-[F:BPS]BPSNUM+SI_MES(35)-"("+[F:BPS]BPSINV+")",-1) From GESECRAN
              WCTRBPC += 2
           Endif
        Endif
        If [F:BPS]BPSGRU <> "" & [F:BPS]BPSGRU <> [F:BPS]BPSNUM 
           Look [BPS1]BPS0=[F:BPS]BPSGRU
           If fstat
              # Fournisseur groupe inexistant
              Call ECR_TRACE(mess(24,121,1)-[F:BPS]BPSNUM+SI_MES(36)-"("+[F:BPS]BPSGRU+")",-1) From GESECRAN
              WCTRBPC += 4
           Endif
        Endif
        If WCTRBPC <> 0
           Trbegin [BPS]
#           Readlock [BPS] Curr
           Case  WCTRBPC 
                 When 2,6
                      Raz [F:BPS]BPSINV
                 When 4,6
                      Raz [F:BPS]BPSGRU
           Endcase
           Rewrite [BPS]
           If LERR=0 & SI_SIMU<>2
              Commit
           Else
              Rollback
           Endif
        Endif
    Next


# si pas simulation controle que  le transporteur du fichier BPDLVCUST (client livré) existe 
    If !clalev([F:BPD])  : Local File =SI_DOSSIER+".BPDLVCUST"  [BPD] : Endif   # Clients livrés
    Call DEBTRANS From GLOCK
    For [BPD] Where [F:BPD]BPTNUM <> "" 

        Look [BPT]BPT0=[F:BPD]BPTNUM
        If fstat
       # transporteur inexistant
           Call ECR_TRACE(mess(42,191,1)-[F:BPD]BPTNUM+SI_MES(41)-"("+[F:BPD]BPTNUM+")",-1) From GESECRAN
           Trbegin [BPD]

#          Readlock [BPD] Curr
           Raz [F:BPD]BPTNUM
           Rewrite [BPD]
           If LERR=0 & SI_SIMU<>2
              Commit
           Else
              Rollback
           Endif
        Endif 
    Next

Endif

GIMPORT=0    # CCC (25/04/08) Bug 47131
End


##################################################################
#  Creation BPSUPPLIER 
#  le fournisseur peut deja existé comme client ..........
##################################################################
$CRE_BPS
Raz [F:BPS]

[F:BPS]BSGCOD    = [F:SPX]BSGCOD         # catégorie

GPE = 0
SI_TABLE = "BPSUPPLIER"
Gosub SI_INIVALEUR From SIXFONCTION
If GPE = 0
   Read [BSG]BSG0   = [F:BPS]BSGCOD
   If fstat 
      Raz [F:BSG] 
      Call ECR_TRACE(mess(24,121,1)-[F:XFOU]CODFOU-" : "-SI_MES(271)+" : "-[F:BPS]BSGCOD , 1) From GESECRAN
      LERR=1
   Endif
Endif

[F:BPS]          = [F:BSG]            # tranclasse categorie fournisseur



# recuperation et controle code fournisseur
If !func SIXFONCTION.SI_CTL("BPSNUM",[F:XFOU]X3CLE,"XIFOU ("+[F:XFOU]CODFOU+")")
    LERR = 1
Else
    [F:BPS]BPSNUM    = [F:XFOU]X3CLE
Endif

# controle existence bpartner
If LERR = 0
   Look [BPR]BPR0 = [F:BPS]BPSNUM
   If !fstat
# si le n° de siret <> "" lecture du bpartner pour le comparer
       If [F:XFOU]NUMSIRET <> "             0"
          Read [BPR]BPR0 = [F:BPS]BPSNUM
          If fstat
             Raz [F:BPR]
          Endif
       # si le n° de siret fournisseur <> n° de siret bpartner ==> erreur
       #  Business Partner existant avec N° Siret différent !
          If [F:BPR]CRN <> "" &  [F:BPR]CRN <> [F:XFOU]NUMSIRET  
             Call ECR_TRACE(mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"+SI_MES(37), 1) From GESECRAN
             LERR = 1
             Return
          Endif
       Endif
# controle meme code postal 
       If [F:XFOU]CODPST <> "" 
          Filter [BPA] Where [F:BPA]BPANUM = [F:BPS]BPSNUM
&                Order By Key BPA0
          For [BPA]
              If [F:BPA]POSCOD <> [F:XFOU]CODPST
                 Call ECR_TRACE(mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"+SI_MES(38), 1) From GESECRAN
                 LERR = 1
                 Break 
              Endif
          Next
          Filter [BPA]
          If LERR = 1
             Return
          Endif 
       Endif
   Endif
Endif

[F:BPS]BPRPAY  = func SIXFONCTION.SI_COR("XIFOU",[F:XFOU]TIERGL ,"",mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-mess(549,197,1))  # Tiers payé 
# pour le Transporteur une moulinette est faite apres creation des fournisseurs pour creer BPCARRIER
[F:BPS]BPTNUM  = func SIXFONCTION.SI_COR("XIFOU",[F:XFOU]TSP ,"",mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-mess(3,277,1))     # Transporteur  

[F:BPS]BPSREM      = [F:XFOU]CMT       # observations  

If [F:XFOU]CPTAUX <> [F:XFOU]X3CLE
   If [F:BPS]BPSREM = ""
      [F:BPS]BPSREM = "CPT_AUX Intégrale : "
      [F:BPS]BPSREM += [F:XFOU]CPTAUX 
   Else
      Local Char WLIB1(100)
      WLIB1 = format$("K:46Xb",[F:BPS]BPSREM)
      WLIB1 += "CPT_AUX Intégrale : "
      WLIB1 += [F:XFOU]CPTAUX 
      [F:BPS]BPSREM = WLIB1
   Endif
Endif

[F:BPS]CREDAT      = [F:XFOU]DATCRE    # date création    
If [F:BPS]CREDAT   = [0/0/0]
   [F:BPS]CREDAT   = date$
   [F:BPS]CREUSR   = GUSER
Endif
[F:BPS]UPDDAT      = date$             # date modification
[F:BPS]UPDUSR      = GUSER             # operateur modification

If [F:XFOU]FLGSML   = "O"               
   [F:BPS]ENAFLG   = 1                 # fournisseur actif
Else
   [F:BPS]ENAFLG   = 2                 # fournisseur actif 
Endif

If [F:XFOU]NAT      = "D"                 
   [F:BPS]BPSTYP   = 3                 # type (divers)
Endif

[F:BPS]BPSNAM      = [F:XFOU]NOM       # raison sociale            
#                                      
If find([F:XFOU]ASJTVA,"O","N","C","I")
    [F:BPS]VACBPR=func SIXFONCTION.SI_VACBPR("S",[F:XFOU]ASJTVA,"","",[F:XFOU]CODPAY)
Endif
# Devise
If dim([F:BPS]CUR) > 0
   If [F:XFOU]CODDVS <> ""
      [F:BPS]CUR = func SIXFONCTION.SI_COR("XIDVS",[F:XFOU]CODDVS,"TABCUR",mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")")
   Endif
Endif
# Famille statistique (Famille)
If [F:XFOU]CODFAM <> "" & dim([F:BPS]TSSCOD(0))>0
   [F:BPS]TSSCOD(0) = func SIXFONCTION.SI_COR("XIFAMFOU",[F:XFOU]CODFAM,"40",mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")")
Endif
# Famille statistique (Sous famille)
If [F:XFOU]CODSOUFAM <> ""  & dim([F:BPS]TSSCOD(1))>0
   [F:BPS]TSSCOD(1) = func SIXFONCTION.SI_COR2("XISOUFMFOU",[F:XFOU]CODFAM,[F:XFOU]CODSOUFAM,"41",mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")")
Endif
# Condition paiement 
If [F:XFOU]RGL <> ""
   [F:BPS]PTE       = func SIXFONCTION.SI_COR2("XIMODRGL",left$([F:XFOU]RGL,2),right$([F:XFOU]RGL,3),"TABPAYTERM",mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")")
Endif
# Mode livraison  
If [F:XFOU]MODEXD <> ""
   [F:BPS]MDL       = func SIXFONCTION.SI_COR("XIMODEXD",[F:XFOU]MODEXD,"TABMODELIV",mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")")
Endif

# recuperation element de facturation suivant parametrage
Local Integer I
Local Integer Y
Raz I
Raz Y
For I = 0 To 7
    If [F:SPX]PFINUM(I) <> 0
       If I = 5 : # C'est un escompte en %
          [F:BPS]INVDTA(Y)    = [F:SPX]PFINUM(I)
          [F:BPS]INVDTAAMT(Y) = [F:XFOU]PRCEPT 
          [F:BPS]AMTCOD(Y)    = 1
       Else
          [F:BPS]INVDTA(Y)    = [F:SPX]PFINUM(I)
          [F:BPS]INVDTAAMT(Y) = 0
          [F:BPS]AMTCOD(Y)    = 2
       Endif
       Y += 1
    Endif 
Next



If [F:XFOU]NBREXLBR > 0
   [F:BPS]NRTPRNFLG = 2             # Bon retour
Endif
If [F:XFOU]NBREXLCMD > 0
   [F:BPS]NORPRNFLG = 2             # Bon commande
Endif
If [F:XFOU]NBREXLLIV > 0
   [F:BPS]NREPRNFLG = 2             # Bon reception
Endif

#---- Reprise du bloc-notes ------#
Read [XBLN]IND0="FO";[F:XFOU]CODFOU
Raz SI_CLOB,I
If !fstat
    For I=1 To 18
        SI_CLOB(I-1) = evalue("[F:XBLN]LIG"+num$(I))
    Next
    [F:BPS]ORDTEX = func SIXFONCTION.SI_CLOB("BPS")
Endif

# initialisation par defaut
# code comptable

# hcb 70899 deb                  
# code comptable
#If [F:BPS]ACCCOD = "" 
#   [F:BPS]ACCCOD = "STD"    # Code comptable inclus dans le dossier de référence. 
#Endif
## comptable par 'STD' (celui livré en standard)
If [F:BPS]ACCCOD = ""
   Read [CAC]CAC0 = 3;"STD"
   If !fstat
      [F:BPS]ACCCOD = "STD"
   Else
      Filter [CAC] Where TYP=3
             Read [CAC]CAC0 First
             If !fstat 
                [F:BPS]ACCCOD = [F:CAC]ACCCOD
             Endif
      Filter [CAC]
   Endif
Endif
# hcb 70899 fin                  

If [F:BPS]BPRPAY = ""  
   [F:BPS]BPRPAY = [F:BPS]BPSNUM     # Tiers  payé
Endif

[F:BPS]BPSINV = [F:BPS]BPRPAY        # Fournisseur facture 

[F:BPS]BPSGRU = [F:BPS]BPSNUM        # Fournisseur groupe  

If dim([F:BPS]BPAPAY) > 0  
   [F:BPS]BPAPAY = "001"             # Adresse tiers  payé   
Endif
If dim([F:BPS]BPAADD) > 0   
   [F:BPS]BPAADD = "001"             # Adresse par defaut    
Endif
If dim([F:BPS]BPAINV) > 0   
   [F:BPS]BPAINV = "001"             # Adresse fournisseur facture
Endif


If dim([F:BPS]BPSRSK ) > 0
   If [F:BPS]BPSRSK = "" 
      [F:BPS]BPSRSK = [F:BPS]BPSNUM  # Tiers risque  
   Endif      
Endif

If [F:BPS]EECLOC    = 0              # Lieu transport CEE  
   [F:BPS]EECLOC    = 1
Endif 
If [F:BPS]SEVLIN    = 0              # Cde multi ligne     
   [F:BPS]SEVLIN    = 2
Endif 
If [F:BPS]OSTCTL    = 0              # Controle en cours   
   [F:BPS]OSTCTL    = 1
Endif 
If [F:BPS]EECINCRAT = 0              # Majoration CEE  
   [F:BPS]EECINCRAT = 1
Endif 
If [F:BPS]DUDCLC    = 0              # Origine echeance    
   [F:BPS]DUDCLC    = 1
Endif 
If [F:BPS]DOUFLG    = 0              # Litige              
   [F:BPS]DOUFLG    = 1
Endif 
If [F:BPS]CHGTYP    = 0              # Type de cours              
   [F:BPS]CHGTYP    = 1
Endif 
If [F:BPS]CURCLC    = 0              # Fixation taux               
   [F:BPS]CURCLC    = 1
Endif 


# Point d'entrée avant écriture
SI_TABLE = "BPSUPPLIER"
Gosub SI_BEFWRI From SIXFONCTION

# test Rubriques obligatoires
# Condition paiement       
If [F:BPS]PTE         = ""
   Call ECR_TRACE(mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-mess(10,123,1)+" : "+PTE_ATABZON, 1) From GESECRAN
   LERR = 1
Endif
# Code comptable        
If [F:BPS]ACCCOD       = ""
   Call ECR_TRACE(mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-mess(10,123,1)+" : "+ACC_COD_ATABZON, 1) From GESECRAN
   LERR = 1
Endif
# Regime taxe        
If [F:BPS]VACBPR       = ""
   Call ECR_TRACE(mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-mess(10,123,1)+" : "+VAC_BPR_ATABZON, 1) From GESECRAN
   LERR = 1
Endif
# Adresse par defaut    
If dim([F:BPS]BPAADD) > 0
   If [F:BPS]BPAADD       = ""
      Call ECR_TRACE(mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-mess(10,123,1)+" : "+BPA_ADD_ATABZON, 1) From GESECRAN
      LERR = 1
   Endif
Endif

# tests suivant uniquement dans le cas d un transcodage correct .........
If [F:BPS]BPSNUM <> ""
# Fournisseur facture       
   If [F:BPS]BPSINV       = ""
      Call ECR_TRACE(mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-mess(10,123,1)+" : "+BPA_INV_ATABZON, 1) From GESECRAN
      LERR = 1
   Endif
# Tiers payé       
   If [F:BPS]BPRPAY       = ""
      Call ECR_TRACE(mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-mess(10,123,1)+" : "+BPR_PAY_ATABZON, 1) From GESECRAN
      LERR = 1
   Endif
# Tiers risque       
   If dim([F:BPS]BPSRSK) > 0
      If [F:BPS]BPSRSK       = ""
         Call ECR_TRACE(mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-mess(10,123,1)+" : "+BPS_RSK_ATABZON, 1) From GESECRAN
         LERR = 1
      Endif
   Endif
Endif

If LERR = 0
   Write [BPS]
   If fstat
      Call ECR_TRACE(mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
      LERR = 1
   Endif
Endif
Return


##################################################################
#  Creation BPARTNER
#  + mise a jour du RIB par defaut dans le fichier BID
##################################################################
$CRE_BPR
Local Integer LEXI
Local Char    LBIDNUM
Raz LEXI
Raz mkstat   # 47061

Look [BPR]BPR0 = [F:BPS]BPSNUM
If fstat <> 0
    Readlock [BPR]BPR0 = [F:BPS]BPSNUM
    If fstat
        Raz [F:BPR]
        [F:BPR]CRY = [F:BSG]CRY
        [F:BPR]LAN = [F:BSG]LAN
        Raz LEXI
    Else
        LEXI = 1
    Endif

    # Rubriques reprises du fournisseur Integrale 
    [F:BPR]EECNUM    = [F:XFOU]NUMIDE           # N° tva intraco
    If [F:XFOU]NUMSIRET <> "             0" 
       [F:BPR]CRN       = [F:XFOU]NUMSIRET   # N° SIRET
    Endif
    # code langue 
    If [F:XFOU]CODLAN <> ""
       [F:BPR]LAN = func SIXFONCTION.SI_COR("XILAN",[F:XFOU]CODLAN,"TABLAN",mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")")
    Endif
    # code pays 
    If [F:XFOU]CODPAY <> ""
       [F:BPR]CRY = func SIXFONCTION.SI_COR("XIPAY",[F:XFOU]CODPAY,"TABCOUNTRY",mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")")
    Endif
   # hcb 46483 
    If [F:BPR]EECNUM <> ""
       Call CONTTVA([F:BPR]EECNUM,[F:BPR]CRY) From CONTNUM
       If mkstat = 2 
          Call ECR_TRACE(mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-GMESSAGE,-1) From GESECRAN
       Endif
    Endif
   # hcb 46588 
    If [F:BPR]CRN <> ""
       Call CONTSIRET([F:BPR]CRN,[F:BPR]CRY,"") From CONTNUM
       If mkstat = 2 
          Call ECR_TRACE(mess(24,121,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-GMESSAGE,-1) From GESECRAN
       Endif
    Endif

    # RIB  
    # lecture du fichier integrale RIB   
    If [F:XFOU]NUMDOMBQE <> 0
       Read [XDQE]IND0 = [F:BPS]BPSNUM;[F:XFOU]NUMDOMBQE
       If fstat
          Raz [F:XDQE]
       Endif
       If [F:XDQE]CODBQE1<> ""
          Raz LBIDNUM
          LBIDNUM += [F:XDQE]CODBQE1
          LBIDNUM += [F:XDQE]CODGUI1
          LBIDNUM += [F:XDQE]NUMCPT1
          LBIDNUM += [F:XDQE]CLERIB1
          Readlock [BID]BID0=1;[F:BPS]BPSNUM;LBIDNUM
          If fstat
             Raz [F:BID]
          Else
       # mise a jour du RIB par defaut dans le fichier BID
             [F:BID]BIDNUMFLG = 2                         # Par defaut
             Rewrite [BID]
          Endif
          [F:BPR]BIDNUM    = [F:BID]BIDNUM     # RIB par défaut
          [F:BPR]BIDCRY    = [F:BID]CRY        # Pays RIB 
       Endif           
    Endif         

    # Rubriques reprises du fournisseur X3
    [F:BPR]BPRNUM    = [F:BPS]BPSNUM          # Tiers
    [F:BPR]BPRSHO    = [F:BPS]BPSSHO          # Intitule court
    If dim([F:BPR]ENAFLG) > 0
       [F:BPR]ENAFLG    = [F:BPS]ENAFLG       # Actif
    Endif
    [F:BPR]ACCCOD    = [F:BPS]ACCCOD          # Code comptable
    [F:BPR]BPRNAM    = [F:BPS]BPSNAM          # Raison social
    If dim([F:BPS]BPAADD) > 0   
       [F:BPR]BPAADD    = [F:BPS]BPAADD       # Adresse par défaut
    Else
       [F:BPR]BPAADD    = "001"               # Adresse par défaut
    Endif
    If dim([F:BPR]CUR) > 0
       If dim([F:BPS]CUR) > 0
         [F:BPR]CUR       = [F:BPS]CUR          # Devise
       Endif
    Endif
    [F:BPR]CREDAT    = [F:BPS]CREDAT          # Date création
    [F:BPR]CREUSR    = [F:BPS]CREUSR          # Opérateur création
    [F:BPR]UPDDAT    = [F:BPS]UPDDAT          # Date modification
    [F:BPR]UPDUSR    = [F:BPS]UPDUSR          # Opérateur modification
          
    # Rubriques par defaut 
    [F:BPR]BPCFLG    = 1                      # Flag client     
    [F:BPR]BPTFLG    = 1                      # Flag transporteur
    [F:BPR]REPFLG    = 1                      # Flag representant
    [F:BPR]FCTFLG    = 1                      # Flag factor
    [F:BPR]BPRFBDMAG = 1                      # Interdit mailing 

    For I = 0 To 3
        [F:BPR]BPRFLG (I) = 1                 # Flag divers
    Next I 
    [F:BPR]BPSFLG    = 2                      # Flag fournisseur

    # Maj
    If LEXI
       [F:BPR]BPSFLG = 2                      # Flag fournisseur
       [F:BPR]UPDDAT = date$ 
       [F:BPR]UPDUSR = GUSER 
       Rewrite [BPR]
    Else
        SI_TABLE = "BPARTNER"
        Gosub SI_BEFWRI From SIXFONCTION
        Write [BPR]
        If fstat
           Call ECR_TRACE("Business Partner"-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
           LERR = 1
        Endif

    Endif
Else
     Readlock [BPR]BPR0 = [F:BPS]BPSNUM
     If fstat = 1
        Call ECR_TRACE("Business Partner"-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-mess(27,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
        LERR = 1
        Return
     Endif
    [F:BPR]BPSFLG    = 2
    [F:BPR]UPDDAT    = date$
    [F:BPR]UPDUSR    = GUSER
    Rewrite [BPR]
Endif

Return


##################################################################
#  Creation BPADDRESS
##################################################################
$CRE_BPA
Local Integer LEXI
Raz LEXI
Local Char LBPAADD(3)
If dim([F:BPS]BPAADD) > 0   
   LBPAADD    = [F:BPS]BPAADD          # Adresse par défaut
Else
   LBPAADD    = "001"                  # Adresse par défaut
Endif

Look [BPA]BPA0 = 1;[F:BPS]BPSNUM;LBPAADD
If fstat <> 0
    Readlock [BPA]BPA0=1;[F:BPS]BPSNUM;LBPAADD
    If fstat
        Raz [F:BPA]
        [F:BPA]CRY = [F:BSG]CRY
        Raz LEXI
    Else
        LEXI = 1
    Endif
    # Rubriques reprises du fournisseur Integrale

    [F:BPA]BPAADDLIG (0) =  [F:XFOU]ADR1      # Ligne adresse 1
    [F:BPA]BPAADDLIG (1) =  [F:XFOU]ADR2      # Ligne adresse 2
    [F:BPA]BPAADDLIG (2) =  [F:XFOU]ADR3      # Ligne adresse 3
    [F:BPA]POSCOD        =  [F:XFOU]CODPST    # Code postal     
    [F:BPA]CTY           =  [F:XFOU]VIL       # Ville 

    Call NUMONLY([F:XFOU]TEL,[F:BPA]TEL) From SIXFONCTION    # Telephone
    Call NUMONLY([F:XFOU]TLC,[F:BPA]FAX) From SIXFONCTION    # Fax   
    [F:BPA]TEL(1)        =  [F:BPA]FAX                       # Fax      # hcb 73119
          
    [F:BPA]WEB           =  [F:XFOU]ADRMAI    # Adresse internet

    # Code pays 
    If [F:XFOU]CODPAY <> ""
       [F:BPA]CRY = func SIXFONCTION.SI_COR("XIPAY",[F:XFOU]CODPAY,"TABCOUNTRY",mess(12,159,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")")
    Endif  
    # Nom pays
    If [F:BPA]CRY <> "" 
       Call LECTEXTRA([F:BPA]CRYNAM,"TABCOUNTRY","CRYDES",[F:BPA]CRY,"") From ATEXTRA
    Endif

    # Rubriques reprises du client X3
    [F:BPA]BPATYP    = 1                      # Type entité
    [F:BPA]BPANUM    = [F:BPS]BPSNUM          # Entité
    [F:BPA]BPAADD    = LBPAADD                # Adresse 
    [F:BPA]CREDAT    = [F:BPS]CREDAT          # Date création
    [F:BPA]CREUSR    = [F:BPS]CREUSR          # Opérateur création
    [F:BPA]UPDDAT    = [F:BPS]UPDDAT          # Date modification
    [F:BPA]UPDUSR    = [F:BPS]UPDUSR          # Opérateur modification
 
    # Rubriques par defaut 
    [F:BPA]BPAADDFLG = 2                      # Par défaut
    [F:BPA]CRETIM    = time                   # Heure
    [F:BPA]UPDTIM    = time                   # Heure

    # Maj
    If LEXI
       [F:BPA]UPDDAT = date$ 
       [F:BPA]UPDUSR = GUSER  
       [F:BPA]UPDTIM = time                   # Heure

       Rewrite [BPA]
    Else
        SI_TABLE = "BPADDRESS"
        Gosub SI_BEFWRI From SIXFONCTION
        Write [BPA]
        If fstat
           Call ECR_TRACE(mess(33,102,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
           LERR = 1
        Endif
    Endif
Endif

Return

##################################################################
#  Creation RIB 
##################################################################
$CRE_BID
Local Integer LEXI
Local Char    BANQUE(GLONBID)

Raz LEXI

# Traitement des domiciliations bancaire  
For [XDQE] Where CODFOU = [F:BPS]BPSNUM
    Raz [F:BID]BIDNUM
    [F:BID]BIDNUM += [F:XDQE]CODBQE1
    [F:BID]BIDNUM += [F:XDQE]CODGUI1
    [F:BID]BIDNUM += [F:XDQE]NUMCPT1
    [F:BID]BIDNUM += [F:XDQE]CLERIB1
    
    Look [BID]BID0 = 1;[F:BPS]BPSNUM;[F:BID]BIDNUM
    If fstat <> 0
       Readlock [BID]BID0=1;[F:BPS]BPSNUM;[F:BID]BIDNUM
       If fstat
          Raz [F:BID]
          [F:BID]CRY = [F:BSG]CRY

          Raz LEXI
       Else
          LEXI = 1
       Endif
       # Rubriques reprises domiciliation bancaire 
       Raz [F:BID]BIDNUM
       [F:BID]BIDNUM += [F:XDQE]CODBQE1
       [F:BID]BIDNUM += [F:XDQE]CODGUI1
       [F:BID]BIDNUM += [F:XDQE]NUMCPT1
       [F:BID]BIDNUM += [F:XDQE]CLERIB1
       [F:BID]BICCOD  = [F:XDQE]CODBIC     # Code BIC       

       # code pays 
       If [F:XDQE]CODPAY <> ""
          [F:BID]CRY = func SIXFONCTION.SI_COR("XIPAY",[F:XDQE]CODPAY,"TABCOUNTRY",mess(12,159,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")")
       Endif
       # lecture Pays pour controle RIB
       If [F:BID]CRY <> "" &  [F:TCY]CRY <> [F:BID]CRY
          Read [TCY]TCY0 = [F:BID]CRY
          If fstat
             Raz [F:TCY]
          Endif
       Endif 
 
       If [F:TCY]BIDCTL=2
           BANQUE = left$([F:XDQE]CODBQE1,[F:TCY]BANLNG)
           Read [ABN]ABN0 = [F:BID]CRY;BANQUE
           If fstat
              Call ECR_TRACE(mess(145,197,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-mess(173,133,1)-[F:TCY]CRY-BANQUE,1) From GESECRAN
              LERR = 1
              Return
           Endif 
       Endif

       # Rubriques reprises de la banque  X3
       [F:BID]PAB1      =  [F:ABN]PAB         # Domiciliation     

       # Rubriques reprises du client X3
       [F:BID]BPATYP    = 1                      # Type entité
       [F:BID]BPANUM    = [F:BPS]BPSNUM          # Entité

       If dim([F:BPS]BPAADD) > 0   
          [F:BID]BPAADD = [F:BPS]BPAADD          # Adresse par défaut
       Else
          [F:BID]BPAADD = "001"                  # Adresse par défaut
        Endif
       [F:BID]CREDAT    = [F:BPS]CREDAT          # Date création
       [F:BID]CREUSR    = [F:BPS]CREUSR          # Opérateur création
       [F:BID]UPDDAT    = [F:BPS]UPDDAT          # Date modification
       [F:BID]UPDUSR    = [F:BPS]UPDUSR          # Opérateur modification

       If dim([F:BPS]CUR) > 0
         [F:BID]CUR       = [F:BPS]CUR          # Devise
       Endif

       # Rubriques par defaut 
       [F:BID]CRETIM    = time                   # Heure
       [F:BID]UPDTIM    = time                   # Heure

       # Maj
       If LEXI
          [F:BID]UPDDAT = date$ 
          [F:BID]UPDUSR = GUSER 
          [F:BID]UPDTIM = time                   # Heure
 
          Rewrite [BID]
       Else
          SI_TABLE = "BID"
          Gosub SI_BEFWRI From SIXFONCTION
          Write [BID]
          If fstat
             Call ECR_TRACE(mess(6,865,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
             LERR = 1
          Endif
       Endif
    Endif
Next

Return


##################################################################
#  Creation BPCARRIER phase 1
##################################################################
# creation des transporteurs :
#  - Lecture des fournisseurs qui ont un transporteur 
#  - Lecture du fournisseur correspondant 

$CRE_BPT
Local Integer LEXI
Local Integer NB
Local Char    LREPRISE
Raz LEXI
If !clalev([F:BPS1])  : Local File =SI_DOSSIER+".BPSUPPLIER" [BPS1] : Endif   # Fournisseur
Raz STOP,LREPRISE 
$LOOP_BPT_CRE
Raz NB
If STOP=1
   CRITERE = "BPSNUM>LREPRISE"
   STOP=0
Else
   CRITERE="1=1"
Endif
Call DEBTRANS From GLOCK
Trbegin [BPS]
Filter [BPS1] Where [F:BPS1]BPTNUM <> "" 
&                 & evalue(CRITERE)
&  Order By Key BPS0
For [BPS1]
If [F:BPS1]BPTNUM  <> [F:BPS1]BPSNUM
   Read [BPS]BPS0  =  [F:BPS1]BPTNUM
   If fstat
      Readlock [BPS1] Curr
      Raz [F:BPS1]BPTNUM
      Rewrite [BPS1]
      NB+=1
   Else 

      Gosub CRE_BPT_2
   Endif
Else
   [F:BPS] = [F:BPS1]
   Gosub CRE_BPT_2
Endif
If NB>1000
   LREPRISE=[F:BPS1]BPSNUM
   STOP=1
   Break
Endif
Next
Filter [F:BPS1]

If GOK>0
   Commit
   If STOP
      Goto LOOP_BPT_CRE
   Endif
Else
   Rollback
Endif

Return

##################################################################
#  Creation BPCARRIER phase 2
##################################################################
# creation des transporteurs :
#  - creation   du BPCARRIER
#  - reecriture du BPARTNER avec bptflg = 2

$CRE_BPT_2
Local Integer LEXI

Look  [BPT]BPT0 = [F:BPS]BPSNUM
If fstat 
   Raz [F:BPT]

   # controle existence bpartner
   Readlock [BPR]BPR0 = [F:BPS]BPSNUM
   If fstat
      # Bpartner inexistant
      Call ECR_TRACE(SI_MES(42)-[F:BPS]BPSNUM,-1) From GESECRAN
      Return
   Endif
   # Rubriques reprises du fournisseur X3 
   [F:BPT]BPTNUM    = [F:BPS]BPSNUM          # Entité
   [F:BPT]BPTSHO    = [F:BPS]BPSSHO          # Intitule court
   If dim([F:BPT]BPAADD) > 0  
      [F:BPT]BPAADD    = [F:BPS]BPAADD       # Adresse
   Endif  
   [F:BPT]CREDAT    = [F:BPS]CREDAT          # Date création
   [F:BPT]CREUSR    = [F:BPS]CREUSR          # Opérateur création
   [F:BPT]UPDDAT    = [F:BPS]UPDDAT          # Date modification
   [F:BPT]UPDUSR    = [F:BPS]UPDUSR          # Opérateur modification
   [F:BPT]BPTNAM    = [F:BPS]BPSNAM          # Raison social         
   If dim([F:BPT]CUR) > 0                      
      [F:BPT]CUR       = [F:BPS]CUR          # Devise               
   Endif
   # Rubriques reprises du bpartner 
   If dim([F:BPT]CNTNAM)> 0
      [F:BPT]CNTNAM    = [F:BPS]CNTNAM        # Contact
   Endif
   # Rubriques par defaut 
   # Maj
   SI_TABLE = "BPCARRIER"
   Gosub SI_BEFWRI From SIXFONCTION
   Write [BPT]
   If fstat
      Call ECR_TRACE(mess(129,198,1)-[F:BPS]BPSNUM-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
      GOK = 0
   Else
      [F:BPR]BPTFLG = 2                      # Flag fournisseur
      [F:BPR]UPDDAT = date$ 
      [F:BPR]UPDUSR = GUSER 
      Rewrite [BPR]
      NB += 2
   Endif

Endif

Return


##################################################################
#  Creation CONTACT
##################################################################
$CRE_CNT
Local Integer LEXI
Local Char WCCNCRM(15) 
Local Integer  WRET  # 47375
Local Char WADR      # 47375  
WADR = "001"         # 47375
        
Raz LEXI

# Traitement des contacts 
For [XITL] Where PFX = "F" & CODTIE = [F:XFOU]CODFOU 
    WCCNCRM = [F:BPS]BPSNUM 
    If [F:XITL]INDX >1
       WCCNCRM += num$([F:XITL]INDX) 
    Endif
    Look [CNT]CNT0 = 1;[F:BPS]BPSNUM;WCCNCRM
    If fstat <> 0
       Readlock [CNT]CNT0=1;[F:BPS]BPSNUM;WCCNCRM
       If fstat
          Raz [F:CNT]
          Raz LEXI
       Else
          LEXI = 1
       Endif
       # Rubriques reprises du client X3
       [F:CNT]BPATYP    = 1                      # Type entité
       [F:CNT]BPANUM    = [F:BPS]BPSNUM          # Entité
       [F:CNT]CCNCRM    = WCCNCRM                # Code   

       If dim([F:BPS]BPAADD) > 0   
          [F:CNT]BPAADD = [F:BPS]BPAADD          # Adresse par défaut
       Else
          [F:CNT]BPAADD = "001"                  # Adresse par défaut
        Endif
#dem 47375 deb
       If  [F:XITL]ADR1   <> "" |   
&          [F:XITL]ADR2   <> "" |     
&          [F:XITL]ADR3   <> "" |   
&          [F:XITL]CODPST <> "" |        
&          [F:XITL]VIL    <> "" |     
&          [F:XITL]ADRMAI <> ""      
           If  [F:XITL]ADR1   =  [F:XFOU]ADR1    &   
&              [F:XITL]ADR2   =  [F:XFOU]ADR2    &    
&              [F:XITL]ADR3   =  [F:XFOU]ADR3    &   
&              [F:XITL]CODPST =  [F:XFOU]CODPST  &       
&              [F:XITL]VIL    =  [F:XFOU]VIL     &    
&              [F:XITL]ADRMAI =  [F:XFOU]ADRMAI     
           Else
               Call PLUS_UN(WADR ,WADR ,WRET) From SIXFONCTION
               If WRET 
                  [F:CNT]BPAADD = "001"              # Adresse par défaut
               Else
                  [F:CNT]BPAADD = WADR               # Adresse par défaut
                  Gosub CRE_BPA_CNT 
                  If GOK <= 0 & SI_SIMU <> 2 
                     Break
                  Endif
               Endif
           Endif
       Endif
#dem 47375 fin

       [F:CNT]CREDAT    = [F:BPS]CREDAT          # Date création
       [F:CNT]CREUSR    = [F:BPS]CREUSR          # Opérateur création
       [F:CNT]UPDDAT    = [F:BPS]UPDDAT          # Date modification
       [F:CNT]UPDUSR    = [F:BPS]UPDUSR          # Opérateur modification
       Call NUMONLY([F:XITL]TEL1,[F:CNT]TEL) From SIXFONCTION    # Telephone
       Call NUMONLY([F:XITL]TLC,[F:CNT]FAX)  From SIXFONCTION    # Fax   
       [F:CNT]WEB       = [F:XITL]ADRMAI         # E-mail                
       # Rubriques par defaut 
       [F:CNT]CNTFNC    = 12                     # Fonction  (cette valeur est un pre-requis)
       [F:CNT]CRETIM    = time                   # Heure
       [F:CNT]UPDTIM    = time                   # Heure

       # Maj
       If LEXI
          [F:CNT]UPDDAT = date$ 
          [F:CNT]UPDUSR = GUSER
          [F:CNT]UPDTIM = time                   # Heure
          Rewrite [CNT]
       Else
          SI_TABLE = "CONTACT"
          Gosub SI_BEFWRI From SIXFONCTION
          Write [CNT]
          If fstat
             Call ECR_TRACE("mess(183,197,1)"-[F:BPS]BPSNUM-"/"-WCCNCRM-"("+[F:XFOU]CODFOU+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
             LERR = 1 
             Return  
          Endif
          Look [AIN]AIN0 = WCCNCRM
          If fstat <> 0
             Readlock [AIN]AIN0=WCCNCRM
             If fstat
                Raz [F:AIN]
                [F:AIN]          = [F:CNT]
                [F:AIN]CNTNUM    = WCCNCRM                # Code   
                [F:AIN]CNTLNA    = [F:XITL]NOM1           # Nom   
                If dim([F:AIN]CNTTYP) > 0   
                       [F:AIN]CNTTYP    = 1               # Type  (standard)
                Endif
                [F:AIN]CNTTTL    = 1                      # Civilité (Monsieur)
                [F:AIN]CNTFULNAM = func SUBAIN.CLE([F:AIN]CNTLNA,[F:AIN]CNTFNA)
                # code pays 
                If [F:XFOU]CODPAY <> ""
                   [F:AIN]CRY = func SIXFONCTION.SI_COR("XIPAY",[F:XFOU]CODPAY,"TABCOUNTRY",mess(12,159,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")")
                Endif
                Call NUMONLY([F:XITL]TEL2,[F:AIN]CNTMOB)  From SIXFONCTION    # Portable   
                SI_TABLE = "CONTACTCRM"
                Gosub SI_BEFWRI From SIXFONCTION
                Write [AIN]
                If fstat
                   Call ECR_TRACE("mess(183,197,1)"-WCCNCRM-"("+[F:XFOU]CODFOU+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
                   LERR = 1
                   Return 
                Endif
             Endif
          Endif
       Endif
    Endif
Next

Return


#dem 47375 deb
##################################################################
#  Creation BPADDRESS
##################################################################
$CRE_BPA_CNT
Local Integer LEXI
Raz LEXI
Local Char LBPAADD(3)
LBPAADD    = [F:CNT]BPAADD          # Adresse par défaut

Look [BPA]BPA0 = 1;[F:BPS]BPSNUM;LBPAADD
If fstat <> 0
    Readlock [BPA]BPA0=1;[F:BPS]BPSNUM;LBPAADD
    If fstat
        Raz [F:BPA]
        [F:BPA]CRY = [F:BSG]CRY
        Raz LEXI
    Else
        LEXI = 1
    Endif
    # Rubriques reprises du client Integrale


    [F:BPA]BPAADDLIG (0) =  [F:XITL]ADR1      # Ligne adresse 1
    [F:BPA]BPAADDLIG (1) =  [F:XITL]ADR2      # Ligne adresse 2
    [F:BPA]BPAADDLIG (2) =  [F:XITL]ADR3      # Ligne adresse 3
    [F:BPA]POSCOD        =  [F:XITL]CODPST    # Code postal     
    [F:BPA]CTY           =  [F:XITL]VIL       # Ville 
    [F:BPA]WEB           =  [F:XITL]ADRMAI    # Adresse internet

    Call NUMONLY([F:XITL]TEL1,[F:BPA]TEL) From SIXFONCTION    # Telephone
    Call NUMONLY([F:XITL]TLC,[F:BPA]FAX)  From SIXFONCTION    # Fax   
    [F:BPA]TEL(1)        =  [F:BPA]FAX                        # Fax      # hcb 73119
          

    # Code pays 
    If [F:XITL]CODPAY <> ""
       [F:BPA]CRY = func SIXFONCTION.SI_COR("XIPAY",[F:XITL]CODPAY,"TABCOUNTRY",mess(183,197,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")")
    Endif  
    # Nom pays
    If [F:BPA]CRY <> "" 
       Call LECTEXTRA([F:BPA]CRYNAM,"TABCOUNTRY","CRYDES",[F:BPA]CRY,"") From ATEXTRA
    Endif

    # Rubriques reprises du client X3
    [F:BPA]BPATYP    = 1                      # Type entité
    [F:BPA]BPANUM    = [F:BPS]BPSNUM          # Entité
    [F:BPA]BPAADD    = LBPAADD                # Adresse 
    [F:BPA]CREDAT    = [F:BPS]CREDAT          # Date création
    [F:BPA]CREUSR    = [F:BPS]CREUSR          # Opérateur création
    [F:BPA]UPDDAT    = [F:BPS]UPDDAT          # Date modification
    [F:BPA]UPDUSR    = [F:BPS]UPDUSR          # Opérateur modification
 
    # Rubriques par defaut 
    [F:BPA]BPAADDFLG = 2                      # Par défaut
    [F:BPA]CRETIM    = time                   # Heure
    [F:BPA]UPDTIM    = time                   # Heure

    # Maj
    If LEXI
       [F:BPA]UPDDAT = date$ 
       [F:BPA]UPDUSR = GUSE  
       [F:BPA]UPDTIM = time                   # Heure

       Rewrite [BPA]
    Else
        SI_TABLE = "BPADDRESS"
        Gosub SI_BEFWRI From SIXFONCTION
        Write [BPA]
        If fstat
           Call ECR_TRACE(mess(33,102,1)-[F:BPS]BPSNUM-"("+[F:XFOU]CODFOU+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
           LERR = 1
        Endif
    Endif
Endif

Return





























