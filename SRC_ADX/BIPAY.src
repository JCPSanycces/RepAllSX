#<AdxTL>@(#)0.0.0.0 $Revision$
# Fonctions diverses pour la BI en paie
######################################################################################
# Modifications :
#     SEGAY - 23/11/12 - EXI 84335 - V6 : Amélioration temps
#     SEGAY - 23/11/12 - EXI 85160 - V6 : Amélioration temps
######################################################################################

################################################################################
$ACTION
Case [L]ACTION
When "DEBUT_FAT"
 Case [L]TABLE
  When "F_VALEMP2" : Gosub DEBUT_VALEMP2
 Endcase
When "FIN_FAT"
 Case [L]TABLE
  When "F_VALEMP2" : Gosub FIN_VALEMP2
 Endcase
Endcase
Return

################################################################################
#
# Table de faits VALEMP2
#
################################################################################

$DEBUT_VALEMP2
If !clalev([F:CTR2]) : Local File =[V]GDOSSIER+".EMPLOCTR" [CTR2] : Endif
If !clalev([F:ADI])  : Local File =[V]GDOSSIER+".ATABDIV"  [ADI]  : Endif
If !clalev([F:ADI2]) : Local File =[V]GDOSSIER+".ATABDIV"  [ADI2] : Endif
#SEGAY 23/11/12 bug 84335
Global Integer ADIN1(1..100),ADIN2(1..100),NADI
Global Char ADICODE(GLONADI)(1..100)

Filter [ADI] Where NUMTAB=10580
NADI=0
For [ADI]CODE
    NADI+=1
    ADIN1(NADI)=[F:ADI]N1
    ADIN2(NADI)=[F:ADI]N2
    ADICODE(NADI)=[F:ADI]CODE
Next
Filter [ADI]

Global Integer ADI2N1(1..100),ADI2N2(1..100),NADI2
Global Char ADI2CODE(GLONADI)(1..100)

Filter [ADI2] Where NUMTAB=10581
For [ADI2]CODE
    NADI2+=1
    ADI2N1(NADI2)=[F:ADI2]N1
    ADI2N2(NADI2)=[F:ADI2]N2
    ADI2CODE(NADI2)=[F:ADI2]CODE
Next
Filter [ADI]
#END SEGAY 23/11/12 bug 84335
#SEGAY 22/11/12 bug 85160
Global Char WGSITE(GLONFCY)
Global Char WGSOCSITE(GLONCPY)

Return

#-------------------------------------------------------------------------------
$FIN_VALEMP2
If clalev([F:CTR2]) : Close Local File [CTR2] : Endif
If clalev([F:ADI])  : Close Local File [ADI]  : Endif
If clalev([F:ADI2]) : Close Local File [ADI2] : Endif
#SEGAY 23/11/12 bug 84335
If dim(ADIN1)>0 : Kill ADIN1 : Endif
If dim(ADIN2)>0 : Kill ADIN2 : Endif
If dim(NADI)>0 : Kill NADI : Endif
If dim(ADICODE)>0 : Kill ADICODE : Endif

If dim(ADI2N1)>0 : Kill ADI2N1 : Endif
If dim(ADI2N2)>0 : Kill ADI2N2 : Endif
If dim(NADI2)>0 : Kill NADI2 : Endif
If dim(ADI2CODE)>0 : Kill ADI2CODE : Endif
#END SEGAY 23/09/12 bug 84335
#SEGAY 22/11/12 bug 85160
If dim(WGSITE)>0 : Kill WGSITE : Endif
If dim(WGSOCSITE)>0 : Kill WGSOCSITE : Endif

Return

#-------------------------------------------------------------------------------
Funprog CTRDAT(REFNUM,CTRNUM,DAT)
Value Char REFNUM(), CTRNUM()
Value Date DAT

If !clalev([F:CTR2]) : Local File =[V]GDOSSIER+".EMPLOCTR" [CTR2] : Endif

If [F:CTR2]CTRNUM=[L]CTRNUM & [F:CTR2]CTRDAT<=[L]DAT
&& ([F:CTR2]XITDAT>=[L]DAT | [F:CTR2]XITDAT=[0/0/0])
 End [F:CTR2]CTRDAT
Endif

Filter [CTR2] Where REFNUM=[L]REFNUM & CTRNUM=[L]CTRNUM & CTRDAT<=[L]DAT
&                 & (XITDAT>=[L]DAT | XITDAT=[0/0/0])
Read [CTR2] First
Filter [CTR2]
If !fstat : End [F:CTR2]CTRDAT : Else End [0/0/0] : Endif

#-------------------------------------------------------------------------------
Funprog AGE(BRNDAT,DAT)
Value Date BRNDAT, DAT

If [L]BRNDAT=[0/0/0] : End "" : Endif

If !clalev([F:ADI]) : Local File =[V]GDOSSIER+".ATABDIV" [ADI] : Endif

Local Shortint AGE

If [L]BRNDAT<>[0/0/0]
 [L]AGE =year([L]DAT)-year([L]BRNDAT)
 [L]AGE-=([L]DAT<addmonth([L]BRNDAT,12*[L]AGE))
Else
 [L]AGE = 0
Endif

#SEGAY 23/11/12 bug 84335
#If [F:ADI]NUMTAB<>10580 | [F:ADI]N1>[L]AGE | [F:ADI]N2<[L]AGE
# Filter [ADI] Where NUMTAB=10580 & N1<=[L]AGE & N2>=[L]AGE
# Read [ADI]CODE First
# Filter [ADI]
# If fstat : End "" : Endif
#Endif
#
#End [F:ADI]CODE

For I=1 To NADI
    If ADIN1(NADI)<=[L]AGE & ADIN2(NADI)>[L]AGE
        End ADICODE(NADI)
    Endif
Next I
End ""
#END SEGAY 23/11/12 bug 84335
#-------------------------------------------------------------------------------
#SEGAY 23/11/12 bug 84335
Funprog ANCOLD(REFNUM,CTRNUM,DAT)
Value Char REFNUM(), CTRNUM()
Value Date DAT

If !clalev([F:CTR2]) : Local File =[V]GDOSSIER+".EMPLOCTR" [CTR2] : Endif
If !clalev([F:ADI2]) : Local File =[V]GDOSSIER+".ATABDIV"  [ADI2] : Endif

Local Shortint ANC
Local Date     DATANC

If [F:CTR2]CTRNUM<>[L]CTRNUM | [F:CTR2]CTRDAT>[L]DAT
&| ([F:CTR2]XITDAT<[L]DAT & [F:CTR2]XITDAT>[0/0/0])
 Filter [CTR2] Where REFNUM=[L]REFNUM & CTRNUM=[L]CTRNUM & CTRDAT<=[L]DAT
&                  & (XITDAT>=[L]DAT | XITDAT=[0/0/0])
 Read [CTR2] First
 Filter [CTR2]
 If fstat : End "" : Endif
Endif

If [F:CTR2]DATANC>[0/0/0] : [L]DATANC=[F:CTR2]DATANC
Else                        [L]DATANC=[F:CTR2]CTRDAT
Endif
If [L]DATANC<>[0/0/0]
 [L]ANC =year([L]DAT)-year([L]DATANC)
 [L]ANC-=([L]DAT<addmonth([L]DATANC,12*[L]ANC))
Else
 [L]ANC = 0
Endif

If [F:ADI2]NUMTAB<>10581 | [F:ADI2]N1>[L]ANC | [F:ADI2]N2<[L]ANC
 Filter [ADI2] Where NUMTAB=10581 & N1<=[L]ANC & N2>=[L]ANC
 Read [ADI2]CODE First
 Filter [ADI2]
 If fstat : End "" : Endif
Endif
Onerrgo
End [F:ADI2]CODE

#SEGAY 23/11/12 bug 84335
Funprog ANC(REFNUM,CTRNUM,DAT)
Value Char REFNUM(), CTRNUM()
Value Date DAT

If !clalev([F:CTR2]) : Local File =[V]GDOSSIER+".EMPLOCTR" [CTR2] : Endif
If !clalev([F:ADI2]) : Local File =[V]GDOSSIER+".ATABDIV"  [ADI2] : Endif

Local Shortint ANC
Local Date     DATANC

If [F:CTR2]CTRNUM<>[L]CTRNUM | [F:CTR2]CTRDAT>[L]DAT
&| ([F:CTR2]XITDAT<[L]DAT & [F:CTR2]XITDAT>[0/0/0])
 Filter [CTR2] Where REFNUM=[L]REFNUM & CTRNUM=[L]CTRNUM & CTRDAT<=[L]DAT
&                  & (XITDAT>=[L]DAT | XITDAT=[0/0/0])
 Read [CTR2] First
 Filter [CTR2]
 If fstat : End "" : Endif
Endif

If [F:CTR2]DATANC>[0/0/0] : [L]DATANC=[F:CTR2]DATANC
Else                        [L]DATANC=[F:CTR2]CTRDAT
Endif
If [L]DATANC<>[0/0/0]
 [L]ANC =year([L]DAT)-year([L]DATANC)
 [L]ANC-=([L]DAT<addmonth([L]DATANC,12*[L]ANC))
Else
 [L]ANC = 0
Endif

#SEGAY on passe sur ADI2 + test : comme en V6
#If [F:ADI2]NUMTAB<>10581 | [F:ADI2]N1>[L]ANC | [F:ADI2]N2<[L]ANC
# Filter [ADI2] Where NUMTAB=10581 & N1<=[L]ANC & N2>=[L]ANC
# Read [ADI2]CODE First
# Filter [ADI2]
# If fstat : End "" : Endif
#Endif
#Onerrgo
#End [F:ADI2]CODE

For I=1 To NADI2
    If ADI2N1(NADI2)<=[L]ANC & ADI2N2(NADI2)>[L]ANC
        End ADI2CODE(NADI2)
    Endif
Next I
End ""

#SEGAY 22/11/12 BUG 85160
########################################
# Donne la société d'un site
Funprog GETSOC(SITE)
Value Char SITE()

Local Shortint I

If dim(WGSITE)>0 & dim(WGSOCSITE)>0 & WGSITE=[L]SITE : End WGSOCSITE : Endif
If dim(WGSITE)>0 & dim(WGSOCSITE)>0
  WGSITE=[L]SITE
  WGSOCSITE=""
Endif

I=find([L]SITE,[V]GSITE(1..[V]GNBSITE))
If I
 If dim(WGSOCSITE)>0 :WGSOCSITE=[V]GSOCSITE(I)  : Endif
 End [V]GSOCSITE(I)
Endif


If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
Read [FCY]FCY0=[L]SITE
If !fstat
  If dim(WGSOCSITE)>0 :WGSOCSITE=[F:FCY]LEGCPY : Endif
  End [F:FCY]LEGCPY
Else
  End ""
Endif
End

