#<AdxTL>@(#)11.0.0.0 $Revision$
# Mask Management RVMVAL1
# Issue 111414/15 - 2016-02-09 by BAKHA : If end date is entered or changed, check work orders for consistency

$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "DEBUT"       : Gosub DEBUT
    When "SETBOUT"     : Gosub SETBOUT
    When "APRES_MODIF" : Gosub APRES_MODIF
    When "ABA"         : Gosub ABANDON
    When "ENR"         : Gosub ENR
    When "END"         : Gosub FIN
  Endcase
Return

$OUVRE
  Local Integer ROUTE_VERSION
  Local Char SYMBOL(50), CRITERIA(250)
  Local Char PRODUCT([V]GLONITM), SITE([V]GLONFCY), MAJOR_VERSION([V]GLONICVVAL)
  Local Integer IS_LOCKED
  Local Integer I
  Local Char FIELD_TEXT_1([V]GLONDES), FIELD_TEXT_2([V]GLONDES)

  ROUTE_VERSION = func RVMLIB.NBRCPNROU([L]PARAM(1))
  If (ROUTE_VERSION = 0)
    GERR = 1 : GMESSAGE = func AFNC.MES1(mess(335,193,1), [L]PARAM(1))
    FIN = 1
  Else
    PRODUCT = [L]PARAM(1)
    SITE = [L]PARAM(2)
    MAJOR_VERSION = [L]PARAM(3)
    If (!clalev([F:ROH])) : Local File ROUTING [ROH] : Endif
    If (!clalev([F:ROO])) : Local File ROUOPE  [ROO] : Endif
    If (!clalev([F:RVV])) : Local File RVMVAL  [RVV] : Endif
  Endif
Return

$DEBUT
  Gosub LOCK_ROUTE
  Gosub FILL_SCREEN
Return

$SETBOUT
  # If Route not locked then display padlock icon ...
  IMGFLG(3) = (!IS_LOCKED & SYMBOL <> "")
  # If no field value change then display refresh icon ...
  If (REP = "")
    CHBOU += "="  # Display Refresh icon
  Endif
Return

$APRES_MODIF
  If (COUZON <> "NBLIG")
    If (REP = "" & !IS_LOCKED)
      GERR = 1 : FOK = 0
    Else
      [M:RVV1]UPDFLG(nolign-1) = 1
      REP = "M"
    Endif
  Endif
Return

$ABANDON
  REP = ""
  Gosub UNLOCK_ROUTE
  Gosub LOCK_ROUTE
  Gosub FILL_SCREEN
Return

$ENR
  Call DEBTRANS From GLOCK
  Gosub UPDATE_TRANSACTION
  If (GOK=1)
    Goto ABANDON
  Endif
Return

$FIN
  Gosub UNLOCK_ROUTE
Return

$UNLOCK_ROUTE
  If (IS_LOCKED = 1 & SYMBOL <> "")
    Unlock = SYMBOL
  Endif
  SYMBOL = "" : IS_LOCKED = 0
Return

$LOCK_ROUTE
  SYMBOL = "" : IS_LOCKED = 0
  Filter [ROH] Where ITMREF=PRODUCT & FCY=SITE & USESTA=2
  Read [ROH]ROH0 Last
  If (fstat <= 2)
    SYMBOL = "ROH"+num$([F:ROH]ROUALT)+"\"+PRODUCT+"\"+SITE
    If (SYMBOL <> "")
      Call TESTLOCK(SYMBOL,IS_LOCKED) From GLOCKM
      If (IS_LOCKED)
        IS_LOCKED = 2 # IS_LOCKED = 0 (no lock), 1 (locked by a.n.other), 2 (locked by RVMVAL).
      Else
        Lock = SYMBOL With lockwait = 0
        IS_LOCKED = (!fstat)
      Endif
    Endif
  Endif
  Filter [ROH]
Return

$FILL_SCREEN
  Gosub SET_CRITERIA
  Raz [M:RVV1]
  nolign = 0
  Filter [RVV] Order By Key RVV1 Desc
  For [RVV] Where evalue(CRITERIA)
    If (nolign >= dim([M:RVV1]ECCVALMAJ))
      Break
    Endif
    nolign += 1
    [M:RVV1] = [F:RVV]
    [M:RVV1]UPDFLG(nolign-1) = 0
#    [M:RVV1]VERSION(nolign-1) = [F:RVV]ECCVALMAJ
#    If ([F:RVV]ECCVALMIN <> "")
#      [M:RVV1]VERSION(nolign-1) -= [F:RVV]ECCVALMIN
#    Endif
  Next
  Filter [RVV]
  [M:RVV1]NBLIG = nolign

  [M:RVV1]ITMREF = [L]PRODUCT
  [M:RVV1]FCY    = [L]SITE
#  [M:RVV1]VALMAJ = [L]MAJOR_VERSION

  Affzo
Return

$SET_CRITERIA
  CRITERIA = "ITMREF='"+[L]PRODUCT+"' & FCY='"+[L]SITE+"'"
  If ([L]MAJOR_VERSION <> "")
    CRITERIA -= "& ECCVALMAJ='"+[L]MAJOR_VERSION+"'"
  Endif
Return

$UPDATE_TRANSACTION
  GOK = 1

  Trbegin [RVV]

  For I = 0 To [M:RVV1]NBLIG-1
    If ([M:RVV1]UPDFLG(I) = 1)
      Readlock [RVV]RVV1 = [M:RVV1]ITMREF;[M:RVV1]FCY;[M:RVV1]ECCVALMAJ(I);[M:RVV1]ECCVALMIN(I)
      If (fstat = 1)
        GOK = -1 : GLOCK = "$RVMVAL"-[M:RVV1]ITMREF-[M:RVV1]FCY-[M:RVV1]ECCVALMAJ(I)-[M:RVV1]ECCVALMIN(I)
        Break
      Elsif (!fstat)
        Gosub UPDATE_ROUTE
        If (GOK < 1)
          Break
        Endif
        nolign = I+1
        [F:RVV] = [M:RVV1]
        Rewrite [RVV]
        If (fstat)
          GOK = 0
          Call FSTA("RVM") From GLOCK
          Break
        Endif
      Endif
    Endif
  Next I

  If (GOK = 1)
    Gosub VALIDATE_ROUTE
  Endif

  If (GOK = 1)
    Commit
  Else
    Rollback
    If (GOK = -1)
      Call ROLL From GLOCK
      If (!GROLL)
        Goto UPDATE_TRANSACTION
      Endif
    Endif
  Endif
Return

$UPDATE_ROUTE
  # Update Route header (ROUTING) ...
  Readlock [ROH]ROH0 = [F:RVV]ITMREF;[F:RVV]ROUALT;[F:RVV]FCY
  If (fstat = 1)
    GOK = -1 : GLOCK = "$ROUTING"-[F:RVV]ITMREF-num$([F:RVV]BOMALT)-[F:RVV]FCY
  Elsif (fstat)
    GOK = 0 : Call RSTA("ROH",[F:RVV]ITMREF-num$([F:RVV]ROUALT)-[F:RVV]FCY) From GLOCK
  Else
    If ([F:RVV]ENDDAT = [F:ROH]ROUENDDAT & [F:ROH]ROUENDDAT <> [M:RVV1]ENDDAT(I))
      [F:ROH]ROUENDDAT = [M:RVV1]ENDDAT(I)
      Rewrite [ROH]
      If (fstat)
        GOK = 0 : Call FSTA("ROH") From GLOCK
      Endif
    Endif
  Endif

  If (GOK > 0)
    # Update Route detail (ROUOPE Operations) ...
    For [ROO] Where ITMREF = [F:RVV]ITMREF & ROUALT = [F:RVV]ROUALT & FCY = [F:RVV]FCY
      If ([F:ROO]VALENDDAT = [F:RVV]ENDDAT & [F:RVV]ENDDAT <> [M:RVV1]ENDDAT(I))
        Readlock [ROO] Curr
        If (!fstat)
          [F:ROO]VALENDDAT = [M:RVV1]ENDDAT(I)
          Rewrite [ROO]
        Endif
        If (fstat)
          GOK = 0 : Call FSTA("ROO") From GLOCK
          Break
        Endif
      Endif
    Next
  Endif
Return

$VALIDATE_ROUTE
  For [ROH] Where ITMREF = [M:RVV1]ITMREF & FCY = [M:RVV1]FCY
    # Validate Route header: start and end dates ...
    If ([F:ROH]ROUENDDAT <> [0/0/0] & [F:ROH]ROUSTRDAT > [F:ROH]ROUENDDAT)
      Call TEXTFIC("ROUTING","ROUALT",3,FIELD_TEXT_1) From OBJDIV
      GOK = 0 : Call RSTA("ROH","#"+FIELD_TEXT_1+"="+[F:ROH]ROUALT
&                 -mess(27,2282,1)+"="+format$(GFMDAT4,[F:ROH]ROUSTRDAT)
&                 -mess(28,2282,1)+"="+format$(GFMDAT4,[F:ROH]ROUENDDAT)) From GLOCK
      Raz [F:ROH]
      Break
    Endif

    # Validate Route detail: start and end dates ...
    For [ROO] Where ITMREF = [F:ROH]ITMREF & ROUALT = [F:ROH]ROUALT & FCY = [F:ROH]FCY
      If ([F:ROH]ROUSTRDAT <> [0/0/0] & [F:ROO]VALSTRDAT < [F:ROH]ROUSTRDAT)
        Gosub ERROR_ROUTE_OPERATION
        Break(2)
      Endif
      If ([F:ROH]ROUENDDAT <> [0/0/0] & ([F:ROO]VALENDDAT = [0/0/0] | [F:ROO]VALENDDAT > [F:ROH]ROUENDDAT))
        Gosub ERROR_ROUTE_OPERATION
        Break(2)
      Endif
      If ([F:ROO]VALENDDAT <> [0/0/0] & [F:ROO]VALSTRDAT > [F:ROO]VALENDDAT)
        Gosub ERROR_ROUTE_OPERATION
        Break(2)
      Endif
    Next
  Next
Return

$ERROR_ROUTE_OPERATION
  Call TEXTFIC("ROUOPE","ROUALT",3,FIELD_TEXT_1) From OBJDIV
  Call TEXTFIC("ROUOPE","OPENUM",3,FIELD_TEXT_2) From OBJDIV
  GOK = 0 : Call RSTA("ROO","#"+FIELD_TEXT_1+"="+num$([F:ROO]ROUALT)
&             -FIELD_TEXT_2+"="+[F:ROO]OPENUM+"\"
&             +mess(70,199,1)) From GLOCK
  Raz [F:ROO]
Return

######################################################################################

Subprog AS_ENDDAT(VALEUR)
Variable Date VALEUR
  # If version is not latest or 'in development' then
  # prevent entry of end date ...
  If (nolign > 1 | [M:RVV1]USESTA(nolign-1) <> 2)
    mkstat = 2
  Endif
End

Subprog AM_ENDDAT(VALEUR)
Variable Date VALEUR
  If VALEUR=[0/0/0] : End : Endif

  # Issue 60919 GH 09/02/2018 - The entered end date will become the route end date
  #                             and should be greater or equal to all exemption dates
  Local Date MAXEXNDAT
  MAXEXNDAT = max([M:RVV1]EXNDAT(1..[M:RVV1]NBLIG-1))
  If VALEUR<MAXEXNDAT
    GMESSAGE = mess(10,109,1)-"<"-format$("D:"+GFMDAT,MAXEXNDAT)
    mkstat=2 : End
  Endif

  # Issue 111414/15 - If end date is entered or changed, check work orders for consistency
  If [M:RVV1]ENDDAT(nolign-1) = [0/0/0] | VALEUR < [M:RVV1]ENDDAT(nolign-1)
    Call CTLEXN([M:RVV1]ITMREF,
&               [M:RVV1]ECCVALMAJ(nolign-1),
&               [M:RVV1]ECCVALMIN(nolign-1),
&               [M:RVV1]FCY,
&               VALEUR)
  Endif
End

######################################################################################
## Management of exemption (flag Y/N + Date)
######################################################################################

Subprog AS_EXNFLG(VALEUR)
Variable Integer VALEUR
  # If version is 'in development' or blank end date then prevent entry of exception flag ...
  If ([M:RVV1]USESTA(nolign-1) = 1 | [M:RVV1]ENDDAT(nolign-1) = [0/0/0])
    VALEUR = 1 : mkstat = 2
  Else : # here, case of a  version available to use with an end date
    # Issue 60919 GH 09/02/2018 - No exemption on the last version
    #                             because the route end date is the last version end date
    Local Date DAT1
    Local Integer I, K
    For I=0 To [M:RVV1]NBLIG-1
      If [M:RVV1]USESTA(I)=2 & DAT1<[M:RVV1]STRDAT(I)
         # The last version is the one avilable to use with the greatest start date
         DAT1=[M:RVV1]STRDAT(I) : K=I+1
      Endif
    Next
    If nolign=K
       VALEUR=1 : mkstat=2
    Endif
  Endif
End

Subprog AM_EXNFLG(VALEUR)
Variable Integer VALEUR
  # If exception flag is changed from "Yes" to "No" then
  # the lack of exemption date is verified
  If (VALEUR=1)
    Call CTLEXN([M:RVV1]ITMREF,
&               [M:RVV1]ECCVALMAJ(nolign-1),
&               [M:RVV1]ECCVALMIN(nolign-1),
&               [M:RVV1]FCY,
&               [M:RVV1]ENDDAT(nolign-1))
  Endif
End

Subprog AS_EXNDAT(VALEUR)
Variable Date    VALEUR
  # If exception flag is "no" then
  # prevent entry of exception date ...
  If ([M:RVV1]EXNFLG(nolign-1) <> 2)
    mkstat = 1
  Endif
End

Subprog C_EXNDAT(VALEUR)
Variable Date    VALEUR
  # If new exception date is non-blank and <= end date then
  # display error ...
  If (VALEUR <> [0/0/0] & VALEUR <= [M:RVV1]ENDDAT(nolign-1))
    GMESSAGE = mess(10,109,1)-"<="-format$("D:"+GFMDAT,[M:RVV1]ENDDAT(nolign-1))
    mkstat = 2
  Endif
End

Subprog AM_EXNDAT(VALEUR)
Variable Date    VALEUR

  # Issue 60919 GH 09/02/2018 - Exemption dates should be previous or equal to the route end date
  If VALEUR<>[0/0/0]
    Local Date DAT1, DAT2
    Local Integer I
    For I=0 To [M:RVV1]NBLIG-1
      If [M:RVV1]USESTA(I)=2 & DAT1<[M:RVV1]STRDAT(I)
         # The last version is the one with the greatest start date
         DAT1=[M:RVV1]STRDAT(I) : DAT2=[M:RVV1]ENDDAT(I)
      Endif
    Next
    If DAT2<>[0/0/0] & VALEUR>DAT2
       GMESSAGE = mess(10,109,1)-">"-format$("D:"+GFMDAT,DAT2)
       mkstat=2 : End
    Endif
  Endif

  # If old exemption date was blank or new exception date is non-blank and < old exception date then
  # the new exemption date is verified
  If ([M:RVV1]EXNDAT(nolign-1) = [0/0/0] | (VALEUR <> [0/0/0] & VALEUR < [M:RVV1]EXNDAT(nolign-1)))
    Call CTLEXN([M:RVV1]ITMREF,
&               [M:RVV1]ECCVALMAJ(nolign-1),
&               [M:RVV1]ECCVALMIN(nolign-1),
&               [M:RVV1]FCY,
&               VALEUR)
  Endif
End

#**---------------------------------------------------------------------<br/>
#* CTLEXN : Set an error if there is a WO start date greater than EXN_DATE
#* amongst planned or firm WO using a route version
#**<br/>----------------------------------------------------------------<br/>
#* @param ROUTE = Route number
#* @param MAJOR_VERSION = Route major version
#* @param MINOR_VERSION = Route minor version
#* @param SITE = Route site
#* @param EXN_DATE = Exemption date (or End date of the route version if there is no exemption)
#**<br/>----------------------------------------------------------------
#*!
Subprog CTLEXN(ROUTE,MAJOR_VERSION,MINOR_VERSION,SITE,EXN_DATE)
Value Char ROUTE()
Value Char MAJOR_VERSION()
Value Char MINOR_VERSION()
Value Char SITE()
Value Date EXN_DATE

   Local Date MAX_WIP_START_DATE
   Local Char WIP_NUMBER(GLONMFG)
   If !clalev([F:MFG]) : Local File MFGHEAD [MFG] : Endif
   Columns [MFG] (STRDAT,MFGNUM)
   For [MFG] Where ROUNUM=[L]ROUTE &
&                  MFGFCY=[L]SITE &
&                  ROUECCMAJ=[L]MAJOR_VERSION &
&                  ROUECCMIN=[L]MINOR_VERSION &
&                  STRDAT>[L]EXN_DATE
       If ([F:MFG]STRDAT > MAX_WIP_START_DATE)
          WIP_NUMBER = [F:MFG]MFGNUM
          MAX_WIP_START_DATE = [F:MFG]STRDAT
       Endif
   Next
   Columns [MFG]

   If (WIP_NUMBER <> "")
      Call TEXTFIC("MFGHEAD","STRDAT",1,GMESSAGE) From OBJDIV
      GMESSAGE = mess(10,701,1)-WIP_NUMBER+"\"+GMESSAGE+"="+format$("D:"+GFMDAT4,MAX_WIP_START_DATE)
      mkstat=2
  Endif
End

