$ACTION
 Case ACTION
  When "SETBOUT"      : Gosub SETBOUT        # => Actions de l'objet métier
  When "AVANTBOUT"    : Gosub AVANTBOUT      #
  When "AVANTBOUT_E"  : Gosub AVANTBOUT_E    #
  When "FIN_ACTION"   : Gosub FIN_ACTION     #
  When "APRES_CHOI"   : Gosub APRES_CHOI     #
  When "AVANT_MODFIC" : Gosub AVANT_MODFIC   #
  When "APRES_MOD"    : Gosub APRES_MOD      #
  When "AB_MODIF"     : Gosub AB_MODIF       #
  When "OUVRE"        : Gosub OUVRE          # => Action de la fenêtre action.
  When "DEBUT"        : Gosub DEBUT          #
  When "OK"           : Gosub OK             #
  When "FIN"          : Gosub FIN            #
  When Default
 Endcase
Return

#========= TRT actions métiers communs à tous les objets Métier

#-------------------------
$SETBOUT

 # Les codes boutons associés aux actions métiers sont stockés dans la variable LIS_ACT1
 # Pour chaque bouton, on va chercher le code action qui lui correspond dans la fenêtre
 # puis on accède à l'étiquette CRITMEN de ACTMEN du TRT+nom d'action pour récupérer la
 # variable CRITMEN. Elle contient l'expression critère qui permet d'activer l'entrée de
 # menu
 Local Char    ACTMET
 Local Char    CRITMEN(100)
 Local Char    CRITSUP(100)
 Local Char    CRITACT(200)
 Local Integer I_BOUT
 Local Char    NOM_ACTION
 Local Integer CDRET
 Local Char    LKEY
 Local Integer OBJET
 Local Char    NOTLOCK
 Local Char    TRTACTION
 Local Integer EXISTE_ADX

 #--> On alimente CRITSUP, critère valable pour toutes les actions si on est pas en création

 If !(GREP="C")
  CRITSUP='!(GREP="M") & num$(VERROU)="1"'
 Else
  CRITSUP="0=1"
 Endif

 #--> On passe chaque action en revue et on lui applique son critère CRITMEN + CRITSUP (V1)

 $V1

 If dim(LIS_NAM)>0 : Goto V2  : Endif  # Dev  # Si LIS_NAM n'existe pas on ne peut pas utiliser V2
 #If GUSER="GBO" : Infbox "V1 TRTOBJACT" : Endif  # Dev  # on est obliger d'utiliser V1

 Local Char TYPBOUT(1)
 For I_BOUT=0 To dim(LIS_ACT1)-1
  If LIS_ACT1(I_BOUT)="" : Break : Endif
  Call GET_ACTINF(LIS_ACT1(I_BOUT),NOM_ACTION,TYPBOUT,CDRET) From TRTOBJACT
  If !CDRET
   # Ici on vérifie d'abord que le traitement associé à l'action existe
   # S'il n'existe pas, on active pas le menu -> Pas d'accès possible à l'action, donc
   # pas de problème par la suite.
   TRTACTION="TRT"+NOM_ACTION
   Call EXISTE_ADX("","",TRTACTION,EXISTE_ADX) From ORDSYS
   If EXISTE_ADX Then
    Raz CRITMEN : ACTMET="CRITMEN" : Gosub ACTMET From =TRTACTION
    If !(CRITMEN="")        # Si CRITMEN alimenté,
     CRITACT=CRITSUP-"&"-CRITMEN
    Else
     CRITACT=CRITSUP             # Si CRITMEN non alimenté, on active toujours le menu
    Endif
    If evalue (CRITACT)
     If TYPBOUT="B"
      Call VIREBOUT(CHAINE,LIS_ACT1(I_BOUT)) From GOBJET # Si c'est un bouton
     Elsif TYPBOUT="M"
      CHMEN+=LIS_ACT1(I_BOUT)                            # si c'est un menu
     Endif
    Endif
   Endif
  Endif
 Next I_BOUT
Return

 #--> On passe chaque action en revue et on lui applique son critère CRITMEN + CRITSUP (V2)
 $V2
 For I_BOUT=0 To dim(LIS_ACT1)-1
  If LIS_ACT1(I_BOUT)="" : Break : Endif
  TRTACTION="TRT"+LIS_NAM(I_BOUT)
  Call EXISTE_ADX("","",TRTACTION,EXISTE_ADX) From ORDSYS
  If EXISTE_ADX Then
   Raz CRITMEN : ACTMET="CRITMEN" : Gosub ACTMET From =TRTACTION
   If !(CRITMEN="")        # Si CRITMEN alimenté,
    CRITACT=CRITSUP-"&"-CRITMEN
   Else
    CRITACT=CRITSUP             # Si CRITMEN non alimenté, on active toujours le menu
   Endif
   If evalue (CRITACT)
    If LIS_TYP(I_BOUT)="B"
     Call VIREBOUT(CHAINE,LIS_ACT1(I_BOUT)) From GOBJET # Si c'est un bouton
    Elsif LIS_TYP(I_BOUT)="M"
     CHMEN+=LIS_ACT1(I_BOUT)                            # si c'est un menu
    Endif
   Endif
  Endif
 Next I_BOUT

Return

#-------------------------
$AVANTBOUT
 # Les codes boutons associés aux actions métiers sont stockées dans la variable LIS_ACT1
 # Pour chaque bouton, on va chercher le code action qui lui correspond dans la fenêtre
 # puis on accède au paramètrage de l'action, à la fenêtre associée pour ouvrir les masques
 # définis dans celle-ci pour l'action métier

 Local Char    ACTNAM  : Raz ACTNAM  # Nom de l'action associé au code bouton
 Local Char    WINNAM  : Raz WINNAM  # Nom de la fenêtre associée à l'action
 Local Integer I_MSK                 # Indice de parcours du tableau de masques de la fenêtre
 Local Integer I_BOUT                # Indice de parcours des occurrences de la variable I_BOUT
 Local Integer BOUT_OK : Raz BOUT_OK # Flag de présence de BOUT dans LIS_ACT1

 # On cherche si le Bouton est dans la liste LIS_ACT1 ...

 For I_BOUT=0 To dim(LIS_ACT1)-1
  If LIS_ACT1(I_BOUT)=""
   Break
  Elsif LIS_ACT1(I_BOUT)=BOUT
   BOUT_OK=1
   Break
  Endif
 Next I_BOUT

 For I_BOUT=0 To dim(LIS_ACT)-1
  If LIS_ACT(I_BOUT)=""
   Break
  Elsif LIS_ACT(I_BOUT)=BOUT
   BOUT_OK=1
   Break
  Endif
 Next I_BOUT

 # ... le bouton est dans la liste

 If BOUT_OK
  # Correspondance entre le code menu et l'action associée
  If !(clalev([F:AWT])) : Local File AWINBOUT [AWT] : Endif
  Filter [AWT] Where WIN=GBOITE
  For [AWT]
   If right$([F:AWT]CODBOUT,len([F:AWT]CODBOUT))=BOUT
    ACTNAM=[F:AWT]ACTBOUT
    Break
   Endif
  Next
  Filter [AWT]
  If ACTNAM<>""
   If !(clalev([F:ACT])) : Local File ACTION [ACT] : Endif
   Read [ACT]ACTION=ACTNAM
   If fstat : PRET=1 : End : Endif
   WINNAM=[F:ACT]PARAM2  #=> On récupère la fenêtre associée à l'action
   If !(clalev([F:AWI])) : Local File AWINDOW [AWI] : Endif
   If !(clalev([F:AMK])) : Local File AMSK   [AMK] : Endif
   Read [AWI]AWI0=WINNAM
   If dim([M:OAC0]OBJREF)>0 : Close Local Mask [M:OAC0] : Endif
   Local Mask =[F:AWI]MSKENT
   For I_MSK=0 To [F:AWI]NBMSK
     Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
     Local Mask =[F:AMK]CODMSK
   Next I_MSK
  Endif
 Endif

Return


#-------------------------
$AVANTBOUT_E
 # Les codes boutons associés aux actions métiers sont stockées dans la variable LIS_ACT1
 # Pour chaque bouton, on va chercher le code action qui lui correspond dans la fenêtre
 # puis on accède au paramètrage de l'action, à la fenêtre associée pour ouvrir les masques
 # définis dans celle-ci pour l'action métier

 Local Char    ACTNAM  : Raz ACTNAM  # Nom de l'action associé au code bouton
 Local Char    WINNAM  : Raz WINNAM  # Nom de la fenêtre associée à l'action
 Local Integer I_MSK                 # Indice de parcours du tableau de masques de la fenêtre
 Local Integer I_BOUT                # Indice de parcours des occurrences de la variable I_BOUT
 Local Integer BOUT_OK : Raz BOUT_OK # Flag de présence de BOUT dans LIS_ACT1

 # On cherche si le Bouton est dans la liste LIS_ACT1 ...

 For I_BOUT=0 To dim(LIS_ACT1)-1
  If LIS_ACT1(I_BOUT)=""
   Break
  Elsif LIS_ACT1(I_BOUT)=BOUT
   BOUT_OK=1
   Break
  Endif
 Next I_BOUT

 For I_BOUT=0 To dim(LIS_ACT)-1
  If LIS_ACT(I_BOUT)=""
   Break
  Elsif LIS_ACT(I_BOUT)=BOUT
   BOUT_OK=1
   Break
  Endif
 Next I_BOUT

 # ... le bouton est dans la liste

 If BOUT_OK
   WINNAM='FASSPE'  #=> On récupère la fenêtre associée à l'action FASSPE dans le cas où le bien a des éléments physiques
   If !(clalev([F:AWI])) : Local File AWINDOW [AWI] : Endif
   If !(clalev([F:AMK])) : Local File AMSK   [AMK] : Endif
   Read [AWI]AWI0=WINNAM
   If dim([M:OAC0]OBJREF)>0 : Close Local Mask [M:OAC0] : Endif
   Local Mask =[F:AWI]MSKENT
   If clalev([M:FASE]) Then Close Local Mask [M:FASE] : Endif
   For I_MSK=0 To [F:AWI]NBMSK
     Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
     Local Mask =[F:AMK]CODMSK
   Next I_MSK
 Endif

Return


#-------------------------
$FIN_ACTION
 # En retour d'une action, celle-ci a créé la globale G_ACT_MOD qui permet de savoir si des modifs ont
 # été validée et doivent être reportées dans le masque courant et si on doit passer le bien en modif.
 # Cette globale est détruite quand c'est fait. On ne passe en modif que si la globale existe.
 If dim(G_ACT_MOD)>0           # G_ACT_MOD existe -> on sort donc d'une action métier
   If G_ACT_MOD                # G_ACT_MOD = 1    -> Des modifs à enregistrer
    REP="M" : GREP="M"         # L'objet passe en mode modif
    If dim(G_ACT_NAM)>0        # G_ACT_NAM Existe donc on sort d'une action métier
     If [M:OCP]NBOBJ=0         # Il n'y a pas de composants dans le masque OCP on le détruit
     #If clalev([M:OAC0]) : Close Local Mask [OAC0] : Endif
     #If clalev([M:OCP])  : Close Local Mask [OCP]  : Endif #Fq67577-Pologne
      If clalev([M:FASE]) : Close Local Mask [FASE] : Endif
     Endif
    Endif
   Else # Pas de modif on détruits les masques
    If clalev([M:OAC0]) : Close Local Mask [OAC0] : Endif
    If clalev([M:OCP])  : Close Local Mask [OCP]  : Endif
    If clalev([M:FASE]) : Close Local Mask [FASE] : Endif
   Endif
   Kill G_ACT_MOD
 Else
 Endif

Return

#-------------------------
$AVANT_MODFIC
 # Pendant la transaction de mise à jour de l'objet principal : si il y a des objets liés
 # on appelle le sous-programme de mise à jour des objets liés. Si une erreur se produit
 # la transaction est interrompue par GOK à 0.
 #
 # A faire : on génére un événement sur le bien principal
 If dim(G_ACT_NAM)>0
  Local Char TRTACTION
  #If !(G_ACT_NAM="") # C'est un objet qui a des composants

  TRTACTION="TRT"+G_ACT_NAM
  ACTMET="VERIF_ELT_PHY" : Gosub ACTMET From =TRTACTION
  If GOK=0 Then
    Return
  Endif

  # If clalev([M:OCP]) and !([M:OCP]NBOBJ=0)
  If !([M:OCP]NBOBJ=0)
   Local Integer CDRET      # Code retour
   Local Char    OBJET      # Type d'objet principal (1 Dépense / 2 Bien comptable / 4 Contrat de Loc fin)
   Local Char    IDEOBJ     # Identifiant de l'objet principal
   Local Char    OBJLNK(1)  # Type d'objet lié (0 indéterminé / 1 Dépense / 2 bien comptable / 4 Contrat de Loc fin)

   If pat (GBOITE,"*LOF*") : OBJET="1" : Endif
   If pat (GBOITE,"*FAS*") : OBJET="2" : Endif
   If pat (GBOITE,"*LEA*") : OBJET="4" : Endif

   IDEOBJ=[M:OAC0]OBJREF
   OBJLNK=[M:OCP]OBJLNK

   Call MAJ_OBJ_LNK(OBJET,IDEOBJ,OBJLNK,G_ACT_NAM,CDRET)
   If CDRET : GOK=0  : Endif
   If !GOK  : Return : Endif
  Endif
 #  TRTACTION="TRT"+G_ACT_NAM
   Gosub ACTION From =TRTACTION
 Endif

Return

#-------------------------
$APRES_CHOI
 # Au retour d'une action métier et si des modifs ont été faites, l'objet est en mode modif
 # On peut soit enregistrer les modifs, soit abandonner. Si on abandonne, on détruit la globale
 # G_ACT_NAM pour éventuellement pouvoir repartir proprement dans une autre action métier.

 If ((REPONSE=GSTAFIN) & (dim([M:OCP]NBOBJ)>0)) # Abandon et présence d'objets liés
  # Il faut unlocker les éventuels objets liés ...
  If !([M:OCP]NBOBJ=0)
   Gosub UNLOCK_LOT From TRTOBJACT
  Endif
  # ... Avant de détruire tous ce qui ne sert plus
  If (clalev([M:OAC0]) & clalev([M:OCP])) : Close Local Mask [OAC0],[OCP] Endif
  If clalev([M:FASE]) : Close Local Mask [FASE] : Endif
  If dim(G_ACT_NAM)>0 : Kill G_ACT_NAM : Endif
 Endif

Return

#-------------------------
$APRES_MOD

 # Après la mise à jour de l'objet et de ses objets liés : tous s'est bien passé. On peut
 # détruire la globale G_ACT_NAM, Unlocker les éventuels composants et détruire les masques.
 # Le calcul sur le bien principal est déclenché dans l'action APRES_MOD du traitement SUBFAS
 # Calcul pour les BCO

 If dim([M:OCP]CALCUL)>0
  For nolign=1 To [M:OCP]NBOBJ
   If [M:OCP]CALCUL(nolign-1)=2
    Call PARAM([M:OCP]OBJCPY(nolign-1),"CALAUTVAL", ACALCULER) From ADOVAL
     If ACALCULER = "2" Then
      # Calcul
      Call CALCULER_BIEN ([M:OCP]OBJCPY(nolign-1), [M:OCP]OBJREF(nolign-1), ERROR) From GLOBB
    Endif
   Endif
  Next
 Endif

 # Destruction des éléments liés à une action

 If dim(G_ACT_NAM)>0
  If !(G_ACT_NAM="")
   If !([M:OCP]NBOBJ=0)
    #Infbox "Après la transaction de MAJ - OK" :  #DEV
    #If (clalev([M:OAC0]) & clalev([M:OCP])) : Close Local Mask [OAC0],[OCP] Endif
    Gosub UNLOCK_LOT
    #If dim(G_ACT_NAM)>0
    # Kill G_ACT_NAM
    #Endif
   Endif
   Kill G_ACT_NAM
   If clalev([M:OAC0])
    Close Local Mask [OAC0]
   Endif
   If clalev([M:OCP])
    Close Local Mask [OCP]
   Endif
   If clalev([M:FASE])
    Close Local Mask [FASE]
   Endif
  Endif
 Endif

Return

#-------------------------
$AB_MODIF
 # Après la mise à jour de l'objet et de ses objets liés : Une erreur s'est produite.
 # Qu'est-ce qu'on fait ? On laisse les objets liés lockés et on ne détruit rien pour
 # pouvoir refaire une tentative ?
 #-Pas la peine de faire ça, car on le fait soit après la transaction de mise à jour si tout
 #              s'est bien passé, soit sur abandon.
Return

#========= TRT actions métiers communs à toutes les actions métier

#-------------------------
$OUVRE
 # A l'entrée dans l'action métier, avant l'ouverture de la fenêtre. On suppose que le masque
 # OCP contenant les objets liés est alimenté. On effectue ici le lock des objets liés. Si l'un
 # d'entre eux est déjà utilisé, on n'ouvre pas la fenêtre.

 Local Char TRTACTION

 #==> Critères d'interdiction à l'entrée dans l'action

 # Dans un tableau de variable dimensionnées, alimenté dans TRT+Nom action deux colonnes :
 #
 #   1 - Une colonne comportant l'expression entrainant l'apparition d'une erreur
 #   2 - Une colonne contenant le numéro de chapitre du message
 #   3 - Une colonne contenant le numéro de message à emettre
 #

 #==> Alim du type d'objet lié

 [M:OCP]OBJLNK=PARAM(2)

 #==> Lock des enregistrements des objets liés

  If !([M:OCP]NBOBJ=0)
   Local Char LKEY(200)                        # Identifiant de l'objet lié
   Local Char TABELT(50)(1..10)  : Raz TABELT  # Tableau d'éléments de la clé de l'objet lié

   If [M:OCP]OBJLNK="0"                                     # Les objets liés ne sont pas des objets métier
    TRTACTION="TRT"+GACTION                                 # Action de lock dans le TRT+nom action
    ACTMET="LCK_OBJ_LNK" : Gosub ACTMET From =TRTACTION     # Les objets liés sont des objets métier
   Else                                                     #
    Raz nolign
    For nolign=1 To [M:OCP]NBOBJ
     # Décomposition de la zone OBJREF en parties de clés
     Raz TABELT
     Call DECODE_REFOBJ([M:OCP]OBJREF(nolign-1),TABELT) From TRTOBJACT
     # Aiguillage et traitement de lock de la ligne du tableau
     Case val([M:OCP]OBJLNK)
      When GVML_OMDEPEN   # Objet lié de type Dépense
       LKEY = func GLOBIENS.GET_KEY_LAYOUTFAS (TABELT(1), val(TABELT(2)))
       If func GLOBIENS.LOCK_SYMBOLE ("LOF", [M:OCP]OBJCPY(nolign-1), LKEY, 0) = 0 Then
        # l'enregistrement de l'objet lié est locké ailleurs : on ne peut pas entrer dans l'action
        Infbox mess(34,7772,1)-[M:OCP]OBJREF(nolign-1)
        FIN=1
       Endif
      When GVML_OMBIEN   #  Objet lié de type BCO
       LKEY = func GLOBIENS.GET_KEY_FXDASSETS (TABELT(1))
       If func GLOBIENS.LOCK_SYMBOLE ("FAS", [M:OCP]OBJCPY(nolign-1), LKEY, 0) = 0 Then
        # l'enregistrement de l'objet lié  est locké ailleurs : on ne peut pas entrer dans l'action
        Infbox mess(34,7772,1)-[M:OCP]OBJREF(nolign-1)
        FIN=1
       Endif
      When GVML_OMLOCFI  # Objet lié de type contrat de location financement
     Endcase
    Next nolign
   Endif
  Endif
Return

#-------------------------
$DEBUT
 # Debut du traitement de l'action : On effectue ici les modifications dynamiques de libellés
 # de bloc, de titre de colonne pour les adapter au type d'objet métier principal et au type
 # d'objets liés.

 If dim (G_ACT_MOD)>0 : Kill G_ACT_MOD : Endif
 Global Integer G_ACT_MOD           : Raz G_ACT_MOD # Global pour retour à SUBFAS : indique si modifs ou pas

 Local Char TRTACTION

 #==> RAF - Contrôle des autorisations utilisateurs par rapport au site financier.

 #==> Alim de l'en-tête

 Case PARAM(1)  # On alimente l'en-tête en fonction du type d'objet métier traité fourni par PARAM(1)
  When "1"
   If dim([M:LOF0]CODLOF)>0  : [M:OAC0]OBJREF=[M:LOF0]CODLOF  : Endif
   If dim([M:LOF0]LINLOF)>0
    If dim([M:OAC0]OBJLIN)>0 : [M:OAC0]OBJLIN=[M:LOF0]LINLOF  : Endif
   Endif
   If dim([M:LOF0]DES)>0     : [M:OAC0]OBJDES=[M:LOF0]DES     : Endif
   If dim([M:LOF0]CPY)>0     : [M:OAC0]OBJCPY=[M:LOF0]CPY     : Endif
 When "2"
   If dim([M:FAS0]AASREF)>0  : [M:OAC0]OBJREF=[M:FAS0]AASREF  : Endif
   If dim([M:FAS0]AASDES1)>0 : [M:OAC0]OBJDES=[M:FAS0]AASDES1 : Endif
   If dim([M:FAS0]CPY)>0     : [M:OAC0]OBJCPY=[M:FAS0]CPY     : Endif
  When "4"
   If dim([M:LEA0]LEAREF)>0  : [M:OAC0]OBJREF=[M:LEA0]LEAREF  : Endif
   If dim([M:LEA0]LEADES)>0  : [M:OAC0]OBJDES=[M:LEA0]LEADES  : Endif
   If dim([M:LEA0]CPY)>0     : [M:OAC0]OBJCPY=[M:LEA0]CPY     : Endif
  When Default
 Endcase

 Local Char ACTMET # On se débranche dans le TRT de l'action pour alim des zones spé
 ACTMET="FILL_HEA"
 TRTACTION="TRT"+GACTION
 Gosub ACTMET From =TRTACTION

 #==> Modification des libellés zone et bloc ET et onglet objets liés (Ajouter objet LEA)

 Case PARAM(1) #-> Modification du titre du bloc de l'En-tête
  When "1"
   Chgtbk [M:OAC0]5     With mess(GVML_OMDEPEN,3141,1)  #"Dépense"
  When "2"
   Chgtbk [M:OAC0]5     With mess(GVML_OMBIEN,3141,1)   #"Bien comptable"
  When "4"
   Chgtbk [M:OAC0]5     With mess(GVML_OMLOCFI,3141,1)  #"Contrat de Location financement"
  When Default
 Endcase

 Case PARAM(2) #-> Modification du titre de la colonne identifiant objet lié
  When "1"
   Titcol [M:OCP]NBOBJ  mess(GVML_OMDEPEN,3141,1)       #"Dépense"
  When "2"
   Titcol [M:OCP]NBOBJ  mess(GVML_OMBIEN,3141,1)        #"Bien"
  When "4"
   Titcol [M:OCP]NBOBJ  mess(GVML_OMLOCFI,3141,1)       #"Contrat de Location financement"
  When Default
 Endcase

 #==> Alim du type d'objet lié  #### DEL - A supprimer car reporté dans $OUVRE

 [M:OCP]OBJLNK=PARAM(2)

 #==> Réaffichage des masques de l'action

 Affzo [M:OCP]NBOBJ,OBJLNK
 Affzo [M:OAC0]

Return

#-------------------------
$OK
# If G_ACT_MOD & !([M:OCP]NBOBJ=0) # S'il y a des modifs à reporter et si il y a des objets liés
#  Global Char G_ACT_NAM           # On crée la variable G_ACT_NAM
#  G_ACT_NAM=GACTION               # On l'alimente avec le nom de l'action en cours
# Endif

# If G_ACT_MOD
#  Global Char G_ACT_NAM
#  If !([M:OCP]NBOBJ=0)
#   G_ACT_NAM=GACTION
#  Else
#   Raz G_ACT_NAM
#  Endif
# Endif

 If G_ACT_MOD                # G_ACT_NAM est maintenant créée sytématiquement et alimentée avec le
  Global Char G_ACT_NAM      # le nom de l'action métier en cours. On saura si il y a des composants
  G_ACT_NAM=GACTION          # en testant la variable de bas de tableau de l'onglet composant
 Endif

Return

#-------------------------
$FIN
 # Quand on quitte la fenêtre de l'action sur bouton FIN ou OK on passe dans cette action
 #
 #
 If clalev([M:OCP]) & !([M:OCP]NBOBJ=0) & !(BOUT="O")
  Gosub UNLOCK_LOT From TRTOBJACT
 Endif

 If dim(G_ACT_NAM)>0 & dim(FROMSUBOBJ)>0
  Kill G_ACT_NAM
 Endif

Return

#==========================================
#========= TRT appelés par Gosub ==========
#==========================================

$UNLOCK_LOT

Local Char LKEY(200)                        # Identifiant de l'objet lié
Local Char TABELT(50)(1..10)  : Raz TABELT  # Tableau d'éléments de la clé de l'objet lié
Local Char TRTACTION                        # Traitement associé à l'action métier

If [M:OCP]OBJLNK="0"                                     # Les objets liés ne sont pas des objets métier

 If GACTION="GOBJET"
  TRTACTION="TRT"+G_ACT_NAM
 Else
  TRTACTION="TRT"+GACTION
 Endif


 ACTMET="ULK_OBJ_LNK" : Gosub ACTMET From =TRTACTION     # Les objets liés sont des objets métier
Else                                                     #
 Raz nolign
 For nolign=1 To [M:OCP]NBOBJ
  # Décomposition de la zone OBJREF en parties de clés
  Raz TABELT
  Call DECODE_REFOBJ([M:OCP]OBJREF(nolign-1),TABELT) From TRTOBJACT
  # Aiguillage et traitement de lock de la ligne du tableau
  Case val([M:OCP]OBJLNK)
   When GVML_OMDEPEN   # Objet lié de type Dépense
    LKEY = func GLOBIENS.GET_KEY_LAYOUTFAS (TABELT(1), val(TABELT(2)))
    Call UNLOCK_SYMBOLE("LOF",[M:OCP]OBJCPY(nolign-1),LKEY) From GLOBIENS
   When GVML_OMBIEN   #  Objet lié de type BCO
    LKEY = func GLOBIENS.GET_KEY_FXDASSETS (TABELT(1))
    Call UNLOCK_SYMBOLE("FAS",[M:OCP]OBJCPY(nolign-1),LKEY) From GLOBIENS
   When GVML_OMLOCFI  # Objet lié de type contrat de location financement
    Call UNLOCK_SYMBOLE("LEA",[M:OCP]OBJCPY(nolign-1),LKEY) From GLOBIENS
  Endcase
 Next nolign
Endif
Return

#========= S/p appelés par Call

#===========================================
# Permet de décomposer PIDEOBJ en tableau  #
# d'éléments de clé PTABKEYELT             #
#===========================================
Subprog DECODE_REFOBJ(PIDEOBJ,PTABKEYELT)
Value    Char    PIDEOBJ()
Variable Char    PTABKEYELT()()

 Local Integer I_CH               : Raz I_CH
 Local Integer I_ELT              : Raz I_ELT

 For I_CH=1 To len(PIDEOBJ)
  If mid$(PIDEOBJ,I_CH,1)="/"
   I_ELT+=1
  Else
   PTABKEYELT(I_ELT)+=mid$(PIDEOBJ,I_CH,1)
  Endif
 Next I_CH
End

#===========================================
# Mise à jour d'un lot de biens composants #
#===========================================
Subprog MAJ_OBJ_LNK(POBJ,PREF,POBJLNK,PACT,PRET)
Value    Char    POBJ     # Type d'objet principal
Value    Char    PREF     # Identifiant de l'objet principal
Value    Char    POBJLNK  # Type d'objet lié
Value    Char    PACT     # Nom de l'action métier à appliquer aux objets liés
Variable Integer PRET     # Code retour


# Variables utilisées par toutes les actions

Local    Integer I_OBJ
Local    Char    ACTTRT
Local    Char    OBJ_TABNAM
Local    Char    EVT_TABNAM
Local    Char    ACTMET

Local    Char    C_NOMCOL    : C_NOMCOL = "BCOCALC"
#Variables à fixer par le traitement de l'action dans l'étiquette "SET_CALCOBJ"
Local    Integer OBJLNKCALC  : OBJLNKCALC = G_NON # Calcul des objets liés
Local    Char    MSKOBJLNK   : MSKOBJLNK  = ""    # Masque dans lequel se trouve le tableau des biens liés à recalculer
Local    Char    ABSOBJLNK   : ABSOBJLNK  = ""    # Nom de la variable de bas de tableau des BCO liés à calculer.
Local    Char    REFOBJLNK   : REFOBJLNK  = ""    # Nom de la variable contenant la référence des biens à calculer
Local    Char    CPYOBJLNK   : CPYOBJLNK  = ""    # Société à laquelle appartiennent les biens liés

# Initialisations diverses

Raz PRET
ACTTRT="TRT"+PACT # Nom du traitement spécifique à chaque action

# Si les objets liés sont des objets métiers ouvertures des tables à mettre à jour
Case POBJLNK
 When "1"
  If !clalev([F:LOFM]) : Local File LAYOUTFAS [LOFM] : Endif
#  If !clalev([F:ELFM]) : Local File EVELOF    [ELFM] : Endif # n'existe plus à partir d'AKIRA
 When "2"
  If !clalev([F:FASM]) : Local File FXDASSETS [FASM] : Endif
  # Ouvrir la table des événements sur les biens comptables
 When "4"
  If !clalev([F:LEAM]) : Local File LEASE [LEAM]     : Endif
  # Ouvrir la table des événements sur les biens comptables
Endcase

# Aiguillage vers le TRT associé à chaque action : ouverture de tables supplémentaires

If GOK
 ACTMET="INIT_OBJ_DIV" : Gosub ACTMET From =ACTTRT
Endif

# Aiguillage vers le TRT associé à chaque action : Mise à jour des objets liés

If GOK
 ACTMET="MAJ_LNK"      : Gosub ACTMET From =ACTTRT
Endif

#-Ajout d'un mécanisme pour calculer automatiquemenet les BCO liés
If GOK
 ACTMET="SET_CALCOBJ"  : Gosub ACTMET From =ACTTRT
Endif

#CHECK IGNORE_BEGIN
If OBJLNKCALC=G_OUI

 Local    Integer CAL_TBCNX(1..GMAXCNXC,0..GTBCNX)      : # Contextes à calculer
 Local    Char    CAL_PIPEDEM(255)                      : # Canal d'écriture
 Local    Char    CAL_PIPEREP(255)                      : # Canal de lecture
 Local    Integer ERROR
 Local    Char    L_EXPRESSION(255)
 Local    Integer I_BCOCALC
 Local    Char    L_BCOREF

 If MSKOBJLNK<>""
  L_EXPRESSION="masklev([M:"+MSKOBJLNK+"])"
  If evalue(L_EXPRESSION)
   L_EXPRESSION="dim([M:"+MSKOBJLNK+"]"+C_NOMCOL+")"
   If evalue(L_EXPRESSION)
    L_EXPRESSION="dim([M:"+MSKOBJLNK+"]"+ABSOBJLNK+")"
    If evalue(L_EXPRESSION)
     L_EXPRESSION="dim([M:"+MSKOBJLNK+"]"+REFOBJLNK+")"
     If evalue(L_EXPRESSION)

      #> Ouverture d'une trace si pas ouverte
      If GTRACE = "" Then
        Call OUVRE_TRACE(mess(1,7774,1)) From LECFIC                     : # Calcul Amortissements
      Endif

      #> Ouverture du moteur de calcul
      Call OUVRE_CANAL_C (CPYOBJLNK, CAL_TBCNX, CAL_PIPEDEM, CAL_PIPEREP, ERROR) From GLOCALC

      #> Boucle sur les biens à calculer
      For I_BCOCALC=1 To evalue("[M:"+MSKOBJLNK+"]"+ABSOBJLNK)
       L_EXPRESSION = "[M:"+MSKOBJLNK+"]"+C_NOMCOL+"("+num$(I_BCOCALC)+"-1)=G_OUI"
       If evalue(L_EXPRESSION)
        L_BCOREF=evalue("[M:"+MSKOBJLNK+"]"+REFOBJLNK+"("+num$(I_BCOCALC)+"-1)")
        Call CALCUL_GROUPE_BIEN(CPYOBJLNK, L_BCOREF , GPIPCLCEXE, -1, 0, ERROR) From GLOCALC
        If ERROR<>0 : Break : Endif
       Endif
      Next I_BCOCALC

      #> Fermeture du moteur de calcul
      Call FERME_CANAL_C (CAL_PIPEDEM, CAL_PIPEREP, ERROR) From GLOCALC

     Endif
    Endif
   Endif
  Endif
 Endif
Endif
#CHECK IGNORE_END


End

#===========================================
# Correspondance code bouton -> Action     #
#===========================================

Subprog GET_ACTINF(PCOD,PVAL,PTYP,PRET)
Value    Char    PCOD   # Code BOUTON
Variable Char    PVAL() # Zone banalisé de retour de valeur
Variable Char    PTYP() # Type de bouton (Bouton / Menu / Ligne)
Variable Integer PRET   # Code retour

 Local Char    ACTNAM : Raz ACTNAM # Nom de l'action associé au code bouton
 Local Char    WINNAM : Raz WINNAM # Nom de la fenêtre associée à l'action
 Local Integer BOUTYP : Raz BOUTYP # Type de bouton (Bouton / Menu / Ligne)

 # Correspondance entre le code menu et l'action associée
 If !(clalev([F:AWT])) : Local File AWINBOUT [AWT] : Endif
 Filter [AWT] Where WIN=GBOITE
 For [AWT]
  If right$([F:AWT]CODBOUT,len([F:AWT]CODBOUT))=PCOD
   ACTNAM=[F:AWT]ACTBOUT
   BOUTYP=[F:AWT]TYPBOUT
   Break
  Endif
 Next
 Filter [AWT]

 If ACTNAM=""
  PRET=1 # Erreur
  End
 Else
  PVAL=ACTNAM
  Case BOUTYP
   When 1 : PTYP="B"
   When 3 : PTYP="M"
   When Default
  Endcase
  End
 Endif
End
