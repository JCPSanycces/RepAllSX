#<AdxTL>@(#)0.0.0.0 $Revision$

# Classe PROPLNH

###################
# CLASS PROPLNH
###################
$ACTION
  If (dim(TRACEUR_D) < 0) Then
    Global Integer TRACEUR_D
    Global Integer B_TRACE_D : B_TRACE_D = 1
    GUSER = adxusr
    TRACEUR_D = 0
    Call TRACE_CLEAR From AXUNIT
    Call TRACE_LINE( "D_____" - "Trace reinitialisee______" - CURPRO ) From AXUNIT
  Endif


  If (B_TRACE_D) Then
    Call TRACE_LINE( "D===" - time$ - ACTION - "Curpro"- CURPRO - "Curpth"- CURPTH ) From AXUNIT
  Endif
  Case CURPRO
    When ""         : Gosub METHODS    : # If CURPRO is empty, we are on class methods
    When Default    : Gosub PROPERTIES : # Otherwise it is a hook called on properties
  Endcase

Return

$EVENTS
  If (B_TRACE_D ) Then
    Call TRACE_LINE("D_____" - "Method : Action" - ACTION - "Curpro"- CURPRO - "Curpth"-CURPTH) From AXUNIT
  Endif
  Case CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"       : Gosub AREAD_AFTER        : # Get method attached to NBMVT
        When Default
      Endcase
    When "LINE"
    When "SUBLINE"
    When Default
  Endcase
Return

$METHODS
  If (B_TRACE_D ) Then
    Call TRACE_LINE("D_____" - "Method : Action" - ACTION - "Curpro"- CURPRO - "Curpth"-CURPTH) From AXUNIT
  Endif
Return


###################################################################
#            METHODES DE LA CLASSE  -  LAYOUTFAS
###################################################################

$AREAD_AFTER
  If ( CURPTH = "" ) Then
    If (B_TRACE_D) Then
      Call TRACE_LINE("D_AREAD_AFTER" - "______"- "Curpro"- CURPRO - "Curpth"-CURPTH  ) From AXUNIT
    Endif
  Endif
Return


###############
###############
# PROPERTY
###############
###############
$PROPERTIES
  If (B_TRACE_D) Then
    Call TRACE_LINE("D_____" - "Property :" - CURPRO - "Action" - ACTION) From AXUNIT
  Endif
  Case CURPRO
    When "CUMQTY"    : Gosub CUMQTY
    When Default
    Endcase
  Return


###################################################################
#            METHODES SUR LA PROPRIETE  -  CUR
###################################################################
$CUMQTY
Case ARULE
   When "INIT"      : Gosub INIT_CUMQTY      : # Init method attached to DEVTRA
   When "CONTROL"   : Gosub CONTROL_CUMQTY   : # Control method attached to DEVTRA
   When "PROPAGATE" : Gosub PROPAGATE_CUMQTY : # Propagate method attached to DEVTRA
   When "GET"       : Gosub GET_CUMQTY       : # Get method attached to DEVTRA
Endcase
Return
#---------------------
$INIT_CUMQTY
  If (B_TRACE_D) Then
    Call TRACE_LINE("D_INIT" - "______"- "Curpro"- CURPRO - "Curpth"-CURPTH  ) From AXUNIT
  Endif
Return
#---------------------
$CONTROL_CUMQTY
  If (B_TRACE_D) Then
    Call TRACE_LINE("D_CONTROL" - "______"- "Curpro"- CURPRO - "Curpth"-CURPTH  ) From AXUNIT
  Endif
Return
#---------------------
$PROPAGATE_CUMQTY
  If (B_TRACE_D) Then
    Call TRACE_LINE("D_PROPAGATE" - "______"- "Curpro"- CURPRO - "Curpth"-CURPTH  ) From AXUNIT
  Endif
Return
#---------------------
$GET_CUMQTY
  If (B_TRACE_D) Then
    Call TRACE_LINE("D_CUMQTY" - "______"- "Curpro"- CURPRO - "Curpth"-CURPTH  ) From AXUNIT
  Endif
Return

