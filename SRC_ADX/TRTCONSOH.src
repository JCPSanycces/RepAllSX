#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
# Affectation des valeurs pour la création d'un contrat de service à partir d'une ligne de
# commande de vente
##########################################################################################################
$SET_HEA_INFO
  #CHECK FILE_DECLARE SORDER [SOHW]
  Case IMPZON
    When "CONBPC"
      [M:CON0]CONBPC = [F:BPC]BPCNUM
      [M:CON1]CONORI = 7
      [M:CON1]CONORIVCR = ""
      [M:CON1]CONORIVCRL = 0
    When "CONCOT"
      [M:CON1]CONCOT = GSZDEFCOTCHX
    When "SIUDAT"
      [M:CON4]SIUDAT = date$
    When "SIUDAT"
      [M:CON4]SIUDAT = [F:SOHW]ORDDAT
    When "CONAMT"
      [M:CON4]CONAMT = 0
    When "PITCDT"
      [M:CON4]PITCDT = GCON4PITCDT
    When "CONVACBPR"
      [M:CONG]CONVACBPR = [F:BPC]VACBPR
    When "CPY"
      [M:CON0]CPY = [F:SOHW]CPY
    When "SALFCY"
      [M:CON0]SALFCY = [F:SOHW]SALFCY
  Endcase
Return
