  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:PJBU0A]PBUFCY
  PARBOUT(2) = ""
  PARBOUT(3) = ""
  PARBOUT(4) = num$("0")
  PARBOUT(5) = ""
  PARBOUT(6) = num$("0")
  PARBOUT(7) = [M:PJBU0]KEYCONCAT
  PARBOUT(8) = num$("0")
  PARBOUT(9) = ""
  PARBOUT(10) = num$(1)
  FLGEXE = 1
  GACTION = "CONSMFG"
  Call CONSULT_CHAR(VALBOUT,"MFG",PARBOUT) From GCONSULT
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


