# Superviseur
# Gestion de la fenêtre OPJMACTBUD

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:14:38"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OPJMACTBUD",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="PJBU0;PJBU0A;PJBU0C;PJBU1;PJBU2E;PJBU2R;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 0
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
If clalev([M:PJBU0])=0 : Local Mask PJMBUD0 [PJBU0] : Endif
If clalev([M:PJBU0A])=0 : Local Mask PJMBUD0A [PJBU0A] : Endif
If clalev([M:PJBU0C])=0 : Local Mask PJMBUD0C [PJBU0C] : Endif
If clalev([M:PJBU1])=0 : Local Mask PJMBUD1 [PJBU1] : Endif
If clalev([M:PJBU2E])=0 : Local Mask PJMBUD2E [PJBU2E] : Endif
If clalev([M:PJBU2R])=0 : Local Mask PJMBUD2R [PJBU2R] : Endif
Gosub TIT
nolign = 1
Return

$DEF_BOITE
Gosub HORODAT From WGOPJMACTBUD
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OPJMACTBUD" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJBU0]
&   Folder Mask [PJBU0A]
& , Folder Mask [PJBU0C]
& , Folder Mask [PJBU1]
& , Folder Mask [PJBU2E]
& , Folder Mask [PJBU2R]
& As [PJBU0A]
Titled [PJBU0A] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOPJMACTBUD
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OPJMACTBUD" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJBU0]
&   Folder Mask [PJBU0A]
& , Folder Mask [PJBU0C]
& , Folder Mask [PJBU1]
& , Folder Mask [PJBU2E]
& , Folder Mask [PJBU2R]
& As [PJBU0A]
Titled [PJBU0A] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [PJBU0A] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [PJBU0A] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [PJBU0A]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TIT(60) , TITTRN(60)
Call TEXTE(49730,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Return

$DEFAUT_BRO
Return

$SETBOX
Return

$SETORDER
Return

$ENDORDER
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "PJMBUD0"      : ABMSK(0)  = "PJBU0"    : AMA(0) = 1
NOMMSK(1) = "PJMBUD0A"     : ABMSK(1)  = "PJBU0A"   : AMA(1) = 1
NOMMSK(2) = "PJMBUD0C"     : ABMSK(2)  = "PJBU0C"   : AMA(2) = 1
NOMMSK(3) = "PJMBUD1"      : ABMSK(3)  = "PJBU1"    : AMA(3) = 1
NOMMSK(4) = "PJMBUD2E"     : ABMSK(4)  = "PJBU2E"   : AMA(4) = 1
NOMMSK(5) = "PJMBUD2R"     : ABMSK(5)  = "PJBU2R"   : AMA(5) = 1
NBMASK = 5
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:PJBU0])>0 : Default Mask [PJBU0] : Endif
 When 1 : If clalev([M:PJBU0A])>0 : Default Mask [PJBU0A] : Endif
 When 2 : If clalev([M:PJBU0C])>0 : Default Mask [PJBU0C] : Endif
 When 3 : If clalev([M:PJBU1])>0 : Default Mask [PJBU1] : Endif
 When 4 : If clalev([M:PJBU2E])>0 : Default Mask [PJBU2E] : Endif
 When 5 : If clalev([M:PJBU2R])>0 : Default Mask [PJBU2R] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:PJBU0])>0 : Gosub TITRES From W1PJMBUD0 : Endif
 When 1 : If clalev([M:PJBU0A])>0 : Gosub TITRES From W1PJMBUD0A : Endif
 When 2 : If clalev([M:PJBU0C])>0 : Gosub TITRES From W1PJMBUD0C : Endif
 When 3 : If clalev([M:PJBU1])>0 : Gosub TITRES From W1PJMBUD1 : Endif
 When 4 : If clalev([M:PJBU2E])>0 : Gosub TITRES From W1PJMBUD2E : Endif
 When 5 : If clalev([M:PJBU2R])>0 : Gosub TITRES From W1PJMBUD2R : Endif
Endcase
Return

$FERME_MASK
If clalev([M:PJBU0])>0 : Close Local Mask [PJBU0] : Endif
If clalev([M:PJBU0A])>0 : Close Local Mask [PJBU0A] : Endif
If clalev([M:PJBU0C])>0 : Close Local Mask [PJBU0C] : Endif
If clalev([M:PJBU1])>0 : Close Local Mask [PJBU1] : Endif
If clalev([M:PJBU2E])>0 : Close Local Mask [PJBU2E] : Endif
If clalev([M:PJBU2R])>0 : Close Local Mask [PJBU2R] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:PJBU0])>0 : Raz [M:PJBU0] : Endif
 When 1 : If clalev([M:PJBU0A])>0 : Raz [M:PJBU0A] : Endif
 When 2 : If clalev([M:PJBU0C])>0 : Raz [M:PJBU0C] : Endif
 When 3 : If clalev([M:PJBU1])>0 : Raz [M:PJBU1] : Endif
 When 4 : If clalev([M:PJBU2E])>0 : Raz [M:PJBU2E] : Endif
 When 5 : If clalev([M:PJBU2R])>0 : Raz [M:PJBU2R] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:PJBU0])>0 : Affzo [M:PJBU0] : Endif
 When 1 : If clalev([M:PJBU0A])>0 : Affzo [M:PJBU0A] : Endif
 When 2 : If clalev([M:PJBU0C])>0 : Affzo [M:PJBU0C] : Endif
 When 3 : If clalev([M:PJBU1])>0 : Affzo [M:PJBU1] : Endif
