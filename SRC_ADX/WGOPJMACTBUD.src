 When "£"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = ""
  PARBOUT(2) = ""
  PARBOUT(3) = ""
  PARBOUT(4) = [M:PJBU0]KEYCONCAT
  PARBOUT(5) = [M:PJBU0]CREDAT
  FLGEXE = 1
