$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
 When "2"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = "PJMBUD"
  PARBOUT(2) = [M:PJBU0A]PBUCOD
  FLGEXE = 1
  GACTION = "PJMEVEB"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OEVENB","SUBPEV","") From GSAISIE
 When "1"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:PJBU0]OPPNUM
  PARBOUT(2) = [M:PJBU0A]PBUCOD
  FLGEXE = 1
  GACTION = "PJMACTTAS"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OPJMACTTAS","PJMACTTAS","") From GSAISIE
 When "9"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:PJBU0A]PBUCOD
  FLGEXE = 1
  GACTION = "PJMBUD1T"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OPJMBUD1T","SUBPJBU1T","SPEPJBU1T") From GSAISIE
 When "4"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:PJBU0]OPPNUM
  PARBOUT(2) = [M:PJBU0A]PBUCOD
  PARBOUT(3) = AVOID.ACHAR
  FLGEXE = 1
  GACTION = "PJMFINOV0"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OPJMFINOV0","PJMFINOV0","") From GSAISIE
 When "5"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:PJBU0]OPPNUM
  PARBOUT(2) = [M:PJBU0A]PBUCOD
  FLGEXE = 1
  GACTION = "PJMAUTBUD"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OPJMAUTBUD","PJMAUTBUD","") From GSAISIE
 When "U"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:PJBU0]OPPNUM
  PARBOUT(2) = AVOID.ACHAR
  FLGEXE = 1
  GACTION = "PJMOVE"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OPJMOVE","PJMOVE","") From GSAISIE
 When "D"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:PJBU0]OPPNUM
  PARBOUT(2) = ""
  PARBOUT(3) = ""
  FLGEXE = 1
  GACTION = "PJMFINOV0"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OPJMFINOV0","PJMFINOV0","") From GSAISIE
 When "6"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = func PJMACTSPLD.CALLER_BUDGET()
  PARBOUT(2) = [M:PJBU0A]PBUCOD
  FLGEXE = 1
  GACTION = "PJMACTSPLD"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"OPJMACTSPLD","PJMACTSPLD","") From GSAISIE
 When "-"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = GBIDC3
  PARBOUT(2) = "PSO"
  PARBOUT(3) = ""
  FLGEXE = 1
  GACTION = "GOBJETC1"
  Call OBJET_CHAR(PARBOUT(1),PARBOUT(2),PARBOUT(3)) From GOBJET
  GBIDC3 = PARBOUT(1)
 When "("
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = ""
  PARBOUT(2) = ""
  PARBOUT(3) = num$("0")
  PARBOUT(4) = ""
  PARBOUT(5) = [M:PJBU0]KEYCONCAT
  PARBOUT(6) = ""
  PARBOUT(7) = [00/00/0000]
  PARBOUT(8) = ""
  PARBOUT(9) = num$("0")
  FLGEXE = 1
  GACTION = "FMFGB"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"FMFGB","FUNGBENCH","",5,"XYZFUNGBENCH") From GTRAITE
 When "*"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:PJBU0]KEYCONCAT
  PARBOUT(2) = [M:PJBU0A]PBUFCY
  PARBOUT(3) = num$(0)
  PARBOUT(4) = [M:PJBU0]CREDAT
  PARBOUT(5) = ""
  FLGEXE = 1
  GACTION = "CONSPTE"
  Call CONSULT_CHAR(VALBOUT,"PTE",PARBOUT) From GCONSULT
 When "^"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = ""
  PARBOUT(2) = ""
  PARBOUT(3) = ""
  PARBOUT(4) = [M:PJBU0]KEYCONCAT
  PARBOUT(5) = [M:PJBU0]CREDAT
  FLGEXE = 1
  GACTION = "CONSCSL"
