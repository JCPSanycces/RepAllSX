#<AdxTL>@(#)166.0.0.0 $Revision$

######################################################
Subprog TOUCHE
If clalev([F:HLP])>0
# Local File AMSKZON [AMZ]
# Read [AMZ]CODE = maskcou;zoncou
# If fstat = 0
#  Call OBJET("AID",[F:AMZ]MOTCLE,"") From GOBJET
# Endif
 Local File AMOTCLE [AMC]
 Read [AMC]AMC0 = 2;maskcou;zoncou
 If fstat = 0
  Call OBJET("AID",[F:AMC]MOTCLE,"") From GOBJET
 Endif
Endif
End

################################################
Subprog HELP
Call INFO(1,maskcou,zoncou)
mkstat = 2
End

################################################
Subprog INFO(NBMASK,NOMMSK,ZONE)
Value Integer NBMASK
Value Char    NOMMSK
Value Char    ZONE

Local Char    MESSA(75)(1..30) , OPTION(20)
Local Integer ER , LONG , I , J , K , NBMESS , DIME
Local Integer SAVNOL , SAVIND
Local Char    COUZON(GLONAVA)

COUZON = zoncou
SAVNOL = nolign
SAVIND = indice

Onerrgo ERRINF
ER = 0
Local File AMSK [AMK] , AMSKZON [AMZ] , ATEXTE [ATX] , ATYPE [ATY] , AOBJET [AOB]
Onerrgo
If ER
 Call MESSAGE(mess(163,124,1)) From GESECRAN : # Trop de tables ouvertes
 Goto SORT
Endif
Read [AMZ]CODE = NOMMSK(I);ZONE
If !fstat
 Gosub INF
Endif

$SORT
#zonsui = COUZON+"("+num$(SAVIND)+")"
indice = SAVIND
nolign = SAVNOL
End

$INF
NBMESS = 1
Call TEXTE([F:AMZ]INTIT,MESSA(NBMESS)) From OBJDIV
MESSA(1) = zoncou-":"-MESSA(NBMESS)
Read [ATY]CODTYP = [F:AMZ]CODTYP
If [F:AMZ]OBLIG=2
 NBMESS += 1
 MESSA(NBMESS) = mess(10,123,1) : # Zone obligatoire
Endif
NBMESS += 1
Call TEXTE([F:ATY]INTITTYP,MESSA(NBMESS)) From OBJDIV
MESSA(NBMESS) = mess(164,124,1)-":"-[F:AMZ]CODTYP-MESSA(NBMESS) : # Type de données
NBMESS += 1
MESSA(NBMESS) = mess(165,124,1)-":"-mess([F:ATY]TYPTYP,30,1) : # Type interne
If [F:ATY]TYPTYP=1
 If [F:ATY]NOLIB<>0 : MESSA(NBMESS) -= num$([F:ATY]NOLIB)
 Else               : MESSA(NBMESS) -= num$([F:AMZ]NOLIB)
 Endif
Endif
If [F:ATY]LNGTYP=0
 LONG = [F:AMZ]LONG
Else
 LONG = [F:ATY]LNGTYP
Endif
NBMESS += 1
MESSA(NBMESS) = mess(81,124,1)-":"-num$(LONG) : # Longueur
If find([F:ATY]TYPTYP,9,10)
 Call CALLNG(LONG,OPTION) From SUBADS
 MESSA(NBMESS) -= OPTION
Endif
If [F:ATY]FORTYP<>""
 MESSA(NBMESS) += "    "+mess(167,124,1)-":"-[F:ATY]FORTYP : # Format
Endif
OPTION = [F:ATY]OPTION+[F:AMZ]OPTSAI
If OPTION<>""
 Gosub DEF_OPTFMT From SELAMK
 For I=1 To len(OPTION)
  K = find(mid$(OPTION,I,1),TEX(1..NBTEX))
  If K & !instr(1,left$(OPTION,I-1),mid$(OPTION,I,1))
   NBMESS += 1
   MESSA(NBMESS) = mess(168,124,1)-":"-TEXTE(K,2) : # Option
  Endif
 Next I
Endif
If [F:ATY]OBJLIEN<>""
 Read [AOB]ABREV = [F:ATY]OBJLIEN
 NBMESS += 1
 Call TEXTE([F:AOB]LIBEL,MESSA(NBMESS)) From OBJDIV
 MESSA(NBMESS) = mess(166,124,1)-":"-[F:ATY]OBJLIEN-MESSA(NBMESS) : # Lien vers objet
 MESSA(NBMESS) -= "("+mess(56,123,1)-[F:AOB]NOMFIC+")" : # Table
Endif
Read [AMK]CODMSK = NOMMSK
If [F:AMZ]CODTYP="ABS"
 DIME = [F:AMK]NBLIGT([F:AMZ]NUMBLOC-1)
 If [F:AMK]ACTBLOC([F:AMZ]NUMBLOC-1)<>""
  If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
  Read [ACV]CODACT = [F:AMK]ACTBLOC([F:AMZ]NUMBLOC-1)
  If !fstat & [F:ACV]DIME<>0
   DIME = [F:ACV]DIME
  Endif
 Endif
 NBMESS += 1
 MESSA(NBMESS) = mess(9,127,1)-num$(DIME) : # Nombre de lignes
Endif
Infbox MESSA(1..NBMESS) Titled mess(36,124,1)-COUZON-"/"-mess(2,42,1)-NOMMSK-"["+[F:AMK]ABRMSK+"]"
Return

$ERRINF
ER = errn
Resume

###############################################
Subprog DLU
Local Char    COUZON(GLONAVA) , COUMSK(GLONAMK) , VALEUR(30)
Local Integer SAVIND , SAVNOL , STAT, ER
SAVIND = indice
SAVNOL = nolign
COUZON = zoncou
COUMSK = maskcou
Onerrgo ERRINF
VALEUR = num$(zc)
Onerrgo
Call DERLU(COUZON,COUMSK,VALEUR,STAT)
If VALEUR<>"" & STAT=0
 Case type(zc)
  When 1,2,4,5,6,7,8,9 : zc = val(VALEUR)
  When 3               : zc = gdat$(VALEUR)
  When Default         : zc = VALEUR
 Endcase
Endif
indice = SAVIND
nolign = SAVNOL
If STAT
 mkstat = 2
Else
 mkstat = 4
 status = 28
Endif
End


#####################################
Subprog DERLU(COUZON,COUMSK,VALEUR,STAT)
Value    Char    COUZON
Value    Char    COUMSK
Variable Char    VALEUR()
Variable Integer STAT
If COUZON="" or COUMSK="" : STAT = 1 : End : Endif
Local Integer NBLU , CHOI , I , J , K , OK , NZ , NUMERO , ER
Local Integer T(1..10) , TXT(1..10)
Local Date    DAT
Local Char    LU(15)(100)
Local Char    OBJET(GLONAOB)
Local Char    CLE(80) , CLEP(GLONID1) , CLE1(30) , CLE2(30)(1..16), ZCLES(30)(0..15)
Local Char    PARAM(80) , FICHE(GLONATB) , ZINTIT(GLONAVA) , TYPDON(GLONATY) , TEXTE(80)
Local Char    TIT1(30)(1..10) , TIT(30)
Local Char    A1(30)(1..100)
Local Char    A2(30)(1..100)
Local Char    A3(30)(1..100)
Local Char    A4(30)(1..100)
Local Char    A5(30)(1..100)
Local Char    A6(30)(1..100)
Local Char    A7(30)(1..100)
Local Char    A8(30)(1..100)
Local Char    A9(30)(1..100)
Local Char    A0(10)(1..100)
Onerrgo ERRLU

# On essaie d'ouvrir le moins de tables possibles
# Il en faut toute de même au moins 2

Local File AMSKZON [AMZ]
Read [AMZ]CODE = COUMSK;COUZON
If fstat : STAT = 1 : End : Endif
TYPDON = [F:AMZ]CODTYP
Close Local File [AMZ]

Local File ATYPE [ATY]
Read [ATY]CODTYP = TYPDON
If fstat : STAT = 1 : End : Endif
OBJET = [F:ATY]OBJLIEN
FICHE = [F:ATY]FICLIEN
Close Local File [ATY]
If OBJET="" : STAT = 1 : End : Endif

Local File ATABLE [ATB]
Read [ATB]CODFIC = FICHE
ZINTIT = [F:ATB]INTIT
Close Local File [ATB]

Local File AOBJET [AOB]
Read [AOB]ABREV = OBJET
If [F:AOB]LIBPAR<>0
 Local File AMSKPAR [AMP]
 Read [AMP]CODPAR = 1;COUMSK;COUZON;OBJET
 PARAM = vireblc(format$("KT:80X",[F:AMP]VALPAR),2)
 Close Local File [AMP]
Endif
Local File ATEXTE [ATX]
Call TEXTE([F:AOB]LIBEL,TIT) From OBJDIV
Close Local File [AOB]

Gosub SETCLE From ="WO"+OBJET
Gosub NOMFIC From ="WO"+OBJET
If evalue("clalev([F:"+ABFIC+"])")=0
 Gosub OUVFIC From ="WO"+OBJET
Endif
Gosub OUVRE_LISTE From ="WO"+OBJET
NZ = 0
For I=1 To [L]NBSEL
 If instr(1,[L]SELZON(I),"[F:"+ABFIC+"]")
  ZCLES(NZ) = right$([L]SELZON(I),len("[F:"+ABFIC+"]")+1)
  NZ += 1
 Endif
Next I

Local File ATABZON [ATZ]
For I=1 To NZ
 Read [ATZ]CODZONE = FICHE;ZCLES(I-1)
 Call TEXTE([F:ATZ]NOCOURT,TIT1(I)) From OBJDIV
 If [F:ATZ]CODTYP="M"
  TXT(I) = [F:ATZ]NOLIB
 Elsif [F:ATZ]CODTYP="ATX"
  TXT(I) = -1
 Else
  TXT(I) = 0
 Endif
Next I
Close Local File [ATZ] , [ATX]

Local File ALSTRD [ALS]
Local File =FICHE [AAA]
Local File ATEXTE [ATX]
For I=1 To NZ
 T(I) = evalue("type([F:AAA]"+ZCLES(I-1)+")")
Next I
NBLU = 0
NCLE = 0
For J=1 To dim(CLESEC)
 If CLESEC(J-1)<>""
  NCLE += 1
 Endif
Next J
If TYPGES=3  : NCLE -= 1 : Endif
If PARAM<>"" : NCLE -= 1 : Endif

Filter [ALS] Where USR=GUSER & OBJ=OBJET Order By Key ALS0 Desc
For [ALS]ALS0
 CLE   = [F:ALS]CLES
 K = instr(1,CLE,"~")
 If K
  CLE1 = left$(CLE,K-1)
  CLE  = right$(CLE,K+1)
 Else
  CLE1 = CLE
  CLE  = ""
 Endif
 For J=1 To dim(CLESEC)
  If CLESEC(J-1)<>""
   K = instr(1,CLE,"~")
   If K
    CLE2(J) = left$(CLE,K-1)
    CLE     = right$(CLE,K+1)
   Else
    CLE2(J) = CLE
    CLE     = ""
   Endif
  Endif
 Next J
 OK = 1
 If PARAM<>""
  If CLE2(1)<>num$(evalue(PARAM)) : OK = 0 : Endif
 Endif
 If OK
  NBLU += 1
  LU(NBLU) = CLE1
  Case evalue("type([F:AAA]"+CLEPRIM+")")
   When 1,2,4,5,6,7,8,9 : Assign "[F:AAA]"+CLEPRIM With val(CLE1)
   When 3               : Assign "[F:AAA]"+CLEPRIM With gdat$(CLE1)
   When Default         : Assign "[F:AAA]"+CLEPRIM With CLE1
  Endcase
  For J=1 To dim(CLESEC)
   If CLESEC(J-1)<>""
    Case evalue("type([F:AAA]"+CLESEC(J-1)+")")
     When 1,2,4,5,6,7,8,9 : Assign "[F:AAA]"+CLESEC(J-1) With val(CLE2(J))
     When 3               : Assign "[F:AAA]"+CLESEC(J-1) With gdat$(CLE2(J))
     When Default         : Assign "[F:AAA]"+CLESEC(J-1) With CLE2(J)
    Endcase
   Endif
  Next J
  Read [AAA] =
  A0(NBLU) = format$("N0:7#",num$(NBLU))
  For I=1 To NZ
   If TXT(I)<0
    NUMERO = evalue("[F:AAA]"+ZCLES(I-1))
    Call TEXTE(NUMERO,TEXTE) From OBJDIV
    Assign "A"+num$(I)+"("+num$(NBLU)+")" With TEXTE
   Elsif TXT(I)>0
    NUMERO = evalue("[F:AAA]"+ZCLES(I-1))
    Assign "A"+num$(I)+"("+num$(NBLU)+")" With mess(NUMERO,TXT(I),1)
   Else
    ER = 0
    Onerrgo ERRINF
    Case T(I)
     When 1,2,4,5,6,7,8,9
      Assign "A"+num$(I)+"("+num$(NBLU)+")" With num$(evalue("[F:AAA]"+ZCLES(I-1)))
     When 3
      DAT = gdat$(evalue("[F:AAA]"+ZCLES(I-1)))
      Assign "A"+num$(I)+"("+num$(NBLU)+")" With format$(GFMD,DAT)
     When Default
      Assign "A"+num$(I)+"("+num$(NBLU)+")" With evalue("[F:AAA]"+ZCLES(I-1))
    Endcase
    If ER
     Assign "A"+num$(I)+"("+num$(NBLU)+")" With ""
    Endif
    Onerrgo ERRLU
   Endif
  Next I
 Endif
 If NBLU>=dim(LU)-1 : Break : Endif
Next
Filter [ALS]
Close Local File [ALS] , [AAA]
If NBLU=0
 STAT = 1
 End
Elsif NBLU=1
 STAT = 0
 VALEUR = LU(1)
Else
 K = find(CLEPRIM,ZCLES)
 If K<1 : STAT = 1 : End : Endif
 Case K
  When 1       : CLEP = "AA"
  When 2       : CLEP = "BB"
  When 3       : CLEP = "CC"
  When 4       : CLEP = "DD"
  When 5       : CLEP = "EE"
  When 6       : CLEP = "FF"
  When 7       : CLEP = "GG"
  When 8       : CLEP = "HH"
  When Default : CLEP = "II"
 Endcase
 Case NZ
  When 1
   Local File (Char AA(30),Char ID(10))
&  From Variable A1(1..NBLU),A0(1..NBLU)
&  As [BBB]
&  Order By ID
   Choose [BBB] Using AA Titled TIT1(1)
&  Sized(80,240)
&  Starting At num$(evalue("[F:BBB]"+CLEP))>=VALEUR
&  Titled TIT-":"-mess(196,123,1)
  When 2
   Local File (Char AA(30),Char BB(30),Char ID(10))
&  From Variable A1(1..NBLU),A2(1..NBLU),A0(1..NBLU)
&  As [BBB]
&  Order By ID
   Choose [BBB] Using AA Titled TIT1(1), BB Titled TIT1(2)
&  Sized(80,240)
&  Starting At num$(evalue("[F:BBB]"+CLEP))>=VALEUR
&  Titled TIT-":"-mess(196,123,1)
  When 3
   Local File (Char AA(30),Char BB(30),Char CC(30),Char ID(10))
&  From Variable A1(1..NBLU),A2(1..NBLU),A3(1..NBLU),A0(1..NBLU)
&  As [BBB]
&  Order By ID
   Choose [BBB] Using AA Titled TIT1(1), BB Titled TIT1(2), CC Titled TIT1(3)
&  Sized(80,240)
&  Starting At num$(evalue("[F:BBB]"+CLEP))>=VALEUR
&  Titled TIT-":"-mess(196,123,1)
  When 4
   Local File (Char AA(30),Char BB(30),Char CC(30),Char DD(30),Char ID(10))
&  From Variable A1(1..NBLU),A2(1..NBLU),A3(1..NBLU),A4(1..NBLU),A0(1..NBLU)
&  As [BBB]
&  Order By ID
   Choose [BBB] Using AA Titled TIT1(1), BB Titled TIT1(2), CC Titled TIT1(3), DD Titled TIT1(4)
&  Sized(80,240)
&  Starting At num$(evalue("[F:BBB]"+CLEP))>=VALEUR
&  Titled TIT-":"-mess(196,123,1)
  When 5
   Local File (Char AA(30),Char BB(30),Char CC(30),Char DD(30),Char EE(30),Char ID(10))
&  From Variable A1(1..NBLU),A2(1..NBLU),A3(1..NBLU),A4(1..NBLU),A5(1..NBLU),A0(1..NBLU)
&  As [BBB]
&  Order By ID
   Choose [BBB] Using AA Titled TIT1(1), BB Titled TIT1(2), CC Titled TIT1(3), DD Titled TIT1(4)
&  , EE Titled TIT1(5)
&  Sized(80,240)
&  Starting At num$(evalue("[F:BBB]"+CLEP))>=VALEUR
&  Titled TIT-":"-mess(196,123,1)
  When 6
   Local File (Char AA(30),Char BB(30),Char CC(30),Char DD(30),Char EE(30),Char FF(30),Char ID(10))
&  From Variable A1(1..NBLU),A2(1..NBLU),A3(1..NBLU),A4(1..NBLU),A5(1..NBLU),A6(1..NBLU),A0(1..NBLU)
&  As [BBB]
&  Order By ID
   Choose [BBB] Using AA Titled TIT1(1), BB Titled TIT1(2), CC Titled TIT1(3), DD Titled TIT1(4)
&  , EE Titled TIT1(5), FF Titled TIT1(6)
&  Sized(80,240)
&  Starting At num$(evalue("[F:BBB]"+CLEP))>=VALEUR
&  Titled TIT-":"-mess(196,123,1)
  When 7
   Local File (Char AA(30),Char BB(30),Char CC(30),Char DD(30),Char EE(30),Char FF(30),Char GG(30)
&  ,Char ID(10))
&  From Variable A1(1..NBLU),A2(1..NBLU),A3(1..NBLU),A4(1..NBLU),A5(1..NBLU),A6(1..NBLU),A7(1..NBLU)
&  ,A0(1..NBLU)
&  As [BBB]
&  Order By ID
   Choose [BBB] Using AA Titled TIT1(1), BB Titled TIT1(2), CC Titled TIT1(3), DD Titled TIT1(4)
&  , EE Titled TIT1(5), FF Titled TIT1(6), GG Titled TIT1(7)
&  Sized(80,240)
&  Starting At num$(evalue("[F:BBB]"+CLEP))>=VALEUR
&  Titled TIT-":"-mess(196,123,1)
  When 8
   Local File (Char AA(30),Char BB(30),Char CC(30),Char DD(30),Char EE(30),Char FF(30),Char GG(30)
&  ,Char HH(30),Char ID(10))
&  From Variable A1(1..NBLU),A2(1..NBLU),A3(1..NBLU),A4(1..NBLU),A5(1..NBLU),A6(1..NBLU),A7(1..NBLU)
&  ,A8(1..NBLU),A0(1..NBLU)
&  As [BBB]
&  Order By ID
   Choose [BBB] Using AA Titled TIT1(1), BB Titled TIT1(2), CC Titled TIT1(3), DD Titled TIT1(4)
&  , EE Titled TIT1(5), FF Titled TIT1(6), GG Titled TIT1(7), HH Titled TIT1(8)
&  Sized(80,240)
&  Starting At num$(evalue("[F:BBB]"+CLEP))>=VALEUR
&  Titled TIT-":"-mess(196,123,1)
  When Default
   Local File (Char AA(30),Char BB(30),Char CC(30),Char DD(30),Char EE(30),Char FF(30),Char GG(30)
&  ,Char HH(30),Char II(30),Char ID(10))
&  From Variable A1(1..NBLU),A2(1..NBLU),A3(1..NBLU),A4(1..NBLU),A5(1..NBLU),A6(1..NBLU),A7(1..NBLU)
&  ,A8(1..NBLU),A9(1..NBLU),A0(1..NBLU)
&  As [BBB]
&  Order By ID
   Choose [BBB] Using AA Titled TIT1(1), BB Titled TIT1(2), CC Titled TIT1(3), DD Titled TIT1(4)
&  , EE Titled TIT1(5), FF Titled TIT1(6), GG Titled TIT1(7), HH Titled TIT1(8), II Titled TIT1(9)
&  Sized(80,240)
&  Starting At num$(evalue("[F:BBB]"+CLEP))>=VALEUR
&  Titled TIT-":"-mess(196,123,1)
 Endcase
 If status<>7
  STAT = 0
  VALEUR = evalue("[F:BBB]"+CLEP)
 Else
  STAT = 1
 Endif
Endif
End

$ERRLU
Call ERREUR(num$(errl)-errmes$(errn)-errm) From GESECRAN
End
