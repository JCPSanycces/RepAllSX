#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################
#   Traitement de sélection d'une adresse Tiers ou Interlocuteur/Intervention Module CRM 13 novembre 2001#
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GITYPADD
Global Integer GIENLARGE
Global Char GSZCODADD(GLONADR)  # FGR 21/08/2015 : X3SUIVI109994
Global Char GSZRECADD(GLONAIN)  # FGR 21/08/2015 : X3SUIVI109994
Global Char GSZBLCTIT(250)      # FGR 21/08/2015 : X3SUIVI109994

  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  GITYPADD = 0
  GSZCODADD = ""
  GSZRECADD = ""
  GIENLARGE = 0
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  [M:BAP6]CONTEXT = PARAM(1)
  #decodification du type de lieu dur la catégorie
  Gosub SETTYPAFF
  Case [M:BAP6]TYPELIEU
    When "1"
      GSZBLCTIT = mess(484,196,1) #Adresse Interlocuteurs
    When "2"
      GSZBLCTIT = mess(485,196,1) #Adresse Sites
    When Default
      GSZBLCTIT = ""
  Endcase
  Chgtbk  [M:BAP6]10  With GSZBLCTIT
  If [M:BAP6]TYPELIEU = "1" Then
    #Intervention sur site
    Gosub LOADFORITN
  Elsif [M:BAP6]TYPELIEU = "2" Then
    #Intervention en nos locaux
    Gosub LOADFORAUS
  Endif
  Affzo [M:BAP6]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:BAP6]
  Kill GITYPADD
  Kill GIENLARGE
  Kill GSZCODADD
  Kill GSZRECADD
  Kill GSZBLCTIT
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      Gosub ONSELECT
    When "B"
      Gosub ONENLARGE
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
#
#  ONSELECT   : Gestion du bouton "Sélectionner".
#  ONENLARGE  : Gestion du bouton "Elargir".
#  LOADFORITN : Chargement de la fenêtre dans l'objet Intervention pour une intervention chez le client.
#  CHKADD     : Vérifie si des adresses supplémentaires peuvent être obtenues.
#  AFFBPRADD  : Affiche l'adresse d'une ligne Tiers.
#  AFFCCNADD  : Affiche l'adresse d'une ligne Interlocuteur.
#  RAZBLCADD  : Efface le contenu du bloc Détail.
#  LOADFORAUS : Chargement de la fenêtre dans l'objet Intervention pour une intervention en nos locaux.
#  SETTYPAFF  : Détermine le type d'affichage à réaliser
#
##########################################################################################################
##########################################################################################################
$ONSELECT
  #Transfère l'adresse sélectionnée dans l'onglet Lieu
  VALEUR = [M:BAP6]ADDLIG1
  [M:ITN3]ADD(0) = [M:BAP6]ADDLIG1
  [M:ITN3]ADD(1) = [M:BAP6]ADDLIG2
  [M:ITN3]ADD(2) = [M:BAP6]ADDLIG3
  [M:ITN3]ZIP = [M:BAP6]POSCOD
  [M:ITN3]CTY = [M:BAP6]CTY
  [M:ITN3]SAT = [M:BAP6]SAT
  [M:ITN3]CRY = [M:BAP6]CRY
  [M:ITN3]TEL = [M:BAP6]TEL
  [M:ITN3]ITNTYPADD = GITYPADD
  [M:ITN3]ITNCODADD = GSZCODADD
  [M:ITN3]ITNRECADD = GSZRECADD
  Affzo [M:ITN3]1-99
  mkstat = 4
  FIN = 1
Return

##########################################################################################################
$ONENLARGE
  If GIENLARGE Then
    GIENLARGE = 0
  Else
    GIENLARGE = 1
  Endif
  If [M:BAP6]TYPELIEU = "1" Then
    #Intervention sur site
    Gosub LOADFORITN
  Elsif [M:BAP6]TYPELIEU = "2" Then
    #Intervention en nos locaux
    Gosub LOADFORAUS
  Endif
  Affzo [M:BAP6]1-99
Return

##########################################################################################################
$LOADFORITN
Local Integer IBOTADD
Local Integer INBADD

  IBOTADD = 0
  INBADD = 0
  Call RAZBLCADD
  Raz [M:BAP6]NBBPRADD
  Raz [M:BAP6]CODADR
  Raz [M:BAP6]LIBADR
  Raz [M:BAP6]NBCCNADD
  Raz [M:BAP6]TYPADD
  Raz [M:BAP6]NAM
  Raz [M:BAP6]COD
  Raz [M:BAP6]LIBCOD
  Raz [M:BAP6]NUM
  #Chargement des adresses Tiers
  If [M:ITN0]BPC <> "" Then
    Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [M:ITN0]BPC
    For [BPA]
      If INBADD >= dim([M:BAP6]CODADR)-1 Then
        Break
      Endif
      [M:BAP6]CODADR(INBADD) = [F:BPA]BPAADD
      #LSE 24/01/2007
      [M:BAP6]LIBADR(INBADD) =[F:BPA]BPADES
      If !IBOTADD Then
        Gosub COPY_F_BPA_M_BPA6 From TRTBAP6  # FGR 21/08/2015 : X3SUIVI109994 : on simplifie un peu
        IBOTADD = 1
      Endif
     INBADD += 1
    Next
    Filter [BPA]
  Endif
  [M:BAP6]NBBPRADD = INBADD
  #Chargement de l'adresse interlocuteur
  INBADD = 0
  Gosub LOADCCNADD
  #Chargement des adresses des relations interlocuteurs
  If GIENLARGE Then
     Gosub LCNTADDL
  Else
     Gosub LOADCNTADD
  Endif
  [M:BAP6]NBCCNADD = INBADD
Return

##########################################################################################################
$LOADCCNADD
  Read [AIN]AIN0=[M:ITN0]CCN
  If fstat Then
    Return
  Endif
  Call BUILDFULNAM("AIN", [M:BAP6]NAM(INBADD)) From CRMUTIL140
  [M:BAP6]TYPADD(INBADD) = 1
  [M:BAP6]COD(INBADD) = ""
  [M:BAP6]LIBCOD(INBADD) = ""
  [M:BAP6]NUM(INBADD) = [M:ITN0]CCN
  If !IBOTADD Then
    [M:BAP6]ADDLIG1 = [F:AIN]ADD(0)
    [M:BAP6]ADDLIG2 = [F:AIN]ADD(1)
    [M:BAP6]ADDLIG3 = [F:AIN]ADD(2)
    [M:BAP6]POSCOD = [F:AIN]ZIP
    [M:BAP6]CTY = [F:AIN]CTY
    [M:BAP6]SAT = [F:AIN]SAT
    [M:BAP6]CRY = [F:AIN]CRY
    Read [TCY]TCY0=[M:BAP6]CRY
    If fstat Then
      [M:BAP6]CRYNAM = ""
    Else
      Call LECTEXTRA([M:BAP6]CRYNAM,"TABCOUNTRY","CRYDES",[M:BAP6]CRY,"") From ATEXTRA
    Endif
    [M:BAP6]TEL = [F:AIN]CNTETS
    [M:BAP6]FAX = [F:AIN]CNTFAX
    [M:BAP6]WEB = [F:AIN]CNTEMA
    IBOTADD = 1
  Endif
  INBADD += 1
Return

##########################################################################################################
$LOADCNTADD
  Filter [CNT] Where [F:CNT]CCNCRM = [M:ITN0]CCN
  For [CNT] CNT2
    If INBADD >= dim([M:BAP6]COD)-1 Then
     Break
    Endif
    [M:BAP6]TYPADD(INBADD) = [F:CNT]BPATYP + 1
    [M:BAP6]COD(INBADD) = [F:CNT]BPAADD
    [M:BAP6]NUM(INBADD) = [F:CNT]BPANUM
    If [M:BAP6]TYPADD(INBADD) = 2 Then
      Read [BPR]BPR0=[F:CNT]BPANUM
      If fstat Then
        [M:BAP6]NAM(INBADD) = ""
      Else
        [M:BAP6]NAM(INBADD) = [F:BPR]BPRNAM
      Endif
    Elsif [M:BAP6]TYPADD(INBADD) = 3 Then
      Read [CPY]CPY0=[F:CNT]BPANUM
      If fstat Then
        [M:BAP6]NAM(INBADD) = ""
      Else
        [M:BAP6]NAM(INBADD) = [F:CPY]CPYNAM
      Endif
    Elsif [M:BAP6]TYPADD(INBADD) = 4 Then
      Read [FCY]FCY0=[F:CNT]BPANUM
      If fstat Then
        [M:BAP6]NAM(INBADD) = ""
      Else
        [M:BAP6]NAM(INBADD) = [F:FCY]FCYNAM
      Endif
    Endif
    Read [BPA]BPA0=[F:CNT]BPATYP;[F:CNT]BPANUM;[F:CNT]BPAADD
    If !fstat Then
      [M:BAP6]LIBCOD(INBADD) = [F:BPA]BPADES
      If !IBOTADD Then
        Gosub COPY_F_BPA_M_BPA6 From TRTBAP6  # FGR 21/08/2015 : X3SUIVI109994 : on simplifie un peu
        IBOTADD = 1
      Endif
    Endif
    INBADD += 1
  Next
  Filter [CNT]
Return

##########################################################################################################
$LCNTADDL
Local Char SZNAM(50)

  SZNAM = ""
  Filter [CNT] Where [F:CNT]CCNCRM = [M:ITN0]CCN
  For [CNT] CNT2
    If INBADD >= dim([M:BAP6]COD)-1 Then
      Break
    Endif
    If [F:CNT]BPATYP = 1 Then
      Read [BPR]BPR0=[F:CNT]BPANUM
      If fstat Then
        SZNAM = ""
      Else
        SZNAM = [F:BPR]BPRNAM
      Endif
    Elsif [F:CNT]BPATYP = 2 Then
      Read [CPY]CPY0=[F:CNT]BPANUM
      If fstat Then
        SZNAM = ""
      Else
        SZNAM = [F:CPY]CPYNAM
      Endif
    Elsif [F:CNT]BPATYP = 3 Then
      Read [FCY]FCY0=[F:CNT]BPANUM
      If fstat Then
        SZNAM = ""
      Else
        SZNAM = [F:FCY]FCYNAM
      Endif
    Endif
    If SZNAM <> "" Then
      Filter [BPA] Where [F:BPA]BPATYP = [F:CNT]BPATYP and [F:BPA]BPANUM = [F:CNT]BPANUM Order By [F:BPA]BPAADD
      For [BPA]
        [M:BAP6]TYPADD(INBADD) = [F:CNT]BPATYP + 1
        [M:BAP6]NAM(INBADD) = SZNAM
        [M:BAP6]COD(INBADD) = [F:BPA]BPAADD
        [M:BAP6]NUM(INBADD) = [F:CNT]BPANUM
        [M:BAP6]LIBCOD(INBADD) = [F:BPA]BPADES
        If !IBOTADD Then
          Gosub COPY_F_BPA_M_BPA6 From TRTBAP6  # FGR 21/08/2015 : X3SUIVI109994 : on simplifie un peu
          IBOTADD = 1
        Endif
        INBADD += 1
      Next
      Filter [BPA]
    Endif
  Next
  Filter [CNT]
Return

##########################################################################################################
# Vérifie si des adresses supplémentaires peuvent être obtenues
#########################################################
Subprog CHKADD(ICASE, IADD)
Value Integer ICASE
Variable Integer IADD

Local Integer INBADD

  INBADD = 0
  #On prévoit le pire.
  IADD = 0
  If ICASE = 1 Then
    #Chez le client
    If [M:ITN0]BPC = "" Then
      #L'intervention concerne des interlocuteurs.
      If [M:ITN0]CCN = "" Then
        #Il n'y a aucun interlocuteur de renseigné.
        IADD = 0
      Else
        #On regarde si l'interlocuteur dispose d'au moins une relation
        If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
        Filter [CNT] Where [F:CNT]CCNCRM = [M:ITN0]CCN
        For [CNT] CNT2
          INBADD += 1
        Next
        Filter [CNT]
        If INBADD Then
          IADD = 1
        Endif
      Endif
    Else
      #Le rendez-vous concerne un tiers.
      If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
      Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [M:ITN0]BPC
      For [BPA]
        INBADD += 1
      Next
      Filter [BPA]
      If INBADD > 1 Then
        #Il y a plusieurs addresses Tiers. Ca vaut le coup d'afficher la fenêtre.
        IADD = 1
      Else
        #Il n'y a qu'une seule adresse Tiers. Il faut regarder si il y a un interlocuteur
        If [M:ITN0]CCN <> "" Then
          IADD = 1
        Endif
      Endif
    Endif
  Elsif ICASE = 2 Then
    #En nos locaux
    #Vérifie si la base de données contient au moins un site.
    If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
    Filter [FCY] Where [F:FCY]LEGCPY = GDEFSOC
    For [FCY]FCY1
      IADD += 1
      Break
    Next
    Filter [FCY]
    If !IADD Then
      For [FCY]
        IADD += 1
        Break
      Next
    Endif
  Endif
End

##########################################################################################################
# Affiche l'adresse d'une ligne Tiers
#######################################################################
Subprog AFFBPRADD(INOLIN)
Value Integer INOLIN

Local Integer INOTENOUGH

  If INOLIN < 0 Then
    End
  Endif
  If [M:BAP6]CODADR(INOLIN) = "" : End : Endif
  INOTENOUGH = 0
  #Purge le bloc adresse.
  Call RAZBLCADD
  #Vérifie si on a ce qu'il faut pour afficher une adresse
  If [M:ITN0]BPC = "" Then
    INOTENOUGH = 1
  Endif
  If [M:BAP6]CODADR(INOLIN) = "" Then
    INOTENOUGH = 1
  Endif
  If INOTENOUGH Then
    GMESSAGE = mess(483,196,1) #Aucune adresse n'a pu être affichée. Insuffisamment d'informations disponibles.
    GERR = 1
    GITYPADD = 2
    GSZCODADD = ""
    GSZRECADD = ""
    Affzo [M:BAP6]15
    End
  Endif
  Read [BPA]BPA0=1;[M:ITN0]BPC;[M:BAP6]CODADR(INOLIN)
  If fstat Then
    GMESSAGE = mess(297,196,1) #Erreur lecture. La recherche a été abandonnée.
    GERR = 1
  Else
    Gosub COPY_F_BPA_M_BPA6 From TRTBAP6  # FGR 21/08/2015 : X3SUIVI109994 : on simplifie un peu
  Endif
  GITYPADD = 2
  GSZCODADD = [M:BAP6]CODADR(INOLIN)
  GSZRECADD = [M:ITN0]BPC
  Affzo [M:BAP6]15
End

##########################################################################################################
# Affiche l'adresse d'une ligne Interlocuteur
#######################################################################
Subprog AFFCCNADD(INOLIN)
Value Integer INOLIN

Local Integer INOTENOUGH

  If INOLIN < 0 Then
    End
  Endif
  If [M:BAP6]NUM(INOLIN) = "" Then
    End
  Endif
  INOTENOUGH = 0
  #Purge le bloc adresse.
  Call RAZBLCADD
  #Vérifie si on a ce qu'il faut pour afficher une adresse
  If [M:BAP6]TYPADD(INOLIN) > 1 Then
    If [M:BAP6]NUM(INOLIN) = "" Then
      INOTENOUGH = 1
    Endif
    If [M:BAP6]COD(INOLIN) = "" Then
      INOTENOUGH = 1
    Endif
  Else
    If [M:BAP6]NUM(INOLIN) = "" Then
      INOTENOUGH = 1
    Endif
  Endif
  If INOTENOUGH Then
    GMESSAGE = mess(483,196,1) #Aucune adresse n'a pu être affichée. Insuffisamment d'informations disponibles.
    GERR = 1
    GITYPADD = [M:BAP6]TYPADD(INOLIN)
    GSZCODADD = ""
    GSZRECADD = ""
    Affzo [M:BAP6]15
    End
  Endif
  #Adresse Interlocuteur
  If [M:BAP6]TYPADD(INOLIN) = 1 Then
    Read [AIN]AIN0=[M:BAP6]NUM(INOLIN)
    If fstat Then
      GMESSAGE = mess(297,196,1) #Erreur lecture. La recherche a été abandonnée.
      GERR = 1
    Else
      [M:BAP6]ADDLIG1 = [F:AIN]ADD(0)
      [M:BAP6]ADDLIG2 = [F:AIN]ADD(1)
      [M:BAP6]ADDLIG3 = [F:AIN]ADD(2)
      [M:BAP6]POSCOD = [F:AIN]ZIP
      [M:BAP6]CTY = [F:AIN]CTY
      [M:BAP6]SAT = [F:AIN]SAT
      [M:BAP6]CRY = [F:AIN]CRY
      Read [TCY]TCY0=[M:BAP6]CRY
      If fstat Then
        [M:BAP6]CRYNAM = ""
      Else
        Call LECTEXTRA([M:BAP6]CRYNAM,"TABCOUNTRY","CRYDES",[M:BAP6]CRY,"") From ATEXTRA
      Endif
      [M:BAP6]TEL = [F:AIN]CNTETS
      [M:BAP6]FAX = [F:AIN]CNTFAX
      [M:BAP6]WEB = [F:AIN]CNTEMA
    Endif
  Endif
  If [M:BAP6]TYPADD(INOLIN) > 1 Then
    If [M:BAP6]TYPADD(INOLIN) = 2 Then
      #Adresse Tiers
      Read [BPA]BPA0=1;[M:BAP6]NUM(INOLIN);[M:BAP6]COD(INOLIN)
    Elsif [M:BAP6]TYPADD(INOLIN) = 3 Then
      #Adresse Société
      Read [BPA]BPA0=2;[M:BAP6]NUM(INOLIN);[M:BAP6]COD(INOLIN)
    Elsif [M:BAP6]TYPADD(INOLIN) = 4 Then
      #Adresse Site
      Read [BPA]BPA0=3;[M:BAP6]NUM(INOLIN);[M:BAP6]COD(INOLIN)
    Endif
    If fstat Then
      GMESSAGE = mess(297,196,1) #Erreur lecture. La recherche a été abandonnée.
      GERR = 1
    Else
      Gosub COPY_F_BPA_M_BPA6 From TRTBAP6  # FGR 21/08/2015 : X3SUIVI109994 : on simplifie un peu
    Endif
  Endif
  GITYPADD = [M:BAP6]TYPADD(INOLIN)
  GSZCODADD = [M:BAP6]COD(INOLIN)
  GSZRECADD = [M:BAP6]NUM(INOLIN)
  Affzo [M:BAP6]15
End

##########################################################################################################
# Efface le contenu du bloc Détail
###############################################################
Subprog RAZBLCADD
  Raz [M:BAP6]ADDLIG1
  Raz [M:BAP6]ADDLIG2
  Raz [M:BAP6]ADDLIG3
  Raz [M:BAP6]POSCOD
  Raz [M:BAP6]CTY
  Raz [M:BAP6]SAT
  Raz [M:BAP6]CRY
  Raz [M:BAP6]CRYNAM
  Raz [M:BAP6]TEL
  Raz [M:BAP6]FAX
  Raz [M:BAP6]WEB
End

##########################################################################################################
# Charge les adresses des sites.
######################################################################
$LOADFORAUS
Local Integer IBOTADD
Local Integer IC
Local Integer INBADD
Local Integer IDUP
Local Integer IEXIT
Local Char SZSITE(GLONFCY)

  IBOTADD = 0
  INBADD = 0
  IC = 0
  IDUP = 0
  IEXIT = 0
  Call RAZBLCADD
  Raz [M:BAP6]NBBPRADD
  Raz [M:BAP6]CODADR
  Raz [M:BAP6]NBCCNADD
  Raz [M:BAP6]TYPADD
  Raz [M:BAP6]NAM
  Raz [M:BAP6]COD
  Raz [M:BAP6]LIBCOD
  Raz [M:BAP6]NUM
  #Etape 1 : Affichage de l'adresse Société du site Support client de l'utilisateur mentionné et de toutes les
  #          adresses de ce site.
  If [M:ITN1]REP <> "" Then
    Read [AUS]CODUSR=[M:ITN1]REP
    If fstat Then
      GMESSAGE = mess(297,196,1) #Erreur lecture. La recherche a été abandonnée.
      GERR = 1
      [M:BAP6]NBBPRADD = 0
      [M:BAP6]NBCCNADD = INBADD
      Return
    Endif
    SZSITE = func CRM_UTIL.GET_SITE_DEFAUT ("HDK", "")
    If SZSITE <> "" Then
      Read [FCY]FCY0=SZSITE
      If fstat Then
        GMESSAGE = mess(297,196,1) #Erreur lecture. La recherche a été abandonnée.
        GERR = 1
        [M:BAP6]NBBPRADD = 0
        [M:BAP6]NBCCNADD = INBADD
        Return
      Endif
      Read [CPY]CPY0=[F:FCY]LEGCPY
      If fstat Then
        GMESSAGE = mess(297,196,1) #Erreur lecture. La recherche a été abandonnée.
        GERR = 1
        [M:BAP6]NBBPRADD = 0
        [M:BAP6]NBCCNADD = INBADD
        Return
      Endif
      Read [BPA]BPA0=2;[F:CPY]CPY;[F:CPY]BPAADD
      If !fstat Then
        IDUP = 0
        Call CHKDUP(INBADD, 3, [F:CPY]BPAADD, [F:CPY]CPY, IDUP) From TRTBAP6
        If !IDUP Then
          If INBADD >= dim([M:BAP6]COD)-1 Then
            GMESSAGE = mess(297,196,1) #Erreur lecture. La recherche a été abandonnée.
            GERR = 1
            [M:BAP6]NBBPRADD = 0
            [M:BAP6]NBCCNADD = INBADD
            Return
          Endif
          [M:BAP6]TYPADD(INBADD) = 3
          [M:BAP6]NAM(INBADD) = [F:CPY]CPYNAM
          [M:BAP6]COD(INBADD) = [F:CPY]BPAADD
          [M:BAP6]LIBCOD(INBADD) = [F:BPA]BPADES
          [M:BAP6]NUM(INBADD) = [F:CPY]CPY
          If !IBOTADD Then
            Gosub COPY_F_BPA_M_BPA6 From TRTBAP6  # FGR 21/08/2015 : X3SUIVI109994 : on simplifie un peu
            IBOTADD = 1
          Endif
          INBADD += 1
        Endif
      Endif
      Filter [BPA] Where [F:BPA]BPATYP = 3 and [F:BPA]BPANUM = SZSITE
      For [BPA]
        IDUP = 0
        Call CHKDUP(INBADD, 4, [F:BPA]BPAADD, [F:FCY]FCY, IDUP) From TRTBAP6
        If !IDUP Then
          If INBADD >= dim([M:BAP6]COD)-1 Then
            IEXIT = 1
            Break
          Endif
          [M:BAP6]TYPADD(INBADD) = 4
          [M:BAP6]NAM(INBADD) = [F:FCY]FCYNAM
          [M:BAP6]COD(INBADD) = [F:BPA]BPAADD
          [M:BAP6]LIBCOD(INBADD) = [F:BPA]BPADES
          [M:BAP6]NUM(INBADD) = [F:FCY]FCY
          If !IBOTADD Then
            Gosub COPY_F_BPA_M_BPA6 From TRTBAP6  # FGR 21/08/2015 : X3SUIVI109994 : on simplifie un peu
            IBOTADD = 1
          Endif
          INBADD += 1
        Endif
      Next
      Filter [BPA]
      If IEXIT Then
        [M:BAP6]NBBPRADD = 0
        [M:BAP6]NBCCNADD = INBADD
        Return
      Endif
    Endif
  Endif
  #Etape 2 : Affiche les adresses de tous les sites de la fiche utilisateur
  If [M:ITN1]REP <> "" Then
    Read [AUS]CODUSR=[M:ITN1]REP
    If fstat Then
      GMESSAGE = mess(297,196,1) #Erreur lecture. La recherche a été abandonnée.
      GERR = 1
      [M:BAP6]NBBPRADD = 0
      [M:BAP6]NBCCNADD = INBADD
      Return
    Endif
    For IC = 0 To 12
      Read [FCY]FCY0=GFCYDEF(IC+1)
      If !fstat Then
        #Affichage de l'adresse société par défaut
        Read [CPY]CPY0=[F:FCY]LEGCPY
        If !fstat Then
          Read [BPA]BPA0=2;[F:CPY]CPY;[F:CPY]BPAADD
          If !fstat Then
            IDUP = 0
            Call CHKDUP(INBADD, 3, [F:CPY]BPAADD, [F:CPY]CPY, IDUP) From TRTBAP6
            If !IDUP Then
              If INBADD >= dim([M:BAP6]COD)-1 Then
                IEXIT = 1
                Break
              Endif
              [M:BAP6]TYPADD(INBADD) = 3
              [M:BAP6]NAM(INBADD) = [F:CPY]CPYNAM
              [M:BAP6]COD(INBADD) = [F:CPY]BPAADD
              [M:BAP6]LIBCOD(INBADD) = [F:BPA]BPADES
              [M:BAP6]NUM(INBADD) = [F:CPY]CPY
              If !IBOTADD Then
                Gosub COPY_F_BPA_M_BPA6 From TRTBAP6  # FGR 21/08/2015 : X3SUIVI109994 : on simplifie un peu
                IBOTADD = 1
              Endif
              INBADD += 1
            Endif
          Endif
        Endif
        #Affichages des adresses du site
        Filter [BPA] Where [F:BPA]BPATYP = 3 and [F:BPA]BPANUM = GFCYDEF(IC + 1)
        For [BPA]
          IDUP = 0
          Call CHKDUP(INBADD, 4, [F:BPA]BPAADD, [F:FCY]FCY, IDUP) From TRTBAP6
          If !IDUP Then
            If INBADD >= dim([M:BAP6]COD)-1 Then
              IEXIT = 1
              Break
            Endif
            [M:BAP6]TYPADD(INBADD) = 4
            [M:BAP6]NAM(INBADD) = [F:FCY]FCYNAM
            [M:BAP6]COD(INBADD) = [F:BPA]BPAADD
            [M:BAP6]LIBCOD(INBADD) = [F:BPA]BPADES
            [M:BAP6]NUM(INBADD) = [F:FCY]FCY
            If !IBOTADD Then
              Gosub COPY_F_BPA_M_BPA6 From TRTBAP6  # FGR 21/08/2015 : X3SUIVI109994 : on simplifie un peu
              IBOTADD = 1
            Endif
            INBADD += 1
          Endif
        Next
        Filter [BPA]
        If IEXIT Then
          Break
        Endif
      Endif
    Next
    If IEXIT Then
      [M:BAP6]NBBPRADD = 0
      [M:BAP6]NBCCNADD = INBADD
      Return
    Endif
  Endif
  #Etape 3 : Afficher l'adresse par défaut de tous les sites de la société courante.
  Filter [FCY] Where [F:FCY]LEGCPY = GDEFSOC
  For [FCY]FCY1
    Read [BPA]BPA0=3;[F:FCY]FCY;[F:FCY]BPAADD
    If !fstat Then
      IDUP = 0
      Call CHKDUP(INBADD, 4, [F:FCY]BPAADD, [F:FCY]FCY, IDUP) From TRTBAP6
      If !IDUP Then
        If INBADD >= dim([M:BAP6]COD)-1 Then
          IEXIT = 1
          Break
        Endif
        [M:BAP6]TYPADD(INBADD) = 4
        [M:BAP6]NAM(INBADD) = [F:FCY]FCYNAM
        [M:BAP6]COD(INBADD) = [F:FCY]BPAADD
        [M:BAP6]LIBCOD(INBADD) = [F:BPA]BPADES
        [M:BAP6]NUM(INBADD) = [F:FCY]FCY
        If !IBOTADD Then
          Gosub COPY_F_BPA_M_BPA6 From TRTBAP6  # FGR 21/08/2015 : X3SUIVI109994 : on simplifie un peu
          IBOTADD = 1
        Endif
        INBADD += 1
      Endif
    Endif
  Next
  Filter [FCY]
  If IEXIT Then
    [M:BAP6]NBBPRADD = 0
    [M:BAP6]NBCCNADD = INBADD
    Return
  Endif
  #Etape 4 : Afficher toutes les adresses de tous les sites de toutes les sociétés.
  If GIENLARGE Then
    For [CPY]
      Filter [BPA] Where [F:BPA]BPATYP = 2 and [F:BPA]BPANUM = [F:CPY]CPY
      For [BPA]
        IDUP = 0
        Call CHKDUP(INBADD, 3, [F:BPA]BPAADD, [F:CPY]CPY, IDUP) From TRTBAP6
        If !IDUP Then
          If INBADD >= dim([M:BAP6]COD)-1 Then
            IEXIT = 1
            Break
          Endif
          [M:BAP6]TYPADD(INBADD) = 3
          [M:BAP6]NAM(INBADD) = [F:CPY]CPYNAM
          [M:BAP6]COD(INBADD) = [F:BPA]BPAADD
          [M:BAP6]LIBCOD(INBADD) = [F:BPA]BPADES
          [M:BAP6]NUM(INBADD) = [F:CPY]CPY
          If !IBOTADD Then
            Gosub COPY_F_BPA_M_BPA6 From TRTBAP6  # FGR 21/08/2015 : X3SUIVI109994 : on simplifie un peu
            IBOTADD = 1
          Endif
          INBADD += 1
        Endif
      Next
      Filter [BPA]
      If IEXIT Then
        Break
      Endif
      Filter [FCY] Where [F:FCY]LEGCPY = [F:CPY]CPY
      For [FCY]FCY1
        Filter [BPA] Where [F:BPA]BPATYP = 3 and [F:BPA]BPANUM = [F:FCY]FCY
        For [BPA]
          IDUP = 0
          Call CHKDUP(INBADD, 4, [F:BPA]BPAADD, [F:FCY]FCY, IDUP) From TRTBAP6
          If !IDUP Then
            If INBADD >= dim([M:BAP6]COD)-1 Then
              IEXIT = 1
              Break
            Endif
            [M:BAP6]TYPADD(INBADD) = 4
            [M:BAP6]NAM(INBADD) = [F:FCY]FCYNAM
            [M:BAP6]COD(INBADD) = [F:BPA]BPAADD
            [M:BAP6]LIBCOD(INBADD) = [F:BPA]BPADES
            [M:BAP6]NUM(INBADD) = [F:FCY]FCY
            If !IBOTADD Then
              Gosub COPY_F_BPA_M_BPA6 From TRTBAP6  # FGR 21/08/2015 : X3SUIVI109994 : on simplifie un peu
              IBOTADD = 1
            Endif
            INBADD += 1
          Endif
        Next
        Filter [BPA]
        If IEXIT Then
          Break
        Endif
      Next
      Filter [FCY]
      If IEXIT Then
        Break
      Endif
    Next
  Endif
  [M:BAP6]NBBPRADD = 0
  [M:BAP6]NBCCNADD = INBADD
Return

##########################################################################################################
# Détermine le type d'affichage à réaliser
##########################################################
$SETTYPAFF
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  Read [ADI]CODE=407;PARAM(2)
  If fstat Then
    [M:BAP6]TYPELIEU = ""
  Else
    Case [F:ADI]N1
      When 1
        #Intervention nulle part
        [M:BAP6]TYPELIEU = ""
      When 2
        #Intervention sur site
        [M:BAP6]TYPELIEU = "1"
      When 3
        #Intervention en nos locaux
        [M:BAP6]TYPELIEU = "2"
      When Default
        [M:BAP6]TYPELIEU = ""
    Endcase
  Endif
Return

