###################################################################################################
# Classe TECALLITM
# Issue X3-31898 - 2017-11-17 by FGR
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SAL_ADD_LINE"                : Gosub SAL_ADD_LINE
    When "MANUF_ADD_LINE"              : Gosub MANUF_ADD_LINE
    When "MANUAL_ADD_LINE"             : Gosub MANUAL_ADD_LINE       # Issue X3-65941 - 2018-01-12 by FGR
    #
    When "_GET_KEYCONCAT"              : Gosub _GET_KEYCONCAT
    When "_EXIST_KEYCONCAT"            : Gosub _EXIST_KEYCONCAT
    When "_LOAD_ONE_OPPNUM"            : Gosub _LOAD_ONE_OPPNUM
    When "_RITT_COPY"                  : Gosub _RITT_COPY
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return

###################################################################################################
# METHODS
###################################################################################################
$SAL_ADD_LINE
#Value Char SPJT ()
#Value Char SITMREF ()
#Value Char SUOM ()
#Value Decimal ODLQTY
#Value Decimal DLVQTY
#Value Decimal ALLQTY
#Local Integer ARET_VALUE

Local Integer ILINE
Local Char SCONCAT(250)
Local Integer IRET
Local Char SOPPNUM(GLONVCR)
Local Char SPBUCOD(GLONPBU)
Local Char STASCOD(GLONTAC)

  # ------------------------------------
  # Method called from sales deliveries to add in to technical class all the information to manage
  # stock allocations in the project.
  # Only if needed :
  #   * PJT(Task) is not empty
  #   * ITMREF is not empty
  #   * ITMREF is managed on the task (in PJMTSKITM)
  # ------------------------------------
  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  If SITMREF <> AVOID.ACHAR and SPJT <> AVOID.ACHAR Then
    Local File ITMMASTER [ITM]
    Read [ITM]ITM0=SITMREF
    SCONCAT = fmet this._GET_KEYCONCAT(SPJT, SITMREF)
    IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(this.ACTX, SPJT, SOPPNUM, SPBUCOD, STASCOD)
    If STASCOD <> AVOID.ACHAR Then
      Local File PJMTSKITM [JTT]
      Filter [JTT] Where [F:JTT]OPPNUM = SOPPNUM and [F:JTT]TASCOD = STASCOD and [F:JTT]ITMREF = SITMREF
      For [JTT]
        ILINE = fmet this.ADDLINE("RITT", [V]CST_ALASTPOS)
        If ILINE <> [V]CST_ANOTDEFINED Then
          this.RITT(ILINE).CALLER = "SALES"
          this.RITT(ILINE).PJT = SPJT
          this.RITT(ILINE).ITMREF = SITMREF
          this.RITT(ILINE).CONCAT = SCONCAT
          this.RITT(ILINE).OPPNUM = SOPPNUM
          this.RITT(ILINE).TASCOD = STASCOD
          this.RITT(ILINE).UOM = SUOM
          this.RITT(ILINE).ODLQTY = ODLQTY
          this.RITT(ILINE).DLVQTY = DLVQTY
          If [F:ITM]STOMGTCOD > 1 Then
            this.RITT(ILINE).ALLQTY = ALLQTY
          Else
            this.RITT(ILINE).ALLQTY = 0
          Endif
        Endif
        Break
      Next
      Filter [JTT]
    Endif
  Endif
  # ------------------------------------
Return

###################################################################################################
$MANUF_ADD_LINE
#Value Char SPJT ()
#Value Char SITMREF ()
#Value Char SUOM ()
#Value Decimal ALLQTY
#Local Integer ARET_VALUE

Local Integer ILINE
Local Char SCONCAT(250)
Local Integer IRET
Local Char SOPPNUM(GLONVCR)
Local Char SPBUCOD(GLONPBU)
Local Char STASCOD(GLONTAC)

  # ------------------------------------
  # Method called from sales deliveries to add in to technical class all the information to manage
  # stock allocations in the project.
  # Only if needed :
  #   * PJT(Task) is not empty
  #   * ITMREF is not empty
  #   * ITMREF is managed on the task (in PJMTSKITM)
  # ------------------------------------
  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  If SITMREF <> AVOID.ACHAR and SPJT <> AVOID.ACHAR Then
    Local File ITMMASTER [ITM]
    Read [ITM]ITM0=SITMREF
    If [F:ITM]STOMGTCOD = 2 Then
      SCONCAT = fmet this._GET_KEYCONCAT(SPJT, SITMREF)
      IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(this.ACTX, SPJT, SOPPNUM, SPBUCOD, STASCOD)
      If STASCOD <> AVOID.ACHAR Then
        Local File PJMTSKITM [JTT]
        Filter [JTT] Where [F:JTT]OPPNUM = SOPPNUM and [F:JTT]TASCOD = STASCOD and [F:JTT]ITMREF = SITMREF
        For [JTT]
          ILINE = fmet this.ADDLINE("RITT", [V]CST_ALASTPOS)
          If ILINE <> [V]CST_ANOTDEFINED Then
            this.RITT(ILINE).CALLER = "MANUF"
            this.RITT(ILINE).PJT = SPJT
            this.RITT(ILINE).ITMREF = SITMREF
            this.RITT(ILINE).CONCAT = SCONCAT
            this.RITT(ILINE).OPPNUM = SOPPNUM
            this.RITT(ILINE).TASCOD = STASCOD
            this.RITT(ILINE).UOM = SUOM
            this.RITT(ILINE).ALLQTY = ALLQTY
          Endif
          Break
        Next
        Filter [JTT]
      Endif
    Endif
  Endif
  # ------------------------------------
Return

###################################################################################################
$MANUAL_ADD_LINE
#Value Char SPJT ()
#Value Char SITMREF ()
#Value Char SUOM ()
#Value Decimal ALLQTY
#Variable Decimal SHTQTY
#Local Integer ARET_VALUE

Local Integer ILINE
Local Char SCONCAT(250)
Local Integer IRET
Local Char SOPPNUM(GLONVCR)
Local Char SPBUCOD(GLONPBU)
Local Char STASCOD(GLONTAC)

  # Issue X3-65941 - 2018-01-12 by FGR
  # ------------------------------------
  # Method called from sales deliveries to add in to technical class all the information to manage
  # stock allocations in the project.
  # Only if needed :
  #   * PJT(Task) is not empty
  #   * ITMREF is not empty
  #   * ITMREF is managed on the task (in PJMTSKITM)
  # ------------------------------------
  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  If SITMREF <> AVOID.ACHAR and SPJT <> AVOID.ACHAR Then
    Local File ITMMASTER [ITM]
    Read [ITM]ITM0=SITMREF
    If [F:ITM]STOMGTCOD = 2 Then
      SCONCAT = fmet this._GET_KEYCONCAT(SPJT, SITMREF)
      IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(this.ACTX, SPJT, SOPPNUM, SPBUCOD, STASCOD)
      If STASCOD <> AVOID.ACHAR Then
        Local File PJMTSKITM [JTT]
        Filter [JTT] Where [F:JTT]OPPNUM = SOPPNUM and [F:JTT]TASCOD = STASCOD and [F:JTT]ITMREF = SITMREF
        For [JTT]
          ILINE = fmet this.ADDLINE("RITT", [V]CST_ALASTPOS)
          If ILINE <> [V]CST_ANOTDEFINED Then
            this.RITT(ILINE).CALLER = "MANUAL"
            this.RITT(ILINE).PJT = SPJT
            this.RITT(ILINE).ITMREF = SITMREF
            this.RITT(ILINE).CONCAT = SCONCAT
            this.RITT(ILINE).OPPNUM = SOPPNUM
            this.RITT(ILINE).TASCOD = STASCOD
            this.RITT(ILINE).UOM = SUOM
            this.RITT(ILINE).ALLQTY = ALLQTY
            this.RITT(ILINE).SHTQTY = SHTQTY
          Endif
          Break
        Next
        Filter [JTT]
      Endif
    Endif
  Endif
  # ------------------------------------
Return
Return

###################################################################################################
$_GET_KEYCONCAT
#Value Char SPJT ()
#Value Char SITMREF ()
#Local Char ARET_VALUE(250)

  [L]ARET_VALUE = SPJT + "~" + SITMREF
Return

###################################################################################################
$_EXIST_KEYCONCAT
#Value Char SKEY ()
#Local Integer ARET_VALUE

Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = [V]CST_ANO
  # ------------------------------------
  NI = find(SKEY, this.RITT(1..maxtab(this.RITT)).CONCAT)
  While NI > 0
    If this.RITT(NI) <> null and find(this.RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = [V]CST_AYES
      Break
    Else
      NI1 = NI
      NI = find(SKEY, this.RITT(NI+1..maxtab(this.RITT)).CONCAT)
      If NI > 0 Then
        NI += NI1
      Endif
    Endif
  Wend
Return

###################################################################################################
$_LOAD_ONE_OPPNUM
#Variable Instance TECALLITM Using C_TECALLITM : #
#Local Integer ARET_VALUE

Local Char SOPPNUM(GLONVCR)
Local Integer NI
Local Integer ILINE
Local Integer IRET

  # Issue X3-18442/120906 - 2017-01-13 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  Raz SOPPNUM
  For NI = 1 To maxtab(TECALLITM.RITT)
    If TECALLITM.RITT(NI) <> null and find(TECALLITM.RITT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If SOPPNUM = AVOID.ACHAR Then
        SOPPNUM = TECALLITM.RITT(NI).OPPNUM
      Endif
      If TECALLITM.RITT(NI).OPPNUM = SOPPNUM Then
        ILINE = fmet this.ADDLINE("RITT", [V]CST_ALASTPOS)
        If ILINE <> [V]CST_ANOTDEFINED Then
          IRET = fmet this._RITT_COPY(TECALLITM, NI, ILINE)
          If IRET < [V]CST_AERROR Then
            IRET = fmet TECALLITM.ADELLINE("RITT", TECALLITM.RITT(NI).AORDER)
          Endif
        Endif
      Endif
    Endif
  Next NI
  # ------------------------------------
Return

###################################################################################################
$_RITT_COPY
#Variable Instance TECALLITM Using C_TECALLITM : #
#Value Shortint LINEFROM
#Value Shortint LINETO
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  this.RITT(LINETO).CALLER = TECALLITM.RITT(LINEFROM).CALLER
  this.RITT(LINETO).PJT    = TECALLITM.RITT(LINEFROM).PJT
  this.RITT(LINETO).ITMREF = TECALLITM.RITT(LINEFROM).ITMREF
  this.RITT(LINETO).OPPNUM = TECALLITM.RITT(LINEFROM).OPPNUM
  this.RITT(LINETO).TASCOD = TECALLITM.RITT(LINEFROM).TASCOD
  this.RITT(LINETO).CONCAT = TECALLITM.RITT(LINEFROM).CONCAT
  this.RITT(LINETO).UOM    = TECALLITM.RITT(LINEFROM).UOM
  this.RITT(LINETO).DLVQTY = TECALLITM.RITT(LINEFROM).DLVQTY
  this.RITT(LINETO).ALLQTY = TECALLITM.RITT(LINEFROM).ALLQTY
  this.RITT(LINETO).SHTQTY = TECALLITM.RITT(LINEFROM).SHTQTY
  # ------------------------------------
Return

