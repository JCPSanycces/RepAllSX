Subprog AS_NBLIG

GBOUT1 = ""
GBOUT2 = ""
If [M:MKI1]NBLIG = 0 : End : Endif
If [M:MKI1]ITMREF(nolign-1) = ""  : End : Endif
GBOUT1 = mess(16,198,1)
If clalev ([M:MTK0]) <= 0 : GBOUT2 = mess(313,198,1) : Endif
End






