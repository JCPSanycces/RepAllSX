#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################
# IMPBPC : Import / Export des Clients                               #
######################################################################

$ACTION

Case ACTION
 When "IMP_OUVRE"     : Gosub OUVRE
 When "IMPORT"        : Gosub IMPORT
 When "IMP_ZONE"      : Gosub IMP_ZONE
 When "IMP_TAB"       : Gosub IMP_ZONE
 When "IMP_CREATION"  : Gosub CREATION
 When "IMP_DEFTRT"    : Gosub IMP_DEFTRT
 When "IMP_INICRE"    : Gosub IMP_INICRE
 When "IMP_INIMOD"    : Gosub IMP_INICRE
 When "EXP_OUVRE"     : Gosub EXP_OUVRE
 When "EXPORT"        : Gosub EXPORT
 When "EXP_ZONE"      : Gosub EXP_ZONE    # FGR 10/02/2010 : X3SUIVI59669
 When "IMP_FERME"     : Gosub IMP_FERME   # FGR 29/11/2010 : X3SUIVI69504
 When "AP_IMPORT"     : Gosub AP_IMPORT   # FGR 29/11/2010 : X3SUIVI69504
Endcase

Return

#######################################################################
#                        IMPORT
#######################################################################

$OUVRE
If !clalev([F:BPR2])  Local File BPARTNER [BPR2]  : Endif  # FGR 17/12/2010 : X3SUIVI69959

Global Char GSTBFIC(GLONABR)(dim([M:IMP2]ABREV))   # FGR 29/11/2010 : X3SUIVI69504
Global Char GLASTFLGREC(10)                        # FGR 29/11/2010 : X3SUIVI69504

# Issue 85335 - 2013-05-13 by MAE : ouverture des écrans de BPR
If !clalev([M:BPR0])  Local Mask BPR0 [BPR0]  : Endif
If !clalev([M:BPR1])  Local Mask BPR1 [BPR1]  : Endif
If !clalev([M:BPR2])  Local Mask BPR2 [BPR2]  : Endif
If !clalev([M:BPAB])  Local Mask BPABPR [BPAB]  : Endif
If !clalev([M:CNTB])  Local Mask CNTBPR [CNTB]  : Endif
If !clalev([M:BIDB])  Local Mask BIDBPR [BIDB]  : Endif

Local Char CORFIC (10)
CORFIC="BPADDRESS" : Gosub IMP_CORRESP From TRTX3IMP
CORFIC="BPDLVCUST" : Gosub IMP_CORRESP From TRTX3IMP
CORFIC="CONTACT"   : Gosub IMP_CORRESP From TRTX3IMP

Gosub OUVRE_TEXTE

Return

#######################################################################
$IMP_FERME
  # FGR 29/11/2010 : X3SUIVI69504 (début)
  If dim(GSTBFIC) > 0 Then
    Kill GSTBFIC
  Endif
  If dim(GLASTFLGREC) > 0 Then
    Kill GLASTFLGREC
  Endif
  # FGR 29/11/2010 : X3SUIVI69504 (fin)
Return

#######################################################################
$AP_IMPORT
  # FGR 29/11/2010 : X3SUIVI69504 (début)
  Case IMPFIC
    When "BPR", "BPC"
      Local Integer I
      Local Integer K

      If SEPNUM > 0 Then
        #MAE, bg 76694
        #If GLASTFLGREC <> [M:AOE1]FLGREC(SEPNUM-1) Then
         #GLASTFLGREC = [M:AOE1]FLGREC(SEPNUM-1) # Optimisation pour ne le refaire que si nécessaire
         # Raz GSTBFIC
          K = 0
          For I = 0 To [M:IMP2]NBFIC-1
            If [M:IMP2]FLG(I) = [M:AOE1]FLGREC(SEPNUM-1) Then
              If !find([M:IMP2]ABREV(I),GSTBFIC(0..dim(GSTBFIC)-1))
                GSTBFIC(K) = [M:IMP2]ABREV(I)
              Endif
              If GSTBFIC(K) = "BPR" Then
                # FGR 17/12/2010 : X3SUIVI69959 : On planque la classe [F:BPR]
               [F:BPR2] = [F:BPR]
              Endif
              K += 1
            Endif
          Next I
        Endif
      #Endif
    When Default
  Endcase
  # FGR 29/11/2010 : X3SUIVI69504 (fin)
Return

#---------------------------------------------------------------------
$OUVRE_TEXTE

Gosub DECLARE_TEXTE From TRTX3IMP

Case ACTION
  When "IMP_OUVRE"    : G_IMPORT=1
  When "EXP_OUVRE"    : G_EXPORT=1
Endcase

#   textes BPCUSTOMER : clients              ( texte ent cde *71 à *78   texte ent fac  *81 à *88 )
TSTCHAMP(31)="BPC*71" : TSTCHAMP(32)="BPC*72" : TSTCHAMP(33)="BPC*73" : TSTCHAMP(34)="BPC*74"
TSTCHAMP(35)="BPC*75" : TSTCHAMP(36)="BPC*76" : TSTCHAMP(37)="BPC*77" : TSTCHAMP(38)="BPC*78"
TSTCHAMP(41)="BPC*81" : TSTCHAMP(42)="BPC*82" : TSTCHAMP(43)="BPC*83" : TSTCHAMP(44)="BPC*84"
TSTCHAMP(45)="BPC*85" : TSTCHAMP(46)="BPC*86" : TSTCHAMP(47)="BPC*87" : TSTCHAMP(58)="BPC*88"

#   textes BPDLVCUST  : clients livres       ( texte prepa   *71 à *78   texte livraison  *81 à *88 )
TSTCHAMP(61)="BPD*71" : TSTCHAMP(62)="BPD*72" : TSTCHAMP(63)="BPD*73" : TSTCHAMP(64)="BPD*74"
TSTCHAMP(65)="BPD*75" : TSTCHAMP(66)="BPD*76" : TSTCHAMP(67)="BPD*77" : TSTCHAMP(68)="BPD*78"
TSTCHAMP(71)="BPD*81" : TSTCHAMP(72)="BPD*82" : TSTCHAMP(73)="BPD*83" : TSTCHAMP(74)="BPD*84"
TSTCHAMP(75)="BPD*85" : TSTCHAMP(76)="BPD*86" : TSTCHAMP(77)="BPD*87" : TSTCHAMP(78)="BPD*88"

Gosub OUVRE_TEXTE From TRTX3IMP

#--- Particularite import textes clients/livres ( en creation )
If G_IMPORT
   # FGR 28/10/2009 : APPLIX57697 : En test les écrans ne sont pas ouverts. Donc dim([M:BPC4]BPAADD)=-1
   Local Integer IDIMBPC4

   If [M:IMP2]TEST = 2 Then
     If !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif
     Call LECTURE("ACV", "BPA", "") From CONTOBJ
     If !fstat and [F:ACV]FLACT = 2 Then
       IDIMBPC4 = [F:ACV]DIME
     Else
       IDIMBPC4 = 1
     Endif
   Else
     IDIMBPC4 = dim([M:BPC4]BPAADD)
   Endif
   #Local Char TXT_BPAADD (GLONBPD) (0..dim([M:BPC4]BPAADD))
   #Local Char TXT_PRPTEX (GLONTXC) (0..dim([M:BPC4]BPAADD))
   #Local Char TXT_DLVTEX (GLONTXC) (0..dim([M:BPC4]BPAADD))
   Local Char TXT_BPAADD (GLONBPD) (0..IDIMBPC4)
   Local Char TXT_PRPTEX (GLONTXC) (0..IDIMBPC4)
   Local Char TXT_DLVTEX (GLONTXC) (0..IDIMBPC4)
   Local Integer TXT_NOL
Endif
#---
Return

#######################################################################
$IMP_DEFTRT
Return

#######################################################################
$CREATION
Return

#######################################################################
#--- Lecture d'un enregistrement
$IMPORT

Local Integer NOL
Gosub IMP_DECLARE From TRTX3IMP

Case IMPFIC
    When "BPA" :
# ---------------------------------------------------#
#     Adresse                                        #
# ---------------------------------------------------#
#        Default Mask [BPAC]
        #MAE/FGR,bg 71813
        Call NEW_TEL_EMAIL("[F:BPA]")
        ICLEPRIM (0) = "[F:BPA]BPAADD"
        TPRIM (0) = "CODADR"
        NBASTAB = "NBADR"
        Gosub RECHERCHE_LIGNE From TRTX3IMP
#       C'est une nouvelle ligne
        If nolign=0
            NOL=[M]NBADR
            [M]XNUMLIG = NOL
            nolign=NOL+1
            [M]NBADR+=1
        Else
            [M]XNUMLIG=nolign-1
        Endif
    When "CNT" :
# ---------------------------------------------------#
#     Contact                                        #
# ---------------------------------------------------#
#        Default Mask [CNTC]
        ICLEPRIM (0) = "CCNCRM"
        NBASTAB = "NBCNT"
        Gosub RECHERCHE_LIGNE From TRTX3IMP
#       C'est une nouvelle ligne
        If nolign=0
            NOL=[M]NBCNT
            [M]KNOLIG = NOL
            nolign = NOL + 1
            [M]NBCNT+=1
        Else
            [M]KNOLIG=nolign-1
        Endif
    When "BID" :
# ---------------------------------------------------#
#     Rib                                            #
# ---------------------------------------------------#
#        Default Mask [BIDC]
 #MAE, le 08/10/2010, bg66884
        ICLEPRIM (0) = "[F:BID]BIDNUM"
        ICLESEC (0)  = "[F:BID]BPAADD"  # FGR 27/08/2010 : X3SUIVI66884
        TPRIM (0) = "BIDNUM"
        TSEC (0) = "BIDBPAADD"          # FGR 27/08/2010 : X3SUIVI66884
        NBASTAB = "NBRIB"
        Gosub RECHERCHE_LIGNE From TRTX3IMP
    When "BPD" :
# ---------------------------------------------------#
#     Clients livrées                                #
# ---------------------------------------------------#
#        Default Mask [BPC4]
        ICLEPRIM (0) = "[F:BPD]BPAADD"
        TPRIM (0) = "BPAADD"
        NBASTAB = "NBDLV"
        Gosub RECHERCHE_LIGNE From TRTX3IMP
#       C'est une nouvelle ligne
        If nolign=0
            NOL=[M]NBDLV
            [M]XNUMLIG = NOL
            [M]NBDLV+=1
            nolign = NOL+1
        Else
            [M]XNUMLIG=nolign-1
        Endif
    When "BPC" :
# ---------------------------------------------------#
#     Clients                                 #
# ---------------------------------------------------#
#MAE, le 26/01/09, bg 51837
        Raz TXT_BPAADD

Endcase

Gosub IMPORT_TEXTE

Return

#---------------------------------------------------------------------
#--- Textes des clients-livres : passage obligatoire par un tableau
#    intermediaire de stockage des cles textes
#    ( stockage impossible dans [M:BPC4] pendant la boucle d import )
$IMPORT_TEXTE
Case IMPFIC
     When "BPC"
          If G_TX11     : # --- Texte entete commande ---
             Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
             If G_CLE_CLOB<>"" : [M:BPC1]ORDTEX=G_CLE_CLOB : [M:BPC1]WORDTEX=2 : Endif
              # FGR 20/04/2012 : X3SUIVI80439 (début)
              If [M:BPC1]ORDTEX <> "" Then
                If dim(GBPC1ORDTEX) < 0 Then
                  Global Char GBPC1ORDTEX(type([M:BPC1]ORDTEX)-10)
                Endif
                GBPC1ORDTEX = [M:BPC1]ORDTEX
              Else
                If dim(GBPC1ORDTEX) >= 0 Then
                  Kill GBPC1ORDTEX
                Endif
              Endif
              # FGR 20/04/2012 : X3SUIVI80439 (fin)
          Endif
          If G_TX12     : # --- Texte entete facture ---
             Gosub IMP_T2 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
             If G_CLE_CLOB<>"" : [M:BPC1]INVTEX=G_CLE_CLOB : [M:BPC1]WINVTEX=2 : Endif
              # FGR 20/04/2012 : X3SUIVI80439 (début)
              If [M:BPC1]INVTEX <> "" Then
                If dim(GBPC1INVTEX) < 0 Then
                  Global Char GBPC1INVTEX(type([M:BPC1]INVTEX)-10)
                Endif
                GBPC1INVTEX = [M:BPC1]INVTEX
              Else
                If dim(GBPC1INVTEX) >= 0 Then
                  Kill GBPC1INVTEX
                Endif
              Endif
              # FGR 20/04/2012 : X3SUIVI80439 (fin)
          Endif
     When "BPD"
          TXT_NOL=find("",TXT_BPAADD)-1
          If G_TX21     : # --- Texte entete prepa ---
             Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
             If G_CLE_CLOB<>""
                TXT_BPAADD(TXT_NOL)=[F:BPD]BPAADD : TXT_PRPTEX(TXT_NOL)=G_CLE_CLOB : [M:BPC4]TWPRPTEX=2
             Endif
         Endif
          If G_TX22     : # --- Texte entete livraison ---
             Gosub IMP_T2 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
             If G_CLE_CLOB<>""
                #MAE, bg51481
                TXT_BPAADD(TXT_NOL)=[F:BPD]BPAADD : TXT_DLVTEX(TXT_NOL)=G_CLE_CLOB : [M:BPC4]TWDLVTEX=2
             Endif
          Endif
Endcase

Return


#######################################################################
$IMP_ZONE
Local Char     IMPZONFIC(30) : IMPZONFIC =""
Local Char     IMPZONMSK(30) : IMPZONMSK =""
Local Integer  IINDICE       : IINDICE=0
Local Integer  IXZ

Case IMPFIC

    When "BPC","BPR" :
# ---------------------------------------------------#
#     Client                                         #
# ---------------------------------------------------#
# ---------------------------------------------------#
#     Deux fichiers sont concernés [BPC] et [BPR]    #
#     Il faut rechercher l'abréviation fichier       #
# ---------------------------------------------------#
# ---   Masque identité : Fichier BPARTNER
        # FGR 11/02/2010 : X3SUIVI59669 : Seul le commentaire a été ajouté ici
        # Note FGR : si on veut que dans l'import l'écran BPRBPC y figure, il faut
        # Modifier l'objet BPC pour ajouter dans import "BPCUSTOMER / BPRBPC".
        # "BPARTNER / BPRBPC" ne suffit pas.
        # FGR 29/11/2010 : X3SUIVI69504 (début)
        #If IMPMSK = "BPRBPC"
        #    IMPFIC = "BPR"
        #Else
        #    IMPFIC = "BPC"
        #Endif
        Gosub TRT_IMP_ZONE
        # FGR 29/11/2010 : X3SUIVI69504 (fin)

        Case IMPZON
            When "WORDMINAMT","WOSTAUZ", "WCDTISR","WFUPMINAMT" :
#                Montants a convertir dans la devise dossier
                IMPZONFIC = mid$(IMPZON,2,19)
                IMPZONMSK=IMPZON
        Endcase

       # X3-66828 (LCC 26/02/18) Updating field DAYMON with an Import File
        Case IMPZON
          When "J1","J2","J3","J4","J5","J6"
           IMPZONFIC="DAYMON("+num$(val(right$(IMPZON,2))-1)+")"
           IMPZONMSK=IMPZON
        Endcase
        # End X3-66828 (LCC 26/02/18) Updating field DAYMON with an Import File

    When "BPA" :
# ---------------------------------------------------#
#     Adresse                                        #
# ---------------------------------------------------#
        Gosub IMP_ZON_BPA From TRTX3IMP
    When "CNT","AIN" :
# ---------------------------------------------------#
#     Contact                                        #
# ---------------------------------------------------#
        Gosub IMP_ZON_CNT From TRTX3IMP

    When "BID" :
# ---------------------------------------------------#
#     Rib                                            #
# ---------------------------------------------------#
        Gosub IMP_ZON_BID From TRTX3IMP

    When "BPD" :
# ---------------------------------------------------#
#     Clients livrés                                 #
# ---------------------------------------------------#
        Case IMPZON
            When "NBDLV" :
#                Traitement particulier sur la 1ère zone de l'écran
#                --> Recharger nolign et indice pour se positionner sur la bonne ligne
                indice = [M]XNUMLIG
                nolign = indice + 1
            When "BPAADD"
#                Traitement particulier sur la 1ère zone de l'écran
#                --> Recharger nolign et indice pour se positionner sur la bonne ligne
                indice = [M]XNUMLIG
                nolign = indice + 1
                IMPZONFIC= IMPZON
                IMPZONMSK= "[M]"+IMPZON+"("+num$(nolign-1)+")"
                [M:BPC4]FLMOD(nolign-1) = 1            # FGR 28/07/2014 : X3SUIVI100229 : si on vient là c'est qu'il y a une modification
                OK=0
            When "XBPDADDFLG"
                # FGR 19/06/2014 : X3SUIVI100660
                If [F:BPC]BPDADD <> "" Then
                  If [F:BPC]BPDADD = [F:BPD]BPAADD Then
                    [M:BPC4]XBPDADDFLG = 2
                  Else
                    [M:BPC4]XBPDADDFLG = 1
                  Endif
                Endif
#LSE 05/10/2006 FQ36055 plus de zone indicé
#            When "XBPDNAM", "XREP" :
##                Nom de zone fichier-ecran different et zones indicées
#                IINDICE = indice+1
#                IMPZONFIC = mid$(IMPZON,2,19)
#                IMPZONMSK= "[M]"+IMPZON+"("+num$(indice)+")"
# Bug 41438 : Régression suite à correction bug 36055
            When "XBPDNAM0", "XBPDNAM1" :
#                Nom de zone fichier-ecran different et zones indicées
                indice=val(mid$(IMPZON,8,1))
                IINDICE = indice+1
                IMPZONFIC = mid$(IMPZON,2,6)
                IMPZONMSK=IMPZON
            When "XREP0","XREP1" :
#                Nom de zone fichier-ecran different et zones indicées
                indice=val(mid$(IMPZON,5,1))
                IINDICE = indice+1
                IMPZONFIC = mid$(IMPZON,2,3)
                IMPZONMSK=IMPZON
# Bug 41438
            When Default
                IXZ = find(IMPFIC-IMPZON,[M:AOE2]ZONMSK)
                If IXZ
                  IMPZONFIC=[M:AOE2]FLD(IXZ-1)
                  IMPZONMSK=IMPZON
                Endif
        Endcase
Endcase

If IMPZONFIC <> "" & IMPZONMSK <> ""
#       On recherche si la zone est paramétrée
        If IINDICE <> 0
#           Zone indicée
            I = find(IMPFIC-IMPZONFIC+"("+num$(indice)+")",[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
            If I <> 0 IMPZONFIC = IMPZONFIC + "("+num$(indice)+")" : Endif
        Endif
        If IINDICE = 0 | IINDICE = 1 & I = 0
#           Zone non indicée ou zone indicée de 0 non trouvée
            I = find(IMPFIC-IMPZONFIC,[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
        Endif

        If I <> 0
#           On charge la classe [M]
#           Cas spécial : Ecran adresse contact et client livré                         #
#           Il faut passer systématiquement en AM_ pour charger le tableau invisible    #
#           même si la zone n'a pas changé                                              #
            If find(IMPFIC, "BPA", "BPD", "CNT", "AIN") IMPMOD = 1 Endif
            # FGR 23/10/2009 : X3SUIVI56028(début)
            If IMPFIC = "BPA" and IMPZONFIC = "CTY" Then
              If evalue (IMPZONMSK) <> evalue ("[F:"+IMPFIC+"]"+IMPZONFIC) and evalue ("[F:"+IMPFIC+"]"+IMPZONFIC) <> "" Then
                IMPMOD=1
                Assign IMPZONMSK With evalue ("[F:"+IMPFIC+"]"+IMPZONFIC)
              Endif
            Else
              If evalue (IMPZONMSK) <> evalue ("[F:"+IMPFIC+"]"+IMPZONFIC)
                IMPMOD=1
                Assign IMPZONMSK With evalue ("[F:"+IMPFIC+"]"+IMPZONFIC)
              Endif
            Endif
            # FGR 23/10/2009 : X3SUIVI56028 (fin)
        Else  #MAE/FGR, bg 71813
          Gosub IMP_ZONE_TELMAIL
        Endif
        OK=0
Endif


Return

#------------------------------------------------------------------
# Traitements de IMP_ZONE et IMP_TAB
#------------------------------------------------------------------
# FGR 29/11/2010 : X3SUIVI69504 (début)
$TRT_IMP_ZONE
  Case IMPFIC
    When "BPR", "BPC"
      #----------------------------------------------------------#
      # Entête facture : Déterminer la bonne abréviation fichier #
      #----------------------------------------------------------#
      Local Integer I
      Local Char SZSIHFIC(50)

      If find("BPR", GSTBFIC(0..dim(GSTBFIC)-1)) <> 0 Then
        # FGR 17/12/2010 : X3SUIVI69959 : Si BPR est dans le bloc, on restaure la classe [F:BPR]
        [F:BPR] = [F:BPR2]
      Endif
      I = find(IMPZON,[M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
      If I = 0 Then
        I = find(IMPZON+"(0)",[M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
      Endif
      If I <> 0 Then
        SZSIHFIC = left$([M:AOE2]ZONE(I-1),3)
        If find(SZSIHFIC, GSTBFIC(0..dim(GSTBFIC)-1)) <> 0 and find(SZSIHFIC, "BPR", "BPC") <> 0 Then
          IMPFIC = SZSIHFIC
        Else
          If IMPFIC = SZSIHFIC and find(SZSIHFIC, "BPR", "BPC") <> 0 Then
            # Si la zone détectée est sur un fichier et qu'il ne fait pas parti de ce qui est importé,
            # on passe sur l'autre pour éviter des erreurs.
            If IMPFIC = "BPR" Then
              IMPFIC = "BPC"
            Else
              IMPFIC = "BPR"
            Endif
          Endif
        Endif
      Endif
  Endcase
Return
# FGR 29/11/2010 : X3SUIVI69504 (fin)

#######################################################################
#--- pour chargement cles textes client-livre dans [M:BPC4]
$IMP_INICRE
Local Integer IJL0,IJL1
For IJL0=0 To dim(TXT_BPAADD)-1
    If  TXT_BPAADD(IJL0)="" : Break : Endif
    IJL1=find(TXT_BPAADD(IJL0),[M:BPC4]BPAADD)
    If IJL1
       If TXT_PRPTEX(IJL0)<>"" : [M:BPC4]PRPTEX(IJL1-1)=TXT_PRPTEX(IJL0) : Endif
       If TXT_DLVTEX(IJL0)<>"" : [M:BPC4]DLVTEX(IJL1-1)=TXT_DLVTEX(IJL0) : Endif
    Endif
Next IJL0
  # FGR 20/04/2012 : X3SUIVI80439 (début)
  If dim(GBPC1ORDTEX) >= 0 Then
    [M:BPC1]ORDTEX = GBPC1ORDTEX
    [F:BPC]ORDTEX = GBPC1ORDTEX
    Kill GBPC1ORDTEX
  Endif
  If dim(GBPC1INVTEX) >= 0 Then
    [M:BPC1]INVTEX = GBPC1INVTEX
    [F:BPC]INVTEX = GBPC1INVTEX
    Kill GBPC1INVTEX
  Endif
  # FGR 20/04/2012 : X3SUIVI80439 (fin)
Return

#######################################################################
#                        EXPORT
#######################################################################

$EXP_OUVRE
Gosub OUVRE_TEXTE
Return

#######################################################################

$EXPORT
Raz G_CLE_CLOB, G_ZON_CLOB

Case EXPFIC

  When "BPC"
    If G_TX11
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:BPC]ORDTEX)>0 & [F:BPC]ORDTEX<>""
          G_CLE_CLOB=[F:BPC]ORDTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
       Endif
    Endif
    If G_TX12
       Gosub EXP_RAZ_T2 From TRTX3IMP
       If dim([F:BPC]INVTEX)>0 & [F:BPC]INVTEX<>""
          G_CLE_CLOB=[F:BPC]INVTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T2 From TRTX3IMP
       Endif
    Endif

  When "BPD"
    If G_TX21
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:BPD]PRPTEX)>0 & [F:BPD]PRPTEX<>""
          G_CLE_CLOB=[F:BPD]PRPTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
       Endif
    Endif
    If G_TX22
       Gosub EXP_RAZ_T2 From TRTX3IMP
       If dim([F:BPD]DLVTEX)>0 & [F:BPD]DLVTEX<>""
          G_CLE_CLOB=[F:BPD]DLVTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T2 From TRTX3IMP
       Endif
    Endif

Endcase

Return

#######################################################################
$EXP_ZONE
Local Char SZABREXPZON(10)

  # FGR 10/02/2010 : X3SUIVI59669
  Case EXPFIC
    When "BPC"
      SZABREXPZON = left$(EXPZON, 7)  # [F:BPR]
      If SZABREXPZON = "[F:BPR]" Then
        If [F:BPC]BPCNUM <> [F:BPR]BPRNUM Then
          Read [BPR]BPR0=[F:BPC]BPCNUM
          If fstat Then
            Raz [F:BPR]
          Endif
        Endif
      Endif
    When Default
  Endcase
Return

#######################################################################
# Utilisation de l'instruction setmode --> suppression affichage
# avant le call SAIMSK et SAI_NBLIG
# pour afficher des infbox dans IMP_ZONE et IMP_TAB
# utiliser Setmode_off Setmode_on
# ( pour afficher : Gosub SETMODE_OFF en debut de IMP_ZONE ou IMP_TAB )
#######################################################################
$SETMODE_OFF
Setmode
Return

$SETMODE_ON
Setmode GNBAFF, GAFFCOD, GAFFMASK, GAFFCHP, GAFFIND, GAFFTXT, GAFFRANG, GAFFOPT1, GAFFOPT2
Return
#######################################################################
#MAE/FGR, bg 71813
$IMP_ZONE_TELMAIL

If IMPFIC = "BPA" and (left$(IMPZONFIC,3) = "TEL" or left$(IMPZONFIC,3) = "WEB" ) Then
   If evalue (IMPZONMSK) <> evalue ("[F:"+IMPFIC+"]"+IMPZONFIC) and evalue ("[F:"+IMPFIC+"]"+IMPZONFIC) <> "" Then
      IMPMOD=1
      Assign IMPZONMSK With evalue ("[F:"+IMPFIC+"]"+IMPZONFIC)
   Endif
Endif

Return


#######################################################################
Subprog NEW_TEL_EMAIL(SCLF)
Value Char SCLF

  # FGR 28/02/2011 : X3SUIVI71813 :
  # Appel : Call NEW_TEL_EMAIL("[F:BPA]")
  # -----------------------------
  # FAX => TEL(1)  mess(2,7873,1)
  # MOB => TEL(4)  mess(5,7873,1)
  If evalue(SCLF+"FAX") <> "" and evalue(SCLF+"TEL(1)") = "" Then
    Assign SCLF+"TEL(1)" With evalue(SCLF+"FAX")
  Endif
  If evalue(SCLF+"MOB") <> "" and evalue(SCLF+"TEL(4)") = "" Then
    Assign SCLF+"TEL(4)" With evalue(SCLF+"MOB")
  Endif
  # -----------------------------
End

