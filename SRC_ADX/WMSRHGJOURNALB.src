$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 4313: RES='Journaux comptables'
   When 4314: RES='Journal'
   When 71: RES='Code d'+"'"+'accès'
   When 26213: RES='Législation'
  Endcase
 When "ENG":
  Case _ID
   When 4313: RES='Journal codes'
   When 4314: RES='Journal'
   When 71: RES='Access code'
   When 26213: RES='Legislation'
  Endcase
 When "ITA":
  Case _ID
   When 4313: RES='Giornali contabili'
   When 4314: RES='Giornale'
   When 71: RES='Codice accesso'
   When 26213: RES='Legislazione'
  Endcase
 When "POR":
  Case _ID
   When 4313: RES='Diários contabilísticos'
   When 4314: RES='Diário'
   When 71: RES='Código acesso'
   When 26213: RES='Legislação'
  Endcase
 When "SPA":
  Case _ID
   When 4313: RES='Diarios contables'
   When 4314: RES='Diario'
   When 71: RES='Cód. de acceso'
   When 26213: RES='Legislación'
  Endcase
 When "BRI":
  Case _ID
   When 4313: RES='Journal Codes'
   When 4314: RES='Journal'
   When 71: RES='Access code'
   When 26213: RES='Legislation'
  Endcase
 When "GER":
  Case _ID
   When 4313: RES='Journalcodes'
   When 4314: RES='Journal'
   When 71: RES='Zugriffscode'
   When 26213: RES='Rechtsordnung'
  Endcase
 When "POL":
  Case _ID
   When 4313: RES='Kody dowodów KG'
   When 4314: RES='Dziennik'
   When 71: RES='Kod dostępu'
   When 26213: RES='Legislacja'
  Endcase
 When "CHI":
  Case _ID
   When 4313: RES='会计日记账'
   When 4314: RES='日记账'
   When 71: RES='访问代码'
   When 26213: RES='准则'
  Endcase
 When "ARB":
  Case _ID
   When 4313: RES='رموز دفتر اليومية'
   When 4314: RES='دفتر اليومية'
   When 71: RES='رمز الدخول'
   When 26213: RES='تشريعات'
  Endcase
Endcase
Return
