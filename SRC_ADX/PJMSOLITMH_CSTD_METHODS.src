#######################################################################################
# Class PJMSOLITMH
#######################################################################################
# METHODS                                                                             #
#######################################################################################
#######################################################################################
$SPL_RESET_ERRORS
Local Integer NI

  # ---------------------------------
  [L]ARET_VALUE = fmet this.ADELETERRORALL()
  For NI = 1 To maxtab(this.SPLD)
    If this.SPLD(NI) <> null and find(this.SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = fmet this.SPLD(NI).ADELETERRORALL()
    Endif
  Next NI
  # ---------------------------------
  For NI = 1 To maxtab(this.SPLO)
    If this.SPLO(NI) <> null and find(this.SPLO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = fmet this.SPLO(NI).ADELETERRORALL()
    Endif
  Next NI
Return

#######################################################################################
$GET_PSONUM_FROM_SALE_DOC
# Issue 7539/119856 - 2016-11-18 by TEJAC : Sales Document Delinking
#Value Tinyint DOCTYP
#Value Char SALDOCNUM ()
#Local Integer ARET_VALUE

  [L]ARET_VALUE = AVOID.ACHAR
  # ------------------------------------
  Local File PJMSOLITMH [PSOH]
  Filter [F:PSOH] Where [F:PSOH]DOCTYP = DOCTYP and [F:PSOH]HDOCNUM = SALDOCNUM
  For [PSOH]
    [L]ARET_VALUE = [F:PSOH]PSONUM
    Break
  Next
  Filter [F:PSOH]
  # ------------------------------------
Return

