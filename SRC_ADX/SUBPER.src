#<AdxTL>@(#)2.0.0.0 $Revision$
# CBO   26.09.2017  X3-55073      List of periods not re-read after changing company

Raz GBIDC1
Call OBJET("PER",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "SETBOUT"     : Gosub SETBOUT
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub LIENS
 When "MODIF"       : Gosub MODIF
 When "FILTRE"      : Gosub FILTRE
 When "FILGAUCHE"   : Gosub FILGAUCHE
Endcase
Return

$OUVRE
If GMODU(2)=2  :# Compta
 If clalev([F:JOU])=0  : Local File GJOURNAL   [JOU]  : Endif
Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
If clalev([F:FIY2])=0 : Local File FISCALYEAR [FIY2] : Endif
If clalev([F:PER2])=0 : Local File PERIOD     [PER2] : Endif
If clalev([F:PER3])=0 : Local File PERIOD     [PER3] : Endif
Local Integer EXERCICE , PERIODE , EXESUIV , NBFIY
Local Libelle DER_PER
Local Char    SOCIETE(GLONCPY)
Local Date    DEBEX, FINEX
Local Date    DAT_DEB, DAT_FIN
Local Integer I_J, REFTYP
Return

$LIENS
nolign = 0
For [PER]PER0 Where CPY=[F:FIY]CPY & LEDTYP=[F:FIY]LEDTYP & FIYNUM=[F:FIY]FIYNUM
 If nolign >= dim ([M]PERSTR) Break : Endif
 nolign += 1
 [M] = [F:PER]
Next
[M]BASTAB = nolign
Return

$FILGAUCHE
If CRITERE<>"" : CRITERE +="&" : Endif
CRITERE +="LEDTYPAUT<>2"
Return

$FILTRE
If FILTSUP<>"" : FILTSUP +="&" : Endif
FILTSUP +="LEDTYPAUT<>2"
Return

$MODIF
Delete [PER] Where CPY=[M]CPY & LEDTYP=[M]LEDTYP & FIYNUM=[M]FIYNUM
If fstat=1
 GOK=-1 : GLOCK="$PERIOD"-[M]CPY : Return
Elsif fstat>5
 GOK=0 : Call RSTA("PER",[M]CPY) From GLOCK : Return
Endif
For nolign=1 To [M]BASTAB
 [F:PER] = [M]
 [F:PER]PERNUM = nolign
 Write [PER]
 If fstat
  GOK=0 : Call FSTA("PER") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
Call PERAUT([M]CPY,[M]LEDTYP,[M]FIYNUM,0,GOK) From SUBPER
If !GOK : Return : Endif
If GMODU(14)=G_OUI
 If func GLOBIENS.DESYNC_CNX([M]CPY, [M]LEDTYP)
  GOK=0
  Return
 Endif
Endif
Return

$SETBOUT
Call VIREBOUT(CHAINE,"AHCDS") From GOBJET
If CLECUR=0 | GREP<>"" | VERROU=0
 Call VIREBOUT(CHAINE,"12") From GOBJET
Endif
Return

$AVANTBOUT
Case BOUT
 When "1","2" : # Ouverture, clôture
  If BOUT = "1"
   Read [FIY]FIY0 = [M]CPY;[M]LEDTYP;[M]FIYNUM
   If [F:FIY]FIYSTA=1
    ## Aucune période à ouvrir
    GMESSAGE = mess(149,104,1) : Return
   Endif
  Elsif BOUT = "2"
   ## Si on essaye de clôturer une période d'un référentiel autre que le référentiel général principal, on contrôle que
   ## la période à clôturer (=première période ouverte) est déjà fermée pour le référentiel général principal
   Local Integer NEXO, NPER
   Local Date NDAT
   Call SETMAINREF([M]CPY,GTYPGEN,GTYPANA) From CPTDIV
   If [M]LEDTYP<>GTYPGEN
    Filter [PER3] Where CPY=[M]CPY & LEDTYP=[M]LEDTYP & PERSTA = 2
    Read [PER3]PER0 First
    Filter [PER3]
    If !fstat
     NDAT = [F:PER3]PEREND
     For [PER3]PER0 Where CPY=[M]CPY & LEDTYP=GTYPGEN & PERSTR<=NDAT & PEREND>=NDAT
      NEXE = [F:PER3]FIYNUM
      NPER = [F:PER3]PERNUM
     Next
     If !NPER | [F:PER3]PERSTA<3
      ## La période du référentiel général principal n'a pas encore été clôturée
      GMESSAGE = mess(148,104,1)-"("+format$(GFMD,[F:PER3]PERSTR)+"->"+format$(GFMD,[F:PER3]PEREND)+")" : Return
     Endif
    Endif
   Endif
  Endif
  If GCONSULT
   OK = 0
  Else
   Gosub VERROU From GOBJET
   If !OK
    # Modification en cours sur un autre poste
    GMESSAGE = mess(10,100,1) : Return
   Endif
  Endif
Endcase
Return

$EXEBOUT
Case REP
 When "1","2" : # Ouverture, clôture
  Gosub DEVERROU From GOBJET
  Read [FIY]FIY0 = [M]CPY;[M]LEDTYP;[M]FIYNUM
  Gosub RELIT From GOBJET
Endcase
Return

$CHARGE_OUV
Local Integer OK_CHARGE, NOLI
SOCIETE = [M:PER1]CPY
# Recherche période à ouvrir
Raz [M:DIA], I_J
[M:DIA]CPY    = [M:PER1]CPY
[M:DIA]LEDTYP = [M:PER1]LEDTYP
[M:DIA]ZCPY   = [M:PER1]ZCPY
For [PER]PER0 Where CPY=SOCIETE and LEDTYP=[M:PER1]LEDTYP and PERSTA=1 and LEDTYPAUT<>2
 EXERCICE = [F:PER]FIYNUM
 REFTYP   = [F:PER]LEDTYP
 PERIODE  = [F:PER]PERNUM
 If I_J>=dim([M:DIA]FIYNUM)
  Break
 Endif
 If EXERCICE<>[F:FIY]FIYNUM
  Read [FIY]FIY0=SOCIETE;REFTYP;EXERCICE
 Endif
 [M:DIA]FIYSTA(I_J)     = [F:FIY]FIYSTA
 [M:DIA]FIYNUM(I_J)     = [F:PER]FIYNUM
 [M:DIA]PERNUM(I_J)     = [F:PER]PERNUM
 [M:DIA]PERSTR(I_J)     = [F:PER]PERSTR
 [M:DIA]PEREND(I_J)     = [F:PER]PEREND
 [M:DIA]PERSTA(I_J)     = [F:PER]PERSTA
 If [M:DIA]FIYSTA(I_J) = 2 : # Ouvert
  [M:DIA]CREAT(I_J) = 2
 Else
  [M:DIA]CREAT(I_J) = 1
 Endif
 I_J += 1
Next
[M:DIA]NBLIG = dim([M:DIA]FIYNUM)

# Les fenêtres d’ouverture et de clôture auront un tableau des référentiels initialisé à l’ensemble des
# référentiels pour lesquels les mêmes opérations sont possibles : mêmes périodes et mêmes états. On ne pourra
# que supprimer des référentiels.

# ouverture :
# affichage du référentiel dans le tableau si :
# - différent du référentiel principal
# - date de premier exercice non ouvert = date de premier exercice non ouvert du référentiel principal
# - date de première période non ouverte = date de première période non ouverte du référentiel principal

# PERIOD : PER0 = CPY+LEDTYP+FIYNUM+PERNUM
# FISCALYEAR : FIY0 = CPY+LEDTYP+FIYNUM
# FISCALYEAR : FIY1 = CPY+LEDTYP

Read [GCM]GCM0=[F:CPY]ACM
For K=0 To dim([F:GCM]LED)-1
 If [F:GCM]LED(K)<>""
  If K+1<>[M:DIA]LEDTYP
   Read [FIY2]FIY0 = [M:PER1]CPY ; [L]K+1 ; [M:PER1]FIYNUM
   If !fstat & [F:FIY2]FIYSTA=2 : # on rajoute le référentiel dans le tableau ssi l'exercice est ouvert sur ce référentiel
    Filter [PER2] Where CPY=[M:PER1]CPY & FIYNUM=[M:PER1]FIYNUM & LEDTYP=[L]K+1 & LEDTYPAUT<>2
    OK_CHARGE = 0 : NOLI = 0
    For [PER2]PER0
     If [F:PER2]PERSTR=[M:PER1]PERSTR(NOLI) & [F:PER2]PEREND=[M:PER1]PEREND(NOLI) & [F:PER2]PERSTA=[M:PER1]PERSTA(NOLI)
      OK_CHARGE = 1
     Else
      OK_CHARGE = 0 : Break
     Endif
     NOLI+=1
    Next
    Filter [PER2]

    # si le nombre de périodes est différentes...
    If NOLI<>[M:PER1]BASTAB : OK_CHARGE=0 : Endif

    # si dates de période et états période identiques, on ajoute le référentiel dans le tableau
    If OK_CHARGE
     [M:DIA]TYP([M:DIA]NBLED)    = K+1
     [M:DIA]LEDFLG([M:DIA]NBLED) = 2
     [M:DIA]NBLED += 1
    Endif
   Endif
  Endif
 Endif
Next

Local Integer FIYNUM
[L]FIYNUM=0
For N=0 To [M]NBLIG-1
 If [M]FIYNUM(N)<>[L]FIYNUM
  # récupération des infos de l'exercice
  Read [FIY]FIY0=[M]CPY;[M]LEDTYP;[M]FIYNUM(N)
  # comparer les dates
  [L]FIYNUM=[M]FIYNUM(N)
 Endif
Next
Return

$VALID_OUV
Call DEBTRANS From GLOCK
For I_J=0 To [M:DIA]NBLIG-1
 If [M:DIA]CREAT(I_J)=2
  EXERCICE = [M:DIA]FIYNUM(I_J)
  PERIODE  = [M:DIA]PERNUM(I_J)
  Gosub TR1
  If GOK<1 : Break : Endif
 Endif
Next I_J

# Ouverture de périodes pour les autres référentiels cochés OUI
For N=0 To [M:DIA]NBLED-1
 If [M:DIA]LEDFLG(N)=2 # Création = Oui
  REFTYP   = [M:DIA]TYP(N)
  For I_J=0 To [M:DIA]NBLIG-1
   If [M:DIA]CREAT(I_J)=2
    EXERCICE = [M:DIA]FIYNUM(I_J)
    PERIODE  = [M:DIA]PERNUM(I_J)
    Gosub TR1
    If GOK<1 : Break : Endif
   Else
    Break
   Endif
  Next I_J
 Endif
Next N
Return

$TR1
GOK=1
Trbegin [PER]
 GCLE = SOCIETE-num$(EXERCICE)-num$(PERIODE)
 Readlock [PER]PER0 = SOCIETE;REFTYP;EXERCICE;PERIODE
 If fstat=1
  GOK=-1 : GLOCK="$PERIOD"-GCLE : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("PER",GCLE) From GLOCK : Goto AB_TR1
 Endif
 If [M:DIA]CREAT(I_J)=2
  [F:PER]PERSTA    = 2
 Endif
 Rewrite [PER]
 If fstat
  GOK=0 : Call FSTA("PER") From GLOCK : Goto AB_TR1
 Endif
 Call PERAUT(SOCIETE,REFTYP,EXERCICE,PERIODE,GOK) From SUBPER
 If !GOK : Goto AB_TR1 : Endif

 If PERIODE=1
  GCLE = SOCIETE-num$(EXERCICE)
  Readlock [FIY]FIY0 = SOCIETE;REFTYP;EXERCICE
  If fstat=1
   GOK=-1 : GLOCK="$FISCALYEAR"-GCLE : Goto ROLL_TR1
  Elsif fstat
   GOK=0 : Call RSTA("FIY",GCLE) From GLOCK : Goto AB_TR1
  Endif
  [F:FIY]FIYSTA = 2
  Rewrite [FIY]
  If fstat
   GOK=0 : Call FSTA("FIY") From GLOCK : Goto AB_TR1
  Endif
  Call FIYAUT(SOCIETE,REFTYP,EXERCICE,GOK) From SUBFIY
  If !GOK : Goto AB_TR1 : Endif
 Endif
Commit
If PERIODE=1 & GMODU(2)=2  :# Compta
 Call EXEAN From GLOBCPT
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

Subprog PERAUT(SOC,REF,EXE,PER,OK)
Value Char SOC()
Value Integer REF
Value Integer EXE
Value Integer PER
Variable Integer OK

If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:PER2])=0 : Local File PERIOD     [PER2] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif

Local Integer N
Local Char FILTRE(50)

FILTRE = "FIYNUM="+num$([L]EXE)
If PER>0 :  FILTRE += "& PERNUM="+num$([L]PER) : Endif

OK=1
For [CPY] Where CPY=SOC
 Read [GCM]GCM0=[F:CPY]ACM
 # Pour tous les types de référentiels
 For N=1 To len(mess(0,2644,1))
  If [F:GCM]LED(N-1)<>"" & [F:GCM]CFMAUT(N-1) = 2 & [F:GCM]ORILEDTYP(N-1)=[L]REF
   # Pour toutes les périodes du Référentiel de Référence / d'origine
   Delete [PER2] Where CPY=[F:CPY]CPY and LEDTYP=N and evalue(FILTRE)
   If fstat
    OK=0 : Call FSTA("PER") From GLOCK : Break 2
   Endif
   For [PER]PER0 Where CPY=[F:CPY]CPY and LEDTYP=[F:GCM]ORILEDTYP(N-1) and evalue(FILTRE)
    Read [PER2]PER0 = [F:PER]CPY;N;[F:PER]FIYNUM;[F:PER]PERNUM
    If fstat
     Raz [PER2]
     [F:PER2] = [F:PER]
     [F:PER2]LEDTYP = N
     [F:PER2]LEDTYPAUT = 2
     Write [PER2]
     If fstat
      OK=0 : Call FSTA("PER") From GLOCK : Break 3
     Endif
    Endif
   Next
  Endif
 Next N
Next
Close Local File [CPY],[GCM],[PER],[PER2]
End

########################################
## Etiquettes                         ##
########################################
Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer OPTION
OPTION = 6
Call LEDTYP_CHOICE([M:PER1]CPY,OPTION) From CPTDIV
End


Subprog D_PERSTR(DAT)
Variable Date DAT
If nolign=1
 DAT = [M]FIYSTR
Else
 DAT = [M]PEREND(nolign-2)+1
Endif
End

Subprog AS_PEREND(DAT)
Variable Date DAT
Gosub SETNOL
If NOL>=[M]BASTAB-1
 mkstat=2 : End
Elsif [M]PERSTA(NOL)>2
 mkstat=2 : End
Elsif [M]PERSTA(NOL)=2
 If [M]PERSTA(NOL+1)>1
  mkstat=2 : End
 Endif
Endif
End

Subprog C_PEREND(DAT)
Value Date DAT
Gosub SETNOL
If [M]PERSTA(NOL)=2 & DAT<[M]PEREND(NOL)
 # Période ouverte : réduction durée impossible
 GMESSAGE = mess(13,101,1) : mkstat=2 : End
Elsif DAT>[M]FIYEND-([M]BASTAB-(NOL+1))
 # Date trop grande pour la fin d'exercice
 GMESSAGE = mess(14,101,1) : mkstat=2 : End
Endif
End

Subprog AM_PEREND(DAT)
Variable Date DAT
Local Integer JOUR , MOIS , I
Local Date    ODAT
Gosub SETNOL
ODAT = [M]PEREND(NOL)
[M]PEREND(NOL) = DAT
For I=NOL+1 To [M]BASTAB-1
 If [M]INS=1 & I=NOL+1
  [M]PERSTR(I) = [M]DATINS
 Endif
 JOUR = [M]PEREND(I)-[M]PERSTR(I)
 If [M]PEREND(I)=eomonth([M]PEREND(I))
  MOIS = 12*(year([M]PEREND(I))-year([M]PERSTR(I)))+month([M]PEREND(I))-month([M]PERSTR(I))+1
 Else
  MOIS=0
 Endif
 [M]PERSTR(I) = [M]PEREND(I-1)+1
 If I<>[M]BASTAB-1 & DAT>ODAT & [M]PERSTR(I)>[M]PEREND(I)  :# bug 14810
  If MOIS
   [M]PEREND(I) = eomonth(addmonth([M]PERSTR(I),MOIS)-1)
  Else
   [M]PEREND(I) = [M]PERSTR(I)+JOUR
  Endif
  If [M]PEREND(I)>[M]PEREND([M]BASTAB-1)-([M]BASTAB-(I+1))
   [M]PEREND(I) = [M]PEREND([M]BASTAB-1)-([M]BASTAB-(I+1))
  Endif
 Endif
 Affzo PERSTR(I),PEREND(I)
Next I
End

Subprog C_BASTAB
Gosub SETNOL
Case status
 When 65,68,83 : # Annulation
  Local Integer I , NOL1 , NOL2
  If status=65
   NOL1 = NOL : NOL2 = NOL
  Else
   NOL1 = NOL : NOL2 = nolign1-1
  Endif
  For I=NOL1 To NOL2
   If [M]PERSTA(I)<>1
    GMESSAGE = mess(15,101,1) : mkstat=2 : Break
    # Période ouverte : annulation impossible
   Elsif I=[M]BASTAB-1
    GMESSAGE = mess(16,101,1) : mkstat=2 : Break
    # Annulation impossible en dernière ligne
   Endif
  Next
  If !mkstat
   If NOL1>0
    [M]PERSTR(NOL2+1) = [M]PEREND(NOL1-1)+1
   Else
    [M]PERSTR(NOL2+1) = [M]FIYSTR
   Endif
   Affzo PERSTR(NOL2+1)
  Endif
 When 73 : # Insertion
  If [M]PERSTA(NOL)<>1
   # Période ouverte : insertion impossible
   GMESSAGE = mess(18,101,1)
   mkstat=2 : End
  Endif
  If [M]BASTAB >= dim(PEREND)-2
   mkstat=2 : End
  Endif
  [M]INS = 1
  [M]DATINS = [M]PERSTR(NOL)
 When Default
  [M]INS = 0
Endcase
End

$SETNOL
Local Integer NOL
NOL=nolign-1
Return

Subprog C_CPY(VALEUR)
Variable Char VALEUR
Call CONTALLFCY(VALEUR) From CPTSUB
End

Subprog AS_PERSTOSTA(VALEUR)
Variable Integer  VALEUR
GMENLOC(2) = 1
# Modification du statut stock interdite si statut stock = interdit et FRADGI="Oui" et période clôturée
If [M]PERSTOSTA(nolign-1)=4 & func AFNC.PARAM("FRADGI",[M]CPY)="2" & [M]PERSTA(nolign-1)=3
 mkstat = 2 : End
Endif

End

Subprog AP_PERSTOSTA(VALEUR)
Variable Integer  VALEUR
Raz GMENLOC
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Raz [M]LEDTYP

# X3-55073
If VALEUR <> [M:PER1]CPY
  Raz [M:PER1]BASTAB
  Affzo [M:PER1]BASTAB
Endif

End

