$ACTION
Case ACTION 
Endcase
Return

########################################
Subprog C_HFIN(VALEUR)
Variable Char    VALEUR()
If [M]JDEB = [M]JFIN & VALEUR < [M]HDEB : GMESSAGE = mess(44,199,1) : mkstat = 1 : End : Endif
End

########################################
Subprog C_JFIN(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]JDEB : GMESSAGE = mess(44,199,1) : mkstat=2 : Endif
End

