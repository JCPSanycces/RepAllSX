#<AdxTL>@(#)0.0.0.0 $Revision$

Subprog VERF_PARAM(PARAM, VALEUR, OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK

  If (clalev([CCMCR]) = 0) : Local File CCMCHGREQ [CCMCR] : Endif

  If (PARAM = "CCMCHGMAN")
    If (VALEUR = "1")
      For [CCMCR] Where CCMUSRID = [M:AUS0]USR
        If ([F:CCMCR]CRSTATUS <> 7)
          OK = 0
          GMESSAGE =  mess(17,2038,1)
          GERR = 1
          Break
        Endif
      Next
    Endif
  Elsif (PARAM = "CCMPLANNER")
     If (VALEUR = "1")
      For [CCMCR] Where PLANNER = [M:AUS0]USR
        If ([F:CCMCR]CRSTATUS <> 7)
          OK = 0
          GMESSAGE =  mess(72,2038,1)
          GERR = 1
          Break
        Endif
      Next
    Endif
  Elsif (PARAM = "CCMAPPROVE")
    If (VALEUR = "1")
      If (clalev([CCMAPPR]) = 0) : Local File CCMAPPROVER [CCMAPPR] : Endif

      For [CCMAPPR] Where APPRUSER = [M:AUS0]USR
        Filter [CCMCR] Where CRID = [F:CCMAPPR]CRID
        Read [CCMCR] First
        If (fstat = 0 and [F:CCMCR]CRSTATUS <> 7)
          OK = 0
          GMESSAGE =  mess(73,2038,1)
          GERR = 1
          Break
        Endif
      Next
      Close Local File [CCMAPPR]
    Endif

  Endif

  Close Local File [CCMCR]

End

