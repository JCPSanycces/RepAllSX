#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ITC1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:54"
A_USER  = "DOC"
A_STAMP = "20181109230454"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ITC1 [ITC1]
Gosub HORODAT
Local Inpbox "ITC1" From GFONCTION At A_STAMP With A_WINDPREV Mask [ITC1] As [SIM_]
Grizo [ITC1]5
Grizo [ITC1]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ITC1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=65 : Y1(0)=1 : Y2(0)=14
X1(1)=66 : X2(1)=80 : Y1(1)=15 : Y2(1)=19
Return

$ON_NBLIG
Onevent BEFORE_AREA Call AV_NBLIG From W1ITC1
Return

Subprog AV_NBLIG
Local Decimal BASPAG
If adxgtb=1 & !GORITITCOL & nolign=1
 Local Char BASPAG(10)
 BASPAG = "NBLIG" : Gosub TIT_COL From W1ITC1
Endif
Gosub _AFF
End

$ON_STDDET
Onevent BEFORE_INPUT Call AS_STDDET(zc) From W1ITC1
Onevent INIT_AREA Call D_STDDET(zc) From W1ITC1
Return

Subprog D_STDDET(VALEUR)
Variable Char    VALEUR()
If varinit([M]STDDET,indice)=0
 VALEUR = "152"
Endif
Gosub _AFF
End

Subprog AS_STDDET(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(454,GBOUTI) From OBJDIV
Onkey 178 Titled GBOUTI Call CL_STDDET(zc) From W1ITC1
Gosub _AFF
End

Subprog CL_STDDET(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call CL_STDDET(VALEUR) From SUBITC
Endif
If !GWEBSERV
 ## Action SAIDECPRI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SAIDECPRI"
 PARMSK(1) = "STD"
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 PARMSK(6) = "2"
 PARMSK(7) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"ISAIDECPRI","SUBSDP","SPESDP") From GSAISIE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

