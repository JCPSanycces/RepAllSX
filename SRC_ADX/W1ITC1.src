Subprog CL_SIMDET(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call CL_SIMDET(VALEUR) From SUBITC
Endif
If !GWEBSERV
 ## Action SAIDECPRI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SAIDECPRI"
 PARMSK(1) = "STD"
 PARMSK(2) = "0"
 PARMSK(3) = "0"
 PARMSK(4) = "0"
 PARMSK(5) = ""
 PARMSK(6) = "2"
 PARMSK(7) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"ISAIDECPRI","SUBSDP","SPESDP") From GSAISIE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$TIT_COL
Local Char TITCL(200)(1..4)
Raz TITCL
Case BASPAG
 When "NBLIG"
  TITCL(1) = mess(1,219,1)
  TITCL(2) = mess(2,219,1)
  TITCL(3) = mess(3,219,1)
  TITCL(4) = mess(4,219,1)
  If !GORITITCOL
   Titcol [M]NBLIG TITCL(1) For STDCST
   Titcol [M]NBLIG TITCL(2) For ACTCST
   Titcol [M]NBLIG TITCL(3) For BUDCST
   Titcol [M]NBLIG TITCL(4) For SIMCST
  Else
   Titcol [M:ITC1]NBLIG TITCL(1) For STDCST
   Titcol [M:ITC1]NBLIG TITCL(2) For ACTCST
   Titcol [M:ITC1]NBLIG TITCL(3) For BUDCST
   Titcol [M:ITC1]NBLIG TITCL(4) For SIMCST
  Endif
Endcase
Return

$CHG_STY
Return


