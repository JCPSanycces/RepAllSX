#<AdxTL>@(#)0.0.0.0 $Revision$
# ------------------------------------------------------------------------- #
# Classe représentation SOHNPAINSD : Liste des cdes pour acomptes non reçus #
# ------------------------------------------------------------------------- #
# Classe de données GACCDUDATE                                              #
# ------------------------------------------------------------------------- #
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub AREAD_AFTER
        When "AQUERY_OPEN_AFTER"     : Gosub AQUERY_OPEN_AFTER
        When "AQUERY_CRITERIA_AFTER" : Gosub AQUERY_CRITERIA_AFTER
        When "AQUERY_JOIN_AFTER"     : Gosub AQUERY_JOIN_AFTER
        When "AQUERY_TRANS_AFTER"    : Gosub AQUERY_TRANS_AFTER
        When Default
      Endcase
    When ""
    When Default
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return
#--------------------------------------
#######################################################################################
$PROPERTIES
#  Case CURPRO
#    When Default
#  Endcase
Return

#######################################################################################
$AQUERY_OPEN_AFTER

# Ouverture des tables additionnelles

Local File SORDER [SOH]

Return
#######################################################################################
$AQUERY_CRITERIA_AFTER

# Ajout de conditions ds la clause Where
# Conditions stockées ds PQRY.QWHERE (Utilisation des fonctions SDATA)

If PQRY.QWHERE<>""
    PQRY.QWHERE="("+PQRY.QWHERE+") and TYP eq'*SO' and PAMTYP eq 2 and SENINS eq 2 and AMTCUR gt (TMPCUR+PAYCUR) and [F:SOH]ORDSTA eq 1 and [F:SOH]UNL ne 2"
Else
    PQRY.QWHERE="TYP eq'*SO' and PAMTYP eq 2 and SENINS eq 2 and  AMTCUR gt (TMPCUR+PAYCUR) and [F:SOH]ORDSTA eq 1 and [F:SOH]UNL ne 2"
Endif

Return
#######################################################################################
$AQUERY_JOIN_AFTER


Local Char VARS(20)(1..3), COLS(20)(1..3)
VARS(1)="ORDSTA": VARS(2)="UNL"
COLS(1)="[SOH]ORDSTA" : COLS(2)="[SOH]UNL"

Link [DUD] With
& [F:SOH]SOH0 = [F:DUD]NUM
& As [LNK_]
& Where DUDDAT<date$ and func AFNC.PARAM("LOKORD",[F:DUD]FCY)="2"                                         : # 100242
#& Where evalueSData(PQRY.QWHERE,VARS,COLS) and DUDDAT<date$ and func AFNC.PARAM("LOKORD",[F:DUD]FCY)="2" : # 100242

Return

#######################################################################################
$AQUERY_TRANS_AFTER

# Alimenter des propriétés qui ne sont pas dans la table

this.SOHNUM=[F:SOH]SOHNUM
this.ORDSTA=[F:SOH]ORDSTA
this.PAYCUR=[F:DUD]TMPCUR+[F:DUD]PAYCUR
this.ORDDAT=[F:SOH]ORDDAT

Return

#######################################################################################
$AREAD_AFTER
Local Integer WNOL

  Local File SORDER [SOH]

If this.DUD.NUM<>""
  Read [F:SOH]SOH0=this.DUD.NUM
  If fstat : Raz [F:SOH] Endif
Endif

this.SOHNUM = [F:SOH]SOHNUM
this.CUSORDREF = [F:SOH]CUSORDREF

For I = 1 To dim([F:SOH]BPCNAM)
  If this.C_BPCNAM(I) = null
    WNOL = fmet this.ADDLINE("C_BPCNAM", [V]CST_ALASTPOS)
  Endif
  If this.C_BPCNAM(WNOL)<>null
    this.C_BPCNAM(WNOL).BPCNAM = [F:SOH]BPCNAM(I-1)
  Endif
Next I

this.ORDDAT = [F:SOH]ORDDAT

For I = 1 To dim([F:SOH]REP)
  If this.C_REP(I) = null
    WNOL = fmet this.ADDLINE("C_REP", [V]CST_ALASTPOS)
  Endif
  If this.C_REP(WNOL)<>null
    this.C_REP(WNOL).REP = [F:SOH]REP(I-1)
  Endif
Next I

this.PAYCUR    = this.DUD.TMPCUR+this.DUD.PAYCUR
this.CUR1      = this.DUD.CUR
this.ORDINVNOT = [F:SOH]ORDINVNOT
this.CURSOH    = [F:SOH]CUR
this.ORDINVATI = [F:SOH]ORDINVATI
this.CURSOH1   = [F:SOH]CUR
this.ORDSTA    = [F:SOH]ORDSTA

Return

