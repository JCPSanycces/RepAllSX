#<AdxTL>@(#)0.0.0.0 $Revision$ 

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","GENDICO","",1,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "EXEC"     : Gosub EXEC
Endcase
Return

#################################
$INIT
TIT = mess(133,10703,1)
Return

#################################
$EXEC
Call GENDICO (1,nomap)
TRA = 1
Return

#################################
Subprog GENDICO (TYP,DOSSIER)
Value Integer TYP    :# 1=DICOEMP ; 2=DICODAD
Value Char    DOSSIER

If clalev([F:ATZ])=0 : Local File =DOSSIER+".ATABZON" [ATZ] : Endif
If clalev([F:ATX])=0 : Local File =DOSSIER+".ATEXTE"  [ATX] : Endif

Local Char CRITERE (100)

If TYP=1
 CRITERE="left$(CODFIC,5)='EMPLO'"
 If clalev([F:DXX])=0 : Local File =DOSSIER+".DICOEMP" [DXX] : Endif
Else
 If clalev([F:DXX])=0 : Local File =DOSSIER+".DICODAD" [DXX] : Endif
 CRITERE="left$(CODFIC,6)='DADEMP' | left$(CODFIC,6)='DADFCY' | left$(CODFIC,6)='DADDNA'"
Endif

Local Integer N , AXE
Local Char    TEXTE(80)

Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE(mess(133,10703,1)) From LECFIC : # Mise à jour dictionnaire
Call DEBTRANS From GLOCK
Gosub TR1
Call FERME_TRACE From LECFIC
Call TEMPOFF From GESECRAN

End

#################################
$TR1
GOK = 1
Trbegin [F:DXX]
 Gosub MAJDIC
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

#################################
$MAJDIC
Local Integer FLGRWR
N = 0 
For [ATZ]CODZONE Where evalue (CRITERE)
 FLGRWR = 0
 Read [F:DXX] = [F:ATZ]CODZONE
 If fstat
  Raz [F:DXX]
  [F:DXX]FLD    = [F:ATZ]CODZONE
  [F:DXX]TBL    = [F:ATZ]CODFIC
  [F:DXX]ROW    = 9999
  [F:DXX]DES    = [F:ATZ]NOLONG
  [F:DXX]CODACT = [F:ATZ]CODACT
  [F:DXX]ENAFLG = 2
  [F:DXX]ENASEL = 2
  #58002
  If dim([F:DXX]MSFLG)>0
   [F:DXX]MSFLG = 1
  Endif
  If dim([F:DXX]POTFLG)>0
     [DXX]POTFLG=1
  Endif
  #72211
  If dim([F:DXX]FLGRET)>0
     [DXX]FLGRET=1
  Endif
  #73020
  If dim([F:DXX]FLDDIM)>0
     [DXX]FLDDIM=[F:ATZ]DIME
  Endif
  Call TEXTE([F:DXX]DES,TEXTE) From OBJDIV
  Case [F:ATZ]CODTYP
   When "CCE"
    AXE = val(left$([F:ATZ]EXPLIEN,1))
    If AXE>=1 & AXE<=9
     [F:DXX]NBRPAR    = 1
     [F:DXX]PARCOD(0) = "CCE"
     [F:DXX]PARVAL(0) = '"'+num$(AXE)+'"'
     If AXE>GOPTCANA
      [F:DXX]ENAFLG = 1
     Endif
    Endif
   When "ADI"
    AXE = val([F:ATZ]EXPLIEN)
    If AXE>=1
     [F:DXX]NBRPAR    = 1
     [F:DXX]PARCOD(0) = "ADI"
     [F:DXX]PARVAL(0) = '"'+num$(AXE)+'"'
    Endif
   When "HRNCT","HRCGD","HRXGD","HRCSP","HRCLV","HRMDT","HRMDP","VRA"
    If [F:ATZ]EXPLIEN<>""
     [F:DXX]NBRPAR    = 2
     [F:DXX]PARCOD(0) = "LEG"
     [F:DXX]PARVAL(0) = "GCURLEG"
     [F:DXX]PARCOD(1) = "SOCIETE"
     [F:DXX]PARVAL(1) = "GSOCIETE"
    Endif
   When "PRF","RUB","CUM"
    If [F:ATZ]EXPLIEN<>""
     [F:DXX]NBRPAR    = 1
     [F:DXX]PARCOD(0) = "LEG"
     [F:DXX]PARVAL(0) = "GCURLEG"
    Endif
  Endcase
  If dim([F:DXX]CREDAT)>0 : [F:DXX]CREDAT = date$ : Endif
  If dim([F:DXX]CREUSR)>0 : [F:DXX]CREUSR = GUSER : Endif
  If dim([F:DXX]CRETIM)>0 : [F:DXX]CRETIM = time  : Endif
  Write [F:DXX]
  If fstat
   GOK = 0 : Call FSTA("DXX") From GLOCK : Break
  Endif
  N += 1
  Call ECR_TRACE(mess(135,10703,1)-":"-[F:DXX]TBL-[F:DXX]FLD-TEXTE,0) From GESECRAN : # Champ ajouté
 Else
  #Maj des intitulés
  If [F:DXX]DES <> [F:ATZ]NOLONG
   [F:DXX]DES   = [F:ATZ]NOLONG
   FLGRWR = 1
  Endif 
  If [F:ATZ]CODTYP="ADI"
    AXE = val([F:ATZ]EXPLIEN)
    If AXE>=1 & [F:DXX]PARVAL(0) <> '"'+num$(AXE)+'"'
     [F:DXX]NBRPAR    = 1
     [F:DXX]PARCOD(0) = "ADI"
     [F:DXX]PARVAL(0) = '"'+num$(AXE)+'"'
     FLGRWR =1
    Endif
  Endif
  If dim([F:DXX]FLDDIM)>0 &  [DXX]FLDDIM<>[F:ATZ]DIME 
    [DXX]FLDDIM=[F:ATZ]DIME
    FLGRWR =1
  Endif

   Case [F:ATZ]CODTYP
    When "HRNCT","HRCGD","HRXGD","HRCSP","HRCLV","HRMDT","HRMDP","VRA"
     If [F:ATZ]EXPLIEN<>"" 
      [F:DXX]NBRPAR    = 2
      [F:DXX]PARCOD(0) = "LEG"
      [F:DXX]PARVAL(0) = "GCURLEG"
      [F:DXX]PARCOD(1) = "SOCIETE"
      [F:DXX]PARVAL(1) = "GSOCIETE"
      FLGRWR =1
     Endif
    When "PRF","RUB","CUM"
     If [F:ATZ]EXPLIEN<>""
      [F:DXX]NBRPAR    = 1
      [F:DXX]PARCOD(0) = "LEG"
      [F:DXX]PARVAL(0) = "GCURLEG"
     Endif
   Endcase

  If FLGRWR
   If dim([F:DXX]UPDDAT)>0 : [F:DXX]UPDDAT = date$ : Endif
   If dim([F:DXX]UPDUSR)>0 : [F:DXX]UPDUSR = GUSER : Endif
   If dim([F:DXX]UPDTIM)>0 : [F:DXX]UPDTIM = time  : Endif
   Rewrite [F:DXX]
   If fstat
    GOK = 0 : Call FSTA("DXX") From GLOCK : Break
   Endif
  Endif 
  If [F:ATZ]CODFIC<>[F:DXX]TBL
   If !find([F:ATZ]CODZONE,"REFNUM","CREDAT","CRETIM","CREUSR","UPDDAT","UPDTIM","UPDUSR","NUMLIG","EXPNUM","CTRNUM")
   Call ECR_TRACE(mess(36,124,1)-[F:ATZ]CODZONE-mess(16,10701,1)-[F:DXX]TBL-[F:ATZ]CODFIC,0) From GESECRAN
#                 Champ                         présent sur 2 tables
  Endif
  Endif
 Endif
Next
If GOK<1 : Return : Endif
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(num$(N)-mess(136,10703,1),0) From GESECRAN : # champs ajoutés
Call ECR_TRACE("",0) From GESECRAN

N = 0
For [F:DXX]
 Read [ATZ]CODZONE = [F:DXX]TBL;[F:DXX]FLD
 If fstat
  N += 1
  Call TEXTE([F:DXX]DES,TEXTE) From OBJDIV
  Call ECR_TRACE(mess(134,10703,1)-":"-[F:DXX]TBL-[F:DXX]FLD-TEXTE,0) From GESECRAN : # Champ supprimé
  Delete [F:DXX]
  If fstat=1
   GOK = -1 
   If TYP=1
    GLOCK = "$DICOEMP"-[F:DXX]TBL-[F:DXX]FLD 
   Else
    GLOCK = "$DICODAD"-[F:DXX]TBL-[F:DXX]FLD 
   Endif  
   Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(num$(N)-mess(137,10703,1),0) From GESECRAN : # champs supprimés
Return

#################################
$AB_TR1
Rollback
Return

#################################
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif





