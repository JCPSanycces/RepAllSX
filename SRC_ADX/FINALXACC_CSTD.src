#<AdxTL>@(#)2.0.0.0 $Revision$
# Classe FINALXACC
##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
          When "ADDLINE_AFTER" : Gosub GAC_ADDLINE_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return
##########################################################################################################


$GAC_ADDLINE_AFTER
  # Change to -1 or 1 instead of Expense or Revenue
  If [F:CLS]SNSANA=2  : this.ACCSGN=-1
  Else                : this.ACCSGN=1
  Endif

  # Income statement or balance sheet
  If [F:CLS]ERA=1     : this.ACCCAT="I"
  Else                : this.ACCCAT="B"
  Endif

  # Expand the array to individual fields
  this.RPTCODDEB0 = [F:GAC]RPTCODDEB(0)
  this.RPTCODDEB1 = [F:GAC]RPTCODDEB(1)
  this.RPTCODDEB2 = [F:GAC]RPTCODDEB(2)
  this.RPTCODDEB3 = [F:GAC]RPTCODDEB(3)
  this.RPTCODDEB4 = [F:GAC]RPTCODDEB(4)
  this.RPTCODDEB5 = [F:GAC]RPTCODDEB(5)
  this.RPTCODDEB6 = [F:GAC]RPTCODDEB(6)
  this.RPTCODDEB7 = [F:GAC]RPTCODDEB(7)
  this.RPTCODDEB8 = [F:GAC]RPTCODDEB(8)
  this.RPTCODDEB9 = [F:GAC]RPTCODDEB(9)

  this.RPTCODCDT0 = [F:GAC]RPTCODCDT(0)
  this.RPTCODCDT1 = [F:GAC]RPTCODCDT(1)
  this.RPTCODCDT2 = [F:GAC]RPTCODCDT(2)
  this.RPTCODCDT3 = [F:GAC]RPTCODCDT(3)
  this.RPTCODCDT4 = [F:GAC]RPTCODCDT(4)
  this.RPTCODCDT5 = [F:GAC]RPTCODCDT(5)
  this.RPTCODCDT6 = [F:GAC]RPTCODCDT(6)
  this.RPTCODCDT7 = [F:GAC]RPTCODCDT(7)
  this.RPTCODCDT8 = [F:GAC]RPTCODCDT(8)
  this.RPTCODCDT9 = [F:GAC]RPTCODCDT(9)

Return

