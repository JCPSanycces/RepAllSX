#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Close Mask
Call OBJET("AOC",GBIDC1,GBIDC2) From GOBJET 
End 
 
############################################################ 
$ACTION
If dim([L]PSUBAOC)<=0
 Local Integer PSUBAOC
 Call EXISTE_ADX("","","SUBAOCB",PSUBAOC) From ORDSYS
Endif
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "LIENS"      : Gosub LIENS
 When "FILTRE"     : Gosub FILTRE
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
 When "SETBOUT"    : Gosub SETBOUT
 When "APRES_MOD"  : Gosub APRES_MOD
 When "MODIF"      : Gosub MODIF
Endcase
If PSUBAOC
 Gosub ACTION From SUBAOCB
Endif
Return

$OUVRE
If clalev([F:AOB2])=0 : Local File AOBJET [AOB2] : Endif
Local Integer NLNK , ABRLNK(1..100)
Local Char    OBJLNK(GLONAOB)(1..100)
Return

$FILTRE
Return

$LIENS
Call TEXTE([M:AOC0]LIBEL,[M:AOC0]ZLIBEL) From OBJDIV
Raz [M:AOC2]
If dim([F:AOB]LIBSHO)>0
 [M:AOC2]LIBSHO = [F:AOB]LIBSHO
 Call TEXTE([M:AOC2]LIBSHO,[M:AOC2]ZLIBSHO) From OBJDIV
Endif

# mb 17.12.02 Recherche d'une fenêtre liée à l'objet et non protégée par un code activité
# pour récupérer les champs DERLU, FIRLIS et détecter la présence de l'explorateur de liaison.
# L'enregistrement provoque la mise à jour de toutes les fenêtres de l'objet non protégées.
#-----------------------------------------------------------------------------------------------#

J = 0
For [AWI]AWI1 Where OBJ=[F:AOB]ABREV :# & CODACT<"X"
 K = 1
 If [F:AWI]CODACT<>""
  Read [ACV]CODACT = [F:AWI]CODACT
  If fstat or [F:ACV]FLACT<>2
   K = 0
  Endif
 Endif
 If K
  Read [AWB]AWB0 = [F:AWI]WIN
  If !fstat
   J = 1 : Break
  Endif
 Endif
Next
If !J
 Raz [F:AWB]
Endif
[M:AOC2]DERLU  = [F:AWB]DERLU
[M:AOC2]FIRLIS = [F:AWB]FIRLIS
If find("ALI",[F:AWB]OBJLIS(0..[F:AWB]NBLIS-1))
 [M:AOC2]EXPLORE = 2
Else
 [M:AOC2]EXPLORE = 1
Endif
nolign = 0
For [AOT] Where ABREV=[F:AOB]ABREV
 nolign += 1
 [M:AOC1] = [F:AOT]
Next AOT
[M:AOC1]NBFIC = nolign
[M:AOC2]LNKTBL(1) = [F:AOB]NOMFIC
Read [ATB]CODFIC = [F:AOB]NOMFIC
[M:AOC2]LNKABR(1) = [F:ATB]ABRFIC
K = 1
For [AOT] Where ABREV=[F:AOB]ABREV & TABLIEN<>""
 K += 1
 [M:AOC2]LNKTBL(K) = [F:AOT]TABFIC
 Read [ATB]CODFIC = [F:AOT]TABFIC
 [M:AOC2]LNKABR(K) = [F:ATB]ABRFIC
Next AOT
nolign = 0
For [AOK]AOK0 Where SRCOBJ=[F:AOB]ABREV
 nolign += 1
 [M:AOC2] = [F:AOK]
Next
[M:AOC2]NBFIC = nolign
Read [AOL]AOL0 = [F:AOB]ABREV
[M:AOC1] = [F:AOL]
For I=0 To [M:AOC1]NBSEL-1
 If [M:AOC1]SELINT(I)=0
  Call TEXTFIC([M:AOC1]SELFIC(I),[M:AOC1]SELZON(I),3,[M:AOC1]ZSELINT(I)) From OBJDIV
 Else
  Call TEXTE([M:AOC1]SELINT(I),[M:AOC1]ZSELINT(I)) From OBJDIV
 Endif
Next I
If [F:AOB]TYPGES=4
 Grizo [AOC1]RPT1, RPT2
 Grizo [AOC2]DERLU, FIRLIS
Else
 Actzo [AOC1]RPT1, RPT2
 Actzo [AOC2]DERLU, FIRLIS
Endif
Return

$INICRE
$INIMOD
[F:AOB]UPDFLG = 0
For [AWI]AWI1 Where OBJ=[F:AOB]ABREV : # & CODACT<"X"
 K = 1
 If [F:AWI]CODACT<>""
  Read [ACV]CODACT = [F:AWI]CODACT
  If fstat or [F:ACV]FLACT<>2
   K = 0
  Endif
 Endif
 If K
  Readlock [AWB]AWB0 = [F:AWI]WIN
  If fstat=1
   GOK = -1 : GLOCK = "$AWINBRO"-[F:AWI]WIN : Break
  Elsif fstat
   Raz [F:AWB]
   #GOK = 0 : Call RSTA("AWB",[F:AWI]WIN) From GLOCK  : Break
  Endif
  If [M:AOC2]EXPLORE=2
   If !find("ALI",[F:AWB]OBJLIS(0..[F:AWB]NBLIS-1))
    K = 0
    For L=0 To [F:AWB]NBLIS-1
     If K<[F:AWB]ROWLIS(L)
      K = [F:AWB]ROWLIS(L)
     Endif
    Next L
    Read [AOB2]ABREV = "ALI"
    [F:AWB]OBJLIS([F:AWB]NBLIS) = "ALI"
    [F:AWB]INTLIS([F:AWB]NBLIS) = [F:AOB2]LIBEL
    [F:AWB]CLELIS([F:AWB]NBLIS) = ""
    [F:AWB]ORDLIS([F:AWB]NBLIS) = 1
    [F:AWB]TRELIS([F:AWB]NBLIS) = 4
    [F:AWB]BROLIS([F:AWB]NBLIS) = 1
    [F:AWB]CHGLIS([F:AWB]NBLIS) = 2
    [F:AWB]ABRLIS([F:AWB]NBLIS) = ""
    [F:AWB]FLELIS([F:AWB]NBLIS) = 1
    [F:AWB]ACTLIS([F:AWB]NBLIS) = ""
    [F:AWB]EXPLIS([F:AWB]NBLIS) = ""
    [F:AWB]ROWLIS([F:AWB]NBLIS) = min(K+5,9999)
    [F:AWB]NBLIS += 1
   Endif
  Else
   L = find("ALI",[F:AWB]OBJLIS(0..[F:AWB]NBLIS-1))
   If L
    Dela L-1,1 [F:AWB]OBJLIS,[F:AWB]INTLIS,[F:AWB]CLELIS,[F:AWB]ORDLIS,[F:AWB]ABRLIS
&             ,[F:AWB]TRELIS,[F:AWB]BROLIS,[F:AWB]CHGLIS,[F:AWB]ACTLIS,[F:AWB]EXPLIS
&             ,[F:AWB]FLELIS,[F:AWB]ROWLIS
    [F:AWB]NBLIS -= 1
   Endif
  Endif
  L = find(CLECUR1,[F:AWB]OBJLIS(0..[F:AWB]NBLIS-1)) 
  If L
   [F:AWB]ORDLIS(L-1) = [F:AOB]SELORD
   If CLECUR1="ALI"
    [F:AWB]TRELIS(L-1) = 4
   Else
    [F:AWB]TRELIS(L-1) = [F:AOB]SELTREE
   Endif
   [F:AWB]CLELIS(L-1) = [F:AOB]SELCLE
  Endif
  [F:AWB]DERLU  = [M:AOC2]DERLU
  [F:AWB]FIRLIS = [M:AOC2]FIRLIS
  If [F:AWB]WIN=""
   [F:AWB]WIN = [F:AWI]WIN
   Write [AWB]
   If fstat
    GOK = 0 : Call FSTA("AWB") From GLOCK : Break
   Endif
  Else  
   Rewrite [AWB]
   If fstat
    GOK = 0 : Call FSTA("AWB") From GLOCK : Break
   Endif
  Endif
 Endif
Next
Return

$SETBOUT
Call VIREBOUT(CHAINE,"CDAH") From GOBJET
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
Return

$MODIF
Readlock [AOL]AOL0 = [F:AOB]ABREV
If fstat=1
 GOK = -1 : GLOCK = "$AOBJLST"-[F:AOB]ABREV
Elsif fstat
 GOK = 0 : Call RSTA("AOL",[F:AOB]ABREV) From GLOCK : Return
Endif
[F:AOL] = [M:AOC1]
Rewrite [AOL]
If fstat
 GOK = 0 : Call FSTA("AOL") From GLOCK : Return
Endif
Raz I, J
Filter [AOT] Where ABREV=[F:AOB]ABREV
For [AOT]ABREV
 If [F:AOT]TABFIC="ALINK"
  J = 1
 Endif
Next AOT
Read [AOT]ABREV Last
If fstat
 I = 0
Else
 I = [F:AOT]NUMLIG
Endif
Filter [AOT]
If [M:AOC2]EXPLORE=2
 If J=0
  Raz [F:AOT]
  [F:AOT]ABREV  = [F:AOB]ABREV
  [F:AOT]NUMLIG = I+1
  [F:AOT]TABFIC = "ALINK"
  Write [AOT]
  If fstat
   GOK = 0 : Call FSTA("AOT") From GLOCK : Return
  Endif
 Endif
Elsif J
 Delete [AOT] Where ABREV=[F:AOB]ABREV & TABFIC="ALINK"
 If fstat=1
  GOK = -1 : GLOCK = "$AOBJTAB"-[F:AOB]ABREV : Return
 Endif
Endif
Delete [AOK] Where SRCOBJ=[F:AOB]ABREV
If fstat=1
 GOK = -1 : GLOCK = "$AOBJLNK"-[F:AOB]ABREV : Return
Endif
NLNK = 0
Raz ABRLNK , OBJLNK
For nolign=1 To [M:AOC2]NBFIC
 [F:AOK] = [M:AOC2]
 [F:AOK]SRCOBJ = [F:AOB]ABREV
 [F:AOK]LIN    = nolign
 Read [AOB2]ABREV = [F:AOK]DSTOBJ
 Read [ATB]CODFIC = [F:AOB2]NOMFIC
 K = find([F:ATB]ABRFIC,OBJLNK(1..NLNK))
 If K
  ABRLNK(K) += 1
  [F:AOK]ABRFIC = [F:ATB]ABRFIC+num$(ABRLNK(K)-1)
 Else
  NLNK += 1
  OBJLNK(NLNK) = [F:ATB]ABRFIC
  [F:AOK]ABRFIC = [F:ATB]ABRFIC
 Endif
 Write [AOK]
 If fstat
  GOK = 0 : Call FSTA("AOK") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
Return

$APRES_MOD
Local Char OBJET(GLONAOB)
OBJET = [F:AOB]ABREV
# Traitement WOxxx
Call VALID(OBJET,nomap,0,OK) From VALOBJ
# Raz du fichier derniers lus
If clalev([F:ALS])=0 : Local File ALSTRD [ALS] : Endif
Trbegin [ALS]
 Delete [ALS] Where OBJ=OBJET
Commit
# Quand on valide un objet à variante, il faut revalider les fenêtres...
OK = 0
For [AWI]AWI1 Where OBJ=OBJET : # & CODACT<"X"
 Call VALID([F:AWI]WIN,nomap,0,OK) From VALWIN
 OK = 1
Next
Return

#########################################################
$TRTCOP
If [M]DOSORG=nomap 
 Local File AOBJET  [AOP1] 
 Local File AOBJLST [AOL1] 
 Local File AOBJLNK [AOK1] 
 Local File AWINDOW [AWI1] 
 Local File AWINBRO [AWB1] 
Else 
 Local File =[M]DOSORG+".AOBJET"  [AOP1]
 Local File =[M]DOSORG+".AOBJLST" [AOL1]
 Local File =[M]DOSORG+".AOBJLNK" [AOK1]
 Local File =[M]DOSORG+".AWINDOW" [AWI1]
 Local File =[M]DOSORG+".AWINBRO" [AWB1]
Endif 
If [M]DOSDES=nomap 
 Local File AOBJET  [AOP2] 
 Local File AOBJLST [AOL2] 
 Local File AOBJLNK [AOK2] 
 Local File AWINDOW [AWI2] 
 Local File AWINBRO [AWB2] 
Else 
 Local File =[M]DOSDES+".AOBJET"  [AOP2]
 Local File =[M]DOSDES+".AOBJLST" [AOL2]
 Local File =[M]DOSDES+".AOBJLNK" [AOK2]
 Local File =[M]DOSDES+".AWINDOW" [AWI2]
 Local File =[M]DOSDES+".AWINBRO" [AWB2]
Endif 
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AOP1], [AOL1], [AOK1], [AWI1], [AWB1]
&              , [AOP2], [AOL2], [AOK2], [AWI2], [AWB2]
Return

$TR_COP
GOK = 1
Trbegin [AOP2], [AOL2] , [AOK2], [AWI1], [AWB1]
 Readlock [AOP2]ABREV = TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AOBJET" : Goto ROLL_TR_COP
 Elsif fstat
  GOK = 0 : Call RSTA("AOP2","") From GLOCK : Goto AB_TR_COP
 Endif
 Read [AOP1]ABREV = TABLE
 [F:AOP2]SELCLE  = [F:AOP1]SELCLE
 [F:AOP2]SELORD  = [F:AOP1]SELORD
 [F:AOP2]SELTREE = [F:AOP1]SELTREE
 [F:AOP2]SELCAR  = [F:AOP1]SELCAR
 [F:AOP2]STA     = [F:AOP1]STA
 If dim([F:AOP2]UPDUSR)>0 : [F:AOP2]UPDUSR = GUSER : Endif
 If dim([F:AOP2]UPDDAT)>0 : [F:AOP2]UPDDAT = date$ : Endif
 Rewrite [AOP2]
 If fstat
  GOK=0 : Call FSTA("AOP2") From GLOCK : Goto AB_TR_COP
 Endif

 Readlock [AOL2]AOL0 = TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AOBJLST" : Goto ROLL_TR_COP
 Elsif fstat
  GOK = 0 : Call RSTA("AOL2","") From GLOCK : Goto AB_TR_COP
 Endif
 Read [AOL1]AOL0 = TABLE
 [F:AOL2]NBSEL   = [F:AOL1]NBSEL
 For I=0 To [F:AOL1]NBSEL-1
  [F:AOL2]SELFIC(I) = [F:AOL1]SELFIC(I)
  [F:AOL2]SELZON(I) = [F:AOL1]SELZON(I)
  [F:AOL2]SELEXP(I) = [F:AOL1]SELEXP(I)
  [F:AOL2]SELTYP(I) = [F:AOL1]SELTYP(I)
  [F:AOL2]SELLNG(I) = [F:AOL1]SELLNG(I)
  [F:AOL2]SELSAI(I) = [F:AOL1]SELSAI(I)
  [F:AOL2]SELINT(I) = [F:AOL1]SELINT(I)
  If dim([F:AOL2]SELPCK)>0
   [F:AOL2]SELPCK(I) = [F:AOL1]SELPCK(I)
  Endif
 Next I
 Rewrite [AOL2]
 If fstat
  GOK=0 : Call FSTA("AOL2") From GLOCK : Goto AB_TR_COP
 Endif

 Delete [AOK2] Where SRCOBJ=TABLE
 If fstat=1
  GOK = -1 : GLOCK = "$AOBJLNK"-TABLE : Goto ROLL_TR_COP
 Endif
 For [AOK1]AOK0 Where SRCOBJ=TABLE
  [F:AOK2] = [F:AOK1]
  Write [AOK2]
  If fstat
   GOK = 0 : Call FSTA("AOK2") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR_COP : Endif

 Gosub TR_COP_BRO
 If GOK=0 : Goto AB_TR_COP
 Elsif GOK<1 : Goto ROLL_TR_COP
 Endif

Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#-------------------------------------------------------------------------#
# Répercussion de la modif de l'explorateur de liaison et des derniers lus
# sur les browsers des fenêtres non protégées du dossier de destination
#-------------------------------------------------------------------------#

$TR_COP_BRO

Local Integer K, EXPLORE, DERLU, FIRLIS

If find("ALI",[F:AWB1]OBJLIS(0..[F:AWB1]NBLIS-1))
 [L]EXPLORE = 2
Else
 [L]EXPLORE = 1
Endif
Raz [L]DERLU, [L]FIRLIS
For [AWI1]AWI1 Where OBJ=TABLE : # & CODACT<"X"
 Read [AWB1]AWB0 = [F:AWI1]WIN
 If !fstat
  [L]DERLU  = [F:AWB1]DERLU
  [L]FIRLIS = [F:AWB1]FIRLIS
  Break
 Endif
Next

For [AWI2]AWI1 Where OBJ=TABLE : # & CODACT<"X"
 Readlock [AWB2]AWB0 = [F:AWI2]WIN
 If fstat=1
  GOK = -1 : GLOCK = "$"+[M]DOSDES+".AWINBRO"-[F:AWI2]WIN : Break
 Elsif fstat
  GOK = 0 : Call RSTA("AWB2",[F:AWI2]WIN) From GLOCK  : Break
 Endif
 If [L]EXPLORE=2
  If !find("ALI",[F:AWB2]OBJLIS(0..[F:AWB2]NBLIS-1))
   K = 0
   For L=0 To [F:AWB2]NBLIS-1
    If K<[F:AWB2]ROWLIS(L)
     K = [F:AWB2]ROWLIS(L)
    Endif
   Next L
   Read [AOP2]ABREV = "ALI"
   [F:AWB2]OBJLIS([F:AWB2]NBLIS) = "ALI"
   [F:AWB2]INTLIS([F:AWB2]NBLIS) = [F:AOP2]LIBEL
   [F:AWB2]CLELIS([F:AWB2]NBLIS) = ""
   [F:AWB2]ORDLIS([F:AWB2]NBLIS) = 1
   [F:AWB2]TRELIS([F:AWB2]NBLIS) = 4
   [F:AWB2]BROLIS([F:AWB2]NBLIS) = 1
   [F:AWB2]CHGLIS([F:AWB2]NBLIS) = 2
   [F:AWB2]ABRLIS([F:AWB2]NBLIS) = ""
   [F:AWB2]FLELIS([F:AWB2]NBLIS) = 1
   [F:AWB2]ACTLIS([F:AWB2]NBLIS) = ""
   [F:AWB2]EXPLIS([F:AWB2]NBLIS) = ""
   [F:AWB2]ROWLIS([F:AWB2]NBLIS) = min(K+5,9999)
   [F:AWB2]NBLIS += 1
  Endif
 Else
  K = find("ALI",[F:AWB2]OBJLIS(0..[F:AWB2]NBLIS-1))
  If K
   Dela K-1,1 [F:AWB2]OBJLIS,[F:AWB2]INTLIS,[F:AWB2]CLELIS,[F:AWB2]ORDLIS,[F:AWB2]ABRLIS
&            ,[F:AWB2]TRELIS,[F:AWB2]BROLIS,[F:AWB2]CHGLIS,[F:AWB2]ACTLIS,[F:AWB2]EXPLIS
&            ,[F:AWB2]FLELIS,[F:AWB2]ROWLIS
   [F:AWB2]NBLIS -= 1
  Endif
 Endif
 K = find(TABLE,[F:AWB2]OBJLIS(0..[F:AWB2]NBLIS-1)) 
 If K
  [F:AWB2]ORDLIS(K-1) = [F:AOP1]SELORD
  [F:AWB2]TRELIS(K-1) = [F:AOP1]SELTREE
  [F:AWB2]CLELIS(K-1) = [F:AOP1]SELCLE
 Endif
 [F:AWB2]DERLU  = [L]DERLU
 [F:AWB2]FIRLIS = [L]FIRLIS
 Rewrite [AWB2]
 If fstat
  GOK = 0 : Call FSTA("AWB2") From GLOCK : Break
 Endif
Next
Return

##########################################################################
# Etiquettes du masque AOC1
##########################################################################

Subprog C_ABREV(VALEUR)
Variable Char    VALEUR()
Call CONTROLE("AOB","",VALEUR,"",mkstat) From CONTOBJ
End

Subprog C_SELFIC(VALEUR)
Variable Char VALEUR()
Call C_SELFIC(VALEUR) From SUBAOB
End

Subprog AS_SELZON(VALEUR)
Variable Char    VALEUR()
Call AS_SELZON(VALEUR) From SUBAOB
End

Subprog C_SELZON(VALEUR)
Variable Char VALEUR()
Call C_SELZON(VALEUR) From SUBAOB
End

Subprog AM_SELZON(VALEUR)
Variable Char VALEUR()
Call AM_SELZON(VALEUR) From SUBAOB
End

Subprog AS_SELCLE(VALEUR)
Variable Char     VALEUR
Call AS_SELCLE(VALEUR) From SUBAOB
End

Subprog AS_SELORD(VALEUR)
Variable Integer  VALEUR
End

Subprog AS_SELEXP(VALEUR)
Variable Char    VALEUR()
Call AS_SELEXP(VALEUR) From SUBAOB
End

Subprog C_SELEXP(VALEUR)
Variable Char    VALEUR()
Call C_SELEXP(VALEUR) From SUBAOB
End

Subprog AS_SELTYP(VALEUR)
Variable Char    VALEUR()
Call AS_SELTYP(VALEUR) From SUBAOB
End

Subprog AS_ZSELINT(VALEUR)
Variable Char    VALEUR()
Call AS_ZSELINT(VALEUR) From SUBAOB
End

Subprog AS_SELSAI(VALEUR)
Variable Char    VALEUR()
Call AS_SELSAI(VALEUR) From SUBAOB
End

Subprog C_SELSAI(VALEUR)
Variable Char    VALEUR()
Call C_SELSAI(VALEUR) From SUBAOB
End

Subprog D_SELLNG(VALEUR)
Variable Decimal VALEUR
Call D_SELLNG(VALEUR) From SUBAOB
End

Subprog AS_SELLNG(VALEUR)
Variable Decimal VALEUR
Call AS_SELLNG(VALEUR) From SUBAOB
End

Subprog C_SELLNG(VALEUR)
Variable Decimal VALEUR
Call C_SELLNG(VALEUR) From SUBAOB
End

Subprog AS_SELPCK(VALEUR)
Variable Decimal  VALEUR
Call AS_SELPCK(VALEUR) From SUBAOB
End

Subprog AS_STA(VALEUR)
Variable Integer VALEUR
Call AS_STA(VALEUR) From SUBAOB
End

########################################
## Masque AOC2
########################################

Subprog AS_DERLU(VALEUR)
Variable Integer  VALEUR
Read [AOB]ABREV = [M]ABREV
Read [AOL]AOL0  = [M]ABREV
If [F:AOL]NBSEL=0 | [F:AOB]TYPGES=2 | sum([F:AOL]SELFIC(0..[F:AOL]NBSEL-1))=""
 VALEUR = 1 : mkstat = 2
Endif
End

Subprog AS_FIRLIS(VALEUR)
Variable Integer  VALEUR
If [M]DERLU<>2
 VALEUR = 1 : mkstat = 2 : End
Endif
End

Subprog AS_EXPLIEN(VALEUR)
Variable Char    VALEUR()
Local Integer OK , K
Local Char    CHAINE(80) , ZONE(80)
If VALEUR<>"" : End : Endif
Read [AOB2]ABREV = [M]DSTOBJ(nolign-1)
Filter [ATZ] Where LIEN=[F:AOB2]NOMFIC & CODFIC=[M]NOMFIC
Read [ATZ]LIEN First
Filter [ATZ]
If !fstat 
 Read [ATB]CODFIC = [M]NOMFIC
 If [F:ATZ]EXPLIEN<>""
  CHAINE = vireblc(format$("KT:80X",[F:ATZ]EXPLIEN),2)
  VALEUR = ""
  Repeat
   K = instr(K,CHAINE,";")
   If K
    ZONE   = left$(CHAINE,K-1)
    CHAINE = right$(CHAINE,K+1)
   Else
    ZONE   = CHAINE
    CHAINE = ""
   Endif
   If VALEUR<>"" : VALEUR += ";" : Endif
   If left$(ZONE,1)>="A" & left$(ZONE,1)<="Z"
    VALEUR += "[F:"+[F:ATB]ABRFIC+"]"+ZONE
   Else
    VALEUR += ZONE
   Endif
  Until CHAINE = ""
 Else
  VALEUR = "[F:"+[F:ATB]ABRFIC+"]"+[F:ATZ]CODZONE
 Endif
Endif
End

Subprog C_EXPLIEN(VALEUR)
Variable Char    VALEUR()
Read [AOB2]ABREV = [M]DSTOBJ(nolign-1)
Call CONTROLE([F:AOB2]NOMFIC,VALEUR) From LNKSUB
End

Subprog C_DSTOBJ(VALEUR)
Variable Char    VALEUR()
End

Subprog C_BASPAG(VALEUR)
Variable Char    VALEUR()
End

Subprog C_DERLU(VALEUR)
Variable Integer VALEUR
Local Integer K , OK , PROT
If VALEUR<>2 : End : Endif
Raz OK , PROT
For [AWI]AWI1 Where OBJ=[M]ABREV
 K = 1
 #If [F:AWI]CODACT>="X"
 # PROT = 1
 # K = 0
 If [F:AWI]CODACT<>""
  Read [ACV]CODACT = [F:AWI]CODACT
  If fstat or [F:ACV]FLACT<>2
   K = 0
  Endif
 Endif
 If K
  Read [AWB]AWB0 = [F:AWI]WIN
  If !fstat
   OK = 1 : Break
  Endif
 Endif
Next AWI
If !OK
 If PROT
  GMESSAGE = mess(26,139,1)+"\"+mess(25,139,1)
  # Impossible de rajouter le dernier lu\Fenêtres protégées par un code activité spécifique
  mkstat = 2 : End
 Else 
  GMESSAGE = mess(26,139,1)+"\"+mess(24,139,1)
  # Impossible de rajouter le dernier lu\Aucune fenêtre disponible
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_EXPLORE(VALEUR)
Variable Integer VALEUR
Local Integer K , OK , FULL , PROT
If VALEUR<>2 : End : Endif
Raz FULL , PROT , OK
For [AWI]AWI1 Where OBJ=[M]ABREV
 K = 1
 #If [F:AWI]CODACT>="X"
 # PROT = 1
 # K = 0
 If [F:AWI]CODACT>""
  Read [ACV]CODACT = [F:AWI]CODACT
  If fstat or [F:ACV]FLACT<>2
   K = 0
  Endif
 Endif
 If K
  Read [AWB]AWB0 = [F:AWI]WIN
  If !fstat
   OK = 1
   If !find("ALI",[F:AWB]OBJLIS(0..[F:AWB]NBLIS-1)) & [F:AWB]NBLIS>=dim([F:AWB]OBJLIS)
    FULL = 1 : Break
   Endif
  Endif
 Endif
Next AWI
If FULL
 GMESSAGE = mess(14,126,1)-[F:AWI]WIN-":"-mess(18,139,1)
 # Fenêtre x : Impossible de rajouter l'explorateur de liaison
 mkstat = 2 : End
Elsif !OK
 If PROT
  GMESSAGE = mess(18,139,1)+"\"+mess(25,139,1)
  # Impossible de rajouter l'explorateur de liaison\Fenêtres protégées par un code activité spécifique
  mkstat = 2 : End
 Else
  GMESSAGE = mess(18,139,1)+"\"+mess(24,139,1)
  # Impossible de rajouter l'explorateur de liaison\Aucune fenêtre disponible
  mkstat = 2 : End 
 Endif
Endif
End

Subprog C_ARCURL(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,"'") & instr(1,VALEUR,'"')
 # Les caractères ' et " ne doivent pas être utilisés ensemble
 GMESSAGE = mess(105,75,1) : mkstat = 1 : End
Endif
End
