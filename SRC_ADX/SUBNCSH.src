    mkstat = 2
    GMESSAGE = mess(10,123,1)
  Endif
End

# Reason must be entered for approver
Subprog C_APPRREASON(VALEUR)
Variable Char    VALEUR()
  mkstat = 0
  If VALEUR = ""
    If [M:NCSH2]NCSAPPUSR(nolign-1) = GUSER and [M:NCSH2]APPRSTAT(nolign-1) > 1
      mkstat = 2
      GMESSAGE = mess(86,199,1)
    Endif
  Endif
End

