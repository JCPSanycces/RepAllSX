Subprog AM_BPSNUM(VALEUR)
  Variable Char    VALEUR()

# Issue X3-94378 - 2018-06-05 by JUSYN : data base structure changes CCMCRORIGS TO NCSBPSCOL
  WNCSRECENT.NCSBPSCOL([M:NCSH3]ORIGSLN(nolign-1)).BPSNUM = VALEUR
  Call GET_ERRORS(WNCSRECENT) From SUBNCSHA
  If GERR = 1 Then
      WNCSRECENT.NCSBPSCOL([M:NCSH3]ORIGSLN(nolign-1)).BPSNUM = WNCSRECENT.NCSBPSCOL([M:NCSH3]ORIGSLN(nolign-1)).snapshot.BPSNUM
# Issue end X3-94378
      GERR = 1
      mkstat = 2
      End
  Else
      Call SHOW_ORIGIN_SUPPLIER([M:NCSH3]ORIGSLN(nolign-1),0) From SUBNCSHA # Issue X3-83486 - default contact
  Endif
  Affzo [M:NCSH3]1-99
End

# disable supplier contact if supplier not entered
Subprog AS_SUPPCONTACT(VALEUR)
Variable Char    VALEUR()

If [M:NCSH3]BPSNUM(nolign-1) = ""
