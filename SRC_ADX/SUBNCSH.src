Subprog C_NBLIG5
Local Integer INDEX
Local Integer NI

If status = 82 or status = 73 Then
    # Insert line
    If [M:NCSH3]BPSNUM(nolign-1) = AVOID.ACHAR Then
# Issue X3-94378 - 2018-06-05 by JUSYN : data base structure changes CCMCRORIGS TO NCSBPSCOL
        INDEX = fmet WNCSRECENT.ADDLINE("NCSBPSCOL", [V]CST_ALASTPOS)
        If INDEX <> [V]CST_ANOTDEFINED Then
            Call SHOW_ORIGIN_SUPPLIER(INDEX,0) From SUBNCSHA # Issue X3-83486 - default contact
        Else
            GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
            GERR = 4
            mkstat = 2
            GOK = 1
            End
        Endif
        Affzo [M:NCSH3]5
    Endif
Elsif status = 65 Then
    # Delete a line
    IRET = fmet WNCSRECENT.ADELLINE("NCSBPSCOL", WNCSRECENT.NCSBPSCOL([M:NCSH3]ORIGSLN(nolign-1)).AORDER)
# Issue end X3-94378
    If IRET = [V]CST_ANOTDEFINED Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
        GOK = 0
        GERR = 1
        mkstat = 2
    Endif
Endif

End

