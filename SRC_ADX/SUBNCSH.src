######################################################################################
# Issue X3-96818 - 2018-06-18 by JUSYN : Rework Approver lines access rights. Set already after lines read.
######################################################################################
## Section automatically added (screen NCSH2) 06/18/2018 11:46:02 (JUSYN)
######################################################################################
Subprog AP_NBLIG2

If [M:NCSH2]NCSMANAGER = GUSER # Issue X3-110459
  Actzo [M:NCSH2]NCSAPPUSR(nolign-1)
  Actzo [M:NCSH2]TRANSTYPE(nolign-1)
Else
  Grizo [M:NCSH2]NCSAPPUSR(nolign-1)
  Grizo [M:NCSH2]TRANSTYPE(nolign-1)
Endif


If [M:NCSH2]NCSAPPUSR(nolign-1) = GUSER
  Actzo [M:NCSH2]APPRSTAT(nolign-1)
  Actzo [M:NCSH2]APPRREASON(nolign-1)
Else
  Grizo [M:NCSH2]APPRSTAT(nolign-1)
  Grizo [M:NCSH2]APPRREASON(nolign-1)
Endif

End


######################################################################################
# End issue X3-96818

# Issue X3-97071 - 2018-06-18 by JUSYN : Same line (Approver and transaction type) only allowed once.
######################################################################################
## Section automatically added (screen NCSH2) 06/18/2018 14:41:23 (JUSYN)
######################################################################################
Subprog C_TRANSTYPE(VALEUR)
Variable Char    VALEUR() # Issue X3-105283
Local Integer J
Local Integer WFLAG

WFLAG = 0
For J = 0 To NBLIG2-1
  If (J <> nolign-1) & ([M:NCSH2]NCSAPPUSR(J) = [M:NCSH2]NCSAPPUSR(nolign-1)) & ([M:NCSH2]TRANSTYPE(J) = VALEUR)
    WFLAG = 1
    Break
  Endif
Next

If WFLAG
  GMESSAGE = mess(43,3702,1)  # The same transaction type for the same approver cannot be entered several times.
  mkstat = 2
Endif

End

######################################################################################
# End issue X3-97071

# Issue X3-92124 - 2018-06-21 by JUSYN : Controls, validations quantity treatment
######################################################################################
## Section automatically added (screen NCSH9) 06/21/2018 07:57:28 (JUSYN)
######################################################################################
Subprog AM_SELLIN(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 # = NO
    [M:NCSH9]NCSQTY(nolign-1) = 0
Elsif VALEUR = 2 # = Yes
    [M:NCSH9]NCSQTY(nolign-1) = [M:NCSH9]DOCQTY(nolign-1)
Endif
[M:NCSH9]SELLIN(nolign-1) = VALEUR
Call UPDATE_TOTAL_NCSQUANTITY
Affzo [NCSH9]1-99
End

Subprog C_NCSQTY(VALEUR)
Variable Decimal VALEUR

If VALEUR > [M:NCSH9]DOCQTY(nolign-1)
    GMESSAGE = mess(44,3702,1)  # Non-conformance quantity exceeds original document quantity.
    mkstat = 2
Endif

End

Subprog AM_NCSQTY(VALEUR)
Variable Decimal VALEUR

If VALEUR = 0
    [M:NCSH9]SELLIN(nolign-1) = 1
Else
    [M:NCSH9]SELLIN(nolign-1) = 2
Endif
[M:NCSH9]NCSQTY(nolign-1) = VALEUR
Call UPDATE_TOTAL_NCSQUANTITY
Affzo [NCSH9]1-99

End

Subprog UPDATE_TOTAL_NCSQUANTITY
Local Integer J

[M:NCSH9]DOCNCSQTY = 0
For J = 0 To NBLIG9-1
    [M:NCSH9]DOCNCSQTY += [M:NCSH9]NCSQTY(J)
Next

End
# Issue X3-92124 - end

######################################################################################

# Issue X3-97893 - 2018-09-11 by JUSYN : document line button not available if implemented and action plan at least in progress or completed/closed.
Funprog CHECK_PROGRESS_COMPLETION
Local Integer WFLAG : WFLAG = 0

Local File PLANDET [PLADET]
Filter [PLADET] Where PLANID=[M:NCSH0]NCSID & LINESTATUS > 1
For [PLADET]
    # at least one action is already in progress or completed
    WFLAG = 1
    Break
Next
Filter [PLADET]
LogicClose File [PLADET]

End WFLAG
# End issue X3-97893
######################################################################################

# Issue X3-97893 - 2018-09-12 by JUSYN : block adding document line if parameter NCSDOCCHG set to 1 = no
######################################################################################
## Section automatically added (screen NCSH1) 09/12/2018 09:24:34 (JUSYN)
######################################################################################
Subprog AP_NBLIG3

Local File NCSDOCHDR [NCSDHD]
Read [F:NCSDHD]NCSDHD0=[M:NCSH1]NCSID(nolign-1);[M:NCSH1]DOCLIN(nolign-1)
If fstat = 0
    If PNCSDOCCHG = "1" & ([M:NCSH0]NCSSTA > 5) | ([M:NCSH0]NCSSTA = 5 & func CHECK_PROGRESS_COMPLETION())
        Grizo [M:NCSH1]VCRLIN(nolign-1)
    Endif
Endif
LogicClose File [NCSDHD]

End


######################################################################################
# End issue X3-97893

