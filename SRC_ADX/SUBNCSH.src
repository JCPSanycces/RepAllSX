# Issue X3-69858 - get default QA manager and Planner
######################################################################################
## Section automatically added (screen NCSH0) 01/03/2018 10:21:27 (BAKHA)
######################################################################################
Subprog AM_SITE(VALEUR)
Variable Char    VALEUR()
# Issue X3-94378 - 2018-06-07 by JUSYN : Class needs to be opened to be able to enter fields
#                                        without getting error if "New" not clicked for first record
Local  Integer MY_STATUS
If WNCSRECENT <> null : FreeGroup WNCSRECENT :Endif
#--- Class instanciation
WNCSRECENT = NewInstance C_NCSRECENT AllocGroup null
[L]MY_STATUS = fmet WNCSRECENT.AINIT()
If [L]MY_STATUS >= [V]CST_AERROR
  #--- Header errors
#  GMESSAGE = func LCCLIB.MAXMSG(WNCSRECENT)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
Endif
WNCSRECENT.SITE = VALEUR
# End issue X3-94378

  # Get default QA manager
  # Issue X3-110459 - changed NCSH1 to NCSH2
  Call PARAM(VALEUR, "NCSQADEF", [M:NCSH2]NCSMANAGER) From ADOVAL
  Call LECTEXTRA([M]ZNCSMANAGER,"AUTILIS","INTUSR",num$([M:NCSH2]NCSMANAGER),"") From ATEXTRA  # Issue X3-94378 - 2018-06-15 by JUSYN : Missing to read new "Subtitle"
  WNCSRECENT.NCSMANAGER = [M:NCSH2]NCSMANAGER
  Affzo [M:NCSH2]NCSMANAGER
  Affzo [M:NCSH2]ZNCSMANAGER     # Issue X3-94378

  # Get default Planner
  Call PARAM(VALEUR, "NCSPLADEF", [M:NCSH2]NCSPLANNER) From ADOVAL
  Call LECTEXTRA([M]ZNCSPLANNER,"AUTILIS","INTUSR",num$([M:NCSH2]NCSPLANNER),"") From ATEXTRA  # Issue X3-94378 - 2018-06-15 by JUSYN : Missing to read new "Subtitle"
  WNCSRECENT.NCSPLANNER = [M:NCSH2]NCSPLANNER
  Affzo [M:NCSH2]NCSPLANNER
  Affzo [M:NCSH2]ZNCSPLANNER     # Issue X3-94378
  # Issue X3-110459 - end

# Issue X3-97893 - 2018-09-19 by JUSYN : reading parameter after NC read
# Issue X3-104609 - 2018-09-06 by JUSYN : Parameter NCSMULTIWO Linking prod. tracking for same or multiple WO
Call PARAM([M:NCSH0]SITE,"NCSMULTIWO",PNCSMULTIWO) From ADOVAL
# End issue X3-104609
# Issue X3-97893 - 2018-09-11 by JUSYN : Parameter NCSDOCCHG Allow changes to linked documents at NC status >= Implement
Call PARAM([M:NCSH0]SITE,"NCSDOCCHG",PNCSDOCCHG) From ADOVAL
# End issue X3-97893
# End issue X3-97893

End

# End issue X3-69858

