######################################################################################
## Section automatically added (screen NCSH2) 11/22/2017 14:05:44 (JUSYN)
######################################################################################
Subprog AS_NCSPLANNER(VALEUR)
Variable Char    VALEUR()

# Issue X3-94378 - 2018-06-05 by JUSYN : CRSTATUS to NCSSTA
# NCSSTA
# 1 = New
# 2 = In review
# 3 = Rejected
# 4 = Plan
# 5 = Implement
# 6 = Completed
# 7 = Closed

# Issue X3-110459 - NCSH1 changed to NCSH2
If (find([M:NCSH0]NCSSTA,1,2,4,5) & ([M:NCSH2]NCSMANAGER = GUSER | fmet WNCSRECENT.IS_USER_PLANNER()))
# End issue X3-94378
    Actzo [M:NCSH2]NCSPLANNER
Else
    Grizo [M:NCSH2]NCSPLANNER
Endif
# Issue X3-110459 - end

End

######################################################################################
## Section automatically added (screen NCSH2) 11/22/2017 16:23:58 (JUSYN)
######################################################################################
Subprog C_NCSPLANNER(VALEUR)
Variable Char    VALEUR()
# Issue X3-67933 - check planner is entered for Plan and implement
# Issue X3-94378 - 2018-06-05 by JUSYN : CRSTATUS to NCSSTA
If (VALEUR = "" & find([M:NCSH0]NCSSTA,4,5))
# End issue X3-94378
  GMESSAGE = mess (29,3702,1)
  mkstat = 2
Endif

End

######################################################################################
## Section automatically added (screen NCSH2) 11/23/2017 11:27:32 (JUSYN)
######################################################################################
Subprog AS_NCSMANAGER(VALEUR)
Variable Char    VALEUR()

  If (WNCSRECENT.NCSMANAGER = WNCSRECENT.ACTX.USER or fmet WNCSRECENT.IS_ADMIN_USER())
      Actzo [M:NCSH2]NCSMANAGER # Issue X3-110459
  Else
      Grizo [M:NCSH2]NCSMANAGER # Issue X3-110459
  Endif

End

# Issue X3-66939 - if product entered, then check it exists on site
Subprog C_PRODUCT(VALEUR)
Variable Char    VALEUR()

Global Char PARAM(32)(1..)

If (VALEUR <> "")
  PARAM(1) = VALEUR
  PARAM(2) = [M:NCSH0]SITE # Issue X3-80496 - 2018-02-28 by ALSHE : move field SITE to screen NCSH0
  PARAM(3) = ""
  Gosub C_ITF From TRTVENCTL
Endif
Raz PARAM
End

# Issue X3-66939 - end

######################################################################################
## Section automatically added (screen NCSH2) 11/24/2017 15:41:13 (JUSYN)
######################################################################################
Subprog AM_PRODUCT(VALEUR)
Variable Char    VALEUR()
Local Integer LRET

If dim([M:NCSH0]ECCVALMAJ) > 0
    Grizo [M:NCSH0]ECCVALMAJ
    Grizo [M:NCSH0]ECCVALMIN
    Raz [M:NCSH0]ECCVALMAJ,[M:NCSH0]ECCVALMIN
    LRET = func ECCLIB.NBRCPN(VALEUR)
    If LRET > 0
        If LRET = 1
            Actzo [M:NCSH0]ECCVALMAJ
            Grizo [M:NCSH0]ECCVALMIN
        Endif
        If LRET = 2
            Actzo [M:NCSH0]ECCVALMAJ
            Actzo [M:NCSH0]ECCVALMIN
        Endif
        Affzo [M:NCSH0]ECCVALMAJ
        Affzo [M:NCSH0]ECCVALMIN
    Endif
Endif

End

######################################################################################
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
If func ECCLIB.NBRCPN([M:NCSH0]PRODUCT) < 1
    mkstat=2
Endif
End

######################################################################################
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local Integer    LRET
Local Char       LMESSAGE(250)

Call CTRECC([M:NCSH0]PRODUCT,"NCSH0","ECCVALMAJ",VALEUR,[M:NCSH0]ECCVALMIN,
&           [0/0/0],LRET,LMESSAGE) From ECCLIB

If find(LRET,1,4)
    GMESSAGE = LMESSAGE
    mkstat=2
Endif
End

######################################################################################
Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
If func ECCLIB.NBRCPN([M:NCSH0]PRODUCT) < 2
    mkstat=2
Endif
End

Subprog C_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
Local Integer    LRET
Local Char       LMESSAGE(250)

Call CTRECC([M:NCSH0]PRODUCT,"NCSH0","ECCVALMIN",[M:NCSH0]ECCVALMAJ,VALEUR,
&           [0/0/0],LRET,LMESSAGE) From ECCLIB

If find(LRET,1,4)
    GMESSAGE = LMESSAGE
    mkstat=2
Endif

End

######################################################################################
## Section automatically added (screen NCSH4) 05.12.2017 10:15:56 (ALSHE)
######################################################################################
Subprog C_REJECTCOD(VALEUR)
Variable Char    VALEUR() # Issue X3-108668

# if the status is rejected the rejection code must contain a valid value
# Issue X3-94378 - 2018-06-05 by JUSYN : CRSTATUS to NCSSTA
If VALEUR = "" and [M:NCSH0]NCSSTA = 3 # Issue X3-108668
    GERR=1
    GMESSAGE = mess(12,2038,1)
    mkstat = 2
# when modifying the record the user und the date will be updated
Elsif VALEUR <> WNCSRECENT.REJECTCOD and [M:NCSH0]NCSSTA = 3
# End issue X3-94378
    [M:NCSH4]REJECTUSR = WNCSRECENT.ACTX.USER
    [M:NCSH4]REJECTDAT = date$
Endif
End

######################################################################################
## Section automatically added (screen NCSH4) 07.12.2017 12:44:52 (ALSHE)
######################################################################################
Subprog C_REJDESC(VALEUR)
Variable Clbfile VALEUR

# when modifying the record user und date are updated
If VALEUR <> WNCSRECENT.REJDESC and [M:NCSH0]NCSSTA = 3     # Issue X3-94378 - 2018-06-05 by JUSYN : CRSTATUS to NCSSTA
    [M:NCSH4]REJECTUSR = WNCSRECENT.ACTX.USER
    [M:NCSH4]REJECTDAT = date$
Endif
End

######################################################################################

# Issue X3-67019 - 2017-12-18 by JUSYN : Control on origin customer line
######################################################################################
## Section automatically added (screen NCSH3) 12/11/2017 13:57:30 (JUSYN)
######################################################################################
Subprog C_NBLIG6
Local Integer INDEX
Local Integer NI

If status = 82 or status = 73 Then
    # Insert line
    If [M:NCSH3]BPCNUM(nolign-1) = AVOID.ACHAR Then
        # Issue X3-94378 - 2018-06-05 by JUSYN : data base structure changes CCMCRORIGC TO NCSBPCCOL
        INDEX = fmet WNCSRECENT.ADDLINE("NCSBPCCOL", [V]CST_ALASTPOS)
        If INDEX <> [V]CST_ANOTDEFINED Then
            Call SHOW_ORIGIN_CUSTOMER(INDEX, 0) From SUBNCSHA  # Issue X3-83486 - default contact
        Else
            GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
            GERR = 4
            mkstat = 2
            GOK = 1
            End
        Endif
        Affzo [M:NCSH3]10
    Endif
Elsif status = 65 Then
    # Delete a line
    IRET = fmet WNCSRECENT.ADELLINE("NCSBPCCOL", WNCSRECENT.NCSBPCCOL([M:NCSH3]ORIGCLN(nolign-1)).AORDER)
        # End issue X3-94378
    If IRET = [V]CST_ANOTDEFINED Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
        GOK = 0
        GERR = 1
        mkstat = 2
    Endif
Endif

End
######################################################################################
# End issue X3-67019

# Issue X3-67019 - 2017-12-18 by JUSYN : Validations on customer and contact
######################################################################################
## Section automatically added (screen NCSH3) 12/11/2017 14:26:29 (JUSYN)
######################################################################################
Subprog AM_CUSTCONTACT(VALEUR)
Variable Char    VALEUR()

# Issue X3-94378 - 2018-06-05 by JUSYN : data base structure changes CCMCRORIGC TO NCSBPCCOL
WNCSRECENT.NCSBPCCOL([M:NCSH3]ORIGCLN(nolign-1)).CUSTCONTACT = VALEUR
Call GET_ERRORS(WNCSRECENT) From SUBNCSHA
If GERR = 1 Then
    WNCSRECENT.NCSBPCCOL([M:NCSH3]ORIGCLN(nolign-1)).CUSTCONTACT = WNCSRECENT.NCSBPCCOL([M:NCSH3]ORIGCLN(nolign-1)).snapshot.CUSTCONTACT
# Issue end X3-94378
    GERR = 1
    mkstat = 2
    End
Else
    Call SHOW_ORIGIN_CUSTOMER([M:NCSH3]ORIGCLN(nolign-1),0) From SUBNCSHA # Issue X3-83486 - default contact
Endif
Affzo [M:NCSH3]1-99

End

######################################################################################
## Section automatically added (screen NCSH3) 12/19/2017 10:05:36 (JUSYN)
######################################################################################
Subprog C_BPCNUM(VALEUR)
Variable Char    VALEUR()
Local Integer WLINE

If (VALEUR = "")
    GMESSAGE = mess(10,123,1)
    mkstat = 2
Else
    WLINE = find(VALEUR, [M:NCSH3]BPCNUM(0..[M:NCSH3]NBLIG6-1))
    If WLINE > 0 & WLINE <> nolign
        GMESSAGE = mess(24,3702,1)  # Duplicate Originator not allowed.
        mkstat = 2
    Endif
Endif

End

######################################################################################
## Section automatically added (screen NCSH3) 12/12/2017 13:56:26 (JUSYN)
######################################################################################
Subprog AM_BPCNUM(VALEUR)
Variable Char    VALEUR()

# Issue X3-94378 - 2018-06-05 by JUSYN : data base structure changes CCMCRORIGC TO NCSBPCCOL
WNCSRECENT.NCSBPCCOL([M:NCSH3]ORIGCLN(nolign-1)).BPCNUM = VALEUR
Call GET_ERRORS(WNCSRECENT) From SUBNCSHA
If GERR = 1 Then
    WNCSRECENT.NCSBPCCOL([M:NCSH3]ORIGCLN(nolign-1)).BPCNUM = WNCSRECENT.NCSBPCCOL([M:NCSH3]ORIGCLN(nolign-1)).snapshot.BPCNUM
# Issue end X3-94378
    GERR = 1
    mkstat = 2
    End
Else
    Call SHOW_ORIGIN_CUSTOMER([M:NCSH3]ORIGCLN(nolign-1), 0) From SUBNCSHA # Issue X3-83486 - default contact
Endif

If VALEUR = ""
    Grizo [M:NCSH3]CUSTCONTACT(nolign-1)
Else
    Actzo [M:NCSH3]CUSTCONTACT(nolign-1)
Endif

Affzo [M:NCSH3]1-99

End

