######################################################################################
Subprog C_USER(VALEUR)
Variable Char    VALEUR()
Local Integer WLINE

If (VALEUR = "")
    GMESSAGE = mess(10,123,1)
    mkstat = 2
Else
    WLINE = find(VALEUR, [M:NCSH3]USER(0..[M:NCSH3]NBLIG7-1))
    If WLINE > 0 & WLINE <> nolign
        GMESSAGE = mess(24,3702,1)  # Duplicate Originator not allowed.
        mkstat = 2
    Endif
Endif

End

