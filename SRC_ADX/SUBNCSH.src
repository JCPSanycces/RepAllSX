      WNCSRECENT.NCSINTUSR([M:NCSH3]ORIGILN(nolign-1)).USER = WNCSRECENT.NCSINTUSR([M:NCSH3]ORIGILN(nolign-1)).snapshot.USER     # Issue X3-94378 - 2018-06-05 by JUSYN : data base structure changes
# CCMCRORIGI TO NCSINTUSR
      GERR = 1
