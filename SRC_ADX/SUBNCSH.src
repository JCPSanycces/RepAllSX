Variable Char    VALEUR()

  WNCSRECENT.NCSAPPROVER([M:NCSH2]APPRLN(nolign-1)).NCSAPPUSR = VALEUR
  Call GET_ERRORS(WNCSRECENT) From SUBNCSHA
  If GERR = 1 Then
      WNCSRECENT.NCSAPPROVER([M:NCSH2]APPRLN(nolign-1)).NCSAPPUSR = WNCSRECENT.NCSAPPROVER([M:NCSH2]APPRLN(nolign-1)).snapshot.NCSAPPUSR
      GERR = 1
      mkstat = 2
      End
  Else
      Call SHOW_APPROVER_USER([M:NCSH2]APPRLN(nolign-1)) From SUBNCSHA
  Endif
  Affzo [M:NCSH2]1-99

End


