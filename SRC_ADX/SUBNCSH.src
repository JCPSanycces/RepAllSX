## Section automatically added (Object NCSH) 10/31/2017 10:41:37 (BAKHA)
######################################################################################
$ACTION
Case ACTION
  When "OUVRE"        : Gosub OUVRE           From SUBNCSHA
  When "SETBOUT"      : Gosub SETBOUT         From SUBNCSHA
  When "EXEBOUT"      : Gosub EXEBOUT         From SUBNCSHA
  When "STATUT"       : Gosub STATUT          From SUBNCSHA
  When "RAZCRE"       : Gosub RAZCRE          From SUBNCSHA
  When "INICRE"       : Gosub INICRE          From SUBNCSHA
  When "CREATION"     : Gosub CREATION        From SUBNCSHA
  When "LIENS"        : Gosub LIENS           From SUBNCSHA
  When "APRES_MOD"    : Gosub APRES_MOD       From SUBNCSHA
  When "APRES_CRE"    : Gosub APRES_CRE       From SUBNCSHA
  When "DEFLIG"       : Gosub DEFLIG          From SUBNCSHA
  When "AV_ANNULE"    : Gosub AV_ANNULE       From SUBNCSHA
  When "ANNULE"       : Gosub ANNULE          From SUBNCSHA
  When "ABANDON"      : Gosub ABANDON         From SUBNCSHA
  When "FILTRE"       : Gosub FILTRE          From SUBNCSHA
  When "FILGAUCHE"    : Gosub FILGAUCHE       From SUBNCSHA          # Issue X3-72455
  When "CLE_GAUCHE"   : Gosub CLE_GAUCHE      From SUBNCSHA          # Issue X3-72457 - 2018-02-16 by ALSHE : add sort to left list with view
  When "GAUCHE"       : Gosub GAUCHE          From SUBNCSHA          # Issue X3-72457 - 2018-02-16 by ALSHE : assign selected value from left list with a view to the main class
  When "MODIF"        : Gosub MODIF           From SUBNCSHA
  When "INICRE_LIG"   : Gosub INICRE_LIG      From SUBNCSHA
  When "LIENS_LIG"    : Gosub LIENS_LIG       From SUBNCSHA
  When "VALLIG"       : Gosub VALLIG          From SUBNCSHA
  When "FERME"        : Gosub FERME           From SUBNCSHA
  When "BB3_NBLIG3"   : Gosub BB3_NBLIG3      From SUBNCSHA
  When "AVANT_CHOI"   : Gosub AVANT_CHOI      From SUBNCSHA          # Issue X3-92174 - 2018-07-06 by JUSYN : fullmode creation NC
  When Default
Endcase
Return

