# Issue X3-77826 - document links grid

######################################################################################
Subprog C_NBLIG3

# if not QA manager, do not allow insert line or delete line
If (WNCSRECENT.NCSMANAGER <> GUSER or !find([M:NCSH0]NCSSTA,2,4,5,6))     # Issue X3-94378 - 2018-06-05 by JUSYN : CRSTATUS to NCSSTA
  If (status = 82 or status = 73)
    mkstat = 2
    End
  Endif
Endif

If (status = 82 or status = 73) Then
    # Insert line
    If [M:NCSH1]DOCTYP(nolign-1) < 1 Then
        INDEX = fmet WNCSRECENT.ADDLINE("NCSDOCHDR", [V]CST_ALASTPOS)     # ISSUE X3-94378
        If INDEX <> [V]CST_ANOTDEFINED Then
            Call SHOW_DOCUMENTS(INDEX) From SUBNCSHA
        Else
            GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
            GERR = 4
            mkstat = 2
            GOK = 1
            End
        Endif
        Affzo [M:NCSH1]10
    Endif
Endif

End

# enable/disable document type
Subprog AS_DOCTYP(VALEUR)
Variable Integer VALEUR

  # check QA manager and status
  # Issue X3-110459 - changed NCSH1 to NCSH2
  If [M:NCSH2]NCSMANAGER = GUSER and find([M:NCSH0]NCSSTA,2,4,5,6)     # Issue X3-94378 - 2018-06-05 by JUSYN : CRSTATUS to NCSSTA
    Actzo [M:NCSH1]DOCTYP(nolign-1)
    # Issue X3-99097 - 2018-07-04 by STWIL : Disable Quality control type as it is currently not required
    Raz GMENLOC
    GMENLOC(4) = 1

    # set to default if customer or supplier entered
    If [M:NCSH0]NCSBPC <> ""
      GMENLOC(1) = 1
      GMENLOC(3) = 1
    Elsif [M:NCSH0]NCSBPS <> ""
      GMENLOC(2) = 1
      GMENLOC(3) = 1
    Endif
    VALEUR=0
  Else
    Grizo [M:NCSH1]DOCTYP(nolign-1)
  Endif

End

Subprog C_DOCTYP(VALEUR)
Variable Integer VALEUR
  mkstat = 0
  If [M:NCSH2]NCSMANAGER = GUSER and VALEUR = 0 # Issue X3-110459
    mkstat = 2
    GMESSAGE = mess(10,123,1)
  Endif
End

Subprog AM_DOCTYP(VALEUR)
Variable Integer VALEUR

  WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).DOCTYP = VALEUR     # ISSUE X3-94378
  Call GET_ERRORS(WNCSRECENT) From SUBNCSHA
  If GERR = 1 Then
      WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).DOCTYP = WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).snapshot.NCSDOCHDR     # ISSUE X3-94378
      GERR = 1
      mkstat = 2
      End
  Else
      Call SHOW_DOCUMENTS([M:NCSH1]DOCLIN(nolign-1)) From SUBNCSHA
  Endif
  Affzo [M:NCSH1]1-99
End

Subprog AS_VCRNUM(VALEUR)
Variable Char    VALEUR()
  # Issue X3-110459
  If [M:NCSH2]NCSMANAGER = GUSER and find([M:NCSH0]NCSSTA,2,4,5,6)     # Issue X3-94378 - 2018-06-05 by JUSYN : CRSTATUS to NCSSTA
    Actzo [M:NCSH1]VCRNUM(nolign-1)
  Else
    Grizo [M:NCSH1]VCRNUM(nolign-1)
  Endif

End

Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()

Local Integer ASTATUS
Local Char MESSAGE(80)
# Issue X3-97893 - 2018-09-14 by JUSYN : check for manual entered document numbers if at least one of its detail lines have required product
If func AFNC.ACTIV("ECC")
    WECCFLG = 1
Endif
Local Integer WFLAG : WFLAG = 0
# End issue X3-97893

  # check document number is not blank
  mkstat = 0
  If [M:NCSH2]NCSMANAGER = GUSER and VALEUR = "" # Issue X3-110459
    mkstat = 2
    GMESSAGE = mess(10,123,1)
    End
  Endif

  MESSAGE = ""
  ASTATUS = fmet WNCSRECENT.IS_DOCUMENT_VALID ([M:NCSH1]DOCTYP(nolign-1), VALEUR, MESSAGE)
  If [L]ASTATUS = [V]CST_AERROR Then
    GMESSAGE = MESSAGE
    mkstat = 2
  Endif

# Issue X3-97893 - 2018-09-15 by JUSYN : check for manual entered document numbers if at least one of its detail lines have required product
  If [M:NCSH0]PRODUCT <> ""
    Case [M:NCSH1]DOCTYP(nolign-1)
      When 1 : # purchase receipt
        If WECCFLG > 0 and [M:NCSH0]ECCVALMAJ <> ""
          If clalev([F:NCSPTHS]) = 0 : Local File NCSPTHPTDSTJ  [NCSPTHS] : Endif
          Filter [NCSPTHS] Where PRHFCY    = [M:NCSH0]SITE
&                              & ITMREF    = [M:NCSH0]PRODUCT
&                              & ECCVALMAJ = [M:NCSH0]ECCVALMAJ
&                              & ECCVALMIN = [M:NCSH0]ECCVALMIN
&                              & PTHNUM    = VALEUR
          Read [NCSPTHS] First
          If fstat
            GMESSAGE = mess(35,3702,1) # Product is different
            mkstat = 2
          Endif
          Filter [NCSPTHS]
        Else # receipt line without version
          If clalev([F:NCSPTH]) = 0 : Local File NCSPTHPTD  [NCSPTH] : Endif
          Filter [NCSPTH] Where PRHFCY    = [M:NCSH0]SITE
&                             & ITMREF    = [M:NCSH0]PRODUCT
&                             & PTHNUM    = VALEUR
          Read [NCSPTH] First
          If fstat
            GMESSAGE = mess(35,3702,1) # Product is different
            mkstat = 2
          Endif
          Filter [NCSPTH]
        Endif
      When 2 : # customer returns
        If WECCFLG > 0 and [M:NCSH0]ECCVALMAJ <> ""
          If clalev([F:NCSSRHS]) = 0 : Local File NCSSRHSRDSTJ  [NCSSRHS] : Endif
          Filter [NCSSRHS] Where STOFCY    = [M:NCSH0]SITE
&                              & ITMREF    = [M:NCSH0]PRODUCT
&                              & ECCVALMAJ = [M:NCSH0]ECCVALMAJ
&                              & ECCVALMIN = [M:NCSH0]ECCVALMIN
&                              & SRHNUM    = VALEUR
          Read [NCSSRHS] First
          If fstat
            GMESSAGE = mess(35,3702,1) # Product is different
            mkstat = 2
          Endif
          Filter [NCSSRHS]
        Else # customer returns line without version
          If clalev([F:NCSSRH]) = 0 : Local File NCSSRHSRD [NCSSRH] : Endif
          Filter [NCSSRH] Where  STOFCY    = [M:NCSH0]SITE
&                              & ITMREF    = [M:NCSH0]PRODUCT
&                              & SRHNUM    = VALEUR
          Read [NCSSRH] First
          If fstat
            GMESSAGE = mess(35,3702,1) # Product is different
            mkstat = 2
          Endif
          Filter [NCSSRH]
        Endif
      When 3 : # production tracking
        If WECCFLG > 0 and [M:NCSH0]ECCVALMAJ <> ""
          If clalev([F:NCSMTKS]) = 0 : Local File NCSMTKMKISTJ [NCSMTKS] : Endif
          Filter [NCSMTKS] Where MFGFCY    = [M:NCSH0]SITE
&                              & ITMREF    = [M:NCSH0]PRODUCT
&                              & ECCVALMAJ = [M:NCSH0]ECCVALMAJ
&                              & ECCVALMIN = [M:NCSH0]ECCVALMIN
&                              & MFGTRKNUM = VALEUR
          Read [NCSMTKS] First
          If fstat
            GMESSAGE = mess(35,3702,1) # Product is different
            mkstat = 2
          Endif
          Filter [NCSMTKS]
        Else # customer returns line without version
          If clalev([F:NCSMTK]) = 0 : Local File NCSMTKMKI  [NCSMTK] : Endif
          Filter [NCSMTK] Where  MFGFCY    = [M:NCSH0]SITE
&                              & ITMREF    = [M:NCSH0]PRODUCT
&                              & MFGTRKNUM = VALEUR
          Read [NCSMTK] First
          If fstat
            GMESSAGE = mess(35,3702,1) # Product is different
            mkstat = 2
          Endif
          Filter [NCSMTK]
        Endif
    Endcase
  Endif
# End issue X3-97893
# Issue X3-104609 - 2018-09-06 by JUSYN : Check production tracking document has got the same WO like in prod. tracking of first line
If PNCSMULTIWO <> "2" & [M:NCSH0]CMFGNUM <> ""
    If [M:NCSH1]DOCTYP(0) = 3 & VALEUR <> ""  # Production tracking
        Local File MFGHEADTRK [MTK]
        Read [F:MTK]MTK0=VALEUR
        If (fstat = 0)
          # check work order number
          If ([F:MTK]MFGNUM <> [M:NCSH0]CMFGNUM)
              GMESSAGE = mess(54,3702,1) # Invalid document number
              mkstat = 2
          Endif
        Endif
        LogicClose File [MTK]
    Endif
# End issue X3-104609
Endif
End

Subprog AP_VCRNUM(VALEUR)
Variable Char    VALEUR()

  WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).VCRNUM = VALEUR     # ISSUE X3-94378
  Call GET_ERRORS(WNCSRECENT) From SUBNCSHA
  If GERR = 1 Then
      WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).VCRNUM = WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).snapshot.NCSDOCHDR     # ISSUE X3-94378
      GERR = 1
      mkstat = 2
      End
  Else
      # Populate all the other fields from document
      WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).LINSTA = 1    # ISSUE X3-94378
      Case [M:NCSH1]DOCTYP(nolign-1)

        When 1 : # check purchase receipt
                 Local File PRECEIPT [PTH]
                 Read [F:PTH]PTH0=VALEUR
                 If (fstat = 0)
                   WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).DOCDAT = [F:PTH]RCPDAT     # ISSUE X3-94378 CCMNCSDOC to NCSDOCHDR
                   WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).BPSNUM = [F:PTH]BPSNUM
                   WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).PJT = [F:PTH]PJTH
                 Endif
                 LogicClose File [PTH]

        When 2 : # check customer return
                 Local File SRETURN [SRH]
                 Read [F:SRH]SRH0=VALEUR
                 If (fstat = 0)
                   WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).DOCDAT = [F:SRH]RTNDAT     # ISSUE X3-94378 CCMNCSDOC to NCSDOCHDR
                   WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).BPCNUM = [F:SRH]BPCORD
                   WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).PJT = [F:SRH]PJT
                 Endif
                 LogicClose File [SRH]

        When 3 : # check production tracking
                 Local File MFGHEADTRK [MTK]
                 Read [F:MTK]MTK0=VALEUR
                 If (fstat = 0)
                   WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).DOCDAT = [F:MTK]MFGTRKDAT     # ISSUE X3-94378
                 Endif
                 LogicClose File [MTK]

        When 4 : # check quailty control
                 Local File STOQLYH [QLH]
                 Read [F:QLH]QLH0=28;VALEUR
                 If (fstat = 0)
                   WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).DOCDAT = [F:QLH]ENDCTLDAT     # ISSUE X3-94378 CCMNCSDOC to NCSDOCHDR
                   WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).PJT = [F:QLH]PJT
                 Endif
                 LogicClose File [QLH]

      Endcase
      # set line as well
      # Issue X3-100238 - 2018-08-20 by JUSYN : if document has been changed then line number has to be reset to 0.
      If [M:NCSH1]VCRNUM(nolign-1) <> VALEUR : [M:NCSH1]VCRLIN(nolign-1) = 0 : Endif
      # End issue X3-100238
      WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).VCRLIN = [M:NCSH1]VCRLIN(nolign-1)     # ISSUE X3-94378

      Call SHOW_DOCUMENTS([M:NCSH1]DOCLIN(nolign-1)) From SUBNCSHA
      # populate fields from line
      Call AM_VCRLIN ([M:NCSH1]VCRLIN(nolign-1))
  Endif
  Affzo [M:NCSH1]1-99

# Issue X3-104609 - 2018-09-06 by JUSYN : set criteria WO depending on param NCSMULTIWO
  If PNCSMULTIWO <> "2" & (nolign-1) = 0
      Call SET_CRITERIA_WO() From SUBNCSHA
  Endif
# End issue X3-104609


End


######################################################################################

######################################################################################
## Section automatically added (screen NCSH1) 03/21/2018 15:49:39 (JUSYN)
#  Issue X3-79084 - 2018-03-21 by JUSYN : Set button to tunnel linked document
######################################################################################
Subprog IB_NBLIG3
Local Integer L     : L = nolign-1

GBOUT1 = ""
GBOUT2 = ""
GBOUT3 = "" # Issue X3-88163

If [M:NCSH1]VCRNUM(L) <> "" & [M:NCSH1]LINSTA(L) = 1
    Case [M:NCSH1]DOCTYP(L)
        When 1:
                  GBOUT1 = mess(1,3718,1)-[M:NCSH1]VCRNUM(L)  # Purchase receipt
        When 2:
                  GBOUT1 = mess(2,3718,1)-[M:NCSH1]VCRNUM(L)  # Customer return
        When 3:
                  GBOUT1 = mess(3,3718,1)-[M:NCSH1]VCRNUM(L)  # Production tracking
        When 4:
                  GBOUT1 = mess(4,3718,1)-[M:NCSH1]VCRNUM(L)  # Quality control
                  [M:NCSH1]VCRTYP(nolign-1) = 28
    Endcase
Endif

# Issue X3-97893 - 2018-09-13 by JUSYN : detail lines not to activate or deactivate
#  Issue X3-79089 - 2018-03-22 by JUSYN : deactivate / activate document link
If (PNCSDOCCHG = "1") & (([M:NCSH0]NCSSTA > 6) | (([M:NCSH0]NCSSTA = 6) & ([M:NCSH1]VCRLIN(L) > 0)) | (([M:NCSH1]VCRLIN(L) > 0) & ([M:NCSH0]NCSSTA = 5 & func CHECK_PROGRESS_COMPLETION())))
    # GBOUT2 = ""  GBOUT2 stays blank
Else
    # X3-110459 - change NCSH1 to NCSH2
    If [M:NCSH0]NCSSTA < 7 & [M:NCSH1]VCRNUM(L) <> "" & [M:NCSH2]NCSMANAGER = GUSER     # Issue X3-94378 - 2018-06-05 by JUSYN : CRSTATUS to NCSSTA
        If [M:NCSH1]LINSTA(L) = 1
            GBOUT2 = mess(505,198,1)  # Deactivate document
        Elsif [M:NCSH1]LINSTA(L) = 2
            GBOUT2 = mess(506,198,1)  # Activate document
        Endif
    Endif
# End issue X3-79089
Endif
# End issue X3-97893

# Issue X3-97893 - 2018-09-19 by JUSYN : Display document lines always
# Issue X3-88163 - display document line button
If ([M:NCSH1]LINSTA(L) = 1)
    If ([M:NCSH1]VCRNUM(L) <> "" & [M:NCSH1]VCRLIN(L) > 0)
        GBOUT3 = mess(1,2415,1)
    Endif
Endif
# End issue X3-97893

End
# End issue X3-79084
######################################################################################

######################################################################################
## Section automatically added (screen NCSH1) 03/21/2018 14:35:21 (JUSYN)
#  Issue X3-79089 - 2018-03-21 by JUSYN : deactivate / activate document link
######################################################################################
Subprog B2_NBLIG3

If [M:NCSH1]LINSTA(nolign-1) = 1
    [M:NCSH1]LINSTA(nolign-1) = 2
Elsif [M:NCSH1]LINSTA(nolign-1) = 2
    [M:NCSH1]LINSTA(nolign-1) = 1
Endif
Affzo [M:NCSH1]LINSTA(nolign-1)
WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).LINSTA = [M:NCSH1]LINSTA(nolign-1)     # ISSUE X3-94378
mkstat = 4

End
# End issue X3-79089
######################################################################################

# Issue X3-78905 - Add selection on field VCRLIN for document line links

Subprog AS_VCRLIN(VALEUR)
Variable Decimal VALEUR
  # Issue X3-78905 - if product entered, allow line selection
  # If [M:NCSH0]PRODUCT <> ""
  # Issue X3-100238 - 2018-08-20 by JUSYN : Line selection possible even if product not entered
  If [M:NCSH2]NCSMANAGER = GUSER and find([M:NCSH0]NCSSTA,2,4,5,6) # Issue X3-110459
  # End issue X3-100238
  # Issue X3-97893 - 2018-09-13 by JUSYN : set VCRLIN active only if no blocking reasons
    If PNCSDOCCHG = "1"
      If ([M:NCSH0]NCSSTA > 5) | ([M:NCSH0]NCSSTA = 5 & func CHECK_PROGRESS_COMPLETION())
        Grizo [M:NCSH1]VCRLIN(nolign-1)
      Endif
    Else
      Actzo [M:NCSH1]VCRLIN(nolign-1)
    Endif
  # End issue X3-97893
  Else
      Grizo [M:NCSH1]VCRLIN(nolign-1)
  Endif
End

Subprog C_VCRLIN(VALEUR)
Variable Decimal VALEUR

  If (VALEUR > 0)
    mkstat = 0
    # check document line exists
    Case [M:NCSH1]DOCTYP(nolign-1)

      When 1 : # check purchase receipt line
               Local File PRECEIPTD [PTD]
               Read [F:PTD]PTD0=[M:NCSH1]VCRNUM(nolign-1);VALEUR
               If (fstat = 0)
                 # Issue X3-100229 - 2018-09-04 by JUSYN : Allow selection from purchase receipts header and detail; check for product only if filled
                 If ([F:PTD]ITMREF <> [M:NCSH0]PRODUCT & [M:NCSH0]PRODUCT <> "")
                 # End issue X3-100229
                   GMESSAGE = mess(35,3702,1)
                   mkstat = 2
                 Endif
               Else
                 GMESSAGE = mess(79,121,1)-mess(3,40,1)
                 mkstat = 2
               Endif
               LogicClose File [PTD]

               # check product major/minor version is same

               If (mkstat = 0 and dim([M:NCSH0]ECCVALMAJ)>0 and [M:NCSH0]ECCVALMAJ <> "")
                 Local File STOJOU [STJ]
                 Read [F:STJ]STJ1=[M:NCSH0]SITE;6;[M:NCSH1]VCRNUM(nolign-1);VALEUR
                 If (fstat = 0)
                   If ([F:STJ]ECCVALMAJ <> [M:NCSH0]ECCVALMAJ)
                     GMESSAGE = mess(420,184,1)
                     mkstat = 2
                   Elsif ([M:NCSH0]ECCVALMIN <> "")
                     If ([F:STJ]ECCVALMIN <> [M:NCSH0]ECCVALMIN)
                       GMESSAGE = mess(420,184,1)
                       mkstat = 2
                     Endif
                   Endif
                 Endif
                 LogicClose File [STJ]
               Endif

      When 2 : # check customer return line
               Local File SRETURND [SRD]
               Read [F:SRD]SRD0=[M:NCSH1]VCRNUM(nolign-1);VALEUR
               If (fstat = 0)
                 # Issue X3-88164 - 2018-08-30 by JUSYN : Allow selection from customer returns header and detail; check for product only if filled
                 If ([F:SRD]ITMREF <> [M:NCSH0]PRODUCT & [M:NCSH0]PRODUCT <> "")
                 # End issue X3-88164
                   GMESSAGE = mess(35,3702,1)
                   mkstat = 2
                 Endif
               Else
                 GMESSAGE = mess(521,197,1)
                 mkstat = 2
               Endif
               LogicClose File [SRD]

               # check product major/minor version is same

               If (mkstat = 0 and dim([M:NCSH0]ECCVALMAJ)>0 and [M:NCSH0]ECCVALMAJ <> "")
                 Local File STOJOU [STJ]
                 Read [F:STJ]STJ1=[M:NCSH0]SITE;13;[M:NCSH1]VCRNUM(nolign-1);VALEUR
                 If (fstat = 0)
                   If ([F:STJ]ECCVALMAJ <> [M:NCSH0]ECCVALMAJ)
                     GMESSAGE = mess(420,184,1)
                     mkstat = 2
                   Elsif ([M:NCSH0]ECCVALMIN <> "")
                     If ([F:STJ]ECCVALMIN <> [M:NCSH0]ECCVALMIN)
                       GMESSAGE = mess(420,184,1)
                       mkstat = 2
                     Endif
                   Endif
                 Endif
                 LogicClose File [STJ]
               Endif


      When 3 : # check production tracking line
               Local File MFGITMTRK [MKI]
               Read [F:MKI]MKI0=[M:NCSH1]VCRNUM(nolign-1);VALEUR
               If (fstat = 0)
                 # Issue X3-100238 - 2018-08-14 by JUSYN : Allow selection from tracking header and detail; check for product only if filled
                 If ([F:MKI]ITMREF <> [M:NCSH0]PRODUCT & [M:NCSH0]PRODUCT <> "" )
                 # End issue X3-100238
                   GMESSAGE = mess(35,3702,1)
                   mkstat = 2
                 Endif
               Else
                 GMESSAGE = mess(214,195,1)-mess(9,155,1)
                 mkstat = 2
               Endif
               LogicClose File [MKI]

               # check product major/minor version is same

               If (mkstat = 0 and dim([M:NCSH0]ECCVALMAJ)>0 and [M:NCSH0]ECCVALMAJ <> "")
                 Local File STOJOU [STJ]
                 Read [F:STJ]STJ1=[M:NCSH0]SITE;15;[M:NCSH1]VCRNUM(nolign-1);VALEUR
                 If (fstat = 0)
                   If ([F:STJ]ECCVALMAJ <> [M:NCSH0]ECCVALMAJ)
                     GMESSAGE = mess(420,184,1)
                     mkstat = 2
                   Elsif ([M:NCSH0]ECCVALMIN <> "")
                     If ([F:STJ]ECCVALMIN <> [M:NCSH0]ECCVALMIN)
                       GMESSAGE = mess(420,184,1)
                       mkstat = 2
                     Endif
                   Endif
                 Endif
                 LogicClose File [STJ]
               Endif

      When 4 : # check quailty control line
               Local File STOQLYD [QLD]
               Read [F:QLD]QLD0=28;[M:NCSH1]VCRNUM(nolign-1);VALEUR
               If (fstat <> 0)
                 GMESSAGE = mess(28,701,1)-mess(9,155,1)
                 mkstat = 2
               Else
                 If (dim([M:NCSH0]ECCVALMAJ)>0 and [M:NCSH0]ECCVALMAJ <> "")
                   If ([F:QLD]ECCVALMAJ <> [M:NCSH0]ECCVALMAJ)
                     GMESSAGE = mess(420,184,1)
                     mkstat = 2
                   Elsif ([M:NCSH0]ECCVALMIN <> "") and ([F:QLD]ECCVALMIN <> [M:NCSH0]ECCVALMIN)
                     GMESSAGE = mess(420,184,1)
                     mkstat = 2
                   Endif
                 Endif
               Endif
               LogicClose File [QLD]

    Endcase
  # if NCS for product then line must be entered
  Elsif ([M:NCSH0]PRODUCT <> "")
    mkstat = 2
    GMESSAGE = mess(10,123,1)
  Endif

End

Subprog AM_VCRLIN(VALEUR)
Variable Decimal VALEUR
Local Char MESSAGE(100) # Issue X3-84473
Local Integer MY_STATUS
# Issue X3-97893 - 2018-09-14 by JUSYN : not stock managed products
Local Char WECCVALMAJ(GLONECS) : WECCVALMAJ = ""
Local Char WECCVALMIN(GLONEVL) : WECCVALMIN = ""
# End issue X3-97893
# Issue X3-100238 - 2018-08-24 by JUSYN : code improvements
Local Integer  WECCFLG            : WECCFLG       = 0
If func AFNC.ACTIV("ECC")
    WECCFLG = 1
Endif
# End issue X3-100238

  If (VALEUR > 0)
    mkstat = 0
    WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).VCRLIN = VALEUR      # ISSUE X3-94378
    # populate fields using document line
    Case [M:NCSH1]DOCTYP(nolign-1)

      When 1 : # populate fields form purchase receipt line
               # Issue X3-97893 - 2018-09-15 by JUSYN : not stock managed products
               # Issue X3-100229 - 2018-09-04 by JUSYN : Allow selection from purchase receipts header and detail; display product and its version
               Local File PRECEIPTD [PTD]
               Read [F:PTD]PTD0=[M:NCSH1]VCRNUM(nolign-1);VALEUR
               If (fstat = 0)
                 Read [F:ITM]ITM0=[F:PTD]ITMREF
                 If [F:ITM]STOMGTCOD <> 1  # stock managed
                   If WECCFLG > 0
                     Local File STOJOU [STJ]
                     Filter [STJ] Where STOFCY = [F:PTD]PRHFCY
&                                     & VCRTYP = 6
&                                     & VCRNUM = [F:PTD]PTHNUM
&                                     & VCRLIN = [F:PTD]PTDLIN
&                                     & REGFLG = 1
                     Read [STJ] First
                     If (fstat = 0)
                       WECCVALMAJ = [F:STJ]ECCVALMAJ
                       WECCVALMIN = [F:STJ]ECCVALMIN
                     Endif
                     LogicClose File [STJ]
                   Endif
                 Endif
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).DOCQTY = [F:PTD]QTYSTU     # ISSUE X3-94378 CCMNCSDOC to NCSDOCHDR
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSQTY = [F:PTD]QTYSTU
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).STU    = [F:PTD]STU        # Issue X3-104585
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).PJT    = [F:PTD]PJT
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).ITMREF = [F:PTD]ITMREF
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).ECCVALMAJ = WECCVALMAJ
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).ECCVALMIN = WECCVALMIN
               Endif
               LogicClose File [PTD]
               # End issue X3-100229
               # End issue X3-97893
      When 2 : # populate fields form customer return line
               # Issue X3-97893 - 2018-09-15 by JUSYN : not stock managed products
               # Issue X3-88164 - 2018-08-30 by JUSYN : Allow selection from customer returns header and detail; display product and its version
               Local File SRETURND [SRD]
               Read [F:SRD]SRD0=[M:NCSH1]VCRNUM(nolign-1);VALEUR
               If (fstat = 0)
                 Read [F:ITM]ITM0=[F:SRD]ITMREF
                 If [F:ITM]STOMGTCOD <> 1  # stock managed
                   If WECCFLG > 0
                     Local File STOJOU [STJ]
                     Filter [STJ] Where STOFCY = [F:SRD]STOFCY
&                                     & VCRTYP = 13
&                                     & VCRNUM = [F:SRD]SRHNUM
&                                     & VCRLIN = [F:SRD]SRDLIN
                     Read [STJ] First
                     If (fstat = 0)
                       WECCVALMAJ = [F:STJ]ECCVALMAJ
                       WECCVALMIN = [F:STJ]ECCVALMIN
                     Endif
                     LogicClose File [STJ]
                   Endif
                 Endif
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).DOCQTY = [F:SRD]QTYSTU     # ISSUE X3-94378 CCMNCSDOC to NCSDOCHDR
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSQTY = [F:SRD]QTYSTU
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).STU    = [F:SRD]STU        # Issue X3-104585
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).PJT    = [F:SRD]PJT
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).ITMREF = [F:SRD]ITMREF
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).ECCVALMAJ = WECCVALMAJ
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).ECCVALMIN = WECCVALMIN
               Endif
               LogicClose File [SRD]
               # End issue X3-88164
               # End issue X3-97893
      When 3 : # populate fields form production tracking line
               # Issue X3-97893 - 2018-09-15 by JUSYN : not stock managed products
               # Issue X3-100238 - 2018-08-14 by JUSYN : Allow selection from tracking header and detail; display product
               Local File MFGITMTRK [MKI]
               Read [F:MKI]MKI0=[M:NCSH1]VCRNUM(nolign-1);VALEUR
               If (fstat = 0)
                 Read [F:ITM]ITM0=[F:MKI]ITMREF
                 If [F:ITM]STOMGTCOD <> 1  # stock managed
                   If WECCFLG > 0
                     Local File STOJOU [STJ]
                     Filter [STJ] Where STOFCY = [F:MKI]MFGFCY
&                                     & VCRTYP = 15
&                                     & VCRNUM = [F:MKI]MFGTRKNUM
&                                     & VCRLIN = [F:MKI]ITMTRKLIN
                     Read [STJ] First
                     If (fstat = 0)
                       WECCVALMAJ = [F:STJ]ECCVALMAJ
                       WECCVALMIN = [F:STJ]ECCVALMIN
                     Endif
                     LogicClose File [STJ]
                   Endif
                 Endif
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).DOCQTY = [MKI]CPLQTY     # ISSUE X3-94378 CCMNCSDOC to NCSDOCHDR
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSQTY = [MKI]CPLQTY
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).STU    = [MKI]STU        # Issue X3-104585
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).PJT    = [MKI]PJT
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).ITMREF = [MKI]ITMREF
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).ECCVALMAJ = WECCVALMAJ
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).ECCVALMIN = WECCVALMIN
               Endif
               LogicClose File [MKI]
               # End issue X3-100238
               # End issue X3-97893
      When 4 : # populate fields form quailty control line
               Local File STOQLYD [QLD]
               Read [F:QLD]QLD0=28;[M:NCSH1]VCRNUM(nolign-1);VALEUR
               If (fstat = 0)
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).DOCQTY = [F:QLD]QTYSTU    # ISSUE X3-94378 CCMNCSDOC to NCSDOCHDR
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSQTY = [F:QLD]QTYSTU
                 WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).PJT = ""
               Endif
               LogicClose File [QLD]

    Endcase
# Issue X3-100238 - 2018-08-20 by JUSYN : reset values because of e.g. document number change
  Else
    Case [M:NCSH1]DOCTYP(nolign-1)
      When 1,2,3 : # reset fields from production tracking line, customer returns line # Issue X3-88164 - 2018-08-30 by JUSYN : Customer returns
                 # Issue X3-100229 - 2018-09-04 by JUSYN : Purchase receipt
               WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).DOCQTY = 0
               WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSQTY = 0
               WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).STU = ""       # X3-104585
               WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).PJT = ""
               WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).ITMREF = ""
               If dim([M:NCSH1]ECCVALMAJ) > 0
                   WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).ECCVALMAJ = ""
                   WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).ECCVALMIN = ""
               Endif
    Endcase
  Endif

  Call SHOW_DOCUMENTS([M:NCSH1]DOCLIN(nolign-1)) From SUBNCSHA
  Affzo [M:NCSH1]1-99

  MY_STATUS = fmet WNCSRECENT.CREATE_DOCUMENT_LINES ([M:NCSH1]DOCLIN(nolign-1), MESSAGE)
  If (MY_STATUS = CST_AFALSE)
    GMESSAGE = MESSAGE
    mkstat = 2
  Endif
# End issue X3-100238
End

# Issue X3-78905 - end

######################################################################################
# Issue X3-88163 - 2018-05-29 by JUSYN : Read document's stock lines and fill class for document lines
$DOCLINES_READ_N_FILL
Local Integer ASTATUS
Local Integer INDEX, NI
Local Char    WSERNUM(GLONSER)
If clalev([F:STS])=0  Local File STOSER     [STS]   Endif

# Issue X3-88163 - Delete ANY EXISTING LINES
If maxtab(WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN) > 0     # ISSUE X3-94378 CCMNCSDOC to NCSDOCHDR
    For NI = maxtab(WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN) To 1 Step -1
        [L]ASTATUS = fmet WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).ADELLINE("NCSDOCLIN",NI)
        If [L]ASTATUS >= [V]CST_AERROR Then
            GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
            GOK = 0
            GERR = 1
            Break
        Endif
    Next NI
Endif
If GERR = 1 Then
    End
Endif
# Issue X3-88163 - end

Case [M:NCSH1]DOCTYP(nolign-1)

    When 1 : # purchase receipt line
             Local File STOJOU [STJ]
             For [STJ]STJ1 Where STOFCY=[M:NCSH0]SITE & VCRTYP=6 & VCRNUM=[M:NCSH1]VCRNUM(nolign-1) & VCRLIN=[M:NCSH1]VCRLIN(nolign-1) & REGFLG=1
                 If [F:STJ]SERDEB <> "" & [F:STJ]SERFIN <> ""
                     Gosub SEPERATE_SERNUM_DOCLINES
                 Else
                     WSERNUM = [F:STJ]SERNUM
                     Gosub ADD_NCSDOCLIN
                 Endif
             Next
             LogicClose File [STJ]

    When 2 : # customer return line
             Local File STOJOU [STJ]
             For [STJ]STJ1 Where STOFCY=[M:NCSH0]SITE & VCRTYP=13 & VCRNUM=[M:NCSH1]VCRNUM(nolign-1) & VCRLIN=[M:NCSH1]VCRLIN(nolign-1) & REGFLG=1
                 If [F:STJ]SERDEB <> "" & [F:STJ]SERFIN <> ""
                     Gosub SEPERATE_SERNUM_DOCLINES
                 Else
                     WSERNUM = [F:STJ]SERNUM
                     Gosub ADD_NCSDOCLIN
                 Endif
             Next
             LogicClose File [STJ]

    When 3 : # production tracking line
             Local File STOJOU [STJ]
             For [STJ]STJ1 Where STOFCY=[M:NCSH0]SITE & VCRTYP=15 & VCRNUM=[M:NCSH1]VCRNUM(nolign-1) & VCRLIN=[M:NCSH1]VCRLIN(nolign-1) & REGFLG=1
                 If [F:STJ]SERDEB <> "" & [F:STJ]SERFIN <> ""
                     Gosub SEPERATE_SERNUM_DOCLINES
                 Else
                     WSERNUM = [F:STJ]SERNUM
                     Gosub ADD_NCSDOCLIN
                 Endif
             Next
             LogicClose File [STJ]

    When 4 : # quality control line
             Local File STOQLYD [QLD]
             For [QLD]QLD0 Where VCRNUM = [M:NCSH1]VCRNUM(nolign-1) and VCRLIN = [M:NCSH1]VCRLIN(nolign-1)
                 INDEX = fmet WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).ADDLINE("NCSDOCLIN", [V]CST_ALASTPOS) # ISSUE X3-94378 CCMNCSDOC to NCSDOCHDR
                 If INDEX <> [V]CST_ANOTDEFINED Then
                     # Issue X3-94378 - 2018-06-05 by JUSYN : CRID to NCSID
                     WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).NCSID = WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSID
                     # End issue X3-94378
                     WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).DOCLIN = WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).DOCLIN
                     WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).SUBLIN = [F:QLD]VCRLIN
                     WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).SELLIN = 2
                     WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).DOCQTY = [F:QLD]QTYSTU
                     WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).NCSQTY = [F:QLD]QTYSTU
                     WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).BPSLOT = ''
                     WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).LOT    = [F:QLD]LOT
                     WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).SLO    = [F:QLD]SLO   # Issue X3-104585
                     WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).SERNUM = [F:QLD]SERNUM
                 Else
                     GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
                     GERR = 4
                     mkstat = 2
                     GOK = 1
                     LogicClose File [QLD]
                     Return
                 Endif
             Next
             LogicClose File [QLD]
Endcase

LogicClose File [STS]
Return

$SEPERATE_SERNUM_DOCLINES
Local Integer J, WRET
Local Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)

# 1st serial number
WSERNUM = [F:STJ]SERDEB
Gosub ADD_NCSDOCLIN

# 2nd serial number to end serial number
WNUMDEB = [F:STJ]SERDEB
For J=1 To [F:STJ]QTYSTU - 1     # Issue X3-92124 - 2018-06-26 by JUSYN : wrong counter used before. Quantity in stock record needed.
   Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
   If WRET=0
      Read [STS]STS0=[F:STJ]ITMREF;WNUMFIN
      If fstat
         mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(43,196,1) : Break    # Non-existent Serial Number
      Else
         WSERNUM = WNUMFIN
         Gosub ADD_NCSDOCLIN
         WNUMDEB = WNUMFIN
      Endif
   Else
      mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1) : Break
   Endif
Next J

Return

$ADD_NCSDOCLIN

INDEX = fmet WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).ADDLINE("NCSDOCLIN", [V]CST_ALASTPOS) # ISSUE X3-94378 CCMNCSDOC to NCSDOCHDR
If INDEX <> [V]CST_ANOTDEFINED Then
    # Issue X3-94378 - 2018-06-05 by JUSYN : CRID to NCSID
    WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).NCSID = WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSID
    # End issue X3-94378
    WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).DOCLIN = WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).DOCLIN
    WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).SUBLIN = INDEX
    WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).SELLIN = 2
    If [F:STJ]SERFIN <> ""
        WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).DOCQTY = 1             # SERNUM separated - one record per serial number
        WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).NCSQTY = 1
    Else
        WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).DOCQTY = [F:STJ]QTYSTU
        WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).NCSQTY = [F:STJ]QTYSTU
    Endif
    WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).BPSLOT = [F:STJ]BPSLOT
    WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).LOT    = [F:STJ]LOT
    WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).SLO    = [F:STJ]SLO  # Issue X3-104585
    WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSDOCLIN(INDEX).SERNUM = WSERNUM
Else
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
    GERR = 4
    mkstat = 2
    GOK = 1
    Return
Endif

Return
# End issue X3-88163
