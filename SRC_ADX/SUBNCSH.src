  If GERR = 1 Then
      WNCSRECENT.NCSAPPROVER([M:NCSH2]APPRLN(nolign-1)).APPRSTAT = WNCSRECENT.NCSAPPROVER([M:NCSH2]APPRLN(nolign-1)).snapshot.APPRSTAT
      GERR = 1
