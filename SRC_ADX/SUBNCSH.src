# Issue X3-62810 - insert/delete approver lines

Subprog C_NBLIG2
Local Integer INDEX
Local Integer NI

# if not QA manager, do not allow insert line or delete line
If (WNCSRECENT.NCSMANAGER <> GUSER)
  If (status = 82 or status = 73 or status = 65)
    If (status = 65)
      GMESSAGE = mess(184,193,1)
    Endif
    mkstat = 2
    End
  Endif
Endif

If (status = 82 or status = 73) Then
    # Insert line
    If [M:NCSH2]NCSAPPUSR(nolign-1) = AVOID.ACHAR Then
        INDEX = fmet WNCSRECENT.ADDLINE("NCSAPPROVER", [V]CST_ALASTPOS)
        If INDEX <> [V]CST_ANOTDEFINED Then
            Call SHOW_APPROVER_USER(INDEX) From SUBNCSHA
        Else
            GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
            GERR = 4
            mkstat = 2
            GOK = 1
            End
        Endif
        Affzo [M:NCSH2]10   # Issue X3-110459
    Endif
Elsif status = 65 Then

    # Delete a line
    IRET = fmet WNCSRECENT.ADELLINE("NCSAPPROVER", WNCSRECENT.NCSAPPROVER([M:NCSH2]APPRLN(nolign-1)).AORDER)     # Issue X3-94378 - 2018-06-05 by JUSYN : data base structure changes CCMCRORIGC TO
# NCSBPCCOL
    If IRET = [V]CST_ANOTDEFINED Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
        GOK = 0
        GERR = 1
        mkstat = 2
    Endif
Endif

End

