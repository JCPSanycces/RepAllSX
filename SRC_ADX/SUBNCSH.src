######################################################################################
Subprog AS_NCSCATEGORY(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
GMENLOC(1) = 1
End

######################################################################################

######################################################################################
## Section automatically added (screen NCSH0) 19.03.2018 13:53:32 (ALSHE)
# Issue X3-82146 - 2018-03-19 by ALSHE : add control for customer/supplier category
######################################################################################
Subprog AM_NCSCATEGORY(VALEUR)
Variable Integer VALEUR

Case VALEUR
    When 2 # Customer - disable supplier field
        Effzo [M:NCSH0]NCSBPS
        Grizo [M:NCSH0]NCSBPS
        Actzo [M:NCSH0]NCSBPC
    When 3 # Supplier - disable customer field
        Effzo [M:NCSH0]NCSBPC
        Grizo [M:NCSH0]NCSBPC
        Actzo [M:NCSH0]NCSBPS
    When Default # internal/external - enable customer and supplier field
        If [M:NCSH0]NCSBPS = ""
            Actzo [M:NCSH0]NCSBPC
        Endif
        If [M:NCSH0]NCSBPC = ""
            Actzo [M:NCSH0]NCSBPS
        Endif
Endcase
End
# End issue X3-82146

######################################################################################
# Issue X3-79366 - control on customer and supplier fields
######################################################################################

Subprog AS_NCSBPC(VALEUR)
Variable Char    VALEUR()
# allow either customer or supplier to be entered
# Issue X3-82146 - 2018-03-19 by ALSHE : add control for customer/supplier category
# Issue X3-94378 - 2018-06-05 by JUSYN : CRSTATUS to NCSSTA
If ([M:NCSH0]NCSSTA = 1 and [M:NCSH0]NCSBPS = "" and [M:NCSH0]NCSCATEGORY <> 3)
# End issue X3-94378
  Actzo [M:NCSH0]NCSBPC
Else
  Grizo [M:NCSH0]NCSBPC
Endif

End

Subprog AM_NCSBPC(VALEUR)
Variable Char    VALEUR()

Local Integer NI, WFOUND, INDEX  # X3-83486

# Issue X3-82146 - 2018-03-19 by ALSHE : add control for customer/supplier category
If (VALEUR  = "" and [M:NCSH0]NCSCATEGORY <> 2)
    Actzo [M:NCSH0]NCSBPS
Else
    Grizo [M:NCSH0]NCSBPS
Endif

# X3-83486 - set customer details on Customers grid line if new/changed customer

WFOUND = 0
If (VALEUR <> "")
  # check if contact already added
  For NI=0 To [M:NCSH3]NBLIG6-1 Step 1
    If [M:NCSH3]BPCNUM(NI) = VALEUR
      WFOUND = 1
      Break
    Endif
  Next

  # if contact not already added, then add customer contact line
  If (WFOUND = 0)
    INDEX = fmet WNCSRECENT.ADDLINE("NCSBPCCOL", [V]CST_ALASTPOS)
    If INDEX = [V]CST_ANOTDEFINED Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
        GERR = 4
        mkstat = 2
        GOK = 1
        End
    Endif

    nolign = [M:NCSH3]NBLIG6 + 1
    WNCSRECENT.NCSBPCCOL(INDEX).BPCNUM = VALEUR
    Call SHOW_ORIGIN_CUSTOMER(INDEX, 1) From SUBNCSHA
    SetInstance WNCSRECENT.NCSBPCCOL(INDEX) With [M:NCSH3]10
    [M:NCSH3]NBLIG6 = nolign
    Affzo [M:NCSH3]10
  Endif
Endif
# X3-83486 - end

End


Subprog AS_NCSBPS(VALEUR)
Variable Char    VALEUR()
# allow either customer or supplier to be entered
# Issue X3-82146 - 2018-03-19 by ALSHE : add control for customer/supplier category
# Issue X3-94378 - 2018-06-05 by JUSYN : CRSTATUS to NCSSTA
If ([M:NCSH0]NCSSTA = 1 and [M:NCSH0]NCSBPC = "" and [M:NCSH0]NCSCATEGORY <> 2)
  # End issue X3-94378
  Actzo [M:NCSH0]NCSBPS
Else
  Grizo [M:NCSH0]NCSBPS
Endif

End

Subprog AM_NCSBPS(VALEUR)
Variable Char    VALEUR()

Local Integer NI, WFOUND, INDEX  # X3-83486

# Issue X3-82146 - 2018-03-19 by ALSHE : add control for customer/supplier category
If (VALEUR  = "" and [M:NCSH0]NCSCATEGORY <> 3)
    Actzo [M:NCSH0]NCSBPC
Else
    Grizo [M:NCSH0]NCSBPC
Endif

# X3-83486 - set customer details on Customers grid line if new/changed customer

WFOUND = 0
If (VALEUR <> "")
  # check if contact already added
  For NI=0 To [M:NCSH3]NBLIG5-1 Step 1
    If [M:NCSH3]BPSNUM(NI) = VALEUR
      WFOUND = 1
      Break
    Endif
  Next

  # if contact not already added, then add customer contact line
  If (WFOUND = 0)
    INDEX = fmet WNCSRECENT.ADDLINE("NCSBPSCOL", [V]CST_ALASTPOS)
    If INDEX = [V]CST_ANOTDEFINED Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
        GERR = 4
        mkstat = 2
        GOK = 1
        End
    Endif

    nolign = [M:NCSH3]NBLIG5 + 1
    # set customer code/name, and default contact
    WNCSRECENT.NCSBPSCOL(INDEX).BPSNUM = VALEUR
    Call SHOW_ORIGIN_SUPPLIER(INDEX,1) From SUBNCSHA
    SetInstance WNCSRECENT.NCSBPSCOL(INDEX) With [M:NCSH3]5
    [M:NCSH3]NBLIG5 = nolign
    Affzo [M:NCSH3]5
  Endif
Endif
# X3-83486 - end

End

# End issue X3-79366
