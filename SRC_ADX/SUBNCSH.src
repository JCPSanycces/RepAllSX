        If INDEX <> [V]CST_ANOTDEFINED Then
            Call SHOW_ORIGIN_USER(INDEX) From SUBNCSHA
        Else
            GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
            GERR = 4
            mkstat = 2
            GOK = 1
            End
        Endif
        Affzo [M:NCSH3]15
    Endif
Elsif status = 65 Then
    # Delete a line
    IRET = fmet WNCSRECENT.ADELLINE("NCSINTUSR", WNCSRECENT.NCSINTUSR([M:NCSH3]ORIGILN(nolign-1)).AORDER)     # Issue X3-94378 - 2018-06-05 by JUSYN : data base structure changes CCMCRORIGI TO
# NCSINTUSR
    If IRET = [V]CST_ANOTDEFINED Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
        GOK = 0
        GERR = 1
        mkstat = 2
    Endif
Endif

End

