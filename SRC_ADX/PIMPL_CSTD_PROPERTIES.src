#######################################################################################
# Classe PIMPL
#######################################################################################
#######################################################################################
# PROPERTIES                                                                          #
#######################################################################################
#######################################################################################
$FCY
  Case [L]ARULE
    When "PROPAGATE" : Gosub FCY_PROPAGATE
  Endcase
Return

$FCY_PROPAGATE
  this.CPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY, "LEGCPY")
  this.FINRSPFCY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY, "FINRSPFCY")
Return

#######################################################################################
$PIMSTA
  Case [L]ARULE
    When "INIT"      : Gosub PIMSTA_INIT
  Endcase
Return

$PIMSTA_INIT
  this.PIMSTA = [V]CST_ANO
Return

#######################################################################################
$OPPNUM
  Case [L]ARULE
    When "CONTROL"   : Gosub OPPNUM_CONTROL
  Endcase
Return

$OPPNUM_CONTROL
  If this.ASTALIN = [V]CST_AUPD Then
    If this.OPPNUM <> this.snapshot.OPPNUM Then
      [L]ASTATUS = fmet this.SETERROR("OPPNUM", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
Return

#######################################################################################
$CPY
  Case [L]ARULE
    When "CONTROL"   : Gosub CPY_CONTROL
  Endcase
Return

$CPY_CONTROL
  If this.ASTALIN = [V]CST_AUPD Then
    If this.CPY <> this.snapshot.CPY Then
      [L]ASTATUS = fmet this.SETERROR("CPY", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
Return

#######################################################################################
$PBUCOD
  Case [L]ARULE
    When "CONTROL"   : Gosub PBUCOD_CONTROL
  Endcase
Return

$PBUCOD_CONTROL
#  If this.ASTALIN = [V]CST_AUPD Then
#    If this.PBUCOD <> this.snapshot.PBUCOD Then
#      [L]ASTATUS = fmet this.SETERROR("PBUCOD", mess(18,9804,1), [V]CST_AERROR)
#    Endif
#  Endif
Return

#######################################################################################
$TASCOD
  Case [L]ARULE
    When "CONTROL"   : Gosub TASCOD_CONTROL
  Endcase
Return

$TASCOD_CONTROL
  If this.ASTALIN = [V]CST_AUPD Then
    If this.TASCOD <> this.snapshot.TASCOD Then
      [L]ASTATUS = fmet this.SETERROR("TASCOD", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
Return

#######################################################################################
$FINRSPFCY
  Case [L]ARULE
    When "CONTROL"   : Gosub FINRSPFCY_CONTROL
  Endcase
Return

$FINRSPFCY_CONTROL
  If this.ASTALIN = [V]CST_AUPD Then
    If this.FINRSPFCY <> this.snapshot.FINRSPFCY Then
      [L]ASTATUS = fmet this.SETERROR("FINRSPFCY", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
Return

