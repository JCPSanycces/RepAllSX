#<AdxTL>@(#)0.0.0.0 $Revision$
#- This selection is a bespoke one. We are going to construct the selection, without using an object
#-
$ACTION
   Case ACTION
      When "SEL_TABLE"
         Gosub SEL_TABLE_ITEM
      When "SEL_LISTE"
         Gosub SEL_LISTE_PO
   Endcase
Return
#############################################################################

$SEL_LISTE_PO
   Local Shortint I
   Local Shortint COLNO
   Local Char PREVKEY(20)
   Local Date PREVDAT
   Local Char PPOHNUM(20)
   Local Char PITMREF(20)
   Local Char PGXAFCY(20)
   Local Date PRECDAT


# The 1..x is to specify the number of fields in the lookup
   Local Char TEXTE(GLONDES)(1..2000,1..5)

#- Open the required tables
   If clalev([F:POH]) = 0 : Local File PORDER     [POH] : Endif
   If clalev([F:POQ]) = 0 : Local File PORDERQ    [POQ] : Endif

   PPOHNUM = PARAM(1)
   PITMREF = PARAM(2)
   PGXAFCY = PARAM(3)
   PRECDAT = gdat$(PARAM(4))

#X3-60320.o   TIT(0) =mess(36,198,1)
   TIT(0) = mess(90,10709,1)          #X3-60320.n

   Call TEXTFIC("PORDERQ", "POHNUM", 1, TIT(1)) From OBJDIV
   Call TEXTFIC("PORDERQ", "EXTRCPDAT", 1, TIT(2)) From OBJDIV
   Call TEXTFIC("PORDERQ", "POHFCY", 1, TIT(3)) From OBJDIV
   Call TEXTFIC("PORDERQ", "BPSNUM", 1, TIT(4)) From OBJDIV
   Call TEXTFIC("PORDER", "ORDREF", 1, TIT(5)) From OBJDIV

   Link [F:POQ] With [F:POH]POH0~=[F:POQ]POHNUM
&                 As [ORDS]
&              Where (PITMREF = "" or (PITMREF <> "" and [F:POQ]ITMREF = PITMREF))
&                and (PRECDAT = [0/0/0] or (PRECDAT <> [0/0/0] and [F:POQ]EXTRCPDAT <= PRECDAT))
&                and [F:POH]APPFLG > 2
&                and [F:POQ]PRHFCY = PGXAFCY
&                and [F:POQ]WIPSTA < 2
&                and [F:POQ]ORI <> 2
&                and [F:POQ]LINTYP < 3
&                and [F:POQ]LINSTA <> 3
&                and [F:POQ]LINCLEFLG = 1
&                and (([F:POQ]QTYPUU > [F:POQ]RCPQTYPUU) or ([F:POQ]QTYSTU > [F:POQ]RCPQTYSTU))
&           Order By [F:POH]POHNUM; [F:POQ]EXTRCPDAT; [F:POQ]ITMREF

   I=1
   NBTEX=0
   PREVKEY=""
   PREVDAT = [0/0/0]

   For [ORDS]
      If PREVKEY <> [F:POQ]POHNUM or PREVDAT <> [F:POQ]EXTRCPDAT
         NBTEX=I
         COLNO = 0

         COLNO += 1
         TEXTE(I,COLNO) = [F:POQ]POHNUM
         TEX(I) = TEXTE(I,COLNO)

         COLNO += 1
         TEXTE(I,COLNO) = format$("DD2",[F:POQ]EXTRCPDAT)

         COLNO += 1
         TEXTE(I,COLNO) = [F:POQ]POHFCY

         COLNO += 1
         TEXTE(I,COLNO)= [F:POQ]BPSNUM

         COLNO += 1
         TEXTE(I,COLNO)= [F:POH]ORDREF

         I=I+1
         PREVKEY = [F:POQ]POHNUM
         PREVDAT = [F:POQ]EXTRCPDAT

         If I > dim(TEXTE)
            Break
          Endif
      Endif
   Next

   If NBTEX=0
#x3-60320.O      GERR=1 : GMESSAGE = mess(104,199,1)
      GERR=2 : GMESSAGE = mess(104,199,1)            #X3-60320.n
   Endif

   If clalev([F:POH]) : Close Local File [POH] : Endif
   If clalev([F:POQ]) : Close Local File [POQ] : Endif
Return

##################################################################

$SEL_TABLE_ITEM
   Local Shortint I
   Local Shortint COLNO
   Local Char PREVKEY(20)
   Local Char PPOHNUM(20)
   Local Char PITMREF(20)
   Local Char PGXAFCY(20)
   Local Date PRECDAT

#- Open the required tables
   If clalev([F:POH]) = 0 : Local File PORDER     [POH] : Endif
   If clalev([F:POQ]) = 0 : Local File PORDERQ    [POQ] : Endif
   If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
   If clalev([F:AXX]) = 0 : Local File ATEXTRA    [AXX] : Endif

   PPOHNUM = PARAM(1)
   PITMREF = PARAM(2)
   PGXAFCY = PARAM(3)
   PRECDAT = gdat$(PARAM(4))

#X3-60309.o   TIT(0) =mess(36,198,1)
   TIT(0) = mess(56,2324,1)           #X3-60309.n
   NBCOL =0
   NBCOL += 1 : COL(NBCOL) = "ITMREF"    : CODFIC = "PORDERQ"   : Gosub TEXTE

   NBCOL += 1 : COL(NBCOL) = "string$(1,[F:AXX]TEXTE)+string$(len([F:AXX]TEXTE)=0,[F:ITM]ITMDES1)"
   Call TEXTFIC("ITMMASTER","DES1AXX",2,TIT(NBCOL)) From OBJDIV
   COLTYP(NBCOL) = 30

   NBCOL += 1 : COL(NBCOL) = "POHNUM"    : CODFIC = "PORDERQ"   : Gosub TEXTE
   NBCOL += 1 : COL(NBCOL) = "POPLIN"    : CODFIC = "PORDERQ"   : Gosub TEXTE
   NBCOL += 1 : COL(NBCOL) = "EXTRCPDAT"  : CODFIC = "PORDERQ"   : Gosub TEXTE
   NBCOL += 1 : COL(NBCOL) = "BPSNUM"    : CODFIC = "PORDERQ"   : Gosub TEXTE
   NBCOL += 1 : COL(NBCOL) = "(QTYPUU - RCPQTYPUU)"
   TIT(NBCOL) = mess(46,7750,1)

   CRITERE(1)="1=1"
   START  = "ITMREF"
   ORDRE  = "ITMREF"
   OBJET  = ""

   Link [F:POQ] With [F:POH]POH0=[F:POQ]POHNUM,
&       [F:ITM]ITM0 = [F:POQ]ITMREF,
&       [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;[F:ITM]ITMREF;""
&                 As [LNK]
&              Where (PPOHNUM = "" or (PPOHNUM <> "" and [F:POQ]POHNUM = PPOHNUM))
&                and (PRECDAT = [0/0/0] or (PRECDAT <> [0/0/0] and [F:POQ]EXTRCPDAT <= PRECDAT))
&                and [F:POH]APPFLG > 2
&                and [F:POQ]PRHFCY = PGXAFCY
&                and [F:POQ]WIPSTA < 2
&                and [F:POQ]ORI <> 2
&                and [F:POQ]LINTYP < 3
&                and [F:POQ]LINSTA <> 3
&                and [F:POQ]LINCLEFLG = 1
&                and (([F:POQ]QTYPUU > [F:POQ]RCPQTYPUU) or ([F:POQ]QTYSTU > [F:POQ]RCPQTYSTU))
&           Order By [F:POQ]ITMREF

   Default File [LNK]
Return

##################################################################

$TEXTE
   Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

