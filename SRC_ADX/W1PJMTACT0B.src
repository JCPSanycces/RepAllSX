#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTACT0B 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:55"
A_USER  = "DOC"
A_STAMP = "20181109230555"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMTACT0B [PJTAC0B]
Gosub HORODAT
Local Inpbox "PJMTACT0B" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJTAC0B] As [SIM_]
Grizo [PJTAC0B]30
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJTAC0B]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=86 : Y1(0)=1 : Y2(0)=20
Return

$ON_EXTQTY
Onevent BEFORE_AREA Gosub AV_EXTQTY From W1PJMTACT0B
Onevent AFTER_CHANGE Gosub AMM_EXTQTY From W1PJMTACT0B
Onevent CONTROL Call C_EXTQTY(zc) From W1PJMTACT0B
Return

$AV_EXTQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find([M:PJTAC0B]OPEUOM,GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]EXTQTY(indice) With "N+z:"+GUNTFMT
Gosub _AFF
Return

Subprog C_EXTQTY(VALEUR)
Variable Decimal VALEUR
Gosub _AFF
End

$AMM_EXTQTY
Call AM_EXTQTY(zc)
If !mkstat & GOBJET
 zoncou = "EXTQTY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_EXTQTY(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_EXTQTY(VALEUR) From SUBPJTAC
If mkstat : GERR = 1 : GZONE = "EXTQTY" : GZNUM = 32576 : Endif
Gosub _AFF
End

$ON_RMNQTY
Onevent BEFORE_AREA Gosub AV_RMNQTY From W1PJMTACT0B
Onevent AFTER_CHANGE Gosub AMM_RMNQTY From W1PJMTACT0B
Onevent CONTROL Call C_RMNQTY(zc) From W1PJMTACT0B
Return

$AV_RMNQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find([M:PJTAC0B]OPEUOM,GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]RMNQTY(indice) With "N+z:"+GUNTFMT
Gosub _AFF
Return

Subprog C_RMNQTY(VALEUR)
Variable Decimal VALEUR
Gosub _AFF
End

$AMM_RMNQTY
Call AM_RMNQTY(zc)
If !mkstat & GOBJET
 zoncou = "RMNQTY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_RMNQTY(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_RMNQTY(VALEUR) From SUBPJTAC
If mkstat : GERR = 1 : GZONE = "RMNQTY" : GZNUM = 42118 : Endif
Gosub _AFF
End

$ON_CSMQTY
Onevent BEFORE_AREA Gosub AV_CSMQTY From W1PJMTACT0B
Return

$AV_CSMQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find([M:PJTAC0B]OPEUOM2,GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]CSMQTY(indice) With "NPz:"+GUNTFMT
Gosub _AFF
Return

$ON_OPEUOM2
Onevent AFTER_CHANGE Gosub AMM_OPEUOM2 From W1PJMTACT0B
Onevent CONTROL Call C_OPEUOM2(zc) From W1PJMTACT0B
Onevent BEFORE_INPUT Call AS_OPEUOM2(zc) From W1PJMTACT0B
Return

Subprog AS_OPEUOM2(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3612,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_OPEUOM2(zc) From W1PJMTACT0B
Onkey   2 Titled GBOUTS Call S_OPEUOM2(zc) From W1PJMTACT0B
Onkey 144 Titled GBOUTP Call P_OPEUOM2(zc) From W1PJMTACT0B
Onkey 146 Titled GBOUTA Call SA_OPEUOM2(zc) From W1PJMTACT0B
Gosub _AFF
End

Subprog C_OPEUOM2(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "OPEUOM2" : GZNUM = 2685 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("TUN","B",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "OPEUOM2" : GZNUM = 2685 : Endif
Endif
Gosub _AFF
End

$AMM_OPEUOM2
Call AM_OPEUOM2(zc)
If !mkstat & GOBJET
 zoncou = "OPEUOM2" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_OPEUOM2(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_OPEUOM2(VALEUR) From SUBPJTAC
If mkstat : GERR = 1 : GZONE = "OPEUOM2" : GZNUM = 2685 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZOPEUOM2)")>indice
 [M]OPEUOM2(indice) = VALEUR
 Affzo ZOPEUOM2(indice)
Endif
Gosub _AFF
End

Subprog S_OPEUOM2(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TUN"
PARMSK(2) = "B"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_OPEUOM2(VALEUR)
Variable Char    VALEUR()
Call OBJET("TUN",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_OPEUOM2(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TUN"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_OPEUOM2(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TUN",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZOPEUOM2
Onevent BEFORE_AREA Gosub AV_ZOPEUOM2 From W1PJMTACT0B
Return

$AV_ZOPEUOM2
Call LECTEXTRA(zc,"TABUNIT","DES",num$([M]OPEUOM2(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_OPECST
Onevent BEFORE_AREA Gosub AV_OPECST From W1PJMTACT0B
Return

$AV_OPECST
## Action INIDEV
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PJTAC0B]CUR,GDEVISE(1..GNBDEV)),1))
Chgfmt [M]OPECST(indice) With "NPz3:"+GDEVFMT
Gosub _AFF
Return

$ON_OPECST2
Onevent BEFORE_AREA Gosub AV_OPECST2 From W1PJMTACT0B
Return

$AV_OPECST2
## Action INIDEV
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PJTAC0B]CUR,GDEVISE(1..GNBDEV)),1))
Chgfmt [M]OPECST2(indice) With "NPz3:"+GDEVFMT
Gosub _AFF
Return

$ON_CUR
Return

$ON_OPEUOM
Return

$CHG_STY
Return


