#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################################################
# Programme généraux pour la synchronisation avec Outlook
# INITVAR      : Initialisation des variables propre à tous les traitements
# INITCFG      : Initialisation des variables de la configuration
# RAZPARAMDYN  : Initialisation des tableaux de paramètres(mise à vide)
# CONTEXT      : gestion du contexte de la synchronisation (AddIn)
##########################################################################################################
# Initialisation des variables propre à tous les traitements
$INITVAR
# Prefixe var Miscellaneous M_
# Prefixe statiques Miscellaneous MC_
Local Char MC_OK(GLONDES)                        : MC_OK = "OK"
Local Char MC_KO(GLONDES)                        : MC_KO = "KO"
Local Char MC_KO_NEXT(GLONDES)                   : MC_KO_NEXT = "KO_NEXT"
Local Char MC_ON(GLONDES)                        : MC_ON = "ON"
Local Char MC_OFF(GLONDES)                       : MC_OFF = "OFF"
Local Char MC_NOMORE(GLONDES)                    : MC_NOMORE = "NOMORE"
Local Char MC_WRN(GLONDES)                       : MC_WRN = "WRN"

Local Integer MC_ERROR                           : MC_ERROR = 2
Local Integer MC_WARNING                         : MC_WARNING = 1
Local Integer MC_TRUE                            : MC_TRUE = 1
Local Integer MC_FALSE                           : MC_FALSE = 0

# Gestion du mode de synchro pour une entité
Local Char MC_MD(GLONDES)                        :   MC_MD = "Mode"
Local Char MC_MDADX_C(GLONDES)                   :   MC_MDADX_C = "ToAdxCreate"
Local Char MC_MDADX_U(GLONDES)                   :   MC_MDADX_U = "ToAdxUpdate"
Local Char MC_MDADX_D(GLONDES)                   :   MC_MDADX_D = "ToAdxDelete"
Local Char MC_MDAPL_C(GLONDES)                   :   MC_MDAPL_C = "ToAplCreate"
Local Char MC_MDAPL_U(GLONDES)                   :   MC_MDAPL_U = "ToAplUpdate"
Local Char MC_MDAPL_D(GLONDES)                   :   MC_MDAPL_D = "ToAplDelete"

# Gestion du flag de maj
Local Char MC_UPD_CRE(GLONDES)                   : MC_UPD_CRE = "C"
Local Char MC_UPD_MOD(GLONDES)                   : MC_UPD_MOD = "M"
Local Char MC_UPD_SUP(GLONDES)                   : MC_UPD_SUP = "A"
Local Char MC_UPD_RES(GLONDES)                   : MC_UPD_RES = "R"

# Gestion type user
Local Char MC_TU_NB(GLONDES)                     : MC_TU_NB = '"olNumber"'
Local Char MC_TU_YESNO(GLONDES)                  : MC_TU_YESNO = '"olYesNo"'

#Type conflit
#Pas de conflit
Local Integer MC_NOCONFLIT                       : MC_NOCONFLIT = 0
#Conflit Outlook le plus récent
Local Integer MC_RECENTOTK                       : MC_RECENTOTK = 1
#Conflit Adonix le plus récent
Local Integer MC_RECENTADX                       : MC_RECENTADX = 2
Return

##########################################################################################################
# Initialisation des variables de la configuration
$INITCFG
Local Char CC_OLVER(GLONDES)                     : CC_OLVER = "OLVer"
Local Char CC_OLVERINT(GLONDES)                  : CC_OLVERINT = "OLVerInterne"        # "1.0" en 1er version
Local Char CC_X3VER(GLONDES)                     : CC_X3VER = "X3Ver"
Local Char CC_ADDINVER(GLONDES)                  : CC_ADDINVER= "AddinVer"
Local Char CC_ADDINNAME(GLONDES)                 : CC_ADDINNAME= "AddinName"
Local Char CC_ADDTRACE(GLONDES)                  : CC_ADDTRACE = "AdxTrace"
Local Char CC_PCDATTIM(GLONDES)                  : CC_PCDATTIM = "CurrentPcDateTime"
Return

##########################################################################################################
#Initialisation des tableaux de paramètres(mise à vide)
$RAZPARAMDYN
  Return #LSE19/12/2006 On ressort car pas besoin de faire le raz pour les paramètres

  # Paramètres caractères
  Raz TBKCHR
  Raz TBVCHR
  # Paramètres entiers
  Raz TBKINT
  Raz TBVINT
  # Paramètres décimaux
  Raz TBKDEC
  Raz TBVDEC
  # Paramètres Dates AAAAMMJJHHMMSS
  Raz TBKDATTIM
  Raz TBVDATTIM
  # Paramètres Textes riches
  Raz TBKCLOB
  Raz TBVCLOB
Return

##########################################################################################################
#Ecriture et réinitialisation des tableaux d'erreur
$WRITE_RAZ_MSG
  If dim(MSGFLG) > 0 Then
    INBMES = 1
    While INBMES < dim(MSGFLG)+1
      If MSGTXT(INBMES) <> "" Then
        If MSGFLG(INBMES) = 0 Then
          Call ECR_TRACE(MSGTXT(INBMES), 0) From GESECRAN
        Else
          Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        Endif
      Endif
      INBMES += 1
    Wend
  Endif
  INBMES = 1
  Raz MSGFLG
  Raz MSGTXT
Return

##########################################################################################################
# gestion du contexte de la synchronisation (AddIn)
Subprog CONTEXT(RET, RMTAPP, USERID , X3LAN, MSGFLG, MSGTXT, TBKCHR, TBVCHR)
# <Par Techniques>
Variable Char RET()                    # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID ()
Value Char X3LAN()
Variable Integer MSGFLG(1..)           # Niveau des messages retournés
Variable Char MSGTXT()(1..)            # Texte des messages retournés
# </PT>
Variable Char TBKCHR()(1..)            # Paramètres caractères
Variable Char TBVCHR()(1..)

#Tableaux Globaux pour alimentation des données écrans
# Issue X3-58429 - 2017-11-16 by FGR : BEGIN
#Global Char GTBKCHR(50)(1..50)         # Paramètres caractères
#Global Char GTBVCHR(50)(1..50)
Global Char GTBKCHR(250)(1..50)         # Paramètres caractères
Global Char GTBVCHR(250)(1..50)
# Issue X3-58429 - 2017-11-16 by FGR : END
Global Char GTBKINT(50)(1..50)         # Paramètres entiers
Global Integer GTBVINT(1..50)
Global Char GTBKDEC(50)(1..50)         # Paramètres décimaux
Global Decimal GTBVDEC(1..50)
Global Char GTBKDATTIM(50)(1..50)      # Paramètres Dates AAAAMMJJHHMMSS
Global Char GTBVDATTIM(50)(1..50)
Global Char GTBKCLOB(50)(1..50)        # Paramètres Textes riches
Global Clbfile GTBVCLOB(3)(1..50)

#Gestion des conflits
Global Integer GITYPECONFLIT
  GITYPECONFLIT = 0

Global Date GDTDATEMODIFOTK
Global Date GDTDATEMODIFADX
  GDTDATEMODIFOTK = [00/00/00]
  GDTDATEMODIFADX = [00/00/00]

#Gestion des données en erreur
Global Char GTBTRTFIE(20)(0..50)
Global Char GTBTRTVAL(250)(0..50)
Global Integer GNBTRT

#Gestion des Noms chrono dans Outlook
#Chrono Correspondant X3
Global Char GLIBCHRONOCOR(250)
  Raz GLIBCHRONOCOR
  GLIBCHRONOCOR = '"' + mess(606,177,1) + '"'

#Chrono tache X3
Global Char GLIBCHRONOTSK(250)
  Raz GLIBCHRONOTSK
  GLIBCHRONOTSK = '"' + mess(607,177,1) + '"'

#Chrono rendez-vous X3
Global Char GLIBCHRONOBAP(250)
  Raz GLIBCHRONOBAP
  GLIBCHRONOBAP = '"' + mess(608,177,1) + '"'

  Gosub INITVAR
  Gosub INITCFG

#Variable de travail
Local Char SZDTHMFMT(250)
  Raz SZDTHMFMT
Local Char SZMESSAGE(250)
  Raz SZMESSAGE
Local Integer IBRETOUR
  IBRETOUR = 1

  #Démarrage de la trace
  #Synchronisation outlook. Utilisateur : USERID
  Call OUVRE_TRACE (mess(224,177,1) + USERID - "(" + GUSER + ")") From LECFIC

Integer WI , WJ
  WI = find(CC_PCDATTIM,TBKCHR)
  If WI Then
    Call FMTCHARDATETIME(TBVCHR(WI), SZDTHMFMT, SZMESSAGE, IBRETOUR) From SUBSYDUTIL
    #Date et heure locale du poste client outlook:+SZDTHMFMT
    Call ECR_TRACE(mess(500,177,1) - SZDTHMFMT, 0) From GESECRAN
  Endif
  WJ = 1
  WI = find(CC_OLVER,TBKCHR)
  If WI Then
    # Outlook 2010(14.0) - 2014(15.0)
    #If (TBVCHR(WI)="14.0" | TBVCHR(WI)="15.0")                      # FGR 18/04/2016 : X3SUIVI115604 ajout de la version 16
    If (TBVCHR(WI)="14.0" | TBVCHR(WI)="15.0" | TBVCHR(WI)="16.0")   # FGR 18/04/2016 : X3SUIVI115604 ajout de la version 16
      # Synchronisation possible
      # FGR 25/08/2014 : X3SUIVI102228 (début)
      If dim(GSYNOLVERSION) < 0 Then
        Global Char GSYNOLVERSION(10)
      Endif
      GSYNOLVERSION = TBVCHR(WI)
      # FGR 25/08/2014 : X3SUIVI102228 (fin)
      Call ECR_TRACE(func AFNC.MES1(mess(677,177,1), TBVCHR(WI)), 0) From GESECRAN
      # Statut
      RET = MC_OK
    Else
      # Version OL non supportée
      MSGFLG(1) = MC_ERROR
      MSGTXT(1) = func AFNC.MES1(mess(674,177,1), TBVCHR(WI))
      MSGFLG(2) = MC_WARNING
      MSGTXT(2) = func AFNC.MES1(mess(675,177,1), TBVCHR(WI))
      RET = MC_KO
    Endif
  Else
    MSGFLG(1) = MC_ERROR
    MSGTXT(1) = mess(676,177,1)
    RET = MC_KO
  Endif
  #On indique que l'on est en mode de synchronisation
  GSYNCOUTLOOK = 1
  #Remonter le code de la trace
  WI = find("", TBKCHR)
  TBKCHR(WI) = CC_ADDTRACE
  TBVCHR(WI) = GTRACE
End

##########################################################################################################
# gestion fin synchronisation (AddIn)
Subprog ENDSYN(RET, RMTAPP, USERID , X3LAN, MSGFLG, MSGTXT, TBKCHR, TBVCHR)
# <Par Techniques>
Variable Char RET()    # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID ()
Value Char X3LAN()
Variable Integer MSGFLG(1..)# Niveau des messages retournés
Variable Char MSGTXT()(1..)# Texte des messages retournés
# </PT>
Variable Char TBKCHR()(1..)       # Paramètres caractères (pour usage futur...)
Variable Char TBVCHR()(1..)


  Gosub INITVAR
  Call FERME_TRACE From LECFIC
End

