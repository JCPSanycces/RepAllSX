#<AdxTL>@(#)0.0.0.0 $Revision$
#-----------------------PROPERTIES------------------------------
#---------------------------------------------------------------
$INIT_INVCNDSTA
  this.INVCNDSTA = 1 #--'To be invoiced'
Return
#---------------------------------------------------------------
$INIT_MODFLG
  this.MODFLG = 1 #--'No'
Return
#---------------------------------------------------------------
$INIT_VCRTYP
  this.VCRTYP=10 :#--Normal orders
Return
#-----------------------
$CONTROL_VCRTYP
  #--Only Order type documents for now
  #--VCRTYP=10
  If this.VCRTYP<>10
    [L]ASTATUS = fmet this.ASETERROR("VCRTYP",func AFNC.MES1(mess(471,192,1),"'"+mess(10,432,1)+"'"),[V]CST_AERROR)
  Endif
Return

