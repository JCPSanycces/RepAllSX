#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
# Gestion commandes ouvertes : visualisation demandes de liv     SUBSOV #
#-----------------------------------------------------------------------#
# Janvier 1998                                                       TS #
#########################################################################

#########################################################################
# SECTION CONTENANT LES ACTIONS SUR L'OBJET                             #
#########################################################################
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "FILTRE"     : Gosub FILTRE
 When "DEFLIG"     : Gosub DEFLIG
 When "SETBOUT"    : Gosub SETBOUT
 When "LIENS"      : Gosub LIENS
 When "LIENS_LIG"  : Gosub LIENS_LIG
 When "FERME"      : Gosub FERME
 When Default
Endcase
Return

#########################################################################
$OUVRE

Local Integer NLR, NOL

If GFONC1<>"GESSOV"
    Local Integer SAVGCONSULT
    SAVGCONSULT=GCONSULT : GCONSULT=2
Endif

GFCY = GFCYDEF(5)
#Call GETDEV(GFCY) From DEVSUB
# Chargement globales référenciels, comptes et sections de la société
Gosub CHARG_PARAM
# Récupération des paramètres vente du site / de la société
Call GLOBVAR(GFCY,"VEN") From TRTX3

Gosub DECLARE From TABLEAUX

Return

#########################################################################
$FILTRE
Default File [SOC]
Return

#########################################################################
$DEFLIG

Default Mask [SOV1]
# Le fichier des lignes doit être "par défaut"
Default File [SOQ]
# Critère de lecture
CRIT = 'SOHNUM="'+[M:SOV1]SOHNUM+'" & SOPLIN='+num$([M:SOV1]SOPLIN)
# Nom et abréviation du fichier ligne
FICLIG = "SORDERQ" : ABLIG = "SOQ"
# Nom de la zone "numéro de ligne"
ZONLIG = "SOQSEQ"
Return

#########################################################################
$SETBOUT

# Suppression des boutons : annulation,création,dupplication,chgt code,modification
Call VIREBOUT(CHAINE,"ACDHM") From GOBJET
Return

#########################################################################
$LIENS

# Lecture du contrat correspondant
Call LECTURE ("SOH",[F:SOC]SOHNUM,"") From CONTOBJ
If fstat  Call RSTA ("SOH",[F:SOC]SOHNUM) From GLOCK : Endif
[M:SOV1]SOHTYP    = [F:SOH]SOHTYP
[M:SOV1]SALFCY    = [F:SOH]SALFCY
#[M:SOV1]CUSORDREF = [F:SOH]CUSORDREF
[M:SOV1]XORDDAT   = [F:SOH]ORDDAT
[M:SOV1]BETFCY    = [F:SOH]BETFCY
[M:SOV1]BETCPY    = [F:SOH]BETCPY

[M:SOV1]PJT       = [F:SOH]PJT   # FGR 20/12/2011 : X3SUIVI71065

# Lecture de la table des types de commande
#Call LECTURE ("TSO",[F:SOH]SOHTYP,"") From CONTOBJ
#If fstat  Call RSTA ("TSO",[F:SOH]SOHTYP) From GLOCK : Endif
##[M:SOV1]XTSOSOH = [F:TSO]TSOSOH
#Call GET_ATEXTRA("TABSOHTYP","SHOAXX",GLANGUE,[M:SOV1]XTSOSOH) From TRTX3TEX

GBPCNUM = [F:SOC]BPCORD
# Lecture du client commande
Read [BPC]BPC0=[F:SOC]BPCORD
If fstat  Call RSTA ("BPC",[F:SOC]BPCORD) From GLOCK : Endif
[M:SOV1]XBPCNAM = [F:BPC]BPCNAM

# Lecture du client livré
Read [BPD]BPD0=[F:SOC]BPCORD;[F:SOC]BPAADD
If fstat  Call RSTA ("BPD",[F:SOC]BPCORD) From GLOCK : Endif
[M:SOV1]XBPDNAM = [F:BPD]BPDNAM

# Lecture de l'article
Read [ITM]ITM0=[F:SOC]ITMREF : #Call LECTURE ("ITM",[F:SOC]ITMREF,"") From CONTOBJ
If fstat  Call RSTA ("ITM",[F:SOC]ITMREF) From GLOCK : Endif

If [F:SOH]SALFCY <> GFCY
   GFCY = [F:SOH]SALFCY
   #Call GETDEV(GFCY) From DEVSUB
   # Chargement globales référenciels, comptes et sections de la société    #
   Gosub CHARG_PARAM
#  Récupération des paramètres vente du site / de la société
   Call GLOBVAR(GFCY,"VEN") From TRTX3
Endif

# Lecture du site d'expédition
Call LECTURE ("FCY",[F:SOC]STOFCY,"") From CONTOBJ
If fstat  Call RSTA ("FCY",[F:SOC]STOFCY) From GLOCK : Endif

NLR = 1
# Chargement des lignes dans le tableau
Gosub LIENS From TABLEAUX

Diszo [M]BPCORD, BPAADD, ITMREF

Return

#########################################################################
$LIENS_LIG
Local Integer WWJOUR, WWMOIS, WWAN
Local Integer NOL
NOL = nolign-1

[M:SOV1]DPJT(NOL) = [F:SOQ]PJT   # FGR 20/12/2011 : X3SUIVI71065

# Simulation de l'état de la ligne selon la date du jour
If [F:SOQ]DEMDLVDAT < date$ & [M]SOQSTA(NOL) = 1
   [M]SOQSTA(NOL) = 2
   [M]UPDFLG(NOL) = 1
Endif

If NLR = 1 & [M]SOQSTA(NOL) = 2
   NLR = NOL+1
Endif

# Alimentation de la zone écran date de livraison demandée
If [F:SOQ]CAD = 3
   If left$(GFMDAT,2) = "MM"
      If [F:SOQ]MON < 10
         [M]XDLVDAT(nolign-1) = "0"+num$([F:SOQ]MON)+"/"+num$([F:SOQ]YEA)
      Else
         [M]XDLVDAT(nolign-1) = num$([F:SOQ]MON)+"/"+num$([F:SOQ]YEA)
      Endif
   Else
      If [F:SOQ]MON < 10
         [M]XDLVDAT(nolign-1) = num$([F:SOQ]YEA)+"/"+"0"+num$([F:SOQ]MON)
      Else
         [M]XDLVDAT(nolign-1) = num$([F:SOQ]YEA)+"/"+num$([F:SOQ]MON)
      Endif
   Endif
Elsif [F:SOQ]CAD = 2
   If left$(GFMDAT,2) = "MM"
      If [F:SOQ]WEE < 10
         [M]XDLVDAT(nolign-1) = "00"+num$([F:SOQ]WEE)+"-"+num$([F:SOQ]YEA)
      Else
         [M]XDLVDAT(nolign-1) = "0"+num$([F:SOQ]WEE)+"-"+num$([F:SOQ]YEA)
      Endif
   Else
      If [F:SOQ]WEE < 10
         [M]XDLVDAT(nolign-1) = num$([F:SOQ]YEA)+"-"+"00"+num$([F:SOQ]WEE)
      Else
         [M]XDLVDAT(nolign-1) = num$([F:SOQ]YEA)+"-"+"0"+num$([F:SOQ]WEE)
      Endif
   Endif
Elsif [F:SOQ]CAD = 1
    WWJOUR = [F:SOQ]DLVDAY
    WWMOIS = [F:SOQ]MON
    WWAN   = [F:SOQ]YEA

   ## If left$(GFMDAT,2) = "DD"
   ##    [M]XDLVDAT(nolign-1) = format$("D:"+GFMDAT4,gdat$(WWJOUR,WWMOIS,WWAN))
   ## Elsif left$(GFMDAT,2) = "YY"
   ##    [M]XDLVDAT(nolign-1) = format$("D:"+GFMDAT4,gdat$(WWAN,WWMOIS,WWJOUR))
   ## Else
   ##    [M]XDLVDAT(nolign-1) = format$("D:"+GFMDAT4,gdat$(WWMOIS,WWJOUR,WWAN))
   ## Endif
   [M]XDLVDAT(nolign-1) = format$("D:"+GFMDAT4,gdat$(WWJOUR,WWMOIS,WWAN))

Endif

# Alimentation du site expédition et du lieu de consommation
[M]STOFCY(NOL) = [F:SOQ]STOFCY
[M]USEPLC(NOL) = [F:SOQ]USEPLC

# Alimentation du no livraison
[M]XSDHNUM(NOL) = [F:SOQ]SDHNUM
[M]XSDDLIN(NOL) = [F:SOQ]SDDLIN
# Lecture de la livraison associée pour récupérer date et qte livrées
If [M]XSDHNUM(NOL) <> ""
   Read [SDH] SDH0=[M]XSDHNUM(NOL)
   If fstat = 0 [M]XDATLIV(NOL) = [F:SDH]DLVDAT Endif
   Read [SDD] SDD0=[M]XSDHNUM(NOL);[M]XSDDLIN(NOL)
   If fstat = 0 [M]XDLVQTY(NOL) = [F:SDD]QTY Endif
Else
   Case [M]SOQSTA(NOL)
    When 2 : [M]XSDHNUM(NOL) = mess(2,279,1)
    When 3 : [M]XSDHNUM(NOL) = mess(3,279,1)
    When Default
   Endcase
Endif

Return
#########################################################################
$FERME
If GFONC1<>"GESSOV"  GCONSULT=SAVGCONSULT : Endif
Return
#########################################################################
# SECTION CONTENANT LES SOUS-PROGRAMMES DE CONTROLE SUR CHAMPS          #
#########################################################################

######################################## Obligatoire
Subprog C_SOPLIN(VALEUR)
Variable Decimal VALEUR
# Si l'enregistrement n'existe pas, on ne passe pas
Look [F:SOC]SOC0=[M]SOHNUM;VALEUR
If fstat
   GERR=1 : GMESSAGE=mess(178,199,1) : mkstat=2
Endif
End

######################################## Obligatoire
Subprog IB_NBLIG
# Définition des boutons : 1 = Complément
#                          2 = Livraison
If nolign > [M:SOV1]NBLIG
   Raz GBOUT1, GBOUT2
   End
Endif
# Définition du bouton complément
GBOUT1 = mess(13,198,1)
# Définition du bouton livraison
Raz GBOUT2
If GFONC1 <> "GESSDH" & [M]XDATLIV(nolign-1) <> [0/0/0] GBOUT2 = mess(54,198,1) Endif
End
#########################################################################
#--------------------------------------------------------------------------#
# Chargement des globales référenciels, comptes et sections de la société  #
#--------------------------------------------------------------------------#
$CHARG_PARAM

Call GETCPY(GFCY,"",0,"") From TRTX3CPT

Return

