#<AdxTL>@(#)0.0.0.0 $Revision$ Traitement des réceptions
################################################################################
# TRTACHRCP1            TRAITEMENTS sur RECEPTIONS                Module ACHAT #
# ---------------------------------------------------------------------------- #
# Subprog MAJ_SOLDE Solde complet de la réception                              #
# Action TRTCLEPTH qui fait un Call MAJ_SOLDE                                  #
# Attention la classe [F:PTH] doit contenir la réception à solder              #
# Issue X3-25003  - 2017-05-09 by SR : Valorisation des réceptions             #
# Traitement CRE_PID_PSV(LPTHNUM,LPTDLIN,LQTYSTU)                              #
# Traitement Subprog PSVCPRCLC()                                               #
################################################################################

###################################################################
# Transaction de solde complet d'une réception d'achats           #
# Après l'appui sur le bouton "Solde"        HN  10/01/03         #
# --------------------------------------------------------------- #
# Action TRTCLEPTH qui fait un Call MAJ_SOLDE                     #
# Attention la classe [F:PTH] doit contenir la réception à solder #
###################################################################
Subprog MAJ_SOLDE
Call DEBTRANS From GLOCK
Local  Decimal  WMT1, WMT2, WRCPNOT, WRCPATI, WQTYPUU, WQTYSTU
Local  Integer  WRETOUR
Local  Char     WCLE   (GLONPTH) : WCLE=[F:PTH]PTHNUM
Local  Decimal  ANC_CPR
Local  Libelle  ANC_LININVFLG
Local Decimal   ANC_WINVDTACST # Issue 85147 - 2012-10-17 by MUARN : modif élément facturation
Local Decimal   ANC_QTY # Issue 102352 - 2014-09-02 by MUARN : mise à jour des quantités
If !clalev([F:PNH])   Local File PRETURN    [PNH]  : Endif :#VPO 13/01/11 70683
If !clalev([F:PND])   Local File PRETURND   [PND]  : Endif :#VPO 13/01/11 70683
#----- Lecture de la devise de la réception pour arrondi -----#
If [F:TCU]CUR<>[F:PTH]CUR
  Read [TCU] TCU0=[F:PTH]CUR : If fstat [F:TCU]CURRND=0.01 : Endif
Endif
#----- Début de transaction mise à jour solde -----#
$TR_SOLDE
GOK=1
Trbegin [PTH]
  For [PTD] PTD0 Where PTHNUM=WCLE
    If [F:PTD]LININVFLG<2
      Readlock [PTD] Curr
      If fstat=1
        GOK=-1 : GLOCK="$PRECEIPTD"-WCLE          : Break
      Elsif fstat
        GOK=0  : Call RSTA("PTD",WCLE) From GLOCK : Break
      Endif
      #----- Désengagement de la ligne de commande si nécessaire -----#
      If [F:PTD]POHNUM<>""
        #----- Lecture entête commande si nécessaire -----#
        If [F:POH]POHNUM<>[F:PTD]POHNUM
          Read [POH] POH0=[F:PTD]POHNUM
          If fstat  Raz [F:POH] : Endif
        Endif
        #----- lecture ligne commande quantité si nécessaire -----#
        If [F:POQ]POHNUM<>[F:PTD]POHNUM |
&          [F:POQ]POPLIN<>[F:PTD]POPLIN |
&          [F:POQ]POQSEQ<>[F:PTD]POQSEQ
          Read [POQ] POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
          If fstat  Raz [F:POQ] : Endif
        Endif
        #----- Lecture ligne commande prix si nécessaire -----#
        If [F:POH]POHTYP<>2
          If [F:POP]POHNUM<>[F:PTD]POHNUM |
&            [F:POP]POPLIN<>[F:PTD]POPLIN |
&            [F:POP]POPSEQ<>1
            Read [POP] POP0=[F:PTD]POHNUM;[F:PTD]POPLIN;1
            If fstat  Raz [F:POP] : Endif
          Endif
        Else
          Filter [POP] Where POHNUM =[F:PTD]POHNUM
&                          & POPLIN =[F:POQ]POPLIN
&                          & POPDAT>=[F:POQ]DEMRCPDAT
          Read [POP] POP1 First
          Filter [POP]
          If fstat  Raz [F:POP]  : Endif
        Endif
        #-----
        If [F:POQ]RCPCLEFLG=2 & [F:POQ]LINCLEFLG=2
          Filter [PTDB] Where POHNUM=[F:POQ]POHNUM
&                           & POPLIN=[F:POQ]POPLIN
&                           & POQSEQ=[F:POQ]POQSEQ
&                           & LININVFLG<>2
&                           & (PTHNUM<>[F:PTD]PTHNUM | PTDLIN<>[F:PTD]PTDLIN) : # Issue 104898 - 2014-12-19 by SR
#&                           & PTHNUM<>[F:PTD]PTHNUM
#&                           & PTDLIN<>[F:PTD]PTDLIN
          Look [PTDB] PTD2 First : If fstat  [F:POQ]LININVFLG=2 : Endif
          Filter [PTDB]
          If [F:POQ]LININVFLG=2
            # Issue 83801 - 2012-07-27 by SR : Possibilité de ne pas lancer la mise à jour des budgets
            # Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,-1,2,"POQ2",0,GBIDI1) From TRTACHDIV1
            # If GOK<1  Break : Endif
            GPE = 1
            [V]GPOINT="CUSMAJCMM" : Gosub ENTREE From EXEFNC
            If GPE
              # Issue 90921 - 2013-07-05 by MUARN : solde réception et BUO, affiche erreur buo WMSGFLG de 0 à 1
              Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,-1,2,"POQ2",1,GBIDI1) From TRTACHDIV1
              If GOK<1  Break : Endif
            Endif
            Update [POQ] Where POHNUM=[F:PTD]POHNUM
&                            & POPLIN=[F:PTD]POPLIN
&                            & POQSEQ=[F:PTD]POQSEQ
&                        With  RCPCLEFLG=1, LININVFLG=2
            If fstat  GOK=0 : Call FSTA("POQ") From GLOCK : Break : Endif
            [F:POQ]RCPCLEFLG=1
          Endif
        Endif
      Endif
      #----- Màj mvts réceptionnés non facturés -----#
      If [F:PTH]BETFCY<>2 | [F:PTH]BETCPY=2
        If [F:PTD]QTYPUU<>0 & [F:PTD]INVQTYPUU<>0
          WMT1=[F:PTD]LINAMT   *max([F:PTD]QTYPUU-[F:PTD]INVQTYPUU,0)/[F:PTD]QTYPUU
          WMT2=[F:PTD]LINATIAMT*max([F:PTD]QTYPUU-[F:PTD]INVQTYPUU,0)/[F:PTD]QTYPUU
        Else
          WMT1=[F:PTD]LINAMT
          WMT2=[F:PTD]LINATIAMT
        Endif
        #----- Lecture commande si nécessaire pour récup type de cours et date -----#
        If [F:PTD]POHNUM<>""
          If [F:POH]POHNUM<>[F:PTD]POHNUM
            Read [POH] POH0=[F:PTD]POHNUM
            If fstat
              Raz [F:POH] : [F:POH]CHGTYP=[F:PTH]CHGTYP : [F:POH]ORDDAT=[F:PTH]RCPDAT
            Endif
          Endif
        Else
          Raz [F:POH] : [F:POH]CHGTYP=[F:PTH]CHGTYP : [F:POH]ORDDAT=[F:PTH]RCPDAT
        Endif
        #----- Conversion si nécessaire du montant en devise entête réception -----#
        If [F:PTH]CUR<>[F:PTD]NETCUR
          Call CONVERT([F:PTD]NETCUR,[F:PTH]CUR,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                      WMT1,WRCPNOT,WRETOUR) From TRTDEV
          If WRETOUR  WRCPNOT=arr(WMT1,[F:TCU]CURRND) : Endif
          Call CONVERT([F:PTD]NETCUR,[F:PTH]CUR,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                      WMT2,WRCPATI,WRETOUR) From TRTDEV
          If WRETOUR  WRCPATI=arr(WMT2,[F:TCU]CURRND) : Endif
        Else
          WRCPNOT=arr(WMT1,[F:TCU]CURRND)
          WRCPATI=arr(WMT2,[F:TCU]CURRND)
        Endif
        #-----
        Call MAJENC_BPS([F:PTD]BPSNUM,4,[F:PTD]PRHFCY,[F:PTH]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                       [F:PTD]PTHNUM,-WRCPNOT,-WRCPATI,[F:PTH]TOTAMTATI) From TRTBPMVT
        If GOK<1  Goto AB_SOLDE : Endif
      Endif
      #----- Réécriture de la ligne réception avec indicateur facturé à OUI -----#
      ANC_LININVFLG=[F:PTD]LININVFLG
      ANC_CPR      =[F:PTD]CPR
      # Issue 114265 - 2016-02-04 by MUARN : pour régul stock
      ANC_QTY      =[F:PTD]QTYSTU

      # Issue 85147 - 2012-10-15 by MUARN : modif éléments de facturation
      Raz ANC_WINVDTACST
      For I=1 To 9
          If [F:PTH]INVDTALIN2(I-1)<>0
            Read [PFI] PFI0=[F:PTH]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
            If [F:PFI]NPRVLT=2
              ANC_WINVDTACST+=evalue("[F:PTD]DISCRGAMT"+num$(I))
            Endif
          Endif
      Next I

      #-----
      [F:PTD]LININVFLG=2
      [F:PTD]UPDDAT   =date$
      [F:PTD]UPDUSR   =GUSER
      Rewrite [PTD]
      If fstat  GOK=0 : Call FSTA("PTD") From GLOCK : Break : Endif
      # Issue 92907 GA 10/2013 If [F:PTD]STOMGTCOD>1
      If [F:PTD]STOMGTCOD>1 & [F:PTD]LINTYP<3
        Gosub REVALOR_STOCK : If GOK<1  Break : Endif
      Endif
    Endif
  Next
  If GOK=-1 Goto ROLL_SOLDE : Endif
  If GOK=0  Goto AB_SOLDE   : Endif
  #----- Mise à jour nbre de lignes facturées et indicateur facturé sur entête rcp -----#
  Readlock [PTH] PTH0=WCLE
  If fstat=1
    GOK=-1 : GLOCK="$PRECEIPT"-WCLE           : Goto ROLL_SOLDE
  Elsif fstat
    GOK=0  : Call RSTA("PTH",WCLE) From GLOCK : Goto AB_SOLDE
  Endif
  [F:PTH]INVLINNBR=[F:PTH]LINNBR
  [F:PTH]INVFLG   =3
  [F:PTH]UPDDAT   =date$
  [F:PTH]UPDUSR   =GUSER
  Rewrite [PTH]
  If fstat  GOK=0 : Call FSTA("PTH") From GLOCK : Goto AB_SOLDE : Endif
Commit
End
$ROLL_SOLDE
#------------------------------------------------------#
# Nouvel essai de transaction ou abandon suivant GROLL #
#------------------------------------------------------#
Rollback : Call ROLL From GLOCK
If GROLL  End Else Goto TR_SOLDE : Endif
$AB_SOLDE
#---------------------------#
# Abandon de la transaction #
#---------------------------#
Rollback
End


#-------------------------------------------#
# Revalorisation des stocks après :         #
#  - un solde ou désolde de ligne réception #
#  - Une modification du prix de revient    #
#-------------------------------------------#
$REVALOR_STOCK
If dim(WMT)<1      Local Decimal WMT     : Endif
If dim(WQTY)<1     Local Decimal WQTY    : Endif
If dim(WQTYRET)<1  Local Decimal WQTYRET : Endif : #VPO 13/01/11 70683
If dim(WRETOUR)<1  Local Integer WRETOUR : Endif
If dim(WCNVRPT)<1  Local Decimal WCNVRPT : Endif    # Taux de conversion devise société vers devise dossier
Local Decimal  WINVDTACST # Issue 85147 - 2012-10-15 by MUARN : modif éléments de facturation
#-----
Raz [L]WRETOUR
#----- Solde ou désolde d'une ligne de réception -----#
If ANC_LININVFLG<>[F:PTD]LININVFLG
  ##VPO 13/01/11 70683 tenir compte de qté retournée sans attente d'avoir
  ##[L]WQTY=[F:PTD]QTYSTU-[F:PTD]INVQTYSTU
  #on va chercher les retours validés sans attente d'avoir
  Raz WQTYRET
  Link [PND] With [PNH]PNH0~=[F:PND]PNHNUM As [PNX]
&   Where [PND]PTHNUM=[F:PTD]PTHNUM & [PND]PTDLIN=[F:PTD]PTDLIN & [PND]LININVFLG=2 & [PNH]CFMFLG=2
  For [PNX]
    WQTYRET +=[F:PND]QTYSTU
  Next
  [L]WQTY=[F:PTD]QTYSTU-[F:PTD]INVQTYSTU-WQTYRET

  #on passe un montant à zero car idem reception gratuit
  Raz [L]WMT
  #----- Annulation solde d'une ligne de réception -----#
  If [F:PTD]LININVFLG<>2
    [L]WQTY=-[L]WQTY
  Endif
  Gosub REGPRIX From TRTACHRCP1
Endif
#----- Modification du prix unitaire de revient (prix de l'ordre) -----#
If ANC_CPR<>[F:PTD]CPR
  Raz [L]WQTY
  [L]WMT=arr(([F:PTD]CPR-ANC_CPR)*[F:PTD]QTYSTU,10^-GDECPRI)
  Gosub REGPRIX From TRTACHRCP1
Endif
Return
#-----------------------------------------#
# Régularisation prix mouvements d'entrée #
#-----------------------------------------#
$REGPRIX
#----- Point d'entrée REVALSTO permettant de court_circuiter la régularisation -----#
If dim(WUPDPRIFLG)<1  Local Libelle WUPDPRIFLG : Endif
WUPDPRIFLG=1 : [V]GPOINT="REVALSTO" : Gosub ENTREE From EXEFNC
If !WUPDPRIFLG  Return : Endif
#-----
If GSTOTRACE>2 & GTRACE<>""
  #----- Impression paramètres du Call si trace détaillée -----#
  GPURTRACE=2
  Call ECR_TRACE("-- Call REGPRIX  From STKVAL",0)        From GESECRAN
  Call ECR_TRACE("   PFCY    ="-[F:PTD]PRHFCY,0)          From GESECRAN
  Call ECR_TRACE("   PTRSTYP = 3",0)                      From GESECRAN
  Call ECR_TRACE("   PITM    ="-[F:PTD]ITMREF,0)          From GESECRAN
  Call ECR_TRACE("   PIPTDAT ="-num$([F:PTD]RCPDAT),0)    From GESECRAN
  Call ECR_TRACE("   PTRSCOD ="-num$([F:PTH]TRSCOD),0)    From GESECRAN
  Call ECR_TRACE("   PVCRTYP = 6",0)                      From GESECRAN
  Call ECR_TRACE("   PVCRNUM ="-[F:PTD]PTHNUM,0)          From GESECRAN
  Call ECR_TRACE("   PVCRLIN ="-num$([F:PTD]PTDLIN),0)    From GESECRAN
  Call ECR_TRACE("   PTYPREG = 6",0)                      From GESECRAN
  Call ECR_TRACE("   PNUMREG ="-[F:PTD]PTHNUM,0)          From GESECRAN
  Call ECR_TRACE("   PLINREG ="-num$([F:PTD]PTDLIN),0)    From GESECRAN
  Call ECR_TRACE("   PNEWAMT ="-num$([L]WMT),0)           From GESECRAN
  Call ECR_TRACE("   PQTY    ="-num$([L]WQTY),0)          From GESECRAN
  Call ECR_TRACE("   PRET    ="-num$([L]WRETOUR),0)       From GESECRAN
  Call ECR_TRACE("----------------------------",0)        From GESECRAN
Endif
Raz [M:SDP]
[M:SDP]QTY    = WQTY

# Issue 101100 - 2014-09-09 by MUARN : écart calcul lié au nombre de décimales
# déplacement calcul WINVDTACST et
# ajustement de WMT
Raz WINVDTACST
For I=1 To 9
  If [F:PTH]INVDTALIN2(I-1)<>0
    Read [PFI] PFI0=[F:PTH]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
    If [F:PFI]NPRVLT=2
      WINVDTACST+=evalue("[F:PTD]DISCRGAMT"+num$(I))
    Endif
  Endif
Next I

# Issue 113362 - 2016-01-05 by MUARN : élément de facturation et devise
If [F:PTD]CPRCUR <> [F:PTD]NETCUR
    Local   Decimal  WINVDTACST_DEV, ANC_WINVDTACST_DEV
    Local   Integer  STAT
    WINVDTACST_DEV = WINVDTACST
    ANC_WINVDTACST_DEV = ANC_WINVDTACST
    If [F:PTH]CHGCOE=0
      Call CONVERT2([F:PTH]CUR,[F:PTD]CPRCUR,[F:PTD]CPRCUR,[F:PTH]CHGTYP,[F:PTH]RCPDAT,
&                    WINVDTACST_DEV,WINVDTACST,STAT) From TRTDEV
      Call CONVERT2([F:PTH]CUR,[F:PTD]CPRCUR,[F:PTD]CPRCUR,[F:PTH]CHGTYP,[F:PTH]RCPDAT,
&                    ANC_WINVDTACST_DEV,ANC_WINVDTACST,STAT) From TRTDEV
    Else
      WINVDTACST=WINVDTACST_DEV*[F:PTH]CHGCOE
      ANC_WINVDTACST=ANC_WINVDTACST_DEV*[F:PTH]CHGCOE
    Endif
Endif

If ANC_QTY <>0
  # Issue 103538 - 2014-10-23 by MUARN : ecart d'arrondi
  #WMT += arr((WINVDTACST/ANC_QTY - arr(WINVDTACST/ANC_QTY,10^-GDECPRI))*ANC_QTY,10^-GDECPRI)
  WMT += arr((WINVDTACST/[F:PTD]QTYSTU - arr(WINVDTACST/[F:PTD]QTYSTU,10^-GDECPRI))*[F:PTD]QTYSTU,10^-GDECPRI)
Endif

[M:SDP]AMTTOT = WMT
If [M:SDP]QTY<>0
  [M:SDP]PRI  = arr([M:SDP]AMTTOT/[M:SDP]QTY,10^-GDECPRI)
Endif
If GACTDECCST
    # Issue 85147 - 2012-10-15 by MUARN : modification des éléments de facturation en réception
    #[M:SDP]INVDTACST = ??
    # Issue 101100 - 2014-09-09 by MUARN : problème calcul CPR unitaire déplacement calcul WINVDTACST
    #Raz WINVDTACST
    #For I=1 To 9
    #  If [F:PTH]INVDTALIN2(I-1)<>0
    #    Read [PFI] PFI0=[F:PTH]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
    #    If [F:PFI]NPRVLT=2
    #      WINVDTACST+=evalue("[F:PTD]DISCRGAMT"+num$(I))
    #    Endif
    #  Endif
    #Next I

    # Issue 101100 - 2014-07-17 by MUARN : modif quantité par moteur de stock
    # et prise en compte structure de cout
    #[M:SDP]INVDTACST = WINVDTACST - ANC_WINVDTACST
    If ANC_QTY <> [F:PTD]QTYSTU & [F:PTD]STCNUM = ""
      [M:SDP]INVDTACST = WMT
    Elsif ANC_QTY <> [F:PTD]QTYSTU & [F:PTD]STCNUM <> ""
      [M:SDP]INVDTACST = WINVDTACST - ( ( ANC_WINVDTACST * [F:PTD]QTYSTU ) / ANC_QTY )
    Else
      [M:SDP]INVDTACST = WINVDTACST - ANC_WINVDTACST
    Endif

    If [F:ITM]ITMREF<>[F:PTD]ITMREF
       Read [F:ITM]ITM0=[F:PTD]ITMREF
    Endif
    If [F:ITM]BRDCOD>0        # sinon plante [M:SDP]MATCST(-1) !!!
      [M:SDP]MATCST([F:ITM]BRDCOD-1) = [M:SDP]AMTTOT-[M:SDP]INVDTACST
    Endif
Endif
#----- Appel du sous-programme de régularisation des prix -----#
Call CONVERT2(GLOCALDEV,GSYSCUR,GLOCALDEV,GCHGTYP,[F:PTD]RCPDAT,
&             1,WCNVRPT,WRETOUR) From TRTDEV
Call REGPRIX ([F:PTD]PRHFCY,3,[F:PTD]ITMREF,[F:PTD]RCPDAT,[F:PTH]TRSCOD,6,[F:PTD]PTHNUM,
&      [F:PTD]PTDLIN,6,[F:PTD]PTHNUM,[F:PTD]PTDLIN,WCNVRPT,[L]WRETOUR) From STKVALREG
If [L]WRETOUR=2     : # Aucun mouvement trouvé pour la régularisation des prix
  Call ECR_TRACE([F:PTD]PTHNUM-num$([F:PTD]PTDLIN)-[F:PTD]ITMREF-mess(215,197,1)
&                                     ,1) From GESECRAN
Elsif [L]WRETOUR<>0 : # Erreur sur la régularisation des prix
  Call ECR_TRACE([F:PTD]PTHNUM-num$([F:PTD]PTDLIN)-[F:PTD]ITMREF-mess(519,197,1)
&                -"("+num$([L]WRETOUR)+")",1) From GESECRAN
Endif
Return


############################################################################
# Gosub MAJ_ADRESSE : Transaction de modification de l'adresse fournisseur #
#                     sur l'entête d'une réception (PRECEIPT) après        #
#                     l'option "Adresse expéditeur"                        #
# ------------------------------------------------------------------------ #
# L'action SAIADRBPR précède le Gosub MAJ_ADRESSE             MBT 04/11/08 #
############################################################################
$MAJ_ADRESSE
If [M:AD68]ADBFLG=0 & GACTSAD<>2  Goto FIN_ADR : Endif
#----- Mise à jour de l'entête de réception -----#
Call DEBTRANS From GLOCK
$TR_ADR
GOK=1
Trbegin [PTH]
  Readlock [PTH] PTH0=[M:PTH0]PTHNUM
  If fstat=1
    GOK=-1 : GLOCK="$PRECEIPT"-[M:PTH0]PTHNUM           : Goto ROLL_ADR
  Elsif fstat
    GOK=0  : Call RSTA("PTH",[M:PTH0]PTHNUM) From GLOCK : Goto AB_ADR
  Endif
  If [M:AD68]ADBFLG<>2
    If [M:AD68]ADBFLG=1
      [F:PTH]BPOADD=[M:AD68]BPAADD
    Endif
    If GACTSAD=2 : # Stockage systématique de l'adresse !
      #----- Lecture BPARTNER si nécessaire -----#
      If [F:BPR]BPRNUM<>[F:PTH]BPSNUM
        Read [BPR] BPR0=[F:PTH]BPSNUM
        If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
      Endif
      #----- Lecture de l'adresse si nécessaire -----#
      If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:PTH]BPSNUM | [F:BPA]BPAADD<>[F:PTH]BPOADD
        Read [BPA] BPA0=1;[F:PTH]BPSNUM;[F:PTH]BPOADD
        If fstat  Raz [F:BPA] : Endif
      Endif
      #-----
      [F:PTH]BPONAM(0)    = [F:BPR]BPRNAM(0)
      [F:PTH]BPONAM(1)    = [F:BPR]BPRNAM(1)
      [F:PTH]BPOADDLIG(0) = [F:BPA]BPAADDLIG(0)
      [F:PTH]BPOADDLIG(1) = [F:BPA]BPAADDLIG(1)
      [F:PTH]BPOADDLIG(2) = [F:BPA]BPAADDLIG(2)
      [F:PTH]BPOCRY       = [F:BPA]CRY
      [F:PTH]BPOCRYNAM    = [F:BPA]CRYNAM
      [F:PTH]BPOSAT       = [F:BPA]SAT
      [F:PTH]BPOPOSCOD    = [F:BPA]POSCOD
      [F:PTH]BPOCTY       = [F:BPA]CTY
    Else
      Raz [F:PTH]BPONAM,[F:PTH]BPOADDLIG,[F:PTH]BPOCRY,[F:PTH]BPOCRYNAM,
&         [F:PTH]BPOSAT,[F:PTH]BPOPOSCOD,[F:PTH]BPOCTY
    Endif
  Else
    [F:PTH]BPOADD       = [M:AD68]BPAADD
    [F:PTH]BPONAM(0)    = [M:AD68]BPRNAM(0)
    [F:PTH]BPONAM(1)    = [M:AD68]BPRNAM(1)
    [F:PTH]BPOADDLIG(0) = [M:AD68]BPAADDLIG(0)
    [F:PTH]BPOADDLIG(1) = [M:AD68]BPAADDLIG(1)
    [F:PTH]BPOADDLIG(2) = [M:AD68]BPAADDLIG(2)
    [F:PTH]BPOCRY       = [M:AD68]CRY
    [F:PTH]BPOCRYNAM    = [M:AD68]CRYNAM
    [F:PTH]BPOSAT       = [M:AD68]SAT
    [F:PTH]BPOPOSCOD    = [M:AD68]POSCOD
    [F:PTH]BPOCTY       = [M:AD68]CTY
  Endif
  Rewrite [PTH]
  If fstat GOK=0 : Call FSTA("PTH") From GLOCK : Goto AB_ADR : Endif
Commit
$FIN_ADR
Gosub DEVERROU From GOBJET : Gosub RELIT From GOBJET
Return
$ROLL_ADR
Rollback : Call ROLL From GLOCK
If GROLL   Goto FIN_ADR  Else  Goto TR_ADR : Endif
$AB_ADR
Rollback
Goto FIN_ADR

######################################################################################
# Issue X3-25003 - 2017-05-09 by SR : Valo des réceptions
#################################################################################
# Régularisation des prix dans les mouvements de stock en création de réception #
#################################################################################
Subprog PSVCPRCLC()
#----- Variables locales -----#
Local Char     WTRANSAC(max(GLONGAU,10))
Local Char     IDENT(30)
Local Shortint OUVFICFLG
Local Char     WFCY    (GLONFCY)
Local Char     WITMREF (GLONITM)
Local Date     WIPTDAT
Local Integer  WVCRTYP
Local Char     WVCRNUM (GLONVCR), WVCRNUM2(GLONVCR)
Local Integer  WVCRLIN, WVCRLIN2
Local Decimal  WQTY,WPRI,WPRIORI, WMT, WNETPRI, WQTYRES, WQTYSTU2,WPECQTY, WPECPRI,WPECCRG
Local Integer  WRET, STAT, WTYP
Local Char     WNUM(GLONVCR), WNUMORI (GLONVCR), WTRSCOD(GLONADI)
Local Integer  WLINORI
Local Decimal  SAV_QTYSTU,WRK_RCPQTYSTU, WREST, WRESTPRI,WRESTCRG,WTO_TAKE
Local Decimal  WRATCUR
Local Shortint WI
Local Integer  I
Local Decimal  WINVDTACST
Local Integer  WINVDTACSTPTD
Local Decimal  WDISCRGVAL, WDISCRGAMT, WTAXE, WCOURS, WMT
Local Decimal  WINVRCPQTYSTU
Local Integer  WREGPTD
Local Decimal  WCPLPRI,WCPLCRG, WCPRPTD
Local Date     WCREDAT
WREGPTD = 2

#----- Lecture code activité "KIT" -----#
If clalev ([F:ACV])<=0 Local File ACTIV [ACV] : OUVFICFLG=1 : Endif
Read [ACV] CODACT="KIT" : If fstat Raz [F:ACV] : Endif
If [F:ACV]FLACT=2 WACTFLG="KIT" Else Raz WACTFLG : Endif
If OUVFICFLG=1 Close Local File [ACV] : Raz OUVFICFLG : Endif

#-----
If !clalev([F:ITM])  Local File ITMMASTER [ITM]  : Endif
If !clalev([F:POQ])  Local File PORDERQ   [POQ]  : Endif
If !clalev([F:PIH])  Local File PINVOICE  [PIH]  : Endif
If !clalev([F:PID])  Local File PINVOICED [PID]  : Endif
If !clalev([F:PIV])  Local File PINVOICEV [PIV]  : Endif
If !clalev([F:PIH2]) Local File PINVOICE  [PIH2] : Endif
If !clalev([F:PID2]) Local File PINVOICED [PID2] : Endif
If !clalev([F:PID3]) Local File PINVOICED [PID3] : Endif
If !clalev([F:STJ])  Local File STOJOU    [STJ]  : Endif

If !clalev([F:PSV])  Local File PTDSTKVAL [PSV]  : Endif
If !clalev([F:PSV2]) Local File PTDSTKVAL [PSV2] : Endif
If !clalev([F:PSV3]) Local File PTDSTKVAL [PSV3] : Endif

If clalev([F:SJV]) = 0 : Local File STOJOUVAL  [SJV] : Endif

If clalev([F:PFI]) = 0 : Local File PFOOTINV   [PFI] : Endif

If clalev([F:STCR]) = 0 : Local File COSTSTCR  [STCR] : Endif

If clalev([F:GAU]) = 0 : Local File GAUTACE    [GAU] : Endif

If GMODU(8)=2 | [F:PTD]LINTYP>1
   If clalev([M:SBCK])=0 Local Mask SBCK  [SBCK] : Endif
Endif

# Suppression d'une réception : Remettre à disposition les enregistrements précédemment pris, sauf pour FCC/AVoir sur FCC sur cde/Expé
# car géré par REGPRIX_FCC
If GREP = "A"
    For [F:PSV] Where PTHNUM = [F:PTD]PTHNUM & PTDLIN = [F:PTD]PTDLIN & find([F:PSV]TYP,3,4,9,10)=0
    Readlock [PSV3]PSV0 = [F:PSV]NUM;[F:PSV]PIDLIN;[F:PSV]PTHNUM;[F:PSV]PTDLIN
    If fstat=1
       GOK=-1 : GLOCK="$PTDSTKVAL"-[F:PTD]PTHNUM :GOK = 0 : Break
    Elsif fstat
       GOK=0 : Call RSTA("PSV3",[F:PTD]PTHNUM) From GLOCK
       Break
    Endif
    Read [PID]PID0 = [F:PSV3]NUM;[F:PSV3]PIDLIN
    If fstat : Raz [F:PID] : Endif
    # Un enregistrement pour cette facture non encore pris en compte (reliquat) existe-t-il ?
    Look [PSV2]PSV0 = [F:PID]NUM;[F:PID]PIDLIN;"";0
    If !fstat
       # Oui, on incrémente la quantité restant à prendre en compte
       Readlock [F:PSV2]PSV0 Curr
        If fstat=1
          GOK=-1 : GLOCK="$PTDSTKVAL"-[F:PID]NUM :GOK = 0 : Break
        Elsif fstat
          GOK=0 : Call RSTA("PSV2",[F:PID]NUM) From GLOCK
          Break
        Endif
       # Si FCC sur commande/Expé/Facture ou Avoir sur ces FCC , on doit aussi mettre à jour le CPR
       If find([F:PSV2]TYP,3,4,5,9,10,11)
        [F:PSV2]CPR += [F:PSV3]CPR
       Endif
       [F:PSV2]QTYSTU += [F:PSV3]QTYSTU
       Rewrite [F:PSV2]
       If fstat GOK=0 : Call FSTA("PSV2") From GLOCK : Break : Endif
    Else
       # Non, on va le créer par duplication de celui en cours de lecture
#       WQTY = [F:PSV]QTYSTU
#       WCPR = [F:PSV]CPR
        Raz [F:PSV2]
        [F:PSV2] = [F:PSV3]
        [F:PSV2]TIAFLG=1
        Raz [F:PSV2]PTHNUM
        Raz [F:PSV2]PTDLIN
        Write [F:PSV2]
        If fstat GOK=0 : Call FSTA("PSV2") From GLOCK : Break : Endif
    Endif
    Delete [F:PSV3]PSV0 Curr
    If fstat GOK=0 : Call FSTA("PSV3") From GLOCK : Break  : Endif
   Next
 End
Endif
#-----
# On est en création de réception: Quantité à régulariser est [F:PTD]QTYSTU #
# INVQTYSTU ne peut pas être utilisée car si Facture+Facture+Avoir, INVQTYSTU a déjà pris en compte l'avoir
# et du coup la 2eme facture ne sera pas correctement exploitée
# exemple:
# CDE de 10
# Facture1  de 8
# Facture2  de 2
# Avoir sur facture1 de 1
# INVQTYSTU contient 9, mais pour pouvoir passer les 2 factures, il faut avoir 10
WRK_RCPQTYSTU = [F:PTD]QTYSTU
# Prise en compte des factures sur commande ou sur autres réceptions ou FCC sur facture de commande + les avoirs correspondants
#  donc TYP = 1,2,5,7,8,11
# Pour rappel,  les valeurs de TYP sont:
# 1 : Facture sur commande
# 2 : Facture sur réception
# 3 : FCC sur commande
# 4 : FCC sur expédition
# 5 : FCC sur facture de commande
# 6 : FCC sur facture de réception
# 7 : Avoir sur facture sur commande
# 8 : Avoir sur facture sur réception
# 9 : Avoir sur FCC sur commande
# 10 :Avoir sur FCC sur expédition
# 11 : Avoir sur FCC sur facture sur commande
# 12 : Avoir sur FCC sur facture sur réception
# 13 : FCC sur réception
# 14 : Avoir sur FCC sur réception

Filter [F:PSV] Where POHNUM = [F:PTD]POHNUM & POPLIN = [F:PTD]POPLIN & POQSEQ = [F:PTD]POQSEQ
&                       & TIAFLG <> 2 & find(TYP,1,2,5,7,8,11)
For [PSV]PSV1
  Gosub RAZ_WRKFLD
  Read [F:PID]PID0=[PSV]NUM;[PSV]PIDLIN
  If fstat : Raz [F:PID] : End : Endif
  Read [F:PIH]PIH0 = [F:PID]NUM
  If fstat : Raz [F:PIH] : Endif
  Read [PIV] PIV0=[F:PIH]NUM
  If fstat  Raz [F:PIV] : Endif
  IDENT   = [F:PIH]NUM
  WINVTYP = [F:PIH]INVTYP
  Gosub TRANSAC From TRTACHFAC1
  # si avoir sur facture : relire la facture
  If find([F:PSV]TYP,2,4,11)
      If [F:PIH2]NUM <> [F:PID]NUMORI
      Read [F:PIH2]PIH0 = [F:PID]NUMORI
      If fstat : Raz [F:PIH2] : Endif
     Endif
  Endif
  If [F:PID]ITMREF<>""
     Read [ITM] ITM0=[F:PID]ITMREF : If fstat  Raz [F:ITM] : Endif
     Case [F:PSV]TYP
          When 1         : If WRK_RCPQTYSTU >0 Gosub LECT_CDE : Endif    : # Facture sur Commande
          When 2         : If WRK_RCPQTYSTU >0 Gosub LECT_RCP : Endif    : # Facture sur autre réception
          When 5,7,8,11  : Gosub LECT_FACTURE                            : # Avoirs et FCC
     Endcase
     If GOK<>1  Break : Endif
   Endif
Next
Filter [F:PSV]
End

#-----------------------------------------------------------
$RAZ_WRKFLD
# Raz des variables de travail entre deux appels à la régul
Raz WQTY, WPRI,WINVDTACST,WINVDTACSTPTD,WFCY,WITMREF,WIPTDAT,WVCRTYP,WVCRNUM,WVCRLIN,WREST,WCPLPRI,WCPLCRG,
&   WTO_TAKE
Return

#------------------------#
# Lecture de la commande #
#------------------------#
$LECT_CDE
  Read [POQ] POQ0=[F:PID]POHNUM;[F:PID]POPLIN;[F:PID]POQSEQ
  If fstat : Raz [F:POQ] : Return : Endif
$LECT_RCP
 SAV_QTYSTU=[F:PID]QTYSTU
 # quantité à traiter : minimum entre qté de [PSV] et qté restant à facturer de PTD
 [F:PID]QTYSTU = min([F:PSV]QTYSTU,WRK_RCPQTYSTU)
 WPECQTY = [F:PID]QTYSTU
 Raz WINVRCPQTYSTU
 Gosub LECT_RCP From TRTACHFAC1 : If GOK<>1  Return : Endif
 WREST = [F:PSV]QTYSTU -WPECQTY
 If WREST < 0 : WREST = 0 : Endif
 Gosub UPD_PTD_PSV
 If WREST <> 0 : Gosub CRE_PTD_PSV : Endif
 # décrémentation de la quantité  réceptionnée restant à traiter
 WRK_RCPQTYSTU -= WPECQTY
 # restore de la quantité de la fature
 [F:PID]QTYSTU=SAV_QTYSTU
Return

#------------------------------------------------------------------#
#        Lecture et traitement à partir de la facture              #
# ---------------------------------------------------------------- #
# Cas des avoirs sur facture,                                      #
# des factures complémentaires                                     #
# et des avoirs sur factures complémentaires                       #
#------------------------------------------------------------------#
$LECT_FACTURE
# première chose à faire :
# si avoir sur facture, FCC sur facture, Avoir sur FCC sur facture:
# La facture d'origine de l'avoir ou de la FCC a-t-elle été PEC pour cette ligne de réception ?
If find([F:PID]PIHTYP,2,3)
   Read [F:PSV2]PSV0 = [F:PSV]NUMORI;[F:PSV]LINORI;[F:PTD]PTHNUM;[F:PTD]PTDLIN
   If fstat : Raz [F:PSV2] : Return : Endif
Endif
# Facture d'origine
Read [PID2] PID0=[F:PID]INVNUM;[F:PID]INVLIN
If fstat  Return : Endif

# sauvegarde de la facture d'origine
[F:PID3] = [F:PID2]
#----- Si avoir sur facture complémentaire, recherche facture d'origine -----#
If [F:PID2]PIHTYP=2 & [F:PID2]TYPORI=4 & [F:PID2]QTYSTU=0
  WNUMORI=[F:PID2]NUMORI
  WLINORI=[F:PID2]LINORI
  Read [PID2] PID0=WNUMORI;WLINORI
  If fstat Raz [F:PID2] : Return : Endif
Endif
WITMREF = [F:PID2]ITMREF
#----- Lecture de l'article de la ligne d'origine -----#
If [F:ITM]ITMREF<>WITMREF
  Read [ITM] ITM0=WITMREF : If fstat Raz [F:ITM] : Endif
Endif
#----- Si article géré en stock ou article sous-traitance -----#
If [F:ITM]STOMGTCOD>1 | [F:PID]ITMKND=2 | [F:PID]LINTYP>2 | [F:PTD]VCRTYPORI = 10
   # Avoir  : la Facture avait été prise en compte, mais existe-t-il encore un reliquat pour cette facture ?
   If [F:PID]PIHTYP <> 2
     Read [F:PSV3]PSV0 = [F:PID3]NUMORI;[F:PID3]LINORI;"";0
     If !fstat
        # Oui, on va donc diminuer la qté de l'avoir à prendre en compte (laisser au maximum le même reliquat)
        WTO_TAKE = [F:PSV]QTYSTU - [F:PSV3]QTYSTU
        # rien à prendre en compte, l'avoir couvre le reliquat de la facture d'origine
        If WTO_TAKE<= 0
           Return
        Else
           # on connait le reliquat à garder  (à minima),
           # c'est-à-dire la différence entre ce qu'on a à prendre en compte et ce qu'on peut prendre en compte
           WREST =[F:PSV]QTYSTU - WTO_TAKE
           # On surcharge la quantité avec la quantité maximum que l'on peut prendre
           [F:PSV]QTYSTU = WTO_TAKE
        Endif
     Endif
   Endif
   # Si avoir sur facture normale (sur cde ou sur rcp) , ne pas prendre une quantité supérieure
   # à celle qui avait été prise pour la facture (la facture a pû impacter plusieurs réceptions)
   If find([F:PSV]TYP,7,8)
      If [F:PID]NETPRI=[F:PID]ORINETPRI & [F:PID]QTYSTU<>0 # avoir en quantité
         SAV_QTYSTU=[F:PID]QTYSTU
         [F:PID]QTYSTU  = min([F:PSV]QTYSTU,[F:PSV2]QTYSTU)
         WPECQTY = [F:PID]QTYSTU
      Else
         SAV_QTYSTU=[F:PID2]QTYSTU
         [F:PID2]QTYSTU = min([F:PSV]QTYSTU,[F:PSV2]QTYSTU)
         WPECQTY = [F:PID2]QTYSTU
      Endif
   # Sinon, FCC sur facture de cde et avoir sur FCC sur facture sur commande
   Else
      SAV_QTYSTU=[F:PID2]QTYSTU
      [F:PID2]QTYSTU = min([F:PSV]QTYSTU,[PTD]QTYSTU)
 #     # surcharger le montant à répartir
 #     [F:PID]CPR = [F:PSV]CPR
       WPECQTY = [F:PID2]QTYSTU
   Endif
   # Proratisation : Calcul de ce qu'on va affecter à la réception(on proratise par rapport au montant d'origine)
   # Le prorata max = 1 (on prend tout)
   If find([F:PSV]TYP,5,11)
      If !find([F:PTD]VCRTYPORI,10,36)
        WPECPRI = arr([F:PID]CPR * min(1,[F:PTD]QTYSTU / SAV_QTYSTU),10^-GDECPRI)
      Else
        # recalculer CPLPRI et NETPRI d'origine
        Gosub CAL_CPLPRI From TRTACHFAC1
        WPECPRI = arr(WPRI * min(1,[F:PTD]QTYSTU / SAV_QTYSTU),10^-GDECPRI)
        WPECCRG = arr((WPRI-WNETPRI) * min(1,[F:PTD]QTYSTU / SAV_QTYSTU),10^-GDECPRI)
        Raz WPRI
      Endif
   Endif
   Raz WINVRCPQTYSTU
   Gosub TRT_RCP2 From TRTACHFAC1
   # avoir sur facture : incrémentation de la quantité  réceptionnée restant à traiter
   If find([F:PSV]TYP,7,8)
     WRK_RCPQTYSTU += WPECQTY
   Endif
   # On incrémente le reliquat
   WREST += [F:PSV]QTYSTU - WPECQTY
   If WREST < 0 : WREST = 0 : Endif
   # FCC sur facture de cde/Avoir sur ces FCC : Montant pris en compte sur la réception?
   If find([F:PSV]TYP,5,11)
      If !find([F:PTD]VCRTYPORI,10,36)
        WRESTPRI = [F:PSV]CPR - WPECPRI
      Else
        WRESTPRI = [F:PSV]CPLPRI - WPECPRI
        WRESTCRG = [F:PSV]CPLCRG - WPECCRG
      Endif
   Endif
   Gosub UPD_PTD_PSV
   If WREST <> 0 : Gosub CRE_PTD_PSV : Endif
   # restore de la quantité de la fature
   If find([F:PSV]TYP,7,8)
      If [F:PID]NETPRI=[F:PID]ORINETPRI & [F:PID]QTYSTU<>0 # avoir en quantité
         [F:PID]QTYSTU = SAV_QTYSTU
      Else
         [F:PID2]QTYSTU = SAV_QTYSTU
      Endif
   Else
      [F:PID2]QTYSTU = SAV_QTYSTU
   Endif
Endif
Return

#-----------------------------------------------------------
# Prise en compte des enregistrements [PSV] en création de réception
# On met à jour l'enregistrement [PSV] pris en compte  avec Réception
# quantité et éventuellement CPR et on créera un reliquat si besoin
$UPD_PTD_PSV
 Readlock [PSV]PSV0 Curr
 If fstat=1
   GOK=-1 : GLOCK="$PTDSTKVAL"-[F:PID]NUM :GOK = 0 : Return
 Elsif fstat
   GOK=0 : Call RSTA("PSV",[F:PID]NUM) From GLOCK
   Return
 Endif
 [F:PSV]QTYSTU    = WPECQTY
 [F:PSV]INVDTACST = abs(WINVDTACST)
 # FCC sur facture de commande et avoir sur FCC sur facture de commande
 # sous-traitance ?
 If find([F:PSV]TYP,5,11)
    If !find([F:PTD]VCRTYPORI,10,36)
      [F:PSV]CPR = WPECPRI
    Else
      [F:PSV]CPLPRI = WPECPRI
      [F:PSV]CPLCRG = WPECCRG
    Endif
 Endif
 [F:PSV]TIAFLG = 2
 [F:PSV]PTHNUM = [F:PTD]PTHNUM
 [F:PSV]PTDLIN = [F:PTD]PTDLIN
 Rewrite [F:PSV]
 If fstat GOK=0 : Call FSTA("PSV") From GLOCK : Return : Endif
Return

#-------------------------------------------------------------------
# Prise en compte des enregistrements [PSV] en création de réception
# Gestion du reliquat
$CRE_PTD_PSV
 Raz [PSV2]
 [F:PSV2] = [F:PSV]
 [F:PSV2]QTYSTU  = WREST
 # FCC sur facture de commande et avoir sur FCC sur facture de commande
 # Sous-traitance ???
 If find([F:PSV]TYP,5,11)
    If !find([F:PTD]VCRTYPORI,10,36)
      [F:PSV2]CPR = WRESTPRI
    Else
      [F:PSV2]CPLPRI = WRESTPRI
      [F:PSV2]CPLCRG = WRESTCRG
    Endif
Else
    [F:PSV2]CPR     = [F:PID]CPR
 Endif
 [F:PSV2]TIAFLG  = 1
 Raz [F:PSV2]PTHNUM
 Raz [F:PSV2]PTDLIN
 Raz [F:PSV2]INVDTACST
 Write [F:PSV2]
 If fstat GOK=0 : Call FSTA("PSV") From GLOCK : Return : Endif
Return

#-----------------------------------------------------------
# Depuis la tâche batch STCREG ou REGPRIX_FCC :
# On proratise les FCC sur commande et leurs avoirs
# Ecriture d'un enregistrement réception par réception
# Pas de FCC sur commande en sous-traitance
$CRE_PTD_PSV_FCC
 Raz [PSV]
 [F:PSV] = [F:PSV2]
 # Si on vient de STCREG : FCC/Avoir sur FCC sur commande,expéditions  ou réception  avec charge
 If [F:PID]CSTMAJLIN = 1 & [F:PID]FCSCOD <> ""
  [F:PSV]CPR    = abs(WMNTPECSOC)
  [F:PSV]QTYSTU = [F:PTD]QTYSTU
  [F:PSV]PTHNUM = [F:PTD]PTHNUM
  [F:PSV]PTDLIN = [F:PTD]PTDLIN
 # Si on vient de REGPRIX_FCC : FCC/Avoir sur FCC sur commande  ou expédition nouveau coût à OUI
 Else
  [F:PSV]CPR    = abs(WPRI)
  [F:PSV]QTYSTU = [F:PTD2]QTYSTU
  [F:PSV]PTHNUM = [F:PTD2]PTHNUM
  [F:PSV]PTDLIN = [F:PTD2]PTDLIN
 Endif
 [F:PSV]TIAFLG = 2

 Write [F:PSV]
 If fstat GOK=0 : Call FSTA("PSV") From GLOCK : Return : Endif
Return

#-----------------------------------------------------------
# Depuis REGPRIX_FCC : Solde de commande, commande partiellement réceptionnée.
# On proratise le reliquat des FCC sur facture/Cde et leurs avoirs (nouveau coût à OUI)
# Réception par réception, on modifie l'enregistrement PSV précédemment créé
$UPD_PTD_PSV_FCC
 Readlock [PSV]PSV0 = [F:PID]NUM;[F:PID]PIDLIN;[F:PTD2]PTHNUM;[F:PTD2]PTDLIN
 If fstat=1
   GOK=-1 : GLOCK="$PTDSTKVAL"-[F:PID]NUM :GOK = 0 : Return
 Elsif fstat
   GOK=0 : Call RSTA("PSV",[F:PID]NUM) From GLOCK
   Return
 Endif
 If !find([F:PTD2]VCRTYPORI,10,36)
  [F:PSV]CPR += abs(WPRI)
 Else
  [F:PSV]CPLPRI += abs([M:SBCK]CPLPRI)
  [F:PSV]CPLCRG += abs([M:SBCK]CPLCRG)
 Endif
 Rewrite [F:PSV]
 If fstat GOK=0 : Call FSTA("PSV") From GLOCK : Return : Endif
Return

#-----------------------------------------------------------
# On vient ici en validation de facture REGPRIX/COSTSTCR/REGPRIX_FCC
# On assume qu'on a tous les buffers PID/PID2/POQ/PTD/SHD nécessaires en ligne
# On assume que le buffer [F:POQ] est vide si facture/ FCC, ETC.  sur réception directe
# En entrée :
# LPTHNUM/LPTDLIN si on a pris en compte une réception (vide pour le reliquat)
# LQTYSTU : La quantité facturée prise en compte  si PTHNUM/PTDLIN renseignés ,sinon,  le reliquat
#-----------------------------------------------------------
Subprog CRE_PID_PSV(LPTHNUM,LPTDLIN,LQTYSTU,LPRI,LCPLPRI,LCPLCRG,LINVDTACST)
Value    Char      LPTHNUM
Value    Integer   LPTDLIN
Value    Decimal   LQTYSTU
Value    Decimal   LPRI
Value    Decimal   LCPLPRI
Value    Decimal   LCPLCRG
Value    Decimal   LINVDTACST
Local    Decimal   WRATCUR2
Local    Integer   STAT, WI
  Raz [F:PSV]
 [F:PSV] = [F:PID]
 [F:PSV]QTYSTU    = LQTYSTU
 [F:PSV]CPR       = LPRI
 [F:PSV]CPLPRI    = LCPLPRI
 [F:PSV]CPLCRG    = LCPLCRG
 # si facture/Avoir sur facture, NETPRI est renseigné, on l'a récupéré par Transclass
 # si FCC ou avoir sur FCC, NETPRI = 0. Il faut le recalculer
 # si FCC
 If [F:PID]PIHTYP = 2
    # FCC  sur commande
    If [F:PID]TYPORI = 1
       [F:PSV]NETPRI = arr([F:PID]AMTNOTLIN / [F:POQ]QTYUOM,10^-GDECPRI)
    # FCC  sur réception
    Elsif [F:PID]TYPORI = 2
       [F:PSV]NETPRI = arr([F:PID]AMTNOTLIN / [F:PTD]QTYUOM,10^-GDECPRI)
    # FCC  sur facture
    Elsif [F:PID]TYPORI = 4
       [F:PSV]NETPRI = arr([F:PID]AMTNOTLIN / [F:PID2]QTYUOM,10^-GDECPRI)
    # FCC sur expé
    Elsif [F:PID]TYPORI = 6
      [F:PSV]NETPRI = arr([F:PID]AMTNOTLIN / [F:SHD]SHIQTY,10^-GDECPRI)
    Endif
 # si avoir
 Elsif [F:PID]PIHTYP=3
    Read [F:PID3]PID0 = [F:PID]NUMORI;[F:PID]LINORI
    If fstat : Raz [F:PID3] : Endif
    # Si Avoir sur FCC
    If [F:PID3]PIHTYP = 2
      # Avoir sur FCC sur commande
      If [F:PID3]TYPORI = 1
        [F:PSV]NETPRI = arr([F:PID]AMTNOTLIN / [F:POQ]QTYUOM,10^-GDECPRI)
      # Avoir sur FCC sur réception
      Elsif [F:PID3]TYPORI = 2
         [F:PSV]NETPRI = arr([F:PID]AMTNOTLIN / [F:PTD]QTYUOM,10^-GDECPRI)
      # Avoir sur FCC sur facture
      Elsif [F:PID3]TYPORI = 4
        # FCC/Avoir sur FCC sur facture : PID2 contient toujours la facture "normale" d'origine
          [F:PSV]NETPRI = arr([F:PID]AMTNOTLIN / [F:PID2]QTYUOM,10^-GDECPRI)
     # Avoir sur FCC sur expé
      Elsif [F:PID3]TYPORI = 6
        [F:PSV]NETPRI = arr([F:PID]AMTNOTLIN / [F:SHD]SHIQTY,10^-GDECPRI)
      Endif
    Endif
 Endif
 # Exprimer NETPRI en devise société et unité de stock
 Raz GBIDD3
 If [F:PID]QTYPUU <> 0
  Call PCAL_QTY([F:PID]QTYPUU,[F:PID]PUU,GBIDD1,[F:PID]STU,
&       [F:PID]ITMREF,[F:PID]BPSNUM,1,GBIDD3) From TRTACHQTE1
 Endif
 If GBIDD3=0 GBIDD3=1 : Endif
 #----- Prix net exprimé en unité de stock -----#
 If [F:PID]UOMPUUCOE=0  [F:PID]UOMPUUCOE=1 : Endif
 [F:PSV]NETPRI=[F:PSV]NETPRI/([F:PID]UOMPUUCOE*GBIDD3)
 #----- Prix net exprimé en devise société -----#
 WI=find(GLOCALDEV,[F:PIH]CURLED)
 If WI & [F:PIH]RATDIV(WI-1)<>0
   WRATCUR2=[F:PIH]RATMLT(WI-1)/[F:PIH]RATDIV(WI-1)
 Else
   WRATCUR2=0
 Endif
 If WRATCUR2=0
   Call CONVERT2([F:PIH]CUR,GCUR,GCUR,[F:PIH]CURTYP,[F:PIH]RATDAT,[F:PSV]NETPRI,[F:PSV]NETPRI,
&              STAT) From TRTDEV
 Else
   [F:PSV]NETPRI=[F:PSV]NETPRI*WRATCUR2
 Endif
 # Si sous-traitance : On a forcément une commande
  If LPRI = 0 & LCPLPRI <> 0
   [F:PSV]VCRTYPORI = [F:POQ]VCRTYPORI
   [F:PSV]VCRNUMORI = [F:POQ]VCRNUMORI
   [F:PSV]VCRLINORI = [F:POQ]VCRLINORI
   [F:PSV]ITMREFORI = [F:POQ]ITMREFORI
 Endif
 Raz [F:PSV]PTHNUM
 Raz [F:PSV]PTDLIN
 [F:PSV]TIAFLG = 1
 If LPTHNUM <> ""
   [F:PSV]PTHNUM = LPTHNUM
   [F:PSV]PTDLIN = LPTDLIN
   [F:PSV]TIAFLG = 2
   [F:PSV]INVDTACST = LINVDTACST # Si réception renseignée, WINVDTACST est en devise société à coup sûr
 Endif
 [F:PSV]VALDATTIM = datetime$ # Date/Time de validation de la facture en cours de traitement
 #
 # La zone technique "TYP" nous indique quel type de facture on traite (utile pour l'exploitation future) :
 # 1 : Facture sur commande
 # 2 : Facture sur réception
 # 3 : FCC sur commande
 # 4 : FCC sur expédition
 # 5 : FCC sur facture de commande
 # 6 : FCC sur facture de réception
 # 7 : Avoir sur facture sur commande
 # 8 : Avoir sur facture sur réception
 # 9 : Avoir sur FCC sur commande
 # 10 : Avoir sur FCC sur expédition
 # 11 : Avoir sur FCC sur facture sur commande
 # 12 : Avoir sur FCC sur facture sur réception
 # 13 : FCC sur réception
 # 14 : Avoir sur FCC sur réception
 # récupérer la clé de la ligne de commande dans tous les cas
 Case [F:PID]PIHTYP :
    When 1
      Case [F:PID]TYPORI :
        When 1 : [F:PSV]TYP = 1                            # Facture sur commande
                 [F:PSV]POHNUM = [F:PID]NUMORI
                 [F:PSV]POPLIN = [F:PID]LINORI
                 [F:PSV]POQSEQ = [F:PID]SEQORI
        When 2 : [F:PSV]TYP = 2                            # Facture sur réception
                 [F:PSV]POHNUM = [F:PTD]POHNUM
                 [F:PSV]POPLIN = [F:PTD]POPLIN
                 [F:PSV]POQSEQ = [F:PTD]POQSEQ
      Endcase
    When 2
      Case [F:PID]TYPORI
        When 1 : [F:PSV]TYP = 3                             # FCC sur commande
                 [F:PSV]POHNUM = [F:POQ]POHNUM
                 [F:PSV]POPLIN = [F:POQ]POPLIN
                 [F:PSV]POQSEQ = [F:POQ]POQSEQ
        When 2 : [F:PSV]TYP = 13                             # FCC sur réception
                 [F:PSV]POHNUM = [F:PTD]POHNUM
                 [F:PSV]POPLIN = [F:PTD]POPLIN
                 [F:PSV]POQSEQ = [F:PTD]POQSEQ
        When 6 : [F:PSV]TYP = 4                             # FCC sur expédition
                 [F:PSV]SHIPNUM = [F:PID]NUMORI
                 [F:PSV]SHIPLIN = [F:PID]LINORI
                 [F:PSV]POHNUM  = [F:SHD]POHNUM
                 [F:PSV]POPLIN  = [F:SHD]POPLIN
                 [F:PSV]POQSEQ  = [F:SHD]POQSEQ
        When 4 : Read [PID3]PID0 = [PID]NUMORI;[PID]LINORI
                 If  [F:PID3]TYPORI = 1 : [PSV]TYP = 5    # FCC sur facture de commande
                     [F:PSV]POHNUM = [F:PID3]NUMORI
                     [F:PSV]POPLIN = [F:PID3]LINORI
                     [F:PSV]POQSEQ = [F:PID3]SEQORI
                 Elsif [F:PID3]TYPORI = 2 : [PSV]TYP = 6    # FCC sur facture de réception
                     [F:PSV]POHNUM = [F:PTD]POHNUM
                     [F:PSV]POPLIN = [F:PTD]POPLIN
                     [F:PSV]POQSEQ = [F:PTD]POQSEQ
                 Endif
      Endcase
    When 3
      Read [PID3]PID0 = [PID]NUMORI;[PID]LINORI # Lecture de la Facture d'origine
      Case [F:PID3]PIHTYP
        When 1 : If [F:PID3]TYPORI = 1 : [PSV]TYP = 7    # Avoir sur facture de commande
                    [F:PSV]POHNUM = [F:PID3]NUMORI
                    [F:PSV]POPLIN = [F:PID3]LINORI
                    [F:PSV]POQSEQ = [F:PID3]SEQORI
                 Elsif [F:PID3]TYPORI = 2 : [PSV]TYP = 8    # Avoir sur facture de réception
                    [F:PSV]POHNUM = [F:PTD]POHNUM
                    [F:PSV]POPLIN = [F:PTD]POPLIN
                    [F:PSV]POQSEQ = [F:PTD]POQSEQ
                 Endif
        When 2 : If [F:PID3]TYPORI = 1 : [PSV]TYP = 9    # Avoir sur FCC sur commande
                    [F:PSV]POHNUM = [F:PID3]NUMORI
                    [F:PSV]POPLIN = [F:PID3]LINORI
                    [F:PSV]POQSEQ = [F:PID3]SEQORI
                 Elsif [F:PID3]TYPORI = 2 : [F:PSV]TYP = 14 # Avoir sur FCC sur réception
                    [F:PSV]POHNUM = [F:PTD]POHNUM
                    [F:PSV]POPLIN = [F:PTD]POPLIN
                    [F:PSV]POQSEQ = [F:PTD]POQSEQ
                 Elsif [F:PID3]TYPORI = 6 : [PSV]TYP = 10   # Avoir sur FCC sur expédition
                    [F:PSV]SHIPNUM = [F:PID3]NUMORI
                    [F:PSV]SHIPLIN = [F:PID3]LINORI
                    [F:PSV]POHNUM  = [F:SHD]POHNUM
                    [F:PSV]POPLIN  = [F:SHD]POPLIN
                    [F:PSV]POQSEQ  = [F:SHD]POQSEQ
                 Elsif [F:PID3]TYPORI = 4
                   Read [PID4]PID0 = [PID3]NUMORI;[PID3]LINORI
                   If  [F:PID4]TYPORI = 1 : [PSV]TYP = 11   # Avoir sur FCC sur facture de commande
                       [F:PSV]POHNUM = [F:PID4]NUMORI
                       [F:PSV]POPLIN = [F:PID4]LINORI
                       [F:PSV]POQSEQ = [F:PID4]SEQORI
                   Elsif [PID4]TYPORI = 2 : [PSV]TYP = 12   # Avoir sur FCC sur facture de réception
                       [F:PSV]POHNUM = [F:PTD]POHNUM
                       [F:PSV]POPLIN = [F:PTD]POPLIN
                       [F:PSV]POQSEQ = [F:PTD]POQSEQ
                   Endif
                 Endif
      Endcase
 Endcase
 Write [F:PSV]
 If fstat GOK=0 : Call FSTA("PSV") From GLOCK : End : Endif
End

# Issue X3-25003 - 2018-02-02 by SR : Calcul de CPLPRI/NETPRI pour sous-traitance avec proratisation
# pour création enregistrement reliquat en cours de prise en compte depuis les réceptions (si FCC sur facture de cde et leurs avoir)
##################################################
$CAL_CPLPRI_PRO
Gosub CAL_CPR_PID_PRO
Call PCAL_QTY([F:PID]QTYPUU,[F:PID]PUU,GBIDD1,[F:PTD]STU,
&                 [F:PID]ITMREF,[F:PID]BPSNUM,1,GBIDD3) From TRTACHQTE1
If GBIDD3=0 GBIDD3=1 : Endif
#----- Prix net exprimé en unité de stock -----#
If [F:PID]UOMPUUCOE=0  [F:PID]UOMPUUCOE=1 : Endif
If [F:PID]QTYUOM <> 0
  WNETPRI=[F:PID]NETPRI/([F:PID]UOMPUUCOE*GBIDD3)
Else
  WNETPRI = [F:PID]AMTNOTLIN
Endif
#----- Prix net exprimé en devise société -----#
WI=find(GLOCALDEV,[F:PIH]CURLED)
If WI & [F:PIH]RATDIV(WI-1)<>0
   WRATCUR=[F:PIH]RATMLT(WI-1)/[F:PIH]RATDIV(WI-1)
Else
   WRATCUR=0
Endif
If WRATCUR=0
   Call CONVERT2([F:PIH]CUR,GCUR,GCUR,[F:PIH]CURTYP,[F:PIH]RATDAT,WNETPRI,WNETPRI,
&                   STAT) From TRTDEV
Else
   WNETPRI=WNETPRI*WRATCUR
Endif
WNETPRI = arr(WNETPRI,10^-8)
#-----
Return

##################################################
$CAL_CPR_PID_PRO
  If [F:PID]QTYUOM <> 0
    WPRI = [F:PID]NETPRI
  Else
    WPRI = [F:PID]AMTNOTLIN
  Endif
 #----- Eléments provenant du tarif -----#
 Raz WDISCRGVAL
 For I=1 To 9
   If GINVDTALIN(I-1)<>0 & GNPRNOTFLG(I-1)=1
     Read [PFI] PFI0=GINVDTALIN(I-1) : If fstat Raz [F:PFI] : Endif
     If [F:PFI]NPRVLT=2
       #----- C'est un montant -----#
       If GDISCRGTYP(I-1)=1
         If GCLCRUL(I-1)=1 : # Par unité
           WDISCRGVAL+=evalue("[F:PID]DISCRGVAL"+num$(I))*[F:PID]QTYUOM
         Else              : # Par ligne
           WDISCRGVAL+=evalue("[F:PID]DISCRGVAL"+num$(I))
         Endif
       #----- C'est un pourcentage -----#
       Else
         WDISCRGVAL+=arr([F:PID]AMTNOTLIN*evalue("[F:PID]DISCRGVAL"+num$(I))/100,WRND)
       Endif
     Endif
   Endif
 Next I
 If [F:PID]QTYUOM <>0
   WPRI += WDISCRGVAL / [F:PID]QTYUOM
 Else
   WPRI += WDISCRGVAL
 Endif
 #----- Eléments provenant du pied de facture -----#
 Raz WDISCRGAMT
 If !clalev([F:PVF2]) Local File PVCRFOOT [PVF2] : Endif
 Filter [F:PVF2] Where VCRTYP=8 & VCRNUM=[F:PID]NUM & INVLINFLG <> 6
 For [PVF2]
   If [F:PFI]PFINUM <> [F:PVF2]INVDTA
     Read [PFI] PFI0=[F:PVF2]INVDTA : If fstat Raz [F:PFI] : Endif
   Endif
   If [F:PFI]NPRVLT=2
     I=find([F:PVF2]INVDTA,[F:PIV]INVDTALIN2(0..8))
     If I<>0
       WDISCRGAMT+=evalue("[F:PID]DISCRGAMT"+num$(I))
     Endif
   Endif
 Next
 Filter [F:PVF2]
 If [F:PID]QTYUOM <>0
   WPRI += WDISCRGAMT / [F:PID]QTYUOM
 Else
   WPRI += WDISCRGAMT
 Endif
 If GNODVATSTO = 2
   #----- Taxes non déductible -----#
   WTAXE=[F:PID]AMTTAXLIN1-[F:PID]DEDTAXLIN1
   WTAXE+=[F:PID]AMTTAXLIN2-[F:PID]DEDTAXLIN2
   WTAXE+=[F:PID]AMTTAXLIN3-[F:PID]DEDTAXLIN3
   If dim([F:PID]AMTTAXRCP)>0
     WTAXE+=[F:PID]AMTTAXRCP-[F:PID]DEDTAXRCP
     WTAXE+=[F:PID]AMTTAXISS-[F:PID]DEDTAXISS
     WTAXE+=[F:PID]AMTTAXOTH1-[F:PID]DEDTAXOTH1
     WTAXE+=[F:PID]AMTTAXOTH2-[F:PID]DEDTAXOTH2
   Endif
   If [F:PID]QTYUOM <>0
     WPRI += WTAXE / [F:PID]QTYUOM
   Else
     WPRI += WTAXE
   Endif
 Endif
 # facture en devise
 If WPRI<>0 & GLOCALDEV<>[F:PIH]CUR
   Call CONVERT_PIH(WPRI,WPRI) From TRTACHFAC1
 Endif
Return


