#-----------------------------------------------------------------------#
# Test demande inter-site                                               #
#-----------------------------------------------------------------------#
$CHK_TP
# 10.04 resynchro TPS orphelines, on vérifie si la TRS est là (même n° pièce)
If WWIPSTA = 3
    OK = 1
    Filter [ORD1] Where WIPTYP=7 & ORIFCY=WSTOFCY & ITMREF=WITMREF & VCRNUM=WVCRNUM
    For [ORD1]ORD0
        OK = 9
        Break
    Next
    Filter [ORD1]

    If OK = 1
        WMESS = mess(WWIPTYP,306,1)+" "+WVCRNUM+"/"+WITMREF
        WMESS1 = "        "+mess(608,197,1)
        If [M:DIA]AUTCOR = 1
            Call ECR_TRACE(WMESS,0) From GESECRAN
            Call ECR_TRACE(WMESS1,0) From GESECRAN
            Raz WMESS, WMESS1
            NBORD += 1
            OK  = 9
            Return
        Endif
        Call DEBTRANS From GLOCK
        Trbegin [ORD]
            Raz [M:ORDK]
            [M:ORDK]MAJCOD     = "A"
            [M:ORDK]WIPTYP     = WWIPTYP
            [M:ORDK]WIPNUM     = WWIPNUM
            [M:ORDK]ITMREF     = WITMREF
            Call WIP From TRTWIP
            If GOK < 1 : Goto AB_TRTORD : Endif
            NBMAJ += 1
        Commit
        OK  = 9
    Endif
    Return
Endif

Read [SOH]SOH0=WVCRNUM
If fstat
    OK = 1
    WMESS1 = "        "+mess(261,197,1)
    Goto TP_NXT
Endif
Read [SOQ]SOQ0=WVCRNUM;WVCRLIN;WVCRSEQ
If fstat
    OK = 1
    WMESS1 = "        "+mess(262,197,1)
    Goto TP_NXT
Endif
# Bug 76699
If [F:SOQ]STOFCY <> [F:ORD]STOFCY
    OK = 1
    WMESS1 = "        "+mess(783,197,1)
    Goto TP_NXT
Endif
# Bug 76699
If [F:SOQ]SOQSTA = 3 & [F:SOQ]ODLQTYSTU = 0
    OK = 1
    WMESS1 = "        "+mess(254,197,1)
    Goto TP_NXT
Endif
If [F:SOQ]QTYSTU <> [F:ORD]EXTQTY & ([F:SOH]APPFLG>2 | GSOHAPPORD=2)
    OK = 2
    WMESS1 = "        "+mess(255,197,1)
    Goto TP_NXT
Endif
If [F:SOQ]DLVQTYSTU <> [F:ORD]CPLQTY
    OK = 2
    WMESS1 = "        "+mess(256,197,1)
    Goto TP_NXT
Endif

GPOINT = "CHK_TP" : Gosub ENTREE From EXEFNC : # GH 15/05/12 dm 80740
If OK=1
   Goto TP_NXT
Endif

Raz WALL, WSHT
If [F:SOQ]OPRQTYSTU + [F:SOQ]PREQTYSTU > 0
   #--- Issue 116484
   #Filter [PRE] Where ORINUM=WVCRNUM & ORILIN=WVCRLIN & ORISEQ=WVCRSEQ
#&               Order By Key CLE=ORINUM;ORILIN;ORISEQ
   #For [PRE]
   Filter [PRE] Where ORINUM=WVCRNUM & ORILIN=WVCRLIN & ORISEQ=WVCRSEQ
   For [PRE]PRE1
   #---
      # Lecture de l'entête de préparation
      Read [PRH]PRH0=[F:PRE]PRHNUM
      # Elle n'existe pas encore ou la prépa n'est pas livrée
      If fstat | [F:PRH]SDHNUM=""
         WALL += [F:PRE]ALLQTY
         WSHT += [F:PRE]SHTQTY
      Endif
   Next
   Filter [PRE]
Endif

If OK=2
   Goto TP_NXT
Endif

#--- Bug 70782
WWRK = [F:SOQ]ALLQTYSTU + WALL + [F:SOQ]ODLQTYSTU
#WWRK = [F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU
#---
If WWRK <> [F:ORD]ALLQTY
    OK = 2
    WMESS1 = "        "+mess(258,197,1)
    Goto TP_NXT
Endif
#--- Bug 70782
If [F:SOQ]SHTQTYSTU + WSHT <> [F:ORD]SHTQTY
#If [F:SOQ]SHTQTYSTU <> [F:ORD]SHTQTY
#---
    OK = 2
    WMESS1 = "        "+mess(259,197,1)
    Goto TP_NXT
Endif
$TP_NXT
If OK = 2
    WEXTQTY = [F:SOQ]QTYSTU
    WCPLQTY = [F:SOQ]DLVQTYSTU
    #--- Bug 70782
    WALLQTY = [F:SOQ]ALLQTYSTU + WALL + [F:SOQ]ODLQTYSTU
    WSHTQTY = [F:SOQ]SHTQTYSTU + WSHT
    #WALLQTY = [F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU
    #WSHTQTY = [F:SOQ]SHTQTYSTU
    #---
Endif
Return

#-----------------------------------------------------------------------#
# Test sous-produit                                                     #
#-----------------------------------------------------------------------#
$CHK_BW
If WABB = "SCIW"
    Read [SCOW]SCO0=WVCRNUM
    If fstat
        OK = 1
        WMESS1 = "        "+mess(261,197,1)
        Goto BW_NXT
    Endif
    If [F:SCOW]SCOSTA > 2
        OK = 1
        WMESS1 = "        "+mess(253,197,1)
        Goto BW_NXT
    Endif
    Return
Endif
Read [MFIW]MFI0=WVCRNUM;WVCRLIN
If fstat
    OK = 1
    WMESS1 = "        "+mess(262,197,1)
    Goto BW_NXT
Endif
If [F:MFIW]ITMSTA > 2
    OK = 1
    WMESS1 = "        "+mess(254,197,1)
    Goto BW_NXT
Endif
If [F:MFIW]EXTQTY <> [F:ORD]EXTQTY
    OK = 2
    WMESS1 = "        "+mess(255,197,1)
    Goto BW_NXT
Endif
If [F:MFIW]CPLQTY <> [F:ORD]CPLQTY
    OK = 2
    WMESS1 = "        "+mess(256,197,1)
    Goto BW_NXT
Endif
If [F:MFIW]RMNEXTQTY <> [F:ORD]RMNEXTQTY
    OK = 2
    WMESS1 = "        "+mess(257,197,1)
    Goto BW_NXT
Endif
$BW_NXT
If OK = 2
    WEXTQTY = [F:MFIW]EXTQTY
    WCPLQTY = [F:MFIW]CPLQTY
    WALLQTY = 0
    WSHTQTY = 0
Endif
Return

#-----------------------------------------------------------------------#
# Traitement d'un encours                                               #
#-----------------------------------------------------------------------#
$TRTORD
Gosub MAJORD
Return

#-----------------------------------------------------------------------#
# Mise à jour des encours                                               #
#-----------------------------------------------------------------------#
$MAJORD
#
Case WWIPTYP
    When 1,8:   WMESS = mess(WWIPTYP,306,1)+" "+WVCRNUM+"/"+num$(WVCRLIN)+"/"+
&                       num$(WVCRSEQ)+" "+WITMREF
    When 2:     Case WWIPSTA
                   When 1:    WMESS = mess(WWIPTYP,306,1)+" "+WVCRNUM+"/"+num$(WVCRLIN)+"/"+
&                                     num$(WVCRSEQ)+" "+WITMREF
                   When 2:    Case WABB
                                  When "POC" : WMESS = mess(222,197,1)+" "+WVCRNUM+"/"+
&                                              num$(WVCRLIN)+"/"+num$(WVCRSEQ)+" "+WITMREF
                                  When "PSD" : WMESS = mess(222,197,1)+" "+WVCRNUM+"/"+
&                                              num$(WVCRLIN)+" "+WITMREF
                              Endcase
                Endcase
    When 4:     If WOPENUM = 0
                   WMESS = mess(WWIPTYP,306,1)+" "+WVCRNUM+" "+WITMREF
                Else
                   WMESS = mess(WWIPTYP,306,1)+" "+WVCRNUM+"/"+num$(WOPENUM)+" "+
&                          num$(WOPESPLNUM)+" "+WITMREF
                Endif
    When 5,6,9: WMESS = mess(WWIPTYP,306,1)+" "+WVCRNUM+"/"+num$(WVCRLIN)+" "+WITMREF
    When 3,13:  WMESS = mess(WWIPTYP,306,1)+" "+WVCRNUM+"/"+num$(WVCRLIN)+" "+WITMREF
    When 7:     WMESS = mess(WWIPTYP,306,1)+" "+WVCRNUM+"/"+num$(WVCRLIN)+"/"+
&                       num$(WVCRSEQ)+" "+WITMREF
Endcase
If [M:DIA]AUTCOR = 1 : Goto FINMAJ : Endif
Call DEBTRANS From GLOCK
Trbegin [ORD]
        Raz [M:ORDK]
        Case OK
            When 1:    [M:ORDK]MAJCOD     = "A"
                       [M:ORDK]WIPTYP     = WWIPTYP
                       [M:ORDK]WIPNUM     = WWIPNUM
                       [M:ORDK]ITMREF     = WITMREF
                       Call WIP From TRTWIP
                       If GOK < 1 : Goto AB_TRTORD : Endif
            When 2:    [M:ORDK]MAJCOD     = "M"
                       [M:ORDK]WIPTYP     = WWIPTYP
                       [M:ORDK]WIPSTA     = [F:ORD]WIPSTA
                       [M:ORDK]WIPNUM     = WWIPNUM
                       [M:ORDK]ITMREF     = WITMREF
                       [M:ORDK]ORIFCY     = [F:ORD]ORIFCY
                       [M:ORDK]STOFCY     = [F:ORD]STOFCY
                       [M:ORDK]PJT        = [F:ORD]PJT
                       [M:ORDK]BPRNUM     = [F:ORD]BPRNUM
                       [M:ORDK]STRDAT     = [F:ORD]STRDAT
                       [M:ORDK]ENDDAT     = [F:ORD]ENDDAT
                       [M:ORDK]VCRTYP     = [F:ORD]VCRTYP
                       [M:ORDK]VCRNUM     = [F:ORD]VCRNUM
                       [M:ORDK]VCRLIN     = [F:ORD]VCRLIN
                       [M:ORDK]VCRSEQ     = [F:ORD]VCRSEQ
                       [M:ORDK]EXTQTY     = WEXTQTY
                       [M:ORDK]CPLQTY     = WCPLQTY
                       [M:ORDK]ALLQTY     = WALLQTY
                       [M:ORDK]SHTQTY     = WSHTQTY
                       [M:ORDK]FMI        = [F:ORD]FMI
                       [M:ORDK]MRPMES     = [F:ORD]MRPMES
                       [M:ORDK]MRPQTY     = [F:ORD]MRPQTY
                       [M:ORDK]MRPDAT     = [F:ORD]MRPDAT
                       [M:ORDK]VCRTYPORI  = [F:ORD]VCRTYPORI
                       [M:ORDK]VCRNUMORI  = [F:ORD]VCRNUMORI
                       [M:ORDK]VCRLINORI  = [F:ORD]VCRLINORI
                       [M:ORDK]VCRSEQORI  = [F:ORD]VCRSEQORI
                       [M:ORDK]ITMREFORI  = [F:ORD]ITMREFORI
                       [M:ORDK]BOMALT     = [F:ORD]BOMALT
                       [M:ORDK]BOMALTTYP  = [F:ORD]BOMALTTYP    # V6
                       [M:ORDK]ORI        = [F:ORD]ORI
                       [M:ORDK]ABBFIL     = [F:ORD]ABBFIL
                       [M:ORDK]PIO        = [F:ORD]PIO
                       Call WIP From TRTWIP
                       If GOK < 1 : Goto AB_TRTORD : Endif
        Endcase
 NBMAJ += 1
Commit
#
$FINMAJ
Call ECR_TRACE(WMESS,0) From GESECRAN
Call ECR_TRACE(WMESS1,0) From GESECRAN
Raz WMESS, WMESS1
NBORD += 1
Return

$ROL_TRTORD
Rollback
Call ROLL From GLOCK
If GROLL
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Else Goto MAJORD :Endif
Return

$AB_TRTORD
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

########################################################################
$TRT_MTOLINK
NBMTO = 0
Call ECR_TRACE(WMESS,0) From GESECRAN
WMESS1 = mess(750,197,1) : # Recalcul des affectations
Call ECR_TRACE(WMESS1,0) From GESECRAN

Gosub SEL_ORD
For [ITF]ITF0 Where evalue(CRITERE)
    Gosub MAJ_MTOLINK
Next
Return

########################################################################
$MAJ_MTOLINK
# règle d'affectation
If [F:ITF]PTOCOD = "" : WPTOCOD = GDEFPTO : Else : WPTOCOD = [F:ITF]PTOCOD : Endif
If [F:PTO]PTOCOD <> WPTOCOD
    Read [PTO]PTO0=WPTOCOD
    If fstat : Raz [F:PTO] : Endif
Endif

# PEC dans traitements auto ?
If [F:PTO]PTOAUT = 2
 GOK=1
 Trbegin [MLK]
    Raz [M:MLIK]
    [M:MLIK]MAJCOD    = "P"
    [M:MLIK]PRPTYP    = 1
    [M:MLIK]PRPMOD    = 1
    [M:MLIK]STOFCY    = [F:ITF]STOFCY
    [M:MLIK]ITMREF    = [F:ITF]ITMREF
    [M:MLIK]TRTNAM    = "FUNMSYNCW"
    [M:MLIK]FRCPRO    = 2
    [M:MLIK]FEEDBACK  = 1
    Call UPDMTOLINK From MTOLINKLIB
 If GOK>0 : Commit
 Else     : Rollback
  If GOK<0 & GLOCK<>""
   Call ECR_LOCK("T") From GLOCK
  Endif
 Endif

 If GOK>0 : NBMTO+=1 : Endif
Endif
Return

########################################################################
$TRT_ITV
NBITV = 0
Call ECR_TRACE(WMESS,0) From GESECRAN
WMESS1 = mess(595,197,1) : # Resynchronisation > en réappro/en commande
Call ECR_TRACE(WMESS1,0) From GESECRAN

Gosub SEL_ORD
For [ITV]ITV0 Where evalue(CRITERE)
    Gosub MAJ_ITV
Next
Return

########################################################################
$MAJ_ITV
Call DEBTRANS From GLOCK
Trbegin [ITV]
    Readlock [ITV]ITV0 Curr
    If fstat = 1 : Call ECR_TRACE(mess(20,100,1)+" : [ITV]"+[F:ITV]ITMREF+";"+[F:ITV]STOFCY,1) From GESECRAN
                   Rollback    : #--- Issue 53734
                 :  mkstat = 0 : Return
    Endif
    If fstat     : Call ECR_TRACE(mess(12,100,1)+" : [ITV]"+[F:ITV]ITMREF+";"+[F:ITV]STOFCY,1) From GESECRAN
                   Rollback   : #--- Issue 53734
                 : mkstat = 0 : Return
    Endif
    [F:ITV]SALSTO = 0
    [F:ITV]ORDSTO = 0
    For [ORD]ORD1 Where STOFCY=[F:ITV]STOFCY & ITMREF=[F:ITV]ITMREF &
&                       WIPSTA=1 & find(WIPTYP,1,2,5,7,8,9)<>0
        If find([F:ORD]WIPTYP,1,8)
            [F:ITV]SALSTO += [F:ORD]RMNEXTQTY
        Else
            [F:ITV]ORDSTO += [F:ORD]RMNEXTQTY
        Endif
    Next
    Rewrite [ITV]
    If fstat : Call ECR_TRACE(mess(13,100,1)+" : [ITV]"+[F:ITV]ITMREF+";"+[F:ITV]STOFCY,1) From GESECRAN
                   Rollback   : #--- Issue 53734
                 : mkstat = 0 : Return
    Endif
    NBITV += 1
Commit
Return

########################################################################
# llc 09.02 15776
$REGEN_WO

If clalev([M:MFGK])  = 0 : Local Mask MFGK  [MFGK]  : Endif



CRITERE  = 'MFGFCY ="'+[M:DIA]STOFCY+'"'            # site de stockage
If [M:DIA]ITMREF <> ""
    CRITERE  += '& ITMREF ="'+[M:DIA]ITMREF+'"'       # article
Endif

Link [MFIW] With [MFGW]MFG0=[F:MFIW]MFGNUM As [MFX]
&          Where evalue(CRITERE) &
&                         [F:MFGW]MFGSTA < 3 &
&                         [F:MFGW]MFGTRKFLG < 5 &
&                         [F:MFIW]ITMTYP = 1 &
&                         [F:MFIW]ITMSTA < 4
For [MFX]
    Raz [M:MFGK] : # GH 04/03/2013 bug 88233 par homogénéité avec les EO
    [M:MFGK]CODMAJ = "M"
    [M:MFGK]CODTRS = 2
    [M:MFGK]MFGNUM = [F:MFIW]MFGNUM
    [M:MFGK]MFGLIN = [F:MFIW]MFGLIN
    [M:MFGK]MFGFCY = [F:MFIW]MFGFCY
    [M:MFGK]MFGSTA = [F:MFIW]MFGSTA
    [M:MFGK]ITMREF = [F:MFIW]ITMREF

    # Issue 102513 - 2018-07-31 by STLIG : communicate versions to MAJ_OF
    [M:MFGK]ECCVALMAJ = [F:MFIW]ECCVALMAJ
    [M:MFGK]ECCVALMIN = [F:MFIW]ECCVALMIN
    [M:MFGK]ROUECCMAJ = [F:MFGW]ROUECCMAJ
    [M:MFGK]ROUECCMIN = [F:MFGW]ROUECCMIN

    [M:MFGK]PRVQTY = [F:MFIW]EXTQTY
    [M:MFGK]EXTQTY = [F:MFIW]EXTQTY
    [M:MFGK]STRDAT = [F:MFIW]STRDAT
    [M:MFGK]ENDDAT = [F:MFIW]ENDDAT
    [M:MFGK]BOMALT = [F:MFIW]BOMALT
    [M:MFGK]ROUNUM = [F:MFGW]ROUNUM
    [M:MFGK]ROUALT = [F:MFGW]ROUALT
    [M:MFGK]PJT    = [F:MFIW]PJT
    [M:MFGK]MFGDES = [F:MFIW]MFGDES   : # GH 04/01/12 bug 78926
    [M:MFGK]LOT    = [F:MFIW]LOT
    [M:MFGK]SYNCHRO = 2
    Call MAJ_OF From MFGAUTLIB
Next

Return

########################################################################
# Achats de sous-traitance GA 03/2006
$REGEN_EO

If clalev([M:SCOK])  = 0 : Local Mask SCOK  [SCOK]  : Endif
CRITERE  = 'PRHFCY ="'+[M:DIA]STOFCY+'"'            # site de réception
If [M:DIA]ITMREF <> ""
    CRITERE  += '& ITMREF ="'+[M:DIA]ITMREF+'"'       # article
Endif

Link [SCIW] With [SCOW]SCO0=[F:SCIW]SCONUM As [SCX]
&          Where evalue(CRITERE) &
&                         [F:SCOW]SCOSTA < 3 &
&                         [F:SCOW]SCOTRKFLG < 5 &
&                         [F:SCIW]ITMSTA < 5

For [SCX]
    Raz [M:SCOK]                       : # GH 04/03/2013 bug 88233
    [M:SCOK]CODMAJ = "M"
    [M:SCOK]CODTRS = 2
    [M:SCOK]SCONUM = [F:SCIW]SCONUM
    [M:SCOK]SCILIN = [F:SCIW]SCILIN
    [M:SCOK]MFGFCY = [F:SCOW]MFGFCY
    [M:SCOK]POHFCY = [F:SCOW]POHFCY    : # GH 04/03/2013 bug 88233
    [M:SCOK]PRHFCY = [F:SCIW]PRHFCY    : # GH 04/03/2013 bug 88233
    [M:SCOK]STOFCY = [F:SCIW]PRHFCY    : # GH 04/03/2013 bug 88233
    [M:SCOK]SCOSTA = [F:SCOW]SCOSTA
    [M:SCOK]ITMREF = [F:SCIW]ITMREF
    [M:SCOK]PRVQTY = [F:SCIW]EXTQTY
    [M:SCOK]EXTQTY = [F:SCIW]EXTQTY
    [M:SCOK]STRDAT = [F:SCOW]ORDDAT
    [M:SCOK]ENDDAT = [F:SCOW]RETDAT
    [M:SCOK]BOMALT = [F:SCIW]BOMALT
    [M:SCOK]PJT    = [F:SCIW]PJT
    [M:SCOK]SCODES = [F:SCOW]SCODES    : # GH 04/01/12 bug 78926
    [M:SCOK]LOT    = [F:SCIW]LOT
    [M:SCOK]BPRNUM = [F:SCOW]BPRNUM    : # Bug 83438
    [M:SCOK]SYNCHRO = 2
    Call MAJ_SCO From SCOAUTLIB
Next

Return

########################################################################
$CHARG_PARAM
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
If GMODU(5) = 2
    # --> Récupération du paramètre vente : GSOHAPPORD    : Encours si commandes non signées
    Local Char     WPARAM(GLONADP)
    Call PARAM(GFCY,"SOHAPPORD",WPARAM) From ADOVAL
    GSOHAPPORD= val(WPARAM)
Endif
Return

########################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

#######################################################################
## Etiquettes (écran SYNCW)
#######################################################################

Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
GFCY=VALEUR
Gosub CHARG_PARAM
End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : End : Endif
#    Lecture article/site
If [F:ITF]ITMREF <> VALEUR | [F:ITF]STOFCY <> [M:DIA]STOFCY
    Read [ITF]ITF0=VALEUR;[M:DIA]STOFCY
    If fstat
      GMESSAGE = mess(45,193,1) : # Article non référencé pour ce site de production
      mkstat = 2
      End
    Endif
Endif
End

########################################
Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()
GBOUT2 = mess(4,198,1) : # Article-Site
End

########################################
Subprog C_ITV(VALEUR)
Variable Integer VALEUR
If [M:DIA]SO = 1 &
&  [M:DIA]PO = 1 &
&  [M:DIA]WO = 1 &
&  [M:DIA]MW = 1 &
&  [M:DIA]SC = 1 &
&  [M:DIA]TR = 1 &
&  [M:DIA]TP = 1 &
&  [M:DIA]BW = 1 &
&  [M:DIA]EO = 1 &
&  [M:DIA]MS = 1 &
&  VALEUR = 1
    mkstat = 2
Endif
End

