#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(30)(1..20) , VALEUR(30)
Local Char OFONCTION(20)
[L]OFONCTION=[V]GFONCTION
[V]GFONCTION="FUNSYNCW"
Call TRAITE_CHAR([L]VALEUR,[L]PARAM,"","FUNSYNCW","DSYNCW",3,"") From GTRAITE
[V]GFONCTION=[L]OFONCTION
End

#########################################################################
# Contient les traitements utilisée pour la modélisation                #
# Etiquettes                                                            #
#########################################################################
#    ACTION MODELISATION E-COMMERCE                                     #
#                                                                       #
# GACTION  : TRTSYNCW   : Action resynchronisation encours              #
#                                                                       #
#########################################################################
$ACTION
Case ACTION
 When "OUVRE_BATCH"   : Gosub OUVRE
 When "INIT"          : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "CONTROLE"      : Gosub CONTROLE
 When "EXEC"          : Gosub EXEC
 When "TERMINE"       : Gosub TERMINE
Endcase
Return

#########################################################################
$INIT

# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Gosub OUVRE

Return

#########################################################################
$INIT_DIA
Local    Char    LFCY : LFCY = PARAM(1)
Local    Char    LITM : LITM = PARAM(2)
Local    Integer LSO  : LSO  = val(PARAM(3))
Local    Integer LPO  : LPO  = val(PARAM(4))
Local    Integer LWO  : LWO  = val(PARAM(5))
Local    Integer LMW  : LMW  = val(PARAM(6))
Local    Integer LSC  : LSC  = val(PARAM(7))
Local    Integer LTR  : LTR  = val(PARAM(8))
Local    Integer LTP  : LTP  = val(PARAM(9))
Local    Integer LBW  : LBW  = val(PARAM(10))
Local    Integer LIT  : LIT  = val(PARAM(11))
Local    Integer LCOR : LCOR = val(PARAM(12))
Local    Integer LEO  : LEO  = val(PARAM(13)) : # Achats sous-traitance
Local    Integer LMS  : LMS  = val(PARAM(14)) : # Achats sous-traitance

Raz [M:DIA]
If LFCY <> "" : GFCY = LFCY : Else Call FIND_GFCYDEF(7) From TRTX3 : Endif
[M:DIA]STOFCY = GFCY : Gosub CHARG_PARAM
If LITM <> "" : [M:DIA]ITMREF    = LITM : Endif
If LSO  <> 0  : [M:DIA]SO        = LSO  : Endif
If LPO  <> 0  : [M:DIA]PO        = LPO  : Endif
If LWO  <> 0  : [M:DIA]WO        = LWO  : Endif
If LMW  <> 0  : [M:DIA]MW        = LMW  : Endif
If LSC  <> 0  : [M:DIA]SC        = LSC  : Endif
If LTR  <> 0  : [M:DIA]TR        = LTR  : Endif
If LTP  <> 0  : [M:DIA]TP        = LTP  : Endif
If LBW  <> 0  : [M:DIA]BW        = LBW  : Endif
If LIT  <> 0  : [M:DIA]ITV       = LIT  : Endif
If LCOR <> 0  : [M:DIA]AUTCOR    = LCOR : Endif
If LEO  <> 0  : [M:DIA]EO        = LEO  : Endif : # Achats sous-traitance
If LMS  <> 0  : [M:DIA]MS        = LMS  : Endif : # Achats sous-traitance
Return

#########################################################################
$CONTROLE
TMP=1
Return

#########################################################################
$EXEC
If !GSERVEUR
    Call TITAWI(BCRIT,TIT) From OBJDIV : # Titre de la trace = titre de la fenêtre
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("SYNCW","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
    TRA=1
Endif

# traitement des encours
Gosub TRT_ORD

# resynchro cumuls
If [M:DIA]ITV     = 2 & [M:DIA]AUTCOR = 2 : Gosub TRT_ITV : Endif
# recalcul des affectations
If [M:DIA]MTOLINK = 2 & [M:DIA]AUTCOR = 2 : Gosub TRT_MTOLINK : Endif
Return

#########################################################################
$TERMINE
#--- X3-38705
#If !GSERVEUR
#---
    If NBANA
        WMESS2 = num$(NBANA)+" "+mess(265,197,1)
        Call ECR_TRACE(WMESS2,0) From GESECRAN
        If NBORD
            WMESS2 = num$(NBORD)+" "+mess(266,197,1)
            Call ECR_TRACE(WMESS2,0) From GESECRAN
        Endif
    Endif
    If NBMAJ
        WMESS2 = num$(NBMAJ)-mess(260,197,1)
        Call ECR_TRACE(WMESS2,0) From GESECRAN
        WMESS2 = mess(264,197,1)
        Call ECR_TRACE(WMESS2,0) From GESECRAN
    Endif
    If !NBORD
         Call ECR_TRACE(mess(264,199,1),0) From GESECRAN
    Endif
    If NBITV
        WMESS1 = num$(NBITV)+" "+mess(596,197,1)
        Call ECR_TRACE(WMESS1,0) From GESECRAN
    Endif
    If NBMTO
        WMESS1 = num$(NBMTO)+" "+mess(749,197,1)
        Call ECR_TRACE(WMESS1,0) From GESECRAN
    Endif
#--- X3-38705
If !GSERVEUR
#---
    # fermeture trace
    Call FERME_TRACE From LECFIC
    # aucune allocation effectuee ou lecture trace
    If !NBORD
         ERR=2 : GMESSAGE = mess(264,199,1)
    Endif
    # lecture trace
Endif
Return


########################################################################
$OUVRE
Local Integer  MODE
Local Integer  OK,I
Local Integer  NBORD,NBMAJ,NBANA, NBITV, NBMTO
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
Local Char     WMESS(85)
Local Char     WMESS1(85)
Local Char     WMESS2(85)
Local Integer  WRET
Local Char     WTRTLIG(1)
Local Char     WTRT(1)
Local Integer  WWIPTYP
Local Char     WWIPNUM
Local Integer  WWIPSTA
Local Char     WITMREF
Local Char     WSTOFCY(GLONFCY)
Local Integer  WVCRTYP
Local Char     WVCRNUM
Local Integer  WVCRLIN
Local Integer  WVCRSEQ
Local Decimal  WEXTQTY
Local Decimal  WCPLQTY
Local Decimal  WALLQTY
Local Decimal  WSHTQTY
Local Integer  WOPENUM
Local Integer  WOPESPLNUM
Local Decimal  WWRK
Local Char     WPTOCOD(GLONPTO)        # 75478
Local Char     WABB, WABBSAV
#--- Bug 70782
Local Decimal  WALL, WSHT

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev([F:ORD1]) = 0 : Local File ORDERS      [ORD1] : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif
If clalev([F:ITV])  = 0 : Local File ITMMVT      [ITV]  : Endif
#--- Bug 70782
If clalev([F:PRH])  = 0 : Local File STOPREH     [PRH]  : Endif
If clalev([F:PRE])  = 0 : Local File STOPRED     [PRE]  : Endif
#---
If GMODU(8) = 2
    # Issue 86205 GA 12/2012 boucler sur MFxW sinon pb sur Sql*Server en mode batch
    If clalev([F:MFGW])  = 0 : Local File MFGHEAD     [MFGW]  : Endif
    If clalev([F:MFIW])  = 0 : Local File MFGITM      [MFIW]  : Endif
    If clalev([F:MFMW])  = 0 : Local File MFGMAT      [MFMW]  : Endif
    If clalev([F:MFOW])  = 0 : Local File MFGOPE      [MFOW]  : Endif
Endif
If GMODU(5) = 2
    If clalev([F:SOH])  = 0 : Local File SORDER      [SOH]  : Endif
    If clalev([F:SOQ])  = 0 : Local File SORDERQ     [SOQ]  : Endif
Endif
If GMODU(6) = 2
    If clalev([F:POH])  = 0 : Local File PORDER      [POH]  : Endif
    If clalev([F:POQ])  = 0 : Local File PORDERQ     [POQ]  : Endif
    If clalev([F:PSH])  = 0 : Local File PREQUIS     [PSH]  : Endif
    If clalev([F:PSD])  = 0 : Local File PREQUISD    [PSD]  : Endif
    If clalev([F:BPR])  = 0 : Local File BPARTNER    [BPR]  : Endif # Issue 78358 GA 01/2012
    If clalev([F:BPS])  = 0 : Local File BPSUPPLIER  [BPS]  : Endif # Issue 78358 GA 01/2012
    If clalev([F:ITP])  = 0 : Local File ITMBPS      [ITP]  : Endif # Issue 78358 GA 01/2012
    # Issue 86205 GA 12/2012 boucler sur SCxW sinon pb sur Sql*Server en mode batch
    #Gosub OPEN_FILES_SCO From SCOLIB : # Achats de sous-traitance
    If clalev([F:SCOW])  = 0 : Local File SCOHEAD     [SCOW]  : Endif
    If clalev([F:SCIW])  = 0 : Local File SCOITM      [SCIW]  : Endif
    If clalev([F:SCMW])  = 0 : Local File SCOMAT      [SCMW]  : Endif
    If clalev([F:SCSW])  = 0 : Local File SCOSRV      [SCSW]  : Endif
Endif

# v6 affectations
Gosub OPEN_MTO From MTOLINKLIB

Local Mask ORDK  [ORDK]
Local Mask STOR  [STOR]

# FQ 59529 GA 11/2009
NAVIG="FUNSYNCW"
Return

########################################################################
# Préparation du filtre sur la table encours                           #
########################################################################
$SEL_ORD

CRITERE  = 'STOFCY ="'+[M:DIA]STOFCY+'"'            # site de stockage
If [M:DIA]ITMREF <> ""
    CRITERE  += '& ITMREF ="'+[M:DIA]ITMREF+'"'       # article
Endif

Return


#---------------------------------------------------------------------#
# Sélection des encours                                               #
#---------------------------------------------------------------------#
$TRT_ORD
#For I = 1 To 7 # GA 03/2006 avant le When 8 n'était pas traité ????
For I = 1 To 10
    Case I
        When 1:    If [M:DIA]SO = 2                                # commandes client
                       Gosub SEL_ORD
                       CRITERE -= '& WIPTYP = 1'
                       Gosub LOOP_ORD
                   Endif
        When 2:    If [M:DIA]PO = 2                                # commandes fournisseur
                       Gosub SEL_ORD
                       CRITERE -= '& WIPTYP = 2'
                       Gosub LOOP_ORD
                   Endif
        When 3:    If [M:DIA]WO = 2 & GMODU(8) = 2                 # ordres de fabrication    llc 09.02 15776
                       Gosub SEL_ORD
                       CRITERE -= '& WIPTYP = 5'
                       Gosub LOOP_ORD
                   Endif
        When 4:    If [M:DIA]MW = 2 & GMODU(8) = 2                 # besoins matières        llc 09.02 15776
                       Gosub SEL_ORD
                       CRITERE -= '& WIPTYP = 6'
                       Gosub LOOP_ORD
                   Endif
        When 5:    If [M:DIA]SC = 2 & GMODU(8) = 2                 # service sous-traitance  llc 09.02 15776
                       Gosub SEL_ORD
                       CRITERE -= '& WIPTYP = 4'
                       Gosub LOOP_ORD
                   Endif
        When 6:    If [M:DIA]TR = 2                                # ordres inter-site
                       Gosub SEL_ORD
                       CRITERE -= '& WIPTYP = 7'
                       Gosub LOOP_ORD
                   Endif
        When 7:    If [M:DIA]TP = 2                                # demandes inter-site
                       Gosub SEL_ORD
                       CRITERE -= '& WIPTYP = 8'
                       Gosub LOOP_ORD
                   Endif
        When 8:    If [M:DIA]BW = 2 & GMODU(8) = 2                 # sous-produit            llc 09.02 15776
                       Gosub SEL_ORD
                       CRITERE -= '& WIPTYP = 9'
                       Gosub LOOP_ORD
                   Endif
        When 9:    If [M:DIA]EO = 2 & GMODU(6) = 2                 # ordre de sous-traitance GA 03/2006
                       Gosub SEL_ORD
                       CRITERE -= '& WIPTYP = 13'
                       Gosub LOOP_ORD
                   Endif
        When 10:    If [M:DIA]MS = 2 & GMODU(6) = 2                # besoins matières sous-traitance GA 03/2006
                       Gosub SEL_ORD
                       CRITERE -= '& WIPTYP = 3'
                       Gosub LOOP_ORD
                   Endif
    Endcase
Next I

# LD  23/04/2004 22019
If [M:DIA]SOREGEN = 2 & GMODU(5) = 2
    Gosub REGEN_SO From FUNSYNCSO
Endif

# MBT 15/04/2004 22019
If [M:DIA]POREGEN = 2 & GMODU(6) = 2
    Gosub REGEN_PO From FUNSYNCPO
Endif

# llc 09.02 15776
If [M:DIA]WOREGEN = 2 & [M:DIA]AUTCOR = 2 & GMODU(8) = 2
    Gosub REGEN_WO
Endif

# Achats de sous-traitance GA 03/2006
If [M:DIA]EOREGEN = 2 & [M:DIA]AUTCOR = 2 & GMODU(6) = 2
    Gosub REGEN_EO
Endif
Return

#---------------------------------------------------------------------#
# Traitement des encours                                              #
#---------------------------------------------------------------------#
$LOOP_ORD
Filter [ORD] Where evalue(CRITERE)
# boucle de lecture
For  [ORD]
      If [F:ORD]WIPSTA = 3 & [F:ORD]WIPTYP <> 8 : Goto NXT1 : Endif            # 10.04
      WITMREF = [F:ORD]ITMREF
      WSTOFCY = [F:ORD]STOFCY
      WWIPTYP = [F:ORD]WIPTYP
      WWIPNUM = [F:ORD]WIPNUM
      WWIPSTA = [F:ORD]WIPSTA
      WVCRTYP = [F:ORD]VCRTYP  : # GA 03/2006 pour différencier les SC (WO, EO)
      WVCRNUM = [F:ORD]VCRNUM
      WVCRLIN = [F:ORD]VCRLIN
      WVCRSEQ = [F:ORD]VCRSEQ
      WABB    = [F:ORD]ABBFIL
      NBANA  += 1
      Gosub CHK_ORD
      If OK = 9 : Goto NXT1 : Endif
      Gosub TRTORD
$NXT1
Next
#
Filter [ORD]
#
Return

#-----------------------------------------------------------------------#
# Vérification encours                                                  #
#-----------------------------------------------------------------------#
$CHK_ORD
OK = 9
Case WWIPTYP
    When 1:    Gosub CHK_SO
    When 2:    Gosub CHK_PO
    When 3:    Gosub CHK_MS       : # GA 03/2006
    When 4:    If WVCRTYP=36
                  Gosub CHK_SC_EO : # GA 03/2006 Achats de sous-traitance
               Else
                  Gosub CHK_SC_WO
               Endif
    When 5:    Gosub CHK_WO
    When 6:    Gosub CHK_MW
    When 7:    Gosub CHK_TR
    When 8:    Gosub CHK_TP
    When 9:    Gosub CHK_BW
    When 13:   Gosub CHK_EO        : # GA 03/2006
Endcase
Return

#-----------------------------------------------------------------------#
# Test commande client                                                  #
#-----------------------------------------------------------------------#
$CHK_SO
Read [SOH]SOH0=WVCRNUM
If fstat
    OK = 1
    WMESS1 = "        "+mess(261,197,1)
    Goto SO_NXT
Endif
Read [SOQ]SOQ0=WVCRNUM;WVCRLIN;WVCRSEQ
If fstat
    OK = 1
    WMESS1 = "        "+mess(262,197,1)
    Goto SO_NXT
Endif
# Bug 76699
If [F:SOQ]STOFCY <> [F:ORD]STOFCY
    OK = 1
    WMESS1 = "        "+mess(783,197,1)
    Goto SO_NXT
Endif
# Bug 76699
If [F:SOQ]SOQSTA = 3 & [F:SOQ]ODLQTYSTU = 0
    OK = 1
    WMESS1 = "        "+mess(254,197,1)
    Goto SO_NXT
Endif

GPOINT = "CHK_SO" : Gosub ENTREE From EXEFNC : # GH 15/05/12 dm 80740
If OK=1
   Goto SO_NXT
Endif

Raz WALL, WSHT
If [F:SOQ]OPRQTYSTU + [F:SOQ]PREQTYSTU > 0
   #--- Issue 116484
   #Filter [PRE] Where ORINUM=WVCRNUM & ORILIN=WVCRLIN & ORISEQ=WVCRSEQ
#&               Order By Key CLE=ORINUM;ORILIN;ORISEQ
   #For [PRE]
   Filter [PRE] Where ORINUM=WVCRNUM & ORILIN=WVCRLIN & ORISEQ=WVCRSEQ
   For [PRE]PRE1
   #---
      # Lecture de l'entête de préparation
      Read [PRH]PRH0=[F:PRE]PRHNUM
      # Elle n'existe pas encore ou la prépa n'est pas livrée
      If fstat | [F:PRH]SDHNUM=""
         WALL += [F:PRE]ALLQTY
         WSHT += [F:PRE]SHTQTY
      Endif
   Next
   Filter [PRE]
Endif

If OK=2
   Goto SO_NXT
Endif

If [F:SOQ]QTYSTU <> [F:ORD]EXTQTY & ([F:SOH]APPFLG>2 | GSOHAPPORD=2)
    OK = 2
    WMESS1 = "        "+mess(255,197,1)
    Goto SO_NXT
Endif
If [F:SOH]SOHCAT = 3            # commande à facturation directe
    If [F:SOQ]INVQTYSTU <> [F:ORD]CPLQTY
        OK = 2
        WMESS1 = "        "+mess(256,197,1)
        Goto SO_NXT
    Endif
Else
    If [F:SOQ]DLVQTYSTU <> [F:ORD]CPLQTY
        OK = 2
        WMESS1 = "        "+mess(256,197,1)
        Goto SO_NXT
    Endif
Endif

#--- Bug 70782
WWRK = [F:SOQ]ALLQTYSTU + WALL + [F:SOQ]ODLQTYSTU
#WWRK = [F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU
#---
If WWRK <> [F:ORD]ALLQTY
    OK = 2
    WMESS1 = "        "+mess(258,197,1)
    Goto SO_NXT
Endif
#--- Bug 70782
If [F:SOQ]SHTQTYSTU + WSHT <> [F:ORD]SHTQTY
#If [F:SOQ]SHTQTYSTU <> [F:ORD]SHTQTY
#---
    OK = 2
    WMESS1 = "        "+mess(259,197,1)
    Goto SO_NXT
Endif

$SO_NXT
If OK = 2
    WEXTQTY = [F:SOQ]QTYSTU
    If [F:SOH]SOHCAT = 3
        WCPLQTY = [F:SOQ]INVQTYSTU
    Else
        WCPLQTY = [F:SOQ]DLVQTYSTU
    Endif
    #--- Bug 70782
    WALLQTY = [F:SOQ]ALLQTYSTU + WALL + [F:SOQ]ODLQTYSTU
    WSHTQTY = [F:SOQ]SHTQTYSTU + WSHT
    #WALLQTY = [F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU
    #WSHTQTY = [F:SOQ]SHTQTYSTU
    #---
    #Issue X3-86458 - YARAM : When sales order line is closed, planned quantity is only updated in ORDERS, not in SORDERQ.
    If [F:SOQ]SOQSTA = 3
    WEXTQTY = WCPLQTY + WALLQTY
    Endif
Endif
Return

#-----------------------------------------------------------------------#
# Test commande fournisseur                                             #
#-----------------------------------------------------------------------#
$CHK_PO
# en attendant que la rubrique abbfil soit renseignée correctement
# (elle permet de savoir si une POP est issue d'une DA ou d'une DL planifiée)
# on tente toutes les possibilités ...
WABBSAV = ""
If WWIPSTA = 2 & WABB = "POQ"    # c'est à dire une origine indéterminée
    WABBSAV = "POQ"
    WABB    = "POC"
Endif
$SPSA    # Same Player Shoot Again
If WWIPSTA = 1 | (WWIPSTA = 2 & WABB = "POC")
    Read [POH]POH0=WVCRNUM
    If fstat
        If WABBSAV = "POQ" : WABB = "PSD" : Goto SPSA : Endif
        OK = 1
        WMESS1 = "        "+mess(261,197,1)
        Goto PO_NXT1
    Endif
    Read [POQ]POQ0=WVCRNUM;WVCRLIN;WVCRSEQ
    If fstat
        OK = 1
        WMESS1 = "        "+mess(262,197,1)
        Goto PO_NXT1
    Endif
    If [F:POQ]LINCLEFLG = 2
        OK = 1
        WMESS1 = "        "+mess(254,197,1)
        Goto PO_NXT1
    Endif
    If [F:POQ]QTYSTU <> [F:ORD]EXTQTY
        OK = 2
        WMESS1 = "        "+mess(255,197,1)
        Goto PO_NXT1
    Endif
    If [F:POQ]RCPQTYSTU <> [F:ORD]CPLQTY
        OK = 2
        WMESS1 = "        "+mess(256,197,1)
        Goto PO_NXT1
    Endif
$PO_NXT1
    If OK = 2
        WEXTQTY = [F:POQ]QTYSTU
        WCPLQTY = [F:POQ]RCPQTYSTU
        WALLQTY = 0
        WSHTQTY = 0
    Endif
Else
    Read [PSH]PSH0=WVCRNUM
    If fstat
        OK = 1
        WMESS1 = "        "+mess(261,197,1)
        Goto PO_NXT2
    Endif
    Read [PSD]PSD0=WVCRNUM;WVCRLIN
    If fstat
        OK = 1
        WMESS1 = "        "+mess(262,197,1)
        Goto PO_NXT2
    Endif
    If [F:PSD]LINCLEFLG = 2
        OK = 1
        WMESS1 = "        "+mess(254,197,1)
        Goto PO_NXT2
    Endif
    If [F:ORD]EXTQTY <> ([F:PSD]QTYSTU - [F:PSD]ORDQTYSTU)
        OK = 2
        WMESS1 = "        "+mess(255,197,1)
        Goto PO_NXT2
    Endif
$PO_NXT2
    If OK = 2
        WEXTQTY = [F:PSD]QTYSTU - [F:PSD]ORDQTYSTU
        WCPLQTY = 0
        WALLQTY = 0
        WSHTQTY = 0
    Endif
Endif
Return

#-----------------------------------------------------------------------#
# Test service sous-traitance pour un OF                                #
#-----------------------------------------------------------------------#
$CHK_SC_WO
WOPENUM = 0 : WOPESPLNUM = 0
Read [MFGW]MFG0=WVCRNUM
If fstat
    OK = 1
    WMESS1 = "        "+mess(261,197,1)
    Goto SC_NXT
Endif
# llc 05.02 14394 Performances
Filter [MFOW] Where MFGNUM = [F:ORD]VCRNUM & WIPNUM=[F:ORD]WIPNUM    # llc 05.02 14394 Performances
Read [MFOW] First
If fstat
    OK = 1
    WMESS1 = "        "+mess(262,197,1)
    Goto SC_NXT
Endif
WOPENUM    = [F:MFOW]OPENUM
WOPESPLNUM = [F:MFOW]OPESPLNUM
If [F:MFGW]MFGTRKFLG > 4
    OK = 1
    WMESS1 = "        "+mess(253,197,1)
    Goto SC_NXT
Endif
If [F:MFOW]OPESTA > 4
    OK = 1
    WMESS1 = "        "+mess(254,197,1)
    Goto SC_NXT
Endif
If [F:MFOW]EXTSTRQTY <> [F:ORD]EXTQTY
    OK = 2
    WMESS1 = "        "+mess(255,197,1)
    Goto SC_NXT
Endif
Filter [MFOW]
$SC_NXT
If OK = 2
    WEXTQTY = [F:MFOW]EXTSTRQTY
    WCPLQTY = 0
    WALLQTY = 0
    WSHTQTY = 0
Endif
Return

#-----------------------------------------------------------------------#
# Test service sous-traitance pour un Ordre de sous-traitance           #
#-----------------------------------------------------------------------#
$CHK_SC_EO
Read [SCOW]SCO0=WVCRNUM
If fstat
    OK = 1
    WMESS1 = "        "+mess(261,197,1)
    Goto SC_NXT_EO
Endif
Filter [SCSW] Where SCONUM = [F:ORD]VCRNUM & WIPNUM=[F:ORD]WIPNUM
Read [SCSW] First
If fstat
    OK = 1
    WMESS1 = "        "+mess(262,197,1)
    Goto SC_NXT_EO
Endif
If [F:SCOW]SCOTRKFLG > 4
    OK = 1
    WMESS1 = "        "+mess(253,197,1)
    Goto SC_NXT_EO
Endif
If [F:SCSW]OPESTA > 4
    OK = 1
    WMESS1 = "        "+mess(254,197,1)
    Goto SC_NXT_EO
Endif
If [F:SCSW]EXTSTRQTY <> [F:ORD]EXTQTY
    OK = 2
    WMESS1 = "        "+mess(255,197,1)
    Goto SC_NXT_EO
Endif
Filter [SCSW]
$SC_NXT_EO
If OK = 2
    WEXTQTY = [F:SCSW]EXTSTRQTY
    WCPLQTY = 0
    WALLQTY = 0
    WSHTQTY = 0
Endif
Return


