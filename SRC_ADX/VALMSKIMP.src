#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char    LAN(GLONLAN)(1..5) , ECRAN(GLONAMK)
Local Integer OK
ECRAN = "CNA1"
LAN(1) = "FRA"
GTRACE = ""
Call VALID(ECRAN,nomap,1,LAN,0,OK) From VALMSK
End

#################################################################################
## VALMSKIMP Ecriture du traitement d'import
#################################################################################

$VALTRT
NOMPROG = "W0"+TET_AUT
FICSRC = filpath("TRT",NOMPROG,"src",APPLI)
Openo FICSRC , 0
adxifs = ""
adxirs = chr$(10)
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq "#"-mess(15,123,1)-ECRAN-TET_TXT : # Gestion du masque
Wrseq

Wrseq "Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)"
Wrseq "Value Char IMPFIC"
Wrseq "Value Char ACTION"
Wrseq "Value Char IMPTRT"
Wrseq
Wrseq "Gosub DEFVAR"
Wrseq

For B=1 To BLC_NBR
 BLC_TRI(B) = B
 BLC_RRR(B) = BLC_RNG(B)
Next B
Sorta BLC_NBR BLC_TRI,BLC_RRR Order By BLC_RRR(indice+1)

Gosub ECRITURE

Openo
Call VALID("TRT",NOMPROG,APPLI,OK) From VALMSKSUB
Return

$ECRITURE
For BT=1 To BLC_NBR
 B = BLC_TRI(BT)
 SPA = 0
 Case BLC_TYP(B)
  When 1   : # Tableau
   Gosub BAS_TABLEAU
  When 2,5,9 : # Liste/invisible/Editeur Html
   Gosub LISTE
 Endcase
Next BT
Wrseq "mkstat = 0"
Wrseq
Wrseq "End"
Wrseq
For BT=1 To BLC_NBR
 B = BLC_TRI(BT)
 SPA = 0
 Case BLC_TYP(B)
  When 1   : # Tableau
   Gosub TABLEAU
 Endcase
Next BT
Wrseq "$DEFVAR"
Wrseq "Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG"
Wrseq "Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)"
Wrseq "Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)"
Wrseq "Local Char    PARAM(250)(1..20) , SAVACT(20)"
Wrseq "Local Char    WCHAR(255)"
Wrseq "Local Decimal WNUM"
Wrseq "Local Date    WDATE"
Wrseq "Local Clbfile WCLOB(9)"
Wrseq
Wrseq 'IMPMSK = "';ECRAN;'"'
Wrseq "Return"
Wrseq
Return

#############################################
## Traitement des blocs
#############################################
$LISTE
Wrseq "####################################"
Wrseq "## Bloc liste"-num$(B)
Wrseq "####################################"
Wrseq space$(SPA);"IMPTBL = 0"
Wrseq
For L=1 To LIG_NBR(B)
 Gosub ZONE
Next L
Return

$BAS_TABLEAU
Wrseq "####################################"
Wrseq "## Bloc tableau"-num$(B)
Wrseq "####################################"
Wrseq space$(SPA);"IMPTBL = 1"
Wrseq
REPET = 0
For L1=1 To LIG_NBR(B)
 If LIG_ZON(B,L1)=BLC_BAS(B)
  L = L1 : Break
 Endif
Next L1
If L
 NBIF     = 0
 FLACTION = 0
 Gosub DEB_ZONE
 AZC = "[M]"+LIG_ZON(B,L)
 Wrseq space$(SPA);"indice = 0"
 Wrseq space$(SPA);"status = 1"
 Wrseq space$(SPA);'zoncou = "'+LIG_ZON(B,L)+'"'
 Gosub AVANT
 Wrseq space$(SPA);'If !mkstat' : NBIF += 1 : SPA += 1
 Wrseq space$(SPA);"NBLIG = [M]";BLC_BAS(B)
 Wrseq space$(SPA);"For nolign=1 To NBLIG"
 SPA += 1
 Wrseq space$(SPA);"indice = nolign-1"
 Wrseq space$(SPA);"[M]";BLC_BAS(B);" = nolign"
 Wrseq space$(SPA);"status = 75"
 Wrseq space$(SPA);"Call SAI_"+BLC_BAS(B)+"(IMPFIC,ACTION,IMPTRT)"
 Wrseq space$(SPA);"If mkstat : Break : Endif"
 SPA -= 1
 Wrseq space$(SPA);"Next nolign"
 REPET = 0
 Wrseq space$(SPA);"If mkstat : End : Endif"
 Wrseq space$(SPA);"indice = 0"
 Gosub APRES
Endif
Wrseq
Return

$TABLEAU
Wrseq "####################################"
Wrseq "## Bloc tableau"-num$(B)
Wrseq "####################################"
Wrseq "Subprog SAI_"+BLC_BAS(B)+"(IMPFIC,ACTION,IMPTRT)"
Wrseq "Value Char IMPFIC"
Wrseq "Value Char ACTION"
Wrseq "Value Char IMPTRT"
Wrseq
Wrseq "Gosub DEFVAR"
Wrseq
Wrseq "IMPTBL = 1"
Wrseq

For L=1 To LIG_NBR(B)
 If LIG_ZON(B,L)=BLC_BAS(B)
  Break
 Endif
Next L
SAVIF = NBIF
REPET = 0
Gosub DEB_ZONE
AZC = "[M]"+LIG_ZON(B,L)
TYPACT = 5 : # Contrôle
FLSAI  = 0
FLCONT = 1
If OKTYP(TYPACT)
 Gosub ETIQUETTE
Endif
TYPACT = 13 : # Avant_
FLSAI  = 0
FLCONT = 0
FLACTION = 0
If OKTYP(TYPACT)
 Gosub ETIQUETTE
Endif
While NBIF>SAVIF
 NBIF -= 1 : SPA -= 1
 Wrseq space$(SPA);"Endif"
Wend
Wrseq

REPET = 0
For L=1 To LIG_NBR(B)
 If LIG_ZON(B,L)<>BLC_BAS(B)
  Gosub ZONE_TABLEAU
 Endif
Next L

For L=1 To LIG_NBR(B)
 If LIG_ZON(B,L)=BLC_BAS(B)
  Break
 Endif
Next L
SAVIF = NBIF
REPET = 0
Gosub DEB_ZONE
AZC = "[M]"+LIG_ZON(B,L)
TYPACT = 14 : # Après
FLSAI  = 0
FLCONT = 0
FLACTION = 0
If OKTYP(TYPACT)
 Wrseq space$(SPA);"status = 71"
 Gosub ETIQUETTE
Endif
While NBIF>SAVIF
 NBIF -= 1 : SPA -= 1
 Wrseq space$(SPA);"Endif"
Wend
Wrseq

Wrseq "End"
Wrseq
Return

#############################################
## Traitement des champs
#############################################
$ZONE
Gosub DEB_ZONE
If !OKZON : Return : Endif
If LIG_DIM(B,L)>1
 REPET = 1
 Wrseq space$(SPA);"For indice=0 To ";LIG_DIM(B,L)-1
 SPA += 1
 AZC = "[M]"+LIG_ZON(B,L)+"(indice)"
 Gosub CHAMP
 Wrseq space$(SPA);"mkstat = 0"
 SPA -= 1
 Wrseq space$(SPA);"Next indice"
 Wrseq space$(SPA);"If mkstat : End : Endif"
Else
 REPET = 0
 Wrseq space$(SPA);"indice = 0"
 AZC = "[M]"+LIG_ZON(B,L)
 Gosub CHAMP
Endif
Wrseq
Return

$ZONE_TABLEAU
Gosub DEB_ZONE
If !OKZON : Return : Endif
AZC = "[M]"+LIG_ZON(B,L)+"(indice)"
Gosub CHAMP
Wrseq
Return

$DEB_ZONE
DA = LIG_PTA(B,L)
FA = LIG_PTA(B,L)+LIG_ACT(B,L)-1
Raz OKTYP
For A=DA To FA
 If find(ACT_EXE(A),2,3)
  OKTYP(ACT_TYP(A)) += 1
 Endif
Next A
If LIG_SAI(B,L)=1
 OKZON = 1
Else
 OKZON = (OKTYP(2)+OKTYP(3)+OKTYP(6)<>0)
Endif
If OKZON
 Wrseq space$(SPA);"## Zone"-LIG_ZON(B,L)
 Wrseq space$(SPA);"mkstat = 0"
 Wrseq space$(SPA);'zoncou = "'+LIG_ZON(B,L)+'"'
Endif
Return

$CHAMP
## Cas particulier des menus locaux (quasi-bug adonix)
If LIG_TYI(B,L)=1
 SAVZC = AZC
 AZC   = "IMPENT"
 Wrseq space$(SPA);AZC;" = ";SAVZC
Endif

NBIF     = 0
FLACTION = 0
Gosub AVANT
Gosub APRES
Return

################################################
## Traitement des étiquettes
################################################
$AVANT

# Sauvegarde du champ s'il y a un après modif

If OKTYP(7)
 Case LIG_TYI(B,L)
  When 7       : Wrseq space$(SPA);"WCHAR = ";AZC
  When 8       : Wrseq space$(SPA);"WDATE = ";AZC
  When 9       : # Blob : on ne fait rien
  When 10      : Wrseq space$(SPA);"WCLOB = ";AZC
  When Default : Wrseq space$(SPA);"WNUM = ";AZC
 Endcase
Endif

# Avant_zone

If find("%DEFOBL",ACT_ACT(DA..FA))
 If LIG_FNU(B,L)=TABLO
  Wrseq space$(SPA);"[M]";LIG_ZON(B,L);
 Else
  Wrseq space$(SPA);AZC;
 Endif
 Wrseq " = ";vireblc(format$("KT:80X",right$(LIG_INI(B,L),2)),2)
 If LIG_TYI(B,L)=1
  Wrseq space$(SPA);"[M]";LIG_ZON(B,L);"(indice) = ";AZC
 Endif
Endif

FLCONT = 0
FLSAI  = 1
TYPACT = 2

Gosub ETIQUETTE

# Init

FLSAI  = 0
TYPACT = 3
If OKTYP(TYPACT)
 Gosub DEB_ACTION
 Wrseq space$(SPA);"If varinit([M]"+LIG_ZON(B,L)+",indice)=0" : SPA += 1 : NBIF += 1

 A = find("%DEFVAL",ACT_ACT(DA..FA))
 If A
  A = DA+A-1 : Gosub ACTION
 Else
  A = find("%MENINI",ACT_ACT(DA..FA))
  If A : A = DA+A-1 : Gosub ACTION : Endif
 Endif

 For A=DA To FA
  If ACT_TYP(A)=TYPACT & left$(ACT_ACT(A),1)<>"%"
   Gosub ACTION
  Endif
 Next A

 Gosub FIN_IF

Endif

# Avant_saisie

FLSAI  = 1
TYPACT = 4
If LIG_SAI(B,L)=1
 Gosub DEB_ACTION
 Wrseq space$(SPA);"If varmode([M]"+LIG_ZON(B,L)+",indice)=0" : SPA += 1 : NBIF += 1

 If OKTYP(TYPACT)

  A = find("%CNSSAI",ACT_ACT(DA..FA))
  If A : A = DA+A-1 : Gosub ACTION : Endif

  A = find("%MENSAI",ACT_ACT(DA..FA))
  If A
   Wrseq space$(SPA);"Call INICOMBO("+num$(LIG_LIB(B,L))+") From COMBOS"
  Endif

  For A=DA To FA
   If ACT_TYP(A)=TYPACT & left$(ACT_ACT(A),1)<>"%"
    Gosub ACTION
   Endif
  Next A

  A = find("%MENSAI",ACT_ACT(DA..FA))
  If A : A = DA+A-1 : Gosub ACTION : Endif

 Else

  A = find("%MENSAI",ACT_ACT(DA..FA))
  If A
   Wrseq space$(SPA);"Call INICOMBO("+num$(LIG_LIB(B,L))+") From COMBOS"
  Endif

 Endif

 If LIG_TYI(B,L)=1 : # mb 29.9.3 Pour revenir dans les conditions de la 130
  Wrseq space$(SPA);'[M]'+LIG_ZON(B,L)+'(indice) = IMPENT'
 Endif

 Wrseq space$(SPA);'If !mkstat' : SPA += 1

 Wrseq space$(SPA);'IMPMOD = 0 : IMPZON = "'+LIG_ZON(B,L)+'" : Gosub ACTION From =IMPTRT'

# Cas particulier du type ATT (le texte étant déjà créé, il faut remplir la zone invisible du numéro)

 If LIG_TYP(B,L)="ATT"
  For A=DA To FA
   If ACT_ACT(A)="TXTCONT"
    For P=1 To MAXPAR
     If PAR_COD(A,P)="NOMESS"
      CHPLIEN = PAR_VAL(A,P)
      J = instr(1,CHPLIEN,"]")
      If J : CHPLIEN = right$(CHPLIEN,J+1) : Endif
      J = instr(1,CHPLIEN,"(")
      If J : CHPLIEN = left$(CHPLIEN,J-1) : Endif
      Wrseq space$(SPA);'IMPMOD = 0 : IMPZON = "'+CHPLIEN+'" : Gosub ACTION From =IMPTRT'
      Break 2
     Endif
    Next P
   Endif
  Next A
 Endif

 If LIG_TYI(B,L)=1
  Wrseq space$(SPA);'IMPENT = [M]'+LIG_ZON(B,L)+'(indice)'
 Endif

 SPA -= 1
 Wrseq space$(SPA);'Endif'

Endif
Return

$APRES

# Contrôle

FLSAI    = 0
FLCONT   = 1

TYPACT = 5
If LIG_SAI(B,L)=1
 A = find("%OBLIG",ACT_ACT(DA..FA))
 If A : A = DA+A-1 : Gosub ACTION : Endif

 A = find("%MOINS",ACT_ACT(DA..FA))
 If A : A = DA+A-1 : Gosub ACTION : Endif

 A = find("%MENCNT",ACT_ACT(DA..FA))
 If A : A = DA+A-1 : Gosub ACTION : Endif

 For A=DA To FA
  If ACT_TYP(A)=TYPACT & ACT_PRI(A)=1 & left$(ACT_ACT(A),1)<>"%"
   Gosub ACTION
  Endif
 Next A

 A = find("%CNTOBJ",ACT_ACT(DA..FA))
 If A : A = DA+A-1 : Gosub ACTION : Endif

 For A=DA To FA
  If ACT_TYP(A)=TYPACT & ACT_PRI(A)=3 & left$(ACT_ACT(A),1)<>"%"
   Gosub ACTION
  Endif
 Next A

 A = find("%TABCNT",ACT_ACT(DA..FA))
 If A : A = DA+A-1 : Gosub ACTION : Endif

Endif

# Après_zone

TYPACT = 6
If LIG_SAI(B,L)=1
 Gosub ETIQUETTE
Endif

# Après_modif

TYPACT = 7
If LIG_SAI(B,L)=1
 If OKTYP(TYPACT)
  Gosub DEB_ACTION
  Wrseq space$(SPA);"If ";
  Case LIG_TYI(B,L)
   When 7       : Wrseq "WCHAR";"<>";AZC;" or ";
   When 8       : Wrseq "WDATE";"<>";AZC;" or ";
   When 9       : # Blob : on ne fait rien
   When 10      : Wrseq "WCLOB";"<>";AZC;" or ";
   When Default : Wrseq "WNUM";"<>";AZC;" or ";
  Endcase
  Wrseq "IMPMOD"
  SPA += 1
  Gosub ETIQUETTE
  SPA -= 1
  Wrseq space$(SPA);"Endif"
 Endif
Endif

# Fin

Gosub FIN_IF

## Cas particulier des menus locaux (quasi-bug adonix)
If LIG_TYI(B,L)=1
 Wrseq space$(SPA);SAVZC;" = ";AZC
 AZC = SAVZC
Endif
Return

$ETIQUETTE
For A=DA To FA
 If ACT_TYP(A)=TYPACT
  Gosub ACTION
 Endif
Next A
Return

$ACTION
Case ACT_ACT(A)

 When "%NULL"

## Valeur par défaut obligatoire

 When "%DEFOBJ"

  Wrseq space$(SPA);AZC;" = ";vireblc(format$("KT:80X",right$(LIG_INI(B,L),2)),2)

## Init des variables pour les formats devises et unités

 When "%BASDEV"

  Wrseq space$(SPA);"Gosub SETDEV From TRTDIV"
  For P=1 To BLC_PAR(B)
   Wrseq space$(SPA);BLC_PVA(B,P);" = ";BLC_PVL(B,P)
  Next P

## Valeur par défaut saisie ou du type de données

 When "%DEFVAL"

  Wrseq space$(SPA);AZC;" = ";vireblc(format$("KT:80X",LIG_INI(B,L)),2)

## Menus locaux

 When "%MENINI"

  Wrseq space$(SPA);AZC;" = 1"

## Init des menus locaux

 When "%MENSAI"

  Wrseq space$(SPA);"If ";AZC;"<1 | GMENLOC(";AZC;")=1"
  Wrseq space$(SPA);" ";AZC;" = find(0,GMENLOC(1..len(mess(0,"+num$(LIG_LIB(B,L))+",1))))"
  Wrseq space$(SPA);"Endif"

## Condition de saisie

 When "%CNSSAI"

  Gosub DEB_ACTION
  Wrseq space$(SPA);"If !("+vireblc(format$("KT:120X",LIG_CNS(B,L)),2)+")"
  Wrseq space$(SPA);' mkstat = 2'
  Wrseq space$(SPA);"Endif"
  Gosub FIN_ACTION

## Traitement des tables diverses

 When "%ADIOBL"

  Gosub PAROBJ
  If PAROBJ<>""
   Wrseq space$(SPA);'If ';AZC;'="" : Call INIADI(';AZC;',';PAROBJ;') From TRTDIV : Endif'
  Endif

## Chiffre négatif

 When "%MOINS"

  Gosub DEB_ACTION
  Wrseq space$(SPA);"If ";AZC;"<0"
  Wrseq space$(SPA);" mkstat = 1 : GMESSAGE = mess(180,141,1)"
  Wrseq space$(SPA);"Endif"
  Gosub FIN_ACTION

## Zone obligatoire

 When "%OBLIG"

  Gosub DEB_ACTION
  Case LIG_TYI(B,L)
   When 1,2,3,4,5,6
    Wrseq space$(SPA);"If ";AZC;"=0"
   When 7
    Wrseq space$(SPA);'If vireblc(';AZC;',2)=""'
   When 8
    Wrseq space$(SPA);'If ';AZC;'=[0/0/0]'
   When 9 , 10
    Wrseq space$(SPA);'If len(';AZC;')=0'
  Endcase
  Wrseq space$(SPA);' mkstat = 1 : GMESSAGE = mess(10,123,1)'
  Wrseq space$(SPA);"Endif"
  Gosub FIN_ACTION

# Contrôle des choix possibles d'un menu local

 When "%MENCNT"

  Gosub DEB_ACTION
  Wrseq space$(SPA);"If ";AZC;">0 & ";AZC;"<dim(GMENLOC) & GMENLOC(";AZC;")<>0"
  Wrseq space$(SPA);" mkstat = 1 : GMESSAGE = mess(99,123,1)"
  Wrseq space$(SPA);"Endif"
  Gosub FIN_ACTION

## Contrôle associé à un objet

 When "%CNTOBJ"

  Gosub DEB_ACTION
  Gosub PAROBJ
  Wrseq space$(SPA);"Call ";
  Case LIG_TYI(B,L)
   When 2,3,4,5,6 : Wrseq "CONTNUM(";
   When 1         : Wrseq "CONTLIB(";
   When Default   : Wrseq "CONTROLE(";
  Endcase
  Wrseq '"'+LIG_OBJ(B,L)+'","';
  If LIG_OBL(B,L)<>2      : Wrseq "!"; : Endif
  If LIG_FIC(B,L)=TET_FIC : Wrseq "$"; : Endif
  Wrseq LIG_OBP(B,L);'",';AZC;',';PAROBJ;',mkstat) From CONTOBJ'
  Gosub FIN_ACTION

## Table de contrôle

 When "%TABCNT"

  If find(ACT_EXE(A),2,3) : # Fin de saisie et toujours
   Gosub DEB_ACTION
   Wrseq space$(SPA);"Call ";
   Case LIG_TYI(B,L)
    When 1         : Wrseq "CONTACL_LIB(";
    When 2,3,4,5,6 : Wrseq "CONTACL_NUM(";
    When 8         : Wrseq "CONTACL_DAT(";
    When Default   : Wrseq "CONTACL_CHAR(";
   Endcase
   Wrseq '"'+LIG_CTL(B,L)+'",'+PAR_VAL(A,1)+',';AZC;') From SUBACL'
   Gosub FIN_ACTION
  Endif

## Autres actions

 When Default

  If find(ACT_EXE(A),2,3) & left$(ACT_ACT(A),1)<>"%" : # Fin de saisie et toujours
   Gosub ACTSTD
  Endif

Endcase
Return

####################################################
## Traitement général d'une action
####################################################
$ACTSTD
If find(ACT_MOD(A),7,8) : # On ne peut pas faire les autres!!
 Gosub DEB_ACTION
 Case ACT_MOD(A)
  When 7 : Gosub GACTION
  When 8 : Gosub SANS_MODELE
 Endcase
 Gosub FIN_ACTION
Endif
Return

$DEB_ACTION
If FLACTION
 Wrseq space$(SPA);'If !mkstat' : NBIF += 1 : SPA += 1
Endif
FLACTION = 0
Return

$FIN_ACTION
If FLCONT
 Wrseq space$(SPA);'If mkstat : GERR = 1 : GZONE = "'+LIG_ZON(B,L)+'" : GZNUM = ';num$(LIG_TIT(B,L));
 Wrseq ' : Endif'
 Wrseq space$(SPA);'Gosub AFF From GSAISIE'
 Wrseq space$(SPA);'If mkstat : ';
 Case REPET
  When 0 : Wrseq 'End';
  When 1 : Wrseq 'Break';
  When 2 : Wrseq 'Return';
 Endcase
 Wrseq ' : Endif'
Endif
If FLSAI
 Wrseq space$(SPA);"If mkstat=1 : Raz ";AZC;" : Endif"
Endif
FLACTION = 1
Return

####################################################
## Traitement des modèles
####################################################
$GACTION
Gosub SAV_ACT
Gosub ACT_AVZ
Gosub GET_PARAM
Case LIG_TYI(B,L)
 When 1         : Wrseq space$(SPA)+"Local Integer VALEUR"
 When 2,3,4,5,6 : Wrseq space$(SPA)+"Local Decimal VALEUR"
 When 8         : Wrseq space$(SPA)+"Local Date    VALEUR"
 When Default   : Wrseq space$(SPA)+"Local Char    VALEUR(250)"
Endcase
Wrseq space$(SPA)+"VALEUR = "+AZC
Wrseq space$(SPA)+'Call'-ACT_SPR(A);
Wrseq '(VALEUR,PARAM,"'+ACT_IDE(A)+'","'+ACT_TRT(A)+'","'+ACT_SPE(A)+'") From'-ACT_PRG(A)
Wrseq space$(SPA)+AZC+" = VALEUR"
Gosub SET_PARAM
Gosub ACT_APZ
Gosub REST_ACT
Return

$SANS_MODELE
Gosub SAV_ACT
If ACT_SPR(A)<>"" & ACT_PRG(A)<>"" & ACT_SPE(A)<>""
 Wrseq space$(SPA)+'Local Integer OKTRT'
 Wrseq space$(SPA)+'Call EXISTE_ADX("","","'+ACT_SPE(A)+'",OKTRT) From ORDSYS'
 Wrseq space$(SPA)+'If OKTRT>0'
 SPA += 1
 TRTSUB = ACT_SPE(A)
 Gosub GEN_CALL
 SPA -= 1
 Wrseq space$(SPA)+"Else"
 TRTSUB = ACT_PRG(A)
 SPA += 1
 Gosub GEN_CALL
 SPA -= 1
 Wrseq space$(SPA)+"Endif"
Elsif ACT_SPR(A)<>"" & ACT_PRG(A)<>""
 TRTSUB = ACT_PRG(A)
 Gosub GEN_CALL
Endif
Gosub REST_ACT
If ACT_INS(A)<>""
 LIGNE = space$(SPA)+ACT_INS(A)
 Repeat
  J = instr(1,LIGNE,"%")
  If J
   If instr(1,"0123456789",mid$(LIGNE,J+2,1))
    L1 = 2
   Else
    L1 = 1
   Endif
   K = val(mid$(LIGNE,J+1,L1))
   If K=0
    PARAM = "[M]"+LIG_ZON(B,L)
   Elsif K=1 & ACT_AZC(A)=2
    PARAM = AZC
   Else
    P = K
    Gosub PARVAL
   Endif
   LIGNE = left$(LIGNE,J-1)+PARAM+right$(LIGNE,J+L1+1)
  Endif
 Until J=0
 For ZON="VALEUR","zc"
  Repeat
   J = instr(1,LIGNE,ZON)
   If J
    LIGNE = left$(LIGNE,J-1)+AZC+right$(LIGNE,J+len(ZON))
   Endif
  Until J=0
 Next ZON
 Wrseq LIGNE
Endif
Return

$GEN_CALL
NOPAR = 0
Wrseq space$(SPA)+'Call'-ACT_SPR(A);
If ACT_AZC(A)=2
 Wrseq "(";AZC;
 NOPAR = 1
Endif
For P=1 To ACT_PAR(A)
 If ACT_AZC(A)<>2 | P>1
  If NOPAR=0 : Wrseq "("; : Else : Wrseq ","; : Endif
  Gosub PARVAL
  If PAR_COD(A,P)=LIG_OBJ(B,L) & PAR_ADR(A,P)=2
   Gosub PARNUM
  Elsif PAR_TYP(A,P)=1
   Gosub PARALPHA
  Endif
  Wrseq PARAM;
  NOPAR += 1
 Endif
Next P
If NOPAR>0 : Wrseq ")"; : Endif
Wrseq " From"-TRTSUB
Return

####################################################
## Sous-prog divers
####################################################
$ACT_AVZ
If ACT_AVZ(A)=2
 Wrseq space$(SPA);'ACTION = "A'+ACT_ETQ(A)+LIG_ZON(B,L)+'"';
 Wrseq ' : PROGSUB = "'+TET_STD+'" : PROGSPE = "'+TET_SPE+'" : PROGSPV = "'+TET_SPV+'"'
 Wrseq space$(SPA);"Gosub ACTSUB From GOBJSUB"
Endif
Return

$ACT_APZ
If ACT_AVZ(A)=2
 Wrseq space$(SPA);'ACTION = "B'+ACT_ETQ(A)+LIG_ZON(B,L)+'"';
 Wrseq ' : PROGSUB = "'+TET_STD+'" : PROGSPE = "'+TET_SPE+'" : PROGSPV = "'+TET_SPV+'"'
 Wrseq space$(SPA);"Gosub ACTSUB From GOBJSUB"
Endif
Return

$SAV_ACT
Wrseq space$(SPA)+'SAVACT = GACTION : GACTION = "'+ACT_ACT(A)+'"'
Return

$REST_ACT
Wrseq space$(SPA)+"GACTION = SAVACT"
Return

$GET_PARAM
NOPAR = 0
For P=1 To ACT_PAR(A)
 If ACT_AZC(A)<>2 | P>1
  NOPAR += 1
  Gosub PARVAL
  Case PAR_TYP(A,P)
   When 1,4
    Wrseq space$(SPA)+"PARAM("+num$(NOPAR)+") = "+PARAM
   When Default
    Gosub PARNUM
    Wrseq space$(SPA)+"PARAM("+num$(NOPAR)+") = "+PARAM
  Endcase
 Endif
Next P
Return

$SET_PARAM
NOPAR = 0
For P=1 To ACT_PAR(A)
 If ACT_AZC(A)<>2 | P>1
  NOPAR += 1
  Gosub PARVAL
  If PAR_ADR(A,P)=1 & PARAM<>""
   If PARAM<>"''" & PARAM<>'""' & PARAM<>"0"
    Case PAR_TYP(A,P)
     When 1,4
      Wrseq space$(SPA)+PARAM+" = PARAM("+num$(NOPAR)+")"
     When Default
      Wrseq space$(SPA)+PARAM+" = val(PARAM("+num$(NOPAR)+"))"
    Endcase
   Endif
  Endif
 Endif
Next IATR
Return

$PARNUM
If num$(val(PARAM))=PARAM
 PARAM = '"'+PARAM+'"'
Elsif PARAM=""
 PARAM = '""'
Elsif left$(PARAM,4)<>"num$" and left$(PARAM,1)<>'"' and left$(PARAM,1)<>"'"
 PARAM = "num$("+PARAM+")"
Endif
Return

$PARALPHA
If num$(val(PARAM))=PARAM
 PARAM = '"'+PARAM+'"'
Elsif PARAM=""
 PARAM = '""'
Endif
Return

$PARVAL
PARAM = PAR_VAL(A,P)
PP = instr(1,PARAM,"[L]VALEUR")
While PP
 PARAM = left$(PARAM,PP-1)+AZC+right$(PARAM,PP+9)
 PP = instr(1,PARAM,"[L]VALEUR")
Wend
If find(PARAM,"VALEUR","zc")
 PARAM = AZC
Endif
Return

$WR_CALL
Wrseq space$(SPA);'Call'-ACT_SPR(A)+"(";
For P=1 To ACT_PAR(A)
 If P>1 : Wrseq ","; : Endif
 Gosub PARVAL
 Wrseq PARAM;
Next P
Wrseq ") From"-ACT_PRG(A)
Return

$PAROBJ
PARAM = ""
For P=1 To ACT_PAR(A)
 If PAR_COD(A,P)=LIG_OBJ(B,L)
  Gosub PARVAL
  Break
 Endif
Next P
If PARAM=""
 PARAM = '""'
Endif
Gosub PARNUM : # Le paramètre objet est toujours alpha
PAROBJ = PARAM
Return

$FIN_IF
For K=1 To NBIF
 SPA = max(0,SPA-1) : Wrseq space$(SPA);"Endif"
Next K
NBIF = 0
Return
