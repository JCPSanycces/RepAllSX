########################################################################
# Sous pro de génération d'événements                                  #
########################################################################
Subprog GENER_EVE(POBJ,PCPY,PFCY,PREF,PLIN,PEVTINT,PDAT,PACCDAT,RCOD)
Value    Integer POBJ          # Objet métier
Value    Char    PCPY()        # Société de l'objet métier
Value    Char    PFCY()        # Site financier
Value    Char    PREF()        # Référence de l'objet métier pour lequel l'evt doit être créé
Value    Integer PLIN          # Complèment de référence, N° de ligne.
Value    Char    PEVTINT()     # Code interne de l'événement à générer
Value    Date    PDAT          # Date d'effet de l'événement
Value    Date    PACCDAT       # Date de comptabilisation de l'événement
Variable Integer RCOD

  Gosub COMMUN_EVE
  If RCOD : End : Endif
  Gosub AIGUILLAGE From =TRTEVTINT
  [F:EVT0]CNX=LCNX
  GOK=1
  GPOINT = "GENEVT" : Gosub ENTREE From EXEFNC
  # FQ106481  End au lieu de Return
  If GOK<1 : End : Endif

  #fq65636
  # Si société avec LEG=FRA, EVT="FASMTC" ou EVT="FASREEVAL"
  # Appel de la fonction d'archivage ARCH_DPRPLN(PAASREF, PDPRPLN, PEVT, PTIMSTP, PNUMTRT, PFICTRA, RERR)
  #> En attendant une extension du mécanisme à d'autres cas et l'éventualité de pouvoir paramétrer
  #  son déclenchement,
  If dim(GFASPLNARC)<0 : Global Integer GFASPLNARC : Endif
 #If (EVT="FASMTC" | EVT="FASREEVAL") & [M:FPC]LEG="FRA"
  If  find(EVT,GARCEVT) & [M:FPC]LEG="FRA"
   GFASPLNARC=G_OUI
  Endif
  #> Appel de la fonction d'archivage si GFASPLNARC=G_OUI
  If GFASPLNARC=G_OUI
   Local Integer RERR
   Call ARCH_DPRPLN(PREF, LPLN, [0/0/0], [0/0/0], "", EVT, [F:EVT0]TIMSTP, 0, "", RERR) From TRCPROCOMARC
   If RERR
    RCOD=100
    GMESSAGE="GENEVE[GENER_EVE-ARC_DPRPLN] Err /RERR="-num$(RERR)-"\"-[F:EVT0]CPY-"-"-PEVTINT-"-"-num$([F:EVT0]DPRPLN)-"-"-[F:EVT0]REF
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    GOK=0
    End
   Endif
  Endif

  Write [EVT0]
  If fstat
    RCOD=90
    GMESSAGE="GENEVE[GENER_EVE] Err /fstat="-num$(fstat)-"\"-[F:EVT0]CPY-"-"-PEVTINT-"-"-num$([F:EVT0]DPRPLN)-"-"-[F:EVT0]REF
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    GOK=0
  Else
   # raf - Paramètre pour activer le suivi de la création des événements (TEC - LOGEVT)
   If GUSER="GBO" | 1=0
    Local Char ENREG(80)
    Openo filpath("tmp","event","log") Using [XTRC]
    ENREG=date$+";"+num$(time)+";"+GUSER+";"+num$(POBJ)+";"+PCPY+";"+PFCY+";"+PREF+";"+num$(PLIN)+";"+PEVTINT+";"+PDAT+";"+PACCDAT
    Wrseq ENREG Using [XTRC]
    Openo Using [XTRC]
   Endif
  Endif

End

########################################################################
# Recherche si l'événement passé existe pour l'objet métier            #
########################################################################
Funprog EXISTE_EVE(POBJ,PCPY,PFCY,PREF,PLIN,PEVTINT,PSNSEVE,RCOD)
Value    Integer POBJ          # Objet métier
Value    Char    PCPY()        # Société de l'objet métier
Value    Char    PFCY()        # Site financier
Value    Char    PREF()        # Référence de l'objet métier pour lequel l'evt doit être recherché
Value    Integer PLIN          # Complément de référence, N° de ligne.
Value    Char    PEVTINT()     # Code interne de l'événement à rechercher
Value    Integer PSNSEVE       # Type d'événement recherché (GVML_TEACT ou GVML_TEAACT)
Variable Integer RCOD

Local Integer LEXISTE
  LEXISTE = G_NON
  Gosub COMMUN_EVE
  If RCOD : End : Endif
  Gosub RAZ_F_EVT0_1 From =TRTEVTINT
  Gosub CONDITION_EVE  From =TRTEVTINT
  Filter [EVT0] Where evalue(LCNDREQEVT)
  Read [EVT0]EVE0 Last
  Filter [EVT0]
  If fstat>2 Then
    LEXISTE = G_NON
  Else
    LEXISTE = G_OUI
  Endif
End LEXISTE

########################################################################
# Recherche si l'événement passé existe pour l'objet métier            #
########################################################################
Funprog EXISTE_EVE_DATE(POBJ,PCPY,PFCY,PREF,PLIN,PEVTINT,PSNSEVE,PTYPDAT, PEVEDAT,RCOD)
Value    Integer POBJ          # Objet métier
Value    Char    PCPY()        # Société de l'objet métier
Value    Char    PFCY()        # Site financier
Value    Char    PREF()        # Référence de l'objet métier pour lequel l'evt doit être recherché
Value    Integer PLIN          # Complément de référence, N° de ligne.
Value    Char    PEVTINT()     # Code interne de l'événement à rechercher
Value    Integer PSNSEVE       # Type d'événement recherché (GVML_TEACT ou GVML_TEAACT)
Value    Integer PTYPDAT       # 1 - EVTDAT / 2 - CPTDATINT
Value    Date    PEVEDAT       # Date d'effet de l'événement à rechercher
Variable Integer RCOD

Local Integer LEXISTE

  LEXISTE = G_NON
  # -------------------------------------
  Gosub COMMUN_EVE
  If RCOD : End LEXISTE : Endif
  # -------------------------------------
  Gosub OUVRE_TABLE From =TRTEVTINT
  # -------------------------------------
  Gosub RAZ_F_EVT0_1 From =TRTEVTINT
  Gosub CONDITION_EVE  From =TRTEVTINT
  If LCNDREQEVT<>"" : LCNDREQEVT+="&" : Endif
  If PTYPDAT = 1
   LCNDREQEVT+="EVTDAT=PEVEDAT"
  Elsif PTYPDAT = 2
   LCNDREQEVT+="CPTDATINT=PEVEDAT"
  Else
   Call ECR_TRACE(EXISTE_EVE_DATE-"PTYPDAT 1/2"-num$(PTYPDAT),1) From GESECRAN
  Endif
  # -------------------------------------
  Filter [EVT0] Where evalue(LCNDREQEVT)
  Read [EVT0]EVE0 Last
  Filter [EVT0]
  If fstat>2 Then
    LEXISTE = G_NON
  Else
    LEXISTE = G_OUI
  Endif
  # -------------------------------------
End LEXISTE

########################################################################
# Recherche si un événement d'annulation d'action existe par rapport   #
# à l'événement en mémoire                                             #
# DOIT ETRE EXECUTE APRES "EXISTE_EVE"                                 #
# ou "EXISTE_EVE_DATE"                                                 #
# L'événement dont on doit chercher l'extourne doit être disponible    #
# dans la classe [F:EVT0]                                              #
########################################################################
Funprog EXISTE_EXTOURNE_EVE(RCOD)
Variable Integer RCOD

Local Integer LEXISTE
Local Char    SREQUETE(250)

  SREQUETE  = 'REF=[F:EVT0]REF&CPY=[F:EVT0]CPY&EVTINT=[F:EVT0]EVTINT&DPRPLN=[F:EVT0]DPRPLN'
  SREQUETE += '&CREUSRO=[F:EVT0]CREUSR&TIMSTPO=[F:EVT0]TIMSTP'
  SREQUETE += '&SNSEVE=GVML_TEAACT'

  Filter [EVT1] Where evalue(SREQUETE)
  Read [EVT1]EVE1 Last
  Filter [EVT1]

  If fstat>2 Then
    LEXISTE = G_NON
  Else
    LEXISTE = G_OUI
  Endif
End LEXISTE

########################################################################
# Génère l'événement d'annulation d'action de l'événement en mémoire   #
# DOIT ETRE EXECUTE APRES "EXISTE_EXTOURNE_EVE"                        #
########################################################################
Subprog EXTOURNE_EVE(POBJ,PCPY,PFCY,PREF,PLIN,PEVTINT,PDAT,RCOD)
Value    Integer POBJ          # Objet métier
Value    Char    PCPY()        # Société de l'objet métier
Value    Char    PFCY()        # Site financier
Value    Char    PREF()        # Référence de l'objet métier pour lequel l'evt doit être créé
Value    Integer PLIN          # Complèment de référence, N° de ligne.
Value    Char    PEVTINT()     # Code interne de l'événement à générer
Value    Date    PDAT          # Date d'effet de l'événement
Variable Integer RCOD

Local Integer LEXISTE
Local Char    SREQUETE(250)

  RCOD=0
  Gosub COMMUN_EVE
  If RCOD : End : Endif
  Gosub ANNULE_EVE From =TRTEVTINT
  GPOINT = "ANNEVT" : Gosub ENTREE From EXEFNC
  # FQ106481  End au lieu de Return
  If GOK<1 : End : Endif
  Write [EVT0]
  If fstat
    RCOD = 90
    GMESSAGE = "GENEVE[EXTOURNE_EVE] Err /fstat="-num$(fstat)-"\"-[F:EVT0]CPY-"-"-[F:EVT0]EVT-"-"-num$([F:EVT0]PLN)-"-"-[F:EVT0]REF
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    GOK  = 0
  Endif

End

########################################################################
# Enchaine les fonctions et sous-programme pour aboutir à l'annulation #
# d'un événement                                                       #
#         C'EST NORMALEMENT CE S/P QUI DEVRAIT ETRE UTILISE            #
########################################################################
Subprog ANNULE_EVE(POBJ,PCPY,PFCY,PREF,PLIN,PEVTINT,PDAT,REVTCREE,RCOD)
Value    Integer POBJ          # Objet métier
Value    Char    PCPY()        # Société de l'objet métier
Value    Char    PFCY()        # Site financier
Value    Char    PREF()        # Référence de l'objet métier pour lequel l'evt doit être créé
Value    Integer PLIN          # Complèment de référence, N° de ligne.
Value    Char    PEVTINT()     # Code interne de l'événement à générer
Value    Date    PDAT          # Date d'effet de l'événement
Variable Integer REVTCREE
Variable Integer RCOD

  Gosub COMMUN_EVE
  If RCOD : End : Endif
  Gosub OUVRE_TABLE  From =TRTEVTINT
  If func GENEVE.EXISTE_EVE(POBJ,PCPY,PFCY,PREF,PLIN,PEVTINT,GVML_TEACT,RCOD) = G_OUI Then
    # Un événement normal existe
    If func GENEVE.EXISTE_EXTOURNE_EVE(RCOD) = G_NON Then
      #FQ61936- Si PDAT=[0/0/0] on prend la date d'effet de l'événement à annuler
      If PDAT=[0/0/0]
       PDAT=[F:EVT0]EVTDAT
      Endif
      # L'événement n'a pas déjà été annulé
      Call EXTOURNE_EVE(POBJ,PCPY,PFCY,PREF,PLIN,PEVTINT,PDAT,RCOD)
      # Si la création de l'événément d'annulation a échoué RCOD=90
      REVTCREE = G_OUI
    Else
      # L'événement a déjà été annulé ! Bizarre qu'on soit dans cette situation !
      RCOD     = 91
      REVTCREE = G_NON
    Endif
  Else
    # Un événement normal n'existe pas : pas la peine de l'annuler
    # On considère donc que tout c'est bien passé dans ce cas
    RCOD       = 0
    REVTCREE   = G_NON
  Endif
End

########################################################################
# Enchaine la création des événements d'annulation de tous les         #
# événements existant pour une référence d'objet                       #
#         C'EST NORMALEMENT CE S/P QUI DEVRAIT ETRE UTILISE            #
########################################################################
Subprog DETRICOTE_EVE(POBJ,PCPY,PREF,PLIN,PDAT,PJAUGE,RCOD)
Value    Integer POBJ          # Objet métier
Value    Char    PCPY()        # Société de l'objet métier
Value    Char    PREF()        # Référence de l'objet métier pour lequel l'evt doit être créé
Value    Integer PLIN          # Complément de référence, N° de ligne.
Value    Date    PDAT          # Date d'effet de l'événement
Value    Integer PJAUGE        # Affichage de la jauge (Modif JDE 2004/01/28)
Variable Integer RCOD

Local    Char    TXTPROG(40)
Local    Integer NBBCO, NBBCO_TRT, LOK
Local    Integer REVTCREE
Local    Char    SREQUETE(255)

 If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
 Filter [ADI] Where NUMTAB=GTD_EVENT & N2=POBJ # Table diverse 962
#Trbegin [F:ADI]
 Raz NBBCO, NBBCO_TRT
 TXTPROG = mess(107,7770,1)
 If PJAUGE = G_OUI : Call OUVRE_BOITE(TXTPROG, NBBCO) From GESECRAN : Call SET_BOITE(TXTPROG, NBBCO) From GESECRAN : Endif
 For [ADI]
  If find([F:ADI]A2,GTABEVT) : # FQ59900
   If clalev([F:EVT0]) : Close Local File [F:EVT0] : Endif
   Local File =[F:ADI]A2 [EVT0]
   If clalev([F:EVT1]) : Close Local File [F:EVT1] : Endif
   Local File =[F:ADI]A2 [EVT1]
   SREQUETE = "CPY=PCPY & REF=PREF & SNSEVE=GVML_TEACT"
   If POBJ = GVML_OMDEPEN
    SREQUETE += "&LIN=PLIN"
   Endif
   Filter [F:EVT0] Where evalue(SREQUETE)
   Raz NBBCO_TRT
   NBBCO   = rowcount([F:EVT0])
   If PJAUGE=G_OUI : Call SET_BOITE(TXTPROG, NBBCO) From GESECRAN : Endif
   For [F:EVT0]
    TXTPROG = right$([F:ADI]A2,5)+'/'+num$([F:EVT0]DPRPLN)+"/"+"["+num$([F:EVT0]EVTDAT)+"] "+num$(NBBCO_TRT)+'/'+num$(NBBCO)
    NBBCO_TRT+=1
    Call AFF_BOITE(TXTPROG,NBBCO_TRT,LOK) From GESECRAN
   Next
   Filter [F:EVT0]
  Endif
 Next
 If PJAUGE = G_OUI : Call FERME_BOITE From GESECRAN : Endif
 If GOK
# Commit
 Else
# Rollback
 Endif
 Filter [ADI]
End

########################################################################
# Enchaine la création des événements d'annulation de tous les         #
# événements existant pour une référence d'objet                       #
#         C'EST NORMALEMENT CE S/P QUI DEVRAIT ETRE UTILISE            #
########################################################################
## Affichage de la jauge (Modif JDE 2004/01/28) : ajout du parametre PJAUGE
Subprog DETRICOTE_EVE_V140(POBJ,PCPY,PREF,PLIN,PDAT,PJAUGE,RCOD)

Value    Integer POBJ          # Objet métier
Value    Char    PCPY()        # Société de l'objet métier
Value    Char    PREF()        # Référence de l'objet métier pour lequel l'evt doit être créé
Value    Integer PLIN          # Complément de référence, N° de ligne.
Value    Date    PDAT          # Date d'effet de l'événement
Value    Integer PJAUGE        # Affichage de la jauge (Modif JDE 2004/01/28)
Variable Integer RCOD

Local    Char    TXTPROG(40)
Local    Integer NBBCO, NBBCO_TRT, LOK
Local    Integer REVTCREE

  If dim(APPLI)<0 : Local Char APPLI(30) : APPLI=nomap : Endif
  Case POBJ
    When GVML_OMDEPEN
      If !clalev([F:EVT0]) : Local File =APPLI+".EVELOF" [EVT0] : Endif
      If !clalev([F:EVT1]) : Local File =APPLI+".EVELOF" [EVT1] : Endif
      Filter [EVT0] Where CPY=PCPY and REF=PREF and LIN=PLIN and SNSEVE=GVML_TEACT
    When GVML_OMBIEN
      If !clalev([F:EVT0]) : Local File =APPLI+".EVEFAS" [EVT0] : Endif
      If !clalev([F:EVT1]) : Local File =APPLI+".EVEFAS" [EVT1] : Endif
      Filter [EVT0] Where CPY=PCPY and REF=PREF and SNSEVE=GVML_TEACT
    When GVML_OMSUBV
      If !clalev([F:EVT0]) : Local File =APPLI+".EVEGRT" [EVT0] : Endif
      If !clalev([F:EVT1]) : Local File =APPLI+".EVEGRT" [EVT1] : Endif
      Filter [EVT0] Where CPY=PCPY and REF=PREF and SNSEVE=GVML_TEACT
    When GVML_OMLOCFI
      If !clalev([F:EVT0]) : Local File =APPLI+".EVELEA" [EVT0] : Endif
      If !clalev([F:EVT1]) : Local File =APPLI+".EVELEA" [EVT1] : Endif
      Filter [EVT0] Where CPY=PCPY and REF=PREF and SNSEVE=GVML_TEACT
  Endcase
  #------------------------------------
  Raz NBBCO, NBBCO_TRT
  TXTPROG = mess(107,7770,1)
  NBBCO   = rowcount([EVT0])

  If PJAUGE = G_OUI
   Call OUVRE_BOITE(TXTPROG, NBBCO) From GESECRAN
   Call SET_BOITE(TXTPROG, NBBCO) From GESECRAN
  Endif

  #------------------------------------
  For [EVT0]EFS0
    #------------------------------------
    NBBCO_TRT += 1
    TXTPROG    = mess(108,7770,1)-': '-[F:EVT0]EVT+'/'+num$([F:EVT0]PLN)+num$([F:EVT0]EVTDAT)+'['+num$(NBBCO_TRT)+'/'+num$(NBBCO)+']'
    # Affichage de la jauge conditionné par un paramètre (Modif JDE 2004/01/28)
    If PJAUGE = G_OUI
     Call AFF_BOITE(TXTPROG,NBBCO_TRT,LOK) From GESECRAN
    Endif
    #------------------------------------
    If func GENEVE.EXISTE_EXTOURNE_EVE(RCOD) = G_NON Then
      # Il n'a pas déjà été extourné, on le fait
      Call EXTOURNE_EVE(POBJ,[F:EVT0]CPY,[F:EVT0]FCY,[F:EVT0]REF,PLIN,[F:EVT0]EVTINT,PDAT,RCOD)
      If RCOD > 20 Then
        Break
      Endif
    Endif
    #------------------------------------
    # Suite de la boucle
  Next
  Filter [EVT0]
  #------------------------------------
  # Affichage de la jauge conditionné par un paramètre (Modif JDE 2004/01/28)
  If PJAUGE = G_OUI
      Call FERME_BOITE From GESECRAN
  Endif
  #------------------------------------
End

# -------------------------------------------------------------------------------------------
$COMMUN_EVE
  Local Char    EVT(9)           # Nom du type événement auquel est rattaché le code interne
  Local Integer LPLN             # Plan d'amortissement auquel est rattaché le code interne
  Local Integer LCNX             # Contexte auquel le plan appartient
  Local Date    LCURPERSTR       # Date début de période courante FQ101826
  Local Char    CRITSEA(200)     # Critère de recherche
  Local Char    CODEVTINT        # Code interne événement à générer
  Local Char    LCNDREQEVT(200)  # Condition de recherche d'événement
  Local Char    NOMTRT(20)       # Nom du traitement généré associé au type événement
  Local Char    PRFX_COM         : PRFX_COM="G"
  Local Char    PRFX_EVT         : PRFX_EVT=PRFX_COM+"EV"
  Local Char    PRFX_INT         : PRFX_INT=PRFX_COM+"V"
  Local Integer EXISTE_ADX

  Local Char TRTEVTINT
  TRTEVTINT=PRFX_INT+PEVTINT
  Call EXISTE_ADX("","",TRTEVTINT,EXISTE_ADX) From ORDSYS
  If EXISTE_ADX Then
   Gosub INFO_EVTINT From =TRTEVTINT
   Call GET_CNX_FROM_PLAN (PCPY, LPLN, LCNX) From GLOBIENS
   If LCNX=-1 : LCNX=0 : Endif
  Else
   RCOD=1 # Le code interne n'existe pas
  Endif

  # FQ101826 Récupération dates début de période courante
  LCURPERSTR = [0/0/0]
  Local Date    TBDAT(1..5)
  Local Integer RRET
  If (LCNX = 0) Then
    Call GET_CNX_DAT( PCPY, G300CPFI, TBDAT, RRET ) From GLOBIENS
  Else
    Call GET_CNX_DAT( PCPY, LCNX, TBDAT, RRET ) From GLOBIENS
  Endif
  If (RRET) Then : RCOD = 2 : Else : LCURPERSTR = TBDAT(3) : Endif

  CODEVTINT = PEVTINT
  NOMTRT    = PRFX_EVT+EVT

  If LPLN <> G301AUC Then
    If func GLOBIENS.CPY_PLN_GERE(PCPY,LPLN)=G_NON
      Raz RCOD
      End
    Endif
  Endif

Return

# -------------------------------------------------------------------------------------------
$GENERE_LOG
Return

########################################################################
# Sous pro permettant de récupérer un tableau contenant le paramètrage #
# par zone numérique de l'événement de la gestion du prorata.          #
# - pour les zones libre, le résultat de ce sous-programme est issu de #
# la lecture du pramètrage contenu dans la table FREFLD                #
# - Pour toutes les autres zones numériques, le status de la zone est  #
#   fixé en développement ou en maintenance et est généré en dur dans  #
#   le traitement propre à chaque type d'événement.                    #
########################################################################
Subprog GET_PRORATA_STATUS(POBJ,PCPY,PEVT,PPLN,R_TABNOMZON, R_TABORDZON, R_TABSTATUS,RCOD)
Value    Integer POBJ               # Objet métier auquel l'événement correspond
Value    Char    PCPY               # Société pour récupérer le paramètrage prorata des ZL
Value    Char    PEVT               # Nom du code interne de l'événement pour lequel on récupère les flags de prorata
Value    Integer PPLN               # Plan d'amortissement
Variable Char    R_TABNOMZON()()    # Tableau des noms de zones
Variable Integer R_TABORDZON()      # Tableau des numéros d'ordre des zones
Variable Integer R_TABSTATUS()      # Tableau des statuts de prorata.
Variable Integer RCOD               # Code retour du s/p

Local Integer NB_NUMZON  : NB_NUMZON = 40
Local Char    PRFX_COM   : PRFX_COM="G"
Local Char    PRFX_EVT   : PRFX_EVT=PRFX_COM+"V"
Local Char    PRFX_INT   : PRFX_INT=PRFX_COM+"I"
Local Char    EVTINT

# Issue 109496
#Case PEVT
# When "FASACT"    : EVTINT = "FASACT"
# When "FASAFFAGE" : EVTINT = "FASAFF"
# When "FASCCNAGE" : EVTINT = "FASCCNAGE"
# When "FASCHGIMP" : EVTINT = "FASCHGIC"
# When "FASCRT"    : EVTINT = "FASCRT"
# When "FASIML"    : EVTINT = "FASIML"
# When "FASISS"    : EVTINT = "FASISS"
# When "FASCCNISS" : EVTINT = "FASCCNISS"
# When "FASMTC"    : EVTINT = "FASMTC"
# When "FASREEVAL" : EVTINT = "FASRVA"
# When "FASVATREG" : EVTINT = "FASVATREG"
# When "FASCCN"    : EVTINT = "FASCCN"
# When "FASRNW"    : EVTINT = "FASRNW"
# When "GRTCASH"   : EVTINT = "GRTCASH"
# When "GRTCRB"    : EVTINT = "GRTCRB"
# When "GRTCRT"    : EVTINT = "GRTCRT"
# When "LEAACTU"   : EVTINT = "LEAACTU"
# When "LEACRT"    : EVTINT = "LEACRT"
# When "LEAEND"    : EVTINT = "LEAEND"
# When "LEAPAY"    : EVTINT = "LEAPAY"
# When "LEARPU"    : EVTINT = "LEARPU"
# When "LEATRM"    : EVTINT = "LEATRM"
# When "LOFCIM"    : EVTINT = "LOFCIM"
# When "LOFVATREG" : EVTINT = "LOFVATREG"
# When "FASPLMDR"  : EVTINT = "FASPLMDR"
# When "FASCFS"    : EVTINT = "FASCFS"      : # 95754_4
#Endcase
Case PEVT
 When "FASAFFAGE" : EVTINT = "FASAFF"
 When "FASCHGIMP" : EVTINT = "FASCHGIC"
 When "FASREEVAL" : EVTINT = "FASRVA"
 When Default     : EVTINT = PEVT
Endcase
# End Issue 109496
Local Char    NOMTRT     : NOMTRT    = PRFX_EVT+EVTINT

If PPLN<>G301AUC
 NOMTRT+=num$(PPLN)
Endif

Local Char    T_INTNOMZON(10)(NB_NUMZON)
Local Integer T_INTORDZON(NB_NUMZON)
Local Integer T_INTSTATUS(NB_NUMZON)
Local Integer I_ZON
Local Integer I_CUR

If !clalev([F:FRFW]) : Local File FREFLD [FRFW] : Endif

# On récupère les infos générés à la validation de l'événement dans le traitement WM+CODEVT

 Raz I_CUR
 Gosub ECLATE_STATUS From =NOMTRT  # Alimente les variables dimensionnées et positionne I_CUR : dernier indice alimenté

# transfert des variables dimensionnées dans les variables de retour

 Local Integer I_CUR : Raz I_CUR
 For I_ZON=0 To dim(T_INTSTATUS)-1
  If T_INTNOMZON(I_ZON)<>""
   R_TABNOMZON(I_ZON)=T_INTNOMZON(I_ZON)
   I_CUR+=1
  Endif
 Next I_ZON

# On va chercher les infos concernant les zones libres dans FREFLD

 Read [FRFW]FRF0=POBJ;PCPY
 If fstat
  Case fstat
   When 5
    Read [FRFW]FRF0=POBJ;""
    If fstat
     RCOD=11
     End
    Endif
   When Default
    RCOD=11
    End
  Endcase
 Endif

 For I_ZON=1 To dim([F:FRFW]AMTRIOIND)
  If [F:FRFW]AMTRIOIND(I_ZON-1)=G_OUI
   R_TABNOMZON(I_CUR+I_ZON-1)="USRFLDM"+num$(I_ZON)
  Endif
 Next I_ZON

End

########################################################################
# Sous pro permettant de supprimer définitivement les événements       #
#                                                                      #
########################################################################
Subprog SUPP_EVE(POBJ,PCPY,PFCY,PREF,PLIN,PEVT,PEVTINT,PDAT,PCRIT,RNBEVESUP,RCOD)
Value    Integer   POBJ       # Objet Métier
Value    Char      PCPY       # Société
Value    Char      PFCY       # Site
Value    Char      PREF       # Référence objet métier
Value    Integer   PLIN       # Ligne Objet métier
Value    Char      PEVT       # Evénement
Value    Char      PEVTINT    # Code interne
Value    Date      PDAT       # Date d'effet
Value    Char      PCRIT      # Critère de sélection
Variable Integer   RNBEVESUP  # Nombre d'enregistrements supprimés
Variable Integer   RCOD       # Code retour

Local Integer L_MAXZON : L_MAXZON=5 #FQ57391

Local Char    L_CRITERE(255)
Local Char    L_TABEVT
Local Char    APPLI             : APPLI=nomap

#FQ57391
#Case POBJ
# When GVML_OMBIEN  : L_TABEVT="EVEFAS"
# When GVML_OMDEPEN : L_TABEVT="EVELOF"
# When GVML_OMLOCFI : L_TABEVT="EVELEA"
# When GVML_OMSUBV  : L_TABEVT="EVEGRT"   #**>Fq-37486
# When GVMLOMPHY    : L_TABEVT="EVEPHY"
# When Default      : RCOD=0 : End
#Endcase
If !clalev([F:ADI])  : Local File =APPLI+"."+"ATABDIV" [ADI] : Endif
Read [F:ADI]CODE= GTD_EVENT ;PEVT : # FQ57391 : il manquait le "E" à "CODE"
                                    #@fq64817 - Mauvais n° de TD 952 au lieu de 962.
If fstat

Endif

If !find([F:ADI]A2,GTABEVT) : End : Endif : # FQ59900

L_TABEVT=[F:ADI]A2 #FQ57391
If !clalev([F:EVT0]) : Local File =APPLI+"."+L_TABEVT [EVT0] : Endif

If PCRIT<>""
 L_CRITERE=PCRIT
Endif

#> Suppression d'événements en précisant des zones de la clé

If PCRIT=""
 Local Char    L_TABZON(15)(L_MAXZON)
 Local Char    L_TABPAR(15)(L_MAXZON)
 Local Char    L_TABTYP(15)(L_MAXZON)
 Local Char    L_EXPRESSION(255)
 Local Integer I_ZON

 L_TABZON(0)="CPY"    : L_TABPAR(0)="PCPY"    : L_TABTYP(0)="Char"
 L_TABZON(1)="FCY"    : L_TABPAR(1)="PFCY"    : L_TABTYP(1)="Char"
 L_TABZON(2)="REF"    : L_TABPAR(2)="PREF"    : L_TABTYP(2)="Char"
 L_TABZON(3)="LIN"    : L_TABPAR(3)="PLIN"    : L_TABTYP(3)="Int"
#L_TABZON(4)="EVT"    : L_TABPAR(4)="PEVT"    : L_TABTYP(4)="Char" #FQ57391
#L_TABZON(5)="EVTINT" : L_TABPAR(5)="PEVTINT" : L_TABTYP(5)="Char" #FQ57391
 L_TABZON(4)="EVTDAT" : L_TABPAR(4)="PDAT"    : L_TABTYP(4)="Date"

 For I_ZON=1 To dim(L_TABZON)
  Case L_TABTYP(I_ZON-1)
   When "Char" : L_EXPRESSION=L_TABPAR(I_ZON-1)+"<>''"
   When "Int"  : L_EXPRESSION=L_TABPAR(I_ZON-1)+"<>0"
   When "Date" : L_EXPRESSION=L_TABPAR(I_ZON-1)+"<>[0/0/0]"
  Endcase
  If evalue(L_EXPRESSION)
   If L_CRITERE<>"" : L_CRITERE+="&" : Endif
   L_CRITERE+=L_TABZON(I_ZON-1)+"="+L_TABPAR(I_ZON-1)
  Endif
 Next I_ZON
Endif

#> Suppression d'événements en utilisant un critère
If L_CRITERE<>""
 If !adxlog : Trbegin [EVT0] : Endif
 Delete [EVT0] Where evalue(L_CRITERE)
 If fstat
  RCOD=90
  Infbox mess(7,21,1)-":"-mess(235,GML_MSGFASPR,1)-"/fstat="-num$(fstat)
  GOK=0
  If !adxlog : Rollback : Endif
 Else
  RNBEVESUP=adxdlrec
  RCOD=0
  GOK=1
  If !adxlog : Commit : Endif
 Endif
Endif

End

######################################################################################
# Suppression de tous les événements autres que ceux d'annulation pour un type donné #
# d'objet métier passé en paramètre                                                  #
######################################################################################
Subprog SUPP_EVE_OBJ(POBJTYP,PCPY,PFCY,PREF,PLIN,PDAT,RNBEVESUP,RCOD)
Value    Integer POBJTYP
Value    Char    PCPY
Value    Char    PFCY
Value    Char    PREF
Value    Integer PLIN
Value    Date    PDAT
Variable Integer RNBEVESUP
Variable Integer RCOD

Local Integer CADIEVT : CADIEVT=GTD_EVENT # Table diverse 962
Local Char    LREQ(255)

# Evènements à ne pas supprimer
Local Char    LSTEVTCNL(20)(6) # FQ94500
LSTEVTCNL(0)="LOFCNL"
LSTEVTCNL(1)="FASCNL"
LSTEVTCNL(2)="FASCCNCNL"
LSTEVTCNL(3)="LEACNL"
LSTEVTCNL(4)="GRTCNL"
LSTEVTCNL(5)="FASLNKCNL" # FQ94500

If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif

#> Contrôle des paramétres

RCOD=0
If PCPY="" | PFCY="" | PREF=""
 RCOD=1
 End
Endif

#> Suppression des événements autres que ceux d'annulation pour la référence passée en paramètre.

GOK=1
Call TEMPON(mess(235,7770,1)) From GESECRAN # "Suppression des événements"
If !adxlog : Trbegin [ADI] : Local Integer LTRS : Endif
For [F:ADI] Where NUMTAB=CADIEVT & N2=POBJTYP
 If !find([F:ADI]CODE,LSTEVTCNL)  #right$([F:ADI]CODE,4)<>"CNL"
  If find([F:ADI]A2,GTABEVT) : # FQ59900
   If clalev([F:EVT]) : Close Local File [F:EVT] : Endif
   Local File =[F:ADI]A2 [EVT]
   LREQ="REF=PREF" : If POBJTYP=GVML_OMDEPEN : LREQ+="& LIN=PLIN" : Endif
   Delete [EVT] Where evalue(LREQ)
   If fstat
    Call ECR_TRACE("GENEVE.SUPP_EVE_OBJ(I)-"+[F:ADI]A2+"("+PREF+")"+"-fstat="+num$(fstat),1) From GESECRAN
    RCOD=2 : GOK=0 : Break
   Else
    RNBEVESUP+=adxdlrec
   Endif
  Endif
 Endif
Next

If dim(LTRS)>0
 If GOK
  Commit
 Else
  Rollback
 Endif
 Kill LTRS
Endif

Call TEMPOFF From GESECRAN

End

######################################################################################
# Création de l'événement d'annulation d'un objet métier                             #
#                                                                                    #
# Statuts de retour du sous-programme :                                              #
#  1  - Paramétres invalides                                                         #
#  2  - Le type d'événement Annulation n'existe pas pour cet objet                   #
#  3  - Le bien comptable passé en paramètre n'existe pas                            #
#                                                                                    #
#                                                                                    #
######################################################################################
Subprog CRE_EVE_CNL_OBJ(POBJTYP,PCPY,PFCY,PREF,PLIN,PDAT,RCOD)
Value    Integer POBJTYP
Value    Char    PCPY
Value    Char    PFCY
Value    Char    PREF
Value    Integer PLIN
Value    Date    PDAT
Variable Integer RCOD

If !clalev([F:ADI])  : Local File ATABDIV  [ADI]  : Endif
If !clalev([F:CNX])  : Local File CONTEXT  [CNX]  : Endif
If !clalev([F:FISC]) : Local File FISCYEAR [FISC] : Endif
If !clalev([F:FISS]) : Local File FISCYEAR [FISS] : Endif


Local Char    LOBJEVT
Local Integer I_PLN, LPLN
Local Integer LPLNGERE(1..G301MAX-1)

#> Contrôle des paramétres

RCOD=0
If PCPY="" | PFCY="" | PREF=""
 RCOD=1
 End
Endif

Case POBJTYP
 When GVML_OMDEPEN : LOBJEVT="LOFCNL"
 When GVML_OMBIEN  : LOBJEVT="FASCNL"
 When GVML_OMLOCFI : LOBJEVT="LEACNL"
 When GVML_OMSUBV  : LOBJEVT="GRTCNL"
 When GVMLOMPHY    : LOBJEVT="PHYCNL"
Endcase

Read [F:ADI]CODE=GTD_EVENT;LOBJEVT # Table diverse 962
If fstat>1
 GOK=0
 RCOD=2
 End
Endif

Case POBJTYP
 When GVML_OMDEPEN : Gosub LOFCNL
 When GVML_OMBIEN  : Gosub FASCNL
 When GVML_OMLOCFI : Gosub LEACNL
 When GVML_OMSUBV  : Gosub GRTCNL
 When GVMLOMPHY    : Gosub PHYCNL
Endcase

End

#----------------------------------------------------------------------------------------
# Evénement(s) d'annulation d'une dépense
# o Exercice courant et antérieurs :
#----------------------------------------------------------------------------------------
$LOFCNL

 If !clalev([F:LOF])  : Local File LAYOUTFAS [LOF]  : Endif

 If [F:LOF]CODLOF<>PREF | [F:LOF]LINLOF<>PLIN
  Read [F:LOF]LOF0=PREF;PLIN
  If fstat>1
   GOK=0
   RCOD=3
   Return
  Endif
 Endif

 Local Integer LPLN
 Local Char    EVTINT
 Local Date    DATE_EFFET
 Local Date    DATE_COMPTA
 Local Integer CODERR

 LPLNGERE(1)=G_OUI
 If GIAS : LPLNGERE(6)=G_OUI : Endif

 For LPLN=1 To G301MAX-1
  EVTINT      = LOBJEVT+num$(LPLN)
  DATE_COMPTA = date$
  DATE_EFFET  = date$
  If dim(GCPTEXEANT)<0 : Global Integer GCPTEXEANT : Endif
  GCPTEXEANT = G_OUI
  Call GENER_EVE(GVML_OMDEPEN,[F:LOF]CPY,[F:LOF]FCY,[F:LOF]CODLOF,[F:LOF]LINLOF,EVTINT,DATE_EFFET,DATE_COMPTA,CODERR) From GENEVE
 Next LPLN

Return

#----------------------------------------------------------------------------------------
# Evénement(s) d'annulation d'un bien comptable.
# o Exercice courant et antérieurs :
#   ------------------------------
#
#   Lecture de l'enregistrement DEPREC période courante, exercice courant
#   - Les cumuls début exercice portés sur cet enregistrement correspondent aux cumuls
#     relevant des exercices antérieurs
#   - Les montants comptabilisés sur l'exercice courant sont calculés en lisant tous
#     les DEPREC de l'exercice et en faisant la somme (info par info) des montants
#     réellement comptabilisés (champs PSTxxx).
#   - Lecture des événements comptabilisés de dépréciation pour l'exercice.
#   - Lecture des événements comptabilisés de réévaluation pour l'exercice.
#   - Date comptable exercice courant (début ou fin ?)
#
# o Exercice suivant :
#   ----------------
#
#   Un événement est créé uniquement si il y a au moins une période en compta définitive
#   - Les cumuls exercices précédent sont vides.
#   - Montants de l'exercice à extourner obtenus par une boucle sur les DEPREC de
#     l'exercice suivant.
#   - Date comptable exercice suivant (début ou fin ?)
#----------------------------------------------------------------------------------------
$FASCNL

 If !clalev([F:FAS])  : Local File FXDASSETS [FAS]  : Endif
 If !clalev([F:DEP])  : Local File DEPREC    [DEP]  : Endif
 If !clalev([F:DEPE]) : Local File DEPREC    [DEPE] : Endif

 Local Char    EVTINT
 Local Date    DATE_EFFET
 Local Date    DATE_COMPTA
 Local Integer CODERR

 If [F:FAS]AASREF<>PREF
  Read [F:FAS]FAS0=PREF
  If fstat>1
   GOK=0
   RCOD=3
   Return
  Endif
 Endif

 For [F:CNX] Where CPY=PCPY
  Read [F:FISC]FIY1=PCPY;[F:CNX]CNX;GVML_TECOURA
  Read [F:FISS]FIY1=PCPY;[F:CNX]CNX;GVML_TESUIV
  For I_PLN=1 To [F:CNX]NBPLC
   Raz [F:DEPE]
   LPLNGERE([F:CNX]PLNCAA(I_PLN-1))=G_OUI
   LPLN=[F:CNX]PLNCAA(I_PLN-1)
   Read [F:DEP]DEP0=PREF;LPLN;[F:FISC]DATENDFIY;[F:FISC]DATENDPER([F:FISC]INDCURPER-1)

   [F:DEPE]=[F:DEP]
   Raz [F:DEPE]PSTDPE,
&      [F:DEPE]PSTEXC,
&      [F:DEPE]PSTDER,
&      [F:DEPE]PSTDERRVE,
&      [F:DEPE]PSTRVETRF,
&      [F:DEPE]PSTRVACRB,
&      [F:DEPE]IML,
&      [F:DEPE]IMLRVE,
&      [F:DEPE]RVAAMT,
&      [F:DEPE]PSTRVACRB

   # Recherche des montants à extourner sur DEPREC

   For [F:DEP] Where CPY=PCPY & AASREF=PREF & DPRPLN=LPLN & FIYENDDAT=[F:FISC]DATENDFIY
    [F:DEPE]PSTDPE    += [F:DEP]PSTDPE
    [F:DEPE]PSTEXC    += [F:DEP]PSTEXC
    [F:DEPE]PSTDER    += [F:DEP]PSTDER
    [F:DEPE]PSTDERRVE += [F:DEP]PSTDERRVE
    [F:DEPE]PSTRVETRF += [F:DEP]PSTRVETRF
    [F:DEPE]PSTRVACRB += [F:DEP]PSTRVACRB
   Next

   # Dépréciation

   If clalev([F:EVT]) : Close Local File [F:EVT] : Endif
   Local File EFASIML [EVT]
   For [F:EVT] Where REF=PREF & DPRPLN=LPLN & EVTDAT>=[F:FISC]DATSTRFIY & EVTDAT<=[F:FISC]DATENDFIY & CPTFLG=G_OUI
    If [F:EVT]SNSEVE=GVML_TEACT
     [F:DEPE]IML      += [F:EVT]IML
     [F:DEPE]IMLRVE   += [F:EVT]IMLRVE
    Else
     [F:DEPE]IML      -= [F:EVT]IML
     [F:DEPE]IMLRVE   -= [F:EVT]IMLRVE
    Endif
   Next

   #> Réévaluation

   If clalev([F:EVT]) : Close Local File [F:EVT] : Endif
   Local File EFASREEVAL [EVT]
   For [F:EVT] Where REF=PREF & DPRPLN=LPLN & EVTDAT>=[F:FISC]DATSTRFIY & EVTDAT<=[F:FISC]DATENDFIY & CPTFLG=G_OUI
    If [F:EVT]SNSEVE=GVML_TEACT
     [F:DEPE]RVAAMT   += [F:EVT]RVAAMT
    Else
     [F:DEPE]RVAAMT   -= [F:EVT]RVAAMT
    Endif
   Next

   ####> Génération de l'événement d'annulation sur l'exercice courant
   EVTINT      = LOBJEVT+num$(LPLN)
   DATE_COMPTA = [F:FISC]DATSTRFIY
   DATE_EFFET  = [F:FISC]DATSTRFIY
   If dim(GCPTEXEANT)<0 : Global Integer GCPTEXEANT : Endif
   GCPTEXEANT = G_OUI
   Call GENER_EVE(GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,EVTINT,DATE_EFFET,DATE_COMPTA,CODERR) From GENEVE
   #Gosub EDIT_PR_CO

   If find(3,[F:FISS]STAPER)
    If find(1,[F:FISS]TYPPST)
     Raz [F:DEPE]
     For [F:DEP] Where CPY=PCPY & AASREF=PREF & DPRPLN=LPLN & FIYENDDAT=[F:FISS]DATENDFIY
      [F:DEPE]PSTDPE    += [F:DEP]PSTDPE
      [F:DEPE]PSTEXC    += [F:DEP]PSTEXC
      [F:DEPE]PSTDER    += [F:DEP]PSTDER
      [F:DEPE]PSTDERRVE += [F:DEP]PSTDERRVE
      [F:DEPE]PSTRVETRF += [F:DEP]PSTRVETRF
      [F:DEPE]PSTRVACRB += [F:DEP]PSTRVACRB
     Next
     ####> Génération de l'événement d'annulation sur l'exercice suivant
     EVTINT      = LOBJEVT+num$(LPLN)
     DATE_COMPTA = [F:FISS]DATSTRFIY
     DATE_EFFET  = [F:FISS]DATSTRFIY
     Call GENER_EVE(GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,EVTINT,DATE_EFFET,DATE_COMPTA,CODERR) From GENEVE
     #Gosub EDIT_SU
    Endif
   Endif
   If dim(GCPTEXEANT)>0 : Kill GCPTEXEANT : Endif
  Next I_PLN
 Next
Return

#----------------------------------------------------------------------------------------
# Evénement(s) d'annulation d'un contrat de location financement
# o Exercice courant et antérieurs :
#----------------------------------------------------------------------------------------
$LEACNL

 If !clalev([F:LEA])  : Local File LEASE [LEA]  : Endif

 If [F:LEA]LEAREF<>PREF
  Read [F:LEA]LEA0=PREF
  If fstat>1
   GOK=0
   RCOD=3
   Return
  Endif
 Endif

 Local Integer LPLN
 Local Char    EVTINT
 Local Date    DATE_EFFET
 Local Date    DATE_COMPTA
 Local Integer CODERR

 LPLNGERE(1)=G_OUI
 If GIAS : LPLNGERE(6)=G_OUI : Endif

 For LPLN=1 To G301MAX-1
  EVTINT      = LOBJEVT+num$(LPLN)
  DATE_COMPTA = date$
  DATE_EFFET  = date$
  If dim(GCPTEXEANT)<0 : Global Integer GCPTEXEANT : Endif
  GCPTEXEANT = G_OUI
  Call GENER_EVE(GVML_OMLOCFI,[F:LEA]CPY,[F:LEA]FCY,[F:LEA]LEAREF,0,EVTINT,DATE_EFFET,DATE_COMPTA,CODERR) From GENEVE
 Next LPLN
Return

#----------------------------------------------------------------------------------------
# Evénement(s) d'annulation d'un contrat d'une subvention
# o Exercice courant et antérieurs :
#----------------------------------------------------------------------------------------
$GRTCNL

 If !clalev([F:GRT])  : Local File GRANTS [GRT]  : Endif

 If [F:GRT]GRAREF<>PREF
  Read [F:GRT]GRT0=PREF
  If fstat>1
   GOK=0
   RCOD=3
   Return
  Endif
 Endif

 Local Integer LPLN
 Local Char    EVTINT
 Local Date    DATE_EFFET
 Local Date    DATE_COMPTA
 Local Integer CODERR

 LPLNGERE(1)=G_OUI
 If GIAS : LPLNGERE(6)=G_OUI : Endif

 For LPLN=1 To G301MAX-1
  EVTINT      = LOBJEVT+num$(LPLN)
  DATE_COMPTA = date$
  DATE_EFFET  = date$
  If dim(GCPTEXEANT)<0 : Global Integer GCPTEXEANT : Endif
  GCPTEXEANT = G_OUI
  Call GENER_EVE(GVML_OMSUBV,[F:GRT]CPY,[F:GRT]FCY,[F:GRT]GRAREF,0,EVTINT,DATE_EFFET,DATE_COMPTA,CODERR) From GENEVE
 Next LPLN

Return

#----------------------------------------------------------------------------------------
# Evénement(s) d'annulation d'un élèment physique
# o Exercice courant et antérieurs :
#----------------------------------------------------------------------------------------
$PHYCNL
Return

#-----------------------
# Pour dev
#-----------------------
$EDIT_PR_CO
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE("Plan"-mess(LPLN,3101,1),0) From GESECRAN
 Call ECR_TRACE(string$(len("Plan"-mess(LPLN,3101,1)),"="),0) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE("Exercices antérieurs",0) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE("DPRCUM        "+num$([F:DEPE]DPRCUM)   ,0) From GESECRAN
 Call ECR_TRACE("EXCCUM        "+num$([F:DEPE]EXCCUM)   ,0) From GESECRAN
 Call ECR_TRACE("LEGCUM        "+num$([F:DEPE]LEGCUM)   ,0) From GESECRAN
 Call ECR_TRACE("LEGRVECUM     "+num$([F:DEPE]LEGRVECUM),0) From GESECRAN
 Call ECR_TRACE("EXEIMLCUM     "+num$([F:DEPE]EXEIMLCUM),0) From GESECRAN
 Call ECR_TRACE("EXERVECUM     "+num$([F:DEPE]EXERVECUM),0) From GESECRAN
 Call ECR_TRACE("EXETRFCUM     "+num$([F:DEPE]EXETRFCUM),0) From GESECRAN
