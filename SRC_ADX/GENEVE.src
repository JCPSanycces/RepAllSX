# DETRICOTE_EVE(POBJ,PCPY,PREF,PLIN,PDAT,PJAUGE,RCOD)
# GET_PRORATA_STATUS(POBJ,PCPY,PEVT,PPLN,R_TABNOMZON, R_TABORDZON, R_TABSTATUS,RCOD)
# SUPP_EVE(POBJ,PCPY,PFCY,PREF,PLIN,PEVT,PEVTINT,PDAT,PCRIT,RNBEVESUP,RCOD)
# SUPP_EVE_OBJ(POBJTYP,PCPY,PFCY,PREF,PLIN,PDAT,RNBEVESUP,RCOD)
