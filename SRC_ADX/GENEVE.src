#====================================================================
Funprog HEURE_TO_STRING(PHEURENUM,PSEP)
Value Integer PHEURENUM
Value Char    PSEP
Local Char RHEURESTR
Local Char PSEP1, PSEP2, PSEP3

 If PSEP="" : PSEP1="h" : Else : PSEP1 = PSEP : Endif
 If PSEP="" : PSEP2="m" : Else : PSEP2 = PSEP : Endif
 If PSEP="" : PSEP3="s" : Else : PSEP3 = ""   : Endif
 RHEURESTR=format$("N0:2",num$(int(PHEURENUM/3600)))+PSEP1+
&         format$("N0:2",num$(int((PHEURENUM-(int(PHEURENUM/3600))*3600)/60)))+PSEP2+
&         format$("N0:2",num$(PHEURENUM-int(PHEURENUM/3600)*3600-int((PHEURENUM-(int(PHEURENUM/3600))*3600)/60)*60))+PSEP3

End RHEURESTR

#====================================================================
# Donne le nom d'un axe pour une société et un type de référentiel donnés
# NUMAXE permet de préciser le numéro de l'axe recherché de 1 à 9
#====================================================================
Funprog GET_DIE_BY_PLN(PCPY,PPLN,PNUMAXE)
Value Char    PCPY
Value Integer PPLN
Value Integer PNUMAXE

Local Integer LCOATYP
Local Char    VAL_DIE(50)

 If    PPLN=G301CPT
  LCOATYP = 2
 Elsif PPLN=G301IAS
  LCOATYP = 3
 Else
  Local Integer RCNX
  Call GET_CNX_FROM_PLAN (PCPY, PPLN, RCNX)  From GLOBIENS
  If RCNX
   If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif
   Read [F:CNX]CNX0=PCPY;RCNX
   If !fstat
    Local Integer I_PLN : I_PLN=find(PPLN,[F:CNX]PLNCAA)
    If I_PLN
     #Fq-80136 : ajout du cas où ORIBASDPR <> PCG et IAS, càd montant "à saisir"
     # sinon axes et sections non-renseignés dans l'événement
     Case [F:CNX]ORIBASDPR(I_PLN-1)
      When 1 : LCOATYP=2
      When 2 : LCOATYP=3
      When Default : LCOATYP=2
     Endcase
    Endif
   Endif
  Endif
 Endif

 VAL_DIE=func GET_DIE_BY_COA_TYP(PCPY,LCOATYP,PNUMAXE)

End VAL_DIE

#====================================================================
# Donne le nom d'un axe pour une société et un type de référentiel donnés
# NUMAXE permet de préciser le numéro de l'axe recherché de 1 à 9
#====================================================================
Funprog GET_DIE_BY_COA_TYP(PCPY,PCOATYP,PNUMAXE)
Value Char    PCPY
Value Integer PCOATYP
Value Integer PNUMAXE

 Local Char    VAL_DIE(50)
 Local Char    LGCM, LCOA
 Local Integer I_LED

 If !clalev([F:GCM]) : Local File GACM [GCM] : Endif
 If !clalev([F:LED]) : Local File GLED [LED] : Endif
 Call SETGCM(PCPY,LGCM) From CPTDIV
 Call LECTURE("GCM",LGCM,"") From CONTOBJ
 Case PCOATYP
  When 2
   I_LED = [F:GCM]ANALEDTYP-1
   If I_LED>=0 : LCOA  = [F:GCM]LED(I_LED) : Endif
  When 3
   I_LED = [F:GCM]IASLEDTYP-1
   If I_LED>=0 : LCOA  = [F:GCM]LED(I_LED) : Endif
 Endcase
 If LCOA<>""
  Call LECTURE("LED",LCOA,"") From CONTOBJ
 VAL_DIE=[F:LED]DIE(PNUMAXE-1)
 Endif
End VAL_DIE

#====================================================================
# Renvoie la section correspondant au code axe passé ene paramétre
#====================================================================
#**
#* On cherche le rang de l'axe PDIE dans le tableau PCLASSE + LDIENAM
#* On renvoie le CCE  du tableau PCLASSE + LCCENAM pour l'indice = rang trouvé moins 1
#*
#* @param PCLASSE
#* @param PDIENAM
#* @param PCCENAM
#* @param PDIE
#*!
Funprog GET_CCE(PCLASSE, PDIENAM, PCCENAM, PDIE)
Value Char    PCLASSE()
Value Char    PDIENAM()
Value Char    PCCENAM()
Value Char    PDIE()

Local Char    LDIENAM(30), LCCENAM(30)
Local Integer I_DIE
Local Char    VAL_CCE(GLONCCE)

  # Issue  X3-64332
  If PDIENAM = ""
    LDIENAM = "DIE"
  Else
    LDIENAM = PDIENAM
  Endif
  If PCCENAM = ""
    LCCENAM = "CCE"
  Else
    LCCENAM = PCCENAM
  Endif

  I_DIE = evalue("find('" + PDIE + "'," + PCLASSE + LDIENAM + ")")
  If I_DIE
    VAL_CCE = evalue(PCLASSE + LCCENAM + "(" + num$(I_DIE - 1) + ")")
  Endif

End VAL_CCE

#====================================================================
# Renvoie la section correspondant au code axe passé en paramétre
#====================================================================
Funprog GET_CCE_DAT(PDATREF,PCLASSE,PDIENAM,PCCENAM,PPLN,PDIE)
Value Date    PDATREF
Value Char    PCLASSE
Value Char    PDIENAM
Value Char    PCCENAM
Value Integer PPLN
Value Char    PDIE
End func GENEVE.GET_CCE_DAT_FCY(PDATREF,PCLASSE,evalue(PCLASSE+"FCY"),PDIENAM,PCCENAM,PPLN,PDIE)

# FQ102598 : ajout en paramètre du site financier qui peut ne pas être le même que celui de la classe PCLASSE
Funprog GET_CCE_DAT_FCY(PDATREF,PCLASSE,PFCY,PDIENAM,PCCENAM,PPLN,PDIE)
Value Date    PDATREF
Value Char    PCLASSE
Value Char    PFCY
Value Char    PDIENAM
Value Char    PCCENAM
Value Integer PPLN
Value Char    PDIE

Local Char    VAL_AXE

# Paramètre invalide, on sort sans alimenter la section
If PCLASSE="" | PDIE="" | PPLN <=0 | PPLN > G301NBPLNFC
 VAL_AXE=""
 End VAL_AXE
Endif
Local Char    LDIENAM,LCCENAM
If PDIENAM="" : LDIENAM="DIE" : Endif
If PCCENAM="" : LCCENAM="CCE" : Endif

Local Integer I_DIE
I_DIE=evalue("find('"+PDIE+"',"+PCLASSE+LDIENAM+")")
If !I_DIE : End VAL_AXE : Endif
# Si pas de date de transfert on prend la section sur le BCO
If PDATREF=[0/0/0]
 VAL_AXE=evalue(PCLASSE+LCCENAM+"("+num$(I_DIE-1)+")")
 End VAL_AXE
Endif
# Si date de transfert antérieure à la date de référence on prend la section sur le BCO
If evalue("PDATREF"+">="+PCLASSE+"TRFDAT")
 VAL_AXE=evalue(PCLASSE+LCCENAM+"("+num$(I_DIE-1)+")")
 End VAL_AXE
Endif

# Ouverture des tables
Local Char    CRITSELEFS(255)   # Critère de sélection des événements
Local Char    W_CCE             # Stockage de la valeur de la section
Local Integer B_NOCCLTRF        # Au moins un événement non annulé trouvé
Local Integer B_DIEFND          # PDIE trouvé dans l'événement

If !clalev([F:TB0])   : Local File EFASAFFAGE [TB0]   : Endif
If !clalev([F:XTB0])  : Local File EFASAFFAGE [XTB0]  : Endif

CRITSELEFS ="REF="+PCLASSE+"AASREF"+"&"  : # FQ102598 mis en premier pour coller avec l'index EVE0
CRITSELEFS+="CPY="+PCLASSE+"CPY"+"&"
CRITSELEFS+="DPRPLN="+num$(PPLN)+"&"
CRITSELEFS+="FCY=PFCY&" : # FQ102598
# Issue 112070  CRITSELEFS+="EVTDAT>="+"["+num$(day(PDATREF))+"/"+num$(month(PDATREF))+"/"+num$(year(PDATREF))+"]"+"&"
CRITSELEFS+="EVTDAT>"+"["+num$(day(PDATREF))+"/"+num$(month(PDATREF))+"/"+num$(year(PDATREF))+"]"+"&"
CRITSELEFS+="EVTPRINC=G_OUI&"
CRITSELEFS+="SNSEVE = GVML_TEACT"

# Issue 112070 - ajout order by pour trier les événements de transfert car l'index ne suffit pas...
# FILTER [TB0] Where evalue(CRITSELEFS)
Filter [TB0] Where evalue(CRITSELEFS) Order By TIMSTP Asc
B_NOCCLTRF = 0

# Issue 112070 For [TB0]EVE0
For [TB0]
 Read [XTB0]EVE1(2)=[F:TB0]REF;[F:TB0]TIMSTP
 # Si l'événement est annulé (fstat<>0) on lit l'événement suivant
 If fstat
  # L'événement n'est pas annulé, on récupére l'imputation
  B_DIEFND = 0

#  For I_DIE = 1 To 9 # issue X3-64332
  For I_DIE = 1 To GOPTCANA
   If evalue("[F:TB0]DIE"+num$(I_DIE)) = PDIE
    B_DIEFND = 1
    Break
   Endif
  Next I_DIE
  If B_DIEFND
   W_CCE=evalue("[F:TB0]CCE"+num$(I_DIE)+"O")
  Else
   W_CCE = ""
  Endif
  B_NOCCLTRF = 1
  Break
 Endif
Next
Filter [TB0]

#> Si on a trouvé au moins un événement non annulé, on prend l'info analytique récupérée sur cet événement,
#  Si on a trouvé aucun événement ou que tous les événements trouvés on été annulé, on prend l'analytique
#  présent sur le bien (=analytique pour la période courante.).

If B_NOCCLTRF
 VAL_AXE=W_CCE
Else
 VAL_AXE=evalue(PCLASSE+LCCENAM+"("+num$(I_DIE-1)+")")
Endif


End VAL_AXE

#====================================================================
# Renvoie la répartition a priori passée en paramétre
#====================================================================
Funprog GET_DSP_DAT(PDATREF,PCLASBCO)
Value Date    PDATREF     # Date à laquelle on doit déterminer la valeur de la section.
Value Char    PCLASBCO    # Classe contenant les infos du bien comptable

Local Char    RDSP        # Section analytique retournée.

# Paramètre invalide, on sort sans alimenter la section
If PCLASBCO="" | PDATREF=[0/0/0]
 RDSP=""
 End RDSP
Endif

# Si pas de date de transfert ou date de transfert antérieure à la date de référence on prend la répartition sur le BCO
If evalue("PDATREF=[0/0/0] | PDATREF"+">="+PCLASBCO+"TRFDAT")
 RDSP=evalue(PCLASBCO+"DSP")
 End RDSP
Endif

# Si date de transfert postérieure à la date de référence
If evalue("PDATREF"+"<"+PCLASBCO+"TRFDAT")

 # Ouverture des tables
 Local Char    CRITSELEFS(255)   # Critère de sélection des événemnts
 Local Char    W_DSP             # Stockage de la valeur de la répartition
 Local Integer I_PLN             # Indice de parcours des plans d'amortissement
 Local Integer L_NOCCLTRF        # Au moins un événement non annulé trouvé

 If !clalev([F:TB0])   : Local File EFASAFFAGE [TB0]   : Endif
 If !clalev([F:XTB0])  : Local File EFASAFFAGE [XTB0]  : Endif

 # Recherche événement de transfert
 Raz RDSP

 For I_PLN=1 To G301MAX-1

  CRITSELEFS ="CPY="+PCLASBCO+"CPY"+"&"
  CRITSELEFS+="DPRPLN="+num$(I_PLN)+"&"
  CRITSELEFS+="FCY="+PCLASBCO+"FCY"+"&"
  CRITSELEFS+="REF="+PCLASBCO+"AASREF"+"&"
  CRITSELEFS+="EVTDAT>="+"["+num$(day(PDATREF))+"/"+num$(month(PDATREF))+"/"+num$(year(PDATREF))+"]"+"&"
  CRITSELEFS+="EVTPRINC=G_OUI&"
  CRITSELEFS+="SNSEVE = GVML_TEACT"

  Filter [TB0] Where evalue(CRITSELEFS)

  L_NOCCLTRF = G_NON

  For [TB0]EVE0
   Read [XTB0]EVE1(2)=[F:TB0]REF;[F:TB0]TIMSTP
   # Si l'événement est annulé (fstat<>0) on lit l'événement suivant
   If fstat
    # L'événement n'est pas annulé, on récupére l'imputation :
    W_DSP=[F:TB0]DSPO
    L_NOCCLTRF = G_OUI
    Break 2
   Endif
  Next EVE0

 Next I_PLN

 Filter [TB0]

 #> Si on a trouvé au moins un événement non annulé, on prend la répartition a priori récupérée sur cet événement,
 #  Si on n'a trouvé aucun événement ou que tous les événements trouvés on été annulé, on prend l'analytique
 #  présent sur le bien (=analytique pour la période courante.).

 If L_NOCCLTRF=G_OUI
  RDSP=W_DSP
 Elsif L_NOCCLTRF=G_NON
  RDSP=evalue(PCLASBCO+"DSP")
 Endif

Endif

End RDSP

