 Call ECR_TRACE("PSTEXC        "+num$([F:DEPE]PSTEXC)   ,0) From GESECRAN
 Call ECR_TRACE("PSTDER        "+num$([F:DEPE]PSTDER)   ,0) From GESECRAN
 Call ECR_TRACE("PSTDERRVE     "+num$([F:DEPE]PSTDERRVE),0) From GESECRAN
 Call ECR_TRACE("PSTRVETRF     "+num$([F:DEPE]PSTRVETRF),0) From GESECRAN
