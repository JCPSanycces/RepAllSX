#################################################################################################
# Sous-programme d'édition des événements de suppression d'objet métier.
#################################################################################################
Subprog LIST_EVT_CNL()

End

#################################################################################################
# Contrôle que, pour le couple Société / Contexte, il ne reste pas
# des événements non comptabilisés. dans ce cas, la clôture est
# interdite.
#################################################################################################
# FQ84664 : ajout de la législation
Subprog CONTROLE_EVENEMENTS(PLEG, PCPY, PCNX, PTYP, PTYPMES, RETOUR)
Value    Char    PLEG     # Législation
Value    Char    PCPY     # Société
Value    Integer PCNX     # Contexte
Value    Integer PTYP     # Type de contrôle  : exercice ou période
Value    Integer PTYPMES  # Type de message   : 0 - Boîte de dialogue / 1 - Information dans la trace (Serveur batch par ex).
Variable Integer RETOUR   # Code retour du sous-programme.

 Local  Char    SOC     : SOC     = PCPY
 Local  Integer CONTEXT : CONTEXT = PCNX
 Local  Integer TYP     : TYP     = PTYP
 Global Char    LISTEVT(10)(1..100)
 Global Integer LISTPLN(1..100)
 Global Integer LISTNBE(1..100)
 Local  Integer I_RET
 Local  Integer RETOUR

 RETOUR = 0

 # FQ84664 : Ajout de la législation
 # FQ88911
 If func CTRL_ALL_EVT_CPT(PLEG, SOC, CONTEXT, TYP, 2, "", LISTEVT, LISTPLN, LISTNBE, RETOUR, [0/0/0], [0/0/0])=G_NON

  #> Liste des erreurs dans une fenêtre.

  If PTYPMES=0
   Call ERREUR(mess(124,7774,1)+" : "-SOC-"/"-mess(CONTEXT,3100,1)) From GESECRAN
   Local Char PARAM(30)(1..2)
   Local Char VALEUR
   PARAM(1)="CTRLEVT"
   Call TRAITE_CHAR(VALEUR,PARAM,"","TRTLISERR","LISERR",4,"") From GTRAITE
  Endif

  #> Liste des erreurs dans une trace.

  If PTYPMES=1
   Local Integer L_OPENTRC
   If GTRACE=""
    Call OUVRE_TRACE(mess(125,7774,1)) From LECFIC
    L_OPENTRC=1
   Endif
   Call ECR_TRACE(mess(124,7774,1)+" : "-SOC-"/"-mess(CONTEXT,3100,1),1) From GESECRAN
   Call ECR_TRACE("",0) From GESECRAN
   Call ECR_TRACE(mess(126,7774,1)+space$(6)+mess(87,7774,1),0) From GESECRAN
   Call ECR_TRACE(string$(len(mess(126,7774,1)),"=")+space$(6)+string$(len(mess(87,7774,1)),"="),0) From GESECRAN
   For I_RET=1 To 100
    If LISTEVT(I_RET)=""
     Break
    Else
     Call ECR_TRACE(left$(LISTEVT(I_RET)+space$(len(mess(126,7774,1))+6),len(mess(126,7774,1))+6)+mess(LISTPLN(I_RET),3101,1),0) From GESECRAN
    Endif
   Next I_RET
   Call ECR_TRACE("",0) From GESECRAN
   If L_OPENTRC=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
   Endif
  Endif

  RETOUR = 1

 Endif

 If dim(LISTEVT) : Kill LISTEVT : Endif
 If dim(LISTPLN) : Kill LISTPLN : Endif
 If dim(LISTNBE) : Kill LISTNBE : Endif

End

#################################################################################################
# Contrôle permettant de déterminer si tous les événements présents
# dans un type d'écriture ont bien été comptabilisés.
#################################################################################################
# FQ84664 : ajout de la législation
# FQ88911 ajout de PTYP = 3 et de 2 dates début et fin
# Le besoin est de savoir si il y a au moins 1 evt de comptabilisé sur 1 période donnée :
# PTYP = 3 et PDATDEB et PDATFIN doivent être renseignées
# PFILLTAB doit être à G_NON dans ce cas (provoque la fin de fonction au 1° enreg comptabilisé trouvé)

Funprog CTRL_ALL_EVT_CPT(PLEG, PCPY, PCNX, PTYP, PFILLTAB, PPNAME, TLSTEVTTYP, TLSTPLN , TLSTNBE, RET, PDATDEB, PDATFIN)
Value    Char    PLEG         # Législation
Value    Char    PCPY         # Société
Value    Integer PCNX         # Contexte
Value    Integer PTYP         # Type de contrôle : (1) Période ou (2) exercice FQ88911 ou (3) utilise les 2 PDATDEB et PDATFIN
Value    Integer PFILLTAB     # Type d'alimentation :
                              #    (1) : Oui ou Non tous les événements sont comptabilisés
                              #    (2) : alimente les tableaux TLSTEVTTYP, TLSTPLN et TLSTNBE
                              #    (3) : appelle l'étiquette CTRL_ALL_EVT_CPT du traitement PPNAME
Value    Char    PPNAME       # Nom du programme à appeler dans la boucle principale
Variable Char    TLSTEVTTYP() # Tableau des types d'événements pour lesquels il reste des événements non comptabilisés
Variable Integer TLSTPLN()    # Tableau des plans pour lesquels il reste des événements non comptabilisés.
Variable Integer TLSTNBE()    # Tableau des compteurs d'événements non comptabilisés
Variable Integer RET          # Retour
Value Date PDATDEB, PDATFIN   # FQ88911 utilisées juste si ptyp = 3

#> Tables

If !clalev([F:CNX]) : Local File CONTEXT  [CNX] : Endif
If !clalev([F:ADI]) : Local File ATABDIV  [ADI] : Endif
If !clalev([F:TPE]) : Local File TYPACE   [TPE] : Endif

#> Constantes

Local Integer CTRL_PER    : CTRL_PER    = 1    # Contrôle sur clôture période
Local Integer CTRL_EXE    : CTRL_EXE    = 2    # Contrôle sur clôture exercice
Local Integer DELAITEMPON : DELAITEMPON = 2    # Delai en seconde de déclenchement de la fenêtre "Vérfication en cours"

#> Variables

Local Integer RALLCPT  : RALLCPT=G_OUI
Local Date    L_CNXDAT(1..5)
Local Integer RETOUR
Local Date    L_DATREFDEB     # Borne de date inférieure pour la sélection des événements
Local Date    L_DATREFFIN     # Borne de date supérieure pour la sélection des événements
Local Integer I_PLN           # Indice de parcours des plans.
Local Integer I_EVTTYP        # Indice de parcours du tableau de retour
Local Integer L_NBEVTFAS      # Nb evts non comptabilisés sur les biens
Local Integer L_NBEVTLOF      # Nb evts non comptabilisés sur les dépenses
Local Integer L_NBEVTLEA      # Nb evts non comptabilisés sur les contrats de location financement
Local Integer L_NBEVTGRT      # Nb evts non comptabilisés sur les subventions
Local Char    CRITSUP(255)    # Critère de sélection constant
Local Char    CRITPLN(255)    # Critère de sélection sur les plans du contexte.
Local Char    CRITEVT(255)    # Critère de sélection sur les événements
Local Integer LTRTTPE

Local Integer LLSTTIME        # Dernière mesure de temps pour déclenchement de la fenêtre d'attente
Local Integer LCURTIME        # Nouvelle mesure de temps pour déclenchement de la fenêtre d'attente
Local Integer LTEMPON         # Indicateur : boîte d'attente ouverte oui / non

# FQ86365
Local Integer LROWCOUNT              # Nombre d'enregistrements
Local Char    TCLE(17)(dim(TLSTPLN)) # Concaténation du type d'événement et du plan pour l'alimentation du tableau des événements

#> Récupération des dates de début et de fin de période de référence pour le contrôle
Call GET_CNX_DAT(PCPY,PCNX,L_CNXDAT,RETOUR) From GLOBIENS

Case PTYP
 When 1
  If L_CNXDAT(3)=[0/0/0]
   RET = 2   # Contrôle période et exercice non périodique # FQ88911 RET et pas RETOUR
  Endif
  L_DATREFDEB = L_CNXDAT(3)
  L_DATREFFIN = L_CNXDAT(4)
 When 2
  L_DATREFDEB = L_CNXDAT(1)
  L_DATREFFIN = L_CNXDAT(2)
 # FQ88911
 When 3
  If PDATDEB = [0/0/0] or PDATFIN = [0/0/0]
   RET = 4
   End 0
  Endif
  L_DATREFDEB = PDATDEB
  L_DATREFFIN = PDATFIN
  PFILLTAB = G_NON
 When Default
  RET = 1    # Paramétre RET inconnu # FQ88911 RET et pas RETOUR
  End 0
Endcase
RET = 0    # FQ88911

#> Constuction du critère de sélection constant

CRITSUP = "ENAFLG=G_OUI & SRCTYP=1"
CRITSUP+= "&(CPY='"+PCPY+"'|CPY='')"
CRITSUP+= "&(LEG='"+PLEG+"'|LEG='')" : # FQ84664

#> Construction du critère de sélection pour les plans en fonction du contexte demandé

Read [F:CNX]CNX0=PCPY;PCNX
If fstat
 RET=3          # Contexte inexistant
 End 0
Endif
L_NBPLN=0

For I_PLN=1 To dim([F:CNX]PLNCAA)
 If [F:CNX]PLNCAA(I_PLN-1)
  If CRITPLN<>"" : CRITPLN+="|" : Endif
  CRITPLN+="[F:TPE]DPRPLN="+num$([F:CNX]PLNCAA(I_PLN-1))
 Endif
Next I_PLN
CRITPLN="("+CRITPLN+")"

#> Initialisation de la temporisation

LLSTTIME = time
LCURTIME = time
#> Boucle sur les types d'événements
For [F:TPE]TPE1 Where evalue(CRITSUP) & evalue(CRITPLN)
 Raz LTRTTPE
 Case [F:TPE]TABOBJ
  When "FXDASSETS" : LTRTTPE=1
  When "LAYOUTFAS" : LTRTTPE=1
  When "LEASE"     : If G_ACTLEA=G_OUI : LTRTTPE=1 : Endif
  When "GRANTS"    : If G_ACTGRT=G_OUI : LTRTTPE=1 : Endif
 Endcase
 If LTRTTPE
  If clalev([F:CPT]) : Close Local File [F:CPT] : Endif
  If clalev([F:OBJ]) : Close Local File [F:OBJ] : Endif
  Local File =[F:TPE]TABCPT [F:CPT]
  Local File =[F:TPE]TABOBJ [F:OBJ]
  Case [F:TPE]TABOBJ
   When "LAYOUTFAS"
     Link [CPT] With [OBJ]LOF0=[F:CPT]REF;[F:CPT]LIN As [RDEC] Order By Key RDEC1 = REF;LIN;TIMSTP
   When "FXDASSETS"
     Link [CPT] With [OBJ]FAS0=[F:CPT]REF As [RDEC] Order By Key RDEC1 = REF;LIN;TIMSTP
   When "GRANTS"
     Link [CPT] With [OBJ]GRT0=[F:CPT]REF As [RDEC] Order By Key RDEC1 = REF;LIN;TIMSTP
   When "LEASE"
     Link [CPT] With [OBJ]LEA0=[F:CPT]REF As [RDEC] Order By Key RDEC1 = REF;LIN;TIMSTP
  Endcase

  Local Char LDIVCRIT(255)
  If [F:TPE]DIVCRIT=""
   LDIVCRIT="1=1"
  Else
   LDIVCRIT=[F:TPE]DIVCRIT
  Endif

  # FK88911 ajout du cas PTYP = 3
  If PTYP = 3
   CRITEVT="[F:CPT]CPTFLG=G_OUI & [F:CPT]CPY=PCPY & [F:CPT]CPTDATINT>=L_DATREFDEB & [F:CPT]CPTDATINT<=L_DATREFFIN"
  Else
   CRITEVT="[F:CPT]CPTFLG=G_NON & [F:CPT]CPY=PCPY & [F:CPT]CPTDATINT>=L_DATREFDEB & [F:CPT]CPTDATINT<=L_DATREFFIN"
  Endif
  If [F:TPE]EVTPLN<>G301AUC
   CRITEVT+="& [F:CPT]DPRPLN=[F:TPE]DPRPLN"
  Endif
  Filter [F:RDEC] Where evalue(CRITEVT) & evalue(LDIVCRIT)
  LROWCOUNT = rowcount([F:RDEC]) : # FQ86365 utilisation de LROWCOUNT pour éviter d'exécuter deux fois rowcount
  If LROWCOUNT>0
   Case PFILLTAB
     When 1 :
      RALLCPT=G_NON
     When 2 :
      If !find([F:TPE]EVTTYP+num$([F:TPE]DPRPLN),TCLE)          : # FQ86365
       TCLE(I_EVTTYP)       = [F:TPE]EVTTYP+num$([F:TPE]DPRPLN) : # FQ86365
       TLSTEVTTYP(I_EVTTYP) = [F:TPE]EVTTYP
       TLSTPLN(I_EVTTYP)    = [F:TPE]DPRPLN
       TLSTNBE(I_EVTTYP)    = LROWCOUNT                         : # FQ86365
       I_EVTTYP+=1
       RALLCPT = G_NON
      Endif
     When 3 :
      Gosub CTRL_ALL_EVT_CPT From =PPNAME
      RALLCPT = G_NON
   Endcase
  Endif
  Filter [F:RDEC]
  If PFILLTAB=1 and RALLCPT=G_NON : Break : Endif               : # FQ86365
 Endif
Next

End RALLCPT

#------------------------------
$GERE_TEMPON_WIN
 If LTEMPON<>G_OUI
  LCURTIME=time
  If abs(LCURTIME-LLSTTIME)>DELAITEMPON
   If !GSERVEUR : Call TEMPON("F") From GESECRAN : LTEMPON=G_OUI : Endif
  Endif
 Endif
Return

#------------------------------
$GERE_TEMPOFF_WIN
 If LTEMPON=G_OUI & !GSERVEUR
  Call TEMPOFF From GESECRAN
 Endif
Return


#################################################################################################
# Sous-programme permettant l'extourne ou la suppression d'un sous-ensemble d'événements parmi
# les événements déjà générés d'un bien comptable.
#
# PEVTDATTYP / PEVTDAT
#   1 - PEVTACCTYP=1 / PACCDAT = [0/0/0] => Date de comptabilisation identique à celle de l'événement origine
#   2 - PEVTACCTYP=2 / PACCDAT = Date de comptabilisation déterminée par l'appelant
#
#################################################################################################
Subprog EXTOURNE_FAS_GRP_EVE(PCPY, PAASREF, PEVEPLN, PDATDEB, PDATFIN, PACCDATTYP, PACCDAT, RET)
Value    Char    PCPY       # Société du bien comptable à traiter (facultatif)
Value    Char    PAASREF    # Référence du bien comtpable à traiter
Value    Integer PEVEPLN    # Liste des plans d'amortissement à traiter
Value    Date    PDATDEB    # Liste des bornes de dates début
Value    Date    PDATFIN    # Liste des bornes de dates fin
Value    Integer PACCDATTYP # Type de date comptable
Value    Date    PACCDAT    # Règle de détermination de la date d'effet de l'événement à annuler
Variable Integer RET

#> Tables
If !clalev([F:REVT]) : Local File EVEFAS [REVT] : Endif
If !clalev([F:AEVT]) : Local File EVEFAS [AEVT] : Endif
If !clalev([F:WEVT]) : Local File EVEFAS [WEVT] : Endif

#> Constantes

Local Integer LDEBUG : If GUSER="MDR" & 1=0 : LDEBUG=1 : Endif

#> Variables

Local Char    L_CRIT1(255)
Local Integer GOK : GOK=1

#> Création du critère de sélection des événements

L_CRIT1="CPY='"+PCPY+"' & REF='"+PAASREF+"' & SNSEVE=1"
If PEVEPLN<G301AUC  : L_CRIT1+="& PLN="+num$(PEVEPLN) : Endif
If PDATDEB<>[0/0/0] : L_CRIT1+="& EVTDAT>=PDATDEB"    : Endif
If PDATFIN<>[0/0/0] : L_CRIT1+="& EVTDAT<=PDATFIN"    : Endif

#> Sélection des événements

If !adxlog : Trbegin [WEVT] : Local Integer SPTRANS : Endif

Filter [REVT] Where evalue (L_CRIT1)
If LDEBUG : Gosub LIST_EVT : Endif
Gosub TRT_EVT
Filter [REVT]

If dim(SPTRANS)>0
 If GOK
  Commit
 Else
  Rollback
 Endif
Endif

If !GOK
 RET=1
Endif

End

#Pour dév : A supprimer
$LIST_EVT
  Local Char     LIGNE(110)
  Local Integer  ANNULE
  Call OUVRE_TRACE("Liste des événements à extourner") From LECFIC
  LIGNE="PLN"+space$(20-len("PLN"))+
&       "EVT"+space$(20-len("EVT"))+
&       "EVTDAT"+space$(20-len("EVTDAT"))+
&       "Annulé"
  Call ECR_TRACE(LIGNE,0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
  For [REVT]
   Read [AEVT]EFS1=[F:REVT]CPY;[F:REVT]EVT;[F:REVT]PLN;[F:REVT]REF;[F:REVT]TIMSTP;[F:REVT]CREUSR
   If fstat=5
    ANNULE=G_NON
   Else
    ANNULE=G_OUI
   Endif
   LIGNE=mess([F:REVT]PLN,3101,1)+space$(20-len(mess([F:REVT]PLN,3101,1)))+
&        [F:REVT]EVT+space$(20-len([F:REVT]EVT))+
&        format$("D:" + GFMDAT4, [F:REVT]EVTDAT) + space$(10) +
&        mess(ANNULE,1,1)
   Call ECR_TRACE(LIGNE,0) From GESECRAN
  Next
  Call LEC_TRACE() From LECFIC
Return

$TRT_EVT
 For [REVT]
    GOK=1

    Filter [AEVT] Where CPY=[F:REVT]CPY & FCY=[F:REVT]FCY & EVT=[F:REVT]EVT & PLN=[F:REVT]PLN & REF=[F:REVT]REF & CREUSRO=[F:REVT]CREUSR & TIMSTPO=[F:REVT]TIMSTP
    Read [F:AEVT] First

    If fstat>2
       [F:WEVT]=[F:REVT]
       Case PACCDATTYP
        When 1 : [F:WEVT]CPTDATINT=[F:WEVT]EVTDAT
        When 2 : [F:WEVT]CPTDATINT=PACCDAT
       Endcase
       [F:WEVT]SNSEVE     = GVML_TEAACT
       [F:WEVT]CREUSR     = GUSER
       [F:WEVT]CREDAT     = date$
       [F:WEVT]CRETIM     = time
       [F:WEVT]TIMSTP     = func GENEVE.BUILD_TIMSTP([F:WEVT]CREDAT, [F:WEVT]CRETIM)
       [F:WEVT]CPTFLG     = G_NON
       [F:WEVT]CREUSRO    = [F:REVT]CREUSR
       [F:WEVT]TIMSTPO    = [F:REVT]TIMSTP
       [F:WEVT]CPTDATINTO = [F:REVT]CPTDATINT
       Write [F:WEVT]
       #FQ 64122 If fstat
       #> Si tentative d'écriture en double on attend que time soit différent
       #FQ 64122Local Integer NBMAXTRY : NBMAXTRY=2
       #FQ 64122 If fstat=3
       #FQ 64122  For NBTRY=1 To NBMAXTRY
       #FQ 64122     Call TEMPO_EVT() From GENEVE
       #FQ 64122     [F:WEVT]CRETIM = time
       #FQ 64122     [F:WEVT]TIMSTP = func GENEVE.BUILD_TIMSTP([F:WEVT]CREDAT, [F:WEVT]CRETIM)
       #FQ 64122     Write [WEVT]
       #FQ 64122     If !fstat
       #FQ 64122        Break
       #FQ 64122     Endif
       #FQ 64122  Next NBTRY
       #FQ 64122 Endif
       #> Si la nouvelle tentative après tempo a de nouveau échouée, erreur
         If fstat
            Local Char LCLE(110)
            LCLE=[F:WEVT]CPY+";"+[F:WEVT]EVT+";"+num$([F:WEVT]PLN)+";"+[F:WEVT]FCY+";"+[F:WEVT]REF+";"+[F:WEVT]TIMSTP+";"+[F:WEVT]CREUSR
            Call ECR_TRACE("GENEVE[EXTOURNE_FAS_GRP_EVE] Err /fstat="-num$(fstat)-"=> EFS0"+LCLE,0) From GESECRAN
            GOK=0
            Break
         Endif
       #FQ 64122 Endif
    Endif
    Filter [F:AEVT]
 Next
Return

#################################################################################################
# Construction du timstamp :
#   - Date YYYYMMDD (8 car)
#   - N° de séquence en base 26 (12 car) contenant
#          o Heure sur 5 chiffre
#          o adxuid(1) sur 10 car
#          o N° de séquence obtenu par incrément de la globale NUMEVT (4 car)
#################################################################################################
Funprog BUILD_TIMSTP(PDATE, PTIME)
Value Date    PDATE
Value Integer PTIME

 Local Char    RTIMSTP(30)
 Local Decimal DECTIMSTP
 Local Char    L36DAT
 Local Char    L36SUITE


 Local Char    RBAS36TIMSTP(20)

 If GNUMEVT=99999 : GNUMEVT=0 : Endif
 GNUMEVT+=1

 Local Integer L_BASE       : L_BASE   = 36
 Local Char    L_YEAR(4)    : L_YEAR   = num$(year(PDATE))
 Local Char    L_MONTH(2)   : L_MONTH  = format$("N0:2",(month(PDATE)))
 Local Char    L_DAY(2)     : L_DAY    = format$("N0:2",(day(PDATE)))
 Local Char    L_TIME(5)    : L_TIME   = format$("N0:5",PTIME)
 Local Char    L_ADXUID(10) : L_ADXUID = format$("N0:10",adxuid(1))
 Local Char    L_SEQ(5)     : L_SEQ   = format$("N0:5",GNUMEVT)

 L36DAT   = func GENEVE.DEC_TO_BASE_N(val(L_YEAR+L_MONTH+L_DAY+L_TIME),L_BASE)
 L36SUITE = func GENEVE.DEC_TO_BASE_N(val(L_ADXUID+L_SEQ),L_BASE)

 RBAS36TIMSTP = L36DAT+"-"+L36SUITE

End RBAS36TIMSTP

#################################################################################################
# Construction du timstamp : ANCIENNE VERSION
#   - Date
#   - Heure
#   - N° de séquence 1 à 9999
#################################################################################################
Funprog BUILD_TIMSTP_OLD(PDATE, PTIME)
Value Date    PDATE
Value Integer PTIME

 Local Char RTIMSTP(20)
 Local Char L_YEAR(4)
 Local Char L_MONTH(2)
 Local Char L_DAY(2)
 Local Char L_TIME(5)
 Local Char L_SEQ(4)

 L_YEAR  = num$(year(PDATE))
 L_MONTH = format$("N0:2",(month(PDATE)))
 L_DAY   = format$("N0:2",(day(PDATE)))
 L_TIME  = format$("N0:5",PTIME)
 If !clalev([F:ACM]) : Local File ACODNUM [ACM] : Endif
 If !adxlog : Trbegin [ACM] : Local Integer LTRS : Endif
 If [C]NUMEVT=9999
  [C]NUMEVT =0
 Else
  [C]NUMEVT+=1
 Endif
 If dim(LTRS)>0 : Commit : Endif
 L_SEQ   = format$("N0:4",[C]NUMEVT)
 RTIMSTP=L_YEAR+L_MONTH+L_DAY+L_TIME+L_SEQ

End RTIMSTP

#################################################################################################
# Conversion d'un nombre entier en base n
#################################################################################################
Funprog DEC_TO_BASE_N(PNBDEC,PBASE)
Value Decimal PNBDEC
Value Integer PBASE

Local Integer LEXPBASEN : LEXPBASEN = 26
Local Char    RNBBASEN, LBUFFBASEN
Local Integer LQUOTIENT, FINI, I
LEXPBASEN=26
Repeat
 If PNBDEC >= PBASE^LEXPBASEN
  Local Integer LDEB
  LQUOTIENT = int(PNBDEC / PBASE^LEXPBASEN)
  If LQUOTIENT<10
   RNBBASEN+=num$(LQUOTIENT)
  Else
   RNBBASEN+=chr$(65+LQUOTIENT-10)
  Endif
  PNBDEC -= LQUOTIENT*PBASE^LEXPBASEN
  LEXPBASEN-=1
 Else
  If dim(LDEB)>0 : RNBBASEN+="0" : Endif
  LEXPBASEN-=1
 Endif
 I+=1
 If LEXPBASEN<0 : FINI=1 : Endif
 If I=500       : FINI=1 : Endif
Until FINI

End RNBBASEN

#################################################################################################
# Conversion d'un nombre entier en base n
#################################################################################################
Funprog BASE_N_TO_DEC(PNBBASEN,PBASE)
Value Char PNBBASEN
Value Integer PBASE

Local Decimal RNBBASEN
Local Integer I_EXPBASEN
Local Integer LEXPBASEN : LEXPBASEN=len(PNBBASEN)
Local Char    LTAB(1)(1..LEXPBASEN)
Local Integer LNBR

For I_EXPBASEN=1 To LEXPBASEN
 LTAB(I_EXPBASEN)=mid$(PNBBASEN,I_EXPBASEN,1)
Next I_EXPBASEN

For I_EXPBASEN=1 To LEXPBASEN
 If ascii(LTAB(I_EXPBASEN))>=65
  LNBR=ascii(LTAB(I_EXPBASEN))-65+10
 Else
  LNBR=val(LTAB(I_EXPBASEN))
 Endif
 RNBBASEN += LNBR*PBASE^(LEXPBASEN-I_EXPBASEN)
Next I_EXPBASEN

End RNBBASEN


#################################################################################################
# Lecture fichier Log de génération des événements pour une session
#################################################################################################
Subprog LEC_LOG_FILE(PADXUID)
Value Integer PADXUID

 Local Date    LDAT
 Local Integer LTIM
 Local Char    LUSR
 Local Char    LOBJ
 Local Char    LCPY
 Local Char    LFCY
 Local Char    LREF
 Local Char    LLIN
 Local Char    LEVTINT
 Local Date    LEVTDAT
 Local Date    LACCDAT
 Local Char    SADXIFS

 If filinfo(filpath("tmp","gvtrc"+num$(PADXUID),"log"),7)<0
  Infbox "No log file for this session"
  End
 Endif

 If GTRACE=""
  Call OUVRE_TRACE("Created events for this session") From LECFIC
  Local Integer LTRC
 Endif
 SADXIFS=adxifs : adxifs=";"
 Gosub ET_TRACE
 Openi filpath("tmp","gvtrc"+num$(PADXUID),"log") Using [XTRC]
 Repeat
  Rdseq LDAT, LTIM, LUSR, LOBJ, LCPY,LFCY, LREF, LLIN, LEVTINT, LEVTDAT, LACCDAT Using [XTRC]
  If LDAT<>[0/0/0] : Gosub LIGNE_TRACE : Endif
 Until fstat
 Openi Using [XTRC]
 adxifs=SADXIFS
 If dim(LTRC)>0
  Call LEC_TRACE() From LECFIC
 Endif

End

