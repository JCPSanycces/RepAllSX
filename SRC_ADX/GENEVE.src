 #Call LEC_LOG_FILE(8175618) From GENEVE
 #Call LEC_LOG_FILE(adxuid(1)) From GENEVE
 #Local Integer RETOUR
 #Call CONTROLE_EVENEMENTS("FRA","GBA", 1, 1, 0, RETOUR) From GENEVE
