Onevent BEFORE_INPUT Call AS_HDCTYP(zc) From W1POT3
Return

Subprog D_HDCTYP(VALEUR)
Variable Char    VALEUR()
If varinit([M]HDCTYP,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"11670","HDCTYP") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_HDCTYP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"11670") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_HDCTYP(zc) From W1POT3
Onkey   2 Titled GBOUTS Call S_HDCTYP(zc) From W1POT3
Onkey 144 Titled GBOUTP Call P_HDCTYP(zc) From W1POT3
Onkey 146 Titled GBOUTA Call SA_HDCTYP(zc) From W1POT3
If VALEUR="" : Call INIADI(VALEUR,"11670") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_HDCTYP(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "HDCTYP" : GZNUM = 55069 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"11670","HDCTYP") From SUBADI
 If mkstat : GERR = 1 : GZONE = "HDCTYP" : GZNUM = 55069 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"11670",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "HDCTYP" : GZNUM = 55069 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_HDCTYP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "11670"
 PARMSK(2) = "HDCTYP"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_HDCTYP(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"11670") From GOBJET
Gosub _AFF
End

Subprog SA_HDCTYP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "11670"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_HDCTYP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "11670"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

