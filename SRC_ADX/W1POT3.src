End

Subprog C_POT2(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_POT2(VALEUR) From SUBPOT
If mkstat : GERR = 1 : GZONE = "POT2" : GZNUM = 46937 : Endif
Gosub _AFF
End

Subprog S_POT2(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPOT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOT"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_POT2" : PROGSUB = "SUBPOT" : PROGSPE = "SPEPOT3" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOT","SUBPOT","") From GACTION
 ACTION = "BS_POT2" : PROGSUB = "SUBPOT" : PROGSPE = "SPEPOT3" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_FLGSAL
Onevent BEFORE_INPUT Call AS_FLGSAL(zc) From W1POT3
Onevent INIT_AREA Call D_FLGSAL(zc) From W1POT3
Return

Subprog D_FLGSAL(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGSAL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FLGSAL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_FLGSAL(VALEUR) From SUBPOT
If mkstat=2
 [M]FLGSAL(INDIC) = VALEUR
 Affzo FLGSAL(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

