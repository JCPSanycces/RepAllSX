Call CONTSITE(VALEUR) From SUBAGF
If mkstat : GERR = 1 : GZONE = "FCYPOT" : GZNUM = 1344 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("FCY","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "FCYPOT" : GZNUM = 1344 : Endif
 If !mkstat
  ## Action CONTFCYCPY
  Call CONTFCYCPY(VALEUR,[M]CPYPOT) From EXEFNC
  If mkstat : GERR = 1 : GZONE = "FCYPOT" : GZNUM = 1344 : Endif
 Endif
Endif
Gosub _AFF
End

