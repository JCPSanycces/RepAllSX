If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("CPY","!A",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CPYPOT" : GZNUM = 1343 : Endif
Endif
Gosub _AFF
End

