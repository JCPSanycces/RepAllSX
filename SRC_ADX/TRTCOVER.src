##########################################################################################################
# Test commun de couverture pour le niveau famille commerciale de produit
$CHKCIACOMCOV
  Gosub CHECKINF
  If ICONTOK Then
    Gosub CHKPARTIAL
    If IFULLCOVER Then
      If [M:SRE7]COVFLG(ITER) <> 2 Then
        [M:SRE7]COVFLG(ITER) = 1
      Endif
    Else
      [M:SRE7]COVFLG(ITER) = 2
    Endif
    If ICCVMODE Then
      [M:SRE7]COVSPT(ITER) = 5
    Else
      [M:SRE7]COVSPT(ITER) = 1
    Endif
    [M:SRE7]COVVCR(ITER) = SZCOVVCR
    [M:SRE7]MACCOVCLA(ITER) = ""
    [M:SRE7]MACCOVREN(ITER) = 0
  Endif
Return

##########################################################################################################
# Test commun de couverture pour les niveaux article et parc
$CHECKCOMCOV
  Gosub CHECKINF
  If ICONTOK Then
    Gosub CHKPARTIAL
    If IFULLCOVER Then
      If [M:SRE7]COVFLG(ITER) = 2 Then
        #On détermine si le caractère partiel de la couverture provient d'une couverture supérieure.
        #ou bien de la couverture courante
        Case SZLNKCASE
          When "000MACMAC"
            If ICCVMODE Then
              Filter [CCVA] Where [F:CCVA]TPL = 2
&                             and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                             and [F:CCVA]RECTYP = "AAA"
&                             and [F:CCVA]PAEKEY(0) = ""
&                             and [F:CCVA]PAEKEY(1) = [F:CCV]RECNUM
&                             and [F:CCVA]PAEKEY(2) = ""
&                             and [F:CCVA]PAEKEYTYP(1) = "MAC"
            Else
              Filter [CCVA] Where [F:CCVA]TPL <> 2
&                             and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                             and [F:CCVA]RECTYP = "AAA"
&                             and [F:CCVA]PAEKEY(0) = ""
&                             and [F:CCVA]PAEKEY(1) = [F:CCV]RECNUM
&                             and [F:CCVA]PAEKEY(2) = ""
&                             and [F:CCVA]PAEKEYTYP(1) = "MAC"
            Endif
          When "000MACITM"
            If ICCVMODE Then
              Filter [CCVA] Where [F:CCVA]TPL = 2
&                             and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                             and [F:CCVA]RECTYP = "AAA"
&                             and [F:CCVA]PAEKEY(0) = ""
&                             and [F:CCVA]PAEKEY(1) = [F:CCV]RECNUM
&                             and [F:CCVA]PAEKEY(2) = ""
&                             and [F:CCVA]PAEKEYTYP(1) = "ITM"
            Else
              Filter [CCVA] Where [F:CCVA]TPL <> 2
&                             and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                             and [F:CCVA]RECTYP = "AAA"
&                             and [F:CCVA]PAEKEY(0) = ""
&                             and [F:CCVA]PAEKEY(1) = [F:CCV]RECNUM
&                             and [F:CCVA]PAEKEY(2) = ""
&                             and [F:CCVA]PAEKEYTYP(1) = "ITM"
            Endif
          When "100MACMAC"
            If ICCVMODE Then
              Filter [CCVA] Where [F:CCVA]TPL = 2
&                             and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                             and [F:CCVA]RECTYP = "AAA"
&                             and [F:CCVA]PAEKEY(0) = [M:SRE7]PBL(ITER)
&                             and [F:CCVA]PAEKEY(1) = [F:CCV]RECNUM
&                             and [F:CCVA]PAEKEY(2) = ""
&                             and [F:CCVA]PAEKEYTYP(1) = "MAC"
            Else
              Filter [CCVA] Where [F:CCVA]TPL <> 2
&                             and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                             and [F:CCVA]RECTYP = "AAA"
&                             and [F:CCVA]PAEKEY(0) = [M:SRE7]PBL(ITER)
&                             and [F:CCVA]PAEKEY(1) = [F:CCV]RECNUM
&                             and [F:CCVA]PAEKEY(2) = ""
&                             and [F:CCVA]PAEKEYTYP(1) = "MAC"
            Endif
          When "100MACITM"
            If ICCVMODE Then
              Filter [CCVA] Where [F:CCVA]TPL = 2
&                             and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                             and [F:CCVA]RECTYP = "AAA"
&                             and [F:CCVA]PAEKEY(0) = [M:SRE7]PBL(ITER)
&                             and [F:CCVA]PAEKEY(1) = [F:CCV]RECNUM
&                             and [F:CCVA]PAEKEY(2) = ""
&                             and [F:CCVA]PAEKEYTYP(1) = "ITM"
            Else
              Filter [CCVA] Where [F:CCVA]TPL <> 2
&                             and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                             and [F:CCVA]RECTYP = "AAA"
&                             and [F:CCVA]PAEKEY(0) = [M:SRE7]PBL(ITER)
&                             and [F:CCVA]PAEKEY(1) = [F:CCV]RECNUM
&                             and [F:CCVA]PAEKEY(2) = ""
&                             and [F:CCVA]PAEKEYTYP(1) = "ITM"
            Endif
        Endcase
        IAAALISTED = 0
        For [CCVA]
          IAAALISTED = 1
          Break
        Next
        Filter [CCVA]
        If !IAAALISTED Then
          [M:SRE7]COVFLG(ITER) = 1
        Endif
      Else
        [M:SRE7]COVFLG(ITER) = 1
      Endif
    Else
      [M:SRE7]COVFLG(ITER) = 2
    Endif
    If ICCVMODE Then
      [M:SRE7]COVSPT(ITER) = 5
    Else
      [M:SRE7]COVSPT(ITER) = 1
    Endif
    [M:SRE7]COVVCR(ITER) = SZCOVVCR
    [M:SRE7]MACCOVCLA(ITER) = ""
    [M:SRE7]MACCOVREN(ITER) = 0
  Endif
Return

##########################################################################################################
# Contrôle des couvertures composants
###########################################################
Subprog CHECKCPN(SZCONCODNUM, SZBPCCOD, INOL, IPREMACNOL, SZCLASS, IERR)
Value Char SZCONCODNUM
Value Char SZBPCCOD
Value Integer INOL
Value Integer IPREMACNOL
Value Char SZCLASS
Variable Integer IERR

Local Char SZLNKCASE
Local Integer ICPNLISTED
Local Integer ITER
Local Integer IFULLCOVER
Local Integer ICONTOK
Local Char SZLITCOD
Local Char SZCOVVCR
Local Integer ICCVMODE
Local Char SZLNDTPLCON
Local Integer IWORTHSTEPONE
Local Date DMACITNDAT
Local Date DLNDENDDAT

  IERR = 0
  ITER = 0
  SZLNKCASE = ""
  ICONTOK = 0
  ICPNLISTED = 0
  ICCVMODE = 0
  SZLNDTPLCON = ""
  IWORTHSTEPONE = 1
  #On essaye de gagner du temps dans le cas d'un contrôle de couverture pour une ligne unique de parc.
  If [M:SRE7]LND(IPREMACNOL) = 2 Then
    IWORTHSTEPONE = 0
  Endif
  #On part d'un état le plus défavorable possible.
  #Au fur et à mesure on améliore la couverture avec ce que l'on trouve.
  If IWORTHSTEPONE  Then
    Link [CCV] With [CON]CON0 = [F:CCV]CONNUM As [LNK] Order By Key KBID = [F:CCV]CPNSRT Asc
    #Contrôle du partiellement couvert
    If SZCONCODNUM = "" Then
      Filter [LNK] Where [F:CCV]TPL <> 2 and [F:CCV]BPC = SZBPCCOD and [F:CCV]CPNSRT <> "" and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONCAT <> 4
    Else
      Filter [LNK] Where [F:CCV]TPL <> 2 and [F:CCV]BPC = SZBPCCOD and [F:CCV]CONNUM = SZCONCODNUM and [F:CCV]CPNSRT <> "" and [F:CON]CONCAT <> 4
    Endif
    For [LNK] KBID
      #Détermine le type de l'enregistrement
      Gosub GETCOVCASE
      Case SZLNKCASE
        When "000PBL"
          #Couverture supérieure d'une compétence
          Gosub CPBL000
        When "100AAA"
          #Couverture supérieure partielle d'une compétence
          Gosub CAAA100
        When "000MACMAC"
          #Couverture supérieure d'un composant indépendant
          Gosub CMACMAC000
        When "000MACITM"
          #Couverture supérieure d'un composant indépendant
          Gosub CMACITM000
        When "000MACCIA"
          #Couverture supérieure d'un composant indépendant
          Gosub CMACCIA000
        When "100MACMAC"
          #Couverture supérieure d'un composant dépendant d'une famille de compétence
          Gosub CMACMAC100
        When "100MACITM"
          #Couverture supérieure d'un composant dépendant d'une famille de compétence
          Gosub CMACITM100
        When "100MACCIA"
          #Couverture supérieure d'un composant dépendant d'une famille de compétence
          Gosub CMACCIA100
        When "010MACCPN"
          #Couverture maitre d'un composant indépendant
          Gosub CMACCPN010
        When "010ITMCPN"
          #Couverture maitre d'un composant indépendant
          Gosub CITMCPN010
        When "010CIACPN"
          #Couverture maitre d'un composant indépendant
          Gosub CCIACPN010
        When "110MACCPN"
          #Couverture maitre d'un composant dépendant d'une famille de compétence
          Gosub CMACCPN110
        When "110ITMCPN"
          #Couverture maitre d'un composant dépendant d'une famille de compétence
          Gosub CITMCPN110
        When "110CIACPN"
          #Couverture maitre d'un composant dépendant d'une famille de compétence
          Gosub CCIACPN110
        When "011MACAAA"
          #Couverture partielle d'un composant indépendant
          Gosub CMACAAA011
        When "011ITMAAA"
          #Couverture partielle d'un composant indépendant
          Gosub CITMAAA011
        When "011CIAAAA"
          #Couverture partielle d'un composant indépendant
          Gosub CCIAAAA011
        When "111MACAAA"
          #Couverture partielle d'un composant dépendant d'une famille de compétence
          Gosub CMACAAA111
        When "111ITMAAA"
          #Couverture partielle d'un composant dépendant d'une famille de compétence
          Gosub CITMAAA111
        When "111CIAAAA"
          #Couverture partielle d'un composant dépendant d'une famille de compétence
          Gosub CCIAAAA111
      Endcase
      If IERR Then
        Break
      Endif
    Next
    Filter [LNK]
  Endif
  #Deuxième partie : On traite uniquement le parc en prêt
  #On essaye de gagner du temps dans le cas d'un contrôle de couverture pour une ligne unique de parc.
  If SZCONCODNUM <> "" Then
    End
  Endif
  If [M:SRE7]LND(IPREMACNOL) <> 2 Then
    End
  Endif
  Read [MAC]MAC0=[M:SRE7]MAC(IPREMACNOL)
  If fstat Then
    End
  Else
    If [F:MAC]MACPDTCOD = "" Then
      End
    Else
      Read [ITM]ITM0=[F:MAC]MACPDTCOD
      If fstat Then
        End
      Else
        If [F:ITM]TPLCONLND = "" Then
          End
        Else
          SZLNDTPLCON = [F:ITM]TPLCONLND
        Endif
      Endif
    Endif
  Endif
  ICCVMODE += 1
  Link [CCV] With [COT]COT0 = [F:CCV]CONNUM As [LNK] Order By Key KBID = [F:CCV]CPNSRT Asc
  #Contrôle du partiellement couvert
  Filter [LNK] Where [F:CCV]TPL = 2 and [F:CCV]CPNSRT <> "" and [F:CCV]CONNUM = SZLNDTPLCON
  For [LNK] KBID
    #Détermine le type de l'enregistrement
    Gosub GETCOVCASE
    Case SZLNKCASE
      When "000PBL"
        #Couverture supérieure d'une compétence
        Gosub CPBL000
      When "100AAA"
        #Couverture supérieure partielle d'une compétence
        Gosub CAAA100
      When "000MACMAC"
        #Couverture supérieure d'un composant indépendant
        Gosub CMACMAC000
      When "000MACITM"
        #Couverture supérieure d'un composant indépendant
        Gosub CMACITM000
      When "000MACCIA"
        #Couverture supérieure d'un composant indépendant
        Gosub CMACCIA000
      When "100MACMAC"
        #Couverture supérieure d'un composant dépendant d'une famille de compétence
        Gosub CMACMAC100
      When "100MACITM"
        #Couverture supérieure d'un composant dépendant d'une famille de compétence
        Gosub CMACITM100
      When "100MACCIA"
        #Couverture supérieure d'un composant dépendant d'une famille de compétence
        Gosub CMACCIA100
      When "010MACCPN"
        #Couverture maitre d'un composant indépendant
        Gosub CMACCPN010
      When "010ITMCPN"
        #Couverture maitre d'un composant indépendant
        Gosub CITMCPN010
      When "010CIACPN"
        #Couverture maitre d'un composant indépendant
        Gosub CCIACPN010
      When "110MACCPN"
        #Couverture maitre d'un composant dépendant d'une famille de compétence
        Gosub CMACCPN110
      When "110ITMCPN"
        #Couverture maitre d'un composant dépendant d'une famille de compétence
        Gosub CITMCPN110
      When "110CIACPN"
        #Couverture maitre d'un composant dépendant d'une famille de compétence
        Gosub CCIACPN110
      When "011MACAAA"
        #Couverture partielle d'un composant indépendant
        Gosub CMACAAA011
      When "011ITMAAA"
        #Couverture partielle d'un composant indépendant
        Gosub CITMAAA011
      When "011CIAAAA"
        #Couverture partielle d'un composant indépendant
        Gosub CCIAAAA011
      When "111MACAAA"
        #Couverture partielle d'un composant dépendant d'une famille de compétence
        Gosub CMACAAA111
      When "111ITMAAA"
        #Couverture partielle d'un composant dépendant d'une famille de compétence
        Gosub CITMAAA111
      When "111CIAAAA"
        #Couverture partielle d'un composant dépendant d'une famille de compétence
        Gosub CCIAAAA111
    Endcase
    If IERR Then
      Break
    Endif
  Next
  Filter [LNK]
End

##########################################################################################################
#Couverture supérieure d'une compétence
$CPBL000
  If SZCLASS = "M" Then
    If ICCVMODE Then
      If [F:COT]EVRMAC = 2 Then
        Gosub MCPBL000
      Endif
    Else
      If [F:CON]EVRMAC = 2 Then
        Gosub MCPBL000
      Endif
    Endif
  Elsif SZCLASS = "F" Then
    If ICCVMODE Then
      If [F:COT]EVRMAC = 2 Then
        Gosub FCPBL000
      Endif
    Else
      If [F:CON]EVRMAC = 2 Then
        Gosub FCPBL000
      Endif
    Endif
  Endif
Return

##########################################################################################################
$MCPBL000
  If [M:SRE7]PBL(IPREMACNOL) <> "" Then
    If [M:SRE7]PBL(IPREMACNOL) = [F:LNK]RECNUM Then
      If [M:SRE7]CPNCOVFLG(INOL) <> 2 Then
        Gosub CHKPARTIAL
        If IFULLCOVER Then
          Gosub CHECKINF
          If ICONTOK Then
            [M:SRE7]CPNCOVFLG(INOL) = 1
            If ICCVMODE Then
              [M:SRE7]CPNCOVSPT(INOL) = 5
            Else
              [M:SRE7]CPNCOVSPT(INOL) = 1
            Endif
            [M:SRE7]CPNCOVVCR(INOL) = SZCOVVCR
            [M:SRE7]CPNCOVCLA(INOL) = ""
            [M:SRE7]CPNCOVREN(INOL) = 0
          Endif
        Else
          Gosub CHECKINF
          If ICONTOK Then
            [M:SRE7]CPNCOVFLG(INOL) = 2
            If ICCVMODE Then
              [M:SRE7]CPNCOVSPT(INOL) = 5
            Else
              [M:SRE7]CPNCOVSPT(INOL) = 1
            Endif
            [M:SRE7]CPNCOVVCR(INOL) = SZCOVVCR
            [M:SRE7]CPNCOVCLA(INOL) = ""
            [M:SRE7]CPNCOVREN(INOL) = 0
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$FCPBL000
  If [M:SRE7]PBL(IPREMACNOL) <> "" Then
    If [M:SRE7]PBL(IPREMACNOL) = [F:LNK]RECNUM Then
      If [F:SRN]CPNCOVFLG <> 2 Then
        Gosub CHKPARTIAL
        If IFULLCOVER Then
          Gosub CHECKINF
          If ICONTOK Then
            Trbegin [SRN]
            [F:SRN]CPNCOVFLG = 1
            If ICCVMODE Then
              [F:SRN]CPNCOVSPT = 5
            Else
              [F:SRN]CPNCOVSPT = 1
            Endif
            [F:SRN]CPNCOVVCR = SZCOVVCR
            [F:SRN]CPNCOVREN = 0
            Rewrite [SRN]
            If fstat Then
              #Erreur lors de la réinitialisation complète de la couverture des composants concernés.
              IERR = 514
              Rollback
            Else
              Commit
            Endif
          Endif
        Else
          Gosub CHECKINF
          If ICONTOK Then
            Trbegin [SRN]
            [F:SRN]CPNCOVFLG = 2
            If ICCVMODE Then
              [F:SRN]CPNCOVSPT = 5
            Else
              [F:SRN]CPNCOVSPT = 1
            Endif
            [F:SRN]CPNCOVVCR = SZCOVVCR
            [F:SRN]CPNCOVREN = 0
            Rewrite [SRN]
            If fstat Then
              #Erreur lors de la réinitialisation complète de la couverture des composants concernés.
              IERR = 514
              Rollback
            Else
              Commit
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
#Couverture supérieure partielle d'une compétence
$CAAA100
  If SZCLASS = "M" Then
    If ICCVMODE Then
      If [F:COT]EVRMAC = 2 Then
        Gosub MCAAA100
      Endif
    Else
      If [F:CON]EVRMAC = 2 Then
        Gosub MCAAA100
      Endif
    Endif
  Elsif SZCLASS = "F" Then
    If ICCVMODE Then
      If [F:COT]EVRMAC = 2 Then
        Gosub FCAAA100
      Endif
    Else
      If [F:CON]EVRMAC = 2 Then
        Gosub FCAAA100
      Endif
    Endif
  Endif
Return

##########################################################################################################
$MCAAA100
  If [M:SRE7]PBL(IPREMACNOL) <> "" Then
    If [M:SRE7]PBL(IPREMACNOL) = [F:LNK]PAEKEY(0) Then
      Gosub CHECKINF
      If ICONTOK Then
        [M:SRE7]CPNCOVFLG(INOL) = 2
        If ICCVMODE Then
          [M:SRE7]CPNCOVSPT(INOL) = 5
        Else
          [M:SRE7]CPNCOVSPT(INOL) = 1
        Endif
        [M:SRE7]CPNCOVVCR(INOL) = SZCOVVCR
        [M:SRE7]CPNCOVCLA(INOL) = ""
        [M:SRE7]CPNCOVREN(INOL) = 0
      Endif
    Endif
  Endif
Return

##########################################################################################################
$FCAAA100
  If [M:SRE7]PBL(IPREMACNOL) <> "" Then
    If [M:SRE7]PBL(IPREMACNOL) = [F:LNK]PAEKEY(0) Then
      Gosub CHECKINF
      If ICONTOK Then
        Trbegin [SRN]
        [F:SRN]CPNCOVFLG = 2
        If ICCVMODE Then
          [F:SRN]CPNCOVSPT = 5
        Else
          [F:SRN]CPNCOVSPT = 1
        Endif
        [F:SRN]CPNCOVVCR = SZCOVVCR
        [F:SRN]CPNCOVREN = 0
        Rewrite [SRN]
        If fstat Then
          #Erreur lors de la réinitialisation complète de la couverture des composants concernés.
          IERR = 514
          Rollback
        Else
          Commit
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
#Couverture supérieure d'un composant indépendant
$CMACMAC000
  If SZCLASS = "M" Then
    If ICCVMODE Then
      If [M:SRE7]PBL(IPREMACNOL) = "" or [F:COT]EVRPBL = 2 Then
        Gosub MCMACMAC000
      Endif
    Else
      If [M:SRE7]PBL(IPREMACNOL) = "" or [F:CON]EVRPBL = 2 Then
        Gosub MCMACMAC000
      Endif
    Endif
  Elsif SZCLASS = "F" Then
    If ICCVMODE Then
      If [M:SRE7]PBL(IPREMACNOL) = "" or [F:COT]EVRPBL = 2 Then
        Gosub FCMACMAC000
      Endif
    Else
      If [M:SRE7]PBL(IPREMACNOL) = "" or [F:CON]EVRPBL = 2 Then
        Gosub FCMACMAC000
      Endif
    Endif
  Endif
Return

##########################################################################################################
$MCMACMAC000
  If [M:SRE7]MAC(IPREMACNOL) <> "" Then
    If [M:SRE7]MAC(IPREMACNOL) = [F:LNK]CMT Then
      #Contrôle si le composant a été listé
      If ICCVMODE Then
        Filter [CCVA] Where [F:CCVA]TPL = 2
&                       and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                       and [F:CCVA]RECTYP = "CPN"
&                       and [F:CCVA]RECNUM = [M:SRE7]CPNITM(INOL)
&                       and [F:CCVA]PAEKEY(0) = ""
&                       and [F:CCVA]PAEKEY(1) <> ""
&                       and [F:CCVA]PAEKEY(2) = ""
&                       and [F:CCVA]PAEKEYTYP(1) = "MAC"
&                       and [F:CCVA]CMT = [M:SRE7]MAC(IPREMACNOL)
      Else
        Filter [CCVA] Where [F:CCVA]TPL <> 2
&                       and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                       and [F:CCVA]RECTYP = "CPN"
&                       and [F:CCVA]RECNUM = [M:SRE7]CPNITM(INOL)
&                       and [F:CCVA]PAEKEY(0) = ""
&                       and [F:CCVA]PAEKEY(1) <> ""
&                       and [F:CCVA]PAEKEY(2) = ""
&                       and [F:CCVA]PAEKEYTYP(1) = "MAC"
&                       and [F:CCVA]CMT = [M:SRE7]MAC(IPREMACNOL)
      Endif
      ICPNLISTED = 0
      For [CCVA]
        ICPNLISTED = 1
        Break
      Next
      Filter [CCVA]
      If !ICPNLISTED Then
        If [F:LNK]CPNICDFLG = 2 Then
          Gosub CHKMACCPNCOV
        Else
          Call RAZCPNLINE(INOL)
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$FCMACMAC000
  If [M:SRE7]MAC(IPREMACNOL) <> "" Then
    If [M:SRE7]MAC(IPREMACNOL) = [F:LNK]CMT Then
      #Contrôle si le composant a été listé
      If ICCVMODE Then
        Filter [CCVA] Where [F:CCVA]TPL = 2
&                       and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                       and [F:CCVA]RECTYP = "CPN"
&                       and [F:CCVA]RECNUM = [F:SRN]CPNITM
&                       and [F:CCVA]PAEKEY(0) = ""
&                       and [F:CCVA]PAEKEY(1) <> ""
&                       and [F:CCVA]PAEKEY(2) = ""
&                       and [F:CCVA]PAEKEYTYP(1) = "MAC"
&                       and [F:CCVA]CMT = [M:SRE7]MAC(IPREMACNOL)
      Else
        Filter [CCVA] Where [F:CCVA]TPL <> 2
&                       and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                       and [F:CCVA]RECTYP = "CPN"
&                       and [F:CCVA]RECNUM = [F:SRN]CPNITM
&                       and [F:CCVA]PAEKEY(0) = ""
&                       and [F:CCVA]PAEKEY(1) <> ""
&                       and [F:CCVA]PAEKEY(2) = ""
&                       and [F:CCVA]PAEKEYTYP(1) = "MAC"
&                       and [F:CCVA]CMT = [M:SRE7]MAC(IPREMACNOL)
      Endif
      ICPNLISTED = 0
      For [CCVA]
        ICPNLISTED = 1
        Break
      Next
      Filter [CCVA]
      If !ICPNLISTED Then
        If [F:LNK]CPNICDFLG = 2 Then
          Gosub CHKMACCPNCOV
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
#Couverture supérieure d'un composant indépendant
$CMACITM000
  If SZCLASS = "M" Then
    If ICCVMODE Then
      If [M:SRE7]PBL(IPREMACNOL) = "" or [F:COT]EVRPBL = 2 Then
        Gosub MCMACITM000
      Endif
    Else
      If [M:SRE7]PBL(IPREMACNOL) = "" or [F:CON]EVRPBL = 2 Then
        Gosub MCMACITM000
      Endif
    Endif
  Elsif SZCLASS = "F" Then
    If ICCVMODE Then
      If [M:SRE7]PBL(IPREMACNOL) = "" or [F:COT]EVRPBL = 2 Then
        Gosub FCMACITM000
      Endif
    Else
      If [M:SRE7]PBL(IPREMACNOL) = "" or [F:CON]EVRPBL = 2 Then
        Gosub FCMACITM000
      Endif
    Endif
  Endif
Return

##########################################################################################################
$MCMACITM000
  If [M:SRE7]MAC(IPREMACNOL) <> "" Then
    Read [MAC]MAC0=[M:SRE7]MAC(IPREMACNOL)
    If !fstat Then
      If [F:MAC]MACPDTCOD = [F:LNK]CMT Then
        If ICCVMODE Then
          Gosub CODE1 From TRTCOVERB
        Else
          If [F:MAC]BPCNUM <> "" Then
            If SZBPCCOD <> "" Then
              If [F:MAC]BPCNUM = SZBPCCOD Then
                Gosub CODE1 From TRTCOVERB
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$FCMACITM000
  If [M:SRE7]MAC(IPREMACNOL) <> "" Then
    Read [MAC]MAC0=[M:SRE7]MAC(IPREMACNOL)
    If !fstat Then
      If [F:MAC]MACPDTCOD = [F:LNK]CMT Then
        If ICCVMODE Then
          Gosub CODE2 From TRTCOVERB
        Else
          If [F:MAC]BPCNUM <> "" Then
            If SZBPCCOD <> "" Then
              If [F:MAC]BPCNUM = SZBPCCOD Then
                Gosub CODE2 From TRTCOVERB
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
#Couverture supérieure d'un composant indépendant
$CMACCIA000
  If SZCLASS = "M" Then
    If ICCVMODE Then
      If [M:SRE7]PBL(IPREMACNOL) = "" or [F:COT]EVRPBL = 2 Then
        Gosub MCMACCIA000
      Endif
    Else
      If [M:SRE7]PBL(IPREMACNOL) = "" or [F:CON]EVRPBL = 2 Then
        Gosub MCMACCIA000
      Endif
    Endif
  Elsif SZCLASS = "F" Then
    If ICCVMODE Then
      If [M:SRE7]PBL(IPREMACNOL) = "" or [F:COT]EVRPBL = 2 Then
        Gosub FCMACCIA000
      Endif
    Else
      If [M:SRE7]PBL(IPREMACNOL) = "" or [F:CON]EVRPBL = 2 Then
        Gosub FCMACCIA000
      Endif
    Endif
  Endif
Return

##########################################################################################################
$MCMACCIA000
  If [M:SRE7]MAC(IPREMACNOL) <> "" Then
    Read [MAC]MAC0=[M:SRE7]MAC(IPREMACNOL)
    If !fstat Then
      If [F:MAC]MACPDTCOD <> "" Then
        Read [ITM]ITM0=[F:MAC]MACPDTCOD
        If !fstat Then
          If [F:ITM]TSICOD(GFAMCIA-1) = [F:LNK]CMT Then
            If ICCVMODE Then
              Gosub CODE3 From TRTCOVERB
            Else
              If [F:MAC]BPCNUM <> "" Then
                If SZBPCCOD <> "" Then
                  If [F:MAC]BPCNUM = SZBPCCOD Then
                    Gosub CODE3 From TRTCOVERB
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$FCMACCIA000
  If [M:SRE7]MAC(IPREMACNOL) <> "" Then
    Read [MAC]MAC0=[M:SRE7]MAC(IPREMACNOL)
    If !fstat Then
      If [F:MAC]MACPDTCOD <> "" Then
        Read [ITM]ITM0=[F:MAC]MACPDTCOD
        If !fstat Then
          If [F:ITM]TSICOD(GFAMCIA-1) = [F:LNK]CMT Then
            If ICCVMODE Then
              Gosub CODE4 From TRTCOVERB
            Else
              If [F:MAC]BPCNUM <> "" Then
                If SZBPCCOD <> "" Then
                  If [F:MAC]BPCNUM = SZBPCCOD Then
                    Gosub CODE4 From TRTCOVERB
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
#Couverture supérieure d'un composant dépendant d'une famille de compétence
$CMACMAC100
  If [M:SRE7]PBL(IPREMACNOL) <> "" Then
    If [M:SRE7]MAC(IPREMACNOL) <> "" Then
      If [M:SRE7]PBL(IPREMACNOL) = [F:LNK]PAEKEY(0) Then
        If [M:SRE7]MAC(IPREMACNOL) = [F:LNK]CMT Then
          #Contrôle si le composant a été listé
          If SZCLASS = "M" Then
            If ICCVMODE Then
              Filter [CCVA] Where [F:CCVA]TPL = 2
&                             and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                             and [F:CCVA]RECTYP = "CPN"
&                             and [F:CCVA]RECNUM = [M:SRE7]CPNITM(INOL)
&                             and [F:CCVA]PAEKEY(0) <> ""
&                             and [F:CCVA]PAEKEY(1) <> ""
&                             and [F:CCVA]PAEKEY(2) = ""
&                             and [F:CCVA]PAEKEYTYP(1) = "MAC"
&                            and [F:CCVA]CMT = [M:SRE7]MAC(IPREMACNOL)
            Else
              Filter [CCVA] Where [F:CCVA]TPL <> 2
&                             and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                             and [F:CCVA]RECTYP = "CPN"
&                             and [F:CCVA]RECNUM = [M:SRE7]CPNITM(INOL)
&                             and [F:CCVA]PAEKEY(0) <> ""
&                             and [F:CCVA]PAEKEY(1) <> ""
&                             and [F:CCVA]PAEKEY(2) = ""
&                             and [F:CCVA]PAEKEYTYP(1) = "MAC"
&                             and [F:CCVA]CMT = [M:SRE7]MAC(IPREMACNOL)
            Endif
          Elsif SZCLASS = "F" Then
            If ICCVMODE Then
              Filter [CCVA] Where [F:CCVA]TPL = 2
&                             and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                             and [F:CCVA]RECTYP = "CPN"
&                             and [F:CCVA]RECNUM = [F:SRN]CPNITM
&                             and [F:CCVA]PAEKEY(0) <> ""
&                             and [F:CCVA]PAEKEY(1) <> ""
&                             and [F:CCVA]PAEKEY(2) = ""
&                             and [F:CCVA]PAEKEYTYP(1) = "MAC"
&                             and [F:CCVA]CMT = [M:SRE7]MAC(IPREMACNOL)
            Else
              Filter [CCVA] Where [F:CCVA]TPL <> 2
&                             and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                             and [F:CCVA]RECTYP = "CPN"
&                             and [F:CCVA]RECNUM = [F:SRN]CPNITM
&                             and [F:CCVA]PAEKEY(0) <> ""
&                             and [F:CCVA]PAEKEY(1) <> ""
&                             and [F:CCVA]PAEKEY(2) = ""
&                             and [F:CCVA]PAEKEYTYP(1) = "MAC"
&                             and [F:CCVA]CMT = [M:SRE7]MAC(IPREMACNOL)
            Endif
          Endif
          ICPNLISTED = 0
          For [CCVA]
            ICPNLISTED = 1
            Break
          Next
          Filter [CCVA]
          If !ICPNLISTED Then
            If [F:LNK]CPNICDFLG = 2 Then
              Gosub CHKMACCPNCOV
            Else
              If SZCLASS = "M" Then
                Call RAZCPNLINE(INOL)
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
#Couverture supérieure d'un composant dépendant d'une famille de compétence
$CMACITM100
  If [M:SRE7]PBL(IPREMACNOL) <> "" Then
    If [M:SRE7]MAC(IPREMACNOL) <> "" Then
      If [M:SRE7]PBL(IPREMACNOL) = [F:LNK]PAEKEY(0) Then
        Read [MAC]MAC0=[M:SRE7]MAC(IPREMACNOL)
        If !fstat Then
          If [F:MAC]MACPDTCOD = [F:LNK]CMT Then
            If ICCVMODE Then
              Gosub CODE5 From TRTCOVERB
            Else
              If [F:MAC]BPCNUM <> "" Then
                If SZBPCCOD <> "" Then
                  If [F:MAC]BPCNUM = SZBPCCOD Then
                    Gosub CODE5 From TRTCOVERB
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
#Couverture supérieure d'un composant dépendant d'une famille de compétence
$CMACCIA100
  If [M:SRE7]PBL(IPREMACNOL) <> "" Then
    If [M:SRE7]MAC(IPREMACNOL) <> "" Then
      If [M:SRE7]PBL(IPREMACNOL) = [F:LNK]PAEKEY(0) Then
