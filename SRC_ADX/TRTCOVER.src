##########################################################################################################
#Couverture partielle d'une famille commerciale de produit indépendante
$CIAAAA010
  If ILINEFLG Then
    ITER2 = INOL
    INBMAC = INOL
  Else
    ITER2 = 0
    INBMAC = [M:SRE7]NBMAC-1
  Endif
  For ITER = ITER2 To INBMAC
    If [M:SRE7]LND(ITER) = 2 Then
      Read [MAC]MAC0=[M:SRE7]MAC(ITER)
      If !fstat Then
        If [F:MAC]MACPDTCOD <> "" Then
          Read [ITM]ITM0=[F:MAC]MACPDTCOD
          If !fstat Then
            If [F:ITM]TPLCONLND <> "" Then
              If [F:CCV]CONNUM = [F:ITM]TPLCONLND Then
                If [M:SRE7]PBL(ITER) = "" or [F:CON]EVRPBL = 2 Then
                  If [M:SRE7]COVFLG(ITER) <> 1 Then
                    If [F:ITM]TSICOD(GFAMCIA-1) = [F:LNK]CMT Then
                      DMACITNDAT = [F:MAC]MACITNDAT
                      Gosub CHECKINF
                      If ICONTOK Then
                        [M:SRE7]COVFLG(ITER) = 2
                        [M:SRE7]COVSPT(ITER) = 5
                        [M:SRE7]COVVCR(ITER) = SZCOVVCR
                        [M:SRE7]MACCOVCLA(ITER) = ""
                        [M:SRE7]MACCOVREN(ITER) = 0
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Else
      If !ICCVMODE Then
        If [M:SRE7]PBL(ITER) = "" or [F:CON]EVRPBL = 2 Then
          If [M:SRE7]COVFLG(ITER) <> 1 Then
            Read [MAC]MAC0=[M:SRE7]MAC(ITER)
            If !fstat Then
              If [F:MAC]MACPDTCOD <> "" Then
                Read [ITM]ITM0=[F:MAC]MACPDTCOD
                If !fstat Then
                  If [F:ITM]TSICOD(GFAMCIA-1) = [F:LNK]CMT Then
                    If [F:MAC]BPCNUM <> "" Then
                      If SZBPCCOD <> "" Then
                        If [F:MAC]BPCNUM = SZBPCCOD Then
                          Gosub CHECKINF
                          If ICONTOK Then
                            [M:SRE7]COVFLG(ITER) = 2
                            [M:SRE7]COVSPT(ITER) = 1
                            [M:SRE7]COVVCR(ITER) = SZCOVVCR
                            [M:SRE7]MACCOVCLA(ITER) = ""
                            [M:SRE7]MACCOVREN(ITER) = 0
                          Endif
                        Endif
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
Return

##########################################################################################################
#Couverture maitre d'une fiche parc dépendante d'une famille de compétence
$MACMAC100
  If ILINEFLG Then
    ITER2 = INOL
    INBMAC = INOL
  Else
    ITER2 = 0
    INBMAC = [M:SRE7]NBMAC-1
  Endif
  For ITER = ITER2 To INBMAC
    If [M:SRE7]LND(ITER) = 2 Then
      Read [MAC]MAC0=[M:SRE7]MAC(ITER)
      If !fstat Then
        If [F:MAC]MACPDTCOD <> "" Then
          Read [ITM]ITM0=[F:MAC]MACPDTCOD
          If !fstat Then
            If [F:ITM]TPLCONLND <> "" Then
              If [F:CCV]CONNUM = [F:ITM]TPLCONLND Then
                If [M:SRE7]COVFLG(ITER) <> 1 Then
                  If [M:SRE7]PBL(ITER) <> "" Then
                    If [M:SRE7]PBL(ITER) = [F:LNK]PAEKEY(0) Then
                      If [M:SRE7]MAC(ITER) = [F:LNK]CMT Then
                        DMACITNDAT = [F:MAC]MACITNDAT
                        Gosub CHECKCOMCOV
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Else
      If !ICCVMODE Then
        If [M:SRE7]COVFLG(ITER) <> 1 Then
          If [M:SRE7]PBL(ITER) <> "" Then
            If [M:SRE7]PBL(ITER) = [F:LNK]PAEKEY(0) Then
              If [M:SRE7]MAC(ITER) = [F:LNK]CMT Then
                Gosub CHECKCOMCOV
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
Return

##########################################################################################################
#Couverture maitre d'une référence article dépendante d'une famille de compétence
$MACITM100
  If ILINEFLG Then
    ITER2 = INOL
    INBMAC = INOL
  Else
    ITER2 = 0
    INBMAC = [M:SRE7]NBMAC-1
  Endif
  For ITER = ITER2 To INBMAC
    If [M:SRE7]LND(ITER) = 2 Then
      Read [MAC]MAC0=[M:SRE7]MAC(ITER)
      If !fstat Then
        If [F:MAC]MACPDTCOD <> "" Then
          Read [ITM]ITM0=[F:MAC]MACPDTCOD
          If !fstat Then
            If [F:ITM]TPLCONLND <> "" Then
              If [F:CCV]CONNUM = [F:ITM]TPLCONLND Then
                If [M:SRE7]COVFLG(ITER) <> 1 Then
                  If [M:SRE7]PBL(ITER) <> "" Then
                    If [M:SRE7]PBL(ITER) = [F:LNK]PAEKEY(0) Then
                      If [F:MAC]MACPDTCOD = [F:LNK]CMT Then
                        DMACITNDAT = [F:MAC]MACITNDAT
                        Gosub CHECKCOMCOV
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Else
      If !ICCVMODE Then
        If [M:SRE7]COVFLG(ITER) <> 1 Then
          If [M:SRE7]PBL(ITER) <> "" Then
            If [M:SRE7]PBL(ITER) = [F:LNK]PAEKEY(0) Then
              Read [MAC]MAC0=[M:SRE7]MAC(ITER)
              If !fstat Then
                If [F:MAC]MACPDTCOD = [F:LNK]CMT Then
                  If [F:MAC]BPCNUM <> "" Then
                    If SZBPCCOD <> "" Then
                      If [F:MAC]BPCNUM = SZBPCCOD Then
                        Gosub CHECKCOMCOV
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
Return

##########################################################################################################
#Couverture maitre d'une famille commerciale de produit dépendante d'une famille de compétence
$MACCIA100
  If ILINEFLG Then
    ITER2 = INOL
    INBMAC = INOL
  Else
    ITER2 = 0
    INBMAC = [M:SRE7]NBMAC-1
  Endif
  For ITER = ITER2 To INBMAC
    If [M:SRE7]LND(ITER) = 2 Then
      Read [MAC]MAC0=[M:SRE7]MAC(ITER)
      If !fstat Then
        If [F:MAC]MACPDTCOD <> "" Then
          Read [ITM]ITM0=[F:MAC]MACPDTCOD
          If !fstat Then
            If [F:ITM]TPLCONLND <> "" Then
              If [F:CCV]CONNUM = [F:ITM]TPLCONLND Then
                If [M:SRE7]COVFLG(ITER) <> 1 Then
                  If [M:SRE7]PBL(ITER) = "" Then
                    If [M:SRE7]PBL(ITER) = [F:LNK]PAEKEY(0) Then
                      If [F:ITM]TSICOD(GFAMCIA-1) = [F:LNK]CMT Then
                        DMACITNDAT = [F:MAC]MACITNDAT
                        Gosub CHKCIACOMCOV
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Else
      If !ICCVMODE Then
        If [M:SRE7]COVFLG(ITER) <> 1 Then
          If [M:SRE7]PBL(ITER) = "" Then
            If [M:SRE7]PBL(ITER) = [F:LNK]PAEKEY(0) Then
              Read [MAC]MAC0=[M:SRE7]MAC(ITER)
              If !fstat Then
                If [F:MAC]MACPDTCOD <> "" Then
                  Read [ITM]ITM0=[F:MAC]MACPDTCOD
                  If !fstat Then
                    If [F:ITM]TSICOD(GFAMCIA-1) = [F:LNK]CMT Then
                      If [F:MAC]BPCNUM <> "" Then
                        If SZBPCCOD <> "" Then
                          If [F:MAC]BPCNUM = SZBPCCOD Then
                            Gosub CHKCIACOMCOV
                          Endif
                        Endif
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
Return

##########################################################################################################
#Couverture partielle d'une fiche parc dépendante d'une famille de compétence
$MACAAA110
  If ILINEFLG Then
    ITER2 = INOL
    INBMAC = INOL
  Else
    ITER2 = 0
    INBMAC = [M:SRE7]NBMAC-1
  Endif
  For ITER = ITER2 To INBMAC
    If [M:SRE7]LND(ITER) = 2 Then
      Read [MAC]MAC0=[M:SRE7]MAC(ITER)
      If !fstat Then
        If [F:MAC]MACPDTCOD <> "" Then
          Read [ITM]ITM0=[F:MAC]MACPDTCOD
          If !fstat Then
            If [F:ITM]TPLCONLND <> "" Then
              If [F:CCV]CONNUM = [F:ITM]TPLCONLND Then
                If [M:SRE7]COVFLG(ITER) <> 1 Then
                  If [M:SRE7]PBL(ITER) = "" Then
                    If [M:SRE7]PBL(ITER) = [F:LNK]PAEKEY(0) Then
                      If [M:SRE7]MAC(ITER) = [F:LNK]CMT Then
                        DMACITNDAT = [F:MAC]MACITNDAT
                        Gosub CHECKINF
                        If ICONTOK Then
                          [M:SRE7]COVFLG(ITER) = 2
                          [M:SRE7]COVSPT(ITER) = 5
                          [M:SRE7]COVVCR(ITER) = SZCOVVCR
                          [M:SRE7]MACCOVCLA(ITER) = ""
                          [M:SRE7]MACCOVREN(ITER) = 0
                        Endif
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Else
      If !ICCVMODE Then
        If [M:SRE7]COVFLG(ITER) <> 1 Then
          If [M:SRE7]PBL(ITER) = "" Then
            If [M:SRE7]PBL(ITER) = [F:LNK]PAEKEY(0) Then
              If [M:SRE7]MAC(ITER) = [F:LNK]CMT Then
                Gosub CHECKINF
                If ICONTOK Then
                  [M:SRE7]COVFLG(ITER) = 2
                  [M:SRE7]COVSPT(ITER) = 1
                  [M:SRE7]COVVCR(ITER) = SZCOVVCR
                  [M:SRE7]MACCOVCLA(ITER) = ""
                  [M:SRE7]MACCOVREN(ITER) = 0
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
Return

