    If [M:SRE7]PBL(IPREMACNOL) <> "" Then
      If [M:SRE7]MAC(IPREMACNOL) <> "" Then
        If [M:SRE7]PBL(IPREMACNOL) = [F:LNK]PAEKEY(0) Then
          Read [MAC]MAC0=[M:SRE7]MAC(IPREMACNOL)
          If !fstat Then
            If [F:MAC]MACPDTCOD <> "" Then
              Read [ITM]ITM0=[F:MAC]MACPDTCOD
              If !fstat Then
                If [F:ITM]TSICOD(GFAMCIA-1) = [F:LNK]CMT Then
                  If [F:SRN]CPNITM = [F:LNK]RECNUM Then
                    If ICCVMODE Then
                      Gosub CHKAAACPNCOV
                    Else
                      If [F:MAC]BPCNUM <> "" Then
                        If SZBPCCOD <> "" Then
                          If [F:MAC]BPCNUM = SZBPCCOD Then
                            Gosub CHKAAACPNCOV
                          Endif
                        Endif
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Test commun de couverture (Couverture financière)
$CHKAAACPNCOV
  Gosub CHECKINF
  If ICONTOK Then
    Gosub CHKPARTIAL
    If SZCLASS = "M" Then
      If IFULLCOVER Then
        If [M:SRE7]CPNCOVFLG(INOL) <> 2 Then
          [M:SRE7]CPNCOVFLG(INOL) = 1
        Endif
     Else
        [M:SRE7]CPNCOVFLG(INOL) = 2
      Endif
      If ICCVMODE Then
        [M:SRE7]CPNCOVSPT(INOL) = 5
      Else
        [M:SRE7]CPNCOVSPT(INOL) = 1
      Endif
      [M:SRE7]CPNCOVVCR(INOL) = SZCOVVCR
      [M:SRE7]CPNCOVCLA(INOL) = ""
      [M:SRE7]CPNCOVREN(INOL) = 0
    Elsif SZCLASS = "F" Then
      Trbegin [SRN]
      If IFULLCOVER Then
        If [F:SRN]CPNCOVFLG <> 2 Then
          [F:SRN]CPNCOVFLG = 1
        Endif
      Else
        [F:SRN]CPNCOVFLG = 2
      Endif
      If ICCVMODE Then
        [F:SRN]CPNCOVSPT = 5
      Else
        [F:SRN]CPNCOVSPT = 1
      Endif
      [F:SRN]CPNCOVVCR = SZCOVVCR
      [F:SRN]CPNCOVREN = 0
      Rewrite [SRN]
      If fstat Then
        #Erreur lors de la réinitialisation complète de la couverture des composants concernés.
        IERR = 514
        Rollback
      Else
        Commit
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Test commun de couverture (Couverture maitre composant)
$CHKCPNCOV
  If SZCLASS = "M" Then
    If [M:SRE7]CPNCOVFLG(INOL) = 2 Then
      Return
    Endif
  Elsif SZCLASS = "F" Then
    If [F:SRN]CPNCOVFLG = 2 Then
      Return
    Endif
  Endif
  Gosub CHKPARTIAL
  If IFULLCOVER Then
    If [F:LNK]ICDFLG = 2 Then
      Gosub CHECKINF
      If ICONTOK Then
        If SZCLASS = "M" Then
          [M:SRE7]CPNCOVFLG(INOL) = 1
          If ICCVMODE Then
            [M:SRE7]CPNCOVSPT(INOL) = 5
          Else
            [M:SRE7]CPNCOVSPT(INOL) = 1
          Endif
          [M:SRE7]CPNCOVVCR(INOL) = SZCOVVCR
          [M:SRE7]CPNCOVCLA(INOL) = ""
          [M:SRE7]CPNCOVREN(INOL) = 0
        Elsif SZCLASS = "F" Then
          Trbegin [SRN]
          [F:SRN]CPNCOVFLG = 1
          If ICCVMODE Then
            [F:SRN]CPNCOVSPT = 5
          Else
            [F:SRN]CPNCOVSPT = 1
          Endif
          [F:SRN]CPNCOVVCR = SZCOVVCR
          [F:SRN]CPNCOVREN = 0
          Rewrite [SRN]
          If fstat Then
            #Erreur lors de la réinitialisation complète de la couverture des composants concernés.
            IERR = 514
            Rollback
          Else
            Commit
          Endif
        Endif
      Endif
    Endif
  Else
    Gosub CHECKINF
    If ICONTOK Then
      If SZCLASS = "M" Then
        [M:SRE7]CPNCOVFLG(INOL) = 2
        If ICCVMODE Then
          [M:SRE7]CPNCOVSPT(INOL) = 5
        Else
          [M:SRE7]CPNCOVSPT(INOL) = 1
        Endif
        [M:SRE7]CPNCOVVCR(INOL) = SZCOVVCR
        [M:SRE7]CPNCOVCLA(INOL) = ""
        [M:SRE7]CPNCOVREN(INOL) = 0
      Elsif SZCLASS = "F" Then
        Trbegin [SRN]
        [F:SRN]CPNCOVFLG = 2
        If ICCVMODE Then
          [F:SRN]CPNCOVSPT = 5
        Else
          [F:SRN]CPNCOVSPT = 1
        Endif
        [F:SRN]CPNCOVVCR = SZCOVVCR
        [F:SRN]CPNCOVREN = 0
        Rewrite [SRN]
        If fstat Then
          #Erreur lors de la réinitialisation complète de la couverture des composants concernés.
          IERR = 514
          Rollback
        Else
          Commit
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Test commun de couverture (Couverture supérieure)
$CHKMACCPNCOV
  Gosub CHECKINF
  If ICONTOK Then
    If SZCLASS = "M" Then
      [M:SRE7]CPNCOVFLG(INOL) = 1
      If ICCVMODE Then
        [M:SRE7]CPNCOVSPT(INOL) = 5
      Else
        [M:SRE7]CPNCOVSPT(INOL) = 1
      Endif
      [M:SRE7]CPNCOVVCR(INOL) = SZCOVVCR
      [M:SRE7]CPNCOVCLA(INOL) = ""
      [M:SRE7]CPNCOVREN(INOL) = 0
    Elsif SZCLASS = "F" Then
      Trbegin [SRN]
      [F:SRN]CPNCOVFLG = 1
      If ICCVMODE Then
        [F:SRN]CPNCOVSPT = 5
      Else
        [F:SRN]CPNCOVSPT = 1
      Endif
      [F:SRN]CPNCOVVCR = SZCOVVCR
      [F:SRN]CPNCOVREN = 0
      Rewrite [SRN]
      If fstat Then
        #Erreur lors de la réinitialisation complète de la couverture des composants concernés.
        IERR = 514
        Rollback
      Else
        Commit
      Endif
    Endif
  Endif
Return

##########################################################################################################
#Vérification de l'échéance et du réglement du contrat
$CHECKINF
  ICONTOK = 1
  SZCOVVCR = ""
  If ICCVMODE Then
    If DMACITNDAT = [00/00/00] Then
      SZCOVVCR = [F:COT]CONNUM
    Else
      Call SETENDDAT(DMACITNDAT, [F:COT]REWFRY, [F:COT]REWFRYBAS, DLNDENDDAT) From SUBCOND
      If DLNDENDDAT < date$ Then
        ICONTOK = 0
      Else
        SZCOVVCR = [F:COT]CONNUM
      Endif
    Endif
    Return
  Endif
  If [F:CON]CONENDDAT < date$ Then
    ICONTOK = 0
  Else
    If [F:CON]CONSTRDAT > date$ Then
      ICONTOK = 0
    Else
      #Contrôle du réglement du contrat
      SZLITCOD = ""
      Call CHECKPAY([F:CON]CONNUM, [F:CON]CONBPC, SZLITCOD, ICONTOK)
      If ICONTOK Then
        SZCOVVCR = [F:CON]CONNUM
      Else
        If SZLITCOD <> "" Then
          Call CHECK2LIT([F:CON]CONNUM, SZLITCOD, ICONTOK)
          If ICONTOK Then
            SZCOVVCR = [F:CON]CONNUM
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
#Détermine si une couverture de compétence est totale
##########################################################
$CHKPARTIAL
  IFULLCOVER = 1
  If [F:LNK]HEIPRC(0) > 0 Then
    IFULLCOVER = 0
  Else
    If [F:LNK]ITMICDFLG = 0 Then
      If GITMICD = 2 Then
        If [F:LNK]HEIPRC(0) = 0 Then
          IFULLCOVER = 0
        Endif
      Endif
    Else
      If [F:LNK]ITMICDFLG = 2 Then
        If [F:LNK]HEIPRC(0) = 0
          IFULLCOVER = 0
        Endif
      Endif
    Endif
  Endif
  If IFULLCOVER Then
    If [F:LNK]MINCOV(0) > 0 Then
      IFULLCOVER = 0
    Endif
  Endif
  If IFULLCOVER Then
    If [F:LNK]MAXCOV(0) > 0 Then
      IFULLCOVER = 0
    Endif
  Endif
  If IFULLCOVER Then
    If [F:LNK]HEIPRC(1) > 0 Then
      IFULLCOVER = 0
    Else
      If [F:LNK]LABICDFLG = 0 Then
        If GLABICD = 2 Then
          If [F:LNK]HEIPRC(1) = 0 Then
            IFULLCOVER = 0
          Endif
        Endif
      Else
        If [F:LNK]LABICDFLG = 2 Then
          If [F:LNK]HEIPRC(1) = 0 Then
            IFULLCOVER = 0
          Endif
        Endif
      Endif
    Endif
  Endif
  If IFULLCOVER Then
    If [F:LNK]MINCOV(1) > 0 Then
      IFULLCOVER = 0
    Endif
  Endif
  If IFULLCOVER Then
    If [F:LNK]MAXCOV(1) > 0 Then
      IFULLCOVER = 0
    Endif
  Endif
  If IFULLCOVER Then
    If [F:LNK]HEIPRC(2) > 0 Then
      IFULLCOVER = 0
    Else
      If [F:LNK]EXSICDFLG = 0 Then
        If GEXSICD = 2 Then
          If [F:LNK]HEIPRC(2) = 0 Then
            IFULLCOVER = 0
          Endif
        Endif
      Else
        If [F:LNK]EXSICDFLG = 2 Then
          If [F:LNK]HEIPRC(2) = 0 Then
            IFULLCOVER = 0
          Endif
        Endif
      Endif
    Endif
  Endif
  If IFULLCOVER Then
    If [F:LNK]MINCOV(2) > 0 Then
      IFULLCOVER = 0
    Endif
  Endif
  If IFULLCOVER Then
    If [F:LNK]MAXCOV(2) > 0 Then
      IFULLCOVER = 0
    Endif
  Endif
Return

##########################################################################################################
# Contrôle du réglement d'une échéance de contrat de service
#################################################################
# Issue X3-58793 - 2017-10-23 by FGR : BEGIN
Subprog CHECKPAY(SZCONCOD, SZBPRCOD, SZLITCOD, IOK)
Value Char SZCONCOD
Value Char SZBPRCOD
Variable Char SZLITCOD
Variable Integer IOK

  IOK = 1
  Local File MTCBATCH [MTB]
  Filter [SIV] Where [F:SIV]SIHORI = 7 and [F:SIV]INVTYP = 1 and [F:SIV]SIHORINUM = SZCONCOD and [F:SIV]INVDAT < date$ Order By [F:SIV]INVDAT Desc
  For [SIV] Hint Key SIV1
    Filter [DUD] Where [F:DUD]NUM = [F:SIV]NUM and [F:DUD]DUDDAT < date$ Order By [F:DUD]DUDDAT Desc
    For [DUD]
      If [F:DUD]AMTCUR <> [F:DUD]PAYCUR + [F:DUD]TMPCUR Then
        # idem SAM-84337 : BEGIN
        Filter [MTB] Where [F:MTB]ACCNUM = [F:DUD]ACCNUM and [F:MTB]DUDLIG = [F:DUD]DUDLIG
        Look [MTB]MTB0 First
        Filter [MTB]
        If !fstat Then
          GMESSAGE = mess(70,119,1)
          GERR = 3
        Endif
        # idem SAM-84337 : END
        IOK = 0
        SZLITCOD = [F:DUD]DPTCOD
        Break
      Endif
    Next
    Filter [DUD]
    If IOK = 0 Then
      Break
    Endif
  Next
  Filter [SIV]
End

