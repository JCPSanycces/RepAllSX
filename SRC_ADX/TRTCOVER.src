#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires de gestion de la couverture SAV           Module CRM            30 Juin 2003
#
#  COVERM       : Effectue le contrôle complet de couverture d'une demande de service en classe écran
#  COVERML      : Effectue le contrôle de couverture d'une ligne de parc concerné en classe écran
#  COVERMLC     : Effectue le contrôle de couverture d'une ligne de composant concerné en classe écran
#  COVERMG      : Détermine le statut de couverture globale d'une demande de service en classe écran
#  COVERMGC     : Détermine le statut de couverture globale en classe écran suite à la saisie d'un composant
#  SETCPNOVRCOV : Met à jour la couverture globale sur la base d'une nouvelle couverture de composant.
#  CHECKFULLCOV : Détermine si toute le reste d'une demande de service est totalement couvert.
#  CHECKCOVMEE  : Contrôle de l'affichage des messages
#  RAZCOVMEE    : Suppression de la mémoire d'un message
#  CHECKOST     : Réalise le contrôle d'en-cours client
#  CHKNBCON     : Contrôle de la souscription d'au moins un contrat
#  CHECKCON     : Contrôle des couvertures compétences, parc et composant
#  FULLCOVSRE   : Couverture totale d'une demande de service
#  FULLCOVMAC   : Couverture totale d'une ligne de parc concerné
#  FULLCOVCPN   : Couverture totale d'une ligne de composant concerné
#  RAZCCV       : Réinitialisation compléte de la couverture d'une demande de service
#  RAZCPNLINE   : Réinitialisation de la couverture d'une ligne de composant concerné d'une demande de service
#  CHECKCCV     : Contrôle des couvertures composants
#  CHECKCPN     : Contrôle des couvertures composants
#  CHECKPAY     : Contrôle du réglement d'une échéance de contrat de service
#  CHECKLIT     : Contrôle de l'existence d'un code litige dérogatoire.
#  CHECK2LIT    : Contrôle de l'existence d'un code litige dérogatoire.
#  CHKPBL       : Contrôle de couverture sur la base d'une compétence
#  SETRESDAT    : Calcul une date de résolution souhaitée par rapport aux contraintes qualité
#                        d'un contrat de service
#  CHECKPIT     : Contrôle des couvertures par point
#  DELPITCOV    : Suppression de toutes les couvertures par point d'une demande de service.
#  RECHECKCPN   : Redéfini la couverture de tous les composants de parc. (Classe F)
#  RECHECKMLC   : Effectue le contrôle de couverture  d'un composant concerné en classe fichier
#  RECHKNBCON   : Contrôle de la souscription d'au moins un contrat
#  RECHECKCON   : Contrôle des couvertures compétences, parc et composant
#  CHKCONCON    : Contrôle des couvertures compétences, parc et composant
#  COVERMCON    : Détermine le statut de couverture d'un contrat de service vis à vis d'une fiche parc.
#  COVERMCCON   : Détermine le statut de couverture d'un contrat de service vis à vis d'un composant de parc.
#
##########################################################################################################
##########################################################################################################
# Effectue le contrôle complet de couverture d'une demande de service en classe écran
###########################################################################
Subprog COVERM
Local Integer ITER
Local Integer IERR
Local Integer IEVRCOV

  IERR = 0
  ITER = 0
  [M:SRE0]CURCOVMEE = 0
  IEVRCOV = 0
  If [M:SRE0]SREBPC = "" Then
    #Aucun code client n'est indiqué. Le contrôle de couverture est abandonné.
    [M:SRE0]CURCOVMEE = -517
    Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
    End
  Endif
  #Analyse de la couverture
  Call TEMPON(mess(297,182,1)) From GESECRAN
  #Etape 1 : Suppression des couvertures par point
  Call DELPITCOV(GREP, 0, 0, IERR)
  If IERR Then
    #Erreur lors de suppression des couvertures par points. Le contrôle de couverture est abandonné.
    [M:SRE0]CURCOVMEE = -IERR
    Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
    Call TEMPOFF From GESECRAN
    End
  Endif
  #Etape 2
  #Vérification du status du client
  [M:SRE2]OVRCOV = 1
  Call CHECKOST([M:SRE0]SREBPC)
  If [M:SRE2]OVRCOV = 3 Then
    If [M:SRE0]CURCOVMEE <> 0 Then
      Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
    Endif
    Call TEMPOFF From GESECRAN
    Gosub AFFSRE2MIS From SUBSREB2
    End
  Endif
  #On change d'état de départ pour les prochaines étapes.
  [M:SRE2]OVRCOV = 3
  #Etape 3
  #Contrôle de la présence d'au moins un contrat
  Call CHKNBCON([M:SRE0]SREBPC, [M:SRE0]SREMAC, 0, 0)
  #Aucun contrat souscrit. Pas la peine de continuer
  If [M:SRE0]CURCOVMEE = 1 Then
    Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
    Call TEMPOFF From GESECRAN
    Call COVERMG(0, 0)
    Gosub AFFSRE2MIS From SUBSREB2
    End
  Endif
  #Etape 4
  #Contrôle de la présence de super contrats toutes compétences et tous articles
  Call CHECKCON([M:SRE0]SREBPC, [M:SRE7]SREPBLGRP, [M:SRE0]SREMAC, "SRE", 0, IEVRCOV)
  #Couvert totalement par un super contrat
  If IEVRCOV Then
    If [M:SRE0]CURCOVMEE <> 0 Then
      Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
    Endif
    Call TEMPOFF From GESECRAN
    Call COVERMG(0, 0)
    Gosub AFFSRE2MIS From SUBSREB2
    End
  Endif
  #Etape 5
  #Vérification de la couverture détaillée compétences et articles
  If [M:SRE7]NBMAC > 0 Then
    Call RAZCCV(IERR)
    If IERR Then
      #Erreur lors de la réinitialisation des informations de couverture. Le contrôle de couverture est abandonné.
      [M:SRE0]CURCOVMEE = -IERR
      Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
      Call TEMPOFF From GESECRAN
      End
    Endif
    Call CHECKCCV("", [M:SRE0]SREBPC, 0, 0)
  Else
    If [M:SRE7]SREPBLGRP <> "" Then
      Call CHKPBL([M:SRE0]SREBPC, [M:SRE7]SREPBLGRP)
    Endif
  Endif
  #Etape 6
  #Recherche de contrats à points
  Call CHECKPIT("", [M:SRE0]SREBPC, 0, 0, IERR)
  If IERR Then
    #Erreur lors de la réinitialisation des informations de couverture. Le contrôle de couverture est abandonné.
    [M:SRE0]CURCOVMEE = -IERR
    Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
    Call TEMPOFF From GESECRAN
    End
  Endif
  #Etape 7
  #Il faut retablir la couverture des composants
  If [M:SRE7]NBMAC > 0 Then
    Call RECHECKCPN(0, 0, IERR)
    If IERR Then
      #Erreur lors de la réinitialisation complète de la couverture des composants concernés.
      [M:SRE0]CURCOVMEE = -IERR
      Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
      Call TEMPOFF From GESECRAN
      End
    Endif
  Endif
  #Etape 8 Affichage des informations globales
  Call COVERMG(0, 0)
  Call LOADTOTPIT(1) From SUBSREB1
  If [M:SRE0]CURCOVMEE <> 0 Then
    Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
    Call TEMPOFF From GESECRAN
    Gosub AFFSRE2MIS From SUBSREB2
    End
  Endif
  If GCOVPROMPT <> 2 Then
    GERR = 4
    GMESSAGE = "."
  Endif
  Call TEMPOFF From GESECRAN
  Gosub AFFSRE2MIS From SUBSREB2
End

##########################################################################################################
# Effectue le contrôle de couverture d'une ligne de parc concerné en classe écran
###########################################################################
Subprog COVERML(INOL)
Value Integer INOL

Local Integer IERR
Local Integer IEVRCOV

  IERR = 0
  [M:SRE0]CURCOVMEE = 0
  IEVRCOV = 0
  If [M:SRE0]SREBPC = "" Then
    #Aucun code client n'est indiqué. Le contrôle de couverture est abandonné.
    [M:SRE0]CURCOVMEE = -517
    Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
    End
  Endif
  #Etape 1 : Suppression des couvertures par point
  Call DELPITCOV(GREP, 1, INOL, IERR)
  If IERR Then
    #Erreur lors de suppression des couvertures par points. Le contrôle de couverture est abandonné.
    [M:SRE0]CURCOVMEE = -IERR
    Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
    End
  Endif
  #Etape 2
  #Contrôle de la présence d'au moins un contrat
  Call CHKNBCON([M:SRE0]SREBPC, [M:SRE7]MAC(INOL), 1, INOL)
  #Aucun contrat souscrit. Pas la peine de continuer
  If [M:SRE0]CURCOVMEE = 1 Then
    Call COVERMG(1, INOL)
    Gosub AFFSRE2MIS From SUBSREB2
    End
  Endif
  #Etape 3
  #Contrôle de la présence de super contrats toutes compétences et tous articles
  Call CHECKCON([M:SRE0]SREBPC, [M:SRE7]PBL(INOL), [M:SRE7]MAC(INOL), "MAC", INOL, IEVRCOV)
  #Couvert totalement par un super contrat
  If IEVRCOV = 1 Then
    Call COVERMG(1, INOL)
    Gosub AFFSRE2MIS From SUBSREB2
    End
  Endif
  #Etape 4
  #Vérification de la couverture détaillée compétences et articles
  Call RAZCCVLINE(INOL, IERR)
  If IERR Then
    #Erreur lors de la réinitialisation des informations de couverture. Le contrôle de couverture est abandonné.
    [M:SRE0]CURCOVMEE = -IERR
    Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
    End
  Endif
  Call CHECKCCV("", [M:SRE0]SREBPC, 1, INOL)
  #Etape 5
  #Recherche de contrats à points
  Call CHECKPIT("", [M:SRE0]SREBPC, 1, INOL, IERR)
  If IERR Then
    #Erreur lors de la réinitialisation des informations de couverture. Le contrôle de couverture est abandonné.
    [M:SRE0]CURCOVMEE = -IERR
    Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
    End
  Endif
  #Etape 6
  #Il faut retablir la couverture des composants
  If [M:SRE7]NBCPN > 0 Then
    Call RECHECKCPN(1, INOL, IERR)
    If IERR Then
      #Erreur lors de la réinitialisation complète de la couverture des composants concernés.
      [M:SRE0]CURCOVMEE = -IERR
      Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
      End
    Endif
  Endif
  #Etape 7 Affichage des informations globales
  Call COVERMG(1, INOL)
  Call LOADTOTPIT(1) From SUBSREB1
  If [M:SRE0]CURCOVMEE <> 0 Then
    Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
    Gosub AFFSRE2MIS From SUBSREB2
    End
  Endif
  If GCOVPROMPT <> 2 Then
    GERR = 4
    GMESSAGE = "."
  Endif
  Gosub AFFSRE2MIS From SUBSREB2
End

##########################################################################################################
# Effectue le contrôle de couverture d'une ligne de composant concerné en classe écran
###########################################################################
Subprog COVERMLC(INOL, IPREMACNOL)
Value Integer INOL
Value Integer IPREMACNOL

Local Integer IERR
Local Integer IEVRCOV

  IERR = 0
  [M:SRE0]CURCOVMEE = 0
  IEVRCOV = 0
  If [M:SRE0]SREBPC = "" Then
    #Aucun code client n'est indiqué. Le contrôle de couverture est abandonné.
    [M:SRE0]CURCOVMEE = -517
    Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
    End
  Endif
  #Etape 1
  #Si le parc est couvert par un contrat à point, le composant est totalement couvert.
  If [M:SRE7]COVFLG(IPREMACNOL) = 1 Then
    If [M:SRE7]COVSPT(IPREMACNOL) = 1 Then
      If [M:SRE7]COVVCR(IPREMACNOL) <> "" Then
        Read [CON]CON0=[M:SRE7]COVVCR(IPREMACNOL)
        If !fstat Then
          If [F:CON]CONCAT = 4 Then
            #Composant totalement couvert
            [M:SRE7]CPNCOVFLG(INOL) = 1
            [M:SRE7]CPNCOVSPT(INOL) = 1
            [M:SRE7]CPNCOVVCR(INOL) = [M:SRE7]COVVCR(IPREMACNOL)
            [M:SRE7]CPNCOVCLA(INOL) = ""
            [M:SRE7]CPNCOVREN(INOL) = 0
            Call COVERMGC(INOL)
            Gosub AFFSRE2MIS From SUBSREB2
            End
          Endif
        Endif
      Endif
    Endif
  Endif
  #Etape 2
  #Contrôle de la présence d'au moins un contrat
  Call CHKNBCON([M:SRE0]SREBPC, [M:SRE7]MAC(IPREMACNOL), 2, INOL)
  #Aucun contrat souscrit. Pas la peine de continuer
  If [M:SRE0]CURCOVMEE = 1 Then
    Call COVERMGC(INOL)
    Gosub AFFSRE2MIS From SUBSREB2
    End
  Endif
  #Etape 3
  #Contrôle de la présence de super contrats toutes compétences et tous articles
  Call CHECKCON([M:SRE0]SREBPC, [M:SRE7]PBL(IPREMACNOL), [M:SRE7]MAC(IPREMACNOL), "CPN", INOL, IEVRCOV)
  #Couvert totalement par un super contrat
  If IEVRCOV = 1 Then
    Call COVERMGC(INOL)
    Gosub AFFSRE2MIS From SUBSREB2
    End
  Endif
  #Etape 4
  #Vérification de la couverture détaillée compétences et articles
  Call RAZCPNLINE(INOL)
  Call CHECKCPN("", [M:SRE0]SREBPC, INOL, IPREMACNOL, "M", IERR)
  If IERR Then
    [M:SRE0]CURCOVMEE = -IERR
    Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
    End
  Endif
  Call COVERMGC(INOL)
  If [M:SRE0]CURCOVMEE <> 0 Then
    Call CHECKCOVMEE([M:SRE0]CURCOVMEE)
    Gosub AFFSRE2MIS From SUBSREB2
    End
  Endif
  If GCOVPROMPT <> 2 Then
    GERR = 4
    GMESSAGE = "."
  Endif
  Gosub AFFSRE2MIS From SUBSREB2
End

##########################################################################################################
# Détermine le statut de couverture globale d'une demande de service en classe écran
###########################################################################
Subprog COVERMG(ILINEFLG, INOL)
Value Integer ILINEFLG
Value Integer INOL

Local Integer IERR
Local Integer INBCONTROL
Local Integer IWHOLECOVF
Local Integer ITER
Local Integer ITER2
Local Integer IALLCOVER
Local Char SZFIRCON(GLONVCR)
Local Integer IMUSTEMPTY
Local Integer ICOVSPTARR(6)

  IERR = 0
  ITER2 = 0
  IALLCOVER = 1
  SZFIRCON = ""
  IMUSTEMPTY = 0
  Raz ICOVSPTARR
  IWHOLECOVF = 0
  INBCONTROL = 0
  #Détermine si la demande est totalement couverte
  #Parc
  For ITER = 0 To [M:SRE7]NBMAC-1
    If [M:SRE7]COVSPT(ITER) > 0 Then
      ICOVSPTARR([M:SRE7]COVSPT(ITER)-1) += 1
      INBCONTROL += 1
    Endif
    If [M:SRE7]COVFLG(ITER) <> 1 Then
      IALLCOVER = 0
      Break
    Endif
  Next
  #Composants classe M
  For ITER = 0 To [M:SRE7]NBCPN-1
    If [M:SRE7]CPNCOVSPT(ITER) > 0 Then
      ICOVSPTARR([M:SRE7]CPNCOVSPT(ITER)-1) += 1
      INBCONTROL += 1
    Endif
    If [M:SRE7]CPNCOVFLG(ITER) <> 1 Then
      IALLCOVER = 0
      Break
    Endif
  Next
  #Composants classe F
  If GREP = "C" Then
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0 Order By [F:SRN]CPNITM Asc
  Else
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0 Order By [F:SRN]CPNITM Asc
  Endif
  For [SRN]
    If [F:SRN]CPNCOVSPT > 0 Then
      ICOVSPTARR([F:SRN]CPNCOVSPT-1) += 1
      INBCONTROL += 1
    Endif
    If [F:SRN]CPNCOVFLG <> 1 Then
      IALLCOVER = 0
      Break
    Endif
  Next
  Filter [SRN]
  If ILINEFLG Then
    If [M:SRE7]COVFLG(INOL) <> 1 Then
      IALLCOVER = 0
    Endif
  Else
    If [M:SRE7]NBMAC = 0 Then
      End
    Endif
  Endif
  If IALLCOVER Then
    For ITER = 0 To dim(ICOVSPTARR)-1
      If ICOVSPTARR(ITER) > 1 Then
        If ICOVSPTARR(ITER) = INBCONTROL Then
          Case ITER
            When 0
              [M:SRE2]OVRCOV = 1
              IWHOLECOVF = 1
            When 1
              [M:SRE2]OVRCOV = 5
              IWHOLECOVF = 1
            When 2
              [M:SRE2]OVRCOV = 6
              IWHOLECOVF = 1
            When 3
              [M:SRE2]OVRCOV = 7
              IWHOLECOVF = 1
            When 4
              [M:SRE2]OVRCOV = 1
              IWHOLECOVF = 1
          Endcase
        Endif
      Endif
    Next
    If INBCONTROL = 0 Then
      IWHOLECOVF = 1
    Endif
    [M:SRE2]OVRCOVTYP = ""
    [M:SRE2]SRECOVAUT = 1
    [M:SRE2]SRECOVAUS = ""
    [M:SRE2]COVAUSCLA = ""
    [M:SRE2]SRECOVCTL = ""
    [M:SRE2]CONSPT = ""
    [M:SRE2]CONSPTTYP = ""
    [M:SRE2]CONSPTCLA = ""
    If IWHOLECOVF = 0 Then
      [M:SRE2]SRECOVNUM = ""
      [M:SRE2]OVRCOV = 1
      Gosub COMPLEXMG From TRTCOVERB
      [M:SRE2]CONSPTFLG = 0
      [M:SRE2]MANUPD = 1
      #Obtient le niveau de réactivité SAV.
      Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0,  [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
      Gosub AFFSRE2MIS From SUBSREB2
      End
    Endif
    #Contrat support
    For ITER = 0 To [M:SRE7]NBMAC-1
      If [M:SRE7]COVSPT(ITER) = 1 or [M:SRE7]COVSPT(ITER) = 5 Then
        [M:SRE2]CONSPT = [M:SRE7]COVVCR(ITER)
        If [M:SRE7]COVSPT(ITER) = 1 Then
          [M:SRE2]CONSPTTYP = "CON"
        Elsif [M:SRE7]COVSPT(ITER) = 5 Then
          [M:SRE2]CONSPTTYP = "COT"
        Endif
        [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement.
        Break
      Endif
    Next
    If ILINEFLG Then
      If [M:SRE2]CONSPT = "" Then
        If [M:SRE7]COVSPT(INOL) = 1 or [M:SRE7]COVSPT(INOL) = 5 Then
          [M:SRE2]CONSPT = [M:SRE7]COVVCR(INOL)
          If [M:SRE7]COVSPT(INOL) = 1 Then
            [M:SRE2]CONSPTTYP = "CON"
          Elsif [M:SRE7]COVSPT(INOL) = 5 Then
            [M:SRE2]CONSPTTYP = "COT"
          Endif
          [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement.
        Endif
      Endif
    Endif
    #Contrat couvrant
    #Parc
    ITER2 = 0
    SZFIRCON = ""
    IMUSTEMPTY = 0
    For ITER = 0 To [M:SRE7]NBMAC-1
      If [M:SRE7]COVFLG(ITER) <> 3 Then
        If ITER2 = 0 Then
          SZFIRCON = [M:SRE7]COVVCR(ITER)
        Else
          If [M:SRE7]COVVCR(ITER) <> SZFIRCON Then
            IMUSTEMPTY = 1
            Break
          Endif
        Endif
        ITER2 += 1
      Endif
    Next
    #Composants classe M
    If IMUSTEMPTY = 0 Then
      For ITER = 0 To [M:SRE7]NBCPN-1
        If [M:SRE7]CPNCOVFLG(ITER) <> 3 Then
          If [M:SRE7]CPNCOVVCR(ITER) <> SZFIRCON Then
            IMUSTEMPTY = 1
            Break
          Endif
        Endif
      Next
    Endif
    #Composants classe F
    If IMUSTEMPTY = 0 Then
      If GREP = "C" Then
        Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0 Order By [F:SRN]CPNITM Asc
      Else
        Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0 Order By [F:SRN]CPNITM Asc
      Endif
      For [SRN]
        If [F:SRN]CPNCOVFLG <> 3 Then
          If [F:SRN]CPNCOVVCR <> SZFIRCON Then
            IMUSTEMPTY = 1
            Break
          Endif
        Endif
      Next
      Filter [SRN]
    Endif
    If !IMUSTEMPTY Then
      If ILINEFLG Then
        If [M:SRE7]COVFLG(INOL) <> 3 Then
          If [M:SRE7]NBMAC Then
            If [M:SRE7]COVVCR(INOL) <> SZFIRCON Then
              IMUSTEMPTY = 1
            Endif
          Endif
        Endif
      Endif
    Endif
    If IMUSTEMPTY Then
      [M:SRE2]SRECOVNUM = ""
      [M:SRE2]OVRCOVTYP = ""
    Else
      If ILINEFLG Then
        [M:SRE2]SRECOVNUM = [M:SRE7]COVVCR(INOL)
        [M:SRE2]OVRCOVTYP = ""
        If [M:SRE7]COVSPT(INOL) = 1 Then
          [M:SRE2]OVRCOVTYP = "CON"
        Elsif [M:SRE7]COVSPT(INOL) = 5 Then
          [M:SRE2]OVRCOVTYP = "COT"
        Endif
      Else
        For ITER = 0 To [M:SRE7]NBMAC-1
          If [M:SRE7]COVFLG(ITER) <> 3 Then
            If [M:SRE7]COVVCR(ITER) <> "" Then
              [M:SRE2]SRECOVNUM = [M:SRE7]COVVCR(INOL)
              [M:SRE2]OVRCOVTYP = ""
              If [M:SRE7]COVSPT(INOL) = 1 Then
                [M:SRE2]OVRCOVTYP = "CON"
              Elsif [M:SRE7]COVSPT(INOL) = 5 Then
                [M:SRE2]OVRCOVTYP = "COT"
              Endif
              Break
            Endif
          Endif
        Next
      Endif
    Endif
    [M:SRE2]CONSPTFLG = 0
    [M:SRE2]MANUPD = 1
    #Obtient le niveau de réactivité SAV.
    Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
    Gosub AFFSRE2MIS From SUBSREB2
    End
  Endif
  IALLCOVER = 1
  #Détermine si la demande est non couverte
  #Parc
  For ITER = 0 To [M:SRE7]NBMAC-1
    If [M:SRE7]COVFLG(ITER) <> 3 Then
      IALLCOVER = 0
      Break
    Endif
  Next
  #Composants classe M
  If IALLCOVER = 1 Then
    For ITER = 0 To [M:SRE7]NBCPN-1
      If [M:SRE7]CPNCOVFLG(ITER) <> 3 Then
        IALLCOVER = 0
        Break
      Endif
    Next
  Endif
  #Composants classe F
  If IALLCOVER = 1 Then
    If GREP = "C" Then
      Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0 Order By [F:SRN]CPNITM Asc
    Else
      Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0 Order By [F:SRN]CPNITM Asc
    Endif
    For [SRN]
      If [F:SRN]CPNCOVFLG <> 3 Then
        IALLCOVER = 0
        Break
      Endif
    Next
    Filter [SRN]
  Endif
  If ILINEFLG Then
    If [M:SRE7]COVFLG(INOL) <> 3 Then
      IALLCOVER = 0
    Endif
  Else
    If [M:SRE7]NBMAC = 0 Then
      End
    Endif
  Endif
  If IALLCOVER Then
    [M:SRE2]OVRCOV = 3
    [M:SRE2]SRECOVNUM = ""
    [M:SRE2]OVRCOVTYP = ""
    [M:SRE2]SRECOVAUT = 1
    [M:SRE2]SRECOVAUS = ""
    [M:SRE2]COVAUSCLA = ""
    [M:SRE2]SRECOVCTL = ""
    [M:SRE2]CONSPT = ""
    [M:SRE2]CONSPTTYP = ""
    [M:SRE2]CONSPTCLA = ""
    [M:SRE2]CONSPTFLG = 0
    [M:SRE2]MANUPD = 1
    #Obtient le niveau de réactivité SAV.
    Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
  Else
    [M:SRE2]OVRCOV = 2
    [M:SRE2]SRECOVAUT = 1
    [M:SRE2]SRECOVAUS = ""
    [M:SRE2]COVAUSCLA = ""
    [M:SRE2]SRECOVCTL = ""
    #Contrat support
    For ITER = 0 To [M:SRE7]NBMAC-1
      If [M:SRE7]COVFLG(ITER) <> 3 Then
        If [M:SRE7]COVSPT(ITER) = 1 Then
          [M:SRE2]CONSPT = [M:SRE7]COVVCR(ITER)
          [M:SRE2]CONSPTTYP = "CON"
          [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement.
          Break
        Elsif [M:SRE7]COVSPT(ITER) = 5 Then
          [M:SRE2]CONSPT = [M:SRE7]COVVCR(ITER)
          [M:SRE2]CONSPTTYP = "COT"
          [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement.
          Break
        Endif
      Endif
    Next
    If ILINEFLG Then
      If [M:SRE2]CONSPT = "" Then
        If [M:SRE7]COVFLG(INOL) <> 3 Then
          If [M:SRE7]COVSPT(INOL) = 1 Then
            [M:SRE2]CONSPT = [M:SRE7]COVVCR(INOL)
            [M:SRE2]CONSPTTYP = "CON"
            [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement.
          Elsif [M:SRE7]COVSPT(INOL) = 5 Then
            [M:SRE2]CONSPT = [M:SRE7]COVVCR(INOL)
            [M:SRE2]CONSPTTYP = "COT"
            [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement.
          Endif
        Endif
      Endif
    Endif
    If [M:SRE2]CONSPT = "" Then
      [M:SRE2]CONSPTCLA = ""
    Else
      [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement.
    Endif
    #Contrat couvrant
    ITER2 = 0
    SZFIRCON = ""
    IMUSTEMPTY = 0
    #Parc
    For ITER = 0 To [M:SRE7]NBMAC-1
      If [M:SRE7]COVFLG(ITER) <> 3 Then
        If ITER2 = 0 Then
          SZFIRCON = [M:SRE7]COVVCR(ITER)
        Else
          If [M:SRE7]COVVCR(ITER) <> SZFIRCON Then
            IMUSTEMPTY = 1
          Endif
        Endif
        ITER2 += 1
      Endif
    Next
    #Composants classe M
    If IMUSTEMPTY = 0 Then
      For ITER = 0 To [M:SRE7]NBCPN-1
        If [M:SRE7]CPNCOVFLG(ITER) <> 3 Then
          If [M:SRE7]CPNCOVVCR(ITER) <> SZFIRCON Then
            IMUSTEMPTY = 1
            Break
          Endif
        Endif
      Next
    Endif
    #Composants classe F
    If IMUSTEMPTY = 0 Then
      If GREP = "C" Then
        Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0 Order By [F:SRN]CPNITM Asc
      Else
        Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0 Order By [F:SRN]CPNITM Asc
      Endif
      For [SRN]
        If [F:SRN]CPNCOVFLG <> 3 Then
          If [F:SRN]CPNCOVVCR <> SZFIRCON Then
            IMUSTEMPTY = 1
            Break
          Endif
        Endif
      Next
      Filter [SRN]
    Endif
    If !IMUSTEMPTY Then
      If ILINEFLG Then
        If [M:SRE7]COVFLG(INOL) <> 3 Then
          If [M:SRE7]NBMAC Then
            If [M:SRE7]COVVCR(INOL) <> SZFIRCON Then
              IMUSTEMPTY = 1
            Endif
          Endif
        Endif
      Endif
    Endif
    If IMUSTEMPTY Then
      [M:SRE2]SRECOVNUM = ""
      [M:SRE2]OVRCOVTYP = ""
    Else
      If ILINEFLG Then
        [M:SRE2]SRECOVNUM = [M:SRE7]COVVCR(INOL)
        If [M:SRE7]COVSPT(INOL) = 1 Then
          [M:SRE2]OVRCOVTYP = "CON"
        Elsif [M:SRE7]COVSPT(INOL) = 5 Then
          [M:SRE2]OVRCOVTYP = "COT"
        Endif
      Else
        For ITER = 0 To [M:SRE7]NBMAC-1
          If [M:SRE7]COVFLG(ITER) <> 3 Then
            If [M:SRE7]COVVCR(ITER) <> "" Then
              [M:SRE2]SRECOVNUM = [M:SRE7]COVVCR(INOL)
              If [M:SRE7]COVSPT(INOL) = 1 Then
                [M:SRE2]OVRCOVTYP = "CON"
              Elsif [M:SRE7]COVSPT(INOL) = 5 Then
                [M:SRE2]OVRCOVTYP = "COT"
              Endif
              Break
            Endif
          Endif
        Next
      Endif
    Endif
    [M:SRE2]CONSPTFLG = 0
    [M:SRE2]MANUPD = 1
    #Obtient le niveau de réactivité SAV.
    Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
  Endif
  [M:SRE2]OVRCOVCLA = ""
  [M:SRE2]OVRCOVREN = 0
  Gosub AFFSRE2MIS From SUBSREB2
End

##########################################################################################################
# Détermine le statut de couverture globale d'une demande de service en classe écran
###########################################################################
Subprog COVERMGC(INOL)
Value Integer INOL

  Call COVERMGCB(INOL) From TRTCOVERB
End

##########################################################################################################
# Met à jour la couverture globale sur la base d'une nouvelle couverture de composant.
#######################################################
$SETCPNOVRCOV
Local Integer ITER
Local Integer ITER2
Local Char SZFIRCON
Local Char SZMACCOVNUM
Local Integer IMUSTEMPTY

  SZMACCOVNUM = ""
  ITER2 = 0
  SZFIRCON = ""
  IMUSTEMPTY = 0
  If [M:SRE7]CPNCOVVCR(INOL) = "" Then
    [M:SRE2]SRECOVNUM = ""
    [M:SRE2]OVRCOVTYP = ""
  Else
    #Contrat couvrant
    ITER2 = 0
    SZFIRCON = ""
    IMUSTEMPTY = 0
    For ITER = 0 To [M:SRE7]NBMAC-1
      If [M:SRE7]COVFLG(ITER) <> 3 Then
        If ITER2 = 0 Then
          SZFIRCON = [M:SRE7]COVVCR(ITER)
        Else
          If [M:SRE7]COVVCR(ITER) <> SZFIRCON Then
            IMUSTEMPTY = 1
          Endif
        Endif
        ITER2 += 1
      Endif
    Next
    If !IMUSTEMPTY Then
      For ITER = 0 To [M:SRE7]NBMAC-1
        If [M:SRE7]COVFLG(ITER) <> 3 Then
          If [M:SRE7]COVVCR(ITER) <> "" Then
            SZMACCOVNUM = [M:SRE7]COVVCR(INOL)
            Break
          Endif
        Endif
      Next
    Endif
    If IMUSTEMPTY Then
      [M:SRE2]SRECOVNUM = ""
      [M:SRE2]OVRCOVTYP = ""
    Else
      If SZMACCOVNUM = [M:SRE7]CPNCOVVCR(INOL) Then
        [M:SRE2]SRECOVNUM = [M:SRE7]CPNCOVVCR(INOL)
        If [M:SRE7]CPNCOVSPT(INOL) = 1 Then
          [M:SRE2]OVRCOVTYP = "CON"
        Elsif [M:SRE7]CPNCOVSPT(INOL) = 5 Then
          [M:SRE2]OVRCOVTYP = "COT"
        Endif
      Else
        [M:SRE2]SRECOVNUM = ""
        [M:SRE2]OVRCOVTYP = ""
      Endif
    Endif
  Endif
  [M:SRE2]SRECOVAUT = 1
  [M:SRE2]SRECOVAUS = ""
  [M:SRE2]COVAUSCLA = ""
  [M:SRE2]SRECOVCTL = ""
  If [M:SRE2]CONSPT = "" Then
    [M:SRE2]CONSPT = [M:SRE7]CPNCOVVCR(INOL)
    If [M:SRE7]CPNCOVSPT(INOL) = 1 Then
      [M:SRE2]CONSPTTYP = "CON"
    Elsif [M:SRE7]CPNCOVSPT(INOL) = 5 Then
      [M:SRE2]CONSPTTYP = "COT"
    Endif
    If [M:SRE7]CPNCOVVCR(INOL) = "" Then
      [M:SRE2]CONSPTCLA = ""
    Else
      [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement.
    Endif
    [M:SRE2]CONSPTFLG = 0
    [M:SRE2]MANUPD = 1
    #Obtient le niveau de réactivité SAV.
    Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
  Endif
Return

##########################################################################################################
# Détermine si toute le reste d'une demande de service est totalement couvert.
###########################################################
Subprog CHECKFULLCOV(INOL, IFULLCOV)
Value Integer INOL
Variable Integer IFULLCOV

Local Integer ITER

  IFULLCOV = 1
  #Tableau du parc
  For ITER = 0 To [M:SRE7]NBMAC-1
    If [M:SRE7]COVFLG <> 1 Then
      IFULLCOV = 0
      Break
    Endif
  Next
  If !IFULLCOV Then
    End
  Endif
  #Autres composants
  #Ecran
  For ITER = 0 To [M:SRE7]NBCPN-1
    If ITER <> INOL Then
      If [M:SRE7]CPNCOVFLG <> 1 Then
        IFULLCOV = 0
        Break
      Endif
    Endif
  Next
  If !IFULLCOV Then
    End
  Endif
  #Fichier
  If GREP = "C" Then
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0 and [F:SRN]MACNUM <> [M:SRE7]MAC([M:SRE7]PRESRE7NOL)
  Elsif GREP = "D" Then
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0 and [F:SRN]MACNUM <> [M:SRE7]MAC([M:SRE7]PRESRE7NOL)
  Else
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0 and [F:SRN]MACNUM <> [M:SRE7]MAC([M:SRE7]PRESRE7NOL)
  Endif
  For [SRN]
    If [F:SRN]CPNCOVFLG <> 1 Then
      IFULLCOV = 0
      Break
    Endif
  Next
  Filter [SRN]
End

##########################################################################################################
# Contrôle de l'affichage des messages
###########################################################
Subprog CHECKCOVMEE(IMEE)
Value Integer IMEE

Local Integer ITER
Local Integer IDISP

  If IMEE < 0 Then
    IMEE = abs(IMEE)
    GERR = 1
    GMESSAGE = mess(IMEE,182,1)
    End
  Else
    If GCOVPROMPT = 2 Then
      GERR = 2
    Else
      GERR = 4
    Endif
  Endif
  #Détecte si le même message n'a pas déjà été affiché
  IDISP = 0
  For ITER = 0 To dim([M:SRE0]COVMEE)-1
    If [M:SRE0]COVMEE(ITER) = IMEE Then
      GERR = 0
      GMESSAGE = ""
      IDISP = 1
      Break
    Endif
  Next
  If !IDISP Then
    #Enregistrement du message à afficher
    For ITER = 0 To dim([M:SRE0]COVMEE)-1
      If [M:SRE0]COVMEE(ITER) = 0 Then
        [M:SRE0]COVMEE(ITER) = IMEE
        Break
      Endif
    Next
    #GMESSAGE = mess(IMEE,178,1)  # Issue X3-58793 - 2017-10-23 by FGR
    GMESSAGE -= mess(IMEE,178,1)  # Issue X3-58793 - 2017-10-23 by FGR
  Endif
  #On réinitialise la barre d'état.
  If GCOVPROMPT <> 2 Then
    If GMESSAGE = "" Then
      GERR = 4
      GMESSAGE = "."
    Endif
  Endif
End

##########################################################################################################
# Suppression de la mémoire d'un message
###########################################################
Subprog RAZCOVMEE(IMEE)
Value Integer IMEE

Local Integer ITER

  If IMEE > 0 Then
    Raz [M:SRE0]CURCOVMEE
    For ITER = 0 To dim([M:SRE0]COVMEE)-1
      If [M:SRE0]COVMEE(ITER) = IMEE Then
        [M:SRE0]COVMEE(ITER) = 0
      Endif
    Next
  Else
    Raz [M:SRE0]COVMEE
    Raz [M:SRE0]CURCOVMEE
    Raz [M:SRE2]OVRCOV
    Raz [M:SRE2]OVRCOVREN
    Raz [M:SRE2]OVRCOVCLA
  Endif
End

##########################################################################################################
# Réalise le contrôle d'en-cours client
###########################################################
Subprog CHECKOST(SZBPCCOD)
Value Char SZBPCCOD

Local Decimal DCBXOST

  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:MVC]) : Local File BPCUSTMVT [MVC] : Endif
  If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif
  Read [BPC]BPC0=SZBPCCOD
  If fstat Then
    #Erreur lors de la lecture du client.
    #L'analyse de la couverture n'a pu être effectué.
    [M:SRE0]CURCOVMEE = -518
  Else
    # FGR 09/07/2009 : X3SUIVI56413 (début)
    If [F:BPC]OSTCTL = 2 Then
      # Contrôle client libre
      [M:SRE2]OVRCOV = 1
    Elsif [F:BPC]OSTCTL = 3 Then
      # Contrôle client bloqué
      [M:SRE0]CURCOVMEE = 2 # Client bloqué. (ça c'est la situation du client, après on fait selon les paramètres)
      If GCOVOST = 2 Then
        # Paramètre COVOSTCTL : Ce paramètre général permet de décider si les clients bloqués peuvent bénéficier d'une couverture des demandes de service
        [M:SRE2]OVRCOV = 1
      Else
        [M:SRE2]OVRCOV = 3
        [M:SRE2]OVRCOVREN = 2
        [M:SRE2]OVRCOVCLA = mess(2,178,1) #Client bloqué
        [M:SRE2]SRECOVNUM = ""
        [M:SRE2]SRECOVAUT = 1
        [M:SRE2]SRECOVAUS = ""
        [M:SRE2]COVAUSCLA = ""
        [M:SRE2]SRECOVCTL = ""
        [M:SRE2]CONSPT = ""
        [M:SRE2]CONSPTCLA = ""
        [M:SRE2]CONSPTFLG = 0
        [M:SRE2]MANUPD = 1
        #Obtient le niveau de réactivité SAV.
        Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
      Endif
    Else
      # Contrôle en-cours (ON NE VIENT LA QUE SI LE CLIENT EST CONTROLE AU NIVEAU DE L'EN-COURS)
      DCBXOST = 0
      Call CALENC([F:BPC]BPCRSK, datesyst, DCBXOST) From TRTBPMVT
      If DCBXOST > [F:BPC]OSTAUZ Then
        [M:SRE0]CURCOVMEE = 3 # L'en-cours autorisé du client est dépassé. (ça c'est la situation du client, après on fait selon les paramètres)
        If GCOVOVF = 2 Then
          # Paramètre COVOSTOVF : Ce paramètre général permet de décider si les clients en dépassement d'en-cours autorisé, peuvent bénéficier d'une couverture des demandes de service
          [M:SRE2]OVRCOV = 1
        Else
          [M:SRE2]OVRCOV = 3
          [M:SRE2]OVRCOVREN = 3
          [M:SRE2]OVRCOVCLA = mess(3,178,1) #L'en-cours autorisé du client est dépassé.
          [M:SRE2]SRECOVNUM = ""
          [M:SRE2]SRECOVAUT = 1
          [M:SRE2]SRECOVAUS = ""
          [M:SRE2]COVAUSCLA = ""
          [M:SRE2]SRECOVCTL = ""
          [M:SRE2]CONSPT = ""
          [M:SRE2]CONSPTCLA = ""
          [M:SRE2]CONSPTFLG = 0
          [M:SRE2]MANUPD = 1
          #Obtient le niveau de réactivité SAV.
          Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
        Endif
      Else
        [M:SRE2]OVRCOV = 1
      Endif
    Endif
    # FGR 09/07/2009 : X3SUIVI56413 (fin)
  Endif
End

##########################################################################################################
# Contrôle de la souscription d'au moins un contrat
###########################################################
Subprog CHKNBCON(SZBPCCOD, SZMACNUM, ILINEFLG, INOL)
Value Char SZBPCCOD
Value Char SZMACNUM
Value Integer ILINEFLG
Value Integer INOL

Local Integer INBCONREAD
Local Integer ILNDFLG

  # ------------------------------------------
  # Issue X3-74295 - 2018-04-05 by FGR : BEGIN
  Local Char SSPESPCALLER(GLONDES)

  SSPESPCALLER = "CHKNBCON"
  Gosub PE_CRITCON From TRTCRMPE
  # Issue X3-74295 - 2018-04-05 by FGR : END
  # ------------------------------------------
  INBCONREAD = 0
  ILNDFLG = 0
  If SZMACNUM <> "" Then
    Read [MAC]MAC0=SZMACNUM
    If !fstat Then
      If [F:MAC]MACITNLND = 2 Then
        ILNDFLG = 1
      Endif
    Endif
  Endif
  If ILNDFLG Then
    #Parc en prêt
    If [F:MAC]MACPDTCOD <> "" Then
      Read [ITM]ITM0=[F:MAC]MACPDTCOD
      If !fstat Then
        If [F:ITM]TPLCONLND <> "" Then
          INBCONREAD += 1
        Endif
      Endif
    Endif
  Else
    #Contrôle de la présence d'au moins un contrat
    # Issue X3-74295 - 2018-04-05 by FGR : BEGIN
    #Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2
    Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and evalue([L]SSPECRITCON)
    # Issue X3-74295 - 2018-04-05 by FGR : END
    Columns [CON] (CONNUM)
    For [CON] Hint Key CON4
      INBCONREAD += 1
      Break
    Next
    Filter [CON]
    Columns [CON]
  Endif
  If !INBCONREAD Then
    [M:SRE0]CURCOVMEE = 1
    If ILINEFLG = 1 Then
      #Parc
      [M:SRE7]COVFLG(INOL) = 3
      [M:SRE7]COVSPT(INOL) = 6
      [M:SRE7]COVVCR(INOL) = ""
      [M:SRE7]MACCOVCLA(INOL) = mess(1,178,1) #Aucun contrat souscrit
      [M:SRE7]MACCOVREN(INOL) = 1
    Elsif ILINEFLG = 2 Then
      #Composants
      [M:SRE7]CPNCOVFLG(INOL) = 3
      [M:SRE7]CPNCOVSPT(INOL) = 6
      [M:SRE7]CPNCOVVCR(INOL) = ""
      [M:SRE7]CPNCOVCLA(INOL) = mess(1,178,1) #Aucun contrat souscrit
      [M:SRE7]CPNCOVREN(INOL) = 1
    Endif
  Endif
End

##########################################################################################################
# Contrôle des couvertures compétences, parc et composant
###########################################################
Subprog CHECKCON(SZBPCCOD, SZPBLCOD, SZMACCOD, SZCONTEXT, INOL, IEVRCOV)
Value Char SZBPCCOD
Value Char SZPBLCOD
Value Char SZMACCOD
Value Char SZCONTEXT
Value Integer INOL
Variable Integer IEVRCOV

Local Integer IEXTERNALMAC
Local Integer INBCONREAD
Local Date DLNDENDDAT
Local Char SZCOVCASE
Local Char SZCOVVCR
Local Char SZCOVTYP
Local Integer IEVRPBL
Local Integer IEVRMAC
Local Integer IERR
Local Integer ILNDFLG

  # ------------------------------------------
  # Issue X3-74295 - 2018-04-05 by FGR : BEGIN
  Local Char SSPESPCALLER(GLONDES)

  SSPESPCALLER = "CHECKCON"
  Gosub PE_CRITCON From TRTCRMPE
  # Issue X3-74295 - 2018-04-05 by FGR : END
  # ------------------------------------------
  SZCOVCASE = ""
  IEVRCOV = 0
  IEVRPBL = 0
  IEVRMAC = 0
  INBCONREAD = 0
  SZCOVVCR = ""
  IERR = 0
  ILNDFLG = 0
  SZCOVTYP = ""
  IEXTERNALMAC = 0
  #On détermine le cas à traiter
  If SZPBLCOD = "" Then
    If SZMACCOD = "" Then
      SZCOVCASE = "00"
    Else
      SZCOVCASE = "01"
    Endif
  Else
    If SZMACCOD = "" Then
      SZCOVCASE = "10"
    Else
      SZCOVCASE = "11"
    Endif
  Endif
  #Parc en prêt
  If SZMACCOD <> "" Then
    Read [MAC]MAC0=SZMACCOD
    If !fstat Then
      If [F:MAC]MACITNLND = 2 Then
        ILNDFLG = 1
      Endif
      If [F:MAC]BPCNUM <> "" Then
        If SZBPCCOD <> "" Then
          If [F:MAC]BPCNUM <> SZBPCCOD Then
            IEXTERNALMAC = 1
          Endif
        Endif
      Endif
    Endif
  Endif
  SZCOVTYP = "CON"
  #Recherche de contrats classiques
  Case SZCOVCASE
    When "00"
      # Issue X3-74295 - 2018-04-05 by FGR : BEGIN
      #Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONCAT <> 4
      Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONCAT <> 4 and evalue([L]SSPECRITCON)
      # Issue X3-74295 - 2018-04-05 by FGR : END
    When "01"
      # Issue X3-74295 - 2018-04-05 by FGR : BEGIN
      #Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONCAT <> 4 and [F:CON]EVRMAC = 2
      Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONCAT <> 4 and [F:CON]EVRMAC = 2 and evalue([L]SSPECRITCON)
      # Issue X3-74295 - 2018-04-05 by FGR : END
    When "10"
      # Issue X3-74295 - 2018-04-05 by FGR : BEGIN
      #Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONCAT <> 4 and [F:CON]EVRPBL = 2
      Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONCAT <> 4 and [F:CON]EVRPBL = 2 and evalue([L]SSPECRITCON)
      # Issue X3-74295 - 2018-04-05 by FGR : END
    When "11"
      # Issue X3-74295 - 2018-04-05 by FGR : BEGIN
      #Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONCAT <> 4 and [F:CON]EVRMAC = 2 and [F:CON]EVRPBL = 2
      Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONCAT <> 4 and [F:CON]EVRMAC = 2 and [F:CON]EVRPBL = 2 and evalue([L]SSPECRITCON)
      # Issue X3-74295 - 2018-04-05 by FGR : END
  Endcase
  #On recherche des contrats toutes compétences, tous articles.
  For [CON] Hint Key CON4
    INBCONREAD += 1
    Case SZCOVCASE
      When "00"
        If GSREDEFCOV = 1 Then
          If [F:CON]EVRMAC = 2 Then
            IEVRMAC = 1
          Endif
        Else
          IEVRMAC = 1
        Endif
        If GSREDEFCOV = 1 Then
          If [F:CON]EVRPBL = 2 Then
            IEVRPBL = 1
          Endif
        Else
          IEVRPBL = 1
        Endif
      When "01"
        IEVRMAC = 1
        If GSREDEFCOV = 1 Then
          If [F:CON]EVRPBL = 2 Then
            IEVRPBL = 1
          Endif
        Else
          IEVRPBL = 1
        Endif
      When "10"
        IEVRPBL = 1
        If GSREDEFCOV = 1 Then
          If [F:CON]EVRMAC = 2 Then
            IEVRMAC = 1
          Endif
        Else
          IEVRMAC = 1
        Endif
      When "11"
        IEVRMAC = 1
        IEVRPBL = 1
    Endcase
    If IEXTERNALMAC Then
      IEVRMAC = 0
    Endif
    If IEVRMAC = 1 Then
      If IEVRPBL = 1 Then
        #Contrôle de l'échéance
        If [F:CON]CONENDDAT < date$ Then
          [M:SRE0]CURCOVMEE = 4
        Else
          If [F:CON]CONSTRDAT > date$ Then
            [M:SRE0]CURCOVMEE = 11
          Else
            #Contrôle du réglement du contrat
            SZLITCOD = ""
            Call CHECKPAY([F:CON]CONNUM, [F:CON]CONBPC, SZLITCOD, IEVRCOV)
            If IEVRCOV Then
              SZCOVVCR = [F:CON]CONNUM
              Break
            Else
              #Contrôle de l'existence d'un code litige accepté
              Call CHECKLIT([F:CON]CONNUM, SZLITCOD, 0, IEVRCOV)
              If IEVRCOV Then
                SZCOVVCR = [F:CON]CONNUM
                Break
              Else
                [M:SRE0]CURCOVMEE = 5
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [CON]
  If IEVRCOV Then
    #Tout est couvert
    Case SZCONTEXT
      When "SRE"
        Call FULLCOVSRE(SZCOVVCR, SZCOVTYP, IERR)
      When "MAC"
        Call FULLCOVMAC(SZCOVVCR, SZCOVTYP, INOL, IERR)
      When "CPN"
        Call FULLCOVCPN(SZCOVVCR, SZCOVTYP, INOL, IERR)
    Endcase
    If IERR Then
      #Erreur lors de la couverture complète de la demande de service. Le contrôle de couverture est abandonné.
      [M:SRE0]CURCOVMEE = -IERR
    Endif
    End
  Endif
  #Contrat de prêt
  If ILNDFLG Then
    #Parc en prêt
    SZCOVTYP = "COT"
    Read [ITM]ITM0=[F:MAC]MACPDTCOD
    If !fstat Then
      If [F:ITM]TPLCONLND <> "" Then
        Read [COT]COT0=[F:ITM]TPLCONLND
        If !fstat Then
          INBCONREAD += 1
          Case SZCOVCASE
            When "01"
              If [F:COT]EVRMAC = 2 Then
                IEVRMAC = 1
              Endif
              If GSREDEFCOV = 1 Then
                If [F:COT]EVRPBL = 2 Then
                  IEVRPBL = 1
                Endif
              Else
                IEVRPBL = 1
              Endif
            When "10"
              If [F:COT]EVRPBL = 2 Then
                IEVRPBL = 1
              Endif
              If GSREDEFCOV = 1 Then
                If [F:COT]EVRMAC = 2 Then
                  IEVRMAC = 1
                Endif
              Else
                IEVRMAC = 1
              Endif
            When "11"
              If [F:COT]EVRMAC = 2 Then
                IEVRMAC = 1
              Endif
              If [F:COT]EVRPBL = 2 Then
                IEVRPBL = 1
              Endif
          Endcase
          If IEVRMAC = 1 Then
            If IEVRPBL = 1 Then
              #Contrôle de l'échéance
              If [F:MAC]MACITNDAT <> [00/00/00] Then
                Call SETENDDAT([F:MAC]MACITNDAT, [F:COT]REWFRY, [F:COT]REWFRYBAS, DLNDENDDAT) From SUBCOND
                If DLNDENDDAT < date$ Then
                  [M:SRE0]CURCOVMEE = 4
                Else
                  IEVRCOV = 1
                  SZCOVVCR = [F:COT]CONNUM
                Endif
              Else
                IEVRCOV = 1
                SZCOVVCR = [F:COT]CONNUM
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
    If IEVRCOV Then
      #Tout est couvert
      Case SZCONTEXT
        When "SRE"
          Call FULLCOVSRE(SZCOVVCR, SZCOVTYP, IERR)
        When "MAC"
          Call FULLCOVMAC(SZCOVVCR, SZCOVTYP, INOL, IERR)
        When "CPN"
          Call FULLCOVCPN(SZCOVVCR, SZCOVTYP, INOL, IERR)
      Endcase
      If IERR Then
        #Erreur lors de la couverture complète de la demande de service. Le contrôle de couverture est abandonné.
        [M:SRE0]CURCOVMEE = -IERR
      Endif
      End
    Endif
  Endif
  If SZCOVCASE = "00" Then
    If INBCONREAD Then
      [M:SRE2]OVRCOV = 3
      [M:SRE2]OVRCOVTYP = ""
      If [M:SRE0]CURCOVMEE > 0 Then
        [M:SRE2]OVRCOVREN = [M:SRE0]CURCOVMEE
        [M:SRE2]OVRCOVCLA = mess([M:SRE0]CURCOVMEE,178,1)
      Else
        [M:SRE2]OVRCOVREN = 0
        [M:SRE2]OVRCOVCLA = ""
      Endif
      [M:SRE2]SRECOVNUM = ""
      [M:SRE2]SRECOVAUT = 1
      [M:SRE2]SRECOVAUS = ""
      [M:SRE2]COVAUSCLA = ""
      [M:SRE2]SRECOVCTL = ""
      [M:SRE2]CONSPT = ""
      [M:SRE2]CONSPTTYP = ""
      [M:SRE2]CONSPTCLA = ""
      [M:SRE2]CONSPTFLG = 0
      [M:SRE2]MANUPD = 1
      #Obtient le niveau de réactivité SAV.
      Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
    Endif
    End
  Endif
End

##########################################################################################################
# Couverture totale d'une demande de service
###########################################################
Subprog FULLCOVSRE(SZCOVVCR, SZCOVTYP, IPBL)
Value Char SZCOVVCR
Value Char SZCOVTYP
Variable Integer IPBL

Local Integer ITER
Local Integer ICREFLG

  ICREFLG = 0
  IPBL = 0
  If GREP = "C" Then
    ICREFLG = 1
  Elsif GREP = "D" Then
    ICREFLG = 1
  Else
    ICREFLG = 0
  Endif
  #Couverture globale
  [M:SRE2]OVRCOV = 1
  [M:SRE2]OVRCOVTYP = SZCOVTYP
  [M:SRE2]OVRCOVREN = 0
  [M:SRE2]OVRCOVCLA = ""
  [M:SRE2]SRECOVNUM = SZCOVVCR
  [M:SRE2]SRECOVAUT = 1
  [M:SRE2]SRECOVAUS = ""
  [M:SRE2]COVAUSCLA = ""
  [M:SRE2]SRECOVCTL = ""
  [M:SRE2]CONSPT = SZCOVVCR
  [M:SRE2]CONSPTTYP = SZCOVTYP
  [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement
  [M:SRE2]CONSPTFLG = 0
  [M:SRE2]MANUPD = 1
  #Obtient le niveau de réactivité SAV.
  Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
  #Parc
  For ITER = 0 To [M:SRE7]NBMAC-1
    [M:SRE7]COVFLG(ITER) = 1
    If SZCOVTYP = "CON" Then
      [M:SRE7]COVSPT(ITER) = 1
    Elsif SZCOVTYP = "COT" Then
      [M:SRE7]COVSPT(ITER) = 5
    Endif
    [M:SRE7]COVVCR(ITER) = SZCOVVCR
    [M:SRE7]MACCOVCLA(ITER) = ""
    [M:SRE7]MACCOVREN(ITER) = 0
  Next
  #Composants
  Call DEBTRANS From GLOCK
  Trbegin [SRN]
  If ICREFLG Then
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
  Else
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0
  Endif
  For [SRN]
    [F:SRN]CPNCOVFLG = 1
    If SZCOVTYP = "CON" Then
      [F:SRN]CPNCOVSPT = 1
    Elsif SZCOVTYP = "COT" Then
      [F:SRN]CPNCOVSPT = 5
    Endif
    [F:SRN]CPNCOVVCR = SZCOVVCR
    [F:SRN]CPNCOVREN = 0
    Rewrite [F:SRN]
    If fstat Then
      IPBL = 520
      Break
    Endif
  Next
  Filter [SRN]
  If IPBL Then
    Rollback
  Else
    Commit
  Endif
  For ITER = 0 To [M:SRE7]NBCPN-1
    [M:SRE7]CPNCOVFLG(ITER) = 1
    If SZCOVTYP = "CON" Then
      [M:SRE7]CPNCOVSPT(ITER) = 1
    Elsif SZCOVTYP = "COT" Then
      [M:SRE7]CPNCOVSPT(ITER) = 5
    Endif
    [M:SRE7]CPNCOVVCR(ITER) = SZCOVVCR
    [M:SRE7]CPNCOVCLA(ITER) = ""
    [M:SRE7]CPNCOVREN(ITER) = 0
  Next
End

##########################################################################################################
# Couverture totale d'une ligne de parc concerné
###########################################################
Subprog FULLCOVMAC(SZCOVVCR, SZCOVTYP, INOL, IPBL)
Value Char SZCOVVCR
Value Char SZCOVTYP
Value Integer INOL
Variable Integer IPBL

Local Integer ITER
Local Integer ICREFLG

  ICREFLG = 0
  IPBL = 0
  If GREP = "C" Then
    ICREFLG = 1
  Elsif GREP = "D" Then
    ICREFLG = 1
  Else
    ICREFLG = 0
  Endif
  [M:SRE7]COVFLG(INOL) = 1
  If SZCOVTYP = "CON" Then
    [M:SRE7]COVSPT(INOL) = 1
  Elsif SZCOVTYP = "COT" Then
    [M:SRE7]COVSPT(INOL) = 5
  Endif
  [M:SRE7]COVVCR(INOL) = SZCOVVCR
  [M:SRE7]MACCOVCLA(INOL) = ""
  [M:SRE7]MACCOVREN(INOL) = 0
  #Composants
  Call DEBTRANS From GLOCK
  Trbegin [SRN]
  If ICREFLG Then
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0 and [F:SRN]MACNUM = [M:SRE7]MAC(INOL)
  Else
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0 and [F:SRN]MACNUM = [M:SRE7]MAC(INOL)
  Endif
  For [SRN]
    [F:SRN]CPNCOVFLG = 1
    If SZCOVTYP = "CON" Then
      [F:SRN]CPNCOVSPT = 1
    Elsif SZCOVTYP = "COT" Then
      [F:SRN]CPNCOVSPT = 5
    Endif
    [F:SRN]CPNCOVVCR = SZCOVVCR
    [F:SRN]CPNCOVREN = 0
    Rewrite [F:SRN]
    If fstat Then
      IPBL = 520
      Break
    Endif
  Next
  Filter [SRN]
  If IPBL Then
    Rollback
  Else
    Commit
  Endif
  For ITER = 0 To [M:SRE7]NBCPN-1
    [M:SRE7]CPNCOVFLG(ITER) = 1
    If SZCOVTYP = "CON" Then
      [M:SRE7]CPNCOVSPT(ITER) = 1
    Elsif SZCOVTYP = "COT" Then
      [M:SRE7]CPNCOVSPT(ITER) = 5
    Endif
    [M:SRE7]CPNCOVVCR(ITER) = SZCOVVCR
    [M:SRE7]CPNCOVCLA(ITER) = ""
    [M:SRE7]CPNCOVREN(ITER) = 0
  Next
End

##########################################################################################################
# Couverture totale d'une ligne de composant concerné
###########################################################
Subprog FULLCOVCPN(SZCOVVCR, SZCOVTYP, INOL, IPBL)
Value Char SZCOVVCR
Value Char SZCOVTYP
Value Integer INOL
Variable Integer IPBL

  [M:SRE7]CPNCOVFLG(INOL) = 1
  If SZCOVTYP = "CON" Then
    [M:SRE7]CPNCOVSPT(INOL) = 1
  Elsif SZCOVTYP = "COT" Then
    [M:SRE7]CPNCOVSPT(INOL) = 5
  Endif
  [M:SRE7]CPNCOVVCR(INOL) = SZCOVVCR
  [M:SRE7]CPNCOVCLA(INOL) = ""
  [M:SRE7]CPNCOVREN(INOL) = 0
End

##########################################################################################################
# Réinitialisation compléte de la couverture d'une demande de service
###########################################################
Subprog RAZCCV(IPBL)
Variable Integer IPBL

Local Integer ITER
Local Integer ICREFLG

  ICREFLG = 0
  IPBL = 0
  If GREP = "C" Then
    ICREFLG = 1
  Elsif GREP = "D" Then
    ICREFLG = 1
  Else
    ICREFLG = 0
  Endif
  #Couverture globale
  [M:SRE2]OVRCOV = 3
  [M:SRE2]OVRCOVTYP = ""
  [M:SRE2]OVRCOVREN = 0
  [M:SRE2]OVRCOVCLA = ""
  [M:SRE2]SRECOVNUM = ""
  [M:SRE2]SRECOVAUT = 1
  [M:SRE2]SRECOVAUS = ""
  [M:SRE2]COVAUSCLA = ""
  [M:SRE2]SRECOVCTL = ""
  [M:SRE2]CONSPT = ""
  [M:SRE2]CONSPTTYP = ""
  [M:SRE2]CONSPTCLA = ""
  [M:SRE2]CONSPTFLG = 0
  [M:SRE2]MANUPD = 1
  #Obtient le niveau de réactivité SAV.
  Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
  #Parc
  For ITER = 0 To [M:SRE7]NBMAC-1
    [M:SRE7]COVFLG(ITER) = 3
    [M:SRE7]COVSPT(ITER) = 6
    [M:SRE7]COVVCR(ITER) = ""
    If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
      # FGR 30/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
      [M:SRE7]PITMAC(ITER) = 0
    Endif
    [M:SRE7]MACCOVCLA(ITER) = ""
    [M:SRE7]MACCOVREN(ITER) = 0
  Next
  #Composants
  Call DEBTRANS From GLOCK
  Trbegin [SRN]
  If ICREFLG
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
  Else
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0
  Endif
  For [SRN]
    [F:SRN]CPNCOVFLG = 3
    [F:SRN]CPNCOVSPT = 6
    [F:SRN]CPNCOVVCR = ""
    [F:SRN]CPNCOVREN = 0
    Rewrite [F:SRN]
    If fstat Then
      #Erreur lors de la réinitialisation des informations de couverture. Le contrôle de couverture est abandonné.
      IPBL = 519
      Break
    Endif
  Next
  Filter [SRN]
  If IPBL Then
    Rollback
  Else
    Commit
  Endif
  For ITER = 0 To [M:SRE7]NBCPN-1
    [M:SRE7]CPNCOVFLG(ITER) = 3
    [M:SRE7]CPNCOVSPT(ITER) = 6
    [M:SRE7]CPNCOVVCR(ITER) = ""
    [M:SRE7]CPNCOVCLA(ITER) = ""
    [M:SRE7]CPNCOVREN(ITER) = 0
  Next
End

##########################################################################################################
# Réinitialisation de la couverture d'une ligne de parc concerné d'une demande de service
###########################################################
Subprog RAZCCVLINE(INOL, IERR)
Value Integer INOL
Variable Integer IERR

Local Integer ITER

  IERR = 0
  #Parc
  [M:SRE7]COVFLG(INOL) = 3
  [M:SRE7]COVSPT(INOL) = 6
  [M:SRE7]COVVCR(INOL) = ""
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 30/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    [M:SRE7]PITMAC(INOL) = 0
  Endif
  [M:SRE7]MACCOVCLA(INOL) = ""
  [M:SRE7]MACCOVREN(INOL) = 0
  #Composants
  If [M:SRE7]NBCPN > 0 Then
    For ITER = 0 To [M:SRE7]NBCPN-1
      Call RAZCPNLINE(INOL)
    Next
    #On fait la même chose en class F
    Trbegin [SRN]
    If GREP = "C" Then
      Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0 and [F:SRN]MACNUM = [M:SRE7]MAC(INOL)
    Elsif GREP = "D" Then
      Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0 and [F:SRN]MACNUM = [M:SRE7]MAC(INOL)
    Else
      Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0 and [F:SRN]MACNUM = [M:SRE7]MAC(INOL)
    Endif
    For [SRN]
      [F:SRN]CPNCOVFLG = 3
      [F:SRN]CPNCOVSPT = 6
      [F:SRN]CPNCOVVCR = ""
      [F:SRN]CPNCOVREN = 0
      Rewrite [SRN]
      If fstat Then
        #Erreur lors de la réinitialisation de la couverture des composants. Le contrôle de couverture est abandonné.
        IERR = 516
        Break
      Endif
    Next
    Filter [SRN]
    If IERR Then
      Rollback
      End
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
# Réinitialisation de la couverture d'une ligne de composant concerné d'une demande de service
###########################################################
Subprog RAZCPNLINE(INOL)
Value Integer INOL

  [M:SRE7]CPNCOVFLG(INOL) = 3
  [M:SRE7]CPNCOVSPT(INOL) = 6
  [M:SRE7]CPNCOVVCR(INOL) = ""
  [M:SRE7]CPNCOVCLA(INOL) = ""
  [M:SRE7]CPNCOVREN(INOL) = 0
End

##########################################################################################################
# Contrôle des couvertures composants
###########################################################
Subprog CHECKCCV(SZCONCODNUM, SZBPCCOD, ILINEFLG, INOL)
Value Char SZCONCODNUM
Value Char SZBPCCOD
Value Integer ILINEFLG
Value Integer INOL

Local Char SZLNKCASE
Local Integer IAAALISTED
Local Integer ITER
Local Integer ITER2
Local Integer IFULLCOVER
Local Integer ICONTOK
Local Char SZLITCOD
Local Char SZCOVVCR
Local Integer ICCVMODE
Local Char SZLNDTPLCON
Local Integer IWORTHSTEPONE
Local Date DMACITNDAT
Local Date DLNDENDDAT

  ITER = 0
  ITER2 = 0
  SZLNKCASE = ""
  ICONTOK = 0
  IAAALISTED = 0
  ICCVMODE = 0
  SZLNDTPLCON = ""
  IWORTHSTEPONE = 1
  #On part d'un état le plus défavorable possible.
  #Au fur et à mesure on améliore la couverture avec ce que l'on trouve.
  #On essaye de gagner du temps dans le cas d'un contrôle de couverture pour une ligne unique de parc.
  If ILINEFLG Then
    If [M:SRE7]LND(INOL) = 2 Then
      IWORTHSTEPONE = 0
    Endif
  Endif
  #Première partie : On traite uniquement le parc qui n'est pas en prêt
  If IWORTHSTEPONE  Then
    Link [CCV] With [CON]CON0 = [F:CCV]CONNUM As [LNK]
&      Order By Key KBID = [F:CCV]RECTYP Asc; [F:CCV]SBBRECTYP Asc; [F:CCV]PAEKEY(0) Asc; [F:CCV]PAEKEY(1) Asc; [F:CCV]PAEKEY(2) Asc; [F:CCV]RECNUM Asc
    #Contrôle du partiellement couvert
    If SZCONCODNUM = "" Then
      Filter [LNK] Where [F:CCV]TPL <> 2 and [F:CCV]BPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONCAT <> 4
    Else
      Filter [LNK] Where [F:CCV]TPL <> 2 and [F:CCV]BPC = SZBPCCOD and [F:CCV]CONNUM = SZCONCODNUM and [F:CON]CONCAT <> 4
    Endif
    For [LNK] KBID
      #Détermine le type de l'enregistrement
      Gosub GETCOVCASE
      Case SZLNKCASE
        When "000MACMAC"
          #Couverture maitre d'une fiche parc indépendante
          Gosub MACMAC000
        When "000MACITM"
          #Couverture maitre d'une référence article indépendante
          Gosub MACITM000
        When "000MACCIA"
          #Couverture maitre d'une famille commerciale de produit indépendante
          Gosub MACCIA000
        When "000PBL"
          #Couverture maitre d'une famille de compétence indépendante
          Gosub PBL000
        When "010MACAAA"
          #Couverture partielle d'une fiche parc indépendante
          Gosub MACAAA010
        When "010ITMAAA"
          #Couverture partielle d'une référence article indépendante
          Gosub ITMAAA010
        When "010CIAAAA"
          #Couverture partielle d'une famille commerciale de produit indépendante
          Gosub CIAAAA010
        When "100MACMAC"
          #Couverture maitre d'une fiche parc dépendante d'une famille de compétence
          Gosub MACMAC100
        When "100MACITM"
          #Couverture maitre d'une référence article dépendante d'une famille de compétence
          Gosub MACITM100
        When "100MACCIA"
          #Couverture maitre d'une famille commerciale de produit dépendante d'une famille de compétence
          Gosub MACCIA100
        When "110MACAAA"
          #Couverture partielle d'une fiche parc dépendante d'une famille de compétence
          Gosub MACAAA110
        When "110ITMAAA"
          #Couverture partielle d'une référence article dépendante d'une famille de compétence
          Gosub ITMAAA110
        When "110CIAAAA"
          #Couverture partielle d'une famille commerciale de produit dépendante d'une famille de compétence
          Gosub CIAAAA110
        When "100AAA"
          #Couverture partielle d'une famille de compétence indépendante
          Gosub AAA100
      Endcase
    Next
    Filter [LNK]
  Endif
  #Deuxième partie : On traite uniquement le parc en prêt
  #On essaye de gagner du temps dans le cas d'un contrôle de couverture pour une ligne unique de parc.
  If ILINEFLG Then
    If SZCONCODNUM <> "" Then
      End
    Endif
    If [M:SRE7]LND(INOL) <> 2 Then
      End
    Endif
    Read [MAC]MAC0=[M:SRE7]MAC(INOL)
    If fstat Then
      End
    Else
      If [F:MAC]MACPDTCOD = "" Then
        End
      Else
        Read [ITM]ITM0=[F:MAC]MACPDTCOD
        If fstat Then
          End
        Else
          If [F:ITM]TPLCONLND = "" Then
            End
          Else
            SZLNDTPLCON = [F:ITM]TPLCONLND
          Endif
        Endif
      Endif
    Endif
  Endif
  ICCVMODE += 1
  Link [CCV] With [COT]COT0 = [F:CCV]CONNUM As [LNK]
&    Order By Key KBID = [F:CCV]RECTYP Asc; [F:CCV]SBBRECTYP Asc; [F:CCV]PAEKEY(0) Asc; [F:CCV]PAEKEY(1) Asc; [F:CCV]PAEKEY(2) Asc; [F:CCV]RECNUM Asc
  #Contrôle du partiellement couvert
  If SZLNDTPLCON = "" Then
    Filter [LNK] Where [F:CCV]TPL = 2
  Else
    Filter [LNK] Where [F:CCV]TPL = 2 and [F:CCV]CONNUM = SZLNDTPLCON
  Endif
  For [LNK] KBID
    #Détermine le type de l'enregistrement
    Gosub GETCOVCASE
    Case SZLNKCASE
      When "000MACMAC"
        #Couverture maitre d'une fiche parc indépendante
        Gosub MACMAC000
      When "000MACITM"
        #Couverture maitre d'une référence article indépendante
        Gosub MACITM000
      When "000MACCIA"
        #Couverture maitre d'une famille commerciale de produit indépendante
        Gosub MACCIA000
      When "000PBL"
        #Couverture maitre d'une famille de compétence indépendante
        Gosub PBL000
      When "010MACAAA"
        #Couverture partielle d'une fiche parc indépendante
        Gosub MACAAA010
      When "010ITMAAA"
        #Couverture partielle d'une référence article indépendante
        Gosub ITMAAA010
      When "010CIAAAA"
        #Couverture partielle d'une famille commerciale de produit indépendante
        Gosub CIAAAA010
      When "100MACMAC"
        #Couverture maitre d'une fiche parc dépendante d'une famille de compétence
        Gosub MACMAC100
      When "100MACITM"
        #Couverture maitre d'une référence article dépendante d'une famille de compétence
        Gosub MACITM100
      When "100MACCIA"
        #Couverture maitre d'une famille commerciale de produit dépendante d'une famille de compétence
        Gosub MACCIA100
      When "110MACAAA"
        #Couverture partielle d'une fiche parc dépendante d'une famille de compétence
        Gosub MACAAA110
      When "110ITMAAA"
        #Couverture partielle d'une référence article dépendante d'une famille de compétence
        Gosub ITMAAA110
      When "110CIAAAA"
        #Couverture partielle d'une famille commerciale de produit dépendante d'une famille de compétence
        Gosub CIAAAA110
      When "100AAA"
        #Couverture partielle d'une famille de compétence indépendante
        Gosub AAA100
    Endcase
  Next
  Filter [LNK]
End

##########################################################################################################
#Couverture maitre d'une famille de compétence indépendante
$PBL000
  If ILINEFLG Then
    ITER2 = INOL
    INBMAC = INOL
  Else
    ITER2 = 0
    INBMAC = [M:SRE7]NBMAC-1
  Endif
  For ITER = ITER2 To INBMAC
    If [M:SRE7]LND(ITER) = 2 Then
      Read [MAC]MAC0=[M:SRE7]MAC(ITER)
      If !fstat Then
        If [F:MAC]MACPDTCOD <> "" Then
          Read [ITM]ITM0=[F:MAC]MACPDTCOD
          If !fstat Then
            If [F:ITM]TPLCONLND <> "" Then
              If [F:CCV]CONNUM = [F:ITM]TPLCONLND Then
                If [M:SRE7]MAC(ITER) = "" or [F:COT]EVRMAC = 2 Then
                  If [M:SRE7]COVFLG(ITER) <> 1 Then
                    If [M:SRE7]PBL(ITER) = [F:LNK]RECNUM Then
                      DMACITNDAT = [F:MAC]MACITNDAT
                      Gosub CHKCIACOMCOV
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Else
      If !ICCVMODE Then
        If [M:SRE7]MAC(ITER) = "" or [F:CON]EVRMAC = 2 Then
          If [M:SRE7]COVFLG(ITER) <> 1 Then
            If [M:SRE7]PBL(ITER) = [F:LNK]RECNUM Then
              Gosub CHKCIACOMCOV
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
Return

##########################################################################################################
#Couverture partielle d'une famille de compétence indépendante
$AAA100
  If ILINEFLG Then
    ITER2 = INOL
    INBMAC = INOL
  Else
    ITER2 = 0
    INBMAC = [M:SRE7]NBMAC-1
  Endif
  For ITER = ITER2 To INBMAC
    If [M:SRE7]LND(ITER) = 2 Then
      Read [MAC]MAC0=[M:SRE7]MAC(ITER)
      If !fstat Then
        If [F:MAC]MACPDTCOD <> "" Then
          Read [ITM]ITM0=[F:MAC]MACPDTCOD
          If !fstat Then
            If [F:ITM]TPLCONLND <> "" Then
              If [F:CCV]CONNUM = [F:ITM]TPLCONLND Then
                If [M:SRE7]MAC(ITER) = "" or [F:COT]EVRMAC = 2 Then
                  If [M:SRE7]COVFLG(ITER) <> 1 Then
                    If [M:SRE7]PBL(ITER) = [F:LNK]PAEKEY(0) Then
                      DMACITNDAT = [F:MAC]MACITNDAT
                      Gosub CHECKINF
                      If ICONTOK Then
                        [M:SRE7]COVFLG(ITER) = 2
                        [M:SRE7]COVSPT(ITER) = 5
                        [M:SRE7]COVVCR(ITER) = SZCOVVCR
                        [M:SRE7]MACCOVCLA(ITER) = ""
                        [M:SRE7]MACCOVREN(ITER) = 0
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Else
      If !ICCVMODE Then
        If [M:SRE7]MAC(ITER) = "" or [F:CON]EVRMAC = 2 Then
          If [M:SRE7]COVFLG(ITER) <> 1 Then
            If [M:SRE7]PBL(ITER) = [F:LNK]PAEKEY(0) Then
              Gosub CHECKINF
              If ICONTOK Then
                [M:SRE7]COVFLG(ITER) = 2
                [M:SRE7]COVSPT(ITER) = 1
                [M:SRE7]COVVCR(ITER) = SZCOVVCR
                [M:SRE7]MACCOVCLA(ITER) = ""
                [M:SRE7]MACCOVREN(ITER) = 0
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
Return

##########################################################################################################
#Couverture maitre d'une fiche parc indépendante
$MACMAC000
  If ILINEFLG Then
    ITER2 = INOL
    INBMAC = INOL
  Else
    ITER2 = 0
    INBMAC = [M:SRE7]NBMAC-1
  Endif
  For ITER = ITER2 To INBMAC
    If [M:SRE7]LND(ITER) = 2 Then
      Read [MAC]MAC0=[M:SRE7]MAC(ITER)
      If !fstat Then
        If [F:MAC]MACPDTCOD <> "" Then
          Read [ITM]ITM0=[F:MAC]MACPDTCOD
          If !fstat Then
            If [F:ITM]TPLCONLND <> "" Then
              If [F:CCV]CONNUM = [F:ITM]TPLCONLND Then
                If [M:SRE7]PBL(ITER) = "" or [F:COT]EVRPBL = 2 Then
                  If [M:SRE7]COVFLG(ITER) <> 1 Then
                    If [M:SRE7]MAC(ITER) = [F:LNK]CMT Then
                      DMACITNDAT = [F:MAC]MACITNDAT
                      Gosub CHECKCOMCOV
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Else
      If !ICCVMODE Then
        If [M:SRE7]PBL(ITER) = "" or [F:CON]EVRPBL = 2 Then
          If [M:SRE7]COVFLG(ITER) <> 1 Then
            If [M:SRE7]MAC(ITER) = [F:LNK]CMT Then
              Gosub CHECKCOMCOV
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
Return

##########################################################################################################
#Couverture maitre d'une référence article indépendante
$MACITM000
  If ILINEFLG Then
    ITER2 = INOL
    INBMAC = INOL
  Else
    ITER2 = 0
    INBMAC = [M:SRE7]NBMAC-1
  Endif
  For ITER = ITER2 To INBMAC
    If [M:SRE7]LND(ITER) = 2 Then
      Read [MAC]MAC0=[M:SRE7]MAC(ITER)
      If !fstat Then
        If [F:MAC]MACPDTCOD <> "" Then
          Read [ITM]ITM0=[F:MAC]MACPDTCOD
          If !fstat Then
            If [F:ITM]TPLCONLND <> "" Then
              If [F:CCV]CONNUM = [F:ITM]TPLCONLND Then
                If [M:SRE7]PBL(ITER) = "" or [F:COT]EVRPBL = 2 Then
                  If [M:SRE7]COVFLG(ITER) <> 1 Then
                    If [F:MAC]MACPDTCOD = [F:LNK]CMT Then
                      DMACITNDAT = [F:MAC]MACITNDAT
                      Gosub CHECKCOMCOV
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Else
      If !ICCVMODE Then
        If [M:SRE7]PBL(ITER) = "" or [F:CON]EVRPBL = 2 Then
          If [M:SRE7]COVFLG(ITER) <> 1 Then
            Read [MAC]MAC0=[M:SRE7]MAC(ITER)
            If !fstat Then
              If [F:MAC]MACPDTCOD = [F:LNK]CMT Then
                If [F:MAC]BPCNUM <> "" Then
                  If SZBPCCOD <> "" Then
                    If [F:MAC]BPCNUM = SZBPCCOD Then
                      Gosub CHECKCOMCOV
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
