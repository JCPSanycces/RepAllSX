##########################################################################################################
# Contrôle de l'existence d'un code litige dérogatoire.
#################################################################
Subprog CHECKLIT(SZCONCOD, SZLITNUM, IREADCON, IOK)
Value Char SZCONCOD
Value Char SZLITNUM
Value Integer IREADCON
Variable Integer IOK

Local Integer IC

  IOK = 0
  If IREADCON Then
    Read [CON]CON0=SZCONCOD
    If fstat Then
      IOK = 0
      End
    Endif
  Endif
  For IC = 0 To dim([F:CON]ACPDPTCOD)-1
    If [F:CON]ACPDPTCOD(IC) <> "" Then
      If [F:CON]ACPDPTCOD(IC) = SZLITNUM Then
        IOK = 1
        Break
      Endif
    Endif
  Next
End

##########################################################################################################
# Contrôle de l'existence d'un code litige dérogatoire.
#################################################################
Subprog CHECK2LIT(SZCONCOD, SZLITNUM, IOK)
Value Char SZCONCOD
Value Char SZLITNUM
Variable Integer IOK

Local Integer IC

  IOK = 0
  For IC = 0 To dim([F:LNK]ACPDPTCOD)-1
    If [F:LNK]ACPDPTCOD(IC) <> "" Then
      If [F:LNK]ACPDPTCOD(IC) = SZLITNUM Then
        IOK = 1
        Break
      Endif
    Endif
  Next
End

##########################################################################################################
# Détermine la nature d'un enregistrement de la table CONTCOV
#################################################################
$GETCOVCASE
  SZLNKCASE = ""
  If [F:LNK]PAEKEY(0) = "" Then
    If [F:LNK]PAEKEY(1) = "" Then
      If [F:LNK]PAEKEY(2) = "" Then
        SZLNKCASE = "000"
      Else
        SZLNKCASE = "001"
      Endif
    Else
      Case [F:LNK]PAEKEYTYP(1)
        When "MAC"
          If [F:LNK]PAEKEY(2) = "" Then
            SZLNKCASE = "010MAC"
          Else
            SZLNKCASE = "011MAC"
          Endif
        When "ITM"
          If [F:LNK]PAEKEY(2) = "" Then
            SZLNKCASE = "010ITM"
          Else
            SZLNKCASE = "011ITM"
          Endif
        When "CIA"
          If [F:LNK]PAEKEY(2) = "" Then
            SZLNKCASE = "010CIA"
          Else
            SZLNKCASE = "011CIA"
          Endif
      Endcase
    Endif
  Else
    If [F:LNK]PAEKEY(1) = "" Then
      If [F:LNK]PAEKEY(2) = "" Then
        SZLNKCASE = "100"
      Else
        SZLNKCASE = "101"
      Endif
    Else
      Case [F:LNK]PAEKEYTYP(1)
        When "MAC"
          If [F:LNK]PAEKEY(2) = "" Then
            SZLNKCASE = "110MAC"
          Else
            SZLNKCASE = "111MAC"
          Endif
        When "ITM"
          If [F:LNK]PAEKEY(2) = "" Then
            SZLNKCASE = "110ITM"
          Else
            SZLNKCASE = "111ITM"
          Endif
        When "CIA"
          If [F:LNK]PAEKEY(2) = "" Then
            SZLNKCASE = "110CIA"
          Else
            SZLNKCASE = "111CIA"
          Endif
      Endcase
    Endif
  Endif
  Case [F:LNK]RECTYP
    When "MAC"
      Case [F:LNK]SBBRECTYP
        When "MAC"
          SZLNKCASE += "MACMAC"
        When "ITM"
          SZLNKCASE += "MACITM"
        When "CIA"
          SZLNKCASE += "MACCIA"
      Endcase
    When "CPN"
      SZLNKCASE += "CPN"
    When "PBL"
      SZLNKCASE += "PBL"
    When "AAA"
      SZLNKCASE += "AAA"
  Endcase
Return

##########################################################################################################
# Contrôle de couverture sur la base d'une compétence
###########################################################
Subprog CHKPBL(SZBPCCOD, SZPBLCOD)
Value Char SZBPCCOD
Value Char SZPBLCOD

Local Integer INBCONREAD
Local Integer IFULLCOVER
Local Char SZLITCOD
Local Integer ICHECKPAY
Local Integer IEVRCOV
Local Char SZCOVVCR

  INBCONREAD = 0
  SZLITCOD = ""
  IFULLCOVER = 1
  ICHECKPAY = 0
  IEVRCOV = 0
  SZCOVVCR = ""
  Link [CCV] With [CON]CON0 = [F:CCV]CONNUM As [LNK] Order By Key KBID = [F:CCV]RECNUM
  #Contrôle du partiellement couvert
  Filter [LNK] Where [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPCCOD
&                and [F:CCV]RECTYP = "AAA"
&                and [F:CCV]PAEKEY(0) = SZPBLCOD
&                and [F:CCV]PAEKEY(1) = ""
&                and [F:CCV]PAEKEY(2) = ""
&                and [F:CON]CONCAT <> 4
&                and [F:CON]RSIFLG <> 2
&                and [F:CON]FDDFLG <> 2
  For [LNK] KBID
    If [F:CON]CONENDDAT < date$ Then
      [M:SRE0]CURCOVMEE = 4
    Else
      If [F:CON]CONSTRDAT > date$ Then
        [M:SRE0]CURCOVMEE = 11
      Else
        #Contrôle du réglement du contrat
        SZLITCOD = ""
        Call CHECKPAY([F:CON]CONNUM, [F:CON]CONBPC, SZLITCOD, IEVRCOV)
        If IEVRCOV Then
          SZCOVVCR = [F:CON]CONNUM
          Break
        Else
          #Contrôle de l'existence d'un code litige accepté
          Call CHECK2LIT([F:CON]CONNUM, SZLITCOD, IEVRCOV)
          If IEVRCOV Then
            SZCOVVCR = [F:CON]CONNUM
            Break
          Else
            [M:SRE0]CURCOVMEE = 5
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [LNK]
  If IEVRCOV Then
    [M:SRE2]OVRCOV = 2
    [M:SRE2]OVRCOVCLA = ""
    [M:SRE2]OVRCOVREN = 0
    [M:SRE2]SRECOVNUM = SZCOVVCR
    [M:SRE2]OVRCOVTYP = "CON"
    [M:SRE2]SRECOVAUT = 1
    [M:SRE2]SRECOVAUS = ""
    [M:SRE2]COVAUSCLA = ""
    [M:SRE2]SRECOVCTL = ""
    [M:SRE2]CONSPT = SZCOVVCR
    [M:SRE2]CONSPTTYP = "CON"
    [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement
    [M:SRE2]CONSPTFLG = 0
    [M:SRE2]MANUPD = 1
    #Obtient le niveau de réactivité SAV.
    Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
    End
  Endif
  #Contrôle du non couvert et du totalement couvert
  IFULLCOVER = 0
  INBCONREAD = 0
  Filter [LNK] Where [F:CCV]TPL <> 2
&                and [F:CCV]BPC = SZBPCCOD
&                and [F:CCV]RECTYP = "PBL"
&                and [F:CCV]RECNUM = SZPBLCOD
&                and [F:CON]CONCAT <> 4
&                and [F:CON]RSIFLG <> 2
&                and [F:CON]FDDFLG <> 2
  For [LNK] KBID
    INBCONREAD += 1
    If [F:CON]CONENDDAT < date$ Then
      [M:SRE0]CURCOVMEE = 4
    Else
      If [F:CON]CONSTRDAT > date$ Then
        [M:SRE0]CURCOVMEE = 11
      Else
        #Contrôle du réglement du contrat
        SZLITCOD = ""
        ICHECKPAY = 0
        Call CHECKPAY([F:CON]CONNUM, [F:CON]CONBPC, SZLITCOD, ICHECKPAY)
        If ICHECKPAY Then
          Gosub CHKPARTIAL
          If IFULLCOVER Then
            SZCOVVCR = [F:CON]CONNUM
            Break
          Else
            SZCOVVCR = [F:CON]CONNUM
          Endif
        Else
          #Contrôle de l'existence d'un code litige accepté
          Call CHECK2LIT([F:CON]CONNUM, SZLITCOD, ICHECKPAY)
          If ICHECKPAY Then
            Gosub CHKPARTIAL
            If IFULLCOVER Then
              SZCOVVCR = [F:CON]CONNUM
              Break
            Else
              SZCOVVCR = [F:CON]CONNUM
            Endif
          Else
            [M:SRE0]CURCOVMEE = 5
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [LNK]
  If INBCONREAD Then
    If IFULLCOVER Then
      [M:SRE2]OVRCOV = 1
    Else
      [M:SRE2]OVRCOV = 2
    Endif
    [M:SRE2]OVRCOVTYP = "CON"
    [M:SRE2]OVRCOVCLA = ""
    [M:SRE2]OVRCOVREN = 0
    [M:SRE0]CURCOVMEE = 0
    [M:SRE2]SRECOVNUM = SZCOVVCR
    [M:SRE2]SRECOVAUT = 1
    [M:SRE2]SRECOVAUS = ""
    [M:SRE2]COVAUSCLA = ""
    [M:SRE2]SRECOVCTL = ""
    [M:SRE2]CONSPT = SZCOVVCR
    [M:SRE2]CONSPTTYP = "CON"
    [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement
    [M:SRE2]CONSPTFLG = 0
    [M:SRE2]MANUPD = 1
    #Obtient le niveau de réactivité SAV.
    Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
  Else
    [M:SRE2]OVRCOV = 3
    [M:SRE2]OVRCOVTYP = ""
    [M:SRE2]OVRCOVCLA = mess(6,178,1)
    [M:SRE2]OVRCOVREN = 6
    [M:SRE0]CURCOVMEE = 6
    [M:SRE2]SRECOVNUM = ""
    [M:SRE2]SRECOVAUT = 1
    [M:SRE2]SRECOVAUS = ""
    [M:SRE2]COVAUSCLA = ""
    [M:SRE2]SRECOVCTL = ""
    [M:SRE2]CONSPT = ""
    [M:SRE2]CONSPTTYP = ""
    [M:SRE2]CONSPTCLA = ""
    [M:SRE2]CONSPTFLG = 0
    [M:SRE2]MANUPD = 1
    #Obtient le niveau de réactivité SAV.
    Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
  Endif
End

##########################################################################################################
# Calcul une date de résolution souhaitée par rapport aux contraintes qualité d'un contrat de service
#################################################################
Subprog SETRESDAT(DOPGDAT, SZOPGHOU, SZCONREF, SZCONTYP, SZGRALEV, IPROMPT, DRESDAT, SZRESHOU)
Value Date DOPGDAT
Value Char SZOPGHOU
Value Char SZCONREF
Value Char SZCONTYP
Value Char SZGRALEV
Value Integer IPROMPT
Variable Date DRESDAT
Variable Char SZRESHOU

Local Char SZMESS(250)
Local Integer INBDAY
Local Integer INBHOU
Local Char SZREAC
Local Integer IREAC

  SZREAC = ""
  IREAC = 0
  INBDAY = 0
  INBHOU = 0
  SZMESS = ""
  Call PARAML("", "QREAC", SZREAC) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  IREAC = val(SZREAC)
  DRESDAT = DOPGDAT + IREAC
  SZRESHOU = left$(SZOPGHOU, 2) + mid$(SZOPGHOU, 3, 2)
  If SZCONREF = "" Then
    End
  Endif
  If SZCONTYP = "" Then
    End
  Endif
  If SZCONTYP = "COT" Then
    Filter [CQL] Where [F:CQL]CONNUM = SZCONREF and [F:CQL]TPL = 2 and [F:CQL]GRALEV = SZGRALEV
  Elsif SZCONTYP = "CON" Then
    Filter [CQL] Where [F:CQL]CONNUM = SZCONREF and [F:CQL]TPL <> 2 and [F:CQL]GRALEV = SZGRALEV
  Endif
  For [CQL]
    If [F:CQL]BASEXXSOL = 1 Then
      Call DAYFROMHOUR(DOPGDAT, SZOPGHOU, [F:CQL]SOLLTIMAX, DRESDAT, SZRESHOU) From CRMUTIL140
    Else
      SZRESHOU = SZOPGHOU
      Call GETNEWDAT(DOPGDAT, [F:CQL]SOLLTIMAX, [F:CQL]BASEXXSOL, DRESDAT) From SUBCONB1
    Endif
    #Le délai maximum de résolution de cette demande est de
    SZMESS = mess(404,196,1) - num$([F:CQL]SOLLTIMAX) - mess([F:CQL]BASEXXSOL,976,1)
    Break
  Next
  Filter [CQL]
  #Aucune contrainte qualité particulière n'a été identifiée pour ce contrat.
  If SZMESS = "" Then
    SZMESS = mess(336,182,1)
  Endif
  If IPROMPT Then
    GMESSAGE = SZMESS
    GERR = 2
  Endif
End

##########################################################################################################
# Contrôle des couvertures par point
###########################################################
Subprog CHECKPIT(SZCONCODNUM, SZBPCCOD, ILINEFLG, INOL, IERRINF)
Value Char SZCONCODNUM
Value Char SZBPCCOD
Value Integer ILINEFLG
Value Integer INOL
Variable Integer IERRINF

Local Integer ICONTOK
Local Char SZLITCOD
Local Char SZCOVVCR
Local Integer ICCVMODE
Local Integer ITER
Local Integer IPITCSM
Local Char SZMAC
Local Char SZITM
Local Char SZPBL
Local Integer ICONTOTPIT
Local Integer ICONPITCDT
Local Integer ICONPITREM
Local Integer IPITDEBFLG

  IERRINF = 0
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    End
  Endif
  # ------------------------------------------
  # Issue X3-74295 - 2018-04-05 by FGR : BEGIN
  Local Char SSPESPCALLER(GLONDES)

  SSPESPCALLER = "CHECKPIT"
  Gosub PE_CRITCON From TRTCRMPE
  # Issue X3-74295 - 2018-04-05 by FGR : END
  # ------------------------------------------
  ICCVMODE = 0
  SZCOVVCR = ""
  IPITCSM = 0
  ITER = 0
  SZMAC = ""
  SZITM = ""
  SZPBL = ""
  IERRINF = 0
  ICONPITREM = 0
  ICONTOTPIT = 0
  ICONPITCDT = 0
  IPITDEBFLG = 0
  If ILINEFLG Then
    ITER = INOL
    INBMAC = INOL
  Else
    INBMAC = [M:SRE7]NBMAC-1
    #Si la demande est déjà couverte au titre d'une garantie ou maintenance. On ne recherche pas de contrats à points
    If [M:SRE7]NBMAC = 0 Then
      If [M:SRE2]OVRCOV = 1 Then
        End
      Elsif [M:SRE2]OVRCOV = 2 Then
        If GPITCOVFLG <> 2 Then
          End
        Endif
      Endif
    Endif
  Endif
  If SZCONCODNUM = "" Then
    # Issue X3-74295 - 2018-04-05 by FGR : BEGIN
    #Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]CONCAT = 4 and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2
    Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]CONCAT = 4 and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and evalue([L]SSPECRITCON)
    # Issue X3-74295 - 2018-04-05 by FGR : END
  Else
    # Issue X3-74295 - 2018-04-05 by FGR : BEGIN
    #Filter [CON] Where [F:CON]CONNUM = SZCONCODNUM and [F:CON]CONCAT = 4 and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2
    Filter [CON] Where [F:CON]CONNUM = SZCONCODNUM and [F:CON]CONCAT = 4 and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and evalue([L]SSPECRITCON)
    # Issue X3-74295 - 2018-04-05 by FGR : END
  Endif
  For [CON]
    If ILINEFLG Then
      #Des points sont consommés par du parc
      For ITER = 0 To INBMAC
        If [M:SRE7]COVFLG(ITER) = 3 Then
          SZMAC = [M:SRE7]MAC(ITER)
          SZPBL = [M:SRE7]PBL(ITER)
          Gosub GETPITCSM
          If IERRINF Then
            Break
          Endif
        Elsif [M:SRE7]COVFLG(ITER) = 2 Then
          If GPITCOVFLG = 2 Then
            SZMAC = [M:SRE7]MAC(ITER)
            SZPBL = [M:SRE7]PBL(ITER)
            Gosub GETPITCSM
            If IERRINF Then
              Break
            Endif
          Endif
        Endif
      Next
    Else
      If [M:SRE7]NBMAC > 0 Then
        #Des points sont consommés par du parc
        For ITER = 0 To INBMAC
          If [M:SRE7]COVFLG(ITER) = 3 Then
            SZMAC = [M:SRE7]MAC(ITER)
            SZPBL = [M:SRE7]PBL(ITER)
            Gosub GETPITCSM
            If IERRINF Then
              Break
            Endif
          Elsif [M:SRE7]COVFLG(ITER) = 2 Then
            If GPITCOVFLG = 2 Then
              SZMAC = [M:SRE7]MAC(ITER)
              SZPBL = [M:SRE7]PBL(ITER)
              Gosub GETPITCSM
              If IERRINF Then
                Break
              Endif
            Endif
          Endif
        Next
      Else
        #Des points sont consommés soit par le client soit par le client + compétence
        SZMAC = ""
        SZPBL = [M:SRE7]SREPBLGRP
        Gosub GETPITCSM
        If IERRINF Then
          Break
        Endif
        #Si le client a été débité de ses points. Pas la peine d'aller plus loin.
        If IPITDEBFLG Then
          Break
        Endif
      Endif
    Endif
  Next
  Filter [CON]
  If IERRINF Then
    End
  Endif
End

##########################################################################################################
# Obtention d'un débit forfaitaire de points
####################################################
$GETPITCSM
  IPITCSM = 0
  SZITM = ""
  If SZMAC <> "" Then
    Read [MAC]MAC0=SZMAC
    If !fstat Then
      If [F:MAC]MACPDTCOD <> "" Then
        SZITM = [F:MAC]MACPDTCOD
      Endif
    Endif
  Endif
  #Priorité de recherche des points :
  #  Client + MACPBL
  #  "" + MACPBL
  #  Client + ""
  #  "" + ""
  Read [PDB]PDB0=SZBPCCOD;SZITM;SZPBL
  If fstat Then
    Read [PDB]PDB0="";SZITM;SZPBL
    If fstat Then
      Read [PDB]PDB0=SZBPCCOD;"";""
      If fstat Then
        Read [PDB]PDB0="";"";""
        If !fstat Then
          IPITCSM = [F:PDB]SGLNBRPIT
        Endif
      Else
        If [F:PDB]SGLNBRPIT <= 0 Then
          If [F:PDB]NULPIO <> 2 Then
            Read [PDB]PDB0="";"";""
            If !fstat Then
              IPITCSM = [F:PDB]SGLNBRPIT
            Endif
          Endif
        Else
          IPITCSM = [F:PDB]SGLNBRPIT
        Endif
      Endif
    Else
      If [F:PDB]SGLNBRPIT <= 0 Then
        If [F:PDB]NULPIO <> 2 Then
          Read [PDB]PDB0=SZBPCCOD;"";""
          If fstat Then
            Read [PDB]PDB0="";"";""
            If !fstat Then
              IPITCSM = [F:PDB]SGLNBRPIT
            Endif
          Else
            If [F:PDB]SGLNBRPIT <= 0 Then
              If [F:PDB]NULPIO <> 2 Then
                Read [PDB]PDB0="";"";""
                If !fstat Then
                  IPITCSM = [F:PDB]SGLNBRPIT
                Endif
              Endif
            Else
              IPITCSM = [F:PDB]SGLNBRPIT
            Endif
          Endif
        Endif
      Else
        IPITCSM = [F:PDB]SGLNBRPIT
      Endif
    Endif
  Else
    If [F:PDB]SGLNBRPIT <= 0 Then
      If [F:PDB]NULPIO <> 2 Then
        Read [PDB]PDB0="";SZITM;SZPBL
        If fstat Then
          Read [PDB]PDB0=SZBPCCOD;"";""
          If fstat Then
            Read [PDB]PDB0="";"";""
            If !fstat Then
              IPITCSM = [F:PDB]SGLNBRPIT
            Endif
          Else
            If [F:PDB]SGLNBRPIT <= 0 Then
              If [F:PDB]NULPIO <> 2 Then
                Read [PDB]PDB0="";"";""
                If !fstat Then
                  IPITCSM = [F:PDB]SGLNBRPIT
                Endif
              Endif
            Else
              IPITCSM = [F:PDB]SGLNBRPIT
            Endif
          Endif
        Else
          If [F:PDB]SGLNBRPIT <= 0 Then
            If [F:PDB]NULPIO <> 2 Then
              Read [PDB]PDB0=SZBPCCOD;"";""
              If fstat Then
                Read [PDB]PDB0="";"";""
                If !fstat Then
                  IPITCSM = [F:PDB]SGLNBRPIT
                Endif
              Else
                If [F:PDB]SGLNBRPIT <= 0 Then
                  If [F:PDB]NULPIO <> 2 Then
                    Read [PDB]PDB0="";"";""
                    If !fstat Then
                      IPITCSM = [F:PDB]SGLNBRPIT
                    Endif
                  Endif
                Else
                  IPITCSM = [F:PDB]SGLNBRPIT
                Endif
              Endif
            Endif
          Else
            IPITCSM = [F:PDB]SGLNBRPIT
          Endif
        Endif
      Endif
    Else
      IPITCSM = [F:PDB]SGLNBRPIT
    Endif
  Endif
  If IPITCSM > 0 Then
    #On vérifie si le contrat comporte assez de points pour être débité.
    Filter [PCT] Where [F:PCT]CONNUM = [F:CON]CONNUM and [F:PCT]FGVCAH = 0
    ICONTOTPIT = 0
    For [PCT] PCT1
      ICONTOTPIT += [F:PCT]PIT
    Next
    Filter [PCT]
    If ICONTOTPIT < [F:CON]PITCDT Then
      #On ajoute la tolérance de point du contrat
      ICONPITCDT = [F:CON]PITCDT + ([F:CON]PITCDT * ([F:CON]PITTOL / 100))
      #On calcul le nombre de points maximum consommables sur ce contrat
      ICONPITREM = ICONPITCDT - ICONTOTPIT
      If IPITCSM <= ICONPITREM Then
        If ICONTOTPIT + IPITCSM >= [F:CON]PITCDT Then
          IPITCSM = [F:CON]PITCDT - ICONTOTPIT
        Endif
        Gosub CHECKINF
        If ICONTOK Then
          #On consomme
          If GREP = "C" Then
            Call CREPIT([M:SRE0]CRESEQ, 1, [F:CON]CONNUM, SZBPCCOD, SZMAC, SZPBL, "", "", IPITCSM, 1, IERRINF) From SUBSREB2
          Elsif GREP = "D" Then
            Call CREPIT([M:SRE0]CRESEQ, 1, [F:CON]CONNUM, SZBPCCOD, SZMAC, SZPBL, "", "", IPITCSM, 1, IERRINF) From SUBSREB2
          Else
            Call CREPIT([M:SRE0]SRENUM, 0, [F:CON]CONNUM, SZBPCCOD, SZMAC, SZPBL, "", "", IPITCSM, 1, IERRINF) From SUBSREB2
          Endif
          If IERRINF Then
            Return
          Endif
          Raz [M:SRE0]CURCOVMEE
          If ILINEFLG Then
            [M:SRE7]COVFLG(ITER) = 1
            [M:SRE7]COVSPT(ITER) = 1
            [M:SRE7]COVVCR(ITER) = SZCOVVCR
            [M:SRE7]PITMAC(ITER) = IPITCSM
            [M:SRE7]MACCOVCLA(ITER) = ""
            [M:SRE7]MACCOVREN(ITER) = 0
          Else
            If [M:SRE7]NBMAC > 0 Then
              [M:SRE7]COVFLG(ITER) = 1
              [M:SRE7]COVSPT(ITER) = 1
              [M:SRE7]COVVCR(ITER) = SZCOVVCR
              [M:SRE7]PITMAC(ITER) = IPITCSM
              [M:SRE7]MACCOVCLA(ITER) = ""
              [M:SRE7]MACCOVREN(ITER) = 0
            Else
              IPITDEBFLG = 1
              [M:SRE2]OVRCOV = 1
              [M:SRE2]OVRCOVTYP = "CON"
              [M:SRE2]OVRCOVCLA = ""
              [M:SRE2]OVRCOVREN = 0
              [M:SRE0]CURCOVMEE = 0
              [M:SRE2]SRECOVNUM = SZCOVVCR
              [M:SRE2]SRECOVAUT = 1
              [M:SRE2]SRECOVAUS = ""
              [M:SRE2]COVAUSCLA = ""
              [M:SRE2]SRECOVCTL = ""
              [M:SRE2]CONSPT = SZCOVVCR
              [M:SRE2]CONSPTTYP = "CON"
              [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement
              [M:SRE2]CONSPTFLG = 0
              [M:SRE2]MANUPD = 1
              #Obtient le niveau de réactivité SAV.
              Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU)
            Endif
          Endif
        Endif
      Else
        #On affiche un message que lorsque la recherche concerne soit la demande soit une seule fiche parc
        If ILINEFLG Then
          If SZCONCODNUM = "" Then
            [M:SRE0]CURCOVMEE = 10
          Endif
        Else
          If [M:SRE7]NBMAC < 2 Then
            [M:SRE0]CURCOVMEE = 10
          Endif
        Endif
      Endif
    Else
      #On affiche un message que lorsque la recherche concerne soit la demande soit une seule fiche parc
      If ILINEFLG Then
        If SZCONCODNUM = "" Then
          [M:SRE0]CURCOVMEE = 10
        Endif
      Else
        If [M:SRE7]NBMAC < 2 Then
          [M:SRE0]CURCOVMEE = 10
        Endif
      Endif
    Endif
  Else
    #La demande est couverte et on ne consomme aucun point.
    #On aboutit donc à une couverture de type contrat de maintenance classique
    Gosub CHECKINF
    If ICONTOK Then
      If ILINEFLG Then
        [M:SRE7]COVFLG(ITER) = 1
        [M:SRE7]COVSPT(ITER) = 1
        [M:SRE7]COVVCR(ITER) = SZCOVVCR
        [M:SRE7]PITMAC(ITER) = IPITCSM
        [M:SRE7]MACCOVCLA(ITER) = ""
        [M:SRE7]MACCOVREN(ITER) = 0
      Else
        If [M:SRE7]NBMAC > 0 Then
          [M:SRE7]COVFLG(ITER) = 1
          [M:SRE7]COVSPT(ITER) = 1
          [M:SRE7]COVVCR(ITER) = SZCOVVCR
          [M:SRE7]PITMAC(ITER) = IPITCSM
          [M:SRE7]MACCOVCLA(ITER) = ""
          [M:SRE7]MACCOVREN(ITER) = 0
        Else
          IPITDEBFLG = 1
          [M:SRE2]OVRCOV = 1
          [M:SRE2]OVRCOVTYP = "CON"
          [M:SRE2]OVRCOVCLA = ""
          [M:SRE2]OVRCOVREN = 0
          [M:SRE0]CURCOVMEE = 0
          [M:SRE2]SRECOVNUM = SZCOVVCR
          [M:SRE2]SRECOVAUT = 1
          [M:SRE2]SRECOVAUS = ""
          [M:SRE2]COVAUSCLA = ""
          [M:SRE2]SRECOVCTL = ""
          [M:SRE2]CONSPT = SZCOVVCR
          [M:SRE2]CONSPTTYP = "CON"
          [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement
          [M:SRE2]CONSPTFLG = 0
          [M:SRE2]MANUPD = 1
          #Obtient le niveau de réactivité SAV.
          Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU)
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Suppression de toutes les couvertures par point d'une demande de service.
####################################################################
Subprog DELPITCOV(SZGREP, ILINEFLG, INOL, IERRINF)
Value Char SZGREP
Value Integer ILINEFLG
Value Integer INOL
Variable Integer IERRINF

Local Integer ITRANSFLG

  IERRINF = 0
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    End
  Endif
  #
  If adxlog Then
    ITRANSFLG = 1
  Else
    ITRANSFLG = 0
  Endif
  If !ITRANSFLG Then
    Call DEBTRANS From GLOCK
    Trbegin [PCT]
  Endif
  If ILINEFLG Then
    If SZGREP = "C" Then
      Delete [PCT] Where [F:PCT]SRENUM = [M:SRE0]CRESEQ
&                    and [F:PCT]TPYFLG = 1
&                    and [F:PCT]FGVCAH = 0
&                    and [F:PCT]PITTYP = 1
&                    and [F:PCT]MAC = [M:SRE7]MAC(INOL)
&                    and [F:PCT]PBL = [M:SRE7]PBL(INOL)
&                    and [F:PCT]SAT <> 2
    Elsif SZGREP = "D" Then
      Delete [PCT] Where [F:PCT]SRENUM = [M:SRE0]CRESEQ
&                    and [F:PCT]TPYFLG = 1
&                    and [F:PCT]FGVCAH = 0
&                    and [F:PCT]PITTYP = 1
&                    and [F:PCT]MAC = [M:SRE7]MAC(INOL)
&                    and [F:PCT]PBL = [M:SRE7]PBL(INOL)
&                    and [F:PCT]SAT <> 2
    Else
      Delete [PCT] Where [F:PCT]SRENUM = [M:SRE0]SRENUM
&                    and [F:PCT]TPYFLG = 0
&                    and [F:PCT]FGVCAH = 0
&                    and [F:PCT]PITTYP = 1
&                    and [F:PCT]MAC = [M:SRE7]MAC(INOL)
&                    and [F:PCT]PBL = [M:SRE7]PBL(INOL)
&                    and [F:PCT]SAT <> 2
    Endif
    If fstat Then
      #Erreur lors de suppression des couvertures par points. Le contrôle de couverture est abandonné.
      IERRINF = 510
      If !ITRANSFLG Then
        Rollback
      Endif
      End
    Endif
    If SZGREP = "C" Then
      Delete [DVA] Where [F:DVA]OBC = "PIT"
&                    and [F:DVA]ALHX(1) = [M:SRE0]CRESEQ
&                    and [F:DVA]INTX(2) = 1
&                    and [F:DVA]INTX(3) = 1
&                    and [F:DVA]ALHX(3) = [M:SRE7]MAC(INOL)
&                    and [F:DVA]ALHX(4) = [M:SRE7]PBL(INOL)
    Elsif SZGREP = "D" Then
      Delete [DVA] Where  [F:DVA]OBC = "PIT"
&                    and [F:DVA]ALHX(1) = [M:SRE0]CRESEQ
&                    and [F:DVA]INTX(2) = 1
&                    and [F:DVA]INTX(3) = 1
&                    and [F:DVA]ALHX(3) = [M:SRE7]MAC(INOL)
&                    and [F:DVA]ALHX(4) = [M:SRE7]PBL(INOL)
    Else
      Delete [DVA] Where [F:DVA]OBC = "PIT"
&                    and [F:DVA]ALHX(1) = [M:SRE0]SRENUM
&                    and [F:DVA]INTX(2) = 0
&                    and [F:DVA]INTX(3) = 1
&                    and [F:DVA]ALHX(3) = [M:SRE7]MAC(INOL)
&                    and [F:DVA]ALHX(4) = [M:SRE7]PBL(INOL)
    Endif
    If fstat Then
      #Erreur lors de suppression des couvertures par points. Le contrôle de couverture est abandonné.
      IERRINF = 510
      If !ITRANSFLG Then
        Rollback
      Endif
      End
    Endif
    If SZGREP = "C" Then
      Delete [PCT] Where [F:PCT]SRENUM = [M:SRE0]CRESEQ
&                    and [F:PCT]TPYFLG = 1
&                    and [F:PCT]FGVCAH = 0
&                    and [F:PCT]PITTYP = 1
&                    and [F:PCT]MAC = ""
&                    and [F:PCT]HDT = ""
&                    and [F:PCT]SAT <> 2
    Elsif SZGREP = "D" Then
      Delete [PCT] Where [F:PCT]SRENUM = [M:SRE0]CRESEQ
&                    and [F:PCT]TPYFLG = 1
&                    and [F:PCT]FGVCAH = 0
&                    and [F:PCT]PITTYP = 1
&                    and [F:PCT]MAC = ""
&                    and [F:PCT]HDT = ""
&                    and [F:PCT]SAT <> 2
    Else
      Delete [PCT] Where [F:PCT]SRENUM = [M:SRE0]SRENUM
&                    and [F:PCT]TPYFLG = 0
&                    and [F:PCT]FGVCAH = 0
&                    and [F:PCT]PITTYP = 1
&                    and [F:PCT]MAC = ""
&                    and [F:PCT]HDT = ""
&                    and [F:PCT]SAT <> 2
    Endif
    If fstat Then
      #Erreur lors de suppression des couvertures par points. Le contrôle de couverture est abandonné.
      IERRINF = 510
      If !ITRANSFLG Then
        Rollback
      Endif
      End
    Endif
    If SZGREP = "C" Then
      Delete [DVA] Where [F:DVA]OBC = "PIT"
&                    and [F:DVA]ALHX(1) = [M:SRE0]CRESEQ
&                    and [F:DVA]INTX(2) = 1
&                    and [F:DVA]INTX(3) = 1
&                    and [F:DVA]ALHX(3) = ""
&                    and [F:DVA]ALHX(5) = ""
    Elsif SZGREP = "D" Then
      Delete [DVA] Where [F:DVA]OBC = "PIT"
&                    and [F:DVA]ALHX(1) = [M:SRE0]CRESEQ
&                    and [F:DVA]INTX(2) = 1
&                    and [F:DVA]INTX(3) = 1
&                    and [F:DVA]ALHX(3) = ""
&                    and [F:DVA]ALHX(5) = ""
    Else
      Delete [DVA] Where [F:DVA]OBC = "PIT"
&                    and [F:DVA]ALHX(1) = [M:SRE0]SRENUM
&                    and [F:DVA]INTX(2)= 0
&                    and [F:DVA]INTX(3) = 1
&                    and [F:DVA]ALHX(3) = ""
&                    and [F:DVA]ALHX(5) = ""
    Endif
    If fstat Then
      If fstat = 4 Then
        If !ITRANSFLG Then
          Commit
        Endif
      Else
        #Erreur lors de suppression des couvertures par points. Le contrôle de couverture est abandonné.
        IERRINF = 510
        If !ITRANSFLG Then
          Rollback
        Endif
        End
      Endif
    Else
      If !ITRANSFLG Then
        Commit
      Endif
    Endif
  Else
    If SZGREP = "C" Then
      Delete [PCT] Where [F:PCT]SRENUM = [M:SRE0]CRESEQ and [F:PCT]TPYFLG = 1 and [F:PCT]FGVCAH = 0 and [F:PCT]SAT <> 2
    Elsif SZGREP = "D" Then
      Delete [PCT] Where [F:PCT]SRENUM = [M:SRE0]CRESEQ and [F:PCT]TPYFLG = 1 and [F:PCT]FGVCAH = 0 and [F:PCT]SAT <> 2
    Else
      Delete [PCT] Where [F:PCT]SRENUM = [M:SRE0]SRENUM and [F:PCT]TPYFLG = 0 and [F:PCT]FGVCAH = 0 and [F:PCT]SAT <> 2
    Endif
    If fstat Then
      #Erreur lors de suppression des couvertures par points. Le contrôle de couverture est abandonné.
      IERRINF = 510
      If !ITRANSFLG Then
        Rollback
      Endif
      End
    Endif
    If SZGREP = "C" Then
        Delete [DVA] Where [F:DVA]OBC = "PIT" and [F:DVA]ALHX(1) = [M:SRE0]CRESEQ and [F:DVA]INTX(2) = 1
    Elsif SZGREP = "D" Then
      Delete [DVA] Where [F:DVA]OBC = "PIT" and [F:DVA]ALHX(1) = [M:SRE0]CRESEQ and [F:DVA]INTX(2) = 1
    Else
      Delete [DVA] Where [F:DVA]OBC = "PIT" and [F:DVA]ALHX(1) = [M:SRE0]SRENUM and [F:DVA]INTX(2) = 0
    Endif
    If fstat Then
      If fstat = 4 Then
        If !ITRANSFLG Then
          Commit
        Endif
      Else
        #Erreur lors de suppression des couvertures par points. Le contrôle de couverture est abandonné.
        IERRINF = 510
        If !ITRANSFLG Then
          Rollback
        Endif
        End
      Endif
    Else
      If !ITRANSFLG Then
        Commit
      Endif
    Endif
  Endif
End

##########################################################################################################
# Redéfini la couverture de tous les composants de parc. (Classe F)
#################################################################
Subprog RECHECKCPN(IRELINEFLG, IRENOL, IERR)
Value Integer IRELINEFLG
Value Integer IRENOL
Variable Integer IERR

Local Integer ITER
Local Integer ITER2
Local Integer IRENBMAC

  IERR = 0
  IRENBMAC = 0
  If IRELINEFLG Then
    ITER2 = IRENOL
    IRENBMAC = IRENOL
  Else
    ITER2 = 0
    IRENBMAC = [M:SRE7]NBMAC-1
  Endif
  For ITER = ITER2 To IRENBMAC
    If GREP = "C" Then
      Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0 and [F:SRN]MACNUM = [M:SRE7]MAC(ITER)
    Elsif GREP = "D"
      Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0 and [F:SRN]MACNUM = [M:SRE7]MAC(ITER)
    Else
      Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0 and [F:SRN]MACNUM = [M:SRE7]MAC(ITER)
    Endif
    For [SRN]
      Call RECHECKMLC(ITER, IERR)
      If IERR Then
        Break
      Endif
    Next
    Filter [SRN]
    If IERR Then
      Break
    Endif
  Next
  If dim(GSRE7NBCPN) < 0 Then          # FGR 01/09/2016 : X3SUIVI117427
    If GREP = "C" Then
      Call LOADCPN([M:SRE0]CRESEQ, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 1) From SUBSREB1
    Elsif GREP = "D" Then
      Call LOADCPN([M:SRE0]CRESEQ, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 1) From SUBSREB1
    Else
      Call LOADCPN([M:SRE0]SRENUM, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 0) From SUBSREB1
    Endif
  Else                                 # FGR 01/09/2016 : X3SUIVI117427
    Kill GSRE7NBCPN                    # FGR 01/09/2016 : X3SUIVI117427
  Endif                                # FGR 01/09/2016 : X3SUIVI117427
End

##########################################################################################################
# Effectue le contrôle de couverture  d'un composant concerné en classe fichier
###########################################################################
Subprog RECHECKMLC(IPREMACNOL, IERR)
Value Integer IPREMACNOL
Variable Integer IERR

Local Integer IEVRCOV

  IEVRCOV = 0
  IERR = 0
  #Etape 1
  #Si le parc est couvert par un contrat à point, le composant est totalement couvert.
  If [M:SRE7]COVFLG(IPREMACNOL) = 1 Then
    If [M:SRE7]COVSPT(IPREMACNOL) = 1 Then
      If [M:SRE7]COVVCR(IPREMACNOL) <> "" Then
        Read [CON]CON0=[M:SRE7]COVVCR(IPREMACNOL)
        If !fstat Then
          If [F:CON]CONCAT = 4 Then
            #Composant totalement couvert
            Trbegin [SRN]
            [F:SRN]CPNCOVFLG = 1
            [F:SRN]CPNCOVSPT = 1
            [F:SRN]CPNCOVVCR = [M:SRE7]COVVCR(IPREMACNOL)
            [F:SRN]CPNCOVREN = 0
            Rewrite [SRN]
            If fstat Then
              #Erreur lors de la réinitialisation complète de la couverture des composants concernés.
              IERR = 514
              Rollback
            Else
              Commit
            Endif
            End
          Endif
        Endif
      Endif
    Endif
  Endif
  #Etape 2
  #Contrôle de la présence d'au moins un contrat
  Call RECHKNBCON([M:SRE0]SREBPC, [M:SRE7]MAC(IPREMACNOL), IEVRCOV)
  #Aucun contrat souscrit. Pas la peine de continuer
  If IEVRCOV Then
    End
  Endif
  #Etape 3
  #Contrôle de la présence de super contrats toutes compétences et tous articles
  Call RECHECKCON([M:SRE0]SREBPC, [M:SRE7]PBL(IPREMACNOL), [M:SRE7]MAC(IPREMACNOL), IEVRCOV, IERR)
  If IERR Then
    End
  Endif
  #Couvert totalement par un super contrat
  If IEVRCOV Then
    End
  Endif
  #Etape 4
  #Vérification de la couverture détaillée compétences et articles
  Call CHECKCPN("", [M:SRE0]SREBPC, 0, IPREMACNOL, "F", IERR)
  If IERR Then
    End
  Endif
End

##########################################################################################################
# Contrôle de la souscription d'au moins un contrat
###########################################################
Subprog RECHKNBCON(SZBPCCOD, SZMACNUM, ICOVCTL)
Value Char SZBPCCOD
Value Char SZMACNUM
Variable Integer ICOVCTL

Local Integer INBCONREAD
Local Integer ILNDFLG

  # ------------------------------------------
  # Issue X3-74295 - 2018-04-05 by FGR : BEGIN
  Local Char SSPESPCALLER(GLONDES)

  SSPESPCALLER = "RECHKNBCON"
  Gosub PE_CRITCON From TRTCRMPE
  # Issue X3-74295 - 2018-04-05 by FGR : END
  # ------------------------------------------
  ICOVCTL = 0
  INBCONREAD = 0
  ILNDFLG = 0
  If SZMACNUM <> "" Then
    Read [MAC]MAC0=SZMACNUM
    If !fstat Then
      If [F:MAC]MACITNLND = 2 Then
        ILNDFLG = 1
      Endif
    Endif
  Endif
  If ILNDFLG Then
    #Parc en prêt
    If [F:MAC]MACPDTCOD <> "" Then
      Read [ITM]ITM0=[F:MAC]MACPDTCOD
      If !fstat Then
        If [F:ITM]TPLCONLND <> "" Then
          INBCONREAD += 1
        Endif
      Endif
    Endif
  Else
    #Contrôle de la présence d'au moins un contrat
    # Issue X3-74295 - 2018-04-05 by FGR : BEGIN
    #Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2
    Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and evalue([L]SSPECRITCON)
    # Issue X3-74295 - 2018-04-05 by FGR : END
    Columns [CON] (CONNUM)
    For [CON] Hint Key CON4
      INBCONREAD += 1
      Break
    Next
    Filter [CON]
    Columns [CON]
  Endif
  If !INBCONREAD Then
    IEVRCOV = 1
  Endif
End

##########################################################################################################
# Contrôle des couvertures compétences, parc et composant
###########################################################
Subprog RECHECKCON(SZBPCCOD, SZPBLCOD, SZMACCOD, IEVRCOV, IERR)
Value Char SZBPCCOD
Value Char SZPBLCOD
Value Char SZMACCOD
Variable Integer IEVRCOV
Variable Integer IERR

Local Integer IEXTERNALMAC
Local Integer INBCONREAD
Local Date DLNDENDDAT
Local Char SZCOVCASE
Local Char SZCOVVCR
Local Char SZCOVTYP
Local Integer IEVRPBL
Local Integer IEVRMAC
Local Integer ILNDFLG

  SZCOVCASE = ""
  IEVRCOV = 0
  IEVRPBL = 0
  IEVRMAC = 0
  INBCONREAD = 0
  SZCOVVCR = ""
  IERR = 0
  ILNDFLG = 0
  SZCOVTYP = ""
  IEXTERNALMAC = 0
  #On détermine le cas à traiter
  If SZPBLCOD = "" Then
    If SZMACCOD = "" Then
      SZCOVCASE = "00"
    Else
      SZCOVCASE = "01"
    Endif
  Else
    If SZMACCOD = "" Then
      SZCOVCASE = "10"
    Else
      SZCOVCASE = "11"
    Endif
  Endif
  #Parc en prêt
  If SZMACCOD <> "" Then
    Read [MAC]MAC0=SZMACCOD
    If !fstat Then
      If [F:MAC]MACITNLND = 2 Then
        ILNDFLG = 1
      Endif
      If [F:MAC]BPCNUM <> "" Then
        If SZBPCCOD <> "" Then
          If [F:MAC]BPCNUM <> SZBPCCOD Then
            IEXTERNALMAC = 1
          Endif
        Endif
      Endif
    Endif
  Endif
  SZCOVTYP = "CON"
  #Recherche de contrats classiques
  Case SZCOVCASE
    When "00"
      Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONCAT <> 4
    When "01"
      Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONCAT <> 4 and [F:CON]EVRMAC = 2
    When "10"
      Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONCAT <> 4 and [F:CON]EVRPBL = 2
    When "11"
      Filter [CON] Where [F:CON]CONBPC = SZBPCCOD and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONCAT <> 4 and [F:CON]EVRMAC = 2 and [F:CON]EVRPBL = 2
  Endcase
  #On recherche des contrats toutes compétences, tous articles.
  For [CON] Hint Key CON4
    INBCONREAD += 1
    Case SZCOVCASE
      When "00"
        If GSREDEFCOV = 1 Then
          If [F:CON]EVRMAC = 2 Then
            IEVRMAC = 1
          Endif
        Else
          IEVRMAC = 1
        Endif
        If GSREDEFCOV = 1 Then
          If [F:CON]EVRPBL = 2 Then
            IEVRPBL = 1
          Endif
        Else
          IEVRPBL = 1
        Endif
      When "01"
        IEVRMAC = 1
        If GSREDEFCOV = 1 Then
          If [F:CON]EVRPBL = 2 Then
            IEVRPBL = 1
          Endif
        Else
          IEVRPBL = 1
        Endif
      When "10"
        IEVRPBL = 1
        If GSREDEFCOV = 1 Then
          If [F:CON]EVRMAC = 2 Then
            IEVRMAC = 1
          Endif
        Else
          IEVRMAC = 1
        Endif
      When "11"
        IEVRMAC = 1
        IEVRPBL = 1
    Endcase
    If IEXTERNALMAC Then
      IEVRMAC = 0
    Endif
    If IEVRMAC = 1 Then
      If IEVRPBL = 1 Then
        #Contrôle de l'échéance
        If [F:CON]CONENDDAT < date$ Then
          [M:SRE0]CURCOVMEE = 4
        Else
          If [F:CON]CONSTRDAT > date$ Then
            [M:SRE0]CURCOVMEE = 11
          Else
            #Contrôle du réglement du contrat
            SZLITCOD = ""
            Call CHECKPAY([F:CON]CONNUM, [F:CON]CONBPC, SZLITCOD, IEVRCOV)
            If IEVRCOV Then
              SZCOVVCR = [F:CON]CONNUM
              Break
            Else
              #Contrôle de l'existence d'un code litige accepté
              Call CHECKLIT([F:CON]CONNUM, SZLITCOD, 0, IEVRCOV)
              If IEVRCOV Then
                SZCOVVCR = [F:CON]CONNUM
                Break
              Else
                [M:SRE0]CURCOVMEE = 5
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [CON]
  If IEVRCOV Then
    #Tout est couvert
    Trbegin [SRN]
    [F:SRN]CPNCOVFLG = 1
    [F:SRN]CPNCOVSPT = SZCOVTYP
    [F:SRN]CPNCOVVCR = SZCOVVCR
    [F:SRN]CPNCOVREN = 0
    Rewrite [SRN]
    If fstat Then
      #Erreur lors de la réinitialisation complète de la couverture des composants concernés.
      IERR = 514
      Rollback
    Else
      Commit
    Endif
    End
  Endif
  #Contrat de prêt
  If ILNDFLG Then
    #Parc en prêt
    SZCOVTYP = "COT"
    Read [ITM]ITM0=[F:MAC]MACPDTCOD
    If !fstat Then
      If [F:ITM]TPLCONLND <> ""
        Read [COT] COT0 = [F:ITM]TPLCONLND
        If !fstat Then
          INBCONREAD += 1
          Case SZCOVCASE
            When "01"
              If [F:COT]EVRMAC = 2 Then
                IEVRMAC = 1
              Endif
              If GSREDEFCOV = 1 Then
                If [F:COT]EVRPBL = 2 Then
                  IEVRPBL = 1
                Endif
              Else
                IEVRPBL = 1
              Endif
            When "10"
              If [F:COT]EVRPBL = 2 Then
                IEVRPBL = 1
              Endif
              If GSREDEFCOV = 1 Then
                If [F:COT]EVRMAC = 2 Then
                  IEVRMAC = 1
                Endif
              Else
                IEVRMAC = 1
              Endif
            When "11"
              If [F:COT]EVRMAC = 2 Then
                IEVRMAC = 1
              Endif
              If [F:COT]EVRPBL = 2 Then
                IEVRPBL = 1
              Endif
          Endcase
          If IEVRMAC = 1 Then
            If IEVRPBL = 1 Then
              #Contrôle de l'échéance
              If [F:MAC]MACITNDAT <> [00/00/00] Then
                Call SETENDDAT([F:MAC]MACITNDAT, [F:COT]REWFRY, [F:COT]REWFRYBAS, DLNDENDDAT) From SUBCOND
                If DLNDENDDAT >= date$ Then
                  IEVRCOV = 1
                  SZCOVVCR = [F:COT]CONNUM
                Endif
              Else
                IEVRCOV = 1
                SZCOVVCR = [F:COT]CONNUM
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
    If IEVRCOV Then
      #Tout est couvert
      Trbegin [SRN]
      [F:SRN]CPNCOVFLG = 5
      [F:SRN]CPNCOVSPT = SZCOVTYP
      [F:SRN]CPNCOVVCR = SZCOVVCR
      [F:SRN]CPNCOVREN = 0
      Rewrite [SRN]
      If fstat Then
        #Erreur lors de la réinitialisation complète de la couverture des composants concernés.
        IERR = 514
        Rollback
      Else
        Commit
      Endif
      End
    Endif
  Endif
End

##########################################################################################################
# Contrôle des couvertures compétences, parc et composant
###########################################################
Subprog CHKCONCON(SZBPCCOD, SZPBLCOD, SZMACCOD, SZCONCOD, SZCONTEXT, INOL, IEVRCOV)
Value Char SZBPCCOD
Value Char SZPBLCOD
Value Char SZMACCOD
Value Char SZCONCOD
Value Char SZCONTEXT
Value Integer INOL
Variable Integer IEVRCOV

Local Integer IEXTERNALMAC
Local Integer INBCONREAD
Local Date DLNDENDDAT
Local Char SZCOVCASE
Local Char SZCOVVCR
Local Char SZCOVTYP
Local Integer IEVRPBL
Local Integer IEVRMAC
Local Integer IERR

  SZCOVCASE = ""
  IEVRCOV = 0
  IEVRPBL = 0
  IEVRMAC = 0
  INBCONREAD = 0
  SZCOVVCR = ""
  IERR = 0
  SZCOVTYP = ""
  IEXTERNALMAC = 0
  #Parc en prêt
  If SZMACCOD <> "" Then
    Read [MAC]MAC0=SZMACCOD
    If !fstat Then
      If [F:MAC]BPCNUM <> "" Then
        If SZBPCCOD <> "" Then
          If [F:MAC]BPCNUM <> SZBPCCOD Then
            IEXTERNALMAC = 1
          Endif
        Endif
      Endif
    Endif
  Endif
  #On détermine le cas à traiter
  If SZPBLCOD = "" Then
    SZCOVCASE = "01"
  Else
    SZCOVCASE = "11"
  Endif
  SZCOVTYP = "CON"
  Read [CON]CON0=SZCONCOD
  If !fstat Then
    INBCONREAD += 1
    Case SZCOVCASE
      When "01"
        If [F:CON]CONCAT <> 4 Then
          If [F:CON]EVRMAC = 2 Then
            IEVRMAC = 1
          Endif
          If GSREDEFCOV = 1 Then
            If [F:CON]EVRPBL = 2 Then
              IEVRPBL = 1
            Endif
          Else
            IEVRPBL = 1
          Endif
        Endif
      When "11"
        If [F:CON]CONCAT <> 4 Then
          If [F:CON]EVRMAC = 2 Then
            IEVRMAC = 1
          Endif
          If [F:CON]EVRPBL = 2 Then
            IEVRPBL = 1
          Endif
        Endif
    Endcase
    If IEXTERNALMAC Then
      IEVRMAC = 0
    Endif
    If IEVRMAC = 1 Then
      If IEVRPBL = 1 Then
        #Contrôle de l'échéance
        If [F:CON]CONENDDAT < date$ Then
          IEVRCOV = 0
        Else
          If [F:CON]CONSTRDAT > date$ Then
            IEVRCOV = 0
          Else
            #Contrôle du réglement du contrat
            SZLITCOD = ""
            Call CHECKPAY([F:CON]CONNUM, [F:CON]CONBPC, SZLITCOD, IEVRCOV)
            If IEVRCOV Then
              SZCOVVCR = [F:CON]CONNUM
            Else
              #Contrôle de l'existence d'un code litige accepté
              Call CHECKLIT([F:CON]CONNUM, SZLITCOD, 0, IEVRCOV)
              If IEVRCOV Then
                SZCOVVCR = [F:CON]CONNUM
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  If IEVRCOV Then
    #Tout est couvert
    Case SZCONTEXT
      When "MAC"
        [M:SRE7]COVFLG(INOL) = 1
        [M:SRE7]COVSPT(INOL) = 1
        [M:SRE7]COVVCR(INOL) = SZCONCOD
      When "CPN"
        [M:SRE7]CPNCOVFLG(INOL) = 1
        [M:SRE7]CPNCOVSPT(INOL) = 1
        [M:SRE7]CPNCOVVCR(INOL) = SZCONCOD
    Endcase
    End
  Endif
  If SZCOVCASE = "00" Then
    If INBCONREAD Then
      Case SZCONTEXT
        When "MAC"
          [M:SRE7]COVFLG(INOL) = 1
          [M:SRE7]COVSPT(INOL) = 1
          [M:SRE7]COVVCR(INOL) = SZCONCOD
        When "CPN"
          [M:SRE7]CPNCOVFLG(INOL) = 1
          [M:SRE7]CPNCOVSPT(INOL) = 1
          [M:SRE7]CPNCOVVCR(INOL) = SZCONCOD
      Endcase
    Endif
    End
  Endif
End

##########################################################################################################
# Détermine le statut de couverture d'un contrat de service vis à vis d'une fiche parc.
###########################################################################
Subprog COVERMCON(INOL, SZMACNUM, SZCONNUM, IERRINF)
Value Integer INOL
Value Char SZMACNUM
Value Char SZCONNUM
Variable Integer IERRINF

Local Integer IERR
Local Integer IEVRCOV

  IERRINF = 0
  #On part d'une situation Non couverte
  [M:SRE7]COVFLG(INOL) = 3
  [M:SRE7]COVSPT(INOL) = 6
  [M:SRE7]COVVCR(INOL) = ""
  IERR = 0
  IEVRCOV = 0
  If [M:SRE0]SREBPC = "" Then
    #Aucun code client n'est indiqué. Le contrôle de couverture est abandonné.
    IERRINF = 517
    End
  Endif
  If SZMACNUM = "" Then
    #Aucun chrono de fiche parc n'est précisé. Le contrôle de couverture est abandonné.
    IERRINF = 568
    End
  Endif
  If SZCONNUM = "" Then
    #Aucun contrat de service n'est précisé. Le contrôle de couverture est abandonné.
    IERRINF = 569
    End
  Endif
  #Etape 1 : Suppression des couvertures par point
  Call DELPITCOV([M:SRE0]SREGREP, 1, INOL, IERRINF)
  If IERRINF Then
    End
  Endif
  #Etape 2
  #Contrôle de la présence de super contrats toutes compétences et tous articles
  Call CHKCONCON([M:SRE0]SREBPC, [M:SRE7]PBL(INOL), [M:SRE7]MAC(INOL), SZCONNUM, "MAC", INOL, IEVRCOV)
  #Couvert totalement par un super contrat
  If IEVRCOV = 1 Then
    End
  Endif
  #Etape 3
  #Vérification de la couverture détaillée compétences et articles
  Call CHECKCCV(SZCONNUM, [M:SRE0]SREBPC, 1, INOL)
  #Etape 4
  #Recherche de contrats à points
  Call CHECKPIT(SZCONNUM, [M:SRE0]SREBPC, 1, INOL, IERRINF)
  If IERRINF Then
    #Erreur lors de la réinitialisation des informations de couverture. Le contrôle de couverture est abandonné.
    End
  Endif
End

##########################################################################################################
# Détermine le statut de couverture d'un contrat de service vis à vis d'un composant de parc.
###########################################################################
Subprog COVERMCCON(INOL, IPREMACNOL, SZMACNUM, SZCPNNUM, SZCONNUM, IERRINF)
Value Integer INOL
Value Integer IPREMACNOL
Value Char SZMACNUM
Value Char SZCPNNUM
Value Char SZCONNUM
Variable Integer IERRINF

Local Integer IERR
Local Integer IEVRCOV

  IERRINF = 0
  #On part d'une situation Non couverte
  [M:SRE7]CPNCOVFLG(INOL) = 3
  [M:SRE7]CPNCOVSPT(INOL) = 6
  [M:SRE7]CPNCOVVCR(INOL) = ""
  IERR = 0
  IEVRCOV = 0
  If [M:SRE0]SREBPC = ""  Then
    #Aucun code client n'est indiqué. Le contrôle de couverture est abandonné.
    IERRINF = 517
    End
  Endif
  If SZMACNUM = "" Then
    #Aucun chrono de fiche parc n'est précisé. Le contrôle de couverture est abandonné.
    IERRINF = 568
    End
  Endif
  If SZCPNNUM = "" Then
    #Aucun composant n'est précisé. Le contrôle de couverture est abandonné.
    IERRINF = 572
    End
  Endif
  If SZCONNUM = "" Then
    #Aucun contrat de service n'est précisé. Le contrôle de couverture est abandonné.
    IERRINF = 569
    End
  Endif
  #Etape 1
  #Si le parc est couvert par un contrat à point, le composant est totalement couvert.
  If [M:SRE7]COVFLG(IPREMACNOL) = 1 Then
    If [M:SRE7]COVSPT(IPREMACNOL) = 1 Then
      If [M:SRE7]COVVCR(IPREMACNOL) <> "" Then
        Read [CON]CON0=[M:SRE7]COVVCR(IPREMACNOL)
        If !fstat Then
          If [F:CON]CONCAT = 4 Then
            #Composant totalement couvert
            [M:SRE7]CPNCOVFLG(INOL) = 1
            [M:SRE7]CPNCOVSPT(INOL) = 1
            [M:SRE7]CPNCOVVCR(INOL) = [M:SRE7]COVVCR(IPREMACNOL)
            [M:SRE7]CPNCOVCLA(INOL) = ""
            [M:SRE7]CPNCOVREN(INOL) = 0
            End
          Endif
        Endif
      Endif
    Endif
  Endif
  #Etape 2
  #Contrôle de la présence de super contrats toutes compétences et tous articles
  Call CHKCONCON([M:SRE0]SREBPC, [M:SRE7]PBL(IPREMACNOL), [M:SRE7]MAC(IPREMACNOL), SZCONNUM, "CPN", INOL, IEVRCOV)
  #Couvert totalement par un super contrat
  If IEVRCOV = 1 Then
    End
  Endif
  #Etape 3
  #Vérification de la couverture détaillée compétences et articles
  Call CHECKCPN(SZCONNUM, [M:SRE0]SREBPC, INOL, IPREMACNOL, "M", IERR)
  If IERR Then
    End
  Endif
End

