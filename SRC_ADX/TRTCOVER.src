##########################################################################################################
#Couverture maitre d'une famille commerciale de produit indépendante
$MACCIA000
  If ILINEFLG Then
    ITER2 = INOL
    INBMAC = INOL
  Else
    ITER2 = 0
    INBMAC = [M:SRE7]NBMAC-1
  Endif
  For ITER = ITER2 To INBMAC
    If [M:SRE7]LND(ITER) = 2 Then
      Read [MAC]MAC0=[M:SRE7]MAC(ITER)
      If !fstat Then
        If [F:MAC]MACPDTCOD <> "" Then
          Read [ITM]ITM0=[F:MAC]MACPDTCOD
          If !fstat Then
            If [F:ITM]TPLCONLND <> "" Then
              If [F:CCV]CONNUM = [F:ITM]TPLCONLND Then
                If [M:SRE7]PBL(ITER) = "" or [F:COT]EVRPBL = 2 Then
                  If [M:SRE7]COVFLG(ITER) <> 1 Then
                    If [F:ITM]TSICOD(GFAMCIA - 1) = [F:LNK]CMT Then
                      DMACITNDAT = [F:MAC]MACITNDAT
                      Gosub CHKCIACOMCOV
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Else
      If !ICCVMODE Then
        If [M:SRE7]PBL(ITER) = "" or [F:CON]EVRPBL = 2 Then
          If [M:SRE7]COVFLG(ITER) <> 1 Then
            Read [MAC]MAC0=[M:SRE7]MAC(ITER)
            If !fstat Then
              If [F:MAC]MACPDTCOD <> "" Then
                Read [ITM]ITM0=[F:MAC]MACPDTCOD
                If !fstat Then
                  If [F:ITM]TSICOD(GFAMCIA - 1) = [F:LNK]CMT Then
                    If [F:MAC]BPCNUM <> "" Then
                      If SZBPCCOD <> "" Then
                        If [F:MAC]BPCNUM = SZBPCCOD Then
                          Gosub CHKCIACOMCOV
                        Endif
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
Return

