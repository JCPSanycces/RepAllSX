If clalev([F:SLF]) = 0 : Local File STOLOTFCY  [SLF] : Endif
If clalev([F:STL]) = 0 : Local File STOLOT     [STL] : Endif
If clalev([F:STLP])= 0 : Local File STOLOT     [STLP]: Endif
If clalev([F:SLFP])= 0 : Local File STOLOTFCY  [SLFP]: Endif
If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:STOP])= 0 : Local File STOCK      [STOP]: Endif
