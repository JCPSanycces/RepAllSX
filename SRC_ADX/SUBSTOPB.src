Endif

Return

###########################################################
# Met à jour les champs EXYQQQSTA et EXYRRRSTA 
# de la table TABSTASTO [TST]
# Appelée sur "OK" et au chargement du tableau
###########################################################
$MAJ_TST
If GHISTO 
   Return
Endif

Local Integer I
Trbegin [TST]
GOK = 1
For I = 0 To [M:DIA]NBLIG-1
  Readlock [TST]TST0=[M:DIA]STASTO(I)
    Case fstat
      When 0 :
        [F:TST]EXYQQQSTA = [M:DIA]NEWSTAQQQ(I)
        [F:TST]EXYRRRSTA = [M:DIA]NEWSTARRR(I)
        Rewrite [TST]
          If fstat 
            GOK = 0
            Call FSTA("TST") From GLOCK
            Break
          Endif
      When 1 :
         GOK = -1
         Break  
      When Default :
         GOK = 0
         Call FSTA("TST") From GLOCK
         Break
    Endcase
Next I
If GOK = 1 
  Commit
Else
  Rollback
Endif
Return

############################################################
Subprog ECR_TRACE(LMSG,LERR,LSIM)
Value Char    LMSG
Value Integer LERR
Value Integer LSIM
If LSIM = 2
  Call ECR_TRACE("("+mess(2,395,1)+")"-LMSG,LERR) From GESECRAN
Else
  Call ECR_TRACE(LMSG,LERR) From GESECRAN
Endif
End
###########################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
Return

