[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_HRSPER
Gosub DECLARE_VAR From WMC0CONTEXT
[L]CURPRO = "HRSPER"
$_LNKPRO_HRSPER
Return


####################################################################
# 30 : FLGSIMDET Detail ( Field Local menu number 1)
####################################################################

$SET_FLGSIMDET
If [L]_AOLDVAL<>this.FLGSIMDET
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_FLGSIMDET
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.FLGSIMDET
 Gosub PROPAGATE_FLGSIMDET
Endif
Return

$INIT_FLGSIMDET
Gosub DECLARE_VAR From WMC0CONTEXT
[L]CURPRO = "FLGSIMDET"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.FLGSIMDET=0 and fmet this.AGETATTRIBUTE("FLGSIMDET","$isMandatory")="true"
 this.FLGSIMDET = 1
Endif
Return
 
$CONTROL_FLGSIMDET
Gosub DECLARE_VAR From WMC0CONTEXT
[L]CURPRO = "FLGSIMDET"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_FLGSIMDET             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_FLGSIMDET             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_FLGSIMDET
[L]CURPRO = "FLGSIMDET"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.FLGSIMDET=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_FLGSIMDET
[L]CURPRO = "FLGSIMDET"
If this.FLGSIMDET<0 or this.FLGSIMDET>len(mess(0,1,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"1 ->"-num$(this.FLGSIMDET)-mess(99,123,1)):  Return : # Local menu "1 -> Invalid option
Endif
Return

$_AOTHERS_FLGSIMDET
[L]CURPRO = "FLGSIMDET"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_FLGSIMDET
[L]CURPRO = "FLGSIMDET"
Return

$PROPAGATE_FLGSIMDET
this.isReadonly = 0
[L]CURPRO = "FLGSIMDET"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_FLGSIMDET
Gosub DECLARE_VAR From WMC0CONTEXT
[L]CURPRO = "FLGSIMDET"
$_LNKPRO_FLGSIMDET
Return




