#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char PARAM(250)(1..3)
PARAM(1) = "2"
PARAM(2) = "14"
Call S_TAB_NUM(GBIDD1,PARAM,"SAILIB1","GESECRAN","") From GACTION
End

#########################################################################
$ACTION
Case ACTION
 When "SEL_LISTE"  : Gosub S_LIB
 When "VERF_LISTE" : Gosub V_LIB
 When "SEL_TABLE"
  Case TABLE
   When Default    : Gosub S_TAB
  Endcase
 When "BOUT_TABLE"
  Case TABLE
   When Default
    Case GSTATUT
     When GSTASVG  : Gosub SVG_TAB
     When GSTAPRG  : Gosub PRG_TAB
    Endcase
  Endcase
 When "FIN_TABLE"
  Case TABLE
   When Default    : Gosub F_TAB
  Endcase
 When "TITRE"      : Gosub TIT
Endcase
Return

##############
$TIT
Case OPERATION
 When "DIALO"     : TIT = TITDIA
 When "AFFICHE"   : TIT = TITAFF
 When "TEMPON"    : TIT = OPE
 When "VISUAMK"   : TIT = mess(107,100,1)-MASQUE-nomap : # Visu écran
 When "VALIDCAR"  : TIT = TITVLC : [M] = [L]
Endcase
Return

################################################################
## Action SAILIB2 : Choix d'un menu local (dans une autre appli)
################################################################

$S_LIB
Gosub OUVRE
If NOLIB=0 : Return : Endif
NBTEX = 0
For [AST]CLE Where LAN=GLANGUE & LANCHP=NOLIB
 If NBTEX>0 | [F:AST]LANNUM>0
  NBTEX += 1
  TEX(NBTEX)   = num$([F:AST]LANNUM)
  TEXTE(NBTEX) = [F:AST]LANMES
 Endif
Next AST
Return

$V_LIB
PARAM(1) = num$(VALEUR)
Return

################################################################
## Action SAILIB1 : Variante SEL_TABLE en VTB
################################################################

$S_TAB
Gosub OUVRE
If NOLIB=0 : Return : Endif
Local Char    WDES(GLONDES)(1..GNBSEL)
Local Integer WNUM(1..GNBSEL)
Local Char    FILTRE(250) , CLELIB(GLONID) , CHAINE(GLONID)
Local Integer SUITE
Local File   (Integer NUM , Char DES(GLONDES)) From Variable WNUM , WDES As [FIC]
Default File [FIC]
ORDRE = "NUM"
NBCOL  = 1 : COL(NBCOL) = "[F:FIC]NUM" : COLTYP(NBCOL) = type([F:FIC]NUM) : TIT(NBCOL) = mess(80,123,1)
NBCOL += 1 : COL(NBCOL) = "[F:FIC]DES" : COLTYP(NBCOL) = type([F:FIC]DES) : TIT(NBCOL) = mess(201,124,1)
FILTRE = "1=1"
CLELIB = "LANNUM"
Gosub CHARGE
Return

$CHARGE
Raz J, SUITE
Filter [AST] Where LAN=GLANGUE & LANCHP=NOLIB & LANNUM>0 & evalue(FILTRE) Order With CLELIB
For [AST]
 If J>=dim(WNUM)
  SUITE = 1 : Break
 Endif
 J += 1
 WNUM(J) = [F:AST]LANNUM
 WDES(J) = [F:AST]LANMES
Next AST
Filter [AST]
For I=J+1 To GNBSEL
 WNUM(I) = 9999
Next I
adxmxl = J
Return

$SVG_TAB
If !SUITE
 Return
Elsif adxmxl
 FILTRE = 'LANNUM>'+num$(WNUM(adxmxl))
Else
 FILTRE = "1=1"
Endif
Gosub CHARGE
Return

$PRG_TAB
FILTRE = 'LANNUM<'+num$(WNUM(1))
Call CHANGE_SENS(CLELIB,CHAINE) From GOBJACT
CLELIB = CHAINE
Gosub CHARGE
If adxmxl
 FILTRE = 'LANNUM>='+num$(WNUM(adxmxl))
Else
 FILTRE = "1=1"
Endif
Call CHANGE_SENS(CLELIB,CHAINE) From GOBJACT
CLELIB = CHAINE
Gosub CHARGE
Return

$F_TAB
PARAM(1) = num$(VALEUR)
Return

$OUVRE
Local Integer NOLIB
Local Char    DOSSIER(200)
If val(num$(VALEUR))=0
 If type(VALEUR)>10
  VALEUR = PARAM(1)
 Else
  VALEUR = val(PARAM(1))
 Endif
Endif
NOLIB   = val(PARAM(2))
DOSSIER = PARAM(3)
If DOSSIER<>""
 Local File =DOSSIER+".AMENLOC" [AML]
 Local File =DOSSIER+".APLSTD"  [AST]
 Local File =DOSSIER+".APLSTD"  [AST4]
 Local File =DOSSIER+".APLSTD"  [AST5]
 Local File =DOSSIER+".APLSTD"  [AST6]
Else
 Local File AMENLOC [AML]
 Local File APLSTD  [AST]
 Local File APLSTD  [AST4]
 Local File APLSTD  [AST5]
 Local File APLSTD  [AST6]
Endif
Link [AML]  With [AST4]CLE = [F:AML]MENLOC;0;GLANGUE
&              , [AST5]CLE = 0;[F:AML]MENLOC;GLANGUE
&              , [AST6]CLE = 200;([F:AML]MENLOC-200);GLANGUE
& As [AML_]
& Order By Key MENLOC
Read [AML_]MENLOC = NOLIB
TIT =  string$([F:AML]MENLOC<100&[F:AML]MENLOCAL=2,[F:AST5]LANMES)
TIT -= string$([F:AML]MENLOC>200&[F:AML]MENLOCAL=2,[F:AST6]LANMES)
TIT -= string$([F:AML]MENLOCAL<>2,[F:AST4]LANMES)
Return

#########################################################################
Subprog ABORT(OK)
Variable Integer OK
Local Char ZONS(20)
ZONS = zonsor+"("+num$(indice)+")"
# Abandon de l'opération en cours ?
Call YESNO(mess(51,100,1),OK) From GESECRAN
If OK=1 : zonsui = ZONS : Endif
End

#########################################################################
Subprog ABANDON(OK)
Variable Integer OK
Local Char ZONS(20)
ZONS = zonsor+"("+num$(indice)+")"
Call OUINON(mess(51,100,1),OK) : # Abandon de l'opération en cours ?
If OK=1 : zonsui = ZONS : Endif
End

#####################################################
Subprog SAILIB(NOLIB,VALEUR)
Value    Integer NOLIB
Variable Integer VALEUR

Local Integer NBLIB , I , OVALEUR , TBPOS(150)
Local Char    TBLIB(50)(150)
Local Char    TIT(50) , ABREV(150)

OVALEUR = VALEUR
If NOLIB<=0
 End : # Y'a plus d'imprimantes
Else
 ABREV = mess(0,NOLIB,1)
 NBLIB = 0
 For I=1 To len(ABREV)
  If !(I<=dim(GMENLOC) & GMENLOC(I)=1)
   NBLIB += 1
   TBLIB(NBLIB) = mess(I,NOLIB,1)
   TBPOS(NBLIB) = I
  Endif
  If VALEUR=I : VALEUR = NBLIB : Endif
 Next I
 If NOLIB<100
  TIT = mess(NOLIB,0,1)
 Else
  TIT = mess(NOLIB-200,200,1)
 Endif
Endif

Call SAITEX(NBLIB,TBLIB,VALEUR,TIT)
If VALEUR=0    : VALEUR = OVALEUR : mkstat = 2
Elsif NOLIB<=0 : VALEUR = TBIMP(VALEUR)
Else           : VALEUR = TBPOS(VALEUR)
Endif
End

#########################################################
Subprog SAITEX(NBLIB,TBLIB,VALEUR,TIT)
Value    Integer NBLIB
Value    Char    TBLIB()
Variable Integer VALEUR
Value    Char    TIT()
Local Integer NBCOL
Onerrgo ERDIM
NBCOL = dim(TBLIB,2)
Onerrgo
NBCOL = min(dim(TIT)-1,NBCOL)
If NBCOL<=0
 Selbox TBLIB(1..NBLIB) Titled TIT  Using VALEUR
 If status=7 : VALEUR = 0 : Endif
Else
 Call SAITEX_COL(NBLIB,TBLIB,VALEUR,TIT)
Endif
End

#########################################################
Subprog SAITEX2(NBLIB,TBLIB,VALEUR,TIT)
Value Integer NBLIB
Value Char TBLIB()(),TIT()
Variable Integer VALEUR
If NBLIB<=0 : End : Endif
Local Char    TLIB(60)(1..NBLIB)
Local Integer I
For I=1 To NBLIB
 If I<=26
  TLIB(I) = chr$(64+I)-TBLIB(I)
 Elsif I<=36
  TLIB(I) = chr$(47+I)-TBLIB(I)
 Else
  TLIB(I) = "-"-TBLIB(I)
 Endif
Next I
Call SAITEX(NBLIB,TBLIB,VALEUR,TIT)
End

#######################################################################################
Subprog SAITEX_COL_MAX(NLIB,VLIB,VALEUR,TIT,SIZCOL,SIZLIG)
Value Integer NLIB
Value Char    VLIB()(1..,1..)
Variable Integer VALEUR
Value Char    TIT()(0..)
Goto SAITEX_C

#######################################################################################
Subprog SAITEX_COL(NLIB,VLIB,VALEUR,TIT)
Value Integer NLIB
Value Char    VLIB()(1..,1..)
Variable Integer VALEUR
Value Char    TIT()(0..)
Local Integer SIZCOL , SIZLIG
SIZCOL = 240
SIZLIG = 80

$SAITEX_C
Local Shortint   DIME , TYP , NBCOL
DIME = dim(VLIB)
TYP = type(VLIB)-10
Local Integer I , J , K
Local Integer WNUM(1..DIME)
Local Char    WDES1(TYP)(1..DIME) , WDES2(TYP)(1..DIME) , WDES3(TYP)(1..DIME)
Local Char    WDES4(TYP)(1..DIME) , WDES5(TYP)(1..DIME)
Local Char    CRIRAP(250) , CRITRAP(250) , CRITCAR(250) , CAR(1)
Local Char    SAIRAP(30)(1..5)
Local Integer ICRITRAP
Local Char    RAPVAR(50) , RAPCAR(50) , REFRAP(50) , SIGRAP(2)
Onerrgo ERDIM
NBCOL = dim(VLIB,2)
Onerrgo
NBCOL = min(dim(TIT)-1,NBCOL)
If NBCOL<=0
 End
Endif
Case NBCOL
 When 1
  Local File   (Integer NUM , Char DES1(TYP)) From Variable WNUM , WDES1 As [FIC]
 When 2
  Local File   (Integer NUM , Char DES1(TYP) , Char DES2(TYP)) From Variable WNUM , WDES1 , WDES2 As [FIC]
 When 3
  Local File   (Integer NUM , Char DES1(TYP) , Char DES2(TYP) , Char DES3(TYP))
& From Variable WNUM , WDES1 , WDES2 , WDES3 As [FIC]
 When 4
  Local File   (Integer NUM , Char DES1(TYP) , Char DES2(TYP) , Char DES3(TYP) , Char DES4(TYP))
& From Variable WNUM , WDES1 , WDES2 , WDES3 , WDES4 As [FIC]
 When Default
  Local File   (Integer NUM , Char DES1(TYP) , Char DES2(TYP) , Char DES3(TYP) , Char DES4(TYP)
&  , Char DES5(TYP)) From Variable WNUM , WDES1 , WDES2 , WDES3 , WDES4 , WDES5 As [FIC]
Endcase
Default File [FIC]
For I=1 To NLIB
 WNUM(I) = I
 Case NBCOL
  When 1
   WDES1(I) = VLIB(I,1)
  When 2
   WDES1(I) = VLIB(I,1)
   WDES2(I) = VLIB(I,2)
  When 3
   WDES1(I) = VLIB(I,1)
   WDES2(I) = VLIB(I,2)
   WDES3(I) = VLIB(I,3)
  When 4
   WDES1(I) = VLIB(I,1)
   WDES2(I) = VLIB(I,2)
   WDES3(I) = VLIB(I,3)
   WDES4(I) = VLIB(I,4)
  When Default
   WDES1(I) = VLIB(I,1)
   WDES2(I) = VLIB(I,2)
   WDES3(I) = VLIB(I,3)
   WDES4(I) = VLIB(I,4)
   WDES5(I) = VLIB(I,5)
 Endcase
Next I
For I=NLIB+1 To DIME
 WNUM(I) = 9999999
Next I
adxmxl = NLIB

$TEXCOL
If CRITRAP="" : CRITRAP = "1=1" : Endif
Case NBCOL
 When 1
  Choose [FIC] Where evalue(CRITRAP) Order With "NUM"
& Using [L]SAIRAP(1) = [F:FIC]DES1 Titled TIT(1)
& Sized (SIZLIG,SIZCOL)
& Starting At [F:FIC]NUM>=[L]VALEUR
& Titled TIT(0)
 When 2
  Choose [FIC] Where evalue(CRITRAP) Order With "NUM"
& Using [L]SAIRAP(1) = [F:FIC]DES1 Titled TIT(1)
&     , [L]SAIRAP(2) = [F:FIC]DES2 Titled TIT(2)
& Sized (SIZLIG,SIZCOL)
& Starting At [F:FIC]NUM>=[L]VALEUR
& Titled TIT(0)
 When 3
  Choose [FIC] Where evalue(CRITRAP) Order With "NUM"
& Using [L]SAIRAP(1) = [F:FIC]DES1 Titled TIT(1)
&     , [L]SAIRAP(2) = [F:FIC]DES2 Titled TIT(2)
&     , [L]SAIRAP(3) = [F:FIC]DES3 Titled TIT(3)
& Sized (SIZLIG,SIZCOL)
& Starting At [F:FIC]NUM>=[L]VALEUR
& Titled TIT(0)
 When 4
  Choose [FIC] Where evalue(CRITRAP) Order With "NUM"
& Using [L]SAIRAP(1) = [F:FIC]DES1 Titled TIT(1)
&     , [L]SAIRAP(2) = [F:FIC]DES2 Titled TIT(2)
&     , [L]SAIRAP(3) = [F:FIC]DES3 Titled TIT(3)
&     , [L]SAIRAP(4) = [F:FIC]DES4 Titled TIT(4)
& Sized (SIZLIG,SIZCOL)
& Starting At [F:FIC]NUM>=[L]VALEUR
& Titled TIT(0)
 When 5
  Choose [FIC] Where evalue(CRITRAP) Order With "NUM"
& Using [L]SAIRAP(1) = [F:FIC]DES1 Titled TIT(1)
&     , [L]SAIRAP(2) = [F:FIC]DES2 Titled TIT(2)
&     , [L]SAIRAP(3) = [F:FIC]DES3 Titled TIT(3)
&     , [L]SAIRAP(4) = [F:FIC]DES4 Titled TIT(4)
&     , [L]SAIRAP(5) = [F:FIC]DES5 Titled TIT(5)
& Sized (SIZLIG,SIZCOL)
& Starting At [F:FIC]NUM>=[L]VALEUR
& Titled TIT(0)
Endcase
Case status
 When 0
  [L]VALEUR = 0
 When GSTAESC
 When GSTASRA
  Gosub SELRAP
  Goto TEXCOL
 When GSTASVG,GSTAPRG
  Call MESSAGE(mess(271,139,1)) From GESECRAN : # Pagination non disponible sur ce type de sélection
  Goto TEXCOL
 When Default
  [L]VALEUR = [F:FIC]NUM
Endcase
End

$ERDIM
NBCOL = 0
Resume

$SELRAP
Raz CRITRAP , ICRITRAP
For I=1 To NBCOL
 If [L]SAIRAP(I)<>""
  CRIRAP = ""
  RAPVAR = "[F:FIC]DES"+num$(I)
  SIGRAP = ""
  REFRAP = [L]SAIRAP(I)
  For J=1 To 2
   If find(mid$([L]SAIRAP(I),J,1),"=",">","<")
    SIGRAP += mid$([L]SAIRAP(I),J,1)
    REFRAP = right$([L]SAIRAP(I),J+1)
   Endif
  Next J
  RAPCAR = REFRAP
  J = instr(1,RAPVAR,"+")
  K = instr(1,RAPVAR,"-")
  If J=0 & K<>0
   RAPVAR = left$(RAPVAR,K-1)
  Elsif J<>0 & K=0
   RAPVAR = left$(RAPVAR,J-1)
  Elsif J<>0 & K<>0
   RAPVAR = left$(RAPVAR,min(J,K)-1)
  Endif
  If dim([V]GCASSE)>0 & GCASSE=1
   RAPCAR = toupper(RAPCAR)
   RAPVAR = "toupper("+RAPVAR+")"
  Endif
  K = instr(1,RAPCAR,'"')
  J = instr(1,RAPCAR,"'")
  If K & J
   Repeat
    K = instr(1,RAPCAR,'"')
    If K : RAPCAR = left$(RAPCAR,K-1)+right$(RAPCAR,K+1) : Endif
   Until K=0
  Elsif K
   CAR = "'"
  Else
   CAR = '"'
  Endif
  If RAPCAR<>""
   Case left$(SIGRAP,1)
    When ">","<"
     CRIRAP = RAPVAR+SIGRAP+CAR+RAPCAR+CAR
    When Default
     J = instr(1,RAPCAR,"*")
     K = instr(1,RAPCAR,"?")
     If J or K
      If K or J<>len(RAPCAR)
       If instr(1,RAPVAR,"string$") : # mb 5.5.9 bug 54938
        # Erreur sur critère de sélection
        # L'instruction $1$ ne peut pas être utilisée avec l'instruction $2$ dans un critère de sélection
        Call ERREUR(mess(33,100,1)+":\"+func AFNC.MES2(mess(275,139,1),'"string$"','"pat"')) From GESECRAN
        Raz FILRAP , IFILRAP : Break
       Endif
       CRIRAP = 'pat('+RAPVAR
       If !instr(1,RAPVAR,"(") : CRIRAP += '(0)' : Endif
       If CAR='"'
        CRIRAP += ',"'+RAPCAR+'")=1'
       Else
        CRIRAP += ",'"+RAPCAR+"')=1"
       Endif
      Endif
      If     J & K : J = min(J,K)
      Elsif !J & K : J = K
      Endif
      If J>1
       If CRIRAP<>"" : CRIRAP += "&" : Endif
       If CAR='"'
        CRIRAP += RAPVAR+'>="'+left$(RAPCAR,J-1)+'"'
        CRIRAP += "&"
        CRIRAP += RAPVAR+'<"'+left$(RAPCAR,J-2)+chr$(ascii(mid$(RAPCAR,J-1,1))+1)+'"'
       Else
        CRIRAP += RAPVAR+">='"+left$(RAPCAR,J-1)+"'"
        CRIRAP += "&"
        CRIRAP += RAPVAR+"<'"+left$(RAPCAR,J-2)+chr$(ascii(mid$(RAPCAR,J-1,1))+1)+"'"
       Endif
      Endif
     Else
      If CAR='"'
       CRIRAP = RAPVAR+'="'+RAPCAR+'"'
      Else
       CRIRAP = RAPVAR+"='"+RAPCAR+"'"
      Endif
     Endif
   Endcase
  Endif
  Call ADDCRIT(CRITRAP,ICRITRAP,"CRITRAP",CRIRAP,"&") From GOBJSUB
 Endif
Next I
Return

########################################################################
##  Caractères magiques
##  { \ } : Effectue un saut de ligne
##  { | } : Inhibe le découpage du texte jusqu'au prochaine { | }
##          Un seul { | } inhibe le découpage jusqu'à la fin du texte.
##
##  Remarque : L'impression du caractère { | } n'est donc pas prévu !
########################################################################
$COUPE_TEXTE
Local Integer X, Y, Z
Local Integer NTEX, PTEX, LTEX, FTEX
Local Char    TEX1(250)(1..30)
Local Clbfile TEXC(2)
NTEX = 1
PTEX = 1
LTEX = 1

TEXC = TEX
If dim(TEX)>1
 For X=1 To dim(TEX)-1
  TEXC += "\"+TEX(X)
 Next X
Endif

Repeat
 FTEX = PTEX
 Repeat
  X = instr(FTEX,TEXC,"\")
  Y = instr(FTEX,TEXC,"|")
  If Y<>0 & ((X<>0 & Y<X) | X=0)
   Z = instr(Y+1,TEXC,"|")
   If Z=0
    X = 0
    TEXC = left$(TEXC,Y-1) + right$(TEXC,Y+1)
   Else
    TEXC  = left$(TEXC,Y-1) + seg$(TEXC,Y+1,Z-1) + right$(TEXC,Z+1)
    FTEX = Z-1
   Endif
  Endif
 Until (X<>0 & X<Y) | Y=0 | Z=0
 If X<>0
  TEX1(NTEX) = seg$(TEXC,PTEX,X-1)
  LTEX = max(LTEX,len(TEX1(NTEX)))
  NTEX += 1
  PTEX = X+1
 Else
  TEX1(NTEX) = right$(TEXC,PTEX)
  LTEX = max(LTEX,len(TEX1(NTEX)))
 Endif
Until X=0 | NTEX>=dim(TEX1)
For X=2 To NTEX
 TEX1(X) = TEX1(X)
Next X
Return

#################################################
Subprog WARNING(TEX,OK)
Value    Char    TEX()
Variable Integer OK
Local Char YES(30) , CANCEL(30) , TIT(50)
YES    = mess(268,126,1) : # Continuer
CANCEL = mess(269,126,1) : # Rester sur la page
TIT    = mess(66,123,1)  : # Avertissement
Goto WARNING2

#################################################
Subprog WARNING_CHX(TEX,TIT,YES,CANCEL,OK)
Value    Char    TEX() , TIT , YES , CANCEL
Variable Integer OK

$WARNING2
If (GIMPORT or GSERVEUR) and !GWEBSERV
 If OK=2
  Call MESSAGE(TEX)
 Else
  Call ERREUR(TEX)
 Endif
 End
Elsif GWEBSERV
 OK = 2    # le web server retourne la valeur qu'il a reçue. Et ça devrait être 2.
 If GW_STAT<dim(GW_MESS)
  GW_STAT += 1
  GW_MESS(GW_STAT)  = TEX
  GW_GRAVE(GW_STAT) = 2
 Endif
 End
Elsif GSILENCE
 End
Endif

GPE = 0
GPOINT = "AVERTIR" : Gosub ENTREE From EXEFNC
If GPE : End : Endif

Gosub COUPE_TEXTE
If OK=1 : OK = 2 : Else : OK = 1 : Endif
Wrnbox TEX1(1..NTEX) Titled '{"ok":"'+YES+'","cancel":"'+CANCEL+'"}'+chr$(7)+TIT Using OK
If OK=1 : OK = 2 : Else : OK = 1 : GERR = 99 : Endif
End

################################################################
Subprog AVERTIRT(TEX,OK)
Value    Char    TEX()
Variable Integer OK
Local    Integer TEMPS
TEMPS = 1
Goto AVERTIR2

##################################
Subprog AVERTIR(TEX,OK)
Value    Char    TEX()
Variable Integer OK
Local    Integer TEMPS

$AVERTIR2
If (GIMPORT or GSERVEUR) and !GWEBSERV
 If OK=2
  Call MESSAGE(TEX)
 Else
  Call ERREUR(TEX)
 Endif
 End
Elsif GWEBSERV
 OK = 2    # le web server retourne la valeur qu'il a reçue. Et ça devrait être 2.
 If GW_STAT<dim(GW_MESS)
  GW_STAT += 1
  GW_MESS(GW_STAT)  = TEX
  GW_GRAVE(GW_STAT) = 2
 Endif
 End
Elsif GSILENCE
 End
Endif

GPE = 0
GPOINT = "AVERTIR" : Gosub ENTREE From EXEFNC
If GPE : End : Endif

Gosub COUPE_TEXTE
If OK=1 : OK = 2 : Else : OK = 1 : Endif
If TEMPS & GTIMOUT>0
 Wrnbox TEX1(1..NTEX) Titled mess(66,123,1) Using OK Sleep GTIMOUT : # Avertissement
Else
 Wrnbox TEX1(1..NTEX) Titled mess(66,123,1) Using OK : # Avertissement
Endif
If OK=1 : OK = 2 : Else : OK = 1 : GERR = 99 : Endif
End

#################################################
Subprog YESNO(TEX,OK)
Value    Char    TEX()
Variable Integer OK
Local Char YES(30) , NO(30) , TIT(50)
YES = mess(268,126,1) : # Continuer
NO  = mess(269,126,1) : # Rester sur la page
TIT = mess(67,123,1)  : # Question
Goto YESNO2

###############################################################
Subprog YESNO_CHX(TEX,TIT,YES,NO,OK)
Value    Char    TEX() , TIT , YES , NO
Variable Integer OK

$YESNO2
If (GIMPORT or GSERVEUR) and !GWEBSERV
 OK = 2
 End
Elsif GWEBSERV
 If OK<>1 and OK<>2 : OK=2 : Endif
 If GW_STAT<dim(GW_MESS)
  GW_STAT += 1
  GW_MESS(GW_STAT)  = TEX+"   ("+string$(OK=2,YES)+string$(OK=1,NO)+")"
  GW_GRAVE(GW_STAT) = 2
 Endif
 End
Elsif GSILENCE
 End
Endif

GPE = 0
GPOINT = "OUINON" : Gosub ENTREE From EXEFNC
If GPE : End : Endif

Gosub COUPE_TEXTE
If OK=1 : OK = 2 : Else : OK = 1 : Endif
Qstbox TEX1(1..NTEX) Titled '{"yes":"'+YES+'","no":"'+NO+'"}'+chr$(7)+TIT Using OK
If OK=1 : OK = 2 : Else : OK = 1 : Endif
End

###############################################################
Subprog OUINONT(TEX,OK)
Value    Char    TEX()
Variable Integer OK

Local Integer TEMPS
TEMPS = 1
Goto OUINON2

##################################
Subprog OUINON(TEX,OK)
Value    Char    TEX()
Variable Integer OK
Local Integer TEMPS

$OUINON2

If (GIMPORT or GSERVEUR) and !GWEBSERV
 OK = 2
 End
Elsif GWEBSERV
 If OK<>1 and OK<>2 : OK=2 : Endif
 If GW_STAT<dim(GW_MESS)
  GW_STAT += 1
  GW_MESS(GW_STAT)  = TEX+"   ("+mess(OK,1,1)+")"
  GW_GRAVE(GW_STAT) = 2
 Endif
 End
Elsif GSILENCE
 End
Endif

GPE = 0
GPOINT = "OUINON" : Gosub ENTREE From EXEFNC
If GPE : End : Endif

Gosub COUPE_TEXTE
If OK=1 : OK = 2 : Else : OK = 1 : Endif
If TEMPS & GTIMOUT>0
 Qstbox TEX1(1..NTEX) Titled mess(67,123,1) Using OK Sleep GTIMOUT : # Question
Else
 Qstbox TEX1(1..NTEX) Titled mess(67,123,1) Using OK : # Question
Endif
If OK=1 : OK = 2 : Else : OK = 1 : Endif
End

###############################################
Subprog AFFTEX(NBLIB,TBLIB)
Value Integer NBLIB
Value Char TBLIB()()

# JP le 04/09/93
If GSILENCE : End : Endif

Local Char TEXTE(240)
Local Integer I
TEXTE=TBLIB(1)
For I=2 To NBLIB
 TEXTE+="\"+TBLIB(I)
Next I
Call MESSAGE(TEXTE)
End

#################################################################
# Permet de saisir un champ dans une boîte
#################################################################
Subprog SAICAR(VALEUR,TITDIA,INTZON,CODTYP,NOLIB,LONG,SUPP,OK)
Variable Char VALEUR
Value    Char TITDIA   : # Titre de la boîte
Value    Char INTZON   : # Intitulé du champ saisi
Value    Char CODTYP   : # Type de donnée
Value    Integer NOLIB : # No de menu local (si menu local)
Value    Integer LONG  : # Longueur du champ (si alpha)
Value    Char    SUPP  : # Paramètre objet (clé 2)
Variable Integer OK    : # Saisie validé (OK=2)
Local Char OVALEUR(255)
Local Mask ASAICAR
[M] = [L]
OVALEUR = VALEUR
Call CHARGE([M]VALEUR,[M]CODTYP,[M]NOLIB,[M]LONG,VALEUR) From FMTVAR
Raz OK
While !OK
 Call DIALWIN(OK,TITDIA,"ASAICAR") From GESECRAN
 Case OK
  When 2
   Call CONTROLE([M]VALEUR,[M]CODTYP,[M]NOLIB,[M]LONG,VALEUR) From FMTVAR
   If [M]VALEUR<>"" & CODTYP="ADI" & NOLIB<>0
    Call CONTROLE("ADI","!",[M]VALEUR,num$([M]NOLIB),mkstat) From CONTOBJ
    If mkstat
     Call ERREUR(GMESSAGE) From GESECRAN
     Raz OK , GMESSAGE
     [M]VALEUR = [L]OVALEUR
    Endif
   Endif
  When 1
   [L]VALEUR = [L]OVALEUR
 Endcase
Wend
End

#################################################################
Subprog DIALWIN(OK,TITDIA,WIN)
Variable Integer OK
Value    Char    TITDIA
Value    Char    WIN
Local Integer MAXBOU : MAXBOU = 80                       : # 114910 Nb max de boutons spéciaux
Local    Char    WINPROG(GLONADC) , SAVPROG(GLONADC)
Local    Integer I , MA , NOL
Local    Char    OPERATION(10)
Local    Integer REPONSE, ETABOU(1..GNBBOU) , SAVGOBJET , DROIT , CHGENV
Local    Char    ZONS(20)
Local    Char    ACTION(20)
Local    Char    TEXTE(30)(30) , STDBOUT(30)
Local    Char    CMEN(1)(1..MAXBOU) , TMEN(30)(1..MAXBOU)
Local    Integer NBMEN , NBRMEN , NMEN(1..MAXBOU) , LMEN(1..MAXBOU) :#114910
Local    Integer NBTEX , LBOUT(30)
Local    Char    CBOUT(1)(30) , CBOUTD(1) , BOUT(1)

#  A-t-on le droit de naviguer vers cette action
Local Char MESSAG(100)
Call CNAVIG(2,"","","","",WIN,"",MESSAG) From EXEFNC
If MESSAG<>"" : End : Endif

Call NOMTRTWIN(WIN,WINPROG) From MSKDIV
SAVPROG    = GPROGRAMME
SAVGOBJET  = GOBJET
GOBJET     = 0
GPROGRAMME = "GESECRAN"
OPERATION  = "DIALO"
GPILOBJ   += 1
NOL = nolign

Gosub FILENV From CHGENV
Gosub OUVRE_BOITE From =WINPROG
MA = 1
Gosub SETMASK From =WINPROG
Gosub TITMASK From =WINPROG
Gosub BOUTON  From =WINPROG

If dim([V]GCHGENV)>0
&& ( instr(1,adxpno(3),"EXEFNC")
&  | instr(1,adxpno(3),"GESUSER")
&  | (instr(1,adxpno(2),"WGAFRQTSUB") & instr(1,adxpno(4),"EXEFNC"))
&  | (instr(1,adxpno(2),"WGOABA") & instr(1,adxpno(6),"EXEFNC"))
&  | (instr(1,adxpno(4),"WGAFRQT") & instr(1,adxpno(6),"EXEFNC"))
&  )
 CHGENV=GCHGENV
Endif
DROIT=1
If GPRODUIT=1 & CHGENV & GUSRFCY(1)<>"\" & !find(GFCY,GUSRFCY(1..GNBAUZ)) : ## GEODE
 DROIT=0
Endif

ZONS = zonsui
zonsui = ""
Call SAVBOUT
If CBOUTD<>""
 I = find(CBOUTD,CBOUT(1..NBTEX))
 If I : GSTASPE(1) = LBOUT(I) : Endif
Endif
Affzo
If GCONSDIA=1 or !DROIT
 Grizo
Elsif GCONSDIA=2
 Diszo
Endif
Call AFF_ENV From MENU
zonsui = ZONS
Setmok [M] With 0

$SAI
If find(GCONSDIA,1,2) or !DROIT
 ETABOU(GVALI) = 0
 If CBOUTD<>"" : ETABOU(GSPE1) = 0 : Endif
Else
 ETABOU(GVALI) = 1 : # OK
 If GBATCH
  If CBOUTD<>"" : ETABOU(GSPE1) = 0 : Endif
 Else
  If CBOUTD<>"" : ETABOU(GSPE1) = 1 : Endif : # Différé
 Endif
Endif
ETABOU(GBFIN) = 1 : # Fin
ETABOU(GCHENV)= (CHGENV<>0) : # Chgt d'environnement
Call SETBOUT(ETABOU)

REPONSE = 0
Gosub SAISIE_BOITE From =WINPROG
Case REPONSE
 When GSTAOK  , GSTARET
  OK = 2
  #116752 si bouton desactivé sur fenetre
  If dim(STDBOUT)>0 & !instr(1,STDBOUT,"O")
   OK = 1
  Endif
 When GSTAESC , GSTAEND
  OK = 1
 When GSTAENV
  Call ACT_CHGENV(OK) From GOBJACT
  Call AFF_ENV From MENU
  If OK
   Effzo
   If DROIT & GUSRFCY(1)<>"\" & !find(GFCY,GUSRFCY(1..GNBAUZ))
    DROIT=0 : Grizo
   Elsif !DROIT & (GUSRFCY(1)="\" or find(GFCY,GUSRFCY(1..GNBAUZ)))
    DROIT=1 : Actzo
   Endif
  Endif
  Goto SAI
 When GSTAHLO , GSTABOI
  Goto SAI
 When GSTASPE(1) : # Différé
  If CBOUTD<>""
   BOUT = CBOUTD
   Gosub EXEBOUT From =WINPROG
   Goto SAI
  Endif
  OK = 1
 When Default
  OK = 1
Endcase
Gosub FERME_BOITE From =WINPROG
Call RESTBOUT
GOBJET = SAVGOBJET
GPROGRAMME = SAVPROG
nolign = NOL
GPILOBJ -= 1

If dim(GNBMASKOUV)>0
 GNBMASKOUV-=1
 GNBMASKOUV=max(0,GNBMASKOUV)
Endif

End

####################################################################
Subprog MESCTL(TEXTE,OK)
Value Clbfile TEXTE
Variable Integer OK
Local Mask AFFMES [AFF]
[M]MESSAGE = TEXTE
# Avertissement
Call AFFWIN(mess(66,123,1),"MESCTL") From GESECRAN
If GSTATUT=GSTABOU+1
 OK = 2
Else
 OK = 1
Endif
End

####################################################################
Subprog AFFMES(TEXTE)
Value Clbfile TEXTE
Local Mask AFFMES [AFF]
[M]MESSAGE = TEXTE
# Message
Call AFFWIN(mess(201,124,1),"AFFMES") From GESECRAN
End

####################################################################
Subprog AFFWIN(TITAFF,WIN)
Value Char    TITAFF
Value Char    WIN
Local Integer REPONSE, ETABOU(1..GNBBOU), SAVGOBJET
Local Char    SAVPROG(GLONADC)
Local Char    WINPROG(GLONADC)
Local Integer NOL , MA
Local Char    OPERATION(10)
Local Char    ACTION(20)

Call NOMTRTWIN(WIN,WINPROG) From MSKDIV
SAVPROG    = GPROGRAMME
SAVGOBJET  = GOBJET
GPROGRAMME = "GESECRAN"
GOBJET     = 0
NOL = nolign
OPERATION = "AFFICHE"

Gosub OUVRE_BOITE From =WINPROG
MA = 1
Gosub SETMASK From =WINPROG
Gosub TITMASK From =WINPROG

Call SAVBOUT

Affzo
If WIN="MESCTL"
 ETABOU(GSPE1) = 1
 ETABOU(GSPE2) = 1
Else
 ETABOU(GBFIN) = 1 : # Fin
Endif
Call SETBOUT(ETABOU)
# BY on fait tout ce qu'on peut pour empêcher de saisir
# mais ça ne marchera pas à 100%!!
Onevent
Onevent BEFORE_INPUT Gosub NOSAI From GESECRAN
Onevent BEFORE_AREA  Gosub NOSAI From GESECRAN
Gosub SAISIE_BOITE From =WINPROG
Gosub FERME_BOITE From =WINPROG
GOBJET     = SAVGOBJET
GPROGRAMME = SAVPROG
GSTATUT    = REPONSE
nolign  = NOL
Call RESTBOUT
End

$NOSAI
mkstat = 2
Return

#################################################################
Subprog SAVBOUT
Local Integer I
If GPTBOU<dim(GPILBOU,2)
 For I=1 To GNBBOU
  GPILBOU(I,GPTBOU) = GETABOU(I)
  GETABOU(I) = 2
 Next I
 For I=1 To min(dim(GSTASPE),dim(GPILSTA))
  GPILSTA(I,GPTBOU) = GSTASPE(I)
  GSTASPE(I) = GSTABOU + I
 Next I
 For I=1 To dim(GETAMEN)
  GPILMEN(I,GPTBOU) = GETAMEN(I)
 Next I
 GPTBOU += 1
Endif
End

##################################
Subprog RESTBOUT
Local Integer I , STATBOUT
GPTBOU -= 1
If GPTBOU>=0
 For I=1 To min(dim(GSTASPE),dim(GPILSTA))
  GSTASPE(I) = GPILSTA(I,GPTBOU)
 Next I
 For I=1 To GNBBOU
  Call STATBOUT(I,STATBOUT)
  If GPILBOU(I,GPTBOU)<>GETABOU(I) or STATBOUT>GSTABOU
   GETABOU(I) = GPILBOU(I,GPTBOU)
   If STATBOUT<>0
    Case GETABOU(I)
     When 1 : Enable  STATBOUT
     When 0 : Disable STATBOUT
    Endcase
   Endif
  Endif
 Next I
 For I=1 To dim(GETAMEN)
  GETAMEN(I) = GPILMEN(I,GPTBOU)
  Case GETAMEN(I)
   When 1 : Enable  GSTAITM+I
   When 0 : Disable GSTAITM+I
  Endcase
 Next I
Endif
End

##################################
Subprog SETBOUT(ETABOU)
Value Integer ETABOU(1..)
Local Integer I , STATBOU
For I=1 To dim(ETABOU)
 If ETABOU(I)<>GETABOU(I)
  GETABOU(I) = ETABOU(I)
  Call STATBOUT(I,STATBOU)
  If STATBOU<>0
   Case GETABOU(I)
    When 1 : Enable  STATBOU
    When 0 : Disable STATBOU
   Endcase
  Endif
 Endif
Next I
End

##################################
Subprog STATBOUT(NUMERO,STATBOU)
Value    Integer NUMERO
Variable Integer STATBOU
Local Integer OK , I
Case NUMERO
 When GCREE   : STATBOU = GSTACRE       : # Créer
 When GENRE   : STATBOU = GSTAENR       : # Enregistrer
 When GSUPP   : STATBOU = GSTAANU       : # Supprimer
 When GABAN   : STATBOU = GSTAFIN       : # Abandon
 When GPREM   : STATBOU = GSTAFIR       : # Premier
 When GDERN   : STATBOU = GSTALAS       : # Dernier
 When GSUIV   : STATBOU = GSTASUI       : # Suivant
 When GPREC   : STATBOU = GSTAPRE       : # Précédent
 When GSELE   : STATBOU = GSTASEL       : # Sélection
 When GCHAN   : STATBOU = GSTACHG       : # Changement de code
 When GNOUV   : STATBOU = GSTANEW       : # Nouveau
 When GVALI   : STATBOU = GSTAOK        : # OK / valider
 When GJOIN   : STATBOU = GSTAJOI       : # Pièce jointe
 When GCOMM   : STATBOU = GSTACOM       : # Commentaire
 When GEDIT   : STATBOU = GSTAEDI       : # Impression
 When GLIST   : STATBOU = GSTALIS       : # Liste
 When GDATC   : STATBOU = GSTADAT       : # Date création
 When GTRAN   : STATBOU = GSTATRN       : # Transaction
 When GRAFF   : STATBOU = GSTARAF       : # Raffraîchir
 When GBFIN   : STATBOU = GSTAEND       : # Fin
 When GSTAT   : STATBOU = GSTASTA       : # Statistiques
 When GWORK   : STATBOU = GSTAWOR       : # Workflow
 When GMOTC   : STATBOU = GSTAMOT       : # Sélection mot-clé
 When GLINK   : STATBOU = GSTALNK       : # Liaisons
 When GNBREC  : STATBOU = GSTANBR       : # Nbre de fiches
 When GCHENV  : STATBOU = GSTAENV       : # Chgt environnement
 When GSIGN   : STATBOU = GSTASIG       : # Signature
 When GHSIG   : STATBOU = GSTAHSG       : # Historique signature
 When GCSIG   : STATBOU = GSTACSG       : # Circuit signature
 When Default
  I = 1 : OK = 0
  While evalue("dim(GSPE"+num$(I)+")")>0 : # Boutons spéciaux de 1 à 12
   If NUMERO = evalue("GSPE"+num$(I))
    STATBOU = GSTASPE(I)
    OK = 1 : Break
   Endif
   I += 1
  Wend
  If !OK
   STATBOU = 0                          : # On connait pas
  Endif
Endcase
End

#################################################################
Subprog SET_IMAGE(NUMERO)
Value Integer NUMERO
If GIMPORT | GSERVEUR | GSILENCE
 End
Endif
If NUMERO>0 & NUMERO<=dim(GSTAIMG) & GSTAIMG(NUMERO)<>1
 Gosub NUM_IMAGE
 If IMG>0
  Infimg IMG Titled "" Coded GSTACLK+NUMERO
  GSTAIMG(NUMERO) = 1
 Endif
Endif
End

##################################
Subprog RESET_IMAGE(NUMERO)
Value Integer NUMERO
If GIMPORT | GSERVEUR | GSILENCE
 End
Endif
If NUMERO>0 & NUMERO<=dim(GSTAIMG) & GSTAIMG(NUMERO)<>0
 Gosub NUM_IMAGE
 If IMG>0
  Infimg -IMG Titled ""
  GSTAIMG(NUMERO) = 0
 Endif
Endif
End

$NUM_IMAGE
Local Integer IMG
Case NUMERO
 When 1       : IMG = 260    : # Panneau information (Présence commentaires)
 When 2       : IMG = 238    : # Trombonne (Présence pièces jointes)
 When 3       : IMG = 279    : # Cadenas
 When 4       : IMG = 132    : # Texte (feuille de texte) : # cg 2 novembre 98 gestion des textes
 When 5       : IMG = 146    : # Crayon barré (ancienne croix blanche sur fond rouge) - Lecture seule
 When 6       : IMG = 155    : # Papier accroché à une punaise bleue (mémo en cours)
 When 7       : IMG = 1      : # Bouton sélection (pas mémo) en cours (utilisé seulement en WEB)
 When 8       : IMG = 134    : # Symbole navigation active
 When 9       : IMG = 182    : # Trois boules bleues (memo picking en cours)
 When 10      : IMG = 7      : # Aide
 When 11      : IMG = 54     : # Symbole lecture - Fiche non verrouillée (si option lock en modification activée)
 When Default : IMG = NUMERO : # Pour les distris
Endcase
Return

#################################################################
# Intéressant en mode test (GTEST<>0)
# Afin de supprimer les "Erreur" dans les sources
# De plus peut-être activé à la demande chez un client
#################################################################

Subprog TEST(TEX)
Value Char TEX()
If GTEST & !GSILENCE : Infbox TEX : Endif
End

############################################################
Subprog INFO(TEX,NBTEX,TIT)
Variable Char    TEX()(1..)
Value    Integer NBTEX
Value    Char    TIT
Infbox TEX(1..NBTEX) Titled TIT
End

############################################################
Subprog TEMPON(LOP)
Value Char LOP()

Local Char    WINPROG(GLONADC) , SAVPROG(GLONADC)
Local Integer NOL
Local Char    OPERATION(10)
Local Char    ACTION(20)
Local Char    OPE(100)

Case LOP
 When "V"        : OPE = mess(1,100,1)   : # Validation
 When "F"        : OPE = mess(2,100,1)   : # Vérification
 When "L"        : OPE = mess(3,100,1)   : # Lecture
 When "E"        : OPE = mess(4,100,1)   : # Ecriture
 When "A"        : OPE = mess(5,100,1)   : # Annulation
 When "S"        : OPE = mess(53,123,1)  : # Suppression
 When "R"        : OPE = mess(163,100,1) : # Recherche
 When "C"        : OPE = mess(105,100,1) : # Calcul
 When Default
  If len(LOP)<=1 : OPE = mess(6,100,1)   : # Opération
  Else           : OPE = LOP
  Endif
Endcase

If GSERVEUR | GSILENCE
 End
Elsif GBROWS and GFUSION<>1
 GTEMPON = 1
 If left$(OPE,6)="$$DBG_"
  Infbox OPE
 Else
  Infbox "$$TEMPOPE"+OPE
 Endif
 End
Endif

#Call NOMTRTWIN("TEMPON",WINPROG) From MSKDIV

WINPROG="WGTEMPON"     :# CC 24/10/2011 pour migrations différées sinon boucle
NOL = nolign
SAVPROG    = GPROGRAMME
GPROGRAMME = "GESECRAN"
OPERATION  = "TEMPON"

If clalev([M:GTMP])>0
 Close Global Mask [GTMP]
Endif
Gosub OUVRE_BOITE From =WINPROG
GTEMPON = 1
nolign = NOL
GPROGRAMME = SAVPROG
End

#################################################################
Subprog TEMPOFF

If GSERVEUR | GSILENCE
 End
Elsif GBROWS and GFUSION<>1
 GTEMPON = 0
 Infbox "$$TEMPCLO"
 End
Elsif clalev([M:GTMP])<=0
 End
Endif

Close Global Mask [GTMP]
GTEMPON = 0
End

#################################################################
Subprog OUVRE_BOITE(OPE,NOMBRE)
Value Char    OPE
Value Decimal NOMBRE

If GSERVEUR or GIMPORT or GSILENCE
 End
Elsif GBROWS and GFUSION<>1
 GMAXBOI = NOMBRE
 Global Integer GCOURBOI
 Infbox "$$PROGOPE" Titled OPE
 End
Endif

Local Char    WINPROG(GLONADC) , SAVPROG(GLONADC)
Local Integer NOL
Local Char    OPERATION(10)
Local Char    ACTION(20)

#Call NOMTRTWIN("TEMPON2",WINPROG) From MSKDIV
WINPROG="WGTEMPON2"     :# CC 24/10/2011 pour migrations différées sinon boucle

NOL = nolign
SAVPROG    = GPROGRAMME
GPROGRAMME = "GESECRAN"
OPERATION  = "TEMPON"
If clalev([M:BOI])>0
 Close Global Mask [BOI]
Endif
Gosub OUVRE_BOITE From =WINPROG
Raz [M:BOI]
Gosub AFFBOITE
GPROGRAMME = SAVPROG
nolign = NOL
End

#################################################################
Subprog SET_BOITE(OPE,NOMBRE)
Value Char    OPE
Value Decimal NOMBRE

If GSERVEUR or GIMPORT or GSILENCE
 End
Elsif GBROWS and GFUSION<>1
 GMAXBOI = NOMBRE
 Global Integer GCOURBOI
 Infbox "$$PROGMOD"+num$(NOMBRE)+"^0^"+OPE
 End
Elsif clalev([M:BOI])<=0
 End
Endif

Raz [M:BOI]
Gosub AFFBOITE
End

$AFFBOITE
[M:BOI]MAXI = NOMBRE
[M:BOI]MES  = OPE
Affzo [BOI] : Envzo
Return

#################################################################
Subprog AFF_BOITE(TEXTE,NOMBRE,INTERRUPT)
Value    Char    TEXTE
Value    Decimal NOMBRE
Variable Integer INTERRUPT

If GSERVEUR or GIMPORT or GSILENCE
 End
Elsif GBROWS and GFUSION<>1
 If dim(GMAXBOI)<0 or GMAXBOI=0 or dim(GCOURBOI)<0 : End : Endif
 If fix(NOMBRE*100/GMAXBOI)>GCOURBOI
   Infbox "$$PROGMOD"+num$(GMAXBOI)+"^"+num$(NOMBRE)+"^"+TEXTE
   GCOURBOI=fix(NOMBRE*100/GMAXBOI)
 Endif
 End
Elsif clalev([M:BOI])<=0
 End
Endif

[M:BOI]PCENT = fix(100*NOMBRE/max(1,[M:BOI]MAXI))
If [M:BOI]PCENT>[M:BOI]OPCENT
 [M:BOI]BARRE = [M:BOI]PCENT
 If TEXTE<>""
  [M:BOI]MES = TEXTE
 Endif
 [M:BOI]OPCENT = [M:BOI]PCENT
 If dim([M:BOI]MES2)>0
  Raz [M:BOI]MES2
 Endif
 Affzo [BOI] : Envzo
 If INTERRUPT
 Endif
Endif
End

#################################################################
Subprog FERME_BOITE

If GSERVEUR or GIMPORT or GSILENCE
 End
Elsif GBROWS and GFUSION<>1
 Infbox "$$PROGCLO"
 End
Elsif clalev([M:BOI])<=0
 End
Endif

Close Global Mask [BOI]
End

#################################################################
Subprog ERRTITT(TEX,TIT)
Value    Char    TEX()
Value    Char    TIT()
Local    Integer TRACE , ERR, AFF
TRACE = 0
ERR   = 1
AFF   = 2
Goto ERR2

#################################################################
Subprog ERRTIT(TEX,TIT)
Value    Char    TEX()
Value    Char    TIT()
Local    Integer TRACE , ERR, AFF
TRACE = 0
ERR   = 1
AFF   = 1
Goto ERR2

##################################
Subprog ERREND(TEX)
Value    Char    TEX()
Local    Integer TRACE , ERR, AFF
TRACE = 0
ERR   = 1
AFF   = 3
Local Integer EN_D_SES  : # Pour récupérer les erreurs de connexion meme en Web service
Goto ERR2

##################################
Subprog ERREUR(TEX)
Value    Char    TEX()
Local    Integer TRACE , ERR, AFF
TRACE = 0
ERR   = 1
AFF   = 1

$ERR2
If TEX=""
 End
Elsif GSILENCE
 End
Elsif GWEBSERV and dim(EN_D_SES)<0
 If GW_STAT<dim(GW_MESS)
   GW_STAT += 1
   GW_MESS(GW_STAT)  = TEX
   GW_GRAVE(GW_STAT) = 3
 Endif
 End
Elsif GSERVEUR=1 & GTRACE<>""
 TRACE = 1
 AFF = 0
Endif
Goto ERR_MESS

################################################################
Subprog MESSAGE(TEX)
Value    Char    TEX()
Local    Integer TRACE , ERR, AFF
TRACE = 0
ERR   = 0
AFF   = 1

If GSILENCE
 End
Elsif GWEBSERV
 If GW_STAT<dim(GW_MESS)
  GW_STAT += 1
  GW_MESS(GW_STAT)  = TEX
  GW_GRAVE(GW_STAT) = 1
 Endif
 End
Elsif GSERVEUR=1 & GTRACE<>""
 TRACE = 1
 AFF = 0
Endif

Goto ERR_MESS

#################################################################
Subprog ERREURT(TEX,ERR)
Value    Char    TEX()
Value    Integer ERR   : # 0=Information, <>0=Erreur; retour=status inp
Local    Integer TRACE : # 0=affichage écran, 1=écriture dans une trace
Local    Integer AFF   : # 0=pas d'affichage, 1=affichage, 2=avec tempo, 3=abort à la connexion
TRACE = 0
AFF   = 2

If GSILENCE
 End
Elsif GWEBSERV
 If GW_STAT<dim(GW_MESS)
  GW_STAT += 1
  GW_MESS(GW_STAT)  = TEX
  If ERR=0
    GW_GRAVE(GW_STAT) = 1
  Else
    GW_GRAVE(GW_STAT) = 3
  Endif
 Endif
 End
Elsif GSERVEUR
 TRACE = 1
 AFF   = 0
Endif

Goto ERR_MESS

################################################################
Subprog ECR_TRACE(TEX,ERR)
Value    Char    TEX() : # Texte du message
Value    Integer ERR
Local    Integer TRACE, TEMPO, AFF
TRACE = 1
AFF   = 0
If GTRACE=""
 If GSERVEUR
  End
 Elsif ERR
  Call ERREUR(TEX)
 Else
  Call MESSAGE(TEX)
 Endif
 End
Endif

$ERR_MESS
# mb 1.3.6 cas de l'import si trace non ouverte
If GIMPORT & GTRACE<>""
 TRACE = 1
 AFF = 0
Endif
# BY 29/08/2005 pour ne pas bloquer une transaction
If adxlog & AFF=1
 AFF = 2
Endif
#
If dim([L]TIT)<=0 or [L]TIT=""
 Local Char TIT(50)
 If dim(GVTMOD)>0 & GVTMOD
  If AFF=3 or ERR
   TIT = mess(6,123,1) : # Erreur
  Else
   TIT = mess(201,124,1) : # Message
  Endif
 Elsif AFF=3
  TIT = mess(194,133,1) : # Erreur de connexion
 Elsif ERR
  TIT = mess(68,123,1) : #  Erreur application X3
 Else
  TIT = mess(69,123,1) : #  Message d'information
 Endif
Elsif GSERVEUR | GIMPORT
 TEX = [L]TIT+"\"+TEX
Endif
Gosub COUPE_TEXTE
If AFF=3
 Endbox TEX1(1..NTEX) Titled TIT
Elsif AFF=2 & GTIMOUT=0
 If ERR
  Errbox TEX1(1..NTEX) Titled TIT
 Else
  Infbox TEX1(1..NTEX) Titled TIT
 Endif
Elsif AFF=2 & GTIMOUT>0
 If ERR
  Errbox TEX1(1..NTEX) Titled TIT Sleep GTIMOUT
 Else
  Infbox TEX1(1..NTEX) Titled TIT Sleep GTIMOUT
 Endif
Elsif AFF=1
 If ERR
  Errbox TEX1(1..NTEX) Titled TIT Using X
 Else
  Infbox TEX1(1..NTEX) Titled TIT Using X
 Endif
Endif
If TRACE
 #107269
 #If dim(GTRALIG)>1 & NTEX<=dim(GTRALIG) & dim(GSERVEUR)>0 & GSERVEUR & (GPRODUIT<>-1 | find(GUSER,"VPO","MB","CCL")=0 )
 If dim(GTRALIG)>1 & NTEX<=dim(GTRALIG)
  If GTRANBR+NTEX>dim(GTRALIG)
   Call FLUSH_TRACE
  Elsif GTRANBR=0 : #96891
   Call OPEN_TRACE
  Endif
  For PTEX=1 To NTEX
   GTRANBR += 1
   If ERR>0
    GTRALIG(GTRANBR) = "<"+right$(num$(10000+mod(ERR,10000)),2)+" "+TEX1(PTEX)
    GERRTRACE += 1
    Call FLUSH_TRACE
   Elsif ERR<0
    GTRALIG(GTRANBR) = ">"+right$(num$(10000+mod(abs(ERR),10000)),2)+" "+TEX1(PTEX)
   Else
    GTRALIG(GTRANBR) = TEX1(PTEX)
   Endif
  Next PTEX
  GTRABLK = (vireblc(TEX1(NTEX),4)="")
 Else
  Onerrgo ER_TRA
  Local Char    OADXIRS(5), OADXIFS(5)
  Local Integer OADXIUM
  OADXIRS = adxirs
  OADXIFS = adxifs
  OADXIUM = adxium
  adxifs = ""
  adxirs = chr$(10)
  adxium = GTRAFOR
  If GTRACE<>""
   Openo filpath("TRA",GTRACE,"tra"), -1 : # Sécurité ?
  Endif
  If ERR
   For PTEX=1 To NTEX
    If ERR<0
     # JML 22/10/99 remplacement de - par +" "+ car TEX1(PTEX) peut commencer par espace !
     Wrseq ">"+right$(num$(10000+mod(abs(ERR),10000)),2)+" "+TEX1(PTEX)
    Else
     Wrseq "<"+right$(num$(10000+mod(ERR,10000)),2)+" "+TEX1(PTEX)
    Endif
   Next PTEX
   If ERR>0
    GERRTRACE += 1
   Endif
  Else
   For PTEX=1 To NTEX
    Wrseq TEX1(PTEX)
   Next PTEX
  Endif
  GTRABLK = (vireblc(TEX1(NTEX),4)="")
  If GTRACE<>""
   Openo : # mb 25.10.01 Flush
   Openo filpath("TRA",GTRACE,"tra"), -1 : # Permet de garder la trace ouverte
  Endif
  adxirs = OADXIRS
  adxifs = OADXIFS
  adxium = OADXIUM
  Onerrgo
 Endif
Endif
End

#--------------------#
$ER_TRA
# mb 11.2.9 bug des tâches batch compta
# On essaie d'écrire dans une trace, mais il n'y a aucun fichier ouvert
# Comme on est déjà dans une erreur, il faut masquer cette erreur
# mb 20.3.9 pour éviter une boucle sans fin sur erreur d'ouverture du fichier trace (openo)
Resume

#--------------------------------------------------------#
Subprog FLUSH_TRACE
Onerrgo ER_TRA
Local Char    OADXIRS(5), OADXIFS(5)
Local Integer OADXIUM , PTEX
If dim(GTRALIG)<=1 or GTRANBR<=0
 End
Endif
OADXIRS = adxirs
OADXIFS = adxifs
OADXIUM = adxium
adxifs = ""
adxirs = chr$(10)
adxium = GTRAFOR
If GTRACE<>""
 Openo filpath("TRA",GTRACE,"tra"), -1 : # Sécurité ?
Endif
For PTEX=1 To GTRANBR
 Wrseq GTRALIG(PTEX)
Next PTEX
Raz GTRALIG , GTRANBR
If GTRACE<>""
 Openo : # mb 25.10.01 Flush
 Openo filpath("TRA",GTRACE,"tra"), -1 : # Permet de garder la trace ouverte
Endif
adxirs = OADXIRS
adxifs = OADXIFS
adxium = OADXIUM
Onerrgo
End

#--------------------------------------------------------#
Subprog OPEN_TRACE
Onerrgo ER_TRA
Local Char    OADXIRS(5), OADXIFS(5)
Local Integer OADXIUM , PTEX
If dim(GTRALIG)<=1 or GTRANBR<>0
 End
Endif
OADXIRS = adxirs
OADXIFS = adxifs
OADXIUM = adxium
adxifs = ""
adxirs = chr$(10)
adxium = GTRAFOR
If GTRACE<>""
 Openo filpath("TRA",GTRACE,"tra"), -1 : # Permet de garder la trace ouverte
Endif
adxirs = OADXIRS
adxifs = OADXIFS
adxium = OADXIUM
Onerrgo
End

#############################################################################
## Pour éditer une trace formatée sur 5 colonnes maxi (obsolète 29.3.4)
#############################################################################

Subprog ECR_TRACE_F(C1,C2,C3,C4,C5,L1,L2,L3,L4,L5,ERR)
Value Char    C1, C2, C3, C4, C5  : # Contenu des champs à formater en colonne
Value Integer L1, L2, L3, L4, L5  : # Nb de caractères par colonne
Value Integer ERR                 : # Code erreur (0=message, sinon erreur)
Local Char    MESSAGE(250), MOT(250)
If L1 | C1<>"" : MOT = C1 : Call FORMAT(MOT,L1,0) From CNSDIV : MESSAGE =  MOT : Endif
If L2 | C2<>"" : MOT = C2 : Call FORMAT(MOT,L2,0) From CNSDIV : MESSAGE += MOT : Endif
If L3 | C3<>"" : MOT = C3 : Call FORMAT(MOT,L3,0) From CNSDIV : MESSAGE += MOT : Endif
If L4 | C4<>"" : MOT = C4 : Call FORMAT(MOT,L4,0) From CNSDIV : MESSAGE += MOT : Endif
If L5 | C5<>"" : MOT = C5 : Call FORMAT(MOT,L5,0) From CNSDIV : MESSAGE += MOT : Endif
Call ECR_TRACE(MESSAGE,ERR) From GESECRAN
End

###############################################################
Subprog ERRZON(ZONE,NUM,MESSAGE)
Value    Char    ZONE
Value    Integer NUM
Variable Char    MESSAGE

Local Char    VALZON(250) , FLD(250)
Local Integer K , DIME , TYP , ER

If ZONE="" or GERR=99 or left$(MESSAGE,1)="#" : End : Endif

Onerrgo ERZON

FLD = ZONE
DIME = instr(1,ZONE,"(")
If DIME : FLD = left$(ZONE,DIME-1) : Endif
TYP = evalue("type([M]"+FLD+")")

If TYP<>8
 If MESSAGE=""
  MESSAGE = mess(83,123,1) : # Valeur incorrecte
 Endif
Endif
If GIMPORT
 If TYP=8
  VALZON = num$(evalue("[M]"+FLD))
 Elsif indice=0 | DIME
  Case TYP
   When 3       : VALZON = format$("D:"+GFMDAT,evalue("[M]"+ZONE))
   When Default : VALZON = num$(evalue("[M]"+ZONE))
  Endcase
 Else
  Case TYP
   When 3       : VALZON = format$("D:"+GFMDAT,evalue("[M]"+ZONE+"(indice)"))
   When Default : VALZON = num$(evalue("[M]"+ZONE+"(indice)"))
  Endcase
 Endif
 If VALZON<>"" & !instr(1,MESSAGE,VALZON)
  MESSAGE = mess(17,115,1)-ZONE-"("+VALZON+") :"-MESSAGE : # Zone
 Else
  MESSAGE = mess(17,115,1)-ZONE-":"-MESSAGE
 Endif
Elsif NUM<>0
 If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
 Read [ATX]NUMERO = GLANGUE;NUM
 If !fstat
  MESSAGE += mess(32,126,1)-'"'+[F:ATX]TEXTE+'"' : # Erreur zone...
 Endif
Endif
End

$ERZON
ER = errn
Resume

##################################
Subprog ERRIMP(ZONE,MESSAGE)
Value Char ZONE
Value Char MESSAGE
If MESSAGE=""
 MESSAGE = mess(83,123,1) : # Valeur incorrecte
Endif
If GIMPORT
 Call ECR_TRACE(ZONE-":"-MESSAGE,1)
Else
 Call ERREUR(MESSAGE)
Endif
End

$COMBOS
If sum(GMENLOC)<>0
 Local Integer WCOMBO(1..100) , WN , WI
 For WI=1 To dim(GMENLOC)-1
  If GMENLOC(WI)<>0
   WN += 1
   WCOMBO(WN) = WI
  Endif
 Next WI
Endif
Return

############################################################
Subprog OUVRE_VLC(TITVLC,INTTEX,INTNUM)
Value Char    TITVLC : # Titre de la boîte
Value Char    INTTEX : # Titre du premier champ
Value Char    INTNUM : # Titre du second champ

Local Integer NOL
Local Char    SAVPROG(GLONADC) , WINPROG(GLONADC)
Local Char    ACTION(20) , OPERATION(10)
Local Integer MA

If GSERVEUR or GIMPORT or GSILENCE
 End
Elsif GBROWS and GFUSION<>1
 Infbox "$$VLC_OPE"+INTTEX+"^"+INTNUM Titled TITVLC+"^"+mess(6,100,1)+"^"+mess(78,134,1)
 # Opération en cours/Patientez SVP
 End
Endif

#Call NOMTRTWIN("VALIDCAR",WINPROG) From MSKDIV
WINPROG="WGVALIDCAR"     :# CC 24/10/2011 pour migrations différées sinon boucle
NOL = nolign
OPERATION  = "VALIDCAR"
SAVPROG    = GPROGRAMME
GPROGRAMME = "GESECRAN"
Gosub OUVRE_BOITE From =WINPROG
MA = 1
Gosub SETMASK From =WINPROG
Gosub TITMASK From =WINPROG
Raz [M:VLC]TEX, [M:VLC]NUMERO
GPROGRAMME = SAVPROG
nolign = NOL
End

#############################
Subprog AFF_VLC(TEXTE,NUMERO)
Value Char TEXTE, NUMERO

If GSERVEUR or GIMPORT or GSILENCE
 End
Elsif GBROWS and GFUSION<>1
 Infbox "$$VLC_MOD"+TEXTE+"^"+NUMERO
 End
Elsif clalev([M:VLC])<=0
 End
Endif

[M:VLC]TEX    = TEXTE
[M:VLC]NUMERO = NUMERO
Affzo [VLC]TEX , NUMERO
Envzo
End

#############################
Subprog FERME_VLC

If GSERVEUR or GIMPORT or GSILENCE
 End
Elsif GBROWS and GFUSION<>1
 Infbox "$$VLC_CLO"
 End
Elsif clalev([M:VLC])<=0
 End
Endif

Close Global Mask [VLC]
End


#############################
Subprog SETBLB(BLB,KEY1,KEY2,KEY3,KEY4,ERR)
Variable Blbfile BLB()
Value Char KEY1,KEY2,KEY3,KEY4
Variable Integer ERR

ERR=0
Local File ABLOB [ABB]
Read [ABB]ABB0=KEY1;KEY2;KEY3;KEY4
If fstat=0
  BLB=[F:ABB]BLOB
Else
  ERR=1
  Raz BLB
Endif
End

#############################
Subprog SETBLBFIC(BLB,LOC,ERR)
Variable Blbfile BLB()
Value Char LOC
Variable Integer ERR

Local Integer IND

ERR=0
Raz BLB
If left$(LOC,2)="#@" and (GBROWS and !GADXLOC)
  ERR=2
Endif
Openi LOC,0 Using [BLF1]
#If fstat<>0 : ERR=1 : End : Endif
Getseq 1,BLB  Using [BLF1]
If fstat<>0 : ERR=1 : Endif
Openi Using [BLF1]
End

#############################
Subprog UPDATEBLB(BLB,KEY1,KEY2,KEY3,KEY4,ERR)
Value Blbfile BLB()
Value Char KEY1,KEY2,KEY3,KEY4
Variable Integer ERR

Local Integer REW,LOCTR
Local File ABLOB [ABB]

Read [ABB]ABB0=KEY1;KEY2;KEY3;KEY4
If fstat=0 : REW=1 : Endif
If adxlog=0 : LOCTR=1 : Trbegin [ABB] : Endif
[F:ABB]NAMBLB=""
[F:ABB]BLOB=BLB
[F:ABB]CREUSR=GUSER
[F:ABB]CREDAT=date$
If dim([F:ABB]CRETIM)>0 : [F:ABB]CRETIM=time : Endif
If REW=1
  Rewrite [ABB]
  ERR=fstat
Else
  [F:ABB]CODBLB=KEY1
  [F:ABB]IDENT1=KEY2
  [F:ABB]IDENT2=KEY3
  [F:ABB]IDENT3=KEY4
  Write [ABB]
  ERR=fstat
Endif
If LOCTR=1 : Commit : Endif
End

#############################

Subprog UPLBLBFIC(LOC,KEY1,KEY2,KEY3,KEY4,ERR)
Value Char LOC
Value Char KEY1,KEY2,KEY3,KEY4
Variable Integer ERR

Local Blbfile BLB(9)
Local Integer REW,LOCTR
Local Char LOC1(100)

If left$(LOC,2)="#@"
 Local Char RETOUR (250),FILEXT,FILNAM(30),FILREP(100)
 LOC1=right$(LOC,3)
 Local Integer I,LA,LP
 For I=1 To len(LOC1)
  Case mid$(LOC1,I,1)
    When "\" : LA=I
    When "." : LP=I
  Endcase
 Next I
 If LP<>0 : FILEXT=right$(LOC1,LP+1) : Endif
 If LA<>0
   FILREP=left$(LOC1,LA-1)
   If LP<>0
     FILNAM=mid$(LOC1,LA+1,LP-LA-1)
   Else
     FILNAM=right$(LOC1,LA+1)
   Endif
 Endif
 LOC1=filpath("tmp","","")
#  On ne peut pas préciser FILNAM et FILEXT
 If FILNAM="*" : FILNAM="" : Endif
 If FILNAM<>"" : FILEXT="" : Endif
 Askui RETOUR = ""  With   "UIAsk=" + chr$(1) + "AskPutFile",
&  "UILocalFileName=" + chr$(1) + FILNAM,
&  "UILocalFileExts=" + chr$(1) + FILEXT,
&  "UILocalPath=" + chr$(1) + FILREP,
&  "UIRemoteFileName=" + chr$(1) + KEY1+"_"+KEY2+"_"+KEY3+"_"+KEY4,
&  "UIRemotePath=" + chr$(1) + LOC1,
&  "UIRemoteOverWrite=" + chr$(1) + "1"

  If left$(RETOUR,1)<>"1" : ERR=3 : End : Endif

  LOC1=filpath("tmp",KEY1+"_"+KEY2+"_"+KEY3+"_"+KEY4,"")

  Openi LOC1,0 Using [BLF1]
#  If fstat<>0 : ERR=1 : End : Endif
  Getseq 1,BLB  Using [BLF1]
  If fstat<>0 : ERR=2 : End : Endif
  Openi Using [BLF1]
  Call EFFACE(LOC1,ERR) From ORDSYS
Else
  Openi LOC,0 Using [BLF1]
 # If fstat<>0 : ERR=1 : End : Endif
  Getseq 1,BLB  Using [BLF1]
  If fstat<>0 : ERR=2 : End : Endif
  Openi Using [BLF1]
  LOC1=LOC
Endif


Local File ABLOB [ABB]
Read [ABB]ABB0=KEY1;KEY2;KEY3;KEY4
If fstat=0 : REW=1 : Endif
If adxlog=0 : LOCTR=1 : Trbegin [ABB] : Endif
If len(LOC1)>30
  [F:ABB]NAMBLB=right$(LOC1,len(LOC1)-30)
Else
  [F:ABB]NAMBLB=LOC1
Endif
[F:ABB]BLOB=BLB
[F:ABB]CREUSR=GUSER
[F:ABB]CREDAT=date$
If dim([F:ABB]CRETIM)>0 : [F:ABB]CRETIM=time : Endif
If REW=1
  Rewrite [ABB]
Else
  [F:ABB]CODBLB=KEY1
  [F:ABB]IDENT1=KEY2
  [F:ABB]IDENT2=KEY3
  [F:ABB]IDENT3=KEY4
  Write [ABB]
Endif
If LOCTR=1 : Commit : Endif
End

#############################

Subprog UPLFILEFIC(LOC,DOSS,REP,FIC,ERR)
Value Char LOC
Value Char DOSS,REP,FIC
Variable Integer ERR

Local Blbfile BLB(9)
Local Integer REW,LOCTR
Local Char LOC1(100)

If left$(LOC,2)="#@"
 Local Char RETOUR (250),FILEXT,FILNAM(30),FILREP(100)
 LOC1=right$(LOC,3)
 Local Integer I,LA,LP
 For I=1 To len(LOC1)
  Case mid$(LOC1,I,1)
    When "\" : LA=I
    When "." : LP=I
  Endcase
 Next I
 If LP<>0 : FILEXT=right$(LOC1,LP+1) : Endif
 If LA<>0
   FILREP=left$(LOC1,LA-1)
   If LP<>0
     FILNAM=mid$(LOC1,LA+1,LP-LA-1)
   Else
     FILNAM=right$(LOC1,LA+1)
   Endif
 Endif
 LOC1=filpath(REP,"","",DOSS)
#  On ne peut pas préciser FILNAM et FILEXT
 If FILNAM="*" : FILNAM="" : Endif
 If FILNAM<>"" : FILEXT="" : Endif
 Askui RETOUR = ""  With   "UIAsk=" + chr$(1) + "AskPutFile",
&  "UILocalFileName=" + chr$(1) + FILNAM,
&  "UILocalFileExts=" + chr$(1) + FILEXT,
&  "UILocalPath=" + chr$(1) + FILREP,
&  "UIRemoteFileName=" + chr$(1) + FIC,
&  "UIRemotePath=" + chr$(1) + LOC1,
&  "UIRemoteOverWrite=" + chr$(1) + "1"

  If left$(RETOUR,1)<>"1" : ERR=3 : End : Endif
Else
  Openi LOC,0 Using [BLF1]
#  If fstat<>0 : ERR=1 : End : Endif
  Getseq 1,BLB  Using [BLF1]
  If fstat<>0 : ERR=2 : End : Endif
  Openi Using [BLF1]
  LOC1=filpath(REP,FIC,"",DOSS)
  Openo LOC1,0 Using [BLF2]
  Putseq 1,BLB  Using [BLF2]
  Openo Using [BLF2]
Endif
End

# ------------------------------------------------------------------------

Subprog ACTLMASK(MASKNAME)
Value Char MASKNAME

#  Ce programme est déclenché par le moteur si il essaie d'ouvrir un masque en attente de validation (size 0)

Local Integer MOK
Call VALIDDIRECT(MASKNAME,nomap,1,GLANGUE,1,MOK) From VALMSK
End
# ------------------------------------------------------------------------

Subprog ACTLMASKFOL(AFOLDER,MASKNAME)
Value Char AFOLDER
Value Char MASKNAME

#  Ce programme est déclenché par le moteur si il essaie d'ouvrir un masque en attente de validation (size 0)

Local Integer MOK
If AFOLDER="" : AFOLDER=nomap : Endif
Call VALIDDIRECT(MASKNAME,AFOLDER,1,GLANGUE,1,MOK) From VALMSK
End

