#<AdxTL>@(#)0.0.0.0 $Revision$ 
Subprog IMPELECINV(NUM,FCY,INVTYP,BPRNUM,REFDAT,FLG,RPT) #NIBOW ZAF LEGISLATION JIRA# X3-1579
Value Char FCY,NUM,BPRNUM,RPT
Value Integer INVTYP,FLG
Value Date REFDAT

Local Char KZACPY(GLONCPY) : KZACPY = func ADP_TOOL.GET_CPY_FROM_SITE(nomap(0), FCY)
Local Char DESTINATION(255) : DESTINATION = func ADP_TOOL.GET_PARAM(nomap(0), 2, KZACPY, "RSADEST")
Local Char TBPAR_BP(15)(1..15),TBVAL_BP(30)(1..15)

TBPAR_BP(1) = "sitedeb" : TBVAL_BP(1) = FCY
TBPAR_BP(2) = "sitefin" : TBVAL_BP(2) = FCY
TBPAR_BP(3) = "facturedeb" : TBVAL_BP(3) = NUM
TBPAR_BP(4) = "facturefin" : TBVAL_BP(4) = NUM
TBPAR_BP(5) = "typedeb" : TBVAL_BP(5) = num$(INVTYP)
TBPAR_BP(6) = "clientdeb" : TBVAL_BP(6) = BPRNUM
TBPAR_BP(7) = "clientfin" : TBVAL_BP(7) = BPRNUM
TBPAR_BP(8) = "datedeb" : TBVAL_BP(8) = REFDAT
TBPAR_BP(9) = "datefin" : TBVAL_BP(9) = REFDAT
TBPAR_BP(10) = "codimp" : TBVAL_BP(10) = num$(FLG)
TBPAR_BP(11) = "usr" : TBVAL_BP(11) = GUSER
TBPAR_BP(12) = "etat" : TBVAL_BP(12) = RPT
TBPAR_BP(13) = "X3ETA" : TBVAL_BP(13) = RPT
#TBPAR_BP(14) = "mentionpays" : TBVAL_BP(14) = mess(121,2281,1)

#Generate the report
Call ETAT(RPT,DESTINATION,"",0,"",TBPAR_BP,TBVAL_BP) From AIMP3
End

$KZADIGITALINVOICE #NIBOW ZAF LEGISLATION JIRA# X3-1579

Local Integer WSTATUS
Local Char KZACPY(GLONCPY) : KZACPY = func ADP_TOOL.GET_CPY_FROM_SITE(nomap(0), [M:SIH0]SALFCY)
Local Char LEG(GLONALEG) : LEG = func ADP_TOOL.GET_LEG_FROM_CPY(nomap(0), KZACPY)
Local Integer LOCALTRACE : LOCALTRACE = [V]CST_ANO
Local Char EMAILADDRESS(255)
Local Char DOCUMENT(GLONVCR) : DOCUMENT = [M:SIH0]NUM
Local Char THEME(255) : THEME = func ADP_TOOL.GET_PARAM(nomap(0), 2, KZACPY, "RSATHEME")
Local Char CERT(255) : CERT = func ADP_TOOL.GET_PARAM(nomap(0), 2, KZACPY, "RSACERT")
Local Char SMTP(255) : SMTP = func ADP_TOOL.GET_PARAM(nomap(0), 2, KZACPY, "RSASMTP")
Local Char TITLE(255) : TITLE = func ADP_TOOL.GET_PARAM(nomap(0), 2, KZACPY, "RSATITLE")
Local Char SUBTITLE(255) : SUBTITLE = func ADP_TOOL.GET_PARAM(nomap(0), 2, KZACPY, "RSASUBTITL")
Local Char SUBJECT(255) : SUBJECT = func ADP_TOOL.GET_PARAM(nomap(0), 2, KZACPY, "RSASUBJECT")
Local Clbfile BODY(2) : BODY = func ADP_TOOL.GET_PARAM(nomap(0), 2, KZACPY, "RSABODY")

If GTRACE = AVOID.ACHAR
  LOCALTRACE = [V]CST_AYES
  Call OUVRE_TRACE(mess(7,7720,1)) From LECFIC
Endif

If CERT = AVOID.ACHAR
  Call ECR_TRACE(mess(1,7720,1) + KZACPY,-1) From GESECRAN
  Goto $ENDEI
Endif
If SMTP = AVOID.ACHAR
  Call ECR_TRACE(mess(2,7720,1) + KZACPY,-1) From GESECRAN
  Goto $ENDEI
Endif

Local File BPCUSTOMER [BPC]
Local File BPADDRESS [BPA]

Read[BPC]BPC0 = [M:SIH0]BPCINV
Read[BPA]BPA0 = 1;[F:BPC]BPCNUM;[F:BPC]BPAADD

If [BPC]AEIFLG <> [V]CST_AYES
  Call ECR_TRACE([F:BPC]BPCNUM + ": " + DOCUMENT + " " + mess(3,7720,1),-1) From GESECRAN
  Goto $ENDEI
Endif

If [BPA]WEB(0) = AVOID.ACHAR
  Call ECR_TRACE([F:BPC]BPCNUM + ": " + DOCUMENT + " " + mess(4,7720,1),-1) From GESECRAN
  Goto $ENDEI
Else
  EMAILADDRESS = [BPA]WEB(0)
Endif

WSTATUS = func LIBZAF.PDFSIGNANDSEND(FICJOB,CERT,THEME,TITLE,SUBTITLE,SUBJECT,BODY,EMAILADDRESS,SMTP,DOCUMENT + "." + EXT)

If WSTATUS <> 200
  Call ECR_TRACE([F:BPC]BPCNUM + ": " + DOCUMENT + " " + mess(5,7720,1) + " " + num$(WSTATUS),1) From GESECRAN
  Goto $ENDEI
Endif

Call ECR_TRACE([F:BPC]BPCNUM + ": " + DOCUMENT + " " + mess(6,7720,1) + " " + EMAILADDRESS,0) From GESECRAN

$ENDEI
If LOCALTRACE = [V]CST_AYES
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Return

#**
#* This Function allows to digitally sign and email a PDF document
#*
#* @param WJOB : Char : The file path to the Archived Job PDF File
#* @param WCERT : Char : The name of the certificate to use and that is defined in Syracuse administration
#* @param WTHEME : Char : The Theme to be used, defined in the Notification Server
#* @param WTITLE : Char : The Title text used in the theme
#* @param WSUBTITLE : Char : The SubTitle text used in the theme
#* @param WSUBJECT : Char : The Email Subject
#* @param WBODY : Clbfile : The HTML mail body text
#* @param WEMAIL : Char : The email address of the recipient, Comma Seperated
#* @param WSMTP : Char : The Notification server used
#* @param WFILNAME : Char : The name of the attached file
#* @return WSTATUS : Integer : The status code return by the javascript runner module.
#*!
Funprog PDFSIGNANDSEND(WJOB,WCERT,WTHEME,WTITLE,WSUBTITLE,WSUBJECT,WBODY,WEMAIL,WSMTP,WFILNAME)#NIBOW ZAF LEGISLATION JIRA# X3-1579
Value Char WJOB
Value Char WCERT
Value Char WTHEME
Value Char WTITLE
Value Char WSUBTITLE
Value Char WSUBJECT
Value Clbfile WBODY
Value Char WEMAIL
Value Char WFILNAME
Value Char WSMTP

Local Clbfile RESHEAD(0)
Local Clbfile RESBODY(0)
Local Integer WSTATUS
Local Blbfile DATA(7)
Local Clbfile B64(0)
Local Integer COUNT
Local Clbfile WTO(1)

WTO = WEMAIL
Openi WJOB,0 Using [TST4]
Getseq 1, DATA Using [TST4]
Openi Using [TST4]
#Encode
COUNT = b64Encode(DATA, B64)
#Sign PDF
WSTATUS = func LIBZAF.PDFSIGN(WFILNAME, B64,WCERT, 0, "data", RESHEAD, RESBODY)
If WSTATUS <> 200 : Goto $ENDEIS : Endif
Local Char ATT_NAME(250)(1)
Local Clbfile ATT_CONTENT(0)(1)
ATT_NAME(0) = WFILNAME
ATT_CONTENT(0) = RESBODY
#Send Email
WSTATUS = func LIBZAF.SEND_EMAIL("", WTO, WSUBJECT, WSMTP, WTHEME, WTITLE,WSUBTITLE, WBODY, "", ATT_NAME, ATT_CONTENT, 0, RESHEAD, RESBODY)
$ENDEIS
End WSTATUS


$AVANTBOUT_VAL #NIBOW ZAF LEGISLATION JIRA# X3-1579
#Validation on SUBSIHA
Local Char KZACPY(GLONCPY) : KZACPY = func ADP_TOOL.GET_CPY_FROM_SITE(nomap(0), [M:SIH0]SALFCY)
Local Char CERT(255) : CERT = func ADP_TOOL.GET_PARAM(nomap(0), 2, KZACPY, "RSACERT")
Local Char SMTP(255) : SMTP = func ADP_TOOL.GET_PARAM(nomap(0), 2, KZACPY, "RSASMTP")
Local Char DESTINATION(255) : DESTINATION = func ADP_TOOL.GET_PARAM(nomap(0), 2, KZACPY, "RSADEST")
Local Char DOCUMENT(GLONVCR) : DOCUMENT = [M:SIH0]NUM

If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPA])=0 : Local File BPADDRESS [BPA] : Endif
Filter[BPC]
Filter[BPA]

Read[BPC]BPC0 = [M:SIH0]BPCINV
Read[BPA]BPA0 = 1;[F:BPC]BPCNUM;[F:BPC]BPAADD

If [BPC]AEIFLG <> [V]CST_AYES
  GMESSAGE = [F:BPC]BPCNUM + ": " + mess(3,7720,1)
  GERR = 1
  Return
Endif
If [BPA]WEB(0) = AVOID.ACHAR
  GMESSAGE = [F:BPC]BPCNUM + ": " + mess(4,7720,1)
  GERR = 1
  Return
Endif
If CERT = AVOID.ACHAR
  GMESSAGE = mess(1,7720,1) + KZACPY
  GERR = 1
  Return
Endif
If SMTP = AVOID.ACHAR
  GMESSAGE = mess(2,7720,1) + KZACPY
  GERR = 1
  Return
Endif
If [F:SLT]DOCNAM = AVOID.ACHAR
  GMESSAGE = mess(8,7720,1)
  GERR = 1
  Return
Endif
If DESTINATION = AVOID.ACHAR
  GMESSAGE = mess(9,7720,1)
  GERR = 1
  Return
Else
  If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif
    Filter[AIM]
    Read[AIM]AIM0 = DESTINATION
    If !fstat
      If [F:AIM]PRT <> 7 or [F:AIM]PRTFMT <> 29
        GMESSAGE = DESTINATION + ": " + mess(11,7720,1)
        GERR = 1
        Return
      Endif
    Else
      GMESSAGE = DESTINATION + ": " + mess(10,7720,1)
      GERR = 1
      Return
    Endif
Endif
Return


#**
#* This Function is working on Fusion Session Client AND Syracuse session client
#* It allows to send emails through Syracuse notification server definition.
#*
#* @param WFROM : Char : The e-mail address of the sender. All e-mail addresses can be plain `'sender@server.com'` or formatted `'Sender Name <sender@server.com>'`
#* @param WTO : Clbfile : Comma separated list of recipients e-mail addresses that will appear on the *To:* field
#* @param SUBJECT : Char : The subject of the e-mail
#* @param SMTPSRV : Char : The notification server code set in Syracuse administration
#* @param THEME : Char : The notification theme defined in Syracuse administration you want to use
#* @param TITLE : Char : The email title
#* @param SUBTITLE : Char : The email subtitle
#* @param CONTENT : Char : The main text of the email
#* @param SIG : Char : The signature used at the end of the email
#* @param FUTURE : Integer : 1 to be called in 'future' mode or 0 for the 'wait' mode.
#* @param RESHEAD : Clbfile : The response header
#* @param RESBODY : Clbfile : Nothing is returned.
#* @return STATUSCODE : Integer : The status code return by the javascript runner module.
#*!
Funprog SEND_EMAIL(WFROM, WTO, SUBJECT, SMTPSRV, THEME, TITLE, SUBTITLE, CONTENT, SIG, ATT_NAME, ATT_CONTENT, FUTURE, RESHEAD, RESBODY) #NIBOW ZAF LEGISLATION JIRA# X3-1579

Value Char WFROM
Value Clbfile WTO
Value Char SUBJECT
Value Char SMTPSRV
Value Char THEME
Value Char TITLE
Value Char SUBTITLE
Value Clbfile CONTENT
Value Char SIG
Value Char ATT_NAME()(1..)
Value Clbfile ATT_CONTENT()(1..)

Value Integer FUTURE
Variable Clbfile RESHEAD()
Variable Clbfile RESBODY()

Local Integer STATUSCODE
Local Char MODULE(100) : MODULE = 'syracuse-4gl-api/lib/mailer'
Local Char FONCTION(30) : FONCTION = 'send'
Local Char MODE(10)
If (FUTURE = 1) : MODE = 'future' : Else : MODE = 'wait' : Endif

Local Clbfile DATA(4) : DATA = ''


Append DATA, '{'
Append DATA, '"from": "' + WFROM + '",'
Append DATA, '"to": "' + WTO + '",'

Append DATA, '"subject": "' + SUBJECT + '"'


If dim(ATT_NAME) <> 0
   Append DATA, ', "attachments": ['
   For I=0 To dim(ATT_NAME) - 1
      Append DATA, '{'
         Append DATA, '"filename": "' + ATT_NAME(I + 1) + '",'
         Append DATA, '"content": "' + ATT_CONTENT(I + 1) + '",'
         Append DATA, '"encoding": "base64"'
      Append DATA, '}'
   Next
   Append DATA, ']'
Endif


Append DATA, '}'

Local Clbfile OPT(4) : OPT = ''
Append OPT, '{'
# set explicitely notification server
If SMTPSRV <> ""
   Append OPT, '"server": "' + SMTPSRV + '",'
Endif
# Manage theme
If THEME <> ""
   Append OPT, '"theme": "' + THEME+ '",'
Else
   Append OPT, '"noTheme": true,'
Endif

# Manage the view object
Append OPT, '"view": {'
Append OPT,       '"title": "' + TITLE + '",'
Append OPT,       '"subtitle": "' + SUBTITLE + '",'
Append OPT,       '"content": "' + CONTENT + '",'
Append OPT,       '"signature": "' + SIG + '"'
Append OPT,    '}' # close view object
Append OPT, '}' # close OPT object

Local Clbfile ARGUMENTS(0)
ARGUMENTS = DATA + ',' + OPT
Local Clbfile RESBODY(0)
# Call 'sign' function
STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, '', 0, '', '0', RESHEAD, RESBODY)

End STATUSCODE


#**
#* This Function is working on Fusion Session Client AND Syracuse session client
#* It allows to sign PDF using certificate defined in Syracuse administration.
#*
#* @param PDFNAME : Char : The PDF name
#* @param DATA : Clbfile : The content encoded in base 64
#* @param CERTNAME : Char : The name of the certificate to use and that is defined in Syracuse administration
#* @param FUTURE : Integer : 1 to be called in 'future' mode or 0 for the 'wait' mode.
#* @param RESHEAD : Clbfile : The response header
#* @param RESBODY : Clbfile : The PDF signed content.
#* @return STATUSCODE : Integer : The status code return by the javascript runner module.
#*!
Funprog PDFSIGN(PDFNAME, DATA, CERTNAME, FUTURE, RETURNS, RESHEAD, RESBODY) #NIBOW ZAF LEGISLATION JIRA# X3-1579

Value Char PDFNAME
Value Clbfile DATA
Value Char CERTNAME

Value Integer FUTURE
Value Char RETURNS
Variable Clbfile RESHEAD()
Variable Clbfile RESBODY()

Local Integer STATUSCODE
Local Char MODULE(100) : MODULE = 'syracuse-4gl-api/lib/pdf'
Local Char FONCTION(30) : FONCTION = 'sign'
Local Char MODE(10)
If (FUTURE = 1) : MODE = 'future' : Else : MODE = 'wait' : Endif

Local Clbfile ARGUMENTS(0)
ARGUMENTS = '"' + PDFNAME + '","' + DATA + '","' + CERTNAME + '", {"returnData": true, "encoding": "base64"}'
Local Clbfile RESBODY(0)
# Call 'sign' function
STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, '0,1,0,0', 0, RETURNS, '0', RESHEAD, RESBODY)

End STATUSCODE






