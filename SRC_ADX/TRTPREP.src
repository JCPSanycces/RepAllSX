#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
# Plan de préparation d'expéditions                             TRTPREP #
#########################################################################
# Fonction : FUNPREP                                                    #
# Action :   SAIPREP                                                    #
# Fenêtre :  IPREP                                                      #
#-----------------------------------------------------------------------#
# Action standard sur les zones de l'écran                              #
#########################################################################

$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE        From TRTPREPA
 When "TITRE"         : Gosub TIT_TRT      From TRTPREPA
 When "OUVRE_BOITE"   : Gosub OUVRE_BOITE  From TRTPREPA
 When "DEBUT"         : Gosub DEBUT        From TRTPREPA
 When "SETBOUT"       : Gosub SETBOUT      From TRTPREPA
 When "BOUTON"        : Gosub BOUTON       From TRTPREPA
 When "APRES_MODIF"   : Gosub APRES_MODIF  From TRTPREPA
 When "AVANT_ENR"     : Gosub AVANT_ENREG  From TRTPREPA
 When "ENR"           : Gosub ENREG        From TRTPREPA
 When "ABA"           : Gosub ABANDON      From TRTPREPA
 When "FIN"           : Call  RAZSTOSORW   From STKSOR
                        Gosub DECOCHAGE_PREP From TRTPREPA     # hcb 93069
                        If SYMBOLE1<>"" Unlock=SYMBOLE1 Endif  #--- Issue 108260 by TS
 When "SUI"           : Gosub SUIVANT      From TRTPREPA
 When "PRE"           : Gosub PRECEDENT    From TRTPREPA
 When "SEL_LISTE"     : Gosub SEL_LISTE    From TRTPREPL
 When "FIN_LISTE"     : Gosub FIN_LISTE    From TRTPREPL
 When "CONTROLE"      : Gosub CONTROLE     From TRTPREPL

Endcase

Case ACTION
 When "AAPRES_NBLIG"  : Gosub AAPRES_NBLIG
 When "BB1_NBLIG"     : Gosub BB1_NBLIG
 When "BB3_NBLIG"     : Gosub BB3_NBLIG
 When Default
Endcase

Return

#########################################################################
#    Débranchements d'actions                                           #
#########################################################################
$AAPRES_NBLIG
Local Integer NOL, WRET
NOL = nolign-1
Raz WRET

Raz GOUVSOR

# Si sortie tableau non validante
If adxgtb=1 & !GIMPORT Return Endif

# Si bon de prépa généré mais non livré/annulé
If [M:PREP]STOMGTCOD(NOL)<>1 & [M:PREP]PRHNUM(NOL)<>"" & [M:PREP]DLVFLG(NOL)<3

   #--- Issue 115937
   # Si allocation globale
   If find([M:PREP]ALLTYP(NOL),1,5) Return Endif
   #---

   # Alimentation de [M:ALP]
   Gosub ALI_ALP
   # Détermination du stock à sortir (automatisme, saisie)
   Call OUVSOR("PREP",NOL,[M:PREP]NBLIG,[M:PREP]WSTOSEQ(NOL),2,WRET) From STKSOR
Endif

Return

#########################################################################
$BB1_NBLIG

# Bouton Enreg et Abandon après fenètre saisie des sortie si enregistrement
If mkstat=4 GREP="M" Endif

Return

#########################################################################
$BB3_NBLIG

Local Integer WRET, NOL

# Après tunnel bon de préparation, raffraichissement liste préparation
I=0
Filter [PRL] Where STOFCY=[M:PREP]STOFCY & PRLNUM=[M:PREP]PRLNUM
For [PRL]
   I=1
   Break
Next
Filter [PRL]

# La liste de préparation été supprimé par la gestion des bons de prépa
If I=0
   Effzo [M:PREP]PRLNUM
   # Issue 55983 - 2013-03-14 by MAE : Modif ordre bloc(30=>40)
   Effzo [M:PREP]40
   Actzo [M:PREP]10
# Raffraichissement du tableau de la liste de prépa
Else
   Gosub RAFFRAICHI From TRTPREPA
Endif
# Pour forcer l'exécution du SETBOUT
mkstat=4

Return

#########################################################################
# Chargement du masque de paramétrage pour composants stock             #
#########################################################################
$ALI_ALP

Raz [M:ALP]
Case [M:PREP]ORITYP(NOL)
 When 1   : [M:ALP]TRSTYP =  4
 When 2   : [M:ALP]TRSTYP = 17
 When 3,4 : [M:ALP]TRSTYP = 20
Endcase
[M:ALP]TRSCOD     = [M:PREP]TRSCOD
[M:ALP]VCRTYP     = 3
[M:ALP]STOFCY     = [M:PREP]STOFCY
[M:ALP]ITMREF     = [M:PREP]ITMREF(NOL)
[M:ALP]PCU        = [M:PREP]PCU(NOL)
[M:ALP]PCUSTUCOE  = [M:PREP]PCUSTUCOE(NOL)
[M:ALP]QTY        = [M:PREP]QTYSTU(NOL)
[M:ALP]TYPQTY     = 2
[M:ALP]BESDAT     = [M:PREP]BESDAT
[M:ALP]DLVDAT     = [M:PREP]DLVDAT
Raz [M:ALP]ALLDAT
Raz [M:ALP]STOLOC
[M:ALP]PECINTLOC  = 2
[M:ALP]PECSCOLOC  = 1
[M:ALP]PECPLFLOC  = 2
[M:ALP]PECCUNLOK  = 1
Raz [M:ALP]FILSTO
[M:ALP]LOT        = [M:PREP]LOTFIL(NOL)
[M:ALP]LOC        = [M:PREP]LOCFIL(NOL)
[M:ALP]STA        = [M:PREP]STAFIL(NOL)
[M:ALP]VCRNUM     = [M:PREP]PRHNUM(NOL)
[M:ALP]VCRLIN     = [M:PREP]PRELIN(NOL)
#DLUBPC
[M:ALP]BPRNUM=[M:PREP]BPCORD(nolign-1)
Raz [M:ALP]VCRSEQ
If dim([M:PREP]WRH)>0 [M:ALP]WRH=[M:PREP]WRH(NOL) Endif

Return

#########################################################################
# Gestion du masque PREPLAN                                             #
#########################################################################

Subprog IB_PRLNUM
# Pas de suppression des bons de prépa
# si modification
# ou bons de preparation non generes
# ou bons prépa déjà livrables/livrés/annulés
If GREP="M" | [M:PREP]NBLIG=0 | find("",[M:PREP]PRHNUM(0..[M:PREP]NBLIG-1))
&           | find(2,[M:PREP]DLVFLG(0..[M:PREP]NBLIG-1))
&           | find(3,[M:PREP]DLVFLG(0..[M:PREP]NBLIG-1))
&           | find(4,[M:PREP]DLVFLG(0..[M:PREP]NBLIG-1))
   Raz GBOUT1
Endif
End

Subprog B1_PRLNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer WRET, WTYP
Local    Char    WPRHNUM(GLONVCR)
Local    Decimal WQTA, WSHT, WDELTAQTY

Raz WRET
Raz WPRHNUM

Call DEBTRANS From GLOCK
Trbegin [PRL]

Filter [PRL] Where PRLNUM=VALEUR Order By PRHNUM;PRELIN
For [PRL]
   # Si rupture bon de prépa, suppression de celui-ci
   If [F:PRL]PRHNUM<>WPRHNUM
      Readlock [PRH]PRH0=[F:PRL]PRHNUM
      If fstat
         Call RSTA("PRH",[F:PRL]PRHNUM) From GLOCK
         GOK=0 : Break
      Else
         # Le bon de préparation était livrable
         If [F:PRH]DLVFLG=2
            WTYP=6
         Else
            WTYP=2
         Endif
         Delete [PRH]
         If fstat
            Call FSTA("PRH") From GLOCK
            GOK=0 : Break
         Endif
      Endif
      WPRHNUM = [F:PRL]PRHNUM
   Endif
   # Suppression du détail bon de prépa et des allocations
   Readlock [PRE]PRE0=[F:PRL]PRHNUM;[F:PRL]PRELIN
   If fstat
      Call RSTA("PRE",[F:PRL]PRHNUM-num$([F:PRL]PRELIN)) From GLOCK
      GOK=0 : Break
   Else
      Call DELALL(3,[F:PRL]PRHNUM,[F:PRL]PRELIN,0,[F:PRL]ITMREF,0,WQTA,WSHT,WRET)
&                 From STKALL
      If WRET<>0 GOK=0 : Break Endif
      Delete [PRE]
      If fstat
         Call FSTA("PRE") From GLOCK
         GOK=0 : Break
      Endif
   Endif
   # Raz bon prépa dans liste de prépa
   Readlock [PRL]Curr
   If fstat
      Call RSTA("PRL",[F:PRL]PRLNUM-num$([F:PRL]PRLSEQ)) From GLOCK
      GOK=0 : Break
   Else
      [F:PRL]PRHNUM = ""
      [F:PRL]PRELIN = 0
      Rewrite [PRL]
      If fstat
         Call FSTA("PRL") From GLOCK
         GOK=0 : Break
      Endif
   Endif

   WDELTAQTY = -1*[F:PRL]QTYSTU

   If find([F:PRL]ORITYP,1,2)
      Call MAJ_SOQ (WTYP,[F:PRL]ORINUM,[F:PRL]ORILIN,[F:PRL]ORISEQ,[F:PRL]PCU,
&                   [F:PRL]PCUSTUCOE,WDELTAQTY) From STKPREPA
      If GOK<=0 Break Endif
   Endif
Next
Filter [PRL]

If GOK<>0
   Commit
Else
   Rollback
Endif

# Rechargement liste preparation
# Issue 55983 - 2013-03-14 by MAE : Modif ordre bloc(30=>40)
Effzo [M:PREP]40
[M:PREP]PRLNUM=VALEUR
Gosub LOAD_PRLNUM From TRTPREPA
Actzo [M:PREP]LSTWIOFLG
If [M:PREP]LSTWIOFLG=2
   Actzo [M:PREP]10
Else
   Diszo [M:PREP]10
Endif
# Issue 55983 - 2013-03-14 by MAE : Modif ordre bloc(30=>40)
Affzo [M:PREP]40
# Pour forcer l'éxécution du SETBOUT
mkstat=4

End

Subprog AS_PRLNUM(VALEUR)
Variable Char    VALEUR()
# Si pas de liste de prépa et tableau chargé avec modif en cours
# alors pas d'accés à la zone 'Liste prépa'
If VALEUR="" & [M:PREP]NBLIG>0 & find(2,[M:PREP]COCHAGE(0,[M:PREP]NBLIG-1))
   mkstat=2
Endif
End

Subprog C_PRLNUM(VALEUR)
Variable Char    VALEUR()
Local Integer I
If VALEUR<>""
   I=0
   Filter [PRL] Where STOFCY=[M:PREP]STOFCY & PRLNUM=VALEUR
   For [PRL]
      I=1 : Break
   Next
   Filter [PRL]
   If I=0
      GMESSAGE=mess(16,184,1) : mkstat=2
   Endif
Endif
End

############################
Subprog AM_LSTWIOFLG(VALEUR)
Variable Integer VALEUR
If [M:PREP]PRLNUM<>""
   If VALEUR=2
      Actzo [M:PREP]10
      If [M:PREP]DRNSTR=0    [M:PREP]DRNSTR=1    Endif
      If [M:PREP]DLVPIOSTR=0 [M:PREP]DLVPIOSTR=1 Endif
       If [M:PREP]DRNEND=0    [M:PREP]DRNEND=len(mess(0,409,1)) Endif
       If [M:PREP]DLVPIOEND=0 [M:PREP]DLVPIOEND=len(mess(0,410,1)) Endif
   Else
      Diszo [M:PREP]10
   Endif
Endif
End

############################
Subprog AM_BPCORDSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   If [M:PREP]BPCORDEND="" [M:PREP]BPCORDEND=VALEUR Endif
   Actzo [M:PREP]BPAADDSTR
Else
   Diszo [M:PREP]BPAADDSTR
Endif
End

############################
Subprog AM_BPAADDSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   If [M:PREP]BPAADDEND="" [M:PREP]BPAADDEND=VALEUR Endif
Endif
End

############################
Subprog AP_BPCORDEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   Actzo [M:PREP]BPAADDEND
Else
   Diszo [M:PREP]BPAADDEND
Endif
End

############################
Subprog C_BPAADDEND(VALEUR)
Variable Char    VALEUR()
If [M:PREP]BPCORDSTR=[M:PREP]BPCORDEND
   If VALEUR<>"" & VALEUR<[M:PREP]BPAADDSTR
      GMESSAGE=mess(44,199,1) : mkstat=2
   Endif
Endif
End

############################
Subprog AM_DRNSTR(VALEUR)
Variable Integer VALEUR
If VALEUR<>0
   If [M:PREP]DRNEND=0 [M:PREP]DRNEND=VALEUR Endif
Endif
End

############################
Subprog C_DRNEND(VALEUR)
Variable Integer VALEUR
If VALEUR<>0 & VALEUR<[M:PREP]DRNSTR
   GMESSAGE=mess(44,199,1) : mkstat=2
Endif
End

############################
Subprog AM_BPTSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   If [M:PREP]BPTEND="" [M:PREP]BPTEND=VALEUR Endif
Endif
End

############################
Subprog AM_SOHNUMSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  If [M:PREP]SOHNUMEND="" [M:PREP]SOHNUMEND=VALEUR Endif
Endif
End

############################
Subprog AS_ALLTYPFLG(VALEUR)
Variable Integer VALEUR
GMENLOC(3) = 1
GMENLOC(4) = 1
GMENLOC(5) = 1
GMENLOC(6) = 1
End

############################
Subprog AS_LOCDESH(VALEUR)
Variable Char    VALEUR()
# Les bons de prépa ne sont pas générés
#If [M:PREP]NBLIG=0 | sum([M:PREP]PRHNUM)=""
#   GMESSAGE = mess(321,184,1)
#   mkstat=2 : End
#Endif
End

############################
Subprog C_LOCDESH(VALEUR)
Variable Char    VALEUR()

VALEUR = toupper(VALEUR)
If !find(VALEUR,"","$")
  Read [STC]STC0=[M]STOFCY;VALEUR
  If fstat
    GMESSAGE = mess(125,184,1)
    mkstat=2 : End
  Endif
Endif

If !find(VALEUR,"","$")
  # Catégories non internes non autorisées
  If [F:STC]LOCCAT<>1
    GMESSAGE = mess(399,199,1)-":"-mess([F:STC]LOCCAT,2710,1)
    mkstat=2 : End
  Elsif [F:STC]LOKSTA=2 | [F:STC]CUNLOKFLG=2
    # Emplacement non disponible
    GMESSAGE=mess(18,196,1)
    mkstat=2 : End
  Endif
  [M]LOCTYPDESH = [F:STC]LOCTYP
Endif

End

############################
Subprog CL_ALILOCDES(VALEUR)
Variable Char    VALEUR()
Local    Integer I, WOK

# Les bons de prépa ne sont pas générés
If [M:PREP]NBLIG=0 | sum([M:PREP]PRHNUM)="" End Endif
# Ils ne sont pas encore livrables ou livrés ou annulés
If sum([M:PREP]DLVFLG)<=[M:PREP]NBLIG
   # Alimentation des emplacements destination des lignes de prépa
   If !find([M]LOCDESH,"","$")
      For I=0 To [M]NBLIG-1
         Read [ITF]ITF0=[M]ITMREF(I);[M]STOFCY
         If !fstat & [F:ITF]LOCMGTCOD=2
            If [M]LOCDES(I)=""
               [M]LOCDES(I)    = [M]LOCDESH
               [M]LOCTYPDES(I) = [M]LOCTYPDESH
               [M]UPDFLG(I)    = 1
               mkstat=4
            Endif
         Endif
      Next I
   # Effacement des emplacements destination des lignes de prépa
   Elsif [M]LOCDESH=""
      WOK=1
      Call AVERTIR (mess(319,184,1),WOK)From GESECRAN
      If WOK=1 End Endif
      For I=0 To [M]NBLIG-1
         Read [ITF]ITF0=[M]ITMREF(I);[M]STOFCY
         If !fstat & [F:ITF]LOCMGTCOD=2
            If [M]LOCDES(I)<>""
               [M]LOCDES(I)    = ""
               [M]LOCTYPDES(I) = ""
               [M]UPDFLG(I)    = 1
               mkstat=4
            Endif
         Endif
      Next I
   Endif
   # Affichage du tableau
   #If mkstat=4
      #GREP="M"
      #Affzo [M:PREP]30
      #status=1048
   #Endif
Endif
End

############################
Subprog IB_NBLIG
Local Integer NOL
NOL = nolign-1

# Pour autoriser la saisie du détail sortie
GOUVSOR = 1

# Bouton  1 : Saisie des sorties
# Bouton  3 : Tunnel bon de préparation
# Bouton  4 : Tunnel commande
# Bouton  5 : Tunnel commande ouverte
# Bouton  6 : Consultation stock par site

# MHB 19/12/08 : ajout n° pièce sur intitulé clic droit
GBOUT3 = GBOUT3-[M]PRHNUM(nolign-1)
GBOUT4 = GBOUT4-[M]ORINUM(nolign-1)
#--- Bug 72139
GBOUT5 = GBOUT5-[M]ORINUM(nolign-1)
# Si pas de bon de préparation
If [M:PREP]PRHNUM(NOL)=""
   Raz GBOUT1, GBOUT3
Endif

# Si bon de préparation livré ou annulé
If find([M:PREP]DLVFLG(NOL),3,4)
   Raz GBOUT1
Endif

#--- Bug 72139
# Si l'origine n'est pas une commande
#If !find([M:PREP]ORITYP(NOL),1,2)
#   Raz GBOUT4
#Endif
# Si l'origine n'est pas une commande
If !find([M:PREP]ORITYP(NOL),1,2)
   Raz GBOUT4, GBOUT5
# Si commande ouverte
Elsif [M:PREP]SOHCAT(NOL)=4
   Raz GBOUT4
# Si commande
Else
   Raz GBOUT5
Endif
#---

# Si pas d'article ou article non géré en stock
If [M]ITMREF(NOL)="" | [M]STOMGTCOD(NOL)<=1
   #--- Bug 72139
   #Raz GBOUT1, GBOUT5
   Raz GBOUT1, GBOUT6
   #---
Endif
End

Subprog AVANT_NBLIG
Local   Integer  NOL,I,WSOW
NOL=nolign-1

Case [M:PREP]ORITYP(NOL)
 When 1   : [M:ALP]TRSTYP =  4
 When 2   : [M:ALP]TRSTYP = 17
 When 3,4 : [M:ALP]TRSTYP = 20
Endcase

# Lecture article et règle de gestion
#--- Bug 81861 (Pb de perf lors du cochage/décochage)
#    A priori le INISOR n'est nécessaire que si le BP existe déjà
#If [M:PREP]ITMREF(NOL)<>""
If [M:PREP]ITMREF(NOL)<>"" & [M:PREP]PRHNUM(NOL)<>""
#---
   Call INIZONSOR("PREP",[M:PREP]ITMREF(NOL),[M:PREP]STOFCY,NOL,
&                 [M:ALP]TRSTYP,[M:PREP]TRSCOD,"") From STKECR
Endif

Raz WSOW
If [M:PREP]WSTOSEQ(NOL)<>0
   # Calcul du nb enreg SOW associé à la ligne de prépa
   WSOW=sigma(I=0,[M:SOW]NBLIG-1,1*([M:SOW]WSTOSEQ(I)=[M:PREP]WSTOSEQ(NOL)))
Endif

# Si pas de bon de prépa ou quantité allouée détaillée,
# pas d'accés aux zones stock
If [M:PREP]PRHNUM(NOL)="" | [M:PREP]ALLTYP(NOL)=2 & [M:PREP]ALLQTY(NOL)<>0
&                         | WSOW<>0

   # Désactivation des colonnes stock du document
   Diszo [M:PREP]STA(NOL)
   If dim([M:PREP]LOT)>0    Diszo [M:PREP]LOT(NOL)    Endif
   If dim([M:PREP]SLO)>0    Diszo [M:PREP]SLO(NOL)    Endif
   If dim([M:PREP]LOC)>0    Diszo [M:PREP]LOC(NOL)    Endif
   If dim([M:PREP]SERNUM)>0 Diszo [M:PREP]SERNUM(NOL) Endif
   If dim([M:PREP]PALNUM)>0 Diszo [M:PREP]PALNUM(NOL) Endif
   If dim([M:PREP]CTRNUM)>0 Diszo [M:PREP]CTRNUM(NOL) Endif
   If dim([M:PREP]WRH)>0    Diszo [M:PREP]WRH(NOL)    Endif
Endif
If [M:PREP]PCKFLG      (NOL) < 2
   Diszo [M:PREP]PCK   (NOL)
   Diszo [M:PREP]PCKCAP(NOL)
Else
   Actzo [M:PREP]PCK   (NOL)
   Actzo [M:PREP]PCKCAP(NOL)
Endif

End


############################
Subprog AS_COCHAGE(VALEUR)
Variable Integer VALEUR
If [M:PREP]PRHNUM(nolign-1)<>""         mkstat=2 Endif
If find([M:PREP]LINTYP(nolign-1),3,4,5,11,12,13) mkstat=2 Endif
#--- Issue X3-95328
If [M:PREP]QTYSTU(nolign-1)=0 mkstat=2 Endif
End

Subprog AM_COCHAGE(VALEUR)
Variable Integer VALEUR
Local    Integer I

[M:PREP]UPDFLG(nolign-1)  = 1
[M:PREP]COCHAGE(nolign-1) = VALEUR
If [M:PREP]PRLNUM<>"" GREP="M" Endif
If [M:PREP]ITMREF(nolign-1) <> ""                                                  # hcb 93069 deb
   Raz GERR
   Call MAJ_STA_STAFLG(nolign-1,VALEUR)  From TRTPREPA
   If GERR <> 0                                                                    # hcb 95774
      mkstat = 2
      End
   Endif
Endif                                                                              # hcb 93069 fin

# Si composé de kit/sous-traité, il faut cocher ou décocher les composants
If find([M:PREP]LINTYP(nolign-1),2,10)
   I = nolign
   While find([M:PREP]LINTYP(I),3,4,5,11,12,13)
      [M:PREP]UPDFLG(I)  = 1
      [M:PREP]COCHAGE(I) = VALEUR
      I+=1
   Wend
   # Issue 55983 - 2013-03-14 by MAE : Modif ordre bloc(30=>40)
   Affzo [M:PREP]40
Endif
End

############################
Subprog AV_DLVFLG(VALEUR)
Variable Integer VALEUR
Local    Integer NOL

NOL=nolign-1
pcolor=GCOUL(0)
# Colorisation de l'état du BP si ligne annulée
If [M:PREP]FLGANN(NOL)<>0
   pcolor=GCOUL(1)
Endif
End

############################
Subprog AV_ORITYP(VALEUR)
Variable Integer VALEUR
Local    Integer NOL

NOL=nolign-1
pcolor=GCOUL(0)
# Colorisation du type origine si ligne annulée
If [M:PREP]FLGANN<>0
   pcolor=GCOUL(1)
Endif
End

############################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Decimal WQTY
Local    Integer J, NOL

NOL=nolign-1
pcolor=GCOUL(0)
# Colorisation de la quantite
# - si tout le stock a sortir n'a pas ete renseigne
# - s'il y a une quantite en rupture
# - si l'allocation est globale
If [M:PREP]PRHNUM(NOL)<>""
   # Ligne modifiee et détail stock dans [M:SOW]
   If [M:PREP]UPDFLG(NOL)<>0 & [M:PREP]WSTOSEQ(NOL)<>0
      WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*([M:SOW]WSTOSEQ(J)=[M:PREP]WSTOSEQ(NOL)))
      # Tout le stock a sortir n'a pas ete renseigne
      If WQTY<>[M:PREP]QTYSTU(NOL)
         pcolor=GCOUL(1)
      Else
         WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*
&                   ([M:SOW]WSTOSEQ(J)=[M:PREP]WSTOSEQ(NOL)&[M:SOW]WSTOCOU(J)<>0))
         # Il y a une quantité en rupture
         If WQTY<>[M:PREP]QTYSTU(NOL)
            pcolor=GCOUL(2)
         Endif
      Endif
   # Allocation globale
   Elsif [M:PREP]ALLTYP(NOL)=1
      pcolor=GCOUL(3)
   # Quantité en rupture
   Elsif [M:PREP]SHTQTY(NOL)>0
      pcolor=GCOUL(2)
   Endif
Endif
End

############################
Subprog AS_QTYSTU(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL
NOL = nolign-1

If [M:PREP]PRHNUM(NOL)<>"" & [M:PREP]DLVFLG(NOL)>2 : mkstat=2 : Endif
If find([M:PREP]LINTYP(NOL),3,4,5,11,12,13)        : mkstat=2 : Endif
End

Subprog AM_QTYSTU(VALEUR)
Variable Decimal VALEUR
Local    Integer I, OK
If VALEUR>[M:PREP]QTYSTUMAX(nolign-1)
   OK = 1
   Call AVERTIR(mess(250,184,1),OK) From GESECRAN
   If OK<>2 mkstat=2 : End Endif
Endif
[M:PREP]UPDFLG(nolign-1)  = 1
If [M:PREP]PRLNUM<>"" GREP="M" Endif
# Si composé de kit/sous-traité, recalcul des quantités des composants
If find([M:PREP]LINTYP(nolign-1),2,10)
   I = nolign
   While find([M:PREP]LINTYP(I),3,4,5,11,12,13)
      [M:PREP]UPDFLG(I) = 1
      [M:PREP]QTYSTU(I) = VALEUR/[M:PREP]QTYSTU(nolign-1)*[M:PREP]QTYSTU(I)
      Call QTEARR([M:PREP]QTYSTU(I),[M:PREP]STU(I)) From TRTDIV
      # Cas d'une prépa d'une nomenclature de sous-traitance avec un service forfaitaire
      # Si trt partiel, le service forfaitaire est également traité partiellement
      # Si tout est traité sur le kit, il faut vérifier que le service est complètement traité (pb d'arrondi)
      If [M:PREP]LINTYP(I)=13
          # Si tout est livré sur le composé, tout doit être livré sur le service
          If VALEUR=[M:PREP]QTYSTUMAX(nolign-1)
              If [M:PREP]QTYSTU(I)<>[M:PREP]QTYSTUMAX(I)
                  [M:PREP]QTYSTU(I)=[M:PREP]QTYSTUMAX(I)
              Endif
          Endif
      Endif
      I+=1
   Wend
   # Issue 55983 - 2013-03-14 by MAE : Modif ordre bloc(30=>40)
   Affzo [M:PREP]40
Endif
End

############################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL : NOL=nolign-1
Local    Char    LSERF(GLONSER)
Local    Decimal LQTYF

If VALEUR<>""
   # Alimentation de [M:ALP]
   Case [M:PREP]ORITYP(NOL)
    When 1   : [M:ALP]TRSTYP =  4
    When 2   : [M:ALP]TRSTYP = 17
    When 3,4 : [M:ALP]TRSTYP = 20
   Endcase
   [M:ALP]TRSCOD     = [M:PREP]TRSCOD
   [M:ALP]STOFCY     = [M:PREP]STOFCY
   [M:ALP]ITMREF     = [M:PREP]ITMREF(NOL)
   [M:ALP]PECINTLOC  = 2
   [M:ALP]PECSCOLOC  = 1
   [M:ALP]PECPLFLOC  = 2
   [M:ALP]BESDAT     = [M:PREP]BESDAT(NOL)
   [M:ALP]DLVDAT     = [M:PREP]DLVDAT(NOL)
   [M:ALP]STA        = [M:PREP]STAFIL(NOL)
   If dim([M:PREP]WRH)>0 [M:ALP]WRH=[M:PREP]WRH(NOL) Endif
   #DLUBPC
   [M:ALP]BPRNUM     = [M:PREP]BPCORD(NOL)

   # Détermination no série fin
   Call CTLSORSER("PREP",NOL,VALEUR,[M:PREP]QTYSTU(NOL),LSERF,LQTYF) From STKSOR
   If LQTYF=0
      Raz VALEUR, [M:PREP]SERNUMF(NOL)
   Else
      [M:PREP]SERNUMF(NOL)=LSERF
   Endif
Else
   Raz [M:PREP]SERNUMF(NOL)
Endif
End

############################
Subprog AM_PCK(VALEUR)
Variable Char    VALEUR()
[M:PREP]UPDFLG(nolign-1) = 1
If [M:PREP]PRLNUM<>"" GREP="M" Endif
End

############################
Subprog AM_PCKCAP(VALEUR)
Variable Decimal VALEUR
[M:PREP]UPDFLG(nolign-1) = 1
If [M:PREP]PRLNUM<>"" GREP="M" Endif
End

############################
Subprog C_WRH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

#                                  hcb 95511 deb
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> [M:PREP]STOFCY
   Gosub DECOCHAGE_PREP From TRTPREPA
Endif
End
#                                  hcb 95511 fin



