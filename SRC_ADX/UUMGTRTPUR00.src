$OUVRE_PUR
Local Integer WJ
#----- Définition et chargement des GLONxx et GACTxx nécessaires aux moulinettes achats -----#
Local File =[F:ADS]DOSSIER+".ATYPE" [ATY]
Local File =[F:ADS]DOSSIER+".ACTIV" [ACV]
#-----
If dim(GLONAOB)<1  Global Shortint GLONAOB : Endif
If dim(GLONAMK)<1  Global Shortint GLONAMK : Endif
If dim(GLONAVA)<1  Global Shortint GLONAVA : Endif
If dim(GLONADI)<1  Global Shortint GLONADI : Endif
If dim(GLONAWR)<1  Global Shortint GLONAWR : Endif
If dim(GLONAUS)<1  Global Shortint GLONAUS : Endif
If dim(GLONLAN)<1  Global Shortint GLONLAN : Endif
If dim(GLONCPY)<1  Global Shortint GLONCPY : Endif
If dim(GLONFCY)<1  Global Shortint GLONFCY : Endif
If dim(GLONCUR)<1  Global Shortint GLONCUR : Endif
If dim(GLONUOM)<1  Global Shortint GLONUOM : Endif
If dim(GLONGAC)<1  Global Shortint GLONGAC : Endif
If dim(GLONCOA)<1  Global Shortint GLONCOA : Endif
If dim(GLONVCR)<1  Global Shortint GLONVCR : Endif
If dim(GLONPQH)<1  Global Shortint GLONPQH : Endif
If dim(GLONPSH)<1  Global Shortint GLONPSH : Endif
If dim(GLONPOH)<1  Global Shortint GLONPOH : Endif
If dim(GLONPTH)<1  Global Shortint GLONPTH : Endif
If dim(GLONPNH)<1  Global Shortint GLONPNH : Endif
If dim(GLONPIH)<1  Global Shortint GLONPIH : Endif
If dim(GLONBPR)<1  Global Shortint GLONBPR : Endif
If dim(GLONBPS)<1  Global Shortint GLONBPS : Endif
If dim(GLONITM)<1  Global Shortint GLONITM : Endif
If dim(GACTDEB)<1  Global Libelle  GACTDEB : Endif
If dim(GACTSAD)<1  Global Libelle  GACTSAD : Endif
#-----
Read [ATY] CODTYP="AOB"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3  : Endif
GLONAOB=[F:ATY]LNGTYP
Read [ATY] CODTYP="AMK"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=12 : Endif
GLONAMK=[F:ATY]LNGTYP
Read [ATY] CODTYP="AVA"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=12 : Endif
GLONAVA=[F:ATY]LNGTYP
Read [ATY] CODTYP="ADI"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=20  : Endif
GLONADI=[F:ATY]LNGTYP
Read [ATY] CODTYP="AWR"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=10 : Endif
GLONAWR=[F:ATY]LNGTYP
Read [ATY] CODTYP="AUS"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=5  : Endif
GLONAUS=[F:ATY]LNGTYP
Read [ATY] CODTYP="LAN"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3  : Endif
GLONLAN=[F:ATY]LNGTYP
Read [ATY] CODTYP="CPY"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=5  : Endif
GLONCPY=[F:ATY]LNGTYP
Read [ATY] CODTYP="FCY"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=5  : Endif
GLONFCY=[F:ATY]LNGTYP
Read [ATY] CODTYP="CUR"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3  : Endif
GLONCUR=[F:ATY]LNGTYP
Read [ATY] CODTYP="UOM"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3  : Endif
GLONUOM=[F:ATY]LNGTYP
Read [ATY] CODTYP="GAC"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=15 : Endif
GLONGAC=[F:ATY]LNGTYP
Read [ATY] CODTYP="COA"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=3  : Endif
GLONCOA=[F:ATY]LNGTYP
Read [ATY] CODTYP="VCR"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=20 : Endif
GLONVCR=[F:ATY]LNGTYP
Read [ATY] CODTYP="PQH"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=20 : Endif
GLONPQH=[F:ATY]LNGTYP
Read [ATY] CODTYP="PSH"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=20 : Endif
GLONPSH=[F:ATY]LNGTYP
Read [ATY] CODTYP="POH"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=20 : Endif
GLONPOH=[F:ATY]LNGTYP
Read [ATY] CODTYP="PTH"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=20 : Endif
GLONPTH=[F:ATY]LNGTYP
Read [ATY] CODTYP="PNH"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=20 : Endif
GLONPNH=[F:ATY]LNGTYP
Read [ATY] CODTYP="PIH"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=20 : Endif
GLONPIH=[F:ATY]LNGTYP
Read [ATY] CODTYP="BPR"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=15 : Endif
GLONBPR=[F:ATY]LNGTYP
Read [ATY] CODTYP="BPS"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=15 : Endif
GLONBPS=[F:ATY]LNGTYP
Read [ATY] CODTYP="ITM"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=20 : Endif
GLONITM=[F:ATY]LNGTYP
#----- Code activité "SAD" Stockage systématique des adresses -----#
Read [ACV] CODACT="SAD"
If !fstat
  GACTSAD=[F:ACV]FLACT
Else
  GACTSAD=1
Endif
#----- Code activité "DEB" Déclaration échange de biens CEE -----#
Read [ACV] CODACT="DEB"
If !fstat
  GACTDEB=[F:ACV]FLACT
Else
  GACTDEB=2
Endif
# Issue 74556 - 2011-07-04 by VPO : chargement code activité PTX
Call SET_ACTIVPTX From TRTX3
#-----
If func AFNC.ACTIV("MUL")
  Local File =[F:ADS]DOSSIER+".BPEXCEPT"   [BPE]
Endif

Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]
Local File =[F:ADS]DOSSIER+".FACILITY"   [FCY]
Local File =[F:ADS]DOSSIER+".CPTANALIN"  [CAL]
Local File =[F:ADS]DOSSIER+".PVCRVAT"    [PVV]
Local File =[F:ADS]DOSSIER+".PVCRFOOT"   [PVF]
Local File =[F:ADS]DOSSIER+".GACM"       [GCM]
Local File =[F:ADS]DOSSIER+".GLED"       [LED]
Local File =[F:ADS]DOSSIER+".BPCUSTOMER" [BPC]
Local File =[F:ADS]DOSSIER+".BPARTNER"   [BPR]
Local File =[F:ADS]DOSSIER+".BPSUPPLIER" [BPS]
Local File =[F:ADS]DOSSIER+".BPADDRESS"  [BPA]
Local File =[F:ADS]DOSSIER+".ITMMASTER"  [ITM]
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU]
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU0]
Local File =[F:ADS]DOSSIER+".TABRATVAT"  [TRA]
Local File =[F:ADS]DOSSIER+".TABCHANGE"  [TCH]
Local File =[F:ADS]DOSSIER+".ATABDIV"    [ADI]
Local File =[F:ADS]DOSSIER+".ADOPAR"     [ADP]
Local File =[F:ADS]DOSSIER+".ADOVAL"     [ADW]
Local File =[F:ADS]DOSSIER+".PRICSTRUCT" [PRS]
Local File =[F:ADS]DOSSIER+".TAXLINK"    [TLK]
Local File =[F:ADS]DOSSIER+".AGRPCPY"    [AGC]
Local File =[F:ADS]DOSSIER+".TABDEPAGIO" [TDA]

Local File =[F:ADS]DOSSIER+".TABVAC"     [TVC]
Local Integer NBTVC : NBTVC=nbrecord([TVC])
Local Char WTVCCLE(GLONADI*3)(0..NBTVC)
Local Char WTVCVAT(GLONVAT)(0..NBTVC)
Raz WJ
For [TVC]TVC1
    # Chargement des éléments dans un tableau memoire
    WTVCCLE(WJ)=[F:TVC]VACBPR+'/'+[F:TVC]VACITM
    WTVCVAT(WJ)=[F:TVC]VAT
    WJ+=1
Next

Local File =[F:ADS]DOSSIER+".TABVAT"     [TVT]
Local Integer NBTVT : NBTVT=nbrecord([TVT])
Local Char WTVTVAT(GLONVAT)(0..NBTVT)
Local Integer WTVTVATCHA(0..NBTVT)
Local Integer WTVTVATBAS(0..NBTVT)
Local Integer WTVTVATTYP(0..NBTVT)
Raz WJ
For [TVT]
    # Chargement des éléments dans un tableau memoire
    WTVTVAT(WJ)=[F:TVT]VAT
    WTVTVATCHA(WJ)=[F:TVT]VATCHA
    WTVTVATBAS(WJ)=[F:TVT]VATBAS
    WTVTVATTYP(WJ)=[F:TVT]VATTYP
    WJ+=1
Next

Local File =[F:ADS]DOSSIER+".TABCOEFF"   [TCO]
Local Integer NBTCO : NBTCO=nbrecord([TCO])
Local Char WTCOREF(GLONUOM*3)(0..NBTCO)
Local Decimal WTCOCOEUOM(0..NBTCO)
Raz WJ
For [TCO]
    # Chargement des éléments dans un tableau memoire
    WTCOREF(WJ)=[F:TCO]UOM1+"/"+[F:TCO]UOM2
    WTCOCOEUOM(WJ)=[F:TCO]COEUOM
    WJ+=1
Next

Local File =[F:ADS]DOSSIER+".TABUNIT"    [TUN]
Local Integer WJTUN,NBTUN : NBTUN=nbrecord([TUN])
Local Char WTUNUOM(GLONUOM)(0..NBTUN)
Local Integer WTUNUOMDEC(0..NBTUN)
Local Char WTUNUOMOLD(GLONUOM)
Raz WJTUN
Raz WJ
For [TUN]
    # Chargement des éléments dans un tableau memoire
    WTUNUOM(WJ)=[F:TUN]UOM
    WTUNUOMDEC(WJ)=[F:TUN]UOMDEC
    WJ+=1
Next

Gosub CHARGE_PFI
Gosub INISOC

# Déclaration des variables communes de travail
Local Integer I, J
Local Char     WSOCIETE(GLONCPY),WSITE(GLONFCY)
Local Decimal WDISCRGVAL

#----- Variables locales pour le calcul de TVA -----#
Local Char     ABREV(8)
Local Integer  STAT, TYPREG
Local Decimal  BASE, MONTANT(1..3), MONTDED(1..3)
Local Char     TAXE(GLONVAT)(1..3)
Local Decimal  WRND
Local Char     WCUR(GLONCUR)
Local Char     WITMREF(GLONITM)
Local Char     WBPSNUM(GLONBPS)
Local Date     WDOCDAT
Local Char     WVACBPR(GLONADI)
Local Integer  WVACTYP
Local Decimal  WQTYPUU
Local Decimal  WLINAMT, WLINATIAMT
Local Decimal  WCLCAMT(1..7)
#-----
Local Char     WPARAM(10)

Return

#####################################################################
$CHARGE_PFI
Local File =[F:ADS]DOSSIER+".PFOOTINV"   [PFI]
Local Integer  WNBPFI : WNBPFI=nbrecord([PFI])
Local Integer  WPFINUM (0..WNBPFI)
Local Integer  WPFIVATRUL (0..WNBPFI)
Local Integer  WPFIDACLIN (0..WNBPFI)
Local Integer  WPFIDSPLIN (0..WNBPFI)
Local Integer  WPFIINCDCR (0..WNBPFI)
Local Integer  WPFIDACORD (0..WNBPFI)
Local Integer  WPFIAMTCOD (0..WNBPFI)
Local Integer  WPFICLCORD (0..WNBPFI)
Local Integer  WPFICLCBAS (0..WNBPFI)
Local Char WPFIVACITM (GLONADI) (0..WNBPFI)
Raz WJ
For [PFI]PFI0
    # Chargement des éléments de facturation dans un tableau memoire
    WPFINUM(WJ)=[F:PFI]PFINUM
    WPFIVATRUL(WJ)=[F:PFI]VATRUL
    WPFIVACITM(WJ)=[F:PFI]VACITM
    WPFIDACLIN(WJ)=[F:PFI]DACLIN
    WPFIDSPLIN(WJ)=[F:PFI]DSPLIN
    WPFIINCDCR(WJ)=[F:PFI]INCDCR

    WPFIDACORD(WJ)=[F:PFI]DACORD
    WPFIAMTCOD(WJ)=[F:PFI]AMTCOD
    WPFICLCORD(WJ)=[F:PFI]CLCORD
    WPFICLCBAS(WJ)=[F:PFI]CLCBAS

    WJ+=1
Next
Return

#####################################################################
$RECUP_PFI
If WJ>0
    [F:PFI]PFINUM=WPFINUM(WJ-1)
    [F:PFI]VATRUL=WPFIVATRUL(WJ-1)
    [F:PFI]VACITM=WPFIVACITM(WJ-1)
    [F:PFI]DACLIN=WPFIDACLIN(WJ-1)
    [F:PFI]DSPLIN=WPFIDSPLIN(WJ-1)
    [F:PFI]INCDCR=WPFIINCDCR(WJ-1)

    [F:PFI]DACORD=WPFIDACORD(WJ-1)
    [F:PFI]AMTCOD=WPFIAMTCOD(WJ-1)
    [F:PFI]CLCORD=WPFICLCORD(WJ-1)
    [F:PFI]CLCBAS=WPFICLCBAS(WJ-1)
Else
    # Issue 83267 - 2012-07-02 by VPO
    #Raz [F:SFI]
    Raz [F:PFI]
Endif
Return

#####################################################################
$OUVRE_POH
Local File =[F:ADS]DOSSIER+".GACCOUNT"   [GAC]
Local File =[F:ADS]DOSSIER+".GAUTACE"    [GAU]
Local File =[F:ADS]DOSSIER+".GAUTACED"   [GAD]
Local File =[F:ADS]DOSSIER+".GAUTACEF"   [GAG]
Local File =[F:ADS]DOSSIER+".GACCDUDATE" [DUD]

Local File =[F:ADS]DOSSIER+".PORDER"     [TB0]
Local File =[F:ADS]DOSSIER+".PORDERQ"    [TB1]
Local File =[F:ADS]DOSSIER+".CPTANALIN"  [TB2]

#déclaration des variables locales de travail
Local Char WBPS(GLONBPS),WBPR(GLONBPR),WITM(GLONITM)
Local Char     WEECICT(GLONADI)
Local Char     TPLAN  (GLONCOA)(1..10)
Local Char     TCOMPTE(GLONGAC)(1..10)
Local Char     ID1(20)(1..1), ID2(20)(1..3), WMSG(80)
Local Integer  STAT, I, J, K, WPOPLIN, WPURTYP, SIGN
Local Libelle  WEECLOC
Local Decimal  WRND, WTOTLINAMT, MTLIG
Local Decimal  WQTYPUU, WQTYWEU, WQTYVOU
Local Integer  WREADPOPPOQ,WOKPOPPOQ

#----- Variables locales pour calcul TVA -----#
Local Decimal  WCLCAMT1, WCLCAMT2, WCLCAMT(1..7)
Local Libelle  WCLCFLG1, WCLCFLG2, WCLCFLG(1..7)
Local Decimal  WBASE, WAMTTAX, WDEDTAX
Local Char     WTAX(GLONVAT)

#----- Tableau des taxes en mémoire (20 maxi) -----#
Local Integer  NBTAX
Local Char     TAX(GLONVAT)(20)
Local Decimal  BASTAX(20)
Local Decimal  AMTTAX(20)
Local Decimal  DEDTAX(20)
Local Libelle  PURTYP(20)
Local Libelle  VATTYP(20)
#----- Tableau des éléments de facturation en mémoire (15 maxi) -----#
Local Integer  NBFAC
Local Integer  INVDTA(15)
Local Decimal  INVDTAAMT(15)
Local Decimal  INVLINAMT(15)
Local Decimal  INVCPLAMT(15)
Local Libelle  INVLINFLG(15)
Local Libelle  DEBCDT(15)
Local Char     INVDTAVAT(GLONVAT)(15)
Local Decimal  DTAAMTTAX(15)
Local Decimal  DTADEDTAX(15)
Local Decimal  CUMLIG(15)

Return

#####################################################################
$CAL_STK
Call STK (WTAB_CAL,WCPT_CAL,[F:CAL]ABRFIC-'/'-num$([F:CAL]VCRTYP)-'/'-[F:CAL]VCRNUM-'/'-num$([F:CAL]VCRLIN)-'/'-num$([F:CAL]VCRSEQ)-'/'-[F:CAL]CPLCLE-'/'-num$([F:CAL]ANALIG)) From TRTMIG
Return
$PVV_STK
Call STK (WTAB_PVV,WCPT_PVV,[F:PVV]VCRNUM-'/'-num$([F:PVV]VCRTYP)-'/'-num$([F:PVV]IND)) From TRTMIG
Return
$PVF_STK
Call STK (WTAB_PVF,WCPT_PVF,[F:PVF]VCRNUM-'/'-num$([F:PVF]VCRTYP)-'/'-num$([F:PVF]IND)) From TRTMIG
Return
#####################################################################
$CAL_ERRTRA
Call ERRTRA (WTAB_CAL,WCPT_CAL,"File CPTANALIN(ABRFIC/VCRTYP/VCRNUM/VCRLIN/VCRSEQ/CPLCLE/ANALIG)=") From TRTMIG
Return
$PVV_ERRTRA
Call ERRTRA (WTAB_PVV,WCPT_PVV,"File PVCRVAT(VCRNUM/VCRTYP/IND)=") From TRTMIG
Return
$PVF_ERRTRA
Call ERRTRA (WTAB_PVF,WCPT_PVF,"File PVCRFOOT(VCRNUM/VCRTYP/IND)=") From TRTMIG
Return



#-------------------------------------------------------------#
# Conversion quantité d"une unité vers une autre avec arrondi #
# ----------------------------------------------------------- #
# WUOM1 : Unité d'origine                                     #
# WUOM2 : Unité destination                                   #
# WQTY  : Quantité à convertir puis quantité convertie        #
#-------------------------------------------------------------#
$CONVERT_QTY
#----- Conversion quantité si unités différentes -----#
If WUOM1<>WUOM2
  Local    Decimal WCOEF
  WJ=find(WUOM1+"/"+WUOM2,WTCOREF(0..NBTCO))
  If WJ>0
      WCOEF=WTCOCOEUOM(WJ-1)
  Else
      WJ=find(WUOM2+"/"+WUOM1,WTCOREF(0..NBTCO))
      If WJ>0 & WTCOCOEUOM(WJ-1)<>0
        WCOEF=1/WTCOCOEUOM(WJ-1)
      Else
        WCOEF=1
      Endif
  Endif
  WQTY*=WCOEF
Endif
Gosub RECHTUN
Return

##############################################################
$RECHTUN
#----- Arrondi de la quantité -----#
If WTUNUOMOLD<>WUOM2
    If WUOM2>WTUNUOMOLD
    WJ=find(WUOM2,WTUNUOM(WJTUN..NBTUN))
    WJTUN+=WJ
    Else
    WJTUN=find(WUOM2,WTUNUOM(0..WJTUN))
    Endif
    WTUNUOMOLD=WUOM2
Endif
If WJTUN>0
    WQTY=arr(WQTY,10^-WTUNUOMDEC(WJTUN-1))
Endif
Return

##############################################################
## Init des tables société/sites                            ##
##############################################################
$INISOC

Local Integer LNBSOC : LNBSOC=rowcount([F:CPY])
If LNBSOC>GDIMSOC
 GDIMSOC=LNBSOC+20
 Global Char    GSOC(GLONCPY)(1..GDIMSOC)
 Global Char    GDEVSOC(GLONCUR)(1..GDIMSOC)
 Global Char    GLEGSOC(GLONADI)(1..GDIMSOC)
 Global Libelle GTYPSOC(1..GDIMSOC)
 Global Char    GGCMSOC(GLONGCM)(1..GDIMSOC)
Endif

Raz GNBSOC
For [CPY]
 GNBSOC += 1
 GSOC(GNBSOC)    = [F:CPY]CPY
 If dim([F:CPY]ACCCUR)>0
  GDEVSOC(GNBSOC) = [F:CPY]ACCCUR
 Else
  GDEVSOC(GNBSOC) = ""
 Endif
 GLEGSOC(GNBSOC) = [F:CPY]LEG
 If dim(GTYPSOC)>0
  GTYPSOC(GNBSOC) = [F:CPY]CPYLEGFLG
 Endif
 If dim(GGCMSOC)>0
  If dim([F:CPY]ACM)>0
   GGCMSOC(GNBSOC) = [F:CPY]ACM
  Else
   GGCMSOC(GNBSOC) = ""
  Endif
 Endif
Next

Local Integer LNBSIT : LNBSIT=rowcount([F:FCY])
If LNBSIT>GDIMSIT
 GDIMSIT=LNBSIT+20
 Global Char GSITE(GLONFCY)(1..GDIMSIT)
 Global Char GSOCSITE(GLONCPY)(1..GDIMSIT)
 Global Char GFINSITE(GLONFCY)(1..GDIMSIT)
Endif

Raz GNBSITE
For [FCY]
 GNBSITE += 1
 GSITE(GNBSITE)    = [F:FCY]FCY
 GSOCSITE(GNBSITE) = [F:FCY]LEGCPY
 GFINSITE(GNBSITE) = [F:FCY]FINRSPFCY
 #----------------------------------------------#
 # si le site financier n'est pas renseigné     #
 # dans ce cas le site est lui même financier   #
 #----------------------------------------------#
 If GFINSITE(GNBSITE)  = ""
  GFINSITE(GNBSITE) = [F:FCY]FCY
 Endif
Next

Return
