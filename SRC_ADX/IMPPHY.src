#<AdxTL>@(#)2.0.0.0 $Revision$
#
#*********************************************************************
#
#           SYRCUSE PHYSICAL ASSET IMPORT PROCESS
#
#*********************************************************************
# Creation
# GLE   07.07.2008
#
#*********************************************************************
# Updates
#
# XXXXX DD.MM.YYYY FQ000000   : XXX
#
#*********************************************************************

$ACTION
  Case ACTION
    When "IMP_OUVRE"     : Gosub IMP_OUVRE
    When "AP_IMPORT"     : Gosub AP_IMPORT
    When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CRE_MOD
    When "IMP_VERIF_MOD" : Gosub IMP_VERIF_CRE_MOD
    When "IMP_FERME"     : Gosub IMP_FERME
    When Default
  Endcase
Return

####################################################################
# At the beginning of import process
####################################################################
$IMP_OUVRE
  Local Integer CRELOC           : # Automatic creation of the location and the building
  Local Integer CREBPR           : # Automatic creation of the supplier

  # Core data tables opening
  If !clalev([F:BPR]) : Local File BPARTNER  [BPR] : Endif : # Supplier table

  # Core data automatic creation parameters
  Local Char LPARM(255)
  Call PARAM("","CRELOC",LPARM) From ADOVAL : # Location
  CRELOC = val(LPARM)
  Call PARAM("","CREBPR",LPARM) From ADOVAL : # Supplier
  CREBPR = val(LPARM)

  # To save time the PHYELT class is instanciated at the beginning of the process
  Local Instance PHY Using C_PHYELT
  PHY = NewInstance C_PHYELT AllocGroup null
Return

####################################################################
# After each line reading
####################################################################
$AP_IMPORT
  Call ECR_TRACE(mess(143,141,1)-[F:PHY]PHYREF-[F:PHY]PHYDES1,0) From GESECRAN

  # Core data autotic creation if asked for

  # Supplier
  If CREBPR = G_OUI and GIMP(7) <> ""
    Call CRE_BPR([F:PHY]BPS, GIMP(7)) From GLOFUNCIMP
  Endif

  # Building
  If CRELOC = G_OUI and GIMP(1) <> ""
    Call CRE_BUI(GIMP(1), GIMP(2)) From GLOFUNCIMP
  Endif

  # Location
  If CRELOC = G_OUI and [F:PHY]LCTCOD <> ""
    Call CRE_LCT([F:PHY]LCTCOD, GIMP(4), GIMP(1), [F:PHY]FCY, GIMP(3)) From GLOFUNCIMP
  Endif

  # Physical asset creation
  Local Integer  RET

  [L]RET = fmet PHY.AINIT()

  SetInstance PHY With [F:PHY]

  [L]RET = fmet PHY.AINSERT()
  If [L]RET = [V]CST_AOK
    Call ECR_TRACE(mess(218,GML_MSGCIG,1)-PHY.PHYREF-PHY.PHYDES1,0) From GESECRAN
  Else
    Call WRITE_ERROR_STACK_CLASSIC(PHY, [V]CST_AERROR) From FXDFCT_SYRA
  Endif
Return

####################################################################
# Before the insert/update transaction
####################################################################
$IMP_VERIF_CRE_MOD
  OK = 0 : # The record mustn't be created by the import process but by the class in $AP_IMPORT
Return

####################################################################
# At the end of import process
####################################################################
$IMP_FERME
  # Core data tables closure
  If clalev([F:BPR]) : Close Local File [BPR]  : Endif

  # Free the PHYELT class
  FreeGroup PHY
Return
