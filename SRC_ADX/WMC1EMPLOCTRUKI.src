If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.PAYPROSTA
 Gosub PROPAGATE_PAYPROSTA
Endif
Return

$INIT_PAYPROSTA
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "PAYPROSTA"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.PAYPROSTA=0 and fmet this.AGETATTRIBUTE("PAYPROSTA","$isMandatory")="true"
 this.PAYPROSTA = 1
Endif
Return
 
$CONTROL_PAYPROSTA
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "PAYPROSTA"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_PAYPROSTA             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_PAYPROSTA             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_PAYPROSTA
[L]CURPRO = "PAYPROSTA"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.PAYPROSTA=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_PAYPROSTA
[L]CURPRO = "PAYPROSTA"
If this.PAYPROSTA<0 or this.PAYPROSTA>len(mess(0,11815,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"11815 ->"-num$(this.PAYPROSTA)-mess(99,123,1)):  Return : # Local menu "11815 -> Invalid option
Endif
Return

$_AOTHERS_PAYPROSTA
[L]CURPRO = "PAYPROSTA"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_PAYPROSTA
[L]CURPRO = "PAYPROSTA"
Return

$PROPAGATE_PAYPROSTA
this.isReadonly = 0
[L]CURPRO = "PAYPROSTA"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_PAYPROSTA
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "PAYPROSTA"
$_LNKPRO_PAYPROSTA
Return




