[L]CURPRO = "RITWRK"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_RITWRK
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "RITWRK"
$_LNKPRO_RITWRK
Return


####################################################################
# 7 : TAXCOD Tax code ( Field Miscellaneous table number)
####################################################################

$SET_TAXCOD
If [L]_AOLDVAL<>this.TAXCOD
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_TAXCOD
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.TAXCOD
 Gosub PROPAGATE_TAXCOD
Endif
Return

$INIT_TAXCOD
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "TAXCOD"
[L]ASTATUS =  func ADI_TOOL.ADI_INI(this,"TAXCOD",this.TAXCOD,11800)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_TAXCOD
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "TAXCOD"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_TAXCOD                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_TAXCOD                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_TAXCOD
[L]CURPRO = "TAXCOD"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.TAXCOD,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_TAXCOD
[L]CURPRO = "TAXCOD"
If vireblc(this.TAXCOD,2)<>vireblc(format$("K:20B",this.TAXCOD),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_TAXCOD
[L]CURPRO = "TAXCOD"
[L]ASTATUS =  func ADI_TOOL.ADI_CONT(this,"TAXCOD",this.TAXCOD,11800,"")
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_TAXCOD
[L]CURPRO = "TAXCOD"
Return

$PROPAGATE_TAXCOD
this.isReadonly = 0
[L]CURPRO = "TAXCOD"
Gosub _LNKPRO_TAXCOD
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_TAXCOD
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "TAXCOD"
$_LNKPRO_TAXCOD
If vireblc(this.TAXCOD,2)<>""
 # Link ATABDIV
 Local File ATABDIV [WADI]
 Read [F:WADI]CODE = 11800;this.TAXCOD
 If !fstat
  Local File ATEXTRA [WAXX]
  Local Char ILAN(GLONLAN)
  For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF
   For [F:WAXX] Where CODFIC="ATABDIV" & ZONE="SHODES" & IDENT1=num$([F:WADI]NUMTAB) & IDENT2=[F:WADI]CODE & LANGUE = ILAN
    [L]ASTATUS = fmet this.ASETATTRIBUTE("TAXCOD","$title",[WAXX]TEXTE)
    Break 2
   Next WAXX
  Next ILAN
  LogicClose File [WAXX]
  Local File ATEXTRA [WAXX]
  Local Char ILAN(GLONLAN)
  For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF
   For [F:WAXX] Where CODFIC="ATABDIV" & ZONE="LNGDES" & IDENT1=num$([F:WADI]NUMTAB) & IDENT2=[F:WADI]CODE & LANGUE = ILAN
    [L]ASTATUS = fmet this.ASETATTRIBUTE("TAXCOD","$description",[WAXX]TEXTE)
    Break 2
   Next WAXX
  Next ILAN
  LogicClose File [WAXX]
 Endif
 LogicClose File [WADI]
Endif
Return


