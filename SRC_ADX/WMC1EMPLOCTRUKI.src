$INIT_NICAT
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "NICAT"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_NICAT
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "NICAT"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_NICAT                 : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_NICAT                 : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_NICAT
[L]CURPRO = "NICAT"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.NICAT,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_NICAT
[L]CURPRO = "NICAT"
If vireblc(this.NICAT,2)<>vireblc(format$("K:30X",this.NICAT),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_NICAT
[L]CURPRO = "NICAT"
If vireblc(this.NICAT,2)<>""
 If fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent")=""
  [L]ASTATUS =  func WMTYPNIC.ACTRLREF(this,"NICAT",this.NICAT,this.NICAT,"")
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Else
  If this.NICAT<>evalue("this.APARENT."+fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent"))
   [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(83,123,1)) :  Return : # Invalid value
  Endif
 Endif
Endif
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_NICAT
[L]CURPRO = "NICAT"
Return

$PROPAGATE_NICAT
this.isReadonly = 0
[L]CURPRO = "NICAT"
Gosub _LNKPRO_NICAT
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_NICAT
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "NICAT"
$_LNKPRO_NICAT
If vireblc(this.NICAT,2)<>""
 # Link NICDET
 Local File NICDET [WNIC]
 Read [F:WNIC]NIC0 = this.NICAT
 If !fstat
  [L]ASTATUS = fmet this.ASETATTRIBUTE("NICAT","$description",[F:WNIC]DES)
 Endif
 LogicClose File [WNIC]
Endif
Return


