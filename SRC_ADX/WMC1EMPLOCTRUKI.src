# 6 : RITWRK Right to work ( Field Local menu number 1)
####################################################################

$SET_RITWRK
If [L]_AOLDVAL<>this.RITWRK
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_RITWRK
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.RITWRK
 Gosub PROPAGATE_RITWRK
Endif
Return

$INIT_RITWRK
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "RITWRK"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.RITWRK=0 and fmet this.AGETATTRIBUTE("RITWRK","$isMandatory")="true"
 this.RITWRK = 1
Endif
Return
 
$CONTROL_RITWRK
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI
[L]CURPRO = "RITWRK"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_RITWRK                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_RITWRK                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_RITWRK
[L]CURPRO = "RITWRK"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.RITWRK=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_RITWRK
[L]CURPRO = "RITWRK"
If this.RITWRK<0 or this.RITWRK>len(mess(0,1,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"1 ->"-num$(this.RITWRK)-mess(99,123,1)):  Return : # Local menu "1 -> Invalid option
Endif
Return

$_AOTHERS_RITWRK
[L]CURPRO = "RITWRK"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_RITWRK
[L]CURPRO = "RITWRK"
Return

$PROPAGATE_RITWRK
