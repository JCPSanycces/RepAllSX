# Module        : Finance
# Description   : - Economic reason code by product (Class PBDECODITM)
######################################################################################################
 # Updates :
 # Date       |Author  |Version|Description
 # 2015-12-21 |ANGRE   |U10    | SAM # 111399 changed ACTION to ARULE in $PROPERTIES. Moved content from $METHODS to $EVENTS
######################################################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
      Case [L]AEVENT
        When "AREAD"                  : Gosub AREAD
        When "AINSERT"                : Gosub AINSERT
        When "AUPDATE"                : Gosub AUPDATE
        When "ADELETE"                : Gosub ADELETE

      Endcase
   When "PBDECODITMD"
        Case [L]AEVENT
          When "AREAD_AFTER"   : Gosub PBDECODITMD_AREAD_AFTER
          When "ADDLINE_AFTER" : Gosub PBDECODITMD_ADDLINE_AFTER
        Endcase
Endcase

Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


# SAM # 111399 $METHODS outcommented content is now implemented in $EVENT
$METHODS
#Case [L]CURPTH
#   When ""
#      Case [L]ACTION
#        When "AREAD"                  : Gosub AREAD
#        When "AINSERT"                : Gosub AINSERT
#        When "AUPDATE"                : Gosub AUPDATE
#        When "ADELETE"                : Gosub ADELETE
#
#      Endcase
#   When "PBDECODITMD"
#        Case ACTION
#          When "AREAD_AFTER"   : Gosub PBDECODITMD_AREAD_AFTER
#          When "ADDLINE_AFTER" : Gosub PBDECODITMD_ADDLINE_AFTER
#        Endcase
#Endcase
#
Return


$PROPERTIES
Case [L]CURPRO
  When "LEG"       : Gosub PROP_LEG
Endcase
Return

$PROP_LEG
  # SAM # 111399 changed ACTION to ARULE
  #Case ACTION
  Case [L]ARULE
    When "PROPAGATE" : Gosub PROPAGATE_LEG
    When "CONTROL"   : Gosub CHECK_LEG
  Endcase
Return


#** #############################################################################################################
#*
#* Sub chunk:  CHECK_LEG
#*
#* Purpose:    check if the given legislation is valid
#*
#*! #############################################################################################################
$CHECK_LEG
   # if the given legislation doesn't exist -> message
   If clalev([F:ADI])=0  : Local File ATABDIV    [ADI]  : Endif
   Read [ADI]CODE = 909;this.LEG
   If fstat
     ASTATUS = fmet this.ASETERROR("LEG", func AFNC.MES1( mess(345,107,1), this.LEG ), CST_AERROR ) # "$1$ is not a valid legislation."
   Else
     # if the parameter 'PBDDCLITM' is not set for the given legislation -> message
     If fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVLEG,this.LEG,"PBDDCLITM") <> 2# CHECK_LEG_PARAM(this.LEG) <> 1
       ASTATUS = fmet this.ASETERROR( "LEG", func AFNC.MES2( mess(346,107,1), this.LEG, "PBDDCLITM" ), CST_AERROR )
                                           # "$1$ is not a valid legislation in this context. Please check parameter '$2$'."
     Endif
   Endif
Return



#** #############################################################################################################
#*
#* Sub chunk:  PROPAGATE_LEG
#*
#* Purpose:    make sure that the legislation is unique
#*
#*! #############################################################################################################
$PROPAGATE_LEG
  Local File PBDECODITM [PBD]
  Local Integer EXIST
  For [PBD] Where LEG=this.LEG
    EXIST += 1
    # The syntax Break condition means that if condition is true (ie 1), a Break 1 is done (Break 0 does nothing)
    Break EXIST > 0
  Next

  #if the given legislation is already in use -> use "Edit" function to add or delete lines.
  If EXIST
    ASTATUS = fmet this.ASETERROR("LEG", func AFNC.MES1( mess(357,107,1), this.LEG ), CST_AERROR ) # "Legislation $1$ already in use. Please use 'Edit' to add lines."
    this.LEG = ""
  Endif
Return



#** #############################################################################################################
#*
#* Sub chunk:  AREAD
#*
#* Purpose:    read the existing data from the database
#*
#*! #############################################################################################################
$AREAD
Local File PBDECODITM [PBD]
Local Integer ILINE

  For [PBD] Where LEG=this.LEG

    #for every record in the database add a line in the grid and read the data from the database into this line
    ILINE = fmet this.ADDLINE("PBDECODITMD",CST_ALASTPOS)
    [L]ASTATUS = fmet this.PBDECODITMD(ILINE).AREAD([F:PBD]LEG, [F:PBD]ITM)
    # The syntax Break condition means that if condition is true (ie 1), a Break 1 is done (Break 0 does nothing)
    Break [L]ASTATUS>=[V]CST_AERROR
  Next
Return

#** #############################################################################################################
#*
#* Sub chunk:  AINSERT
#*
#* Purpose:    insert the new lines in the database
#*
#*! #############################################################################################################
$AINSERT
Local Integer ILINE

# check consistency
  Gosub CTL_CONSISTENCY : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Loop on every line that is marked as new (CST_ANEW) has to be created
  For ILINE=1 To maxtab(this.PBDECODITMD)
    If this.PBDECODITMD(ILINE)<>null
      If this.PBDECODITMD(ILINE).ASTALIN = CST_ANEW
        [L]ASTATUS = fmet this.PBDECODITMD(ILINE).AINSERT()
        Break ([L]ASTATUS>=[V]CST_AERROR)
      Endif
    Endif
  Next
Return



#** #############################################################################################################
#*
#* Sub chunk:  AUPDATE
#*
#* Purpose:    update the data. Deleted, updated and new lines
#*
#*! #############################################################################################################
$AUPDATE
Local Integer ILINE

  Gosub CTL_CONSISTENCY : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Delete the lines
  For ILINE= 1 To maxtab(this.PBDECODITMD)
    If this.PBDECODITMD(ILINE)<>null
      If this.PBDECODITMD(ILINE).ASTALIN = [V]CST_ADEL
        [L]ASTATUS = fmet this.PBDECODITMD(ILINE).ADELETE()
        If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
      Endif
    Endif
  Next

# Update the lines
  For ILINE= 1 To maxtab(this.PBDECODITMD)
    If this.PBDECODITMD(ILINE)<>null
      If this.PBDECODITMD(ILINE).ASTALIN = [V]CST_AUPD
        [L]ASTATUS = fmet this.PBDECODITMD(ILINE).AUPDATE()
        If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
      Endif
    Endif
  Next

# Insert the lines
  For ILINE= 1 To maxtab(this.PBDECODITMD)
    If this.PBDECODITMD(ILINE)<>null
      If this.PBDECODITMD(ILINE).ASTALIN = [V]CST_ANEW
        #[L]ASTATUS = fmet this.ASETERROR("irgendwas", num$(this.PBDECODITMD(ILINE).ASTALIN) -"(ASTALIN):"-mess(94,139,1),[V]CST_AERROR)
        [L]ASTATUS = fmet this.PBDECODITMD(ILINE).AINSERT()
        Break [L]ASTATUS>=[V]CST_AERROR
      Endif
    Endif
  Next
Return


#** #############################################################################################################
#*
#* Sub chunk:  ADELETE
#*
#* Purpose:    delete all lines for a legislation
#*
#*! #############################################################################################################
$ADELETE
Local Integer ILINE
  For ILINE= 1 To maxtab(this.PBDECODITMD)
    If this.PBDECODITMD(ILINE)<>null
      [L]ASTATUS = fmet this.PBDECODITMD(ILINE).ADELETE()
      Break [L]ASTATUS>=[V]CST_AERROR
    Endif
  Next
Return


$PBDECODITMD_AREAD_AFTER
# Assign ASTALIN to CST_ALL (they have the value 'CST_ANEW' just after AREAD method)
this.ASTALIN = [V]CST_ALL
Return

$PBDECODITMD_ADDLINE_AFTER
# To initialize properties of the header
this.LEG = this.APARENT.LEG
#this.YNAM = this.APARENT.YNAM
Return






# Check the consistency
$CTL_CONSISTENCY
Local Shortint LINE_FOUND
Local Integer IL, JL

  For IL=1 To maxtab(this.PBDECODITMD)
    If this.PBDECODITMD(IL)<>null
      If find(this.PBDECODITMD(IL).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        LINE_FOUND=1
      Endif
    Endif
  Next IL
  If LINE_FOUND=0
    [L]ASTATUS = fmet this.ASETERROR("",mess(178,123,1),[V]CST_AERROR)
  Endif
Return

