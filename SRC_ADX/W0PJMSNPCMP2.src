#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMSNPCMP2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBTYP
mkstat = 0
zoncou = "NBTYP"
indice = 0
status = 1
zoncou = "NBTYP"
If varmode([M]NBTYP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBTYP" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBTYP
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBTYP = nolign
   status = 75
   Call SAI_NBTYP(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBTYP(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBTYP
mkstat = 0
zoncou = "NBTYP"

## Zone ICO
mkstat = 0
zoncou = "ICO"
If varinit([M]ICO,indice)=0
 [M]ICO(indice) = "Folder.GIF"
Endif

## Zone EXPFLG
mkstat = 0
zoncou = "EXPFLG"
If varinit([M]EXPFLG,indice)=0
 [M]EXPFLG(indice) = 1
Endif

## Zone NBTYP
mkstat = 0
zoncou = "NBTYP"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMSNPCMP2"
Return

