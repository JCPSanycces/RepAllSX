#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque GRASOL

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "ABA"         : Gosub ABANDON
 When "ENR"         : Gosub ENREG
 When "FIN"         : Gosub FIN
 When Default
Endcase
Return

$OUVRE
If clalev([GTC3])=0 : Local File GTABACC3 [GTC3] : Endif
Return

$DEBUT
Local Char SYMBOLE(20)
Local Integer VERROU
Raz [M:GRS]
VERROU = 0
[M:GRS]CNSCOD = PARAM(1)
[M:GRS]COD    = PARAM(2)
If [M:GRS]CNSCOD="CPT"
 Chgfmt [GRS]TYPAMT  With "+LA:3605"
 Chgfmt [GRS]TYPAMT2 With "-LA:3606"
Else
 Chgfmt [GRS]TYPAMT  With "-LA:3605"
 Chgfmt [GRS]TYPAMT2 With "+LA:3606"
Endif
Gosub CHARGE
Return

$CHARGE
Gosub DEVERROU
Read [GTC3]GTC3= PARAM(1);PARAM(2)
If !fstat
 [M:GRS]=[F:GTC3]
 Gosub GRISE_REPGRAS
 Gosub GRISE_TYPGRAS
 Affzo [GRS]
Endif
Return

$APRES_MODIF
If !VERROU
 SYMBOLE = "GTC"+[M:GRS]COD+"\"+[M:GRS]CNSCOD
 Lock =SYMBOLE With lockwait=0
 If fstat
  FOK  = 0
  GERR = 1 : Return
 Else
  VERROU = 1
  REP = "M"
 Endif
Endif
Return

$ABANDON
REP = ""
Gosub CHARGE
Return

$DEVERROU
Unlock =SYMBOLE
Return

$ENREG
Call DEBTRANS From GLOCK
Gosub TR1
If GOK<1
 OK = 0 : Return
Endif
Gosub DEVERROU
VERROU = 0
REP = ""
Return

$TR1
GOK = 1
Trbegin [GTC3]
 Raz [F:GTC3]
 Readlock [GTC3]GTC3 = [M:GRS]CNSCOD;[M:GRS]COD
 If fstat=1
  GOK=-1 : GLOCK="$GTABACC3" : Goto ROLL_TR1
 Elsif !fstat
  [F:GTC3] = [M:GRS]
  [F:GTC3]UPDDAT = date$
  [F:GTC3]UPDUSR = GUSER
  [F:GTC3]UPDTIM = time
  Rewrite [GTC3]
  If fstat
   GOK=0 : Call FSTA("GTC3") From GLOCK : Goto AB_TR1
  Endif
 Else
  [F:GTC3] = [M:GRS]
  [F:GTC3]CREDAT = date$
  [F:GTC3]CREUSR = GUSER
  [F:GTC3]CRETIM = time
  Write [GTC3]
  If fstat
   GOK = 0 : Call FSTA("GTC3") From GLOCK
   Goto AB_TR1
  Endif
 Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return

$FIN
Gosub DEVERROU
Return

######################################################################################
## Etiquette du masque GRASOL
######################################################################################
Subprog AM_REPGRAS(VALEUR)
Variable Integer VALEUR
[M]REPGRAS = VALEUR
Gosub GRISE_REPGRAS
Gosub GRISE_TYPGRAS
End

Subprog AP_OPTGRAS(VALEUR)
Variable Char    VALEUR()
Case [M]REPGRAS
 When 2 : [M]AFFGRAS = val([M]VALREPGRAS)
 When 3 : [M]POSGRAS = val([M]VALREPGRAS)
Endcase
End

Subprog AS_TYPGRAS(VALEUR)
Variable Integer VALEUR
GMENLOC(3) = 1
GMENLOC(4) = 1
GMENLOC(5) = 1
GMENLOC(6) = 1
End

Subprog AP_TYPGRAS(VALEUR)
Variable Integer VALEUR
[M]TYPGRAS = VALEUR
Gosub GRISE_TYPGRAS
End

Subprog AS_FSHGRAS(VALEUR)
Variable Integer VALEUR
Case [M]TYPGRAS
 When 2
  GMENLOC(1)=0 : GMENLOC(2)=0 : GMENLOC(3)=0
  GMENLOC(4)=1 : GMENLOC(5)=1 : GMENLOC(6)=1
  If [M]DEFGRAS=4 or  [M]DEFGRAS=5
    GMENLOC(2)=1 : GMENLOC(3)=1
  Endif
 When 3
  GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=1
  GMENLOC(4)=0 : GMENLOC(5)=0 : GMENLOC(6)=0
 When Default  : mkstat=1
Endcase
End

Subprog AP_FSHGRAS(VALEUR)
Variable Integer VALEUR
[M]FSHGRAS = VALEUR
Gosub AFF_IMAGE
End

Subprog AS_DEFGRAS(VALEUR)
Variable Integer VALEUR
If [M]TYPGRAS<>1 and [M]TYPGRAS<>2 : mkstat=1 : Endif
If [M]FSHGRAS<>1
 GMENLOC(4)=1
Else
 GMENLOC(4)=0
Endif
End
End

Subprog AP_DEFGRAS(VALEUR)
Variable Integer VALEUR
[M]DEFGRAS = VALEUR
Gosub AFF_IMAGE
End

######################################################################################
$AFF_IMAGE
Local Char NOMIMAG(200) , IMAG1(20)
Case [M]TYPGRAS
 When 1,2
  Case [M]DEFGRAS
   When 1 : IMAG1="xbar"
   When 2 : IMAG1="xline"
   When 3 : IMAG1="xarea"
   When 4 : IMAG1="xpie"
   When 5 : IMAG1="xradar"
  Endcase
  If IMAG1<>""
   Case [M]FSHGRAS
    When 1 : IMAG1+="m"
    When 2 : IMAG1+="cu"
    When 3 : IMAG1+="co"
   Endcase
  Endif
 When 3
  Case [M]FSHGRAS
   When 4 : IMAG1="calmonth"
   When 5 : IMAG1="calweek"
   When 6 : IMAG1="calday"
  Endcase
 When 5
  IMAG1="gantt"
Endcase
Read [ASB]ASB0="SCR";toupper(IMAG1)
If !fstat
  [M]IMAGS=[F:ASB]BLOB
Else
  Raz [M]IMAGS
Endif
Affzo
Return

######################################################################################
$GRISE_REPGRAS
Case [M]REPGRAS
 When 0,1 : # Caractère
  [M]OPTGRAS = "" : [M]TYPGRAS = 0 : [M]DEFGRAS = 0
  If dim([M]TYPAMT)>=1  : [M]TYPAMT = 1 : Endif
  If dim([M]TYPAMT2)>=1 : [M]TYPAMT2 = 1 : Endif
  Raz [M]IMAGS
  Affzo OPTGRAS, TYPGRAS, DEFGRAS, IMAGS
  Grizo OPTGRAS, TYPGRAS, DEFGRAS, IMAGS
  If dim([M]TYPAMT)>=1  : Affzo TYPAMT  : Grizo TYPAMT  : Endif
  If dim([M]TYPAMT2)>=1 : Affzo TYPAMT2 : Grizo TYPAMT2 : Endif
 When 2 : # Caractère ou graphique
  Actzo OPTGRAS
  Actzo DEFGRAS, IMAGS, TYPGRAS
  If dim([M]TYPAMT)>=1  : Actzo TYPAMT  : Endif
  If dim([M]TYPAMT2)>=1 : Actzo TYPAMT2 : Endif
 When 3 : # Caractère et graphique
  Actzo OPTGRAS
  Actzo DEFGRAS, IMAGS, TYPGRAS
  If dim([M]TYPAMT)>=1  : Actzo TYPAMT  : Endif
  If dim([M]TYPAMT2)>=1 : Actzo TYPAMT2 : Endif
 When 4 : # Graphique
  [M]OPTGRAS = ""
  Affzo OPTGRAS
  Grizo OPTGRAS
  Actzo DEFGRAS, IMAGS, TYPGRAS
  If dim([M]TYPAMT)>=1  : Actzo TYPAMT  : Endif
  If dim([M]TYPAMT2)>=1 : Actzo TYPAMT2 : Endif
Endcase
Gosub AFF_OPTIONS
Return

######################################################################################
$AFF_OPTIONS
Case [M]REPGRAS
 When 2
  [M]INTREPGRAS = mess(164,139,1) : # Affichage par défaut
  [M]TYPREPGRAS = "M"
  [M]LIBREPGRAS = 2936
  [M]LNGREPGRAS = 20
  [M]VALREPGRAS = num$([M]AFFGRAS)
  [M]OPTGRAS = [M]VALREPGRAS
  Call CHARGE([M]OPTGRAS,[M]TYPREPGRAS,[M]LIBREPGRAS,[M]LNGREPGRAS,[M]VALREPGRAS) From FMTVAR
 When 3
  [M]INTREPGRAS = mess(163,139,1) : # Position graphique
  [M]TYPREPGRAS = "M"
  [M]LIBREPGRAS = 2931
  [M]LNGREPGRAS = 20
  [M]VALREPGRAS = num$([M]POSGRAS)
  [M]OPTGRAS = [M]VALREPGRAS
  Call CHARGE([M]OPTGRAS,[M]TYPREPGRAS,[M]LIBREPGRAS,[M]LNGREPGRAS,[M]VALREPGRAS) From FMTVAR
 When Default
  [M]INTREPGRAS = ""
Endcase
Chgtzn [M]OPTGRAS With [M]INTREPGRAS
Return

######################################################################################
$GRISE_TYPGRAS
Case [M]REPGRAS
 When 0,1 : # Graphique
  [M]FSHGRAS = 0
  Affzo FSHGRAS
  Grizo FSHGRAS
 When Default : # Caractère ou graphique/Caractère ou graphique/Graphique
  Case [M]TYPGRAS
   When 1  : # Graphe Flash
    [M]FSHGRAS = 0 : Affzo FSHGRAS : Grizo FSHGRAS
   When 2 : # Graphe multi Flash
    Actzo FSHGRAS
   When 4 : # XSL
    [M]FSHGRAS = 0 : Affzo FSHGRAS : Grizo FSHGRAS
  Endcase
Endcase
Gosub AFF_IMAGE
Return
