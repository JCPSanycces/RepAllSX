######################################################################
$APRES_MODIF

    If GRAFFRAICHISCS
        Gosub TIROIR From SUBLPNAFP
        Raz GRAFFRAICHISCS
    Endif

    Case COUZON
      When "ITMREFSEL" :
          Gosub TIROIR From SUBLPNAFP
      When "LOCSEL" :
          Gosub TIROIR From SUBLPNAFP
      When "ECCSEL" :
          Gosub TIROIR From SUBLPNAFP
      When "LOTSEL" :
          Gosub TIROIR From SUBLPNAFP
      When "NBLIG" :
          If find(status,65,83)
              Gosub TIROIR From SUBLPNAFP
          Endif
    Endcase
Return
######################################################################
$ABANDON
    Local Integer LRET
    Actzo [M:LPNA]VCRNUM
    Raz [M:LPNA]ITMREFSEL
    If dim([M:LPNA]WRHDESH)>0    Raz [M:LPNA]WRHDESH    Endif
    If dim([M:LPNA]LOCSEL) >0    Raz [M:LPNA]LOCSEL     Endif
    If dim([M:LPNA]LOCDESH)>0    Raz [M:LPNA]LOCDESH    Endif
    If dim([M:LPNA]LOCTYPDESH)>0 Raz [M:LPNA]LOCTYPDESH Endif
    ILIS=val(right$(currbox,8))
    Gosub REMP_LISGAU From GOBJSUB
    WPICK = 1
    Gosub RAFFRAICHI From SUBLPNAFP
    Call DELSTOCHGW("LPNA",[M:LPNA]STOFCY,-1,-1,1,LRET) From SUBSCSB
    Chgstl [M:LPNA]LPNDESH With ""
Return
