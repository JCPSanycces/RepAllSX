######################################################################
$VERIF_ENR
#Vérification des infos du LPN saisi
# Une seule ligne dans LPNA ou plusieurs mais une seule active (WSTOSEQ<>0)
LRET = 1
If [M:LPNA]NBLIG=1 | ([M:LPNA]NBLIG>1 & sigma(0,[M:LPNA]NBLIG-1,1*([M:LPNA]WSTOSEQ(indcum)<>0))=1)
    # Si une seule
    If [M:LPNA]NBLIG=1
      IC=0
    # Si plusieurs, récupération de l'indice de celle qui est active
    Else
      IC=sigma(0,[M:LPNA]NBLIG-1,indcum*([M:LPNA]WSTOSEQ(indcum)<>0))
    Endif
    If [M:LPNA]LPNNUMDES(IC)<>"" & [M:LPNA]WSTOSEQ(IC)<>0
      Read [ITM]ITM0=[M:LPNA]ITMREF(IC)
      Read [LPN]LPN0=[M:LPNA]LPNNUMDES(IC)
      #--- Contrôle du mono-lot pour le LPN concerné
      If [F:LPN]MONLOTFLG=2 & [F:ITM]LOTMGTCOD>1
        Filter [STO] Where LPNNUM=[M:LPNA]LPNNUMDES(IC) & (ITMREF<>[M:LPNA]ITMREF(IC) | LOT<>[M:LPNA]LOT(IC))
        Look [STO]STO3 First
        If !fstat : LRET=0 : Endif
        Filter [STO]
        If LRET=0
          Call ERREUR(func AFNC.MES2(mess(516,184,1),[M:LPNA]LPNNUMDES(IC),"")) From GESECRAN
          Raz OK : Return
        Endif
      #--- Contrôle du mono-article pour le LPN concerné
      Elsif [F:LPN]MONITMFLG=2
        Filter [STO] Where LPNNUM=[M:LPNA]LPNNUMDES(IC) & ITMREF<>[M:LPNA]ITMREF(IC)
        Look [STO]STO3 First
        If !fstat : LRET=0 : Endif
        Filter [STO]
        If LRET=0
          Call ERREUR(func AFNC.MES2(mess(517,184,1),[M:LPNA]LPNNUMDES(IC),"")) From GESECRAN
          Raz OK : Return
        Endif
      Endif
    Endif
  # Plusieurs lignes dans LPNAFF
  Else
    For I=0 To [M:LPNA]NBLIG-2
      If [M:LPNA]LPNNUMDES(I)<>"" & [M:LPNA]WSTOSEQ(I)<>0
        If [F:ITM]ITMREF<>[M:LPNA]ITMREF(I)
          Read [ITM]ITM0=[M:LPNA]ITMREF(I)
        Endif
        If [F:LPN]LPNNUM<>[M:LPNA]LPNNUMDES(I)
          Read [LPN]LPN0=[M:LPNA]LPNNUMDES(I)
        Endif
        J=0
        #--- Contrôle du mono-lot pour le LPN concerné
        If [F:LPN]MONLOTFLG=2 & [F:ITM]LOTMGTCOD>1
          J=sigma(I+1,[M:LPNA]NBLIG-1,1*([M:LPNA]LPNNUMDES(indcum)=[M:LPNA]LPNNUMDES(I) & [M:LPNA]WSTOSEQ(indcum)<>0
&              & ([M:LPNA]ITMREF(indcum)<>[M:LPNA]ITMREF(I) | [M:LPNA]LOT(indcum)<>[M:LPNA]LOT(I))))
          If J>=1
            LRET=0
          Else
            Filter [STO] Where LPNNUM=[M:LPNA]LPNNUMDES(I) & (ITMREF<>[M:LPNA]ITMREF(I) | LOT<>[M:LPNA]LOT(I))
            Look [STO]STO3 First
            If !fstat : LRET=0 : Endif
            Filter [STO]
          Endif
          If LRET=0
            Call ERREUR(func AFNC.MES2(mess(516,184,1),[M:LPNA]LPNNUMDES(I),"")) From GESECRAN
            Break
          Endif
        #--- Contrôle du mono-article pour le LPN concerné
        Elsif [F:LPN]MONITMFLG=2
          J=sigma(I+1,[M:LPNA]NBLIG-1,1*([M:LPNA]LPNNUMDES(indcum)=[M:LPNA]LPNNUMDES(I) & [M:LPNA]WSTOSEQ(indcum)<>0
&                 & [M:LPNA]ITMREF(indcum)<>[M:LPNA]ITMREF(I)))
          If J>=1
            LRET=0
          Else
            Filter [STO] Where LPNNUM=[M:LPNA]LPNNUMDES(I) & ITMREF<>[M:LPNA]ITMREF(I)
            Look [STO]STO3 First
            If !fstat : LRET=0 : Endif
            Filter [STO]
          Endif
          If LRET=0
            Call ERREUR(func AFNC.MES2(mess(517,184,1),[M:LPNA]LPNNUMDES(I),"")) From GESECRAN
            Break
          Endif
        Endif
        #--- Contrôle du mono-emplacement par LPN
        K=sigma(I+1,[M:LPNA]NBLIG-1,1*([M:LPNA]LPNNUMDES(indcum)=[M:LPNA]LPNNUMDES(I) & [M:LPNA]WSTOSEQ(indcum)<>0))
        L=sigma(I+1,[M:LPNA]NBLIG-1,1*([M:LPNA]LPNNUMDES(indcum)=[M:LPNA]LPNNUMDES(I) & [M:LPNA]WSTOSEQ(indcum)<>0
&               & [M:LPNA]LOCDES(indcum)=[M:LPNA]LOCDES(I)))
        If K<>L
          Call ERREUR(func AFNC.MES2(mess(521,184,1),[M:LPNA]LPNNUMDES(I),[M:LPNA]LOCDES(I))) From GESECRAN
          LRET=0 : Break
        Endif
      Endif
    Next I
Endif
If LRET = 0 : OK = 0 : Return : Endif
    Call CTLSTOCHG( OK ) From SUBLPNAFB
    If OK
        # Issue X3-106909 - 2018-09-21 by MAE : Ajout du GSTOTRACE
        If !GIMPORT & GSTOTRACE >1
           Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
        Endif
        If func SUBSCSB.VERALL( "LPNA" ) & !GIMPORT                               # hcb 82350
            OK = 1
            Call AVERTIR(mess(81,184,1),OK) From GESECRAN
            OK -= 1
             # Issue X3-106909 - 2018-09-21 by MAE : Ajout du GSTOTRACE
            If OK & !GIMPORT & GSTOTRACE > 1
              Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
              Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
            Endif
        Endif
    Else
        Raz OK
        #--- Issue 113595
        Return
    Endif

Return
######################################################################
$INICRE

Local Integer LSTAT, I
Local Char    LNUM
    # Création du numéro de document si nécessaire
    If GSTKCPTMAN(14)<>2 | [M:LPNA]VCRNUM = ""
        Call NUMERO(GSTKCPT(14), [M:LPNA]STOFCY, [M:LPNA]IPTDAT,
&                   "", LNUM, LSTAT) From SUBANM
        If GOK<0 Return Endif
        If LSTAT=0
           [M:LPNA]VCRNUM = LNUM
           [F:SGH]VCRNUM  = LNUM
        Else
            GERR=1:GMESSAGE = mess(60,199,1)
            GOK=0
        Endif
    Endif

Return

