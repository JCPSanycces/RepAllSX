$APRES_CRE
Local Integer LRET

Call STKDELRES(0,[M:LPNA]STOFCY,"",LRET) From STKLOC

#---- Régularisation des mouvements et alloc -----#
Call REGFROMENT( 0, "LPNA", "[M:LPNA]CREFLG(I)=0", "ITMREF", [M:LPNA]STOFCY ) From TRTSHTCOM

If !GIMPORT & !GWEBSERV & GTRACE<>""
  Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
Endif
If !GIMPORT & !GVTMOD
  Gosub RELIT From GOBJSUB
  Gosub TIROIR From SUBLPNAFP
Endif
