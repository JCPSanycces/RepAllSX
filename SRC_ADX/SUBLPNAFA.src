######################################################################
$LIENS

#FQ 68364
If GFCY<>[F:SGH]STOFCY : GFCY=[F:SGH]STOFCY Endif    # hcb test
#----- Affichage entêtes de colonne variables -----#                     # Ana
Gosub CHARG_PARAM   # hcb test
#fin FQ 68364
Chgfmt [M:LPNA]MODAFFLPN  With "-K:"
#[M:LPNA]MODAFFLPN = 2
Grizo [M:LPNA]25
#Actzo [M:LPNA]MODAFFLPN
#Affzo [M:LPNA]MODAFFLPN

# hcb 33564 deb
# globales servant à tester la date d imputation par rapport à la date du jour
If dim(GCTRDATSCS) > 0
   Kill GCTRDATSCS
Endif
# hcb 33564 deb

Local Integer I
Local Integer LRET

    [M:LPNA]VCRTYP = 29
    Raz [M:SGW]
    [M:SGW]TRSTYP = 36
    [M:SGW]TRSCOD = ""
    [M:SGW]FCYDES = [M:LPNA]STOFCY

    Gosub LIENS From TABLEAUX

    # Ce qui suit ne fonctionne pas dans LIEN_LIG, càd que rien n'est grisé

    # Force l'affichage afin que les Diszo
    # appelés ensuite fonctionnent
    Affzo [M:LPNA]
    Call STKCTRIPT( [M:LPNA]IPTDAT, [M:LPNA]STOFCY, "1") From STKLIB
    If GERR=1
        Call ERREUR(GMESSAGE) From GESECRAN
        Raz GERR
        Raz GMESSAGE
    Elsif GERR=2
        Call MESSAGE(GMESSAGE) From GESECRAN
        Raz GERR
        Raz GMESSAGE
    Else
        # Rend insaisissables toutes les colonnes, puis...
        # ( Diszo du tableau empêche la réactivation)
        # ...rend saisissable la dernière ligne (la ligne vide)
        # Car celle-ci peut avoir été rendue inactive
        # par le chargement précédent d'un document (comportant plus de lignes)
        Call STKDISCOL("LPNA",[M]NBLIG) From STKECR
        Diszo [LPNA]ITMREF
        Actzo [LPNA]ITMREF([M]NBLIG)
        If dim([M:LPNA]QTYPCU)>0
            Diszo [LPNA]QTYPCU
            Actzo [LPNA]QTYPCU([M]NBLIG)
        Endif
     Endif
    #--- TS 106217
    # Pas de filtre version pour les changements stock, car il n'y a pas de règle de gestion
    If dim([M:LPNA]ECSSEL)>0
      Actzo [M:LPNA]ECSSEL
    Endif
    #---
    Diszo [M:LPNA]5
    Actzo [M:LPNA]VCRNUM
    [M:LPNA]ALLSTO   =2
    [M:LPNA]NOTALLSTO=2
Return


