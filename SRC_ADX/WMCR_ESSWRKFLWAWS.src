#<AdxTL>@(#)0.0.0.0 $Revision$Class Workflow
# Supervisor
## CRUD-CLASSE ## ESSWRKFLWAWS
# 2018-10-23 06:53:13 714


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File ESSWRKFLWDET [ESWD_]

If !SILENCE : Call TRACE("2 --> Local Instance C_ESSWRKFLWAWS") From ASYRCOM : Endif
Local Instance ESSWRKFLWAWS Using C_ESSWRKFLWAWS

If !SILENCE : Call TRACE("3 --> New Instance C_ESSWRKFLWAWS") From ASYRCOM : Endif
ESSWRKFLWAWS = NewInstance C_ESSWRKFLWAWS AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [ESWD_]ESWD0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of ESSWRKFLWAWS") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKFLWAWS.AREAD([ESWD_]UID,[ESWD_]CLA,[ESWD_]REFNUM,[ESWD_]MAIREC,[ESWD_]FLDNAM))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("ESSWRKFLWAWS.UID ="-num$(ESSWRKFLWAWS.UID)) From ASYRCOM
 Call TRACE("ESSWRKFLWAWS.CLA ="-num$(ESSWRKFLWAWS.CLA)) From ASYRCOM
 Call TRACE("ESSWRKFLWAWS.REFNUM ="-num$(ESSWRKFLWAWS.REFNUM)) From ASYRCOM
 Call TRACE("ESSWRKFLWAWS.MAIREC ="-num$(ESSWRKFLWAWS.MAIREC)) From ASYRCOM
 Call TRACE("ESSWRKFLWAWS.FLDNAM ="-num$(ESSWRKFLWAWS.FLDNAM)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(ESSWRKFLWAWS.AKEYS)
  Call TRACE("-"-num$(I)-":"-ESSWRKFLWAWS.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [ESWD_]
FreeGroup ESSWRKFLWAWS
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(ESSWRKFLWAWS,ACLE,ASTATUS,_ETAG)
Variable Instance ESSWRKFLWAWS Using C_ESSWRKFLWAWS
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Integer _UID
Local Char _CLA(20)
Local Char _REFNUM(15)
Local Tinyint _MAIREC
Local Char _FLDNAM(12)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_UID = val([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_CLA = num$([L]CLE(2)) : Endif
If [L]CLE(3)<>"" : [L]_REFNUM = num$([L]CLE(3)) : Endif
If [L]CLE(4)<>"" : [L]_MAIREC = val([L]CLE(4)) : Endif
If [L]CLE(4)="false" : [L]_MAIREC = 1 : Endif
If [L]CLE(4)="true" : [L]_MAIREC = 2 : Endif
If [L]CLE(5)<>"" : [L]_FLDNAM = num$([L]CLE(5)) : Endif
Raz [L]_ETAG
Local File ESSWRKFLWDET [ESWD]
Default File [F:ESWD]
Read [F:ESWD]ESWD0 = [L]_UID;[L]_CLA;[L]_REFNUM;[L]_MAIREC;[L]_FLDNAM
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:ESWD]UPDTICK)>0
 [L]_ETAG = num$([F:ESWD]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(ESSWRKFLWAWS,ACLE,ASTATUS)
Variable Instance ESSWRKFLWAWS Using C_ESSWRKFLWAWS
Value Char ACLE
Variable Integer ASTATUS
Local Integer _UID
Local Char _CLA(20)
Local Char _REFNUM(15)
Local Tinyint _MAIREC
Local Char _FLDNAM(12)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_UID = val([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_CLA = num$([L]CLE(2)) : Endif
If [L]CLE(3)<>"" : [L]_REFNUM = num$([L]CLE(3)) : Endif
If [L]CLE(4)<>"" : [L]_MAIREC = val([L]CLE(4)) : Endif
If [L]CLE(4)="false" : [L]_MAIREC = 1 : Endif
If [L]CLE(4)="true" : [L]_MAIREC = 2 : Endif
If [L]CLE(5)<>"" : [L]_FLDNAM = num$([L]CLE(5)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKFLWAWS.AREAD([L]_UID,[L]_CLA,[L]_REFNUM,[L]_MAIREC,[L]_FLDNAM))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(ESSWRKFLWAWS,_UID,_CLA,_REFNUM,_MAIREC,_FLDNAM,ASTATUS)
Variable Instance ESSWRKFLWAWS Using C_ESSWRKFLWAWS
Value Integer _UID
Value Char _CLA
Value Char _REFNUM
Value Tinyint _MAIREC
Value Char _FLDNAM
Variable Integer ASTATUS

If ESSWRKFLWAWS = null : End : Endif

Gosub AVARIABLES From WMC00ESSWRKFLWAWS
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If ESSWRKFLWAWS.APARENT=null
 [L]A_I = ESSWRKFLWAWS.freeSnapshot
 ESSWRKFLWAWS.snapshotEnabled = 0
 ESSWRKFLWAWS.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & ESSWRKFLWAWS.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKFLWAWS._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If ESSWRKFLWAWS.APARENT=null
 ESSWRKFLWAWS.snapshotEnabled = 1
 ESSWRKFLWAWS.setAccessorEnabled = 1
Endif
LogicClose File [ESWD] ,[EWIS] ,[EWSA] ,[EWCD]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKFLWAWS._ACTION_PARAM("AREAD_BEFORE",[L]_UID,[L]_CLA,[L]_REFNUM,[L]_MAIREC,[L]_FLDNAM))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:ESWD]
Read [F:ESWD]ESWD0 = [L]_UID;[L]_CLA;[L]_REFNUM;[L]_MAIREC;[L]_FLDNAM
If fstat
[L]A_ERROR = num$([L]_UID)+"~"+[L]_CLA+"~"+[L]_REFNUM+"~"+num$([L]_MAIREC)+"~"+[L]_FLDNAM
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(ESSWRKFLWAWS,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:ESWD]AUUID)>0 & [F:ESWD]AUUID=NullUuid
 [F:ESWD]AUUID = getUuid
Endif
If dim([F:ESWD]EMPPIC)>0: Raz [F:ESWD]EMPPIC: Endif
SetInstance ESSWRKFLWAWS With [F:ESWD]
ESSWRKFLWAWS.ASTALIN = [V]CST_ALL

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:EWIS]
 [L]A_N2=0
 For [F:EWIS]EWID0 Where UID=[F:ESWD]UID
  [L]A_N2 +=1
  ESSWRKFLWAWS.ESSWRKEMP(A_N2) = NewInstance  C_ESSWRKEMP(ESSWRKFLWAWS.ACTX,NullUuid,[L]A_N2,ESSWRKFLWAWS,"ESSWRKEMP") AllocGroup ESSWRKFLWAWS
  [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKFLWAWS.ESSWRKEMP(A_N2).ADDINSTANCE_BOUND)
  Callmet ESSWRKFLWAWS.ESSWRKEMP(A_N2).AREAD([F:EWIS]UID)
  ESSWRKFLWAWS.ESSWRKEMP(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKFLWAWS.ESSWRKEMP(A_N2).ASETATTRIBUTE("UID","$isDisabled","true"))
 Next EWIS
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:EWSA]
 [L]A_N2=0
 For [F:EWSA]EWSA0 Where UID=[F:ESWD]UID
  [L]A_N2 +=1
  ESSWRKFLWAWS.ESSWRKSA(A_N2) = NewInstance  C_ESSWRKSA(ESSWRKFLWAWS.ACTX,NullUuid,[L]A_N2,ESSWRKFLWAWS,"ESSWRKSA") AllocGroup ESSWRKFLWAWS
  [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKFLWAWS.ESSWRKSA(A_N2).ADDINSTANCE_BOUND)
  Callmet ESSWRKFLWAWS.ESSWRKSA(A_N2).AREAD([F:EWSA]UID)
  ESSWRKFLWAWS.ESSWRKSA(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKFLWAWS.ESSWRKSA(A_N2).ASETATTRIBUTE("UID","$isDisabled","true"))
 Next EWSA
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:EWCD]
 [L]A_N2=0
 For [F:EWCD]EWCHD0 Where UID=[F:ESWD]UID
  [L]A_N2 +=1
  ESSWRKFLWAWS.ESSWRKCHD(A_N2) = NewInstance  C_ESSWRKCHD(ESSWRKFLWAWS.ACTX,NullUuid,[L]A_N2,ESSWRKFLWAWS,"ESSWRKCHD") AllocGroup ESSWRKFLWAWS
  [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKFLWAWS.ESSWRKCHD(A_N2).ADDINSTANCE_BOUND)
  Callmet ESSWRKFLWAWS.ESSWRKCHD(A_N2).AREAD([F:EWCD]UID)
  ESSWRKFLWAWS.ESSWRKCHD(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKFLWAWS.ESSWRKCHD(A_N2).ASETATTRIBUTE("UID","$isDisabled","true"))
 Next EWCD
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKFLWAWS.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



