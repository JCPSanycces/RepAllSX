#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ITCMATCH2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:58"
A_USER  = "DOC"
A_STAMP = "20181109230458"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBMAT"
  If [M]NBMAT=0
  Endif
 When "NBLIG2"
  If [M]NBLIG2=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ITCMATCH2 [ICM2]
Gosub HORODAT
Local Inpbox "ITCMATCH2" From GFONCTION At A_STAMP With A_WINDPREV Mask [ICM2] As [SIM_]
Grizo [ICM2]5
Grizo [ICM2]10
Grizo [ICM2]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ICM2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=56 : Y1(0)=1 : Y2(0)=14
X1(1)=57 : X2(1)=112 : Y1(1)=1 : Y2(1)=18
X1(2)=1 : X2(2)=56 : Y1(2)=15 : Y2(2)=18
Return

$ON_MATCST1
Onevent BEFORE_AREA Gosub AV_MATCST1 From W1ITCMATCH2
Return

$AV_MATCST1
## Action PARDEV
Gosub _AFF
Return

$ON_MATCST2
Onevent BEFORE_AREA Gosub AV_MATCST2 From W1ITCMATCH2
Return

$AV_MATCST2
## Action PARDEV
Gosub _AFF
Return

$ON_SCOTOT1
Onevent BEFORE_AREA Gosub AV_SCOTOT1 From W1ITCMATCH2
Return

$AV_SCOTOT1
## Action PARDEV
Gosub _AFF
Return

$ON_SCOTOT2
Onevent BEFORE_AREA Gosub AV_SCOTOT2 From W1ITCMATCH2
Return

$AV_SCOTOT2
## Action PARDEV
Gosub _AFF
Return

$ON_DEVSCO
Onevent BEFORE_AREA Gosub AV_DEVSCO From W1ITCMATCH2
Return

$AV_DEVSCO
## Action PARDEV
Gosub _AFF
Return

$CHG_STY
Return


