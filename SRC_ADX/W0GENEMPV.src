#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque GENEMPV 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone BPAG
mkstat = 0
zoncou = "BPAG"
indice = 0
status = 1
zoncou = "BPAG"
If varmode([M]BPAG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BPAG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]BPAG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]BPAG = nolign
   status = 75
   Call SAI_BPAG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBHIS
mkstat = 0
zoncou = "NBHIS"
indice = 0
status = 1
zoncou = "NBHIS"
If varmode([M]NBHIS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBHIS" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBHIS
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBHIS = nolign
   status = 75
   Call SAI_NBHIS(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_BPAG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone BPAG
mkstat = 0
zoncou = "BPAG"

## Zone CODZONE
mkstat = 0
zoncou = "CODZONE"
If varmode([M]CODZONE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODZONE" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone LIBZONE
mkstat = 0
zoncou = "LIBZONE"
If varmode([M]LIBZONE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LIBZONE" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone OPT
mkstat = 0
zoncou = "OPT"
IMPENT = [M]OPT(indice)
If varinit([M]OPT,indice)=0
 IMPENT = 1
Endif
If varmode([M]OPT,indice)=0
 [M]OPT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OPT(indice)
 Endif
Endif
[M]OPT(indice) = IMPENT

## Zone CODFIC
mkstat = 0
zoncou = "CODFIC"
If varmode([M]CODFIC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODFIC" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ATB","!",[M]CODFIC(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODFIC" : GZNUM = 6 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone ROW
mkstat = 0
zoncou = "ROW"
If varmode([M]ROW,indice)=0
