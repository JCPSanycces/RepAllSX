####################################
## Bloc tableau 2
####################################
Subprog SAI_NBHIS(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBHIS
mkstat = 0
zoncou = "NBHIS"

## Zone HISDAT
mkstat = 0
zoncou = "HISDAT"
If varmode([M]HISDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "HISDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone HISDES
mkstat = 0
zoncou = "HISDES"
If varmode([M]HISDES,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "HISDES" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone HISTBL
mkstat = 0
zoncou = "HISTBL"
If varmode([M]HISTBL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "HISTBL" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ATB","!",[M]HISTBL(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "HISTBL" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone NBHIS
mkstat = 0
zoncou = "NBHIS"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "GENEMPV"
Return

