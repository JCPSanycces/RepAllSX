##################################
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
If func ECCLIB.NBRCPN([M]ITMREF)<1
    mkstat=2
Endif
End

##################################
# for usage in PBW1, PBW3
# - Request-date
##################################
Subprog C_ECCVALMAJ_P(VALEUR, ABR)
Variable Char    VALEUR()
Value    Char    ABR()

If VALEUR<>""
    Call CTRECC([M]ITMREF,ABR,"ECCVALMAJ",VALEUR,[M]ECCVALMIN,
&               [M]EXTRCPDAT,GERR,GMESSAGE) From ECCLIB
    If GERR>0
        GERR=2
        mkstat=2
    Endif
Else
    [M]ECCVALMIN=""
Endif

End

##################################

Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
If func ECCLIB.NBRCPN([M]ITMREF)<2
&  |    [M]ECCVALMAJ=""
    mkstat=2
Endif
End

##################################
# for usage in PBW1, PBW3
# - Request-date
##################################
Subprog C_ECCVALMIN_P(VALEUR, ABR)
Variable Char    VALEUR()
Value    Char    ABR

If [M]ECCVALMAJ<>""
    Call CTRECC([M]ITMREF, ABR,"ECCVALMIN",[M]ECCVALMAJ,VALEUR,
&               [M]EXTRCPDAT,GERR,GMESSAGE) From ECCLIB
    If GERR>0
        GERR=2
        mkstat=2
    Endif
Endif

End

##################################
# usage in PBW4,
##################################
Subprog C_EXTRCPDAT(VALEUR, ABR)
Variable Date    VALEUR
Value    Char    ABR
Local Date LSAVDAT
Local Integer IND

# VALEUR can contain a new value, but CTRECCPRD needs [M:MBWx]STRDAT2
Case ABR
    When "PBW4"
          LSAVDAT = [M:PBW4]EXTRCPDAT
          If LSAVDAT <> VALEUR
              [M:PBW4]EXTRCPDAT = VALEUR
          Endif
    When "PBW3"
          LSAVDAT = [M:PBW3]EXTRCPDAT
          If LSAVDAT <> VALEUR
              [M:PBW3]EXTRCPDAT = VALEUR
          Endif
    When "PBW5"
          LSAVDAT = [M:PBW5]EXTRCPDAT
          If LSAVDAT <> VALEUR
              [M:PBW5]EXTRCPDAT = VALEUR
          Endif
Endcase
If [M]ECCVALMAJ<>""
    Call CTRECCPRD(ABR) From MFGECCLIB    # Control each line of product and highlight them if necessary
    IND = find(GERR,1,4)
Endif

# Only when major-version is loaded and required date has been changed
# -> selection of a valid version
Case ABR
     When "PBW3"
          If [M:PBW3]ECCVALMAJ=""
              Call ECCAFF([M:PBW3]ITMREF,"PBW3") From MFGECCLIB
              If func ECCLIB.NBRCPN([M:PBW3]ITMREF)
                  # ECC preload of major and minor version
                  Raz [M:PBW3]ECCVALMAJ,[M:PBW3]ECCVALMIN
                  Call INIECCITM([M:PBW3]ITMREF, [M:PBW3]STOFCY, [M:PBW3]EXTRCPDAT, [M:PBW3]ECCVALMAJ,[M:PBW3]ECCVALMIN,4) From MFGECCLIB
                  Affzo [M:PBW3]ECCVALMAJ,ECCVALMIN
                  GERR=0
                  GMESSAGE=""
                  End
              Endif
          Endif
     When "PBW4"
          If [M:PBW4]ECCVALMAJ=""
              Call ECCAFF([M:PBW4]ITMREF,"PBW4") From MFGECCLIB
              If func ECCLIB.NBRCPN([M:PBW4]ITMREF)
                  # ECC preload of major and minor version
                  Raz [M:PBW4]ECCVALMAJ,[M:PBW4]ECCVALMIN
                  Call INIECCITM([M:PBW4]ITMREF, [M:PBW4]STOFCY, [M:PBW4]EXTRCPDAT, [M:PBW4]ECCVALMAJ,[M:PBW4]ECCVALMIN,4) From MFGECCLIB
                  Affzo [M:PBW4]ECCVALMAJ,ECCVALMIN
                  GERR=0
                  GMESSAGE=""
                  End
              Endif
          Endif
     When "PBW5"
          If [M:PBW5]ECCVALMAJ=""
              Call ECCAFF([M:PBW5]ITMREF,"PBW5") From MFGECCLIB
              If func ECCLIB.NBRCPN([M:PBW5]ITMREF)
                  # ECC preload of major and minor version
                  Raz [M:PBW5]ECCVALMAJ,[M:PBW5]ECCVALMIN
                  Call INIECCITM([M:PBW5]ITMREF, [M:PBW5]STOFCY, [M:PBW5]EXTRCPDAT, [M:PBW5]ECCVALMAJ,[M:PBW5]ECCVALMIN,4) From MFGECCLIB
                  Affzo [M:PBW5]ECCVALMAJ,ECCVALMIN
                  GERR=0
                  GMESSAGE=""
                  End
              Endif
          Endif
Endcase

# In case of an error -> error-message
If IND>0 | GERR>0
    [M]EXTRCPDAT = LSAVDAT
    Affzo [M]EXTRCPDAT
    GERR=1
    mkstat=2
Endif
End

