##################################
# 104943 : version management in Work orders
#          - Enterprise Planning, planning workbench
##################################


##################################
# for usage in PBW3
##################################
Subprog AM_ITMREF_PBW3(VALEUR)
Variable Char VALEUR

# enable, disable ECCVALMAJ, ECCVALMIN, BOMALT
Call ECCAFF(VALEUR,"PBW3")  From MFGECCLIB
If func ECCLIB.NBRCPN(VALEUR)
    # ECC preload of major and minor version
    Raz [M:PBW3]ECCVALMAJ, [M:PBW3]ECCVALMIN
    Call INIECCITM(VALEUR, [M:PBW3]STOFCY, [M:PBW3]EXTRCPDAT, [M:PBW3]ECCVALMAJ,[M:PBW3]ECCVALMIN,4) From MFGECCLIB
    Affzo [M:PBW3]ECCVALMAJ, ECCVALMIN
Else
    Effzo [M:PBW3]ECCVALMAJ, ECCVALMIN
Endif

End

##################################
# for usage in PBW3
##################################
