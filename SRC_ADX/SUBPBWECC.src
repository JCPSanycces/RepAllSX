##################################
# for usage in PBW5
##################################
Subprog AM_ITMREF_PBW1(VALEUR)
Variable Char VALEUR

# enable, disable ECCVALMAJ, ECCVALMIN, BOMALT
Call ECCAFF(VALEUR,"PBW1")  From MFGECCLIB
If func ECCLIB.NBRCPN(VALEUR)
    # ECC preload of major and minor version
