#<AdxTL>@(#)10.0.0.0 $Revision$
Local Char PARAM(30)(1..10) , VALEUR(30)
Call TRAITE_CHAR(VALEUR,PARAM,"","ADOCEXT","ADOCEXT",3,"") From GTRAITE
End

################################################################
$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
 When "SORTIE"     : Gosub FERME
Endcase
Return

###################################################################
$FERME
# cg mai  2013
# il faut killer les var globales crée via prog
Gosub FERME_KILL From AGENLIBA
Return

###################################################################
$REPERT_LAN_EXT
  REPERT_DOC = [M:DIA]REPERT
  II=instr(1,REPERT_DOC,"%")
  If II
    REPERT_DOC=left$(REPERT_DOC,II-1)+[V]COD_LAN+right$(REPERT_DOC,II+1)
  Else
    REPERT_DOC=REPERT_DOC
  Endif
  SLASH=string$(instr(1,REPERT_DOC,"\")=0,"/")+string$(instr(1,REPERT_DOC,"\")<>0,"\")

  Gosub REPERT_TYP_EXT
  # JPGA-EXI-85524-28 02/04/2014 : Pour la V7 et +, Implémentation de l'utilisation de VOLUME dans les nom de répertoires.
  REPERT_DOC=func AGENLIBA.REMPLACE_VOLUME (REPERT_DOC)
Return

$REPERT_TYP_EXT
  If [M:DIA]REPERTTYP = 2
     REPERT_DOC = REPERT_DOC + SLASH + [L]VV_TYP
  Endif
Return

###################################################################
$INIT
Local Char COD_LAN(GLONLAN)
Local Mask ADOCEXT [DIA], ADOCEXT [DIA2]

# cg mai 2013
# init a blanc du code en fct car en fct d ou on vient
# cette var n est pas forcement killer ou remise à blanc en sortie
If dim(GISO_COD_LAN) >=0
    GISO_COD_LAN =""
Endif

Gosub INIT_DIA_ADOCEXT

#JPGA 08/04/2010 BUG-62245 : Lors de l'appel l'action ADOCEXT, prise en compte de la langue/langue REF données en paramètre PARAM(1) et PARAM(2)
#Gosub INIT_LAN_LANREF

Gosub DECL_COMVAR From AGENLIBA

# JPGA 09/04/2010 Bug-51883 : Appel à la procédure de recherche du Répertoire html ou xml d'extraction

Call INIT_REPERT_LAN([M:DIA]REPERT, "xml") From AGENLIBA
Return

$INIT_LANTRA_LANREFTRA
Local Char WLANREF(250), WLANTRA(250)

    If [M:DIA]LANREF=""
      Call PARAMUTIL("LANREF",WLANREF,"","") From SUBAUS
      [M:DIA]LANREFTRA=WLANREF
      If [M:DIA]LANREFTRA="" : [M:DIA]LANREFTRA=GLANDEF : Endif
    Else
      [M:DIA]LANREFTRA=[M:DIA]LANREF
    Endif

    If [M:DIA]LAN=""
      Call PARAMUTIL("LANTRA",WLANTRA,"","") From SUBAUS
      [M:DIA]LANTRA=WLANTRA
      If [M:DIA]LANTRA="" : [M:DIA]LANTRA=GLANGUE : Endif
    Else
      [M:DIA]LANTRA=[M:DIA]LAN
    Endif
Return

$INIT_LANEXT_LANREFEXT
Local Char WLANREF(250), WLANTRA(250)
    If [M:DIA]LANREF=""
      Call PARAMUTIL("LANREF",WLANREF,"","") From SUBAUS
      [M:DIA]LANREFEXT=WLANREF
      If [M:DIA]LANREFEXT="" : [M:DIA]LANREFEXT=GLANDEF : Endif
    Else
      [M:DIA]LANREFEXT=[M:DIA]LANREF
    Endif

    If [M:DIA]LAN=""
      Call PARAMUTIL("LANTRA",WLANTRA,"","") From SUBAUS
      [M:DIA]LANEXT=WLANTRA
      If [M:DIA]LANEXT="" : [M:DIA]LANEXT=GLANGUE : Endif
      Gosub TEST_LANEXT
    Else
      [M:DIA]LANEXT=[M:DIA]LAN
      Gosub TEST_LANEXT
    Endif
Return

# Initialisation des la Langue en cas de Traduction. LAN et LANREF ne doivent pas être identiques
$TEST_LANEXT
 If [M:DIA]LANEXT=[M:DIA]LANREFEXT
   # HN SI029 95979-1 : On laisse le prog faire quand même vu avec JPGA
   #[M:DIA]LANEXT="ENG"
 Endif
Return

# Initialisation des Champs du masque ADOCEXT par la fonction ADOCEXT
$INIT_DIA_ADOCEXT
   Raz [M:DIA]
   [M:DIA]ENLANREF  = 1  :  [M:DIA]EXCTYP = 2     :  [M:DIA]REPERTTYP = 1
   [M:DIA]FORTRA    = 1     # [M:DIA]FORTRA : Indicateur de provenance extraction : 1 : Ecran ADOCEXT / 2 : Plan de travail ADOCTRA
   [M:DIA]ALLLAN    = 1  :  [M:DIA]ALLTYP    = 1  :  [M:DIA]ALLACV    = 2  :  [M:DIA]ALLCOD = 1  :  [M:DIA]ALLMOD = 2  :  [M:DIA]EXCMOD = 1
   [M:DIA]HLPFIL    = 1  :  [M:DIA]HLPLNKFLD = 1  :  [M:DIA]HLPFLD    = 1  :  [M:DIA]VALDOC = 3
   [M:DIA]LANREF    = PARAM(1) : If [M:DIA]LANREF<>"" : [M:DIA]LANREFTRA=[M:DIA]LANREF : [M:DIA]LANREFEXT=[M:DIA]LANREF : Endif
   [M:DIA]LAN       = PARAM(2) : If [M:DIA]LAN<>"" : [M:DIA]LANTRA=[M:DIA]LAN : [M:DIA]LANEXT=[M:DIA]LAN : Endif
   [M:DIA]TYP       = PARAM(3)
   [M:DIA]CODDEB    = PARAM(4)
   #Call INIT_ALLCREGRP("[M:DIA]ALLCREGRP") From AGENLIBA
   If func AGENLIBA.IS_ENV_GROUPE : If dim([M:DIA]ALLCREGRP)>0 : [M:DIA]ALLCREGRP=2 : Affzo [M:DIA]ALLCREGRP:Endif:Endif
Return

# Initialisation des Champs du masque ADOCEXT par la fonction ADOCTRA
$INIT_DIA_ADOCTRA
   Raz [M:DIA]
   [M:DIA]CHOICE    = 2  :  [M:DIA]ENLANREF  = 1  :  [M:DIA]EXCTYP = 2     :  [M:DIA]REPERTTYP = 1
   [M:DIA]FORTRA    = 2     # [M:DIA]FORTRA : Indicateur de provenance extraction : 1 : Ecran ADOCEXT / 2 : Plan de travail ADOCTRA
   [M:DIA]ALLLAN    = 1  :  [M:DIA]ALLTYP    = 1  :  [M:DIA]ALLACV = 2     :  [M:DIA]ALLCOD = 1  :  [M:DIA]ALLMOD = 2  :  [M:DIA]EXCMOD = 1
   [M:DIA]REPERT    = [M:TRA4]REPERT
   [M:DIA]LANREF    = V_LANREF
   [M:DIA]LAN       = V_LAN
   [M:DIA]TYP       = V_TYPDOC
   [M:DIA]CODDEB    = V_CODDOC
   [M:DIA]CODFIN    = V_CODDOC
   Call INIT_ALLCREGRP("[M:DIA]ALLCREGRP") From AGENLIBA
Return

# Initialisation des Champs FLD du masque ADOCEXT par la fonction ADOCTRA
$INITFLD_DIA_ADOCTRA
   Raz [M:DIA]
   [M:DIA]CHOICE    = 2  :  [M:DIA]ENLANREF  = 1  :  [M:DIA]EXCTYP = 2     :  [M:DIA]REPERTTYP = 1
   [M:DIA]FORTRA    = 2     # [M:DIA]FORTRA : Indicateur de provenance extraction : 1 : Ecran ADOCEXT / 2 : Plan de travail ADOCTRA
   [M:DIA]ALLLAN    = 1  :  [M:DIA]ALLTYP    = 1  :  [M:DIA]ALLACV = 2     :  [M:DIA]ALLCOD = 1  :  [M:DIA]ALLMOD = 2  :  [M:DIA]EXCMOD = 1
   [M:DIA]HLPFIL    = 1  :  [M:DIA]HLPLNKFLD = 1  :  [M:DIA]HLPFLD = 2
   [M:DIA]REPERT    =[M:TRA4]REPERT
   [M:DIA]LANREF    = V_LANREF
   [M:DIA]LAN       = V_LAN
   [M:DIA]TYP       = ""
   [M:DIA]CODDEB    = ""
   [M:DIA]CODFIN    = ""
   [M:DIA]FLDDEB    = V_CODDOC
   [M:DIA]FLDFIN    = V_CODDOC
   Call INIT_ALLCREGRP("[M:DIA]ALLCREGRP") From AGENLIBA
Return

$CONTROLE
If [M:DIA]EXTLAN=1 & [M:DIA]EXTTRA=1 & [M:DIA]EXTRETRA=1
    GERR = 1
    GMESSAGE = mess(122,176,1)
    SAI=1
    Return
Endif
If [M:DIA]LAN="" & ([M:DIA]EXTTRA=2 | [M:DIA]EXTRETRA=2)
    GERR = 1
    GMESSAGE = mess(62,176,1)
    SAI=1
    Return
Endif
If [M:DIA]EXTLAN=2 & [M:DIA]ALLLAN=1 & [M:DIA]LAN=""
    GERR = 1
    GMESSAGE = mess(62,176,1)
    SAI=1
    Return
Endif
If [M:DIA]CHOICE=2 & [M:DIA]LANREF=""
    GERR = 1
    GMESSAGE = mess(64,176,1)
    SAI=1
    Return
Endif
If [M:DIA]LAN=[M:DIA]LANREF
   If [M:DIA]CHOICE=2
        GERR = 1
        GMESSAGE = mess(53,176,1)
        SAI=1
        Return
   Else
        [M:DIA]ENLANREF = 1
        Affzo [M:DIA]ENLANREF
   Endif
Endif
Return

################################################################################
$EXEC
################################################################################
Local Char    ADOCTRACE(GLONTRA)
Local Char    EV(250)
Local Integer A_EXTRAIRE, DOC_FOUND, DOC_DOSSREF, SORTIE
Local Integer NB_DOC, NB_FLD, NB_FIL, NB_NONFIC, NB_ERR, NB_ERR2, NB_NONTRA, NBFLD_NTRA, NB_FLD_EXIST, NBFLD_L_NTRA, NBFLD_L_EXIS
Local Integer NB_TOT_DOC, NB_TOT_FLD, NB_TOT_FIL, NB_GENE_KO, NB_FLD_LIES, NB_TOT_FLD_L
Local Integer INTERRUPT, NB_MOTCLE, NBMAX_MOTCLE : NBMAX_MOTCLE = 32000
Local Char    AIDE_TRAITE(GLONADZ) ([L]NBMAX_MOTCLE)

    Raz ADOCTRACE
    NB_DOC=0 : NB_FLD=0 : NB_FIL=0 : NB_ERR=0 : NB_ERR2=0 : NB_NONTRA=0 : NBFLD_NTRA=0 : NB_FLD_EXIST=0 : NBFLD_L_NTRA=0 : NBFLD_L_EXIS=0
    NB_NONFIC=0 : NB_TOT_DOC=0 : NB_TOT_FLD=0 : NB_TOT_FIL=0 : NB_GENE_KO=0 : NB_FLD_LIES=0 : NB_TOT_FLD_L=0 : NB_MOTCLE=0 : INTERRUPT=1
    ADOCTRACE=GTRACE
    If ADOCTRACE=""
       Gosub TRACE_NON_PLAN_TRAVAIL
    Endif

    # Si Traduction depuis ADOCEXT , on effectue la génération ADOCUMENT + COPIE afin de vérifier la cohérence entre LAN et LANREF
    If [M:DIA]FORTRA=1 & [M:DIA]CHOICE=2
       Gosub GENERATION_ADOCUMENT
    Endif

    If clalev([ADB2])=0  : Gosub DECLARE_TABLES From AGENLIBA : Endif
    If clalev([ADO3])=0  : Local File ADOCUMENT [ADO3] : Endif
    If clalev([ADO2])=0  : Local File ADOCUMENT [ADO2] : Endif
    If clalev([AD2])=0   : Local File ADOCUMENT [AD2] : Endif
    # Issue 75246/7 - 2012-06-29 by VPO : mot clé d'aide
    If clalev([AMC2])=0  : Local File AMOTCLE [AMC2] : Endif
    #If clalev([AMZ2])=0  : Local File AMSKZON [AMZ2] : Endif
    If clalev([ZDO2])<>0 : Close File [ZDO2] : Endif
    If clalev([ZDO2])=0  : Local File =GDOSX3+".ADOCUMENT" [ZDO2] : Endif
    If clalev([ADZ])=0   : Local File ADOCFLD [ADZ] : Endif
    If clalev([ADZ2])=0  : Local File ADOCFLD [ADZ2] : Endif
    If clalev([ZDZ1])<>0 : Close File [ZDZ1] : Endif
    If clalev([ZDZ1])=0  : Local File =GDOSX3+".ADOCFLD" [ZDZ1] : Endif

    EV = string$( [M:DIA]ALLLAN=1, "(LAN=[M:DIA]LAN)" )
    EV+= string$( [M:DIA]ALLLAN=2 & [M:DIA]CHOICE>1,  string$(EV<>""," & ")+"(LAN<>[M:DIA]LANREF)" )
    EV+= string$( [M:DIA]VALDOC=1 & [M:DIA]CHOICE=1,  string$(EV<>""," & ")+"(VLDDAT<>[0/0/0] and VLDFLG=2)" )
    EV+= string$( [M:DIA]VALDOC=2 & [M:DIA]CHOICE=1,  string$(EV<>""," & ")+"(VLDDAT=[0/0/0] or VLDFLG<>2)" )
    Gosub ALIM_EV

    If ADOCTRACE=""
       Call AFF_BOITE(mess(68,176,1) ,2,INTERRUPT ) From GESECRAN
       Call ECR_TRACE(string$(20,"*")-mess(68,176,1),0) From GESECRAN
    Endif

    # on boucle sur LAN+TYP+COD
    For [ADO]ADO0(3) Where evalue(EV)
      If ADOCTRACE=""
         Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
         Call ECR_TRACE("* ADO"+":"+[ADO]LAN+"~"+[ADO]TYP+"~"+[ADO]COD,0) From GESECRAN
      Endif

      A_EXTRAIRE=1 : NB_TOT_DOC+=1
      #VPO 20/12/06 traitement extraction pour trad (CHOICE = 2 : Traduction ou 3 : (re)Traduction) / CONTROLES DE TRAITEMENT !
      If [M:DIA]CHOICE>1
          A_EXTRAIRE=0  :  DOC_FOUND=0 : DOC_DOSSREF=0

          #CONTROLES DE VALIDITE : Boucle sur les paragraphes de la langue de ref
          For [ADO2] Where LAN=[M:DIA]LANREF and TYP=[ADO]TYP and COD=[ADO]COD
              DOC_FOUND=1 : SORTIE=0
              Call CONTROLE_VALIDITE([ADO2]VLDDAT, [ADO2]VLDFLG, [ADO2]LAN, [ADO2]LEV, [ADO2]SUBLEV, A_EXTRAIRE, SORTIE)
              If SORTIE  :  Break  :  Endif
          Next ADO2

          # Si Documentation non trouvée dans le dossier courante : Recherche dans le dossier de Référence.
          If DOC_FOUND=0
              DOC_DOSSREF=1
              #Boucle sur les paragraphes de la langue de ref
              For [ZDO2] Where LAN=[M:DIA]LANREF and TYP=[ADO]TYP and COD=[ADO]COD
                  DOC_FOUND=1 : SORTIE=0
                  Call CONTROLE_VALIDITE([ZDO2]VLDDAT, [ZDO2]VLDFLG, [ZDO2]LAN, [ZDO2]LEV, [ZDO2]SUBLEV, A_EXTRAIRE, SORTIE)
                  If SORTIE  :  Break  :  Endif
              Next ADO2
          Endif

          If A_EXTRAIRE
             # Controle pour savoir si la structure entre langue cible et langue de REF est différente : on n'extrait pas
             Call CONTROLE_VALIDITE_DIF ([ADO]LAN, [ADO]TYP, [ADO]COD, [M:DIA]LANREF, A_EXTRAIRE, SORTIE)
             If SORTIE      # Si SORTIE : Une erreur structurelle est détectée
                NB_ERR2+=1
             Endif
          Endif
      Endif

      If A_EXTRAIRE
          Call EXTR_XML([M:DIA]REPERT, [ADO]LAN, [ADO]TYP, [ADO]COD, [M:DIA]CHOICE, [L]NB_DOC, [L]NB_NONFIC)

          If [M:DIA]ENLANREF = 2   # CBO 2009.07.10 bug56210 : Générer également en Langue de ref si demandé
              Call  EXTR_XML([M:DIA]REPERT, [M:DIA]LANREF, [ADO]TYP, [ADO]COD, [M:DIA]CHOICE, [L]NB_DOC, [L]NB_NONFIC)
          Endif
          If [M]HLPFIL = 2         #VPO 12/06/06 : Plus tard on ne prendra que les fichiers liés à traduire
              Gosub EXTR_FIL
          Endif
          If [M]HLPLNKFLD = 2      #VPO 15/06/06 : Extraire les champs liés
              Gosub EXTR_XML_LNKFLD
          Endif
      Else
          If SORTIE         # Si SORTIE : Une erreur est détectée
             NB_ERR+=1
          Else                     # Si la documentation n'est pas en erreur mais les dates sont équivalentes : pas à traduire
             NB_NONTRA+=1
             If ADOCTRACE=""
                Call ECR_TRACE("      "+[ADO]LAN+"~"+[ADO]TYP+"~"+[ADO]COD-":"-mess(84,176,1),-1) From GESECRAN
             Endif
          Endif
      Endif
    Next ADO

    If ADOCTRACE=""
       Call AFF_BOITE(mess(79,141,1)-mess(42,176,1),3,INTERRUPT ) From GESECRAN
    Endif
    If [M]HLPFLD=2
      #VPO 20/12/06 traitement extraction pour trad
      EV= string$( [M:DIA]ALLLAN=1, "(LAN=[M:DIA]LAN)" )
      EV+=string$( [M:DIA]ALLLAN=2 & [M:DIA]CHOICE>1,  string$(EV<>""," & ")+"(LAN<>[M:DIA]LANREF)" )
      Gosub ALIM_EV_FLD

      Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
      For [ADZ] Where evalue(EV)
         A_EXTRAIRE=0
         Gosub EXTR_XML_FLD
      Next
    Endif

    If ADOCTRACE=""
       Call AFF_BOITE(mess(27,150,1),4,INTERRUPT ) From GESECRAN
       Call FERME_BOITE From GESECRAN
       Call ECR_TRACE(string$(80,"*"),0) From GESECRAN
       Call ECR_TRACE("",0) From GESECRAN
       If [M:DIA]ALLLAN<2
          Call ECR_TRACE(mess(69,116,1)-mess(88,176,1)-":"-num$([L]NB_GENE_KO)-mess(110,123,1)-mess(163,125,1),0) From GESECRAN
          Call ECR_TRACE(mess(69,116,1)-mess(90,176,1)-":"-num$([L]NB_DOC)+"/"+num$([L]NB_TOT_DOC),0) From GESECRAN
          Call ECR_TRACE(mess(69,116,1)-mess(92,176,1)-":"-num$([L]NB_ERR2)+"/"+num$([L]NB_ERR)-":"-mess(84,176,1)-":"-num$([L]NB_NONTRA)+"."-mess(93,176,1)-":"-num$([L]NB_NONFIC),0) From GESECRAN
          Call ECR_TRACE(mess(69,116,1)-mess(87,176,1)-":"-num$([L]NB_FLD_LIES)+"/"+num$([L]NB_TOT_FLD_L-[L]NBFLD_L_EXIS),0) From GESECRAN
          Call ECR_TRACE(mess(69,116,1)-mess(42,176,1)-"("+mess(20,127,1)+") :"-num$([L]NB_FLD)+"/"+num$([L]NB_TOT_FLD-[L]NB_FLD_EXIST),0) From GESECRAN
          Call ECR_TRACE(mess(69,116,1)-mess(43,176,1)-":"-num$([L]NB_FIL)+"/"+num$([L]NB_TOT_FIL),0) From GESECRAN
          Call ECR_TRACE("",0) From GESECRAN
          Call FERME_TRACE From LECFIC
       Endif
    Endif
Return

# Affichage du détail de la trace en mode : Extraction via la boite d'extraction et non via Plan de TRavail
$TRACE_NON_PLAN_TRAVAIL
    TRA = 1
    Call OUVRE_BOITE(mess(6,100,1),4) From GESECRAN
    Call OUVRE_TRACE(mess(68,176,1)) From LECFIC
    Call ECR_TRACE("",0) From GESECRAN

    Case [M:DIA]CHOICE
      When 2 : Call ECR_TRACE(mess(69,176,1) -func AFNC.MES2(mess(125,176,1),[M:DIA]LANREF,[M:DIA]LAN),0)  From GESECRAN
      When 3 : Call ECR_TRACE(mess(123,176,1)-func AFNC.MES2(mess(125,176,1),[M:DIA]LANREF,[M:DIA]LAN),0)  From GESECRAN
      When 1 : Call ECR_TRACE(mess(124,176,1),0)                                           From GESECRAN
      When Default :
    Endcase

    Call ECR_TRACE(mess(174,124,1)-":",0)                                      From GESECRAN  # Critères de sélection
    Call ECR_TRACE(string$(23,"*"),0)                                          From GESECRAN
    If [M:DIA]CHOICE=1   # Extraction simple par langue
      Call ECR_TRACE(mess(41,176,1)-":"-mess([M:DIA]VALDOC,2950,1),0)          From GESECRAN
      If [M:DIA]ALLLAN=2 : Call ECR_TRACE(mess(70,176,1)-":"-mess(71,176,1),0) From GESECRAN  # Toutes Langues
      Else               : Call ECR_TRACE(mess(70,176,1)-":"-[M:DIA]LAN,0)     From GESECRAN
      Endif
      If [M:DIA]ENLANREF=2
        Call ECR_TRACE(mess(70,176,1)-":"-[M:DIA]LANREF-"("+mess(67,176,1)+")",0) From GESECRAN
      Endif
    Endif
    If [M:DIA]ALLTYP=2    : Call ECR_TRACE(mess(59,100,1)-":"-mess(210,133,1),0) From GESECRAN  # Tous Types
    Else                  : Call ECR_TRACE(mess(59,100,1)-":"-[M:DIA]TYP,0)      From GESECRAN
    Endif
    If [M:DIA]EXCTYP=2    : Call ECR_TRACE(mess(3,2943,1)-": APM, AT*, AML",0)   From GESECRAN  :  Endif
    If [M:DIA]ALLCOD=2    : Call ECR_TRACE(mess(72,9953,1)-":"-mess(210,133,1),0)                  From GESECRAN  # Tous Codes
    Else                  : Call ECR_TRACE(mess(72,9953,1)-":"-[M:DIA]CODDEB-"->"-[M:DIA]CODFIN,0) From GESECRAN
    Endif
    If [M:DIA]ALLACV=2    : Call ECR_TRACE(mess(14,115,1)-":"-mess(210,133,1),0) From GESECRAN  # Tous Codes activités
    Else                  : Call ECR_TRACE(mess(14,115,1)-":"-[M:DIA]ACV,0)      From GESECRAN
    Endif
    If [M:DIA]ALLMOD=2    : Call ECR_TRACE(mess(75,106,1)-":"-mess(210,133,1),0)          From GESECRAN  # Tous modules
    Else                  : Call ECR_TRACE(mess(75,106,1)-":"-mess([M:DIA]MODULE,14,1),0) From GESECRAN
    Endif
    If [M:DIA]EXCMOD=2    : Call ECR_TRACE(mess(3,2943,1)-mess(58,105,1)-":"-mess([M:DIA]MODTOEXC,14,1),0) From GESECRAN  :  Endif
    If [M:DIA]HLPFIL=2    : Call ECR_TRACE(mess(43,176,1)-":"-mess(([M:DIA]HLPFIL=2)+1,1,1),0)             From GESECRAN  :  Endif
    If [M:DIA]HLPLNKFLD=2 : Call ECR_TRACE(mess(87,176,1)-":"-mess(([M:DIA]HLPLNKFLD=2)+1,1,1),0)          From GESECRAN  :  Endif
    If [M:DIA]HLPFLD=2    : Call ECR_TRACE(mess(42,176,1)-":"-[M:DIA]FLDDEB-"->"-[M:DIA]FLDFIN,0)          From GESECRAN  :  Endif
    Call ECR_TRACE("|"+mess(37,139,1)-mess(29,115,1)-":"-[M:DIA]REPERT,0)  From GESECRAN
    Call ECR_TRACE(string$(80,"*"),0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
Return

# CAS DE TRADUCTION GLOBALE : Génération de ADOCUMENT et COPIE ADOCFLD dans la langue cible V_LAN
$GENERATION_ADOCUMENT
    V_LAN=[M:DIA]LAN  :  V_LANREF=[M:DIA]LANREF
    # JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
    Gosub DECL_VALLCREGRP                                       From AGENLIBA
    Call  TRANS_ALLCREGRP("[V]V_ALLCREGRP", "[M:DIA]ALLCREGRP") From AGENLIBA
    If ADOCTRACE=""
       Call AFF_BOITE(mess(29,115,1)-"ADOCUMENT -"-V_LAN,1,INTERRUPT )      From GESECRAN
       Call ECR_TRACE(string$(20,"*")-mess(16,176,1)-"ADOCUMENT -"-V_LAN,0) From GESECRAN
    Endif

    # Sauvegarde Masque initial
    [DIA2]=[DIA]

    # 1/ Génération de ADOCUMENT avec les Aides sur champs ADOCFLD liées aux documentations sélectionnées dans la langue cible V_LAN
    If clalev([ADO4])=0 : Local File ADOCUMENT [ADO4] : Endif
    EV = "(LAN=[M:DIA]LANREF)"
    EV+= " & (VLDDAT<>[0/0/0] and VLDFLG=2)"
    Gosub ALIM_EV
    Gosub GENERATION_PAR_LAN
    Local Mask ADOCEXT [DIA]
    [DIA]=[DIA2]

    # 2/ Génération de ADOCFLD par copie de la langue standard vers langue cible V_LAN pour l'extraction des aides sur champs seules
    If [M]HLPFLD=2
       If clalev([ADZ6])=0 : Local File ADOCFLD [ADZ6] : Endif
       EV = "(LAN=[M:DIA]LANREF)"
       Gosub ALIM_EV_FLD
       Gosub GENERATION_FLD_PAR_LAN
       Local Mask ADOCEXT [DIA]
       [DIA]=[DIA2]
    Endif

    If ADOCTRACE=""
       Call ECR_TRACE("",0) From GESECRAN
    Endif
    # JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
    Gosub KILL_VALLCREGRP   From AGENLIBA
Return

$GENERATION_PAR_LAN
    # On boucle sur LAN+TYP+COD en langue de référence et on génère selon V_LAN
    For [ADO4]ADO0(3) Where evalue(EV)
       If clalev([DIA]) : Close Mask [DIA] : Endif
       V_TYPDOC=[ADO4]TYP  :  V_CODDOC=[ADO4]COD
       Call TRAITE_GENE_COPIE(V_LAN, V_LANREF, V_TYPDOC, V_CODDOC, "[V]V_ALLCREGRP") From ADOCTRA
       If [V]NB_GEN_ADOC = 0 : NB_GENE_KO+=1 : Endif
    Next ADO4
Return

$GENERATION_FLD_PAR_LAN
    # On boucle sur MOTCLE en langue de référence et on génère selon V_LAN
    For [ADZ6] Where evalue(EV)
       If clalev([DIA]) : Close Mask [DIA] : Endif
       V_CODDOC=[ADZ6]MOTCLE
       Call TRAITE_COPIE_FLD(V_LAN, V_LANREF, V_CODDOC, "[V]V_ALLCREGRP") From ADOCTRA
    Next ADZ6
Return

$ALIM_EV
    #JPGA 14/04/2011 BUG-71587: Pas de traduction pour las DOCS de type MC qui sont Crées/Gérées Manuellement par l'Industrialisation
    Gosub DOC_INTRADUISIBLES  From ADOCTRA

    EV+= string$( [M:DIA]EXCTYP=2, string$(EV<>""," & ")+"(find(TYP,"+[L]DOC_NONTRA+") = 0)" )
    EV+= string$( [M:DIA]ALLTYP=1, string$(EV<>""," & ")+"(TYP=[M:DIA]TYP)" )
    EV+= string$( [M:DIA]ALLACV=1, string$(EV<>""," & ")+"(CODACT=[M:DIA]ACV)" )
    #EV+=string$( [M:DIA]ALLCOD=1, string$(EV<>""," & ")+"([ADO]COD=[M:DIA]CODDEB)" )
    EV+= string$( [M:DIA]ALLCOD=1, string$(EV<>""," & ")+"(COD>=[M:DIA]CODDEB)&(COD<=[M:DIA]CODFIN)" )
    EV+= string$( [M:DIA]ALLMOD=1, string$(EV<>""," & ")+"MODULE="+num$([M:DIA]MODULE) )
    EV+= string$( [M:DIA]EXCMOD=2, string$(EV<>""," & ")+"MODULE<>"+num$([M:DIA]MODTOEXC) )
    EV+= string$( EV="","1=1" )
Return

$ALIM_EV_FLD
    EV+=string$(EV<>"", " & ")+"(MOTCLE>=[M:DIA]FLDDEB)&(MOTCLE<=[M:DIA]FLDFIN)"
    EV+=string$( [M:DIA]ALLMOD=1, string$(EV<>""," & ")+"MODULE="+num$([M:DIA]MODULE) )
    EV+=string$( [M:DIA]EXCMOD=2, string$(EV<>""," & ")+"MODULE<>"+num$([M:DIA]MODTOEXC) )
    EV+=string$( EV="","1=1" )
Return


################################################################################
# Controles de validité par comparaison entre la langue cible d'extraction et la langue de Référence
Subprog CONTROLE_VALIDITE (REF_VLDDAT, REF_VLDFLG, REF_LAN, REF_LEV, REF_SUBLEV, A_EXTRAIRE, SORTIE)
Value Date       REF_VLDDAT
Value Integer    REF_VLDFLG, REF_LEV, REF_SUBLEV
Value Char       REF_LAN
Variable Integer A_EXTRAIRE, SORTIE

    #on ne traite pas la doc si un paragraphe n'est pas valide
    If REF_VLDDAT=[0/0/0] or REF_VLDFLG<>2
       # Un paragraphe de la langue de référence n'est pas validé : extraction pour traduction impossible
       Call ECR_TRACE("      "+mess(77,176,1)-"("+REF_LAN+"/LEV="+num$(REF_LEV)-"SUBLEV="+num$(REF_SUBLEV)+")",1) From GESECRAN
       A_EXTRAIRE=0 : SORTIE=1 : End
    Endif

    #on ne traite pas la doc s'il manque un paragraphe dans la langue cible
    Read [ADO3]ADO0=[ADO]LAN;[ADO]TYP;[ADO]COD;REF_LEV;REF_SUBLEV
    If fstat<>0
       # Il manque un paragraphe dans la langue de traduction : extraction pour traduction impossible
       Call ECR_TRACE("      "+mess(78,176,1)-"("+"LEV="+num$(REF_LEV)-"SUBLEV="+num$(REF_SUBLEV)+")",1) From GESECRAN
       A_EXTRAIRE=0 : SORTIE=1 : End
    Endif

    # On extrait la doc si : Doc non validée ou Date Langue cible <> Date Langue ref ou (re)Traduction
    If ! A_EXTRAIRE
       If [M:DIA]CHOICE=3
          A_EXTRAIRE=1
       Else
          If [ADO3]VLDDAT=[0/0/0] or [ADO3]VLDFLG<>2 or [ADO3]VLDDAT<>REF_VLDDAT
             A_EXTRAIRE=1
          Endif
       Endif
    Endif
End

# Controle pour savoir si la structure entre langue cible et langue de REF est différente : on n'extrait pas
Subprog CONTROLE_VALIDITE_DIF (TRA_LAN, TRA_TYP, TRA_COD, REF_LAN, A_EXTRAIRE, SORTIE)
Value Char       TRA_LAN, TRA_TYP, TRA_COD, REF_LAN
Variable Integer A_EXTRAIRE, SORTIE

    For [AD1]ADO0 Where LAN=TRA_LAN & TYP=TRA_TYP & COD=TRA_COD
       Raz [ADO3]
       Read [ADO3]ADO0=REF_LAN;[AD1]TYP;[AD1]COD;[AD1]LEV;[AD1]SUBLEV
       If [S]fstat<>0
          Raz [ZDO2]
          Read [ZDO2]ADO0=REF_LAN;[AD1]TYP;[AD1]COD;[AD1]LEV;[AD1]SUBLEV
          [ADO3]=[ZDO2]
       Endif
       If [ADO3]COD<>""
          If [ADO3]PAR<>[AD1]PAR
             # les paragraphes doivent correspondre
             Call ECR_TRACE("      "+mess(74,176,1)-"("+"LEV="+num$([AD1]LEV)-"SUBLEV="+num$([AD1]SUBLEV)+")",1) From GESECRAN
             A_EXTRAIRE=0 : SORTIE=1 : Break
          Endif
       Else
          # Paragraphe inexistant de la langue de Référence
          Call ECR_TRACE("      "+mess(85,176,1)-"("+[M:DIA]LANREF+"/LEV="+num$([AD1]LEV)-"SUBLEV="+num$([AD1]SUBLEV)+")",1) From GESECRAN
          A_EXTRAIRE=0 : SORTIE=1 : Break
       Endif
    Next
End

# Controles de validité par comparaison entre la langue cible d'extraction et la langue de Référence
Subprog CONTROLE_VALIDITE_FLD (REF_UPDDAT, REF_CREDAT, REF_TEXTE, LAN_UPDDAT, LAN_CREDAT, LAN_TEXTE, A_TRADUIRE)
Value Date       REF_UPDDAT, REF_CREDAT, LAN_UPDDAT, LAN_CREDAT
Value Clbfile    REF_TEXTE, LAN_TEXTE
Variable Integer A_TRADUIRE
Local Char       V_TXTORI (250)
Local Char       V_TXTFLD (250)

   REF_DAT=[0/0/0]
   If REF_UPDDAT=[0/0/0]
      REF_DAT=REF_CREDAT
   Else
      REF_DAT=REF_UPDDAT
   Endif
   Setlob V_TXTORI With REF_TEXTE
   Setlob V_TXTFLD With LAN_TEXTE

   If !(REF_DAT>LAN_CREDAT or (V_TXTORI<>"" and V_TXTFLD="") )
      A_TRADUIRE=0
   Endif
End

# Controles de validité des fichiers liés : En Traduction, on n'extrait que les fichier liés html ou ceux marqués à Traduire
Subprog CONTROLE_VALIDITE_FIL (A_TRADUIRE)
Variable Integer A_TRADUIRE

   If dim([ADB]TRAFIL)>0
      If (pat([ADB]NAM,"*.htm*")<>0 & find([ADO]TYP,"AM","AD","FI")) | [ADB]TRAFIL=2
         [L]A_TRADUIRE = 1
      Endif
   Else
      If pat([ADB]NAM,"*.htm*")<>0
         [L]A_TRADUIRE = 1
      Endif
   Endif
End

################################################################################
# Extraction d'une doc en XML
Subprog EXTR_XML(CREP, CLAN, CTYP, CCODE, CCHOICE, NB_DOC, NB_NONFIC)
Value Char       CREP, CLAN, CTYP, CCODE
Value Integer    CCHOICE
Variable Integer NB_DOC, NB_NONFIC

Local Clbfile MYCLOBTIT
Local Clbfile TXTCLOB(10)
Local Clbfile MYCLOB(10)
# Pour pouvoir utiliser la fonction REPNOM_FIC
Local Char NOMDOC(100),SOUS_REPERT(100), LIENSGEN(100)
Local Integer TYPEFONC

  Gosub DECL_COMVAR From AGENLIBA
  [V]COD_LAN=CLAN  :  VV_TYP=CTYP

# Détermination du répertoire et du nom de la documentation
  #Gosub REPERT_LAN From AGENDOCA
  Gosub REPERT_LAN_EXT
  Gosub REPNOM_FIC From AGENADO

# La doc n'est pas à générer si NOMDOC est vide
  If NOMDOC=""
    NB_NONFIC+=1
    Call ECR_TRACE("      "+[ADO]LAN+"~"+[ADO]TYP+"~"+[ADO]COD-":"-mess(93,176,1),-1) From GESECRAN
    End
  Endif

  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", CLAN, CTYP, CCODE, "[M:DIA]ALLCREGRP") : End : Endif

  NB_DOC+=1
# Magouille imfame apres etre passe par REPNOM_FIC de AGENADO pour retransformer le $ de fin en _D (pour l'import futur!)
  If CTYP="AD"
     If pat(CCODE,"*_D") & right$(NOMDOC,len(NOMDOC))="$"  : NOMDOC=left$(NOMDOC,len(NOMDOC)-1)+"_D" : Endif
  Endif

  If CTYP<> "AFC"
    RECH=CTYP+"_"
    If left$(NOMDOC,len(RECH))<>RECH
        NOMDOC=RECH+NOMDOC
    Endif
  Endif

  FICOUV = REPERT_DOC + SLASH + NOMDOC + ".xml"
  Gosub TEST_SOUS_REPERT From AGENDOCA
  Call ECR_TRACE("|"+"      "+mess(72,176,1)-FICOUV,0) From GESECRAN

  Openo FICOUV,0 Using [AXML]
  Iomode adxifs chr$(0) Using [AXML]
  Iomode adxirs chr$(13)+chr$(10) Using [AXML]
  #Iomode adxium GADXHTENT Using [AXML]
  Iomode adxium GUTF8 Using [AXML]

# En-tête
  Wrseq '<?xml version="1.0" encoding="utf-8" ?>' Using [AXML]
  Wrseq '<DOC TYPE="'+CTYP+'" NAME="'+CCODE+'">' Using [AXML]

# Liste des paragraphes
  For [AD1]ADO0 Where LAN=CLAN & TYP=CTYP & COD=CCODE
    Wrseq '  <PAR LAN="'+CLAN+'" LEV="'+num$([AD1]LEV)+'" SUBLEV="'+num$([AD1]SUBLEV)+'" '; Using [AXML]
    #VPO 15/06/06 le titre doit être extrait en dehors de la balise
    #Wrseq ' PAR="'+[AD1]PAR+'" TIT="'+[AD1]TIT+'" STY="'+num$([AD1]STY); Using [AXML]
    #VPO 20/12/06 ajout MSK
    Wrseq ' PAR="'+[AD1]PAR+'" MSK="'+[AD1]MSK+'" STY="'+num$([AD1]STY); Using [AXML]

    #VPO 20/12/06 ajout extraction pour trad + VLDDAT et VLDFLG / #JPGA 01/04/2010 BUG-52484: En Re-Traduction : le contenu doit être en LANREF
    [AD2]=[AD1]
    If ! (CCHOICE<2)
       Raz [ADO3]
       Read [ADO3]ADO0=[M:DIA]LANREF;[AD1]TYP;[AD1]COD;[AD1]LEV;[AD1]SUBLEV
       If [S]fstat<>0
           Raz [ZDO2]
           Read [ZDO2]ADO0=[M:DIA]LANREF;[AD1]TYP;[AD1]COD;[AD1]LEV;[AD1]SUBLEV
           [ADO3]=[ZDO2]
       Endif

       If [ADO3]COD<>"" & [ADO3]PAR=[AD1]PAR
          [AD1]=[ADO3]
       Endif
    Endif
    If [AD1]VLDDAT=[0/0/0] | [AD1]VLDFLG<>2
        # Attention: le paragraphe extrait n'est pas validé
        Call ECR_TRACE("      >>"+mess(76,176,1)-"("+[AD1]LAN+"/LEV="+num$([AD1]LEV)-"SUBLEV="+num$([AD1]SUBLEV)+")",-1) From GESECRAN
    Endif

    Wrseq '" VLDDAT="'+[AD1]VLDDAT+'" VLDFLG="'+num$([AD1]VLDFLG); Using [AXML]
    Wrseq '" ACT="'+[AD2]CODACT+'" MOD="'+num$([AD2]MODULE)+'" >' Using [AXML]
    #VPO 15/06/06 le titre doit être extrait en dehors de la balise
    #VPO 16/01/07 mettre balise titre même s'il est vide car sinon pb de fichier
    #             suite passage dans trados
    Wrseq '    <TIT>' Using [AXML]
    If [AD2]TIT<>""
        # Setlob MYCLOBTIT With [AD2]TIT
        If [AD2]UPDDATTIM > [AD1]UPDDATTIM : # 111505 CCL
         Setlob MYCLOBTIT With [AD2]TIT
        Else
         Setlob MYCLOBTIT With [AD1]TIT
        Endif # 111505 CCL
        Wrseq MYCLOBTIT Using [AXML]
    Endif
    Wrseq '    </TIT>' Using [AXML]
    Gosub LEC_AD1 From AGENDOCA
    If TEXBASE
        Wrseq '    <HTML>' Using [AXML]
        If TEXBASE=1
            TXTCLOB=[ADH]TEXTE
            Gosub CORRIGEXML
            Wrseq TXTCLOB Using [AXML]
        Else
            TXTCLOB=[ADH2]TEXTE
            Gosub CORRIGEXML
            Wrseq TXTCLOB Using [AXML]
        Endif
        Wrseq '    </HTML>' Using [AXML]
    Endif
    Wrseq '  </PAR>' Using [AXML]
  Next

# On referme la balise de doc et le fichier
  Wrseq '</DOC>' Using [AXML]
Openo Using [AXML]
End

$CORRIGEXML
