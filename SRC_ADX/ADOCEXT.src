######################################################################################
Subprog C_ALLTYP(VALEUR)
Variable Integer  VALEUR
If VALEUR=2
 [M]TYP = "" : Actzo [M]EXCTYP : Grizo [M]TYP : Affzo [M]TYP , EXCTYP
Else
 Actzo [M]TYP   : Grizo [M]EXCTYP : Affzo [M]TYP, EXCTYP
Endif
End

Subprog AM_TYP(VALEUR)
Variable Char    VALEUR()
If VALEUR="FI"
 [M]HLPFIL=2 : Affzo HLPFIL
Endif
End

Subprog C_ALLACV(VALEUR)
Variable Integer VALEUR
   [M]ALLACV=VALEUR
   Gosub GRISAGE_ALLACV
End

######################################################################################
Subprog AM_ALLMOD(VALEUR)
Variable Integer VALEUR
    [M]ALLMOD=VALEUR
    Gosub GRISAGE_MODULE
End

Subprog AM_EXCMOD(VALEUR)
Variable Integer VALEUR
    [M]EXCMOD=VALEUR
    Gosub GRISAGE_EXCLUSION
End

######################################################################################
Subprog C_ALLCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]CODDEB = "" : Affzo CODDEB : Grizo CODDEB
 [M]CODFIN = "" : Affzo CODFIN : Grizo CODFIN
Else
 Actzo CODDEB
 Actzo CODFIN
Endif
End

Subprog AM_ALLCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]HLPLNKFLD=2 : Affzo HLPLNKFLD
Endif
End

Subprog AM_CODDEB(VALEUR)
Variable Char    VALEUR()
   If VALEUR<>"" and [M]CODFIN=""
      [M]CODFIN=VALEUR : Affzo [M]CODFIN
   Endif
   [M]CODDEB=VALEUR
   Gosub FORCAGE_FICHIERS_LIES
End

Subprog AS_CODFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   VALEUR=[M:DIA]CODDEB
   If VALEUR=""
      VALEUR="X"
   Endif
Endif
End

Subprog AM_CODFIN(VALEUR)
Variable Char    VALEUR()
   [M]CODFIN=VALEUR
   Gosub FORCAGE_FICHIERS_LIES
End

######################################################################################
Subprog AS_HLPFIL(VALEUR)
Variable Integer VALEUR
If ([M]TYP="" and [M]ALLTYP=1) or ([M]CODDEB="" and [M]CODFIN="" and [M]ALLCOD=1)
    [S]mkstat=1
Endif
End

Subprog AS_HLPLNKFLD(VALEUR)
Variable Integer VALEUR
If ([M]TYP="" and [M]ALLTYP=1) or ([M]CODDEB="" and [M]CODFIN="" and [M]ALLCOD=1)
    [S]mkstat=1
Endif
End

######################################################################################
Subprog C_HLPFLD(VALEUR)
Variable Integer VALEUR
If VALEUR=1
    [M]FLDDEB="" : Affzo [M]FLDDEB
    [M]FLDFIN="" : Affzo [M]FLDFIN
Endif
End

Subprog AM_FLDDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
    If [M]FLDFIN=""
       [M]FLDFIN=VALEUR : Affzo [M]FLDFIN
    Endif
    [M]HLPFLD=2 : Affzo [M]HLPFLD
    Call C_HLPFLD([M]HLPFLD)
Endif
End

Subprog AS_FLDFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   VALEUR=[M:DIA]FLDDEB
   If VALEUR=""
      VALEUR="X"
   Endif
Endif
End

Subprog AM_FLDFIN(VALEUR)
Variable Char    VALEUR()
   [M]FLDFIN=VALEUR
   Gosub FORCAGE_FLD
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ADOCEXT) 17/10/2012 16:52:30 (JPGA)
######################################################################################
Subprog AV_ALLCREGRP(VALEUR)
Variable Integer VALEUR
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  #Le modèle "Traitement Standard-Boite de dialogue" ne permet pas chgfmt en INIT_DIA : on le fait donc en Avant-zone de champ
  Call AFFMASK_GROUPE("[M]ALLCREGRP") From AGENLIBA
End
######################################################################################

$GRISAGE_EXT
  [M:DIA]ALLLAN=1 : Affzo [M:DIA]ALLLAN
  [M:DIA]ENLANREF=1 : Affzo [M:DIA]ENLANREF
  [M:DIA]VALDOC=3 : Affzo [M:DIA]VALDOC
  [M:DIA]LANEXT="" : Affzo [M:DIA]LANEXT : Grizo [M:DIA]LANEXT
  [M:DIA]LANREFEXT="" : Affzo [M:DIA]LANREFEXT : Grizo [M:DIA]LANREFEXT
  Diszo [M:DIA]ENLANREF,ALLLAN,LANEXT,VALDOC
Return

$GRISAGE_TRAD
  [M:DIA]LANTRA="" : Affzo [M:DIA]LANTRA : Grizo [M:DIA]LANTRA
  [M:DIA]LANREFTRA="" : Affzo [M:DIA]LANREFTRA : Grizo [M:DIA]LANREFTRA
  Diszo [M:DIA]LANTRA,LANREFTRA
Return

$DEGRISE_EXT
  Gosub GRISAGE_LANEXT
  Actzo [M:DIA]ENLANREF,ALLLAN,LANEXT,VALDOC : Affzo [M:DIA]LANEXT
  Gosub INIT_LANEXT_LANREFEXT
Return

$DEGRISE_TRAD
  Actzo [M:DIA]LANTRA,LANREFTRA : Affzo [M:DIA]LANTRA,LANREFTRA
  Gosub INIT_LANTRA_LANREFTRA
Return

$GRISAGE_LANEXT
  If [M]ALLLAN=2
     [M]LANEXT = "" : Affzo [M]LANEXT : Grizo [M]LANEXT : [M]LAN=[M]LANEXT
  Else
     Actzo [M]LANEXT
  Endif
  Affzo [M]LANEXT, LAN
Return

Subprog AS_EXTRETRA(VALEUR)
Variable Integer VALEUR
  If [M]EXTTRA=1 : Gosub GRISAGE_TRAD : Endif
  Gosub GRISAGE_EXT
  Gosub GRISAGE_ALLACV
  Gosub GRISAGE_MODULE
  Gosub GRISAGE_EXCLUSION
  Gosub FORCAGE_FICHIERS_LIES
End

Subprog AM_EXTRETRA(VALEUR)
Variable Integer VALEUR
  If VALEUR=2
    [M:DIA]CHOICE=3
    If [M]EXTLAN=2 : [M]EXTLAN=1 : Affzo [M]EXTLAN : Endif
    If [M]EXTTRA=2 : [M]EXTTRA=1 : Affzo [M]EXTTRA : Endif
    Gosub GRISAGE_EXT
    Gosub DEGRISE_TRAD
  Else
    Gosub GRISAGE_TRAD
    Gosub GRISAGE_EXT
  Endif
  [M:DIA]LAN=[M:DIA]LANTRA : [M:DIA]LANREF=[M:DIA]LANREFTRA
  Affzo [M:DIA]LAN,LANREF,LANTRA,LANREFTRA
  zonsui="EXTTRA"
End

Subprog AM_EXTTRA(VALEUR)
Variable Integer VALEUR
  If VALEUR=2
    [M:DIA]CHOICE=2
    If [M]EXTLAN=2 : [M]EXTLAN=1 : Affzo [M]EXTLAN : Endif
    If [M]EXTRETRA=2 : [M]EXTRETRA=1 : Affzo [M]EXTRETRA : Endif
    Gosub GRISAGE_EXT
    Gosub DEGRISE_TRAD
  Else
    Gosub GRISAGE_TRAD
    Gosub GRISAGE_EXT
  Endif
  [M:DIA]LAN=[M:DIA]LANTRA : [M:DIA]LANREF=[M:DIA]LANREFTRA
  Affzo [M:DIA]LAN,LANREF,LANTRA,LANREFTRA
  [M]HLPFIL=2 : Affzo [M]HLPFIL
End

Subprog AM_EXTLAN(VALEUR)
Variable Integer VALEUR
  If VALEUR=2
    [M:DIA]CHOICE=1
    Gosub GRISAGE_TRAD
    Gosub DEGRISE_EXT
    If [M]EXTTRA=2 : [M]EXTTRA=1 : Affzo [M]EXTTRA : Endif
    If [M]EXTRETRA=2 : [M]EXTRETRA=1 : Affzo [M]EXTRETRA : Endif
  Else
    Gosub GRISAGE_EXT
    Gosub GRISAGE_TRAD
  Endif
  [M:DIA]LAN=[M:DIA]LANEXT : [M:DIA]LANREF=[M:DIA]LANREFEXT
  Affzo [M:DIA]LAN,LANREF,LANEXT,LANREFEXT
End

Subprog AM_LANTRA(VALEUR)
Variable Char    VALEUR()
  [M:DIA]LAN = VALEUR : Affzo [M:DIA]LAN
End

Subprog AM_LANREFTRA(VALEUR)
Variable Char    VALEUR()
  [M:DIA]LANREF = VALEUR : Affzo [M:DIA]LANREF
End

Subprog AM_LANEXT(VALEUR)
Variable Char    VALEUR()
  [M:DIA]LAN = VALEUR : Affzo [M:DIA]LAN
End

Subprog AM_LANREFEXT(VALEUR)
Variable Char    VALEUR()
  [M:DIA]LANREF = VALEUR : Affzo [M:DIA]LANREF
End

Subprog C_LANEXT(VALEUR)
Variable Char    VALEUR()
   If VALEUR="" & [M]ALLLAN=1
      GMESSAGE = mess(62,176,1)
      mkstat=1 : End
   Endif
End

Subprog C_LANTRA(VALEUR)
Variable Char    VALEUR()
   If VALEUR=[M:DIA]LANREF
    Gosub ERREUR_MEME_LANGUE
    End
   Endif
End

Subprog C_LANREFTRA(VALEUR)
Variable Char    VALEUR()
   If VALEUR=[M:DIA]LAN
    Gosub ERREUR_MEME_LANGUE
    End
   Endif
End

#####################################################################################

