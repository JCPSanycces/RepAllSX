    #####
    Gosub CORRIGE_P
    Gosub CORRIGE_TD
    Gosub VERIF_LI
Return

$CORRIGE_TD
CPTDEBP=0 : CPTFINP=0

RECH='<td>'
CPT = -1 : J = 0
Repeat J = instr(J+1, TXTCLOB,RECH) : CPT += 1 : Until J = 0
CPTDEBP+=CPT

RECH='<td '
CPT = -1 : J = 0
Repeat J = instr(J+1, TXTCLOB,RECH) : CPT += 1 : Until J = 0
CPTDEBP+=CPT

RECH='</td>'
CPT = -1 : J = 0
Repeat J = instr(J+1, TXTCLOB,RECH) : CPT += 1 : Until J = 0
CPTFINP+=CPT

If CPTDEBP=0 & CPTFINP=1
    RECH='</td>'
    AREMP=' '
    Gosub ONSUPP
Endif
Return

$CORRIGE_P
CPTDEBP=0 : CPTFINP=0

RECH='<P>'
CPT = -1 : J = 0
Repeat J = instr(J+1, TXTCLOB,RECH) : CPT += 1 : Until J = 0
CPTDEBP+=CPT

RECH='<P '
CPT = -1 : J = 0
# JPGA 08/02/2010 BUG-62251 : Ne pas compter les balises <P .../> qui n'ont pas besoin de </P>
Repeat
   J = instr(J+1, TXTCLOB,RECH)
   If J
      Gosub RECH_SLASH
      If ! TROUVE
         CPT += 1
      Endif
   Else
      CPT += 1
   Endif
Until J = 0
CPTDEBP+=CPT

RECH='</P>'
CPT = -1 : J = 0
Repeat J = instr(J+1, TXTCLOB,RECH) : CPT += 1 : Until J = 0
CPTFINP+=CPT

If CPTDEBP<CPTFINP
    For J=CPTDEBP+1 To CPTFINP
        TXTCLOB="<P>"+TXTCLOB
    Next J
Endif
If CPTFINP<CPTDEBP
    For J=CPTFINP+1 To CPTDEBP
        TXTCLOB=TXTCLOB+"</P>"
    Next J
Endif
Return

$VERIF_LI
CPTDEBP=0 : CPTFINP=0

RECH='<LI'
CPT = -1 : J = 0
Repeat J = instr(J+1, TXTCLOB,RECH) : CPT += 1 : Until J = 0
CPTDEBP+=CPT

RECH='</LI>'
CPT = -1 : J = 0
Repeat J = instr(J+1, TXTCLOB,RECH) : CPT += 1 : Until J = 0
CPTFINP+=CPT

If CPTDEBP<>CPTFINP
    Call ECR_TRACE("      "+mess(79,176,1),1) From GESECRAN
Endif
Return

$ONSUPP
J=instr(1,TXTCLOB,RECH)
While J>0
    MYCLOB=left$(TXTCLOB,J-1)+AREMP+right$(TXTCLOB,J+len(RECH))
    TXTCLOB=MYCLOB
    J=instr(1,TXTCLOB,RECH)
Wend
Return

$AJQUOTE
TROUVE=0 : CAR=' '
J=instr(1,TXTCLOB,RECH)
While J>0
    I=J+len(RECH)
    TROUVE=0
    While I<len(TXTCLOB)
        CAR=mid$(TXTCLOB,I,1)
        If CAR='"' : Break : Endif
        If CAR=' ' | CAR='>' : TROUVE=1 : Break : Endif
        I+=1
    Wend
    If TROUVE=1
        MYCLOB=left$(TXTCLOB,J-1)+AREMP+'"'+mid$(TXTCLOB,J+len(RECH),I-(J+len(RECH)))+'"'+right$(TXTCLOB,I)
        TXTCLOB=MYCLOB
    Endif
    J=instr(J+len(RECH)+1,TXTCLOB,RECH)
Wend
Return

$ONSUPP2
J=instr(1,TXTCLOB,RECH1)
I=instr(1,TXTCLOB,RECH2)
While J>0 & I=0
    MYCLOB=left$(TXTCLOB,J-1)+AREMP+right$(TXTCLOB,J+len(RECH1))
    TXTCLOB=MYCLOB
    J=instr(1,TXTCLOB,RECH1)
Wend
Return

$AJSLASH
TROUVE=0 : CAR=' ' : CAR2=' '
J=instr(1,TXTCLOB,RECH)
While J>0
    Gosub RECH_SLASH
    If ! TROUVE
        MYCLOB=left$(TXTCLOB,I-1)+AREMP+right$(TXTCLOB,I+1)
        TXTCLOB=MYCLOB
    Endif
    J=instr(J+len(RECH)+1,TXTCLOB,RECH)
Wend
Return

$RECH_SLASH
    I=J+len(RECH)
    TROUVE=0
    While I<(len(TXTCLOB))
        CAR=mid$(TXTCLOB,I,1) : CAR2=mid$(TXTCLOB,I+1,1)
        If CAR='>' : Break : Endif
        If CAR='/' & CAR2='>' : TROUVE=1 : Break : Endif
        I+=1
    Wend
Return

######################################################################################
$EXTR_XML_LNKFLD
Local Char WMOTCLE(10) : WMOTCLE=""
#VPO 20/12/06 traitement extraction pour trad

# Issue 75246/7 - 2012-06-29 by VPO : mot clé d'aide
#Link [AMZ2] With [ADO3]ADO0(3)=[ADO]LAN;[ADO]TYP;[ADO]COD,[ADZ]ADZ0(1)=[ADO]LAN As [AZZ]
#&                Where [AMZ2]CODMSK=[ADO3]MSK and [AMZ2]MOTCLE=[ADZ]MOTCLE
#& Order By MOTCLE

Link [AMC2] With [ADO3]ADO0(3)=[ADO]LAN;[ADO]TYP;[ADO]COD, [ADZ]ADZ0(1)=[ADO]LAN As [AZZ]
&                Where [AMC2]TYPZON=2 & [AMC2]IDENT1=[ADO3]MSK & [AMC2]MOTCLE=[ADZ]MOTCLE
& Order By [AMC2]MOTCLE


  For [AZZ]
     If WMOTCLE<>[ADZ]MOTCLE
        WMOTCLE=[ADZ]MOTCLE
        Gosub EXTR_XML_FLD
     Endif
  Next
  NB_FLD_LIES=NB_FLD_LIES+NB_FLD : NB_TOT_FLD_L=NB_TOT_FLD_L+NB_TOT_FLD
  NBFLD_L_NTRA=NBFLD_L_NTRA+NBFLD_NTRA : NBFLD_L_EXIS=NBFLD_L_EXIS+NB_FLD_EXIST
  NB_FLD=0 : NB_TOT_FLD=0 : NBFLD_NTRA=0 : NB_FLD_EXIST=0
Return

######################################################################################

$EXTR_XML_FLD
Local Clbfile TXTCLOB(10), MYCLOB(10)
Local Char    SVLAN(GLONLAN)

    #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
    If ! func AGENLIBA.TEST_GROUPE_OK("ADZ", [ADZ]LAN, "", [ADZ]MOTCLE, "[M:DIA]ALLCREGRP") : Return : Endif

    A_EXTRAIRE=1  :  VV_TYP=""  :  NB_TOT_FLD+=1
    Read [ADZ2]ADZ0=[M:DIA]LANREF;[ADZ]MOTCLE
    If [S]fstat<>0
        Read [ZDZ1]ADZ0=[M:DIA]LANREF;[ADZ]MOTCLE
        If [S]fstat<>0
            Call ECR_TRACE("      ADZ:"+[V]COD_LAN+"~"+[ADZ]MOTCLE+" : "+mess(73,176,1),1) From GESECRAN
            [ADZ2]=[ADZ]
        Else
            [ADZ2]=[ZDZ1]
        Endif
    Endif

    # Cas de Traduction : on regarde s'il faut extraite
    If [M:DIA]CHOICE=2
        Call CONTROLE_VALIDITE_FLD ([ADZ2]UPDDAT, [ADZ2]CREDAT, [ADZ2]TEXTE, [ADZ]UPDDAT, [ADZ]CREDAT, [ADZ]TEXTE, A_EXTRAIRE)
        If ! A_EXTRAIRE
           NBFLD_NTRA+=1
           Return
        Endif
    Endif

    Gosub DECL_COMVAR From AGENLIBA

    [V]COD_LAN=[ADZ]LAN
    Call ECR_TRACE("    "+"* ADZ"+":"+[V]COD_LAN+"~"+[ADZ]MOTCLE,0) From GESECRAN
    Gosub AJOUT_NB_FLD
    If ! A_EXTRAIRE
       Return
    Endif

    Gosub REPERT_LAN_EXT
    # On écrit systématiquement dans le sous-répertoire xml
    FICOUV = REPERT_DOC + SLASH + "FLD" + SLASH + [ADZ]MOTCLE + ".xml"
    Gosub TEST_SOUS_REPERT From AGENDOCA
    Call ECR_TRACE("|"+"      "+mess(72,176,1)-FICOUV,0) From GESECRAN

    #CBO 2009.07.10 BUG56210
    Gosub EXTR_XML_FLD2

    # CBO 2009.07.10 bug56210 : Cas de la génération en langue de ref (après celle en langue)
    If [M:DIA]ENLANREF = 2
        [ADZ]=[ADZ2]          : # Dans la lecture avec langue, on remplace par lanref
        [V]COD_LAN=[M:DIA]LANREF
        Gosub REPERT_LAN_EXT

        # On écrit systématiquement dans le sous-répertoire xml
        FICOUV = REPERT_DOC + SLASH + "FLD" + SLASH + [ADZ]MOTCLE + ".xml"

        Gosub TEST_SOUS_REPERT From AGENDOCA
        Call ECR_TRACE("|"+"      "+mess(72,176,1)-FICOUV,0) From GESECRAN

        SVLAN           = [ADZ]LAN
        [ADZ]LAN        = [V]COD_LAN
        Gosub EXTR_XML_FLD2
        [ADZ]LAN        = SVLAN
    Endif
Return

$EXTR_XML_FLD2

  Openo FICOUV,0 Using [AXML]
  Iomode adxifs chr$(0) Using [AXML]
  Iomode adxirs chr$(13)+chr$(10) Using [AXML]
  #Iomode adxium GADXHTENT Using [AXML]
  Iomode adxium GUTF8 Using [AXML]

# En-tête
  Wrseq '<?xml version="1.0" encoding="utf-8" ?>' Using [AXML]
  Wrseq '<FLD NAME="'+[ADZ]MOTCLE+'" LAN="'+[ADZ]LAN; Using [AXML]
  Wrseq '" MOD="'+num$([ADZ]MODULE)+'" GEN="'+num$([ADZ]GEN); Using [AXML]
  Wrseq '" LNKHLP="'+[ADZ]LNKHLP+'" LNKORD="'+num$([ADZ]LNKORD); Using [AXML]
  #Wrseq '" CREDAT="'+[ADZ]CREDAT+'" UPDDAT="'+[ADZ]UPDDAT+'" >' Using [AXML]

    If [M:DIA]CHOICE > 1
        Wrseq '" CREDAT="'+[ADZ2]CREDAT+'" UPDDAT="'+[ADZ2]UPDDAT+'" >' Using [AXML]
        TXTCLOB=[ADZ2]TEXTE
    Else
        Wrseq '" CREDAT="'+[ADZ]CREDAT+'" UPDDAT="'+[ADZ]UPDDAT+'" >' Using [AXML]
        TXTCLOB=[ADZ]TEXTE
    Endif

  Wrseq '  <HTML>' Using [AXML]


  #TXTCLOB=[ADZ2]TEXTE
  Gosub CORRIGEXML

  Wrseq TXTCLOB Using [AXML]

  Wrseq '  </HTML>' Using [AXML]

  # On referme la balise de champ et le fichier
  Wrseq '</FLD>' Using [AXML]
  Openo Using [AXML]
Return

$AJOUT_NB_FLD
   If [M:DIA]ALLLAN<2
      If NB_MOTCLE > NBMAX_MOTCLE
         If ADOCTRACE=""
            Call ECR_TRACE(mess(91,176,1)-":"-num$([L]NBMAX_MOTCLE),0) From GESECRAN
         Endif
         NB_FLD+=1
      Else
         If ! find([ADZ]MOTCLE, AIDE_TRAITE)
            AIDE_TRAITE(NB_MOTCLE)=[ADZ]MOTCLE
            NB_MOTCLE+=1 : NB_FLD+=1
         Else
            A_EXTRAIRE=0 : NB_FLD_EXIST+=1
        Endif
      Endif
   Else
      NB_FLD+=1
   Endif
Return

######################################################################################
$EXTR_FIL
Local Char CLEFIC(250),NAMFIC(250),LENFIC(250),DEBFIC(250),FINFIC(250), SVREPERT_DOC(200)
Local Integer A_EXTRAIRE

    #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
    If ! func AGENLIBA.TEST_GROUPE_OK("ADB",[ADO]LAN, [ADO]TYP, [ADO]COD, "[M:DIA]ALLCREGRP") : Return : Endif

    Gosub DECL_COMVAR From AGENLIBA
    [V]COD_LAN=[ADO]LAN  :  VV_TYP=[ADO]TYP

    # Détermination du répertoire et du nom de la documentation
    Gosub REPERT_LAN_EXT

    #VPO 13/12/07 BUG44457 on n'extrait que les fichiers htm pour la trad
    If [M:DIA]CHOICE = 1
        # CBO 2009.07.10 bug56210
        If [M:DIA]ENLANREF = 2
            Local File "ADOCBLB" [ADB9]
        Endif

        #plus tard on ne prendra que les fichiers liés à traduire
        For [ADB]ADB0 Where LAN=[ADO]LAN and TYP=[ADO]TYP and COD=[ADO]COD
            NB_TOT_FIL+=1
            Gosub EXTR_FIL_WRITE

            # CBO 2009.07.10 bug56210 : Cas de la génération en langue de ref (après celle en langue)
            If [M:DIA]ENLANREF = 2
                [V]COD_LAN=[M:DIA]LANREF
                [L]SVREPERT_DOC=REPERT_DOC
                Gosub REPERT_LAN_EXT

                CLEFIC = [ADB]COD+"_"+[V]COD_LAN+"_"+[ADB]TYP+"_"+num$([ADB]LEV)+"_"+num$([ADB]SUBLEV)+"_"+num$([ADB]LIG)
                FICOUV = REPERT_DOC + SLASH + "FILE" + SLASH + CLEFIC + "_" + NAMFIC

                # On écrit systématiquement dans le sous-répertoire xml
                Gosub TEST_SOUS_REPERT From AGENDOCA
                Call ECR_TRACE("|"+"      "+mess(72,176,1)-FICOUV,0) From GESECRAN

                Openo FICOUV,0 Using [BLO]

                Read [ADB9]ADB0 = [V]COD_LAN; [ADO]TYP; [ADO]COD; [ADB]LEV; [ADB]SUBLEV;  [ADB]LIG
                Putseq 1,[ADB]PICTUR Using [BLO]
                Openo Using [BLO]

                [V]COD_LAN=[ADO]LAN
                REPERT_DOC=[L]SVREPERT_DOC
            Endif
        Next

        If [M:DIA]ENLANREF = 2
            Close File [ADB9]
        Endif
    Else
        #VPO 05/12/07 BUG44457 special trad type=AD,FI,AM
        #VPO 05/12/07 on doit prendre le fichier dans la langue de ref
        #JPGA 06/08/2009 - Cas différence V5-V6 pour avoir le même traitement: TRAFIL inexistant en V5
        #JPGA 30/03/2012 BUG-80530 : Mauvais traitement de la Traduction des fichiers liés dans un Dossier Fille
        Filter [ADB] Where LAN=[M:DIA]LANREF and TYP=[ADO]TYP and COD=[ADO]COD
        If rowcount([ADB])      # Recherche dans dossier Courant en Langue de REF si au moins 1 Enreg
          For [ADB]ADB0
            Gosub EXTR_ADB
          Next ADB
        Else                    # Recherche dans dossier Racine  en Langue de REF
          If GDOSX3<>nomap
            For [ADB2]ADB0 Where LAN=[M:DIA]LANREF and TYP=[ADO]TYP and COD=[ADO]COD
              [ADB]=[ADB2]
              Gosub EXTR_ADB
            Next ADB2
          Endif
        Endif
        Filter [ADB]
    Endif
Return

$EXTR_ADB
  #VPO 13/12/07 BUG44457 on n'extrait que les fichiers htm pour la trad
  #VPO 06/10/08 on extrait pour trad les fichiers traduisibles
  [L]A_EXTRAIRE = 0 : NB_TOT_FIL+=1

  Call CONTROLE_VALIDITE_FIL(A_EXTRAIRE)
  If [L]A_EXTRAIRE
    [ADB]LAN=[ADO]LAN
    Gosub EXTR_FIL_WRITE
  Endif
Return

$EXTR_FIL_WRITE
     NB_FIL+=1
     Call ECR_TRACE("    "+"* ADB"+":"+[ADB]LAN+"~"+[ADB]TYP+"~"+[ADB]COD+"~"+num$([ADB]LEV)+"~"+num$([ADB]SUBLEV)+"~"+num$([ADB]LIG),0) From GESECRAN
     CLEFIC=[ADB]COD+"_"+[ADB]LAN+"_"+[ADB]TYP+"_"+num$([ADB]LEV)+"_"+num$([ADB]SUBLEV)+"_"+num$([ADB]LIG)
     LENFIC="_"+num$(len(CLEFIC))
     Raz NAMFIC

     If [ADB]NAM=""
        NAMFIC="IMG"+format$("N0:3",[ADB]LIG)+LENFIC+".jpg"
     Else
        If [ADB]TYP="AD" and pat([ADB]NAM,"*_d.htm")<>0
            NAMFIC=left$([ADB]NAM,instr(1,[ADB]NAM,"_d")-1)+"$"+LENFIC+".htm"
        Else
            Call COUPEFIC([ADB]NAM,DEBFIC,FINFIC)
            NAMFIC=DEBFIC+LENFIC+FINFIC
        Endif
    Endif

    FICOUV = REPERT_DOC + SLASH + "FILE" + SLASH + CLEFIC + "_" + NAMFIC

    Gosub TEST_SOUS_REPERT From AGENDOCA
    Call ECR_TRACE("|"+"      "+mess(72,176,1)-FICOUV,0) From GESECRAN

    Openo FICOUV,0 Using [BLO]
    Putseq 1,[ADB]PICTUR Using [BLO]
    Openo Using [BLO]
Return

######################################################################################
$GRISAGE_EXTRACTION
   If [M]CHOICE < 2
      Grizo [M]LANREF
   Else
      Actzo [M]LANREF
   Endif

   Gosub GRISAGE_ENLANREF
Return

$GRISAGE_VALDOC
   If [M]CHOICE < 2
      Actzo [M]VALDOC
   Else
      [M]VALDOC=1
      Grizo [M]VALDOC
   Endif
   Affzo [M]VALDOC
Return

$GRISAGE_MODULE
   If [M]ALLMOD = 2
      Grizo [M]MODULE
      Actzo [M]EXCMOD
   Else
      Actzo [M]MODULE
      Effzo [M]EXCMOD
      Effzo [M]MODTOEXC
      Grizo [M]EXCMOD
      Grizo [M]MODTOEXC
   Endif
Return

$GRISAGE_EXCLUSION
   If [M]EXCMOD = 2
      Actzo [M]MODTOEXC
   Else
      Grizo [M]MODTOEXC
   Endif
   Affzo [M]MODTOEXC
Return

$GRISAGE_ALLLAN
   If [M]CHOICE > 1
      [M]ALLLAN = 1
      Grizo [M]ALLLAN
   Else
      Actzo [M]ALLLAN
   Endif
   Affzo [M]ALLLAN
   Gosub GRISAGE_LAN
Return

$GRISAGE_ALLACV
   If [M]ALLACV>1
      [M]ACV = ""   : Grizo [M]ACV
   Else
      Actzo [M]ACV
   Endif
   Affzo [M]ACV
Return

$GRISAGE_LAN
  If [M]ALLLAN=2
     [M]LAN = "" : Affzo [M]LAN : Grizo [M]LAN
  Else
     Actzo [M]LAN
  Endif
  Affzo [M]LAN
Return

$GRISAGE_ENLANREF
   If [M]CHOICE > 1 or [M]ALLLAN = 2
      [M]ENLANREF = 1
      Grizo [M]ENLANREF
   Else
      Actzo [M]ENLANREF
   Endif
   Affzo [M]ENLANREF
Return

$ERREUR_MEME_LANGUE
   # Pour extraire en vue d'une traduction, les langues de traduction et de référence doivent être différentes
   GERR = 1 : GMESSAGE = mess(53,176,1) : SAI=1 : [S]mkstat=2
Return

$FORCAGE_FICHIERS_LIES
   If [M]CODDEB<>"" or ([M]CODFIN<>"" & [M]CODFIN<>"X")
      [M]HLPLNKFLD=2 : Affzo HLPLNKFLD
   Endif
Return

$FORCAGE_FLD
   If [M]FLDDEB<>"" or ([M]FLDFIN<>"" & [M]FLDFIN<>"X")
      [M]HLPFLD=2 : Affzo [M]HLPFLD
      Call C_HLPFLD([M]HLPFLD)
   Endif
Return

######################################################################################
Subprog COUPEFIC(FICHIER,DEBFIC,FINFIC)
Value    Char    FICHIER()
Variable Char    DEBFIC()
Variable Char    FINFIC()

Raz DEBFIC,FINFIC
If FICHIER="" : End : Endif

Local Integer J
Local Char    CHAINE(250)

J=len(FICHIER)
While J>0
 CHAINE = mid$(FICHIER,J,1)
 If CHAINE="."
    DEBFIC=left$(FICHIER,J-1)
    FINFIC=right$(FICHIER,J)
    Break
 Endif
 J-=1
Wend
If J=0 : DEBFIC=FICHIER : Endif
End


######################################################################################
## ETIQUETTES DU MASQUE
######################################################################################
Subprog AS_CHOICE(VALEUR)
Variable Integer VALEUR
   # En Modele = Traitement standard : Grisage/Degrisage des zones sur : Action sur champs d'un champs saisi uniquement et pas dans INIT
   Gosub GRISAGE_EXTRACTION
   Gosub GRISAGE_ALLLAN
   Gosub GRISAGE_ALLACV
   Gosub GRISAGE_MODULE
   Gosub GRISAGE_EXCLUSION
   Gosub FORCAGE_FICHIERS_LIES
End

Subprog AM_CHOICE(VALEUR)
Variable Integer VALEUR
   # On extrait pas la langue de référence si "Extraction pour Traduction" (2) ou "Exctraction pour (re)traduction" (3)
   [M]CHOICE=VALEUR
   Gosub GRISAGE_EXTRACTION
   Gosub GRISAGE_VALDOC
   Gosub GRISAGE_ALLLAN
   Gosub GRISAGE_ENLANREF
   If [M]CHOICE=2
      [M]HLPFIL=2 : Affzo [M]HLPFIL
   Endif
End

Subprog C_CHOICE(VALEUR)
Variable Integer VALEUR
    If VALEUR > 1 & [M:DIA]LAN=[M:DIA]LANREF
        #Gosub ERREUR_MEME_LANGUE
        [M:DIA]LAN="ENG" : Affzo [M:DIA]LAN
        GERR = 2 : GMESSAGE = mess(53,176,1)
    Endif
End

Subprog C_ENLANREF(VALEUR)
Variable Integer VALEUR
    If VALEUR = 2 & ([M:DIA]CHOICE = 3 or [M:DIA]CHOICE = 2 or [M:DIA]LAN = [M:DIA]LANREF)
       VALEUR = 1 : Affzo [M:DIA]ENLANREF
    Endif
End


######################################################################################
Subprog C_REPERT(VALEUR)
Variable Char    VALEUR()
   If VALEUR=""
      GMESSAGE = mess(09,141,1) : # Repertoire inexistant
      mkstat = 1 : End
   Elsif left$(VALEUR,1)="#" & (GBROWS | GSERVEUR )
      GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
      mkstat = 2 : End
   Elsif len(VALEUR) > 150
      GMESSAGE = func AFNC.MES(mess(115,75,1),num$(150)) : # Valeur trop grande (maximum #)
      mkstat = 2 : End
   Endif

   #JPGA 09/04/2010 BUG-51883 controle pour savoir si le répertoire est accessible ou nom par creation d'un fichier qui est supprimé ensuite.
   Local Integer DOC_CODERET
   Call CONTROLE_REPERTOIRE(VALEUR, [M]LAN, [L]DOC_CODERET, 1) From AGENLIBA
   If [L]DOC_CODERET
      GMESSAGE = "|"+VALEUR+"|\"+mess(203,139,1) : mkstat = 2 : End
   Endif
End

