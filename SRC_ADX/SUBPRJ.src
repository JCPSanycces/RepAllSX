#<AdxTL>@(#)2.0.0.0 $Revision$
#--------------------------------------------------------------------------
#                       Budgets Opérationnels
#--------------------------------------------------------------------------
#   Objet    : PRJ
#   Fonction : GESPRJ - Entité
#   Action   : GOBJET
#   Ecran concerné : PRJ0, PRJ1, PRJ2, PRJ3
#   Description : Définition de projet pour les budgets opérationnels
#
#--------------------------------------------------------------------------

Raz GPILOBJ
Call OBJET("PRJ",GBIDC1,GBIDC2) From GOBJET
End
##############################################################################
########### Gestion des dépenses - Gestion des Projets - 08-02-2008  #########
##############################################################################

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "SETBOUT"     : Gosub SETBOUT
 When "RAZDUP"      : Gosub RAZDUP
 When "RAZCRE"      : Gosub RAZCRE
 When "INICRE"      : Gosub INICRE
 When "CREATION"    : Gosub CREATION
 When "APRES_CRE"   : Gosub APRES_CRE
 When "MODIF"       : Gosub MODIF
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "ANNULE"      : Gosub ANNULE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "ABANDON"     : Gosub ABANDON
 When Default
Endcase
Return

$ABANDON
Actzo [M:PRJ0]PRJ
Return

$OUVRE
#-Tables
If !clalev([F:PJL]) : Local File PRJLOT    [PJL] : Endif
If !clalev([F:PJF]) : Local File PRJFAS    [PJF] : Endif
If !clalev([F:CPY]) : Local File COMPANY   [CPY] : Endif
If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif
If !clalev([F:AGC]) : Local File AGRPCPY   [AGC] : Endif
If !clalev([F:AGF]) : Local File AGRPFCY   [AGF] : Endif
If !clalev([F:FGR]) : Local File FACGROUP  [FGR] : Endif
If !clalev([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
If !clalev([F:ANM]) : Local File ACODNUM   [ANM] : Endif
If !clalev([F:ENV]) : Local File ENVELOPPE [ENV] : Endif
If !clalev([F:GCM]) : Local File GACM      [GCM] : Endif
If !clalev([F:LED]) : Local File GLED      [LED] : Endif

#-Variables
Local Integer I,STAT
If dim(GSLTOFFTYP)<=0 : Global Integer GSLTOFFTYP : Endif : # Type de document office autorisé
Local Integer INDENV, INDENT, INDCCE3
Return

$LIENS
[M:PRJ0]=[F:PRJ]
[M:PRJ1]=[F:PRJ]
#-Chargement du tableau des financeurs
I=0
While [F:PRJ]BPRFIN(I)<>"" & I<dim([F:PRJ]BPRFIN)
 [M:PRJ1]BPRFIN(I) = [F:PRJ]BPRFIN(I)
 [M:PRJ1]AMTFIN(I) = [F:PRJ]AMTFIN(I)
 [M:PRJ1]NBFIN+=1
 I+=1
Wend
#-Chargement des montants prévisonnels par période
I=0
While [F:PRJ]AMTPRV(I)<>0 & I<dim([F:PRJ]AMTPRV)
 [M:PRJ1]PERSTR(I) = [F:PRJ]PERSTR(I)
 [M:PRJ1]PEREND(I) = [F:PRJ]PEREND(I)
 [M:PRJ1]AMTPRV(I) = [F:PRJ]AMTPRV(I)
 [M:PRJ1]NBPRV+=1
 I+=1
Wend
#-Chargement des lots
I=0
For [PJL]PJL0 Where PRJ=[F:PRJ]PRJ
 [M:PRJ2]LOT(I)    = [F:PJL]LOT
 [M:PRJ2]DESLOT(I) = [F:PJL]DESLOT
 [M:PRJ2]FASGRP(I) = [F:PJL]FASGRP :# le type de donnée sera à revoir
 [M:PRJ2]ACTDAT(I) = [F:PJL]ACTDAT
 [M:PRJ2]AMTLOT(I) = [F:PJL]AMTLOT
 [M:PRJ2]CURLOT(I) = [F:PJL]CURLOT
 [M:PRJ2]FINMOD(I) = [F:PJL]FINMOD
 [M:PRJ2]FCY(I)    = [F:PJL]FCY
 [M:PRJ2]NBLOT+=1
 I+=1
Next
#Chargement des biens comptables
For [PJF]PJF0 Where PRJ=[F:PRJ]PRJ
 [M:PRJ3]FAS([F:PJF]LIG-1)       = [F:PJF]FAS
 [M:PRJ3]AMTSALPRV([F:PJF]LIG-1) = [F:PJF]AMTSALPRV
 [M:PRJ3]LOTFAS([F:PJF]LIG-1)    = [F:PJF]LOTFAS
 [M:PRJ3]NBFAS+=1
Next
#Chargement de l'intitulé du niveau de définition (groupe/société/site)
If [F:PRJ]GCF<>""
 Read [AGF]AGF0 = [F:PRJ]GCF
 If !fstat
  [M:PRJ1]INTGCF=[F:AGF]DES
 Else
  Read [FCY]FCY0 = [F:PRJ]GCF
  If !fstat
   [M:PRJ1]INTGCF=[F:FCY]FCYNAM
  Endif
 Endif
#Chargement des textes traduisibles (intitulés)
Call LECTEXTRA([M:PRJ0]DESTRA,"PROJET","DESTRA",[M:PRJ0]PRJ,"") From ATEXTRA
Call LECTEXTRA([M:PRJ1]SHOTRA,"PROJET","SHOTRA",[M:PRJ0]PRJ,"") From ATEXTRA
Endif

# Onglet biens cpt
Call AP_AIM([F:PRJ]AIM)

# Société/Site
#Call C_GCF([F:PRJ]GCF)
Read [AGF]AGF0 = [F:PRJ]GCF
If fstat=5
 Read [FCY]FCY0 = [F:PRJ]GCF
 If fstat<>5   # Site
  [M:PRJ1]SITE    = [F:FCY]FCY
  [M:PRJ1]SOCIETE = [F:FCY]LEGCPY
 Endif
Elsif !fstat
 If [F:AGF]FLGCPY=2
  If [F:AGF]FLGLEG=2
   # Sociéte juridique
   Call LECTURE("CPY",[F:PRJ]GCF,"") From CONTOBJ
   [M:PRJ1]SOCIETE = [F:CPY]CPY
   If [F:CPY]MAIFCY<>""
    [M:PRJ1]SITE    = [F:CPY]MAIFCY
   Endif
  Else
   # Groupe de sociétés
   Filter [AGC] Where GRP=[F:AGF]GRP
   Read [AGC] First
   If !fstat
    Call LECTURE("CPY",[F:AGC]CPY,"") From CONTOBJ
    [M:PRJ1]SOCIETE = [F:CPY]CPY
    [M:PRJ1]SITE    = [F:CPY]MAIFCY
   Endif
   Filter [AGC]
  Endif
 Else
  # Groupe de sites
  Filter [FGR] Where CPY=[F:AGF]GRP
  Read [FGR] First
  If !fstat
   Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
   [M:PRJ1]SOCIETE = [F:FCY]LEGCPY
   [M:PRJ1]SITE    = [F:FCY]FCY
  Endif
  Filter [FGR]
 Endif
Endif

#Si projet utilisé dans les enveloppes, on ne peut pas modifier le groupe
Actzo [M:PRJ1]GCF
For [ENV]ENV0
 If [F:ENV]PRJ=[F:PRJ]PRJ
  Grizo [M:PRJ1]GCF : Break
 Endif
Next

#Si le compteur du Site/Groupe saisi contient le code société, on a plus le droit d'en changer.
[M:PRJ1]GCF=[F:PRJ]GCF
Gosub RECUP_CODNUM
If PRJCPT<>""
 Call LECTURE("ANM",PRJCPT,"") From CONTOBJ
 If [F:ANM]POSTYP=6
  Grizo [M:PRJ1]GCF
 Endif
Endif

Local Integer LRET_VALUE
Call LEC_CPY([M:PRJ1]SOCIETE) From CPTLEC
LRET_VALUE=func AOFFDOC.OFFICE_DOC("PRJ", "PROJET", "PROJET", [M:PRJ0]PRJ, isomess, [M:PRJ1]SOCIETE, [F:CPY]LEG, "GDD")
Return

$SETBOUT
If !clalev([F:ENV]) : Local File ENVELOPPE [ENV] : Endif
If !clalev([F:BUD]) : Local File BUD       [BUD] : Endif
Local Integer OKSIT
OKSIT=0
Filter [ENV] Where PRJ=[F:PRJ]PRJ
For [ENV]ENV0
 Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
 Filter [BUD] Where evalue('CCE'+num$(INDENV))=[F:ENV]ENV
  Look [BUD] First
  If !fstat
   OKSIT=1 : Break
  Endif
 Filter [BUD]
Next
Filter [ENV]
If OKSIT
 CHMEN+="1"
Endif
Return

$RAZDUP
$RAZCRE
Actzo [M:PRJ1]GCF
Affzo [M:PRJ1]GCF
Return

$RECUP_CODNUM
Local Char NUMPRJ
Local Char PRJCPT(GLONANM) : PRJCPT = "" : # Compteur Projets
Local Char SOC(GLONCPY)
Local Integer TYP

#Determination du type groupe ou soc ou sit utilisé dans le projet pour trouver le compteur correspondant ou le général si groupe
Call GETGCFTYP([M:PRJ1]GCF,TYP)
Case TYP
 When 1,2 : SOC=""
 When 3,4 : SOC=[M:PRJ1]SOCIETE
Endcase

Read [TCA]TCA0 = 2;SOC
If !fstat
 PRJCPT = [F:TCA]CODNUM(8)
Else
 If SOC<>""
  Read [TCA]TCA0 = 2;""
  If !fstat
   PRJCPT = [F:TCA]CODNUM(8)
  Endif
 Endif
Endif
Return

$INICRE
## Gestion du numéro/code de projet ([M]PRJ)
Gosub RECUP_CODNUM

If PRJCPT=""
 #Call NUMERO("PRJ","",date$,"",[L]NUMPRJ,STAT) From SUBANM
 #Problème lors de la récupération du compteur
 GERR=1 : GMESSAGE = mess(60,199,1) : GOK=0 : Return
Else
 Call LECTURE("ANM",PRJCPT,"") From CONTOBJ
 If [F:ANM]LNG>GLONPRJ
  #La longueur du compteur affecté à la société est incompatible avec les projets
  GMESSAGE=mess(215,108,1)
  GOK=0 : Return
 Endif
 Call NUMERO(PRJCPT,[M]SITE,date$,"",[L]NUMPRJ,STAT) From SUBANM
Endif

If GOK<0 : Return : Endif
If STAT =0
 [F:PRJ]PRJ  = [L]NUMPRJ
 [M:PRJ0]PRJ = [L]NUMPRJ
 Affzo [M:PRJ0]PRJ
Else
 Gosub MESSAGE From SUBANM
 #Erreur sur compteur
 GMESSAGE=mess(104,117,1)-"("+PRJCPT+") : "-MESSA
 GOK = 0 : Return
Endif
Return

$CREATION
Gosub SAVPRJLOT
Gosub SAVPRJFAS
Gosub TEXTRA
Return

$APRES_CRE
Grizo [M:PRJ1]GCF
Affzo [M:PRJ1]GCF
Return

$MODIF
Gosub DELTABS
Gosub CREATION
Gosub TEXTRA
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("PROJET","DESTRA",CLECUR1,"","PROJET","DESTRA",[M:PRJ0]PRJ,"")  From ATEXTRA
 Call DUPTEXTRA("PROJET","SHOTRA",CLECUR1,"","PROJET","SHOTRA",[M:PRJ0]PRJ,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M:PRJ0]DESTRA,"PROJET","DESTRA",[M:PRJ0]PRJ,"") From ATEXTRA
Call MAJTEXTRA([M:PRJ1]SHOTRA,"PROJET","SHOTRA",[M:PRJ0]PRJ,"") From ATEXTRA
Return

$AP_CHANGE
Call CHGTEXTRA("PROJET","DESTRA",[M:PRJ0]PRJ,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("PROJET","SHOTRA",[M:PRJ0]PRJ,"",NCODE,"") From ATEXTRA
Return

$SAVPRJLOT
#Ecriture de la table des Lots
For nolign=1 To [M:PRJ2]NBLOT
 Raz [F:PJL]
 [F:PJL]PRJ    = [M:PRJ0]PRJ
 [F:PJL]LOT    = [M:PRJ2]LOT(nolign-1)
 [F:PJL]DESLOT = [M:PRJ2]DESLOT(nolign-1)
 [F:PJL]FASGRP = [M:PRJ2]FASGRP(nolign-1)
 [F:PJL]ACTDAT = [M:PRJ2]ACTDAT(nolign-1)
 [F:PJL]AMTLOT = [M:PRJ2]AMTLOT(nolign-1)
 [F:PJL]CURLOT = [M:PRJ2]CURLOT(nolign-1)
 [F:PJL]FINMOD = [M:PRJ2]FINMOD(nolign-1)
 [F:PJL]FCY    = [M:PRJ2]FCY(nolign-1)
 Write [PJL]
 If fstat
  GOK=0 : Call FSTA("PJL") From GLOCK : Break
 Endif
Next nolign
Return

$SAVPRJFAS
#Ecriture de la table des Biens Comptables
For nolign=1 To [M:PRJ3]NBFAS
 Raz [F:PJF]
 [F:PJF]PRJ = [M:PRJ0]PRJ
 [F:PJF]LIG = nolign
 [F:PJF]FAS = [M:PRJ3]FAS(nolign-1)
 [F:PJF]AMTSALPRV = [M:PRJ3]AMTSALPRV(nolign-1)
 [F:PJF]LOTFAS    = [M:PRJ3]LOTFAS(nolign-1)
 Write [PJF]
 If fstat
  GOK=0 : Call FSTA("PJF") From GLOCK : Break
 Endif
Next nolign
Return

$ANNULE
Gosub DELTABS
# Suppression du document office
Call SUPBLOB("PRJ",[M:PRJ0]PRJ,"","") From SUBAON
# Annulation des Textes Traduisibles
Call SUPTEXTRA("PROJET","DESTRA",[M:PRJ0]PRJ,"") From ATEXTRA
Call SUPTEXTRA("PROJET","SHOTRA",[M:PRJ0]PRJ,"") From ATEXTRA
Return

$DELTABS
#-Suppression des tables PRJLOT & PRJFAS
Delete [PJL] Where PRJ=[M:PRJ0]PRJ
If fstat=1
 GOK=-1 : GLOCK="$PRJLOT"-[M:PRJ0]PRJ : Return
Endif
Delete [PJF] Where PRJ=[M:PRJ0]PRJ
If fstat=1
 GOK=-1 : GLOCK="$PRJFAS"-[M:PRJ0]PRJ : Return
Endif
Return

$SEL_TABLE
Case TABLE
 When "SELPRJ"
  If !clalev([F:PRJ]) : Local File PROJET  [PRJ] : Endif
  Default File [PRJ]
  OBJET = "PRJ"
  If PARAM(1)<>""
   If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif
   If !clalev([F:AGC]) : Local File AGRPCPY   [AGC] : Endif
   If !clalev([F:FGR]) : Local File FACGROUP  [FGR] : Endif
   Local Integer NBRFCY, NBRFCYGRP, NBRCPYGRP

   Filter [FCY] Where LEGCPY=PARAM(1)
   NBRFCY = rowcount([FCY])
   Filter [FCY]
   If !NBRFCY : NBRFCY = 1 : Endif

   Filter [AGC] Where CPY=PARAM(1)
   NBRGRPCPY = rowcount([AGC])
   Filter [AGC]
   If !NBRGRPCPY : NBRGRPCPY = 1 : Endif

   Link [FGR] With [FCY]FCY0=[F:FGR]FCY
&  As [LFGR]
&  Where [FGR]CPY=PARAM(1) | [FCY]LEGCPY=PARAM(1)
   NBRGRPFCY = rowcount([LFGR])
   If !NBRGRPFCY : NBRGRPFCY = 1 : Endif

   Local Char FCYLST(GLONFCY)(1..NBRFCY)
   Local Char GRPFCYLST(GLONAGF)(1..NBRGRPFCY)
   Local Char GRPCPYLST(GLONAFC)(1..NBRGRPCPY)

   NBRFCY=0 : NBRGRPFCY=0 : NBRGRPCPY=0

   For [FCY]FCY0 Where LEGCPY=PARAM(1)
    NBRFCY+=1
    FCYLST(NBRFCY)=[F:FCY]FCY
   Next

   For [AGC]AGC0 Where CPY=PARAM(1)
    NBRGRPCPY+=1
    GRPCPYLST(NBRGRPCPY)=[F:AGC]GRP
   Next

   For [FGR]FGR0
    If find([F:FGR]FCY,FCYLST(1..NBRFCY)) | [F:FGR]CPY=PARAM(1)
     NBRGRPFCY+=1
     GRPFCYLST(NBRGRPFCY)=[F:FGR]CPY
    Endif
   Next

   Local Integer LENCRIT
   CRITERE = "1=1"
   #####
   If GFONCTION<>"GESENV" & GFONCTION<>"GESPRJ"
    #Les projets ne comportant aucune enveloppe rattachée ne doivent pas être présentés
    If !clalev([F:ENV]) : Local File ENVELOPPE [ENV] : Endif
    Global Integer NBRACTPRJ : NBRACTPRJ=1
    Global Char LSTACTPRJ(GLONPRJ)(1..max(1,nbrecord([PRJ]))),RES(250)
    NBRACTPRJ=0
    #
    Local Char CRTIENV(250)
    CRITENV='PRJ<>""'
    #
    If PARAM(2)<>"" & PARAM(3)<>""
     Local Date DSTR,DEND
     If instr(1,PARAM(2),"/"):DSTR=evalue("["+PARAM(2)+"]"):Elsif PARAM(2)<>"":DSTR=PARAM(2):Endif
     If instr(1,PARAM(3),"/"):DEND=evalue("["+PARAM(3)+"]"):Elsif PARAM(3)<>"":DEND=PARAM(3):Endif
    Endif
    #
    Case GFONCTION
     When "CCLEXTBUD"
      CRITENV -= '& EXTBUD=2 & AMTENV<>0 & REVDAT<>[0/0/0]'
      If PARAM(2)<>"" & PARAM(3)<>""
       CRITENV -='& REASTR<=['+format$(GFMD,DEND)+'] & REAEND>=['+format$(GFMD,DSTR)+']'
      Endif
     When "CONSGDD"
      If PARAM(2)<>"" & PARAM(3)<>""
       CRITENV -='& REASTR<=['+format$(GFMD,DEND)+'] & REAEND>=['+format$(GFMD,DSTR)+']'
      Endif
    Endcase
    #
    Filter [ENV] Where evalue(CRITENV)
    For [ENV]ENV0
     If !find([F:ENV]PRJ,LSTACTPRJ(1..max(NBRACTPRJ,1)))
      NBRACTPRJ+=1
      LSTACTPRJ(NBRACTPRJ)=[F:ENV]PRJ
     Endif
    Next
    Filter [ENV]
    #
    If NBRACTPRJ
     CRITERE -='& find(PRJ,LSTACTPRJ(1..NBRACTPRJ))'
    Endif
   Endif
   #####

   CRITERE-="& ("
   LENCRIT=len(CRITERE)

   If NBRFCY
    CRITERE -= 'find(GCF,FCYLST(1..NBRFCY))'
   Endif
   If NBRGRPFCY
    If len(CRITERE)>LENCRIT
      CRITERE -= '| find(GCF,GRPFCYLST(1..NBRGRPFCY))'
    Else
     CRITERE -= 'find(GCF,GRPFCYLST(1..NBRGRPFCY))'
    Endif
   Endif
   If NBRGRPCPY
    If len(CRITERE)>LENCRIT
     CRITERE -= '| find(GCF,GRPCPYLST(1..NBRGRPCPY))'
    Else
     CRITERE -= 'find(GCF,GRPCPYLST(1..NBRGRPCPY))'
    Endif
   Endif
   CRITERE+=")"
  Endif
Endcase
Return

$SEL_LISTE
Case LISTE
 When "SELGCF"    : Gosub S_GCF     :#Selection groupe/société/site
 When "SELLOT"    : Gosub S_LOT     :#Selection lot
 When "SELFCYLOT" : Gosub S_FCYLOT  :#Selection site
Endcase
Return

$S_GCF
Local Integer DIMGRP : DIMGRP=nbrecord([F:AGF])+nbrecord([F:FCY])+1
Local Char TEX(GLONDES)(DIMGRP)
Local Char TEXTE(GLONDES)(1..DIMGRP,1..3)
TIT = mess(18,100,1)   :# Sélection
TIT(1)=mess(131,104,1) :# Site/Groupe
TIT(2)=mess(30,109,1)  :# Intitulé
TIT(3)=mess(59,100,1)  :# Type

#Groupe de société/site - sociétés
For [AGF]AGF0
 NBTEX += 1
 TEX(NBTEX)   = [F:AGF]GRP
 TEXTE(NBTEX,1) = [F:AGF]GRP
 TEXTE(NBTEX,2) = [F:AGF]DES
 If [AGF]FLGCPY=2
  If [AGF]FLGLEG =2
   #Société
   TEXTE(NBTEX,3) = mess(3,2696,1)
  Else
   #Groupe de société
   TEXTE(NBTEX,3) = mess(1,2696,1)
  Endif
 Else
  #Groupe de site
  TEXTE(NBTEX,3) = mess(2,2696,1)
 Endif
Next
#Site
For [FCY]FCY0
 NBTEX += 1
 TEX(NBTEX)   = [F:FCY]FCY
 TEXTE(NBTEX,1) = [F:FCY]FCY
 TEXTE(NBTEX,2) = [F:FCY]FCYNAM
 TEXTE(NBTEX,3) = mess(4,2696,1)
Next
Return

$S_LOT
Local Char TEXTE(GLONDES)(1..200,1..2)
TIT = mess(10,16,1) :# Choix
TIT(1)=mess(23,107,1) :# Lot
TIT(2)=mess(30,109,1) :# Intitulé
For I=0 To [M:PRJ2]NBLOT-1
 NBTEX += 1
 TEX(NBTEX)   = [M:PRJ2]LOT(I)
 TEXTE(NBTEX,1) = [M:PRJ2]LOT(I)
 TEXTE(NBTEX,2) = [M:PRJ2]DESLOT(I)
Next
Return

$S_FCYLOT
Local Char TEXTE(GLONDES)(1..200,1..2)
TIT = mess(183,195,1) :# Choix sites
TIT(1)=mess(3,45,1) :# Site
TIT(2)=mess(30,109,1) :# Intitulé
For [FGR]FGR0 Where CPY=[M:PRJ1]GCF
 Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
 NBTEX += 1
 TEX(NBTEX)   = [F:FCY]FCY
 TEXTE(NBTEX,1) = [F:FCY]FCY
 TEXTE(NBTEX,2) = [F:FCY]FCYNAM
Next
Return

#----------------------
Subprog GETGCFTYP(GRPSIT,TYP)
Value Char       GRPSIT()
Variable Integer TYP
If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif
If !clalev([F:AGF]) : Local File AGRPFCY   [AGF] : Endif
Read [AGF]AGF0 = GRPSIT
If fstat
 Read [FCY]FCY0 = GRPSIT
 If fstat
  #Groupe, société ou site inexistant
  GMESSAGE=mess(149,108,1)
  mkstat=2 : End
 Elsif !fstat
  # Site
  TYP = 4
 Endif
Elsif !fstat
 If [F:AGF]FLGCPY=2
  If [F:AGF]FLGLEG=2
   # Sociéte juridique
   TYP = 3
  Else
   # Groupe de sociétés
   TYP=1
  Endif
 Else
  # Groupe de sites
  TYP=2
 Endif
Endif
End

####################################################################
############  Etiquettes écrans PRJx 02/2008   #####################
####################################################################

#----------------#
#-Ecran [M:PRJ0]-#
#----------------#

#Subprog AS_PRJ(VALEUR)
#Variable Char    VALEUR()
#If VALEUR=""
# VALEUR="AUTO"
#Endif
#End

Subprog C_PRJ(VALEUR)
Variable Char    VALEUR()
# En création ou duplication: automatisation du numéro d'engagemment
If (GREP="" or GREP="C" or GREP="D") & VALEUR<>""
 Look [PRJ]PRJ0 = VALEUR
 If fstat
#  If VALEUR<>"AUTO"
   #Compteur automatique
   Call MESSAGE(mess(193,108,1)) From GESECRAN
   Raz [M:PRJ0]PRJ
   Affzo [M:PRJ0]PRJ
#  Endif
#  VALEUR = "AUTO"
#  [M:PRJ0]PRJ=VALEUR
 Endif
Endif
End

#----------------#
#-Ecran [M:PRJ1]-#
#----------------#

Subprog C_GCF(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Local Libelle LEDTYPGEN, LEDTYPANA
 Local Char CODLED(GLONLED), DEVLED(GLONCUR)

 Read [AGF]AGF0 = VALEUR
 If fstat=5
  Read [FCY]FCY0 = VALEUR
  If fstat=5
   #Groupe, société ou site inexistant
   GMESSAGE=mess(149,108,1)
   mkstat=2 : End
  Elsif !fstat
   # Site
   [M:PRJ1]INTGCF  = [F:FCY]FCYNAM
   [M:PRJ1]SITE    = [F:FCY]FCY
   [M:PRJ1]SOCIETE = [F:FCY]LEGCPY
   #06/10/09-Dmd54223:Autorisation site
   Call CONTFCY(VALEUR) From CPTSUB
  Endif
 Elsif !fstat
  [M:PRJ1]INTGCF=[F:AGF]DES
  If [F:AGF]FLGCPY=2
   If [F:AGF]FLGLEG=2
    # Sociéte juridique
    Call LECTURE("CPY",VALEUR,"") From CONTOBJ
    [M:PRJ1]SOCIETE = [F:CPY]CPY
    If [F:CPY]MAIFCY=""
     #La société saisie ne comporte pas de site principal
     GMESSAGE=mess(214,108,1)
     mkstat = 2 : End
    Else
     [M:PRJ1]SITE    = [F:CPY]MAIFCY
    Endif
    Call CONTCPY(VALEUR) From CPTSUB
   Else
    # Groupe de sociétés
    Filter [AGC] Where GRP=[F:AGF]GRP
    #Contrôle cohérence des devises
    Local Char OLDCUR(GLONCUR)
    OLDCUR=""
    For [AGC]AGC0
     Call LECTURE("CPY",[F:AGC]CPY,"") From CONTOBJ
     Call SETMAINREF([F:AGC]CPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
     Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
     If [F:GCM]CUR(LEDTYPANA-1)<>OLDCUR & OLDCUR<>""
      #Les sociétés de ce groupe ne sont pas gérées dans la même devise
      GMESSAGE=mess(211,108,1)
      mkstat = 2  : Break
     Else
      OLDCUR=""
      OLDCUR=[F:GCM]CUR(LEDTYPANA-1)
     Endif
    Next
    If mkstat=2 : End : Endif
    Read [AGC] First
    If !fstat
     Call LECTURE("CPY",[F:AGC]CPY,"") From CONTOBJ
     [M:PRJ1]SOCIETE = [F:CPY]CPY
     [M:PRJ1]SITE    = [F:CPY]MAIFCY
    Endif
    Filter [AGC]
    #06/10/09-Dmd54223:Autorisation site
    Call CONTALLCPY(VALEUR) From CPTSUB
   Endif
  Else
   # Groupe de sites
   Filter [FGR] Where CPY=[F:AGF]GRP
   #Contrôle cohérence des devises
   Local Char OLDCUR(GLONCUR)
   OLDCUR=""
   For [FGR]FGR0
    Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    Call SETMAINREF([F:CPY]CPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
    Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
    If [F:GCM]CUR(LEDTYPANA-1)<>OLDCUR & OLDCUR<>""
     #Les sociétés de ce groupe ne sont pas gérées dans la même devise
     GMESSAGE=mess(211,108,1)
     mkstat=2  : Break
    Else
     OLDCUR=""
     OLDCUR=[F:GCM]CUR(LEDTYPANA-1)
    Endif
   Next
   If mkstat=2 : End : Endif
   Read [FGR] First
   If !fstat
    Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
    [M:PRJ1]SOCIETE = [F:FCY]LEGCPY
    [M:PRJ1]SITE    = [F:FCY]FCY
   Endif
   Filter [FGR]
  Endif
 Endif

 Call LECTURE("CPY",[M:PRJ1]SOCIETE,"") From CONTOBJ
 Call SETMAINREF([M:PRJ1]SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV
 Call LECLED([M:PRJ1]SOCIETE,LEDTYPANA,CODLED,DEVLED) From CPTDIV
 Call LECTURE("LED",CODLED,"") From CONTOBJ
 If [F:LED]GDD<>2
  #Seules sont autorisées les sociétés/sites dont le référentiel analytique principal est flagué Budget opérationnels
  GMESSAGE = mess(114,108,1)
  mkstat=2 : End
 Endif
 Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
 If [M:PRJ1]CUR<>"" & [F:GCM]CUR(LEDTYPANA-1)<>[M:PRJ1]CUR
  #Devise du projet incompatible avec la devise du référentiel analytique principal du groupe renseigné.
  #La devise du projet devient celle du référentiel analytique principal du groupe.
  Call MESSAGE(mess(209,108,1)-chr$(10)-mess(210,108,1)) From GESECRAN
  [M:PRJ1]CUR=[F:GCM]CUR(LEDTYPANA-1)
 Else
  [M:PRJ1]CUR=[F:GCM]CUR(LEDTYPANA-1)
 Endif
 Affzo [M:PRJ1]CUR
Endif
End

Subprog C_REASTR(VALEUR)
Variable Date    VALEUR
If ([M]STUEND<>[0/0/0] & VALEUR<[M]STUEND) | ([M]STUSTR<>[0/0/0] & VALEUR<[M]STUSTR)
 # La période d'étude du projet doit être antérieure à sa période de réalisation
 GMESSAGE = mess(247,108,1)
 mkstat = 2 : End
Endif
End

Subprog C_AMTEVAL(VALEUR)
Variable Decimal VALEUR
Local Decimal I,SOMAMT
For I=0 To [M:PRJ2]NBLOT-1
 SOMAMT += [M:PRJ2]AMTLOT(I)
Next
If SOMAMT>VALEUR
 #La somme des montants des lots dépasse le montant estimé du projet
 GMESSAGE=mess(107,108,1)
 mkstat=2 : End
Endif
End

Subprog C_CUR(VALEUR)
Variable Char    VALEUR()
 Local Libelle LEDTYPGEN, LEDTYPANA
 Local Char CODLED(GLONLED), DEVLED(GLONCUR)
 Call LECTURE("CPY",[M:PRJ1]SOCIETE,"") From CONTOBJ
 Call SETMAINREF([M:PRJ1]SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV
 Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
 If VALEUR<>"" & [F:GCM]CUR(LEDTYPANA-1)<>VALEUR
  #Devise du projet incompatible avec la devise du référentiel analytique principal du groupe renseigné.
  #La devise du projet devient celle du référentiel analytique principal du groupe.
  Call MESSAGE(mess(209,108,1)-chr$(10)-mess(210,108,1)) From GESECRAN
  [M:PRJ1]CUR=[F:GCM]CUR(LEDTYPANA-1)
  Affzo [M:PRJ1]CUR
 Endif
End

Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]LOT) From OBJDIV
End

Subprog C_FAS(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]FAS) From OBJDIV
End

Subprog AP_AIM(VALEUR)
Variable Char    VALEUR()
If !clalev([ADI]) : Local File ATABDIV [ADI] : Endif
Read [ADI]CODE = 347;VALEUR
If !fstat
 If [F:ADI]N1<>2 : Grizo [M:PRJ3] : Else : Actzo [M:PRJ3] : Endif
Endif
End

#----------------#
#-Ecran [M:PRJ2]-#
#----------------#

Subprog C_AMTLOT(VALEUR)
Variable Decimal VALEUR
Local Integer I
Local Decimal SOMAMT
SOMAMT=0
For I=0 To nolign-2
 SOMAMT += [M:PRJ2]AMTLOT(I)
Next
For I=nolign To [M:PRJ2]NBLOT-1
 SOMAMT += [M:PRJ2]AMTLOT(I)
Next
SOMAMT+=VALEUR
If SOMAMT>[M:PRJ1]AMTEVAL
 #La somme des montants des lots dépasse le montant estimé du projet
 GMESSAGE=mess(107,108,1)
 mkstat=2
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If VALEUR<>[M:PRJ1]GCF
  Read [FGR]FGR0 = [M:PRJ1]GCF;VALEUR
  If fstat=5
   #Le site saisi ne fait pas partie des sites rattachés au projet
   GMESSAGE=mess(158,108,1)
   mkstat=2 : End
  Endif
 Endif
Endif
End

#----------------#
#-Ecran [M:PRJ3]-#
#----------------#

Subprog C_LOTFAS(VALEUR)
Variable Char VALEUR
If VALEUR<>"" & !find(VALEUR,[M:PRJ2]LOT(0..[M:PRJ2]NBLOT-1))
 #Lot indéfini
 GMESSAGE=mess(108,108,1)
 mkstat=2
Endif
End

