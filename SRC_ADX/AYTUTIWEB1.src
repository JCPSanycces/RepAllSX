# <XT_SPE>Modify arguments</XT_SPE>
Call ACCAUS(  AXPARCOD,AXPARVAL,AXWHRLFTBRK,AXWHRCOD,AXWHROPE,AXWHRCODVAL,AXWHRRGTBRK
&                ,AXWHRANDOR,AXORDCOD,AXORDTYP
&                ,FAX,NOMUSR,TELEP,USR,NBPRT, NBADR, DEFLIB)
Call ECR_TRACE("### Dump of values - Indice max: 6" ,0) From GESECRAN
Call ECR_TRACE("###   Technical section",0) from GESECRAN
Call ECR_TRACE("AXPARCOD(1)             ="+ num$(AXPARCOD(1)) ,0) From GESECRAN
Call ECR_TRACE("AXPARCOD(2)             ="+ num$(AXPARCOD(2)) ,0) From GESECRAN
Call ECR_TRACE("AXPARCOD(3)             ="+ num$(AXPARCOD(3)) ,0) From GESECRAN
