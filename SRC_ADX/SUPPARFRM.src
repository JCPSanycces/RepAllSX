#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du masque SUPPARFRM
GBIDC2="" : GBIDC3="" : GPILCOD=""
Call OBJET("EDM",GBIDC2,GBIDC3) From GOBJET
End


$ACTION
Case ACTION
 When "INIT_DIA" : Gosub INIT_DIA
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
 When Default 
Endcase
Return


$INIT_DIA
[M]MES = PARAM(1)
[M]BAN = PARAM(2)
Return

$CONTROLE
# bug 37720
Filter [EDM] Where MES=[M]MES & BAN=[M]BAN & ([M]ALLGRP=2 | (GRP>=[M]GRPDEB & GRP<=[M]GRPFIN))
&                & OCC>=[M]OCCDEB & OCC<=[M]OCCFIN
Look [EDM]EDM0 First
Filter [EDM]
If fstat 
 GERR = 1 : GMESSAGE=mess(9,136,1)  :# Paramétrage inexistant
Endif
Return

$EXEC
Call DEBTRANS From GLOCK
Gosub SUPPR
Return

$SUPPR
Trbegin [EDM]
GOK=1
Gosub TR1
If GOK<1 : Goto AB_SUPPR : Endif
Commit
Return

$AB_SUPPR
Rollback
Return

$TR1
# bug 37723
Delete [EDM] Where MES=[M]MES & BAN=[M:DIA]BAN & ([M]ALLGRP=2 | (GRP>=[M]GRPDEB & GRP<=[M]GRPFIN))
&                & OCC>=[M]OCCDEB & OCC<=[M]OCCFIN & ORDNUM=[M:EDM1]ORDNUM & SEG=[M:EDM1]SEG
&                & SEGOCC=[M:EDM1]SEGOCC
If fstat
  GOK=0 : Call FSTA("EDM") From GLOCK
Endif
Return


Subprog C_ALLGRP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo GRPDEB,GRPFIN : Grizo GRPDEB,GRPFIN
Else
 Actzo GRPDEB,GRPFIN
Endif
End

Subprog D_GRPDEB(VALEUR)
Variable Decimal VALEUR
If [M]ALLGRP<>2
 VALEUR = [M:EDM1]GRP
Endif
End

Subprog AS_GRPDEB(VALEUR)
Variable Decimal VALEUR
If [M]ALLGRP=2 : mkstat = 1 : End : Endif
End

Subprog D_GRPFIN(VALEUR)
Variable Decimal VALEUR
If [M]ALLGRP<>2
 VALEUR = [M]GRPDEB
Endif
End

Subprog AS_GRPFIN(VALEUR)
Variable Decimal VALEUR
If [M]ALLGRP=2 : mkstat = 1 : End : Endif
If VALEUR=0 | VALEUR<[M]GRPDEB : VALEUR = [M]GRPDEB : Endif
End

Subprog C_GRPFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M]GRPDEB
  mkstat=2 : GMESSAGE = mess(83,123,1)   :# Valeur incorrecte
Endif
End

Subprog D_OCCDEB(VALEUR)
Variable Decimal VALEUR
VALEUR = [M:EDM1]OCC
End

Subprog AS_OCCDEB(VALEUR)
Variable Decimal VALEUR
End

Subprog D_OCCFIN(VALEUR)
Variable Decimal VALEUR
VALEUR = [M]OCCDEB
End

Subprog AS_OCCFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 | VALEUR<[M]OCCDEB : VALEUR = [M]OCCDEB : Endif
End

