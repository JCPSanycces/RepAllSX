#    Call AM_ENDDAY([M:ESDCG1]ENDDAY)
#    Call AM_STRDAY([M:ESDCG1]STRDAY)
#    Diszo [M:ESDCG1]ENDDAY
#    Diszo [M:ESDCG1]STRDAY
#  Else
#    Actzo [M:ESDCG1]ENDDAY
#    Actzo [M:ESDCG1]STRDAY
#  Endif
#Endif
#Affzo [M:ESDCG1]1-99

#-------------------------Hybrid----------------------------#
I_DEMCONGEESS.STRDAT = VALEUR
Call RECOVERS_ERROR_IN_CLASSIC(I_DEMCONGEESS)
If GERR = 1 Then
  I_DEMCONGEESS.STRDAT = I_DEMCONGEESS.snapshot.STRDAT
  GERR = 1
  mkstat = 2
