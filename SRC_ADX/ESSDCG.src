#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
   When "OK"          : Gosub OK
Endcase
Return



$OUVRE
#Opening tables and declaring an instance of the main class
If clalev([F:DCG])    = 0 : Local File DEMCONGE     [DCG]     : Endif
If clalev([F:HRCTR])  = 0 : Local File EMPLOCTR     [HRCTR]   : Endif
If clalev([F:ID])     = 0 : Local File EMPLOID      [ID]      : Endif

#Instantiate the DEMCONGE class
Global Instance I_DEMCONGEESS Using C_DEMCONGEESS

#Manage Localisations
Call MANAGE_LOCALISATION("ESSDCG") From DIVPAYE
Return

$DEBUT
Local Integer MY_STATUS
Local Integer USERTRCK_STAT
Local Char ATT_ID1(GLONID1)
Local Char ATT_ID2(GLONID2)

#-------------------------------Hybrid----------------------------------#

If I_DEMCONGEESS <> null Then
  FreeGroup I_DEMCONGEESS
Endif

I_DEMCONGEESS = NewInstance C_DEMCONGEESS AllocGroup null
[L]MY_STATUS = fmet I_DEMCONGEESS.AINIT()
If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_DEMCONGEESS)
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    OK = 0
    Return
  Endif
Endif


#Update User tracking - used for attachment handling in classes
[L]ATT_ID1 = "DCG"+"~"+I_DEMCONGEESS.REFNUM+"~"+num$(I_DEMCONGEESS.DEM)
[L]ATT_ID2 = num$(I_DEMCONGEESS.UID)
[L]USERTRCK_STAT = func ESS_FUNCTIONS.UPDATE_ESSURSTRK(GUSER, "EML",[L]ATT_ID1, [L]ATT_ID2, "","ESSDCG",1,I_DEMCONGEESS.REFNUM,I_DEMCONGEESS.UID,I_DEMCONGEESS.CTRNUM)

#Read the data from the class and transfer to the mask (Default Values)
#Updating addtional technical fields
[M:ESDCG1]SRNNAM  = I_DEMCONGEESS.TCH_NAMSRN
[M:ESDCG1]LEG     = I_DEMCONGEESS.TCH_LEG

#Setting GCURLEG

Gosub UPDATE_DCG1
#---------------------------------Hybrid----------------------------------#

#Updating the function icons
#[M:ESDCG1]WPEN    = "53"
#[M:ESDCG1]WHIS    = "54"

If GFONCTION = "ESSMGRDCG"
  [M:ESDCG1]CHEF = [M:ESDCG1]REFNUM
  Raz [M:ESDCG1]REFNUM
  Raz [M:ESDCG1]SRNNAM
  Raz [M:ESDCG1]LEG
Endif

Gosub SHOW_HIDE

#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSDCGHIDE
Call SHOW_LEGACTCALLS From WESSDCGSHOW

Affzo [M:ESDCG1]1-99
Return

$OK
#Invoke the creation method on the class
Local Integer MY_STATUS, STAT
Local Integer YESNO
Local Char ERRMESSAGE(250)
Local Char ATT_ID1(GLONID1)
Local Char ATT_ID2(GLONID2)

Trbegin [DCG]

[L]MY_STATUS = fmet I_DEMCONGEESS.AINSERT()
If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_DEMCONGEESS)
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(10,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    Rollback
    Return
  Endif
Endif

#Update GLM
If func AFNC.ACTIV("GLM")>0
  #Change function
  GFONCTION = "GESDCG"
  Call UPDATE_GLM(I_DEMCONGEESS.REFNUM,I_DEMCONGEESS.UID,STAT) From ESSDCG
  GFONCTION = "ESSDCG"
  If [L]STAT<> [V]CST_AOK Then #GMESSAGE controlled in GLM script
    Rollback
    #Delete created record
    GOK=0
    Return
  Endif
Endif

#Use the open instance just to trigger workflow
#In ESSDCG the UID of the record does NOT change, so the current instance of DEMCONGEESS can still be used
MY_STATUS = fmet I_DEMCONGEESS.EXEWORKFLOW_DCGMOD()
If [L]MY_STATUS <> [V]CST_AOK Then
  Rollback
  GMESSAGE= mess(12,10727,1)
  GERR=1
  GOK=0
  Return
Endif

If [L]MY_STATUS <> [V]CST_AOK Then
  Rollback
Else
  Commit
  If GMESSAGE = AVOID.ACHAR Then
    Call OUINON(mess(11,10727,1)+"."+mess(13,10727,1), [L]YESNO) From GESECRAN
  Else
     Call OUINON(mess(11,10727,1)+":"-GMESSAGE+"."+mess(13,10727,1),[L]YESNO) From GESECRAN
  Endif
Endif

If [L]YESNO = 2
  #Update User tracking - used for attachment handling in classes
  [L]ATT_ID1 = "DCG"+"~"+I_DEMCONGEESS.REFNUM+"~"+num$(I_DEMCONGEESS.DEM)
  [L]ATT_ID2 = num$(I_DEMCONGEESS.UID)
  [L]USERTRCK_STAT = func ESS_FUNCTIONS.UPDATE_ESSURSTRK(GUSER, "EML",[L]ATT_ID1, [L]ATT_ID2, "","ESSDCG",2,I_DEMCONGEESS.REFNUM,I_DEMCONGEESS.UID,I_DEMCONGEESS.CTRNUM)
Endif

Return




$SHOW_HIDE
If GFONCTION = "ESSMGRDCG"
  Actzo [M:ESDCG1]REFNUM
Else
  Diszo [M:ESDCG1]REFNUM
Endif

Return



Subprog UPDATE_GLM(PREFNUM,PUID,VSTAT)
Value Char PREFNUM
Value Integer PUID
Variable Integer VSTAT
Local Integer SOA_GOK, IS_SOA
Local Char SOALEG (GLONADI)
Local Integer VGOK # Variable set for GOK that will be used for both V6 and SOA code
Local Char CLASS_REFNUM(GLONEML)
Local Char GLM_ERRMESSAGE(250)
Local Integer UIDS_TO_INCLUDE(20)(1..)
Local Integer UIDS_COUNT : UIDS_COUNT=1
Local Char VSYSMSG(250)
Local Integer ORG_UID, L_AMLMSG, L_AML
Local Date CHECKD

L_AML = 11691 # Local menu used for all GLM messages
L_AMLMSG = 32 # Local menu number to be saved as standard for all transactions #Request validated


Read [F:DCG]DCG3 = PREFNUM;PUID
If fstat
  GMESSAGE = mess(12,10727,1)
  GERR=1
  VSTAT=1
  End
Endif

CLASS_REFNUM  = [F:DCG]REFNUM
ORG_UID       = [F:DCG]UID


#Delete future accruals
Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]CTRDAT, [F:DCG]ENDDAT, [F:DCG]TIM,IS_SOA,GCURLEG) From SUBDCGGLM

#Split the current transaction - This filter will only be used for requested records - STA=2
#Assign the split filter(s)
Gosub ASSIGN_SPLITFILTER_SPLIT_THIS_TRANSACTION From SUBDCGGLM

If [F:DCG]UID<>99999999
  Call RESET_FUTURE_SPLITS_PROG(SOA_GOK,GCURLEG,IS_SOA,UIDS_TO_INCLUDE,UIDS_COUNT) From SUBDCGGLM
   If SOA_GOK = 1
    #Handle error - stop transaction
    GMESSAGE = mess(00034,11691,1)
    GERR=1
    VSTAT=1
    End
   Endif
Endif


Call SPLIT_TRANSACTIONS_PROG(SOA_GOK,GCURLEG,IS_SOA,CLASS_REFNUM,SPLITFILTER1,SPLITFILTER2,GLM_ERRMESSAGE,[0/0/0]) From SUBDCGGLM
If SOA_GOK = 1
  #stop processing
  VSTAT=1
  End
Endif

#Resplit any possible future transactions - transaction already cleared
Call RESPLIT_TRANSACTIONS_PROG(SOA_GOK,GCURLEG,IS_SOA,CLASS_REFNUM,GLM_ERRMESSAGE,[0/0/0]) From SUBDCGGLM
If SOA_GOK = 1
  VSTAT=1
  End
Endif



End

$UPDATE_DCG1
#Load the data from the class to the screen
SetInstance [M:ESDCG1] With I_DEMCONGEESS
[M:ESDCG1]LEG = I_DEMCONGEESS.TCH_LEG
[V]GCURLEG = [M:ESDCG1]LEG


If GFONCTION = "ESSMGRDCG"
  [M:ESDCG1]SRNNAM  = I_DEMCONGEESS.TCH_NAMSRN
Endif

Affzo [M:ESDCG1]1-99
Return

Subprog RECOVERS_ERROR_IN_CLASSIC(I_DEMCONGEESS)
Variable Instance I_DEMCONGEESS Using C_DEMCONGEESS

Local Integer NI
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE
Local Integer IOPEN_TRACE

#----------Hybrid----------------------#
IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(I_DEMCONGEESS, SMESSAGE)
If IMESSAGE = [V]CST_AWARNING or IMESSAGE = [V]CST_AINFO Then
  GMESSAGE = SMESSAGE
  GERR = 2
Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
  GMESSAGE = SMESSAGE
  GOK = 0
  GERR = 1
Endif
#----------Hybrid----------------------#


# To help debug process : write a classic log file with all errors in class.
If GERR <> 0 Then
  If GTRACE = AVOID.ACHAR Then
    Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG" + GUSER) From LECFIC
    IOPEN_TRACE = [V]CST_AYES
  Endif
  Call ECR_TRACE("->", 0) From GESECRAN
  Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(I_DEMCONGEESS) From SYRSTACKTOOLS
  If IOPEN_TRACE = [V]CST_AYES Then
    Call FERME_TRACE From LECFIC
  Endif
Endif
# ----------------------------------------------------------

[L]MY_STATUS = fmet I_DEMCONGEESS.ADELETERRORALL()
End


Subprog CANCEL_REQUEST(EMP,UID)
Value    Char    EMP
Value    Char    UID
Local Integer MY_STATUS

If clalev([F:DCG2])    = 0 : Local File DEMCONGE     [DCG2]     : Endif
Read [F:DCG2]DCG3 = EMP;val(UID)
If !fstat and ([F:DCG2]STA=2 | [F:DCG2]STA=3)
  Gosub CANCEL_REQUEST_CLASSIC
  Gosub UPDATE_APPROVAL_SCREEN
  Affzo [M]1-99
Else
  If !fstat and ([F:DCG2]STA<>2 and [F:DCG2]STA<>3)
   GMESSAGE = mess(0017,10727,1)+": (" + mess(0002,10743,1) +", " + mess(0003,10743,1) + ")"
   GERR = 2
  Endif
Endif
End


$CANCEL_REQUEST_CLASSIC
Local Integer RET_UID
Trbegin [DCG2]

Local Instance I_DEMCONGEESS Using C_DEMCONGEESS
If I_DEMCONGEESS <> null Then
  FreeGroup I_DEMCONGEESS
Endif

I_DEMCONGEESS = NewInstance C_DEMCONGEESS AllocGroup null
[L]MY_STATUS = fmet I_DEMCONGEESS.AINIT()
If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_DEMCONGEESS)
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    Rollback
    End
  Endif
Endif

#Invoke the operation
MY_STATUS = fmet I_DEMCONGEESS.CANREQ(EMP,val(UID))
  If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_DEMCONGEESS)
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    Rollback
    End
  Endif
Endif

#Trigger workflow
If I_DEMCONGEESS <> null Then
  FreeGroup I_DEMCONGEESS
Endif

#Handled in the class no futher update required.
If [L]MY_STATUS <> [V]CST_AOK and [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
  Rollback
Else
  Commit
Endif



If GMESSAGE = AVOID.ACHAR Then
  GMESSAGE= mess(11,10727,1)
Else
  GMESSAGE= mess(11,10727,1)+":"-GMESSAGE
Endif
GERR = 2

Return

$CANCEL_REQUEST_GLM
Local Integer TRANSACTION_PENDING
Local Char CRITERE1(250)
Local Char VREFNUM(GLONEML) : VREFNUM = REFNUM
Local Integer DEM_NUM
Local Integer VUID : VUID = UID
Local File TIMEMP [TIP3]
#Assign values
[L]CRITERE1="REFNUM="+num$([L]EMP)-"and UID="+num$([L]UID)
TRANSACTION_PENDING = adxlog


#Get DCG in context
Local File DEMCONGE [DCG]
Read [F:DCG]DCG3 = EMP;UID
If fstat
  #Handle error and stop any further process
  GMESSAGE = mess(00081,00075,1)-":"-num$(EMP)+"~"+num$(UID)
  GERR=1
  Return
Else
  If !fstat and ([F:DCG2]STA<>2 & [F:DCG2]STA<>3)
   GMESSAGE = mess(0017,10727,1)+": (" + mess(0002,10743,1) +", " + mess(0003,10743,1) + ")"
   GERR = 2
   Return
  Endif
Endif

#Store request number
DEM_NUM = [F:DCG]DEM

If TRANSACTION_PENDING=0
  Trbegin [DCG]
Endif

#Update existing records so that the workflow does not get triggered again
Local File DEMCONGE [DCG5]
Update [DCG5] Where REFNUM=EMP & WRK>"" With WRK=""
LogicClose File [DCG5]

#Update the worfkflow records
Call MAJ_HISSUIPOR([F:DCG2]STA) From SUBDCG



Gosub DECLARE_SOA_GLM_VARIABLES From DEMCONGE_CSTD_EVT

#Create a new cancellation request record
#Only for records that is not in request state
If [F:DCG]STA <> 2
Call RESET_FUTURE_SPLITS_PROG(SOA_GOK,SOALEG,5,UIDS_TO_INCLUDE,UIDS_COUNT) From SUBDCGGLM
 If SOA_GOK =1
  #Handle error - stop transaction
  GMESSAGE = mess(00034,11691,1)
  GERR=1
  If TRANSACTION_PENDING=0
    Rollback
  Endif
  Return #Don't allow additional processing
 Endif
Endif
#[F:DCG] is now in the new record context - set appliclable variables
VUID = [F:DCG]UID

#Delete future accruals
#PEVAN - 2018-07-30 - X3-90320 - START
#Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]STRDAT, [F:DCG]TIM, IS_SOA, SOALEG) From SUBDCGGLM
Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]CTRDAT, [F:DCG]STRDAT, [F:DCG]TIM, IS_SOA, SOALEG) From SUBDCGGLM
#PEVAN - 2018-07-30 - X3-90320 - END

#Split the current transaction
#Assign the split filter(s)
Gosub ASSIGN_SPLITFILTER_SPLIT_THIS_TRANSACTION From SUBDCGGLM


If [F:DCG]UID<>99999999
  Call RESET_FUTURE_SPLITS_PROG(SOA_GOK,SOALEG,1,UIDS_TO_INCLUDE,UIDS_COUNT) From SUBDCGGLM
   If SOA_GOK =1
    #Handle error - stop transaction
    GMESSAGE = mess(00034,11691,1)
    GERR=1
    If TRANSACTION_PENDING=0
      Rollback
    Endif
    Return #Don't allow additional processing
   Endif
Endif

#Split the current transaction using the ASSIGN_SPLITFILTER_SPLIT_THIS_TRANSACTION already done
Call SPLIT_TRANSACTIONS_PROG(SOA_GOK,SOALEG,IS_SOA,CLASS_REFNUM,SPLITFILTER1,SPLITFILTER2,SOA_ERRMESSAGE,[0/0/0]) From SUBDCGGLM
If SOA_GOK <> 0
  If SOA_GOK = 1
    #stop processing
    GMESSAGE = SOA_ERRMESSAGE
    GERR=1
    If TRANSACTION_PENDING=0
      Rollback
    Endif
    Return
  Endif
Endif


#Resplit any possible future transactions - transaction already cleared
Call RESPLIT_TRANSACTIONS_PROG(SOA_GOK,SOALEG,IS_SOA,[F:DCG]REFNUM,SOA_ERRMESSAGE,[0/0/0]) From SUBDCGGLM
If SOA_GOK = 1
  GMESSAGE = SOA_ERRMESSAGE
  GERR=1
  If TRANSACTION_PENDING=0
    Rollback
  Endif
  Return
Else
  #Commit and Trigger the workflow
  Gosub UPDATE_OBSOLETE_WRKFLW
  If TRANSACTION_PENDING=0
    Commit
  Endif
 # Gosub TRIGGER_WORKFLOW
  GMESSAGE = "Cancellation request submitted"
  GERR=2
Endif

#Commit and Trigger the workflow
If SOA_GOK <> 1

Endif
Return

$TRIGGER_WORFKLOW_GLM
  Local Instance I_DEMCONGEESS Using C_DEMCONGEESS
  If I_DEMCONGEESS <> null Then
    FreeGroup I_DEMCONGEESS
  Endif

  I_DEMCONGEESS = NewInstance C_DEMCONGEESS AllocGroup null
  [L]MY_STATUS = fmet I_DEMCONGEESS.AINIT()
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(I_DEMCONGEESS)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(0009,10727,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
      Rollback
      End
    Endif
  Endif
Return

$UPDATE_OBSOLETE_WRKFLW
Local Integer J
Local File AWRKHISSUI [AWS3]

Filter [F:AWS3] Where VALCTX1 = VREFNUM and VALCTX4 = num$(VUID) Order By CHRONO Desc
For [F:AWS3]
  #If [F:AWS3]FLGSIG = 3 #Cancel even if previously signed
    [F:AWS3]FLGSIG = 1 : #Cancel workflow
    Rewrite [F:AWS3]
    If fstat : Break : Endif
  #Endif
 Next

LogicClose File [F:AWS3]
Return

$UPDATE_APPROVAL_SCREEN
If GOK

  If dim([M:ESDCGR]REFNUM)>0
    #Set the status of the line
    [M:ESDCGR]WWRK(nolign-1) = "S"
    Gosub REFRESH_DCGR
  Endif

   If dim([M:ESDCGH]REFNUM)>0
    #Set the status of the line
    [M:ESDCGH]WWRK(nolign-1) = "S"
    Gosub REFRESH_DCGH
  Endif
Endif
Return

$REFRESH_DCGR
Local Integer TOTLINE, I
##This routine is used to refresh the screen after an approval has been made to remove the record(s) from the screen

[L]TOTLINE = [M:ESDCGR]NBRLIN
[L]I = [L]TOTLINE
For nolign = 1 To TOTLINE
  If [M:ESDCGR]WWRK(nolign-1) = "S" #signed
    Dela nolign-1 [M:ESDCGR]NBRLIN
    [L]I-=1
  Endif
Next
[M:ESDCGR]NBRLIN = [L]I
Return


$REFRESH_DCGH
Local Integer TOTLINE, I
##This routine is used to refresh the screen after an approval has been made to remove the record(s) from the screen

[L]TOTLINE = [M:ESDCGH]NBRLIN
[L]I = [L]TOTLINE
For nolign = 1 To TOTLINE
  If [M:ESDCGH]WWRK(nolign-1) = "S" #signed
    Dela nolign-1 [M:ESDCGH]NBRLIN
    [L]I-=1
  Endif
Next
[M:ESDCGH]NBRLIN = [L]I
Return



Subprog CL_ICO(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
#------------------------Hybrid-------------------------#
If GFONCTION = "ESSMGRDCG" #Update TCH_EMP
  I_DEMCONGEESS.TCH_EMPSBD = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(I_DEMCONGEESS)
  If GERR = 1 Then
    I_DEMCONGEESS.TCH_EMPSBD  = I_DEMCONGEESS.snapshot.TCH_EMPSBD
    GERR = 1
    mkstat = 2
    End
  Else
    Gosub UPDATE_DCG1
  Endif
Endif
#------------------------Hybrid-------------------------#
End

Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
[M:ESDCG1]ENDDAY = 1
Call AM_ENDDAY([M:ESDCG1]ENDDAY)

[M:ESDCG1]STRDAY = 1
