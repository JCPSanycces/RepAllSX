Funprog SHIFT_MSG(VSTAT,VSTRDAT,VENDDAT,VSHIFT)
Value Integer VSTAT,VSHIFT
Value Date VSTRDAT,VENDDAT
Local Char RESULTMESSAGE(60)
If (VSTRDAT =[0/0/0] and VENDDAT =[0/0/0]) or VSTAT <> 2 : End [L]RESULTMESSAGE : Endif
Case VSHIFT
  When 1 : [L]RESULTMESSAGE = mess(0020,10727,1)-mess(0021,10727,1)-"("+format$("D:"+GFMDAT,VENDDAT)+")"
  When 2 : [L]RESULTMESSAGE = mess(0020,10727,1)-mess(0022,10727,1)-"("+format$("D:"+GFMDAT,VSTRDAT)+")"
Endcase
End [L]RESULTMESSAGE



