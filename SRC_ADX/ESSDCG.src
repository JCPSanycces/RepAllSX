Subprog AM_STRDAY(VALEUR)
Variable Integer VALEUR
If [M:ESDCG1]STRDAT = [M:ESDCG1]ENDDAT
  If VALEUR = 2
    Diszo [M:ESDCG1]ENDDAY
  Else
    Actzo [M:ESDCG1]ENDDAY
  Endif
Else
  Actzo [M:ESDCG1]ENDDAY
  Actzo [M:ESDCG1]STRDAY
Endif

Raz [M:ESDCG1]STRDAYMSG
[M:ESDCG1]STRDAYMSG = func ESSDCG.SHIFT_MSG(VALEUR,[M:ESDCG1]STRDAT,[M:ESDCG1]ENDDAT,1)

Affzo [M:ESDCG1]1-99

#--------------------Hybrid------------------------#
I_DEMCONGEESS.STRDAY = VALEUR
Call RECOVERS_ERROR_IN_CLASSIC(I_DEMCONGEESS)

If GERR = 1 Then
  I_DEMCONGEESS.STRDAY = I_DEMCONGEESS.snapshot.STRDAY
  GERR = 1
  mkstat = 2
  End
Else
  Gosub UPDATE_DCG1
Endif
#--------------------Hybrid------------------------#
End

