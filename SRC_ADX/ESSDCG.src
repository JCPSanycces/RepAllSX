End

Subprog AM_ENDDAY(VALEUR)
Variable Integer VALEUR
If [M:ESDCG1]STRDAT = [M:ESDCG1]ENDDAT
  If VALEUR = 2
    Diszo [M:ESDCG1]STRDAY
  Else
    Actzo [M:ESDCG1]STRDAY
  Endif
Else
  Actzo [M:ESDCG1]STRDAY
  Actzo [M:ESDCG1]ENDDAY
Endif

Raz [M:ESDCG1]ENDDAYMSG
[M:ESDCG1]ENDDAYMSG = func ESSDCG.SHIFT_MSG(VALEUR,[M:ESDCG1]STRDAT,[M:ESDCG1]ENDDAT,2)

Affzo [M:ESDCG1]1-99

#-------------------------Hybrid----------------------------#
I_DEMCONGEESS.ENDDAY = VALEUR
Call RECOVERS_ERROR_IN_CLASSIC(I_DEMCONGEESS)
If GERR = 1 Then
  I_DEMCONGEESS.ENDDAY = I_DEMCONGEESS.snapshot.ENDDAY
  GERR = 1
  mkstat = 2
  End
Else
  Gosub UPDATE_DCG1
Endif
#-------------------------Hybrid----------------------------#
End

