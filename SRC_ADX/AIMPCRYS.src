#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(30)(1..1) , VALEUR(10)
Raz GNBMASKOUV
Call TRAITE_CHAR(VALEUR,PARAM,"","AIMPCRYS","AIMPCRYS",4,"") From GTRAITE
End

#-------------------------------------------------------------#
$ACTION
Case ACTION
  When "EXEC"             : Gosub EXEC
Endcase
Return

#-------------------------------------------------------------#
$EXEC
Gosub TRANS_PARAM
Gosub READ_REPRESENTATION
If ERROR>0 : Return : Endif

Gosub ALOAD_REPORT_CRYSTAL From =func APREFIXTRT.GET_PREFIX_RPT+[L]WCODREP : # "WMRPT"

If [L]ETAT<>""
  Case GFONCTION
   When "AIMPCRYS"      : Gosub GO_AIMP
   When "AIMPCRYSD"   : Gosub PRINT_DIRECT
  Endcase
Endif

If GMESSAGE<>""
 Call AVERTIR(GMESSAGE) From GESECRAN
Endif
Gosub FREE_GROUP
Return

#-------------------------------------------------------------#
$FREE_GROUP
If dim(WDET)>0 and WDET<>null
 FreeGroup WDET
Endif
Return

#-------------------------------------------------------------#
$TRANS_PARAM
Local Char ETAT(GLONARP)
Local Char FONCTION(GLONAFC)
Local Char TBPAR(GLONAVB)(1..)
Local Char TBVAL(250)(1..)
Local Integer ASTATUS
Local Char ACODLNK(GLONAVC),WCODREP(GLONASW)
Local Char WCLE1(250)
Local Char WCLE2(250)
Local Char WCLE3(250)
Local Char WCLE4(250)
Local Char WCLE5(250)
Local Char WCLE6(250)
Local Char WCLE7(250)
Local Char WCLE8(250)
Local Char WCLE9(250)
Local Char WCLE10(250)
Local Char WCLE11(250)
Local Char WCLE12(250)
Local Char WCLE13(250)
Local Char WCLE14(250)
Local Char WCLE15(250)
Local Char WCLE16(250)
ACODLNK=[L]PARAM(1)
WCODREP=[L]PARAM(2)
For I=1 To 16
 If evalue("dim([L]PARAM("+num$(I+2)+"))>0")>0
  Assign '[L]WCLE'+num$(I) With evalue("[L]PARAM("+num$(I+2)+")")
 Endif
Next
Return

#-------------------------------------------------------------#
$GO_AIMP
Call  ETATN(ETAT,FONCTION,TBPAR,TBVAL) From ETAT
Return

#-------------------------------------------------------------#
$PRINT_DIRECT
Call  ETAT(ETAT,FONCTION,TBPAR,TBVAL) From ETAT
Return

#-------------------------------------------------------------#
$READ_REPRESENTATION
Local Integer   ERROR : ERROR = [V]CST_AOK
Local Integer I , J , NUMLIN
Local Char    PRGREP(30),WCODFNC(GLONAFC)
Local Char    REPNAM(20),WCODCLA(GLONACLA)
Local Uuident UIDINS
Local Integer ASTAERR

Local Integer MODULE,CHECKRIGHT

Local File ASHW [ASW]

Read [F:ASW]ASW0 = [L]WCODREP
If fstat
 ERROR = func ASYRSUB._ASETSTATUS(GACTX,"",0,ERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(8,149,1),[L]WCODREP))
 Goto ERR_READ_REPRESENTATION
Else
 WCODCLA = [F:ASW]CODCLA
Endif

ERROR = func ASHWVAL._CHECK_ASW(GACTX,WCODREP,WCODCLA,"$details",WCODFNC,MODULE,CHECKRIGHT)

If ERROR>[V]CST_AOK
 Goto ERR_READ_REPRESENTATION
Endif

Close Local File [ASW]

#----------------------------#
# Define data Instance
#----------------------------#
Local Instance DET Using C_AREPENT : # Representation containing metadatas
REPNAM = "DET"

#--------------------------------------------------#
# Load json presentation (metadata & data)
#--------------------------------------------------#
PRGREP = func SUBASW.PREFIX_TRT+WCODREP : # WMREP

Call DESCRIPTION_REPRESENTATION(DET,REPNAM) From =PRGREP
If  (dim(DET.AENAFAC)>0 & DET.AENAFAC(1)>=1 & DET.AENAFAC(1)<>2 ) & (dim(DET.AENAFAC)>0 & DET.AENAFAC(5)>=1 & DET.AENAFAC(5)<>2)
 GMESSAGE = func ASYRFNC.MES2(mess(14,149,1),"$details",WCODREP)
 ERROR = [V]CST_AERROR
 Return
Endif

# update fonction rigth for AIMP
FONCTION =  DET.AFCRIGHT

# Create instance representation
Local Instance WDET Using ="R_"+DET.REP
WDET = evalue ("Newinstance R_"+DET.REP+ " AllocGroup null")

# cacul of key
Local Char WKEY(250)
For I=1 To maxtab(DET.CLE)
 If I=1
  WKEY = [L]PARAM(I+2)
 Else
  WKEY  += '~'+ [L]PARAM(I+2) # Issue X3-42695 - 2017-06-16 by ERB : Added ~ separator
 Endif
Next

# Load data (Read from CRUD)
Call _AREADSUP(WDET,WKEY,ERROR) From =func ACLAVALCRUD.GET_PREFIX_REP_READ+DET.REP
ASTAERR= fmet WDET._AERROR(GACTX,2)
If ERROR>[V]CST_AOK
 Goto ERR_READ_REPRESENTATION
Endif

Return

#--------------------------------------------------#

$ERR_READ_REPRESENTATION
Local Instance ERRORS(1..) Using C_AERROR
ASTATUS = func ASYRSUB.AGETERRORS(GACTX.AERROR,"",ERRORS)
For I=1 To maxtab(ERRORS)
 If ERRORS(I)<>null & ERRORS(I).STA=[V]CST_AERROR
  Call ERREUR(ERRORS(1).MES) From GESECRAN
 Endif
Next
ASTATUS = fmet GACTX.ADELETEERROR(CST_ALLERRORS)
Gosub FREE_GROUP
Return

