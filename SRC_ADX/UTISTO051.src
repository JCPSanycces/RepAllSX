#<AdxTL>@(#)11.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
##########################################################################
# UTISTO051 Moulinette d éclatement du CLSTYP demande  28874 module STOCK #
# ---------------------------------------------------------------------- #
##########################################################################

Call MAJ_UTISTO051
End

#If [F:ADS]MODULE(6)<>2    # Ne concerne que le module stock
#    End
#Endif
#6 = STOCK
# 7 Gp
# 8 TC
Subprog MAJ_UTISTO051
Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
#  Call TRT_COR(DOSSIER) 
#  Call TRT_COR1(DOSSIER) 
#  Call TRT_ANA_SMH(DOSSIER) 
  Call TRT_ANA_SGH(DOSSIER) 
#  Call TRT_ANA_SRT(DOSSIER) 
#  Call TRT_ANA_CUN(DOSSIER) 
Endif
End
############################################################
Subprog TRT_COR(DOSSIER)
Value Char DOSSIER
Call TEMPON("O") From GESECRAN
#
Local Integer CLSTYP_AV
Local Integer WRE
Raz WRE
If clalev([F:ITG]) = 0 : Local File =DOSSIER+".ITMCATEG"   [ITG] : Endif
If clalev([F:ITM]) = 0 : Local File =DOSSIER+".ITMMASTER"  [ITM] : Endif
If clalev([F:CBH]) = 0 : Local File =DOSSIER+".CBNHEA"     [CBH] : Endif
If clalev([F:BMR]) = 0 : Local File =DOSSIER+".BOMRET"     [BMR] : Endif
If clalev([F:ITF]) = 0 : Local File =DOSSIER+".ITMFACILIT" [ITF] : Endif
#
Call OUVRE_TRACE("Correction") From LECFIC


#----                                                                ITMCATEG ----#
Call ECR_TRACE("Start trace : ITMCATEG / CLSTYP" ,0) From GESECRAN
Local Char WVEN
Call TEXTFIC("ITMCATEG","SALFLG",2,WVEN) From OBJDIV  

Trbegin [ITG]
For [ITG]
    Readlock [ITG] Curr
    If !fstat
        [F:ITG]PURFLG = 1 
        [F:ITG]MFGFLG = 1
        [F:ITG]SCPFLG = 1
        [F:ITG]SCSFLG = 1
        [F:ITG]PHAFLG = 1
        [F:ITG]GENFLG = 1
        [F:ITG]TOOFLG = 1
        [F:ITG]DLVFLG = 1
        [F:ITG]INTFLG = 1
        CLSTYP_AV     = [F:ITG]CLSTYP
        If [F:ITG]SALFLG = 2
           [F:ITG]DLVFLG = 2
           If [F:ITG]CLSTYP = 6               # Sous_traitance
              [F:ITG]CLSTYP = 1
           Endif
           If [F:ITG]CLSTYP = 8               # generique
              [F:ITG]CLSTYP = 1
           Endif 
           If [F:ITG]CLSTYP = 9               # Outillage
              [F:ITG]CLSTYP = 1
           Endif
           If CLSTYP_AV <> [F:ITG]CLSTYP
             Call ECR_TRACE([F:ITG]STOFCY-" "-[F:ITG]TCLCOD-" "-mess(125,188,1)-" : "-WVEN-" / "
&                          -mess(CLSTYP_AV,222,1) -mess(2,2333,1)
&                          -" ! -> "-mess(2,2359,1)-" : "-WVEN-mess(254,184,1)-mess(1,222,1),1) From GESECRAN 
           Endif
        Endif
        Case [F:ITG]CLSTYP
             When 1 :
                [F:ITG]PURFLG = 2
             When 2 :
                [F:ITG]MFGFLG = 2
             When 3 :
                [F:ITG]PURFLG = 2
                [F:ITG]MFGFLG = 2
             When 4 :
                [F:ITG]PURFLG = 2
                [F:ITG]MFGFLG = 2
             When 5 :
                [F:ITG]SCPFLG = 2
             When 6 :
                [F:ITG]SCSFLG = 2
             When 7 :
                [F:ITG]PHAFLG = 2
             When 8 :
                [F:ITG]GENFLG = 2
             When 9 :
                [F:ITG]TOOFLG = 2
        Endcase
        If [F:ITG]SCSFLG = 2
           [F:ITG]PURFLG = 2
        Endif
        If [F:ITG]TOOFLG = 2
           [F:ITG]PURFLG = 2
        Endif
        If [F:ITG]GENFLG = 2
           [F:ITG]PURFLG = 2
           [F:ITG]MFGFLG = 2
        Endif
        If [F:ITG]PHAFLG = 2
           [F:ITG]PURFLG = 2
        Endif
        If CLSTYP_AV <> [F:ITG]CLSTYP
           [F:ITG]CLSTYP  = CLSTYP_AV     
        Endif
        Rewrite [ITG] 
        WRE +=1
    Endif
Next
Commit


Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),1) From GESECRAN  

#----                                                                ITMMASTER ----#
$SUIT1
Call ECR_TRACE("Start trace : ITMMASTER / CLSTYP" ,0) From GESECRAN
Raz WRE

Trbegin [ITM]
For [ITM]
    Readlock [ITM] Curr
    If !fstat
        [F:ITM]EECGES = 2 
        #---- CLSTYP ----#
        If [F:ITM]TCLCOD<>""
            Readlock [ITG]ITG1=[F:ITM]TCLCOD;""
            If !fstat 
               [F:ITM]MFGFLG = [F:ITG]MFGFLG
               [F:ITM]SCPFLG = [F:ITG]SCPFLG 
               [F:ITM]SCSFLG = [F:ITG]SCSFLG 
               [F:ITM]PHAFLG = [F:ITG]PHAFLG
               [F:ITM]GENFLG = [F:ITG]GENFLG 
               [F:ITM]TOOFLG = [F:ITG]TOOFLG 
               [F:ITM]DLVFLG = [F:ITG]DLVFLG 
               [F:ITM]PURFLG = [F:ITG]PURFLG 
               [F:ITM]SALFLG = [F:ITG]SALFLG 
               [F:ITM]INTFLG = [F:ITG]INTFLG 
               If [F:ITM]CLSTYP <> [F:ITG]CLSTYP
                  Call ECR_TRACE([F:ITM]ITMREF-" "-[F:ITM]TCLCOD-" "-mess(252,184,1)
&                      -mess([F:ITM]CLSTYP,222,1)-mess(254,184,1)-mess([F:ITG]CLSTYP,222,1),1) From GESECRAN
               Endif
# si livrable et unite de vente = "" alors unite de vente = unite de stock
               If [F:ITM]SAU        = "" 
                  [F:ITM]SAU        = [F:ITM]STU
               Endif
               If [F:ITM]SAUSTUCOE  = 0  
                  [F:ITM]SAUSTUCOE  = 1
               Endif

            Endif  
        Endif
        Rewrite [ITM] 
        WRE +=1
    Endif
Next
Commit

Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),1) From GESECRAN  

Goto SUITE10
#----                                                                BOMRET ----#

Call ECR_TRACE("Start trace : BOMRET / CLSTYP" ,0) From GESECRAN
Raz WRE

Trbegin [BMR]
For [BMR]
    Readlock [BMR] Curr
    If !fstat
        #---- CLSTYP ----#
        If [F:BMR]ITMREF<>""
            Read [ITM]ITM0=[F:BMR]ITMREF
            If !fstat 
               [F:BMR]MFGFLG = [F:ITM]MFGFLG
               [F:BMR]SCPFLG = [F:ITM]SCPFLG 
               [F:BMR]SCSFLG = [F:ITM]SCSFLG 
               [F:BMR]PHAFLG = [F:ITM]PHAFLG
               [F:BMR]GENFLG = [F:ITM]GENFLG 
               [F:BMR]TOOFLG = [F:ITM]TOOFLG 
               [F:BMR]DLVFLG = [F:ITM]DLVFLG 
               [F:BMR]PURFLG = [F:ITM]PURFLG 
               [F:BMR]SALFLG = [F:ITM]SALFLG 
               [F:BMR]INTFLG = [F:ITM]INTFLG 
               If [F:ITM]CLSTYP <> [F:BMR]CLSTYP
                  Call ECR_TRACE(num$([F:BMR]BMRUID)-" "-[F:BMR]ITMREF-" "-num$([F:BMR]NIV)-" "-mess(253,184,1)
&                   -mess([F:BMR]CLSTYP,222,1)-mess(254,184,1)-mess([F:ITM]CLSTYP,222,1),1) From GESECRAN
               Endif
            Endif
        Endif
        Rewrite [BMR] 
        WRE +=1
    Endif
Next
Commit

Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),1) From GESECRAN  

#----                                                                CBNHEA ----#

Call ECR_TRACE("Start trace : CBNHEA / CLSTYP" ,0) From GESECRAN
Raz WRE

Trbegin [CBH]
For [CBH]
    Readlock [CBH] Curr
    If !fstat
        #---- CLSTYP ----#
        If [F:CBH]ITMREF<>""
            Read [ITM]ITM0=[F:CBH]ITMREF
            If !fstat 
               [F:CBH]MFGFLG = [F:ITM]MFGFLG
               [F:CBH]SCPFLG = [F:ITM]SCPFLG 
               [F:CBH]SCSFLG = [F:ITM]SCSFLG 
               [F:CBH]PHAFLG = [F:ITM]PHAFLG
               [F:CBH]GENFLG = [F:ITM]GENFLG 
               [F:CBH]TOOFLG = [F:ITM]TOOFLG 
               [F:CBH]DLVFLG = [F:ITM]DLVFLG 
               [F:CBH]PURFLG = [F:ITM]PURFLG 
               [F:CBH]SALFLG = [F:ITM]SALFLG 
               [F:CBH]INTFLG = [F:ITM]INTFLG 
               If [F:ITM]CLSTYP <> [F:CBH]CLSTYP
                  Call ECR_TRACE([F:CBH]STOFCY-" "-[F:CBH]ITMREF-" "-mess(255,184,1)
&                   -mess([F:CBH]CLSTYP,222,1)-mess(254,184,1)-mess([F:ITM]CLSTYP,222,1),1) From GESECRAN
               Endif
            Endif
        Endif
        Rewrite [CBH] 
        WRE +=1
    Endif
Next
Commit

Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),1) From GESECRAN  

#----                                                                PDPHEA ----#
# Ne concerne que le module GPAO

#If [F:ADS]MODULE(7) = 2                  
   If clalev([F:PDH]) = 0 : Local File =DOSSIER+".PDPHEA"     [PDH] : Endif

   Call ECR_TRACE("Start trace : PDPHEA / CLSTYP" ,0) From GESECRAN
   Raz WRE

   Trbegin [PDH]
   For [PDH]
       Readlock [PDH] Curr
       If !fstat
           #---- CLSTYP ----#
           If [F:PDH]ITMREF<>""
              Read [ITM]ITM0=[F:PDH]ITMREF
              If !fstat 
                 [F:PDH]MFGFLG = [F:ITM]MFGFLG
                 [F:PDH]SCPFLG = [F:ITM]SCPFLG 
                 [F:PDH]SCSFLG = [F:ITM]SCSFLG 
                 [F:PDH]PHAFLG = [F:ITM]PHAFLG
                 [F:PDH]GENFLG = [F:ITM]GENFLG 
                 [F:PDH]TOOFLG = [F:ITM]TOOFLG 
                 [F:PDH]DLVFLG = [F:ITM]DLVFLG 
                 [F:PDH]PURFLG = [F:ITM]PURFLG 
                 [F:PDH]SALFLG = [F:ITM]SALFLG 
                 [F:PDH]INTFLG = [F:ITM]INTFLG 
                 If [F:ITM]CLSTYP <> [F:PDH]CLSTYP
                    Call ECR_TRACE([F:PDH]STOFCY-" "-[F:PDH]ITMREF-" "-mess(256,184,1)
&                   -mess([F:PDH]CLSTYP,222,1)-mess(254,184,1)-mess([F:ITM]CLSTYP,222,1),1) From GESECRAN
                 Endif
              Endif
           Endif
           Rewrite [PDH] 
           WRE +=1
       Endif
   Next
   Commit
   Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),1) From GESECRAN  
#Endif

$SUITE10
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End



############################################################
Subprog TRT_COR1(DOSSIER)
Value Char DOSSIER
Call TEMPON("O") From GESECRAN
#

Local Integer WRE
If clalev([F:ITG]) = 0 : Local File =DOSSIER+".ITMCATEG"   [ITG] : Endif
If clalev([F:ITS]) = 0 : Local File =DOSSIER+".ITMSALES"   [ITS] : Endif
If clalev([F:ITF]) = 0 : Local File =DOSSIER+".ITMFACILIT" [ITF] : Endif
If clalev([F:ITM]) = 0 : Local File =DOSSIER+".ITMMASTER"  [ITM] : Endif
#
Call OUVRE_TRACE("Correction") From LECFIC


#----                                                                ITMCATEG ----#

Call ECR_TRACE("Start trace : ITMFACILIT / PCK" ,0) From GESECRAN
Raz WRE

Trbegin [ITF]

Filter [ITS] Where PCK <> ""  
&            Order By Key ITS0
For [ITS]
#----       
    Filter [ITF] Where ITMREF = [F:ITS]ITMREF  
&            Order By Key ITF0

    For [ITF]
        Readlock [ITF] Curr
        If !fstat
           [F:ITF]PCK    = [F:ITS]PCK
           [F:ITF]PCKCAP = [F:ITS]PCKCAP 
#           Rewrite [ITF] 
           WRE +=1
        Endif
    Next
    Filter [ITF]
Next
Filter [ITS]
Commit

Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),1) From GESECRAN  

Local Char WTCLCOD
Raz WTCLCOD
Local Integer WOK
Raz WOK
Local Char WPCK
Raz WPCK
Local Decimal WPCKCAP
Raz WPCKCAP
 
Call ECR_TRACE("Start trace : ITMCATEG / PCK" ,0) From GESECRAN
Trbegin [ITG]

Raz WRE
Link [ITM] With [ITS]ITS0=[F:ITM]ITMREF 
&          As [ART] 
&          Where [F:ITS]PCK <> ""   
&          Order By Key CLE = TCLCOD 
    For [ART]
        Read [ART] Curr
        If !fstat
           If WTCLCOD = "" 
              WTCLCOD = [F:ITM]TCLCOD
              WPCK    = [F:ITS]PCK
              WPCKCAP = [F:ITS]PCKCAP
           Endif
           If WTCLCOD <> [F:ITM]TCLCOD 
              If WOK = 0
                 Readlock [ITG]ITG1=WTCLCOD;""
                 If !fstat 
                    If [F:ITG]SALFLG = 2 | [F:ITG]DLVFLG = 2 
                       [F:ITG]PCK    = WPCK
                       [F:ITG]PCKCAP = WPCKCAP
                       Rewrite [ITG] 
                       WRE +=1
                    Endif
                 Endif
              Endif
              WPCK    = [F:ITS]PCK
              WPCKCAP = [F:ITS]PCKCAP
              WTCLCOD = [F:ITM]TCLCOD
              WOK = 0
           Else
               If WPCK <>  [F:ITS]PCK 
                  Raz WPCK    
                  Raz WPCKCAP 
                  WOK = 9
               Endif
               If WPCKCAP <>  [F:ITS]PCKCAP 
                  Raz WPCKCAP
               Endif
           Endif
        Endif
    Next
    If WOK = 0
       Readlock [ITG]ITG1=WTCLCOD;""
       If !fstat 
          If [F:ITG]SALFLG = 2 | [F:ITG]DLFVLG = 2 
             [F:ITG]PCK    = WPCK
             [F:ITG]PCKCAP = WPCKCAP
             Rewrite [ITG] 
             WRE +=1
          Endif
       Endif
    Endif
    Filter [ART]
Commit
Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),1) From GESECRAN  


Call ECR_TRACE("Start trace : ITMCATEG site  / PCK" ,0) From GESECRAN

If clalev([F:ITG1]) = 0 : Local File =DOSSIER+".ITMCATEG"   [ITG1] : Endif

Raz WRE

Trbegin [ITG]

Filter [ITG1] Where PCK <> ""  
&             Order By Key ITG0
For [ITG1]
#----       
    Filter [ITG] Where TCLCOD = [F:ITG1]TCLCOD &
&                      STOFCY <> ""            
&                Order By Key ITG0

    For [ITG]
        Readlock [ITG] Curr
        If !fstat
           [F:ITG]PCK    = [F:ITG1]PCK
           [F:ITG]PCKCAP = [F:ITG1]PCKCAP 
           Rewrite [ITG] 
           WRE +=1
        Endif
    Next
    Filter [ITG]
Next
Filter [ITG1]
Commit

Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),1) From GESECRAN  



Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End






############################################################
Subprog TRT_ANA_SMH(DOSSIER)
Value Char DOSSIER
Call TEMPON("O") From GESECRAN
#

If GMODU(2)=2  Local File =DOSSIER+".GACM" [GCM] : Endif
If clalev([F:SMH]) = 0 : Local File =DOSSIER+".SMVTH"      [SMH] : Endif
If clalev([F:SMD]) = 0 : Local File =DOSSIER+".SMVTD"      [SMD] : Endif
If clalev([F:CAL]) = 0 : Local File =DOSSIER+".CPTANALIN"  [CAL] : Endif

#
Call OUVRE_TRACE("Correction") From LECFIC


#----                                                                SMVH SMVTD ----#

Call ECR_TRACE("Start trace : SMVH SMVTD / Cce" ,0) From GESECRAN
Local Integer WRE
Local Integer WRE1
Local Integer I
Local Integer J
Raz WRE
Raz WRE1

#If GUSER  = "HCB"
#   Trbegin [CAL]
#   For [CAL] Where [F:CAL]ABRFIC="SMD"
#       Delete [CAL] Curr
#   Next
#   Commit
#Endif

Trbegin [SMH] , [SMD]
For [SMH]
#----       
    Readlock [SMH] Curr
    If !fstat
    #----- Alimentation champs pour le multi-référenciels comptabilité -----#
       Call RECUP_GLOBAL_CPT(DOSSIER,[F:SMH]STOFCY) From TRTX3CPT
       For I=1 To max(GNBDIE,GOPTCANA)
           [F:SMH]DIE(I-1) = GDIE(I)
           [F:SMH]CCE(I-1) =  evalue("[F:SMH]CCE"+num$(I))
       Next I
       Rewrite [SMH]
       If fstat
          Call ECR_TRACE("File SMVTH"-[F:SMH]VCRNUM+", Error ="-num$(fstat),1) From GESECRAN
       Endif
       WRE +=1
    Endif
    For [SMD] Where VCRTYP = [F:SMH]VCRTYP & VCRNUM=[F:SMH]VCRNUM
#----       
        Read [SMD] Curr
        If fstat
           Call ECR_TRACE("File SMVTD"-[F:SMH]VCRNUM+", Error ="-num$(fstat),1) From GESECRAN
        Else
           Look [CAL] CAL0="SMD";[F:SMD]VCRTYP;[F:SMD]VCRNUM;[F:SMD]VCRLIN;0;"";1
           If fstat
              Raz [F:CAL]
              [F:CAL]ABRFIC="SMD"
              [F:CAL]VCRTYP=[F:SMD]VCRTYP
              [F:CAL]VCRNUM=[F:SMD]VCRNUM
              [F:CAL]VCRLIN=[F:SMD]VCRLIN
              [F:CAL]ANALIG=1
              For J=1 To max(GNBCOA,2)
                [F:CAL]LED(J-1)=GLEDSOC(J)
                [F:CAL]COA(J-1)=GCOA(J)
              Next J
              For J=1 To max(GNBDIE,GOPTCANA)
                  [F:CAL]DIE(J-1)=GDIE(J)
                  [F:CAL]CCE(J-1)=evalue("[F:SMD]CCE"+num$(J))
              Next J
              Write [CAL]
              If fstat
                 Call ECR_TRACE("File CPTANALIN SMD"-num$([F:SMD]VCRTYP)-[F:SMD]VCRNUM-num$([F:SMD]VCRLIN)
&                             +", Error ="-num$(fstat),1) From GESECRAN
              Endif
              WRE1 +=1
           Endif
        Endif
    Next
Next
Commit

Call ECR_TRACE(mess(104,141,1)-"  SMH : "-num$(WRE),0) From GESECRAN  
Call ECR_TRACE(mess(104,141,1)-"  CAL : "-num$(WRE1),0) From GESECRAN  

Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

############################################################
Subprog TRT_ANA_SGH(DOSSIER)
Value Char DOSSIER
Call TEMPON("O") From GESECRAN
#

If GMODU(2)=2  Local File =DOSSIER+".GACM" [GCM] : Endif
If clalev([F:SGH]) = 0 : Local File =DOSSIER+".SCHGH"      [SGH] : Endif
If clalev([F:SGD]) = 0 : Local File =DOSSIER+".SCHGD"      [SGD] : Endif
If clalev([F:CAL]) = 0 : Local File =DOSSIER+".CPTANALIN"  [CAL] : Endif

#
Call OUVRE_TRACE("Correction") From LECFIC


#----                                                                SCHGH SCHGD ----#

Call ECR_TRACE("Start trace : SCHGH SCHGD / Cce" ,0) From GESECRAN
Local Integer WRE
Local Integer WRE1
Local Integer I
Local Integer J
Raz WRE
Raz WRE1

#If GUSER  = "HCB"
#   Trbegin [CAL]
#   For [CAL] Where [F:CAL]ABRFIC="SGD"
#       Delete [CAL] Curr
#   Next
#   Commit
#Endif

Trbegin [SGH] , [SGD]
For [SGH] 
#----       
    Readlock [SGH] Curr
    If !fstat
    #----- Alimentation champs pour le multi-référenciels comptabilité -----#
       Call RECUP_GLOBAL_CPT(DOSSIER,[F:SGH]STOFCY) From TRTX3CPT
       For I=1 To max(GNBDIE,GOPTCANA)
           [F:SGH]DIE(I-1) = GDIE(I)
           [F:SGH]CCE(I-1) =  evalue("[F:SGH]CCE"+num$(I))
       Next I
      Rewrite [SGH]
       If fstat
          Call ECR_TRACE("File SCHGH"-[F:SGH]VCRNUM+", Error ="-num$(fstat),1) From GESECRAN
       Endif
       WRE +=1
    Endif
    For [SGD] Where VCRNUM = [F:SGH]VCRNUM
#----       
        Read [SGD] Curr
        If fstat
           Call ECR_TRACE("File SCHGD"-[F:SGH]VCRNUM+", Error ="-num$(fstat),1) From GESECRAN
        Else
           Look [CAL] CAL0="SGD";0;[F:SGD]VCRNUM;[F:SGD]VCRLIN;0;"";1
           If fstat
              Raz [F:CAL]
              [F:CAL]ABRFIC="SGD"
              [F:CAL]VCRTYP= 29           
              [F:CAL]VCRNUM=[F:SGD]VCRNUM
              [F:CAL]VCRLIN=[F:SGD]VCRLIN
              [F:CAL]ANALIG=1
              For J=1 To max(GNBCOA,2)
                [F:CAL]LED(J-1)=GLEDSOC(J)
                [F:CAL]COA(J-1)=GCOA(J)
              Next J
              For J=1 To max(GNBDIE,GOPTCANA)
                  [F:CAL]DIE(J-1)=GDIE(J)
                  [F:CAL]CCE(J-1)=evalue("[F:SGD]CCE"+num$(J))
              Next J
            Write [CAL]
              If fstat
                 Call ECR_TRACE("File CPTANALIN SGD"-[F:SGD]VCRNUM-num$([F:SGD]VCRLIN)
&                             +", Error ="-num$(fstat),1) From GESECRAN
              Endif
              WRE1 +=1
           Endif
        Endif
    Next
Next
Commit

Call ECR_TRACE(mess(104,141,1)-"  SGH : "-num$(WRE),0) From GESECRAN  
Call ECR_TRACE(mess(104,141,1)-"  CAL : "-num$(WRE1),0) From GESECRAN  

Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End






#------------------------------------------------------------------#
# Alimentation des nouveaux champs dans les transactions de saisie #
# ---------------------------------------------------------------- #
# Table STKTRS - Transactions de saisie stock                      #
#  1 Transactions entrees diverses                                 #
#  2 Transactions sorties diverses                                 #
#  5 Transactions plan de rangement                                #
#  3 Transactions changement de stock                              #
#  6 Transactions inventaire            (en attente)               #
#  7 Transactions assemblage / desassemblage                       #
#------------------------------------------------------------------#
Subprog TRT_ANA_SRT(DOSSIER)
Value Char DOSSIER
Call TEMPON("O") From GESECRAN

If clalev([F:SRT]) = 0 : Local File =DOSSIER+".STKTRS"      [SRT] : Endif
If clalev([F:DTR]) = 0 : Local File =DOSSIER+".DIETRS"      [DTR] : Endif
If clalev([F:DIE]) = 0 : Local File =DOSSIER+".GDIE"        [DIE] : Endif

Local Integer WNBR , WI
Raz WNBR
Call ECR_TIME(" Stock Transactions : Update STKTRS") From DOSSUB
#----- S'assurer que la table contient les anciens champs supprimés -----#
Trbegin [DTR]
For [SRT] SRT0 Where find(SRTTYP,1,2,3,5,6,7)
    Read [SRT] Curr
    If fstat
       Call ECR_TRACE("File STKTRS"-num$([F:SRT]SRTTYP)-[F:SRT]SRTNUM+", Error ="-num$(fstat),1) From GESECRAN
    Else
       #----- Alimentation nouvelle table pour axes analytiques -----#
       Look [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0
       If fstat
          If [F:SRT]HEACCECOD=0  [F:SRT]HEACCECOD=3 : Endif
          If [F:SRT]CCECODS  =0  [F:SRT]CCECODS  =3 : Endif
          Raz [F:DTR]
          [F:DTR]ABRFIC="SRT"
          [F:DTR]DTRTYP=[F:SRT]SRTTYP
          [F:DTR]DTRNUM=[F:SRT]SRTNUM
          [F:DTR]DIE   =""
          [F:DTR]HEACCECOD=[F:SRT]HEACCECOD
          [F:DTR]STOCCECOD=[F:SRT]CCECODS
          [F:DTR]DSPCOD =3
          [F:DTR]DSPSCR =1
          [F:DTR]CCESCR =[F:SRT]CCESCR(0)
          [F:DTR]CCESCR2=1
          [F:DTR]CCESCR3=1
          Write [DTR]
          If fstat
            Call ECR_TRACE("File DIETRS"-[F:DTR]ABRFIC-num$([F:DTR]DTRTYP)+", ERROR ="-num$(fstat),1) From GESECRAN
          Endif
          Raz WI
          For [DIE] DIE0
              Look [DTR] DTR1="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;1;[F:DIE]DIE
              If fstat
                 [F:DTR]DTRTNU=1
                 [F:DTR]DTRLIN=WI+1
                 [F:DTR]DIE   =[F:DIE]DIE
                 If dim([F:SRT]CCECOD)>WI & [F:SRT]CCECOD(WI)>0 & [F:SRT]CCECOD(WI)<3
                   [F:DTR]CCECOD=[F:SRT]CCECOD(WI)
                   Write [DTR]
                   If fstat
                     Call ECR_TRACE("File DIETRS"-[F:DTR]ABRFIC-num$([F:DTR]DTRTYP)+", ERROR ="-num$(fstat),1) From GESECRAN
                   Endif
                 Endif
              Endif
              WI+=1
          Next
       Endif
       WNBR+=1
    Endif
Next
Commit
Call ECR_TIME("DOSMAJ999 Stock Transactions  : Ended ("+num$(WNBR)+")") From DOSSUB
#-----
End


############################################################
Subprog TRT_ANA_CUN(DOSSIER)
Value Char DOSSIER
Call TEMPON("O") From GESECRAN
#

If GMODU(2)=2  Local File =DOSSIER+".GACM" [GCM] : Endif
If clalev([F:CUL]) = 0 : Local File =DOSSIER+".CUNLISTE"   [CUL] : Endif
If clalev([F:CUD]) = 0 : Local File =DOSSIER+".CUNLISDET"  [CUD] : Endif

#
Call OUVRE_TRACE("Correction") From LECFIC


#----                                                                SMVH SMVTD ----#

Call ECR_TRACE("Start trace : CUNLISTE CUNLISDET / Cce" ,0) From GESECRAN
Local Integer WRE
Local Integer WRE1
Local Integer I
Local Integer J
Raz WRE
Raz WRE1

#If GUSER  = "HCB"
#   Trbegin [CAL]
#   For [CAL] Where [F:CAL]ABRFIC="SMD"
#       Delete [CAL] Curr
#   Next
#   Commit
#Endif

Trbegin [CUL] , [CUD]
For [CUL]
#----       
    Readlock [CUL] Curr
    If !fstat
    #----- Alimentation champs pour le multi-référenciels comptabilité -----#
       Call RECUP_GLOBAL_CPT(DOSSIER,[F:CUL]STOFCY) From TRTX3CPT
       For I=1 To max(GNBDIE,GOPTCANA)
           [F:CUL]DIE(I-1) = GDIE(I)
           [F:CUL]CCE(I-1) =  evalue("[F:CUL]CCE"+num$(I))
       Next I
       Rewrite [CUL]
       If fstat
          Call ECR_TRACE("File CUNLISTE"-[F:CUL]CUNSSSNUM-[F:CUL]CUNLISNUM+", Error ="-num$(fstat),1) From GESECRAN
       Endif
       WRE +=1
    Endif
    For [CUD] Where CUNSSSNUM = [F:CUL]CUNSSSNUM & CUNLISNUM=[F:CUL]CUNLISNUM
#----       
        Readlock [CUD] Curr
        If !fstat
           For I=1 To max(GNBDIE,GOPTCANA)
               [F:CUD]DIE(I-1) = GDIE(I)
               [F:CUD]CCE(I-1) =  evalue("[F:CUD]CCE"+num$(I))
           Next I
           Rewrite [CUD]
           If fstat
              Call ECR_TRACE("File CUNLISDET"-[F:CUD]CUNSSSNUM-[F:CUD]CUNLISNUM+", Error ="-num$(fstat),1) From GESECRAN
           Endif
           WRE1 +=1
        Endif
    Next
Next
Commit

Call ECR_TRACE(mess(104,141,1)-"  CUL : "-num$(WRE),0) From GESECRAN  
Call ECR_TRACE(mess(104,141,1)-"  CUD : "-num$(WRE1),0) From GESECRAN  

Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

