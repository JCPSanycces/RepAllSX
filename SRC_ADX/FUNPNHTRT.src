#<AdxTL>@(#)180.0.0.0 $Revision$
##########################################################################
# FUNPNHTRT        Validation des retours fournisseurs      sr Juin 1998 #
# ---------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)                 #
#   - TRTFUNPNH : Fonction de validation des retours fournisseurs        #
##########################################################################


$ACTION
#----------------------------------------------------------#
# Actions sur le traitement standard (GTRAITE)             #
# TRTFUNPNH  : Fonction de validation des factures/avoirs  #
#----------------------------------------------------------#
Case ACTION
 When "OUVRE_BATCH" : Gosub OPEN_FILE
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Affzo [DIA]1-99 : Gosub GRISAGE
 When "SETBOUT"     : If GHISTO
                        Diszo [DIA]1-99
                        Call VIREBOUT(CHBOU,"O")   From GOBJET
                        Call VIREBOUT(CHMEN,"MRE") From GOBJET
                      Endif
 When "BOUTON"      : Gosub BOUTON
 When "OK"          : GOK=1
 When "END"         : GOK=0
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When Default
Endcase
Return


#################################################
# Initialisations avant exécution du traitement #
#################################################
$INIT
If GSERVEUR
  Onerrgo ERRBATCH : # En batch, il vaut mieux mettre onerrgo
Endif
#-----
Local Integer I, OK
Local Char    CRITERE(250)(0..1)
Local Char    TIT(50), WMSG(80), PARAMA(10), WCPY(GLONCPY)
Local Integer LRET, WSTA
#-----
GFCY = GFCYDEF(7)
#--- Issue 96320
#Call GETDEV(GFCY)  From DEVSUB
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
#---
Call GLOBVAR(GFCY) From WWGLOBACH
Call GLOBVAR(GFCY) From WWGLOBSTO
Gosub OPEN_FILE
#-----
Local Mask PSELRET [DIA]
Raz [M:DIA]
[M:DIA]DATFIN=date$
Call LECMEMO("STD","[M:DIA]","pm4") From GMEMO
TIT=mess(58,195,1)  : # Titre de la boite de dialogue et message de temporisation
TMP=1               : # Affichage d'un message de temporisation
Return


###############################
# Après exécution d'un bouton #
###############################
$BOUTON
Case BOUT
  When "r" : Gosub GRISAGE
Endcase
Return


##########################################
# Contrôle avant exécution du traitement #
##########################################
$CONTROLE
If GOK<1  FIN=1 : Endif
Return


###########################
# Exécution du traitement #
###########################
$EXEC
Raz CRITERE
CRITERE(0) = 'CFMFLG=1'
If [M:DIA]RETDEB<>""
   CRITERE(0) -= '& PNHNUM>="'+[M:DIA]RETDEB+'"'
Endif
If [M:DIA]RETFIN<>""
   CRITERE(0) -= '& PNHNUM<="'+[M:DIA]RETFIN+'"'
Endif
If [M:DIA]FCYDEB<>""
   CRITERE(0) -= '& PNHFCY>="'+[M:DIA]FCYDEB+'"'
Endif
If [M:DIA]FCYFIN<>""
   CRITERE(0) -= '& PNHFCY<="'+[M:DIA]FCYFIN+'"'
Endif
If [M:DIA]DATDEB<>[0/0/0]
   CRITERE(0) -= '& RTNDAT>=['+format$(GFMD,[M:DIA]DATDEB)+']'
Endif
If [M:DIA]DATFIN<>[0/0/0]
   CRITERE(0) -= '& RTNDAT<=['+format$(GFMD,[M:DIA]DATFIN)+']'
Endif
If [M:DIA]FOUDEB<>""
   CRITERE(0) -= '& BPSNUM>="'+[M:DIA]FOUDEB+'"'
Endif
If [M:DIA]FOUFIN<>""
   CRITERE(0) -= '& BPSNUM<="'+[M:DIA]FOUFIN+'"'
Endif
If [M:DIA]AUZDEB<>""
   CRITERE(1) -= '& AUZNUM>="'+[M:DIA]AUZDEB+'"'
Endif
If [M:DIA]AUZFIN<>""
   CRITERE(1) -= '& AUZNUM<="'+[M:DIA]AUZFIN+'"'
Endif
If [M:DIA]TRPDEB<>""
   CRITERE(1) -= '& BPTNUM>="'+[M:DIA]TRPDEB+'"'
Endif
If [M:DIA]TRPFIN<>""
   CRITERE(1) -= '& BPTNUM<="'+[M:DIA]TRPFIN+'"'
Endif
If !GSERVEUR
  #----- Ouverture fichier trace et écriture des sélections -----#
  Call OUVRE_TRACE(mess(79,197,1))    From LECFIC
  Call ECR_TRACE(" ",0)               From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0)   From GESECRAN
  Call PRTSCR("PSELRET","DIA","",0,1) From ATRTX3
  Call ECR_TRACE(string$(70,"-"),0)   From GESECRAN
  Call ECR_TRACE(" ",0)               From GESECRAN
Endif
LRET = 99
Filter [PNH] Where evalue(CRITERE)
For [PNH] With Nohint
  If [F:PNH]PNHFCY<>[F:FCY]FCY
    Read [FCY] FCY0=[F:PNH]PNHFCY : If fstat  Raz [F:FCY] : Endif
  Endif
  If [F:PNH]PNHFCY<>GFCY
    GFCY=[F:PNH]PNHFCY
    #--- Issue 96320
    #Call GETDEV(GFCY)  From DEVSUB
    Call GETCPY(GFCY,"",0,"") From TRTX3CPT
    #---
    Call GLOBVAR(GFCY) From WWGLOBACH
    Call GLOBVAR(GFCY) From WWGLOBSTO
    #-----
    Call LECTCA(7,LRET) From SUBTCA
    If fstat | !LRET
      Call ECR_TRACE(mess(58,105,1)-mess(7,14,1)-GSOCIETE-mess(250,199,1),1) From GESECRAN
      Goto SUIT
    Endif
    GWIP=[F:TCA]CODNUM(8)
    #-----
    #Call CTRCPT(GWIP,25,LRET) From STKLIB
    #If LRET
    #  Call ECR_TRACE(GWIP-mess(222,199,1),1) From GESECRAN
    #  Goto SUIT
    #Endif
    #-----
  Endif
  LRET=0
  WSTA=0
  WCPY=[F:FCY]LEGCPY
  For [PER] PER0 Where CPY=WCPY & PERSTR<=[F:PNH]RTNDAT & PEREND>=[F:PNH]RTNDAT
#   If [F:PNH]RTNDAT>=[F:PER]PERSTR &  [F:PNH]RTNDAT<=[F:PER]PEREND
      WSTA=[F:PER]PERSTOSTA  : Break
#   Endif
  Next
  #---- Message : période indéfinie ou traitement interdit à cette date -----#
  If WSTA<>1
    Call ECR_TRACE(mess(21,196,1),1) From GESECRAN
  Else
    #----- Vérification si habilité sur ce site -----#
    If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
      If !find(([F:PNH]PNHFCY),GUSRFCY(1..GNBAUZ))
        WMSG=[F:PNH]PNHNUM-mess(123,197,1)-[F:PNH]PNHFCY-mess(2,104,1)
        Call ECR_TRACE(WMSG,1) From GESECRAN
        Goto SUIT
      Endif
    Endif
    #-----
    Call PARAM([F:PNH]PNHFCY,"PURRMA",PARAMA) From ADOVAL
    If val(PARAMA)=2 & [F:PNH]AUZNUM=""
      Call ECR_TRACE(mess(137,197,1),1) From GESECRAN
    Else
      Call VALIDATION([F:PNH]PNHNUM,2,LRET) From TRTACHRET1
    Endif
  Endif
$SUIT
Next
If LRET=99  GERR=2 : GMESSAGE=mess(99,100,1) : Endif
If !GSERVEUR
  Call FERME_TRACE From LECFIC
Endif
Return


#####################################
# Fin après exécution du traitement #
#####################################
$TERMINE
If !GSERVEUR  TRA=1  Else  TRA=0 : Endif
Return


#######################################################
# Traitement du grisage et dégrisage des champs écran #
#######################################################
$GRISAGE
Return


##############################
# Ouverture des des fichiers #
##############################
$OPEN_FILE
If !clalev([F:PNH])   Local File PRETURN    [PNH] : Endif
If !clalev([F:PND])   Local File PRETURND   [PND] : Endif
If !clalev([F:PTH])   Local File PRECEIPT   [PTH] : Endif
If !clalev([F:PTD])   Local File PRECEIPTD  [PTD] : Endif
If !clalev([F:POH])   Local File PORDER     [POH] : Endif
If !clalev([F:POQ])   Local File PORDERQ    [POQ] : Endif
If !clalev([F:POP])   Local File PORDERP    [POP] : Endif
If !clalev([F:POC])   Local File PORDERC    [POC] : Endif
If !clalev([F:PPK])   Local File PPRICLINK  [PPK] : Endif
If !clalev([F:BPS])   Local File BPSUPPLIER [BPS] : Endif
If !clalev([F:BPR])   Local File BPARTNER   [BPR] : Endif
If !clalev([F:MVS])   Local File BPSUPPMVT  [MVS] : Endif
If !clalev([F:ITM])   Local File ITMMASTER  [ITM] : Endif
If !clalev([F:ITP])   Local File ITMBPS     [ITP] : Endif
If !clalev([F:ITV])   Local File ITMMVT     [ITV] : Endif
If !clalev([F:FCY])   Local File FACILITY   [FCY] : Endif
If !clalev([F:ITF])   Local File ITMFACILIT [ITF] : Endif
If !clalev([F:TUN])   Local File TABUNIT    [TUN] : Endif
If !clalev([F:STO])   Local File STOCK      [STO] : Endif
If !clalev([F:STL])   Local File STOLOT     [STL] : Endif
If !clalev([F:STJ])   Local File STOJOU     [STJ] : Endif
If !clalev([F:STA])   Local File STOALL     [STA] : Endif
If !clalev([F:ORD])   Local File ORDERS     [ORD] : Endif
#----- Ouverture des fichiers nécessaire à la gestion des numéros de série -----#
If !clalev([F:STS])   Local File STOSER     [STS] : Endif
#----- Ouverture des fichier nécessaires au budget -----#
If !clalev([F:PER])   Local File PERIOD     [PER] : Endif
If !clalev([F:TCO])   Local File TABCOEFF   [TCO] : Endif
If GMODU(2)=2 : # Test si présence du module comptabilité
  If !clalev([F:BUP]) Local File BUDPAR     [BUP] : Endif
Endif
#----- Chargement du compteur des encours -----#
If !clalev([F:TCA])   Local File TABCOUAFF  [TCA] : Endif
#-----
If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif
#-----
OK=1
Return


###################
# Si erreur Batch #
###################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
