#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################################
# Gestion du masque ITNH
######################################################################################
Subprog IB_NBITN
  # Détail Demande de service
  GBOUT1 = GBOUT1 - "(" + [M:ITNH]NUM(nolign-1) + ")"
  # Demande de service
  If [M:ITNH]FILTRE <> "SRE" Then
    GBOUT2 = GBOUT2 - "(" + [M:ITNH]SRENUMORI + ")"
  Else
    Raz GBOUT2
  Endif
  # Client
  If [M:ITNH]FILTRE <> "BPR" Then
    GBOUT3 = GBOUT3 - "(" + [M:ITNH]BPC(nolign-1) + ")"
  Else
    Raz GBOUT3
  Endif
  If [M:ITNH]SCO(nolign-1) = 2 Then
    # Sous-traitant
    If [M:ITNH]FILTRE <> "SCO" Then
      GBOUT4 = GBOUT4 - "(" + [M:ITNH]ITNASS(nolign-1) + ")"
    Else
      Raz GBOUT4
    Endif
    Raz GBOUT5
  Else
    # Intervenant
    Raz GBOUT4
    If [M:ITNH]FILTRE <> "AUS" Then
      GBOUT5 = GBOUT5 - "(" + [M:ITNH]ITNASS(nolign-1) + ")"
    Else
      Raz GBOUT5
    Endif
  Endif
  # Interlocuteur
  If [M:ITNH]FILTRE <> "CCN" Then
    If [M:ITNH]CCN(nolign-1) <> "" Then
      GBOUT6 = GBOUT6 - "(" + [M:ITNH]CCN(nolign-1) + ")"
    Else
      Raz GBOUT6
    Endif
  Else
    Raz GBOUT6
  Endif
End

######################################################################################
Subprog B2_NBITN
  # Filtre sur demande de service
  [M:ITNH]FILTRE = "SRE"
  [M:ITNH]VCRNUM = [M:ITNH]SRENUMORI
  [M:ITNH]VCRNUMCLA = func TRTITNH.GET_NAM_VCRNUM([M:ITNH]FILTRE, [M:ITNH]VCRNUM)
  Chgtzn [M:ITNH]VCRNUM With mess(287,196,1)
  Affzo [M:ITNH]5
  Call LOADHISITN From TRTITNH
End

######################################################################################
Subprog B3_NBITN
  # Filtre sur client
  [M:ITNH]FILTRE = "BPR"
  [M:ITNH]VCRNUM = [M:ITNH]BPC(nolign-1)
  [M:ITNH]VCRNUMCLA = func TRTITNH.GET_NAM_VCRNUM([M:ITNH]FILTRE, [M:ITNH]VCRNUM)
  Chgtzn [M:ITNH]VCRNUM With mess(78,117,1)
  Affzo [M:ITNH]5
  Call LOADHISITN From TRTITNH
End

######################################################################################
Subprog B4_NBITN
  # Filtre sur sous-traitant
  [M:ITNH]FILTRE = "SCO"
  [M:ITNH]VCRNUM = [M:ITNH]ITNASS(nolign-1)
  [M:ITNH]VCRNUMCLA = func TRTITNH.GET_NAM_VCRNUM([M:ITNH]FILTRE, [M:ITNH]VCRNUM)
  Chgtzn [M:ITNH]VCRNUM With mess(572,197,1)
  Affzo [M:ITNH]5
  Call LOADHISITN From TRTITNH
End

######################################################################################
Subprog B5_NBITN
Local Char LIBPAR(30)

  # Filtre sur intervenant
  [M:ITNH]FILTRE = "AUS"
  [M:ITNH]VCRNUM = [M:ITNH]ITNASS(nolign-1)
  [M:ITNH]VCRNUMCLA = func TRTITNH.GET_NAM_VCRNUM([M:ITNH]FILTRE, [M:ITNH]VCRNUM)
  Call TEXTE(15584, LIBPAR) From OBJDIV
  Chgtzn [M:ITNH]VCRNUM With LIBPAR
  Affzo [M:ITNH]5
  Call LOADHISITN From TRTITNH
End

######################################################################################
Subprog B6_NBITN
  # Filtre sur interlocuteur
  [M:ITNH]FILTRE = "AIN"
  [M:ITNH]VCRNUM = [M:ITNH]CCN(nolign-1)
  [M:ITNH]VCRNUMCLA = func TRTITNH.GET_NAM_VCRNUM([M:ITNH]FILTRE, [M:ITNH]VCRNUM)
  Chgtzn [M:ITNH]VCRNUM With mess(3,3032,1)
  Affzo [M:ITNH]5
  Call LOADHISITN From TRTITNH
End
