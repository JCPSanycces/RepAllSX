#----------------------------------------
# CHARGEMENT DE L'ONGLET ECARTS ENTRE
# PLANS
# @fq64544
#----------------------------------------
$LOAD_PSTLNK

If 1=1
 If G_ACTLNK<>G_OUI : Return : Endif
 Local Integer NOLNK

 Columns [DEP] (CPY,FCY,AASREF,CNX,DPRPLN,FIYENDDAT,PERENDDAT,PSTLNK)

 For [F:CNX] Where CPY=[M:FC0]CPY
  Local Integer I_PLN
  Local Integer L_PLN
  Local Integer I_DPRPLN
  Read [F:FIYC]FIY1=[M:FC0]CPY;[F:CNX]CNX;GVML_TECOURA
  Read [F:FIYS]FIY1=[M:FC0]CPY;[F:CNX]CNX;GVML_TESUIV

  For I_PLN=1 To [F:CNX]NBPLC
   L_PLN=[F:CNX]PLNCAA(I_PLN-1)
   GFLGPLNLNK(L_PLN)=G_NON
   If ![F:CNX]LNKPLN(I_PLN-1) : Goto NEXT_PLNLNK  : Endif
   I_DPRPLN=find([M:FPC]DPRPLNLED(find (L_PLN,[M:FPC]DPRPLNCNX)-1),[M:FPC]DPRPLN)
   Local Integer I_PER

   # Chargement du tableau invisible pour l'exercice courant

   For I_PER=1 To [F:FIYC]NBRPER
    If [F:FIYC]TYPPST(I_PER-1)=GVML_TPSTDEF
     Read [DEP]DEP0=[M:FC0]AASREF;L_PLN;[F:FIYC]DATENDFIY;[F:FIYC]DATENDPER(I_PER-1)
     If !fstat
      If [F:DEP]PSTLNK

       GFLGPLNLNK(L_PLN)=G_OUI

       # Montants comptabilisés

       [M:FC4]DPRPLNI([M:FC4]NBLNKI)    = [F:DEP]DPRPLN
       [M:FC4]STAFIYI([M:FC4]NBLNKI)    = GVML_TECOURA
       [M:FC4]FIYENDDATI([M:FC4]NBLNKI) = [F:DEP]FIYENDDAT
       [M:FC4]PERENDDATI([M:FC4]NBLNKI) = [F:DEP]PERENDDAT
       [M:FC4]PSTLNKI([M:FC4]NBLNKI)    = [F:DEP]PSTLNK

       # Imputations analytiques

       [M:FC4]DSPI([M:FC4]NBLNKI) = func GENEVE.GET_DSP_DAT([F:DEP]PERENDDAT,"[F:FAS]")
       If [M:FC4]DSPI([M:FC4]NBLNKI)=""
        Local Integer I_AXE
        Local Char    L_NOMCHAMP
        For I_AXE=1 To 9
         L_NOMCHAMP="[M:FC4]DIE"+num$(I_AXE)+"I([M:FC4]NBLNKI)"
         Assign L_NOMCHAMP With evalue("[M:FPC]DPRPLNDIE"+num$(I_AXE)+"("+num$(I_DPRPLN-1)+")")
         L_NOMCHAMP="[M:FC4]CCE"+num$(I_AXE)+"I([M:FC4]NBLNKI)"
         Assign L_NOMCHAMP With func GENEVE.GET_CCE_DAT([F:DEP]PERENDDAT,"[F:FAS]","","",L_PLN,evalue("[M:FC4]DIE"+num$(I_AXE)+"I([M:FC4]NBLNKI)"))
        Next I_AXE
       Endif

       # Cumuls exercices antérieurs

       If dim(LFIRST)<0
        [M:FC4]LNKCUMI([M:FC4]NBLNKI)    = [F:DEP]LNKCUM
        Local Integer LFIRST
       Endif

       [M:FC4]NBLNKI+=1
      Endif
     Endif
    Endif
   Next I_PER

   # Chargement du tableau invisible pour l'exercice suivant

   For I_PER=1 To [F:FIYS]NBRPER
    If [F:FIYS]TYPPST(I_PER-1)=GVML_TPSTDEF
     Read [DEP]DEP0=[M:FC0]AASREF;L_PLN;[F:FIYS]DATENDFIY;[F:FIYS]DATENDPER(I_PER-1)
     If !fstat
      If [F:DEP]PSTLNK
       GFLGPLNLNK(L_PLN)=G_OUI

       # Montants comptabilisés

       [M:FC4]DPRPLNI([M:FC4]NBLNKI)    = [F:DEP]DPRPLN
       [M:FC4]STAFIYI([M:FC4]NBLNKI)    = GVML_TESUIV
       [M:FC4]FIYENDDATI([M:FC4]NBLNKI) = [F:DEP]FIYENDDAT
       [M:FC4]PERENDDATI([M:FC4]NBLNKI) = [F:DEP]PERENDDAT
       [M:FC4]PSTLNKI([M:FC4]NBLNKI)    = [F:DEP]PSTLNK

       # Imputations analytiques

       [M:FC4]DSPI([M:FC4]NBLNKI) = func GENEVE.GET_DSP_DAT([F:DEP]PERENDDAT,"[F:FAS]")
       If [M:FC4]DSPI([M:FC4]NBLNKI)=""
        Local Integer I_AXE
        Local Char    L_NOMCHAMP
        For I_AXE=1 To 9
         L_NOMCHAMP="[M:FC4]DIE"+num$(I_AXE)+"I([M:FC4]NBLNKI)"
         Assign L_NOMCHAMP With evalue("[M:FPC]DPRPLNDIE"+num$(I_AXE)+"("+num$(I_DPRPLN-1)+")")
         L_NOMCHAMP="[M:FC4]CCE"+num$(I_AXE)+"I([M:FC4]NBLNKI)"
         Assign L_NOMCHAMP With func GENEVE.GET_CCE_DAT([F:DEP]PERENDDAT,"[F:FAS]","","",L_PLN,evalue("[M:FC4]DIE"+num$(I_AXE)+"I([M:FC4]NBLNKI)"))
        Next I_AXE
       Endif

       [M:FC4]NBLNKI+=1
      Endif
     Endif
    Endif
   Next I_PER

   # Préparation des événements d'annulation
   If GFLGPLNLNK(L_PLN)=G_OUI
    Call PREP_EVT_CNLLNK(L_PLN)
   Endif

   If dim(LFIRST)>0 : Kill LFIRST : Endif
  $NEXT_PLNLNK
  Next I_PLN
 Next
 Columns [DEP]
 Affzo [M:FC4]

 # Contrôle si il y a des montants comptabilisés

 If ![M:FC4]NBLNKI
  #Local Integer NOAMT
  NOLNK=1
  [M:FC4]DPRPLNLNK=0 : Diszo [M:FC4]DPRPLNLNK
 Else
  #> Chargement du premier plan pour lequel il y a des montants comptabilisés
  Local Integer LFIRPLN : LFIRPLN=find(G_OUI,GFLGPLNLNK)
  Call LOAD_LNK_TAB(LFIRPLN)
  Call LOAD_EVTLNK_TAB(LFIRPLN) From TRTFASCNLLNK
  Diszo [M:FC4]CPTDATINT
  [M:FC4]DPRPLNLNK = LFIRPLN : Affzo [M:FC4]DPRPLNLNK
  Call AV_NBLNK    From TRTFASCNLLNK
  #Call AV_NBLNKEVT From TRTFASCNLLNK
 Endif
Endif
Return

#----------------------------------------
# Chargement du tableau des écarts entre
# plans comptabilisés à partir du
# tableau invisible
#----------------------------------------
Subprog LOAD_LNK_TAB(PDPRPLN)
Value Integer PDPRPLN
 I_DEBPLAN = find(PDPRPLN,[M:FC4]DPRPLNI)
 If I_DEBPLAN
  Local Integer I_OCC
  Raz [M:FC4]NBLNK
  For I_OCC=I_DEBPLAN To [M:FC4]NBLNKI
   If [M:FC4]DPRPLNI(I_OCC-1)<>PDPRPLN : Break : Endif
    If [M:FC4]NBLNK<=1
     [M:FC4]STAFIY([M:FC4]NBLNK) = [M:FC4]STAFIYI(I_OCC-1)
    Elsif [M:FC4]NBLNK>1
     If [M:FC4]STAFIYI(I_OCC-1)<>[M:FC4]STAFIYI(I_OCC-2)
      [M:FC4]STAFIY([M:FC4]NBLNK) = [M:FC4]STAFIYI(I_OCC-1)
     Else
      [M:FC4]STAFIY([M:FC4]NBLNK) = 0
     Endif
    Endif
    [M:FC4]FIYENDDAT([M:FC4]NBLNK) = [M:FC4]FIYENDDATI(I_OCC-1)
    [M:FC4]PERENDDAT([M:FC4]NBLNK) = [M:FC4]PERENDDATI(I_OCC-1)
    [M:FC4]PSTLNK([M:FC4]NBLNK)    = [M:FC4]PSTLNKI(I_OCC-1)
    [M:FC4]DSP([M:FC4]NBLNK)       = [M:FC4]DSPI(I_OCC-1)
    For I=1 To 9
     CHAMP = "[M:FC4]CCE"+num$(I)+"([M:FC4]NBLNK)"
     Assign CHAMP With evalue("[M:FC4]CCE"+num$(I)+"I(I_OCC-1)")
    Next I
    [M:FC4]NBLNK+=1
  Next I_OCC
 Endif
 Affzo [M:FC4]10
End

#----------------------------------------
# Chargement du tableau des événements
# d'annulation à partir du tableau
# invisible
#----------------------------------------
Subprog LOAD_EVTLNK_TAB(PDPRPLN)
Value Integer PDPRPLN

 I_DEBPLAN = find(PDPRPLN,[M:FC4]IDPRPLN)
 If I_DEBPLAN
  Local Integer I_OCC, I
  Local Char    CHAMP
  Raz [M:FC4]NBLNKEVT
  For I_OCC=I_DEBPLAN To [M:FC4]NBLNKEVTI
   If [M:FC4]IDPRPLN(I_OCC-1)<>PDPRPLN : Break : Endif
    [M:FC4]EFIYSTA([M:FC4]NBLNKEVT)    = [M:FC4]IFIYSTA(I_OCC-1)
    [M:FC4]EVTDAT([M:FC4]NBLNKEVT)     = [M:FC4]IEVTDAT(I_OCC-1)
    [M:FC4]CPTDATINT([M:FC4]NBLNKEVT)  = [M:FC4]ICPTDATINT(I_OCC-1)
    [M:FC4]CPTDATSAV([M:FC4]NBLNKEVT)  = [M:FC4]ICPTDATSAV(I_OCC-1)
    [M:FC4]EPSTLNK([M:FC4]NBLNKEVT)    = [M:FC4]IPSTLNK(I_OCC-1)
    [M:FC4]EDSP([M:FC4]NBLNKEVT)       = [M:FC4]IDSP(I_OCC-1)
    For I=1 To 9
     CHAMP = "[M:FC4]ECCE"+num$(I)+"([M:FC4]NBLNKEVT)"
     Assign CHAMP With evalue("[M:FC4]ICCE"+num$(I)+"(I_OCC-1)")
    Next I
    [M:FC4]NBLNKEVT+=1
  Next I_OCC
 Endif
 Affzo [M:FC4]20
 Call AV_NBLNKEVT From TRTFASCNLLNK
End

#----------------------------------------
# Préparation des événements d'annulation
# d'écart de dotations entre plans
# à générer dans le tableau invisible
#----------------------------------------
Subprog PREP_EVT_CNLLNK(PDPRPLN)
Value Integer PDPRPLN

 I_DEBPLAN = find(PDPRPLN,[M:FC4]DPRPLNI)
 If I_DEBPLAN

  Local Char    CHAMP
  Local Integer I
  Local Integer I_OCC
  Local Integer R_FIY
  Local Integer S_FIY
  Local Integer R_CCE
  Local Char    S_CCE
  Local Char    C_CCE
  Local Decimal T_PSTLNK
  Local Decimal T_LNKCUM

  For I_OCC=I_DEBPLAN To [M:FC4]NBLNKI
   If [M:FC4]DPRPLNI(I_OCC-1)<>PDPRPLN : Break : Endif

   If I_OCC=I_DEBPLAN
    S_FIY=[M:FC4]STAFIYI(I_OCC-1)
    S_CCE=[M:FC4]DSPI(I_OCC-1)
    For I=1 To 9
     S_CCE+="~"+evalue("[M:FC4]CCE"+num$(I)+"I(I_OCC-1)")
    Next I_CCE
   Else
    # Rupture Exercice ?
    If S_FIY<>[M:FC4]STAFIYI(I_OCC-1) : R_FIY=1 : S_FIY=[M:FC4]STAFIYI(I_OCC-1) : Else : R_FIY=0 : Endif
    # Rupture analytique ?
    If PDPRPLN=G301CPT
     C_CCE=[M:FC4]DSPI(I_OCC-1)
     For I=1 To 9
      C_CCE+="~"+evalue("[M:FC4]CCE"+num$(I)+"I(I_OCC-1)")
     Next I_CCE
     If S_CCE<>C_CCE : R_CCE=1 : S_CCE=C_CCE : Else : R_CCE=0 : Endif
    Endif
   Endif

   # Rupture, on ajoute l'événement

   If R_FIY | R_CCE : Gosub ADD_CNLLNK_EVENT : Endif

   # Totalisation

   T_PSTLNK    += [M:FC4]PSTLNKI(I_OCC-1)

   If S_FIY=GVML_TECOURA & [M:FC4]FLGEXTANT=G_OUI & dim(LFIRST)<0
    Local Integer LFIRST
    T_LNKCUM    = [M:FC4]LNKCUMI(I_OCC-1)
   Endif

  Next I_OCC

  If [M:FC4]NBLNKI-I_DEBPLAN<>0 | I_OCC
   Gosub ADD_CNLLNK_EVENT
  Endif

  If dim(LPREM) >0 : Kill LPREM  : Endif
  If dim(LFIRST)>0 : Kill LFIRST : Endif
 Endif
End

#----------------------------------------
# Ajout d'un événement d'annulation de
# dotation si rupture
#----------------------------------------
$ADD_CNLLNK_EVENT
  [M:FC4]IFIYSTA([M:FC4]NBLNKEVTI)    = [M:FC4]STAFIYI(I_OCC-2)
  [M:FC4]IDPRPLN([M:FC4]NBLNKEVTI)    = PDPRPLN
  [M:FC4]IEVTDAT([M:FC4]NBLNKEVTI)    = [M:FC4]PERENDDATI(I_OCC-2)
  # DEB FQ90143
  #[M:FC4]ICPTDATINT([M:FC4]NBLNKEVTI) = [M:FC4]PERENDDATI(I_OCC-2)
  #[M:FC4]ICPTDATSAV([M:FC4]NBLNKEVTI) = [M:FC4]PERENDDATI(I_OCC-2)
  [M:FC4]ICPTDATINT([M:FC4]NBLNKEVTI) = PLNPERENDDAT(PDPRPLN-1)
  [M:FC4]ICPTDATSAV([M:FC4]NBLNKEVTI) = PLNPERENDDAT(PDPRPLN-1)
  # FIN FQ90143
  [M:FC4]IPSTLNK([M:FC4]NBLNKEVTI)    = T_PSTLNK
  [M:FC4]IDSP([M:FC4]NBLNKEVTI)       = [M:FC4]DSPI(I_OCC-2)
  For I=1 To 9
   CHAMP="[M:FC4]IDIE"+num$(I)+"([M:FC4]NBLNKEVTI)"
   Assign CHAMP With evalue("[M:FC4]DIE"+num$(I)+"I(I_OCC-2)")
   CHAMP="[M:FC4]ICCE"+num$(I)+"([M:FC4]NBLNKEVTI)"
   Assign CHAMP With evalue("[M:FC4]CCE"+num$(I)+"I(I_OCC-2)")
  Next I

  If [M:FC4]IFIYSTA([M:FC4]NBLNKI)=GVML_TECOURA & dim(LPREM)<0 & [M:FC4]FLGEXTANT=G_OUI
   Local Integer LPREM
   [M:FC4]ILNKCUM([M:FC4]NBLNKEVTI)    = T_LNKCUM
  Else
   Raz [M:FC4]ILNKCUM([M:FC4]NBLNKEVTI)
  Endif

  Raz T_PSTLNK
  Raz T_LNKCUM
  If R_FIY : R_FIY=0 : Endif
  If R_CCE : R_CCE=0 : Endif
  [M:FC4]NBLNKEVTI+=1
Return

######################################################################################
# ACTIONS CHAMPS ECRAN FASCNL4
######################################################################################

#----------------------------------------
Subprog AS_DPRPLNLNK(VALEUR)
Variable Integer VALEUR
 Local Integer I_PLN
 For I_PLN=1 To G301MAX-1
  If GFLGPLNLNK(I_PLN)<>G_OUI
   GMENLOC(I_PLN)=1
  Endif
 Next I_PLN
 GMENLOC(G301AUC)=1
End

#----------------------------------------
Subprog C_DPRPLNLNK(VALEUR)
Variable Integer VALEUR
 Raz [M:FC4]NBLNK, [M:FC4]NBLNKEVT
 Call LOAD_LNK_TAB(VALEUR) From TRTFASCNLLNK
 Call LOAD_EVTLNK_TAB(VALEUR)  From TRTFASCNLLNK
 [M:FC4]DPRPLNLNK=VALEUR
 Local Char LCCE
 Call AV_CCE1(LCCE) From TRTFASCNLLNK
 Call AV_ECCE1(LCCE) From TRTFASCNLLNK
 Call AV_NBLNK From TRTFASCNLLNK
#Call AV_NBLNKEVT From TRTFASCNLLNK
End

#----------------------------------------
Subprog AM_DPRPLNLNK(VALEUR)
Variable Integer VALEUR
 Raz [M:FC4]NBLNK
 Call LOAD_LNK_TAB(VALEUR)
End

#----------------------------------------
Subprog AP_DPRPLNLNK(VALEUR)
Variable Integer VALEUR
End

#----------------------------------------
Subprog AV_NBLNK
 Local Integer I_LED
 Local Integer I_PLNLED
 Local Integer LPLNLED

 I_PLNLED = find([M:FC4]DPRPLNLNK,[M:FPC]DPRPLNCNX)
 LPLNLED  = [M:FPC]DPRPLNLED(I_PLNLED-1)
 I_LED    = find(LPLNLED,[M:FPC]DPRPLN)

 If I_LED
  Local Integer I_DIE
  Local Char    LFORMAT
  For I_DIE=1 To 9
   If evalue("[M:FPC]DPRPLNDIE"+num$(I_DIE)+"("+num$(I_LED-1)+")=''")
    LFORMAT="-K:"+num$(GLONCCE)+"X"
    GTITDIE(I_DIE)=""
   Else
    LFORMAT="K:"+num$(GLONCCE)+"X"
    GTITDIE(I_DIE)=evalue("[M:FPC]DPRPLNDIE"+num$(I_DIE)+"("+num$(I_LED-1)+")")
   Endif
   Case I_DIE
    When 1 : Chgfmt [M:FC4]CCE1 With LFORMAT
    When 2 : Chgfmt [M:FC4]CCE2 With LFORMAT
    When 3 : Chgfmt [M:FC4]CCE3 With LFORMAT
    When 4 : Chgfmt [M:FC4]CCE4 With LFORMAT
    When 5 : Chgfmt [M:FC4]CCE5 With LFORMAT
    When 6 : Chgfmt [M:FC4]CCE6 With LFORMAT
    When 7 : Chgfmt [M:FC4]CCE7 With LFORMAT
    When 8 : Chgfmt [M:FC4]CCE8 With LFORMAT
    When 9 : Chgfmt [M:FC4]CCE9 With LFORMAT
   Endcase
  Next I_DIE
 Endif
End

#----------------------------------------
Subprog AV_CCE1(VALEUR)
Variable Char    VALEUR()
 #Vide
End

#----------------------------------------
Subprog AP_FLGEXTANT(VALEUR)
Variable Integer VALEUR
 Raz [M:FC4]NBLNKEVTI, [M:FC4]NBLNKEVT
 Local Integer I_PLN
 For I_PLN=1 To G301MAX-1
  If GFLGPLNLNK(I_PLN)=G_OUI
   [M:FC4]FLGEXTANT=VALEUR
   Call PREP_EVT_CNLLNK(I_PLN) From TRTFASCNLLNK
  Endif
 Next I_PLN
 Affzo [M:FC4]25
 Call LOAD_EVTLNK_TAB([M:FC4]DPRPLNLNK) From TRTFASCNLLNK
End

#----------------------------------------
Subprog AM_FLGUPDDAT(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_NON
  Raz [M:FC4]NBLNKEVT
  Local Integer I
  For I=1 To [M:FC4]NBLNKEVTI
   [M:FC4]ICPTDATINT(I-1)=[M:FC4]ICPTDATSAV(I-1)
  Next I
  Diszo [M:FC4]CPTDATINT
  Affzo [M:FC4]CPTDATINT
  Call LOAD_EVTLNK_TAB([M:FC4]DPRPLNLNK) From TRTFASCNLLNK
 Else
  Actzo [M:FC4]CPTDATINT
  Affzo [M:FC4]CPTDATINT
 Endif

End

#----------------------------------------
Subprog AV_NBLNKEVT
 Local Integer I_LED
 Local Integer I_PLNLED
 Local Integer LPLNLED

 I_PLNLED = find([M:FC4]DPRPLNLNK,[M:FPC]DPRPLNCNX)
 LPLNLED  = [M:FPC]DPRPLNLED(I_PLNLED-1)
 I_LED    = find(LPLNLED,[M:FPC]DPRPLN)

 If I_LED
  Local Integer I_DIE
  Local Char    LFORMAT
  For I_DIE=1 To 9
   If evalue("[M:FPC]DPRPLNDIE"+num$(I_DIE)+"("+num$(I_LED-1)+")=''")
    LFORMAT="-K:"+num$(GLONCCE)+"X"
    GTITDIE(I_DIE)=""
   Else
    LFORMAT="K:"+num$(GLONCCE)+"X"
    GTITDIE(I_DIE)=evalue("[M:FPC]DPRPLNDIE"+num$(I_DIE)+"("+num$(I_LED-1)+")")
   Endif
   Case I_DIE
    When 1 : Chgfmt [M:FC4]ECCE1 With LFORMAT
    When 2 : Chgfmt [M:FC4]ECCE2 With LFORMAT
    When 3 : Chgfmt [M:FC4]ECCE3 With LFORMAT
    When 4 : Chgfmt [M:FC4]ECCE4 With LFORMAT
    When 5 : Chgfmt [M:FC4]ECCE5 With LFORMAT
    When 6 : Chgfmt [M:FC4]ECCE6 With LFORMAT
    When 7 : Chgfmt [M:FC4]ECCE7 With LFORMAT
    When 8 : Chgfmt [M:FC4]ECCE8 With LFORMAT
    When 9 : Chgfmt [M:FC4]ECCE9 With LFORMAT
   Endcase
  Next I_DIE
 Endif
End

#----------------------------------------
Subprog AP_CPTDATINT(VALEUR)
Variable Date    VALEUR
 Local Integer LPLAN
 Local Date    LEVTDAT
 Local Integer I

 LPLAN  =[M:FC4]DPRPLNLNK
 LEVTDAT=[M:FC4]EVTDAT(nolign-1)
 For I=1 To [M:FC4]NBLNKEVTI
  If [M:FC4]IDPRPLN(I-1)=LPLAN &
&    [M:FC4]IEVTDAT(I-1)=LEVTDAT
   [M:FC4]ICPTDATINT(I-1)=VALEUR
   Break
  Endif
 Next I
End

#----------------------------------------
Subprog AV_ECCE1(VALEUR)
Variable Char    VALEUR()
 #vide
End
