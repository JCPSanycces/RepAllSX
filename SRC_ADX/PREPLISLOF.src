#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################################
# Programme : PREPLISLOF                                                                #
#                                                                                       #
# Fonction  :                                                                           #
#      1- Managment of the table TMPLISLOF                                              #
#    Modification :
# UUUUU jj.mm.aaaa nnnnnn_nn Cccccccccccccccccccccccccccccccccccccccccccccccccccccccc
# MDJ   03.02.2016 114161    Intitulés Code comptable absents (en sqlserver)
# MDJ   09/02/2015 FQ100398  Suppression site géographique
# CBO   29/04/2014 FQ-69690  Objet FAM
# MDJ   15/01/2014 FQ-XXXXX  Creation of the standard processing for the report LISLOF
#########################################################################################

######################################################################################
$ACTION

    Case ACTION
        When "OUVRE" :   Gosub OUVRE
        When "EXEC"  :   Gosub EXEC
        When "FIN"   :   Gosub FIN
    Endcase
Return
######################################################################################
$OUVRE
#=============================================================================
# traitement PRESITU : alimentation de la table TMPLISLOF
#=============================================================================
If clalev([F:TLI])=0    : Local File TMPLISLOF [TLI] : Endif
If clalev([F:TLIM])=0   : Local File TMPLISLOF [TLIM] : Endif

If clalev([F:LOF])=0   : Local File LAYOUTFAS   [LOF]  : Endif
If clalev([F:CCE])=0   : Local File CACCE       [CCE]  : Endif
If clalev([F:DSP])=0   : Local File CADSP       [DSP]  : Endif

If clalev([F:CPY])=0   : Local File COMPANY     [CPY] : Endif
If clalev([F:GCM])=0   : Local File GACM        [GCM] : Endif
If clalev([F:LED])=0   : Local File GLED        [LED] : Endif
If clalev([F:DIE])=0   : Local File GDIE        [DIE] : Endif

If clalev([F:FCY])=0   : Local File FACILITY    [FCY]  : Endif  # Financial sites

If clalev([F:CAC])=0   : Local File GACCCODE    [CAC]  : Endif  # Accounting code
If clalev([F:GACC])=0  : Local File GACCOUNT    [GACC] : Endif  # CoA account
If clalev([F:GACI])=0  : Local File GACCOUNT    [GACI] : Endif  # IAS account

If clalev([F:BPR])=0  : Local File BPARTNER     [BPR] : Endif   # Supplier

If clalev([F:ADI])=0  : Local File ATABDIV      [ADI] : Endif   # Miscellaneous table  (Family, Activity, UGT... )
If clalev([F:AFF])=0  : Local File AFCTFCY      [AFF] : Endif   # Site profile function

If clalev([FAM])=0 : Local File FASFAM [FAM] : Endif

Return
######################################################################################
$FIN

Unlock PREPLISLOF

Return
######################################################################################
$EXEC

Lock PREPLISLOF With lockwait = 3
If fstat
   Return
Endif

Gosub MAJ_TMPLISLOF

Return
###################################################
$MAJ_TMPLISLOF
#------------------------------------------------------------------------------------#
#--- Création table temporaire TMPLISLOF pour l'état LISLOF                       ---#
#------------------------------------------------------------------------------------#

   Gosub OUVRE

    Local Integer I, I_COA      # Compteur paramètres / Indices
    Local Integer RCNX, WCNX
    Local Char LCPY              # Company deb
    Local Char LCPYDEB          # Company deb
    Local Char LCPYFIN          # Company fin
    Local Char LFCYDEB          # Finacial site deb
    Local Char LFCYFIN
    Local Char LCCPTDEB         # Accounting code deb
    Local Char LCCPTFIN         #                fin
    Local Char LACCDEB          # CoA account deb
    Local Char LACCFIN          #            fin
    Local Char LIASACDEB        # IAS account deb
    Local Char LIASACFIN        #            fin
    Local Char LDIE             # Axe
    Local Char LCCEDEB          #  Section déb
    Local Char LCCEFIN          #  Section fin
    Local Char LACGGRPDEB       # Family  deb
    Local Char LACGGRPFIN       #         fin
    Local Char LJOUDEB          #Journal  deb
    Local Char LJOUFIN          #         fin

    Local Char LBPRDEB       # Supplier  deb
    Local Char LBPRFIN       #       fin
    Local Char LACTDEB       # Activity  deb
    Local Char LACTFIN       #           fin
    Local Char LUGTDEB       #  UGT  deb
    Local Char LUGTFIN       #           fin
    Local Char LPLNDEB       #  Invest Project  deb
    Local Char LPLNFIN       #           fin
    Local Char LBUDDEB       #  Invest Budget  deb
    Local Char LBUDFIN       #           fin
    Local Char LCONDEB       #  Marché  deb
    Local Char LCONFIN       #           fin

    Local Date   LDATIMPDEB     # Posting date début
    Local Date   LDATIMPFIN     # Date fin

    Local Integer LDET          # Detail ?

    Local Integer  LEDTNUM       # Identifiant session

    Local Char     LCRITERE  (250) # Critère de sélection
    Local Char     LCRITERE2 (250) # Critère de sélection
    Local Char     LCRITERE3 (250) # Critère de sélection
    Local Char     LCRITANA  (250) # Critère de sélection

    Local Char     SCPY         #  Company
    Local Char     SFCY         #* Financial site
    Local Char     X3PRF        #* Code profil user
    Local Char     X3FCT        #* Fonction
    Global Char    GWCOA        #* Plan de compte

    Local Integer  NBAXE
    Local Char     AXE(GLONDIE)(1..3)

    If clalev([TLI])=0 : Local File TMPLISLOF [TLI] : Endif
    Trbegin [TLI]
    Delete [TLI] Where CREUSR = GUSER
    If fstat = 1
      #  "Problème à l'effacement du fichier temporaire"
      Call MESSAGE (mess(155,197,1)) From GESECRAN
      Rollback
      Return
    Else
       Commit
    Endif

   Call GETPARAM("cpydeb",NBPAR,PARAMETRE,LCPYDEB)
   Call GETPARAM("cpyfin",NBPAR,PARAMETRE,LCPYFIN)

   Call GETPARAM("fcydeb",NBPAR,PARAMETRE,LFCYDEB)
   Call GETPARAM("fcyfin",NBPAR,PARAMETRE,LFCYFIN)

   Call GETPARAM("accdeb",NBPAR,PARAMETRE,LACCDEB)
   Call GETPARAM("accfin",NBPAR,PARAMETRE,LACCFIN)

   Call GETPARAM("accifrsdeb",NBPAR,PARAMETRE,LIASACDEB)
   Call GETPARAM("accifrsfin",NBPAR,PARAMETRE,LIASACFIN)

   Call GETPARAM("axe",NBPAR,PARAMETRE,LDIE)
   Call GETPARAM("secdeb",NBPAR,PARAMETRE,LCCEDEB)
   Call GETPARAM("secfin",NBPAR,PARAMETRE,LCCEFIN)

   Call GETPARAM("acggrpdeb",NBPAR,PARAMETRE,LACGGRPDEB)
   Call GETPARAM("acggrpfin",NBPAR,PARAMETRE,LACGGRPFIN)

   Call GETPARAM("bprdeb",NBPAR,PARAMETRE,LBPRDEB)
   Call GETPARAM("bprfin",NBPAR,PARAMETRE,LBPRFIN)

   Call GETPARAM("actdeb",NBPAR,PARAMETRE,LACTDEB)
   Call GETPARAM("actfin",NBPAR,PARAMETRE,LACTFIN)

  Call GETPARAM("ugtdeb",NBPAR,PARAMETRE,LUGTDEB)
  Call GETPARAM("ugtfin",NBPAR,PARAMETRE,LUGTFIN)

   Call GETPARAM("plndeb",NBPAR,PARAMETRE,LPLNDEB)
   Call GETPARAM("plnfin",NBPAR,PARAMETRE,LPLNFIN)

  Call GETPARAM("buddeb",NBPAR,PARAMETRE,LBUDDEB)
  Call GETPARAM("budfin",NBPAR,PARAMETRE,LBUDFIN)

  Call GETPARAM("condeb",NBPAR,PARAMETRE,LCONDEB)
  Call GETPARAM("confin",NBPAR,PARAMETRE,LCONFIN)

  Call GETPARAM("joudeb",NBPAR,PARAMETRE,LJOUDEB)
  Call GETPARAM("joufin",NBPAR,PARAMETRE,LJOUFIN)

   Call GETPARAM("datimpdeb",NBPAR,PARAMETRE,PARAM)    : LDATIMPDEB  =  PARAM
   Call GETPARAM("datimpfin",NBPAR,PARAMETRE,PARAM)    : LDATIMPFIN  =  PARAM


   Call GETPARAM("detail",NBPAR,PARAMETRE,PARAM)    : LDET       = val(PARAM)
   Call GETPARAM("edtnum",NBPAR,PARAMETRE,PARAM)    : LEDTNUM    = val(PARAM)

   Call GETPARAM("X3PRF",NBPAR,PARAMETRE,X3PRF)
   Call GETPARAM("X3FCT",NBPAR,PARAMETRE,X3FCT)

   LCRITERE  = "1=1"
   LCRITERE2 = "1=1"
   LCRITERE3 = "1=1"
   LCRITANA  = "1=1"

   For I=1 To NBPAR
      J=instr(1,[L]PARAMETRE(I),"=")
      If J
         [L]PARAM  = left$([L]PARAMETRE(I),J-1)
         [L]VALEUR = right$([L]PARAMETRE(I),J+1)
         Case [L]PARAM

            When "cpydeb"     :     LCRITERE += "& CPY >='"+LCPYDEB+"'"
            When "cpyfin"     :     LCRITERE += "& CPY <='"+LCPYFIN+"'"

            When "fcydeb"     :     LCRITERE += "& FCY>='"+LFCYDEB+"'"
            When "fcyfin"     :     LCRITERE += "& FCY<='"+LFCYFIN+"'"

            When "ccptdeb"    :     LCRITERE += "& ACCCOD>='"+LCCPTDEB+"'"
            When "ccptfin"    :     LCRITERE += "& ACCCOD<='"+LCCPTFIN+"'"

            When "accdeb"     :     LCRITERE += "& GAC>='"+LACCDEB+"'"
            When "accfin"     :     LCRITERE += "& GAC<='"+LACCFIN+"'"

            When "accifrsdeb" :     LCRITERE += "& IASACC>='"+LIASACDEB+"'"
            When "accifrsfin" :     LCRITERE += "& IASACC<='"+LIASACFIN+"'"

            When "acggrpdeb"  :     LCRITERE2 += "& ACGGRP >='"+LACGGRPDEB+"'"
            When "acggrpfin"  :     LCRITERE2 += "& ACGGRP <='"+LACGGRPFIN+"'"

            When "bprdeb"     :     LCRITERE2 += "& BPR >='"+LBPRDEB+"'"
            When "bprfin"     :     LCRITERE2 += "& BPR <='"+LBPRFIN+"'"

            When "ugtdeb"     :     LCRITERE2 += "& IASCGU >='"+LUGTDEB+"'"
            When "ugtfin"     :     LCRITERE2 += "& IASCGU <='"+LUGTFIN+"'"

            When "plndeb"     :     LCRITERE2 += "& PLNINV >='"+LPLNDEB+"'"
            When "plnfin"     :     LCRITERE2 += "& PLNINV <='"+LPLNFIN+"'"

            When "buddeb"     :     LCRITERE2 += "& BUDINV >='"+LBUDDEB+"'"
            When "budfin"     :     LCRITERE2 += "& BUDINV <='"+LBUDFIN+"'"

            When "condeb"     :     LCRITERE3 += "& CONNUM >='"+LCONDEB+"'"
            When "confin"     :     LCRITERE3 += "& CONNUM <='"+LCONFIN+"'"

            When "joudeb"     :     LCRITERE3 += "& JOU >='"+LJOUDEB+"'"
            When "joufin"     :     LCRITERE3 += "& JOU <='"+LJOUFIN+"'"

            When "datimpdeb"  :
            If LDATIMPDEB >  [01/01/1900]
               LCRITERE3 +=  "& DATIMP >= ["+format$(GFMD,LDATIMPDEB)+"]"
               LCRITERE3 +=  "& DATIMP <= ["+format$(GFMD,LDATIMPFIN)+"]"
            Else
               LCRITERE3 +=  "& DATIMP <= ["+format$(GFMD,LDATIMPFIN)+"]"
            Endif
         Endcase
      Endif
   Next

 Read [CPY]CPY0 = LCPYDEB
 Read [GCM]GCM0 = [F:CPY]ACM

  If LDIE <> ""
    If LCPYDEB <> LCPYFIN
       # Axe non pris en compte si état multi-sociétés
       Call MESSAGE ( mess(64,7784,1)) From GESECRAN
       GOK = 0 : Return
    Endif

    Local Mask FASPARCPY [FPC]
    Local Integer ERROR
    Raz [M:FPC]

    Call LOAD_FASPARCPY(LCPYDEB,"FPC",G_NON,ERROR) From GLOFCYCPY
    Local Integer IDX_AXE
    IDX_AXE=find(LDIE,[M:FPC]DIE)

    LCRITANA += "& [F:LOF]DIE(" + num$(IDX_AXE-1) + ") = '" + LDIE + "'"

    If (LCCEDEB <> "") & (LCCEDEB = LCCEFIN)
       LCRITANA += "&  [F:LOF]CCE(" + num$(IDX_AXE-1) + ") = '" + LCCEDEB + "'"
    Else
       If LCCEDEB <>""
          LCRITANA += "& [F:LOF]CCE(" + num$(IDX_AXE-1) + ") >= '" + LCCEDEB + "'"
          LCRITANA += "& [F:LOF]CCE(" + num$(IDX_AXE-1) + ") <= '" + LCCEFIN + "'"
       Endif
    Endif
 Else
    If LCCEDEB <> ""
       # Section interdite si axe non saisi
       Call MESSAGE ( mess(65,7784,1)) From GESECRAN
       GOK = 0 : Return
    Endif
 Endif
 #--------------------------------
   If clalev([TLI])=0 : Local File TMPLISLOF [TLI] : Endif
   Trbegin [TLI]
   Delete [TLI] Where CREUSR = GUSER
   If fstat=1 | fstat>5
      Rollback
    Else
        Commit
   Endif

   #
   Trbegin [TLI]
   SFCY= ""
   GWCOA= ""

   Filter [LOF] Where  (evalue(LCRITERE) ) & (evalue (LCRITERE2)) & (evalue (LCRITERE3)) & (evalue (LCRITANA) )
   For [LOF]LOF0
      If [F:LOF]FCY <> SFCY
         Read[FCY]FCY0=[F:LOF]FCY
         If [F:FCY]LEGCPY <> [F:LOF]CPY
            SFCY= [F:LOF]FCY
            Goto NEXTLOF
         Endif
         Read [AFF]AFF0 = [F:LOF]FCY;X3PRF;X3FCT
         If fstat <> 0
            SFCY= [F:LOF]FCY
            Goto NEXTLOF
         Endif
         SFCY= [F:LOF]FCY
      Endif
      #1------------
      Raz [F:TLIM]
      [F:TLIM] = [F:LOF]
      #=========================================================
      # Récupération des intitulés des champs
      #=========================================================
      Read [CPY]CPY0    = [F:LOF]CPY
      If fstat=0 :     [F:TLIM]CPYNAM    = [F:CPY]CPYNAM  : Endif
      Read [FCY]FCY0    = [F:LOF]FCY
      If fstat=0 :     [F:TLIM]FCYNAM    = [F:FCY]FCYNAM : Endif
      [F:TLIM]AASDES1   = [F:LOF]AASDES1
      # Issue 114161  READ[CAC]CAC0="15";[F:FAS]ACCCOD;GWCOA
      Read[CAC]CAC0=15;[F:FAS]ACCCOD;GWCOA
      If fstat=0
         Call LECTEXTRA([F:TLIM]ACCDES,"GACCCODE","DESTRA","15",[F:LOF]ACCCOD) From ATEXTRA
         # Issue 114161 [F:TLIM]ACCDES=[F:CAC]DESTRA
      Endif
      Read[GACC]GAC0=GWCOA;[F:LOF]GAC
      If fstat=0
         Call LECTEXTRA([F:TLIM]GACDES,"GACCOUNT","DESTRA",GWCOA,[F:LOF]GAC) From ATEXTRA
      Endif
      Read[GACI]GAC0=GWCOA;[F:LOF]IASACC :
      If fstat=0
         Call LECTEXTRA([F:TLIM]IASACCDES,"GACCOUNT","DESTRA",GWCOA,[F:LOF]IASACC) From ATEXTRA
      Endif

      Read[DSP]DSP0=[F:LOF]DSP;1
      If fstat=0
       [F:TLIM]DSPDES = [F:DSP]DESTRA
      Endif
      [F:TLIM]OWNTYPDEB=mess(LTYPDETDEB,3171,1)
      [F:TLIM]OWNTYPFIN=mess(LTYPDETFIN,3171,1)


      #* Récupération des intitulés de l'axe et des sections
      [F:TLIM]DIE=LDIE
      Read [F:FAM]FAM0 = [F:LOF]ACGGRP
#      Read [ADI]CODE = GTD_FAMCPT;[F:LOF]ACGGRP
      If fstat=0
         Call LECTEXTRA ([F:TLIM]ACGGRPDES, "FASFAM", "FAMDES", [F:LOF]ACGGRP, "") From ATEXTRA
#         Call LECTEXTRA ([F:TLIM]ACGGRPDES, "ATABDIV", "LNGDES", num$(GTD_FAMCPT), [F:ADI]CODE) From ATEXTRA
      Endif
      Read [ADI]CODE = 613;[F:LOF]IASCGU
      If fstat=0
         Call LECTEXTRA ([F:TLIM]IASCGUDES, "ATABDIV", "LNGDES", "613", [F:ADI]CODE) From ATEXTRA
      Endif
      #=========================================================
       [F:TLI]=[F:TLIM]
       [F:TLI]EDTNUM = LEDTNUM
       [F:TLI]CREUSR = GUSER
       [F:TLI]CREDAT = date$
       Write [F:TLI]
       If fstat <> 0
          GOK=0
          Rollback
          Unlock[TLI]
          Break
       Else
          Commit
          Unlock[TLI]
       Endif
      #1------------
      $NEXTLOF
   Next # [LOF]
   Filter[LOF]

 If GOK : Commit : Else Rollback : Endif

Unlock PREPLISLOF

Return
######################################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
End
####################################################
#================================================================
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L

   Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
   L = len(PARAM)
   If right$(PARAM,L-2)="deb"
      If VALEUR=string$(len(VALEUR)," ")
          VALEUR = ""
      Endif
   Endif

End
####################################################

