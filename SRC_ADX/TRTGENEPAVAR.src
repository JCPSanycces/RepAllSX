#FRLAA - 2016-12-05 - REQUIREMENT X3-11647 US X3-12771 - START
Funprog CREATE_EPA_VARIABLE
Local Integer WRET, ERROR_COUNT, VARERROR, X, K,KDUP, RECORDSCREATE, MAXEPA : ERROR_COUNT = 0 : WRET = 0 : RECORDSCREATE = 0 : VARERROR = 0
Local Char ALLFIELDS
Local Char VARDESC, VARNAM, VARNAMCHECK
Local Char EPAELEMENT(7)(7)
LOANELEMENT(0) = "CAPVRA"

#Getting the maximum number of external payments per employee allowed for this payment type
#This will be used to create the correct number of variables for the payment type
MAXEPA = [M:EPATYP0]MAXEPA

#Checking if there are any duplicate descriptions per line
For I = 0 To [M:EPATYP1]EPAVARNBR-1
  For K = 1 To 4 # Fixed per element ( Installment, Admin etc)
    For KDUP = 1 To 4
      If KDUP <> K
        VARNAM      = num$(evalue("[M:EPATYP1]"+num$(mess(K,010660,1))+"("+num$(I)+")"))
        VARNAMCHECK = num$(evalue("[M:EPATYP1]"+num$(mess(KDUP,010660,1))+"("+num$(I)+")"))
        If VARNAM = VARNAMCHECK
          If VARNAM <> ""
           VARERROR = 1 : Break
          Endif
        Endif
      Endif
    Next KDUP
  Next K
Next I

If VARERROR = 1
  Call ERREUR(mess(00069,00104,1)-num$(VARNAM)) From GESECRAN
  End
Endif


#Creating/Updating variables for the Payment types
If clalev([F:VRA]) = 0 : Local File VARIA     [VRA]         : Endif
Filter [VRA]
#Clear the variable table
Lock [VRA]
If fstat=0
  Delete [VRA] Where CMT(2) ="EPA_"-num$([M:EPATYP0]EPATYP)
  Unlock [VRA]
Endif

#Opening the trace file
TIT = mess(00005,10661,1)
Call OUVRE_TRACE(TIT) From LECFIC

#Setting the heading
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN

Trbegin [VRA]

For I = 0 To [M:EPATYP1]EPAVARNBR-1
  ALLFIELDS = [M:EPATYP1]INSVAR(I)+[M:EPATYP1]ADMVAR(I)+[M:EPATYP1]ADDPAYVAR(I)+[M:EPATYP1]BALVAR(I)
  If ALLFIELDS = "" : Break : Endif
  For K = 1 To 4 #Fixed per element ( Installment, Admin etc)
    VARDESC = func GETVARDESC(K)
    If num$(evalue("[M:EPATYP1]"+num$(mess(K,010660,1))+"("+num$(I)+")")) <> ""
      #For X = 1 To 5  #Parameter to be added to control
      For X = 1 To MAXEPA
        [F:VRA]COD = num$(evalue("[M:EPATYP1]"+num$(mess(K,010660,1))+"("+num$(I)+")"))+num$(X)
        #[F:VRA]DES = VARDESC - "-" - left$([M:EPATYP0]EPATYP,10)
        [F:VRA]CMT(1) = mess(00008,010661,1)
        [F:VRA]CMT(2) = "EPA_"-num$([M:EPATYP0]EPATYP)
        [F:VRA]FLGEMP = 2
        [F:VRA]PAGEMP = [M:EPATYP0]PAGEMP
        [F:VRA]LEG = [M:EPATYP0]LEG
        #[F:VRA]TYPINI = 2 #Cancellation
        Write [VRA]
        If fstat = 1
          Call ECR_TRACE(num$(mess(7,00021,1))- "EPA_"-num$([M:EPATYP0]EPATYP)-num$(evalue("[M:EPATYP1]"+num$(mess(K,010660,1))+"("+num$(I)+")"))+num$(X) ,1) From GESECRAN
          Break
        Else
          Call MAJTEXTRA(VARDESC - "-" - left$([M:EPATYP0]EPATYP,10),"VARIA","DES",[M:EPATYP0]LEG,[F:VRA]COD) From ATEXTRA
          Call ECR_TRACE(mess(00042,00187,1) - mess(00005,010661,1)-num$(evalue("[M:EPATYP1]"+num$(mess(K,010660,1))+"("+num$(I)+")"))+num$(X),0) From GESECRAN
        Endif
      Next X
    Endif
  Next K
Next I

If ERROR_COUNT = 1
  Rollback
Else
  #Commit if all write statements successful
  Commit
Endif

Call FERME_TRACE From LECFIC
# Lecture de la trace, sinon avec la nouvelle étiquette EXEC, on ne la voit pas
Call LEC_TRACE From LECFIC

End WRET

$WRITEINSTRUCT
Write [VRA]
If fstat = 1
  ERROR_COUNT = 1
Else
  RECORDSCREATE +=1
Endif
Return


Funprog GETVARDESC(LOCMENNUM)
Value Integer LOCMENNUM
Local Char WRET
WRET = num$(mess(LOCMENNUM,010662,1))

End WRET


#FRLAA - 2016-12-05 - REQUIREMENT X3-11647 US X3-12771 - END


