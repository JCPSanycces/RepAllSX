############################################################
$SUPPRIME
  Local Char     MESSAGE(250), PROCESS(100), OUTPUT_LOGNAME(100)
  Local Integer  NOL, LECTRACE
  Local Instance FICLOG Using C_ALOG

  # 2018-01-13 - JPGA X3-64517 : Adding-session-kill-button-in-PSADX-APSDX
  If this.NBAPSADXP>0
    # We retreive the list of Processes for the Session given by the current record
    Raz PROCESS
    [L]LECTRACE=[V]CST_AYES
    For NOL=1 To this.NBAPSADXP
      If this.APSADXP(NOL).NUMERO<>""
        PROCESS -= this.APSADXP(NOL).NUMERO
      Endif
    Next NOL

    # We initiate the Session closure calling a SYRACUSE function
    MESSAGE=this.CLIENT-this.DOSSIER-this.PORT-this.USER
    [L]LECTRACE=[V]CST_AYES

    Call CLOSE_SOCKET_WITH_LOG(this.ID, this, PROCESS, MESSAGE, [L]LECTRACE, [L]OUTPUT_LOGNAME) From ASESSIONS
  Endif
Return

#----------------------------------------------------------------#
# Permet de killer un processus
#----------------------------------------------------------------#

Subprog KILLPROC(ACTX,MACHINE,PROCESS,MESSA,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char    MACHINE , PROCESS , MESSA
Variable Char ERRMES
Local Char    WCMDE(250)(1..2) , FICTRA(GDIMFIC)
Local Char    MESSAGE(80)(1..5) , OS(20) , MOTIF(GLONADI)
Local Integer K , STAT , OK
ERRMES = ""
#Call GET_OS(MACHINE,OS) From ORDSYS
Call GET_OS(ACTX,MACHINE,OS) From ASYRSYS
$KILL_OS
Case OS
 When "unix" : WCMDE(1) = "killadx -9"-PROCESS
 When "dos"  : WCMDE(1) = "killadx"-PROCESS
 When ""
  If !(left$(MACHINE,1)>="0" & left$(MACHINE,1)<="9")
   K = instr(1,MACHINE,".")
   If K
    MACHINE = left$(MACHINE,K-1)
    #Call GET_OS(MACHINE,OS) From ORDSYS
    Call GET_OS(ACTX,MACHINE,OS) From ASYRSYS
   Endif
  Endif
  If OS="" | !find(OS,"unix","dos")
   ERRMES = mess(54,115,1)-PROCESS-":"-MACHINE-mess(199,100,1) : # Machine inaccessible
   End
  Endif
  Goto KILL_OS
Endcase
FICTRA = filpath("tmp","psadx_"+num$(adxuid(2)),"tra",nomap)
Openo FICTRA,0 Using [TR_]
Openo Using [TR_]
WCMDE(2)  = FICTRA

#Call SYSTEME(MACHINE,WCMDE,"",STAT) From ORDSYS
Call SYSTEME(ACTX,MACHINE,WCMDE,"",STAT) From ASYRSYS

If STAT
 # Erreur
 ERRMES = mess(6,123,1)-num$(STAT)-"SYSTEME"+"\|"+WCMDE(1)
Endif
Openi FICTRA Using [TR_]
Iomode adxifs "" Using [TR_]
Iomode adxirs chr$(10) Using [TR_]
Raz MESSAGE
Rdseq MESSAGE(1) Using [TR_]
Rdseq MESSAGE(2) Using [TR_]
Rdseq MESSAGE(3) Using [TR_]
Rdseq MESSAGE(4) Using [TR_]
Rdseq MESSAGE(5) Using [TR_]
Openi Using [TR_]
OK = 1
If MESSAGE(1)<>""
 OK = 0
 For I=1 To 5
  If instr(1,MESSAGE(I),"(3)") or instr(1,MESSAGE(I),"(87)") : # Processus inexistant
   OK = 1 : Break
  Endif
 Next I
Endif
If !OK
 # Arrêt processus
 ERRMES = mess(54,115,1)-PROCESS+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3)+"|\|"+MESSAGE(4)
Endif
#Call EFFACE(FICTRA,STAT) From ORDSYS
Call _EFFACE(FICTRA,STAT) From ASYRSYS
If STAT
 # Erreur
 ERRMES = mess(6,123,1)-num$(STAT)-"EFFACE"+"\|"+FICTRA
Elsif WCMDE(1)<>""
 # Espionnage des kill process
 Call TRACE_ORDRE(MOTIF,WCMDE(1)-"("+MESSA+")") From ESPION
Endif
End

###############################################
$GET_T
#this.ID        = [LNK_]ID
this.CLIENT    = TCLIENT
this.USER      = TUSER
this.DOSSIER   = TDOSSIER
this.MODULE    = TMODULE
this.FONCTION  = TFONCTION
this.LOGIN     = TLOGIN
this.PORT      = TPORT
this.DATCON    = TDATCON
this.HRECON    = THRECON
this.DATTIME   = TDATTIME
this.CPU       = TCPU
this.TYP       = TTYP
this.UID       = TUID
this.ADRESSE   = TADRESSE
this.IPCLI     = TIPCLI

If [L]NBTABPROC>0
  Local Integer NOL
  For NOL=1 To [L]NBTABPROC
    this.NBAPSADXP +=1
    this.APSADXP(NOL) = NewInstance C_APSADXP AllocGroup this
    this.APSADXP(NOL).NUMERO=[L]TABNUMERO(NOL)
    this.APSADXP(NOL).MACHINE=[L]TABMACHINE(NOL)
    this.APSADXP(NOL).PROCESS=[L]TABPROCESS(NOL)
  Next
Endif
Return

