#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe APSADX
##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD"             : Gosub AREAD
      When "ADELETE"           : Gosub ADELETE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Case [L]AOPERATION
  When "ADELSESS" : Gosub ADELSESS
Endcase
Return

# 2017-09-12 JPGA : X3-48260 - Remove inactive sessions
#---------------------------#
$ADELSESS
  Local Integer NBDEL_ASM3   : # Number of records deleted in ASYSSMDBASSO session table
  Local Integer NBDEL_ASM0   : # Number of records deleted in ASYSSMINTERN session table
  Local Integer NBDEL_ASM1   : # Number of records deleted in ASYSSMEXTERN session table
  Local Integer NBDEL_ASM2   : # Number of records deleted in ASYSSMPROCES session table
  Local Char    MESSAGE(250) : # Message returned in case of error
  Local Integer WRET_VALUE   : # Return_code returned by method

  # Calling the MAIN deletion procedure with the current folder as INPUT (must be a ROOT folder)
  ARET_VALUE= func ASESSIONS.RAZ_DEAD_SESSION(this.ACTX.AFOLDER, NBDEL_ASM3, NBDEL_ASM0, NBDEL_ASM1, NBDEL_ASM2, MESSAGE)

  # Processing results after calling the MAIN deletion procedure with the current folder as INPUT  (must be a ROOT folder)
  If [L]ARET_VALUE<>[V]CST_AOK
    [L]MESSAGE=mess(218,123,1)+" #"+num$(ARET_VALUE)+" : "+[L]MESSAGE : # Code retour global #n ...
    ARET_VALUE=fmet this.ASETERROR("",[L]MESSAGE,[V]CST_AERROR)
  Else
    WRET_VALUE=fmet this.ASETERROR("",mess(246,100,1)+" :"+" ASYSSMDBASSO="+num$([L]NBDEL_ASM3) +
&                                                          " ASYSSMINTERN="+num$([L]NBDEL_ASM0) +
&                                                          " ASYSSMEXTERN="+num$([L]NBDEL_ASM1) +
&                                                          " ASYSSMPROCES="+num$([L]NBDEL_ASM2),[V]CST_AINFO)
  Endif
Return


###############################################
$AREAD
Local Char QUERY_ID (10) : QUERY_ID=this.ID
Gosub CHARGE_TAB From APSADX_CSTD

If NBSESS<>1
  #Récupération no processus impossible
  ASTATUS = fmet this.ASETERROR("","---"-mess(16,134,1)-QUERY_ID,[V]CST_AERROR)
  Return
Endif

Gosub GET_T

Return

###############################################
$ADELETE

If this.USER=""
  #Récupération no processus impossible
  ASTATUS = fmet this.ASETERROR("",this.USER-mess(16,134,1),[V]CST_AERROR)
  Return
Endif
#Controles
If this.PORT<>num$(adxtcp) & pat(this.PORT,num$(adxtcp)+":*")=0
  #Action non autorisée : Service
  ASTATUS = fmet this.ASETERROR("",mess(99,9009,1)-func ASYRFNC.MES2(mess(239,100,1), this.PORT, num$(adxtcp)),[V]CST_AERROR)
Endif
If this.DOSSIER<>GACTX.AFOLDER
  #Action non autorisée : Dossier
  ASTATUS = fmet this.ASETERROR("",mess(99,9009,1)-func ASYRFNC.MES2(mess(240,100,1), this.DOSSIER, GACTX.AFOLDER),[V]CST_AERROR)
Endif
If this.USER<>GACTX.LOGIN
  #Action non autorisée : Login
  ASTATUS = fmet this.ASETERROR("",mess(99,9009,1)-func ASYRFNC.MES2(mess(241,100,1), this.USER, GACTX.LOGIN),[V]CST_AERROR)
Endif
If this.LOGIN<>adxcus
  #Action non autorisée : Compte système
  ASTATUS = fmet this.ASETERROR("",mess(99,9009,1)-func ASYRFNC.MES2(mess(242,100,1), this.LOGIN, adxcus),[V]CST_AERROR)
Endif
If ASTATUS
  Return
Endif

#Suppression
Gosub SUPPRIME

Return


###############################################
$CHARGE_TAB
Local Integer NBSESS : NBSESS=0
Local Char    TCLIENT         (100) (1..)
Local Char    TUSER           (100) (1..)
Local Char    TDOSSIER        (100) (1..)
Local Integer TMODULE               (1..)
Local Char    TFONCTION       (100) (1..)
Local Char    TLOGIN          (100) (1..)
Local Char    TPORT           (100) (1..)
Local Date    TDATCON               (1..)
Local Char    THRECON         (100) (1..)
Local Char    TDATTIME        (100) (1..)
Local Char    TCPU            (100) (1..)
Local Integer TTYP                  (1..)
Local Char    TID             (100) (1..)
Local Char    TUID            (100) (1..)
Local Char    TADRESSE        (100) (1..)
Local Char    TIPCLI          (100) (1..)
Local Integer TNATURE               (1..)

If func ASESSIONS.ISMNGSESSIONS
 Gosub REMPLIT_SYS_SESSION
Else
 Gosub REMPLIT_SYS
Endif
Return


$REMPLIT_SYS_SESSION

Local File ASYSSMPROCES [ASM2]
If QUERY_ID=""
  Call RAZ_CURFCT("") : # Ménage dans la table AFCTCUR
Endif

Local Char SID(250) , SPORT(20) , SCLI(80) , SADR(40) , SDOS(40) , SFCT(50)
Local Char SDATW(20) , SDATM(20) , SDATD(20) , SDATH(20) , SDATY(20)
Local Char SLOG(50) , STIME(20) , SUSER(50) , SMOD(50)
Local Char SUID(20) , SSER(30) , SPRO(250)
Local Integer  LIGENT , OKUSR
Local Char PROCESS(255)
Local Integer WAND

Local Integer NBTABPROC
Local Char TABNUMERO(10)(1..),TABPROCESS(10)(1..),TABMACHINE(GLONAMC)(1..)

Local Char     WCMDE(250) , SERVEUR(GLONAMC) , APPLI(GLONADS) , UTIL(GLONAUS), CODUID(GLONAUS),ERRMES(250)
Local Integer ALLPRO
[L]SERVEUR = adxmac(0)
[L]ALLPRO = 2
[L]APPLI = ""
[L]UTIL = ""
[L]CODUID = ""

Gosub INIT_RQT From ASESSIONS
WSELECT = "X3SM0.SESSIONID_0,X3SM0.FOLD_0,X3SM0.LAN_0,X3SM0.SOLUTION_0,X3SM0.SESSIONTYPE_0,"
Gosub ADD_SELECT_RQT From ASESSIONS
WSELECT = "X3SM0.REMOTE_0,X3SM0.PEER_0,X3SM0.SYSTEMUSER_0,X3SM0.NATURE_0,X3SM0.ALOGIN_0,"
Gosub ADD_SELECT_RQT From ASESSIONS
WSELECT = "X3SM0.PROCESSADX_0,X3SM0.UPDUSR_0,X3SM0.CREDATTIM_0 "
Gosub ADD_SELECT_RQT From ASESSIONS
If dim([L]APPLI)>0 & [L]APPLI<>""
 WAND = 1
 WWHERE  = "X3SM0.FOLD_0='"+[L]APPLI+"'"     : Gosub ADD_WHERE_RQT From ASESSIONS
Endif
#If dim([L]UTIL)>0 & [L]UTIL<>""
#  If WAND>0 : WWHERE  = " and " : Endif
#  WWHERE  += "X3SM0.ALOGIN_0='"+tolower([L]UTIL)+"'"     : Gosub ADD_WHERE_RQT From ASESSIONS
#Endif
If QUERY_ID<>""
 If WAND>0 : WWHERE  = " and " : Endif
 WWHERE  += "X3SM0.SESSIONID_0="+([L]QUERY_ID)     : Gosub ADD_WHERE_RQT From ASESSIONS
Endif
#SESSIONID,FOLD,LAN,SOLUTION,MODULE,FONCTION,SESSIONTYPE,REMOTE,PEER,SYSTEMUSER,NATURE,CREDATTIM,UPDDATTIM,ALOGIN,UPDUSR
For (Integer SESSIONID,Char FOLD(GLONADS),Char LAN(GLONLAN),Char SOLUTION(40),Integer SESSIONTYPE,Char REMOTE(40),
&    Char PEER(250),Char SYSTEMUSER(250),Integer NATURE,Char ALOGIN(30),Integer PROCESSADX,Char UPDUSR(GLONAUS),Datetime CREDATTIM)
&    From num$((GTYPDBA*2)+1)  Sql RQT_SESSION As [SYS_]
 [L]NBSESS += 1 : Gosub ADD_SESSIONS
Next
LogicClose File  [ASM2]
Return

$ADD_SESSIONS
K = [L]NBSESS
[L]TID(K)       = num$([F:SYS_]SESSIONID)      : # Identifiant (adxuid(1))
[L]TCLIENT(K)   = [F:SYS_]REMOTE : #[F:SYS_]SCLI      : # Poste client
If find([F:SYS_]SESSIONTYPE,25,33)>0
 [L]TIPCLI(K) = [F:SYS_]PEER :# [F:SYS_]SIPCLI : #Adresse client
Endif
[L]TADRESSE(K)  = [F:SYS_]PEER  : #[F:SYS_]SADR  : #Adresse client ou serveur syracuse
[L]TDOSSIER(K)  = [F:SYS_]FOLD      : # Dossier
[L]TUSER(K)     = [F:SYS_]ALOGIN     : # Login X3
[L]TUID(K)      = num$([F:SYS_]SESSIONID  )    : # ID adonix adxuid(2)
[L]TTYP(K)      = [F:SYS_]SESSIONTYPE : # Type de session
[L]TLOGIN(K)    = [F:SYS_]SYSTEMUSER: # [F:SYS_]SLOG      : # Login système
# [L]TCPU(K)     = "" # space$(6-min(instr(1,[F:SYS_]STIME,":"),5))+[F:SYS_]STIME : # Temps cpu du process adonix
[L]TDATCON(K)   = func ASYRFNC.DATE_FROM_DT([F:SYS_]CREDATTIM)
[L]THRECON(K)   = func ASYRFNC.TIME_FROM_DT([F:SYS_]CREDATTIM)
[L]TDATTIME(K)   = format$("D:4Y[-]2M[-]2D",[L]TDATCON(K)) + "T" + [L]THRECON(K) + "Z" # X3-105217 17.09.2018
[L]TNATURE(K)   = [F:SYS_]NATURE
Call GET_CURFCT([L]SERVEUR,[L]TDOSSIER(K),[L]TID(K),[L]TFONCTION(K),[L]TMODULE(K),[L]TUSER(K)) From ASYRPSADX
For [F:ASM2]SESSIONID Where SESSIONID=[SYS_]SESSIONID
 NBTABPROC += 1
 [L]TABNUMERO(NBTABPROC) = num$([F:ASM2]SYSTEMID)
 [L]TABMACHINE(NBTABPROC) = [F:ASM2]SERVER
 [L]TABPROCESS(NBTABPROC) = [F:ASM2]PROCESSNAME
  If [F:SYS_]PROCESSADX = [F:ASM2]PROCESSID
  [L]TPORT(K)     = num$([F:ASM2]PORT) : # [F:SYS_]SPORT     : # Port
  Call CPU_PROCESS([F:ASM2]SERVER,num$([F:ASM2]SYSTEMID),[L]TCPU(K) ,ERRMES) From ASYRPSADX
 Endif
Next
Return

#---------------------------#
$REMPLIT_SYS

If QUERY_ID=""
  Call RAZ_CURFCT("") : # Ménage dans la table AFCTCUR
Endif

Local Char SID(250) , SPORT(20) , SCLI(80) , SADR(40) , SDOS(40) , SFCT(50)
Local Char SDATW(20) , SDATM(20) , SDATD(20) , SDATH(20) , SDATY(20)
Local Char SLOG(50) , STIME(20) , SUSER(50) , SMOD(50)
Local Char SUID(20) , SSER(30) , SPRO(250)
Local Integer  LIGENT , OKUSR
Local Char PROCESS(255)

Local Integer NBTABPROC
Local Char TABNUMERO(10)(1..),TABPROCESS(10)(1..),TABMACHINE(GLONAMC)(1..)

Local Char     WCMDE(250) , SERVEUR(GLONAMC) , APPLI(GLONADS) , UTIL(GLONAUS), CODUID(GLONAUS)
Local Integer ALLPRO
[L]SERVEUR = adxmac(0)
[L]ALLPRO = 2
[L]APPLI = ""
[L]UTIL = ""
[L]CODUID = ""

Local Char VERSRUN(30)
Local Integer IPCLI
VERSRUN=func ASYRSYS.VERSRUN(GACTX,[L]SERVEUR+string$([L]SERVEUR="",adxmac(0)))
If VERSRUN>="18r.102"
 IPCLI=1
 Local Char SIPCLI(40)
Endif

WCMDE = [L]SERVEUR+"@psadx -"
WCMDE += "a" : # Adresse du client
If IPCLI
WCMDE += "e" : # Adresse IP du client (web page, Classic client)
Endif
WCMDE += "f" : # Dossier
WCMDE += "g" : # user X3 (GUSER)
WCMDE += "h" : # Jour et heure de connexion
WCMDE += "i" : # ID adonix
If [L]ALLPRO<>1
 WCMDE += "n" : # Login
Endif
WCMDE += "t" : # Type de session
WCMDE += "p" : # No de port utilisé
WCMDE += "x" : # Processus
If [L]ALLPRO<>1
 WCMDE += "z" : # Temps CPU du processus adonix
Endif
WCMDE += " -l"-GACTX.LAN
If [L]APPLI<>""
 WCMDE += " -b"-[L]APPLI
Endif
If [L]UTIL<>""
 WCMDE += " -u"-tolower([L]UTIL)
Endif

GPOINT = "SYSTEM" : Gosub ENTREE From EXEFNC : # Demande 61565
If IPCLI
 If dim([L]ALLPRO)<=0 or [L]ALLPRO<>1
  Local File (SID,SPORT,SCLI,SADR,SDOS,SDATW,SDATM,SDATD,SDATH,SDATY,SLOG,STIME,SUSER,SUID,SSER,SIPCLI,SPRO) From System WCMDE As [SYS_]
 Else
  Local File (SID,SPORT,SCLI,SADR,SDOS,SDATW,SDATM,SDATD,SDATH,SDATY,SUSER,SUID,SSER,SIPCLI,SPRO) From System WCMDE As [SYS_]
 Endif
Else
 If dim([L]ALLPRO)<=0 or [L]ALLPRO<>1
  Local File (SID,SPORT,SCLI,SADR,SDOS,SDATW,SDATM,SDATD,SDATH,SDATY,SLOG,STIME,SUSER,SUID,SSER,SPRO) From System WCMDE As [SYS_]
 Else
  Local File (SID,SPORT,SCLI,SADR,SDOS,SDATW,SDATM,SDATD,SDATH,SDATY,SUSER,SUID,SSER,SPRO) From System WCMDE As [SYS_]
 Endif
Endif
Raz LIGENT , OKUSR
For [SYS_]
 If LIGENT<2
  LIGENT += 1
 Else
  #On décale si pb sur SUSER ou SIPCLI
  If IPCLI
   If [F:SYS_]SPRO="" & [F:SYS_]SIPCLI="" & [F:SYS_]SSER<>"" & [F:SYS_]SUID<>"" & [F:SYS_]SUSER<>"" & instr(1,[F:SYS_]SSER,":")>0
    [F:SYS_]SPRO=[F:SYS_]SSER
    [F:SYS_]SIPCLI=""
    [F:SYS_]SSER=[F:SYS_]SUID
    [F:SYS_]SUID=[F:SYS_]SUSER
    [F:SYS_]SUSER="???"
   Elsif [F:SYS_]SPRO="" & [F:SYS_]SIPCLI<>"" & instr(1,[F:SYS_]SIPCLI,":")>0
    [F:SYS_]SPRO=[F:SYS_]SIPCLI
    [F:SYS_]SIPCLI=""
   Endif
  Else
   If [F:SYS_]SPRO="" & [F:SYS_]SSER<>"" & [F:SYS_]SUID<>"" & [F:SYS_]SUSER<>"" & instr(1,[F:SYS_]SSER,":")>0
    [F:SYS_]SPRO=[F:SYS_]SSER
    [F:SYS_]SSER=[F:SYS_]SUID
    [F:SYS_]SUID=[F:SYS_]SUSER
    [F:SYS_]SUSER="???"
   Endif
  Endif
  ###
  If [F:SYS_]SUSER="" & [F:SYS_]SPORT<>""
   # Dernière ligne
  Elsif [F:SYS_]SUSER="" : # Ligne de processus
   If OKUSR
    PROCESS = [F:SYS_]SID
    Gosub PROCESS
   Endif
  Else : # Ligne utilisateur
   If (CODUID="" or CODUID=[F:SYS_]SUID) &
&     (QUERY_ID="" or QUERY_ID=[F:SYS_]SID)
#    If [L]NBLIG>=dim([L]ID)
#     Call ERREUR(mess(161,115,1)) From GESECRAN : # Trop de lignes
#     Break
#    Endif
    OKUSR = 1
    NBSESS += 1
    Gosub LIGNE_SYS
    #If NBSESS = (PQRY.QCOUNT+1) : Break :Endif
   Else
    OKUSR = 0
   Endif
  Endif
 Endif
Next SYS_
Close Local File [SYS_]
Return


#---------------------------#
$LIGNE_SYS
K = NBSESS
[L]TID(K)       = [F:SYS_]SID       : # Identifiant (adxuid(1))
[L]TPORT(K)     = [F:SYS_]SPORT     : # Port
[L]TCLIENT(K)   = [F:SYS_]SCLI      : # Poste client
If IPCLI & find(val([F:SYS_]SSER),25,33)>0 & [F:SYS_]SIPCLI<>""
[L]TIPCLI(K)  = [F:SYS_]SIPCLI    : # Adresse client
Else
[L]TIPCLI(K)=""
Endif
[L]TADRESSE(K)  = [F:SYS_]SADR      : # Adresse client ou serveur syracuse
[L]TDOSSIER(K)  = [F:SYS_]SDOS      : # Dossier
[L]TUSER(K)     = [F:SYS_]SUSER     : # Login X3
[L]TUID(K)      = [F:SYS_]SUID      : # ID adonix adxuid(2)
[L]TTYP(K)      = val([F:SYS_]SSER) : # Type de session
If dim([L]ALLPRO)<=0 or [L]ALLPRO<>1
 [L]TLOGIN(K)    = [F:SYS_]SLOG      : # Login système
 #115751
 #[L]TCPU(K)      = space$(6-min(instr(1,[F:SYS_]STIME,":"),5))+[F:SYS_]STIME : # Temps cpu du process adonix
 [L]TCPU(K)      = [F:SYS_]STIME : # Temps cpu du process adonix
Endif
PROCESS            = [F:SYS_]SPRO      : # Processus système
MOIS = find(toupper([F:SYS_]SDATM),"JAN","FEB","MAR","APR","MAY","JUN","JUL","AUG","SEP","OCT","NOV","DEC")
If MOIS
 JOUR = val([F:SYS_]SDATD)
 ANNEE = val([F:SYS_]SDATY)
 If JOUR>=1 & JOUR<=31 & ANNEE>=1600 & ANNEE<=9999
  [L]TDATCON(K) = gdat$(JOUR,MOIS,ANNEE)
  [L]THRECON(K) = [F:SYS_]SDATH
  [L]TDATTIME(K)   = format$("D:4Y[-]2M[-]2D",[L]TDATCON(K)) + "T" + [L]THRECON(K) + "Z" # X3-105217 17.09.2018
 Endif
Endif
Gosub PROCESS
Call GET_CURFCT([L]SERVEUR,[L]TDOSSIER(K),[L]TID(K),[L]TFONCTION(K),[L]TMODULE(K),[L]TUSER(K)) From ASYRPSADX
Return

#---------------------------#
$PROCESS
If QUERY_ID="" : Return : Endif

 NBTABPROC += 1
 Call GET_PROCESS(PROCESS,TABNUMERO(NBTABPROC),TABMACHINE(NBTABPROC),TABPROCESS(NBTABPROC))
Return

#---------------------------------------------------------------------#
# Saucissonnage du psadx -> processus:nomProcessus(machine)
#---------------------------------------------------------------------#

Subprog GET_PROCESS(PROCESS,NUM,MAC,PRO)
Value Char PROCESS
Variable Char NUM , MAC , PRO
Local Integer J , L
J = instr(1,PROCESS,":")
If J
 NUM     = left$(PROCESS,J-1)
 PROCESS = right$(PROCESS,J+1)
Else
 NUM     = PROCESS
 PROCESS = ""
Endif
J = instr(1,PROCESS,"(")
If J
 PRO = left$(PROCESS,J-1)
 L = instr(J,PROCESS,")")
 If L
  MAC = seg$(PROCESS,J+1,L-1)
 Else
  MAC = right$(PROCESS,J+1)
 Endif
Else
 PRO = PROCESS
 MAC = adxmac(0)
Endif
End

