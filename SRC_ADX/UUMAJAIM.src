#<AdxTL>@(#)11.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour format export à "pdf" sur les destination prévisu
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update printer") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub DESAIM
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub DESAIM
End

#-------------------#
$DESAIM

Local File =DOSSIER+".APRINTER" [AIM] 

# Mise à jour de la table APRINTER
Call ECR_TRACE(mess(81,125,1)-"APRINTER:"-time$,0) From GESECRAN
Trbegin [AIM]
 For [AIM] Where PRT=1 : # Pré-visu
  If [F:AIM]PRTFMT=1 : # .rpt
   [F:AIM]PRTFMT = 29 : # .pdf
   Rewrite [AIM]
   If fstat
    Call ERREUR("APRINTER"-[F:AIM]COD,2) From DOSDIC
   Endif 
  Endif
 Next AIM
Commit

Close Local File [AIM]

Return
