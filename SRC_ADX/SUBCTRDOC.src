#<AdxTL>@(#)0.0.0.0 $Revision$
$LIENS
#MABOS-02/01/2013
Local Char NUMLIB(10)
Local Integer PNOLIB
Local Integer ONLEG   :#- 1 : Parameter TYPDOC on the leg or 0: Not
Call PARAM([F:HRCLC]LEG,"TYPDOC",NUMLIB,[L]ONLEG) From SUBHRCLC
If NUMLIB<>"0" & NUMLIB<>"" Then
  If mess(1,val(NUMLIB),1)="" Then
      Call MESSAGE(mess(156,10701,1)-"("+NUMLIB+")") From GESECRAN : # Le menu local du paramètre TYPDOC n'est pas correctement renseigné
  Else
    PNOLIB=val(NUMLIB)
    [M:CLC0]NOLIB=PNOLIB
    Affzo [M:CLC0]NOLIB
  Endif

Else
  Call MESSAGE(mess(157,10701,1)) From GESECRAN :# Le paramètre TYPDOC n'est pas correctement renseigné
Endif

nolign=1


For I=0 To dim([F:HRCLC]DOCCLA)-1
    If ![M]DOCCLA(I) : Break : Endif
    [M]DOCCLA(I)=[F:HRCLC]DOCCLA(I)
    If [M:CLC0]DOCCLA(I)<>0 Then
      If [M:CLC0]NOLIB <> 0 Then
        If mess([M:CLC0]DOCCLA(I),[M:CLC0]NOLIB,1)<>"" Then
          [M:CLC0]DOCCLAA(I)=mess([M:CLC0]DOCCLA(I),[M:CLC0]NOLIB,1)
        Else
      #    Call MESSAGE(num$([M:CLC0]DOCCLA(I))+"-"+mess(141,143,1))  From GESECRAN : #'Valeur non définie'
          [M:CLC0]DOCCLAA(I)= num$([M:CLC0]DOCCLA(I))-":"-mess(141,143,1): :# 'Valeur non définie'
        Endif
      Else
        [M:CLC0]DOCCLAA(I)=num$([M:CLC0]DOCCLA(I)):# -":"-mess(98,123,1)
      Endif
    Else
      Raz [M:CLC0]DOCCLAA(I)
    Endif

    nolign+=1
Next

[M]NBRDOC=nolign-1

