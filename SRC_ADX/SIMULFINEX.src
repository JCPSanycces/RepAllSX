#<AdxTL>@(#)10.0.0.0 $Revision$
#################################################################################
#                           Simulated cost calculation                          #
#                           reconstitution à-nouveau pour 1 soc/ref             #
#################################################################################
#*X3-104535 MWA  Parameters linked to activity code (04.09.2018)
# Issue X3-51077 - 2017-08-21 by BEFOU : User with a Funtion profile, problem in Year end simulation
#

Local Char PARAM(10)(1..10) , VALEUR(10)
  Call TRAITE_CHAR(VALEUR,PARAM,"","SIMULFINEX","UTIFINEX",3,"") From GTRAITE
  GHYPER = 1
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
 When "TERMINE"     : Gosub TERMINE
Endcase
Return

$OUVRE

  If clalev([F:BAL])=0  : Local File BALANCE    [BAL]  : Endif
  If clalev([F:BAL2])=0 : Local File BALANCE    [BAL2] : Endif
  If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
  If clalev([F:BLA])=0  : Local File BALANA     [BLA]  : Endif
  If clalev([F:BLA2])=0 : Local File BALANA     [BLA2] : Endif
  If clalev([F:BLQ])=0  : Local File BLAQTY     [BLQ]  : Endif
  If clalev([F:BLQ2])=0 : Local File BLAQTY     [BLQ2] : Endif
  If clalev([F:CCE])=0  : Local File CACCE      [CCE]  : Endif
  If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
  If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
  If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
  If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
  If clalev([F:COA])=0  : Local File GCOA       [COA]  : Endif
  If clalev([F:CLS])=0  : Local File GACCCLS    [CLS]  : Endif

  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

  If GNBLEG = 1
    GCURLEG = GDOSLEG
  Endif
Return

$INIT

  Gosub OUVRE
  TMP = 1
Return

$EXEC
  If func AFNC.ACTIV("PRCSL")
   Call FINEX([M:DIA]LEDTYP,[M:DIA]TOUSOC,[M:DIA]SOCIETE,[M:DIA]FIY,[M:DIA]GEN,[M:DIA]ANA,[M:DIA]CSL,GSERVEUR)
  Else
   Call FINEX([M:DIA]LEDTYP,[M:DIA]TOUSOC,[M:DIA]SOCIETE,[M:DIA]FIY,[M:DIA]GEN,[M:DIA]ANA,0,GSERVEUR)
  Endif
  TRA = 1
Return


$TERMINE

  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

############################################################################
## Simulation de fin d'exercice
############################################################################
Subprog FINEX(REFER,TOUSOC,SOC,EXE,GEN,ANA,CSL,BATCH)
Value Integer REFER
Value Integer TOUSOC
Value Char    SOC
Value Integer EXE
Value Integer GEN
Value Integer ANA
Value Integer CSL
Value Integer BATCH

Gosub OUVRE
Local Integer OK , EXERCICE , ISOC
Local Char    SOCIETE(GLONCPY)
Local Tinyint CSLFLG
Local Integer ASTATUS
Local Char    ERRMES(250)

  If !BATCH
    Call OUVRE_TRACE(mess(104,116,1)) From LECFIC
  Else
    If GNBLEG=1
      GCURLEG = GDOSLEG
    Else
      GCURLEG=[M:DIA]LEG
    Endif
  Endif

  Call ECR_TRACE(mess(104,116,1),0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(mess(49,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

  If GEN=2
    Call ECR_TRACE(mess(54,116,1),0) From GESECRAN
    If TOUSOC=2
      # All cpy then should take care of the leg : leg cpy = screen leg
      For [CPY]CPY0 Where CPYLEGFLG=2 & LEG=GCURLEG
        SOCIETE = [F:CPY]CPY
        ISOC = find(SOCIETE,GSOC(1..GNBSOC))
        If GEXEAN(ISOC,REFER)<>0
          EXERCICE = GEXEAN(ISOC,REFER)+1
          Gosub SOC_GEN
        Endif
      Next
    Else
      SOCIETE  = SOC
      EXERCICE = EXE
      Gosub SOC_GEN
    Endif
  Endif

  If ANA=2
    Call ECR_TRACE(mess(73,116,1),0) From GESECRAN
      If TOUSOC=2
        # All cpy then should take care of the leg : leg cpy = screen leg
        For [CPY]CPY0 Where CPYLEGFLG=2 & LEG=GCURLEG
          SOCIETE = [F:CPY]CPY
          ISOC = find(SOCIETE,GSOC(1..GNBSOC))
          If GEXEAN(ISOC,REFER)<>0
          EXERCICE = GEXEAN(ISOC,REFER)+1
          Gosub SOC_ANA
        Endif
      Next
    Else
      SOCIETE  = SOC
      EXERCICE = EXE
      Gosub SOC_ANA
    Endif
  Endif

  If CSL=2
    Call ECR_TRACE(mess(177,116,1),0) From GESECRAN
    If TOUSOC=2
      # All cpy then should take care of the leg : leg cpy = screen leg
      For [CPY]CPY0 Where CPYLEGFLG=2 & LEG=GCURLEG
        SOCIETE = [F:CPY]CPY
        ISOC = find(SOCIETE,GSOC(1..GNBSOC))
        If GEXEAN(ISOC,REFER)<>0
          EXERCICE = GEXEAN(ISOC,REFER)+1
          Gosub SOC_CSL
        Endif
      Next
    Else
      SOCIETE  = SOC
      EXERCICE = EXE
      Gosub SOC_CSL
    Endif
  Endif

  Call ECR_TRACE(mess(50,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
  If !BATCH
   Call FERME_TRACE From LECFIC
  Endif

End

$SOC_GEN

  Call LEC_CPY(SOCIETE) From CPTLEC
  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  If [F:GCM]LED(REFER-1)<>""
    Call MONOCPY(SOCIETE,OK) From AX3MONO # Lock in mono CPY
    If OK
      Call ECR_TRACE(mess(2,116,1)-SOCIETE-[F:CPY]CPYNAM,0) From GESECRAN

      Call RECUPBAL(SOCIETE,REFER,EXERCICE)

      Read [FIY]FIY0 = SOCIETE;REFER;EXERCICE-1
      If fstat=0
        Call ECR_TRACE(mess(51,104,1)-":"-num$(EXERCICE-1)-num$([FIY]FIYSTR)-"-"-num$([FIY]FIYEND),0) From GESECRAN
      Endif
      Call MULTICPY(SOCIETE) From AX3MONO # Repassage en multisociété
    Endif
  Endif

Return

$SOC_ANA

  Call LEC_CPY(SOCIETE) From CPTLEC
  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  If [F:GCM]LED(REFER-1)<>""
    Call LEC_LED([F:GCM]LED(REFER-1)) From CPTLEC
    If [F:LED]DIENBR>0
      Call MONOCPY(SOCIETE,OK) From AX3MONO
      If OK
        Call ECR_TRACE(mess(2,116,1)-SOCIETE-[F:CPY]CPYNAM,0) From GESECRAN

        Call RECUPBLA(SOCIETE,REFER,EXERCICE)

        Read [FIY]FIY0 = SOCIETE;REFER;EXERCICE-1
        If fstat=0
          Call ECR_TRACE(mess(51,104,1)-":"-num$(EXERCICE-1)-num$([FIY]FIYSTR)-"-"-num$([FIY]FIYEND),0) From GESECRAN
        Endif
        Call MULTICPY(SOCIETE) From AX3MONO
      Endif
    Endif
  Endif

Return

$SOC_CSL

  Call LEC_CPY(SOCIETE) From CPTLEC
  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  If [F:GCM]LED(REFER-1)<>""
    [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX,[F:GCM]LED(REFER-1),CSLFLG,ERRMES)
    If [L]CSLFLG = [V]CST_AYES
      Call MONOCPY(SOCIETE,OK) From AX3MONO
      If OK
        Call ECR_TRACE(mess(2,116,1)-SOCIETE-[F:CPY]CPYNAM,0) From GESECRAN

        Call RECUPCSL(SOCIETE,REFER,EXERCICE)

        Read [FIY]FIY0 = SOCIETE;REFER;EXERCICE-1
        If fstat=0
          Call ECR_TRACE(mess(51,104,1)-":"-num$(EXERCICE-1)-num$([FIY]FIYSTR)-"-"-num$([FIY]FIYEND),0) From GESECRAN
        Endif
        Call MULTICPY(SOCIETE) From AX3MONO
      Endif
    Endif
  Endif

Return

#########################################################
# Reconstitution à-nouveau pour 1 société, 1 référentiel
#########################################################
Subprog RECUPBAL(SOCIETE,REFER,EXERCICE)
Value    Char    SOCIETE
Value    Integer REFER
Variable Integer EXERCICE

Local Integer EQUILIBRE
Local Char    BALACC(GLONGAC) , BALBPR(GLONBPR)
Local Decimal ANOUVCUR , ANOUVLED
Local Integer ISOC
Local Integer OK2
Local Char    PLAN(GLONCOA)

If clalev([F:BAL])=0  : Local File BALANCE  [BAL]  : Endif
If clalev([F:BAL2])=0 : Local File BALANCE  [BAL2] : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT [GAC]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY  [CPY]  : Endif
If clalev([F:GCM])=0  : Local File GACM     [GCM]  : Endif
If clalev([F:LED])=0  : Local File GLED     [LED]  : Endif
If clalev([F:COA])=0  : Local File GCOA     [COA]  : Endif
If clalev([F:CLS])=0  : Local File GACCCLS  [CLS]  : Endif

  Call LEC_CPY(SOCIETE) From CPTLEC
  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  Call LEC_LED([F:GCM]LED(REFER-1)) From CPTLEC
  PLAN = [F:LED]COA
  Call LEC_COA(PLAN) From CPTLEC
  EQUILIBRE = ([F:LED]EQLRANANA=2)
  If EQUILIBRE & [F:COA]ACCMIS(10)=""
    Call ECR_TRACE(mess(106,106,1)-"("+PLAN+")",1) From GESECRAN
    GOK = 0
    End
  Endif

  Call DEBTRANS From GLOCK
  Gosub TR1
End

$TR1

  GOK = 1
  If EXERCICE=0
    ISOC = find(SOCIETE,GSOC(1..GNBSOC))
    EXERCICE = GEXEAN(ISOC,REFER)+1
  Endif
  Trbegin [BAL2]
  Update [BAL2] Where CPY=SOCIETE & LEDTYP=REFER & FIY=EXERCICE
&        With DEB(0) = 0 , CDT(0) = 0 , DEBLED(0) = 0 , CDTLED(0) = 0
  If fstat
    GOK = 0 : Call FSTA("BAL2") From GLOCK : Goto AB_TR1
  Endif

  # loop on closing exersise
  For [BAL]BAL0 Where CPY = SOCIETE and LEDTYP = REFER and FIY = EXERCICE - 1
    ANOUVCUR = sum([F:BAL]DEB)-sum([F:BAL]CDT)
    ANOUVLED = sum([F:BAL]DEBLED)-sum([F:BAL]CDTLED)
    Call LEC_GAC([F:BAL]ACC,PLAN) From CPTLEC
    Call LEC_CLS([F:COA]LEGCLS,[F:GAC]CLSCOD) From CPTLEC
    OK2 = 1
    BALBPR = [F:BAL]BPR
    If [F:CLS]ERA<>2 : # Classe remise à zéro => compte de résultat
      If EQUILIBRE
        BALACC = [F:COA]ACCMIS(10)
        BALBPR = ""
      Else
        OK2 = 0
      Endif
    Else
      BALACC = [F:BAL]ACC
    Endif
    If OK2
      # read on future current exersise
      Read [BAL2]BAL0 = REFER; [F:BAL]CPY; [F:BAL]FCY; EXERCICE; BALACC; BALBPR; [F:BAL]CUR
      If fstat
        Raz [F:BAL2]
        [F:BAL2] = [F:BAL]
        Raz [F:BAL2]DEB , [F:BAL2]CDT , [F:BAL2]DEBLED , [F:BAL2]CDTLED
        [F:BAL2]LEDTYP = REFER
        [F:BAL2]ACC    = BALACC
        [F:BAL2]BPR    = BALBPR
        [F:BAL2]FIY    = EXERCICE
        [F:BAL2]ACCNUM = uniqid([F:BAL2])
        If ANOUVCUR>0
          [F:BAL2]DEB(0) = +ANOUVCUR
          [F:BAL2]CDT(0) = 0
        Else
          [F:BAL2]CDT(0) = -ANOUVCUR
          [F:BAL2]DEB(0) = 0
        Endif
        If ANOUVLED>0
          [F:BAL2]DEBLED(0) = +ANOUVLED
          [F:BAL2]CDTLED(0) = 0
        Else
          [F:BAL2]CDTLED(0) = -ANOUVLED
          [F:BAL2]DEBLED(0) = 0
        Endif

        Write [BAL2]
      Else
        [F:BAL2]DEB(0) = [F:BAL2]DEB(0)-[F:BAL2]CDT(0)+ANOUVCUR
        If [F:BAL2]DEB(0)<0
          [F:BAL2]CDT(0) = -[F:BAL2]DEB(0)
          [F:BAL2]DEB(0) = 0
        Else
          [F:BAL2]CDT(0) = 0
        Endif
        [F:BAL2]DEBLED(0) = [F:BAL2]DEBLED(0)-[F:BAL2]CDTLED(0)+ANOUVLED
        If [F:BAL2]DEBLED(0)<0
          [F:BAL2]CDTLED(0) = -[F:BAL2]DEBLED(0)
          [F:BAL2]DEBLED(0) = 0
        Else
          [F:BAL2]CDTLED(0) = 0
        Endif

        Rewrite [BAL2]
      Endif
      If fstat
        GOK = 0 : Call FSTA("BAL2") From GLOCK : Break
      Endif
    Endif
  Next
  If GOK<1 : Goto AB_TR1 : Endif
  Commit

Return

$AB_TR1
Rollback
Return

#####################################################
# Reconstitution balana 1 société, 1 référentiel
#####################################################
Subprog RECUPBLA(SOCIETE,REFER,EXERCICE)
Value    Char    SOCIETE
Value    Integer REFER
Variable Integer EXERCICE

Local Integer OK2 , AXE , EQUILIBRE
Local Char    BALACC(GLONGAC) , BALBPR(GLONBPR) , SECTION(GLONCCE)
Local Char    BALSEC1(GLONCCE) , BALSEC2(GLONCCE) , BALSEC3(GLONCCE)
Local Char    BALSEC4(GLONCCE) , BALSEC5(GLONCCE) , BALSEC6(GLONCCE)
Local Char    BALSEC7(GLONCCE) , BALSEC8(GLONCCE) , BALSEC9(GLONCCE)
Local Decimal ANOUVCUR , ANOUVLED , ANOUVQTE
Local Integer ISOC
Local Char    PLAN(GLONCOA) , BALAXE(GLONDIE)
Local Integer J

If clalev([F:BLA])=0  : Local File BALANA   [BLA]  : Endif
If clalev([F:BLA2])=0 : Local File BALANA   [BLA2] : Endif
If clalev([F:BLQ])=0  : Local File BLAQTY   [BLQ]  : Endif
If clalev([F:BLQ2])=0 : Local File BLAQTY   [BLQ2] : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT [GAC]  : Endif
If clalev([F:CCE])=0  : Local File CACCE    [CCE]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY  [CPY]  : Endif
If clalev([F:GCM])=0  : Local File GACM     [GCM]  : Endif
If clalev([F:LED])=0  : Local File GLED     [LED]  : Endif
If clalev([F:COA])=0  : Local File GCOA     [COA]  : Endif
If clalev([F:CLS])=0  : Local File GACCCLS  [CLS]  : Endif

  Call LEC_CPY(SOCIETE) From CPTLEC
  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  Call LEC_LED([F:GCM]LED(REFER-1)) From CPTLEC
  PLAN = [F:LED]COA
  Call LEC_COA(PLAN) From CPTLEC
  EQUILIBRE = ([F:LED]EQLRANANA=2)
  If EQUILIBRE & [F:COA]ACCMIS(10)=""
    Call ECR_TRACE(mess(106,106,1)-"("+PLAN+")",1) From GESECRAN
    GOK = 0
    End
  Endif

  If EXERCICE=0
    ISOC = find(SOCIETE,GSOC(1..GNBSOC))
    EXERCICE = GEXEAN(ISOC,REFER)+1
  Endif

  Call DEBTRANS From GLOCK
  Gosub TR2
End

$TR2

  GOK = 1
  Trbegin [BLA2] , [BLQ2]
  Update [BLA2] Where CPY=SOCIETE & LEDTYP=REFER & FIY=EXERCICE
&         With DEB(0) = 0 , CDT(0) = 0 , DEBLED(0) = 0 , CDTLED(0) = 0
  If fstat
    GOK = 0 : Call FSTA("BLA2") From GLOCK : Goto AB_TR2
  Endif
  Update [BLQ2] Where CPY=SOCIETE & LEDTYP=REFER & FIY=EXERCICE
&        With QTY(0) = 0
  If fstat
    GOK = 0 : Call FSTA("BLQ2") From GLOCK : Goto AB_TR2
  Endif

  Link [BLA] With [BLQ]BLQ0=[BLA]LEDTYP;[BLA]CPY;[BLA]FCY;[BLA]FIY;[BLA]ACC;[BLA]BPR
&                         ;[BLA]CCE1;[BLA]CCE2;[BLA]CCE3;[BLA]CCE4;[BLA]CCE5;[BLA]CCE6
&                         ;[BLA]CCE7;[BLA]CCE8;[BLA]CCE9
&                         ;[BLA]CUR
&            As [LBLA]

# loop on closing exersise
  For [LBLA]BLA0 Where [BLA]CPY = SOCIETE and [BLA]LEDTYP = REFER and [BLA]FIY = EXERCICE - 1
    Call LEC_GAC([F:BLA]ACC,PLAN) From CPTLEC
    Call LEC_CLS([F:COA]LEGCLS,[F:GAC]CLSCOD) From CPTLEC
    OK2  = 1
    BALBPR = [F:BLA]BPR
    If [F:CLS]ERA<>2 : # Classe remise à zéro => compte de résultat
      If EQUILIBRE
        BALACC = [F:COA]ACCMIS(10)
        BALBPR = ""
      Else
        OK2 = 0
      Endif
    Else
      BALACC = [F:BLA]ACC
    Endif
    If OK2
      For AXE=1 To 9
        BALAXE  = [F:BLA]DIE(AXE-1)
        SECTION = evalue("[F:BLA]CCE"+num$(AXE))
        If [F:CLS]ERA<>2 & EQUILIBRE : SECTION="" : Endif
        If BALAXE<>"" & SECTION<>""
          J = find(BALAXE,GDIECOD(1..GDIENBR))
          If GDIEPRJ(J)=2
            SECTION = ""
          Else
            Call LEC_CCE(SECTION,BALAXE) From CPTLEC
            If [F:CCE]FRW<>2
              SECTION = ""
            Endif
          Endif
        Endif
        Assign "BALSEC"+num$(AXE) With SECTION
      Next AXE

      GPOINT = "ANAFRW" : Gosub ENTREE From EXEFNC

      ANOUVCUR = sum([F:BLA]DEB)-sum([F:BLA]CDT)
      ANOUVLED = sum([F:BLA]DEBLED)-sum([F:BLA]CDTLED)
      ANOUVQTE = sum([F:BLQ]QTY)

      # read on future current exersise
      Read [BLA2]BLA0 = REFER; [F:BLA]CPY; [F:BLA]FCY; EXERCICE; BALACC; BALBPR
&                   ;BALSEC1; BALSEC2; BALSEC3; BALSEC4; BALSEC5; BALSEC6; BALSEC7; BALSEC8; BALSEC9; [F:BLA]CUR
      If fstat
        [F:BLA2] = [F:BLA]
        Raz [F:BLA2]DEB, [F:BLA2]CDT, [F:BLA2]DEBLED, [F:BLA2]CDTLED
        If ANOUVCUR>0
          [F:BLA2]DEB(0) = +ANOUVCUR
          [F:BLA2]CDT(0) = 0
        Else
          [F:BLA2]CDT(0) = -ANOUVCUR
          [F:BLA2]DEB(0) = 0
        Endif
        If ANOUVLED>0
          [F:BLA2]DEBLED(0) = +ANOUVLED
          [F:BLA2]CDTLED(0) = 0
        Else
          [F:BLA2]CDTLED(0) = -ANOUVLED
          [F:BLA2]DEBLED(0) = 0
        Endif
        [F:BLA2]LEDTYP = REFER
        [F:BLA2]ACC    = BALACC
        [F:BLA2]BPR    = BALBPR
        [F:BLA2]CCE1   = BALSEC1
        [F:BLA2]CCE2   = BALSEC2
        [F:BLA2]CCE3   = BALSEC3
        [F:BLA2]CCE4   = BALSEC4
        [F:BLA2]CCE5   = BALSEC5
        [F:BLA2]CCE6   = BALSEC6
        [F:BLA2]CCE7   = BALSEC7
        [F:BLA2]CCE8   = BALSEC8
        [F:BLA2]CCE9   = BALSEC9
        [F:BLA2]FIY    = EXERCICE
        [F:BLA2]ACCNUM = uniqid([F:BLA2])
        Write [BLA2]
      Else
        [F:BLA2]DEB(0) = [F:BLA2]DEB(0)-[F:BLA2]CDT(0)+ANOUVCUR
        If [F:BLA2]DEB(0)<0
          [F:BLA2]CDT(0) = -[F:BLA2]DEB(0)
          [F:BLA2]DEB(0) = 0
        Else
          [F:BLA2]CDT(0) = 0
        Endif
        [F:BLA2]DEBLED(0) = [F:BLA2]DEBLED(0)-[F:BLA2]CDTLED(0)+ANOUVLED
        If [F:BLA2]DEBLED(0)<0
          [F:BLA2]CDTLED(0) = -[F:BLA2]DEBLED(0)
          [F:BLA2]DEBLED(0) = 0
        Else
          [F:BLA2]CDTLED(0) = 0
        Endif
        Rewrite [BLA2]
      Endif
      If fstat
        OK = 0 : Call FSTA("BLA2") From GLOCK : Break
      Endif
      If ANOUVQTE
        Read [BLQ2]BLQ0 = REFER;[F:BLQ]CPY;[F:BLQ]FCY;EXERCICE;BALACC;BALBPR
&                    ;BALSEC1;BALSEC2;BALSEC3;BALSEC4;BALSEC5;BALSEC6;BALSEC7;BALSEC8;BALSEC9;[F:BLQ]CUR
        If fstat
          [F:BLQ2] = [F:BLQ]
          Raz [F:BLQ2]QTY
          [F:BLQ2]QTY(0) = ANOUVQTE
          [F:BLQ2]LEDTYP = REFER
          [F:BLQ2]ACC    = BALACC
          [F:BLQ2]BPR    = BALBPR
          [F:BLQ2]CCE1   = BALSEC1
          [F:BLQ2]CCE2   = BALSEC2
          [F:BLQ2]CCE3   = BALSEC3
          [F:BLQ2]CCE4   = BALSEC4
          [F:BLQ2]CCE5   = BALSEC5
          [F:BLQ2]CCE6   = BALSEC6
          [F:BLQ2]CCE7   = BALSEC7
          [F:BLQ2]CCE8   = BALSEC8
          [F:BLQ2]CCE9   = BALSEC9
          [F:BLQ2]FIY    = EXERCICE
          [F:BLQ2]ACCNUM = uniqid([F:BLQ2])
          Write [BLQ2]
        Else
          [F:BLQ2]QTY(0) += ANOUVQTE
          Rewrite [BLQ2]
        Endif
        If fstat
          GOK = 0 : Call FSTA("BLA2") From GLOCK : Break
        Endif
      Endif
    Endif
  Next
  If GOK<1 : Goto AB_TR2 : Endif
  Commit

Return

$AB_TR2
Rollback
Return

#####################################################
# Reconstitution BALPRECSL 1 société, 1 référentiel
#####################################################
Subprog RECUPCSL(SOCIETE,REFER,EXERCICE)
Value    Char    SOCIETE
Value    Integer REFER
Variable Integer EXERCICE

If clalev([F:BLP])=0  : Local File BALPRECSL [BLP]  : Endif
If clalev([F:BLP2])=0 : Local File BALPRECSL [BLP2] : Endif
If clalev([F:IDTC])=0 : Local File IDTCCE    [IDTC] : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT  [GAC]  : Endif
If clalev([F:CCE])=0  : Local File CACCE     [CCE]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY   [CPY]  : Endif
If clalev([F:GCM])=0  : Local File GACM      [GCM]  : Endif
If clalev([F:LED])=0  : Local File GLED      [LED]  : Endif
If clalev([F:COA])=0  : Local File GCOA      [COA]  : Endif
If clalev([F:CLS])=0  : Local File GACCCLS   [CLS]  : Endif

Local Integer OK2 , AXE , EQUILIBRE
Local Char    BALACC(GLONGAC)  , BALBPR(GLONBPR) , SECTION(GLONCCE)
Local Char    BALSEC1(GLONCCE) , BALSEC2(GLONCCE) , BALSEC3(GLONCCE)
Local Char    BALSEC4(GLONCCE) , BALSEC5(GLONCCE) , BALSEC6(GLONCCE)
Local Char    BALSEC7(GLONCCE) , BALSEC8(GLONCCE) , BALSEC9(GLONCCE)
#YYFIN_105932_US10
Local Char    BALCSLFLO(GLONADI) , BALCSLBPR(GLONBPR)
Local Integer BALIDTCCE
Local Char    TDIE(GLONDIE)(0..dim([F:LED]DIE)-1)
Local Char    TCCE(GLONCCE)(0..dim([F:LED]DIE)-1)
#YYFIN_105932_end
Local Decimal ANOUVCUR , ANOUVLED
Local Integer ISOC
Local Char    PLAN(GLONCOA) , BALAXE(GLONDIE)
Local Integer J


  Call LEC_CPY(SOCIETE) From CPTLEC
  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  Call LEC_LED([F:GCM]LED(REFER-1)) From CPTLEC
  PLAN = [F:LED]COA
  Call LEC_COA(PLAN) From CPTLEC
  EQUILIBRE = ([F:LED]EQLRANANA=2)
  If EQUILIBRE & [F:COA]ACCMIS(10)=""
    Call ECR_TRACE(mess(106,106,1)-"("+PLAN+")",1) From GESECRAN
    GOK = 0
    End
  Endif

  If EXERCICE=0
    ISOC = find(SOCIETE,GSOC(1..GNBSOC))
    EXERCICE = GEXEAN(ISOC,REFER)+1
  Endif

  Local Integer LPRCSL : # X3-104535
  LPRCSL = func AFNC.ACTIV("PRCSL")
  If LPRCSL = G_OUI
    [L]BALCSLFLO = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVCPY,SOCIETE,"CSLFRWFLO")
  Endif : # X3-104535

  Call DEBTRANS From GLOCK
  Gosub TR3

End

$TR3

  GOK = 1
  Trbegin [BLP2]
  Update [BLP2] Where CPY=SOCIETE & LEDTYP=REFER & FIY=EXERCICE
&        With DEB(0) = 0 , CDT(0) = 0 , DEBLED(0) = 0 , CDTLED(0) = 0
  If fstat
    GOK = 0 : Call FSTA("BLP2") From GLOCK : Goto AB_TR3
  Endif

# loop on closing exersise
  Link [BLP] With [GAC]GAC0 ~= PLAN; [F:BLP]ACC,
&                 [CLS]CLS0 ~= [F:COA]LEGCLS; [F:GAC]CLSCOD
&            As [LNK]
&            Where  [BLP]CPY=SOCIETE and [BLP]LEDTYP=REFER and [BLP]FIY=EXERCICE-1

  For [LNK]BLP0
    OK2  = 1
    BALBPR    = [F:BLP]BPR
    BALCSLBPR = [F:BLP]CSLBPR
    If [F:CLS]ERA<>2 : # Classe remise à zéro => compte de résultat
      If EQUILIBRE
        BALACC = [F:COA]ACCMIS(10)
        BALBPR = ""
        BALCSLBPR = ""
      Else
        OK2 = 0
      Endif
    Else
      BALACC = [F:BLP]ACC
    Endif
      If OK2
        Raz BALIDTCCE
        If [BLP]IDTCCE<>0
          For AXE=1 To 9
            BALAXE  = [F:BLP]DIE(AXE-1)
            Case AXE
              When 1 : SECTION = [F:BLP]CCE1
              When 2 : SECTION = [F:BLP]CCE2
              When 3 : SECTION = [F:BLP]CCE3
              When 4 : SECTION = [F:BLP]CCE4
              When 5 : SECTION = [F:BLP]CCE5
              When 6 : SECTION = [F:BLP]CCE6
              When 7 : SECTION = [F:BLP]CCE7
              When 8 : SECTION = [F:BLP]CCE8
              When 9 : SECTION = [F:BLP]CCE9
            Endcase
            If [F:CLS]ERA<>2 & EQUILIBRE : SECTION="" : Endif
            If BALAXE<>"" & SECTION<>""
              J = find(BALAXE,GDIECOD(1..GDIENBR))
              If GDIEPRJ(J)=2
                SECTION = ""
              Else
                Call LEC_CCE(SECTION,BALAXE) From CPTLEC
                If [F:CCE]FRW<>2
                  SECTION = ""
                Endif
              Endif
            Endif
            Case AXE
              When 1 : BALSEC1 = SECTION : TDIE(0) = BALAXE : TCCE(0)= SECTION
              When 2 : BALSEC2 = SECTION : TDIE(1) = BALAXE : TCCE(1)= SECTION
              When 3 : BALSEC3 = SECTION : TDIE(2) = BALAXE : TCCE(2)= SECTION
              When 4 : BALSEC4 = SECTION : TDIE(3) = BALAXE : TCCE(3)= SECTION
              When 5 : BALSEC5 = SECTION : TDIE(4) = BALAXE : TCCE(4)= SECTION
              When 6 : BALSEC6 = SECTION : TDIE(5) = BALAXE : TCCE(5)= SECTION
              When 7 : BALSEC7 = SECTION : TDIE(6) = BALAXE : TCCE(6)= SECTION
              When 8 : BALSEC8 = SECTION : TDIE(7) = BALAXE : TCCE(7)= SECTION
              When 9 : BALSEC9 = SECTION : TDIE(8) = BALAXE : TCCE(8)= SECTION
            Endcase
          Next AXE
          Call GETIDTCCE([F:LED]LED,TDIE,TCCE,BALIDTCCE) From CPTBAL
          If GOK<1 : Break : Endif
        Else
          For AXE=1 To 9
            Case AXE
              When 1 : BALSEC1 = ""
              When 2 : BALSEC2 = ""
              When 3 : BALSEC3 = ""
              When 4 : BALSEC4 = ""
              When 5 : BALSEC5 = ""
              When 6 : BALSEC6 = ""
              When 7 : BALSEC7 = ""
              When 8 : BALSEC8 = ""
              When 9 : BALSEC9 = ""
            Endcase
          Next
        Endif

        ANOUVCUR = sum([F:BLP]DEB)-sum([F:BLP]CDT)
        ANOUVLED = sum([F:BLP]DEBLED)-sum([F:BLP]CDTLED)

        # read on future current exersise
        Read [BLP2]BLP0 = REFER; [F:BLP]CPY; [F:BLP]FCY; EXERCICE; BALACC; BALBPR;
&            BALCSLFLO; BALCSLBPR; BALIDTCCE; [F:BLP]CUR
        If fstat
          [F:BLP2] = [F:BLP]
          Raz [F:BLP2]DEB, [F:BLP2]CDT, [F:BLP2]DEBLED, [F:BLP2]CDTLED
          If ANOUVCUR>0
            [F:BLP2]DEB(0) = +ANOUVCUR
            [F:BLP2]CDT(0) = 0
          Else
            [F:BLP2]CDT(0) = -ANOUVCUR
            [F:BLP2]DEB(0) = 0
          Endif
          If ANOUVLED>0
            [F:BLP2]DEBLED(0) = +ANOUVLED
            [F:BLP2]CDTLED(0) = 0
          Else
            [F:BLP2]CDTLED(0) = -ANOUVLED
            [F:BLP2]DEBLED(0) = 0
          Endif
          [F:BLP2]LEDTYP = REFER
          [F:BLP2]ACC    = BALACC
          [F:BLP2]BPR    = BALBPR
          [F:BLP2]CSLFLO = BALCSLFLO
          [F:BLP2]CSLBPR = BALCSLBPR
          [F:BLP2]CCE1   = BALSEC1
          [F:BLP2]CCE2   = BALSEC2
          [F:BLP2]CCE3   = BALSEC3
          [F:BLP2]CCE4   = BALSEC4
          [F:BLP2]CCE5   = BALSEC5
          [F:BLP2]CCE6   = BALSEC6
          [F:BLP2]CCE7   = BALSEC7
          [F:BLP2]CCE8   = BALSEC8
          [F:BLP2]CCE9   = BALSEC9
          [F:BLP2]IDTCCE = BALIDTCCE
          [F:BLP2]FIY    = EXERCICE
          [F:BLP2]ACCNUM = uniqid([F:BLP2])
          Write [BLP2]
        Else
          [F:BLP2]DEB(0) = [F:BLP2]DEB(0)-[F:BLP2]CDT(0)+ANOUVCUR
          If [F:BLP2]DEB(0)<0
            [F:BLP2]CDT(0) = -[F:BLP2]DEB(0)
            [F:BLP2]DEB(0) = 0
          Else
            [F:BLP2]CDT(0) = 0
          Endif
          [F:BLP2]DEBLED(0) = [F:BLP2]DEBLED(0)-[F:BLP2]CDTLED(0)+ANOUVLED
          If [F:BLP2]DEBLED(0)<0
            [F:BLP2]CDTLED(0) = -[F:BLP2]DEBLED(0)
            [F:BLP2]DEBLED(0) = 0
          Else
            [F:BLP2]CDTLED(0) = 0
          Endif
          Rewrite [BLP2]
        Endif
      If fstat
        GOK = 0 : Call FSTA("BLP2") From GLOCK : Break
      Endif
    Endif
  Next
  If GOK<1 : Goto AB_TR3 : Endif
  Commit

Return

$AB_TR3
Rollback
Return


########################################
## Ecran SIMULFINEX
########################################
Subprog D_INI(VALEUR)
Variable Char    VALEUR()
# Issue X3-51077 - 2017-08-21 by BEFOU : If the user as not ACCESS to all sites
If GNBAUZ<>GNBSITE
  [M]TOUSOC=[V]G_NON
  Affzo [M]TOUSOC
  Grizo [M]TOUSOC
Endif
Gosub GRISE
End

Subprog AS_TOUSOC(VALEUR)
Variable Integer    VALEUR()
# Issue X3-51077 - 2017-08-17 by BEFOU : User with a Funtion profile, problem in Year end simulation
#If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE : mkstat = 1 : End  : Endif
End

Subprog C_TOUSOC(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]DATDEB = [0/0/0]
 [M]DATFIN = [0/0/0]
 [M]FIY    = 0
 Affzo DATDEB, DATFIN, FIY
 Grizo FIY
 Effzo SOCIETE : Grizo SOCIETE
 If dim([M]LEG)>0 : Actzo LEG : Endif
 If dim([M]CSL)>0 : Actzo CSL : Endif
Else
 #Call INICPY(SOCIETE) From EXEFNC
 Actzo FIY, SOCIETE
 If dim([M]LEG)>0 : Grizo LEG : Endif
Endif
End

Subprog AS_SOCIETE(VALEUR)
Variable Char    VALEUR()
If [M]TOUSOC=2 : mkstat = 1 : End : Endif
End

Subprog C_SOCIETE(VALEUR)
Variable Char    VALEUR()
Local Integer ISOC
Local Integer ASTATUS
Local Tinyint CSLFLG
Local Char    ERRMES(250)
If [M]TOUSOC<>2
 Call LEC_CPY(VALEUR) From CPTLEC
 Call LEC_GCM([F:CPY]ACM) From CPTLEC
 If [F:GCM]LED([M]LEDTYP-1)=""
  GMESSAGE = mess([M]LEDTYP,2644,1)-":"-mess(98,104,1)-[F:CPY]ACM
  mkstat = 2 : End
 Endif
 If dim([M]CSL)>0
  [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX,[F:GCM]LED([M]LEDTYP-1),CSLFLG,ERRMES)
  If [L]CSLFLG = [V]CST_AYES
   Actzo CSL : Affzo CSL
  Else
   [M]CSL=1 : Affzo CSL : Grizo CSL
  Endif
 Endif
Endif
If VALEUR<>[M]SOCIETE or [M]FIY=0
 ISOC = find(VALEUR,GSOC(1..GNBSOC))
 [M]FIY = GEXEAN(ISOC,[M]LEDTYP)+1
 Read [FIY]FIY0 = VALEUR;[M]LEDTYP;[M]FIY
 If !fstat
  [M]DATDEB = [F:FIY]FIYSTR
  [M]DATFIN = [F:FIY]FIYEND
  Affzo DATDEB, DATFIN
 Endif
Endif
End

Subprog AM_SOCIETE(VALEUR)
Variable Char    VALEUR()
Call LEC_CPY(VALEUR) From CPTLEC
If dim([M]LEG)>0 : [M]LEG = [F:CPY]LEG : Endif
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
End

Subprog AS_FIY(VALEUR)
Variable Decimal VALEUR
If [M]TOUSOC=2 : mkstat = 1 : End : Endif
End

Subprog C_FIY(VALEUR)
Variable Decimal VALEUR
Read [FIY]FIY0 = [M]SOCIETE;[M]LEDTYP;VALEUR
If fstat
 GMESSAGE = mess(7,101,1)
 mkstat = 2 : End
Elsif [F:FIY]FIYSTA=1
 GMESSAGE = mess(20,101,1)
 mkstat = 2 : End
Elsif [F:FIY]FIYSTA=3
 GMESSAGE = mess(21,101,1)
 mkstat = 2 : End
Endif
[M]DATDEB = [F:FIY]FIYSTR
[M]DATFIN = [F:FIY]FIYEND
Read [FIY]FIY0 = [M]SOCIETE;[M]LEDTYP;VALEUR-1
If fstat or ([F:FIY]FIYSTA=1 | [F:FIY]FIYSTA=3)
 GMESSAGE = mess(3,101,1)
 mkstat = 2 : End
Endif
Affzo DATDEB, DATFIN
End

Subprog AS_GEN(VALEUR)
Variable Integer VALEUR
End

$GRISE
If [M]TOUSOC=2
 Grizo SOCIETE
 If dim([M]LEG)>0 : Affzo LEG : Endif
Else
 Actzo SOCIETE
 If dim([M]LEG)>0 : Effzo LEG : Grizo LEG : Endif
Endif
Return

######################################################################################

