#######################################################################################################################
#
#  Gestion du ciblage marketing                                              Module CRM          18 mars 2002 
#
#######################################################################################################################
#  Traitement de génération d'une population sur la base d'un support de sélection de type :
#  PAR TRAITEMENT
#######################################################################################################################
# Liste des sous-programmes : 
# GENRTTRT    : Génération d'une population 
#######################################################################################################################
###########################################################################
Subprog GENRTTRT(SZQURCOD, IPPLORDCOD, SZSSPCOD)
Value Char SZQURCOD
Value Integer IPPLORDCOD
Value Char SZSSPCOD          #Support de sélection

Local Char SZTRTTORUN
Local Char SZPRGSRC(250)
Local Char SZPRGADX(250)
Local Integer IEXIST
Local Integer IVALIDOK

  Raz SZPRGSRC
  Raz SZPRGADX
  SZTRTTORUN = ""
  IEXIST = 0
  #On obtient le nom du traitement à exécuter.
  Read [SSP]SSP0=SZSSPCOD
  If fstat Then
    GERR = 1
    End
  Else
    SZTRTTORUN = [F:SSP]SPTPRO
  Endif
  If SZTRTTORUN = "" Then
    GERR = 1
    End
  Endif
  #On vérifie si le SRC existe réellement
  SZPRGSRC = filpath("TRT",SZTRTTORUN,"src",nomap)
  IEXIST = 0
  Call EXISTE(SZPRGSRC,IEXIST) From ORDSYS
  If !IEXIST Then
    GERR = 1
    End
  Endif
  #On le compile avant de l'exécuter
  IVALIDOK = 1
  Call VALID("TRT", SZTRTTORUN, nomap, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    GERR = 1
    End
  Endif
  If GMESSAGE <> "" Then
    GERR = 1
    End
  Endif
  #On vérifie si le ADX existe réellement
  SZPRGADX = filpath("TRT",SZTRTTORUN,"adx",nomap)
  IEXIST = 0
  Call EXISTE(SZPRGADX,IEXIST) From ORDSYS
  If !IEXIST Then
    GERR = 1
    End
  Endif
  #On l'exécute
  Call LOOKUPTARGET(SZQURCOD, IPPLORDCOD) From =SZTRTTORUN
End
