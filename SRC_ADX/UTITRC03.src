#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UTITRC03   Contrôle des articles-ventes après migration à la V6        #
##########################################################################
# FQ 69273 GA 11/2010
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  # Issue 108760 - 2015-08-07 by MAE :
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    # Issue 108760 - 2015-08-07 by MAE :
    #Read [ADS]DOSSIER=[L]DOSSIER
    #If fstat Then
    #  Raz [F:ADS]
    #Endif
    If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTITRC03(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITRC03(LDOS)
Value Char LDOS

Local Integer COMPTEUR
Local Integer WNBR

  Call ECR_TRACE("UTITRC03: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =LDOS+".ITMMASTER"   [ITM]
  Local File =LDOS+".ITMCATEG"    [ITG]
  Local File =LDOS+".ITMSALES"    [ITS]
  Trbegin [ITS]
  Raz WNBR
  Filter [ITM] Where DLVFLG=2 | SALFLG=2
  For [ITM]
      #MAE, bg 69273, si DLVFLG = 2, on vérifie qu'il existe un ITMSALES, sinon, on le créé
       Read [ITS]ITS0 = [F:ITM]ITMREF
       If fstat > 1
          If [F:ITM]TCLCOD<>""
            Read [ITG]ITG1=[F:ITM]TCLCOD;""
            If fstat Raz [F:ITG] Endif
          Endif
          #MISE à jour table ITMSALES
          [F:ITS]       = [F:ITG]
          [F:ITS]       = [F:ITM]
          [F:ITS]CREUSR = GUSER
          [F:ITS]CREDAT = date$
          [F:ITS]UPDUSR = GUSER
          [F:ITS]UPDDAT = date$
          Write [ITS]
          Call ECR_TRACE([F:ITM]ITMREF-[F:ITM]TCLCOD-" "-mess(59,123,1)-" "-mess(16,752,1), -1) From GESECRAN
          If fstat
            Call FSTA("ITS") From GLOCK
            Break
          Endif
          WNBR += 1
      Endif
  Next
  Filter [ITM]
  Commit
  Close Local File [ITS]
  Call ECR_TRACE("UTITRC03 : finish - total rows inserted into ITMSALES="-num$(WNBR),0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI
  #If fstat Then
  #  Raz [F:ADS]
  #Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If filinfo(filpath("FIL","ITMSALES","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","ITMMASTER","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","ITMCATEG","fde",APPLI),0)<=0 : End : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"ITMSALES") : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"ITMMASTER") : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"ITMCATEG") : End : Endif
  Call MAJ_UTITRC03(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If filinfo(filpath("FIL","ITMSALES","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","ITMMASTER","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","ITMCATEG","fde",APPLI),0)<=0 : End : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"ITMSALES") : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"ITMMASTER") : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"ITMCATEG") : End : Endif
  Call MAJ_UTITRC03(APPLI)
End

