#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management VXECO


$ACTION
  Case ACTION
    When "DEBUT"         : Gosub DEBUT
    When "OK"            : Gosub OK
  Endcase
Return

######################################################################################
$DEBUT
  Raz   [M:XECO]
  Affzo [M:XECO]
Return

######################################################################################
$OK

  Local Instance SFTTXN Using C_SFTTXN
  SFTTXN = NewInstance C_SFTTXN AllocGroup null
  Local Integer CSTATUS

  Local File SFTTXN [SFTX]
  Filter [SFTX] Where EMPNUM = [M:XECO]EMPNUM and SFTTYP = 1 and UTCENDDATTIM = AVOID.ADATTIM
  Read [SFTX] First
  If fstat
    Call ERREUR(mess(12,2422,1)) From GESECRAN
    mkstat = 1
    End
  Endif

  [L]CSTATUS = fmet SFTTXN.AREAD([M:XECO]EMPNUM, 1, "", [F:SFTX]SFTSEQ)
  [L]CSTATUS = fmet SFTTXN.EMPLOYEE_CLOCKOUT([M:XECO]EMPNUM, [F:SFTX]FCY)

  Local Date ODATE
  Local Char OTIME(5)
  Call TIMESTAMP([F:SFTX]FCY, ODATE, OTIME) From SFTLIB
  OTIME = left$(OTIME,2) + ":" + right$(OTIME,3)
  Call MESSAGE(func AFNC.MES2(mess(74,2422,1),num$([M:XECO]EMPDES), OTIME) ) From GESECRAN

  FreeGroup SFTTXN
  Kill SFTTXN
  LogicClose File [SFTX]


Return

######################################################################################
Subprog C_EMPNUM(VALEUR)
Variable Decimal VALEUR

  Local File TABMAT [TMA]
  Read [TMA]TMA0=VALEUR
  If fstat
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(23,100,1)
    mkstat = 1
    End
  Endif

  If [F:TMA]EMPTYP = 2
    #GMESSAGE = mess(76,2422,1)
    Call ERREUR(func AFNC.MES1(mess(76,2422,1), num$(VALEUR))) From GESECRAN #CT-1797
    mkstat = 1
    End
  Endif

  LogicClose File [TMA]# No longer need the file

  If func SFTLIB.EMPLOYEEACTIVE(VALEUR) = [V]CST_ANO
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(2,126,1)
    mkstat = 1
    End
  Endif

  If func SFTLIB.EMPLOYEE_CLOCKED_IN(VALEUR) = [V]CST_ANO
    Call ERREUR(func AFNC.MES1(mess(12,2422,1), num$(VALEUR))) From GESECRAN #CT-1797
    mkstat = 1
    End
  Endif

End

######################################################################################
Subprog AM_EMPNUM(VALEUR)
Variable Decimal VALEUR

  If !clalev([TMA]) : Local File TABMAT [TMA] : Endif

  Read [TMA]TMA0=VALEUR

  #Employee description
  [M:XECO]EMPDES = [F:TMA]EMPDES
  LogicClose File [TMA]

End


######################################################################################

