#<AdxTL>@(#)0.0.0.0 $Revision$ 
#**###########################################################
#
#  Legal datas for legislation POR for table TABVAT
#
# Window AWI=>TVTLEGPOR
# Mask/Screen AMK=>TVTLEGPOR [TVTPOR]
#
############################################################**!
#85803 RICAR 2014/05/20 - Portuguese legal requirements
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "FIN"           : Gosub FIN
 Endcase
Return

$OUVRE
#----- Paramètres de l'action DATALEG -----#
Local Char LEG(GLONADI)
Local Char COD(GLONVAT)
[L]LEG = PARAM(1)
[L]COD = PARAM(2)

#----- Tables utilisée -----#
If !clalev([F:TVT]) : Local File TABVAT [TVT] : Endif

#----- Masque local -----#
Local Mask TVTLEGPOR [TVTPOR]
Return

$DEBUT
Local Integer WRET :#--CPO 71937

#--- Alimentation des champs de l'écran ---#
#--CPO 71937 TVT and LEG as part of the key
Call LEC_TVT_LEG([L]LEG,[L]COD,WRET) From TRTLECLEG
If WRET : Raz [F:TVT] Endif
Raz  [M:TVTPOR]
#85803 RICAR 2014/05/26 - Portuguese legal requirements - BEGIN
[M:TVTPOR]EXEMOT = [F:TVT]POREXEMOT
Call UPD_EXEMOTDSC([F:TVT]POREXEMOT)
#85803 RICAR 2014/05/26 - Portuguese legal requirements - END
[L]=[M:TVTPOR]

Affzo [M:TVTPOR]
Setmok [M:TVTPOR] With 0
Return

$ENR
Trbegin [TVT]
Readlock [TVT]TVT0 = [L]COD;[L]LEG
If fstat=5
  Readlock [TVT]TVT0 = [L]COD;""
Endif
If !fstat
 [F:TVT]POREXEMOT    = [M:TVTPOR]EXEMOT
 Rewrite [TVT]
 If fstat
  GOK = 0 : Call FSTA("TVT") From GLOCK : Return
 Endif
Endif
Commit
[L]=[M:TVTPOR] : REP=""
# Issue 111186 - 2015-09-21 by RMA : To print the exemption reason on invoices
Call UPD_EXEMOTTXT([L]COD,[M:TVTPOR]EXEMOTDESC,[L]LEG)
Return

$ABA
Raz [M:TVTPOR]
[M:TVTPOR]=[L] : REP=""
Gosub ENR
Affzo [M:TVTPOR]
Return

$APRES_MODIF
Read [ALK]LCKCLE="TVT"+[L]LEG+"\"+[L]COD;0
If !fstat & [F:ALK]LCKPID<>adxuid(2)
 GMESSAGE=mess(10,100,1)
 GERR=1
 [M:TVTPOR]=[L]
 Affzo [M:TVTPOR] :# FIN=1
Else
 REP = "M"
 Local Char SYMB(20)
 SYMB="TVT"+[L]LEG+"\"+[L]COD
 Lock SYMB With lockwait=0
Endif

Return

$FIN
If dim(SYMB)>0
 Unlock SYMB
Endif
Return
######################################################################################
######################################################################################
## Section automatically added (screen TVTLEGPOR) 07/04/2014 11:23:46 (RICAR)
######################################################################################
Subprog C_EXEMOT(VALEUR)
Variable Char    VALEUR()

#85803 RICAR 2014/05/26 - Portuguese legal requirements - BEGIN
Call UPD_EXEMOTDSC(VALEUR)
#85803 RICAR 2014/05/26 - Portuguese legal requirements - END

End


######################################################################################
######################################################################################
## Section automatically added (screen TVTLEGPOR) 07/09/2014 11:19:09 (RICAR)
######################################################################################
Subprog AM_EXEMOT(VALEUR)
Variable Char    VALEUR()

#85803 RICAR 2014/05/26 - Portuguese legal requirements - BEGIN
Call UPD_EXEMOTDSC(VALEUR)
#85803 RICAR 2014/05/26 - Portuguese legal requirements - END

End


######################################################################################
Subprog UPD_EXEMOTDSC(P_EXEMOT)
Variable Char P_EXEMOT

#85803 RICAR 2014/05/26 - Portuguese legal requirements - BEGIN
If !clalev([F:VER]) : Local File VATEXEREA [VER] : Endif

If P_EXEMOT <> ''
  Read [F:VER]VER0 = P_EXEMOT
  If !fstat
    [M:TVTPOR]EXEMOTDESC = [F:VER]DESCRIPTION
  Endif
Else
  [M:TVTPOR]EXEMOTDESC = ''
Endif


Close File [VER]
#85803 RICAR 2014/05/26 - Portuguese legal requirements - END

End
######################################################################################
######################################################################################
Subprog UPD_EXEMOTTXT(PTVT,PDES, PLEG)
Value Char PTVT
Value Char PDES
Value Char PLEG

Local File ATEXTRA  [AXX]
Local File TABLAN   [TLA]
Local File TABVAT   [TVT]

Local Char FTABLE(50), FCHAMP(50), FCLE1(50), FCLE2(50), FLAN(GLONLAN)

[L]FTABLE   = "TABVAT"
[L]FCHAMP   = "TEXAXX"
[L]FCLE1    = PTVT
[L]FCLE2    = PLEG

For [F:TLA] Where [F:TLA]LANSTD = 2

  [L]FLAN = [F:TLA]LAN
  Read [AXX]AXX0 = FTABLE;FCHAMP;FLAN;FCLE1;FCLE2
  If !fstat
    If [F:AXX]TEXTE <> PDES
      Trbegin [AXX]
      [F:AXX]TEXTE = PDES
      If dim([F:AXX]UPDDAT)>0 : [F:AXX]UPDDAT = date$ : Endif
      If dim([F:AXX]UPDUSR)>0 : [F:AXX]UPDUSR = GUSER : Endif
      If dim([F:AXX]UPDTIM)>0 : [F:AXX]UPDTIM = time  : Endif
      Rewrite [AXX]
      If fstat
        Rollback : Call FSTA("AXX") From GLOCK
      Else
        Commit
      Endif
    Endif
  Else
    Raz [F:AXX]
    Trbegin [AXX]
    [F:AXX]CODFIC = FTABLE
    [F:AXX]ZONE   = FCHAMP
    [F:AXX]LANGUE = FLAN
    [F:AXX]TEXTE  = PDES
    [F:AXX]IDENT1 = FCLE1
    [F:AXX]IDENT2 = FCLE2
    If dim([F:AXX]CREDAT)>0 : [F:AXX]CREDAT = date$ : Endif
    If dim([F:AXX]CREUSR)>0 : [F:AXX]CREUSR = GUSER : Endif
    If dim([F:AXX]CRETIM)>0 : [F:AXX]CRETIM = time  : Endif
    Write [AXX]
    If fstat
      Rollback : Call FSTA("AXX") From GLOCK
    Else
      Commit
    Endif
  Endif
Next

End
######################################################################################
