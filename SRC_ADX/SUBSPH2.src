#<AdxTL>@(#)0.0.0.0 $Revision$

###########################################################
## Génération de l'écran de saisie des plans
###########################################################
Subprog GENECR(APPLI,COD)
Value Char APPLI
Value Char COD

  If clalev([F:AMK])=0  : Local File =APPLI+".AMSK"       [AMK]  : Endif
  If clalev([F:AMZ])=0  : Local File =APPLI+".AMSKZON"    [AMZ]  : Endif
  If clalev([F:AMA])=0  : Local File =APPLI+".AMSKACT"    [AMA]  : Endif
  If clalev([F:AMP])=0  : Local File =APPLI+".AMSKPAR"    [AMP]  : Endif
  Local File =APPLI+".AWINDOW"    [AWI]
  If clalev([F:AWP])=0  : Local File =APPLI+".AWINPAR"    [AWP]  : Endif
  If clalev([F:AWT])=0  : Local File =APPLI+".AWINBOUT"   [AWT]  : Endif
  If clalev([F:AWB])=0  : Local File =APPLI+".AWINBRO"    [AWB]  : Endif
  If clalev([F:AMK2])=0 : Local File =APPLI+".AMSK"       [AMK2] : Endif
  If clalev([F:AMZ2])=0 : Local File =APPLI+".AMSKZON"    [AMZ2] : Endif
  If clalev([F:AMA2])=0 : Local File =APPLI+".AMSKACT"    [AMA2] : Endif
  If clalev([F:AMP2])=0 : Local File =APPLI+".AMSKPAR"    [AMP2] : Endif
  If clalev([F:AWI2])=0 : Local File =APPLI+".AWINDOW"    [AWI2] : Endif
  If clalev([F:AWP2])=0 : Local File =APPLI+".AWINPAR"    [AWP2] : Endif
  If clalev([F:AWT2])=0 : Local File =APPLI+".AWINBOUT"   [AWT2] : Endif
  If clalev([F:AWB2])=0 : Local File =APPLI+".AWINBRO"    [AWB2] : Endif

  If clalev([F:HRSPH])=0  : Local File =APPLI+".SCRPLFH"    [HRSPH]  : Endif
  If clalev([F:HRSPD])=0  : Local File =APPLI+".SCRPLFD"    [HRSPD]  : Endif

  If clalev([F:ADS])=0  : Local File ADOSSIER             [ADS]  : Endif

  Local Char    MASKDES(GLONAMK), MASKREF(GLONAMK)
  Local Char    WINREF(GLONFEN), WINDES(GLONFEN)
  Local Integer NBRFLD, NOLIG, OK
  Local Integer FLDOPT(1..50), FLDOBG(1..50), FLDORD(1..50), FLDLIEN(1..50)
  Local Char    FLDCOD(10)(1..50) : # Zones de la transaction à afficher dans l'écran de saisie

  MASKREF = "PLF1"
  MASKDES = "WMPLF"+COD
  WINREF  = "OPLF"
  WINDES  = "WFPLF"+COD

  NBRFLD = 0
  For [HRSPD]SPD0 Where COD=[L]COD
    NBRFLD +=1
    FLDCOD(NBRFLD)  = [F:HRSPD]FLD    : # Zone
    FLDOPT(NBRFLD)  = [F:HRSPD]OPT    : # Saisi/Affiché/Invisible
    FLDORD(NBRFLD)  = [F:HRSPD]ORD+2  : # Ordre d'affichage des colonnes
    FLDOBG(NBRFLD)  = [F:HRSPD]OBG    : # Obligatoire Oui/Non
    FLDLIEN(NBRFLD) = [F:HRSPD]LIEN   : # Lien Non/Court/Long
  Next

  Call TR_DELMSK(MASKDES,APPLI) From MSKDIV
  If GOK=0 : End : Endif
  Call TR_DELWIN(WINDES,APPLI) From MSKDIV
  If GOK=0 : End : Endif
  Call DEBTRANS From GLOCK
  Gosub TR1
  If GOK=0 : End : Endif

  # Validation écran
  Read [ADS]DOSSIER = APPLI
  Call VALID(MASKDES,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
  If !OK : GOK = 0 : End : Endif

  ## Validation fenêtre
  Call VALID(WINDES,APPLI,0,OK) From VALWIN
  If !OK : GOK = 0 : End : Endif
End

$TR1
Local Integer I

  GOK = 1
  Trbegin [AMK]
  # Création de l'écran de saisie
  Read [AMK2]CODMSK = MASKREF
  [F:AMK]       = [F:AMK2]
  [F:AMK]CODMSK = MASKDES
  [F:AMK]MDL    = 1
  Write [AMK]
  If fstat : GOK=0 : Call FSTA("AMK") From GLOCK : Goto AB_TR1 : Endif

  # Création des zones de l'écran
  NOLIG = 0
  For [AMZ2]CODZON Where CODMSK=MASKREF
    NOLIG += 1
    [F:AMZ] = [F:AMZ2]
    [F:AMZ]CODMSK = MASKDES
    [F:AMZ]NUMLIG = NOLIG
    If [F:AMZ2]NUMBLOC=1 : # Les champs de la transaction de saisie portent uniquement sur le bloc 1 de PLF1
      I=find([F:AMZ]CODZON, FLDCOD)
      If I>0 Then
        [F:AMZ]NOZONE = FLDORD(I)
        [F:AMZ]SAIAFF = FLDOPT(I)
        [F:AMZ]OBLIG  = FLDOBG(I)
        [F:AMZ]LIEN   = FLDLIEN(I)
      Endif
      # Si un champ est demandé invisible, et qu'il peut avoir un lien long ou court, on met le tunnel et le lien à 0
      If [F:AMZ]SAIAFF=3 & find([F:AMZ2]CODZON,"STG","THM","DOPM","AGE","JOBPOT","POT","EMP","FCY","CATFRT","SRV")>0 Then
        [F:AMZ]TUNNEL = 0
        [F:AMZ]LIEN   = 0
      Endif
    Endif
    Write [AMZ]
    If fstat : GOK=0 : Call FSTA("AMZ") From GLOCK : Goto AB_TR1 : Endif
    Gosub COPIE_ACTION
    If GOK<1 : Break : Endif
  Next
  If GOK<1 : Goto AB_TR1 : Endif

  # Création de la fenêtre de saisie
  Read [AWI2]AWI0 = WINREF
  [F:AWI] = [F:AWI2]
  [F:AWI]WIN       = WINDES
  [F:AWI]NOMMSK(0) = MASKDES
  [F:AWI]ENAFLG    = 2
  [F:AWI]MDL       = 1
  [F:AWI]TRN       = COD
  Read [HRSPH]SPH0=COD
  If !fstat
    [F:AWI]LIBEL    = [F:HRSPH]DES
  Endif
  Write [AWI]
  If fstat
    GOK = 0 : Call FSTA("AWI") From GLOCK : Goto AB_TR1
  Endif

  # Création des paramètres de la fenêtre
  For [AWP2]AWP0 Where WIN=WINREF
    [F:AWP] = [F:AWP2]
    [F:AWP]WIN = WINDES
    Write [AWP]
    If fstat
      GOK = 0 : Call FSTA("AWP") From GLOCK : Break
    Endif
  Next
  If GOK<1 : Goto AB_TR1 : Endif

  # Création des boutons de la fenêtre
  For [AWT2]AWT0 Where WIN=WINREF
    [F:AWT] = [F:AWT2]
    [F:AWT]WIN = WINDES
    Write [AWT]
    If fstat
      GOK = 0 : Call FSTA("AWT") From GLOCK : Break
    Endif
  Next
  If GOK<1 : Goto AB_TR1 : Endif

  # Création des browsers de la fenêtre
  For [AWB2]AWB0 Where WIN=WINREF
    [F:AWB] = [F:AWB2]
    [F:AWB]WIN = WINDES
    Write [F:AWB]
    If fstat
      GOK = 0 : Call FSTA("AWB") From GLOCK : Break
    Endif
  Next
  If GOK<1 : Goto AB_TR1 : Endif

  Commit
Return

# Création des affectations et des paramètres Action/Objet
$COPIE_ACTION

  For [AMA2] Where TYPAFF=1 & CODAFF=MASKREF & CODZON=[F:AMZ]CODZON
    [F:AMA] = [F:AMA2]
    [F:AMA]CODAFF = MASKDES
    Write [AMA]
    If fstat
      GOK=0 : Call FSTA("AMA") From GLOCK : Break
    Endif
  Next
  If GOK<1 : Return : Endif
  For [AMP2] Where TYPAFF=1 & CODAFF=MASKREF & CODZON=[F:AMZ]CODZON
    [F:AMP] = [F:AMP2]
    [F:AMP]CODAFF = MASKDES
    Write [AMP]
    If fstat
      GOK=0 : Call FSTA("AMP") From GLOCK : Break
    Endif
  Next
  If   GOK<1 : Return : Endif
Return

$AB_TR1

  Rollback
Return

