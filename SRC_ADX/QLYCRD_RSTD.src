#################### Standard Query Events #########################

$AQUERY_DECODE_CRITERIA_AFTER
Raz NBPRO
NBPRO += 1
TBPRO(NBPRO) = "QLYCRD"
TBTYP(NBPRO) = 7
TBPTH(NBPRO) = "QLC.QLYCRD"
TBFIL(NBPRO) = "[LNK_]QLYCRD"
#
NBPRO += 1
TBPRO(NBPRO) = "QLYDES"
TBTYP(NBPRO) = 7
TBPTH(NBPRO) = "QLC.QLYDES"
TBFIL(NBPRO) = "[LNK_]QLYDES"
Return

$AQUERY_PRIMARYKEYS_AFTER
ASTDKEY = "[LNK_]QLYCRD"
Return

$AQUERY_OPEN_AFTER
Local File QLYCRD [QRY_QLC]
Local Integer I : I=0
Local Char TQLYCRD(8)(1..)
Local Char TQLYDES(30)(1..)
For [QRY_QLC]QLC0(1)
 I+=1
 TQLYCRD(I) = [F:QRY_QLC]QLYCRD
# TQLYDES(I) = #Lecture de ATEXTRA
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
Read [AXX]AXX0 = "QLYCRD";"QLYDESAXX";"FRA";[F:QRY_QLC]QLYCRD;""
If !fstat
   TQLYDES(I)= [F:AXX]TEXTE
Endif

Next
Local File (Char QLYCRD    (8), Char QLYDES (30)) From Variable TQLYCRD,TQLYDES As [LNK_]
Return

$AQUERY_TRANS_AFTER
this.QLC.QLYCRD    = [LNK_]QLYCRD
this.QLC.QLYDES    = [LNK_]QLYDES
Return

$AQUERY_CLOSE_AFTER
Close Local File [LNK_]
Return

