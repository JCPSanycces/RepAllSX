#<AdxTL>@(#)4.0.0.0 $Revision$
######################################################################################
#                                                                                    #
#      TRAITEMENT LIE à la gestion multi-société dans le module vente                #
#                                                                                    #
######################################################################################
#                                                                                    #
# Subprog GENSOH(LMAJCOD, LORICOD, LERRCOD)                                          #
#    S/P de mises à jour automatiques d'une commande de vente                        #
#                                                                                    #
# Subprog ALIBETCPY(LVCRTYP,LSALFCY,LBPCORD,LBPAADD,LPOHFCY,LBPSNUM,LBETFCY,LBETCPY) #
#    S/P de détermination d'un document inter-société                                #
#                                                                                    #
# Subprog CTLMAJSOH(LMAJCOD, LSOHNUM, LERRCOD)                                       #
#    S/P de contrôle de mise à jour d'une entête commande vente                      #
# Subprog C_SALFCY(LSALFCY)                                                          #
#    S/P de contrôle du site de vente                                                #
# Subprog C_BPCORD(LBPCORD, LSALFCY)                                                 #
#    S/P de contrôle du client commande                                              #
# Subprog RECBPCINV(LINVFCY, LSALFCY, LBPCINV)                                       #
#    S/P de Recherche et ctrl du client facture à partir du site de facturation      #
# Subprog RECINVFCY(LBPCINV, LINVFCY)                                                #
#    S/P de Recherche du site de facturation à partir du client facture              #
# Subprog AS_BPCINV(LBPCINV, LSALFCY)                                                #
#    S/P de Recherche si client facture modifiable                                   #
# Subprog C_BPCINV(LBPCINV, LSALFCY)                                                 #
#    S/P de contrôle du client facture                                               #
# Subprog C_BPCGRU(LBPCGRU, LSALFCY)                                                 #
#    S/P de contrôle du client groupe                                                #
# Subprog C_BPCPYR(LBPCPYR, LSALFCY)                                                 #
#    S/P de contrôle du client payeur                                                #
# Subprog C_STOFCY(LSTOFCY)                                                          #
#    S/P de contrôle du site d'expédition                                            #
# Subprog CTLMAJSOP(LMAJCOD,LSOHNUM,LSOPLIN,LSOQSEQ,LERRCOD)                         #
#    S/P de contrôle de mise à jour d'une ligne commande vente                       #
# Subprog C_ITMREF(LITMREF, LORDDAT, LORICOD)                                        #
#    S/P de contrôle de la référence article                                         #
# Subprog AS_SAU(LSOHNUM,LSOPLIN,LSOQSEQ)                                            #
#    S/P de recherche si unité de vente modifiable                                   #
# Subprog RECBPAADD(LPRHFCY, LBPCORD, LBPAADD)                                       #
#    S/P de Recherche et ctrl de l'adresse livraison à partir du site de réception   #
# Subprog RECPRHFCY(LBPCORD, LBPAADD, LPRHFCY)                                       #
#    S/P de Recherche du site de réception à partir du client livré                  #
# Subprog AS_DBPAADD(LSALFCY, LBPCORD, LSOHNUM)                                      #
#    S/P de Recherche si adresse de livraison modifiable                             #
# Subprog AS_DSTOFCY(LSTOFCY, LBPCORD, LSOHNUM, LSOPLIN, LSOQSEQ)                    #
#    S/P d'AS_ du site expédition détail                                             #
# Subprog C_QTY(LRECHQTYMAX,LBPCORD,LITMREF,LSAU,LSOHNUM,LSOPLIN,LSOQSEQ,LQTY)       #
#    S/P de Contrôle de la quantité commandée                                        #
# Subprog C_SHIDAT(LDEMDLVDAT, LBPCORD, LPRHFCY, LSTOFCY, LORDDAT)                   #
#    S/P de Contrôle de la date d'expédition                                         #
# Funprog CTLPLISTC(LBPSNUM, LSALFCY, LMSG)                                          # : # Issue 26113
#    Contrôle de la cohérence des structures entre les 2 sociétés                    # : # Issue 26113
######################################################################################
# Issue 26113 - 20150703 by LD : Inter-site : Price recalculation
# Issue 116162 - 20160422 by LD : Inter-société et révision des indexs
# Issue 116989 - 20160711 by LD : Inter-site sale order : DSPVOU field is empty
# Issue 117004 - 20161102 by LD : Back to back interco order
# Issue 120050 - 20161130 by LD : Price -/+tax on a sales order in inter-sites
# Issue 119002 - 20161226 by LD : Affectation et flux intersites
# Issue 118439 - 20170104 by LD : Sale price initialization in inter-sites orders
# Issue X3-26200 - 20170512 by LD : Closing purchase order not allowed when flows are not ended in inter-company
# Issue X3-38629 - 20170607 by LD : Intersite generated sales order does not pull line item text
# Issue X3-66385 - 20180222 by LD : Sales order: Default package by shipment site

#------------------------------------------------------------------------------------#
# GENSOH : Sous-progrme de mises à jour automatiques d'une commande de               #
#          VENTE                                                                     #
#------------------------------------------------------------------------------------#
# Prérequis : Le buffer à l'origine de la maj doit être ouvert                       #
#------------------------------------------------------------------------------------#
# Entrée  LMAJCOD    : Code mise à jour :                                            #
#                            "C" : Création                                          #
#                            "M" : Modification                                      #
#                            "A" : Suppression                                       #
#                            "S" : Solde                                             #
#         LORICOD    : Code origine                                                  #
#                            1   : Commande achat                                    #
# Sortie  LERRCOD    : Code retour                                                   #
#------------------------------------------------------------------------------------#
Subprog GENSOH(LMAJCOD, LORICOD, LERRCOD)
Value    Char    LMAJCOD
Value    Integer LORICOD
Variable Integer LERRCOD
Raz LERRCOD
Local Integer SAV_GMANCOU        : SAV_GMANCOU=GMANCOU : # MBT 30/08/2004
Local Char    SAV_GFLAG(GLONAVA) : SAV_GFLAG  =GFLAG   : # MBT 20/04/2009
Local Char    SAV_GABREV(5)      : SAV_GABREV =GABREV  : # MBT 20/04/2009
Gosub OUVRE
If GOK=0
  GMANCOU=SAV_GMANCOU                                  : # MBT 23/08/2004
  GFLAG  =SAV_GFLAG                                    : # MBT 20/04/2009
  GABREV =SAV_GABREV                                   : # MBT 20/04/2009
  End
Endif
Case LMAJCOD
    When "C" : Gosub SOH_CREATION    # creation
    When "M" : Gosub SOH_MODIF       # modification
    When "A" : Gosub SOH_ANNULE      # suppression
    When "S" : Gosub SOH_SOLDE       # solde
Endcase
Gosub FERME
GMANCOU=SAV_GMANCOU                                    : # MBT 30/08/2004
GFLAG  =SAV_GFLAG                                      : # MBT 20/04/2009
GABREV =SAV_GABREV                                     : # MBT 20/04/2009
End

##############################################################################
# ouverture des tables                                                       #
##############################################################################
$OUVRE
If clalev ([F:SOH])=0  Local File SORDER      [SOH] : Endif
If clalev ([F:SOP])=0  Local File SORDERP     [SOP] : Endif
If clalev ([F:SOQ])=0  Local File SORDERQ     [SOQ] : Endif

If clalev ([F:BPR])=0  Local File BPARTNER    [BPR] : Endif
If clalev ([F:BPD])=0  Local File BPDLVCUST   [BPD] : Endif
If clalev ([F:BPDW])=0 Local File BPDLVCUST   [BPDW]: Endif
If clalev ([F:BPC])=0  Local File BPCUSTOMER  [BPC] : Endif
If clalev ([F:TSO])=0  Local File TABSOHTYP   [TSO] : Endif
If clalev ([F:ITM])=0  Local File ITMMASTER   [ITM] : Endif
If clalev ([F:ITS])=0  Local File ITMSALES    [ITS] : Endif
If clalev ([F:ITU])=0  Local File ITMBPC      [ITU] : Endif
If clalev ([F:ITP])=0  Local File ITMBPS      [ITP] : Endif
If clalev ([F:TCA])=0  Local File TABCOUAFF   [TCA] : Endif
If clalev ([F:FCY])=0  Local File FACILITY    [FCY] : Endif
If clalev ([F:SPK])=0  Local File SPRICLINK   [SPK] : Endif
If clalev ([F:SPL])=0  Local File SPRICLIST   [SPL] : Endif
If clalev ([F:TCU])=0  Local File TABCUR      [TCU] : Endif
If clalev ([F:REP])=0  Local File SALESREP    [REP] : Endif
If clalev ([F:PRS])=0  Local File PRICSTRUCT  [PRS] : Endif
If clalev ([F:ITF])=0  Local File ITMFACILIT  [ITF] : Endif

# ouverture des masques
If clalev([M:SOH0])=0 Local Mask SOH0 [SOH0] Endif
If clalev([M:SOH1])=0 Local Mask SOH1 [SOH1] Endif
If clalev([M:SOH2])=0 Local Mask SOH2 [SOH2] Endif
If clalev([M:SOH3])=0 Local Mask SOH3 [SOH3] Endif
If clalev([M:SOH4])=0 Local Mask SOH4 [SOH4] Endif

Diszo [M:SOH0]1-99
Diszo [M:SOH1]1-99
Diszo [M:SOH2]1-99
Diszo [M:SOH3]1-99
Diszo [M:SOH4]1-99

Raz [M:SOH0], [M:SOH1], [M:SOH2], [M:SOH3], [M:SOH4]

Local  Integer   OK
Local  Integer   WNBLIG
Local  Char      ACTION(20)
Local  Char      ABFIC(5)
Local  Char      OBJLIS(1)(1..8)
Local  Decimal   QTY_UV
Local  Integer   WFMI
Local  Integer   WOUVRE_TRACE
Local  Integer   NLIG
Local  Integer   NOLPOH           # indice utilisé pour travailler ds le tableau [M:POH2]
Local  Char      WITM(GLONITM)
Local  Char      WREP(GLONREP)
Local  Char      WDBPAADD(GLONBPD)
Local  Char      WMESS(80)
Local  Integer   SAVGIMPORT
Local  Char      SAVGREP
Local  Char      GRPDEB(GLONVCR)
Local  Integer   NOL              # 107890 : Scheduled invoices : (LD:06/06/16)

Global Char      GPNTITMREF       # composé
Global Integer   GMANCOU
Global Integer   GDACLOK        : # Flag ctrl qté, prix, marge, montant mini

Local  Char      WPARAM(10)
#--------------------------------------------------------------#
# Chargement param.utilisateur ctrl qte,prix,marge,montant mini#
#--------------------------------------------------------------#
Call PARAMUTIL("SDACLOK",WPARAM,"","") From SUBAUS
GDACLOK=val(WPARAM)
If GDACLOK=0 GDACLOK=1 Endif

SAVGREP=GREP
# Issue 99819 - 2014-06-19 by SR : Toujours sauvegarder GIMPORT
SAVGIMPORT = GIMPORT

If LMAJCOD<>"A"
# GIMPORT=1 pose pb en suppression (on part en boucle)
#    SAVGIMPORT = GIMPORT : GIMPORT =1
     GIMPORT =1
Endif
Raz GFLAG : # MBT 20/04/2009
OK=1
GABREV="SOH"
ABFIC="SOH"
ACTION ="OUVRE"
Gosub ACTION From  GOBJSUB
If !OK : GOK=0 : Return : Endif

# masques par défaut
Default Mask [SOH0]
Default Mask [SOH1]
Default Mask [SOH2]
Default Mask [SOH3]
Default Mask [SOH4]

#If GTRACE=""
#    Call OUVRE_TRACE(mess(494,197,1)) From LECFIC
#    WOUVRE_TRACE=1
#Else
#    WMESS=mess(494,197,1)                     : # HN
#    Call ECR_TRACE(WMESS,0) From GESECRAN     : # HN
#Endif
#----- Ecriture dans la trace si elle est ouverte (MBT 16/04/09) -----#
If GTRACE<>""
  Call ECR_TRACE(mess(494,197,1),0) From GESECRAN
  If LORICOD=1
    WMESS=mess(40,197,1)-mess(14,701,1)-num$([M:POH0]POHNUM)
    Call ECR_TRACE(WMESS,0) From GESECRAN
   Endif
Endif
#-----
Return

##############################################################################
$SOH_CREATION

    GREP="C"

    # -- ACA - Ouverture du tableau de stockage des éléments facture
    Local Char SFIT_OBJ : SFIT_OBJ="SOH"
    Gosub INIT_SFIT From SUBSFIT
    #-----
    If GTRACE<>""
      WMESS=mess(59,123,1)-mess(2,701,1) : # Création commande vente
      Call ECR_TRACE(WMESS,0) From GESECRAN
    Endif
    #-----
    Gosub ALISOH
    If GOK <= 0 Return : Endif
    OK =1
    ACTION ="VERIF_CRE"
    Gosub ACTION From  GOBJSUB
    If !OK : GOK = 0 : Return : Endif
    Default File [SOH]
    Raz  [F:SOH]
    nolign  =  1
    [F:SOH] = [M:SOH0]
    [F:SOH] = [M:SOH1]
    [F:SOH] = [M:SOH2]
    [F:SOH] = [M:SOH3]
    [F:SOH] = [M:SOH4]
    Gosub INICRE From GOBJSUB
    ACTION ="INICRE"
    Gosub ACTION From  GOBJSUB
    If GOK<=0 : Return : Endif
    Write [F:SOH]
    If fstat
      GOK=0 : Call FSTA("SOH") From GLOCK : Return
    Endif
    ACTION ="CREATION"
    Gosub ACTION From  GOBJSUB
    If GOK<=0 : Return : Endif
    #----- Mise à jour du suivi workflow signature -----#
    If GOK=1
      # -- Déf des variables workflow
      Call WRKGLOB(170,[F:SOH]SOHNUM,"SORDER","") From GOBJACT
      #-------------------------------------------------------------------------------------#
      # Subprog WORKPLUS(TYPEVT,CODEVT,OPERAT,CLEOBJ,CODE,SIMUL,DIFFERE,TYPDEC,GRPDEB)      #
      # TYPEVT  : Type d'évènement Workflow (objet/import/etc.)                             #
      # CODEVT  : Code évènement                                                            #
      # OPERAT  : Opération (Modification/Bouton/etc.)                                      #
      # CLEOBJ  : Clé de l'objet si typevt=objet ou chrono origine/dest si typevt=signature #
      # CODE    : Code workflow (cas du bouton W et du workflow manuel)                     #
      # SIMUL   : Permet de simuler OU de générer un workflow manuel                        #
      # DIFFERE : Envoi message différé (transactions de création/modification d'un objet)  #
      # TYPDEC  : Déclenchement workflow avant/après mise à jour classe [F] (modif objet)   #
      # GRPDEB  : Premier chrono groupe (utilisé pour l'envoi différé)                      #
      #-------------------------------------------------------------------------------------#
      Call WORKPLUS(2,"SOH","C",[F:SOH]SOHNUM,"",0,1,0,GRPDEB) From AWRK
      If GOK<=0 : Return : Endif
      #----- Envoi des messages groupe workflow signature -----#
      If GRPDEB<>""  Call ENVOI_GROUPE(GRPDEB) From AWRK : GRPDEB="" : Endif
    Endif
    Gosub MAJPOH
    #-----
    If GTRACE<>""
      WMESS=mess(10,159,1)-num$([M:POH3]OCNNUM)-mess(224,197,1)-"   "-mess(99,197,1)-[M:POH0]BPCORD
      Call ECR_TRACE(WMESS,0) From GESECRAN
    Endif
    #-----
Return

##############################################################################
# Alimentation Entête cmd de vente                                           #
##############################################################################
$ALISOH

NOLPOH =1
Case LORICOD
    When 1 : Gosub ALIPOHENT
             If GOK <= 0 Return : Endif
             WNBLIG = [M:POH2]NBLIG
Endcase
Gosub ALIBPCENT
If GOK <= 0 Return : Endif
Gosub ALIDIVENT
If GOK <= 0 Return : Endif

# nolign est l'indice utilisé pour parcourir le tableau [M:SOH4]
# NOLPOH est l'indice utilisé pour parcourir le tableau [M:POH2]

[M:SOH4]NBLIG=0
nolign=1
For NOLPOH =1 To WNBLIG
    # Alimentation d'une ligne détail cmd de vente
    Gosub CTLALIDET
    If GERR =0
        Gosub ALIDET
        If GOK<=0 Break Endif
        If GERR=0
            [M:SOH4]SOPLIN(nolign-1) = nolign*1000
            [M:SOH4]NBLIG+=1
            nolign+=1
        Endif
    Endif
Next
If GOK<=0 Return Endif

# point d'entrée pour alimenter des champs spécifiques des écrans commande
GPOINT ="ALIMSKSOH" : Gosub ENTREE From EXEFNC

Return
##############################################################################
# alimentation des zones à partir de la cmd d'achat
$ALIPOHENT
Local Integer WOK
Local Integer WRETTSO
# catégorie de cmd
[M:SOH0]SOHCAT = [M:POH0]SOHCAT

# site de vente
[M:SOH0]SALFCY = [M:POH0]SALFCY
GFCY = [M:SOH0]SALFCY
#Call GETDEV(GFCY) From DEVSUB
# Chargement des globales référenciels, comptes et sections de la société
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
GHEADIE=2
Call GLOBVAR(GFCY,"VEN") From TRTX3

# 95742 : PJT en inter société/inter site : (LD:20/04/16)
Gosub CHARG_PARAM From SUBSOHA
If GERR=1 Gosub TRT_ERR : GOK=0 : Return : Endif
# 95742 : PJT en inter société/inter site : (LD:20/04/16)

# Init.devise pr init.format saisie colonnes remise pr pouvoir ensuite afficher le tableau des lignes
#[M:SOH1]CUR=GLOCALDEV
[M:SOH1]CUR=[M:POH1]CUR : # Bug 60043 : Init de la devise avec la devise de la commande d'achat
[M:SOH0]CUR=[M:SOH1]CUR : # Bug 60043
#----------------------------------------------------#
# Chargement libellés et formats colonnes tarif      #
#----------------------------------------------------#
#If GACTMUL=2
# Alimentation concernant les colonnes frais/remises en fonction de la structure tarif de la société
Local Integer SVG_GIMPORT : SVG_GIMPORT=GIMPORT : GIMPORT=1
Call ALICOLREM (1,2,GFLAG,"SOH4",[M:SOH1]CUR,1,[M:SOH0]PLISTC) From TRTPRICE
GIMPORT=SVG_GIMPORT
#Endif

# client cmd
[M:SOH0]BPCORD = [M:POH0]BPCORD

# date de la cmd
[M:SOH0]ORDDAT = [M:POH0]ORDDAT

# ref cmd client
[M:SOH0]CUSORDREF = [M:POH0]POHNUM

# site origine
[M:SOH0]ORIFCY =[M:POH0]POHFCY

# fournisseur
[M:SOH0]BPSNUM =[M:POH0]BPSNUM

# site achat
[M:SOH0]POHFCY =[M:POH0]POHFCY

# client facture
Read [BPR]BPR2(2)=2;[M:POH1]INVFCY
[G:BPR]currind=1 :[G:BPR]currlen=0
If !fstat
    [M:SOH1]BPCINV =  [F:BPR]BPRNUM
Endif

# client payeur
[M:SOH1]BPCPYR = [M:SOH1]BPCINV
# adresse de livraison
Filter [BPD] Where BPCNUM = [M:SOH0]BPCORD and RCPFCY =[M:POH2]PRHFCY(0)
Read [BPD]BPD0 First
If !fstat
    [M:SOH1]BPAADD = [F:BPD]BPAADD
Endif
Filter [BPD]

# site expédition
[M:SOH2]STOFCY =[M:POH1]STOFCY

#alimentation du flag inter-site
[M:SOH1]BETFCY =[M:POH0]BETFCY

#alimentation du flag livraison partielle
[M:SOH2]DME =[M:POH0]DME

# date de livraison demandée
[M:SOH2]DEMDLVDAT  =[M:POH1]EXTRCPDAT1

#alimentation du flag inter-société
[M:SOH1]BETCPY =[M:POH0]BETCPY

# type de cmd
Call IS_SOHTYP ([M:SOH0]SOHCAT,[M:SOH0]SALFCY,[M:SOH0]SOHTYP) From FUNBCH

# Bug 79827 : Informations douanières initialisées à partir de la commande d'achat
[M:SOH0]EECICT=[M:POH1]EECICT2
If dim([M:SOH2]EECICT)>0 [M:SOH2]EECICT=[M:POH1]EECICT2 Endif
[M:SOH0]ICTCTY=[M:POH1]ICTCTY2
If dim([M:SOH2]ICTCTY)>0 [M:SOH2]ICTCTY=[M:POH1]ICTCTY2 Endif
# Bug 79827

# point d'entrée après alim. des champs entête cde vente à partir des champs entête cde achat
GPOINT ="ALIPOHENT" : Gosub ENTREE From EXEFNC

#--CPO 71937 26.04.2013 Cohérence
#Read [TSO]TSO0=[M:SOH0]SOHTYP
#If !fstat
Call LEC_TSO_LEG(GCURLEG,[M:SOH0]SOHTYP,WRETTSO) From TRTLECLEG
If WRETTSO=0
#--/
    # flag compteur manuel
    GMANCOU=[F:TSO]MANCOU
    # code compteur
    GCPT=[F:TSO]CODNUM
    # 75115 : V7 : Extension of Digital Signature : New field delivery type
    [M:SOH2]SDHTYP = [F:TSO]SDHTYP
Endif

# 95742 : PJT en inter société/inter site : (LD:20/04/16)
# Le PJT transite uniquement en intersite
If [M:SOH1]BETFCY=2 & [M:SOH1]BETCPY=1
    [M:SOH1]PJT=[M:POH1]PJTH
Endif
# 95742 : PJT en inter société/inter site : (LD:20/04/16)

Return


##############################################################################
#alimentation à partir des clients
$ALIBPCENT
Local Integer NBPOSTE
Local Integer I, SPSTAT
Local Decimal MONTANT

# contrôle du client cmd
Read [BPC]BPC0 = [M:SOH0]BPCORD
If fstat : GERR=1 : LERRCOD=1 : Gosub TRT_ERR : GOK=0 : Return : Endif
If [F:BPR]BPRNUM<>[M:SOH0]BPCORD
    Read [BPR]BPR0 = [M:SOH0]BPCORD
    If fstat : GERR=1 : LERRCOD=1 : Gosub TRT_ERR : GOK=0 : Return : Endif
Endif
If LORICOD<>1
    Call C_BPCORD([M:SOH0]BPCORD, [M:SOH0]SALFCY)
    If GERR=1 :Gosub TRT_ERR : GOK=0 : Return : Endif
Endif

#alimentation à partir du client cmd
# nom
[M:SOH0]BPCNAM     = [F:BPC]BPCNAM
# impression ARC
[M:SOH0]OCNFLG     = [F:BPC]OCNFLG
# montant mini cde
[M:SOH0]ORDMINAMT  = [F:BPC]ORDMINAMT
# code statistique
If dim([M:SOH0]TSCCOD)>0
    For I = 1 To dim([M:SOH0]TSCCOD)
        [M:SOH0]TSCCOD(I-1) = [F:BPC]TSCCOD(I-1)
    Next I
Endif
# représentants
If dim([M:SOH1]REP)>0
    For I = 1 To dim([M:SOH1]REP)
        [M:SOH1]REP(I-1)    = [F:BPC]REP(I-1)
    Next I
Endif
# autor. solde cde
[M:SOH2]ORDCLE = [F:BPC]ORDCLE
# 1 cde par livraison
[M:SOH2]ODL    = [F:BPC]ODL
# livraison partielle
If LORICOD<>1 [M:SOH2]DME = [F:BPC]DME : Endif
# mode facturation
[M:SOH3]IME    = [F:BPC]IME
# langue
[M:SOH0]LAN    = [F:BPR]LAN

# personne à contacter
If dim([M:ADB1]CNTNAM)>0
    Call RECH_CNTNAM([M:SOH0]BPCORD, [F:BPC]BPAADD, [M:ADB1]CNTNAM) From TRTVENDIV
Endif

#alimentation de [M:SOH3]IME
If [M:SOH0]SOHCAT=3 &  [M:SOH3]IME=1 : [M:SOH3]IME=3 : Endif

#lecture du client livré
If [M:SOH1]BPAADD = "" & LORICOD<>1
    Filter [BPD] Where BPCNUM = [M:SOH0]BPCORD & ENAFLG=2
    Read [BPD]BPD0=[M:SOH0]BPCORD;[F:BPC]BPDADD
    If !fstat
        [M:SOH1]BPAADD = [F:BPD]BPAADD
    Else
        Read [BPD]BPD0 First
        #--CPO 87264 filter reste positionné
        #If fstat : GOK=0 : Return : Endif
        If fstat : GOK=0 : Filter [BPD] : Return : Endif
        [M:SOH1]BPAADD = [F:BPD]BPAADD
    Endif
    Filter [BPD]
Endif
If [M:SOH1]BPAADD = ""
    GERR=1 : LERRCOD=2 : Gosub TRT_ERR : GOK=0 : Return
Endif
If [F:BPD]BPCNUM <> [M:SOH0]BPCORD | [F:BPD]BPAADD <> [M:SOH1]BPAADD
    Read [BPD]BPD0 = [M:SOH0]BPCORD;[M:SOH1]BPAADD
    If fstat : GERR=1 : LERRCOD=2 : Gosub TRT_ERR : GOK=0 : Return : Endif
Endif

#alimentation à partir du client livré
# raison sociale
[M:SOH1]BPDNAM = [F:BPD]BPDNAM
# représentant
If dim([M:SOH1]REP)>0
    For I = 1 To dim([M:SOH1]REP)
        If [M:SOH1]REP(I-1) = "" [M:SOH1]REP(I-1) = [F:BPD]REP(I-1) : Endif
    Next I
Endif
# n°de tournée
[M:SOH2]DRN    = [F:BPD]DRN
# priorité  de livraison
[M:SOH2]DLVPIO = [F:BPD]DLVPIO
# délai de livraiosn
[M:SOH2]DAYLTI = [F:BPD]DAYLTI
# mode de livraison
[M:SOH2]MDL    = [F:BPD]MDL
# transporteur
[M:SOH2]BPTNUM = [F:BPD]BPTNUM

If LORICOD=1 & [M:SOH2]MDL ="" : [M:SOH2]MDL = [M:POH1]MDL : Endif
If LORICOD=1 & [M:SOH2]BPTNUM ="" :[M:SOH2]BPTNUM = [M:POH1]BPTNUM : Endif

# Adresse de livraison
If dim([M:ADB2]BPAADD)>0 [M:ADB2]BPAADD = [F:BPD]BPAADD Endif
#contact livraison
If dim([M:ADB2]CNTNAM)>0
    Call RECH_CNTNAM([M:SOH0]BPCORD, [F:BPD]BPAADD, [M:ADB2]CNTNAM) From TRTVENDIV
Endif

# Alimentation régime de taxe à partir du client livré
# JPGA : 16/06/2008 - Recherche Régime taxe s'il est renseigné dans le tiers société
Call INIT_REGIME([M:SOH0]BPCORD, GSOCIETE, "C", [M:SOH1]VACBPR) From CPTSUB
If [F:BPD]VACBPR<>"" [M:SOH1]VACBPR = [F:BPD]VACBPR Endif

# Alimentation des champs relatifs au infos douanières
# Bug 79827 : Initialisé à partir de la commande d'achat
#[M:SOH0]EECICT=[F:BPD]EECICT
#If dim([M:SOH2]EECICT)>0 [M:SOH2]EECICT=[F:BPD]EECICT Endif   :#-- CPO 65018
#[M:SOH0]ICTCTY=[F:BPD]ICTCTY
#If dim([M:SOH2]ICTCTY)>0 [M:SOH2]ICTCTY=[F:BPD]ICTCTY Endif   :#-- CPO 65018
#[M:SOH0]FFWNUM=[F:BPD]FFWNUM
#[M:SOH0]FFWADD=[F:BPD]FFWADD
# Bug 79827
If dim([M:SOH0]EECLOC)>0 [M:SOH0]EECLOC=[F:BPD]EECLOC Endif

# lecture + contrôle du client facture
If [M:SOH1]BPCINV =""
    If [F:BPC]BPCNUM<>[M:SOH0]BPCORD
        Read [BPC]BPC0 = [M:SOH0]BPCORD
        If fstat : GOK=0 : Return : Endif
    Endif
    [M:SOH1]BPCINV =[F:BPC]BPCINV
Endif
If  [F:BPC]BPCNUM<>[M:SOH1]BPCINV
    Read [BPC]BPC0 = [M:SOH1]BPCINV
    If fstat : GERR=1 : LERRCOD=3 : Gosub TRT_ERR : GOK=0 : Return : Endif
Endif
If  [F:BPR]BPRNUM<>[M:SOH1]BPCINV
    Read [BPR]BPR0 = [M:SOH1]BPCINV
    If fstat : GERR=1 : LERRCOD=3 : Gosub TRT_ERR : GOK=0 : Return : Endif
Endif
# Pas de contrôle si commande intrasociété puisqu'il n'y aura aucune facture
If LORICOD<>1 & [M:SOH1]BETCPY=1
    Call C_BPCINV([M:SOH1]BPCINV, [M:SOH0]SALFCY)
    If GERR=1 : Gosub TRT_ERR : GOK=0 : Return : Endif
Endif

#alimentation à partir du client facture
# type de cours
[M:SOH0]CHGTYP = [F:BPC]CHGTYP
# raison sociale
[M:SOH1]BPINAM = [F:BPC]BPCNAM
# type de prix
# Issue 120050
# Purchase order manage only exclude tax (not include tax)
#[M:SOH1]PRITYP = [F:BPC]PRITYP
[M:SOH1]PRITYP = 1
# End issue 120050

# Initialisation des escomptes et agios
Call INIT_ESCOMPTE([F:BPC]BPCNUM, GSOCIETE, "C", [M:SOH3]DEP) From CPTSUB

# devise
# Bug 60043 : Init de la devise avec la devise de la commande d'achat
#[M:SOH0]CUR    = [F:BPC]CUR
#[M:SOH1]CUR    = [F:BPC]CUR
If [F:BPC]CUR<>[M:SOH0]CUR   : # Conversion du montant mini cde si besoin
    Call CONVERT([F:BPC]CUR, [M:SOH0]CUR, GLOCALDEV, [M]CHGTYP, date$, [M:SOH0]ORDMINAMT,MONTANT,SPSTAT) From TRTDEV
    [M:SOH0]ORDMINAMT = MONTANT
Endif

# contact facture
If dim([M:ADB3]CNTNAM)>0
    Call RECH_CNTNAM([M:SOH1]BPCINV, [F:BPC]BPAADD, [M:ADB3]CNTNAM) From TRTVENDIV
Endif
# Bug 117347: adresse de facturation et flux inter-sites (Lc-28/11/16)
[M:ADB3]BPAADD=[F:BPC]BPAINV

# identification CEE
#If dim([M:ADB3]EECNUM)>0
#   [M:ADB3]EECNUM = [F:BPR]EECNUM
#Endif

If dim([M:SOH0]BPIEECNUM)>0
    Call INIEECNUM ([M:SOH0]BPCORD,[M:SOH1]BPAADD,[M:SOH1]BPCINV,[M:SOH0]BPIEECNUM,[M:SOH0]EECNUMCRY) From TRTVENDIV
Endif

# 107890 : Scheduled invoices : (LD:03/06/16)
# Init of the invoicing condition only for Normal order
If [M:SOH0]SOHCAT=1
    [M:SOH3]INVCND=[F:BPC]INVCND
Else
    Raz [M:SOH3]INVCND
Endif
# 107890 : Scheduled invoices : (LD:03/06/16)

# Init. du tableau des éléments de facturation
NBPOSTE=dim([M:SOH3]INVDTA)
Raz [M:SOH3]INVDTAAMT
Call STRUFOOT (3,"SOH3",NBPOSTE,[M:SOH0]CHGTYP,[M:SOH0]CUR, [M:SOH0]CUR, "OUI") From SUBSFIT
[M:SOH3]NBFAC = NBPOSTE

# -- ACA - Ouverture du tableau de stockage des éléments facture
Call NEW_SFIT ("M","SOH3",[M:SOH0]CUR,[M:SOH1]BPCINV, [M:SOH0]BPCORD, [M:SOH0]ORDDAT) From SUBSFIT

Local Integer WRET
Call IS_DTAPOHSOH ([M:SOH0]ORIFCY,[M:SOH0]SALFCY,"[M:POH3]","[M:SOH3]",[M:POH1]CUR,[M:SOH0]CHGTYP,[M:SOH1]CUR,[M:SOH0]ORDDAT,WRET) From FUNBCH

# calcul de l'état crédit
Call SDCDTSTA([M:SOH0]CUSORDREF,[M:SOH0]BPCORD,[M:SOH0]CHGTYP,0,[M:SOH0]CUR,[M:SOH0]ORDDAT,[M:SOH2]UNL,1,[M:SOH1]CDTSTA,
&                [M:SOH0]OST,[M:SOH0]OSTAUZ) From TRTVENCDT

# lecture + contrôle du client payeur
If [M:SOH1]BPCPYR =""
    Read [BPC]BPC0 = [M:SOH0]BPCORD
    If fstat : GOK=0 : Return : Endif
    [M:SOH1]BPCPYR =[F:BPC]BPCPYR
Endif
If LORICOD<>1
    Call C_BPCPYR([M:SOH1]BPCPYR, [M:SOH0]SALFCY)
    If GERR=1 : Gosub TRT_ERR : GOK=0 : Return : Endif
Endif

# Initialisation du code condition de paiement
Call INIPTE ([M:SOH1]BPCPYR, [M:SOH1]BPCINV, "C", [M:SOH3]PTE) From TRTX3

# client groupe
If [F:BPC]BPCNUM<>[M:SOH0]BPCORD
    Read [BPC]BPC0 = [M:SOH0]BPCORD
    If fstat : GOK=0 : Return : Endif
Endif
[M:SOH1]BPCGRU = [F:BPC]BPCGRU
If LORICOD<>1
    Call C_BPCGRU([M:SOH1]BPCGRU,  [M:SOH0]SALFCY)
    If GERR=1 :Gosub TRT_ERR : GOK=0 : Return : Endif
Endif

Return

##############################################################################
#alimentation diverses
$ALIDIVENT
Local Char    SECTION
Local Integer STAT

# Alimentation du code structure
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If [F:CPY]CPY<>GSOCIETE
    Read [CPY] CPY0=GSOCIETE
    If fstat Raz [F:CPY] Endif
Endif
[M:SOH0]PLISTC=[F:CPY]PLISTC

# type de cmd
If [M:SOH0]SOHTYP =""
#    Filter [TSO] Where SOHCAT =[M:SOH0]SOHCAT
#    Read [TSO]TSO0 First
    If !clalev([F:FGR]) : Local File FACGROUP  [FGR] : Endif
    Link [TSO] With [FGR]FGR0=[F:TSO]GFY;GCURFCY As [KTSO]

    Filter [KTSO] Where SOHCAT=[M:SOH0]SOHCAT  & ([TSO]GFY="" | [FGR]FCY=GCURFCY)
    Read [KTSO]TSO0 First
    #--CPO 87264 filter reste positionné
    #If fstat : LERRCOD=35 : Gosub TRT_ERR : GOK=0 : Return : Endif  : # Il faudrait un message d'erreur SVP
    If fstat : LERRCOD=35 : Gosub TRT_ERR : GOK=0 : Filter [KTSO] : Return : Endif  : # Il faudrait un message d'erreur SVP
    [M:SOH0]SOHTYP = [F:TSO]SOHTYP
    # flag compteur manuel
    GMANCOU=[F:TSO]MANCOU
    # code compteur
    GCPT=[F:TSO]CODNUM
    #--CPO 87264 filter reste positionné
    #Filter [TSO]
    Filter [KTSO]
Endif

# type allocation
[M:SOH2]ALLTYP = GALLTYP

# date expédition
Call CALC_SHIDAT ([M:SOH2]DEMDLVDAT, [M:SOH2]DAYLTI, [M:SOH2]STOFCY,1,1,[M:SOH0]ORDDAT,[M:SOH2]SHIDAT) From TRTVENDAT
# Bug 81008
If GERR=2
    LERRCOD=29 : Gosub TRT_ERR : Raz GERR
Endif

If [M:SOH2]SHIDAT>[M:SOH2]DEMDLVDAT
    GERR=2 : LERRCOD=29 : Gosub TRT_ERR : Raz GERR
    [M:SOH2]SHIDAT =[M:SOH2]DEMDLVDAT
Endif

# 107890 : Scheduled invoices : (LD:03/06/16)
# Init of the scheduled invoice start date only for Normal order
If [M:SOH0]SOHCAT=1
    [M:SOH3]VCRINVCNDDAT=[M:SOH0]ORDDAT
Endif
# 107890 : Scheduled invoices : (LD:03/06/16)

#----- Lecture entete commande achat si elle a été paramétrée dans "SOH" -----#
If LORICOD=1 & [M:POH0]POHNUM<>""
    If [F:POH]POHNUM<>[M:POH0]POHNUM
        Read [POH] POH0=[M:POH0]POHNUM
        If fstat  Raz [F:POH] : Endif
    Endif
Endif

# Initialisation sections analytiques
If dim([M:SOH3]NBAXE)>0
   For nolign = 1 To GNBDIE
       [M:SOH3]DIE(nolign -1) = GDIE(nolign)
       Call INISEC(SECTION, "SOH",GDIE(nolign)) From SUBCDE
       [M:SOH3]CCE(nolign -1) = SECTION
   Next nolign

  #-- nb axe
#  [M:SOH3]NBAXE = GOPTCANA
Endif

# initialisation des flags
[M:SOH1]ORDSTA = 1
[M:SOH1]ALLSTA = 1
[M:SOH1]DLVSTA = 1
[M:SOH1]INVSTA = 1
[M:SOH1]OCNPRN = 1
[M:SOH1]APPFLG = 1  : GUPDAPPFLG=1

# 94587 : Pb naming convention
#Raz [M:SOH0]YAPPFLG : # 89410 : Pb maj encde client en suppression ligne
Raz [M:SOH0]OLDAPPFLG
# 94587

# Issue 116989
#------------------------------------------------------------#
# Renseignement des unités de répartition                    #
#------------------------------------------------------------#
[M:SOH0]DSPWEU = GSALDSPWEU
[M:SOH0]DSPVOU = GSALDSPVOU
# End issue 116989

Return
##############################################################################
# contrôle l'alimentation d'une ligne détail cmd de vente                    #
##############################################################################
$CTLALIDET

Raz GERR : Raz GMESSAGE : Raz mkstat

Case LORICOD
    When 1 :
        WITM = [M:POH2]ITMREF(NOLPOH-1)    # alimentation ref. article
        Gosub RECBPD                       # recherche adresse de livraison
Endcase

If WDBPAADD="" & LORICOD<>1 WDBPAADD=[M:SOH1]BPAADD : Endif
If WDBPAADD="" GERR=1 : LERRCOD=2 : Gosub TRT_ERR :  Return : Endif

# alimentation représentant
If dim([M:SOH1]REP(0))>0 : WREP = [M:SOH1]REP(0) : Endif

# lecture + contrôle article
Read [ITM]ITM0= WITM
If fstat : GERR=1 :  LERRCOD=5 : Gosub TRT_ERR  : Return : Endif
Read [ITS]ITS0= WITM
If fstat : GERR=1 :  LERRCOD=6 : Gosub TRT_ERR : Return : Endif
If LORICOD<>1
    Call C_ITMREF(WITM, [M:SOH0]ORDDAT, LORICOD)
    If GERR=1 : Gosub TRT_ERR :  Return : Endif
Endif

# recherche interdit
Call RECH_INTERDIT (WITM,WDBPAADD,WREP,2) From TRTVENTAR
If mkstat=2 : GERR=1 : LERRCOD=27 : Gosub TRT_ERR : Return : Endif

# 107890 : Scheduled invoices : (LD:08/12/15)
# Invoicing condition is mandatory for undeliverable item
If [F:ITM]DLVFLG=1 & [M:SOH3]INVCND="" & [F:ITS]INVCND=""
    GERR=1 : GMESSAGE=WITM-":"-mess(501,192,1)-":"-mess(864,197,1) :
    Gosub TRT_ERR : Return
Endif
# 107890 : Scheduled invoices : (LD:08/12/15)

Return

##############################################################################
# alimentation d'une ligne de détail
##############################################################################
$ALIDET

Gosub ALIENTDET
If GOK <= 0 Return : Endif
Case LORICOD
    When 1: Gosub ALIPOHDET
            If GOK <= 0 Return : Endif
Endcase
Gosub ALIBPDDET
If GOK <= 0 Return : Endif
Gosub ALIARTDET
If GERR = 1 Return : Endif
If GOK <= 0 Return : Endif
Gosub ALIDIVDET
If GOK <= 0 Return : Endif

# point d'entrée pour alimenter des champs spécifiques de l'écran détail commande
GPOINT ="ALIMSKSOH4" : Gosub ENTREE From EXEFNC

Return

##############################################################################
# alimentation avec l'entête de cmd de vente
$ALIENTDET
Local Integer I


# Alimentation des commissions représentants
For I=0 To dim([M:SOH1]REP)-1

  WREP = evalue("[M:SOH1]REP("+num$(I)+")")

  Assign ("[M:SOH4]REP"+num$(I+1)+"(nolign-1)") With WREP

  If WREP <> ""
        Read [F:REP]REP0 = WREP
        If fstat Raz [F:REP] : Endif
        Read [F:BPC]BPC0 = [M:SOH0]BPCORD
        If fstat Raz [F:BPC] : Endif
        If [F:BPC]COMCAT <> 0
            Assign ("[M:SOH4]REPRAT"+num$(I+1)+"(nolign-1)") With evalue("[F:REP]COMRAT"+num$(I+1)+"([F:BPC]COMCAT-1)")
        Endif
  Endif

Next
# type alloc
[M:SOH4]DALLTYP(nolign-1)= [M:SOH2]ALLTYP
# contact
[M:SOH4]CNDNAM(nolign-1) =[M:ADB2]CNTNAM

Return

##############################################################################
# alimentation avec le détail cmd achat                                      #
##############################################################################
$ALIPOHDET
# ref article
[M:SOH4]ITMREF(nolign-1)  =[M:POH2]ITMREF(NOLPOH-1)

# désignation
[M:SOH4]ITMDES(nolign-1)    =[M:POH2]ITMDES1(NOLPOH-1) : # Bug 60028
[M:SOH4]ITMDES1(nolign-1)   =[M:POH2]ITMDES(NOLPOH-1)  : # Bug 60028

# 105605 : CCM - Revision index (LD:03/06/15)
If dim([M:SOH4]ECCVALMAJ) > 0         : # Issue 116162
    [M:SOH4]ECCVALMAJ(nolign-1) =[M:POH2]ECCVALMAJ(NOLPOH-1)
    [M:SOH4]ECCVALMIN(nolign-1) =[M:POH2]ECCVALMIN(NOLPOH-1)
Endif                                 : # Issue 116162
# 105605 : CCM - Revision index (LD:03/06/15)

# unité de vente
[M:SOH4]SAU(nolign-1)       =[M:POH2]UOM(NOLPOH-1)

# unité de stock
[M:SOH4]STU(nolign-1)       =[M:POH2]STU(NOLPOH-1)

# qté cmdée en UV
[M:SOH4]QTY(nolign-1)       =[M:POH2]QTYUOM(NOLPOH-1)

# qté cmdée en US
[M:SOH4]QTYSTU(nolign-1)    =[M:POH2]QTYSTU(NOLPOH-1)

# calcul du coef de conversion UV-US
#Gosub CALSAUSTUCOE : # Modif MBT du 9/06/2004
If [M:POH2]QTYUOM(NOLPOH-1)=0  [M:POH2]QTYUOM(NOLPOH-1)=1 : Endif
[M:SOH4]SAUSTUCOE(nolign-1)=arr([M:POH2]QTYSTU(NOLPOH-1)/[M:POH2]QTYUOM(NOLPOH-1),10^-6)

# flag saisie coef
[M:SOH4]DACSAUCOE(nolign-1) =[M:POH2]COEFLG(NOLPOH-1)

# date de livraison demandée
[M:SOH4]DDEMDLVDAT(nolign-1)=[M:POH2]EXTRCPDAT(NOLPOH-1)

# site exp
[M:SOH4]DSTOFCY(nolign-1)   =[M:POH2]LINSTOFCY(NOLPOH-1)

# lieu conso
[M:SOH4]USEPLC(nolign-1)    =[M:POH2]USEPLC(NOLPOH-1)

# n° ligne
[M:SOH4]POPLIN(nolign-1)    =[M:POH2]POPLIN(NOLPOH-1)

# 95742 : PJT en inter société/inter site : (LD:20/04/16)
# Le PJT transite uniquement en intersite
If [M:SOH1]BETFCY=2 & [M:SOH1]BETCPY=1
    [M:SOH4]DPJT(nolign-1)=[M:POH2]PJT(NOLPOH-1)
Endif
# 95742 : PJT en inter société/inter site : (LD:20/04/16)

# type ligne : achats de sous-traitance
Case  [M:POH2]LINTYP(NOLPOH-1)
  When 2 : # Nomenclature composé
    [M:SOH4]LINTYP(nolign-1)=10   : # Sous-traité (composé)
  When 3 : # Service
    If [M:POH2]LIKQTYCOE(NOLPOH-1)<>0
        [M:SOH4]LINTYP(nolign-1)=11   : # Service (composant)
    Else
        [M:SOH4]LINTYP(nolign-1)=13   : # Service forfaitaire (composant)
    Endif
    [M:SOH4]OCNPRNBOM(nolign-1)=2 : # Il apparaît sur l'ARC client
    [M:SOH4]NDEPRNBOM(nolign-1)=2 : # Il apparaît sur le BL
    [M:SOH4]INVPRNBOM(nolign-1)=2 : # Il apparaît sur la Facture
  When 4 : # Matière fournie par le sous-traitant
    [M:SOH4]LINTYP(nolign-1)=12   : # Matière fournie par le sous-traitant (composant)
    [M:SOH4]STOMGTCOD(nolign-1)=1 : # Article non géré en stock (pas livrées physiquement mais facturées par le sous-traitant)
    [M:SOH4]OCNPRNBOM(nolign-1)=2 : # Elle apparaît sur l'ARC client
    [M:SOH4]NDEPRNBOM(nolign-1)=1 : # Elle n'apparaît pas sur le BL
    [M:SOH4]INVPRNBOM(nolign-1)=2 : # Elle apparaît sur la Facture
Endcase


[M:SOH4]INVPRNBOM(nolign-1) = 1

# méthode de livraison
#--CPO 84304 Méthode pour livraison pour le flux :
#--1 - Création commande de vente avec ligne de contremarque d'achat
#--2 - Génération de la commande d'achat de contremarque
#--3 - Création automatique de commande de vente intersociété
#--Cas de la ctm de production => le flux sera arrêté (donc on peut avoir "ordre de prod")
#If [M:POH2]SOHNUM(NOLPOH-1) <> ""
#    # Si la commande d'achat est issue d'une contremarque, l'article ne doit pas de nouveau être géré en contremarque
#    [M:SOH4]FMI(nolign-1)=1
#Else
#    Call ALIFMI([M:SOH4]ITMREF(nolign-1), [M:SOH4]DSTOFCY(nolign-1), WFMI) From TRTVENCDE
#    [M:SOH4]FMI(nolign-1)=WFMI
#    If [M:SOH4]FMI(nolign-1)=3 |[M:SOH4]FMI(nolign-1)=5 Gosub ALIFMI : Endif
#Endif
Call ALIFMI([M:SOH4]ITMREF(nolign-1), [M:SOH4]DSTOFCY(nolign-1), WFMI) From TRTVENCDE
[M:SOH4]FMI(nolign-1)=WFMI

# Issue 117004
# If FMI has been put to 2 by the entry point ALIFMI, STOMGTCOD has to be put to 1
If [M:SOH4]FMI(nolign-1)=2 [M]STOMGTCOD(nolign-1)=1 Endif
# End issue 117004

If [M:POH2]SOHNUM(NOLPOH-1) <> ""
    # Si la commande d'achat est issue d'une contremarque, l'article ne doit pas de nouveau être géré en contremarque
    Case [M:SOH4]FMI(nolign-1)
    When 1 :
    When 5  : [M:SOH4]DALLTYP(nolign-1) =2 :#--Fait dans ALIFMI que l'on n'appelle plus
    When Default : [M:SOH4]FMI(nolign-1)=1
    Endcase
Else
    # 106864 : Pb génération ctm directe au lieu de ctm de production (la ctm directe ne concerne que la ctm achat)
    #If [M:SOH4]FMI(nolign-1)=3 |[M:SOH4]FMI(nolign-1)=5 Gosub ALIFMI : Endif
    If [M:SOH4]FMI(nolign-1)=3 Gosub ALIFMI : Endif
    # 106864
Endif

Return

##############################################################################
# alim. des zones à partir du client livré
$ALIBPDDET

[M:SOH4]DBPAADD (nolign-1)=WDBPAADD

If [F:BPD]BPCNUM <> [M:SOH0]BPCORD | [F:BPD]BPAADD <> [M:SOH4]DBPAADD (nolign-1)
    Read [BPD]BPD0 = [M:SOH0]BPCORD;[M:SOH4]DBPAADD (nolign-1)
    If fstat : GERR=1 : LERRCOD=2 : Gosub TRT_ERR : GOK=0 : Return : Endif
Endif

#zones liées à l'adresse de livraison
Gosub ALIBPD

Return

##############################################################################
# alim. des zones à partir de l'article
$ALIARTDET
Local Char    VAT(GLONVAT)(3)
Local Char    WTSCCOD(GLONADI) (0..5)
Local Char    WTSICOD(GLONADI) (0..5)
Local Integer WI

# niveau de taxe
[M:SOH4]VACITM1(nolign-1)  = [F:ITM]VACITM(0)
[M:SOH4]VACITM2(nolign-1)  = [F:ITM]VACITM(1)
[M:SOH4]VACITM3(nolign-1)  = [F:ITM]VACITM(2)

# codes statistiques
If dim([M:SOH4]TSICOD1(nolign-1))>0: [M:SOH4]TSICOD1(nolign-1) = [F:ITM]TSICOD(0):Endif
If dim([M:SOH4]TSICOD2(nolign-1))>0: [M:SOH4]TSICOD2(nolign-1) = [F:ITM]TSICOD(1):Endif
If dim([M:SOH4]TSICOD3(nolign-1))>0: [M:SOH4]TSICOD3(nolign-1) = [F:ITM]TSICOD(2):Endif
If dim([M:SOH4]TSICOD4(nolign-1))>0: [M:SOH4]TSICOD4(nolign-1) = [F:ITM]TSICOD(3):Endif
If dim([M:SOH4]TSICOD5(nolign-1))>0: [M:SOH4]TSICOD5(nolign-1) = [F:ITM]TSICOD(4):Endif

# gestion stock
If [M:SOH4]STOMGTCOD(nolign-1)=0
    [M:SOH4]STOMGTCOD(nolign-1) = [F:ITM]STOMGTCOD
    If [F:ITM]STOMGTCOD>1
        If [F:ITF]ITMREF<>[M:SOH4]ITMREF(nolign-1) | [F:ITF]STOFCY<>[M:SOH4]DSTOFCY(nolign-1)
            Read [ITF] ITF0=[M:SOH4]ITMREF(nolign-1);[M:SOH4]DSTOFCY(nolign-1)
            If fstat Raz [F:ITF] : Endif
        Endif
        If [F:ITF]STOMGTCOD>0 [M:SOH4]STOMGTCOD(nolign-1) = [F:ITF]STOMGTCOD Endif
    Endif
Endif

# ref article client
Read [ITU]ITU0= [M:SOH4]ITMREF(nolign-1);[M:SOH0]BPCORD
If !fstat
    [M:SOH4]ITMREFBPC(nolign-1) = [F:ITU]ITMREFBPC
Endif
# codes taxes
#Call ALITAXEV([M:SOH1]VACBPR,[F:ITM]VACITM,VAT) From TRTX3
Call RECHVATCOD(1,1,[M:SOH0]BPCORD,[M:SOH4]ITMREF(nolign-1),"SOH4",nolign-1,VAT) From TRTX3
[M:SOH4]VAT1(nolign-1)  = VAT(0)
[M:SOH4]VAT2(nolign-1)  = VAT(1)
[M:SOH4]VAT3(nolign-1)  = VAT(2)

# Initialisation du code prépa
If dim([M:SOH0]TSCCOD) <> -1
    For WI = 1 To dim([M:SOH0]TSCCOD)
        WTSCCOD(WI-1) = [M:SOH0]TSCCOD(WI-1)
    #--CPO 90371 Lors de la correction de cette fiche - ici on fait For WI et Next I
    #Next I
    Next WI
    #--/
Endif
If dim([M:SOH4]TSICOD1)>0: WTSICOD(0) = [M:SOH4]TSICOD1(nolign-1): Endif
If dim([M:SOH4]TSICOD2)>0: WTSICOD(1) = [M:SOH4]TSICOD2(nolign-1): Endif
If dim([M:SOH4]TSICOD3)>0: WTSICOD(2) = [M:SOH4]TSICOD3(nolign-1): Endif
If dim([M:SOH4]TSICOD4)>0: WTSICOD(3) = [M:SOH4]TSICOD4(nolign-1): Endif
If dim([M:SOH4]TSICOD5)>0: WTSICOD(4) = [M:SOH4]TSICOD5(nolign-1): Endif
If [F:BPC]BPCNUM<>[M:SOH0]BPCORD
   Read [BPC]BPC0=[M:SOH0]BPCORD : If fstat Raz [F:BPC] Endif
Endif
Call REC_PRECOD([M:SOH4]DSTOFCY(nolign-1),[M:SOH4]ITMREF(nolign-1),[F:ITM]TCLCOD,WTSICOD(0),
&               WTSICOD(1),WTSICOD(2),WTSICOD(3),WTSICOD(4),[M:SOH0]BPCORD,
&               [F:BPC]BCGCOD,WTSCCOD(0),WTSCCOD(1),WTSCCOD(2),WTSCCOD(3),
&               WTSCCOD(4),[M:SOH4]PRECOD(nolign-1)) From STKLIB

# emballage, cap emballage
Gosub ALISAU

# 107890 : Scheduled invoices : (LD:22/03/16)
[M:SOH4]DLVFLG(nolign-1)=[F:ITM]DLVFLG
# 107890 : Scheduled invoices : (LD:22/03/16)

# 107890 : Scheduled invoices : (LD:03/06/16)
# Invoicing condition managed only for Normal order and
# For Service/Generic category and type of flow sales and not deliverable
If [M:SOH0]SOHCAT=1 & [F:ITM]DLVFLG=1
    [M:SOH4]DINVCND(nolign-1)=[M:SOH3]INVCND
    If [M:SOH4]DINVCND(nolign-1)=""
        [M:SOH4]DINVCND(nolign-1)=[F:ITS]INVCND
    Endif
Endif
# 107890 : Scheduled invoices : (LD:03/06/16)

# SAL_X3-79087_Sales_text_in_intersit (LCC-12/03/18)
## Issue X3-38629
#Raz [M:SOH4]SOQTEX(NLIG)
#If find(GSALTEXLIN,1,5)
#   [M:SOH4]SOQTEX(NLIG) = [F:ITU]ITSTEX
#   If [M:SOH4]SOQTEX(NLIG)=""
#      [M:SOH4]SOQTEX(NLIG) = [F:ITS]ITSTEX
#   Endif
#Endif
## End issue X3-38629
Raz [M:SOH4]SOQTEX(nolign-1)
If find(GSALTEXLIN,1,5)
   [M:SOH4]SOQTEX(nolign-1) = [F:ITU]ITSTEX
   If [M:SOH4]SOQTEX(nolign-1)=""
      [M:SOH4]SOQTEX(nolign-1) = [F:ITS]ITSTEX
   Endif
Endif
# End SAL_X3-79087_Sales_text_in_intersit (LCC-12/03/18)
Return

##############################################################################
# alim. diverses
$ALIDIVDET
Local Char    SECTION, WTEMP(GLONDES)
Local Integer TYPRECH, WTRFPRI, STAT      : # 26113  : Inter-site : Price recalculation (LD:22/06/15)
Local Integer WRECH_TAR   :#--CPO 81500
# recherche prix
NLIG = nolign-1
TYPRECH =1

# 26113  : Inter-site : Price recalculation (LD:22/06/15)
##--CPO 81500 PE Permettant de recalculer les prix/remises ou forcer la recherche d'un tarif
##-- Si on ne veut forcer la de recherche tarif         => mettre WRECH_TAR à 2
##-- Si on modifie le prix brut et/ou les frais/remises => mettre WRECH_TAR à 3
#WRECH_TAR=2
#GPOINT ="BETCPYSETPRI" : Gosub ENTREE From EXEFNC
#If WRECH_TAR<2 : WRECH_TAR=2 : Endif :#--En création on recherche le tarif (sauf si positionné à 3)
##--/CPO
# 26113  : Inter-site : Price recalculation (LD:22/06/15)

Call ALICLCAMT([M:SOH4]ITMREF(NLIG), [M:SOH4]QTY(NLIG), NLIG,"SOH4",[M:SOH4]CLCAMT1(NLIG),[M:SOH4]CLCAMT2(NLIG) ) From TRTX3

# 26113  : Inter-site : Price recalculation (LD:22/06/15)
Gosub C_PRIX_INTER_SOC_SITE
##--CPO 81500 PE
##Call RECH_TARIF(TYPRECH,[M:SOH4]ITMREF(NLIG),NLIG ,[M:SOH4]QTY(NLIG),"SOH",[M:SOH4]GROPRI(NLIG)) From TRTVENTAR
#If WRECH_TAR<>3
#  Call RECH_TARIF(TYPRECH,[M:SOH4]ITMREF(NLIG),NLIG ,[M:SOH4]QTY(NLIG),"SOH",[M:SOH4]GROPRI(NLIG)) From TRTVENTAR
#Endif
##--/CPO
#Call CLCNETPRI([M:SOH4]QTY(NLIG), [M:SOH0]CUR, NLIG ) From TRTVENPRI
# 26113  : Inter-site : Price recalculation (LD:22/06/15)

Call CLCPFM([M:SOH4]DSTOFCY(NLIG) , [M:SOH1]PRITYP, [M:SOH0]CHGTYP, [M:SOH0]ORDDAT, [M:SOH0]CUR, NLIG, 2) From TRTVENPRI
nolign= NLIG+1

# contrôle date  de livraison demandée
If [M:SOH4]DDEMDLVDAT(nolign-1) <[M:SOH0]ORDDAT
    GERR=2 : LERRCOD=31 : Gosub TRT_ERR : Raz GERR
    [M:SOH4]DDEMDLVDAT(nolign-1)=[M:SOH0]ORDDAT
Endif

# calcul des dates
Gosub CALDATDET

# sections analytiques
#----- Lecture ligne commande achat si elle a été paramétrée dans "SOP" -----#
If [M:POH0]POHNUM<>"" & [M:POH2]POPLIN(NOLPOH-1)<>0
    If [F:POP]POHNUM<>[M:POH0]POHNUM |
&      [F:POP]POPLIN<>[M:POH2]POPLIN(NOLPOH-1) |
&      [F:POP]POPSEQ<>1
      Read [POP] POP0=[M:POH0]POHNUM;[M:POH2]POPLIN(NOLPOH-1);1
      If fstat  Raz [F:POP] : Endif
    Endif
Endif
For I = 1 To GNBDIE
    If evalue("dim([M:SOH4]CCE"+num$(I)+"(nolign-1))") >0
        Raz GMESSAGE : mkstat=0
        Call INISEC(SECTION, "SOP", I) From TRTX3CPT
#        Call AAACTLCCEX(SECTION, num$(I),3,GFINRSP,[M:SOH4]EXTDLVDAT(nolign-1)) From CONTX3
        Call CTRL_CCE(SECTION,I,"",GFINRSP,[M:SOH4]EXTDLVDAT(nolign-1)) From TRTX3CPT
        #If mkstat LERRCOD=28 : GERR=2 : Raz mkstat : Gosub TRT_ERR : Endif : # Bug 81249
        If mkstat LERRCOD=28 : GERR=2 : Raz mkstat : Gosub TRT_ERR : Raz GERR : Endif : # Bug 81249
        Assign "[M:SOH4]CCE"+num$(I)+"(nolign-1)" With SECTION
    Endif
Next

# désignation traduite
#Call CHARGE_ITMDES("DES1AXX",[M:SOH0]LAN,[F:ITM]ITMREF,WTEMP) From TRTX3
# Bug 60028
#Call CHARGE_DEFITMDES("DES1AXX",[M:SOH0]LAN,[F:ITM]ITMREF,WTEMP, "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
#[M:SOH4]ITMDES(nolign-1)=WTEMP
#If [M:SOH4]ITMDES(nolign-1)= "" [M:SOH4]ITMDES(nolign-1)=[M:SOH4]ITMDES1(nolign-1) Endif

# initialisation des flags
[M:SOH4]DEMSTA(nolign-1) = 1
[M:SOH4]SOQSTA(nolign-1) = 1
[M:SOH4]INVFLG(nolign-1) = 1
# Ajout GA 12/2006 : à valider
If [M:SOH4]LINTYP(nolign-1)=0    [M:SOH4]LINTYP(nolign-1)=1 Endif
[M:SOH4]FOCFLG(nolign-1) = 1
[M:SOH4]ORILIN(nolign-1) = 1
[M:SOH4]UPDFLG(nolign-1) = 1
[M:SOH4]CREFLG(nolign-1) = 0

If [M:SOH4]OCNPRNBOM(nolign-1)=0 [M:SOH4]OCNPRNBOM(nolign-1)=1 Endif
If [M:SOH4]NDEPRNBOM(nolign-1)=0 [M:SOH4]NDEPRNBOM(nolign-1)=1 Endif
If [M:SOH4]INVPRNBOM(nolign-1)=0 [M:SOH4]INVPRNBOM(nolign-1)=1 Endif

# Init de la qté à allouer selon paramètre
#If GINIALLORD=2 & ((GSOHAPPORD=2 & GSOHAPPALL=2) | [M:SOH1]APPFLG>2)               : # Bug 80955
If GINIALLORD=2 & (GAPPSOH=1 | ((GSOHAPPORD=2 & GSOHAPPALL=2) | [M:SOH1]APPFLG>2))  : # Bug 80955
    NLIG = nolign-1 : Gosub INIT_WALLQTYSTU
Endif

# calcul des montants HT et TTC de la ligne
Gosub CALC_ORD From SUBSOHB
Gosub CALC_DSP From TRTVENDIV
# calcul des montants à liv. HT et TTC de la ligne
Gosub CALC_DLR From SUBSOHB

NLIG = nolign-1
# calcul des montants HT et TTC de la commande
Call ADD_TOT(NLIG ) From SUBSOHB
nolign= NLIG+1

Return

##############################################################################
# MAJ de [POH] à partir de [SOH]
##############################################################################
$MAJPOH
Local Integer I,J

If LMAJCOD="A"                                                        # : HN
  Raz [M:POH3]OCNNUM                                                  # : HN
  Raz [M:POH3]OCNDAT
  Raz [M:POH3]OCNREM                                                  # : HN
  For I=0 To [M:POH2]NBLIG-1                                          # : HN
    Raz [M:POH2]LINOCNNUM(I), [M:POH2]LINOCNDAT(I), [M:POH2]OCNLIN(I) # : HN
  Next                                                                # : HN
Else                                                                  # : HN
  [M:POH3]OCNNUM = [M:SOH0]SOHNUM
  [M:POH3]OCNDAT = [M:SOH0]ORDDAT
  [M:POH3]OCNREM = mess(74,187,1)
  For I=0 To [M:SOH4]NBLIG-1
    J= find([M:SOH4]POPLIN(I),[M:POH2]POPLIN(0..[M:POH2]NBLIG))
    If J
      [M:POH2]LINOCNNUM(J-1)=[M:SOH0]SOHNUM
      [M:POH2]LINOCNDAT(J-1)=[M:SOH0]ORDDAT
      [M:POH2]OCNLIN(J-1)=[M:SOH4]SOPLIN(I)
    Endif
  Next
Endif                                                                 : # HN
Return

##############################################################################
$SOH_MODIF
    #-----
    If GTRACE<>""
      WMESS=mess(3,85,1)-mess(2,701,1)-num$([M:POH3]OCNNUM)-"   "-mess(99,197,1)-[M:POH0]BPCORD
      Call ECR_TRACE(WMESS,0) From GESECRAN
    Endif
    #-----
    Gosub  CHARGESOH
    If GOK <= 0 Return : Endif
    Gosub  MAJSOH
    If GOK <= 0 Return : Endif

    OK =1
    ACTION ="VERIF_MOD"
    Gosub ACTION From  GOBJSUB
    If !OK : GOK = 0 : Return : Endif

    Default File [F:SOH]
    Readlock [SOH]SOH0= [M:SOH0]SOHNUM
    If fstat=1 :  GOK = -1: GLOCK="$SORDER"+[M:SOH0]SOHNUM : Return
    Elsif fstat :  GOK = 0 : Call RSTA("SOH", [M:SOH0]SOHNUM) From GLOCK  : Return : Endif

    nolign  =  1
    ACTION ="AVANT_MODFIC"
    Gosub ACTION From  GOBJSUB
    If GOK<=0 : Return : Endif
    #----- Mise à jour du suivi workflow signature -----#
    # -- Déf des variables workflow
    Call WRKGLOB(171,[F:SOH]SOHNUM,"SORDER","") From GOBJACT
    #-------------------------------------------------------------------------------------#
    # Subprog WORKPLUS(TYPEVT,CODEVT,OPERAT,CLEOBJ,CODE,SIMUL,DIFFERE,TYPDEC,GRPDEB)      #
    # TYPEVT  : Type d'évènement Workflow (objet/import/etc.)                             #
    # CODEVT  : Code évènement                                                            #
    # OPERAT  : Opération (Modification/Bouton/etc.)                                      #
    # CLEOBJ  : Clé de l'objet si typevt=objet ou chrono origine/dest si typevt=signature #
    # CODE    : Code workflow (cas du bouton W et du workflow manuel)                     #
    # SIMUL   : Permet de simuler OU de générer un workflow manuel                        #
    # DIFFERE : Envoi message différé (transactions de création/modification d'un objet)  #
    # TYPDEC  : Déclenchement workflow avant/après mise à jour classe [F] (modif objet)   #
    # GRPDEB  : Premier chrono groupe (utilisé pour l'envoi différé)                      #
    #-------------------------------------------------------------------------------------#
    Call WORKPLUS(2,"SOH","M",[F:SOH]SOHNUM,"",0,1,1,GRPDEB) From AWRK
    If GOK<=0 : Return : Endif

    [F:SOH] = [M:SOH0]
    [F:SOH] = [M:SOH1]
    [F:SOH] = [M:SOH2]
    [F:SOH] = [M:SOH3]
    [F:SOH] = [M:SOH4]

    #-- X3Suivi 80221: le No chrono [F:SOH]EXPNUM n'était pas Maj si modification de commmande achat intersite --#
    Gosub INIMOD From GOBJSUB

    ACTION ="INIMOD"
    Gosub ACTION From  GOBJSUB
    If GOK<=0 : Return : Endif
    Rewrite [F:SOH]
    If fstat
      GOK=0 : Call FSTA("SOH") From GLOCK : Return
    Endif

    ACTION ="MODIF"
    Gosub ACTION From  GOBJSUB
    If GOK<=0 : Return : Endif

    Call WORKPLUS(2,"SOH","M",[F:SOH]SOHNUM,"",0,1,2,GRPDEB) From AWRK
    If GOK<=0 : Return : Endif
    #----- Envoi des messages groupe workflow signature -----#
    If GRPDEB<>""  Call ENVOI_GROUPE(GRPDEB) From AWRK : GRPDEB="" : Endif

    Gosub MAJPOH
    Unlock = SYMBOLE
    #-----
    If GTRACE<>""
      WMESS=mess(10,159,1)-mess(223,197,1) : # Commande modifiée !
      Call ECR_TRACE(WMESS,0) From GESECRAN
    Endif
    #-----
Return
##############################################################################
# chargement de la cmd de vente avec les masques
$CHARGESOH
Local Char SZUSRLOCK(50)  # FGR 19/11/2009 : X3SUIVI57762
Local Char SZMACLOCK(50)  # FGR 19/11/2009 : X3SUIVI57762

    Raz SZUSRLOCK  # FGR 19/11/2009 : X3SUIVI57762
    Raz SZMACLOCK  # FGR 19/11/2009 : X3SUIVI57762
    # lecture de la cmd de vente
    Default File [F:SOH]
    Read [SOH]SOH0= [M:POH3]OCNNUM
    If fstat : GERR=1:  LERRCOD=7 : Gosub TRT_ERR : GOK=0 : Return : Endif

$CHARGE
    # chargement de masques
    Raz [M:SOH0], [M:SOH1], [M:SOH2], [M:SOH3], [M:SOH4]
    nolign=1
    [M:SOH0]= [F:SOH]
    [M:SOH1]= [F:SOH]
    [M:SOH2]= [F:SOH]
    [M:SOH3]= [F:SOH]
    [M:SOH4]= [F:SOH]

    MODI=1  : SUPPR=1
    VERROU=0
    If MODI|SUPPR
        $VERROU
            SYMBOLE="SOH"+[F:SOH]SOHNUM
            OK=1
            Lock =SYMBOLE With lockwait=0
            #If fstat : OK=0 : Endif   # FGR 19/11/2009 : X3SUIVI57762
            If fstat Then
              # FGR 19/11/2009 : X3SUIVI57762
              OK=0
              #Call QUILOCKE(SYMBOLE, SZMACHINE, SZUSER) From OBJDIV
              Call QUILOCKE(SYMBOLE, SZMACLOCK, SZUSRLOCK) From OBJDIV   # FGR 11/01/2011 : X3SUIVI70620
            Endif
            If OK VERROU=1 Endif
    Endif
    If VERROU=0 : GERR=1:  LERRCOD=33 : Gosub TRT_ERR : GOK=0 : Return : Endif
    Gosub LIENS_SOH From SUBSOHA
    Gosub MAJSTASOH From SUBSOHB
Return
##############################################################################
# MAJ des masques [M:SOH]
$MAJSOH

# MAJ avec l'entête cmd d'achat
Case LORICOD
    When 1 : Gosub MAJPOHSOH

Endcase

Return
##############################################################################
# MAJ des masques [M:SOH] avec [M:POH]
##############################################################################
$MAJPOHSOH
Local Integer I, J, K, WNBLIG

GREV=1: If GSALREV=2: GREV=2 : [M:SOH0]REVNUM+=1 : Endif

# MAJ de l'entête de la cmd de vente
Gosub MAJPOHENT
If GOK <= 0 Return : Endif

# MAJ des lignes de la cmd de vente
# Traitement des lignes à supprimer
K=0
WNBLIG=[M:SOH4]NBLIG
For I=0 To WNBLIG-1
    J=find([M:SOH4]POPLIN(K),[M:POH2]POPLIN(0..[M:POH2]NBLIG))
    If J=0
       Gosub ANNDET
    Else
        If [M:POH2]CREFLG(J-1)= 0  : Gosub ANNDET
        Else K+=1
        Endif
    Endif
Next

#--------------------------------------------------------------#
# Traitement des lignes à créer et à modifier
# nolign est l'indice utilisé pour parcourir le tableau [M:SOH4]
# NOLPOH est l'indice utilisé pour parcourir le tableau [M:POH2]
#--------------------------------------------------------------#
WNBLIG= [M:POH2]NBLIG
nolign=1
For NOLPOH=1 To WNBLIG
    Raz GERR : Raz GMESSAGE : Raz mkstat
    If [M:POH2]CREFLG(NOLPOH-1)= 0
        Gosub CREDET        # création
        If GOK <= 0 Break : Endif
        If GERR=0 : nolign+=1 : Endif
    Elsif [M:POH2]UPDFLG(NOLPOH-1)<>0
        If  [M:POH2]LINCLEFLG(NOLPOH-1)=1 & [M:SOH4]SOQSTA(nolign-1)<>1
            # la ligne a été désoldée
             Gosub CLEDET    # désolde
             Gosub MODDET    # modification possible après désolde
             If GOK <= 0 Break : Endif
        Elsif [M:POH2]LINCLEFLG(NOLPOH-1)=2 & [M:SOH4]SOQSTA(nolign-1)<>3
            # la ligne a été soldée
             Gosub MODDET    # modification possible avant solde
             If GOK <= 0 Break : Endif
             Gosub CLEDET    # solde
        Else
             Gosub MODDET         #  ligne modifiée
             If GOK <= 0 Break : Endif
        Endif
        nolign+=1
    Else
        nolign+=1
    Endif
    If GOK<=0 : Break : Endif
Next
If GOK <= 0 Return : Endif

# point d'entrée pour alimenter des champs spécifiques des écrans commande
GPOINT ="ALIMSKSOH" : Gosub ENTREE From EXEFNC


Return
##############################################################################
# mise à jour à partir de l'entête commande d'achat
$MAJPOHENT
Local Char    WBPCINV(GLONBPC)

# client facture
WBPCINV=[M:SOH1]BPCINV
Read [BPR]BPR2(2)=2;[M:POH1]INVFCY
[G:BPR]currind=1 :[G:BPR]currlen=0
If !fstat
    [M:SOH1]BPCINV =  [F:BPR]BPRNUM
Else
    GERR=1 : LERRCOD=34 : Gosub TRT_ERR : GOK=0 : Return
Endif

# calcul de l'état crédit
If WBPCINV<>[M:SOH1]BPCINV
    Call SDCDTSTA([M:SOH0]CUSORDREF,[M:SOH0]BPCORD,[M:SOH0]CHGTYP,0,[M:SOH0]CUR,[M:SOH0]ORDDAT,[M:SOH2]UNL,1,[M:SOH1]CDTSTA,
&                [M:SOH0]OST,[M:SOH0]OSTAUZ) From TRTVENCDT
Endif

# client payeur
If [M:SOH1]BPCPYR<>[M:SOH1]BPCINV GUPDAPPFLG=2 Endif
[M:SOH1]BPCPYR = [M:SOH1]BPCINV

# site expédition
[M:SOH2]STOFCY =[M:POH1]STOFCY

# Bug 79827 : Informations douanières initialisées à partir de la commande d'achat
[M:SOH0]EECICT=[M:POH1]EECICT2
If dim([M:SOH2]EECICT)>0 [M:SOH2]EECICT=[M:POH1]EECICT2 Endif
[M:SOH0]ICTCTY=[M:POH1]ICTCTY2
If dim([M:SOH2]ICTCTY)>0 [M:SOH2]ICTCTY=[M:POH1]ICTCTY2 Endif
[M:SOH0]FFWNUM=[M:PCEV]FFWNUM
[M:SOH0]FFWADD=[M:PCEV]FFWADD
# Bug 79827

# 95742 : PJT en inter société/inter site : (LD:20/04/16)
# Le PJT transite uniquement en intersite
If [M:SOH1]BETFCY=2 & [M:SOH1]BETCPY=1
    [M:SOH1]PJT=[M:POH1]PJTH
Endif
# 95742 : PJT en inter société/inter site : (LD:20/04/16)

Return


##############################################################################
# suppression d'une ligne de cmd
$ANNDET
Local Integer WRET

# 107890 : Scheduled invoices : (LD:03/06/16)
GMODIF=1
NOL=K
Gosub MAJ_INVCND_SOH
If GOK <= 0 Return : Endif
If GERR = 1 Return : Endif
# 107890 : Scheduled invoices : (LD:03/06/16)

GUPDAPPFLG=2
Call SUP_LIG (K, WRET) From SUBSOHB
Return

##############################################################################
# ajout d'une ligne de cmd
$CREDET

Gosub CTLALIDET
If GOK <= 0 Return : Endif
If GERR = 1 Return : Endif
# --> Vérif. si l'insertion possible
If [M]NBLIG + 1 >= dim([M]ITMREF) - 1
    GERR=1 : LERRCOD=8 : Gosub TRT_ERR : GOK=0: Return
Endif

# insertion
If dim([M:SOH4]ITMREF)=[M:SOH4]NBLIG-1
    Insa nolign-1,1[M:SOH4]NBLIG
Else
    Insa nolign-1,1,[M:SOH4]NBLIG [M:SOH4]NBLIG
Endif
[M:SOH4]NBLIG+=1
status=0

Call LINNUM("SOPLIN")From TABLEAUX
Gosub ALIDET
If GERR = 1 Return : Endif
If GOK <= 0 Return : Endif
GUPDAPPFLG=2

# 107890 : Scheduled invoices : (LD:03/06/16)
GMODIF=2
NOL=nolign-1
Gosub MAJ_INVCND_SOH
If GERR = 1 Return : Endif
If GOK <= 0 Return : Endif
# 107890 : Scheduled invoices : (LD:03/06/16)

Return
##############################################################################
# solde/desolde d'une ligne de cmd
$CLEDET

If [M:POH2]LINCLEFLG(NOLPOH-1)=1
    If [M:SOH4]SOQSTA(nolign-1)=3
        NLIG =nolign-1
        Gosub TRT_CLESOQ From SUBSOHB
        nolign =NLIG+1
    Endif
Else
    If [M:SOH4]SOQSTA(nolign-1)=1
        NLIG =nolign-1
        Gosub TRT_CLESOQ From SUBSOHB
        nolign =NLIG+1
    Endif
Endif

Return
##############################################################################
# modification d'une ligne de cmd
$MODDET
    Call LECT_FIC(nolign-1) From SUBSOHB
    Call SUB_TOT(nolign-1) From SUBSOHB
    Case LORICOD
        When 1: Gosub MAJPOHDET
                If GOK <= 0 Return : Endif
    Endcase

#recalcul état détail cde
Gosub CALC_SOQSTA From SUBSOHB
# calcul des montants HT et TTC de la ligne
Gosub CALC_ORD From SUBSOHB
Gosub CALC_DSP From TRTVENDIV
# calcul des montants à liv. HT et TTC de la ligne
Gosub CALC_DLR From SUBSOHB

NLIG = nolign-1
# calcul des montants HT et TTC de la commande
Call ADD_TOT(NLIG ) From SUBSOHB

# 107890 : Scheduled invoices : (LD:03/06/16)
GMODIF=0
NOL=nolign-1
Gosub MAJ_INVCND_SOH
If GERR = 1 Return : Endif
If GOK <= 0 Return : Endif
# 107890 : Scheduled invoices : (LD:03/06/16)

nolign= NLIG+1

[M:SOH4]UPDFLG(nolign-1)=1
If GREV=2: [M:SOH4]LINREVNUM(nolign-1)= [M:SOH0]REVNUM : Endif

# point d'entrée pour alimenter des champs spécifiques de l'écran détail commande
GPOINT ="ALIMSKSOH4" : Gosub ENTREE From EXEFNC

Return

# 107890 : Scheduled invoices : (LD:03/06/16)
##############################################################################
# Modification of the order  :
# Modification of the Scheduled invoices when a line is deleted, created, closed
##############################################################################
$MAJ_INVCND_SOH

# This is done in AVANT_NBLIG from SUBSOH
#--In order the keep the association nolign-1 and GSOHVCRINVCND_UPD(nolign-1)
#--We are going to do an Insa/Dela instruction on GSOHVCRINVCND_UPD(..)
If GMODIF=1
  Gosub AVANT_NBLIG_DINVCND_DEL From LIBSAL_INVCND_SOH
Elsif GMODIF=2 #CPO 18/01/2016
  Gosub AVANT_NBLIG_DINVCND_INS From LIBSAL_INVCND_SOH
Endif

# This is done in APRES_NBLIG : P1_NBLIG from SUBSOH
#--The user create/modify the order                 => the $CREATION/$MODIF will instantiate
#--Or the user wants to modify the invoice schedule => it's the TRTSAISVIC that will instantiate
Case GMODIF
    When 0 : #--0 = Modification ligne
             Gosub P1_NBLIG_DINVCND_UPD From LIBSAL_INVCND_SOH
             If mkstat>0 or GERR>0 : mkstat=2 : Return : Endif
    When 1 : #--1 = Suppression ligne
             #--Done in AV_NBLIG
    When 2 : #--2 = Nouvelle ligne
             Gosub P1_NBLIG_DINVCND_INS From LIBSAL_INVCND_SOH
             If mkstat>0 or GERR>0 : mkstat=2 : Return : Endif
Endcase

Return
# 107890 : Scheduled invoices : (LD:03/06/16)

##############################################################################
$MAJPOHDET
Local    Decimal   WUNTCLCAMT1, WUNTCLCAMT2 : Raz WUNTCLCAMT1, WUNTCLCAMT2
Local    Decimal   WSAUSTUCOE : Raz WSAUSTUCOE
Local    Integer   WCLCPFM : WCLCPFM=0
Local    Integer   WCHG : WCHG = 0
Local    Char      WBPAADD(GLONBPD)
Local    Decimal   WSNETPRI, WSNETPRINOT, WSNETPRIATI : # Bug 70861
Local    Integer   WRECH_TAR, TYPRECH                 : # Bug 80955

Local    Integer   WTRFPRI, STAT                      : # 26113  : Inter-site : Price recalculation (LD:22/06/15)

# 107890 : Scheduled invoices : (LD:07/06/16)
# Use to mark fields modification that causes Schedules invoices modification
Local    Integer   WINVCND_CHG
Raz WINVCND_CHG
# 107890 : Scheduled invoices : (LD:07/06/16)

# 26113  : Inter-site : Price recalculation (LD:22/06/15)
# recherche prix
NLIG = nolign-1
TYPRECH =1
# 26113  : Inter-site : Price recalculation (LD:22/06/15)

# désignation
[M:SOH4]ITMDES1(nolign-1)  = [M:POH2]ITMDES1(NOLPOH-1)

# 105605 : CCM - Revision index (LD:03/06/15)
If dim([M:SOH4]ECCVALMAJ) > 0         : # Issue 116162
    [M:SOH4]ECCVALMAJ(nolign-1) =[M:POH2]ECCVALMAJ(NOLPOH-1)
    [M:SOH4]ECCVALMIN(nolign-1) =[M:POH2]ECCVALMIN(NOLPOH-1)
Endif                                 : # Issue 116162
# 105605 : CCM - Revision index (LD:03/06/15)

# 95742 : PJT en inter société/inter site : (LD:20/04/16)
# Le PJT transite uniquement en intersite
If [M:SOH1]BETFCY=2 & [M:SOH1]BETCPY=1
    [M:SOH4]DPJT(nolign-1)=[M:POH2]PJT(NOLPOH-1)
Endif
# 95742 : PJT en inter société/inter site : (LD:20/04/16)

# adresse de livraison
WBPAADD = [M:SOH4]DBPAADD(nolign-1)
Gosub RECBPD
If WDBPAADD<>""
    [M:SOH4]DBPAADD (nolign-1)=WDBPAADD
Else
    GERR=1 :LERRCOD=2 : Gosub TRT_ERR : Return
Endif
If  [M:SOH4]DBPAADD(nolign-1)<>WBPAADD
    If [F:BPD]DAYLTI<>[M:SOH4]DDAYLTI(nolign-1) WCHG =1 : [M:SOH4]WUPDAPPFLG(nolign-1)=2 : Endif
    Gosub ALIBPD
    If WCHG = 1 Gosub CALDATDET : Endif
Endif

WRECH_TAR=1       : # Bug 80955 : Recalcul tarif si l'unité de vente a été modifiée
# unité de vente
If [M:SOH4]SAU(nolign-1) <>[M:POH2]UOM(NOLPOH-1)
    [M:SOH4]SAU(nolign-1)     =[M:POH2]UOM(NOLPOH-1)
    Read [ITU]ITU0= [M:SOH4]ITMREF(nolign-1);[M:SOH0]BPCORD
    Gosub ALISAU
    # 26113  : Inter-site : Price recalculation (LD:22/06/15)
    # L'unité de vente a été modifiée : Recherche tarif ou transfert des prix
    WRECH_TAR = 2 : # Bug 80955 : Recalcul tarif si l'unité de vente a été modifiée
    # 107890 : Scheduled invoices : (LD:07/06/16)
    WINVCND_CHG=1
    # 107890 : Scheduled invoices : (LD:07/06/16)
Endif

# Bug 80955 : Recalcul tarif si l'unité de vente a été modifiée
# Le coefficient de conversion doit être remis à jour avant la recherche tarif
#coef de conversion UV-US
WSAUSTUCOE = [M:SOH4]SAUSTUCOE(nolign-1)
#Gosub CALSAUSTUCOE    :    Modif MBT du 9/06/2004
[M:SOH4]SAUSTUCOE(nolign-1)=arr([M:POH2]QTYSTU(NOLPOH-1)/[M:POH2]QTYUOM(NOLPOH-1),10^-6)
If WSAUSTUCOE <>[M:SOH4]SAUSTUCOE(nolign-1) : [M:SOH4]WUPDAPPFLG(nolign-1)=2 : WCLCPFM=1 : Endif
# Bug 80955

# 26113  : Inter-site : Price recalculation (LD:22/06/15)
##--CPO 81500 PE Permettant de recalculer les prix/remises ou forcer la recherche d'un tarif
##-- Appelé içi car si l'UV a été modifiée il faut bien tenir compte de cette dernière
##-- ainsi que du coef de conversion UV-US
##-- Si on ne veut pas de recherche tarif               => mettre WRECH_TAR à 1
##-- Si on ne veut forcer la de recherche tarif         => mettre WRECH_TAR à 2
##-- Si on modifie le prix brut et/ou les frais/remises => mettre WRECH_TAR à 3
#GPOINT ="BETCPYSETPRI" : Gosub ENTREE From EXEFNC
##--/CPO
# 26113  : Inter-site : Price recalculation (LD:22/06/15)

# qté cmdée en UV
If [M:SOH4]QTY(nolign-1) <> [M:POH2]QTYUOM(NOLPOH-1)
    If [M:SOH4]QTY(nolign-1) <> 0
        WUNTCLCAMT1=[M:SOH4]CLCAMT1(nolign-1)/[M:SOH4]QTY(nolign-1)
        WUNTCLCAMT2=[M:SOH4]CLCAMT2(nolign-1)/[M:SOH4]QTY(nolign-1)
    Endif
    [M:SOH4]QTY(nolign-1)     =[M:POH2]QTYUOM(NOLPOH-1)
    [M:SOH4]WUPDAPPFLG(nolign-1)=2
    If find([M:SOH4]FMI(nolign-1), 2, 3) [M:SOH4]FMI(nolign-1)=3 : Gosub ALIFMI : Endif
    NLIG = nolign-1

    # 107890 : Scheduled invoices : (LD:07/06/16)
    WINVCND_CHG=1
    # 107890 : Scheduled invoices : (LD:07/06/16)

    # 26113  : Inter-site : Price recalculation (LD:22/06/15)
    # La quantité a été modifiée : Recherche tarif ou transfert des prix
    WRECH_TAR=2 : # La quantité a été modifiée : Recherche tarif ou transfert des prix

#    # Bug 80955 : Recalcul tarif si l'unité de vente a été modifiée
#    If WRECH_TAR=2
#      TYPRECH =1
#      Call RECH_TARIF(TYPRECH,[M:SOH4]ITMREF(NLIG),NLIG ,[M:SOH4]QTY(NLIG),"SOH",[M:SOH4]GROPRI(NLIG)) From TRTVENTAR
#    Endif
#    # Bug 80955
#
    Call ALICLCAMT([M:SOH4]ITMREF(NLIG), [M:SOH4]QTY(NLIG), NLIG,"SOH4",[M:SOH4]CLCAMT1(NLIG),[M:SOH4]CLCAMT2(NLIG) ) From TRTX3
    # Bug 70861 : Recalcul prix net car impact des frais/remise par ligne sur le prix net
#    WSNETPRI=[M:SOH4]NETPRI(NLIG) : WSNETPRINOT=[M:SOH4]NETPRINOT(NLIG) : WSNETPRIATI=[M:SOH4]NETPRIATI(NLIG)
#    # --> Calcul du prix net
#    Call CLCNETPRI([M:SOH4]QTY(NLIG), [M:SOH0]CUR, NLIG) From TRTVENPRI
#    # Bug 70861
#
#    # Bug 80955
#    #If  WUNTCLCAMT1<>[M:SOH4]CLCAMT1(NLIG)|  WUNTCLCAMT2<>[M:SOH4]CLCAMT2(NLIG)
#    #--CPO 81500 PE ajout cas WRECH_TAR=3
#    #If  WRECH_TAR=2 | WUNTCLCAMT1<>[M:SOH4]CLCAMT1(NLIG)|  WUNTCLCAMT2<>[M:SOH4]CLCAMT2(NLIG)
#    If  find(WRECH_TAR,2,3)>0 | WUNTCLCAMT1<>[M:SOH4]CLCAMT1(NLIG)|  WUNTCLCAMT2<>[M:SOH4]CLCAMT2(NLIG)
#    # Bug 80955
    If  WUNTCLCAMT1<>[M:SOH4]CLCAMT1(NLIG)|  WUNTCLCAMT2<>[M:SOH4]CLCAMT2(NLIG)
        WCLCPFM=1
    Endif
#    nolign=NLIG+1
    # 26113  : Inter-site : Price recalculation (LD:22/06/15)

# 26113  : Inter-site : Price recalculation (LD:22/06/15)
## Bug 80955 : Recalcul tarif si l'unité de vente a été modifiée
##--CPO 81500 PE
##Elsif WRECH_TAR=2
#Elsif find(WRECH_TAR,2,3)>0
#    NLIG = nolign-1
#    If WRECH_TAR=2 :#--CPO 81500
#      TYPRECH =1
#      Call RECH_TARIF(TYPRECH,[M:SOH4]ITMREF(NLIG),NLIG ,[M:SOH4]QTY(NLIG),"SOH",[M:SOH4]GROPRI(NLIG)) From TRTVENTAR
#    Endif
#    Call CLCNETPRI([M:SOH4]QTY(NLIG), [M:SOH0]CUR, NLIG ) From TRTVENPRI
#    WCLCPFM=1
#    nolign= NLIG+1
## Bug 80955
# 26113  : Inter-site : Price recalculation (LD:22/06/15)
Endif

# Bug 67893
# qté cmdée en UV
If [M:SOH4]QTYSTU(nolign-1) <> [M:POH2]QTYSTU(NOLPOH-1) & GINIALLORD=2 & ((GSOHAPPORD=2 & GSOHAPPALL=2) | [M:SOH1]APPFLG>2)
    # Si la qté cdée a évoluée, Init de la qté à allouer
    [M:SOH4]QTYSTU(nolign-1)  =[M:POH2]QTYSTU(NOLPOH-1)
    NLIG = nolign-1 : Gosub INIT_WALLQTYSTU
Endif
# Bug 67893

# qté cmdée en US
[M:SOH4]QTYSTU(nolign-1)  =[M:POH2]QTYSTU(NOLPOH-1)

# Bug 80955 : Recalcul tarif si l'unité de vente a été modifiée
# Le coefficient de conversion doit être remis à jour avant la recherche tarif
##coef de conversion UV-US
#WSAUSTUCOE = [M:SOH4]SAUSTUCOE(nolign-1)
##Gosub CALSAUSTUCOE    :    Modif MBT du 9/06/2004
#[M:SOH4]SAUSTUCOE(nolign-1)=arr([M:POH2]QTYSTU(NOLPOH-1)/[M:POH2]QTYUOM(NOLPOH-1),10^-6)
#If WSAUSTUCOE <>[M:SOH4]SAUSTUCOE(nolign-1) : [M:SOH4]WUPDAPPFLG(nolign-1)=2 : WCLCPFM=1 : Endif
# Bug 80955

# flag saisie coef
[M:SOH4]DACSAUCOE(nolign-1)  =[M:POH2]COEFLG(NOLPOH-1)

#date de livraison demandée
# 101447 : point d'entrée pour alimenter de façon spécifique la date de livraison demandée
Local Date WSAVDDEMDLVDAT : WSAVDDEMDLVDAT=[M:SOH4]DDEMDLVDAT(nolign-1)
Raz GPE
GPOINT ="MAJDEMDLVDAT" : Gosub ENTREE From EXEFNC
If !GPE
#If [M:SOH4]DDEMDLVDAT(nolign-1) <> [M:POH2]EXTRCPDAT(NOLPOH-1)
#    [M:SOH4]DDEMDLVDAT(nolign-1)  =[M:POH2]EXTRCPDAT(NOLPOH-1)
#    # contrôle date de livraison demandée
#    If [M:SOH4]DDEMDLVDAT(nolign-1)<  [M:SOH0]ORDDAT
#         GERR=2 : LERRCOD=31 : Gosub TRT_ERR : Raz GERR
#        [M:SOH4]DDEMDLVDAT(nolign-1)=[M:SOH0]ORDDAT
#    Endif
#    Gosub CALDATDET
#Endif
    If [M:SOH4]DDEMDLVDAT(nolign-1) <> [M:POH2]EXTRCPDAT(NOLPOH-1)
        [M:SOH4]DDEMDLVDAT(nolign-1)  =[M:POH2]EXTRCPDAT(NOLPOH-1)
    Endif
Endif
If [M:SOH4]DDEMDLVDAT(nolign-1)<> WSAVDDEMDLVDAT
    # contrôle date de livraison demandée
    If [M:SOH4]DDEMDLVDAT(nolign-1)<  [M:SOH0]ORDDAT
        GERR=2 : LERRCOD=31 : Gosub TRT_ERR : Raz GERR
        [M:SOH4]DDEMDLVDAT(nolign-1)=[M:SOH0]ORDDAT
    Endif
    Gosub CALDATDET
Endif
# 101447

# site exp
If [M:SOH4]DSTOFCY(nolign-1)     <> [M:POH2]LINSTOFCY(NOLPOH-1)
    [M:SOH4]DSTOFCY(nolign-1)     =[M:POH2]LINSTOFCY(NOLPOH-1)
    If [M:POH2]SOHNUM(NOLPOH-1) = ""
        Call ALIFMI([M:SOH4]ITMREF(nolign-1), [M:SOH4]DSTOFCY(nolign-1), WFMI) From TRTVENCDE
        [M:SOH4]FMI(nolign-1)=WFMI
        If [M:SOH4]FMI(nolign-1)=3 : Gosub ALIFMI : Endif
    Endif
    WCLCPFM=1
Endif

# lieu de conso
[M:SOH4]USEPLC(nolign-1) = [M:POH2]USEPLC(NOLPOH-1)

# 26113  : Inter-site : Price recalculation (LD:22/06/15)
If ([M:SOH1]BETFCY=2 | [M:SOH1]BETCPY=2)
 Gosub M_PRIX_INTER_SOC_SITE
Endif
# 26113  : Inter-site : Price recalculation (LD:22/06/15)

# recalcul marge
If WCLCPFM=1
    # 107890 : Scheduled invoices : (LD:07/06/16)
    # If we need to recalcul the margin :
    # - Coefficient conversion modification, Qty modification, Sales Unit modification
    # - Price modification
    # CLCPFM will set flags for Scheduled invoices modification if the price has changed
    # These flags will be tested at the end of the line modification
    # 107890 : Scheduled invoices : (LD:07/06/16)
    NLIG = nolign-1
    Call CLCPFM([M:SOH4]DSTOFCY(NLIG) , [M:SOH1]PRITYP, [M:SOH0]CHGTYP, [M:SOH0]ORDDAT, [M:SOH0]CUR, NLIG, 2) From TRTVENPRI
    nolign=NLIG+1
Endif

# 107890 : Scheduled invoices : (LD:07/06/16)
If WINVCND_CHG=1
    # If the Qty or the sales unit are modified but this does not impact the price
    # We need to set flags for Scheduled invoices modification
    # These flags will be tested at the end of the line modification
    # 107890 : Scheduled invoices : (LD:06/06/16)
    #--Changing the quantity or due to the price search, the invoice schedule has to be updated
    If [M:SOH4]DINVCND(NLIG)<>""
      [M:SOH4]DINVCNDTOUPD(NLIG)=[V]CST_AYES
      [M:SOH4]DINVCNDTODIS(NLIG)=[V]CST_AYES #CPO 18/01/2016 Thus, we only do it once after an order line modification
      #--Here it is to early to call the redispatch for the global invoice condition schedule associated to the line
      #--It will be done in "after line" action on P1_NBLIG
    Else
      [M:SOH4]DINVCNDTOUPD(NLIG)=[V]CST_ANO
      [M:SOH4]DINVCNDTODIS(NLIG)=[V]CST_ANO #CPO 18/01/2016
    Endif
Endif
# 107890 : Scheduled invoices : (LD:07/06/16)

Return

# 26113  : Inter-site : Price recalculation (LD:22/06/15)
################################################################################################
# $C_PRIX_INTER_SOC_SITE : Gestion du prix intersite et intersociété en création de commande  ##
# Cas de la création                                                                           #
################################################################################################
$C_PRIX_INTER_SOC_SITE
Local Decimal WVALZONE_CMD_ACH
Local Integer WRECH_TAR         :#--CPO 81500
Local Integer K

# Recupération paramétrage tranfert de prix : WTRFPRI
# Issue 118439
#Call IS_FLUX(14, [M:POH0]POHFCY, [M:POH0]BPSNUM, WTRFPRI, STAT) From FUNBCH
Call IS_FLUX(14, [M:POH0]POHFCY, [M:SOH0]SALFCY, WTRFPRI, STAT) From FUNBCH
# End issue 118439

#- Sur paramétrage intersociété: Si Transfert prix=Non --#
# If WTRFPRI=1 : #--  Pas recherche tarif sauf si prix, remise, de cmd vente=0  --#
#    Local Decimal  WGROPRI
#    If WGROPRI<>0
#      [M:SOH4]GROPRI(NLIG)= WGROPRI
#      Return
#    Endif
# Endif

If WTRFPRI = 2
    # Transfert des prix = Oui
    # Alimentation du prix brut et des frais/remises à partir de la commande d'achat

    # Alimentation du prix brut
    [M:SOH4]GROPRI(NLIG)= [M:POH2]GROPRI(NOLPOH-1)

    # Alimentation des frais/remises
    For K = 1 To 9
      If evalue ("dim([M:SOH4]DISCRGVAL"+num$(K)+")") > 0 & evalue ("dim([M:POH2]DISCRGVAL"+num$(K)+")") > 0
             WVALZONE_CMD_ACH= evalue ("[M:POH2]DISCRGVAL"+num$(K)+"(" + num$(NOLPOH-1)+ ")")
             Assign "[M:SOH4]DISCRGVAL"+num$(K)+"("+num$(NLIG)+")" With WVALZONE_CMD_ACH
      Endif
      If evalue ("dim([M:SOH4]DISCRGREN"+num$(K)+")") > 0 & evalue ("dim([M:POH2]DISCRGREN"+num$(K)+")") > 0
             WVALZONE_CMD_ACH= evalue ("[M:POH2]DISCRGREN"+num$(K)+"(" + num$(NOLPOH-1)+ ")")
             Assign "[M:SOH4]DISCRGREN"+num$(K)+"("+num$(NLIG)+")" With WVALZONE_CMD_ACH
      Endif
    Next

    # Calcul du prix net, s'il est à 0 et que l'on est en inter-société il faudra effectuer la recherche tarif
    Call CLCNETPRI([M:SOH4]QTY(NLIG), [M:SOH0]CUR, NLIG ) From TRTVENPRI

    If [M:SOH4]NETPRI(NLIG)<>0 | [M]BETCPY=1
        # Le prix net n'est pas à 0                            : Il ne faut pas effectuer la recherche tarif
        # Le prix net est à 0       et on est en inter-site    : Il ne faut pas effectuer la recherche tarif
        WRECH_TAR = 1
    Else
        # Le prix net est à 0       et on est en inter-société : Il faut effectuer la recherche tarif
        WRECH_TAR = 2
    Endif
Else
    # Transfert des prix = Non
    # Il faut effectuer la recherche tarif
    WRECH_TAR = 2
Endif

# --- Recherche tarif

#--CPO 81500 PE Permettant de recalculer les prix/remises ou forcer la recherche d'un tarif
#-- Appelé içi car si l'UV a été modifiée il faut bien tenir compte de cette dernière
#-- ainsi que du coef de conversion UV-US
#-- Si on ne veut pas de recherche tarif               => mettre WRECH_TAR à 1
#-- Si on    veut forcer la recherche tarif            => mettre WRECH_TAR à 2
#-- Si on modifie le prix brut et/ou les frais/remises => mettre WRECH_TAR à 3
GPOINT ="BETCPYSETPRI" : Gosub ENTREE From EXEFNC
If find(WRECH_TAR,2,3)>0
    If WRECH_TAR=2 :#--CPO 81500
      TYPRECH =1
      Call RECH_TARIF(TYPRECH,[M:SOH4]ITMREF(NLIG),NLIG ,[M:SOH4]QTY(NLIG),"SOH",[M:SOH4]GROPRI(NLIG)) From TRTVENTAR
    Endif
    Call CLCNETPRI([M:SOH4]QTY(NLIG), [M:SOH0]CUR, NLIG ) From TRTVENPRI
    WCLCPFM=1
Endif
#--/CPO

Return
###################################################################################################
# $M_PRIX_INTER_SOC_SITE : Gestion du prix intersite et intersociété en modification de commande ##
#-- X3Suivi 26113: Transfert du Prix en Intersite/Intersoc : Cas de la modification             --#
###################################################################################################
$M_PRIX_INTER_SOC_SITE
Local Integer MAJ_PRIX
Local Decimal WVALZONE_CMD_VEN
Local Decimal WVALZONE_CMD_ACH
MAJ_PRIX=1

# Recupération paramétrage tranfert de prix : WTRFPRI
# Issue 118439
#Call IS_FLUX(14, [M:POH0]POHFCY, [M:POH0]BPSNUM, WTRFPRI, STAT) From FUNBCH : #-- Recupération valeur de WTRFPRI
Call IS_FLUX(14, [M:POH0]POHFCY, [M:SOH0]SALFCY, WTRFPRI, STAT) From FUNBCH : #-- Recupération valeur de WTRFPRI
# End issue 118439

If WTRFPRI=2
    # Transfert des prix = Oui

    # Si le prix brut ou les frais/remises ont été modifiés
    # Si l'unité de vente ou la qté        ont été modifiées
    # --> Réalimentation du prix brut et des frais/remises à partir de la commande d'achat

    #-- Réalimentation du prix ------------#
    If [M:SOH4]GROPRI(NLIG) <> [M:POH2]GROPRI(NOLPOH-1) | WRECH_TAR=2
        #-Sur paramétrage intersociété: Si Transfert prix=Oui ou (Transfert prix=Non et prix de vente=0) --#
        MAJ_PRIX=2
        [M:SOH4]GROPRI(NLIG )= [M:POH2]GROPRI(NOLPOH-1)
    Endif

    #-- Réalimentation des frais/remises --#
    For K = 1 To 9
      If evalue ("dim([M:SOH4]DISCRGVAL"+num$(K)+")") > 0 & evalue ("dim([M:POH2]DISCRGVAL"+num$(K)+")") > 0
        WVALZONE_CMD_ACH= evalue ("[M:POH2]DISCRGVAL"+num$(K)+"(" + num$(NOLPOH-1)+ ")")
        WVALZONE_CMD_VEN= evalue ("[M:SOH4]DISCRGVAL"+num$(K)+"(" + num$(NLIG)+ ")")
        If WVALZONE_CMD_VEN <> WVALZONE_CMD_ACH | WRECH_TAR=2
          MAJ_PRIX=2
          Assign "[M:SOH4]DISCRGVAL"+num$(K)+"("+num$(NLIG)+")" With WVALZONE_CMD_ACH
          WVALZONE_CMD_ACH= evalue ("[M:POH2]DISCRGREN"+num$(K)+"(" + num$(NOLPOH-1)+ ")")
          Assign "[M:SOH4]DISCRGREN"+num$(K)+"("+num$(NLIG)+")" With WVALZONE_CMD_ACH
        Endif
      Endif
    Next

    If MAJ_PRIX=2
        Call CLCNETPRI([M:SOH4]QTY(NLIG ), [M:SOH0]CUR, NLIG ) From TRTVENPRI
        WCLCPFM=1

        If [M:SOH4]NETPRI(NLIG)<>0 | [M]BETCPY=1
            # Le prix net n'est pas à 0                            : Il ne faut pas effectuer la recherche tarif
            # Le prix net est à 0       et on est en inter-site    : Il ne faut pas effectuer la recherche tarif
            WRECH_TAR = 1
        Else
            # Le prix net est à 0       et on est en inter-société : Il faut effectuer la recherche tarif
            WRECH_TAR = 2
        Endif
    Endif
Endif

# Transfert des prix à Non
#    Et modification de l'unité, de la qté
# Transfert des prix à Oui
#    Et modification de l'unité, de la qté, du prix brut ou des frais/remises
#    Et le prix net issus de la cde d'achat à 0
# --> Recherche tarif

#--CPO 81500 PE Permettant de recalculer les prix/remises ou forcer la recherche d'un tarif
#-- Appelé içi car si l'UV a été modifiée il faut bien tenir compte de cette dernière
#-- ainsi que du coef de conversion UV-US
#-- Si on ne veut pas de recherche tarif               => mettre WRECH_TAR à 1
#-- Si on ne veut forcer la de recherche tarif         => mettre WRECH_TAR à 2
#-- Si on modifie le prix brut et/ou les frais/remises => mettre WRECH_TAR à 3
GPOINT ="BETCPYSETPRI" : Gosub ENTREE From EXEFNC
If find(WRECH_TAR,2,3)>0
    NLIG = nolign-1
    If WRECH_TAR=2 :#--CPO 81500
      TYPRECH =1
      Call RECH_TARIF(TYPRECH,[M:SOH4]ITMREF(NLIG),NLIG ,[M:SOH4]QTY(NLIG),"SOH",[M:SOH4]GROPRI(NLIG)) From TRTVENTAR
    Endif
    Call CLCNETPRI([M:SOH4]QTY(NLIG), [M:SOH0]CUR, NLIG ) From TRTVENPRI
    WCLCPFM=1
    nolign= NLIG+1
Endif
#--/CPO

Return
# 26113  : Inter-site : Price recalculation (LD:22/06/15)

#######################################################################
# Bug 67893
# ----------------------------------- #
# Initialisationn de la qté à allouer #
# ----------------------------------- #
$INIT_WALLQTYSTU
# -- Si Commande non bloquée, pas en dépassement d'en-cours avec blocage
#       Ligne ferme
#       Article géré en stock ou composé kit
# ----> Initialisation de la qté à allouer
If  (find([M:SOH1]CDTSTA,1,4) | ([M:SOH1]CDTSTA=3 & GCDTUNL=2)) & [M:SOH4]DEMSTA(NLIG)=1 & [M:SOH4]FMI(NLIG)=1 & ([M:SOH4]STOMGTCOD(NLIG)<>1 | find([M:SOH4]LINTYP(NLIG),2,10))
    # (Il faut toujours repartir des qté en US pour effectuer les calculs)
    # --- Qté à allouer = Qté déjà allouée + Reste à allouer
    Local Decimal COEF
    [M]WALLQTYSTU(NLIG) =[M]ALLQTYSTU(NLIG)+([M]QTYSTU(NLIG)-[M]TALLQTYSTU(NLIG))
    COEF=1/[M]SAUSTUCOE(NLIG)
    Call CNVQTY([M]WALLQTYSTU(NLIG),COEF,[M]SAU(NLIG),[M]WALLQTY(NLIG)) From TRTVENQTE
    If [M]WALLQTY(NLIG)>0 & GUSERERBPC=3
        # Dde d'utilisation des réservations clients
        [M]RERBPCFLG(NLIG)=1
        Local Char WVCRRER
        Local Decimal WALLCLI
        WVCRRER= vireblc(format$("K:"+num$(GLONBPC)+"X",[M]BPCORD)+format$("K:"+num$(GLONBPD)+"X",[M]DBPAADD(NLIG)), 1)
        #--- Bug 65986
        #Call CAL_RERQTY(1,[M]ITMREF(NLIG),[M]DSTOFCY(NLIG),WVCRRER,WALLCLI) From STKALL
        Call CAL_RERQTY(1,[M]ITMREF(NLIG),[M]DSTOFCY(NLIG),WVCRRER,[M]DSHIDAT(NLIG),WALLCLI) From STKALL
        #---
        If WALLCLI <> 0 [M]RERBPCFLG(NLIG)=2 : Endif
    Endif
Endif
Return
# Bug 67893

##############################################################################
# adresse de livraison
$RECBPD

Raz WDBPAADD
Filter [BPD] Where BPCNUM = [M:SOH0]BPCORD and RCPFCY =[M:POH2]PRHFCY(NOLPOH-1)
Read [BPD]BPD0 First
If !fstat
   WDBPAADD   = [F:BPD]BPAADD
Endif
Filter [BPD]

# point d'entrée pour alimenter l'adresse de livraison de façon spécifique
GPOINT ="ALIBPAADD" : Gosub ENTREE From EXEFNC

Return
##############################################################################
# Calcul du coef de conversion UV-US                                         #
##############################################################################
$CALSAUSTUCOE

# lecture article
If [F:ITM]ITMREF<>[M:SOH4]ITMREF(nolign-1)
    Read [ITM]ITM0= [M:SOH4]ITMREF(nolign-1)
    If fstat : GERR=1 :  LERRCOD=5 : Gosub TRT_ERR : GOK=0  : Return : Endif
    Read [ITS]ITS0= [M:SOH4]ITMREF(nolign-1)
    If fstat : GERR=1 :  LERRCOD=6 : Gosub TRT_ERR : GOK=0  : Return : Endif
Endif

# calcul du coef de conversion UV-US
Read [ITP]ITP0= [M:SOH4]ITMREF(nolign-1);[M:POH0]BPSNUM
If (!fstat & [F:ITP]PUU=[M:POH2]PUU(NOLPOH-1))
    [M:SOH4]SAUSTUCOE(nolign-1)   =[M:POH2]UOMPUUCOE(NOLPOH-1)*[F:ITP]PUUSTUCOE
Else
    [M:SOH4]SAUSTUCOE(nolign-1)   =[M:POH2]UOMPUUCOE(NOLPOH-1)*[F:ITM]PUUSTUCOE
Endif

Return
##############################################################################
$ALIFMI


If [M:SOH4]SAU(nolign-1) <> [F:ITM]SAU
    Call SCAL_QUV( [M:SOH4]QTY(nolign-1), [M:SOH4]ITMREF(nolign-1),[M:SOH0]BPCORD,[M:SOH4]SAU(nolign-1),[F:ITM]SAU, QTY_UV, GBIDD1) From TRTVENQTE
Else
    QTY_UV = [M:SOH4]QTY(nolign-1)
Endif

# Issue 117004
# Ctm directe interdit en intersite (intersociete et intrasociete) : Limite produit
## -->  On regarde si ctm directe
#If QTY_UV >= [F:ITS]CTMQTY & [F:ITS]CTMQTY > 0
#   [M:SOH4]FMI(nolign-1) = 2
#   [M:SOH4]STOMGTCOD(nolign-1) = 1
#Endif
# End issue 117004

If [M:SOH4]FMI(nolign-1)=3 |[M:SOH4]FMI(nolign-1)=5
      [M:SOH4]DALLTYP(nolign-1) =2
Endif

Return
##############################################################################
$ALISAU

# Issue X3-66385
# emballage, cap emballage
#If [M:SOH4]SAU(nolign-1) = [F:ITU]SAU
#    [M:SOH4]PCK(nolign-1)       = [F:ITU]PCK
#    [M:SOH4]PCKCAP(nolign-1)    = [F:ITU]PCKCAP
#Elsif [M:SOH4]SAU(nolign-1)     = [F:ITM]SAU
##    [M:SOH4]PCK(nolign-1)       = [F:ITS]PCK
##    [M:SOH4]PCKCAP(nolign-1)    = [F:ITS]PCKCAP
#    Call ALIPCK([M:SOH4]ITMREF(nolign-1), [M:SOH4]DSTOFCY(nolign-1), [M:SOH4]PCK(nolign-1), [M:SOH4]PCKCAP(nolign-1)) From TRTVENDIV
#Else Raz [M:SOH4]PCK(nolign-1),[M:SOH4]PCKCAP(nolign-1)
#Endif

# L'emballage est initialisé en priorité avec l'article client
# Il est initialisé avec l'article (article site ou catégorie article) uniquement si l'UV de l'article = l'UV de la ligne
# et si l'UV de l'article client = l'UV de la ligne mais il n'y a pas d'emballage pour l'article client
# ou si l'UV de l'article client est différente de l'UV de la ligne
# Package is initialized in priority with product customer
# It is initialized  with product (product site or product category) only if UV product= UV line
# and if UV product customer = UV line but there is no package for product customer
# or  if UV product customer <> UV line
Raz [M:SOH4]PCK(nolign-1),[M:SOH4]PCKCAP(nolign-1)
If [M:SOH4]SAU(nolign-1) = [F:ITU]SAU
    [M:SOH4]PCK(nolign-1)       = [F:ITU]PCK
    [M:SOH4]PCKCAP(nolign-1)    = [F:ITU]PCKCAP
Endif
If [M:SOH4]PCK(nolign-1) = ""
    If [M:SOH4]SAU(nolign-1) = [F:ITM]SAU
      Call ALIPCK ([M:SOH4]ITMREF(nolign-1), [M:SOH4]DSTOFCY(nolign-1), [M:SOH4]PCK(nolign-1), [M:SOH4]PCKCAP(nolign-1)) From TRTVENDIV
    Endif
Endif
# End issue X3-66385

Return
##############################################################################
$ALIBPD
Local Integer WSVGDAYLTI
Local Char    WSVGMDL(GLONMDL), WSVGBPTNUM(GLONBPT)
WSVGDAYLTI=[M:SOH4]DDAYLTI(nolign-1)
WSVGMDL=[M:SOH4]DMDL(nolign-1)
WSVGBPTNUM=[M:SOH4]DBPTNUM(nolign-1)

If [M:SOH4]DBPAADD(nolign-1)  <> [M:SOH1]BPAADD
    If [F:BPD]BPCNUM <> [M:SOH0]BPCORD | [F:BPD]BPAADD <> [M:SOH4]DBPAADD (nolign-1)
        Read [BPD]BPD0=[M:SOH0]BPCORD;[M:SOH4]DBPAADD(nolign-1)
        If fstat : GOK=0 : Return : Endif
    Endif
    [M:SOH4]DDLVPIO(nolign-1)          =[F:BPD]DLVPIO
    [M:SOH4]DDAYLTI(nolign-1)          =[F:BPD]DAYLTI
    [M:SOH4]DMDL(nolign-1)             =[F:BPD]MDL
    [M:SOH4]DDRN(nolign-1)             =[F:BPD]DRN
    [M:SOH4]DBPTNUM(nolign-1)          =[F:BPD]BPTNUM
    If LORICOD=1 & [F:BPD]MDL ="" : [M:SOH4]DMDL(nolign-1) = [M:SOH2]MDL  : Endif
    If LORICOD=1 & [F:BPD]BPTNUM ="" :[M:SOH4]DBPTNUM(nolign-1) = [M:SOH2]BPTNUM  : Endif
Else
    [M:SOH4]DDLVPIO(nolign-1)          =[M:SOH2]DLVPIO
    [M:SOH4]DDAYLTI(nolign-1)          =[M:SOH2]DAYLTI
    [M:SOH4]DMDL(nolign-1)             =[M:SOH2]MDL
    [M:SOH4]DDRN(nolign-1)             =[M:SOH2]DRN
    [M:SOH4]DBPTNUM(nolign-1)          =[M:SOH2]BPTNUM
Endif

If [M:SOH4]DDAYLTI(nolign-1)<>WSVGDAYLTI | [M:SOH4]DMDL(nolign-1)<>WSVGMDL | [M:SOH4]DBPTNUM(nolign-1)<>WSVGBPTNUM
    [M:SOH4]WUPDAPPFLG(nolign-1)=2
Endif

#contact livraison
If dim([M:SOH4]CNDNAM(nolign-1))>0
    Call RECH_CNTNAM([M:SOH0]BPCORD, [M:SOH4]DBPAADD(nolign-1), [M:SOH4]CNDNAM(nolign-1)) From TRTVENDIV
Endif

Return

##############################################################################
$CALDATDET

# date expédition
Call CALC_SHIDAT([M:SOH4]DDEMDLVDAT(nolign-1), [M:SOH4]DDAYLTI(nolign-1), [M:SOH4]DSTOFCY(nolign-1), 1,1,
&                [M:SOH0]ORDDAT, [M:SOH4]DSHIDAT(nolign-1)) From TRTVENDAT
# Bug 81008
If GERR=2
    LERRCOD=30 : Gosub TRT_ERR : Raz GERR
Endif

# date de livraison prévue
Call CALC_DLVDAT([M:SOH4]DSHIDAT(nolign-1), [M:SOH4]DDAYLTI(nolign-1), [M:SOH4]DBPAADD(nolign-1), [M:SOH0]BPCORD, 0,0,
&                [M:SOH4]EXTDLVDAT(nolign-1)) From TRTVENDAT
# Bug 81008
If GERR=2
    LERRCOD=32 : Gosub TRT_ERR : Raz GERR
Endif

# contrôle date d'exp
If [M:SOH4]DSHIDAT(nolign-1) <[M:SOH0]ORDDAT
     GERR=2 : LERRCOD=30 : Gosub TRT_ERR : Raz GERR
    [M:SOH4]DSHIDAT(nolign-1)=[M:SOH0]ORDDAT
Endif

# contrôle date liv prévue
If [M:SOH4]EXTDLVDAT(nolign-1) <[M:SOH4]DSHIDAT(nolign-1)
    GERR=2 : LERRCOD=32 : Gosub TRT_ERR : Raz GERR
    [M:SOH4]EXTDLVDAT(nolign-1) =[M:SOH4]DSHIDAT(nolign-1)
Endif


Return

##############################################################################
$TRT_ERR
Local Integer WERR

Case LERRCOD
    When 1:  GMESSAGE=[M:SOH0]BPCORD-":"-mess(139,100,1)
    When 2:  GMESSAGE=mess(262,192,1)-[M:POH2]PRHFCY(NOLPOH-1)
    When 3:  GMESSAGE=[M:SOH1]BPCINV-":"-mess(147,192,1)
    When 5:  GMESSAGE=WITM-":"-mess(212,199,1)
    When 6:  GMESSAGE=WITM-":"-mess(5,192,1)
    When 7:  GMESSAGE=[M:POH3]OCNNUM-mess(150,192,1)
    When 8:  GMESSAGE=mess(122,199,1)
    When 27: GMESSAGE=WITM-GMESSAGE
    When 28: GMESSAGE=[M:SOH4]ITMREF(nolign-1)-GMESSAGE
    When 29: GMESSAGE=mess(495,197,1)-":"-mess(184,197,1)-":"-[M:SOH2]SHIDAT
    When 30: GMESSAGE=mess(495,197,1)-":"-[M:SOH4]ITMREF(nolign-1)-":"-mess(184,197,1)-":"-[M:SOH4]DSHIDAT(nolign-1)
    When 31: GMESSAGE=mess(495,197,1)-":"-[M:SOH4]ITMREF(nolign-1)-":"-mess(496,197,1)-":"-[M:SOH4]DDEMDLVDAT(nolign-1)
    When 32: GMESSAGE=mess(495,197,1)-":"-[M:SOH4]ITMREF(nolign-1)-":"-mess(497,197,1)-":"-[M:SOH4]EXTDLVDAT(nolign-1)
    #When 33: If dim(SZUSER) < 0 Then  # FGR 19/11/2009 : X3SUIVI57762  GUSER
    #           GMESSAGE=mess(91,9139,1)-GUSER
    #         Else
    #           GMESSAGE=mess(91,9139,1)-SZUSER
    #         Endif
    When 33: If dim(SZUSRLOCK) < 0 Then  # FGR 11/01/2011 : X3SUIVI70620
               GMESSAGE=mess(91,9139,1)-GUSER
             Else
               GMESSAGE=mess(91,9139,1)-SZUSRLOCK
             Endif
    When 34: GMESSAGE=mess(147,192,1)
    When 35: GMESSAGE=mess(146,192,1)
Endcase

If GTRACE<>""
    If GERR=1 : WERR=1 : Endif
    If GERR=2 : WERR=0 : Endif
    Call ECR_TRACE(GMESSAGE,WERR) From GESECRAN
Endif
Return

##############################################################################
$SOH_ANNULE
    #-----
    If GTRACE<>""
      WMESS=mess(2,24,1)-mess(2,701,1)-num$([M:POH3]OCNNUM)-"   "-mess(99,197,1)-[M:POH0]BPCORD
      Call ECR_TRACE(WMESS,0) From GESECRAN
    Endif
    #-----
    Gosub  CHARGESOH
    If GOK <= 0 Return : Endif
    GBIDC1=""

    # Issue 119002
    ACTION = "AV_ANNULE"
    Gosub ACTION From GOBJSUB
    If   GOK<=0 Return : Endif
    # End issue 119002

    #Call ANNULE("SOH",[F:SOH]SOHNUM,GBIDC1,OK) From ANUCOD
    #Call ANUCOD("SOH",[F:SOH]SOHNUM,GBIDC1,OK) From GOBJSUB
    ACTION = "ANNULE"
    Gosub ACTION From  GOBJSUB
    If GOK<=0 : Return : Endif
    Delete [SOH] Where SOHNUM=[M:SOH0]SOHNUM
    If fstat
      GOK=0 : Call FSTA("SOH") From GLOCK : Return
    Endif
    Unlock = SYMBOLE
    Raz [M:SOH0], [M:SOH1], [M:SOH2], [M:SOH3], [M:SOH4]  : # HN

    # -- Déf des variables workflow
    Call WRKGLOB(172,[F:SOH]SOHNUM,"SORDER","") From GOBJACT
    #-------------------------------------------------#
    # Traitement d'un Workflow (normal)
    #-------------------------------------------------#
    Call WORKFLOW(2,"SOH","A",[F:SOH]SOHNUM) From AWRK

    Gosub MAJPOH                                          : # HN
    #-----
    If GTRACE<>""
      WMESS=mess(10,159,1)-mess(170,197,1) : # Commande supprimée !
      Call ECR_TRACE(WMESS,0) From GESECRAN
    Endif
    #-----
Return

##############################################################################
$SOH_SOLDE
    #-----
    If GTRACE<>""
      WMESS=mess(1,106,1)-mess(2,701,1)-num$([M:POH3]OCNNUM)-"   "-mess(99,197,1)-[M:POH0]BPCORD
      Call ECR_TRACE(WMESS,0) From GESECRAN
    Endif
    #-----
    Gosub  CHARGESOH
    If GOK <= 0 Return : Endif
    GBIDC1=""

    Call DIVCLESOH([F:SOH]SOHNUM ,GBIDC1) From TRTVENCDE
    Unlock = SYMBOLE
    #-----
    If GTRACE<>""
      WMESS=mess(10,159,1)-mess(263,197,1) : # Commande soldée !
      Call ECR_TRACE(WMESS,0) From GESECRAN
    Endif
    #-----
Return

##############################################################################
$FERME
#Close Local File [SOH]
#Close Local File [BPR]
#Close Local File [BPD]
#Close Local File [BPDW]
#Close Local File [BPC]
#Close Local File [TSO]
#Close Local File [ITM]
#Close Local File [ITS]
#Close Local File [ITU]
#Close Local File [ITP]

# restitution des variables globales
Gosub REST_GLOB From TRTX3GLOB #Gbn-Fq80541-Suppression du conditionnement de la restauration des globales
#If GFONC1<>"GESSOH" Gosub REST_GLOB From TRTX3GLOB : Endif

GIMPORT=SAVGIMPORT
GREP=SAVGREP

If WOUVRE_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif

Return

#------------------------------------------------------------------------------------#
# ALIBETCPY: Sous-programme de détermination d'un document inter-société             #
#------------------------------------------------------------------------------------#
# Entrée  LVCRTYP    : Type de pièce                                                 #
#                            2 : Commande de vente                                   #
#                           14 : Commande d'achat                                    #
#                            4 : Livraison                                           #
#                            5 : Facture de vente                                    #
#                           13 : Retour client                                       #
#         LBPAADD    : Adresse de livraison                                          #
# Sortie  LSALFCY    : Site de vente                                                 #
#                    : Client commande                                               #
#                    : Site de commande                                              #
#                    : Fournisseur                                                   #
#                    : Flag inter-site                                               #
#                    : Flag inter-société                                            #
#------------------------------------------------------------------------------------#
Subprog ALIBETCPY(LVCRTYP, LSALFCY, LBPCORD, LBPAADD, LPOHFCY, LBPSNUM, LBETFCY, LBETCPY)
Value    Integer LVCRTYP
Variable Char    LSALFCY
Variable Char    LBPCORD
Value    Char    LBPAADD
Variable Char    LPOHFCY
Variable Char    LBPSNUM
Variable Integer LBETFCY
Variable Integer LBETCPY

Local    Char    WBPRNUM(GLONBPR), WFCYORI(GLONFCY), WFCYDES(GLONFCY), WLEGCPY(GLONCPY)
Local    Integer STAT
Local    Integer WTRFPRI  :   # 26113  : Inter-site : Price recalculation (LD:22/06/15)

If clalev ([F:BPR])=0  Local File BPARTNER  [BPR] Endif
If clalev ([F:BPD])=0  Local File BPDLVCUST [BPD] Endif
If clalev ([F:FCY])=0  Local File FACILITY  [FCY] Endif

LBETFCY=1:LBETCPY=1
Case LVCRTYP
    When 2,4,5,13 : WBPRNUM=LBPCORD
                    WFCYORI=LSALFCY
    When 14       : WBPRNUM=LBPSNUM
                    WFCYORI=LPOHFCY
Endcase
# ------------------------------------------------------------- #
# Vérification que le tiers (client ou fournisseur) est correct #
# ------------------------------------------------------------- #
# Recherche si le tiers est inter-site
If [F:BPR]BPRNUM<>WBPRNUM
    Read [BPR]BPR0 = WBPRNUM
    If fstat Raz [F:BPR] Endif
Endif
If [F:BPR]BETFCY<2 End : Endif
If LVCRTYP=13
    # Particularité retour de livraison : Correspondance = client livré <==> site de réception
    # on recherche le site de réception raccroché au client livré
    Read [BPD]BPD0 = LBPCORD;LBPAADD
    If fstat Raz [F:BPD] Endif
    WFCYDES=[F:BPD]RCPFCY
Else
    WFCYDES=[F:BPR]FCY
Endif
If WFCYDES= "" End : Endif
# Le tiers est rattaché à un site : On vérifie que ce site est correct
If [F:FCY]FCY<>WFCYDES
    Read [FCY]FCY0 = WFCYDES
    If fstat Raz [F:FCY] Endif
Endif
WLEGCPY=[F:FCY]LEGCPY  : # Récup. de la société du Site rattaché au tiers
#If find(LVCRTYP,2,4,5)  & [F:FCY]PURFLG<>2 End Endif : # Site lié au client doit être site achat      : # Bug 66169
If find(LVCRTYP,2,4)    & [F:FCY]PURFLG<>2 End Endif : # Site lié au client doit être site achat       : # Bug 66169
If find(LVCRTYP,5)      & [F:FCY]FINFLG<>2 End Endif : # Site lié au client doit être site financier   : # Bug 66169
If find(LVCRTYP,13)     & [F:FCY]WRHFLG<>2 End Endif : # Site lié au client livré doit être site dépot
If find(LVCRTYP,14)     & [F:FCY]SALFLG<>2 End Endif : # Site lié au fsseur doit être site vente
# ------------------------------------------------------------- #
# Vérification que le site (vente ou commande) est correct      #
# ------------------------------------------------------------- #
#--CPO 81814 Lecture du site remontée ici pour besoins correction
# Recherche si le document est intra ou inter-société
If [F:FCY]FCY<>WFCYORI              : # Recherche de la société du Site origine
    Read [FCY]FCY0 = WFCYORI
    If fstat Raz [F:FCY] Endif
Endif
#--/CPO
# Recherche si le site est bien rattaché à un tiers
# Particularité retour de livraison : le site origine n'est pas forcément site de vente
# Donc il ne doit pas forcément être lié à un fsseur
Read [BPR] BPR2(2)=2;WFCYORI
[G:BPR]currind=1 : [G:BPR]currlen=0 : # Réinitialisation clé par défaut
#--CPO 81814 Retour sur livraison non inter-sites avec site de dépôt également site de vente
#If fstat & LVCRTYP=13 Raz [F:BPR] Elsif fstat End Endif
If fstat & LVCRTYP=13
  If [F:FCY]SALFLG=2
    End                 :#--CPO si site de dépôt également site de vente => il doit être paramétré comme inter-site
  Else
    Raz [F:BPR]         :#--CPO si site de dépôt uniquement => on garde le raisonnment existant (marqué plus haut)
  Endif
Elsif fstat
  End
Endif
#--/CPO
If find(LVCRTYP,2,4,5)  & [F:BPR]BPSFLG<>2 End Endif : # Tiers lié au site vente doit être fournisseur
If find(LVCRTYP,14)     & [F:BPR]BPCFLG<>2 End Endif : # Tiers lié au site achat doit être client
#
# Site et tiers sont ok                               ==> Document inter-site
#
LBETFCY=2
#--CPO 81814 Lecture du site remontée plus haut pour besoins correction
# Recherche si le document est intra ou inter-société
#If [F:FCY]FCY<>WFCYORI              : # Recherche de la société du Site origine
#    Read [FCY]FCY0 = WFCYORI
#    If fstat Raz [F:FCY] Endif
#Endif
#--/CPO
#If LVCRTYP=13
    # Particularité retour de livraison :
    # Le site origine est le site de réception, il est forcément dépôt mais pas forcément site de vente
#    If [F:FCY]SALFLG<>2 End Endif
#Endif
# --- Les 2 Sites sont sur 2 sociétés différentes     ==> Document inter-société
If WLEGCPY<>[F:FCY]LEGCPY LBETCPY=2 : Endif

Case LVCRTYP
    When 2,4,5  : LBPSNUM=[F:BPR]BPRNUM : # Document vente : On ramène le fournisseur
    When 14     : LBPCORD=[F:BPR]BPRNUM : # Document achat : On ramène le client
Endcase
# Recherche s'il y a un flux automatique à générer (sauf pour les livraisons et les retours)
If !find(LVCRTYP,4,13)
    # 26113  : Inter-site : Price recalculation (LD:22/06/15)
    # Il y a un flux automatisme à générer
    If find(LVCRTYP,2,5) & GMODU(6) <> 2 End Endif : # Origine vente et module achat non présent
    If find(LVCRTYP,14)  & GMODU(5) <> 2 End Endif : # Origine achat et module vente non présent
    Call IS_FLUX(LVCRTYP, WFCYORI, WFCYDES,WTRFPRI, STAT) From FUNBCH :
    If STAT=0 End Endif
    # Pour les performances, il est mieux de faire ce test avant l'appel à IS_FLUX
    ## Il y a un flux automatisme à générer
    #If find(LVCRTYP,2,5) & GMODU(6) <> 2 End Endif : # Origine vente et module achat non présent
    #If find(LVCRTYP,14)  & GMODU(5) <> 2 End Endif : # Origine achat et module vente non présent
    # 26113  : Inter-site : Price recalculation (LD:22/06/15)
Endif
# Tout est cohérent : On renvoie le site et le tiers destinataire
Case LVCRTYP
    When 2,5    : LPOHFCY=WFCYDES       : # Document vente : On ramène le site d'achat
    When 13     : LPOHFCY=WFCYDES       : # Document vente : On ramène le site de réception
    When 14     : LSALFCY=WFCYDES       : # Document achat : On ramène le site de vente
Endcase
End

#------------------------------------------------------------------------------------#
# CTLMAJSOH : Sous-programme de contrôle de mise à jour d'une entête commande vente  #
#------------------------------------------------------------------------------------#
# Entrée  LMAJCOD    : Code mise à jour :                                            #
#                            "C" : Création                                          #
#                            "M" : Modification                                      #
#                            "A" : Suppression                                       #
#                            "S" : Solde                                             #
#         LSOHNUM    : N° de la commande à modifier                                  #
# Sortie  LERRCOD    : Code retour                                                   #
#------------------------------------------------------------------------------------#
Subprog CTLMAJSOH(LMAJCOD, LSOHNUM, LERRCOD)
Value    Char    LMAJCOD
Value    Char    LSOHNUM
Variable Integer LERRCOD
Raz GMESSAGE, LERRCOD
If !find (LMAJCOD, "C","M","A","S") End Endif
If LSOHNUM =  ""  End Endif

If clalev([F:SOH])=0 : Local File SORDER     [SOH] : Endif

Local Integer WOK
# --- Lecture de la commande
Read [SOH]SOH0=LSOHNUM
If fstat LERRCOD = 7: GMESSAGE=LSOHNUM-":"-mess(150,192,1) : End : Endif

Case LMAJCOD
    When "M" :    # Contrôle de modification d'une commande
        # Commande non modifiable si soldée
        If [F:SOH]ORDSTA=2 LERRCOD=9:GMESSAGE=LSOHNUM-":"-mess(16,192,1) : End : Endif
    When "A" :   # Contrôle de suppression d'une commande
        # Commande non supprimable si allouée ou livrée ou facturée
        If [F:SOH]ALLSTA<>1 |[F:SOH]DLVSTA<>1 | [F:SOH]INVSTA<>1
            LERRCOD=16:GMESSAGE=LSOHNUM-":"-mess(15,192,1) : End
        Endif
        # Commande non supprimable si une ligne est préparée
        If clalev([F:SOQ])<=0 Local File SORDERQ [SOQ] : Endif
        Filter [SOQ] Where SOHNUM=[F:SOH]SOHNUM & sum(LPRQTYSTU,OPRQTYSTU,PREQTYSTU)<>0
        Read [SOQ]SOQ0 First
        If !fstat LERRCOD=16:GMESSAGE=LSOHNUM-":"-mess(310,192,1) : Filter [SOQ] : End : Endif
        Filter [SOQ]
        # Commande non supprimable s'il existe des contremarque pour cette cde
        If clalev([F:SOQ])<=0 Local File SORDERQ [SOQ] : Endif
        # Recherche si une ligne est liée à une contremarque
        Filter [SOQ] Where SOHNUM=[F:SOH]SOHNUM & FMINUM<>""
        Read [SOQ]SOQ0 First
        If !fstat LERRCOD=19:GMESSAGE=LSOHNUM-":"-mess(53,191,1) : Filter [SOQ] : End : Endif
        Filter [SOQ]
        WOK=1
        # Commande no supprimable si un acompte a été versé
        Call ACOMPTES(5,3,[F:SOH]SOHNUM,[F:SOH]LINNBR,[F:SOH]PTE,[F:SOH]ORDDAT,[F:SOH]ORDINVNOT,[F:SOH]ORDINVATI,
&                    [F:SOH]CUR,0,"","","",1,WOK) From TRTTPT
        If WOK=0 LERRCOD=18: GMESSAGE=LSOHNUM-":"-GMESSAGE : End : Endif
        # Commande non supprimable si elle est associé à une proforma
        If [F:SOH]PRFNUM <> ""
            LERRCOD=17:GMESSAGE=LSOHNUM-":"-mess(106,191,1)-[F:SOH]PRFNUM : End
        Endif
    When "S" : # Contrôle de solde d'une commande
        # Pas de solde si la commande est déjà soldée
        # Issue 83217 - 2012-07-02 by SR : continuer les contrôles
#        If [F:SOH]ORDSTA=2 LERRCOD= 9:GMESSAGE=LSOHNUM-":"-mess(16,192,1) : End : Endif
        If [F:SOH]ORDSTA=2 LERRCOD= 9:GMESSAGE=LSOHNUM-":"-mess(16,192,1) : Endif
        # Pas de solde si solde non autorisé
        If [F:SOH]ORDCLE=1 LERRCOD=20:GMESSAGE=LSOHNUM-":"-mess(24,192,1) : End : Endif
        # Pas de solde si une ligne est allouée ou préparée ou livrée ou facturée
        If clalev([F:SOQ])<=0 Local File SORDERQ [SOQ] : Endif
        # Issue X3-26200
#        Filter [SOQ] Where SOHNUM=[F:SOH]SOHNUM & sum(ALLQTYSTU,SHTQTYSTU,LPRQTYSTU,OPRQTYSTU,PREQTYSTU,ODLQTYSTU)<>0
#        Read [SOQ]SOQ0 First
#        If !fstat
#            LERRCOD=16:GMESSAGE=LSOHNUM-":"
#            If sum([F:SOQ]ALLQTYSTU,[F:SOQ]SHTQTYSTU,[F:SOQ]ODLQTYSTU)<>0     : # Bug 72308
#                GMESSAGE-=mess(15,192,1)
#            Elsif sum([F:SOQ]LPRQTYSTU,[F:SOQ]OPRQTYSTU,[F:SOQ]PREQTYSTU)<>0  : # Bug 72308
#                GMESSAGE-=mess(310,192,1)
#            Endif
#            Filter [SOQ] : End
#        Endif
        Local File PORDERQ    [POQ]
        Local File SDELIVERYD [SDD]
        Filter [SOQ] Where SOHNUM=[F:SOH]SOHNUM & sum(ALLQTYSTU,SHTQTYSTU,LPRQTYSTU,OPRQTYSTU,PREQTYSTU,ODLQTYSTU,DLVQTYSTU,INVQTYSTU)<>0
        For [SOQ]SOQ0
            If sum([F:SOQ]ALLQTYSTU,[F:SOQ]SHTQTYSTU)<>0
                # La ligne est allouée
                # Traitement impossible : Cette commande est allouée, livrée, facturée
                LERRCOD=16:GMESSAGE=LSOHNUM-":"-mess(15,192,1) : Break
            Elsif sum([F:SOQ]LPRQTYSTU,[F:SOQ]OPRQTYSTU,[F:SOQ]PREQTYSTU)<>0
                # La ligne est préparée
                # Commande en préparation
                LERRCOD=16:GMESSAGE=LSOHNUM-":"-mess(310,192,1) : Break
            Elsif [F:SOH]SOHCAT=1 & [F:SOQ]DLVFLG=2 & [F:SOQ]ODLQTYSTU<>0
                # Commande normale et Article livrable
                # La ligne est en cours de livraison
                # Traitement impossible : Cette commande est allouée, livrée, facturée
                LERRCOD=16:GMESSAGE=LSOHNUM-":"-mess(15,192,1) : Break
            Elsif [F:SOH]SOHCAT=1 & [F:SOQ]DLVFLG=2 & [F:SOQ]DLVQTYSTU<>0
                # Commande normale et Article livrable
                # La ligne est livrée
                # On vérifie qu'elle est réceptionnée : Si au moins une ligne n'est pas réceptionnée
                # Traitement impossible : Cette commande est allouée, livrée, facturée
                Filter [SDD] Where SOHNUM=[F:SOQ]SOHNUM & SOPLIN=[F:SOQ]SOPLIN & SOQSEQ=[F:SOQ]SOQSEQ & (QTYSTU-RTNQTYSTU>RCPQTYSTU)
                Read [SDD]SDD1 First
                If !fstat
                    LERRCOD=16:GMESSAGE=LSOHNUM-":"-mess(15,192,1) : Filter [SDD] : Break
                Endif
                Filter [SDD]
            Endif
            # La ligne de commande n'est ni allouée, ni préparée, ni en cours de livraison
            # Elle peut être livrée mais dans ce cas elle est réceptionnée
            # Elle peut être facturée
            If ([F:SOH]SOHCAT=1 & [F:SOQ]DLVFLG=2 & [F:SOQ]INVQTYSTU<>0) |
&              ([F:SOH]SOHCAT=1 & [F:SOQ]DLVFLG<>2 & sum([F:SOQ]ODLQTYSTU,[F:SOQ]INVQTYSTU)<>0) |
&              ([F:SOH]SOHCAT=3 & sum([F:SOQ]ODLQTYSTU,[F:SOQ]INVQTYSTU)<>0)
                # 3 cas possibles :
                # Commande normale et Article livrable
                # Commande normale et Article non livrable
                # Commande à facturation directe
                # La ligne est facturée
                # Il faut vérifier que ce qui est facturé côté vente est facturé côté achat
                # Lecture de la ligne de commande d'achat
                If [F:POQ]POHNUM <> [F:SOQ]POHNUM | [F:POQ]POPLIN <> [F:SOQ]POPLIN | [F:POQ]POQSEQ <> [F:SOQ]POQSEQ
                    Read [POQ]POQ0=[F:SOQ]POHNUM;[F:SOQ]POPLIN;[F:SOQ]POQSEQ
                    If fstat Raz [POQ] Endif
                Endif
                If ([F:SOH]SOHCAT=1 & [F:SOQ]DLVFLG=2  & [F:SOQ]INVQTYSTU<>[F:POQ]INVQTYSTU) |
&                  ([F:SOH]SOHCAT=1 & [F:SOQ]DLVFLG<>2 & sum([F:SOQ]ODLQTYSTU,[F:SOQ]INVQTYSTU)<>[F:POQ]INVQTYSTU) |
&                  ([F:SOH]SOHCAT=3 & sum([F:SOQ]ODLQTYSTU,[F:SOQ]INVQTYSTU)<>[F:POQ]INVQTYSTU)
                    # Traitement impossible : Cette commande est allouée, livrée, facturée
                    LERRCOD=16:GMESSAGE=LSOHNUM-":"-mess(15,192,1) : Break
                Endif
            Endif
        Next
        # End issue X3-26200
        Filter [SOQ]
Endcase

End
######################################################################################
Subprog C_SALFCY(LSALFCY)                : # Contrôle du site de vente
Variable Char    LSALFCY

GERR=0
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If [F:FCY]FCY<>LSALFCY
    Read [FCY]FCY0=LSALFCY
    If fstat GERR=1 : GMESSAGE=LSALFCY-":"-mess(15,104,1) : End : Endif
Endif
# Le site doit être site de vente
If SALFLG<> 2 GERR=1 : GMESSAGE=LSALFCY-":"-mess(413,199,1) : End : Endif
End
######################################################################################
Subprog C_BPCORD(LBPCORD, LSALFCY)          : # Contrôle du client commande
Variable Char    LBPCORD
Value    Char    LSALFCY

GERR=0
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If [F:BPC]BPCNUM<>LBPCORD
    Read [BPC]BPC0=LBPCORD
    If fstat GERR=1 : GMESSAGE=LBPCORD-":"-mess(139,100,1) : End : Endif
Endif
# Il doit être actif
If [F:BPC]BPCSTA<>2 GERR=1 : GMESSAGE=LBPCORD-":"-mess(4,119,1) : End : Endif
# Le tiers risque ne doit pas être bloqué
Local Integer WOSTCTL
If [F:BPC]BPCRSK<>LBPCORD
    Local File BPCUSTOMER [BPC1] : # Lecture du tiers risque ss une autre abrev pour ne pas casser [F:BPC] du clt cde
    If [F:BPC1]BPCNUM <> [F:BPC]BPCRSK
        Read [F:BPC1]BPC0 = [F:BPC]BPCRSK
        If fstat Raz [F:BPC1] : Endif
    Endif
    WOSTCTL=[F:BPC1]OSTCTL
Else
    WOSTCTL=[F:BPC]OSTCTL
Endif
If WOSTCTL = 3
    If !GIMPORT
        Local Integer WOK : WOK=1
        GMESSAGE=[F:BPC]BPCRSK-":"-mess(151,199,1)
        Call AVERTIR(GMESSAGE, WOK) From GESECRAN
        If WOK=1 : GERR=1 : mkstat=2 : Raz GMESSAGE : End : Endif
    Else
        GMESSAGE=[F:BPC]BPCRSK-":"-mess(151,199,1) : GERR=1 : mkstat=2 : End
    Endif
Endif
# Le tiers doit être autorisé pour la société
Call CTLBPRCPY(LBPCORD, LSALFCY) From CONTX3
If mkstat=2 GERR=1 : End : Endif

End
######################################################################################
Subprog RECINVFCY(LBPCINV, LINVFCY)          : # Recherche du site de facturation
Value    Char    LBPCINV
Variable Char    LINVFCY

GERR=0
If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
# Recherche du site de facturation lié au client facture
If [F:BPR]BPRNUM<>LBPCINV
    Read [BPR]BPR0=LBPCINV
    If fstat GERR=1 : GMESSAGE=mess(147,192,1) : End : Endif
Endif
If [F:BPR]FCY="" GMESSAGE=mess(74,187,1)-":"-mess(415,199,1) : End : Endif
# Vérification si le site est un site financier
If [F:FCY]FCY<>[F:BPR]FCY
    Read [FCY]FCY0=[F:BPR]FCY
    If fstat GERR=1 : GMESSAGE=mess(74,187,1)-":"-[F:BPR]FCY-":"-mess(415,199,1) : End : Endif
Endif
If [F:FCY]FINFLG<>2 GERR=1 : GMESSAGE=mess(74,187,1)-":"-[F:FCY]FCY-":"-mess(415,199,1) : End : Endif
LINVFCY=[F:BPR]FCY
End
######################################################################################
Subprog RECBPCINV(LINVFCY, LSALFCY, LBPCINV)  : # Recherche et contrôle du client facture
Value    Char    LINVFCY()
Value    Char    LSALFCY
Variable Char    LBPCINV

GERR=0
If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
# Recherche du tiers lié au site de facturation
If [F:BPR]FCY<>LINVFCY
    Read [BPR]BPR2(2)=2;LINVFCY
    [G:BPR]currind=1 : [G:BPR]currlen=0 : # Réinitialisation clé par défaut
    If fstat GERR=1 : GMESSAGE=LINVFCY-":"-mess(147,192,1) : End : Endif
Endif
LBPCINV=[F:BPR]BPRNUM
Call C_BPCINV(LBPCINV, LSALFCY)
End
######################################################################################
Subprog AS_BPCINV(LSOHNUM,LSOPLIN,LSOQSEQ) : # Recherche si client facture modifiable
Value    Char    LSOHNUM
Value    Integer LSOPLIN
Value    Integer LSOQSEQ

If clalev([F:SOH])=0 : Local File SORDER    [SOH] : Endif
If clalev([F:SOQ])=0 : Local File SORDERQ   [SOQ] : Endif
# Lecture de la commande
If [F:SOH]SOHNUM <> LSOHNUM
    Read [SOH]SOH0=LSOHNUM
    If fstat mkstat=2:GMESSAGE=LSOHNUM-":"-mess(359,197,1) : End : Endif
Endif
# Lecture de la ligne de commande
If [F:SOQ]SOHNUM <> LSOHNUM | [F:SOQ]SOPLIN <> LSOPLIN | [F:SOQ]SOQSEQ <> LSOQSEQ
    Read [SOQ]SOQ0=LSOHNUM;LSOPLIN;LSOQSEQ
    If fstat mkstat=2:GMESSAGE=LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(360,197,1) : End : Endif
Endif
# Client facture non modifiable si commande livrée
If [F:SOH]DLVSTA > 1 mkstat=2:GMESSAGE=mess(261,192,1) : End : Endif
End
######################################################################################
Subprog C_BPCINV(LBPCINV, LSALFCY)        : # Contrôle du client facture
Variable Char    LBPCINV()
Value    Char    LSALFCY

GERR=0
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
# Lecture du client
If [F:BPC]BPCNUM<>LBPCINV
    Read [BPC]BPC0=LBPCINV
    If fstat GERR=1 : GMESSAGE=LBPCINV-":"-mess(147,192,1): mkstat=2 : End : Endif
Endif
# Il doit être actif
If [F:BPC]BPCSTA<>2 GERR=1 : GMESSAGE=LBPCINV-":"-mess(4,119,1) : mkstat=2 : End : Endif
# Le tiers doit être autorisé pour la société
Call CTLBPRCPY(LBPCINV, LSALFCY) From CONTX3
If mkstat=2 GERR=1 : End : Endif
## Il ne doit pas être bloqué
#If [F:BPC]OSTCTL=3
#    If !GIMPORT
#        Local Integer WOK : WOK=1
#        GMESSAGE=LBPCINV-":"-mess(151,199,1)
#        Call AVERTIR(GMESSAGE, WOK) From GESECRAN
#        If WOK=1 : GERR=1 : mkstat=2 : Raz GMESSAGE : End : Endif
#    Else
#        GMESSAGE=LBPCINV-":"-mess(151,199,1) : GERR=1 : mkstat=2 : End
#    Endif
#Endif

End
######################################################################################
Subprog C_BPCGRU(LBPCGRU, LSALFCY)        : # Contrôle du client groupe
Variable Char    LBPCGRU()
Value    Char    LSALFCY

GERR=0
If LBPCGRU="" End Endif
# Lecture du client
If [F:BPC]BPCNUM<>LBPCGRU
    Read [BPC]BPC0=LBPCGRU
    If fstat Raz LBPCGRU : End : Endif
Endif
# Le tiers doit être autorisé pour la société
Call CTLBPRCPY(LBPCGRU, LSALFCY) From CONTX3
If mkstat=2 GERR=1 : End : Endif

End
######################################################################################
Subprog C_BPCPYR(LBPCPYR, LSALFCY)        : # Contrôle du client payeur
Variable Char    LBPCPYR()
Value    Char    LSALFCY

GERR=0
If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
# Lecture du tiers
If [F:BPR]BPRNUM<>LBPCPYR
    Read [BPR]BPR0=LBPCPYR
    If fstat GERR=1 : GMESSAGE=LBPCPYR-":"-mess(259,192,1) : End : Endif
Endif
# Le tiers doit être autorisé pour la société
Call CTLBPRCPY(LBPCPYR, LSALFCY) From CONTX3
If mkstat=2 GERR=1 : End : Endif

End
######################################################################################
Subprog C_STOFCY(LSTOFCY)                : # Contrôle du site d'expédition
Variable Char    LSTOFCY

# --- Prérequis    : GSOCIETE doit être chargé avec la société du site de vente
GERR=0
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If [F:FCY]FCY<>LSTOFCY
    Read [FCY]FCY0=LSTOFCY
    If fstat GERR=1 : GMESSAGE=LSTOFCY-":"-mess(15,104,1) : End : Endif
Endif
# Le site doit être site dépot
If WRHFLG<> 2 GERR=1 : GMESSAGE=LSTOFCY-":"-mess(58,199,1) : End : Endif
# Le site d'expédition doit être sur la même société juridique que le site de vente
If [F:FCY]LEGCPY <> GSOCIETE GERR=1 : GMESSAGE=mess(2,194,1) : End : Endif

End
#------------------------------------------------------------------------------------#
# CTLMAJSOP : Sous-programme de contrôle de mise à jour d'une ligne commande vente   #
#------------------------------------------------------------------------------------#
# Entrée  LMAJCOD    : Code mise à jour :                                            #
#                            "C" : Création                                          #
#                            "M" : Modification                                      #
#                            "A" : Suppression                                       #
#                            "S" : Solde                                             #
#         LSOHNUM    : N° de la commande à modifier                                  #
#         LSOPLIN    : N° de la ligne de commande à modifier                         #
#         LSOQSEQ    : N° de la ligne de commande à modifier                         #
# Sortie  LERRCOD    : Code retour                                                   #
#------------------------------------------------------------------------------------#
Subprog CTLMAJSOP(LMAJCOD,LSOHNUM,LSOPLIN,LSOQSEQ,LERRCOD)
Value    Char    LMAJCOD
Value    Char    LSOHNUM
Value    Integer LSOPLIN
Value    Integer LSOQSEQ
Variable Integer LERRCOD

Raz GMESSAGE, LERRCOD
If !find (LMAJCOD, "C","M","A","S") End Endif
If LSOHNUM =  ""  End Endif

If clalev([F:SOH])=0 : Local File SORDER      [SOH] : Endif
If clalev([F:SOQ])=0 : Local File SORDERQ     [SOQ] : Endif

Local Integer WOK, WRET
Local Decimal WTALLQTYSTU
# --- Lecture de la commande
Read [SOH]SOH0=LSOHNUM
If fstat LERRCOD = 7:GMESSAGE=LSOHNUM-":"-mess(359,197,1) : End : Endif
# --- Lecture de la ligne de commande
Read [SOQ]SOQ0=LSOHNUM;LSOPLIN;LSOQSEQ
If fstat LERRCOD = 21:GMESSAGE=LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(360,192,1) : End : Endif

Case LMAJCOD
    When "M" :    # Contrôle de modification d'une ligne de commande
        # Ligne de commande non modifiable si soldée
        If [F:SOQ]SOQSTA=3 LERRCOD=10:GMESSAGE=LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(18,192,1) : End : Endif
    When "A" :   # Contrôle de suppression d'une ligne de commande
        # Ligne de commande non supprimable si soldée
        If [F:SOQ]SOQSTA=3 LERRCOD=16:GMESSAGE=LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(18,192,1) : End : Endif
        # Ligne de commande non supprimable si allouée ou préparée ou livrée
        WTALLQTYSTU = sum([F:SOQ]ALLQTYSTU,[F:SOQ]LPRQTYSTU,[F:SOQ]OPRQTYSTU,[F:SOQ]PREQTYSTU,[F:SOQ]ODLQTYSTU)
        # 107888 : Scheduled invoices : (LD:20/05/16)
        #If [F:SOQ]SOHCAT=3
        If [F:SOQ]SOHCAT=3 | ([F:SOQ]SOHCAT=1 & [F:SOQ]DLVFLG=1)
            # --> Commande à facturation directe
            # --> Commande normale et article non livrable
        # 107888 : Scheduled invoices : (LD:20/05/16)
            WTALLQTYSTU += [F:SOQ]INVQTYSTU
        Else
            # --> Commande normale et article livrable      : # 107888 : Scheduled invoices : (LD:20/05/16)
            WTALLQTYSTU += [F:SOQ]DLVQTYSTU
        Endif
        If WTALLQTYSTU <> 0 LERRCOD=11:GMESSAGE=LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(311,192,1) : End : Endif
        # Ligne de commande non supprimable si liée à une contremarque
        If [F:SOQ]FMINUM <> ""
            LERRCOD=22:GMESSAGE=LSOHNUM-":"-mess(54,123,1)-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(52,191,1) : End
        Endif
    When "S" : # Contrôle de désolde/solde d'une ligne de commande
        # 107888 : Scheduled invoices : (LD:20/05/16)
        #If [F:SOQ]SOHCAT=3
        If [F:SOQ]SOHCAT=3 | ([F:SOQ]SOHCAT=1 & [F:SOQ]DLVFLG=1)
        # --> Commande à facturation directe
        # --> Commande normale et article non livrable
        # 107888 : Scheduled invoices : (LD:20/05/16)
            WTALLQTYSTU = sum([F:SOQ]INVQTYSTU,[F:SOQ]ODLQTYSTU)
        Else
        # --> Commande normale et article livrable      : # 107888 : Scheduled invoices : (LD:20/05/16)
            WTALLQTYSTU = sum([F:SOQ]DLVQTYSTU,[F:SOQ]ODLQTYSTU)
        Endif
        If [F:SOQ]SOQSTA=3
            # Pas de désolde si la ligne de commande est totalement livrée/facturée
            If WTALLQTYSTU>=[F:SOQ]QTYSTU LERRCOD=23:GMESSAGE=LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(258,192,1) : End : Endif
        Else
            # Pas de solde si solde non autorisé
            If [F:SOH]ORDCLE=1 & WTALLQTYSTU<[F:SOQ]QTY LERRCOD=24:GMESSAGE=LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(24,192,1) : End : Endif
            # Issue X3-26200
            # Pas de solde si la ligne est allouée ou préparée ou livrée ou facturée
#            If sum([F:SOQ]ALLQTYSTU,[F:SOQ]SHTQTYSTU,[F:SOQ]LPRQTYSTU,[F:SOQ]OPRQTYSTU,[F:SOQ]PREQTYSTU,[F:SOQ]ODLQTYSTU)<>0
#                LERRCOD=11:GMESSAGE=LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(311,192,1) : End
#            Endif
            Local File PORDERQ    [POQ]
            Local File SDELIVERYD [SDD]
            If sum([F:SOQ]ALLQTYSTU,[F:SOQ]SHTQTYSTU)<>0
                # La ligne est allouée
                # Traitement impossible : Cette ligne est allouée, préparée, livrée, facturée
                LERRCOD=11:GMESSAGE=LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(311,192,1) : End
            Elsif sum([F:SOQ]LPRQTYSTU,[F:SOQ]OPRQTYSTU,[F:SOQ]PREQTYSTU)<>0
                # La ligne est préparée
                # Traitement impossible : Cette ligne est allouée, préparée, livrée, facturée
                LERRCOD=11:GMESSAGE=LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(311,192,1) : End
            Elsif [F:SOH]SOHCAT=1 & [F:SOQ]DLVFLG=2 & [F:SOQ]ODLQTYSTU<>0
                # Commande normale et Article livrable
                # La ligne est en cours de livraison
                # Traitement impossible : Cette ligne est allouée, préparée, livrée, facturée
                LERRCOD=11:GMESSAGE=LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(311,192,1) : End
            Elsif [F:SOH]SOHCAT=1 & [F:SOQ]DLVFLG=2 & [F:SOQ]DLVQTYSTU<>0
                # Commande normale et Article livrable
                # La ligne est livrée
                # On vérifie qu'elle est réceptionnée
                # Traitement impossible : Cette ligne est allouée, préparée, livrée, facturée
                Filter [SDD] Where SOHNUM=[F:SOQ]SOHNUM & SOPLIN=[F:SOQ]SOPLIN & SOQSEQ=[F:SOQ]SOQSEQ & (QTYSTU-RTNQTYSTU>RCPQTYSTU)
                Read [SDD]SDD1 First
                If !fstat
                    LERRCOD=11:GMESSAGE=LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(311,192,1) : Filter [SDD] : End
                Endif
                Filter [SDD]
            Endif
            # La ligne de commande n'est ni allouée, ni préparée, ni en cours de livraison
            # Elle peut être livrée mais dans ce cas elle est réceptionnée
            # Elle peut être facturée
            If ([F:SOH]SOHCAT=1 & [F:SOQ]DLVFLG=2  & [F:SOQ]INVQTYSTU<>0) |
&              ([F:SOH]SOHCAT=1 & [F:SOQ]DLVFLG<>2 & sum([F:SOQ]ODLQTYSTU,[F:SOQ]INVQTYSTU)<>0) |
&              ([F:SOH]SOHCAT=3 & sum([F:SOQ]ODLQTYSTU,[F:SOQ]INVQTYSTU)<>0)
                # 3 cas possibles :
                # Commande normale et Article livrable
                # Commande normale et Article non livrable
                # Commande à facturation directe
                # La ligne est facturée
                # Il faut vérifier que ce qui est facturé côté vente est facturé côté achat
                # Lecture de la ligne de commande d'achat
                If [F:POQ]POHNUM <> [F:SOQ]POHNUM | [F:POQ]POPLIN <> [F:SOQ]POPLIN | [F:POQ]POQSEQ <> [F:SOQ]POQSEQ
                    Read [POQ]POQ0=[F:SOQ]POHNUM;[F:SOQ]POPLIN;[F:SOQ]POQSEQ
                    If fstat Raz [POQ] Endif
                Endif
                If ([F:SOH]SOHCAT=1 & [F:SOQ]DLVFLG=2  & [F:SOQ]INVQTYSTU<>[F:POQ]INVQTYSTU) |
&                  ([F:SOH]SOHCAT=1 & [F:SOQ]DLVFLG<>2 & sum([F:SOQ]ODLQTYSTU,[F:SOQ]INVQTYSTU)<>[F:POQ]INVQTYSTU) |
&                  ([F:SOH]SOHCAT=3 & sum([F:SOQ]ODLQTYSTU,[F:SOQ]INVQTYSTU)<>[F:POQ]INVQTYSTU)
                    # Traitement impossible : Cette ligne est allouée, préparée, livrée, facturée
                    LERRCOD=11:GMESSAGE=LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(311,192,1) : End
                Endif
            Endif
            # End issue X3-26200
        Endif
Endcase

End
######################################################################################
Subprog C_ITMREF(LITMREF, LORDDAT, LORICOD)        : # Contrôle de la référence article
Variable Char    LITMREF
Value    Date    LORDDAT
Value    Integer LORICOD           : # 1=origine cde d'achat

GERR=0
Local Integer WRET
If clalev([F:ITS])=0 : Local File ITMSALES  [ITS] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif

If [F:ITS]ITMREF<> LITMREF
    Read [ITS]ITS0 = LITMREF
    If fstat GERR=1: GMESSAGE=LITMREF-":"-mess(5,192,1) : End : Endif
Endif
# Remplacement par article de substitution
Call CTLSBSITM(LITMREF, LORDDAT, WRET) From TRTVENCTL
If WRET = 1
    GERR=1:GMESSAGE=LITMREF-":"-mess(40,192,1) : End
Elsif WRET = 2
    LITMREF=[F:ITS]ITMREF : GMESSAGE=mess(10,191,1) - LITMREF
    Call MESSAGE(GMESSAGE) From GESECRAN
Endif
# Lecture objet ITM
If [F:ITM]ITMREF<> LITMREF
    Read [ITM]ITM0 = LITMREF
    If fstat GERR=1:GMESSAGE=LITMREF-":"-mess(212,199,1) : End : Endif
Endif
# Contrôle du statut de l'article
If [F:ITM]ITMSTA > 1
   GERR=1:GMESSAGE=LITMREF-":"-mess(3,196,1)+" ("+mess([F:ITM]ITMSTA,246,1)+")"
   If LORICOD=1 & [F:ITM]ITMSTA=3    : # si cree depuis cde achat et statut rupture
      Raz GMESSAGE : GERR=0          : #    pas d erreur
   Else
      End                            : # sinon fin erreur
   Endif
Endif
# Contrôle de la date de début de vie de l'article
If [F:ITM]LIFSTRDAT<>[0/0/0] & LORDDAT<[F:ITM]LIFSTRDAT
    GERR=1:GMESSAGE=LITMREF-":"-mess(331,199,1)-":"-format$(GFMDAT,[F:ITM]LIFSTRDAT) : End
Endif
# Contrôle que l'article est toujours vendu
If clalev([F:ITG])= 0 Local File ITMCATEG [ITG] : Endif
If [F:ITG]TCLCOD <> [F:ITM]TCLCOD
    Read [ITG]ITG1=[F:ITM]TCLCOD;""
    If fstat GERR=1:GMESSAGE=LITMREF-":"-[F:ITM]TCLCOD-":"-mess(338,199,1) : End : Endif
Endif
If [F:ITG]SALFLG<>2 GERR=1:GMESSAGE=LITMREF-":"-mess(221,199,1)-"("-[F:ITM]TCLCOD-")" : End : Endif

End
######################################################################################
Subprog AS_SAU(LSOHNUM,LSOPLIN,LSOQSEQ)         : # Recherche si unité de vente modifiable
Value    Char    LSOHNUM
Value    Integer LSOPLIN
Value    Integer LSOQSEQ

# Remarque : Pas de positionnement de GMESSAGE, juste positionnement de mkstat car sous-pro appelé en AS_
If LSOHNUM<>""
    # Si commande créée
    If clalev([F:SOH])=0 : Local File SORDER    [SOH] : Endif
    If clalev([F:SOQ])=0 : Local File SORDERQ   [SOQ] : Endif
    # Lecture de la commande
    If [F:SOH]SOHNUM <> LSOHNUM
        Read [SOH]SOH0=LSOHNUM
#        If fstat mkstat=2:GMESSAGE=LSOHNUM-":"-mess(359,197,1) : End : Endif
        If fstat mkstat=2 : End : Endif
    Endif
    # Lecture de la ligne de commande
    If [F:SOQ]SOHNUM <> LSOHNUM | [F:SOQ]SOPLIN <> LSOPLIN | [F:SOQ]SOQSEQ <> LSOQSEQ
        Read [SOQ]SOQ0=LSOHNUM;LSOPLIN;LSOQSEQ
#        If fstat mkstat=2:GMESSAGE=LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(360,197,1) : End : Endif
        If fstat mkstat=2 : End : Endif
    Endif
    # Unité non modifiable si la commande est partiellement allouée/livrée
    If sum([F:SOQ]ALLQTYSTU,[F:SOQ]SHTQTYSTU,[F:SOQ]LPRQTYSTU,[F:SOQ]OPRQTYSTU,[F:SOQ]PREQTYSTU,[F:SOQ]ODLQTYSTU,[F:SOQ]DLVQTYSTU,[F:SOQ]INVQTYSTU) <> 0
#        mkstat=2:GMESSAGE=mess(9,123,1)-":"-mess(257,192,1) : End
        mkstat=2 : End
    Endif
Endif
End
######################################################################################
Subprog RECBPAADD(LPRHFCY, LBPCORD, LBPAADD)     : # Recherche et contrôle de l'adresse de livraison
Value    Char    LPRHFCY
Value    Char    LBPCORD
Variable Char    LBPAADD

GERR=0
If clalev([F:BPD])=0 : Local File BPDLVCUST [BPD] : Endif
# Recherche de l'adresse de livraison
Filter [BPD] Where BPCNUM = LBPCORD and RCPFCY = LPRHFCY & ENAFLG=2
Read [BPD]BPD0 First
If !fstat
    LBPAADD = [F:BPD]BPAADD
Else
#--CPO 87264 filter reste positionné
Filter [BPD]
    GERR=1: GMESSAGE=mess(413,199,1) : End
Endif
#--CPO 87264 filter reste positionné
Filter [BPD]
End
######################################################################################
Subprog RECPRHFCY(LBPCORD, LBPAADD, LPRHFCY)     : # Recherche du site de reception
Value    Char    LBPCORD
Value    Char    LBPAADD
Variable Char    LPRHFCY

GERR=0
If clalev([F:BPD])=0 : Local File BPDLVCUST [BPD] : Endif
# Recherche du site de reception lié à l'adresse de livraison
If [F:BPD]BPCNUM<>LBPCORD | [F:BPD]BPAADD<>LBPAADD
    Read [BPD]BPD0=LBPCORD;LBPAADD
    If fstat Raz [F:BPD] Endif
Endif
LPRHFCY=[F:BPD]RCPFCY
If LPRHFCY="" GERR=1: GMESSAGE=mess(74,187,1)-":": End : Endif
End
######################################################################################
Subprog AS_DBPAADD(LSALFCY, LBPCORD, LSOHNUM)     : # Recherche si adresse de livraison modifiable
Value    Char    LSALFCY
Value    Char    LBPCORD
Value    Char    LSOHNUM
# GLINBPD=1 : Pas de gestion des clients livrés à la ligne : 1 Seul client livré par commande
# --> 1 Seul site de réception par commande
Local Char    WPARAM(10)
Call PARAML(LSALFCY,"LINBPD",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GLINBPD = val(WPARAM)
If GLINBPD<>2 mkstat=2 : End : Endif
# DME=3     : Livraison commande complète                  : 1 Seul client livré par commande
# --> 1 Seul site de réception par commande
# Remarque : Pas de positionnement de GMESSAGE, juste positionnement de mkstat car sous-pro appelé en AS_
If LSOHNUM<>""
    # Commande créée
    If clalev([F:SOH])=0 : Local File SORDER [SOH] : Endif
    If [F:SOH]SOHNUM <> LSOHNUM
        Read [SOH]SOH0=LSOHNUM
#        If fstat GERR=1 : GMESSAGE=LSOHNUM-":"-mess(359,197,1) : End : Endif
        If fstat mkstat=2 : End : Endif
    Endif
    If [F:SOH]DME=3 mkstat=2 : End : Endif
Else
    # Commande non encore créée
    If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
    If [F:BPC]BPCNUM <> LBPCORD
       Read [BPC]BPC0=LBPCORD
#       If fstat GERR=1 : GMESSAGE=LBPCORD-":"-mess(139,100,1) : End : Endif
       If fstat mkstat=2 : End : Endif
    Endif
    If [F:BPC]DME=3 mkstat=2 : End : Endif
Endif
End
######################################################################################
Subprog AS_DSTOFCY(LSTOFCY,LBPCORD, LSOHNUM,LSOPLIN,LSOQSEQ) : # AS_ du site expédition détail
Variable Char    LSTOFCY
Value    Char    LBPCORD
Value    Char    LSOHNUM
Value    Integer LSOPLIN
Value    Integer LSOQSEQ

# Remarque : Pas de positionnement de GMESSAGE, juste positionnement de mkstat car sous-pro appelé en AS_
If LSOHNUM<>""
    # Commande créée
    If clalev([F:SOH])=0 : Local File SORDER    [SOH] : Endif
    If clalev([F:SOQ])=0 : Local File SORDERQ   [SOQ] : Endif
    # Lecture de la commande
    If [F:SOH]SOHNUM <> LSOHNUM
        Read [SOH]SOH0=LSOHNUM
#        If fstat mkstat=2:GMESSAGE=LSOHNUM-":"-mess(359,197,1) : End : Endif
        If fstat mkstat=2 : End : Endif
    Endif
    # Lecture de la ligne de commande
    If [F:SOQ]SOHNUM <> LSOHNUM | [F:SOQ]SOPLIN <> LSOPLIN | [F:SOQ]SOQSEQ <> LSOQSEQ
        Read [SOQ]SOQ0=LSOHNUM;LSOPLIN;LSOQSEQ
#        If fstat mkstat=2:GMESSAGE=LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(360,197,1) : End : Endif
        If fstat mkstat=2 : End : Endif
    Endif
    # Site non modifiable si il y a des allocations
    If sum([F:SOQ]ALLQTYSTU,[F:SOQ]SHTQTYSTU,[F:SOQ]LPRQTYSTU,[F:SOQ]OPRQTYSTU,[F:SOQ]PREQTYSTU,[F:SOQ]ODLQTYSTU,[F:SOQ]DLVQTYSTU,[F:SOQ]INVQTYSTU) <> 0
#        mkstat=2:GMESSAGE=mess(9,123,1)-":"-mess(257,192,1) : End
        mkstat=2 : End
    Endif
    # Site non modifiable si la contremarque a été générée
#    If [F:SOQ]FMINUM<>"" mkstat=2:GMESSAGE=mess(9,123,1)-":"-mess(52,191,1) : End : Endif
    If [F:SOQ]FMINUM<>"" mkstat=2 : End : Endif
    # Site non modifiable si livraison commande complète
#    If [F:SOH]DME=3 mkstat=2:GMESSAGE=mess(9,123,1)-":"-mess(260,192,1) : End : Endif
    If [F:SOH]DME=3 mkstat=2 : End : Endif
Else
    # Commande non encore créée
    If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
    If [F:BPC]BPCNUM <> LBPCORD
        Read [BPC]BPC0=LBPCORD
#        If fstat mkstat=2 : GMESSAGE=LBPCORD-":"-mess(139,100,1) : End : Endif
        If fstat mkstat=2 : End : Endif
    Endif
#    If [F:BPC]DME=3 mkstat=2:GMESSAGE=mess(9,123,1)-":"-mess(260,192,1) : End : Endif
    If [F:BPC]DME=3 mkstat=2 : End : Endif
Endif
End
######################################################################################
#-- X3Suivi 77496 : Commandes achat/vente inter-sociétés désynchronisées --#
Subprog C_QTY(LRECHQTYMAX,LBPCORD, LITMREF,LSAU,LSOHNUM,LSOPLIN,LSOQSEQ,LQTY) : # Contrôle de la quantité commandée ou Rech qté max
Value    Integer LRECHQTYMAX
Value    Char    LBPCORD
Value    Char    LITMREF
Value    Char    LSAU
Value    Char    LSOHNUM
Value    Integer LSOPLIN
Value    Integer LSOQSEQ
Variable Decimal LQTY

Local    Decimal WQTY
GERR=0
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:ITS])=0 : Local File ITMSALES  [ITS] : Endif
If clalev([F:SOH])=0 : Local File SORDER    [SOH] : Endif
If clalev([F:SOQ])=0 : Local File SORDERQ   [SOQ] : Endif

If LRECHQTYMAX <> 2 : #-- Cas du contrôle de la quantité --#
 # A voir faut-il charger ce paramêtre dans les achats si est en inter-société
 Local  Integer   GDACLOK
 Local  Char      WPARAM(10)
 #--------------------------------------------------------------#
 # Chargement param.utilisateur ctrl qte,prix,marge,montant mini#
 #--------------------------------------------------------------#
 Call PARAMUTIL("SDACLOK",WPARAM,"","") From SUBAUS
 GDACLOK=val(WPARAM)
 If GDACLOK=0 GDACLOK=1 Endif

 # Lecture de l'article
 If [F:ITM]ITMREF <> LITMREF
    Read [ITM]ITM0=LITMREF
    If fstat GERR=1:GMESSAGE=LITMREF-":"-mess(212,199,1) : End : Endif
 Endif
 # Lecture de l'article vente
 If [F:ITS]ITMREF <> LITMREF
    Read [ITS]ITS0=LITMREF
    If fstat GERR=1:GMESSAGE=LITMREF-":"-mess(7,192,1) : End : Endif
 Endif
 # --> Calcul de la qtée cdée en UV
 WQTY = LQTY
 If LSAU  <> [F:ITM]SAU Call SCAL_QUV(LQTY, LITMREF, LBPCORD, LSAU, [F:ITM]SAU, WQTY, GBIDD1) From TRTVENQTE : Endif
 # --> Controle qte cdee >= a la qte minimale
 If WQTY < [F:ITS]MINQTY & [F:ITS]MINQTY > 0
    GMESSAGE = sum(mess(12,192,1), format$("N:"+GFMTQTY, num$([F:ITS]MINQTY)), " ", [F:ITM]SAU)
    If GDACLOK = 1 mkstat=2 : End
    Else           GERR=2 : Endif
 Endif
 # --> Controle qte cdee <= a la qte maximale
 If WQTY > [F:ITS]MAXQTY & [F:ITS]MAXQTY > 0
    If GERR=2 GMESSAGE += "\" Endif
    GMESSAGE += sum(mess(13,192,1), format$("N:"+GFMTQTY, num$([F:ITS]MAXQTY)), " ", [F:ITM]SAU)
    If GDACLOK = 1 mkstat=2 : End
    Else           GERR=2 : Endif
 Endif
 If LSOHNUM = "" End Endif
Endif


# Si la commande de vente existe il faut regarder si la ligne est allouée
If [F:SOH]SOHNUM <> LSOHNUM
    Read [SOH]SOH0=LSOHNUM
    If fstat mkstat=2:GMESSAGE=LSOHNUM-":"-mess(359,197,1) : End : Endif
Endif
# Lecture de la ligne de commande
If [F:SOQ]SOHNUM <> LSOHNUM | [F:SOQ]SOPLIN <> LSOPLIN | [F:SOQ]SOQSEQ <> LSOQSEQ
    Read [SOQ]SOQ0=LSOHNUM;LSOPLIN;LSOQSEQ
    If fstat mkstat=2:GMESSAGE=LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)-":"-mess(360,197,1) : End : Endif
Endif
# La qté commandée ne doit pas être inférieure à ce qui est déjà alloué/préparé/livré/facturé
WQTY = [F:SOQ]ALLQTYSTU+[F:SOQ]SHTQTYSTU+[F:SOQ]LPRQTYSTU+[F:SOQ]OPRQTYSTU+[F:SOQ]PREQTYSTU+[F:SOQ]ODLQTYSTU
# 107888 : Scheduled invoices : (LD:20/05/16)
#If [F:SOH]SOHCAT = 3
If [F:SOH]SOHCAT = 3 | ([F:SOQ]SOHCAT=1 & [F:SOQ]DLVFLG=1)
    # --> Commande à facturation directe
    # --> Commande normale et article non livrable
# 107888 : Scheduled invoices : (LD:20/05/16)
    WQTY += [F:SOQ]INVQTYSTU
Else
    # --> Commande normale et article livrable      : # 107888 : Scheduled invoices : (LD:20/05/16)
    WQTY += [F:SOQ]DLVQTYSTU
Endif

If LRECHQTYMAX=2 : #-- Cas de la recherche de la quanité max --#
  LQTY = WQTY
Else
 If LQTY < WQTY
    mkstat=2: If GERR=2 GMESSAGE+= "\" Endif : GMESSAGE+=mess(312,192,1) : End
 Endif
Endif

End
######################################################################################
Subprog C_SHIDAT(LDEMDLVDAT, LBPCORD, LPRHFCY, LSTOFCY, LORDDAT)        : # Contrôle de la date d'expédition
Value Date LDEMDLVDAT
Value Char LBPCORD
Value Char LPRHFCY
Value Char LSTOFCY
Value Date LORDDAT

Local Date LSHIDAT
GERR=0
If clalev([F:BPD])=0 : Local File BPDLVCUST [BPD] : Endif

Local Char WSAVFCY(GLONFCY) : WSAVFCY=[F:FCY]FCY
# Recherche de l'adresse de livraison correspondant au site de réception
Filter [BPD] Where BPCNUM = LBPCORD and RCPFCY = LPRHFCY & ENAFLG=2
Read [BPD]BPD0 First
If !fstat
    # --> Calcul date expedition
    Call CALC_SHIDAT(LDEMDLVDAT, [F:BPD]DAYLTI, LSTOFCY, 1, 1, [0/0/0], LSHIDAT) From TRTVENDAT
    If mkstat=2
        GMESSAGE=mess(645,197,1)-":"-mess(81,197,1)-":"-LSTOFCY-":"-GMESSAGE : GERR=1
    Elsif LSHIDAT<LORDDAT
        :#--CPO 83985 GFMDAT au lieu de GFMD
        GMESSAGE=mess(645,197,1)-":"-format$(GFMDAT,LSHIDAT)-":"-mess(307,192,1)-"("+format$(GFMDAT,LORDDAT)+")": GERR=1 : mkstat=2
    Endif
Endif
If [F:FCY]FCY<>WSAVFCY & WSAVFCY<>""
    Read [F:FCY]FCY0 = WSAVFCY
    If fstat Raz [F:FCY] : Endif
Endif
Filter [BPD]  : # Bug 81166
End

# Issue 26113
######################################################################################
# Contrôle de la cohérence des structures entre les 2 sociétés                       #
#                                                                                    #
# Contrôle entre :                                                                   #
#    La structure du fournisseur de la commande d'achat                              #
#    La structure de la société  de la commande de vente                             #
#                                                                                    #
#------------------------------------------------------------------------------------#
# Entrée  LBPSNUM : Fournisseur                                                      #
#         LSALFCY : Site de vente                                                    #
# Sortie  LMSG    : Message d'erreur de retour                                       #
#         LRET    : Valeur de mkstat (2=Erreur)                                      #
#------------------------------------------------------------------------------------#
Funprog CTLPLISTC(LBPSNUM, LSALFCY, LMSG)
Value    Char LBPSNUM
Value    Char LSALFCY
Variable Char LMSG

Local Integer I
Local Integer LRET
LRET = [V]CST_AOK

Local File BPSUPPLIER [BPS]
Local File FACILITY   [FCY]
Local File COMPANY    [CPY]
Local File PRICSTRUCT [PRS]
Local File PRICSTRUCT [PRS2]

# Côté achat : Informations liées au fournisseur
Read [BPS]BPS0 = LBPSNUM
If fstat
    LRET=[V]CST_AERROR
    LMSG = func AFNC.MES2 (mess(641,199, 1),[F:BPS]BPSNUM, [F:FCY]LEGCPY)
    End
Endif

Read [PRS] PRS0=2;[F:BPS]PLISTC
If fstat
    LRET=[V]CST_AERROR
    LMSG = func AFNC.MES2 (mess(641,199, 1),[F:BPS]BPSNUM, [F:FCY]LEGCPY)
    End
Endif

# Côté vente : Informations liées à la société
Read [FCY]FCY0 = LSALFCY
If fstat
    LRET=[V]CST_AERROR
    LMSG = func AFNC.MES2 (mess(641,199, 1),[F:BPS]BPSNUM, [F:FCY]LEGCPY)
    End
Endif

Read [CPY]CPY0=[F:FCY]LEGCPY
If fstat
    LRET=[V]CST_AERROR
    LMSG = func AFNC.MES2 (mess(641,199, 1),[F:BPS]BPSNUM, [F:FCY]LEGCPY)
    End
Endif

Read [PRS2] PRS0=1;[F:CPY]PLISTC
If fstat
    LRET=[V]CST_AERROR
    LMSG = func AFNC.MES2 (mess(641,199, 1),[F:BPS]BPSNUM, [F:FCY]LEGCPY)
    End
Endif

# Comparaison des structures : Elles doivent être identiques (même colonnes)
# On accepte uniquement que la structure côté vente ait une colonne supplémentaire de type document
For I=0 To 8
  If [F:PRS2]INCDCR(I)   <>[F:PRS]INCDCR(I)    |
&    [F:PRS2]VALTYP(I)   <>[F:PRS]VALTYP(I)    |
&    [F:PRS2]CLCRUL(I)   <>[F:PRS]CLCRUL(I)    |
&    [F:PRS2]NPRNOTFLG(I)<>[F:PRS]NPRNOTFLG(I)
    # Une colonne est différente
    If !([F:PRS2]CLCRUL(I)=3 & [F:PRS]CLCRUL(I)=0)
        # Ce n'est pas une colonne supplémentaire vente de type document
        LRET=[V]CST_AERROR
        LMSG = func AFNC.MES2 (mess(575,199, 1),[F:BPS]BPSNUM - '('+ [F:BPS]PLISTC + ')', [F:FCY]LEGCPY - '('+ [F:CPY]PLISTC + ')')
        Break
    Endif
  Endif
Next I

End LRET
# Issue 26113

