#<AdxTL>@(#)3.0.0.0 $Revision$
Close Local Mask
Call SQLPRO(nomap)
End

########################################################################
Subprog SQLPRO(APPLI)
Value Char APPLI
Local Char PARAM(30)(1..2)
Call SAISIE_CHAR(APPLI,PARAM,"SQLPRO","SQLPRO","") From GSAISIE
End

######################################################################################
# Gestion des masques SQLPRO0,SQLPRO2,SQLPRO3,SQLPRO4
####################
$ACTION
If GACTION="SQLPRO4"
    Case ACTION
     When "INIT" : Gosub INIT45
     When "INIT_DIA" : Gosub INIT_DIA45
     When "EXEC"     : Gosub EXEC45
     When "TERMINE"  : Gosub TERMINE45
     When Default
    Endcase
Elsif GACTION="SQLPRO2"
    Case ACTION
     When "INIT_DIA" : Gosub INIT_DIA2
     When Default
    Endcase
Else
    Case ACTION
     When "OUVRE"        : Gosub OUVRE
     When "DEBUT"        : Gosub DEBUT
     When "SETBOUT"      : Gosub SETBOUT
     When "BOUTON"       : Gosub BOUTON
     When "RAF"          : Gosub RAF
     When "FIN"          : Gosub FIN
     When "EXEC"         : Gosub EXEC_BATCH
     When Default
    Endcase
Endif
Return



####################
$INIT45
Local Char TXT (255)
TXT="\"+num$([M:PRO1]SPID(nolign-1))-"/"-[M:PRO1]DBNAM(nolign-1)-"/"-[M:PRO1]LOGNAM(nolign-1)
# Terminer le processus
OK = 1 : Call OUINON(mess(223,100,1)+TXT,OK) From GESECRAN
If OK<>2
    FIN=1
Endif
Return

####################
$INIT_DIA45
Local Char TXT (255)
TXT=":"-num$([M:PRO1]SPID(nolign-1))-"/"-[M:PRO1]DBNAM(nolign-1)-"/"-[M:PRO1]LOGNAM(nolign-1)
# Terminer le processus
[M:PRO4]TXT1=mess(223,100,1)+TXT
[M:PRO4]TXT2=space$(30)+mess(224,100,1)
[M:PRO4]QST=mess(226,100,1)
#[M:PRO4]USR="sa"
# voir ici a recup authenfication login
# Récupération du passwd authenfication login
# jira X3-86047 86048 86049
Local Integer ERRDOS
Call PASSWD("database.software.sqlinternallogin",[M:PRO4]USR,ERRDOS) From DOSBASE
Return

####################
$EXEC45
Call TEMPON("") From GESECRAN
Call TUER_PRO1(FIN)
Call TEMPOFF From GESECRAN
Return

####################
$TERMINE45
Gosub ACTUALISER
Return

####################
$INIT_DIA2
Local Integer J

[M:PRO2]SPID=val(PARAM(1))
J=find([M:PRO2]SPID,[M:PRO1]SPID(0..[M:PRO1]NBPRO-1))
If J>0
    [M:PRO2]DBNAM=[M:PRO1]DBNAM(J-1)
    [M:PRO2]LOGNAM=[M:PRO1]LOGNAM(J-1)
    [M:PRO2]LASDAT=[M:PRO1]LASDAT(J-1)
    [M:PRO2]LASHOU=[M:PRO1]LASHOU(J-1)
    [M:PRO2]MAC=[M:PRO1]MAC(J-1)
    Call CHARGE_PRO2(FIN)
Endif
Return

####################
$OUVRE
If GTYPDBA<>2
    FIN=1
    Return
Endif
Return

####################
$EXEC_BATCH
#VPO 22/12/08 49736 rendre fonction batchable
If !GSERVEUR
    Return
Else
Local Mask SQLPRO0 [PRO0],SQLPRO1[PRO1],SQLPRO3[PRO3]
Endif
########################################
$DEBUT
If GTYPDBA<>2
    Call ERREUR(mess(185,115,1)) From GESECRAN : # La base de données n'est pas SQLSERVER
    FIN=1
    Return
Endif

#VPO 22/12/08 49736 rendre fonction batchable
If GSERVEUR
Call OUVRE_TRACE(mess(90,134,1)-mess(GTYPDBA,57,1)) From LECFIC
Endif

Raz [M:PRO0]
Raz [M:PRO1]
[M:PRO1]FLT=1
[M:PRO1]TRI=1
[M:PRO1]TYPTRI=1
Call VERS_SQL([M:PRO0]BDDNAM,[M:PRO0]VER,[M:PRO0]VERDES,FIN) From SQLPROP
If FIN : Return : Endif

#VPO 22/12/08 49736 rendre fonction batchable
If GSERVEUR
    Call ECR_TRACE("",0) From GESECRAN
    Call ECR_TRACE(func RDM("SQLPRO0","BDDNAM")-":"-[M:PRO0]BDDNAM,0) From GESECRAN
    Call ECR_TRACE(func RDM("SQLPRO0","VER")-":"-[M:PRO0]VER-[M:PRO0]VERDES,0) From GESECRAN
Endif

Gosub ACTUALISER
Return

####################
$FIN
#VPO 22/12/08 49736 rendre fonction batchable
If GSERVEUR
Call FERME_TRACE From LECFIC
Endif
Return

###################################################################################################
###################################################################################################
# Textes du dictionnaire (ATEXTE)
Funprog RDT(I)
Value Integer I
 If clalev([ZATX])=0 : Local File ATEXTE [ZATX] : Endif
 Read [ZATX]NUMERO=GLANGUE;I
 If fstat<>0
    If GLANGUE<>"FRA"
        Read [ZATX]NUMERO="FRA";I
        If fstat=0
            [ZATX]TEXTE="["+[ZATX]TEXTE+"]"
        Else
            Raz [ZATX]
        Endif
    Else
        Raz [ZATX]
    Endif
 Endif
End [ZATX]TEXTE

# Textes du dictionnaire par référence au champ d'un écran
# (ou au titre de l'écran si le champ est vide, ou au titre du bloc si on retrouve un champ numérique)
# A utiliser dès qu'on a besoin d'un texte "constant" déjà traduit (le numéro de ATEXTE n'est pas constant)
#
Funprog RDM(MASQ,CHAMP)
Value Char MASQ(),CHAMP()

 If clalev([AMK1])=0 : Local File AMSK [AMK1] : Endif
 If clalev([AMZ1])=0 : Local File AMSKZON [AMZ1] : Endif
 If pat(CHAMP,"#*")
    Read [AMK1]CODMSK=MASQ
    If fstat=0
        If [AMK1]TITBLOC(val(CHAMP))<>0
            End func SQLPRO.RDT([AMK1]TITBLOC(val(CHAMP)))
        Endif
    Endif
 Elsif CHAMP<>""
    Read [AMZ1]CODE=MASQ;CHAMP
    If fstat=0
        If [AMZ1]INTIT<>0
            End func SQLPRO.RDT([AMZ1]INTIT)
        Endif
    Endif
 Else
    Read [AMK1]CODMSK=MASQ
    If fstat=0
        If [AMK1]INTMSK<>0
            End func SQLPRO.RDT([AMK1]INTMSK)
        Endif
    Endif
  Endif
End ""



####################
$BOUTON
Case BOUT
   When "A" : Gosub ACTUALISER
Endcase
Return

#########
$SETBOUT
Call VIREBOUT(CHMEN,"A") From GOBJET

#on affiche toujours Actualiser
CHMEN+="A"
CHBOU += "=" : # Raffraîchir

Gosub SET_BOUT_SPE From GSAISIE
Return

####################
$RAF
$ACTUALISER
Call TEMPON("L") From GESECRAN
Call CHARGE_PRO1(FIN)
Call CHARGE_PRO3(FIN)
Affzo [M:PRO1]
Affzo [M:PRO3]
Call TEMPOFF From GESECRAN
Return


###################################################################################################
###################################################################################################
Subprog CHARGE_PRO1(ERR)
Variable Integer ERR

Local Char SQLREQ (200) (3)
Local Integer TRI,TYPTRI,FLT

Onerrgo ERR_SQL
SQLREQ(0) = "SELECT spid,db_name(dbid),loginame,"
SQLREQ(0) +="CONVERT(varchar,login_time,120),status,blocked,"
SQLREQ(0) +="cmd,program_name,convert(varchar,last_batch,120),"
SQLREQ(0) +="hostprocess,hostname, "
SQLREQ(1) = "cast(cpu as varchar),cast(memusage as varchar),cast(physical_io as varchar) "
SQLREQ(1) +="from [master]..sysprocesses "
If [M:PRO1]FLT=1
    SQLREQ(1) += "where loginame='"+nomap+"' and db_name(dbid)='"+[M:PRO0]BDDNAM+"'"
Elsif [M:PRO1]FLT=2
    SQLREQ(1) += "where db_name(dbid)='"+[M:PRO0]BDDNAM+"'"
Endif

SQLREQ(2) =" Order by "
Case [M:PRO1]TRI
    When 2: SQLREQ(2)-="db_name(dbid)"
    When 3: SQLREQ(2)-="loginame"
    When 4: SQLREQ(2)-="login_time"
    When 5: SQLREQ(2)-="status"
    When 6: SQLREQ(2)-="program_name"
    When 7: SQLREQ(2)-="cmd"
    When 8: SQLREQ(2)-="last_batch"
    When 9: SQLREQ(2)-="hostprocess"
    When 10: SQLREQ(2)-="hostname"
    When 11: SQLREQ(2)-="cpu"
    When 12: SQLREQ(2)-="memusage"
    When 13: SQLREQ(2)-="physical_io"
    When Default: SQLREQ(2)-="spid"
Endcase
Case [M:PRO1]TYPTRI
    When 2: SQLREQ(2)-="DESC"
    When Default: SQLREQ(2)-="ASC"
Endcase
If [M:PRO1]TRI<>1 : SQLREQ(2) += ",spid " : Endif

FLT = [M:PRO1]FLT
TRI = [M:PRO1]TRI
TYPTRI = [M:PRO1]TYPTRI
Raz [M:PRO1]
[M:PRO1]FLT=FLT
[M:PRO1]TRI=TRI
[M:PRO1]TYPTRI=TYPTRI
nolign = 0

For (Integer VSPID,Char VDBNAM(128),Char VLOGNAM(128),
&  Char VLOGDAT(50),Char VSTA(30),Integer VBLOCKID,
&  Char VCMD(30),Char VAPP(128),Char VLASDAT(50),
&  Char VHPRO(10),Char VMAC(128),
&  Char VCPU(30),Char VMEMUSE(30),Char VPHYIO(30)) From '5' Sql
&  SQLREQ
&   As [BXX]
    # Issue 84811 - 2012-10-01 by VPO : nb de lignes dans les tableaux
    If nolign>=dim([M:PRO1]SPID)
      Call ERREUR(mess(88,134,1)-mess(26,100,1)) From GESECRAN
      Break
    Endif
    nolign +=1
    [M:PRO1]SPID(nolign-1)=[BXX]VSPID
    [M:PRO1]DBNAM(nolign-1)=vireblc([BXX]VDBNAM,1)
    [M:PRO1]LOGNAM(nolign-1)=vireblc([BXX]VLOGNAM,1)
    [M:PRO1]LOGDAT(nolign-1)=format$("DZ<:YYYYMMDD",left$([BXX]VLOGDAT,10))
    #[M:PRO1]LOGHOU(nolign-1)=mid$([BXX]VLOGDAT,12,2)+mid$([BXX]VLOGDAT,15,2)
    [M:PRO1]LOGHOU(nolign-1)=mid$([BXX]VLOGDAT,12,8)
    [M:PRO1]STA(nolign-1)=vireblc([BXX]VSTA,1)
    [M:PRO1]APP(nolign-1)=vireblc([BXX]VAPP,1)
    [M:PRO1]CMD(nolign-1)=vireblc([BXX]VCMD,1)
    [M:PRO1]LASDAT(nolign-1)=format$("DZ<:YYYYMMDD",left$([BXX]VLASDAT,10))
    #[M:PRO1]LASHOU(nolign-1)=mid$([BXX]VLASDAT,12,2)+mid$([BXX]VLASDAT,15,2)
    [M:PRO1]LASHOU(nolign-1)=mid$([BXX]VLASDAT,12,8)
    [M:PRO1]OSPRO(nolign-1)=vireblc([BXX]VHPRO,1)
    [M:PRO1]MAC(nolign-1)=vireblc([BXX]VMAC,1)
    [M:PRO1]CPU(nolign-1)=val([BXX]VCPU)
    [M:PRO1]MEMUSE(nolign-1)=val([BXX]VMEMUSE)
    [M:PRO1]PHYIO(nolign-1)=val([BXX]VPHYIO)
    [M:PRO1]BLOCKID(nolign-1)=[BXX]VBLOCKID
Next
[M:PRO1]NBPRO = nolign
Onerrgo

#VPO 22/12/08 49736 rendre fonction batchable
If GSERVEUR & [M:PRO1]NBPRO>0
    Call ECR_TRACE("",0) From GESECRAN

    Call ECR_TRACE(mess(90,134,1),0) From GESECRAN
    Call ECR_TRACE_F(string$(160,"_"),"","","","",160,0,0,0,0,0) From GESECRAN

    Call ECR_TRACE_F(format$("K:8X",func RDM("SQLPRO1","SPID")),format$("K:20X",func RDM("SQLPRO1","LOGNAM"))+" "+format$("K:20X",func RDM("SQLPRO1","DBNAM")),
& format$("K:20X",func RDM("SQLPRO1","LOGDAT")),
& format$("K:15X",func RDM("SQLPRO1","STA"))+" "+format$("K:40X",func RDM("SQLPRO1","APP")+"/"+func RDM("SQLPRO1","CMD")),"",
& 9,42,21,57,0,0) From GESECRAN
    Call ECR_TRACE_F(string$(8,"_"),string$(20,"_")+" "+string$(20,"_"),
& string$(20,"_"),
& string$(15,"_")+" "+string$(40,"_"),"",
& 9,42,21,57,0,0) From GESECRAN

    Call ECR_TRACE_F("",format$("K:20X",func RDM("SQLPRO1","LASDAT")),"","","",
& 51,21,0,0,0,0) From GESECRAN
    Call ECR_TRACE_F("",string$(20,"_"),"","","",
& 51,21,0,0,0,0) From GESECRAN

    Call ECR_TRACE_F("",format$("K:20X",func RDM("SQLPRO1","OSPRO")),format$("K:60X",func RDM("SQLPRO1","MAC")),"","",
& 51,21,61,0,0,0) From GESECRAN
    Call ECR_TRACE_F("",string$(20,"_"),string$(60,"_"),"","",
& 51,21,61,0,0,0) From GESECRAN

    Call ECR_TRACE_F("",
& format$("K:8X",func RDM("SQLPRO1","CPU")),format$("K:8X",func RDM("SQLPRO1","MEMUSE")),
& format$("K:8X",func RDM("SQLPRO1","PHYIO")),format$("K:8X",func RDM("SQLPRO1","BLOCKID")),
& 51,9,9,9,9,0) From GESECRAN
    Call ECR_TRACE_F("",
& string$(8,"_"),string$(8,"_"),
& string$(8,"_"),string$(8,"_"),
& 51,9,9,9,9,0) From GESECRAN


    For I=0 To [M:PRO1]NBPRO-1

        Call ECR_TRACE_F(string$(160,"_"),"","","","",160,0,0,0,0,0) From GESECRAN

        Call ECR_TRACE_F(format$("N:8",[M:PRO1]SPID(I)),format$("K:20X",[M:PRO1]LOGNAM(I))+" "+format$("K:20X",[M:PRO1]DBNAM(I)),
& format$("K:20X",format$("D:"+GFMDAT,[M:PRO1]LOGDAT(I))-[M:PRO1]LOGHOU(I)),
& format$("K:15X",[M:PRO1]STA(I))+" "+format$("K:40X",[M:PRO1]APP(I)+"/"+[M:PRO1]CMD(I)),"",
& 9,42,21,57,0,0) From GESECRAN

        Call ECR_TRACE_F("",format$("K:20X",format$("D:"+GFMDAT,[M:PRO1]LASDAT(I))-[M:PRO1]LASHOU(I)),"","","",
& 51,21,0,0,0,0) From GESECRAN

        Call ECR_TRACE_F("",format$("K:20X",[M:PRO1]OSPRO(I)),format$("K:60X",[M:PRO1]MAC(I)),"","",
& 51,21,61,0,0,0) From GESECRAN

        Call ECR_TRACE_F("",
& format$("N:8",[M:PRO1]CPU(I)),format$("N:8",[M:PRO1]MEMUSE(I)),
& format$("N:8",[M:PRO1]PHYIO(I)),format$("N:8",[M:PRO1]BLOCKID(I)),
& 51,9,9,9,9,0) From GESECRAN

    Next I
    Call ECR_TRACE_F(string$(160,"_"),"","","","",160,0,0,0,0,0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
Endif
End

###################################################################################################
###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End



######################################################################################
######################################################################################
Subprog CHARGE_PRO2(ERR)
Variable Integer ERR
#############################################################
## Pour SQL-server
#############################################################
Local Char CHAINE(255) (3)
Local Char    BASE(30), USER(30), PASSE(30)
Local Char    SAVIFS(5) , SAVIRS(5) , XBASE(20) , WORDRE(250)
Local Integer SAVIUM,I
Local Char    TBDAT(30) , TBIDX(30)
Local Char    CMDFIC(GDIMFIC), FICCMD(GDIMFIC)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    RESTE(250), LIGNE(250)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    APPLI(50) ,SQLDBA(50) , IRS(2)
Local Char    MACHINE(GDIMFIC), NOMDOS(GDIMFIC),MACBID(GDIMFIC)
Local Char PROPERTY(100),VPROP(200),VPWD(200)
Local Char AUTHEN_LOGIN (200)
Local Char XINSTANCE(200)
Local Char XHOSTNAME(200) : # Hostname (, port) where the SQL Server is running. Could be "." for local host
Local Char TEXT(250)(3)

APPLI=nomap
Call MACHINE(APPLI,MACHINE,NOMDOS) From ORDSYS
IRS = chr$(13)+chr$(10)

# jira X3-86047 86048 86049 replace osql by sqlcmd
If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
    SQLDBA = "sqlcmd"

    # instance ?
    Call RECH_PROPERTY("database.adonix.sqlinstance",XINSTANCE,ERR) From DOSBASE
    If ERR <> 0
          Goto FIN_INFOS_SQL
    Endif
     # Get the SQL Server hostname from CONNECTSTR. Remove # and \ right part if exist
     XHOSTNAME = getenv$("CONNECTSTR")
     If (instr(0,XHOSTNAME,"\") > 0)
         XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"\")-1)
     Endif
     If (instr(0,XHOSTNAME,"#") > 0)
        XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"#")-1)
     Endif
     #XINSTANCE = ".\"+XINSTANCE
     XINSTANCE = XHOSTNAME+'\'+XINSTANCE
Else
    SQLDBA = "osql"
Endif

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = chr$(10) : adxium = GASCII
Call PASSE(APPLI,XBASE,USER,PASSE,BASE,TBIDX) From ORAPASSE
If BASE<>""
 # jira X3-86047 86048 86049 replace osql by sqlcmd
 Call PASSWD("database.software.sqlinternalpwd",VPWD,ERR) From DOSBASE
 If ERR <> 0
      Goto FIN_INFOS_SQL
 Endif
 #

 Call PASSWD("database.software.sqlinternallogin",AUTHEN_LOGIN,ERR) From DOSBASE
 If ERR <> 0
      Goto FIN_INFOS_SQL
 Endif
 #

 FICCMD = filpath("tmp","sqlpro"+num$(adxuid(2)),"BAT",APPLI)
 Call MACHINE(FICCMD ,MACBID,CMDFIC) From ORDSYS
 FICSQL = filpath("tmp","sqlpro"+num$(adxuid(2)),"sql",APPLI)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath("tmp","sqlpro"+num$(adxuid(2)),"log",APPLI)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 adxifs = "" : adxirs = IRS : adxium = GASCII
 ##
 ## On ecrit le fichier sql pour les tables
 ##
 Openo FICSQL , 0
 Wrseq "DBCC INPUTBUFFER ("+num$([M:PRO2]SPID)+")"
 Wrseq "GO"
 Wrseq "EXIT"
 Openo
 ##
 ## On ecrit le fichier de commande pour le déclenchement
 ## car bug sur probleme de PATH
 ##WORDRE = SQLDBA-"-D"-BASE-"-U sa -P"-VPWD-"-i"-SQLFIC-"-o"-TRAFIC-"-h-1 -n -w250"
 ##
 Openo FICCMD , 0
 Wrseq "@ECHO OFF"
 Wrseq "BREAK OFF"
 # jira X3-86047 86048 86049 replace osql by sqlcmd and password
 If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
      Wrseq "SET SQLCMD_EXE="+SQLDBA
      WORDRE = 'IF EXIST "%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE" SET SQLCMD_EXE="%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE"'
      Wrseq WORDRE
      WORDRE = '%SQLCMD_EXE%'-'-S'-XINSTANCE-'-d'-XBASE-'-U'-AUTHEN_LOGIN-'-P'-VPWD-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -w500'
      Wrseq WORDRE
 Else
     Wrseq "SET OSQL_EXE="+SQLDBA
     WORDRE = 'IF EXIST "%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE" SET OSQL_EXE="%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE"'
     Wrseq WORDRE
     WORDRE = '%OSQL_EXE%'-'-D'-BASE-'-U sa -P'-VPWD-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -n -w500'
     Wrseq WORDRE
 Endif
 Wrseq "BREAK ON"
 Openo
 System COMMANDE = MACHINE+'@'+CMDFIC
 If filinfo(FICTRA,0)>=0
  adxifs = "" : adxirs = IRS : adxium = GASCII
  I=0
  Openi FICTRA
  Rdseq LIGNE
  While fstat=0
   LIGNE = vireblc(LIGNE,2)
   If len(LIGNE)>0
      If len(CHAINE(I))+len(LIGNE)>255
         I +=1
      Endif
      CHAINE(I)+=LIGNE
   Else
      Break
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Endif
 System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
Endif
$FIN_INFOS_SQL
Setlob [M:PRO2]SQLTXT With CHAINE
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
End

###################################################################################################
###################################################################################################
Subprog TUER_PRO1(ERR)
Variable Integer ERR
Local Char    BASE(30), USER(30), PASSE(30)
Local Char    SAVIFS(5) , SAVIRS(5) , XBASE(20) , WORDRE(250)
Local Integer SAVIUM,I
Local Char    TBDAT(30) , TBIDX(30)
Local Char    CMDFIC(GDIMFIC), FICCMD(GDIMFIC)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    RESTE(250), LIGNE(250)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    APPLI(50) ,SQLDBA(50) , IRS(2)
Local Char    MACHINE(GDIMFIC), NOMDOS(GDIMFIC),MACBID(GDIMFIC)
Local Integer ERR
Local Char XINSTANCE(200)
Local Char XHOSTNAME(200) : # Hostname (, port) where the SQL Server is running. Could be "." for local host

APPLI=nomap
Call MACHINE(APPLI,MACHINE,NOMDOS) From ORDSYS
IRS = chr$(13)+chr$(10)
# jira X3-86047 86048 86049 replace osql by sqlcmd
If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
    SQLDBA = "sqlcmd"
    # instance ?
    Call RECH_PROPERTY("database.adonix.sqlinstance",XINSTANCE,ERR) From DOSBASE
    If ERR<>0
        End
    Endif
    #XINSTANCE = ".\"+XINSTANCE
     # Get the SQL Server hostname from CONNECTSTR. Remove # and \ right part if exist
     XHOSTNAME = getenv$("CONNECTSTR")
     If (instr(0,XHOSTNAME,"\") > 0)
         XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"\")-1)
     Endif
     If (instr(0,XHOSTNAME,"#") > 0)
        XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"#")-1)
     Endif
     #XINSTANCE = ".\"+XINSTANCE
     XINSTANCE = XHOSTNAME+'\'+XINSTANCE
Else
    SQLDBA = "osql"
Endif

#
SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = chr$(10) : adxium = GASCII
Call PASSE(APPLI,XBASE,USER,PASSE,BASE,TBIDX) From ORAPASSE
If BASE<>""

 FICCMD = filpath("tmp","sqlpro"+num$(adxuid(2)),"BAT",APPLI)
 Call MACHINE(FICCMD ,MACBID,CMDFIC) From ORDSYS
 FICSQL = filpath("tmp","sqlpro"+num$(adxuid(2)),"sql",APPLI)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath("tmp","sqlpro"+num$(adxuid(2)),"log",APPLI)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 adxifs = "" : adxirs = IRS : adxium = GASCII
 ##
 ## On ecrit le fichier sql pour les tables
 ##
 Openo FICSQL , 0
 Wrseq "KILL "+num$([M:PRO1]SPID(nolign-1))
 Wrseq "GO"
 Wrseq "EXIT"
 Openo
 ##
 ## On ecrit le fichier de commande pour le déclenchement
 ## car bug sur probleme de PATH
 ##WORDRE = SQLDBA-"-D"-BASE-"-U sa -P"-VPWD-"-i"-SQLFIC-"-o"-TRAFIC-"-h-1 -n -w250"
 ##
 Openo FICCMD , 0
 Wrseq "@ECHO OFF"
 Wrseq "BREAK OFF"
 # jira X3-86047 86048 86049 replace osql by sqlcmd
 If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
    Wrseq "SET SQLCMD_EXE="+SQLDBA
    WORDRE = 'IF EXIST "%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE" SET SQLCMD_EXE="%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE"'
    Wrseq WORDRE
    WORDRE = '%SQLCMD_EXE%'-'-S'-XINSTANCE-'-d'-XBASE-'-U'-[M:PRO4]USR-'-P'-[M:PRO4]PWD-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -w500'
    Wrseq WORDRE
 Else
    Wrseq "SET OSQL_EXE="+SQLDBA
    WORDRE = 'IF EXIST "%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE" SET OSQL_EXE="%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE"'
    Wrseq WORDRE
    WORDRE = '%OSQL_EXE%'-'-D'-BASE-'-U'-[M:PRO4]USR-'-P'-[M:PRO4]PWD-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -n -w500'
    Wrseq WORDRE
 Endif
 Wrseq "BREAK ON"
 Openo
 System COMMANDE = MACHINE+'@'+CMDFIC
 adxifs = "" : adxirs = IRS : adxium = GASCII
 If filinfo(FICTRA,0)>0
  Openi FICTRA
  Rdseq LIGNE
  While fstat=0
   LIGNE=vireblc(LIGNE,2)
   If LIGNE<>""
      Errbox LIGNE
      ERR=1
      Break
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Endif
 System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
Endif
$FIN_TUER
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
End



######################################################################################


###################################################################################################
###################################################################################################
Subprog CHARGE_PRO3(ERR)
Variable Integer ERR

Local Char SQLREQ1 (250)
Local Char SQLREQ (250) (4)
Local Integer J

SQLREQ(0) += "select l.req_spid spid"
SQLREQ(0) += ",coalesce(substring (s.loginame,1,20),'') loginname"
SQLREQ(0) += ",coalesce(substring (s.hostname,1,30),'') hostname"
SQLREQ(0) += ",cast(l.rsc_dbid as varchar) dbid"
SQLREQ(0) += ",substring (db_name(l.rsc_dbid),1,20) dbname"
SQLREQ(1) += ",cast(l.rsc_objid as varchar) objId"
SQLREQ(1) += ",cast(l.rsc_indid as varchar) IndId"
SQLREQ(1) += ",substring (v.name, 1, 20)  Type"
SQLREQ(1) += ",substring (l.rsc_text, 1, 20)   Resource"
SQLREQ(1) += ",substring (u.name, 1, 20)  Mode"
SQLREQ(1) += ",substring (x.name, 1, 20)  status"
SQLREQ(2) += " from [master]..syslockinfo l,"
SQLREQ(2) += "[master]..spt_values v,"
SQLREQ(2) += "[master]..spt_values x,"
SQLREQ(2) += "[master]..spt_values u,"
SQLREQ(2) += "[master]..sysprocesses s"
SQLREQ(3) += " where l.rsc_type = v.number"
SQLREQ(3) -= "and v.type = 'LR'"
SQLREQ(3) -= "and l.req_status = x.number"
SQLREQ(3) -= "and x.type = 'LS'"
SQLREQ(3) -= "and l.req_mode + 1 = u.number"
SQLREQ(3) -= "and u.type = 'L'"
SQLREQ(3) -= "and req_spid = s.spid"
If [M:PRO1]FLT=1
    SQLREQ(3) -= "and s.loginame='"+nomap+"' and db_name(s.dbid)='"+[M:PRO0]BDDNAM+"'"
Elsif [M:PRO1]FLT=2
    SQLREQ(3) -= "and db_name(s.dbid)='"+[M:PRO0]BDDNAM+"'"
Endif

SQLREQ(3) -= "order by spid"

Raz [M:PRO3]

nolign = 0

Local Char WVERSSQL(30)
Call NOVERS_SQL(WVERSSQL,ERR) From SQLPROP
If ERR<>0 : End : Endif

Onerrgo ERR_SQL
For (Integer VSPID,Char VLOGNAM(128),Char VMAC(128),
&  Char VDBID(20),Char VDBNAM(128),
&  Char VOBJID(20),Char VINDID(20),
&  Char VTYPLCK(30),Char VRES(30),
&  Char VMOD(30),Char VLCKSTA(30)) From '5' Sql
&    SQLREQ
&    As [BXX]
  If vireblc([BXX]VDBNAM,1)<>""
    # Issue 84811 - 2012-10-01 by VPO : nb de lignes dans les tableaux
    If nolign>=dim([M:PRO3]SPID)
      Call ERREUR(mess(513,153,1)-mess(26,100,1)) From GESECRAN
      Break
    Endif
    nolign +=1
    [M:PRO3]SPID(nolign-1)=[BXX]VSPID
    [M:PRO3]DBID(nolign-1)=vireblc([BXX]VDBID,1)
    [M:PRO3]DBNAM(nolign-1)=vireblc([BXX]VDBNAM,1)
    [M:PRO3]LOGNAM(nolign-1)=vireblc([BXX]VLOGNAM,1)
    [M:PRO3]MAC(nolign-1)=vireblc([BXX]VMAC,1)
    [M:PRO3]OBJID(nolign-1)=vireblc([BXX]VOBJID,1)
    If WVERSSQL="8"
        SQLREQ1="select name,USER_NAME(uid) from ["+[BXX]VDBNAM+"]..sysobjects where id ="+[BXX]VOBJID
    Else
        SQLREQ1="select name,SCHEMA_NAME(uid) from ["+[BXX]VDBNAM+"]..sysobjects where id ="+[BXX]VOBJID
    Endif
    For (Char VOBJNAM(128),Char VOBJOWN(128)) From '5' Sql SQLREQ1 As [BZZ]
        [M:PRO3]OBJNAM(nolign-1)=vireblc([BZZ]VOBJNAM,1)
        [M:PRO3]OBJOWN(nolign-1)=vireblc([BZZ]VOBJOWN,1)
        Break
    Next
    [M:PRO3]INDID(nolign-1)=vireblc([BXX]VINDID,1)
    SQLREQ1="select name from ["+[BXX]VDBNAM+"]..sysindexes where id ="+[BXX]VOBJID-"and indid="+[BXX]VINDID
    For (Char VINDNAM(128)) From '5' Sql SQLREQ1 As [BZZ]
        [M:PRO3]INDNAM(nolign-1)=vireblc([BZZ]VINDNAM,1)
        Break
    Next
    [M:PRO3]TYPLCK(nolign-1)=vireblc([BXX]VTYPLCK,1)
    [M:PRO3]RES(nolign-1)=vireblc([BXX]VRES,1)
    [M:PRO3]MODE(nolign-1)=vireblc([BXX]VMOD,1)
    [M:PRO3]LCKSTA(nolign-1)=vireblc([BXX]VLCKSTA,1)

    J=find([BXX]VSPID,[M:PRO1]SPID(0..[M:PRO1]NBPRO-1))
    If J>0
        [M:PRO3]WAIT(nolign-1)=[M:PRO1]BLOCKID(J-1)
    Endif
  Endif
Next
[M:PRO3]NBLOCK = nolign
Onerrgo
#VPO 22/12/08 49736 rendre fonction batchable
If GSERVEUR & [M:PRO3]NBLOCK>0
    Call ECR_TRACE("",0) From GESECRAN

    Call ECR_TRACE(mess(513,153,1) ,0) From GESECRAN
    Call ECR_TRACE_F(string$(160,"_"),"","","","",160,0,0,0,0,0) From GESECRAN

    Call ECR_TRACE_F(format$("K:8X",func RDM("SQLPRO3","SPID")),format$("K:20X",func RDM("SQLPRO3","LOGNAM"))+" "+format$("K:20X",func RDM("SQLPRO3","DBNAM")),
& format$("K:20X",func RDM("SQLPRO3","DBID"))+" "+format$("K:40X",func RDM("SQLPRO3","MAC")),
& format$("K:8X",func RDM("SQLPRO3","WAIT")),"",
& 9,42,62,9,0,0) From GESECRAN
    Call ECR_TRACE_F(string$(8,"_"),string$(20,"_")+" "+string$(20,"_"),
& string$(20,"_")+" "+string$(40,"_"),
& string$(8,"_"),"",
& 9,42,62,9,0,0) From GESECRAN

    Call ECR_TRACE_F("",
& format$("K:20X",func RDM("SQLPRO3","OBJOWN"))+" "+format$("K:20X",func RDM("SQLPRO3","OBJID"))+" "+format$("K:20X",func RDM("SQLPRO3","OBJNAM")),
& format$("K:20X",func RDM("SQLPRO3","INDID")),
& format$("K:40X",func RDM("SQLPRO3","INDNAM")),"",
& 51,63,21,41,0,0) From GESECRAN
    Call ECR_TRACE_F("",
& string$(20,"_")+" "+string$(20,"_")+" "+string$(20,"_"),
& string$(20,"_"),
& string$(40,"_"),"",
& 51,63,21,41,0,0) From GESECRAN

    Call ECR_TRACE_F("",
& format$("K:30X",func RDM("SQLPRO3","TYPLCK"))+" "+format$("K:30X",func RDM("SQLPRO3","RES")),
& format$("K:30X",func RDM("SQLPRO3","MODE")),
& format$("K:30X",func RDM("SQLPRO3","LCKSTA")),
& "",
& 51,62,31,31,0,0) From GESECRAN
    Call ECR_TRACE_F("",
& string$(30,"_")+" "+string$(30,"_"),
& string$(30,"_"),
& string$(30,"_"),"",
& 51,62,31,31,0,0) From GESECRAN

    For I=0 To [M:PRO3]NBLOCK-1

        Call ECR_TRACE_F(string$(160,"_"),"","","","",160,0,0,0,0,0) From GESECRAN

        Call ECR_TRACE_F(format$("N:8",[M:PRO3]SPID(I)),format$("K:20X",[M:PRO3]LOGNAM(I))+" "+format$("K:20X",[M:PRO3]DBNAM(I)),
& format$("K:20X",[M:PRO3]DBID(I))+" "+format$("K:40X",[M:PRO3]MAC(I)),
& format$("N:8",[M:PRO3]WAIT(I)),"",
& 9,42,62,9,0,0) From GESECRAN

        Call ECR_TRACE_F("",
& format$("K:20X",[M:PRO3]OBJOWN(I))+" "+format$("K:20X",[M:PRO3]OBJID(I))+" "+format$("K:20X",[M:PRO3]OBJNAM(I)),
& [M:PRO3]INDID(I),
& [M:PRO3]INDNAM(I),"",
& 51,63,21,41,0,0) From GESECRAN

        Call ECR_TRACE_F("",
& format$("K:30X",[M:PRO3]TYPLCK(I))+" "+format$("K:30X",[M:PRO3]RES(I)),
& format$("K:30X",[M:PRO3]MODE(I)),
& format$("K:30X",[M:PRO3]LCKSTA(I)),
& "",
& 51,62,31,31,0,0) From GESECRAN

    Next I
    Call ECR_TRACE_F(string$(160,"_"),"","","","",160,0,0,0,0,0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
Endif
End

