######################################################################################
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FIC,E_TYPE_FOLDER,GMESSAGE)
End
######################################################################################
######################################################################################
######################################################################################
## Section automatically added (screen SIESGNR) 06/23/2014 12:41:01 (RICAR)
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

#Local Integer I
#  For I=1 To GNBSITE
#    If GSOCSITE(I)=VALEUR & !find(GSITE(I),GUSRFCY(1..GNBAUZ))
#     GMESSAGE = mess(32,104,1)-VALEUR : # Tous les sites ne sont pas accessibles dans la société
#     mkstat = 1 : Break
#    Endif
#  Next I
Call CONTALLFCY(VALEUR) From CPTSUB : # Accès à tous les sites de la société ?


If func AFNC.PARAM("PORVAT",VALEUR) <> "2"
  GMESSAGE = mess(231,107,1)
  mkstat = 2
Endif
End


######################################################################################
######################################################################################
## Section automatically added (screen SIESGNR) 06/23/2014 12:35:25 (RICAR)
######################################################################################
Subprog C_DCLNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ''
  Read [F:DVPH]DVPH0 = VALEUR
  If [DVPH]CPY <> [M:DIA]CPY
    GMESSAGE=mess(86,7711,1)
    mkstat=2
    End
  Endif

  Filter [F:DVPH] Where [F:DVPH]CPY=[M:DIA]CPY and [F:DVPH]DCLTYP=2 and [F:DVPH]STRDAT=[M:DIA]FIYSTR and [F:DVPH]ENDDAT=FIYEND and
& [F:DVPH]DCLNUM=VALEUR
  Read [F:DVPH]DVPH0 First
  If fstat<>0
    GMESSAGE=mess(87,7711,1)
    mkstat=2
  Endif

  Filter [DVPH]
Endif
End


