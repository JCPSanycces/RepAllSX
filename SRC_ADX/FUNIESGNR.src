#################################################################################################

######################################################################################
## Section automatically added (screen SIESGNR) 15-04-2014 15:46:37 (RMA)
######################################################################################
Subprog C_FIYEND(VALEUR)
Variable Date    VALEUR

If !clalev([F:FIY])      : Local File FISCALYEAR[FIY] : Endif

Filter [F:FIY] Where [F:FIY]FIYSTR=[M:DIA]FIYSTR & [F:FIY]FIYEND=VALEUR & [F:FIY]CPY=[M:DIA]CPY
Read [F:FIY]FIY0 First
If fstat<>0
    mkstat=1
    Call ERREND(mess(63,7711,1)) From GESECRAN #Wrong fiscal year date. Please insert data again.
Endif
Filter [F:FIY]

End
######################################################################################
######################################################################################
Subprog AM_FIYEND(VALEUR)
Variable Date    VALEUR

Local Char    FLD
Local Char    CPY, FLDFCY
Local Date    DATAINI
Local Date    DATAFIM
Local Integer LINE

CPY     = [M:DIA]CPY
DATAINI = [M:DIA]FIYSTR
DATAFIM = VALEUR

For LINE = 0 To [M:DIA]NBLIG-1
  Raz [M:DIA]VERSION(LINE)
  FLD = [M:DIA]TXSNAM(LINE)
  Gosub SEL From SELIESGNRSTD
  If I = 2 : [M:DIA]VERSION(LINE) = [F:TXP]VERSION : Endif
Next

FLD = "VAT"
Raz [M:DIA]DCLNUM
Gosub SEL From SELIESGNRSTD
If I = 2 : [M:DIA]DCLNUM=[F:DVPH]DCLNUM : Endif

FLD = "04C"
Raz [M:DIA]NUMRPT
Gosub SEL From SELIESGNRSTD
If I = 2 : [M:DIA]NUMRPT=[F:CSRH]NUMRPT : Endif

Gosub SET_FCY_LIST From SELIESGNRSTD

FLD = "ANEXOR"
For LINE = 0 To [M]NBLIG1-1
  Raz [M:DIA]NUMR04A(LINE)
  FLDFCY = [M:DIA]FCY(LINE)
  Gosub SEL From SELIESGNRSTD
  If I = 2 : [M:DIA]NUMR04A(LINE)=[F:TXP]VERSION : Endif
Next

Affzo [M:DIA]10-30

End
######################################################################################
######################################################################################
Subprog D_INI(VALEUR)
Variable Decimal VALEUR
If [M]VOLFIL=""
 [M]TYPEXP=1
 Grizo [M]VOLFIL
Else
 [M]TYPEXP=2
 Actzo [M]VOLFIL
Endif
End
######################################################################################
######################################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR

If GBATCH & VALEUR=1
 # Le poste client est inaccessible en batch
 GMESSAGE = mess(163,141,1)
 mkstat = 2 : End
Endif

End
######################################################################################
######################################################################################
Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR

If VALEUR=1
 Raz [M:DIA]VOLFIL
 Grizo [M:DIA]VOLFIL
Else
 [M]VOLFIL = "[TMP]"
 Actzo [M:DIA]VOLFIL
Endif
Affzo [M:DIA]VOLFIL

End
