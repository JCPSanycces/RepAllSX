#<AdxTL>@(#)11.0.0.0 $Revision$
############################################################################################
############################################################################################
$ACTION

Case ACTION
    When "INIT"       : Gosub INIT
    When "INIT_DIA"   : Gosub INIT_DIA
    When "CONTROLE"   : Gosub CONTROLE
    When "EXEC"       : Gosub EXEC
Endcase

Return
############################################################################################
############################################################################################
$INIT

If !clalev([F:ADI])      : Local File ATABDIV         [ADI] : Endif
If !clalev([F:GTE])      : Local File GTYPACCENT      [GTE] : Endif
If !clalev([F:CPY])      : Local File COMPANY         [CPY] : Endif
If !clalev([F:FCY])      : Local File FACILITY        [FCY] : Endif
If !clalev([F:DVPH])     : Local File DCLVATPORH      [DVPH] : Endif
If !clalev([F:DVPF])     : Local File DCLVATPORF      [DVPF] : Endif
If !clalev([F:DVPL])     : Local File DCLVATPORL      [DVPL] : Endif
If !clalev([F:BPR])      : Local File BPARTNER        [BPR] : Endif
If !clalev([F:BPA])      : Local File BPADDRESS       [BPA] : Endif
If !clalev([F:TXM])      : Local File TXSM            [TXM] : Endif
If !clalev([F:DVPP])     : Local File DCLVATPORP      [DVPP] : Endif

Local Shortint  NESTAB      : NESTAB   = 0
Local Shortint  TEMANEXA    : TEMANEXA = 0
Local Shortint  TEMQ4B      : TEMQ4B   = 0
Local Char      SOC         : SOC      = ""
Local Char      NID         : NID      = ""
Local Char      COD         : COD      = ""
Local Char      CAE         : CAE      = ""
Local Char      NIFRL       : NIFRL    = ""
Local Char      NIFTOC      : ZNIFTOC  = ""
Local Char      TAGNAM      : TAGNAM   = ""
Local Char      DATDEB      : DATDEB   = [0/0/0]
Local Char      DATFIN      : DATFIN   = [0/0/0]
Local Char      ANO         : ANO      = ""
Local Integer   I           : I         = 0
Local Integer   Q           : Q         = 0
Local Integer   C
Local Integer   C2
Local Decimal   TMPVAL
Local Char      VERSION
Local Char      QUADRO
Local Char      CAMPO
Local Integer   COL
Local Char      ANEXO
Local Char      IESCRIT : IESCRIT = "0531A" #Variable to exclude the IES indicators from the list

#Local Char      DESTFILETMP(250)      : DESTFILETMP = ""    #Temporary File
#Local Char      DESTFILE(250)         : DESTFILE    = ""    #Final version of file
#Local Integer   OK : OK = 1

#Local Char    DIR_FIC(GDIMFIC)
#Local Char    MACHIN(GDIMFIC)                      : # Machine
#Local Char    IRS(2)                               : # Record separator
#Local Char    OS(20)
Local Integer OK
#Local Integer ERR

#New version to export IES file
Local Mask    SIESGNR [DIA]
Local Char    NAM(GDIMFIC), FICHIER(GDIMFIC), CHEMIN(GDIMFIC), MACHINE(GDIMFIC), CRITSPE(250)
Local Char    FICDON(GDIMFIC),URL(GDIMFIC)
Local Integer STAT
Local Char    NOMFIC(GDIMFIC)
Local Char    SEPCHR(10)
Local Char    SEPENR(10)
Local Char    SAVADXIRS(10)
Local Char    SAVADXIFS(10)

############################################################################
## Options d'export
############################################################################
SEPCHP = chr$(59)                                          : # Séparateur de champ (;)
SEPENR = chr$(13)+chr$(10)                                 : # Séparateur de ligne (CR+LF)
NAM    = "IES_"+format$("D:DDMMYYYY",date$)+"_"+num$(time) : # Nom du fichier
EXT    = "xml"

TRA = 1
TMP = 1
Raz [M:DIA]
[M]TYPEXP=2
If [M]VOLFIL="" & !GBATCH
 Call PARAM("","FUNIESGNR",NOMFIC) From ADOVAL
 If NOMFIC<>"" & left$(NOMFIC,1)="["
  [M]VOLFIL = NOMFIC
 Else
  [M]VOLFIL = "[TMP]"
 Endif
Endif
Actzo [M]VOLFIL
#

Gosub DEC_03A    From FUNIESGNRA
Gosub DEC_04A    From FUNIESGNRA
Gosub DEC_04B    From FUNIESGNRB # Capital Entry
Gosub DEC_04C    From FUNIESGNRB # Cash Flow
Gosub DEC_05041A From FUNIESGNRA
Gosub DEC_05071A From FUNIESGNRA
Gosub DEC_05081A From FUNIESGNRA
Gosub DEC_05121A From FUNIESGNRA
Gosub DEC_0516A  From FUNIESGNRA
Gosub DEC_05191A From FUNIESGNRA
Gosub DEC_05192A From FUNIESGNRA
Gosub DEC_0522A  From FUNIESGNRA
Gosub DEC_05241A From FUNIESGNRA
Gosub DEC_0526A  From FUNIESGNRA
Gosub DEC_05281A From FUNIESGNRA
Gosub DEC_05283A From FUNIESGNRA
Gosub DEC_05284A From FUNIESGNRA
Gosub DEC_05292A From FUNIESGNRA
#Gosub DEC_0531A  From FUNIESGNRA
Gosub DEC_061A   From FUNIESGNRA
Gosub DEC_ANEXOR From FUNIESGNRA

For [ADI] Where [F:ADI]NUMTAB = 304 & !find([ADI]A1,[L]IESCRIT)
  [M:DIA]CODE([M:DIA]NBLIG)   = [ADI]CODE
  [M:DIA]TXSNAM([M:DIA]NBLIG) = [ADI]A1
  [M:DIA]NBLIG               += 1
Next

Return
############################################################################################
############################################################################################
$INIT_DIA


Return
############################################################################################
############################################################################################
$CONTROLE
Read [F:CPY]CPY0 = [M:DIA]CPY
If fstat
   FIN         = 1
   GERR        = 1
   GMESSAGE    = func AFNC.MES1(mess(57,7711,1),[M:DIA0]CPY)  # Sociedade + [M:DIA]CPY + inexistente.
   GOK         = 0
   Return
Endif
If [M:DIA]DCLNUM <> ""
    Read [F:DVPH]DVPH0 = [M:DIA]DCLNUM
    If fstat
       FIN         = 1
       GERR        = 1
       GMESSAGE    = func AFNC.MES1(mess(58,7711,1),[M:DIA]DCLNUM) #Processo + [M:DIA]NUMIVAA + inexistente.
       GOK         = 0
       Return
    Endif
Endif

Return
############################################################################################
############################################################################################
$EXEC

Local Char PLEDTYP
[L]PLEDTYP = "1"

#New version of IES file
SAVADXIRS = adxirs
SAVADXIFS = adxifs
adxirs=SEPENR
adxifs=SEPCHP

FICHIER = [M:DIA]FIC
Call MACHINE(FICHIER,MACHINE,CHEMIN) From ORDSYS
NOMFIC  = [L]NAM

If [M]TYPEXP=1 : # Client
 FICHIER = filpath(CHEMIN,NOMFIC,EXT)
 Call SET_FICNAM(FICHIER,FICDON,URL) From ORDSYS
Else
 FICDON = filpath(CHEMIN,NOMFIC,EXT,"","",MACHINE)
 If filinfo(FICDON,7)>0
  ## Fichier existant, souhaitez-vous l'écraser ?
  Call OUINON(mess(127,105,1), OK) From GESECRAN
  If OK=1 : Return : Endif
 Endif
Endif

Openo FICDON,0
Openo

Openo FICDON Using [FIL]

## Exportation IES Portugal
Call OUVRE_TRACE("Export IES file"-mess(7,201,1)) From LECFIC
#

#Feed Rosto Annex of IES File
Gosub ALIM_ROSTO

#New version of IES file
Call ECR_TRACE("Filling the Face Annex of IES File",0) From GESECRAN : # Compte
#

Local Char CAB1(250) : CAB1=''
Local Char CAB2(250) : CAB2=''
Local Char CAB3(250) : CAB3=''

#CAB1='<IES-DA ano="'+ ANO +'" nif="'+NID+'" nif-representante="'+NIFRL+'" nif-toc="'+NIFTOC+'" versao="5" '
#CAB2='xmlns="http://www.portaldasfinancas.gov.pt/de/schema/IES-DA/2012" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.portaldasfinancas.gov.pt/de/schem'
#CAB3='a/IES-DA/2012 IES-DA.xsd">'
CAB1='<IES-DA xmlns="http://www.portaldasfinancas.gov.pt/de/schema/IES-DA/2015" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.portaldasfinancas.gov.pt/de/schem'
&  + 'a/IES-DA/2015 IES-DA.xsd" '
CAB2='ano="'+ ANO +'" nif="'+NID+'" nif-representante="'+NIFRL+'" nif-toc="'+NIFTOC+'" versao="6" >'

#New version of IES file
#Openo FICDON,-1
#

Wrseq "<?xml version='1.0' encoding='ISO-8859-1'?>" + chr$(13) + chr$(10)  Using [FIL]
#Wrseq CAB1+CAB2+CAB3 #Using [FIL]
Wrseq CAB1+CAB2 Using [FIL]

##-----------------------------------------Rosto Annex-----------------------------------------------##
Wrseq '<Rosto>' Using [FIL]
TAGNAM = 'Q01-1-inicio'                     : TAGVAL = DATDEB       : Gosub WRITETAG
TAGNAM = 'Q01-1-fim'                        : TAGVAL = DATFIN       : Gosub WRITETAG
TAGNAM = 'Q01-ano'                          : TAGVAL = ANO          : Gosub WRITETAG
TAGNAM = 'Q02-codSF'                        : TAGVAL = COD          : Gosub WRITETAG
TAGNAM = 'Q03-nif'                          : TAGVAL = NID          : Gosub WRITETAG
TAGNAM = 'Q04-1'                            : TAGVAL = CAE          : Gosub WRITETAG
TAGNAM = 'Q04-2'                            : TAGVAL = "100"        : Gosub WRITETAG
TAGNAM = 'Q04-4'                            : TAGVAL = num$(NESTAB) : Gosub WRITETAG
TAGNAM = 'Q07-opcao'                        : TAGVAL = "1"          : Gosub WRITETAG
TAGNAM = 'Q08-1'                            : TAGVAL = "01"         : Gosub WRITETAG
TAGNAM = 'Q09-nif-representante-legal'      : TAGVAL = NIFRL        : Gosub WRITETAG
TAGNAM = 'Q09-nif-toc'                      : TAGVAL = NIFTOC       : Gosub WRITETAG
Wrseq '</Rosto>' Using [FIL]

##----------------------------------------Annex A----------------------------------------------##
ANEXO = "A"
For LINE = 0 To [M:DIA]NBLIG-1
  If [M:DIA]VERSION(LINE) <> ""
    If TEMANEXA = 0 : Gosub ABREANEXA : Endif
    QUADRO  = [M:DIA]TXSNAM(LINE)
    VERSION = [M:DIA]VERSION(LINE)
    Gosub ALIM_AQVAR    From FUNIESGNRA
    Case [M:DIA]TXSNAM(LINE)
      When "03A"    Gosub WRIT_AQ03A    From FUNIESGNRA
      When "04A"
        Gosub WRIT_AQ04A    From FUNIESGNRA
        Gosub ALIM_AQ04B    From FUNIESGNRB
        Gosub WRIT_AQ04B    From FUNIESGNRB
        If [M:DIA]NUMRPT <> 0
          If TEMANEXA = 0 : Gosub ABREANEXA : Endif
          Gosub ALIM_AQ04C    From FUNIESGNRB
          Gosub WRIT_AQ04C    From FUNIESGNRB
        Endif
      When "05041A" Gosub WRIT_AQ05041  From FUNIESGNRA
      When "05071A" Gosub WRIT_AQ05071  From FUNIESGNRA
      When "05081A" Gosub WRIT_AQ05081  From FUNIESGNRA
      When "05121A" Gosub WRIT_AQ05121  From FUNIESGNRA
      When "0516A"  Gosub WRIT_AQ0516   From FUNIESGNRA
      When "05191A" Gosub WRIT_AQ05191  From FUNIESGNRA
      When "05192A" Gosub WRIT_AQ05192  From FUNIESGNRA
      When "0522A"  Gosub WRIT_AQ0522   From FUNIESGNRA
      When "05241A" Gosub WRIT_AQ05241  From FUNIESGNRA
      When "0526A"  Gosub WRIT_AQ0526   From FUNIESGNRA
      When "05281A" Gosub WRIT_AQ05281  From FUNIESGNRA
      When "05283A" Gosub WRIT_AQ05283  From FUNIESGNRA
      When "05284A" Gosub WRIT_AQ05284  From FUNIESGNRA
      When "05292A"
        Gosub WRIT_AQ05292  From FUNIESGNRA
        Gosub WRIT_AQ0530   From FUNIESGNRA
      #When "0531A"  Gosub WRIT_AQ0531   From FUNIESGNRA
      When "061A"   Gosub WRIT_AQ061    From FUNIESGNRA
      When Default
    Endcase
    #New version of IES file
    Call ECR_TRACE("Generating "-[M:DIA]TXSNAM(LINE),0) From GESECRAN : # Compte
    #
  Endif
Next

If TEMANEXA = 1 : Gosub FECHANEXA : Endif
##----------------------------------------Annex L----------------------------------------------##

Q=0

If [M:DIA]DCLNUM = "" : Goto FIMIVA : Endif

If [F:DVPH]DCLNUM <> [M:DIA]DCLNUM
    Call MESSAGE(mess(59,7711,1)) From GESECRAN # Error - Annual VAT.
    Return
Endif

#New version of IES file
#Openo FICDON,-1
#

Wrseq '<AnexoL>' Using [FIL] #ANNEX L

For Q = 3 To 9
  Case Q
    When 3
      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=1)
        Case [F:DVPF]DCLFLD
          When "001", "002", "003", "004", "005", "006", "007", "008", "009", "010", "011", "012", "013", "014",
&              "015", "016", "017", "018", "019","064","065","066","067","068"
             TAGNAM ='Q03-L'+right$([F:DVPF]DCLFLD,2)
             TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
             Gosub WRITETAG
          #END Annex L - Quadro 3 do IES
        Endcase
      Next
    When 4
      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=1)
        Case [F:DVPF]DCLFLD
          When "020", "021", "022", "023", "024", "025", "026", "027", "028", "029", "030", "031", "032",
&              "033", "034", "035", "036", "069", "070", "071", "072", "073", "074", "075", "076", "077", "078", "079"
             TAGNAM ='Q04-L'+right$([F:DVPF]DCLFLD,2)
             TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
             Gosub WRITETAG
          #END Annex L - Quadro 4 do IES
        Endcase
      Next
    When 5
      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=1)
        Case [F:DVPF]DCLFLD
          When "037", "038", "039", "040", "041", "042", "043", "044"
             TAGNAM ='Q05-L'+right$([F:DVPF]DCLFLD,2)
             TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
             Gosub WRITETAG
          #END Annex L - Quadro 5 do IES
        Endcase
      Next
    When 6
      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=1)
        Case [F:DVPF]DCLFLD
          When "045", "046", "047", "048", "049", "050", "051", "052", "053", "054", "055", "056"
             TAGNAM ='Q06-L'+right$([F:DVPF]DCLFLD,2)
             TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
             Gosub WRITETAG
          #END Annex L - Quadro 6 do IES
        Endcase
      Next
    When 7
#      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=1)
#        Case [F:DVPF]DCLFLD
#          When "057","058","059"
#             If [F:DVPF]AMT<>0
#               Wrseq '<Q07-opcao>1</Q07-opcao>' Using [FIL]
#               TAGNAM ='Q07-L'+right$([F:DVPF]DCLFLD,2)
#               TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
#               Gosub WRITETAG
#             Else
               Wrseq '<Q07-opcao>0</Q07-opcao>' Using [FIL]
#             Endif
          #END Annex L - Quadro 7 do IES
#        Endcase
#      Next
    When 8
      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=1)
        Case [F:DVPF]DCLFLD
          When "060"
               TAGNAM ='Q08-L'+right$([F:DVPF]DCLFLD,2)
               TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
               Gosub WRITETAG
          #END Annex L - Quadro 8 do IES
        Endcase
      Next
    When 9
      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=1)
        Case [F:DVPF]DCLFLD
          When "061", "062", "063"
               TAGNAM ='Q09-L'+right$([F:DVPF]DCLFLD,2)
               TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
               Gosub WRITETAG
          #END Annex L - Quadro 9 do IES
        Endcase
      Next
    When Default
  Endcase
  #New version of IES file
  Call ECR_TRACE("Generating Annex L"-num$(Q),0) From GESECRAN : # Compte
  #
Next

#New version of IES file
#Openo FICDON,-1
#
Wrseq '</AnexoL>' Using [FIL]
##----------------------------------------1º Annex M----------------------------------------------##

Q=0

Read [F:DVPP]DVPP0=[M:DIA]CPY;val(ANO)
If fstat : Goto FIM1ANEXOM : Endif
If [F:DVPP]AN1LOC<1 | [F:DVPP]AN1LOC>3 : Goto FIM1ANEXOM : Endif

Wrseq '<AnexoM id="'+num$([F:DVPP]AN1LOC)+'">' Using [FIL]          #1º ANNEX M
Wrseq '<Q03-opcao>'+num$([F:DVPP]AN1LOC)+'</Q03-opcao>' Using [FIL] #1º ANNEX M

For Q = 4 To 8
  Case Q
    When 4
      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=2)
        Case [F:DVPF]DCLFLD
          When "001", "002", "003", "004", "005", "006", "007", "008", "009", "010", "011", "012", "013", "014",
&              "015", "016", "017", "018", "019", "059", "060", "061", "062", "063"
             TAGNAM ='Q04-M'+right$([F:DVPF]DCLFLD,2)
             TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
             Gosub WRITETAG
          #END 1º Anexo M - Quadro 4 do IES
        Endcase
      Next
    When 5
      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=2)
        Case [F:DVPF]DCLFLD
          When "020", "021", "022", "023", "024", "025", "026", "027", "028", "029", "030", "031", "032", "033",
&              "034", "035", "036", "065", "066", "067", "068", "069", "070", "071", "072", "073", "074", "075"
             TAGNAM ='Q05-M'+right$([F:DVPF]DCLFLD,2)
             TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
             Gosub WRITETAG
          #END 1º Anexo M - Quadro 5 do IES
        Endcase
      Next
    When 6
      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=2)
        Case [F:DVPF]DCLFLD
          When "037", "038", "039", "040", "041", "042", "043", "044"
             TAGNAM ='Q06-M'+right$([F:DVPF]DCLFLD,2)
             TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
             Gosub WRITETAG
          #END 1º Anexo M - Quadro 6 do IES
        Endcase
      Next
    When 7
      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=2)
        Case [F:DVPF]DCLFLD
          When "045", "046", "047", "048", "049", "050", "051", "052", "053", "054", "055", "056"
             TAGNAM ='Q07-M' + right$([F:DVPF]DCLFLD,2)
             TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
             Gosub WRITETAG
          #END 1º Anexo M - Quadro 7 do IES
        Endcase
      Next
    When 8
#      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=2)
#        Case [F:DVPF]DCLFLD
#          When "057","058","059"
#             #If [F:XIA]ZVALORM(56) <> 0 | [F:XIA]ZVALORM(57) <> 0 | [F:XIA]ZVALORM(58) <> 0
#             If [F:DVPF]AMT <> 0
#               Wrseq '<Q08-1-2>1</Q08-1-2>' Using [FIL]
#               TAGNAM ='Q0'+'8'+ '-'+[F:DVPF]DCLFLD
#               TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
#               Gosub WRITETAG
#             Else
               Wrseq '<Q08-1-2>0</Q08-1-2>' Using [FIL]
#             Endif
          #END 1º Anexo M - Quadro 8 do IES
#        Endcase
#      Next
    When Default
  Endcase
  #New version of IES file
  Call ECR_TRACE("Generating Annex 1º M"-num$(Q),0) From GESECRAN : # Compte
  #
Next

Wrseq '</AnexoM>' Using [FIL]

$FIM1ANEXOM

##----------------------------------------2º Anexo M----------------------------------------------##

Q=0

Read [F:DVPP]DVPP0=[M:DIA]CPY;val(ANO)
If fstat : Goto FIM2ANEXOM : Endif
If [F:DVPP]AN2LOC<1 | [F:DVPP]AN2LOC>3 : Goto FIM2ANEXOM : Endif

Wrseq '<AnexoM id="'+num$([F:DVPP]AN2LOC)+'">' Using [FIL]          #2º ANNEX M
Wrseq '<Q03-opcao>'+num$([F:DVPP]AN2LOC)+'</Q03-opcao>' Using [FIL] #2º ANNEX M

For Q = 4 To 8
  Case Q
    When 4
      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=3)
        Case [F:DVPF]DCLFLD
          When "001", "002", "003", "004", "005", "006", "007", "008", "009", "010", "011", "012", "013", "014",
&              "015", "016", "017", "018", "019", "059", "060", "061", "062", "063"
             TAGNAM ='Q04-M'+right$([F:DVPF]DCLFLD,2)
             TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
             Gosub WRITETAG
        Endcase
      Next
    When 5
      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=3)
        Case [F:DVPF]DCLFLD
          When "020", "021", "022", "023", "024", "025", "026", "027", "028", "029", "030", "031", "032", "033",
&              "034", "035", "036", "065", "066", "067", "068", "069", "070", "071", "072", "073", "074", "075"
             TAGNAM ='Q05-M'+right$([F:DVPF]DCLFLD,2)
             TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
             Gosub WRITETAG
        Endcase
      Next
    When 6
      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=3)
        Case [F:DVPF]DCLFLD
          When "037", "038", "039", "040", "041", "042", "043", "044"
             TAGNAM ='Q06-M'+right$([F:DVPF]DCLFLD,2)
             TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
             Gosub WRITETAG
        Endcase
      Next
    When 7
      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=3)
        Case [F:DVPF]DCLFLD
          When "045", "046", "047", "048", "049", "050", "051", "052", "053", "054", "055", "056"
             TAGNAM ='Q07-M'+right$([F:DVPF]DCLFLD,2)
             TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
             Gosub WRITETAG
          Endcase
      Next
    When 8
#      For [F:DVPF] Where ([F:DVPF]DCLNUM=[F:DVPH]DCLNUM and [F:DVPF]DCLPAG=3)
#        Case [F:DVPF]DCLFLD
#          When "057", "058", "059"
#             If [F:DVPF]AMT <> 0
#               Wrseq '<Q08-1-2>1</Q08-1-2>' Using [FIL]
#               TAGNAM ='Q0'+'8'+ '-'+[F:DVPF]DCLFLD
#               TAGVAL = ctrans(vireblc(format$("N:20.2", ar2(abs([F:DVPF]AMT))),2), ",", ".")
#               Gosub WRITETAG
#             Else
               Wrseq '<Q08-1-2>0</Q08-1-2>' Using [FIL]
#             Endif
#        Endcase
#      Next
    When Default
  Endcase
  #New version of IES file
  Call ECR_TRACE("Generating Annex 2º M"-num$(Q),0) From GESECRAN : # Compte
  #
Next

Wrseq '</AnexoM>' Using [FIL]

$FIM2ANEXOM
##----------------------------------------Anexo O----------------------------------------------##

If [F:DVPH]BPCFLG=2 #ANNEX 0
    Wrseq '<AnexoO>'    Using [FIL]
    Wrseq '<Q03-lista>' Using [FIL]

    Local Double  SOMACLT   : SOMACLT   = 0
    Local Integer NIF       : NIF       = 0
    Local Double  SOMALINHA : SOMALINHA = 0

    #Filter [F:XAZ] Where [F:XAZ]ZID=[M:DIA]DCLNUM & [F:XAZ]MTC = "C" & [F:XAZ]TOTAMTVAT>=[F:XIA]ZVALMIN #RM * 10-07-2012 * não estavamos a tomar em consideração os montantes mínimos
    Filter [F:DVPL] Where [F:DVPL]DCLNUM=[M:DIA]DCLNUM & [F:DVPL]LINTYP = 21 #& [F:DVPL]AMTVAT>=[F:XIA]ZVALMIN #RM * 10-07-2012 * não estavamos a tomar em consideração os montantes mínimos

    For [DVPL]

        NIF       = val(ctrans([F:DVPL]EECNUM,'PT',''))
        SOMALINHA = fix([F:DVPL]AMTBAS)

        If SOMALINHA<>0
            Wrseq '<Q03-linha>' Using [FIL]
            TAGNAM   = 'Q03-1'                     : TAGVAL =num$(NIF)        : Gosub WRITETAG
            TAGNAM   = 'Q03-2'                     : TAGVAL =num$(SOMALINHA)  : Gosub WRITETAG
            SOMACLT += SOMALINHA
            Wrseq '</Q03-linha>' Using [FIL]
        Endif

    Next

    Filter [F:DVPL]

    Wrseq '</Q03-lista>' Using [FIL]

    TAGNAM = 'Q03-soma'                     : TAGVAL =num$(SOMACLT)     : Gosub WRITETAG

    Wrseq '</AnexoO>'    Using [FIL]

  #New version of IES file
  Call ECR_TRACE("Generating Annex O",0) From GESECRAN : # Compte
  #
Endif

##----------------------------------------Anexo P----------------------------------------------##

If [F:DVPH]BPSFLG=2 #ANNEX P
    Wrseq '<AnexoP>'    Using [FIL]
    Wrseq '<Q03-lista>' Using [FIL]

    Local Double  SOMAFOR    : SOMAFOR    = 0
    Local Integer NIFF       : NIFF       = 0
    Local Double  SOMALINHAF : SOMALINHAF = 0

    #Filter [F:XAZ] Where [F:XAZ]ZID=[M:DIA]DCLNUM & [F:XAZ]MTC = "F" & [F:XAZ]TOTAMTVAT>=[F:XIA]ZVALMIN #RM * 10-07-2012 * não estavamos a tomar em consideração os montantes mínimos
    #Filter [F:DVPL] Where [F:DVPL]DCLNUM=[M:DIA]DCLNUM & [F:DVPL]LINTYP = 22 #& [F:XAZ]TOTAMTVAT>=[F:XIA]ZVALMIN #RM * 10-07-2012 * não estavamos a tomar em consideração os montantes mínimos
    For [DVPL] Where [F:DVPL]DCLNUM=[M:DIA]DCLNUM & [F:DVPL]LINTYP = 22

        NIFF       = val(ctrans([F:DVPL]EECNUM,'PT',''))
        SOMALINHAF = fix([F:DVPL]AMTBAS)

        If SOMALINHAF<>0
            Wrseq '<Q03-linha>'  Using [FIL]
            TAGNAM   = 'Q03-1'                     : TAGVAL =num$(NIFF )       : Gosub WRITETAG
            TAGNAM   = 'Q03-2'                     : TAGVAL =num$(SOMALINHAF)  : Gosub WRITETAG
            SOMAFOR += SOMALINHAF
            Wrseq '</Q03-linha>' Using [FIL]
        Endif

    Next

    Filter [F:DVPL]

    Wrseq '</Q03-lista>' Using [FIL]

    TAGNAM = 'Q03-soma'                          : TAGVAL =num$(SOMAFOR)     : Gosub WRITETAG

    Wrseq '</AnexoP>'    Using [FIL]

  #New version of IES file
  Call ECR_TRACE("Generating Annex P",0) From GESECRAN : # Compte
  #
Endif

$FIMIVA
##----------------------------------------Anexo R----------------------------------------------##
ANEXO = "R"

Local Integer FCYPOR, FCYNOTPOR

For [F:FCY] Where [F:FCY]LEGCPY = [M:DIA]CPY & [F:FCY]FINFLG = 2
  If [F:FCY]CRY = 'PT'
    FCYPOR    += 1
  Else
    FCYNOTPOR += 1
  Endif
Next

Wrseq '<AnexoRSNC>' Using [FIL]
If [L]FCYPOR > 0
  Wrseq '<Q03-1>'+ num$([L]FCYPOR)    +'</Q03-1>' Using [FIL]
Elsif [L]FCYNOTPOR > 0
  Wrseq '<Q03-2>'+ num$([L]FCYNOTPOR) +'</Q03-2>' Using [FIL]
Endif

Wrseq '<Q04A-lista>' Using [FIL]

QUADRO = "ANEXOR"

For LINE = 0 To [M:DIA]NBLIG1-1
  Read [F:FCY]FCY0 = [M:DIA]FCY(LINE)
  If !fstat
    Wrseq '<Q04A-linha>'                        Using [FIL]
    Gosub WRIT_FCY From FUNIESGNRA
    If [M:DIA]NUMR04A(LINE) <> ""
      VERSION = [M:DIA]NUMR04A(LINE)
      Gosub ALIM_AQVAR    From FUNIESGNRA
      Gosub WRIT_RQ04A    From FUNIESGNRA
    Endif
    Wrseq '</Q04A-linha>'                       Using [FIL]
  Endif
Next

Wrseq '</Q04A-lista>'   Using [FIL]

Wrseq '</AnexoRSNC>'    Using [FIL]

#New version of IES file
Call ECR_TRACE("Generating Annex R",0) From GESECRAN : # Compte
#

##-----------------------------------------CLOSE-----------------------------------------------##

Wrseq '</IES-DA>' Using [FIL]

#New version of IES File
Openo Using [FIL]

If [M]TYPEXP=1
 Call COPCLI(FICDON,FICHIER,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  Call ERREUR(mess(164,141,1)) From GESECRAN
  FIN=1 : TRA=0
 Elsif STAT>1
  # Fichier inexistant
  Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  FIN=1 : TRA=0
 Endif
Endif

Call FERME_TRACE From LECFIC

adxifs = SAVADXIFS
adxirs = SAVADXIRS
#
Return
#############################################################################################
#############################################################################################
$ALIM_ROSTO

Read [F:CPY]CPY0 = [M:DIA]CPY

ANO    = num$(year([M:DIA]FIYSTR))
SOC    = [M:DIA]CPY
[L]DATDEB = format$("D:YYYY[-]MM[-]DD",[M:DIA]FIYSTR)
[L]DATFIN = format$("D:YYYY[-]MM[-]DD",[M:DIA]FIYEND)
NID    = [F:CPY]NID
If NID = ""
  NID    = [F:CPY]EECNUM
  If left$(NID,2) = "PT" : NID = ctrans(NID,"PT","") : Endif
Endif
COD    = num$([F:CPY]PORFINDPR)
CAE    = format$("N0:5",[F:CPY]PORCPYACT)
NIFRL  = [F:CPY]PORLRC
NIFTOC = [F:CPY]PORCTFACN

If left$(NID,2)='PT'
  NID=right$(NID,3)
Endif

If NIFRL =""
   NIFRL="0"
Endif

If NIFTOC =""
   NIFTOC="0"
Endif

If NID<>"0"
  If left$(NID,1)="0"
    While left$(NID,1)="0"
      NID=right$(NID,2)
    Wend
  Endif
Endif

If NIFTOC<>"0"
  If left$(NIFTOC,1)="0"
    While left$(NIFTOC,1)="0"
      NIFTOC=right$(NIFTOC,2)
    Wend
  Endif
Endif

If NIFRL<>"0"
  If left$(NIFRL,1)="0"
    While left$(NIFRL,1)="0"
      NIFRL=right$(NIFRL,2)
    Wend
  Endif
Endif

NESTAB = 0
Filter [F:FCY] Where [F:FCY]LEGCPY=SOC
For [F:FCY]
    NESTAB+=1
Next

Return
############################################################################################
############################################################################################
$WRITETAG

AMPIND = 0
While instr(AMPIND,TAGVAL,"&")>0
  AMPIND  = instr(AMPIND,TAGVAL,"&")
  TAGVAL  = left$(TAGVAL,AMPIND-1) + "&amp;" + right$(TAGVAL,AMPIND+1)
  AMPIND +=1
Wend

AMPIND = 0
While instr(AMPIND,TAGVAL,"<")>0
  AMPIND  = instr(AMPIND,TAGVAL,"<")
  TAGVAL  = left$(TAGVAL,AMPIND-1) + "&lt;" + right$(TAGVAL,AMPIND+1)
  AMPIND +=1
Wend

AMPIND = 0
While instr(AMPIND,TAGVAL,">")>0
  AMPIND  = instr(AMPIND,TAGVAL,">")
  TAGVAL  = left$(TAGVAL,AMPIND-1) + "&gt;" + right$(TAGVAL,AMPIND+1)
  AMPIND +=1
Wend

AMPIND = 0
While instr(AMPIND,TAGVAL,'"')>0
  AMPIND  = instr(AMPIND,TAGVAL,'"')
  TAGVAL  = left$(TAGVAL,AMPIND-1) + "&quot;" + right$(TAGVAL,AMPIND+1)
  AMPIND +=1
Wend

AMPIND = 0
While instr(AMPIND,TAGVAL,"'")>0
  AMPIND  = instr(AMPIND,TAGVAL,"'")
  TAGVAL  = left$(TAGVAL,AMPIND-1) + "&#39;" + right$(TAGVAL,AMPIND+1)
  AMPIND +=1
Wend

If(TAGVAL <>"0.00")
    #New version of IES file
    #Openo FICDON,-1
    #
    Wrseq '<' + TAGNAM + '>' + TAGVAL + '</' + TAGNAM + '>' Using [FIL]
Endif

Return
#############################################################################################
#############################################################################################
$ABREANEXA

#New version of IES file
#Openo FICDON,-1
#

Wrseq '<AnexoASNC id="NIC">'       Using [FIL]
Wrseq "<Q02A-opcao>"+ num$([M:DIA]ACCTYP) +"</Q02A-opcao>" Using [FIL]
TEMANEXA = 1

Return
#############################################################################################
#############################################################################################
$FECHANEXA

#New version of IES file
#Openo FICDON,-1
#

Wrseq '</AnexoASNC>' Using [FIL]

Return
#############################################################################################
#############################################################################################
$OPEN_FILE

Local Char FILEPATHTMP(GDIMFIC)

Onerrgo $ERROR
#opening file to write to (on temporary folder)
[L]FILEPATHTMP = filpath('tmp','IES_'+[M:DIA]CPY+"_"+format$("D:DDMMYYYYhhmmss", date$),'xml')

#empty file if exists
Openo [L]FILEPATHTMP,0              #Using [FIL]

Iomode adxirs chr$(13) + chr$(10)   #Using [FIL]
Iomode adxifs ''                    #Using [FIL]
Iomode adxium 50                    #Using [FIL]

Onerrgo

Return
#################################################################################################
#################################################################################################
$ERROR

GMESSAGE = mess(93,100,1)- num$(errl) - "("+errp+"):" - errmes$(errn)+"\"+errm
OK = 0

Resume
#################################################################################################
#################################################################################################
$CLOSE_FILE

Openo Using [FIL]

If [M:DIA]TYPEXP=1 : # Client

  # Check that de file to copy is existing
  If filinfo([L]FILEPATHTMP, 7) < 0 Then
    GMESSAGE = mess(4,95,1) - [L]FILEPATHTMP - tolower(mess(87,100,1))
    GERR = 1
    Return
  Else
    [M:DIA]NOIMP = "IES_" + [M:DIA]CPY + '_' + format$("D:DDMMYYYY",[M:DIA]FIYSTR) + '_' + format$("D:DDMMYYYY",[M:DIA]FIYEND) + ".XML"
    Call COPCLI([L]FILEPATHTMP, [M:DIA]NOIMP, [L]STAT) From ORDSYS
    If [L]STAT=1
      Call ERREUR(mess(164,141,1)) From GESECRAN
    Elsif [L]STAT>1
      Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
    Endif
  Endif

Else
  Call MOVE([L]FILEPATHTMP, [M:DIA]NOIMP, [L]STAT) From ORDSYS
  If [L]STAT : Call ERREUR (mess(23,7711,1) + " ("+num$([L]STAT)+")") From GESECRAN : Endif
Endif

Return
