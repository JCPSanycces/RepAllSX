# Classe BPSUPPLIER
#######################################################################################
End

#######################################################################################
$AREAD_AFTER
Local Integer IRET

  IRET = fmet this.INIT_TSSCODADI()
Return

#######################################################################################
$AINIT
Local Integer IRET

  IRET = fmet this.INIT_TSSCODADI()
Return

#######################################################################################
$INIT_TSSCODADI
Local Integer DIM_STS
Local Integer NI

  DIM_STC = func ASYRFNC.ACTIV("STS")
  # -------------------
  For NI = 1 To DIM_STS
    this.C_TSCCOD(NI).TSSCODADI = NI + 40
  Next NI
  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
Return

