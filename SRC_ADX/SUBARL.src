#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion du fichier AROLE
Call OBJET("ARL",GBIDC1,GBIDC2) From GOBJET
End

#######################################################
$ACTION
Case ACTION
 When "SETBOUT"    : Gosub SETBOUT
 When "LIENS2"     : Gosub LIENS
 When "APRES_CRE"  : Call INIROLE From GLOBSUP
 When "APRES_MOD"  : Call INIROLE From GLOBSUP
 When "AP_ANNULE"  : Call INIROLE From GLOBSUP
Endcase
Return

$LIENS
For I=0 To [M]NBLIG-1
 Read [AOB]ABREV = [M]OBJ(I)
 [M]NOMFIC(I) = [F:AOB]NOMFIC
Next I
Return

$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
Return

########################################################
$TRTCOP
# Copie de la table des rôles
If [M]DOSORG=nomap                            # Fichier source
 Local File AROLE [ARL1]
Else
 Local File =[M]DOSORG+".AROLE" [ARL1]
Endif
If [M]DOSDES=nomap                           # Fichier destination
 Local File AROLE [ARL2]
Else
 Local File =[M]DOSDES+".AROLE" [ARL2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ARL1], [ARL2]
Return

$TR_COP
GOK = 1
Trbegin [ARL2]
 Delete [ARL2] Where 1=1
 If fstat=1
  GOK = -1 : GLOCK="$AROLE" : Goto ROLL_TR_COP
 Endif
 For [ARL1]ARL0
  [F:ARL2] = [F:ARL1]
  Write [ARL2]
  If fstat
   GOK = 0 : Call FSTA("ARL2") From GLOCK : Goto AB_TR_COP
  Endif
 Next
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

########################################
Subprog C_OBJ(VALEUR)
Variable Char    VALEUR()
Call LECTURE("AOB",VALEUR,"") From CONTOBJ
[M]NOMFIC(nolign-1) = [F:AOB]NOMFIC
End

Subprog C_FLD(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
Local Integer K , DIME , DIMMAX
Local Char    ZONE(20)
K = instr(1,VALEUR,"(")
If K
 DIME = val(right$(VALEUR,K+1))
 ZONE = left$(VALEUR,K-1)
Else
 DIME = 0
 ZONE = VALEUR
Endif
Read [ATZ]CODZONE = [M]NOMFIC(nolign-1);ZONE
If fstat
 GMESSAGE = mess(9,124,1) : # Champ inexistant
 mkstat = 2 : End
Endif
If [F:ATZ]CODACT<>""
 Read [ACV]CODACT = [F:ATZ]CODACT
 If !fstat & ([F:ACV]DIMFIL>0 or [F:ACV]DIME>0)
  DIMMAX = max([F:ACV]DIMFIL,[F:ACV]DIME)
 Else
  DIMMAX = 1
 Endif
Else
 DIMMAX = [F:ATZ]DIME
Endif
If DIME>DIMMAX-1
 GMESSAGE = mess(46,105,1) : # Indice incorrect
 mkstat = 2 : End
Endif
Read [ATY]CODTYP = [F:ATZ]CODTYP
If [F:ATY]TYPTYP>7 or find([F:ATY]CODTYP,"ATX","AXX","AX1","AX2","AX3")>0 : # mb 14.2.2 demande 13363 Gestion des champs numériques, interdiction AXX
 GERR = 1 : GMESSAGE = mess(10,124,1) : # Zone de type incorrect
 mkstat = 2 : End
Endif
VALEUR = ZONE
If DIME>0 | DIMMAX<>1
 VALEUR += "("+num$(DIME)+")"
Endif
End

#######################################################
## Vérification d'un rôle en saisie
#######################################################
Subprog CONT_ROLE(VALEUR,ABREV,CHAMP)
Variable Char     VALEUR()
Value    Char     ABREV
Value    Char     CHAMP
Local Integer I , K
Local Char WROL (15)  #X3-58117 (JUCON 15/11/17)
mkstat = 0
For I=1 To GNBROLUSR
 K = find(GROLUSR(I)-ABREV,GROLE(1..GNBROLE))
 WROL=GROLUSR(I)    #X3-58117 (JUCON 15/11/17)
 If K & GFLDROLE(K)=CHAMP
  If I=1 or GROLUSR(I)<>GROLUSR(I-1)
   mkstat = 1
   GMESSAGE = mess(198,126,1)-GROLUSR(I) : # Valeur interdite par le rôle
  Endif
  If VALEUR=GROLCLE(I) : mkstat = 0 : Endif
 Endif
Next I

# Ini X3-58117 (JUCON 15/11/17)
If GMESSAGE="" and GFONCTION="GESSIH"
  If !clalev([F:KTSV]): Local File TABSIVTYP [KTSV]: Endif # X3-105747 JUCON 28/08/18)
  Local Char  WCNTROLE(250)
  Call FILROLE("TSV",WCNTROLE)
  If WCNTROLE="" : WCNTROLE = "1=1" : Endif
  Filter [KTSV] Where [TSV]SIVTYP=VALEUR & evalue(WCNTROLE)
  If rowcount([KTSV])=0
    mkstat = 1
    GMESSAGE = mess(198,126,1)-WROL : # Valeur interdite par le rôle
  Endif
  Filter [KTSV]
Endif
# End X3-58117 (JUCON 15/11/17)
End

#################################################################
# Initialisation du filtre rôle (listes de gauche secondaires)
#################################################################
Subprog FILROLE(ABROL,FILROLE)
Value    Char ABROL
Variable Char FILROLE()()
Local Integer I, J , K , T, IFILROLE
Local Char    CHAINE(250)
If ABROL<>""
 Gosub NOMFIC From ="WO"+ABROL
Endif
I = 1
Raz FILROLE, IFILROLE
While I<=GNBROLUSR
 K = find(GROLUSR(I)-ABROL,GROLE(1..GNBROLE))
 If K
  T = evalue('type([F:'+ABFIC+']'+GFLDROLE(K)+')')
  If I<GNBROLUSR & GROLUSR(I+1)=GROLUSR(I)
   Call ADDCRIT(FILROLE,IFILROLE,"FILROLE",'find([F:'+ABFIC+']'+GFLDROLE(K),"&") From GOBJSUB
   If FILROLE="" : Break : Endif
   J = I
   While I<=GNBROLUSR & GROLUSR(I)=GROLUSR(J)
    CHAINE = GROLCLE(I)
    If left$(CHAINE,1)="="
     CHAINE = right$(CHAINE,2)
    Elsif !find(T,1,2,4,5,6,7,8)
     CHAINE = '"'+CHAINE+'"'
    Endif
    Call ADDCRIT(FILROLE,IFILROLE,"FILROLE",','+CHAINE,"") From GOBJSUB
    If FILROLE="" : Break 2 : Endif
    I += 1
   Wend
   Call ADDCRIT(FILROLE,IFILROLE,"FILROLE",")<>0","") From GOBJSUB
   If FILROLE="" : Break : Endif
  Else
   CHAINE = GROLCLE(I)
   If left$(CHAINE,1)="="
    CHAINE = right$(CHAINE,2)
   Elsif !find(T,1,2,4,5,6,7,8)
    CHAINE = '"'+CHAINE+'"'
   Endif
   Call ADDCRIT(FILROLE,IFILROLE,"FILROLE",'[F:'+ABFIC+']'+GFLDROLE(K)+'='+CHAINE,"&") From GOBJSUB
   If FILROLE="" : Break : Endif
   I += 1
  Endif
 Else
  I += 1
 Endif
Wend
If FILROLE="" : FILROLE = "1=1" : Endif
End

