$EMPLORIB_BNKSRTCOD_CONTROL
If len(this.BNKSRTCOD) <> 6
  ASTATUS = fmet this.ASETERROR([L]CURPRO,mess(00013,11800,1),[V]CST_AINFO)
Endif

Return


#FRLAA 2018-01-30 X3-74425 - START
$EMPLORIB_BNKACCNUM_CONTROL
#Mandatory check as field can be cleared on the basic class
If this.BNKACCNUM = AVOID.AINT
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(00010,00123,1),[V]CST_AERROR)
Endif
Return
#FRLAA 2018-01-30 X3-74425 - END

