#<AdxTL>@(#)4.0.0.0 $Revision$
#################################################################################
# GPAMAJ30 : Mises à jour à effectuer lors du passage à la v6     Module GPAO   #
# ----------------------------------------------------------------------------- #
# Avant mise à jour                                                             #
#    - DES2AXX   : Remplacement des champs DES par des intitulés traduisibles   #
#                                                                               #
#    - ROUOPESTD, table des opérations standard                                 #
#      Initialisation du champs tiers (BPRNUM)                                  # 
#    - ROUSCD,Table jalonnement opération de gammes                             # 
#        - initialisation de la zone site                                       # 
#    - BENCHTRS,Table des transactions de plans                                 #
#        - Initialisation des zones filtre                                      #
#        - Axes analytiques                                                     #
#    - PARJAL,TABLE DES PARAMETRES JALONNEMENT                                  #
#        - Initialisation AUTWIPSCD                                             #
#    - MFGTRS,Table des transactions                                            #
#        - Axes analytiques                                                     #
#    - WORKSTATIO, table des postes de charge                                   #
#      Initialisation des champs RPLAUTO et SBBFLG                              #  
#    - MFGCOST, Prix de revient de fabrication                                  # cf UUMGTRTGPA02
#      Initialisation du champ BOMALTTYP                                        #  
#      MFGNUM --> VCRNUM ; MFGLIN --> VCRLIN ; 10 --> VCRTYP                    #
#    - MFCNAT, Natures FG prix de revient de fabrication                        # cf UUMGTRTGPA02
#      MFGNUM --> VCRNUM ; MFGLIN --> VCRLIN ; 10 --> VCRTYP                    #
#    - MFGWIP, Valorisation encours                                             # cf UUMGTRTGPA01
#      Initialisation du champ BOMALTTYP                                        #
#    - MFGOPETRK :  Initialisation du champ IPTDAT et enr CPTANALIN             # cf UUMGTRTGPA04
#    - MFGITMTRK :  Initialisation enr CPTANALIN                                # cf UUMGTRTGPA04
#    - MFGMATTRK :  Initialisation enr CPTANALIN                                # cf UUMGTRTGPA04
#    - MFGMAT    :  Initialisation type de composant et enr CPTANALIN           # cf UUMGTRTGPA03
#    - MFGITM    :  Initialisation enr CPTANALIN                                # cf UUMGTRTGPA03
#    - MFGOPE    :  Initialisation enr CPTANALIN                                # cf UUMGTRTGPA03
#                                                                               #
# ----------------------------------------------------------------------------- #
# Après mise à jour                                                             #
#    - UPDPWA    :  Alimentation de la législation dans PARWIPACC               #
#    - UPDMFC    :  Changt de clé de MFC màj onglet sélection & RAZ dern lus    #
#    - UPDTMA    :  Initalisation ENAFLG dans les Matricules TABMAT             #
#################################################################################

#################################################################################
# Moulinette Avant mise à jour concernant le module GPAO                        #
#################################################################################
Subprog AGPAMAJ30
Local Integer  COMPTEUR, INDIC, STOP
Local Char     CLE1(50),CLE3(50),CLE6(50),CLE7(50),CRITERE(250)
Local Integer  CLE2, CLE4, CLE5
Local Integer  I

#---- Remplacement des désignation par des textes traduisibles ------#
Call ECR_TIME("AGPAMAJ30 : GP Transactions Process [DES --> AXX]") From DOSSUB
Call DES2AXX([F:ADS]DOSSIER)

# CCC (2009-04-21) Bug 54027 : Les sections analytiques des sections de valorisations n'étaient pas mises à jour
$MWC
#-------------------------------------------------------------------------------#
#  WORKCOST, table des sections de valorisation                                 #
#  Initialisation des sections analytiques                                      #
#-------------------------------------------------------------------------------#

Call ECR_TIME("AGPAMAJ30 : Costing dimension (WORKCOST) Process") From DOSSUB

Local File =[F:ADS]DOSSIER+".WORKCOST"    [MWC]
Local File =[F:ADS]DOSSIER+".CADIEDEF"    [CDI]
Local Integer NBENR
Raz NBENR

Raz CLE1, CLE3

Read [CDI]CDI0=16
If fstat
    Call ECR_TRACE("File CADIEDEF obj=16, Error ="-num$(fstat),1) From GESECRAN
Else
    $BOUCLE_MWC
    
    If STOP=1
      CRITERE = 'VLTCCE="'+CLE1+'" & VLTFCY>"'+CLE3+'"'
      STOP += 1 
    Elsif STOP=2
      CRITERE = 'VLTCCE>"'+CLE1+'"'
      STOP = 0
    Else
      CRITERE = "1=1"
    Endif
    
    Raz COMPTEUR
    Trbegin [MWC]
    For [MWC]WCT0 Where evalue(CRITERE)
        #Readlock [MWC]WCT0=[F:MWC]VLTCCE;[F:MWC]VLTFCY  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
        #If !fstat
            For I=0 To [F:CDI]NBRDIE-1
                If [F:MWC]DIE(I)=""
                    [F:MWC]DIE(I)=[F:CDI]DIE(I)
                Endif
                If dim([F:MWC]DIE)<=I : Break : Endif
            Next
            Rewrite [MWC]
            NBENR+=1
            If fstat
                Call ECR_TRACE("File WORKCOST, Error ="-num$(fstat),1) From GESECRAN
            Else
                COMPTEUR += 1
                If COMPTEUR > GMAXUPDTRS
                    CLE1=[F:MWC]VLTCCE
                    CLE3=[F:MWC]VLTFCY
                    STOP=1
                    Break
                Endif
            Endif
        #Endif
    Next
    
    Commit
    If STOP : Goto BOUCLE_MWC : Endif
Endif

Call ECR_TRACE("DOSMAJ30 : Processed records number :"-num$(NBENR),0) From GESECRAN

Close Local File [MWC]
Close Local File [CDI]

$ROT
#-------------------------------------------------------------------------------#
#  ROUOPESTD, table des opérations standard                                     #
#  Initialisation de BPRNUM(=BPSNUM)                                            #
#-------------------------------------------------------------------------------#
If filinfo (filpath ("FIL", "ROUOPESTD"    , "fde",[F:ADS]DOSSIER ) ,0) < 0: End : Endif

Local File =[F:ADS]DOSSIER+".ROUOPESTD" [ROT]

Call ECR_TIME("AGPAMAJ30 : Standard Operations Process") From DOSSUB

Raz CLE1, CLE2 , CLE4, CLE5 , STOP
$BOUCLE_ROT
If STOP=1
   STOP=2 : CRITERE='FCY="'+CLE1+'"'+'& STDOPENUM>'+ num$(CLE2)
Elsif STOP=2
   STOP =0 :CRITERE='FCY>"'+CLE1+'"'
Else
   CRITERE="1=1"
Endif

Raz COMPTEUR
Trbegin [ROT]

For [ROT]ROT0 Where evalue (CRITERE)
    #Readlock [ROT] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat
    #    Call ECR_TRACE("File ROUOPESTD, Error="-num$(fstat),1) From GESECRAN
    #Else
        If dim([F:ROT]BPSNUM) > 0
            If [F:ROT]BPSNUM <>"" & [F:ROT]BPRNUM ="" : [F:ROT]BPRNUM =[F:ROT]BPSNUM : Endif
        Endif
        Rewrite [F:ROT]
    #Endif
    COMPTEUR += 1
    If COMPTEUR >GMAXUPDTRS
        CLE1 = [F:ROT]FCY
        CLE2 = [F:ROT]STDOPENUM
        STOP =1
        Break
    Endif
Next
Commit

If STOP : Goto BOUCLE_ROT : Endif
Close Local File [ROT]

#$ROS
If filinfo (filpath ("FIL", "ROUTING", "fde",[F:ADS]DOSSIER ) ,0) < 0 : End : Endif
If filinfo (filpath ("FIL", "ROUSCD", "fde",[F:ADS]DOSSIER ) ,0) < 0  : End : Endif
#----------------------------------------------#
#  Initialisation site ROUSCD                  #
#----------------------------------------------#
Local File =[F:ADS]DOSSIER+".ROUTING" [ROH]
Local File =[F:ADS]DOSSIER+".ROUSCD"   [ROS]
Local File =[F:ADS]DOSSIER+".ROUSCD"   [ROS1]

Call ECR_TIME("AGPAMAJ30 : Operations Process") From DOSSUB

Raz CLE1, CLE2 , CLE3 , STOP
$BOUCLE_ROH
If STOP=1
   STOP=2 : CRITERE='FCY ="'+CLE1+'"'+'& ITMREF="'+CLE3+'"'+'& ROUALT>'+ num$(CLE2)
Elsif STOP=2
   STOP=3 : CRITERE='FCY ="'+CLE1+'"'+'& ITMREF>"'+CLE3 +'"'
Elsif STOP=3
   STOP=0 : CRITERE='FCY >"'+CLE1 +'"'
Else
   CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [ROS]
 #For [ROH] Where evalue (CRITERE) : # Issue 106321 - 2015-12-15 by GH : key for the loop must be ROH1
 For [ROH]ROH1 Where evalue (CRITERE)
    Update [F:ROS] Where ITMREF = [F:ROH]ITMREF & ROUALT = [F:ROH]ROUALT
&                  With  FCY = [F:ROH]FCY
    COMPTEUR += adxuprec
    If COMPTEUR >GMAXUPDTRS
        CLE1 = [F:ROH]FCY
        CLE3 = [F:ROH]ITMREF
        CLE2 = [F:ROH]ROUALT
        STOP =1
        Break
    Endif
 Next
Commit

If STOP : Goto BOUCLE_ROH : Endif
Filter [ROH]
Filter [ROS]
Close Local File [ROH]
Close Local File [ROS]
Close Local File [ROS1]


$BTS
#-------------------------------------------------#
# Initialisation plans travail     BENCHTRS       #
#-------------------------------------------------#
If filinfo (filpath ("FIL","BENCHTRS","fde",[F:ADS]DOSSIER),0)   < 0  : End : Endif
Local File =[F:ADS]DOSSIER+".BENCHTRS"   [BTS]
Local File =[F:ADS]DOSSIER+".DIETRS"     [DTR]
Local File =[F:ADS]DOSSIER+".GDIE"       [DIE]
Local Integer  WNBR, FLAG
Call ECR_TIME("AGPAMAJ30 : Planning Tools Process") From DOSSUB
Raz CLE1,CLE2
Raz WNBR

Trbegin [BTS]
CRITERE = "find(BTSTYP,60,61,62,63)"
For [BTS]BTS0 Where evalue(CRITERE)
    #Readlock [BTS] Curr      # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat
    #    Call ECR_TRACE("File BENCHTRS, Error ="-num$(fstat),1) From GESECRAN
    #Else
        If [F:BTS]BTSTYP = 60 & [F:BTS]MATFLTFLG = 0
                                [F:BTS]MATFLTFLG = 1                           
                                [F:BTS]ITMFLTFLG = 1                           
        Endif
        If [F:BTS]BTSTYP = 62 & [F:BTS]MATFLTFLG = 0
                                [F:BTS]MATFLTFLG = 1                           
        Endif
        #----- Alimentation nouvelle table pour axes analytiques -----#
        Look [DTR] DTR0="BTS";[F:BTS]BTSTYP;[F:BTS]BTSNUM;0;0
        If fstat
           Raz [F:DTR]
           [F:DTR]ABRFIC="BTS"
           [F:DTR]DTRTYP=[F:BTS]BTSTYP
           [F:DTR]DTRNUM=[F:BTS]BTSNUM
           [F:DTR]DIE   =""
           [F:DTR]HEACCECOD=3
           [F:DTR]DSPCOD =3
           [F:DTR]DSPSCR =1
           [F:DTR]STOCCECOD=[F:BTS]CCECODS    
           If [F:DTR]STOCCECOD = 0 : [F:DTR]STOCCECOD = 1 : Endif
           [F:DTR]CCESCR  = 3
           Write [DTR]
           If fstat
             Call ECR_TRACE("File DIETRS"-[F:DTR]ABRFIC-num$([F:DTR]DTRTYP)+", ERROR ="-num$(fstat),1) From GESECRAN
           Endif
       Endif 
       Rewrite [BTS]
    #Endif
Next
Commit
Close Local File [BTS]
Close Local File [DTR]
Close Local File [DIE]

$PJA
#-------------------------------------------------#
# Initialisation paramètres jalonnement PARJAL    #
#-------------------------------------------------#
If filinfo (filpath ("FIL","PARJAL","fde",[F:ADS]DOSSIER),0)   < 0  : End : Endif
Local File =[F:ADS]DOSSIER+".PARJAL"     [PJA]
Local Integer  WNBR, FLAG
Call ECR_TIME("AGPAMAJ30 : Scheduling parameters Process") From DOSSUB
Raz CLE1,CLE2
Raz WNBR

Trbegin [PJA]

For [PJA]PJA0 
    #Readlock [PJA] Curr      # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat
    #    Call ECR_TRACE("File PARJAL, Error ="-num$(fstat),1) From GESECRAN
    #Else
        If [F:PJA]AUTWIPSCD = 0 : [F:PJA]AUTWIPSCD = 1 : Endif
        Rewrite [PJA]
    #Endif
Next
Commit
Close Local File [PJA]

$MTS
If filinfo (filpath ("FIL","MFGTRS","fde",[F:ADS]DOSSIER),0)   < 0  : End : Endif
Local File =[F:ADS]DOSSIER+".MFGTRS"   [MTS]
Local File =[F:ADS]DOSSIER+".DIETRS"   [DTR]
Local File =[F:ADS]DOSSIER+".GDIE"     [DIE]
Call ECR_TIME("AGPAMAJ30 : Manufacturing Transactions Process") From DOSSUB
Local Integer  WNBR, FLAG, WI
Raz WNBR
Trbegin [MTS]
For [MTS] MTS0 
     #----- Alimentation nouvelle table pour axes analytiques -----#
     Look [DTR] DTR0="MTS";[F:MTS]MTSTYP;[F:MTS]MTSNUM;0;0
     If fstat
          Raz [F:DTR]
          [F:DTR]ABRFIC="MTS"
          [F:DTR]DTRTYP=[F:MTS]MTSTYP
          [F:DTR]DTRNUM=[F:MTS]MTSNUM
          [F:DTR]DIE   =""
          [F:DTR]HEACCECOD=3
          [F:DTR]DSPCOD =3
          [F:DTR]DSPSCR =1
          If [F:MTS]MTSTYP = 2
             [F:DTR]STOCCECOD=[F:MTS]CCECODS    
             If [F:DTR]STOCCECOD = 0 : [F:DTR]STOCCECOD = 1 : Endif
            [F:DTR]CCESCR  = 3
            [F:DTR]CCESCR2 = 3
            [F:DTR]CCESCR3 = 3 
          Else
            [F:DTR]STOCCECOD=3
            [F:DTR]CCESCR =[F:MTS]CCESCR(0)
            [F:DTR]CCESCR2 =[F:MTS]MATCCESCR(0)
            [F:DTR]CCESCR3 =[F:MTS]OPECCESCR(0)
          Endif 
          Write [DTR]
          If fstat
            Call ECR_TRACE("File DIETRS"-[F:DTR]ABRFIC-num$([F:DTR]DTRTYP)+", ERROR ="-num$(fstat),1) From GESECRAN
          Endif
          Raz WI
          For [DIE] DIE0
            Look [DTR] DTR1="MTS";[F:MTS]MTSTYP;[F:MTS]MTSNUM;1;[F:DIE]DIE
            If fstat
              If [F:MTS]MTSTYP=1
                #-----
                If dim([F:MTS]CCECOD)>WI & [F:MTS]CCECOD(WI)>0 & [F:MTS]CCECOD(WI)<3
                  [F:DTR]DIE   =[F:DIE]DIE
                  [F:DTR]DTRTNU=1
                  [F:DTR]DTRLIN=WI+1
                  [F:DTR]CCECOD=[F:MTS]CCECOD(WI)
                  Write [DTR]
                  If fstat
                    Call ECR_TRACE("File DIETRS"-[F:DTR]ABRFIC-num$([F:DTR]DTRTYP)+", ERROR ="-num$(fstat),1) From GESECRAN
                  Endif
                Endif
                #-----
                If dim([F:MTS]MATCCECOD)>WI & [F:MTS]MATCCECOD(WI)>0 & [F:MTS]MATCCECOD(WI)<3
                  Look [DTR] DTR1="MTS";[F:MTS]MTSTYP;[F:MTS]MTSNUM;2;[F:DIE]DIE
                  If fstat
                    [F:DTR]DIE   =[F:DIE]DIE
                    [F:DTR]DTRTNU=2
                    [F:DTR]DTRLIN=WI+1
                    [F:DTR]CCECOD=[F:MTS]MATCCECOD(WI)
                    Write [DTR]
                    If fstat
                      Call ECR_TRACE("File DIETRS"-[F:DTR]ABRFIC-num$([F:DTR]DTRTYP)+", ERROR ="-num$(fstat),1) From GESECRAN
                    Endif
                  Endif
                Endif
                #-----
                If dim([F:MTS]OPECCECOD)>WI & [F:MTS]OPECCECOD(WI)>0 & [F:MTS]OPECCECOD(WI)<3
                  Look [DTR] DTR1="MTS";[F:MTS]MTSTYP;[F:MTS]MTSNUM;3;[F:DIE]DIE
                  If fstat
                    [F:DTR]DIE   =[F:DIE]DIE
                    [F:DTR]DTRTNU=3
                    [F:DTR]DTRLIN=WI+1
                    [F:DTR]CCECOD=[F:MTS]OPECCECOD(WI)
                    Write [DTR]
                    If fstat
                      Call ECR_TRACE("File DIETRS"-[F:DTR]ABRFIC-num$([F:DTR]DTRTYP)+", ERROR ="-num$(fstat),1) From GESECRAN
                    Endif
                  Endif
                Endif
                #-----
              Endif
            Endif
            WI+=1
          Next
      Endif
      WNBR+=1
Next
Commit
Close Local File [MTS]
Close Local File [DTR]
Close Local File [DIE]

$MWS
#-------------------------------------------------------------------------------#
#  Initialisation de champs de la table WOKSTATIO                               #
#-------------------------------------------------------------------------------#
If filinfo (filpath ("FIL", "WORKSTATIO"    , "fde",[F:ADS]DOSSIER ) ,0) < 0: End : Endif
Local File =[F:ADS]DOSSIER+".WORKSTATIO" [MWS]

Call ECR_TIME("AGPAMAJ30 : Workstations Process") From DOSSUB

Raz CLE1, CLE3, STOP
$BOUCLE_MWS
If STOP=1
    STOP= 2 : CRITERE='WST="'+CLE1+'"'+' & WCRFCY>"'+ CLE3 +'"'
Elsif STOP= 2
    STOP= 0 : CRITERE='WST>"'+CLE1 +'"'
Else
    CRITERE ="1=1"
Endif

Raz COMPTEUR
Trbegin [MWS]

For [MWS]WST0 Where evalue(CRITERE)
#Readlock [MWS] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat 
    #    Call ECR_TRACE("File WORKSTATIO, Error="-num$(fstat),1) From GESECRAN
    #Else
        If !find([F:MWS]RPLAUTO,1,2)    : [F:MWS]RPLAUTO = 1    : Endif
        If !find([F:MWS]SBBFLG,1,2)     : [F:MWS]SBBFLG  = 1    : Endif
        Rewrite [F:MWS]
    #Endif
    COMPTEUR +=1
    If COMPTEUR>GMAXUPDTRS
        CLE1 = [F:MWS]WST
        CLE3 = [F:MWS]WCRFCY
        STOP = 1
        Break
    Endif
Next
Commit

If STOP : Goto BOUCLE_MWS : Endif
Close Local File [MWS]

