#################################################################################
# Moulinette Après mise à jour concernant le module GPAO                        #
################################################################################
Subprog GPAMAJ30()

#---- Ajout de la législation dans la table PARWIPACC ------#
Call ECR_TIME("AGPAMAJ30 : GP Transactions Process Update PARWIPACC") From DOSSUB
Call UPDPWA([F:ADS]DOSSIER)

#---- Changement de la clé de MFC => màj onglet sélection & RAZ derniers lus ------#
Call ECR_TIME("AGPAMAJ30 : GP Transactions Process Update MFC") From DOSSUB
Call UPDMFC([F:ADS]DOSSIER)

#---- Table des Matricules ------#
Call ECR_TIME("AGPAMAJ30 : GP Transactions Process Update TABMAT") From DOSSUB
Call UPDTMA([F:ADS]DOSSIER)

End


#########################################################################
#  UPDPWA : mise à jour  table  PARWIPACC (alimentation de la législation)
#########################################################################
Subprog UPDPWA(LDOS)
Value Char LDOS

If filinfo(filpath("FIL","PARWIPACC","fde",LDOS),0) < 0  : End : Endif

Local File =LDOS+".PARWIPACC"       [PWA]
Local File =LDOS+".PARWIPACC"       [PWA2]

Local Integer LRET
Local Integer LNBLEG
Local Char    LDOSLEG(type(GDOSLEG(1))-10)(1..dim(GDOSLEG))

Call SETLEG(LDOS,LDOSLEG,LNBLEG) From DOSCONT

If LNBLEG=0
    Call ECR_TRACE(LDOS-": No legislation found",1) From GESECRAN
    End
Endif

Call DEBTRANS From GLOCK
Trbegin [PWA]
Update [PWA] Where LEG=""
&            With LEG=LDOSLEG(1)
Commit
For I_LEG=2 To LNBLEG
    Trbegin [PWA]
    For [PWA] Where LEG=LDOSLEG(1)
        [F:PWA2] = [F:PWA]
        [F:PWA2]LEG = LDOSLEG(I_LEG)
        Write [PWA2]
    Next
    Commit
Next

# On ne génère pas le traitement car cela est de toute façon fait au moment de la comptabilisation.

# Mise à jour de l'onglet sélection de l'objet PAS
Call MAJ_SEL(LDOS,"PWA") From PATCHAOB
Call VALID("PWA",LDOS,1,LRET) From VALOBJ
Call VALID("OPWA",LDOS,1,LRET) From VALWIN

Close Local File [PWA]
Close Local File [PWA2]
End

#########################################################################
#  UPDMFC : Changement de la clé de MFC => màj onglet sélection & RAZ derniers lus 
#########################################################################
Subprog UPDMFC(LDOS)
Value Char LDOS

Local Integer LRET

# Mise à jour de l'onglet sélection de l'objet MFC (+raz du dernier lu)
Call MAJ_SEL(LDOS,"MFC") From PATCHAOB
Call VALID("MFC",LDOS,1,LRET) From VALOBJ
Call VALID("OMFC",LDOS,1,LRET) From VALWIN

# Mise à jour de l'onglet sélection de l'objet HIM (+raz du dernier lu)
Call MAJ_SEL(LDOS,"HIM") From PATCHAOB
Call VALID("HIM",LDOS,1,LRET) From VALOBJ
Call VALID("OHIM",LDOS,1,LRET) From VALWIN

End

#########################################################################
#  UPDTMA : mise à jour  table TABMAT
#########################################################################
Subprog UPDTMA(LDOS)
Value Char LDOS

If filinfo(filpath("FIL","TABMAT","fde",LDOS),0) < 0  : End : Endif

Local File =LDOS+".TABMAT" [TMA]

Local Integer LRET

Call DEBTRANS From GLOCK
Trbegin [TMA]
If dim([F:TMA]ENAFLG)>0
   Update [TMA] Where ENAFLG=0
&               With  ENAFLG=2
Endif
Commit
Close Local File [TMA]
End


#################################################################################
# Met à jour les tables dont le(s) champ(s) désignation sont devenus traduisibles
#################################################################################
# Tables mises à jour:
#  - MFGTRS
#  - BENCHTRS
#################################################################################
Subprog DES2AXX(PDOS)
Value Char PDOS
If filinfo(filpath("FIL","ATEXTRA","fde",PDOS),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": ATEXTRA"-time$,0) From GESECRAN : # maj table

Local File =PDOS+".ATEXTRA"   [AXX]

#----- Sauvegarde puis récupération de la langue du dossier à migrer -----#
Local Char SAV_GLANGUE(GLONLAN)
SAV_GLANGUE=GLANGUE
GLANGUE=[F:ADS]LANDEF

