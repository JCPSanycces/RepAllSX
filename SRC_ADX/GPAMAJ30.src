#------- TABWEEDIA  [TWD] : Schémas hébdomadaires ---------------------
If filinfo(filpath("FIL","TABWEEDIA","fde",[F:ADS]DOSSIER),0)>0 
  Local File =[F:ADS]DOSSIER+".TABWEEDIA"   [TWD]
  Trbegin [AXX], [TWD]
    For [TWD]TWD0
      If !instr(1,[F:TWD]TWDDES,"~")
        #Readlock [TWD] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
        #If fstat
        #  Call ECR_TRACE("File TABWEEDIA"-[F:TWD]TWD+", Error ="-num$(fstat),1) From GESECRAN
        #Else
          Call MAJTEXTRA ([F:TWD]TWDDES,"TABWEEDIA","TWDDESAXX",[F:TWD]TWD,"") From ATEXTRA
          If GOK<1
            Call ECR_TRACE("File ATEXTRA"-"TABWEEDIA TWDDESAXX"-[F:TWD]TWD-
&                          ",Error ="-num$(fstat),1) From GESECRAN
            GOK=1 : Break
          Endif
          Call MAJTEXTRA ([F:TWD]TWDSHO,"TABWEEDIA","TWDSHOAXX",[F:TWD]TWD,"") From ATEXTRA
          If GOK<1
            Call ECR_TRACE("File ATEXTRA"-"TABWEEDIA TWDSHOAXX"-[F:TWD]TWD-
&                          ",Error ="-num$(fstat),1) From GESECRAN
            GOK=1 : Break
          Endif
        #Endif
        [F:TWD]TWDDES=GLANGUE+"~"+[F:TWD]TWDDES
        Rewrite [TWD]
        If fstat
          Call ECR_TRACE("File TABWEEDIA"-[F:TWD]TWD+", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
    Next
  Commit
  Close Local File [TWD]
  Call ECR_TIME("DOSMAJ30 Update ATEXTRA for Weekly Structures  : Ended") From DOSSUB
Endif
#------- DIAHOU  [DIH] : Schémas horaires ---------------------
If filinfo(filpath("FIL","DIAHOU","fde",[F:ADS]DOSSIER),0)>0 
  Local File =[F:ADS]DOSSIER+".DIAHOU"   [DIH]
  Trbegin [AXX], [DIH]
    For [DIH]DIH0
      If !instr(1,[F:DIH]DIANAM,"~")
        #Readlock [DIH] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
        #If fstat
        #  Call ECR_TRACE("File DIAHOU"-[F:DIH]NUM+", Error ="-num$(fstat),1) From GESECRAN
        #Else
          Call MAJTEXTRA ([F:DIH]DIANAM,"DIAHOU","DIANAMAXX",[F:DIH]NUM,"") From ATEXTRA
          If GOK<1
            Call ECR_TRACE("File ATEXTRA"-"DIAHOU DIANAMAXX"-[F:DIH]NUM-
&                          ",Error ="-num$(fstat),1) From GESECRAN
            GOK=1 : Break
          Endif
          Call MAJTEXTRA ([F:DIH]DIASHO,"DIAHOU","DIASHOAXX",[F:DIH]NUM,"") From ATEXTRA
          If GOK<1
            Call ECR_TRACE("File ATEXTRA"-"DIAHOU DIASHOAXX"-[F:DIH]NUM-
&                          ",Error ="-num$(fstat),1) From GESECRAN
            GOK=1 : Break
          Endif
        #Endif
        [F:DIH]DIANAM=GLANGUE+"~"+[F:DIH]DIANAM
        Rewrite [DIH]
        If fstat
          Call ECR_TRACE("File DIAHOU"-[F:DIH]NUM+", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
    Next
  Commit
  Close Local File [DIH]
  Call ECR_TIME("DOSMAJ30 Update ATEXTRA for Hours Structures  : Ended") From DOSSUB
Endif

#----- Restitution du code langue de connexion -----#
GLANGUE=SAV_GLANGUE
End


