#<AdxTL>@(#)7.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
GBIDC3="" : GBIDC2=""
Raz GPILOBJ, GPILCOD
Call OBJET("AOW",GBIDC2,GBIDC3) From GOBJET
End

####################################################
$COMPILE
NOMTRT = "WWE"+num$(adxuid(1))
TRTSRC = filpath("TRT",NOMTRT,"src",0)

Openo TRTSRC , 0
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8

Local Integer NBXML , NOL , J , JJ
Local Char MODELE(GLONAOE)

Local Mask AOW0 [OW0]
Local Mask AOW1 [OW1]

TITPRG = mess(93,141,1)-[F:AOW]EXT-"("+NOMTRT+")" : # Exportation de données
MODELE = [M:AOW0]EXT

Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"-TITPRG

Wrseq "Subprog EXPORT(NBEXP,SEPREC,E)"
Wrseq "Variable Integer NBEXP"
Wrseq "Value    Char    SEPREC"
Wrseq "Variable Integer E"
Wrseq
Wrseq "Local Integer  OK"
Wrseq "Local Char     LIGNE(250) , LIGXML(250)"
If [F:AOE]TYPFIL=4
 Wrseq "Local Char     BUFFER(200)(1..15)"
Endif
Wrseq "Local Date     DAT"
Wrseq "Local Integer  NOL ,J,K,I,M"
Wrseq "Local Integer  LIBEL"
Wrseq "Local Char     FLDS(255)"
If [F:AOE]OPTCHA>1
 Wrseq "Local Char     TRANS1(250) , TRANS2(250)"
 Wrseq "Call INITRANS(TRANS1,TRANS2,"+num$([F:AOE]OPTCHA)+") From SUBEXPOBJ"
Endif
Wrseq "Local Char     ACTION(20), EXPFIC(4)"
If find([F:AOE]TYPFIL,5)
 Wrseq "Local Char     FLGXML(15)(0..30)"
 Wrseq "Local Integer  NBXML ,NIVXML(0..30)"
Endif
Wrseq
For I=0 To [F:AOE]NBRFLG-1
 Read [ATB]CODFIC = [F:AOE]FLGFIL(I)
  Wrseq "If !clalev([F:"+[F:ATB]ABRFIC+"]) : ";
  Wrseq "Local File "+format$("K:"+num$(GLONATB)+"X",[F:AOE]FLGFIL(I))+" ["+[F:ATB]ABRFIC+"] : Endif"
Next I
Wrseq
Wrseq "If !clalev([F:AOW]) : Local File AOBJEXTMP   [AOW] : Endif"
Wrseq "If !clalev([F:AOV]) : Local File AOBJEXTMPD  [AOV] : Endif"
Wrseq "If !clalev([F:AOY]) : Local File AOBJEXTMPC  [AOY] : Endif"
Wrseq "If !clalev([F:AOZ]) : Local File AOBJEXTMPB  [AOZ] : Endif"
Wrseq
Wrseq "NBEXP = 0"
Wrseq "For [AOV]AOV0(2) where NUMLOT = '"+num$([F:AOW]NUMLOT)+"'"
If find([F:AOE]TYPFIL,5)
 Wrseq " If NBEXP > 0"
 Wrseq "  If FLGXML(NBXML-1)= '</'+[AOV]LEVCOD+'>'"
 Wrseq "   Wrseq space$(5*[F:AOV]LEV)+FLGXML(NBXML-1) Using  [AEXP]"
 Wrseq "   FLGXML(NBXML-1) = '' : : NIVXML(NBXML-1) = 0"
 Wrseq "   NBXML-=1"
 Wrseq "  Elsif NIVXML(NBXML-1)>=[F:AOV]LEV "
 Wrseq "   I = NIVXML(NBXML-1)-[F:AOV]LEV "
 Wrseq "   For M=1 To I+1"
 Wrseq "    Wrseq space$(5*NIVXML(NBXML-M))+FLGXML(NBXML-M) Using  [AEXP]"
 Wrseq "    FLGXML(NBXML-M) = '' : NIVXML(NBXML-M) = 0"
 Wrseq "   Next"
 Wrseq "   NBXML-=(I+1)"
 Wrseq "  Endif"
 Wrseq " Endif"
Endif
Wrseq " NBEXP += 1"
If find([F:AOE]TYPFIL,6,7)
 Wrseq " For [AOV]AOV0"
 Wrseq "  Case [AOV]LEVCOD"
 For II=0 To [F:AOE]NBRFLG-1
  For [AOV]AOV0(2) Where NUMLOT = [F:AOW]NUMLOT & LEVCOD= [F:AOE]FLGREC(II)
   Wrseq "    When '"+[F:AOE]FLGREC(II)+"' : Gosub EXPORT_"+[F:AOE]FLGREC(II)
   Break
  Next AOV
 Next II
 If [F:AOE]NBRFLG=0 :  Wrseq "  When Default : Gosub EXPORT_" : Endif
 Wrseq "  Endcase"
 Wrseq " Next AOV"
 Wrseq "Next AOV"
Else
 Wrseq " Case [AOV]LEVCOD"
 For II=0 To [F:AOE]NBRFLG-1
  For [AOV]AOV0(2) Where NUMLOT = [F:AOW]NUMLOT & LEVCOD = [F:AOE]FLGREC(II)
   Wrseq "    When '"+[F:AOE]FLGREC(II)+"' : Gosub EXPORT_"+[F:AOE]FLGREC(II)
   Break
  Next AOV
 Next II
 If [F:AOE]NBRFLG=0 :  Wrseq "  When Default : Gosub EXPORT_" : Endif
 Wrseq " Endcase"
 If find([F:AOE]TYPFIL,5)
  Wrseq " FLGXML(NBXML) = '</'+[AOV]LEVCOD+'>'"
  Wrseq " NIVXML(NBXML) = [F:AOV]LEV"
  Wrseq " NBXML +=1"
 Endif
 Wrseq "Next AOV"
Endif
Wrseq
If [F:AOE]TYPFIL=5
 Wrseq 'If NBEXP>0'
 Wrseq 'For K=NBXML To 0 Step -1'
 Wrseq ' If FLGXML(K)<> ""'
 Wrseq '  Wrseq space$(5*NIVXML(K))+FLGXML(K) Using  [AEXP]'
 Wrseq ' Endif'
 Wrseq 'Next K'
 Call FIN_GROUPE("EXP"," ")
 Wrseq 'Endif'
Endif
Wrseq 'End'
Wrseq
If [F:AOE]NBRFLG > 0
 CPT=0
 For II=0 To [F:AOE]NBRFLG-1
  CPT +=1
  For [AOV]AOV0(2) Where NUMLOT = [F:AOW]NUMLOT & LEVCOD = [F:AOE]FLGREC(II)
   Gosub CHARGE_MODELE
   Gosub EXPORT
   Break
  Next AOV
 Next II
Else
 CPT =1
 For [AOV]AOV0(2) Where NUMLOT = [F:AOW]NUMLOT  : # & LEVCOD = ""
  Gosub CHARGE_MODELE
  Gosub EXPORT
  Break
 Next AOV
Endif
Openo
Close Local Mask
Return

#####################################################################################################
$EXPORT
Wrseq ""
Wrseq "$EXPORT_"+[AOV]LEVCOD
If CPT=1 & [F:AOE]TYPFIL=5
 Wrseq 'If NBEXP=1'
 Call DEB_GROUPE("EXP"," ")
 Wrseq 'Endif'
Endif
If [F:AOE]TYPFIL=5
 Call DEB_GROUPE([F:AOV]LEVCOD,"")
Endif
If [F:AOE]TYPFIL=4
 K = find([F:AOV]LEVCOD,[F:AOE]FLGREC)
 Wrseq "Call INI_BUF(BUFFER,"+num$([F:AOE]RECLEN(K-1))+") From SUBEXPOBJ"
Endif
If !find([F:AOE]TYPFIL,6,7)
 Wrseq "For [AOV]AOV0"
Endif
Wrseq " Case [AOV]FLDNUM"
Local Integer NBCHP
Filter [AOD] Where EXT = [F:AOE]EXT
Read [AOD]AOD0 Last
Filter [AOD]
NBCHP = [AOD]NUMLIG
JJ=0
For [AOV]AOV0
 JJ+=1
 Wrseq "  When "+num$([AOV]FLDNUM)
 Read [ATY]CODTYP = [M:OW1]FLDATY(JJ-1)
 FLDS = "[F:AOV]FLDVAL"
 Gosub DICO
 NOLIB  = 0
 Gosub LIGNES
 If !find(TYPFMT,7,8) : # Blob , Clob
  Case [F:AOE]TYPFIL
   When 1
    Wrseq "   Wrseq LIGNE Using [AEXP]"
   When 2,3
    FINLIG = 0
    If JJ=[M:OW1]NBRFLD : FINLIG = 1 : Endif
    If FINLIG
     Wrseq "   Wrseq LIGNE Using [AEXP]"
    Else
     Wrseq "   Wrseq LIGNE; Using [AEXP]"
    Endif
   When 4
    Wrseq '   Call SET_BUF(BUFFER,LIGNE,'+num$([M:OW1]FLDLOC(JJ-1))+',';
    Wrseq num$([M:OW1]FLDLNG(JJ-1))+',"'+num$([M:OW1]FLDFMT(JJ-1))+'",'+num$(TYPFMT)+',"'+SEPDEC+'") ';
    Wrseq 'From SUBEXPOBJ'
   When 5
    Call FLD_LIGNE(JJ-1)
   When 6,7
    If [AOV]FLDNUM = NBCHP
     Wrseq "   Wrseq LIGNE Using [AEXP]"
    Else
     Wrseq "   Wrseq LIGNE; Using [AEXP]"
    Endif
  Endcase
 Endif
Next AOV
Wrseq "Endcase"
If !find([F:AOE]TYPFIL,6,7)
 Wrseq "Next AOV"
Endif
If [F:AOE]TYPFIL=4
 Wrseq "Call WR_BUF(BUFFER) From SUBEXPOBJ"
Endif
Wrseq "Return"
Return
#####################################################################################################
$DICO
Case [M:OW1]FLDTYP(JJ-1)
 When 1         : TYPFMT = 4 : NOLIB = [F:ATY]NOLIB : If NOLIB=0 : NOLIB = [F:ATZ]NOLIB : Endif
 When 2,3,4,5,6 : TYPFMT = 2
 When 7         : TYPFMT = 1
 When 8         : TYPFMT = 3
 When 9         : TYPFMT = 7 : # Blob
 When 10        : TYPFMT = 8 : # Clob
Endcase
Case [M:OW1]FLDATY(JJ-1)
 When "ATX"                   : TYPFMT = 5
 When "AXX","AX1","AX2","AX3" : TYPFMT = 6
Endcase
Return

#####################################################################################################
$LIGNES
Local Char TYPTRANS
If [M:OW1]FLDNUMTAB(JJ-1) > 0 # il y a une table de transcodage précisée
 TYPTRANS = "N" #numérique
 For[F:AOR] Where NUMTAB = [M:OW1]FLDNUMTAB(JJ-1)
  If num$(val([F:AOR]CODEXT)) <> num$([F:AOR]CODEXT)
   TYPTRANS = "A" : Break : #Il s'agit d'un alphanumérique
  Endif
 Next
Else
 If find(TYPFMT,1,7) : TYPTRANS= "A" : Else : TYPTRANS= "N" : Endif
Endif

Case TYPFMT
 When 1 : # Alpha
  Wrseq "   #Alpha"
  Wrseq '   FLDS = '+FLDS
  If TYPTRANS = "A"
   If [F:AOE]OPTCHA>1
    Wrseq '   LIGNE = '+QUOTE+'+ctrans(';FLDS;',TRANS1,TRANS2)+'+QUOTE
   Else
    Wrseq '   LIGNE = '+QUOTE+'+FLDS+'+QUOTE
   Endif
  Else
   If instr(1,[F:ATY]OPTION,"-")
    Wrseq "   LIGNE = mid$('- +',sgn(",val(FLDS),")+2,1)+num$(abs(",FLDS,"))"
   Else
    Wrseq "   LIGNE = num$(FLDS)"
   Endif
   If SEPDEC<>"."
    Wrseq 'CALL SETNUM(LIGNE,"'+SEPDEC+'") From SUBEXPOBJ'
   Endif
  Endif
 When 2 : # Numérique
  Wrseq "   #Numérique"
  Wrseq '   FLDS = num$('+FLDS+')'
  If TYPTRANS = "A"
   If [F:AOE]OPTCHA>1
    Wrseq '   LIGNE = '+QUOTE+'+ctrans(';FLDS;',TRANS1,TRANS2)+'+QUOTE
   Else
    Wrseq '   LIGNE = '+QUOTE+'+FLDS+'+QUOTE
   Endif
  Else
   If instr(1,[F:ATY]OPTION,"-")
    Wrseq "   LIGNE = mid$('- +',sgn(",val(FLDS),")+2,1)+num$(abs(",FLDS,"))"
   Else
    Wrseq "   LIGNE = num$(FLDS)"
   Endif
   If SEPDEC<>"."
    Wrseq 'CALL SETNUM(LIGNE,"'+SEPDEC+'") From SUBEXPOBJ'
   Endif
  Endif
 When 3 : # Date
  Wrseq "   # Date"
  Wrseq "   FLDS = ",FLDS
  Wrseq "   LIGNE = FLDS"
 When 4 : # Menu local
  Wrseq "   # Menu local"
  Case [F:AOE]OPTMNL
   When 0
    Wrseq '   FLDS = '+FLDS
    Wrseq "   LIGNE  = num$(FLDS)"
   When Default
    Wrseq '   FLDS = '+FLDS
    If [F:AOE]OPTCHA>1
     Wrseq '   LIGNE = '+QUOTE+'+ctrans(';FLDS;',TRANS1,TRANS2)+'+QUOTE
    Else
     Wrseq '   LIGNE = '+QUOTE+'+FLDS+'+QUOTE
    Endif
  Endcase
 When 5 : # Texte (ATEXTE)
   Wrseq "   # ATX"
   Wrseq '   If instr(1,[F:AOV]FLDVAL,"&~&") & left$([F:AOV]FLDVAL,instr(1,[F:AOV]FLDVAL,"&~&")-1)<>""'
   Wrseq '    FLDS = left$([F:AOV]FLDVAL,instr(1,[F:AOV]FLDVAL,"&~&")-1)';
   Wrseq '+"~"+num$(right$([F:AOV]FLDVAL,instr(1,[F:AOV]FLDVAL,"&~&")+3))'
   Wrseq '   Else'
   Wrseq "    FLDS = '' "
   Wrseq '   Endif'
   If [F:AOE]OPTCHA>1
    Wrseq '   LIGNE = '+QUOTE+'+ctrans(';FLDS;',TRANS1,TRANS2)+'+QUOTE
   Else
    Wrseq '   LIGNE = '+QUOTE+'+FLDS+'+QUOTE
   Endif
 When 6 : # Texte traduisible (ATEXTRA)
   Wrseq '   FLDS = '+FLDS
   If [F:AOE]OPTCHA>1
    Wrseq '   LIGNE = '+QUOTE+'+ctrans(';FLDS;',TRANS1,TRANS2)+'+QUOTE
   Else
    Wrseq '   LIGNE = '+QUOTE+'+FLDS+'+QUOTE
   Endif
 When 7 : # Blob
  Wrseq "   # Blob"
  Wrseq '   Read [AOZ]AOZ0 = [F:AOV]NUMLOT;[F:AOV]NUMLIG'
  Wrseq '   Call ECRIRE_BLOB([F:AOZ]FLDBLB) From SUBEXPOBJ'
 When 8 : # Clob
  Wrseq '   # Clob'
  Wrseq '   Read [AOY]AOY0 = [F:AOV]NUMLOT;[F:AOV]NUMLIG'
  Wrseq '   Call ECRIRE_CLOB([F:AOY]FLDCLB) From SUBEXPOBJ'
Endcase
Return

#################################################################################################
Subprog DEB_GROUPE(REC,DIF)
Value Char    REC , DIF
Local Char    LIGNE(250)
Local Integer I , K
If REC="EXP"
 Gosub SET_HEAD
 Wrseq DIF;'LIGXML ='-"'"+LIGNE1+"'"
 Wrseq DIF;'Wrseq LIGXML Using  [AEXP]'
 Wrseq DIF;'LIGXML ='-"'"+LIGNE2+"'"
 Wrseq DIF;'Wrseq LIGXML Using  [AEXP]'
Else
 Wrseq DIF;'LIGXML ='-"'"+space$(5*[F:AOV]LEV)+'<'+REC+'>'+"'"
 Wrseq DIF;'Wrseq LIGXML Using  [AEXP]'
Endif
End

#-----------------------#
$SET_HEAD
Local Char LIGNE1(255) , LIGNE2(255)
LIGNE1 = '<?xml version="1.0" encoding="'+func AEXPSCHEMA.ENCODING([F:AOE]CODDBA,[F:AOE]OPTCHA)+'" ?>'
LIGNE2 = '<p:'+func AEXPSCHEMA.PUBLI([F:AOE]EXT)
LIGNE2 -= 'xmlns:p="http://com.sage/X3/'+func AEXPSCHEMA.PUBLI([F:AOE]EXT)+'"'
LIGNE2 -= 'xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"'
LIGNE2 -= 'xsi:schemaLocation="http://com.sage/X3/'+func AEXPSCHEMA.PUBLI([F:AOE]EXT)-func AEXPSCHEMA.PUBLI([F:AOE]EXT)+'.xsd'
LIGNE2 -= '">'
Return

#################################################################################################
Subprog FLD_LIGNE(NUMLIG)
Value Integer NUMLIG
Local Integer I , LON , NOLIB , DIME , TTY
Local Char    TYP(GLONATY) , FLD(30) , TAB(GLONATB) , TBD(30) , BAL(30)

I = NUMLIG
TAB = [M:OW1]FLDATB(I)
Read [ATB]CODFIC = TAB

# Paramètres du champ
Raz DIME , NOLIB , LON
Case left$([M:OW1]FLDNAM(I),1)
 When "/","*","=","'",'"',""
  TYP = 'A'
  LON = 30
  BAL = [M:OW1]FLDATY(I)+"__"+num$(NUMLIG)
  TTY = 7
 When Default
  FLD = [M:OW1]FLDNAM(I)
  K = instr(1,FLD,"(")
  If K
   DIME = val(right$(FLD,K+1))
   FLD = left$(FLD,K-1)
   BAL = FLD+"_"+num$(DIME)
  Else
   BAL = FLD
  Endif
  Read [ATZ]CODZONE = [M:OW1]FLDATB(I) ; FLD
  If !fstat
   TTY = [F:ATY]TYPTYP
   TYP = [F:ATZ]CODTYP
   Read [ATY]CODTYP = [F:ATZ]CODTYP
   If [F:ATY]LNGTYP<>0
    LON = [F:ATY]LNGTYP
   Else
    LON = [F:ATZ]LONG
   Endif
   If [F:ATY]TYPTYP=1
    If [F:ATY]NOLIB<>0
     NOLIB = [F:ATY]NOLIB
    Else
     NOLIB = [F:ATZ]NOLIB
    Endif
   Endif
   If TYP="ADI"
    Read [AMP]CODPAR=2;TAB;FLD;"ADI"
    If !fstat
     If find(left$([F:AMP]VALPAR,1),"'",'"')
      TBD = num$(evalue([F:AMP]VALPAR))
     Else
      TBD = num$([F:AMP]VALPAR)
     Endif
    Endif
   Endif
  Endif
Endcase
If [M:OW1]BAL(I)<>""
 BAL = [M:OW1]BAL(I)
Else
 BAL = [F:ATB]ABRFIC+"_"+BAL
Endif

If left$([M:OW1]FLDNAM(I),1)<>"/"
 # Caractéristiques champ normal
 K = find([M:OW1]FLDTYP(I),[F:AOV]LEV)
 # On n'exporte plus les champs vides (même pas avec <balise/>)
 Case TYP
  When "ATX","AXX","AX1","AX2","AX3"
   Wrseq 'If LIGNE<>""'
  When Default
   Case TTY
    When 8 : # Date
     Wrseq 'If LIGNE<>"" and left$(LIGNE,4)<>"0000"'
    When 1,2,3,4,5,6 : # Numérique
     Wrseq 'If LIGNE<>"" and val(LIGNE)<>0'
    When Default
     Wrseq 'If LIGNE<>""'
   Endcase
 Endcase
 Wrseq '   LIGXML ='-"'"+space$((5*[F:AOV]LEV)+5)+'<'+BAL+'>'+"'"
 Wrseq "   Call MODVAL(LIGNE) From INTRUTILA" : # Valeur du champ
 Wrseq "   Wrseq LIGXML+LIGNE+'</"+BAL+">' Using  [AEXP]" : # Balise de fin d'enregistrement
 Wrseq 'Endif'
Endif
End

#################################################################################################
Subprog FIN_GROUPE(REC,DIF)
Value Char    REC , DIF
Local Integer K
If REC="EXP"
 Gosub SET_FOOT
 Wrseq DIF;'LIGXML ='-"'"+LIGNE1+"'"
Else
 # K = find(REC,[F:AOE]FLGREC)
 Wrseq DIF;'LIGXML ='-"'"+space$(5*[F:AOV]LEV)+'</'+REC+'>'+"'"
Endif
Wrseq DIF;'Wrseq LIGXML Using  [AEXP]'
End

#----------------#
$SET_FOOT
Local Char LIGNE1(255)
LIGNE1 = '</p:'+func AEXPSCHEMA.PUBLI([F:AOE]EXT)+'>'
Return

#################################################################################################
$CHARGE_MODELE
Local Integer J,CPTCLB
Local Decimal L1
Local Char    CFLD
Read [AOE]AOE0 = [L]MODELE
If !fstat
 [M:OW1]OPTMNL  = [F:AOE]OPTMNL
 [M:OW0]COD0    = [F:AOE]FLGREC(0)
 If [F:AOE]NBRFLG > 0
  For I=0 To [F:AOE]NBRFLG-1
   If [F:AOE]FLGREC(I) = [F:AOV]LEVCOD
    [M:OW0]LEV     = [F:AOE]FLGLEV(I)
    [M:OW1]FLDKEY  = [F:AOE]FLGKEY(I)
    [M:OW1]FLDLNK  = [F:AOE]FLGLNK(I)
    J += 1
    Break
   Endif
  Next I
 Else
  [M:OW0]LEV     = 0
  [M:OW1]FLDKEY  = ""
  [M:OW1]FLDLNK  = ""
  J += 1
 Endif
Endif
If !J
 GMESSAGE = mess(83,123,1)
 mkstat=2 : Return
Endif
Gosub EFF_TAB
nolign = 0
For [AOD]AOD0 Where EXT = [L]MODELE
 If [F:AOD]SEL <> 3
  If [F:AOD]TYP = [F:AOV]LEVCOD
   nolign += 1
   If !find(left$([F:AOD]FLD,1),"*","'",'"',"=")
    [M:OW1]FLDNAM(nolign-1)     = [F:AOD]FLD
   Else
    [M:OW1]FLDNAM(nolign-1)     = ""
   Endif
   If [M:OW1]FLDNAM(nolign-1) = "/" : [M:OW1]FLDVAL(nolign-1) = [F:AOV]LEVCOD : Endif
   [M:OW1]FLDATB(nolign-1)    = [F:AOD]FIL
   [M:OW1]FLDNUMTAB(nolign-1) = [F:AOD]NUMTAB
   [M:OW1]FLDLNG(nolign-1)    = [F:AOD]LNG
   [M:OW1]FLDFMT(nolign-1)    = [F:AOD]FMT
   [M:OW1]FLDLOC(nolign-1)    = [F:AOD]LOC
   [M:OW1]FLDINTIT(nolign-1)  = [F:AOD]COM
   [M:OW1]BAL(nolign-1)       = [F:AOD]BAL
   CFLD = [F:AOD]FLD
   If instr(1,[L]CFLD,"(")
    CFLD = left$([L]CFLD,instr(1,[L]CFLD,"(")-1)
   Endif
   Read [ATZ]CODZONE = [F:AOD]FIL;[L]CFLD
   If !fstat
    [M:OW1]FLDATY(nolign-1)  = [F:ATZ]CODTYP
    Read [ATY]CODTYP = [F:ATZ]CODTYP
    If !fstat
     [M:OW1]FLDTYP(nolign-1)  = [F:ATY]TYPTYP
     If [F:ATY]LNGTYP<>0
      [M:OW1]FLDLON(nolign-1)= [F:ATY]LNGTYP
     Else
      [M:OW1]FLDLON(nolign-1)= [F:ATZ]LONG
     Endif
    Endif
   Else
    [M:OW1]FLDTYP(nolign-1)  = 7
    [M:OW1]FLDATY(nolign-1)  = "A"
   Endif
  Endif
 Endif
Next
[M:OW1]OPTDAT = [F:AOE]OPTDAT
[M:OW1]TYPFIL = [F:AOE]TYPFIL
[M:OW1]NBLIG  = nolign
[M:OW1]NBRFLD = nolign
Return

$EFF_TAB
Raz [M:OW1]FLDNAM
Raz [M:OW1]FLDATB
Raz [M:OW1]FLDNUMTAB
Raz [M:OW1]FLDLNG
Raz [M:OW1]FLDFMT
Raz [M:OW1]FLDLOC
Raz [M:OW1]FLDINTIT
Raz [M:OW1]FLDTYP
Raz [M:OW1]FLDATY
Raz [M:OW1]OPTDAT
Raz [M:OW1]TYPFIL
Return
