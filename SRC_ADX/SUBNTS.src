#<AdxTL>@(#)4.0.0.0 $Revision$
  Call OBJET ("NTS", GBIDC1, GBIDC2) From GOBJET
End
#############################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "FERME"        : Gosub FERME
    When "RAZCRE"       : Gosub RAZCRE
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "LIENS"        : Gosub LIENS
    When "ANNULE"       : Gosub ANNULE
    When "FILGAUCHE"    : Gosub FILGAUCHE
    When "FILTRE"       : Gosub FILTRE
    When "INICRE"       : Gosub INICRE
    When "INIMOD"       : Gosub INIMOD
    When "CHANGE"       : Gosub CHANGE
    When "SETBOUT"      : Gosub SETBOUT
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "ABANDON"      : Gosub ABANDON
    When "AVANT_MOD"    : Gosub AVANT_MOD
    When Default
  Endcase
Return

#############################################################################################
#############################################################################################
# currbox = "GAU_CHE"  tiroir "Notes" (principal)
# currbox = "GAU_CHE1" tiroir "Toutes notes"
#############################################################################################
#############################################################################################
$OUVRE
Local Integer WTYP, WITF, WNEW, WRET
Local Char WFIELD(250)
Global Integer GINPUTKEY

  If !clalev([F:NTSW]) : Local File NOTE     [NTSW] : Endif
  If !clalev([F:NTG])  : Local File NOTCATEG [NTG]  : Endif
  If !clalev([F:TXC])  : Local File TEXCLOB  [TXC]  : Endif
  If !clalev([F:AUS])  : Local File AUTILIS  [AUS]  : Endif
  Gosub NOTE_TYPE
  Gosub CHARGE
  GINPUTKEY = 0
Return

#############################################################################################
$AVANT_MOD
  If currbox = "GAU_CHE1" Then
    # Modification interdite sur le tiroir "Toutes notes"
    GMESSAGE = mess(1147,196,1)
    mkstat = 2
    GINPUTKEY = 0
  Endif
Return

#############################################################################################
$APRES_MODIF
  If GINPUTKEY = 1 Then
    If currbox = "GAU_CHE" Then
      If ([F:NTS]NTSCOD <> [M:NTS0]NTSCOD) or ([F:NTS]NTGCOD <> [M:NTS0]NTGCOD) Then
        # Magique, mais obligé d'être ici pour tester si on est en duplication
        SCHAINE = [M:NTS0]NTSCOD+"~"+num$([M:NTS0]NTGTYP)+"~"+[M:NTS0]STOFCY+"~"+[M:NTS0]NTGCOD
        Read [NTSW]NTS0=[M:NTS0]CODE;SCHAINE
        If fstat Then
          # Si ça n'existe pas on est en duplication
          # GREP="" when it should ="D"
          #GINPUTKEY = 3                      # 101575.o
          If GREP="" : GINPUTKEY = 3 : Endif  # 101575.n
          Gosub SETBOUT From GOBJSUB
        Else
          # Si ça existe on lit l'enregistrement en question
          CLECUR1 = SCHAINE
          Gosub RELIT From GOBJSUB
          GREP = ""
          REP = ""
          GINPUTKEY = 2
          Gosub SETBOUT From GOBJSUB
          OK = -1  # Permet de sortir du mode modif
        Endif
      Endif
    Endif
  Else
    GINPUTKEY = 0
  Endif
Return

#############################################################################################
$SETBOUT
  If GINPUTKEY = 2 Then
    GREP = ""
    REP = ""
    GINPUTKEY = 0
  Elsif GINPUTKEY = 3 Then
    GREP = "D"
    REP = "D"
    GINPUTKEY = 0
  Endif
  If currbox = "GAU_CHE1" Then
    Call VIREBOUT(CHAINE, "A") From GOBJET   # Suppression interdite
    Call VIREBOUT(CHAINE, "C") From GOBJET   # Création interdite
    Call VIREBOUT(CHAINE, "H") From GOBJET   # Duplication interdite
  Endif
Return

###############################################################################################
$FERME
  Kill GINPUTKEY
Return

###############################################################################################
$ABANDON
  GINPUTKEY = 0
Return

###############################################################################################
$RAZCRE
  Gosub CHARGE
  Affzo [M:NTS0]1-99
Return

#############################################################################################
$LIENS
  Gosub CHARGE
  Affzo [M:NTS0]
Return

#############################################################################################
$INICREMOD
  #--- Create/Update in ATEXTRA
  Call MAJTEXTRA ([M:NTS0]NTSDESAXX, "NOTE", "NTSDESAXX", [M:NTS0]CODE, [M:NTS0]NTSCOD2) From ATEXTRA
  Call MAJTEXTRA ([M:NTS0]NTSSHOAXX, "NOTE", "NTSSHOAXX", [M:NTS0]CODE, [M:NTS0]NTSCOD2) From ATEXTRA
Return

#############################################################################################
$INICRE
  Gosub INICREMOD
Return

#############################################################################################
$INIMOD
 Gosub INICREMOD
Return

#############################################################################################
$CHANGE
  Call CHANGE_AXX("NOTE", [L]OCODE, [L]SUPP(0), [L]NCODE, [L]SUPP(0)) From TRTX3TEX
Return

#############################################################################################
$ANNULE
  Delete [AXX] Where CODFIC="NOTE" & IDENT1=[M:NTS0]CODE and IDENT2=[M:NTS0]NTSCOD2
Return

#############################################################################################
$CHARGE
  Gosub NOTE_TYPE
  Case WTYP
    When 1
      If WITF Then
        # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
        #[M:NTS0] = [M:ITF0]            # Item - site
        #Raz [M:NTS0] : Transmask [M:ITF0] To [M:NTS0]     # Issue X3-47758 - 2017-07-19 by FGR
        Transmask [M:ITF0] To [M:NTS0]                     # Issue X3-47758 - 2017-07-19 by FGR
        # Issue X3-35454 - 2017-05-03 by FGR : END
        [M:NTS0]ART  = [M:ITF0]ITMREF
        [M:NTS0]CODE = [M:ITF0]ITMREF
 #      [M:NTS0]DES  = [F:ITM]ITMDES1L #101479.o
        [M:NTS0]DES  = [F:ITM]ITMDES1  #101479.n
      Else
        # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
        #[M:NTS0] = [M:ITM0]            # Item
        #Raz [M:NTS0] : Transmask [M:ITM0] To [M:NTS0]     # Issue X3-47758 - 2017-07-19 by FGR
        Transmask [M:ITM0] To [M:NTS0]                     # Issue X3-47758 - 2017-07-19 by FGR
        # Issue X3-35454 - 2017-05-03 by FGR : END
        [M:NTS0]ART  = [M:ITM0]ITMREF
        [M:NTS0]CODE = [M:ITM0]ITMREF
        [M:NTS0]DES  = [M:ITM0]DES1AXX
      Endif
    When 2
      If GNAVIG(GPILNAV-1) <> "GESBPP"
        # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
        #[M:NTS0] = [M:BPC0]            # Customer
        #Raz [M:NTS0] : Transmask [M:BPC0] To [M:NTS0]     # Issue X3-47758 - 2017-07-19 by FGR
        Transmask [M:BPC0] To [M:NTS0]                     # Issue X3-47758 - 2017-07-19 by FGR
        # Issue X3-35454 - 2017-05-03 by FGR : END
        [M:NTS0]ART  = [M:BPC0]BPCNUM
        [M:NTS0]CODE = [M:BPC0]BPCNUM
        [M:NTS0]DES  = [M:BPC0]BPCNAM
      Else
        # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
        #[M:NTS0] = [M:BPP0]            # Prospect
        #Raz [M:NTS0] : Transmask [M:BPP0] To [M:NTS0]     # Issue X3-47758 - 2017-07-19 by FGR
        Transmask [M:BPP0] To [M:NTS0]                     # Issue X3-47758 - 2017-07-19 by FGR
        # Issue X3-35454 - 2017-05-03 by FGR : END
        [M:NTS0]ART  = [M:BPP0]BPCNUM
        [M:NTS0]CODE = [M:BPP0]BPCNUM
        [M:NTS0]DES  = [M:BPP0]BPCNAM
      Endif
    When 3
      # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
      #[M:NTS0] = [M:BPS0]              # Supplier
      #Raz [M:NTS0] : Transmask [M:BPS0] To [M:NTS0]       # Issue X3-47758 - 2017-07-19 by FGR
      Transmask [M:BPS0] To [M:NTS0]                       # Issue X3-47758 - 2017-07-19 by FGR
      # Issue X3-35454 - 2017-05-03 by FGR : END
      [M:NTS0]ART  = [M:BPS0]BPSNUM
      [M:NTS0]CODE = [M:BPS0]BPSNUM
      [M:NTS0]DES  = [M:BPS0]BPSNAM
  Endcase
  [M:NTS0]NTGTYP = WTYP
  Chgtzn [M:NTS0]ART With mess(WTYP,2087,1)
  If WITF Then
    [M:NTS0]STOFCY=[M:ITF0]STOFCY
  Else
    Chgfmt [M:NTS0]STOFCY With "-K:5B" # Hide site field except on product-site screen
  Endif
  #Affzo [M:NTS0]                                          # Issue X3-47758 - 2017-07-19 by FGR
  Affzo [M:NTS0]1-99                                       # Issue X3-47758 - 2017-07-19 by FGR
Return

#############################################################################################
$VERIF

  Raz WNEW
  If find(GREP,"C","D") and [M:NTS0]NOTE = "" Then
    GERR = 1
    GOK = 1
    GMESSAGE = mess(178,123,1)
    Return
  Endif
  #
  Call CTLDATVAL([M]ENDDAT, [M]EFFDAT) From TRTNTSCTL
  # -------------------------
  Gosub INIT_NTSCOD2
  # -------------------------
  GINPUTKEY = 0
Return

#############################################################################################
$VERIF_CRE
  Gosub VERIF
Return

#############################################################################################
$VERIF_MOD
  Gosub VERIF
Return

#############################################################################################
$FILGAUCHE
  Gosub NOTE_TYPE
  If WTYP > 0 Then
    Case currbox
      When "GAU_CHE"
        FILGAUCHE = 'NTGTYP=' + num$(WTYP) + ' & CODE="' + evalue(WFIELD) + '"'  # Notes drawer
      When "GAU_CHE1", "GAU_CHE9"
        Effzo [M:NTS0]NOTE, NTGCOD, EFFDAT, ENDDAT, PRIORITY
        If WITF <> 1 Then
          FILGAUCHE = 'NTGTYP=' + num$(WTYP) + '& STOFCY=""'   # All notes drawer
        Else
          FILGAUCHE = 'NTGTYP=' + num$(WTYP)
        Endif
        If WITF Then
          FILGAUCHE -= '& STOFCY<>""'
        Endif  # All notes drawer
        FILGAUSUP = FILGAUCHE
      When Default
    Endcase
  Endif
Return

#############################################################################################
$FILTRE
  Gosub NOTE_TYPE
  If WTYP > 0 Then
    FILTRE = 'NTGTYP=' + num$(WTYP) + ' & CODE="' + evalue(WFIELD) + '"' + ' & STOFCY="' # Notes drawer
    If WITF Then
      # Product-site
      FILTRE += [M:ITF0]STOFCY
    Endif
    FILTRE += '"'
  Endif
Return

#############################################################################################
$INIT_NTSCOD2
  [M:NTS0]NTSCOD2 = [M:NTS0]NTSCOD+"~"+num$([M:NTS0]NTGTYP)+"~"+[M:NTS0]STOFCY+"~"+[M:NTS0]NTGCOD
Return

#############################################################################################
$NOTE_TYPE
Local Integer WTYP
Local Char WFIELD(250)

  WITF = 0
  Case GNAVIG(GPILNAV-1)
    When "GESITM"
      WTYP = 1 # Product
      WFIELD = '[M:ITM0]ITMREF'
    When "GESITF"
      WTYP = 1 # Product-site
      WITF = 1
      WFIELD = '[M:ITF0]ITMREF'
    When "GESBPC"
      WTYP = 2 # Customer
      WFIELD = '[M:BPC0]BPCNUM'
    When "GESBPS"
      WTYP = 3  # Supplier
      WFIELD = '[M:BPS0]BPSNUM'
    When "GESBPP"
      WTYP = 2 # Prospect
      WFIELD = '[M:BPP0]BPCNUM'
    When Default
#      WTYP = 1 # Product
#      WFIELD = '[M:ITM0]ITMREF'
  Endcase
  Chgtzn [M:NTS0]ART With mess(WTYP,2087,1)
Return

#############################################################################################
Subprog AM_NTGCOD(VALEUR)
Variable Char    VALEUR()

  If currbox = "GAU_CHE1" Then
    # Modification interdite sur le tiroir "Toutes notes"
    GMESSAGE = mess(1147,196,1)
    mkstat = 2
    End
  Endif
  [M:NTS0]NTGCOD = VALEUR
  Gosub INIT_NTSCOD2
  GINPUTKEY = 1
End

#############################################################################################
Subprog AS_NTSCOD(VALEUR)
Variable Char    VALEUR()

  Case GNAVIG(GPILNAV-1)
    When "GESITM"
      [M:NTS0]ITMREF = [M:ITM0]ITMREF  # Item
      [M:NTS0]NTGTYP =  1
    When "GESITF"
      [M:NTS0]ITMREF = [M:ITF0]ITMREF  # Item-site
      [M:NTS0]NTGTYP =  1
    When "GESBPC"
      [M:NTS0]BPCNUM = [M:BPC0]BPCNUM  # Customer
      [M:NTS0]NTGTYP =  2
    When "GESBPS"
      [M:NTS0]BPSNUM = [M:BPS0]BPSNUM  # Supplier
      [M:NTS0]NTGTYP =  3
    When "GESBPP"
      [M:NTS0]BPCNUM = [M:BPP0]BPCNUM  # Prospect
      [M:NTS0]NTGTYP =  2
  Endcase
End

#############################################################################################
Subprog AM_NTSCOD(VALEUR)
Variable Char    VALEUR()

  If currbox = "GAU_CHE1" Then
    # Modification interdite sur le tiroir "Toutes notes"
    GMESSAGE = mess(1147,196,1)
    mkstat = 2
    End
  Endif
  [M:NTS0]NTSCOD = VALEUR
  Gosub INIT_NTSCOD2
  GINPUTKEY = 1
End

