#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CONSAJE2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:19"
A_USER  = "DOC"
A_STAMP = "20181109230319"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CONSAJE2 [AJE2]
Gosub HORODAT
Local Inpbox "CONSAJE2" From GFONCTION At A_STAMP With A_WINDPREV Mask [AJE2] As [SIM_]
Grizo [AJE2]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [AJE2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=112 : Y1(0)=1 : Y2(0)=23
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1CONSAJE2
Return

Subprog IB_NBLIG
Local Decimal BASPAG
## Action STD
Call IB_NBLIG From CNSAJESTD
Gosub _AFF
End

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(37838,GBOUT1) From OBJDIV
Call TEXTE(37839,GBOUT2) From OBJDIV
Call TEXTE(87,GBOUT3) From OBJDIV
Call IB_NBLIG
Onkey 129 Titled GBOUT1 Call B1_NBLIG From W1CONSAJE2
Onkey 130 Titled GBOUT2 Call B2_NBLIG From W1CONSAJE2
Onkey 131 Titled GBOUT3 Call B3_NBLIG From W1CONSAJE2
Gosub _AFF
End

Subprog B1_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B1_NBLIG From CNSAJESTD
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B2_NBLIG From CNSAJESTD
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B3_NBLIG From CNSAJESTD
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_WSEL
Onevent INIT_AREA Call D_WSEL(zc) From W1CONSAJE2
Onevent BEFORE_INPUT Call AS_WSEL(zc) From W1CONSAJE2
Return

Subprog D_WSEL(VALEUR)
Variable Integer VALEUR
If varinit([M]WSEL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_WSEL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


