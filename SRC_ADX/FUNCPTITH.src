#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################
# création complements ITMMVTHIS
#          => création des périodes non mouvementées
# action TRTCPTITH
############################################################
$ACTION
Case ACTION
  When "OUVRE_BATCH"  : Gosub OUVRE_BATCH_SYNLOC
  When "INIT"         : Gosub INIT_SYNLOC
  When "EXEC"         : Gosub EXEC_SYNLOC
  When "TERMINE"      : Gosub TERMINE_SYNLOC
  When "INIT_DIA"     : Gosub INIT_DIA_SYNLOC
  When "OK"           : Gosub OK_SYNLOC
  When "END"          : Gosub END_SYNLOC
Endcase 
Return
############################################################
$OUVRE_BATCH_SYNLOC
Gosub OPEN_FILE
Return
############################################################
$INIT_SYNLOC
Gosub OPEN_FILE
Return
#############################################################
$EXEC_SYNLOC
Local Char    WFIL(250) 
WFIL = "1=1"
Local Char    WFIL2(250)  # hcb 49062
WFIL2 = "1=1"             # hcb 49062

Local Integer LRET
#
If GSERVEUR
  Onerrgo ERRBATCH

  Call ECR_TRACE(mess(896,196,1),0) From GESECRAN

  If [M:CITH]TOUSITE = 2
     Call ECR_TRACE("-"-mess(4,116,1),0) From GESECRAN      # Tous sites 
  Endif
  If [M:CITH]STOFCY <> ""
     Call ECR_TRACE("-"-mess(565,197,1)-" : "-[M:CITH]STOFCY,0) From GESECRAN      # Site de stockage
  Endif
  If [M:CITH]ITMREFEND <> ""
   Call ECR_TRACE("-"-mess(569,197,1)-" : "-[M:CITH]ITMREFSTR-" / "-[M:CITH]ITMREFEND,0) From GESECRAN  # Article
  Endif

Else
  Call OUVRE_TRACE(mess(896,196,1)) From LECFIC 
  Call ECR_TRACE(mess(896,196,1),0) From GESECRAN

  If [M:CITH]TOUSITE = 2
     Call ECR_TRACE("-"-mess(4,116,1),0) From GESECRAN      # Tous sites 
  Endif
  If [M:CITH]STOFCY <> ""
     Call ECR_TRACE("-"-mess(565,197,1)-" : "-[M:CITH]STOFCY,0) From GESECRAN      # Site de stockage
  Endif
  If [M:CITH]ITMREFEND <> ""
     Call ECR_TRACE("-"-mess(569,197,1)-" : "-[M:CITH]ITMREFSTR-" / "-[M:CITH]ITMREFEND,0) From GESECRAN  # Article
  Endif

Endif

If [M:CITH]STOFCY <> ""
    WFIL  += "&[F:ITH1]STOFCY=[M:CITH]STOFCY"
    WFIL2 += "&[F:ITH1]STOFCY=[M:CITH]STOFCY"   # hcb 49062
Endif

If [M:CITH]ITMREFSTR <> ""
  WFIL += "& [F:ITH1]ITMREF >= [M:CITH]ITMREFSTR" 
Endif
If [M:CITH]ITMREFEND <> ""
  WFIL += "& [F:ITH1]ITMREF <= [M:CITH]ITMREFEND"
Endif                                                       

Call TEMPON ("O") From GESECRAN
Gosub TRAITEMENT
Call TEMPOFF      From GESECRAN

Call ECR_TRACE(mess(895,196,1)-num$(WNBPER),0)  From GESECRAN   # Nombre de periodes créés  


Onerrgo
Return
#############################################################
$TERMINE_SYNLOC
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  Return
Endif

Return
#############################################################
$INIT_DIA_SYNLOC
Raz [M:CITH]
[M:CITH]TOUSITE  = 2
Return
#############################################################
$OK_SYNLOC
FIN  = 1
Return
#############################################################
$END_SYNLOC
Raz [M:CITH]
FIN = 1
Return
############################################################
$OPEN_FILE
If clalev([F:ITH])   = 0 : Local File ITMMVTHIS [ITH]  : Endif
If clalev([F:ITH1])  = 0 : Local File ITMMVTHIS [ITH1]  : Endif
If clalev([F:PER1])  = 0 : Local File PERIOD    [PER1]  : Endif
If clalev([F:PER2])  = 0 : Local File PERIOD    [PER2]  : Endif                       # hcb 49062
If clalev([F:ITM])   = 0 : Local File ITMMASTER [ITM]  : Endif
Return
############################################################
#Création des périodes non mouvementées ITMMVTHIS
###########################################################
$TRAITEMENT
#
Local Char    WITMREF(GLONITM) : # 05/2008 V6 avant (20)
Local Char    WSTOFCY(GLONFCY)  : # 05/2008 V6 avant (3)
Local Integer WNBPER

Local Shortint WFIYNUM 
Local Date     WPERSTR

Raz WITMREF 
Raz WSTOFCY 
Raz WNBPER
Raz WFIYNUM
Raz WPERSTR
Gosub OPEN_FILE
# premiere boucle
#    recherche premiere periode existente PERIOD / ITMMVTHIS quel que soit l article 

Columns [ITH1] (ITMREF, STOFCY) 
Filter [ITH1]  Where evalue(WFIL2)
&              Order By Key ITH1

For [ITH1]
    If WITMREF <> [F:ITH1]ITMREF | [F:ITH1]STOFCY <> WSTOFCY 
       WITMREF =  [F:ITH1]ITMREF
# recuperation GSOCIETE
       WSTOFCY = [F:ITH1]STOFCY  
       Call GETDEV([F:ITH1]STOFCY) From DEVSUB
       Link [ITH] With [PER2]PER0=GSOCIETE;1;[F:ITH]FIYNUM;[F:ITH]PERNUM
&           As [LNK]
&              Where [F:ITH]PERSTR = [F:PER2]PERSTR
&                 &  ITMREF        = [F:ITH1]ITMREF
&                 &  STOFCY        = [F:ITH1]STOFCY
&              Order By Key ITH0  
               Raz [F:ITH],[F:PER2] 
               For [LNK]  
#  Stockage  depart des periodes à controler
                   If ([F:ITH]FIYNUM <  WFIYNUM) | WFIYNUM = 0 
                      WFIYNUM     = [F:ITH]FIYNUM
                      WPERSTR     = [F:ITH]PERSTR
                   Else
                      If [F:ITH]PERSTR <  WPERSTR 
                         WPERSTR     = [F:ITH]PERSTR
                      Endif
                   Endif
               Next
    Endif 
Next
Filter [ITH1]
Columns [ITH1]

Raz WITMREF 

# deuxieme boucle
#    creation periode inexistante dans ITMMVTHIS 
$BOUCLE_ITH1

Columns [ITH1] (ITMREF, STOFCY) 
Filter [ITH1]  Where evalue(WFIL)
&                Order By Key ITH1

For [ITH1]
    If WITMREF <> [F:ITH1]ITMREF 
       WITMREF =  [F:ITH1]ITMREF
       Gosub TRT_ITH
    Endif 
Next
Filter [ITH1]
Columns [ITH1]


Return


###########################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
PRET = 1
End

#################################################
$TRT_ITH
Local Date     WDATEND
Local Integer  WCRE
# recuperation GSOCIETE
If [F:ITH1]STOFCY <> WSTOFCY
   WSTOFCY = [F:ITH1]STOFCY  
   Call GETDEV([F:ITH1]STOFCY) From DEVSUB
Endif


# Lecture article 
Read [ITM]ITM0=[F:ITH1]ITMREF
If fstat 
   Return
Endif

WDATEND = date$
If [F:ITM]LIFENDDAT <> [0/0/0]
   If [F:ITM]LIFENDDAT < date$
      WDATEND = [F:ITM]LIFENDDAT
   Endif
Endif
Call DEBTRANS From GLOCK
Trbegin [ITH]

# lecture PERIOD sur societe , exercice et periode 

Filter [PER1] Where CPY    = GSOCIETE 
&                 & FIYNUM >= WFIYNUM
&                 & PERSTR >= WPERSTR 
&                 & PERSTR <= WDATEND 
&                 & LEDTYP =  1
&             Order By Key PER0 Asc

For [PER1]
    Call GETITH([F:ITH1]ITMREF,[F:ITH1]STOFCY,[F:PER1]PERSTR,0,WCRE) From STKLIB
    If fstat
       Call FSTA("ITH") From GLOCK 
       Break  
    Endif
    WNBPER += (WCRE<>0)
Next
Filter [PER1]
Commit 
Return


 
