#<AdxTL>@(#)0.0.0.0 $Revision$
Call OBJET("AAR",GBIDC1,GBIDC2) From GOBJET
End

################################################
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "SETBOUT"   : Gosub SETBOUT
 When "LIENS"     : Gosub LIENS
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "APRES_MOD" : Gosub APRES_MOD
 When "CREATION"  : Gosub CREATION
 When "INICRE"    : Gosub INICRE
Endcase
Return

$OUVRE
If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
Local Integer NOL

# Pour SCM
Local Integer ATAB_NB,ATAB_I
Local Char    ATAB_CODPAR(GLONAAR)(1..)
Local Char    ATAB_TYPTRA(10)(1..)
Return

$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
Return

$LIENS
Call TEXTE([F:AAR]INTITPAR,[M]ZINTITPAR(nolign-1)) From OBJDIV
Return

$VERIF_MOD
Raz [L]ATAB_NB,ATAB_CODPAR,ATAB_TYPTRA
For I=0 To [M]NBLIG-1
 Read [AAR]CODPAR = [M]CODPAR(I)
 If fstat
  [M]MODIF(I) = 2
 Elsif [F:AAR]TYPPAR<>[M]TYPPAR(I) or [F:AAR]INTITPAR<>[M]INTITPAR(I)
  [M]MODIF(I) = 1
 Else
  [M]MODIF(I) = 0
 Endif
Next I
If GADONIX=2
 For I=0 To [M]NBLIG-1
  Read [AAR]CODPAR = [M]CODPAR(I)
  If fstat
   # Call TRACE_COR(ABREV,[M]CODPAR(I),"","C") From GOBJET
   [L]ATAB_NB +=1
   [L]ATAB_CODPAR([L]ATAB_NB) = [M]CODPAR(I)
   [L]ATAB_TYPTRA([L]ATAB_NB) = "C"
  Endif
 Next I
 For [AAR]
  I = find([F:AAR]CODPAR,[M]CODPAR(0..[M]NBLIG-1))
  If I=0
   #Call TRACE_COR(ABREV,[F:AAR]CODPAR,"","A") From GOBJET
   [L]ATAB_NB +=1
   [L]ATAB_CODPAR([L]ATAB_NB) = [F:AAR]CODPAR
   [L]ATAB_TYPTRA([L]ATAB_NB) = "A"
  Elsif [F:AAR]TYPPAR<>[M]TYPPAR(I-1) or [F:AAR]INTITPAR<>[M]INTITPAR(I-1)
   #Call TRACE_COR(ABREV,[F:AAR]CODPAR,"","M") From GOBJET
   [L]ATAB_NB +=1
   [L]ATAB_CODPAR([L]ATAB_NB) = [F:AAR]CODPAR
   [L]ATAB_TYPTRA([L]ATAB_NB) = "M"
  Endif
 Next
Endif
NOL = nolign
Return

$APRES_MOD
SUIZON = "[M]NBLIG("+num$(NOL-1)+")"
For ATAB_I=1 To [L]ATAB_NB
 Call TRACE_COR(ABREV,[L]ATAB_CODPAR([L]ATAB_I),"", [L]ATAB_TYPTRA([L]ATAB_I)) From GOBJET
Next
Return

$INICRE
Case [M]MODIF(nolign-1)
 When 0
  If dim([F:AAR]CREUSR)>0 & dim([M]CREUSR)>0 : [F:AAR]CREUSR = [M]CREUSR(nolign-1) : Endif
  If dim([F:AAR]CREDAT)>0 & dim([M]CREDAT)>0 : [F:AAR]CREDAT = [M]CREDAT(nolign-1) : Endif
  If dim([F:AAR]UPDUSR)>0 : [F:AAR]UPDUSR = ""      : Endif
  If dim([F:AAR]UPDDAT)>0 : [F:AAR]UPDDAT = [0/0/0] : Endif
 When 1 : # Modification
  If dim([F:AAR]CREUSR)>0 & dim([M]CREUSR)>0 : [F:AAR]CREUSR = [M]CREUSR(nolign-1) : Endif
  If dim([F:AAR]CREDAT)>0 & dim([M]CREDAT)>0 : [F:AAR]CREDAT = [M]CREDAT(nolign-1) : Endif
  If dim([F:AAR]UPDUSR)>0 : [F:AAR]UPDUSR = GUSER   : Endif
  If dim([F:AAR]UPDDAT)>0 : [F:AAR]UPDDAT = date$   : Endif
 When 2 : # Création
  If dim([F:AAR]CREUSR)>0 : [F:AAR]CREUSR = GUSER   : Endif
  If dim([F:AAR]CREDAT)>0 : [F:AAR]CREDAT = date$   : Endif
  If dim([F:AAR]UPDUSR)>0 : [F:AAR]UPDUSR = ""      : Endif
  If dim([F:AAR]UPDDAT)>0 : [F:AAR]UPDDAT = [0/0/0] : Endif
Endcase
Return

$CREATION
For I=0 To [M]NBLIG-1
 If [M]MODIF(I)>0
  For [ATR]CODPAR Where CODPAR=[M]CODPAR(I)
   [F:ATR]TYPPAR = [M]TYPPAR(I)
   [F:ATR]INTITPAR = [M]INTITPAR(I)
   Rewrite [ATR]
   If fstat
    GOK = 0 : Call FSTA("ATR") From GLOCK : Break 2
   Endif
  Next
 Endif
Next I
Return

###########################################
$TRTCOP
If [M]DOSORG=nomap
 Local File ACTCODPAR [AAR1]
 Local File ATEXTE    [ATX1]
Else
 Local File =[M]DOSORG+".ACTCODPAR" [AAR1]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1]
Endif
If [M]DOSDES=nomap
 Local File ACTPAR    [ATR2]
 Local File ACTCODPAR [AAR2]
 Local File ATEXTE    [ATX2]
Else
 Local File =[M]DOSDES+".ACTPAR"    [ATR2]
 Local File =[M]DOSDES+".ACTCODPAR" [AAR2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AAR1], [ATX1], [ATR2], [AAR2], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [ATR2] , [AAR2] , [ATX2]
 Read [AAR1]CODPAR = TABLE
 If !fstat
  Readlock [AAR2]CODPAR = TABLE
  If fstat=1
   GOK=-1 : GLOCK = "$ACTCODPAR"-TABLE : Goto ROLL_TR_COP
  Elsif fstat
   [F:AAR2] = [F:AAR1]
   Call COPTEXTE([F:AAR1]INTITPAR,[F:AAR2]INTITPAR) From OBJDIV
   If GOK<1 : Goto AB_TR_COP : Endif
   Write [AAR2]
  Else
   [F:AAR2] = [F:AAR1]
   Call COPTEXTE([F:AAR1]INTITPAR,[F:AAR2]INTITPAR) From OBJDIV
   If GOK<1 : Goto AB_TR_COP : Endif
   Rewrite [AAR2]
  Endif
  If fstat
   GOK=0 : Call FSTA("AAR2") From GLOCK : Goto AB_TR_COP
  Endif
  For [ATR2]CODPAR Where CODPAR=TABLE
   Call COPTEXTE([F:AAR1]INTITPAR,[F:ATR2]INTITPAR) From OBJDIV
   If GOK<1 : Break : Endif
   [F:ATR2]TYPPAR = [F:AAR1]TYPPAR
   Rewrite [ATR2]
   If fstat
    GOK=0 : Call FSTA("ATR2") From GLOCK : Break
   Endif
  Next
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#########################################################################
# Etiquettes du masque AAR1
#########################################################################
Subprog AS_CODPAR(VALEUR)
Variable Char    VALEUR()
If clalev([F:AAR])=0 : Local File ACTCODPAR [AAR] : Endif
If VALEUR <> ""
 Look [AAR]CODPAR = VALEUR
 If !fstat : mkstat = 2 : Endif
Endif
End

Subprog C_CODPAR(VALEUR)
Variable Char VALEUR()
If VALEUR<>"" & [M]CODPAR(nolign-1)<>""
 If clalev([F:ATR])=0 : Local File ACTPAR [ATR] : Endif
 Filter [ATR] Where CODPAR=[M]CODPAR(nolign-1)
 Read [ATR] First
 Filter [ATR]
 If !fstat
  GMESSAGE = mess(9,123,1) : # Modification impossible
  VALEUR = [M]CODPAR(nolign-1) : mkstat = 2 : End
 Endif
Elsif VALEUR=""
 mkstat = 2
Endif
Call UNICITE(VALEUR,[M]CODPAR) From OBJDIV
End

Subprog AS_TYPPAR(VALEUR)
Variable Integer VALEUR
If clalev([F:AAR])=0 : Local File ACTCODPAR [AAR] : Endif
Look [AAR]CODPAR = [M]CODPAR(nolign-1)
If !fstat : mkstat = 2 : Endif
GMENLOC(8) = 1
End

######################################################################################

