# Modèle
#If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]AASREF = [F:DEPC]AASREF and [F:DEPC]DPRPLN = [F:DEPC]DPRPLN ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif


#
#########################################################
Subprog  CALCUL_CUMUL_E_1
#
# - Objet  :
#
#
# - Entrée : Cette fonction évalue le champ cumul E-1
#
#            Si le cumul E-1 n'est pas forcé, le Cumul E-1 est recalculé.
#               Si la situation antérieure peut être remise en cause
#                 le cumul E-1 annule et remplace le précédent.
#               Sinon
#                 le cumul E-1 reste à 0.
#                 le cumul E-1 calculé complétera la dot. Exe. "Courant" et la Dot. Pér. "courante".
#
#            Si un changement de méthode avec prise d'effet "Début d'amortissement"
#               a été réalisé et qu'il existe un cumul E-1. L'écart entre l'ancien et le nouveau
#               cumul est calculé afin qu'il soit réintégré selon la modalité choisie.
#               Si la modalité de réintégration du cumul E-1 est "Report à nouveau".
#                 le nouveau cumul annule et remplace le précédent (même s'il est forcé).
#
# - Sortie : [F:DEPn]
#            [F:DEPC]DPRCUM         Cumul d'amortissement antérieur
#            [F:DEPC]DPRCUMFLG      Indicateur Cumul d'amortissement à recalculer
#            [F:DEPC]MTCDPEDEV      Ecart cumul antérieur suite à changement de méthode
#
#   Boite noire
#

Local Decimal WCUME_1

Local Decimal WECACUME_1R
Local Decimal WECACUME_1T
Local Decimal WECACUME_1I
Local Decimal WCUME_1R
Local Decimal WCUME_1T
Local Decimal WCUME_1I
Local Decimal WEXCE_1R
Local Decimal WEXCE_1T
Local Decimal WEXCE_1I
Local Decimal WAFIE_1
Local Decimal WVEHE_1

Raz WECACUME_1R
Raz WECACUME_1T
Raz WECACUME_1I
Raz WCUME_1R
Raz WCUME_1T
Raz WCUME_1I
Raz WEXCE_1R
Raz WEXCE_1T
Raz WEXCE_1I
Raz WAFIE_1
Raz WVEHE_1

Raz [M:DIV]ECACUME_1R
Raz [M:DIV]ECACUME_1T
Raz [M:DIV]ECACUME_1I

Raz [M:DIV]PRVCUME_1R
Raz [M:DIV]PRVCUME_1I
Raz [M:DIV]PRVCUME_1T


#If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]BCUME_1 = 1
  # Sauvegarde du cumul E-1
  WCUME_1 = [F:DEPC]DPRCUM

  # ---------------------------------------------
  # - RECONSTITUTION CUM E-1
  # ---------------------------------------------
  # Le cumul d'amortissement n'est pas forcé, il doit être calculé
  #-1 ------------------------------
  # FQ97127
  #If ( [F:DEPC]DPM <> G_DPMUO and [F:DEPC]DPM <> G_DPMUR and [F:DEPC]DPM <> G_DPMSA ) Then
  If ( [F:DEPC]DPM <> G_DPMUO and [F:DEPC]DPM <> G_DPMUR ) Then

    #-2 ------------------------------
    # FQ73777
    If ( ( [F:DEPC]DPRCUMFLG <> G_OUI ) ) Then
      # Recalcul du cumul & actualisation
      [M:DIV]LVLLIB = "3.CAL_CUMUL_E_1 (Reconst.)" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call CAL_CUMUL_E_1 ( WCUME_1R, WCUME_1T, WCUME_1I,
&          WEXCE_1R, WEXCE_1T, WEXCE_1I, WAFIE_1, WVEHE_1) From =G_GLOB3
      If ([M:DIV]ERROR) Then : End : Endif
      # Actualisation Cumul E-1
      # -- Cumul Dotation
      [F:DEPC]DPRCUM      = WCUME_1R
      [F:DEPC]EXECLOCUMT  = WCUME_1T
      [F:DEPC]EXECLOCUMI  = WCUME_1I
      # -- Cumul Amortissement exceptionnel
      [F:DEPC]EXCCUM      = WEXCE_1R
      [F:DEPC]EXCCUMT     = WEXCE_1T
      [F:DEPC]EXCCUMI     = WEXCE_1I
      # -- Cumul Aide fiscale
      [F:DEPC]ALWCUM      = WAFIE_1
      # -- Cumul Réintégration véhicule
      [F:DEPC]CRBCUM      = WVEHE_1

      # Application de la règle du minimum après reconstitution des cumuls
      If ( [F:DEPC]DPRPLN = G301FIS and [M:DIV]PLNMIN  ) Then
        If ( [F:DEPC]ALWCOD = GVML_RPALOGI ) Then
          # Pas d'application de la règle du minimum pour les logiciels (JRI-14/01/2008)
        Else
          If ( abs([M:PMIN]DPRCUM([M:DIV]DPC-1)) > abs([F:DEPC]DPRCUM ) and
&              ( [F:DEPC]DPRCUM = [F:DEPC]EXECLOCUMT and [F:DEPC]ENDDPE = [F:DEPC]ENDDPET )  ) Then
            # Le cumul exercice fiscale hérite de celui  l'amortissement minimum fiscal
            # si ce dernier lui est supérieur et que le plan fiscal n'a pas été déprécié
            Call ECR_FICH("FS1", 5,
&           "Application règle du MINIMUM"-format$([M:DIV]CURFMT,[M:PMIN]DPRCUM([M:DIV]DPC-1))-"=>"-
&           format$([M:DIV]CURFMT,[F:DEPC]DPRCUM) ) From =G_GLOB0
            [F:DEPC]DPRCUM      = [M:PMIN]DPRCUM([M:DIV]DPC-1)
            [F:DEPC]EXECLOCUMI  = [M:PMIN]DPRCUM([M:DIV]DPC-1)
            [F:DEPC]EXECLOCUMT  = [M:PMIN]DPRCUM([M:DIV]DPC-1)
          Endif
        Endif
      Endif
    Endif
    #-2 ------------------------------
  Endif
  #-1 ------------------------------

  # ---------------------------------------------
  # - ECART CUM E-1
  # ---------------------------------------------
  #-1 ------------------------------
  If ( [F:DEPC]STRDPRDAT < [F:DEPC]FIYSTRDAT ) Then
    # A ne pas faire si la remise en cause de la situation est interdite et que le cumul est forcé à 0.
    #-2 ------------------------------
    # FQ97127
    #If ( [F:DEPC]MTCDEVADJ <> 0 and [F:DEPC]DPM <> G_DPMUO )     Then
    If ( [F:DEPC]MTCTIATYP = GVML_PEDBAM and [F:DEPC]DPM <> G_DPMUO )     Then
      # Changement de méthode pour un mode différent de "Unité d'oeuvre"
      #-3 ------------------------------
      # Dans le cas d'un recalcul, il faut selon les cas
      If ( [F:DEPC]MTCDEVADJ = GVML_RREPAN ) Then
        # Report à nouveau, il faut reintégrer l'écart sur cumul pour obtenir de nouveau l'ancien
        [F:DEPC]DPRCUM     -= [F:DEPC]MTCDPEDEV
        [F:DEPC]EXECLOCUMT -= [F:DEPC]MTCDPEDEVT
        [F:DEPC]EXECLOCUMI -= [F:DEPC]MTCDPEDEVI
      Endif
      #-3 ------------------------------
      # Calcul de l'ecart Cumul E-1 suite à un changement de méthode
      # F103697_1
#      If [F:DEPC]MTCDEVADJ = GVML_RREPAN or
#&        func GLOBB9.CAL_DAT_INSIDE([F:DEPC]MTCTIADAT, [F:DEPC]PERSTRDAT,[F:DEPC]PERENDDAT,"I") Then
      # FQ103913
      If [F:DEPC]MTCDEVADJ = GVML_RREPAN or
&        ([F:DEPC]MTCTIADAT <> [0/0/0] and [F:DEPC]MTCTIADAT < [F:DEPC]FIYSTRDAT and [F:DEPC]MTCDPEDAT <> [0/0/0]) Then
        [M:DIV]LVLLIB = "3.CAL_ECART_CUMUL_E_1 (Chg méth.)" : Gosub CAL_ADDLVL  From =G_GLOB0
        Call CAL_ECART_CUMUL_E_1
&            ([M:DIV]ECACUME_1R, [M:DIV]ECACUME_1T, [M:DIV]ECACUME_1I) From =G_GLOB3
        If ([M:DIV]ERROR) Then : End : Endif

        [F:DEPC]MTCDPEDEV  = [M:DIV]ECACUME_1R
        [F:DEPC]MTCDPEDEVT = [M:DIV]ECACUME_1T
        [F:DEPC]MTCDPEDEVI = [M:DIV]ECACUME_1I

        # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
        # E   Point d'entrée    AFTECAE_1  FQ104730     E
        # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
        If ( G_ETP_GLOBI2 ) Then : # FQ114113
          GPOINT = "AFTECAE_1"
          Gosub ENTREE From EXEFNC
          If !(GOK) Then
          [M:DIV]ERRID = 9000 : End
          Endif
        Endif
#CHECK IGNORE_END
        # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

      Else
        # Le changement de méthode n'a pas eu lieu dans l'exercice on conserve l'écart eventuellement calculé
        [M:DIV]ECACUME_1R  = [F:DEPC]MTCDPEDEV
        [M:DIV]ECACUME_1T  = [F:DEPC]MTCDPEDEVT
        [M:DIV]ECACUME_1I  = [F:DEPC]MTCDPEDEVI
      Endif

      #-3 ------------------------------
      If ( [F:DEPC]MTCDEVADJ = GVML_RREPAN ) Then
        # Lorsque suite à un changement de méthode
        # la modalité de gestion de l'écart E-1 est "Report à nouveau"
        # Le nouveau cumul d'amortissement annule et remplace l'ancien.
        Call ECR_FICH("FS1", 10, "Chgt méth. avec rattrapage écart E-1 en REPORT A NOUVEAU" ) From =G_GLOB0
        Call ECR_FICH("FS1", 10, "L'écart E-1 annule et remplace les cumul E-1 (I,T,R)" ) From =G_GLOB0
        [F:DEPC]DPRCUM     += [M:DIV]ECACUME_1R
        [F:DEPC]EXECLOCUMT += [M:DIV]ECACUME_1T
        [F:DEPC]EXECLOCUMI += [M:DIV]ECACUME_1I
      Endif
      #-3 ------------------------------
    Elsif( [F:DEPC]DPM = G_DPMCA and [F:DEPC]ALWCOD = GVML_RPCONCE ) Then
    #-2 ------------------------------
        # Mode "Caducité sur valeur brute" et Règle Part. "Régul/Reint. amortissement"

        # Calcul systématique de l'ecart Cumul E-1
        [M:DIV]LVLLIB = "3.CAL_ECART_CUMUL_E_1 (CA/Conces.)" : Gosub CAL_ADDLVL  From =G_GLOB0
        Call ECR_FICH("FS1", 10, "Caducité / valeur brute avec règle 'Régul/Reint. amortissement' " ) From =G_GLOB0
        Call ECR_FICH("FS1", 10, "Les écarts E-1 (I,T,R) sont sytématiquement calculés " ) From =G_GLOB0
        Call CAL_ECART_CUMUL_E_1
&            ([M:DIV]ECACUME_1R, [M:DIV]ECACUME_1T, [M:DIV]ECACUME_1I) From =G_GLOB3
        If ([M:DIV]ERROR) Then : End : Endif
    Endif
    #-2 ------------------------------
  Endif
  #-1 ------------------------------

  [M:DIV]BCUME_1 = 0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#########################################################
Subprog  CALCUL_EXERCICE
#
# - Objet  :
#
#
# - Entrée : Cette fonction évalue le champ cumul E-1
#
#
# - Sortie : [F:DEPn]
#
#   Boite noire
#



  If ([F:DEPC]ENDDPEFLG <> G_OUI ) Then
    [F:DEPC]ENDDPE = 0
  Endif
  [F:DEPC]EXCDPR = 0

  #-1 ------------------------------
  If !([M:DIV]BSTPCLC) Then

    # Calcul de la dotation de l'exercice
    [M:DIV]LVLLIB = "3.DOTATION_EXERCICE" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call DOTATION_EXERCICE  From =G_GLOB3
    If ([M:DIV]ERROR) Then : End : Endif

    #=================
    # Reintégration Véhicule
    #=================

    [M:DIV]LVLLIB = "6.CAL_REINT_VEH" : Gosub CAL_ADDLVL  From =G_GLOB0

#    FQ106650
#    Call CAL_REINT_VEH ( [F:DEPC]CRBVEHCOD, [F:DEPC]ENDDPE, [F:DEPC]DPRBAS,
#&                        [F:DEPC]CRBCUM,    [F:DEPC]CRBAMT ) From =G_GLOB6
    Call CAL_REINT_VEH ( [F:DEPC]CRBVEHCOD, [F:DEPC]ENDDPE, [F:DEPC]DPRBAS,
&                        [F:DEPC]CRBCUM,    [M:DIV]DTFNAMT, [F:DEPC]FIYSTRDAT, [F:DEPC]FIYENDDAT, [F:DEPC]CRBAMT ) From =G_GLOB6

    #-- Valeur nette initiale,thèorique & réelle fin de période ( HORS valeur résiduelle)
    #-- Quand le bien sera totalement amorti, la valeur nette sera égale à la valeur résiduelle
    [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - IFE" : Gosub CAL_ADDLVL  From =G_GLOB0
    #Call CAL_VALEUR_NETTE ( "IFE", [F:DEPC]BSEVAL, 0, [M:DIV]BMDR, [F:DEPC]NBVI ) From =G_GLOB4
    [M:DIV]PC(0)= "IFE" : [M:DIV]PV(0)= [F:DEPC]BSEVAL : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
    Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
    [F:DEPC]NBVI= [M:DIV]RV(1)
    #Call CAL_VALEUR_NETTE ( "TFE", [F:DEPC]DPRBAS, 0, [M:DIV]BMDR, [F:DEPC]NBVT ) From =G_GLOB4
    [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - TFE" : Gosub CAL_ADDLVL  From =G_GLOB0
    [M:DIV]PC(0)= "TFE" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
    Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
    [F:DEPC]NBVT= [M:DIV]RV(1)
    [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - RFE" : Gosub CAL_ADDLVL  From =G_GLOB0
    #Call CAL_VALEUR_NETTE ( "RFE", [F:DEPC]DPRBAS, 0, [M:DIV]BMDR, [F:DEPC]NBV  ) From =G_GLOB4
    [M:DIV]PC(0)= "RFE" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
    Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
    [F:DEPC]NBV = [M:DIV]RV(1)


  Endif
  #-1 ------------------------------

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog  CALCUL_PERIODE
#
# - Objet  :
#
#
# - Entrée : Cette fonction évalue le champ cumul E-1
#
#
# - Sortie : [F:DEPn]
#
#   Boite noire
#


Local Decimal WVALNET

  #If ( [M:DIV]BDEBUG and [F:DEPC]PERENDDAT=[30/12/2009]) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If (  [M:DIV]BDEBUG and [F:DEPC]DPRPLN = G301CPT and [F:DEPC]PERSTRDAT = [01/01/2010] ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  #-1 ------------------------------
  If !([M:DIV]BSTPCLC) Then

    #-2 -------------------------------
    If ( [M:DIV]DEBCLCPER ) Then

      [M:DIV]DEBCLCPER = 0
      #--
      # FQ106778_1
      [M:DIV2]BSOLDPER = G_NON
      #-----------------------
      # Traitement de début
      #-----------------------

      [M:DIV]RGLDATMTC = [F:DEPC]MTCTIATYP
      [M:DIV]RGLECAE_1 = [F:DEPC]MTCDEVADJ

      #-- REEL
      #--------------------------------
      # FQ74785 If ( [F:DEPC]PERREFCLC <> [F:DEPC]FIYSTRDAT  ) Then
      If ( ![M:DIV]BSRA and [F:DEPC]PERREFCLC <> [F:DEPC]FIYSTRDAT  ) Then
        # En prospectif, il ne faut pas tenir compte du cumul P-1 déjà constaté
        # La dotation période est égale à Dotation [Déb Pér.,Fin Per Cour.]
        [M:DIV]PERDATREFR  = [F:DEPC]PERSTRDAT
        [M:DIV]CUMP_1R     = 0
        [M:DIV]CUMEXCP_1R  = 0  : # FQ104870
      Else
        # Par défaut, la dotation période est égale à  Dotation [Déb Ex.,Fin Per Cour.] - Cumul P-1
        [M:DIV]PERDATREFR  = [F:DEPC]FIYSTRDAT
        [M:DIV]CUMP_1R     = [F:DEPC]PERCLOCUM
        [M:DIV]CUMEXCP_1R = [F:DEPC]PERCLOEXC  : # FQ104870
        #
        # FQ102893 If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and [F:DEPC]MTCDPEDAT = [0/0/0]  ) Then
        # FQ120486
        If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and [F:DEPC]MTCDPEDAT = [0/0/0] and not [M:DIV]BSRA  ) Then
          # En cas de calcul sur une période ultérieure au rattrapage il ne faut plus tenir compte de l'écart
          [M:DIV]CUMP_1R  -= [M:DIV]ECACUME_1R
        Endif

        # FQ104870
        If ( [M:DIV]RGLECAE_1 = GVML_REXCPER and [F:DEPC]MTCDPEDAT = [0/0/0]  ) Then
          # En cas de calcul sur une période ultérieure au rattrapage il ne faut plus tenir compte de l'écart
          [M:DIV]CUMEXCP_1R  -= [M:DIV]ECACUME_1R
        Endif
        # FQ100742 recadrage par rapport au début du plan de production
        If ([F:DEPC]DPM = G_DPMUO and [M:PPL]PERSTRDAT(0) > [F:DEPC]FIYSTRDAT ) Then
          [M:DIV]PERDATREFR  = [M:PPL]PERSTRDAT(0)
        Endif
      Endif

      #-- THEORIQUE
      #--------------------------------
      # FQ74785 If ( [F:DEPC]PERREFCLCT <> [F:DEPC]FIYSTRDAT ) Then
      If ( ![M:DIV]BSRA and [F:DEPC]PERREFCLCT <> [F:DEPC]FIYSTRDAT ) Then
        # En prospectif, il ne faut pas tenir compte du cumul P-1 déjà constaté
        # La dotation période est égale à Dotation [Déb Pér.,Fin Per Cour.]
        [M:DIV]PERDATREFT   = [F:DEPC]PERSTRDAT
        [M:DIV]CUMP_1T      = 0
        [M:DIV]CUMEXCP_1T = 0 : # FQ104870
      Else
        # Par défaut, la dotation période est égale à  Dotation [Déb Ex.,Fin Per Cour.] - Cumul P-1
        [M:DIV]PERDATREFT   = [F:DEPC]FIYSTRDAT
        [M:DIV]CUMP_1T      = [F:DEPC]PERCLOCUMT
        [M:DIV]CUMEXCP_1T = [F:DEPC]PERCLOEXCT    : # FQ104870
        # FQ102893 If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and [F:DEPC]MTCDPEDAT = [0/0/0]  ) Then
        # FQ120486
        If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and [F:DEPC]MTCDPEDAT = [0/0/0] and not [M:DIV]BSRA  ) Then
          # En cas de calcul sur une période ultérieure au rattrapage il ne faut plus tenir compte de l'écart
          [M:DIV]CUMP_1T  -= [M:DIV]ECACUME_1T
        Endif
        # FQ104870
        If ( [M:DIV]RGLECAE_1 = GVML_REXCPER and [F:DEPC]MTCDPEDAT = [0/0/0]  ) Then
          # En cas de calcul sur une période ultérieure au rattrapage il ne faut plus tenir compte de l'écart
          [M:DIV]CUMEXCP_1T  -= [M:DIV]ECACUME_1T
        Endif
        # FQ100742 recadrage par rapport au début du plan de production
        If ([F:DEPC]DPMT = G_DPMUO and [M:PPL]PERSTRDAT(0) > [F:DEPC]FIYSTRDAT ) Then
          [M:DIV]PERDATREFT  = [M:PPL]PERSTRDAT(0)
        Endif
      Endif

      #-- INITIAL
      #--------------------------------
      # FQ74785 If ( [F:DEPC]PERREFCLCI <> [F:DEPC]FIYSTRDAT  ) Then
      If ( ![M:DIV]BSRA and [F:DEPC]PERREFCLCI <> [F:DEPC]FIYSTRDAT  ) Then
        # En prospectif, il ne faut pas tenir compte du cumul P-1 déjà constaté
        # La dotation période est égale à Dotation [Déb Pér.,Fin Per Cour.]
        [M:DIV]PERDATREFI   = [F:DEPC]PERSTRDAT
        [M:DIV]CUMP_1I      = 0
        [M:DIV]CUMEXCP_1I   = 0  : # FQ104870
      Else
        # Par défaut, la dotation période est égale à  Dotation [Déb Ex.,Fin Per Cour.] - Cumul P-1
        [M:DIV]PERDATREFI   = [F:DEPC]FIYSTRDAT
        [M:DIV]CUMP_1I      = [F:DEPC]PERCLOCUMI
        [M:DIV]CUMEXCP_1I = [F:DEPC]PERCLOEXCI    : # FQ104870

        # FQ102893 If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and [F:DEPC]MTCDPEDAT = [0/0/0]  ) Then
        # FQ120486
        If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and [F:DEPC]MTCDPEDAT = [0/0/0] and not [M:DIV]BSRA  ) Then
          # En cas de calcul sur une période ultérieure au rattrapage il ne faut plus tenir compte de l'écart
          [M:DIV]CUMP_1I  -= [M:DIV]ECACUME_1I
        Endif
        # # FQ104870
        If ( [M:DIV]RGLECAE_1 = GVML_REXCPER and [F:DEPC]MTCDPEDAT = [0/0/0]  ) Then
          # En cas de calcul sur une période ultérieure au rattrapage il ne faut plus tenir compte de l'écart
          [M:DIV]CUMEXCP_1I  -= [M:DIV]ECACUME_1I
        Endif
        # FQ100742 recadrage par rapport au début du plan de production
        If ([F:DEPC]DPMI = G_DPMUO and [M:PPL]PERSTRDAT(0) > [F:DEPC]FIYSTRDAT ) Then
          [M:DIV]PERDATREFI  = [M:PPL]PERSTRDAT(0)
        Endif
      Endif

      # Evaluation Cumul amortissement exceptionnel P-1
      #---------------------------------------------------------------------------
      # (initialisé avec le cumul de l'amortissement exceptionnel des périodes réellement closes )
      #FQ104870
      #[M:DIV]CUMEXCP_1R = [F:DEPC]PERCLOEXC
      #[M:DIV]CUMEXCP_1I = [F:DEPC]PERCLOEXCI
      #[M:DIV]CUMEXCP_1T = [F:DEPC]PERCLOEXCT

      # Evaluation Montant à repartir sur les périodes non closes de l'exercice
      #---------------------------------------------------------------------------
      # -- Par défaut [M:DIV]MNTREPn reste tel qu'évalué dans DOTATION_EXERCICE (sauf ci-dessous)
      #---------------------------------------------------------------------------
      #- 3 ----------------------------
      If ( [F:DEPC]MTCTIATYP = GVML_PEDBAM and [F:DEPC]STRDPRDAT < [M:FIY]DATSTRFIY([M:DIV]FEC-1) ) Then
        # Suite à un changement de méthode dont la prise d'effet est "Début d'amortissement"
        If ( [F:DEPC]MTCDEVADJ = GVML_RDOTEXE ) Then
          # la modalité de gestion de l'écart Cumul E-1 est "Régularisation sur dotation exercice"
          # Le montant à répartir correspond à la dotation écart réintégré (avec écart)
          [M:DIV]MNTREPR += [M:DIV]ECACUME_1R
          [M:DIV]MNTREPT += [M:DIV]ECACUME_1T
          [M:DIV]MNTREPI += [M:DIV]ECACUME_1I
        Endif
        # FQ104870
        #If ( [F:DEPC]MTCDEVADJ = GVML_REXCEXE ) Then
        #  # la modalité de gestion de l'écart Cumul E-1 est "Régularisation sur dotation exercice"
        # # Le montant à répartir correspond à la dotation écart réintégré (avec écart)
        #  [M:DIV]EXCREPR += [M:DIV]ECACUME_1R
        #  [M:DIV]EXCREPT += [M:DIV]ECACUME_1T
        #  [M:DIV]EXCREPI += [M:DIV]ECACUME_1I
        #Endif
      Endif
      # En prospectif le montant à repartir sur les périodes non closes
      # correspond à la dotation exercice diminuée du cumul P-1 déjà constaté
      #- 3 ----------------------------
      If ( [F:DEPC]PERREFCLC <> [F:DEPC]FIYSTRDAT  ) Then
        [M:DIV]MNTREPR  = [F:DEPC]ENDDPE - [F:DEPC]PERCLOCUM
        # FQ104870
        #  [M:DIV]EXCREPR  = [F:DEPC]EXCDPR - [F:DEPC]PERCLOEXC
        # FQ114381
        #[M:DIV]EXCREPR  = [F:DEPC]EXCDPR - ([F:DEPC]PERCLOEXC  - [F:DEPC]PERTRFCUM)
        [M:DIV]EXCREPR  = [F:DEPC]EXCDPR - [F:DEPC]PERCLOEXC
      Endif

      If ( [F:DEPC]PERREFCLCT <> [F:DEPC]FIYSTRDAT  ) Then
          [M:DIV]MNTREPT  = [F:DEPC]ENDDPET - [F:DEPC]PERCLOCUMT
          [M:DIV]EXCREPT  = [F:DEPC]EXCDPRT - [F:DEPC]PERCLOEXCT
      Endif
      If ( [F:DEPC]PERREFCLCI <> [F:DEPC]FIYSTRDAT  ) Then
          [M:DIV]MNTREPI  = [F:DEPC]ENDDPEI - [F:DEPC]PERCLOCUMI
          [M:DIV]EXCREPI  = [F:DEPC]EXCDPRI - [F:DEPC]PERCLOEXCI
      Endif
    Endif
    #-2 -------------------------------


    [M:DIV]LVLLIB = "3.DOTATION_PERIODE" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call DOTATION_PERIODE  From =G_GLOB3

    # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
    # E   Point d'entrée    AFTDOTPER               E
    # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
    If ( G_ETP_GLOBI2 ) Then : # FQ114113
      GPOINT = "AFTDOTPER" : # FQ75488
      Gosub ENTREE From EXEFNC
      If !(GOK) Then
        [M:DIV]ERRID = 9003 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
      Endif
    Endif
#CHECK IGNORE_END
    # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

    # Suivi "Reel" - Neutralisation de la Repr. Dépr. à Transférer en Amt. Except.
    # à réaliser sur la dernière période de l'exercice suivant ou sur la période de sortie ou
    # sur la période de fin d'amortissement
##    If ( [M:DIV]PLNSTD(find([F:DEPC]DPRPLN, [M:DIV]PLNCAA)-1) = GVML_NPCRC and
##&        ( [F:DEPC]IMLBLC + [F:DEPC]IML - [F:DEPC]IMLRVE ) <> 0  and
##&        ( [F:DEPC]FIYENDDAT = [F:DEPC]PERENDDAT or
##&          func GLOBB9.CAL_DAT_INSIDE([F:WFAS]ISSDAT,    [F:DEPC]PERSTRDAT, [F:DEPC]PERENDDAT, "I") or
##&          func GLOBB9.CAL_DAT_INSIDE([F:DEPC]ENDDPRDAT, [F:DEPC]PERSTRDAT, [F:DEPC]PERENDDAT, "I")
##&        ) ) Then
##      # Reprise de dépréciation
##      [F:DEPC]IMLRVETRF = ([F:DEPC]EXECLOCUMT + [F:DEPC]ENDDPET + [F:DEPC]EXCDPRT )
##&                       - ( [F:DEPC]DPRCUM    + [F:DEPC]ENDDPE  + [F:DEPC]EXCDPR )
##      # Majoration de l'Amort. Except.
##      [F:DEPC]EXCDPR    = [F:DEPC]EXCDPR    + [F:DEPC]IMLRVETRF
##      [F:DEPC]PEREXCDPR = [F:DEPC]PEREXCDPR + [F:DEPC]IMLRVETRF
##    Else
##      [F:DEPC]IMLRVETRF = 0
##    Endif

#    F103461
#    If ( [M:DIV]PLNSTD(find([F:DEPC]DPRPLN, [M:DIV]PLNCAA)-1) = GVML_NPCRC and
#&        ( [F:DEPC]IMLBLC + [F:DEPC]IML - [F:DEPC]IMLRVE ) <> 0   ) Then
    If ( [M:DIV]PLNSTD(find([F:DEPC]DPRPLN, [M:DIV]PLNCAA)-1) = GVML_NPCRC and
&        (([F:DEPC]IMLBLC + [F:DEPC]IML - [F:DEPC]IMLRVE) <> 0 or [F:DEPC]PERTRFCUM <> 0)  ) Then
      # Reprise de dépréciation
      [F:DEPC]IMLRVETRF = ([F:DEPC]EXECLOCUMT + [F:DEPC]PERCLOCUMT + [F:DEPC]PERCLOEXCT + [F:DEPC]DPET      )
&                       - ([F:DEPC]DPRCUM     + [F:DEPC]PERCLOCUM  + [F:DEPC]PERCLOEXC  + [F:DEPC]PERENDDPE )
      # Majoration de l'Amort. Except.
      # FQ74115 - début
      #[F:DEPC]EXCDPR    = [F:DEPC]EXCDPR    + [F:DEPC]IMLRVETRF
      If ( [F:DEPC]PERSTRDAT = [M:FIY]DATSTRPER([M:DIV]FPC-1) ) Then
        [F:DEPC]EXCDPR    = [F:DEPC]EXCDPR    + [F:DEPC]IMLRVETRF + [F:DEPC]PERTRFCUM
      Else
        [F:DEPC]EXCDPR    = [F:DEPC]EXCDPR    + [F:DEPC]IMLRVETRF
      Endif
      # FQ74115 - fin

      [F:DEPC]PEREXCDPR = [F:DEPC]PEREXCDPR + [F:DEPC]IMLRVETRF
    Else
      [F:DEPC]IMLRVETRF = 0
    Endif
    # Reprise de dépréciation à comptabiliser
    If ( [F:WFAS]OWNTYP = GVML_TDPREVU ) Then
      [F:DEPC]RVETRFDEV = 0
    Else
      [F:DEPC]RVETRFDEV = [F:DEPC]IMLRVETRF - [F:DEPC]PSTRVETRF
    Endif

    # -- Sortie ( Traitement impactant la valeur nette au jour de sortie )
    If ([M:DIV]BSOR) Then

      If ( func GLOBB9.CAL_DAT_INSIDE([F:WFAS]ISSDAT, [F:DEPC]PERSTRDAT, [F:DEPC]PERENDDAT, "I") or
&          [M:DIV]BSRA ) Then
        # Dépréciation
        If ( [M:DIV]FLGISSIML = G_OUI ) Then
          # Reprise de dépréciation selon paramétrage dans la période de sortie impactant la valeur nette
          [F:WFAS]IMLRVEISS ([F:DEPC]DPRPLN-1) =
&                            [F:DEPC]IMLBLC + [F:DEPC]IML - [F:DEPC]IMLRVE - [F:DEPC]IMLRVETRF
        Endif
        # Plan "Subvention" :
        If ( [F:DEPC]DPRPLN = G301SUB ) Then
          #-- Reprise de la valeur nette en amortissement exceptionnel dans la période de sortie
          [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - IFP Subv." : Gosub CAL_ADDLVL  From =G_GLOB0
          #Call CAL_VALEUR_NETTE ( "IFP", [F:DEPC]BSEVAL, 0, [M:DIV]BMDR, WVALNET ) From =G_GLOB4
          [M:DIV]PC(0)= "IFP" : [M:DIV]PV(0)= [F:DEPC]BSEVAL : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
          Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
          WVALNET  = [M:DIV]RV(1)
          [F:DEPC]PEREXCDPRI += WVALNET
          [F:DEPC]EXCDPRI    += WVALNET
          [F:DEPC]PEREXCDPRT += WVALNET
          [F:DEPC]EXCDPRT    += WVALNET
          [F:DEPC]PEREXCDPR  += WVALNET
          [F:DEPC]EXCDPR     += WVALNET
        Endif
        # Règle Valeur nette en amortissement exceptionnel
        # ( sans effet sur le plan subvention ni sur le plan de caducité et non applicable au mode "IT") FQ93935
        # FQ99110
#        If (  [F:WFAS]ISSDATRUL = GVML_IRVLNAE and [F:DEPC]DPRPLN <> G301SUB and [F:DEPC]DPRPLN <> [M:DIV]CCNCADPLN and
#&             [F:DEPC]DPM <> G_DPMIT) Then
        If (  [F:WFAS]ISSDATRUL = GVML_IRVLNAE ) Then
        # FQ111994
        If (  [F:DEPC]DPRPLN <> G301SUB and [F:DEPC]DPM <> G_DPMIT) Then
        # FQ113733
        #If ( (not [M:DIV]BACTCCN) or ([M:DIV]BACTCCN and [M:DIV]CCNFLG = G_OUI and [F:DEPC]DPRPLN <> [M:DIV]CCNCADPLN))
        If ( (not [M:DIV]BACTCCN) or ([M:DIV]BACTCCN and [F:DEPC]DPRPLN <> [M:DIV]CCNCADPLN))
          #-- Reprise de la valeur nette en amortissement exceptionnel dans la période de sortie
          [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - IFP Rebut AE" : Gosub CAL_ADDLVL  From =G_GLOB0
          #Call CAL_VALEUR_NETTE ( "IFP", [F:DEPC]BSEVAL, 0, [M:DIV]BMDR, WVALNET ) From =G_GLOB4
          [M:DIV]PC(0)= "IFP" : [M:DIV]PV(0)= [F:DEPC]BSEVAL : [M:DIV]PE(0)= 0  : [M:DIV]PE(1)= [M:DIV]BMDR
          Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
          WVALNET  = [M:DIV]RV(1)
          [F:DEPC]PEREXCDPRI += WVALNET
          [F:DEPC]EXCDPRI    += WVALNET
          [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - TFP Rebut AE" : Gosub CAL_ADDLVL  From =G_GLOB0
          #Call CAL_VALEUR_NETTE ( "TFP", [F:DEPC]DPRBAS, 0, [M:DIV]BMDR, WVALNET ) From =G_GLOB4
          [M:DIV]PC(0)= "TFP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
          Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
          WVALNET  = [M:DIV]RV(1)
          [F:DEPC]PEREXCDPRT += WVALNET
          [F:DEPC]EXCDPRT    += WVALNET
          [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - RFP Rebut AE" : Gosub CAL_ADDLVL  From =G_GLOB0
          #Call CAL_VALEUR_NETTE ( "RFP", [F:DEPC]DPRBAS, 0, [M:DIV]BMDR, WVALNET ) From =G_GLOB4
          [M:DIV]PC(0)= "RFP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
          Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
          WVALNET  = [M:DIV]RV(1)
          [F:DEPC]PEREXCDPR  += WVALNET
          [F:DEPC]EXCDPR     += WVALNET
        Endif
        Endif
        Endif
      Endif

      # FQ105655
      # Sécurité - Recalage de l'amortissement exceptionnel
      [F:DEPC]EXCDPR     = [F:DEPC]PERCLOEXC  + [F:DEPC]PEREXCDPR    : # Cum E-1 Amt. Except.
      [F:DEPC]EXCDPRT    = [F:DEPC]PERCLOEXCT + [F:DEPC]PEREXCDPRT   : # Cum E-1 Amt. Except. Théo.
      [F:DEPC]EXCDPRI    = [F:DEPC]PERCLOEXCI + [F:DEPC]PEREXCDPRI   : # Cum E-1 Amt. Except. Init.

    Endif


   #===============================
    #-- Valeur nette Fin Période
    #===============================
    [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - IFP" : Gosub CAL_ADDLVL  From =G_GLOB0
    #Call CAL_VALEUR_NETTE ( "IFP", [F:DEPC]BSEVAL, 0, [M:DIV]BMDR, [F:DEPC]NBVI ) From =G_GLOB4
    [M:DIV]PC(0)= "IFP" : [M:DIV]PV(0)= [F:DEPC]BSEVAL : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
    Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
    [F:DEPC]NBVI= [M:DIV]RV(1)
    [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - TFP" : Gosub CAL_ADDLVL  From =G_GLOB0
    #Call CAL_VALEUR_NETTE ( "TFP", [F:DEPC]DPRBAS, 0, [M:DIV]BMDR, [F:DEPC]NBVT ) From =G_GLOB4
    [M:DIV]PC(0)= "TFP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
    Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
    [F:DEPC]NBVT= [M:DIV]RV(1)
    [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - RFP" : Gosub CAL_ADDLVL  From =G_GLOB0
    #Call CAL_VALEUR_NETTE ( "RFP", [F:DEPC]DPRBAS, 0, [M:DIV]BMDR, [F:DEPC]NBV  ) From =G_GLOB4
    [M:DIV]PC(0)= "RFP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
    Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
    [F:DEPC]NBV = [M:DIV]RV(1)

    #=================
    # Reprise de réévaluation
    #=================
    # Reprise de réévaluation dans l'exercice
    # FQ64311
    #[F:DEPC]RVACRB = ( [F:DEPC]DPET + [F:DEPC]PEREXCDPRT )  - ( [F:DEPC]DPEI + [F:DEPC]PEREXCDPRI )
    # Uniquement si il existe de la réserve de réévaluation
    [F:DEPC]RVACRB = 0

    # FQ67995
    If ([M:DIV]LEGSOC = "FRA" and [F:DEPC]DPRPLN = G301CPT ) Then
      # Si pays France et plan comptable pas de reprise de réévaluation
      [F:DEPC]RVACRB = 0
    Else
      If (([F:DEPC]BSEVAL >= 0 and ([F:DEPC]EXERVADEV + [F:DEPC]PERRVADEV + [F:DEPC]RVAAMT) > 0 ) or
&         ([F:DEPC]BSEVAL <= 0 and ([F:DEPC]EXERVADEV + [F:DEPC]PERRVADEV + [F:DEPC]RVAAMT) < 0 ) ) Then
        If (( [F:DEPC]BSEVAL >= 0 and ([F:DEPC]DPET + [F:DEPC]PEREXCDPRT)-([F:DEPC]DPEI+[F:DEPC]PEREXCDPRI)>= 0 ) or
&           ( [F:DEPC]BSEVAL <= 0 and ([F:DEPC]DPET + [F:DEPC]PEREXCDPRT)-([F:DEPC]DPEI+[F:DEPC]PEREXCDPRI)<= 0 )) Then
          [F:DEPC]RVACRB = ( [F:DEPC]DPET + [F:DEPC]PEREXCDPRT )  - ( [F:DEPC]DPEI + [F:DEPC]PEREXCDPRI )
        Endif
      Endif
    Endif

    # FQ74785
    # Reprise limitée à la réserve de réévaluation fin de période
    If ( abs([F:DEPC]RVACRB) > abs([F:DEPC]EXERVADEV+[F:DEPC]PERRVADEV+[F:DEPC]RVAAMT) ) Then
      [F:DEPC]RVACRB = ( [F:DEPC]EXERVADEV+[F:DEPC]PERRVADEV+[F:DEPC]RVAAMT )
    Endif

    Call ECR_FICH("FS1", 6, "CALCUL_PERIODE - Reprise réévaluation       ="+
&       format$([M:DIV]CURFMT, [F:DEPC]RVACRB) ) From =G_GLOB0


    # actualisation Cumul P-1
    [M:DIV]CUMP_1R += [F:DEPC]PERENDDPE
    [M:DIV]CUMP_1T += [F:DEPC]DPET
    [M:DIV]CUMP_1I += [F:DEPC]DPEI
    # FQ102893 En cas de rattrapage de l'écart sur la période, il faut déduire l'écart qui se trouve dans PERENDDPE, DPET, DPEI
    If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and [F:DEPC]MTCDPEDAT <> [0/0/0] ) Then
      [M:DIV]CUMP_1R -= [M:DIV]ECACUME_1R
      [M:DIV]CUMP_1T -= [M:DIV]ECACUME_1T
      [M:DIV]CUMP_1I -= [M:DIV]ECACUME_1I
    Endif

    # actualisation Cumul Exceptionnel P-1
    [M:DIV]CUMEXCP_1R += [F:DEPC]PEREXCDPR
    [M:DIV]CUMEXCP_1T += [F:DEPC]PEREXCDPRT
    [M:DIV]CUMEXCP_1I += [F:DEPC]PEREXCDPRI
    # FQ104870
    If ( [M:DIV]RGLECAE_1 = GVML_REXCPER and [F:DEPC]MTCDPEDAT <> [0/0/0] ) Then
      [M:DIV]CUMEXCP_1R -= [M:DIV]ECACUME_1R
      [M:DIV]CUMEXCP_1I -= [M:DIV]ECACUME_1T
      [M:DIV]CUMEXCP_1I -= [M:DIV]ECACUME_1I
    Endif

    #=================
    # Sortie ( à partir de la valeur nette jour de sortie)
    #=================

    #If (GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -= 1 : Dbgaff : Endif

    # FQ95592
    If ([M:DIV]BSOR) Then
      # FQ55503
      If ( func GLOBB9.CAL_DAT_INSIDE([F:WFAS]ISSDAT, [F:DEPC]PERSTRDAT, [F:DEPC]PERENDDAT, "I") or [M:DIV]BSRA ) Then
        # Reprise de réévaluation en cas de sortie = ( VN réelle - VN initiale ) au jour de sortie
        # Pas de reprise de réserve négative en cas de réévalution négative
        Local Decimal RVABLC : RVABLC = [F:DEPC]EXERVADEV+[F:DEPC]PERRVADEV+[F:DEPC]RVAAMT
        If (( [F:DEPC]BSEVAL >= 0 and RVABLC >= 0 ) or
&           ( [F:DEPC]BSEVAL <= 0 and RVABLC <= 0 )) Then
          [F:DEPC]RVACRB = RVABLC
        Else
          [F:DEPC]RVACRB = 0
        Endif
        Call ECR_FICH("FS1", 6, "CALCUL_PERIODE - Reprise réévaluation sortie="+
&          format$([M:DIV]CURFMT, [F:DEPC]RVACRB) ) From =G_GLOB0
      Endif
      If ( [F:WFAS]ISSDAT >= [F:DEPC]PERSTRDAT or [M:DIV]BSRA ) Then
        # Détermination ( TVA sur vente, Déduction complémentaire, Reversement  de TVA )
        # Ces champs participent à la détermination de la +/- value
        [M:DIV]LVLLIB = "6.CAL_SORTIE_TVA" : Gosub CAL_ADDLVL  From =G_GLOB0
        Call CAL_SORTIE_TVA  From =G_GLOB6
        # Détermination de la +/- value
        [M:DIV]LVLLIB = "6.CAL_SORTIE_PMV" : Gosub CAL_ADDLVL  From =G_GLOB0
        Call CAL_SORTIE_PMV  From =G_GLOB6
      Endif
    Endif

    ####=================
    #### Plafond de reprise FQ72008
    ####=================
    [M:DIV]LVLLIB = "6.CAL_PLAFOND_REPR_DEPRECIATION" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call CAL_PLAFOND_REPR_DEPRECIATION ( [F:DEPC]NBV, [F:DEPC]NBVT, [F:DEPC]IMLBLC,
&                                        [F:DEPC]IMLRVELIM ) From =G_GLOB6

  Endif
  #-1 -------------------------------

  #=================
  # A comptabiliser
  #=================
  # Les champs PST "comptabilisé" sont actualisés par la génération des écritures comptables
  If ( [F:WFAS]OWNTYP = GVML_TDPREVU ) Then
    # Un bien en prévision ne peut pas avoir de "A comptabiliser"
    [F:DEPC]DPEDEV    = 0
    [F:DEPC]EXCDEV    = 0
    [F:DEPC]RVACRBDEV = 0
  Else

    # FQ84283
    Local Decimal WPERENDDPE
    WPERENDDPE = [F:DEPC]PERENDDPE
    # -------------------------------------
    If (find([F:DEPC]DPM, G_DPMAL, G_DPMAD) and [F:DEPC]DPRRAT2 <> 0 ) Then
      WPERENDDPE = [F:DEPC]PERENDDPE * (1-[F:DEPC]DPRRAT2)
      #Call CAL_ARRONDI_MNT (WPERENDDPE, [M:DIV]CUR , WPERENDDPE) From =G_GLOB8
      [M:DIV]PV(0)= WPERENDDPE : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WPERENDDPE = [M:DIV]RV(1)

#      If ([F:DEPC]PERENDDAT = [F:DEPC]FIYENDDAT or
#&         func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSORREG, [F:DEPC]PERSTRDAT, [F:DEPC]PERENDDAT, "I")) Then
#        Local Decimal WCPTP_1 : WCPTP_1 = 0.
#        Local Integer I_CPT : I_CPT = find([F:DEPC]FIYSTRDAT, [M:DEP]FIYSTRDAT)
#        While [M:DEP]PERENDDAT(I_CPT-1) <> [M:DEP]FIYENDDAT(I_CPT-1) and
#&             (not func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSORREG, [M:DEP]PERSTRDAT(I_CPT-1), [M:DEP]PERENDDAT(I_CPT-1), "I"))
#          WCPTP_1 += [M:DEP]PSTDPE(I_CPT-1) + [M:DEP]DPEDEV(I_CPT-1)
#          I_CPT += 1
#        Wend
#        Local Decimal WDOTAXE
#        WDOTTAXE = [M:DIV]DOTEXE * (1-[F:DEPC]DPRRAT2)
#        #Call CAL_ARRONDI_MNT (WDOTTAXE, [M:DIV]CUR , WPERENDDPE) From =G_GLOB8
#        [M:DIV]PV(0)= WDOTTAXE : [M:DIV]PC(0)= [M:DIV]CUR
#        Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTTAXE = [M:DIV]RV(1)
#        WPERENDDPE = WDOTTAXE - WCPTP_1
#      Endif

    Endif
    #-------------------------------------

    [F:DEPC]DPEDEV    = WPERENDDPE        - [F:DEPC]PSTDPE
    [F:DEPC]EXCDEV    = [F:DEPC]PEREXCDPR - [F:DEPC]PSTEXC
    [F:DEPC]RVACRBDEV = [F:DEPC]RVACRB    - [F:DEPC]PSTRVACRB
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog INIT_DEPS_AVANT_CLOTURE
#
# - Objet  : Alimentation du buffer DEPS avant clôture
#
#            DEPS est initialisé avec l'enreg. [M:DEP] suivant
#            L'enreg. [M:DEP] suivant est lui-même au préalable créé
#            et alimenté à partir de DEPC.
#

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif


  # Sauvegarde des rubriques "Comptabilisé"
  If ( [M:DIV]DL < [M:DIV]NBDEPSV ) Then
    [F:DEPS]FLGPST       = [M:DEP]FLGPST    ([M:DIV]DL)
    [F:DEPS]PSTDPE       = [M:DEP]PSTDPE    ([M:DIV]DL)
    [F:DEPS]PSTEXC       = [M:DEP]PSTEXC    ([M:DIV]DL)
    [F:DEPS]PSTDER       = [M:DEP]PSTDER    ([M:DIV]DL)
    [F:DEPS]PSTDERRVE    = [M:DEP]PSTDERRVE ([M:DIV]DL)
    [F:DEPS]PSTRVETRF    = [M:DEP]PSTRVETRF ([M:DIV]DL)
    [F:DEPS]PSTRVACRB    = [M:DEP]PSTRVACRB ([M:DIV]DL)
    # FQ64544
    [F:DEPS]FLGPSTLNK    = [M:DEP]FLGPSTLNK ([M:DIV]DL)
    [F:DEPS]PSTLNK       = [M:DEP]PSTLNK    ([M:DIV]DL)
    # FQ54202
    [F:DEPS]FCY          = [M:DEP]FCY       ([M:DIV]DL)
    # FQ54343
    If ([M:DIV]BACTCCN) Then
      [F:DEPS]PSTCADCRB    = [M:DEP]PSTCADCRB ([M:DIV]DL)
    Endif
  Endif

  # Ligne suivante dans [M:DEP]
  # Création ligne [M:DEP] à partir de [F:DEPC])
  nolign = [M:DIV]DL + 1 : [M:DEP] = [F:DEPC]
  # ---------------------------------
  If ( [M:DIV]DL = [M:DEP]NB_DEP ) Then
    # Ajustement nombre de ligne dans [M:DEP]
    [M:DEP]NB_DEP = [M:DIV]DL + 1
    [M:DEP]FLGPST    ([M:DIV]DL) = 0
    [M:DEP]PSTDPE    ([M:DIV]DL) = 0
    [M:DEP]PSTEXC    ([M:DIV]DL) = 0
    [M:DEP]PSTDER    ([M:DIV]DL) = 0
    [M:DEP]PSTDERRVE ([M:DIV]DL) = 0
    [M:DEP]PSTRVETRF ([M:DIV]DL) = 0
    [M:DEP]PSTRVACRB ([M:DIV]DL) = 0
    # FQ64544
    [M:DEP]FLGPSTLNK ([M:DIV]DL) = 0
    [M:DEP]PSTLNK    ([M:DIV]DL) = 0
    # FQ54343
    If ([M:DIV]BACTCCN) Then
      [M:DEP]PSTCADCRB ([M:DIV]DL) = 0
    Endif
  Endif
  # ---------------------------------

  # Restauration des rubriques "Comptabilisé"
  If ( [M:DIV]DL < [M:DIV]NBDEPSV ) Then
    [M:DEP]FLGPST    ([M:DIV]DL) = [F:DEPS]FLGPST
    [M:DEP]PSTDPE    ([M:DIV]DL) = [F:DEPS]PSTDPE
    [M:DEP]PSTEXC    ([M:DIV]DL) = [F:DEPS]PSTEXC
    [M:DEP]PSTDER    ([M:DIV]DL) = [F:DEPS]PSTDER
    [M:DEP]PSTDERRVE ([M:DIV]DL) = [F:DEPS]PSTDERRVE
    [M:DEP]PSTRVETRF ([M:DIV]DL) = [F:DEPS]PSTRVETRF
    [M:DEP]PSTRVACRB ([M:DIV]DL) = [F:DEPS]PSTRVACRB
    # FQ64544
    [M:DEP]FLGPSTLNK ([M:DIV]DL) = [F:DEPS]FLGPSTLNK
    [M:DEP]PSTLNK    ([M:DIV]DL) = [F:DEPS]PSTLNK
    # FQ54202
    [M:DEP]FCY       ([M:DIV]DL) = [F:DEPS]FCY
    # FQ54343
    If ([M:DIV]BACTCCN) Then
      [M:DEP]PSTCADCRB ([M:DIV]DL) = [F:DEPS]PSTCADCRB
    Endif
  Endif


  # Initialisation [F:DEPS]
  nolign = [M:DIV]DL + 1 : [F:DEPS] = [M:DEP]
  # Synchronisation dates DEP selon FIY
  [M:DIV]LVLLIB = "2.CAL_DATES_DEP" : Gosub CAL_ADDLVL  From =G_GLOB0
  Call CAL_DATES_DEP ("S", [F:DEPC]FIYENDDAT, [F:DEPC]PERENDDAT, "[F:DEPS]" ) From =G_GLOB2
  If ([M:DIV]ERROR) Then : End : Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End
#
#########################################################
Subprog  CAL_DATES_DEP (PTYP, PDATEXE, PDATPER, PABR )
#
# - Objet  : Calcule des dates de DEP
#            (Début & Fin exercice) (Début & Fin période)
#            pour l'enregistrement courant ou pour le suivant
#
#        Pour des soucis de performances (Assign gourmand)
#        PABR ne peut prendre que les valeurs [F:DEPC] [F:DEPS]
#        Si une nouvelle abréviation doit être utilisée il faut adapter ce sous-programme
#
#   Rem. Les dates exercices / périodes ont pu être remises en cause
#        dans les limites des possibilités de la transaction dédiée.
#        Le calcul se doit de resynchroniser DEP avec ces nouvelles
#        dates. Dans ce cas, s'il s'agit de la période courante les
#        informations hors synchronisation sont conservées. S'il s'agit
#        d'une période ultérieure, elle hérite des informations hors
#        synchronisation de la période précédente.
#
# - Entrée :
#
#        Type "C" enreg. courant  [F:DEPC], "S" enreg. précédent [F:DEPC][F:DEPS]
#        Début exercice ( PTYP = "C") de l'enreg. courant ou Fin exercice de l'enreg. précédent ( PTYP = "S")
#        Début période  ( PTYP = "C") de l'enreg. courant ou Fin période  de l'enreg. précédent ( PTYP = "S")
#        Date de début ou de fin période  de l'enregistrement précédent
#        Abréviation du fichier type DEPREC
#
# - Sortie : [F:DEPn]
#
#   Boite noire
#
Value     Char     PTYP
Value     Date     PDATEXE, PDATPER
Value     Char     PABR

Local     Date     WDTDB
Local     Date     WDTDBEXE, WDTFNEXE
Local     Date     WDTDBPER, WDTFNPER
Local     Integer  WINDEXE


  #- 1 ------------------------------------------------
  If ( PTYP = "C" ) Then
    # Enreg. courant
    If ( PDATPER <> [0/0/0] ) Then
      WDTDB = PDATPER
    Else
      WDTDB = PDATEXE
    Endif
  #- 1 ------------------------------------------------
  Else
    # Nouvel enregistement
    If ( PDATPER <> [0/0/0] ) Then
      WDTDB  = func GLOBB9.CAL_DAT_PLUS( PDATPER , 1, "D" )
    Else
      WDTDB  = func GLOBB9.CAL_DAT_PLUS( PDATEXE , 1, "D" )
    Endif
  Endif
  #- 1 ------------------------------------------------

  # Début/Fin exercice
  #Call CAL_EXERCICE_SELON_DATE  ( WDTDB , GVML_TPJOUR, WDTDBEXE, WDTFNEXE, WINDEXE ) From =G_GLOB8
  [M:DIV]PD(0)= WDTDB : [M:DIV]PV(0)= GVML_TPJOUR
  Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
  WDTDBEXE = [M:DIV]RD(1) : WDTFNEXE = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
  If ([M:DIV]ERROR) Then : End : Endif


  # L'exercice est forcemment découpé en (1 ou plusieurs) période(s) =>  Début/Fin Période  selon découpage
  WDTDBPER  = [M:FIY]DATSTRPER(find(WDTDB,[M:FIY]DATSTRPER)-1)
  WDTFNPER  = [M:FIY]DATENDPER(find(WDTDB,[M:FIY]DATSTRPER)-1)

  # Affectation des dates
  Case PABR
    When "[F:DEPC]"
      [F:DEPC]FIYSTRDAT = WDTDBEXE
      [F:DEPC]FIYENDDAT = WDTFNEXE
      [F:DEPC]PERSTRDAT = WDTDBPER
      [F:DEPC]PERENDDAT = WDTFNPER
  When "[F:DEPS]"
      [F:DEPS]FIYSTRDAT = WDTDBEXE
      [F:DEPS]FIYENDDAT = WDTFNEXE
      [F:DEPS]PERSTRDAT = WDTDBPER
      [F:DEPS]PERENDDAT = WDTFNPER
  Endcase

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog  CLOTURE_EXERCICE
#
# - Objet  :
#
#
# - Entrée : Cette fonction évalue le champ cumul E-1
#
#
# - Sortie : [F:DEPn]
#
#   Boite noire
#


  # Clôture exercice [F:DEPC] -> [F:DEPS]

  If !([M:DIV]BCLOPER) Then
    # Initialisation [F:DEPS] avant clôture ( sauf si la clôture période l'a déjà fait)
    [M:DIV]LVLLIB = "2.INIT_DEPS_AVANT_CLOTURE (1)" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call INIT_DEPS_AVANT_CLOTURE From =G_GLOB2
    If ([M:DIV]ERROR) Then : End : Endif
  Endif

  # Clôture exercice [F:DEPC] -> [F:DEPS]
  [M:DIV]LVLLIB = "6.CAL_CLORE_EXERCICE_AMT" : Gosub CAL_ADDLVL  From =G_GLOB0
  Gosub CAL_CLORE_EXERCICE_AMT From =G_GLOB6
  If ([M:DIV]ERROR) Then : End : Endif

  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    AFTCLOEXE FQ56392       E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
  If ( G_ETP_GLOBI2 ) Then : # FQ114113
    GPOINT = "AFTCLOEXE"
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9003 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
    Endif
  Endif
#CHECK IGNORE_END
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  # Mise à jour [M:DEP]
  nolign = [M:DIV]DL + 1 :  [M:DEP] = [F:DEPS]

  # Incrémentation du pointeur DEP
  [M:DIV]DL  += 1
  # Initialisation [F:DEPC]
  nolign = [M:DIV]DL     :  [F:DEPC] = [M:DEP]

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog  CLOTURE_PERIODE
#
# - Objet  :
#
#
# - Entrée : Cette fonction évalue le champ cumul E-1
#
#
# - Sortie : [F:DEPn]
#
#   Boite noire
#


# Clôture période [F:DEPC] -> [F:DEPS]

  # Initialisation [F:DEPS] avant clôture
  [M:DIV]LVLLIB = "2.INIT_DEPS_AVANT_CLOTURE (2)" : Gosub CAL_ADDLVL  From =G_GLOB0
  Call INIT_DEPS_AVANT_CLOTURE From =G_GLOB2
  If ([M:DIV]ERROR) Then : End : Endif

  # Clôture période [F:DEPC] -> [F:DEPS]
  [M:DIV]LVLLIB = "6.CAL_CLORE_PERIODE_AMT" : Gosub CAL_ADDLVL  From =G_GLOB0
  Gosub CAL_CLORE_PERIODE_AMT From =G_GLOB6

  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    AFTCLOPER FQ56392       E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
  If ( G_ETP_GLOBI2 ) Then : # FQ114113
    GPOINT = "AFTCLOPER"
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9004 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
    Endif
  Endif
#CHECK IGNORE_END
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  # Mise à jour [M:DEP]
  nolign = [M:DIV]DL + 1 :  [M:DEP] = [F:DEPS]

  # Pas d'incrémentation du pointeur DEP sur la dernière période d'un exercice
  # c'est la clôture exercice qui s'en charge
  If ( [F:DEPC]PERENDDAT <> [F:DEPC]FIYENDDAT ) Then
    # Incrémentation du pointeur DEP après clôture période
    [M:DIV]DL  += 1
    # Initialisation [F:DEPC]
    nolign = [M:DIV]DL   :  [F:DEPC] = [M:DEP]
  Endif

  # Clôture périodique effectuée = Vrai
  [M:DIV]BCLOPER = 1

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#
#########################################################
Subprog CAL_ARRETER_ALIM_DEP(RTRN)
# - Objet  : Renvoie 1 si il ne faut plus alimenter le masque [M:DEP].
#
# - Entrée :
#
# - Sortie : 0 continuer 1 arrêter
#
#

Variable Integer RTRN

Local Integer IP

  RTRN = 0

  #-1 --------------------------------
  If (  [F:WFAS]ISSDAT <> [0/0/0] and
&     ( [F:WFAS]EXTISSFLG <> G_OUI or ([F:WFAS]EXTISSFLG =  G_OUI and [M:DIV]TRTDEM <> "CALSIM")  ) and
&     ( not([M:DIV]BACTCCN) or ([M:DIV]BACTCCN and ( [F:WFAS]CCNETRTYP <> GVML_NA1ERBC or [F:WFAS]ISSTYP = GVML_TSFCONC )) )  ) Then

    IP = func GLOBB9.CAL_LOCALISE_DAT ([F:WFAS]ISSDAT, [M:FIY]DATSTRFIY, [M:FIY]DATENDFIY, 0, [M:FIY]NB_EXE-1)
    If (IP >= 0 ) Then
      # Arrêt de l'amortissement
      # après avoir calculé la dernière période de l'exercice suivant l'exercice de sortie du bien
      If (  [F:WFAS]ISSDAT    <= [M:FIY]DATENDFIY(IP+1) and
&           [F:DEPC]PERENDDAT  = [M:FIY]DATENDFIY(IP+1)      ) Then
        RTRN = 1
      Endif
    Endif
  Endif
  #-1 --------------------------------

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#
#########################################################
Subprog CAL_ARRETER_CALCUL(RTRN)
# - Objet  : Renvoie 1 si le calcul doit être interrompu.
#            Cela ne veut pas dire que l'on arrête
#            l'alimentation de DEPREC.
#
# - Entrée :
#
# - Sortie : 0 continuer 1 arrêter
#
#
Variable Decimal RTRN


  RTRN = 0
  # Arrêt de l'amortissement si après avoir calculé
  # la valeur nette fin de période est égale à 0
  # à condition que le mode d'amortissement ne soit pas "Linéaire au delà de la valeur résiduelle"
  # FQ59941
  # If ( [F:DEPC]NBV = [F:DEPC]RSDVAL and [F:DEPC]NBVT = [F:DEPC]RSDVAL and [F:DEPC]DPM <> G_DPMLV  )  Then
  If ( [M:DIV]BBONUS ) Then
    If ( [F:DEPC]NBV - [M:DIV]BONUS = [F:DEPC]RSDVAL and [F:DEPC]NBVT - [M:DIV]BONUS = [F:DEPC]RSDVAL and
&        [F:DEPC]DPM <> G_DPMLV  )  Then
      RTRN = 1
    Endif
  Else
    If ( [F:DEPC]NBV = [F:DEPC]RSDVAL and [F:DEPC]NBVT = [F:DEPC]RSDVAL and
&        [F:DEPC]DPM <> G_DPMLV  )  Then
      RTRN = 1
    Endif
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
$CALCUL_PLAN_LIENS
#
# - Objet  :
#
#
# - Entrée : Cette fonction gère les liens entre plans
#            génériques & légaux ( Dérogatoire, Réintégration )
#            Dotation minimum, Amortissement différable
#
#
# - Sortie : [F:DEPn]
#
#   Boite noire
#


  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # Amortissement dérogatoire (Dérogatoire/Réintégration)
  Gosub CAL_DEROG_REINT

  # Ecart entre plans
  Gosub CAL_PLANS_LIES

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0


Return

#
#########################################################
$CAL_DEROG_REINT
#
# - Objet  :
#
#
# - Entrée : Cette fonction calcul Provision/Reprise de dérogatoire / réintégration fiscale
#

Local Integer ID
Local Decimal WSLD

Local Decimal WDEREXE
Local Decimal WECADER
Local Decimal WCOEAFI  :  WCOEAFI = 1.

Local Integer RTRN
Local Decimal WDPRCUMR_C
Local Decimal WDPRCUMR_F
Local Decimal WSLDDPR
Local Decimal WSLDLEG

  # Si le bien a été sorti dans un exercice antérieur à l'exercice courant on ne calcule pas les liens entre plan
  #FQ66341
  If ( [F:WFAS]ISSDAT <> [0/0/0] and [F:WFAS]ISSDAT < [M:FIY]DATSTRFIY([M:DIV]FEC-1) and
&      (not ([M:DIV]BACTCCN) or ([M:DIV]BACTCCN and [F:WFAS]CCNETRTYP <> GVML_NA1ERBC )) ) Then
    Call ECR_FICH ( "FS1", 3, "CALCUL_PLAN_LIENS - "-"Aucun calcul amortissement bien sorti dans un exercice antérieur"  ) From =G_GLOB0
    Return
  Endif

  #----------------------------------------
  # Dérogatoire / Reintegration fiscale
  #----------------------------------------
  Call ECR_FICH("FS1", 4, "***********************************************" )        From =G_GLOB0

  #-1 -----------------------------------------------
  If ( [M:DIV]PLNFIS and [M:DIV]CNT = G300CPFI ) Then
    Call ECR_FICH("FS1", 4, "CAL_DEROG_REINT - Dérogatoire/Réintégration fiscale " ) From =G_GLOB0

    # FQ82293
    If ( [M:DIV]TRTDEM = "CALSOC" and not G_BERRDER and [M:PCPT]LSTCLODAT([M:DIV]DPC-1) <> [0/0/0] and [M:PFIS]LSTCLODAT([M:DIV]DPC-1) <> [0/0/0] ) Then
      WSLDDPR = ([M:PFIS]DPRCUM([M:DIV]DPC-1)+[M:PFIS]PERCLOCUM([M:DIV]DPC-1)+[M:PFIS]PERCLOEXC([M:DIV]DPC-1))
&             - ([M:PCPT]DPRCUM([M:DIV]DPC-1)+[M:PCPT]PERCLOCUM([M:DIV]DPC-1)+[M:PCPT]PERCLOEXC([M:DIV]DPC-1))
      WSLDLEG = ( ([M:PCPT]LEGCUM   ([M:DIV]DPC-1)+[M:PCPT]PERLEGCUM([M:DIV]DPC-1)) -
&                 ([M:PCPT]LEGRVECUM([M:DIV]DPC-1)+[M:PCPT]PERLEGRVE([M:DIV]DPC-1)) )
&             - ( ([M:PFIS]LEGCUM   ([M:DIV]DPC-1)+[M:PFIS]PERLEGCUM([M:DIV]DPC-1)) -
&                 ([M:PFIS]LEGRVECUM([M:DIV]DPC-1)+[M:PFIS]PERLEGRVE([M:DIV]DPC-1)) )
      If ( WSLDDPR <> WSLDLEG ) Then
        G_BERRDER = 1
        # Incohérence cumuls dérogatoire
        Call ECR_TRACE(mess(194,7774,1),-1) From =G_GLOB0
      Endif
    Endif


    # *********************************************
    # Immobilisation : Cas standard
    # *********************************************

    # Initialisation des cumuls E-1
    #-2 -----------------------------------------------
    If ( [M:PCPT]DPRCUMFLG([M:DIV]DPC-1) <> G_OUI or [M:PFIS]DPRCUMFLG([M:DIV]DPC-1) <> G_OUI ) Then
      # FQ107633 If ( abs([M:PFIS]DPRCUM([M:DIV]DPC-1)) > abs([M:PCPT]DPRCUM([M:DIV]DPC-1)) ) Then
      If (func GLOBB9.CAL_CMP_MNT ([M:PFIS]DPRCUM([M:DIV]DPC-1),">",[M:PCPT]DPRCUM([M:DIV]DPC-1),[M:PCPT]DPRBAS([M:DIV]DPC-1))) Then
        # -- Dérogatoire (Comptable)
        [M:PCPT]LEGCUM([M:DIV]DPC-1)    = [M:PFIS]DPRCUM([M:DIV]DPC-1) - [M:PCPT]DPRCUM([M:DIV]DPC-1)
        [M:PCPT]LEGRVECUM([M:DIV]DPC-1) = 0.
        [M:PCPT]PERLEGCUM([M:DIV]DPC-1) = 0.
        [M:PCPT]PERLEGRVE([M:DIV]DPC-1) = 0.
        [M:PFIS]LEGCUM([M:DIV]DPC-1)    = 0.
        [M:PFIS]LEGRVECUM([M:DIV]DPC-1) = 0.
        [M:PFIS]PERLEGCUM([M:DIV]DPC-1) = 0.
        [M:PFIS]PERLEGRVE([M:DIV]DPC-1) = 0.
        Call ECR_FICH ("FS1", 5, "CAL_DEROG_REINT - Cumul Dérogatoire ="+
&              format$([M:DIV]CURFMT, [M:PCPT]LEGCUM([M:DIV]DPC-1))) From =G_GLOB0
        Else
          # -- Réintégration fiscale (Fiscal)
        [M:PFIS]LEGCUM([M:DIV]DPC-1)    = [M:PCPT]DPRCUM([M:DIV]DPC-1) - [M:PFIS]DPRCUM([M:DIV]DPC-1)
        [M:PFIS]LEGRVECUM([M:DIV]DPC-1) = 0.
        [M:PFIS]PERLEGCUM([M:DIV]DPC-1) = 0.
        [M:PFIS]PERLEGRVE([M:DIV]DPC-1) = 0.
        [M:PCPT]LEGCUM([M:DIV]DPC-1)    = 0.
        [M:PCPT]LEGRVECUM([M:DIV]DPC-1) = 0.
        [M:PCPT]PERLEGCUM([M:DIV]DPC-1) = 0.
        [M:PCPT]PERLEGRVE([M:DIV]DPC-1) = 0.
        Call ECR_FICH ("FS1", 5, "CAL_DEROG_REINT - Cumul Réint/Fisc. ="+
&              format$([M:DIV]CURFMT, [M:PFIS]LEGCUM([M:DIV]DPC-1))) From =G_GLOB0
        Endif
    Endif
    #-2 -----------------------------------------------

    #-2 ------------------------------------------------
    # FQ106373 UMAJDEROG Dérogatoire recalculé dans tous les cas.
    If ( [M:PCPT]LSTCLODAT([M:DIV]DPC-1) = [0/0/0] or [M:PFIS]LSTCLODAT([M:DIV]DPC-1) = [0/0/0] or
&        [M:DIV2]EXTCALL = "UMAJDEROG" ) Then

      #-3 ------------------------------------------------
      # FQ107633 If ( abs([M:PFIS]DPRCUM([M:DIV]DPC-1)) > abs([M:PCPT]DPRCUM([M:DIV]DPC-1)) ) Then
      If (func GLOBB9.CAL_CMP_MNT ([M:PFIS]DPRCUM([M:DIV]DPC-1),">",[M:PCPT]DPRCUM([M:DIV]DPC-1),[M:PCPT]DPRBAS([M:DIV]DPC-1))) Then
        # -- Dérogatoire (Comptable)
        [M:PCPT]LEGCUM([M:DIV]DPC-1)    = [M:PFIS]DPRCUM([M:DIV]DPC-1)    - [M:PCPT]DPRCUM([M:DIV]DPC-1)
        [M:PCPT]LEGRVECUM([M:DIV]DPC-1) = 0.
        [M:PFIS]LEGCUM   ([M:DIV]DPC-1) = 0.
        [M:PFIS]LEGRVECUM([M:DIV]DPC-1) = 0.
        Call ECR_FICH ("FS1", 5, "CAL_DEROG_REINT - CmE-1 Dérogatoire ="+
&            format$([M:DIV]CURFMT, [M:PCPT]LEGCUM([M:DIV]DPC-1))) From =G_GLOB0
      #-3 ------------------------------------------------
      Else
        # -- Réintégration fiscale (Fiscal)
        [M:PFIS]LEGCUM   ([M:DIV]DPC-1) = [M:PCPT]DPRCUM([M:DIV]DPC-1)    - [M:PFIS]DPRCUM([M:DIV]DPC-1)
        [M:PFIS]LEGRVECUM([M:DIV]DPC-1) = 0.
        [M:PCPT]LEGCUM   ([M:DIV]DPC-1) = 0.
        [M:PCPT]LEGRVECUM([M:DIV]DPC-1) = 0.
        Call ECR_FICH ("FS1", 5, "CAL_DEROG_REINT - CmE-1 Réint/Fisc. ="+
&            format$([M:DIV]CURFMT, [M:PFIS]LEGCUM([M:DIV]DPC-1))) From =G_GLOB0
      Endif
      #-3 ------------------------------------------------

      Local Decimal WLEG_F, WLEGRVE_F, WLEG_C, WLEGRVE_C, WDERDEV_C, WDERRVEDEV_C, WDERRVEISS

#     FQ107633
#        Call  CAL_PER_DEROG_REINT( "CALCUL",
#&             [M:DIV]BSOR, [F:WFAS]ISSDAT, [F:WFAS]OWNTYP, [F:WFAS]GACACN, [M:DIV]CUR, [M:DIV]BACTCCN,
#&             [M:DIV]FLGDERBEC, [F:WFAS]CCNETRTYP, [M:PCPT]DPRBAS([M:DIV]DPC-1), [M:PCPT]ALWCOD([M:DIV]DPC-1),
#&             [M:PFIS]ALWAMT([M:DIV]DPC-1), [M:PFIS]ALWCUM([M:DIV]DPC-1), [M:PFIS]ALWCOD([M:DIV]DPC-1),
#&             [M:PFIS]DPRCUM([M:DIV]DPC-1), [M:PFIS]PERCLOCUM([M:DIV]DPC-1), [M:PFIS]PERCLOEXC([M:DIV]DPC-1),
#&             [M:PFIS]ENDDPE([M:DIV]DPC-1), [M:PFIS]EXCDPR([M:DIV]DPC-1), [M:PFIS]PERENDDPE([M:DIV]DPC-1),
#&             [M:PFIS]PEREXCDPR([M:DIV]DPC-1), [M:PFIS]NBV([M:DIV]DPC-1),
#&             [M:PFIS]LEGCUM([M:DIV]DPC-1),    [M:PFIS]LEGRVECUM([M:DIV]DPC-1),
#&             [M:PFIS]PERLEGCUM([M:DIV]DPC-1), [M:PFIS]PERLEGRVE([M:DIV]DPC-1),
#&             [M:PCPT]DPRCUM([M:DIV]DPC-1), [M:PCPT]PERCLOCUM([M:DIV]DPC-1), [M:PCPT]PERCLOEXC([M:DIV]DPC-1),
#&             [M:PCPT]ENDDPE([M:DIV]DPC-1), [M:PCPT]EXCDPR([M:DIV]DPC-1), [M:PCPT]PERENDDPE([M:DIV]DPC-1),
#&             [M:PCPT]PEREXCDPR([M:DIV]DPC-1), [M:PCPT]NBV([M:DIV]DPC-1),
#&             [M:PCPT]LEGCUM([M:DIV]DPC-1),    [M:PCPT]LEGRVECUM([M:DIV]DPC-1),
#&             [M:PCPT]PERLEGCUM([M:DIV]DPC-1), [M:PCPT]PERLEGRVE([M:DIV]DPC-1),
#&             [M:PCPT]FIYENDDAT([M:DIV]DPC-1), [M:PCPT]PERSTRDAT([M:DIV]DPC-1), [M:PCPT]PERENDDAT([M:DIV]DPC-1),
#&             [M:PCPT]PSTDER([M:DIV]DPC-1), [M:PCPT]PSTDERRVE([M:DIV]DPC-1),
#&             WLEG_F, WLEGRVE_F, WLEG_C, WLEGRVE_C, WDERDEV_C, WDERRVEDEV_C, WDERRVEISS, RTRN)

      # Si le contexte d'appel est "CALCUL" ou "CALP_1" il n'y aura pas d'écriture de trace.
      # Si le contexte d'appel est "CALP_1" ou "EXTP_1" il n'y aura pas de surcharge du à l'aide fiscale.
      Call  CAL_PER_DEROG_REINT( "CALP_1",
&             [M:DIV]BSOR, [F:WFAS]ISSDAT, [F:WFAS]OWNTYP, [F:WFAS]GACACN, [M:DIV]CUR, [M:DIV]BACTCCN,
&             [M:DIV]FLGDERBEC, [F:WFAS]CCNETRTYP, [M:PCPT]DPRBAS([M:DIV]DPC-1), [M:PCPT]ALWCOD([M:DIV]DPC-1),
&             [M:PFIS]ALWAMT([M:DIV]DPC-1), [M:PFIS]ALWCUM([M:DIV]DPC-1), [M:PFIS]ALWCOD([M:DIV]DPC-1),
&             [M:PFIS]DPRCUM([M:DIV]DPC-1), 0, 0,
&             [M:PFIS]ENDDPE([M:DIV]DPC-1), [M:PFIS]EXCDPR([M:DIV]DPC-1), [M:PFIS]PERCLOCUM([M:DIV]DPC-1),
&             [M:PFIS]PERCLOEXC([M:DIV]DPC-1), [M:PFIS]NBV([M:DIV]DPC-1),
&             [M:PFIS]LEGCUM([M:DIV]DPC-1),    [M:PFIS]LEGRVECUM([M:DIV]DPC-1),
&             0, 0,
&             [M:PCPT]DPRCUM([M:DIV]DPC-1), 0, 0,
&             [M:PCPT]ENDDPE([M:DIV]DPC-1), [M:PCPT]EXCDPR([M:DIV]DPC-1), [M:PCPT]PERCLOCUM([M:DIV]DPC-1),
&             [M:PCPT]PERCLOEXC([M:DIV]DPC-1), [M:PCPT]NBV([M:DIV]DPC-1),
&             [M:PCPT]LEGCUM([M:DIV]DPC-1),    [M:PCPT]LEGRVECUM([M:DIV]DPC-1),
&             0, 0,
&             [M:PCPT]FIYENDDAT([M:DIV]DPC-1), [M:PCPT]PERSTRDAT([M:DIV]DPC-1), [M:PCPT]PERENDDAT([M:DIV]DPC-1),
&             [M:PCPT]PSTDER([M:DIV]DPC-1), [M:PCPT]PSTDERRVE([M:DIV]DPC-1),
&             WLEG_F, WLEGRVE_F, WLEG_C, WLEGRVE_C, WDERDEV_C, WDERRVEDEV_C, WDERRVEISS, RTRN)


      [M:PCPT]PERLEGCUM([M:DIV]DPC-1) = WLEG_C
      If (WLEG_C <> 0 ) Then
        Call ECR_FICH ("FS1", 5, "CAL_DEROG_REINT - CmP-1 Dérogatoire ="+
&            format$([M:DIV]CURFMT, [M:PCPT]PERLEGCUM([M:DIV]DPC-1))) From =G_GLOB0
      Endif

      [M:PFIS]PERLEGCUM([M:DIV]DPC-1) = WLEG_F
      If (WLEG_F <> 0 ) Then
        Call ECR_FICH ("FS1", 5, "CAL_DEROG_REINT - CmP-1 Réint/Fisc. ="+
&            format$([M:DIV]CURFMT, [M:PFIS]PERLEGCUM([M:DIV]DPC-1))) From =G_GLOB0
      Endif

      [M:PCPT]PERLEGRVE([M:DIV]DPC-1) = WLEGRVE_C
      If (WLEGRVE_C <> 0 ) Then
        Call ECR_FICH ("FS1", 5, "CAL_DEROG_REINT - CmP-1 Dérogatoire Repr. ="+
&            format$([M:DIV]CURFMT, [M:PCPT]PERLEGRVE([M:DIV]DPC-1))) From =G_GLOB0
      Endif

      [M:PFIS]PERLEGRVE([M:DIV]DPC-1) = WLEGRVE_F
      If (WLEGRVE_F <> 0 ) Then
        Call ECR_FICH ("FS1", 5, "CAL_DEROG_REINT - CmP-1 Réint/Fisc. Repr. ="+
&            format$([M:DIV]CURFMT, [M:PFIS]PERLEGRVE([M:DIV]DPC-1))) From =G_GLOB0
      Endif

    Endif
    #-2 ------------------------------------------------


    # >2 >>>>>>>>>>>
    For ID = [M:DIV]DPC To [M:PFIS]NB_DEP

      #-3 -----------------------------------------------
      If ( ID > [M:DIV]DPC ) Then
        # -- Entretien des cumuls
        If ( [M:PCPT]PERSTRDAT(ID-1) = [M:PCPT]FIYSTRDAT(ID-1) ) Then
          #- Exercice
          [M:PCPT]LEGCUM(ID-1)    = [M:PCPT]LEGCUM(ID-2)    + [M:PCPT]PERLEGCUM(ID-2) + [M:PCPT]LEG(ID-2)
          [M:PCPT]LEGRVECUM(ID-1) = [M:PCPT]LEGRVECUM(ID-2) + [M:PCPT]PERLEGRVE(ID-2) + [M:PCPT]LEGRVE(ID-2)
          [M:PFIS]LEGCUM(ID-1)    = [M:PFIS]LEGCUM(ID-2)    + [M:PFIS]PERLEGCUM(ID-2) + [M:PFIS]LEG(ID-2)
          [M:PFIS]LEGRVECUM(ID-1) = [M:PFIS]LEGRVECUM(ID-2) + [M:PFIS]PERLEGRVE(ID-2) + [M:PFIS]LEGRVE(ID-2)
          [M:PCPT]PERLEGCUM(ID-1) = 0.
          [M:PCPT]PERLEGRVE(ID-1) = 0.
          [M:PFIS]PERLEGCUM(ID-1) = 0.
          [M:PFIS]PERLEGRVE(ID-1) = 0.
        Else
          #- Période
          [M:PCPT]PERLEGCUM(ID-1) = [M:PCPT]PERLEGCUM(ID-2) + [M:PCPT]LEG(ID-2)
          [M:PCPT]PERLEGRVE(ID-1) = [M:PCPT]PERLEGRVE(ID-2) + [M:PCPT]LEGRVE(ID-2)
          [M:PFIS]PERLEGCUM(ID-1) = [M:PFIS]PERLEGCUM(ID-2) + [M:PFIS]LEG(ID-2)
          [M:PFIS]PERLEGRVE(ID-1) = [M:PFIS]PERLEGRVE(ID-2) + [M:PFIS]LEGRVE(ID-2)
          [M:PCPT]LEGCUM(ID-1)    = [M:PCPT]LEGCUM(ID-2)
          [M:PCPT]LEGRVECUM(ID-1) = [M:PCPT]LEGRVECUM(ID-2)
          [M:PFIS]LEGCUM(ID-1)    = [M:PFIS]LEGCUM(ID-2)
          [M:PFIS]LEGRVECUM(ID-1) = [M:PFIS]LEGRVECUM(ID-2)
        Endif
      Endif
      #-3 -----------------------------------------------

      # FQ96461, FQ107633
      Call  CAL_PER_DEROG_REINT( "CALCUL",
&                                [M:DIV]BSOR, [F:WFAS]ISSDAT, [F:WFAS]OWNTYP, [F:WFAS]GACACN, [M:DIV]CUR, [M:DIV]BACTCCN,
&                                [M:DIV]FLGDERBEC, [F:WFAS]CCNETRTYP, [M:PCPT]DPRBAS([M:DIV]DPC-1), [M:PCPT]ALWCOD(ID-1),
&                                [M:PFIS]ALWAMT(ID-1), [M:PFIS]ALWCUM(ID-1), [M:PFIS]ALWCOD(ID-1),
&                                [M:PFIS]DPRCUM(ID-1), [M:PFIS]PERCLOCUM(ID-1), [M:PFIS]PERCLOEXC(ID-1),
&                                [M:PFIS]ENDDPE(ID-1), [M:PFIS]EXCDPR(ID-1), [M:PFIS]PERENDDPE(ID-1),
&                                [M:PFIS]PEREXCDPR(ID-1), [M:PFIS]NBV(ID-1),
&                                [M:PFIS]LEGCUM(ID-1),    [M:PFIS]LEGRVECUM(ID-1),
&                                [M:PFIS]PERLEGCUM(ID-1), [M:PFIS]PERLEGRVE(ID-1),
&                                [M:PCPT]DPRCUM(ID-1), [M:PCPT]PERCLOCUM(ID-1), [M:PCPT]PERCLOEXC(ID-1),
&                                [M:PCPT]ENDDPE(ID-1), [M:PCPT]EXCDPR(ID-1), [M:PCPT]PERENDDPE(ID-1),
&                                [M:PCPT]PEREXCDPR(ID-1), [M:PCPT]NBV(ID-1),
&                                [M:PCPT]LEGCUM(ID-1),    [M:PCPT]LEGRVECUM(ID-1),
&                                [M:PCPT]PERLEGCUM(ID-1), [M:PCPT]PERLEGRVE(ID-1),
&                                [M:PCPT]FIYENDDAT(ID-1), [M:PCPT]PERSTRDAT(ID-1), [M:PCPT]PERENDDAT(ID-1),
&                                [M:PCPT]PSTDER(ID-1), [M:PCPT]PSTDERRVE(ID-1),
&                                [M:PFIS]LEG(ID-1), [M:PFIS]LEGRVE(ID-1), [M:PCPT]LEG(ID-1), [M:PCPT]LEGRVE(ID-1),
&                                [M:PCPT]DERDEV(ID-1), [M:PCPT]DERRVEDEV(ID-1), [F:WFAS]DERRVEISS, RTRN)


    Next ID
    # >2 >>>>>>>>>>>>


    # Affichage informations  dérogatoire
    PKTPOINTTRT=G_GLOB2 : PBKPOINTNAM="AFTLEGDER" :  PDBGMSK = "" : PDBGPLAN=G301CPT
    Gosub DEBUG_VISU_MSK From GCALDEBUG

    # Affichage informations  réintégration fiscale
    PKTPOINTTRT=G_GLOB2 : PBKPOINTNAM="AFTLEGRFI" :  PDBGMSK = "" : PDBGPLAN=G301FIS
    Gosub DEBUG_VISU_MSK From GCALDEBUG

  Endif
  #-1 -----------------------------------------------


Return


#########################################################
# - Objet  : Retourne les informations de dérogatoire pour une période donnée
#            (la période pouvant être un exercice si pas de découpage en période)
#
# - Entrée :
#
# - Sortie :
#
# FQ96461, FQ107633
#

Subprog CAL_PER_DEROG_REINT( CALLCTX,
&  BSOR, ISSDAT, OWNTYP, GACACN, CUR, BACTCCN, FLGDERBEC, CCNETRTYP, C_DPRBAS, C_ALWCOD,
&  F_ALWAMT, F_ALWCUM, F_ALWCOD, F_DPRCUM, F_PERCLOCUM, F_PERCLOEXC, F_ENDDPE, F_EXCDPR, F_PERENDDPE, F_PEREXCDPR, F_NBV,
&  F_LEGCUM, F_LEGRVECUM, F_PERLEGCUM, F_PERLEGRVE,
&  C_DPRCUM, C_PERCLOCUM, C_PERCLOEXC, C_ENDDPE, C_EXCDPR, C_PERENDDPE, C_PEREXCDPR, C_NBV,
&  C_LEGCUM, C_LEGRVECUM, C_PERLEGCUM, C_PERLEGRVE,
&  C_FIYENDDAT, C_PERSTRDAT, C_PERENDDAT, C_PSTDER, C_PSTDERRVE,
&  F_LEG, F_LEGRVE, C_LEG, C_LEGRVE, C_DERDEV, C_DERRVEDEV, DERRVEISS, RTRN)


#
Value Char       CALLCTX           # Contexte d'appel "CALCUL"
Value Integer    BSOR
Value Date       ISSDAT
Value Integer    OWNTYP
Value Integer    GACACN
Value Char       CUR
Value Integer    BACTCCN
Value Integer    FLGDERBEC
Value Integer    CCNETRTYP
Value Decimal    C_DPRBAS

Value Decimal    C_ALWCOD
Value Decimal    F_ALWAMT
Value Decimal    F_ALWCUM
Value Decimal    F_ALWCOD

Value Decimal    F_DPRCUM
Value Decimal    F_PERCLOCUM
Value Decimal    F_PERCLOEXC
Value Decimal    F_ENDDPE
Value Decimal    F_EXCDPR
Value Decimal    F_PERENDDPE
Value Decimal    F_PEREXCDPR
Value Decimal    F_NBV
Value Decimal    F_LEGCUM
Value Decimal    F_LEGRVECUM
Value Decimal    F_PERLEGCUM
Value Decimal    F_PERLEGRVE

Value Decimal    C_DPRCUM
Value Decimal    C_PERCLOCUM
Value Decimal    C_PERCLOEXC
Value Decimal    C_ENDDPE
Value Decimal    C_EXCDPR
Value Decimal    C_PERENDDPE
Value Decimal    C_PEREXCDPR
Value Decimal    C_NBV
Value Decimal    C_LEGCUM
Value Decimal    C_LEGRVECUM
Value Decimal    C_PERLEGCUM
Value Decimal    C_PERLEGRVE

Value Date       C_FIYENDDAT
Value Date       C_PERSTRDAT
Value Date       C_PERENDDAT
Value Decimal    C_PSTDER
Value Decimal    C_PSTDERRVE

Variable Decimal F_LEG
Variable Decimal F_LEGRVE
Variable Decimal C_LEG
Variable Decimal C_LEGRVE
Variable Decimal C_DERDEV
Variable Decimal C_DERRVEDEV
Variable Decimal DERRVEISS
Variable Integer RTRN

Local Decimal WDEREXE
Local Decimal WECADER
Local Decimal WCOEAFI  :  WCOEAFI = 1.
Local Decimal WSLD

Local Decimal  FIS_CUM  : FIS_CUM = F_DPRCUM    + F_PERCLOCUM   + F_PERCLOEXC
Local Decimal  FIS_EXE  : FIS_EXE = F_ENDDPE    + F_EXCDPR
Local Decimal  FIS_PER  : FIS_PER = F_PERENDDPE + F_PEREXCDPR


Local Decimal  CPT_CUM  : CPT_CUM = C_DPRCUM    + C_PERCLOCUM   + C_PERCLOEXC
Local Decimal  CPT_EXE  : CPT_EXE = C_ENDDPE    + C_EXCDPR
Local Decimal  CPT_PER  : CPT_PER = C_PERENDDPE + C_PEREXCDPR


  #-------------------------------------------------
  C_LEG     = 0.
  C_LEGRVE  = 0.
  F_LEG     = 0.
  F_LEGRVE  = 0.
  #-------------------------------------------------
  #-- Prise en compte de l'aide fiscale ( 25%, 50%, 39bis ) dans le calcul du dérogatoire
  #   ne concerne que le premier exercice d'amortissement
  #- 1 ------------------------------------------------
  If ( F_ALWAMT  <> 0 and F_ALWCUM  = 0  and find (F_ALWCOD , GVML_RPAID25, GVML_RPAID50, GVML_RPPR39B) ) Then

    #-- Dans ce contexte, on ne peut être qu'en situation de Provision/Reprise de dérogatoire
    If ( find(CALLCTX, "EXTP_1", "CALP_1") > 0 ) Then
      # En reconstitution P_1, F_PERENDDPE contient l'equivalent de F_PERCLOCUM
      If ( F_PERENDDPE  <> 0 ) Then
        # On passe l'aide fiscale en cumul provision P-1 si cumul amort P-1 repris
        C_LEG   = F_ALWAMT
      Endif
    Else
      If ( F_PERCLOCUM  = 0 ) Then
        # On est dans la période où l'on doit comptabiliser  l'aide fiscale en Provision de dérogatoire
        C_LEG   = F_ALWAMT
      Endif
    Endif

    #-2 --------
    # FQ107633 If ( abs(FIS_EXE - CPT_EXE) > abs(F_ALWAMT) ) Then
    If (func GLOBB9.CAL_CMP_MNT ( (FIS_EXE - CPT_EXE),">",F_ALWAMT, C_DPRBAS)) Then
      #-- Dérogatoire : Provision
      WDEREXE = FIS_EXE - CPT_EXE
      If (WDEREXE) Then
        WCOEAFI = ((( WDEREXE - F_ALWAMT ) * 100. ) / WDEREXE ) / 100
      Else
        WCOEAFI = 1.
      Endif

      C_LEG = C_LEG + ( (FIS_PER - CPT_PER) * WCOEAFI )
      Call CAL_ARRONDI_MNT (C_LEG, CUR, C_LEG) From =G_GLOB8

      If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
        Call ECR_FICH ("FS1", 5, "CAL_DEROG_REINT - Dérogatoire Prov. ="+ format$([M:DIV]CURFMT, C_LEG )) From =G_GLOB0
      Endif

      If ( C_PERENDDAT = C_FIYENDDAT or func GLOBB9.CAL_DAT_INSIDE(ISSDAT, C_PERSTRDAT , C_PERENDDAT ,"I") ) Then
        # Ajustement en fin d'exercice ou dans la période de sortie
        WECADER = WDEREXE - ( (C_PERLEGCUM + C_LEG) - ( C_PERLEGRVE + C_LEGRVE ) )
        C_LEG   = C_LEG   - WECADER
      Endif
    Endif
    #-2 --------

    #-2 --------
    # FQ107633 If ( abs(FIS_EXE - CPT_EXE ) < abs(F_ALWAMT ) ) Then
    If (func GLOBB9.CAL_CMP_MNT ( (FIS_EXE - CPT_EXE),"<",F_ALWAMT, C_DPRBAS)) Then
      #-- Dérogatoire : Reprise
      #   On est toujours en situation de prov. car la dot. exercice fiscal contient l'aide fiscale
      WDEREXE = FIS_EXE - CPT_EXE
      If (WDEREXE) Then
        WCOEAFI = (((F_ALWAMT - WDEREXE) * 100. ) / WDEREXE ) / 100
      Else
        WCOEAFI = 1.
      Endif
      C_LEGRVE  = ( (FIS_PER - CPT_PER) * WCOEAFI  )
      Call CAL_ARRONDI_MNT (C_LEGRVE , CUR , C_LEGRVE  ) From =G_GLOB8
      If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
        Call ECR_FICH ("FS1", 5, "CAL_DEROG_REINT - Dérogatoire Repr. ="+ format$([M:DIV]CURFMT, C_LEGRVE )) From =G_GLOB0
      Endif

      If ( C_PERENDDAT = C_FIYENDDAT  or func GLOBB9.CAL_DAT_INSIDE(ISSDAT, C_PERSTRDAT , C_PERENDDAT ,"I") ) Then
        # Ajustement en fin d'exercice ou dans la période de sortie
        WECADER = WDEREXE - ( (C_PERLEGCUM + C_LEG) - ( C_PERLEGRVE + C_LEGRVE ) )
        C_LEGRVE  = C_LEGRVE  - WECADER
      Endif
    Endif
    #-2 --------

  #-1 -----------------------------------------------
  Else

    #-- Cas classique
    #-2 -----------------------------------------------
    # FQ107633   If ( abs(CPT_PER) > abs(FIS_PER)   and
    #&        ( (CPT_CUM = 0 and FIS_CUM = 0) or (abs(CPT_CUM) >= abs(FIS_CUM)) )  ) Then
    If (func GLOBB9.CAL_CMP_MNT ( CPT_PER, ">",FIS_PER, C_DPRBAS) and
&       ((CPT_CUM = 0 and FIS_CUM = 0) or (func GLOBB9.CAL_CMP_MNT ( CPT_CUM, ">=",FIS_CUM, C_DPRBAS))) ) Then
      #--------------------------------
      #-- Réint. fiscale : Provision
      #--------------------------------
      F_LEG = CPT_PER - FIS_PER
      If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
        Call ECR_FICH ("FS1", 5, "CAL_DEROG_REINT - Réint/Fisc.         (CS3) ="+ format$([M:DIV]CURFMT, F_LEG)) From =G_GLOB0
      Endif

    #-2 -----------------------------------------------
    # FQ107633    Elsif ( abs(FIS_PER) > abs(CPT_PER) and
    #&           ( (CPT_CUM = 0 and FIS_CUM = 0) or (abs(FIS_CUM) >= abs(CPT_CUM)) )  ) Then
    Elsif (func GLOBB9.CAL_CMP_MNT ( FIS_PER, ">",CPT_PER, C_DPRBAS) and
&       ((CPT_CUM = 0 and FIS_CUM = 0) or (func GLOBB9.CAL_CMP_MNT ( FIS_CUM, ">=",CPT_CUM, C_DPRBAS))) ) Then
      #--------------------------------
      #-- Dérogatoire : Provision
      #--------------------------------
      C_LEG = FIS_PER - CPT_PER
      If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
        Call ECR_FICH ("FS1", 6, "CAL_DEROG_REINT - Dérogatoire Prov.   (CS1) ="+ format$([M:DIV]CURFMT, C_LEG)) From =G_GLOB0
      Endif

    #-2 -----------------------------------------------
    # FQ107633   Elsif ( abs(FIS_PER) < abs(CPT_PER) and
    #&           abs(FIS_CUM) > abs(CPT_CUM) and FIS_CUM <>  0  ) Then
    Elsif ( func GLOBB9.CAL_CMP_MNT ( FIS_PER, "<",CPT_PER, C_DPRBAS) and
&           func GLOBB9.CAL_CMP_MNT ( FIS_CUM, ">",CPT_CUM, C_DPRBAS) and  FIS_CUM <>  0 ) Then

      WSLD = (C_LEGCUM  + C_PERLEGCUM ) - (C_LEGRVECUM  + C_PERLEGRVE )

      # FQ107633 If ( WSLD <> 0 and abs(WSLD) >= abs(CPT_PER - FIS_PER) ) Then
      If ( WSLD <> 0 and func GLOBB9.CAL_CMP_MNT ( WSLD,">=",(CPT_PER - FIS_PER), C_DPRBAS)) Then
        #--------------------------------
        #-- Dérogatoire : Reprise
        #--------------------------------
        C_LEGRVE = CPT_PER - FIS_PER
        If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
          Call ECR_FICH ("FS1", 6, "CAL_DEROG_REINT - Dérogatoire Repr. (CS2) ="+ format$([M:DIV]CURFMT, C_LEGRVE)) From =G_GLOB0
        Endif
      Else
        #--------------------------------
        #-- Dérogatoire : Reprise  / Réint. fiscale : Provision
        #--------------------------------
        C_LEGRVE   = WSLD
        If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
          Call ECR_FICH ("FS1", 6, "CAL_DEROG_REINT - Dérogatoire Repr. (CC3) ="+ format$([M:DIV]CURFMT, C_LEGRVE)) From =G_GLOB0
        Endif
        #-- Réint. fiscale : Provision
        F_LEG = CPT_PER - FIS_PER -  WSLD
        If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
          Call ECR_FICH ("FS1", 5, "CAL_DEROG_REINT - Réint/Fisc.       (CC3) ="+ format$([M:DIV]CURFMT, F_LEG)) From =G_GLOB0
        Endif
      Endif

    #-2 -----------------------------------------------
    # FQ107633 Elsif ( abs(FIS_PER) > abs(CPT_PER) and abs(FIS_CUM) < abs(CPT_CUM) and CPT_CUM <>  0  ) Then
    Elsif ( func GLOBB9.CAL_CMP_MNT ( FIS_PER, ">",CPT_PER, C_DPRBAS) and
&           func GLOBB9.CAL_CMP_MNT ( FIS_CUM, "<",CPT_CUM, C_DPRBAS) and  CPT_CUM <>  0 ) Then

      WSLD = (F_LEGCUM + F_PERLEGCUM ) - (F_LEGRVECUM  + F_PERLEGRVE )

      # FQ107633 If ( WSLD <> 0 and abs(WSLD) >=  abs(FIS_PER - CPT_PER)    ) Then
      If ( WSLD <> 0 and func GLOBB9.CAL_CMP_MNT ( WSLD,">=",(FIS_PER - CPT_PER), C_DPRBAS)) Then

        #--------------------------------
        #-- Réint. fiscale : Reprise
        #--------------------------------
        F_LEGRVE = FIS_PER - CPT_PER
        If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
          Call ECR_FICH ("FS1", 6, "CAL_DEROG_REINT - Réint/Fisc. Repr. (CS4) ="+ format$([M:DIV]CURFMT, F_LEGRVE)) From =G_GLOB0
        Endif
      Else
        #--------------------------------
        #-- Réint. fiscale : Reprise / Dérogatoire : Provision
        #--------------------------------
        F_LEGRVE   = WSLD
        If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
          Call ECR_FICH ("FS1", 6, "CAL_DEROG_REINT - Réint/Fisc. Repr. (CC1) ="+ format$([M:DIV]CURFMT, F_LEGRVE)) From =G_GLOB0
        Endif
        #-- Dérogatoire : Provision
        C_LEG = FIS_PER - CPT_PER -  WSLD
        If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
          Call ECR_FICH ("FS1", 5, "CAL_DEROG_REINT - Dérogatoire Prov. (CC1) ="+ format$([M:DIV]CURFMT, C_LEG)) From =G_GLOB0
        Endif
      Endif
    Endif
    #-2 -----------------------------------------------
  Endif
  #-1 -----------------------------------------------

  # Si le bien est sorti, il faut reprendre le dérogatoire
  # Sauf s'il s'agit du premier bien cédé de la concession car il continue à s'amortir.
  #-1 -----------------------------------------------
  #DERRVEISS = 0 : FQ108030
  If ( BSOR ) Then
    If ( BACTCCN and CCNETRTYP = GVML_NA1ERBC and
&        ( F_ALWCOD  = GVML_RPCONCE or C_ALWCOD  = GVML_RPCONCE ) ) Then
      # Pas de reprise de Dérogatoire
      DERRVEISS = 0 : # FQ108030
    Else
      # Reprise de Dérogatoire sur sortie FQ106806 FQ108030
      If ( func GLOBB9.CAL_DAT_INSIDE(ISSDAT, C_PERSTRDAT , C_PERENDDAT ,"I") or ISSDAT < C_PERSTRDAT  ) Then
        # La reprise a lieu dans la période de sortie sauf s'il s'agit d'une SRA
        # Dans ce cas, la reprise de dérogatoire a lieu dans la période courante.
        DERRVEISS =  (C_LEGCUM + C_PERLEGCUM + C_LEG) - (C_LEGRVECUM + C_PERLEGRVE + C_LEGRVE)
        If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
          Call ECR_FICH ("FS1", 6, "CAL_DEROG_REINT - Sortie Dérog Repr ="+
&                format$( [M:DIV]CURFMT, DERRVEISS )) From =G_GLOB0
        Endif
      Endif
    Endif
  #-1 -----------------------------------------------
  Else
    # le bien n'est pas sorti : Pas de reprise de Dérogatoire FQ108030
    DERRVEISS = 0
  Endif
  #-1 -----------------------------------------------

  #-- Dérogatoire à comptabiliser
  #-1 -----------------------------------------------
  If ( OWNTYP <> GVML_TDPREVU and
&     (GACACN <> GVML_NIENCOU  or FLGDERBEC = G_OUI) ) Then
    C_DERDEV      = C_LEG      - C_PSTDER
    C_DERRVEDEV   = C_LEGRVE   - C_PSTDERRVE
  Else
    # Pas de dérogatoire à comptabiliser pour un bien dont le type de détention est "En prévision"
    # Pas de dérogatoire à comptabiliser pour bien dont la nature comptable PCG est "Immo en cours"
    # Sauf si le contraire a été paramétré c'est-à-dire :
    #      si le paramètre société "Dérogatoire sur Immo. en cours" a été positionné,
    #      dans ce cas le mode du plan comptable est "SA" et un mode <> "SA" a pu être appliqué au plan fiscal
    C_DERDEV      = 0
    C_DERRVEDEV   = 0
  Endif
  #-1 -----------------------------------------------
End

#
#########################################################
$CAL_PLANS_LIES
#
# - Objet  :
#
#
# - Entrée : Cette fonction gère les liens entre plans
#

  #----------------------------------------
  # Lien générique  / Plans du contexte  FQ79813
  #----------------------------------------

  # Un plan dit "Maitre" peut posséder un plan lié dit "Esclave"
  # Le plan "Maitre" portera les écarts (Plan maître - Plan esclave)

Local Integer DEB
Local Integer N_P
Local Char    PABRM
Local Char    PABRE

  # Si le bien a été sorti dans un exercice antérieur à l'exercice courant on ne calcule pas les liens entre plan
  #FQ66341
  If ( [F:WFAS]ISSDAT <> [0/0/0] and [F:WFAS]ISSDAT < [M:FIY]DATSTRFIY([M:DIV]FEC-1) and
&      (not ([M:DIV]BACTCCN) or ([M:DIV]BACTCCN and [F:WFAS]CCNETRTYP <> GVML_NA1ERBC )) ) Then
    Call ECR_FICH ( "FS1", 3, "CALCUL_PLAN_LIENS - "-"Aucun calcul amortissement bien sorti dans un exercice antérieur"  ) From =G_GLOB0
    Return
  Endif

  #If (GUSER = "MWA") Then : Dbgaff : Endif

  DEB = find([M:DIV]CNT, [M:DIV]PLNCNT)
  # > 1 >>>>>>>>>>>
  # Pour chaque plan d'amortissement rattaché au contexte
  For N_P = DEB To [M:DIV]NB_PLN
    # Si le plan d'amortissement n'appartient plus au contexte en cours de calcul
    If ( [M:DIV]PLNCNT (N_P-1) <> [M:DIV]CNT )  Then : Break : Endif
      #-1 ---------------
      If ( [M:DIV]LNKPLN(N_P-1) <> 0 ) Then

        If clalev([M:MAI]) =0   : Local Mask CALDEP   [MAI]   :  Endif  : # Maître  FQ79813
        If clalev([M:ESC]) =0   : Local Mask CALDEP   [ESC]   :  Endif  : # Esclave FQ79813

        #-- "Plan Maitre" FQ79813
        Case [M:DIV]PLNCAA(N_P-1)
          When G301CPT  : Transmask [M:PCPT] To [M:MAI]
          When G301FIS  : Transmask [M:PFIS] To [M:MAI]
          When G301MIN  : Transmask [M:PMIN] To [M:MAI]
          When G301ORI  : Transmask [M:PORI] To [M:MAI]
          When G301R76  : Transmask [M:PR76] To [M:MAI]
          When G301IAS  : Transmask [M:PIAS] To [M:MAI]
          When G301TEC  : Transmask [M:PTEC] To [M:MAI]
          When G301RET  : Transmask [M:PRET] To [M:MAI]
          When G301SUB  : Transmask [M:PSUB] To [M:MAI]
          When G301LI1  : Transmask [M:PLI1] To [M:MAI]
          When G301LI2  : Transmask [M:PLI2] To [M:MAI]
          When G301LI3  : Transmask [M:PLI3] To [M:MAI]
          When G301LI4  : Transmask [M:PLI4] To [M:MAI]
          When G301LI5  : Transmask [M:PLI5] To [M:MAI]
          When G301LI6  : Transmask [M:PLI6] To [M:MAI]
        Endcase
        #-- "Plan Esclave"
        Case [M:DIV]LNKPLN(N_P-1)
          When G301CPT  : Transmask [M:PCPT] To [M:ESC]
          When G301FIS  : Transmask [M:PFIS] To [M:ESC]
          When G301MIN  : Transmask [M:PMIN] To [M:ESC]
          When G301ORI  : Transmask [M:PORI] To [M:ESC]
          When G301R76  : Transmask [M:PR76] To [M:ESC]
          When G301IAS  : Transmask [M:PIAS] To [M:ESC]
          When G301TEC  : Transmask [M:PTEC] To [M:ESC]
          When G301RET  : Transmask [M:PRET] To [M:ESC]
          When G301SUB  : Transmask [M:PSUB] To [M:ESC]
          When G301LI1  : Transmask [M:PLI1] To [M:ESC]
          When G301LI2  : Transmask [M:PLI2] To [M:ESC]
          When G301LI3  : Transmask [M:PLI3] To [M:ESC]
          When G301LI4  : Transmask [M:PLI4] To [M:ESC]
          When G301LI5  : Transmask [M:PLI5] To [M:ESC]
          When G301LI6  : Transmask [M:PLI6] To [M:ESC]
        Endcase


        Call ECR_FICH ("FS1", 4, "CAL_PLANS_LIES - Ecart entre Plans ") From =G_GLOB0
        Call ECR_FICH ("FS1", 5, "CAL_PLANS_LIES - Ecart Maitre  ="+
&            mess([M:DIV]PLNCAA(N_P-1), GML_NPLAN,1)) From =G_GLOB0
        Call ECR_FICH ("FS1", 5, "CAL_PLANS_LIES - Ecart Esclave ="+
&            mess([M:DIV]LNKPLN(N_P-1), GML_NPLAN,1)) From =G_GLOB0

        #- Cumul écart E-1
        [M:MAI]LNKCUM([M:DIV]DPC-1) = [M:MAI]DPRCUM([M:DIV]DPC-1)
&                                   - [M:ESC]DPRCUM([M:DIV]DPC-1)

        Call ECR_FICH ("FS1", 5, "CAL_PLANS_LIES - Ecart Cumul E-1 ="+
&            format$([M:DIV]CURFMT, [M:MAI]LNKCUM([M:DIV]DPC-1))) From =G_GLOB0

        #- Cumul écart P-1
        [M:MAI]PERLNKCUM([M:DIV]DPC-1) = [M:MAI]PERCLOCUM([M:DIV]DPC-1)
&                                      + [M:MAI]PERCLOEXC([M:DIV]DPC-1)
&                                      - [M:ESC]PERCLOCUM([M:DIV]DPC-1)
&                                      - [M:ESC]PERCLOEXC([M:DIV]DPC-1)

        Call ECR_FICH ("FS1", 5, "CAL_PLANS_LIES - Ecart Cumul P-1 ="+
&            format$([M:DIV]CURFMT, [M:MAI]PERLNKCUM([M:DIV]DPC-1))) From =G_GLOB0

        # > 2 >>>>>>>>>>>>
        For ID = [M:DIV]DPC To [M:MAI]NB_DEP
          If ( ID > [M:DIV]DPC ) Then
            # -- Entretien des cumuls
            If ( [M:MAI]PERSTRDAT(ID-1) = [M:MAI]FIYSTRDAT(ID-1) ) Then
              #- Exercice
              [M:MAI]LNKCUM(ID-1)    = [M:MAI]LNKCUM   (ID-2)
&                                    + [M:MAI]PERLNKCUM(ID-2)
&                                    + [M:MAI]LNK      (ID-2)
              [M:MAI]PERLNKCUM(ID-1) = 0.
            Else
              #- Période
              [M:MAI]PERLNKCUM(ID-1) = [M:MAI]PERLNKCUM(ID-2)
&                                    + [M:MAI]LNK      (ID-2)
              [M:MAI]LNKCUM(ID-1)    = [M:MAI]LNKCUM   (ID-2)
            Endif
          Endif

          [M:MAI]LNK(ID-1) = [M:MAI]PERENDDPE(ID-1)
&                          + [M:MAI]PEREXCDPR(ID-1)
&                          - [M:ESC]PERENDDPE(ID-1)
&                          - [M:ESC]PEREXCDPR(ID-1)

          Call ECR_FICH ("FS1", 5, "CAL_PLANS_LIES - Ecart/Plan ="+
&              format$([M:DIV]CURFMT, [M:MAI]LNK(ID-1))) From =G_GLOB0

          # FQ64544
          # Les champs PST "comptabilisé" sont actualisés par la génération des écritures comptables
          If ( [F:WFAS]OWNTYP = GVML_TDPREVU ) Then
            # Un bien en prévision ne peut pas avoir de "A comptabiliser"
            [M:MAI]LNKDEV(ID-1) = 0.
          Else

            # FQ84283
            Local Decimal WLNK
            WLNK = [M:MAI]LNK(ID-1)

            Local Decimal M_PERENDDPE : M_PERENDDPE = [M:MAI]PERENDDPE(ID-1)
            If ( find([M:MAI]DPM(ID-1), G_DPMAL, G_DPMAD) > 0 and [M:MAI]DPRRAT2(ID-1) <> 0 ) Then
              M_PERENDDPE = [M:MAI]PERENDDPE(ID-1) * (1-[M:MAI]DPRRAT2(ID-1))
              #Call CAL_ARRONDI_MNT (M_PERENDDPE, [M:DIV]CUR , M_PERENDDPE) From =G_GLOB8
              [M:DIV]PV(0)= M_PERENDDPE : [M:DIV]PC(0)= [M:DIV]CUR
              Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : M_PERENDDPE = [M:DIV]RV(1)
          Endif
            Local Decimal E_PERENDDPE : E_PERENDDPE = [M:ESC]PERENDDPE(ID-1)
            If ( find([M:ESC]DPM(ID-1), G_DPMAL, G_DPMAD) > 0 and [M:ESC]DPRRAT2(ID-1) <> 0 ) Then
              E_PERENDDPE = [M:ESC]PERENDDPE(ID-1) * (1-[M:ESC]DPRRAT2(ID-1))
              #Call CAL_ARRONDI_MNT (E_PERENDDPE, [M:DIV]CUR , E_PERENDDPE) From =G_GLOB8
              [M:DIV]PV(0)= E_PERENDDPE : [M:DIV]PC(0)= [M:DIV]CUR
              Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : E_PERENDDPE = [M:DIV]RV(1)
          Endif

            If (M_PERENDDPE <> [M:MAI]PERENDDPE(ID-1) or E_PERENDDPE <> [M:ESC]PERENDDPE(ID-1)) Then
              WLNK = M_PERENDDPE
&                  + [M:MAI]PEREXCDPR(ID-1)
&                  - E_PERENDDPE
&                  - [M:ESC]PEREXCDPR(ID-1)
            Endif

            [M:MAI]LNKDEV(ID-1) = WLNK - [M:MAI]PSTLNK(ID-1)
          Endif

        Next ID
        # > 2 >>>>>>>>>>>>

        #-- "Plan Maitre" FQ79813
        Case [M:DIV]PLNCAA(N_P-1)
          When G301CPT  : Transmask [M:MAI] To [M:PCPT]
          When G301FIS  : Transmask [M:MAI] To [M:PFIS]
          When G301MIN  : Transmask [M:MAI] To [M:PMIN]
          When G301ORI  : Transmask [M:MAI] To [M:PORI]
          When G301R76  : Transmask [M:MAI] To [M:PR76]
          When G301IAS  : Transmask [M:MAI] To [M:PIAS]
          When G301TEC  : Transmask [M:MAI] To [M:PTEC]
          When G301RET  : Transmask [M:MAI] To [M:PRET]
          When G301SUB  : Transmask [M:MAI] To [M:PSUB]
          When G301LI1  : Transmask [M:MAI] To [M:PLI1]
          When G301LI2  : Transmask [M:MAI] To [M:PLI2]
          When G301LI3  : Transmask [M:MAI] To [M:PLI3]
          When G301LI4  : Transmask [M:MAI] To [M:PLI4]
          When G301LI5  : Transmask [M:MAI] To [M:PLI5]
          When G301LI6  : Transmask [M:MAI] To [M:PLI6]
        Endcase
        #-- "Plan Esclave"
        Case [M:DIV]LNKPLN(N_P-1)
          When G301CPT  : Transmask [M:ESC] To [M:PCPT]
          When G301FIS  : Transmask [M:ESC] To [M:PFIS]
          When G301MIN  : Transmask [M:ESC] To [M:PMIN]
          When G301ORI  : Transmask [M:ESC] To [M:PORI]
          When G301R76  : Transmask [M:ESC] To [M:PR76]
          When G301IAS  : Transmask [M:ESC] To [M:PIAS]
          When G301TEC  : Transmask [M:ESC] To [M:PTEC]
          When G301RET  : Transmask [M:ESC] To [M:PRET]
          When G301SUB  : Transmask [M:ESC] To [M:PSUB]
          When G301LI1  : Transmask [M:ESC] To [M:PLI1]
          When G301LI2  : Transmask [M:ESC] To [M:PLI2]
          When G301LI3  : Transmask [M:ESC] To [M:PLI3]
          When G301LI4  : Transmask [M:ESC] To [M:PLI4]
          When G301LI5  : Transmask [M:ESC] To [M:PLI5]
          When G301LI6  : Transmask [M:ESC] To [M:PLI6]
        Endcase

        # Affichage informations  Après lien entre plans ( Maitre)
        PKTPOINTTRT=G_GLOB2 : PBKPOINTNAM="AFTLNKPLN" :  PDBGMSK = "" : PDBGPLAN=[M:DIV]PLNCAA(N_P-1)
        Gosub DEBUG_VISU_MSK From GCALDEBUG

      Endif
      #-1 ---------------
  Next N_P
  # < 1 <<<<<<<<<<<

  If (clalev([M:MAI])) Then : Close Local Mask [MAI] : Endif : # Maitre  FQ79813
  If (clalev([M:ESC])) Then : Close Local Mask [ESC] : Endif : # Esclave FQ79813

Return

#
#########################################################
Subprog CALCUL_DEPRECIATION
#
# - Objet  :
#
# - Entrée :
#
# - Sortie :
#
#


  #- 1---------------------------------------------------
  # FQ72008 If ( [F:DEPC]IML = 0 ) Then
  If ( [F:DEPC]IML = 0 and [F:DEPC]IMLRVE = 0 ) Then
    #--
    # Cas normal : Pas de dépréciation à prendre en compte
    [M:DIV]BIML = 0
    #--
  #- 1---------------------------------------------------
  Else

    Call ECR_FICH("FS1", 10, "Prise en compte d'une DEPRECIATION ") From =G_GLOB0
    #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

    # A passer en CLORE_APRES_DEPRECIATION
    # S'il y a eu une dépréciation sur la période/exercice courant,
    # la période/exercice est considérée comme déjà calculée
    # 2 possibilités :
    # 1- On passe dans la boucle en sautant les calculs et en passant par la clôture période exercice
    # 2- On réalise à priori la clôture période, on demarre le cacul sur la période suivant la dépréciation.
    # Seule la 2 est possible car on doit tjrs calculer d'abord la dot. exerc. pour avoir celles des périodes
    # Positionnement booleen "Dépréciation période"
    [M:DIV]BIML = 1
    # Recherche indice du mode d'amortissement
    [M:DIV]LVLLIB = "8.CAL_LOCALISE_MODE" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call CAL_LOCALISE_MODE
&        ( [F:DEPC]DPM, [F:DEPC]STRDPRDAT, [F:DEPC]FIYSTRDAT,  [F:DEPC]FIYENDDAT,
&          [M:DIV]INDMOD, [M:DIV]INDANNLB, [M:DIV]TXLB, [M:DIV]TX2LB, [M:DIV2]RGRPPER ) From =G_GLOB8  : # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
    If ([M:DIV]ERROR) Then : End : Endif

    # Clôture période effectuée = Faux
    [M:DIV]BCLOPER = 0
    # Clôture période
    [M:DIV]LVLLIB = "2.CLOTURE_PERIODE" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call CLOTURE_PERIODE  From =G_GLOB2
    If ([M:DIV]ERROR) Then : End : Endif
    If ( [F:DEPC]FIYENDDAT <> [F:DEPS]FIYENDDAT or [F:DEPC]PERENDDAT <> [F:DEPS]PERENDDAT ) Then
      #-- Clôture exercice
      [M:DIV]LVLLIB = "2.CLOTURE_EXERCICE" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call CLOTURE_EXERCICE  From =G_GLOB2
      If ([M:DIV]ERROR) Then : End : Endif
    Endif

  Endif
  #- 1---------------------------------------------------

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#
#########################################################
Subprog CALCUL_REEV_FIN_EXE
#
# - Objet  : FQ79819
#
# - Entrée :
#
# - Sortie :
#
#


  #- 1---------------------------------------------------
  If ( [F:DEPC]RVATIADAT <> GVML_ERENDEX ) Then
    #--
    # Cas normal : Pas de réévaluation fin exercice à prendre en compte
    [M:DIV]BRFE = 0
    #--
  #- 1---------------------------------------------------
  Else

    Call ECR_FICH("FS1", 10, "Prise en compte d'une REEVALUATION Fin Exercice ") From =G_GLOB0
    #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

    # S'il y a eu une réévaluation fin exercice sur la période/exercice courant,
    # la période/exercice est considérée comme déjà calculée
    # On conserve la même cinématique que pour la dépréciation
    # Positionnement booleen "Réévaluation fin exercice"
    [M:DIV]BRFE = 1
    # Recherche indice du mode d'amortissement
    [M:DIV]LVLLIB = "8.CAL_LOCALISE_MODE" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call CAL_LOCALISE_MODE
&        ( [F:DEPC]DPM, [F:DEPC]STRDPRDAT, [F:DEPC]FIYSTRDAT,  [F:DEPC]FIYENDDAT,
&          [M:DIV]INDMOD, [M:DIV]INDANNLB, [M:DIV]TXLB, [M:DIV]TX2LB, [M:DIV2]RGRPPER ) From =G_GLOB8  : # X3-54580
    If ([M:DIV]ERROR) Then : End : Endif

    # Clôture période NON effectuée
    [M:DIV]BCLOPER = 0
    # Clôture période
    [M:DIV]LVLLIB = "2.CLOTURE_PERIODE" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call CLOTURE_PERIODE  From =G_GLOB2
    If ([M:DIV]ERROR) Then : End : Endif
    If ( [F:DEPC]FIYENDDAT <> [F:DEPS]FIYENDDAT or [F:DEPC]PERENDDAT <> [F:DEPS]PERENDDAT ) Then
      #-- Clôture exercice
      [M:DIV]LVLLIB = "2.CLOTURE_EXERCICE" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call CLOTURE_EXERCICE  From =G_GLOB2
      If ([M:DIV]ERROR) Then : End : Endif
    Endif

  Endif
  #- 1---------------------------------------------------

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#
#########################################################
$CALCUL_SORTIE_RETROACTIVE
#
# - Objet  :
#
# - Entrée :
#
# - Sortie :
#
#

Local Date    WDTDBPER
Local Date    WDTFNPER
Local Integer WINDPER

  #-------------------------
  #-- Sortie & Sortie rétroactive
  #-------------------------
  # Evaluation du booleen "Bien à sortir"
  If ( [F:WFAS]ISSDAT <> [0/0/0] and
&      ( ( [F:WFAS]EXTISSFLG <> G_OUI ) or
&        ( [F:WFAS]EXTISSFLG =  G_OUI and [M:DIV]TRTDEM = "CALSIM" )  )  ) Then
    # Le bien a une date de sortie renseignée
    # Il s'agit d'une sortie réelle ou d'une sortie prévisionnelle dans le cadre d'une simulation
    Call ECR_FICH("FS1", 10, "Détection d'une SORTIE ") From =G_GLOB0
    [M:DIV]BSOR = 1
  Else
    [M:DIV]BSOR = 0
  Endif


  #- 1 -----------------------------------------------------------------------
  If ( [M:DIV]BSOR and [F:WFAS]ISSDAT < [M:FIY]DATSTRPER ([M:DIV]FPC-1) and [F:WFAS]ISSDAT >= [M:FIY]DATSTRFIY ([M:DIV]FEC-1)) Then

    #-- Sortie rétroactive
    [M:DIV]BSRA = 1
    # Retraitement BSRA
    If ( [M:DIV]BACTCCN and [M:DIV]CCNFLG = G_OUI ) Then
      If( [M:DIV]CCNMOD = GVML_GCRNW ) Then
        If ([F:DEPC]DPRPLN <> [M:DIV]CCNCADPLN and [F:DEPC]DPM = G_DPMRA and [F:WFAS]CCNETRTYP = GVML_GCFIR) Then
          [M:DIV]BSRA = 0
          [M:DIV]DSR  = 0
        Endif
      Else
        If ([F:DEPC]DPRPLN = [M:DIV]CCNCADPLN and ([F:DEPC]DPM = G_DPMRA or [F:DEPC]DPM = G_DPMCA) and [F:WFAS]CCNETRTYP = GVML_GCFIR) Then
          [M:DIV]BSRA = 0
          [M:DIV]DSR  = 0
        Endif
      Endif
    Endif

    #- 2 -----------------------------------------------------------------------
    If ( [M:DIV]BSRA ) Then
      Call ECR_FICH("FS1", 10, "RETROACTIVE ") From =G_GLOB0
      #-- Indice dans [M:DEP] de la période de sortie
      Call CAL_PERIODE_SELON_DATE ( [F:WFAS]ISSDAT, WDTDBPER, WDTFNPER, WINDPER ) From =G_GLOB8
      [M:DIV]DSR = find( WDTDBPER, [M:DEP]PERSTRDAT )
      #-- [F:DEPC] période de sortie
      nolign = [M:DIV]DSR  : [F:DEPC] = [M:DEP]
      #-- Dotation exercice au jour de sortie
      [M:DIV]LVLLIB = "2.CALCUL_EXERCICE" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call CALCUL_EXERCICE  From =G_GLOB2
      If ( [M:DIV]ERROR) Then : End : Endif

      #-- Résultat du calcul dans [F:DEPS]
      [F:DEPS] = [F:DEPC]
      #-- [F:DEPC] période courante
      nolign = [M:DIV]DL : [F:DEPC] = [M:DEP]
      #-- Récupération Dotations Exercice calculés
      [F:DEPC]ENDDPE   = [F:DEPS]ENDDPE
      [F:DEPC]EXCDPR   = [F:DEPS]EXCDPR
      [F:DEPC]ENDDPEI  = [F:DEPS]ENDDPEI
      [F:DEPC]EXCDPRI  = [F:DEPS]EXCDPRI
      [F:DEPC]ENDDPET  = [F:DEPS]ENDDPET
      [F:DEPC]EXCDPRT  = [F:DEPS]EXCDPRT
      # Issue X3-65300 - 2017-11-29 by BEFOU : Wrong calculation of the vehicle reintegration amount in case of a disposal prior to the current period
      [F:DEPC]CRBCUM   = [F:DEPS]CRBCUM
      [F:DEPC]CRBAMT   = [F:DEPS]CRBAMT

      #-- Dotation période au jour de sortie
      [M:DIV]DEBCLCPER = 1
      [M:DIV]LVLLIB = "2.CALCUL_PERIODE" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call CALCUL_PERIODE  From =G_GLOB2
      If ( [M:DIV]ERROR) Then : End : Endif

      nolign = [M:DIV]DL : [M:DEP] = [F:DEPC]
      # Arrêt calcul à vrai
      [M:DIV]BSTPCLC = 1
    Endif
    #- 2 -----------------------------------------------------------------------
  Else
    [M:DIV]DSR  = 0
    [M:DIV]BSRA = 0
  Endif
  #- 1 -----------------------------------------------------------------------


  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

Return




#
#
#*****************************************************************************************************
#*****************************************************************************************************
#*****************************************************************************************************
#    C O N C E S S I O N S      -     P R O V I S I O N S     R E N O U V E L L E M E N T
#*****************************************************************************************************
#*****************************************************************************************************
#*****************************************************************************************************
#
# FQ54343

#########################################################
Subprog  CALCUL_PROVISION_EXERCICE
#
# - Objet  :
#
#
# - Entrée : Cette fonction évalue le champ cumul E-1
#
#
# - Sortie : [F:DEPn]
#
#   Boite noire
#
#
  [F:RPRC]EXEACGRPR = 0
  [F:RPRC]EXEFISRPR = 0

  #-1 ------------------------------
  If !([M:DIV]BSTPCLC) Then

    # Calcul de la dotation de l'exercice
    Call PROVISION_EXERCICE  From =G_GLOB3
    If ([M:DIV]ERROR) Then : End : Endif

  Endif
  #-1 ------------------------------


End


#########################################################
Subprog  CALCUL_PROVISION_PERIODE
#
# - Objet  :
#
#
# - Entrée : Cette fonction calcule la provision de la période#
#
# - Sortie : [F:RPRn]
#
#   Boite noire
#

  #If ( [M:DIV]BDEBUG and [F:DEPC]PERENDDAT=[31/01/2010]) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If (  [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  #-1 ------------------------------
  If !([M:DIV]BSTPCLC) Then

    #-2 -------------------------------
    If ( [M:DIV]DEBCLCPER ) Then

      [M:DIV]DEBCLCPER = 0
      #--

      #-----------------------
      # Traitement de début
      #-----------------------

      #--------------------------------
      If ( [F:DEPC]PERREFCLC <> [F:DEPC]FIYSTRDAT  ) Then
        # En prospectif, il ne faut pas tenir compte du cumul P-1 déjà constaté
        # La dotation période est égale à Dotation [Déb Pér.,Fin Per Cour.]
        [M:DIV]PERDATREF  = [F:DEPC]PERSTRDAT
        [M:DIV]P_1ACGRPR  = 0
        [M:DIV]P_1FISRPR  = 0
        [M:DIV]P_1RVERPR  = 0
        [M:DIV]P_1SUPCAD  = 0
      Else
        # Par défaut, la dotation période est égale à  Dotation [Déb Ex.,Fin Per Cour.] - Cumul P-1
        [M:DIV]PERDATREF  = [F:DEPC]FIYSTRDAT
        [M:DIV]P_1ACGRPR  = [F:RPRC]P_1ACGRPR
        [M:DIV]P_1FISRPR  = [F:RPRC]P_1FISRPR
        [M:DIV]P_1RVERPR  = [F:RPRC]P_1RVERPR
        [M:DIV]P_1SUPCAD  = [F:RPRC]P_1SUPCAD
      Endif

      # Evaluation Montant à repartir sur les périodes non closes de l'exercice
      # En prospectif le montant à repartir sur les périodes non closes
      # correspond à la dotation exercice diminuée du cumul P-1 déjà constaté
      If ( [F:DEPC]PERREFCLC <> [F:DEPC]FIYSTRDAT  ) Then
          [M:DIV]ACGRPRAREP  = [F:RPRC]EXEACGRPR - [F:RPRC]P_1ACGRPR
          [M:DIV]FISRPRAREP  = [F:RPRC]EXEFISRPR - [F:RPRC]P_1FISRPR
          [M:DIV]RVERPRAREP  = [F:RPRC]EXERVERPR - [F:RPRC]P_1RVERPR
          [M:DIV]SUPCADAREP  = [F:RPRC]EXESUPCAD - [F:RPRC]P_1SUPCAD
      Endif

    Endif
    #-2 -------------------------------

    # ========================
    Call PROVISION_PERIODE  From =G_GLOB3
    # ========================

    # Pas de provision s'il n'y a pas d'obligation effective de renouvellement
    # S'il existe des cumuls E-1 & P-1 ils sont à reprendre dans la période courante
    If ( [F:WFAS]RNWFLG <> G_OUI ) Then
      [F:RPRC]PERACGRPR = [M:DIV]EXEACGRPR - [M:DIV]P_1ACGRPR
      [F:RPRC]PERFISRPR = [M:DIV]EXEFISRPR - [M:DIV]P_1FISRPR
    Endif

    # actualisation Cumul P-1
    [M:DIV]P_1ACGRPR += [F:RPRC]PERACGRPR
    [M:DIV]P_1FISRPR += [F:RPRC]PERFISRPR
    [M:DIV]P_1RVERPR += [F:RPRC]PERRVERPR
    [M:DIV]P_1SUPCAD += [F:RPRC]PERSUPCAD


  Endif
  #-1 -------------------------------

  #=================
  # A comptabiliser
  #=================
  # Les champs PST "comptabilisé" sont actualisés par la génération des écritures comptables
  If ( [F:WFAS]OWNTYP = GVML_TDPREVU ) Then
    # Un bien en prévision ne peut pas avoir de "A comptabiliser"
    [F:RPRC]ACGRPRDEV = 0
    [F:RPRC]FISRPRDEV = 0
  Else
    # Selon type de comptabilisation
    If ( [M:DIV]CCNRPRTYP = GVML_CPCPT ) Then
      # Comptable
      [F:RPRC]FISRPRDEV = 0
      [F:RPRC]ACGRPRDEV = [F:RPRC]PERACGRPR - [F:RPRC]PSTACGRPR
    Else
      # Fiscale
      [F:RPRC]FISRPRDEV = [F:RPRC]PERFISRPR - [F:RPRC]PSTFISRPR
      [F:RPRC]ACGRPRDEV = 0
    Endif
  Endif

End


#########################################################
Subprog INIT_RPRS_AVANT_CLOTURE
#
# - Objet  : Alimentation du buffer DEPS avant clôture
#
#            DEPS est initialisé avec l'enreg. [M:DEP] suivant
#            L'enreg. [M:DEP] suivant est lui-même au préalable créé
#            et alimenté à partir de DEPC.
#

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif


  # Sauvegarde des rubriques "Comptabilisé"
  If ( [M:DIV]DL < [M:DIV]NBRPRSV ) Then
    [F:RPRS]PSTACGRPR    = [M:RPR]PSTACGRPR   ([M:DIV]DL)
    [F:RPRS]PSTFISRPR    = [M:RPR]PSTFISRPR   ([M:DIV]DL)
    [F:RPRS]FCY          = [M:RPR]FCY         ([M:DIV]DL)
  Endif

  # Ligne suivante dans [M:DEP]
  # Création ligne [M:DEP] à partir de [F:DEPC])
  nolign = [M:DIV]DL + 1 : [M:RPR] = [F:RPRC]
  # ---------------------------------
  If ( [M:DIV]DL = [M:RPR]NB_RPR ) Then
    # Ajustement nombre de ligne dans [M:RPR]
    [M:RPR]NB_RPR = [M:DIV]DL + 1
    [M:RPR]PSTACGRPR  ([M:DIV]DL) = 0
    [M:RPR]PSTFISRPR  ([M:DIV]DL) = 0
   Endif
  # ---------------------------------

  # Restauration des rubriques "Comptabilisé"
  If ( [M:DIV]DL < [M:DIV]NBRPRSV ) Then
    [M:RPR]PSTACGRPR  ([M:DIV]DL) = [F:RPRS]PSTACGRPR
    [M:RPR]PSTFISRPR  ([M:DIV]DL) = [F:RPRS]PSTFISRPR
    [M:RPR]FCY        ([M:DIV]DL) = [F:RPRS]FCY
  Endif

  # Initialisation [F:RPRS]
  nolign = [M:DIV]DL + 1 : [F:RPRS] = [M:RPR]
  # Synchronisation dates DEP selon FIY
  Call CCN_DATES_PRV ("S", [F:RPRC]FIYENDDAT, [F:RPRC]PERENDDAT, "[F:RPRS]" ) From =G_GLOB2
  If ([M:DIV]ERROR) Then : End : Endif

End
#
#########################################################
Subprog  CCN_DATES_PRV (PTYP, PDATEXE, PDATPER, PABR )
#
# - Objet  : Calcule des dates de DEP
#            (Début & Fin exercice) (Début & Fin période)
#            pour l'enregistrement courant ou pour le suivant
#
#        Pour des soucis de performances (Assign gourmand)
#        PABR ne peut prendre que les valeurs [F:DEPC] [F:DEPS]
#        Si une nouvelle abréviation doit être utilisée il faut adapter ce sous-programme
#
#   Rem. Les dates exercices / périodes ont pu être remises en cause
#        dans les limites des possibilités de la transaction dédiée.
#        Le calcul se doit de resynchroniser DEP avec ces nouvelles
#        dates. Dans ce cas, s'il s'agit de la période courante les
#        informations hors synchronisation sont conservées. S'il s'agit
#        d'une période ultérieure, elle hérite des informations hors
#        synchronisation de la période précédente.
#
# - Entrée :
#
#        Type "C" enreg. courant  [F:DEPC], "S" enreg. précédent [F:DEPC][F:DEPS]
#        Début exercice ( PTYP = "C") de l'enreg. courant ou Fin exercice de l'enreg. précédent ( PTYP = "S")
#        Début période  ( PTYP = "C") de l'enreg. courant ou Fin période  de l'enreg. précédent ( PTYP = "S")
#        Date de début ou de fin période  de l'enregistrement précédent
#        Abréviation du fichier type DEPREC
#
# - Sortie : [F:DEPn]
#
#   Boite noire
#
Value     Char     PTYP
Value     Date     PDATEXE, PDATPER
Value     Char     PABR

Local     Date     WDTDB
Local     Date     WDTDBEXE, WDTFNEXE
Local     Date     WDTDBPER, WDTFNPER
Local     Integer  WINDEXE


  #- 1 ------------------------------------------------
  If ( PTYP = "C" ) Then
    # Enreg. courant
    If ( PDATPER <> [0/0/0] ) Then
      WDTDB = PDATPER
    Else
      WDTDB = PDATEXE
    Endif
  #- 1 ------------------------------------------------
  Else
    # Nouvel enregistement
    If ( PDATPER <> [0/0/0] ) Then
      WDTDB  = func GLOBB9.CAL_DAT_PLUS( PDATPER , 1, "D" )
    Else
      WDTDB  = func GLOBB9.CAL_DAT_PLUS( PDATEXE , 1, "D" )
    Endif
  Endif
  #- 1 ------------------------------------------------

  # Début/Fin exercice
  #Call CAL_EXERCICE_SELON_DATE  ( WDTDB , GVML_TPJOUR, WDTDBEXE, WDTFNEXE, WINDEXE ) From GLOBB8
  [M:DIV]PD(0)= WDTDB : [M:DIV]PV(0)= GVML_TPJOUR
  Gosub GSB_CAL_EXERCICE_SELON_DATE From GLOBB8
  WDTDBEXE = [M:DIV]RD(1) : WDTFNEXE = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
  If ([M:DIV]ERROR) Then : End : Endif


  # L'exercice est forcemment découpé en (1 ou plusieurs) période(s) =>  Début/Fin Période  selon découpage
  WDTDBPER  = [M:FIY]DATSTRPER(find(WDTDB,[M:FIY]DATSTRPER)-1)
  WDTFNPER  = [M:FIY]DATENDPER(find(WDTDB,[M:FIY]DATSTRPER)-1)

  # Affectation des dates
  Case PABR
    When "[F:RPRC]"
      [F:RPRC]FIYSTRDAT = WDTDBEXE
      [F:RPRC]FIYENDDAT = WDTFNEXE
      [F:RPRC]PERSTRDAT = WDTDBPER
      [F:RPRC]PERENDDAT = WDTFNPER
  When "[F:RPRS]"
      [F:RPRS]FIYSTRDAT = WDTDBEXE
      [F:RPRS]FIYENDDAT = WDTFNEXE
      [F:RPRS]PERSTRDAT = WDTDBPER
      [F:RPRS]PERENDDAT = WDTFNPER
  Endcase

End


#########################################################
Subprog  CCN_CLOTURE_EXERCICE
#
# - Objet  :
#
#
# - Entrée :
#
#
# - Sortie :
#
#


  # Clôture exercice [F:RPRC] -> [F:RPRS]

  If !([M:DIV]BCLOPER) Then
    # Initialisation [F:RPRS] avant clôture ( sauf si la clôture période l'a déjà fait)
    Call INIT_RPRS_AVANT_CLOTURE From =G_GLOB2
    If ([M:DIV]ERROR) Then : End : Endif
  Endif

  # Clôture exercice [F:RPRC] -> [F:RPRS]
  Gosub CCN_CLORE_EXERCICE_RPR From =G_GLOB6

  # Mise à jour [M:DEP]
  nolign = [M:DIV]DL + 1 :  [M:RPR] = [F:RPRS]

  # Incrémentation du pointeur RPR
  [M:DIV]DL  += 1

  # Initialisation [F:RPRC]
  nolign = [M:DIV]DL     :  [F:RPRC] = [M:RPR]
  # Initialisation [F:DEPC]
  nolign = [M:DIV]DL     :  [F:DEPC] = [M:DEP]

End


#########################################################
Subprog  CCN_CLOTURE_PERIODE
#
# - Objet  :
#
#
# - Entrée :
#
#
# - Sortie : [F:RPRn]
#
#   Boite noire
#


# Clôture période [F:RPRC] -> [F:RPRS]

  # Initialisation [F:RPRS] avant clôture
  Call INIT_RPRS_AVANT_CLOTURE From =G_GLOB2
  If ([M:DIV]ERROR) Then : End : Endif

  # Clôture période [F:DEPC] -> [F:DEPS]
  Gosub CCN_CLORE_PERIODE_RPR From =G_GLOB6

  # Mise à jour [M:RPR]
  nolign = [M:DIV]DL + 1 :  [M:RPR] = [F:RPRS]

  # Pas d'incrémentation du pointeur RPR sur la dernière période d'un exercice
  # c'est la clôture exercice qui s'en charge
  If ( [F:RPRC]PERENDDAT <> [F:RPRC]FIYENDDAT ) Then
    # Incrémentation du pointeur DEP après clôture période
    [M:DIV]DL  += 1
    # Initialisation [F:RPRC]
    nolign = [M:DIV]DL   :  [F:RPRC] = [M:RPR]
  Endif

  # Clôture périodique effectuée = Vrai
  [M:DIV]BCLOPER = 1


End

#
#########################################################
Subprog CCN_ARRETER_ALIM_RPR(RTRN)
# - Objet  : Renvoie 1 si il ne faut plus alimenter le masque [M:RPR].
#
# - Entrée :
#
# - Sortie : 0 continuer 1 arrêter
#
#

Variable Integer RTRN

Local Integer IP

  RTRN = 0

  #-1 -------------------------------- FQ63340
  If (  [F:WFAS]ISSDAT    <> [0/0/0] and
&       [F:WFAS]EXTISSFLG <> G_OUI   and
&       ( [F:WFAS]CCNETRTYP <> GVML_NA1ERBC or [F:WFAS]ISSTYP = GVML_TSFCONC ) ) Then

    IP = func GLOBB9.CAL_LOCALISE_DAT ([F:WFAS]ISSDAT, [M:FIY]DATSTRFIY, [M:FIY]DATENDFIY, 0, [M:FIY]NB_EXE-1)
    If (IP >= 0 ) Then
      # Arrêt du calcul des provisions
      # après avoir calculé la dernière période de l'exercice suivant l'exercice de sortie du bien
      If (  [F:WFAS]ISSDAT    <= [M:FIY]DATENDFIY(IP+1) and
&           [F:RPRC]PERENDDAT  = [M:FIY]DATENDFIY(IP+1)      ) Then
#&          [F:DEPC]PERENDDAT  = [M:FIY]DATENDFIY(IP+1)      ) Then   : FQ65600
        RTRN = 1
      Endif
    Endif
  Endif
  #-1 --------------------------------

End

#
#########################################################
Subprog CCN_ARRETER_CALCUL(RTRN)
# - Objet  : Renvoie 1 si le calcul doit être interrompu.
#            Cela ne veut pas dire que l'on arrête
#            l'alimentation de CCNRPR.
#
# - Entrée :
#
# - Sortie : 0 continuer 1 arrêter
#
#
Variable Decimal RTRN


  RTRN = 0
  # Arrêt de la provision si ....
  If ( 1 = 0  )  Then
    RTRN = 1
  Endif

End



#
#########################################################
$CCN_SORTIE_RETROACTIVE
#
# - Objet  :
#
# - Entrée :
#
# - Sortie :
#
#

Local Date    WDTDBPER
Local Date    WDTFNPER
Local Integer WINDPER

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  #-------------------------
  #-- Sortie & Sortie rétroactive
  #-------------------------
  # Evaluation du booleen "Bien à sortir"
  If ( [F:WFAS]ISSDAT <> [0/0/0] and
&      ( ( [F:WFAS]EXTISSFLG <> G_OUI ) or
&        ( [F:WFAS]EXTISSFLG =  G_OUI and [M:DIV]TRTDEM = "CALSIM" )  )  ) Then
    # Le bien a une date de sortie renseignée
    # Il s'agit d'une sortie réelle ou d'une sortie prévisionnelle dans le cadre d'une simulation
    Call ECR_FICH("FS1", 10, "Détection d'une SORTIE ") From =G_GLOB0
    [M:DIV]BSOR = 1
  Else
    [M:DIV]BSOR = 0
  Endif
  #- 1 -----------------------------------------------------------------------
  If ( [M:DIV]BSOR and [F:WFAS]ISSDAT < [M:FIY]DATSTRPER ([M:DIV]FPC-1)  and [F:WFAS]ISSDAT >= [M:FIY]DATSTRFIY ([M:DIV]FEC-1) ) Then

    Call ECR_FICH("FS1", 10, "RETROACTIVE ") From =G_GLOB0
    #-- Sortie rétroactive
    [M:DIV]BSRA = 1
    #-- Indice dans [M:DEP] de la période de sortie
    Call CAL_PERIODE_SELON_DATE ( [F:WFAS]ISSDAT, WDTDBPER, WDTFNPER, WINDPER ) From =G_GLOB8
    [M:DIV]DSR = find( WDTDBPER, [M:DEP]PERSTRDAT )
    #-- [F:DEPC] période de sortie
    nolign = [M:DIV]DSR  : [F:DEPC] = [M:DEP]
    #-- [F:RPRC] période courante
    nolign = [M:DIV]DSR  : [F:RPRC] = [M:RPR]
    #-- Dotation exercice au jour de sortie
    [M:DIV]LVLLIB = "2.CALCUL_PROVISION_EXERCICE" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call CALCUL_PROVISION_EXERCICE  From =G_GLOB2
    If ( [M:DIV]ERROR) Then : End : Endif

    #-- Résultat du calcul dans [F:DEPS]
    [F:RPRS] = [F:RPRC]
    #-- [F:DEPC] période courante
    nolign = [M:DIV]DL : [F:DEPC] = [M:DEP]
    #-- [F:RPRC] période courante
    nolign = [M:DIV]DL : [F:RPRC] = [M:RPR]
    #-- Récupération Dotations Exercice calculés
    [F:RPRC]EXEACGRPR = [F:RPRS]EXEACGRPR
    [F:RPRC]EXEFISRPR = [F:RPRS]EXEFISRPR
    [F:RPRC]EXERVERPR = [F:RPRS]EXERVERPR
    [F:RPRC]EXESUPCAD = [F:RPRS]EXESUPCAD

    #-- Dotation période au jour de sortie
    [M:DIV]DEBCLCPER = 1
    [M:DIV]LVLLIB = "2.CALCUL_PROVISION_PERIODE" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call CALCUL_PROVISION_PERIODE  From =G_GLOB2
    If ( [M:DIV]ERROR) Then : End : Endif

    nolign = [M:DIV]DL : [M:DEP] = [F:DEPC]
    nolign = [M:DIV]DL : [M:RPR] = [F:RPRC]
    # Arrêt calcul à vrai
    [M:DIV]BSTPCLC = 1
  Else
    [M:DIV]DSR  = 0
    [M:DIV]BSRA = 0
  Endif
  #- 1 -----------------------------------------------------------------------


  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

Return


