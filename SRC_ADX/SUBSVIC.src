######################################################################################
#------------------------------------------------------------------------------------------------------
# Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
$HYBRID_REVERT_TO_SNAPSHOT
Local Integer  WRET

  #--In order to handle abandonned modifications (on GESINVCND, when a line is abandoned - exp : using Escape)
  If GSVCRINVCND<>null and GSVCRINVCND.snapshot<>null
    WRET = GSVCRINVCND.revertToSnapshot
    If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
      # Error management
      WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSVCRINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
      If WRET>=[V]CST_AERROR
        GERR=1
      Else
        GERR=2
      Endif
    Endif
    If GERR=1 :Return : Endif
  Endif

Return
#------------------------------------------------------------------------------------------------------
# Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
$HYBRID_SET_SNAPSHOT
Local Integer WRET

  #--In order to handle abandonned modifications (on GESSIH, when a line is abandoned - exp : using Escape)
  If GSVCRINVCND<>null
    If GSVCRINVCND.snapshot<>null
      WRET = GSVCRINVCND.freeSnapshot
      If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
        # Error management
        WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSVCRINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
        If WRET>=[V]CST_AERROR
          GERR=1
        Else
          GERR=2
        Endif
      Endif
      If GERR=1 : Return : Endif
    Endif
    If GSVCRINVCND.snapshotEnabled = 0
      GSVCRINVCND.snapshotEnabled = 1 #--snapshot enabeling if not done yet
    Endif
  Endif

Return
# End issue X3-38457
