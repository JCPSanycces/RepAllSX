      SetInstance GSVCRINVCND.VCRINVCNDLIN(ILINE) With [F:SVICD]
      GSVCRINVCND.VCRINVCNDLIN(ILINE).IS_PROP_CHG = [V]CST_ANO
      # Complete for non matching fields and translatable fields
      Gosub SET_CLS_LINE_WITH_M_SVIC1
      If GERR = 1 Then
        End
      Endif
    Endif
  Endif

  GSVCRINVCND.VCRINVCNDLIN(ILINE).INVCNDQTY = [M:SVIC1]INVCNDQTY(nolign-1)

#  #--The upper line code triggers the propagate, hence the following code :
#  Gosub SET_M_SVIC1_WITH_CLS_LINE
