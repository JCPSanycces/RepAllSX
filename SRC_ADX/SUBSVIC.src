Subprog C_PERTO(VALEUR)
Variable Date    VALEUR

  If [M:SVIC1]PERFROM(nolign-1)<>[0/0/0] and VALEUR<[M:SVIC1]PERFROM(nolign-1)
    GMESSAGE = mess(217,10702,1)
    mkstat = 2
  Endif

End
######################################################################################
Subprog AVANT_NBLIG

Local Integer ILINE,MY_STATUS,SAVE_NOLIGN,LAST_LIG,WOK,WRECALC_PERCENTAGE,WSIGMA,WRET,WILINE
Local Date    DELETED_PERFROM, DELETED_PERTO
Local Decimal WTMPPRC
Local Integer NOL : NOL = nolign-1 # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification

  DELETED_PERFROM = [0/0/0]
  DELETED_PERTO   = [0/0/0]

  # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
  #--Let's do a snapshot before modifications
  If  find(status,73, 75, 82)>0
    Gosub HYBRID_SET_SNAPSHOT : If GERR=1 : End : Endif
  Endif
  # End issue X3-38457

  If    status=73 | status = 82

    #--Triggering actions for the line instance also
    #--Si insertion ligne : init du pourcentage restant
    [M:SVIC1]INVPERCENT(nolign-1)=max(0,100-sum([M:SVIC1]INVPERCENT(0..[M:SVIC1]NBLIG-1)))
    #----------------------------------------------------------------------------
    # Retrieve the element using the screen's AUUID
    ILINE=0
    If [M:SVIC1]AUUID(nolign-1)<>""
      #--We have to consider the ASTALIN
      ILINE = sigma(1,maxtab(GSVCRINVCND.VCRINVCNDLIN),
&         (indcum)*(GSVCRINVCND.VCRINVCNDLIN(indcum)<>null and find(GSVCRINVCND.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and
&                   toUuid([M:SVIC1]AUUID(nolign-1))=GSVCRINVCND.VCRINVCNDLIN(indcum).AUUID))
#&                &( WSIGMA=0 and sigma(WSIGMA=1,1,1)))
    Endif
    If (ILINE = 0)
      # We did not find the element matching with the array line.
      # We add a line.
      ILINE = fmet GSVCRINVCND.ADDLINE("VCRINVCNDLIN", [V]CST_ALASTPOS)
      If (ILINE = [V]CST_ANOTDEFINED)
        # Error management
        GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
        MY_STATUS = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
        GERR = 1
        End
      Endif
    Endif

    #--This will trigger the propagate and hence the code into the class
    GSVCRINVCND.VCRINVCNDLIN(ILINE).INVPERCENT = [M:SVIC1]INVPERCENT(nolign-1)

    #--The upper line code triggers the propagate, hence the following code :
    #--It'll load the mask with the line instance properties modified by the propagate done previously
#    Gosub SET_M_SVIC1_WITH_CLS_LINE
#    If GERR = 1 : End : Endif
    #--The upper line code triggers the propagate, hence the following code :
    SAVE_NOLIGN = nolign
    WILINE=ILINE
    Gosub SET_M_SVIC1_WITH_CLS_LINE
    nolign = SAVE_NOLIGN
    If GERR = 1 : End : Endif

    # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
    #--Done in $APRES_LIGNE and $APRES_MODIF
    #--Updating the footer totals
    #[M:SVIC1]TOTINVCNDPRC += [M:SVIC1]INVPERCENT(nolign-1)
    #[M:SVIC1]TOTINVCNDQTY += [M:SVIC1]INVCNDQTY (nolign-1)
    #If [M:SVIC1]PRITYP=2
    #  [M:SVIC1]TOTINVCNDAMT += [M:SVIC1]INVCNDAMTATI(nolign-1)
    #Else
    #  [M:SVIC1]TOTINVCNDAMT += [M:SVIC1]INVCNDAMTNOT(nolign-1)
    #Endif
    #--
    # End issue X3-38457

    Affzo [M:SVIC1]1-99
    #----------------------------------------------------------------------------
  Elsif status=65
    #--No deletion if invoiced status other then "To be invoiced"
    If [M:SVIC1]INVCNDSTA(nolign-1)>1
      GMESSAGE = func AFNC.MES1(mess(470,192,1),mess(1,2419,1))
      mkstat=2 : GERR=1
      End
    Endif

    #--Si suppression ligne : répartition du delta sur la dernière ligne saisie, ayant le statut "Non facturé"
    #--ou sur l'avant dernière si suppression de la dernière ligne
    WRECALC_PERCENTAGE = [V]CST_ANO
    If [M]NBLIG>1 #--At list 2 lines
      LAST_LIG=-1
      For ILINE = [M:SVIC1]NBLIG-1 To 0 Step -1
        If [M:SVIC1]INVCNDSTA(ILINE)<=1 and ILINE<>nolign-1
          LAST_LIG = ILINE : Break
        Endif
      Next ILINE
      If LAST_LIG>=0
        WOK=1
        #--Case of a change of the header quantity (done on the original doc line)
        If sum([M:SVIC1]INVCNDQTY(0..[M:SVIC1]NBLIG-1))-[M:SVIC1]INVCNDQTY(nolign-1)=[M:SVIC1]QTY
          #--a recalculation of the percentages is needed
          WRECALC_PERCENTAGE = [V]CST_AYES
        Endif
        Call OUINON(mess(480,192,1),WOK) From GESECRAN
        If WOK=2
          #[M:SVIC1]INVPERCENT(LAST_LIG)+=[M:SVIC1]INVPERCENT(nolign-1)
          WTMPPRC = [M:SVIC1]INVPERCENT(LAST_LIG)+[M:SVIC1]INVPERCENT(nolign-1)
          SAVE_NOLIGN=nolign : nolign = LAST_LIG+1
          Call AM_INVPERCENT(WTMPPRC)
          nolign=SAVE_NOLIGN
          Affzo [M:SVIC1]INVPERCENT(LAST_LIG)
        Endif

        If WRECALC_PERCENTAGE = [V]CST_AYES
          For ILINE = 0 To LAST_LIG
            If [M:SVIC1]QTY<>0
              #[M:SVIC1]INVPERCENT(ILINE) = arr([M:SVIC1]INVCNDQTY(ILINE)*100/[M:SVIC1]QTY,0.01)
              WTMPPRC = arr([M:SVIC1]INVCNDQTY(ILINE)*100/[M:SVIC1]QTY,0.01)
            Else
              #TODO CPO Amount driven scheduling invoice

            Endif
            SAVE_NOLIGN=nolign : nolign = ILINE+1
            Call AM_INVPERCENT(WTMPPRC)
            nolign=SAVE_NOLIGN
          Next
          Affzo [M:SVIC1]NBLIG
        Endif

      Endif
    Else
      #--Updating the footer totals
      #[M:SVIC1]TOTINVCNDPRC -= [M:SVIC1]INVPERCENT(nolign-1)
      #[M:SVIC1]TOTINVCNDQTY -= [M:SVIC1]INVCNDQTY (nolign-1)
      #If [M:SVIC1]PRITYP=2
      #  [M:SVIC1]TOTINVCNDAMT -= [M:SVIC1]INVCNDAMTATI(nolign-1)
      #Else
      #  [M:SVIC1]TOTINVCNDAMT -= [M:SVIC1]INVCNDAMTNOT(nolign-1)
      #Endif
      #--
    Endif

    #----------------------------------------------------------------------------
    # Retrieve the element using the screen's AUUID
    # 1st) Eventually deleting the old line from the collection
    ILINE=0
    If [M:SVIC1]AUUID(nolign-1)<>""
      #--We have to consider the ASTALIN
      ILINE = sigma(1,maxtab(GSVCRINVCND.VCRINVCNDLIN),
&      (indcum)*(GSVCRINVCND.VCRINVCNDLIN(indcum)<>null and find(GSVCRINVCND.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and
&                toUuid([M:SVIC1]AUUID(nolign-1))=GSVCRINVCND.VCRINVCNDLIN(indcum).AUUID))
#&                &( WSIGMA=0 and sigma(WSIGMA=1,1,1)))
    Endif
    If (ILINE <> 0)
     #If (find(GSVCRINVCND.VCRINVCNDLIN(ILINE).ASTALIN, [V]CST_ANEW, [V]CST_AUPD))=0
     #If find(GSVCRINVCND.VCRINVCNDLIN(ILINE).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL)=0
        DELETED_PERFROM = GSVCRINVCND.VCRINVCNDLIN(ILINE).PERFROM
        DELETED_PERTO   = GSVCRINVCND.VCRINVCNDLIN(ILINE).PERTO
        If (fmet GSVCRINVCND.ADELLINE("VCRINVCNDLIN", GSVCRINVCND.VCRINVCNDLIN(ILINE).AORDER) <> [V]CST_AOK)
          # Error management
          GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
          MY_STATUS = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
          mkstat=2 : GERR = 1
          End
        Endif
     #Endif
    Endif

    # 2nd) Updating properties for the NBLIG-1 line
    #--Does this Mask line exist into the collection ?
    # Retrieve the element using the screen's AUUID
    If LAST_LIG>0 and WOK=2

      # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
      #--Done in $APRES_LIGNE and $APRES_MODIF
      #--Updating the footer totals
      #[M:SVIC1]TOTINVCNDPRC -= [M:SVIC1]INVPERCENT(LAST_LIG)
      #[M:SVIC1]TOTINVCNDQTY -= [M:SVIC1]INVCNDQTY (LAST_LIG)
      #If [M:SVIC1]PRITYP=2
      #  [M:SVIC1]TOTINVCNDAMT -= [M:SVIC1]INVCNDAMTATI(LAST_LIG)
      #Else
      #  [M:SVIC1]TOTINVCNDAMT -= [M:SVIC1]INVCNDAMTNOT(LAST_LIG)
      #Endif
      #--
      # End issue X3-38457

      ILINE=0
      If [M:SVIC1]AUUID(LAST_LIG)<>""
        #--We have to consider the ASTALIN
        ILINE = sigma(1,maxtab(GSVCRINVCND.VCRINVCNDLIN),
&           (indcum)*(GSVCRINVCND.VCRINVCNDLIN(indcum)<>null and find(GSVCRINVCND.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and
&                   toUuid([M:SVIC1]AUUID(LAST_LIG))=GSVCRINVCND.VCRINVCNDLIN(indcum).AUUID))
#&                &( WSIGMA=0 and sigma(WSIGMA=1,1,1)))
      Endif
      If (ILINE = 0)
        # We did not find the element matching with the array line.
        # We add a line.
        ILINE = fmet GSVCRINVCND.ADDLINE("VCRINVCNDLIN", [V]CST_ALASTPOS)
        If (ILINE = [V]CST_ANOTDEFINED)
          # Error management
          GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
          MY_STATUS = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
          mkstat=2 : GERR = 1
          End
        Endif
      Endif
      #--Updating properties...done by the propagate
      GSVCRINVCND.VCRINVCNDLIN(ILINE).INVPERCENT = [M:SVIC1]INVPERCENT(LAST_LIG)

      MY_STATUS = fmet GSVCRINVCND.DISPATCH_ON_LASTLINE()
      If (MY_STATUS > [V]CST_AOK)
        # Error management
        GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
        WRET      = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
        If MY_STATUS>=[V]CST_AERROR
          mkstat=2 : GERR = 1
          End
        Endif
      Endif

      #--The upper line code triggers the propagate, hence the following code :
      SAVE_NOLIGN=nolign : nolign = LAST_LIG+1

#      #--The upper line code triggers the propagate, hence the following code :
#      #--It'll load the mask with the line instance properties modified by the propagate done previously
#      Gosub SET_M_SVIC1_WITH_CLS_LINE
      #--The upper line code triggers the propagate, hence the following code :
      WILINE=ILINE
      Gosub SET_M_SVIC1_WITH_CLS_LINE
      nolign = SAVE_NOLIGN
      If GERR = 1 : mkstat=2 : End : Endif

      # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
      #--Done in $APRES_LIGNE and $APRES_MODIF
      #--Updating the footer totals
      #[M:SVIC1]TOTINVCNDPRC += [M:SVIC1]INVPERCENT(LAST_LIG)
      #[M:SVIC1]TOTINVCNDQTY += [M:SVIC1]INVCNDQTY (LAST_LIG)
      #If [M:SVIC1]PRITYP=2
      #  [M:SVIC1]TOTINVCNDAMT += [M:SVIC1]INVCNDAMTATI(LAST_LIG)
      #Else
      #  [M:SVIC1]TOTINVCNDAMT += [M:SVIC1]INVCNDAMTNOT(LAST_LIG)
      #Endif
      #--
      # End issue X3-38457

    Else
      #--Updating the footer totals
      #[M:SVIC1]TOTINVCNDPRC -= [M:SVIC1]INVPERCENT(nolign-1)
      #[M:SVIC1]TOTINVCNDQTY -= [M:SVIC1]INVCNDQTY (nolign-1)
      #If [M:SVIC1]PRITYP=2
      #  [M:SVIC1]TOTINVCNDAMT -= [M:SVIC1]INVCNDAMTATI(nolign-1)
      #Else
      #  [M:SVIC1]TOTINVCNDAMT -= [M:SVIC1]INVCNDAMTNOT(nolign-1)
      #Endif
      #--
    Endif

    If GERR = 1 : mkstat=2 : End : Endif

    # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
    #--Done in $APRES_LIGNE and $APRES_MODIF
    #--Updating the footer totals
    #[M:SVIC1]TOTINVCNDPRC -= [M:SVIC1]INVPERCENT(nolign-1)
    #[M:SVIC1]TOTINVCNDQTY -= [M:SVIC1]INVCNDQTY (nolign-1)
    #If [M:SVIC1]PRITYP=2
    #  [M:SVIC1]TOTINVCNDAMT -= [M:SVIC1]INVCNDAMTATI(nolign-1)
    #Else
    #  [M:SVIC1]TOTINVCNDAMT -= [M:SVIC1]INVCNDAMTNOT(nolign-1)
    #Endif
    #--
    # End issue X3-38457

    Affzo [M:SVIC1]1-99
  Endif

End
######################################################################################
## Etiquette ajoutée par le superviseur (écran SVIC1) 01/09/2016 15:23:20 (CPO)
######################################################################################
Subprog APRES_NBLIG
# Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
Local Integer  NOL : NOL=nolign-1

  #--in case of abandonned modification (esc, select of another browser list while still beeing on the line etc.)
  If adxgtb=1 | find(status,6,7)
     Gosub HYBRID_REVERT_TO_SNAPSHOT
     End
  Elsif find(status,71, 75)
     Gosub HYBRID_SET_SNAPSHOT
     If GERR=1 : End : Endif
  Endif

  Gosub UPD_TOTAL_SUM_LINES
  #--As [M]NBLIG isn't incremented yet, in case of last line, we add the amounts
  If NOL>([M:SVIC1]NBLIG-1)
    Gosub UPD_TOTAL_PLUS_CURR_LINE
  Endif

End
######################################################################################
$UPD_TOTALS

  # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
  #--Moved at the end, associated with a new label
  #--Updating the footer totals
  #[M:SVIC1]TOTINVCNDPRC = sum([M:SVIC1]INVPERCENT(0..[M:SVIC1]NBLIG-1))
  #[M:SVIC1]TOTINVCNDQTY = sum([M:SVIC1]INVCNDQTY (0..[M:SVIC1]NBLIG-1))
  #If [M:SVIC1]PRITYP=2
  #  [M:SVIC1]TOTINVCNDAMT = sum([M:SVIC1]INVCNDAMTATI(0..[M:SVIC1]NBLIG-1))
  #Else
  #  [M:SVIC1]TOTINVCNDAMT = sum([M:SVIC1]INVCNDAMTNOT(0..[M:SVIC1]NBLIG-1))
  #Endif
  ##--

  Local Integer WWRET, WWMY_STATUS, WWVCRINVCNDLIN : WWVCRINVCNDLIN=0 #--0 will send back all lines different totals

  Local Decimal VINV_QTY_P
  Local Decimal VINV_QTY_NP
  Local Decimal VCN_QTY_P
  Local Decimal VCN_QTY_NP
  Local Decimal VEXTINV_QTY_P
  Local Decimal VEXTINV_QTY_NP
  Local Decimal VEXTCN_QTY_P
  Local Decimal VEXTCN_QTY_NP
  #--
  Local Decimal VINV_AMT_P
  Local Decimal VINV_AMT_NP
  Local Decimal VCN_AMT_P
  Local Decimal VCN_AMT_NP
  Local Decimal VEXTINV_AMT_P
  Local Decimal VEXTINV_AMT_NP
  Local Decimal VEXTCN_AMT_P
  Local Decimal VEXTCN_AMT_NP

  WWMY_STATUS = fmet GSVCRINVCND.GET_INVOICED_VALUES(WWVCRINVCNDLIN,VINV_QTY_P,VINV_QTY_NP,VCN_QTY_P,VCN_QTY_NP,VEXTINV_QTY_P,VEXTINV_QTY_NP,VEXTCN_QTY_P,VEXTCN_QTY_NP,VINV_AMT_P,VINV_AMT_NP,VCN_AMT_P
& ,VCN_AMT_NP,VEXTINV_AMT_P,VEXTINV_AMT_NP,VEXTCN_AMT_P,VEXTCN_AMT_NP)
  If (WWMY_STATUS > [V]CST_AOK)
    # Error management
    GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
    WWRET      = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
    If MY_STATUS>=[V]CST_AERROR
      GERR = 1
      Return
    Endif
  Endif

  [M:SVIC1]TOT_INV_QTY = VINV_QTY_P+VINV_QTY_NP
  [M:SVIC1]TOTINVQTYP  = VINV_QTY_P
  [M:SVIC1]TOTINVQTYNP = VINV_QTY_NP
  [M:SVIC1]TOT_INV_AMT = VINV_AMT_P+VINV_AMT_NP
  [M:SVIC1]TOTINVAMTP  = VINV_AMT_P
  [M:SVIC1]TOTINVAMTNP = VINV_AMT_NP
  [M:SVIC1]TOT_EXT_QTY = VEXTINV_QTY_P+VEXTINV_QTY_NP
  [M:SVIC1]TOTEXTQTYP  = VEXTINV_QTY_P
  [M:SVIC1]TOTEXTQTYNP = VEXTINV_QTY_NP
  [M:SVIC1]TOT_EXT_AMT = VEXTINV_AMT_P+VEXTINV_AMT_NP
  [M:SVIC1]TOTEXTAMTP  = VEXTINV_AMT_P
  [M:SVIC1]TOTEXTAMTNP = VEXTINV_AMT_NP
  [M:SVIC1]TOT_CN_QTY  = VCN_QTY_P+VCN_QTY_NP
  [M:SVIC1]TOTCNQTYP   = VCN_QTY_P
  [M:SVIC1]TOTCNQTYNP  = VCN_QTY_NP
  [M:SVIC1]TOT_CN_AMT  = VCN_AMT_P+VCN_AMT_NP
  [M:SVIC1]TOTCNAMTP   = VCN_AMT_P
  [M:SVIC1]TOTCNAMTNP  = VCN_AMT_NP

$UPD_TOTAL_SUM_LINES
  # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
  #--Moved at the end, associated with a new label
  #--Updating the footer totals
  [M:SVIC1]TOTINVCNDPRC = sum([M:SVIC1]INVPERCENT(0..[M:SVIC1]NBLIG-1))
  [M:SVIC1]TOTINVCNDQTY = sum([M:SVIC1]INVCNDQTY (0..[M:SVIC1]NBLIG-1))
  If [M:SVIC1]PRITYP=2
    [M:SVIC1]TOTINVCNDAMT = sum([M:SVIC1]INVCNDAMTATI(0..[M:SVIC1]NBLIG-1))
  Else
    [M:SVIC1]TOTINVCNDAMT = sum([M:SVIC1]INVCNDAMTNOT(0..[M:SVIC1]NBLIG-1))
  Endif
  #--

  Affzo [M:SVIC1]1-99
Return
######################################################################################
# Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
$UPD_TOTAL_MINUS_CURR_LINE

  #--Updating the footer totals
  [M:SVIC1]TOTINVCNDPRC -= [M:SVIC1]INVPERCENT(NOL)
  [M:SVIC1]TOTINVCNDQTY -= [M:SVIC1]INVCNDQTY (NOL)
  If [M:SVIC1]PRITYP=2
    [M:SVIC1]TOTINVCNDAMT -= [M:SVIC1]INVCNDAMTATI(NOL)
  Else
    [M:SVIC1]TOTINVCNDAMT -= [M:SVIC1]INVCNDAMTNOT(NOL)
  Endif
  #--
  Affzo [M:SVIC1]1-99

Return
######################################################################################
# Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
$UPD_TOTAL_PLUS_CURR_LINE

  #--Updating the footer totals (adding the new value wich was substracted)
  [M:SVIC1]TOTINVCNDPRC += [M:SVIC1]INVPERCENT(NOL)
  [M:SVIC1]TOTINVCNDQTY += [M:SVIC1]INVCNDQTY (NOL)
  If [M:SVIC1]PRITYP=2
    [M:SVIC1]TOTINVCNDAMT += [M:SVIC1]INVCNDAMTATI(NOL)
  Else
    [M:SVIC1]TOTINVCNDAMT += [M:SVIC1]INVCNDAMTNOT(NOL)
  Endif
  #--
  Affzo [M:SVIC1]1-99

Return
######################################################################################
$AB1_VCRNUMORI
Local Integer WSAVE_GCONSULT :

  If GFONCTION<>"GESSVIC" : WSAVE_GCONSULT = GCONSULT: GCONSULT=1 Endif

Return
######################################################################################
$BB1_VCRNUMORI

  If GFONCTION<>"GESSVIC" and dim(WSAVE_GCONSULT)>0 : GCONSULT=WSAVE_GCONSULT Endif

Return
