#######################################################################################
# 107888 : Scheduled invoices : X3-7222 (LD:01/12/16)
#**
#* Label CHANGE_SCHEDULING_DATE Is used recalculate scheduling invoices lines's starting periode/ending period and next invoice date
#* It calls C_SVCRINVCND class's methods CHANGE_SCHEDULING_DATE
#* It returns GOK=0 and GERR = 1 if an error occurs
#* @param [M:SVIC1]VCRINVCNDDAT wich is the new invoice scheduling date to start from
#* @param GSVCRINVCND an instance  of C_SVCRINVCND class
#* @param [M:SVIC1] used to fill the instance (so it have to be "online")
#*!
$CHANGE_SCHEDULING_DATE
Local Integer WRET

  Gosub SET_CLS_WITH_M
  If (GERR = 1) : GOK=0 : Return : Endif

  MY_STATUS = fmet GSVCRINVCND.CHANGE_SCHEDULING_DATE([M:SVIC1]VCRINVCNDDAT)
  If ([L]MY_STATUS > [V]CST_AOK)
    # Error management
    GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
    WRET      = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
    If ([L]MY_STATUS >= [V]CST_AERROR)
      GOK = 0 : GERR = 1
      Return
    Endif
  Endif
  Gosub LIENS_WITHOUT_FREEGROUP_AND_AREAD
  Affzo [M:SVIC1]1-99

Return
######################################################################################
#**
#* INIT_FROM_DOCORI is used to load the properties from an original document line
#* it calls a fonction from SVCRINVCND script according to the VCRTYP property
#* (exp. for orders it calls func LIBSAL_INVCND_SOH.INIT_SVCRINVCND_FROM_ORDER_F)
#* @param [M:SVIC1]VCRTYP    the original document type
#* @param [M:SVIC1]VCRNUMORI the original document's number
#* @param [M:SVIC1]VCRLINORI the original document's line number
#* @param [M:SVIC1]VCRSEQORI the original document's line sequence (if any)
#*!
$INIT_FROM_DOCORI
Local Integer WRET
  #--
  If (GSVCRINVCND <> null) : FreeGroup GSVCRINVCND : GSVCRINVCND=null : Endif
  GSVCRINVCND = NewInstance C_SVCRINVCND AllocGroup null

  Case [M:SVIC1]VCRTYP
    When 10 : #--Sales orders
      MY_STATUS = func LIBSAL_INVCND_SOH.INIT_SVCRINVCND_FROM_ORDER_F([M:SVIC1]VCRNUMORI,[M:SVIC1]VCRLINORI,[M:SVIC1]VCRSEQORI,GSVCRINVCND)
      If ([L]MY_STATUS > [V]CST_AOK)
        # Error management
        GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
        WRET      = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
        If ([L]MY_STATUS >= [V]CST_AERROR)
          GOK = 0 : GERR = 1
          Return
        Endif
      Endif
    When Default
  Endcase

  Gosub LIENS_WITHOUT_FREEGROUP_AND_AREAD
  Affzo [M:SVIC1]1-99

Return
######################################################################################
#**
#* Label AUTO_GENERATE_INVOICE_SCHEDULE is used to create the scheduling invoice's lines for the original header document and according to the invoice condition
#* It calls C_SVCRINVCND class's methods AINIT and CREATE_DETAIL_SCHEDINV
#* Warning : if the scheduling invoice already has lines, those will be deleted
#* It returns GOK = 0 and GERR = 1 if an error occurs
#* @param GSVCRINVCND An instance  of C_SVCRINVCND class
#* @param [M:SVIC1] Used to fill the instance (so it have to be "online")
#*!
$AUTO_GENERATE_INVOICE_SCHEDULE
Local Integer WRET

  #--If there was a previous error on while "Creation", lines keep adding to the class !
  If maxtab(GSVCRINVCND.VCRINVCNDLIN)>0
    FreeGroup GSVCRINVCND : GSVCRINVCND = null
    GSVCRINVCND = NewInstance C_SVCRINVCND AllocGroup null
    [L]MY_STATUS = fmet GSVCRINVCND.AINIT()
    If ([L]MY_STATUS > [V]CST_AOK)
      # Error management
      GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
      WRET      = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
      If ([L]MY_STATUS >= [V]CST_AERROR)
        GOK = 0 : GERR = 1
        Return
      Endif
    Endif
  Endif

  Gosub AUTO_GENERATE_INVOICE_SCHEDULE_WITHOUT_FREEGROUP

Return
######################################################################################
$AUTO_GENERATE_INVOICE_SCHEDULE_WITHOUT_FREEGROUP
Local Integer MY_STATUS,I,ILINE,WRET,WILINE

  Raz [F:SVIC] : [F:SVIC] = [M:SVIC1]
  #--Header properties
  SetInstance GSVCRINVCND With [F:SVIC]
  Gosub SET_CLS_WITH_M_SVIC1
  If GERR=1
    GOK=0
    Return
  Endif

  #--Create lines into the collection
  For I = 0 To [M:SVIC1]NBLIG-1
    # We add a line.
    ILINE = fmet GSVCRINVCND.ADDLINE("VCRINVCNDLIN", [V]CST_ALASTPOS)
    If (ILINE = [V]CST_ANOTDEFINED)
      # Error management
      GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
      MY_STATUS = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
      GOK = 0 : GERR = 1
      Break
    Endif

    nolign = I + 1
    # Need to use [F] because it's not possible to set a class from [M]
    #--First, there are some inportant properties set in ADDLINE_AFTER method
    #--As they are not set in classic X3 after addind a line, it's important to copy them to [M]
    [M:SVIC1]VCRINVCNDLIN(nolign-1) = GSVCRINVCND.VCRINVCNDLIN(ILINE).VCRINVCNDLIN

    Raz [F:SVICD]
    [F:SVICD] = [M:SVIC1]
    # Use the SetInstance
    SetInstance GSVCRINVCND.VCRINVCNDLIN(ILINE) With [F:SVIC]
    SetInstance GSVCRINVCND.VCRINVCNDLIN(ILINE) With [F:SVICD]
    # Complete for non matching fields and translatable fields
    WILINE = ILINE
    Gosub SET_CLS_LINE_WITH_M_SVIC1
    If GERR = 1 Then
      GOK=0
      Break
    Endif
  Next

  If (GERR = 1) : Return : Endif

  Gosub AUTO_GENERATE_INVOICE_SCHEDULE_WITHOUT_FREEGROUP_WITHOUT_SET_CLS
  If GOK = 0 or GERR = 1 : Return : Endif

Return
######################################################################################
$AUTO_GENERATE_INVOICE_SCHEDULE_WITHOUT_FREEGROUP_WITHOUT_SET_CLS
Local Integer WRET

  MY_STATUS = fmet GSVCRINVCND.CREATE_DETAIL_SCHEDINV()
  If ([L]MY_STATUS > [V]CST_AOK)
    # Error management
    GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
    WRET      = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
    If ([L]MY_STATUS >= [V]CST_AERROR)
      GOK = 0 : GERR = 1
      Return
    Endif
  Endif
  Gosub LIENS_WITHOUT_FREEGROUP_AND_AREAD
  Affzo [M:SVIC1]1-99

Return
######################################################################################
Subprog AM_VCRLINORI(VALEUR)
Variable Decimal VALEUR
  [M:SVIC1]VCRSEQORI = VALEUR
End
######################################################################################
Subprog AS_VCRSEQORI(VALEUR)
Variable Decimal VALEUR
  If [M:SVIC1]VCRSEQORI=0 : [M:SVIC1]VCRSEQORI = [M:SVIC1]VCRLINORI : Endif
End
######################################################################################
Subprog AS_INVCNDTYP(VALEUR)
Variable Integer VALEUR
  GMENLOC(1) = 1
End
######################################################################################
Subprog IB_VCRNUMORI

  #-- On gère différents objets

  #-- VCRABR sera utilisée pour l'action de tunnel
  Case [M:SVIC1]VCRTYP
    When 10      : [M:SVIC1]VCRABR="SOH" :# Commande normale
                   [V]GBOUT1=mess(10,159,1)
    When Default : Raz [V]GBOUT1
  Endcase
  If [M:SVIC1]VCRABR="" Raz [V]GBOUT1 Endif

  #--No tunneling if not the GESSVIC fonction
  #If GFONCTION<>"GESSVIC" : Raz [V]GBOUT1 Endif ---> set GCONSULT to 1

End
######################################################################################
Subprog C_VCRTYP(VALEUR)
Variable Integer VALEUR

  #-- VCRABR sera utilisée pour l'action de tunnel
  Case VALEUR
    When 10      : [M:SVIC1]VCRABR="SOH" :# Commande normale
    When Default : mkstat = 2
  Endcase

End
######################################################################################
Subprog AS_VCRTYP(VALEUR)
Variable Integer VALEUR

  Local Integer IJK
  #--- Désactivation des entrées suivantes du type de document  :
  For IJK = 1 To 23
    If IJK<>10
      GMENLOC(IJK) = 1
    Endif
  Next

End
######################################################################################
Subprog AM_INVCND(VALEUR)
Variable Char    VALEUR()

Local File TABINVCND [INVCND]
Local Integer WRET

  #--Should call the SET accessor from class ?
  [M:SVIC1]LEG       = ""
  [M:SVIC1]INVCNDTYP = 0
  Call LEC_INVCND_LEG([M:SVIC1]CURLEG,VALEUR,WRET) From TRTLECLEG
  If WRET=0
    [M:SVIC1]LEG       = [F:INVCND]LEG
    [M:SVIC1]INVCNDTYP = [F:INVCND]INVCNDTYP
  Else
    GERR = 1
    mkstat = 2
    GMESSAGE = func AFNC.MES1(mess(453,192,1), VALEUR+[M:SVIC1]CURLEG)
  Endif
End
######################################################################################
Subprog AS_INVCND(VALEUR)
Variable Char    VALEUR()

  Local Integer IJK

  If ([M:SVIC1]NBLIG>0) or find(GREP,"C","D")=0
    Diszo [M:SVIC1]INVCND
  Endif
End
######################################################################################
Subprog AV_PERFROM(VALEUR)
Variable Date    VALEUR
  If [M:SVIC1]INVCNDSTA(nolign-1)>1
    Diszo [M:SVIC1]PERFROM(nolign-1)
  Else
    Actzo [M:SVIC1]PERFROM(nolign-1)
 Endif
End
######################################################################################
Subprog AV_PERTO(VALEUR)
Variable Date    VALEUR
