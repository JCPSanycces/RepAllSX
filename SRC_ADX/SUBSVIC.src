  Else
    Actzo [M:SVIC1]PERTO(nolign-1)
 Endif
End
######################################################################################
Subprog AV_NEXINVDAT(VALEUR)
Variable Date    VALEUR
  If [M:SVIC1]INVCNDSTA(nolign-1)>1
