Subprog AM_DINVCNDAMT(VALEUR)
Variable Decimal VALEUR


  Local Integer ILINE,MY_STATUS,SAVE_NOLIGN,LAST_LIG,WOK,WSIGMA,WILINE

  #--First, retrieving the actual amounts
  #--Updating the footer totals
  [M:SVIC1]TOTINVCNDPRC -= [M:SVIC1]INVPERCENT(nolign-1)
  [M:SVIC1]TOTINVCNDQTY -= [M:SVIC1]INVCNDQTY (nolign-1)
  [M:SVIC1]TOTINVCNDAMT -= [M:SVIC1]DINVCNDAMT(nolign-1)
  #--

  [M:SVIC1]DINVCNDAMT(nolign-1) = VALEUR
  # Retrieve the element using the screen's AUUID
  ILINE=0
  If [M:SVIC1]AUUID(nolign-1)<>""
    #--We have to consider the ASTALIN
    ILINE = sigma(1,maxtab(GSVCRINVCND.VCRINVCNDLIN),
&       (indcum)*(GSVCRINVCND.VCRINVCNDLIN(indcum)<>null and find(GSVCRINVCND.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and
&                 toUuid([M:SVIC1]AUUID(nolign-1))=GSVCRINVCND.VCRINVCNDLIN(indcum).AUUID))
#&                &( WSIGMA=0 and sigma(WSIGMA=1,1,1)))
  Endif
  If (ILINE = 0)
    # We did not find the element matching with the array line.
    # We add a line.
    ILINE = fmet GSVCRINVCND.ADDLINE("VCRINVCNDLIN", [V]CST_ALASTPOS)
    If (ILINE = [V]CST_ANOTDEFINED)
      # Error management
      GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
      MY_STATUS = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
      GERR = 1
      End
    Endif
  Endif

  #--In order not to loose modified properties not yet loaded into the line instance...
  SAVE_NOLIGN = nolign
  Raz [F:SVIC] : [F:SVIC] = [M:SVIC1]
  Gosub SET_CLS_WITH_M
  nolign = SAVE_NOLIGN
  If GERR = 1 : End : Endif

  #--For a newly inserted line, the NBLIG is not increased yet
  #--We need to manually set the ILINE instance with mask's values...
  If nolign>[M:SVIC1]NBLIG
    If [M:SVIC1]INVCNDSTA(nolign-1)<=1

      # Need to use [F] because it's not possible to set a class from [M]
      #--First, there are some inportant properties set in ADDLINE_AFTER method
      #--As they are not set in classic X3 after addind a line, it's important to copy them to [M]
      [M:SVIC1]VCRINVCNDLIN(nolign-1) = GSVCRINVCND.VCRINVCNDLIN(ILINE).VCRINVCNDLIN

      Raz [F:SVIC]  : [F:SVIC]  = [M:SVIC1]
      Raz [F:SVICD] : [F:SVICD] = [M:SVIC1]
      # Use the SetInstance
      GSVCRINVCND.VCRINVCNDLIN(ILINE).IS_PROP_CHG = [V]CST_AYES

      SetInstance GSVCRINVCND.VCRINVCNDLIN(ILINE) With [F:SVIC]
      SetInstance GSVCRINVCND.VCRINVCNDLIN(ILINE) With [F:SVICD]
      GSVCRINVCND.VCRINVCNDLIN(ILINE).IS_PROP_CHG = [V]CST_ANO
      # Complete for non matching fields and translatable fields
      Gosub SET_CLS_LINE_WITH_M_SVIC1
      If GERR = 1 Then
        End
      Endif
    Endif
  Endif

  WOK=1
#  Call OUINON(mess(479,192,1),WOK) From GESECRAN             #X3-25622
#  If WOK<2                                                   #X3-25622
#    GSVCRINVCND.VCRINVCNDLIN(ILINE).IS_PROP_CHG=[V]CST_AYES  #X3-25622
#  Endif                                                      #X3-25622
  If [M:SVIC1]PRITYP=2
    GSVCRINVCND.VCRINVCNDLIN(ILINE).INVCNDAMTATI = [M:SVIC1]DINVCNDAMT(nolign-1)
  Else
    GSVCRINVCND.VCRINVCNDLIN(ILINE).INVCNDAMTNOT = [M:SVIC1]DINVCNDAMT(nolign-1)
  Endif
  GSVCRINVCND.VCRINVCNDLIN(ILINE).IS_PROP_CHG=[V]CST_ANO

  #--The upper line code triggers the propagate, hence the following code :
  SAVE_NOLIGN = nolign
  WILINE=ILINE
  Gosub SET_M_SVIC1_WITH_CLS_LINE
  nolign = SAVE_NOLIGN
  If GERR = 1 : End : Endif

  #--Last, adding new amounts
  #--Updating the footer totals
  [M:SVIC1]TOTINVCNDPRC += [M:SVIC1]INVPERCENT(nolign-1)
  [M:SVIC1]TOTINVCNDQTY += [M:SVIC1]INVCNDQTY (nolign-1)
  [M:SVIC1]TOTINVCNDAMT += [M:SVIC1]DINVCNDAMT(nolign-1)
  If [M:SVIC1]PRITYP=2
    [M:SVIC1]INVCNDAMTATI(nolign-1) = [M:SVIC1]DINVCNDAMT(nolign-1)
  Else
    [M:SVIC1]INVCNDAMTNOT(nolign-1) = [M:SVIC1]DINVCNDAMT(nolign-1)
  Endif
  #--

  Affzo [M:SVIC1]1-99

End
######################################################################################
Subprog AV_VCRINVCNDDAT(VALEUR)
