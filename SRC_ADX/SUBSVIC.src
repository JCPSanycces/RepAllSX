#<AdxTL>@(#)0.0.0.0 $Revision$
End
######################################################################################
# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
$ACTION

  Case ACTION
    When "OUVRE"          : Gosub OUVRE
    When "FERME"          : Gosub FERME
    When "LIENS"          : Gosub LIENS
    #--Update
    When "MODIF"          : Gosub MODIF
    When "APRES_MOD"      : Gosub APRES_MOD
    #--Create
    When "RAZCRE"         : Gosub RAZCRE
    When "RAZDUP"         : Gosub RAZDUP
    When "CREATION"       : Gosub CREATION
    When "APRES_CRE"      : Gosub APRES_CRE
    #--Delete
    When "AV_ANNULE"      : Gosub AV_ANNULE
    When "ANNULE"         : Gosub ANNULE
    #--Others
    When "SETBOUT"        : Gosub SETBOUT
    When "EXEBOUT"        : Gosub EXEBOUT
    #--Browser list
    When "FILGAUCHE"      : Gosub FILGAUCHE
    #--Field menu entries
    When "AB1_VCRNUMORI"  : Gosub AB1_VCRNUMORI
    When "BB1_VCRNUMORI"  : Gosub BB1_VCRNUMORI
    When "APRES_MODIF"    : Gosub APRES_MODIF    # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
    #--Picking
    #When "OUVRE_BOITE"  : Gosub OUVRE_BOITE     From SUBSVICC
    #When "FILGAUCHE"    : Gosub FILGAUCHE       From SUBSVICC
    #When "REMP_DERLU"   : Gosub REMP_DERLU      From SUBSVICC
    #When "FILGAUCHE"    : Gosub FILGAUCHE       From SUBSVICC
    #When "AP_FILGAUCHE" : Gosub AP_FILGAUCHE    From SUBSVICC
    #When "HINT"         : Gosub HINT_KEY        From SUBSVICC
    #When "DEB_PICK"     : Gosub DEB_PICK        From SUBSVICC
    #When "PICKE"        : Gosub PICKE           From SUBSVICC
    #When "DEPICK"       : Gosub DEPICK          From SUBSVICC
    #When "FIN_PICK"     : Gosub FIN_PICK        From SUBSVICC
    When Default
  Endcase
Return
######################################################################################
$OUVRE
Local Integer WRET # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification

  #--Hybride mode ON
  ANOWRITE = 1
  If dim(GSVCRINVCND)>0
    If (GSVCRINVCND <> null) : FreeGroup GSVCRINVCND : Endif
    Kill GSVCRINVCND
  Endif
  Global Instance GSVCRINVCND Using C_SVCRINVCND
  #--

  # Issue X3-38457 - 2017-05-17 by CPO : SAM 120402 Invoicing terms modification
  GSVCRINVCND = NewInstance C_SVCRINVCND AllocGroup null
  #--Mandatory to call in order to have the context ACTX set before the first snapshot
  WRET = fmet GSVCRINVCND.AINIT()
  If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
    # Error management
    WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSVCRINVCND, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
    If WRET>=[V]CST_AERROR
      GERR=1
    Else
      GERR=2
    Endif
  Endif
  If GERR=1 : OK=0 : Return : Endif
  # End issue X3-38457

  #-----------------------------------#
  # Sauvegarde des variables globales #
  #-----------------------------------#
  Gosub SAUV_GLOB From TRTX3GLOB
  #--Lors d'un tunnel depuis un document (exemple : livraison)
  Raz GCURFCY  :#--Ici pas de contexte et on veut éviter le filtrage des groupes de sites
  Raz GSOCIETE :#--Ici pas de contexte et on veut éviter le filtrage des groupes de societes
Return
#-------------------------------------------------------------------------------------
$MODIF
  Local Integer MY_STATUS, I, ILINE,OLD_MAXTAB,WRET

  If dim(GSVCRINVCND)>0 and GSVCRINVCND<>null
    MY_STATUS = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
  Endif

  #-----------------------------
  Gosub SET_CLS_WITH_M
  If (GERR = 1) : GOK=0 : Return : Endif
  #-----------------------------

  [L]MY_STATUS = fmet GSVCRINVCND.AUPDATE()
  If ([L]MY_STATUS > [V]CST_AOK)
    # Error management
    GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
    WRET      = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
    If ([L]MY_STATUS >= [V]CST_AERROR)
      GOK = 0 : GERR = 1
      Return
    Endif
  Endif

  Gosub LIENS

Return
#-------------------------------------------------------------------------------------
#**
#* Label LIENS is used to Freegroup the GSVCRINVCND instance of C_SVCRINVCND class and load it with mask [M:SVIC1] properties
#*!
$LIENS
  Local Integer MY_STATUS, WILINE,SAV_NOLIGN

  #--Loading screen throught the class AREAD Method
  If (GSVCRINVCND <> null) : FreeGroup GSVCRINVCND : Endif
  GSVCRINVCND = NewInstance C_SVCRINVCND AllocGroup null

  Gosub LIENS_WITHOUT_FREEGROUP

Return
#-------------------------------------------------------------------------------------
#**
#* Label LIENS_WITHOUT_FREEGROUP is used to load the GSVCRINVCND instance throught the class C_SVCRINVCND AREAD event
#* After doing the AREAD, the current [M:SVIC1] mask is loaded with GSVCRINVCND instance's values
#* Warning : it does not Freegroup the GSVCRINVCND instance before reading it
#* It returns GERR = 1 if an error occurs
#*!
$LIENS_WITHOUT_FREEGROUP
Local Integer WRET

  [L]MY_STATUS = fmet GSVCRINVCND.AREAD([M:SVIC1]VCRTYP,[M:SVIC1]VCRNUMORI,[M:SVIC1]VCRLINORI,[M:SVIC1]VCRSEQORI)
  If ([L]MY_STATUS > [V]CST_AOK)
    # Error management
    GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
    WRET      = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
    If ([L]MY_STATUS >= [V]CST_AERROR)
      GERR = 1
      Return
    Endif
  Endif

  Gosub LIENS_WITHOUT_FREEGROUP_AND_AREAD

Return
#-------------------------------------------------------------------------------------
#**
#* Label LIENS_WITHOUT_FREEGROUP_AND_AREAD is used to load the current [M:SVIC1] mask from previously readed GSVCRINVCND instance
#* It returns GERR = 1 if an error occurs
#*!
$LIENS_WITHOUT_FREEGROUP_AND_AREAD
  #--Loading header properties into the screen, from the class
  Gosub SET_M_SVIC1_WITH_CLS
  If GERR = 1 Then
    Return
  Endif
  #--
  #--Once the class is loaded, we have to load the collection lines into the screen
  #--We could do it directly from looping on the F file, but we prefer loading from collection lines of the class
  nolign=0
  For WILINE=1 To maxtab(GSVCRINVCND.VCRINVCNDLIN)
    If GSVCRINVCND.VCRINVCNDLIN(WILINE)<>null and find(GSVCRINVCND.VCRINVCNDLIN(WILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      nolign += 1
      Gosub SET_M_SVIC1_WITH_CLS_LINE
      If GERR = 1 Then
        Break
      Endif
    Endif
  Next
  [M:SVIC1]NBLIG=nolign
  If GERR = 1 Then
    Return
  Endif

  Gosub UPD_TOTALS

Return
#-------------------------------------------------------------------------------------
$RAZCRE
  Local Integer MY_STATUS,WRET,WILINE

  #--Initializing screen throught the class AINIT Method
  If (GSVCRINVCND <> null) : FreeGroup GSVCRINVCND : Endif
  GSVCRINVCND = NewInstance C_SVCRINVCND AllocGroup null

  [L]MY_STATUS = fmet GSVCRINVCND.AINIT()
  If ([L]MY_STATUS > [V]CST_AOK)
    # Error management
    GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
    WRET      = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
    If ([L]MY_STATUS >= [V]CST_AERROR)
      GOK = 0 : GERR = 1
      Return
    Endif
  Endif
  #--
  #--Now, we have to load the properties into the screen INVCND1
  Gosub SET_M_SVIC1_WITH_CLS
  If GERR = 1 Then
    Return
  Endif
  Affzo [M:SVIC1]1-99
  #--
Return
#-------------------------------------------------------------------------------------
$RAZDUP

  # ----------------------------------------------------------
  #--Duplication is forbidden
  #--Hybride mode ON
  GMESSAGE = mess(1182,196,1)
  GOK = 0
  GERR = 1
  #--Hybride mode OFF
  # ----------------------------------------------------------

Return
#-------------------------------------------------------------------------------------
$SET_CLS_WITH_M
Local Integer WSIGMA,WIJSAVE_NOLIGN,WILINE

  WIJSAVE_NOLIGN = nolign

  If dim(WPREVENT_PROPAGATE_ON_LINES)<0
    Local Integer WPREVENT_PROPAGATE_ON_LINES
    WPREVENT_PROPAGATE_ON_LINES = [V]CST_AFALSE
  Endif

  #--Header properties
  #Raz [F:SVIC]
  #[F:SVIC] = [M:SVIC1]
  SetInstance GSVCRINVCND With [F:SVIC]
  Gosub SET_CLS_WITH_M_SVIC1
  If GERR = 1 Then
    Return
  Endif

  #--Lines properties
  For I = 0 To [M:SVIC1]NBLIG-1
    # Retrieve the element using the screen's AUUID
    WILINE=0
    If [M:SVIC1]AUUID(I)<>""
      #--We have to consider the ASTALIN
      WILINE = sigma(1,maxtab(GSVCRINVCND.VCRINVCNDLIN),
&      (indcum)*(GSVCRINVCND.VCRINVCNDLIN(indcum)<>null and find(GSVCRINVCND.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and
&                toUuid([M:SVIC1]AUUID(I))=GSVCRINVCND.VCRINVCNDLIN(indcum).AUUID))
#&                &( WSIGMA=0 and sigma(WSIGMA=1,1,1)))
    Endif
    If (WILINE = 0)
      # We did not find the element matching with the array line.
      # We add a line.
      WILINE = fmet GSVCRINVCND.ADDLINE("VCRINVCNDLIN", [V]CST_ALASTPOS)
      If (WILINE = [V]CST_ANOTDEFINED)
        # Error management
        GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
        MY_STATUS = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
        GERR = 1
        Break
      Endif
    Endif

    nolign = I + 1
    #--Only lines having invoiced status to "Not invoiced"
    If [M:SVIC1]INVCNDSTA(nolign-1)<=1

      # Need to use [F] because it's not possible to set a class from [M]
      #--First, there are some inportant properties set in ADDLINE_AFTER method
      #--As they are not set in classic X3 after addind a line, it's important to copy them to [M]
      [M:SVIC1]VCRINVCNDLIN(nolign-1) = GSVCRINVCND.VCRINVCNDLIN(WILINE).VCRINVCNDLIN

      #--CPO 29/08/2016 Taking advantage of the new possibility to set directly with [M:XXX]
      If 1=1
        Raz [F:SVICD]
        [F:SVICD] = [M:SVIC1]
        # Use the SetInstance
        If WPREVENT_PROPAGATE_ON_LINES = [V]CST_AYES
          GSVCRINVCND.VCRINVCNDLIN(WILINE).IS_PROP_CHG = [V]CST_AYES
        Endif
        SetInstance GSVCRINVCND.VCRINVCNDLIN(WILINE) With [F:SVIC]
        SetInstance GSVCRINVCND.VCRINVCNDLIN(WILINE) With [F:SVICD]
        GSVCRINVCND.VCRINVCNDLIN(WILINE).IS_PROP_CHG = [V]CST_ANO
      Else
        # Use the SetInstance
        If WPREVENT_PROPAGATE_ON_LINES = [V]CST_AYES
          GSVCRINVCND.VCRINVCNDLIN(WILINE).IS_PROP_CHG = [V]CST_AYES
        Endif
        #SetInstance GSVCRINVCND.VCRINVCNDLIN(WILINE) With [M:SVIC1]
        #SetInstance GSVCRINVCND.VCRINVCNDLIN(WILINE) With [M:SVIC1]20
        GSVCRINVCND.VCRINVCNDLIN(WILINE).IS_PROP_CHG = [V]CST_ANO
      Endif
      # Complete for non matching fields and translatable fields
      Gosub SET_CLS_LINE_WITH_M_SVIC1
      If GERR = 1 Then
        GOK=0
        Break
      Endif
    Endif

  Next

  nolign = WIJSAVE_NOLIGN
  If (GERR = 1) : Return : Endif

  # Now, all elements that don't have the status Updated or Created must be deleted, because it means they don't match with lines in the array
  For I = 1 To maxtab(GSVCRINVCND.VCRINVCNDLIN) #[V]CST_ANEW, [V]CST_ADEL,[V]CST_ANEWDEL))=0
    If GSVCRINVCND.VCRINVCNDLIN(I)<>null and (find(GSVCRINVCND.VCRINVCNDLIN(I).ASTALIN, [V]CST_ADEL,[V]CST_ANEWDEL))=0
&   and      num$(GSVCRINVCND.VCRINVCNDLIN(I).AUUID)<>""
&   and find(num$(GSVCRINVCND.VCRINVCNDLIN(I).AUUID),[M:SVIC1]AUUID(0..[M:SVIC1]NBLIG-1))=0
      If (fmet GSVCRINVCND.ADELLINE("VCRINVCNDLIN", GSVCRINVCND.VCRINVCNDLIN(I).AORDER) <> [V]CST_AOK)
        # Error management
        GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
        MY_STATUS = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
        GOK = 0 : GERR = 1
        Break
      Endif
    Endif
  Next

Return
#-------------------------------------------------------------------------------------
#--Header properties CLS => M:
$SET_M_SVIC1_WITH_CLS
  If GSVCRINVCND=null : GERR=1 : Return : Endif

  #--Copying properties from class into the screen
  #--CPO 29/08/2016 Taking advantage of the new possibility to set directly with [M:XXX]
  If 1=1
    SetInstance [F:SVIC] With GSVCRINVCND

    [M:SVIC1] = [F:SVIC]

    [M:SVIC1]QTY        = GSVCRINVCND.QTY
    [M:SVIC1]SAU_UOMDEC = GSVCRINVCND.SAU_UOMDEC
    [M:SVIC1]CUR_DECNBR = GSVCRINVCND.CUR_DECNBR
    [M:SVIC1]LINORISAU  = GSVCRINVCND.SAU
    [M:SVIC1]AMTNOT     = GSVCRINVCND.AMTNOT
    [M:SVIC1]AMTATI     = GSVCRINVCND.AMTATI
    [M:SVIC1]DOCDAT     = GSVCRINVCND.DOCDAT
  Else
    SetInstance [M:SVIC1] With GSVCRINVCND
  Endif

  If GSVCRINVCND.PRITYP = 2
    [M:SVIC1]AMTVCR     = GSVCRINVCND.AMTATI
    [M:SVIC1]NETPRIVCR  = GSVCRINVCND.NETPRIATI
  Else
    [M:SVIC1]AMTVCR     = GSVCRINVCND.AMTNOT
    [M:SVIC1]NETPRIVCR  = GSVCRINVCND.NETPRINOT
  Endif
#

# 107888 : Scheduled invoices : X3-7222 (LD:01/12/16)
#  [M:SVIC1]DESAXX     = GSVCRINVCND.DESAXX
#  [M:SVIC1]SHOAXX     = GSVCRINVCND.SHOAXX
# 107888 : Scheduled invoices : X3-7222 (LD:01/12/16)
#


Return
#-------------------------------------------------------------------------------------
#--Header properties M: => CLS
$SET_CLS_WITH_M_SVIC1
  Local Integer MY_STATUS

  If GSVCRINVCND=null : GERR= 1 : Return : Endif

  #--Copying properties from mask into the class
  GSVCRINVCND.QTY        = [M:SVIC1]QTY
  GSVCRINVCND.SAU_UOMDEC = [M:SVIC1]SAU_UOMDEC
  GSVCRINVCND.SAU        = [M:SVIC1]LINORISAU
  GSVCRINVCND.AMTNOT     = [M:SVIC1]AMTNOT
  GSVCRINVCND.CUR_DECNBR = [M:SVIC1]CUR_DECNBR
  GSVCRINVCND.AMTATI     = [M:SVIC1]AMTATI
  GSVCRINVCND.DOCDAT     = [M:SVIC1]DOCDAT

  If [M:SVIC1]PRITYP = 2
    GSVCRINVCND.AMTATI    = [M:SVIC1]AMTVCR
    GSVCRINVCND.NETPRIATI = [M:SVIC1]NETPRIVCR
  Else
    GSVCRINVCND.AMTNOT    = [M:SVIC1]AMTVCR
    GSVCRINVCND.NETPRINOT = [M:SVIC1]NETPRIVCR
  Endif

# 107888 : Scheduled invoices : X3-7222 (LD:01/12/16)
#  GSVCRINVCND.DESAXX     = [M:SVIC1]DESAXX
#  GSVCRINVCND.SHOAXX     = [M:SVIC1]SHOAXX
# 107888 : Scheduled invoices : X3-7222 (LD:01/12/16)

  GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
  MY_STATUS = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
  If GMESSAGE<>""
    GERR = 1
  Endif
Return
#-------------------------------------------------------------------------------------
#--Line properties CLS => M:
$SET_M_SVIC1_WITH_CLS_LINE

  If WILINE<1 or GSVCRINVCND.VCRINVCNDLIN(WILINE)=null : GERR=1 : Return : Endif

  #--Copying properties from class into the screen
  #--CPO 29/08/2016 Taking advantage of the new possibility to set directly with [M:XXX]
  If 1=1
    Raz [F:SVICD]
    SetInstance [F:SVICD] With GSVCRINVCND.VCRINVCNDLIN(WILINE)
    [M:SVIC1] = [F:SVICD]

    If GSVCRINVCND.PRITYP = 2
      [M:SVIC1]DINVCNDAMT(nolign-1) = GSVCRINVCND.VCRINVCNDLIN(WILINE).INVCNDAMTATI
      [M:SVIC1]DNETPRIVCR(nolign-1) = GSVCRINVCND.VCRINVCNDLIN(WILINE).DNETPRIATI
    Else
      [M:SVIC1]DINVCNDAMT(nolign-1) = GSVCRINVCND.VCRINVCNDLIN(WILINE).INVCNDAMTNOT
      [M:SVIC1]DNETPRIVCR(nolign-1) = GSVCRINVCND.VCRINVCNDLIN(WILINE).DNETPRINOT
    Endif
  Else
    #SetInstance [M:SVIC1]20 With GSVCRINVCND.VCRINVCNDLIN(WILINE)
    #If GSVCRINVCND.PRITYP = 2
    #  [M:SVIC1]DINVCNDAMT(nolign-1) = GSVCRINVCND.VCRINVCNDLIN(WILINE).INVCNDAMTATI
    #  [M:SVIC1]DNETPRIVCR(nolign-1) = GSVCRINVCND.VCRINVCNDLIN(WILINE).DNETPRIATI
    #Else
    #  [M:SVIC1]DINVCNDAMT(nolign-1) = GSVCRINVCND.VCRINVCNDLIN(WILINE).INVCNDAMTNOT
    #  [M:SVIC1]DNETPRIVCR(nolign-1) = GSVCRINVCND.VCRINVCNDLIN(WILINE).DNETPRINOT
    #Endif
  Endif

  [M:SVIC1]AUUID(nolign-1) = num$(GSVCRINVCND.VCRINVCNDLIN(WILINE).AUUID)

Return
#-------------------------------------------------------------------------------------
#--Header properties M: => CLS
$SET_CLS_LINE_WITH_M_SVIC1
  Local Integer MY_STATUS

  If WILINE<1 or GSVCRINVCND.VCRINVCNDLIN(WILINE)=null : GERR=1 : Return : Endif
  #--Copying properties from class into the screen

  If GSVCRINVCND.PRITYP = 2
    GSVCRINVCND.VCRINVCNDLIN(WILINE).INVCNDAMTATI = [M:SVIC1]DINVCNDAMT(nolign-1)
    GSVCRINVCND.VCRINVCNDLIN(WILINE).DNETPRIATI   = [M:SVIC1]DNETPRIVCR(nolign-1)
  Else
    GSVCRINVCND.VCRINVCNDLIN(WILINE).INVCNDAMTNOT = [M:SVIC1]DINVCNDAMT(nolign-1)
    GSVCRINVCND.VCRINVCNDLIN(WILINE).DNETPRINOT   = [M:SVIC1]DNETPRIVCR(nolign-1)
  Endif
  #--

Return
#-------------------------------------------------------------------------------------
$CREATION
  Local Integer MY_STATUS,I,ILINE,WRET

  #--If there was a previous error on while "Creation", lines keep adding to the class !
  #--also, we want to start from screen's properties
  If maxtab(GSVCRINVCND.VCRINVCNDLIN)>0
    FreeGroup GSVCRINVCND
    GSVCRINVCND = NewInstance C_SVCRINVCND AllocGroup null
    [L]MY_STATUS = fmet GSVCRINVCND.AINIT()
    If ([L]MY_STATUS > [V]CST_AOK)
      # Error management
      GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
      WRET      = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
      If ([L]MY_STATUS >= [V]CST_AERROR)
        GOK = 0 : GERR = 1
        Return
      Endif
    Endif
  Endif

  If dim(GSVCRINVCND)>0 and GSVCRINVCND<>null
    MY_STATUS = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
  Endif

  Gosub SET_CLS_WITH_M
  If (GERR = 1) : GOK=0 : Return : Endif

  Local Integer MY_STATUS
  [L]MY_STATUS = fmet GSVCRINVCND.AINSERT()
  If ([L]MY_STATUS > [V]CST_AOK)
    # Error management
    GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
    WRET      = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
    If ([L]MY_STATUS >= [V]CST_AERROR)
      GOK = 0 : GERR = 1
      Return
    Endif
  Endif

  Gosub LIENS

Return
#-------------------------------------------------------------------------------------
$APRES_CRE

  Gosub RELIT From GOBJSUB

Return
#-------------------------------------------------------------------------------------
$APRES_MOD

  Gosub RELIT From GOBJSUB

Return
#-------------------------------------------------------------------------------------
$AV_ANNULE
  #--It's called from a subprog so the ANOWRITE opened in $OUVRE is not known
  Local Integer ANOWRITE
  ANOWRITE = 1

Return
#-------------------------------------------------------------------------------------
$ANNULE
  Local Integer MY_STATUS,WRET

  [L]MY_STATUS = fmet GSVCRINVCND.ADELETE()
  If ([L]MY_STATUS > [V]CST_AOK)
    # Error management
    GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSVCRINVCND)
    WRET      = func SUBINVCND.RAZMAXMSG(GSVCRINVCND,"VCRINVCNDLIN")
    If ([L]MY_STATUS >= [V]CST_AERROR)
      GOK = 0 : GERR = 1
      Return
    Endif
  Endif
  #--Update the order line - invoicing condition set to ""
  Case [M:SVIC1]VCRTYP
    When 10 : #--Sales order
              Local File SORDER  [SOH]
              Local File SORDERP [SOP]
              Local File SORDERQ [SOQ]
              #--The SOH record is beeing lock if someone is modifying it throught GESSOH
              Readlock [SOH]SOH0=[M:SVIC1]VCRNUMORI
              If fstat>0 :
                GOK=0 : GERR=1
                Call FSTA("SOH") From GLOCK
                Return
              Endif
              Readlock [SOP]SOP0=[M:SVIC1]VCRNUMORI;[M:SVIC1]VCRLINORI;[M:SVIC1]VCRSEQORI
              If fstat>0 :
                GOK=0 : GERR=1
                Call FSTA("SOP") From GLOCK
                Return
              Endif
              Readlock [SOQ]SOQ0=[M:SVIC1]VCRNUMORI;[M:SVIC1]VCRLINORI;[M:SVIC1]VCRSEQORI
              If fstat>0 :
                GOK=0 : GERR=1
                Call FSTA("SOQ") From GLOCK
                Return
              Endif
              #--The order line does not have to be partially/fully invoiced or closed
              If [F:SOQ]SOQSTA=3 or [F:SOQ]INVFLG=2
                GMESSAGE = mess(495,192,1)
                GOK=0 : GERR=1
                Return
              Endif
              [F:SOP]INVCND=""
              Rewrite [SOP]
              If fstat>0 :
                GOK=0 : GERR=1
                Call FSTA("SOP") From GLOCK
                Return
              Endif
              GMESSAGE = mess(487,192,1)
              Unlock [SOH],[SOP],[SOQ]
  Endcase
Return
#-------------------------------------------------------------------------------------
$SETBOUT
Local Integer WTEMPSIGMA

  Call VIREBOUT(CHAINE,"D") From GOBJET #--Duplication forbidden

  If CLECUR <> 0 | find(GREP,"C","D")=0 :# au lieu de CLECUR1 = ""
    Call VIREBOUT(CHAINE,"1") From GOBJET
  Endif
  If GREP = "" Then
    # Note FGR : obligé de l'ajouter à la main. comme il y a plus de deux
    #            éléments dans la clé, le superviseur ne le mets pas tout seul
    CHAINE += "A"
#    # FGR 23/04/2013 : X3SUIVI71937 : obligé de le réactivé à la main parce que 3 éléments de PK
#    CHAINE += "H"
  Endif

  Call VIREBOUT(CHAINE,"1") From GOBJET
  If GREP="C" and [M:SVIC1]VCRNUMORI<>"" and [M:SVIC1]INVCND=""
    CHAINE += "1"
  Endif
#  If GREP="C" and [M:SVIC1]INVCND<>""
#    CHAINE += "2"
#  Endif

  #--No re-generation of the scheduling lines if at least one has a status different then 'To be invoiced'
  If [M:SVIC1]NBLIG>0
      #--Does the schedule invoice have ohter lines than 'To be invoiced' ?
      WTEMPSIGMA = -1
      WTEMPSIGMA = sigma(0,[M:SVIC1]NBLIG-1, [M:SVIC1]INVCNDSTA(indcum)>1)
      If WTEMPSIGMA>0
        Call VIREBOUT(CHAINE,"12") From GOBJET
      Endif
  Endif
  #--If comming from elsewhere, no creation and record navigation
  If GFONC1<>"" and GFONC1 <> "GESSVIC"
    Call VIREBOUT(CHAINE,"RCDH<>S0912") From GOBJET
  Endif

Return
#-------------------------------------------------------------------------------------
$EXEBOUT
  #-------------------------------------------#
  # After execution toolbar buttons           #
  #-------------------------------------------#
  Case BOUT
    When "1"  : Gosub INIT_FROM_DOCORI
                If GOK<1 or GERR>0 : Return : Endif
                Gosub AUTO_GENERATE_INVOICE_SCHEDULE
                If GOK<1 or GERR>0 : Return : Endif
    When "2"  : Gosub CHANGE_SCHEDULING_DATE
                If GOK<1 or GERR>0 : Return : Endif
  Endcase
Return
#-------------------------------------------------------------------------------------
$FERME
  #--Freeing/Killing the global instance used by hybride mode
  If (GSVCRINVCND <> null) : FreeGroup GSVCRINVCND : Endif
  Kill GSVCRINVCND

  #------------------------------------#
  # Restitution des variables globales #
  #------------------------------------#
  Gosub REST_GLOB From TRTX3GLOB

Return
#-------------------------------------------------------------------------------------
$FILGAUCHE

  #--No browser left list empty if comming from elsewhere
  If GFONC1<>"" and GFONC1<>"GESSVIC" and ILIS=0
    adxmxl=0
  Endif

Return
