  [M:SVIC1]TOTINVCNDQTY += [M:SVIC1]INVCNDQTY (nolign-1)
  If [M:SVIC1]PRITYP=2
    [M:SVIC1]TOTINVCNDAMT += [M:SVIC1]INVCNDAMTATI(nolign-1)
  Else
    [M:SVIC1]TOTINVCNDAMT += [M:SVIC1]INVCNDAMTNOT(nolign-1)
  Endif
  #--

  Affzo [M:SVIC1]1-99

End
