#<AdxTL>@(#)5.0.0.0 $Revision$
Call OBJET("POO",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "AVANT_OUVRE"           : Gosub AVANT_OUVRE
 When "OUVRE_BOITE"           : Gosub OUVRE_BOITE
 When "FILTRE"                : Gosub FILTRE
 When "GAUCHE"                : Gosub GAUCHE
 When "VERIF_CRE","VERIF_MOD" : Gosub VERIF
Endcase
Return


$AVANT_OUVRE
# Bug 5875 : Tunnel sur les pools bancaires (CP : 11/07/01)
If clalev([M:DIA])
 Local Char SVGCPY (GLONCPY), SVGFCY (GLONFCY)
 Raz SVGCPY, SVGFCY
 If dim([M:DIA]CPY)>0 : SVGCPY=[M:DIA]CPY : Endif 
 If dim([M:DIA]FCY)>0 : SVGFCY=[M:DIA]FCY : Endif
 Raz FILTRE
Endif
Return

$OUVRE_BOITE
Local Integer BROWBAN
Local Char    BOXBAN(10)
BROWBAN = find("BAN",OBJLIS(1..8)) : BOXBAN = "GAU_CHE"+num$(BROWBAN)
Return

$FILTRE
# Bug 5875 : Tunnel sur les pools bancaires (CP : 11/07/01)
If dim(SVGCPY)>0 
 If SVGCPY<>"" :  FILTRE  = "CPY='"+SVGCPY+"'" : Endif
 If SVGFCY<>"" :  FILTRE += " & (FCY='' | FCY='"+SVGFCY+"')" : Endif  
Endif
Return

$VERIF
If sum([M]PRC(0..[M]NBL-1))>100
 GMESSAGE = mess(14,117,1)-"> 100" : # Somme des pourcentages > 100
 OK=0
Elsif sum([M]PRC(0..[M]NBL-1))<100 : # Somme des pourcentages < 100
 OK=1 : Call AVERTIR(mess(14,117,1)-"< 100",OK) From GESECRAN
 If OK<>2 : OK=0 : Else OK=1 : Endif
Endif
Return

$GAUCHE
Case currbox
 When BOXBAN
  If [F:BAN]BAN<>"" & !find([F:BAN]BAN,[M]BAN(0..[M]NBL-1)) & [M]NBL<dim([M]BAN)
   OK = 0
   Case REP
    When "C","M","D"
     OK = 1
    When ""
     If CLECUR & VERROU & ACTMOD & !GCONSULT
      OK = 1
     Endif
   Endcase
   If OK
    mkstat = 0 : Call C_BAN([F:BAN]BAN)
    If !mkstat
     [M]BAN([M]NBL)   = [F:BAN]BAN
     [M]NBL += 1
     Affzo 20
     If REP=""
      Gosub ENTRE_MODIF From GOBJSUB
     Endif
    Endif
   Endif
  Endif
Endcase
Return


###############################
## Etiquette de l'écran POO0 ##
###############################
Subprog C_BAN(VALEUR)
Variable Char     VALEUR
Call UNICITE(VALEUR,[M]BAN(0..[M]NBL-1)) From OBJDIV
If mkstat : End : Endif
Read [F:BAN]BAN0=VALEUR
If fstat=0
 If [F:BAN]CPY<>[M]CPY
  # Compte en banque non détenu par la société"-[M]CPY
  GMESSAGE=mess(12,117,1)-[M]CPY
  mkstat = 2 : End
 Elsif ([M]FCY="" & [F:BAN]FCY<>"")
&    | ([M]FCY<>"" & [F:BAN]FCY<>"" & [F:BAN]FCY<>[M]FCY) 
  # Banque du site-[F:BAN]FCY
  GMESSAGE = mess(13,117,1)-[F:BAN]FCY
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If VALEUR="" & [M]CPY<>""
 Call CONTALLFCY([M]CPY) From CPTSUB
Endif
End

Subprog AM_FCY(VALEUR)
Variable Char     VALEUR
[M]CPY = ""
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
If [M]FCY<>""
 VALEUR = [F:FCY]LEGCPY
 mkstat = 2
Else
 Call CONTACCCFY(VALEUR,"") From CFYSUB : # Accès refusé si pas accès à tous les sites de la société
Endif
End

Subprog C_CPY(VALEUR)
Variable Char     VALEUR
Call CONTALLFCY(VALEUR) From CPTSUB
End


