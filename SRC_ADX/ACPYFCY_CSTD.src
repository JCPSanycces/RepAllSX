#<AdxTL>@(#)0.0.0.0 $Revision$
# Class ACPYFCY_CSTD

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD" : Gosub AREAD
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return



##########################################################################################################
# METHODS
##########################################################################################################

$AREAD
  Local Integer MY_STATUS
  Local Instance MY_FACILITY Using C_FACILITY
  MY_FACILITY = NewInstance C_FACILITY AllocGroup null
  [L]MY_STATUS = fmet MY_FACILITY.AREAD(this.FCY)
  If [L]MY_STATUS = [V]CST_AOK
    this.CPYFCYNAM = MY_FACILITY.FCYNAM
    # Site
    this.TYP       = mess(3,45,1)
  Else
    Local Instance MY_COMPANY Using C_COMPANY
    MY_COMPANY = NewInstance C_COMPANY AllocGroup null
    [L]MY_STATUS = fmet MY_COMPANY.AREAD(this.FCY)

    If [L]MY_STATUS = [V]CST_AOK
      this.CPYFCYNAM = MY_COMPANY.CPYNAM
      # Company
      this.TYP       = mess(2,45,1)
    Endif
    FreeGroup MY_COMPANY
  Endif
  FreeGroup MY_FACILITY

  If [L]MY_STATUS<>[V]CST_AOK
    [L]ASTATUS = fmet this.ASETERROR("AREAD",mess(61,133,1),[V]CST_AERROR)
  Endif

Return

