            If GFOLDER_V180 (0) <> "" 
                # ATEXTE de l'appli SUPERV180
                Local File =GFOLDER_V180(0)+".ATEXTE" [XYSV8]
                # gproduit = 0 : c'est x3
                # gproduit = 1 : c'est geode
                # gproduit = 3 : c'est abelx3
                # gproduit = 2 : c'est paye
                If GPRODUIT = 0
                    # ATEXTE de l appli X3IND170
                    Local File =GFOLDER_V170(1)+".ATEXTE" [XYZ]
