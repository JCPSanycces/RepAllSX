               When 0 :
                  [F:XXZ]       = [F:ATX2]
                  [F:XXZ]LAN    = WLAN_INDUS
                  [F:XXZ]NUMERO = WTAB_NUM (W_INDICE)
                  [F:XXZ]CLEREC = left$(vireblc(toupper(ctrans(WTEXT_INDUS)),4),20) 
                  [F:XXZ]TEXTE  = WTEXT_INDUS
                  [F:XXZ]COMMENT  = WCOMMENT_INDUS
                  Call FLDCRE("XXZ") From OBJDIV
                  Write [XXZ]  
                  If fstat : GOK = 0 : Call FSTA("XXZ") From GLOCK  : Endif 
                  # dans le cas du BRI on met a jour egalement langue USA uniquement en creation
                  # suite a demande (2007) sophie rebeyrotte : inversion
                  # c'est maintenant le ENG qui est maitre et qui met a jour le bri

                  If GUSER="XENG" and WLAN_INDUS ="ENG"
                     Read [XXZ]NUMERO = "BRI";WTAB_NUM (W_INDICE)
                     Case fstat
                           When 4, 5 :
                          #ici record n'existe pas dans la langue de trad mais existe en francais
                          # attention car atx2 est ouvert dans le dossier ou l'on se trouve 
                          # recup du numero WNUM_INDUS  mais ecriture avec wtab_num
