#############################################################################
# ouverture des differents fichiers
#  etiquette commune au trts : Atxttrad subamd subatt et subatr
#############################################################################

$OUVRE_FIC

If filinfo(filpath("",GMAGIC,""),0)>=0
    WIND_TRAD = 0
    For ILAN=1 To GNBLANSTD
       If GUSER=GUSRLAN(ILAN) and nomap=GREFER(ILAN)
            # on est sur à dossier indus pour trad
            # ici on ne peut pas tester code langue car classe M  pas ouverte
            WIND_TRAD = 1
      Endif
    Next ILAN
    #
    Local Char WDOSMOTH(GLONADS+2)
    WDOSMOTH = "*"+adxmother(0)+"*"
    If pat (GINDUS , WDOSMOTH)
        If GINDUS  = ""
                 Local File ATEXTE [XTX]
        Else
                 Local File =adxmother(0)+"."+"ATEXTE" [XTX]
        Endif
        If WIND_TRAD <> 0
            If GFOLDER_PRODUIT (0) <> ""
                # ATEXTE de l'appli SUPERV140
                Local File =GFOLDER_PRODUIT(0)+".ATEXTE" [XXS]
                # gproduit = 0 : c'est x3
                # gproduit = 1 : c'est geode
                # gproduit = 3 : c'est abelx3
                # gproduit = 2 : c'est paye 
                If GPRODUIT = 0
                    If GFOLDER_PRODUIT(4) <> ""
                        # ATEXTE de l appli abelx3
                        Local File =GFOLDER_PRODUIT(4)+".ATEXTE" [XXY]
                    Endif
                    If GFOLDER_PRODUIT(2) <> ""
                        # aplstd de l appli geode
                        Local File =GFOLDER_PRODUIT(2)+".ATEXTE" [XXX]
                    Endif
                    If GFOLDER_PRODUIT(3) <> ""
                        # aplstd de l appli paye
                        Local File =GFOLDER_PRODUIT(3)+".ATEXTE" [XXP]
                    Endif
                Elsif GPRODUIT = 1
                    If GFOLDER_PRODUIT(1) <> ""
                        # ATEXTE de l appli x3
                        Local File =GFOLDER_PRODUIT(1)+".ATEXTE" [XXZ]
                    Endif
                    If GFOLDER_PRODUIT(4) <> ""
                        # aplstd de l appli abelx3
                        Local File =GFOLDER_PRODUIT(4)+".ATEXTE" [XXY]
                    Endif
                    If GFOLDER_PRODUIT(3) <> ""
                        # aplstd de l appli paye
                        Local File =GFOLDER_PRODUIT(3)+".ATEXTE" [XXP]
                    Endif
                Elsif GPRODUIT = 3
                    If GFOLDER_PRODUIT(1) <> ""
                        # ATEXTE de l appli x3
                        Local File =GFOLDER_PRODUIT(1)+".ATEXTE" [XXZ]
                    Endif
                    If GFOLDER_PRODUIT(2) <> ""
                        # aplstd de l appli geode
                        Local File =GFOLDER_PRODUIT(2)+".ATEXTE" [XXX]
                    Endif
                    If GFOLDER_PRODUIT(3) <> ""
                        # aplstd de l appli paye
                        Local File =GFOLDER_PRODUIT(3)+".ATEXTE" [XXP]
                    Endif
                Elsif GPRODUIT = 2
                    If GFOLDER_PRODUIT(4) <> ""
                        # ATEXTE de l appli abelx3
                        Local File =GFOLDER_PRODUIT(4)+".ATEXTE" [XXY]
                    Endif
                    If GFOLDER_PRODUIT(2) <> ""
                        # aplstd de l appli geode
                        Local File =GFOLDER_PRODUIT(2)+".ATEXTE" [XXX]
                    Endif
                    If GFOLDER_PRODUIT(1) <> ""
                        # ATEXTE de l appli x3
                        Local File =GFOLDER_PRODUIT(1)+".ATEXTE" [XXZ]
                    Endif
                Endif
            Endif
            # version v150 superv150 +
            # mettre a jour le fichier atexte des dossiers 140 ex : pour x3 X3IND140.
            If GFOLDER_V150 (0) <> "" 
                # ATEXTE de l'appli SUPERV150
                Local File =GFOLDER_V150(0)+".ATEXTE" [XVS]
                # gproduit = 0 : c'est x3
                # gproduit = 1 : c'est geode
                # gproduit = 3 : c'est abelx3
                # gproduit = 2 : c'est paye
                If GPRODUIT = 0
                    If GFOLDER_PRODUIT (1) <> ""
                        # ATEXTE de l appli X3IND140
                        Local File =GFOLDER_PRODUIT(1)+".ATEXTE" [XXZ]
                    Endif
                    If GFOLDER_V150(4) <> ""
                        # ATEXTE de l appli abelx3 v150
                        Local File =GFOLDER_V150(4)+".ATEXTE" [XVY]
                    Endif
                    If GFOLDER_V150(2) <> ""
                        # aplstd de l appli geode v150
                        Local File =GFOLDER_V150(2)+".ATEXTE" [XVX]
                    Endif
                    If GFOLDER_V150(3) <> ""
                        # aplstd de l appli paye v150
                        Local File =GFOLDER_V150(3)+".ATEXTE" [XVP]
                    Endif
                Elsif GPRODUIT = 1
                    If GFOLDER_PRODUIT (2) <> ""
                        # ATEXTE de l appli GEOIND140
                        Local File =GFOLDER_PRODUIT(2)+".ATEXTE" [XXX]
                    Endif
                    If GFOLDER_V150(1) <> ""
                        # aplstd de l appli x3 v150
                        Local File =GFOLDER_V150(1)+".ATEXTE" [XVZ]
                    Endif
                    If GFOLDER_V150(4) <> ""
                        # aplstd de l appli abelx3 v150
                        Local File =GFOLDER_V150(4)+".ATEXTE" [XVY]
                    Endif
                    If GFOLDER_V150(3) <> ""
                        # aplstd de l appli paye v150
                        Local File =GFOLDER_V150(3)+".ATEXTE" [XVP]
                    Endif
                Elsif GPRODUIT = 3
                    If GFOLDER_PRODUIT (4) <> ""
                        # ATEXTE de l appli ABEIND140
                        Local File =GFOLDER_PRODUIT(4)+".ATEXTE" [XXY]
                    Endif
                    If GFOLDER_V150(1) <> ""
                        # aplstd de l appli x3 v150
                        Local File =GFOLDER_V150(1)+".ATEXTE" [XVZ]
                    Endif
                    If GFOLDER_V150(2) <> ""
                        # aplstd de l appli geode v150
                        Local File =GFOLDER_V150(2)+".ATEXTE" [XVX]
                    Endif
                    If GFOLDER_V150(3) <> ""
                        # aplstd de l appli paye v150
                        Local File =GFOLDER_V150(3)+".ATEXTE" [XVP]
                    Endif
                Elsif GPRODUIT = 2
                    If GFOLDER_PRODUIT (3) <> ""
                        # ATEXTE de l appli payind v140
                        Local File =GFOLDER_PRODUIT(3)+".ATEXTE" [XXP]
                    Endif
                    If GFOLDER_V150(1) <> ""
                        # aplstd de l appli x3 v150
                        Local File =GFOLDER_V150(1)+".ATEXTE" [XVZ]
                    Endif
                    If GFOLDER_V150(2) <> ""
                        # aplstd de l appli geode v150
                        Local File =GFOLDER_V150(2)+".ATEXTE" [XVX]
                    Endif
                    If GFOLDER_V150(4) <> ""
                        # aplstd de l appli abelx3 v150
                        Local File =GFOLDER_V150(4)+".ATEXTE" [XVY]
                    Endif
                Endif
            Endif
            # version v160 superv160
            # mettre a jour le fichier atexte des dossiers 150 ex : pour x3 X3IND150.
            If GFOLDER_V160 (0) <> "" 
                # ATEXTE de l'appli SUPERV160
                Local File =GFOLDER_V160(0)+".ATEXTE" [XUS]
                # gproduit = 0 : c'est x3
                # gproduit = 1 : c'est geode
                # gproduit = 3 : c'est abelx3
                # gproduit = 2 : c'est paye
                If GPRODUIT = 0
                    # ATEXTE de l appli X3IND150
                    Local File =GFOLDER_V150(1)+".ATEXTE" [XVZ]
                    If GFOLDER_V160(4) <> ""
                        # ATEXTE de l appli abelx3 en V6 : n existe plus
                    Endif
