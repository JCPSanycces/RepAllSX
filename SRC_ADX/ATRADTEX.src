              [F:XVP]CLEREC = left$(vireblc(toupper(ctrans(WTEXT_INDUS)),4),20) 
              [F:XVP]TEXTE  = WTEXT_INDUS
              Call FLDUPD("XVP") From OBJDIV
              If WCOMMENT_INDUS <> ""
                  [F:XVP]COMMENT  = WCOMMENT_INDUS
              Endif
              Rewrite [XVP]
              If fstat : GOK = 0 : Call FSTA("XVP") From GLOCK : Endif 
            When 4,5 :
              WLANTRAD = GFRA
              #ici record n'existe pas dans la langue de trad mais existe en francais
              # attention car atx2 est ouvert dans le dossier ou l'on se trouve 
              # recup du numero WNUM_INDUS  mais ecriture avec wtab_num
              Read [ATX2]NUMERO = WLANTRAD;WNUM_INDUS
              Case fstat
               When 0 :
                  [F:XVP]       = [F:ATX2]
                  [F:XVP]NUMERO = WTAB_NUM (W_INDICE)
                  [F:XVP]LAN    = WLAN_INDUS
                  [F:XVP]CLEREC = left$(vireblc(toupper(ctrans(WTEXT_INDUS)),4),20) 
                  [F:XVP]TEXTE  = WTEXT_INDUS
                  [F:XVP]COMMENT  = WCOMMENT_INDUS
                  Call FLDCRE("XVP") From OBJDIV
                  Write [XVP]  
                  If fstat : GOK = 0 : Call FSTA("XVP") From GLOCK  : Endif 
                  # dans le cas du BRI on met a jour egalement langue USA uniquement en creation
                  # suite a demande (2007) sophie rebeyrotte : inversion
                  # c'est maintenant le ENG qui est maitre et qui met a jour le bri

                  If GUSER="XENG" and WLAN_INDUS ="ENG"
                     Read [XVP]NUMERO = "BRI";WTAB_NUM (W_INDICE)
                     Case fstat
                          When 4, 5 :
                          #ici record n'existe pas dans la langue de trad mais existe en francais
                          # attention car atx2 est ouvert dans le dossier ou l'on se trouve 
                          # recup du numero WNUM_INDUS  mais ecriture avec wtab_num
                          Read [ATX2]NUMERO = WLANTRAD;WNUM_INDUS
                           [F:XVP]       = [F:ATX2]
                           [F:XVP]NUMERO = WTAB_NUM (W_INDICE)
                           [F:XVP]LAN    = "BRI"
                           [F:XVP]CLEREC = left$(vireblc(toupper(ctrans(WTEXT_INDUS)),4),20) 
                           [F:XVP]TEXTE  = WTEXT_INDUS
                           [F:XVP]COMMENT  = WCOMMENT_INDUS
                           Call FLDCRE("XVP") From OBJDIV
                           Write [XVP]  
                           If fstat : GOK = 0 : Call FSTA("XVP") From GLOCK  : Endif 
                          When 0 :
                           If [F:XVP]TEXTE = ""
                                   [F:XVP]CLEREC = left$(vireblc(toupper(ctrans(WTEXT_INDUS)),4),20) 
                                   [F:XVP]TEXTE  = WTEXT_INDUS
                                   Call FLDUPD("XVP") From OBJDIV
                                   If WCOMMENT_INDUS <> ""
                                      [F:XVP]COMMENT  = WCOMMENT_INDUS
                                   Endif
                                   Rewrite [XVP]  
                                   If fstat : GOK = 0 : Call FSTA("XVP") From GLOCK  : Endif 
                           Endif
                     Endcase
                  Endif
              Endcase
              WLANTRAD = WLAN_INDUS
           When Default :
              GOK = 0 
              Call FSTA("XVP") From GLOCK 
Endcase

Return

