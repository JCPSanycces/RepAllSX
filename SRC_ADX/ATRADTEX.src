                    If GFOLDER_V170(3) <> ""
                        # atexte de l appli paye v7 : n existe plus
                        Local File =GFOLDER_V170(3)+".ATEXTE" [XYP]
                    Endif
                Elsif GPRODUIT = 3
                    # abel v7  n'existera pas : commun avec X3
                    # depusi la v6
                Elsif GPRODUIT = 2
                    # ATEXTE de l appli payind160
                    Local File =GFOLDER_V160(3)+".ATEXTE" [XUP]
                    If GFOLDER_V170(1) <> ""
                        # aplstd de l appli x3 v7
                        Local File =GFOLDER_V170(1)+".ATEXTE" [XYZ]
                    Endif
                    If GFOLDER_V170(4) <> ""
                        # ATEXTE de l appli abelx3 en V7 : n existe plus
                    Endif
                    If GFOLDER_V170(2) <> ""
                        # aplstd de l appli geode v7
                        Local File =GFOLDER_V170(2)+".ATEXTE" [XYX]
                    Endif
                Endif
            Endif
            # version v180 superv180
