#############################################################
#   TRT pour mise a jour atexte tout produit toute version
#############################################################


#############################################################################
#  
#############################################################################
  
$SUPERV140_TEXTE
If GFOLDER_PRODUIT (0) = ""
    Return
Endif

Read [XXS]NUMERO = WLANTRAD; WTAB_NUM (W_INDICE)
Case fstat
            When 0 :
              [F:XXS]CLEREC = left$(vireblc(toupper(ctrans(WTEXT_INDUS)),4),20) 
              [F:XXS]TEXTE  = WTEXT_INDUS
              Call FLDUPD("XXS") From OBJDIV
              If WCOMMENT_INDUS <> ""
                  [F:XXS]COMMENT  = WCOMMENT_INDUS
              Endif
              Rewrite [XXS]
              If fstat : GOK = 0 : Call FSTA("XXS") From GLOCK : Endif 
            When 4,5 :
              #ici record n'existe pas dans la langue de trad mais existe en francais
              # attention car atx2 est ouvert dans le dossier ou l'on se trouve 
              # recup du numero WNUM_INDUS  mais ecriture avec wtab_num
              WLANTRAD = GFRA
              Read [ATX2]NUMERO = WLANTRAD;WNUM_INDUS
              Case fstat
               When 0 :
                  [F:XXS]       = [F:ATX2]
                  [F:XXS]LAN    = WLAN_INDUS
                  [F:XXS]NUMERO = WTAB_NUM (W_INDICE)
                  [F:XXS]CLEREC = left$(vireblc(toupper(ctrans(WTEXT_INDUS)),4),20) 
                  [F:XXS]TEXTE  = WTEXT_INDUS
                  [F:XXS]COMMENT  = WCOMMENT_INDUS
                  Call FLDCRE("XXS") From OBJDIV
                  Write [XXS]  
                  If fstat : GOK = 0 : Call FSTA("XXS") From GLOCK  : Endif 
                  # dans le cas du BRI on met a jour egalement langue USA uniquement en creation
                  # suite a demande (2007) sophie rebeyrotte : inversion
                  # c'est maintenant le ENG qui est maitre et qui met a jour le bri
                  If GUSER="XENG" and WLAN_INDUS="ENG"
                     Read [XXS]NUMERO = "BRI";WTAB_NUM (W_INDICE)
                     Case fstat
                          When 4, 5 :
                          #ici record n'existe pas dans la langue de trad mais existe en francais
                          # attention car atx2 est ouvert dans le dossier ou l'on se trouve 
                          # recup du numero WNUM_INDUS  mais ecriture avec wtab_num
                           Read [ATX2]NUMERO = WLANTRAD;WNUM_INDUS
                           [F:XXS]       = [F:ATX2]
                           [F:XXS]LAN    = "BRI"
                           [F:XXS]NUMERO = WTAB_NUM (W_INDICE)
                           [F:XXS]CLEREC = left$(vireblc(toupper(ctrans(WTEXT_INDUS)),4),20) 
                           [F:XXS]TEXTE  = WTEXT_INDUS
                           [F:XXS]COMMENT  = WCOMMENT_INDUS
                           Call FLDCRE("XXS") From OBJDIV
                           Write [XXS]  
                           If fstat : GOK = 0 : Call FSTA("XXS") From GLOCK  : Endif 
                          When 0 :
                            If [F:XXS]TEXTE = ""
                                   [F:XXS]CLEREC = left$(vireblc(toupper(ctrans(WTEXT_INDUS)),4),20) 
                                   [F:XXS]TEXTE  = WTEXT_INDUS
                                   Call FLDUPD("XXS") From OBJDIV
                                   If WCOMMENT_INDUS <> ""
                                      [F:XXS]COMMENT  = WCOMMENT_INDUS
                                   Endif
                                   Rewrite [XXS]  
                                   If fstat : GOK = 0 : Call FSTA("XXS") From GLOCK  : Endif 
                            Endif
                     Endcase
                  Endif
              Endcase
              WLANTRAD = WLAN_INDUS
           When Default :
              GOK = 0 
              Call FSTA("XXS") From GLOCK 
Endcase
Return


