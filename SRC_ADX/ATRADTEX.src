$X3IND140_TEXTE
If GFOLDER_PRODUIT (1) = ""
    Return
Endif

Read [XXZ]NUMERO = WLANTRAD; WTAB_NUM (W_INDICE)
Case fstat
            When 0 :
              [F:XXZ]CLEREC = left$(vireblc(toupper(ctrans(WTEXT_INDUS)),4),20) 
              [F:XXZ]TEXTE  = WTEXT_INDUS
              Call FLDUPD("XXZ") From OBJDIV
