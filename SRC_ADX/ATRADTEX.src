                        Local File =GFOLDER_V160(1)+".ATEXTE" [XUZ]
                    Endif
                    If GFOLDER_V160(4) <> ""
                        # ATEXTE de l appli abelx3 en V6 : n existe plus
                    Endif
                    If GFOLDER_V160(3) <> ""
                        # aplstd de l appli paye v6
                        Local File =GFOLDER_V160(3)+".ATEXTE" [XUP]
                    Endif
                Elsif GPRODUIT = 3
                    # abel v6  n'existera pas : commun avec X3
                    # depusi la v6
                Elsif GPRODUIT = 2
                    # ATEXTE de l appli payind150
                    Local File =GFOLDER_V150(3)+".ATEXTE" [XVP]
                    If GFOLDER_V160(1) <> ""
                        # aplstd de l appli x3 v6
                        Local File =GFOLDER_V160(1)+".ATEXTE" [XUZ]
                    Endif
                    If GFOLDER_V160(4) <> ""
                        # ATEXTE de l appli abelx3 en V6 : n existe plus
