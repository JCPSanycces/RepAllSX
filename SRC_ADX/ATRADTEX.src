                # gproduit = 2 : c'est paye
                If GPRODUIT = 0
                    # ATEXTE de l appli X3IND160
                    Local File =GFOLDER_V160(1)+".ATEXTE" [XUZ]
                    If GFOLDER_V170(4) <> ""
                        # ATEXTE de l appli abelx3 en V7 : n existe plus
                    Endif
                    If GFOLDER_V170(2) <> ""
                        # atexte de l appli geode v7
                        Local File =GFOLDER_V170(2)+".ATEXTE" [XYX]
                    Endif
                    If GFOLDER_V170(3) <> ""
                        # atexte de l appli paye v7 : n existe plus
