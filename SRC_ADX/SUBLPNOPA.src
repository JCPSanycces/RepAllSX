$FILTRE
Default File [SGH]
FILTSUP = "TRSTYP = 36"    # changement identifiant contenant
Return

######################################################################
$LIENS
WMOD = 1
Diszo [M:LPNO]
#FQ 68364
If GFCY<>[F:SGH]STOFCY : GFCY=[F:SGH]STOFCY Endif    # hcb test
#----- Affichage entêtes de colonne variables -----#                     # Ana
Gosub CHARG_PARAM   # hcb test
#fin FQ 68364


# hcb 33564 deb
# globales servant à tester la date d imputation par rapport à la date du jour
If dim(GCTRDATSCS) > 0
   Kill GCTRDATSCS
Endif
# hcb 33564 deb

Local Integer I
Local Integer LRET

[M:LPNO]VCRTYP = 29
Raz [M:SGW]
[M:SGW]TRSTYP = 36
[M:SGW]TRSCOD = ""
[M:SGW]FCYDES = [M:LPNO]STOFCY

Gosub LIENS From TABLEAUX

# Ce qui suit ne fonctionne pas dans LIEN_LIG, càd que rien n'est grisé

# Force l'affichage afin que les Diszo
# appelés ensuite fonctionnent
Affzo [M:LPNO]
Call STKCTRIPT( [M:LPNO]IPTDAT, [M:LPNO]STOFCY, "1") From STKLIB
If GERR=1
  Call ERREUR(GMESSAGE) From GESECRAN
  Raz GERR
  Raz GMESSAGE
Elsif GERR=2
  Call MESSAGE(GMESSAGE) From GESECRAN
  Raz GERR
  Raz GMESSAGE
Else
  # Rend insaisissables toutes les colonnes, puis...
  # ( Diszo du tableau empêche la réactivation)
  # ...rend saisissable la dernière ligne (la ligne vide)
  # Car celle-ci peut avoir été rendue inactive
  # par le chargement précédent d'un document (comportant plus de lignes)
  Call STKDISCOL("LPNO",[M]NBLIG) From STKECR
  Diszo [LPNO]ITMREF
  Actzo [LPNO]ITMREF([M]NBLIG)
  If dim([M:LPNO]QTYPCU)>0
    Diszo [LPNO]QTYPCU
    Actzo [LPNO]QTYPCU([M]NBLIG)
  Endif
Endif
#---
Diszo [M:LPNO]5
Actzo [M:LPNO]VCRNUM
# Issue X3-106909
If [F:SGH]MODOPELPN = 0
  [M:LPNO]MODOPELPN = 1
Endif
#Actzo [M:LPNO]MODOPELPN
Affzo [M:LPNO]MODOPELPN
Return


######################################################################
$DEFLIG
    Default Mask [LPNO]
    Default File [SGD]
    CRIT = 'VCRNUM="'+[M:LPNO]VCRNUM+'"'
    FICLIG="SCHGD"
    ABLIG="SGD"
    ZONLIG="VCRLIN"
Return

######################################################################
$LIENS_LIG
Local Integer NBROW
#lecture de l'article et de l'article site
If [F:ITM]ITMREF <> [M:LPNO]ITMREF(nolign-1)
  Read [ITM]ITM0 = [M:LPNO]ITMREF(nolign-1)
Endif
If [F:ITF]ITMREF <> [M:LPNO]ITMREF(nolign-1)
  Read [ITF]ITF0 = [M:LPNO]ITMREF(nolign-1);[M:LPNO]STOFCY
Endif
    Gosub SET_NOL
    Call RECSTOSOR (1,"LPNO",NOL,[M:LPNO]STOFCY,[M:LPNO]ITMREF(NOL),
&                   [M:LPNO]VCRTYP,[M:LPNO]VCRNUM,[M:LPNO]VCRLIN(NOL),
&                   "",LRET) From STKECR

Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:LPNO]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 03/07/2009 : X3SUIVI56319


Return

######################################################################
$RAZCRE
WMOD = 0

If GFCY<>GFCYDEF(7)                             # Ana
  GFCY=GFCYDEF(7) : Gosub CHARG_PARAM           # Ana
Endif                                           # Ana

Actzo [M:LPNO]5
If GSTKCPTMAN(14)<>2
  Effzo [M:LPNO]VCRNUM
  Diszo [M:LPNO]VCRNUM
Endif

[M:LPNO]VCRTYP=29
[M:LPNO]TRSTYP = 36
Actzo [M:LPNO]10

Grizo [M:LPNO]LOCDESH

[M:LPNO]MODOPELPN = 1
Actzo [M:LPNO]MODOPELPN
Affzo [M:LPNO]MODOPELPN
Actzo [M:LPNO]30

Return

