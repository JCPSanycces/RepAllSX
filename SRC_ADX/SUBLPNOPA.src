$RAZDUP
Return

######################################################################
$SETBOUT

#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
Gosub SET_BOUT_SPE From GSAISIE
Return

######################################################################
$VERIF_CRE
    Gosub VERIF_ENR
Return

######################################################################
$VERIF_MOD
    Gosub VERIF_ENR
Return

######################################################################
$VERIF_ENR
#au moins une ligne doite être sélectionnée
If [M:LPNO]NBLIG=0  | ( sigma(0,[M:LPNO]NBLIG-1,([M:LPNO]FLGSEL(indcum)=2))=0)
  GMESSAGE = mess(187,7900,1)
  Raz OK : Return
Endif

#Vérification des infos du LPN saisi
# Une seule ligne dans LPNO ou plusieurs mais une seule active et une seule sélectionnée (WSTOSEQ<>0 et FLGSEL = 2)
LRET = 1
If [M:LPNO]NBLIG=1  | ([M:LPNO]NBLIG>1 & sigma(0,[M:LPNO]NBLIG-1,1*([M:LPNO]WSTOSEQ(indcum)<>0)*([M:LPNO]FLGSEL(indcum)=2))=1)
    # Si une seule
    If [M:LPNO]NBLIG=1
      IC=0
    # Si plusieurs, récupération de l'indice de celle qui est active
    Else
      IC=sigma(0,[M:LPNO]NBLIG-1,indcum*([M:LPNO]WSTOSEQ(indcum)<>0)*([M:LPNO]FLGSEL(indcum)=2))
    Endif
    If [M:LPNO]LPNNUMDES(IC)<>"" & [M:LPNO]WSTOSEQ(IC)<>0
      Read [ITM]ITM0=[M:LPNO]ITMREF(IC)
      Read [LPN]LPN0=[M:LPNO]LPNNUMDES(IC)
      #--- Contrôle du mono-lot pour le LPN concerné
      If [F:LPN]MONLOTFLG=2 & [F:ITM]LOTMGTCOD>1
        Filter [STO] Where LPNNUM=[M:LPNO]LPNNUMDES(IC) & (ITMREF<>[M:LPNO]ITMREF(IC) | LOT<>[M:LPNO]LOT(IC))
        Look [STO]STO3 First
        If !fstat : LRET=0 : Endif
        Filter [STO]
        If LRET=0
          Call ERREUR(func AFNC.MES2(mess(516,184,1),[M:LPNO]LPNNUMDES(IC),"")) From GESECRAN
          Raz OK : Return
        Endif
      #--- Contrôle du mono-article pour le LPN concerné
      Elsif [F:LPN]MONITMFLG=2
        Filter [STO] Where LPNNUM=[M:LPNO]LPNNUMDES(IC) & ITMREF<>[M:LPNO]ITMREF(IC)
        Look [STO]STO3 First
        If !fstat : LRET=0 : Endif
        Filter [STO]
        If LRET=0
          Call ERREUR(func AFNC.MES2(mess(517,184,1),[M:LPNO]LPNNUMDES(IC),"")) From GESECRAN
          Raz OK : Return
        Endif
      Endif
    Endif
  # Plusieurs lignes dans LPNOPE
  Else
    For I=0 To [M:LPNO]NBLIG-2
      If [M:LPNO]LPNNUMDES(I)<>"" & [M:LPNO]WSTOSEQ(I)<>0 & [M:LPNO]FLGSEL(I)=2
        If [F:ITM]ITMREF<>[M:LPNO]ITMREF(I)
          Read [ITM]ITM0=[M:LPNO]ITMREF(I)
        Endif
        If [F:LPN]LPNNUM<>[M:LPNO]LPNNUMDES(I)
          Read [LPN]LPN0=[M:LPNO]LPNNUMDES(I)
        Endif
        J=0
        #--- Contrôle du mono-lot pour le LPN concerné
        If [F:LPN]MONLOTFLG=2 & [F:ITM]LOTMGTCOD>1
          J=sigma(I+1,[M:LPNO]NBLIG-1,1*([M:LPNO]LPNNUMDES(indcum)=[M:LPNO]LPNNUMDES(I) & [M:LPNO]WSTOSEQ(indcum)<>0 & ([M:LPNO]FLGSEL(indcum)=2)
&              & ([M:LPNO]ITMREF(indcum)<>[M:LPNO]ITMREF(I) | [M:LPNO]LOT(indcum)<>[M:LPNO]LOT(I))))
          If J>=1
            LRET=0
          Else
            Filter [STO] Where LPNNUM=[M:LPNO]LPNNUMDES(I) & (ITMREF<>[M:LPNO]ITMREF(I) | LOT<>[M:LPNO]LOT(I))
            Look [STO]STO3 First
            If !fstat : LRET=0 : Endif
            Filter [STO]
          Endif
          If LRET=0
            Call ERREUR(func AFNC.MES2(mess(516,184,1),[M:LPNO]LPNNUMDES(I),"")) From GESECRAN
            Break
          Endif
        #--- Contrôle du mono-article pour le LPN concerné
        Elsif [F:LPN]MONITMFLG=2
          J=sigma(I+1,[M:LPNO]NBLIG-1,1*([M:LPNO]LPNNUMDES(indcum)=[M:LPNO]LPNNUMDES(I) & [M:LPNO]WSTOSEQ(indcum)<>0 & ([M:LPNO]FLGSEL(indcum)=2)
&                 & [M:LPNO]ITMREF(indcum)<>[M:LPNO]ITMREF(I)))
          If J>=1
            LRET=0
          Else
            Filter [STO] Where LPNNUM=[M:LPNO]LPNNUMDES(I) & ITMREF<>[M:LPNO]ITMREF(I)
            Look [STO]STO3 First
            If !fstat : LRET=0 : Endif
            Filter [STO]
          Endif
          If LRET=0
            Call ERREUR(func AFNC.MES2(mess(517,184,1),[M:LPNO]LPNNUMDES(I),"")) From GESECRAN
            Break
          Endif
        Endif
        #--- Contrôle du mono-emplacement par LPN
        K=sigma(I+1,[M:LPNO]NBLIG-1,1*([M:LPNO]LPNNUMDES(indcum)=[M:LPNO]LPNNUMDES(I) & [M:LPNO]WSTOSEQ(indcum)<>0)&([M:LPNO]FLGSEL(indcum)=2))
        L=sigma(I+1,[M:LPNO]NBLIG-1,1*([M:LPNO]LPNNUMDES(indcum)=[M:LPNO]LPNNUMDES(I) & [M:LPNO]WSTOSEQ(indcum)<>0 &([M:LPNO]FLGSEL(indcum)=2)
&               & [M:LPNO]LOCDES(indcum)=[M:LPNO]LOCDES(I)))
        If K<>L
          Call ERREUR(func AFNC.MES2(mess(521,184,1),[M:LPNO]LPNNUMDES(I),[M:LPNO]LOCDES(I))) From GESECRAN
          LRET=0 : Break
        Endif
      Endif
    Next I
Endif

If LRET = 0 : OK = 0 : Return : Endif
    Call CTLSTOCHG( OK ) From SUBLPNOPB
    If OK
         # Issue X3-106909 - 2018-09-21 by MAE : Ajout du GSTOTRACE
        If !GIMPORT & GSTOTRACE>1
           Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
        Endif
        If func SUBSCSB.VERALL( "LPNO" ) & !GIMPORT                               # hcb 82350
            OK = 1
            Call AVERTIR(mess(81,184,1),OK) From GESECRAN
            OK -= 1
            If OK & !GIMPORT & GSTOTRACE>1
              Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
              Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
            Endif
        Endif
    Else
        Raz OK
        #--- Issue 113595
        Return
    Endif

Return
######################################################################
$INICRE

Local Integer LSTAT, I
Local Char    LNUM
    # Création du numéro de document si nécessaire
    If GSTKCPTMAN(14)<>2 | [M:LPNO]VCRNUM = ""
        Call NUMERO(GSTKCPT(14), [M:LPNO]STOFCY, [M:LPNO]IPTDAT,
&                   "", LNUM, LSTAT) From SUBANM
        If GOK<0 Return Endif
        If LSTAT=0
           [M:LPNO]VCRNUM = LNUM
           [F:SGH]VCRNUM  = LNUM
        Else
            GERR=1:GMESSAGE = mess(60,199,1)
            GOK=0
        Endif
    Endif
Return

######################################################################
$INIMOD
Return

######################################################################
$CREATION
Gosub CREATION From TABLEAUX
Return

######################################################################
$MODIF
    Gosub MODIF From TABLEAUX
Return


######################################################################
$INICRE_LIG
    [F:SGD]VCRNUM = [F:SGH]VCRNUM
#
    If [F:ITM]ITMREF<>[F:SGD]ITMREF
       Read [ITM]ITM0=[F:SGD]ITMREF
       If fstat
          Raz [F:ITM]
       Endif
    Endif
    If [F:ITM]SERMGTCOD = 4
       Raz [F:SGD]SERNUM
       Raz [F:SGD]SERNUMF
    Endif
  #si la ligne n'est pas sélectionnée, on positionne ANOWRITE à 1 => permet de ne pas inserer par CRUD dans la table
  If [M:LPNO]FLGSEL(nolign-1) <> 2
    #suppression du STOCHGW
    Call DELSTOCHGW("LPNO", [M:LPNO]STOFCY, nolign-1, nolign-1,1, LRET) From SUBSCSB
    ANOWRITE = 1
  Else
    ANOWRITE = 0
  Endif
#

Return

######################################################################
$VALLIG
Local Integer LRET
Local Decimal LQTY
Local Integer LSEQ

If SIGN=1 & [M:LPNO]FLGSEL(nolign-1) = 2
    #remplissage du STOWORK
    Call ALISTW (nolign-1) From SUBLPNOPB
    #-----
    Gosub DEFLIG
Endif
Return

######################################################################
$APRES_CRE
Local Integer LRET

Call STKDELRES(0,[M:LPNO]STOFCY,"",LRET) From STKLOC

#---- Régularisation des mouvements et alloc -----#
Call REGFROMENT( 0, "LPNO", "[M:LPNO]CREFLG(I)=0", "ITMREF", [M:LPNO]STOFCY ) From TRTSHTCOM

If !GIMPORT & !GWEBSERV & GTRACE<>""
  Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
Endif
If !GIMPORT & !GVTMOD
  Gosub RELIT From GOBJSUB
  Gosub TIROIR From SUBLPNOPP
Endif
Return

######################################################################
$APRES_MOD
    Gosub APRES_CRE
Return

######################################################################
$AB_CREATION
If GTRACE<>"" & !GIMPORT
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Return

######################################################################
$AB_MODIF
If GTRACE<>"" & !GIMPORT
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
Return

######################################################################
$APRES_MODIF

    If GRAFFRAICHISCS
        Gosub TIROIR From SUBLPNOPP
        Raz GRAFFRAICHISCS
    Endif
    Case COUZON
      When "LOCTYPSTR" :
          [M:LPNO]LOCTYPSTR = CZ
          Gosub TIROIR From SUBLPNOPP
      When "LOCTYPEND" :
          [M:LPNO]LOCTYPEND = CZ
          Gosub TIROIR From SUBLPNOPP
      When "LOCSTR" :
          [M:LPNO]LOCSTR = CZ
          Gosub TIROIR From SUBLPNOPP
      When "LOCEND" :
          [M:LPNO]LOCEND = CZ
          Gosub TIROIR From SUBLPNOPP
      When "LPNNUMSEL" :
          [M:LPNO]LPNNUMSEL = CZ
          Gosub TIROIR From SUBLPNOPP
      When "NBLIG" :
          If find(status,65,83)
              Gosub TIROIR From SUBLPNOPP
          Endif
    Endcase
Return
######################################################################
$ABANDON
    Local Integer LRET
    Actzo [M:LPNO]VCRNUM
    WPICK = 1
    If dim([M:LPNO]LOCDESH)>0    Raz [M:LPNO]LOCDESH    Endif
    Gosub REMP_LISGAU From GOBJSUB
    Gosub RAFFRAICHI From SUBLPNOPP
    Call DELSTOCHGW("LPNO",[M:LPNO]STOFCY,-1,-1,1,LRET) From SUBSCSB
Return
######################################################################
$FERME

# hcb 33564 deb
# globales servant à tester la date d imputation par rapport à la date du jour
If dim(GCTRDATSCS) > 0
   Kill GCTRDATSCS
Endif
# hcb 33564 deb

    Kill GSCSAUZSST

#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB

Return



###############################                         # Ana   deb
$CHARG_PARAM
#----- Chargement des globales référenciels, comptes et sections de la société -----#
Call GETCPY([M:LPNO]STOFCY,"",0,"") From TRTX3CPT             # hcb 50197
# en import test il ne faut pas controler les compteurs
If dim([M:IMP2]TEST)>0
   If [M:IMP2]TEST = 2
      Return
   Endif
Endif
Local Integer LRET

# Récupération des codes compteur et effacement fichier de travail
If clalev ([F:TCA])<=0
   Local File TABCOUAFF [TCA]
Endif
# Compteur module stock
Call LECTCA(7,LRET) From SUBTCA
If !LRET
   GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
   GERR=1
   Return
Endif


#Controle compteur
Call CTRCPT(GSTKCPT(14),type([M:LPNO]VCRNUM), LRET) From STKLIB
If LRET<>0
   GMESSAGE = mess(242,199,1)
   GERR = 1
   GOK  = 0
   Return
Endif
GSTKCPTMAN(0) = [F:TCA]MANCOU(0)
GSTKCPT   (0) = [F:TCA]CODNUM(0)
GSTKCPTMAN(2) = [F:TCA]MANCOU(2)
GSTKCPT   (2) = [F:TCA]CODNUM(2)

Return

