#<AdxTL>@(#)3.0.0.0 $Revision$
#########################################################################
# SQUOT : Liste des devis par no et par site/client                     #
#         Carnets de commande client                                    #
# --------------------------------------------------------------------- #
# Chargement et gestion du filtre représentant                          #
#      Etat SQUOT      : Liste des devis par numéro                     #
#      Etat SQUOT2     : Liste des devis par site /client               #
#      Etat SCARNETCDE : Carnet de commande client valorisé             #
#      Etat SCARNETQTY : Carnet de commande client                      #
#########################################################################

$ACTION
Case ACTION
  When "OUVRE"   : Gosub OUVRE2
  When "INIPAR"  : Gosub INIPAR
  When "INIPAR2" : Gosub INIPAR
Endcase
Return

$OUVRE2
GBIDI2=find("REP",[M:RPT]PARTYP)
If GBIDI2
  If GAUSCRMF<>"" & GAUSCRMA=2 & (dim(GAUSCRMROL)<1 | (dim(GAUSCRMROL)>0 & GAUSCRMROL<>1))
    [M:RPT]VALEUR1(GBIDI2-1)=GAUSCRMF
    [M:RPT]VALINT1(GBIDI2-1)=GAUSCRMF
  Endif
  Affzo [RPT]VALEUR1(GBIDI2-1)
Endif
#--CPO 104383 Nouveau : "Type de devis"
If clalev([F:TSQ])=0 : Local File TABSQHTYP [TSQ] : Endif
GBIDI2 = find("TSQ",[M:RPT]PARTYP)
If GBIDI2
  Read [F:TSQ] Last
  If ! fstat : [M:RPT]VALEUR2(GBIDI2-1) = [F:TSQ]SQHTYP : Endif
Endif
#--/
Return

$INIPAR
If GAUSCRMF<>"" & GAUSCRMA=2 & [M:RPT]PARTYP(nolign-1)="REP"  mkstat=2 : Endif
Return

######################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
End

######################################################################
