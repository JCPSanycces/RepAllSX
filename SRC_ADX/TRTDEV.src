#<AdxTL>@(#)7.0.0.0 $Revision$
Local Integer STAT
Local Decimal MTDES1,MTDES2
#Call COURSITE("TL","PAR",1,date$,MTDES,STAT)
Call CONVERT3("TL","JPY","EUR",1,date$,10000,MTDES1,0,STAT) From CPTSUB
Call COURMNT("TL","JPY","EUR",1,date$,1,10000,MTDES2,0,STAT)
Infbox num$(MTDES1),num$(MTDES2)
End

######################################################################################
## Conversion d'un montant unique
## Subprog CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
##
## Conversion avec toute la précision
## Subprog CONVERT2(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
##
## Conversion avec un arrondi donné (en nombre de décimales)
## Subprog CONVERT3(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT)
##
## Converting a single amount and user currency rate included
## Subprog CONVERT4(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT,CURRATUSR)
##
## Conversion d'un tableau à somme constante
## Subprog CONVERT_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
##
## Conversion d'un tableau avec un arrondi forcé
## Subprog CONVERT3_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT)
##
## Récupération du cours entre une devise origine et la devise société
## Subprog COURSITE(DEVORG,SITE,TYPCOURS,DATCOURS,COURS,STAT)
##
## Conversion avec un arrondi donné (en nombre de décimales) et cours éventuellement fourni
## Subprog COURMNT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,COURS,STAT)
######################################################################################

Subprog CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG            : # Montant origine
Variable Decimal MTDES            : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = 0
Local Integer ARROND : ARROND = 1 : # Arrondi
Goto CONVERSION

Subprog CONVERT2(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG            : # Montant origine
Variable Decimal MTDES            : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = 0
Local Integer ARROND : ARROND = 0 : # Pas d'arrondi
Goto CONVERSION

Subprog CONVERT3(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Integer ARODEC           : # Arrondi
Value    Decimal MTORG            : # Montant origine
Variable Decimal MTDES            : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = 0
Local Integer ARROND : ARROND = 2 : # Arrondi forcé à ARODES
Local Decimal ADODES
If int(ARODEC)>0 : ARODES = 10^(-ARODEC) : Else : ARROND = 1 : Endif
Goto CONVERSION

Subprog CONVERT4(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT,CURRATUSR)
#Issue 31729 – 2017-05-10  by MADOR - As a user I want to be able to compute
#payments with the new rate currency field
Value    Char    DEVORG           : # Original currency
Value    Char    DEVDES           : # Currency of destination
Value    Char    DEVSOC           : # Company Currency
Value    Integer TYPCOURS         : # Course Type
Value    Date    DATCOURS         : # Course date
Value    Decimal MTORG            : # Original Amount
Variable Decimal MTDES            : # Destination Amount
Variable Integer STAT             : # Return status (0 = OK)
Variable Decimal CURRATUSR           : # User currency rate
Local Integer NBMONT : NBMONT = 0
Local Integer ARROND : ARROND = 1 : # Round
Goto CONVERSION
#Issue end

Subprog CONVERT_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG(0..)       : # Montant origine
Variable Decimal MTDES(0..)       : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = dim(MTORG)-1
Local Integer ARROND : ARROND = 1
Goto CONVERSION

Subprog CONVERT2_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG(0..)       : # Montant origine
Variable Decimal MTDES(0..)       : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = dim(MTORG)-1
Local Integer ARROND : ARROND = 0
Goto CONVERSION

Subprog CONVERT3_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Integer ARODEC           : # Arrondi
Value    Decimal MTORG(0..)       : # Montant origine
Variable Decimal MTDES(0..)       : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = dim(MTORG)-1
Local Integer ARROND : ARROND = 2 : # Arrondi forcé à ARODES
Local Decimal ADODES
If int(ARODEC)>0 : ARODES = 10^(-ARODEC) : Else : ARROND = 1 : Endif
Goto CONVERSION

$CONVERSION
Local Decimal COURS , COURDIV , COURMUL , COURDIV1 , COURMUL1 , ARD
Local Char    DEV1(GLONCUR) , DEV2(GLONCUR) , DEVCUR(GLONCUR)
Local Decimal MTEURO , AROEURO , EURT1 , EURT2 , SOMME
Local Integer EUR1 , EUR2 , I , FLEURO , NO_CUR_RAT
If dim([V]GAROEURO)>0
 AROEURO = 10^(-GAROEURO)   : # Arrondi pour les calculs en euro
Else
 AROEURO = 0.001            : # Valeur par défaut minimale
Endif
FLEURO  = 1       : # Passage par l'euro ou non
NO_CUR_RAT = 0

STAT = 0
If DATCOURS=[0/0/0] : DATCOURS = GHIDATE : Endif
If TYPCOURS=0       : TYPCOURS = 1       : Endif

If clalev([F:TCU])=0
 Local File TABCUR    [TCU]
Else
 DEVCUR = [F:TCU]CUR
Endif

# Cas trivial
If DEVORG=DEVDES
 If [F:TCU]CUR<>DEVDES
     Read [TCU]TCU0=DEVDES : If fstat  Raz [F:TCU] : Endif
 Endif
 For I=0 To NBMONT
  MTDES(I) = MTORG(I)
  Case ARROND
   When 1 : MTDES(I)=arr(MTDES(I),[F:TCU]CURRND)
   When 2 : MTDES(I)=arr(MTDES(I),ARODES)
  Endcase
 Next I
 Goto FIN
Endif

If clalev([F:TCH])=0
 Local File =GTABCPT+"TABCHANGE" [TCH]
Endif

If DEVORG=GEURO
 If [F:TCU]CUR<>DEVDES
     Read [TCU]TCU0=DEVDES
     If fstat : STAT = 3 : Goto FIN : Endif
 Endif
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
# Euro vers devise "in"
  SOMME = 0
  Case ARROND
   When 1       : ARD = [F:TCU]CURRND
   When 2       : ARD = ARODES
   When Default : ARD = 0
  Endcase
  For I=0 To NBMONT
   MTDES(I) = arr((MTORG(I)+SOMME)*[F:TCU]EURRAT,ARD)
&             -arr(SOMME*[F:TCU]EURRAT,ARD)
   SOMME += MTORG(I)
  Next I
 Else
# Euro vers devise "out"
  DEV1 = GEURO : DEV2 = DEVDES : Gosub COURS
  If STAT=0
   SOMME = 0
   Case ARROND
    When 1       : ARD = [F:TCU]CURRND
    When 2       : ARD = ARODES
    When Default : ARD = 0
   Endcase
   For I=0 To NBMONT
## <PP 31/05/2010>
#    MTDES(I) = arr((MTORG(I)+SOMME)*COURMUL/COURDIV,ARD)
#&             -arr(SOMME*COURMUL/COURDIV,ARD)
    MTDES(I) = arr((MTORG(I)+SOMME)*arr(COURMUL/COURDIV,10^-GDECRCU),ARD)
&             -arr(SOMME*arr(COURMUL/COURDIV,10^-GDECRCU),ARD)
    SOMME += MTORG(I)
   Next I
  Endif
 Endif
Elsif DEVDES=GEURO
 # Issue 74775 - 2011-07-07 by VPO : Pour perf, on passe par une 2eme classe F
 # ssi la classe [F:TCU0] existe pour ne pas avoir d'effet de bord en migration
  If clalev([F:TCU0])=0
     If [F:TCU]CUR<>DEVORG
         Read  [TCU] TCU0=DEVORG
         If fstat : STAT = 2 : Goto FIN : Endif
     Endif

     If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
    # Devise "in" vers Euro
      SOMME = 0
      Case ARROND
       When 1       : ARD = GEURODEV
       When 2       : ARD = ARODES
       When Default : ARD = 0
      Endcase
      For I=0 To NBMONT
       MTDES(I) = arr((MTORG(I)+SOMME)/[F:TCU]EURRAT,ARD)
&                -arr(SOMME/[F:TCU]EURRAT,ARD)
       SOMME += MTORG(I)
      Next I
     Else
    # Devise "out" vers Euro
      DEV1 = GEURO : DEV2 = DEVORG : Gosub COURS
      If STAT=0
       SOMME = 0
       Case ARROND
        When 1       : ARD = GEURODEV
        When 2       : ARD = ARODES
        When Default : ARD = 0
       Endcase
       For I=0 To NBMONT
    ## <PP 31/05/2010>
    #    MTDES(I) = arr((MTORG(I)+SOMME)*COURDIV/COURMUL,ARD)
    #&             -arr(SOMME*COURDIV/COURMUL,ARD)
        MTDES(I) = arr((MTORG(I)+SOMME)*arr(COURDIV/COURMUL,10^-GDECRCU),ARD)
&                -arr(SOMME*arr(COURDIV/COURMUL,10^-GDECRCU),ARD)
        SOMME += MTORG(I)
       Next I
      Endif
     Endif
  Else
     If [F:TCU0]CUR<>DEVORG
      If [F:TCU]CUR=DEVORG
         [F:TCU0]=[F:TCU]
      Else
         Read  [TCU0] TCU0=DEVORG
         If fstat : STAT = 2 : Goto FIN : Endif
      Endif
     Endif

     If [F:TCU0]EURFLG=2 & ([F:TCU0]EURDAT=[0/0/0] | [F:TCU0]EURDAT<=DATCOURS)
    # Devise "in" vers Euro
      SOMME = 0
      Case ARROND
       When 1       : ARD = GEURODEV
       When 2       : ARD = ARODES
       When Default : ARD = 0
      Endcase
      For I=0 To NBMONT
       MTDES(I) = arr((MTORG(I)+SOMME)/[F:TCU0]EURRAT,ARD)
&                -arr(SOMME/[F:TCU0]EURRAT,ARD)
       SOMME += MTORG(I)
      Next I
     Else
    # Devise "out" vers Euro
      DEV1 = GEURO : DEV2 = DEVORG : Gosub COURS
      If STAT=0
       SOMME = 0
       Case ARROND
        When 1       : ARD = GEURODEV
        When 2       : ARD = ARODES
        When Default : ARD = 0
       Endcase
       For I=0 To NBMONT
    ## <PP 31/05/2010>
    #    MTDES(I) = arr((MTORG(I)+SOMME)*COURDIV/COURMUL,ARD)
    #&             -arr(SOMME*COURDIV/COURMUL,ARD)
        MTDES(I) = arr((MTORG(I)+SOMME)*arr(COURDIV/COURMUL,10^-GDECRCU),ARD)
&                -arr(SOMME*arr(COURDIV/COURMUL,10^-GDECRCU),ARD)
        SOMME += MTORG(I)
       Next I
      Endif
     Endif
  Endif
Else
 # Issue 74775 - 2011-07-07 by VPO : Pour perf, on passe par une 2eme classe F
 # ssi la classe [F:TCU0] existe pour ne pas avoir d'effet de bord en migration
 If clalev([F:TCU0])=0
   If [F:TCU]CUR<>DEVORG
       Read  [TCU] TCU0=DEVORG
       If fstat : STAT = 2 : Goto FIN : Endif
   Endif

   If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
    EUR1 = [F:TCU]EURFLG
   Else EUR1 = 1
   Endif
   EURT1 = [F:TCU]EURRAT
 Else
   If [F:TCU0]CUR<>DEVORG
    If [F:TCU]CUR=DEVORG
       [F:TCU0]=[F:TCU]
    Else
       Read  [TCU0] TCU0=DEVORG
       If fstat : STAT = 2 : Goto FIN : Endif
    Endif
   Endif

   If [F:TCU0]EURFLG=2 & ([F:TCU0]EURDAT=[0/0/0] | [F:TCU0]EURDAT<=DATCOURS)
    EUR1 = [F:TCU0]EURFLG
   Else EUR1 = 1
   Endif
   EURT1 = [F:TCU0]EURRAT
 Endif

 If [F:TCU]CUR<>DEVDES
     Read [TCU]TCU0=DEVDES
     If fstat : STAT = 3 : Goto FIN : Endif
 Endif
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
  EUR2 = [F:TCU]EURFLG
 Else EUR2 = 1
 Endif
 EURT2 = [F:TCU]EURRAT
 If EUR1=2 & EUR2=2
# Devise "in" vers devise "in"
  SOMME = 0
  For I=0 To NBMONT
   Case ARROND
    When 1       : ARD = AROEURO
    When 2       : ARD = ARODES
    When Default : ARD = 0
   Endcase
   MTEURO = arr((MTORG(I)+SOMME)/EURT1,ARD)
   MTSOMM = arr(SOMME/EURT1,ARD)
   Case ARROND
    When 1       : ARD = [F:TCU]CURRND
    When 2       : ARD = ARODES
    When Default : ARD = 0
   Endcase
   MTDES(I)  = arr(MTEURO*EURT2,ARD)
&             -arr(MTSOMM*EURT2,ARD)
   SOMME += MTORG(I)
  Next I
 Elsif EUR1=2
# Devise "in" vers devise "out"
  DEV1 = GEURO : DEV2 = DEVDES : Gosub COURS
  If STAT=0
   SOMME = 0
   For I=0 To NBMONT
    Case ARROND
     When 1       : ARD = AROEURO
     When 2       : ARD = ARODES
     When Default : ARD = 0
    Endcase
    MTEURO = arr((MTORG(I)+SOMME)/EURT1,ARD)
    MTSOMM = arr(SOMME/EURT1,ARD)
    Case ARROND
     When 1       : ARD = [F:TCU]CURRND
     When 2       : ARD = ARODES
     When Default : ARD = 0
    Endcase
## <PP 31/05/2010>
#    MTDES(I) = arr(MTEURO*COURMUL/COURDIV,ARD)
#&             -arr(MTSOMM*COURMUL/COURDIV,ARD)
    MTDES(I) = arr(MTEURO*arr(COURMUL/COURDIV,10^-GDECRCU),ARD)
&             -arr(MTSOMM*arr(COURMUL/COURDIV,10^-GDECRCU),ARD)
    SOMME += MTORG(I)
   Next I
  Endif
 Elsif EUR2=2
# Devise "out" vers devise "in"
  DEV1 = GEURO : DEV2 = DEVORG : Gosub COURS
  If STAT=0
   SOMME = 0
   For I=0 To NBMONT
    Case ARROND
     When 1       : ARD = AROEURO
     When 2       : ARD = ARODES
     When Default : ARD = 0
    Endcase
    ## <PP 31/05/2010>
    #MTEURO = arr((MTORG(I)+SOMME)*COURDIV/COURMUL,ARD)
    #MTSOMM = arr(SOMME*COURDIV/COURMUL,ARD)
    MTEURO = arr((MTORG(I)+SOMME)*arr(COURDIV/COURMUL,10^-GDECRCU),ARD)
    MTSOMM = arr(SOMME*arr(COURDIV/COURMUL,10^-GDECRCU),ARD)
    Case ARROND
     When 1       : ARD = [F:TCU]CURRND
     When 2       : ARD = ARODES
     When Default : ARD = 0
    Endcase
    MTDES(I)  = arr(MTEURO*EURT2,ARD)
&              -arr(MTSOMM*EURT2,ARD)
    SOMME += MTORG(I)
   Next I
  Endif
 Else
# Devise "out" vers devise "out"
  DEV1 = DEVDES : DEV2 = DEVORG : Gosub COURS
  If STAT=0
#  Y'a un cours direct
   SOMME = 0
   For I=0 To NBMONT
    Case ARROND
     When 1       : ARD = [F:TCU]CURRND
     When 2       : ARD = ARODES
     When Default : ARD = 0
    Endcase
## <PP 31/05/2010>
#    MTDES(I) = arr((MTORG(I)+SOMME)*COURDIV/COURMUL,ARD)
#&             -arr(SOMME*COURDIV/COURMUL,ARD)
    MTDES(I) = arr((MTORG(I)+SOMME)*arr(COURDIV/COURMUL,10^-GDECRCU),ARD)
&             -arr(SOMME*arr(COURDIV/COURMUL,10^-GDECRCU),ARD)
    SOMME += MTORG(I)
   Next I
  Else
#  Sinon, on passe par le cours "société" (pour l'étranger)
#  ou par l'euro pour l'europe
   STAT = 0
   If FLEURO
    NO_CUR_RAT = 1
    DEV1 = GEURO : DEV2 = DEVORG : Gosub COURS
    If STAT=0
     COURMUL1 = COURMUL
     COURDIV1 = COURDIV
     DEV1 = GEURO : DEV2 = DEVDES : Gosub COURS
     If STAT=0
      SOMME = 0
      For I=0 To NBMONT
       Case ARROND
        When 1       : ARD = AROEURO
        When 2       : ARD = ARODES
        When Default : ARD = 0
       Endcase
       ## <PP 31/05/2010>
       #MTEURO = arr((MTORG(I)+SOMME)*COURDIV1/COURMUL1,ARD)
       #MTSOMM = arr(SOMME*COURDIV1/COURMUL1,ARD)
       MTEURO = arr((MTORG(I)+SOMME)*arr(COURDIV1/COURMUL1,10^-GDECRCU),ARD)
       MTSOMM = arr(SOMME*arr(COURDIV1/COURMUL1,10^-GDECRCU),ARD)
       Case ARROND
        When 1       : ARD = [F:TCU]CURRND
        When 2       : ARD = ARODES
        When Default : ARD = 0
       Endcase
       ## <PP 31/05/2010>
       #MTDES(I) = arr(MTEURO*COURMUL/COURDIV,ARD)
#&                -arr(MTSOMM*COURMUL/COURDIV,ARD)
       MTDES(I) = arr(MTEURO*arr(COURMUL/COURDIV,10^-GDECRCU),ARD)
&                -arr(MTSOMM*arr(COURMUL/COURDIV,10^-GDECRCU),ARD)
       SOMME += MTORG(I)
      Next I
     Endif
    Endif
   Else
    DEV1 = DEVSOC : DEV2 = DEVORG : Gosub COURS
    If STAT=0
     COURMUL1 = COURMUL
     COURDIV1 = COURDIV
     DEV1 = DEVSOC : DEV2 = DEVDES : Gosub COURS
     If STAT=0
      SOMME = 0
      For I=0 To NBMONT
       Case ARROND
        When 1       : ARD = AROEURO
        When 2       : ARD = ARODES
        When Default : ARD = 0
       Endcase
       ## <PP 31/05/2010>
       #MTEURO = arr((MTORG(I)+SOMME)*COURDIV1/COURMUL1,ARD)
       #MTSOMM = arr(SOMME*COURDIV1/COURMUL1,ARD)
       MTEURO = arr((MTORG(I)+SOMME)*arr(COURDIV1/COURMUL1,10^-GDECRCU),ARD)
       MTSOMM = arr(SOMME*arr(COURDIV1/COURMUL1,10^-GDECRCU),ARD)
       Case ARROND
        When 1       : ARD = [F:TCU]CURRND
        When 2       : ARD = ARODES
        When Default : ARD = 0
       Endcase
       ## <PP 31/05/2010>
#       MTDES(I) = arr(MTEURO*COURMUL/COURDIV,ARD)
#&                -arr(MTSOMM*COURMUL/COURDIV,ARD)
       MTDES(I) = arr(MTEURO*arr(COURMUL/COURDIV,10^-GDECRCU),ARD)
&                -arr(MTSOMM*arr(COURMUL/COURDIV,10^-GDECRCU),ARD)
       SOMME += MTORG(I)
      Next I
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

$FIN
If DEVCUR<>""
 If [F:TCU]CUR<>DEVCUR
    Read [TCU]TCU0=DEVCUR: If fstat  Raz [F:TCU] : Endif
 Endif
Endif
End

$COURS
Filter [TCH] Where CHGTYP=TYPCOURS & CURDEN=DEV1 & CUR=DEV2 &
&                  CHGSTRDAT<=DATCOURS
Read [TCH]TCH0 Last
If fstat <= 2
    STAT = 0
    # Version 150, il y a 2 cours...
    #Issue 31729 – 2017-05-10  by MADOR - As a user I want to be able to compute
    #payments with the new rate currency field
    If dim([L]CURRATUSR) > 0 and [L]CURRATUSR(0) <> 0 and dim([L]NO_CUR_RAT) > 0
        If [L]NO_CUR_RAT = 1
            STAT = 1
        Elsif DEV1 = DEVORG or DEVSOC = DEVORG
            COURMUL = CURRATUSR(0)
            COURDIV = [F:TCH]CHGDIV
        Else
            COURMUL = [F:TCH]REVCOURS
            COURDIV = CURRATUSR(0)
        Endif
    Else
        COURMUL = [F:TCH]REVCOURS
        COURDIV = [F:TCH]CHGDIV
    Endif

    If dim([L]CURRATUSR) > 1 and STAT = 0
        If DEV1 = DEVORG
            [L]CURRATUSR(0) = COURMUL
            [L]CURRATUSR(1) = COURDIV
        Else
            [L]CURRATUSR(0) = COURDIV
            [L]CURRATUSR(1) = COURMUL
        Endif
    Endif
    # Issue end

    ## <PP 31/05/2010>
    #COURS   = COURDIV/COURMUL
    If STAT = 0
        COURS = arr(COURDIV/COURMUL,10^-GDECRCU)
    Endif
Else
    STAT = 1
Endif
GPOINT = "RECHTCH" : Gosub ENTREE From EXEFNC
Return

#################################################################################
Subprog COURSITE(DEVORG,SITE,TYPCOURS,DATCOURS,COURS,STAT)
Value    Char    DEVORG        : # Devise origine
Value    Char    SITE          : # Site
Value    Libelle TYPCOURS      : # Type de cours
Value    Date    DATCOURS      : # Date du cours
Variable Decimal COURS         : # Cours
Variable Integer STAT          : # Status de retour (OK=0)

Local Char    DEVDES(GLONCUR), DEV1(GLONCUR), DEV2(GLONCUR), DEVCUR(GLONCUR)
Local Decimal COURDIV , COURMUL
Local Decimal EURT1, EURT2, COURS1
Local Integer EUR1, EUR2, FLEURO, NO_CUR_RAT

If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif

COURS=1
If SITE="" : SITE=GFCYDEF : Endif
If [F:FCY]FCY<>SITE
 Read [FCY]FCY0=SITE
 If fstat : STAT=1 : End Endif
Endif
If [F:CPY]CPY<>[F:FCY]LEGCPY
 Read [CPY]CPY0=[F:FCY]LEGCPY
 If fstat : STAT=1 : End Endif
Endif
Call SETCUR(1,[F:CPY]CPY,DEVDES) From CPTDIV

FLEURO=1
NO_CUR_RAT = 0
STAT=0
If DATCOURS=[0/0/0] : DATCOURS=GHIDATE : Endif
If TYPCOURS=0 : TYPCOURS=1 : Endif

If DEVORG=DEVDES
 COURS=1 : End
Endif

If clalev([F:TCU])=0 : Local File TABCUR    [TCU] : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE [TCH] : Endif

If DEVORG=GEURO
 If [F:TCU]CUR<>DEVDES
     Read [TCU]TCU0=DEVDES
     If fstat STAT=3 : End Endif
 Endif
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
  # Euro vers devise "in"
  If [F:TCU]EURRAT=0
   COURS=1 : STAT=1
  Else
   COURS=[F:TCU]EURRAT
  Endif
 Else
  # Euro vers devise "out"
  DEV1=DEVDES : DEV2=GEURO : Gosub COURS
 Endif
Elsif DEVDES=GEURO
 If [F:TCU]CUR<>DEVORG
     Read [TCU]TCU0=DEVORG
     If fstat STAT=2 : End Endif
 Endif
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
  # Devise "in" vers Euro
  If [F:TCU]EURRAT=0
   COURS=1 : STAT=1
  Else
   COURS=1/[F:TCU]EURRAT
  Endif
 Else
  # Devise "out" vers Euro
  DEV1=GEURO : DEV2=DEVORG : Gosub COURS
 Endif
Else
 If [F:TCU]CUR<>DEVORG
     Read [TCU]TCU0=DEVORG
     If fstat STAT=2 : End Endif
 Endif
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
  EUR1=[F:TCU]EURFLG
 Else
  EUR1=1
 Endif
 EURT1=[F:TCU]EURRAT
 If [F:TCU]CUR<>DEVDES
     Read [TCU]TCU0=DEVDES
     If fstat STAT=3 : End Endif
 Endif
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
  EUR2=[F:TCU]EURFLG
 Else
  EUR2=1
 Endif
 EURT2=[F:TCU]EURRAT
 If EUR1=2 & EUR2=2
  # Devise "in" vers devise "in"
  If EURT1=0 | EURT2=0
   COURS=1 : STAT=1
  Else
   COURS=EURT2/EURT1
  Endif
 Elsif EUR1=2
  # Devise "in" vers devise "out"
  DEV1=DEVDES : DEV2=GEURO : Gosub COURS
  If EURT1=0
   COURS=1 : STAT=1
  Else
   COURS=COURS/EURT1
  Endif
 Elsif EUR2=2
  # Devise "out" vers devise "in"
  DEV1=GEURO : DEV2=DEVORG : Gosub COURS
  If EURT2=0
   COURS=1 : STAT=1
  Else
   COURS=COURS*EURT2
  Endif
 Else
  # Devise "out" vers devise "out"
  DEV1=DEVDES : DEV2=DEVORG : Gosub COURS
  If STAT<>0
   # Y'a pas de cours direct, on passe l'euro pour l'europe
   STAT=0
   If FLEURO
    NO_CUR_RAT = 1
    DEV1=GEURO : DEV2=DEVORG : Gosub COURS
    If STAT=0
     COURS1=COURS
     DEV1=DEVDES : DEV2=GEURO : Gosub COURS
     If STAT=0
      COURS=COURS1*COURS
     Endif
    Endif
   Endif
  Endif
 Endif
Endif
End

#####################################################################
Subprog COURMNT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,COURS,STAT)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise de destination
Value    Char    DEVSOC           : # Devise de référentiel général principal
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Integer ARODEC           : # Arrondi
Value    Decimal MTORG            : # Montant origine
Variable Decimal MTDES            : # Montant destination
Value    Decimal COURS            : # Cours devise -> destination eventuelt donné
Variable Integer STAT             : # Status de retour (0 = OK)

Local  Decimal AMTINT             : # Montant intermédiaire
Local  Integer ORGFLG, DESFLG     : # Flags monnaies origine et destination
Local  Decimal ARRONDI
Local  Integer I

# Recherche de l'arrondi
If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif
If [F:TCU]CUR<>DEVDES
   Read [TCU]TCU0=DEVDES : If fstat  Raz [F:TCU] : Endif
Endif
#-- Si ARODEC > 1 : Arrondi forcé avec le nombre de décimales
#-- Si ARODEC = 0 : Aucun Arrondi
#-- Sinon l'arrondi est récupéré sous le paramètrage de la devise
If int(ARODEC)>1
 ARRONDI = 10^(-ARODEC)
Elsif ARODEC=0
 ARRONDI = 0
Else
 ARRONDI = [F:TCU]CURRND
Endif

STAT=0
If DEVORG="" | DEVDES=""
 # Devise inexistante
 Call ECR_TRACE(mess(151,105,1),1) From GESECRAN : STAT=1
 End
Endif
ORGFLG=1 : DESFLG=1
#----- Partie modifiée par MBT pour un fonctionnement avec un contexte sans globale -----#
# Issue 74775 - 2011-07-07 by VPO : Pour perf, on passe par une 2eme classe F
# ssi la classe [F:TCU0] existe pour ne pas avoir d'effet de bord en migration
If clalev([F:TCU0])=0
  If [F:TCU]CUR<>DEVORG
       Read  [TCU] TCU0=DEVORG : If fstat  Raz [F:TCU] : Endif
  Endif
  If [F:TCU]CUR<>"" & [F:TCU]EURFLG=2  ORGFLG=2 : Endif
Else
  If [F:TCU0]CUR<>DEVORG
    If [F:TCU]CUR=DEVORG
       [F:TCU0]=[F:TCU]
    Else
       Read  [TCU0] TCU0=DEVORG : If fstat  Raz [F:TCU0] : Endif
    Endif
  Endif
  If [F:TCU0]CUR<>"" & [F:TCU0]EURFLG=2  ORGFLG=2 : Endif
Endif

If [F:TCU]CUR<>DEVDES
  Read  [TCU] TCU0=DEVDES : If fstat  Raz [F:TCU] : Endif
Endif
If [F:TCU]CUR<>"" & [F:TCU]EURFLG=2  DESFLG=2 : Endif
#-----
#I = find(DEVORG, GDEVISE(1..GNBDEV))
#If GDEVDAT(I) <= DATCOURS : ORGFLG = 2 : Endif   : # Si devise 'Out', GDEVDAT=31/12/9999
#I = find(DEVDES, GDEVISE(1..GNBDEV))
#If GDEVDAT(I) <= DATCOURS : DESFLG = 2 : Endif
#-----

If COURS<>0
 If ORGFLG=1
  #-------- 'Out' --> 'Out'
  If DESFLG=1
   MTDES = arr(MTORG*COURS, ARRONDI)
  Else
   #-------- 'Out' --> 'In'
   If DEVDES = GEURO
    MTDES = arr(MTORG*COURS, ARRONDI)
   Else      : # Si on a un cours, c'est celui de l'Euro
    AMTINT = arr(MTORG*COURS, 10^(-GAROEURO))
    Case ARODEC
     When 0  : Call CONVERT2(GEURO,DEVDES,DEVSOC,TYPCOURS,DATCOURS,AMTINT,MTDES,STAT) From TRTDEV
     When 1  : Call CONVERT(GEURO,DEVDES,DEVSOC,TYPCOURS,DATCOURS,AMTINT,MTDES,STAT) From TRTDEV
     When Default : Call CONVERT3(GEURO,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,AMTINT,MTDES,STAT) From TRTDEV
    Endcase
   Endif
  Endif
 Else
  If DESFLG=1
   #-------- 'In' --> 'Out'
   If DEVORG=GEURO
    MTDES = arr(MTORG*COURS, ARRONDI)
   Else
    Case ARODEC
     When 0  : Call CONVERT2(DEVORG,GEURO,DEVSOC,TYPCOURS,DATCOURS,MTORG,AMTINT,STAT) From TRTDEV
     When 1  : Call CONVERT(DEVORG,GEURO,DEVSOC,TYPCOURS,DATCOURS,MTORG,AMTINT,STAT) From TRTDEV
     When Default : Call CONVERT3(DEVORG,GEURO,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,AMTINT,STAT) From TRTDEV
    Endcase
    MTDES = arr(AMTINT*COURS, ARRONDI)
   Endif
  Else
  #-------- 'In' --> 'In'  : # si cours renseigné, on n'en tient pas compte
   Case ARODEC
    When 0  : Call CONVERT2(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV
    When 1  : Call CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV
    When Default : Call CONVERT3(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT) From TRTDEV
   Endcase
  Endif
 Endif
Else
 Case ARODEC
  When 0  : Call CONVERT2(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV
  When 1  : Call CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV
  When Default : Call CONVERT3(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT) From TRTDEV
 Endcase
Endif
End


#################################################################################
## Contrôle de saisie devise, euro et date de fin
#################################################################################
Subprog CONTDEV(DEVISE,DAT)
Value Char DEVISE
Value Date DAT
Local Integer OK
If clalev([F:TCU])=0 : Local File TABCUR  [TCU] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
If [F:TCU]CUR<>DEVISE
    Read [TCU]TCU0=DEVISE
    If fstat : End : Endif
Endif
If [F:AUS]USR<>GUSER
    Read [AUS]CODUSR=GUSER
    If fstat : End : Endif
Endif
# Date de validité
If [F:TCU]CURENDDAT<>[0/0/0] & DAT>=[F:TCU]CURENDDAT
 mkstat = 2 : GMESSAGE = DEVISE-":"-mess(96,107,1)-format$("D:"+GFMDAT4,[F:TCU]CURENDDAT)
 # Devise non valide à cette date
 End
Endif
# Contrôle utilisateur
If DEVISE = GEURO : End : Endif : # Perf CP 08/07
Local Char LEURDAT(10), LEURDAC(3)
Local Date DEURDAT
Call PARAMUTIL("SAIDEVISE",LEURDAC,"","") From SUBAUS
Call PARAMUTIL("DATDEBCTR",LEURDAT,"","") From SUBAUS
If LEURDAT<>""
 DEURDAT = LEURDAT
 If DEURDAT<>[0/0/0] & datesyst>DEURDAT
  If [F:TCU]EURFLG=2 & DEVISE<>GEURO
   If val(LEURDAC)<>2
    mkstat = 2 : GMESSAGE = mess(94,107,1) : # Saisie en devise in interdite
    End
   Elsif (GPROGRAMME="GOBJSUB"
&       & find(GABREV,"GAS","GAF","BIC","BIS","PAY","CMM","LOT","PIH","FAS","BUP","FRM","PAB",
&                     "SQH","SOH","SOR","SDH","SIH","PPD","PSH","POI","POH","POC"))
&       | find(left$(GFONCTION,6),"SUBHLN","BUDDET","BUDNAT","BUDSEC","PAYPRO")
    OK = 2 : Call AVERTIR(mess(95,107,1),OK) From GESECRAN  :# Attention saisie en devise in
    If OK<>2 : mkstat = 2 : End : Endif
   Endif
  Endif
 Endif
Endif
End

