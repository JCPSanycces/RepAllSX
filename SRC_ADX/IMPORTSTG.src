#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################################
# Modification :
#     SEGAY -  - 13/06/12 - EXI 81085 US 460
#     Remplacement fiche ORGANISME par ORGFINTRA (table ORGFINTRA)
######################################################################################

Call IMPORTATION("CATALOGUE") From GIMPOBJ
End

###################################################################################
$ACTION

  Case ACTION
    When "OUVRE"     : Gosub OUVRE
    When "RAZCRE"    : Gosub RAZCRE
    When "SAIMSK"    : Gosub SAIMSK
    When "VALID"     : Gosub VALID
  Endcase
Return


###################################################################################
$OUVRE

  Local Mask STG0   [STG0],   STG1   [STG1],   STG2   [STG2],   STG3   [STG3],   STG4   [STG4],   STG5   [STG5]
  Local Mask HRSES0 [HRSES0], HRSES1 [HRSES1], HRSES2 [HRSES2], HRSES3 [HRSES3], HRSES4 [HRSES4], HRSES5 [HRSES5], HRSES6 [HRSES6]

  If clalev([F:STG])=0   : Local File STAGE    [STG]   : Endif
  If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
  If clalev([F:HRSTR])=0 : Local File STAGETRG [HRSTR] : Endif
  If clalev([F:BCB])=0   : Local File BCLOB    [BCB]   : Endif
#     SEGAY -  - 13/06/12 - EXI 81085 US 460
#  If clalev([F:ORG])=0   : Local File ORGANISME [ORG]  : Endif
  If clalev([F:OFT])=0   : Local File ORGFINTRA [OFT]  : Endif

  nolign=0
Return

###################################################################################
$RAZCRE

  #Initialisation des masks et des variables
  Raz [M:STG0],   [M:STG1],   [M:STG2],   [M:STG3],   [M:STG4],   [M:STG5]
  Raz [M:HRSES0], [M:HRSES1], [M:HRSES2], [M:HRSES3], [M:HRSES4], [M:HRSES5], [M:HRSES6]
  nolign=0
Return

Subprog CREATE_ADI(NUMTAB, CODE)
Value Integer NUMTAB
Value Char    CODE

  Readlock [F:ADI]CODE=NUMTAB;CODE
  If fstat>1 Then
    [F:ADI]NUMTAB = NUMTAB
    [F:ADI]CODE   = CODE
    Write [F:ADI]
  Endif
  If fstat
    GOK=0 : Call FSTA("ADI") From GLOCK : End
  Endif
End

Subprog CREATE_ORG(CODE,DES)
Value Char    CODE,DES
#     SEGAY -  - 13/06/12 - EXI 81085 US 460
#  If clalev([F:ORG])=0 : Local File ORGANISME [ORG] : Endif
  If clalev([F:OFT])=0 : Local File ORGFINTRA [OFT] : Endif
  Readlock [F:OFT]OFT0=CODE
  If fstat>1 Then
    [F:OFT]COD  = CODE
    [F:OFT]DES  = DES
    [F:OFT]TYP    = 1 # SEGAY 19/04/12 81651
    [F:OFT]ENAFLG = 2 # SEGAY 19/04/12 81651
    Write [F:OFT]
  Endif
  If fstat
    GOK=0 : Call FSTA("OFT") From GLOCK : End
  Endif
End

###################################################################################
$SAIMSK
Local Integer I

  #Affectation des masks
  Case IMPFIC
    When "STG"
      nolign = 1
      [M:STG0]  = [F:STG]
      [M:STG1]  = [F:STG]
      [M:STG2]  = [F:STG]
      [M:STG3]  = [F:STG]
      [M:STG4]  = [F:STG]
      [M:STG5]  = [F:STG]
      # Création du domaine s'il n'existe pas
      If [F:STG]DOM<>""    Then Call CREATE_ADI(10381, [F:STG]DOM)       : Endif
      # Création du thème s'il n'existe pas
      If [F:STG]THM<>""    Then Call CREATE_ADI(10457, [F:STG]THM)       : Endif
      # Création de la cible si elle n'existe pas
      If [F:STG]CATTRG<>"" Then Call CREATE_ADI(10453, [F:STG]CATTRG)    : Endif
      # Création du niveau s'il n'existe pas
      If [F:STG]LEVEXM<>"" Then Call CREATE_ADI(10382, [F:STG]LEVEXM)    : Endif
      # Création de la ressource si elle n'existe pas
      For I=0 To dim([F:STG]RSCNEC)-1
        If [F:STG]RSCNEC(I)<>"" Then Call CREATE_ADI(10455, [F:STG]RSCNEC(I))    : Endif
      Next

    # Organisme
#     SEGAY -  - 13/06/12 - EXI 81085 US 460
    When "OFT" : # FQ79504 - MABON 23/01/11 - Création organisme
      [M:HRSES1] = [F:OFT]
      # Création de l'organisme s'il n'existe pas
      If [F:STG]ORG<>""    Then Call CREATE_ORG([F:OFT]COD,[F:OFT]DES)  : Endif

    #Session
    When "HRSES"
      [M:HRSES0] = [F:HRSES]
      [M:HRSES1] = [F:HRSES]
      [M:HRSES2] = [F:HRSES]
      [M:HRSES3] = [F:HRSES]
      [M:HRSES4] = [F:HRSES]
      [M:HRSES5] = [F:HRSES]
      [M:HRSES6] = [F:HRSES]
      # Création du domaine s'il n'existe pas
      If [F:HRSES]DOM<>""    Then Call CREATE_ADI(10381, [F:HRSES]DOM)       : Endif
      # Création du thème s'il n'existe pas
      If [F:HRSES]THM<>""    Then Call CREATE_ADI(10457, [F:HRSES]THM)       : Endif
      # Création de la ressource si elle n'existe pas
      For I=0 To dim([F:HRSES]RSCNEC)-1
        If [F:HRSES]RSCNEC(I)<>"" Then Call CREATE_ADI(10455, [F:HRSES]RSCNEC(I)) : Endif
      Next
      # Création de l'action suivi si elle n'existe pas
      For I=0 To dim([F:HRSES]SUIACN)-1
        If [F:HRSES]SUIACN(I)<>"" Then Call CREATE_ADI(10468, [F:HRSES]SUIACN(I)) : Endif
      Next
      # FQ83519 - MABON 13/07/12 - Récupération formateur externe et organisme
      If [M:HRSES0]STG<>"" & ([M:HRSES1]TCHNAM="" | [M:HRSES1]ORG="") Then
        Read [F:STG]STG0=[M:HRSES0]STG
        If !fstat Then
          If [F:STG]TCHNAM<>"" Then [M:HRSES1]TCHNAM=[F:STG]TCHNAM : Endif
          If [F:STG]ORG<>""    Then [M:HRSES1]ORG=[F:STG]ORG       : Endif
        Endif
      Endif
      # Fin MABON
      Readlock [F:HRSES]SES0=[M:HRSES0]COD
      If fstat>1
        Gosub AFFECT_SES
#        SEGAY 20/04/12 bug 78896
        Local Decimal VALHMDEB, VALHMFIN
        Gosub MOD_JOURS From SUBSTG
#        END bug 78896
        Write [F:HRSES]
      Elsif !fstat & [M:AOE1]OPTUPD=2
        Gosub AFFECT_SES
#        SEGAY 20/04/12  bug 78896
        Gosub MOD_JOURS From SUBSTG
#        END bug 78896
        Rewrite [F:HRSES]
      Endif
      If fstat
        GOK=0 : Call FSTA("HRSES") From GLOCK : Return
      Endif

    #Cibles
    When "STR"
      [M:STG2] = [F:HRSTR]

    #Clob
    When "BCB"
      [M:STG1]    = [F:BCB]
      [M:STG1]CMT = [F:BCB]CLOB
  Endcase
Return

###################################################################################
$VALID

  GOK=1
  If nolign=0 : Return : Endif
  If GOK=0 : GERREUR=1 : Return : Endif

  Call DEBTRANS From GLOCK
  Gosub TR1
  If GOK<0 : GERREUR=1 : Goto AB_TR1 : Endif
Return

#######################################################################################
#                ENREGISTREMENT DES DONNEES DANS LES TABLES
#######################################################################################
$TR1

  Trbegin [STG], [HRSES], [HRSTR]

  Readlock [F:STG]STG0=[M:STG0]COD
  If fstat>1
    Gosub AFFECT_STG
    If dim([F:STG]CREDAT)>0 : [F:STG]CREDAT = date$ : Endif
    If dim([F:STG]CREUSR)>0 : [F:STG]CREUSR = GUSER : Endif
    If dim([F:STG]CRETIM)>0 : [F:STG]CRETIM = time  : Endif
    If dim([F:STG]EXPNUM)>0 : [F:STG]EXPNUM = [C]EXPORT : Endif
    Write [F:STG]
    Call TRACE(0,mess(33,10717,1)-[M:STG0]COD) From SUBIMPOBJ
  Elsif !fstat & [M:AOE1]OPTUPD=2
    Gosub AFFECT_STG
    If dim([F:STG]UPDDAT)>0 : [F:STG]UPDDAT = date$ : Endif
    If dim([F:STG]UPDUSR)>0 : [F:STG]UPDUSR = GUSER : Endif
    If dim([F:STG]UPDTIM)>0 : [F:STG]UPDTIM = time  : Endif
    Rewrite [F:STG]
    Call TRACE(1,mess(33,10717,1)-[M:STG0]COD) From SUBIMPOBJ
  Endif
  If fstat
    GOK=0 : Call FSTA("STG") From GLOCK : Return
  Endif

  Readlock [F:HRSTR]STR0=[M:STG0]COD
  If fstat=5
    Gosub AFFECT_STR
    Write [F:HRSTR]
  Elsif !fstat & [M:AOE1]OPTUPD=2
    Gosub AFFECT_STR
    Rewrite [F:HRSTR]
  Endif
  If fstat
    GOK=0 : Call FSTA("HRSTR") From GLOCK : Return
  Endif

  Readlock [F:BCB]BCB0="SUBSTG";[M:STG0]COD
  If fstat=5
    Gosub AFFECT_BCB
    Write [F:BCB]
  Elsif !fstat & [M:AOE1]OPTUPD=2
    Gosub AFFECT_BCB
    Rewrite [F:BCB]
  Endif
  If fstat
    GOK=0 : Call FSTA("BCB") From GLOCK : Return
  Endif

  Commit
Return

#########################
$AFFECT_STG

  Raz [F:STG]
  Call CALL_INIML1 From SUBSTG #FQ93180  - Initialisation ML1 <> 0
  [F:STG]=[M:STG0]
  [F:STG]=[M:STG1]
  [F:STG]=[M:STG2]
  [F:STG]=[M:STG3]
  [F:STG]=[M:STG4]
  [F:STG]=[M:STG5]
Return

#########################
$AFFECT_SES

  Raz [F:HRSES]
  [F:HRSES]=[M:HRSES0]
  [F:HRSES]=[M:HRSES1]
  [F:HRSES]=[M:HRSES2]
  [F:HRSES]=[M:HRSES3]
  [F:HRSES]=[M:HRSES4]
  [F:HRSES]=[M:HRSES5]
  [F:HRSES]=[M:HRSES6]
Return

#########################
$AFFECT_STR

  Raz [F:HRSTR]
  [F:HRSTR]=[M:STG2]
  [F:HRSTR]COD=[M:STG0]COD
Return

#########################
$AFFECT_BCB

  Raz [F:BCB]
  [F:BCB]=[M:STG1]
  [F:BCB]CODBLB = "SUBSTG"
  [F:BCB]IDENT1 = [M:STG0]COD
  [F:BCB]CLOB   = [M:STG1]CMT
Return

#########################
$AB_TR1
Rollback
#Rollback suite à erreur dans la transaction
Call TRACE(2,mess(17,107,1)) From SUBIMPOBJ
Return
