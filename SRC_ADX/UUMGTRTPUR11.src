#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
# UUMGTRTPUR11  Migration des expéditions : SHIPMENT et SHIPMENTD  Module PUR  #
#            Mise à  jour poids et volume                                      #
################################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR11") From LECFIC
  Endif

  #Call RAZ_UUMGTRTPUR11(DOSSIER)

  Call MAJ_UUMGTRTPUR11(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##########################################################################
Subprog RAZ_UUMGTRTPUR11(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################
If [F:ADS]MODULE(5)<>2 : End : Endif          : # N= no module

Local Char WNAMSHHM,WNAMSHDM
Call MIGTABNAME (DOSSIER,"SHIPMENT",WNAMSHHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SHIPMENTD",WNAMSHDM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMSHHM,"fde",[F:ADS]DOSSIER),0) < 0 :  End : Endif
If filinfo(filpath("FIL",WNAMSHDM,"fde",[F:ADS]DOSSIER),0) < 0 :  End : Endif




##2 - On vide les fichiers selon le cas
#######################################

Call MIGTABRAZ (DOSSIER,"SHIPMENT",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"SHIPMENTD",ERR) From TRTMIG

##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR11",ERR) From TRTMIG

End

##########################################################################
##########################################################################
##########################################################################
Subprog MAJ_UUMGTRTPUR11(DOSSIER)
Value Char DOSSIER

Local Integer ERR

Gosub MIG_OUVRE From TRTMIG

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR11",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

Local Char WNAMSHHM,WNAMSHDM
Call MIGTABNAME (DOSSIER,"SHIPMENT",WNAMSHHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SHIPMENTD",WNAMSHDM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR11",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMSHHM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR11",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

If filinfo(filpath("FIL",WNAMSHDM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR11",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR11",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR11",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

###################


Local Char WTAB_SHH (100) (adxwrb)

Local Char WTAB_SHD (100) (adxwrb)
Local Shortint WCPT_SHH,WCPT_SHD


Call ECR_TIME("UUMGTRTPUR11 tables SHH Process : Update SHH") From DOSSUB
Call ECR_TRACE("UUMGTRTPUR11 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Call MIGTABINIT (DOSSIER,"SHIPMENT",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"SHIPMENTD",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:SHH])  = 0 : Local File =DOSSIER+".SHIPMENT"    [SHH]  : Endif   # Fichier X3 "Vide"
If clalev([F:SHD])  = 0 : Local File =DOSSIER+".SHIPMENTD"    [SHD]  : Endif   # Fichier X3 "Vide"

If clalev([F:SHHM]) = 0 : Local File =DOSSIER+"."+WNAMSHHM   [SHHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:SHDM]) = 0 : Local File =DOSSIER+"."+WNAMSHDM   [SHDM] : Endif   # Fichier X3 renommé Avant Migration

Local File =[F:ADS]DOSSIER+".CONTAINER"    [CTRH]
Local File =[F:ADS]DOSSIER+".TABCONTAINER"    [TCTR]
Local File =[F:ADS]DOSSIER+".PORDERQ"    [POQ]

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBCOMMIT, NBLUS
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=4
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE,NBCOMMIT
Local Char SAVCTRNUM(GLONVCR)

# Déclaration des variables communes de travail
Local Integer I, J
Local Integer WNBRECEPT,WNBPRECEPT,WNBCREE, LVCRTYP,WNBSOLDE  # Issue 15175

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTPUR11",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  Lien des tables entête & lignes -----#
Link [SHDM] With [SHHM]SHH0~=[F:SHDM]SHIPNUM
&    As [LNK]
&    Order By Key CLE = [F:SHHM]SHIPNUM

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTPUR11" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_SHH00
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:SHHM]SHIPNUM=TABMIGKEY(1) "
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:SHHM]SHIPNUM=TABMIGKEY(1) "
Elsif STOP=3
 STOP = 0
 CRITERE = "[F:SHHM]SHIPNUM>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [SHH],[SHD]
GOK = 1

For [LNK]CLE(1) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTPUR11" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

   # version < V11, raz des champs v11
  If val(VERSION)<GMIGX3VER110
      Gosub RAZV11_SHH
  Endif

  [F:SHH] = [F:SHHM]

  #Appel proc de migration sur entete
  # Passage en V11
  If val(VERSION)<GMIGX3VER110
    Gosub MAJV11_SHH
    If GOK<1 : Break : Endif
  Endif

   # Issue 15175 - 2016-12-07 by MAE
  # Passage en V12
  If val(VERSION)<GMIGX3VER120
    Gosub MAJV12_SHH
    If GOK<1 : Break : Endif
  Endif

  ############################
  #-- Boucle sur les lignes
  ############################
  For [LNK]CLE
    #rupture par ligne
    # version < V11, raz des champs v11
    If val(VERSION)<GMIGX3VER110
        Gosub RAZV11_SHD
    Endif

    [F:SHD] = [F:SHDM]

    #Appel proc de migration sur detail
    # Passage en V11
    If val(VERSION)<GMIGX3VER110
      Gosub MAJV11_SHD
      If GOK<1 : Break : Endif
    Endif
    # Issue 15175 - 2016-12-07 by MAE
    # Passage en V12
    If val(VERSION)<GMIGX3VER120
      Gosub MAJV12_SHD
      If GOK<1 : Break : Endif
    Endif

    # --- écriture enreg
    Gosub SHD_STK : # pour stocker ref
    WriteB [SHD]
    If fstat
        Call ECR_TRACE("File SHIPMENTD, Error ="-num$(fstat),1) From GESECRAN
        Gosub SHD_ERRTRA : # pour afficher les ref
        GOK=0 : Break
    Endif
  Next

  If GOK<1 : Break : Endif

  #Appel proc de migration sur entete arpès boucle sur les détails
  # Passage en V11
  If val(VERSION)<GMIGX3VER110
    Gosub MAJV11_SHH_SUITE
    If GOK<1 : Break : Endif
  Endif
  # Issue 15175 - 2016-12-07 by MAE
  # Passage en V12
  If val(VERSION)<GMIGX3VER120
    Gosub MAJV12_SHH_SUITE
    If GOK<1 : Break : Endif
  Endif


  # --- écriture enreg
  Gosub SHH_STK : # pour stocker ref
  WriteB [F:SHH]
  If fstat
    Call ECR_TRACE("File SHIPMENT, Error ="-num$(fstat),1) From GESECRAN
    Gosub SHH_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:SHHM]SHIPNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR11",7,ERR) From TRTMIG : #7=Erreur
Else
  Flush [F:SHH]
  If fstat
      Call ECR_TRACE("File SHIPMENT, Error ="-num$(fstat),1) From GESECRAN
      Gosub SHH_ERRTRA : # pour afficher les ref
      GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
  Endif
  Flush [F:SHD]
  If fstat
      Call ECR_TRACE("File SHIPMENTD, Error ="-num$(fstat),1) From GESECRAN
      Gosub SHD_ERRTRA : # pour afficher les ref
      GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
  Endif
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTPUR11",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTPUR11",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_SHH00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [SHH], [SHD]
Close Local File [SHHM], [SHDM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"SHIPMENT",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"SHIPMENTD",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTPUR11") From TRTMIG
Call ECR_TIME("UUMGTRTPUR11 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


################################################
$SHH_STK
Call STK (WTAB_SHH,WCPT_SHH,[F:SHH]SHIPNUM) From TRTMIG
Return
$SHD_STK
Call STK (WTAB_SHD,WCPT_SHD,[F:SHD]SHIPNUM-'/'-num$([F:SHD]SHIPLIN)) From TRTMIG
Return
##############################################################################################
$SHH_ERRTRA
Call ERRTRA (WTAB_SHH,WCPT_SHH,"File SHIPMENT(SHIPNUM)=") From TRTMIG
Return
$SHD_ERRTRA
Call ERRTRA (WTAB_SHD,WCPT_SHD,"File SHIPMENTD(SHIPNUM/SHIPLIN)=") From TRTMIG
Return

########################################################################
# Migration entete                                                     #
########################################################################
$RAZV11_SHH
Raz [F:SHH]CRRWEI
Raz [F:SHH]CRRVOL
Raz [F:SHH]AVAWEI
Raz [F:SHH]AVAVOL
Return

$MAJV11_SHH
If [F:SHH]TRNNUM <> AVOID.ACHAR & [F:SHH]BPRNUM <> AVOID.ACHAR
  [F:SHH]BPRNUM = AVOID.ACHAR
Endif
Return

$MAJV11_SHH_SUITE

Return
########################################################################
# Issue 15175 - 2016-12-07 by MAE
$MAJV12_SHH
WNBRECEPT=0:WNBPRECEPT=0:WNBCREE=0:WNBSOLDE=0
Return
########################################################################
$MAJV12_SHH_SUITE
If WNBCREE > 0  : [F:SHH]SHIPSTAT = 1
Elsif WNBPRECEPT > 0 : [F:SHH]SHIPSTAT = 3
Elsif WNBRECEPT > 0 : [F:SHH]SHIPSTAT = 4
Elsif WNBSOLDE >0 : [F:SHH]SHIPSTAT = 5
Endif
Return
# End issue 15175

# Migration détail                                                     #
########################################################################

$RAZV11_SHD
Return

$MAJV11_SHD
If [F:SHD]CTRNUM <> AVOID.ACHAR & [F:SHD]CTRNUM <> SAVCTRNUM
  Read [CTRH] CTRH0=[F:SHD]CTRNUM
  If !fstat
    Read [TCTR] TCTR0=[F:CTRH]TCTRNUM
    If fstat Raz[F:TCTR] : Endif
  Endif
  #mise à jour de l'unité de poids : DSPWE
  If [F:SHH]DSPWEU = AVOID.ACHAR
    [F:SHH]DSPWEU = [F:TCTR]WEU
  Endif
  #mise à jour de l'unité de volume : DSPVOU
  If [F:SHH]DSPVOU = AVOID.ACHAR
    [F:SHH]DSPVOU = [F:TCTR]VOU
  Endif
  #mise à jour du poids total : CRRWEI
  WQTYWEU = [F:CTRH]CRRWEI
  Call CONVERT_QTY([F:CTRH]DSPWEU,[F:SHH]DSPWEU,WQTYWEU)From TRTX3
  [F:SHH]CRRWEI += WQTYWEU
  #mise à jour du volume total : CRRVOL
  WQTYVOU = [F:TCTR]TCTRVOL
  Call CONVERT_QTY([F:TCTR]VOU,[F:SHH]DSPVOU,WQTYVOU)From TRTX3
  [F:SHH]CRRVOL += WQTYVOU
  #mise à jour du type de gestion en "Multiconteneur"
  [F:SHH]SHIPMGT = 2
  #
  SAVCTRNUM = [F:SHD]CTRNUM
Elsif [F:SHD]CTRNUM = AVOID.ACHAR
  #lecture de la commande
  If [F:POQ]POHNUM <> [F:SHD]POHNUM
    Read [POQ] POQ0=[F:SHD]POHNUM;[F:SHD]POPLIN;[F:SHD]POQSEQ
    If fstat Raz[F:POQ] Endif
  Endif
  #mise à jour de l'unité de poids : DSPWEU
  If [F:SHH]DSPWEU = AVOID.ACHAR
    [F:SHH]DSPWEU = [F:POQ]LINWEU
  Endif
  #mise à jour de l'unité de volume : DSPVOU
  If [F:SHH]DSPVOU = AVOID.ACHAR
    [F:SHH]DSPVOU = [F:POQ]LINVOU
  Endif
  #mise à jour du poids total : CRRWEI
  WQTYWEU = [F:SHD]QTYWEU
  Call CONVERT_QTY([F:SHD]LINWEU,[F:SHH]DSPWEU,WQTYWEU)From TRTX3
  [F:SHH]CRRWEI += WQTYWEU
  #mise à jour du volume total : CRRVOL
  WQTYVOU = [F:SHD]QTYVOU
  Call CONVERT_QTY([F:SHD]LINVOU,[F:SHH]DSPVOU,WQTYVOU)From TRTX3
  [F:SHH]CRRVOL += WQTYVOU
  #mise à jour du type de gestion en "Ligne de commande"
  [F:SHH]SHIPMGT = 1

Endif
# Issue 120493 - 2016-12-20 by MAE : Mise à jour de PRCPFLG
If [F:SHD]PRCPQTY <> 0
  [F:SHD]PRCPFLG = 2
Else
  [F:SHD]PRCPFLG = 1
Endif
Return
########################################################################
# Issue 15175 - 2016-12-07 by MAE
$MAJV12_SHD
If ([F:SHD]CLEFLG = 2)
      WNBSOLDE += 1
Elsif ([F:SHD]RCPQTYPUU=[F:SHD]SHIQTYPUU) #receptionné
      WNBRECEPT += 1
Elsif ([F:SHD]PRCPFLG=2)  #pre receptionné
      WNBPRECEPT += 1
Else
      WNBCREE += 1
Endif

Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
#on charge [F:ADS]
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

Call MAJ_UUMGTRTPUR11(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
#on sait qu'on a déjà [F:ADS]
Call MAJ_UUMGTRTPUR11(APPLI)
End

