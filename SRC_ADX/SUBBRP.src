#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion du masque BODRPL0
#####################################################################
# Fenêtre de changement de n° de séquence nomenclature TB mars 2000 #
#####################################################################
Subprog C_NEWSEQ(VALEUR)
Variable Decimal VALEUR
Local    Char    CONC
# faire le controle d'unicité seulement
CONC = num$(VALEUR) + [M:BOD1]CPNITMREF(nolign-1)
Call UNICITE(CONC,[M:BOD1]CONCATKEY(0..[M:BOD1]NBLIG-1)) From OBJDIV
If mkstat = 2 : End : Endif 

# comparer à un éventuel enregistrement non visible
If [M:BOH0]DATREF <> [0/0/0]
   Read [BOD]BOD0=[M:BOH0]ITMREF;[M:BOH0]BOMALT;VALEUR;[M:BOD1]CPNITMREF(nolign-1);[M:BOH0]BOMALTTYP
   If !fstat  mkstat = 2 : GMESSAGE = mess(50,199,1) : End : Endif
Endif
End

# GA 23/11/2005 idem sur les sequences opérations de nomenclature de sous-traitance
Subprog C_NEWSEQS(VALEUR)
Variable Decimal VALEUR
Local    Char    CONC
# faire le controle d'unicité seulement
CONC = num$(VALEUR) + [M:BOS2]CPNITMREF(nolign-1)
Call UNICITE(CONC,[M:BOS2]CONCATKEY(0..[M:BOS2]NBLIG-1)) From OBJDIV
If mkstat = 2 : End : Endif 

# comparer à un éventuel enregistrement non visible
If [M:BOH0]DATREF <> [0/0/0]
   Read [BOD]BOD0=[M:BOH0]ITMREF;[M:BOH0]BOMALT;VALEUR;[M:BOS2]CPNITMREF(nolign-1);[M:BOH0]BOMALTTYP
   If !fstat  mkstat = 2 : GMESSAGE = mess(50,199,1) : End : Endif
Endif
End
