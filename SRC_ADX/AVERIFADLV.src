#<AdxTL>@(#)7.0.0.0 $Revision$
###########################################################################################
#  controle des livrables actifs
#  action a lancer en batch 
###########################################################################################
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AVERIFADLV","",2,"") From GTRAITE

End
##################################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "AVANT_PAR"   : TIT = mess(54,7999,1)
 When "EXEC"        : Gosub EXEC
Endcase
Return

##################################################################
$INIT
Return

##################################################################
$EXEC
Local Integer WOK
WOK = 0

Local Integer WTYPE
WTYPE = 1
# verif cohérence tous livrables actifs
Call CHECK_ALL_ADLV (WOK,WTYPE) From SUBADLV
Return


