#<AdxTL>@(#)10.0.0.0 $Revision$
##################################################################################################
# SUBTGLB    Dictionnaire des cibles                    Module CRM                15 mars 2002   #
#                                                                                                #
# Sous-programmes utilitaires                                                                    #
##################################################################################################
#                                                                                                #
# SETTABSRT : Définie si le champ table de tri est grisé ou non.                                 #
# LOADFIE   : Charge une description des champs.                                                 #
# LOADSRT   : Charge une description des informations de tri.                                    #       
# SAVEFIE   : Enregistre une description des champs.                                             #
# LOADLNK   : Charge une description des tables liées.                                           #
# SAVELNK   : Enregistre une description des tables liées.                                       #
# CRESSP3   : Crée un support de sélection de type Tous, s'il n'en existe pas pour la cible.     #
# CRESSP4   : Crée un support de type Premier niveau, s'il n'en existe pas pour la cible.        #
# CHKFIESRT : Vérifie la présence du champ de tri dans les quinzes premières lignes du tableau   #
# CRETGRDEF : Créé un support de présentation par défaut, s'il n'en existe pas.                  #
# ANALYSE   : Analyse le contenu d'une expression de lien                                        #
# ACTIVEPSS : Activation du calcul des positions                                                 #
# SETPSS    : Enregistrement de l'activation du calcul des positions                             #
#                                                                                                #
##################################################################################################

##########################################################################################################
# Définie si le champ table de tri est grisé ou non.
##################################################################################################
Subprog SETTABSRT(SZTAB)
Value Char SZTAB

Local Integer Z2
Local Integer IFOUND

  IFOUND = 0
  For Z2 = 0 To [M:TGL2]NBFIE-1 
    If [M:TGL2]TGRFIE(Z2) = [M:TGL2]FIESRT Then
     IFOUND += 1
    Endif
  Next
  If IFOUND > 1 Then
    Actzo [M:TGL2]TABSRT
  Else
    Grizo [M:TGL2]TABSRT
  Endif
  Affzo [M:TGL2]TABSRT
End

##########################################################################################################
# Charge une description des champs.
##################################################################################################
Subprog LOADFIE(SZCRITAB, SZSSPDEF)
Value Char SZCRITAB
Value Char SZSSPDEF

Local Integer INBFIE
Local Integer ITER
Local Char SZLEFTCRIFIE(GLONAVA)
Local Char SZTEXTE(GLONDCO)

  ITER = 0
  INBFIE = 0
  SZTEXTE = ""
  Raz [M:TGL2]NBFIE
  Raz [M:TGL2]TGRTABLNK
  Raz [M:TGL2]TGRFIE
  Raz [M:TGL2]TGRFIEORD
  #---------------------------------------------------#
  #On charge une description personnalisée.
  Filter [TLF] Where [F:TLF]TGRTAB = SZCRITAB and [F:TLF]TGRSSPNUM = SZSSPDEF Order By [F:TLF]TGRFIEORD Asc; [F:TLF]TGRTABLNK Asc; [F:TLF]TGRFIE Asc
  For [TLF] Hint Key TLF1
    If INBFIE >= dim([M:TGL2]TGRFIE) Then
      Break
    Endif
    [M:TGL2]TGRTABLNK(INBFIE) = [F:TLF]TGRTABLNK
    [M:TGL2]TGRFIE(INBFIE) = [F:TLF]TGRFIE
    Read [FDF]FDF0=[M:TGL2]TGRTABLNK(INBFIE);[M:TGL2]TGRFIE(INBFIE);GAUSCRMI
    If fstat Then
      Read [FDF]FDF0=[M:TGL2]TGRTABLNK(INBFIE);[M:TGL2]TGRFIE(INBFIE);""
      If fstat Then
        SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND([M:TGL2]TGRFIE(INBFIE))    # FGR 12/01/2009 : X3SUIVI51579
        Read [ATZ]CODZONE=[M:TGL2]TGRTABLNK(INBFIE);SZLEFTCRIFIE
        If fstat Then
          [M:TGL2]TGRFIENAM(INBFIE) = ""
        Else
          Call TEXTE([F:ATZ]NOLONG, SZTEXTE) From OBJDIV
          [M:TGL2]TGRFIENAM(INBFIE) = left$(SZTEXTE, GLONDCO)
        Endif
      Else
        Call LECTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
        [M:TGL2]TGRFIENAM(INBFIE) = left$(SZTEXTE, GLONDCO)
      Endif
    Else
      Call LECTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
      [M:TGL2]TGRFIENAM(INBFIE) = left$(SZTEXTE, GLONDCO)
    Endif
    [M:TGL2]TGRFIEORD(INBFIE) = [F:TLF]TGRFIEORD
    INBFIE += 1
  Next
  Filter [TLF]
  [M:TGL2]NBFIE = INBFIE
  If [M:TGL2]NBFIE > 0 Then
    Gosub UNDER15
    End
  Endif
  #---------------------------------------------------#
  #On charge à partir des critères de ciblage
  Read [FID]FID0=SZCRITAB;GAUSCRMI
  If fstat Then
    Read [FID]FID0=SZCRITAB;""
    If !fstat Then
      Filter [FDF] Where [F:FDF]CRITAB = SZCRITAB and [F:FDF]SELCRIFLG = 2 and [F:FDF]CAT = "" Order By [F:FDF]SELCRISRT Asc
      For [FDF]
        If INBFIE >= dim([M:TGL2]TGRFIE) Then
          Break
        Endif
        [M:TGL2]TGRTABLNK(INBFIE) = SZCRITAB
        [M:TGL2]TGRFIE(INBFIE) = [F:FDF]SELCRIFIE
        SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND([M:TGL2]TGRFIE(INBFIE))    # FGR 12/01/2009 : X3SUIVI51579
        Read [ATZ]CODZONE=[M:TGL2]TGRTABLNK(INBFIE);SZLEFTCRIFIE
        If fstat Then
          [M:TGL2]TGRFIENAM(INBFIE) = ""
        Else
          Call TEXTE([F:ATZ]NOLONG, SZTEXTE) From OBJDIV
          [M:TGL2]TGRFIENAM(INBFIE) = left$(SZTEXTE, 40)
        Endif
        [M:TGL2]TGRFIEORD(INBFIE) = [F:FDF]SELCRISRT
        INBFIE += 1
      Next
      Filter [FDF]
      [M:TGL2]NBFIE = INBFIE
    Endif
  Else
    Filter [FDF] Where [F:FDF]CRITAB = SZCRITAB and [F:FDF]SELCRIFLG = 2 and [F:FDF]CAT = GAUSCRMI Order By [F:FDF]SELCRISRT Asc
    For [FDF]
      If INBFIE >= dim([M:TGL2]TGRFIE) Then
        Break
      Endif
      [M:TGL2]TGRTABLNK(INBFIE) = SZCRITAB
      [M:TGL2]TGRFIE(INBFIE) = [F:FDF]SELCRIFIE
      SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND([M:TGL2]TGRFIE(INBFIE))    # FGR 12/01/2009 : X3SUIVI51579
      Read [ATZ]CODZONE=[M:TGL2]TGRTABLNK(INBFIE);SZLEFTCRIFIE
      If fstat Then
        [M:TGL2]TGRFIENAM(INBFIE) = ""
      Else
        Call TEXTE([F:ATZ]NOLONG, SZTEXTE) From OBJDIV
        [M:TGL2]TGRFIENAM(INBFIE) = left$(SZTEXTE, 40)
      Endif
      [M:TGL2]TGRFIEORD(INBFIE) = [F:FDF]SELCRISRT
      INBFIE += 1
    Next
    Filter [FDF]
    [M:TGL2]NBFIE = INBFIE
  Endif
  If [M:TGL2]NBFIE > 0 Then
    Gosub UNDER15
    End
  Endif
  #---------------------------------------------------#
  # On charge à partir de la personnalisation objet de la table.
  Read [ATB]CODFIC=SZCRITAB
  If !fstat Then
    Read [AOL]AOL0=[F:ATB]ABRFIC
    If !fstat Then
      Read [AOB]ABREV=[F:ATB]ABRFIC
      If !fstat Then
        If [F:AOB]NOMFIC = SZCRITAB
          #On charge les champs
          For ITER = 0 To dim([F:AOL]SELZON)-1
            If [F:AOL]SELZON(ITER) <> "" Then
              If [F:AOL]SELFIC(ITER) = SZCRITAB Then
                [M:TGL2]TGRTABLNK(INBFIE) = [F:AOL]SELFIC(ITER)
                [M:TGL2]TGRFIE(INBFIE) = [F:AOL]SELZON(ITER)
                SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND([M:TGL2]TGRFIE(INBFIE))    # FGR 12/01/2009 : X3SUIVI51579
                Read [ATZ]CODZONE=[M:TGL2]TGRTABLNK(INBFIE);SZLEFTCRIFIE
                If fstat Then
                  [M:TGL2]TGRFIENAM(INBFIE) = ""
                Else
                  Call TEXTE([F:ATZ]NOLONG, SZTEXTE) From OBJDIV
                  [M:TGL2]TGRFIENAM(INBFIE) = left$(SZTEXTE, 40)
                Endif
                [M:TGL2]TGRFIEORD(INBFIE) = INBFIE + 1
                INBFIE += 1    
              Endif                    
            Endif
          Next
          [M:TGL2]NBFIE = INBFIE
        Endif
      Endif
    Endif
  Endif
  If [M:TGL2]NBFIE > 0 Then
    Gosub UNDER15
    End
  Endif
  #---------------------------------------------------#
  # On charge à partir du dictionnaire des tables standards X3
  Filter [ATZ] Where [F:ATZ]CODFIC = SZCRITAB
  For [ATZ] CODZONE
    If INBFIE >= dim([M:TGL2]TGRFIE) Then
      Break
    Endif
    [M:TGL2]TGRTABLNK(INBFIE) = SZCRITAB
    [M:TGL2]TGRFIE(INBFIE) = [F:ATZ]CODZONE
    Call TEXTE([F:ATZ]NOLONG, SZTEXTE) From OBJDIV
    [M:TGL2]TGRFIENAM(INBFIE) = left$(SZTEXTE, 40)
    [M:TGL2]TGRFIEORD(INBFIE) = INBFIE + 1
    INBFIE += 1
  Next
  Filter [ATZ]
  [M:TGL2]NBFIE = INBFIE
  Gosub UNDER15
End

##########################################################################################################
#On s'assure que la champs de tri soit toujours dans les quinze premiers
################################################################################
$UNDER15
  If [M:TGL2]NBFIE > 15 Then
    For ITER = 15 To [M:TGL2]NBFIE-1
      If [M:TGL2]TGRFIE(ITER) = [M:TGL2]FIESRT Then
        [M:TGL2]TGRFIEORD(ITER) = 1
      Endif
    Next
  Endif
Return

##########################################################################################################
# Charge une description des informations de tri.
##################################################################################################
Subprog LOADSRT(SZCRITAB, SZSSPDEF)
Value Char SZCRITAB
Value Char SZSSPDEF

  Read [TGP]TGP0=SZSSPDEF
  If fstat Then
    #Erreur lors du chargement des informations de tri.
    GMESSAGE = mess(764,196,1)
    GERR = 1
  Else
    [M:TGL2]FIESRT = [F:TGP]FIESRT
    [M:TGL2]TABSRT = [F:TGP]TABSRT
    [M:TGL2]FIESRTTYP = [F:TGP]FIESRTTYP
  Endif
End

##########################################################################################################
# Enregistre une description des champs.
##################################################################################################
$SAVEFIE
Local Integer IFIEITER
Local Integer ITGLPBL

  ITGLPBL = 0
  #On efface tout et on recommence
  Filter [TLF]
  Delete [TLF] Where [F:TLF]TGRTAB=[M:TGL0]TGRTAB and [F:TLF]TGRSSPNUM=[M:TGL2]TGRSSPDEF
  If fstat Then
    ITGLPBL = 1
    GOK = 0
    Call FSTA("TLF") From GLOCK
  Endif
  If ITGLPBL Then
    Return
  Endif
  #Enregistre le tableau 1
  For IFIEITER = 0 To [M:TGL2]NBFIE-1
    If [M:TGL2]TGRTABLNK(IFIEITER) <> "" Then
      If [M:TGL2]TGRFIE(IFIEITER) <> "" Then
        [F:TLF]TGRTAB = [M:TGL0]TGRTAB
        [F:TLF]TGRSSPNUM = [M:TGL2]TGRSSPDEF
        [F:TLF]TGRTABLNK = [M:TGL2]TGRTABLNK(IFIEITER)
        [F:TLF]TGRFIE = [M:TGL2]TGRFIE(IFIEITER)
        [F:TLF]TGRFIEORD = [M:TGL2]TGRFIEORD(IFIEITER)
        [F:TLF]TGRFIESTD = 0
        Write [TLF]
        If fstat Then
          ITGLPBL = 1
          GOK = 0
          Call FSTA("TLF") From GLOCK
        Endif
      Endif
    Endif
    If ITGLPBL Then
      Break
    Endif
  Next
  If ITGLPBL Then
    Return
  Endif
  #Enregistre les informations de tri sur le support de présentation.
  Read [TGP]TGP0=[M:TGL2]TGRSSPDEF
  If !fstat Then
    [F:TGP]FIESRT = [M:TGL2]FIESRT
    [F:TGP]TABSRT = [M:TGL2]TABSRT
    [F:TGP]FIESRTTYP = [M:TGL2]FIESRTTYP
    Rewrite [TGP]
    If fstat Then
      ITGLPBL = 1
      GOK = 0
      Call FSTA("TGP") From GLOCK
    Endif
  Endif
Return

##########################################################################################################
# Charge une description des tables liées
##################################################################################################
Subprog LOADLNK(SZCRITAB)
Value Char SZCRITAB

Local Integer INBLNK
Local Integer ITER

  ITER = 0
  INBLNK = 0
  Raz [M:TGL3]NBLNK
  Raz [M:TGL3]TGRLNK
  Raz [M:TGL3]TGRLNKIDX
  Raz [M:TGL3]TGREXPLNK
  Filter [TLL] Where [F:TLL]TGRTAB = SZCRITAB
  For [TLL]
    If INBLNK >= dim([M:TGL3]TGRLNK) Then
      Break
    Endif
    [M:TGL3]TGRLNK(INBLNK) = [F:TLL]TGRLNK
    [M:TGL3]TGRLNKIDX(INBLNK) = [F:TLL]TGRLNKIDX
    [M:TGL3]TGREXPLNK(INBLNK) = [F:TLL]TGREXPLNK
    INBLNK += 1
  Next
  Filter [TLL]
  [M:TGL3]NBLNK = INBLNK
End

##########################################################################################################
# Enregistre une description des tables liées
##################################################################################################
$SAVELNK
Local Integer ILNKITER
Local Integer ILNKPBL

  ILNKPBL = 0
  #On efface tout et on recommence
  Filter [TLL]
  Delete [TLL] Where [F:TLL]TGRTAB = [M:TGL0]TGRTAB
  If fstat Then
    ILNKPBL = 1
    GOK = 0
    Call FSTA("TLL") From GLOCK
  Endif
  If ILNKPBL Then
    Return
  Endif
  #Enregistre le tableau 1
  For ILNKITER = 0 To [M:TGL3]NBLNK-1
    If [M:TGL3]TGRLNK(ILNKITER) <> "" Then
      If [M:TGL3]TGRLNKIDX(ILNKITER) <> "" Then
        If [M:TGL3]TGREXPLNK(ILNKITER) <> "" Then
          [F:TLL]TGRTAB = [M:TGL0]TGRTAB
          [F:TLL]TGRLNK = [M:TGL3]TGRLNK(ILNKITER)
          [F:TLL]TGRLNKIDX = [M:TGL3]TGRLNKIDX(ILNKITER)
          [F:TLL]TGREXPLNK = [M:TGL3]TGREXPLNK(ILNKITER)
          [F:TLL]TGRLNKSTD = 0
          Write [TLL]
          If fstat Then
            ILNKPBL = 1
            GOK = 0
            Call FSTA("TLL") From GLOCK
          Endif
        Endif
      Endif
    Endif
    If ILNKPBL Then
      Break
    Endif
  Next
Return

##########################################################################################################
# Crée un support de sélection de type Tous, s'il n'en existe pas pour la cible.
###########################################################################
$CRESSP3
Local Char SZABRTGR
Local Char SZTEXTE(GLONDCO)
Local Integer ISSPEXIST
Local Integer ISSPSUFFIX
Local Integer ICREATESSP

  SZABRTGR = ""
  SZTEXTE = ""
  ISSPEXIST = 0
  ISSPSUFFIX = 0
  ICREATESSP = 1
  Filter [SSP] Where [F:SSP]SPTTGR = [M:TGL0]TGRTAB and [F:SSP]SPTTYP = 3
  For [SSP]SSP1
    ISSPEXIST += 1
  Next
  Filter [SSP]
  If !ISSPEXIST Then
    #Détermine un nom pour le support de sélection
    SZSPTNUM = "ALL" + [M:TGL0]TGRTAB
    While 1
      Read [SSP]SSP0=SZSPTNUM
      If fstat Then
        Break
      Else
        ISSPSUFFIX += 1
        SZSPTNUM = "ALL" + [M:TGL0]TGRTAB + ISSPSUFFIX
      Endif
      If ISSPSUFFIX >= 100 Then
        ICREATESSP = 0
        Break
      Endif
    Wend
    If ICREATESSP Then
      Read [FID]FID0=[M:TGL0]TGRTAB;GAUSCRMI
      If fstat Then
        Read [FID]FID0=[M:TGL0]TGRTAB;""
        If fstat Then
          Read [ATB]CODFIC=[M:TGL0]TGRTAB
          If fstat Then
            SZTEXTE = [M:TGL0]TGRTAB
          Else    
            Call TEXTE([F:ATB]INTITFIC, SZTEXTE) From OBJDIV
          Endif
        Else
          Call LECTEXTRA(SZTEXTE, "FIEDIC", "CRITABAXX", [F:FID]CRITAB, [F:FID]CAT) From ATEXTRA
          If SZTEXTE = "" Then
            Read [ATB]CODFIC=[M:TGL0]TGRTAB
            If fstat Then
              SZTEXTE = [M:TGL0]TGRTAB
            Else    
              Call TEXTE([F:ATB]INTITFIC, SZTEXTE) From OBJDIV
            Endif
          Else
            SZTEXTE = SZTEXTE
          Endif
        Endif
      Else
        Call LECTEXTRA(SZTEXTE, "FIEDIC", "CRITABAXX", [F:FID]CRITAB, [F:FID]CAT) From ATEXTRA
        If SZTEXTE = "" Then
          Read [ATB]CODFIC=[M:TGL0]TGRTAB
          If fstat Then
            SZTEXTE = [M:TGL0]TGRTAB
          Else    
            Call TEXTE([F:ATB]INTITFIC, SZTEXTE) From OBJDIV
          Endif
        Else
          SZTEXTE = SZTEXTE
        Endif
      Endif
      Call DEBTRANS From GLOCK
      Trbegin [SSP]
      [F:SSP]SPTNUM = SZSPTNUM
      [F:SSP]SPTTGR = [M:TGL0]TGRTAB
      [F:SSP]SPTDES = ""
      [F:SSP]SPTTYP = 3
      [F:SSP]SPTPRO = ""
      [F:SSP]SPTSTD = 0
      Write [SSP]
      If fstat Then
        Rollback
        #Erreur lors de la génération du support de sélection de type : Tous les enregistrements.
        GMESSAGE = mess(745,196,1)
        GERR = 1
      Else
        Call MAJTEXTRA(SZTEXTE, "SELSSP", "SPTNAMAXX", [F:SSP]SPTNUM, "") From ATEXTRA
        If GOK < 1 Then
          Rollback
          #Erreur lors de la génération du support de sélection de type : Tous les enregistrements.
          GMESSAGE = mess(745,196,1)
          GERR = 1
        Else
          Commit
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Crée un support de sélection de type Premier niveau, s'il n'en existe pas pour la cible.
###########################################################################
$CRESSP4
Local Char SZABRTGR
Local Char SZTEXTE(GLONDCO)
Local Integer ISSPEXIST
Local Integer ISSPSUFFIX
Local Integer ICREATESSP

  SZABRTGR = ""
  SZTEXTE = ""
  ISSPEXIST = 0
  ISSPSUFFIX = 0
  ICREATESSP = 1
  Filter [SSP] Where [F:SSP]SPTTGR = [M:TGL0]TGRTAB and [F:SSP]SPTTYP = 4
  For [SSP] SSP1
    ISSPEXIST += 1
  Next
  Filter [SSP]
  If !ISSPEXIST Then
    #Détermine un nom pour le support de sélection
    SZSPTNUM = "SEL" + [M:TGL0]TGRTAB
    While 1
      Read [SSP]SSP0=SZSPTNUM
      If fstat Then
        Break
      Else
        ISSPSUFFIX += 1
        SZSPTNUM = "SEL" + [M:TGL0]TGRTAB + ISSPSUFFIX
      Endif
      If ISSPSUFFIX >= 100 Then
        ICREATESSP = 0
        Break
      Endif
    Wend
    If ICREATESSP Then
      Read [FID]FID0=[M:TGL0]TGRTAB;GAUSCRMI
      If fstat Then
        Read [FID]FID0=[M:TGL0]TGRTAB;""
        If fstat Then
          Read [ATB]CODFIC=[M:TGL0]TGRTAB
          If fstat Then
            SZTEXTE = [M:TGL0]TGRTAB
          Else    
            Call TEXTE([F:ATB]INTITFIC, SZTEXTE) From OBJDIV
          Endif
        Else
          Call LECTEXTRA(SZTEXTE, "FIEDIC", "CRITABAXX", [F:FID]CRITAB, [F:FID]CAT) From ATEXTRA
          If SZTEXTE = "" Then
            Read [ATB]CODFIC=[M:TGL0]TGRTAB
            If fstat Then
              SZTEXTE = [M:TGL0]TGRTAB
            Else    
              Call TEXTE([F:ATB]INTITFIC, SZTEXTE) From OBJDIV
            Endif
          Else
            SZTEXTE = SZTEXTE
          Endif
        Endif
      Else
        Call LECTEXTRA(SZTEXTE, "FIEDIC", "CRITABAXX", [F:FID]CRITAB, [F:FID]CAT) From ATEXTRA
        If SZTEXTE = "" Then
          Read [ATB]CODFIC=[M:TGL0]TGRTAB
          If fstat Then
            SZTEXTE = [M:TGL0]TGRTAB
          Else    
            Call TEXTE([F:ATB]INTITFIC, SZTEXTE) From OBJDIV
          Endif
        Else
          SZTEXTE = SZTEXTE
        Endif
      Endif
      Call DEBTRANS From GLOCK
      Trbegin [SSP]
      [F:SSP]SPTNUM = SZSPTNUM
      [F:SSP]SPTTGR = [M:TGL0]TGRTAB
      [F:SSP]SPTDES = ""
      [F:SSP]SPTTYP = 4
      [F:SSP]SPTPRO = ""
      [F:SSP]SPTSTD = 0
      Write [SSP]
      If fstat Then
        Rollback
        #Erreur lors de la génération du support de sélection de type : Liaison de premier niveau.
        GMESSAGE = mess(749,196,1)
        GERR = 1
      Else
        SZTEXTE = mess(747,196,1) - SZTEXTE
        Call MAJTEXTRA(SZTEXTE, "SELSSP", "SPTNAMAXX", [F:SSP]SPTNUM, "") From ATEXTRA
        If GOK < 1 Then
          Rollback
          #Erreur lors de la génération du support de sélection de type : Liaison de premier niveau.
          GMESSAGE = mess(749,196,1)
          GERR = 1
        Else
          Commit
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Vérifie la présence du champ de tri dans les quinzes premières lignes du tableau des champs affichés
#######################################################################
$CHKFIESRT
Local Integer ITERZ
Local Integer IFIEFOUND
Local Integer IFIEORD([M:TGL2]NBFIE)
Local Char SZFIENAM(30)([M:TGL2]NBFIE)

  Raz SZFIENAM
  Raz IFIEORD
  IFIEFOUND = 0
  For ITERZ = 0 To [M:TGL2]NBFIE-1
    IFIEORD(ITERZ) = [M:TGL2]TGRFIEORD(ITERZ)
    SZFIENAM(ITERZ) = [M:TGL2]TGRFIE(ITERZ)
  Next
  Sorta IFIEORD, SZFIENAM
  For ITERZ = 0 To 14
    If ITERZ >= [M:TGL2]NBFIE Then
      Break
    Endif
    If SZFIENAM(ITERZ) = [M:TGL2]FIESRT Then
      IFIEFOUND = 1
      Break
    Endif
  Next
  If !IFIEFOUND Then
    #Le champ de tri n'est pas inclus dans l'une des quinze premières lignes de la liste ci-dessus.
    GMESSAGE = mess(718,196,1)
    GERR = 3
    OK = 0
  Endif
Return

##########################################################################################################
#   Créé le support de présentation par défaut, s'il n'existe pas.
#####################################################################
Subprog CRETGPDEF(SZTGR, IERROR)
Value Char SZTGR
Variable Integer IERROR

Local Integer IDEFFOUND
Local Char SZSPTNUM
Local Integer ISSPSUFFIX
Local Integer ICREATESSP

  IDEFFOUND = 0
  SZSPTNUM = ""
  ISSPSUFFIX = 0
  ICREATESSP = 1
  Filter [TGP] Where [F:TGP]TGR = SZTGR and [F:TGP]SPTDEF = 1
  For [TGP] TGP1
    [M:TGL2]TGRSSPDEF = [F:TGP]TGRSSPNUM
    IDEFFOUND += 1
    Break
  Next
  Filter [TGP]
  If IDEFFOUND Then
    End
  Endif
  #Détermine un nom pour le support de sélection
  SZSPTNUM = "DEF" + SZTGR
  While 1
    Read [TGP]TGP0=SZSPTNUM
    If fstat Then
      Break
    Else
      ISSPSUFFIX += 1
      SZSPTNUM = "DEF" + SZTGR + ISSPSUFFIX
    Endif
    If ISSPSUFFIX >= 100 Then
      ICREATESSP = 0
      Break
    Endif
  Wend
  If ICREATESSP Then
    Call DEBTRANS From GLOCK
    Trbegin [TGP]
    [F:TGP]TGRSSPNUM = SZSPTNUM
    [F:TGP]TGR = SZTGR
    [F:TGP]SPTSTD = 0
    [F:TGP]SPTDEF = 1
    [F:TGP]CREUSR = GUSER
    [F:TGP]CREDAT = date$
    Write [TGP]
    If fstat Then
      Rollback
      IERROR = 1
    Else
      Call MAJTEXTRA(mess(763,196,1) - SZTGR, "TGRSSP", "TGRAXX", [F:TGP]TGRSSPNUM, "") From ATEXTRA
      If GOK <= 0 Then
        Rollback
        IERROR = 1
      Else
        Commit
        GITGLFGVCTL = 1
      Endif
    Endif
  Endif
  [M:TGL2]TGRSSPDEF = SZSPTNUM
End

##########################################################################################################
# Analyse le contenu d'une expression de lien
################################################################################
Subprog ANALYSE(CHAINE,TABLE,MSG)
Variable Char CHAINE()
Variable Char TABLE()
Variable Char MSG()

Local Integer NBPAR,II
Local Char CHAINE1(250)
# Variables utiles pour les analyses syntaxiques
Local Char ALPHA(27) : ALPHA="ABCDEFGHIJKLMNOPQRSTUVWXYZ_"
Local Char ALPHAN(37) : ALPHAN=ALPHA+"0123456789"
Local Char CARSKIP(100) : CARSKIP="abcdefghijklmnopqrstuvwxyz0123456789.$+-*=/!,"
Local Char SPACE100(100) : SPACE100=space$(100)

  If clalev([F:ATB])=0 : Local File ATABLE : Endif
  If clalev([F:ATZ])=0 : Local File ATABZON : Endif
  If CHAINE = "" Then
    #L'expression de lien n'est pas définie.
    MSG = mess(825,196,1)
    End
  Endif
  Read [ATB]CODFIC=TABLE
  If fstat Then
    #TABLE Table inexistante
    MSG = TABLE - ":" - mess(124,124,1)
    End
  Endif
  # Normalisation de la chaine
  CHAINE = vireblc(vireblc(format$("KT:255X",toupper(CHAINE)),2),5)
  CHAINE1 = ""
  # Analyse des expressions séparées par des ";"
  NBPAR = 0
  Repeat
    If left$(CHAINE,1) = "(" Then
      NBPAR += 1
      CHAINE = right$(CHAINE,2)
      CHAINE1 += "("
    Elsif left$(CHAINE,1) = ")" Then
        NBPAR -= 1
        CHAINE = right$(CHAINE,2)
        CHAINE1 += ")"
    Elsif left$(CHAINE, 1) = '"' or left$(CHAINE, 1) = "'" Then
        II = instr(2,CHAINE+left$(CHAINE,1),left$(CHAINE,1))
        CHAINE1 += left$(CHAINE,II)
        CHAINE = right$(CHAINE,II+1)
    Elsif left$(CHAINE,1) = ";" Then
      If parse(CHAINE1) Then
        MSG = mess(820,196,1)  #Expression syntaxiquement incorrecte.
        End
      Endif
      CHAINE1 = ""
      CHAINE = right$(CHAINE,2)
    Elsif pat(CHAINE,"["+[ATB]ABRFIC+"]*") or pat(CHAINE,"[F:"+[ATB]ABRFIC+"]*") or pat(CHAINE,"[F]*") Then
      II = instr(1,CHAINE,"]")
      CHAINE1 += left$(CHAINE,II)
      If instr(1,ALPHA,mid$(CHAINE,II+1,1)) = 0 Then
        #left$(CHAINE,II) "n'est pas suivie d'un nom de variable. Syntaxe incorrecte"
        MSG = left$(CHAINE,II) - mess(821,196,1)
        End
      Endif
      CHAINE = right$(CHAINE,II+1)
      II = len(CHAINE) - len(vireblc(ctrans(CHAINE,ALPHAN,SPACE100),0))
      Read [ATZ]CODZONE=[ATB]CODFIC;left$(CHAINE,II)
      If fstat Then
        #left$(CHAINE,II) + " "  + "n'est pas un champ de la table" + " : " + TABLE
        MSG = left$(CHAINE,II) - mess(574,196,1) - TABLE
        End
      Endif
      CHAINE1 += left$(CHAINE,II)
      CHAINE = right$(CHAINE,II+1)
    Elsif pat(CHAINE,"[M:*") Then
      MSG = "Expression intégrant une variable de masque interdite"
      End
    Elsif pat(CHAINE,"[V]*") Then
      CHAINE1 += left$(CHAINE,3)
      CHAINE = right$(CHAINE,4)
      II = len(CHAINE)-len(vireblc(ctrans(CHAINE,ALPHAN,SPACE100),0))
      CHAINE1+=left$(CHAINE,II)
      CHAINE = right$(CHAINE,II+1)
    Elsif pat(CHAINE,"[*")
      #Expression intégrant un lien vers une autre table que" + " : " + TABLE
      MSG = mess(823,196,1) - ":" - TABLE
      End
    Elsif instr(1,ALPHA,left$(CHAINE,1)) Then
      II = len(CHAINE)-len(vireblc(ctrans(CHAINE,ALPHAN,SPACE100),0))
      Read [ATZ]CODZONE=[ATB]CODFIC;left$(CHAINE,II)
      If fstat and left$(CHAINE,1) <> "G"  Then
        # OK pour variables globales non préfixées par [V] dans le lien...
        #left$(CHAINE,II) + " "  + "n'est pas un champ de la table" + " : " + TABLE
        MSG = left$(CHAINE,II) - mess(574,196,1) - TABLE
        End
      Endif
      CHAINE1 += left$(CHAINE,II)
      CHAINE = right$(CHAINE,II+1)
    Else
      # petite optimisation : on saute d'un coup les caractères minuscules, les opérateurs et $
      II = max(len(CHAINE)-len(vireblc(ctrans(CHAINE,CARSKIP,SPACE100),0)),1)
      CHAINE1 += left$(CHAINE,II)
      CHAINE = right$(CHAINE,II+1)
    Endif
  Until CHAINE = ""
  If parse(CHAINE1) Then
    MSG = mess(820,196,1)  #Expression syntaxiquement incorrecte.
    End
  Endif
  MSG = ""
End

##########################################################################################################
# Activation du calcul des positions                                                 
##################################################################################################
$ACTIVEPSS
  Raz GBOUT1
  Read [DVA]DVA0="PSS";GUSER
  If fstat Then
    #Activer le calcul des numéros d'ordre
    GBOUT1 = mess(669,182,1)
  Else
    If [F:DVA]INTX(0) > 0 Then
      #Désactiver le calcul des numéros d'ordre
      GBOUT1 = mess(670,182,1)
    Else
      #Activer le calcul des numéros d'ordre
      GBOUT1 = mess(669,182,1)
    Endif
  Endif
Return

##########################################################################################################
# Enregistrement de l'activation du calcul des positions                                                 
##################################################################################################
$SETPSS
Local Char SZMESS(250)

  SZMESS = ""
  Call DEBTRANS From GLOCK
  Trbegin [DVA]
  Readlock [DVA]DVA0="PSS";GUSER
  If fstat = 5 Then
    #Enregistrement non trouvé, il faut le créer
    [F:DVA]OBC = "PSS"
    [F:DVA]PARAM = GUSER
    [F:DVA]INTX(0) = 1
    Write [DVA]
    If fstat Then
      GMESSAGE = mess(671,182,1) #Erreur lors de l'activation du calcul des numéros d'ordres.
      GERR = 1
      Unlock [DVA]
      Rollback
      End
    Endif
  Elsif fstat = 0 Then
    #Enregistrement trouvé, il faut le réécrire pour préserver les éventuelles modifs.
    [F:DVA]OBC = "PSS"
    [F:DVA]PARAM = GUSER
    If [F:DVA]INTX(0) > 0 Then
      SZMESS = mess(672,182,1) #Erreur lors de la désactivation du calcul des numéros d'ordres.
      [F:DVA]INTX(0) = 0
    Else
      SZMESS = mess(671,182,1) #Erreur lors de l'activation du calcul des numéros d'ordres.
      [F:DVA]INTX(0) = 1
    Endif
    Rewrite [DVA]
    If fstat Then
      GMESSAGE = SZMESS
      GERR = 1
      Unlock [DVA]
      Rollback
      End
    Endif
  Endif
  Commit
Return
