#<AdxTL>@(#)0.0.0.0 $Revision$
# ALNKDELTAB_CSTD
$ACTION
Case ACTION
 When "GET_OBJECT"     : Gosub GET_OBJECT
 When "SET_OBJECT"     : Gosub SET_OBJECT
Endcase
Return

$GET_OBJECT
Local Integer IOBJ
VARINT=3
IOBJ = find (CLASS+"~"+KEYS,AOBJECTKEY)
If IOBJ
 OBJ = AOBJECT(IOBJ)
 VARINT = 0
Endif
Return

$SET_OBJECT
Local Integer IOBJ
VARINT=3
IOBJ = find (OBJ.OBJECTTYPE()+"~"+KEYS,AOBJECTKEY)
If !IOBJ
 IOBJ = 1 + maxtab(AOBJECT)
 AOBJECT(IOBJ)    = OBJ
 AOBJECTKEY(IOBJ) = OBJ.OBJECTTYPE()+"~"+KEYS
Endif
Return
