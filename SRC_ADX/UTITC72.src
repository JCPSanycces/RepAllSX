#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# UTITC72                                                                            #
#                                                                                    #
# Common Data module migration update tool for VNEXT                                 #
#                                                                                    #
# Issue 21158 – 2017-03-28  by MADOR- As an accountant I want to export              #
# correctly the data regarding taxonomy codes                                        #
#                                                                                    #
######################################################################################
  Call MAJ_UTITC72
End

#-------------------------------------------------------------------------------#
Subprog MAJ_UTITC72
Local Char DOSSIER(30)

  DOSSIER=nomap
  Call SAIDOS(DOSSIER,"UTITC72 - Upgrade process to VNEXT patch SAFT for common data.") From SAIDOS
  If DOSSIER <> "" Then
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTITC72 - Upgrade process to VNEXT patch SAFT for common data.") From LECFIC
    Call EXE_UTITC72(DOSSIER)
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

#-------------------------------------------------------------------------------#
Subprog EXE_UTITC72(DOSSIER)
Value Char    DOSSIER
  Call ECR_TIME("UTITC72 : Start folder's process"-DOSSIER) From DOSSUB
  #----- Start LEDTYPE field init -----#
  Gosub TRT_LEDTYPE
  #----- End LEDTYPE field init -----#
$FIN_UTITC72
  Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
  Call ECR_TIME("UTITC72 : End folder's process"-DOSSIER) From DOSSUB
End

#-------------------------------------------------------------------------------#
#   Initialization of the new field LEDTYPE for ledger    #
#-------------------------------------------------------------------------------#
$TRT_LEDTYPE
 # Tables GLED
 # Criterias :
 #  If "GEN"=1 or activity code KPO=1 or activity code SAFT=1 or ( LEG<>"POR" & LEG <> "ALL")
 #  => value should be defaulted to 1 and should be hidden
 # IN THE REST OF THE CASES, IT SHOULD BE DEFAULTED To 2

If GTRACE=""
 Call OUVRE_TRACE("UTITC72 - Upgrade process to VNEXT patch SAFT for common data.") From LECFIC
 Local Integer LTRACE
Endif

If filinfo(filpath("FIL","GLED","fde",DOSSIER),0) <= 0 Then
  Return
Endif

If func AFNC.ACTIV("KPO")
  Local File = DOSSIER+".GLED"    [F:LED]

  Trbegin [LED]
  For [F:LED] Where [F:LED]LEDTYPE = 0
    If ([F:LED]LEG <> "" or [F:LED]LEG <> "POR") & [F:LED]GEN = 1
      [F:LED]LEDTYPE = 1
      Rewrite[F:LED]
    Else
      [F:LED]LEDTYPE = 2
      Rewrite[F:LED]
    Endif
  Next

  If GOK<1
    Rollback
  Else
    Commit
  Endif
Endif

If dim(LTRACE)>0
  Call LEC_TRACE From LECFIC
Endif

Return

#-------------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If func DOSSUB.FILL_ADS(APPLI)=0    : End : Endif
  #/*YYFIN_SAM-122729 -------------------------------
  If filinfo(filpath("FIL","GLED","fde",APPLI),0)<=0  : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"GLED")                 : End : Endif
  #YYFIN_SAM-122729 */
  Call EXE_UTITC72(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  #/*YYFIN_SAM-122729 -------------------------------
  If filinfo(filpath("FIL","GLED","fde",APPLI),0)<=0  : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"GLED")                 : End : Endif
  #YYFIN_SAM-122729 */
  Call EXE_UTITC72(APPLI)
End

