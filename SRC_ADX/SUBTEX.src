#<AdxTL>@(#)7.0.0.0 $Revision$
Call OBJET("TEX",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When Default
Endcase
Return

$OUVRE
If clalev([F:TVT])=0 : Local File TABVAT  [TVT] : Endif
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif  :#--CPO 71937 TVT et multi-lèg
Return


######################################################################################
## Etiquettes du masque TEX1
######################################################################################
Subprog AS_VATTYP(VALEUR)
Variable Integer VALEUR
Local Integer WRET :#--CPO 71937 TVT
Gosub SETNOL
If [M:TEX1]VAT(NOL) <> ""
 #--CPO 71937 TVT et multi-lèg
 #If clalev([F:TVT])=0 : Local File TABVAT [TVT] : Endif
 #Call LECTURE("TVT",[M:TEX1]VAT(NOL),"") From CONTOBJ
 If [M:TEX1]CPY(NOL)<>[F:CPY]CPY
   Read [F:CPY]CPY0=[M:TEX1]CPY(NOL)
   If fstat : Raz [F:CPY] Endif
 Endif
 Call LEC_TVT_LEG([F:CPY]LEG,[M:TEX1]VAT(NOL),WRET) From TRTLECLEG
 If WRET : Raz [F:TVT] Endif
 #--/CPO
 VALEUR = [F:TVT]VATTYP : mkstat = 2 : End
Endif
End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
Gosub SETNOL
Local Integer I
For I=0 To [M:TEX1]NBEXE-1
 If I<>NOL & [M:TEX1]CPY(I)=[M:TEX1]CPY(NOL) & [M:TEX1]VAT(I)=[M:TEX1]VAT(NOL) & [M:TEX1]VATTYP(I)=[M:TEX1]VATTYP(NOL)
& & [M:TEX1]STRDAT(NOL)=[M:TEX1]STRDAT(I)
  GERR = 1
  ## Paramétrage exonération déjà défini en ligne
  GMESSAGE = mess(75,119,1)-num$(I+1)
  mkstat = 2 : Break
 Endif
Next I
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return
