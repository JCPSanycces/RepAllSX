#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion objet TVI
########################################################################
# SUBTVI : Niveau de taxe                                           #
########################################################################

$ACTION
Case ACTION
 When "OUVRE": Gosub OUVRE :#--CPO 71937
 When "AFFMASK"     : Gosub AFFMASK
 When "RAZCRE"      : Gosub RAZCRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INICRE
 When "ANNULE"      : Gosub ANNULE
 #-- X3Suivi 71937 : Données par législation pour le niveau de taxe
 When "SEL_TABLE"   : Case TABLE :      When "SELTVI"    : Gosub SELTVI :    Endcase
 When "LIENS"       : Gosub LIENS
 When "CHGCOD"      : Gosub CHGCOD
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "FERME"       : Gosub FERME
 When Default
Endcase
Return

$OUVRE
#-----------------------------------#
# Sauvegarde des variables globales #
#-----------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB

#--Lors d'un tunnel depuis un document (exemple : livraison)
Raz GCURFCY  :#--Ici pas de contexte et on veut éviter le filtrage des groupes de sites
Raz GSOCIETE :#--Ici pas de contexte et on veut éviter le filtrage des groupes de societes

Return
######################################################################
# $INICRE
######################################################################
$INICRE
 #--- Creation / Modif de ATEXTRA
 Call MAJTEXTRA ([M:TVI1]DESAXX,"TABVACITM","DESAXX",[M:TVI1]VACITM,[M:TVI1]LEG) From ATEXTRA
 Call MAJTEXTRA ([M:TVI1]SHOAXX,"TABVACITM","SHOAXX",[M:TVI1]VACITM,[M:TVI1]LEG) From ATEXTRA

 #--- SOS libellés
 If dim([F:TVI]LANDESSHO)>0
   [F:TVI]LANDESSHO=GLANGUE+"~"+[M:TVI1]DESAXX+"~"+[M:TVI1]SHOAXX
 Endif
Return

######################################################################
# $LIENS
######################################################################
$LIENS
#--CPO 71937
GCURLEG = [F:TVI]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
GGRPFCY = [M:TVI1]SOC :#--CPO 71937
Return

######################################################################
# $AP_CHANGE
######################################################################
$AP_CHANGE
 Call CHGTEXTRA("TABVACITM","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
 Call CHGTEXTRA("TABVACITM","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

######################################################################
# $AFFMASK
######################################################################
$AFFMASK
 Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
 Gosub GRILEG
Return

######################################################################
$RAZCRE
Gosub GRILEG
Return

######################################################################
$GRILEG
If func AFNC.ACTIV("LEG")=0 : # Dossier mono-législation
  Diszo [M:TVI1]LEG
  [M:TVI1]LEG=GDOSLEG(1)
  Affzo [M:TVI1]LEG
Endif
Return
######################################################################
$FERME
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB

# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONTVI) : Endif
VCOD = CLE2
Return

######################################################################
$ANNULE
Delete [AXX]Where CODFIC="TABVACITM" & IDENT1=[F:TVI]VACITM & IDENT2=[F:TVI]LEG
Return

######################################################################

##################################################
## Actions of the data type TVI
##################################################

######################################################################################
#-- X3SUIVI 71937 : Données par législation pour le niveau de taxe
######################################################################################
Subprog CONTTVI(VACITM,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,CPY )

Variable Char    VACITM()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY

Local Integer  WRET

Local    Integer CAS
Local    Char    OPTIONS(30)

If GFONCTION = "GESTVI" | VACITM="" : End : Endif

If clalev([F:TVI]) =0 : Local File TABVACITM [TVI]  : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON   [AMZZ] : Endif :#Pour déterminer les options de sélection
If clalev([F:CPY]) =0 : Local File COMPANY   [CPY]  : Endif :#--CPO 71937
If clalev([F:FCY]) =0 : Local File FACILITY  [FCY]  : Endif :#--CPO 71937

If func AFNC.ACTIV("LEG")=0
  LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
  LEG = GCURLEG
Endif
CAS = 1 : # Legislation is empty

#--CPO 71937
#--Cas particulier : pas de GCURLEG mais société ou site en ligne
If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
  If [L]FCY<>""
    If [F:FCY]FCY<>[L]FCY
     Read [F:FCY]FCY0=[L]FCY
     If fstat : Raz [F:FCY] Endif
    Endif
    If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
  Endif
  If [L]CPY<>""
    If [F:CPY]CPY<>[L]CPY
     Read [F:CPY]CPY0=[L]CPY
     If fstat : Raz [F:CPY] Endif
    Endif
    [L]LEG=[F:CPY]LEG
   Endif
Endif
#--/CPO

If LEG<>""
 Read [TVI]TVI0=VACITM;LEG
 If fstat
  Read [TVI]TVI0=VACITM;""
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Read [TVI]TVI0(1)=VACITM
 If !fstat
  LEG = [F:TVI]LEG
  CAS = 2
 Endif
Endif

If fstat
 Filter [TVI] Where VACITM=[L]VACITM
 Look [TVI]TVI0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  GMESSAGE = [L]VACITM-":"-mess(232,107,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  GMESSAGE = [L]VACITM-":"-mess(23,100,1)
 Endif
 Filter [TVI]
 mkstat = 2 : End
Endif

#--Filtrage par groupe de société
#--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
#--Du fait du type de donné AGF sur le champ SOC de TABVACITM, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
#If [L]CPY<>""
If [L]CPY<>"" and [L]FCY="" :#--CPO 71937
  If [F:TVI]SOC<>""
  	#--CPO 71937
  	If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
		Read [AGF]AGF0=[F:TVI]SOC
		If !fstat
  		If [F:AGF]FLGLEG=2
    		#--Société
				If [F:TVI]SOC<>[L]CPY
          GMESSAGE += VACITM +"\"+mess(63,127,1)-":"-[F:TVI]SOC : # Réservé au groupe de société
          mkstat = 2 : End
				Endif
  		Elsif [F:AGF]FLGCPY=2
  	#--CPO
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        Look [AGC]AGC0 = [F:TVI]SOC;[L]CPY
        If fstat
          GMESSAGE += VACITM +"\"+mess(63,127,1)-":"-[F:TVI]SOC : # Réservé au groupe de société
          mkstat = 2 : End
        Endif
      Endif :#--CPO 71937
    Endif
  Endif
Endif
#--

#--Contrôle de cohérence entre le groupe de la taxe et la législation
If [F:TVI]SOC<>"" and LEG<>""
  Call CTLGFYLEG([F:TVI]SOC,LEG,"","") From TRTVENCTL
  If mkstat : End : Endif
Endif
#--Contrôle de cohérence entre le groupe passé en paramètre et la législation de l'enregistrement retenu
If GROUPE<>"" and [F:TVI]LEG<>""
	Call CTLGFYLEG(GROUPE,[F:TVI]LEG,"","") From TRTVENCTL
	If mkstat : End : Endif
Endif
#--Contrôle de la cohérence entre le groupe passé en param et celui de la taxe à contrôler
#--uniquement si le groupe passé est renseigné
#--uniquement si pas de contexte site ou société !
If GROUPE<>""
  If CPY="" & FCY="" & [F:TVI]SOC<>"" & [F:TVI]SOC<>GROUPE
    #--Les groupes doivent avoir au moins une société en commun
    Gosub CTLGFYGRP
    If mkstat : End : Endif
  Endif
Endif

#--On charge les options définies sur le type de données du champ du masque
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS=[F:AMZZ]OPTOBJ : Endif
Endif

If CAS=2
 Call CONTROLE("TVI",OPTIONS,LEG,VACITM,mkstat) From CONTOBJ
Else
 Call CONTROLE("TVI",OPTIONS,"",VACITM,mkstat) From CONTOBJ
Endif

End

############################
#  $CTLGFYGRP
############################
$CTLGFYGRP
Local Integer ERR
Local Char    SZVIEW(GLONAVW)
If [F:TVI]LEG=""
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTVIZGRP"
    Local File =SZVIEW [TVIZ]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TVIZ]TVIZ0 = [L]GROUPE;[F:TVI]VACITM;[F:TVI]SOC;[F:TVI]LEG
  If fstat
  GMESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TVI]SOC-":"-mess(178,187,1)
  mkstat=1
  Return
  Endif
Else
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTVIYGRP"
    Local File =SZVIEW [TVIY]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TVIY]TVIY0 = [L]GROUPE;[F:TVI]VACITM;[F:TVI]SOC;[F:TVI]LEG
  If fstat
  GMESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TVI]SOC-":"-mess(178,187,1)
  mkstat=1
  Return
  Endif
Endif
Return


######################################################################################
#-- X3SUIVI 71937 : Données par législation pour le niveau de taxe
######################################################################################
Subprog CONTTVI_OLD(VACITM,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,CPY )
Value    Char    VACITM()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY
Local Integer WNBTOT, WI, WNO_ERR,  WENROK, WENAFLG_OK,  W1ER_ENROK_INACTIF
Local Char    WLEG  (GLONADI), WMESS1 (120), WMESS2 (120), WMESS3 (120)
Local Integer CAS
Local Char    OPTIONS(30)

CAS = 1 : # Legislation is empty

WENROK             = 1
W1ER_ENROK_INACTIF = 1
WLEG               = LEG

#--CPO 71937
#--Cas particulier : pas de GCURLEG mais société ou site en ligne
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif :#--CPO 71937
If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif :#--CPO 71937
If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
If [L]FCY<>""
If [F:FCY]FCY<>[L]FCY
Read [F:FCY]FCY0=[L]FCY
If fstat : Raz [F:FCY] Endif
Endif
If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
Endif
If [L]CPY<>""
If [F:CPY]CPY<>[L]CPY
Read [F:CPY]CPY0=[L]CPY
If fstat : Raz [F:CPY] Endif
Endif
[L]LEG=[F:CPY]LEG
Endif
Endif
#--/CPO

If WLEG<>'' :  CAS = 2  : Endif

If GFONCTION = "GESTVI" | VACITM="" : End : Endif
If clalev([F:TVI]) =0 : Local File TABVACITM [TVI] : Endif

#------------------------------------------------------------------------------#
#-- Test s'il existe un enregistrement 'Niveau de taxe'                     ---#
#------------------------------------------------------------------------------#
WI=0
If WLEG = ''
  Filter [TVI] Where VACITM=[L]VACITM                                       Order By Key CLE=[F:TVI]VACITM; [F:TVI]LEG
Else
  Filter [TVI] Where VACITM=[L]VACITM    & ([F:TVI]LEG='' |[F:TVI]LEG=WLEG) Order By Key CLE=[F:TVI]VACITM; [F:TVI]LEG Desc
Endif

For [TVI]CLE(1)
 WNO_ERR= 0
 WI     = 0
 W1ER_ENROK_INACTIF = 1
 Raz WMESS1, WMESS2, WMESS3, GMESSAGE
 For [TVI]CLE
   WENROK = 2
   If WLEG = '' or [F:TVI]LEG=WLEG or (WLEG<>'' & [F:TVI]LEG='')

     WI+=1

     If [L]CPY <> '' or [L]FCY <> '' : Gosub CTRL_SOC     : Endif   : #-- Rend ENROK=1 (et WNO_ERR=1) ou 2 --#

     If WENROK = 2  &  GROUPE<>''    : Gosub CTRL_GROUPE  : Endif   : #-- Rend ENROK=1 (et WNO_ERR=2) ou 2 --#

     If WENROK = 2                   : Gosub CTRL_ENAFLG  : Endif   : #-- Rend ENROK=1 (et WNO_ERR=3) ou 2 --#

     If  [F:TVI]LEG=WLEG or WENROK = 2 : Break :  Endif : #--- si on a trouvé la WLEG (ou si WLEG='' et on est sur la derniere LEG) : On sort
   Endif
 Next
Next

Filter [TVI]

If WI=0
 #-- Mess : Niveau de taxe XXX & Législation YYY : Fiche inexistante
 GMESSAGE = mess(210,183,1)- VACITM - '&'- mess(218,107,1)
 If [L]WLEG <> ''
  GMESSAGE -=  "'"+[L]WLEG+ "'" - mess(377,192,1)
 Endif
 GMESSAGE -=  mess(376,192,1) - ":"-mess(23,100,1)
 mkstat = 2
 End
Endif

If W1ER_ENROK_INACTIF = 2 & WNO_ERR <>0
 GMESSAGE = WMESS1 - "'" + WMESS2 + "'" - WMESS3                : #-- Mess : Niveau taxe xxx inactif
 mkstat = 2
 End
Endif

If WNO_ERR = 2
 GMESSAGE = WMESS1 - "'" + WMESS2 + "'" - WMESS3                : #-- Mess: Niv taxe xxx: Groupes soc/sit différents  yy<>zz
 mkstat = 2 : End
Endif

If WNO_ERR = 1
 GMESSAGE= WMESS1 - "'" + WMESS2 + "'" - WMESS3                 : #-- Mess : Réservé au groupe de société
 mkstat=1 : End
Endif

#--On charge les options définies sur le type de données du champ du masque
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS=[F:AMZZ]OPTOBJ : Endif
Endif

If OPTIONS<>""
 If CAS=2
  Call CONTROLE("TVI",OPTIONS,LEG,VACITM,mkstat) From CONTOBJ
 Else
  Call CONTROLE("TVI",OPTIONS,"",VACITM,mkstat) From CONTOBJ
 Endif
Endif

End

###############################################
# $CTRL_SOC
###############################################
$CTRL_SOC
 If [L]CPY<>""
  If [F:TVI]SOC<>""

   #-- Filtrage par Société : Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
   #-- Du fait du type de donné AGF sur le champ SOC de TABVACITM, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
   If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
   Look [AGC]AGC0 = [F:TVI]SOC;[L]CPY
   If fstat
     WENROK = 1
     WNO_ERR= 1
     If WLEG = '' or [F:TVI]LEG=WLEG
      #-- Mess : Niveau de taxe XXX & Législation YYY \ Réservé au groupe de société ZZZ ---#
      WMESS1 = mess(210,183,1)-VACITM- '&'- mess(218,107,1)
      If WMESS2 = '' : If [F:TVI]LEG <> '' : WMESS2 -=  [F:TVI]LEG : Else : WMESS2 -= mess(91,187,1) : Endif  :  Endif
      WMESS3 =  ":"+"\"+mess(63,127,1)-[F:TVI]SOC
     Endif
   Endif
 Endif
Endif
Return

###############################################
# $CTRL_GROUPE
###############################################
$CTRL_GROUPE
  #--Contrôle cohérence entre Groupe passé et Groupe du Niveau de taxe courant (uniquement si pas de contexte site ou société) --#
  If CPY="" & FCY="" & [F:TVI]SOC<>"" & [F:TVI]SOC<>GROUPE
      WENROK = 1
      WNO_ERR= 2
      If WLEG=''  or [F:TVI]LEG=WLEG or [F:TVI]LEG=''
       #-- Mess : Niveau de taxe XXX & Législation YYY \ Groupes sociétés/sites différents (WWW<>ZZZ)---#
       WMESS1 = mess(210,183,1)-VACITM - '&'- mess(218,107,1)
       If WMESS2 = ''
         If [F:TVI]LEG <> '' : WMESS2 -=  [F:TVI]LEG : Else : WMESS2 -= mess(91,187,1) : Endif
       Endif
       WMESS3 =  ':' +"\"+mess(92,187,1)-"("
       WMESS3 +=[F:TVI]SOC-"<>"-GROUPE+")"
      Endif
  Endif
Return

###############################################
# $CTRL_ENAFLG
###############################################
$CTRL_ENAFLG
  If [F:TVI]ENAFLG<>2
   WNO_ERR   = 3
   If W1ER_ENROK_INACTIF = 1
     If WLEG = '' or [F:TVI]LEG=WLEG
       #-- Mess : Niveau de taxe XXX & Législation YYY : Inactif  ---#
       WMESS1             = mess(210,183,1)- VACITM - '&'- mess(218,107,1)
       If [F:TVI]LEG <> '' : WMESS2 =  [F:TVI]LEG : Else : WMESS2 = mess(91,187,1) : Endif
       WMESS3            = ':' - mess(3,271,1)
     Endif
     W1ER_ENROK_INACTIF = 2
     WENROK =1
   Else
     WENROK =1
   Endif
  Else
   WNO_ERR=0
  Endif
Return

######################################################################################
#-- X3SUIVI 71937 : Données par législation pour le niveau de taxe
######################################################################################
## Tunnel Niveau de taxe
######################################################################################
Subprog TUNTVI(VACITM,LEG)
Variable Char    VACITM()
Value    Char    LEG()

Local Integer TOKILL

TOKILL = 0
If dim(VCOD)<1
  Global Char VCOD(GLONVAT)
  TOKILL = 1
Endif

If clalev([F:TVI])=0 : Local File TABVACITM [TVI] : Endif

VCOD = VACITM

If GNBLEG=1
  LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>""
  LEG = GCURLEG
#--If LEG="" then firstly we search a TVT record with LEG="" secondly a TVT record with TVT<>""
Elsif LEG=""
  Read [TVI]TVI0 = VCOD;LEG
  If fstat
    Read [TVI]TVI0(1)=VCOD
    If !fstat
      LEG = [F:TVI]LEG
    Endif
  Endif
Endif

Read [TVI]TVI0 = VCOD;LEG
If fstat : LEG = "" : Endif

Call OBJET("TVI",LEG,VCOD) From GOBJET

VACITM = VCOD
If TOKILL : Kill VCOD : Endif
End

####################################################################################################
## $SELTVI : X3SUIVI 71937 : Données par législation pour le niveau de taxe                       ##
##       --> Si [L]LEG<>""                           --> Utilisation de la vue LEGTVISEL  (TVIS)  ##
##       --> Si [L]LEG=""                            --> Utilisation de la vue LEGTVIPAR  (TVIP)  ##
##       --> Si [L]LEG=<>"" OU (LEG="" & GROUPE<>'') --> Utilisation de la vue LEGTVICPY  (TVIC)  ##
##   FACGROUP --> Table de lien Groupe et site                                                    ##
##   AGRPCPY  --> Table de lien Groupe et société                                                 ##
###################################################################################################
$SELTVI

If clalev([F:TVI]) =0 : Local File TABVACITM  [TVI]  : Endif
If clalev([F:FCY]) =0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:CPY]) =0 : Local File COMPANY    [CPY]  : Endif
If clalev([F:FGR]) =0 : Local File FACGROUP   [FGR]  : Endif
If clalev([F:AXX]) =0 : Local File ATEXTRA    [AXX]  : Endif
If clalev([F:AGF]) =0 : Local File AGRPFCY    [AGF]  : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON    [AMZZ] : Endif :#--CPO 71937 Pour déterminer les options de sélection

Local Char    FCY(GLONFCY), CPY(GLONCPY), LEG(GLONADI), SOC(GLONAGC) :#CPO 71937 25.02.13 GRP(GLONAGC)
Local Integer WNOL, ERR
Local Integer ERR
Local Char    AUTRE_CRIT(250)
Local Char    SZVIEW(GLONAVW)

If dim(OPTIONS)<0 : Local Char OPTIONS(30) Endif #--CPO 71937 Pour déterminer les options de sélection
Local Char CODMSK   (GLONAMK)  #--CPO 71937 Pour déterminer les options de sélection
Local Char CHAMPCOD (GLONAVA)  #--CPO 71937 Pour déterminer les options de sélection

AUTRE_CRIT = '1=1'

#--------------------------------------------------------------------------------------------------
# Récupération des paramètres
#--------------------------------------------------------------------------------------------------
If GFONCTION="ADPVAL"     :#--"Parameter values". Data type = ???
  FCY      = [M:ADWP]FCY
  CPY      = [M:ADWP]CMP
  If dim([M:ADWP]LEG)>0
    LEG = [M:ADWP]LEG
  Endif
Else
  LEG      = PARAM(1)
  FCY      = PARAM(2)
  SOC      = PARAM(3)
  CPY      = PARAM(4)
  CODMSK   = PARAM(5)
  CHAMPCOD = PARAM(6)
Endif

#--On charge les options définies sur le type de données du champ du masque
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS =[F:AMZZ]OPTOBJ : Endif
Endif
#--/CPO

#--------------------------------------------------------------------------------------------------
If GFONCTION = "GESTVI" Then
  # Si on est sur l'objet de paramétrage, pas de filtre on part sur la sélection standard
  OBJET = "TVI"
  Return
Endif

#-- Initialisation de législation
If func AFNC.ACTIV("LEG")=0
  [L]LEG = GDOSLEG
Endif

If [L]LEG=""
 If [L]FCY<>""
  Call LEC_FCY([L]FCY) From CPTLEC
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Elsif [L]CPY<>""
  Call LEC_CPY([L]CPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Endif
Endif

If [L]LEG="" :  [L]LEG = GCURLEG : Endif
#--------------------------------------------------------------------------------------------------
## Position et taille de la fenêtre
#--------------------------------------------------------------------------------------------------
Gosub OUVRE_LISTE From WOTVI
For I=1 To NBSEL
 If SELEXP(I)<>""
  COL(I) = SELEXP(I)
 Else
  COL(I) = SELZON(I)
 Endif
 TIT(I)  = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I

NBCOL   = NBSEL
SIZCOL  = 240
SIZLIG  = 100
TIT(0)  = mess(12,123,1)  # Choix
Call TITOBJ("TVI","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START   = "[F:TVI]VACITM"
ORDRE   = "[F:TVI]VACITM;[F:TVI]LEG"
OBJET   = ""
#--------------------------------------------------------------------------------------------------
## Critères pour la sélection standard
#--------------------------------------------------------------------------------------------------

CRITERE(1) = '1=1 & [F:TVI]ENAFLG=2'

#--Groupe de soc/sites
If FCY="" & CPY="" & SOC<>""
 Read [F:AGF]AGF0=[L]SOC
 If !fstat
 If [F:AGF]FLGLEG=2 : [L]CPY=[L]SOC : Endif
Endif
Endif

If    [L]FCY<>""   : CRITERE(1) -= '& ([F:TVI]SOC="" | ([F:TVI]SOC<>"" & [F:FGR]FCY="'+[L]FCY+'"))'             : #--Site

Elsif [L]CPY<>""   : CRITERE(1) -= '& ([F:TVI]SOC="" | ([F:TVI]SOC<>"" & [F:TVIC]LEGCPY="'+[L]CPY+'"))' : Endif : #--Société


If [L]FCY="" & [L]CPY="" & [L]SOC<>"" : CRITERE(1) -= '& ([F:TVI]SOC="'+[L]SOC+'" or [F:TVI]SOC="")'                : Endif : #--Groupe soc/sites

If [L]LEG<>""         : CRITERE(2) -= '& ([F:TVI]LEG="'+[L]LEG+'" | [F:TVI]LEG="")'                        : Endif : #--Législation


If dim(SELCAR)>0 & SELCAR<>0
  CRITERE(2) -= '& left$([F:TVI]VACITM,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

ICRITERE = 3

#MGG X3-38593 Row level permission
#Call FILROLE(OBJET,FILROLE) From SUBARL
Call FILROLE("TVI",FILROLE) From SUBARL
#END MGG X3-38593 Row level permission

If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif

#--------------------------------------------------------------------------------------------------
## Appel à la vue LEGTVICPY selectionnant les Niveaux de taxe avec groupe soc/site
#--------------------------------------------------------------------------------------------------
If ([L]CPY="" and [L]FCY="" and [L]SOC<>"")
  If [L]LEG<>""
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTVIYGRP"
      Local File =SZVIEW [TVIY]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TVI"
      Return
    Endif
  Else
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTVIZGRP"
      Local File =SZVIEW [TVIZ]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TVI"
      Return
    Endif
  Endif
Endif

If 1=1
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTVICPY"
    Local File =SZVIEW [TVIC]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, on se déroute sur le select standard
    OBJET = "TVI"
    Return
  Endif

  If [L]LEG<>""
    ##############################################################################################################
    ## Cas avec [L]LEG<>"" :  Appel à la vue LEGTSVSEL selectionnant les Type facture avec LEG en parametre
    ##                             et la vue LEGTSVGRP  (TSVG) pour le groupe
    ##############################################################################################################
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTVISEL"
      Local File =SZVIEW [TVIS]
      Onerrgo
    Until ERR <> -1
    If ERR : OBJET = "TVI" : Return : Endif    :   #-- Si problème, on se déroute sur le select standard

    If ([L]CPY="" and [L]FCY="" and [L]SOC<>"")
      Link [TVI] With [F:AXX]AXX0    = "TABVACITM";"DESAXX";GLANGUE;[F:TVI]VACITM;[F:TVI]LEG,
&                     [F:TVIY]TVIY0 ~= [L]SOC;[F:TVI]VACITM;[F:TVI]SOC;[F:TVI]LEG,
&                     [F:TVIS]TVI0  ~= [F:TVI]VACITM;[F:TVI]LEG;[L]LEG
&              As [LTVI]
    Else
      Link [TVI] With [F:AXX]AXX0   = "TABVACITM";"DESAXX";GLANGUE;[F:TVI]VACITM;[F:TVI]LEG,
&                   [F:FGR]FGR1     = [L]FCY;[F:TVI]SOC,
&                   [F:TVIC]TVI0    = [F:TVI]VACITM;[F:TVI]LEG;[F:TVI]SOC;[L]CPY,
&                   [F:TVIS]TVI0   ~= [F:TVI]VACITM;[F:TVI]LEG;[L]LEG
&     As [LTVI]
    Endif

 Else
   #--View without legislation
   ERR = 0
   Repeat
     # -----------------------------------------------------------------------------------------------
     # ERR=0  : Pas d'erreur, on sort
     # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
     # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
     # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
     # -----------------------------------------------------------------------------------------------
     Onerrgo ERRVUE
     SZVIEW = "LEGTVIPAR"
     Local File =SZVIEW [TVIP]
     Onerrgo
   Until ERR <> -1

   If ERR Then
    # Si problème, on se déroute sur le select standard
     OBJET = "TVI"
     Return
   Endif

   If ([L]CPY="" and [L]FCY="" and [L]SOC<>"")
  Link [TVI] With [F:AXX]AXX0    ="TABVACITM";"DESAXX";GLANGUE;[F:TVI]VACITM;[F:TVI]LEG,
&                 [F:TVIZ]TVIZ0 ~= [L]SOC;[F:TVI]VACITM;[F:TVI]SOC;[F:TVI]LEG
&              As [LTVI]
 Else
   Link [TVI] With [F:AXX]AXX0    = "TABVACITM";"DESAXX";GLANGUE;[F:TVI]VACITM;[F:TVI]LEG,
&                 [F:FGR]FGR1     = [L]FCY;[F:TVI]SOC,
&                 [F:TVIC]TVI0    = [F:TVI]VACITM;[F:TVI]LEG;[F:TVI]SOC;[L]CPY,
&                 [F:TVIP]TVI0   ~= [F:TVI]VACITM;[F:TVI]LEG
&      As [LTVI]
Endif
  Endif
Endif

# Options de sélection
If OPTIONS<>""
  Gosub OPTIONS From WOTVI
  ICRITERE=2
  For I=1 To NBCOND
   If instr(1,OPTIONS,OPT(I))
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+CONDIT(I)+")","&") From GOBJSUB
   Endif
  Next I
Endif

Default File [LTVI]
DEFPAG = 1

Return


################################
$ERRVUE
  If ERR = 0 Then
    ERR = -1
    Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif
Resume

###########################################################################
# $CHGCOD
###########################################################################
$CHGCOD
 Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return


###########################################################################
# $TRTCOP
###########################################################################
$TRTCOP

#-----------------------------------------------------------#
# Etiquette appelée depuis le traitement superviseur ACOPIE #
# --------------------------------------------------------- #
# Traitement de la copie d'une retenue                      #
#-----------------------------------------------------------#
If [M]DOSORG=nomap
   Local File TABVACITM [TVI1]
   Local File ATEXTRA   [AXX1]

Else
   Local File =[M]DOSORG+".TABVACITM" [TVI1]
   Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
Endif
If [M]DOSDES=nomap
   Local File TABVACITM [TVI2]
   Local File ATEXTRA   [AXX2]
   Local File ACTIV     [ACV2]
Else
   Local File =[M]DOSDES+".TABVACITM" [TVI2]
   Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
   Local File =[M]DOSDES+".ATABDIV"   [ADI2]
   Local File =[M]DOSDES+".ACTIV"     [ACV2]
   Local File =func DOSCONT.DOSX3([M]DOSDES)+".ADOSSIER"  [ADS2] : #-- car ADOSSIER uniquement sur dossier mère --#
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TRT_COPIE

Close Local File [TVI1], [TVI2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
If clalev([F:ADI2])>0 : Close Local File [ADI2] : Endif
If clalev([F:ACV2])>0 : Close Local File [ACV2] : Endif

Return

######################################################################################
# $TRT_COPIE
######################################################################################
$TRT_COPIE
#--------------------------------------------------#
# Transaction de copie d'une retenue               #
#--------------------------------------------------#
Local Char    LEGDES
Local Integer WMONOLEGDES
# Par défaut : Leg destination=leg de l'enregistrement à copier
LEGDES=TABLE2
GOK=1

#If TABLE2<>''
# If [M]DOSDES<>nomap
#  Local Char SZDOSSIER(GLONADS)
#  Local Integer LG
#  Read [ADI2]CODE=909; TABLE2
#  If fstat
#   Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
#   Return
#  Endif
#
#  LG = instr(1, [M]DOSDES, "@")
#  If LG = 0 Then
#    SZDOSSIER = [M]DOSDES
#  Else
#    SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
#  Endif
#  Read [ADS2]DOSSIER=SZDOSSIER
#    If !fstat Then
#      If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
#        Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
#        Return
#      Endif
#  Endif
#
# Endif
#Endif

If [M]DOSDES<>nomap
    # Le dossier destination est-il mono-leg ?
    If [F:ACV2]CODACT<>"LEG"
     Read [ACV2]CODACT = "LEG"
     If fstat Raz [F:ACV2] : Endif
    Endif
    If [F:ACV2]FLACT<>2
     WMONOLEGDES=0
    Else
     WMONOLEGDES=1
    Endif

    If WMONOLEGDES =0
        # Dossier destination mono-leg
        LG = instr(1, [M]DOSDES, "@")
        If LG = 0 Then
          SZDOSSIER = [M]DOSDES
        Else
          SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
        Endif
        Read [ADS2]DOSSIER=SZDOSSIER
        If fstat
            # Pb lecture dossier
            Call MESSAGE(SZDOSSIER-":"-mess(78,133,1) ) From GESECRAN  #-- Dossier inexistant --#
            Return
        Endif
        If [F:ADS2]DOSLEG(0)=""
            # Pas de législation pour le dossier
            Call MESSAGE(SZDOSSIER-":"-mess(241,133,1) ) From GESECRAN  #-- Il doit y avoir au moins une législation  --#
            Return
        Endif
        If TABLE2<>[F:ADS2]DOSLEG(0) & TABLE2<>''
            # La leg de l'enreg. à copier n'est pas tte leg et elle est <> Leg dossier mono-leg
            # Pas de copie
            Call MESSAGE(mess(617,199,1)-"("-[F:ADS2]DOSLEG(0)-") :"-mess(618,199,1) ) From GESECRAN
            Return
        Elsif TABLE2=''
            # La leg de l'enreg. à copier est toute leg
            # On peut copier l'enreg : Leg destination=leg du dossier mono-leg
            LEGDES=[F:ADS2]DOSLEG(0)
        Endif
    Else
        # Dossier destination multi-leg
        If TABLE2<>''
          # Enregistrement à copier avec leg<>""
          Local Char SZDOSSIER(GLONADS)
          Local Integer LG
          Read [ADI2]CODE=909; TABLE2
          If fstat
           Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
           Return
          Endif

          LG = instr(1, [M]DOSDES, "@")
          If LG = 0 Then
            SZDOSSIER = [M]DOSDES
          Else
            SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
          Endif
          Read [ADS2]DOSSIER=SZDOSSIER
          If !fstat Then
              If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
                Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
                Return
              Endif
          Endif
        Endif
    Endif
Endif

Read [TVI2]TVI0=TABLE ;LEGDES
If !fstat
    Local Integer WOK : WOK=1
    Call AVERTIR (mess(197,133,1), WOK) From GESECRAN : #-- enregistrement existe déjà --#
    If WOK=1 Return : Endif
Endif

Local Integer ILIG
Trbegin [TVI2]
  Delete [TVI2] Where VACITM=TABLE & LEG = LEGDES
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".TABVACITM"-TABLE : Goto ROLL_COPIE
  Elsif fstat GOK=0 : Call RSTA("TVI2",TABLE) From GLOCK    : Goto AB_COPIE
  Endif
  If !fstat
     #--- copie des données
     For [TVI1]Where VACITM=TABLE & LEG = TABLE2
         [F:TVI2]=[F:TVI1]
         [F:TVI2]LEG=LEGDES
         If TABLE2=LEGDES
             Call COPTEXTRA("TABVACITM","DESAXX",TABLE,TABLE2) From ATEXTRA
             Call COPTEXTRA("TABVACITM","SHOAXX",TABLE,TABLE2) From ATEXTRA
         Else
             Call COPTEXTRA1("TABVACITM","DESAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
             Call COPTEXTRA1("TABVACITM","SHOAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
         Endif
         If dim([F:TVI2]UPDUSR)>0 : [F:TVI2]UPDUSR = GUSER : Endif
         If dim([F:TVI2]UPDDAT)>0 : [F:TVI2]UPDDAT = date$ : Endif
         If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
         Write [TVI2]
         If fstat
            GOK = 0 : Call FSTA("TVI2") From GLOCK : Break
         Endif
     Next
  Endif
  If   GOK<0    : Goto ROLL_COPIE
     Elsif !GOK : Goto AB_COPIE
  Endif
Commit

Return
#----- Abandon de la copie -----#
$AB_COPIE
Rollback

Return

#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
Rollback : Call ROLL From GLOCK : If !GROLL Goto TRT_COPIE : Endif

Return
