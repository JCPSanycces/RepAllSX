#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# ALI_DOC : Alimente la ligne de document en cours (nolign-1) avec [F:STO]
#            Les valeurs de destination sont initialisées
###############################################################################
$ALI_DOC
Local Shortint WRET
Local Integer  LRET, I, NBROW
Local Char     LSEC
Local Char     VAT(GLONVAT)(3)
Local Decimal  WQTE



#---- Positionnement sur les tables ------------#
Call POSTABLE([M:LPNO]STOFCY, [F:STO]ITMREF, [F:STO]LOT, [F:STO]SLO, LRET) From SUBSCSB
If LRET
  OK=0: Return
Endif

Raz NBROW

# Ouverture de la ligne
nolign = [M:LPNO]NBLIG
Insa nolign,1,[M:LPNO]NBLIG [M:LPNO]NBLIG
[M:LPNO]NBLIG += 1
nolign = [M:LPNO]NBLIG
NOL = nolign-1
status = 73
Call INSERE("VCRLIN") From TABLEAUX
status = 71
Call LINNUM("VCRLIN") From TABLEAUX
status = 0

[M:LPNO]ITMREF(NOL) = [F:STO]ITMREF
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:LPNO]ITMDES1(NOL), "[F:ITM]") From TRTX3 # FGR 03/07/2009 : X3SUIVI56319
If dim([M:LPNO]LOT)>0
  [M:LPNO]LOT(NOL)    = [F:STO]LOT
Endif
If dim([M:LPNO]SLO)>0
  [M:LPNO]SLO(NOL)    = [F:STO]SLO
Endif
If dim([M:LPNO]ECCVALMAJ)>0
  [M:LPNO]ECCVALMAJ(NOL) = [F:STO]ECCVALMAJ
Endif
If dim([M:LPNO]PALNUMDES)>0
  [M:LPNO]PALNUMDES(NOL) = [F:STO]PALNUM
Endif
If dim([M:LPNO]CTRNUMDES)>0
  [M:LPNO]CTRNUMDES(NOL) = [F:STO]CTRNUM
Endif
[M:LPNO]STA(NOL)    = [F:STO]STA
If dim([M:LPNO]LOC)>0
  [M:LPNO]LOC(NOL) = [F:STO]LOC
Endif
If dim([M:LPNO]LOCTYP)>0
  [M:LPNO]LOCTYP(NOL) = [F:STO]LOCTYP
Endif
If dim([M:LPNO]WRHDES)>0
  [M:LPNO]WRHDES(NOL) = [F:STO]WRH
Endif
If dim([M:LPNO]SERNUM)>0
  [M:LPNO]SERNUM(NOL) = [F:STO]SERNUM
Endif
If dim([M:LPNO]STOFLD1)>0
  [M:LPNO]STOFLD1(NOL) = [F:STO]STOFLD1
Endif
If dim([M:LPNO]STOFLD2)>0
  [M:LPNO]STOFLD2(NOL) = [F:STO]STOFLD2
Endif
[M:LPNO]STADES(NOL)    = [F:STO]STA
[M:LPNO]OWNER(NOL)     = [F:STO]OWNER
[M:LPNO]PCUSTUCOE(NOL) = [F:STO]PCUSTUCOE
[M:LPNO]QLYCTLDEM(NOL) = [F:STO]QLYCTLDEM
[M:LPNO]LPNNUM(NOL)    = [F:STO]LPNNUM
#LPN destination
If [M:LPNO]MODOPELPN = 1
  [M:LPNO]LPNNUMDES(NOL) = [M:LPNO]LPNDESH
  #emplacement destination
  [M:LPNO]LOCDES(NOL)    = [M:LPNO]LOCDESH
  [M:LPNO]LOCTYPDES(NOL) = [M:LPNO]LOCTYPDESH
  If dim([M:LPNO]WRHDESH)>0
    [M:LPNO]WRHDES(NOL) = [M:LPNO]WRHDESH
  Endif
Endif

[M:LPNO]WSTOCOU(NOL) = [F:STO]STOCOU
#gestion des quantités et des unités : pas de déconditionnement
nolign=NOL+1
Gosub MAJ_STUDIS
[M:LPNO]STU(NOL)   = [F:ITM]STU
[M:LPNO]PCU(NOL)   = [F:STO]PCU
[M:LPNO]QTYPCU(NOL)=[F:STO]QTYPCU
[M:LPNO]QTYSTUDES(NOL) = [M:LPNO]STUDIS(NOL)
If [M:LPNO]PCUSTUCOE(NOL)
  [M:LPNO]QTYPCU(NOL) = [M:LPNO]QTYSTUDES(NOL) / [M:LPNO]PCUSTUCOE(NOL)
Endif
#testMAE
[M:LPNO]COEDES(NOL) = [F:STO]PCUSTUCOE
[M:LPNO]PCUDES(NOL) = [F:STO]PCU
#fin test MAE

# Si ligne avec no série pas d'accés qte en US
If dim([M:LPNO]SERNUM)>0 & [M:LPNO]SERNUM(NOL)<>""
  If dim([M:LPNO]QTYSTUDES)>0 Diszo [M:LPNO]QTYSTUDES(NOL) Endif
Endif

If dim([M:LPNO]SERNUMF)>0 & [F:ITM]SERMGTCOD = 3
  [M:LPNO]SERNUMF(NOL) = [F:STO]SERNUM
Endif

If [M:LPNO]WLOCSEQ(NOL)=0
  Call STKWLOCSEQ("LPNO", NOL, LRET) From STKECR
Endif

#gestion des zones du tableau
Case [M:LPNO]MODOPELPN
  When 1 #regroupement
    [M:LPNO]FLGSEL(NOL) = 2
    Affzo [M:LPNO]FLGSEL
    Grizo [M:LPNO]FLGSEL(NOL)
    Grizo [M:LPNO]QTYPCU(NOL)
    Grizo [M:LPNO]LPNNUMDES(NOL)
    Grizo [M:LPNO]LOCDES(NOL)
  When 2 : #éclatement
    Actzo [M:LPNO]FLGSEL(NOL)
    Actzo [M:LPNO]QTYPCU(NOL)
    Actzo [M:LPNO]LPNNUMDES(NOL)
    #lecture du LPN destination
    If [F:LPN]LPNNUM <> [M:LPNO]LPNDESH
      Read[LPN]LPN0 = [M:LPNO]LPNDESH
    Endif
    If [F:LPN]LPNSTAT = 2
      Grizo [M:LPNO]LOCDES(NOL)
    Else
      Actzo [M:LPNO]LOCDES(NOL)
    Endif
  When 3 #désaffectation
    Actzo [M:LPNO]FLGSEL(NOL)
    Actzo [M:LPNO]QTYPCU(NOL)
    Diszo [M:LPNO]LPNNUMDES(NOL)
    Actzo [M:LPNO]LOCDES(NOL)
Endcase

#gestion de l'ouverture de la fenêtre de changement contenant
[M:LPNO]OUVCHGLPN = 1 #premiére ouverture de la fenêtre

If [M:LPNO]NBLIG >=0
  Grizo [M:LPNO]MODOPELPN
Endif


  Return

###############################################################################
###############################################################################
$MAJ_STUDIS

Local Decimal WPCUDIS, WSTUDIS, WSTUACTDIS, WTOTACTDIS, WDISPO
Local Integer LTYPLOC, LSTA
#--- Bug 78712
Local Decimal WACTDIS

# On autorise de faire des changements même sur ce qui est alloué
# Il faut juste avoir la trace au moment de l'enregistrement et un message au picking
[M:LPNO]STUDIS(nolign-1) = [F:STO]QTYSTU-[F:STO]CUMWIPQTY
WACTDIS = [F:STO]QTYSTUACT-[F:STO]CUMWIPQTA


If [M:LPNO]WSTOSEQ(nolign-1)>0
   [M:LPNO]STUDIS(nolign-1) += sigma(0,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=[M:LPNO]WSTOSEQ(nolign-1))*[M:SGW]WWIPQTY(indcum))
Endif

Affzo [M:LPNO]STUDIS(nolign-1)

Return
###############################################################################
# CTLSTOCHG : Effectue divers contrôle pour s'assurer d'un bon enregistrement
###############################################################################
# Paramètres S : POK = Indique si le contrôle est bon
#                      (0=Erreur / 1=OK)
###############################################################################
Subprog CTLSTOCHG( POK )
Variable Integer POK

Local Decimal WARR, WQTYPCU
#Local Decimal WPCUDIS, WSTUDIS, WSTUACTDIS
Local Integer I,J
Raz POK,I,J

If GREP<>"M" & sigma( 0,[M:LPNO]NBLIG-1, [M:LPNO]CREFLG(indcum)=0)=0
    End
Endif


# Contrôle que la qté US correspond à un nombre entier d'UC
# (fonction du nb de décimales de l'UC)
If !clalev([F:TUN]) Local File TABUNIT [TUN] Endif

#--- Issue 113595
POK=1

For I=0 To [M:SGW]NBLIG-1
  If [M:LPNO]MODOPELPN  = 1 | ([M:LPNO]MODOPELPN <> 1 & [M:LPNO]FLGSEL(I) = 2)
    If [M:SGW]WSTOSEQ(I)<>0 & !find([M:SGW]WCOEDES(I),0,1)
        Read [TUN]TUN0=[M:SGW]WPCUDES(I)
        If !fstat
            Case [F:TUN]UOMDEC
             When 1       : WARR=0.1
             When 2       : WARR=0.01
             When 3       : WARR=0.001
             When 4       : WARR=0.0001
             When 5       : WARR=0.00001
             When 6       : WARR=0.000001
             When Default : WARR=1
            Endcase
            WQTYPCU = arr([M:SGW]WQTYPCUDES(I),WARR)
            If WQTYPCU<>[M:SGW]WQTYPCUDES(I)
                J=find([M:SGW]WSTOSEQ(I),[M:LPNO]WSTOSEQ(0..[M:LPNO]NBLIG-1))
                If J<>0
                    Call ECR_TRACE([M:LPNO]ITMREF(J-1)-":"-mess(160,184,1)-"("+[M:SGW]WPCUDES(I)+")",1) From GESECRAN
                Else
                    Call ECR_TRACE(mess(160,184,1)-"("+[M:SGW]WPCUDES(I)+")",1) From GESECRAN
                Endif
                #--- Issue 113595
                #End
                POK=0 : Break
                #---
            Endif
        Endif
    Endif
  Endif
Next I

#--- Issue 113595
#POK = 1
#                                                                  # hcb 110327 deb
If find("",[M:LPNO]LPNNUM(0..[M:LPNO]NBLIG-1)) <> 0
  GMESSAGE=mess(513,184,1)
  POK=0 : End
Endif

For I=0 To [M:LPNO]NBLIG-1
 If [M:LPNO]FLGSEL(I) = 2 & [M:LPNO]WSTOSEQ(I)<>0
  #contenant destination obligatoire
  If [M:LPNO]MODOPELPN <> 3 & [M:LPNO]LPNNUMDES(I) = AVOID.ACHAR
    GMESSAGE=mess(3,40,1)-num$(I+1)-mess(525,184,1)
    POK=0 : Break
  Endif
  #emplacement destination obligatoire
  If [M:LPNO]LOCDES(I) = AVOID.ACHAR
    GMESSAGE=mess(3,40,1)-num$(I+1)-mess(536,184,1)
    POK=0 : Break
  Endif

    If [F:ITM]ITMREF<>[M:LPNO]ITMREF(I)
       Read [ITM]ITM0=[M:LPNO]ITMREF(I)
       If fstat
          Raz [F:ITM]
       Endif
    Endif
    If [F:ITM]SERMGTCOD = 4
        J=find([M:LPNO]WSTOSEQ(I),[M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))
          If [M:SGW]WSERNUM(J-1) = "" & [M:SGW]WQTYSTUDES(J-1) <> 0
             GMESSAGE=mess(3,40,1)-num$(I+1)-mess(246,199,1)
             POK=0    : Break
          Endif
    Endif
   #controle quantité supérieure à 0
   If [M:LPNO]QTYSTUDES(I) = 0
      GMESSAGE=mess(83,182,1)
      POK=0    : Break
   Endif
 Endif
Next
#                                                                  # hcb 110327 end

End

###############################################################################
# ALISTW : Alimente le masque STOWORK et effectue la mise à jour des tables stock
###############################################################################
# Paramètres E : PNOL = indice de la ligne en cours d'enregistrement
###############################################################################
Subprog ALISTW( PNOL )
Value Integer PNOL
Local Decimal LQTA
Local Decimal LSHT
Local Integer LRET
Local Integer LNBR, LNBJ
# Initialisation de l'en-tête
[M:STW]STOFCY     = [M:LPNO]STOFCY      # Site
[M:STW]TRSTYP     = 7      #
[M:STW]VCRTYP     = [M:LPNO]VCRTYP      # Type pièce (M.701)
[M:STW]VCRNUM     = [F:SGD]VCRNUM       # Numéro pièce
[M:STW]VCRLIN     = [F:SGD]VCRLIN       # Numero ligne pièce
[M:STW]ITMREF     = [M:LPNO]ITMREF(PNOL) # Article
[M:STW]MVTDES     = [M:LPNO]MVTDES(PNOL) # Désignation mouvement
If GIMPORT                                # hcb 119744
   [M:STW]MVTDES     = [F:STJ]MVTDES      # hcb 119744
Endif                                     # hcb 119744
#[M:STW]TRSFAM     = [M:LPNO]TRSFAM      # Famille mouvement
#[M:STW]ENTCOD     = [M:LPNO]ENTCOD      # Famille mouvement
[M:STW]IPTDAT     = [M:LPNO]IPTDAT      # Date imputation
[M:STW]TRSCOD     = ""      # Code mouvement
[M:STW]LPNNUM     = [M:LPNO]LPNNUM(PNOL)

Call ALISTOWORK( 7, [M:LPNO]WSTOSEQ(PNOL), LQTA, LSHT, LNBR, LNBJ, LRET ) From STKINT
If !LRET
   Call MAJ_STOCK From STKMAJ
Else
   GOK = 0
Endif

End
###############################################################################
# MAJQTY : Mise à jour des quantités et n° de série après modif
#            de QTYPCU ou QTYSTUDES
###############################################################################
# Paramètres E : PCOD = 1: MAJ de QTYSTUDES
#                       2: MAJ de QTYPCU
#                PVAL = Nouvelle valeur
#            S : PRET = Code retour (0:OK / 1:Erreur)
###############################################################################
Subprog MAJQTY( PCOD, PVAL, PRET )
Value    Integer PCOD
Value    Decimal PVAL
Variable Integer PRET

Local Decimal LQTYSTU
Local Integer LNOL          : LNOL = nolign-1
Local Char    LSERF(GLONSER)

Raz PRET

If PCOD=1
    LQTYSTU = PVAL*[M:LPNO]PCUSTUCOE(LNOL)
    Call QTEARR(LQTYSTU, [M:LPNO]STU(LNOL)) From TRTDIV
Else
    LQTYSTU=PVAL
Endif

If [F:ITM]SERMGTCOD=3
    LSERF = [M:LPNO]SERNUM(LNOL)
    For I=2 To LQTYSTU
        Call PLUS_UN(LSERF,LSERF,PRET) From STKLIB
        If PRET : Break : Endif
    Next
    If PRET
        GMESSAGE = mess(476,197,1)
        PRET = 1
        End
    Endif
    [M:LPNO]SERNUMF(LNOL) = LSERF
Else
    If [M:LPNO]STUDIS(LNOL) < LQTYSTU
        GMESSAGE = mess(207,197,1)
        PRET = 1
        End
    Endif
Endif

[M:LPNO]QTYSTUDES(LNOL) = LQTYSTU    # On l'affecte dans tous les cas pour le calcul de STUDIS
If PCOD=1
    Affzo [M:LPNO]QTYSTUDES(LNOL)
Else
    [M:LPNO]QTYPCU(LNOL) = LQTYSTU / [M:LPNO]PCUSTUCOE(LNOL)
    Affzo [M:LPNO]QTYPCU(LNOL)
Endif

Gosub MAJ_STUDIS

End

###############################################################################
# DEPICK : Depick d'une ligne de stock
###############################################################################
# Paramètres E : PSTOFCY = Site
#                PSTOCOU = Chrono stock
#                PABR    = Abréviation de l'écran document
#                PRET    = Code retour (0=OK, 1=Erreur)
#
# Il faut faire Affzo du mask en sortie
###############################################################################
Subprog DEPICK(PSTOFCY, PSTOCOU, PABR, PRET)
Value Char    PSTOFCY
Value Decimal PSTOCOU
Value Char    PABR
Variable Integer PRET

Local Integer  LRET
Local Shortint WRET
Local Integer  LSEQ
Local Integer  I1, LLIGDOC
Local Decimal  LWIPQTY, LWIPQTA
Local Integer  LNB
Local Char     LPCU(GLONUOM)
Local Decimal  LCOEF, LQTYSTYU
Local Decimal  LSTOCOU
Local Char     LSERF(GLONSER)
Local Integer  WTRBEGIN



Local Char     LABR(10) : LABR = PABR    # Utilisée dans MAJ_LIG_DOC


#-- Toute sortie prématurée est signe d'erreur
PRET = 1

Raz WTRBEGIN
If clalev([F:STO1])=0  Local File STOCK   [STO1]  Endif
If clalev([F:SWW]) =0  Local File STOWIPW [SWW]   Endif

# Si pas de transaction en cours
If adxlog<>1
#   GOK=0     hcb  40625
   Trbegin [STO1]
   WTRBEGIN=1
Endif

Readlock [STO1]STO0=PSTOFCY;PSTOCOU
If fstat
    Goto ENDTRANSAC
Endif

If [F:STO1]SERNUM<>""
    I1 = find(PSTOCOU, [M:SGW]WSTOCOU(0..[M:SGW]NBLIG-1))
    If !I1 : Goto ENDTRANSAC : Endif
    I1 -= 1
    LSEQ = [M:SGW]WSTOSEQ(I1)
    LLIGDOC = evalue("find(LSEQ, [M:"+PABR+"]WSTOSEQ(0..[M:"+PABR+"]NBLIG))")
    If !LLIGDOC : Goto ENDTRANSAC : Else LLIGDOC-=1 : Endif
    If [F:STO1]SERNUM<>evalue("[M:"+PABR+"]SERNUMF(LLIGDOC)")
        GMESSAGE = mess(58,184,1)+evalue("[M:"+PABR+"]SERNUMF(LLIGDOC)")
        Goto ENDTRANSAC
    Endif
    [M:SGW]WSTOSEQ(I1)   = 0
    [M:SGW]WSTOCOU(I1)   = 0
    [M:SGW]WQTYPCUDES(I1)= 0


    # Dans le cas où l'on serait passé en négatif
    LWIPQTY = min([F:STO1]CUMWIPQTY, [F:STO1]QTYSTU)
    LWIPQTA = min([F:STO1]CUMWIPQTA, [F:STO1]QTYSTUACT)
    [F:STO1]CUMWIPQTY -= LWIPQTY
    [F:STO1]CUMWIPQTA -= LWIPQTA
    # Suppression qté en cours de traitement
    LSTOCOU = [F:STO1]STOCOU
    Call DEL_STOWIPW(LSTOCOU,LWIPQTY) From STKLIB
    Rewrite [F:STO1]
#                                                                                               # hcb 110327 deb
    If [M:SGW]WSTOSEQIND(I1) <> 0 & [M:SGW]WSERNUM(I1) <> ""
       # Suppression série en cours de traitement
       Call DEL_STOSERW([F:STO]ITMREF,[M:SGW]WSERNUM(I1),[M:SGW]WQTYSTUDES(I1),PRET) From STKLIB
       If PRET <>0
          Goto ENDTRANSAC
       Endif
    Endif
    [M:SGW]WQTYSTUDES(I1)= 0
#                                                                                               # hcb 110327 fin
    If evalue("[M:"+PABR+"]QTYSTUDES(LLIGDOC)")=1

        Dela LLIGDOC,1 [M:LPNO]NBLIG
        [M:LPNO]NBLIG -= 1
    Else
        LNB = sigma(0,[M:SGW]NBLIG-1,[M:SGW]WSTOSEQ(indcum)=LSEQ)
        I1 = find (LSEQ,[M:SGW]WSTOSEQ)-1
        If I1>=0
            LPCU = [M:SGW]WPCUDES(I1)
            LCOEF = [M:SGW]WCOEDES(I1)
            LPCU = string$( !!( sigma(I1,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=LSEQ)&(LPCU=[M:SGW]WPCUDES(indcum)))=LNB), LPCU)
            LCOEF = (!!( sigma(0,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=LSEQ)&([M:SGW]WCOEDES(indcum)=LCOEF))=LNB))* LCOEF
            LQTYSTU = sigma(0,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=LSEQ)*[M:SGW]WQTYSTUDES(indcum))
            If evalue("dim([M:"+PABR+"]SERNUMF(LLIGDOC))")>0
                Call MOINS_UN([F:STO1]SERNUM,LSERF,LRET) From STKLIB
                Assign "[M:"+PABR+"]SERNUMF(LLIGDOC)" With LSERF
            Endif
            Gosub MAJ_LIG_DOC From SUBSCSB
        Endif
        nolign=LLIGDOC+1
        Gosub MAJ_STUDIS
    Endif
Else
    #--- On cherche la ligne dans le document
    LLIGDOC = evalue("find(PSTOCOU, [M:"+PABR+"]WSTOCOU(0..[M:"+PABR+"]NBLIG))")
    If !LLIGDOC : Goto ENDTRANSAC : Else LLIGDOC-=1 : Endif

    #--- On fait le ménage dans STOCHGW et dans le document
    Call DELSTOCHGW(PABR, PSTOFCY, LLIGDOC, LLIGDOC, 1, LRET) From SUBSCSB
    Dela LLIGDOC,1 [M:LPNO]NBLIG
    [M:LPNO]NBLIG -= 1
Endif

Affzo [M:LPNO]

Raz PRET

GOK=1

$ENDTRANSAC
# Si on a ouvert une transaction
If WTRBEGIN=1
   If GOK : Commit : Else : Rollback : Endif
   Raz WTRBEGIN
Endif

End

