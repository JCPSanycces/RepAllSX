#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
######################################################################################
Subprog B1_NBLIG
Local Integer STAT
If clalev([F:PTDKD])= 0 : Local File DKSDATA [PTDKD] : Endif

Call SENDDTTOAT([M:TDC1]NUM(nolign-1), [M:TDC1]LINDOCTYP(nolign-1), [L]STAT) From PORLEGLIB
If [L]STAT=0
  Read [F:PTDKD]DKD0="SAFT-PT";[M:TDC1]LINDOCTYP1(nolign-1);[M:TDC1]NUM(nolign-1)
  If !fstat
    [M:TDC1]ATDTCOMSTA(nolign-1)   = [F:PTDKD]ATDTCOMSTA
    [M:TDC1]ATDTINPTYP(nolign-1)   = [F:PTDKD]ATDTINPTYP
    [M:TDC1]ATDTCOD(nolign-1)      = [F:PTDKD]ATDTCOD
    Affzo [M:TDC1]ATDTCOD(nolign-1)
    Affzo [M:TDC1]ATDTCOMSTA(nolign-1)
    Affzo [M:TDC1]ATDTINPTYP(nolign-1)
  Endif
Endif

End
######################################################################################
######################################################################################
Subprog B2_NBLIG

If dim(VARIA)>0 : Raz VARIA : Endif

Case [M]LINDOCTYP(nolign-1)
  When 2
    Call EXEFNCK("GESSDH","",[M:TDC1]NUM(nolign-1)) From EXEFNC
  When 3
    Call EXEFNCK("GESSRH","",[M:TDC1]NUM(nolign-1)) From EXEFNC
  When 4
    Call EXEFNCK("GESSRL","",[M:TDC1]NUM(nolign-1)) From EXEFNC
  When 5
    Call EXEFNCK("GESSRS","",[M:TDC1]NUM(nolign-1)) From EXEFNC
  When 6
    Call EXEFNCK("GESSIS","",[M:TDC1]NUM(nolign-1)) From EXEFNC
  When 7
    Call EXEFNCK("GESSST","",[M:TDC1]NUM(nolign-1)) From EXEFNC
  When 8
    Call EXEFNCK("GESSTR","",[M:TDC1]NUM(nolign-1)) From EXEFNC
  When 9
    Call EXEFNCK("GESPNH","",[M:TDC1]NUM(nolign-1)) From EXEFNC
  When 10
    Call EXEFNCK("GESTNH","",[M:TDC1]NUM(nolign-1)) From EXEFNC
Endcase

End
######################################################################################
######################################################################################
Subprog B3_NBLIG

Local Integer I

If [M:TDC0]FLGSTA = 2
   [M:TDC0]FLGSTA = 1
Else
   [M:TDC0]FLGSTA = 2
Endif

For I = 0 To [M:TDC1]NBLIG-1
   If vireblc([M:TDC1]ATDTCOD(I),2) = ""
      [M:TDC1]FLG(I) = [M:TDC0]FLGSTA
   Endif
Next

Affzo [M:TDC1]

End
######################################################################################
######################################################################################
Subprog IB_NBLIG

GBOUT2 = "Document"-[M:TDC1]NUM(nolign-1)

If vireblc([M:TDC1]ATDTCOD(nolign-1),2) <> ""
   Diszo [M:TDC1]FLG(nolign-1)
   Raz GBOUT1
Else
   Actzo [M:TDC1]FLG(nolign-1)
Endif

End
######################################################################################
######################################################################################
Subprog AV_FLG(VALEUR)
Variable Integer    VALEUR()

If vireblc([M:TDC1]ATDTCOD(nolign-1),2) <> ""
  mkstat = 2
Endif

End
######################################################################################
######################################################################################
Subprog AS_ATDTCOD(VALEUR)
Variable Char    VALEUR()

If ([M:TDC1]ATDTINPTYP(nolign-1) > 1 & VALEUR <> "") #| ([M:TDC1]ATDTINPTYP(nolign-1) = 1 & pat([M:TDC1]ATDTCOMSTA(nolign-1),"0*"))
  Diszo [M:TDC1]ATDTCOD(nolign-1)
  mkstat = 2
Else
 If func AFNC.PARAMUTIL('ATCODCHG', GUSER, '') ='2'# &  [M:TDC1]ATDTINPTYP(nolign-1)=1
  Actzo [M:TDC1]ATDTCOD(nolign-1)
 Else
  Diszo [M:TDC1]ATDTCOD(nolign-1)
  mkstat = 2
 Endif
Endif

End
######################################################################################
######################################################################################
Subprog AM_ATDTCOD(VALEUR)
Variable Char    VALEUR()

[M:TDC1]UPDFLG(nolign-1) = 2
[M:TDC1]ATDTINPTYP(nolign-1) = 1
Affzo [M:TDC1]ATDTINPTYP(nolign-1)

End
######################################################################################
######################################################################################
Subprog AS_DOCNUMSTR(VALEUR)
Variable Char    VALEUR()

If [M:TDC0]DOCTYP = 1
  mkstat = 2
  Diszo [M:TDC0]DOCNUMSTR
Endif

End
######################################################################################
######################################################################################
Subprog AM_DOCNUMSTR(VALEUR)
Variable Char    VALEUR()

If [M:TDC0]DOCNUMEND = ""
  [M:TDC0]DOCNUMEND = VALEUR
  Affzo [M:TDC0]DOCNUMEND
Endif

End
######################################################################################
######################################################################################
Subprog AS_DOCNUMEND(VALEUR)
Variable Char    VALEUR()

If [M:TDC0]DOCTYP = 1
  mkstat = 2
  Diszo [M:TDC0]DOCNUMEND
Endif

End
######################################################################################
######################################################################################
Subprog AM_BPRNUMSTR(VALEUR)
Variable Char    VALEUR()

If [M:TDC0]BPRNUMEND = ""
  [M:TDC0]BPRNUMEND = VALEUR
  Affzo [M:TDC0]BPRNUMEND
Endif

End
######################################################################################
######################################################################################
