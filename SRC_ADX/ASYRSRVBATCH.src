#<AdxTL>@(#)9.0.0.0 $Revision$
#example POST : http://localhost:8124/sdata/x3/erp/SUPERV/$service/batch?requestId=<REQNUM>
Funprog _EXPORTED() : End 1
#**
#* Funprog HANDLER_POST()
#*!
Funprog HANDLER_POST(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Gosub READ_PAYLOAD_REQUEST

Local Char WCHREQUEST(50)
Local Integer WREQUEST
Local Integer ERROR : ERROR=[V]CST_AOK
Local Integer I
For I=1 To maxtab(ARCV.PARAMCOD)
 Case toupper(ARCV.PARAMCOD(I))
  When "REQUESTID" : WCHREQUEST=toupper(ARCV.PARAMVAL(I))
 Endcase
Next I
If WCHREQUEST="" | val(WCHREQUEST)=0
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(122,134,1))
 End ERROR
Endif
WREQUEST=val(WCHREQUEST)
#117092
If dim([S]adxtrp)>0 & dim([S]adxtrl)>0
  Local Char ASYRSRVBATCHTRP(type([S]adxtrp)-10)
  Local Char ASYRSRVBATCHTRL(type([S]adxtrl)-10)
  ASYRSRVBATCHTRP = [S]adxtrp
  ASYRSRVBATCHTRL = [S]adxtrl
  If func EXISTE("ATRIFIL")
   [S]adxtrp = "ATRIFIL" : # Traitement appelé par les Write/Rewrite/Update
   [S]adxtrl = "ATRIOPE" : # Etiquette appelée par les Write/Rewrite/Update
  Endif
Endif
Gosub EXEC_REQUEST
#117092
If dim([S]adxtrp)>0 & dim([S]adxtrl)>0 & dim(ASYRSRVBATCHTRP)>0 & dim(ASYRSRVBATCHTRL)>0
 [S]adxtrp = ASYRSRVBATCHTRP : # Traitement appelé par les Write/Rewrite/Update
 [S]adxtrl = ASYRSRVBATCHTRL : # Etiquette appelée par les Write/Rewrite/Update
Endif
If dim(ERROR)>0
End ERROR
Endif
End [V]CST_AOK

#####################################################
Funprog EXISTE(TRT)
Value Char TRT
Local Integer OKTRT
Call EXISTE_ADX("","",TRT,OKTRT) From ASYRSYS
End OKTRT


################################################################
$READ_PAYLOAD_REQUEST
Local Instance  PNODE          Using C_ASYRJSO
Local Integer ASYRB_MAXDELAY
Local Char CTRLFOLDER(GLONADS)
Local Char CTRLLOGIN(GLONALO)
Local Char CTRLLANISO(GLONLAN)
#1°) Loop on node
PNODE=JSON
While PNODE <> null
 Case toupper(PNODE.PRO)
  When "MAXDELAY" : ASYRB_MAXDELAY=val(fmet PNODE.AGETCNT)
  When "CTRLFOLDER" : CTRLFOLDER=toupper(fmet PNODE.AGETCNT)
  When "CTRLLOGIN" : CTRLLOGIN=toupper(fmet PNODE.AGETCNT)
  When "CTRLLANISO" : CTRLLANISO=fmet PNODE.AGETCNT
 Endcase
 PNODE = PNODE.NEX
Wend
Return

################################################################
$EXEC_REQUEST
Gosub INIT_VAR

GBATCHRQT=num$(WREQUEST)
Read [ABR]NUMREQ=WREQUEST
If fstat
 If OKTRA : Call TRACE_LOG(adxmac(-2)-"Ask request"-num$(WREQUEST)-"(fstat="+num$(fstat)+")",0,0) From SERVEUR : Endif
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,func ASYRFNC.MES1(mess(123,134,1), num$(WREQUEST)))
 Return
Elsif [F:ABR]FLAG<>1
 If OKTRA : Call TRACE_LOG(adxmac(-2)-"Ask request"-num$([F:ABR]NUMREQ)-"([f:abr]flag="+num$([F:ABR]FLAG)+")",0,0) From SERVEUR : Endif
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,func ASYRFNC.MES1(mess(123,134,1), num$(WREQUEST)))
 Return
Else
  If OKTRA : Call TRACE_LOG(adxmac(-2)-"Ask request"-num$([F:ABR]NUMREQ)-"([f:abr]flag="+num$([F:ABR]FLAG)+")",0,0) From SERVEUR : Endif
Endif

# X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
Call SCHEDULING_DATE_TIME   ( [L]DD, [L]HH, [L]HS) From SERVEUR
If [F:ABR]DAT<DD or ([F:ABR]DAT=DD & [F:ABR]HEURE<=HH)
 Read [ABT]CODTAC = [F:ABR]TACHE
 Gosub RETARD From SERVEUR
 If !RETARD
  If OKTRA : Call TRACE_LOG("Exec pending request"-num$([F:ABR]NUMREQ)-[F:ABR]TACHE-"("+[F:ABR]DOSSIER+")",0,0) From SERVEUR : Endif
  Gosub EXEC_RQT From SERVEUR
 Endif
Else
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,func ASYRFNC.MES1(mess(123,134,1), num$(WREQUEST)))
 Return
Endif
Close Local File
If RETARD
 Return
Endif

Local Char     APPLI(GLONADS)
GTRACE = func SERVSYS.GET_FILE_RQT(format$("N0:8#",WREQUEST),"")    # Issue X3-70499 - 2018-03-05 by CCC : no extension file
If GTRACE=""
     ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_OK,mess(86,133,1)-func SERVSYS.GET_BATCH_TRA_DIRECTORY("", ""), num$(WREQUEST))
     Return
Endif
#inutile
#Call RQT_PID("RQT"+format$("N0:8#",WREQUEST)) From SERVSYS
Openo filpath("TRA",GTRACE,"tra") , -1
Call INIREQ From REQUETES
Gosub EXECTRT
Call FINREQ From REQUETES
Raz GTRACE
Return

$EXECTRT
If GOK=1 & GTRT<>""
 Run =GTRT : # mb 22.10.03 Onerrgo impossible
Endif
Return

################################################################
# batch server management from RPC
################################################################
$ACTION
Case ACTION
 When "ABATCH_MNGT_ALLPARGET" : Gosub ABATCH_MNGT_ALLPARGET
 When "ABATCH_MNGT_SERVREQ"   : Gosub ABATCH_MNGT_SERVREQ
 When "ABATCH_STOP_SERVREQ"   : Gosub ABATCH_STOP_SERVREQ
 When "ABATCH_STOP_RECURRENT" : Gosub ABATCH_STOP_RECURRENT
 When "ABATCH_MNGT_ALLREQ"    : Gosub ABATCH_MNGT_ALLREQ
 When "ABATCH_MNGT_ALLERR"    : Gosub ABATCH_MNGT_ALLERR
Endcase
Return

################################################################
# ACTION POSTED BY SYRACUSE : ABATCH_MNGT_ALLPARGET - Executed 1 time but no more called in the Batch Server
################################################################
$ABATCH_MNGT_ALLPARGET
Local File ABATPAR [ABP]
Read [ABP]SPOOL First
If fstat
 GOK=0 : GMESSAGE = mess(12,100,1)-"ABATPAR"
 Return : # Erreur d'accès sur le fichier
Endif
#RETURNCLB
 RETURNCLB='"execInterval" :'+num$([F:ABP]TEMPS)+","
 RETURNCLB-='"killOverTime" :'+num$([F:ABP]TIMOUT)+","
 RETURNCLB-='"maxDelay" :'+num$([F:ABP]RETARD)+","
 RETURNCLB-='"maxQueries" :'+num$([F:ABP]NBTACHE)
Return


################################################################
$READ_PAYLOAD_1
Local Instance  PNODE          Using C_ASYRJSO
Local Char WSERVER(GLONAMC)
Local Char WFOLDER(GLONADS)
Local Char WPORT(10)
Local Integer I,J
Local Integer ASYRB_MAXDELAY

#1°) Loop on node
PNODE=JSON
While PNODE <> null
 Case toupper(PNODE.PRO)
  When "SERVER" : WSERVER=toupper(fmet PNODE.AGETCNT)
  When "PORT"   : WPORT=fmet PNODE.AGETCNT
  When "FOLDER" : WFOLDER=toupper(fmet PNODE.AGETCNT)
  When "MAXDELAY" : ASYRB_MAXDELAY=val(fmet PNODE.AGETCNT)
 Endcase
 PNODE = PNODE.NEX
Wend
If left$(WSERVER,1)='"'
 WSERVER=mid$(WSERVER,2,len(WSERVER)-2)
Endif
If left$(WPORT,1)='"'
 WPORT=mid$(WPORT,2,len(WPORT)-2)
Endif
If left$(WFOLDER,1)='"'
 WFOLDER=mid$(WFOLDER,2,len(WFOLDER)-2)
Endif
# Issue 57975 - 2017-10-12 by CCC : server & port sent by syracuse don't correspond to actual server & port => it's useless and wrong to test !
#If WSERVER="" | WPORT=""
# ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(118,134,1)-'server:'+WSERVER-'port:'+WPORT)
#Elsif val(WPORT)<>adxtcp
# ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(121,134,1)-'port:'+WPORT-'adxtcp:'+num$(adxtcp))
#Else
# I=instr(1,WSERVER,".")
# J=instr(1,adxmac(-1),".")
# If I & J
#  If WSERVER<>toupper(adxmac(-1))
#   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(121,134,1)-'server:'+WSERVER-'adxmac(-1):'+adxmac(-1))
#  Endif
# Elsif I
#  If left$(WSERVER,I-1)<>toupper(adxmac(-1))
#   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(121,134,1)-'server:'+WSERVER-'adxmac(-1):'+adxmac(-1))
#  Endif
# Elsif J
#  If WSERVER<>toupper(left$(adxmac(-1),J-1))
#   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(121,134,1)-'server:'+WSERVER-'adxmac(-1):'+adxmac(-1))
#  Endif
# Endif
#Endif
Return

################################################################
$INIT_VAR
GOK=1
Local File ABATPAR [ABP]

Local Integer OK, MORT, ERR , TT , TX
Local Char    PROCESS(30)
Local Char    MESSA(50) , ERRMES(50)
Local Char    FICTRA(GDIMFIC)
Local Char    FICTRATECH(GDIMFIC)    # Technical log (messages concerning only batch server, not requests)
Local Char    FICTRQ(GDIMFIC)
Local Char    FICJOB(GDIMFIC)

Read [ABP]SPOOL First

[L]FICTRA     = func SERVSYS.GET_FILE_SERVEUR("tra")         # Issue X3-70499 - 2018-03-05 by CCC : whole path => with extension file
[L]FICTRATECH = func SERVSYS.GET_FILE_SERVEUR_TECH("tra")    # Issue X3-70499 - 2018-03-05 by CCC : add technical log

Local Char    MESSA(250) , MESSTOP(80) , UTIL(10), MESSAGE(250), OUTPUT_LOGNAME(100)
Local Char    PID(10)
Local Integer X3SESSIONID   # X3-55215
Local Integer ENTREE, MORT, MINUTES, TEMPS, KILSRV, KILRQT, STAT , KILRECURRENT
Local Integer MAXPROC , NBPROC , FLG , GRPNUM(3) , CPT
Local Char    MACHINE(GDIMFIC)(1..2)
Local Char    RQTID(50)
Local Integer TT , TX , OKPAR , OKDOS , OKDAT , RETARD , KILJOB , ERR
Local Integer NUMLIG , REQNUM , CNTERR , NUMLOO , TRASRV , OKTRA
Local Char    HREQ(10),CRITERIA(250)
Local Char    HH(10), HS(10)
Local Integer SS
Local Date    DD
Local Integer LECTRACE, PREVFLAG
Local Char    PARENT_ACTION (50) : # Title of the ACTION where we come from
Local Integer GRPSEQ   # Issue X3-59123 - 2018-05-29 by CCC : add sequence in group of tasks


Local File ABATRQT   [ABR], ABATRQT   [ABR2], ABATTAC  [ABT]
&        , ABATABT   [ABA], ABATABTD [ABD], ABATGRP  [ABG]
&        , ABATCAL   [ABC], ABATHOR  [ABH], ABATRQTL [ABL]

# Géode

If dim([F:ABR]FCY)>0
 Global Char GFCY(type([F:ABR]FCY)-10)
Endif
If dim([F:ABR]DEP)>0
 Global Char GDEP(type([F:ABR]DEP)-10)
Endif
Filter [ABR]
Filter [ABR2]
OKTRA=1
Return

################################################################
# ACTION POSTED BY SYRACUSE : ABATCH_MNGT_SERVREQ - Executed in a Loop for every Application server Runtime of the Batch Server
################################################################
$ABATCH_MNGT_SERVREQ
Gosub READ_PAYLOAD_1
If ERROR<>[V]CST_AOK : Return : Endif
Gosub INIT_VAR

Gosub ETAT_RQT From SERVEUR
# Gosub TIMOUT From SERVEUR
Gosub TRTJOB   From SERVJOB
Return


################################################################
# ACTION POSTED BY SYRACUSE : ABATCH_STOP_SERVREQ - PREVIOUSLY Executed in a Loop for every Application server Runtime of the Batch Server
#                                                 - NOW Executed just 1 time with 1 Application server Runtime of the Batch Server
################################################################
$ABATCH_STOP_SERVREQ
Gosub READ_PAYLOAD_1
If ERROR<>[V]CST_AOK : Return : Endif
Gosub INIT_VAR

Call STRACE(FICTRA,56000,0,mess(6,134,1)-WSERVER-"("+WPORT+")") From SERVEUR

Gosub STOP_RECURRENT
Gosub STOP_REQUEST
Return

$STOP_REQUEST
# X3-64516 - JPGA - 2017-12-18 : Manage the kill of a session in Batch requests ( in multi-runtime environments with Load balancer such as Mindo : impossible to test adxmac(-1))
Filter [ABR2] Where [F:ABR2]FLAG=2
For [ABR2]
 Gosub TR_STOP
 If GOK<1
  ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,0,GMESSAGE)
  Raz GMESSAGE
  GOK=1
 Endif
Next

KILRECURRENT=1
Gosub ETAT_RQT From SERVEUR
KILRECURRENT=0

Filter [ABR2]
Return

################################################################
# ACTION POSTED BY SYRACUSE : ABATCH_STOP_RECURRENT - Executed 1 time for 1 Request using 1 Application server Runtime of the Batch Server
################################################################
$ABATCH_STOP_RECURRENT
Gosub READ_PAYLOAD_1
If ERROR<>[V]CST_AOK : Return : Endif
If WFOLDER=""
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(124,134,1))
 Return
Endif
Gosub INIT_VAR

$STOP_RECURRENT
# X3-64516 - JPGA - 2017-12-18 : Manage the kill of a session in Batch requests ( in multi-runtime environments with Load balancer such as Mindo : impossible to test adxmac(-1))
If WFOLDER="" : #117002
 Filter [ABR2] Where [F:ABR2]FLAG=2 & [F:ABR2]FRQ<>0
Else
 Filter [ABR2] Where [F:ABR2]FLAG=2 & [F:ABR2]DOSSIER=WFOLDER & [F:ABR2]FRQ<>0
Endif
KILRECURRENT=1 :#117002
For [ABR2]
 Gosub TR_STOP
 If GOK<1
  ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,0,GMESSAGE)
  Raz GMESSAGE
  GOK=1
 Endif
Next
KILRECURRENT=0 :#117002
Filter [ABR2]

# X3-59028 - 2018-02-22 JPGA - Accounting_Task has been removed and managed like other Batch task
# X3-59028 - Code removed

KILRECURRENT=1
Gosub ETAT_RQT From SERVEUR
KILRECURRENT=0

Filter [ABR2]
Return


$TR_STOP
GOK=1
Call DEBTRANS From GLOCK
Local Char SYMBOLE(20)
If [F:ABR2]CODABT<>""
 SYMBOLE = "ABA"+[F:ABR2]CODABT
 Lock =SYMBOLE With lockwait=0
 If fstat
  GOK=-1 : GLOCK="$ABATABT"-[F:ABR2]CODABT
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR_STOP : Endif
 Endif
Endif
Gosub TR_INTERR
If [F:ABR2]CODABT<>""
 Unlock =SYMBOLE
Endif
Return

$TR_INTERR
GOK=1
Call DEBTRANS From GLOCK
Local Integer NEWFLAG
Trbegin [ABR] , [ABT]

 Readlock [ABR]NUMREQ = [F:ABR2]NUMREQ
 If fstat=1
  GOK=-1 : GLOCK="$ABATRQT"-num$([F:ABR2]NUMREQ) : Goto ROLL_INTERR
 Elsif fstat>=5
  GOK=0 : Call RSTA("ABR",num$([F:ABR2]NUMREQ)) From GLOCK
  Goto AB_INTERR
 Endif

 If [F:ABR2]CODABT<>""
  Readlock [ABA]CODABT = [F:ABR2]CODABT
  If fstat=1
   GOK=-1 : GLOCK="$ABATABT"-[F:ABR2]CODABT : Goto ROLL_INTERR
  Elsif fstat>=5
   GOK=0 : Call RSTA("ABA",[F:ABR2]CODABT) From GLOCK
   Goto AB_INTERR
  Endif
 Endif

 [L]PREVFLAG=[F:ABR]FLAG
 If [F:ABR]FLAG=2 : NEWFLAG=5
 Elsif [F:ABR]FLAG=1 : NEWFLAG=7
 Else NEWFLAG=[F:ABR]FLAG
 Endif

  Gosub IDENT_RQT          From SERVEUR
  Gosub INIT_PARENT_ACTION From SERVEUR
  MESSA = func AFNC.MES3(mess(114,134,1),num$([F:ABR]NUMREQ),mess([L]PREVFLAG,21,1),mess(NEWFLAG,21,1)) #   Modification of the request status $1$: $2$ -> $3$
  ERR = 30000
  Call STRACE(FICTRA,ERR,[F:ABR]NUMREQ,[L]PARENT_ACTION+" - Query Stop management:"-MESSA-"("+RQTID+")") From SERVEUR
  Call RTRACE(FICTRQ,ERR,MESSA) From SERVEUR

 Update [ABR]
& Where NUMREQ=[F:ABR2]NUMREQ & [F:ABR]FLAG=[L]PREVFLAG
& With  FLAG = NEWFLAG
&     , USRINT = GUSER
 If fstat
  GOK=0 : Call RSTA("ABR",num$([F:ABR2]NUMREQ)) From GLOCK
  Goto AB_INTERR
 Endif

 ## 1: En attente
 ## 2: En cours
 ## 3: Terminée
 ## 4: Bloquée
 ## 5: A tuer
 ## 6: Avortée
 ## 7: Erreur
 ## 8: Hors délai
 ## 9: Warning

 If [F:ABR]NUMGRP<>0
  # X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
  Call GET_INSTANT_DATE_TIME_DB   ( [L]DD, [L]HH, [L]HS, [L]SS) From SERVEUR

  GRPNUM = [F:ABR]NUMGRP
  Update [ABR]
& Where NUMGRP=[L]GRPNUM & FLAG=4
& With  FLAG = 6
&     , USRINT = GUSER
&     , DFIN   = DD
&     , HFIN   = HS
  If fstat
   GOK=0 : Call RSTA("ABR",num$([F:ABR]NUMREQ)) From GLOCK
   Goto AB_INTERR
  Endif
 Endif

 If [F:ABR2]CODABT<>"" & NEWFLAG<>7 & KILRECURRENT=1 :#117002 test KILRECURRENT
  Update [ABA] Where CODABT=[F:ABR2]CODABT With DREL=2
  If fstat
   GOK=0 : Call RSTA("ABA",[F:ABR2]CODABT) From GLOCK
   Goto AB_INTERR
  Endif
 Endif
Commit
Return

$AB_INTERR
Rollback
Return


$ROLL_INTERR
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_INTERR : Endif


################################################################
# ACTION POSTED BY SYRACUSE : ABATCH_MNGT_ALLREQ - Executed 1 time for Recurring tasks using 1 Application server Runtime of the Batch Server
################################################################
$ABATCH_MNGT_ALLREQ
Gosub INIT_VAR
Gosub AUTO From SERVEUR
Return


################################################################
$READ_PAYLOAD_ERR
Local Instance  PNODE          Using C_ASYRJSO
Local Integer WNUMREQ
Local Char WSEVERITY(50)
Local Clbfile WMESSAGE
Local Char WCHNUMREQ(50)

#1°) Loop on node
PNODE=JSON
While PNODE <> null
 Case toupper(PNODE.PRO)
  When "NUMREQ" : WCHNUMREQ=fmet PNODE.AGETCNT
  When "$SEVERITY" : WSEVERITY=fmet PNODE.AGETCNT
  When "$MESSAGE" : WMESSAGE=fmet PNODE.AGETCNT
 Endcase
 PNODE = PNODE.NEX
Wend
If left$(WCHNUMREQ,1)='"'
 WCHNUMREQ=mid$(WCHNUMREQ,2,len(WCHNUMREQ)-2)
Endif
If left$(WSEVERITY,1)='"'
 WSEVERITY=mid$(WSEVERITY,2,len(WSEVERITY)-2)
Endif
If left$(WMESSAGE,1)='"'
 WMESSAGE=mid$(WMESSAGE,2,len(WMESSAGE)-2)
Endif
WNUMREQ=val(WCHNUMREQ)
If WNUMREQ=0 | WSEVERITY="" | WMESSAGE=""
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(118,134,1))
Elsif WNUMREQ=0
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(122,134,1))
Endif
Return

################################################################
# ACTION POSTED BY SYRACUSE : ABATCH_MNGT_ALLERR - Executed 1 time for 1 Request using 1 Application server Runtime of the Batch Server
################################################################
$ABATCH_MNGT_ALLERR
Gosub READ_PAYLOAD_ERR
If ERROR<>[V]CST_AOK : Return : Endif
Gosub INIT_VAR

Read [ABR2]NUMREQ=WNUMREQ
If fstat
 Return
Endif

Gosub TR_STOP

Read [ABR]NUMREQ=WNUMREQ
If fstat
 Return
Endif
Gosub IDENT_RQT From SERVEUR

# X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
Call SCHEDULING_DATE_TIME   ( [L]DD, [L]HH, [L]HS) From SERVEUR

Call STRACE(FICTRA,10001,[F:ABR]NUMREQ,toupper(WSEVERITY)-':'-WMESSAGE) From SERVEUR
Call RTRACE(FICTRQ,10001,toupper(WSEVERITY)-':'-WMESSAGE) From SERVEUR

Return

