# $ACTION
#
########################################################################################################################
# Modifications :
# -------------
#
# USERxx xx.xx.xxxx nnnnnn    Commentaire
# MDJ    11.08.2015 110217    Issue on space$(15-len(mess(39,7778,1))) ==> result <0
# CBO    12.03.2012 FQ 80246  GFMDAT4 au lieu de DD[/]MM[/]YYYY
# MDJ    09.08.2010 Fq 64312  Détachement du contrat de location lors de la suppression du bien
# MDJ    18.08.2010 Fq 66737  Msg 22 remplacé par le msg 56 (cause trad avec espaces ==> plantage)
# GBO    07.05.2010 Fq 64544  Gestion des écarts entre plans d'amortissement
# GBO    22.03.2010 Fq 63450  Message à tort si dépenses et pas de trace
# GBO    04.03.2010 Fq 63049  Création du traitement à partir de SUBFASCNL
#
########################################################################################################################
 Call OUVRE_TRACE("Test trace suppression") From LECFIC
 If !clalev([M:FC0]) : Local Mask FASCNL0 [FC0] : Endif
 [M:FC0]FLGTRC=G_OUI
 Gosub TRACE_CNL_ET_LOF
 #- FQ-64312  --------------------------
 If ( G_ACTLEA = G_OUI )
    Gosub TRACE_CNL_ET_LEA
 Endif
 Call LEC_TRACE From LECFIC
End

#---------------------------------------
# En-tête générale de la trace
#---------------------------------------
$TRACE_CNL_ET
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 #Fq-66737 :  En ENG  Pb de trad ds ML 7778 (espaces après le mot Company)
 #LIGNE = mess(22,7778,1)+space$(20-len(mess(22,7778,1)))+":"-[M:FC0]CPY
 LIGNE = mess(56,7778,1)+space$(20-len(mess(56,7778,1)))+":"-[M:FC0]CPY
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = mess(24,7778,1)+space$(20-len(mess(24,7778,1)))+":"-[M:FC0]FCY
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = mess(2,3141,1)+space$(20-len(mess(2,3141,1)))+":"-[M:FC0]AASREF
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = mess(1,76,1)+space$(20-len(mess(1,76,1)))+":"-GUSER
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = mess(700,7773,1)+space$(20-len(mess(700,7773,1)))+":"-format$(GFMDAT4,date$)  #"Date de suppression"
 Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#---------------------------------------
# En-tête événements d'annulation de
# dotation - général
#---------------------------------------
$TRACE_CNL_ET_DOT
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 Call ECR_TRACE("",0) From GESECRAN
 LIGNE = toupper(mess(701,7773,1)) : Call ECR_TRACE(LIGNE,0) From GESECRAN            # "EVENEMENT D'ANNULATION GENERES"
 LIGNE = string$(len(mess(701,7773,1)),"=") : Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#@fq54644
#---------------------------------------
# En-tête événements d'annulation
# d'écarts entre plans - général
#---------------------------------------
$TRACE_LNK_ET_DOT
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 Call ECR_TRACE("",0) From GESECRAN
#LIGNE = toupper(mess(701,7773,1)) : Call ECR_TRACE(LIGNE,0) From GESECRAN            # "EVENEMENT D'ANNULATION D'ECARTS ENTRE PLANS GENERES"
#LIGNE = string$(len(mess(701,7773,1)),"=") : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = toupper("EVENEMENT D'ANNULATION D'ECARTS ENTRE PLANS GENERES") : Call ECR_TRACE(LIGNE,0) From GESECRAN            # "EVENEMENT D'ANNULATION D'ECARTS ENTRE PLANS GENERES"
 LIGNE = string$(len("EVENEMENT D'ANNULATION D'ECARTS ENTRE PLANS GENERES"),"=") : Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#---------------------------------------
# En-tête événement d'annulation de
# dotation - Plan d'amortissement
#---------------------------------------
$TRACE_CNL_PLN
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 If dim(FIRSTEVT)>0 : Kill FIRSTEVT : Endif
 If [M:FC1]IDPRPLN(I_EVT-1)<>SPLAN
  If SPLAN
   LIGNE = string$(100,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
   Call ECR_TRACE("",0) From GESECRAN
  Endif
  SPLAN = [M:FC1]IDPRPLN(I_EVT-1)
  Call ECR_TRACE("",0) From GESECRAN
  LIGNE = mess(184,7773,1)-mess([M:FC1]IDPRPLN(I_EVT-1),3101,1)  # "Plan"
  Call ECR_TRACE(LIGNE,0) From GESECRAN
  Call ECR_TRACE(string$(len(LIGNE),"-"),0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
  Gosub TRACE_CNL_ET_EVT From SUBFASCNLTRA
 Endif
Return

#@fq54644
#---------------------------------------
# En-tête événement d'annulation
# d'écarts entre plans - Plan d'amortissement
#---------------------------------------
$TRACE_LNK_PLN
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 If dim(FIRSTEVT)>0 : Kill FIRSTEVT : Endif
 If [M:FC4]IDPRPLN(I_EVT-1)<>SPLAN
  If SPLAN
   LIGNE = string$(100,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
   Call ECR_TRACE("",0) From GESECRAN
  Endif
  SPLAN = [M:FC4]IDPRPLN(I_EVT-1)
  Call ECR_TRACE("",0) From GESECRAN
  LIGNE = mess(184,7773,1)-mess([M:FC1]IDPRPLN(I_EVT-1),3101,1)  # "Plan"
  Call ECR_TRACE(LIGNE,0) From GESECRAN
  Call ECR_TRACE(string$(len(LIGNE),"-"),0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
  Gosub TRACE_CNL_ET_EVT From SUBFASCNLTRA
 Endif
Return
#---------------------------------------
# En-tête : traitement du contrat de LocFI lié
#           liées
#---------------------------------------
$TRACE_CNL_ET_LEA
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 Call ECR_TRACE("",0) From GESECRAN
 LIGNE = toupper(mess(89,7772,1)) : Call ECR_TRACE(LIGNE,0) From GESECRAN  # "DEPENSES REGROUPEES"
 LIGNE = string$(len(mess(89,7772,1)),"=") : Call ECR_TRACE(LIGNE,0) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN
 LIGNE = string$(41,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = space$(1)+left$(mess(4,3141,1)+space$(13),20)+space$(1)+left$(mess(79,7772,1)+space$(3),8)+mess(1,3109,1) : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = string$(41,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
Return
#---------------------------------------
# En-tête : traitement des dépenses
#           liées
#---------------------------------------
$TRACE_CNL_ET_LOF
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 Call ECR_TRACE("",0) From GESECRAN
 LIGNE = toupper(mess(82,7772,1)) : Call ECR_TRACE(LIGNE,0) From GESECRAN  # "DEPENSES REGROUPEES"
 LIGNE = string$(len(mess(82,7772,1)),"=") : Call ECR_TRACE(LIGNE,0) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN
 LIGNE = string$(41,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = space$(1)+left$(mess(1,3141,1)+space$(13),20)+space$(1)+left$(mess(79,7772,1)+space$(3),8)+mess(1,3109,1) : Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = string$(41,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#---------------------------------------
# En-tête événements d'annulation de
# provisions pour renouvellement
# général
#---------------------------------------
$TRACE_CNL_ET_RPR
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 Call ECR_TRACE("",0) From GESECRAN
 LIGNE = toupper("EVENEMENT D'ANNULATION GENERES (PROVISIONS POUR RENOUVELLEMENT)") : Call ECR_TRACE(LIGNE,0) From GESECRAN  # "EVENEMENT D'ANNULATION GENERES"
 LIGNE = string$(len(mess(701,7773,1)),"=") : Call ECR_TRACE(LIGNE,0) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN
 Gosub TRACE_CNL_ET_EVT From SUBFASCNLTRA
Return

#---------------------------------------
# En-tête Annulation du renouvellement
# général
#---------------------------------------
$TRACE_CNL_ET_RNWCAN
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 Call ECR_TRACE("",0) From GESECRAN
 LIGNE = toupper("BIEN RENOUVELANT SUPPRIME : ANNULATION DU RENOUVELLEMENT") : Call ECR_TRACE(LIGNE,0) From GESECRAN  # "BIEN RENOUVELANT SUPPRIME : ANNULATION DU RENOUVELLEMENT"
 LIGNE = string$(len(mess(701,7773,1)),"=") : Call ECR_TRACE(LIGNE,0) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN
Return

#---------------------------------------
# En-tête Annulation de la sortie des
# biens renouvelés
#---------------------------------------
$TRACE_CNL_ET_ISSCAN
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 Call ECR_TRACE("",0) From GESECRAN
 LIGNE = "Annulation de sortie des biens renouvelés"
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = string$(74,"-")
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = space$(1)+"Référence"+space$(12)+"Désignation"
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = string$(74,"-")
 Call ECR_TRACE(LIGNE,0) From GESECRAN
Return
#---------------------------------------
# Pied contrat liés
#---------------------------------------
$TRACE_CNL_PIED_LEA
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 LIGNE = string$(41,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
Return
#---------------------------------------
# Pied dépenses liées
#---------------------------------------
$TRACE_CNL_PIED_LOF
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif #Fq63450
 LIGNE = string$(41,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#---------------------------------------
# Pied Annulation de la sortie des
# biens renouvelés
#---------------------------------------
$TRACE_CNL_PIED_ISSCAN
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif #Fq63450
 LIGNE = string$(74,"-")
 Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#---------------------------------------
# En-tête tableau des événements : commun
# événements d'annulation de dotation
# et événéments d'annulation de
# provision
#---------------------------------------
$TRACE_CNL_ET_EVT
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
  LIGNE = string$(100,"-")                                : Call ECR_TRACE(LIGNE,0) From GESECRAN
  # Issue 110217 - 2015-08-11 by MDJ
#  LIGNE = mess(155,403,1)+space$(15-len(mess(155,7773,1)))+
#&         mess(157,403,1)+space$(15-len(mess(157,7773,1)))+
#&         mess(39,7778,1)+space$(15-len(mess(39,7778,1)))+
#&         mess(159,150,1)+space$(25-len(mess(159,150,1)))
  LIGNE = mess(155,7773,1)+space$(25-len(mess(155,7773,1)))+
&         mess(157,7773,1)+space$(25-len(mess(157,7773,1)))+
&         mess(39,7778,1)+space$(25-len(mess(39,7778,1)))+
&         mess(159,150,1)+space$(25-len(mess(159,150,1)))
  Call ECR_TRACE(LIGNE,0) From GESECRAN
  LIGNE = string$(100,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#---------------------------------------
# Evénement d'annulation de dotation
#---------------------------------------
$TRACE_CNL_DOT_EVT
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 Gosub TRACE_CNL_DEF_VAR
 Gosub TRACE_CNL_DOT_FIL_VAR
 Gosub TRACE_CNL_EVT
Return

#---------------------------------------
# Evénement d'annulation de d'écart
# entre plans
#---------------------------------------
$TRACE_CNL_LNK_EVT
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 Gosub TRACE_CNL_DEF_VAR
 Gosub TRACE_CNL_LNK_FIL_VAR
 Gosub TRACE_CNL_EVT
Return

#---------------------------------------
# Evénement d'annulation de PPR
#---------------------------------------
$TRACE_CNL_RPR_EVT
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 Gosub TRACE_CNL_DEF_VAR
 Gosub TRACE_CNL_RPR_FIL_VAR
 Gosub TRACE_CNL_EVT
Return

#---------------------------------------
# Evénement d'annulation de renouvellement
#---------------------------------------
$TRACE_CNL_RNW_EVT
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 Gosub TRACE_CNL_DEF_VAR
 Gosub TRACE_CNL_RNW_FIL_VAR
 Gosub TRACE_CNL_EVT
Return

#---------------------------------------
# Evénement : définition des variables
#---------------------------------------
$TRACE_CNL_DEF_VAR
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 Local Integer LFIYSTA
 Local Date    LEVTDAT
 Local Date    LCPTDATINT
 Local Char    LTIMSTP
Return

#---------------------------------------
# Evénement d'annulation de dotation :
# alimentation des variables
#---------------------------------------
$TRACE_CNL_DOT_FIL_VAR
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
  LFIYSTA    = [M:FC1]IFIYSTA(I_EVT-1)
  LEVTDAT    = [M:FC1]IEVTDAT(I_EVT-1)
  LCPTDATINT = [M:FC1]ICPTDATINT(I_EVT-1)
  LTIMSTP    = [F:EVT0]TIMSTP
Return

#@fq54644
#---------------------------------------
# Evénement d'annulation de dotation :
# alimentation des variables
#---------------------------------------
$TRACE_CNL_LNK_FIL_VAR
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
  LFIYSTA    = [M:FC4]IFIYSTA(I_EVT-1)
  LEVTDAT    = [M:FC4]IEVTDAT(I_EVT-1)
  LCPTDATINT = [M:FC4]ICPTDATINT(I_EVT-1)
  LTIMSTP    = [F:EVT0]TIMSTP
Return

#---------------------------------------
# Evénement d'annulation de RPR :
# alimentation des variables
#---------------------------------------
$TRACE_CNL_RPR_FIL_VAR
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
  LFIYSTA    = [M:FC2]EFIYSTA(I_EVT-1)
  LEVTDAT    = [M:FC2]EVTDAT(I_EVT-1)
  LCPTDATINT = [M:FC2]CPTDATINT(I_EVT-1)
  LTIMSTP    = [F:EVT0]TIMSTP
Return

#---------------------------------------
# Evénement d'annulation de renouvevllement
# alimentation des variables
#---------------------------------------
$TRACE_CNL_RNW_FIL_VAR
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
  LFIYSTA    = GVML_TECOURA
  LEVTDAT    = [F:EVT]EVTDAT
  LCPTDATINT = [F:EVT]CPTDATINT
  LTIMSTP    = [F:EVT]TIMSTP
Return

#---------------------------------------
# Ligne correspondant à un événement
# dans le tableau des événements
# d'annulation généré (dotation ou
# provisions pour renouvellement)
#---------------------------------------
$TRACE_CNL_EVT
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
# Issue 110217 - 2015-08-11 by MDJ
# LIGNE = mess(LFIYSTA,3102,1)+space$(15-len(mess(LFIYSTA,3102,1)))+
#&        format$("D:" + GFMDAT4,LEVTDAT)+space$(15-len(format$("D:" + GFMDAT4,LEVTDAT)))+
#&        format$("D:" + GFMDAT4,LCPTDATINT)+space$(15-len(format$("D:" + GFMDAT4,LCPTDATINT)))+
#&        LTIMSTP+space$(25-len(LTIMSTP))
 LIGNE = mess(LFIYSTA,3102,1)+space$(25-len(mess(LFIYSTA,3102,1)))+
&        format$("D:" + GFMDAT4,LEVTDAT)+space$(25-len(format$("D:" + GFMDAT4,LEVTDAT)))+
&        format$("D:" + GFMDAT4,LCPTDATINT)+space$(25-len(format$("D:" + GFMDAT4,LCPTDATINT)))+
&        LTIMSTP+space$(25-len(LTIMSTP))
 If CODERR
  LIGNE +=mess(4,7778,1)-"n°"+num$(CODERR)
 Endif
 Call ECR_TRACE(LIGNE,evalue("CODERR>0")) From GESECRAN
Return

#---------------------------------------
# Ligne correspondant à un bien renouvelé
# dont on annule la sortie lors de la
# suppression de son bien renouvelant
#---------------------------------------
$TRACE_CNL_ISSCAN
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 LIGNE = space$(1)+
&        [M:FC2]MOTHAASREF(I_MOTH-1)+space$(1)+
&        [M:FC2]MOTHAASDES(I_MOTH-1)
 Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#---------------------------------------
# Ligne correspondant à un bien renouvelé
# dont on annule la sortie lors de la
# suppression de son bien renouvelant
#---------------------------------------
$TRACE_CNL_RNWPREP
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 #@raf
 If CODERR
  LIGNE +=mess(4,7778,1)-"n°"+num$(CODERR)
 Endif
 Call ECR_TRACE(LIGNE,evalue("CODERR>0")) From GESECRAN
Return

#---------------------------------------
# Ligne dans le tableau des événements
# indiquant qu'aucun événement n'a
# été généré
#---------------------------------------
$TRACE_CNL_NO_EVT
 If [M:FC0]FLGTRC<>G_OUI : Return : Endif
 LIGNE = "AUCUN EVENEMENT D'ANNULATION GENERE"
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE = string$(100,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#---------------------------------------
# Ligne dans le tableau des dépenses
# liées :
# détachement de dépense
#---------------------------------------
$TRACE_LOF_UNLINK
 LIGNE=space$(1)+left$([M:FC3]CODLOF(I_LOF-1)+space$(20),20)+
&      space$(1)+left$(num$([M:FC3]LINLOF(I_LOF-1))+space$(7),7)+
&      space$(1)+mess(80,7772,1)
 Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

#---------------------------------------
# Ligne dans le tableau des dépenses
# liées :
# suppression de dépense
#---------------------------------------
$TRACE_LOF_DELETE
 LIGNE=space$(1)+left$([M:FC3]CODLOF(I_LOF-1)+space$(20),20)+
&      space$(1)+left$(num$([M:FC3]LINLOF(I_LOF-1))+space$(7),7)+
&      space$(1)+mess(81,7772,1)
 Call ECR_TRACE(LIGNE,0) From GESECRAN
Return
#---------------------------------------
# Contrat lié : détachement contrat
#---------------------------------------
$TRACE_LEA_DETA
 LIGNE=space$(1)+left$([M:FC0]LEAREF+space$(20),20)+
&      space$(1)+mess(80,7772,1)
 Call ECR_TRACE(LIGNE,0) From GESECRAN
Return

